@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:AccionProhibidaDisminuirMedidasSeguridad a rdf:type, ex:AccionProhibida ;
    ex:textoExtracto "QUEDA TERMINANTEMENTE PROHIBIDO TRATAR DE DISMINUIR O ELUDIR LAS MEDIDAS DE PROTECCIÓN DE LA MÁQUINA." ;
    rdfs:label "Disminuir o eludir medidas de protección" .

ex:AccionProhibidaRetirarPlacasAdvertencia a rdf:type, ex:AccionProhibida ;
    ex:textoExtracto "EN NINGÚN CASO SE DEBEN RETIRAR LAS PLACAS DE ADVERTENCIA O INSTRUCCIONES DE LA MÁQUINA." ;
    rdfs:label "Retirar placas de advertencia o instrucciones" .

ex:AccionProhibidaModificacionesSeguridad a rdf:type, ex:AccionProhibida ;
    ex:textoExtracto "No se deben emprender modificaciones, montajes o reconversiones de la máquina que afecten a su seguridad sin la aprobación de EKIN, S.Coop." ;
    rdfs:label "Modificaciones, montajes o reconversiones sin aprobación" .

ex:AccionProhibidaEmplearPiezasNoOriginales a rdf:type, ex:AccionProhibida ;
    ex:textoExtracto "Las piezas de recambio deben respetar los requisitos técnicos fijados por EKIN S.Coop. Esto se garantiza siempre empleando las piezas de recambio originales." ;
    rdfs:label "Emplear piezas de recambio no originales" .

ex:AccionProhibidaMantenimientoDesordenado a rdf:type, ex:AccionProhibida ;
    ex:textoExtracto "La zona de trabajo y el interior de la máquina se deben mantener libres de herramientas, materiales auxiliares y cualquier otro objeto." ;
    rdfs:label "Mantenimiento desordenado en la zona de trabajo" .

ex:ManualInstrucciones a rdf:type, ex:Manual ;
    ex:textoExtracto "SE DEBEN OBSERVAR SIEMPRE LAS MEDIDAS DE SEGURIDAD EXPRESADAS EN LOS CARTELES ADOSADOS A LA MÁQUINA Y EN EL MANUAL DE INSTRUCCIONES." ;
    rdfs:label "Manual de Instrucciones" .

ex:AvisoSeguridadCarteles a rdf:type, ex:AvisoSeguridad ;
    ex:textoExtracto "SE DEBEN OBSERVAR SIEMPRE LAS MEDIDAS DE SEGURIDAD EXPRESADAS EN LOS CARTELES ADOSADOS A LA MÁQUINA Y EN EL MANUAL DE INSTRUCCIONES." ;
    rdfs:label "Carteles de seguridad" .

ex:AvisoSeguridadPersonalInstruido a rdf:type, ex:AvisoSeguridad ;
    ex:textoExtracto "El personal que vaya a hacerse cargo y/o vaya a hacer uso de la máquina debe ser previamente instruido en el manejo de la misma, incluyendo los peligros que presenta, las medidas de seguridad que debe adoptar y respetar, así como las prendas de protección que debe utilizar y las acciones que no debe ejecutar." ;
    rdfs:label "Personal instruido" .

ex:AvisoSeguridadVerificarElementos a rdf:type, ex:AvisoSeguridad ;
    ex:textoExtracto "EL ESTADO DE LOS ELEMENTOS DE SEGURIDAD DE LA MÁQUINA SE DEBE VERIFICAR REGULARMENTE PARA GARANTIZAR LA SEGURIDAD DE LA MISMA." ;
    rdfs:label "Verificar elementos de seguridad" .

ex:AvisoSeguridadComunicarAveria a rdf:type, ex:AvisoSeguridad ;
    ex:textoExtracto "En caso de alteraciones que afecten de manera relevante a la seguridad de la máquina o al procedimiento en las operaciones, o si la máquina sufre daños funcionales, ésta se debe detener de inmediato y comunicar la avería a la persona o departamento competentes." ;
    rdfs:label "Comunicar averías" .

ex:AvisoSeguridadRespetarReglamentacion a rdf:type, ex:AvisoSeguridad ;
    ex:textoExtracto "En conjunto con el presente Manual de Instrucciones se deben respetar y tener en cuenta las reglamentaciones obligatorias de carácter general, legal y de otros tipos para la prevención de accidentes y la protección del medio ambiente." ;
    rdfs:label "Respetar reglamentación" .

ex:AvisoSeguridadLimpiezaZonaTrabajo a rdf:type, ex:AvisoSeguridad ;
    ex:textoExtracto "La zona de trabajo y el interior de la máquina se deben mantener libres de herramientas, materiales auxiliares y cualquier otro objeto. Además, se debe asegurar que la zona de trabajo y los alrededores de la máquina están limpios y ordenados." ;
    rdfs:label "Limpieza y orden en la zona de trabajo" .

ex:AvisoSeguridadPiezasRecambio a rdf:type, ex:AvisoSeguridad ;
    ex:textoExtracto "Las piezas de recambio deben respetar los requisitos técnicos fijados por EKIN S.Coop. Esto se garantiza siempre empleando las piezas de recambio originales." ;
    rdfs:label "Piezas de recambio originales" .

ex:AvisoSeguridadPersonalAutorizado a rdf:type, ex:AvisoSeguridad ;
    ex:textoExtracto "El personal que vaya a hacerse cargo y/o vaya a hacer uso de la máquina debe ser previamente instruido en el manejo de la misma." ;
    rdfs:label "Personal autorizado" .

ex:AccionProhibidaDisminuirMedidasSeguridad ex:textoExtracto "QUEDA TERMINANTEMENTE PROHIBIDO TRATAR DE DISMINUIR O ELUDIR LAS MEDIDAS DE PROTECCIÓN DE LA MÁQUINA." ;
    rdfs:label "Disminuir o eludir medidas de protección" .

ex:AccionProhibidaRetirarPlacasAdvertencia ex:textoExtracto "EN NINGÚN CASO SE DEBEN RETIRAR LAS PLACAS DE ADVERTENCIA O INSTRUCCIONES DE LA MÁQUINA." ;
    rdfs:label "Retirar placas de advertencia o instrucciones" .

ex:AccionProhibidaModificacionesSeguridad ex:textoExtracto "No se deben emprender modificaciones, montajes o reconversiones de la máquina que afecten a su seguridad sin la aprobación de EKIN, S.Coop." ;
    rdfs:label "Modificaciones, montajes o reconversiones sin aprobación" .

ex:AccionProhibidaEmplearPiezasNoOriginales ex:textoExtracto "Las piezas de recambio deben respetar los requisitos técnicos fijados por EKIN S.Coop. Esto se garantiza siempre empleando las piezas de recambio originales." ;
    rdfs:label "Emplear piezas de recambio no originales" .

ex:AccionProhibidaMantenimientoDesordenado ex:textoExtracto "La zona de trabajo y el interior de la máquina se deben mantener libres de herramientas, materiales auxiliares y cualquier otro objeto." ;
    rdfs:label "Mantenimiento desordenado en la zona de trabajo" .