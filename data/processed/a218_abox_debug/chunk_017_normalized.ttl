@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:AvisoSeguridadInstruccionesGenerales de a ex:AvisoSeguridad ;
    rdfs:label "Instrucciones generales de seguridad" ;
    ex:textoExtracto "ADVERTENCIA O INSTRUCCIONES DE LA MÁQUINA. LOS ENCLAVAMIENTOS DE SEGURIDAD NO DEBEN ANULARSE." .

ex:AccionProhibidaAnularEnclavamientos de a ex:AccionProhibida ;
    rdfs:label "Anulación de enclavamientos de seguridad" ;
    ex:textoExtracto "LOS ENCLAVAMIENTOS DE SEGURIDAD NO DEBEN ANULARSE." .

ex:AccionProhibidaPonerEnMarchaCarro de a ex:AccionProhibida ;
    rdfs:label "Poner en marcha el carro sin asegurarse de la colocación correcta" ;
    ex:textoExtracto "NO PONER EN MARCHA EL CARRO DE LA MAQUINA SIN ASEGURARSE DE QUE LAS PIEZAS A BROCHAR ESTAN CORRECTAMENTE COLOCADAS EN EL UTIL DE AMARRE." .

ex:AccionProhibidaUsarFluidosPerjudiciales de a ex:AccionProhibida ;
    rdfs:label "Uso de fluidos perjudiciales para la salud" ;
    ex:textoExtracto "NO SE DEBEN EMPLEAR FLUIDOS (ESPECIALMENTE ACEITE DE CORTE Y TALADRINAS) QUE MUESTREN EFECTOS PERJUDICIALES PARA LA SALUD." .

ex:AccionProhibidaManipularPiezasPesadas de a ex:AccionProhibida ;
    rdfs:label "Manipulación manual de piezas pesadas" ;
    ex:textoExtracto "En caso de tener que manipular manualmente piezas de más de 10kg. de peso, deberán emplearse medios de elevación tales como grúas, plumas, etc." .

ex:AccionProhibidaPonerManosObjetosDefensas de a ex:AccionProhibida ;
    rdfs:label "Poner manos u objetos más allá de las defensas" ;
    ex:textoExtracto "NO SE DEBE PONER JAMÁS LAS MANOS U OBJETOS MÁS ALLÁ DE LAS DEFENSAS DURANTE EL FUNCIONAMIENTO DE LA MÁQUINA O CUANDO CUALQUIERA DE SUS ELEMENTOS ESTÉ EN MOVIMIENTO." .

ex:AccionProhibidaMovimientoMaquinaSinLegislacion de a ex:AccionProhibida ;
    rdfs:label "Movimiento de la máquina sin seguir legislación vigente" ;
    ex:textoExtracto "LAS OPERACIONES DE MOVIMIENTO DE LA MÁQUINA POR PARTE DEL USUARIO CON MEDIOS DE ELEVACIÓN, SE DEBEN EFECTUAR SIGUIENDO LA LEGISLACIÓN VIGENTE EN EL PAÍS DE UTILIZACIÓN." .

ex:AvisoSeguridadInstruccionesGenerales ex:mitigaRiesgo ex:AccionProhibidaAnularEnclavamientos ;
    ex:mitigaRiesgo ex:AccionProhibidaPonerEnMarchaCarro ;
    ex:mitigaRiesgo ex:AccionProhibidaUsarFluidosPerjudiciales ;
    ex:mitigaRiesgo ex:AccionProhibidaManipularPiezasPesadas ;
    ex:mitigaRiesgo ex:AccionProhibidaPonerManosObjetosDefensas ;
    ex:mitigaRiesgo ex:AccionProhibidaMovimientoMaquinaSinLegislacion .