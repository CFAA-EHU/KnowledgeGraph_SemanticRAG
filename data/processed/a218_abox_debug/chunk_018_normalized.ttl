@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:MaquinaBrochadoraExterna rdfs:label "Máquina Brochadora Externa" ;
    ex:textoExtracto "LA MÁQUINA A LA CUAL HACE REFERENCIA EL PRESENTE MANUAL HA SIDO CONCEBIDA EXCLUSIVAMENTE PARA EL BROCHADO EXTERIOR, CUYO MECANIZADO TENGA UN ESFUERZO INFERIOR A 70KN Y CARRO PORTABROCHAS DE LONGITUD MENOR A 3000MM." .

ex:ManualInstrucciones rdfs:label "Manual de Instrucciones" ;
    ex:textoExtracto "ES PARTE DEL USO ACORDE CON LAS ESPECIFICACIONES EL CUMPLIMIENTO DE LAS INDICACIONES DEL MANUAL DE INSTRUCCIONES." .

ex:AvisoSeguridadUsoNoAcorde rdfs:label "Aviso de Seguridad para Uso No Acorde" ;
    ex:textoExtracto "TODO USO DIVERGENTE DEL ESPECIFICADO EN LA DOCUMENTACIÓN DE LA MÁQUINA SE CONSIDERA 'NO ACORDE CON LAS ESPECIFICACIONES' Y DE ÉL PUEDE DERIVARSE RIESGO DE LESIONES O MUERTE DE LOS USUARIOS O DE TERCERAS PERSONAS, O DAÑOS A LA MÁQUINA Y A OTROS BIENES." .

ex:AvisoSeguridadConexi_nTierras rdfs:label "Aviso de Seguridad para Conexión a Tierras" ;
    ex:textoExtracto "Antes de efectuar la puesta en marcha de la máquina, ésta debe conectarse al sistema de tierras del usuario y dicho sistema debe cumplir con lo exigido por las leyes nacionales." .

ex:AvisoSeguridadCicloAutom_tico rdfs:label "Aviso de Seguridad para Ciclo Automático" ;
    ex:textoExtracto "En ningún caso se debe poner en marcha el ciclo automático de la máquina sin antes asegurarse de que el útil de amarre está adaptado a las piezas que se van a brochar." .

ex:MaquinaBrochadoraExterna ex:documentadoEn ex:ManualInstrucciones ;
    ex:mitigaRiesgo ex:AvisoSeguridadUsoNoAcorde, ex:AvisoSeguridadConexi_nTierras, ex:AvisoSeguridadCicloAutom_tico .