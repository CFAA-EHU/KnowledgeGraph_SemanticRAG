@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:SistemaPanelesDesmontablesDeMantenimiento a ex:Sistema ;
    rdfs:label "Sistema Paneles Desmontables de Mantenimiento" ;
    ex:textoExtracto "La máquina dispone de seis paneles de este tipo, dos en la parte trasera y dos en cada lateral." .

ex:PanelDesmontableDeMantenimiento1 a ex:Componente ;
    rdfs:label "Panel Desmontable de Mantenimiento" ;
    ex:textoExtracto "La máquina dispone de seis paneles de este tipo, dos en la parte trasera y dos en cada lateral." .

ex:HerramientaCorrespondiente a ex:Herramienta ;
    rdfs:label "Herramienta Correspondiente" ;
    ex:textoExtracto "Los paneles de mantenimiento están atornillados y no pueden abrirse sin las herramientas correspondientes." .

ex:SistemaPuertasControladas a ex:Sistema ;
    rdfs:label "Sistema Puertas Controladas con Interruptor de Seguridad" ;
    ex:textoExtracto "La máquina dispone de tres puertas controladas con un interruptor de seguridad EUCHNER, una en la parte frontal (23SQ1), una en el lateral izquierdo (24SQ1) y una en el lateral derecho (24SQ2)." .

ex:PuertaControladaFrontal a ex:Componente ;
    rdfs:label "Puerta Controlada Frontal" ;
    ex:identificador "23SQ1" ;
    ex:textoExtracto "La máquina dispone de tres puertas controladas con un interruptor de seguridad EUCHNER, una en la parte frontal (23SQ1), una en el lateral izquierdo (24SQ1) y una en el lateral derecho (24SQ2)." .

ex:PuertaControladaIzquierda a ex:Componente ;
    rdfs:label "Puerta Controlada Izquierda" ;
    ex:identificador "24SQ1" ;
    ex:textoExtracto "La máquina dispone de tres puertas controladas con un interruptor de seguridad EUCHNER, una en la parte frontal (23SQ1), una en el lateral izquierdo (24SQ1) y una en el lateral derecho (24SQ2)." .

ex:PuertaControladaDerecha a ex:Componente ;
    rdfs:label "Puerta Controlada Derecha" ;
    ex:identificador "24SQ2" ;
    ex:textoExtracto "La máquina dispone de tres puertas controladas con un interruptor de seguridad EUCHNER, una en la parte frontal (23SQ1), una en el lateral izquierdo (24SQ1) y una en el lateral derecho (24SQ2)." .

ex:InterruptorSeguridadFrontal a ex:Componente ;
    rdfs:label "Interruptor de Seguridad Frontal" ;
    ex:identificador "23SQ1" ;
    ex:textoExtracto "Micro de Puerta seguridad frontal (23SQ1)" .

ex:InterruptorSeguridadIzquierda a ex:Componente ;
    rdfs:label "Interruptor de Seguridad Izquierda" ;
    ex:identificador "24SQ1" ;
    ex:textoExtracto "Micro de Puerta seguridad izquierda (24SQ1)" .

ex:InterruptorSeguridadDerecha a ex:Componente ;
    rdfs:label "Interruptor de Seguridad Derecha" ;
    ex:identificador "24SQ2" ;
    ex:textoExtracto "Micro de Puerta seguridad derecha (24SQ2)" .

ex:SistemaPanelesDesmontablesDeMantenimiento ex:tieneComponente ex:PanelDesmontableDeMantenimiento1 .
ex:SistemaPuertasControladas ex:tieneComponente ex:PuertaControladaFrontal ;
    ex:tieneComponente ex:PuertaControladaIzquierda ;
    ex:tieneComponente ex:PuertaControladaDerecha .

ex:PanelDesmontableDeMantenimiento1 ex:requiereHerramienta ex:HerramientaCorrespondiente .