@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:EPIIndumentariaAjustada a {
  a ex:EPI ;
  rdfs:label "Indumentaria ajustada" ;
  ex:textoExtracto "El personal de mantenimiento debe emplear una indumentaria ajustada para evitar accidentes." .
}

ex:EPIRecogidoCabello a {
  a ex:EPI ;
  rdfs:label "Cabellos recogidos" ;
  ex:textoExtracto "Los cabellos largos deben estar recogidos adecuadamente." .
}

ex:EPICalzadoSeguridad a {
  a ex:EPI ;
  rdfs:label "Calzado de seguridad con puntera reforzada" ;
  ex:textoExtracto "Debe ser calzado de seguridad y con puntera reforzada. De no usarse correctamente pueden producirse aplastamientos de los pies." .
}

ex:EPIGafasSeguridad a {
  a ex:EPI ;
  rdfs:label "Gafas de seguridad" ;
  ex:textoExtracto "EL OPERARIO DEBE EMPLEAR GAFAS DE SEGURIDAD Y GUANTES DURANTE EL TRABAJO CON LA MÁQUINA EN FUNCIONAMIENTO." .
}

ex:EPIGuantes a {
  a ex:EPI ;
  rdfs:label "Guantes adecuados" ;
  ex:textoExtracto "Deben ser adecuados para cada tipo de trabajo, tales como:" .
}

ex:EPIAuriculares a {
  a ex:EPI ;
  rdfs:label "Auriculares o tapones" ;
  ex:textoExtracto "Para los trabajos con ruidos superiores a los 78 dB. Se pueden utilizar tapones en lugar de los auriculares." .
}

ex:EPICascoSeguridad a {
  a ex:EPI ;
  rdfs:label "Casco de seguridad" ;
  ex:textoExtracto "Para trabajos en los que exista peligro de daños en la cabeza, en especial en trabajos de montaje o desmontaje y transporte de elementos de la máquina." .
}

ex:AvisoSeguridadIndumentaria a {
  a ex:AvisoSeguridad ;
  rdfs:label "Aviso sobre indumentaria" ;
  ex:textoExtracto "El personal de mantenimiento debe emplear una indumentaria ajustada para evitar accidentes. En particular, no debe emplear corbatas, anillos o cadena, que podrían quedar atrapados en partes móviles de la máquina." .
}

ex:AvisoSeguridadGafas a {
  a ex:AvisoSeguridad ;
  rdfs:label "Aviso sobre gafas" ;
  ex:textoExtracto "Para todo tipo de trabajo con herramienta en el que exista proyección de partículas. Para todos los trabajos de soldadura, usar pantalla protectora, mandil y guantes adecuados." .
}

ex:AvisoSeguridadCalzado a {
  a ex:AvisoSeguridad ;
  rdfs:label "Aviso sobre calzado" ;
  ex:textoExtracto "Debe ser calzado de seguridad y con puntera reforzada. De no usarse correctamente pueden producirse aplastamientos de los pies." .
}

ex:AvisoSeguridadGuantes a {
  a ex:AvisoSeguridad ;
  rdfs:label "Aviso sobre guantes" ;
  ex:textoExtracto "Deben ser adecuados para cada tipo de trabajo, tales como:" .
}

ex:AvisoSeguridadAuriculares a {
  a ex:AvisoSeguridad ;
  rdfs:label "Aviso sobre auriculares o tapones" ;
  ex:textoExtracto "Para los trabajos con ruidos superiores a los 78 dB. Se pueden utilizar tapones en lugar de los auriculares." .
}

ex:AvisoSeguridadCasco a {
  a ex:AvisoSeguridad ;
  rdfs:label "Aviso sobre casco de seguridad" ;
  ex:textoExtracto "Para trabajos en los que exista peligro de daños en la cabeza, en especial en trabajos de montaje o desmontaje y transporte de elementos de la máquina." .
}