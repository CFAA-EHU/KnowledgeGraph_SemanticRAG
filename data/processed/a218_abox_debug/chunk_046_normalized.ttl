@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:SistemaColumnaGuiaLineal a ex:Sistema ;
    rdfs:label "Sistema Columna Guía Lineal" ;
    ex:textoExtracto "sobre el zócalo se monta la columna con dos guías lineales por las que se desplaza el carro porta-piezas, siendo el recorrido máximo de 3000 mm." .

ex:CarroPortaPiezas a ex:ComponenteMecanico ;
    rdfs:label "Carro Porta-Piezas" ;
    ex:textoExtracto "el carro porta-piezas, siendo el recorrido máximo de 3000 mm. La posición del carro se controla a través de dos reglas lineales colocadas en el lateral de la columna." .

ex:ReglaLineal1 a ex:ComponenteMecanico ;
    rdfs:label "Regla Lineal" ;
    ex:textoExtracto "La posición del carro se controla a través de dos reglas lineales colocadas en el lateral de la columna." .

ex:ReglaLineal2 a ex:ComponenteMecanico, ex:ReglaLineal1 ;
    rdfs:label "Regla Lineal" ;
    ex:textoExtracto "La posición del carro se controla a través de dos reglas lineales colocadas en el lateral de la columna." .

ex:Cremallera a ex:ComponenteMecanico ;
    rdfs:label "Cremallera WITTENSTEIN" ;
    ex:textoExtracto "Dispone de juegos de sistemas piñón/cremallera (WITTENSTEIN) accionados por dos servomotores colocados sobre el carro porta-piezas que provocan su movimiento." .

ex:Pi_on a ex:ComponenteMecanico ;
    rdfs:label "Piñón" ;
    ex:textoExtracto "Dispone de juegos de sistemas piñón/cremallera (WITTENSTEIN) accionados por dos servomotores colocados sobre el carro porta-piezas que provocan su movimiento." .

ex:Servomotor1 a ex:ComponenteElectrico ;
    rdfs:label "Servomotor" ;
    ex:textoExtracto "accionados por dos servomotores colocados sobre el carro porta-piezas que provocan su movimiento." .

ex:Servomotor2 a ex:ComponenteElectrico, ex:Servomotor1 ;
    rdfs:label "Servomotor" ;
    ex:textoExtracto "accionados por dos servomotores colocados sobre el carro porta-piezas que provocan su movimiento." .

ex:SistemaColumnaGuiaLineal ex:tieneComponente ex:CarroPortaPiezas, ex:ReglaLineal1, ex:Cremallera, ex:Pi_on, ex:Servomotor1 ;
    ex:textoExtracto "sobre el zócalo se monta la columna con dos guías lineales por las que se desplaza el carro porta-piezas, siendo el recorrido máximo de 3000 mm." .

ex:ParametroVelocidad a ex:Parametro ;
    rdfs:label "Velocidad Máxima" ;
    ex:textoExtracto "El movimiento se realiza a una velocidad máxima de 40 m/min de avance y 40 m/min de retroceso." ;
    ex:valor "40 m/min" .

ex:SistemaColumnaGuiaLineal ex:monitoreaParametro ex:ParametroVelocidad .