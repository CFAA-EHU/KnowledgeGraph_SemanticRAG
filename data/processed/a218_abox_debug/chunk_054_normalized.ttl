@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:SistemaNeumaticoMquina rdfs:label "Sistema Neumático" ;
    ex:textoExtracto "El sistema neumático está situado en la parte posterior de la máquina. Está compuesto por una válvula neumática de mando manual, un filtro regulador de presión, un secador de aire, manómetros, un lubricador, presostatos, reguladores de presión, electroválvulas, silenciadores, etc." ;
    ex:compuestoPor ex:ComponenteElectricoValvulaNeumaticaManual ,
                     ex:ComponenteHidraulicoFiltroReguladorPresion ,
                     ex:ComponenteHidraulicoSecadorAire ,
                     ex:SensorManometro ,
                     ex:ComponenteHidraulicoLubricador ,
                     ex:SensorPresostato ,
                     ex:ComponenteElectricoReguladorPresion ,
                     ex:ComponenteElectricoElectrovavula ,
                     ex:ComponenteElectricoSilenciador .

ex:ComponenteElectricoValvulaNeumaticaManual rdfs:label "Válvula Neumática de Mando Manual" ;
    ex:textoExtracto "una válvula neumática de mando manual" .

ex:ComponenteHidraulicoFiltroReguladorPresion rdfs:label "Filtro Regulador de Presión" ;
    ex:textoExtracto "un filtro regulador de presión" .

ex:ComponenteHidraulicoSecadorAire rdfs:label "Secador de Aire" ;
    ex:textoExtracto "un secador de aire" .

ex:SensorManometro rdfs:label "Manómetro" ;
    ex:textoExtracto "manómetros" .

ex:ComponenteHidraulicoLubricador rdfs:label "Lubricador" ;
    ex:textoExtracto "un lubricador" .

ex:SensorPresostato rdfs:label "Presostato" ;
    ex:textoExtracto "presostatos" .

ex:ComponenteElectricoReguladorPresion rdfs:label "Regulador de Presión" ;
    ex:textoExtracto "reguladores de presión" .

ex:ComponenteElectricoElectrovavula rdfs:label "ELECTROVÁLVULA" ;
    ex:textoExtracto "electroválvulas" .

ex:ComponenteElectricoSilenciador rdfs:label "Silenciador" ;
    ex:textoExtracto "silenciadores" .

ex:ParametroYP801 rdfs:label "Entrada General de Aire" ;
    ex:identificador "YP801" ;
    ex:textoExtracto "- YP801: ENTRADA GENERAL DE AIRE" .

ex:ParametroYP901 rdfs:label "Avanzar Cepillo" ;
    ex:identificador "YP901" ;
    ex:textoExtracto "- YP901: AVANZAR CEPILLO" .

ex:ParametroYP902 rdfs:label "Retroceder Cepillo" ;
    ex:identificador "YP902" ;
    ex:textoExtracto "- YP902: RETROCEDER CEPILLO" .

ex:ParametroYP903 rdfs:label "Refrigerante Limpieza Bastidor" ;
    ex:identificador "YP903" ;
    ex:textoExtracto "- YP903: REFRIGERANTE LIMPIEZA BASTIDOR" .

ex:ParametroBP710 rdfs:label "Presión General de Aire" ;
    ex:identificador "BP710" ;
    ex:textoExtracto "- BP710: PRESIÓN GENERAL DE AIRE" .

ex:ParametroBP711 rdfs:label "Presión Aire Reglas Lineales YP901 – YP902 YP903 YP801 BP711 BP710" ;
    ex:identificador "BP711" ;
    ex:textoExtracto "- BP711: PRESIÓN AIRE REGLAS LINEALES YP901 – YP902 YP903 YP801 BP711 BP710" .

ex:SistemaNeumaticoMquina ex:tieneComponente ex:ParametroYP801 ,
                            ex:ParametroYP901 ,
                            ex:ParametroYP902 ,
                            ex:ParametroYP903 ,
                            ex:ParametroBP710 ,
                            ex:ParametroBP711 .