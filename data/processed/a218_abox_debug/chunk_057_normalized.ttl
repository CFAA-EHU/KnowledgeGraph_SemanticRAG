@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:SistemaRefrigeracionMaquina rdfs:label "Sistema de refrigeración" ;
    ex:textoExtracto "La máquina dispone de un sistema de refrigeración que tiene como objetico principal el evitar el calentamiento excesivo de la herramienta y de la pieza durante el brochado, además de evitar que se queden virutas en lugares indeseados." .

ex:ComponenteElectricoMotorRefrigeranteFiltroPapel a ex:ComponenteElectrico ;
    rdfs:label "MOTOR REFRIGERANTE DE FILTRO PAPEL" ;
    ex:identificador "M1" ;
    ex:textoExtracto "- M1: MOTOR REFRIGERANTE DE FILTRO PAPEL" .

ex:ComponenteElectricoMotorRefrigeranteMaquina a ex:ComponenteElectrico ;
    rdfs:label "MOTOR REFRIGERANTE MÁQUINA" ;
    ex:identificador "M3" ;
    ex:textoExtracto "- M3: MOTOR REFRIGERANTE MÁQUINA" .

ex:ComponenteElectricoMotorTrasvaseRefrigerante a ex:ComponenteElectrico ;
    rdfs:label "MOTOR TRASVASE REFRIGERANTE" ;
    ex:identificador "M4" ;
    ex:textoExtracto "- M4: MOTOR TRASVASE REFRIGERANTE" .

ex:ComponenteElectricoMotorExtractorVirutas a ex:ComponenteElectrico ;
    rdfs:label "MOTOR EXTRACTOR DE VIRUTAS" ;
    ex:identificador "M5" ;
    ex:textoExtracto "- M5: MOTOR EXTRACTOR DE VIRUTAS" .

ex:ParametroNivelRefrigeranteSucio a ex:Parametro ;
    rdfs:label "NIVEL REFRIGERANTE SUCIO" ;
    ex:identificador "BN41" ;
    ex:textoExtracto "- BN41: NIVEL REFRIGERANTE SUCIO" .

ex:ParametroPresenciaPapel a ex:Parametro ;
    rdfs:label "PRESENCIA DE PAPEL" ;
    ex:identificador "SQ40" ;
    ex:textoExtracto "- SQ40: PRESENCIA DE PAPEL" .

ex:ParametroNivelRefrigerante a ex:Parametro ;
    rdfs:label "NIVEL REFRIGERANTE" ;
    ex:identificador "BN42" ;
    ex:textoExtracto "- BN42: NIVEL REFRIGERANTE" .

ex:ParametroCaudalRefrigerante a ex:Parametro ;
    rdfs:label "CAUDAL REFRIGERANTE" ;
    ex:identificador "BC44" ;
    ex:textoExtracto "- BC44: CAUDAL REFRIGERANTE" .

ex:SistemaRefrigeracionMaquina ex:tieneComponente ex:ComponenteElectricoMotorRefrigeranteFiltroPapel, ex:ComponenteElectricoMotorRefrigeranteMaquina, ex:ComponenteElectricoMotorTrasvaseRefrigerante, ex:ComponenteElectricoMotorExtractorVirutas ;
    ex:monitoreaParametro ex:ParametroNivelRefrigeranteSucio, ex:ParametroPresenciaPapel, ex:ParametroNivelRefrigerante, ex:ParametroCaudalRefrigerante .