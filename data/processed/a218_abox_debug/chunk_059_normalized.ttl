@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:AccionProhibidaUsoCarretillasElevadorasAparatosTransporte a rdf:type, ex:AccionProhibida ;
    ex:textoExtracto "QUEDA PROHIBIDO EL USO DE CARRETILLAS ELEVADORAS O SIMILARES A TAL EFECTO." ;
    rdfs:label "Uso de carretillas elevadoras o similares para transporte"@es .

ex:AvisoSeguridadEslingasHomologadas a rdf:type, ex:AvisoSeguridad ;
    ex:textoExtracto "ES IMPERATIVO ADEMÁS UTILIZAR ESLINGAS HOMOLOGADAS CON DECLARACIÓN 'CE' DE CONFORMIDAD, PARA EVITAR SITUACIONES DE RIESGO POR POSIBLES ROTURAS DE ESLINGAS DEFECTUOSAS." ;
    rdfs:label "Utilización de eslingas homologadas"@es .

ex:AvisoSeguridadNoPermanecerBajoCargas a rdf:type, ex:AvisoSeguridad ;
    ex:textoExtracto "EN LOS PROCESOS DE ELEVACIÓN DE COMPONENTES MEDIANTE GRÚAS NO SE DEBE PERMANECER DEBAJO DE CARGAS SUSPENDIDAS." ;
    rdfs:label "No permanecer bajo cargas suspendidas"@es .

ex:AvisoSeguridadDimensionesPeso a rdf:type, ex:AvisoSeguridad ;
    ex:textoExtracto "SE DEBEN TENER EN CUENTA LAS DIMENSIONES Y EL PESO DE LA MÁQUINA Y DEL ESPACIO DISPONIBLE, ANTES DE TRANSPORTARLA." ;
    rdfs:label "Considerar dimensiones y peso antes del transporte"@es .

ex:AvisoSeguridadEslingasLibresDefensas a rdf:type, ex:AvisoSeguridad ;
    ex:textoExtracto "LA LONGITUD DE LAS ESLINGAS DEBE SER TAL QUE LIBREN CON HOLGURA LAS DEFENSAS INSTALADAS EN LA MÁQUINA, CON EL FIN DE EVITAR ABOLLADURAS O ROCES." ;
    rdfs:label "Longitud de eslingas para evitar roces"@es .

ex:AvisoSeguridadAparatosElevadores a rdf:type, ex:AvisoSeguridad ;
    ex:textoExtracto "SÓLO SE DEBEN EMPLEAR APARATOS ELEVADORES APROPIADOS Y TÉCNICAMENTE IMPECABLES, CON CARGA NOMINAL SUFICIENTE." ;
    rdfs:label "Uso de aparatos elevadores adecuados"@es .

ex:AvisoSeguridadCadenasGanchos a rdf:type, ex:AvisoSeguridad ;
    ex:textoExtracto "LAS CADENAS, CUERDAS, GANCHOS Y OJALES DEBEN SER ASIMISMO ADECUADOS PARA LOS PESOS INDICADOS." ;
    rdfs:label "Cadenas, cuerdas, ganchos y ojales adecuados"@es .

ex:AvisoSeguridadGarantizarSeguridad a rdf:type, ex:AvisoSeguridad ;
    ex:textoExtracto "SIEMPRE QUE SEA NECESARIO EMPLEAR GRÚAS O APARATOS ELEVADORES, SE DEBE GARANTIZAR QUE NO SE DERIVA NINGÚN PELIGRO DE ESTOS PROCESOS." ;
    rdfs:label "Garantizar seguridad en procesos con grúas"@es .

ex:AvisoSeguridadSuspensionTransporte a rdf:type, ex:AvisoSeguridad ;
    ex:textoExtracto "LAS MÁQUINAS HAN SIDO DISEÑADAS PARA SER TRANSPORTADAS MEDIANTE SUSPENSIÓN" ;
    rdfs:label "Máquinas diseñadas para transporte por suspensión"@es .

ex:AvisoSeguridadCamaras a rdf:type, ex:AvisoSeguridad ;
    ex:textoExtracto "La máquina dispone de cuatro cámaras, dos en la parte superior de la columna y dos en la parte frontal, para poder manipularla por medio de una grúa o similar." ;
    rdfs:label "Cámaras para manipulación"@es .