@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MaquinaConElementosMando a ex:Maquina ;
    ex:textoExtracto "La máquina está compuesta por los siguientes elementos de mando:" ;
    ex:tieneComponente ex:PulsadorParadaEmergencia, ex:PulsadorSimple, ex:PulsadorLuminoso, ex:Selector, ex:PanelOperadorPC21 ;

ex:PulsadorParadaEmergencia a ex:ComponenteElectrico ;
    rdfs:label "Pulsadores de parada de emergencia" ;
    ex:textoExtracto "Pulsadores de parada de emergencia" .

ex:PulsadorSimple a ex:ComponenteElectrico ;
    rdfs:label "Pulsadores simples" ;
    ex:textoExtracto "Pulsadores simples" .

ex:PulsadorLuminoso a ex:ComponenteElectrico ;
    rdfs:label "Pulsadores luminosos" ;
    ex:textoExtracto "Pulsadores luminosos" .

ex:Selector a ex:ComponenteElectrico ;
    rdfs:label "Selectores" ;
    ex:textoExtracto "Selectors" .

ex:PanelOperadorPC21 a ex:InterfazUsuario ;
    rdfs:label "Panel operador PC-21' Panorámico 16Gb" ;
    ex:textoExtracto "Panel operador PC-21\" Panorámico 16Gb" .