@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:InterfazUsuarioPanelOperador rdfs:label "Panel operador" ;
    ex:textoExtracto "Pantalla principal o Movimientos manuales o Movimientos máquina" .

ex:TareaMantenimientoArranqueMotores rdfs:label "Arranque motores" ;
    ex:textoExtracto "Arranque motores" .

ex:TareaMantenimientoCambioBrocha rdfs:label "Ciclo cambio de brocha" ;
    ex:textoExtracto "Ciclo cambio de brocha" .

ex:TareaMantenimientoInspeccion rdfs:label "Inspección" ;
    ex:textoExtracto "Inspección" .

ex:SistemaCondicionesMaquina rdfs:label "Condiciones máquina" ;
    ex:textoExtracto "Condiciones máquina" .

ex:CicloAnillaDesbaste rdfs:label "Ciclo anilla desbaste" ;
    ex:textoExtracto "Ciclo anilla desbaste" .

ex:CicloAnillaAcabado rdfs:label "Ciclo anilla acabado" ;
    ex:textoExtracto "Ciclo anilla acabado" .

ex:CicloPlanaDesbaste rdfs:label "Ciclo plana desbaste" ;
    ex:textoExtracto "Ciclo plana desbaste" .

ex:CicloPlanaAcabado rdfs:label "Ciclo plana acabado" ;
    ex:textoExtracto "Ciclo plana acabado" .

ex:InterfazUsuarioPanelOperador ex:documentadoEn ex:TareaMantenimientoArranqueMotores ,
    ex:TareaMantenimientoCambioBrocha , ex:SistemaCondicionesMaquina ,
    ex:CicloAnillaDesbaste , ex:CicloAnillaAcabado , ex:CicloPlanaDesbaste ,
    ex:CicloPlanaAcabado , ex:TareaMantenimientoInspeccion .