@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:ModoOperacionManual642 rdfs:label "modo manual" ;
    ex:textoExtracto "Para seleccionar el modo de trabajo manual: Con máquina en servicio y presión general de aire OK. Puertas con enclavamiento de seguridad cerradas y bloqueadas. Seleccionar el modo manual." .

ex:TareaMantenimientoCambioDeHerramienta rdfs:label "cambio de herramienta" ;
    ex:textoExtracto "A partir de este momento se pueden realizar todos los movimientos manuales de la máquina y el cambio de herramienta." .

ex:MaquinaBrochadora rdfs:label "máquina" ;
    ex:textoExtracto "Con máquina en servicio y presión general de aire OK." ;
    ex:tieneComponente ex:SistemaSeguridadPuertas .

ex:SistemaSeguridadPuertas rdfs:label "sistema de seguridad puertas" ;
    ex:textoExtracto "Puertas con enclavamiento de seguridad cerradas y bloqueadas." .