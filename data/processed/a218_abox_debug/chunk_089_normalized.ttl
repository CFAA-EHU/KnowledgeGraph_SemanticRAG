@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoOperacion_Manual_89 a ex:ModoOperacion ;
    rdfs:label "modo manual" ;
    ex:textoExtracto "Para seleccionar el modo de trabajo manual: Con máquina en servicio y presión general de aire OK.  Puertas con enclavamiento de seguridad cerradas y bloqueadas.  Seleccionar el modo manual.  A partir de este momento se pueden realizar todos los movimientos manuales de la máquina y el cambio de herramienta." .

ex:Maquina_89 a ex:Maquina ;
    rdfs:label "máquina" ;
    ex:textoExtracto "Con máquina en servicio y presión general de aire OK.  ... se pueden realizar todos los movimientos manuales de la máquina y el cambio de herramienta." .

ex:Herramienta_89 a ex:Herramienta ;
    rdfs:label "herramienta" ;
    ex:textoExtracto "el cambio de herramienta" .