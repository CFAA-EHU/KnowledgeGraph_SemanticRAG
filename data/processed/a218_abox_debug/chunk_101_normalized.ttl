@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:TareaMantenimientoApretarTornillos
    a ex:TareaMantenimiento ;
    rdfs:label "Comprobación de apriete" ;
    ex:textoExtracto "Comprobar si se han soltado los tornillos, tuercas, etc. En el caso de que así fuera, apretarlos."@es .

ex:ComponenteMecanicoTornillo
    a ex:ComponenteMecanico ;
    rdfs:label "tornillo" ;
    ex:textoExtracto "Comprobar si se han soltado los tornillos, tuercas, etc."@es .

ex:TareaMantenimientoApretarTornillos ex:requiereMantenimiento ex:ComponenteMecanicoTornillo .