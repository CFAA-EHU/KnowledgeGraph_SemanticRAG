@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TareaMantenimientoEngrasePatinesCarroPortaPiezas a ex:TareaMantenimiento ;
    rdfs:label "Engrase de patines del carro porta-piezas" ;
    ex:textoExtracto "Proceder a lubricar adecuadamente los patines del carro porta-piezas y de los contrapesos." .

ex:ComponentePatinesCarroPortaPiezas a ex:ComponenteMecanico ;
    rdfs:label "Patines del carro porta-piezas" ;
    ex:textoExtracto "Proceder a lubricar adecuadamente los patines del carro porta-piezas y de los contrapesos." .

ex:TareaMantenimientoEngrasePatinesCarroPortaPiezas ex:requiereConsumible ex:AceiteLubricante ;
    ex:textoExtracto "Proceder a lubricar adecuadamente los patines del carro porta-piezas y de los contrapesos." .

ex:AceiteLubricante a ex:Consumible ;
    rdfs:label "Aceite Lubricante" ;
    ex:textoExtracto "Proceder a lubricar adecuadamente los patines del carro porta-piezas y de los contrapesos." .