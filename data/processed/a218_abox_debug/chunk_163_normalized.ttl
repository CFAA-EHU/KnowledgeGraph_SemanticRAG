@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ComponenteHidraulicoBloqueoHydraulic ex:rdfs label "Bloqueos Hidráulicos" ;
    ex:textoExtracto "Se destacan patines y bloqueos hidráulicos;" .

ex:HerramientaLuminariaVertical ex:rdfs label "Luminaria Vertical" ;
    ex:textoExtracto "Vista exterior con llamadas a tres recuadros de detalle: dos luminarias verticales enfocando al plato divisor" ;
    ex:activaAlarma ex:AvisoSeguridadVisibilidadZonaTrabajo .

ex:AvisoSeguridadVisibilidadZonaTrabajo ex:rdfs label "Aviso de Visibilidad en Zona de Trabajo" ;
    ex:textoExtracto "menciona protección IP67 y función de visibilidad en zona de trabajo." .

