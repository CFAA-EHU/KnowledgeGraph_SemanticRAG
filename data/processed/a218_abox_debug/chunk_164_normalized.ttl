@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:ComponenteMecanicoPlatoDivisor a ex:ComponenteMecanico ;
    rdfs:label "Plato divisor" ;
    ex:textoExtracto "Perspectiva del plato con dentado Hirth, servomotor y torreta de micros (SQ46/SQ47)." .

ex:SistemaHidraulicoDesbloqueo a ex:SistemaHidraulico ;
    rdfs:label "Sistema hidráulico de desbloqueo" ;
    ex:textoExtracto "flechas sugieren el giro tras el desbloqueo hidráulico." .

ex:TareaMantenimientoCambioBase a ex:TareaMantenimiento ;
    rdfs:label "Cambio de base (0º–15º / 15º–0º)" ;
    ex:textoExtracto "Procedimiento cambio de base (0º–15º / 15º–0º)." .

ex:ComponenteElectricoServomotor a ex:ComponenteElectrico ;
    rdfs:label "Servomotor" ;
    ex:textoExtracto "Perspectiva del plato con dentado Hirth, servomotor y torreta de micros (SQ46/SQ47)." .

ex:TablaCambioBase a ex:Tabla ;
    rdfs:label "Tablas de cambio de base" ;
    ex:textoExtracto "Dos vistas comparativas con rótulos Base 0º y Base 15º." .

ex:SistemaHidraulicoTuberias a ex:SistemaHidraulico ;
    rdfs:label "Sistema hidráulico de tuberías" ;
    ex:textoExtracto "fotografías de detalle con recuadros y flechas hacia cables del motor, cable torreta de micros, tubos hidráulicos y tubo neumático a desconectar." .

ex:ComponenteMecanicoTornillosFijacion a ex:ComponenteMecanico ;
    rdfs:label "Tornillos de fijación" ;
    ex:textoExtracto "Vista superior del disco con agujeros roscados M12 para cáncamos y llamadas a tornillos de fijación y tornillos de ajuste." .

ex:SistemaNeumaticoTubo a ex:Sistema ;
    rdfs:label "Sistema neumático de tubo" ;
    ex:textoExtracto "fotografías de detalle con recuadros y flechas hacia cables del motor, cable torreta de micros, tubos hidráulicos y tubo neumático a desconectar." .

ex:SistemaHidraulicoTuberias ex:documentadoEn ex:TablaCambioBase .
ex:TareaMantenimientoCambioBase ex:textoExtracto "Procedimiento cambio de base (0º–15º / 15º–0º)." ;
    ex:requiereConsumible ex:AceiteHidraulicoISO46 .

ex:SistemaHidraulicoDesbloqueo ex:documentadoEn ex:TablaCambioBase .