@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CapituloGeneralInformacion a ns1:Capitulo ;
    rdfs:label "Información General" ;
    ns1:textoExtracto "El manual consta de 10 capítulos en los cuales el lector encontrará información general de la máquina, así como la descripción y funcionamiento de cada componente." .

ns1:CapituloMantenimientoPreventivo a ns1:Capitulo ;
    rdfs:label "Mantenimiento Preventivo" ;
    ns1:textoExtracto "También incluye un capítulo de mantenimiento preventivo y una lista de repuestos con sus correspondientes proveedores." .

ns1:CapituloSeguridad a ns1:Capitulo ;
    rdfs:label "Seguridad" ;
    ns1:textoExtracto "En el capítulo de seguridad se han contemplado tanto la seguridad del operario como de la propia máquina y de los materiales desechables empleados." .

ns1:ManualIntroduccionBrochadoraA218 a ns1:DocumentoTecnico ;
    rdfs:label "INTRODUCCIÓN" ;
    ns1:textoExtracto "El objeto de este manual es facilitar el uso, manejo y conservación correctos de la máquina al personal que vaya a trabajar con la misma." .

ns1:MaquinaBrochadoraA218 a ns1:Maquina ;
    rdfs:label "Máquina Brochadora" ;
    ns1:textoExtracto "El objeto de este manual es facilitar el uso, manejo y conservación correctos de la máquina al personal que vaya a trabajar con la misma." .

