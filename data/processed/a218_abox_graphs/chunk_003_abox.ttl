@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Aviso_Instalacion_3 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de instalación"@es ;
    ns1:textoExtracto "LEER ATENTAMENTE LAS INSTRUCCIONES DE ESTE MANUAL ANTES DE INSTALAR Y UTILIZAR EL EQUIPO."@es .

ns1:Capitulo_Mantenimiento_3 a ns1:Capitulo ;
    rdfs:label "Capítulo de mantenimiento preventivo"@es ;
    ns1:textoExtracto "incluye un capítulo de mantenimiento preventivo"@es .

ns1:Capitulo_Seguridad_3 a ns1:Capitulo ;
    rdfs:label "Capítulo de seguridad"@es ;
    ns1:textoExtracto "En el capítulo de seguridad se han contemplado tanto la seguridad del operario como de la propia máquina y de los materiales desechables empleados."@es .

ns1:Esquema_Manual_3 a ns1:Esquema ;
    rdfs:label "Esquemas del manual"@es ;
    ns1:textoExtracto "El manual incluye los planos y esquemas necesarios para poner en servicio, conservar, inspeccionar, comprobar el buen funcionamiento y, si fuera necesario, reparar la máquina"@es .

ns1:Manual_Introduccion_3 a ns1:Manual ;
    rdfs:label "Manual de introducción"@es ;
    ns1:textoExtracto "El objeto de este manual es facilitar el uso, manejo y conservación correctos de la máquina al personal que vaya a trabajar con la misma. El manual consta de 10 capítulos en los cuales el lector encontrará información general de la máquina, así como la descripción y funcionamiento de cada componente. También incluye un capítulo de mantenimiento preventivo y una lista de repuestos con sus correspondientes proveedores. En el capítulo de seguridad se han contemplado tanto la seguridad del operario como de la propia máquina y de los materiales desechables empleados. El manual incluye los planos y esquemas necesarios para poner en servicio, conservar, inspeccionar, comprobar el buen funcionamiento y, si fuera necesario, reparar la máquina y cualquier otra instrucción pertinente, en particular, en materia de seguridad."@es .

ns1:Maquina_Referenciada_3 a ns1:Maquina ;
    rdfs:label "Máquina referenciada en el manual"@es ;
    ns1:textoExtracto "facilitar el uso, manejo y conservación correctos de la máquina"@es .

