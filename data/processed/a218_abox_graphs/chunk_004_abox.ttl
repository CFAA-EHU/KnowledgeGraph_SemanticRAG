ns1:Figura0_1_1 a ns1:Figura ;
    rdfs:label "Información mostrada en páginas" ;
    ns1:textoExtracto "Nombre del Fabricante de capítulo la máquina Nombre de Capitulo Nº la máquina Modelo de la máquina Contenido Página/Capítulo Nombre del fichero Figura 0-1-1. Información mostrada en páginas." .

ns1:NombreDelCapitulo a ns1:Capitulo ;
    rdfs:label "Nombre del Capítulo" ;
    ns1:textoExtracto "Nombre de Capitulo Nº la máquina Modelo de la máquina Contenido Página/Capítulo Nombre del fichero Figura 0-1-1. Información mostrada en páginas." .

ns1:MaquinaBrochadoraA218 a ns1:Maquina ;
