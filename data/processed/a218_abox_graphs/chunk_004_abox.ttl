@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DocumentoTecnicoManualBrochadoraA218 a ns1:DocumentoTecnico ;
    rdfs:label "Manual de mantenimiento de la Brochadora A218 / RASHEM - 7x3000x500" ;
