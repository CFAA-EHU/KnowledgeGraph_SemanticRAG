@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InstruccionesDeSeguridad_64d5dc3c25 a ns1:AvisoSeguridad ;
    rdfs:label "Instrucciones de Seguridad" ;
    ns1:mitigaRiesgo ns1:MaquinaPrincipal ;
    ns1:textoExtracto "Todas las máquinas EKIN, S. Coop. han sido fabricadas siguiendo todas las normas de seguridad en diseño, fabricación y montaje para evitar accidentes durante su funcionamiento; no obstante, se debe tener precaución y considerar ciertas instrucciones de seguridad." .

ns1:MaquinaPrincipal a ns1:Maquina ;
    rdfs:label "Máquina EKIN" ;
    ns1:textoExtracto "Todas las máquinas EKIN, S. Coop. han sido fabricadas siguiendo todas las normas de seguridad en diseño, fabricación y montaje para evitar accidentes durante su funcionamiento;" .

