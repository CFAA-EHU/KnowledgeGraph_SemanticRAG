@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DisminuirOEludirLasMedidasDeProteccion a ns1:AccionProhibida ;
    rdfs:label "Disminuir o eludir las medidas de protección" ;
    ns1:textoExtracto "QUEDA TERMINANTEMENTE PROHIBIDO TRATAR DE DISMINUIR O ELUDIR LAS MEDIDAS DE PROTECCIÓN DE LA MÁQUINA." .

ns1:EmprenderModificacionesSinLaAprobacionDeEKINSCoop a ns1:AccionProhibida ;
    rdfs:label "Emprender modificaciones sin la aprobación de EKIN, S.Coop" ;
    ns1:textoExtracto "No se deben emprender modificaciones, montajes o reconversiones de la máquina que afecten a su seguridad sin la aprobación de EKIN, S.Coop." .

ns1:MantenerLaZonaDeTrabajoDesordenada a ns1:AccionProhibida ;
    rdfs:label "Mantener la zona de trabajo desordenada" ;
    ns1:textoExtracto "La zona de trabajo y el interior de la máquina se deben mantener libres de herramientas, materiales auxiliares y cualquier otro objeto." .

ns1:ManualInstrucciones a ns1:Manual ;
    rdfs:label "Manual de Instrucciones" ;
    ns1:textoExtracto "En conjunto con el presente Manual de Instrucciones se deben respetar y tener en cuenta las reglamentaciones obligatorias de carácter general, legal y de otros tipos para la prevención de accidentes y la protección del medio ambiente." .

ns1:MedidasDeSeguridadExpresadasEnLosCartelesAdosados a ns1:AvisoSeguridad ;
    rdfs:label "Medidas de seguridad expresadas en los carteles adosados" ;
    ns1:textoExtracto "SE DEBEN OBSERVAR SIEMPRE LAS MEDIDAS DE SEGURIDAD EXPRESADAS EN LOS CARTELES ADOSADOS A LA MÁQUINA Y EN EL MANUAL DE INSTRUCCIONES." .

ns1:ModificacionesMontajesOReconversionesDeLaMaquinaSinAprobacion a ns1:AccionProhibida ;
    rdfs:label "Modificaciones, montajes o reconversiones de la máquina sin aprobación" ;
    ns1:textoExtracto "No se deben emprender modificaciones, montajes o reconversiones de la máquina que afecten a su seguridad sin la aprobación de EKIN, S.Coop." .

ns1:PersonalInstruido a ns1:Personal ;
    rdfs:label "Personal instruido" ;
    ns1:textoExtracto "El personal que vaya a hacerse cargo y/o vaya a hacer uso de la máquina debe ser previamente instruido en el manejo de la misma, incluyendo los peligros que presenta, las medidas de seguridad que debe adoptar y respetar, así como las prendas de protección que debe utilizar y las acciones que no debe ejecutar." .

ns1:PiezaRecambioOriginal a ns1:PiezaRecambio ;
    rdfs:label "Piezas de recambio originales" ;
    ns1:textoExtracto "Esto se garantiza siempre empleando las piezas de recambio originales." .

ns1:RetirarPlacasDeAdvertenciaOInstrucciones a ns1:AccionProhibida ;
    rdfs:label "Retirar placas de advertencia o instrucciones" ;
    ns1:textoExtracto "EN NINGÚN CASO SE DEBEN RETIRAR LAS PLACAS DE ADVERTENCIA O INSTRUCCIONES DE LA MÁQUINA." .

ns1:ElementoSeguridad a ns1:ElementoSeguridad ;
    rdfs:label "Elementos de seguridad de la máquina" ;
    ns1:textoExtracto "EL ESTADO DE LOS ELEMENTOS DE SEGURIDAD DE LA MÁQUINA SE DEBE VERIFICAR REGULARMENTE PARA GARANTIZAR LA SEGURIDAD DE LA MISMA." .

