@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnularEnclavamientosDeSeguridad a ns1:AccionProhibida ;
    rdfs:label "Anular enclavamientos de seguridad" ;
    ns1:textoExtracto "LOS ENCLAVAMIENTOS DE SEGURIDAD NO DEBEN ANULARSE." .

ns1:AvisosDeSeguridadSobrePlacasYEnclavamientos a ns1:AvisoSeguridad ;
    rdfs:label "Avisos de seguridad sobre placas y enclavamientos" ;
    ns1:textoExtracto "EN NINGÚN CASO SE DEBEN RETIRAR LAS PLACAS DE ADVERTENCIA O INSTRUCCIONES DE LA MÁQUINA. LOS ENCLAVAMIENTOS DE SEGURIDAD NO DEBEN ANULARSE." .

ns1:MaquinaPrincipal a ns1:Maquina ;
    rdfs:label "Máquina principal" ;
    ns1:textoExtracto "EN NINGÚN CASO SE DEBEN RETIRAR LAS PLACAS DE ADVERTENCIA O INSTRUCCIONES DE LA MÁQUINA. LOS ENCLAVAMIENTOS DE SEGURIDAD NO DEBEN ANULARSE." .

ns1:RetirarPlacasDeAdvertenciaOInstrucciones a ns1:AccionProhibida ;
    rdfs:label "Retirar placas de advertencia o instrucciones" ;
    ns1:textoExtracto "EN NINGÚN CASO SE DEBEN RETIRAR LAS PLACAS DE ADVERTENCIA O INSTRUCCIONES DE LA MÁQUINA." .

