@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:CarroMaquina1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "NO PONER EN MARCHA EL CARRO DE LA MÁQUINA SIN ASEGURARSE DE QUE LAS PIEZAS A BROCHAR ESTAN CORRECTAMENTE COLOCADAS EN EL UTIL DE AMARRE." .

ns1:DefensaMaquina1 a ns1:ElementoSeguridad ;
    ns1:textoExtracto "Todas las defensas de la máquina deben estar situadas en su posición correcta y mantenidas en buenas condiciones." .

ns1:EnclavamientoSeguridad1 a ns1:ElementoSeguridad ;
    ns1:textoExtracto "LOS ENCLAVAMIENTOS DE SEGURIDAD NO DEBEN ANULARSE." .

ns1:FluidoCorte1 a ns1:Consumible ;
    ns1:identificador "ACEITE DE CORTE" ;
    ns1:textoExtracto "NO SE DEBEN EMPLEAR FLUIDOS (ESPECIALMENTE ACEITE DE CORTE Y TALADRINAS) QUE MUESTREN EFECTOS PERJUDICIALES PARA LA SALUD." .

ns1:FluidoTaladrina1 a ns1:Consumible ;
    ns1:identificador "TALADRINAS" ;
    ns1:textoExtracto "NO SE DEBEN EMPLEAR FLUIDOS (ESPECIALMENTE ACEITE DE CORTE Y TALADRINAS) QUE MUESTREN EFECTOS PERJUDICIALES PARA LA SALUD." .

ns1:ManipulacionManualPieza1 a ns1:AccionProhibida ;
    ns1:textoExtracto "NO SE DEBE PONER JAMÁS LAS MANOS U OBJETOS MÁS ALLÁ DE LAS DEFENSAS DURANTE EL FUNCIONAMIENTO DE LA MÁQUINA O CUANDO CUALQUIERA DE SUS ELEMENTOS ESTÉ EN MOVIMIENTO." .

ns1:Maquina1 a ns1:Maquina ;
    ns1:textoExtracto "LAS OPERACIONES DE MOVIMIENTO DE LA MÁQUINA POR PARTE DEL USUARIO CON MEDIOS DE ELEVACIÓN, SE DEBEN EFECTUAR SIGUIENDO LA LEGISLACIÓN VIGENTE EN EL PAÍS DE UTILIZACIÓN." .

ns1:MedioElevacion1 a ns1:Herramienta ;
    ns1:identificador "grúas, plumas" ;
    ns1:textoExtracto "En caso de tener que manipular manualmente piezas de más de 10kg. de peso, deberán emplearse medios de elevación tales como grúas, plumas, etc." .

ns1:UtilAmarre1 a ns1:Componente ;
    ns1:textoExtracto "LAS PIEZAS A BROCHAR ESTAN CORRECTAMENTE COLOCADAS EN EL UTIL DE AMARRE." .

