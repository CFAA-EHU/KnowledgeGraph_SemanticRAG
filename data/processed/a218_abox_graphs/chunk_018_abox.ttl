@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    rdfs:label "Máquina para brochado exterior" ;
    ns1:documentadoEn ns1:ManualInstrucciones ;
    ns1:textoExtracto "LA MÁQUINA A LA CUAL HACE REFERENCIA EL PRESENTE MANUAL HA SIDO CONCEBIDA EXCLUSIVAMENTE PARA EL BROCHADO EXTERIOR, CUYO MECANIZADO TENGA UN ESFUERZO INFERIOR A 70KN Y CARRO PORTABROCHAS DE LONGITUD MENOR A 3000MM." .

ns1:AdvertenciaDeUsoNoAcorde a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia de uso no acorde" ;
    ns1:mitigaRiesgo ns1:UsoNoAcordeConLasEspecificaciones ;
    ns1:textoExtracto "TODO USO DIVERGENTE DEL ESPECIFICADO EN LA DOCUMENTACIÓN DE LA MÁQUINA SE CONSIDERA 'NO ACORDE CON LAS ESPECIFICACIONES' Y DE ÉL PUEDE DERIVARSE RIESGO DE LESIONES O MUERTE DE LOS USUARIOS O DE TERCERAS PERSONAS, O DAÑOS A LA MÁQUINA Y A OTROS BIENES." .

ns1:ManualInstrucciones a ns1:DocumentoTecnico ;
    rdfs:label "Manual de instrucciones" ;
    ns1:textoExtracto "ES PARTE DEL USO ACORDE CON LAS ESPECIFICACIONES EL CUMPLIMIENTO DE LAS INDICACIONES DEL MANUAL DE INSTRUCCIONES." .

ns1:UsoNoAcordeConLasEspecificaciones a ns1:AccionProhibida ;
    rdfs:label "Uso no acorde con las especificaciones" ;
    ns1:mitigaRiesgo ns1:AdvertenciaDeUsoNoAcorde ;
    ns1:textoExtracto "TODO USO DIVERGENTE DEL ESPECIFICADO EN LA DOCUMENTACIÓN DE LA MÁQUINA SE CONSIDERA 'NO ACORDE CON LAS ESPECIFICACIONES' Y DE ÉL PUEDE DERIVARSE RIESGO DE LESIONES O MUERTE DE LOS USUARIOS O DE TERCERAS PERSONAS, O DAÑOS A LA MÁQUINA Y A OTROS BIENES." .

