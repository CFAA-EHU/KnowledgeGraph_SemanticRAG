@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisosDeSeguridadParaElUsoDeLaMaquina a ns1:AvisoSeguridad ;
    rdfs:label "Avisos de seguridad para el uso de la máquina" ;
    ns1:mitigaRiesgo ns1:AbrirPuertasDeArmariosElectricos,
        ns1:EmplearHerramientasDiferentesALasEspecificadasPorEKINSCOOP,
        ns1:PonerEnFuncionamientoLaMaquinaSinVerificarQueNoHayNadieEnSuInterior,
        ns1:PonerEnMarchaElCicloAutomaticoDeLaMaquinaSinVerificarElUtilDeAmarre,
        ns1:SobrepasarLaCapacidadDeTrabajoDeLaMaquina ;
    ns1:textoExtracto "En ningún caso se debe poner en marcha el ciclo automático de la máquina sin antes asegurarse de que el útil de amarre está adaptado a las piezas que se van a brochar. LAS PUERTAS DE LOS ARMARIOS ELÉCTRICOS DEBEN ESTAR CERRADAS Y BLOQUEADAS. ABRIR LAS PUERTAS SUPONE EXPONERSE A TENSIONES ELÉCTRICAS PELIGROSAS." .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    rdfs:label "Máquina Brochadora Electromecánica Exterior A218" ;
    ns1:textoExtracto "NO SE DEBE PONER EN FUNCIONAMIENTO LA MAQUINA EN NINGUNO DE SUS MODOS DE TRABAJO, SIN ANTES VERIFICAR QUE NO SE ENCUENTRA NADIE EN SU INTERIOR." .

ns1:AbrirPuertasDeArmariosElectricos a ns1:AccionProhibida ;
    rdfs:label "Abrir puertas de armarios eléctricos" ;
    ns1:textoExtracto "LAS PUERTAS DE LOS ARMARIOS ELÉCTRICOS DEBEN ESTAR CERRADAS Y BLOQUEADAS. ABRIR LAS PUERTAS SUPONE EXPONERSE A TENSIONES ELÉCTRICAS PELIGROSAS." .

ns1:EmplearHerramientasDiferentesALasEspecificadasPorEKINSCOOP a ns1:AccionProhibida ;
    rdfs:label "Emplear herramientas diferentes a las especificadas por EKIN S. COOP" ;
    ns1:textoExtracto "NO SE DEBEN EMPLEAR HERRAMIENTAS DIFERENTES A LAS ESPECIFICADAS POR EKIN S. COOP." .

ns1:PonerEnFuncionamientoLaMaquinaSinVerificarQueNoHayNadieEnSuInterior a ns1:AccionProhibida ;
    rdfs:label "Poner en funcionamiento la máquina sin verificar que no hay nadie en su interior" ;
    ns1:textoExtracto "NO SE DEBE PONER EN FUNCIONAMIENTO LA MAQUINA EN NINGUNO DE SUS MODOS DE TRABAJO, SIN ANTES VERIFICAR QUE NO SE ENCUENTRA NADIE EN SU INTERIOR." .

ns1:PonerEnMarchaElCicloAutomaticoDeLaMaquinaSinVerificarElUtilDeAmarre a ns1:AccionProhibida ;
    rdfs:label "Poner en marcha el ciclo automático de la máquina sin verificar el útil de amarre" ;
    ns1:textoExtracto "En ningún caso se debe poner en marcha el ciclo automático de la máquina sin antes asegurarse de que el útil de amarre está adaptado a las piezas que se van a brochar." .

ns1:SobrepasarLaCapacidadDeTrabajoDeLaMaquina a ns1:AccionProhibida ;
    rdfs:label "Sobrepasar la capacidad de trabajo de la máquina" ;
    ns1:textoExtracto "NO SE DEBE SOBREPASAR LA CAPACIDAD DE TRABAJO DE LA MÁQUINA." .

