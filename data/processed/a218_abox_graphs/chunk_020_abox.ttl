@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Herramienta_522a0cbce4 a ns1:Herramienta ;
    rdfs:label "Candado" ;
    ns1:textoExtracto "COLOCAR UN CARTEL DE ADVERTENCIA JUNTO AL INTERRUPTOR GENERAL, SITUADO EN UN COSTADO DEL ARMARIO ELECTRICO, PROHIBIENDO LA PUESTA EN TENSIÓN DE LA MÁQUINA Y TAMBIEN BLOQUEANDOLO CON UN CANDADO." .

ns1:InterruptorGeneral_1a4659be08 a ns1:ComponenteElectrico ;
    rdfs:label "Interruptor general" ;
    ns1:textoExtracto "COLOCAR UN CARTEL DE ADVERTENCIA JUNTO AL INTERRUPTOR GENERAL, SITUADO EN UN COSTADO DEL ARMARIO ELECTRICO." .

ns1:PersonalTecnico a ns1:Personal ;
    rdfs:label "Personal que repare y mantenga la máquina" ;
    ns1:ejecuta ns1:AvisoSeguridad_4b963dff63,
        ns1:AvisoSeguridad_afa689218f ;
    ns1:textoExtracto "EL PERSONAL QUE REPARA Y MANTIENE LA MÁQUINA DEBE TENER LOS CONOCIMIENTOS PRECISOS DE MECÁNICA, HIDRÁULICA, NEUMÁTICA, ELECTRICIDAD-ELECTRÓNICA" .

ns1:AvisoSeguridad_4b963dff63 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de consignación" ;
    ns1:mitigaRiesgo ns1:MaquinaBrochadoraElectromecanicaExteriorA218 ;
    ns1:textoExtracto "ANTES DE REALIZAR OPERACIONES DE MANTENIMIENTO QUE PRECISEN RETIRAR LOS RESGUARDOS, SE DEBE CONSIGNAR LA MÁQUINA." .

ns1:AvisoSeguridad_afa689218f a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de advertencia con cartel" ;
    ns1:mitigaRiesgo ns1:MaquinaBrochadoraElectromecanicaExteriorA218 ;
    ns1:textoExtracto "COLOCAR UN CARTEL DE ADVERTENCIA JUNTO AL INTERRUPTOR GENERAL, SITUADO EN UN COSTADO DEL ARMARIO ELECTRICO, PROHIBIENDO LA PUESTA EN TENSIÓN DE LA MÁQUINA Y TAMBIEN BLOQUEANDOLO CON UN CANDADO." .

ns1:ManualInstrucciones a ns1:Manual ;
    rdfs:label "Manual de instrucciones" ;
    ns1:textoExtracto "ANTES DE EFECTUAR REPARACIONES EN LA MÁQUINA, SE DEBE CONSULTAR ESTE MANUAL DE INSTRUCCIONES." .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    ns1:documentadoEn ns1:ManualInstrucciones ;
    ns1:textoExtracto "ANTES DE EFECTUAR REPARACIONES EN LA MÁQUINA, SE DEBE CONSULTAR ESTE MANUAL DE INSTRUCCIONES." .

