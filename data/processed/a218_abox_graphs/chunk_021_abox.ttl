@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AparatoElevador a ns1:Componente ;
    rdfs:label "Aparatos elevadores" ;
    ns1:textoExtracto "SÓLO SE DEBEN EMPLEAR APARATOS ELEVADORES APROPIADOS Y TÉCNICAMENTE IMPECABLES, CON CARGA NOMINAL SUFICIENTE." .

ns1:Componente_76afa518df a ns1:Componente ;
    rdfs:label "Cadenas",
        "Cuerdas",
        "Ganchos",
        "Ojales" ;
    ns1:textoExtracto "LAS CADENAS, CUERDAS, GANCHOS Y OJALES DEBEN SER ASIMISMO ADECUADOS PARA LOS PESOS INDICADOS." .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    rdfs:label "Máquina Brochadora" ;
    ns1:textoExtracto "SU MÁQUINA BROCHADORA" ;
    ns1:tieneComponente ns1:SistemaSeguridad .

ns1:SustitucionDeComponentesConGruasOAparatosElevadores a ns1:TareaMantenimiento ;
    rdfs:label "Sustitución de componentes con grúas o aparatos elevadores" ;
    ns1:textoExtracto "SIEMPRE QUE SEA NECESARIO EMPLEAR GRÚAS O APARATOS ELEVADORES PARA LA SUSTITUCIÓN DE COMPONENTES DE LA MÁQUINA SE DEBE GARANTIZAR QUE NO SE DERIVA NINGÚN PELIGRO DE ESTOS PROCESOS." .

ns1:RevisionYMantenimientoDeSistemasDeSeguridad a ns1:TareaMantenimiento ;
    rdfs:label "Revisión y mantenimiento de sistemas de seguridad" ;
    ns1:textoExtracto "SE DEBEN REVISAR Y MANTENER REGULARMENTE LOS SISTEMAS DE SEGURIDAD DE LOS QUE VA PROVISTA LA MÁQUINA." .

ns1:SistemaSeguridad a ns1:Sistema ;
    rdfs:label "Sistemas de seguridad" ;
    ns1:requiereMantenimiento ns1:RevisionYMantenimientoDeSistemasDeSeguridad ;
    ns1:textoExtracto "LOS SISTEMAS DE SEGURIDAD DE LOS QUE VA PROVISTA LA MÁQUINA." .

