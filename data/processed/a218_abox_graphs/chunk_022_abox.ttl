@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RevisionYMantenimientoDeSistemasDeSeguridad a ns1:TareaMantenimiento ;
    rdfs:label "Revisión y mantenimiento de sistemas de seguridad" ;
    ns1:esMantenimientoDe ns1:MaquinaBrochadoraA218 ;
    ns1:textoExtracto "SE DEBEN REVISAR Y MANTENER REGULARMENTE LOS SISTEMAS DE SEGURIDAD DE LOS QUE VA PROVISTA LA MÁQUINA." .

ns1:MaquinaBrochadoraA218 a ns1:Maquina ;
    rdfs:label "Máquina Brochadora" ;
    ns1:textoExtracto "SU MÁQUINA BROCHADORA (VER APARTADO 7.1 plan de mantenimiento)." .

