@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ElementosProteccionSeguridad a ns1:Sistema ;
    rdfs:label "Elementos de protección y seguridad de la máquina" ;
    ns1:compuestoPor ns1:InterruptorGeneralArmarioElectrico,
        ns1:PanelesDesmontables,
        ns1:PanelesFijos,
        ns1:Puertas,
        ns1:PulsadorParadaEmergencia ;
    ns1:detalladoEnEsquema ns1:Figura2_1ElementosSeguridadMaquina ;
    ns1:textoExtracto "ELEMENTOS DE PROTECCIÓN Y SEGURIDAD DE LA MÁQUINA EL ESTADO DE LOS ELEMENTOS DE SEGURIDAD DE LA MÁQUINA SE DEBE VERIFICAR REGULARMENTE PARA GARANTIZAR LA SEGURIDAD DE LA MISMA." .

ns1:Figura2_1ElementosSeguridadMaquina a ns1:Figura ;
    rdfs:label "Figura 2-1. Elementos de seguridad de la máquina" ;
    ns1:textoExtracto "La Figura 2-1. Elementos de seguridad de la máquina muestra la ubicación de los elementos de seguridad de la máquina Interruptor general del armario eléctrico Pulsador de parada de emergencia Paneles Desmont ables Puertas Paneles Fijos Figura 2-1. Elementos de seguridad de la máquina." .

ns1:InterruptorGeneralArmarioElectrico a ns1:ElementoSeguridad ;
    rdfs:label "Interruptor general del armario eléctrico" ;
    ns1:textoExtracto "Interruptor general del armario eléctrico" .

ns1:PanelesDesmontables a ns1:ElementoSeguridad ;
    rdfs:label "Paneles desmontables" ;
    ns1:textoExtracto "Paneles Desmont ables" .

ns1:PanelesFijos a ns1:ElementoSeguridad ;
    rdfs:label "Paneles fijos" ;
    ns1:textoExtracto "Paneles Fijos" .

ns1:Puertas a ns1:ElementoSeguridad ;
    rdfs:label "Puertas" ;
    ns1:textoExtracto "Puertas" .

ns1:PulsadorParadaEmergencia a ns1:ElementoSeguridad ;
    rdfs:label "Pulsador de parada de emergencia" ;
    ns1:textoExtracto "Pulsador de parada de emergencia" .

