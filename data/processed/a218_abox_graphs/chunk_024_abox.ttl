@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    ns1:textoExtracto "La máquina está equipada con 2 tipos de defensas: paneles desmontables de mantenimiento y puertas controladas por interruptor de seguridad." ;
    ns1:tieneComponente ns1:PanelMantenimientoDesmontable,
        ns1:PuertaControladaSeguridad .

ns1:InterruptorSeguridadEuchner a ns1:Componente ;
    rdfs:label "Interruptor de seguridad EUCHNER"@es ;
    ns1:textoExtracto "La máquina dispone de tres puertas controladas con un interruptor de seguridad EUCHNER, una en la parte frontal (23SQ1), una en el lateral izquierdo (24SQ1) y una en el lateral derecho (24SQ2)." .

ns1:PanelMantenimientoDesmontable a ns1:Componente ;
    rdfs:label "Panel de mantenimiento no controlado"@es ;
    ns1:textoExtracto "Paneles de mantenimiento no controlados, sin interruptor de seguridad: sólo se deben abrir para tareas de mantenimiento, cuando la máquina está parada y consignada." .

ns1:PuertaControladaSeguridad a ns1:Componente ;
    rdfs:label "Puerta controlada con interruptor de seguridad"@es ;
    ns1:controladoPor ns1:InterruptorSeguridadEuchner ;
    ns1:textoExtracto "La máquina dispone de tres puertas controladas con un interruptor de seguridad EUCHNER, una en la parte frontal (23SQ1), una en el lateral izquierdo (24SQ1) y una en el lateral derecho (24SQ2)." .

