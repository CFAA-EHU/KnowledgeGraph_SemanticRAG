@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterruptorDeSeguridad a ns1:Sensor ;
    rdfs:label "Interruptor de seguridad" ;
    ns1:textoExtracto "Puertas controladas con interruptor de seguridad" .

ns1:NoAbrirPuertasDuranteElServicioAutomatico a ns1:AccionProhibida ;
    rdfs:label "No abrir puertas durante el servicio automático" ;
    ns1:mitigaRiesgo ns1:DesconexionDeSistemasYServomotores ;
    ns1:textoExtracto "NO SE DEBEN ABRIR LAS PUERTAS DE LA MÁQUINA DURANTE EL SERVICIO AUTOMÁTICO." .

ns1:DesconexionDeSistemasYServomotores a ns1:Alarma ;
    rdfs:label "Desconexión de sistemas y servomotores" ;
    ns1:textoExtracto "LA APERTURA DE LOS INTERRUPTORES PROVOCA LA DESCONEXIÓN DE LOS DISTINTOS SISTEMAS Y DE LOS SERVOMOTORES Y LA PARADA DE LA MÁQUINA." .

