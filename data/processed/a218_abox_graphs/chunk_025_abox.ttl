@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterruptorSeguridad_25 a ns1:Sensor ;
    rdfs:label "Interruptor de seguridad" ;
    ns1:textoExtracto "Puertas controladas con interruptor de seguridad" .

ns1:Maquina_25 a ns1:Maquina ;
    rdfs:label "Máquina" ;
    ns1:textoExtracto "LA APERTURA DE LOS INTERRUPTORES PROVOCA ... LA PARADA DE LA MÁQUINA" .

ns1:Servomotor_25 a ns1:ComponenteElectrico ;
    rdfs:label "Servomotores" ;
    ns1:textoExtracto "DESCONEXIÓN DE LOS ... SERVOMOTORES" .

ns1:Sistema_25 a ns1:Sistema ;
    rdfs:label "Sistemas" ;
    ns1:textoExtracto "DESCONEXIÓN DE LOS DISTINTOS SISTEMAS" .

