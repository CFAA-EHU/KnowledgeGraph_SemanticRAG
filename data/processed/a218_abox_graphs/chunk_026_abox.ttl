@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaPlataformaCambioHerramienta a ns1:Sistema ;
    rdfs:label "Sistema Plataforma Cambio Herramienta" ;
    ns1:textoExtracto "En la parte superior del carro porta-piezas se ha instalado una plataforma que se utiliza para realizar el cambio de herramienta." ;
    ns1:tieneComponente ns1:TrampillaPlataformaCambioHerramienta .

ns1:ElementoSeguridadEnclavamientoElectronico a ns1:ElementoSeguridad ;
    rdfs:label "Enclavamiento Electrónico de Seguridad" ;
    ns1:identificador "25SQ1 EUCHNER" ;
    ns1:textoExtracto "La trampilla está equipada con un enclavamiento electrónico de seguridad (25SQ1) EUCHNER que se acciona automáticamente cuando la máquina está en funcionamiento." .

ns1:TrampillaPlataformaCambioHerramienta a ns1:Componente ;
    rdfs:label "Trampilla Plataforma Cambio Herramienta" ;
    ns1:controladoPor ns1:ElementoSeguridadEnclavamientoElectronico ;
    ns1:textoExtracto "La plataforma dispone de una trampilla en la parte central que se abre para realizar el cambio del plato divisor." .

