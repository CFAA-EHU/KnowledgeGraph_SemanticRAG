@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesconectarLaMaquinaMedianteElPulsadorDeParadaDeEmergenciaEnSituacionesNormales a ns1:AccionProhibida ;
    rdfs:label "Desconectar la máquina mediante el pulsador de parada de emergencia en situaciones normales" ;
    ns1:mitigaRiesgo ns1:UsarElPulsadorDeParadaDeEmergenciaEnCasosNoDeEmergencia ;
    ns1:textoExtracto "EN SITUACIONES NORMALES NO SE DEBE DESCONECTAR NUNCA LA MÁQUINA MEDIANTE EL PULSADOR DE PARADA DE EMERGENCIA." .

ns1:PulsadorDeParadaDeEmergencia a ns1:ComponenteElectrico ;
    rdfs:label "Pulsador de parada de emergencia" ;
    ns1:textoExtracto "Tanto el armario eléctrico como la botonera de la máquina disponen de un pulsador de parada de emergencia." .

ns1:UsarElPulsadorDeParadaDeEmergenciaEnCasosNoDeEmergencia a ns1:AccionProhibida ;
    rdfs:label "Usar el pulsador de parada de emergencia en casos no de emergencia" ;
    ns1:textoExtracto "EL PULSADOR DE PARADA DE EMERGENCIA SÓLO SE DEBE EMPLEAR EN CASOS DE EMERGENCIA." .

