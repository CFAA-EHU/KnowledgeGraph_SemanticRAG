@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Figura_27_1 a ns1:Figura ;
    rdfs:label "Pulsadores de Parada de emergencia" ;
    ns1:textoExtracto "Pulsadores de Parada de emergencia Figura 2-5. Pulsadores de parada de emergencia." .

ns1:Maquina_27_1 a ns1:Maquina ;
    rdfs:label "máquina" ;
    ns1:textoExtracto "la desconexión de los distintos sistemas y motores de la máquina" .

ns1:PulsadorParadaEmergencia_27_1 a ns1:ElementoSeguridad ;
    rdfs:label "Pulsador de parada de emergencia" ;
    ns1:textoExtracto "Tanto el armario eléctrico como la botonera de la máquina disponen de un pulsador de parada de emergencia." .

ns1:Relay_27_1 a ns1:ComponenteElectrico ;
    rdfs:label "relé" ;
    ns1:textoExtracto "Al pulsar uno de ellos se produce la caída del relé, lo que conlleva a la desconexión de los distintos sistemas y motores de la máquina." .

ns1:Sistema_27_1 a ns1:Sistema ;
    rdfs:label "sistemas" ;
    ns1:textoExtracto "la desconexión de los distintos sistemas y motores de la máquina" .

