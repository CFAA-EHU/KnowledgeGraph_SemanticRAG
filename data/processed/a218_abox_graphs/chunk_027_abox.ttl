@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:pulsadorEmergencia_ArmarioElectrico
    a ex:ComponenteElectrico ;
    rdfs:label "Pulsador de parada de emergencia (armario eléctrico)" ;
    ex:textoExtracto "Tanto el armario eléctrico como la botonera de la máquina disponen de un pulsador de parada de emergencia." ;
    ex:controla ex:releSeguridad_Maquina .

ex:pulsadorEmergencia_Botonera
    a ex:ComponenteElectrico ;
    rdfs:label "Pulsador de parada de emergencia (botonera)" ;
    ex:textoExtracto "Tanto el armario eléctrico como la botonera de la máquina disponen de un pulsador de parada de emergencia." ;
    ex:controla ex:releSeguridad_Maquina .

ex:releSeguridad_Maquina
    a ex:ComponenteElectrico ;
    rdfs:label "Relé de seguridad" ;
    ex:textoExtracto "Al pulsar uno de ellos se produce la caída del relé, lo que conlleva a la desconexión de los distintos sistemas y motores de la máquina." ;
    ex:controla ex:sistemasMaquina .

ex:sistemasMaquina
    a ex:Sistema ;
    rdfs:label "Sistemas y motores de la máquina" ;
    ex:textoExtracto "la desconexión de los distintos sistemas y motores de la máquina." .

ex:figura2_5
    a ex:Figura ;
    rdfs:label "Figura 2-5. Pulsadores de parada de emergencia" ;
    ex:identificador "2-5" ;
    ex:textoExtracto "Pulsadores de Parada de emergencia Figura 2-5. Pulsadores de parada de emergencia." ;
    ex:ilustradoEn ex:pulsadorEmergencia_ArmarioElectrico ;
    ex:ilustradoEn ex:pulsadorEmergencia_Botonera .

ex:avisoUsoEmergencia
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso de uso exclusivo en emergencias" ;
    ex:textoExtracto "EL PULSADOR DE PARADA DE EMERGENCIA SÓLO SE DEBE EMPLEAR EN CASOS DE EMERGENCIA. EN SITUACIONES NORMALES NO SE DEBE DESCONECTAR NUNCA LA MÁQUINA MEDIANTE EL PULSADOR DE PARADA DE EMERGENCIA." ;
    ex:mitigaRiesgo ex:pulsadorEmergencia_ArmarioElectrico ;
    ex:mitigaRiesgo ex:pulsadorEmergencia_Botonera .