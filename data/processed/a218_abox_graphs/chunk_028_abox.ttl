@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_db945be8e2 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de consignación de la máquina" ;
    ns1:mitigaRiesgo ns1:ManipulacionInvoluntariaDelInterruptorGeneral ;
    ns1:textoExtracto "Para realizar labores de mantenimiento es necesario consignar la máquina; para consignar la máquina hay que situar el interruptor general en posición OFF y colocar un candado que evite a terceras personas situarlo en la posición ON de forma involuntaria." .

ns1:InterruptorGeneralDelArmarioElectrico_d31f2a781a a ns1:ComponenteElectrico ;
    rdfs:label "Interruptor general del armario eléctrico" ;
    ns1:controla ns1:MaquinaBrochadoraElectromecanicaExteriorA218 ;
    ns1:textoExtracto "El armario eléctrico de la máquina dispone en un lateral de un interruptor general, mediante el cual se realiza la conexión y desconexión del suministro eléctrico de toda la máquina." .

ns1:ManipulacionInvoluntariaDelInterruptorGeneral a ns1:AccionProhibida ;
    rdfs:label "Manipulación involuntaria del interruptor general" ;
    ns1:textoExtracto "Para realizar labores de mantenimiento es necesario consignar la máquina; para consignar la máquina hay que situar el interruptor general en posición OFF y colocar un candado que evite a terceras personas situarlo en la posición ON de forma involuntaria." .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    rdfs:label "Máquina" ;
    ns1:textoExtracto "El armario eléctrico de la máquina dispone en un lateral de un interruptor general, mediante el cual se realiza la conexión y desconexión del suministro eléctrico de toda la máquina." .

