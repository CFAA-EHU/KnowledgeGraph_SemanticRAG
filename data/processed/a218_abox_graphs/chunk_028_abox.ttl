@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterruptorGeneralArmarioElectrico_22
    a               ex:ComponenteElectrico ;
    rdfs:label      "Interruptor general del armario eléctrico" ;
    ex:textoExtracto "El armario eléctrico de la máquina dispone en un lateral de un interruptor general, mediante el cual se realiza la conexión y desconexión del suministro eléctrico de toda la máquina." ;
    ex:controla     ex:SuministroElectricoMaquina_22 ;
    ex:tieneFrecuencia ex:FrecuenciaMantenimiento_22 .

ex:SuministroElectricoMaquina_22
    a               ex:Sistema ;
    rdfs:label      "Suministro eléctrico de la máquina" ;
    ex:textoExtracto "conexión y desconexión del suministro eléctrico de toda la máquina" ;
    ex:compuestoPor ex:ServomotoresMaquina_22 .

ex:ServomotoresMaquina_22
    a               ex:ComponenteElectrico ;
    rdfs:label      "Servomotores de la máquina" ;
    ex:textoExtracto "desconexión de los sistemas y de todos los servomotores de la máquina" .

ex:FrecuenciaMantenimiento_22
    a               ex:Frecuencia ;
    rdfs:label      "Frecuencia de consignación para mantenimiento" ;
    ex:textoExtracto "Para realizar labores de mantenimiento es necesario consignar la máquina" .

ex:ProcedimientoConsignacion_22
    a               ex:TareaMantenimiento ;
    rdfs:label      "Consignación de la máquina" ;
    ex:textoExtracto "para consignar la máquina hay que situar el interruptor general en posición OFF y colocar un candado que evite a terceras personas situarlo en la posición ON de forma involuntaria" ;
    ex:requiereMantenimiento ex:InterruptorGeneralArmarioElectrico_22 .

ex:SenalVisualConsignacion_22
    a               ex:AvisoSeguridad ;
    rdfs:label      "Señal visual 'Máquina consignada'" ;
    ex:textoExtracto "Señal visual Interruptor general de tensión del armario eléctrico Máquina consignada" ;
    ex:mitigaRiesgo ex:ProcedimientoConsignacion_22 .

ex:Figura2_6
    a               ex:Figura ;
    rdfs:label      "Figura 2-6. Interruptor general armario eléctrico" ;
    ex:textoExtracto "Figura 2-6. Interruptor general armario eléctrico" ;
    ex:ilustradoEn  ex:Pagina22 .