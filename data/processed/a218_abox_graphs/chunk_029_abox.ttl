@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FormacionDelPersonal a ns1:TareaMantenimiento ;
    rdfs:label "formación del personal" ;
    ns1:ejecutadoPor ns1:PersonalFormado ;
    ns1:textoExtracto "FORMACIÓN DEL PERSONAL Sólo se debe emplear personal debidamente formado e instruido tanto en el manejo como en el mantenimiento de la máquina." .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    rdfs:label "BROCHADORA ELECTROMECÁNICA DE EXTERIORES A218/RASHEM 7x3000x500" ;
    ns1:textoExtracto "BROCHADORA ELECTROMECÁNICA DE EXTERIORES | INSTRUCCIONES DE SEGURIDAD | A218/ RASHEM 7x3000x500" .

ns1:ManualInstrucciones a ns1:DocumentoTecnico ;
    rdfs:label "manual de instrucciones" ;
    ns1:textoExtracto "Éste debe estudiar los planos, esquemas y toda la documentación que indica este manual de instrucciones acerca de la máquina." .

ns1:PersonalFormado a ns1:Personal ;
    rdfs:label "personal debidamente formado e instruido" ;
    ns1:documentadoEn ns1:ManualInstrucciones ;
    ns1:textoExtracto "Sólo se debe emplear personal debidamente formado e instruido tanto en el manejo como en el mantenimiento de la máquina." .

