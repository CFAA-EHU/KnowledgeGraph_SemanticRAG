@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CalzadoDeSeguridad_3889236862 a ns1:EPI ;
    rdfs:label "Calzado de seguridad" ;
    ns1:epiRequeridoEn ns1:MaquinaPrincipal ;
    ns1:textoExtracto "Calzado | Debe ser calzado de seguridad y con puntera reforzada. De no usarse correctamente pueden producirse aplastamientos de los pies." .

ns1:EPICascoSeguridad a ns1:EPI ;
    rdfs:label "Casco de seguridad" ;
    ns1:epiRequeridoEn ns1:MaquinaPrincipal ;
    ns1:textoExtracto "Casco de seguridad | Para trabajos en los que exista peligro de daños en la cabeza, en especial en trabajos de montaje o desmontaje y transporte de elementos de la máquina, y en toda acción de movimiento de elementos pesados mediante una grúa." .

ns1:EPI_89230a27a4 a ns1:EPI ;
    rdfs:label "Auriculares" ;
    ns1:epiRequeridoEn ns1:MaquinaPrincipal ;
    ns1:textoExtracto "Auriculares | Para los trabajos con ruidos superiores a los 78 dB. Se pueden utilizar tapones en lugar de los auriculares." .

ns1:EPI_a3b7c29319 a ns1:EPI ;
    rdfs:label "Guantes" ;
    ns1:epiRequeridoEn ns1:MaquinaPrincipal ;
    ns1:textoExtracto "Guantes | Deben ser adecuados para cada tipo de trabajo, tales como: Para trabajos con materiales abrasivos o a altas temperaturas. Para trabajos con elementos de aristas cortantes." .

ns1:GafasDeSeguridad_2030580f14 a ns1:EPI ;
    rdfs:label "Gafas de seguridad" ;
    ns1:epiRequeridoEn ns1:MaquinaPrincipal ;
    ns1:textoExtracto "Gafas | Para todo tipo de trabajo con herramienta en el que exista proyección de partículas. Para todos los trabajos de soldadura, usar pantalla protectora, mandil y guantes adecuados." .

ns1:MaquinaPrincipal a ns1:Maquina ;
    rdfs:label "Máquina principal" ;
    ns1:textoExtracto "La máquina principal mencionada en el contexto del mantenimiento y seguridad." .

