@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EPICascoSeguridad a ns1:EPI ;
    rdfs:label "Casco de seguridad" ;
    ns1:textoExtracto "Para trabajos en los que exista peligro de daños en la cabeza, en especial en trabajos de montaje o desmontaje y transporte de elementos de la máquina, y en toda acción de movimiento de elementos pesados mediante una grúa." .

