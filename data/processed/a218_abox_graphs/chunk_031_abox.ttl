@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Tabla2_1 a ns1:Tabla ;
    ns1:textoExtracto "Tabla 2-1. Equipo para la seguridad personal." ;
    ns1:tieneComponente ns1:CascoDeSeguridad .

ns1:CascoDeSeguridad a ns1:EPI ;
    ns1:textoExtracto "Casco de seguridad | Para trabajos en los que exista peligro de daños en la cabeza, en especial en trabajos de montaje o desmontaje y transporte de elementos de la máquina, y en toda acción de movimiento de elementos pesados mediante una grúa." .

