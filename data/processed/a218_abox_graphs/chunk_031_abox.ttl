@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_2_1
    a                       ex:Tabla ;
    ex:identificador         "2-1" ;
    rdfs:label              "Equipo para la seguridad personal"@es ;
    ex:textoExtracto         "Tabla 2-1. Equipo para la seguridad personal."@es .

ex:CascoSeguridad_2_1
    a                       ex:EPI ;
    rdfs:label              "Casco de seguridad"@es ;
    ex:textoExtracto         "Casco de seguridad | Para trabajos en los que exista peligro de daños en la cabeza, en especial en trabajos de montaje o desmontaje y transporte de elementos de la máquina, y en toda acción de movimiento de elementos pesados mediante una grúa."@es ;
    ex:documentadoEn         ex:Tabla_2_1 ;
    ex:mitigaRiesgo          ex:MovimientoElementosPesados .

ex:MovimientoElementosPesados
    a                       ex:AccionProhibida ;
    rdfs:label              "Movimiento de elementos pesados mediante grúa"@es ;
    ex:textoExtracto         "acción de movimiento de elementos pesados mediante una grúa"@es .