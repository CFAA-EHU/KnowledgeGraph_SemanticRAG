@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaMantenimientoSeguridadResiduos a ns1:Sistema ;
    rdfs:label "Sistema de seguridad para residuos" ;
    ns1:requiereConsumible ns1:ConsumibleAceitesGrasas ;
    ns1:textoExtracto "Los residuos que se forman pueden dar lugar a problemas medio ambientales y para su almacenamiento y deshecho debe recurrirse a la legislación vigente en el país de utilización de la máquina." .

ns1:ConsumibleAceitesGrasas a ns1:Consumible ;
    rdfs:label "Aceites, grasas y fluidos" ;
    ns1:textoExtracto "LOS ACEITES, GRASAS, FLUIDOS Y DEMÁS SUSTANCIAS QUÍMICAS UTILIZADAS EN LA MÁQUINA DEBEN CUMPLIR LAS NORMATIVAS VIGENTES PARA LA PROTECCIÓN DEL MEDIOAMBIENTE." .

