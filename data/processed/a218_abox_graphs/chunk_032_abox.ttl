@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MateriaPrimasMaquina_32 a ns1:Consumible ;
    rdfs:label "Aceites, grasas, fluidos y sustancias químicas de la máquina"@es ;
    ns1:cumpleNormativa ns1:NormativaAmbientalVigente_32 ;
    ns1:textoExtracto "LOS ACEITES, GRASAS, FLUIDOS Y DEMÁS SUSTANCIAS QUÍMICAS UTILIZADAS EN LA MÁQUINA"@es .

ns1:MaterialesServicioAuxiliares_32 a ns1:Consumible ;
    rdfs:label "Materiales de servicio y auxiliares de la máquina"@es ;
    ns1:cumpleNormativa ns1:NormativaAmbientalVigente_32 ;
    ns1:textoExtracto "TODOS LOS MATERIALES DE SERVICIO Y AUXILIARES"@es .

ns1:PiezasRecambioMaquina_32 a ns1:PiezaRecambio ;
    rdfs:label "Piezas de recambio de la máquina"@es ;
    ns1:cumpleNormativa ns1:NormativaAmbientalVigente_32 ;
    ns1:textoExtracto "TODAS LAS PIEZAS DE RECAMBIO"@es .

ns1:ResiduosMaquina_32 a ns1:Consumible ;
    rdfs:label "Residuos generados por la máquina"@es ;
    ns1:cumpleNormativa ns1:NormativaAmbientalVigente_32 ;
    ns1:textoExtracto "Los residuos que se forman pueden dar lugar a problemas medio ambientales"@es .

ns1:NormativaAmbientalVigente_32 a ns1:Directiva ;
    rdfs:label "Legislación ambiental vigente para residuos de máquina"@es ;
    ns1:textoExtracto "legislación vigente en el país de utilización de la máquina"@es .

