@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceiteUsado a ns1:Consumible ;
    rdfs:label "Aceite usado" ;
    ns1:textoExtracto "Se considera aceite usado todo aceite industrial o lubricante, con base mineral o sintética, que se haya vuelto inadecuado para el uso que se le hubiere asignado inicialmente." .

ns1:DepositoConEfectosNocivosDeAceiteUsado a ns1:AccionProhibida ;
    rdfs:label "Depósito con efectos nocivos de aceite usado" ;
    ns1:textoExtracto "Todo depósito con efectos nocivos o vertido de aceite usado sobre el suelo, así como todo vertido incontrolado de residuos derivados de tratamiento del aceite usado." .

ns1:TratamientoDelAceiteUsadoQueProvoqueContaminacionAtmosferica a ns1:AccionProhibida ;
    rdfs:label "Tratamiento del aceite usado que provoque contaminación atmosférica" ;
    ns1:textoExtracto "Todo tratamiento del aceite usado que provoque una contaminación atmosférica superior al nivel establecido por la legislación vigente." .

ns1:VertidoDeAceiteUsado a ns1:AccionProhibida ;
    rdfs:label "Vertido de aceite usado" ;
    ns1:textoExtracto "Todo vertido de aceite usado en aguas superficiales, interiores, subterráneas, en cualquier zona del mar territorial y en los sistemas de alcantarillado o evacuación de aguas residuales." .

