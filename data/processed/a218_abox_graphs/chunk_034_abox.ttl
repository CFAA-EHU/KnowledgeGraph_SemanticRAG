@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SistemaAlumbradoMaquina_34
    a ex:Sistema ;
    rdfs:label "Sistema de alumbrado de máquina" ;
    ex:textoExtracto "La máquina está provista de un sistema de alumbrado, compuesto por cuatro lámparas de 19.5 W con una protección total contra polvo, viruta, aceites y refrigerantes (IP67)." ;
    ex:compuestoPor ex:LamparaVertical1_34, ex:LamparaVertical2_34, ex:LamparaHorizontal1_34, ex:LamparaHorizontal2_34 ;
    ex:ilustradoEn ex:Figura2_7_34 .

ex:LamparaVertical1_34
    a ex:ComponenteElectrico ;
    rdfs:label "Lámpara vertical 1 (IP67, 19.5 W)" ;
    ex:textoExtracto "dos colocadas en posición vertical alumbrando el plato divisor" ;
    ex:valor "19.5 W / IP67" .

ex:LamparaVertical2_34
    a ex:ComponenteElectrico ;
    rdfs:label "Lámpara vertical 2 (IP67, 19.5 W)" ;
    ex:textoExtracto "dos colocadas en posición vertical alumbrando el plato divisor" ;
    ex:valor "19.5 W / IP67" .

ex:LamparaHorizontal1_34
    a ex:ComponenteElectrico ;
    rdfs:label "Lámpara horizontal 1 (IP67, 19.5 W)" ;
    ex:textoExtracto "otras dos colocadas en horizontal alumbrando la herramienta" ;
    ex:valor "19.5 W / IP67" .

ex:LamparaHorizontal2_34
    a ex:ComponenteElectrico ;
    rdfs:label "Lámpara horizontal 2 (IP67, 19.5 W)" ;
    ex:textoExtracto "otras dos colocadas en horizontal alumbrando la herramienta" ;
    ex:valor "19.5 W / IP67" .

ex:Figura2_7_34
    a ex:Figura ;
    rdfs:label "Figura 2-7. Alumbrado interior de la máquina" ;
    ex:textoExtracto "Figura 2-7. Alumbrado interior de la máquina" ;
    ex:identificador "2-7" .