@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaAlumbradoMaquina a ns1:Sistema ;
    rdfs:label "Sistema de alumbrado" ;
    ns1:textoExtracto "La máquina esta provista de un sistema de alumbrado, compuesto por cuatro lámparas de 19.5 W con una protección total contra polvo, viruta, aceites y refrigerantes (IP67)." ;
    ns1:tieneComponente ns1:ComponenteElectrico_2c818633f7 .

ns1:ComponenteElectrico_2c818633f7 a ns1:ComponenteElectrico ;
    rdfs:label "Lámpara" ;
    ns1:textoExtracto "compuesto por cuatro lámparas de 19.5 W con una protección total contra polvo, viruta, aceites y refrigerantes (IP67)." .

