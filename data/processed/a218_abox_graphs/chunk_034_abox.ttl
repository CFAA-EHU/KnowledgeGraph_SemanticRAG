@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:SistemaAlumbradoMaquina_34 a ns1:Sistema ;
    ns1:compuestoPor ns1:LamparaAlumbrado_1_34,
        ns1:LamparaAlumbrado_2_34,
        ns1:LamparaAlumbrado_3_34,
        ns1:LamparaAlumbrado_4_34 ;
    ns1:textoExtracto "La máquina esta provista de un sistema de alumbrado, compuesto por cuatro lámparas de 19.5 W con una protección total contra polvo, viruta, aceites y refrigerantes (IP67)." .

ns1:LamparaAlumbrado_1_34 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "cuatro lámparas de 19.5 W" ;
    ns1:valor "19.5 W" .

ns1:LamparaAlumbrado_2_34 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "cuatro lámparas de 19.5 W" ;
    ns1:valor "19.5 W" .

ns1:LamparaAlumbrado_3_34 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "cuatro lámparas de 19.5 W" ;
    ns1:valor "19.5 W" .

ns1:LamparaAlumbrado_4_34 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "cuatro lámparas de 19.5 W" ;
    ns1:valor "19.5 W" .

