@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Maquina_Broaching_36
    a               ex:Maquina ;
    rdfs:label      "Máquina de brochado (especificaciones de color)" ;
    ex:textoExtracto "Color de la columna, carro, carenado, armario eléctrico y pupitre .... BLANCO RAL 7035" ;
    ex:identificador "RAL 7035" .

ex:ComponenteMecanico_Columna_36
    a               ex:ComponenteMecanico ;
    rdfs:label      "Columna (componente mecánico)" ;
    ex:textoExtracto "Color de la columna" ;
    ex:valor         "BLANCO RAL 7035" .

ex:ComponenteMecanico_Carro_36
    a               ex:ComponenteMecanico ;
    rdfs:label      "Carro (componente mecánico)" ;
    ex:textoExtracto "Color del carro" ;
    ex:valor         "BLANCO RAL 7035" .

ex:ComponenteMecanico_Carenado_36
    a               ex:ComponenteMecanico ;
    rdfs:label      "Carenado (componente mecánico)" ;
    ex:textoExtracto "Color del carenado" ;
    ex:valor         "BLANCO RAL 7035" .

ex:ComponenteElectrico_ArmarioElectrico_36
    a               ex:ComponenteElectrico ;
    rdfs:label      "Armario eléctrico" ;
    ex:textoExtracto "Color del armario eléctrico" ;
    ex:valor         "BLANCO RAL 7035" .

ex:InterfazUsuario_Pupitre_36
    a               ex:InterfazUsuario ;
    rdfs:label      "Pupitre (interfaz de usuario)" ;
    ex:textoExtracto "Color del pupitre" ;
    ex:valor         "BLANCO RAL 7035" .

ex:Maquina_Broaching_36
    ex:tieneComponente ex:ComponenteMecanico_Columna_36 ,
                      ex:ComponenteMecanico_Carro_36 ,
                      ex:ComponenteMecanico_Carenado_36 ,
                      ex:ComponenteElectrico_ArmarioElectrico_36 ;
    ex:ilustradoEn    ex:InterfazUsuario_Pupitre_36 .