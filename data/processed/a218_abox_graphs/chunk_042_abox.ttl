@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoAutomaticoCargaDescargaManual a ns1:ModoOperacion ;
    rdfs:label "Modo automático carga-descarga manual" ;
    ns1:textoExtracto "Modo automático carga-descarga manual" .

ns1:ModoManual a ns1:ModoOperacion ;
    rdfs:label "Modo manual" ;
    ns1:textoExtracto "Modo manual" .

