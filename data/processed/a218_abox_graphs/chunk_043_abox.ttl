@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FuerzaMaxima_5ada88c892 a ns1:Parametro ;
    rdfs:label "Fuerza Máxima" ;
    ns1:textoExtracto "Esta máquina es una brochadora de exteriores de un único puesto, con movimiento de carro porta-piezas (la brocha permanece fija) accionado por un sistema piñón cremallera con un servomotor que desarrolla una fuerza máxima de 70 kNw a una velocidad de 40 m/min." ;
    ns1:valor "70 kNw" .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    rdfs:label "Máquina Brochadora de Exteriores" ;
    ns1:textoExtracto "Esta máquina es una brochadora de exteriores de un único puesto, con movimiento de carro porta-piezas (la brocha permanece fija) accionado por un sistema piñón cremallera con un servomotor que desarrolla una fuerza máxima de 70 kNw a una velocidad de 40 m/min." ;
    ns1:tieneComponente ns1:SistemaPinonCremallera .

ns1:VelocidadMaxima_ec46089279 a ns1:Parametro ;
    rdfs:label "Velocidad Máxima" ;
    ns1:textoExtracto "Esta máquina es una brochadora de exteriores de un único puesto, con movimiento de carro porta-piezas (la brocha permanece fija) accionado por un sistema piñón cremallera con un servomotor que desarrolla una fuerza máxima de 70 kNw a una velocidad de 40 m/min." ;
    ns1:valor "40 m/min" .

ns1:ComponenteElectrico_64757187f7 a ns1:ComponenteElectrico ;
    rdfs:label "Servomotor" ;
    ns1:controladoPor ns1:SistemaPinonCremallera ;
    ns1:textoExtracto "Esta máquina es una brochadora de exteriores de un único puesto, con movimiento de carro porta-piezas (la brocha permanece fija) accionado por un sistema piñón cremallera con un servomotor que desarrolla una fuerza máxima de 70 kNw a una velocidad de 40 m/min." .

ns1:SistemaPinonCremallera a ns1:Sistema ;
    rdfs:label "Sistema Piñón Cremallera" ;
    ns1:controla ns1:ComponenteElectrico_64757187f7 ;
    ns1:textoExtracto "Esta máquina es una brochadora de exteriores de un único puesto, con movimiento de carro porta-piezas (la brocha permanece fija) accionado por un sistema piñón cremallera con un servomotor que desarrolla una fuerza máxima de 70 kNw a una velocidad de 40 m/min." .

