@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    rdfs:label "Máquina Brochadora Electromecánica Exterior A218" ;
    ns1:textoExtracto "La máquina se compone de:" ;
    ns1:tieneComponente ns1:ArmarioElectrico,
        ns1:Carenado,
        ns1:CarroPortaBrochas,
        ns1:CarroPortaPiezas,
        ns1:Componente_b73783f26b,
        ns1:Componente_eb6c44def7,
        ns1:PlatoDivisor,
        ns1:SistemaEngrase,
        ns1:SistemaHidraulico,
        ns1:SistemaLimpiezaDeBrocha,
        ns1:SistemaNeumatico,
        ns1:SistemaRefrigeracion .

ns1:ArmarioElectrico a ns1:Componente ;
    rdfs:label "Armario eléctrico" ;
    ns1:textoExtracto "La máquina se compone de: Armario eléctrico" .

ns1:Carenado a ns1:Componente ;
    rdfs:label "Carenado" ;
    ns1:textoExtracto "La máquina se compone de: Carenado" .

ns1:CarroPortaBrochas a ns1:Componente ;
    rdfs:label "Carro porta-brochas" ;
    ns1:textoExtracto "La máquina se compone de: Carro porta-brochas" .

ns1:CarroPortaPiezas a ns1:Componente ;
    rdfs:label "Carro porta-piezas" ;
    ns1:textoExtracto "La máquina se compone de: Carro porta-piezas" .

ns1:Componente_b73783f26b a ns1:Componente ;
    rdfs:label "Zócalo" ;
    ns1:textoExtracto "La máquina se compone de: Zócalo" .

ns1:Componente_eb6c44def7 a ns1:Componente ;
    rdfs:label "Columna" ;
    ns1:textoExtracto "La máquina se compone de: Columna" .

ns1:PlatoDivisor a ns1:Componente ;
    rdfs:label "Plato divisor" ;
    ns1:textoExtracto "La máquina se compone de: Plato divisor" .

ns1:SistemaEngrase a ns1:Sistema ;
    rdfs:label "Sistema de engrase" ;
    ns1:textoExtracto "La máquina se compone de: Sistema de engrase" .

ns1:SistemaHidraulico a ns1:Sistema ;
    rdfs:label "Sistema hidráulico" ;
    ns1:textoExtracto "La máquina se compone de: Sistema hidráulico" .

ns1:SistemaLimpiezaDeBrocha a ns1:Sistema ;
    rdfs:label "Sistema de limpieza de brocha" ;
    ns1:textoExtracto "La máquina se compone de: Sistema de limpieza de brocha" .

ns1:SistemaNeumatico a ns1:Sistema ;
    rdfs:label "Sistema neumático" ;
    ns1:textoExtracto "La máquina se compone de: Sistema neumático" .

ns1:SistemaRefrigeracion a ns1:Sistema ;
    rdfs:label "Sistema de refrigeración" ;
    ns1:textoExtracto "La máquina se compone de: Sistema de refrigeración" .

