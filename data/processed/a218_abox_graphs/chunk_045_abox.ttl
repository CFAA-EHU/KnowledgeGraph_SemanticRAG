@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ZocaloMaquina
    a               ex:ComponenteMecanico ;
    rdfs:label      "Zócalo" ;
    ex:textoExtracto "El zócalo es la base de la máquina sobre el que se monta la columna. A su vez, hace de depósito de refrigerante, donde se va acumulando el aceite y la viruta durante el proceso de brochado y desde el que se envía al extractor de virutas para separar el aceite de la viruta." ;
    ex:tieneComponente ex:SistemaAntiVibratorio .

ex:SistemaAntiVibratorio
    a               ex:ComponenteMecanico ;
    rdfs:label      "Anti-vibratorios" ;
    ex:textoExtracto "Zócalo Anti-vibratorios" .

ex:Figura4_1
    a               ex:Figura ;
    rdfs:label      "Figura 4-1. Zócalo" ;
    ex:identificador "4-1" ;
    ex:textoExtracto "Figura 4-1. Zócalo" ;
    ex:ilustradoEn   ex:ZocaloMaquina .