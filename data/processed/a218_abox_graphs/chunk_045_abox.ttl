@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Columna_45_34 a ns1:ComponenteMecanico ;
    rdfs:label "Columna" ;
    ns1:textoExtracto "El zócalo es la base de la máquina sobre el que se monta la columna." .

ns1:ExtractorVirutas_45_34 a ns1:ComponenteMecanico ;
    rdfs:label "Extractor de virutas" ;
    ns1:textoExtracto "desde el que se envía al extractor de virutas para separar el aceite de la viruta." .

ns1:Zocalo_45_34 a ns1:ComponenteMecanico ;
    rdfs:label "Zócalo" ;
    ns1:identificador "Figura 4-1. Zócalo" ;
    ns1:textoExtracto "El zócalo es la base de la máquina sobre el que se monta la columna. A su vez, hace de depósito de refrigerante, donde se va acumulando el aceite y la viruta durante el proceso de brochado y desde el que se envía al extractor de virutas para separar el aceite de la viruta." .

