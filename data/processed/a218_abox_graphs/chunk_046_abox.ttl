@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FuerzaMaximaDesarrollada a ns1:Parametro ;
    rdfs:label "Fuerza Máxima Desarrollada" ;
    ns1:textoExtracto "La fuerza máxima desarrollada en este movimiento es de 70 kNw." ;
    ns1:valor "70 kNw" .

ns1:SistemaColumna a ns1:Sistema ;
    rdfs:label "Sistema Columna" ;
    ns1:textoExtracto "Sobe el zócalo se monta la columna con dos guías lineales por las que se desplaza el carro pota-piezas, siendo el recorrido máximo de 3000 mm." ;
    ns1:tieneComponente ns1:CarroPortaPiezas_39ab259c1d,
        ns1:Componente_0b35968ea0,
        ns1:GuiaLineal_f0ee4e593a,
        ns1:ReglaLineal .

ns1:VelocidadDeAvance a ns1:Parametro ;
    rdfs:label "Velocidad de Avance" ;
    ns1:textoExtracto "El movimiento se realiza a una velocidad máxima de 40 m/min de avance y 40 m/min de retroceso." ;
    ns1:valor "40 m/min" .

ns1:VelocidadDeRetroceso_90dbf94ee5 a ns1:Parametro ;
    rdfs:label "Velocidad de Retroceso" ;
    ns1:textoExtracto "El movimiento se realiza a una velocidad máxima de 40 m/min de avance y 40 m/min de retroceso." ;
    ns1:valor "40 m/min" .

ns1:CarroPortaPiezas_39ab259c1d a ns1:Componente ;
    rdfs:label "Carro Porta-Piezas" ;
    ns1:textoExtracto "Sobe el zócalo se monta la columna con dos guías lineales por las que se desplaza el carro pota-piezas, siendo el recorrido máximo de 3000 mm." .

ns1:Componente_0b35968ea0 a ns1:Componente ;
    rdfs:label "Cremallera",
        "Piñón",
        "Servomotor" ;
    ns1:textoExtracto "Dispone de juegos de sistemas piñón/cremallera (WITTENSTEIN) accionados por dos servomotores colocados sobre el carro porta-piezas que provocan su movimiento." .

ns1:GuiaLineal_f0ee4e593a a ns1:Componente ;
    rdfs:label "Guía Lineal" ;
    ns1:textoExtracto "Sobe el zócalo se monta la columna con dos guías lineales por las que se desplaza el carro pota-piezas, siendo el recorrido máximo de 3000 mm." .

ns1:ReglaLineal a ns1:Componente ;
    rdfs:label "Regla Lineal" ;
    ns1:textoExtracto "La posición del carro se controla a través de dos reglas lineales colocadas en el lateral de la columna." .

