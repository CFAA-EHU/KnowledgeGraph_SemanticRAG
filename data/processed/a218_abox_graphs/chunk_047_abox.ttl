@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:CarroPortaPiezas_47
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Carro porta-piezas"@es ;
    ex:textoExtracto       "El carro porta-piezas lleva seis patines y dos bloqueos hidráulicos en la parte posterior."@es ;
    ex:tieneComponente     ex:Patines_CarroPortaPiezas_47, ex:BloqueosHidraulicos_CarroPortaPiezas_47 ;
    ex:compuestoPor        ex:Contrapesos_47 .

ex:Patines_CarroPortaPiezas_47
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Patines del carro porta-piezas"@es ;
    ex:textoExtracto       "seis patines"@es ;
    ex:valor               "6"^^<http://www.w3.org/2001/XMLSchema#integer> .

ex:BloqueosHidraulicos_CarroPortaPiezas_47
    a                     ex:ComponenteHidraulico ;
    rdfs:label            "Bloqueos hidráulicos del carro porta-piezas"@es ;
    ex:textoExtracto       "dos bloqueos hidráulicos en la parte posterior"@es ;
    ex:valor               "2"^^<http://www.w3.org/2001/XMLSchema#integer> .

ex:Contrapesos_47
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Contrapesos del carro porta-piezas"@es ;
    ex:textoExtracto       "dos contrapesos. Cada uno lleva instalados dos patines y un bloqueo hidráulico."@es ;
    ex:tieneComponente     ex:Patines_Contrapesos_47, ex:BloqueosHidraulicos_Contrapesos_47 ;
    ex:valor               "2"^^<http://www.w3.org/2001/XMLSchema#integer> .

ex:Patines_Contrapesos_47
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Patines de los contrapesos"@es ;
    ex:textoExtracto       "dos patines"@es ;
    ex:valor               "2"^^<http://www.w3.org/2001/XMLSchema#integer> .

ex:BloqueosHidraulicos_Contrapesos_47
    a                     ex:ComponenteHidraulico ;
    rdfs:label            "Bloqueos hidráulicos de los contrapesos"@es ;
    ex:textoExtracto       "un bloqueo hidráulico"@es ;
    ex:valor               "1"^^<http://www.w3.org/2001/XMLSchema#integer> .

