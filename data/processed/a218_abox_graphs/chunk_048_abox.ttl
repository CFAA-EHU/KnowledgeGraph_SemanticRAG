@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MovimientoDelPlatoDivisorBloqueado a ns1:AccionProhibida ;
    rdfs:label "Movimiento del Plato Divisor Bloqueado" ;
    ns1:textoExtracto "- SQ46: MESA ABAJO (BLOQUEADO)" .

ns1:MovimientoDelPlatoDivisorDesbloqueado a ns1:AccionProhibida ;
    rdfs:label "Movimiento del Plato Divisor Desbloqueado" ;
    ns1:textoExtracto "- SQ47: MESA ARRIBA (DESBLOQUEADO)" .

ns1:MovimientoDelPlatoDivisorSinPresionHidraulica a ns1:AccionProhibida ;
    rdfs:label "Movimiento del Plato Divisor sin Presión Hidráulica" ;
    ns1:textoExtracto "Para que el movimiento del plato divisor pueda llevarse a cabo interviene un servomotor y presión hidráulica." .

ns1:SistemaHidraulicoCilindroPlatoDivisor a ns1:Sistema ;
    rdfs:label "Sistema Hidráulico del Cilindro para el Plato Divisor" ;
    ns1:controla ns1:ServomotorParaPlatoDivisor ;
    ns1:textoExtracto "El cilindro hidráulico permite que el engranaje superior del 'DENTADO HIRTH' se mueva verticalmente, liberando los dientes del engranaje inferior." .

ns1:ServomotorParaPlatoDivisor a ns1:ComponenteElectrico ;
    rdfs:label "Servomotor para Plato Divisor" ;
    ns1:textoExtracto "El servomotor gira el plato una vez que el dentado HIRTH está liberado." .

