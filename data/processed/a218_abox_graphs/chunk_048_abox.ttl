@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CilindroHidraulico_48 a ns1:ComponenteHidraulico ;
    rdfs:label "cilindro hidráulico"@es ;
    ns1:alimenta ns1:DentadoHirth_48 ;
    ns1:textoExtracto "El cilindro hidráulico permite que el engranaje superior del 'DENTADO HIRTH' se mueva verticalmente"@es .

ns1:Figura4_5_48 a ns1:Figura ;
    rdfs:label "Figura 4-5. Bases del plato divisor (0º y 15º)"@es ;
    ns1:textoExtracto "Figura 4-5. Bases del plato divisor (0º y 15º)"@es .

ns1:PlatoDivisor_48 a ns1:ComponenteMecanico ;
    rdfs:label "plato divisor"@es ;
    ns1:compuestoPor ns1:DentadoHirth_48 ;
    ns1:detalladoEnEsquema ns1:Figura4_4_48 ;
    ns1:textoExtracto "El plato divisor de la máquina va colocado sobre el carro porta-piezas y dispone de un dentado Hirth con capacidad para hacer divisiones de 1º."@es ;
    ns1:tieneComponente ns1:BaseInclinada_48,
        ns1:BasePlana_48 .

ns1:BaseInclinada_48 a ns1:ComponenteMecanico ;
    rdfs:label "base inclinada del plato divisor"@es ;
    ns1:textoExtracto "otra inclinada para brochar a 15º."@es .

ns1:BasePlana_48 a ns1:ComponenteMecanico ;
    rdfs:label "base plana del plato divisor"@es ;
    ns1:textoExtracto "El plato divisor dispone de dos bases, una plana para brochar a 0º"@es .

ns1:EngranajeInferior_48 a ns1:ComponenteMecanico ;
    rdfs:label "engranaje inferior del dentado Hirth"@es ;
    ns1:textoExtracto "liberando los dientes del engranaje inferior."@es .

ns1:EngranajeSuperior_48 a ns1:ComponenteMecanico ;
    rdfs:label "engranaje superior del dentado Hirth"@es ;
    ns1:textoExtracto "El cilindro hidráulico permite que el engranaje superior del 'DENTADO HIRTH' se mueva verticalmente, liberando los dientes del engranaje inferior."@es .

ns1:Figura4_4_48 a ns1:Figura ;
    rdfs:label "Figura 4-4. Plato divisor"@es ;
    ns1:textoExtracto "Figura 4-4. Plato divisor"@es .

ns1:Servomotor_48 a ns1:ComponenteElectrico ;
    rdfs:label "servomotor"@es ;
    ns1:controla ns1:DentadoHirth_48 ;
    ns1:monitoreaParametro ns1:SQ46_48,
        ns1:SQ47_48 ;
    ns1:textoExtracto "Para que el movimiento del plato divisor pueda llevarse a cabo interviene un servomotor"@es .

ns1:SQ46_48 a ns1:Sensor ;
    rdfs:label "SQ46"@es ;
    ns1:textoExtracto "SQ46: MESA ABAJO (BLOQUEADO)"@es .

ns1:SQ47_48 a ns1:Sensor ;
    rdfs:label "SQ47"@es ;
    ns1:textoExtracto "SQ47: MESA ARRIBA (DESBLOQUEADO)"@es .

ns1:DentadoHirth_48 a ns1:ComponenteMecanico ;
    rdfs:label "dentado Hirth"@es ;
    ns1:compuestoPor ns1:EngranajeInferior_48,
        ns1:EngranajeSuperior_48 ;
    ns1:controla ns1:Servomotor_48 ;
    ns1:monitoreaParametro ns1:SQ46_48,
        ns1:SQ47_48 ;
    ns1:textoExtracto "dispone de un dentado Hirth con capacidad para hacer divisiones de 1º."@es .

