@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CablesDelMotor_82d2ec8b20 a ns1:ComponenteElectrico ;
    rdfs:label "Cables del motor" ;
    ns1:textoExtracto "Desconectar los cables del motor y de la torreta de micros;" .

ns1:CambioDeBase0o15o15o0o a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de base (0º - 15º / 15º - 0º)"@es ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:requiereConsumible ns1:AceiteHidraulicoISO46 ;
    ns1:textoExtracto "Para realizar el cambio de base seguir los siguientes pasos:" .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    rdfs:label "Máquina Brochadora Electromecánica Exterior A218" ;
    ns1:textoExtracto "Consignar la máquina para realizar la operación." .

ns1:SistemaHidraulicoBase a ns1:Sistema ;
    rdfs:label "Sistema Hidráulico Base" ;
    ns1:textoExtracto "soltar los tubos hidráulicos" ;
    ns1:tieneComponente ns1:TornilloAjustePlatoDivisor,
        ns1:TornilloBasePlatoDivisor .

ns1:TornilloAjustePlatoDivisor a ns1:ComponenteMecanico ;
    rdfs:label "Tornillos de ajuste del plato divisor" ;
    ns1:textoExtracto "Soltar los tres tornillos que fijan las piezas de ajuste del plato." .

ns1:TornilloBasePlatoDivisor a ns1:ComponenteMecanico ;
    rdfs:label "Tornillos que fijan la base del plato divisor" ;
    ns1:textoExtracto "Soltar los tornillos que fijan la base del plato divisor al carro porta-piezas." .

