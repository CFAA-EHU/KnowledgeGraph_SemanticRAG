@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CarroPortaBrochas a ns1:ComponenteMecanico ;
    rdfs:label "carro porta-brochas" ;
    ns1:textoExtracto "Sobre el carro porta-brochas van amarradas las herramientas y está fijado a la columna." .

ns1:Columna a ns1:ComponenteMecanico ;
    ns1:textoExtracto "está fijado a la columna" .

ns1:Herramienta a ns1:Herramienta ;
    ns1:textoExtracto "van amarradas las herramientas" .

