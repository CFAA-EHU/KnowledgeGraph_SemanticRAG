@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioDePortaCremalleras_cd86ca8cdc a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de porta-cremalleras" ;
    ns1:ejecutadoPor ns1:PersonalOperario ;
    ns1:textoExtracto "La máquina dispone de dos plataformas a distintas alturas, una en cada lateral de la máquina, con una puerta para acceder al interior de la máquina y realizar el cambio de herramienta." .

ns1:CarroPortaPiezas_a3320037d6 a ns1:Componente ;
    rdfs:label "Carro porta-piezas" ;
    ns1:textoExtracto "El carro porta-piezas baja a la posición inferior (1)" .

ns1:PortonPrincipal a ns1:Componente ;
    rdfs:label "Portón principal" ;
    ns1:textoExtracto "tanto la de la plataforma izquierda como el portón principal permanecen cerrados y bloqueados." .

ns1:PuertaDerecha a ns1:Componente ;
    rdfs:label "Puerta derecha" ;
    ns1:textoExtracto "El operario sube por la plataforma derecha, abre la puerta y accede al interior de la máquina." .

ns1:PuertaIzquierda a ns1:Componente ;
    rdfs:label "Puerta izquierda" ;
    ns1:textoExtracto "En esta situación, se permite la apertura de la puerta lateral izquierda para el acceso del operario y la del portón frontal para el acceso de la grúa." .

ns1:PersonalOperario a ns1:Personal ;
    rdfs:label "Operario" ;
    ns1:textoExtracto "El operario sube por la plataforma derecha, abre la puerta y accede al interior de la máquina." .

