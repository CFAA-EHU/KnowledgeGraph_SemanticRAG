@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BQ740 a ns1:Sensor ;
    rdfs:label "CEPILLO AVANZADO" ;
    ns1:identificador "BQ740" ;
    ns1:textoExtracto "BQ740: CEPILLO AVANZADO" .

ns1:BQ741 a ns1:Sensor ;
    rdfs:label "CEPILLO RETROCEDIDO" ;
    ns1:identificador "BQ741" ;
    ns1:textoExtracto "BQ741: CEPILLO RETROCEDIDO" .

ns1:CepillosLimpiezaBrochas_53 a ns1:Componente ;
    rdfs:label "cepillos" ;
    ns1:textoExtracto "compuesto por ... unos cepillos" .

ns1:CilindroNeumaticoGuiado_53 a ns1:Componente ;
    rdfs:label "cilindro neumático guiado" ;
    ns1:textoExtracto "compuesto por un cilindro neumático guiado" .

ns1:Figura4_14_53 a ns1:Figura ;
    ns1:identificador "4-14" ;
    ns1:ilustradoEn ns1:SistemaLimpiezaBrochas_53 ;
    ns1:textoExtracto "Figura 4-14. Sistema de limpieza" .

ns1:SistemaLimpiezaBrochas_53 a ns1:Sistema ;
    ns1:compuestoPor ns1:CepillosLimpiezaBrochas_53,
        ns1:CilindroNeumaticoGuiado_53 ;
    ns1:detalladoEnEsquema ns1:Figura4_14_53 ;
    ns1:textoExtracto "La máquina dispone de un sistema de limpieza de brochas situado en la parte superior del carro porta-piezas compuesto por un cilindro neumático guiado y unos cepillos." .

