@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaLimpiezaBrochas a ns1:Sistema ;
    rdfs:label "Sistema de limpieza de brochas" ;
    ns1:monitoreaParametro ns1:CEPILLOAVANZADO_a741e73b86,
        ns1:CEPILLORETROCEDIDO_3a42284840 ;
    ns1:textoExtracto "La máquina dispone de un sistema de limpieza de brochas situado en la parte superior del carro porta-piezas compuesto por un cilindro neumático guiado y unos cepillos." ;
    ns1:tieneComponente ns1:CilindroNeumatico_2e1a0d87c3,
        ns1:Componente_09e8ac4b41 .

ns1:CEPILLOAVANZADO_a741e73b86 a ns1:Parametro ;
    rdfs:label "CEPILLO AVANZADO" ;
    ns1:identificador "BQ740" ;
    ns1:textoExtracto "- BQ740: CEPILLO AVANZADO" .

ns1:CEPILLORETROCEDIDO_3a42284840 a ns1:Parametro ;
    rdfs:label "CEPILLO RETROCEDIDO" ;
    ns1:identificador "BQ741" ;
    ns1:textoExtracto "- BQ741: CEPILLO RETROCEDIDO" .

ns1:CilindroNeumatico_2e1a0d87c3 a ns1:Componente ;
    rdfs:label "Cilindro neumático" ;
    ns1:textoExtracto "El cilindro permanece retrocedido durante el movimiento de brochado (subida del carro porta-piezas)" .

ns1:Componente_09e8ac4b41 a ns1:Componente ;
    rdfs:label "Cepillos" ;
    ns1:textoExtracto "los cepillos limpian la brocha mientras el carro porta-piezas desciende." .

