@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:sistemaNeumaticoYP
    a ex:Sistema ;
    rdfs:label "Sistema neumático de la máquina" ;
    ex:textoExtracto "El sistema neumático está situado en la parte posterior de la máquina. Está compuesto por una válvula neumática de mando manual, un filtro regulador de presión, un secador de aire, manómetros, un lubricador, presostatos, reguladores de presión, electroválvulas, silenciadores, etc." ;
    ex:tieneComponente ex:valvulaManualYP, ex:filtroReguladorYP, ex:secadorAireYP, ex:manometroGeneralYP, ex:manometroReglasYP, ex:lubricadorYP, ex:presostatoYP, ex:reguladorPresionYP, ex:electrovalvulaYP901, ex:electrovalvulaYP902, ex:electrovalvulaYP903, ex:silenciadorYP ;
    ex:ilustradoEn ex:figura4_15 ;
    ex:identificador "YP" .

ex:valvulaManualYP
    a ex:ComponenteHidraulico ;
    rdfs:label "Válvula neumática de mando manual" ;
    ex:textoExtracto "válvula neumática de mando manual" .

