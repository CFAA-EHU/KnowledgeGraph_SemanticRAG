@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PresionAireReglasLineales a ns1:Parametro ;
    rdfs:label "Presión Aire Reglas Lineales" ;
    ns1:identificador "BP711" ;
    ns1:textoExtracto "- BP711: PRESIÓN AIRE REGLAS LINEALES YP901 – YP902 YP903 YP801 BP711 BP710" .

ns1:PresionGeneralDeAire a ns1:Parametro ;
    rdfs:label "Presión General de Aire" ;
    ns1:identificador "BP710" ;
    ns1:textoExtracto "- BP710: PRESIÓN GENERAL DE AIRE" .

ns1:SistemaNeumaticoMaquinaBrochadora a ns1:Sistema ;
    rdfs:label "Sistema Neumático" ;
    ns1:textoExtracto "El sistema neumático está situado en la parte posterior de la máquina. Está compuesto por una válvula neumática de mando manual, un filtro regulador de presión, un secador de aire, manómetros, un lubricador, presostatos, reguladores de presión, electroválvulas, silenciadores, etc." ;
    ns1:tieneComponente ns1:ELECTROVALVULA_AVANZAR_CEPILLO,
        ns1:FiltroReguladorPresion,
        ns1:Lubricador,
        ns1:ManometroGeneral,
        ns1:Presostato1_f4391f966b,
        ns1:ReguladorDePresion1,
        ns1:SILENCIADOR_YP902,
        ns1:SecadorAire,
        ns1:ValvulaNeumaticaMandoManual .

ns1:ELECTROVALVULA_AVANZAR_CEPILLO a ns1:Componente ;
    rdfs:label "Electroválvula Avanzar Cepillo" ;
    ns1:identificador "YP901" ;
    ns1:textoExtracto "- YP901: AVANZAR CEPILLO" .

ns1:FiltroReguladorPresion a ns1:Componente ;
    rdfs:label "Filtro Regulador de Presión" ;
    ns1:textoExtracto "un filtro regulador de presión" .

ns1:Lubricador a ns1:Componente ;
    rdfs:label "Lubricador" ;
    ns1:textoExtracto "un lubricador" .

ns1:ManometroGeneral a ns1:Componente ;
    rdfs:label "Manómetro General" ;
    ns1:identificador "BP710" ;
    ns1:textoExtracto "manómetros" .

ns1:Presostato1_f4391f966b a ns1:Componente ;
    rdfs:label "Presostato 1" ;
    ns1:textoExtracto "presostatos" .

ns1:ReguladorDePresion1 a ns1:Componente ;
    rdfs:label "Regulador de Presión 1" ;
    ns1:textoExtracto "reguladores de presión" .

ns1:SILENCIADOR_YP902 a ns1:Componente ;
    rdfs:label "Silenciador YP902" ;
    ns1:identificador "YP902" ;
    ns1:textoExtracto "- YP902: RETROCEDER CEPILLO" .

ns1:SecadorAire a ns1:Componente ;
    rdfs:label "Secador de Aire" ;
    ns1:textoExtracto "un secador de aire" .

ns1:ValvulaNeumaticaMandoManual a ns1:Componente ;
    rdfs:label "Válvula Neumática de Mando Manual" ;
    ns1:textoExtracto "una válvula neumática de mando manual" .

