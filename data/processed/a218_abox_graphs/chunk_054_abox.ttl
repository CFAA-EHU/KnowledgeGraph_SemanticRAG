@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionCepilloLimieza_YP a ns1:AccionProhibida ;
    rdfs:label "Accionar cepillo de limpieza"@es ;
    ns1:textoExtracto "accionar el cepillo de limpieza brocha"@es .

ns1:AccionCortarRefrigerante_YP a ns1:AccionProhibida ;
    rdfs:label "Cortar refrigerante de limpieza bastidor"@es ;
    ns1:textoExtracto "cortar el refrigerante de limpieza bastidor"@es .

ns1:AccionPresurizarReglas_YP a ns1:AccionProhibida ;
    rdfs:label "Presurizar reglas de captación y la mesa"@es ;
    ns1:textoExtracto "presurizar las reglas de captación y la mesa"@es .

ns1:AvanzarCepillo_YP901 a ns1:Componente ;
    rdfs:label "YP901: AVANZAR CEPILLO"@es ;
    ns1:identificador "YP901" ;
    ns1:textoExtracto "YP901: AVANZAR CEPILLO"@es .

ns1:EntradaGeneralAire_YP801 a ns1:Componente ;
    rdfs:label "YP801: ENTRADA GENERAL DE AIRE"@es ;
    ns1:identificador "YP801" ;
    ns1:textoExtracto "YP801: ENTRADA GENERAL DE AIRE"@es .

ns1:Figura4_15 a ns1:Figura ;
    rdfs:label "Figura 4-15"@es ;
    ns1:ilustradoEn ns1:SistemaNeumatico_YP ;
    ns1:textoExtracto "Figura 4-15. Sistema neumático"@es .

ns1:PresionAireReglasLineales_BP711 a ns1:Sensor ;
    rdfs:label "BP711: PRESIÓN AIRE REGLAS LINEALES"@es ;
    ns1:identificador "BP711" ;
    ns1:textoExtracto "BP711: PRESIÓN AIRE REGLAS LINEALES"@es .

ns1:PresionGeneralAire_BP710 a ns1:Sensor ;
    rdfs:label "BP710: PRESIÓN GENERAL DE AIRE"@es ;
    ns1:identificador "BP710" ;
    ns1:textoExtracto "BP710: PRESIÓN GENERAL DE AIRE"@es .

ns1:RefrigeranteLimpiezaBastidor_YP903 a ns1:Componente ;
    rdfs:label "YP903: REFRIGERANTE LIMPIEZA BASTIDOR"@es ;
    ns1:identificador "YP903" ;
    ns1:textoExtracto "YP903: REFRIGERANTE LIMPIEZA BASTIDOR"@es .

ns1:RetrocederCepillo_YP902 a ns1:Componente ;
    rdfs:label "YP902: RETROCEDER CEPILLO"@es ;
    ns1:identificador "YP902" ;
    ns1:textoExtracto "YP902: RETROCEDER CEPILLO"@es .

ns1:Electrovalvula_YP a ns1:ComponenteElectrico ;
    rdfs:label "Electroválvula"@es ;
    ns1:textoExtracto "electroválvulas"@es .

ns1:FiltroReguladorPresion_YP a ns1:Componente ;
    rdfs:label "Filtro regulador de presión"@es ;
    ns1:textoExtracto "un filtro regulador de presión"@es .

ns1:Lubricador_YP a ns1:Componente ;
    rdfs:label "Lubricador"@es ;
    ns1:textoExtracto "un lubricador"@es .

ns1:Manometro_YP a ns1:Sensor ;
    rdfs:label "Manómetro"@es ;
    ns1:textoExtracto "manómetros"@es .

ns1:Presostato_YP a ns1:Sensor ;
    rdfs:label "Presostato"@es ;
    ns1:textoExtracto "presostatos"@es .

ns1:ReguladorPresion_YP a ns1:Componente ;
    rdfs:label "Regulador de presión"@es ;
    ns1:textoExtracto "reguladores de presión"@es .

ns1:SecadorAire_YP a ns1:Componente ;
    rdfs:label "Secador de aire"@es ;
    ns1:textoExtracto "un secador de aire"@es .

ns1:Silenciador_YP a ns1:Componente ;
    rdfs:label "Silenciador"@es ;
    ns1:textoExtracto "silenciadores"@es .

ns1:SistemaNeumatico_YP a ns1:Sistema ;
    rdfs:label "Sistema neumático"@es ;
    ns1:compuestoPor ns1:Electrovalvula_YP,
        ns1:FiltroReguladorPresion_YP,
        ns1:Lubricador_YP,
        ns1:Manometro_YP,
        ns1:Presostato_YP,
        ns1:ReguladorPresion_YP,
        ns1:SecadorAire_YP,
        ns1:Silenciador_YP,
        ns1:ValvulaNeumaticaMandoManual_YP ;
    ns1:textoExtracto "El sistema neumático está situado en la parte posterior de la máquina. Está compuesto por una válvula neumática de mando manual, un filtro regulador de presión, un secador de aire, manómetros, un lubricador, presostatos, reguladores de presión, electroválvulas, silenciadores, etc."@es .

ns1:ValvulaNeumaticaMandoManual_YP a ns1:Componente ;
    rdfs:label "Válvula neumática de mando manual"@es ;
    ns1:textoExtracto "una válvula neumática de mando manual"@es .

