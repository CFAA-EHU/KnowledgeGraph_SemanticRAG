@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaEngrasePrincipal a ns1:Sistema ;
    rdfs:label "Sistema de engrase" ;
    ns1:textoExtracto "El sistema de engrase se encuentra situado en la parte posterior de la máquina, debajo del sistema neumático." ;
    ns1:tieneComponente ns1:SistemaLubricacionAutomatica,
        ns1:SistemaLubricacionManual .

ns1:BombaEmboloManual a ns1:ComponenteMecanico ;
    rdfs:label "Bomba de émbolo con mando manual" ;
    ns1:textoExtracto "El engrase manual está compuesto por una bomba de émbolo con mando manual que se encarga de lubricar los rodamientos de los piñones superiores." .

ns1:CentralLubricacionAutomatica a ns1:ComponenteElectrico ;
    rdfs:label "Central de lubricación" ;
    ns1:textoExtracto "El engrase automático está compuesto por una central de lubricación y un piñón que lubrica el sistema piñón-cremallera." .

ns1:PinonLubricanteAutomatico a ns1:ComponenteMecanico ;
    rdfs:label "Piñón de lubricación" ;
    ns1:textoExtracto "El piñón de lubricación es de espuma de poliuretano de célula abierta y garantiza un suministro óptimo de lubricante durante largos periodos de tiempo." .

ns1:SistemaLubricacionAutomatica a ns1:Sistema ;
    rdfs:label "Engrase automático de grasa" ;
    ns1:compuestoPor ns1:CentralLubricacionAutomatica,
        ns1:PinonLubricanteAutomatico ;
    ns1:textoExtracto "El engrase automático está compuesto por una central de lubricación y un piñón que lubrica el sistema piñón-cremallera." .

ns1:SistemaLubricacionManual a ns1:Sistema ;
    rdfs:label "Engrase manual de aceite" ;
    ns1:compuestoPor ns1:BombaEmboloManual ;
    ns1:textoExtracto "El engrase manual está compuesto por una bomba de émbolo con mando manual que se encarga de lubricar los rodamientos de los piñones superiores." .

