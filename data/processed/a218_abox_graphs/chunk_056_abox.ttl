@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:sistemaHidraulicoMaquina
    a ex:Sistema ;
    rdfs:label "Sistema hidráulico"@es ;
    ex:textoExtracto "El sistema hidráulico se encuentra en el lateral izquierdo de la máquina y está compuesto por una bomba de pistones, un indicador de nivel con termómetro, un sensor de nivel, semi-acoplamientos, un motor, una reductora de presión, electroválvulas, un presostato electrónico, un manómetro vertical y un filtro."@es ;
    ex:tieneComponente ex:bombaPistones, ex:indicadorNivelTermometro, ex:sensorNivel, ex:semiAcoplamientos, ex:motorGrupoHidraulico, ex:reductoraPresion, ex:electrovalvulas, ex:presostatoElectronico, ex:manometroVertical, ex:filtroHidraulico ;
    ex:compuestoPor ex:bombaPistones, ex:indicadorNivelTermometro, ex:sensorNivel, ex:semiAcoplamientos, ex:motorGrupoHidraulico, ex:reductoraPresion, ex:electrovalvulas, ex:presostatoElectronico, ex:manometroVertical, ex:filtroHidraulico ;
    ex:ilustradoEn ex:figura4_17 .

ex:bombaPistones
    a ex:ComponenteHidraulico ;
    rdfs:label "Bomba de pistones"@es ;
    ex:textoExtracto "una bomba de pistones"@es .

ex:indicadorNivelTermometro
    a ex:ComponenteHidraulico ;
    rdfs:label "Indicador de nivel con termómetro"@es ;
    ex:textoExtracto "un indicador de nivel con termómetro"@es .

ex:sensorNivel
    a ex:Sensor ;
    rdfs:label "Sensor de nivel"@es ;
    ex:textoExtracto "un sensor de nivel"@es .

ex:semiAcoplamientos
    a ex:ComponenteMecanico ;
    rdfs:label "Semi-acoplamientos"@es ;
    ex:textoExtracto "semi-acoplamientos"@es .

ex:motorGrupoHidraulico
    a ex:ComponenteHidraulico ;
    rdfs:label "Motor del grupo hidráulico"@es ;
    ex:identificador "M6" ;
    ex:textoExtracto "M6: MOTOR GRUPO HIDRÁULICO"@es .

ex:reductoraPresion
    a ex:ComponenteHidraulico ;
    rdfs:label "Reductora de presión"@es ;
    ex:textoExtracto "una reductora de presión"@es .

ex:electrovalvulas
    a ex:ComponenteHidraulico ;
    rdfs:label "Electroválvulas"@es ;
    ex:textoExtracto "electroválvulas"@es .

ex:presostatoElectronico
    a ex:ComponenteElectrico ;
    rdfs:label "Presostato electrónico"@es ;
    ex:identificador "BP714" ;
    ex:textoExtracto "un presostato electrónico [...] BP714: MESA ABAJO PRESOSTATO"@es .

ex:manometroVertical
    a ex:ComponenteHidraulico ;
    rdfs:label "Manómetro vertical"@es ;
    ex:textoExtracto "un manómetro vertical"@es .

ex:filtroHidraulico
    a ex:ComponenteHidraulico ;
    rdfs:label "Filtro hidráulico"@es ;
    ex:textoExtracto "un filtro"@es .

ex:figura4_17
    a ex:Figura ;
    rdfs:label "Figura 4-17. Sistema hidráulico"@es ;
    ex:identificador "4-17" ;
    ex:textoExtracto "Figura 4-17. Sistema hidráulico"@es .

ex:alarmaNivelMinimo
    a ex:Alarma ;
    rdfs:label "Nivel mínimo del grupo hidráulico"@es ;
    ex:identificador "BL726" ;
    ex:textoExtracto "BL726: NIVEL MÍNIMO GRUPO HIDRÁULICO"@es ;
    ex:activaAlarma ex:sensorNivel .

ex:accionMesaArriba
    a ex:ModoOperacion ;
    rdfs:label "Mesa arriba"@es ;
    ex:identificador "YP802" ;
    ex:textoExtracto "YP802: MESA ARRIBA"@es .

ex:accionMesaAbajo
    a ex:ModoOperacion ;
    rdfs:label "Mesa abajo"@es ;
    ex:identificador "YP803" ;
    ex:textoExtracto "YP803: MESA ABAJO"@es .

ex:accionFrenoDesbloqueo
    a ex:ModoOperacion ;
    rdfs:label "Freno Mayr desbloqueo"@es ;
    ex:identificador "YP900" ;
    ex:textoExtracto "YP900: FRENO MAYR DESBLOQUEO"@es .

ex:bloqueoCarroDesbloqueado
    a ex:ModoOperacion ;
    rdfs:label "Bloqueo Mayr carro tracción desbloqueado"@es ;
    ex:identificador "BP727" ;
    ex:textoExtracto "BP727: BLOQUEO MAYR CARRO TRACCIÓN DESBLOQUEADO"@es .