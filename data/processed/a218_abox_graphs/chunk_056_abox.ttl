ns1:ComponenteElectrico_d97ed297a0 a ns1:ComponenteElectrico ;
    rdfs:label "MOTOR GRUPO HIDRÁULICO" ;
    ns1:identificador "M6" ;
    ns1:textoExtracto "- M6: MOTOR GRUPO HIDRÁULICO - BL726: NIVEL MÍNIMO GRUPO HIDRÁULICO - YP802: MESA ARRIBA - YP803: MESA ABAJO - YP900: FRENO MAYR DESBLOQUEO - BP714: MESA ABAJO PRESOSTATO - BP727: BLOQUEO MAYR CARRO TRACCION DESBLOQUEADO" .

