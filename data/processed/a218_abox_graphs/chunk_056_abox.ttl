@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SemiAcoplamamientosSistemaHidraulico a ns1:Componente ;
    rdfs:label "Semi-acoplamientos" ;
    ns1:textoExtracto "El sistema hidráulico se encuentra en el lateral izquierdo de la máquina y está compuesto por una bomba de pistones, un indicador de nivel con termómetro, un sensor de nivel, semi- acoplamamientos, un motor, una reductora de presión, electroválvulas, un presostato electrónico, un manómetro vertical y un filtro." .

ns1:SistemaHidraulicoLateralIzquierdo a ns1:Sistema ;
    rdfs:label "Sistema hidráulico" ;
    ns1:textoExtracto "El sistema hidráulico se encuentra en el lateral izquierdo de la máquina y está compuesto por una bomba de pistones, un indicador de nivel con termómetro, un sensor de nivel, semi- acoplamientos, un motor, una reductora de presión, electroválvulas, un presostato electrónico, un manómetro vertical y un filtro." ;
    ns1:tieneComponente ns1:BombaDePistonesSistemaHidraulico,
        ns1:ComponenteElectrico_d97ed297a0,
        ns1:Componente_e2ca13bb33,
        ns1:EletrovalvulasSistemaHidraulico,
        ns1:FiltroSistemaHidraulico,
        ns1:IndicadorNivelConTermometro,
        ns1:ManometroVerticalSistemaHidraulico,
        ns1:PresostatoElectronicoSistemaHidraulico,
        ns1:ReductoraPresionSistemaHidraulico,
        ns1:SemiAcoplamientosSistemaHidraulico .

