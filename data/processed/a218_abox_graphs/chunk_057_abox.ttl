ex:sistema_refrigeracion_57
    a                   ex:Sistema ;
    rdfs:label          "Sistema de refrigeración" ;
    ex:textoExtracto    "La máquina dispone de un sistema de refrigeración que tiene como objetico principal el evitar el calentamiento excesivo de la herramienta y de la pieza durante el brochado, además de evitar que se queden virutas en lugares indeseados." ;
    ex:tieneComponente   ex:motor_M1_57, ex:motor_M3_57, ex:motor_M4_57, ex:motor_M5_57,
                        ex:sensor_BN41_57, ex:sensor_SQ40_57, ex:sensor_BN42_57, ex:sensor_BC44_57 ;
    ex:ilustradoEn       ex:figura_4_18_57 .

ex:motor_M1_57
    a                   ex:ComponenteElectrico ;
    rdfs:label          "MOTOR REFRIGERANTE DE FILTRO PAPEL (M1)" ;
