@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaFiltracionAceite_57 a ns1:Sistema ;
    rdfs:label "sistema de filtración"@es ;
    ns1:textoExtracto "y a través de una bomba se envía al sistema de filtración."@es .

ns1:SistemaRefrigeracion_57 a ns1:Sistema ;
    rdfs:label "sistema de refrigeración"@es ;
    ns1:compuestoPor ns1:BombaAceiteCorte_57,
        ns1:CaudalRefrigerante_BC44,
        ns1:MotorExtractorVirutas_M5,
        ns1:MotorRefrigeranteFiltroPapel_M1,
        ns1:MotorRefrigeranteMaquina_M3,
        ns1:MotorTrasvaseRefrigerante_M4,
        ns1:NivelRefrigeranteSucio_BN41,
        ns1:NivelRefrigerante_BN42,
        ns1:PresenciaPapel_SQ40,
        ns1:ZocaloAceiteCorte_57 ;
    ns1:ilustradoEn ns1:Figura4_18 ;
    ns1:textoExtracto "La máquina dispone de un sistema de refrigeración que tiene como objetico principal el evitar el calentamiento excesivo de la herramienta y de la pieza durante el brochado, además de evitar que se queden virutas en lugares indeseados."@es .

ns1:BombaAceiteCorte_57 a ns1:Componente ;
    rdfs:label "bomba"@es ;
    ns1:textoExtracto "y a través de una bomba se envía al sistema de filtración"@es .

ns1:CaudalRefrigerante_BC44 a ns1:Sensor ;
    rdfs:label "CAUDAL REFRIGERANTE"@es ;
    ns1:identificador "BC44" ;
    ns1:textoExtracto "BC44: CAUDAL REFRIGERANTE"@es .

ns1:Figura4_18 a ns1:Figura ;
    rdfs:label "Figura 4-18"@es ;
    ns1:textoExtracto "Figura 4-18. Sistema de refrigeración"@es .

ns1:MotorExtractorVirutas_M5 a ns1:ComponenteElectrico ;
    rdfs:label "MOTOR EXTRACTOR DE VIRUTAS"@es ;
    ns1:identificador "M5" ;
    ns1:textoExtracto "M5: MOTOR EXTRACTOR DE VIRUTAS"@es .

ns1:MotorRefrigeranteFiltroPapel_M1 a ns1:ComponenteElectrico ;
    rdfs:label "MOTOR REFRIGERANTE DE FILTRO PAPEL"@es ;
    ns1:identificador "M1" ;
    ns1:textoExtracto "M1: MOTOR REFRIGERANTE DE FILTRO PAPEL"@es .

ns1:MotorRefrigeranteMaquina_M3 a ns1:ComponenteElectrico ;
    rdfs:label "MOTOR REFRIGERANTE MÁQUINA"@es ;
    ns1:identificador "M3" ;
    ns1:textoExtracto "M3: MOTOR REFRIGERANTE MÁQUINA"@es .

ns1:MotorTrasvaseRefrigerante_M4 a ns1:ComponenteElectrico ;
    rdfs:label "MOTOR TRASVASE REFRIGERANTE"@es ;
    ns1:identificador "M4" ;
    ns1:textoExtracto "M4: MOTOR TRASVASE REFRIGERANTE"@es .

ns1:NivelRefrigeranteSucio_BN41 a ns1:Sensor ;
    rdfs:label "NIVEL REFRIGERANTE SUCIO"@es ;
    ns1:identificador "BN41" ;
    ns1:textoExtracto "BN41: NIVEL REFRIGERANTE SUCIO"@es .

ns1:NivelRefrigerante_BN42 a ns1:Sensor ;
    rdfs:label "NIVEL REFRIGERANTE"@es ;
    ns1:identificador "BN42" ;
    ns1:textoExtracto "BN42: NIVEL REFRIGERANTE"@es .

ns1:PresenciaPapel_SQ40 a ns1:Sensor ;
    rdfs:label "PRESENCIA DE PAPEL"@es ;
    ns1:identificador "SQ40" ;
    ns1:textoExtracto "SQ40: PRESENCIA DE PAPEL"@es .

ns1:ZocaloAceiteCorte_57 a ns1:Componente ;
    rdfs:label "zócalo"@es ;
    ns1:textoExtracto "Todo el aceite de corte utilizado durante el proceso de brochado queda acumulado en el zócalo"@es .

