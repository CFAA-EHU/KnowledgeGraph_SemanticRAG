@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaRefrigeracionMaquinaBrochadora a ns1:Sistema ;
    rdfs:label "Sistema de refrigeración" ;
    ns1:monitoreaParametro ns1:CAUDALREFRIGERANTE,
        ns1:NIVELREFRIGERANTE,
        ns1:NIVELREFRIGERANTESUCIO,
        ns1:PRESENCIADEPAPEL ;
    ns1:textoExtracto "La máquina dispone de un sistema de refrigeración que tiene como objetico principal el evitar el calentamiento excesivo de la herramienta y de la pieza durante el brochado, además de evitar que se queden virutas en lugares indeseados." ;
    ns1:tieneComponente ns1:ComponenteElectrico_015b0878b2,
        ns1:ComponenteElectrico_143a5c1ced,
        ns1:ComponenteElectrico_1e6dd8f594,
        ns1:ComponenteElectrico_b109a7c7d7 .

ns1:CAUDALREFRIGERANTE a ns1:Parametro ;
    rdfs:label "CAUDAL REFRIGERANTE" ;
    ns1:identificador "BC44" ;
    ns1:textoExtracto "- BC44: CAUDAL REFRIGERANTE" .

ns1:ComponenteElectrico_015b0878b2 a ns1:ComponenteElectrico ;
    rdfs:label "MOTOR EXTRACTOR DE VIRUTAS" ;
    ns1:identificador "M5" ;
    ns1:textoExtracto "- M5: MOTOR EXTRACTOR DE VIRUTAS" .

ns1:ComponenteElectrico_143a5c1ced a ns1:ComponenteElectrico ;
    rdfs:label "MOTOR TRASVASE REFRIGERANTE" ;
    ns1:identificador "M4" ;
    ns1:textoExtracto "- M4: MOTOR TRASVASE REFRIGERANTE" .

ns1:ComponenteElectrico_1e6dd8f594 a ns1:ComponenteElectrico ;
    rdfs:label "MOTOR REFRIGERANTE MÁQUINA" ;
    ns1:identificador "M3" ;
    ns1:textoExtracto "- M3: MOTOR REFRIGERANTE MÁQUINA" .

ns1:ComponenteElectrico_b109a7c7d7 a ns1:ComponenteElectrico ;
    rdfs:label "MOTOR REFRIGERANTE DE FILTRO PAPEL" ;
    ns1:identificador "M1" ;
    ns1:textoExtracto "- M1: MOTOR REFRIGERANTE DE FILTRO PAPEL" .

ns1:NIVELREFRIGERANTE a ns1:Parametro ;
    rdfs:label "NIVEL REFRIGERANTE" ;
    ns1:identificador "BN42" ;
    ns1:textoExtracto "- BN42: NIVEL REFRIGERANTE" .

ns1:NIVELREFRIGERANTESUCIO a ns1:Parametro ;
