@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaPLCControlMovimiento a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:controladoPor ns1:ArmarioElectrico ;
    ns1:textoExtracto "Dispone de un PLC que controla el movimiento secuencial de los diferentes mecanismos de la máquina." .

ns1:ArmarioElectrico a ns1:ComponenteElectrico ;
    rdfs:label "Armario eléctrico" ;
    ns1:alimentadoPor ns1:Entity380Volt,
        ns1:Entity50Hz ;
    ns1:textoExtracto "El armario eléctrico está colocado en la parte derecha de la máquina y es alimentado a 380 volt - 50 Hz." .

ns1:Entity380Volt a ns1:Parametro ;
    rdfs:label "380 volt" ;
    ns1:textoExtracto "El armario eléctrico está colocado en la parte derecha de la máquina y es alimentado a 380 volt - 50 Hz." .

ns1:Entity50Hz a ns1:Parametro ;
    rdfs:label "50 Hz" ;
    ns1:textoExtracto "El armario eléctrico está colocado en la parte derecha de la máquina y es alimentado a 380 volt - 50 Hz." .

