@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArmarioElectrico58 a ns1:ComponenteElectrico ;
    rdfs:label "Armario eléctrico"@es ;
    ns1:alimenta ns1:Maquina58 ;
    ns1:compuestoPor ns1:PLC58 ;
    ns1:textoExtracto "El armario eléctrico está colocado en la parte derecha de la máquina y es alimentado a 380 volt - 50 Hz. Dispone de un PLC que controla el movimiento secuencial de los diferentes mecanismos de la máquina."@es .

ns1:Maquina58 a ns1:Maquina ;
    rdfs:label "máquina"@es ;
    ns1:textoExtracto "El armario eléctrico está colocado en la parte derecha de la máquina y es alimentado a 380 volt - 50 Hz. Dispone de un PLC que controla el movimiento secuencial de los diferentes mecanismos de la máquina."@es .

ns1:MovimientoSecuencial58 a ns1:ModoOperacion ;
    rdfs:label "movimiento secuencial"@es ;
    ns1:textoExtracto "controla el movimiento secuencial de los diferentes mecanismos de la máquina."@es .

ns1:PLC58 a ns1:ComponenteElectrico ;
    rdfs:label "PLC"@es ;
    ns1:controla ns1:MovimientoSecuencial58 ;
    ns1:textoExtracto "Dispone de un PLC que controla el movimiento secuencial de los diferentes mecanismos de la máquina."@es .

