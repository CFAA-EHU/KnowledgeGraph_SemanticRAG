@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ArmarioElectrico_58
    a               ex:ComponenteElectrico ;
    rdfs:label      "Armario eléctrico" ;
    ex:textoExtracto "El armario eléctrico está colocado en la parte derecha de la máquina y es alimentado a 380 volt - 50 Hz." ;
    ex:alimenta     ex:Maquina_58 ;
    ex:tieneComponente ex:PLC_58 ;
    ex:controla     ex:MovimientoMecanismos_58 ;
    ex:ilustradoEn   ex:Figura_4_19 .

ex:Maquina_58
    a               ex:Maquina ;
    rdfs:label      "Máquina" ;
    ex:textoExtracto "máquina"@es .

ex:PLC_58
    a               ex:ComponenteElectrico ;
    rdfs:label      "PLC" ;
    ex:textoExtracto "Dispone de un PLC que controla el movimiento secuencial de los diferentes mecanismos de la máquina."@es .

ex:MovimientoMecanismos_58
    a               ex:ModoOperacion ;
    rdfs:label      "Movimiento secuencial de mecanismos" ;
    ex:textoExtracto "movimiento secuencial de los diferentes mecanismos de la máquina"@es .

ex:Figura_4_19
    a               ex:Figura ;
    rdfs:label      "Figura 4-19. Armario eléctrico" ;
    ex:identificador "4-19" ;
    ex:textoExtracto "Figura 4-19. Armario eléctrico." .