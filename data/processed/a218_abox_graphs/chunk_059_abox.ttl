@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LongitudDeLasEslingas a ns1:AvisoSeguridad ;
    rdfs:label "Longitud de las eslingas" ;
    ns1:textoExtracto "LA LONGITUD DE LAS ESLINGAS DEBE SER TAL QUE LIBREN CON HOLGURA LAS DEFENSAS INSTALADAS EN LA MÁQUINA, CON EL FIN DE EVITAR ABOLLADURAS O ROCES." .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    rdfs:label "Máquina Brochadora Electromecánica Exterior A218" ;
    ns1:textoExtracto "La máquina dispone de cuatro cáncamos, dos en la parte superior de la columna y dos en la parte frontal, para poder manipularla por medio de una grúa o similar." .

ns1:NoPermanecerBajoCargasSuspendidas_e692b5920e a ns1:AvisoSeguridad ;
    rdfs:label "No permanecer bajo cargas suspendidas" ;
    ns1:textoExtracto "EN LOS PROCESOS DE ELEVACIÓN DE COMPONENTES MEDIANTE GRÚAS NO SE DEBE PERMANECER DEBAJO DE CARGAS SUSPENDIDAS." .

ns1:TenerEnCuentaLasDimensionesYElPesoDeLaMaquina a ns1:AvisoSeguridad ;
    rdfs:label "Tener en cuenta las dimensiones y el peso de la máquina" ;
    ns1:textoExtracto "SE DEBEN TENER EN CUENTA LAS DIMENSIONES Y EL PESO DE LA MÁQUINA Y DEL ESPACIO DISPONIBLE, ANTES DE TRANSPORTARLA." .

ns1:UsoDeAparatosElevadoresAdecuados a ns1:AvisoSeguridad ;
    rdfs:label "Uso de aparatos elevadores adecuados" ;
    ns1:textoExtracto "SÓLO SE DEBEN EMPLEAR APARATOS ELEVADORES APROPIADOS Y TÉCNICAMENTE IMPECABLES, CON CARGA NOMINAL SUFICIENTE." .

ns1:UsoDeCadenasCuerdasGanchosYOjalesAdecuados a ns1:AvisoSeguridad ;
    rdfs:label "Uso de cadenas, cuerdas, ganchos y ojales adecuados" ;
    ns1:textoExtracto "LAS CADENAS, CUERDAS, GANCHOS Y OJALES DEBEN SER ASIMISMO ADECUADOS PARA LOS PESOS INDICADOS." .

ns1:UsoDeCarretillasElevadorasParaTransportarLaMaquina a ns1:AccionProhibida ;
    rdfs:label "Uso de carretillas elevadoras para transportar la máquina" ;
    ns1:textoExtracto "QUEDA PROHIBIDO EL USO DE CARRETILLAS ELEVADORAS O SIMILARES A TAL EFECTO." .

ns1:UsoDeEslingasHomologadas a ns1:AvisoSeguridad ;
    rdfs:label "Uso de eslingas homologadas" ;
    ns1:textoExtracto "ES IMPERATIVO ADEMÁS UTILIZAR ESLINGAS HOMOLOGADAS CON DECLARACIÓN 'CE' DE CONFORMIDAD, PARA EVITAR SITUACIONES DE RIESGO POR POSIBLES ROTURAS DE ESLINGAS DEFECTUOSAS." .

