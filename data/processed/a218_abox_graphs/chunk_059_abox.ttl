@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Canamo_59_1 a ns1:ComponenteMecanico ;
    rdfs:label "cáncamo"@es ;
    ns1:compuestoPor ns1:Maquina_59_1 ;
    ns1:textoExtracto "cuatro cáncamos, dos en la parte superior de la columna y dos en la parte frontal"@es .

ns1:Columna_59_1 a ns1:ComponenteMecanico ;
    rdfs:label "columna"@es ;
    ns1:compuestoPor ns1:Maquina_59_1 ;
    ns1:textoExtracto "parte superior de la columna"@es .

ns1:Eslinga_59_1 a ns1:Componente ;
    rdfs:label "eslinga"@es ;
    ns1:textoExtracto "LA LONGITUD DE LAS ESLINGAS DEBE SER TAL QUE LIBREN CON HOLGURA LAS DEFENSAS INSTALADAS EN LA MÁQUINA, CON EL FIN DE EVITAR ABOLLADURAS O ROCES. ES IMPERATIVO ADEMÁS UTILIZAR ESLINGAS HOMOLOGADAS CON DECLARACIÓN 'CE' DE CONFORMIDAD, PARA EVITAR SITUACIONES DE RIESGO POR POSIBLES ROTURAS DE ESLINGAS DEFECTUOSAS."@es .

ns1:Gr_a_59_1 a ns1:Maquina ;
    rdfs:label "grúa"@es ;
    ns1:textoExtracto "manipularla por medio de una grúa o similar"@es .

ns1:Maquina_59_1 a ns1:Maquina ;
    rdfs:label "máquina"@es ;
    ns1:textoExtracto "La máquina dispone de cuatro cáncamos, dos en la parte superior de la columna y dos en la parte frontal, para poder manipularla por medio de una grúa o similar."@es .

