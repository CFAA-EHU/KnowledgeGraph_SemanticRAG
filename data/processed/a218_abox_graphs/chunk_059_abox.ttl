@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Maquina_Desplazamiento
    a               ex:Maquina ;
    rdfs:label      "Máquina con sistema de manipulación por grúa"@es ;
    ex:textoExtracto
        "La máquina dispone de cuatro cáncamos, dos en la parte superior de la columna y dos en la parte frontal, para poder manipularla por medio de una grúa o similar. [...] LAS MÁQUINAS HAN SIDO DISEÑADAS PARA SER TRANSPORTADAS MEDIANTE SUSPENSIÓN"@es ;
    ex:tieneComponente
        ex:Cancamo_Superior_1 ,
        ex:Cancamo_Superior_2 ,
        ex:Cancamo_Frontal_1 ,
        ex:Cancamo_Frontal_2 ;
    ex:requiereEPI
        ex:EPI_ManipulacionGr_a .

ex:Cancamo_Superior_1
    a               ex:ComponenteMecanico ;
    rdfs:label      "Cáncamo superior (columna, lado 1)"@es ;
    ex:textoExtracto
        "La máquina dispone de cuatro cáncamos, dos en la parte superior de la columna [...] para poder manipularla por medio de una grúa"@es .

ex:Cancamo_Superior_2
    a               ex:ComponenteMecanico ;
    rdfs:label      "Cáncamo superior (columna, lado 2)"@es ;
    ex:textoExtracto
        "La máquina dispone de cuatro cáncamos, dos en la parte superior de la columna [...] para poder manipularla por medio de una grúa"@es .

ex:Cancamo_Frontal_1
    a               ex:ComponenteMecanico ;
    rdfs:label      "Cáncamo frontal (lado 1)"@es ;
    ex:textoExtracto
        "La máquina dispone de cuatro cáncamos, [...] dos en la parte frontal, para poder manipularla por medio de una grúa"@es .

ex:Cancamo_Frontal_2
    a               ex:ComponenteMecanico ;
    rdfs:label      "Cáncamo frontal (lado 2)"@es ;
    ex:textoExtracto
        "La máquina dispone de cuatro cáncamos, [...] dos en la parte frontal, para poder manipularla por medio de una grúa"@es .

ex:EPI_ManipulacionGr_a
    a               ex:EPI ;
    rdfs:label      "Equipo de protección individual para manipulación con grúa"@es ;
    ex:textoExtracto
        "El desplazamiento y manipulación de la máquina se debe realizar teniendo en cuenta las condiciones de seguridad. [...] SÓLO SE DEBEN EMPLEAR APARATOS ELEVADORES APROPIADOS Y TÉCNICAMENTE IMPECABLES"@es .

ex:AccionProhibida_TransporteCarretilla
    a               ex:AccionProhibida ;
    rdfs:label      "Uso de carretillas elevadoras para transporte de la máquina"@es ;
    ex:textoExtracto
        "QUEDA PROHIBIDO EL USO DE CARRETILLAS ELEVADORAS O SIMILARES A TAL EFECTO"@es ;
    ex:mitigaRiesgo ex:Maquina_Desplazamiento .

ex:AvisoSeguridad_ElevacionCargas
    a               ex:AvisoSeguridad ;
    rdfs:label      "Prohibición de permanecer bajo cargas suspendidas"@es ;
    ex:textoExtracto
        "EN LOS PROCESOS DE ELEVACIÓN DE COMPONENTES MEDIANTE GRÚAS NO SE DEBE PERMANECER DEBAJO DE CARGAS SUSPENDIDAS"@es ;
    ex:mitigaRiesgo ex:Maquina_Desplazamiento .

ex:AvisoSeguridad_EslingasHomologadas
    a               ex:AvisoSeguridad ;
    rdfs:label      "Uso obligatorio de eslingas homologadas con declaración CE"@es ;
    ex:textoExtracto
        "ES IMPERATIVO ADEMÁS UTILIZAR ESLINGAS HOMOLOGADAS CON DECLARACIÓN 'CE' DE CONFORMIDAD, PARA EVITAR SITUACIONES DE RIESGO POR POSIBLES ROTURAS DE ESLINGAS DEFECTUOSAS"@es ;
    ex:mitigaRiesgo ex:Maquina_Desplazamiento .