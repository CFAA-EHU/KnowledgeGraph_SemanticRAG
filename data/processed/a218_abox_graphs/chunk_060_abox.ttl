@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:EslingaHomologadaCE a ns1:ElementoSeguridad ;
    ns1:textoExtracto "ES IMPERATIVO ADEMÁS UTILIZAR ESLINGAS HOMOLOGADAS CON DECLARACIÓN 'CE' DE CONFORMIDAD, PARA EVITAR SITUACIONES DE RIESGO POR POSIBLES ROTURAS DE ESLINGAS DEFECTUOSAS." .

ns1:TableroProteccionContacto a ns1:ElementoSeguridad ;
    ns1:textoExtracto "DEBEN COLOCARSE TABLONES O TRAPOS EN TODOS LOS PUNTOS DE CONTACTO ENTRE ESLINGAS Y MÁQUINA, PARA EVITAR EVENTUALES DAÑOS EN LA MISMA." .

ns1:Maquina a ns1:Maquina ;
    ns1:textoExtracto "LA PRESIÓN DE LOS CABLES NO DEBE ACTUAR SOBRE HUSILLOS, GUÍAS, CAJAS DE CABLES U OTRAS ZONAS DEFORMABLES. ES CONVENIENTE LEVANTAR INICIALMENTE LA MÁQUINA SÓLO UNOS POCOS CENTÍMETROS DEL SUELO, PARA VERIFICAR QUE ESTÁ BIEN EQUILIBRADA. EN CASO DE QUE NO SE PUDIERAN VACIAR, PRESTAR ESPECIAL CUIDADO EN QUE LOS TAPONES DE CIERRE SE ENCUENTREN BIEN" .

