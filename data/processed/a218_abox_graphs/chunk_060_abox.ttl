@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_0dc31e015f a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre verificar equilibrio" ;
    ns1:mitigaRiesgo ns1:MaquinaBrochadoraElectromecanicaExteriorA218 ;
    ns1:textoExtracto "ES CONVENIENTE LEVANTAR INICIALMENTE LA MÁQUINA SÓLO UNOS POCOS CENTÍMETROS DEL SUELO, PARA VERIFICAR QUE ESTÁ BIEN EQUILIBRADA." .

ns1:AvisoSeguridad_18d9f487f0 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre presión de cables" ;
    ns1:mitigaRiesgo ns1:MaquinaBrochadoraElectromecanicaExteriorA218 ;
    ns1:textoExtracto "LA PRESIÓN DE LOS CABLES NO DEBE ACTUAR SOBRE HUSILLOS, GUÍAS, CAJAS DE CABLES U OTRAS ZONAS DEFORMABLES." .

ns1:AvisoSeguridad_2e364f904b a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre depósitos de aceite" ;
    ns1:mitigaRiesgo ns1:MaquinaBrochadoraElectromecanicaExteriorA218 ;
    ns1:textoExtracto "ES MUY RECOMENDABLE QUE DURANTE EL TRANSPORTE DE LA MÁQUINA LOS DEPÓSITOS DE ACEITE SE ENCUENTREN VACÍOS. EN CASO DE QUE NO SE PUDIERAN VACIAR, PRESTAR ESPECIAL CUIDADO EN QUE LOS TAPONES DE CIERRE SE ENCUENTREN BIEN." .

ns1:AvisoSeguridad_318b26b6a6 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre tablones en puntos de contacto" ;
    ns1:mitigaRiesgo ns1:MaquinaBrochadoraElectromecanicaExteriorA218 ;
    ns1:textoExtracto "ASIMISMO, DEBEN COLOCARSE TABLONES O TRAPOS EN TODOS LOS PUNTOS DE CONTACTO ENTRE ESLINGAS Y MÁQUINA, PARA EVITAR EVENTUALES DAÑOS EN LA MISMA." .

ns1:AvisoSeguridad_cf291489c9 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre eslingas homologadas" ;
    ns1:mitigaRiesgo ns1:MaquinaBrochadoraElectromecanicaExteriorA218 ;
    ns1:textoExtracto "ES IMPERATIVO ADEMÁS UTILIZAR ESLINGAS HOMOLOGADAS CON DECLARACIÓN 'CE' DE CONFORMIDAD, PARA EVITAR SITUACIONES DE RIESGO POR POSIBLES ROTURAS DE ESLINGAS DEFECTUOSAS." .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    rdfs:label "Máquina Brochadora Electromecánica Exterior A218" ;
    ns1:textoExtracto "ES IMPERATIVO ADEMÁS UTILIZAR ESLINGAS HOMOLOGADAS CON DECLARACIÓN 'CE' DE CONFORMIDAD, PARA EVITAR SITUACIONES DE RIESGO POR POSIBLES ROTURAS DE ESLINGAS DEFECTUOSAS." .

