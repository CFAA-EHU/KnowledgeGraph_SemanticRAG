@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Maquina_Transporte_61
    a               ex:Maquina ;
    rdfs:label      "Máquina en proceso de transporte"@es ;
    ex:textoExtracto "QUE DURANTE EL TRANSPORTE DE LA MÁQUINA LOS DEPÓSITOS DE ACEITE SE ENCUENTREN VACÍOS... Para proceder con el transporte la máquina hay que voltearla y colocarla en posición horizontal."@es ;
    ex:tieneComponente ex:DepositosAceite_61, ex:TaponesCierre_61, ex:PlataformasLaterales_61, ex:ArmarioElectrico_61, ex:GrupoHidraulico_61, ex:EquipoRefrigeracion_61, ex:BombaTrasera_61, ex:CarroPortaPiezas_61, ex:PortonesDelanteros_61, ex:CancamosSuperiores_61, ex:CancamosFrontales_61 ;
    ex:ilustradoEn   ex:Figura5_1, ex:Figura5_2 .

ex:DepositosAceite_61
    a               ex:ComponenteHidraulico ;
    rdfs:label      "Depósitos de aceite"@es ;
    ex:textoExtracto "QUE DURANTE EL TRANSPORTE DE LA MÁQUINA LOS DEPÓSITOS DE ACEITE SE ENCUENTREN VACÍOS."@es .

ex:TaponesCierre_61
    a               ex:ComponenteMecanico ;
    rdfs:label      "Tapones de cierre de depósitos"@es ;
    ex:textoExtracto "PRESTAR ESPECIAL CUIDADO EN QUE LOS TAPONES DE CIERRE SE ENCUENTREN BIEN CERRADOS."@es .

ex:PlataformasLaterales_61
    a               ex:ComponenteMecanico ;
    rdfs:label      "Plataformas laterales"@es ;
    ex:textoExtracto "hay que soltar las plataformas laterales"@es .

ex:ArmarioElectrico_61
    a               ex:ComponenteElectrico ;
    rdfs:label      "Armario eléctrico"@es ;
    ex:textoExtracto "soltar [...] el armario eléctrico"@es .

ex:GrupoHidraulico_61
    a               ex:Sistema ;
    rdfs:label      "Grupo hidráulico"@es ;
    ex:textoExtracto "soltar [...] el grupo hidráulico"@es .

ex:EquipoRefrigeracion_61
    a               ex:Sistema ;
    rdfs:label      "Equipo de refrigeración"@es ;
    ex:textoExtracto "soltar [...] el equipo de refrigeración"@es .

ex:BombaTrasera_61
    a               ex:ComponenteHidraulico ;
    rdfs:label      "Bomba trasera"@es ;
    ex:textoExtracto "soltar también la bomba trasera que va conectada al zócalo"@es .

ex:CarroPortaPiezas_61
    a               ex:ComponenteMecanico ;
    rdfs:label      "Carro porta-piezas"@es ;
    ex:textoExtracto "hay que posicionar el carro porta-piezas en la parte superior"@es .

ex:PortonesDelanteros_61
    a               ex:ComponenteMecanico ;
    rdfs:label      "Portones delanteros"@es ;
    ex:textoExtracto "dejar los portones delanteros abiertos"@es .

ex:CancamosSuperiores_61
    a               ex:ComponenteMecanico ;
    rdfs:label      "Cáncamos superiores"@es ;
    ex:textoExtracto "colocar las eslingas en los superiores cáncamos"@es .

ex:CancamosFrontales_61
    a               ex:ComponenteMecanico ;
    rdfs:label      "Cáncamos frontales"@es ;
    ex:textoExtracto "colocar [...] otros dos en los cáncamos frontales"@es ;
    ex:ilustradoEn   ex:Figura5_1 .

ex:Figura5_1
    a               ex:Figura ;
    rdfs:label      "Figura 5-1. Cáncamos transporte"@es ;
    ex:identificador "5-1" ;
    ex:textoExtracto "Figura 5-1. Cáncamos transporte"@es .

ex:Figura5_2
    a               ex:Figura ;
    rdfs:label      "Figura 5-2. Volteo máquina"@es ;
    ex:identificador "5-2" ;
    ex:textoExtracto "Figura 5-2. Volteo máquina"@es .