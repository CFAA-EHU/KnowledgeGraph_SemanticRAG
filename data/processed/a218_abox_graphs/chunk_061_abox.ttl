@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    rdfs:label "Máquina" ;
    ns1:textoExtracto "Para proceder con el transporte la máquina hay que voltearla y colocarla en posición horizontal." ;
    ns1:tieneComponente ns1:ArmarioElectrico_b6f1b60c9f,
        ns1:CancamosFrontales,
        ns1:CancamosSuperiores,
        ns1:SistemaHidraulicoBrochadora,
        ns1:SistemaRefrigeracionBrochadora .

ns1:ArmarioElectrico_b6f1b60c9f a ns1:ComponenteElectrico ;
    rdfs:label "Armario Eléctrico" ;
    ns1:textoExtracto "Previamente, hay que soltar las plataformas laterales, el armario eléctrico, el grupo hidráulico y el equipo de refrigeración." .

ns1:CancamosFrontales a ns1:ComponenteMecanico ;
    rdfs:label "Cáncamos Frontales" ;
    ns1:textoExtracto "otros dos en los cáncamos frontales" .

ns1:CancamosSuperiores a ns1:ComponenteMecanico ;
    rdfs:label "Cáncamos Superiores" ;
    ns1:textoExtracto "antes de colocar las eslingas en los superiores cáncamos" .

ns1:SistemaHidraulicoBrochadora a ns1:Sistema ;
    rdfs:label "Grupo Hidráulico" ;
    ns1:textoExtracto "Previamente, hay que soltar las plataformas laterales, el armario eléctrico, el grupo hidráulico y el equipo de refrigeración." .

ns1:SistemaRefrigeracionBrochadora a ns1:Sistema ;
    rdfs:label "Equipo de Refrigeración" ;
    ns1:textoExtracto "Previamente, hay que soltar las plataformas laterales, el armario eléctrico, el grupo hidráulico y el equipo de refrigeración." .

