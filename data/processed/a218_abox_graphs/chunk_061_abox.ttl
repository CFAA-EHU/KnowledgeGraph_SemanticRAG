@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:CancamosFrontales_Transporte_61 a ns1:Componente ;
    ns1:textoExtracto "colocar dos eslingas en los cáncamos frontales" .

ns1:CancamosSuperiores_Transporte_61 a ns1:Componente ;
    ns1:textoExtracto "colocar dos eslingas en los cáncamos superiores" .

ns1:CarroPortapiezas_Transporte_61 a ns1:Componente ;
    ns1:textoExtracto "posicionar el carro porta-piezas en la parte superior para poder acceder a los cáncamos frontales" .

ns1:CierresDepositos_Transporte_61 a ns1:Componente ;
    ns1:textoExtracto "TAPONES DE CIERRE" .

ns1:Figura5_1_Transporte_61 a ns1:Figura ;
    ns1:textoExtracto "Figura 5-1. Cáncamos transporte" .

ns1:Figura5_2_Transporte_61 a ns1:Figura ;
    ns1:textoExtracto "Figura 5-2. Volteo máquina" .

ns1:Maquina_Transporte_61 a ns1:Maquina ;
    ns1:textoExtracto "QUE DURANTE EL TRANSPORTE DE LA MÁQUINA LOS DEPÓSITOS DE ACEITE SE ENCUENTREN VACÍOS. EN CASO DE QUE NO SE PUDIERAN VACIAR, PRESTAR ESPECIAL CUIDADO EN QUE LOS TAPONES DE CIERRE SE ENCUENTREN BIEN CERRADOS. Para proceder con el transporte la máquina hay que voltearla y colocarla en posición horizontal. Previamente, hay que soltar las plataformas laterales, el armario eléctrico, el grupo hidráulico y el equipo de refrigeración (soltar también la bomba trasera que va conectada al zócalo)." ;
    ns1:tieneComponente ns1:ArmarioElectrico_Transporte_61,
        ns1:BombaTrasera_Transporte_61,
        ns1:EquipoRefrigeracion_Transporte_61,
        ns1:GrupoHidraulico_Transporte_61,
        ns1:PlataformasLaterales_Transporte_61 .

ns1:PortonesDelanteros_Transporte_61 a ns1:Componente ;
    ns1:textoExtracto "dejar los portones delanteros abiertos" .

ns1:ArmarioElectrico_Transporte_61 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "soltar el armario eléctrico" .

ns1:BombaTrasera_Transporte_61 a ns1:Componente ;
    ns1:textoExtracto "soltar también la bomba trasera que va conectada al zócalo" .

ns1:GrupoHidraulico_Transporte_61 a ns1:ComponenteHidraulico ;
    ns1:textoExtracto "soltar el grupo hidráulico" .

ns1:PlataformasLaterales_Transporte_61 a ns1:Componente ;
    ns1:textoExtracto "soltar las plataformas laterales" .

