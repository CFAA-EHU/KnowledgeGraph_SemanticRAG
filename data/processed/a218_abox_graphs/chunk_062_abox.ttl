@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    rdfs:label "Máquina" ;
    ns1:monitoreaParametro ns1:TemperaturaMaxima,
        ns1:TemperaturaMinima ;
    ns1:textoExtracto "El recinto donde se instala la máquina deberá estar cerrado y protegido de los fenómenos atmosféricos." .

ns1:SueloInstalacionMaquina a ns1:EntidadFisica ;
    rdfs:label "Suelo de instalación" ;
    ns1:textoExtracto "ES IMPORTANTE QUE EL SUELO DONDE SE VAYA A INSTALAR LA MÁQUINA TENGA CONSISTENCIA SUFICIENTE PARA AGUANTAR EL PESO DE LA MÁQUINA." .

ns1:TemperaturaMaxima a ns1:Parametro ;
    rdfs:label "Temperatura máxima" ;
    ns1:textoExtracto "La temperatura no debe ser inferior a 0 ºC ni superior a 45 ºC." ;
    ns1:valor "45 ºC" .

ns1:TemperaturaMinima a ns1:Parametro ;
    rdfs:label "Temperatura mínima" ;
    ns1:textoExtracto "La temperatura no debe ser inferior a 0 ºC ni superior a 45 ºC." ;
    ns1:valor "-0 ºC" .

