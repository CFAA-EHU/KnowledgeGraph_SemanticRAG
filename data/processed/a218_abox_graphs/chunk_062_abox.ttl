PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Maquina_Instalacion_62
    a               ex:Maquina ;
    rdfs:label      "Máquina (requisitos de instalación)"@es ;
    ex:textoExtracto
        "El recinto donde se instala la máquina deberá estar cerrado y protegido de los fenómenos atmosféricos. La temperatura no debe ser inferior a 0 ºC ni superior a 45 ºC. ES IMPORTANTE QUE EL SUELO DONDE SE VAYA A INSTALAR LA MÁQUINA TENGA CONSISTENCIA SUFICIENTE PARA AGUANTAR EL PESO DE LA MÁQUINA."@es ;
    ex:documentadoEn ex:Pagina_55 .

ex:Pagina_55
    a               ex:Pagina ;
    ex:identificador "55" ;
    ex:textoExtracto
        "COLOCACIÓN DE LA MÁQUINA [...] VER APARTADO 5.2.1. Dimensiones y peso de la máquina."@es .