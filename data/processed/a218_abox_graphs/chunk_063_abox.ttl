PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Maquina_Principal_63
    a                     ex:Maquina ;
    rdfs:label            "Máquina principal" ;
    ex:textoExtracto       "El peso total de la máquina es de aproximadamente unas 25Tn. Las dimensiones máximas de la máquina son: 5850 x 4000 x 5000mm." ;
    ex:identificador       "25Tn ; 5850x4000x5000mm" .

ex:ElementoAntivibracion_LM7_100BA_63
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Elemento antivibración LM7-100BA (EFFBE)" ;
    ex:textoExtracto       "Entre el zócalo de la máquina y el suelo están colocados diez elementos de antivibración LM7-100BA (EFFBE)." ;
    ex:identificador       "LM7-100BA" .

ex:Figura_5_3_63
    a                     ex:Figura ;
    rdfs:label            "Figura 5-3. Dimensiones máquina" ;
    ex:textoExtracto       "En la siguiente figura se muestra el plano de implantación de la máquina en el que se incluyen las dimensiones de la máquina." ;
    ex:identificador       "5-3" ;
    ex:ilustradoEn         ex:Maquina_Principal_63 .

ex:Maquina_Principal_63
    ex:tieneComponente     ex:ElementoAntivibracion_LM7_100BA_63 .