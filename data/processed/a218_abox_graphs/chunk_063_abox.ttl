@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ElementoAntivibracionLM7_100BA a ns1:ComponenteMecanico ;
    rdfs:label "Elemento de antivibración LM7-100BA (EFFBE)" ;
    ns1:textoExtracto "Entre el zócalo de la máquina y el suelo están colocados diez elementos de antivibración LM7- 100BA (EFFBE)." .

ns1:EsquemaDimensionamientoMaquina a ns1:Esquema ;
    rdfs:label "Plano de implantación de la máquina" ;
    ns1:detalladoEnEsquema ns1:MaquinaBrochadoraElectromecanicaExteriorA218 ;
    ns1:textoExtracto "En la siguiente figura se muestra el plano de implantación de la máquina en el que se incluyen las dimensiones de la máquina." .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    rdfs:label "Máquina Brochadora Electromecánica Exterior A218" ;
    ns1:textoExtracto "El peso total de la máquina es de aproximadamente unas 25Tn. Las dimensiones máximas de la máquina son: 5850 x 4000 x 5000mm." ;
    ns1:valor "25 Tn"^^xsd:string,
        "5850 x 4000 x 5000 mm"^^xsd:string .

