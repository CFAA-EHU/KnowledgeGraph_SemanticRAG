@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CartuchoGrassaLUE4000501 a ns1:Consumible ;
    rdfs:label "cartucho de grasa LUE+400-05-1" ;
    ns1:identificador "LUE+400-05-1" ;
    ns1:textoExtracto "Colocar un cartucho de grasa LUE+400-05-1 en la centralita de engrase automática." .

ns1:CentralitaEngraseAutomatica a ns1:ComponenteMecanico ;
    rdfs:label "centralita de engrase automática" ;
    ns1:textoExtracto "Colocar un cartucho de grasa LUE+400-05-1 en la centralita de engrase automática." .

ns1:CentralitaEngraseManual a ns1:ComponenteMecanico ;
    rdfs:label "centralita de engrase manual" ;
    ns1:textoExtracto "Llenar la centralita de engrase manual con aceite ISO 3498 G220." .

ns1:DepositoRefrigerante a ns1:ComponenteMecanico ;
    rdfs:label "depósito de refrigerante" ;
    ns1:textoExtracto "Llenar el depósito de refrigerante con aceite de corte CUT-MAX S 5029-1." .

ns1:GrupoHidraulico a ns1:ComponenteHidraulico ;
    rdfs:label "grupo hidráulico" ;
    ns1:textoExtracto "Llenar el grupo hidráulico con aceite ISO 3498 HM46." .

ns1:Maquina a ns1:Maquina ;
    rdfs:label "máquina" ;
    ns1:textoExtracto "Para poder poner en marcha la máquina es necesario conectar: Conexión del suministro de aire máx. a 6 bar. La máquina debe conectarse a red trifásica de 380 V y 50 Hz." .

