@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Maquina_65
    a ex:Maquina ;
    rdfs:label "Máquina principal" ;
    ex:textoExtracto "Para poder poner en marcha la máquina es necesario conectar: [...]" ;
    ex:requiereMantenimiento ex:TareaMantenimiento_EngraseManual_65, ex:TareaMantenimiento_EngraseAutomatico_65, ex:TareaMantenimiento_Hidraulico_65, ex:TareaMantenimiento_Refrigerante_65 ;
    ex:tieneComponente ex:SistemaElectrico_65, ex:SistemaHidraulico_65, ex:CentralitaEngraseManual_65, ex:CentralitaEngraseAutomatica_65, ex:DepositoRefrigerante_65 .

ex:SistemaElectrico_65
    a ex:ComponenteElectrico ;
    rdfs:label "Conexión eléctrica trifásica" ;
    ex:textoExtracto "La máquina debe conectarse a red trifásica de 380 V y 50 Hz." ;
    ex:valor "380 V / 50 Hz / trifásica" .

ex:SistemaHidraulico_65
    a ex:ComponenteHidraulico ;
    rdfs:label "Suministro de aire comprimido" ;
    ex:textoExtracto "Conexión del suministro de aire máx. a 6 bar." ;
    ex:valor "6 bar (máx.)" .

ex:CentralitaEngraseManual_65
    a ex:ComponenteHidraulico ;
    rdfs:label "Centralita de engrase manual" ;
    ex:textoExtracto "Llenar la centralita de engrase manual con aceite ISO 3498 G220." ;
    ex:requiereConsumible ex:Consumible_AceiteG220_65 .

ex:CentralitaEngraseAutomatica_65
    a ex:ComponenteHidraulico ;
    rdfs:label "Centralita de engrase automática" ;
    ex:textoExtracto "Colocar un cartucho de grasa LUE+400-05-1 en la centralita de engrase automática." ;
    ex:requiereConsumible ex:Consumible_GrasaLUE400_65 .

ex:DepositoRefrigerante_65
    a ex:ComponenteHidraulico ;
    rdfs:label "Depósito de refrigerante" ;
    ex:textoExtracto "Llenar el depósito de refrigerante con aceite de corte CUT-MAX S 5029-1." ;
    ex:requiereConsumible ex:Consumible_AceiteCorte_65 .

ex:GrupoHidraulico_65
    a ex:ComponenteHidraulico ;
    rdfs:label "Grupo hidráulico" ;
    ex:textoExtracto "Llenar el grupo hidráulico con aceite ISO 3498 HM46." ;
    ex:requiereConsumible ex:Consumible_AceiteHM46_65 .

ex:TareaMantenimiento_EngraseManual_65
    a ex:TareaMantenimiento ;
    rdfs:label "Llenado de centralita de engrase manual" ;
    ex:textoExtracto "Llenar la centralita de engrase manual con aceite ISO 3498 G220." .

ex:TareaMantenimiento_EngraseAutomatico_65
    a ex:TareaMantenimiento ;
    rdfs:label "Colocación de cartucho de grasa en centralita automática" ;
    ex:textoExtracto "Colocar un cartucho de grasa LUE+400-05-1 en la centralita de engrase automática." .

ex:TareaMantenimiento_Hidraulico_65
    a ex:TareaMantenimiento ;
    rdfs:label "Llenado del grupo hidráulico" ;
    ex:textoExtracto "Llenar el grupo hidráulico con aceite ISO 3498 HM46." .

ex:TareaMantenimiento_Refrigerante_65
    a ex:TareaMantenimiento ;
    rdfs:label "Llenado del depósito de refrigerante" ;
    ex:textoExtracto "Llenar el depósito de refrigerante con aceite de corte CUT-MAX S 5029-1." .

ex:Consumible_AceiteG220_65
    a ex:Consumible ;
    rdfs:label "Aceite ISO 3498 G220" ;
    ex:identificador "ISO 3498 G220" ;
    ex:textoExtracto "aceite ISO 3498 G220" .

ex:Consumible_GrasaLUE400_65
    a ex:Consumible ;
    rdfs:label "Cartucho de grasa LUE+400-05-1" ;
    ex:identificador "LUE+400-05-1" ;
    ex:textoExtracto "cartucho de grasa LUE+400-05-1" .

ex:Consumible_AceiteHM46_65
    a ex:Consumible ;
    rdfs:label "Aceite ISO 3498 HM46" ;
    ex:identificador "ISO 3498 HM46" ;
    ex:textoExtracto "aceite ISO 3498 HM46" .

ex:Consumible_AceiteCorte_65
    a ex:Consumible ;
    rdfs:label "Aceite de corte CUT-MAX S 5029-1" ;
    ex:identificador "CUT-MAX S 5029-1" ;
    ex:textoExtracto "aceite de corte CUT-MAX S 5029-1" .