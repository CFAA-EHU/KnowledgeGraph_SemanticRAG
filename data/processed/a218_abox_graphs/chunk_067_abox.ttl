@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Maquina_67
    a               ex:Maquina ;
    rdfs:label      "Máquina principal"@es ;
    ex:textoExtracto "PUESTA EN TENSIÓN ANTES DE PONER LA MÁQUINA EN FUNCIONAMIENTO... colocando en ON la posición del interruptor general que se encuentra en la parte derecha del armario eléctrico"@es ;
    ex:tieneComponente ex:ArmarioElectrico_67 ;
    ex:tieneComponente ex:InterruptorGeneral_67 ;
    ex:tieneComponente ex:TomaCorrienteInterior_67 ;
    ex:tieneComponente ex:TomaCorrienteExterior_67 ;
    ex:tieneComponente ex:IluminacionArmario_67 .

ex:ArmarioElectrico_67
    a               ex:ComponenteElectrico ;
    rdfs:label      "Armario eléctrico"@es ;
    ex:textoExtracto "interruptor general que se encuentra en la parte derecha del armario eléctrico visto de frente"@es ;
    ex:tieneComponente ex:InterruptorGeneral_67 ;
    ex:tieneComponente ex:TomaCorrienteInterior_67 ;
    ex:tieneComponente ex:IluminacionArmario_67 .

ex:InterruptorGeneral_67
    a               ex:ComponenteElectrico ;
    rdfs:label      "Interruptor general"@es ;
    ex:textoExtracto "colocando en ON la posición del interruptor general... (ver Figura 6-1. Interruptor general del armario eléctrico)"@es ;
    ex:ilustradoEn   ex:Figura_6_1 .

ex:TomaCorrienteInterior_67
    a               ex:ComponenteElectrico ;
    rdfs:label      "Toma de corriente interior"@es ;
    ex:textoExtracto "1 TOMA DE CORRIENTE EN EL INTERIOR DEL ARMARIO... que SÍ ESTÁN CON TENSIÓN DE 220VAC"@es ;
    ex:valor         "220VAC" .

ex:TomaCorrienteExterior_67
    a               ex:ComponenteElectrico ;
    rdfs:label      "Toma de corriente exterior"@es ;
    ex:textoExtracto "OTRA EN EL EXTERIOR DEL PANEL PRINCIPAL... que SÍ ESTÁN CON TENSIÓN DE 220VAC"@es ;
    ex:valor         "220VAC" .

ex:IluminacionArmario_67
    a               ex:ComponenteElectrico ;
    rdfs:label      "Iluminación del armario"@es ;
    ex:textoExtracto "LA ILUMINACIÓN DEL ARMARIO QUE SÍ ESTÁ CON TENSIÓN DE 220VAC"@es ;
    ex:valor         "220VAC" .

ex:Figura_6_1
    a               ex:Figura ;
    rdfs:label      "Figura 6-1. Interruptor general del armario eléctrico"@es ;
    ex:textoExtracto "Figura 6-1. Interruptor general del armario eléctrico"@es ;
    ex:identificador "6-1" .