@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_01549742be a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre elementos con tensión" ;
    ns1:mitigaRiesgo ns1:PuestaEnTensionAntesDeLeerInstruccionesDeSeguridad ;
    ns1:textoExtracto "AÚN SIN LA MÁQUINA EN TENSIÓN EXISTEN ELEMENTOS COMO 1 TOMA DE CORRIENTE EN EL INTERIOR DEL ARMARIO Y OTRA EN EL EXTERIOR DEL PANEL PRINCIPAL, Y LA ILUMINACIÓN DEL ARMARIO QUE SÍ ESTÁN CON TENSIÓN DE 220VAC." .

ns1:EsquemaPosicionInterruptorGeneral a ns1:Esquema ;
    rdfs:label "Figura 6-1. Interruptor general del armario eléctrico" ;
    ns1:textoExtracto "ON Figura 6-1. Interruptor general del armario eléctrico." .

ns1:IluminacionDelArmario a ns1:ComponenteElectrico ;
    rdfs:label "Iluminación del armario" ;
    ns1:textoExtracto "1 TOMA DE CORRIENTE EN EL INTERIOR DEL ARMARIO Y OTRA EN EL EXTERIOR DEL PANEL PRINCIPAL, Y LA ILUMINACIÓN DEL ARMARIO QUE SÍ ESTÁN CON TENSIÓN DE 220VAC." .

ns1:InterruptorGeneral_ee44f0d535 a ns1:ComponenteElectrico ;
    rdfs:label "Interruptor general" ;
    ns1:textoExtracto "colocando en ON la posición del interruptor general que se encuentra en la parte derecha del armario eléctrico visto de frente (ver abajo)." .

ns1:TomaDeCorrienteExterior a ns1:ComponenteElectrico ;
    rdfs:label "Toma de corriente exterior" ;
    ns1:textoExtracto "1 TOMA DE CORRIENTE EN EL INTERIOR DEL ARMARIO Y OTRA EN EL EXTERIOR DEL PANEL PRINCIPAL, Y LA ILUMINACIÓN DEL ARMARIO QUE SÍ ESTÁN CON TENSIÓN DE 220VAC." .

ns1:TomaDeCorrienteInterior a ns1:ComponenteElectrico ;
    rdfs:label "Toma de corriente interior" ;
    ns1:textoExtracto "1 TOMA DE CORRIENTE EN EL INTERIOR DEL ARMARIO Y OTRA EN EL EXTERIOR DEL PANEL PRINCIPAL, Y LA ILUMINACIÓN DEL ARMARIO QUE SÍ ESTÁN CON TENSIÓN DE 220VAC." .

ns1:PuestaEnTensionAntesDeLeerInstruccionesDeSeguridad a ns1:AccionProhibida ;
    rdfs:label "Puesta en tensión antes de leer instrucciones de seguridad" ;
    ns1:textoExtracto "PUESTA EN TENSIÓN ANTES DE PONER LA MÁQUINA EN FUNCIONAMIENTO, SE DEBEN LEER ATENTAMENTE LAS INSTRUCCIONES DE SEGURIDAD INDICADAS EN EL APARTADO 2.1." .

