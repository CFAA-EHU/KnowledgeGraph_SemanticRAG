@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArmarioElectrico a ns1:ComponenteElectrico ;
    rdfs:label "Armario eléctrico" ;
    ns1:textoExtracto "el armario eléctrico visto de frente"@es .

ns1:Figura6_1 a ns1:Figura ;
    rdfs:label "Figura 6-1" ;
    ns1:ilustradoEn ns1:InterruptorGeneral ;
    ns1:textoExtracto "ON Figura 6-1. Interruptor general del armario eléctrico."@es .

ns1:IluminacionArmario a ns1:ComponenteElectrico ;
    rdfs:label "Iluminación del armario" ;
    ns1:textoExtracto "LA ILUMINACIÓN DEL ARMARIO QUE SÍ ESTÁN CON TENSIÓN DE 220VAC"@es ;
    ns1:valor "220VAC" .

ns1:TomaCorrienteExterior a ns1:ComponenteElectrico ;
    rdfs:label "Toma de corriente exterior" ;
    ns1:textoExtracto "OTRA EN EL EXTERIOR DEL PANEL PRINCIPAL"@es ;
    ns1:valor "220VAC" .

ns1:TomaCorrienteInterior a ns1:ComponenteElectrico ;
    rdfs:label "Toma de corriente interior" ;
    ns1:textoExtracto "1 TOMA DE CORRIENTE EN EL INTERIOR DEL ARMARIO"@es ;
    ns1:valor "220VAC" .

ns1:InterruptorGeneral a ns1:ComponenteElectrico ;
    rdfs:label "Interruptor general" ;
    ns1:identificador "Figura 6-1" ;
    ns1:textoExtracto "colocando en ON la posición del interruptor general que se encuentra en la parte derecha del armario eléctrico visto de frente"@es .

