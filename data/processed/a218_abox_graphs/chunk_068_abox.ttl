@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    ns1:textoExtracto "La máquina está compuesta por los siguientes elementos de mando:" ;
    ns1:tieneComponente ns1:Componente_a555a0e2db,
        ns1:PanelOperadorPC21,
        ns1:PulsadorLuminoso,
        ns1:PulsadorParadaEmergencia,
        ns1:PulsadorSimple .

ns1:Componente_a555a0e2db a ns1:Componente ;
    rdfs:label "Selectores" ;
    ns1:textoExtracto "Selectors" .

ns1:PanelOperadorPC21 a ns1:Componente ;
    rdfs:label "Panel operador PC-21' Panorámico 16Gb" ;
    ns1:textoExtracto "Panel operador PC-21\" Panorámico 16Gb"@es .

ns1:PulsadorLuminoso a ns1:Componente ;
    rdfs:label "Pulsadores luminosos" ;
    ns1:textoExtracto "Pulsadores luminosos" .

ns1:PulsadorParadaEmergencia a ns1:Componente ;
    rdfs:label "Pulsadores de parada de emergencia" ;
    ns1:textoExtracto "Pulsadores de parada de emergencia" .

ns1:PulsadorSimple a ns1:Componente ;
    rdfs:label "Pulsadores simples" ;
    ns1:textoExtracto "Pulsadores simples" .

