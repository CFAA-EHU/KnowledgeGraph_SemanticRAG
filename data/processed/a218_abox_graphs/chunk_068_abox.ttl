@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Maquina_Chunk68
    a ex:Maquina ;
    rdfs:label "Máquina (pág. 60)" ;
    ex:textoExtracto "La máquina está compuesta por los siguientes elementos de mando: [...]" ;
    ex:tieneComponente ex:PulsadorEmergencia_Chunk68 ,
                       ex:PulsadorSimple_Chunk68 ,
                       ex:PulsadorLuminoso_Chunk68 ,
                       ex:Selector_Chunk68 ,
                       ex:PanelOperador_Chunk68 .

ex:PulsadorEmergencia_Chunk68
    a ex:ComponenteElectrico , ex:ElementoSeguridad ;
    rdfs:label "Pulsador de parada de emergencia" ;
    ex:textoExtracto "Pulsadores de parada de emergencia" ;
    ex:mitigaRiesgo ex:Alarma_Emergencia_Chunk68 .

ex:Alarma_Emergencia_Chunk68
    a ex:Alarma ;
    rdfs:label "Alarma de emergencia" ;
    ex:textoExtracto "parada de emergencia"@es .

ex:PulsadorSimple_Chunk68
    a ex:ComponenteElectrico ;
    rdfs:label "Pulsador simple" ;
    ex:textoExtracto "Pulsadores simples" .

ex:PulsadorLuminoso_Chunk68
    a ex:ComponenteElectrico ;
    rdfs:label "Pulsador luminoso" ;
    ex:textoExtracto "Pulsadores luminosos" .

ex:Selector_Chunk68
    a ex:ComponenteElectrico ;
    rdfs:label "Selector" ;
    ex:textoExtracto "Selectores" .

ex:PanelOperador_Chunk68
    a ex:InterfazUsuario ;
    rdfs:label "Panel operador PC-21' Panorámico 16Gb" ;
    ex:identificador "PC-21' Panorámico 16Gb" ;
    ex:textoExtracto "Panel operador PC-21' Panorámico 16Gb" .