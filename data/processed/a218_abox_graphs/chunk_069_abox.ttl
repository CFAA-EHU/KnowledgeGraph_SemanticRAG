@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ArmarioElectrico_621
    a ex:Sistema ;
    rdfs:label "Armario eléctrico (6.2.1)"@es ;
    ex:textoExtracto "6.2.1 Armario eléctrico"@es ;
    ex:tieneComponente ex:InterruptorGeneral_621, ex:PulsadorEmergencia_621, ex:PilotoLuminosoTension_621 .

ex:InterruptorGeneral_621
    a ex:ComponenteElectrico ;
    rdfs:label "Interruptor general"@es ;
    ex:textoExtracto "INTERRUPTOR GENERAL"@es .

ex:PulsadorEmergencia_621
    a ex:ComponenteElectrico, ex:ElementoSeguridad ;
    rdfs:label "Pulsador de emergencia"@es ;
    ex:textoExtracto "PULSADOR EMERGENCIA"@es .

ex:PilotoLuminosoTension_621
    a ex:ComponenteElectrico ;
    rdfs:label "Piloto luminoso de tensión"@es ;
    ex:textoExtracto "PILOTO LUMINOSO TENSIÓN"@es .