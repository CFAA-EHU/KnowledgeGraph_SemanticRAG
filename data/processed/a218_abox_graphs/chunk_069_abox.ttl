    ns1:textoExtracto "PILOTO LUMINOSO TENSIÓN" .

ns1:PULSADOREMERGENCIA a ns1:ComponenteElectrico ;
    rdfs:label "PULSADOR EMERGENCIA" ;
    ns1:textoExtracto "PULSADOR EMERGENCIA" .

