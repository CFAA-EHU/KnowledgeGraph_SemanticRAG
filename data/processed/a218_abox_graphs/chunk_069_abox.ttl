ns1:INTERRUPTORGENERAL a ns1:ComponenteElectrico ;
    rdfs:label "INTERRUPTOR GENERAL" ;
    ns1:textoExtracto "INTERRUPTOR GENERAL" .

ns1:PILOTOLUMINOSOTENSION a ns1:ComponenteElectrico ;
