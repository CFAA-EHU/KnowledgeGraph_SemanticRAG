ex:PanelOperador_6_2
    a ex:InterfazUsuario ;
    rdfs:label "Panel operador (Figura 6-2)"@es ;
    ex:textoExtracto "PARADA DE EMERGENCIA - PUESTA SERVICIO - PARO SERVICIO - MARCHA CICLO - MODO SETUP - HABILITAR PUERTAS - APERTURA PUERTAS - Puesta Habilitar Servicio Puertas Parada de Apertura Emergencia Puertas Modo Paro Marcha Setup Servicio Ciclo Figura 6-2. Panel operador"@es ;
    ex:identificador "Figura 6-2" .

ex:ModoParadaEmergencia
    a ex:ModoOperacion ;
    rdfs:label "Parada de emergencia"@es ;
    ex:textoExtracto "PARADA DE EMERGENCIA"@es ;
    ex:habilitadoPor ex:PanelOperador_6_2 .

