@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActuadorAsociado a ns1:Actuador ;
    rdfs:label "Actuador asociado" ;
    ns1:textoExtracto "cambian de color dependiendo del estado del sensor de un actuador o del estado de un sinóptico." .

ns1:BotonSenalizador a ns1:ComponenteElectrico ;
    rdfs:label "Botón Señalizadores" ;
    ns1:monitoreaParametro ns1:Sensor_15af5dafc0 ;
    ns1:textoExtracto "Botones Señalizadores" .

ns1:Sensor_15af5dafc0 a ns1:Sensor ;
    rdfs:label "Sensor de estado" ;
    ns1:textoExtracto "cambian de color dependiendo del estado del sensor de un actuador o del estado de un sinóptico." .

