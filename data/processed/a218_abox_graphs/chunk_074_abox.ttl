@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioTeclado a ns1:InterfazUsuario ;
    rdfs:label "Teclado" ;
    ns1:documentadoEn ns1:CNC8070_225fe112f0 ;
    ns1:textoExtracto "El teclado está siempre visible en la parte derecha de la pantalla y tiene dos versiones, Kyboard y Jog." ;
    ns1:tieneComponente ns1:ModoOperacionAuto,
        ns1:ModoOperacionManual .

ns1:CNC8070_225fe112f0 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Desde la versión JOG es posible mover tanto el carro como la mesa pulsando los botones Z+, Z-, C+, C- estando la máquina en modo manual." .

ns1:ModoOperacionAuto a ns1:ModoOperacion ;
    rdfs:label "Modo Auto" ;
    ns1:textoExtracto "Ambas permiten seleccionar el modo de trabajo (auto o manual)" .

ns1:ModoOperacionManual a ns1:ModoOperacion ;
    rdfs:label "Modo Manual" ;
    ns1:textoExtracto "Ambas permiten seleccionar el modo de trabajo (auto o manual)" .

