@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Boton_CMas_74_62 a ns1:InterfazUsuario ;
    rdfs:label "C+"@es ;
    ns1:textoExtracto "Desde la versión JOG es posible mover tanto el carro como la mesa pulsando los botones Z+, Z-, C+, C- estando la máquina en modo manual."@es .

ns1:Boton_CMenos_74_62 a ns1:InterfazUsuario ;
    rdfs:label "C-"@es ;
    ns1:textoExtracto "Desde la versión JOG es posible mover tanto el carro como la mesa pulsando los botones Z+, Z-, C+, C- estando la máquina en modo manual."@es .

ns1:Boton_CUSTOM_74_62 a ns1:InterfazUsuario ;
    rdfs:label "CUSTOM"@es ;
    ns1:textoExtracto "dan acceso a las pantallas de movimientos manuales a través del botón 'CUSTOM'."@es .

ns1:Boton_ZMas_74_62 a ns1:InterfazUsuario ;
    rdfs:label "Z+"@es ;
    ns1:textoExtracto "Desde la versión JOG es posible mover tanto el carro como la mesa pulsando los botones Z+, Z-, C+, C- estando la máquina en modo manual."@es .

ns1:Boton_ZMenos_74_62 a ns1:InterfazUsuario ;
    rdfs:label "Z-"@es ;
    ns1:textoExtracto "Desde la versión JOG es posible mover tanto el carro como la mesa pulsando los botones Z+, Z-, C+, C- estando la máquina en modo manual."@es .

ns1:ModoTrabajo_Auto_74_62 a ns1:ModoOperacion ;
    rdfs:label "Auto"@es ;
    ns1:textoExtracto "Ambas permiten seleccionar el modo de trabajo (auto o manual)"@es .

ns1:ModoTrabajo_Manual_74_62 a ns1:ModoOperacion ;
    rdfs:label "Manual"@es ;
    ns1:textoExtracto "Ambas permiten seleccionar el modo de trabajo (auto o manual)"@es .

ns1:Teclado_74_62 a ns1:InterfazUsuario ;
    rdfs:label "Teclado"@es ;
    ns1:textoExtracto "El teclado está siempre visible en la parte derecha de la pantalla y tiene dos versiones, Kyboard y Jog."@es .

ns1:Teclado_Jog_74_62 a ns1:InterfazUsuario ;
    rdfs:label "Jog"@es ;
    ns1:textoExtracto "Ambas permiten seleccionar el modo de trabajo (auto o manual) y dan acceso a las pantallas de movimientos manuales a través del botón 'CUSTOM'."@es .

ns1:Teclado_Keyboard_74_62 a ns1:InterfazUsuario ;
    rdfs:label "Keyboard"@es ;
    ns1:textoExtracto "Ambas permiten seleccionar el modo de trabajo (auto o manual) y dan acceso a las pantallas de movimientos manuales a través del botón 'CUSTOM'."@es .

