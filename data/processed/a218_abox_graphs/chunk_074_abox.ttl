@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Teclado_InterfazUsuario_74
    a               ex:InterfazUsuario ;
    rdfs:label      "Teclado de control"@es ;
    ex:textoExtracto
                    "El teclado está siempre visible en la parte derecha de la pantalla y tiene dos versiones, Kyboard y Jog. Ambas permiten seleccionar el modo de trabajo (auto o manual) y dan acceso a las pantallas de movimientos manuales a través del botón 'CUSTOM'."@es ;
    ex:ilustradoEn  ex:PantallaPrincipal_62 ;
    ex:habilitadoPor
                    ex:ModoManual_74 ,
                    ex:ModoAutomatico_74 .

ex:ModoManual_74
    a               ex:ModoOperacion ;
    rdfs:label      "Modo manual"@es ;
    ex:textoExtracto
                    "modo de trabajo (auto o manual)"@es ;
    ex:textoExtracto
                    "estando la máquina en modo manual"@es .

ex:ModoAutomatico_74
    a               ex:ModoOperacion ;
    rdfs:label      "Modo automático"@es ;
    ex:textoExtracto
                    "modo de trabajo (auto o manual)"@es .

ex:VersionKeyboard_74
    a               ex:InterfazUsuario ;
    rdfs:label      "Versión Keyboard"@es ;
    ex:textoExtracto
                    "tiene dos versiones, Kyboard y Jog"@es ;
    ex:ilustradoEn  ex:PantallaPrincipal_62 .

ex:VersionJog_74
    a               ex:InterfazUsuario ;
    rdfs:label      "Versión JOG"@es ;
    ex:textoExtracto
                    "tiene dos versiones, Kyboard y Jog"@es ;
    ex:textoExtracto
                    "Desde la versión JOG es posible mover tanto el carro como la mesa pulsando los botones Z+, Z-, C+, C-"@es ;
    ex:ilustradoEn  ex:PantallaPrincipal_62 ;
    ex:controla    ex:CarroMaquina_74 ,
                    ex:MesaMaquina_74 .

ex:PantallaPrincipal_62
    a               ex:InterfazUsuario ;
    rdfs:label      "Pantalla principal (página 62)"@es ;
    ex:textoExtracto
                    "El teclado está siempre visible en la parte derecha de la pantalla"@es .

ex:CarroMaquina_74
    a               ex:ComponenteMecanico ;
    rdfs:label      "Carro de la máquina"@es ;
    ex:textoExtracto
                    "mover tanto el carro como la mesa"@es .

ex:MesaMaquina_74
    a               ex:ComponenteMecanico ;
    rdfs:label      "Mesa de la máquina"@es ;
    ex:textoExtracto
                    "mover tanto el carro como la mesa"@es .

ex:BotonCustom_74
    a               ex:ComponenteElectrico ;
    rdfs:label      "Botón CUSTOM"@es ;
    ex:textoExtracto
                    "dan acceso a las pantallas de movimientos manuales a través del botón 'CUSTOM'"@es ;
    ex:tieneComponente ex:VersionKeyboard_74 ,
                      ex:VersionJog_74 .

ex:BotonCambioVersion_74
    a               ex:ComponenteElectrico ;
    rdfs:label      "Botones de cambio de versión del teclado"@pl ;
    ex:textoExtracto
                    "En la parte superior hay dos botones que permiten cambiar la versión del teclado"@es .

ex:BotonZPositivo_74
    a               ex:ComponenteElectrico ;
    rdfs:label      "Botón Z+"@es ;
    ex:textoExtracto
                    "pulsando los botones Z+, Z-, C+, C-"@es ;
    ex:tieneComponente ex:VersionJog_74 .

ex:BotonZNegativo_74
    a               ex:ComponenteElectrico ;
    rdfs:label      "Botón Z-"@es ;
    ex:textoExtracto
                    "pulsando los botones Z+, Z-, C+, C-"@es ;
    ex:tieneComponente ex:VersionJog_74 .

ex:BotonCPositivo_74
    a               ex:ComponenteElectrico ;
    rdfs:label      "Botón C+"@es ;
    ex:textoExtracto
                    "pulsando los botones Z+, Z-, C+, C-"@es ;
    ex:tieneComponente ex:VersionJog_74 .

ex:BotonCNegativo_74
    a               ex:ComponenteElectrico ;
    rdfs:label      "Botón C-"@es ;
    ex:textoExtracto
                    "pulsando los botones Z+, Z-, C+, C-"@es ;
    ex:tieneComponente ex:VersionJog_74 .