@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjeC_75 a ns1:ComponenteMecanico ;
    rdfs:label "Eje C"@es ;
    ns1:textoExtracto "muestra las posiciones de los ejes de la máquina (Z, Z1 y C)"@es .

ns1:EjeZ1_75 a ns1:ComponenteMecanico ;
    rdfs:label "Eje Z1"@es ;
    ns1:textoExtracto "muestra las posiciones de los ejes de la máquina (Z, Z1 y C)"@es .

ns1:EjeZ_75 a ns1:ComponenteMecanico ;
    rdfs:label "Eje Z"@es ;
    ns1:textoExtracto "muestra las posiciones de los ejes de la máquina (Z, Z1 y C)"@es .

ns1:PantallaPrincipal_75 a ns1:InterfazUsuario ;
    rdfs:label "Pantalla principal"@es ;
    ns1:compuestoPor ns1:SoftkeyHorizontalCicloBrochado_75,
        ns1:SoftkeyVerticalInspeccion_75 ;
    ns1:textoExtracto "Es la pantalla principal de la máquina y muestra las posiciones de los ejes de la máquina (Z, Z1 y C), el avance y las propiedades del ciclo de brochado."@es .

ns1:PortonPrincipal_75 a ns1:ComponenteMecanico ;
    rdfs:label "Portón principal"@es ;
    ns1:textoExtracto "con el portón principal abierto"@es .

ns1:CarroPortaPieza_75 a ns1:ComponenteMecanico ;
    rdfs:label "Carro porta-pieza"@es ;
    ns1:textoExtracto "habilita el movimiento del carro porta-pieza a velocidad reducida"@es .

ns1:ModoSetUp_75 a ns1:ModoOperacion ;
    rdfs:label "Modo set-up"@es ;
    ns1:textoExtracto "cuando la máquina se encuentra en modo set-up con el portón principal abierto."@es .

ns1:PantallaSeleccionCicloBrochado_75 a ns1:InterfazUsuario ;
    rdfs:label "Pantalla de selección del ciclo de brochado"@es ;
    ns1:textoExtracto "permite acceder a la pantalla de selección del ciclo de brochado."@es .

ns1:SoftkeyHorizontalCicloBrochado_75 a ns1:InterfazUsuario ;
    rdfs:label "Softkey horizontal Ciclo brochado"@es ;
    ns1:documentadoEn ns1:PantallaSeleccionCicloBrochado_75 ;
    ns1:textoExtracto "El botón 'Ciclo brochado' de las softkeys horizontales permite acceder a la pantalla de selección del ciclo de brochado."@es .

ns1:SoftkeyVerticalInspeccion_75 a ns1:InterfazUsuario ;
    rdfs:label "Softkey vertical Inspección"@es ;
    ns1:controla ns1:CarroPortaPieza_75 ;
    ns1:habilitadoPor ns1:ModoSetUp_75 ;
    ns1:textoExtracto "El botón 'Inspección' de las softkeys verticales habilita el movimiento del carro porta-pieza a velocidad reducida cuando la máquina se encuentra en modo set-up con el portón principal abierto."@es .

