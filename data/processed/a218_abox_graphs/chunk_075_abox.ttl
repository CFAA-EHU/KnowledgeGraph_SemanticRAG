@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:pantallaPrincipal_6261
    a                     ex:InterfazUsuario ;
    rdfs:label            "Pantalla principal"@es ;
    ex:textoExtracto       "Es la pantalla principal de la máquina y muestra las posiciones de los ejes de la máquina (Z, Z1 y C), el avance y las propiedades del ciclo de brochado."@es ;
    ex:ilustradoEn         ex:botonInspeccion_6261 , ex:botonCicloBrochado_6261 ;
    ex:monitoreaParametro  ex:parametroPosicionEjeZ_6261 , ex:parametroPosicionEjeZ1_6261 , ex:parametroPosicionEjeC_6261 , ex:parametroAvance_6261 .

ex:botonInspeccion_6261
    a               ex:ComponenteElectrico ;
    rdfs:label      "Botón Inspección (softkey vertical)"@es ;
    ex:textoExtracto "El botón 'Inspección' de las softkeys verticales habilita el movimiento del carro porta-pieza a velocidad reducida cuando la máquina se encuentra en modo set-up con el portón principal abierto."@es ;
    ex:habilitadoPor ex:modoSetup_6261 .

ex:botonCicloBrochado_6261
    a               ex:ComponenteElectrico ;
    rdfs:label      "Botón Ciclo brochado (softkey horizontal)"@es ;
    ex:textoExtracto "El botón 'Ciclo brochado' de las softkeys horizontales permite acceder a la pantalla de selección del ciclo de brochado."@es .

ex:modoSetup_6261
    a               ex:ModoOperacion ;
    rdfs:label      "Modo set-up (portón abierto)"@es ;
    ex:textoExtracto "modo set-up con el portón principal abierto"@es .

ex:parametroPosicionEjeZ_6261
    a               ex:Parametro ;
    rdfs:label      "Posición eje Z"@es ;
    ex:textoExtracto "posiciones de los ejes de la máquina (Z, Z1 y C)"@es .

ex:parametroPosicionEjeZ1_6261
    a               ex:Parametro ;
    rdfs:label      "Posición eje Z1"@es ;
    ex:textoExtracto "posiciones de los ejes de la máquina (Z, Z1 y C)"@es .

ex:parametroPosicionEjeC_6261
    a               ex:Parametro ;
    rdfs:label      "Posición eje C"@es ;
    ex:textoExtracto "posiciones de los ejes de la máquina (Z, Z1 y C)"@es .

ex:parametroAvance_6261
    a               ex:Parametro ;
    rdfs:label      "Avance"@es ;
    ex:textoExtracto "el avance y las propiedades del ciclo de brochado"@es .