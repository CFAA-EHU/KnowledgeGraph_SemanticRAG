@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PantallaPrincipalMaquinaBrochadora a ns1:InterfazUsuario ;
    rdfs:label "Pantalla principal" ;
    ns1:textoExtracto "Es la pantalla principal de la máquina y muestra las posiciones de los ejes de la máquina (Z, Z1 y C), el avance y las propiedades del ciclo de brochado." ;
    ns1:tieneComponente ns1:BotonCicloBrochado,
        ns1:BotonInspeccion .

ns1:BotonCicloBrochado a ns1:Componente ;
    rdfs:label "Botón Ciclo brochado" ;
    ns1:textoExtracto "El botón 'Ciclo brochado' de las softkeys horizontales permite acceder a la pantalla de selección del ciclo de brochado." .

ns1:BotonInspeccion a ns1:Componente ;
    rdfs:label "Botón Inspección" ;
    ns1:textoExtracto "El botón 'Inspección' de las softkeys verticales habilita el movimiento del carro porta-pieza a velocidad reducida cuando la máquina se encuentra en modo set-up con el portón principal abierto." .

