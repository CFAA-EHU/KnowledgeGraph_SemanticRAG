@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_958844fc18 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Para acceder a las pantallas hay que pulsar el botón 'CUSTOM' desde el teclado." ;
    ns1:tieneComponente ns1:PantallaArranqueMotores,
        ns1:PantallaMovimientosMaquina .

ns1:ComponenteElectrico_45f6c5147c a ns1:ComponenteElectrico ;
    rdfs:label "Motor Refrigerante A Brocha/Bastidor" ;
    ns1:textoExtracto "La columna 'MARCHA' permite arrancar y parar los motores de 'REFRIGERANTE A BROCHA/BASTIDOR'" .

ns1:ComponenteElectrico_750cf73729 a ns1:ComponenteElectrico ;
    rdfs:label "Motor Extractor de Virutas" ;
    ns1:textoExtracto "La columna 'MARCHA' permite arrancar y parar los motores de 'EXTRACTOR DE VIRUTA'" .

ns1:PantallaArranqueMotores a ns1:InterfazUsuario ;
    rdfs:label "Pantalla Arranque Motores" ;
    ns1:textoExtracto "Esta pantalla muestra el estado de todos los motores de la máquina (REFRIGERANTE A BROCHA/BASTIDOR, TRASVASE REFRIGERANTE, GRUPO HIDRÁULICO, EXTRACTOR DE VIRUTAS y MOTOR ENGRASE) y dispone de cuatro columnas (MARCHA, MOTOR, DISYUNTOR y SEÑALES)." .

ns1:PantallaMovimientosMaquina a ns1:InterfazUsuario ;
    rdfs:label "Pantalla Movimientos Máquina" ;
    ns1:textoExtracto "Esta pantalla permite controlar los movimientos de la máquina. El carro de tracción se puede llevar a tres posiciones (superior, intermedio e inferior), mientras que la mesa giratoria se puede subir/bajar y girar." .

