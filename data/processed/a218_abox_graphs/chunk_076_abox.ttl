@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:GrupoHidraulico a ns1:ComponenteHidraulico ;
    rdfs:label "grupo hidráulico" ;
    ns1:textoExtracto "En la columna 'SEÑALES' hay dos señalizadores de nivel mínimo; uno para el refrigerante y otro para el grupo hidráulico." .

ns1:MotorEngrase a ns1:ComponenteElectrico ;
    rdfs:label "motor MOTOR ENGRASE" ;
    ns1:textoExtracto "muestra el estado de todos los motores de la máquina (REFRIGERANTE A BROCHA/BASTIDOR/BASTIDOR, TRASVASE REFRIGERANTE, GRUPO HIDRÁULICO, EXTRACTOR DE VIRUTAS y MOTOR ENGRASE)" .

ns1:MotorExtractorVirutas a ns1:ComponenteElectrico ;
    rdfs:label "motor EXTRACTOR DE VIRUTAS" ;
    ns1:textoExtracto "muestra el estado de todos los motores de la máquina (REFRIGERANTE A BROCHA/BASTIDOR/BASTIDOR, TRASVASE REFRIGERANTE, GRUPO HIDRÁULICO, EXTRACTOR DE VIRUTAS y MOTOR ENGRASE)" .

ns1:MotorRefrigeranteBrochaBastidor a ns1:ComponenteElectrico ;
    rdfs:label "motor REFRIGERANTE A BROCHA/BASTIDOR" ;
    ns1:textoExtracto "muestra el estado de todos los motores de la máquina (REFRIGERANTE A BROCHA/BASTIDOR/BASTIDOR, TRASVASE REFRIGERANTE, GRUPO HIDRÁULICO, EXTRACTOR DE VIRUTAS y MOTOR ENGRASE)" .

ns1:PantallaArranqueMotores a ns1:InterfazUsuario ;
    rdfs:label "pantalla Arranque motores" ;
    ns1:compuestoPor ns1:ColumnaDisyuntor,
        ns1:ColumnaMarcha,
        ns1:ColumnaMotor,
        ns1:ColumnaSenales ;
    ns1:textoExtracto "Arranque motores  Esta pantalla muestra el estado de todos los motores de la máquina" .

ns1:PantallaMovimientosManuales a ns1:InterfazUsuario ;
    rdfs:label "pantallas de movimientos manuales" ;
    ns1:textoExtracto "Hay cuatro pantallas de movimientos manuales (Movimientos máquina, Arranque motores, Ciclo cambio de brocha y Condiciones máquina)." ;
    ns1:tieneComponente ns1:BotonCUSTOM,
        ns1:BotonOPMAN1_4 .

ns1:PantallaMovimientosMaquina a ns1:InterfazUsuario ;
    rdfs:label "pantalla Movimientos máquina" ;
    ns1:compuestoPor ns1:CarroTraccion,
        ns1:IndicadorPosicionesEjes,
        ns1:IndicadorTemperaturaMotores,
        ns1:MesaGiratoria,
        ns1:SenalizadorConsumosMotores,
        ns1:SenalizadorFrenosMAYR ;
    ns1:textoExtracto "Movimientos máquina  Esta pantalla permite controlar los movimientos de la máquina." .

ns1:BotonCUSTOM a ns1:Componente ;
    rdfs:label "botón CUSTOM" ;
    ns1:textoExtracto "Para acceder a las pantallas hay que pulsar el botón 'CUSTOM' desde el teclado." .

ns1:BotonOPMAN1_4 a ns1:Componente ;
    rdfs:label "botón OP MAN 1/4" ;
    ns1:textoExtracto "Para cambiar de una pantalla a otra hay que pulsar el botón 'OP MAN 1/4' de la parte superior." .

ns1:CarroTraccion a ns1:ComponenteMecanico ;
    rdfs:label "carro de tracción" ;
    ns1:textoExtracto "El carro de tracción se puede llevar a tres posiciones (superior, intermedio e inferior)" .

ns1:ColumnaDisyuntor a ns1:InterfazUsuario ;
    rdfs:label "columna DISYUNTOR" ;
    ns1:textoExtracto "La columna 'DISYUNTOR' permite visualizar el estado de la protección eléctrica de los motores." .

ns1:ColumnaMarcha a ns1:InterfazUsuario ;
    rdfs:label "columna MARCHA" ;
    ns1:textoExtracto "La columna 'MARCHA' permite arrancar y parar los motores de 'REFRIGERANTE A BROCHA/BASTIDOR' y 'EXTRACTOR DE VIRUTA' y activar una embolada de engrase." .

ns1:ColumnaMotor a ns1:InterfazUsuario ;
    rdfs:label "columna MOTOR" ;
    ns1:textoExtracto "La columna 'MOTOR' muestra el estado de los motores (si están activados o no) a través de unos señalizadores" .

ns1:ColumnaSenales a ns1:InterfazUsuario ;
    rdfs:label "columna SEÑALES" ;
    ns1:textoExtracto "En la columna 'SEÑALES' hay dos señalizadores de nivel mínimo; uno para el refrigerante y otro para el grupo hidráulico." .

ns1:IndicadorPosicionesEjes a ns1:Sensor ;
    rdfs:label "indicador de posiciones de los ejes Z, Z1 y C" ;
    ns1:textoExtracto "muestra [...] las posiciones de los ejes Z, Z1 y C" .

ns1:IndicadorTemperaturaMotores a ns1:Sensor ;
    rdfs:label "indicador de temperatura de los motores" ;
    ns1:textoExtracto "También muestra la temperatura de los motores" .

ns1:MesaGiratoria a ns1:ComponenteMecanico ;
    rdfs:label "mesa giratoria" ;
    ns1:textoExtracto "la mesa giratoria se puede subir/bajar y girar" .

ns1:SenalizadorConsumosMotores a ns1:Sensor ;
    rdfs:label "señalizadores de consumos de los motores" ;
    ns1:textoExtracto "señalizadores que indican [...] los consumos de los motores de los ejes del carro de tracción y de la mesa giratoria" .

ns1:SenalizadorFrenosMAYR a ns1:Sensor ;
    rdfs:label "señalizadores que indican el estado de los frenos MAYR" ;
    ns1:textoExtracto "dispone de varios señalizadores que indican el estado en el que se encuentran los frenos MAYR" .

