@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PantallaCambioHerramienta a ns1:InterfazUsuario ;
    rdfs:label "Pantalla de cambio de herramienta" ;
    ns1:textoExtracto "Esta pantalla guía al operario en los pasos que tiene que realizar para realizar el cambio de herramienta." .

ns1:SenalizadorDeErrorDeEngrasado_a21f11cc02 a ns1:Alarma ;
    rdfs:label "Señalizador de error de engrasado" ;
    ns1:textoExtracto "También hay un señalizador para el caudal del refrigerante y dos para los errores del engrase (error de embolada o de nivel mínimo)" .

ns1:SenalizadorDeNivelMinimoDelGrupoHidraulico_cbd061cfba a ns1:Alarma ;
    rdfs:label "Señalizador de nivel mínimo del grupo hidráulico" ;
    ns1:textoExtracto "En la columna 'SEÑALES' hay dos señalizadores de nivel mínimo; uno para el refrigerante y otro para el grupo hidráulico." .

ns1:SenalizadorDeNivelMinimoDelRefrigerante_13c362bfb6 a ns1:Alarma ;
    rdfs:label "Señalizador de nivel mínimo del refrigerante" ;
    ns1:textoExtracto "En la columna 'SEÑALES' hay dos señalizadores de nivel mínimo; uno para el refrigerante y otro para el grupo hidráulico." .

ns1:SenalizadorDelCaudalDelRefrigerante_cda5393ce2 a ns1:Alarma ;
    rdfs:label "Señalizador del caudal del refrigerante" ;
    ns1:textoExtracto "También hay un señalizador para el caudal del refrigerante y dos para los errores del engrase (error de embolada o de nivel mínimo)" .

