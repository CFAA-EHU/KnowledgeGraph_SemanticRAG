@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Seccion6_2_6_2_MovimientosManuales
    a ex:Capitulo ;
    rdfs:label "6.2.6.2 Movimientos manuales"@es ;
    ex:textoExtracto "En la columna 'SEÑALES' hay dos señalizadores de nivel mínimo; uno para el refrigerante y otro para el grupo hidráulico. También hay un señalizador para el caudal del refrigerante y dos para los errores del engrase (error de embolada o de nivel mínimo). Ciclo cambio de brocha. Esta pantalla guía al operario en los pasos que tiene que realizar para realizar el cambio de herramienta."@es .

ex:InterfazUsuario_CambioBrocha
    a ex:InterfazUsuario ;
    rdfs:label "Pantalla de cambio de brocha"@es ;
    ex:textoExtracto "Esta pantalla guía al operario en los pasos que tiene que realizar para realizar el cambio de herramienta. Desde esta pantalla no se pueden ejecutar los movimientos"@es ;
    ex:documentadoEn ex:Seccion6_2_6_2_MovimientosManuales .

ex:Sensor_NivelMinimo_Refrigerante
    a ex:Sensor ;
    rdfs:label "Señalizador de nivel mínimo de refrigerante"@es ;
    ex:textoExtracto "hay dos señalizadores de nivel mínimo; uno para el refrigerante"@es ;
    ex:ilustradoEn ex:Seccion6_2_6_2_MovimientosManuales .

ex:Sensor_NivelMinimo_GrupoHidraulico
    a ex:Sensor ;
    rdfs:label "Señalizador de nivel mínimo del grupo hidráulico"@es ;
    ex:textoExtracto "uno para el refrigerante y otro para el grupo hidráulico"@es ;
    ex:ilustradoEn ex:Seccion6_2_6_2_MovimientosManuales .

ex:Sensor_Caudal_Refrigerante
    a ex:Sensor ;
    rdfs:label "Señalizador de caudal de refrigerante"@es ;
    ex:textoExtracto "También hay un señalizador para el caudal del refrigerante"@es ;
    ex:ilustradoEn ex:Seccion6_2_6_2_MovimientosManuales .

ex:Sensor_ErrorEngrase_Embolada
    a ex:Sensor ;
    rdfs:label "Señalizador de error de embolada en engrase"@es ;
    ex:textoExtracto "dos para los errores del engrase (error de embolada o de nivel mínimo)"@es ;
    ex:ilustradoEn ex:Seccion6_2_6_2_MovimientosManuales .

ex:Sensor_ErrorEngrase_NivelMinimo
    a ex:Sensor ;
    rdfs:label "Señalizador de error de nivel mínimo en engrase"@es ;
    ex:textoExtracto "dos para los errores del engrase (error de embolada o de nivel mínimo)"@es ;
    ex:ilustradoEn ex:Seccion6_2_6_2_MovimientosManuales .

ex:Sistema_Se_ales
    a ex:Sistema ;
    rdfs:label "Columna 'SEÑALES'"@es ;
    ex:textoExtracto "En la columna 'SEÑALES' hay dos señalizadores de nivel mínimo"@es ;
    ex:tieneComponente ex:Sensor_NivelMinimo_Refrigerante ;
    ex:tieneComponente ex:Sensor_NivelMinimo_GrupoHidraulico ;
    ex:tieneComponente ex:Sensor_Caudal_Refrigerante ;
    ex:tieneComponente ex:Sensor_ErrorEngrase_Embolada ;
    ex:tieneComponente ex:Sensor_ErrorEngrase_NivelMinimo ;
    ex:detalladoEnEsquema ex:Seccion6_2_6_2_MovimientosManuales .