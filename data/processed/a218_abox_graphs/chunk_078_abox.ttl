@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CicloCambioDeBrocha_9fd048c2c7 a ns1:TareaMantenimiento ;
    rdfs:label "Ciclo cambio de brocha" ;
    ns1:documentadoEn ns1:PantallaMovimientosMaquina ;
    ns1:textoExtracto "Ciclo cambio de brocha  Esta pantalla guía al operario en los pasos que tiene que realizar para realizar el cambio de herramienta." .

ns1:PantallaEstadoMaquina a ns1:InterfazUsuario ;
    rdfs:label "Pantalla Estado Máquina" ;
    ns1:textoExtracto "Esta pantalla muestra el estado de las señales de diagnóstico de la máquina. En caso de que haya algún error se accede a esta página para detectarlo." .

ns1:PantallaMovimientosMaquina a ns1:InterfazUsuario ;
    rdfs:label "Pantalla de Movimientos máquina" ;
    ns1:textoExtracto "Desde esta pantalla no se pueden ejecutar los movimientos, para ello hay que acceder a la pantalla de 'Movimientos máquina'." .

