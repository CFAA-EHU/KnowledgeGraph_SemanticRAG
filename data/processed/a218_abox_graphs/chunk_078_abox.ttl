@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:pantalla_cambio_brocha
    a ex:InterfazUsuario ;
    rdfs:label "Pantalla de ciclo cambio de brocha" ;
    ex:textoExtracto "Esta pantalla guía al operario en los pasos que tiene que realizar para realizar el cambio de herramienta." ;
    ex:ilustradoEn ex:pantalla_movimientos_maquina .

ex:pantalla_movimientos_maquina
    a ex:InterfazUsuario ;
    rdfs:label "Pantalla de Movimientos máquina" ;
    ex:textoExtracto "para ello hay que acceder a la pantalla de 'Movimientos máquina'." .

ex:pantalla_condiciones_maquina
    a ex:InterfazUsuario ;
    rdfs:label "Pantalla de Condiciones máquina" ;
    ex:textoExtracto "Esta pantalla muestra el estado de las señales de diagnóstico de la máquina. En caso de que haya algún error se accede a esta página para detectarlo." ;
    ex:monitoreaParametro ex:se_ales_diagnostico .

ex:se_ales_diagnostico
    a ex:Parametro ;
    rdfs:label "Señales de diagnóstico de la máquina" ;
    ex:textoExtracto "el estado de las señales de diagnóstico de la máquina" .