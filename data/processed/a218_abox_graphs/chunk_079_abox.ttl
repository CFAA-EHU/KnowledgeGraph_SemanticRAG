@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_895599822e a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El acceso a esta pantalla se realiza a través de la pantalla principal pulsando el botón 'Ciclo brochado'." ;
    ns1:tieneComponente ns1:AvanceFAcabado,
        ns1:AvanceFDesbaste,
        ns1:NumeroDeRanuras_0127fe9d70,
        ns1:Parametro_47117b6ae9,
        ns1:PasoEntreRanuras,
        ns1:PasoIncremento_c7c6af6b2c,
        ns1:PosicionInicialDelPlatoAngulo,
        ns1:TipoDeOperacion,
        ns1:TipoDePieza .

ns1:EjecutarCiclo a ns1:TareaMantenimiento ;
    rdfs:label "Ejecutar ciclo" ;
    ns1:textoExtracto "de ejecutar el ciclo pulsando el botón 'Ejecutar ciclo'." .

ns1:MemorizarCiclo_9a700911c4 a ns1:TareaMantenimiento ;
    rdfs:label "Memorizar ciclo" ;
    ns1:textoExtracto "y de guardar el ciclo en la memoria de la máquina con los parámetros seleccionados pulsando el botón 'Memorizar ciclo'." .

ns1:SimularCiclo a ns1:TareaMantenimiento ;
    rdfs:label "Simular ciclo" ;
    ns1:textoExtracto "A través de las softkeys verticales existe la posibilidad de simular el ciclo pulsando el botón 'Simular ciclo'." .

ns1:AvanceFAcabado a ns1:Parametro ;
    rdfs:label "Avance (F Acabado)" ;
    ns1:identificador "AvanceAcabado" ;
    ns1:textoExtracto "En los ciclos con pieza en forma de anillo se pueden modificar los siguientes parámetros de brochado: Avance (F Desbaste y F Acabado)." .

ns1:AvanceFDesbaste a ns1:Parametro ;
    rdfs:label "Avance (F Desbaste)" ;
    ns1:identificador "AvanceDesbaste" ;
    ns1:textoExtracto "En los ciclos con pieza en forma de anillo se pueden modificar los siguientes parámetros de brochado: Avance (F Desbaste y F Acabado)." .

ns1:NumeroDeRanuras_0127fe9d70 a ns1:Parametro ;
    rdfs:label "Número de ranuras" ;
    ns1:identificador "NumeroRanuras" ;
    ns1:textoExtracto "El valor de 'Número de ranuras' hace referencia a cada cuantos brochados se realiza la inspección." .

ns1:Parametro_47117b6ae9 a ns1:Parametro ;
    rdfs:label "Refrigeración" ;
    ns1:identificador "Refrigerante" ;
    ns1:textoExtracto "Seleccionar si el ciclo se va a realizar con o sin refrigerante." .

ns1:PasoEntreRanuras a ns1:Parametro ;
    rdfs:label "Paso entre ranuras" ;
    ns1:identificador "PasoEntreRanuras" ;
    ns1:textoExtracto "Paso entre ranuras." .

ns1:PasoIncremento_c7c6af6b2c a ns1:Parametro ;
    rdfs:label "Paso incremento" ;
    ns1:identificador "PasoIncremento" ;
    ns1:textoExtracto "Con el valor de 'Paso incremento' se la distancia entre cada foto realizada a la herramienta;" .

ns1:PosicionInicialDelPlatoAngulo a ns1:Parametro ;
    rdfs:label "Posición inicial del plato (Ángulo)" ;
    ns1:identificador "PosicionInicialPlato" ;
    ns1:textoExtracto "Posición inicial del plato (Ángulo)." .

ns1:TipoDeOperacion a ns1:Parametro ;
    rdfs:label "Tipo de operación" ;
    ns1:identificador "TipoOperacion" ;
    ns1:textoExtracto "El tipo de operación a seleccionar es entre desbaste y acabado." .

ns1:TipoDePieza a ns1:Parametro ;
    rdfs:label "Tipo de pieza" ;
    ns1:identificador "TipoPieza" ;
    ns1:textoExtracto "El tipo de pieza a seleccionar es entre anillo y plana." .

