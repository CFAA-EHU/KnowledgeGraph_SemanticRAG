@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:AvanceAcabado a ns1:Parametro ;
    ns1:textoExtracto "Avance (F Desbaste y F Acabado)" .

ns1:AvanceDesbaste a ns1:Parametro ;
    ns1:textoExtracto "Avance (F Desbaste y F Acabado)" .

ns1:CicloBrochado a ns1:ModoOperacion ;
    ns1:detalladoEnEsquema ns1:PantallaPrincipal ;
    ns1:textoExtracto "El acceso a esta pantalla se realiza a través de la pantalla principal pulsando el botón 'Ciclo brochado'." .

ns1:ConRefrigerante a ns1:ModoOperacion ;
    ns1:textoExtracto "Refrigeración: Seleccionar si el ciclo se va a realizar con o sin refrigerante." .

ns1:MaquinaBrochadora a ns1:Maquina ;
    ns1:textoExtracto "A través de las softkeys verticales existe la posibilidad de simular el ciclo pulsando el botón 'Simular ciclo', de ejecutar el ciclo pulsando el botón 'Ejecutar ciclo' y de guardar el ciclo en la memoria de la máquina con los parámetros seleccionados pulsando el botón 'Memorizar ciclo'. Otra posibilidad que ofrece la máquina para cada tipo de ciclo es la de incorporar un ciclo de inspección, que consiste en la captura de varias fotos de la herramienta." ;
    ns1:tieneComponente ns1:CicloInspeccion,
        ns1:EjecutarCiclo,
        ns1:MemorizarCiclo,
        ns1:SimularCiclo .

ns1:NumeroRanuras a ns1:Parametro ;
    ns1:textoExtracto "Número de ranuras" .

ns1:NumeroRanurasInspeccion a ns1:Parametro ;
    ns1:textoExtracto "El valor de 'Número de ranuras' hace referencia a cada cuantos brochados se realiza la inspección." .

ns1:OperacionAcabado a ns1:ModoOperacion ;
    ns1:textoExtracto "Tipo de operación: El tipo de operación a seleccionar es entre desbaste y acabado." .

ns1:OperacionDesbaste a ns1:ModoOperacion ;
    ns1:textoExtracto "Tipo de operación: El tipo de operación a seleccionar es entre desbaste y acabado." .

ns1:PasoEntreRanuras a ns1:Parametro ;
    ns1:textoExtracto "Paso entre ranuras" .

ns1:PasoIncremento a ns1:Parametro ;
    ns1:textoExtracto "Paso incremento" .

ns1:PiezaAnillo a ns1:PiezaRecambio ;
    ns1:textoExtracto "Tipo de pieza: El tipo de pieza a seleccionar es entre anillo y plana." .

ns1:PiezaPlana a ns1:PiezaRecambio ;
    ns1:textoExtracto "Tipo de pieza: El tipo de pieza a seleccionar es entre anillo y plana." .

ns1:PosicionInicialPlato a ns1:Parametro ;
    ns1:textoExtracto "Posición inicial del plato (Ángulo)" .

ns1:Refrigeracion a ns1:Parametro ;
    ns1:textoExtracto "Refrigeración: Seleccionar si el ciclo se va a realizar con o sin refrigerante." ;
    ns1:valor "con refrigerante, sin refrigerante" .

ns1:SinRefrigerante a ns1:ModoOperacion ;
    ns1:textoExtracto "Refrigeración: Seleccionar si el ciclo se va a realizar con o sin refrigerante." .

ns1:TipoOperacion a ns1:Parametro ;
    ns1:textoExtracto "Tipo de operación: El tipo de operación a seleccionar es entre desbaste y acabado." ;
    ns1:valor "desbaste, acabado" .

ns1:TipoPieza a ns1:Parametro ;
    ns1:textoExtracto "Tipo de pieza: El tipo de pieza a seleccionar es entre anillo y plana." ;
    ns1:valor "anillo, plana" .

ns1:CicloInspeccion a ns1:ModoOperacion ;
    ns1:textoExtracto "Otra posibilidad que ofrece la máquina para cada tipo de ciclo es la de incorporar un ciclo de inspección, que consiste en la captura de varias fotos de la herramienta." .

ns1:EjecutarCiclo a ns1:TareaMantenimiento ;
    ns1:textoExtracto "de ejecutar el ciclo pulsando el botón 'Ejecutar ciclo'" .

ns1:MemorizarCiclo a ns1:TareaMantenimiento ;
    ns1:textoExtracto "y de guardar el ciclo en la memoria de la máquina con los parámetros seleccionados pulsando el botón 'Memorizar ciclo'." .

ns1:PantallaPrincipal a ns1:InterfazUsuario ;
    ns1:textoExtracto "El acceso a esta pantalla se realiza a través de la pantalla principal pulsando el botón 'Ciclo brochado'." .

ns1:SimularCiclo a ns1:AccionProhibida ;
    ns1:textoExtracto "A través de las softkeys verticales existe la posibilidad de simular el ciclo pulsando el botón 'Simular ciclo'." .

