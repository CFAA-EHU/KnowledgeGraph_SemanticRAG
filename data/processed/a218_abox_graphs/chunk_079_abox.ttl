@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazUsuario_CicloBrochado
    a ex:InterfazUsuario ;
    rdfs:label "Pantalla de Ciclo de Brochado"@es ;
    ex:textoExtracto "El acceso a esta pantalla se realiza a través de la pantalla principal pulsando el botón 'Ciclo brochado'."@es ;
    ex:tieneComponente ex:Parametro_TipoPieza ;
    ex:tieneComponente ex:Parametro_TipoOperacion ;
    ex:tieneComponente ex:Parametro_Refrigeracion ;
    ex:tieneComponente ex:Parametro_AvanceDesbaste ;
    ex:tieneComponente ex:Parametro_AvanceAcabado ;
    ex:tieneComponente ex:Parametro_PosicionInicialPlato ;
    ex:tieneComponente ex:Parametro_NumeroRanuras ;
    ex:tieneComponente ex:Parametro_PasoEntreRanuras ;
    ex:tieneComponente ex:Parametro_NumeroRanurasInspeccion ;
    ex:tieneComponente ex:Parametro_PasoIncrementoInspeccion ;
    ex:tieneComponente ex:Accion_SimularCiclo ;
    ex:tieneComponente ex:Accion_EjecutarCiclo ;
    ex:tieneComponente ex:Accion_MemorizarCiclo ;
    ex:tieneComponente ex:Accion_InspeccionHerramienta .

ex:Parametro_TipoPieza
    a ex:Parametro ;
    rdfs:label "Tipo de pieza"@es ;
    ex:textoExtracto "Tipo de pieza: El tipo de pieza a seleccionar es entre anillo y plana."@es ;
    ex:valor "anillo"@es, "plana"@es .

ex:Parametro_TipoOperacion
    a ex:Parametro ;
    rdfs:label "Tipo de operación"@es ;
    ex:textoExtracto "Tipo de operación: El tipo de operación a seleccionar es entre desbaste y acabado."@es ;
    ex:valor "desbaste"@es, "acabado"@es .

ex:Parametro_Refrigeracion
    a ex:Parametro ;
    rdfs:label "Refrigeración"@es ;
    ex:textoExtracto "Refrigeración: Seleccionar si el ciclo se va a realizar con o sin refrigerante."@es ;
    ex:valor "con refrigerante"@es, "sin refrigerante"@es .

ex:Parametro_AvanceDesbaste
    a ex:Parametro ;
    rdfs:label "Avance (F Desbaste)"@es ;
    ex:textoExtracto "Avance (F Desbaste y F Acabado)"@es .

ex:Parametro_AvanceAcabado
    a ex:Parametro ;
    rdfs:label "Avance (F Acabado)"@es ;
    ex:textoExtracto "Avance (F Desbaste y F Acabado)"@es .

ex:Parametro_PosicionInicialPlato
    a ex:Parametro ;
    rdfs:label "Posición inicial del plato (Ángulo)"@es ;
    ex:textoExtracto "Posición inicial del plato (Ángulo)"@es .

ex:Parametro_NumeroRanuras
    a ex:Parametro ;
    rdfs:label "Número de ranuras"@es ;
    ex:textoExtracto "Número de ranuras"@es .

ex:Parametro_PasoEntreRanuras
    a ex:Parametro ;
    rdfs:label "Paso entre ranuras"@es ;
    ex:textoExtracto "Paso entre ranuras"@es .

ex:Parametro_NumeroRanurasInspeccion
    a ex:Parametro ;
    rdfs:label "Número de ranuras (inspección)"@es ;
    ex:textoExtracto "El valor de 'Número de ranuras' hace referencia a cada cuantos brochados se realiza la inspección."@es .

ex:Parametro_PasoIncrementoInspeccion
    a ex:Parametro ;
    rdfs:label "Paso incremento (inspección)"@es ;
    ex:textoExtracto "Con el valor de 'Paso incremento' se [define] la distancia entre cada foto realizada a la herramienta; la primera siempre se realiza al primer diente y la última al último diente."@es .

ex:Accion_SimularCiclo
    a ex:AccionProhibida ;
    rdfs:label "Simular ciclo"@es ;
    ex:textoExtracto "existe la posibilidad de simular el ciclo pulsando el botón 'Simular ciclo'"@es .

ex:Accion_EjecutarCiclo
    a ex:AccionProhibida ;
    rdfs:label "Ejecutar ciclo"@es ;
    ex:textoExtracto "existe la posibilidad de [...] ejecutar el ciclo pulsando el botón 'Ejecutar ciclo'"@es .

ex:Accion_MemorizarCiclo
    a ex:AccionProhibida ;
    rdfs:label "Memorizar ciclo"@es ;
    ex:textoExtracto "existe la posibilidad de [...] guardar el ciclo en la memoria de la máquina [...] pulsando el botón 'Memorizar ciclo'."@es .

ex:Accion_InspeccionHerramienta
    a ex:AccionProhibida ;
    rdfs:label "Inspección de herramienta"@es ;
    ex:textoExtracto "Otra posibilidad que ofrece la máquina para cada tipo de ciclo es la de incorporar un ciclo de inspección, que consiste en la captura de varias fotos de la herramienta."@es .