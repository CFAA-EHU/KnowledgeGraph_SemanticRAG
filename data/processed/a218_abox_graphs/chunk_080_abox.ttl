@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:pantalla_ciclo_brochado_69
    a ex:InterfazUsuario ;
    rdfs:label "Pantalla de ciclo de brochado"@es ;
    ex:textoExtracto "En la pantalla de ciclo de brochado se seleccionan los parámetros deseados"@es ;
    ex:tieneComponente ex:parametros_brochado_69 ;
    ex:tieneComponente ex:opcion_guardar_programa_69 .

ex:parametros_brochado_69
    a ex:Parametro ;
    rdfs:label "Parámetros de brochado"@es ;
    ex:textoExtracto "parámetros deseados; para guardarlos en un programa nuevo: [...] Pulsar parámetros +, vuelca parámetros de brochado al programa"@es .

ex:opcion_guardar_programa_69
    a ex:InterfazUsuario ;
    rdfs:label "Opción 'Memorizar ciclo'"@es ;
    ex:textoExtracto "Memorizar ciclo  Nuevo programa  Poner nombre deseado"@es ;
    ex:controla ex:accion_guardar_programa_69 .

ex:accion_guardar_programa_69
    a ex:TareaMantenimiento ;
    rdfs:label "Guardar parámetros de brochado en programa"@es ;
    ex:textoExtracto "Nuevo programa  Poner nombre deseado  Pulsar parámetros +, vuelca parámetros de brochado al programa  Se añade un M30 al final"@es ;
    ex:requiereMantenimiento ex:parametros_brochado_69 .