@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MemorizarCiclo a ns1:Parametro ;
    rdfs:label "Memorizar ciclo" ;
    ns1:textoExtracto "En la pantalla de ciclo de brochado se seleccionan los parámetros deseados; para guardarlos en un programa nuevo: Memorizar ciclo" .

ns1:NuevoPrograma_8b118e2c2a a ns1:Parametro ;
    rdfs:label "Nuevo programa" ;
    ns1:textoExtracto "Memorizar ciclo  Nuevo programa" .

ns1:PonerNombreDeseado_136413c1a4 a ns1:Parametro ;
    rdfs:label "Poner nombre deseado" ;
    ns1:textoExtracto "Nuevo programa  Poner nombre deseado" .

ns1:PulsarParametros_ef14262384 a ns1:Parametro ;
    rdfs:label "Pulsar parámetros +" ;
    ns1:textoExtracto "Poner nombre deseado  Pulsar parámetros +, vuelca parámetros de brochado al programa" .

