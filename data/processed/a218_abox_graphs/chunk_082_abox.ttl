@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionRecall a ns1:AccionProhibida ;
    rdfs:label "Recall"@es ;
    ns1:textoExtracto "se pulsa 'Recall'"@es .

ns1:ImagenCicloBrochado a ns1:Figura ;
    rdfs:label "imagen de ciclo de brochado"@es ;
    ns1:textoExtracto "automáticamente lleva a la imagen de ciclo de brochado"@es .

ns1:InstruccionParametros a ns1:Parametro ;
    rdfs:label "instrucción donde están almacenados los parámetros"@es ;
    ns1:textoExtracto "en la primera instrucción donde están almacenados los parámetros"@es .

ns1:InterfazCicloBrochado a ns1:InterfazUsuario ;
    rdfs:label "pantalla de ciclo de brochado"@es ;
    ns1:textoExtracto "Carga los parámetros y automáticamente lleva a la imagen de ciclo de brochado"@es .

ns1:InterfazListaProgramas a ns1:InterfazUsuario ;
    rdfs:label "lista de programas"@es ;
    ns1:textoExtracto "Estando en la lista de programas (Pulsando Edit)"@es .

ns1:ProgramaBrochado a ns1:Manual ;
    rdfs:label "programa"@es ;
    ns1:textoExtracto "se pincha en el programa deseado"@es .

