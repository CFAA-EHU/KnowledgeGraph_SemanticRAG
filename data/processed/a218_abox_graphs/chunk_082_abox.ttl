@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InstruccionParametrosCicloBrochado
    a ex:Parametro ;
    rdfs:label "Primera instrucción con parámetros almacenados"@es ;
    ex:textoExtracto "primera instrucción donde están almacenados los parámetros"@es ;
    ex:monitoreaParametro ex:ParametrosCicloBrochado .

ex:ParametrosCicloBrochado
    a ex:Parametro ;
    rdfs:label "Parámetros de ciclo de brochado"@es ;
    ex:textoExtracto "los parámetros [...] lleva a la imagen de ciclo de brochado"@es .

ex:FuncionRecall a ex:Tabla ;
     a ex:AccionProhibida ;  # Interpretación: "Recall" es una acción del sistema no ejecutable manualmente fuera de interfaz
    rdfs:label "Función Recall"@es ;
    ex:textoExtracto "se pulsa 'Recall'. Carga los parámetros"@es ;
    ex:controla ex:ParametrosCicloBrochado ;
    ex:habilitadoPor ex:InterfazListaProgramas .

ex:InterfazListaProgramas
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de lista de programas (modo Edit)"@es ;
    ex:textoExtracto "lista de programas (Pulsando Edit) se pincha en el programa deseado"@es ;
    ex:ilustradoEn ex:PantallaCicloBrochado .

ex:PantallaCicloBrochado
    a ex:InterfazUsuario ;
    rdfs:label "Pantalla de ciclo de brochado"@es ;
    ex:textoExtracto "automáticamente lleva a la imagen de ciclo de brochado"@es .