@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CargarParametrosGuardadosEnElProgramaALaPantallaDeCicloDeBrochado_ad69ca6586 a ns1:TareaMantenimiento ;
    rdfs:label "Cargar parámetros guardados en el programa a la pantalla de ciclo de brochado" ;
    ns1:textoExtracto "Estando en la lista de programas (Pulsando Edit) se pincha en el programa deseado y después en la primera instrucción donde están almacenados los parámetros. A continuación, se pulsa 'Recall'. Carga los parámetros y auto..." .

