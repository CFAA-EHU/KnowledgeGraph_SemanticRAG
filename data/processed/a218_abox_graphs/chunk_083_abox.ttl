@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModificarParametrosDeBrochadoYSobrescribirlosAUnProgramaExistente_b6713169bb a ns1:TareaMantenimiento ;
    rdfs:label "Modificar parámetros de brochado y sobrescribirlos a un programa existente" ;
    ns1:requiereMantenimiento ns1:ModoOperacionCicloTrabajo ;
    ns1:textoExtracto "Pulsar softkey 'Ejecutar programa'  De este modo se vuelve a seleccionar el mismo programa pero con los parámetros actualizados." .

ns1:ProgramaExistente a ns1:Sistema ;
    rdfs:label "Programa existente" ;
    ns1:textoExtracto "De este modo se vuelve a seleccionar el mismo programa pero con los parámetros actualizados." .

ns1:ModoOperacionCicloTrabajo a ns1:ModoOperacion ;
    rdfs:label "Ciclo de trabajo" ;
    ns1:textoExtracto "¡ Tener en cuenta que para que surtan efecto los cambios si se tiene seleccionado el mismo ciclo de trabajo..." .

