@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PanelDesmontableLateral a ns1:Componente ;
    rdfs:label "Panel Desmontable Lateral" ;
    ns1:esComponenteDe ns1:MaquinaBrochadoraElectromecanicaExteriorA218 ;
    ns1:textoExtracto "dos paneles desmontables en cada lateral" .

ns1:PanelDesmontableTrasero a ns1:Componente ;
    rdfs:label "Panel Desmontable Trasero" ;
    ns1:esComponenteDe ns1:MaquinaBrochadoraElectromecanicaExteriorA218 ;
    ns1:textoExtracto "dos paneles desmontables en la parte trasera" .

ns1:PortonDobleCorrederoFrontal a ns1:Componente ;
    rdfs:label "Portón Doble Corredero Frontal" ;
    ns1:esComponenteDe ns1:MaquinaBrochadoraElectromecanicaExteriorA218 ;
    ns1:textoExtracto "un portón doble corredero en la parte frontal" .

ns1:PuertaCorrederaLateral a ns1:Componente ;
    rdfs:label "Puerta Corredera Lateral" ;
    ns1:esComponenteDe ns1:MaquinaBrochadoraElectromecanicaExteriorA218 ;
    ns1:textoExtracto "una puerta corredera en cada lateral" .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    rdfs:label "Maquina Brochadora Electromecanica Exterior A218" ;
    ns1:textoExtracto "La máquina dispone de las siguientes puertas y ventanas para acceder al interior: un portón doble corredero en la parte frontal, una puerta corredera en cada lateral, dos paneles desmontables en cada lateral, dos paneles..." .

