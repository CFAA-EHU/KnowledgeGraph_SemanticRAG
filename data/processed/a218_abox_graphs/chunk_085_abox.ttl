@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Maquina_Accesos
    a               ex:Maquina ;
    rdfs:label      "Máquina con puertas y ventanas de acceso"@es ;
    ex:textoExtracto "La máquina dispone de las siguientes puertas y ventanas para acceder al interior: un portón doble corredero en la parte frontal • una puerta corredera en cada lateral • dos paneles desmontables en cada lateral • dos paneles desmontables en la parte trasera"@es ;
    ex:tieneComponente
        ex:PortonFrontalCorredero ,
        ex:PuertaLateralCorredera_1 ,
        ex:PuertaLateralCorredera_2 ,
        ex:PanelLateralDesmontable_1 ,
        ex:PanelLateralDesmontable_2 ,
        ex:PanelLateralDesmontable_3 ,
        ex:PanelLateralDesmontable_4 ,
        ex:PanelTraseroDesmontable_1 ,
        ex:PanelTraseroDesmontable_2 .

ex:PortonFrontalCorredero
    a               ex:ComponenteMecanico ;
    rdfs:label      "Portón doble corredero frontal"@es ;
    ex:textoExtracto "un portón doble corredero en la parte frontal"@es .

ex:PuertaLateralCorredera_1
    a               ex:ComponenteMecanico ;
    rdfs:label      "Puerta corredera lateral (izquierda)"@es ;
    ex:textoExtracto "una puerta corredera en cada lateral"@es .

ex:PuertaLateralCorredera_2
    a               ex:ComponenteMecanico ;
    rdfs:label      "Puerta corredera lateral (derecha)"@es ;
    ex:textoExtracto "una puerta corredera en cada lateral"@es .

ex:PanelLateralDesmontable_1
    a               ex:ComponenteMecanico ;
    rdfs:label      "Panel desmontable lateral (izquierda, superior)"@es ;
    ex:textoExtracto "dos paneles desmontables en cada lateral"@es .

ex:PanelLateralDesmontable_2
    a               ex:ComponenteMecanico ;
    rdfs:label      "Panel desmontable lateral (izquierda, inferior)"@es ;
    ex:textoExtracto "dos paneles desmontables en cada lateral"@es .

ex:PanelLateralDesmontable_3
    a               ex:ComponenteMecanico ;
    rdfs:label      "Panel desmontable lateral (derecha, superior)"@es ;
    ex:textoExtracto "dos paneles desmontables en cada lateral"@es .

ex:PanelLateralDesmontable_4
    a               ex:ComponenteMecanico ;
    rdfs:label      "Panel desmontable lateral (derecha, inferior)"@es ;
    ex:textoExtracto "dos paneles desmontables en cada lateral"@es .

ex:PanelTraseroDesmontable_1
    a               ex:ComponenteMecanico ;
    rdfs:label      "Panel desmontable trasero (superior)"@es ;
    ex:textoExtracto "dos paneles desmontables en la parte trasera"@es .

ex:PanelTraseroDesmontable_2
    a               ex:ComponenteMecanico ;
    rdfs:label      "Panel desmontable trasero (inferior)"@es ;
    ex:textoExtracto "dos paneles desmontables en la parte trasera"@es .