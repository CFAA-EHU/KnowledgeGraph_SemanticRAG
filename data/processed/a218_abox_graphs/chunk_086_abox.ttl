@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BotonAperturaPuertas a ns1:InterfazUsuario ;
    rdfs:label "botón 'Apertura puertas'" ;
    ns1:textoExtracto "pulsar el botón 'Apertura puertas'" .

ns1:CarroPortaPieza a ns1:ComponenteMecanico ;
    rdfs:label "carro porta-pieza" ;
    ns1:textoExtracto "Ciclo de cambio de cremallera con carro porta-pieza en posición inferior" .

ns1:CicloCambioCremallera a ns1:TareaMantenimiento ;
    rdfs:label "Ciclo de cambio de cremallera" ;
    ns1:textoExtracto "Ciclo de cambio de cremallera con carro porta-pieza en posición inferior" .

ns1:DesbloqueoElectrico a ns1:Actuador ;
    rdfs:label "desbloqueo eléctrico" ;
    ns1:textoExtracto "disponen de un dispositivo de seguridad de bloqueo mecánico y desbloqueo eléctrico" .

ns1:DispositivoSeguridadBloqueoMecanico a ns1:ElementoSeguridad ;
    rdfs:label "dispositivo de seguridad de bloqueo mecánico" ;
    ns1:textoExtracto "disponen de un dispositivo de seguridad de bloqueo mecánico y desbloqueo eléctrico" .

ns1:ModoEmergencia a ns1:ModoOperacion ;
    rdfs:label "Máquina en emergencia" ;
    ns1:textoExtracto "Máquina en emergencia" .

ns1:ModoServicio a ns1:ModoOperacion ;
    rdfs:label "Máquina en servicio" ;
    ns1:textoExtracto "Máquina en servicio y pulsar el botón 'Apertura puertas'" .

ns1:ModoSetUp a ns1:ModoOperacion ;
    rdfs:label "Modo set-up" ;
    ns1:textoExtracto "Modo set-up y pulsar 'Apertura puertas'" .

ns1:PortonFrontal a ns1:ComponenteMecanico ;
    rdfs:label "Portón frontal" ;
    ns1:textoExtracto "Portón frontal y puertas correderas laterales: Son de apertura manual y disponen de un dispositivo de seguridad de bloqueo mecánico y desbloqueo eléctrico." .

ns1:PuertaCorrederaLateral a ns1:ComponenteMecanico ;
    rdfs:label "puertas correderas laterales" ;
    ns1:textoExtracto "Portón frontal y puertas correderas laterales: Son de apertura manual y disponen de un dispositivo de seguridad de bloqueo mecánico y desbloqueo eléctrico." .

ns1:Maquina a ns1:Maquina ;
    rdfs:label "Máquina" ;
    ns1:textoExtracto "Máquina en emergencia" .

