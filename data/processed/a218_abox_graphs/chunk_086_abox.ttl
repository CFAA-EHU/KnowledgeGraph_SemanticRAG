@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AperturaPuertasDuranteCambioDeCremallera a ns1:AccionProhibida ;
    rdfs:label "Apertura puertas durante cambio de cremallera" ;
    ns1:textoExtracto "Ciclo de cambio de cremallera con carro porta-pieza en posición inferior." .

ns1:AperturaPuertasEnEmergencia a ns1:AccionProhibida ;
    rdfs:label "Apertura puertas en emergencia" ;
    ns1:textoExtracto "Para su apertura se tiene que dar cualquiera de estas posibilidades: Máquina en emergencia" .

ns1:AperturaPuertasEnModoSetUp a ns1:AccionProhibida ;
    rdfs:label "Apertura puertas en modo set-up" ;
    ns1:textoExtracto "Modo set-up y pulsar 'Apertura puertas'" .

ns1:AperturaPuertasEnServicio a ns1:AccionProhibida ;
    rdfs:label "Apertura puertas en servicio" ;
    ns1:textoExtracto "Máquina en servicio y pulsar el botón 'Apertura puertas'" .

ns1:RealizarMovimientosConPuertasAbiertas a ns1:AccionProhibida ;
    rdfs:label "Realizar movimientos con puertas abiertas" ;
    ns1:textoExtracto "En modo set-up se pueden realizar movimientos con puertas abiertas a velocidad reducida." .

ns1:SistemaBloqueoMecanicoElectrico a ns1:Sistema ;
    rdfs:label "Sistema de bloqueo mecánico y desbloqueo eléctrico" ;
    ns1:textoExtracto "Son de apertura manual y disponen de un dispositivo de seguridad de bloqueo mecánico y desbloqueo eléctrico." .

