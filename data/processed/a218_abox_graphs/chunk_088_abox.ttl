@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_47a571b15c a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de emergencia" ;
    ns1:textoExtracto "Siempre atendiendo las indicaciones de la ventana de avisos: Con máquina en tensión, asegurarse de que ninguna emergencia esté pulsada." .

ns1:BotonPuestaEnServicio88 a ns1:ComponenteElectrico ;
    rdfs:label "Botón PUESTA SERVICIO" ;
    ns1:textoExtracto "Pulsar el botón 'PUESTA SERVICIO'." .

ns1:BotonReset88 a ns1:ComponenteElectrico ;
    rdfs:label "Botón RESET" ;
    ns1:textoExtracto "Pulsar botón 'RESET'." .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    rdfs:label "Brochadora en servicio" ;
    ns1:textoExtracto "Brochadora en servicio." .

