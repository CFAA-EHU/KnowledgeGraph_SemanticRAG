@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:VentanaAvisos_88
    a               ex:InterfazUsuario ;
    rdfs:label      "Ventana de avisos" ;
    ex:textoExtracto "Siempre atendiendo las indicaciones de la ventana de avisos"@es ;
    ex:ilustradoEn   ex:PuestaEnServicio_88 .

ex:PuestaEnServicio_88
    a               ex:ModoOperacion ;
    rdfs:label      "Puesta en servicio" ;
    ex:textoExtracto "Pulsar botón 'PUESTA SERVICIO'. Brochadora en servicio"@es ;
    ex:habilitadoPor ex:BotonReset_88 .

ex:BotonReset_88
    a               ex:ComponenteElectrico ;
    rdfs:label      "Botón RESET" ;
    ex:textoExtracto "Pulsar botón 'RESET'"@es .

ex:BotonPuestaServicio_88
    a               ex:ComponenteElectrico ;
    rdfs:label      "Botón PUESTA SERVICIO" ;
    ex:textoExtracto "Pulsar botón 'PUESTA SERVICIO'"@es ;
    ex:habilitadoPor ex:BotonReset_88 .

ex:Emergencia_88
    a               ex:ElementoSeguridad ;
    rdfs:label      "Emergencia" ;
    ex:textoExtracto "asegurarse de que ninguna emergencia esté pulsada"@es .