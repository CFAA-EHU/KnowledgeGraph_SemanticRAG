@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    rdfs:label "máquina" ;
    ns1:textoExtracto "Con máquina en servicio y presión general de aire OK." ;
    ns1:tieneComponente ns1:PuertasConEnclavamientoDeSeguridad .

ns1:ModoOperacionManual a ns1:ModoOperacion ;
    rdfs:label "modo manual" ;
    ns1:ejecuta ns1:CambioDeHerramienta_d248fee356 ;
    ns1:textoExtracto "Para seleccionar el modo de trabajo manual: Con máquina en servicio y presión general de aire OK." .

ns1:CambioDeHerramienta_d248fee356 a ns1:TareaMantenimiento ;
    rdfs:label "cambio de herramienta" ;
    ns1:textoExtracto "el cambio de herramienta" .

ns1:PuertasConEnclavamientoDeSeguridad a ns1:AvisoSeguridad ;
    rdfs:label "puertas con enclavamiento de seguridad" ;
    ns1:textoExtracto "puertas con enclavamiento de seguridad" .

