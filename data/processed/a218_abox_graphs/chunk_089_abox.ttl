@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EnclavamientoSeguridad89 a ns1:ElementoSeguridad ;
    ns1:textoExtracto "Puertas con enclavamiento de seguridad cerradas y bloqueadas" .

ns1:HerramientaCambio89 a ns1:Herramienta ;
    ns1:textoExtracto "cambio de herramienta" .

ns1:Maquina89 a ns1:Maquina ;
    ns1:textoExtracto "Con máquina en servicio y presión general de aire OK. Puertas con enclavamiento de seguridad cerradas y bloqueadas. A partir de este momento se pueden realizar todos los movimientos manuales de la máquina y el cambio de herramienta." .

ns1:ModoManual89 a ns1:ModoOperacion ;
    rdfs:label "modo manual" ;
    ns1:textoExtracto "Seleccionar el modo manual" .

