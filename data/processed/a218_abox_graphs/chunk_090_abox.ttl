@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoAutomatico
    a ex:ModoOperacion ;
    rdfs:label "Modo automático" ;
    ex:textoExtracto "Para seleccionar el modo de trabajo automático: Con máquina en servicio y presión general de aire OK. [...] A partir de este momento se pueden ejecutar los siguientes ciclos: Plana, anillo e inspección." ;
    ex:requiereMantenimiento ex:EnclavamientoPuertas ;
    ex:habilitadoPor ex:PresionGeneralAire .

ex:EnclavamientoPuertas
    a ex:ElementoSeguridad ;
    rdfs:label "Enclavamiento de seguridad de puertas" ;
    ex:textoExtracto "Puertas con enclavamiento de seguridad cerradas y bloqueadas." .

ex:PresionGeneralAire
    a ex:Parametro ;
    rdfs:label "Presión general de aire" ;
    ex:textoExtracto "presión general de aire OK" ;
    ex:valor "OK" .

ex:CicloInspeccion
    a ex:TareaMantenimiento ;
    rdfs:label "Ciclo inspección" ;
    ex:textoExtracto "1. Ciclo inspección: El carro sube a posición de inspección con el plato en 0º. [...] Este ciclo se utiliza con anillo, pudiendo seleccionar cada cuantas ranuras se desea ejecutar este ciclo." ;
    ex:ejecutadoPor ex:MaquinaBrochadora ;
    ex:tieneFrecuencia ex:FrecuenciaInspeccion .

ex:CicloPlana
    a ex:TareaMantenimiento ;
    rdfs:label "Ciclo plana" ;
    ex:textoExtracto "2. Ciclo plana: La pieza a brochar se coloca a 90º. Selección de desbaste (limitado la velocidad de brochado a 5000 mm/min) o acabado (limitado la velocidad de brochado a 5000 mm/min)." ;
    ex:ejecutadoPor ex:MaquinaBrochadora ;
    ex:tieneFrecuencia ex:FrecuenciaPlana .

ex:CicloAnilloDesbaste
    a ex:TareaMantenimiento ;
    rdfs:label "Ciclo anillo desbaste" ;
    ex:textoExtracto "3. Ciclo anillo desbaste: [...] Se cierran las puertas y dando 'Marcha ciclo' el carro sube hasta arriba a velocidad de brochado para que en el caso de que no estuviera bien posicionada la anilla la broche en 0º." ;
    ex:ejecutadoPor ex:MaquinaBrochadora ;
    ex:tieneFrecuencia ex:FrecuenciaAnilloDesbaste .

ex:CicloAnilloAcabado
    a ex:TareaMantenimiento ;
    rdfs:label "Ciclo anillo acabado" ;
    ex:textoExtracto "4. Ciclo anillo acabado: El ciclo inicia con el carro posicionándose en la cota de inspección con el plato girado en el primer diente." ;
    ex:ejecutadoPor ex:MaquinaBrochadora ;
    ex:tieneFrecuencia ex:FrecuenciaAnilloAcabado .

ex:MaquinaBrochadora
    a ex:Maquina ;
    rdfs:label "Máquina brochadora" ;
    ex:textoExtracto "Con máquina en servicio y presión general de aire OK." ;
    ex:tieneComponente ex:CarroBrochadora ;
    ex:tieneComponente ex:PlatoGiratorio ;
    ex:tieneComponente ex:PuertasSeguridad .

ex:CarroBrochadora
    a ex:ComponenteMecanico ;
    rdfs:label "Carro" ;
    ex:textoExtracto "El carro sube a posición de inspección con el plato en 0º. [...] La última posición es la de carro arriba (3150mm)." ;
    ex:monitoreaParametro ex:PosicionCarro .

ex:PosicionCarro
    a ex:Parametro ;
    rdfs:label "Posición del carro" ;
    ex:textoExtracto "La última posición es la de carro arriba (3150mm)." ;
    ex:valor "3150mm" .

ex:PlatoGiratorio
    a ex:ComponenteMecanico ;
    rdfs:label "Plato giratorio" ;
    ex:textoExtracto "El carro sube a posición de inspección con el plato en 0º. [...] con el plato girado en el primer diente." ;
    ex:monitoreaParametro ex:AnguloPlato .

ex:AnguloPlato
    a ex:Parametro ;
    rdfs:label "Ángulo del plato" ;
    ex:textoExtracto "plato en 0º. [...] plato girado en el primer diente." ;
    ex:valor "0°" .

ex:PuertasSeguridad
    a ex:ElementoSeguridad ;
    rdfs:label "Puertas de seguridad" ;
    ex:textoExtracto "Puertas con enclavamiento de seguridad cerradas y bloqueadas." .

ex:FrecuenciaInspeccion
    a ex:Frecuencia ;
    rdfs:label "Frecuencia de inspección" ;
    ex:textoExtracto "pudiendo seleccionar cada cuantas ranuras se desea ejecutar este ciclo." .

ex:FrecuenciaPlana
    a ex:Frecuencia ;
    rdfs:label "Frecuencia de ciclo plana" ;
    ex:textoExtracto "limitado la velocidad de brochado a 5000 mm/min" ;
    ex:valor "5000 mm/min" .

ex:FrecuenciaAnilloDesbaste
    a ex:Frecuencia ;
    rdfs:label "Frecuencia de ciclo anillo desbaste" ;
    ex:textoExtracto "velocidad de brochado para que en el caso de que no estuviera bien posicionada la anilla la broche en 0º." ;
    ex:valor "5000 mm/min" .

ex:FrecuenciaAnilloAcabado
    a ex:Frecuencia ;
    rdfs:label "Frecuencia de ciclo anillo acabado" ;
    ex:textoExtracto "velocidad de brochado" .