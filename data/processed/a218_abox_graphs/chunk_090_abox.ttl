@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CicloAnilloAcabado a ns1:AccionProhibida ;
    rdfs:label "Ciclo anillo acabado" ;
    ns1:textoExtracto "El ciclo inicia con el carro posicionándose en la cota de inspección con el plato girado en el primer diente." .

ns1:CicloAnilloDesbaste a ns1:AccionProhibida ;
    rdfs:label "Ciclo anillo desbaste" ;
    ns1:textoExtracto "El ciclo inicia aproximando el carro a la posición de verificación con el plato en 0º, hay un M0 donde se pueden abrir las puertas para verificar que el 0º de la anilla está correctamente posicionada." .

ns1:CicloInspeccion a ns1:AccionProhibida ;
    rdfs:label "Ciclo inspección" ;
    ns1:textoExtracto "El carro sube a posición de inspección con el plato en 0º. En esta posición se pueden abrir las puertas y mover el carro hasta la posición deseada para la primera foto." .

ns1:CicloPlana a ns1:AccionProhibida ;
    rdfs:label "Ciclo plana" ;
    ns1:textoExtracto "La pieza a brochar se coloca a 90º. Selección de desbaste (limitado la velocidad de brochado a 5000 mm/min) o acabado (limitado la velocidad de brochado a 5000 mm/min)." .

ns1:ModoOperacionAutomatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático" ;
    ns1:ejecutadoPor ns1:MaquinaBrochadoraElectromecanicaExteriorA218 ;
    ns1:textoExtracto "Para seleccionar el modo de trabajo automático: Con máquina en servicio y presión general de aire OK. Puertas con enclavamiento de seguridad cerradas y bloqueadas." .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    rdfs:label "Máquina" ;
    ns1:textoExtracto "Con máquina en servicio y presión general de aire OK. Puertas con enclavamiento de seguridad cerradas y bloqueadas." .

