@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:CicloAnilloAcabado_91 a ns1:TareaMantenimiento ;
    ns1:compuestoPor ns1:Carro_91,
        ns1:Plato_91 ;
    ns1:textoExtracto "Ciclo anillo acabado El ciclo inicia con el carro posicionándose en la cota de inspección con el plato girado en el primer diente."@es ;
    ns1:tieneComponente ns1:PuertaVerificacion_91 .

ns1:ModoAutomatico_91 a ns1:ModoOperacion ;
    ns1:textoExtracto "Siempre volviendo a 0º para la bajada del carro. Se podrá seleccionar si se desea con ciclo inspección o no. 4. Ciclo anillo acabado El ciclo inicia con el carro posicionándose en la cota de inspección con el plato girado en el primer diente."@es .

ns1:Carro_91 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "el carro posicionándose en la cota de inspección"@es .

ns1:Plato_91 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "el plato girado en el primer diente"@es .

ns1:PuertaVerificacion_91 a ns1:ElementoSeguridad ;
    ns1:textoExtracto "Se pueden abrir las puertas para verificar visualmente que el primer diente concuerda."@es .

