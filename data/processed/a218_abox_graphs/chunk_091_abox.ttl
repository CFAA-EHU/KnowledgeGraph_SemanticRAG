@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CicloAnilloAcabado a ns1:AccionProhibida ;
    rdfs:label "Ciclo anillo acabado" ;
    ns1:textoExtracto "El ciclo inicia con el carro posicionándose en la cota de inspección con el plato girado en el primer diente." .

ns1:CicloInspeccion a ns1:AccionProhibida ;
    rdfs:label "Ciclo inspección" ;
    ns1:textoExtracto "Se podrá seleccionar si se desea con ciclo inspección o no." .

ns1:CotaInspeccion a ns1:Parametro ;
    rdfs:label "cota de inspección" ;
    ns1:textoExtracto "El ciclo inicia con el carro posicionándose en la cota de inspección con el plato girado en el primer diente." .

ns1:ModoOperacionAutomatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático" ;
    ns1:textoExtracto "Siempre volviendo a 0º para la bajada del carro. Se podrá seleccionar si se desea con ciclo inspección o no." .

