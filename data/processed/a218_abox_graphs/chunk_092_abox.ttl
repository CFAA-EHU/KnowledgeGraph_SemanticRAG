@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CicloInspeccion a ns1:TareaMantenimiento ;
    rdfs:label "Ciclo de Inspección" ;
    ns1:textoExtracto "Se podrá seleccionar si se desea con ciclo inspección o no." .

ns1:VerificacionDeCicloInspeccion a ns1:AccionProhibida ;
    rdfs:label "Verificación de ciclo inspección" ;
    ns1:textoExtracto "Se pueden abrir las puertas para verificar visualmente que el primer diente concuerda." .

