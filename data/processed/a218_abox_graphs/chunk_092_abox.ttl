@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoOperacion_Automatico_6_4_3
    a ex:ModoOperacion ;
    rdfs:label "Modo automático (Sección 6.4.3)"@es ;
    ex:textoExtracto "en la cota de inspección con el plato girado en el primer diente... Ya hecha la verificación empieza a brochar desde el primer diente. Se podrá seleccionar si se desea con ciclo inspección o no."@es ;
    ex:tieneComponente ex:PlatoDentado_Inspeccion ;
    ex:tieneComponente ex:CicloInspeccion_Opcional ;
    ex:tieneComponente ex:CotaVerificacion_Plato .

ex:PlatoDentado_Inspeccion
    a ex:ComponenteMecanico ;
    rdfs:label "Plato dentado (verificación)"@es ;
    ex:textoExtracto "el plato girado en el primer diente... verificación visual de que el último diente concuerda"@es .

ex:CicloInspeccion_Opcional
    a ex:ModoOperacion ;
    rdfs:label "Ciclo de inspección (opcional)"@es ;
    ex:textoExtracto "Se podrá seleccionar si se desea con ciclo inspección o no."@es .

ex:CotaVerificacion_Plato
    a ex:Parametro ;
    rdfs:label "Cota de verificación del plato"@es ;
    ex:textoExtracto "en la cota de inspección... sube el carro a cota de verificación"@es ;
    ex:valor "cota de verificación"@es .