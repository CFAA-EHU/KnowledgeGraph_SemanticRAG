@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoSetUp_74
    a                     ex:ModoOperacion ;
    rdfs:label            "Modo Set-up"@es ;
    ex:textoExtracto       "Para seleccionar el modo set-up: [...] Este modo sirve para la apertura de puertas durante el ciclo de brochado sin tener que salir del ciclo automático, por ejemplo, para la verificación de la posición del carro respecto al primer diente."@es ;
    ex:habilitadoPor       ex:SelectorSetUp_74 .

ex:SelectorSetUp_74
    a                     ex:InterfazUsuario ;
    rdfs:label            "Selector de Set-up"@es ;
    ex:textoExtracto       "Habilitar el selector de Set-up en el panel operador."@es .

ex:BotonAperturaPuertas_74
    a                     ex:InterfazUsuario ;
    rdfs:label            "Botón Apertura puertas"@es ;
    ex:textoExtracto       "Para poder abrir las puertas, una vez habilitado el selector de Set-up, hay que pulsar el botón 'Apertura puertas'."@es .

ex:PuertasConEnclavamiento_74
    a                     ex:ElementoSeguridad ;
    rdfs:label            "Puertas con enclavamiento de seguridad"@es ;
    ex:textoExtracto       "Puertas con enclavamiento de seguridad cerradas y bloqueadas."@es .

ex:MaquinaBrochadora_74
    a                     ex:Maquina ;
    rdfs:label            "Máquina brochadora"@es ;
    ex:textoExtracto       "Con máquina en servicio y presión general de aire OK."@es ;
    ex:tieneComponente     ex:PuertasConEnclavamiento_74 ;
    ex:tieneComponente     ex:SelectorSetUp_74 ;
    ex:tieneComponente     ex:BotonAperturaPuertas_74 .