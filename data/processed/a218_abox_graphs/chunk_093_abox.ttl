@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    rdfs:label "máquina" ;
    ns1:textoExtracto "Con máquina en servicio y presión general de aire OK." ;
    ns1:tieneComponente ns1:BotonAperturaPuertas,
        ns1:SelectorSetUp .

ns1:ModoSetUp a ns1:ModoOperacion ;
    rdfs:label "modo set-up" ;
    ns1:ejecutadoPor ns1:PersonalOperador ;
    ns1:textoExtracto "Para seleccionar el modo set-up: Con máquina en servicio y presión general de aire OK. Puertas con enclavamiento de seguridad cerradas y bloqueadas." .

ns1:BotonAperturaPuertas a ns1:Componente ;
    rdfs:label "botón Apertura puertas" ;
    ns1:textoExtracto "Para poder abrir las puertas, una vez habilitado el selector de Set-up, hay que pulsar el botón 'Apertura puertas'." .

ns1:PersonalOperador a ns1:Personal ;
    rdfs:label "operador" ;
    ns1:textoExtracto "Este modo sirve para la apertura de puertas durante el ciclo de brochado sin tener que salir del ciclo automático, por ejemplo, para la verificación de la posición del carro respecto al primer diente." .

ns1:SelectorSetUp a ns1:Componente ;
    rdfs:label "selector de Set-up" ;
    ns1:textoExtracto "Habilitar el selector de Set-up en el panel operador." .

