@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ATENCIONPARAREALIZARTRABAJOSENALTURAESNECESARIOCOLOCARELMASTILANTICAIDAS a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de colocar mástil anticaídas" ;
    ns1:textoExtracto "¡ATENCIÓN! PARA REALIZAR TRABAJOS EN ALTURA ES NECESARIO COLOCAR EL MÁSTIL ANTICAÍDAS." .

ns1:AvisoSeguridad_a9feb1943c a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de parada correcta" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_60b4bdcf3d ;
    ns1:textoExtracto "LOS TRABAJOS DE MANTENIMIENTO Y DE LIMPIEZA SE DEBEN REALIZAR MIENTRAS LA MAQUINA SE HAYA PARADO CORRECTAMENTE Y SE HAYAN BLOQUEADO MEDIANTE MEDIDAS PERTINENTES AQUELLAS FUNCIONES QUE PUEDAN SUPONER UN PELIGRO" .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    rdfs:label "Máquina Brochadora Electromecánica Exterior A218" ;
    ns1:textoExtracto "LA MAQUINA SE HAYA PARADO CORRECTAMENTE Y SE HAYAN BLOQUEADO MEDIANTE MEDIDAS PERTINENTES AQUELLAS FUNCIONES QUE PUEDAN SUPONER UN PELIGRO" .

ns1:NOUTILIZARAIREAPRESIONPARATRABAJOSDELIMPIEZA a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de no utilizar aire a presión para limpieza" ;
    ns1:textoExtracto "¡NO UTILIZAR AIRE A PRESION PARA TRABAJOS DE LIMPIEZA!" .

ns1:SeccionadorGeneralDelArmarioElectrico a ns1:Componente ;
    rdfs:label "Seccionador General del Armario Eléctrico" ;
    ns1:textoExtracto "VALVULA MANUAL DE ENTRADA GENERAL DE AIRE Y EL SECCIONADOR GENERAL DEL ARMARIO ELECTRICO." .

ns1:ValvulaManualDeEntradaGeneralDeAire a ns1:Componente ;
    rdfs:label "Válvula manual de entrada general de aire" ;
    ns1:textoExtracto "VALVULA MANUAL DE ENTRADA GENERAL DE AIRE Y EL SECCIONADOR GENERAL DEL ARMARIO ELECTRICO." .

ns1:AccionProhibida_60b4bdcf3d a ns1:AccionProhibida ;
    rdfs:label "Acción prohibida de conservación de la máquina" ;
    ns1:textoExtracto "ANTES DE REALIZAR LABORES DE MANTENIMIENTO, ES NECESARIO CONSIGNAR LA MÁQUINA (VER APARTADO 2.2.4 INTERRUPTOR GENERAL DEL ARMARIO ELÉCTRICO)." .

