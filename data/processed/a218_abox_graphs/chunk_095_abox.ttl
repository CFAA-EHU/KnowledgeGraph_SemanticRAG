@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:PlanMantenimiento_76
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Plan de Mantenimiento (Pág. 76)"@es ;
    ex:textoExtracto      "PLAN DE MANTENIMIENTO [...] LOS TRABAJOS DE MANTENIMIENTO Y DE LIMPIEZA SE DEBEN REALIZAR MIENTRAS LA MÁQUINA SE HAYA PARADO CORRECTAMENTE Y SE HAYAN BLOQUEADO MEDIANTE MEDIDAS PERTINENTES AQUELLAS FUNCIONES QUE PUEDAN SUPONER UN PELIGRO, TALES COMO LA VÁLVULA MANUAL DE ENTRADA GENERAL DE AIRE Y EL SECCIONADOR GENERAL DEL ARMARIO ELÉCTRICO."@es ;
    ex:requiereMantenimiento ex:Maquina_General ;
    ex:requiereEPI         ex:MastilAnticaidas_76 .

ex:Maquina_General
    a                     ex:Maquina ;
    rdfs:label            "Máquina (general)"@es ;
    ex:textoExtracto      "LA MÁQUINA SE HAYA PARADO CORRECTAMENTE [...] CONSIGNAR LA MÁQUINA (VER APARTADO 2.2.4 INTERRUPTOR GENERAL DEL ARMARIO ELÉCTRICO)."@es ;
    ex:tieneComponente     ex:ValvulaEntradaAire_76, ex:SeccionadorGeneral_76 .

ex:ValvulaEntradaAire_76
    a                     ex:ComponenteHidraulico ;
    rdfs:label            "Válvula manual de entrada general de aire"@es ;
    ex:textoExtracto      "LA VÁLVULA MANUAL DE ENTRADA GENERAL DE AIRE"@es ;
    ex:identificador      "Entrada general de aire"@es .

ex:SeccionadorGeneral_76
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Seccionador general del armario eléctrico"@es ;
    ex:textoExtracto      "EL SECCIONADOR GENERAL DEL ARMARIO ELÉCTRICO [...] VER APARTADO 2.2.4 INTERRUPTOR GENERAL DEL ARMARIO ELÉCTRICO"@es ;
    ex:identificador      "Seccionador 2.2.4"@es .

ex:MastilAnticaidas_76
    a                     ex:EPI ;
    rdfs:label            "Mástil anticaídas"@es ;
    ex:textoExtracto      "¡ATENCIÓN! PARA REALIZAR TRABAJOS EN ALTURA ES NECESARIO COLOCAR EL MÁSTIL ANTICAÍDAS."@es .

ex:AvisoSeguridad_Limpieza_76
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Advertencia: No usar aire a presión para limpieza"@es ;
    ex:textoExtracto      "¡NO UTILIZAR AIRE A PRESION PARA TRABAJOS DE LIMPIEZA!"@es ;
    ex:mitigaRiesgo        ex:PlanMantenimiento_76 .

ex:AvisoSeguridad_Consignacion_76
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Advertencia: Consignar máquina antes de mantenimiento"@es ;
    ex:textoExtracto      "ANTES DE REALIZAR LABORES DE MANTENIMIENTO, ES NECESARIO CONSIGNAR LA MÁQUINA (VER APARTADO 2.2.4 INTERRUPTOR GENERAL DEL ARMARIO ELÉCTRICO)."@es ;
    ex:mitigaRiesgo        ex:PlanMantenimiento_76 .