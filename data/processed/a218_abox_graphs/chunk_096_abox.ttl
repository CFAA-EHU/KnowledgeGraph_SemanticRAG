@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:BrochadoraElectromecanicaExteriores a ns1:Maquina ;
    ns1:identificador "A218/ RASHEM 7x3000x500" ;
    ns1:textoExtracto "BROCHADORA ELECTROMECÁNICA DE EXTERIORES" .

ns1:Capitulo7MantenimientoInspeccion a ns1:Capitulo ;
    ns1:identificador "CAPÍTULO 7" ;
    ns1:textoExtracto "MANTENIMIENTO E INSPECCIÓN" .

ns1:TablaMantenimientoSemanal a ns1:Tabla ;
    ns1:compuestoPor ns1:AccionarBombeoEngraseManual,
        ns1:ComprobacionAprieteRacores,
        ns1:ComprobacionEstanqueidadTuberias,
        ns1:ComprobacionFugasAceiteManguerasEmpalmes,
        ns1:ComprobacionFugasAireSistemaNeumatico,
        ns1:ComprobacionNivelDepositoHidraulico,
        ns1:ComprobacionNivelDepositoRefrigeracion,
        ns1:ComprobacionNivelGrasaAceiteLubricacion,
        ns1:ComprobacionTemperaturaGrupoHidraulico,
        ns1:LimpiezaExteriorMaquina,
        ns1:PurgarRecipienteFiltroAire ;
    ns1:textoExtracto "Limpieza del exterior de la máquina | Cada 50 h | OPERARIO / MANTENIMIENTO Comprobar la estanqueidad de las tuberías | Cada 50 h | OPERARIO Comprobar el buen apriete de racores | Cada 50 h | OPERARIO Comprobar la temperatura de trabajo del grupo hidráulico (65ºC Max.) | Cada 50 h | OPERARIO Comprobar fugas de aceite en mangueras y empalmes | Cada 50 h | OPERARIO Comprobar nivel de grasa y aceite en los equipos de lubricación | Cada 50 h | OPERARIO Comprobar nivel del depósito hidráulico | Cada 50 h | OPERARIO Comprobar nivel del depósito de refrigeración | Cada 50 h | OPERARIO Comprobar fugas de aire en el sistema neumático | Cada 50 h | OPERARIO Purgar el recipiente del filtro de aire | Cada 50 h | OPERARIO / MANTENIMIENTO Accionar el bombeo de engrase manual | Cada 50 h | OPERARIO" .

ns1:AccionarBombeoEngraseManual a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Accionar el bombeo de engrase manual" ;
    ns1:tieneFrecuencia ns1:FrecuenciaCada50Horas .

ns1:ComprobacionAprieteRacores a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Comprobar el buen apriete de racores" ;
    ns1:tieneFrecuencia ns1:FrecuenciaCada50Horas .

ns1:ComprobacionEstanqueidadTuberias a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Comprobar la estanqueidad de las tuberías" ;
    ns1:tieneFrecuencia ns1:FrecuenciaCada50Horas .

ns1:ComprobacionFugasAceiteManguerasEmpalmes a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Comprobar fugas de aceite en mangueras y empalmes" ;
    ns1:tieneFrecuencia ns1:FrecuenciaCada50Horas .

ns1:ComprobacionFugasAireSistemaNeumatico a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Comprobar fugas de aire en el sistema neumático" ;
    ns1:tieneFrecuencia ns1:FrecuenciaCada50Horas .

ns1:ComprobacionNivelDepositoHidraulico a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Comprobar nivel del depósito hidráulico" ;
    ns1:tieneFrecuencia ns1:FrecuenciaCada50Horas .

ns1:ComprobacionNivelDepositoRefrigeracion a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Comprobar nivel del depósito de refrigeración" ;
    ns1:tieneFrecuencia ns1:FrecuenciaCada50Horas .

ns1:ComprobacionNivelGrasaAceiteLubricacion a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Comprobar nivel de grasa y aceite en los equipos de lubricación" ;
    ns1:tieneFrecuencia ns1:FrecuenciaCada50Horas .

ns1:ComprobacionTemperaturaGrupoHidraulico a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Comprobar la temperatura de trabajo del grupo hidráulico (65ºC Max.)" ;
    ns1:tieneFrecuencia ns1:FrecuenciaCada50Horas .

ns1:LimpiezaExteriorMaquina a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Limpieza del exterior de la máquina" ;
    ns1:tieneFrecuencia ns1:FrecuenciaCada50Horas .

ns1:PurgarRecipienteFiltroAire a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Purgar el recipiente del filtro de aire" ;
    ns1:tieneFrecuencia ns1:FrecuenciaCada50Horas .

ns1:FrecuenciaCada50Horas a ns1:Frecuencia ;
    ns1:textoExtracto "Cada 50 h" ;
    ns1:valor "Cada 50 h" .

