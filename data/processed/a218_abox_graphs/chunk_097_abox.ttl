@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobacionDeLaInstalacionDeRefrigerante a ns1:TareaMantenimiento ;
    rdfs:label "Comprobación de la instalación de refrigerante" ;
    ns1:textoExtracto "Comprobar la instalación de refrigerante" .

ns1:ComprobacionDeLasPresionesDeTrabajo a ns1:TareaMantenimiento ;
    rdfs:label "Comprobación de las presiones de trabajo" ;
    ns1:textoExtracto "Comprobar las presiones de trabajo" .

ns1:ComprobacionVisualDeLosCepillosDelSistemaDeLimpiezaBrocha a ns1:TareaMantenimiento ;
    rdfs:label "Comprobación visual de los cepillos del sistema de limpieza brocha" ;
    ns1:textoExtracto "Comprobar visualmente el estado de los cepillos del sistema de limpieza brocha" .

ns1:ComprobacionYCambioDeFiltroDelRefrigeradorDelArmario a ns1:TareaMantenimiento ;
    rdfs:label "Comprobación y cambio de filtro del refrigerador del armario" ;
    ns1:textoExtracto "Comprobar y, si procede, cambiar el filtro del refrigerador del armario" .

ns1:PersonalOperario a ns1:Personal ;
    rdfs:label "Operario" ;
    ns1:textoExtracto "OPERARIO" .

