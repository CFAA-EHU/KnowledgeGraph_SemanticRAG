@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Tareas de mantenimiento
ex:TareaMantenimiento_ComprobarCambiarJuntas
    a ex:TareaMantenimiento ;
    rdfs:label "Comprobar y, si procede, cambiar juntas en bombas, cilindros y válvulas" ;
    ex:textoExtracto "Comprobar y, si procede, cambiar juntas en bombas, cilindros y válvulas" ;
    ex:tieneFrecuencia ex:Frecuencia_1000h ;
    ex:ejecutadoPor ex:Personal_Mantenimiento .

ex:TareaMantenimiento_LimpiarFinalesCarrera
    a ex:TareaMantenimiento ;
    rdfs:label "Limpiar y comprobar el funcionamiento de los finales de carrera" ;
    ex:textoExtracto "Limpiar y comprobar el funcionamiento de los finales de carrera" ;
    ex:tieneFrecuencia ex:Frecuencia_1000h ;
    ex:ejecutadoPor ex:Personal_Mantenimiento .

ex:TareaMantenimiento_CambiarCartuchoFiltroAireEntrada
    a ex:TareaMantenimiento ;
    rdfs:label "Cambiar el cartucho del filtro de la entrada general de aire" ;
    ex:textoExtracto "Cambiar el cartucho del filtro de la entrada general de aire" ;
    ex:tieneFrecuencia ex:Frecuencia_1000h ;
    ex:ejecutadoPor ex:Personal_Mantenimiento .

ex:TareaMantenimiento_LimpiarDepositoRefrigerante
    a ex:TareaMantenimiento ;
    rdfs:label "Realizar limpieza del depósito de refrigerante" ;
    ex:textoExtracto "Realizar limpieza del depósito de refrigerante" ;
    ex:tieneFrecuencia ex:Frecuencia_1000h ;
    ex:ejecutadoPor ex:Personal_Mantenimiento .

ex:TareaMantenimiento_LimpiarDepositoHidraulico
    a ex:TareaMantenimiento ;
    rdfs:label "Realizar limpieza del depósito hidráulico" ;
    ex:textoExtracto "Realizar limpieza del depósito hidráulico" ;
    ex:tieneFrecuencia ex:Frecuencia_1000h ;
    ex:ejecutadoPor ex:Personal_Mantenimiento .

ex:TareaMantenimiento_LimpiarDepositoEngraseManual
    a ex:TareaMantenimiento ;
    rdfs:label "Realizar limpieza del depósito de engrase manual" ;
    ex:textoExtracto "Realizar limpieza del depósito de engrase manual" ;
    ex:tieneFrecuencia ex:Frecuencia_1000h ;
    ex:ejecutadoPor ex:Personal_Mantenimiento .

ex:TareaMantenimiento_CambiarCartuchosFiltrosAireGrupoHidraulico
    a ex:TareaMantenimiento ;
    rdfs:label "Cambio de los cartuchos de los filtros de aire del grupo hidráulico" ;
    ex:textoExtracto "Proceder al cambio de los cartuchos de los filtros de aire del grupo hidráulico" ;
    ex:tieneFrecuencia ex:Frecuencia_2000h ;
    ex:ejecutadoPor ex:Personal_Mantenimiento .

ex:TareaMantenimiento_EngrasarPatinesCarroPortaPiezas
    a ex:TareaMantenimiento ;
    rdfs:label "Engrasar los patines del carro porta-piezas y de los contrapesos" ;
    ex:textoExtracto "Engrasar los patines del carro porta-piezas y de los contrapesos" ;
    ex:tieneFrecuencia ex:Frecuencia_2000h ;
    ex:ejecutadoPor ex:Personal_Mantenimiento .

### Frecuencias
ex:Frecuencia_1000h
    a ex:Frecuencia ;
    rdfs:label "Cada 1000 horas" ;
    ex:textoExtracto "Cada 1000 h" ;
    ex:valor "1000" .

ex:Frecuencia_2000h
    a ex:Frecuencia ;
    rdfs:label "Cada 2000 horas" ;
    ex:textoExtracto "Cada 2000 h" ;
    ex:valor "2000" .

### Personal
ex:Personal_Mantenimiento
    a ex:Personal ;
    rdfs:label "Personal de mantenimiento" ;
    ex:textoExtracto "MANTENIMIENTO" .

### Componentes eléctricos (según texto)
ex:ComponenteElectrico_MicrosPuertas
    a ex:ComponenteElectrico ;
    rdfs:label "Micros de puertas" ;
    ex:textoExtracto "Los micros de puertas tienen que estar bloqueados, es decir, el selector de los micros - debe estar en la posición de bloqueo" .

ex:ComponenteElectrico_PilzEmergencia
    a ex:ComponenteElectrico ;
    rdfs:label "Pilz de emergencias" ;
    ex:textoExtracto "Pilz de emergencias, puertas, ventana/puerta de carga: Para que la máquina funcione correctamente tienen que estar los canales cerrados" .

ex:ComponenteElectrico_CanalesSeguridad
    a ex:ComponenteElectrico ;
    rdfs:label "Canales de seguridad (canal 1 y 2)" ;
    ex:textoExtracto "los leds de canal 1 y 2 estarán encendidos cuando todas las setas estén desenclavadas, las puertas cerradas" .

### Máquina (contexto)
ex:Maquina_Brochadora
    a ex:Maquina ;
    rdfs:label "Máquina brochadora" ;
    ex:textoExtracto "Para el correcto funcionamiento de la máquina" ;
    ex:tieneComponente ex:ComponenteElectrico_MicrosPuertas ;
    ex:tieneComponente ex:ComponenteElectrico_PilzEmergencia ;
    ex:tieneComponente ex:ComponenteElectrico_CanalesSeguridad .