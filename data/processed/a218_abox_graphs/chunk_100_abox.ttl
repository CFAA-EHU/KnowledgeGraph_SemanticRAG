@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ComprobacionFugas_7211
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Comprobación de fugas de fluidos"@es ;
    ex:textoExtracto       "Comprobar la existencia de fugas de fluidos por las tuberías. En caso de que se encontrase alguna, por favor apretar los racores."@es ;
    ex:requiereMantenimiento ex:SistemaHidraulico_7211 ;
    ex:requiereMantenimiento ex:Tuberias_7211 ;
    ex:requiereMantenimiento ex:Racores_7211 .

ex:ComprobacionNivelesFluidos_7211
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Comprobación de niveles de fluidos"@es ;
    ex:textoExtracto       "Comprobar niveles de fluidos en depósitos de engrase, hidráulico y refrigeración."@es ;
    ex:requiereMantenimiento ex:DepositoEngrase_7211 ;
    ex:requiereMantenimiento ex:DepositoHidraulico_7211 ;
    ex:requiereMantenimiento ex:DepositoRefrigeracion_7211 .

ex:SistemaHidraulico_7211
    a                     ex:Sistema ;
    rdfs:label            "Sistema hidráulico (tuberías y racores)"@es ;
    ex:textoExtracto       "fugas de fluidos por las tuberías [...] apretar los racores"@es ;
    ex:tieneComponente     ex:Tuberias_7211 ;
    ex:tieneComponente     ex:Racores_7211 .

ex:Tuberias_7211
    a                     ex:ComponenteHidraulico ;
    rdfs:label            "Tuberías del sistema hidráulico"@es ;
    ex:textoExtracto       "fugas de fluidos por las tuberías"@es .

ex:Racores_7211
    a                     ex:ComponenteHidraulico ;
    rdfs:label            "Racores del sistema hidráulico"@es ;
    ex:textoExtracto       "apretar los racores"@es .

ex:DepositoEngrase_7211
    a                     ex:ComponenteHidraulico ;
    rdfs:label            "Depósito de engrase"@es ;
    ex:textoExtracto       "depósitos de engrase"@es .

ex:DepositoHidraulico_7211
    a                     ex:ComponenteHidraulico ;
    rdfs:label            "Depósito hidráulico"@es ;
    ex:textoExtracto       "depósitos [...] hidráulico"@es .

ex:DepositoRefrigeracion_7211
    a                     ex:ComponenteHidraulico ;
    rdfs:label            "Depósito de refrigeración"@es ;
    ex:textoExtracto       "depósitos [...] refrigeración"@es .