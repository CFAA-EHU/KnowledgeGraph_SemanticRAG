@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TareaMantenimiento_100_78_1 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobación de fugas" ;
    ns1:requiereMantenimiento ns1:ComponenteHidraulico_100_78 ;
    ns1:textoExtracto "Comprobar la existencia de fugas de fluidos por las tuberías. En caso de que se encontrase alguna, por favor apretar los racores. Comprobar niveles de fluidos en depósitos de engrase, hidráulico y refrigeración." .

ns1:ComponenteHidraulico_100_78 a ns1:ComponenteHidraulico ;
    rdfs:label "tuberías y racores" ;
    ns1:textoExtracto "tuberías. En caso de que se encontrase alguna, por favor apretar los racores" .

