@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ApretarLosRacoresEnCasoDeFuga a ns1:AccionProhibida ;
    rdfs:label "Apretar los racores en caso de fuga" ;
    ns1:textoExtracto "En caso de que se encontrase alguna, por favor apretar los racores." .

ns1:ComprobarFugasDeFluidosPorLasTuberias a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar fugas de fluidos por las tuberías" ;
    ns1:textoExtracto "Comprobar la existencia de fugas de fluidos por las tuberías." .

ns1:ComprobarNivelesDeFluidosEnDepositos a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar niveles de fluidos en depósitos" ;
    ns1:textoExtracto "Comprobar niveles de fluidos en depósitos de engrase, hidráulico y refrigeración." .

