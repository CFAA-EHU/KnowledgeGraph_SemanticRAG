@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TareaMantenimiento_ComprobacionApriete_78
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Comprobación de apriete de tornillos y tuercas"@es ;
    ex:textoExtracto      "Comprobar si se han soltado los tornillos, tuercas, etc. En el caso de que así fuera, apretarlos."@es ;
    ex:requiereMantenimiento
            ex:ComponenteMecanico_TornillosTuercas_78 .

ex:ComponenteMecanico_TornillosTuercas_78
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Tornillos y tuercas"@es ;
    ex:textoExtracto      "tornillos, tuercas"@es .