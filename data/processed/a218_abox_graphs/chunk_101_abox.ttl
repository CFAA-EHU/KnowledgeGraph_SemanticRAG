@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ApretarTornillosYTuercas a ns1:TareaMantenimiento ;
    rdfs:label "Apretar tornillos y tuercas" ;
    ns1:solucionaFallo ns1:ComprobacionDeApriete_dd6aba8de2 ;
    ns1:textoExtracto "En el caso de que así fuera, apretarlos." .

ns1:ComprobacionDeApriete_dd6aba8de2 a ns1:AccionProhibida ;
    rdfs:label "Comprobación de apriete" ;
    ns1:textoExtracto "Comprobar si se han soltado los tornillos, tuercas, etc." .

