@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:ComprobacionPresiones_102 a ns1:TareaMantenimiento ;
    ns1:requiereMantenimiento ns1:Esquema_102 ;
    ns1:textoExtracto "Comprobar presiones y compararlas con las indicadas en los esquemas correspondientes mostrados en el Capítulo 10 - anexos." .

ns1:Esquema_102 a ns1:Esquema ;
    ns1:textoExtracto "esquemas correspondientes mostrados en el Capítulo 10 - anexos" .

