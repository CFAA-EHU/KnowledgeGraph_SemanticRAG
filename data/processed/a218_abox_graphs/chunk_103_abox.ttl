@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DetectoresDeProximidad a ns1:ComponenteElectrico ;
    rdfs:label "Detectores de proximidad" ;
    ns1:textoExtracto "Comprobar el funcionamiento correcto de los finales de carrera y de los detectores de proximidad." .

ns1:FinalesDeCarrera a ns1:ComponenteElectrico ;
    rdfs:label "Finales de carrera" ;
    ns1:textoExtracto "Comprobar el funcionamiento correcto de los finales de carrera y de los detectores de proximidad." .

