@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TareaMantenimiento_EngrasePatinesCarroPortaPiezas
    a ex:TareaMantenimiento ;
    rdfs:label "Engrase de patines del carro porta-piezas"@es ;
    ex:textoExtracto "Proceder a lubricar adecuadamente los patines del carro porta-piezas"@es ;
    ex:requiereConsumible ex:Consumible_Lubricante .

ex:TareaMantenimiento_EngrasePatinesContrapesos
    a ex:TareaMantenimiento ;
    rdfs:label "Engrase de patines de contrapesos"@es ;
    ex:textoExtracto "lubricar adecuadamente los patines [...] de los contrapesos"@es ;
    ex:requiereConsumible ex:Consumible_Lubricante .

ex:Consumible_Lubricante
    a ex:Consumible ;
    rdfs:label "Lubricante para patines"@es ;
    ex:textoExtracto "lubricar adecuadamente"@es .