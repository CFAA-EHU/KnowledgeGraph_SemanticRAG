@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceiteCorte_CUT_MAX_S_5029_1 a ns1:Consumible ;
    rdfs:label "Aceite de corte CUT-MAX S 5029-1" ;
    ns1:identificador "CUT-MAX S 5029-1" ;
    ns1:textoExtracto "Recomendamos utilizar el aceite de corte CUT-MAX S 5029-1, o en su defecto un aceite equivalente." .

ns1:DepartamentoHerramientas_EKIN a ns1:Personal ;
    rdfs:label "Departamento de Herramientas de EKIN" ;
    ns1:textoExtracto "ANTE CUALQUIER DUDA SOBRE EL TIPO DE REFRIGERANTE A UTILIZAR, PONERSE EN CONTACTO CON EL DEPARTAMENTO DE HERRAMIENTAS DE EKIN." .

ns1:DepositoRefrigeracion_119_86 a ns1:Componente ;
    rdfs:label "Depósito de refrigeración" ;
    ns1:textoExtracto "La capacidad del depósito es de 260 litros." ;
    ns1:valor "260 litros" .

