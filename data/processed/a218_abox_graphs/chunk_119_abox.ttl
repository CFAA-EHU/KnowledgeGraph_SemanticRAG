@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceiteDeCorteCUTMAXS50291 a ns1:Consumible ;
    rdfs:label "Aceite de corte CUT-MAX S 5029-1" ;
    ns1:identificador "CUT-MAX S 5029-1" ;
    ns1:requiereConsumible ns1:AceiteEquivalente ;
    ns1:textoExtracto "Recomendamos utilizar el aceite de corte CUT-MAX S 5029-1, o en su defecto un aceite equivalente." .

ns1:DepositoRefrigerante a ns1:Sistema ;
    rdfs:label "Sistema de Refrigeración" ;
    ns1:textoExtracto "La capacidad del depósito es de 260 litros. Recomendamos utilizar el aceite de corte CUT-MAX S 5029-1, o en su defecto un aceite equivalente." ;
    ns1:tieneComponente ns1:DepositoDeRefrigerante_54dfbdf1f2 .

ns1:AceiteEquivalente a ns1:Consumible ;
    rdfs:label "Aceite equivalente" ;
    ns1:textoExtracto "Recomendamos utilizar el aceite de corte CUT-MAX S 5029-1, o en su defecto un aceite equivalente." .

ns1:DepositoDeRefrigerante_54dfbdf1f2 a ns1:ComponenteElectrico ;
    rdfs:label "Depósito de refrigerante" ;
    ns1:textoExtracto "La capacidad del depósito es de 260 litros." .

