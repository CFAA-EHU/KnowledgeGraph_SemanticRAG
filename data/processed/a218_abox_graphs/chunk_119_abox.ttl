@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DepositoRefrigerante_86
    a               ex:ComponenteHidraulico ;
    rdfs:label      "Depósito de refrigerante" ;
    ex:textoExtracto "La capacidad del depósito es de 260 litros." ;
    ex:valor        "260 litros"^^xsd:string .

ex:AceiteCorte_CUT_MAX_S_5029_1
    a               ex:Consumible ;
    rdfs:label      "Aceite de corte CUT-MAX S 5029-1" ;
    ex:identificador "CUT-MAX S 5029-1" ;
    ex:textoExtracto "Recomendamos utilizar el aceite de corte CUT-MAX S 5029-1, o en su defecto un aceite equivalente." .

ex:DepartamentoHerramientas_EKIN
    a               ex:Empresa ;
    rdfs:label      "Departamento de Herramientas de EKIN" ;
    ex:textoExtracto "ANTE CUALQUIER DUDA SOBRE EL TIPO DE REFRIGERANTE A UTILIZAR, PONERSE EN CONTACTO CON EL DEPARTAMIENTO DE HERRAMIENTAS DE EKIN." .

ex:DepositoRefrigerante_86
    ex:requiereConsumible ex:AceiteCorte_CUT_MAX_S_5029_1 .