@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CaudalDeAireComprimido a ns1:Parametro ;
    rdfs:label "caudal de aire comprimido" ;
    ns1:identificador "CAUDAL225LPM" ;
    ns1:textoExtracto "A una presión de 6 bar, un caudal de 225 L/min filtrado y secado." ;
    ns1:valor "225 L/min" .

ns1:PresionDeAireComprimido a ns1:Parametro ;
    rdfs:label "presión de aire comprimido" ;
    ns1:identificador "PRES6BAR" ;
    ns1:textoExtracto "A una presión de 6 bar, un caudal de 225 L/min filtrado y secado." ;
    ns1:valor "6 bar" .

