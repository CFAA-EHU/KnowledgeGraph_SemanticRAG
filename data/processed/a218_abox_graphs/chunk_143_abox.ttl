    rdfs:label "Sistema de señalización del estado de la máquina (columna luminosa 40U1)"@es ;
    ex:identificador "40U1" ;
    ex:textoExtracto "SEÑALIZACION DEL ESTADO DE LA MAQUINA (COLUMNA LUMINOSA)"@es ;
