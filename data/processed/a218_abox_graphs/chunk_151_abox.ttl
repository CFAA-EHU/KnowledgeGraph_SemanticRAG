@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaComponentes a ns1:Esquema ;
    rdfs:label "Esquema de Componentes Eléctricos" ;
    ns1:ilustradoEn ns1:AcopladorPorReleMICROSERIES,
        ns1:CONTACTORAUX3NA1NCDC24V,
        ns1:CONTACTORINSTACON2CONTACTOSNA,
        ns1:ContactorAUX4NADC24V,
        ns1:INTERRUPTORSECCIONADORFUSIBLE3POLOS,
        ns1:InterruptorDeProteccionSeleccionable,
        ns1:InterruptorDeProteccionSeleccionableAutomaticoMagnetotermico,
        ns1:JuegoDeFusiblesSITOR100A,
        ns1:LIMITADORSOBRETENSIONVARISTORCONLED ;
    ns1:textoExtracto "Planos mecánicos y esquemas eléctricos del capítulo 10." .

ns1:AcopladorPorReleMICROSERIES a ns1:ComponenteElectrico ;
    rdfs:label "Acoplador por relé MICROSERIES" ;
    ns1:identificador "MRZ 24VDC 1CO" ;
    ns1:textoExtracto "Acoplador por relé MICROSERIES, Número de contactos: 1 Contacto" .

ns1:CONTACTORAUX3NA1NCDC24V a ns1:ComponenteElectrico ;
    rdfs:label "Contactor Aux., 3NA+1NC DC 24V" ;
    ns1:identificador "3RH2131-1BB40" ;
    ns1:textoExtracto "CONTACTOR AUX., 3NA+1NC DC 24V, TAMANO S00, BORNES DE TORNILLO" .

ns1:CONTACTORINSTACON2CONTACTOSNA a ns1:ComponenteElectrico ;
    rdfs:label "Contactor Insta con 2 contactos NA" ;
    ns1:identificador "5TT5800-0" ;
    ns1:textoExtracto "CONTACTOR INSTA CON 2 CONTACTOS NA, P. 230, 400 V AC" .

ns1:ContactorAUX4NADC24V a ns1:ComponenteElectrico ;
    rdfs:label "Contactor Aux., 4NA DC 24V" ;
    ns1:identificador "3RH2140-1BB40" ;
    ns1:textoExtracto "CONTACTOR AUX., 4NA DC 24V, TAMANO S00, BORNES DE TORNILLO" .

ns1:INTERRUPTORSECCIONADORFUSIBLE3POLOS a ns1:ComponenteElectrico ;
