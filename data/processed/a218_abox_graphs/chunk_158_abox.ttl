        ns1:PNOZmulti2InputModule24VDC,
        ns1:SeccionSoporteCP120L1000mm,
        ns1:TransformadorPrim400VAC,
        ns1:UnidadIluminadaConstante70mm,
        ns1:UnidadIluminadaRojo70mm,
        ns1:UnidadIluminadaVerde70mm .

