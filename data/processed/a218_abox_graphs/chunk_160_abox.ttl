        ex:CarcasaHDC_06B_SLU_2M20G_160_1,
        ex:CarcasaHDC_06B_TSLU_1M20G_160_1,
        ex:ConectorHDC_HE6_MP_160_1,
        ex:ConectorHDC_HE6_FP_160_1,
        ex:Enchufe_67901_160_1,
        ex:SocketMODLINK_4000_68000_160_1,
        ex:MarcoPupitre_4000_68112_160_1 .

