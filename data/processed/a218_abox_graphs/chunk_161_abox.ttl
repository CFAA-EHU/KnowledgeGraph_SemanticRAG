@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisosDeSeguridadGenerales a ns1:AvisoSeguridad ;
    rdfs:label "Avisos de seguridad generales" ;
    ns1:textoExtracto "Paneles infográficos con pictograma 'STOP' y avisos de seguridad (placas, enclavamientos, manipulación segura, uso de medios de elevación). Diseño en bloques rojos con texto blanco para resaltar severidad." .

ns1:AvisosDeSeguridadParaElUsoDeLaMaquina_dc18fdb95b a ns1:AvisoSeguridad ;
    rdfs:label "Avisos de seguridad para el uso de la máquina" ;
    ns1:textoExtracto "Conjunto de recuadros 'STOP' que enfatizan aplicación prevista, cumplimiento del manual, cierre de armarios eléctricos, no sobrepasar capacidad y verificación de interior; iconografía y color refuerzan las advertencias." .

ns1:Componente_9e31730b26 a ns1:Componente ;
    rdfs:label "Puertas" ;
    ns1:esComponenteDe ns1:EsquemaElementosSeguridadMaquina ;
    ns1:textoExtracto "marcadores y colores señalan la ubicación de puertas" .

ns1:InterruptorGeneral_6ac7354432 a ns1:Componente ;
    rdfs:label "Interruptor General" ;
    ns1:esComponenteDe ns1:EsquemaElementosSeguridadMaquina ;
    ns1:textoExtracto "marcadores y colores señalan la ubicación de interruptor general" .

ns1:PanelDesmontable a ns1:Componente ;
    rdfs:label "Paneles desmontables" ;
    ns1:esComponenteDe ns1:EsquemaElementosSeguridadMaquina ;
    ns1:textoExtracto "marcadores y colores señalan la ubicación de paneles fijos/desmontables" .

ns1:PanelFijo a ns1:Componente ;
    rdfs:label "Paneles fijos" ;
    ns1:esComponenteDe ns1:EsquemaElementosSeguridadMaquina ;
    ns1:textoExtracto "marcadores y colores señalan la ubicación de paneles fijos/desmontables" .

ns1:ParadasDeEmergencia a ns1:AvisoSeguridad ;
    rdfs:label "Paradas de emergencia" ;
    ns1:esComponenteDe ns1:EsquemaElementosSeguridadMaquina ;
    ns1:textoExtracto "marcadores y colores señalan la ubicación de paradas de emergencia" .

ns1:EsquemaElementosSeguridadMaquina a ns1:Esquema ;
    rdfs:label "Esquema de elementos de seguridad de la máquina" ;
    ns1:textoExtracto "Lámina con varias vistas de la máquina; marcadores y colores señalan la ubicación de interruptor general, paradas de emergencia, paneles fijos/desmontables y puertas, ofreciendo un mapa visual de zonas seguras." .

