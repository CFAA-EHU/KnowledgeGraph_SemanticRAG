ns1:AvisoSeguridad_554049bb9d a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de riesgo de apertura en servicio automático" ;
    ns1:textoExtracto "Ilustración explodida del carenado con flechas a paneles no controlados; recuadros indican su posición y el riesgo de apertura en servicio automático" .

ns1:EsquemaAlumbradoMaquina a ns1:Esquema ;
    rdfs:label "Esquema Alumbrado Máquina" ;
    ns1:textoExtracto "Figura 2-7. Esquema Alumbrado Máquina" .

ns1:InterruptorGeneralArmarioElectrico a ns1:ComponenteElectrico ;
    rdfs:label "Interruptor general del armario eléctrico" ;
    ns1:textoExtracto "Composición con primer plano del seccionador, luz de presencia de tensión y pictograma de máquina consignada; el encuadre y flechas muestran posiciones ON/OFF y uso de candado." .

ns1:MicroDeSeguridad25SQ1 a ns1:ComponenteElectrico ;
    rdfs:label "Micro de seguridad 25SQ1" ;
    ns1:textoExtracto "Corte isométrico del carro porta-piezas; se señalan plataforma, trampilla central y micro de seguridad 25SQ1" .

ns1:MicrointerruptorEUCHNER23SQ1 a ns1:ComponenteElectrico ;
    rdfs:label "Microinterruptor EUCHNER 23SQ1" ;
    ns1:textoExtracto "Vista frontal y laterales con microinterruptores EUCHNER etiquetados (23SQ1, 24SQ1, 24SQ2)" .

ns1:MicrointerruptorEUCHNER24SQ1 a ns1:ComponenteElectrico ;
    rdfs:label "Microinterruptor EUCHNER 24SQ1" ;
    ns1:textoExtracto "Vista frontal y laterales con microinterruptores EUCHNER etiquetados (23SQ1, 24SQ1, 24SQ2)" .

ns1:MicrointerruptorEUCHNER24SQ2 a ns1:ComponenteElectrico ;
    rdfs:label "Microinterruptor EUCHNER 24SQ2" ;
    ns1:textoExtracto "Vista frontal y laterales con microinterruptores EUCHNER etiquetados (23SQ1, 24SQ1, 24SQ2)" .

ns1:PulsadoresDeParadaDeEmergencia a ns1:Componente ;
    rdfs:label "Pulsadores de parada de emergencia" ;
    ns1:textoExtracto "Fotografías de detalle de los pulsadores en armario y botonera; rótulos indican su función y localización para detención inmediata." .

