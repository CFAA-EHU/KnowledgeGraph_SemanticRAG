@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Figura_2_7_AlumbradoInterior
    a               ex:Figura ;
    ex:identificador "Figura 2-7" ;
    rdfs:label      "Alumbrado interior de la máquina" ;
    ex:textoExtracto "Vista exterior con llamadas a tres recuadros de detalle: dos luminarias verticales enfocando al plato divisor y dos horizontales hacia la herramienta; menciona protección IP67 y función de visibilidad en zona de trabajo." ;
    ex:ilustradoEn   ex:Manual_Seccion_2.6_Alumbrado .

ex:LuminariaVertical_PlatoDivisor
    a               ex:ComponenteElectrico ;
    ex:textoExtracto "dos luminarias verticales enfocando al plato divisor" ;
    ex:ilustradoEn   ex:Figura_2_7_AlumbradoInterior .

ex:LuminariaHorizontal_Herramienta
    a               ex:ComponenteElectrico ;
    ex:textoExtracto "dos horizontales hacia la herramienta" ;
    ex:ilustradoEn   ex:Figura_2_7_AlumbradoInterior .

ex:Figura_4_1_Zocalo
    a               ex:Figura ;
    ex:identificador "Figura 4-1" ;
    rdfs:label      "Zócalo" ;
    ex:textoExtracto "Vista isométrica del zócalo con recuadros que señalan la cubeta superior y los apoyos antivibratorios. El tono gris del cuerpo y los resaltados en rojo ayudan a identificar la base estructural y su función como depósito/retorno del refrigerante y virutas." ;
    ex:ilustradoEn   ex:Manual_Seccion_4.2.1 .

ex:Zocalo_Maquina
    a               ex:ComponenteMecanico ;
    ex:textoExtracto "base estructural y su función como depósito/retorno del refrigerante y virutas" ;
    ex:ilustradoEn   ex:Figura_4_1_Zocalo ;
    ex:compuestoPor  ex:CubetaSuperior_Zocalo, ex:ApoyoAntivibratorio_Zocalo .

ex:CubetaSuperior_Zocalo
    a               ex:ComponenteMecanico ;
    ex:textoExtracto "cubeta superior" ;
    ex:ilustradoEn   ex:Figura_4_1_Zocalo .

ex:ApoyoAntivibratorio_Zocalo
    a               ex:ComponenteMecanico ;
    ex:textoExtracto "apoyos antivibratorios" ;
    ex:ilustradoEn   ex:Figura_4_1_Zocalo .

ex:Figura_4_2_ColumnaTraccion
    a               ex:Figura ;
    ex:identificador "Figura 4-2" ;
    rdfs:label      "Conjunto tracción" ;
    ex:textoExtracto "Corte 3D de la columna mostrando guías lineales, regla lineal, cremallera, piñón, servomotores y carro porta-piezas. Flechas y rótulos marcan la direccionalidad vertical del movimiento y la relación entre accionamientos y guiado." ;
    ex:ilustradoEn   ex:Manual_Seccion_4.2.2 .

ex:Columna_Maquina
    a               ex:ComponenteMecanico ;
    ex:textoExtracto "guías lineales, regla lineal, cremallera, piñón, servomotores" ;
    ex:ilustradoEn   ex:Figura_4_2_ColumnaTraccion ;
    ex:tieneComponente ex:GuiasLineales_Columna, ex:ReglaLineal_Columna, ex:Cremallera_Columna, ex:Pinon_Columna, ex:Servomotor_Columna .

ex:GuiasLineales_Columna
    a               ex:ComponenteMecanico ;
    ex:textoExtracto "guías lineales" ;
    ex:ilustradoEn   ex:Figura_4_2_ColumnaTraccion .

ex:ReglaLineal_Columna
    a               ex:ComponenteMecanico ;
    ex:textoExtracto "regla lineal" ;
    ex:ilustradoEn   ex:Figura_4_2_ColumnaTraccion .

ex:Cremallera_Columna
    a               ex:ComponenteMecanico ;
    ex:textoExtracto "cremallera" ;
    ex:ilustradoEn   ex:Figura_4_2_ColumnaTraccion .

ex:Pinon_Columna
    a               ex:ComponenteMecanico ;
    ex:textoExtracto "piñón" ;
    ex:ilustradoEn   ex:Figura_4_2_ColumnaTraccion .

ex:Servomotor_Columna
    a               ex:Actuador ;
    ex:textoExtracto "servomotores" ;
    ex:ilustradoEn   ex:Figura_4_2_ColumnaTraccion .

ex:Figura_4_3_CarroPortaPiezas
    a               ex:Figura ;
    ex:identificador "Figura 4-3" ;
    rdfs:label      "Carro porta-pieza y contrapesos" ;
    ex:textoExtracto "Explosivo funcional del carro y las guías traseras de contrapesos. Se destacan patines y bloqueos hidráulicos; etiquetas laterales listan frenos MAYR por posiciones izquierda/derecha." ;
    ex:ilustradoEn   ex:Manual_Seccion_4.2.3 .

ex:CarroPortaPiezas
    a               ex:ComponenteMecanico ;
    ex:textoExtracto "carro porta-piezas" ;
    ex:ilustradoEn   ex:Figura_4_3_CarroPortaPiezas ;
    ex:tieneComponente ex:Patines_Carro, ex:BloqueoHidraulico_Izquierdo, ex:BloqueoHidraulico_Derecho, ex:FrenoMAYR_Izquierdo, ex:FrenoMAYR_Derecho .

ex:Patines_Carro
    a               ex:ComponenteMecanico ;
    ex:textoExtracto "patines" ;
    ex:ilustradoEn   ex:Figura_4_3_CarroPortaPiezas .

ex:BloqueoHidraulico_Izquierdo
    a               ex:ComponenteHidraulico ;
    ex:textoExtracto "bloqueos hidráulicos" ;
    ex:ilustradoEn   ex:Figura_4_3_CarroPortaPiezas .

ex:BloqueoHidraulico_Derecho
    a               ex:ComponenteHidraulico ;
    ex:textoExtracto "bloqueos hidráulicos" ;
    ex:ilustradoEn   ex:Figura_4_3_CarroPortaPiezas .

ex:FrenoMAYR_Izquierdo
    a               ex:ComponenteMecanico ;
    ex:textoExtracto "frenos MAYR por posiciones izquierda" ;
    ex:ilustradoEn   ex:Figura_4_3_CarroPortaPiezas .

ex:FrenoMAYR_Derecho
    a               ex:ComponenteMecanico ;
    ex:textoExtracto "frenos MAYR por posiciones derecha" ;
    ex:ilustradoEn   ex:Figura_4_3_CarroPortaPiezas .

ex:Figura_4_4_PlatoDivisor
    a               ex:Figura ;
    ex:identificador "Figura 4-4" ;
    rdfs:label      "Plato divisor" ;
    ex:textoExtracto "Perspectiva del plato con dentado Hirth, servomotor y torreta de micros (SQ46/SQ47). Colores cálidos resaltan el anillo dentado; flechas sugieren el giro tras el desbloqueo hidráulico." ;
    ex:ilustradoEn   ex:Manual_Seccion_4.2.4 .

ex:PlatoDivisor
    a               ex:ComponenteMecanico ;
    ex:textoExtracto "dentado Hirth, servomotor y torreta de micros (SQ46/SQ47)" ;
    ex:ilustradoEn   ex:Figura_4_4_PlatoDivisor ;
    ex:tieneComponente ex:DentadoHirth_Plato, ex:Servomotor_Plato, ex:TorretaMicros_SQ46_SQ47 .

ex:DentadoHirth_Plato
    a               ex:ComponenteMecanico ;
    ex:textoExtracto "anillo dentado Hirth" ;
    ex:ilustradoEn   ex:Figura_4_4_PlatoDivisor .

ex:Servomotor_Plato
    a               ex:Actuador ;
    ex:textoExtracto "servomotor" ;
    ex:ilustradoEn   ex:Figura_4_4_PlatoDivisor .

ex:TorretaMicros_SQ46_SQ47
    a               ex:ComponenteMecanico ;
    ex:identificador "SQ46/SQ47" ;
    ex:textoExtracto "torreta de micros (SQ46/SQ47)" ;
    ex:ilustradoEn   ex:Figura_4_4_PlatoDivisor .