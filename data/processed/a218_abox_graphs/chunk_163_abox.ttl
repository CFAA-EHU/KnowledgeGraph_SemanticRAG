@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlumbradoInteriorMaquina a ns1:ElementoSeguridad ;
    rdfs:label "Alumbrado interior de la máquina" ;
    ns1:textoExtracto "Vista exterior con llamadas a tres recuadros de detalle: dos luminarias verticales enfocando al plato divisor y dos horizontales hacia la herramienta; menciona protección IP67 y función de visibilidad en zona de trabajo." ;
    ns1:tieneComponente ns1:LuminariaHorizontal1,
        ns1:LuminariaHorizontal2,
        ns1:LuminariaVertical1,
        ns1:LuminariaVertical2 .

ns1:CarroPortapiezasConjunto a ns1:ComponenteMecanico ;
    rdfs:label "Carro porta-pieza y contrapesos" ;
    ns1:textoExtracto "Explosivo funcional del carro y las guías traseras de contrapesos. Se destacan patines y bloqueos hidráulicos; etiquetas laterales listan frenos MAYR por posiciones izquierda/derecha." ;
    ns1:tieneComponente ns1:BloqueoHidraulico,
        ns1:FrenoMayrDerecha,
        ns1:FrenoMayrIzquierda,
        ns1:Patin .

ns1:Columna a ns1:ComponenteMecanico ;
    rdfs:label "Columna" ;
    ns1:textoExtracto "Corte 3D de la columna mostrando guías lineales, regla lineal, cremallera, piñón, servomotores y carro porta-piezas. Flechas y rótulos marcan la direccionalidad vertical del movimiento y la relación entre accionamientos y guiado." ;
    ns1:tieneComponente ns1:CarroPortapiezas,
        ns1:Cremallera,
        ns1:GuiaLineal,
        ns1:Pinon,
        ns1:ReglaLineal,
        ns1:ServomotorColumna .

ns1:PlatoDivisor a ns1:ComponenteMecanico ;
    rdfs:label "Plato divisor" ;
    ns1:textoExtracto "Perspectiva del plato con dentado Hirth, servomotor y torreta de micros (SQ46/SQ47). Colores cálidos resaltan el anillo dentado; flechas sugieren el giro tras el desbloqueo hidráulico." ;
    ns1:tieneComponente ns1:DentadoHirth,
        ns1:ServomotorPlato,
        ns1:TorretaMicros .

ns1:Zocalo a ns1:ComponenteMecanico ;
    rdfs:label "Zócalo" ;
    ns1:textoExtracto "Vista isométrica del zócalo con recuadros que señalan la cubeta superior y los apoyos antivibratorios. El tono gris del cuerpo y los resaltados en rojo ayudan a identificar la base estructural y su función como depósito/retorno del refrigerante y virutas." ;
    ns1:tieneComponente ns1:ApoyoAntivibratorio,
        ns1:CubetaSuperior .

ns1:ApoyoAntivibratorio a ns1:ComponenteMecanico ;
    rdfs:label "Apoyo antivibratorio" ;
    ns1:textoExtracto "apoyos antivibratorios" .

ns1:BloqueoHidraulico a ns1:ComponenteHidraulico ;
    rdfs:label "Bloqueo hidráulico" ;
    ns1:textoExtracto "bloqueos hidráulicos" .

ns1:CarroPortapiezas a ns1:ComponenteMecanico ;
    rdfs:label "Carro porta-piezas" ;
    ns1:textoExtracto "carro porta-piezas" .

ns1:Cremallera a ns1:ComponenteMecanico ;
    rdfs:label "Cremallera" ;
    ns1:textoExtracto "cremallera" .

ns1:CubetaSuperior a ns1:ComponenteMecanico ;
    rdfs:label "Cubeta superior" ;
    ns1:textoExtracto "cubeta superior" .

ns1:DentadoHirth a ns1:ComponenteMecanico ;
    rdfs:label "Dentado Hirth" ;
    ns1:textoExtracto "dentado Hirth" .

ns1:FrenoMayrDerecha a ns1:ComponenteMecanico ;
    rdfs:label "Freno MAYR derecha" ;
    ns1:textoExtracto "frenos MAYR por posiciones izquierda/derecha" .

ns1:FrenoMayrIzquierda a ns1:ComponenteMecanico ;
    rdfs:label "Freno MAYR izquierda" ;
    ns1:textoExtracto "frenos MAYR por posiciones izquierda/derecha" .

ns1:GuiaLineal a ns1:ComponenteMecanico ;
    rdfs:label "Guía lineal" ;
    ns1:textoExtracto "guías lineales" .

ns1:LuminariaHorizontal1 a ns1:ComponenteElectrico ;
    rdfs:label "Luminaria horizontal 1" ;
    ns1:textoExtracto "dos horizontales hacia la herramienta" .

ns1:LuminariaHorizontal2 a ns1:ComponenteElectrico ;
    rdfs:label "Luminaria horizontal 2" ;
    ns1:textoExtracto "dos horizontales hacia la herramienta" .

ns1:LuminariaVertical1 a ns1:ComponenteElectrico ;
    rdfs:label "Luminaria vertical 1" ;
    ns1:textoExtracto "dos luminarias verticales enfocando al plato divisor" .

ns1:LuminariaVertical2 a ns1:ComponenteElectrico ;
    rdfs:label "Luminaria vertical 2" ;
    ns1:textoExtracto "dos luminarias verticales enfocando al plato divisor" .

ns1:Patin a ns1:ComponenteMecanico ;
    rdfs:label "Patín" ;
    ns1:textoExtracto "patines" .

ns1:Pinon a ns1:ComponenteMecanico ;
    rdfs:label "Piñón" ;
    ns1:textoExtracto "piñón" .

ns1:ReglaLineal a ns1:ComponenteMecanico ;
    rdfs:label "Regla lineal" ;
    ns1:textoExtracto "regla lineal" .

ns1:ServomotorColumna a ns1:ComponenteElectrico ;
    rdfs:label "Servomotor de columna" ;
    ns1:textoExtracto "servomotores" .

ns1:ServomotorPlato a ns1:ComponenteElectrico ;
    rdfs:label "Servomotor de plato" ;
    ns1:textoExtracto "servomotor" .

ns1:TorretaMicros a ns1:ComponenteMecanico ;
    rdfs:label "Torreta de micros" ;
    ns1:textoExtracto "torreta de micros (SQ46/SQ47)" .

