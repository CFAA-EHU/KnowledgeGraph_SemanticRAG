@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PlatoDivisor_e9e9d63098 a ns1:ComponenteMecanico ;
    rdfs:label "Plato Divisor" ;
    ns1:textoExtracto "Perspectiva del plato con dentado Hirth, servomotor y torreta de micros (SQ46/SQ47)." .

ns1:SistemaHidraulicoAlumbrado a ns1:Sistema ;
    rdfs:label "Sistema Alumbrado" ;
    ns1:textoExtracto "Vista exterior con llamadas a tres recuadros de detalle: dos luminarias verticales enfocando al plato divisor y dos horizontales hacia la herramienta; menciona protección IP67 y función de visibilidad en zona de trabajo." .

ns1:SistemaHidraulicoBloqueos a ns1:Sistema ;
    rdfs:label "Sistema Hidráulico Bloqueos" ;
    ns1:textoExtracto "Se destacan patines y bloqueos hidráulicos; etiquetas laterales listan frenos MAYR por posiciones izquierda/derecha." .

ns1:SistemaHidraulicoContrapesos a ns1:Sistema ;
    rdfs:label "Sistema Hidraulico Contrapesos" ;
    ns1:textoExtracto "Se destacan patines y bloqueos hidráulicos; etiquetas laterales listan frenos MAYR por posiciones izquierda/derecha." ;
    ns1:tieneComponente ns1:CarroPortaPiezas_249e6308bb .

ns1:SistemaHidraulicoRefrigeracion a ns1:Sistema ;
    rdfs:label "Sistema Hidraulico Refrigerante" ;
    ns1:textoExtracto "El tono gris del cuerpo y los resaltados en rojo ayudan a identificar la base estructural y su función como depósito/retorno del refrigerante y virutas." ;
    ns1:tieneComponente ns1:ComponenteMecanico_4c7037b26b .

ns1:CarroPortaPiezas_249e6308bb a ns1:ComponenteMecanico ;
    rdfs:label "Carro Porta-Piezas" ;
    ns1:textoExtracto "Explosivo funcional del carro y las guías traseras de contrapesos." .

ns1:ComponenteMecanico_4c7037b26b a ns1:ComponenteMecanico ;
    rdfs:label "Columna" ;
    ns1:textoExtracto "Corte 3D de la columna mostrando guías lineales, regla lineal, cremallera, piñón, servomotores y carro porta-piezas." .

