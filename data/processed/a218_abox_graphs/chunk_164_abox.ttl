@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaCambioBase a ns1:Esquema ;
    rdfs:label "Esquema Cambio Base" ;
    ns1:textoExtracto "Dos vistas comparativas con rótulos Base 0º y Base 15º. La codificación cromática diferencia ambas configuraciones, evidenciando el ajuste angular disponible para el brochado." .

ns1:EsquemaPlatoDivisor a ns1:Esquema ;
    rdfs:label "Esquema Plato Divisor" ;
    ns1:ilustra ns1:SistemaHidraulicoPlatoDivisor ;
    ns1:textoExtracto "Perspectiva del plato con dentado Hirth, servomotor y torreta de micros (SQ46/SQ47). Colores cálidos resaltan el anillo dentado; flechas sugieren el giro tras el desbloqueo hidráulico." .

ns1:TareaMantenimiento_56edd21e49 a ns1:TareaMantenimiento ;
    rdfs:label "Tarea de Cambio de Base" ;
    ns1:textoExtracto "Fotografías de detalle con recuadros y flechas hacia cables del motor, cable torreta de micros, tubos hidráulicos y tubo neumático a desconectar. Enfatiza los puntos de intervención iniciales." .

ns1:ComponenteElectrico_cf8e5331d1 a ns1:ComponenteElectrico ;
    rdfs:label "Servomotor" ;
    ns1:textoExtracto "Perspectiva del plato con dentado Hirth, servomotor y torreta de micros (SQ46/SQ47)." .

ns1:SistemaHidraulicoPlatoDivisor a ns1:Sistema ;
    rdfs:label "Sistema Hidráulico Plato Divisor" ;
    ns1:textoExtracto "Perspectiva del plato con dentado Hirth, servomotor y torreta de micros (SQ46/SQ47). Colores cálidos resaltan el anillo dentado; flechas sugieren el giro tras el desbloqueo hidráulico." ;
    ns1:tieneComponente ns1:ComponenteElectrico_cf8e5331d1 .

