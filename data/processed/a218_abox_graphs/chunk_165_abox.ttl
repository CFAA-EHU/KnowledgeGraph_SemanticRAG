@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioBase a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de base" ;
    ns1:textoExtracto "Cambio de base (3) --- Perspectiva del plato fuera de máquina; rótulos repetidos a tornillos del plato refuerzan la extracción de la base. La repetición visual ayuda a ver la simetría del amarre." .

ns1:Columna a ns1:ComponenteMecanico ;
    rdfs:label "columna" ;
    ns1:textoExtracto "Elevación 3D de la columna con el porta-brochas resaltado" .

ns1:Figura4_10 a ns1:Figura ;
    rdfs:label "Figura 4-10. Cambio de base" ;
    ns1:textoExtracto "Inserción del conjunto con grúa a través de la plataforma; círculos marcan los siete tornillos del plato y tres de ajuste a reapretar. Flechas orientan la secuencia final." .

ns1:Figura4_11 a ns1:Figura ;
    rdfs:label "Figura 4-11. Porta-brochas" ;
    ns1:textoExtracto "Elevación 3D de la columna con el porta-brochas resaltado. Se muestra fijo, alineado con el eje vertical, frente al movimiento del carro porta-piezas." .

ns1:Figura4_12 a ns1:Figura ;
    rdfs:label "Figura 4-12. Plataformas laterales" ;
    ns1:textoExtracto "Vista frontal del equipo con dos plataformas (marcas 1 y 2) a distinta altura. Líneas horizontales rojas indican posiciones de trabajo y puerta de acceso a interior." .

ns1:Figura4_13 a ns1:Figura ;
    rdfs:label "Figura 4-13. Plataformas laterales" ;
    ns1:textoExtracto "Sección frontal con codificación ROJO (tornillería superior a retirar) y AZUL (resto de tornillería)." .

ns1:Figura4_9 a ns1:Figura ;
    rdfs:label "Figura 4-9. Cambio de base" ;
    ns1:textoExtracto "Colocación del plato en base plana. Recuadros señalan los tornillos de amarre en ambos laterales; vista limpia para verificar apoyos." .

ns1:Plataforma a ns1:ComponenteMecanico ;
    rdfs:label "plataforma" ;
    ns1:textoExtracto "Vista frontal del equipo con dos plataformas (marcas 1 y 2) a distinta altura" .

ns1:Plato a ns1:ComponenteMecanico ;
    rdfs:label "plato" ;
    ns1:textoExtracto "Inserción del conjunto con grúa a través de la plataforma; círculos marcan los siete tornillos del plato" .

ns1:PortaBrochas a ns1:ComponenteMecanico ;
    rdfs:label "porta-brochas" ;
    ns1:textoExtracto "Elevación 3D de la columna con el porta-brochas resaltado" .

ns1:TornilloAmarre a ns1:ComponenteMecanico ;
    rdfs:label "tornillos de amarre" ;
    ns1:textoExtracto "Recuadros señalan los tornillos de amarre en ambos laterales" .

