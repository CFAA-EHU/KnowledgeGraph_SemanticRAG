@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioDeBase_0235fe500b a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de base",
        "Personal Técnico" ;
    ns1:ejecutadoPor ns1:PersonalTecnico ;
    ns1:textoExtracto "Procedimiento cambio de base (0º–15º / 15º–0º)" .

ns1:PlatoBase a ns1:ComponenteMecanico ;
    rdfs:label "Plato Base" ;
    ns1:textoExtracto "Colocación del plato en base plana. Recuadros señalan los tornillos de amarre en ambos laterales; vista limpia para verificar apoyos." .

ns1:SistemaCarroPortaBrochas a ns1:Sistema ;
    rdfs:label "Sistema Carro Porta-Brochas" ;
    ns1:textoExtracto "Elevación 3D de la columna con el porta-brochas resaltado. Se muestra fijo, alineado con el eje vertical, frente al movimiento del carro porta-piezas." ;
    ns1:tieneComponente ns1:PortaBrochas .

ns1:PortaBrochas a ns1:ComponenteMecanico ;
    rdfs:label "Porta-Brochas" ;
    ns1:textoExtracto "Elevación 3D de la columna con el porta-brochas resaltado. Se muestra fijo, alineado con el eje vertical, frente al movimiento del carro porta-piezas." .

