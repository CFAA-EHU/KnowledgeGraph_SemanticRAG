@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Figura 4-13 (Porta-cremalleras)
ex:Figura4_13
    a ex:Figura ;
    rdfs:label "Figura 4-13. Plataformas laterales" ;
    ex:textoExtracto "Sección frontal con codificación ROJO (tornillería superior a retirar) y AZUL (resto de tornillería). Flechas verticales y textos laterales describen la extracción del porta-cremalleras con cáncamos y grúa." ;
    ex:ilustradoEn ex:Pagina_44 .

ex:PortaCremalleras
    a ex:ComponenteMecanico ;
    rdfs:label "Porta-cremalleras" ;
    ex:textoExtracto "extracción del porta-cremalleras con cáncamos y grúa" ;
    ex:detalladoEnEsquema ex:Figura4_13 .

### Figura 4-14 (Sistema de limpieza de brochas)
ex:Figura4_14
    a ex:Figura ;
    rdfs:label "Figura 4-14. Sistema de limpieza" ;
    ex:textoExtracto "Dos vistas: a la izquierda, el conjunto sobre el carro; a la derecha, módulo con cilindro y cepillos. Rótulos BQ740/BQ741 reflejan estados Avanzado/Retrocedido." ;
    ex:ilustradoEn ex:Pagina_45 .

ex:SistemaLimpiezaBrochas
    a ex:Sistema ;
    rdfs:label "Sistema de limpieza de brochas" ;
    ex:textoExtracto "conjunto sobre el carro; módulo con cilindro y cepillos" ;
    ex:detalladoEnEsquema ex:Figura4_14 ;
    ex:compuestoPor ex:CilindroLimpiezaBrochas, ex:CepillosLimpieza .

ex:CilindroLimpiezaBrochas
    a ex:ComponenteHidraulico ;
    rdfs:label "Cilindro de limpieza de brochas" ;
    ex:identificador "BQ740/BQ741" ;
    ex:textoExtracto "Rótulos BQ740/BQ741 reflejan estados Avanzado/Retrocedido" ;
    ex:detalladoEnEsquema ex:Figura4_14 .

ex:CepillosLimpieza
    a ex:ComponenteMecanico ;
    rdfs:label "Cepillos de limpieza" ;
    ex:textoExtracto "módulo con cilindro y cepillos" ;
    ex:detalladoEnEsquema ex:Figura4_14 .

### Figura 4-15 (Sistema neumático)
ex:Figura4_15
    a ex:Figura ;
    rdfs:label "Figura 4-15. Sistema neumático" ;
    ex:textoExtracto "Fotografía del armario neumático con etiquetas a YP801 (entrada), YP901/YP902 (avance/retroceso cepillo), YP903 (refrigerante), BP710/BP711 (presiones)." ;
    ex:ilustradoEn ex:Pagina_46 .

ex:SistemaNeumatico
    a ex:Sistema ;
    rdfs:label "Sistema neumático" ;
    ex:textoExtracto "armario neumático con etiquetas a YP801, YP901/YP902, YP903, BP710/BP711" ;
    ex:detalladoEnEsquema ex:Figura4_15 ;
    ex:compuestoPor ex:ValvulaEntradaYP801, ex:ActuadorAvanceCepilloYP901, ex:ActuadorRetrocesoCepilloYP902, ex:ValvulaRefrigeranteYP903, ex:ManometroBP710, ex:ManometroBP711 .

ex:ValvulaEntradaYP801
