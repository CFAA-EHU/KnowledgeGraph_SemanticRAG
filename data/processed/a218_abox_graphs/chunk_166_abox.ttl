    ex:textoExtracto "YP901 (avance cepillo)" ;
    ex:detalladoEnEsquema ex:Figura4_15 .

ex:ActuadorRetrocesoCepilloYP902
    a ex:Actuador ;
    rdfs:label "Actuador de retroceso de cepillo" ;
    ex:identificador "YP902" ;
    ex:textoExtracto "YP902 (retroceso cepillo)" ;
    ex:detalladoEnEsquema ex:Figura4_15 .

ex:ValvulaRefrigeranteYP903
    a ex:ComponenteHidraulico ;
    rdfs:label "Válvula de refrigerante" ;
    ex:identificador "YP903" ;
    ex:textoExtracto "YP903 (refrigerante)" ;
    ex:detalladoEnEsquema ex:Figura4_15 .

ex:ManometroBP710
    a ex:Sensor ;
    rdfs:label "Manómetro de presión" ;
    ex:identificador "BP710" ;
    ex:textoExtracto "BP710 (presiones)" ;
    ex:detalladoEnEsquema ex:Figura4_15 .

ex:ManometroBP711
    a ex:Sensor ;
    rdfs:label "Manómetro de presión" ;
    ex:identificador "BP711" ;
    ex:textoExtracto "BP711 (presiones)" ;
