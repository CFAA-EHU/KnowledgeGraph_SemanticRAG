ns1:MesaArribaYP802_48a831a8a0 a ns1:Componente ;
    rdfs:label "Mesa arriba YP802" ;
    ns1:textoExtracto "Conjunto sobre bancada con ... YP802/YP803 (mesa arriba/abajo)" .

ns1:NivelBL726_3096d040b4 a ns1:Componente ;
