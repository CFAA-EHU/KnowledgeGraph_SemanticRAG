@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaArmarioElectrico a ns1:Esquema ;
    rdfs:label "Figura 4-19. Armario eléctrico" ;
    ns1:textoExtracto "Fotografía del gabinete lateral con señalética de alta tensión y ventilación. Plano frontal que contextualiza su ubicación y acceso para control/diagnóstico." .

ns1:SistemaHidraulicoRefrigeracion a ns1:Sistema ;
    rdfs:label "Sistema de refrigeración" ;
    ns1:textoExtracto "Conjunto sobre bancada con M6 (motor), BL726 (nivel), YP802/YP803 (mesa arriba/abajo), YP900 (freno), BP714/BP727 (presión). Flechas rojas y rótulos guían funciones y puntos de medida." ;
    ns1:tieneComponente ns1:Componente_3d3d770351,
        ns1:Componente_feaa5e7147,
        ns1:FrenoYP900_8c8376fa32,
        ns1:MesaAbajoYP803_3c65a4d23b,
        ns1:MesaArribaYP802_48a831a8a0,
        ns1:NivelBL726_3096d040b4,
        ns1:PresionBP714,
        ns1:PresionBP727 .

