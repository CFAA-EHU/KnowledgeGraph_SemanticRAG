@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ControlCMas a ns1:ComponenteElectrico ;
    rdfs:label "Control C+" ;
    ns1:textoExtracto "Captura JOG con controles Z+/Z- y C+/C- destacados."@es .

ns1:ControlCMenos a ns1:ComponenteElectrico ;
    rdfs:label "Control C-" ;
    ns1:textoExtracto "Captura JOG con controles Z+/Z- y C+/C- destacados."@es .

ns1:ControlZMas a ns1:ComponenteElectrico ;
    rdfs:label "Control Z+" ;
    ns1:textoExtracto "Captura JOG con controles Z+/Z- y C+/C- destacados."@es .

ns1:ControlZMenos a ns1:ComponenteElectrico ;
    rdfs:label "Control Z-" ;
    ns1:textoExtracto "Captura JOG con controles Z+/Z- y C+/C- destacados."@es .

ns1:Figura5_3_DimensionesMaquina a ns1:Figura ;
    rdfs:label "Figura 5-3. Dimensiones máquina" ;
    ns1:textoExtracto "Volteo máquina --- Secuencia 1–2–3 con flechas verticales y curva que ilustran el volteo desde vertical a horizontal con dos grúas; vistas frontal y lateral para claridad espacial."@es .

ns1:Figura6_1_InterruptorGeneralArmarioElectrico a ns1:Figura ;
    rdfs:label "Figura 6-1. Interruptor general del armario eléctrico" ;
    ns1:textoExtracto "Plano con vistas planta, alzado y perspectiva acotadas (p. ej., 5850 y 5000 mm visibles). Rejilla y cartelas técnicas estructuran lectura y ubicación en planta."@es .

ns1:Figura6_2_PanelOperador a ns1:Figura ;
    rdfs:label "Figura 6-2. Panel operador" ;
    ns1:textoExtracto "Esquema frontal del pupitre con botones señalados mediante etiquetas: Parada emergencia, Puesta servicio, Paro servicio, Marcha ciclo, Modo Setup, Habilitar/Apertura puertas. La maquetación por bloques y flechas clarifica funciones y jerarquía de mandos."@es .

ns1:PanelOperador a ns1:InterfazUsuario ;
    rdfs:label "Panel operador" ;
    ns1:compuestoPor ns1:BotonHabilitarAperturaPuertas,
        ns1:BotonMarchaCiclo,
        ns1:BotonModoSetup,
        ns1:BotonParadaEmergencia,
        ns1:BotonParoServicio,
        ns1:BotonPuestaServicio ;
    ns1:textoExtracto "Esquema frontal del pupitre con botones señalados mediante etiquetas: Parada emergencia, Puesta servicio, Paro servicio, Marcha ciclo, Modo Setup, Habilitar/Apertura puertas. La maquetación por bloques y flechas clarifica funciones y jerarquía de mandos."@es .

ns1:SeccionadorInterruptorGeneral a ns1:ComponenteElectrico ;
    rdfs:label "Seccionador interruptor general" ;
    ns1:textoExtracto "Primer plano del seccionador con flecha roja que indica el giro a ON. Se aprecia luz piloto y marcaje del mando; enfoque en la acción previa a la puesta en servicio y en la identificación visual del estado del interruptor."@es .

ns1:Teclado a ns1:InterfazUsuario ;
    rdfs:label "Teclado" ;
    ns1:textoExtracto "Captura KEYBOARD con agrupaciones de teclas funcionales (modo, navegación, utilidades). Distribución en celdas grandes/pequeñas y rótulos tipográficos que permiten identificar acciones rápidas."@es .

ns1:TecladoJOG a ns1:InterfazUsuario ;
    rdfs:label "Teclado JOG" ;
    ns1:textoExtracto "Captura JOG con controles Z+/Z- y C+/C- destacados. Zonas de estado en la parte inferior y lateral; contraste claro entre teclas activas/inactivas para la conducción manual de ejes."@es .

ns1:BotonHabilitarAperturaPuertas a ns1:ComponenteElectrico ;
    rdfs:label "Boton Habilitar/Apertura puertas" ;
    ns1:textoExtracto "Esquema frontal del pupitre con botones señalados mediante etiquetas: Parada emergencia, Puesta servicio, Paro servicio, Marcha ciclo, Modo Setup, Habilitar/Apertura puertas."@es .

ns1:BotonMarchaCiclo a ns1:ComponenteElectrico ;
    rdfs:label "Boton Marcha ciclo" ;
    ns1:textoExtracto "Esquema frontal del pupitre con botones señalados mediante etiquetas: Parada emergencia, Puesta servicio, Paro servicio, Marcha ciclo, Modo Setup, Habilitar/Apertura puertas."@es .

ns1:BotonModoSetup a ns1:ComponenteElectrico ;
    rdfs:label "Boton Modo Setup" ;
    ns1:textoExtracto "Esquema frontal del pupitre con botones señalados mediante etiquetas: Parada emergencia, Puesta servicio, Paro servicio, Marcha ciclo, Modo Setup, Habilitar/Apertura puertas."@es .

ns1:BotonParadaEmergencia a ns1:ComponenteElectrico ;
    rdfs:label "Boton Parada emergencia" ;
    ns1:textoExtracto "Esquema frontal del pupitre con botones señalados mediante etiquetas: Parada emergencia, Puesta servicio, Paro servicio, Marcha ciclo, Modo Setup, Habilitar/Apertura puertas."@es .

ns1:BotonParoServicio a ns1:ComponenteElectrico ;
    rdfs:label "Boton Paro servicio" ;
    ns1:textoExtracto "Esquema frontal del pupitre con botones señalados mediante etiquetas: Parada emergencia, Puesta servicio, Paro servicio, Marcha ciclo, Modo Setup, Habilitar/Apertura puertas."@es .

ns1:BotonPuestaServicio a ns1:ComponenteElectrico ;
    rdfs:label "Boton Puesta servicio" ;
    ns1:textoExtracto "Esquema frontal del pupitre con botones señalados mediante etiquetas: Parada emergencia, Puesta servicio, Paro servicio, Marcha ciclo, Modo Setup, Habilitar/Apertura puertas."@es .

