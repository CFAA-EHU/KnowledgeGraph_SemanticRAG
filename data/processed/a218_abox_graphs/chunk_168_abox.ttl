@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaInterruptorGeneral a ns1:Esquema ;
    rdfs:label "Figura 6-1. Interruptor general del armario eléctrico.",
        "Primer plano del seccionador con flecha roja que indica el giro a ON" ;
    ns1:textoExtracto "Primer plano del seccionador con flecha roja que indica el giro a ON. Se aprecia luz piloto y marcaje del mando; enfoque en la acción previa a la puesta en servicio y en la identificación visual del estado del interruptor." .

ns1:EsquemaVolteoMaquina a ns1:Esquema ;
    rdfs:label "Figura 5-3. Dimensiones máquina",
        "Plano con vistas planta, alzado y perspectiva acotadas" ;
    ns1:textoExtracto "Plano con vistas planta, alzado y perspectiva acotadas (p. ej., 5850 y 5000 mm visibles). Rejilla y cartelas técnicas estructuran lectura y ubicación en planta." .

ns1:InterfazUsuarioJog a ns1:InterfazUsuario ;
    rdfs:label "Captura JOG con controles Z+/Z- y C+/C-" ;
    ns1:textoExtracto "Captura JOG con controles Z+/Z- y C+/C- destacados. Zonas de estado en la parte inferior y lateral; contraste claro entre teclas activas/inactivas para la conducción manual de ejes." .

ns1:InterfazUsuarioPanelOperador a ns1:InterfazUsuario ;
    rdfs:label "Esquema frontal del pupitre con botones señalados mediante etiquetas",
        "Figura 6-2. Panel operador" ;
    ns1:textoExtracto "Esquema frontal del pupitre con botones señalados mediante etiquetas: Parada emergencia, Puesta servicio, Paro servicio, Marcha ciclo, Modo Setup, Habilitar/Apertura puertas." .

ns1:InterfazUsuarioTeclado a ns1:InterfazUsuario ;
    rdfs:label "Captura KEYBOARD con agrupaciones de teclas funcionales" ;
    ns1:textoExtracto "Captura KEYBOARD con agrupaciones de teclas funcionales (modo, navegación, utilidades). Distribución en celdas grandes/pequeñas y rótulos tipográficos que permiten identificar acciones rápidas." .

