@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Figuras y Esquemas Principales
ex:Figura_5_3_DimensionesMaquina
    a ex:Figura ;
    rdfs:label "Figura 5-3. Dimensiones máquina" ;
    ex:textoExtracto "Figura 5-3. Dimensiones máquina --- Secuencia 1–2–3 con flechas verticales y curva que ilustran el volteo desde vertical a horizontal con dos grúas; vistas frontal y lateral para claridad espacial." ;
    ex:ilustradoEn ex:Manual_Tecnico ;
    ex:identificador "5-3" .

ex:Figura_6_1_InterruptorGeneral
    a ex:Figura ;
    rdfs:label "Figura 6-1. Interruptor general del armario eléctrico" ;
    ex:textoExtracto "Primer plano del seccionador con flecha roja que indica el giro a ON. Se aprecia luz piloto y marcaje del mando; enfoque en la acción previa a la puesta en servicio y en la identificación visual del estado del interruptor." ;
    ex:ilustradoEn ex:Manual_Tecnico ;
    ex:identificador "6-1" .

ex:Figura_6_2_PanelOperador
    a ex:Figura ;
    rdfs:label "Figura 6-2. Panel operador" ;
    ex:textoExtracto "Esquema frontal del pupitre con botones señalados mediante etiquetas: Parada emergencia, Puesta servicio, Paro servicio, Marcha ciclo, Modo Setup, Habilitar/Apertura puertas. La maquetación por bloques y flechas clarifica funciones y jerarquía de mandos." ;
    ex:ilustradoEn ex:Manual_Tecnico ;
    ex:identificador "6-2" .

### Interfaz de Usuario (Componentes)
ex:PanelOperador_Maquina
    a ex:InterfazUsuario ;
    rdfs:label "Panel operador de la máquina" ;
    ex:textoExtracto "Esquema frontal del pupitre con botones señalados mediante etiquetas: Parada emergencia, Puesta servicio, Paro servicio, Marcha ciclo, Modo Setup, Habilitar/Apertura puertas." ;
    ex:tieneComponente ex:Bot_n_ParadaEmergencia, ex:Bot_n_PuestaServicio, ex:Bot_n_ParoServicio, ex:Bot_n_MarchaCiclo, ex:Bot_n_ModoSetup, ex:Bot_n_HabilitarPuertas ;
    ex:detalladoEnEsquema ex:Figura_6_2_PanelOperador .

ex:Teclado_Control
    a ex:InterfazUsuario ;
    rdfs:label "Teclado de control (KEYBOARD)" ;
    ex:textoExtracto "Captura KEYBOARD con agrupaciones de teclas funcionales (modo, navegación, utilidades). Distribución en celdas grandes/pequeñas y rótulos tipográficos que permiten identificar acciones rápidas." ;
    ex:detalladoEnEsquema ex:Manual_Tecnico .

ex:Interfaz_JOG
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz JOG para conducción manual" ;
    ex:textoExtracto "Captura JOG con controles Z+/Z- y C+/C- destacados. Zonas de estado en la parte inferior y lateral; contraste claro entre teclas activas/inactivas para la conducción manual de ejes." ;
    ex:detalladoEnEsquema ex:Manual_Tecnico .

### Componentes Eléctricos (Botones y Controles)
ex:Bot_n_ParadaEmergencia
    a ex:ComponenteElectrico ;
    rdfs:label "Botón de parada de emergencia" ;
    ex:textoExtracto "Parada emergencia" ;
    ex:mitigaRiesgo ex:Alarma_Emergencia .

ex:Bot_n_PuestaServicio
    a ex:ComponenteElectrico ;
    rdfs:label "Botón de puesta en servicio" ;
    ex:textoExtracto "Puesta servicio" .

ex:Bot_n_ParoServicio
    a ex:ComponenteElectrico ;
    rdfs:label "Botón de paro de servicio" ;
    ex:textoExtracto "Paro servicio" .

ex:Bot_n_MarchaCiclo
    a ex:ComponenteElectrico ;
    rdfs:label "Botón de marcha de ciclo" ;
    ex:textoExtracto "Marcha ciclo" .

ex:Bot_n_ModoSetup
    a ex:ComponenteElectrico ;
    rdfs:label "Botón de modo setup" ;
    ex:textoExtracto "Modo Setup" .

ex:Bot_n_HabilitarPuertas
    a ex:ComponenteElectrico ;
    rdfs:label "Botón de habilitar/apertura de puertas" ;
    ex:textoExtracto "Habilitar/Apertura puertas" .

ex:InterruptorGeneral_Armario
    a ex:ComponenteElectrico ;
    rdfs:label "Interruptor general del armario eléctrico" ;
    ex:textoExtracto "Primer plano del seccionador con flecha roja que indica el giro a ON. Se aprecia luz piloto y marcaje del mando." ;
    ex:detalladoEnEsquema ex:Figura_6_1_InterruptorGeneral .

### Manual (Entidad Ancla)
ex:Manual_Tecnico
    a ex:Manual ;
    rdfs:label "Manual técnico de la máquina" ;
    ex:textoExtracto "CAPÍTULO 10 - ANEXOS - 10.1 – PLANOS MECANICOS - 10.2 – ESQUEMAS DE FLUIDOS - 10.3 – ESQUEMAS ELECTRICOS" ;
    ex:documentadoEn ex:Capitulo_10_Anexos .

ex:Capitulo_10_Anexos
    a ex:Capitulo ;
    rdfs:label "Capítulo 10 - Anexos" ;
    ex:textoExtracto "10.1 – PLANOS MECANICOS - 10.2 – ESQUEMAS DE FLUIDOS - 10.3 – ESQUEMAS ELECTRICOS" ;
    ex:compuestoPor ex:Figura_5_3_DimensionesMaquina, ex:Figura_6_1_InterruptorGeneral, ex:Figura_6_2_PanelOperador .