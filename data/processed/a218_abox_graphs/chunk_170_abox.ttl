@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:BotoneriaSoftkeys a ns1:InterfazUsuario ;
    ns1:textoExtracto "Botonería con softkeys para ejecutar/simular/memorizar." .

ns1:FragmentoTecladoResetAutoManual a ns1:InterfazUsuario ;
    ns1:textoExtracto "Fragmento de teclado con Reset / Auto / Manual enfatizados por color (rojo/amarillo/verde)." .

ns1:PanelInfograficoAdvertencias a ns1:InterfazUsuario ;
    ns1:textoExtracto "Panel infográfico de advertencias con pictogramas STOP y triángulos de peligro; bloques rojos con texto blanco destacan consignación, prohibición de aire a presión y uso de mástil anticaídas." .

ns1:SelectorModoOperacion a ns1:ModoOperacion ;
    ns1:textoExtracto "Selector con iconos conmutables de pieza (ANILLO/PLANA), operación (DESBASTE/ACABADO) y refrigeración (CON/SIN); gráfico circular contextualiza trayectorias." .

ns1:Vista3DColumnaCarro a ns1:Esquema ;
    ns1:textoExtracto "Vista 3D a color de la columna y el carro con globos numerados y recuadros en rojo; identifica cremalleras, servomotores, guías, frenos, fuelles y sensores. La codificación visual enlaza cada ítem con su ubicación." ;
    ns1:tieneComponente ns1:Cremallera1,
        ns1:Freno1,
        ns1:Fuelle1,
        ns1:Guia1,
        ns1:Sensor1,
        ns1:Servomotor1 .

ns1:Vista3DPlatoDivisor a ns1:Esquema ;
    ns1:textoExtracto "Perspectiva del conjunto del plato sobre bancada con resaltado del plato (1) y servomotor (2). Paleta de colores separa elementos y facilita la correspondencia con referencias comerciales." ;
    ns1:tieneComponente ns1:Plato1,
        ns1:Servomotor2 .

ns1:Cremallera1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "identifica cremalleras, servomotores, guías, frenos, fuelles y sensores" .

ns1:Freno1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "identifica cremalleras, servomotores, guías, frenos, fuelles y sensores" .

ns1:Fuelle1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "identifica cremalleras, servomotores, guías, frenos, fuelles y sensores" .

ns1:Guia1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "identifica cremalleras, servomotores, guías, frenos, fuelles y sensores" .

ns1:Plato1 a ns1:PiezaRecambio ;
    ns1:textoExtracto "Perspectiva del conjunto del plato sobre bancada con resaltado del plato (1) y servomotor (2)" .

ns1:Sensor1 a ns1:Sensor ;
    ns1:textoExtracto "identifica cremalleras, servomotores, guías, frenos, fuelles y sensores" .

ns1:Servomotor1 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "identifica cremalleras, servomotores, guías, frenos, fuelles y sensores" .

ns1:Servomotor2 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "Perspectiva del conjunto del plato sobre bancada con resaltado del plato (1) y servomotor (2)" .

