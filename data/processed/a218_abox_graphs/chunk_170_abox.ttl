@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioModosFuncionamiento a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de Modos de Funcionamiento" ;
    ns1:textoExtracto "Selector con iconos conmutables de pieza (ANILLO/PLANA), operación (DESBASTE/ACABADO) y refrigeración (CON/SIN); gráfico circular contextualiza trayectorias." .

ns1:InterfazUsuarioPlanMantenimiento a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de Plan de Mantenimiento" ;
    ns1:textoExtracto "Fragmento de teclado con Reset / Auto / Manual enfatizados por color (rojo/amarillo/verde). Flechas rojas subrayan la secuencia de puesta en servicio y cambio de modo." .

ns1:SistemaHidraulicoColumnaCarroPortaPiezas a ns1:Sistema ;
    rdfs:label "Sistema Hidráulico de Columna y Carro Porta-Piezas" ;
    ns1:textoExtracto "Vista 3D a color de la columna y el carro con globos numerados y recuadros en rojo; identifica cremalleras, servomotores, guías, frenos, fuelles y sensores." ;
    ns1:tieneComponente ns1:ServomotorDelPlatoDivisor_025687f953 .

ns1:SistemaInfograficoAdvertencias a ns1:Sistema ;
    rdfs:label "Sistema Infográfico de Advertencias" ;
    ns1:textoExtracto "Panel infográfico de advertencias con pictogramas STOP y triángulos de peligro; bloques rojos con texto blanco destacan consignación, prohibición de aire a presión y uso de mástil anticaídas." .

ns1:ServomotorDelPlatoDivisor_025687f953 a ns1:ComponenteMecanico ;
    rdfs:label "Servomotor del Plato Divisor" ;
    ns1:textoExtracto "Perspectiva del conjunto del plato sobre bancada con resaltado del plato (1) y servomotor (2)." .

