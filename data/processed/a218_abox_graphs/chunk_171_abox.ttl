@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CarroPortaPiezas a ns1:Sistema ;
    rdfs:label "Conjunto Carro Porta-piezas" ;
    ns1:documentadoEn ns1:EsquemaCarroPortaPiezas ;
    ns1:textoExtracto "Lámina con vistas frontal, lateral, planta e isométrica explotada. Globos de referencia señalan subconjuntos y puntos de fijación; rejilla alfanumérica y cartela técnica estructuran la localización." .

ns1:ConjuntoDelCarenado a ns1:Componente ;
    rdfs:label "Conjunto del carenado" ;
    ns1:documentadoEn ns1:EsquemaComponenteCarenado ;
    ns1:textoExtracto "Conjunto del carenado con llamadas a lámparas y interruptores EUCHNER (transponder y monitorización). Globos numerados y recuadros localizan componentes de sustitución frecuente." .

ns1:SistemaLimpiezaBrocha a ns1:Sistema ;
    rdfs:label "Sistema de limpieza de brocha" ;
    ns1:documentadoEn ns1:EsquemaSistemaLimpiezaBrocha ;
    ns1:textoExtracto "Elementos comerciales y de desgaste del sistema limpieza brocha --- Módulo longitudinal con cilindro neumático y cepillos señalados (1–2). Círculo de detalle sobre el peine de cerdas; disposición evidencia el área activa de limpieza." .

ns1:SubconjuntoICarroPortaPiezas a ns1:Sistema ;
    rdfs:label "Carro Porta-piezas (Subconjunto I)" ;
    ns1:documentadoEn ns1:EsquemaSubconjuntoICarroPortaPiezas ;
    ns1:textoExtracto "Conjunto detallado con múltiples llamadas numeradas y tres detalles ampliados (A, B, C). Se distinguen columnas con guías, patines y cableado de sensores; el isométrico resalta la jerarquía de componentes." .

ns1:EsquemaCarroPortaPiezas a ns1:Esquema ;
    rdfs:label "Esquema del Carro Porta-piezas" ;
    ns1:textoExtracto "Lámina con vistas frontal, lateral, planta e isométrica explotada. Globos de referencia señalan subconjuntos y puntos de fijación; rejilla alfanumérica y cartela técnica estructuran la localización." .

ns1:EsquemaComponenteCarenado a ns1:Esquema ;
    rdfs:label "Figura 8-4. Elementos comerciales y de desgaste del carenado" ;
    ns1:textoExtracto "Conjunto del carenado con llamadas a lámparas y interruptores EUCHNER (transponder y monitorización). Globos numerados y recuadros localizan componentes de sustitución frecuente." .

ns1:EsquemaSistemaLimpiezaBrocha a ns1:Esquema ;
    rdfs:label "Figura 8-3. Elementos comerciales y de desgaste del sistema limpieza brocha" ;
    ns1:textoExtracto "Módulo longitudinal con cilindro neumático y cepillos señalados (1–2). Círculo de detalle sobre el peine de cerdas; disposición evidencia el área activa de limpieza." .

ns1:EsquemaSubconjuntoICarroPortaPiezas a ns1:Esquema ;
    rdfs:label "Esquema del Carro Porta-piezas (Subconjunto I)" ;
    ns1:textoExtracto "Conjunto detallado con múltiples llamadas numeradas y tres detalles ampliados (A, B, C). Se distinguen columnas con guías, patines y cableado de sensores; el isométrico resalta la jerarquía de componentes." .

