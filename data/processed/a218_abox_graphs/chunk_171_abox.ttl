@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Apoyo a ns1:ComponenteMecanico ;
    ns1:textoExtracto "apoyos" .

ns1:Bastidor a ns1:ComponenteMecanico ;
    ns1:textoExtracto "bastidor" .

ns1:CableadoSensor a ns1:ComponenteElectrico ;
    ns1:textoExtracto "cableado de sensores" .

ns1:Carenado a ns1:ComponenteMecanico ;
    ns1:identificador "A21811000" ;
    ns1:textoExtracto "Conjunto del carenado con llamadas a lámparas y interruptores EUCHNER (transponder y monitorización)" .

ns1:CarroPortaPiezas a ns1:ComponenteMecanico ;
    ns1:identificador "A21811000" ;
    ns1:textoExtracto "Lámina con vistas frontal, lateral, planta e isométrica explotada. Globos de referencia señalan subconjuntos y puntos de fijación; rejilla alfanumérica y cartela técnica estructuran la localización. Se aprecian guías lineales, bastidor y apoyos" .

ns1:Cepillo a ns1:ComponenteMecanico ;
    ns1:textoExtracto "cepillos" .

ns1:CilindroNeumatico a ns1:ComponenteHidraulico ;
    ns1:textoExtracto "cilindro neumático" .

ns1:ColumnaGuia a ns1:ComponenteMecanico ;
    ns1:textoExtracto "columnas con guías" .

ns1:GuiaLineal a ns1:ComponenteMecanico ;
    ns1:textoExtracto "guías lineales" .

ns1:InterruptorEUCHNER a ns1:ComponenteElectrico ;
    ns1:textoExtracto "interruptores EUCHNER (transponder y monitorización)" .

ns1:Lampara a ns1:ComponenteElectrico ;
    ns1:textoExtracto "lámparas" .

ns1:ModuloLongitudinal a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Módulo longitudinal con cilindro neumático y cepillos señalados (1–2)" .

ns1:Patin a ns1:ComponenteMecanico ;
    ns1:textoExtracto "patines" .

ns1:PeineCerdas a ns1:ComponenteMecanico ;
    ns1:textoExtracto "peine de cerdas" .

ns1:PlatoDivisor a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Perspectiva del conjunto del plato sobre bancada con resaltado del plato (1) y servomotor (2)" .

ns1:Servomotor a ns1:ComponenteElectrico ;
    ns1:textoExtracto "servomotor (2)" .

ns1:SubconjuntoCarroPortaPiezasI a ns1:ComponenteMecanico ;
    ns1:identificador "A21811000_I" ;
    ns1:textoExtracto "Conjunto detallado con múltiples llamadas numeradas y tres detalles ampliados (A, B, C). Se distinguen columnas con guías, patines y cableado de sensores; el isométrico resalta la jerarquía de componentes" .

