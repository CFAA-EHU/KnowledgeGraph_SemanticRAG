@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaCarroPortaPiezasII a ns1:Esquema ;
    rdfs:label "Planos mecánicos (Carro porta-piezas)" ;
    ns1:ilustradoEn ns1:SoportesCarro ;
    ns1:textoExtracto "Vistas parciales del zócalo del carro con soportes, alojamientos mecanizados y componentes morados resaltados." .

ns1:EsquemaGuiaDerecha a ns1:Esquema ;
    rdfs:label "Guías carro porta-pieza derecha" ;
    ns1:ilustradoEn ns1:GuiaDerecha ;
    ns1:textoExtracto "Vista general a longitud completa con sección lateral del perfil guía. Se indican posiciones de deslizaderas y patrón de taladros a paso regular;" .

ns1:EsquemaGuiaIzquierda a ns1:Esquema ;
    rdfs:label "Guías carro porta-pieza izquierda" ;
    ns1:ilustradoEn ns1:GuiaIzquierda ;
    ns1:textoExtracto "Lámina simétrica a la anterior: vista longitudinal con esquema de tres patines y sección de anclaje." .

ns1:EsquemaPinyonesContrapeso a ns1:Esquema ;
    rdfs:label "Piñones contrapeso" ;
    ns1:ilustradoEn ns1:PinonesContrapeso ;
    ns1:textoExtracto "Vistas múltiples del soporte de piñón con cotas de referencia (distancias entre ejes y alturas)." .

ns1:GuiaDerecha a ns1:ComponenteMecanico ;
    rdfs:label "Guía Derecha" ;
    ns1:textoExtracto "Vista general a longitud completa con sección lateral del perfil guía. Se indican posiciones de deslizaderas y patrón de taladros a paso regular;" .

ns1:GuiaIzquierda a ns1:ComponenteMecanico ;
    rdfs:label "Guía Izquierda" ;
    ns1:textoExtracto "Lámina simétrica a la anterior: vista longitudinal con esquema de tres patines y sección de anclaje." .

ns1:PinonesContrapeso a ns1:ComponenteMecanico ;
    rdfs:label "Piñones Contrapeso" ;
    ns1:textoExtracto "Vistas múltiples del soporte de piñón con cotas de referencia (distancias entre ejes y alturas)." .

ns1:SoportesCarro a ns1:ComponenteMecanico ;
    rdfs:label "Soportes Carro" ;
    ns1:textoExtracto "Vistas parciales del zócalo del carro con soportes, alojamientos mecanizados y componentes morados resaltados." .

