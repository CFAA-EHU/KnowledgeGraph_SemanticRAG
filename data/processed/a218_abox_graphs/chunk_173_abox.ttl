@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaFuelleCarroPortaPiezas a ns1:Esquema ;
    rdfs:label "Fuelle carro porta-piezas" ;
    ns1:textoExtracto "Conjunto de fuelles plegados con secciones A-A y B-B. Se representan radios de pliegue, pasos y ángulos;" .

ns1:EsquemaSoportePinyonDCH a ns1:Esquema ;
    rdfs:label "Soporte piñón DCH" ;
    ns1:textoExtracto "Vistas ortogonales y sección A-A a escala 1:2 mostrando eje estriado, chaveteros y alojamiento de rodamientos." .

ns1:EsquemaSoportePinyonIZQ a ns1:Esquema ;
    rdfs:label "Soporte piñón IZQ" ;
    ns1:textoExtracto "Misma estructura que el derecho: vistas y sección A-A. Se aprecian cotas de alojamiento, roscas y posición del racor;" .

ns1:PinonMacizoDobleISO1_764f77be95 a ns1:Esquema ;
    rdfs:label "Piñón macizo doble (ISO 1\")" ;
    ns1:textoExtracto "Vistas de alzado, perfil y sección A-A con dentado para cadena de 1\"." .

