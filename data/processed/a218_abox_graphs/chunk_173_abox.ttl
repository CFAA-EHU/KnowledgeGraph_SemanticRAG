@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FuelleCarroPortapiezas a ns1:ComponenteMecanico ;
    rdfs:label "Fuelle carro porta-piezas" ;
    ns1:compuestoPor ns1:Angulo,
        ns1:FuellePlegado,
        ns1:Paso,
        ns1:RadioPliegue ;
    ns1:identificador "A21811069" ;
    ns1:textoExtracto "Conjunto de fuelles plegados con secciones A-A y B-B. Se representan radios de pliegue, pasos y ángulos; leyenda 'Virutas a proteger de INCONEL' contextualiza la función de barrera." .

ns1:PinonMacizoDoble a ns1:ComponenteMecanico ;
    rdfs:label "Piñón macizo doble (ISO 1\")" ;
    ns1:compuestoPor ns1:Chavetero,
        ns1:DentadoCadena,
        ns1:RadioTransicion,
        ns1:TaladroRoscado ;
    ns1:identificador "A21811035" ;
    ns1:textoExtracto "Vistas de alzado, perfil y sección A-A con dentado para cadena de 1\". Se detallan ajuste del cubo (K7), chaveteros, taladros roscados y radio de transición; un detalle A (2:1) muestra el flanco de diente." .

ns1:SoportePi_onDCH a ns1:ComponenteMecanico ;
    rdfs:label "Soporte piñón DCH" ;
    ns1:compuestoPor ns1:AlojamientoRodamientos,
        ns1:Chavetero,
        ns1:EjeEstriado ;
    ns1:identificador "A21811030_DCH" ;
    ns1:textoExtracto "Vistas ortogonales y sección A-A a escala 1:2 mostrando eje estriado, chaveteros y alojamiento de rodamientos. Se indican radios, chaflanes y referencias de cadena de rodillos; globos vinculan piezas clave." .

ns1:SoportePi_onIZQ a ns1:ComponenteMecanico ;
    rdfs:label "Soporte piñón IZQ" ;
    ns1:compuestoPor ns1:Alojamiento,
        ns1:AlojamientoRoscas,
        ns1:Racor ;
    ns1:identificador "A21811030_IZQ" ;
    ns1:textoExtracto "Misma estructura que el derecho: vistas y sección A-A. Se aprecian cotas de alojamiento, roscas y posición del racor; el isométrico evidencia la geometría diferenciada por lateralidad." .

