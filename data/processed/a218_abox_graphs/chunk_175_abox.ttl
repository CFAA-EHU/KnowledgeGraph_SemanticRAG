ns1:ComponenteElectrico_e4dbe127cd a ns1:ComponenteElectrico ;
    rdfs:label "Sensor de nivel" ;
    ns1:identificador "BL726" ;
    ns1:textoExtracto "Esquema hidráulico del grupo: depósito 130 L con sensor de nivel (BL726), M6 motor del grupo, bomba y retorno al tanque." .

ns1:M3MotorRefrigeracion a ns1:ComponenteElectrico ;
    rdfs:label "M3 Motor Refrigeración" ;
    ns1:textoExtracto "Circuito de refrigeración con capacidad 200 L. Motores: M3 (refrigerante máquina), M4 (trasvase), M5 (extractor de viruta) y grupo de filtro de papel (SQ40)." .

