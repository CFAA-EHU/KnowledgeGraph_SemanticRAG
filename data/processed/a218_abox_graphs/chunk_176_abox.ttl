@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BloqueBomba a ns1:ComponenteHidraulico ;
    rdfs:label "Bloque de la bomba" ;
    ns1:detalladoEnEsquema ns1:EsquemaLubricacion ;
    ns1:textoExtracto "Distribución de engrase hacia piñones de cadena y cremalleras izquierda/derecha desde la unidad 516U1. Se especifica capacidad 400 cm³ y grasa hasta NLGI 3; caudal de 0,2 l/min. Flechas marcan el sentido de suministro y el bloque de la bomba aparece en recuadro con simbología de válvulas." .

ns1:BombaLubricacion a ns1:ComponenteHidraulico ;
    rdfs:label "Bomba de lubricación" ;
    ns1:detalladoEnEsquema ns1:EsquemaLubricacion ;
    ns1:textoExtracto "Hoja de lubricación con imagen de la bomba y su conexionado a bornes (XT1 24S/0S/E700, etc.). Se incluyen notas operativas (p. ej., ' Cantidad de lubricante por impulso: 0,15 cm³ (por salida); excitación secuencial 1.1→1.2') y tablas de mensajes/fallos." .

ns1:ComponenteHidraulico_ac10922b14 a ns1:ComponenteHidraulico ;
    rdfs:label "Sensor de caudal",
        "Sensor de nivel" ;
    ns1:esComponenteDe ns1:SistemaLubricacion ;
    ns1:textoExtracto "Sensores de nivel (BN41/BN42) y caudal BC44. Las líneas y válvulas señalan el recorrido desde tanque, filtración y retorno; se anotan potencias y datos de placa." .

ns1:CorrienteDeSeccionamientoIs a ns1:Parametro ;
    rdfs:label "Corriente de seccionamiento Is" ;
    ns1:textoExtracto "Diagrama unifilar de entrada 3×380 V/50 Hz con seccionador/interruptor (10QS1), cálculos (S total 67 kVA, Is 102 A), barras L1/L2/L3 y derivaciones a PE; cartucho de ATENCIÓN enmarcado." ;
    ns1:valor "102 A" .

ns1:STotal a ns1:Parametro ;
    rdfs:label "S total" ;
    ns1:textoExtracto "Diagrama unifilar de entrada 3×380 V/50 Hz con seccionador/interruptor (10QS1), cálculos (S total 67 kVA, Is 102 A), barras L1/L2/L3 y derivaciones a PE; cartucho de ATENCIÓN enmarcado." ;
    ns1:valor "67 kVA" .

ns1:SeccionadorPrincipal a ns1:ComponenteElectrico ;
    rdfs:label "Seccionador principal" ;
    ns1:detalladoEnEsquema ns1:EsquemaElectricoPotencia ;
    ns1:textoExtracto "Diagrama unifilar de entrada 3×380 V/50 Hz con seccionador/interruptor (10QS1), cálculos (S total 67 kVA, Is 102 A), barras L1/L2/L3 y derivaciones a PE; cartucho de ATENCIÓN enmarcado." .

ns1:EsquemaElectricoPotencia a ns1:Esquema ;
    rdfs:label "Diagrama unifilar de entrada 3×380 V/50 Hz" ;
    ns1:textoExtracto "Diagrama unifilar de entrada 3×380 V/50 Hz con seccionador/interruptor (10QS1), cálculos (S total 67 kVA, Is 102 A), barras L1/L2/L3 y derivaciones a PE; cartucho de ATENCIÓN enmarcado." .

ns1:SistemaLubricacion a ns1:Sistema ;
    rdfs:label "Sistema de lubricación" ;
    ns1:textoExtracto "Sensores de nivel (BN41/BN42) y caudal BC44. Las líneas y válvulas señalan el recorrido desde tanque, filtración y retorno; se anotan potencias y datos de placa." .

ns1:EsquemaLubricacion a ns1:Esquema ;
    rdfs:label "Hoja de lubricación" ;
    ns1:textoExtracto "Hoja de lubricación con imagen de la bomba y su conexionado a bornes (XT1 24S/0S/E700, etc.). Se incluyen notas operativas (p. ej., ' Cantidad de lubricante por impulso: 0,15 cm³ (por salida); excitación secuencial 1.1→1.2') y tablas de mensajes/fallos." .

