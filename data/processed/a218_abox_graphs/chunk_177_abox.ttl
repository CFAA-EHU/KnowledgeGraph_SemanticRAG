ns1:esquemaAlimentacion24VDC a ns1:Esquema ;
    rdfs:label "Alimentacion 24VDC" ;
    ns1:compuestoPor ns1:SITOP12T1,
        ns1:XT1,
        ns1:XT1P1,
        ns1:_12F1,
        ns1:_12F2,
        ns1:_12HL1 ;
    ns1:textoExtracto "Arquitectura 24 V DC: SITOP 12T1 40 A y módulos 12F1/12F2 (4 salidas/10 A). Distribución a PLC, Safety, Panel, CNC, I/O Externos (rótulos 24API/24EBC/24VAN/24E/24SAFE/24PNL/24S/24CNC). Bornes XT1/XTP1, piloto 12HL1; líneas rojas (positivo) y verdes (retorno/PE)."@es .

ns1:esquemaAlimentacionGeneral a ns1:Esquema ;
    rdfs:label "Alimentación general" ;
    ns1:compuestoPor ns1:XT1,
        ns1:XT2,
        ns1:_11HL3,
        ns1:_11HL4,
        ns1:_11HL5,
        ns1:_11KA1,
        ns1:_11QF1,
        ns1:_11QF2,
        ns1:_11QF3,
        ns1:_11QF4,
        ns1:_11QF5,
        ns1:_11QF6,
        ns1:_11TR1 ;
    ns1:textoExtracto "Esquema de servicios a 230 VAC (iluminación máquina/pupitre, tomas de corriente, transformador 11TR1 1000 VA, luminarias 11HL3–5). Bloques con magnetotérmicos (11QF1–6) y reles (11KA1); cableado rotulado y pasos por XT1/XT2."@es .

ns1:esquemaClimatizadorArmario a ns1:Esquema ;
    rdfs:label "Climatizador armario" ;
    ns1:compuestoPor ns1:SK3304540,
        ns1:_13QF1 ;
    ns1:textoExtracto "Bloque funcional de climatizador 1000 W (Rittal SK.3304540) con protección 13QF1 y señal 'Climatizador ON'. Representación del módulo con bornes X1–X3, conexión trifásica y control por 24E; flechas de flujo eléctrico hacia el equipo."@es .

