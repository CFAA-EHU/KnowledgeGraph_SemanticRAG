ns1:CNC8070_830396ee23 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Módulo CNC 8070 con buses CAN, SERCOS II, EtherCAT, Ethernet; alimentación 24CNC/0CNC y relé 16KA1 (PLC OK)." .

ns1:DriveAXD2 a ns1:ComponenteElectrico ;
    rdfs:label "Drive AXD2" ;
    ns1:textoExtracto "Drive AXD2 con U/V/W/PE, entradas DRIVE/SPEED ENABLE, DC BUS y encoder lineal." .

ns1:EsquemaElectricoCNC8070 a ns1:Esquema ;
    rdfs:label "Esquemas eléctricos — Control numérico" ;
    ns1:textoExtracto "Módulo CNC 8070 con buses CAN, SERCOS II, EtherCAT, Ethernet; alimentación 24CNC/0CNC y relé 16KA1 (PLC OK)." .

ns1:EsquemaElectricoDrives a ns1:Esquema ;
    rdfs:label "Esquemas eléctricos — Drives (servos)" ;
    ns1:textoExtracto "Fuente de drives/reguladores: entradas L1/L2/L3, DC BUS+/–, señales RESET/SYSTEM OK/ENABLE y salidas a 24CNC/24E." .

ns1:EsquemaElectricoEjeTractionIzq a ns1:Esquema ;
