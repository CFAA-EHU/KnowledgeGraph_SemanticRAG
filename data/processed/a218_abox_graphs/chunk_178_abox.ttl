@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Barras_L1_L2_L3 a ns1:ComponenteElectrico ;
    rdfs:label "Barras L1/L2/L3" ;
    ns1:textoExtracto "Tres barras L1/L2/L3 en cabeza" .

ns1:Esquema_Electrico_CNC_8070 a ns1:Esquema ;
    rdfs:label "Esquema eléctrico CNC 8070" ;
    ns1:compuestoPor ns1:CNC_8070,
        ns1:Relay_16KA1 ;
    ns1:textoExtracto "Módulo CNC 8070 con buses CAN, SERCOS II, EtherCAT, Ethernet; alimentación 24CNC/0CNC y relé 16KA1 (PLC OK). Puertos y señales se representan como bornes alineados; referencias cruzadas a otras láminas." .

ns1:Esquema_Electrico_Fuente_Drives a ns1:Esquema ;
    rdfs:label "Esquema eléctrico Fuente de alimentación reguladores" ;
    ns1:compuestoPor ns1:Fuente_Alimentacion_Drives,
        ns1:Relay_27KA3_4 ;
    ns1:textoExtracto "Fuente de drives/reguladores: entradas L1/L2/L3, DC BUS+/–, señales RESET/SYSTEM OK/ENABLE y salidas a 24CNC/24E. Bloques de potencia con bornes X1–X3 y relés asociados (27KA3–4)." .

ns1:Esquema_Electrico_Monitor_Panel_PC a ns1:Esquema ;
    rdfs:label "Esquema eléctrico Monitor Panel PC" ;
    ns1:compuestoPor ns1:Alimentacion_24PNL_0PNL,
        ns1:Enlace_USB_VGA,
        ns1:Monitor_Panel_PC ;
    ns1:textoExtracto "Conexiones de Monitor y Panel PC: alimentación 24PNL/0PNL, enlaces USB/VGA (15WUSB1/15WVGA1) y LAN A–D con salto al esquema de red. Esquemas rectangulares de los equipos con conectores etiquetados." .

ns1:Esquema_Electrico_Servomotor_IZQUIERDA a ns1:Esquema ;
    rdfs:label "Esquema eléctrico Servomotor IZQUIERDA AXD2" ;
    ns1:compuestoPor ns1:Relay_27KAx,
        ns1:Servomotor_IZQUIERDA_AXD2 ;
    ns1:textoExtracto "Drive AXD2 con U/V/W/PE, entradas DRIVE/SPEED ENABLE, DC BUS y encoder lineal. Buses SERCOS, señales 24S/24SAFE, relés 27KAx y enlaces a bornes XT1." .

ns1:Motor_UVW_PE a ns1:ComponenteElectrico ;
    rdfs:label "Motor U/V/W/PE" ;
    ns1:textoExtracto "cada motor con U/V/W/PE y cableados WMx con longitudes." .

ns1:Alimentacion_24PNL_0PNL a ns1:ComponenteElectrico ;
    rdfs:label "Alimentación 24PNL/0PNL" ;
    ns1:textoExtracto "alimentación 24PNL/0PNL" .

ns1:CNC_8070 a ns1:Sistema ;
    rdfs:label "Módulo CNC 8070" ;
    ns1:textoExtracto "Módulo CNC 8070 con buses CAN, SERCOS II, EtherCAT, Ethernet; alimentación 24CNC/0CNC y relé 16KA1 (PLC OK)." .

ns1:Enlace_USB_VGA a ns1:ComponenteElectrico ;
    rdfs:label "Enlaces USB/VGA" ;
    ns1:textoExtracto "enlaces USB/VGA (15WUSB1/15WVGA1)" .

ns1:Fuente_Alimentacion_Drives a ns1:ComponenteElectrico ;
    rdfs:label "Fuente de alimentación reguladores" ;
    ns1:textoExtracto "Fuente de drives/reguladores: entradas L1/L2/L3, DC BUS+/–, señales RESET/SYSTEM OK/ENABLE y salidas a 24CNC/24E. Bloques de potencia con bornes X1–X3 y relés asociados (27KA3–4)." .

ns1:Monitor_Panel_PC a ns1:InterfazUsuario ;
    rdfs:label "Monitor Panel PC" ;
    ns1:textoExtracto "Conexiones de Monitor y Panel PC: alimentación 24PNL/0PNL, enlaces USB/VGA (15WUSB1/15WVGA1) y LAN A–D con salto al esquema de red. Esquemas rectangulares de los equipos con conectores etiquetados." .

ns1:Relay_16KA1 a ns1:ComponenteElectrico ;
    rdfs:label "Relé 16KA1" ;
    ns1:textoExtracto "relé 16KA1 (PLC OK)" .

ns1:Relay_27KA3_4 a ns1:ComponenteElectrico ;
    rdfs:label "Relés 27KA3–4" ;
    ns1:textoExtracto "relés asociados (27KA3–4)" .

ns1:Relay_27KAx a ns1:ComponenteElectrico ;
    rdfs:label "Relés 27KAx" ;
    ns1:textoExtracto "relés 27KAx" .

ns1:Servomotor_IZQUIERDA_AXD2 a ns1:ComponenteElectrico ;
    rdfs:label "Servomotor IZQUIERDA AXD2" ;
    ns1:textoExtracto "Drive AXD2 con U/V/W/PE, entradas DRIVE/SPEED ENABLE, DC BUS y encoder lineal. Buses SERCOS, señales 24S/24SAFE, relés 27KAx y enlaces a bornes XT1." .

