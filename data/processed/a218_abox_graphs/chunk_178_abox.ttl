    ns1:textoExtracto "Drive AXD2 con U/V/W/PE, entradas DRIVE/SPEED ENABLE, DC BUS y encoder lineal." .

ns1:EsquemaElectricoMonitorPanelPC a ns1:Esquema ;
    rdfs:label "Esquemas eléctricos — HMI" ;
    ns1:textoExtracto "Conexiones de Monitor y Panel PC: alimentación 24PNL/0PNL, enlaces USB/VGA (15WUSB1/15WVGA1) y LAN A–D con salto al esquema de red." .

ns1:Rele16KA1 a ns1:ComponenteElectrico ;
    rdfs:label "Relé 16KA1" ;
    ns1:textoExtracto "Módulo CNC 8070 con buses CAN, SERCOS II, EtherCAT, Ethernet; alimentación 24CNC/0CNC y relé 16KA1 (PLC OK)." .

