    a ex:Sensor ;
    rdfs:label "Sensor EUCHNER STP (puerta frontal)" ;
    ex:textoExtracto "Sensor EUCHNER STP para puerta frontal con contactos etiquetados (21/22, 41/42, 11/12, 33/34)" ;
