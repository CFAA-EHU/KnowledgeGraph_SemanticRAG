@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaElectricoEjeMesaGiratoria a ns1:Esquema ;
    rdfs:label "Esquemas eléctricos — Eje mesa giratoria" ;
    ns1:textoExtracto "Esquema gemelo del anterior para el servo derecho: mismas funciones y cableados (19W1–W3, 1910). Se detallan saltos a buses y señales de safety." .

ns1:EsquemaElectricoEjeTractionDCHA a ns1:Esquema ;
    rdfs:label "Esquemas eléctricos — Eje tracción DCHA" ;
    ns1:detalladoEnEsquema ns1:DriveAXD1 ;
    ns1:textoExtracto "Buses SERCOS, señales 24S/24SAFE, relés 27KAx y enlaces a bornes XT1. Líneas rojas (potencia) y verdes/azules (control/safety)." .

ns1:EsquemaElectricoSeguridadPuertaFrontal a ns1:Esquema ;
    rdfs:label "Esquemas eléctricos — Seguridad (Puerta frontal)" ;
    ns1:textoExtracto "Sensor EUCHNER STP para puerta frontal con contactos etiquetados (21/22, 41/42, 11/12, 33/34) y líneas a 0S/24SAFE." ;
    ns1:tieneComponente ns1:ComponenteElectrico_7eafe0ab99 .

ns1:EsquemaElectricoSeguridadPuertasLaterales a ns1:Esquema ;
    rdfs:label "Esquemas eléctricos — Seguridad (Puertas laterales)" ;
    ns1:textoExtracto "Dos bloques CTP-L1-AP-M-HA-AZ-SA (izquierda/derecha) con Safety Outputs/Monitoring Outputs." ;
    ns1:tieneComponente ns1:BloqueCTPL1 .

ns1:BloqueCTPL1 a ns1:ComponenteElectrico ;
    rdfs:label "Bloque CTP-L1" ;
    ns1:textoExtracto "Dos bloques CTP-L1-AP-M-HA-AZ-SA (izquierda/derecha) con Safety Outputs/Monitoring Outputs." .

ns1:ComponenteElectrico_7eafe0ab99 a ns1:ComponenteElectrico ;
    rdfs:label "Sensor EUCHNER STP" ;
    ns1:textoExtracto "Sensor EUCHNER STP para puerta frontal con contactos etiquetados (21/22, 41/42, 11/12, 33/34) y líneas a 0S/24SAFE." .

ns1:DriveAXD1 a ns1:ComponenteElectrico ;
    rdfs:label "Drive AXD1" ;
    ns1:textoExtracto "Drive AXD1 de mesa: potencia U/V/W, DC BUS, habilitaciones por 27KA1/2/5/6, retorno de encoder y enlaces 24CNC/0CNC." .

