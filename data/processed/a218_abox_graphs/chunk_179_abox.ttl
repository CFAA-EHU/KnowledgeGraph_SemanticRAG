@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Esquemas eléctricos y componentes asociados
ex:Esquema_Servomotor_DERECHA_AXD2
    a ex:Esquema ;
    rdfs:label "Esquema eléctrico - Servomotor DERECHA AXD2" ;
    ex:textoExtracto "Buses SERCOS, señales 24S/24SAFE, relés 27KAx y enlaces a bornes XT1. Líneas rojas (potencia) y verdes/azules (control/safety)." ;
    ex:identificador "AXD2" ;
    ex:detalladoEnEsquema ex:ComponenteElectrico_27KAx_DCHA ;
    ex:detalladoEnEsquema ex:ComponenteElectrico_Bornes_XT1_DCHA ;
    ex:detalladoEnEsquema ex:ComponenteElectrico_Bus_SERCOS_DCHA .

ex:Esquema_Servomotor_MESA_AXD1
    a ex:Esquema ;
    rdfs:label "Esquema eléctrico - Servomotor MESA AXD1" ;
    ex:textoExtracto "Drive AXD1 de mesa: potencia U/V/W, DC BUS, habilitaciones por 27KA1/2/5/6, retorno de encoder y enlaces 24CNC/0CNC." ;
    ex:identificador "AXD1" ;
    ex:detalladoEnEsquema ex:ComponenteElectrico_27KA1_MESA ;
    ex:detalladoEnEsquema ex:ComponenteElectrico_27KA2_MESA ;
    ex:detalladoEnEsquema ex:ComponenteElectrico_27KA5_MESA ;
    ex:detalladoEnEsquema ex:ComponenteElectrico_27KA6_MESA .

ex:Esquema_Puertas_Seguridad_Frontal
    a ex:Esquema ;
    rdfs:label "Esquema eléctrico - Puertas de Seguridad (Frontal)" ;
    ex:textoExtracto "Sensor EUCHNER STP para puerta frontal con contactos etiquetados (21/22, 41/42, 11/12, 33/34) y líneas a 0S/24SAFE." ;
    ex:detalladoEnEsquema ex:Sensor_Puerta_Frontal_EUCHNER_STP .

ex:Esquema_Puertas_Seguridad_Laterales
    a ex:Esquema ;
    rdfs:label "Esquema eléctrico - Puertas de Seguridad (Laterales)" ;
    ex:textoExtracto "Dos bloques CTP-L1-AP-M-HA-AZ-SA (izquierda/derecha) con Safety Outputs/Monitoring Outputs." ;
    ex:detalladoEnEsquema ex:ComponenteElectrico_CTP_L1_AP_Izquierda ;
    ex:detalladoEnEsquema ex:ComponenteElectrico_CTP_L1_AP_Derecha .

