@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaElectricoEscotillaInterior a ns1:Esquema ;
    rdfs:label "Esquemas eléctricos — Seguridad (Escotilla interior)"@es ;
    ns1:detalladoEnEsquema ns1:BloqueCTPParaEscotillaInterior25SQ1 ;
    ns1:textoExtracto "Bloque único CTP para escotilla interior (25SQ1) con salidas de seguridad y diagnóstico; enlaces a 24SAFE/0S y rótulo Puerta cerrada." .

ns1:EsquemaElectricoPLCSeguridad a ns1:Esquema ;
    rdfs:label "Esquemas eléctricos — PLC de seguridad"@es ;
    ns1:detalladoEnEsquema ns1:SistemaPLCSeguridadPILZ ;
    ns1:textoExtracto "Arquitectura PNOZ m B0 + EF 16DI: entradas/salidas, paradas de emergencia (pupitre y armario), puesta/paro de servicio, PLC OK, y salidas a relés 27KA1–8." .

ns1:EsquemaElectricoPuertasSeguridad a ns1:Esquema ;
    rdfs:label "Esquemas eléctricos — Seguridad (Puertas laterales)"@es ;
    ns1:detalladoEnEsquema ns1:BloqueCTPL1APMHAAZSADerecha,
        ns1:BloqueCTPL1APMHAAZSAIzquierda ;
    ns1:textoExtracto "Dos bloques CTP-L1-AP-M-HA-AZ-SA (izquierda/derecha) con Safety Outputs/Monitoring Outputs. Cableado multicolor (WH/BN/RD/BU/PK/GN/YE), rótulos Puerta cerrada y rutas a 24SAFE/0S." .

ns1:EsquemaElectricoSalidasSeguras a ns1:Esquema ;
    rdfs:label "Esquemas eléctricos — Salidas seguras"@es ;
