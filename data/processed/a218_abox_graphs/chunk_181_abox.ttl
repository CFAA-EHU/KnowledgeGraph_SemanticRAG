@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaIODeMaquina a ns1:Esquema ;
    rdfs:label "I/O Maquina vista" ;
    ns1:ilustradoEn ns1:SistemaHidraulicoElectrico ;
    ns1:textoExtracto "Vista de módulos Phoenix Contact en fila: IL EC BK-PAC (bus), varias DI 8/HD-ECO, DO 8/HD-ECO, PWR IN, y AI 4/U-PAC." .

ns1:ModuloAI4UPAC a ns1:ComponenteElectrico ;
    rdfs:label "Módulo AI 4/U-PAC" ;
    ns1:textoExtracto "Vista de módulos Phoenix Contact en fila: IL EC BK-PAC (bus), varias DI 8/HD-ECO, DO 8/HD-ECO, PWR IN, y AI 4/U-PAC." .

ns1:ModuloDI8HDECO a ns1:ComponenteElectrico ;
    rdfs:label "Módulo DI 8/HD-ECO" ;
    ns1:textoExtracto "Vista de módulos Phoenix Contact en fila: IL EC BK-PAC (bus), varias DI 8/HD-ECO, DO 8/HD-ECO, PWR IN, y AI 4/U-PAC." .

ns1:ModuloDO8HDECO a ns1:ComponenteElectrico ;
    rdfs:label "Módulo DO 8/HD-ECO" ;
    ns1:textoExtracto "Vista de módulos Phoenix Contact en fila: IL EC BK-PAC (bus), varias DI 8/HD-ECO, DO 8/HD-ECO, PWR IN, y AI 4/U-PAC." .

ns1:ModuloILECBKPAC a ns1:ComponenteElectrico ;
    rdfs:label "Módulo IL EC BK-PAC" ;
    ns1:identificador "IL EC BK-PAC" ;
    ns1:textoExtracto "Vista de módulos Phoenix Contact en fila: IL EC BK-PAC (bus), varias DI 8/HD-ECO, DO 8/HD-ECO, PWR IN, y AI 4/U-PAC." .

ns1:ModuloPWRIN a ns1:ComponenteElectrico ;
    rdfs:label "Módulo PWR IN" ;
    ns1:textoExtracto "Vista de módulos Phoenix Contact en fila: IL EC BK-PAC (bus), varias DI 8/HD-ECO, DO 8/HD-ECO, PWR IN, y AI 4/U-PAC." .

ns1:SistemaHidraulicoElectrico a ns1:Sistema ;
    rdfs:label "Sistema Hidráulico Eléctrico" ;
    ns1:textoExtracto "Diagrama del módulo de potencia y alimentación de bus para 19A1 IL EC BK-PAC." ;
    ns1:tieneComponente ns1:ModuloAI4UPAC,
        ns1:ModuloDI8HDECO,
        ns1:ModuloDO8HDECO,
        ns1:ModuloILECBKPAC,
        ns1:ModuloPWRIN .

