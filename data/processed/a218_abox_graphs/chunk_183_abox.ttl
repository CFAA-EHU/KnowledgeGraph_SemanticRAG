### Contactos intermedios (reles lógicos)
ex:ContactosIntermedios_KA00_KA04
    a ex:ComponenteElectrico ;
    rdfs:label "Bloque de contactos intermedios KA00–KA04" ;
    ex:textoExtracto "Los contactos intermedios (KA00–KA04, 27KA7/27KA8, SA36/SBL37) aparecen como bloques con bobina y contactos, enlazando la lógica." ;
    ex:identificador "KA00-KA04" ;
    ex:detalladoEnEsquema ex:Esquema_BorneEntradaDigital_19A6 .  # Asumido por contexto de esquemas eléctricos

