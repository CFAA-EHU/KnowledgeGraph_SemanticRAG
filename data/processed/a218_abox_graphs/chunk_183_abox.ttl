@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ContactoIntermedio_27KA7 a ns1:ComponenteElectrico ;
    rdfs:label "Contacto intermedio 27KA7"@es ;
    ns1:identificador "27KA7" ;
    ns1:textoExtracto "Los contactos intermedios (KA00–KA04, 27KA7/27KA8, SA36/SBL37) aparecen como bloques con bobina y contactos, enlazando la lógica."@es .

ns1:ContactoIntermedio_KA00 a ns1:ComponenteElectrico ;
    rdfs:label "Contacto intermedio KA00"@es ;
    ns1:identificador "KA00" ;
    ns1:textoExtracto "Los contactos intermedios (KA00–KA04, 27KA7/27KA8, SA36/SBL37) aparecen como bloques con bobina y contactos, enlazando la lógica."@es .

ns1:ContactoIntermedio_KA01 a ns1:ComponenteElectrico ;
    rdfs:label "Contacto intermedio KA01"@es ;
    ns1:identificador "KA01" ;
    ns1:textoExtracto "Los contactos intermedios (KA00–KA04, 27KA7/27KA8, SA36/SBL37) aparecen como bloques con bobina y contactos, enlazando la lógica."@es .

ns1:Modulo_19A6 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de entradas digitales 19A6"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_EntradasDigitales_19A6 ;
    ns1:identificador "19A6" ;
    ns1:textoExtracto "Entradas E40–E47 (módulo 19A6) para presencia de papel, niveles de refrigerante (BN41/BN42), marcha ciclo, caudal BC44, apertura puertas, mesa arriba/abajo."@es ;
    ns1:tieneComponente ns1:Sensor_BC44,
        ns1:Sensor_BN41,
        ns1:Sensor_BN42 .

ns1:Modulo_19A7 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de entradas digitales 19A7"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_EntradasDigitales_19A7 ;
    ns1:identificador "19A7" ;
    ns1:textoExtracto "Entradas E50–E57 (módulo 19A7) dedicadas a puertas (frontal/izquierda/derecha, escotilla interior), drives power supply OK y señal fuente alimentación."@es .

ns1:Modulo_19A8 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de salidas digitales 19A8"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_SalidasDigitales_19A8 ;
    ns1:identificador "19A8" ;
    ns1:textoExtracto "Salidas A20–A27 (módulo 19A8) a desbloqueos de puertas (frontal/izq./dcha./escotilla) y columna luminosa (roja/verde/naranja)."@es ;
    ns1:tieneComponente ns1:Actuador_ColumnaLuminosa,
        ns1:Piloto_HL23,
        ns1:Piloto_HL24,
        ns1:Piloto_HL25 .

ns1:Actuador_ColumnaLuminosa a ns1:Actuador ;
    rdfs:label "Columna luminosa (roja/verde/naranja)"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_SalidasDigitales_19A8 ;
    ns1:textoExtracto "columna luminosa (roja/verde/naranja)"@es .

ns1:Esquema_EntradasDigitales_19A7 a ns1:Esquema ;
    rdfs:label "Esquema de entradas digitales (módulo 19A7)"@es ;
    ns1:identificador "19A7" ;
    ns1:textoExtracto "Entradas E50–E57 (módulo 19A7) dedicadas a puertas (frontal/izquierda/derecha, escotilla interior), drives power supply OK y señal fuente alimentación. Líneas verticales en rojo y etiquetas superiores sitúan cada evento; referencias (p. ej., 23.17/E50) indican su procedencia en otras láminas."@es .

ns1:Piloto_HL23 a ns1:ComponenteElectrico ;
    rdfs:label "Piloto HL23"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_SalidasDigitales_19A8 ;
    ns1:identificador "HL23" ;
    ns1:textoExtracto "Los pilotos HL23–HL25 se agrupan en un bloque; la codificación cromática está indicada por el rótulo de cada lámpara."@es .

ns1:Piloto_HL24 a ns1:ComponenteElectrico ;
    rdfs:label "Piloto HL24"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_SalidasDigitales_19A8 ;
    ns1:identificador "HL24" ;
    ns1:textoExtracto "Los pilotos HL23–HL25 se agrupan en un bloque; la codificación cromática está indicada por el rótulo de cada lámpara."@es .

ns1:Piloto_HL25 a ns1:ComponenteElectrico ;
    rdfs:label "Piloto HL25"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_SalidasDigitales_19A8 ;
    ns1:identificador "HL25" ;
    ns1:textoExtracto "Los pilotos HL23–HL25 se agrupan en un bloque; la codificación cromática está indicada por el rótulo de cada lámpara."@es .

ns1:Sensor_BC44 a ns1:Sensor ;
    rdfs:label "Sensor de caudal BC44"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_EntradasDigitales_19A6 ;
    ns1:identificador "BC44" ;
    ns1:textoExtracto "caudal BC44"@es .

ns1:Sensor_BN41 a ns1:Sensor ;
    rdfs:label "Sensor de nivel de refrigerante BN41"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_EntradasDigitales_19A6 ;
    ns1:identificador "BN41" ;
    ns1:textoExtracto "niveles de refrigerante (BN41/BN42)"@es .

ns1:Sensor_BN42 a ns1:Sensor ;
    rdfs:label "Sensor de nivel de refrigerante BN42"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_EntradasDigitales_19A6 ;
    ns1:identificador "BN42" ;
    ns1:textoExtracto "niveles de refrigerante (BN41/BN42)"@es .

ns1:Esquema_EntradasDigitales_19A6 a ns1:Esquema ;
    rdfs:label "Esquema de entradas digitales (módulo 19A6)"@es ;
    ns1:identificador "19A6" ;
    ns1:textoExtracto "Entradas E40–E47 (módulo 19A6) para presencia de papel, niveles de refrigerante (BN41/BN42), marcha ciclo, caudal BC44, apertura puertas, mesa arriba/abajo. Se representan sensores con símbolos (p. ej., BN/BC/SQ), conectores M12, longitudes de cable (7,5 m 5×0,34) y flechas hacia 24E/0E."@es .

ns1:Esquema_SalidasDigitales_19A8 a ns1:Esquema ;
    rdfs:label "Esquema de salidas digitales (módulo 19A8)"@es ;
    ns1:identificador "19A8" ;
    ns1:textoExtracto "Salidas A20–A27 (módulo 19A8) a desbloqueos de puertas (frontal/izq./dcha./escotilla) y columna luminosa (roja/verde/naranja). Los pilotos HL23–HL25 se agrupan en un bloque; la codificación cromática está indicada por el rótulo de cada lámpara."@es .

