@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaElectricoBorneDeSalidaDigital a ns1:Esquema ;
    rdfs:label "Borne de salida digital" ;
    ns1:textoExtracto "Los pilotos HL23–HL25 se agrupan en un bloque; la codificación cromática está indicada por el rótulo de cada lámpara." ;
    ns1:tieneComponente ns1:PilotoHL23_ec4b21c5a2,
        ns1:PilotoHL24,
        ns1:PilotoHL25_9e2ea69d86 .

ns1:EsquemaElectricoBorneDeSalidaDigital2 a ns1:Esquema ;
    rdfs:label "Borne de salida digital" ;
    ns1:textoExtracto "Salidas A00–A07 (módulo 19A21) que accionan contactores KA00–KA04 (motores de refrigeración brocha, limpieza, trasvase, extractor, grupo hidráulico) y una línea 'Activación freno desde PLC a PILZ'. Los contactores se dibujan con bobina A1/A2, pares de contactos y conexiones de potencia 1/L1…6/T3." ;
    ns1:tieneComponente ns1:ContactadorKA00,
        ns1:ContactadorKA01,
        ns1:ContactadorKA02,
        ns1:ContactadorKA03,
        ns1:ContactadorKA04 .

ns1:EsquemaElectricoEntradaAnaloga a ns1:Esquema ;
    rdfs:label "Entrada Analógica" ;
    ns1:textoExtracto "Bloque de entradas diferenciales E80/E82/E84/E86 (+/–) en el módulo 19A35. Canales reservados (etiqueta RESERVA) con polaridad indicada y referencias a bornes XT1; se representa la asignación +U/–U por canal." .

ns1:EsquemaElectricoPowerModule a ns1:Esquema ;
    rdfs:label "Power Module" ;
    ns1:textoExtracto "Módulo de alimentación de riel (19A20/1) para la isla de E/S: bornes US/UM/GND/FE y conexión a 24S/0S. Dos relés (27KA1/27KA2) se muestran alimentados desde las barras; flechas rojas/verde marcan positivo y retorno." ;
    ns1:tieneComponente ns1:Rele27KA1,
        ns1:Rele27KA2 .

ns1:PilotoHL33_0815c7507f a ns1:ComponenteElectrico ;
    rdfs:label "Piloto HL33" ;
    ns1:textoExtracto "Salidas A30–A37 (módulo 19A9) para marcha ciclo, enable puertas, apertura puerta, puesta en servicio, reset fuente drives, emergencia CNC. Se incluyen pilotos HL33/HL34 y contactos intermedios (26SBL1, 34SBL2), con retorno a 0S por línea verde." .

ns1:PilotoHL34_6e4943b6d5 a ns1:ComponenteElectrico ;
    rdfs:label "Piloto HL34" ;
    ns1:textoExtracto "Salidas A30–A37 (módulo 19A9) para marcha ciclo, enable puertas, apertura puerta, puesta en servicio, reset fuente drives, emergencia CNC. Se incluyen pilotos HL33/HL34 y contactos intermedios (26SBL1, 34SBL2), con retorno a 0S por línea verde." .

