ns1:EsquemaPanelOperadorVistaExterior a ns1:Esquema ;
    rdfs:label "Panel Operador Vista Exterior" ;
    ns1:ilustradoEn ns1:Pagina150 ;
    ns1:textoExtracto "Alzado del HMI con cotas (558×350 mm, separación de 79 mm entre elementos) y rotulado de teclas: Puesta en servicio, Paro servicio, Marcha ciclo, Setup, Enable puertas, Apertura puertas." .

ns1:EsquemaAlimentacionYComunicaciones a ns1:Esquema ;
    rdfs:label "External I/O" ;
    ns1:ilustradoEn ns1:Pagina153 ;
    ns1:textoExtracto "Esquema de alimentación y comunicaciones del 60U1: entradas 24VAN/0VAN/24EBC/0EBC, BUS IN (X21) y BUS OUT (X22) con latiguillo 61WAL1 (7,5 m); referencias a WCAT2/WCAT3 enlazan el tramo de red." .

ns1:EsquemaExternalIO a ns1:Esquema ;
    rdfs:label "External I/O" ;
    ns1:ilustradoEn ns1:Pagina153 ;
    ns1:textoExtracto "Lámina de asignación de conectores M12 del módulo 60U1. En el centro se dibuja el dispositivo con pines X01–X08 y, a ambos lados, columnas con Us/GND/FE/IN1…IN16 y referencias cruzadas (62.xx/63.xx/61.xx)." .

