ns1:ConectorM12_60U1 a ns1:ComponenteElectrico ;
    ns1:identificador "60U1" ;
    ns1:textoExtracto "Lámina de asignación de conectores M12 del módulo 60U1. En el centro se dibuja el dispositivo con pines X01–X08 y, a ambos lados, columnas con Us/GND/FE/IN1…IN16 y referencias cruzadas (62.xx/63.xx/61.xx)." ;
    ns1:tieneComponente ns1:PinX01,
        ns1:PinX02,
        ns1:PinX03,
        ns1:PinX04,
        ns1:PinX05,
        ns1:PinX06,
        ns1:PinX07,
        ns1:PinX08 .

