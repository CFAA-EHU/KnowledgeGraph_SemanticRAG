@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:EsquemaAlimentacionComunicaciones60U1 a ns1:Esquema ;
    ns1:textoExtracto "Esquema de alimentación y comunicaciones del 60U1: entradas 24VAN/0VAN/24EBC/0EBC, BUS IN (X21) y BUS OUT (X22) con latiguillo 61WAL1 (7,5 m); referencias a WCAT2/WCAT3 enlazan el tramo de red. Se muestran bloques X31/X32 con US/UA/GND." ;
    ns1:tieneComponente ns1:BloqueX31,
        ns1:BloqueX32,
        ns1:ConectorBUSIN_X21,
        ns1:ConectorBUSOUT_X22,
        ns1:Entrada0EBC,
        ns1:Entrada0VAN,
        ns1:Entrada24EBC,
        ns1:Entrada24VAN,
        ns1:Latiguillo61WAL1 .

ns1:ModuloDI16M12 a ns1:ComponenteElectrico ;
    ns1:identificador "AXL E EC DI16 M12" ;
    ns1:textoExtracto "External I/O (módulo DI16 M12)" ;
    ns1:tieneComponente ns1:ConectorM12_60U1 .

