@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BUSINOUTX21X22 a ns1:ComponenteElectrico ;
    rdfs:label "BUS IN/OUT X21/X22"@es ;
    ns1:textoExtracto "BUS IN/OUT (X21/X22)" .

ns1:ConectoresM12X01X08 a ns1:ComponenteElectrico ;
    rdfs:label "Conectores M12 X01–X08"@es ;
    ns1:textoExtracto "conectores M12 (X01–X08)" .

ns1:ConectoresX01X04 a ns1:ComponenteElectrico ;
    rdfs:label "Conectores X01–X04"@es ;
    ns1:textoExtracto "Cableado de IN1–IN8 (conectores X01–X04)" .

ns1:ConectoresX05X08 a ns1:ComponenteElectrico ;
    rdfs:label "Conectores X05–X08"@es ;
    ns1:textoExtracto "Cableado de IN9–IN16 (conectores X05–X08)" .

ns1:EsquemaExternalIO154 a ns1:Esquema ;
    rdfs:label "Esquemas eléctricos — External I/O (entradas 1–8 + lubricación)"@es ;
    ns1:textoExtracto "Se muestran bloques X31/X32 con US/UA/GND." .

ns1:EsquemaExternalIO155 a ns1:Esquema ;
    rdfs:label "Esquemas eléctricos — External I/O (entradas 9–16 + presiones/frenos)"@es ;
    ns1:textoExtracto "Cableado de IN9–IN16 (conectores X05–X08) y sensórica" .

ns1:EsquemaExternalIO156 a ns1:Esquema ;
    rdfs:label "External I/O (70U1) — AXL E EC DI8 DO4 2A M12 6P — 70U1 (vista de asignaciones)"@es ;
    ns1:textoExtracto "Vista del módulo descentralizado con su silueta centrada y columnas laterales que listan conectores M12 (X01–X08), BUS IN/OUT (X21/X22) y bornes de alimentación/masa (US/UA/GND/FE)." .

ns1:SensortipoBP710 a ns1:ComponenteElectrico ;
