    ns1:textoExtracto "BP710 (presión aire reglas lineales)" .

ns1:SensortipoBP711 a ns1:ComponenteElectrico ;
    rdfs:label "Sensor BP711"@es ;
    ns1:textoExtracto "BP711" .

ns1:SensortipoBP714 a ns1:ComponenteElectrico ;
    rdfs:label "Sensor BP714 (presostato)"@es ;
    ns1:textoExtracto "BP714 (presostato)" .

ns1:UnidadDeLubricacionWA800WE700 a ns1:ComponenteElectrico ;
    rdfs:label "Unidad de lubricación WA800/WE700"@es ;
    ns1:textoExtracto "Se representa la unidad de lubricación (WA800/WE700) con su E/S (24 V, OUT, 0 V)" .

