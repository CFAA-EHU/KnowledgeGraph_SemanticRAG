@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:BP710 a ns1:Sensor ;
    ns1:textoExtracto "Cableado de IN9–IN16 (conectores X05–X08) y sensórica: BP710 (presión aire reglas lineales), BP711, BP714 (presostato); entradas de mesa abajo, frenos MAYR (frontal/compensación IZQ), cadena derecha tensada." .

