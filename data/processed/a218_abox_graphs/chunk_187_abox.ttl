@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Esquemas y módulos principales
ex:Esquema_70U1_AlimentacionBus
    a ex:Esquema ;
    rdfs:label "Esquema de alimentación y bus del módulo 70U1" ;
    ex:textoExtracto "Esquema de cableado del 70U1: líneas en rojo para +24 V y en verde para 0 V, derivadas desde XT1 (24VAN/0VAN/24EBC/0EBC) hacia US/UA del módulo y relés auxiliares 27KA1/27KA2." ;
    ex:identificador "70U1" ;
    ex:detalladoEnEsquema ex:Modulo_70U1 .

ex:Esquema_70U1_EntradasDI
    a ex:Esquema ;
    rdfs:label "Esquema de entradas digitales (IN1–IN8) del módulo 70U1" ;
    ex:textoExtracto "Cuatro bloques con conectores M12 X01–X04 que agrupan entradas digitales (IN1–IN8). Se muestran sensores/actuadores asociados a frenos MAYR, tensado de cadena, niveles/pressostatos y señales de bloqueo/desbloqueo." ;
    ex:identificador "70U1_IN1-IN8" ;
    ex:detalladoEnEsquema ex:Modulo_70U1 .

ex:Esquema_70U1_SalidasDO
    a ex:Esquema ;
    rdfs:label "Esquema de salidas digitales (OUT1–OUT7) del módulo 70U1" ;
    ex:textoExtracto "Cuatro salidas a válvulas neumáticas/funciones: entrada general de aire, mesa arriba, mesa abajo y engrase. Cada conector (X05–X08) etiqueta OUT1/3/5/7 y FE/GND." ;
    ex:identificador "70U1_OUT1-OUT7" ;
    ex:detalladoEnEsquema ex:Modulo_70U1 .

ex:Modulo_70U1
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo de E/S externo 70U1" ;
    ex:textoExtracto "External I/O (70U1)" ;
    ex:identificador "70U1" ;
    ex:compuestoPor ex:Conector_XT1 ;
    ex:compuestoPor ex:Relay_27KA1, ex:Relay_27KA2 ;
    ex:compuestoPor ex:Conector_X21, ex:Conector_X22 ;
    ex:compuestoPor ex:Latiguillo_71WAL1 ;
    ex:compuestoPor ex:Conector_X01, ex:Conector_X02, ex:Conector_X03, ex:Conector_X04 ;
    ex:compuestoPor ex:Conector_X05, ex:Conector_X06, ex:Conector_X07, ex:Conector_X08 .

### Conectores y componentes eléctricos
ex:Conector_XT1
    a ex:ComponenteElectrico ;
    rdfs:label "Conector XT1 (24VAN/0VAN/24EBC/0EBC)" ;
    ex:textoExtracto "líneas en rojo para +24 V y en verde para 0 V, derivadas desde XT1 (24VAN/0VAN/24EBC/0EBC)" ;
    ex:identificador "XT1" .

ex:Relay_27KA1
    a ex:ComponenteElectrico ;
    rdfs:label "Relé auxiliar 27KA1" ;
    ex:textoExtracto "relés auxiliares 27KA1/27KA2" ;
    ex:identificador "27KA1" .

ex:Relay_27KA2
    a ex:ComponenteElectrico ;
    rdfs:label "Relé auxiliar 27KA2" ;
    ex:textoExtracto "relés auxiliares 27KA1/27KA2" ;
    ex:identificador "27KA2" .

ex:Conector_X21
    a ex:ComponenteElectrico ;
    rdfs:label "Conector BUS IN (X21)" ;
    ex:textoExtracto "conectores BUS IN/OUT (X21/X22)" ;
    ex:identificador "X21" .

ex:Conector_X22
    a ex:ComponenteElectrico ;
    rdfs:label "Conector BUS OUT (X22)" ;
    ex:textoExtracto "conectores BUS IN/OUT (X21/X22)" ;
    ex:identificador "X22" .

ex:Latiguillo_71WAL1
    a ex:ComponenteElectrico ;
    rdfs:label "Latiguillo de red 71WAL1" ;
    ex:textoExtracto "latiguillo de red (71WAL1)" ;
    ex:identificador "71WAL1" .

### Conectores de entradas digitales (IN1–IN8)
ex:Conector_X01
    a ex:ComponenteElectrico ;
    rdfs:label "Conector M12 X01 (entradas digitales IN1–IN2)" ;
    ex:textoExtracto "Cuatro bloques con conectores M12 X01–X04 que agrupan entradas digitales (IN1–IN8)" ;
    ex:identificador "X01" ;
    ex:ilustradoEn ex:Esquema_70U1_EntradasDI .

ex:Conector_X02
    a ex:ComponenteElectrico ;
    rdfs:label "Conector M12 X02 (entradas digitales IN3–IN4)" ;
    ex:textoExtracto "Cuatro bloques con conectores M12 X01–X04 que agrupan entradas digitales (IN1–IN8)" ;
    ex:identificador "X02" ;
    ex:ilustradoEn ex:Esquema_70U1_EntradasDI .

ex:Conector_X03
    a ex:ComponenteElectrico ;
    rdfs:label "Conector M12 X03 (entradas digitales IN5–IN6)" ;
    ex:textoExtracto "Cuatro bloques con conectores M12 X01–X04 que agrupan entradas digitales (IN1–IN8)" ;
    ex:identificador "X03" ;
    ex:ilustradoEn ex:Esquema_70U1_EntradasDI .

ex:Conector_X04
    a ex:ComponenteElectrico ;
    rdfs:label "Conector M12 X04 (entradas digitales IN7–IN8)" ;
    ex:textoExtracto "Cuatro bloques con conectores M12 X01–X04 que agrupan entradas digitales (IN1–IN8)" ;
    ex:identificador "X04" ;
    ex:ilustradoEn ex:Esquema_70U1_EntradasDI .

### Conectores de salidas digitales (OUT1–OUT7)
ex:Conector_X05
    a ex:ComponenteElectrico ;
    rdfs:label "Conector X05 (salida OUT1 - entrada general de aire)" ;
    ex:textoExtracto "Cuatro salidas a válvulas neumáticas/funciones: entrada general de aire [...] Cada conector (X05–X08) etiqueta OUT1/3/5/7" ;
    ex:identificador "X05" ;
    ex:ilustradoEn ex:Esquema_70U1_SalidasDO ;
    ex:controla ex:Valvula_YP801 .

ex:Conector_X06
    a ex:ComponenteElectrico ;
    rdfs:label "Conector X06 (salida OUT3 - mesa arriba)" ;
    ex:textoExtracto "mesa arriba [...] Cada conector (X05–X08) etiqueta OUT1/3/5/7" ;
    ex:identificador "X06" ;
    ex:ilustradoEn ex:Esquema_70U1_SalidasDO ;
    ex:controla ex:Valvula_YP803 .

ex:Conector_X07
    a ex:ComponenteElectrico ;
    rdfs:label "Conector X07 (salida OUT5 - mesa abajo)" ;
    ex:textoExtracto "mesa abajo [...] Cada conector (X05–X08) etiqueta OUT1/3/5/7" ;
    ex:identificador "X07" ;
    ex:ilustradoEn ex:Esquema_70U1_SalidasDO ;
    ex:controla ex:Valvula_YP805 .

ex:Conector_X08
    a ex:ComponenteElectrico ;
    rdfs:label "Conector X08 (salida OUT7 - engrase)" ;
    ex:textoExtracto "engrase [...] Cada conector (X05–X08) etiqueta OUT1/3/5/7" ;
    ex:identificador "X08" ;
    ex:ilustradoEn ex:Esquema_70U1_SalidasDO ;
    ex:controla ex:Valvula_YP807 .

### Actuadores neumáticos (válvulas)
ex:Valvula_YP801
    a ex:Actuador ;
    rdfs:label "Válvula neumática YP801 (entrada general de aire)" ;
    ex:textoExtracto "Cuatro salidas a válvulas neumáticas/funciones: entrada general de aire [...] símbolos YP80x" ;
    ex:identificador "YP801" .

ex:Valvula_YP803
    a ex:Actuador ;
    rdfs:label "Válvula neumática YP803 (mesa arriba)" ;
    ex:textoExtracto "mesa arriba [...] símbolos YP80x" ;
    ex:identificador "YP803" .

ex:Valvula_YP805
    a ex:Actuador ;
    rdfs:label "Válvula neumática YP805 (mesa abajo)" ;
    ex:textoExtracto "mesa abajo [...] símbolos YP80x" ;
    ex:identificador "YP805" .

ex:Valvula_YP807
    a ex:Actuador ;
    rdfs:label "Válvula neumática YP807 (engrase)" ;
    ex:textoExtracto "engrase [...] símbolos YP80x" ;
    ex:identificador "YP807" .