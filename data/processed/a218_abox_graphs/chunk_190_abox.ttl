@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaArmarioElectrico a ns1:Esquema ;
    rdfs:label "Esquema del Armario Eléctrico" ;
    ns1:ilustradoEn ns1:ComponenteElectrico_2a6f6ef4b1,
        ns1:ComponenteElectrico_f7941b32d9,
        ns1:SetaDeEmergencia ;
    ns1:textoExtracto "Alzado frontal y lateral del armario con dimensiones principales (alto 1800 mm, ancho 1200 mm, fondo 500 mm aprox.) y ubicación de elementos exteriores (selector, seta de emergencia, climatizador, pasamuros). Cotas y símbolos de seguridad se representan con flechas y etiquetas." .

ns1:EsquemaDisposicionEquipos a ns1:Esquema ;
    rdfs:label "Esquema de Disposición de Equipos" ;
    ns1:ilustradoEn ns1:ComponenteElectrico_2a6f6ef4b1,
        ns1:FuenteSITOP,
        ns1:ModuloPhoenix ;
    ns1:textoExtracto "Vista interior del armario con disposición y cotas entre carriles y equipos: se distinguen seccionadores, contactores, fuentes SITOP, módulos Phoenix, relés, climatizador y pasacables. Líneas de cota (mm) y rótulos de referencia (p. ej., 19A1…19A9, 27KAx) dan jerarquía y ubicación precisa." .

ns1:EsquemaGrafcetCicloBrochadora a ns1:Esquema ;
    rdfs:label "Secuencia de Ciclo - GRAFCET" ;
    ns1:textoExtracto "Diagrama de etapas/acciones numeradas (0–15) para la broachadora: origen, subir/girar/bajar mesa giratoria, movimiento del carro de tracción, avance/retroceso de cepillos y fin de ciclo. Flechas y ramas paralelas representan transiciones y condiciones; cada etapa se anota con su precondición (110.x/111.x)." .

ns1:EsquemaPlacaCaracteristicas a ns1:Esquema ;
    rdfs:label "Esquema de Placa de Características" ;
    ns1:textoExtracto "Placa ilustrada con logotipo y campos: potencia instalada (80 kVA), alimentación (3×380 V 50 Hz), control (220 V/24 V =), año, protección (125 A, 10 kA) y datos del fabricante. Diseño con recuadros y tipografía clara a modo de etiqueta industrial." .

ns1:ComponenteElectrico_f7941b32d9 a ns1:ComponenteElectrico ;
    rdfs:label "Selector" ;
    ns1:textoExtracto "Alzado frontal y lateral del armario con dimensiones principales (alto 1800 mm, ancho 1200 mm, fondo 500 mm aprox.) y ubicación de elementos exteriores (selector, seta de emergencia, climatizador, pasamuros)." .

ns1:FuenteSITOP a ns1:ComponenteElectrico ;
    rdfs:label "Fuente SITOP" ;
    ns1:textoExtracto "Vista interior del armario con disposición y cotas entre carriles y equipos: se distinguen seccionadores, contactores, fuentes SITOP, módulos Phoenix, relés, climatizador y pasacables." .

ns1:ModuloPhoenix a ns1:ComponenteElectrico ;
    rdfs:label "Módulo Phoenix" ;
    ns1:textoExtracto "Vista interior del armario con disposición y cotas entre carriles y equipos: se distinguen seccionadores, contactores, fuentes SITOP, módulos Phoenix, relés, climatizador y pasacables." .

ns1:SetaDeEmergencia a ns1:ComponenteElectrico ;
    rdfs:label "Seta de Emergencia" ;
    ns1:textoExtracto "Alzado frontal y lateral del armario con dimensiones principales (alto 1800 mm, ancho 1200 mm, fondo 500 mm aprox.) y ubicación de elementos exteriores (selector, seta de emergencia, climatizador, pasamuros)." .

ns1:ComponenteElectrico_2a6f6ef4b1 a ns1:ComponenteElectrico ;
    rdfs:label "Climatizador",
        "Contactador",
        "Pasacable",
        "Relé",
        "Seccionador" ;
    ns1:textoExtracto "Vista interior del armario con disposición y cotas entre carriles y equipos: se distinguen seccionadores, contactores, fuentes SITOP, módulos Phoenix, relés, climatizador y pasacables." .

