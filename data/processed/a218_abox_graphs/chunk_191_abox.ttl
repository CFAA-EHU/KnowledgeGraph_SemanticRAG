@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Esquema_PlanoConexiones_XT1M
    a                       ex:Esquema ;
    rdfs:label              "Plano de conexiones — XT1M"@es ;
    ex:identificador        "XT1M" ;
    ex:textoExtracto         "Diagrama matricial del bloque XT1M con filas etiquetadas U/V/W para motores (refrigerante, trasvase, extractor, grupo hidráulico) y climatizador. Cada borne se representa por casillas alineadas con su función y referencia de hoja; es un esquema de conexiones (no tabla de datos)."@es .

ex:Esquema_PlanoConexiones_XT1
    a                       ex:Esquema ;
    rdfs:label              "Plano de conexiones — XT1"@es ;
    ex:identificador        "XT1" ;
    ex:textoExtracto         "Vista de bornes XT1 con asignaciones a 0V/24V de distintos sistemas (API, CNC, PNL, S, SAFE) y señales de puertas, columna luminosa y motores. La disposición por columnas facilita seguir conexiones desde etiquetas (0S, 24E, 24S, etc.) hasta funciones de máquina."@es .

ex:Sistema_Electrico_XT1
    a                       ex:Sistema ;
    rdfs:label              "Sistema eléctrico XT1"@es ;
    ex:detalladoEnEsquema   ex:Esquema_PlanoConexiones_XT1 ;
    ex:textoExtracto         "Continuación de XT1 con líneas dedicadas a alimentaciones (24API/24CNC/24E/24EBC/24PNL/24S/24SAFE) y vínculos a servomotores (mesa e izquierda). Se resaltan bornes de 'ALIMENTACIÓN ENTRADAS/SALIDAS/Safety'."@es .

ex:ComponenteElectrico_Borne_1104
    a                       ex:ComponenteElectrico ;
    rdfs:label              "Bornero 1104"@es ;
    ex:identificador        "1104" ;
    ex:textoExtracto         "El diagrama ordena por grupos funcionales y muestra numeración correlativa (1104, 1117, 1204, etc.) para localizar físicamente cada borne."@es ;
    ex:compuestoPor          ex:Sistema_Electrico_XT1 .

ex:ComponenteElectrico_Borne_1117
    a                       ex:ComponenteElectrico ;
    rdfs:label              "Bornero 1117"@es ;
    ex:identificador        "1117" ;
    ex:textoExtracto         "El diagrama ordena por grupos funcionales y muestra numeración correlativa (1104, 1117, 1204, etc.) para localizar físicamente cada borne."@es ;
    ex:compuestoPor          ex:Sistema_Electrico_XT1 .

ex:ComponenteElectrico_Borne_1204
    a                       ex:ComponenteElectrico ;
    rdfs:label              "Bornero 1204"@es ;
    ex:identificador        "1204" ;
    ex:textoExtracto         "El diagrama ordena por grupos funcionales y muestra numeración correlativa (1104, 1117, 1204, etc.) para localizar físicamente cada borne."@es ;
    ex:compuestoPor          ex:Sistema_Electrico_XT1 .

ex:ComponenteElectrico_ColumnaLuminosa
    a                       ex:ComponenteElectrico ;
    rdfs:label              "Columna luminosa"@es ;
    ex:textoExtracto         "Vista de bornes XT1 con asignaciones a [...] señales de puertas, columna luminosa y motores."@es ;
    ex:compuestoPor          ex:Sistema_Electrico_XT1 .

ex:ComponenteElectrico_ServomotorMesa
    a                       ex:ComponenteElectrico ;
    rdfs:label              "Servomotor de mesa"@es ;
    ex:textoExtracto         "Continuación de XT1 con líneas dedicadas a [...] vínculos a servomotores (mesa e izquierda)."@es ;
    ex:compuestoPor          ex:Sistema_Electrico_XT1 .

ex:ComponenteElectrico_ServomotorIzquierda
    a                       ex:ComponenteElectrico ;
    rdfs:label              "Servomotor izquierdo"@es ;
    ex:textoExtracto         "Continuación de XT1 con líneas dedicadas a [...] vínculos a servomotores (mesa e izquierda)."@es ;
