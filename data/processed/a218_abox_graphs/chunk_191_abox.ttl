ex:ComponenteElectrico_Alimentacion_24API
    a                       ex:ComponenteElectrico ;
    rdfs:label              "Alimentación 24API"@es ;
    ex:identificador         "24API" ;
    ex:textoExtracto         "Continuación de XT1 con líneas dedicadas a alimentaciones (24API/24CNC/24E/24EBC/24PNL/24S/24SAFE)."@es ;
    ex:alimenta             ex:Sistema_Electrico_XT1 .

