@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BorneXT2 a ns1:ComponenteElectrico ;
    rdfs:label "Borne XT2"@es ;
    ns1:documentadoEn ns1:EsquemaPlanoConexionesXT2_XTP1 ;
    ns1:textoExtracto "Bloques de bornes XT2 y XTP1 con asignaciones a 1204 (tensión 24 V) y enlaces T0M20/T1M21." .

ns1:BorneXTP1 a ns1:ComponenteElectrico ;
    rdfs:label "Borne XTP1"@es ;
    ns1:documentadoEn ns1:EsquemaPlanoConexionesXT2_XTP1 ;
    ns1:textoExtracto "Bloques de bornes XT2 y XTP1 con asignaciones a 1204 (tensión 24 V) y enlaces T0M20/T1M21." .

ns1:EntradaAnalogicaE80 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada Analógica E80"@es ;
    ns1:documentadoEn ns1:PlanoDeConexionesXT13 ;
    ns1:textoExtracto "Bloque XT1.3 para entradas E26–E57 y analógicas E80–E86, incluyendo señales de estado (feedback frenos, setup, enable puertas), proceso (presencia de papel, niveles, caudal, mesa) y safety." .

ns1:EntradaAnalogicaE86 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada Analógica E86"@es ;
    ns1:documentadoEn ns1:PlanoDeConexionesXT13 ;
    ns1:textoExtracto "Bloque XT1.3 para entradas E26–E57 y analógicas E80–E86, incluyendo señales de estado (feedback frenos, setup, enable puertas), proceso (presencia de papel, niveles, caudal, mesa) y safety." .

ns1:EntradaE26 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada E26"@es ;
    ns1:documentadoEn ns1:PlanoDeConexionesXT13 ;
    ns1:textoExtracto "Bloque XT1.3 para entradas E26–E57 y analógicas E80–E86, incluyendo señales de estado (feedback frenos, setup, enable puertas), proceso (presencia de papel, niveles, caudal, mesa) y safety." .

ns1:EntradaE57 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada E57"@es ;
    ns1:documentadoEn ns1:PlanoDeConexionesXT13 ;
    ns1:textoExtracto "Bloque XT1.3 para entradas E26–E57 y analógicas E80–E86, incluyendo señales de estado (feedback frenos, setup, enable puertas), proceso (presencia de papel, niveles, caudal, mesa) y safety." .

ns1:EsquemaPlanoConexionesXT1_3_XT2 a ns1:Esquema ;
    rdfs:label "Plano de conexiones — XT1.3 y XT2"@es ;
    ns1:textoExtracto "Vista de transición entre bornes XT1.3 y XT2: se agrupan líneas SAFE (emergencia CH1/CH2, puertas, freno), salidas de mando (puesta en servicio, marcha ciclo) y tomas de corriente." .

ns1:PlanoDeConexionesXT144 a ns1:Esquema ;
    rdfs:label "Plano de conexiones — XT1 (4/4)"@es ;
    ns1:textoExtracto "Último tramo de XT1 con salidas A20–A37 (desbloqueos de puertas, columna luminosa, marcha ciclo, reset drives, enable, etc.) y entradas E00–E17." .

ns1:EsquemaPlanoConexionesXT2_XTP1 a ns1:Esquema ;
    rdfs:label "Plano de conexiones — XT2 y XTP1"@es ;
    ns1:textoExtracto "Bloques de bornes XT2 y XTP1 con asignaciones a 1204 (tensión 24 V) y enlaces T0M20/T1M21." .

ns1:PlanoDeConexionesXT13 a ns1:Esquema ;
    rdfs:label "Plano de conexiones — XT1.3"@es ;
    ns1:textoExtracto "Bloque XT1.3 para entradas E26–E57 y analógicas E80–E86, incluyendo señales de estado (feedback frenos, setup, enable puertas), proceso (presencia de papel, niveles, caudal, mesa) y safety." .

