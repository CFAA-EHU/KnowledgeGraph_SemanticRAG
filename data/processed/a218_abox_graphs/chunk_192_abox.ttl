@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Esquema_PlanoConexiones_XT1
    a ex:Esquema ;
    rdfs:label "Plano de conexiones — XT1 (4/4)"@es ;
    ex:textoExtracto "El diagrama ordena por grupos funcionales y muestra numeración correlativa (1104, 1117, 1204, etc.) para localizar físicamente cada borne."@es ;
    ex:identificador "XT1 (4/4)" .

ex:Esquema_PlanoConexiones_XT1.3
    a ex:Esquema ;
    rdfs:label "Plano de conexiones — XT1.3"@es ;
    ex:textoExtracto "Último tramo de XT1 con salidas A20–A37 (desbloqueos de puertas, columna luminosa, marcha ciclo, reset drives, enable, etc.) y entradas E00–E17. La jerarquía separa claramente salidas (Axx) e inputs (Exx), con leyenda de función por cada borne."@es ;
    ex:identificador "XT1.3" .

ex:Esquema_PlanoConexiones_XT1.3_XT2
    a ex:Esquema ;
    rdfs:label "Plano de conexiones — XT1.3 y XT2"@es ;
    ex:textoExtracto "Vista de transición entre bornes XT1.3 y XT2: se agrupan líneas SAFE (emergencia CH1/CH2, puertas, freno), salidas de mando (puesta en servicio, marcha ciclo) y tomas de corriente."@es ;
    ex:identificador "XT1.3-XT2" .

ex:Esquema_PlanoConexiones_XT2_XTP1
    a ex:Esquema ;
    rdfs:label "Plano de conexiones — XT2 y XTP1"@es ;
    ex:textoExtracto "Bloques de bornes XT2 y XTP1 con asignaciones a 1204 (tensión 24 V) y enlaces T0M20/T1M21. Estructura de casillas alineadas por hilera que representa físicamente cada posición de borne y su destino."@es ;
    ex:identificador "XT2-XTP1" .

ex:Sistema_Bornes_XT1
    a ex:Sistema ;
    rdfs:label "Bloque de bornes XT1"@es ;
    ex:textoExtracto "Último tramo de XT1 con salidas A20–A37 (desbloqueos de puertas, columna luminosa, marcha ciclo, reset drives, enable, etc.) y entradas E00–E17."@es ;
    ex:detalladoEnEsquema ex:Esquema_PlanoConexiones_XT1 ;
    ex:detalladoEnEsquema ex:Esquema_PlanoConexiones_XT1.3 .

ex:Sistema_Bornes_XT1.3
    a ex:Sistema ;
    rdfs:label "Bloque de bornes XT1.3"@es ;
    ex:textoExtracto "Bloque XT1.3 para entradas E26–E57 y analógicas E80–E86, incluyendo señales de estado (feedback frenos, setup, enable puertas), proceso (presencia de papel, niveles, caudal, mesa) y safety."@es ;
    ex:detalladoEnEsquema ex:Esquema_PlanoConexiones_XT1.3 ;
    ex:detalladoEnEsquema ex:Esquema_PlanoConexiones_XT1.3_XT2 .

ex:Sistema_Bornes_XT2
    a ex:Sistema ;
    rdfs:label "Bloque de bornes XT2"@es ;
    ex:textoExtracto "Bloques de bornes XT2 y XTP1 con asignaciones a 1204 (tensión 24 V) y enlaces T0M20/T1M21."@es ;
    ex:detalladoEnEsquema ex:Esquema_PlanoConexiones_XT1.3_XT2 ;
    ex:detalladoEnEsquema ex:Esquema_PlanoConexiones_XT2_XTP1 .

ex:Sistema_Bornes_XTP1
    a ex:Sistema ;
    rdfs:label "Bloque de bornes XTP1"@es ;
    ex:textoExtracto "Bloques de bornes XT2 y XTP1 con asignaciones a 1204 (tensión 24 V) y enlaces T0M20/T1M21."@es ;
    ex:detalladoEnEsquema ex:Esquema_PlanoConexiones_XT2_XTP1 .

ex:ComponenteElectrico_ColumnaLuminosa
    a ex:ComponenteElectrico ;
    rdfs:label "Columna luminosa (salida A20–A37)"@es ;
    ex:textoExtracto "desbloqueos de puertas, columna luminosa, marcha ciclo"@es ;
    ex:documentadoEn ex:Esquema_PlanoConexiones_XT1.3 .

ex:ComponenteElectrico_SalidaA20_A37
    a ex:ComponenteElectrico ;
    rdfs:label "Salidas A20–A37 (desbloqueos, marcha ciclo, reset drives)"@es ;
    ex:textoExtracto "salidas A20–A37 (desbloqueos de puertas, columna luminosa, marcha ciclo, reset drives, enable, etc.)"@es ;
    ex:documentadoEn ex:Esquema_PlanoConexiones_XT1.3 .

ex:ComponenteElectrico_EntradasE00_E17
    a ex:ComponenteElectrico ;
    rdfs:label "Entradas E00–E17"@es ;
    ex:textoExtracto "entradas E00–E17"@es ;
    ex:documentadoEn ex:Esquema_PlanoConexiones_XT1.3 .

ex:ComponenteElectrico_EntradasE26_E57
    a ex:ComponenteElectrico ;
    rdfs:label "Entradas digitales E26–E57"@es ;
    ex:textoExtracto "entradas E26–E57"@es ;
    ex:documentadoEn ex:Esquema_PlanoConexiones_XT1.3_XT2 .

ex:ComponenteElectrico_EntradasAnalogicasE80_E86
    a ex:ComponenteElectrico ;
    rdfs:label "Entradas analógicas E80–E86"@es ;
    ex:textoExtracto "analógicas E80–E86, incluyendo señales de estado (feedback frenos, setup, enable puertas), proceso (presencia de papel, niveles, caudal, mesa)"@es ;
    ex:documentadoEn ex:Esquema_PlanoConexiones_XT1.3_XT2 .

ex:ComponenteElectrico_LineasSAFE_Emergencia
    a ex:ComponenteElectrico ;
    rdfs:label "Líneas SAFE (emergencia CH1/CH2, puertas, freno)"@es ;
    ex:textoExtracto "líneas SAFE (emergencia CH1/CH2, puertas, freno)"@es ;
    ex:documentadoEn ex:Esquema_PlanoConexiones_XT1.3_XT2 .

ex:ComponenteElectrico_Alimentacion1204_24V
    a ex:ComponenteElectrico ;
    rdfs:label "Alimentación 1204 (24 V)"@es ;
    ex:textoExtracto "asignaciones a 1204 (tensión 24 V)"@es ;
    ex:documentadoEn ex:Esquema_PlanoConexiones_XT2_XTP1 ;
    ex:alimenta ex:Sistema_Bornes_XT2 ;
    ex:alimenta ex:Sistema_Bornes_XTP1 .