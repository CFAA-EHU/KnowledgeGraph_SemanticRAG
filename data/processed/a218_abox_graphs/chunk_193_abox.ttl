ex:BrochadoraElectromecanica_A218_Rashem_7x3000x500
    a                     ex:Maquina ;
    rdfs:label            "Brochadora electromecánica de exteriores A218/RASHEM 7×3000×500"@es ;
    ex:identificador      "A218/RASHEM 7×3000×500" ;
    ex:textoExtracto      "BROCHADORA ELECTROMECÁNICA DE EXTERIORES — A218/ RASHEM 7×3000×500"@es .

ex:Esquema_CasillasConexion_Brochadora_A218
    a                     ex:Esquema ;
    rdfs:label            "Estructura de casillas alineadas por hilera para bornes de la brochadora A218"@es ;
    ex:textoExtracto      "Estructura de casillas alineadas por hilera que representa físicamente cada posición de borne y su destino, útil para montaje y verificación de cableado."@es ;
    ex:detalladoEnEsquema ex:BrochadoraElectromecanica_A218_Rashem_7x3000x500 .

ex:ManualTecnico_Brochadora_A218
    a                     ex:Manual ;
    rdfs:label            "Manual técnico de la brochadora electromecánica A218/RASHEM"@es ;
    ex:identificador      "A218" ;
    ex:textoExtracto      "Lámina de identificación del manual con el logotipo del fabricante, denominación de la máquina y datos de contacto. Diseño limpio con bloques de texto centrados, actuando como carátula final del dossier técnico."@es ;
    ex:documentadoEn      ex:BrochadoraElectromecanica_A218_Rashem_7x3000x500 .