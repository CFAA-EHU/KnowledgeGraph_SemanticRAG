@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Esquema_Electrico_1 a ns1:Esquema ;
    ns1:compuestoPor ns1:BROCHADORA_ELECTROMECANICA_A218_RASHEM_7x3000x500 ;
    ns1:textoExtracto "Estructura de casillas alineadas por hilera que representa físicamente cada posición de borne y su destino, útil para montaje y verificación de cableado." .

ns1:Portada_Manual_1 a ns1:InterfazUsuario ;
    ns1:compuestoPor ns1:BROCHADORA_ELECTROMECANICA_A218_RASHEM_7x3000x500 ;
    ns1:textoExtracto "Lámina de identificación del manual con el logotipo del fabricante, denominación de la máquina y datos de contacto. Diseño limpio con bloques de texto centrados, actuando como carátula final del dossier técnico." .

ns1:BROCHADORA_ELECTROMECANICA_A218_RASHEM_7x3000x500 a ns1:Maquina ;
    rdfs:label "BROCHADORA ELECTROMECANICA DE EXTERIORES — A218/ RASHEM 7×3000×500" ;
    ns1:textoExtracto "BROCHADORA ELECTROMECANICA DE EXTERIORES — A218/ RASHEM 7×3000×500" .

