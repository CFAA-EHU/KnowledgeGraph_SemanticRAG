@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    rdfs:label "BROCHADORA ELECTROMECÁNICA DE EXTERIORES" ;
    ns1:detalladoEnEsquema ns1:EsquemaCableadoBornes ;
    ns1:textoExtracto "BROCHADORA ELECTROMECÁNICA DE EXTERIORES — A218/ RASHEM 7×3000×500" .

ns1:EsquemaCableadoBornes a ns1:Esquema ;
    rdfs:label "Estructura de casillas alineadas por hilera que representa físicamente cada posición de borne y su destino" ;
    ns1:textoExtracto "Estructura de casillas alineadas por hilera que representa físicamente cada posición de borne y su destino, útil para montaje y verificación de cableado." .

