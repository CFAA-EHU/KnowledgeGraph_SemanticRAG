ns1:AvisoSeguridadInterruptorGeneralArmarioElectrico a ns1:AvisoSeguridad ;
    rdfs:label "Aviso seguridad interruptor general armario eléctrico" ;
    ns1:textoExtracto "Composición con primer plano del seccionador, luz de presencia de tensión y pictograma de máquina consignada; el encuadre y flechas muestran posiciones ON/OFF y uso de candado." .

ns1:AvisoSeguridadPlataformaCambioHerramienta a ns1:AvisoSeguridad ;
    rdfs:label "Aviso seguridad plataforma cambio herramienta" ;
    ns1:textoExtracto "se señalan plataforma, trampilla central y micro de seguridad 25SQ1; flechas describen la zona de intervención para cambio del plato divisor." .

ns1:AvisoSeguridadPuertasControladas a ns1:AvisoSeguridad ;
    rdfs:label "Aviso seguridad puertas controladas" ;
    ns1:textoExtracto "Vista frontal y laterales con microinterruptores EUCHNER etiquetados (23SQ1, 24SQ1, 24SQ2); flechas relacionan cada puerta con su sensor, indicando enclavamiento y parada por apertura." .

ns1:AvisoSeguridad_045b32c51b a ns1:AvisoSeguridad ;
    rdfs:label "Precaución" ;
    ns1:textoExtracto "Precaución  SI NO SE TIENE EN CUENTA ESTA INDICACIÓN, O SI LAS INSTRUCCIONES QUE FIGURAN EN ELLA NO SE REALIZAN CORRECTAMENTE, PUEDEN PRODUCIRSE DAÑOS Y/O LA DESTRUCCIÓN DE PARTES DE LA MÁQUINA." .

ns1:AvisoSeguridad_0b8f4981be a ns1:AvisoSeguridad ;
    rdfs:label "Aviso seguridad pulsadores parada emergencia" ;
    ns1:textoExtracto "Fotografías de detalle de los pulsadores en armario y botonera; rótulos indican su función y localización para detención inmediata." .

ns1:AvisoSeguridad_18d9f487f0 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre presión de cables" ;
    ns1:mitigaRiesgo ns1:AvisoSeguridad_0dc31e015f ;
    ns1:textoExtracto "LA PRESIÓN DE LOS CABLES NO DEBE ACTUAR SOBRE HUSILLOS, GUÍAS, CAJAS DE CABLES U OTRAS ZONAS DEFORMABLES." .

ns1:AvisoSeguridad_1c813d5a11 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre placas de advertencia" ;
    ns1:mitigaRiesgo ns1:MaquinaBrochadora ;
    ns1:textoExtracto "EN NINGÚN CASO SE DEBEN RETIRAR LAS PLACAS DE ADVERTENCIA O INSTRUCCIONES DE LA MÁQUINA." .

ns1:AvisoSeguridad_3e2a866415 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de Seguridad" ;
    ns1:mitigaRiesgo ns1:MaquinaM_quinasEKIN ;
    ns1:textoExtracto "Todas las máquinas EKIN, S. Coop. han sido fabricadas siguiendo todas las normas de seguridad en diseño, fabricación y montaje para evitar accidentes durante su funcionamiento; no obstante, se debe tener precaución y considerar ciertas instrucciones de seguridad." .

ns1:AvisoSeguridad_44e856a637 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de Seguridad para Uso No Acorde" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_243776b443 ;
    ns1:textoExtracto "TODO USO DIVERGENTE DEL ESPECIFICADO EN LA DOCUMENTACIÓN DE LA MÁQUINA SE CONSIDERA 'NO ACORDE CON LAS ESPECIFICACIONES' Y DE ÉL PUEDE DERIVARSE RIESGO DE LESIONES O MUERTE DE LOS USUARIOS O DE TERCERAS PERSONAS, O DAÑOS A LA MÁQUINA Y A OTROS BIENES." .

ns1:AvisoSeguridad_52ca7fc788 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de apertura de puertas durante el servicio automático" ;
    ns1:textoExtracto "NO SE DEBEN ABRIR LAS PUERTAS DE LA MÁQUINA DURANTE EL SERVICIO AUTOMÁTICO." .

ns1:AvisoSeguridad_6fdf9ffcf8 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de apertura de paneles durante el servicio automático" ;
    ns1:textoExtracto "LA APERTURA DE ESTOS PANELES DURANTE EL SERVICIO AUTOMÁTICO NO PROVOCA UNA PARADA DE LA MÁQUINA, LO QUE PUEDE OCASIONAR UN PELIGRO DE DAÑOS PERSONALES." .

ns1:AvisoSeguridad_81d8145c8b a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para manipulación y transporte" ;
    ns1:textoExtracto "Panel infográfico de advertencias con iconografía (STOP, triángulos de peligro) y bloques de texto en rojo que jerarquizan riesgos y condiciones de elevación/transporte." .

ns1:AvisoSeguridad_8a9019f3bb a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para volteo de máquina" ;
    ns1:textoExtracto "Secuencia 1–2–3 con flechas verticales y curva que ilustran el volteo desde vertical a horizontal con dos grúas; vistas frontal y lateral para claridad espacial." .

ns1:AvisoSeguridad_bdb686d9df a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre gafas" ;
    ns1:textoExtracto "EL OPERARIO DEBE EMPLEAR GAFAS DE SEGURIDAD Y GUANTES DURANTE EL TRABAJO CON LA MÁQUINA EN FUNCIONAMIENTO." .

ns1:AvisoSeguridad_cbfa997d72 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre depósitos de aceite" ;
    ns1:mitigaRiesgo ns1:AvisoSeguridad_792eb79f50 ;
    ns1:textoExtracto "ES MUY RECOMENDABLE QUE DURANTE EL TRANSPORTE DE LA MÁQUINA LOS DEPÓSITOS DE ACEITE SE ENCUENTREN VACÍOS." .

ns1:AvisoSeguridad_cf291489c9 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre eslingas homologadas" ;
    ns1:mitigaRiesgo ns1:AvisoSeguridad_318b26b6a6 ;
    ns1:textoExtracto "ES IMPERATIVO ADEMÁS UTILIZAR ESLINGAS HOMOLOGADAS CON DECLARACIÓN 'CE' DE CONFORMIDAD, PARA EVITAR SITUACIONES DE RIESGO POR POSIBLES ROTURAS DE ESLINGAS DEFECTUOSAS." .

ns1:AvisoSeguridad_d355ea55f9 a ns1:AvisoSeguridad ;
    rdfs:label "Peligro" ;
    ns1:textoExtracto "Peligro  SI NO SE TIENE EN CUENTA ESTA ADVERTENCIA, O NO SE LLEVAN A CABO CORRECTAMENTE LAS INSTRUCCIONES QUE FIGURAN EN ELLA, PUEDEN PRODUCIRSE LESIONES PERSONALES GRAVES, INCLUSO MORTALES." .

ns1:AvisoSeguridad_ed0c336f54 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre indumentaria" ;
    ns1:textoExtracto "Los cabellos largos deben estar recogidos adecuadamente. Para realizar los trabajos de mantenimiento conservando la seguridad personal, se debe emplear la indumentaria que a continuación se describe y la que el personal de mantenimiento considere adecuada en cada tipo de trabajo a realizar." .

ns1:AvisosDeSeguridad a ns1:AvisoSeguridad ;
    rdfs:label "Avisos de seguridad" ;
    ns1:textoExtracto "Paneles infográficos con pictograma 'STOP' y avisos de seguridad (placas, enclavamientos, manipulación segura, uso de medios de elevación)." .

ns1:AvisosDeSeguridadParaConservarElAceiteUsado a ns1:AvisoSeguridad ;
    rdfs:label "Avisos de seguridad para conservar el aceite usado" ;
    ns1:textoExtracto "Almacenar el aceite usado en condiciones satisfactorias, evitando la mezcla con otros residuos peligrosos, así como con agua y otros residuos oleaginosos." .

ns1:AvisosDeSeguridadParaInstalaciones a ns1:AvisoSeguridad ;
    rdfs:label "Avisos de seguridad para instalaciones" ;
    ns1:textoExtracto "Disponer de instalaciones que permitan la conservación del aceite usado hasta su recogida y que sean accesibles a los vehículos encargados de efectuarla." .

