ns1:Maquina_Transporte_61 a ns1:Maquina ;
    ns1:textoExtracto "QUE DURANTE EL TRANSPORTE DE LA MÁQUINA LOS DEPÓSITOS DE ACEITE SE ENCUENTREN VACÍOS. EN CASO DE QUE NO SE PUDIERAN VACIAR, PRESTAR ESPECIAL CUIDADO EN QUE LOS TAPONES DE CIERRE SE ENCUENTREN BIEN CERRADOS. Para proceder con el transporte la máquina hay que voltearla y colocarla en posición horizontal. Previamente, hay que soltar las plataformas laterales, el armario eléctrico, el grupo hidráulico y el equipo de refrigeración (soltar también la bomba trasera que va conectada al zócalo)." ;
    ns1:tieneComponente ns1:ArmarioElectrico_Transporte_61,
        ns1:BombaTrasera_Transporte_61,
        ns1:EquipoRefrigeracion_Transporte_61,
        ns1:GrupoHidraulico_Transporte_61,
        ns1:PlataformasLaterales_Transporte_61 .

