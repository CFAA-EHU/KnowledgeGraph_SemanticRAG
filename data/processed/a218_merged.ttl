ns1:AvisoSeguridad_01549742be a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre elementos con tensión" ;
    ns1:mitigaRiesgo ns1:PuestaEnTensionAntesDeLeerInstruccionesDeSeguridad ;
    ns1:textoExtracto "AÚN SIN LA MÁQUINA EN TENSIÓN EXISTEN ELEMENTOS COMO 1 TOMA DE CORRIENTE EN EL INTERIOR DEL ARMARIO Y OTRA EN EL EXTERIOR DEL PANEL PRINCIPAL, Y LA ILUMINACIÓN DEL ARMARIO QUE SÍ ESTÁN CON TENSIÓN DE 220VAC." .

ns1:AvisoSeguridad_045b32c51b a ns1:AvisoSeguridad ;
    rdfs:label "Precaución" ;
    ns1:textoExtracto "Precaución  SI NO SE TIENE EN CUENTA ESTA INDICACIÓN, O SI LAS INSTRUCCIONES QUE FIGURAN EN ELLA NO SE REALIZAN CORRECTAMENTE, PUEDEN PRODUCIRSE DAÑOS Y/O LA DESTRUCCIÓN DE PARTES DE LA MÁQUINA." .

ns1:AvisoSeguridad_0dc31e015f a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre verificar equilibrio" ;
    ns1:mitigaRiesgo ns1:MaquinaBrochadoraElectromecanicaExteriorA218 ;
    ns1:textoExtracto "ES CONVENIENTE LEVANTAR INICIALMENTE LA MÁQUINA SÓLO UNOS POCOS CENTÍMETROS DEL SUELO, PARA VERIFICAR QUE ESTÁ BIEN EQUILIBRADA." .

ns1:AvisoSeguridad_18d9f487f0 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre presión de cables" ;
    ns1:mitigaRiesgo ns1:MaquinaBrochadoraElectromecanicaExteriorA218 ;
    ns1:textoExtracto "LA PRESIÓN DE LOS CABLES NO DEBE ACTUAR SOBRE HUSILLOS, GUÍAS, CAJAS DE CABLES U OTRAS ZONAS DEFORMABLES." .

ns1:AvisoSeguridad_2e364f904b a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre depósitos de aceite" ;
    ns1:mitigaRiesgo ns1:MaquinaBrochadoraElectromecanicaExteriorA218 ;
    ns1:textoExtracto "ES MUY RECOMENDABLE QUE DURANTE EL TRANSPORTE DE LA MÁQUINA LOS DEPÓSITOS DE ACEITE SE ENCUENTREN VACÍOS. EN CASO DE QUE NO SE PUDIERAN VACIAR, PRESTAR ESPECIAL CUIDADO EN QUE LOS TAPONES DE CIERRE SE ENCUENTREN BIEN." .

ns1:AvisoSeguridad_318b26b6a6 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre tablones en puntos de contacto" ;
    ns1:mitigaRiesgo ns1:MaquinaBrochadoraElectromecanicaExteriorA218 ;
    ns1:textoExtracto "ASIMISMO, DEBEN COLOCARSE TABLONES O TRAPOS EN TODOS LOS PUNTOS DE CONTACTO ENTRE ESLINGAS Y MÁQUINA, PARA EVITAR EVENTUALES DAÑOS EN LA MISMA." .

ns1:AvisoSeguridad_3549fde65b a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de derechos de autor" ;
    ns1:textoExtracto "DERECHOS DE AUTOR Los derechos de autor de este manual están reservados a EKIN S. Coop. Queda terminantemente prohibida la: reproducción o alteración, difusión, divulgación, parcial o total de todos los documentos incluidos en el manual, sin la previa autorización de esta empresa." .

ns1:AvisoSeguridad_47a571b15c a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de emergencia" ;
    ns1:textoExtracto "Siempre atendiendo las indicaciones de la ventana de avisos: Con máquina en tensión, asegurarse de que ninguna emergencia esté pulsada." .

ns1:AvisoSeguridad_554049bb9d a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de riesgo de apertura en servicio automático" ;
    ns1:textoExtracto "Ilustración explodida del carenado con flechas a paneles no controlados; recuadros indican su posición y el riesgo de apertura en servicio automático" .

ns1:AvisoSeguridad_a9feb1943c a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de parada correcta" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_60b4bdcf3d ;
    ns1:textoExtracto "LOS TRABAJOS DE MANTENIMIENTO Y DE LIMPIEZA SE DEBEN REALIZAR MIENTRAS LA MAQUINA SE HAYA PARADO CORRECTAMENTE Y SE HAYAN BLOQUEADO MEDIANTE MEDIDAS PERTINENTES AQUELLAS FUNCIONES QUE PUEDAN SUPONER UN PELIGRO" .

ns1:AvisoSeguridad_cf291489c9 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre eslingas homologadas" ;
    ns1:mitigaRiesgo ns1:MaquinaBrochadoraElectromecanicaExteriorA218 ;
    ns1:textoExtracto "ES IMPERATIVO ADEMÁS UTILIZAR ESLINGAS HOMOLOGADAS CON DECLARACIÓN 'CE' DE CONFORMIDAD, PARA EVITAR SITUACIONES DE RIESGO POR POSIBLES ROTURAS DE ESLINGAS DEFECTUOSAS." .

ns1:AvisoSeguridad_d355ea55f9 a ns1:AvisoSeguridad ;
    rdfs:label "Peligro" ;
    ns1:textoExtracto "Peligro  SI NO SE TIENE EN CUENTA ESTA ADVERTENCIA, O NO SE LLEVAN A CABO CORRECTAMENTE LAS INSTRUCCIONES QUE FIGURAN EN ELLA, PUEDEN PRODUCIRSE LESIONES PERSONALES GRAVES, INCLUSO MORTALES." .

ns1:AvisoSeguridad_db945be8e2 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de consignación de la máquina" ;
    ns1:mitigaRiesgo ns1:ManipulacionInvoluntariaDelInterruptorGeneral ;
    ns1:textoExtracto "Para realizar labores de mantenimiento es necesario consignar la máquina; para consignar la máquina hay que situar el interruptor general en posición OFF y colocar un candado que evite a terceras personas situarlo en la posición ON de forma involuntaria." .

ns1:AvisosDeSeguridadGenerales a ns1:AvisoSeguridad ;
    rdfs:label "Avisos de seguridad generales" ;
    ns1:textoExtracto "Paneles infográficos con pictograma 'STOP' y avisos de seguridad (placas, enclavamientos, manipulación segura, uso de medios de elevación). Diseño en bloques rojos con texto blanco para resaltar severidad." .

ns1:AvisosDeSeguridadParaElUsoDeLaMaquina a ns1:AvisoSeguridad ;
    rdfs:label "Avisos de seguridad para el uso de la máquina" ;
    ns1:mitigaRiesgo ns1:AbrirPuertasDeArmariosElectricos,
        ns1:EmplearHerramientasDiferentesALasEspecificadasPorEKINSCOOP,
        ns1:PonerEnFuncionamientoLaMaquinaSinVerificarQueNoHayNadieEnSuInterior,
        ns1:PonerEnMarchaElCicloAutomaticoDeLaMaquinaSinVerificarElUtilDeAmarre,
        ns1:SobrepasarLaCapacidadDeTrabajoDeLaMaquina ;
    ns1:textoExtracto "En ningún caso se debe poner en marcha el ciclo automático de la máquina sin antes asegurarse de que el útil de amarre está adaptado a las piezas que se van a brochar. LAS PUERTAS DE LOS ARMARIOS ELÉCTRICOS DEBEN ESTAR CERRADAS Y BLOQUEADAS. ABRIR LAS PUERTAS SUPONE EXPONERSE A TENSIONES ELÉCTRICAS PELIGROSAS." .

ns1:AvisosDeSeguridadParaElUsoDeLaMaquina_dc18fdb95b a ns1:AvisoSeguridad ;
    rdfs:label "Avisos de seguridad para el uso de la máquina" ;
    ns1:textoExtracto "Conjunto de recuadros 'STOP' que enfatizan aplicación prevista, cumplimiento del manual, cierre de armarios eléctricos, no sobrepasar capacidad y verificación de interior; iconografía y color refuerzan las advertencias." .

ns1:AvisosDeSeguridadSobrePlacasYEnclavamientos a ns1:AvisoSeguridad ;
    rdfs:label "Avisos de seguridad sobre placas y enclavamientos" ;
    ns1:textoExtracto "EN NINGÚN CASO SE DEBEN RETIRAR LAS PLACAS DE ADVERTENCIA O INSTRUCCIONES DE LA MÁQUINA. LOS ENCLAVAMIENTOS DE SEGURIDAD NO DEBEN ANULARSE." .

