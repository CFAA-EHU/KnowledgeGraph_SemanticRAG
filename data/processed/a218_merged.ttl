ns1:MaquinaBrochadoraA218 a ns1:Maquina ;
    rdfs:label "Brochadora A218 / RASHEM - 7x3000x500",
        "Máquina Brochadora" ;
    ns1:textoExtracto "Este manual proporciona la información necesaria para el mantenimiento de la Brochadora A218 / RASHEM - 7x3000x500" .

ns1:PUESTASERVICIO a ns1:AccionProhibida ;
    rdfs:label "PUESTA SERVICIO" ;
    ns1:textoExtracto "PARADA DE EMERGENCIA - PUESTA SERVICIO - PARO SERVICIO - MARCHA CICLO - MODO SETUP - HABILITAR PUERTAS - APERTURA PUERTAS - Puesta Habilitar Servicio Puertas Parada de Apertura Emergencia Puertas Modo Paro Marcha Setup Servicio Ciclo" .

ns1:PantallaMovimientosMaquina a ns1:InterfazUsuario ;
    rdfs:label "Pantalla Movimientos Máquina",
        "Pantalla de Movimientos máquina" ;
    ns1:textoExtracto "Esta pantalla permite controlar los movimientos de la máquina. El carro de tracción se puede llevar a tres posiciones (superior, intermedio e inferior), mientras que la mesa giratoria se puede subir/bajar y girar." .

ns1:PulsadorParadaEmergencia a ns1:ComponenteElectrico ;
    rdfs:label "Pulsador de parada de emergencia",
        "Pulsadores de parada de emergencia" ;
    ns1:textoExtracto "Pulsadores de parada de emergencia" .

ns1:SistemaPinonCremallera a ns1:Sistema ;
    rdfs:label "Sistema Piñón Cremallera" ;
    ns1:controla ns1:ComponenteElectrico_64757187f7 ;
    ns1:textoExtracto "Esta máquina es una brochadora de exteriores de un único puesto, con movimiento de carro porta-piezas (la brocha permanece fija) accionado por un sistema piñón cremallera con un servomotor que desarrolla una fuerza máxima de 70 kNw a una velocidad de 40 m/min." .

ns1:EsquemaEsquemasDeFluidos a ns1:Esquema ;
    rdfs:label "Esquemas de Fluidos" ;
    ns1:textoExtracto "Página 20 - Servomotor IZQUIERDA AXD2, Página 19 - Servomotor DERECHA AXD2, Página 18 - Servomotor MESA AXD1" .

ns1:EsquemaPlanosMecanicos a ns1:Esquema ;
    rdfs:label "Planos Mecánicos" ;
    ns1:textoExtracto "Página 10 - Seccionador principal, Página 11 - Alimentación general, Página 12 - Alimentacion 24VDC, Página 13 - Climatizador armario, Página 14 - Motores de C.A" .

ns1:PlanoDeConexionesXT13 a ns1:Esquema ;
    rdfs:label "Plano de conexiones — XT1.3"@es ;
    ns1:textoExtracto "Bloque XT1.3 para entradas E26–E57 y analógicas E80–E86, incluyendo señales de estado (feedback frenos, setup, enable puertas), proceso (presencia de papel, niveles, caudal, mesa) y safety." .

ns1:ElementoSeguridad a ns1:ElementoSeguridad ;
    rdfs:label "Elementos de seguridad de la máquina" ;
    ns1:textoExtracto "EL ESTADO DE LOS ELEMENTOS DE SEGURIDAD DE LA MÁQUINA SE DEBE VERIFICAR REGULARMENTE PARA GARANTIZAR LA SEGURIDAD DE LA MISMA." .

