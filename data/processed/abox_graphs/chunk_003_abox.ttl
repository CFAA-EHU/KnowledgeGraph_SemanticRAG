@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Manual rdfs:subClassOf owl:Thing .
ex:Capitulo rdfs:subClassOf owl:Thing .
ex:InformacionGeneral rdfs:subClassOf owl:Thing .
ex:DescripcionComponente rdfs:subClassOf owl:Thing .
ex:FuncionamientoComponente rdfs:subClassOf owl:Thing .
ex:MantenimientoPreventivo rdfs:subClassOf owl:Thing .
ex:ListaRepuestos rdfs:subClassOf owl:Thing .
ex:Proveedor rdfs:subClassOf owl:Thing .
ex:SeguridadOperario rdfs:subClassOf owl:Thing .
ex:SeguridadMaquina rdfs:subClassOf owl:Thing .
ex:SeguridadMaterialesDesechables rdfs:subClassOf owl:Thing .
ex:Plano rdfs:subClassOf owl:Thing .
ex:Esquema rdfs:subClassOf owl:Thing .
ex:InstruccionSeguridad rdfs:subClassOf owl:Thing .

ex:tieneCapitulo a owl:ObjectProperty ;
    rdfs:domain ex:Manual ;
    rdfs:range ex:Capitulo .

ex:tieneInformacionGeneral a owl:ObjectProperty ;
    rdfs:domain ex:Capitulo ;
    rdfs:range ex:InformacionGeneral .

ex:tieneDescripcionComponente a owl:ObjectProperty ;
    rdfs:domain ex:Capitulo ;
    rdfs:range ex:DescripcionComponente .

ex:tieneFuncionamientoComponente a owl:ObjectProperty ;
    rdfs:domain ex:Capitulo ;
    rdfs:range ex:FuncionamientoComponente .

ex:tieneMantenimientoPreventivo a owl:ObjectProperty ;
    rdfs:domain ex:Capitulo ;
    rdfs:range ex:MantenimientoPreventivo .

ex:tieneListaRepuestos a owl:ObjectProperty ;
    rdfs:domain ex:Capitulo ;
    rdfs:range ex:ListaRepuestos .

ex:tieneProveedor a owl:ObjectProperty ;
    rdfs:domain ex:ListaRepuestos ;
    rdfs:range ex:Proveedor .

ex:tieneSeguridadOperario a owl:ObjectProperty ;
    rdfs:domain ex:Capitulo ;
    rdfs:range ex:SeguridadOperario .

ex:tieneSeguridadMaquina a owl:ObjectProperty ;
    rdfs:domain ex:Capitulo ;
    rdfs:range ex:SeguridadMaquina .

ex:tieneSeguridadMaterialesDesechables a owl:ObjectProperty ;
    rdfs:domain ex:Capitulo ;
    rdfs:range ex:SeguridadMaterialesDesechables .

ex:tienePlano a owl:ObjectProperty ;
    rdfs:domain ex:Capitulo ;
    rdfs:range ex:Plano .

ex:tieneEsquema a owl:ObjectProperty ;
    rdfs:domain ex:Capitulo ;
    rdfs:range ex:Esquema .

ex:tieneInstruccionSeguridad a owl:ObjectProperty ;
    rdfs:domain ex:Capitulo ;
    rdfs:range ex:InstruccionSeguridad .

ex:numeroCapitulo a owl:DatatypeProperty ;
    rdfs:domain ex:Capitulo ;
    rdfs:range xsd:integer .

ex:tituloCapitulo a owl:DatatypeProperty ;
    rdfs:domain ex:Capitulo ;
    rdfs:range xsd:string .

ex:contenidoManual a owl:DatatypeProperty ;
    rdfs:domain ex:Manual ;
    rdfs:range xsd:string .

ex:advertenciaManual a owl:DatatypeProperty ;
    rdfs:domain ex:Manual ;
    rdfs:range xsd:string .