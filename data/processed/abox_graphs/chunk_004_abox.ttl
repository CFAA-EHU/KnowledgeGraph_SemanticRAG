@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Manual rdfs:subClassOf owl:Thing .
ex:Brochadora rdfs:subClassOf owl:Thing .
ex:Fabricante rdfs:subClassOf owl:Thing .
ex:Capitulo rdfs:subClassOf owl:Thing .
ex:Modelo rdfs:subClassOf owl:Thing .
ex:Contenido rdfs:subClassOf owl:Thing .
ex:Pagina rdfs:subClassOf owl:Thing .
ex:Fichero rdfs:subClassOf owl:Thing .
ex:Figura rdfs:subClassOf owl:Thing .

ex:tieneNombre rdfs:domain ex:Manual ; rdfs:range xsd:string .
ex:tieneNumero rdfs:domain ex:Manual ; rdfs:range xsd:integer .
ex:tieneModelo rdfs:domain ex:Manual ; rdfs:range ex:Modelo .
ex:tieneContenido rdfs:domain ex:Manual ; rdfs:range ex:Contenido .
ex:tienePagina rdfs:domain ex:Manual ; rdfs:range ex:Pagina .
ex:tieneFichero rdfs:domain ex:Manual ; rdfs:range ex:Fichero .
ex:tieneFigura rdfs:domain ex:Manual ; rdfs:range ex:Figura .
ex:tieneFabricante rdfs:domain ex:Manual ; rdfs:range ex:Fabricante .
ex:tieneCapitulo rdfs:domain ex:Manual ; rdfs:range ex:Capitulo .