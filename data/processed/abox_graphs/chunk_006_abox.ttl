@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DocumentoTecnicoIlustracionesManual a ns1:DocumentoTecnico ;
    rdfs:label "Ilustraciones" ;
    ns1:textoExtracto "Los dibujos, esquemas de componentes y de conjuntos incluidos en este manual pueden estar representados parcialmente, sin acotar y simplificados. Son meramente informativos y carecen de validez contractual." .

