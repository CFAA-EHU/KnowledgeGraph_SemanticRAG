@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:DerechoDeAutor a owl:Class ;
    rdfs:label "Derecho de Autor"@es ;
    rdfs:comment "Clase que representa los derechos de autor del manual."@es .

ex:Empresa a owl:Class ;
    rdfs:label "Empresa"@es ;
    rdfs:comment "Clase que representa una empresa."@es .

ex:Manual a owl:Class ;
    rdfs:label "Manual"@es ;
    rdfs:comment "Clase que representa un manual técnico."@es .

ex:Alteracion a owl:Class ;
    rdfs:label "Alteración"@es ;
    rdfs:comment "Clase que representa una alteración en la información."@es .

ex:Reproduccion a owl:Class ;
    rdfs:label "Reproducción"@es ;
    rdfs:comment "Clase que representa la reproducción de documentos."@es .

ex:Divulgacion a owl:Class ;
    rdfs:label "Divulgación"@es ;
    rdfs:comment "Clase que representa la divulgación de información."@es .

ex:Autorizacion a owl:Class ;
    rdfs:label "Autorización"@es ;
    rdfs:comment "Clase que representa una autorización."@es .

ex:Desarrollo a owl:Class ;
    rdfs:label "Desarrollo"@es ;
    rdfs:comment "Clase que representa el desarrollo de una empresa."@es .

ex:Calidad a owl:Class ;
    rdfs:label "Calidad"@es ;
    rdfs:comment "Clase que representa la calidad de un producto o servicio."@es .

ex:tieneDerechoDeAutor a owl:ObjectProperty ;
    rdfs:domain ex:Manual ;
    rdfs:range ex:DerechoDeAutor ;
    rdfs:comment "Propiedad que relaciona un manual con sus derechos de autor."@es .

ex:tieneEmpresa a owl:ObjectProperty ;
    rdfs:domain ex:Manual ;
    rdfs:range ex:Empresa ;
    rdfs:comment "Propiedad que relaciona un manual con la empresa que lo posee."@es .

ex:prohibe a owl:ObjectProperty ;
    rdfs:domain ex:DerechoDeAutor ;
    rdfs:range ex:Reproduccion ;
    rdfs:comment "Propiedad que indica que los derechos de autor prohíben la reproducción."@es .

ex:prohibe a owl:ObjectProperty ;
    rdfs:domain ex:DerechoDeAutor ;
    rdfs:range ex:Alteracion ;
    rdfs:comment "Propiedad que indica que los derechos de autor prohíben la alteración."@es .

ex:prohibe a owl:ObjectProperty ;
    rdfs:domain ex:DerechoDeAutor ;
    rdfs:range ex:Divulgacion ;
    rdfs:comment "Propiedad que indica que los derechos de autor prohíben la divulgación."@es .

ex:requiere a owl:ObjectProperty ;
    rdfs:domain ex:Reproduccion ;
    rdfs:range ex:Autorizacion ;
    rdfs:comment "Propiedad que indica que la reproducción requiere autorización."@es .

ex:requiere a owl:ObjectProperty ;
    rdfs:domain ex:Alteracion ;
    rdfs:range ex:Autorizacion ;
    rdfs:comment "Propiedad que indica que la alteración requiere autorización."@es .

ex:requiere a owl:ObjectProperty ;
    rdfs:domain ex:Divulgacion ;
    rdfs:range ex:Autorizacion ;
    rdfs:comment "Propiedad que indica que la divulgación requiere autorización."@es .

ex:puedeSufrir a owl:ObjectProperty ;
    rdfs:domain ex:Manual ;
    rdfs:range ex:Alteracion ;
    rdfs:comment "Propiedad que indica que un manual puede sufrir alteraciones."@es .

ex:enVirtudDe a owl:ObjectProperty ;
    rdfs:domain ex:Alteracion ;
    rdfs:range ex:Desarrollo ;
    rdfs:comment "Propiedad que indica que las alteraciones son en virtud del desarrollo."@es .

ex:busca a owl:ObjectProperty ;
    rdfs:domain ex:Desarrollo ;
    rdfs:range ex:Calidad ;
    rdfs:comment "Propiedad que indica que el desarrollo busca mejorar la calidad."@es .