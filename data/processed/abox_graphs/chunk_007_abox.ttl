@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_DifusionManual a ns1:AccionProhibida ;
    rdfs:label "Difusión o divulgación del manual" ;
    ns1:cumpleNormativa ns1:Manual_Broaching_7 ;
    ns1:textoExtracto "Queda terminantemente prohibida la: difusión • divulgación" .

ns1:AccionProhibida_ReproduccionManual a ns1:AccionProhibida ;
    rdfs:label "Reproducción o alteración del manual" ;
    ns1:cumpleNormativa ns1:Manual_Broaching_7 ;
    ns1:textoExtracto "Queda terminantemente prohibida la: reproducción o alteración" .

ns1:Empresa_EKIN_S_Coop a ns1:Empresa ;
    rdfs:label "EKIN S. Coop" ;
    ns1:identificador "EKIN S. Coop" ;
    ns1:textoExtracto "Los derechos de autor de este manual están reservados a EKIN S. Coop." .

ns1:Manual_Broaching_7 a ns1:Manual ;
    rdfs:label "Manual de Broaching" ;
    ns1:documentadoEn ns1:Empresa_EKIN_S_Coop ;
    ns1:textoExtracto "DERECHOS DE AUTOR Los derechos de autor de este manual están reservados a EKIN S. Coop." .

