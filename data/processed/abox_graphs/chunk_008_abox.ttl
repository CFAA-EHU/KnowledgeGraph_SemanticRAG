@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:DeclaracionCE a owl:Class ;
    rdfs:label "Declaración CE"@es ;
    rdfs:comment "Declaración de conformidad sobre máquinas según la Directiva 2006/42/CE"@es .

ex:Directiva a owl:Class ;
    rdfs:label "Directiva"@es ;
    rdfs:comment "Normativa que regula la conformidad de las máquinas"@es .

ex:Maquina a owl:Class ;
    rdfs:label "Máquina"@es ;
    rdfs:comment "Equipo o dispositivo mecánico"@es .

ex:tieneDirectiva a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:Directiva ;
    rdfs:label "tiene directiva"@es .

ex:DeclaracionCEDeConformidad a owl:Class ;
    rdfs:label "Declaración de Conformidad"@es ;
    rdfs:comment "Documento que certifica la conformidad de una máquina con la normativa vigente"@es .

ex:tieneDeclaracionCE a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:DeclaracionCEDeConformidad ;
    rdfs:label "tiene declaración CE"@es .

ex:Directiva2006_42_CE a owl:Class ;
    rdfs:label "Directiva 2006/42/CE"@es ;
    rdfs:comment "Directiva de la Unión Europea sobre la conformidad de las máquinas"@es .