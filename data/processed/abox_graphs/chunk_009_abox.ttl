@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Direccion a owl:Class ;
    rdfs:label "Dirección" ;
    rdfs:comment "Clase que representa la dirección de la empresa." .

ex:Telefono a owl:Class ;
    rdfs:label "Teléfono" ;
    rdfs:comment "Clase que representa el número de teléfono de la empresa." .

ex:Fax a owl:Class ;
    rdfs:label "Fax" ;
    rdfs:comment "Clase que representa el número de fax de la empresa." .

ex:Email a owl:Class ;
    rdfs:label "Email" ;
    rdfs:comment "Clase que representa el correo electrónico de la empresa." .

ex:Empresa a owl:Class ;
    rdfs:label "Empresa" ;
    rdfs:comment "Clase que representa la empresa." .

ex:Declaracion a owl:Class ;
    rdfs:label "Declaración" ;
    rdfs:comment "Clase que representa la declaración de responsabilidad de la empresa." .

ex:tieneDireccion a owl:ObjectProperty ;
    rdfs:domain ex:Empresa ;
    rdfs:range ex:Direccion ;
    rdfs:comment "Propiedad que relaciona una empresa con su dirección." .

ex:tieneTelefono a owl:ObjectProperty ;
    rdfs:domain ex:Empresa ;
    rdfs:range ex:Telefono ;
    rdfs:comment "Propiedad que relaciona una empresa con su número de teléfono." .

ex:tieneFax a owl:ObjectProperty ;
    rdfs:domain ex:Empresa ;
    rdfs:range ex:Fax ;
    rdfs:comment "Propiedad que relaciona una empresa con su número de fax." .

ex:tieneEmail a owl:ObjectProperty ;
    rdfs:domain ex:Empresa ;
    rdfs:range ex:Email ;
    rdfs:comment "Propiedad que relaciona una empresa con su correo electrónico." .

ex:tieneDeclaracion a owl:ObjectProperty ;
    rdfs:domain ex:Empresa ;
    rdfs:range ex:Declaracion ;
    rdfs:comment "Propiedad que relaciona una empresa con su declaración de responsabilidad." .

ex:nombreDireccion a owl:DatatypeProperty ;
    rdfs:domain ex:Direccion ;
    rdfs:range xsd:string ;
    rdfs:comment "Propiedad que representa el nombre de la dirección." .

ex:numeroTelefono a owl:DatatypeProperty ;
    rdfs:domain ex:Telefono ;
    rdfs:range xsd:string ;
    rdfs:comment "Propiedad que representa el número de teléfono." .

ex:numeroFax a owl:DatatypeProperty ;
    rdfs:domain ex:Fax ;
    rdfs:range xsd:string ;
    rdfs:comment "Propiedad que representa el número de fax." .

ex:direccionEmail a owl:DatatypeProperty ;
    rdfs:domain ex:Email ;
    rdfs:range xsd:string ;
    rdfs:comment "Propiedad que representa la dirección de correo electrónico." .

ex:textoDeclaracion a owl:DatatypeProperty ;
    rdfs:domain ex:Declaracion ;
    rdfs:range xsd:string ;
    rdfs:comment "Propiedad que representa el texto de la declaración." .