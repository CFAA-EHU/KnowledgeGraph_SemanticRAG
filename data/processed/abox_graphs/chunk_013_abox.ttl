@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Directiva rdfs:subClassOf owl:Thing .
ex:NormaArmonizada rdfs:subClassOf owl:Thing .
ex:Persona rdfs:subClassOf owl:Thing .
ex:Empresa rdfs:subClassOf owl:Thing .

ex:cumpleConDisposicion a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:Directiva .

ex:tieneNormaArmonizada a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:NormaArmonizada .

ex:tieneSignatario a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:Persona .

ex:tieneFecha a owl:DatatypeProperty ;
    rdfs:domain ex:Persona ;
    rdfs:range xsd:date .

ex:tieneCargo a owl:DatatypeProperty ;
    rdfs:domain ex:Persona ;
    rdfs:range xsd:string .

ex:tieneNombre a owl:DatatypeProperty ;
    rdfs:domain ex:Persona ;
    rdfs:range xsd:string .

ex:tieneEmpresa a owl:ObjectProperty ;
    rdfs:domain ex:Persona ;
    rdfs:range ex:Empresa .

ex:tieneNombreEmpresa a owl:DatatypeProperty ;
    rdfs:domain ex:Empresa ;
    rdfs:range xsd:string .