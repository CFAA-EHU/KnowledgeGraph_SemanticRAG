@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InstruccionesSeguridad_2_1 a ns1:Directiva ;
    ns1:textoExtracto "INSTRUCCIONES DE SEGURIDAD Todas las máquinas EKIN, S. Coop. han sido fabricadas siguiendo todas las normas de seguridad en diseño, fabricación y montaje para evitar accidentes durante su funcionamiento; no obstante, se debe tener precaución y considerar ciertas instrucciones de seguridad." .

ns1:Maquina_EKIN a ns1:Maquina ;
    rdfs:label "EKIN" ;
    ns1:textoExtracto "Todas las máquinas EKIN, S. Coop. han sido fabricadas siguiendo todas las normas de seguridad en diseño, fabricación y montaje para evitar accidentes durante su funcionamiento" .

