@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix base: <https://vocab.cfaa.eus/broaching/base#> .
@prefix seguridad: <https://vocab.cfaa.eus/broaching/seguridad#> .
@prefix empresa: <https://vocab.cfaa.eus/broaching/empresa#> .

base:Maquina a owl:Class ;
    rdfs:label "Máquina" ;
    rdfs:comment "Clase base para máquinas EKIN, S. Coop." .

base:InstruccionSeguridad a owl:Class ;
    rdfs:label "Instrucción de Seguridad" ;
    rdfs:comment "Instrucciones de seguridad para el funcionamiento de las máquinas EKIN, S. Coop." .

base:DepartamentoAsistenciaCliente a owl:Class ;
    rdfs:label "Departamento de Asistencia al Cliente" ;
    rdfs:comment "Departamento de asistencia al cliente de EKIN, S. Coop." .

seguridad:cumpleNormasSeguridad a owl:ObjectProperty ;
    rdfs:label "cumple normas de seguridad" ;
    rdfs:domain base:Maquina ;
    rdfs:range base:InstruccionSeguridad .

seguridad:requierePrecaucion a owl:ObjectProperty ;
    rdfs:label "requiere precaución" ;
    rdfs:domain base:Maquina ;
    rdfs:range base:InstruccionSeguridad .

seguridad:evitarAccidentes a owl:ObjectProperty ;
    rdfs:label "evitar accidentes" ;
    rdfs:domain base:Maquina ;
    rdfs:range base:InstruccionSeguridad .

seguridad:consultarDepartamentoAsistencia a owl:ObjectProperty ;
    rdfs:label "consultar departamento de asistencia" ;
    rdfs:domain base:InstruccionSeguridad ;
    rdfs:range base:DepartamentoAsistenciaCliente .

empresa:fabricadoPor a owl:ObjectProperty ;
    rdfs:label "fabricado por" ;
    rdfs:domain base:Maquina ;
    rdfs:range empresa:Empresa .

empresa:Empresa a owl:Class ;
    rdfs:label "Empresa" ;
    rdfs:comment "Clase para empresas fabricantes de máquinas." .

empresa:EKIN a empresa:Empresa ;
    rdfs:label "EKIN, S. Coop." ;
    rdfs:comment "Empresa fabricante de máquinas EKIN, S. Coop." .