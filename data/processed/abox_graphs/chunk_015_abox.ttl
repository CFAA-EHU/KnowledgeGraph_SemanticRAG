ex:PrevencionAccidentes a owl:Class ;
    rdfs:label "Prevención de accidentes"@es .

ex:ProteccionMedioAmbiente a owl:Class ;
    rdfs:label "Protección del medio ambiente"@es .

ex:verificarEstado a owl:ObjectProperty ;
    rdfs:label "verificar estado"@es ;
    rdfs:domain ex:ElementoDeSeguridad ;
    rdfs:range ex:Maquina .

ex:debeRespetar a owl:ObjectProperty ;
    rdfs:label "debe respetar"@es ;
    rdfs:domain ex:PersonalInstruido ;
    rdfs:range ex:ManualDeInstrucciones .

ex:debeSerInstruidoEn a owl:ObjectProperty ;
    rdfs:label "debe ser instruido en"@es ;
    rdfs:domain ex:PersonalInstruido ;
    rdfs:range ex:Maquina .

