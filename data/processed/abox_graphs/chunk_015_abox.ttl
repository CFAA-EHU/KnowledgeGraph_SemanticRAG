@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:MedidaDeProteccion a owl:Class ;
    rdfs:label "Medida de protección"@es .

ex:ElementoDeSeguridad a owl:Class ;
    rdfs:label "Elemento de seguridad"@es .

ex:PersonalInstruido a owl:Class ;
    rdfs:label "Personal instruido"@es .

ex:ManualDeInstrucciones a owl:Class ;
    rdfs:label "Manual de instrucciones"@es .

ex:CartelDeAdvertencia a owl:Class ;
    rdfs:label "Cartel de advertencia"@es .

ex:PlacaDeAdvertencia a owl:Class ;
    rdfs:label "Placa de advertencia"@es .

ex:PersonaCompetente a owl:Class ;
    rdfs:label "Persona competente"@es .

ex:DepartamentoHerramientas a owl:Class ;
    rdfs:label "Departamento de herramientas"@es .

ex:PiezaDeRecambio a owl:Class ;
    rdfs:label "Pieza de recambio"@es .

ex:ZonaDeTrabajo a owl:Class ;
    rdfs:label "Zona de trabajo"@es .

ex:MedidaDeSeguridad a owl:Class ;
    rdfs:label "Medida de seguridad"@es .

ex:Modificacion a owl:Class ;
    rdfs:label "Modificación"@es .

ex:Procedimiento a owl:Class ;
    rdfs:label "Procedimiento"@es .

ex:Operacion a owl:Class ;
    rdfs:label "Operación"@es .

ex:Maquina a owl:Class ;
    rdfs:label "Máquina"@es .

ex:EKIN a owl:Class ;
    rdfs:label "EKIN"@es .

ex:FormacionPersonal a owl:Class ;
    rdfs:label "Formación del personal"@es .

ex:Peligro a owl:Class ;
    rdfs:label "Peligro"@es .

ex:PrendaDeProteccion a owl:Class ;
    rdfs:label "Prenda de protección"@es .

ex:Accion a owl:Class ;
