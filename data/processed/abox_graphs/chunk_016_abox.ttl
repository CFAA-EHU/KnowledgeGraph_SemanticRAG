@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:CarroMaquina16 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "NO PONER EN MARCHA EL CARRO DE LA MÁQUINA SIN ASEGURARSE DE QUE LAS PIEZAS A BROCHAR ESTAN CORRECTAMENTE" .

ns1:EnclavamientoSeguridad16 a ns1:ElementoSeguridad ;
    ns1:textoExtracto "LOS ENCLAVAMIENTOS DE SEGURIDAD NO DEBEN ANULARSE." .

ns1:PlacaAdvertencia16 a ns1:AvisoSeguridad ;
    ns1:textoExtracto "EN NINGÚN CASO SE DEBEN RETIRAR LAS PLACAS DE ADVERTENCIA O INSTRUCCIONES DE LA MÁQUINA." .

