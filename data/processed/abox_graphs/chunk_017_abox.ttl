@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:EnclavamientoDeSeguridad a owl:Class ;
    rdfs:label "Enclavamiento de seguridad"@es .

ex:PiezaABrochar a owl:Class ;
    rdfs:label "Pieza a brochar"@es .

ex:UtilDeAmarre a owl:Class ;
    rdfs:label "Util de amarre"@es .

ex:Fluido a owl:Class ;
    rdfs:label "Fluido"@es .

ex:AceiteDeCorte a owl:Class ;
    rdfs:label "Aceite de corte"@es .

ex:Taladrina a owl:Class ;
    rdfs:label "Taladrina"@es .

ex:DefensaDeLaMaquina a owl:Class ;
    rdfs:label "Defensa de la máquina"@es .

ex:ElementoEnMovimiento a owl:Class ;
    rdfs:label "Elemento en movimiento"@es .

ex:MedioDeElevacion a owl:Class ;
    rdfs:label "Medio de elevación"@es .

ex:Grúa a owl:Class ;
    rdfs:label "Grúa"@es .

ex:Pluma a owl:Class ;
    rdfs:label "Pluma"@es .

ex:LegislacionVigente a owl:Class ;
    rdfs:label "Legislación vigente"@es .

ex:noDebeAnularse a owl:ObjectProperty ;
    rdfs:domain ex:EnclavamientoDeSeguridad ;
    rdfs:range xsd:boolean .

ex:noDebePonerseEnMarchaSinAsegurarseDeQue a owl:ObjectProperty ;
    rdfs:domain ex:CarroDeLaMaquina ;
    rdfs:range ex:PiezaABrochar .

ex:noDebenEmplearse a owl:ObjectProperty ;
    rdfs:domain ex:Fluido ;
    rdfs:range xsd:boolean .

ex:debeSolicitarse a owl:ObjectProperty ;
    rdfs:domain ex:Fluido ;
    rdfs:range ex:MedidasDeSeguridad .

ex:debenEstarSituadasEnSuPosicionCorrecta a owl:ObjectProperty ;
    rdfs:domain ex:DefensaDeLaMaquina ;
    rdfs:range xsd:boolean .

ex:noDebePonerseLasManosUObjetosMasAllaDeLasDefensasDuranteElFuncionamientoDeLaMaquina a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range xsd:boolean .

ex:debenEmplearse a owl:ObjectProperty ;
    rdfs:domain ex:Pieza ;
    rdfs:range ex:MedioDeElevacion .

ex:debenEfectuarseSiguiendoLaLegislacionVigenteEnElPaisDeUtilizacion a owl:ObjectProperty ;
    rdfs:domain ex:Operacion ;
    rdfs:range ex:LegislacionVigente .

ex:tieneEfectoPerjudicialParaLaSalud a owl:ObjectProperty ;
    rdfs:domain ex:Fluido ;
    rdfs:range xsd:boolean .

ex:tienePeso a owl:ObjectProperty ;
    rdfs:domain ex:Pieza ;
    rdfs:range xsd:decimal .

ex:tieneMedidasDeSeguridad a owl:ObjectProperty ;
    rdfs:domain ex:Fluido ;
    rdfs:range ex:MedidasDeSeguridad .

ex:MedidasDeSeguridad a owl:Class ;
    rdfs:label "Medidas de seguridad"@es .

ex:CarroDeLaMaquina a owl:Class ;
    rdfs:label "Carro de la máquina"@es .