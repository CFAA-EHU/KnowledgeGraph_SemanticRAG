@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:BrochadoExterior a owl:Class ;
    rdfs:label "BrochadoExterior" ;
    rdfs:comment "Mecanizado con esfuerzo inferior a 70KN y carro portabrochas de longitud menor a 3000mm" .

ex:Maquina a owl:Class ;
    rdfs:label "Maquina" ;
    rdfs:comment "Máquina diseñada y fabricada según los últimos avances de la técnica y las normas técnicas de seguridad vigentes" .

ex:CarroPortabrochas a owl:Class ;
    rdfs:label "CarroPortabrochas" ;
    rdfs:comment "Carro portabrochas de longitud menor a 3000mm" .

ex:UtilDeAmarre a owl:Class ;
    rdfs:label "UtilDeAmarre" ;
    rdfs:comment "Útil de amarre adaptado a las piezas que se van a brochar" .

ex:SistemaTierras a owl:Class ;
    rdfs:label "SistemaTierras" ;
    rdfs:comment "Sistema de tierras del usuario" .

ex:DirectivaUniónEuropea a owl:Class ;
    rdfs:label "DirectivaUniónEuropea" ;
    rdfs:comment "Directivas de seguridad de la Unión Europea" .

ex:EquipoSeguridadPersonal a owl:Class ;
    rdfs:label "EquipoSeguridadPersonal" ;
    rdfs:comment "Equipo para la seguridad personal" .

ex:cumpleNormasTécnicasDeSeguridad a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:DirectivaUniónEuropea .

ex:tieneEsfuerzoMaximo a owl:DatatypeProperty ;
    rdfs:domain ex:BrochadoExterior ;
    rdfs:range xsd:decimal .

ex:tieneLongitudMaxima a owl:DatatypeProperty ;
    rdfs:domain ex:CarroPortabrochas ;
    rdfs:range xsd:decimal .

ex:requiereConexionSistemaTierras a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:SistemaTierras .

ex:requiereUtilDeAmarre a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:UtilDeAmarre .

ex:cumpleDirectivasSeguridad a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:DirectivaUniónEuropea .

ex:requiereEquipoSeguridadPersonal a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:EquipoSeguridadPersonal .