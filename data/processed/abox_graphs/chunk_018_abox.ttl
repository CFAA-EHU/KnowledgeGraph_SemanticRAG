@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibidaUsoNoAcordado18 a ns1:AccionProhibida ;
    rdfs:label "Uso no acorde con las especificaciones"@es ;
    ns1:textoExtracto "TODO USO DIVERGENTE DEL ESPECIFICADO EN LA DOCUMENTACIÓN DE LA MÁQUINA SE CONSIDERA 'NO ACORDE CON LAS ESPECIFICACIONES' Y DE ÉL PUEDE DERIVARSE RIESGO DE LESIONES O MUERTE DE LOS USUARIOS O DE TERCERAS PERSONAS, O DAÑOS A LA MÁQUINA Y A OTROS BIENES."@es .

ns1:ManualInstrucciones18 a ns1:Manual ;
    rdfs:label "Manual de instrucciones"@es ;
    ns1:textoExtracto "ES PARTE DEL USO ACORDE CON LAS ESPECIFICACIONES EL CUMPLIMIENTO DE LAS INDICACIONES DEL MANUAL DE INSTRUCCIONES."@es .

ns1:MaquinaBrochadora18 a ns1:Maquina ;
    rdfs:label "MÁQUINA"@es ;
    ns1:cumpleNormativa ns1:DirectivaSeguridadUE18 ;
    ns1:textoExtracto "Antes de efectuar la puesta en marcha de la máquina, ésta debe conectarse al sistema de tierras del usuario y dicho sistema debe cumplir con lo exigido por las leyes nacionales."@es .

ns1:SistemaTierra18 a ns1:Sistema ;
    rdfs:label "Sistema de tierras"@es ;
    ns1:textoExtracto "Antes de efectuar la puesta en marcha de la máquina, ésta debe conectarse al sistema de tierras del usuario y dicho sistema debe cumplir con lo exigido por las leyes nacionales."@es .

ns1:DirectivaSeguridadUE18 a ns1:Directiva ;
    rdfs:label "Directivas de seguridad de la Unión Europea"@es ;
    ns1:textoExtracto "LA MÁQUINA A LA CUAL HACE REFERENCIA EL PRESENTE MANUAL HA SIDO DISEÑADA Y FABRICADA SEGÚN LOS ÚLTIMOS AVANCES DE LA TÉCNICA Y LAS NORMAS TÉCNICAS DE SEGURIDAD VIGENTES, CONFORME A LAS DIRECTIVAS DE SEGURIDAD DE LA UNIÓN EUROPEA, CUMPLIENDO TODOS LOS REQUISITOS NECESARIOS PARA EL MARCADO"@es .

