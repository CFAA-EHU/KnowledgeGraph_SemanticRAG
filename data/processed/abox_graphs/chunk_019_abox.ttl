@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_19_1 a ns1:AvisoSeguridad ;
    ns1:textoExtracto "En ningún caso se debe poner en marcha el ciclo automático de la máquina sin antes asegurarse de que el útil de amarre está adaptado a las piezas que se van a brochar." .

ns1:AccionProhibida_19_2 a ns1:AvisoSeguridad ;
    ns1:textoExtracto "LAS PUERTAS DE LOS ARMARIOS ELÉCTRICOS DEBEN ESTAR CERRADAS Y BLOQUEADAS. ABRIR LAS PUERTAS SUPONE EXPONERSE A TENSIONES ELÉCTRICAS PELIGROSAS." .

ns1:AccionProhibida_19_3 a ns1:AvisoSeguridad ;
    ns1:textoExtracto "NO SE DEBEN EMPLEAR HERRAMIENTAS DIFERENTES A LAS ESPECIFICADAS POR EKIN S. COOP." .

ns1:AccionProhibida_19_4 a ns1:AvisoSeguridad ;
    ns1:textoExtracto "NO SE DEBE SOBREPASAR LA CAPACIDAD DE TRABAJO DE LA MÁQUINA." .

ns1:AccionProhibida_19_5 a ns1:AvisoSeguridad ;
    ns1:textoExtracto "NO SE DEBE PONER EN FUNCIONAMIENTO LA MAQUINA EN NINGUNO DE SUS MODOS DE TRABAJO, SIN ANTES VERIFICAR QUE NO SE ENCUENTRA NADIE EN SU INTERIOR." .

ns1:ComponenteElectrico_19_1 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "LAS PUERTAS DE LOS ARMARIOS ELÉCTRICOS" .

ns1:Empresa_19_1 a ns1:Empresa ;
    rdfs:label "EKIN S. COOP." ;
    ns1:textoExtracto "EKIN S. COOP." .

ns1:Maquina_19_1 a ns1:Maquina ;
    ns1:textoExtracto "NO SE DEBE SOBREPASAR LA CAPACIDAD DE TRABAJO DE LA MÁQUINA." .

ns1:ModoOperacion_19_1 a ns1:ModoOperacion ;
    ns1:textoExtracto "NO SE DEBE PONER EN FUNCIONAMIENTO LA MAQUINA EN NINGUNO DE SUS MODOS DE TRABAJO" .

