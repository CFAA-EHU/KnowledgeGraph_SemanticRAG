@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:ArmarioElectricoMaquina a ns1:ComponenteElectrico ;
    ns1:textoExtracto "PARA ELLO, COLOCAR UN CARTEL DE ADVERTENCIA JUNTO AL INTERRUPTOR GENERAL, SITUADO EN UN COSTADO DEL ARMARIO ELÉCTRICO, PROHIBIENDO LA PUESTA EN TENSIÓN DE LA MÁQUINA Y TAMBIEN BLOQUEÁNDOLO CON UN CANDADO." .

ns1:CartelAdvertenciaMaquina a ns1:AvisoSeguridad ;
    ns1:textoExtracto "PARA ELLO, COLOCAR UN CARTEL DE ADVERTENCIA JUNTO AL INTERRUPTOR GENERAL, ... PROHIBIENDO LA PUESTA EN TENSIÓN DE LA MÁQUINA Y TAMBIEN BLOQUEÁNDOLO CON UN CANDADO." .

ns1:DepartamentoAsistenciaClienteEKIN a ns1:Empresa ;
    ns1:textoExtracto "EN CASO NECESARIO DEBE PONERSE EN CONTACTO CON DEPARTAMENTO DE ASISTENCIA AL CLIENTE DE EKIN." .

ns1:EquipoElectricoMaquina a ns1:ComponenteElectrico ;
    ns1:textoExtracto "LOS TRABAJOS EN EL EQUIPO ELÉCTRICO DEBEN EFECTUARSE SIN TENSIÓN Y CON LA MÁQUINA CONSIGNADA." .

ns1:FormacionPersonalApartado2_3 a ns1:Capitulo ;
    ns1:textoExtracto "VER APARTADO 2.3 - FORMACIÓN DEL PERSONAL." .

ns1:HerramientaProteccionPersonal a ns1:Herramienta ;
    ns1:textoExtracto "LOS TRABAJOS CON TENSIÓN DEBEN EFECTUARSE POR PERSONAL COMPETENTE E INSTRUIDO, CON LAS HERRAMIENTAS Y PRENDAS DE PROTECCIÓN PERSONAL DE ACUERDO CON LA LEGISLACIÓN VIGENTE EN EL PAÍS DE UTILIZACIÓN." .

ns1:InterruptorGeneralMaquina a ns1:ComponenteElectrico ;
    ns1:textoExtracto "PARA ELLO, COLOCAR UN CARTEL DE ADVERTENCIA JUNTO AL INTERRUPTOR GENERAL, SITUADO EN UN COSTADO DEL ARMARIO ELÉCTRICO, PROHIBIENDO LA PUESTA EN TENSIÓN DE LA MÁQUINA Y TAMBIEN BLOQUEÁNDOLO CON UN CANDADO." .

ns1:ManualInstruccionesMantenimientoMaquina a ns1:Manual ;
    ns1:textoExtracto "ANTES DE EFECTUAR REPARACIONES EN LA MÁQUINA, SE DEBE CONSULTAR ESTE MANUAL DE INSTRUCCIONES." .

ns1:PersonalMantenimientoMaquina a ns1:Personal ;
    ns1:textoExtracto "EL PERSONAL QUE REPARA Y MANTIENE LA MÁQUINA DEBE TENER LOS CONOCIMIENTOS PRECISOS DE MECÁNICA, HIDRÁULICA, NEUMÁTICA, ELECTRICIDAD-ELECTRÓNICA, PARA QUE, EN FUNCIÓN DE SUS CONOCIMIENTOS ESPECÍFICOS, PUEDA DESARROLLAR LOS TRABAJOS ENCOMENDADOS." .

ns1:PrendaProteccionPersonal a ns1:EPI ;
    ns1:textoExtracto "LOS TRABAJOS CON TENSIÓN DEBEN EFECTUARSE POR PERSONAL COMPETENTE E INSTRUIDO, CON LAS HERRAMIENTAS Y PRENDAS DE PROTECCIÓN PERSONAL DE ACUERDO CON LA LEGISLACIÓN VIGENTE EN EL PAÍS DE UTILIZACIÓN." .

ns1:ResguardoMaquina a ns1:ElementoSeguridad ;
    ns1:textoExtracto "ANTES DE REALIZAR OPERACIONES DE MANTENIMIENTO QUE PRECISEN RETIRAR LOS RESGUARDOS, SE DEBE CONSIGNAR LA MÁQUINA." .

ns1:Maquina a ns1:Maquina ;
    ns1:textoExtracto "ANTES DE EFECTUAR REPARACIONES EN LA MÁQUINA, SE DEBE CONSULTAR ESTE MANUAL DE INSTRUCCIONES. ... LOS TRABAJOS EN EL EQUIPO ELÉCTRICO DEBEN EFECTUARSE SIN TENSIÓN Y CON LA MÁQUINA CONSIGNADA." .

