@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Grúa a owl:Class .
ex:AparatoElevador a owl:Class .
ex:Componente a owl:Class .
ex:SistemaSeguridad a owl:Class .
ex:PlanMantenimiento a owl:Class .
ex:MaquinaBrochadora a owl:Class .
ex:Peso a owl:Class .
ex:CargaNominal a owl:Class .
ex:Cadena a owl:Class .
ex:Cuerda a owl:Class .
ex:Gancho a owl:Class .
ex:Ojal a owl:Class .
ex:ProcesoElevacion a owl:Class .
ex:ProcesoSustitucion a owl:Class .

ex:emplear a owl:ObjectProperty ;
    rdfs:domain ex:ProcesoSustitucion ;
    rdfs:range ex:Grúa .
ex:garantizar a owl:ObjectProperty ;
    rdfs:domain ex:ProcesoSustitucion ;
    rdfs:range ex:Seguridad .
ex:derivar a owl:ObjectProperty ;
    rdfs:domain ex:ProcesoSustitucion ;
    rdfs:range ex:Peligro .
ex:emplearAparatoElevador a owl:ObjectProperty ;
    rdfs:domain ex:ProcesoSustitucion ;
    rdfs:range ex:AparatoElevador .
ex:tenerCargaNominal a owl:ObjectProperty ;
    rdfs:domain ex:AparatoElevador ;
    rdfs:range ex:CargaNominal .
ex:serAdecuadoPara a owl:ObjectProperty ;
    rdfs:domain ex:Cadena ;
    rdfs:range ex:Peso .
ex:permanecerDebajo a owl:ObjectProperty ;
    rdfs:domain ex:ProcesoElevacion ;
    rdfs:range ex:CargaSuspendida .
ex:revisar a owl:ObjectProperty ;
    rdfs:domain ex:SistemaSeguridad ;
    rdfs:range ex:Mantenimiento .
ex:mantenerRegularmente a owl:ObjectProperty ;
    rdfs:domain ex:SistemaSeguridad ;
    rdfs:range ex:Mantenimiento .
ex:seguir a owl:ObjectProperty ;
    rdfs:domain ex:PlanMantenimiento ;
    rdfs:range ex:MaquinaBrochadora .
ex:especificar a owl:ObjectProperty ;
    rdfs:domain ex:PlanMantenimiento ;
    rdfs:range ex:MaquinaBrochadora .

ex:tienePeso a owl:ObjectProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range ex:Peso .
ex:tieneCargaNominal a owl:ObjectProperty ;
    rdfs:domain ex:AparatoElevador ;
    rdfs:range ex:CargaNominal .
ex:tieneCadena a owl:ObjectProperty ;
    rdfs:domain ex:Grúa ;
    rdfs:range ex:Cadena .
ex:tieneCuerda a owl:ObjectProperty ;
    rdfs:domain ex:Grúa ;
    rdfs:range ex:Cuerda .
ex:tieneGancho a owl:ObjectProperty ;
    rdfs:domain ex:Grúa ;
    rdfs:range ex:Gancho .
ex:tieneOjal a owl:ObjectProperty ;
    rdfs:domain ex:Grúa ;
    rdfs:range ex:Ojal .
ex:tieneSistemaSeguridad a owl:ObjectProperty ;
    rdfs:domain ex:MaquinaBrochadora ;
    rdfs:range ex:SistemaSeguridad .
ex:tienePlanMantenimiento a owl:ObjectProperty ;
    rdfs:domain ex:MaquinaBrochadora ;
    rdfs:range ex:PlanMantenimiento .

ex:tienePesoIndicado a owl:DatatypeProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range xsd:decimal .
ex:tieneCargaNominalSuficiente a owl:DatatypeProperty ;
    rdfs:domain ex:AparatoElevador ;
    rdfs:range xsd:boolean .
ex:tienePesoIndicado a owl:DatatypeProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range xsd:decimal .