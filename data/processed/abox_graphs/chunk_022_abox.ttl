@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_Brochadora_22 a ns1:Maquina ;
    rdfs:label "Máquina brochadora"@es ;
    ns1:textoExtracto "SE DEBEN REVISAR Y MANTENER REGULARMENTE LOS SISTEMAS DE SEGURIDAD DE LOS QUE VA PROVISTA LA MÁQUINA. SE DEBE SEGUIR EL PLAN DE MANTENIMIENTO ESPECIFICADO POR EKIN PARA SU MÁQUINA BROCHADORA (VER APARTADO 7.1 plan de mantenimiento)." .

