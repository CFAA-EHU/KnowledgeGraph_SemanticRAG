@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix seg: <https://vocab.cfaa.eus/broaching/seguridad/> .
@prefix mant: <https://vocab.cfaa.eus/broaching/mantenimiento/> .
@prefix maq: <https://vocab.cfaa.eus/broaching/maquina/> .

seg:ElementoSeguridad a owl:Class ;
    rdfs:label "Elemento de seguridad" ;
    rdfs:comment "Componente crítico para la seguridad de la máquina" .

seg:InterruptorGeneral a seg:ElementoSeguridad ;
    rdfs:label "Interruptor general del armario eléctrico" .

seg:PulsadorEmergencia a seg:ElementoSeguridad ;
    rdfs:label "Pulsador de parada de emergencia" .

seg:PanelDesmontable a seg:ElementoSeguridad ;
    rdfs:label "Panel desmontable" .

seg:Puerta a seg:ElementoSeguridad ;
    rdfs:label "Puerta" .

seg:PanelFijo a seg:ElementoSeguridad ;
    rdfs:label "Panel fijo" .

mant:VerificacionSeguridad a owl:Class ;
    rdfs:label "Verificación de seguridad" ;
    rdfs:comment "Proceso de verificación de los elementos de seguridad" .

mant:SustitucionElemento a owl:Class ;
    rdfs:label "Sustitución de elemento" ;
    rdfs:comment "Proceso de sustitución de elementos de seguridad" .

mant:ComprobacionFuncionamiento a owl:Class ;
    rdfs:label "Comprobación de funcionamiento" ;
    rdfs:comment "Proceso de comprobación del funcionamiento de los elementos de seguridad" .

maq:Maquina a owl:Class ;
    rdfs:label "Máquina" ;
    rdfs:comment "Máquina que requiere verificación de elementos de seguridad" .

seg:tieneElementoSeguridad a owl:ObjectProperty ;
    rdfs:domain maq:Maquina ;
    rdfs:range seg:ElementoSeguridad .

seg:requiereSustitucion a owl:ObjectProperty ;
    rdfs:domain seg:ElementoSeguridad ;
    rdfs:range mant:SustitucionElemento .

seg:requiereComprobacion a owl:ObjectProperty ;
    rdfs:domain seg:ElementoSeguridad ;
    rdfs:range mant:ComprobacionFuncionamiento .

mant:afectaElementoSeguridad a owl:ObjectProperty ;
    rdfs:domain mant:TareaMantenimiento ;
    rdfs:range seg:ElementoSeguridad .

mant:requiereVerificacion a owl:ObjectProperty ;
    rdfs:domain maq:Maquina ;
    rdfs:range mant:VerificacionSeguridad .

mant:TareaMantenimiento a owl:Class ;
    rdfs:label "Tarea de mantenimiento" ;
    rdfs:comment "Tarea que puede afectar a los elementos de seguridad" .