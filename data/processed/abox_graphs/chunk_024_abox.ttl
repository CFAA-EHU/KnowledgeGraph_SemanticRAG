@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:PanelMantenimiento a owl:Class ;
    rdfs:label "Panel de mantenimiento no controlado"@es ;
    rdfs:comment "Panel de mantenimiento sin interruptor de seguridad"@es .

ex:PuertaControlada a owl:Class ;
    rdfs:label "Puerta controlada con interruptor de seguridad"@es .

ex:InterruptorSeguridad a owl:Class ;
    rdfs:label "Interruptor de seguridad EUCHNER"@es .

ex:EnclavamientoElectronicoSeguridad a owl:Class ;
    rdfs:label "Enclavamiento electrónico de seguridad"@es .

ex:tieneInterruptorSeguridad a owl:ObjectProperty ;
    rdfs:domain ex:PuertaControlada ;
    rdfs:range ex:InterruptorSeguridad .

ex:tieneEnclavamientoElectronicoSeguridad a owl:ObjectProperty ;
    rdfs:domain ex:PuertaControlada ;
    rdfs:range ex:EnclavamientoElectronicoSeguridad .

ex:requiereHerramienta a owl:ObjectProperty ;
    rdfs:domain ex:PanelMantenimiento ;
    rdfs:range rdfs:Resource .

ex:estaAtornillado a owl:ObjectProperty ;
    rdfs:domain ex:PanelMantenimiento ;
    rdfs:range rdfs:Resource .

ex:provoqueParada a owl:ObjectProperty ;
    rdfs:domain ex:PanelMantenimiento ;
    rdfs:range rdfs:Resource .

ex:debeEstarCerrado a owl:ObjectProperty ;
    rdfs:domain ex:PanelMantenimiento ;
    rdfs:range rdfs:Resource .

ex:tieneAccionamientoManual a owl:ObjectProperty ;
    rdfs:domain ex:PuertaControlada ;
    rdfs:range rdfs:Resource .

ex:tieneMicroDeSeguridad a owl:ObjectProperty ;
    rdfs:domain ex:PuertaControlada ;
    rdfs:range rdfs:Resource .

ex:tieneCantidad a owl:DatatypeProperty ;
    rdfs:domain ex:PanelMantenimiento ;
    rdfs:range xsd:integer .

ex:tieneUbicacion a owl:DatatypeProperty ;
    rdfs:domain ex:PanelMantenimiento ;
    rdfs:range xsd:string .

ex:tieneCodigo a owl:DatatypeProperty ;
    rdfs:domain ex:PuertaControlada ;
    rdfs:range xsd:string .