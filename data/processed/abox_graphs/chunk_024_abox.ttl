@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaPuertas a ns1:Sistema ;
    rdfs:label "Sistema de puertas y paneles desmontables" ;
    ns1:textoExtracto "La máquina está equipada con 2 tipos de defensas: paneles desmontables de mantenimiento y puertas controladas por interruptor de seguridad." ;
    ns1:tieneComponente ns1:InterruptorSeguridadDerecha,
        ns1:InterruptorSeguridadFrontal,
        ns1:InterruptorSeguridadIzquierda,
        ns1:PanelMantenimiento1,
        ns1:PanelMantenimiento2,
        ns1:PanelMantenimiento3,
        ns1:PanelMantenimiento4,
        ns1:PanelMantenimiento5,
        ns1:PanelMantenimiento6,
        ns1:PuertaFrontal,
        ns1:PuertaLateralDerecha,
        ns1:PuertaLateralIzquierda .

ns1:InterruptorSeguridadDerecha a ns1:Sensor ;
    rdfs:label "Interruptor de seguridad lateral derecho" ;
    ns1:identificador "24SQ2" ;
    ns1:textoExtracto "Micro de Puerta seguridad derecha (24SQ2)" .

ns1:InterruptorSeguridadFrontal a ns1:Sensor ;
    rdfs:label "Interruptor de seguridad frontal" ;
    ns1:identificador "23SQ1" ;
    ns1:textoExtracto "Micro de Puerta seguridad frontal (23SQ1)" .

ns1:InterruptorSeguridadIzquierda a ns1:Sensor ;
    rdfs:label "Interruptor de seguridad lateral izquierdo" ;
    ns1:identificador "24SQ1" ;
    ns1:textoExtracto "Micro de Puerta seguridad izquierda (24SQ1)" .

ns1:PanelMantenimiento1 a ns1:Componente ;
    rdfs:label "Panel de mantenimiento trasero 1" ;
    ns1:identificador "Panel trasero 1" ;
    ns1:textoExtracto "dos en la parte trasera" .

ns1:PanelMantenimiento2 a ns1:Componente ;
    rdfs:label "Panel de mantenimiento trasero 2" ;
    ns1:identificador "Panel trasero 2" ;
    ns1:textoExtracto "dos en la parte trasera" .

ns1:PanelMantenimiento3 a ns1:Componente ;
    rdfs:label "Panel de mantenimiento lateral izquierdo 1" ;
    ns1:identificador "Panel lateral izquierdo 1" ;
    ns1:textoExtracto "dos en cada lateral" .

ns1:PanelMantenimiento4 a ns1:Componente ;
    rdfs:label "Panel de mantenimiento lateral izquierdo 2" ;
    ns1:identificador "Panel lateral izquierdo 2" ;
    ns1:textoExtracto "dos en cada lateral" .

ns1:PanelMantenimiento5 a ns1:Componente ;
    rdfs:label "Panel de mantenimiento lateral derecho 1" ;
    ns1:identificador "Panel lateral derecho 1" ;
    ns1:textoExtracto "dos en cada lateral" .

ns1:PanelMantenimiento6 a ns1:Componente ;
    rdfs:label "Panel de mantenimiento lateral derecho 2" ;
    ns1:identificador "Panel lateral derecho 2" ;
    ns1:textoExtracto "dos en cada lateral" .

ns1:PuertaFrontal a ns1:Componente ;
    rdfs:label "Puerta frontal" ;
    ns1:identificador "23SQ1" ;
    ns1:textoExtracto "una en la parte frontal (23SQ1)" .

ns1:PuertaLateralDerecha a ns1:Componente ;
    rdfs:label "Puerta lateral derecha" ;
    ns1:identificador "24SQ2" ;
    ns1:textoExtracto "una en el lateral derecho (24SQ2)" .

ns1:PuertaLateralIzquierda a ns1:Componente ;
    rdfs:label "Puerta lateral izquierda" ;
    ns1:identificador "24SQ1" ;
    ns1:textoExtracto "una en el lateral izquierdo (24SQ1)" .

