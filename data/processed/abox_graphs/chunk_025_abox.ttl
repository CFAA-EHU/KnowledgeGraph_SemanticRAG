@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:PuertaControlada a owl:Class ;
    rdfs:label "Puerta controlada con interruptor de seguridad" .

ex:InterruptorDeSeguridad a owl:Class ;
    rdfs:label "Interruptor de seguridad" .

ex:ServicioAutomatico a owl:Class ;
    rdfs:label "Servicio automático" .

ex:Servomotor a owl:Class ;
    rdfs:label "Servomotor" .

ex:Maquina a owl:Class ;
    rdfs:label "Máquina" .

ex:provocaDesconexion a owl:ObjectProperty ;
    rdfs:domain ex:InterruptorDeSeguridad ;
    rdfs:range ex:Sistema .

ex:provocaParada a owl:ObjectProperty ;
    rdfs:domain ex:InterruptorDeSeguridad ;
    rdfs:range ex:Maquina .

ex:tieneInterruptorDeSeguridad a owl:ObjectProperty ;
    rdfs:domain ex:PuertaControlada ;
    rdfs:range ex:InterruptorDeSeguridad .

ex:requiereNoAperturaDuranteServicioAutomatico a owl:ObjectProperty ;
    rdfs:domain ex:PuertaControlada ;
    rdfs:range ex:ServicioAutomatico .

ex:Sistema a owl:Class ;
    rdfs:label "Sistema" .

ex:desconectarServomotor a owl:ObjectProperty ;
    rdfs:domain ex:Sistema ;
    rdfs:range ex:Servomotor .