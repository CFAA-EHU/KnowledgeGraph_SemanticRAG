@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PlataformaInteriorCambioHerramienta a ns1:Sistema ;
    rdfs:label "Plataforma interior cambio de herramienta" ;
    ns1:compuestoPor ns1:PlataformaCambioHerramienta ;
    ns1:textoExtracto "En la parte superior del carro porta-piezas se ha instalado una plataforma que se utiliza para realizar el cambio de herramienta." .

ns1:PlataformaCambioHerramienta a ns1:ComponenteMecanico ;
    rdfs:label "Plataforma cambio de herramienta" ;
    ns1:compuestoPor ns1:EnclavamientoElectronicoSeguridad25SQ1,
        ns1:TrampillaPlataformaCambioHerramienta ;
    ns1:textoExtracto "La plataforma dispone de una trampilla en la parte central que se abre para realizar el cambio del plato divisor." .

ns1:TrampillaPlataformaCambioHerramienta a ns1:ElementoSeguridad ;
    rdfs:label "Trampilla Plataforma plataforma Micro de seguridad" ;
    ns1:textoExtracto "La plataforma dispone de una trampilla en la parte central que se abre para realizar el cambio del plato divisor. La trampilla está equipada con un enclavamiento electrónico de seguridad (25SQ1) EUCHNER que se acciona automáticamente cuando la máquina está en funcionamiento." ;
    ns1:tieneComponente ns1:EnclavamientoElectronicoSeguridad25SQ1 .

ns1:EnclavamientoElectronicoSeguridad25SQ1 a ns1:ComponenteElectrico ;
    rdfs:label "Enclavamiento electrónico de seguridad (25SQ1) EUCHNER" ;
    ns1:identificador "25SQ1" ;
    ns1:textoExtracto "La trampilla está equipada con un enclavamiento electrónico de seguridad (25SQ1) EUCHNER que se acciona automáticamente cuando la máquina está en funcionamiento." .

