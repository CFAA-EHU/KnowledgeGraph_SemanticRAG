@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Figura2_6_28 a ns1:Figura ;
    rdfs:label "Figura 2-6" ;
    ns1:ilustradoEn ns1:InterruptorGeneralArmarioElectrico_28 ;
    ns1:textoExtracto "Figura 2-6. Interruptor general armario eléctrico." .

ns1:MaquinaConsignada_28 a ns1:Maquina ;
    rdfs:label "Máquina consignada" ;
    ns1:textoExtracto "Máquina consignada" .

ns1:Maquina_28 a ns1:Maquina ;
    rdfs:label "Máquina" ;
    ns1:textoExtracto "la máquina" .

ns1:Servomotor_28 a ns1:ComponenteElectrico ;
    rdfs:label "Servomotor" ;
    ns1:textoExtracto "desconexión de todos los servomotores de la máquina" .

ns1:Sistema_28 a ns1:Sistema ;
    rdfs:label "Sistema" ;
    ns1:textoExtracto "se produce la desconexión de los sistemas" .

ns1:InterruptorGeneralArmarioElectrico_28 a ns1:ComponenteElectrico ;
    rdfs:label "Interruptor general del armario eléctrico" ;
    ns1:textoExtracto "El armario eléctrico de la máquina dispone en un lateral de un interruptor general, mediante el cual se realiza la conexión y desconexión del suministro eléctrico de toda la máquina." .

