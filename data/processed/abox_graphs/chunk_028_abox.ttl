@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:ArmarioElectrico a owl:Class ;
    rdfs:label "Armario eléctrico"@es .

ex:InterruptorGeneral a owl:Class ;
    rdfs:label "Interruptor general"@es .

ex:SuministroElectrico a owl:Class ;
    rdfs:label "Suministro eléctrico"@es .

ex:Servomotor a owl:Class ;
    rdfs:label "Servomotor"@es .

ex:Máquina a owl:Class ;
    rdfs:label "Máquina"@es .

ex:Consignación a owl:Class ;
    rdfs:label "Consignación"@es .

ex:Candado a owl:Class ;
    rdfs:label "Candado"@es .

ex:PosiciónOFF a owl:Class ;
    rdfs:label "Posición OFF"@es .

ex:PosiciónON a owl:Class ;
    rdfs:label "Posición ON"@es .

ex:Mantenimiento a owl:Class ;
    rdfs:label "Mantenimiento"@es .

ex:TerceraPersona a owl:Class ;
    rdfs:label "Tercera persona"@es .

ex:InterruptorGeneralTensión a owl:Class ;
    rdfs:label "Interruptor general de tensión"@es .

ex:SeñalVisual a owl:Class ;
    rdfs:label "Señal visual"@es .

ex:Figura2_6 a owl:Class ;
    rdfs:label "Figura 2-6"@es .

ex:tieneInterruptorGeneral a owl:ObjectProperty ;
    rdfs:domain ex:ArmarioElectrico ;
    rdfs:range ex:InterruptorGeneral .

ex:realizaConexión a owl:ObjectProperty ;
    rdfs:domain ex:InterruptorGeneral ;
    rdfs:range ex:SuministroElectrico .

ex:realizaDesconexión a owl:ObjectProperty ;
    rdfs:domain ex:InterruptorGeneral ;
    rdfs:range ex:SuministroElectrico .

ex:produceDesconexión a owl:ObjectProperty ;
    rdfs:domain ex:InterruptorGeneral ;
    rdfs:range ex:Servomotor .

ex:requiereConsignación a owl:ObjectProperty ;
    rdfs:domain ex:Mantenimiento ;
    rdfs:range ex:Máquina .

ex:situarInterruptorGeneral a owl:ObjectProperty ;
    rdfs:domain ex:Consignación ;
    rdfs:range ex:PosiciónOFF .

ex:colocarCandado a owl:ObjectProperty ;
    rdfs:domain ex:Consignación ;
    rdfs:range ex:Candado .

ex:evitarSituación a owl:ObjectProperty ;
    rdfs:domain ex:Candado ;
    rdfs:range ex:PosiciónON .

ex:tieneSeñalVisual a owl:ObjectProperty ;
    rdfs:domain ex:InterruptorGeneralTensión ;
    rdfs:range ex:SeñalVisual .

ex:tieneFigura a owl:ObjectProperty ;
    rdfs:domain ex:InterruptorGeneral ;
    rdfs:range ex:Figura2_6 .