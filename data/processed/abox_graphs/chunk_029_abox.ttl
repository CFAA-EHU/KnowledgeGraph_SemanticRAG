@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix base: <https://vocab.cfaa.eus/broaching/base#> .
@prefix mecanica: <https://vocab.cfaa.eus/broaching/mecanica#> .
@prefix elec: <https://vocab.cfaa.eus/broaching/elec#> .

base:FormacionPersonal a owl:Class ;
    rdfs:label "Formación del Personal" ;
    rdfs:comment "Clase que representa la formación y competencias del personal para el manejo y mantenimiento de la máquina." .

base:Personal a owl:Class ;
    rdfs:label "Personal" ;
    rdfs:comment "Clase que representa al personal involucrado en el manejo y mantenimiento de la máquina." .

base:ResponsableMaquina a owl:Class ;
    rdfs:label "Responsable de Máquina" ;
    rdfs:comment "Clase que representa al responsable de la máquina, con competencias para denegar acciones que comprometan la seguridad." .

base:BrochadoraElectromecanicaExteriores a owl:Class ;
    rdfs:label "Brochadora Electromecánica de Exteriores" ;
    rdfs:comment "Clase que representa la máquina brochadora electromecánica de exteriores." ;
    rdfs:isDefinedBy "A218/RASHEM 7x3000x500" .

base:InstruccionesSeguridad a owl:Class ;
    rdfs:label "Instrucciones de Seguridad" ;
    rdfs:comment "Clase que representa las instrucciones de seguridad para el manejo y mantenimiento de la máquina." .

base:ManualInstrucciones a owl:Class ;
    rdfs:label "Manual de Instrucciones" ;
    rdfs:comment "Clase que representa el manual de instrucciones de la máquina." .

base:Planos a owl:Class ;
    rdfs:label "Planos" ;
    rdfs:comment "Clase que representa los planos de la máquina." .

base:Esquemas a owl:Class ;
    rdfs:label "Esquemas" ;
    rdfs:comment "Clase que representa los esquemas de la máquina." .

base:Documentacion a owl:Class ;
    rdfs:label "Documentación" ;
    rdfs:comment "Clase que representa la documentación de la máquina." .

mecanica:tieneCompetencias a owl:ObjectProperty ;
    rdfs:label "tiene competencias" ;
    rdfs:domain base:Personal ;
    rdfs:range base:FormacionPersonal .

mecanica:actuaEnMaquina a owl:ObjectProperty ;
    rdfs:label "actúa en la máquina" ;
    rdfs:domain base:Personal ;
    rdfs:range base:BrochadoraElectromecanicaExteriores .

mecanica:tieneConocimientos a owl:ObjectProperty ;
    rdfs:label "tiene conocimientos" ;
    rdfs:domain base:Personal ;
    rdfs:range base:FormacionPersonal .

mecanica:tieneResponsable a owl:ObjectProperty ;
    rdfs:label "tiene responsable" ;
    rdfs:domain base:BrochadoraElectromecanicaExteriores ;
    rdfs:range base:ResponsableMaquina .

mecanica:deniegaAcciones a owl:ObjectProperty ;
    rdfs:label "deniega acciones" ;
    rdfs:domain base:ResponsableMaquina ;
    rdfs:range rdfs:Resource .

mecanica:estudiarDocumentacion a owl:ObjectProperty ;
    rdfs:label "estudiar documentación" ;
    rdfs:domain base:Personal ;
    rdfs:range base:Documentacion .

elec:tieneInstruccionesSeguridad a owl:ObjectProperty ;
    rdfs:label "tiene instrucciones de seguridad" ;
    rdfs:domain base:BrochadoraElectromecanicaExteriores ;
    rdfs:range base:InstruccionesSeguridad .

elec:tieneManualInstrucciones a owl:ObjectProperty ;
    rdfs:label "tiene manual de instrucciones" ;
    rdfs:domain base:BrochadoraElectromecanicaExteriores ;
    rdfs:range base:ManualInstrucciones .

elec:tienePlanos a owl:ObjectProperty ;
    rdfs:label "tiene planos" ;
    rdfs:domain base:BrochadoraElectromecanicaExteriores ;
    rdfs:range base:Planos .

elec:tieneEsquemas a owl:ObjectProperty ;
    rdfs:label "tiene esquemas" ;
    rdfs:domain base:BrochadoraElectromecanicaExteriores ;
    rdfs:range base:Esquemas .

elec:tieneDocumentacion a owl:ObjectProperty ;
    rdfs:label "tiene documentación" ;
    rdfs:domain base:BrochadoraElectromecanicaExteriores ;
    rdfs:range base:Documentacion .