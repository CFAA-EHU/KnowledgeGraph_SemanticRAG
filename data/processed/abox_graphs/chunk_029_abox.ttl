@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DocumentacionManual a ns1:Manual ;
    rdfs:label "documentación del manual"@es ;
    ns1:textoExtracto "toda la documentación que indica este manual de instrucciones acerca de la máquina." .

ns1:EsquemaMaquina a ns1:Esquema ;
    rdfs:label "esquemas de la máquina"@es ;
    ns1:textoExtracto "Éste debe estudiar los planos, esquemas y toda la documentación que indica este manual de instrucciones acerca de la máquina." .

ns1:ManualInstruccionesSeguridad a ns1:Manual ;
    rdfs:label "manual de instrucciones de seguridad"@es ;
    ns1:textoExtracto "INSTRUCCIONES DE SEGURIDAD | CAPÍTULO - 2" .

ns1:MaquinaBROCHADORAElectromecanicaExteriores a ns1:Maquina ;
    rdfs:label "brochadora electromecánica de exteriores A218/RASHEM 7x3000x500"@es ;
    ns1:identificador "A218/ RASHEM 7x3000x500" ;
    ns1:textoExtracto "BROCHADORA ELECTROMECÁNICA DE EXTERIORES | A218/ RASHEM 7x3000x500" .

ns1:PersonalFormado a ns1:Personal ;
    rdfs:label "personal formado"@es ;
    ns1:textoExtracto "Sólo se debe emplear personal debidamente formado e instruido tanto en el manejo como en el mantenimiento de la máquina." .

ns1:PersonalMantenimiento a ns1:Personal ;
    rdfs:label "personal de mantenimiento"@es ;
    ns1:textoExtracto "El personal que repara y mantiene la máquina debe tener los conocimientos precisos de mecánica, hidráulica, neumática, electricidad-electrónica, para que, en función de sus conocimientos específicos, pueda desarrollar los trabajos encomendados." .

ns1:ResponsableMaquina a ns1:Personal ;
    rdfs:label "responsable de máquina"@es ;
    ns1:textoExtracto "Se debe establecer un responsable de máquina – incluso de cara a las prescripciones legales de uso – y dotarlo de competencias para denegar a terceros acciones que comprometan la seguridad." .

