@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EPI_AuricularesProteccion a ns1:EPI ;
    rdfs:label "Auriculares de protección auditiva" ;
    ns1:textoExtracto "Para los trabajos con ruidos superiores a los 78 dB." .

ns1:EPI_CalzadoSeguridad a ns1:EPI ;
    rdfs:label "Calzado de seguridad" ;
    ns1:textoExtracto "Debe ser calzado de seguridad y con puntera reforzada." .

ns1:EPI_CascoSeguridad a ns1:EPI ;
    rdfs:label "Casco de seguridad" ;
    ns1:textoExtracto "Para trabajos en los que exista peligro de daños en la cabeza, en especial en trabajos de montaje o desmontaje y transporte de elementos de la máquina, y en toda acción de movimiento de elementos pesados mediante una grúa." .

ns1:EPI_GafasSeguridad a ns1:EPI ;
    rdfs:label "Gafas de seguridad" ;
    ns1:textoExtracto "EL OPERARIO DEBE EMPLEAR GAFAS DE SEGURIDAD Y GUANTES DURANTE EL TRABAJO CON LA MÁQUINA EN FUNCIONAMIENTO." .

ns1:EPI_GuantesSeguridad a ns1:EPI ;
    rdfs:label "Guantes de seguridad" ;
    ns1:textoExtracto "EL OPERARIO DEBE EMPLEAR GAFAS DE SEGURIDAD Y GUANTES DURANTE EL TRABAJO CON LA MÁQUINA EN FUNCIONAMIENTO." .

ns1:EPI_MandilProtectorSoldadura a ns1:EPI ;
    rdfs:label "Mandil protector para soldadura" ;
    ns1:textoExtracto "Para todos los trabajos de soldadura, usar pantalla protectora, mandil y guantes adecuados." .

ns1:EPI_PantallaProtectorSoldadura a ns1:EPI ;
    rdfs:label "Pantalla protectora para soldadura" ;
    ns1:textoExtracto "Para todos los trabajos de soldadura, usar pantalla protectora, mandil y guantes adecuados." .

