@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix seguridad: <https://vocab.cfaa.eus/broaching/seguridad/> .
@prefix indumentaria: <https://vocab.cfaa.eus/broaching/indumentaria/> .
@prefix trabajo: <https://vocab.cfaa.eus/broaching/trabajo/> .

# Clases
seguridad:EquipoSeguridadPersonal a owl:Class .
seguridad:IndumentariaSeguridad a owl:Class .
seguridad:GafasSeguridad a owl:Class .
seguridad:CalzadoSeguridad a owl:Class .
seguridad:GuantesSeguridad a owl:Class .
seguridad:AuricularesSeguridad a owl:Class .
seguridad:CascoSeguridad a owl:Class .
trabajo:TrabajoConMaquinaEnFuncionamiento a owl:Class .
trabajo:TrabajoConHerramienta a owl:Class .
trabajo:TrabajoConMaterialesAbrasivos a owl:Class .
trabajo:TrabajoConAltasTemperaturas a owl:Class .
trabajo:TrabajoConElementosCortantes a owl:Class .
trabajo:TrabajoConRuidos a owl:Class .
trabajo:TrabajoDeMontajeDesmontaje a owl:Class .
trabajo:TrabajoConElementosPesados a owl:Class .

# Propiedades de objeto
seguridad:emplearIndumentaria a owl:ObjectProperty .
seguridad:requiereIndumentaria a owl:ObjectProperty .
seguridad:evitarAccidentes a owl:ObjectProperty .
seguridad:protegerPartesCuerpo a owl:ObjectProperty .
trabajo:realizarTrabajo a owl:ObjectProperty .
trabajo:requiereEquipoSeguridad a owl:ObjectProperty .

# Propiedades de datos
seguridad:descripcionIndumentaria a owl:DatatypeProperty .
seguridad:riesgoAsociado a owl:DatatypeProperty .
seguridad:lesionPosible a owl:DatatypeProperty .
trabajo:tipoTrabajo a owl:DatatypeProperty .
trabajo:nivelRuido a owl:DatatypeProperty .