@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:CascoSeguridad a owl:Class ;
    rdfs:label "Casco de seguridad"@es ;
    rdfs:comment "Equipo para la seguridad personal en trabajos con peligro de daños en la cabeza, especialmente en montaje, desmontaje, transporte de elementos de la máquina y movimiento de elementos pesados mediante grúa."@es .

ex:EquipoSeguridadPersonal a owl:Class ;
    rdfs:label "Equipo para la seguridad personal"@es .

ex:TrabajoMontaje a owl:Class ;
    rdfs:label "Trabajo de montaje"@es .

ex:TrabajoDesmontaje a owl:Class ;
    rdfs:label "Trabajo de desmontaje"@es .

ex:TransporteElementosMaquina a owl:Class ;
    rdfs:label "Transporte de elementos de la máquina"@es .

ex:MovimientoElementosPesados a owl:Class ;
    rdfs:label "Movimiento de elementos pesados"@es .

ex:Grúa a owl:Class ;
    rdfs:label "Grúa"@es .

ex:tieneEquipoSeguridadPersonal a owl:ObjectProperty ;
    rdfs:domain ex:CascoSeguridad ;
    rdfs:range ex:EquipoSeguridadPersonal .

ex:requiereParaTrabajoMontaje a owl:ObjectProperty ;
    rdfs:domain ex:CascoSeguridad ;
    rdfs:range ex:TrabajoMontaje .

ex:requiereParaTrabajoDesmontaje a owl:ObjectProperty ;
    rdfs:domain ex:CascoSeguridad ;
    rdfs:range ex:TrabajoDesmontaje .

ex:requiereParaTransporteElementosMaquina a owl:ObjectProperty ;
    rdfs:domain ex:CascoSeguridad ;
    rdfs:range ex:TransporteElementosMaquina .

ex:requiereParaMovimientoElementosPesados a owl:ObjectProperty ;
    rdfs:domain ex:CascoSeguridad ;
    rdfs:range ex:MovimientoElementosPesados .

ex:utilizaGrúa a owl:ObjectProperty ;
    rdfs:domain ex:MovimientoElementosPesados ;
    rdfs:range ex:Grúa .