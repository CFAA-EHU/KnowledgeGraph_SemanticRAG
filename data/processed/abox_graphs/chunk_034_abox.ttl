@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:AlumbradoInteriorDeMaquina a owl:Class ;
    rdfs:label "Alumbrado interior de la máquina"@es ;
    rdfs:comment "Sistema de alumbrado compuesto por cuatro lámparas de 19.5 W con protección IP67"@es .

ex:Lampara a owl:Class ;
    rdfs:label "Lámpara"@es ;
    rdfs:comment "Componente del sistema de alumbrado"@es .

ex:PlatoDivisor a owl:Class ;
    rdfs:label "Plato divisor"@es ;
    rdfs:comment "Componente de la máquina alumbrado por las lámparas verticales"@es .

ex:Herramienta a owl:Class ;
    rdfs:label "Herramienta"@es ;
    rdfs:comment "Componente de la máquina alumbrado por las lámparas horizontales"@es .

ex:tieneLampara a owl:ObjectProperty ;
    rdfs:domain ex:AlumbradoInteriorDeMaquina ;
    rdfs:range ex:Lampara .

ex:tienePlatoDivisor a owl:ObjectProperty ;
    rdfs:domain ex:AlumbradoInteriorDeMaquina ;
    rdfs:range ex:PlatoDivisor .

ex:tieneHerramienta a owl:ObjectProperty ;
    rdfs:domain ex:AlumbradoInteriorDeMaquina ;
    rdfs:range ex:Herramienta .

ex:tieneProteccion a owl:ObjectProperty ;
    rdfs:domain ex:Lampara ;
    rdfs:range ex:ProteccionIP67 .

ex:ProteccionIP67 a owl:Class ;
    rdfs:label "Protección IP67"@es ;
    rdfs:comment "Protección total contra polvo, viruta, aceites y refrigerantes"@es .

ex:tienePotencia a owl:DatatypeProperty ;
    rdfs:domain ex:Lampara ;
    rdfs:range xsd:decimal .

ex:tienePosicion a owl:DatatypeProperty ;
    rdfs:domain ex:Lampara ;
    rdfs:range xsd:string .