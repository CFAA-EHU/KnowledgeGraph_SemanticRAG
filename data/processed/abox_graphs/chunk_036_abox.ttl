@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Color rdf:type owl:Class .
ex:Columna rdf:type owl:Class .
ex:Carro rdf:type owl:Class .
ex:Carenado rdf:type owl:Class .
ex:ArmarioElectrico rdf:type owl:Class .
ex:Pupitre rdf:type owl:Class .

ex:tieneColor a owl:ObjectProperty ;
    rdfs:domain [ owl:unionOf ( ex:Columna ex:Carro ex:Carenado ex:ArmarioElectrico ex:Pupitre ) ] ;
    rdfs:range ex:Color .

ex:ColorBlancoRAL7035 a ex:Color ;
    rdfs:label "BLANCO RAL 7035" .