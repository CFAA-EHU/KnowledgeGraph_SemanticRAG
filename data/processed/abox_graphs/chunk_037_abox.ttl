@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix mecanica: <https://vocab.cfaa.eus/broaching/mecanica/> .
@prefix elec: <https://vocab.cfaa.eus/broaching/elec/> .
@prefix base: <https://vocab.cfaa.eus/broaching/base/> .

ex:ColumnaMecanoSoldadoEstabilizado a owl:Class ;
    rdfs:label "Columna mecano-soldado estabilizado" ;
    rdfs:comment "Modelo RASHEM - 7x3000x500" .

ex:CarroPortaPieza a owl:Class ;
    rdfs:label "Carro porta-pieza" .

ex:Servomotor a owl:Class ;
    rdfs:label "Servomotor" ;
    rdfs:comment "Modelo FAGOR FKM85.20A.A3.310.11" .

ex:Cremallera a owl:Class ;
    rdfs:label "Cremallera" ;
    rdfs:comment "Modelos ZST 500-324-500-R1C-60 y ZST 500-324-1000-R1C-60 de WITTENSTEIN" .

ex:ConjuntoGuiado a owl:Class ;
    rdfs:label "Conjunto guiado" ;
    rdfs:comment "Modelos A21811005 y A21811006 de EKIN-IKO" .

mecanica:accionamientoElectromecanico a owl:ObjectProperty ;
    rdfs:domain ex:CarroPortaPieza ;
    rdfs:range ex:Servomotor .

mecanica:accionamientoCremallera a owl:ObjectProperty ;
    rdfs:domain ex:CarroPortaPieza ;
    rdfs:range ex:Cremallera .

mecanica:conjuntoGuiadoCarroPortaPieza a owl:ObjectProperty ;
    rdfs:domain ex:CarroPortaPieza ;
    rdfs:range ex:ConjuntoGuiado .