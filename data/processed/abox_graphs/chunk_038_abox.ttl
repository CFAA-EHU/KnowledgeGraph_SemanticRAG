@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:PupitreDeMandoPrincipal a owl:Class ;
    rdfs:label "Pupitre de mando principal con brazo articulado" ;
    rdfs:comment "Modelo: RITTAL CP.6320600" .

ex:PantallaTactil a owl:Class ;
    rdfs:label "Pantalla táctil de pupitre principal" ;
    rdfs:comment "Modelo: FAGOR PANEL PC-21” Panorámico 16Gb" .

ex:tieneModelo a owl:ObjectProperty ;
    rdfs:domain ex:PupitreDeMandoPrincipal ;
    rdfs:range xsd:string .

ex:tieneModelo a owl:ObjectProperty ;
    rdfs:domain ex:PantallaTactil ;
    rdfs:range xsd:string .