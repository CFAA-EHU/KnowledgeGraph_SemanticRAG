@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Electrovalvula a owl:Class ;
    rdfs:label "Electroválvula"@es ;
    rdfs:comment "Componente neumático de control"@es .

ex:SMC a owl:Class ;
    rdfs:label "SMC"@es ;
    rdfs:comment "Fabricante de componentes neumáticos"@es .

ex:VSVA_B_M52_MH_A2_1R5L a owl:Class ;
    rdfs:label "VSVA-B-M52-MH-A2-1R5L"@es ;
    rdfs:comment "Modelo específico de electroválvula SMC"@es .

ex:VSVA_B_B52_ZH_A2_1R5L a owl:Class ;
    rdfs:label "VSVA-B-B52-ZH-A2-1R5L"@es ;
    rdfs:comment "Modelo específico de electroválvula SMC"@es .

ex:tieneModelo a owl:ObjectProperty ;
    rdfs:domain ex:Electrovalvula ;
    rdfs:range ex:SMC .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:Electrovalvula ;
    rdfs:range ex:SMC .

ex:tieneModeloEspecifico a owl:ObjectProperty ;
    rdfs:domain ex:Electrovalvula ;
    rdfs:range [ a owl:Class ] ;
    rdfs:comment "Relación con modelos específicos de electroválvulas"@es .