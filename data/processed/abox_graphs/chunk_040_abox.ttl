@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

ex:TomaDePresion a owl:Class ;
    rdfs:label "Toma de presión" ;
    rdfs:comment "Componente hidráulico para medir presión." .

ex:TomaDePresion18G a owl:Class ;
    rdfs:label "Toma de presión 1/8”G" ;
    rdfs:comment "Toma de presión con rosca de 1/8 pulgada." .

ex:HYDROTECHNIK a owl:Class ;
    rdfs:label "HYDROTECHNIK" ;
    rdfs:comment "Fabricante de componentes hidráulicos." .

ex:PI586001 a owl:Class ;
    rdfs:label "PI 586001" ;
    rdfs:comment "Modelo de componente hidráulico." .

ex:tieneRoscaConexion a owl:ObjectProperty ;
    rdfs:domain ex:TomaDePresion18G ;
    rdfs:range ex:RoscaConexion .

ex:RoscaConexion a owl:Class ;
    rdfs:label "Rosca de conexión" ;
    rdfs:comment "Tipo de rosca utilizada en la conexión de la toma de presión." .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:TomaDePresion18G ;
    rdfs:range ex:HYDROTECHNIK .

ex:tieneModelo a owl:ObjectProperty ;
    rdfs:domain ex:TomaDePresion18G ;
    rdfs:range ex:PI586001 .

ex:tieneReferencia a owl:ObjectProperty ;
    rdfs:domain ex:TomaDePresion18G ;
    rdfs:range ex:Referencia .

ex:Referencia a owl:Class ;
    rdfs:label "Referencia" ;
    rdfs:comment "Número de referencia del componente." .

ex:tieneCodigo a owl:ObjectProperty ;
    rdfs:domain ex:TomaDePresion18G ;
    rdfs:range ex:Codigo .

ex:Codigo a owl:Class ;
    rdfs:label "Código" ;
    rdfs:comment "Código de identificación del componente." .