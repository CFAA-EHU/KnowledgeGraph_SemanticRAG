@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

ex:TomaDePresion a owl:Class ;
    rdfs:label "Toma de presión"@es ;
    rdfs:comment "Clase que representa una toma de presión en el sistema hidráulico."@es .

ex:PI586001 a owl:Class ;
    rdfs:label "PI 586001"@es ;
    rdfs:comment "Clase que representa el modelo PI 586001 de HYDROTECHNIK."@es .

ex:HYDROTECHNIK a owl:Class ;
    rdfs:label "HYDROTECHNIK"@es ;
    rdfs:comment "Clase que representa la marca HYDROTECHNIK."@es .