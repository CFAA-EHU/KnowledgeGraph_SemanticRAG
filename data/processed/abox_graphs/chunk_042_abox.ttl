@prefix ex: <https://vocab.cfaa.eus/broaching/>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

ex:ModoManual a owl:Class ;
    rdfs:label "ModoManual"@es ;
    rdfs:comment "Modo de trabajo manual"@es .

ex:ModoAutomaticoCargaDescargaManual a owl:Class ;
    rdfs:label "ModoAutomaticoCargaDescargaManual"@es ;
    rdfs:comment "Modo de trabajo automático con carga y descarga manual"@es .