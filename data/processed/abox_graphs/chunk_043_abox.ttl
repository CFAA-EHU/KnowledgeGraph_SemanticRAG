@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:BrocadoraElectromecanicaDeExteriores a owl:Class ;
    rdfs:label "Brocadora Electromecánica de Exteriores" .

ex:CarroPortaPiezas a owl:Class ;
    rdfs:label "Carro Porta-Piezas" .

ex:Servomotor a owl:Class ;
    rdfs:label "Servomotor" .

ex:SistemaPiñonCremallera a owl:Class ;
    rdfs:label "Sistema Piñón-Cremallera" .

ex:tieneMovimiento a owl:ObjectProperty ;
    rdfs:domain ex:BrocadoraElectromecanicaDeExteriores ;
    rdfs:range ex:CarroPortaPiezas .

ex:accionadoPor a owl:ObjectProperty ;
    rdfs:domain ex:CarroPortaPiezas ;
    rdfs:range ex:SistemaPiñonCremallera .

ex:desarrollaFuerzaMaxima a owl:DatatypeProperty ;
    rdfs:domain ex:Servomotor ;
    rdfs:range xsd:decimal .

ex:tieneVelocidad a owl:DatatypeProperty ;
    rdfs:domain ex:Servomotor ;
    rdfs:range xsd:decimal .