@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Brocha_43 a ns1:PiezaRecambio ;
    rdfs:label "brocha"@es ;
    ns1:textoExtracto "la brocha permanece fija"@es .

ns1:BrochadoraExteriores_43 a ns1:Maquina ;
    rdfs:label "brochadora de exteriores de un único puesto"@es ;
    ns1:textoExtracto "Esta máquina es una brochadora de exteriores de un único puesto"@es .

ns1:CarroPortapiezas_43 a ns1:ComponenteMecanico ;
    rdfs:label "carro porta-piezas"@es ;
    ns1:textoExtracto "movimiento de carro porta-piezas (la brocha permanece fija)"@es .

ns1:ParametroFuerzaMaxima_43 a ns1:Parametro ;
    rdfs:label "fuerza máxima"@es ;
    ns1:textoExtracto "que desarrolla una fuerza máxima de 70 kNw"@es ;
    ns1:valor "70 kNw"@es .

ns1:ParametroVelocidad_43 a ns1:Parametro ;
    rdfs:label "velocidad"@es ;
    ns1:textoExtracto "a una velocidad de 40 m/min"@es ;
    ns1:valor "40 m/min"@es .

ns1:Servomotor_43 a ns1:ComponenteElectrico ;
    rdfs:label "servomotor"@es ;
    ns1:textoExtracto "accionado por un sistema piñón cremallera con un servomotor"@es .

ns1:SistemaPinyonCremallera_43 a ns1:ComponenteMecanico ;
    rdfs:label "sistema piñón cremallera"@es ;
    ns1:textoExtracto "accionado por un sistema piñón cremallera"@es .

