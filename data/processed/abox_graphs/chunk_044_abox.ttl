@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Maquina_44 a ns1:Maquina ;
    ns1:compuestoPor ns1:ArmarioElectrico_44,
        ns1:Carenado_44,
        ns1:CarroPortaBrochas_44,
        ns1:CarroPortaPiezas_44,
        ns1:Columna_44,
        ns1:PlatoDivisor_44,
        ns1:SistemaEngrase_44,
        ns1:SistemaHidraulico_44,
        ns1:SistemaLimpiezaBrocha_44,
        ns1:SistemaNeumatico_44,
        ns1:SistemaRefrigeracion_44,
        ns1:Zocalo_44 ;
    ns1:textoExtracto "La máquina se compone de: Zócalo  Columna  Carro porta-piezas  Plato divisor  Carro porta-brochas  Sistema de limpieza de brocha  Sistema neumático  Sistema de engrase  Sistema hidráulico  Sistema de refrigeración  Carenado  Armario eléctrico " .

ns1:ArmarioElectrico_44 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "Armario eléctrico" .

ns1:Carenado_44 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Carenado" .

ns1:CarroPortaBrochas_44 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Carro porta-brochas" .

ns1:CarroPortaPiezas_44 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Carro porta-piezas" .

ns1:Columna_44 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Columna" .

ns1:PlatoDivisor_44 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Plato divisor" .

ns1:SistemaEngrase_44 a ns1:Sistema ;
    ns1:textoExtracto "Sistema de engrase" .

ns1:SistemaHidraulico_44 a ns1:Sistema ;
    ns1:textoExtracto "Sistema hidráulico" .

ns1:SistemaLimpiezaBrocha_44 a ns1:Sistema ;
    ns1:textoExtracto "Sistema de limpieza de brocha" .

ns1:SistemaNeumatico_44 a ns1:Sistema ;
    ns1:textoExtracto "Sistema neumático" .

ns1:SistemaRefrigeracion_44 a ns1:Sistema ;
    ns1:textoExtracto "Sistema de refrigeración" .

ns1:Zocalo_44 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Zócalo" .

