@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix base: <https://vocab.cfaa.eus/broaching/base#> .
@prefix mecanica: <https://vocab.cfaa.eus/broaching/mecanica#> .
@prefix elec: <https://vocab.cfaa.eus/broaching/elec#> .
@prefix hidraulica: <https://vocab.cfaa.eus/broaching/hidraulica#> .
@prefix neumatico: <https://vocab.cfaa.eus/broaching/neumatico#> .

base:Zocalo a owl:Class .
base:Columna a owl:Class .
base:CarroPortaPiezas a owl:Class .
base:PlatoDivisor a owl:Class .
base:CarroPortaBrochas a owl:Class .
base:SistemaLimpiezaBrocha a owl:Class .
neumatico:SistemaNeumatico a owl:Class .
base:SistemaEngrase a owl:Class .
hidraulica:SistemaHidraulico a owl:Class .
base:SistemaRefrigeracion a owl:Class .
base:Carenado a owl:Class .
elec:ArmarioElectrico a owl:Class .

mecanica:tieneZocalo a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:Zocalo .

mecanica:tieneColumna a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:Columna .

mecanica:tieneCarroPortaPiezas a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:CarroPortaPiezas .

mecanica:tienePlatoDivisor a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:PlatoDivisor .

mecanica:tieneCarroPortaBrochas a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:CarroPortaBrochas .

mecanica:tieneSistemaLimpiezaBrocha a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:SistemaLimpiezaBrocha .

mecanica:tieneSistemaNeumatico a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range neumatico:SistemaNeumatico .

mecanica:tieneSistemaEngrase a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:SistemaEngrase .

mecanica:tieneSistemaHidraulico a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range hidraulica:SistemaHidraulico .

mecanica:tieneSistemaRefrigeracion a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:SistemaRefrigeracion .

mecanica:tieneCarenado a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:Carenado .

mecanica:tieneArmarioElectrico a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range elec:ArmarioElectrico .