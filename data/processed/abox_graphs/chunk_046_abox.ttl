@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Columna_46 a ns1:ComponenteMecanico ;
    ns1:compuestoPor ns1:CarroPortapiezas_46,
        ns1:GuiaLineal_46_1,
        ns1:GuiaLineal_46_2 ;
    ns1:textoExtracto "Sobe el zócalo se monta la columna con dos guías lineales por las que se desplaza el carro porta-piezas" .

ns1:ReglaLineal_46 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "dos reglas lineales colocadas en el lateral de la columna" .

ns1:ReglaLineal_46_1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "dos reglas lineales colocadas en el lateral de la columna" .

ns1:ReglaLineal_46_2 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "dos reglas lineales colocadas en el lateral de la columna" .

ns1:CarroPortapiezas_46 a ns1:ComponenteMecanico ;
    ns1:compuestoPor ns1:Servomotor_46_1,
        ns1:Servomotor_46_2,
        ns1:SistemaPinonCremallera_46 ;
    ns1:textoExtracto "el carro porta-piezas" .

ns1:GuiaLineal_46_1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "dos guías lineales por las que se desplaza el carro porta-piezas" .

ns1:GuiaLineal_46_2 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "dos guías lineales por las que se desplaza el carro porta-piezas" .

ns1:Servomotor_46_1 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "dos servomotores colocados sobre el carro porta-piezas" .

ns1:Servomotor_46_2 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "dos servomotores colocados sobre el carro porta-piezas" .

ns1:SistemaPinonCremallera_46 a ns1:ComponenteMecanico ;
    ns1:identificador "WITTENSTEIN" ;
    ns1:textoExtracto "juegos de sistemas piñón/cremallera (WITTENSTEIN) accionados por dos servomotores" .

