@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:CarroPortaPiezas47 a ns1:Maquina ;
    ns1:textoExtracto "El carro porta-piezas lleva seis patines y dos bloqueos hidráulicos en la parte posterior. Para equilibrar el peso del carro, hay colocadas dos guías en la parte trasera de la columna por las que se desplazan dos contrapesos. Cada uno lleva instalados dos patines y un bloqueo hidráulico." ;
    ns1:tieneComponente ns1:BloqueoHidraulico47_1,
        ns1:BloqueoHidraulico47_2,
        ns1:Contrapeso47_1,
        ns1:Contrapeso47_2,
        ns1:Guia47_1,
        ns1:Guia47_2,
        ns1:Patin47_1,
        ns1:Patin47_2,
        ns1:Patin47_3,
        ns1:Patin47_4,
        ns1:Patin47_5,
        ns1:Patin47_6 .

ns1:BloqueoHidraulico47_1 a ns1:ComponenteHidraulico ;
    ns1:textoExtracto "dos bloqueos hidráulicos" .

ns1:BloqueoHidraulico47_2 a ns1:ComponenteHidraulico ;
    ns1:textoExtracto "dos bloqueos hidráulicos" .

ns1:Contrapeso47_1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "dos contrapesos" .

ns1:Contrapeso47_2 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "dos contrapesos" .

ns1:Guia47_1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "dos guías en la parte trasera de la columna" .

ns1:Guia47_2 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "dos guías en la parte trasera de la columna" .

ns1:Patin47_1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "seis patines" .

ns1:Patin47_2 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "seis patines" .

ns1:Patin47_3 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "seis patines" .

ns1:Patin47_4 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "seis patines" .

ns1:Patin47_5 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "seis patines" .

ns1:Patin47_6 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "seis patines" .

