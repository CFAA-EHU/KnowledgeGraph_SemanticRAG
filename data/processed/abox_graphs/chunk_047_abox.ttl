@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix mecanica: <https://vocab.cfaa.eus/broaching/mecanica/> .
@prefix elec: <https://vocab.cfaa.eus/broaching/elec/> .
@prefix base: <https://vocab.cfaa.eus/broaching/base/> .

ex:CarroPortaPieza a owl:Class ;
    rdfs:label "CarroPortaPieza" ;
    rdfs:comment "Componente mecánico que porta piezas en la máquina de brochado." .

ex:Patin a owl:Class ;
    rdfs:label "Patín" ;
    rdfs:comment "Elemento de soporte y deslizamiento en el carro porta-piezas." .

ex:BloqueoHidraulico a owl:Class ;
    rdfs:label "BloqueoHidraulico" ;
    rdfs:comment "Mecanismo de bloqueo hidráulico utilizado en el carro porta-piezas." .

ex:Contrapeso a owl:Class ;
    rdfs:label "Contrapeso" ;
    rdfs:comment "Elemento utilizado para equilibrar el peso del carro porta-piezas." .

ex:Guia a owl:Class ;
    rdfs:label "Guía" ;
    rdfs:comment "Elemento de guía para el desplazamiento de los contrapesos." .

mecanica:tienePatines a owl:ObjectProperty ;
    rdfs:domain ex:CarroPortaPieza ;
    rdfs:range ex:Patin ;
    rdfs:comment "Relación que indica que un carro porta-piezas tiene patines." .

mecanica:tieneBloqueosHidraulicos a owl:ObjectProperty ;
    rdfs:domain ex:CarroPortaPieza ;
    rdfs:range ex:BloqueoHidraulico ;
    rdfs:comment "Relación que indica que un carro porta-piezas tiene bloqueos hidráulicos." .

mecanica:tieneContrapesos a owl:ObjectProperty ;
    rdfs:domain ex:CarroPortaPieza ;
    rdfs:range ex:Contrapeso ;
    rdfs:comment "Relación que indica que un carro porta-piezas tiene contrapesos." .

mecanica:tieneGuia a owl:ObjectProperty ;
    rdfs:domain ex:CarroPortaPieza ;
    rdfs:range ex:Guia ;
    rdfs:comment "Relación que indica que un carro porta-piezas tiene guías." .

mecanica:tienePatinesContrapeso a owl:ObjectProperty ;
    rdfs:domain ex:Contrapeso ;
    rdfs:range ex:Patin ;
    rdfs:comment "Relación que indica que un contrapeso tiene patines." .

mecanica:tieneBloqueoHidraulicoContrapeso a owl:ObjectProperty ;
    rdfs:domain ex:Contrapeso ;
    rdfs:range ex:BloqueoHidraulico ;
    rdfs:comment "Relación que indica que un contrapeso tiene un bloqueo hidráulico." .

mecanica:seDesplazanPor a owl:ObjectProperty ;
    rdfs:domain ex:Contrapeso ;
    rdfs:range ex:Guia ;
    rdfs:comment "Relación que indica que los contrapesos se desplazan por guías." .

ex:FrenoMayr a owl:Class ;
    rdfs:label "FrenoMayr" ;
    rdfs:comment "Tipo específico de freno utilizado en el carro porta-piezas." .

mecanica:tieneFrenoMayr a owl:ObjectProperty ;
    rdfs:domain ex:CarroPortaPieza ;
    rdfs:range ex:FrenoMayr ;
    rdfs:comment "Relación que indica que un carro porta-piezas tiene frenos Mayr." .

mecanica:tieneLado a owl:ObjectProperty ;
    rdfs:domain ex:FrenoMayr ;
    rdfs:range rdfs:Literal ;
    rdfs:comment "Relación que indica el lado del freno Mayr." .

mecanica:tieneNumero a owl:ObjectProperty ;
    rdfs:domain ex:FrenoMayr ;
    rdfs:range rdfs:Literal ;
    rdfs:comment "Relación que indica el número del freno Mayr." .