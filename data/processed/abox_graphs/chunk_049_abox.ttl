@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:ComponenteElectrico_Cables_49_1 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "Desconectar los cables del motor y de la torreta de micros" .

ns1:ComponenteElectrico_TuboNeumatico_49_1 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "y el neumático" .

ns1:ComponenteHidraulico_Tubos_49_1 a ns1:ComponenteHidraulico ;
    ns1:textoExtracto "soltar los tubos hidráulicos" .

ns1:ComponenteMecanico_Canamos_49_1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Colocar dos cáncamos en los agujeros roscados (M12) de la cara superior del disco." .

ns1:ComponenteMecanico_PlataformaInterior_49_1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Abrir la plataforma interior, colocar unas eslingas en los cáncamos y por medio de una grúa sacar el plato divisor hacia arriba." .

ns1:ComponenteMecanico_PlatoBasePlana_49_1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Colocar el plato en la base plana." .

ns1:ComponenteMecanico_TornillosAjustePlato_49_1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Soltar los tres tornillos que fijan las piezas de ajuste del plato." .

ns1:ComponenteMecanico_TornillosBasePlato_49_1 a ns1:ComponenteMecanico ;
    ns1:identificador "M12" ;
    ns1:textoExtracto "Soltar los tornillos que fijan la base del plato divisor al carro porta-piezas." .

ns1:ComponenteMecanico_TornillosPlatoBase_49_1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Soltar los cuatro tornillos que fijan el plato a la base." .

ns1:ComponenteMecanico_TornillosPlatoCarro_49_1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Amarrar los siete tornillos que fijan el plato al carro porta-piezas y los tres tornillos que fijan las piezas de ajuste del plato." .

ns1:Figura_4_10_49_1 a ns1:Figura ;
    ns1:textoExtracto "Figura 4-10. Cambio de base (5 ajuste plato" .

ns1:Figura_4_6_49_1 a ns1:Figura ;
    ns1:textoExtracto "Figura 4-6. Cambio de base (1)" .

ns1:Figura_4_7_49_1 a ns1:Figura ;
    ns1:textoExtracto "Figura 4-7. Cambio de base (2)" .

ns1:Figura_4_8_49_1 a ns1:Figura ;
    ns1:textoExtracto "Figura 4-8. Cambio de base (3)" .

ns1:Figura_4_9_49_1 a ns1:Figura ;
    ns1:textoExtracto "Figura 4-9. Cambio de base (4 amarre amarre plato plato)" .

ns1:Maquina_49_1 a ns1:Maquina ;
    ns1:textoExtracto "Para realizar el cambio de base seguir los siguientes pasos: 1. Consignar la máquina para realizar la operación." .

ns1:Motor_49_1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Desconectar los cables del motor y de la torreta de micros; soltar los tubos hidráulicos y el neumático." .

