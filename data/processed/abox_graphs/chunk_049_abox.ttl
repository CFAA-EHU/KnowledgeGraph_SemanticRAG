@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix mec: <https://vocab.cfaa.eus/mecanica/> .
@prefix elec: <https://vocab.cfaa.eus/electrica/> .
@prefix base: <https://vocab.cfaa.eus/base/> .

ex:CambioDeBase a owl:Class ;
    rdfs:label "Cambio de base" ;
    rdfs:comment "Procedimiento para realizar el cambio de base en la máquina" .

ex:ConsignacionMaquina a owl:Class ;
    rdfs:label "Consignación de máquina" ;
    rdfs:comment "Proceso de consignación de la máquina para realizar operaciones" .

ex:DesconexionComponentes a owl:Class ;
    rdfs:label "Desconexión de componentes" ;
    rdfs:comment "Proceso de desconexión de cables y tubos" .

ex:Cancamo a owl:Class ;
    rdfs:label "Cáncamo" ;
    rdfs:comment "Elemento utilizado para fijar y levantar componentes" .

ex:AgujeroRoscado a owl:Class ;
    rdfs:label "Agujero roscado" ;
    rdfs:comment "Agujero con rosca para fijación de componentes" .

ex:Tornillo a owl:Class ;
    rdfs:label "Tornillo" ;
    rdfs:comment "Elemento de fijación" .

ex:PlataformaInterior a owl:Class ;
    rdfs:label "Plataforma interior" ;
    rdfs:comment "Plataforma interior de la máquina" .

ex:Eslinga a owl:Class ;
    rdfs:label "Eslinga" ;
    rdfs:comment "Elemento utilizado para levantar componentes" .

ex:Grúa a owl:Class ;
    rdfs:label "Grúa" ;
    rdfs:comment "Equipo utilizado para levantar y mover componentes pesados" .

ex:PlatoDivisor a owl:Class ;
    rdfs:label "Plato divisor" ;
    rdfs:comment "Componente de la máquina que se cambia de base" .

ex:BasePlana a owl:Class ;
    rdfs:label "Base plana" ;
    rdfs:comment "Base plana donde se coloca el plato divisor" .

ex:CarroPortaPiezas a owl:Class ;
    rdfs:label "Carro porta-piezas" ;
    rdfs:comment "Carro que porta las piezas de la máquina" .

ex:PiezaDeAjuste a owl:Class ;
    rdfs:label "Pieza de ajuste" ;
    rdfs:comment "Pieza utilizada para ajustar el plato divisor" .

mec:consignarMaquina a owl:ObjectProperty ;
    rdfs:domain ex:CambioDeBase ;
    rdfs:range ex:ConsignacionMaquina .

mec:desconectarCables a owl:ObjectProperty ;
    rdfs:domain ex:DesconexionComponentes ;
    rdfs:range elec:Cable .

mec:desconectarTubosHidraulicos a owl:ObjectProperty ;
    rdfs:domain ex:DesconexionComponentes ;
    rdfs:range base:TuboHidraulico .

mec:desconectarNeumatico a owl:ObjectProperty ;
    rdfs:domain ex:DesconexionComponentes ;
    rdfs:range base:TuboNeumatico .

mec:colocarCancamos a owl:ObjectProperty ;
    rdfs:domain ex:CambioDeBase ;
    rdfs:range ex:Cancamo .

mec:colocarCancamosEn a owl:ObjectProperty ;
    rdfs:domain ex:Cancamo ;
    rdfs:range ex:AgujeroRoscado .

mec:soltarTornillos a owl:ObjectProperty ;
    rdfs:domain ex:CambioDeBase ;
    rdfs:range ex:Tornillo .

mec:abrirPlataformaInterior a owl:ObjectProperty ;
    rdfs:domain ex:CambioDeBase ;
    rdfs:range ex:PlataformaInterior .

mec:colocarEslingas a owl:ObjectProperty ;
    rdfs:domain ex:CambioDeBase ;
    rdfs:range ex:Eslinga .

mec:sacarPlatoDivisor a owl:ObjectProperty ;
    rdfs:domain ex:CambioDeBase ;
    rdfs:range ex:PlatoDivisor .

mec:soltarBaseParaCambio a owl:ObjectProperty ;
    rdfs:domain ex:CambioDeBase ;
    rdfs:range base:Base .

mec:colocarPlatoEn a owl:ObjectProperty ;
    rdfs:domain ex:CambioDeBase ;
    rdfs:range ex:BasePlana .

mec:introducirConjunto a owl:ObjectProperty ;
    rdfs:domain ex:CambioDeBase ;
    rdfs:range ex:PlatoDivisor .

mec:amarrarTornillos a owl:ObjectProperty ;
    rdfs:domain ex:CambioDeBase ;
    rdfs:range ex:Tornillo .

mec:soltarEslingas a owl:ObjectProperty ;
    rdfs:domain ex:CambioDeBase ;
    rdfs:range ex:Eslinga .

mec:quitarCancamos a owl:ObjectProperty ;
    rdfs:domain ex:CambioDeBase ;
    rdfs:range ex:Cancamo .

mec:retirarGrúa a owl:ObjectProperty ;
    rdfs:domain ex:CambioDeBase ;
    rdfs:range ex:Grúa .

elec:Cable a owl:Class ;
    rdfs:label "Cable" ;
    rdfs:comment "Cable eléctrico" .

base:TuboHidraulico a owl:Class ;
    rdfs:label "Tubo hidráulico" ;
    rdfs:comment "Tubo utilizado en sistemas hidráulicos" .

base:TuboNeumatico a owl:Class ;
    rdfs:label "Tubo neumático" ;
    rdfs:comment "Tubo utilizado en sistemas neumáticos" .

base:Base a owl:Class ;
    rdfs:label "Base" ;
    rdfs:comment "Base de la máquina" .

ex:Motor a owl:Class ;
    rdfs:label "Motor" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Motor> .