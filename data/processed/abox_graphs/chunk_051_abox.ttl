@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:CarroPortaBrochas a owl:Class ;
    rdfs:label "CarroPortaBrochas" ;
    rdfs:comment "Componente que sostiene las herramientas y está fijado a la columna." .

ex:Herramienta a owl:Class ;
    rdfs:label "Herramienta" ;
    rdfs:comment "Elemento utilizado en el proceso de mecanizado." .

ex:Columna a owl:Class ;
    rdfs:label "Columna" ;
    rdfs:comment "Estructura a la que está fijado el carro porta-brochas." .

ex:CarroPortaPiezas a owl:Class ;
    rdfs:label "CarroPortaPiezas" ;
    rdfs:comment "Componente que realiza el desplazamiento durante el proceso de mecanizado." .

ex:ProcesoMecanizado a owl:Class ;
    rdfs:label "ProcesoMecanizado" ;
    rdfs:comment "Proceso durante el cual el carro porta-brochas permanece quieto." .

ex:amarrar a owl:ObjectProperty ;
    rdfs:domain ex:CarroPortaBrochas ;
    rdfs:range ex:Herramienta ;
    rdfs:label "amarrar" ;
    rdfs:comment "Relación que indica que las herramientas están amarradas al carro porta-brochas." .

ex:estaFijadoA a owl:ObjectProperty ;
    rdfs:domain ex:CarroPortaBrochas ;
    rdfs:range ex:Columna ;
    rdfs:label "estaFijadoA" ;
    rdfs:comment "Relación que indica que el carro porta-brochas está fijado a la columna." .

ex:realizaDesplazamiento a owl:ObjectProperty ;
    rdfs:domain ex:CarroPortaPiezas ;
    rdfs:range ex:ProcesoMecanizado ;
    rdfs:label "realizaDesplazamiento" ;
    rdfs:comment "Relación que indica que el carro porta-piezas realiza el desplazamiento durante el proceso de mecanizado." .

ex:permaneceQuietoDurante a owl:ObjectProperty ;
    rdfs:domain ex:CarroPortaBrochas ;
    rdfs:range ex:ProcesoMecanizado ;
    rdfs:label "permaneceQuietoDurante" ;
    rdfs:comment "Relación que indica que el carro porta-brochas permanece quieto durante el proceso de mecanizado." .