@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:C_ncamosLaterales_52 a ns1:ComponenteMecanico ;
    ns1:identificador "cáncamos laterales" ;
    ns1:textoExtracto "cáncamos laterales" .

ns1:CarroPortaPiezas_52 a ns1:ComponenteMecanico ;
    ns1:identificador "carro porta-piezas" ;
    ns1:textoExtracto "El carro porta-piezas" .

ns1:Eslingas_52 a ns1:Consumible ;
    ns1:identificador "eslingas" ;
    ns1:textoExtracto "eslingas" .

ns1:Gr_a_52 a ns1:Maquina ;
    ns1:identificador "grúa" ;
    ns1:textoExtracto "la grúa" .

ns1:Herramienta_52 a ns1:Herramienta ;
    ns1:identificador "herramienta" ;
    ns1:textoExtracto "cambio de herramienta" .

ns1:Maquina_52 a ns1:Maquina ;
    ns1:textoExtracto "La máquina dispone de dos plataformas a distintas alturas, una en cada lateral de la máquina, con una puerta para acceder al interior de la máquina y realizar el cambio de herramienta." ;
    ns1:tieneComponente ns1:PlataformaDerecha_52,
        ns1:PlataformaIzquierda_52,
        ns1:PortonFrontal_52,
        ns1:PuertaLateralDerecha_52,
        ns1:PuertaLateralIzquierda_52 .

ns1:PortaCremalleras_52 a ns1:ComponenteMecanico ;
    ns1:identificador "porta-cremalleras" ;
    ns1:textoExtracto "porta-cremalleras" .

ns1:TornillosAzules_52 a ns1:PiezaRecambio ;
    ns1:identificador "tornillos restantes (AZULES)" ;
    ns1:textoExtracto "los tornillos restantes (AZULES), tanto frontales como laterales" .

ns1:TornillosRojos_52 a ns1:PiezaRecambio ;
    ns1:identificador "tornillos superiores (ROJOS)" ;
    ns1:textoExtracto "los tornillos del porta-cremalleras y de las referencias laterales de la parte superior (ROJOS)" .

ns1:PlataformaDerecha_52 a ns1:InterfazUsuario ;
    ns1:textoExtracto "una plataforma a distintas alturas, en el lateral derecho de la máquina" .

ns1:PlataformaIzquierda_52 a ns1:InterfazUsuario ;
    ns1:textoExtracto "una plataforma a distintas alturas, en el lateral izquierdo de la máquina" .

ns1:PortonFrontal_52 a ns1:ElementoSeguridad ;
    ns1:identificador "portón frontal" ;
    ns1:textoExtracto "el portón frontal" .

ns1:PuertaLateralDerecha_52 a ns1:ElementoSeguridad ;
    ns1:identificador "puerta lateral derecha" ;
    ns1:textoExtracto "una puerta para acceder al interior de la máquina" .

ns1:PuertaLateralIzquierda_52 a ns1:ElementoSeguridad ;
    ns1:identificador "puerta lateral izquierda" ;
    ns1:textoExtracto "la puerta lateral izquierda" .

