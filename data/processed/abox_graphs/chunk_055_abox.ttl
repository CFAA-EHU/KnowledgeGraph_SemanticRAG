@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:SistemaDeEngrase a owl:Class ;
    rdfs:label "Sistema de engrase" ;
    rdfs:comment "Compuesto por engrase automático de grasa y engrase manual de aceite." .

ex:CentralDeLubricacion a owl:Class ;
    rdfs:label "Central de lubricación" ;
    rdfs:comment "Parte del sistema de engrase automático." .

ex:PiñonDeLubricacion a owl:Class ;
    rdfs:label "Piñón de lubricación" ;
    rdfs:comment "De espuma de poliuretano de célula abierta." .

ex:SistemaPiñonCremallera a owl:Class ;
    rdfs:label "Sistema piñón-cremallera" ;
    rdfs:comment "Parte del sistema de engrase automático." .

ex:BombaDeEmbolo a owl:Class ;
    rdfs:label "Bomba de émbolo" ;
    rdfs:comment "Parte del sistema de engrase manual." .

ex:Rodamiento a owl:Class ;
    rdfs:label "Rodamiento" ;
    rdfs:comment "Parte lubricada por el sistema de engrase manual." .

ex:GrasaAlphaG11NLGI01 a owl:Class ;
    rdfs:label "Grasa Alpha G11 NLGI 0-1" ;
    rdfs:comment "176cSt – 40ºC." .

ex:AceiteG220ISO3498 a owl:Class ;
    rdfs:label "Aceite G220 según ISO 3498" ;
    rdfs:comment "220cSt – 40ºC." .

ex:tieneComponente a owl:ObjectProperty ;
    rdfs:domain ex:SistemaDeEngrase ;
    rdfs:range owl:Class .

ex:tieneMaterial a owl:ObjectProperty ;
    rdfs:domain ex:PiñonDeLubricacion ;
    rdfs:range owl:Class .

ex:tieneFuncion a owl:ObjectProperty ;
    rdfs:domain ex:PiñonDeLubricacion ;
    rdfs:range owl:Class .

ex:tieneFrecuencia a owl:ObjectProperty ;
    rdfs:domain ex:BombaDeEmbolo ;
    rdfs:range owl:Class .

ex:tieneLubricante a owl:ObjectProperty ;
    rdfs:domain ex:SistemaDeEngrase ;
    rdfs:range owl:Class .

ex:tieneViscosidad a owl:DatatypeProperty ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:string .

ex:tieneTemperatura a owl:DatatypeProperty ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:string .