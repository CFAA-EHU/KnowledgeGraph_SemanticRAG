@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaEngrase_55 a ns1:Sistema ;
    rdfs:label "Sistema de engrase"@es ;
    ns1:compuestoPor ns1:EngraseAutomatico_55,
        ns1:EngraseManual_55 ;
    ns1:textoExtracto "El sistema de engrase se encuentra situado en la parte posterior de la máquina, debajo del sistema neumático."@es .

ns1:AceiteG220ISO3498_55 a ns1:Consumible ;
    rdfs:label "Aceite G220 según ISO 3498"@es ;
    ns1:identificador "G220 según ISO 3498 (220cSt – 40ºC)" ;
    ns1:textoExtracto "El sistema manual emplea un aceite G220 según ISO 3498 (220cSt – 40ºC)"@es .

ns1:BombaEmbolo_55 a ns1:ComponenteMecanico ;
    rdfs:label "Bomba de émbolo"@es ;
    ns1:textoExtracto "El engrase manual está compuesto por una bomba de émbolo con mando manual que se encarga de lubricar los rodamientos de los piñones superiores."@es .

ns1:CentralLubricacion_55 a ns1:ComponenteElectrico ;
    rdfs:label "Central de lubricación"@es ;
    ns1:textoExtracto "El engrase automático está compuesto por una central de lubricación y un piñón que lubrica el sistema piñón-cremallera."@es .

ns1:EngraseAutomatico_55 a ns1:Componente ;
    rdfs:label "Engrase automático"@es ;
    ns1:compuestoPor ns1:CentralLubricacion_55,
        ns1:PinonLubricacion_55 ;
    ns1:textoExtracto "El engrase automático está compuesto por una central de lubricación y un piñón que lubrica el sistema piñón-cremallera."@es ;
    ns1:tieneComponente ns1:GrassaAlphaG11NLGI01_55 .

ns1:EngraseManual_55 a ns1:Componente ;
    rdfs:label "Engrase manual"@es ;
    ns1:compuestoPor ns1:BombaEmbolo_55 ;
    ns1:textoExtracto "El engrase manual está compuesto por una bomba de émbolo con mando manual que se encarga de lubricar los rodamientos de los piñones superiores."@es ;
    ns1:tieneComponente ns1:AceiteG220ISO3498_55 .

ns1:GrassaAlphaG11NLGI01_55 a ns1:Consumible ;
    rdfs:label "Grassa Alpha G11 NLGI 0-1"@es ;
    ns1:identificador "Alpha G11 NLGI 0-1 (176cSt – 40ºC)" ;
    ns1:textoExtracto "El sistema automático emplea una grasa Alpha G11 NLGI 0-1 (176cSt – 40ºC)"@es .

ns1:PinonLubricacion_55 a ns1:ComponenteMecanico ;
    rdfs:label "Piñón de lubricación"@es ;
    ns1:textoExtracto "El piñón de lubricación es de espuma de poliuretano de célula abierta y garantiza un suministro óptimo de lubricante durante largos periodos de tiempo."@es .

