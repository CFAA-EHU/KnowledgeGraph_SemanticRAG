@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaHidraulico_56 a ns1:Sistema ;
    rdfs:label "Sistema hidráulico"@es ;
    ns1:compuestoPor ns1:BombaPistones_56,
        ns1:Electrovalvulas_56,
        ns1:Filtro_56,
        ns1:IndicadorNivelTermometro_56,
        ns1:ManometroVertical_56,
        ns1:MotorGrupoHidraulico_56,
        ns1:PresostatoElectronico_56,
        ns1:ReductoraPresion_56,
        ns1:SemiAcoplamientos_56,
        ns1:SensorNivel_56 ;
    ns1:textoExtracto "El sistema hidráulico se encuentra en el lateral izquierdo de la máquina y está compuesto por una bomba de pistones, un indicador de nivel con termómetro, un sensor de nivel, semi-acoplamientos, un motor, una reductora de presión, electroválvulas, un presostato electrónico, un manómetro vertical y un filtro."@es ;
    ns1:tieneComponente ns1:BombaPistones_56,
        ns1:Electrovalvulas_56,
        ns1:Filtro_56,
        ns1:IndicadorNivelTermometro_56,
        ns1:ManometroVertical_56,
        ns1:MotorGrupoHidraulico_56,
        ns1:PresostatoElectronico_56,
        ns1:ReductoraPresion_56,
        ns1:SemiAcoplamientos_56,
        ns1:SensorNivel_56 .

ns1:BombaPistones_56 a ns1:ComponenteHidraulico ;
    rdfs:label "Bomba de pistones"@es ;
    ns1:textoExtracto "bomba de pistones"@es .

ns1:Electrovalvulas_56 a ns1:ComponenteHidraulico ;
    rdfs:label "Electroválvulas"@es ;
    ns1:textoExtracto "electroválvulas"@es .

ns1:Filtro_56 a ns1:ComponenteHidraulico ;
    rdfs:label "Filtro"@es ;
    ns1:textoExtracto "filtro"@es .

ns1:IndicadorNivelTermometro_56 a ns1:ComponenteHidraulico ;
    rdfs:label "Indicador de nivel con termómetro"@es ;
    ns1:textoExtracto "indicador de nivel con termómetro"@es .

ns1:ManometroVertical_56 a ns1:ComponenteHidraulico ;
    rdfs:label "Manómetro vertical"@es ;
    ns1:textoExtracto "manómetro vertical"@es .

ns1:MotorGrupoHidraulico_56 a ns1:ComponenteElectrico ;
    rdfs:label "Motor grupo hidráulico"@es ;
    ns1:identificador "M6" ;
    ns1:textoExtracto "M6: MOTOR GRUPO HIDRÁULICO"@es .

ns1:PresostatoElectronico_56 a ns1:Sensor ;
    rdfs:label "Presostato electrónico"@es ;
    ns1:identificador "BP714" ;
    ns1:textoExtracto "BP714: MESA ABAJO PRESOSTATO"@es .

ns1:ReductoraPresion_56 a ns1:ComponenteHidraulico ;
    rdfs:label "Reductora de presión"@es ;
    ns1:textoExtracto "reductora de presión"@es .

ns1:SemiAcoplamientos_56 a ns1:ComponenteHidraulico ;
    rdfs:label "Semi-acoplamientos"@es ;
    ns1:textoExtracto "semi-acoplamientos"@es .

ns1:SensorNivel_56 a ns1:Sensor ;
    rdfs:label "Sensor de nivel"@es ;
    ns1:textoExtracto "sensor de nivel"@es .

