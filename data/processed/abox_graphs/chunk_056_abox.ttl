@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix mech: <http://www.semanticweb.org/ontologies/2023/mechanics#> .
@prefix elec: <http://www.semanticweb.org/ontologies/2023/electronics#> .
@prefix base: <http://www.semanticweb.org/ontologies/2023/base#> .
@prefix admin: <https://admin-shell.io/dictionary/> .

@prefix hidraulico: <http://www.semanticweb.org/ontologies/2023/hydraulic#> .

owl:Ontology rdf:about "https://vocab.cfaa.eus/broaching/" ;
    rdfs:label "Ontología de Brochado" ;
    rdfs:comment "Ontología para el dominio de máquinas de brochado." .

# Clases
hidraulico:SistemaHidraulico a owl:Class ;
    rdfs:label "Sistema Hidráulico" ;
    rdfs:comment "Sistema hidráulico de la máquina de brochado." .

hidraulico:BombaPistones a owl:Class ;
    rdfs:label "Bomba de Pistones" ;
    rdfs:comment "Bomba de pistones del sistema hidráulico." ;
    rdfs:subClassOf ex:Bomba .

hidraulico:IndicadorNivelTermometro a owl:Class ;
    rdfs:label "Indicador de Nivel con Termómetro" ;
    rdfs:comment "Indicador de nivel con termómetro del sistema hidráulico." ;
    rdfs:subClassOf ex:IndicadorDeNivel .

hidraulico:SensorNivel a owl:Class ;
    rdfs:label "Sensor de Nivel" ;
    rdfs:comment "Sensor de nivel del sistema hidráulico." ;
    rdfs:subClassOf admin:Sensor .

hidraulico:SemiAcoplamiento a owl:Class ;
    rdfs:label "Semi-Acoplamiento" ;
    rdfs:comment "Semi-acoplamiento del sistema hidráulico." ;
    rdfs:subClassOf ex:SemiAcoplamiento .

hidraulico:Motor a owl:Class ;
    rdfs:label "Motor" ;
    rdfs:comment "Motor del sistema hidráulico." ;
    rdfs:subClassOf admin:Motor .

hidraulico:ReductoraPresion a owl:Class ;
    rdfs:label "Reductora de Presión" ;
    rdfs:comment "Reductora de presión del sistema hidráulico." ;
    rdfs:subClassOf ex:ReductoraPresion .

hidraulico:Electrovalvula a owl:Class ;
    rdfs:label "Electroválvula" ;
    rdfs:comment "Electroválvula del sistema hidráulico." ;
    rdfs:subClassOf ex:Electrovalvula .

hidraulico:PresostatoElectronico a owl:Class ;
    rdfs:label "Presostato Electrónico" ;
    rdfs:comment "Presostato electrónico del sistema hidráulico." ;
    rdfs:subClassOf ex:Presostato .

hidraulico:ManometroVertical a owl:Class ;
    rdfs:label "Manómetro Vertical" ;
    rdfs:comment "Manómetro vertical del sistema hidráulico." ;
    rdfs:subClassOf ex:Manometro .

hidraulico:Filtro a owl:Class ;
    rdfs:label "Filtro" ;
    rdfs:comment "Filtro del sistema hidráulico." ;
    rdfs:subClassOf ex:Filtro .

hidraulico:Mesa a owl:Class ;
    rdfs:label "Mesa" ;
    rdfs:comment "Mesa de la máquina de brochado." ;
    rdfs:subClassOf ex:Mesa .

hidraulico:CarroPortaPieza a owl:Class ;
    rdfs:label "Carro Porta-Piezas" ;
    rdfs:comment "Carro porta-piezas de la máquina de brochado." ;
    rdfs:subClassOf ex:CarroPortaPieza .

hidraulico:Contrapeso a owl:Class ;
    rdfs:label "Contrapeso" ;
    rdfs:comment "Contrapeso de la máquina de brochado." ;
    rdfs:subClassOf ex:Contrapeso .

# Propiedades de objeto
mech:estaCompuestoPor a owl:ObjectProperty ;
    rdfs:label "está compuesto por" ;
    rdfs:comment "Relación que indica que un sistema está compuesto por componentes." .

mech:ejecutaMovimiento a owl:ObjectProperty ;
    rdfs:label "ejecuta movimiento" ;
    rdfs:comment "Relación que indica que un sistema ejecuta movimientos." .

mech:acciona a owl:ObjectProperty ;
    rdfs:label "acciona" ;
    rdfs:comment "Relación que indica que un sistema acciona componentes." .

# Propiedades de datos
base:tieneDatosDePlaca a owl:DatatypeProperty ;
    rdfs:label "tiene datos de placa" ;
    rdfs:comment "Relación que indica los datos de placa de un componente." .

base:tieneModelo a owl:DatatypeProperty ;
    rdfs:label "tiene modelo" ;
    rdfs:comment "Relación que indica el modelo de un componente." .

base:tieneCodigo a owl:DatatypeProperty ;
    rdfs:label "tiene código" ;
    rdfs:comment "Relación que indica el código de un componente." .