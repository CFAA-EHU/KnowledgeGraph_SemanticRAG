@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix mec: <https://admin-shell.io/dictionary/Mecanica/> .
@prefix elec: <https://admin-shell.io/dictionary/Electronica/> .
@prefix hid: <https://admin-shell.io/dictionary/Hidraulica/> .

ex:SistemaHidraulico a owl:Class ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:BombaDePistones a owl:Class ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:IndicadorNivelConTermometro a owl:Class ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:SensorNivel a owl:Class ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Sensor> .

ex:SemiAcoplamiento a owl:Class ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:Motor a owl:Class ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Motor> .

ex:ReductoraPresion a owl:Class ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:Electrovalvula a owl:Class ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:PresostatoElectronico a owl:Class ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:ManometroVertical a owl:Class ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:Filtro a owl:Class ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:Mesa a owl:Class ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:CarroPortaPieza a owl:Class ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:Contrapeso a owl:Class ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:Bloqueo a owl:Class ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:FrenoMayr a owl:Class ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:MovimientoSubida a owl:Class ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:MovimientoBajada a owl:Class ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:estaCompuestoPor a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range owl:Class .

ex:ejecutaMovimiento a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range owl:Class .

ex:accionaBloqueo a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:Bloqueo .

ex:tieneSensorNivel a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:SensorNivel .

ex:tieneIndicadorNivelConTermometro a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:IndicadorNivelConTermometro .

ex:tieneBombaDePistones a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:BombaDePistones .

ex:tieneSemiAcoplamiento a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:SemiAcoplamiento .

ex:tieneMotor a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:Motor .

ex:tieneReductoraPresion a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:ReductoraPresion .

ex:tieneElectrovalvula a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:Electrovalvula .

ex:tienePresostatoElectronico a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:PresostatoElectronico .

ex:tieneManometroVertical a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:ManometroVertical .

ex:tieneFiltro a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:Filtro .

ex:tieneMesa a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:Mesa .

ex:tieneCarroPortaPieza a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:CarroPortaPieza .

ex:tieneContrapeso a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:Contrapeso .

ex:tieneFrenoMayr a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:FrenoMayr .

ex:tieneMovimientoSubida a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:MovimientoSubida .

ex:tieneMovimientoBajada a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:MovimientoBajada .

ex:tieneBloqueo a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:Bloqueo .

ex:tieneMotorGrupoHidraulico a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:Motor ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

ex:tieneNivelMinimoGrupoHidraulico a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:SensorNivel ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

ex:tieneMesaArriba a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:Mesa ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

ex:tieneMesaAbajo a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:Mesa ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

ex:tieneFrenoMayrDesbloqueo a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:FrenoMayr ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

ex:tieneMesaAbajoPresostato a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:PresostatoElectronico ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

ex:tieneBloqueoMayrCarroTracionDesbloqueado a owl:ObjectProperty ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:Bloqueo ;
    rdfs:comment "Incompleto: Requiere resolución externa" .