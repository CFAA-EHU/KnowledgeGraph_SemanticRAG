@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SistemaHidraulico429 a ex:Sistema ;
    ex:textoExtracto "El sistema hidráulico se encuentra en el lateral izquierdo de la máquina y está compuesto por una bomba de pistones, un indicador de nivel con termómetro, un sensor de nivel, semi-acoplamientos, un motor, una reductora de presión, electroválvulas, un presostato electrónico, un manómetro vertical y un filtro." ;
    ex:compuestoPor ex:BombaPistones429, ex:IndicadorNivelTermometro429, ex:SensorNivel429, ex:SemiAcoplamientos429, ex:MotorGrupoHidraulicoM6, ex:ReductoraPresion429, ex:Electrovalvulas429, ex:PresostatoElectronicoBP714, ex:ManometroVertical429, ex:Filtro429 .

ex:BombaPistones429 a ex:ComponenteHidraulico ;
    ex:textoExtracto "bomba de pistones" .

ex:IndicadorNivelTermometro429 a ex:ComponenteHidraulico ;
    ex:textoExtracto "indicador de nivel con termómetro" .

ex:SensorNivel429 a ex:Sensor ;
    ex:textoExtracto "sensor de nivel" .

ex:SemiAcoplamientos429 a ex:ComponenteHidraulico ;
    ex:textoExtracto "semi-acoplamientos" .

ex:MotorGrupoHidraulicoM6 a ex:ComponenteElectrico ;
    ex:identificador "M6" ;
    ex:textoExtracto "MOTOR GRUPO HIDRÁULICO" .

ex:ReductoraPresion429 a ex:ComponenteHidraulico ;
    ex:textoExtracto "reductora de presión" .

ex:Electrovalvulas429 a ex:ComponenteHidraulico ;
    ex:textoExtracto "electroválvulas" .

ex:PresostatoElectronicoBP714 a ex:Sensor ;
    ex:identificador "BP714" ;
    ex:textoExtracto "presostato electrónico" .

ex:ManometroVertical429 a ex:ComponenteHidraulico ;
    ex:textoExtracto "manómetro vertical" .

ex:Filtro429 a ex:ComponenteHidraulico ;
    ex:textoExtracto "filtro" .