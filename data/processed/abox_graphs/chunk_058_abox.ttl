@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:ArmarioElectrico a owl:Class ;
    rdfs:label "Armario eléctrico"@es .

ex:PLC a owl:Class ;
    rdfs:label "PLC"@es .

ex:MovimientoSecuencial a owl:Class ;
    rdfs:label "Movimiento secuencial"@es .

ex:Mecanismo a owl:Class ;
    rdfs:label "Mecanismo"@es .

ex:controla a owl:ObjectProperty ;
    rdfs:domain ex:PLC ;
    rdfs:range ex:MovimientoSecuencial .

ex:disponeDe a owl:ObjectProperty ;
    rdfs:domain ex:ArmarioElectrico ;
    rdfs:range ex:PLC .

ex:alimentadoA a owl:DatatypeProperty ;
    rdfs:domain ex:ArmarioElectrico ;
    rdfs:range xsd:string .

ex:ArmarioElectrico rdfs:comment "El armario eléctrico está colocado en la parte derecha de la máquina y es alimentado a 380 volt - 50 Hz."@es .