@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Maquina a owl:Class ;
    rdfs:label "Máquina" .

ex:Cáncamo a owl:Class ;
    rdfs:label "Cáncamo" .

ex:Grúa a owl:Class ;
    rdfs:label "Grúa" .

ex:AparatoElevador a owl:Class ;
    rdfs:label "Aparato elevador" .

ex:Cadena a owl:Class ;
    rdfs:label "Cadena" .

ex:Cuerda a owl:Class ;
    rdfs:label "Cuerda" .

ex:Gancho a owl:Class ;
    rdfs:label "Gancho" .

ex:Ojal a owl:Class ;
    rdfs:label "Ojal" .

ex:EslingaHomologada a owl:Class ;
    rdfs:label "Eslinga homologada" ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

ex:Defensa a owl:Class ;
    rdfs:label "Defensa" .

ex:CarretillaElevadora a owl:Class ;
    rdfs:label "Carretilla elevadora" .

ex:Dimensiones a owl:Class ;
    rdfs:label "Dimensiones" .

ex:Peso a owl:Class ;
    rdfs:label "Peso" .

ex:EspacioDisponible a owl:Class ;
    rdfs:label "Espacio disponible" .

ex:DeclaracionCE a owl:Class ;
    rdfs:label "Declaración CE" .

ex:tieneCáncamos a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:Cáncamo .

ex:tieneAparatoElevador a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:AparatoElevador .

ex:tieneCadena a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:Cadena .

ex:tieneCuerda a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:Cuerda .

ex:tieneGancho a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:Gancho .

ex:tieneOjal a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:Ojal .

ex:tieneEslingaHomologada a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:EslingaHomologada .

ex:tieneDefensa a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:Defensa .

ex:tieneCarretillaElevadora a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:CarretillaElevadora .

ex:tieneDimensiones a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:Dimensiones .

ex:tienePeso a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:Peso .

ex:tieneEspacioDisponible a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:EspacioDisponible .

ex:tieneDeclaracionCE a owl:ObjectProperty ;
    rdfs:domain ex:EslingaHomologada ;
    rdfs:range ex:DeclaracionCE .

ex:requiereCargaNominal a owl:ObjectProperty ;
    rdfs:domain ex:AparatoElevador ;
    rdfs:range xsd:decimal .

ex:requiereLongitudEslinga a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range xsd:decimal .

ex:requiereHomologacion a owl:ObjectProperty ;
    rdfs:domain ex:EslingaHomologada ;
    rdfs:range xsd:boolean .