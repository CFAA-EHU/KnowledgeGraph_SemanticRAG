@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

ex:EslingaHomologada a owl:Class ;
    rdfs:label "Eslinga homologada con declaración 'CE' de conformidad" ;
    rdfs:comment "Eslinga homologada con declaración 'CE' de conformidad para evitar situaciones de riesgo por posibles roturas de eslingas defectuosas." .

ex:Tablon a owl:Class ;
    rdfs:label "Tablon" ;
    rdfs:comment "Tablon o trapo colocado en puntos de contacto entre eslingas y máquina para evitar daños." .

ex:DepositoAceite a owl:Class ;
    rdfs:label "Deposito de aceite" ;
    rdfs:comment "Deposito de aceite que debe estar vacío durante el transporte de la máquina." .

ex:TaponCierre a owl:Class ;
    rdfs:label "Tapon de cierre" ;
    rdfs:comment "Tapon de cierre que debe estar bien cerrado durante el transporte de la máquina." .

ex:Maquina a owl:Class ;
    rdfs:label "Maquina" ;
    rdfs:comment "Maquina que debe ser levantada inicialmente unos pocos centímetros del suelo para verificar su equilibrio." .

ex:Suelo a owl:Class ;
    rdfs:label "Suelo" ;
    rdfs:comment "Suelo sobre el que se levanta la máquina para verificar su equilibrio." .

ex:verificarEquilibrio a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:Suelo .

ex:levantarInicialmente a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:Suelo .

ex:colocarTablon a owl:ObjectProperty ;
    rdfs:domain ex:Tablon ;
    rdfs:range ex:Maquina .

ex:evitarDanios a owl:ObjectProperty ;
    rdfs:domain ex:Tablon ;
    rdfs:range ex:Maquina .

ex:debeEstarVacio a owl:ObjectProperty ;
    rdfs:domain ex:DepositoAceite ;
    rdfs:range ex:Maquina .

ex:estarBienCerrado a owl:ObjectProperty ;
    rdfs:domain ex:TaponCierre ;
    rdfs:range ex:DepositoAceite .

ex:evitarRiesgoPorRotura a owl:ObjectProperty ;
    rdfs:domain ex:EslingaHomologada ;
    rdfs:range ex:Maquina .