@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

ex:DepositoAceite a owl:Class ;
    rdfs:label "DepositoAceite" ;
    rdfs:comment "Deposito de aceite mencionado en el texto." .

ex:TaponCierre a owl:Class ;
    rdfs:label "TaponCierre" ;
    rdfs:comment "Tapon de cierre mencionado en el texto." .

ex:PlataformaLaterales a owl:Class ;
    rdfs:label "PlataformaLaterales" ;
    rdfs:comment "Plataformas laterales mencionadas en el texto." .

ex:ArmarioElectrico a owl:Class ;
    rdfs:label "ArmarioElectrico" ;
    rdfs:comment "Armario eléctrico mencionado en el texto." .

ex:GrupoHidraulico a owl:Class ;
    rdfs:label "GrupoHidraulico" ;
    rdfs:comment "Grupo hidráulico mencionado en el texto." .

ex:EquipoRefrigeracion a owl:Class ;
    rdfs:label "EquipoRefrigeracion" ;
    rdfs:comment "Equipo de refrigeración mencionado en el texto." .

ex:Bomba a owl:Class ;
    rdfs:label "Bomba" ;
    rdfs:comment "Bomba mencionada en el texto." .

ex:Zocalo a owl:Class ;
    rdfs:label "Zocalo" ;
    rdfs:comment "Zócalo mencionado en el texto." .

ex:Cancamo a owl:Class ;
    rdfs:label "Cancamo" ;
    rdfs:comment "Cáncamos mencionados en el texto." .

ex:CarroPortaPiezas a owl:Class ;
    rdfs:label "CarroPortaPiezas" ;
    rdfs:comment "Carro porta-piezas mencionado en el texto." .

ex:PortonDelantero a owl:Class ;
    rdfs:label "PortonDelantero" ;
    rdfs:comment "Portones delanteros mencionados en el texto." .

ex:Grúa a owl:Class ;
    rdfs:label "Grúa" ;
    rdfs:comment "Grúa mencionada en el texto." .

ex:Eslinga a owl:Class ;
    rdfs:label "Eslinga" ;
    rdfs:comment "Eslingas mencionadas en el texto." .

ex:estaVacio a owl:ObjectProperty ;
    rdfs:label "estaVacio" ;
    rdfs:comment "Propiedad que indica si un depósito está vacío." .

ex:estaCerrado a owl:ObjectProperty ;
    rdfs:label "estaCerrado" ;
    rdfs:comment "Propiedad que indica si un tapón está cerrado." .

ex:estaConectadoA a owl:ObjectProperty ;
    rdfs:label "estaConectadoA" ;
    rdfs:comment "Propiedad que indica la conexión entre componentes." .

ex:estaPosicionadoEn a owl:ObjectProperty ;
    rdfs:label "estaPosicionadoEn" ;
    rdfs:comment "Propiedad que indica la posición de un componente." .

ex:requiereUtilizar a owl:ObjectProperty ;
    rdfs:label "requiereUtilizar" ;
    rdfs:comment "Propiedad que indica la necesidad de utilizar un componente." .

ex:tieneCantidad a owl:DatatypeProperty ;
    rdfs:label "tieneCantidad" ;
    rdfs:comment "Propiedad que indica la cantidad de un componente." .

ex:tienePosicion a owl:DatatypeProperty ;
    rdfs:label "tienePosicion" ;
    rdfs:comment "Propiedad que indica la posición de un componente." .