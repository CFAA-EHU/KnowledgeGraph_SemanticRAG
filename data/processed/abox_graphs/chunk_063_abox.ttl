@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ElementoAntivibracion_LM7_100BA_63_1 a ns1:Componente ;
    rdfs:label "elementos de antivibración LM7-100BA (EFFBE)" ;
    ns1:identificador "LM7-100BA" ;
    ns1:textoExtracto "Entre el zócalo de la máquina y el suelo están colocados diez elementos de antivibración LM7- 100BA (EFFBE)." ;
    ns1:valor "10" .

ns1:PlanoImplantacion_63_1 a ns1:Esquema ;
    rdfs:label "plano de implantación" ;
    ns1:compuestoPor ns1:Maquina_63_1 ;
    ns1:detalladoEnEsquema ns1:Figura_5_3_63_1 ;
    ns1:textoExtracto "En la siguiente figura se muestra el plano de implantación de la máquina en el que se incluyen las dimensiones de la máquina." .

ns1:Figura_5_3_63_1 a ns1:Figura ;
    rdfs:label "Figura 5-3" ;
    ns1:identificador "5-3" ;
    ns1:textoExtracto "En la siguiente figura se muestra el plano de implantación de la máquina en el que se incluyen las dimensiones de la máquina. Figura 5-3. Dimensiones máquina" .

ns1:Maquina_63_1 a ns1:Maquina ;
    rdfs:label "máquina" ;
    ns1:textoExtracto "El peso total de la máquina es de aproximadamente unas 25Tn. Las dimensiones máximas de la máquina son: 5850 x 4000 x 5000mm." ;
    ns1:valor "25Tn",
        "5850 x 4000 x 5000mm" .

