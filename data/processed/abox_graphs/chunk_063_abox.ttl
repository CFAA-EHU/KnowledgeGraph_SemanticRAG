@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix mecanica: <https://vocab.cfaa.eus/broaching/mecanica#> .
@prefix base: <https://vocab.cfaa.eus/broaching/base#> .

# Clases
ex:Maquina a owl:Class ;
    rdfs:comment "Clase que representa una máquina en general." .

ex:ElementoAntivibracion a owl:Class ;
    rdfs:comment "Clase que representa un elemento de antivibración." .

ex:PlanoImplantacion a owl:Class ;
    rdfs:comment "Clase que representa un plano de implantación." .

ex:NivelBurbujas a owl:Class ;
    rdfs:comment "Clase que representa un nivel de burbujas." .

ex:Mesa a owl:Class ;
    rdfs:comment "Clase que representa una mesa." .

# Propiedades de objeto
mecanica:tienePeso a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range xsd:decimal .

mecanica:tieneDimensiones a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range xsd:string .

mecanica:tieneElementoAntivibracion a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:ElementoAntivibracion .

mecanica:tienePlanoImplantacion a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:PlanoImplantacion .

mecanica:tieneNivelBurbujas a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:NivelBurbujas .

mecanica:tieneMesa a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:Mesa .

mecanica:nivelarMaquina a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:NivelBurbujas .

# Propiedades de datos
base:pesoTotal a owl:DatatypeProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range xsd:decimal .

base:dimensionesMaximas a owl:DatatypeProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range xsd:string .

base:capacidadSustentadora a owl:DatatypeProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range xsd:decimal .

base:numeroElementosAntivibracion a owl:DatatypeProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range xsd:integer .

base:modeloElementoAntivibracion a owl:DatatypeProperty ;
    rdfs:domain ex:ElementoAntivibracion ;
    rdfs:range xsd:string .

base:fabricanteElementoAntivibracion a owl:DatatypeProperty ;
    rdfs:domain ex:ElementoAntivibracion ;
    rdfs:range xsd:string .