@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

ex:CentralitaEngraseManual a owl:Class ;
    rdfs:label "Centralita de engrase manual" ;
    rdfs:comment "Componente que requiere llenado con aceite ISO 3498 G220" .

ex:CentralitaEngraseAutomatica a owl:Class ;
    rdfs:label "Centralita de engrase automática" ;
    rdfs:comment "Componente que requiere cartucho de grasa LUE+400-05-1" .

ex:GrupoHidraulico a owl:Class ;
    rdfs:label "Grupo hidráulico" ;
    rdfs:comment "Componente que requiere llenado con aceite ISO 3498 HM46" .

ex:DepositoRefrigerante a owl:Class ;
    rdfs:label "Depósito de refrigerante" ;
    rdfs:comment "Componente que requiere llenado con aceite de corte CUT-MAX S 5029-1" .

ex:SuministroAire a owl:Class ;
    rdfs:label "Suministro de aire" ;
    rdfs:comment "Conexión del suministro de aire máx. a 6 bar" .

ex:RedElectrica a owl:Class ;
    rdfs:label "Red eléctrica" ;
    rdfs:comment "Conexión a red trifásica de 380 V y 50 Hz" .

ex:aceiteISO3498G220 a owl:Class ;
    rdfs:label "Aceite ISO 3498 G220" ;
    rdfs:comment "Aceite utilizado para llenar la centralita de engrase manual" .

ex:cartuchoGrasaLUE400051 a owl:Class ;
    rdfs:label "Cartucho de grasa LUE+400-05-1" ;
    rdfs:comment "Cartucho de grasa utilizado en la centralita de engrase automática" .

ex:aceiteISO3498HM46 a owl:Class ;
    rdfs:label "Aceite ISO 3498 HM46" ;
    rdfs:comment "Aceite utilizado para llenar el grupo hidráulico" .

ex:aceiteCorteCUTMAXS50291 a owl:Class ;
    rdfs:label "Aceite de corte CUT-MAX S 5029-1" ;
    rdfs:comment "Aceite de corte utilizado para llenar el depósito de refrigerante" .

ex:conectarSuministroAire a owl:ObjectProperty ;
    rdfs:label "conectar suministro de aire" ;
    rdfs:comment "Propiedad que indica la conexión del suministro de aire" .

ex:conectarRedElectrica a owl:ObjectProperty ;
    rdfs:label "conectar red eléctrica" ;
    rdfs:comment "Propiedad que indica la conexión a red eléctrica" .

ex:llenarCentralitaEngraseManual a owl:ObjectProperty ;
    rdfs:label "llenar centralita de engrase manual" ;
    rdfs:comment "Propiedad que indica el llenado de la centralita de engrase manual" .

ex:colocarCartuchoGrasa a owl:ObjectProperty ;
    rdfs:label "colocar cartucho de grasa" ;
    rdfs:comment "Propiedad que indica la colocación del cartucho de grasa" .

ex:llenarGrupoHidraulico a owl:ObjectProperty ;
    rdfs:label "llenar grupo hidráulico" ;
    rdfs:comment "Propiedad que indica el llenado del grupo hidráulico" .

ex:llenarDepositoRefrigerante a owl:ObjectProperty ;
    rdfs:label "llenar depósito de refrigerante" ;
    rdfs:comment "Propiedad que indica el llenado del depósito de refrigerante" .