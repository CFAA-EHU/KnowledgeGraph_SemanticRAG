@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:PanelOperador_66 a ns1:InterfazUsuario ;
    ns1:textoExtracto "Desde el panel operador se puede ajustar la velocidad de brochado hasta un límite de 40m/min." ;
    ns1:tieneComponente ns1:VelocidadBrochado_66_1,
        ns1:VelocidadBrochado_66_2 .

ns1:VelocidadBrochado_66_1 a ns1:Parametro ;
    ns1:textoExtracto "velocidad de brochado" ;
    ns1:valor "40m/min" .

ns1:VelocidadBrochado_66_2 a ns1:Parametro ;
    ns1:textoExtracto "velocidad de brochado" ;
    ns1:valor "40m/min" .

