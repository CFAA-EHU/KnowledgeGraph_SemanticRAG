@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ElementosMando_68 a ns1:Sistema ;
    rdfs:label "Elementos de mando" ;
    ns1:compuestoPor ns1:PanelOperadorPC21_68,
        ns1:PulsadorLuminoso_68,
        ns1:PulsadorParadaEmergencia_68,
        ns1:PulsadorSimple_68,
        ns1:Selector_68 ;
    ns1:textoExtracto "La máquina está compuesta por los siguientes elementos de mando:  Pulsadores de parada de emergencia  Pulsadores simples  Pulsadores luminosos  Selectores  Panel operador PC-21' Panorámico 16Gb" .

ns1:PanelOperadorPC21_68 a ns1:InterfazUsuario ;
    rdfs:label "Panel operador PC-21' Panorámico 16Gb" ;
    ns1:identificador "PC-21' Panorámico 16Gb" ;
    ns1:textoExtracto "Panel operador PC-21' Panorámico 16Gb" .

ns1:PulsadorLuminoso_68 a ns1:ComponenteElectrico ;
    rdfs:label "Pulsadores luminosos" ;
    ns1:textoExtracto "Pulsadores luminosos" .

ns1:PulsadorParadaEmergencia_68 a ns1:ComponenteMecanico ;
    rdfs:label "Pulsadores de parada de emergencia" ;
    ns1:textoExtracto "Pulsadores de parada de emergencia" .

ns1:PulsadorSimple_68 a ns1:ComponenteMecanico ;
    rdfs:label "Pulsadores simples" ;
    ns1:textoExtracto "Pulsadores simples" .

ns1:Selector_68 a ns1:ComponenteMecanico ;
    rdfs:label "Selectores" ;
    ns1:textoExtracto "Selectores" .

