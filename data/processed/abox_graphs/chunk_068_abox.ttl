@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:PulsadorDeParadaDeEmergencia a owl:Class .
ex:PulsadorSimple a owl:Class .
ex:PulsadorLuminoso a owl:Class .
ex:Selector a owl:Class .
ex:PanelOperadorPC21Panoramico16Gb a owl:Class .

ex:tieneElementoDeMando a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range owl:Class .

ex:tieneElementoDeMando rdfs:subPropertyOf ex:tieneComponente .