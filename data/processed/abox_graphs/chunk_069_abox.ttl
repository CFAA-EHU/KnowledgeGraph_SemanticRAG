@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

ex:InterruptorGeneral a owl:Class ;
    rdfs:label "Interruptor General" ;
    rdfs:comment "Componente eléctrico para controlar el suministro de energía al armario eléctrico." .

ex:PulsadorEmergencia a owl:Class ;
    rdfs:label "Pulsador de Emergencia" ;
    rdfs:comment "Dispositivo para detener la máquina en situaciones de emergencia." .

ex:PilotoLuminosoTension a owl:Class ;
    rdfs:label "Piloto Luminoso de Tensión" ;
    rdfs:comment "Indicador visual que muestra el estado de la tensión eléctrica." .