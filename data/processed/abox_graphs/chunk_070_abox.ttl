@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionAperturaPuertas a ns1:AccionProhibida ;
    rdfs:label "Apertura puertas"@es ;
    ns1:habilitadoPor ns1:PanelOperador_6_2 ;
    ns1:textoExtracto "APERTURA PUERTAS"@es .

ns1:AccionHabilitarPuertas a ns1:AccionProhibida ;
    rdfs:label "Habilitar puertas"@es ;
    ns1:habilitadoPor ns1:PanelOperador_6_2 ;
    ns1:textoExtracto "HABILITAR PUERTAS"@es .

ns1:ModoCiclo a ns1:ModoOperacion ;
    rdfs:label "Marcha ciclo"@es ;
    ns1:habilitadoPor ns1:PanelOperador_6_2 ;
    ns1:textoExtracto "MARCHA CICLO"@es .

ns1:ModoEmergencia a ns1:ModoOperacion ;
    rdfs:label "Parada de emergencia"@es ;
    ns1:habilitadoPor ns1:PanelOperador_6_2 ;
    ns1:textoExtracto "PARADA DE EMERGENCIA"@es .

ns1:ModoServicio a ns1:ModoOperacion ;
    rdfs:label "Modo servicio"@es ;
    ns1:habilitadoPor ns1:PanelOperador_6_2 ;
    ns1:textoExtracto "PUESTA SERVICIO - PARO SERVICIO"@es .

ns1:ModoSetup a ns1:ModoOperacion ;
    rdfs:label "Modo setup"@es ;
    ns1:habilitadoPor ns1:PanelOperador_6_2 ;
    ns1:textoExtracto "MODO SETUP"@es .

ns1:Figura_6_2 a ns1:Figura ;
    rdfs:label "Figura 6-2: Panel operador"@es ;
    ns1:identificador "6-2" ;
    ns1:textoExtracto "PARADA DE EMERGENCIA - PUESTA SERVICIO - PARO SERVICIO - MARCHA CICLO - MODO SETUP - HABILITAR PUERTAS - APERTURA PUERTAS - Puesta Habilitar Servicio Puertas Parada de Apertura Emergencia Puertas Modo Paro Marcha Setup Servicio Ciclo"@es .

ns1:PanelOperador_6_2 a ns1:InterfazUsuario ;
    rdfs:label "Panel operador"@es ;
    ns1:identificador "Figura 6-2" ;
    ns1:ilustradoEn ns1:Figura_6_2 ;
    ns1:textoExtracto "Figura 6-2. Panel operador"@es .

