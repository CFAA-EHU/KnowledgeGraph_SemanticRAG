@prefix ex: <https://vocab.cfaa.eus/broaching/>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

ex:ParadaDeEmergencia a owl:Class ;
    rdfs:label "ParadaDeEmergencia"@es ;
    rdfs:comment "Clase que representa la parada de emergencia en el panel operador."@es .

ex:PuestaServicio a owl:Class ;
    rdfs:label "PuestaServicio"@es ;
    rdfs:comment "Clase que representa la puesta en servicio en el panel operador."@es .

ex:ParoServicio a owl:Class ;
    rdfs:label "ParoServicio"@es ;
    rdfs:comment "Clase que representa el paro de servicio en el panel operador."@es .

ex:MarchaCiclo a owl:Class ;
    rdfs:label "MarchaCiclo"@es ;
    rdfs:comment "Clase que representa la marcha de ciclo en el panel operador."@es .

ex:ModoSetUp a owl:Class ;
    rdfs:label "ModoSetUp"@es ;
    rdfs:comment "Clase que representa el modo setup en el panel operador."@es .

ex:HabilitarPuertas a owl:Class ;
    rdfs:label "HabilitarPuertas"@es ;
    rdfs:comment "Clase que representa la habilitación de puertas en el panel operador."@es .

ex:AperturaPuertas a owl:Class ;
    rdfs:label "AperturaPuertas"@es ;
    rdfs:comment "Clase que representa la apertura de puertas en el panel operador."@es .

ex:PanelOperador a owl:Class ;
    rdfs:label "PanelOperador"@es ;
    rdfs:comment "Clase que representa el panel operador."@es .

ex:Figura a owl:Class ;
    rdfs:label "Figura"@es ;
    rdfs:comment "Clase que representa una figura en el manual."@es .