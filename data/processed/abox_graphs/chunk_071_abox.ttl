@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:PantallaPrincipal a owl:Class .
ex:MovimientosManuales a owl:Class .
ex:MovimientosMaquina a owl:Class .
ex:ArranqueMotores a owl:Class .
ex:CicloCambioBrocha a owl:Class .
ex:CondicionesMaquina a owl:Class .
ex:CiclosBrochado a owl:Class .
ex:CicloAnilloDesbaste a owl:Class .
ex:CicloAnilloAcabado a owl:Class .
ex:CicloPlanaDesbaste a owl:Class .
ex:CicloPlanaAcabado a owl:Class .
ex:Inspeccion a owl:Class .

ex:tienePantallaPrincipal a owl:ObjectProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range ex:PantallaPrincipal .

ex:tieneMovimientosManuales a owl:ObjectProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range ex:MovimientosManuales .

ex:tieneMovimientosMaquina a owl:ObjectProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range ex:MovimientosMaquina .

ex:tieneArranqueMotores a owl:ObjectProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range ex:ArranqueMotores .

ex:tieneCicloCambioBrocha a owl:ObjectProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range ex:CicloCambioBrocha .

ex:tieneCondicionesMaquina a owl:ObjectProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range ex:CondicionesMaquina .

ex:tieneCiclosBrochado a owl:ObjectProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range ex:CiclosBrochado .

ex:tieneCicloAnilloDesbaste a owl:ObjectProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range ex:CicloAnilloDesbaste .

ex:tieneCicloAnilloAcabado a owl:ObjectProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range ex:CicloAnilloAcabado .

ex:tieneCicloPlanaDesbaste a owl:ObjectProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range ex:CicloPlanaDesbaste .

ex:tieneCicloPlanaAcabado a owl:ObjectProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range ex:CicloPlanaAcabado .

ex:tieneInspeccion a owl:ObjectProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range ex:Inspeccion .