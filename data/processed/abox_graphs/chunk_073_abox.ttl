@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Actuador_73_1 a ns1:Actuador ;
    rdfs:label "Actuador"@es ;
    ns1:textoExtracto "dependiendo del estado del sensor de un actuador"@es .

ns1:Se_alizador_73_1 a ns1:Sensor ;
    rdfs:label "Señalizador"@es ;
    ns1:textoExtracto "Siempre van acompañados de un texto o de un botón al cual están asociados y cambian de color dependiendo del estado del sensor de un actuador o del estado de un sinóptico."@es .

ns1:Se_alizador_73_2 a ns1:Sensor ;
    rdfs:label "Señalizador"@es ;
    ns1:textoExtracto "cambian de color dependiendo del estado del sensor de un actuador"@es .

ns1:Se_alizador_73_3 a ns1:Sensor ;
    rdfs:label "Señalizador"@es ;
    ns1:textoExtracto "cambian de color dependiendo del estado de un sinóptico"@es .

ns1:Sinoptico_73_1 a ns1:InterfazUsuario ;
    rdfs:label "Sinóptico"@es ;
    ns1:textoExtracto "dependiendo del estado de un sinóptico"@es .

