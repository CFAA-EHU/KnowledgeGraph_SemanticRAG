@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Sensor_73_1 a ex:Sensor ;
    ex:textoExtracto "Siempre van acompañados de un texto o de un botón al cual están asociados y cambian de color dependiendo del estado del sensor de un actuador o del estado de un sinóptico." ;
    ex:textoExtracto "Negro = Desactivado Verde = Activado" .

ex:Actuador_73_1 a ex:Actuador ;
    ex:textoExtracto "cambian de color dependiendo del estado del sensor de un actuador" .

ex:Boton_73_1 a ex:InterfazUsuario ;
    ex:textoExtracto "Siempre van acompañados de un texto o de un botón al cual están asociados" ;
    ex:textoExtracto "Botones Señalizadores" .