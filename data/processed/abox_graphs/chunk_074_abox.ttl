@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Teclado a owl:Class ;
    rdfs:label "Teclado"@es .

ex:VersiónTeclado a owl:Class ;
    rdfs:label "VersiónTeclado"@es .

ex:ModoTrabajo a owl:Class ;
    rdfs:label "ModoTrabajo"@es .

ex:Pantalla a owl:Class ;
    rdfs:label "Pantalla"@es .

ex:Botón a owl:Class ;
    rdfs:label "Botón"@es .

ex:Carro a owl:Class ;
    rdfs:label "Carro"@es .

ex:Mesa a owl:Class ;
    rdfs:label "Mesa"@es .

ex:tieneVersión a owl:ObjectProperty ;
    rdfs:domain ex:Teclado ;
    rdfs:range ex:VersiónTeclado .

ex:permiteSeleccionarModoTrabajo a owl:ObjectProperty ;
    rdfs:domain ex:VersiónTeclado ;
    rdfs:range ex:ModoTrabajo .

ex:daAcceso a owl:ObjectProperty ;
    rdfs:domain ex:VersiónTeclado ;
    rdfs:range ex:Pantalla .

ex:tieneBotón a owl:ObjectProperty ;
    rdfs:domain ex:Teclado ;
    rdfs:range ex:Botón .

ex:permiteCambiarVersión a owl:ObjectProperty ;
    rdfs:domain ex:Teclado ;
    rdfs:range ex:VersiónTeclado .

ex:permiteMover a owl:ObjectProperty ;
    rdfs:domain ex:VersiónTeclado ;
    rdfs:range ex:Carro .

ex:permiteMoverMesa a owl:ObjectProperty ;
    rdfs:domain ex:VersiónTeclado ;
    rdfs:range ex:Mesa .

ex:estaEnModoManual a owl:ObjectProperty ;
    rdfs:domain ex:Teclado ;
    rdfs:range xsd:boolean .

ex:tieneBotones a owl:ObjectProperty ;
    rdfs:domain ex:Teclado ;
    rdfs:range ex:Botón .