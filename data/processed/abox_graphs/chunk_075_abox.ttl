@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:PantallaPrincipal a owl:Class ;
    rdfs:label "Pantalla principal"@es .

ex:PosicionEje a owl:Class ;
    rdfs:label "Posición de eje"@es .

ex:Avance a owl:Class ;
    rdfs:label "Avance"@es .

ex:PropiedadCicloBrochado a owl:Class ;
    rdfs:label "Propiedad del ciclo de brochado"@es .

ex:BotonInspeccion a owl:Class ;
    rdfs:label "Botón Inspección"@es .

ex:SoftkeyVertical a owl:Class ;
    rdfs:label "Softkey vertical"@es .

ex:VelocidadReducida a owl:Class ;
    rdfs:label "Velocidad reducida"@es .

ex:ModoSetUp a owl:Class ;
    rdfs:label "Modo set-up"@es .

ex:PortonPrincipal a owl:Class ;
    rdfs:label "Portón principal"@es .

ex:CarroPortaPieza a owl:Class ;
    rdfs:label "Carro porta-pieza"@es .

ex:BotonCicloBrochado a owl:Class ;
    rdfs:label "Botón Ciclo brochado"@es .

ex:SoftkeyHorizontal a owl:Class ;
    rdfs:label "Softkey horizontal"@es .

ex:PantallaSeleccionCicloBrochado a owl:Class ;
    rdfs:label "Pantalla de selección del ciclo de brochado"@es .

ex:muestraPosicionesEjes a owl:ObjectProperty ;
    rdfs:domain ex:PantallaPrincipal ;
    rdfs:range ex:PosicionEje .

ex:muestraAvance a owl:ObjectProperty ;
    rdfs:domain ex:PantallaPrincipal ;
    rdfs:range ex:Avance .

ex:muestraPropiedadesCicloBrochado a owl:ObjectProperty ;
    rdfs:domain ex:PantallaPrincipal ;
    rdfs:range ex:PropiedadCicloBrochado .

ex:habilitaMovimientoCarroPortaPieza a owl:ObjectProperty ;
    rdfs:domain ex:BotonInspeccion ;
    rdfs:range ex:CarroPortaPieza .

ex:requiereVelocidadReducida a owl:ObjectProperty ;
    rdfs:domain ex:BotonInspeccion ;
    rdfs:range ex:VelocidadReducida .

ex:requiereModoSetUp a owl:ObjectProperty ;
    rdfs:domain ex:BotonInspeccion ;
    rdfs:range ex:ModoSetUp .

ex:requierePortonPrincipalAbierto a owl:ObjectProperty ;
    rdfs:domain ex:BotonInspeccion ;
    rdfs:range ex:PortonPrincipal .

ex:permiteAccederPantallaSeleccionCicloBrochado a owl:ObjectProperty ;
    rdfs:domain ex:BotonCicloBrochado ;
    rdfs:range ex:PantallaSeleccionCicloBrochado .

ex:estaEnModoSetUp a owl:ObjectProperty ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:ModoSetUp .

ex:estaAbierto a owl:ObjectProperty ;
    rdfs:domain ex:PortonPrincipal ;
    rdfs:range xsd:boolean .