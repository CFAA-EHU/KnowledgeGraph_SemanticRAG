@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix mec: <https://vocab.cfaa.eus/broaching/mecanica/> .
@prefix elec: <https://vocab.cfaa.eus/broaching/electrica/> .
@prefix base: <https://vocab.cfaa.eus/broaching/base/> .
@prefix motor: <https://admin-shell.io/dictionary/Motor> .

ex:PantallaMovimientosManuales a owl:Class ;
    rdfs:label "Pantalla de Movimientos Manuales" ;
    rdfs:comment "Pantalla para controlar los movimientos de la máquina." .

ex:PantallaArranqueMotores a owl:Class ;
    rdfs:label "Pantalla de Arranque de Motores" ;
    rdfs:comment "Pantalla para controlar el estado y arranque de los motores de la máquina." .

ex:PantallaCicloCambioBrocha a owl:Class ;
    rdfs:label "Pantalla de Ciclo Cambio de Brocha" ;
    rdfs:comment "Pantalla para controlar el ciclo de cambio de brocha." .

ex:PantallaCondicionesMaquina a owl:Class ;
    rdfs:label "Pantalla de Condiciones de Máquina" ;
    rdfs:comment "Pantalla para controlar las condiciones de la máquina." .

ex:BotonCustom a owl:Class ;
    rdfs:label "Botón Custom" ;
    rdfs:comment "Botón para acceder a las pantallas de movimientos manuales." .

ex:BotonOPMan14 a owl:Class ;
    rdfs:label "Botón OP MAN 1/4" ;
    rdfs:comment "Botón para cambiar entre las pantallas de movimientos manuales." .

ex:Ventana a owl:Class ;
    rdfs:label "Ventana" ;
    rdfs:comment "Ventana que se despliega para seleccionar una pantalla de movimientos manuales." .

ex:CarroTracion a owl:Class ;
    rdfs:label "Carro de Tración" ;
    rdfs:comment "Carro de tracción de la máquina." .

ex:MesaGiratoria a owl:Class ;
    rdfs:label "Mesa Giratoria" ;
    rdfs:comment "Mesa giratoria de la máquina." .

ex:Señalizador a owl:Class ;
    rdfs:label "Señalizador" ;
    rdfs:comment "Señalizador que indica el estado de los frenos y consumos de los motores." .

ex:FrenoMayr a owl:Class ;
    rdfs:label "Freno MAYR" ;
    rdfs:comment "Freno de la máquina." .

ex:MotorRefrigeranteABrochaBastidor a owl:Class ;
    rdfs:label "Motor de Refrigerante a Brocha/Bastidor" ;
    rdfs:comment "Motor para el sistema de refrigerante a brocha/bastidor." .

ex:MotorTrasvaseRefrigerante a owl:Class ;
    rdfs:label "Motor de Trasvase de Refrigerante" ;
    rdfs:comment "Motor para el trasvase de refrigerante." .

ex:GrupoHidraulico a owl:Class ;
    rdfs:label "Grupo Hidráulico" ;
    rdfs:comment "Grupo hidráulico de la máquina." .

ex:MotorExtractorVirutas a owl:Class ;
    rdfs:label "Motor de Extractor de Virutas" ;
    rdfs:comment "Motor para el extractor de virutas." .

ex:MotorEngrase a owl:Class ;
    rdfs:label "Motor de Engrase" ;
    rdfs:comment "Motor para el sistema de engrase." .

ex:Columna a owl:Class ;
    rdfs:label "Columna" ;
    rdfs:comment "Columna en la pantalla de arranque de motores." .

ex:SeñalizadorNivelMinimo a owl:Class ;
    rdfs:label "Señalizador de Nivel Mínimo" ;
    rdfs:comment "Señalizador de nivel mínimo para refrigerante y grupo hidráulico." .

mec:tienePosiciones a owl:ObjectProperty ;
    rdfs:label "tiene posiciones" ;
    rdfs:comment "Propiedad que indica las posiciones de un componente." .

mec:permiteControlar a owl:ObjectProperty ;
    rdfs:label "permite controlar" ;
    rdfs:comment "Propiedad que indica que un componente permite controlar otro." .

mec:muestraEstado a owl:ObjectProperty ;
    rdfs:label "muestra estado" ;
    rdfs:comment "Propiedad que indica que un componente muestra el estado de otro." .

mec:permiteArrancarParar a owl:ObjectProperty ;
    rdfs:label "permite arrancar parar" ;
    rdfs:comment "Propiedad que indica que un componente permite arrancar o parar otro." .

mec:activaEmboladaEngrase a owl:ObjectProperty ;
    rdfs:label "activa embolada de engrase" ;
    rdfs:comment "Propiedad que indica que un componente activa una embolada de engrase." .

mec:visualizarEstadoProteccion a owl:ObjectProperty ;
    rdfs:label "visualizar estado de protección" ;
    rdfs:comment "Propiedad que indica que un componente permite visualizar el estado de protección de otro." .

mec:tieneSeñalizadoresNivel a owl:ObjectProperty ;
    rdfs:label "tiene señalizadores de nivel" ;
    rdfs:comment "Propiedad que indica que un componente tiene señalizadores de nivel." .

elec:tieneColumna a owl:ObjectProperty ;
    rdfs:label "tiene columna" ;
    rdfs:comment "Propiedad que indica que un componente tiene una columna." .

elec:tieneSeñalizadores a owl:ObjectProperty ;
    rdfs:label "tiene señalizadores" ;
    rdfs:comment "Propiedad que indica que un componente tiene señalizadores." .

base:tieneMotor a owl:ObjectProperty ;
    rdfs:label "tiene motor" ;
    rdfs:comment "Propiedad que indica que un componente tiene un motor." .

base:tieneSeñalizador a owl:ObjectProperty ;
    rdfs:label "tiene señalizador" ;
    rdfs:comment "Propiedad que indica que un componente tiene un señalizador." .

base:tieneFreno a owl:ObjectProperty ;
    rdfs:label "tiene freno" ;
    rdfs:comment "Propiedad que indica que un componente tiene un freno." .

base:tieneGrupoHidraulico a owl:ObjectProperty ;
    rdfs:label "tiene grupo hidráulico" ;
    rdfs:comment "Propiedad que indica que un componente tiene un grupo hidráulico." .

base:tieneExtractorVirutas a owl:ObjectProperty ;
    rdfs:label "tiene extractor de virutas" ;
    rdfs:comment "Propiedad que indica que un componente tiene un extractor de virutas." .

base:tieneEngrase a owl:ObjectProperty ;
    rdfs:label "tiene engrase" ;
    rdfs:comment "Propiedad que indica que un componente tiene un sistema de engrase." .

base:tieneRefrigerante a owl:ObjectProperty ;
    rdfs:label "tiene refrigerante" ;
    rdfs:comment "Propiedad que indica que un componente tiene un sistema de refrigerante." .

base:tieneColumna a owl:ObjectProperty ;
    rdfs:label "tiene columna" ;
    rdfs:comment "Propiedad que indica que un componente tiene una columna." .

base:tieneSeñalizadorNivelMinimo a owl:ObjectProperty ;
    rdfs:label "tiene señalizador de nivel mínimo" ;
    rdfs:comment "Propiedad que indica que un componente tiene un señalizador de nivel mínimo." .

motor:Motor a owl:Class ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Motor> .