@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:HerramientaCambioBrocha a ns1:Herramienta ;
    rdfs:label "herramienta para cambio de brocha" ;
    ns1:textoExtracto "Esta pantalla guía al operario en los pasos que tiene que realizar para realizar el cambio de herramienta." .

ns1:PantallaCambioBrocha a ns1:InterfazUsuario ;
    rdfs:label "pantalla guía para el cambio de brocha" ;
    ns1:detalladoEnEsquema ns1:Se_alizadorCaudalRefrigerante,
        ns1:Se_alizadorErrorEngraseEmbolada,
        ns1:Se_alizadorErrorEngraseNivelMinimo,
        ns1:Se_alizadorGrupoHidraulicoNivelMinimo,
        ns1:Se_alizadorRefrigeranteNivelMinimo1 ;
    ns1:textoExtracto "Esta pantalla guía al operario en los pasos que tiene que realizar para realizar el cambio de herramienta." .

ns1:Se_alizadorCaudalRefrigerante a ns1:Sensor ;
    rdfs:label "señalizador para el caudal del refrigerante" ;
    ns1:textoExtracto "También hay un señalizador para el caudal del refrigerante" .

ns1:Se_alizadorErrorEngraseEmbolada a ns1:Sensor ;
    rdfs:label "señalizador para el error de embolada en el engrase" ;
    ns1:textoExtracto "dos para los errores del engrase (error de embolada o de nivel mínimo)" .

ns1:Se_alizadorErrorEngraseNivelMinimo a ns1:Sensor ;
    rdfs:label "señalizador para el error de nivel mínimo en el engrase" ;
    ns1:textoExtracto "dos para los errores del engrase (error de embolada o de nivel mínimo)" .

ns1:Se_alizadorGrupoHidraulicoNivelMinimo a ns1:Sensor ;
    rdfs:label "señalizador de nivel mínimo para el grupo hidráulico" ;
    ns1:textoExtracto "En la columna 'SEÑALES' hay dos señalizadores de nivel mínimo; uno para el refrigerante y otro para el grupo hidráulico." .

ns1:Se_alizadorRefrigeranteNivelMinimo1 a ns1:Sensor ;
    rdfs:label "señalizador de nivel mínimo para el refrigerante" ;
    ns1:textoExtracto "En la columna 'SEÑALES' hay dos señalizadores de nivel mínimo; uno para el refrigerante y otro para el grupo hidráulico." .

