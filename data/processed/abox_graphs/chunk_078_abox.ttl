@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:CicloCambioBrocha a owl:Class ;
    rdfs:label "Ciclo cambio de brocha"@es .

ex:Pantalla a owl:Class ;
    rdfs:label "Pantalla"@es .

ex:Operario a owl:Class ;
    rdfs:label "Operario"@es .

ex:Paso a owl:Class ;
    rdfs:label "Paso"@es .

ex:MovimientoMaquina a owl:Class ;
    rdfs:label "Movimiento máquina"@es .

ex:CondicionMaquina a owl:Class ;
    rdfs:label "Condiciones máquina"@es .

ex:SeñalDiagnostico a owl:Class ;
    rdfs:label "Señal de diagnóstico"@es .

ex:Error a owl:Class ;
    rdfs:label "Error"@es .

ex:guiaEnPasos a owl:ObjectProperty ;
    rdfs:domain ex:CicloCambioBrocha ;
    rdfs:range ex:Paso .

ex:requiereAccesoA a owl:ObjectProperty ;
    rdfs:domain ex:CicloCambioBrocha ;
    rdfs:range ex:Pantalla .

ex:muestraEstado a owl:ObjectProperty ;
    rdfs:domain ex:CondicionMaquina ;
    rdfs:range ex:SeñalDiagnostico .

ex:detecta a owl:ObjectProperty ;
    rdfs:domain ex:CondicionMaquina ;
    rdfs:range ex:Error .