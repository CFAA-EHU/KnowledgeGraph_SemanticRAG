@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:PantallaPrincipal a owl:Class ;
    rdfs:label "Pantalla principal" .

ex:Botón a owl:Class ;
    rdfs:label "Botón" .

ex:CicloBrochado a owl:Class ;
    rdfs:label "Ciclo de brochado" .

ex:TipoPieza a owl:Class ;
    rdfs:label "Tipo de pieza" .

ex:PiezaAnillo a owl:Class ;
    rdfs:label "Pieza en forma de anillo" .

ex:PiezaPlana a owl:Class ;
    rdfs:label "Pieza plana" .

ex:TipoOperación a owl:Class ;
    rdfs:label "Tipo de operación" .

ex:Desbaste a owl:Class ;
    rdfs:label "Desbaste" .

ex:Acabado a owl:Class ;
    rdfs:label "Acabado" .

ex:Refrigeración a owl:Class ;
    rdfs:label "Refrigeración" .

ex:Refrigerante a owl:Class ;
    rdfs:label "Refrigerante" .

ex:SinRefrigerante a owl:Class ;
    rdfs:label "Sin refrigerante" .

ex:ParámetroBrochado a owl:Class ;
    rdfs:label "Parámetro de brochado" .

ex:Avance a owl:Class ;
    rdfs:label "Avance" .

ex:PosiciónInicial a owl:Class ;
    rdfs:label "Posición inicial" .

ex:NúmeroRanuras a owl:Class ;
    rdfs:label "Número de ranuras" .

ex:PasoEntreRanuras a owl:Class ;
    rdfs:label "Paso entre ranuras" .

ex:Softkey a owl:Class ;
    rdfs:label "Softkey" .

ex:SimulaciónCiclo a owl:Class ;
    rdfs:label "Simulación de ciclo" .

ex:EjecuciónCiclo a owl:Class ;
    rdfs:label "Ejecución de ciclo" .

ex:MemorizaciónCiclo a owl:Class ;
    rdfs:label "Memorización de ciclo" .

ex:CicloInspección a owl:Class ;
    rdfs:label "Ciclo de inspección" .

ex:Inspección a owl:Class ;
    rdfs:label "Inspección" .

ex:PasoIncremento a owl:Class ;
    rdfs:label "Paso incremento" .

ex:Icono a owl:Class ;
    rdfs:label "Icono" .

ex:Pantalla a owl:Class ;
    rdfs:label "Pantalla" .

ex:BotónSimularCiclo a owl:Class ;
    rdfs:label "Botón simular ciclo" .

ex:BotónEjecutarCiclo a owl:Class ;
    rdfs:label "Botón ejecutar ciclo" .

ex:BotónMemorizarCiclo a owl:Class ;
    rdfs:label "Botón memorizar ciclo" .

ex:BotónInspección a owl:Class ;
    rdfs:label "Botón inspección" .

ex:SoftkeyVertical a owl:Class ;
    rdfs:label "Softkey vertical" .

ex:IconoPieza a owl:Class ;
    rdfs:label "Icono de pieza" .

ex:IconoOperación a owl:Class ;
    rdfs:label "Icono de operación" .

ex:IconoRefrigerante a owl:Class ;
    rdfs:label "Icono de refrigerante" .

ex:IconoInspección a owl:Class ;
    rdfs:label "Icono de inspección" .

ex:tieneBotón a owl:ObjectProperty ;
    rdfs:domain ex:PantallaPrincipal ;
    rdfs:range ex:Botón .

ex:tieneCicloBrochado a owl:ObjectProperty ;
    rdfs:domain ex:PantallaPrincipal ;
    rdfs:range ex:CicloBrochado .

ex:tieneTipoPieza a owl:ObjectProperty ;
    rdfs:domain ex:CicloBrochado ;
    rdfs:range ex:TipoPieza .

ex:tienePiezaAnillo a owl:ObjectProperty ;
    rdfs:domain ex:TipoPieza ;
    rdfs:range ex:PiezaAnillo .

ex:tienePiezaPlana a owl:ObjectProperty ;
    rdfs:domain ex:TipoPieza ;
    rdfs:range ex:PiezaPlana .

ex:tieneTipoOperación a owl:ObjectProperty ;
    rdfs:domain ex:CicloBrochado ;
    rdfs:range ex:TipoOperación .

ex:tieneDesbaste a owl:ObjectProperty ;
    rdfs:domain ex:TipoOperación ;
    rdfs:range ex:Desbaste .

ex:tieneAcabado a owl:ObjectProperty ;
    rdfs:domain ex:TipoOperación ;
    rdfs:range ex:Acabado .

ex:tieneRefrigeración a owl:ObjectProperty ;
    rdfs:domain ex:CicloBrochado ;
    rdfs:range ex:Refrigeración .

ex:tieneRefrigerante a owl:ObjectProperty ;
    rdfs:domain ex:Refrigeración ;
    rdfs:range ex:Refrigerante .

ex:tieneSinRefrigerante a owl:ObjectProperty ;
    rdfs:domain ex:Refrigeración ;
    rdfs:range ex:SinRefrigerante .

ex:tieneParámetroBrochado a owl:ObjectProperty ;
    rdfs:domain ex:CicloBrochado ;
    rdfs:range ex:ParámetroBrochado .

ex:tieneAvance a owl:ObjectProperty ;
    rdfs:domain ex:ParámetroBrochado ;
    rdfs:range ex:Avance .

ex:tienePosiciónInicial a owl:ObjectProperty ;
    rdfs:domain ex:ParámetroBrochado ;
    rdfs:range ex:PosiciónInicial .

ex:tieneNúmeroRanuras a owl:ObjectProperty ;
    rdfs:domain ex:ParámetroBrochado ;
    rdfs:range ex:NúmeroRanuras .

ex:tienePasoEntreRanuras a owl:ObjectProperty ;
    rdfs:domain ex:ParámetroBrochado ;
    rdfs:range ex:PasoEntreRanuras .

ex:tieneSoftkey a owl:ObjectProperty ;
    rdfs:domain ex:Pantalla ;
    rdfs:range ex:Softkey .

ex:tieneSimulaciónCiclo a owl:ObjectProperty ;
    rdfs:domain ex:Softkey ;
    rdfs:range ex:SimulaciónCiclo .

ex:tieneEjecuciónCiclo a owl:ObjectProperty ;
    rdfs:domain ex:Softkey ;
    rdfs:range ex:EjecuciónCiclo .

ex:tieneMemorizaciónCiclo a owl:ObjectProperty ;
    rdfs:domain ex:Softkey ;
    rdfs:range ex:MemorizaciónCiclo .

ex:tieneCicloInspección a owl:ObjectProperty ;
    rdfs:domain ex:CicloBrochado ;
    rdfs:range ex:CicloInspección .

ex:tieneInspección a owl:ObjectProperty ;
    rdfs:domain ex:CicloBrochado ;
    rdfs:range ex:Inspección .

ex:tienePasoIncremento a owl:ObjectProperty ;
    rdfs:domain ex:Inspección ;
    rdfs:range ex:PasoIncremento .

ex:tieneIcono a owl:ObjectProperty ;
    rdfs:domain ex:Pantalla ;
    rdfs:range ex:Icono .

ex:tieneIconoPieza a owl:ObjectProperty ;
    rdfs:domain ex:Pantalla ;
    rdfs:range ex:IconoPieza .

ex:tieneIconoOperación a owl:ObjectProperty ;
    rdfs:domain ex:Pantalla ;
    rdfs:range ex:IconoOperación .

ex:tieneIconoRefrigerante a owl:ObjectProperty ;
    rdfs:domain ex:Pantalla ;
    rdfs:range ex:IconoRefrigerante .

ex:tieneIconoInspección a owl:ObjectProperty ;
    rdfs:domain ex:Pantalla ;
    rdfs:range ex:IconoInspección .

ex:tieneBotónSimularCiclo a owl:ObjectProperty ;
    rdfs:domain ex:Pantalla ;
    rdfs:range ex:BotónSimularCiclo .

ex:tieneBotónEjecutarCiclo a owl:ObjectProperty ;
    rdfs:domain ex:Pantalla ;
    rdfs:range ex:BotónEjecutarCiclo .

ex:tieneBotónMemorizarCiclo a owl:ObjectProperty ;
    rdfs:domain ex:Pantalla ;
    rdfs:range ex:BotónMemorizarCiclo .

ex:tieneBotónInspección a owl:ObjectProperty ;
    rdfs:domain ex:Pantalla ;
    rdfs:range ex:BotónInspección .

ex:tieneSoftkeyVertical a owl:ObjectProperty ;
    rdfs:domain ex:Pantalla ;
    rdfs:range ex:SoftkeyVertical .