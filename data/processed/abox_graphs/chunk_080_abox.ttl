@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionMemorizarCiclo a ns1:AccionProhibida ;
    rdfs:label "Memorizar ciclo"@es ;
    ns1:ejecutadoPor ns1:InterfazUsuario ;
    ns1:textoExtracto "Memorizar ciclo"@es .

ns1:AccionNuevoPrograma a ns1:AccionProhibida ;
    rdfs:label "Nuevo programa"@es ;
    ns1:ejecutadoPor ns1:InterfazUsuario ;
    ns1:textoExtracto "Nuevo programa"@es .

ns1:AccionPonerNombre a ns1:AccionProhibida ;
    rdfs:label "Poner nombre deseado"@es ;
    ns1:ejecutadoPor ns1:InterfazUsuario ;
    ns1:textoExtracto "Poner nombre deseado"@es .

ns1:AccionPulsarParametrosMas a ns1:AccionProhibida ;
    rdfs:label "Pulsar parámetros +"@es ;
    ns1:compuestoPor ns1:ProgramaBrochado ;
    ns1:controla ns1:ParametroBrochado ;
    ns1:ejecutadoPor ns1:InterfazUsuario ;
    ns1:textoExtracto "Pulsar parámetros +, vuelca parámetros de brochado al programa"@es .

ns1:InstruccionM30 a ns1:AccionProhibida ;
    rdfs:label "M30"@es ;
    ns1:ejecutadoPor ns1:InterfazUsuario ;
    ns1:textoExtracto "Se añade un M30 al final"@es .

ns1:PantallaCicloBrochado a ns1:InterfazUsuario ;
    rdfs:label "pantalla de ciclo de brochado"@es ;
    ns1:compuestoPor ns1:ParametroBrochado ;
    ns1:textoExtracto "En la pantalla de ciclo de brochado se seleccionan los parámetros deseados"@es .

ns1:ProgramaBrochado a ns1:Esquema ;
    rdfs:label "programa de brochado"@es ;
    ns1:compuestoPor ns1:ParametroBrochado ;
    ns1:textoExtracto "guardarlos en un programa nuevo"@es .

ns1:ParametroBrochado a ns1:Parametro ;
    rdfs:label "parámetros de brochado"@es ;
    ns1:textoExtracto "parámetros deseados"@es .

