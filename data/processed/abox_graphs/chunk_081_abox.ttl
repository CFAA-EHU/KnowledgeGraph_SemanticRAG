@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteElectrico_BotonEliminar_81 a ns1:ComponenteElectrico ;
    rdfs:label "Botón Eliminar" ;
    ns1:textoExtracto "Pulsar Eliminar" .

ns1:ComponenteElectrico_BotonUtilities_81 a ns1:ComponenteElectrico ;
    rdfs:label "Botón Utilities" ;
    ns1:textoExtracto "Pulsar Utilities" .

ns1:InterfazUsuario_NavegadorCarpetas_81 a ns1:InterfazUsuario ;
    rdfs:label "Navegador de carpetas" ;
    ns1:textoExtracto "acceder al navegador de carpetas" .

ns1:Programa_Borrar_81 a ns1:TareaMantenimiento ;
    rdfs:label "Borrar programa" ;
    ns1:textoExtracto "Para borrar un programa ya guardado, acceder al navegador de carpetas, para ello: Pulsar Utilities  Acceder a la carpeta C:\\FAGORCNC\\Users\\PRG  Seleccionar programa que se desea borrar  Pulsar Eliminar " .

ns1:Sistema_ProgramasFAGORCNC_81 a ns1:Sistema ;
    rdfs:label "Sistema de programas FAGOR CNC" ;
    ns1:textoExtracto "Acceder a la carpeta C:\\FAGORCNC\\Users\\PRG" .

