@prefix base: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

base:NavegadorDeCarpetas a owl:Class ;
    rdfs:label "Navegador de carpetas"@es .

base:Programa a owl:Class ;
    rdfs:label "Programa"@es .

base:Pulsar a owl:Class ;
    rdfs:label "Pulsar"@es .

base:Acceder a owl:ObjectProperty ;
    rdfs:label "acceder a"@es ;
    rdfs:domain base:NavegadorDeCarpetas ;
    rdfs:range base:Carpeta .

base:Seleccionar a owl:ObjectProperty ;
    rdfs:label "seleccionar"@es ;
    rdfs:domain base:NavegadorDeCarpetas ;
    rdfs:range base:Programa .

base:Eliminar a owl:ObjectProperty ;
    rdfs:label "eliminar"@es ;
    rdfs:domain base:NavegadorDeCarpetas ;
    rdfs:range base:Programa .

base:tieneRuta a owl:DatatypeProperty ;
    rdfs:label "tiene ruta"@es ;
    rdfs:domain base:Carpeta ;
    rdfs:range xsd:string .

base:Carpeta a owl:Class ;
    rdfs:label "Carpeta"@es .

base:Utilities a owl:Class ;
    rdfs:label "Utilities"@es .