@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Programa a owl:Class .
ex:Instrucción a owl:Class .
ex:Parámetro a owl:Class .
ex:PantallaCicloBrochado a owl:Class .
ex:ImagenCicloBrochado a owl:Class .

ex:tieneInstrucción a owl:ObjectProperty ;
    rdfs:domain ex:Programa ;
    rdfs:range ex:Instrucción .

ex:tieneParámetros a owl:ObjectProperty ;
    rdfs:domain ex:Instrucción ;
    rdfs:range ex:Parámetro .

ex:cargarParámetros a owl:ObjectProperty ;
    rdfs:domain ex:Instrucción ;
    rdfs:range ex:Parámetro .

ex:mostrarImagenCicloBrochado a owl:ObjectProperty ;
    rdfs:domain ex:Instrucción ;
    rdfs:range ex:ImagenCicloBrochado .

ex:llevarAPantallaCicloBrochado a owl:ObjectProperty ;
    rdfs:domain ex:ImagenCicloBrochado ;
    rdfs:range ex:PantallaCicloBrochado .

ex:recall a owl:ObjectProperty ;
    rdfs:domain ex:Instrucción ;
    rdfs:range ex:ImagenCicloBrochado .

ex:tienePrograma a owl:ObjectProperty ;
    rdfs:domain ex:ListaProgramas ;
    rdfs:range ex:Programa .

ex:ListaProgramas a owl:Class .