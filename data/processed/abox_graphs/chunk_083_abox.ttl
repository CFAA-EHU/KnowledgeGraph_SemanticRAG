@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:PantallaParámetrosDeBrochado a owl:Class ;
    rdfs:label "Pantalla de parámetros de brochado"@es .

ex:VentanaEmergente a owl:Class ;
    rdfs:label "Ventana emergente"@es .

ex:Programa a owl:Class ;
    rdfs:label "Programa"@es .

ex:CicloTrabajo a owl:Class ;
    rdfs:label "Ciclo de trabajo"@es .

ex:Softkey a owl:Class ;
    rdfs:label "Softkey"@es .

ex:Parámetro a owl:Class ;
    rdfs:label "Parámetro"@es .

ex:tieneVentanaEmergente a owl:ObjectProperty ;
    rdfs:domain ex:PantallaParámetrosDeBrochado ;
    rdfs:range ex:VentanaEmergente .

ex:tieneSoftkey a owl:ObjectProperty ;
    rdfs:domain ex:PantallaParámetrosDeBrochado ;
    rdfs:range ex:Softkey .

ex:tienePrograma a owl:ObjectProperty ;
    rdfs:domain ex:PantallaParámetrosDeBrochado ;
    rdfs:range ex:Programa .

ex:tieneCicloTrabajo a owl:ObjectProperty ;
    rdfs:domain ex:PantallaParámetrosDeBrochado ;
    rdfs:range ex:CicloTrabajo .

ex:tieneParámetro a owl:ObjectProperty ;
    rdfs:domain ex:Programa ;
    rdfs:range ex:Parámetro .

ex:reemplazarParámetro a owl:ObjectProperty ;
    rdfs:domain ex:VentanaEmergente ;
    rdfs:range ex:Parámetro .

ex:ejecutarPrograma a owl:ObjectProperty ;
    rdfs:domain ex:Softkey ;
    rdfs:range ex:Programa .

ex:seleccionarCicloTrabajo a owl:ObjectProperty ;
    rdfs:domain ex:PantallaParámetrosDeBrochado ;
    rdfs:range ex:CicloTrabajo .

ex:tieneEfecto a owl:ObjectProperty ;
    rdfs:domain ex:Parámetro ;
    rdfs:range xsd:boolean .

ex:requiereSelección a owl:ObjectProperty ;
    rdfs:domain ex:CicloTrabajo ;
    rdfs:range xsd:boolean .