@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:CicloTrabajo a ns1:ModoOperacion ;
    ns1:textoExtracto "ciclo de trabajo" .

ns1:PantallaParametrosBrochado a ns1:InterfazUsuario ;
    ns1:textoExtracto "Estando en la pantalla de parámetros de brochado" ;
    ns1:tieneComponente ns1:ParametroBrochado .

ns1:ProgramaBrochado a ns1:ModoOperacion ;
    ns1:textoExtracto "programa" .

ns1:SoftkeyEjecutarPrograma a ns1:InterfazUsuario ;
    ns1:textoExtracto "Pulsar softkey 'Ejecutar programa'" .

ns1:VentanaEmergenteReemplazarCiclo a ns1:InterfazUsuario ;
    ns1:textoExtracto "ventana emergente '¿Reemplazar el antiguo ciclo o insertar nuevo?'" .

ns1:ParametroBrochado a ns1:Parametro ;
    ns1:textoExtracto "parámetros de brochado" .

