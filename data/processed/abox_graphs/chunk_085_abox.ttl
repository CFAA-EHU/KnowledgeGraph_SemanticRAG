@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PanelDesmontableLateral a ns1:ComponenteMecanico ;
    rdfs:label "panel desmontable" ;
    ns1:textoExtracto "dos paneles desmontables en cada lateral" .

ns1:PanelDesmontableTrasero a ns1:ComponenteMecanico ;
    rdfs:label "panel desmontable" ;
    ns1:textoExtracto "dos paneles desmontables en la parte trasera" .

ns1:PortonDobleCorrederoFrontal a ns1:ComponenteMecanico ;
    rdfs:label "portón doble corredero" ;
    ns1:textoExtracto "un portón doble corredero en la parte frontal" .

ns1:PuertaCorrederaLateral a ns1:ComponenteMecanico ;
    rdfs:label "puerta corredera" ;
    ns1:textoExtracto "una puerta corredera en cada lateral" .

