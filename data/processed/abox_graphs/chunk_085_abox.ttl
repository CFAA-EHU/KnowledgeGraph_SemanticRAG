@prefix base: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:PortonDobleCorredero a owl:Class ;
    rdfs:label "Portón doble corredero" ;
    rdfs:comment "Portón doble corredero en la parte frontal de la máquina" .

base:PuertaCorredera a owl:Class ;
    rdfs:label "Puerta corredera" ;
    rdfs:comment "Puerta corredera en cada lateral de la máquina" .

base:PanelDesmontable a owl:Class ;
    rdfs:label "Panel desmontable" ;
    rdfs:comment "Panel desmontable en los laterales y parte trasera de la máquina" .

base:tienePuertaCorredera a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:PuertaCorredera .

base:tienePortonDobleCorredero a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:PortonDobleCorredero .

base:tienePanelDesmontable a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:PanelDesmontable .