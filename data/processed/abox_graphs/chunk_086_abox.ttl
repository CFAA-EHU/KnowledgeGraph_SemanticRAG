@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:PortonFrontal a owl:Class ;
    rdfs:label "Portón frontal" ;
    rdfs:comment "Portón frontal y puertas correderas laterales: Son de apertura manual y disponen de un dispositivo de seguridad de bloqueo mecánico y desbloqueo eléctrico." .

ex:PuertaCorredera a owl:Class ;
    rdfs:label "Puerta corredera" ;
    rdfs:comment "Portón frontal y puertas correderas laterales: Son de apertura manual y disponen de un dispositivo de seguridad de bloqueo mecánico y desbloqueo eléctrico." .

ex:DispositivoSeguridad a owl:Class ;
    rdfs:label "Dispositivo de seguridad" ;
    rdfs:comment "Dispositivo de seguridad de bloqueo mecánico y desbloqueo eléctrico." .

ex:BloqueoMecanico a owl:Class ;
    rdfs:label "Bloqueo mecánico" ;
    rdfs:comment "Dispositivo de seguridad de bloqueo mecánico y desbloqueo eléctrico." .

ex:DesbloqueoElectrico a owl:Class ;
    rdfs:label "Desbloqueo eléctrico" ;
    rdfs:comment "Dispositivo de seguridad de bloqueo mecánico y desbloqueo eléctrico." .

ex:MaquinaEnEmergencia a owl:Class ;
    rdfs:label "Máquina en emergencia" ;
    rdfs:comment "Para su apertura se tiene que dar cualquiera de estas posibilidades: Máquina en emergencia." .

ex:MaquinaEnServicio a owl:Class ;
    rdfs:label "Máquina en servicio" ;
    rdfs:comment "Para su apertura se tiene que dar cualquiera de estas posibilidades: Máquina en servicio y pulsar el botón 'Apertura puertas'." .

ex:BotonAperturaPuertas a owl:Class ;
    rdfs:label "Botón Apertura puertas" ;
    rdfs:comment "Para su apertura se tiene que dar cualquiera de estas posibilidades: Máquina en servicio y pulsar el botón 'Apertura puertas'." .

ex:CicloCambioCremallera a owl:Class ;
    rdfs:label "Ciclo de cambio de cremallera" ;
    rdfs:comment "Para su apertura se tiene que dar cualquiera de estas posibilidades: Ciclo de cambio de cremallera con carro porta-pieza en posición inferior." .

ex:CarroPortaPieza a owl:Class ;
    rdfs:label "Carro porta-pieza" ;
    rdfs:comment "Para su apertura se tiene que dar cualquiera de estas posibilidades: Ciclo de cambio de cremallera con carro porta-pieza en posición inferior." .

ex:PosicionInferior a owl:Class ;
    rdfs:label "Posición inferior" ;
    rdfs:comment "Para su apertura se tiene que dar cualquiera de estas posibilidades: Ciclo de cambio de cremallera con carro porta-pieza en posición inferior." .

ex:ModoSetUp a owl:Class ;
    rdfs:label "Modo set-up" ;
    rdfs:comment "Para su apertura se tiene que dar cualquiera de estas posibilidades: Modo set-up y pulsar 'Apertura puertas'." .

ex:VelocidadReducida a owl:Class ;
    rdfs:label "Velocidad reducida" ;
    rdfs:comment "En modo set-up se pueden realizar movimientos con puertas abiertas a velocidad reducida." .

ex:tieneDispositivoSeguridad a owl:ObjectProperty ;
    rdfs:domain ex:PortonFrontal ;
    rdfs:range ex:DispositivoSeguridad .

ex:tieneDispositivoSeguridad a owl:ObjectProperty ;
    rdfs:domain ex:PuertaCorredera ;
    rdfs:range ex:DispositivoSeguridad .

ex:tieneBloqueoMecanico a owl:ObjectProperty ;
    rdfs:domain ex:DispositivoSeguridad ;
    rdfs:range ex:BloqueoMecanico .

ex:tieneDesbloqueoElectrico a owl:ObjectProperty ;
    rdfs:domain ex:DispositivoSeguridad ;
    rdfs:range ex:DesbloqueoElectrico .

ex:requiereEmergenciaParaApertura a owl:ObjectProperty ;
    rdfs:domain ex:PortonFrontal ;
    rdfs:range ex:MaquinaEnEmergencia .

ex:requiereEmergenciaParaApertura a owl:ObjectProperty ;
    rdfs:domain ex:PuertaCorredera ;
    rdfs:range ex:MaquinaEnEmergencia .

ex:requiereMaquinaEnServicioYPulsarBoton a owl:ObjectProperty ;
    rdfs:domain ex:PortonFrontal ;
    rdfs:range ex:MaquinaEnServicio .

ex:requiereMaquinaEnServicioYPulsarBoton a owl:ObjectProperty ;
    rdfs:domain ex:PuertaCorredera ;
    rdfs:range ex:MaquinaEnServicio .

ex:requierePulsarBoton a owl:ObjectProperty ;
    rdfs:domain ex:MaquinaEnServicio ;
    rdfs:range ex:BotonAperturaPuertas .

ex:requiereCicloCambioCremallera a owl:ObjectProperty ;
    rdfs:domain ex:PortonFrontal ;
    rdfs:range ex:CicloCambioCremallera .

ex:requiereCicloCambioCremallera a owl:ObjectProperty ;
    rdfs:domain ex:PuertaCorredera ;
    rdfs:range ex:CicloCambioCremallera .

ex:requiereCarroPortaPiezaEnPosicionInferior a owl:ObjectProperty ;
    rdfs:domain ex:CicloCambioCremallera ;
    rdfs:range ex:CarroPortaPieza .

ex:tienePosicionInferior a owl:ObjectProperty ;
    rdfs:domain ex:CarroPortaPieza ;
    rdfs:range ex:PosicionInferior .

ex:requiereModoSetUpYPulsarBoton a owl:ObjectProperty ;
    rdfs:domain ex:PortonFrontal ;
    rdfs:range ex:ModoSetUp .

ex:requiereModoSetUpYPulsarBoton a owl:ObjectProperty ;
    rdfs:domain ex:PuertaCorredera ;
    rdfs:range ex:ModoSetUp .

ex:requierePulsarBoton a owl:ObjectProperty ;
    rdfs:domain ex:ModoSetUp ;
    rdfs:range ex:BotonAperturaPuertas .

ex:permiteMovimientoConPuertasAbiertas a owl:ObjectProperty ;
    rdfs:domain ex:ModoSetUp ;
    rdfs:range ex:VelocidadReducida .