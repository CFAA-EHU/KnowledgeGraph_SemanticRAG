@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:BotonPuestaServicio_88 a ns1:InterfazUsuario ;
    ns1:textoExtracto "Pulsar el botón 'PUESTA SERVICIO'" .

ns1:BotonReset_88 a ns1:InterfazUsuario ;
    ns1:textoExtracto "Pulsar botón 'RESET'" .

ns1:Emergencia_88 a ns1:ElementoSeguridad ;
    ns1:textoExtracto "asegurarse de que ninguna emergencia esté pulsada" .

ns1:ModoManual_88 a ns1:ModoOperacion ;
    ns1:textoExtracto "Brochadora en servicio. Reset Auto Manual" .

ns1:VentanaAvisos_88 a ns1:AvisoSeguridad ;
    ns1:textoExtracto "Siempre atendiendo las indicaciones de la ventana de avisos" .

