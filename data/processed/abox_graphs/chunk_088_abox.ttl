@prefix ex: <https://vocab.cfaa.eus/broaching/>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

ex:VentanaAvisos a owl:Class ;
    rdfs:label "Ventana de avisos"@es ;
    rdfs:comment "Ventana que muestra indicaciones y avisos durante el funcionamiento de la máquina."@es .

ex:BotonReset a owl:Class ;
    rdfs:label "Botón de reset"@es ;
    rdfs:comment "Botón utilizado para reiniciar el sistema o componentes de la máquina."@es .

ex:BotonPuestaServicio a owl:Class ;
    rdfs:label "Botón de puesta en servicio"@es ;
    rdfs:comment "Botón utilizado para poner la máquina en servicio."@es .

ex:Brochadora a owl:Class ;
    rdfs:label "Brochadora"@es ;
    rdfs:comment "Máquina utilizada para el proceso de brochado."@es .

ex:Emergencia a owl:Class ;
    rdfs:label "Emergencia"@es ;
    rdfs:comment "Situación de emergencia que requiere la atención inmediata del operador."@es .

ex:Pulsar a owl:ObjectProperty ;
    rdfs:domain ex:BotonReset ;
    rdfs:range ex:Brochadora ;
    rdfs:label "Pulsar"@es ;
    rdfs:comment "Acción de pulsar un botón para realizar una función específica."@es .

ex:PulsarBotonPuestaServicio a owl:ObjectProperty ;
    rdfs:domain ex:BotonPuestaServicio ;
    rdfs:range ex:Brochadora ;
    rdfs:label "Pulsar botón de puesta en servicio"@es ;
    rdfs:comment "Acción de pulsar el botón de puesta en servicio para activar la máquina."@es .

ex:ResetAutoManual a owl:Class ;
    rdfs:label "Reset auto manual"@es ;
    rdfs:comment "Modo de reset que puede ser automático o manual."@es .

ex:estaPulsada a owl:ObjectProperty ;
    rdfs:domain ex:Emergencia ;
    rdfs:range xsd:boolean ;
    rdfs:label "Está pulsada"@es ;
    rdfs:comment "Indica si la emergencia está activada o no."@es .