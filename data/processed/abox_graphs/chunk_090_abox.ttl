@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CicloAnilloAcabado a ns1:TareaMantenimiento ;
    rdfs:label "Ciclo anillo acabado"@es ;
    ns1:textoExtracto "4. Ciclo anillo acabado El ciclo inicia con el carro posicionándose en la cota de inspección con el plato girado en el primer diente."@es .

ns1:CicloAnilloDesbaste a ns1:TareaMantenimiento ;
    rdfs:label "Ciclo anillo desbaste"@es ;
    ns1:textoExtracto "3. Ciclo anillo desbaste El ciclo inicia aproximando el carro a la posición de verificación con el plato en 0º, hay un M0 donde se pueden abrir las puertas para verificar que el 0º de la anilla está correctamente posicionada (así queda verificado que en el retorno que siempre es a 0º es correcto). Se cierran las puertas y dando 'Marcha ciclo' el carro sube hasta arriba a velocidad de brochado para que en el caso de que no estuviera bien posicionada la anilla la broche en 0º. Los siguientes brochados se hacen respecto al inicio del primer brochado con su incremento y número de dientes. Siempre volviendo a 0º para la bajada del carro. Se podrá seleccionar si se desea con ciclo inspección o no."@es .

ns1:CicloInspeccion a ns1:TareaMantenimiento ;
    rdfs:label "Ciclo inspección"@es ;
    ns1:textoExtracto "1. Ciclo inspección El carro sube a posición de inspección con el plato en 0º. En esta posición se pueden abrir las puertas y mover el carro hasta la posición deseada para la primera foto. Una vez cerradas las puertas, la posición actual se coge como primer punto de inspección y hace movimiento hasta el siguiente incremento y volviendo a parar con un M0. La última posición es la de carro arriba (3150mm). Este ciclo se utiliza con anillo, pudiendo seleccionar cada cuantas ranuras se desea ejecutar este ciclo."@es .

ns1:CicloPlana a ns1:TareaMantenimiento ;
    rdfs:label "Ciclo plana"@es ;
    ns1:textoExtracto "2. Ciclo plana La pieza a brochar se coloca a 90º. Selección de desbaste (limitado la velocidad de brochado a 5000 mm/min) o acabado (limitado la velocidad de brochado a 5000 mm/min). No tiene la opción de inspección ."@es .

ns1:M0 a ns1:TareaMantenimiento ;
    rdfs:label "M0"@es ;
    ns1:textoExtracto "volviendo a parar con un M0"@es .

ns1:ModoAutomatico a ns1:ModoOperacion ;
    rdfs:label "modo automático"@es ;
    ns1:textoExtracto "Para seleccionar el modo de trabajo automático: Con máquina en servicio y presión general de aire OK.  Puertas con enclavamiento de seguridad cerradas y bloqueadas.  Seleccionar el modo automático."@es .

ns1:Plato0 a ns1:Parametro ;
    rdfs:label "plato en 0º"@es ;
    ns1:textoExtracto "con el plato en 0º"@es .

ns1:Plato90 a ns1:Parametro ;
    rdfs:label "plato en 90º"@es ;
    ns1:textoExtracto "La pieza a brochar se coloca a 90º."@es .

ns1:PosicionCarroArriba a ns1:Parametro ;
    rdfs:label "posición de carro arriba"@es ;
    ns1:textoExtracto "La última posición es la de carro arriba (3150mm)."@es ;
    ns1:valor "3150mm" .

ns1:PosicionInspeccion a ns1:Parametro ;
    rdfs:label "posición de inspección"@es ;
    ns1:textoExtracto "El carro sube a posición de inspección con el plato en 0º."@es .

ns1:PosicionVerificacion a ns1:Parametro ;
    rdfs:label "posición de verificación"@es ;
    ns1:textoExtracto "aproximando el carro a la posición de verificación con el plato en 0º"@es .

ns1:VelocidadBrochado5000 a ns1:Parametro ;
    rdfs:label "velocidad de brochado 5000 mm/min"@es ;
    ns1:textoExtracto "limitado la velocidad de brochado a 5000 mm/min"@es ;
    ns1:valor "5000 mm/min" .

