@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:ModoAutomatico a owl:Class ;
    rdfs:label "Modo de trabajo automático"@es .

ex:ModoTrabajo a owl:Class ;
    rdfs:label "Modo de trabajo"@es .

ex:CicloInspeccion a owl:Class ;
    rdfs:label "Ciclo de inspección"@es .

ex:CicloPlana a owl:Class ;
    rdfs:label "Ciclo plana"@es .

ex:CicloAnilloDesbaste a owl:Class ;
    rdfs:label "Ciclo anillo desbaste"@es .

ex:CicloAnilloAcabado a owl:Class ;
    rdfs:label "Ciclo anillo acabado"@es .

ex:Carro a owl:Class ;
    rdfs:label "Carro"@es .

ex:PlatoDivisor a owl:Class ;
    rdfs:label "Plato divisor"@es .

ex:Puerta a owl:Class ;
    rdfs:label "Puerta"@es .

ex:EnclavamientoDeSeguridad a owl:Class ;
    rdfs:label "Enclavamiento de seguridad"@es .

ex:PiezaABrochar a owl:Class ;
    rdfs:label "Pieza a brochar"@es .

ex:Desbaste a owl:Class ;
    rdfs:label "Desbaste"@es .

ex:Acabado a owl:Class ;
    rdfs:label "Acabado"@es .

ex:VelocidadBrochado a owl:Class ;
    rdfs:label "Velocidad de brochado"@es .

ex:Incremento a owl:Class ;
    rdfs:label "Incremento"@es .

ex:Diente a owl:Class ;
    rdfs:label "Diente"@es .

ex:Anilla a owl:Class ;
    rdfs:label "Anilla"@es .

ex:Posicion a owl:Class ;
    rdfs:label "Posición"@es .

ex:MarchaCiclo a owl:Class ;
    rdfs:label "Marcha ciclo"@es .

ex:PuntoInspeccion a owl:Class ;
    rdfs:label "Punto de inspección"@es .

ex:Ranura a owl:Class ;
    rdfs:label "Ranura"@es .

ex:MaquinaEnServicio a owl:Class ;
    rdfs:label "Máquina en servicio"@es .

ex:PresionGeneralDeAire a owl:Class ;
    rdfs:label "Presión general de aire"@es .

ex:seleccionarModoAutomatico a owl:ObjectProperty ;
    rdfs:domain ex:ModoTrabajo ;
    rdfs:range ex:ModoAutomatico .

ex:ejecutarCiclo a owl:ObjectProperty ;
    rdfs:domain ex:ModoAutomatico ;
    rdfs:range ex:CicloInspeccion .

ex:ejecutarCiclo a owl:ObjectProperty ;
    rdfs:domain ex:ModoAutomatico ;
    rdfs:range ex:CicloPlana .

ex:ejecutarCiclo a owl:ObjectProperty ;
    rdfs:domain ex:ModoAutomatico ;
    rdfs:range ex:CicloAnilloDesbaste .

ex:ejecutarCiclo a owl:ObjectProperty ;
    rdfs:domain ex:ModoAutomatico ;
    rdfs:range ex:CicloAnilloAcabado .

ex:subirCarro a owl:ObjectProperty ;
    rdfs:domain ex:Carro ;
    rdfs:range ex:Posicion .

ex:girarPlato a owl:ObjectProperty ;
    rdfs:domain ex:PlatoDivisor ;
    rdfs:range xsd:integer .

ex:abrirPuertas a owl:ObjectProperty ;
    rdfs:domain ex:Puerta ;
    rdfs:range xsd:boolean .

ex:cerrarPuertas a owl:ObjectProperty ;
    rdfs:domain ex:Puerta ;
    rdfs:range xsd:boolean .

ex:verificarPosicion a owl:ObjectProperty ;
    rdfs:domain ex:Anilla ;
    rdfs:range xsd:boolean .

ex:seleccionarDesbaste a owl:ObjectProperty ;
    rdfs:domain ex:Desbaste ;
    rdfs:range ex:VelocidadBrochado .

ex:seleccionarAcabado a owl:ObjectProperty ;
    rdfs:domain ex:Acabado ;
    rdfs:range ex:VelocidadBrochado .

ex:seleccionarIncremento a owl:ObjectProperty ;
    rdfs:domain ex:Incremento ;
    rdfs:range xsd:integer .

ex:seleccionarDiente a owl:ObjectProperty ;
    rdfs:domain ex:Diente ;
    rdfs:range xsd:integer .

ex:seleccionarCicloInspeccion a owl:ObjectProperty ;
    rdfs:domain ex:CicloAnilloDesbaste ;
    rdfs:range xsd:boolean .

ex:seleccionarCicloInspeccion a owl:ObjectProperty ;
    rdfs:domain ex:CicloAnilloAcabado ;
    rdfs:range xsd:boolean .

ex:tieneEnclavamientoDeSeguridad a owl:ObjectProperty ;
    rdfs:domain ex:Puerta ;
    rdfs:range ex:EnclavamientoDeSeguridad .

ex:tienePiezaABrochar a owl:ObjectProperty ;
    rdfs:domain ex:CicloPlana ;
    rdfs:range ex:PiezaABrochar .

ex:tieneVelocidadBrochado a owl:ObjectProperty ;
    rdfs:domain ex:Desbaste ;
    rdfs:range ex:VelocidadBrochado .

ex:tieneVelocidadBrochado a owl:ObjectProperty ;
    rdfs:domain ex:Acabado ;
    rdfs:range ex:VelocidadBrochado .

ex:tieneIncremento a owl:ObjectProperty ;
    rdfs:domain ex:CicloInspeccion ;
    rdfs:range ex:Incremento .

ex:tieneDiente a owl:ObjectProperty ;
    rdfs:domain ex:CicloAnilloDesbaste ;
    rdfs:range ex:Diente .

ex:tieneDiente a owl:ObjectProperty ;
    rdfs:domain ex:CicloAnilloAcabado ;
    rdfs:range ex:Diente .

ex:tieneCicloInspeccion a owl:ObjectProperty ;
    rdfs:domain ex:CicloAnilloDesbaste ;
    rdfs:range xsd:boolean .

ex:tieneCicloInspeccion a owl:ObjectProperty ;
    rdfs:domain ex:CicloAnilloAcabado ;
    rdfs:range xsd:boolean .

ex:tieneEnclavamientoDeSeguridad a owl:ObjectProperty ;
    rdfs:domain ex:Puerta ;
    rdfs:range ex:EnclavamientoDeSeguridad .

ex:tienePiezaABrochar a owl:ObjectProperty ;
    rdfs:domain ex:CicloPlana ;
    rdfs:range ex:PiezaABrochar .

ex:tieneVelocidadBrochado a owl:ObjectProperty ;
    rdfs:domain ex:Desbaste ;
    rdfs:range ex:VelocidadBrochado .

ex:tieneVelocidadBrochado a owl:ObjectProperty ;
    rdfs:domain ex:Acabado ;
    rdfs:range ex:VelocidadBrochado .

ex:tieneIncremento a owl:ObjectProperty ;
    rdfs:domain ex:CicloInspeccion ;
    rdfs:range ex:Incremento .

ex:tieneDiente a owl:ObjectProperty ;
    rdfs:domain ex:CicloAnilloDesbaste ;
    rdfs:range ex:Diente .

ex:tieneDiente a owl:ObjectProperty ;
    rdfs:domain ex:CicloAnilloAcabado ;
    rdfs:range ex:Diente .

ex:tieneCicloInspeccion a owl:ObjectProperty ;
    rdfs:domain ex:CicloAnilloDesbaste ;
    rdfs:range xsd:boolean .

ex:tieneCicloInspeccion a owl:ObjectProperty ;
    rdfs:domain ex:CicloAnilloAcabado ;
    rdfs:range xsd:boolean .

ex:tieneMaquinaEnServicio a owl:ObjectProperty ;
    rdfs:domain ex:ModoAutomatico ;
    rdfs:range ex:MaquinaEnServicio .

ex:tienePresionGeneralDeAire a owl:ObjectProperty ;
    rdfs:domain ex:ModoAutomatico ;
    rdfs:range ex:PresionGeneralDeAire .

ex:tieneEnclavamientoDeSeguridad a owl:ObjectProperty ;
    rdfs:domain ex:Puerta ;
    rdfs:range ex:EnclavamientoDeSeguridad .

ex:tienePiezaABrochar a owl:ObjectProperty ;
    rdfs:domain ex:CicloPlana ;
    rdfs:range ex:PiezaABrochar .

ex:tieneVelocidadBrochado a owl:ObjectProperty ;
    rdfs:domain ex:Desbaste ;
    rdfs:range ex:VelocidadBrochado .

ex:tieneVelocidadBrochado a owl:ObjectProperty ;
    rdfs:domain ex:Acabado ;
    rdfs:range ex:VelocidadBrochado .

ex:tieneIncremento a owl:ObjectProperty ;
    rdfs:domain ex:CicloInspeccion ;
    rdfs:range ex:Incremento .

ex:tieneDiente a owl:ObjectProperty ;
    rdfs:domain ex:CicloAnilloDesbaste ;
    rdfs:range ex:Diente .

ex:tieneDiente a owl:ObjectProperty ;
    rdfs:domain ex:CicloAnilloAcabado ;
    rdfs:range ex:Diente .

ex:tieneCicloInspeccion a owl:ObjectProperty ;
    rdfs:domain ex:CicloAnilloDesbaste ;
    rdfs:range xsd:boolean .

ex:tieneCicloInspeccion a owl:ObjectProperty ;
    rdfs:domain ex:CicloAnilloAcabado ;
    rdfs:range xsd:boolean .