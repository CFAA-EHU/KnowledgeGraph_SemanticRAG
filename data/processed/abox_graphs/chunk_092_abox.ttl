@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:SistemaBrochado a ns1:Maquina ;
    ns1:compuestoPor ns1:Carro,
        ns1:PlatoGiratorio,
        ns1:Puerta ;
    ns1:textoExtracto "empieza a brochar desde el primer diente" ;
    ns1:tieneComponente ns1:CicloInspeccion,
        ns1:CotaInspeccion .

ns1:Carro a ns1:ComponenteMecanico ;
    ns1:textoExtracto "el carro sube" .

ns1:CicloInspeccion a ns1:ModoOperacion ;
    ns1:textoExtracto "Se podrá seleccionar si se desea con ciclo inspección o no" .

ns1:CotaInspeccion a ns1:Parametro ;
    ns1:textoExtracto "cota de inspección" .

ns1:PlatoGiratorio a ns1:ComponenteMecanico ;
    ns1:textoExtracto "plato girado en el primer diente" .

ns1:Puerta a ns1:ElementoSeguridad ;
    ns1:textoExtracto "se pueden abrir las puertas para verificación visual" .

