@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:CotaInspeccion a owl:Class ;
    rdfs:label "Cota de inspección" .

ex:PlatoGirado a owl:Class ;
    rdfs:label "Plato girado" .

ex:Diente a owl:Class ;
    rdfs:label "Diente" .

ex:Carro a owl:Class ;
    rdfs:label "Carro" .

ex:CotaVerificacion a owl:Class ;
    rdfs:label "Cota de verificación" .

ex:Puerta a owl:Class ;
    rdfs:label "Puerta" .

ex:Incremento a owl:Class ;
    rdfs:label "Incremento" .

ex:CicloInspeccion a owl:Class ;
    rdfs:label "Ciclo de inspección" .

ex:Brochado a owl:Class ;
    rdfs:label "Brochado" .

ex:verificarVisualmente a owl:ObjectProperty ;
    rdfs:domain ex:Puerta ;
    rdfs:range ex:Diente .

ex:posicionarPlato a owl:ObjectProperty ;
    rdfs:domain ex:Carro ;
    rdfs:range ex:Diente .

ex:subirCarro a owl:ObjectProperty ;
    rdfs:domain ex:Carro ;
    rdfs:range ex:CotaVerificacion .

ex:abrirPuertas a owl:ObjectProperty ;
    rdfs:domain ex:Puerta ;
    rdfs:range ex:Diente .

ex:seleccionarCicloInspeccion a owl:ObjectProperty ;
    rdfs:domain ex:CicloInspeccion ;
    rdfs:range ex:Brochado .

ex:empezarBrochar a owl:ObjectProperty ;
    rdfs:domain ex:Brochado ;
    rdfs:range ex:Diente .

ex:concuerda a owl:ObjectProperty ;
    rdfs:domain ex:Diente ;
    rdfs:range ex:Diente .

ex:verificarIncremento a owl:ObjectProperty ;
    rdfs:domain ex:Incremento ;
    rdfs:range ex:Diente .

ex:bajarCarro a owl:ObjectProperty ;
    rdfs:domain ex:Carro ;
    rdfs:range ex:Diente .