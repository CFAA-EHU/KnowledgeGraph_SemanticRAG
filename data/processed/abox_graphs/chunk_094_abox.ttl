    rdfs:label "Mantenimiento e Inspección" ;
    rdfs:comment "Capítulo 7" .

ex:Capitulo a owl:Class ;
    rdfs:label "Capítulo" .

ex:Mantenimiento a owl:Class ;
    rdfs:label "Mantenimiento" .

ex:Inspeccion a owl:Class ;
    rdfs:label "Inspección" .

ex:Brochadora a owl:Class ;
    rdfs:label "Brochadora" .

ex:Electromecanica a owl:Class ;
    rdfs:label "Electromecánica" .

ex:Exteriores a owl:Class ;
    rdfs:label "Exteriores" .

ex:Modelo a owl:Class ;
    rdfs:label "Modelo" .

ex:Rashem a owl:Class ;
    rdfs:label "Rashem" .

ex:Dimensiones a owl:Class ;
    rdfs:label "Dimensiones" .