@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_LimpiezaAirePresion_95 a ns1:AccionProhibida ;
    rdfs:label "no utilizar aire a presión para trabajos de limpieza" ;
    ns1:textoExtracto "¡NO UTILIZAR AIRE A PRESION PARA TRABAJOS DE LIMPIEZA!" .

ns1:InterruptorGeneralArmarioElectrico_95 a ns1:ComponenteElectrico ;
    rdfs:label "interruptor general del armario eléctrico" ;
    ns1:textoExtracto "INTERRUPTOR GENERAL DEL ARMARIO ELÉCTRICO" .

ns1:MastilAnticaidas_95 a ns1:EPI ;
    rdfs:label "mástil anticaídas" ;
    ns1:textoExtracto "COLOCAR EL MÁSTIL ANTICAÍDAS" .

ns1:PlanMantenimiento_95 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "PLAN DE MANTENIMIENTO" .

ns1:SeccionadorGeneralArmarioElectrico_95 a ns1:ComponenteElectrico ;
    rdfs:label "seccionador general del armario eléctrico" ;
    ns1:textoExtracto "EL SECCIONADOR GENERAL DEL ARMARIO ELECTRICO" .

ns1:ValvulaManualEntradaAire_95 a ns1:Componente ;
    rdfs:label "válvula manual de entrada general de aire" ;
    ns1:textoExtracto "LA VALVULA MANUAL DE ENTRADA GENERAL DE AIRE" .

