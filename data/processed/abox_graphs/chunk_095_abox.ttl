@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:PlanDeMantenimiento a owl:Class ;
    rdfs:label "Plan de Mantenimiento"@es .

ex:TrabajoDeMantenimiento a owl:Class ;
    rdfs:label "Trabajo de Mantenimiento"@es .

ex:TrabajoDeLimpieza a owl:Class ;
    rdfs:label "Trabajo de Limpieza"@es .

ex:MedidaDeSeguridad a owl:Class ;
    rdfs:label "Medida de Seguridad"@es .

ex:ValvulaManualDeEntradaGeneralDeAire a owl:Class ;
    rdfs:label "Válvula Manual de Entrada General de Aire"@es .

ex:SeccionadorGeneralDelArmarioElectrico a owl:Class ;
    rdfs:label "Seccionador General del Armario Eléctrico"@es .

ex:MastilAnticaidas a owl:Class ;
    rdfs:label "Mástil Anticaídas"@es .

ex:InterruptorGeneralDelArmarioElectrico a owl:Class ;
    rdfs:label "Interruptor General del Armario Eléctrico"@es .

ex:realizarTrabajoDeMantenimiento a owl:ObjectProperty ;
    rdfs:domain ex:PlanDeMantenimiento ;
    rdfs:range ex:TrabajoDeMantenimiento .

ex:realizarTrabajoDeLimpieza a owl:ObjectProperty ;
    rdfs:domain ex:PlanDeMantenimiento ;
    rdfs:range ex:TrabajoDeLimpieza .

ex:requerirMedidaDeSeguridad a owl:ObjectProperty ;
    rdfs:domain ex:TrabajoDeMantenimiento ;
    rdfs:range ex:MedidaDeSeguridad .

ex:requerirMedidaDeSeguridad a owl:ObjectProperty ;
    rdfs:domain ex:TrabajoDeLimpieza ;
    rdfs:range ex:MedidaDeSeguridad .

ex:bloquearFuncion a owl:ObjectProperty ;
    rdfs:domain ex:MedidaDeSeguridad ;
    rdfs:range ex:ValvulaManualDeEntradaGeneralDeAire .

ex:bloquearFuncion a owl:ObjectProperty ;
    rdfs:domain ex:MedidaDeSeguridad ;
    rdfs:range ex:SeccionadorGeneralDelArmarioElectrico .

ex:requerirMastilAnticaidas a owl:ObjectProperty ;
    rdfs:domain ex:TrabajoDeMantenimiento ;
    rdfs:range ex:MastilAnticaidas .

ex:consignarMaquina a owl:ObjectProperty ;
    rdfs:domain ex:TrabajoDeMantenimiento ;
    rdfs:range ex:InterruptorGeneralDelArmarioElectrico .

ex:prohibirUsoDeAireAPresion a owl:ObjectProperty ;
    rdfs:domain ex:TrabajoDeLimpieza ;
    rdfs:comment "Incompleto: Requiere resolución externa" .