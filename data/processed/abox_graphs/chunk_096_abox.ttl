ex:tienePeriodo a owl:ObjectProperty .
ex:tieneResponsable a owl:ObjectProperty .
ex:tieneOperacion a owl:ObjectProperty .

ex:tienePeriodo rdfs:domain ex:Operacion .
ex:tienePeriodo rdfs:range ex:Periodo .

ex:tieneResponsable rdfs:domain ex:Operacion .
ex:tieneResponsable rdfs:range ex:Responsable .

ex:tieneOperacion rdfs:domain ex:BrochadoraElectromecanicaDeExteriores .
ex:tieneOperacion rdfs:range ex:Operacion .

ex:LimpiezaExteriorMaquina rdfs:label "Limpieza del exterior de la máquina" .
