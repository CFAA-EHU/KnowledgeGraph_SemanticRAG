@prefix ex: <https://vocab.cfaa.eus/broaching/>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.

ex:LimpiezaExteriorMaquina a owl:Class ;
    rdfs:label "LimpiezaExteriorMaquina" ;
    rdfs:comment "Limpieza del exterior de la máquina" .

ex:ComprobarEstanqueidadTuberias a owl:Class ;
    rdfs:label "ComprobarEstanqueidadTuberias" ;
    rdfs:comment "Comprobar la estanqueidad de las tuberías" .

ex:ComprobarAprieteRacores a owl:Class ;
    rdfs:label "ComprobarAprieteRacores" ;
    rdfs:comment "Comprobar el buen apriete de racores" .

ex:ComprobarTemperaturaGrupoHidraulico a owl:Class ;
    rdfs:label "ComprobarTemperaturaGrupoHidraulico" ;
    rdfs:comment "Comprobar la temperatura de trabajo del grupo hidráulico (65ºC Max.)" .

ex:ComprobarFugasAceite a owl:Class ;
    rdfs:label "ComprobarFugasAceite" ;
    rdfs:comment "Comprobar fugas de aceite en mangueras y empalmes" .

ex:ComprobarNivelLubricacion a owl:Class ;
    rdfs:label "ComprobarNivelLubricacion" ;
    rdfs:comment "Comprobar nivel de grasa y aceite en los equipos de lubricación" .

ex:ComprobarNivelDepositoHidraulico a owl:Class ;
    rdfs:label "ComprobarNivelDepositoHidraulico" ;
    rdfs:comment "Comprobar nivel del depósito hidráulico" .

ex:ComprobarNivelDepositoRefrigeracion a owl:Class ;
    rdfs:label "ComprobarNivelDepositoRefrigeracion" ;
    rdfs:comment "Comprobar nivel del depósito de refrigeración" .

ex:ComprobarFugasAireSistemaNeumatico a owl:Class ;
    rdfs:label "ComprobarFugasAireSistemaNeumatico" ;
    rdfs:comment "Comprobar fugas de aire en el sistema neumático" .

ex:PurgarRecipienteFiltroAire a owl:Class ;
    rdfs:label "PurgarRecipienteFiltroAire" ;
    rdfs:comment "Purgar el recipiente del filtro de aire" .

ex:AccionarBombeoEngraseManual a owl:Class ;
    rdfs:label "AccionarBombeoEngraseManual" ;
    rdfs:comment "Accionar el bombeo de engrase manual" .

ex:Cada50Horas a owl:Class ;
    rdfs:label "Cada50Horas" ;
    rdfs:comment "Cada 50 h" .

ex:Operario a owl:Class ;
    rdfs:label "Operario" ;
    rdfs:comment "Operario" .

ex:Mantenimiento a owl:Class ;
    rdfs:label "Mantenimiento" ;
    rdfs:comment "Mantenimiento" .

ex:BrochadoraElectromecanicaDeExteriores a owl:Class ;
    rdfs:label "BrochadoraElectromecanicaDeExteriores" ;
    rdfs:comment "Brochadora Electromecánica de Exteriores" .

ex:A218Rashem7x3000x500 a owl:Class ;
    rdfs:label "A218Rashem7x3000x500" ;
    rdfs:comment "A218/ RASHEM 7x3000x500" .

ex:Capitulo7 a owl:Class ;
    rdfs:label "Capitulo7" ;
    rdfs:comment "CAPÍTULO 7" .

ex:tienePeriodo a owl:ObjectProperty ;
    rdfs:label "tienePeriodo" ;
    rdfs:domain ex:TareaDeMantenimiento ;
    rdfs:range ex:Periodo .

ex:tieneResponsable a owl:ObjectProperty ;
    rdfs:label "tieneResponsable" ;
    rdfs:domain ex:TareaDeMantenimiento ;
    rdfs:range ex:Persona .

ex:tieneOperacion a owl:ObjectProperty ;
    rdfs:label "tieneOperacion" ;
    rdfs:domain ex:TareaDeMantenimiento ;
    rdfs:range ex:Operacion .