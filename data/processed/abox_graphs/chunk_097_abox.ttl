@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix mant: <https://vocab.cfaa.eus/mantenimiento/> .
@prefix base: <https://vocab.cfaa.eus/base/> .

mant:TrabajoSemanales a owl:Class ;
    rdfs:label "Trabajos semanales de mantenimiento" ;
    rdfs:comment "Tareas de mantenimiento programadas semanalmente" .

mant:Operario a owl:Class ;
    rdfs:label "Operario" ;
    rdfs:comment "Persona encargada de realizar tareas de mantenimiento" .

mant:Mantenimiento a owl:Class ;
    rdfs:label "Mantenimiento" ;
    rdfs:comment "Departamento o equipo encargado de tareas de mantenimiento" .

mant:comprobarYCambiarFiltroRefrigerador a owl:Class ;
    rdfs:label "Comprobar y cambiar filtro del refrigerador" ;
    rdfs:comment "Tarea de mantenimiento para verificar y reemplazar el filtro del refrigerador" .

mant:comprobarEstadoCepillos a owl:Class ;
    rdfs:label "Comprobar estado de los cepillos" ;
    rdfs:comment "Tarea de mantenimiento para verificar el estado de los cepillos del sistema de limpieza" .

mant:comprobarInstalacionRefrigerante a owl:Class ;
    rdfs:label "Comprobar instalación de refrigerante" ;
    rdfs:comment "Tarea de mantenimiento para verificar la instalación del refrigerante" .

mant:comprobarPresionesTrabajo a owl:Class ;
    rdfs:label "Comprobar presiones de trabajo" ;
    rdfs:comment "Tarea de mantenimiento para verificar las presiones de trabajo" .

mant:periodo a owl:DatatypeProperty ;
    rdfs:label "Periodo" ;
    rdfs:comment "Periodo de tiempo en el que se realiza la tarea de mantenimiento" ;
    rdfs:domain mant:TrabajoSemanales ;
    rdfs:range xsd:string .

mant:responsable a owl:ObjectProperty ;
    rdfs:label "Responsable" ;
    rdfs:comment "Persona o equipo responsable de realizar la tarea de mantenimiento" ;
    rdfs:domain mant:TrabajoSemanales ;
    rdfs:range mant:Operario .

mant:tienePeriodo a owl:ObjectProperty ;
    rdfs:label "Tiene periodo" ;
    rdfs:comment "Relación entre una tarea de mantenimiento y su periodo de realización" ;
    rdfs:domain mant:TrabajoSemanales ;
    rdfs:range xsd:string .

mant:tieneResponsable a owl:ObjectProperty ;
    rdfs:label "Tiene responsable" ;
    rdfs:comment "Relación entre una tarea de mantenimiento y su responsable" ;
    rdfs:domain mant:TrabajoSemanales ;
    rdfs:range mant:Operario .