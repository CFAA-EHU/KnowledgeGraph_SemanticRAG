@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:SistemaLimpiezaBrocha_97 a ns1:Sistema ;
    ns1:textoExtracto "sistema de limpieza brocha" .

ns1:Tabla_97_77 a ns1:Tabla ;
    ns1:textoExtracto "Comprobar y, si procede, cambiar el filtro del refrigerador del armario Cada 200 h OPERARIO / MANTENIMIENTO Comprobar visualmente el estado de los cepillos del sistema de limpieza brocha Cada 200 h OPERARIO Comprobar la instalación de refrigerante Cada 200 h OPERARIO Comprobar las presiones de trabajo Cada 200 h OPERARIO" ;
    ns1:tieneComponente ns1:CepillosSistemaLimpiezaBrocha_97,
        ns1:FiltroRefrigeradorArmario_97,
        ns1:InstalacionRefrigerante_97,
        ns1:PresionesTrabajo_97 .

ns1:CepillosSistemaLimpiezaBrocha_97 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "cepillos del sistema de limpieza brocha" .

ns1:FiltroRefrigeradorArmario_97 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "filtro del refrigerador del armario" .

ns1:InstalacionRefrigerante_97 a ns1:ComponenteHidraulico ;
    ns1:textoExtracto "instalación de refrigerante" .

ns1:PresionesTrabajo_97 a ns1:Parametro ;
    ns1:textoExtracto "presiones de trabajo" .

