@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TareaMantenimiento_98_1 a ex:TareaMantenimiento ;
    ex:textoExtracto "Comprobar y, si procede, cambiar juntas en bombas, cilindros y válvulas" ;
    ex:tieneFrecuencia ex:Frecuencia_1000h .

ex:TareaMantenimiento_98_2 a ex:TareaMantenimiento ;
    ex:textoExtracto "Limpiar y comprobar el funcionamiento de los finales de carrera" ;
    ex:tieneFrecuencia ex:Frecuencia_1000h .

ex:TareaMantenimiento_98_3 a ex:TareaMantenimiento ;
    ex:textoExtracto "Cambiar el cartucho del filtro de la entrada general de aire" ;
    ex:tieneFrecuencia ex:Frecuencia_1000h .

ex:TareaMantenimiento_98_4 a ex:TareaMantenimiento ;
    ex:textoExtracto "Realizar limpieza del depósito de refrigerante" ;
    ex:tieneFrecuencia ex:Frecuencia_1000h .

ex:TareaMantenimiento_98_5 a ex:TareaMantenimiento ;
    ex:textoExtracto "Realizar limpieza del depósito hidráulico" ;
    ex:tieneFrecuencia ex:Frecuencia_1000h .

ex:TareaMantenimiento_98_6 a ex:TareaMantenimiento ;
    ex:textoExtracto "Realizar limpieza del depósito de engrase manual" ;
    ex:tieneFrecuencia ex:Frecuencia_1000h .

ex:TareaMantenimiento_98_7 a ex:TareaMantenimiento ;
    ex:textoExtracto "Proceder al cambio de los cartuchos de los filtros de aire del grupo hidráulico" ;
    ex:tieneFrecuencia ex:Frecuencia_2000h .

ex:TareaMantenimiento_98_8 a ex:TareaMantenimiento ;
    ex:textoExtracto "Engrasar los patines del carro porta-piezas y de los contrapesos" ;
    ex:tieneFrecuencia ex:Frecuencia_2000h .

ex:Frecuencia_1000h a ex:Frecuencia ;
    ex:valor "Cada 1000 h" ;
    ex:textoExtracto "Cada 1000 h" .

ex:Frecuencia_2000h a ex:Frecuencia ;
    ex:valor "Cada 2000 h" ;
    ex:textoExtracto "Cada 2000 h" .

ex:ComponenteElectrico_98_1 a ex:ComponenteElectrico ;
    ex:textoExtracto "Los micros de puertas tienen que estar bloqueados, es decir, el selector de los micros debe estar en la posición de bloqueo." .

ex:ComponenteElectrico_98_2 a ex:ComponenteElectrico ;
    ex:textoExtracto "Pilz de emergencias, puertas, ventana/puerta de carga: Para que la máquina funcione correctamente tienen que estar los canales cerrados, es decir, los leds de canal 1 y 2 estarán encendidos cuando todas las setas estén desenclavadas, las puertas cerradas…" .