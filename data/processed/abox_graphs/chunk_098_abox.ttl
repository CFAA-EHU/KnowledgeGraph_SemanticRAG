@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:CartuchoFiltroAireGrupoHidraulico a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Proceder al cambio de los cartuchos de los filtros de aire del grupo hidráulico" .

ns1:CartuchoFiltroEntradaAire a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Cambiar el cartucho del filtro de la entrada general de aire" .

ns1:Contrapesos a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Engrasar los patines del carro porta-piezas y de los contrapesos" .

ns1:DepositoEngraseManual a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Realizar limpieza del depósito de engrase manual" .

ns1:DepositoHidraulico a ns1:ComponenteHidraulico ;
    ns1:textoExtracto "Realizar limpieza del depósito hidráulico" .

ns1:DepositoRefrigerante a ns1:ComponenteHidraulico ;
    ns1:textoExtracto "Realizar limpieza del depósito de refrigerante" .

ns1:FinalCarrera a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Limpiar y comprobar el funcionamiento de los finales de carrera" .

ns1:JuntaBombaCilindroValvula a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Comprobar y, si procede, cambiar juntas en bombas, cilindros y válvulas" .

ns1:LedCanal1 a ns1:Sensor ;
    ns1:textoExtracto "los leds de canal 1 y 2 estarán encendidos cuando todas las setas estén desenclavadas" .

ns1:LedCanal2 a ns1:Sensor ;
    ns1:textoExtracto "los leds de canal 1 y 2 estarán encendidos cuando todas las setas estén desenclavadas" .

ns1:MicrosPuertas a ns1:Sensor ;
    ns1:textoExtracto "Los micros de puertas tienen que estar bloqueados, es decir, el selector de los micros debe estar en la posición de bloqueo" .

ns1:PatinesCarroPortapiezas a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Engrasar los patines del carro porta-piezas y de los contrapesos" .

ns1:PilzEmergencias a ns1:Sensor ;
    ns1:textoExtracto "Pilz de emergencias" .

ns1:PuertaCarga a ns1:ElementoSeguridad ;
    ns1:textoExtracto "puertas, ventana/puerta de carga" .

ns1:SeccionMantenimientoComponentesElectricos a ns1:Capitulo ;
    ns1:textoExtracto "MANTENIMIENTO COMPONENTES ELECTRICOS Para el correcto funcionamiento de la máquina, hay que tener en cuenta los siguientes puntos en cuando elementos eléctricos: Los micros de puertas tienen que estar bloqueados, es decir, el selector de los micros - debe estar en la posición de bloqueo. Pilz de emergencias, puertas, ventana/puerta de carga: Para que la máquina funcione - correctamente tienen que estar los canales cerrados, es decir, los leds de canal 1 y 2 estarán encendidos cuando todas las setas estén desenclavadas, las puertas cerradas…" .

ns1:SelectorMicros a ns1:ComponenteElectrico ;
    ns1:textoExtracto "el selector de los micros debe estar en la posición de bloqueo" .

ns1:SetaEmergencia a ns1:Sensor ;
    ns1:textoExtracto "todas las setas estén desenclavadas" .

ns1:TablaMantenimientoSemanalMensualAnual a ns1:Tabla ;
    ns1:textoExtracto "OPERACION | PERIODO | RESPOSABLE | --- | --- | --- | Comprobar y, si procede, cambiar juntas en bombas, cilindros y válvulas | Cada 1000 h | MANTENIMIENTO | Limpiar y comprobar el funcionamiento de los finales de carrera | Cada 1000 h | MANTENIMIENTO | Cambiar el cartucho del filtro de la entrada general de aire | Cada 1000 h | MANTENIMIENTO | Realizar limpieza del depósito de refrigerante | Cada 1000 h | MANTENIMIENTO | Realizar limpieza del depósito hidráulico | Cada 1000 h | MANTENIMIENTO | Realizar limpieza del depósito de engrase manual | Cada 1000 h | MANTENIMIENTO | Proceder al cambio de los cartuchos de los filtros de aire del grupo hidráulico | Cada 2000 h | MANTENIMIENTO | Engrasar los patines del carro porta-piezas y de los contrapesos | Cada 2000 h | MANTENIMIENTO" .

ns1:VentanaCarga a ns1:ElementoSeguridad ;
    ns1:textoExtracto "puertas, ventana/puerta de carga" .

