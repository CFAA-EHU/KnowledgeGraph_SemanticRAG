@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TransferenciaBCD_a_Binario a ns1:AccionProhibida ;
    rdfs:label "Transferencia de código BCD a binario mediante MOV"@es ;
    ns1:controla ns1:Salidas_O16_a_O23 ;
    ns1:habilitadoPor ns1:Entrada_I11 ;
    ns1:identificador "MOV I14 O16 108" ;
    ns1:monitoreaParametro ns1:Entradas_I14_a_I21 ;
    ns1:textoExtracto "Si la entrada I11 vale \"1\" el PLC realiza una transferencia de los estados lógicos de las 8 entradas I14 y siguientes en código BCD, hacia las 8 salidas O16 y siguientes en código binario."@es .

ns1:Entrada_I11 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada I11 (señal de activación)"@es ;
    ns1:identificador "I11" ;
    ns1:textoExtracto "Si la entrada I11 vale \"1\" el PLC realiza una transferencia..."@es .

ns1:Entradas_I14_a_I21 a ns1:ComponenteElectrico ;
    rdfs:label "Bloque de 8 entradas (I14-I21) en código BCD"@es ;
    ns1:identificador "I14-I21" ;
    ns1:textoExtracto "las 8 entradas I14 y siguientes en código BCD"@es .

ns1:Salidas_O16_a_O23 a ns1:ComponenteElectrico ;
    rdfs:label "Bloque de 8 salidas (O16-O23) en código binario"@es ;
    ns1:identificador "O16-O23" ;
    ns1:textoExtracto "las 8 salidas O16 y siguientes en código binario"@es .

