@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Entrada_I15 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada I15" ;
    ns1:controla ns1:Instruccion_NGU_R_1_1024 ;
    ns1:identificador "I15" ;
    ns1:textoExtracto "I15 = NGU R152 Si la entrada I15 vale \"1\" el PLC complementa los 32 bits del registro R152." .

ns1:Entrada_I16 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada I16" ;
    ns1:controla ns1:Instruccion_NGS_R_1_1024 ;
    ns1:identificador "I16" ;
    ns1:textoExtracto "I16 = NGS R89 Si la entrada I16 vale \"1\" el PLC cambia de signo el contenido del registro R89." .

ns1:Operacion_ADS a ns1:AccionProhibida ;
    rdfs:label "ADS (suma aritmética)" ;
    ns1:documentadoEn ns1:Manual_Seccion_4_4_4 ;
    ns1:identificador "ADS" ;
    ns1:textoExtracto "ADS R1/1024 R1/1024 R1/1024 [...] Permiten realizar las operaciones de suma (ADS), resta (SBS), multiplicación (MLS), división (DVS) y módulo o resto de la división (MDS)." .

ns1:Operacion_DVS a ns1:AccionProhibida ;
    rdfs:label "DVS (división aritmética)" ;
    ns1:documentadoEn ns1:Manual_Seccion_4_4_4 ;
    ns1:identificador "DVS" ;
    ns1:textoExtracto "=DVS [...] Permiten realizar las operaciones de suma (ADS), resta (SBS), multiplicación (MLS), división (DVS) y módulo o resto de la división (MDS)." .

ns1:Operacion_MDS a ns1:AccionProhibida ;
    rdfs:label "MDS (módulo/resto de división)" ;
    ns1:documentadoEn ns1:Manual_Seccion_4_4_4 ;
    ns1:identificador "MDS" ;
    ns1:textoExtracto "Permiten realizar las operaciones de suma (ADS), resta (SBS), multiplicación (MLS), división (DVS) y módulo o resto de la división (MDS)." .

ns1:Operacion_MLS a ns1:AccionProhibida ;
    rdfs:label "MLS (multiplicación aritmética)" ;
    ns1:documentadoEn ns1:Manual_Seccion_4_4_4 ;
    ns1:identificador "MLS" ;
    ns1:textoExtracto "Permiten realizar las operaciones de suma (ADS), resta (SBS), multiplicación (MLS), división (DVS) y módulo o resto de la división (MDS)." .

ns1:Operacion_SBS a ns1:AccionProhibida ;
    rdfs:label "SBS (resta aritmética)" ;
    ns1:documentadoEn ns1:Manual_Seccion_4_4_4 ;
    ns1:identificador "SBS" ;
    ns1:textoExtracto "SBS R CNC-PLC R CNC-PLC R CNC-PLC [...] Permiten realizar las operaciones de suma (ADS), resta (SBS), multiplicación (MLS), división (DVS) y módulo o resto de la división (MDS)." .

ns1:Registro_R152 a ns1:ComponenteElectrico ;
    rdfs:label "Registro R152" ;
    ns1:identificador "R152" ;
    ns1:monitoreaParametro ns1:Instruccion_NGU_R_1_1024 ;
    ns1:textoExtracto "R152 antes: 0001 0001 0001 0001 0001 0001 0001 0001 R152 después: 1110 1110 1110 1110 1110 1110 1110 1110" .

ns1:Registro_R89 a ns1:ComponenteElectrico ;
    rdfs:label "Registro R89" ;
    ns1:identificador "R89" ;
    ns1:monitoreaParametro ns1:Instruccion_NGS_R_1_1024 ;
    ns1:textoExtracto "R89 antes: 0001 0001 0001 0001 0001 0001 0001 0001 R89 después: 1110 1110 1110 1110 1110 1110 1110 1111" .

ns1:Instruccion_NGS_R_1_1024 a ns1:AccionProhibida ;
    rdfs:label "NGS R 1/1024" ;
    ns1:documentadoEn ns1:Manual_Seccion_4_4_4 ;
    ns1:identificador "NGS R 1/1024" ;
    ns1:textoExtracto "NGS R 1/1024 Cambio de signo del registro. Cambia el signo del registro. I16 = NGS R89 Si la entrada I16 vale \"1\" el PLC cambia de signo el contenido del registro R89." .

ns1:Instruccion_NGU_R_1_1024 a ns1:AccionProhibida ;
    rdfs:label "NGU R 1/1024" ;
    ns1:documentadoEn ns1:Manual_Seccion_4_4_4 ;
    ns1:identificador "NGU R 1/1024" ;
    ns1:textoExtracto "NGU R 1/1024 Complementa los bits de un registro. Realiza una complementación de los 32 bits del registro (cambia el estado de cada uno de los bits). I15 = NGU R152 Si la entrada I15 vale \"1\" el PLC complementa los 32 bits del registro R152." .

ns1:Manual_Seccion_4_4_4 a ns1:Manual ;
    rdfs:label "Sección 4.4.4: Instrucciones de acción aritméticas" ;
    ns1:textoExtracto "Instrucciones de acción aritméticas. NGU R 1/1024 Complementa los bits de un registro... Operaciones aritméticas. Permiten realizar las operaciones de suma (ADS), resta (SBS), multiplicación (MLS), división (DVS) y módulo o resto de la división (MDS)." .

