@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InstruccionADS_742 a ns1:Parametro ;
    rdfs:label "Instrucción ADS (suma)"@es ;
    ns1:documentadoEn ns1:Pagina_371_372_4_4_4 ;
    ns1:identificador "ADS" ;
    ns1:textoExtracto "ADS R100 R101 R102 ; R102 = 1234 + 100 = 1334"@es .

ns1:InstruccionDVS_742 a ns1:Parametro ;
    rdfs:label "Instrucción DVS (división)"@es ;
    ns1:documentadoEn ns1:Pagina_371_372_4_4_4 ;
    ns1:identificador "DVS" ;
    ns1:textoExtracto "DVS R100 R101 R105 ; R105 = 1234 : 100 = 12"@es .

ns1:InstruccionMDS_742 a ns1:Parametro ;
    rdfs:label "Instrucción MDS (módulo)"@es ;
    ns1:documentadoEn ns1:Pagina_371_372_4_4_4 ;
    ns1:identificador "MDS" ;
    ns1:textoExtracto "MDS R100 R101 R106 ; R106 = 1234 MOD 100 = 34"@es .

ns1:InstruccionMLS_742 a ns1:Parametro ;
    rdfs:label "Instrucción MLS (multiplicación)"@es ;
    ns1:documentadoEn ns1:Pagina_371_372_4_4_4 ;
    ns1:identificador "MLS" ;
    ns1:textoExtracto "MLS R100 R101 R104 ; R104 = 1234 x 100 = 123400"@es .

ns1:InstruccionSBS_742 a ns1:Parametro ;
    rdfs:label "Instrucción SBS (resta)"@es ;
    ns1:documentadoEn ns1:Pagina_371_372_4_4_4 ;
    ns1:identificador "SBS" ;
    ns1:textoExtracto "SBS R100 R101 R103 ; R103 = 1234 - 100 = 1134"@es .

ns1:ParametroSANALOG_742 a ns1:Parametro ;
    rdfs:label "Parámetro SANALOG (entrada analógica)"@es ;
    ns1:documentadoEn ns1:Pagina_371_372_4_4_4 ;
    ns1:identificador "SANALOG" ;
    ns1:textoExtracto "MLS SANALOG 10000 R115 = DVS R115 32767 R115 ; Consigna cabezal en mV"@es ;
    ns1:valor "mV"@es .

ns1:Pagina_371_372_4_4_4 a ns1:Pagina ;
    rdfs:label "Sección 4.4.4: Instrucciones de acción aritméticas (págs. 371-372)"@es ;
    ns1:textoExtracto "Ejemplos con R100=1234 y R101=100. () = ADS R100 R101 R102 ; R102 = 1234 + 100 = 1334 () = SBS R100 R101 R103 ; R103 = 1234 - 100 = 1134 () = MLS R100 R101 R104 ; R104 = 1234 x 100 = 123400 () = DVS R100 R101 R105 ; R105 = 1234 : 100 = 12 () = MDS R100 R101 R106 ; R106 = 1234 MOD 100 = 34"@es .

