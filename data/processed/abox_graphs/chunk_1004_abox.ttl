@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCNC_PLC a ns1:Sistema ;
    rdfs:label "Sistema CNC-PLC" ;
    ns1:requiereMantenimiento ns1:OperacionLogica_AND,
        ns1:OperacionLogica_OR,
        ns1:OperacionLogica_XOR,
        ns1:RotacionRegistro_RL1,
        ns1:RotacionRegistro_RL2,
        ns1:RotacionRegistro_RR1,
        ns1:RotacionRegistro_RR2 ;
    ns1:textoExtracto "Su formato de programación es: AND R1/1024 R1/1024 R1/1024 OR R CNC-PLC R CNC-PLC R CNC-PLC" ;
    ns1:tieneComponente ns1:Registro_R100,
        ns1:Registro_R200,
        ns1:Registro_R201,
        ns1:Registro_R202,
        ns1:Registro_R203,
        ns1:Registro_R204,
        ns1:Registro_R205,
        ns1:Registro_R206,
        ns1:Registro_R207 .

ns1:OperacionLogica_AND a ns1:TareaMantenimiento ;
    rdfs:label "Operación lógica AND" ;
    ns1:identificador "AND" ;
    ns1:textoExtracto "= AND [...] Permiten realizar las operaciones lógicas AND, OR y XOR entre contenido de registros o entre contenidos de registro y número. El resultado siempre se colocará en un registro. Su formato de programación es: AND R1/1024 R1/1024 R1/1024" .

ns1:OperacionLogica_OR a ns1:TareaMantenimiento ;
    rdfs:label "Operación lógica OR" ;
    ns1:identificador "OR" ;
    ns1:textoExtracto "= OR [...] Permiten realizar las operaciones lógicas AND, OR y XOR entre contenido de registros o entre contenidos de registro y número. El resultado siempre se colocará en un registro. Su formato de programación es: OR R CNC-PLC R CNC-PLC R CNC-PLC" .

ns1:OperacionLogica_XOR a ns1:TareaMantenimiento ;
    rdfs:label "Operación lógica XOR" ;
    ns1:identificador "XOR" ;
    ns1:textoExtracto "= XOR [...] Permiten realizar las operaciones lógicas AND, OR y XOR entre contenido de registros o entre contenidos de registro y número. El resultado siempre se colocará en un registro. Su formato de programación es: XOR R CNC-PLC R CNC-PLC R CNC-PLC" .

ns1:Registro_R100 a ns1:Parametro ;
    rdfs:label "Registro R100" ;
    ns1:identificador "R100" ;
    ns1:textoExtracto "RR1 R100 1 R200 Realiza una rotación a derechas tipo 1 de R100 dejando el resultado en R200." .

ns1:Registro_R200 a ns1:Parametro ;
    rdfs:label "Registro R200" ;
    ns1:identificador "R200" ;
    ns1:textoExtracto "Ejemplos con R200 = B1001 0010 y R201 = B0100 0101. () = AND R200 R201 R202 ; R202 = B0" ;
    ns1:valor "B10010010" .

ns1:Registro_R201 a ns1:Parametro ;
    rdfs:label "Registro R201" ;
    ns1:identificador "R201" ;
    ns1:textoExtracto "Ejemplos con R200 = B1001 0010 y R201 = B0100 0101." ;
    ns1:valor "B01000101" .

ns1:Registro_R202 a ns1:Parametro ;
    rdfs:label "Registro R202" ;
    ns1:identificador "R202" ;
    ns1:textoExtracto "= AND R200 R201 R202 ; R202 = B0" ;
    ns1:valor "B00000000" .

ns1:Registro_R203 a ns1:Parametro ;
    rdfs:label "Registro R203" ;
    ns1:identificador "R203" ;
    ns1:textoExtracto "= OR R200 R201 R203 ; R203 = B11010111" ;
    ns1:valor "B11010111" .

ns1:Registro_R204 a ns1:Parametro ;
    rdfs:label "Registro R204" ;
    ns1:identificador "R204" ;
    ns1:textoExtracto "= XOR R200 R201 R204 ; R204 = B11010111" ;
    ns1:valor "B11010111" .

ns1:Registro_R205 a ns1:Parametro ;
    rdfs:label "Registro R205" ;
    ns1:identificador "R205" ;
    ns1:textoExtracto "= AND B1111 R201 R205 ; R205 = B00000101" ;
    ns1:valor "B00000101" .

ns1:Registro_R206 a ns1:Parametro ;
    rdfs:label "Registro R206" ;
    ns1:identificador "R206" ;
    ns1:textoExtracto "= OR R200 B1111 R206 ; R206 = B10011111" ;
    ns1:valor "B10011111" .

ns1:Registro_R207 a ns1:Parametro ;
    rdfs:label "Registro R207" ;
    ns1:identificador "R207" ;
    ns1:textoExtracto "= XOR B1010 B1110 R207 ; R207 = B00000100" ;
    ns1:valor "B00000100" .

ns1:RotacionRegistro_RL1 a ns1:TareaMantenimiento ;
    rdfs:label "Rotación de registro a izquierdas tipo 1 (RL1)" ;
    ns1:identificador "RL1" ;
    ns1:textoExtracto "Tipo de rotación 1 (RL1 o RR1): Introduce un 0 en el bit menos significativo (RL1) o en el más significativo (RR1), desplazando los restantes bits del registro. El valor del último bit desaparece." .

ns1:RotacionRegistro_RL2 a ns1:TareaMantenimiento ;
    rdfs:label "Rotación de registro a izquierdas tipo 2 (RL2)" ;
    ns1:identificador "RL2" ;
    ns1:textoExtracto "Tipo de rotación 2 (RL2 o RR2): Rotación circular del registro en el sentido indicado." .

ns1:RotacionRegistro_RR1 a ns1:TareaMantenimiento ;
    rdfs:label "Rotación de registro a derechas tipo 1 (RR1)" ;
    ns1:identificador "RR1" ;
    ns1:textoExtracto "Rotación de registros. [...] Tipo de rotación 1 (RL1 o RR1): Introduce un 0 en el bit menos significativo (RL1) o en el más significativo (RR1), desplazando los restantes bits del registro. El valor del último bit desaparece. [...] RR1 R100 1 R200 Realiza una rotación a derechas tipo 1 de R100 dejando el resultado en R200." .

ns1:RotacionRegistro_RR2 a ns1:TareaMantenimiento ;
    rdfs:label "Rotación de registro a derechas tipo 2 (RR2)" ;
    ns1:identificador "RR2" ;
    ns1:textoExtracto "Tipo de rotación 2 (RL2 o RR2): Rotación circular del registro en el sentido indicado." .

