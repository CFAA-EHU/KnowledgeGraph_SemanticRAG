@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Instruccion_RL2 a ns1:TareaMantenimiento ;
    rdfs:label "Rotación a izquierdas tipo 2 (RL2)" ;
    ns1:habilitadoPor ns1:Registro_R101 ;
    ns1:identificador "RL2" ;
    ns1:requiereMantenimiento ns1:Registro_R102 ;
    ns1:textoExtracto "Realiza cuatro rotaciones a izquierdas tipo 2 de R102 dejando el resultado en R101." .

ns1:Instruccion_RR1 a ns1:TareaMantenimiento ;
    rdfs:label "Rotación a derechas tipo 1 (RR1)" ;
    ns1:habilitadoPor ns1:Registro_R200 ;
    ns1:identificador "RR1" ;
    ns1:requiereMantenimiento ns1:Registro_R100 ;
    ns1:textoExtracto "Realiza una rotación a derechas tipo 1 de R100 dejando el resultado en R200." .

ns1:Registro_R100 a ns1:Componente ;
    rdfs:label "Registro R100" ;
    ns1:identificador "R100" ;
    ns1:textoExtracto "R100" .

ns1:Registro_R101 a ns1:Componente ;
    rdfs:label "Registro R101" ;
    ns1:identificador "R101" ;
    ns1:textoExtracto "R101" .

ns1:Registro_R102 a ns1:Componente ;
    rdfs:label "Registro R102" ;
    ns1:identificador "R102" ;
    ns1:textoExtracto "R102" .

ns1:Registro_R200 a ns1:Componente ;
    rdfs:label "Registro R200" ;
    ns1:identificador "R200" ;
    ns1:textoExtracto "R200" .

