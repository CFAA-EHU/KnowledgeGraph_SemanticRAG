@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Instruccion_CNCRD a ns1:AccionProhibida ;
    rdfs:label "Instrucción CNCRD (Lectura de variables CNC)" ;
    ns1:identificador "CNCRD" ;
    ns1:textoExtracto "CNCRD = Lectura de las variables del CNC." .

ns1:Instruccion_CNCWR a ns1:AccionProhibida ;
    rdfs:label "Instrucción CNCWR (Escritura de variables CNC)" ;
    ns1:identificador "CNCWR" ;
    ns1:textoExtracto "CNCWR = Escritura de las variables del CNC." .

ns1:Instruccion_ERA a ns1:AccionProhibida ;
    rdfs:label "Instrucción ERA (Borra grupo de recursos)" ;
    ns1:identificador "ERA" ;
    ns1:textoExtracto "ERA Borra un grupo de recursos. Permite borrar o inicializar un grupo de recursos del mismo tipo. [...] Esta acción está especialmente indicada para ser ejecutada en el módulo del primer ciclo (CY1) con el fin de poner los recursos deseados en condiciones iniciales de trabajo." .

ns1:Instruccion_PAR a ns1:AccionProhibida ;
    rdfs:label "Instrucción PAR (Paridad de registro)" ;
    ns1:identificador "PAR" ;
    ns1:textoExtracto "PAR Paridad de un registro. Analiza el tipo de paridad de un registro. Si el registro tiene paridad PAR, esta instrucción asignará un 1 a la marca, mensaje o error seleccionado, y si tiene paridad IMPAR, le asignará un 0." .

ns1:Marca_M222 a ns1:Parametro ;
    rdfs:label "Marca M222" ;
    ns1:identificador "M222" ;
    ns1:textoExtracto "Si la entrada I15 vale '1' el PLC [...] asignará un '1' a la marca M222 si tiene paridad PAR o un '0' si tiene paridad IMPAR." ;
    ns1:valor 0,
        1 .

ns1:Modulo_CY1 a ns1:ModoOperacion ;
    rdfs:label "Módulo del primer ciclo (CY1)" ;
    ns1:identificador "CY1" ;
    ns1:textoExtracto "Esta acción está especialmente indicada para ser ejecutada en el módulo del primer ciclo (CY1) con el fin de poner los recursos deseados en condiciones iniciales de trabajo." .

ns1:Parametro_I10 a ns1:Parametro ;
    rdfs:label "Entrada I10" ;
    ns1:identificador "I10" ;
    ns1:monitoreaParametro ns1:Parametro_O5_O12 ;
    ns1:textoExtracto "I10 = ERA O5 12. Si la entrada I10 vale '1' el PLC asignará el valor 0 a las salidas O5 a O12, ambas inclusive." .

ns1:Parametro_I15 a ns1:Parametro ;
    rdfs:label "Entrada I15" ;
    ns1:identificador "I15" ;
    ns1:monitoreaParametro ns1:Registro_R123 ;
    ns1:textoExtracto "I15 = PAR R123 M222. Si la entrada I15 vale '1' el PLC analiza el registro R123 y asignará un '1' a la marca M222 si tiene paridad PAR o un '0' si tiene paridad IMPAR." .

ns1:Parametro_I23 a ns1:Parametro ;
    rdfs:label "Entrada I23" ;
    ns1:identificador "I23" ;
    ns1:monitoreaParametro ns1:Contadores_C15_C18 ;
    ns1:textoExtracto "I23 = ERA C15 18. Si la entrada I23 vale '1' el PLC preseleccionará a 0 los contadores C15 a C18, ambos inclusive." .

ns1:Contadores_C15_C18 a ns1:Parametro ;
    rdfs:label "Contadores C15 a C18" ;
    ns1:identificador "C15-C18" ;
    ns1:textoExtracto "Si la entrada I23 vale '1' el PLC preseleccionará a 0 los contadores C15 a C18, ambos inclusive." ;
    ns1:valor "0" .

ns1:Parametro_O5_O12 a ns1:Parametro ;
    rdfs:label "Salidas O5 a O12" ;
    ns1:identificador "O5-O12" ;
    ns1:textoExtracto "Si la entrada I10 vale '1' el PLC asignará el valor 0 a las salidas O5 a O12, ambas inclusive." ;
    ns1:valor "0" .

ns1:Registro_R123 a ns1:Parametro ;
    rdfs:label "Registro R123" ;
    ns1:identificador "R123" ;
    ns1:textoExtracto "Si la entrada I15 vale '1' el PLC analiza el registro R123 y asignará un '1' a la marca M222 si tiene paridad PAR o un '0' si tiene paridad IMPAR." .

