@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:SistemaCNC a ns1:Sistema ;
    ns1:textoExtracto "CNCWR carga el contenido del registro en la variable. La marca se pone a \"1\" cuando comienza la operación y se mantiene a dicho valor hasta que finaliza la misma. En la lectura mediante CNCRD de las variables de los parámetros aritméticos y de fabricante se devuelve el valor multiplicado por 10000 (lectura en modo float). Si se solicita información de una variable inexistente (por ejemplo la cota de un eje que no existe) se mostrará un mensaje de error. De la misma manera, si se intenta leer un valor cuyo rango es mayor al del registro PLC, el CNC devolverá valor cero y mostrará el error correspondiente. Siempre que se de un error en la lectura de la variable, la marca de comunicación se quedará a \"1\". Sintaxis de las variables en los comandos CNCRD y CNCWR. Para estos dos comandos, en el mnemónico de la variable se puede definir el número de canal mediante un número entero, un registro o un símbolo definido mediante DEF o PDEF." ;
    ns1:tieneComponente ns1:ComandoCNCRD,
        ns1:ComandoCNCWR,
        ns1:MarcaM1000,
        ns1:MarcaM11,
        ns1:RegistroR10,
        ns1:RegistroR101,
        ns1:RegistroR11,
        ns1:RegistroR12,
        ns1:SimboloCHANNEL,
        ns1:SimboloPARAM,
        ns1:VariableG_FREAL,
        ns1:VariableG_GUP,
        ns1:VariableTM_TOOL .

ns1:ComandoCNCRD a ns1:AccionProhibida ;
    ns1:textoExtracto "CNCRD ([1].G.FREAL, R10, M1000)" .

ns1:ComandoCNCWR a ns1:AccionProhibida ;
    ns1:textoExtracto "CNCWR carga el contenido del registro en la variable" .

ns1:MarcaM1000 a ns1:Sensor ;
    ns1:textoExtracto "se pone a \"1\" cuando comienza la operación y se mantiene a dicho valor hasta que finaliza la misma" ;
    ns1:valor "M1000" .

ns1:MarcaM11 a ns1:Sensor ;
    ns1:textoExtracto "<condición> AND NOT M11 = CNCRD (TM.TOOL, R11, M11)" ;
    ns1:valor "M11" .

ns1:RegistroR10 a ns1:Parametro ;
    ns1:textoExtracto "el contenido del registro en la variable" ;
    ns1:valor "R10" .

ns1:RegistroR101 a ns1:Parametro ;
    ns1:textoExtracto "MOV 153 R101" ;
    ns1:valor "R101" .

ns1:RegistroR11 a ns1:Parametro ;
    ns1:textoExtracto "CNCRD (TM.TOOL, R11, M11)" ;
    ns1:valor "R11" .

ns1:RegistroR12 a ns1:Parametro ;
    ns1:textoExtracto "([R12].G.FREAL, R10, M1000)" ;
    ns1:valor "R12" .

ns1:SimboloCHANNEL a ns1:Parametro ;
    ns1:textoExtracto "DEF CHANNEL 3" ;
    ns1:valor "CHANNEL" .

ns1:SimboloPARAM a ns1:Parametro ;
    ns1:textoExtracto "DEF PARAM 153" ;
    ns1:valor "PARAM" .

ns1:VariableG_FREAL a ns1:Parametro ;
    ns1:textoExtracto "([1].G.FREAL, R10, M1000)" ;
    ns1:valor "G.FREAL" .

ns1:VariableG_GUP a ns1:Parametro ;
    ns1:textoExtracto "([R12].G.FREAL, R10, M1000)" ;
    ns1:valor "G.GUP" .

ns1:VariableTM_TOOL a ns1:Parametro ;
    ns1:textoExtracto "CNCRD (TM.TOOL, R11, M11)" ;
    ns1:valor "TM.TOOL" .

