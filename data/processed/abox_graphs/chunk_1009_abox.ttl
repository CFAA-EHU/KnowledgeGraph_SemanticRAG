@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CondicionFinalizacion_748 a ns1:Parametro ;
    rdfs:label "Condición de finalización DFD M11 AND CPS R11 EQ 3"@es ;
    ns1:identificador "DFD M11 AND CPS R11 EQ 3" ;
    ns1:textoExtracto "DFD M11 AND CPS R11 EQ 3 = ... esperar a que finalice la consulta para evaluar los datos."@es .

ns1:CondicionSincrona_748 a ns1:Parametro ;
    rdfs:label "Condición síncrona CPS R12 GT 2000"@es ;
    ns1:identificador "CPS R12 GT 2000" ;
    ns1:textoExtracto "CPS R12 GT 2000 = ... no hace falta esperar para consultar los datos porque las variables síncronas se resuelven"@es .

ns1:ConsultaAsincrona_748 a ns1:Parametro ;
    rdfs:label "Consulta asíncrona CNCRD (TM.TOOL, R11, M11)"@es ;
    ns1:identificador "CNCRD (TM.TOOL, R11, M11)" ;
    ns1:textoExtracto "<condición> AND NOT M11 = CNCRD (TM.TOOL, R11, M11) no repetir la consulta mientras no finalice la misma."@es .

ns1:ConsultaSincrona_748 a ns1:Parametro ;
    rdfs:label "Consulta síncrona CNCRD (G.FREAL, R12, M12)"@es ;
    ns1:identificador "CNCRD (G.FREAL, R12, M12)" ;
    ns1:textoExtracto "<condición> = CNCRD (G.FREAL, R12, M12) CPS R12 GT 2000 = ..."@es .

