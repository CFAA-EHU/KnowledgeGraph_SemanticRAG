@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:ComprobacionDeFugas a owl:Class ;
    rdfs:label "Comprobación de fugas"@es ;
    rdfs:comment "Proceso de verificación de fugas de fluidos en tuberías"@es .

ex:Tuberias a owl:Class ;
    rdfs:label "Tuberías"@es ;
    rdfs:comment "Elementos conductores de fluidos en la máquina"@es .

ex:Racores a owl:Class ;
    rdfs:label "Racores"@es ;
    rdfs:comment "Componentes para apretar y sellar tuberías"@es .

ex:DepositoEngrase a owl:Class ;
    rdfs:label "Depósito de engrase"@es ;
    rdfs:comment "Contenedor para el fluido de engrase"@es .

ex:DepositoHidraulico a owl:Class ;
    rdfs:label "Depósito hidráulico"@es ;
    rdfs:comment "Contenedor para el fluido hidráulico"@es .

ex:DepositoRefrigeracion a owl:Class ;
    rdfs:label "Depósito de refrigeración"@es ;
    rdfs:comment "Contenedor para el fluido de refrigeración"@es .

ex:comprobarExistenciaFugas a owl:ObjectProperty ;
    rdfs:domain ex:ComprobacionDeFugas ;
    rdfs:range ex:Tuberias ;
    rdfs:label "comprobar existencia de fugas"@es .

ex:apretarRacores a owl:ObjectProperty ;
    rdfs:domain ex:ComprobacionDeFugas ;
    rdfs:range ex:Racores ;
    rdfs:label "apretar racores"@es .

ex:comprobarNivelesFluidos a owl:ObjectProperty ;
    rdfs:domain ex:ComprobacionDeFugas ;
    rdfs:range [ a owl:Class ;
                 owl:unionOf ( ex:DepositoEngrase ex:DepositoHidraulico ex:DepositoRefrigeracion ) ] ;
    rdfs:label "comprobar niveles de fluidos"@es .