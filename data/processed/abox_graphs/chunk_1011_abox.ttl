@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Comando_CNCEX a ns1:AccionProhibida ;
    rdfs:label "Comando CNCEX" ;
    ns1:ejecutadoPor ns1:Canal_CNC ;
    ns1:identificador "CNCEX" ;
    ns1:textoExtracto "El comando CNCEX se ejecuta a través de una canal del CNC mientras que los comandos MOVE* se ejecutan directamente en el interpolador (habitualmente ejecución más rápida)." .

ns1:Comandos_MOVE a ns1:AccionProhibida ;
    rdfs:label "Comandos MOVE*" ;
    ns1:ejecutadoPor ns1:Interpolador_CNC ;
    ns1:identificador "MOVE*" ;
    ns1:textoExtracto "los comandos MOVE* se ejecutan directamente en el interpolador (habitualmente ejecución más rápida)." .

ns1:Subrutina_Programa a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina/Programa" ;
    ns1:textoExtracto "No se recomienda utilizar ambas en el mismo programa o subrutina." .

ns1:Canal_CNC a ns1:InterfazUsuario ;
    rdfs:label "Canal del CNC" ;
    ns1:textoExtracto "El comando CNCEX se ejecuta a través de una canal del CNC" .

ns1:Interpolador_CNC a ns1:Sistema ;
    rdfs:label "Interpolador del CNC" ;
    ns1:textoExtracto "los comandos MOVE* se ejecutan directamente en el interpolador" .

