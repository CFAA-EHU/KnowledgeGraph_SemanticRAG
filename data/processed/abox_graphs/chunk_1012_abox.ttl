@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramaMovimientoIndependiente_751 a ns1:ModoOperacion ;
    rdfs:label "Programa de movimiento independiente"@es ;
    ns1:identificador "CNCEX(#MOVE ADD [X100,F100,NULL], M120,1)",
        "MOVEADD(X,100000,100000,NULL)" ;
    ns1:textoExtracto "Los movimientos independientes se pueden ejecutar de las siguientes maneras. No se recomienda utilizar ambas en el mismo programa o subrutina."@es .

ns1:SubrutinaMovimiento_751 a ns1:ModoOperacion ;
    rdfs:label "Subrutina de movimiento"@es ;
    ns1:textoExtracto "No se recomienda utilizar ambas en el mismo programa o subrutina."@es .

