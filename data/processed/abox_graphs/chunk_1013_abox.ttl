@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Comando_CAM_OFF a ns1:ModoOperacion ;
    rdfs:label "CAM OFF" ;
    ns1:documentadoEn ns1:ManualLevaElectronicaEspecifico ;
    ns1:identificador "CAM OFF" ;
    ns1:textoExtracto "cancelar la leva electrónica (CAM OFF). La ejecución del comando CAM OFF implica eliminar la sincronización de la leva. Una vez programado este comando, la leva termina cuando se alcanza el final de su perfil." .

ns1:Comando_CAM_ON a ns1:ModoOperacion ;
    rdfs:label "CAM ON" ;
    ns1:documentadoEn ns1:ManualLevaElectronicaEspecifico ;
    ns1:identificador "CAM ON" ;
    ns1:monitoreaParametro ns1:Parametro_cam,
        ns1:Parametro_master,
        ns1:Parametro_master_off,
        ns1:Parametro_range_master,
        ns1:Parametro_range_slave,
        ns1:Parametro_slave,
        ns1:Parametro_slave_off,
        ns1:Parametro_type ;
    ns1:textoExtracto "Activar la leva electrónica con las cotas reales (CAM ON)" .

ns1:Comando_TCAM_ON a ns1:ModoOperacion ;
    rdfs:label "TCAM ON" ;
    ns1:documentadoEn ns1:ManualLevaElectronicaEspecifico ;
    ns1:identificador "TCAM ON" ;
    ns1:monitoreaParametro ns1:Parametro_cam,
        ns1:Parametro_master,
        ns1:Parametro_master_off,
        ns1:Parametro_range_master,
        ns1:Parametro_range_slave,
        ns1:Parametro_slave,
        ns1:Parametro_slave_off,
        ns1:Parametro_type ;
    ns1:textoExtracto "activar la leva electrónica con las cotas teóricas (TCAM ON)" .

ns1:Parametro_cam a ns1:Parametro ;
    rdfs:label "cam" ;
    ns1:identificador "cam" ;
    ns1:textoExtracto "parámetro 'cam' en los comandos CAM ON y TCAM ON" .

ns1:Parametro_master a ns1:Parametro ;
    rdfs:label "master o TIME" ;
    ns1:identificador "master/TIME" ;
    ns1:textoExtracto "parámetro 'master' o 'TIME' en los comandos CAM ON y TCAM ON" .

ns1:Parametro_master_off a ns1:Parametro ;
    rdfs:label "master_off" ;
    ns1:identificador "master_off" ;
    ns1:textoExtracto "parámetro 'master_off' en los comandos CAM ON y TCAM ON" .

ns1:Parametro_range_master a ns1:Parametro ;
    rdfs:label "range_master" ;
    ns1:identificador "range_master" ;
    ns1:textoExtracto "parámetro 'range_master' en los comandos CAM ON y TCAM ON" .

ns1:Parametro_range_slave a ns1:Parametro ;
    rdfs:label "range_slave" ;
    ns1:identificador "range_slave" ;
    ns1:textoExtracto "parámetro 'range_slave' en los comandos CAM ON y TCAM ON" .

ns1:Parametro_slave a ns1:Parametro ;
    rdfs:label "slave" ;
    ns1:identificador "slave" ;
    ns1:textoExtracto "parámetro 'slave' en los comandos CAM ON, TCAM ON y CAM OFF" .

ns1:Parametro_slave_off a ns1:Parametro ;
    rdfs:label "slave_off" ;
    ns1:identificador "slave_off" ;
    ns1:textoExtracto "parámetro 'slave_off' en los comandos CAM ON y TCAM ON" .

ns1:Parametro_type a ns1:Parametro ;
    rdfs:label "type" ;
    ns1:identificador "type" ;
    ns1:textoExtracto "parámetro 'type' en los comandos CAM ON y TCAM ON" .

ns1:ManualLevaElectronicaEspecifico a ns1:Manual ;
    rdfs:label "Manual específico de la leva electrónica" ;
    ns1:textoExtracto "Esta funcionalidad dispone de un manual específico. En este manual, que está usted leyendo, sólo se ofrece información orientativa sobre esta funcionalidad. Consulte la documentación específica para obtener más información acerca de los requisitos y el funcionamiento de la leva electrónica." .

