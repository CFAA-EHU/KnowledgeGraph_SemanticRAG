@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TIME a ns1:Parametro ;
    rdfs:label "TIME" ;
    ns1:textoExtracto "Parámetro. | Significado. | TIME | Leva de tiempo. Si en lugar de programar un nombre de eje se programa \"TIME\", la leva se interpreta como una leva en tiempo. |" .

ns1:cam a ns1:Parametro ;
    rdfs:label "cam" ;
    ns1:textoExtracto "Parámetro. | Significado. | cam | Número de leva. |" .

ns1:master a ns1:Parametro ;
    rdfs:label "master" ;
    ns1:textoExtracto "Parámetro. | Significado. | master | Nombre del eje maestro. |" .

ns1:master_off a ns1:Parametro ;
    rdfs:label "master_off" ;
    ns1:textoExtracto "Parámetro. | Significado. | master_off | Offset para el eje maestro. |" .

ns1:range_master a ns1:Parametro ;
    rdfs:label "range_master" ;
    ns1:textoExtracto "Parámetro. | Significado. | range_master | Escala o rango de activación del eje maestro. |" .

ns1:range_slave a ns1:Parametro ;
    rdfs:label "range_slave" ;
    ns1:textoExtracto "Parámetro. | Significado. | range_slave | Escala o rango de activación del eje esclavo. |" .

ns1:slave a ns1:Parametro ;
    rdfs:label "slave" ;
    ns1:textoExtracto "Parámetro. | Significado. | slave | Nombre del eje esclavo. |" .

ns1:slave_off a ns1:Parametro ;
    rdfs:label "slave_off" ;
    ns1:textoExtracto "Parámetro. | Significado. | slave_off | Offset para el eje esclavo. |" .

ns1:type a ns1:Parametro ;
    rdfs:label "type" ;
    ns1:textoExtracto "Parámetro. | Significado. | type | Define el tipo de leva; periódica o no periódica. Se programa mediante los parámetros \"ONCE\" (leva no periódica) o \"CONT\" (leva periódica). |" .

