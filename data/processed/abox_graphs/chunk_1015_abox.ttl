@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComandoCAMOFF a ns1:AccionProhibida ;
    rdfs:label "Comando CAM OFF" ;
    ns1:textoExtracto "Alcanzado dicho comando, la ejecución de la leva finalizará la próxima vez que sea alcanzado el final del perfil de leva." .

ns1:SistemaLevaElectronica a ns1:Sistema ;
    rdfs:label "Sistema de leva electrónica" ;
    ns1:controla ns1:LevaNoPeriodica,
        ns1:LevaPeriodica,
        ns1:ModoLevaPosicion,
        ns1:ModoLevaTiempo ;
    ns1:textoExtracto "Modo de leva. Se pueden activar dos tipos de leva; levas en función de tiempo o levas en función de la posición de un eje maestro." ;
    ns1:tieneComponente ns1:ParametroMasterOff,
        ns1:ParametroRangeMaster,
        ns1:ParametroRangeSlave,
        ns1:ParametroSlaveOff,
        ns1:ParametroType .

ns1:LevaNoPeriodica a ns1:ModoOperacion ;
    rdfs:label "Leva no periódica (ONCE)" ;
    ns1:identificador "ONCE" ;
    ns1:textoExtracto "No periódica Se define asignando al parámetro type el valor 'ONCE'. En este modo se mantiene la sincronización para el rango definido del eje maestro." .

ns1:LevaPeriodica a ns1:ModoOperacion ;
    rdfs:label "Leva periódica (CONT)" ;
    ns1:identificador "CONT" ;
    ns1:textoExtracto "Periódica Se define asignando al parámetro type el valor 'CONT'. En este modo, al llegar al final del rango del eje maestro se recalcula el offset para volver a ejecutar la leva." .

ns1:ModoLevaPosicion a ns1:ModoOperacion ;
    rdfs:label "Leva en función de posición" ;
    ns1:textoExtracto "Se pueden activar dos tipos de leva; levas en función de tiempo o levas en función de la posición de un eje maestro." .

ns1:ModoLevaTiempo a ns1:ModoOperacion ;
    rdfs:label "Leva en función de tiempo" ;
    ns1:textoExtracto "Se pueden activar dos tipos de leva; levas en función de tiempo o levas en función de la posición de un eje maestro." .

ns1:ParametroMasterOff a ns1:Parametro ;
    rdfs:label "Parámetro 'master_off' de rango de activación" ;
    ns1:textoExtracto "La leva se activa cuando el eje maestro se encuentra entre las posiciones 'master_off' y 'master_off + range_master'." .

ns1:ParametroRangeMaster a ns1:Parametro ;
    rdfs:label "Parámetro 'range_master' de rango de activación" ;
    ns1:textoExtracto "La leva se activa cuando el eje maestro se encuentra entre las posiciones 'master_off' y 'master_off + range_master'." .

ns1:ParametroRangeSlave a ns1:Parametro ;
    rdfs:label "Parámetro 'range_slave' de rango esclavo" ;
    ns1:textoExtracto "La leva aplica al eje esclavo cuando éste se encuentra entre 'slave_off' y 'slave_off + range_slave'." .

ns1:ParametroSlaveOff a ns1:Parametro ;
    rdfs:label "Parámetro 'slave_off' de rango esclavo" ;
    ns1:textoExtracto "La leva aplica al eje esclavo cuando éste se encuentra entre 'slave_off' y 'slave_off + range_slave'." .

ns1:ParametroType a ns1:Parametro ;
    rdfs:label "Parámetro 'type' de selección de tipo de leva" ;
    ns1:textoExtracto "La selección se realiza mediante el parámetro type." ;
    ns1:valor "CONT",
        "ONCE" .

