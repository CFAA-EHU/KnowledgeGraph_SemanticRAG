@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArchivoLeva a ns1:Esquema ;
    rdfs:label "archivo de leva"@es ;
    ns1:textoExtracto "Los datos de la leva pueden estar definidos en un archivo, el cual se puede cargar desde el CNC o el PLC."@es .

ns1:ComandoCAMDESELECT a ns1:ModoOperacion ;
    rdfs:label "comando CAM DESELECT"@es ;
    ns1:textoExtracto "Seleccionar (CAM SELECT) o anular una leva de archivo (CAM DESELECT)."@es .

ns1:ComandoCAMOFF a ns1:ModoOperacion ;
    rdfs:label "comando CAM OFF"@es ;
    ns1:textoExtracto "En los dos modos se mantiene la sincronización hasta la ejecución del comando CAM OFF."@es .

ns1:ComandoCAMSELECT a ns1:ModoOperacion ;
    rdfs:label "comando CAM SELECT"@es ;
    ns1:textoExtracto "Seleccionar (CAM SELECT) o anular una leva de archivo (CAM DESELECT)."@es .

ns1:PerfilLeva a ns1:ModoOperacion ;
    rdfs:label "perfil de leva"@es ;
    ns1:textoExtracto "la ejecución de la leva finalizará la próxima vez que sea alcanzado el final del perfil de leva."@es .

