@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:CNC a ns1:Maquina ;
    ns1:identificador "CNC" ;
    ns1:textoExtracto "el CNC lee sus datos de manera dinámica" .

ns1:LevaElectronica a ns1:Sistema ;
    ns1:compuestoPor ns1:ArchivoLeva,
        ns1:ComandoCAMDESELECT,
        ns1:ComandoCAMOFF,
        ns1:ComandoCAMON,
        ns1:ComandoCAMSELECT ;
    ns1:textoExtracto "Los datos de la leva pueden estar definidos en un archivo, el cual se puede cargar desde el CNC o el PLC. Al ejecutar una leva desde un archivo, el CNC lee sus datos de manera dinámica, por lo que no hay límite de puntos a la hora de definir la leva." .

ns1:PLC a ns1:Maquina ;
    ns1:identificador "PLC" ;
    ns1:textoExtracto "el cual se puede cargar desde el CNC o el PLC" .

ns1:ParametrosMaquina a ns1:Parametro ;
    ns1:textoExtracto "Tras seleccionar una leva de archivo, ésta permanece disponible hasta que se valide la tabla de levas de los parámetros máquina o se apague el CNC." ;
    ns1:valor "tabla de levas de los parámetros máquina" .

ns1:ArchivoLeva a ns1:ComponenteElectrico ;
    ns1:textoExtracto "Los datos de la leva pueden estar definidos en un archivo, el cual se puede cargar desde el CNC o el PLC." .

ns1:ComandoCAMDESELECT a ns1:Parametro ;
    ns1:textoExtracto "CAM DESELECT (cam)" ;
    ns1:valor "CAM DESELECT (cam)" .

ns1:ComandoCAMOFF a ns1:Parametro ;
    ns1:textoExtracto "El formato de programación para cada de ellos es el siguiente. ... La ejecución del comando CAM OFF implica eliminar la sincronización de la leva." ;
    ns1:valor "CAM OFF" .

ns1:ComandoCAMON a ns1:Parametro ;
    ns1:textoExtracto "para activarla, utilizar la sentencia #CAM ON (desde el CNC) o el comando CAM ON (desde el PLC)" ;
    ns1:valor "#CAM ON o CAM ON" .

ns1:ComandoCAMSELECT a ns1:Parametro ;
    ns1:textoExtracto "CAM SELECT (cam, file)" ;
    ns1:valor "CAM SELECT (cam, file)" .

