@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_ParametrosLevaElectronica_4_4_7 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de leva electrónica (Sección 4.4.7)"@es ;
    ns1:textoExtracto """
| Parámetro. | Significado. |
| --- | --- |
| cam | Número de leva. |
| file | Nombre y dirección (path) del archivo con los datos de la leva.
"""@es ;
    ns1:tieneComponente ns1:Parametro_cam_LevaElectronica,
        ns1:Parametro_file_LevaElectronica .

ns1:Parametro_cam_LevaElectronica a ns1:Parametro ;
    rdfs:label "cam"@es ;
    ns1:identificador "cam" ;
    ns1:textoExtracto "Número de leva."@es .

ns1:Parametro_file_LevaElectronica a ns1:Parametro ;
    rdfs:label "file"@es ;
    ns1:identificador "file" ;
    ns1:textoExtracto "Nombre y dirección (path) del archivo con los datos de la leva."@es .

