@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_MoveABS a ns1:ModoOperacion ;
    rdfs:label "Movimiento de posicionamiento absoluto (MOVE ABS)"@es ;
    ns1:documentadoEn ns1:Manual_Actual,
        ns1:Manual_MovimientoIndependiente ;
    ns1:identificador "MOVE_ABS" ;
    ns1:textoExtracto "Movimiento de posicionamiento absoluto (MOVE ABS). [...] MOVE ABS (axis, pos, feed, blend)"@es .

ns1:ModoOperacion_MoveADD a ns1:ModoOperacion ;
    rdfs:label "Movimiento de posicionamiento incremental (MOVE ADD)"@es ;
    ns1:documentadoEn ns1:Manual_Actual,
        ns1:Manual_MovimientoIndependiente ;
    ns1:identificador "MOVE_ADD" ;
    ns1:textoExtracto "Movimiento de posicionamiento [...] incremental (MOVE ADD). [...] MOVE ADD (axis, pos, feed, blend)"@es .

ns1:ModoOperacion_MoveINF a ns1:ModoOperacion ;
    rdfs:label "Movimiento de posicionamiento sin fin (MOVE INF)"@es ;
    ns1:documentadoEn ns1:Manual_Actual,
        ns1:Manual_MovimientoIndependiente ;
    ns1:identificador "MOVE_INF" ;
    ns1:textoExtracto "Movimiento de posicionamiento [...] sin fín (MOVE INF). [...] MOVE INF (axis, direction, feed, blend)"@es .

ns1:Parametro_axis a ns1:Parametro ;
    rdfs:label "Parámetro 'axis'"@es ;
    ns1:textoExtracto "MOVE ABS (axis, pos, feed, blend)"@es .

ns1:Parametro_blend a ns1:Parametro ;
    rdfs:label "Parámetro 'blend'"@es ;
    ns1:textoExtracto "MOVE ABS (axis, pos, feed, blend)"@es .

ns1:Parametro_direction a ns1:Parametro ;
    rdfs:label "Parámetro 'direction'"@es ;
    ns1:textoExtracto "MOVE INF (axis, direction, feed, blend)"@es .

ns1:Parametro_feed a ns1:Parametro ;
    rdfs:label "Parámetro 'feed'"@es ;
    ns1:textoExtracto "MOVE ABS (axis, pos, feed, blend)"@es .

ns1:Parametro_pos a ns1:Parametro ;
    rdfs:label "Parámetro 'pos'"@es ;
    ns1:textoExtracto "MOVE ABS (axis, pos, feed, blend)"@es .

ns1:Manual_Actual a ns1:Manual ;
    rdfs:label "Manual actual (orientativo)"@es ;
    ns1:textoExtracto "En este manual, que está usted leyendo, sólo se ofrece información orientativa sobre esta funcionalidad."@es .

ns1:Manual_MovimientoIndependiente a ns1:Manual ;
    rdfs:label "Manual específico de movimiento independiente"@es ;
    ns1:identificador "Manual_MovimientoIndependiente" ;
    ns1:textoExtracto "Esta funcionalidad dispone de un manual específico. [...] Consulte la documentación específica para obtener más información acerca de los requisitos y el funcionamiento de los ejes independientes."@es .

