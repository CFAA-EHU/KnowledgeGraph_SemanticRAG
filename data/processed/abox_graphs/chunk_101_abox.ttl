@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:ComprobacionDeApriete a owl:Class ;
    rdfs:label "Comprobación de apriete"@es ;
    rdfs:comment "Proceso de verificación y ajuste de tornillos y tuercas en una máquina."@es .

ex:Tornillo a owl:Class ;
    rdfs:label "Tornillo"@es ;
    rdfs:comment "Elemento de fijación utilizado en la máquina."@es .

ex:Tuerca a owl:Class ;
    rdfs:label "Tuerca"@es ;
    rdfs:comment "Elemento de fijación utilizado en la máquina."@es .

ex:comprobarEstado a owl:ObjectProperty ;
    rdfs:domain ex:ComprobacionDeApriete ;
    rdfs:range ex:Tornillo .

ex:comprobarEstado a owl:ObjectProperty ;
    rdfs:domain ex:ComprobacionDeApriete ;
    rdfs:range ex:Tuerca .

ex:apretar a owl:ObjectProperty ;
    rdfs:domain ex:ComprobacionDeApriete ;
    rdfs:range ex:Tornillo .

ex:apretar a owl:ObjectProperty ;
    rdfs:domain ex:ComprobacionDeApriete ;
    rdfs:range ex:Tuerca .