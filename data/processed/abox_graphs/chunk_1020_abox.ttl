@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_MOVE_ABS a ns1:ModoOperacion ;
    rdfs:label "MOVE ABS" ;
    ns1:identificador "MOVE_ABS" ;
    ns1:textoExtracto "Con MOVE ABS se definirá en coordenadas absolutas." .

ns1:ModoOperacion_MOVE_ADD a ns1:ModoOperacion ;
    rdfs:label "MOVE ADD" ;
    ns1:identificador "MOVE_ADD" ;
    ns1:textoExtracto "Con MOVE ADD se definirá en coordenadas incrementales." .

ns1:ModoOperacion_MOVE_INF a ns1:ModoOperacion ;
    rdfs:label "MOVE INF" ;
    ns1:identificador "MOVE_INF" ;
    ns1:textoExtracto "Se utiliza con MOVE INF, para ejecutar un movimiento sin fin hasta alcanzar el límite del eje o hasta que el movimiento sea interrumpido." .

ns1:Parametro_DIRNEG a ns1:Parametro ;
    rdfs:label "DIRNEG" ;
    ns1:identificador "DIRNEG" ;
    ns1:textoExtracto "Sentido negativo." .

ns1:Parametro_DIRPOS a ns1:Parametro ;
    rdfs:label "DIRPOS" ;
    ns1:identificador "DIRPOS" ;
    ns1:textoExtracto "Sentido positivo." .

ns1:Parametro_NEXT a ns1:Parametro ;
    rdfs:label "NEXT" ;
    ns1:identificador "NEXT" ;
    ns1:textoExtracto "El eje alcanza la posición indicada al avance especificado en el siguiente bloque." .

ns1:Parametro_NULL a ns1:Parametro ;
    rdfs:label "NULL" ;
    ns1:identificador "NULL" ;
    ns1:textoExtracto "El eje alcanza la posición indicada a avance nulo." .

ns1:Parametro_PRESENT a ns1:Parametro ;
    rdfs:label "PRESENT" ;
    ns1:identificador "PRESENT" ;
    ns1:textoExtracto "El eje alcanza la posición indicada al avance especificado para el propio bloque." .

ns1:Parametro_WAITINPOS a ns1:Parametro ;
    rdfs:label "WAITINPOS" ;
    ns1:identificador "WAITINPOS" ;
    ns1:textoExtracto "El eje alcanza la posición indicada a avance nulo y espera a estar en posición para ejecutar el siguiente bloque." .

ns1:Tabla_ParametrosMovimiento a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de movimiento independiente" ;
    ns1:textoExtracto "axis | Eje a posicionar. pos | Posición a alcanzar. direction | Sentido de desplazamiento. feed | Avance de posicionamiento. blend | Enlace dinámico con el siguiente bloque." ;
    ns1:tieneComponente ns1:Parametro_axis,
        ns1:Parametro_blend,
        ns1:Parametro_direction,
        ns1:Parametro_feed,
        ns1:Parametro_pos .

ns1:Parametro_axis a ns1:Parametro ;
    rdfs:label "axis" ;
    ns1:identificador "axis" ;
    ns1:textoExtracto "Eje a posicionar." .

ns1:Parametro_blend a ns1:Parametro ;
    rdfs:label "blend" ;
    ns1:identificador "blend" ;
    ns1:textoExtracto "Enlace dinámico con el siguiente bloque. Se programa mediante los parámetros \"PRESENT\", \"NULL\", \"NEXT\" o \"WAITINPOS\"." .

ns1:Parametro_direction a ns1:Parametro ;
    rdfs:label "direction" ;
    ns1:identificador "direction" ;
    ns1:textoExtracto "Sentido de desplazamiento. Se programa mediante los parámetros \"DIRPOS\" (sentido positivo) o \"DIRNEG\" (sentido negativo)." .

ns1:Parametro_feed a ns1:Parametro ;
    rdfs:label "feed" ;
    ns1:identificador "feed" ;
    ns1:textoExtracto "Avance de posicionamiento." .

ns1:Parametro_pos a ns1:Parametro ;
    rdfs:label "pos" ;
    ns1:identificador "pos" ;
    ns1:textoExtracto "Posición a alcanzar." .

