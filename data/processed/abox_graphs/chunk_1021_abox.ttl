@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_WAITINPOS a ns1:ModoOperacion ;
    rdfs:label "Modo WAITINPOS" ;
    ns1:textoExtracto "WAITINPOS El eje alcanza la posición indicada a avance nulo y espera a estar en posición para ejecutar el siguiente bloque." .

ns1:Parametro_Avance_250 a ns1:Parametro ;
    rdfs:label "Avance F250" ;
    ns1:textoExtracto "F 500 250" ;
    ns1:valor "250" .

ns1:Parametro_Avance_500 a ns1:Parametro ;
    rdfs:label "Avance F500" ;
    ns1:textoExtracto "F 500 250" ;
    ns1:valor "500" .

ns1:TareaMantenimiento_ComandoMOVE_ABS_1 a ns1:TareaMantenimiento ;
    rdfs:label "Comando MOVE ABS (X, 500000, 5000000, PRESENT)" ;
    ns1:textoExtracto ".. = MOVE ABS (X, 500000, 5000000, PRESENT)" .

ns1:TareaMantenimiento_ComandoMOVE_ABS_2 a ns1:TareaMantenimiento ;
    rdfs:label "Comando MOVE ABS (X, 1000000, 2500000, NEXT)" ;
    ns1:habilitadoPor ns1:ModoOperacion_NEXT ;
    ns1:textoExtracto ".. = MOVE ABS (X, 1000000, 2500000, NEXT)" .

ns1:TareaMantenimiento_ComandoMOVE_ABS_3 a ns1:TareaMantenimiento ;
    rdfs:label "Comando MOVE ABS (X, 1500000, 1250000, NULL)" ;
    ns1:habilitadoPor ns1:ModoOperacion_NULL ;
    ns1:textoExtracto ".. = MOVE ABS (X, 1500000, 1250000, NULL)" .

ns1:ModoOperacion_NEXT a ns1:ModoOperacion ;
    rdfs:label "Modo NEXT" ;
    ns1:textoExtracto "NEXT El eje alcanza la posición indicada al avance especificado en el siguiente bloque." .

ns1:ModoOperacion_NULL a ns1:ModoOperacion ;
    rdfs:label "Modo NULL" ;
    ns1:textoExtracto "NULL El eje alcanza la posición indicada a avance nulo." .

