@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_FollowOff a ns1:ModoOperacion ;
    rdfs:label "FOLLOW OFF" ;
    ns1:documentadoEn ns1:Manual_MovimientoIndependiente ;
    ns1:identificador "FOLLOW_OFF" ;
    ns1:monitoreaParametro ns1:Parametro_Slave ;
    ns1:textoExtracto "cancelar el movimiento de sincronización (FOLLOW OFF)"@es .

ns1:ModoOperacion_FollowOn a ns1:ModoOperacion ;
    rdfs:label "FOLLOW ON" ;
    ns1:documentadoEn ns1:Manual_MovimientoIndependiente ;
    ns1:identificador "FOLLOW_ON" ;
    ns1:monitoreaParametro ns1:Parametro_Ddratio,
        ns1:Parametro_Master,
        ns1:Parametro_Nnratio,
        ns1:Parametro_Slave,
        ns1:Parametro_SyncType ;
    ns1:textoExtracto "Activar el movimiento de sincronización con las cotas reales (FOLLOW ON)"@es .

ns1:ModoOperacion_TFollowOn a ns1:ModoOperacion ;
    rdfs:label "TFOLLOW ON" ;
    ns1:documentadoEn ns1:Manual_MovimientoIndependiente ;
    ns1:identificador "TFOLLOW_ON" ;
    ns1:monitoreaParametro ns1:Parametro_Ddratio,
        ns1:Parametro_Master,
        ns1:Parametro_Nnratio,
        ns1:Parametro_Slave,
        ns1:Parametro_SyncType ;
    ns1:textoExtracto "con las cotas teóricas (TFOLLOW ON)"@es .

ns1:Parametro_Ddratio a ns1:Parametro ;
    rdfs:label "Ddratio" ;
    ns1:identificador "Ddratio" ;
    ns1:textoExtracto "FOLLOW ON (master, slave, <Nnratio>, <Ddratio>, synctype)"@es .

ns1:Parametro_Master a ns1:Parametro ;
    rdfs:label "master" ;
    ns1:identificador "master" ;
    ns1:textoExtracto "FOLLOW ON (master, slave, <Nnratio>, <Ddratio>, synctype)"@es .

ns1:Parametro_Nnratio a ns1:Parametro ;
    rdfs:label "Nnratio" ;
    ns1:identificador "Nnratio" ;
    ns1:textoExtracto "FOLLOW ON (master, slave, <Nnratio>, <Ddratio>, synctype)"@es .

ns1:Parametro_SyncType a ns1:Parametro ;
    rdfs:label "synctype" ;
    ns1:identificador "synctype" ;
    ns1:textoExtracto "FOLLOW ON (master, slave, <Nnratio>, <Ddratio>, synctype)"@es .

ns1:Manual_MovimientoIndependiente a ns1:Manual ;
    rdfs:label "Manual específico de movimiento independiente"@es ;
    ns1:identificador "Manual_MovimientoIndependiente" ;
    ns1:textoExtracto "Esta funcionalidad dispone de un manual específico. En este manual, que está usted leyendo, sólo se ofrece información orientativa sobre esta funcionalidad. Consulte la documentación específica para obtener más información acerca de los requisitos y el funcionamiento de los ejes independientes."@es .

ns1:Parametro_Slave a ns1:Parametro ;
    rdfs:label "slave" ;
    ns1:identificador "slave" ;
    ns1:textoExtracto "FOLLOW ON (master, slave, <Nnratio>, <Ddratio>, synctype)"@es .

