@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_Ddratio a ns1:Parametro ;
    rdfs:label "Ddratio" ;
    ns1:documentadoEn ns1:Tabla_ParametrosSincronizacion_4_4_9 ;
    ns1:identificador "Ddratio" ;
    ns1:textoExtracto "Ddratio | Opcional. Denominador del ratio de transmisión. Rotaciones del eje maestro."@es .

ns1:Parametro_Nnratio a ns1:Parametro ;
    rdfs:label "Nnratio" ;
    ns1:documentadoEn ns1:Tabla_ParametrosSincronizacion_4_4_9 ;
    ns1:identificador "Nnratio" ;
    ns1:textoExtracto "Nnratio | Opcional. Numerador del ratio de transmisión. Rotaciones del eje esclavo."@es .

ns1:Parametro_master a ns1:Parametro ;
    rdfs:label "master" ;
    ns1:documentadoEn ns1:Tabla_ParametrosSincronizacion_4_4_9 ;
    ns1:identificador "master" ;
    ns1:textoExtracto "master | Nombre del eje maestro."@es .

ns1:Parametro_slave a ns1:Parametro ;
    rdfs:label "slave" ;
    ns1:documentadoEn ns1:Tabla_ParametrosSincronizacion_4_4_9 ;
    ns1:identificador "slave" ;
    ns1:textoExtracto "slave | Nombre del eje esclavo."@es .

ns1:Parametro_synctype a ns1:Parametro ;
    rdfs:label "synctype" ;
    ns1:documentadoEn ns1:Tabla_ParametrosSincronizacion_4_4_9 ;
    ns1:identificador "synctype" ;
    ns1:textoExtracto "synctype | Tipo de sincronización. Se programa mediante los parámetros \"POS\" (sincronización en posición) o \"VEL\" (sincronización en velocidad)."@es .

ns1:Tabla_ParametrosSincronizacion_4_4_9 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de sincronización (4.4.9)"@es ;
    ns1:textoExtracto "synctype | Tipo de sincronización. Se programa mediante los parámetros \"POS\" (sincronización en posición) o \"VEL\" (sincronización en velocidad)."@es .

