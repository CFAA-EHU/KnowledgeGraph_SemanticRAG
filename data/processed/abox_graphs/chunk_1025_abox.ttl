@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SincronizacionPosicion a ns1:ModoOperacion ;
    rdfs:label "Sincronización en posición (en fase)" ;
    ns1:identificador "POS" ;
    ns1:textoExtracto "Sincronización en posición (en fase). Offset de posición. Permite variar la posición del eje esclavo independientemente de la posición del eje maestro. Se define con la variable V.A.SYNCPOSOFF.xn." .

ns1:SincronizacionVelocidad a ns1:ModoOperacion ;
    rdfs:label "Sincronización en velocidad" ;
    ns1:identificador "VEL" ;
    ns1:textoExtracto "Sincronización en velocidad. Offset de velocidad. Permite variar la velocidad del eje esclavo independientemente de la velocidad del eje maestro. Se define con la variable V.A.SYNCVELOFF.xn." .

ns1:SistemaSincronizacion a ns1:Sistema ;
    rdfs:label "Sistema de sincronización de ejes" ;
    ns1:monitoreaParametro ns1:VariableGearAdj,
        ns1:VariableSyncPosOff,
        ns1:VariableSyncVelOff ;
    ns1:textoExtracto "Sincronización en velocidad. [...] Sincronización en posición (en fase). [...] El ratio de transmisión se determina al programar la sentencia y su valor permanece constante durante toda la operación." ;
    ns1:tieneComponente ns1:ModoOperacionSincronizacionPosicion,
        ns1:ModoOperacionSincronizacionVelocidad,
        ns1:ParametroSyncType .

ns1:ModoOperacionSincronizacionPosicion a ns1:ModoOperacion ;
    rdfs:label "Modo de sincronización en posición" ;
    ns1:identificador "POS" ;
    ns1:textoExtracto "TFOLLOW ON (A1, Z, VEL) [...] Sincronización en posición (en fase)." .

ns1:ModoOperacionSincronizacionVelocidad a ns1:ModoOperacion ;
    rdfs:label "Modo de sincronización en velocidad" ;
    ns1:identificador "VEL" ;
    ns1:textoExtracto "FOLLOW ON (A1, Z, N3, D1, VEL) [...] Sincronización en velocidad." .

ns1:ParametroSyncType a ns1:Parametro ;
    rdfs:label "Tipo de sincronización (synctype)" ;
    ns1:identificador "synctype" ;
    ns1:textoExtracto "| synctype | Tipo de sincronización. Se programa mediante los parámetros \"POS\" (sincronización en posición) o \"VEL\" (sincronización en velocidad)." .

ns1:VariableGearAdj a ns1:Parametro ;
    rdfs:label "Ajuste fino del ratio de transmisión (GEARADJ)" ;
    ns1:identificador "GEARADJ" ;
    ns1:textoExtracto "El ajuste fino del ratio se define con la variable GEARADJ." .

ns1:VariableSyncPosOff a ns1:Parametro ;
    rdfs:label "Offset de posición (V.A.SYNCPOSOFF.xn)" ;
    ns1:identificador "V.A.SYNCPOSOFF.xn" ;
    ns1:textoExtracto "Offset de posición. Permite variar la posición del eje esclavo independientemente de la posición del eje maestro. Se define con la variable V.A.SYNCPOSOFF.xn." .

ns1:VariableSyncVelOff a ns1:Parametro ;
    rdfs:label "Offset de velocidad (V.A.SYNCVELOFF.xn)" ;
    ns1:identificador "V.A.SYNCVELOFF.xn" ;
    ns1:textoExtracto "Offset de velocidad. Permite variar la velocidad del eje esclavo independientemente de la velocidad del eje maestro. Se define con la variable V.A.SYNCVELOFF.xn." .

