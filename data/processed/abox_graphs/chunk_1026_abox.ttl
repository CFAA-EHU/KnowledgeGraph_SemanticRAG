@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LevaElectronica_765 a ns1:ComponenteElectrico ;
    rdfs:label "Leva electrónica"@es ;
    ns1:solucionaFallo ns1:ModoSincronizacion_765 ;
    ns1:textoExtracto "este comportamiento es más propio de una leva electrónica [...] Para solucionar esta cuestión puede recurrirse a la programación de una leva electrónica"@es .

ns1:Parametro_RatioTransmision_765 a ns1:Parametro ;
    rdfs:label "Ratio de transmisión"@es ;
    ns1:monitoreaParametro ns1:ModoSincronizacion_765 ;
    ns1:textoExtracto "El ratio de transmisión se determina al programar la sentencia y su valor permanece constante durante toda la operación"@es ;
    ns1:valor "constante (programable)"@es .

ns1:SistemaControl_765 a ns1:Sistema ;
    rdfs:label "Sistema de engranaje electrónico"@es ;
    ns1:controla ns1:ModoSincronizacion_765 ;
    ns1:textoExtracto "este comportamiento es más propio de una leva electrónica que de un engranaje electrónico"@es .

ns1:ModoSincronizacion_765 a ns1:ModoOperacion ;
    rdfs:label "Modo de sincronización por ratio de transmisión fijo"@es ;
    ns1:identificador "4.4.9 (ratio fijo)" ;
    ns1:textoExtracto "El ratio de transmisión se determina al programar la sentencia y su valor permanece constante durante toda la operación. En este modo de sincronización no se contempla la posibilidad de modificar este valor mientras el sistema está operativo"@es .

