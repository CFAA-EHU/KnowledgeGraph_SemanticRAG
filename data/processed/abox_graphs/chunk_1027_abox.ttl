@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InstruccionLatcheoCota_766 a ns1:TareaMantenimiento ;
    rdfs:label "Instrucción de latcheo de cota con TOUCHPROBE"@es ;
    ns1:documentadoEn ns1:Manual_Seccion4_4_10 ;
    ns1:requiereMantenimiento ns1:SistemaCNC_766 ;
    ns1:textoExtracto "Se entiende por latcheo de cota a que el CNC capture la cota de un eje cuando se produce un evento dado. La instrucción TOUCHPROBE latchea la cota de un eje por evento de un palpador, de una entrada digital física o de una entrada lógica."@es .

ns1:EntradaDigital_PRBDI1_766 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada digital PRBDI1"@es ;
    ns1:identificador "PRBDI1" ;
    ns1:textoExtracto "Los eventos a utilizar serán las entradas digitales definidas en los parámetros PRBDI1 y PRBDI2."@es .

ns1:EntradaDigital_PRBDI2_766 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada digital PRBDI2"@es ;
    ns1:identificador "PRBDI2" ;
    ns1:textoExtracto "Los eventos a utilizar serán las entradas digitales definidas en los parámetros PRBDI1 y PRBDI2."@es .

ns1:EntradaLogica_PLC_766 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada lógica gestionada por PLC"@es ;
    ns1:textoExtracto "Si el evento seleccionado es una entrada lógica, la activación de la misma puede realizarse desde programa PLC."@es .

ns1:Manual_Seccion4_4_10 a ns1:Pagina ;
    rdfs:label "Sección 4.4.10: Instrucciones de latcheo de cota"@es ;
    ns1:ilustradoEn ns1:Manual_Tecnico ;
    ns1:textoExtracto "Se entiende por latcheo de cota a que el CNC capture la cota de un eje cuando se produce un evento dado."@es .

ns1:Palpador_766 a ns1:Sensor ;
    rdfs:label "Palpador para latcheo de cota"@es ;
    ns1:monitoreaParametro ns1:Parametro_PosicionEje_766 ;
    ns1:textoExtracto "evento de un palpador [...] el palpador ya ha alcanzado su nivel lógico (el palpador actúa por nivel, no por flanco)."@es .

ns1:Parametro_PRBDI1_766 a ns1:Parametro ;
    rdfs:label "Parámetro PRBDI1"@es ;
    ns1:identificador "PRBDI1" ;
    ns1:textoExtracto "Los eventos a utilizar serán las entradas digitales definidas en los parámetros PRBDI1 y PRBDI2."@es .

ns1:Parametro_PRBDI2_766 a ns1:Parametro ;
    rdfs:label "Parámetro PRBDI2"@es ;
    ns1:identificador "PRBDI2" ;
    ns1:textoExtracto "Los eventos a utilizar serán las entradas digitales definidas en los parámetros PRBDI1 y PRBDI2."@es .

ns1:Parametro_PROBEAXIS_766 a ns1:Parametro ;
    rdfs:label "Parámetro PROBEAXIS"@es ;
    ns1:identificador "PROBEAXIS" ;
    ns1:textoExtracto "Los siguientes parámetros máquina asociados al palpador no tienen efecto; PROBEAXIS, PROBERANGE, PROBEFEED, PRB1MIN, PRB2MIN, PRB3MIN, PRB1MAX, PRB2MAX y PRB3MAX."@es .

ns1:Parametro_PosicionEje_766 a ns1:Parametro ;
    rdfs:label "Posición del eje durante latcheo"@es ;
    ns1:textoExtracto "El latcheo de la cota se puede realizar en cualquier posición del recorrido del eje o bien se puede definir una ventana de latcheo."@es .

ns1:SistemaCNC_766 a ns1:Sistema ;
    rdfs:label "Sistema CNC con funcionalidad TOUCHPROBE"@es ;
    ns1:textoExtracto "El CNC capture la cota de un eje cuando se produce un evento dado. La instrucción TOUCHPROBE latchea la cota de un eje por evento de un palpador, de una entrada digital física o de una entrada lógica."@es ;
    ns1:tieneComponente ns1:EntradaDigital_PRBDI1_766,
        ns1:EntradaDigital_PRBDI2_766,
        ns1:EntradaLogica_PLC_766,
        ns1:Palpador_766,
        ns1:Parametro_PRBDI1_766,
        ns1:Parametro_PRBDI2_766,
        ns1:Parametro_PROBEAXIS_766 .

