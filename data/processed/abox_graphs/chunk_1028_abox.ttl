@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_axis a ns1:Parametro ;
    rdfs:label "axis"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosLatcheo_4_4_10 ;
    ns1:textoExtracto "Nombre del eje objeto del latcheo."@es .

ns1:Parametro_probe a ns1:Parametro ;
    rdfs:label "probe"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosLatcheo_4_4_10 ;
    ns1:textoExtracto "Número de palpador a utilizar como evento para el latcheo."@es .

ns1:Parametro_winmaxpos a ns1:Parametro ;
    rdfs:label "winmaxpos"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosLatcheo_4_4_10 ;
    ns1:textoExtracto "Límite superior para la ventana del latch."@es .

ns1:Parametro_winminpos a ns1:Parametro ;
    rdfs:label "winminpos"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosLatcheo_4_4_10 ;
    ns1:textoExtracto "Límite inferior para la ventana del latch."@es .

ns1:Parametro_wintype a ns1:Parametro ;
    rdfs:label "wintype"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosLatcheo_4_4_10 ;
    ns1:textoExtracto "Tipo de ventana para el latcheo. Se programa mediante los comandos DISABLE (sin ventana), EXCLUSIVE (latch fuera de la ventana) e INCLUSIVE (latch dentro de la ventana)."@es .

ns1:Tabla_ParametrosLatcheo_4_4_10 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de latcheo (Sección 4.4.10)"@es ;
    ns1:documentadoEn ns1:Pagina_384_387 ;
    ns1:textoExtracto "axis | Nombre del eje objeto del latcheo."@es .

