@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EntradaDigital a ns1:Sensor ;
    rdfs:label "Entrada digital" ;
    ns1:textoExtracto "En vez de un palpador, también se puede utilizar como evento una entrada digital física o de una entrada lógica." .

ns1:PLC_estandar a ns1:Sistema ;
    rdfs:label "PLC estándar" ;
    ns1:textoExtracto "Las unidades de programación serán las estándar del PLC." .

ns1:PRBDI1 a ns1:Parametro ;
    rdfs:label "PRBDI1" ;
    ns1:textoExtracto "el palpador 1 será el asignado al parámetro PRBDI1" .

ns1:PRBDI2 a ns1:Parametro ;
    rdfs:label "PRBDI2" ;
    ns1:textoExtracto "el palpador 2 será el asignado al parámetro PRBDI2" .

ns1:Palpador1_c565801fc4 a ns1:Sensor ;
    rdfs:label "Palpador 1" ;
    ns1:textoExtracto "el palpador 1 será el asignado al parámetro PRBDI1" .

ns1:Palpador2_0cbdb9c803 a ns1:Sensor ;
    rdfs:label "Palpador 2" ;
    ns1:textoExtracto "el palpador 2 será el asignado al parámetro PRBDI2" .

ns1:ParametroDeLimiteInferiorDeVentana_faa5d8ccdd a ns1:Parametro ;
    rdfs:label "Parámetro de límite inferior de ventana" ;
    ns1:textoExtracto "Tamaño de la ventana de latcheo. Cuando la ventana para el latcheo es del tipo exclusive o inclusive, hay que definir el tamaño de la ventana. Los parámetros de llamada ꞏwinminposꞏ y ꞏwinmaxposꞏ establecen los límites inferior y superior de la ventana del latch." .

ns1:ParametroDeLimiteSuperiorDeVentana_84e104eae9 a ns1:Parametro ;
    rdfs:label "Parámetro de límite superior de ventana" ;
    ns1:textoExtracto "Tamaño de la ventana de latcheo. Cuando la ventana para el latcheo es del tipo exclusive o inclusive, hay que definir el tamaño de la ventana. Los parámetros de llamada ꞏwinminposꞏ y ꞏwinmaxposꞏ establecen los límites inferior y superior de la ventana del latch." .

ns1:ParametroDePosicion_a0a17152e6 a ns1:Parametro ;
    rdfs:label "Parámetro de posición" ;
    ns1:textoExtracto "Nombre del eje objeto del latcheo. Nombre del eje sobre el que se realiza el latcheo; no se admiten cabezales, excepto si están activos como eje C." .

ns1:ParametroDeTipoDeVentana_14d9326934 a ns1:Parametro ;
    rdfs:label "Parámetro de tipo de ventana" ;
    ns1:textoExtracto "Tipo de ventana para el latcheo. Esta opción se programa mediante los siguientes comandos. DISABLE No hay ventana de latcheo (opción por defecto). El latcheo de la cota se puede realizar en cualquier posición del recorrido del eje. EXCLUSIVE El latcheo de la cota se realiza si el eje está fuera de la ventana. INCLUSIVE El latcheo de la cota se realiza si el eje está dentro de la ventana." .

ns1:TOUCHPROBEX1_cefb2bd5ff a ns1:Parametro ;
    rdfs:label "TOUCHPROBE (X, 1)" ;
    ns1:textoExtracto "TOUCHPROBE (X, 1)" .

