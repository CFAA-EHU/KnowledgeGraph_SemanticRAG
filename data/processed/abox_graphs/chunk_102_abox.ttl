@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:ComprobacionDePresiones a owl:Class ;
    rdfs:label "Comprobación de presiones"@es ;
    rdfs:comment "Proceso de verificación de presiones en sistemas hidráulicos o neumáticos."@es .

ex:Esquema a owl:Class ;
    rdfs:label "Esquema"@es ;
    rdfs:comment "Documento técnico que muestra las presiones indicadas para un sistema."@es .

ex:Capitulo a owl:Class ;
    rdfs:label "Capítulo"@es ;
    rdfs:comment "Sección de un manual técnico que contiene información específica."@es .

ex:Anexo a owl:Class ;
    rdfs:label "Anexo"@es ;
    rdfs:comment "Documento adicional que complementa la información principal."@es .

ex:mostrar a owl:ObjectProperty ;
    rdfs:label "mostrar"@es ;
    rdfs:comment "Relación que indica que un elemento muestra información en otro."@es ;
    rdfs:domain ex:Capitulo ;
    rdfs:range ex:Anexo .

ex:comparar a owl:ObjectProperty ;
    rdfs:label "comparar"@es ;
    rdfs:comment "Relación que indica que un elemento se compara con otro."@es ;
    rdfs:domain ex:ComprobacionDePresiones ;
    rdfs:range ex:Esquema .

ex:indicadasEn a owl:ObjectProperty ;
    rdfs:label "indicadas en"@es ;
    rdfs:comment "Relación que indica que un elemento está indicado en otro."@es ;
    rdfs:domain ex:ComprobacionDePresiones ;
    rdfs:range ex:Esquema .