@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ComprobacionPresiones_102 a ex:TareaMantenimiento ;
    ex:textoExtracto "Comprobar presiones y compararlas con las indicadas en los esquemas correspondientes mostrados en el Capítulo 10 - anexos." ;
    ex:requiereMantenimiento ex:Esquema_10_anexos .

ex:Esquema_10_anexos a ex:Esquema ;
    ex:textoExtracto "esquemas correspondientes mostrados en el Capítulo 10 - anexos" .