@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LatcheoCotas_4_4_10 a ns1:ModoOperacion ;
    rdfs:label "Latcheo de cotas con palpador o entrada digital"@es ;
    ns1:requiereMantenimiento ns1:ErrorSimultaneidadG100 ;
    ns1:textoExtracto "Cuando la ventana para el latcheo es del tipo exclusive o inclusive, hay que definir el tamaño de la ventana. Los parámetros de llamada ꞏwinminposꞏ y ꞏwinmaxposꞏ establecen los límites inferior y superior de la ventana del latch. Funcionamiento del latcheo de cotas."@es ;
    ns1:tieneComponente ns1:Parametro_winmaxpos,
        ns1:Parametro_winminpos .

ns1:ErrorSimultaneidadG100 a ns1:AvisoSeguridad ;
    rdfs:label "Error por simultaneidad con G100"@es ;
    ns1:textoExtracto "Para un mismo palpador no es posible tener activos simultáneamente un proceso de latcheo de cota y un proceso de palpado programado con G100, aunque sea en ejes distintos; si se ejecuta uno de ellos estando el otro activo, el CNC mostrará un error."@es .

ns1:Parametro_winmaxpos a ns1:Parametro ;
    rdfs:label "winmaxpos" ;
    ns1:identificador "winmaxpos" ;
    ns1:textoExtracto "Los parámetros de llamada [...] ꞏwinmaxposꞏ establecen los límites inferior y superior de la ventana del latch."@es ;
    ns1:valor "límite superior de la ventana de latcheo"@es .

ns1:Parametro_winminpos a ns1:Parametro ;
    rdfs:label "winminpos" ;
    ns1:identificador "winminpos" ;
    ns1:textoExtracto "Los parámetros de llamada ꞏwinminposꞏ [...] establecen los límites inferior y superior de la ventana del latch."@es ;
    ns1:valor "límite inferior de la ventana de latcheo"@es .

