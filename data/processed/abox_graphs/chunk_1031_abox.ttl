@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorLatcheoCotas a ns1:AvisoSeguridad ;
    rdfs:label "Error por latcheo de cotas simultáneo"@es ;
    ns1:ilustradoEn ns1:Manual_Seccion_4.4.10 ;
    ns1:textoExtracto "si se ejecuta uno de ellos estando el otro activo, el CNC mostrará un error"@es .

ns1:Funcion_G100 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G100 (palpado programado)"@es ;
    ns1:documentadoEn ns1:Manual_Seccion_4.4.10 ;
    ns1:identificador "G100" ;
    ns1:textoExtracto "palpado programado con G100"@es .

ns1:Funcion_G101 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G101"@es ;
    ns1:identificador "G101" ;
    ns1:textoExtracto "El latcheo de cotas no se ve afectado por las funciones G101"@es .

ns1:Funcion_G102 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G102"@es ;
    ns1:identificador "G102" ;
    ns1:textoExtracto "El latcheo de cotas no se ve afectado por las funciones [...] G102"@es .

ns1:Manual_Seccion_4.4.10 a ns1:Pagina ;
    rdfs:label "Sección 4.4.10: Instrucciones de latcheo de cotas con palpador o entrada digital"@es ;
    ns1:identificador "4.4.10" ;
    ns1:textoExtracto "Instrucciones de latcheo de cotas con un palpador o entrada digital"@es .

