@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Comando_PLC_TOUCHPROBE_Z1 a ns1:Parametro ;
    rdfs:label "TOUCHPROBE (Z,1)"@en ;
    ns1:documentadoEn ns1:Tabla_InstruccionesLatcheoCotas ;
    ns1:identificador "TOUCHPROBE (Z,1)" ;
    ns1:textoExtracto "ꞏꞏ = TOUCHPROBE (Z,1)"@es .

ns1:Combinacion_Correcta_Probe1_TouchprobeX2 a ns1:ModoOperacion ;
    rdfs:label "Combinación correcta: SELECT PROBE [1] + TOUCHPROBE (X,2)"@es ;
    ns1:documentadoEn ns1:Tabla_InstruccionesLatcheoCotas ;
    ns1:textoExtracto "Correcto."@es ;
    ns1:tieneComponente ns1:Comando_CNC_SELECT_PROBE_1,
        ns1:Comando_PLC_TOUCHPROBE_X2 .

ns1:Combinacion_Correcta_Probe2_TouchprobeX1 a ns1:ModoOperacion ;
    rdfs:label "Combinación correcta: SELECT PROBE [2] + TOUCHPROBE (X,1)"@es ;
    ns1:documentadoEn ns1:Tabla_InstruccionesLatcheoCotas ;
    ns1:textoExtracto "Correcto."@es ;
    ns1:tieneComponente ns1:Comando_CNC_SELECT_PROBE_2,
        ns1:Comando_PLC_TOUCHPROBE_X1 .

ns1:Comando_CNC_SELECT_PROBE_1 a ns1:Parametro ;
    rdfs:label "SELECT PROBE [1]"@en ;
    ns1:documentadoEn ns1:Tabla_InstruccionesLatcheoCotas ;
    ns1:identificador "SELECT PROBE [1]" ;
    ns1:textoExtracto "#SELECT PROBE [1]"@es .

ns1:Comando_CNC_SELECT_PROBE_2 a ns1:Parametro ;
    rdfs:label "SELECT PROBE [2]"@en ;
    ns1:documentadoEn ns1:Tabla_InstruccionesLatcheoCotas ;
    ns1:identificador "SELECT PROBE [2]" ;
    ns1:textoExtracto "#SELECT PROBE [2]"@es .

ns1:Comando_PLC_TOUCHPROBE_X1 a ns1:Parametro ;
    rdfs:label "TOUCHPROBE (X,1)"@en ;
    ns1:documentadoEn ns1:Tabla_InstruccionesLatcheoCotas ;
    ns1:identificador "TOUCHPROBE (X,1)" ;
    ns1:textoExtracto "ꞏꞏ = TOUCHPROBE (X,1)"@es .

ns1:Comando_PLC_TOUCHPROBE_X2 a ns1:Parametro ;
    rdfs:label "TOUCHPROBE (X,2)"@en ;
    ns1:documentadoEn ns1:Tabla_InstruccionesLatcheoCotas ;
    ns1:identificador "TOUCHPROBE (X,2)" ;
    ns1:textoExtracto "ꞏꞏ = TOUCHPROBE (X,2)"@es .

ns1:Tabla_InstruccionesLatcheoCotas a ns1:Tabla ;
    rdfs:label "Tabla de instrucciones de latcheo de cotas con palpador o entrada digital"@es ;
    ns1:textoExtracto """
| CNC               | PLC                     |       |
|-------------------|-------------------------|-------|
| #SELECT PROBE [1] | ꞏꞏ = TOUCHPROBE (X,1)  | Incorrecto. |
| #SELECT PROBE [1] | ꞏꞏ = TOUCHPROBE (Z,1)  | Incorrecto. |
| #SELECT PROBE [1] | ꞏꞏ = TOUCHPROBE (X,2)  | Correcto.  |
| #SELECT PROBE [2] | ꞏꞏ = TOUCHPROBE (X,1)  | Correcto.  |
"""@es .

