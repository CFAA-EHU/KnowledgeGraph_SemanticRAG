@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Instruccion_TOUCHPROBE a ns1:AccionProhibida ;
    ns1:textoExtracto "La instrucción TOUCHPROBE podrá activarse de forma simultánea para cualquiera de los 2 palpadores y para cualquiera de los ejes del sistema." .

ns1:Sistema_de_latcheo a ns1:Sistema ;
    ns1:compuestoPor ns1:PRBDI1_182bbc0b0a,
        ns1:PRBDI2_0e0c9fec1c ;
    ns1:textoExtracto "para cualquiera de los ejes del sistema" ;
    ns1:tieneComponente ns1:Marca_IRESET,
        ns1:Marca_LATCH1ACTIVE,
        ns1:Marca_LATCH1DONE,
        ns1:Marca_LATCH2ACTIVE,
        ns1:Marca_LATCH2DONE,
        ns1:Marca_PROBE1ACTIVE,
        ns1:Marca_PROBE2ACTIVE .

ns1:Marca_IRESET a ns1:Parametro ;
    ns1:textoExtracto "Si el PLC activa la marca IRESET(axis), cancela el proceso de latcheo en el eje" .

ns1:Marca_LATCH1ACTIVE a ns1:Parametro ;
    ns1:textoExtracto "el interpolador independiente desactiva la marca LATCH1ACTIVE(axis) o LATCH2ACTIVE(axis) asociada al proceso" .

ns1:Marca_LATCH1DONE a ns1:Parametro ;
    ns1:textoExtracto "el interpolador independiente sólo activará la marca LATCH1DONE(axis) o LATCH2DONE(axis) del eje en el que se ha producido el evento" .

ns1:Marca_LATCH2ACTIVE a ns1:Parametro ;
    ns1:textoExtracto "el interpolador independiente desactiva la marca LATCH1ACTIVE(axis) o LATCH2ACTIVE(axis) asociada al proceso" .

ns1:Marca_LATCH2DONE a ns1:Parametro ;
    ns1:textoExtracto "el interpolador independiente sólo activará la marca LATCH1DONE(axis) o LATCH2DONE(axis) del eje en el que se ha producido el evento" .

ns1:Marca_PROBE1ACTIVE a ns1:Parametro ;
    ns1:textoExtracto "El interpolador independiente activa esta marca cuando hay algún proceso de latcheo activo con el palpador indicado y la desactiva cuando no hay ningún proceso de latcheo activo con el palpador indicado." .

ns1:Marca_PROBE2ACTIVE a ns1:Parametro ;
    ns1:textoExtracto "El interpolador independiente activa esta marca cuando hay algún proceso de latcheo activo con el palpador indicado y la desactiva cuando no hay ningún proceso de latcheo activo con el palpador indicado." .

ns1:PRBDI1_182bbc0b0a a ns1:Sensor ;
    ns1:identificador "PRBDI1" ;
    ns1:textoExtracto "El palpador 1 será el asignado al parámetro PRBDI1" .

ns1:PRBDI2_0e0c9fec1c a ns1:Sensor ;
    ns1:identificador "PRBDI2" ;
    ns1:textoExtracto "el palpador 2 será el asignado al parámetro PRBDI2" .

