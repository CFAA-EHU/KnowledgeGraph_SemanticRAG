@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:IRESET a ns1:Parametro ;
    ns1:textoExtracto "Si el PLC activa la marca IRESET(axis) se cancela el proceso de latcheo en el eje." .

ns1:LATCH1ACTIVE a ns1:Sensor ;
    ns1:textoExtracto "LATCH1ACTIVE(axis) LATCH2ACTIVE(axis) El interpolador independiente activa esta marca al activar un proceso de latcheo en el eje con el palpador indicado; la desactiva cuando finaliza el proceso de latcheo o cuando se cancela el proceso." .

ns1:LATCH2ACTIVE a ns1:Sensor ;
    ns1:textoExtracto "LATCH1ACTIVE(axis) LATCH2ACTIVE(axis) El interpolador independiente activa esta marca al activar un proceso de latcheo en el eje con el palpador indicado; la desactiva cuando finaliza el proceso de latcheo o cuando se cancela el proceso." .

ns1:PROBE1ACTIVE a ns1:Sensor ;
    ns1:textoExtracto "PROBE1ACTIVE PROBE2ACTIVE El interpolador independiente activa esta marca cuando hay algún proceso de latcheo activo con el palpador indicado y la desactiva cuando no hay ningún proceso de latcheo activo con el palpador indicado." .

ns1:PROBE2ACTIVE a ns1:Sensor ;
    ns1:textoExtracto "PROBE1ACTIVE PROBE2ACTIVE El interpolador independiente activa esta marca cuando hay algún proceso de latcheo activo con el palpador indicado y la desactiva cuando no hay ningún proceso de latcheo activo con el palpador indicado." .

