@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Canal_ch a ns1:InterfazUsuario ;
    rdfs:label "Canal ch" ;
    ns1:controla ns1:Variable_LATCH1_xn ;
    ns1:identificador "ch" ;
    ns1:textoExtracto "ꞏchꞏ Número de canal." .

ns1:Eje_xn a ns1:ComponenteMecanico ;
    rdfs:label "Eje xn" ;
    ns1:identificador "xn" ;
    ns1:textoExtracto "Nombre, número lógico o índice del eje." .

ns1:Variable_LATCH1_xn a ns1:Parametro ;
    rdfs:label "Variable LATCH1.xn" ;
    ns1:identificador "LATCH1.xn" ;
    ns1:monitoreaParametro ns1:Eje_xn ;
    ns1:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. Variable válida para ejes rotativos y lineales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Cota máquina obtenida del latcheo del palpador 1 en el eje ꞏxnꞏ." .

