@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_Latcheo a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de latcheo de cotas con palpador" ;
    ns1:ilustradoEn ns1:Tabla_VariablesLatcheo ;
    ns1:textoExtracto "Instrucciones de latcheo de cotas con un palpador o entrada digital." .

ns1:Variable_ACCUDIST a ns1:Parametro ;
    rdfs:label "(V.)[ch].A.ACCUDIST.xn" ;
    ns1:monitoreaParametro ns1:Eje_Generico ;
    ns1:textoExtracto "(V.)[ch].A.ACCUDIST.xn Variable de lectura y escritura desde el programa, PLC e interfaz. Variable válida para ejes rotativos, lineales y cabezales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Distancia recorrida por el eje o cabezal desde el último latcheo de cota." .

ns1:Variable_LATCH1_4 a ns1:Parametro ;
    rdfs:label "V.A.LATCH1.4" ;
    ns1:monitoreaParametro ns1:Eje_Logico_4 ;
    ns1:textoExtracto "V.A.LATCH1.4 | Eje con número lógico ꞏ4ꞏ." .

ns1:Variable_LATCH1_Canal2_Indice1 a ns1:Parametro ;
    rdfs:label "V.[2].A.LATCH1.1" ;
    ns1:monitoreaParametro ns1:Eje_Canal2_Indice1 ;
    ns1:textoExtracto "V.[2].A.LATCH1.1 | Eje con índice ꞏ1ꞏ en el canal ꞏ2ꞏ." .

ns1:Variable_LATCH1_Z a ns1:Parametro ;
    rdfs:label "V.A.LATCH1.Z" ;
    ns1:monitoreaParametro ns1:Eje_Z ;
    ns1:textoExtracto "V.A.LATCH1.Z | Eje Z." .

ns1:Variable_LATCH2_4 a ns1:Parametro ;
    rdfs:label "V.A.LATCH2.4" ;
    ns1:monitoreaParametro ns1:Eje_Logico_4 ;
    ns1:textoExtracto "V.A.LATCH2.4 | Eje con número lógico ꞏ4ꞏ." .

ns1:Variable_LATCH2_Canal2_Indice1 a ns1:Parametro ;
    rdfs:label "V.[2].A.LATCH2.1" ;
    ns1:monitoreaParametro ns1:Eje_Canal2_Indice1 ;
    ns1:textoExtracto "V.[2].A.LATCH2.1 | Eje con índice ꞏ1ꞏ en el canal ꞏ2ꞏ." .

ns1:Variable_LATCH2_Z a ns1:Parametro ;
    rdfs:label "V.A.LATCH2.Z" ;
    ns1:monitoreaParametro ns1:Eje_Z ;
    ns1:textoExtracto "V.A.LATCH2.Z | Eje Z." .

ns1:Tabla_VariablesLatcheo a ns1:Tabla ;
    rdfs:label "Tabla de variables de latcheo (LATCH1, LATCH2, ACCUDIST)" ;
    ns1:documentadoEn ns1:Pagina_384_387 ;
    ns1:textoExtracto "| V.A.LATCH1.Z | Eje Z. | ... (V.)[ch].A.LATCH2.xn Variable de lectura desde el programa, PLC e interfaz. Variable válida para ejes rotativos y lineales. ... (V.)[ch].A.ACCUDIST.xn Variable de lectura y escritura desde el programa, PLC e interfaz. Variable válida para ejes rotativos, lineales y cabezales." .

ns1:Eje_Canal2_Indice1 a ns1:ComponenteMecanico ;
    rdfs:label "Eje con índice 1 en el canal 2" ;
    ns1:textoExtracto "Eje con índice ꞏ1ꞏ en el canal ꞏ2ꞏ" .

ns1:Eje_Logico_4 a ns1:ComponenteMecanico ;
    rdfs:label "Eje con número lógico 4" ;
    ns1:textoExtracto "Eje con número lógico ꞏ4ꞏ" .

ns1:Eje_Z a ns1:ComponenteMecanico ;
    rdfs:label "Eje Z" ;
    ns1:textoExtracto "Eje Z" .

