@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_SintaxisVariablesLatcheo a ns1:Tabla ;
    rdfs:label "Tabla de sintaxis de variables de latcheo" ;
    ns1:documentadoEn ns1:Pagina_384_387 ;
    ns1:textoExtracto "Sintaxis. ꞏchꞏ Número de canal. ꞏxnꞏ Nombre, número lógico o índice del eje. | V.MPA.ACCUDIST.Z | Eje Z. | | --- | --- | | V.MPA.ACCUDIST.4 | Eje con número lógico ꞏ4ꞏ. | | V.[2].MPA.ACCUDIST.1 | Eje con índice ꞏ1ꞏ en el canal ꞏ2ꞏ." .

ns1:Variable_V_2_MPA_ACCUDIST_1 a ns1:Parametro ;
    rdfs:label "Variable V.[2].MPA.ACCUDIST.1" ;
    ns1:identificador "V.[2].MPA.ACCUDIST.1" ;
    ns1:monitoreaParametro ns1:EjeIndice1_Canal2 ;
    ns1:textoExtracto "| V.[2].MPA.ACCUDIST.1 | Eje con índice '1' en el canal '2'." .

ns1:Variable_V_A_PREVACCUDIST_xn a ns1:Parametro ;
    rdfs:label "Variable (V.)[ch].A.PREVACCUDIST.xn" ;
    ns1:identificador "(V.)[ch].A.PREVACCUDIST.xn" ;
    ns1:textoExtracto "(V.)[ch].A.PREVACCUDIST.xn Variable de lectura y escritura desde el programa, PLC e interfaz. Variable válida para ejes rotativos, lineales y cabezales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Distancia recorrida por el eje o cabezal entre los dos últimos latcheo de cota." .

ns1:Variable_V_MPA_ACCUDIST_4 a ns1:Parametro ;
    rdfs:label "Variable V.MPA.ACCUDIST.4" ;
    ns1:identificador "V.MPA.ACCUDIST.4" ;
    ns1:monitoreaParametro ns1:EjeLogico4 ;
    ns1:textoExtracto "| V.MPA.ACCUDIST.4 | Eje con número lógico '4'." .

ns1:Variable_V_MPA_ACCUDIST_Z a ns1:Parametro ;
    rdfs:label "Variable V.MPA.ACCUDIST.Z" ;
    ns1:identificador "V.MPA.ACCUDIST.Z" ;
    ns1:monitoreaParametro ns1:EjeZ ;
    ns1:textoExtracto "| V.MPA.ACCUDIST.Z | Eje Z." .

ns1:EjeIndice1_Canal2 a ns1:ComponenteMecanico ;
    rdfs:label "Eje con índice 1 en canal 2" ;
    ns1:textoExtracto "Eje con índice '1' en el canal '2'" .

ns1:EjeLogico4 a ns1:ComponenteMecanico ;
    rdfs:label "Eje con número lógico 4" ;
    ns1:textoExtracto "Eje con número lógico '4'" .

ns1:EjeZ a ns1:ComponenteMecanico ;
    rdfs:label "Eje Z" ;
    ns1:textoExtracto "Eje Z" .

