@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:FinalDeCarrera a owl:Class ;
    rdfs:label "Final de carrera"@es .

ex:DetectorProximidad a owl:Class ;
    rdfs:label "Detector de proximidad"@es .

ex:comprobarFuncionamiento a owl:ObjectProperty ;
    rdfs:domain ex:FinalDeCarrera ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Propiedad para comprobar el funcionamiento de un final de carrera"@es .

ex:comprobarFuncionamiento a owl:ObjectProperty ;
    rdfs:domain ex:DetectorProximidad ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Propiedad para comprobar el funcionamiento de un detector de proximidad"@es .

ex:requiereReemplazo a owl:ObjectProperty ;
    rdfs:domain ex:FinalDeCarrera ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Propiedad para indicar si un final de carrera requiere reemplazo"@es .

ex:requiereReemplazo a owl:ObjectProperty ;
    rdfs:domain ex:DetectorProximidad ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Propiedad para indicar si un detector de proximidad requiere reemplazo"@es .