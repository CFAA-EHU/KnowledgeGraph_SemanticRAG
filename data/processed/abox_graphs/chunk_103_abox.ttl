@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:FinalesDeCarrera a ex:Sensor ;
    rdfs:label "finales de carrera" ;
    ex:textoExtracto "Comprobar el funcionamiento correcto de los finales de carrera y de los detectores de proximidad. En caso necesario, reemplazarlos." .

ex:DetectoresDeProximidad a ex:Sensor ;
    rdfs:label "detectores de proximidad" ;
    ex:textoExtracto "Comprobar el funcionamiento correcto de los finales de carrera y de los detectores de proximidad. En caso necesario, reemplazarlos." .