@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DetectorProximidad a ns1:Sensor ;
    rdfs:label "detectores de proximidad"@es ;
    ns1:textoExtracto "Comprobar el funcionamiento correcto de los finales de carrera y de los detectores de proximidad. En caso necesario, reemplazarlos." .

ns1:FinalDeCarrera a ns1:Sensor ;
    rdfs:label "finales de carrera"@es ;
    ns1:textoExtracto "Comprobar el funcionamiento correcto de los finales de carrera y de los detectores de proximidad. En caso necesario, reemplazarlos." .

