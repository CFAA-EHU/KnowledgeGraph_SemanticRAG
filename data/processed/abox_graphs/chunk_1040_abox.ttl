@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ZonasTrabajo_PLC a ns1:Sistema ;
    rdfs:label "Sistema de gestión de zonas de trabajo (PLC)"@es ;
    ns1:controla ns1:ZonaTrabajo_Generica ;
    ns1:textoExtracto "Las zonas de trabajo se pueden definir, habilitar y deshabilitar desde el PLC mediante el comando CNCWR, escribiendo las variables correspondientes."@es ;
    ns1:tieneComponente ns1:Variable_ZONECIRAX1,
        ns1:Variable_ZONELIMITTOL,
        ns1:Variable_ZONELOWLIM,
        ns1:Variable_ZONEST,
        ns1:Variable_ZONEUPLIM .

ns1:AvisoSeguridad_ZonaActiva a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de zona de trabajo activa"@es ;
    ns1:textoExtracto "Zona habilitada como zona de no entrada (1) o zona de no salida (2)."@es .

ns1:Variable_ZONECIRAX1 a ns1:Parametro ;
    rdfs:label "[ch].G.ZONECIRAX1[k]"@es ;
    ns1:identificador "ZONECIRAX1" ;
    ns1:monitoreaParametro ns1:ZonaTrabajo_Generica ;
    ns1:textoExtracto "Eje lógico correspondiente a la primera cota del centro de la zona [k]."@es .

ns1:Variable_ZONELIMITTOL a ns1:Parametro ;
    rdfs:label "[ch].A.ZONELIMITTOL.xn"@es ;
    ns1:identificador "ZONELIMITTOL" ;
    ns1:monitoreaParametro ns1:ZonaTrabajo_Generica ;
    ns1:textoExtracto "Distancia de seguridad de los límites de las zonas de trabajo."@es .

ns1:Variable_ZONELOWLIM a ns1:Parametro ;
    rdfs:label "[ch].A.ZONELOWLIM[k].xn"@es ;
    ns1:identificador "ZONELOWLIM" ;
    ns1:monitoreaParametro ns1:ZonaTrabajo_Generica ;
    ns1:textoExtracto "Límite inferior de la zona [k]."@es .

ns1:Variable_ZONEST a ns1:Parametro ;
    rdfs:label "[ch].G.ZONEST[k]"@es ;
    ns1:identificador "ZONEST" ;
    ns1:monitoreaParametro ns1:ZonaTrabajo_Generica ;
    ns1:textoExtracto "Estado de la zona de trabajo [k]. (0=Zona deshabilitada). (1=Zona habilitada como zona de no entrada). (2=Zona habilitada como zona de no salida)."@es ;
    ns1:valor "0",
        "1",
        "2" .

ns1:Variable_ZONEUPLIM a ns1:Parametro ;
    rdfs:label "[ch].A.ZONEUPLIM[k].xn"@es ;
    ns1:identificador "ZONEUPLIM" ;
    ns1:monitoreaParametro ns1:ZonaTrabajo_Generica ;
    ns1:textoExtracto "Límite superior de la zona [k]."@es .

ns1:ZonaTrabajo_Generica a ns1:ElementoSeguridad ;
    rdfs:label "Zona de trabajo configurable"@es ;
    ns1:controla ns1:AvisoSeguridad_ZonaActiva ;
    ns1:textoExtracto "Zonas de trabajo definidas, habilitadas y deshabilitadas desde el PLC mediante el comando CNCWR."@es .

