@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ZonasTrabajo a ns1:Sistema ;
    rdfs:label "Sistema de parámetros de zonas de trabajo"@es ;
    ns1:textoExtracto "Sintaxis de las variables."@es ;
    ns1:tieneComponente ns1:Parametro_ZONECIR1,
        ns1:Parametro_ZONECIR2,
        ns1:Parametro_ZONECIRAX1,
        ns1:Parametro_ZONECIRAX2,
        ns1:Parametro_ZONER,
        ns1:Parametro_ZONETOOLWATCH .

ns1:Parametro_ZONECIR1 a ns1:Parametro ;
    rdfs:label "Primera cota de centro de zona circular"@es ;
    ns1:identificador "G.ZONECIR1[k]" ;
    ns1:textoExtracto "Cota del centro de la zona [k], según el primer eje que define la zona circular."@es .

ns1:Parametro_ZONECIR2 a ns1:Parametro ;
    rdfs:label "Segunda cota de centro de zona circular"@es ;
    ns1:identificador "G.ZONECIR2[k]" ;
    ns1:textoExtracto "Cota del centro de la zona [k], según el segundo eje que define la zona circular."@es .

ns1:Parametro_ZONECIRAX1 a ns1:Parametro ;
    rdfs:label "Eje lógico de primera cota de zona circular"@es ;
    ns1:identificador "G.ZONECIRAX1[k]" ;
    ns1:textoExtracto "Eje lógico correspondiente a la primera cota del centro de la zona [k]."@es .

ns1:Parametro_ZONECIRAX2 a ns1:Parametro ;
    rdfs:label "Eje lógico de segunda cota de zona circular"@es ;
    ns1:identificador "G.ZONECIRAX2[k]" ;
    ns1:textoExtracto "Eje lógico correspondiente a la segunda cota del centro de la zona [k]."@es .

ns1:Parametro_ZONER a ns1:Parametro ;
    rdfs:label "Radio de zona circular"@es ;
    ns1:identificador "G.ZONER[k]" ;
    ns1:textoExtracto "Radio de la zona [k] (zona circular)."@es .

ns1:Parametro_ZONETOOLWATCH a ns1:Parametro ;
    rdfs:label "Modo de vigilancia de herramienta"@es ;
    ns1:identificador "G.ZONETOOLWATCH[k]" ;
    ns1:textoExtracto "Vigilar la punta o la base de la herramienta. (0=Vigilar la punta de la herramienta). (1=Vigilar la base de la herramienta). (2=Vigilar tanto la punta como la base de la herramienta)."@es ;
    ns1:valor "0",
        "1",
        "2" .

