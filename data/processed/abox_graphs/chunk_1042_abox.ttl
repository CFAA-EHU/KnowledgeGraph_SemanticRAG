@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Herramienta_4.5.1 a ns1:Herramienta ;
    rdfs:label "Herramienta de vigilancia"@es ;
    ns1:textoExtracto "(2=Vigilar tanto la punta como la base de la herramienta)."@es .

ns1:ZonaTrabajo_4.5.1 a ns1:Sistema ;
    rdfs:label "Sistema de zonas de trabajo"@es ;
    ns1:textoExtracto "4.5 Consideraciones a algunas funciones. - 4.5.1 Zonas de trabajo."@es ;
    ns1:tieneComponente ns1:Canal_k,
        ns1:Eje_xn,
        ns1:Zona_k .

ns1:Canal_k a ns1:Componente ;
    rdfs:label "Canal (k)"@es ;
    ns1:identificador "k" ;
    ns1:textoExtracto "ꞏkꞏ Número de canal."@es .

ns1:Eje_xn a ns1:ComponenteMecanico ;
    rdfs:label "Eje (xn)"@es ;
    ns1:identificador "xn" ;
    ns1:textoExtracto "ꞏxnꞏ Nombre, número lógico o índice del eje."@es .

ns1:Zona_k a ns1:Componente ;
    rdfs:label "Zona (k)"@es ;
    ns1:identificador "k" ;
    ns1:textoExtracto "ꞏkꞏ Número de zona."@es .

