@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:AccionProhibida_MovimientoX_0a100mm a ns1:AccionProhibida ;
    rdfs:label "Movimiento prohibido en eje X entre 0 y 100 mm (Zona 1)"@es ;
    ns1:mitigaRiesgo ns1:ZonaTrabajo_1 ;
    ns1:textoExtracto "zona prohibida del eje X la comprendida entre las cotas 0 y 100 mm (1000000 diezmilésimas de milímetro)"@es .

ns1:Parametro_EstadoZona1 a ns1:Parametro ;
    rdfs:label "Estado de activación de Zona 1"@es ;
    ns1:identificador "G.ZONEST[1]" ;
    ns1:textoExtracto "CNCWR(R1, G.ZONEST[1], M1)"@es ;
    ns1:valor 1 .

ns1:Parametro_LimiteInferior_X_Zona1 a ns1:Parametro ;
    rdfs:label "Límite inferior del eje X en Zona 1"@es ;
    ns1:identificador "A.ZONELOWLIM[1].X" ;
    ns1:textoExtracto "CNCWR(R1, A.ZONELOWLIM[1].X, M1)"@es ;
    ns1:valor 0 .

ns1:Parametro_LimiteSuperior_X_Zona1 a ns1:Parametro ;
    rdfs:label "Límite superior del eje X en Zona 1"@es ;
    ns1:identificador "A.ZONEUPLIM[1].X" ;
    ns1:textoExtracto "CNCWR(R1, A.ZONEUPLIM[1].X, M1)"@es ;
    ns1:valor 1000000 .

ns1:ZonaTrabajo_1 a ns1:Sistema ;
    rdfs:label "Zona 1"@es ;
    ns1:compuestoPor ns1:Parametro_EstadoZona1,
        ns1:Parametro_LimiteInferior_X_Zona1,
        ns1:Parametro_LimiteSuperior_X_Zona1 ;
    ns1:identificador "A.ZONEUPLIM[1]",
        "G.ZONEST[1]" ;
    ns1:textoExtracto "Eje con número lógico ꞏ4ꞏ. Zona 1." .

