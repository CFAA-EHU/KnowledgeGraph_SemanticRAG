@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PLC_Recursos_4_6 a ns1:Sistema ;
    rdfs:label "Recursos disponibles en el PLC (Sección 4.6)"@es ;
    ns1:textoExtracto "Recursos disponibles en el PLC. Entradas (I1ꞏꞏI1024) Salidas (O1ꞏꞏO1024) Marcas (M1ꞏꞏM8192) Marcas de mensajes (MSG1ꞏꞏMSG1024) Marcas de errores (ERR1ꞏꞏERR1024) Relojes (CLK) Marcas CNC-PLC Temporizadores (T1ꞏꞏT512) Contadores (C1ꞏꞏC256) Registros (R1ꞏꞏR1024) Registros CNC-PLC"@es ;
    ns1:tieneComponente ns1:PLC_Contadores_C,
        ns1:PLC_Entradas_I,
        ns1:PLC_MarcasErrores_ERR,
        ns1:PLC_MarcasMensajes_MSG,
        ns1:PLC_Marcas_CNC,
        ns1:PLC_Marcas_M,
        ns1:PLC_Registros_CNC,
        ns1:PLC_Registros_R,
        ns1:PLC_Relojes_CLK,
        ns1:PLC_Salidas_O,
        ns1:PLC_Temporizadores_T .

ns1:PLC_Contadores_C a ns1:Parametro ;
    rdfs:label "Contadores del PLC (C1–C256)"@es ;
    ns1:identificador "C1ꞏꞏC256" ;
    ns1:textoExtracto "Contadores (C1ꞏꞏC256)"@es .

ns1:PLC_Entradas_I a ns1:ComponenteElectrico ;
    rdfs:label "Entradas del PLC (I1–I1024)"@es ;
    ns1:identificador "I1ꞏꞏI1024" ;
    ns1:textoExtracto "Entradas (I1ꞏꞏI1024)"@es .

ns1:PLC_MarcasErrores_ERR a ns1:Parametro ;
    rdfs:label "Marcas de errores del PLC (ERR1–ERR1024)"@es ;
    ns1:identificador "ERR1ꞏꞏERR1024" ;
    ns1:textoExtracto "Marcas de errores (ERR1ꞏꞏERR1024)"@es .

ns1:PLC_MarcasMensajes_MSG a ns1:Parametro ;
    rdfs:label "Marcas de mensajes del PLC (MSG1–MSG1024)"@es ;
    ns1:identificador "MSG1ꞏꞏMSG1024" ;
    ns1:textoExtracto "Marcas de mensajes (MSG1ꞏꞏMSG1024)"@es .

ns1:PLC_Marcas_CNC a ns1:Parametro ;
    rdfs:label "Marcas CNC-PLC"@es ;
    ns1:textoExtracto "Marcas CNC-PLC"@es .

ns1:PLC_Marcas_M a ns1:Parametro ;
    rdfs:label "Marcas del PLC (M1–M8192)"@es ;
    ns1:identificador "M1ꞏꞏM8192" ;
    ns1:textoExtracto "Marcas (M1ꞏꞏM8192)"@es .

ns1:PLC_Registros_CNC a ns1:Parametro ;
    rdfs:label "Registros CNC-PLC"@es ;
    ns1:textoExtracto "Registros CNC-PLC"@es .

ns1:PLC_Registros_R a ns1:Parametro ;
    rdfs:label "Registros del PLC (R1–R1024)"@es ;
    ns1:identificador "R1ꞏꞏR1024" ;
    ns1:textoExtracto "Registros (R1ꞏꞏR1024). El valor del registro puede ser tratado como número decimal o hexadecimal ('$'). También se puede hacer referencia a un bit del registro con la letra B (0ꞏꞏ31) R (1ꞏꞏ1024)."@es .

ns1:PLC_Relojes_CLK a ns1:Parametro ;
    rdfs:label "Relojes del PLC (CLK)"@es ;
    ns1:identificador "CLK" ;
    ns1:textoExtracto "Relojes (CLK)"@es .

ns1:PLC_Salidas_O a ns1:ComponenteElectrico ;
