@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Cabezal_Multiple a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal múltiple en comunicación CNC-PLC" ;
    ns1:textoExtracto "Cuando se dispone de varios cabezales, las marcas y registros de estas funciones hacen referencia al número de cabezal."@es ;
    ns1:tieneComponente ns1:Comunicacion_CNC_PLC .

ns1:Canal_Logico a ns1:ComponenteElectrico ;
    rdfs:label "Canal lógico en comunicación CNC-PLC" ;
    ns1:textoExtracto "Cuando se dispone de varios canales, en las marcas y registros de estas funciones habrá que indicar el número de canal al que se refiere."@es ;
    ns1:tieneComponente ns1:Comunicacion_CNC_PLC .

ns1:FuncionesAuxiliares_MHS a ns1:InterfazUsuario,
        ns1:Tabla ;
    rdfs:label "Funciones auxiliares M, H y S en comunicación CNC-PLC" ;
    ns1:documentadoEn ns1:Comunicacion_CNC_PLC ;
    ns1:textoExtracto "La transferencia del CNC al PLC de las funciones auxiliares M, H y S. [...] Funciones –M– y –H– con canales. [...] Funciones –S– con cabezales múltiples."@es .

ns1:Marca_PLC a ns1:Parametro ;
    rdfs:label "Marca del PLC para control lógico" ;
    ns1:monitoreaParametro ns1:Comunicacion_CNC_PLC ;
    ns1:textoExtracto "El control de las entradas y salidas lógicas del CNC mediante un intercambio de información entre ambos sistemas, que se realiza [...] mediante determinadas Marcas y Registros del PLC. [...] (=0) nivel lógico bajo. (=1) nivel lógico alto."@es .

ns1:Registro_PLC a ns1:Parametro ;
    rdfs:label "Registro del PLC para funciones M/H/S" ;
    ns1:monitoreaParametro ns1:Comunicacion_CNC_PLC ;
    ns1:textoExtracto "El intercambio de las funciones M y H se realiza por canal [...] en las marcas y registros de estas funciones."@es .

ns1:Comunicacion_CNC_PLC a ns1:Sistema ;
    rdfs:label "Sistema de comunicación CNC-PLC" ;
    ns1:identificador "5.5" ;
    ns1:textoExtracto "El intercambio de información entre el CNC y el PLC permite: [...] La monitorización en la pantalla del CNC de los recursos del PLC."@es .

