@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:BloqueFuncionesM_788 a ns1:Sistema ;
    rdfs:label "Bloque de funciones M programables"@es ;
    ns1:textoExtracto "Se pueden programar hasta 7 funciones M en un mismo bloque. [...] De esta forma si en un bloque se encuentran programadas las funciones M100, M120 y M135, el CNC pasará al PLC la siguiente información."@es ;
    ns1:tieneComponente ns1:FuncionM100_788,
        ns1:FuncionM120_788,
        ns1:FuncionM135_788,
        ns1:Registro_MFUN1_788,
        ns1:Registro_MFUN2_788,
        ns1:Registro_MFUN3_788,
        ns1:Registro_MFUN4_788,
        ns1:Registro_MFUN5_788,
        ns1:Registro_MFUN6_788,
        ns1:Registro_MFUN7_788 .

ns1:FuncionM100_788 a ns1:AccionProhibida,
        ns1:Tabla ;
    rdfs:label "Función auxiliar M100"@es ;
    ns1:identificador "M100" ;
    ns1:textoExtracto "funciones M programadas en el bloque en ejecución [...] las funciones M100, M120 y M135"@es .

ns1:FuncionM120_788 a ns1:AccionProhibida,
        ns1:Tabla ;
    rdfs:label "Función auxiliar M120"@es ;
    ns1:identificador "M120" ;
    ns1:textoExtracto "funciones M programadas en el bloque en ejecución [...] las funciones M100, M120 y M135"@es .

ns1:FuncionM135_788 a ns1:AccionProhibida,
        ns1:Tabla ;
    rdfs:label "Función auxiliar M135"@es ;
    ns1:identificador "M135" ;
    ns1:textoExtracto "funciones M programadas en el bloque en ejecución [...] las funciones M100, M120 y M135"@es .

ns1:Registro_MFUN1_788 a ns1:ComponenteElectrico ;
    rdfs:label "Registro MFUN1 (32 bits)"@es ;
    ns1:identificador "MFUN1" ;
    ns1:monitoreaParametro ns1:Parametro_NumFuncionM_788 ;
    ns1:textoExtracto "El CNC indica al PLC mediante los registros de 32 bits MFUN1 a MFUN7, las funciones auxiliares M programadas en el bloque en ejecución."@es .

ns1:Registro_MFUN2_788 a ns1:ComponenteElectrico ;
    rdfs:label "Registro MFUN2 (32 bits)"@es ;
    ns1:identificador "MFUN2" ;
    ns1:monitoreaParametro ns1:Parametro_NumFuncionM_788 ;
    ns1:textoExtracto "El CNC indica al PLC mediante los registros de 32 bits MFUN1 a MFUN7, las funciones auxiliares M programadas en el bloque en ejecución."@es .

ns1:Registro_MFUN3_788 a ns1:ComponenteElectrico ;
    rdfs:label "Registro MFUN3 (32 bits)"@es ;
    ns1:identificador "MFUN3" ;
    ns1:monitoreaParametro ns1:Parametro_NumFuncionM_788 ;
    ns1:textoExtracto "El CNC indica al PLC mediante los registros de 32 bits MFUN1 a MFUN7, las funciones auxiliares M programadas en el bloque en ejecución."@es .

ns1:Registro_MFUN4_788 a ns1:ComponenteElectrico ;
    rdfs:label "Registro MFUN4 (32 bits)"@es ;
    ns1:identificador "MFUN4" ;
    ns1:monitoreaParametro ns1:Parametro_NumFuncionM_788 ;
    ns1:textoExtracto "El CNC indica al PLC mediante los registros de 32 bits MFUN1 a MFUN7, las funciones auxiliares M programadas en el bloque en ejecución."@es .

ns1:Registro_MFUN5_788 a ns1:ComponenteElectrico ;
    rdfs:label "Registro MFUN5 (32 bits)"@es ;
    ns1:identificador "MFUN5" ;
    ns1:monitoreaParametro ns1:Parametro_NumFuncionM_788 ;
    ns1:textoExtracto "El CNC indica al PLC mediante los registros de 32 bits MFUN1 a MFUN7, las funciones auxiliares M programadas en el bloque en ejecución."@es .

ns1:Registro_MFUN6_788 a ns1:ComponenteElectrico ;
    rdfs:label "Registro MFUN6 (32 bits)"@es ;
    ns1:identificador "MFUN6" ;
    ns1:monitoreaParametro ns1:Parametro_NumFuncionM_788 ;
    ns1:textoExtracto "El CNC indica al PLC mediante los registros de 32 bits MFUN1 a MFUN7, las funciones auxiliares M programadas en el bloque en ejecución."@es .

ns1:Registro_MFUN7_788 a ns1:ComponenteElectrico ;
    rdfs:label "Registro MFUN7 (32 bits)"@es ;
    ns1:identificador "MFUN7" ;
