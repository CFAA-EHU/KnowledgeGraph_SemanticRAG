    ns1:textoExtracto "El CNC indica al PLC mediante los registros de 32 bits MFUN1 a MFUN7, las funciones auxiliares M programadas en el bloque en ejecución."@es .

ns1:Parametro_NumFuncionM_788 a ns1:Parametro ;
    rdfs:label "Número de función M programada"@es ;
    ns1:textoExtracto "Cada uno de los registros indica el número de una de las funciones M programadas en el bloque."@es ;
    ns1:valor "ffffffff"^^xsd:hexBinary .

