@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:CentralitaDeEngraseManual a owl:Class ;
    rdfs:label "Centralita de Engrase Manual"@es .

ex:AceiteISO3498G220 a owl:Class ;
    rdfs:label "Aceite ISO 3498 G220"@es .

ex:rellenar a owl:ObjectProperty ;
    rdfs:domain ex:CentralitaDeEngraseManual ;
    rdfs:range ex:AceiteISO3498G220 ;
    rdfs:label "rellenar"@es .

ex:tieneTipoDeAceite a owl:DatatypeProperty ;
    rdfs:domain ex:CentralitaDeEngraseManual ;
    rdfs:range xsd:string ;
    rdfs:label "tieneTipoDeAceite"@es .