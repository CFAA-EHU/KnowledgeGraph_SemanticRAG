@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TareaMantenimientoRellenoAceite_104 a ns1:TareaMantenimiento ;
    rdfs:label "Tarea de mantenimiento: rellenar aceite" ;
    ns1:requiereConsumible ns1:CentralitaEngraseManual_104 ;
    ns1:textoExtracto "Rellenar centralita de engrase manual con aceite ISO 3498 G220." .

ns1:CentralitaEngraseManual_104 a ns1:ComponenteMecanico ;
    rdfs:label "centralita de engrase manual" ;
    ns1:identificador "ISO 3498 G220" ;
    ns1:textoExtracto "Rellenar centralita de engrase manual con aceite ISO 3498 G220." .

