@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Bloque_Ejemplo_X100_M11_M12_M13_M14 a ns1:ModoOperacion ;
    rdfs:label "Bloque de ejemplo con funciones M11, M12, M13, M14" ;
    ns1:documentadoEn ns1:Capitulo_5 ;
    ns1:identificador "X100 F1000 M11 M12 M13 M14" ;
    ns1:textoExtracto "Si se ejecuta un bloque del siguiente tipo. X100 F1000 M11 M12 M13 M14. La transferencia de funciones se realiza de la siguiente manera: 1 Se envían las funciones M11, M12 y M13 al PLC. 2 Se espera a que el PLC ejecute la función M12. 3 El CNC desplaza el eje a la cota X100. 4 Se envía la función M14 al PLC." .

ns1:Comando_MFUN a ns1:InterfazUsuario ;
    rdfs:label "Comando MFUN*" ;
    ns1:identificador "MFUN*" ;
    ns1:textoExtracto "Comando MFUN*. Analizar si una función ha sido programada en el bloque. Para poder conocer si una determinada función M se encuentra programada en el bloque en ejecución, se puede utilizar uno de los siguientes métodos: • Analizar todos los registros MFUN uno a uno, hasta encontrar dicha función M o hasta que uno de ellos tenga el valor $FFFFFFFF. • Utilizar el comando MFUN* que permite analizar todos los registros a la vez. Ejemplo para detectar M30. Si se ha programado devolverá un \"1\"; un \"0\" en caso contrario. CPS MFUN* EQ 30 = ..." .

ns1:Funcion_M11 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función auxiliar M11" ;
    ns1:detalladoEnEsquema ns1:Tabla_FuncionesAuxiliares_M ;
    ns1:identificador "M11" ;
    ns1:textoExtracto "M11 sin sincronización." .

ns1:Funcion_M12 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función auxiliar M12" ;
    ns1:detalladoEnEsquema ns1:Tabla_FuncionesAuxiliares_M ;
    ns1:identificador "M12" ;
    ns1:textoExtracto "M12 se envía antes y se sincroniza antes el movimiento." .

ns1:Funcion_M13 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función auxiliar M13" ;
    ns1:detalladoEnEsquema ns1:Tabla_FuncionesAuxiliares_M ;
    ns1:identificador "M13" ;
    ns1:textoExtracto "M13 se envía antes y se sincroniza tras el movimiento." .

ns1:Funcion_M14 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función auxiliar M14" ;
    ns1:detalladoEnEsquema ns1:Tabla_FuncionesAuxiliares_M ;
    ns1:identificador "M14" ;
    ns1:textoExtracto "M14 se envía después y se sincroniza tras el movimiento." .

ns1:Capitulo_5 a ns1:Capitulo ;
    rdfs:label "Capítulo 5: Funciones auxiliares –M–" ;
    ns1:identificador "5" ;
    ns1:textoExtracto "Sección 5.1 Funciones auxiliares –M–" .

ns1:Tabla_FuncionesAuxiliares_M a ns1:Tabla ;
    rdfs:label "Tabla de funciones auxiliares –M–" ;
    ns1:documentadoEn ns1:Capitulo_5 ;
    ns1:textoExtracto "Dentro de los parámetros máquina del CNC, en la tabla de funciones auxiliares –M– se indica cuándo se envía la función y cuándo se sincroniza la ejecución del PLC. En ambos casos podrá ser antes o después del movimiento. Los tipos de envío y sincronización pueden ser los siguientes. M sin sincronización. M antes del movimiento y sincronización antes del movimiento. M antes del movimiento y sincronización tras el movimiento. M tras el movimiento y sincronización tras el movimiento." .

