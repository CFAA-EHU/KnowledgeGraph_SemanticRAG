@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC_Sistema a ns1:Sistema ;
    rdfs:label "CNC" ;
    ns1:monitoreaParametro ns1:CotaX100 ;
    ns1:textoExtracto "El CNC desplaza el eje a la cota X100." .

ns1:PLC_Controlador a ns1:Sistema ;
    rdfs:label "PLC" ;
    ns1:controla ns1:FuncionM11,
        ns1:FuncionM12,
        ns1:FuncionM13,
        ns1:FuncionM14 ;
    ns1:textoExtracto "Se envían las funciones M11, M12 y M13 al PLC. Se espera a que el PLC ejecute la función M12. Se envía la función M14 al PLC. Se espera a que el PLC ejecute las funciones M13 y M14." .

ns1:CotaX100 a ns1:Parametro ;
    rdfs:label "Cota X100" ;
    ns1:identificador "X100" ;
    ns1:textoExtracto "El CNC desplaza el eje a la cota X100." ;
    ns1:valor "100" .

ns1:FuncionM11 a ns1:AccionProhibida,
        ns1:Tabla ;
    rdfs:label "Función M11" ;
    ns1:identificador "M11" ;
    ns1:textoExtracto "Se envían las funciones M11, M12 y M13 al PLC." .

ns1:FuncionM12 a ns1:AccionProhibida,
        ns1:Tabla ;
    rdfs:label "Función M12" ;
    ns1:identificador "M12" ;
    ns1:textoExtracto "Se envían las funciones M11, M12 y M13 al PLC. Se espera a que el PLC ejecute la función M12." .

ns1:FuncionM13 a ns1:AccionProhibida,
        ns1:Tabla ;
    rdfs:label "Función M13" ;
    ns1:identificador "M13" ;
    ns1:textoExtracto "Se envían las funciones M11, M12 y M13 al PLC. Se espera a que el PLC ejecute las funciones M13 y M14." .

ns1:FuncionM14 a ns1:AccionProhibida,
        ns1:Tabla ;
    rdfs:label "Función M14" ;
    ns1:identificador "M14" ;
    ns1:textoExtracto "Se envía la función M14 al PLC. Se espera a que el PLC ejecute las funciones M13 y M14." .

