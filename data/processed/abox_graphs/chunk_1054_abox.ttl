@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC_793 a ns1:Sistema ;
    rdfs:label "Sistema CNC multicabezal" ;
    ns1:controla ns1:PLC_793 ;
    ns1:textoExtracto "El CNC puede disponer de hasta cuatro canales y cada canal puede ejecutar un programa pieza en paralelo con los demás." ;
    ns1:tieneComponente ns1:CanalC1_793,
        ns1:CanalC2_793,
        ns1:CanalC3_793,
        ns1:CanalC4_793 .

ns1:CanalC1_793 a ns1:Componente ;
    rdfs:label "Canal 1 (C1)" ;
    ns1:textoExtracto "MFUN1C1 - MFUN7C1 para el primer canal." ;
    ns1:tieneComponente ns1:Registro_MFUN1C1_793,
        ns1:Registro_MFUN2C1_793,
        ns1:Registro_MFUN3C1_793,
        ns1:Registro_MFUN4C1_793,
        ns1:Registro_MFUN5C1_793,
        ns1:Registro_MFUN6C1_793,
        ns1:Registro_MFUN7C1_793 .

ns1:CanalC2_793 a ns1:Componente ;
    rdfs:label "Canal 2 (C2)" ;
    ns1:textoExtracto "MFUN1C2 - MFUN7C2 para el segundo canal." ;
    ns1:tieneComponente ns1:Registro_MFUN1C2_793,
        ns1:Registro_MFUN2C2_793,
        ns1:Registro_MFUN3C2_793,
        ns1:Registro_MFUN4C2_793,
        ns1:Registro_MFUN5C2_793,
        ns1:Registro_MFUN6C2_793,
        ns1:Registro_MFUN7C2_793 .

ns1:CanalC3_793 a ns1:Componente ;
    rdfs:label "Canal 3 (C3)" ;
    ns1:textoExtracto "MFUN1C3 - MFUN7C3 para el tercer canal." .

ns1:CanalC4_793 a ns1:Componente ;
    rdfs:label "Canal 4 (C4)" ;
    ns1:textoExtracto "MFUN1C4 - MFUN7C4 para el cuarto canal." .

ns1:PLC_793 a ns1:ComponenteElectrico ;
    rdfs:label "PLC (Controlador Lógico Programable)" ;
    ns1:textoExtracto "el CNC enviará al PLC las funciones M en dos fases." .

ns1:Registro_MFUN1C1_793 a ns1:Parametro ;
    rdfs:label "Registro MFUN1C1" ;
    ns1:identificador "MFUN1C1" ;
    ns1:textoExtracto "| MFUN1C1 | MFUN2C1 | MFUN3C1 - MFUN7C1 | --- | --- | --- | 100 | 135 | $FFFFFFFF" ;
    ns1:valor "100" .

ns1:Registro_MFUN2C1_793 a ns1:Parametro ;
    rdfs:label "Registro MFUN2C1" ;
    ns1:identificador "MFUN2C1" ;
    ns1:textoExtracto "| MFUN1C1 | MFUN2C1 | MFUN3C1 - MFUN7C1 | --- | --- | --- | 100 | 135 | $FFFFFFFF" ;
    ns1:valor "135" .

ns1:Registro_MFUN3C1_793 a ns1:Parametro ;
    rdfs:label "Registro MFUN3C1" ;
    ns1:identificador "MFUN3C1" ;
    ns1:textoExtracto "el CNC asigna el valor hexadecimal $FFFFFFFF a los que queden libres, los de numeración más alta." ;
    ns1:valor "$FFFFFFFF" .

ns1:Registro_MFUN4C1_793 a ns1:Parametro ;
    rdfs:label "Registro MFUN4C1" ;
    ns1:identificador "MFUN4C1" ;
    ns1:textoExtracto "el CNC asigna el valor hexadecimal $FFFFFFFF a los que queden libres, los de numeración más alta." ;
    ns1:valor "$FFFFFFFF" .

ns1:Registro_MFUN5C1_793 a ns1:Parametro ;
    rdfs:label "Registro MFUN5C1" ;
    ns1:identificador "MFUN5C1" ;
    ns1:textoExtracto "el CNC asigna el valor hexadecimal $FFFFFFFF a los que queden libres, los de numeración más alta." ;
    ns1:valor "$FFFFFFFF" .

ns1:Registro_MFUN6C1_793 a ns1:Parametro ;
    rdfs:label "Registro MFUN6C1" ;
    ns1:identificador "MFUN6C1" ;
    ns1:textoExtracto "el CNC asigna el valor hexadecimal $FFFFFFFF a los que queden libres, los de numeración más alta." ;
    ns1:valor "$FFFFFFFF" .

ns1:Registro_MFUN7C1_793 a ns1:Parametro ;
    rdfs:label "Registro MFUN7C1" ;
    ns1:identificador "MFUN7C1" ;
    ns1:textoExtracto "el CNC asigna el valor hexadecimal $FFFFFFFF a los que queden libres, los de numeración más alta." ;
    ns1:valor "$FFFFFFFF" .

