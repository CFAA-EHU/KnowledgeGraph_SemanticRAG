@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Ejemplo_DeteccionM04 a ns1:InterfazUsuario ;
    rdfs:label "Ejemplo de detección de función M04 en canal 1"@es ;
    ns1:ilustradoEn ns1:Sistema_Multicabezal ;
    ns1:textoExtracto "Ejemplo para detectar M04 en el canal 1. Si se ha programado devolverá un \"1\"; un \"0\" en caso contrario. CPS MFUNC1* EQ 4 = ..."@es .

ns1:Parametro_MFUNC1 a ns1:Parametro ;
    rdfs:label "Comando MFUNC1*"@es ;
    ns1:documentadoEn ns1:Tabla_MFUNC_Canal1 ;
    ns1:textoExtracto "MFUNC1* Para el canal 1"@es ;
    ns1:valor "MFUNC1*" .

ns1:Parametro_MFUNC2 a ns1:Parametro ;
    rdfs:label "Comando MFUNC2*"@es ;
    ns1:documentadoEn ns1:Tabla_MFUNC_Canal2 ;
    ns1:textoExtracto "MFUNC2* Para el canal 2"@es ;
    ns1:valor "MFUNC2*" .

ns1:Parametro_MFUNC3 a ns1:Parametro ;
    rdfs:label "Comando MFUNC3*"@es ;
    ns1:textoExtracto "MFUNC3* Para el canal 3"@es ;
    ns1:valor "MFUNC3*" .

ns1:Parametro_MFUNC4 a ns1:Parametro ;
    rdfs:label "Comando MFUNC4*"@es ;
    ns1:textoExtracto "MFUNC4* Para el canal 4"@es ;
    ns1:valor "MFUNC4*" .

ns1:Parametro_ValorTerminador a ns1:Parametro ;
    rdfs:label "Valor terminador de registros MFUN"@es ;
    ns1:documentadoEn ns1:Tabla_MFUNC_Canal1,
        ns1:Tabla_MFUNC_Canal2 ;
    ns1:textoExtracto "valor $FFFFFFFF"@es ;
    ns1:valor "$FFFFFFFF" .

ns1:Sistema_Multicabezal a ns1:Sistema ;
    rdfs:label "Sistema multicabezal con análisis de funciones por canal"@es ;
    ns1:documentadoEn ns1:Tabla_MFUNC_Canal1,
        ns1:Tabla_MFUNC_Canal2 ;
    ns1:textoExtracto "Particularidades con la opción multicabezal y canales. Comandos MFUNC1* - MFUNC4*. Analizar si una función ha sido programada en el canal."@es ;
    ns1:tieneComponente ns1:Parametro_MFUNC1,
        ns1:Parametro_MFUNC2,
        ns1:Parametro_MFUNC3,
        ns1:Parametro_MFUNC4,
        ns1:Parametro_ValorTerminador .

ns1:Tabla_MFUNC_Canal1 a ns1:Tabla ;
    rdfs:label "Tabla de registros MFUN para Canal 1"@es ;
    ns1:identificador "MFUN*C1" ;
    ns1:textoExtracto """
| MFUN1C1 | MFUN2C1 | MFUN3C1 - MFUN7C1 |
| --- | --- | --- |
| 100 | 135 | $FFFFFFFF
"""@es .

ns1:Tabla_MFUNC_Canal2 a ns1:Tabla ;
    rdfs:label "Tabla de registros MFUN para Canal 2"@es ;
    ns1:identificador "MFUN*C2" ;
    ns1:textoExtracto """
| MFUN1C2 | MFUN2C2 | MFUN3C2 - MFUN7C2 |
| --- | --- | --- |
| 88 | 75 | $FFFFFFFF
"""@es .

