@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Pagina_5.4_TransferenciaFuncionesAuxiliares a ns1:Pagina ;
    rdfs:label "Página 400: 5.4 Transferencia de las funciones auxiliares –M–, –H–, –S–" ;
    ns1:identificador "400" ;
    ns1:textoExtracto "Ver en la página '5.4 Transferencia de las funciones auxiliares –M–, –H–, –S–.' 400." .

ns1:SistemaTransferenciaFuncionesH a ns1:Sistema ;
    rdfs:label "Sistema de transferencia de funciones auxiliares H" ;
    ns1:controla ns1:FuncionH11,
        ns1:FuncionH12,
        ns1:FuncionH20,
        ns1:FuncionH35,
        ns1:FuncionH77 ;
    ns1:textoExtracto "Las funciones H no tienen sincronización y se envían al PLC al comienzo de la ejecución del bloque. La transferencia de las funciones auxiliares H está detallada más adelante en este mismo capítulo." ;
    ns1:tieneComponente ns1:RegistroHFUN1,
        ns1:RegistroHFUN2,
        ns1:RegistroHFUN3,
        ns1:RegistroHFUN4,
        ns1:RegistroHFUN5,
        ns1:RegistroHFUN6,
        ns1:RegistroHFUN7 .

ns1:FuncionH11 a ns1:AccionProhibida,
        ns1:Tabla ;
    rdfs:label "Función auxiliar H11" ;
    ns1:textoExtracto "Si se ejecuta un bloque del siguiente tipo. X100 F1000 H11 H12. La transferencia de funciones se realiza de la siguiente manera. 1 Se envían las funciones H11, H12 al PLC." .

ns1:FuncionH12 a ns1:AccionProhibida,
        ns1:Tabla ;
    rdfs:label "Función auxiliar H12" ;
    ns1:ilustradoEn ns1:RegistroHFUN1 ;
    ns1:textoExtracto "Si en un bloque se encuentran programadas las funciones H12, H20 y H35, el CNC pasará al PLC la siguiente información." .

ns1:FuncionH20 a ns1:AccionProhibida,
        ns1:Tabla ;
    rdfs:label "Función auxiliar H20" ;
    ns1:ilustradoEn ns1:RegistroHFUN2 ;
    ns1:textoExtracto "Si en un bloque se encuentran programadas las funciones H12, H20 y H35, el CNC pasará al PLC la siguiente información." .

ns1:FuncionH35 a ns1:AccionProhibida,
        ns1:Tabla ;
    rdfs:label "Función auxiliar H35" ;
    ns1:ilustradoEn ns1:RegistroHFUN3 ;
    ns1:textoExtracto "Si en un bloque se encuentran programadas las funciones H12, H20 y H35, el CNC pasará al PLC la siguiente información." .

ns1:FuncionH77 a ns1:AccionProhibida,
        ns1:Tabla ;
    rdfs:label "Función auxiliar H77" ;
    ns1:textoExtracto "Ejemplo para detectar H77. Si se ha programado devolverá un '1'; un '0' en caso contrario. CPS HFUN* EQ 77 = ..." .

ns1:RegistroHFUN4 a ns1:ComponenteElectrico ;
    rdfs:label "Registro HFUN4 (32 bits)" ;
    ns1:textoExtracto "Si no se utilizan todos los registros, el CNC asigna el valor $FFFFFFFF a los que queden libres, los de numeración más alta." ;
    ns1:valor "$FFFFFFFF"^^xsd:string .

ns1:RegistroHFUN5 a ns1:ComponenteElectrico ;
    rdfs:label "Registro HFUN5 (32 bits)" ;
    ns1:textoExtracto "Si no se utilizan todos los registros, el CNC asigna el valor $FFFFFFFF a los que queden libres, los de numeración más alta." ;
    ns1:valor "$FFFFFFFF"^^xsd:string .

ns1:RegistroHFUN6 a ns1:ComponenteElectrico ;
    rdfs:label "Registro HFUN6 (32 bits)" ;
    ns1:textoExtracto "Si no se utilizan todos los registros, el CNC asigna el valor $FFFFFFFF a los que queden libres, los de numeración más alta." ;
    ns1:valor "$FFFFFFFF"^^xsd:string .

ns1:RegistroHFUN7 a ns1:ComponenteElectrico ;
    rdfs:label "Registro HFUN7 (32 bits)" ;
    ns1:textoExtracto "Si no se utilizan todos los registros, el CNC asigna el valor $FFFFFFFF a los que queden libres, los de numeración más alta." ;
    ns1:valor "$FFFFFFFF"^^xsd:string .

ns1:RegistroHFUN1 a ns1:ComponenteElectrico ;
    rdfs:label "Registro HFUN1 (32 bits)" ;
    ns1:textoExtracto "El CNC indica al PLC mediante los registros de 32 bits HFUN1 a HFUN7, las funciones auxiliares H programadas en el bloque en ejecución." ;
    ns1:valor "12"^^xsd:string .

ns1:RegistroHFUN2 a ns1:ComponenteElectrico ;
    rdfs:label "Registro HFUN2 (32 bits)" ;
    ns1:textoExtracto "Cada uno de los registros indica el número de una de las funciones H programadas en el bloque." ;
    ns1:valor "20"^^xsd:string .

ns1:RegistroHFUN3 a ns1:ComponenteElectrico ;
    rdfs:label "Registro HFUN3 (32 bits)" ;
    ns1:textoExtracto "Si en un bloque se encuentran programadas las funciones H12, H20 y H35, el CNC pasará al PLC la siguiente información." ;
    ns1:valor "35"^^xsd:string .

