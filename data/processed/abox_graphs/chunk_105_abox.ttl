@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:CentralDeEngraseAutomatico a owl:Class ;
    rdfs:label "Central de engrase automático" .

ex:CartuchoDeGrasa a owl:Class ;
    rdfs:label "Cartucho de grasa" .

ex:LUE400051 a ex:CartuchoDeGrasa ;
    rdfs:label "LUE+400-05-1" .

ex:cambiarCartuchoFiltro a owl:ObjectProperty ;
    rdfs:domain ex:CentralDeEngraseAutomatico ;
    rdfs:range ex:CartuchoDeGrasa .

ex:CentralDeEngraseAutomatico ex:cambiarCartuchoFiltro ex:LUE400051 .