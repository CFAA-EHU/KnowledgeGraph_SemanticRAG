@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Cabezal1 a ns1:Componente ;
    rdfs:label "Cabezal 1" ;
    ns1:monitoreaParametro ns1:FuncionM5,
        ns1:SP1FUN ;
    ns1:textoExtracto "SP1FUN* Para el cabezal 1. Comprueba si se ha enviado al cabezal 1 la función M5 desde algún canal." .

ns1:Cabezal2 a ns1:Componente ;
    rdfs:label "Cabezal 2" ;
    ns1:monitoreaParametro ns1:SP2FUN ;
    ns1:textoExtracto "SP2FUN* Para el cabezal 2." .

ns1:Cabezal3 a ns1:Componente ;
    rdfs:label "Cabezal 3" ;
    ns1:monitoreaParametro ns1:SP3FUN ;
    ns1:textoExtracto "SP3FUN* Para el cabezal 3." .

ns1:Cabezal4 a ns1:Componente ;
    rdfs:label "Cabezal 4" ;
    ns1:monitoreaParametro ns1:SP4FUN ;
    ns1:textoExtracto "SP4FUN* Para el cabezal 4." .

ns1:FuncionM5 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función M5" ;
    ns1:identificador "M5" ;
    ns1:textoExtracto "Comprueba si se ha enviado al cabezal 1 la función M5 desde algún canal." .

ns1:SP1FUN a ns1:Parametro ;
    rdfs:label "SP1FUN*" ;
    ns1:identificador "SP1FUN*" ;
    ns1:textoExtracto "SP1FUN* Para el cabezal 1." .

ns1:SP2FUN a ns1:Parametro ;
    rdfs:label "SP2FUN*" ;
    ns1:identificador "SP2FUN*" ;
    ns1:textoExtracto "SP2FUN* Para el cabezal 2." .

ns1:SP3FUN a ns1:Parametro ;
    rdfs:label "SP3FUN*" ;
    ns1:identificador "SP3FUN*" ;
    ns1:textoExtracto "SP3FUN* Para el cabezal 3." .

ns1:SP4FUN a ns1:Parametro ;
    rdfs:label "SP4FUN*" ;
    ns1:identificador "SP4FUN*" ;
    ns1:textoExtracto "SP4FUN* Para el cabezal 4." .

