@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_TransferenciaFuncionesAuxiliares a ns1:Sistema ;
    rdfs:label "Sistema de transferencia de funciones auxiliares (M, H, S)"@es ;
    ns1:textoExtracto "Transferencia de las funciones auxiliares –M–, –H–, –S–."@es ;
    ns1:tieneComponente ns1:EntradaLogica_AUXEND,
        ns1:SalidaLogica_SSTROBE .

ns1:EntradaLogica_AUXEND a ns1:ComponenteElectrico ;
    rdfs:label "Entrada general AUXEND"@es ;
    ns1:textoExtracto "El CNC espera la activación de la entrada general AUXEND, indicativo de fin de ejecución del PLC."@es .

ns1:SalidaLogica_SSTROBE a ns1:ComponenteElectrico ;
    rdfs:label "Salida lógica general SSTROBE"@es ;
    ns1:textoExtracto "El CNC activa la salida lógica general SSTROBE para indicar al PLC que debe ejecutarla. [...] desactiva la salida lógica general SSTROBE para dar por finalizada su ejecución."@es .

