@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TransferenciaSincronizada_5_4_1 a ns1:ModoOperacion ;
    rdfs:label "Transferencia sincronizada (S y M)"@es ;
    ns1:textoExtracto "Este tipo de transferencia se efectúa con la función S y con las funciones M personalizadas con sincronización."@es ;
    ns1:tieneComponente ns1:FuncionM_5_4_1,
        ns1:FuncionS_5_4_1,
        ns1:Parametro_MINAENDW,
        ns1:Senal_AUXEND,
        ns1:Senal_MSTROBE,
        ns1:Senal_SSTROBE .

ns1:FuncionM_5_4_1 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función M (MSTROBE)"@es ;
    ns1:identificador "MFUN1-MFUN7" ;
    ns1:monitoreaParametro ns1:Senal_MSTROBE ;
    ns1:textoExtracto "El CNC indica en los registros MFUN1 a MFUN7 del canal las funciones M programadas en el bloque y activa la marca MSTROBE para que el PLC las ejecute."@es .

ns1:FuncionS_5_4_1 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función S (SSTROBE)"@es ;
    ns1:identificador "SFUN1-SFUN4" ;
    ns1:monitoreaParametro ns1:Senal_SSTROBE ;
    ns1:textoExtracto "El CNC indica en los registros SFUN1 a SFUN4 el valor de la S programada en el bloque y activa la marca SSTROBE para que el PLC las ejecute."@es .

ns1:Senal_AUXEND a ns1:Sensor ;
    rdfs:label "Señal AUXEND"@es ;
    ns1:monitoreaParametro ns1:Parametro_MINAENDW ;
    ns1:textoExtracto "El PLC debe desactivar la marca AUXEND para indicar al CNC que comienza la ejecución [...] Una vez ejecutadas las funciones auxiliares requeridas, el PLC debe activar la marca AUXEND para indicar al CNC que ha finalizado."@es .

ns1:Parametro_MINAENDW a ns1:Parametro ;
    rdfs:label "Tiempo mínimo de AUXEND (MINAENDW)"@es ;
    ns1:identificador "MINAENDW" ;
    ns1:textoExtracto "La marca AUXEND debe mantenerse a (=1) un tiempo superior al definido en el parámetro MINAENDW."@es ;
    ns1:valor "Tiempo de espera para confirmación"@es .

ns1:Senal_MSTROBE a ns1:Sensor ;
    rdfs:label "Señal MSTROBE"@es ;
    ns1:textoExtracto "activa la marca MSTROBE para que el PLC las ejecute [...] Transcurrido dicho tiempo, el CNC desactiva la marca MSTROBE dando por finalizada la ejecución."@es .

ns1:Senal_SSTROBE a ns1:Sensor ;
    rdfs:label "Señal SSTROBE"@es ;
    ns1:textoExtracto "activa la marca SSTROBE para que el PLC las ejecute [...] Transcurrido dicho tiempo, el CNC desactiva la marca SSTROBE dando por finalizada la ejecución."@es .

