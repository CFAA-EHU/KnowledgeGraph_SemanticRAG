@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_PRGFREQ a ns1:Parametro ;
    rdfs:label "PRGFREQ" ;
    ns1:identificador "PRGFREQ" ;
    ns1:textoExtracto "periodicidad con que se ejecuta el programa de PLC, parámetro PRGFREQ"@es ;
    ns1:valor "Frecuencia de ejecución del programa PLC"@es .

ns1:Sistema_TransferenciaNoSincronizada a ns1:Sistema ;
    rdfs:label "Transferencia no sincronizada (funciones H/M)"@es ;
    ns1:controla ns1:Canal_CNC ;
    ns1:textoExtracto "Este tipo de transferencia se efectúa con la función H y las funciones M personalizadas sin sincronización"@es ;
    ns1:tieneComponente ns1:FuncionH,
        ns1:FuncionM,
        ns1:Marca_HSTROBE,
        ns1:Marca_MSTROBE .

ns1:Canal_CNC a ns1:InterfazUsuario ;
    rdfs:label "Canal CNC"@es ;
    ns1:textoExtracto "registros [...] del canal"@es ;
    ns1:tieneComponente ns1:Registro_HFUN1a7,
        ns1:Registro_MFUN1a7 .

ns1:FuncionH a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función H"@es ;
    ns1:monitoreaParametro ns1:Parametro_MINAENDW ;
    ns1:textoExtracto "funciones H programadas en el bloque"@es .

ns1:FuncionM a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función M personalizada"@es ;
    ns1:monitoreaParametro ns1:Parametro_MINAENDW ;
    ns1:textoExtracto "funciones M programadas en el bloque"@es .

ns1:Marca_HSTROBE a ns1:Sensor ;
    rdfs:label "HSTROBE" ;
    ns1:identificador "HSTROBE" ;
    ns1:monitoreaParametro ns1:Parametro_MINAENDW ;
    ns1:textoExtracto "activa la marca HSTROBE para que el PLC las ejecute"@es .

ns1:Marca_MSTROBE a ns1:Sensor ;
    rdfs:label "MSTROBE" ;
    ns1:identificador "MSTROBE" ;
    ns1:monitoreaParametro ns1:Parametro_MINAENDW ;
    ns1:textoExtracto "activa la marca MSTROBE para que el PLC las ejecute"@es .

ns1:Registro_HFUN1a7 a ns1:ComponenteElectrico ;
    rdfs:label "Registros HFUN1 a HFUN7"@es ;
    ns1:textoExtracto "registros HFUN1 a HFUN7 del canal las funciones H programadas"@es .

ns1:Registro_MFUN1a7 a ns1:ComponenteElectrico ;
    rdfs:label "Registros MFUN1 a MFUN7"@es ;
    ns1:textoExtracto "registros MFUN1 a MFUN7 del canal las funciones M programadas"@es .

ns1:Parametro_MINAENDW a ns1:Parametro ;
    rdfs:label "MINAENDW" ;
    ns1:identificador "MINAENDW" ;
    ns1:textoExtracto "tiempo indicado en el parámetro MINAENDW"@es ;
    ns1:valor "Tiempo de activación de marcas HSTROBE/MSTROBE"@es .

