@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_VisualizacionErroresPLC a ns1:Sistema ;
    rdfs:label "Sistema de visualización de errores y mensajes del PLC"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_MensajesYErroresPLC ;
    ns1:ilustradoEn ns1:InterfazUsuario_VentanaMensajesPLC ;
    ns1:textoExtracto "El PLC dispone de 1024 marcas para visualización de mensajes y 1024 marcas para visualizar errores en el CNC. Cuando la marca está a (=1) el mensaje o error está activo. MSG1 - MSG1024 para visualizar mensajes. ERR1 - ERR1024 para visualizar errores."@es ;
    ns1:tieneComponente ns1:ComponenteElectrico_ReleEmergencia .

ns1:ComponenteElectrico_ReleEmergencia a ns1:ComponenteElectrico ;
    rdfs:label "Relé de emergencia de la unidad central"@es ;
    ns1:textoExtracto "En el caso de los errores, si estos abren o no el relé de emergencia de la unidad central."@es .

ns1:InterfazUsuario_VentanaMensajesPLC a ns1:InterfazUsuario ;
    rdfs:label "Ventana de mensajes del PLC"@es ;
    ns1:textoExtracto "Al activarse una de las marcas MSG, el CNC muestra en la ventana de mensajes del PLC, dentro de la barra de estado, el número de mensaje y su texto asociado. [...] Para ver la lista completa, pulsar las teclas [...] Para cerrar la ventana de"@es .

ns1:ManualOperacionPLC a ns1:Manual ;
    rdfs:label "Manual de operación del PLC"@es ;
    ns1:textoExtracto "Para más información sobre cómo editar esta tabla consultar el manual de operación."@es .

ns1:Tabla_MensajesYErroresPLC a ns1:Tabla ;
    rdfs:label "Tabla de mensajes y errores del PLC"@es ;
    ns1:documentadoEn ns1:ManualOperacionPLC ;
    ns1:textoExtracto "En el PLC hay una tabla de mensajes y errores en la que se puede asociar a cada mensaje o error lo siguiente: • Un número (campo ID). • Un texto (campo \"Mensaje\"). • Un archivo de información adicional (campo \"Archivo asociado\"), que podrá ser un fichero del tipo bmp, txt, jpg, gif, htm, html ó avi. • Si al activarse un error o mensaje, se debe mostrar directamente el fichero de ayuda adicional (campo \"Mostrar\" seleccionado) o sólo el texto del mensaje o error. • En el caso de los errores, si estos abren o no el relé de emergencia de la unidad central."@es .

