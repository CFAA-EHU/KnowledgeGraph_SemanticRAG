@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteElectrico_ReleEmergencia a ns1:ComponenteElectrico ;
    rdfs:label "Relé de emergencia"@es ;
    ns1:controla ns1:AvisoSeguridad_ReleEmergenciaCNC ;
    ns1:textoExtracto "el error abrirá el relé de emergencia del CNC"@es .

ns1:Parametro_CampoEmergen a ns1:Parametro ;
    rdfs:label "Campo 'Emergen' en configuración de errores"@es ;
    ns1:monitoreaParametro ns1:Alarma_ErrorPLC ;
    ns1:textoExtracto "Si el error tiene seleccionado el campo \"Emergen\", el error abrirá el relé de emergencia del CNC."@es .

ns1:Parametro_CampoMostrar a ns1:Parametro ;
    rdfs:label "Campo 'Mostrar' en configuración de errores"@es ;
    ns1:monitoreaParametro ns1:Alarma_ErrorPLC ;
    ns1:textoExtracto "Si el error tiene asociado un fichero de información adicional, se mostrará un icono de acceso a la derecha del número de error. Si el error tiene seleccionado el campo \"Mostrar\", el CNC muestra directamente en la pantalla el archivo de información adicional."@es .

ns1:Sistema_GestionArchivosAyuda a ns1:Sistema ;
    rdfs:label "Sistema de gestión de archivos de ayuda para errores de PLC"@es ;
    ns1:documentadoEn ns1:InterfazUsuario_VisualizacionErroresPLC ;
    ns1:textoExtracto "Los mensajes y errores de PLC pueden mostrar un archivo de información adicional en formato texto. El PLC permite agrupar varios o todos estos archivos en un sólo archivo."@es .

ns1:Alarma_ErrorPLC a ns1:Alarma ;
    rdfs:label "Alarma por error de PLC"@es ;
    ns1:activaAlarma ns1:InterfazUsuario_VisualizacionErroresPLC ;
    ns1:mitigaRiesgo ns1:AvisoSeguridad_ReleEmergenciaCNC ;
    ns1:textoExtracto "Al activarse una de las marcas ERR se detiene la ejecución del programa pieza y se muestra en el centro de la pantalla una ventana con el número de error y su texto asociado."@es .

ns1:AvisoSeguridad_ReleEmergenciaCNC a ns1:AvisoSeguridad ;
    rdfs:label "Relé de emergencia del CNC"@es ;
    ns1:textoExtracto "Si el error tiene seleccionado el campo \"Emergen\", el error abrirá el relé de emergencia del CNC."@es .

ns1:InterfazUsuario_VisualizacionErroresPLC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de visualización de errores y mensajes del PLC"@es ;
    ns1:textoExtracto "Al activarse una de las marcas ERR se detiene la ejecución del programa pieza y se muestra en el centro de la pantalla una ventana con el número de error y su texto asociado."@es .

