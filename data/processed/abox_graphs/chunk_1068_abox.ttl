@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MensajeError_10 a ns1:AvisoSeguridad ;
    rdfs:label "Mensaje de ayuda 10" ;
    ns1:documentadoEn ns1:ArchivoOEM_TXT ;
    ns1:identificador "10" ;
    ns1:textoExtracto "[10] Texto de ayuda." .

ns1:MensajeError_27 a ns1:AvisoSeguridad ;
    rdfs:label "Mensaje de ayuda 27" ;
    ns1:documentadoEn ns1:ArchivoOEM_TXT ;
    ns1:identificador "27" ;
    ns1:textoExtracto "[27] Texto de ayuda." .

ns1:MensajeError_33 a ns1:AvisoSeguridad ;
    rdfs:label "Mensaje de ayuda 33" ;
    ns1:documentadoEn ns1:ArchivoOEM_TXT ;
    ns1:identificador "33" ;
    ns1:textoExtracto "[33] Texto de ayuda." .

ns1:RutaAsociacionMensajes a ns1:InterfazUsuario ;
    rdfs:label "Sistema de asociación de mensajes de ayuda" ;
    ns1:identificador "C:\\FAGORCNC\\MTB\\PLC\\LANG\\OEM.txt" ;
    ns1:textoExtracto "Para asociar el mensaje de ayuda a un mensaje o error de PLC, el campo 'Archivo asociado' hay que definirlo de la forma <archivo>#<id>. Por ejemplo, el campo 'Archivo asociado' estará definido de la forma: C:\\FAGORCNC\\MTB\\PLC\\LANG\\OEM.txt#27" .

ns1:ArchivoOEM_TXT a ns1:InterfazUsuario ;
    rdfs:label "OEM.txt" ;
    ns1:identificador "OEM.txt" ;
    ns1:textoExtracto "El fichero OEM.txt tendrá la siguiente estructura. [10] Texto de ayuda. [27] Texto de ayuda. [33] Texto de ayuda." .

