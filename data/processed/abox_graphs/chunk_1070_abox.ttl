@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:SistemaEntradasSalidasCNC a ns1:Sistema ;
    rdfs:label "Sistema de entradas y salidas físicas del CNC"@es ;
    ns1:controla ns1:Se_al_ALARM,
        ns1:Se_al_AUXEND,
        ns1:Se_al_CNCREADY,
        ns1:Se_al_EMERGEN,
        ns1:Se_al_MANUAL,
        ns1:Se_al_STOP ;
    ns1:textoExtracto "Se denominan entradas y salidas físicas del CNC al conjunto de entradas y salidas del sistema que, siendo gobernadas por el PLC, se comunican con el exterior a través de los conectores del CNC."@es ;
    ns1:tieneComponente ns1:ConectoresCNC,
        ns1:EntradasLogicasCNC,
        ns1:SalidasLogicasCNC .

ns1:ConectoresCNC a ns1:ComponenteElectrico ;
    rdfs:label "Conectores del CNC"@es ;
    ns1:textoExtracto "se comunican con el exterior a través de los conectores del CNC"@es .

ns1:EntradasLogicasCNC a ns1:InterfazUsuario ;
    rdfs:label "Entradas lógicas del CNC (modificables por PLC)"@es ;
    ns1:textoExtracto "El CNC dispone además de una serie de entradas y salidas lógicas para el intercambio de información interna con las marcas y registros del PLC. [...] Las entradas lógicas del CNC o señales modificables por PLC se agrupan en: Señales modificables generales, de los ejes, de los cabezales, del interpolador independiente, del gestor de herramientas, del laser y de las teclas."@es .

ns1:SalidasLogicasCNC a ns1:InterfazUsuario ;
    rdfs:label "Salidas lógicas del CNC (señales de consulta del PLC)"@es ;
    ns1:textoExtracto "Las salidas lógicas del CNC o señales de consulta del PLC se agrupan en: Señales de consulta generales, de los ejes, de los cabezales, del interpolador independiente, del gestor de herramientas, del laser y de las teclas."@es .

ns1:Se_al_ALARM a ns1:Alarma ;
    rdfs:label "_ALARM" ;
    ns1:identificador "_ALARM" ;
    ns1:textoExtracto "_ALARM [...] Los mnemónicos que comienzan por el carácter '_' indican que la señal es activa a nivel lógico bajo (0 V.)"@es ;
    ns1:valor "0"^^xsd:string .

ns1:Se_al_AUXEND a ns1:AvisoSeguridad ;
    rdfs:label "AUXEND" ;
    ns1:identificador "AUXEND" ;
    ns1:textoExtracto "AUXEND" .

ns1:Se_al_CNCREADY a ns1:AvisoSeguridad ;
    rdfs:label "CNCREADY" ;
    ns1:identificador "CNCREADY" ;
    ns1:textoExtracto "CNCREADY" ;
    ns1:valor "1"^^xsd:string .

ns1:Se_al_EMERGEN a ns1:Alarma ;
    rdfs:label "_EMERGEN" ;
    ns1:identificador "_EMERGEN" ;
    ns1:textoExtracto "_EMERGEN"@es ;
    ns1:valor "0"^^xsd:string .

ns1:Se_al_MANUAL a ns1:ModoOperacion ;
    rdfs:label "MANUAL" ;
    ns1:identificador "MANUAL" ;
    ns1:textoExtracto "MANUAL" .

ns1:Se_al_STOP a ns1:Alarma ;
    rdfs:label "_STOP" ;
    ns1:identificador "_STOP" ;
    ns1:textoExtracto "_STOP [...] Los mnemónicos que comienzan por el carácter '_' indican que la señal es activa a nivel lógico bajo (0 V.)"@es ;
    ns1:valor "0"^^xsd:string .

