@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Pagina_437 a ns1:Pagina ;
    rdfs:label "Página 437" ;
    ns1:documentadoEn ns1:ManualBrochadora ;
    ns1:identificador "437" ;
    ns1:textoExtracto "Ver en la página 437." .

ns1:SistemaControlPLC a ns1:Sistema ;
    rdfs:label "Sistema de control PLC" ;
    ns1:textoExtracto "el PLC debe activar la marca CYSTART para que comience la ejecución del programa." ;
    ns1:tieneComponente ns1:Marca_CYSTART,
        ns1:Marca_RESETOUTC1 .

ns1:Marca_CYSTART a ns1:ComponenteElectrico ;
    rdfs:label "Marca CYSTART" ;
    ns1:identificador "CYSTART" ;
    ns1:textoExtracto "el PLC debe activar la marca CYSTART para que comience la ejecución del programa." .

ns1:Marca_RESETOUTC1 a ns1:ComponenteElectrico ;
    rdfs:label "Marca RESETOUTC1" ;
    ns1:identificador "RESETOUTC1" ;
    ns1:textoExtracto "RESETOUTC1 (también se puede programar como RESETOUT)" .

