@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_ALARM a ns1:ComponenteElectrico ;
    rdfs:label "Marca _ALARM (_ALARMC1-4)" ;
    ns1:identificador "_ALARM" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. _ALARMC1 (también se puede programar como _ALARM) _ALARMC2 _ALARMC3 _ALARMC4. El canal del CNC activa esta marca (nivel '0') cuando hay una alarma, una emergencia generada por el canal del CNC o cuando el PLC activa señal de emergencia _EMERGEN." .

ns1:Marca_CYSTART a ns1:ComponenteElectrico ;
    rdfs:label "Marca CYSTART" ;
    ns1:identificador "CYSTART" ;
    ns1:textoExtracto "'CYSTART' START AND (resto de condiciones) = CYSTART RESETOUT. Para reanudar la ejecución el PLC debe poner las marcas '_STOP' y 'CYSTART' a (=1)." .

ns1:Marca_EMERGEN a ns1:ComponenteElectrico ;
    rdfs:label "Marca _EMERGEN" ;
    ns1:identificador "_EMERGEN" ;
    ns1:textoExtracto "El canal del CNC activa esta marca [_ALARM] cuando [...] el PLC activa señal de emergencia _EMERGEN." .

ns1:Marca_FEEDHOL a ns1:ComponenteElectrico ;
    rdfs:label "Marca _FEEDHOL" ;
    ns1:identificador "_FEEDHOL" ;
    ns1:textoExtracto "Si el PLC ha puesto la marca '_FEEDHOL' a (=0), para reanudar la ejecución el PLC debe poner la marca '_FEEDHOL' a (=1)." .

ns1:Marca_FHOUT a ns1:ComponenteElectrico ;
    rdfs:label "Marca FHOUT (FHOUTC1-4)" ;
    ns1:identificador "FHOUT" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. FHOUTC1 (también se puede programar como FHOUT) FHOUTC2 FHOUTC3 FHOUTC4. El canal del CNC pone esta marca a (=1) cuando está detenida la ejecución del programa pieza." .

ns1:Marca_RESETIN a ns1:ComponenteElectrico ;
    rdfs:label "Marca RESETIN" ;
    ns1:identificador "RESETIN" ;
    ns1:textoExtracto "El canal utiliza esta marca [RESETOUT] siempre que realiza un reset, ya sea desde la tecla [RESET] del panel de mando o cuando el PLC activa la marca RESETIN." .

ns1:Marca_RESETOUT a ns1:ComponenteElectrico ;
    rdfs:label "Marca RESETOUT (RESETOUTC1-4)" ;
    ns1:identificador "RESETOUT" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. RESETOUTC1 (también se puede programar como RESETOUT) RESETOUTC2 RESETOUTC3 RESETOUTC4. El canal activa la marca RESETOUT (RESETOUT=1) para indicar que ha finalizado el reset." .

ns1:Marca_STOP a ns1:ComponenteElectrico ;
    rdfs:label "Marca _STOP" ;
    ns1:identificador "_STOP" ;
    ns1:textoExtracto "Si el PLC ha puesto la marca '_STOP' a (=0), para reanudar la ejecución el PLC debe poner las marcas '_STOP' y 'CYSTART' a (=1)." .

ns1:Parametro_MINAENDW a ns1:Parametro ;
    rdfs:label "Parámetro general MINAENDW" ;
    ns1:identificador "MINAENDW" ;
    ns1:textoExtracto "Esta marca [RESETOUT] permanece activa el tiempo fijado en el parámetro general MINAENDW." .

ns1:Tecla_RESET a ns1:InterfazUsuario ;
    rdfs:label "Tecla [RESET] del panel de mando" ;
    ns1:identificador "RESET" ;
    ns1:textoExtracto "El canal utiliza esta marca [RESETOUT] siempre que realiza un reset, ya sea desde la tecla [RESET] del panel de mando o cuando el PLC activa la marca RESETIN." .

