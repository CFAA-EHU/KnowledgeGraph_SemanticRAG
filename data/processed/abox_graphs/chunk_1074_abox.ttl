@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionDetencionEmergencia_813 a ns1:AccionProhibida ;
    rdfs:label "Detención por colisión en ciclo de palpador"@es ;
    ns1:activaAlarma ns1:AlarmaEmergencia_813 ;
    ns1:textoExtracto "detiene el movimiento, muestra el error correspondiente, abre el relé de emergencia y activa la señal _ALARM (nivel \"0\")"@es .

ns1:SistemaCNC_813 a ns1:Sistema ;
    rdfs:label "Sistema CNC (canal de control)"@es ;
    ns1:activaAlarma ns1:AlarmaEmergencia_813 ;
    ns1:textoExtracto "El canal del CNC desactiva esta marca (nivel \"1\") cuando se ha eliminado el mensaje del canal del CNC y ha desaparecido la causa de la alarma o emergencia."@es ;
    ns1:tieneComponente ns1:ReleEmergencia_813,
        ns1:SensorPalpador_813 .

ns1:ReleEmergencia_813 a ns1:ComponenteElectrico ;
    rdfs:label "Relé de emergencia"@es ;
    ns1:textoExtracto "abre el relé de emergencia"@es .

ns1:SensorPalpador_813 a ns1:Sensor ;
    rdfs:label "Sensor de palpador (detección de colisión)"@es ;
    ns1:textoExtracto "si el CNC detecta una colisión en un movimiento de posicionamiento o retirada dentro de un ciclo de palpador"@es .

ns1:AlarmaEmergencia_813 a ns1:Alarma ;
    rdfs:label "Señal _ALARM (nivel \"0\")"@es ;
    ns1:identificador "_ALARM" ;
    ns1:textoExtracto "activa la señal _ALARM (nivel \"0\")"@es .

