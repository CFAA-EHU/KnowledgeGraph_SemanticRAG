@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:activaAlarma ns1:Se_al_ALARM ;
    ns1:compuestoPor ns1:Sistema_CNC_Canal1,
        ns1:Sistema_CNC_Canal2,
        ns1:Sistema_CNC_Canal3,
        ns1:Sistema_CNC_Canal4 ;
    ns1:textoExtracto "El canal del CNC pone esta marca a (=1) cuando está seleccionado el modo de operación" ;
    ns1:tieneComponente ns1:ComponenteElectrico_ReleEmergencia .

ns1:ComponenteElectrico_ReleEmergencia a ns1:ComponenteElectrico ;
    rdfs:label "Relé de emergencia" ;
    ns1:textoExtracto "abre el relé de emergencia" .

ns1:Se_al_ALARM a ns1:Alarma ;
    rdfs:label "Señal _ALARM" ;
    ns1:textoExtracto "activa la señal _ALARM (nivel \"0\")." ;
    ns1:valor "0" .

ns1:Sistema_CNC_Canal1 a ns1:Sistema ;
    rdfs:label "Canal 1 del CNC" ;
    ns1:identificador "C1" ;
    ns1:textoExtracto "MANUALC1, AUTOMATC1, MDIC1, SBOUTC1" ;
    ns1:tieneComponente ns1:ModoOperacion_Automatico,
        ns1:ModoOperacion_BloqueABloque,
        ns1:ModoOperacion_MDI,
        ns1:ModoOperacion_Manual .

ns1:Sistema_CNC_Canal2 a ns1:Sistema ;
    rdfs:label "Canal 2 del CNC" ;
    ns1:identificador "C2" ;
    ns1:textoExtracto "MANUALC2, AUTOMATC2, MDIC2, SBOUTC2" ;
    ns1:tieneComponente ns1:ModoOperacion_Automatico,
        ns1:ModoOperacion_BloqueABloque,
        ns1:ModoOperacion_MDI,
        ns1:ModoOperacion_Manual .

ns1:Sistema_CNC_Canal3 a ns1:Sistema ;
    rdfs:label "Canal 3 del CNC" ;
    ns1:identificador "C3" ;
    ns1:textoExtracto "MANUALC3, AUTOMATC3, MDIC3, SBOUTC3" ;
    ns1:tieneComponente ns1:ModoOperacion_Automatico,
        ns1:ModoOperacion_BloqueABloque,
        ns1:ModoOperacion_MDI,
        ns1:ModoOperacion_Manual .

ns1:Sistema_CNC_Canal4 a ns1:Sistema ;
    rdfs:label "Canal 4 del CNC" ;
    ns1:identificador "C4" ;
    ns1:textoExtracto "MANUALC4, AUTOMATC4, MDIC4, SBOUTC4" ;
    ns1:tieneComponente ns1:ModoOperacion_Automatico,
        ns1:ModoOperacion_BloqueABloque,
        ns1:ModoOperacion_MDI,
        ns1:ModoOperacion_Manual .

ns1:ModoOperacion_Automatico a ns1:ModoOperacion ;
    rdfs:label "Modo de operación automático" ;
    ns1:identificador "AUTOMAT" ;
    ns1:textoExtracto "modo de operación automático" .

ns1:ModoOperacion_BloqueABloque a ns1:ModoOperacion ;
    rdfs:label "Modo de ejecución 'bloque a bloque'" ;
    ns1:identificador "SBOUT" ;
    ns1:textoExtracto "modo de ejecución \"bloque a bloque\"" .

ns1:ModoOperacion_MDI a ns1:ModoOperacion ;
    rdfs:label "Modo MDI (introducción manual de datos)" ;
    ns1:identificador "MDI" ;
    ns1:textoExtracto "modo MDI (introducción manual de datos)" .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo de operación manual" ;
    ns1:identificador "MANUAL" ;
    ns1:textoExtracto "modo de operación manual" .

