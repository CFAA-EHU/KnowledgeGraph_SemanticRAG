@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_INCYCLE a ns1:AvisoSeguridad ;
    rdfs:label "INCYCLE" ;
    ns1:textoExtracto "INCYCLE. Hay una marca para cada canal." .

ns1:ModoOperacion_Automatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático" ;
    ns1:textoExtracto "Si estando en modo automático se selecciona –bloque a bloque– se activan las marcas AUTOMAT y SBOUT." .

ns1:ModoOperacion_BloqueABloque a ns1:ModoOperacion ;
    rdfs:label "Modo bloque a bloque" ;
    ns1:textoExtracto "se selecciona –bloque a bloque–" .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo manual" ;
    ns1:textoExtracto "Si estando en modo manual se selecciona –bloque a bloque– se activan las marcas MANUAL y SBOUT." .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "El canal del CNC pone esta marca a" ;
    ns1:tieneComponente ns1:AvisoSeguridad_INCYCLEC1,
        ns1:AvisoSeguridad_INCYCLEC2,
        ns1:AvisoSeguridad_INCYCLEC3,
        ns1:AvisoSeguridad_INCYCLEC4 .

ns1:AvisoSeguridad_INCYCLEC1 a ns1:AvisoSeguridad ;
    rdfs:label "INCYCLEC1" ;
    ns1:identificador "INCYCLEC1" ;
    ns1:textoExtracto "INCYCLEC1 (también se puede programar como INCYCLE)" .

ns1:AvisoSeguridad_INCYCLEC2 a ns1:AvisoSeguridad ;
    rdfs:label "INCYCLEC2" ;
    ns1:identificador "INCYCLEC2" ;
    ns1:textoExtracto "INCYCLEC2" .

ns1:AvisoSeguridad_INCYCLEC3 a ns1:AvisoSeguridad ;
    rdfs:label "INCYCLEC3" ;
    ns1:identificador "INCYCLEC3" ;
    ns1:textoExtracto "INCYCLEC3" .

ns1:AvisoSeguridad_INCYCLEC4 a ns1:AvisoSeguridad ;
    rdfs:label "INCYCLEC4" ;
    ns1:identificador "INCYCLEC4" ;
    ns1:textoExtracto "INCYCLEC4" .

