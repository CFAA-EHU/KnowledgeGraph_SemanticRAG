@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Interfaz_CNC_Se_alesConsulta a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de señales de consulta del CNC" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes [...]" ;
    ns1:tieneComponente ns1:Se_al_INCYCLEC1,
        ns1:Se_al_INCYCLEC2,
        ns1:Se_al_INCYCLEC3,
        ns1:Se_al_INCYCLEC4,
        ns1:Se_al_PROBEC1,
        ns1:Se_al_PROBEC2,
        ns1:Se_al_PROBEC3,
        ns1:Se_al_PROBEC4,
        ns1:Se_al_RAPIDC1,
        ns1:Se_al_RAPIDC2,
        ns1:Se_al_RAPIDC3,
        ns1:Se_al_RAPIDC4,
        ns1:Se_al_THREADC1,
        ns1:Se_al_THREADC2,
        ns1:Se_al_THREADC3,
        ns1:Se_al_THREADC4,
        ns1:Se_al_ZEROC1,
        ns1:Se_al_ZEROC2,
        ns1:Se_al_ZEROC3,
        ns1:Se_al_ZEROC4 .

ns1:Se_al_INCYCLEC1 a ns1:Parametro ;
    rdfs:label "INCYCLEC1" ;
    ns1:identificador "INCYCLEC1" ;
    ns1:textoExtracto "INCYCLEC1 (también se puede programar como INCYCLE) [...] El canal del CNC pone esta marca a (=1) cuando está ejecutando un bloque o desplazando algún eje." .

