    rdfs:label "INCYCLEC2" ;
    ns1:identificador "INCYCLEC2" ;
    ns1:textoExtracto "INCYCLEC2 [...] El canal del CNC pone esta marca a (=1) cuando está ejecutando un bloque o desplazando algún eje." .

