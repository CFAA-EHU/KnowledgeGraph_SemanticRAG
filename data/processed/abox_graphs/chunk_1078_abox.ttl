ns1:THREADC1 a ns1:Parametro ;
    rdfs:label "THREADC1" ;
    ns1:identificador "THREADC1" ;
    ns1:monitoreaParametro ns1:BloqueRoscadoElectronico_G33 ;
    ns1:textoExtracto "THREADC1 (también se puede programar como THREAD) [...] El canal del CNC pone esta marca a (=1) cuando está ejecutando un bloque de roscado electrónico (G33)." .

