@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TAPPINGC1 a ns1:Parametro ;
    rdfs:label "TAPPINGC1" ;
    ns1:identificador "TAPPINGC1" ;
    ns1:monitoreaParametro ns1:CicloFijoRoscadoMacho ;
    ns1:textoExtracto "TAPPINGC1 (también se puede programar como TAPPING) [...] El canal del CNC pone esta marca a (=1) cuando está ejecutando el ciclo fijo de roscado con macho." .

