    ns1:textoExtracto "THREADC4 [...] El canal del CNC pone esta marca a (=1) cuando está ejecutando un bloque de roscado electrónico (G33)." .

ns1:BloqueRoscadoElectronico_G33 a ns1:ModoOperacion ;
    rdfs:label "Bloque de roscado electrónico (G33)" ;
    ns1:identificador "G33" ;
    ns1:textoExtracto "bloque de roscado electrónico (G33)." .

ns1:CicloFijoRoscadoMacho a ns1:ModoOperacion ;
    rdfs:label "Ciclo fijo de roscado con macho" ;
    ns1:textoExtracto "ciclo fijo de roscado con macho. La marca se mantiene activa durante la posible temporización que se haya programado en el fondo de la rosca." .

