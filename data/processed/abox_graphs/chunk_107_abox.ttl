@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

ex:DepositoRefrigeracion a owl:Class ;
    rdfs:label "Depósito de refrigeración" ;
    rdfs:comment "Componente utilizado para almacenar aceite de corte en el sistema de refrigeración." .

ex:AceiteCorte a owl:Class ;
    rdfs:label "Aceite de corte" ;
    rdfs:comment "Fluido utilizado para la lubricación y refrigeración durante el proceso de brochado." .

ex:CUTMAXS50291 a owl:Class ;
    rdfs:label "CUT-MAX S 5029-1" ;
    rdfs:comment "Modelo específico de aceite de corte utilizado en el sistema de refrigeración." .

ex:llenar a owl:ObjectProperty ;
    rdfs:label "llenar" ;
    rdfs:comment "Propiedad que indica la acción de llenar un componente con un fluido específico." .

ex:tieneModelo a owl:ObjectProperty ;
    rdfs:label "tieneModelo" ;
    rdfs:comment "Propiedad que relaciona un componente con su modelo específico." .

ex:tieneFluido a owl:ObjectProperty ;
    rdfs:label "tieneFluido" ;
    rdfs:comment "Propiedad que relaciona un componente con el fluido que debe contener." .