@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_ADVINPOS a ns1:ComponenteElectrico ;
    rdfs:label "ADVINPOS" ;
    ns1:textoExtracto "También puede utilizarse la marca ADVINPOS." .

ns1:Marca_INPOSI a ns1:ComponenteElectrico ;
    rdfs:label "INPOSI" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. INPOSIC1 (también se puede programar como INPOSI o INPOS) INPOSIC2 INPOSIC3 INPOSIC4 El canal del CNC pone la marca INPOSI a (=1) para indicar que todos sus ejes y cabezales activos han llegado a posición, exceptuando los ejes independientes programados desde el PLC." .

ns1:Marca_INPOSIC1 a ns1:ComponenteElectrico ;
    rdfs:label "INPOSIC1" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. INPOSIC1 (también se puede programar como INPOSI o INPOS) INPOSIC2 INPOSIC3 INPOSIC4" .

ns1:Marca_INPOSIC2 a ns1:ComponenteElectrico ;
    rdfs:label "INPOSIC2" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. INPOSIC1 (también se puede programar como INPOSI o INPOS) INPOSIC2 INPOSIC3 INPOSIC4" .

ns1:Marca_INPOSIC3 a ns1:ComponenteElectrico ;
    rdfs:label "INPOSIC3" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. INPOSIC1 (también se puede programar como INPOSI o INPOS) INPOSIC2 INPOSIC3 INPOSIC4" .

ns1:Marca_INPOSIC4 a ns1:ComponenteElectrico ;
    rdfs:label "INPOSIC4" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. INPOSIC1 (también se puede programar como INPOSI o INPOS) INPOSIC2 INPOSIC3 INPOSIC4" .

ns1:Marca_INTEREND a ns1:ComponenteElectrico ;
    rdfs:label "INTEREND" ;
    ns1:textoExtracto "La marca INTEREND puede utilizarse para activar mecanismos antes de llegar los ejes a posición." .

