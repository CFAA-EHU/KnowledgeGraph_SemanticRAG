@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:canal_CNC a ns1:Sistema ;
    rdfs:label "Canal del CNC" ;
    ns1:monitoreaParametro ns1:marca_INPOSI,
        ns1:parametro_INPOSW,
        ns1:parametro_INPOTIME ;
    ns1:textoExtracto "El canal del CNC pone la marca INPOSI a (=1) para indicar que todos sus ejes y cabezales activos han llegado a posición" ;
    ns1:tieneComponente ns1:registro_SPN1 .

ns1:funcion_M a ns1:AccionProhibida ;
    rdfs:label "Función auxiliar M" ;
    ns1:documentadoEn ns1:registro_SPN1 ;
    ns1:textoExtracto "El canal indica al PLC mediante estos registros a qué cabezal del canal están dirigidas cada una de las funciones auxiliares M que se han seleccionado para su ejecución." .

ns1:registro_SPN1C1 a ns1:InterfazUsuario ;
    rdfs:label "SPN1C1" ;
    ns1:documentadoEn ns1:registro_SPN1 ;
    ns1:textoExtracto "SPN1C1 SPN1C2 SPN1C3 SPN1C4" .

ns1:registro_SPN1C2 a ns1:InterfazUsuario ;
    rdfs:label "SPN1C2" ;
    ns1:documentadoEn ns1:registro_SPN1 ;
    ns1:textoExtracto "SPN1C1 SPN1C2 SPN1C3 SPN1C4" .

ns1:registro_SPN1C3 a ns1:InterfazUsuario ;
    rdfs:label "SPN1C3" ;
    ns1:documentadoEn ns1:registro_SPN1 ;
    ns1:textoExtracto "SPN1C1 SPN1C2 SPN1C3 SPN1C4" .

ns1:registro_SPN1C4 a ns1:InterfazUsuario ;
    rdfs:label "SPN1C4" ;
    ns1:documentadoEn ns1:registro_SPN1 ;
    ns1:textoExtracto "SPN1C1 SPN1C2 SPN1C3 SPN1C4" .

ns1:parametro_INPOSW a ns1:Parametro ;
    rdfs:label "INPOSW" ;
    ns1:textoExtracto "Un eje está en posición cuando permanece dentro de la banda de muerte (parámetro INPOSW) el tiempo indicado en el parámetro INPOTIME." .

ns1:parametro_INPOTIME a ns1:Parametro ;
    rdfs:label "INPOTIME" ;
    ns1:textoExtracto "el tiempo indicado en el parámetro INPOTIME." .

ns1:marca_INPOSI a ns1:Parametro ;
    rdfs:label "INPOSI" ;
    ns1:textoExtracto "El canal del CNC pone la marca INPOSI a (=1) para indicar que todos sus ejes y cabezales activos han llegado a posición, exceptuando los ejes independientes programados desde el PLC." ;
    ns1:valor "1" .

ns1:registro_SPN1 a ns1:InterfazUsuario ;
    rdfs:label "SPN1" ;
    ns1:monitoreaParametro ns1:marca_INPOSI ;
    ns1:textoExtracto "Hay un registro para cada canal. Los mnemónicos para cada canal son los siguientes. Se muestra como ejemplo los mnemónicos de SPN1; para el resto de registros es equivalente." .

