@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Bloque_821_1 a ns1:ComponenteElectrico ;
    rdfs:label "bloque" ;
    ns1:textoExtracto "En cada canal puede haber hasta 7 funciones M en un mismo bloque." .

ns1:CNC_821_1 a ns1:Sistema ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "el CNC asigna el valor hexadecimal $FFFFFFFF a los que queden libres, los de numeración más alta. De esta forma si en el primer canal se encuentra programado el siguiente bloque, el CNC pasará al PLC la siguiente información." .

ns1:Cabezal_821_1 a ns1:ComponenteMecanico ;
    rdfs:label "cabezal" ;
    ns1:textoExtracto "Giro a derechas del cabezal S1 a 1000 rpm y giro a izquierdas del cabezal S2 a 500 rpm." .

ns1:Cabezal_821_2 a ns1:ComponenteMecanico ;
    rdfs:label "cabezal" ;
    ns1:textoExtracto "Giro a derechas del cabezal S1 a 1000 rpm y giro a izquierdas del cabezal S2 a 500 rpm." .

ns1:Canal_821_1 a ns1:ComponenteElectrico ;
    rdfs:label "canal" ;
    ns1:textoExtracto "En cada canal puede haber hasta 7 funciones M en un mismo bloque." .

ns1:FuncionM_821_1 a ns1:ComponenteElectrico ;
    rdfs:label "funciones M" ;
    ns1:textoExtracto "En cada canal puede haber hasta 7 funciones M en un mismo bloque." .

ns1:PLC_821_1 a ns1:Sistema ;
    rdfs:label "PLC" ;
    ns1:textoExtracto "el CNC pasará al PLC la siguiente información." .

ns1:ParametroRPM_821_1 a ns1:Parametro ;
    rdfs:label "1000 rpm" ;
    ns1:textoExtracto "Giro a derechas del cabezal S1 a 1000 rpm" ;
    ns1:valor "1000" .

ns1:ParametroRPM_821_2 a ns1:Parametro ;
    rdfs:label "500 rpm" ;
    ns1:textoExtracto "giro a izquierdas del cabezal S2 a 500 rpm" ;
    ns1:valor "500" .

ns1:ValorHexadecimal_821_1 a ns1:Parametro ;
    rdfs:label "valor hexadecimal $FFFFFFFF" ;
    ns1:textoExtracto "el CNC asigna el valor hexadecimal $FFFFFFFF a los que queden libres, los de numeración más alta." ;
    ns1:valor "$FFFFFFFF" .

