@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FuncionM88_EjecucionDinamica a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Ejecución dinámica de función M88 (Canal 1)" ;
    ns1:identificador "M88" ;
    ns1:textoExtracto "Si a continuación se ejecuta en el primer canal la función M88..." ;
    ns1:valor "88" .

ns1:FuncionM100_Canal1 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función M100 (Canal 1)" ;
    ns1:identificador "M100" ;
    ns1:monitoreaParametro ns1:Canal1_CNC ;
    ns1:textoExtracto "funciones M100 y M135" ;
    ns1:valor "100" .

ns1:FuncionM135_Canal1 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función M135 (Canal 1)" ;
    ns1:identificador "M135" ;
    ns1:monitoreaParametro ns1:Canal1_CNC ;
    ns1:textoExtracto "funciones M100 y M135" ;
    ns1:valor "135" .

ns1:FuncionM75_Canal2 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función M75 (Canal 2)" ;
    ns1:identificador "M75" ;
    ns1:monitoreaParametro ns1:Canal2_CNC ;
    ns1:textoExtracto "funciones M88 y M75" ;
    ns1:valor "75" .

ns1:FuncionM88_Canal2 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función M88 (Canal 2)" ;
    ns1:identificador "M88" ;
    ns1:monitoreaParametro ns1:Canal2_CNC ;
    ns1:textoExtracto "funciones M88 y M75" ;
    ns1:valor "88" .

ns1:Canal1_CNC a ns1:ComponenteElectrico ;
    rdfs:label "Canal 1 del CNC" ;
    ns1:compuestoPor ns1:SistemaSe_alesConsultaCNC ;
    ns1:textoExtracto "primer canal... funciones M100 y M135" ;
    ns1:tieneComponente ns1:FuncionM100_Canal1,
        ns1:FuncionM135_Canal1 .

ns1:Canal2_CNC a ns1:ComponenteElectrico ;
    rdfs:label "Canal 2 del CNC" ;
    ns1:compuestoPor ns1:SistemaSe_alesConsultaCNC ;
    ns1:textoExtracto "segundo canal... funciones M88 y M75" ;
    ns1:tieneComponente ns1:FuncionM75_Canal2,
        ns1:FuncionM88_Canal2 .

ns1:SistemaSe_alesConsultaCNC a ns1:Sistema ;
    rdfs:label "Sistema de señales de consulta CNC-PLC" ;
    ns1:textoExtracto "De esta forma si en el primer canal se encuentran programadas las funciones M100 y M135 y en el segundo canal las funciones M88 y M75, el CNC pasará al PLC la siguiente información..." .

