@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC para gestión de funciones por canal"@es ;
    ns1:compuestoPor ns1:Registro_HFUN1C1,
        ns1:Registro_HFUN1C2,
        ns1:Registro_MFUN1C1,
        ns1:Registro_MFUN1C2,
        ns1:Registro_MFUN2C1,
        ns1:Registro_MFUN2C2 ;
    ns1:textoExtracto """
    El canal indica al PLC mediante estos registros las funciones auxiliares H que se han seleccionado para su ejecución.
    """@es ;
    ns1:tieneComponente ns1:InterfazUsuario_CNC .

ns1:Registro_HFUN1C1 a ns1:Parametro ;
    rdfs:label "Registro HFUN1C1 (Funciones auxiliares H, Canal 1)"@es ;
    ns1:identificador "HFUN1C1" ;
    ns1:monitoreaParametro ns1:InterfazUsuario_CNC ;
    ns1:textoExtracto """
    HFUN1C1 (también se puede programar como HFUN1)
    El canal indica al PLC mediante estos registros las funciones auxiliares H que se han seleccionado para su ejecución.
    """@es .

ns1:Registro_HFUN1C2 a ns1:Parametro ;
    rdfs:label "Registro HFUN1C2 (Funciones auxiliares H, Canal 2)"@es ;
    ns1:identificador "HFUN1C2" ;
    ns1:monitoreaParametro ns1:InterfazUsuario_CNC ;
    ns1:textoExtracto """
    HFUN1C2
    En cada canal puede haber hasta 7 funciones H en un mismo bloque. Si no se utilizan todos los registros, el CNC asigna el valor hexadecimal $FFFFFFFF a los que queden libres.
    """@es .

ns1:Registro_MFUN1C1 a ns1:Parametro ;
    rdfs:label "Registro MFUN1C1 (Canal 1)"@es ;
    ns1:identificador "MFUN1C1" ;
    ns1:monitoreaParametro ns1:Tabla_MFUNC ;
    ns1:textoExtracto """
    | MFUN1C1 | MFUN2C1 | MFUN3C1 - MFUN7C1 |
    | --- | --- | --- |
    | 88 | $FFFFFFFF | $FFFFFFFF |
    """@es ;
    ns1:valor "$FFFFFFFF" .

ns1:Registro_MFUN1C2 a ns1:Parametro ;
    rdfs:label "Registro MFUN1C2 (Canal 2)"@es ;
    ns1:identificador "MFUN1C2" ;
    ns1:monitoreaParametro ns1:Tabla_MFUNC ;
    ns1:textoExtracto """
    | MFUN1C2 | MFUN2C2 | MFUN3C2 - MFUN7C2 |
    | --- | --- | --- |
    | 88 | 75 | $FFFFFFFF |
    """@es ;
    ns1:valor "88" .

ns1:Registro_MFUN2C1 a ns1:Parametro ;
    rdfs:label "Registro MFUN2C1 (Canal 1)"@es ;
    ns1:identificador "MFUN2C1" ;
    ns1:monitoreaParametro ns1:Tabla_MFUNC ;
    ns1:textoExtracto """
    | MFUN1C1 | MFUN2C1 | MFUN3C1 - MFUN7C1 |
    | --- | --- | --- |
    | 88 | $FFFFFFFF | $FFFFFFFF |
    """@es ;
    ns1:valor "$FFFFFFFF" .

ns1:Registro_MFUN2C2 a ns1:Parametro ;
    rdfs:label "Registro MFUN2C2 (Canal 2)"@es ;
    ns1:identificador "MFUN2C2" ;
    ns1:monitoreaParametro ns1:Tabla_MFUNC ;
    ns1:textoExtracto """
    | MFUN1C2 | MFUN2C2 | MFUN3C2 - MFUN7C2 |
    | --- | --- | --- |
    | 88 | 75 | $FFFFFFFF |
    """@es ;
    ns1:valor "75" .

ns1:InterfazUsuario_CNC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de usuario del CNC para programación y consulta de funciones por canal"@es ;
    ns1:textoExtracto """
    Si a continuación se ejecuta en el primer canal la función M88 se tiene:
    CPS MFUNC1* EQ 4 = ... Ejemplo para detectar M04 en el canal 1. Si se ha programado devolverá un "1"; un "0" en caso contrario.
    """@es .

ns1:Tabla_MFUNC a ns1:Tabla ;
    rdfs:label "Tabla de registros MFUNC para análisis de funciones programadas en canales"@es ;
    ns1:ilustradoEn ns1:InterfazUsuario_CNC ;
    ns1:textoExtracto """
    Comandos MFUNC1* - MFUNC4*. Analizar si una función ha sido programada en el canal. Para poder conocer si una determinada función se encuentra programada en el bloque en ejecución, se pueden analizar todos los registros uno a uno o se pueden utilizar los siguientes comandos para analizar todos ellos a la vez.
    MFUNC1* Para el canal 1. También se pueden programar como MFUN*.
    MFUNC2* Para el canal 2.
    MFUNC3* Para el canal 3.
    MFUNC4* Para el canal 4.
    """@es .

