@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_HFUN1C1 a ns1:Parametro ;
    rdfs:label "HFUN1C1 (Función H10 - Canal 1)"@es ;
    ns1:documentadoEn ns1:Tabla_Se_alesConsultaGenerales_6_1 ;
    ns1:identificador "H10" ;
    ns1:textoExtracto "HFUN1C1 | 10" ;
    ns1:valor "10" .

ns1:Parametro_HFUN1C2 a ns1:Parametro ;
    rdfs:label "HFUN1C2 (Función H30 - Canal 2)"@es ;
    ns1:documentadoEn ns1:Tabla_Se_alesConsultaGenerales_6_1 ;
    ns1:identificador "H30" ;
    ns1:textoExtracto "HFUN1C2 | 30" ;
    ns1:valor "30" .

ns1:Parametro_HFUN2C1 a ns1:Parametro ;
    rdfs:label "HFUN2C1 (Función H20 - Canal 1)"@es ;
    ns1:documentadoEn ns1:Tabla_Se_alesConsultaGenerales_6_1 ;
    ns1:identificador "H20" ;
    ns1:textoExtracto "HFUN2C1 | 20" ;
    ns1:valor "20" .

ns1:Parametro_HFUN2C2 a ns1:Parametro ;
    rdfs:label "HFUN2C2 (Función H40 - Canal 2)"@es ;
    ns1:documentadoEn ns1:Tabla_Se_alesConsultaGenerales_6_1 ;
    ns1:identificador "H40" ;
    ns1:textoExtracto "HFUN2C2 | 40" ;
    ns1:valor "40" .

ns1:Parametro_HFUN_Vacio a ns1:Parametro ;
    rdfs:label "Registro no utilizado (valor por defecto)"@es ;
    ns1:documentadoEn ns1:Tabla_Se_alesConsultaGenerales_6_1 ;
    ns1:textoExtracto "HFUN3C1 - HFUN7C1 | $FFFFFFFF" ;
    ns1:valor "$FFFFFFFF" .

ns1:Tabla_Se_alesConsultaGenerales_6_1 a ns1:Tabla ;
    rdfs:label "Tabla de asignación de funciones H en canales CNC"@es ;
    ns1:textoExtracto """
    Si no se utilizan todos los registros, el CNC asigna el valor hexadecimal $FFFFFFFF a los que queden libres, los de numeración más alta. De esta forma si en el primer canal se encuentran programadas las funciones H10 y H20 y en el segundo canal las funciones H30 y H40, el CNC pasará al PLC la siguiente información.
    | HFUN1C1 | HFUN2C1 | HFUN3C1 - HFUN7C1 |
    | --- | --- | --- |
    | 10 | 20 | $FFFFFFFF |
    | HFUN1C2 | HFUN2C2 | HFUN3C2 - HFUN7C2 |
    | --- | --- | --- |
    | 30 | 40 | $FFFFFFFF |
    """ .

