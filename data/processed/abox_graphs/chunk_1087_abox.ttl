@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComandoHFUNC1 a ns1:InterfazUsuario ;
    rdfs:label "Comando de consulta para Canal 1 (HFUNC1*)"@es ;
    ns1:controla ns1:Canal1 ;
    ns1:identificador "HFUNC1*" ;
    ns1:textoExtracto "HFUNC1* Para el canal 1. También se pueden programar como HFUN*."@es .

ns1:ComandoHFUNC2 a ns1:InterfazUsuario ;
    rdfs:label "Comando de consulta para Canal 2 (HFUNC2*)"@es ;
    ns1:controla ns1:Canal2 ;
    ns1:identificador "HFUNC2*" ;
    ns1:textoExtracto "HFUNC2* Para el canal 2."@es .

ns1:SistemaConsultaFunciones a ns1:Sistema ;
    rdfs:label "Sistema de señales de consulta de funciones por canal"@es ;
    ns1:textoExtracto "Señales de consulta generales [...] Comandos HFUNC1* - HFUNC4* [...] Para poder conocer si una determinada función se encuentra programada en el bloque en ejecución, se pueden analizar todos los registros uno a uno o se pueden utilizar los siguientes comandos para analizar todos ellos a la vez."@es ;
    ns1:tieneComponente ns1:Canal1,
        ns1:Canal2,
        ns1:Canal3,
        ns1:Canal4,
        ns1:RegistroHFUN1C1,
        ns1:RegistroHFUN1C2,
        ns1:RegistroHFUN2C1,
        ns1:RegistroHFUN2C2,
        ns1:RegistroHFUN3C1,
        ns1:RegistroHFUN3C2,
        ns1:RegistroHFUN4C1,
        ns1:RegistroHFUN4C2,
        ns1:RegistroHFUN5C1,
        ns1:RegistroHFUN5C2,
        ns1:RegistroHFUN6C1,
        ns1:RegistroHFUN6C2,
        ns1:RegistroHFUN7C1,
        ns1:RegistroHFUN7C2 .

ns1:Canal1 a ns1:Componente ;
    rdfs:label "Canal 1"@es ;
    ns1:identificador "C1" ;
    ns1:textoExtracto "HFUNC1* Para el canal 1. También se pueden programar como HFUN*."@es ;
    ns1:tieneComponente ns1:RegistroHFUN1C1,
        ns1:RegistroHFUN2C1,
        ns1:RegistroHFUN3C1,
        ns1:RegistroHFUN4C1,
        ns1:RegistroHFUN5C1,
        ns1:RegistroHFUN6C1,
        ns1:RegistroHFUN7C1 .

ns1:Canal2 a ns1:Componente ;
    rdfs:label "Canal 2"@es ;
    ns1:identificador "C2" ;
    ns1:textoExtracto "HFUNC2* Para el canal 2."@es ;
    ns1:tieneComponente ns1:RegistroHFUN1C2,
        ns1:RegistroHFUN2C2,
        ns1:RegistroHFUN3C2,
        ns1:RegistroHFUN4C2,
        ns1:RegistroHFUN5C2,
        ns1:RegistroHFUN6C2,
        ns1:RegistroHFUN7C2 .

ns1:RegistroHFUN1C1 a ns1:Parametro ;
    rdfs:label "Registro HFUN1 del Canal 1"@es ;
    ns1:identificador "HFUN1C1" ;
    ns1:textoExtracto "| HFUN1C1 | HFUN2C1 | HFUN3C1 - HFUN7C1 | --- | --- | --- | 50 | $FFFFFFFF | $FFFFFFFF |"@es ;
    ns1:valor "50" .

ns1:RegistroHFUN1C2 a ns1:Parametro ;
    rdfs:label "Registro HFUN1 del Canal 2"@es ;
    ns1:identificador "HFUN1C2" ;
    ns1:textoExtracto "| HFUN1C2 | HFUN2C2 | HFUN3C2 - HFUN7C2 | --- | --- | --- | 30 | 40 | $FFFFFFFF |"@es ;
    ns1:valor "30" .

ns1:RegistroHFUN2C1 a ns1:Parametro ;
    rdfs:label "Registro HFUN2 del Canal 1"@es ;
    ns1:identificador "HFUN2C1" ;
    ns1:textoExtracto "| HFUN1C1 | HFUN2C1 | HFUN3C1 - HFUN7C1 | --- | --- | --- | 50 | $FFFFFFFF | $FFFFFFFF |"@es ;
    ns1:valor "$FFFFFFFF" .

ns1:RegistroHFUN2C2 a ns1:Parametro ;
    rdfs:label "Registro HFUN2 del Canal 2"@es ;
    ns1:identificador "HFUN2C2" ;
    ns1:textoExtracto "| HFUN1C2 | HFUN2C2 | HFUN3C2 - HFUN7C2 | --- | --- | --- | 30 | 40 | $FFFFFFFF |"@es ;
    ns1:valor "40" .

