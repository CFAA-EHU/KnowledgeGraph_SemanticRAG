@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ComunicacionCNC_PLC a ns1:Sistema ;
    rdfs:label "Sistema de comunicación CNC-PLC" ;
    ns1:textoExtracto "El canal del CNC pone esta marca a (=1) para indicar al PLC que debe ejecutar la(s) función(es) auxiliares" ;
    ns1:tieneComponente ns1:Marca_HSTROBEC1,
        ns1:Marca_HSTROBEC2,
        ns1:Marca_HSTROBEC3,
        ns1:Marca_HSTROBEC4,
        ns1:Marca_MSTROBEC1,
        ns1:Marca_MSTROBEC2,
        ns1:Marca_MSTROBEC3,
        ns1:Marca_MSTROBEC4,
        ns1:Parametro_SPDLTIME,
        ns1:Registro_HFUN1,
        ns1:Registro_HFUN2,
        ns1:Registro_HFUN3,
        ns1:Registro_HFUN4,
        ns1:Registro_HFUN5,
        ns1:Registro_HFUN6,
        ns1:Registro_HFUN7,
        ns1:Registro_MFUN1,
        ns1:Registro_MFUN2,
        ns1:Registro_MFUN3,
        ns1:Registro_MFUN4,
        ns1:Registro_MFUN5,
        ns1:Registro_MFUN6,
        ns1:Registro_MFUN7,
        ns1:Registro_SFUN1,
        ns1:Registro_SFUN2,
        ns1:Registro_SFUN3,
        ns1:Registro_SFUN4 .

ns1:Marca_HSTROBEC1 a ns1:Parametro ;
    rdfs:label "HSTROBEC1 (HSTROBE)" ;
    ns1:textoExtracto "marca para cada canal [...] HSTROBEC1 (también se puede programar como HSTROBE)" ;
    ns1:valor "1" .

ns1:Marca_HSTROBEC2 a ns1:Parametro ;
    rdfs:label "HSTROBEC2" ;
    ns1:textoExtracto "marca para cada canal [...] HSTROBEC2" ;
    ns1:valor "1" .

ns1:Marca_HSTROBEC3 a ns1:Parametro ;
    rdfs:label "HSTROBEC3" ;
    ns1:textoExtracto "marca para cada canal [...] HSTROBEC3" ;
    ns1:valor "1" .

ns1:Marca_HSTROBEC4 a ns1:Parametro ;
    rdfs:label "HSTROBEC4" ;
    ns1:textoExtracto "marca para cada canal [...] HSTROBEC4" ;
    ns1:valor "1" .

ns1:Marca_MSTROBEC1 a ns1:Parametro ;
    rdfs:label "MSTROBEC1 (MSTROBE)" ;
    ns1:textoExtracto "marca para cada canal [...] MSTROBEC1 (también se puede programar como MSTROBE)" ;
    ns1:valor "1" .

ns1:Marca_MSTROBEC2 a ns1:Parametro ;
    rdfs:label "MSTROBEC2" ;
    ns1:textoExtracto "marca para cada canal [...] MSTROBEC2" ;
    ns1:valor "1" .

ns1:Marca_MSTROBEC3 a ns1:Parametro ;
    rdfs:label "MSTROBEC3" ;
    ns1:textoExtracto "marca para cada canal [...] MSTROBEC3" ;
    ns1:valor "1" .

ns1:Marca_MSTROBEC4 a ns1:Parametro ;
    rdfs:label "MSTROBEC4" ;
    ns1:textoExtracto "marca para cada canal [...] MSTROBEC4" ;
    ns1:valor "1" .

ns1:Parametro_SPDLTIME a ns1:Parametro ;
    rdfs:label "SPDLTIME" ;
    ns1:textoExtracto "parámetro SPDLTIME tenga un valor distinto de cero" ;
    ns1:valor "distinto_de_cero" .

ns1:Registro_HFUN1 a ns1:Parametro ;
    rdfs:label "HFUN1" ;
    ns1:identificador "CPS_HFUNC1" ;
    ns1:textoExtracto "registros HFUN1 a HFUN7" .

ns1:Registro_HFUN2 a ns1:Parametro ;
    rdfs:label "HFUN2" ;
    ns1:textoExtracto "registros HFUN1 a HFUN7" .

ns1:Registro_HFUN3 a ns1:Parametro ;
    rdfs:label "HFUN3" ;
    ns1:textoExtracto "registros HFUN1 a HFUN7" .

ns1:Registro_HFUN4 a ns1:Parametro ;
    rdfs:label "HFUN4" ;
    ns1:textoExtracto "registros HFUN1 a HFUN7" .

ns1:Registro_HFUN5 a ns1:Parametro ;
    rdfs:label "HFUN5" ;
    ns1:textoExtracto "registros HFUN1 a HFUN7" .

ns1:Registro_HFUN6 a ns1:Parametro ;
    rdfs:label "HFUN6" ;
    ns1:textoExtracto "registros HFUN1 a HFUN7" .

ns1:Registro_HFUN7 a ns1:Parametro ;
    rdfs:label "HFUN7" ;
    ns1:textoExtracto "registros HFUN1 a HFUN7" .

ns1:Registro_MFUN1 a ns1:Parametro ;
    rdfs:label "MFUN1" ;
    ns1:textoExtracto "registros MFUN1 a MFUN7 del canal" .

ns1:Registro_MFUN2 a ns1:Parametro ;
    rdfs:label "MFUN2" ;
    ns1:textoExtracto "registros MFUN1 a MFUN7 del canal" .

ns1:Registro_MFUN3 a ns1:Parametro ;
    rdfs:label "MFUN3" ;
    ns1:textoExtracto "registros MFUN1 a MFUN7 del canal" .

ns1:Registro_MFUN4 a ns1:Parametro ;
    rdfs:label "MFUN4" ;
    ns1:textoExtracto "registros MFUN1 a MFUN7 del canal" .

ns1:Registro_MFUN5 a ns1:Parametro ;
    rdfs:label "MFUN5" ;
    ns1:textoExtracto "registros MFUN1 a MFUN7 del canal" .

ns1:Registro_MFUN6 a ns1:Parametro ;
    rdfs:label "MFUN6" ;
    ns1:textoExtracto "registros MFUN1 a MFUN7 del canal" .

ns1:Registro_MFUN7 a ns1:Parametro ;
    rdfs:label "MFUN7" ;
    ns1:textoExtracto "registros MFUN1 a MFUN7 del canal" .

ns1:Registro_SFUN1 a ns1:Parametro ;
    rdfs:label "SFUN1" ;
    ns1:textoExtracto "registros SFUN1 a SFUN4 [...] indican la velocidad programada en cada uno de los cabezales" ;
    ns1:valor "velocidad_cabezal_1" .

ns1:Registro_SFUN2 a ns1:Parametro ;
    rdfs:label "SFUN2" ;
    ns1:textoExtracto "registros SFUN1 a SFUN4 [...] indican la velocidad programada en cada uno de los cabezales" ;
    ns1:valor "velocidad_cabezal_2" .

ns1:Registro_SFUN3 a ns1:Parametro ;
    rdfs:label "SFUN3" ;
    ns1:textoExtracto "registros SFUN1 a SFUN4 [...] indican la velocidad programada en cada uno de los cabezales" ;
    ns1:valor "velocidad_cabezal_3" .

ns1:Registro_SFUN4 a ns1:Parametro ;
