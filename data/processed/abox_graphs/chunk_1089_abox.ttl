@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_SFUN1 a ns1:Parametro ;
    rdfs:label "SFUN1" ;
    ns1:documentadoEn ns1:Tabla_SenalesConsulta_6_1 ;
    ns1:textoExtracto "SFUN1 | ... | 1000"@es ;
    ns1:valor "1000" .

ns1:Parametro_SFUN2 a ns1:Parametro ;
    rdfs:label "SFUN2" ;
    ns1:documentadoEn ns1:Tabla_SenalesConsulta_6_1 ;
    ns1:textoExtracto "SFUN2 | ... | 550"@es ;
    ns1:valor "550" .

ns1:Parametro_SFUN3 a ns1:Parametro ;
    rdfs:label "SFUN3" ;
    ns1:documentadoEn ns1:Tabla_SenalesConsulta_6_1 ;
    ns1:textoExtracto "SFUN3 | ... | $FFFFFFFF"@es ;
    ns1:valor "$FFFFFFFF" .

ns1:Parametro_SFUN4 a ns1:Parametro ;
    rdfs:label "SFUN4" ;
    ns1:documentadoEn ns1:Tabla_SenalesConsulta_6_1 ;
    ns1:textoExtracto "SFUN4 | ... | $FFFFFFFF"@es ;
    ns1:valor "$FFFFFFFF" .

ns1:Tabla_SenalesConsulta_6_1 a ns1:Tabla ;
    rdfs:label "Tabla de señales de consulta generales (Sección 6.1)"@es ;
    ns1:identificador "Sección 6.1 - Señales de consulta generales" ;
    ns1:textoExtracto "SFUN1 | SFUN2 | SFUN3 | SFUN4"@es .

