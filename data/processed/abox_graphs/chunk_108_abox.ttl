@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TareaMantenimiento_lubricacion_patines a ex:TareaMantenimiento ;
    rdfs:label "Lubricación de patines" ;
    ex:textoExtracto "Proceder a lubricar adecuadamente los patines del carro porta-piezas y de los contrapesos." ;
    ex:requiereConsumible ex:Consumible_lubricante .

ex:Consumible_lubricante a ex:Consumible ;
    rdfs:label "Lubricante" ;
    ex:textoExtracto "Proceder a lubricar adecuadamente los patines del carro porta-piezas y de los contrapesos." .