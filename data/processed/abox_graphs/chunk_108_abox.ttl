@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Lubricacion rdfs:subClassOf ex:Mantenimiento .
ex:Patin rdfs:subClassOf ex:ElementoMecanico .
ex:CarroPortaPieza rdfs:subClassOf ex:ComponenteMaquina .
ex:Contrapeso rdfs:subClassOf ex:ComponenteMaquina .

ex:lubrica a owl:ObjectProperty ;
    rdfs:domain ex:Mantenimiento ;
    rdfs:range ex:ElementoMecanico .

ex:tienePatines a owl:ObjectProperty ;
    rdfs:domain ex:CarroPortaPieza ;
    rdfs:range ex:Patin .

ex:tieneContrapesos a owl:ObjectProperty ;
    rdfs:domain ex:CarroPortaPieza ;
    rdfs:range ex:Contrapeso .