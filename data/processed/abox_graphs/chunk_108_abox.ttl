@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Contrapesos a ns1:ComponenteMecanico ;
    rdfs:label "contrapesos" ;
    ns1:textoExtracto "Proceder a lubricar adecuadamente los patines del carro porta-piezas y de los contrapesos." .

ns1:PatinesCarroPortaPiezas a ns1:ComponenteMecanico ;
    rdfs:label "patines del carro porta-piezas" ;
    ns1:textoExtracto "Proceder a lubricar adecuadamente los patines del carro porta-piezas y de los contrapesos." .

