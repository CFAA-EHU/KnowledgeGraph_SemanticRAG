@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC_Se_alesConsulta a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de señales de consulta CNC-PLC" ;
    ns1:monitoreaParametro ns1:M00,
        ns1:M01,
        ns1:M02,
        ns1:M03,
        ns1:M04,
        ns1:M05,
        ns1:M06,
        ns1:M08,
        ns1:M09,
        ns1:M19,
        ns1:M30,
        ns1:M41,
        ns1:M42,
        ns1:M43,
        ns1:M44 ;
    ns1:textoExtracto "El canal del CNC pone esta marca a (=1) para indicar al PLC que hay seleccionada una nueva velocidad de cabezal. [...] El CNC indica en estas marcas el estado de las funciones auxiliares M de cabezal." ;
    ns1:tieneComponente ns1:DM00,
        ns1:DM00C1,
        ns1:DM00C2,
        ns1:DM00C3,
        ns1:DM00C4,
        ns1:SPDLTIME,
        ns1:SSTROBE1,
        ns1:SSTROBE2,
        ns1:SSTROBE3,
        ns1:SSTROBE4 .

ns1:DM03SP1 a ns1:Parametro ;
    rdfs:label "DM03SP1" ;
    ns1:identificador "DM03SP1" ;
    ns1:monitoreaParametro ns1:M03 ;
    ns1:textoExtracto "DM03SP1 (también se puede programar como DM03)" .

ns1:DM00 a ns1:Parametro ;
    rdfs:label "DM00" ;
    ns1:identificador "DM00" ;
    ns1:monitoreaParametro ns1:M00 ;
    ns1:textoExtracto "DM00 (también se puede programar como DM00)" .

