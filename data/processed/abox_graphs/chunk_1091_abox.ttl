@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:controla ns1:ModoOperacion_Automatico ;
    ns1:textoExtracto "El canal del CNC pone esta marca [...] El canal del CNC pone esta señal"@es ;
    ns1:tieneComponente ns1:Senal_ADVINPOS,
        ns1:Senal_ADVINPOS_C1,
        ns1:Senal_ADVINPOS_C2,
        ns1:Senal_ADVINPOS_C3,
        ns1:Senal_ADVINPOS_C4,
        ns1:Senal_BLKSEARCH,
        ns1:Senal_BLKSEARCHC1,
        ns1:Senal_BLKSEARCHC2,
        ns1:Senal_BLKSEARCHC3,
        ns1:Senal_BLKSEARCHC4 .

ns1:ModoOperacion_Automatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático"@es ;
    ns1:textoExtracto "modo de operación automático"@es .

ns1:Senal_ADVINPOS a ns1:Parametro ;
    rdfs:label "ADVINPOS"@es ;
    ns1:identificador "ADVINPOS" ;
    ns1:textoExtracto "ADVINPOS [...] El canal del CNC pone esta señal"@es .

ns1:Senal_ADVINPOS_C1 a ns1:Parametro ;
    rdfs:label "ADVINPOS Canal 1"@es ;
    ns1:identificador "ADVINPOSC1" ;
    ns1:textoExtracto "ADVINPOSC1 (también se puede programar como ADVINPOS)"@es .

ns1:Senal_ADVINPOS_C2 a ns1:Parametro ;
    rdfs:label "ADVINPOS Canal 2"@es ;
    ns1:identificador "ADVINPOSC2" ;
    ns1:textoExtracto "ADVINPOSC2"@es .

ns1:Senal_ADVINPOS_C3 a ns1:Parametro ;
    rdfs:label "ADVINPOS Canal 3"@es ;
    ns1:identificador "ADVINPOSC3" ;
    ns1:textoExtracto "ADVINPOSC3"@es .

ns1:Senal_ADVINPOS_C4 a ns1:Parametro ;
    rdfs:label "ADVINPOS Canal 4"@es ;
    ns1:identificador "ADVINPOSC4" ;
    ns1:textoExtracto "ADVINPOSC4"@es .

ns1:Senal_BLKSEARCH a ns1:Parametro ;
    rdfs:label "BLKSEARCH (búsqueda de bloque)"@es ;
    ns1:identificador "BLKSEARCH" ;
    ns1:textoExtracto "BLKSEARCH [...] El canal del CNC pone esta marca a (=1) para indicar que se encuentra activa la opción –búsqueda de bloque– en el modo de operación automático."@es ;
    ns1:valor "1 (activo), 0 (inactivo)"@es .

ns1:Senal_BLKSEARCHC1 a ns1:Parametro ;
    rdfs:label "BLKSEARCH Canal 1"@es ;
    ns1:identificador "BLKSEARCHC1" ;
    ns1:textoExtracto "BLKSEARCHC1 (también se puede programar como BLKSEARCH)"@es .

ns1:Senal_BLKSEARCHC2 a ns1:Parametro ;
    rdfs:label "BLKSEARCH Canal 2"@es ;
    ns1:identificador "BLKSEARCHC2" ;
    ns1:textoExtracto "BLKSEARCHC2"@es .

ns1:Senal_BLKSEARCHC3 a ns1:Parametro ;
    rdfs:label "BLKSEARCH Canal 3"@es ;
    ns1:identificador "BLKSEARCHC3" ;
    ns1:textoExtracto "BLKSEARCHC3"@es .

ns1:Senal_BLKSEARCHC4 a ns1:Parametro ;
    rdfs:label "BLKSEARCH Canal 4"@es ;
    ns1:identificador "BLKSEARCHC4" ;
    ns1:textoExtracto "BLKSEARCHC4"@es .

