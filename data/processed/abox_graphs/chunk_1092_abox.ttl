@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ADVINPOSC1 a ns1:Parametro ;
    rdfs:label "ADVINPOSC1" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. ADVINPOSC1 (también se puede programar como ADVINPOS) ADVINPOSC2 ADVINPOSC3 ADVINPOSC4" .

ns1:ADVINPOSC2 a ns1:Parametro ;
    rdfs:label "ADVINPOSC2" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. ADVINPOSC1 (también se puede programar como ADVINPOS) ADVINPOSC2 ADVINPOSC3 ADVINPOSC4" .

ns1:ADVINPOSC3 a ns1:Parametro ;
    rdfs:label "ADVINPOSC3" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. ADVINPOSC1 (también se puede programar como ADVINPOS) ADVINPOSC2 ADVINPOSC3 ADVINPOSC4" .

ns1:ADVINPOSC4 a ns1:Parametro ;
    rdfs:label "ADVINPOSC4" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. ADVINPOSC1 (también se puede programar como ADVINPOS) ADVINPOSC2 ADVINPOSC3 ADVINPOSC4" .

ns1:ANTIME a ns1:Parametro ;
    rdfs:label "ANTIME" ;
    ns1:textoExtracto "Este tiempo lo fija el parámetro máquina ANTIME. Si la duración total del movimiento es inferior al valor especificado en el parámetro ANTIME, la marca se pone a (=1) inmediatamente. Si el parámetro ANTIME se ha definido con valor ꞏ0ꞏ, la marca está siempre activa." .

ns1:CAXIS a ns1:Parametro ;
    rdfs:label "CAXIS" ;
    ns1:textoExtracto "CAXIS Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes." .

ns1:MaquinaPunzonadora a ns1:Maquina ;
    rdfs:label "Punzonadora con excéntrica" ;
    ns1:textoExtracto "Se utiliza en las punzonadoras que tienen una excéntrica como sistema de golpeo." .

ns1:senalADVINPOS a ns1:Parametro ;
    rdfs:label "senalADVINPOS" ;
    ns1:textoExtracto "El canal del CNC pone esta señal a nivel lógico alto un tiempo antes de llegar los ejes a posición." .

