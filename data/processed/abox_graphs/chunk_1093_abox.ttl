@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CAXIS a ns1:Sensor ;
    rdfs:label "CAXIS" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. CAXISC1 (también se puede programar como CAXIS) CAXISC2 CAXISC3 CAXISC4 El canal del CNC pone esta marca a (=1) cuando el cabezal está trabajando como eje C. Esta marca se mantiene activa mientras se mantengan activas alguna de las funciones #CAX, #FACE o #CYL." .

ns1:CAXISC1 a ns1:Sensor ;
    rdfs:label "CAXISC1" ;
    ns1:identificador "CAXISC1" ;
    ns1:textoExtracto "CAXISC1 (también se puede programar como CAXIS)" .

ns1:CAXISC2 a ns1:Sensor ;
    rdfs:label "CAXISC2" ;
    ns1:identificador "CAXISC2" ;
    ns1:textoExtracto "CAXISC2" .

ns1:CAXISC3 a ns1:Sensor ;
    rdfs:label "CAXISC3" ;
    ns1:identificador "CAXISC3" ;
    ns1:textoExtracto "CAXISC3" .

ns1:CAXISC4 a ns1:Sensor ;
    rdfs:label "CAXISC4" ;
    ns1:identificador "CAXISC4" ;
    ns1:textoExtracto "CAXISC4" .

ns1:FREE a ns1:Sensor ;
    rdfs:label "FREE" ;
    ns1:textoExtracto "FREE Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. FREEC1 FREEC2 FREEC3 FREEC4 El canal del CNC pone esta señal a (=1) para indicar al PLC que está listo para aceptar un nuevo bloque, enviado mediante el comando CNCEX." .

ns1:FREEC1 a ns1:Sensor ;
    rdfs:label "FREEC1" ;
    ns1:identificador "FREEC1" ;
    ns1:textoExtracto "FREEC1" .

ns1:FREEC2 a ns1:Sensor ;
    rdfs:label "FREEC2" ;
    ns1:identificador "FREEC2" ;
    ns1:textoExtracto "FREEC2" .

ns1:FREEC3 a ns1:Sensor ;
    rdfs:label "FREEC3" ;
    ns1:identificador "FREEC3" ;
    ns1:textoExtracto "FREEC3" .

ns1:FREEC4 a ns1:Sensor ;
    rdfs:label "FREEC4" ;
    ns1:identificador "FREEC4" ;
    ns1:textoExtracto "FREEC4" .

ns1:WAITOUT a ns1:Sensor ;
    rdfs:label "WAITOUT" ;
    ns1:textoExtracto "WAITOUT Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. WAITOUTC1 WAITOUTC2 WAITOUTC3 WAITOUTC4 Se aplica a la sincronización de canales. El canal del CNC pone esta señal a (=1) para indicar al PLC que está esperando una señal de sincronización." .

ns1:WAITOUTC1 a ns1:Sensor ;
    rdfs:label "WAITOUTC1" ;
    ns1:identificador "WAITOUTC1" ;
    ns1:textoExtracto "WAITOUTC1" .

ns1:WAITOUTC2 a ns1:Sensor ;
    rdfs:label "WAITOUTC2" ;
    ns1:identificador "WAITOUTC2" ;
    ns1:textoExtracto "WAITOUTC2" .

ns1:WAITOUTC3 a ns1:Sensor ;
    rdfs:label "WAITOUTC3" ;
    ns1:identificador "WAITOUTC3" ;
    ns1:textoExtracto "WAITOUTC3" .

ns1:WAITOUTC4 a ns1:Sensor ;
    rdfs:label "WAITOUTC4" ;
    ns1:identificador "WAITOUTC4" ;
    ns1:textoExtracto "WAITOUTC4" .

