@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramaPieza a ns1:InterfazUsuario ;
    rdfs:label "Programa pieza" ;
    ns1:controla ns1:SenalSincronizacionCNC ;
    ns1:textoExtracto "Las señales de sincronización se pueden ejecutar desde el programa pieza mediante las sentencias #WAIT o #MEET." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "sistema operativo CNC" ;
    ns1:tieneComponente ns1:MarcaMMCWDG .

ns1:EstadoSincronizacionCNC a ns1:Parametro ;
    rdfs:label "Estado de sincronización CNC-PLC" ;
    ns1:textoExtracto "El canal del CNC pone esta señal a (=1) para indicar al PLC que está esperando una señal de sincronización." ;
    ns1:valor "1" .

ns1:EstadoSistemaOperativoCNC a ns1:Parametro ;
    rdfs:label "Estado del sistema operativo CNC" ;
    ns1:textoExtracto "Tiene el valor (=0) cuando el sistema operativo CNC funciona correctamente y valor (=1) en caso de bloqueo del sistema." ;
    ns1:valor "0",
        "1" .

ns1:MarcaMMCWDG a ns1:Sensor ;
    rdfs:label "MMCWDG" ;
    ns1:identificador "MMCWDG" ;
    ns1:monitoreaParametro ns1:EstadoSistemaOperativoCNC ;
    ns1:textoExtracto "MMCWDG. Esta marca indica el estado del sistema operativo." .

ns1:SenalSincronizacionCNC a ns1:Sensor ;
    rdfs:label "Señal de sincronización CNC-PLC" ;
    ns1:monitoreaParametro ns1:EstadoSincronizacionCNC ;
    ns1:textoExtracto "El canal del CNC pone esta señal a (=1) para indicar al PLC que está esperando una señal de sincronización. Las señales de sincronización se pueden ejecutar desde el programa pieza mediante las sentencias #WAIT o #MEET." .

