@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MarcaPSWSET a ns1:Parametro ;
    rdfs:label "Marca PSWSET" ;
    ns1:identificador "PSWSET" ;
    ns1:textoExtracto "El CNC activa esta marca cuando existe un password de fabricante." .

ns1:MarcaRetrace a ns1:Parametro ;
    rdfs:label "Marca RETRACE" ;
    ns1:identificador "RETRACE" ;
    ns1:monitoreaParametro ns1:FuncionRetrace ;
    ns1:textoExtracto "cuando al PLC pone a (=0) la marca RETRACE del canal" .

ns1:ParametroDINDISTC1 a ns1:Parametro ;
    rdfs:label "Parámetro DINDISTC1" ;
    ns1:identificador "DINDISTC1" ;
    ns1:textoExtracto "DINDISTC1" .

ns1:FuncionRetrace a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función retrace" ;
    ns1:textoExtracto "La función retrace también se cancela tras ejecutar M30, con un reset o cuando al PLC pone a (=0) la marca RETRACE del canal." .

