@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_PSWSET a ns1:Componente ;
    rdfs:label "Marca PSWSET" ;
    ns1:monitoreaParametro ns1:Parametro_PasswordFabricante ;
    ns1:textoExtracto "El CNC activa esta marca cuando existe un password de fabricante" .

ns1:Marca_RETRACE a ns1:Componente ;
    rdfs:label "Marca RETRACE" ;
    ns1:monitoreaParametro ns1:Parametro_CancelacionRetrace ;
    ns1:textoExtracto "PLC pone a (=0) la marca RETRACE del canal" .

ns1:Sistema_DistribucionDinamica a ns1:Sistema ;
    rdfs:label "Distribución dinámica de mecanizado entre canales" ;
    ns1:compuestoPor ns1:Marca_DINDISTC1C2,
        ns1:Marca_DINDISTC1C3,
        ns1:Marca_DINDISTC1C4,
        ns1:Marca_DINDISTC2C1,
        ns1:Marca_DINDISTC2C3,
        ns1:Marca_DINDISTC2C4,
        ns1:Marca_DINDISTC3C1,
        ns1:Marca_DINDISTC3C2,
        ns1:Marca_DINDISTC3C4,
        ns1:Marca_DINDISTC4C1,
        ns1:Marca_DINDISTC4C2,
        ns1:Marca_DINDISTC4C3 ;
    ns1:textoExtracto "Estas marcas están asociadas a la distribución dinámica del mecanizado entre canales (sentencia #DINDIST)" .

ns1:Marca_DINDISTC1C2 a ns1:Componente ;
    rdfs:label "DINDISTC1C2" ;
    ns1:identificador "DINDISTC1C2" ;
    ns1:monitoreaParametro ns1:Parametro_DistribucionPasadas_1_2 ;
    ns1:textoExtracto "Si el ciclo se ejecuta en el canal ꞏ1ꞏ y el resto de pasadas se distribuyen con el canal ꞏ2ꞏ, el CNC activa la marca DINDISTC1C2" .

ns1:Marca_DINDISTC1C3 a ns1:Componente ;
    rdfs:label "DINDISTC1C3" ;
    ns1:identificador "DINDISTC1C3" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes: DINDISTC1C3" .

ns1:Marca_DINDISTC1C4 a ns1:Componente ;
    rdfs:label "DINDISTC1C4" ;
    ns1:identificador "DINDISTC1C4" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes: DINDISTC1C4" .

ns1:Marca_DINDISTC2C1 a ns1:Componente ;
    rdfs:label "DINDISTC2C1" ;
    ns1:identificador "DINDISTC2C1" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes: DINDISTC2C1" .

ns1:Marca_DINDISTC2C3 a ns1:Componente ;
    rdfs:label "DINDISTC2C3" ;
    ns1:identificador "DINDISTC2C3" ;
    ns1:textoExtracto "Si el ciclo se ejecuta en el canal ꞏ2ꞏ y el resto de pasadas se distribuyen con los canales ꞏ1ꞏ y ꞏ3ꞏ, el CNC activa las marcas DINDISTC2C1 y DINDISTC2C3" .

ns1:Marca_DINDISTC2C4 a ns1:Componente ;
    rdfs:label "DINDISTC2C4" ;
    ns1:identificador "DINDISTC2C4" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes: DINDISTC2C4" .

ns1:Marca_DINDISTC3C1 a ns1:Componente ;
    rdfs:label "DINDISTC3C1" ;
    ns1:identificador "DINDISTC3C1" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes: DINDISTC3C1" .

ns1:Marca_DINDISTC3C2 a ns1:Componente ;
    rdfs:label "DINDISTC3C2" ;
    ns1:identificador "DINDISTC3C2" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes: DINDISTC3C2" .

ns1:Marca_DINDISTC3C4 a ns1:Componente ;
    rdfs:label "DINDISTC3C4" ;
    ns1:identificador "DINDISTC3C4" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes: DINDISTC3C4" .

ns1:Marca_DINDISTC4C1 a ns1:Componente ;
    rdfs:label "DINDISTC4C1" ;
    ns1:identificador "DINDISTC4C1" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes: DINDISTC4C1" .

ns1:Marca_DINDISTC4C2 a ns1:Componente ;
    rdfs:label "DINDISTC4C2" ;
    ns1:identificador "DINDISTC4C2" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes: DINDISTC4C2" .

ns1:Marca_DINDISTC4C3 a ns1:Componente ;
    rdfs:label "DINDISTC4C3" ;
    ns1:identificador "DINDISTC4C3" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes: DINDISTC4C3" .

ns1:Parametro_CancelacionRetrace a ns1:Parametro ;
    rdfs:label "Cancelación de retrace" ;
    ns1:textoExtracto "retrace también se cancela tras ejecutar M30, con un reset o cuando al PLC pone a (=0) la marca RETRACE del canal" ;
    ns1:valor "0" .

ns1:Parametro_DistribucionPasadas_1_2 a ns1:Parametro ;
    rdfs:label "Distribución de pasadas entre canal 1 y 2" ;
    ns1:textoExtracto "el canal del CNC activa estas marcas para indicar cuál es el canal en el que está programado el ciclo y cuales son los canales implicados en el reparto de las pasadas" .

ns1:Parametro_PasswordFabricante a ns1:Parametro ;
    rdfs:label "Password de fabricante" ;
    ns1:textoExtracto "El CNC activa esta marca cuando existe un password de fabricante" .

