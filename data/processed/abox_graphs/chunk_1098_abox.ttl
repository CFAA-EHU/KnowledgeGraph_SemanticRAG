@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DINDISTC2C1 a ns1:Sensor ;
    rdfs:label "DINDISTC2C1" ;
    ns1:textoExtracto "el CNC activa las marcas DINDISTC2C1 y DINDISTC2C3"@es .

ns1:DINDISTC2C3 a ns1:Sensor ;
    rdfs:label "DINDISTC2C3" ;
    ns1:textoExtracto "el CNC activa las marcas DINDISTC2C1 y DINDISTC2C3"@es .

ns1:DINDISTYPEC1 a ns1:Sensor ;
    rdfs:label "DINDISTYPEC1" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. DINDISTYPEC1 DINDISTYPEC2 DINDISTYPEC3 DINDISTYPEC4"@es .

ns1:DINDISTYPEC2 a ns1:Sensor ;
    rdfs:label "DINDISTYPEC2" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. DINDISTYPEC1 DINDISTYPEC2 DINDISTYPEC3 DINDISTYPEC4"@es .

ns1:DINDISTYPEC3 a ns1:Sensor ;
    rdfs:label "DINDISTYPEC3" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. DINDISTYPEC1 DINDISTYPEC2 DINDISTYPEC3 DINDISTYPEC4"@es .

ns1:DINDISTYPEC4 a ns1:Sensor ;
    rdfs:label "DINDISTYPEC4" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. DINDISTYPEC1 DINDISTYPEC2 DINDISTYPEC3 DINDISTYPEC4"@es .

