@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PLC_Maquina a ns1:ComponenteElectrico ;
    rdfs:label "PLC de la máquina" ;
    ns1:monitoreaParametro ns1:ParametroTemperatura ;
    ns1:textoExtracto "Incluir esta marca en la maniobra del PLC para restringir la operativa del CNC en caso de sobretemperatura." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:controla ns1:MarcaSobretemperaturaCNC ;
    ns1:textoExtracto "El CNC permitirá finalizar la ejecución en marcha, pero no permitirá reanudarla tras una interrupción, una inspección de herramienta, etc." .

ns1:AccionApagadoEquipo a ns1:AccionProhibida ;
    rdfs:label "Apagado obligatorio del equipo" ;
    ns1:textoExtracto "Apagar el equipo para evitar [daños por sobretemperatura]." .

ns1:AlarmaSobretemperatura a ns1:Alarma ;
    rdfs:label "Alarma por sobretemperatura" ;
    ns1:mitigaRiesgo ns1:AccionApagadoEquipo ;
    ns1:textoExtracto "Si el PLC activa esta marca, existe riesgo de sobretemperatura y está en peligro la integridad del equipo." .

ns1:MarcaSobretemperaturaCNC a ns1:InterfazUsuario ;
    rdfs:label "Marca de sobretemperatura en PLC" ;
    ns1:activaAlarma ns1:AlarmaSobretemperatura ;
    ns1:textoExtracto "Incluir esta marca en la maniobra del PLC para restringir la operativa del CNC en caso de sobretemperatura." .

ns1:ParametroTemperatura a ns1:Parametro ;
    rdfs:label "Temperatura del equipo" ;
    ns1:textoExtracto "riesgo de sobretemperatura" ;
    ns1:valor "sobretemperatura" .

