@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_COLLISIONACTIV a ns1:InterfazUsuario ;
    rdfs:label "COLLISIONACTIV (control de colisiones)" ;
    ns1:identificador "COLLISIONACTIV (COLLISIONACTIVC1)" ;
    ns1:requiereMantenimiento ns1:Esquema_ModelizadoMaquina ;
    ns1:textoExtracto "El CNC activa esta marca cuando la opción FCAS está activa. Para tener activo el control de colisiones, debe estar cargado el esquema modelizado de la máquina (archivo .xca) y seleccionados los gráficos HD." .

ns1:Marca_MLINKRDY a ns1:InterfazUsuario ;
    rdfs:label "MLINKRDY (Mechatrolink bus status)" ;
    ns1:identificador "MLINKRDY" ;
    ns1:monitoreaParametro ns1:Parametro_EstadoBusMechatrolink ;
    ns1:textoExtracto "En las configuraciones Mechatrolink, esta marca indica el estado del bus. El CNC activa esta marca para indicar que el bus Mechatrolink se encuentra inicializado correctamente." .

ns1:Marca_RETRACT a ns1:InterfazUsuario ;
    rdfs:label "Señal RETRACT (retirada de ejes)" ;
    ns1:habilitadoPor ns1:Parametro_RETRACTTHREAD ;
    ns1:identificador "RETRACT (RETRACTC1-4)" ;
    ns1:textoExtracto "El CNC utiliza esta marca cuando retira los ejes de la pieza tras interrumpir un roscado. El canal del CNC pone esta señal a nivel lógico alto cuando empieza a retirar los ejes de la pieza, y la mantiene así hasta que finaliza el movimiento." .

ns1:Marca_Sobretemperatura a ns1:AvisoSeguridad ;
    rdfs:label "Marca de sobretemperatura (PLC)" ;
    ns1:mitigaRiesgo ns1:Riesgo_Sobretemperatura ;
    ns1:textoExtracto "Si el PLC activa esta marca, existe riesgo de sobretemperatura y está en peligro la integridad del equipo. Apagar el equipo para evitar daños." .

ns1:Parametro_VAMALARM a ns1:Parametro ;
    rdfs:label "V.A.MALARM.xn" ;
    ns1:identificador "V.A.MALARM.xn" ;
    ns1:textoExtracto "El estado de los servos e inverters se puede consultar en [...] V.A.MALARM.xn" .

ns1:Parametro_VAMIOMON a ns1:Parametro ;
    rdfs:label "V.A.MIOMON.xn" ;
    ns1:identificador "V.A.MIOMON.xn" ;
    ns1:textoExtracto "El estado de los servos e inverters se puede consultar en [...] V.A.MIOMON.xn" .

ns1:Parametro_VAMSTATUS a ns1:Parametro ;
    rdfs:label "V.A.MSTATUS.xn" ;
    ns1:identificador "V.A.MSTATUS.xn" ;
    ns1:textoExtracto "El estado de los servos e inverters se puede consultar en [...] V.A.MSTATUS.xn" .

ns1:Parametro_VAMSUBSTAT a ns1:Parametro ;
    rdfs:label "V.A.MSUBSTAT.xn" ;
    ns1:identificador "V.A.MSUBSTAT.xn" ;
    ns1:textoExtracto "El estado de los servos e inverters se puede consultar en [...] V.A.MSUBSTAT.xn" .

ns1:Sistema_Mechatrolink a ns1:Sistema ;
    rdfs:label "Sistema Mechatrolink (bus de comunicación)" ;
    ns1:monitoreaParametro ns1:Parametro_EstadoBusMechatrolink ;
    ns1:textoExtracto "configuraciones Mechatrolink [...] bus Mechatrolink [...] consultas del estado de los servos e inverters" ;
    ns1:tieneComponente ns1:Componente_InvertersMechatrolink,
        ns1:Componente_ServosMechatrolink .

ns1:Componente_InvertersMechatrolink a ns1:ComponenteElectrico ;
    rdfs:label "Inverters (Mechatrolink)" ;
    ns1:textoExtracto "consultas del estado de [...] inverters [...] V.A.MSTATUS.xn, V.A.MSUBSTAT.xn, V.A.MALARM.xn, V.A.MIOMON.xn" .

ns1:Componente_ServosMechatrolink a ns1:ComponenteElectrico ;
    rdfs:label "Servos (Mechatrolink)" ;
    ns1:textoExtracto "consultas del estado de los servos [...] V.A.MSTATUS.xn, V.A.MSUBSTAT.xn, V.A.MALARM.xn, V.A.MIOMON.xn" .

ns1:Esquema_ModelizadoMaquina a ns1:Esquema ;
    rdfs:label "Esquema modelizado de la máquina (archivo .xca)" ;
    ns1:identificador ".xca" ;
    ns1:textoExtracto "debe estar cargado el esquema modelizado de la máquina (archivo xca)" .

ns1:Parametro_RETRACTTHREAD a ns1:Parametro ;
    rdfs:label "RETRACTTHREAD" ;
    ns1:identificador "RETRACTTHREAD" ;
    ns1:textoExtracto "La retirada de ejes se habilita en el parámetro RETRACTTHREAD, y se aplica al roscado electrónico (G33/G34) y los ciclos fijos de roscado." .

ns1:Riesgo_Sobretemperatura a ns1:AccionProhibida ;
    rdfs:label "Operativa restringida por sobretemperatura" ;
    ns1:textoExtracto "restringir la operativa del CNC en caso de sobretemperatura." .

ns1:Parametro_EstadoBusMechatrolink a ns1:Parametro ;
    rdfs:label "Estado del bus Mechatrolink" ;
    ns1:textoExtracto "El estado del bus Mechatrolink condiciona las consultas de servos e inverters (CNCRD/CNCWR)." .

