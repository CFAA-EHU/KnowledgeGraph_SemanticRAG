@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ControlColisiones a ns1:Sistema ;
    rdfs:label "control de colisiones"@es ;
    ns1:compuestoPor ns1:Esquema_Modelizado_Maquina,
        ns1:Graficos_HD,
        ns1:Graficos_STD,
        ns1:Marca_COLLISIONOFF,
        ns1:Marca_DMCPWRPEAK,
        ns1:Marca_DMCPWRPEAKC1,
        ns1:Marca_DMCPWRPEAKC2,
        ns1:Marca_DMCPWRPEAKC3,
        ns1:Marca_DMCPWRPEAKC4 ;
    ns1:textoExtracto "Para tener activo el control de colisiones"@es .

ns1:Esquema_Modelizado_Maquina a ns1:Esquema ;
    rdfs:label "esquema modelizado de la máquina"@es ;
    ns1:identificador "xca"@es ;
    ns1:textoExtracto "debe estar cargado el esquema modelizado de la máquina (archivo xca)"@es .

ns1:Graficos_HD a ns1:InterfazUsuario ;
    rdfs:label "gráficos HD"@es ;
    ns1:textoExtracto "deben estar seleccionados los gráficos HD"@es .

ns1:Graficos_STD a ns1:InterfazUsuario ;
    rdfs:label "gráficos estándar"@es ;
    ns1:textoExtracto "no estará activo si están seleccionados los gráficos STD (gráficos estándar Fagor)"@es .

ns1:Marca_COLLISIONOFF a ns1:ComponenteElectrico ;
    rdfs:label "COLLISIONOFF"@es ;
    ns1:identificador "COLLISIONOFF"@es ;
    ns1:textoExtracto "actuar sobre la marca COLLISIONOFF"@es .

ns1:Marca_DMCPWRPEAK a ns1:ComponenteElectrico ;
    rdfs:label "DMCPWRPEAK"@es ;
    ns1:identificador "DMCPWRPEAK"@es ;
    ns1:textoExtracto "DMCPWRPEAK Hay una marca para cada canal"@es .

ns1:Marca_DMCPWRPEAKC1 a ns1:ComponenteElectrico ;
    rdfs:label "DMCPWRPEAKC1"@es ;
    ns1:identificador "DMCPWRPEAKC1"@es ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. DMCPWRPEAKC1 DMCPWRPEAKC2 DMCPWRPEAKC3 DMCPWRPEAKC4"@es .

ns1:Marca_DMCPWRPEAKC2 a ns1:ComponenteElectrico ;
    rdfs:label "DMCPWRPEAKC2"@es ;
    ns1:identificador "DMCPWRPEAKC2"@es ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. DMCPWRPEAKC1 DMCPWRPEAKC2 DMCPWRPEAKC3 DMCPWRPEAKC4"@es .

ns1:Marca_DMCPWRPEAKC3 a ns1:ComponenteElectrico ;
    rdfs:label "DMCPWRPEAKC3"@es ;
    ns1:identificador "DMCPWRPEAKC3"@es ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. DMCPWRPEAKC1 DMCPWRPEAKC2 DMCPWRPEAKC3 DMCPWRPEAKC4"@es .

ns1:Marca_DMCPWRPEAKC4 a ns1:ComponenteElectrico ;
    rdfs:label "DMCPWRPEAKC4"@es ;
    ns1:identificador "DMCPWRPEAKC4"@es ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. DMCPWRPEAKC1 DMCPWRPEAKC2 DMCPWRPEAKC3 DMCPWRPEAKC4"@es .

