@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ControlCinematico a ns1:Sistema ;
    rdfs:label "Sistema de control de compensaciones cinemáticas"@es ;
    ns1:controla ns1:Parametro_FWAITLIM,
        ns1:Parametro_KINCOMP1,
        ns1:Parametro_KINCOMP2,
        ns1:Parametro_KINCOMP3 ;
    ns1:textoExtracto "Cada cinemática tiene una compensación asociada (parámetro COMPID). [...] al activar esta cinemática, el PLC activa la marca KINCOMP3"@es ;
    ns1:tieneComponente ns1:Parametro_COMPID,
        ns1:Parametro_FWAITLIM,
        ns1:Parametro_KINCOMP1,
        ns1:Parametro_KINCOMP2,
        ns1:Parametro_KINCOMP3 .

ns1:Parametro_FWAITLIM a ns1:Parametro ;
    rdfs:label "Marca de límite de espera en seguimiento (FWAITLIM)"@es ;
    ns1:identificador "FWAITLIM" ;
    ns1:textoExtracto "El PLC activa esta marca cuando detiene la ejecución del programa por un #FOLLOW[WAITINLIMIT], para que la cota programada entre dentro de los límites (modelo láser)"@es .

ns1:Parametro_KINCOMP1 a ns1:Parametro ;
    rdfs:label "Marca de compensación cinemática 1 (KINCOMP1)"@es ;
    ns1:identificador "KINCOMP1" ;
    ns1:monitoreaParametro ns1:Parametro_COMPID ;
    ns1:textoExtracto "KINCOMP1 está asociado a COMPID 1"@es .

ns1:Parametro_KINCOMP2 a ns1:Parametro ;
    rdfs:label "Marca de compensación cinemática 2 (KINCOMP2)"@es ;
    ns1:identificador "KINCOMP2" ;
    ns1:monitoreaParametro ns1:Parametro_COMPID ;
    ns1:textoExtracto "KINCOMP2 a COMPID2"@es .

ns1:Parametro_KINCOMP3 a ns1:Parametro ;
    rdfs:label "Marca de compensación cinemática 3 (KINCOMP3)"@es ;
    ns1:identificador "KINCOMP3" ;
    ns1:monitoreaParametro ns1:Parametro_COMPID ;
    ns1:textoExtracto "si la primera cinemática (#KINID[1]) tiene asociada la tercera compensación (COMPID=3), al activar esta cinemática, el PLC activa la marca KINCOMP3"@es .

ns1:Parametro_COMPID a ns1:Parametro ;
    rdfs:label "Parámetro de compensación cinemática (COMPID)"@es ;
    ns1:identificador "COMPID" ;
    ns1:textoExtracto "cada cinemática tiene una compensación asociada (parámetro COMPID). KINCOMP1 está asociado a COMPID 1, KINCOMP2 a COMPID2 y así sucesivamente"@es .

