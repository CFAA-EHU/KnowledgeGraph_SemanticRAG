@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaControlEjes a ns1:Sistema ;
    rdfs:label "Sistema de control de ejes y cabezales" ;
    ns1:textoExtracto "Cuando el cabezal trabaja en lazo cerrado (M19 ó G63) se comporta como un eje. Las denominaciones de las señales son genéricas. Sustituir el texto (axis) por el nombre del cabezal o por el nombre o número lógico de eje...." ;
    ns1:tieneComponente ns1:ENABLE3,
        ns1:ENABLE5,
        ns1:ENABLEB,
        ns1:ENABLES,
        ns1:ENABLEX,
        ns1:ENABLEZ2,
        ns1:INPOS .

ns1:ENABLE3 a ns1:Sensor ;
    rdfs:label "ENABLE3" ;
    ns1:textoExtracto "ENABLE3" ;
    ns1:valor "ENABLE3" .

ns1:ENABLE5 a ns1:Sensor ;
    rdfs:label "ENABLE5" ;
    ns1:textoExtracto "ENABLE5" ;
    ns1:valor "ENABLE5" .

ns1:ENABLEB a ns1:Sensor ;
    rdfs:label "ENABLEB" ;
    ns1:textoExtracto "ENABLEB" ;
    ns1:valor "ENABLEB" .

ns1:ENABLES a ns1:Sensor ;
    rdfs:label "ENABLES" ;
    ns1:textoExtracto "ENABLES" ;
    ns1:valor "ENABLES" .

ns1:ENABLEX a ns1:Sensor ;
    rdfs:label "ENABLEX" ;
    ns1:textoExtracto "ENABLEX" ;
    ns1:valor "ENABLEX" .

ns1:ENABLEZ2 a ns1:Sensor ;
    rdfs:label "ENABLEZ2" ;
    ns1:textoExtracto "ENABLEZ2" ;
    ns1:valor "ENABLEZ2" .

ns1:INPOS a ns1:Sensor ;
    rdfs:label "INPOS(axis)" ;
    ns1:textoExtracto "INPOS(axis)" .

