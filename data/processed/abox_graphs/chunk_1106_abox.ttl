@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionEjesGantry a ns1:Sistema ;
    rdfs:label "Configuración de ejes gantry" ;
    ns1:textoExtracto "ejes gantry, ejes acoplados con #LINK, ejes sincronizados con #FOLLOW, levas electrónicas o en sincronización de cabezales en lazo cerrado mediante la sentencia #SYNC" ;
    ns1:tieneComponente ns1:EjeEsclavo .

ns1:LevasElectronicas a ns1:Sistema ;
    rdfs:label "Levas electrónicas" ;
    ns1:textoExtracto "levas electrónicas" .

ns1:MarcaDIR_axis a ns1:Parametro ;
    rdfs:label "Marca DIR(axis)" ;
    ns1:identificador "DIR(axis)" ;
    ns1:textoExtracto "DIR(axis) El CNC pone esta marca a (=1) para indicar que el eje se desplaza en sentido negativo y a (=0) cuando se desplaza en sentido positivo." ;
    ns1:valor "0 (positivo), 1 (negativo)" .

ns1:MarcaENABLE_axis a ns1:Parametro ;
    rdfs:label "Marca ENABLE(axis)" ;
    ns1:identificador "ENABLE(axis)" ;
    ns1:textoExtracto "Esta marca también se habilita en los movimientos de eje independiente... Cuando el movimiento de un eje implica el movimiento de un eje esclavo, también se habilitará la marca ENABLE(axis) del eje esclavo." .

ns1:MovimientoCabezalLazoCerrado a ns1:ModoOperacion ;
    rdfs:label "Movimiento de cabezal en lazo cerrado" ;
    ns1:identificador "M19, G74" ;
    ns1:textoExtracto "movimientos de cabezal en lazo cerrado (por ejemplo M19 ó G74)" .

ns1:MovimientoEjeIndependiente a ns1:ModoOperacion ;
    rdfs:label "Movimiento de eje independiente" ;
    ns1:textoExtracto "Esta marca también se habilita en los movimientos de eje independiente, en los movimientos de cabezal en lazo cerrado (por ejemplo M19 ó G74), o cuando un cabezal pasa a lazo cerrado mediante la sentencia #SERVO ON." .

ns1:SentenciaFOLLOW a ns1:Parametro ;
    rdfs:label "Sentencia #FOLLOW" ;
    ns1:identificador "#FOLLOW" ;
    ns1:textoExtracto "ejes sincronizados con #FOLLOW" .

ns1:SentenciaLINK a ns1:Parametro ;
    rdfs:label "Sentencia #LINK" ;
    ns1:identificador "#LINK" ;
    ns1:textoExtracto "ejes acoplados con #LINK" .

ns1:SentenciaSERVO_ON a ns1:Parametro ;
    rdfs:label "Sentencia #SERVO ON" ;
    ns1:identificador "#SERVO ON" ;
    ns1:textoExtracto "cuando un cabezal pasa a lazo cerrado mediante la sentencia #SERVO ON" .

ns1:SentenciaSYNC a ns1:Parametro ;
    rdfs:label "Sentencia #SYNC" ;
    ns1:identificador "#SYNC" ;
    ns1:textoExtracto "sincronización de cabezales en lazo cerrado mediante la sentencia #SYNC" .

ns1:EjeEsclavo a ns1:ComponenteMecanico ;
    rdfs:label "Eje esclavo" ;
    ns1:textoExtracto "Cuando el movimiento de un eje implica el movimiento de un eje esclavo, también se habilitará la marca ENABLE(axis) del eje esclavo." .

