@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ControlEjes a ns1:Sistema ;
    rdfs:label "Sistema de control de ejes y cabezales" ;
    ns1:monitoreaParametro ns1:Parametro_ABSFEEDBACK ;
    ns1:textoExtracto "Cuando el eje está parado se mantiene el último valor. Si el PLC detiene el avance de los ejes (marca _FEEDHOL=0) la señal ENABLE(axis) se mantiene a (=1)." ;
    ns1:tieneComponente ns1:Se_al_ENABLE,
        ns1:Se_al_REFPOIN .

ns1:Parametro_ABSFEEDBACK a ns1:Parametro ;
    rdfs:label "Parámetro ABSFEEDBACK" ;
    ns1:textoExtracto "Captación absoluta total (parámetro ABSFEEDBACK=Sí)." ;
    ns1:valor "Sí" .

ns1:Se_al_ENABLE a ns1:ComponenteElectrico ;
    rdfs:label "Señal ENABLE(axis)" ;
    ns1:textoExtracto "Si el PLC detiene el avance de los ejes (marca _FEEDHOL=0) la señal ENABLE(axis) se mantiene a (=1)." ;
    ns1:valor "1" .

ns1:Se_al_REFPOIN a ns1:ComponenteElectrico ;
    rdfs:label "Señal REFPOIN(axis)" ;
    ns1:textoExtracto "El CNC activa esta marca (=1) cuando el eje o cabezal está referenciado. Captación absoluta total (parámetro ABSFEEDBACK=Sí). La marca REFPOIN(axis) siempre está activa (=1)." ;
    ns1:valor "1" .

