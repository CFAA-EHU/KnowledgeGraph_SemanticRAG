@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Funcion_G174 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "G174" ;
    ns1:textoExtracto "tras fijar la cota máquina (G174)"@es .

ns1:SistemaCNC_ReferenciacionEjes a ns1:Sistema ;
    rdfs:label "Sistema de referenciación de ejes y cabezales (CNC)" ;
    ns1:controla ns1:Marca_REFPOIN_axis ;
    ns1:monitoreaParametro ns1:Marca_REFPOIN_axis,
        ns1:Parametro_ABSFEEDBACK,
        ns1:Parametro_MAXDIFREF ;
    ns1:textoExtracto "El CNC activa (=1) la marca REFPOIN(axis) en el arranque si en la sesión anterior el eje ha sido referenciado correctamente, el CNC ha recuperado la posición del eje guardada en el apagado y la posición del encóder es la misma que la del apagado."@es .

ns1:Parametro_ABSFEEDBACK a ns1:Parametro ;
    rdfs:label "ABSFEEDBACK" ;
    ns1:textoExtracto "Sin captación absoluta (parámetro ABSFEEDBACK=No)"@es ;
    ns1:valor "No" .

ns1:Parametro_MAXDIFREF a ns1:Parametro ;
    rdfs:label "MAXDIFREF" ;
    ns1:textoExtracto "diferencia de posiciones menor que el parámetro MAXDIFREF"@es .

ns1:Marca_REFPOIN_axis a ns1:Parametro ;
    rdfs:label "REFPOIN(axis)" ;
    ns1:textoExtracto "La marca REFPOIN(axis) siempre está activa (=1). No es necesaria la búsqueda de referencia. Captación absoluta en una vuelta."@es ;
    ns1:valor "1" .

