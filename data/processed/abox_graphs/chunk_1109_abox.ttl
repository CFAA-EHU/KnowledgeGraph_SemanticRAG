@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_CaptacionFallida a ns1:Alarma ;
    rdfs:label "Alarma de captación fallida"@es ;
    ns1:activaAlarma ns1:Sensor_Captacion ;
    ns1:documentadoEn ns1:Seccion_6.2_SenalesConsultaEjesCabezales ;
    ns1:textoExtracto "En ejes analógicos, si se produce una alarma de captación."@es .

ns1:Marca_DRSTAF a ns1:Parametro ;
    rdfs:label "DRSTAF(axis)" ;
    ns1:documentadoEn ns1:Seccion_6.2_SenalesConsultaEjesCabezales ;
    ns1:monitoreaParametro ns1:Regulador_Sercos ;
    ns1:textoExtracto "DRSTAF(axis) [...] El CNC utiliza estas marcas cuando la comunicación con el regulador es vía Sercos® e indican el estado del regulador."@es .

ns1:Marca_DRSTAS a ns1:Parametro ;
    rdfs:label "DRSTAS(axis)" ;
    ns1:documentadoEn ns1:Seccion_6.2_SenalesConsultaEjesCabezales ;
    ns1:monitoreaParametro ns1:Regulador_Sercos ;
    ns1:textoExtracto "DRSTAS(axis) [...] El CNC utiliza estas marcas cuando la comunicación con el regulador es vía Sercos® e indican el estado del regulador."@es .

ns1:Proceso_InicializacionRegulador a ns1:ModoOperacion ;
    rdfs:label "Proceso de inicialización del regulador"@es ;
    ns1:controla ns1:Regulador_Sercos ;
    ns1:documentadoEn ns1:Seccion_6.2_SenalesConsultaEjesCabezales ;
    ns1:textoExtracto "1 Tras accionar el interruptor general del armario eléctrico se le proporcionan 24 V DC al regulador. 2 El regulador efectúa una comprobación interna. Si es correcta activa la salida System OK."@es .

ns1:Salida_SystemOK a ns1:Parametro ;
    rdfs:label "System OK" ;
    ns1:documentadoEn ns1:Seccion_6.2_SenalesConsultaEjesCabezales ;
    ns1:monitoreaParametro ns1:Regulador_Sercos ;
    ns1:textoExtracto "Si es correcta activa la salida System OK."@es .

ns1:Anillo_Sercos a ns1:ComponenteElectrico ;
    rdfs:label "Anillo Sercos"@es ;
    ns1:documentadoEn ns1:Seccion_6.2_SenalesConsultaEjesCabezales ;
    ns1:textoExtracto "En ejes y cabezales Sercos, si cae el anillo."@es .

ns1:Eje_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Eje o cabezal (sin captación absoluta)"@es ;
    ns1:documentadoEn ns1:Seccion_6.2_SenalesConsultaEjesCabezales ;
    ns1:textoExtracto "En ejes y cabezales sin captación absoluta, el CNC desactiva (=0) esta marca en los siguientes casos: [...] Al producirse una búsqueda de cero fallida. [...] Al aparcar el eje o cabezal."@es ;
    ns1:tieneComponente ns1:Anillo_Sercos,
        ns1:Sensor_Captacion .

ns1:Sensor_Captacion a ns1:Sensor ;
    rdfs:label "Sensor de captación (ejes/cabezales)"@es ;
    ns1:documentadoEn ns1:Seccion_6.2_SenalesConsultaEjesCabezales ;
    ns1:textoExtracto "En ejes y cabezales sin captación absoluta [...] En cabezales o ejes rotativos controlados como un cabezal, al pasar a lazo abierto. [...] En ejes analógicos, si se produce una alarma de captación."@es .

ns1:Regulador_Sercos a ns1:ComponenteElectrico ;
    rdfs:label "Regulador (comunicación Sercos)"@es ;
    ns1:controla ns1:Eje_Cabezal ;
    ns1:documentadoEn ns1:Seccion_6.2_SenalesConsultaEjesCabezales ;
    ns1:textoExtracto "El CNC utiliza estas marcas [...] cuando la comunicación con el regulador es vía Sercos® e indican el estado del regulador."@es .

ns1:Seccion_6.2_SenalesConsultaEjesCabezales a ns1:Capitulo ;
    rdfs:label "Señales de consulta de los ejes y cabezales"@es ;
    ns1:identificador "6.2" ;
    ns1:textoExtracto "En ejes y cabezales sin captación absoluta, el CNC desactiva (=0) esta marca en los siguientes casos..."@es .

