@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Cremallera a owl:Class ;
    rdfs:label "Cremallera" ;
    rdfs:comment "Componente mecánico utilizado en sistemas de guiado." .

ex:ReductorConPinon a owl:Class ;
    rdfs:label "Reductor con piñón" ;
    rdfs:comment "Componente mecánico que reduce la velocidad y transmite movimiento." .

ex:Servomotor a owl:Class ;
    rdfs:label "Servomotor" ;
    rdfs:comment "Motor que controla la posición, velocidad y aceleración de un sistema." .

ex:PinonDeFieltro a owl:Class ;
    rdfs:label "Piñón de fieltro" ;
    rdfs:comment "Componente utilizado para el guiado y lubricación en sistemas mecánicos." .

ex:ReglaLinealAbsoluta a owl:Class ;
    rdfs:label "Regla lineal absoluta" ;
    rdfs:comment "Dispositivo de medición lineal utilizado en sistemas de guiado." .

ex:SistemaGuiadoCarroPortaPiezaDerecha a owl:Class ;
    rdfs:label "Sistema de guiado carro porta-pieza derecha" ;
    rdfs:comment "Sistema de guiado para el carro porta-pieza en el lado derecho." .

ex:SistemaGuiadoCarroPortaPiezaIzquierda a owl:Class ;
    rdfs:label "Sistema de guiado carro porta-pieza izquierda" ;
    rdfs:comment "Sistema de guiado para el carro porta-pieza en el lado izquierdo." .

ex:FrenoCarroPortaPieza a owl:Class ;
    rdfs:label "Freno carro porta-pieza" ;
    rdfs:comment "Freno utilizado para detener el movimiento del carro porta-pieza." .

ex:SistemaGuiadoContrapesos a owl:Class ;
    rdfs:label "Sistema guiado contrapesos" ;
    rdfs:comment "Sistema de guiado para contrapesos en máquinas." .

ex:Fuelle a owl:Class ;
    rdfs:label "Fuelle" ;
    rdfs:comment "Componente utilizado para proteger y guiar elementos móviles." .

ex:PinonContrapeso a owl:Class ;
    rdfs:label "Piñón contrapeso" ;
    rdfs:comment "Piñón utilizado en sistemas de contrapeso." .

ex:Cadena a owl:Class ;
    rdfs:label "Cadena" ;
    rdfs:comment "Componente mecánico utilizado para transmitir movimiento." .

ex:Rodamiento a owl:Class ;
    rdfs:label "Rodamiento" ;
    rdfs:comment "Componente utilizado para reducir la fricción en sistemas mecánicos." .

ex:DetectorProximidad a owl:Class ;
    rdfs:label "Detector de proximidad" ;
    rdfs:comment "Sensor utilizado para detectar la presencia de objetos cercanos." .

