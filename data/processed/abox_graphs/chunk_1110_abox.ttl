@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Estado_DRSTAF_0 a ns1:ModoOperacion ;
    rdfs:label "DRSTAF=0" ;
    ns1:controla ns1:Regulador_Eje ;
    ns1:identificador "DRSTAF(*)=0" ;
    ns1:textoExtracto "Marcas DRSTAF(*)=0"@es .

ns1:Estado_DRSTAF_1 a ns1:ModoOperacion ;
    rdfs:label "DRSTAF=1" ;
    ns1:controla ns1:Regulador_Eje ;
    ns1:identificador "DRSTAF(*)=1" ;
    ns1:textoExtracto "Marcas DRSTAF(*)=1"@es .

ns1:Estado_DRSTAS_0 a ns1:ModoOperacion ;
    rdfs:label "DRSTAS=0" ;
    ns1:controla ns1:Regulador_Eje ;
    ns1:identificador "DRSTAS(*)=0" ;
    ns1:textoExtracto "DRSTAS(*)=0"@es .

ns1:Estado_DRSTAS_1 a ns1:ModoOperacion ;
    rdfs:label "DRSTAS=1" ;
    ns1:controla ns1:Regulador_Eje ;
    ns1:identificador "DRSTAS(*)=1" ;
    ns1:textoExtracto "DRSTAF(*)=0 DRSTAS(*)=1"@es .

ns1:Entrada_DriveEnable a ns1:ComponenteElectrico ;
    rdfs:label "Drive enable"@es ;
    ns1:habilitadoPor ns1:Regulador_Eje ;
    ns1:textoExtracto "activar las entradas Drive enable"@es .

ns1:Entrada_SpeedEnable a ns1:ComponenteElectrico ;
    rdfs:label "Speed enable"@es ;
    ns1:habilitadoPor ns1:Regulador_Eje ;
    ns1:textoExtracto "activar las entradas [...] Speed enable"@es .

ns1:Se_al_SystemOK a ns1:AvisoSeguridad ;
    rdfs:label "System OK"@es ;
    ns1:textoExtracto "Si es correcta activa la salida System OK."@es .

ns1:Regulador_Eje a ns1:ComponenteElectrico ;
    rdfs:label "Regulador de eje"@es ;
    ns1:activaAlarma ns1:Se_al_SystemOK ;
    ns1:textoExtracto "el regulador está preparado para tener par. Para ello, activar las entradas Drive enable y Speed enable."@es ;
    ns1:tieneComponente ns1:Entrada_DriveEnable,
        ns1:Entrada_SpeedEnable .

