@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Marca_HIRTHON a ns1:Sensor ;
    ns1:identificador "HIRTHON(axis)" ;
    ns1:textoExtracto "Esta marca está relacionada con ejes Hirth. Se denomina eje Hirth al eje que debe posicionarse siempre en posiciones concretas. La marca HIRTHON(axis) indica si el eje Hirth está trabajando como eje Hirth (=1) o como un eje rotativo o lineal normal (=0), sin necesidad de posicionarse en posiciones concretas." .

ns1:Marca_INPOS a ns1:Sensor ;
    ns1:identificador "INPOS(axis)" ;
    ns1:textoExtracto "El CNC pone esta marca a (=1) cuando el eje o cabezal correspondiente se encuentra en posición y no hay ninguna petición de movimiento (marca ENABLE(axis) desactivada). Un eje está en posición cuando permanece dentro de la banda de muerte (parámetro INPOSW) el tiempo indicado en el parámetro INPOTIME. Hay una marca INPOS(axis) para cada eje y cabezal, y una marca INPOSI general para el canal que indica si todos sus ejes y cabezales activos han llegado a posición, exceptuando los ejes independientes programados desde el PLC." .

ns1:Marca_INPOSI a ns1:Sensor ;
    ns1:identificador "INPOSI" ;
    ns1:textoExtracto "marca INPOSI general para el canal que indica si todos sus ejes y cabezales activos han llegado a posición" .

ns1:Parametro_HIRTH a ns1:Parametro ;
    ns1:identificador "HIRTH" ;
    ns1:textoExtracto "El parámetro máquina HIRTH indica si el eje puede trabajar como eje Hirth" .

ns1:Parametro_INPOSW a ns1:Parametro ;
    ns1:identificador "INPOSW" ;
    ns1:textoExtracto "banda de muerte (parámetro INPOSW)" .

ns1:Parametro_INPOTIME a ns1:Parametro ;
    ns1:identificador "INPOTIME" ;
    ns1:textoExtracto "tiempo indicado en el parámetro INPOTIME" .

ns1:Regulador_1 a ns1:ComponenteElectrico ;
    ns1:identificador "DRSTAF(*)=1 DRSTAS(*)=1" ;
    ns1:textoExtracto "regulador está funcionando correctamente" .

ns1:Regulador_2 a ns1:ComponenteElectrico ;
    ns1:identificador "DRSTAF(*)=0 DRSTAS(*)=0" ;
    ns1:textoExtracto "El regulador está en estado de error o no existe" .

ns1:Regulador_3 a ns1:ComponenteElectrico ;
    ns1:identificador "DRSTAF(*)=0 DRSTAS(*)=1" ;
    ns1:textoExtracto "No hay potencia en el bus de continua. No se puede habilitar el regulador pero se puede dar potencia a la fuente de los reguladores" .

ns1:Regulador_4 a ns1:ComponenteElectrico ;
    ns1:identificador "DRSTAF(*)=1 DRSTAS(*)=0" ;
    ns1:textoExtracto "El regulador ya tiene potencia en el bus de continua. Se puede habilitar el regulador" .

