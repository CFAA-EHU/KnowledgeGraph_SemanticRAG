@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Funcion_G170 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G170"@es ;
    ns1:identificador "G170" ;
    ns1:textoExtracto "Las funciones G170 y G171 indican si se desea que el eje trabaje como eje Hirth (G171, función por defecto) o como un eje rotativo o lineal normal (G170)."@es .

ns1:Funcion_G171 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G171"@es ;
    ns1:identificador "G171" ;
    ns1:textoExtracto "Las funciones G170 y G171 indican si se desea que el eje trabaje como eje Hirth (G171, función por defecto) o como un eje rotativo o lineal normal (G170)."@es ;
    ns1:valor "función por defecto"@es .

ns1:Marca_MATCH_axis a ns1:Parametro ;
    rdfs:label "Marca MATCH(axis)"@es ;
    ns1:identificador "MATCH(axis)" ;
    ns1:textoExtracto "La marca MATCH(axis) indica si el eje Hirth está bien"@es .

ns1:Parametro_HIRTH a ns1:Parametro ;
    rdfs:label "Parámetro máquina HIRTH"@es ;
    ns1:identificador "HIRTH" ;
    ns1:textoExtracto "El parámetro máquina HIRTH indica si el eje puede trabajar como eje Hirth."@es .

