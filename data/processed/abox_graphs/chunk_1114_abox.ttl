@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:CNC_853_1 a ns1:Sistema ;
    ns1:controla ns1:M_quina_853_1 ;
    ns1:textoExtracto "El proceso de aparcar y desaparcar ejes se podrá realizar desde el CNC o desde el PLC." .

ns1:Configuraci_nEjesNormal_853_1 a ns1:ModoOperacion ;
    ns1:textoExtracto "Con el cabezal normal, configuración de ejes X Y Z." ;
    ns1:tieneComponente ns1:EjeX_853_1,
        ns1:EjeY_853_1,
        ns1:EjeZ_853_1 .

ns1:Configuraci_nEjesOrtogonal_853_1 a ns1:ModoOperacion ;
    ns1:textoExtracto "Con el cabezal ortogonal, configuración de ejes X Y Z A B." ;
    ns1:tieneComponente ns1:EjeA_853_1,
        ns1:EjeB_853_1,
        ns1:EjeX_853_1,
        ns1:EjeY_853_1,
        ns1:EjeZ_853_1 .

ns1:PLC_853_1 a ns1:Sistema ;
    ns1:controla ns1:M_quina_853_1 ;
    ns1:textoExtracto "El proceso de aparcar y desaparcar ejes se podrá realizar desde el CNC o desde el PLC." .

ns1:CabezalNormal_853_1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "cabezal normal" .

ns1:CabezalOrtogonal_853_1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "cabezal ortogonal" .

ns1:Reguladores_853_1 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "reguladores" .

ns1:SistemaCaptaci_n_853_1 a ns1:Sensor ;
    ns1:textoExtracto "sistemas de captación" .

ns1:EjeA_853_1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "eje A" .

ns1:EjeB_853_1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "eje B" .

ns1:M_quina_853_1 a ns1:Maquina ;
    ns1:compuestoPor ns1:CabezalNormal_853_1,
        ns1:CabezalOrtogonal_853_1,
        ns1:EjeA_853_1,
        ns1:EjeB_853_1,
        ns1:EjeX_853_1,
        ns1:EjeY_853_1,
        ns1:EjeZ_853_1,
        ns1:Reguladores_853_1,
        ns1:SistemaCaptaci_n_853_1 ;
    ns1:textoExtracto "Hay máquinas que dependiendo del tipo de mecanizado pueden disponer de 2 configuraciones de ejes distintas." .

ns1:EjeX_853_1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "eje X" .

ns1:EjeY_853_1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "eje Y" .

ns1:EjeZ_853_1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "eje Z" .

