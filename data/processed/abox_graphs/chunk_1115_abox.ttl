@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlarmaHabilitacionFalla a ns1:Alarma ;
    rdfs:label "Alarma por fallo en señales de habilitación"@es ;
    ns1:textoExtracto "sus señales de habilitación tienen que estar (=0)."@es .

ns1:CabezalEsclavo a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal esclavo o sincronizado"@es ;
    ns1:textoExtracto "Si el cabezal forma parte de una pareja tándem o es un cabezal sincronizado, ya sea el maestro o el esclavo."@es .

ns1:CabezalMaster a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal master del canal"@es ;
    ns1:controla ns1:SenalPARK,
        ns1:SenalUNPARK ;
    ns1:textoExtracto "Con G96 o G63 activa y sea el cabezal master del canal. • Con G33 o G95 activa y sea el cabezal master del canal o el cabezal que se utiliza para sincronizar el avance."@es .

ns1:EjeA a ns1:ComponenteMecanico ;
    rdfs:label "Eje A (cinemática)"@es ;
    ns1:textoExtracto "El CNC no permitirá aparcar un eje en los siguientes casos. • Si el eje pertenece a la cinemática activa. • Si el eje forma parte de una pareja gantry, tándem o es un eje acoplado."@es .

ns1:EjeB a ns1:ComponenteMecanico ;
    rdfs:label "Eje B (cinemática)"@es ;
    ns1:textoExtracto "será necesario aparcar los ejes A B."@es .

ns1:EsquemaParkUnpark a ns1:Esquema ;
    rdfs:label "Esquema de señales PARK/UNPARK (Sección 6.2)"@es ;
    ns1:ilustradoEn ns1:SistemaCNC_Seccion6_2 ;
    ns1:textoExtracto "Park/Unpark desde el CNC. [...] El CNC utiliza las señales PARK y UNPARK para informar al PLC."@es .

ns1:ProcesoPark a ns1:ModoOperacion ;
    rdfs:label "Proceso de aparcado (Park)"@es ;
    ns1:activaAlarma ns1:AlarmaHabilitacionFalla ;
    ns1:ejecutadoPor ns1:SistemaCNC_Seccion6_2 ;
    ns1:textoExtracto "La maniobra de aparcar/desaparcar ejes desde un programa pieza o MDI se controla mediante las sentencias de programación #PARK."@es .

ns1:ProcesoUnpark a ns1:ModoOperacion ;
    rdfs:label "Proceso de desaparcado (Unpark)"@es ;
    ns1:ejecutadoPor ns1:SistemaCNC_Seccion6_2 ;
    ns1:textoExtracto "sentencias de programación #UNPARK."@es .

ns1:ParametroHabilitacion a ns1:Parametro ;
    rdfs:label "Parámetro de habilitación de ejes/cabezales"@es ;
    ns1:textoExtracto "Para poder aparcar un eje o cabezal, sus señales de habilitación tienen que estar (=0)."@es ;
    ns1:valor "0" .

ns1:SenalPARK a ns1:InterfazUsuario ;
    rdfs:label "Señal PARK (CNC → PLC)"@es ;
    ns1:monitoreaParametro ns1:ParametroHabilitacion ;
    ns1:textoExtracto "El CNC utiliza las señales PARK y UNPARK para informar al PLC que se ha desencadenado el proceso correspondiente de aparcar."@es .

ns1:SenalUNPARK a ns1:InterfazUsuario ;
    rdfs:label "Señal UNPARK (CNC → PLC)"@es ;
    ns1:monitoreaParametro ns1:ParametroHabilitacion ;
    ns1:textoExtracto "se ha desencadenado el proceso [...] de desaparcar."@es .

ns1:SistemaCNC_Seccion6_2 a ns1:Sistema ;
    rdfs:label "Sistema de control CNC para aparcado de ejes y cabezales"@es ;
    ns1:controla ns1:ProcesoPark,
        ns1:ProcesoUnpark,
        ns1:SenalPARK,
        ns1:SenalUNPARK ;
    ns1:detalladoEnEsquema ns1:EsquemaParkUnpark ;
    ns1:textoExtracto "sistemas de captación, etc.). Para evitar esto, será necesario aparcar los ejes A B. [...] Park/Unpark desde el CNC. Este tipo de maniobra está indicado para aplicaciones que necesitan ejecutar el proceso de aparcar ejes o cabezales de forma automática, por ejemplo desde un programa pieza. El CNC utiliza las señales PARK y UNPARK para informar al PLC que se ha desencadenado el proceso correspondiente de aparcar o desaparcar."@es ;
    ns1:tieneComponente ns1:CabezalEsclavo,
        ns1:CabezalMaster,
        ns1:EjeA,
        ns1:EjeB .

