@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ManiobraAparcamientoEje a ns1:TareaMantenimiento ;
    rdfs:label "Maniobra para aparcar un eje o cabezal desde el CNC" ;
    ns1:identificador "#PARK" ;
    ns1:monitoreaParametro ns1:SenalPARK,
        ns1:SenalPARKED ;
    ns1:requiereMantenimiento ns1:ReguladorEjeDigital ;
    ns1:textoExtracto "Maniobra para aparcar un eje o cabezal desde el CNC. 1 Cuando se ejecuta la sentencia de programación #PARK el CNC comprueba si se puede aparcar el eje requerido. En caso afirmativo, el CNC pone la marca PARK a (=1) para indicar al PLC que debe aparcar el eje correspondiente. En el caso de ejes digitales el PLC debe quitar previamente la habilitación del regulador correspondiente al eje a aparcar (DRENA). Además, el CNC envía al regulador el comando para aparcar el eje. 2 El PLC tras recibir la señal PARK aparca el eje requerido. Tras comprobar que el eje se ha aparcado (sensores de presencia) el PLC pone la marca PARKED a (=1). 3 El CNC reconocerá que se ha aparcado el eje al detectar que se ha activado la señal PARKED. Se resetean las señales PARK y REFPOIN dando por finalizado el proceso." .

ns1:ManiobraDesaparcamientoEje a ns1:TareaMantenimiento ;
    rdfs:label "Maniobra para desaparcar un eje o cabezal desde el CNC" ;
    ns1:identificador "#UNPARK" ;
    ns1:monitoreaParametro ns1:SenalPARKED,
        ns1:SenalUNPARK ;
    ns1:requiereMantenimiento ns1:ReguladorEjeDigital ;
    ns1:textoExtracto "Maniobra para desaparcar un eje o cabezal desde el CNC. 4 Cuando se ejecuta la sentencia de programación #UNPARK el CNC pone la marca UNPARK a (=1) para indicar al PLC que debe desaparcar el eje correspondiente. En el caso de ejes digitales el CNC envía al regulador el comando para desaparcar el eje. 5 El PLC tras recibir la señal UNPARK desaparca el eje requerido. Tras comprobar que el eje se ha desaparcado (sensores de presencia) el PLC pone la marca PARKED a (=0). 6 El CNC reconocerá que se ha completado el proceso al detectar que se ha desactivado la señal PARKED. Se resetean las señales UNPARK y REFPOIN. En el caso de ejes digitales el PLC activará la habilitación del regulador correspondiente al eje (DRENA)." .

ns1:SenalPARK a ns1:Parametro ;
    rdfs:label "Señal PARK" ;
    ns1:textoExtracto "el CNC pone la marca PARK a (=1) para indicar al PLC que debe aparcar el eje correspondiente" ;
    ns1:valor "1" .

ns1:SenalUNPARK a ns1:Parametro ;
    rdfs:label "Señal UNPARK" ;
    ns1:textoExtracto "el CNC pone la marca UNPARK a (=1) para indicar al PLC que debe desaparcar el eje correspondiente" ;
    ns1:valor "1" .

ns1:SensorPresenciaEje a ns1:Sensor ;
    rdfs:label "Sensor de presencia de eje" ;
    ns1:textoExtracto "Tras comprobar que el eje se ha aparcado (sensores de presencia) [...] Tras comprobar que el eje se ha desaparcado (sensores de presencia)" .

ns1:ReguladorEjeDigital a ns1:ComponenteElectrico ;
    rdfs:label "Regulador de eje digital" ;
    ns1:controla ns1:SensorPresenciaEje ;
    ns1:textoExtracto "En el caso de ejes digitales el PLC debe quitar previamente la habilitación del regulador correspondiente al eje a aparcar (DRENA) [...] el CNC envía al regulador el comando para aparcar el eje" .

ns1:SenalPARKED a ns1:Parametro ;
    rdfs:label "Señal PARKED" ;
    ns1:textoExtracto "el PLC pone la marca PARKED a (=1) [...] el CNC reconocerá que se ha aparcado el eje al detectar que se ha activado la señal PARKED" ;
    ns1:valor "1" .

