@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Regulador_Eje_B a ns1:ComponenteElectrico ;
    rdfs:label "Regulador del eje B" ;
    ns1:controla ns1:Eje_B ;
    ns1:identificador "DRENAB" ;
    ns1:textoExtracto "En el caso de ejes digitales el PLC activará la habilitación del regulador correspondiente al eje (DRENA)." .

ns1:Senal_PARKB a ns1:AvisoSeguridad ;
    rdfs:label "Señal PARKB (petición de aparcado del eje B)" ;
    ns1:textoExtracto "Si hay una petición para aparcar el eje 'B' (PARKB) y el eje no está presente (NOT I15), el eje está aparcado (SET PARKEDB)." .

ns1:Senal_PARKED a ns1:AvisoSeguridad ;
    rdfs:label "Señal PARKED" ;
    ns1:textoExtracto "El CNC reconocerá que se ha completado el proceso al detectar que se ha desactivado la señal PARKED." .

ns1:Senal_PARKEDB a ns1:AvisoSeguridad ;
    rdfs:label "Señal PARKEDB (eje B aparcado)" ;
    ns1:textoExtracto "Si hay una petición para aparcar el eje 'B' (PARKB) y el eje no está presente (NOT I15), el eje está aparcado (SET PARKEDB)." .

ns1:Senal_REFPOIN a ns1:AvisoSeguridad ;
    rdfs:label "Señal REFPOIN" ;
    ns1:textoExtracto "Se resetean las señales UNPARK y REFPOIN." .

ns1:Senal_UNPARK a ns1:AvisoSeguridad ;
    rdfs:label "Señal UNPARK" ;
    ns1:textoExtracto "Se resetean las señales UNPARK y REFPOIN." .

ns1:Senal_UNPARKB a ns1:AvisoSeguridad ;
    rdfs:label "Señal UNPARKB (petición de desaparcado del eje B)" ;
    ns1:textoExtracto "Si hay una petición para desaparcar el eje 'B' (UNPARKB) y el eje está presente (I15), el eje está desaparcado (RES PARKEDB)." .

ns1:Eje_B a ns1:ComponenteMecanico ;
    rdfs:label "Eje B" ;
    ns1:textoExtracto "Ejemplo para aparcar y desaparcar un eje: La entrada I15 corresponde al sensor de presencia del eje 'B'." ;
    ns1:tieneComponente ns1:Sensor_Presencia_Eje_B .

ns1:Parametro_Presencia_Eje_B a ns1:Parametro ;
    rdfs:label "Presencia del eje B" ;
    ns1:textoExtracto "La entrada I15 corresponde al sensor de presencia del eje 'B'." .

ns1:Sensor_Presencia_Eje_B a ns1:Sensor ;
    rdfs:label "Sensor de presencia del eje B" ;
    ns1:identificador "I15" ;
    ns1:monitoreaParametro ns1:Parametro_Presencia_Eje_B ;
    ns1:textoExtracto "La entrada I15 corresponde al sensor de presencia del eje 'B'." .

