@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ControlEjeB a ns1:Sistema ;
    rdfs:label "Sistema de control del eje B" ;
    ns1:controla ns1:Param_EstadoAparcadoB,
        ns1:Param_HabilitacionEjeB,
        ns1:Param_PuntoReferenciaEje ;
    ns1:textoExtracto "La maniobra de aparcar/desaparcar ejes gestionada desde el programa de PLC se controla mediante la señal PARKED." ;
    ns1:tieneComponente ns1:Senal_DRENAB,
        ns1:Senal_PARKB,
        ns1:Senal_PARKEDB,
        ns1:Senal_REFPOIN,
        ns1:Senal_SERVOBON,
        ns1:Senal_SPENAB,
        ns1:Senal_UNPARKB .

ns1:Senal_DRENAB a ns1:Sensor ;
    rdfs:label "Señal DRENAB" ;
    ns1:monitoreaParametro ns1:Param_HabilitacionEjeB ;
    ns1:textoExtracto "NOT (PARKB OR UNPARKB OR PARKEDB) AND··· = DRENAB = SPENAB = SERVOBON Si el eje no está aparcado ni en proceso y se cumplen las condiciones de habilitación, se habilita el eje." .

ns1:Senal_PARKB a ns1:Sensor ;
    rdfs:label "Señal PARKB" ;
    ns1:monitoreaParametro ns1:Param_EstadoAparcadoB ;
    ns1:textoExtracto "La maniobra de aparcar/desaparcar ejes gestionada desde el programa de PLC se controla mediante la señal PARKED. Esta marca normalmente está afectada por la entrada correspondiente al sensor de presencia del eje." .

ns1:Senal_PARKEDB a ns1:Sensor ;
    rdfs:label "Señal PARKEDB" ;
    ns1:monitoreaParametro ns1:Param_EstadoAparcadoB ;
    ns1:textoExtracto "Si hay una petición para desaparcar el eje \"B\" (UNPARKB) y el eje está presente (I15), el eje está desaparcado (RES PARKEDB)." .

ns1:Senal_REFPOIN a ns1:Sensor ;
    rdfs:label "Señal REFPOIN" ;
    ns1:monitoreaParametro ns1:Param_PuntoReferenciaEje ;
    ns1:textoExtracto "Por seguridad, tras aparcar y desaparcar un eje, la señal REFPOIN del eje se pone a (=0)." .

ns1:Senal_SERVOBON a ns1:Sensor ;
    rdfs:label "Señal SERVOBON" ;
    ns1:monitoreaParametro ns1:Param_HabilitacionEjeB ;
    ns1:textoExtracto "NOT (PARKB OR UNPARKB OR PARKEDB) AND··· = DRENAB = SPENAB = SERVOBON Si el eje no está aparcado ni en proceso y se cumplen las condiciones de habilitación, se habilita el eje." .

ns1:Senal_SPENAB a ns1:Sensor ;
    rdfs:label "Señal SPENAB" ;
    ns1:monitoreaParametro ns1:Param_HabilitacionEjeB ;
    ns1:textoExtracto "NOT (PARKB OR UNPARKB OR PARKEDB) AND··· = DRENAB = SPENAB = SERVOBON Si el eje no está aparcado ni en proceso y se cumplen las condiciones de habilitación, se habilita el eje." .

ns1:Senal_UNPARKB a ns1:Sensor ;
    rdfs:label "Señal UNPARKB" ;
    ns1:monitoreaParametro ns1:Param_EstadoAparcadoB ;
    ns1:textoExtracto "Si hay una petición para desaparcar el eje \"B\" (UNPARKB) y el eje está presente (I15), el eje está desaparcado (RES PARKEDB)." .

ns1:Param_PuntoReferenciaEje a ns1:Parametro ;
    rdfs:label "Punto de referencia del eje" ;
    ns1:textoExtracto "Por seguridad, tras aparcar y desaparcar un eje, la señal REFPOIN del eje se pone a (=0)." .

ns1:Param_EstadoAparcadoB a ns1:Parametro ;
    rdfs:label "Estado de aparcado del eje B" ;
    ns1:textoExtracto "el eje está desaparcado (RES PARKEDB)." .

ns1:Param_HabilitacionEjeB a ns1:Parametro ;
    rdfs:label "Habilitación del eje B" ;
    ns1:textoExtracto "las señales de habilitación del eje tienen que estar (=0). Así mismo, tras desaparcar el eje las señales de habilitación del eje se deben poner a (=1)." .

