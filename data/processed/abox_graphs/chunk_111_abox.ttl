@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:ElementoComercial a owl:Class ;
    rdfs:label "Elemento comercial"@es ;
    rdfs:comment "Clase que representa los elementos comerciales del plato divisor."@es .

ex:ElementoDeDesgaste a owl:Class ;
    rdfs:label "Elemento de desgaste"@es ;
    rdfs:comment "Clase que representa los elementos de desgaste del plato divisor."@es .

ex:PlatoDivisor a owl:Class ;
    rdfs:label "Plato divisor"@es ;
    rdfs:comment "Clase que representa el plato divisor de la máquina."@es .

ex:tieneElementoComercial a owl:ObjectProperty ;
    rdfs:domain ex:PlatoDivisor ;
    rdfs:range ex:ElementoComercial ;
    rdfs:label "tiene elemento comercial"@es .

ex:tieneElementoDesgaste a owl:ObjectProperty ;
    rdfs:domain ex:PlatoDivisor ;
    rdfs:range ex:ElementoDeDesgaste ;
    rdfs:label "tiene elemento de desgaste"@es .