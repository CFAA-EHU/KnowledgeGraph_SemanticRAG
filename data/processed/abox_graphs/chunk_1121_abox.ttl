@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazCNC_PLC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz CNC-PLC" ;
    ns1:textoExtracto "El CNC pone esta marca... para indicar al PLC que" ;
    ns1:tieneComponente ns1:Marca_FBACKSEL,
        ns1:Marca_LOPEN,
        ns1:Marca_TANGACT .

ns1:Marca_LOPEN a ns1:Parametro ;
    rdfs:label "LOPEN(axis)" ;
    ns1:identificador "LOPEN" ;
    ns1:textoExtracto "El CNC activa esta marca para indicar al PLC que" .

ns1:ModoControlTangencial a ns1:ModoOperacion ;
    rdfs:label "Control tangencial de eje" ;
    ns1:controla ns1:Marca_TANGACT ;
    ns1:textoExtracto "control tangencial se encuentra activo en el eje" .

ns1:SistemaCaptacionEjes a ns1:Sistema ;
    rdfs:label "Sistema de captación de ejes" ;
    ns1:controla ns1:Marca_FBACKSEL ;
    ns1:textoExtracto "captación interna (captación motor)" .

ns1:Marca_FBACKSEL a ns1:Parametro ;
    rdfs:label "FBACKSEL(axis)" ;
    ns1:identificador "FBACKSEL" ;
    ns1:monitoreaParametro ns1:SistemaCaptacionEjes ;
    ns1:textoExtracto "El tipo de captación se podrá conmutar desde el PLC mediante la marca FBACKSEL(axis)." .

ns1:Marca_TANGACT a ns1:Parametro ;
    rdfs:label "TANGACT(axis)" ;
    ns1:identificador "TANGACT" ;
    ns1:monitoreaParametro ns1:ModoControlTangencial ;
    ns1:textoExtracto "El CNC pone esta marca a (=1) para indicar que el control tangencial se encuentra activo en el eje. El CNC pone esta marca a (=0) cuando se suspende (congela) o anula el control tangencial del eje." .

