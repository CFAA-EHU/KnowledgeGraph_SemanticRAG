@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaControlEjesGantry a ns1:Sistema ;
    rdfs:label "Sistema de control de ejes gantry"@es ;
    ns1:monitoreaParametro ns1:MarcaControlTangencial,
        ns1:MarcaLazoPosicionAbierto,
        ns1:ParametroMaxDiff ;
    ns1:textoExtracto "Ejes gantry con corrección de diferencia de cota entre eje maestro y esclavo mediante parámetro MAXDIFF(axis)."@es .

ns1:MarcaControlTangencial a ns1:Parametro ;
    rdfs:label "Marca de control tangencial (axis)"@es ;
    ns1:identificador "axis" ;
    ns1:textoExtracto "El CNC pone esta marca a (=0) cuando se suspende (congela) o anula el control tangencial del eje."@es .

ns1:MarcaLazoPosicionAbierto a ns1:Parametro ;
    rdfs:label "LOPEN(axis)"@es ;
    ns1:identificador "LOPEN(axis)" ;
    ns1:textoExtracto "El CNC activa esta marca para indicar al PLC que el lazo de posición del eje está abierto."@es .

ns1:ParametroMaxDiff a ns1:Parametro ;
    rdfs:label "MAXDIFF(axis)"@es ;
    ns1:identificador "MAXDIFF(axis)" ;
    ns1:textoExtracto "El CNC activa (=1) esta marca cuando no puede corregir la diferencia de cota entre el eje maestro y esclavo, ya que la diferencia es superior a la indicada por el parámetro MAXDIFF(axis)."@es .

