@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:maquina_CNC a ns1:Maquina ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "El CNC pone esta marca a (=1) cuando las revoluciones reales del cabezal corresponden a las programadas."@es ;
    ns1:tieneComponente ns1:se_al_REVOK1,
        ns1:se_al_REVOK2,
        ns1:se_al_REVOK3,
        ns1:se_al_REVOK4,
        ns1:se_al_REVOK5,
        ns1:se_al_REVOK6,
        ns1:se_al_SYNCMASTER1,
        ns1:se_al_SYNCMASTER2,
        ns1:se_al_SYNCMASTER3,
        ns1:se_al_SYNCMASTER4,
        ns1:se_al_SYNCMASTER5,
        ns1:se_al_SYNCMASTER6 .

ns1:se_al_REVOK1 a ns1:Sensor ;
    rdfs:label "REVOK1" ;
    ns1:identificador "REVOK1" ;
    ns1:monitoreaParametro ns1:parametro_revolucionesCabezal ;
    ns1:textoExtracto "REVOK1 (también se puede programar como REVOK) [...] Indica si las revoluciones reales del cabezal corresponden a las programadas (=1) o no (=0)." .

ns1:se_al_REVOK2 a ns1:Sensor ;
    rdfs:label "REVOK2" ;
    ns1:identificador "REVOK2" ;
    ns1:monitoreaParametro ns1:parametro_revolucionesCabezal ;
    ns1:textoExtracto "REVOK2 [...] Indica si las revoluciones reales del cabezal corresponden a las programadas." .

ns1:se_al_REVOK3 a ns1:Sensor ;
    rdfs:label "REVOK3" ;
    ns1:identificador "REVOK3" ;
    ns1:monitoreaParametro ns1:parametro_revolucionesCabezal ;
    ns1:textoExtracto "REVOK3 [...] Indica si las revoluciones reales del cabezal corresponden a las programadas." .

ns1:se_al_REVOK4 a ns1:Sensor ;
    rdfs:label "REVOK4" ;
    ns1:identificador "REVOK4" ;
    ns1:monitoreaParametro ns1:parametro_revolucionesCabezal ;
    ns1:textoExtracto "REVOK4 [...] Indica si las revoluciones reales del cabezal corresponden a las programadas." .

ns1:se_al_REVOK5 a ns1:Sensor ;
    rdfs:label "REVOK5" ;
    ns1:identificador "REVOK5" ;
    ns1:monitoreaParametro ns1:parametro_revolucionesCabezal ;
    ns1:textoExtracto "REVOK5 [...] Indica si las revoluciones reales del cabezal corresponden a las programadas." .

ns1:se_al_REVOK6 a ns1:Sensor ;
    rdfs:label "REVOK6" ;
    ns1:identificador "REVOK6" ;
    ns1:monitoreaParametro ns1:parametro_revolucionesCabezal ;
    ns1:textoExtracto "REVOK6 [...] Indica si las revoluciones reales del cabezal corresponden a las programadas." .

ns1:se_al_SYNCMASTER1 a ns1:Sensor ;
    rdfs:label "SYNCMASTER1" ;
    ns1:activaAlarma ns1:alerta_sincronizacionCabezales ;
    ns1:identificador "SYNCMASTER1" ;
    ns1:textoExtracto "SYNCMASTER1 [...] Esta marca se activa en el cabezal maestro e indica que ha comenzado una sincronización mediante la sentencia #SYNC." .

ns1:se_al_SYNCMASTER2 a ns1:Sensor ;
    rdfs:label "SYNCMASTER2" ;
    ns1:activaAlarma ns1:alerta_sincronizacionCabezales ;
    ns1:identificador "SYNCMASTER2" ;
    ns1:textoExtracto "SYNCMASTER2 [...] Esta marca se activa en el cabezal maestro e indica que ha comenzado una sincronización." .

ns1:se_al_SYNCMASTER3 a ns1:Sensor ;
    rdfs:label "SYNCMASTER3" ;
    ns1:activaAlarma ns1:alerta_sincronizacionCabezales ;
    ns1:identificador "SYNCMASTER3" ;
    ns1:textoExtracto "SYNCMASTER3 [...] Esta marca se activa en el cabezal maestro e indica que ha comenzado una sincronización." .

ns1:se_al_SYNCMASTER4 a ns1:Sensor ;
    rdfs:label "SYNCMASTER4" ;
    ns1:activaAlarma ns1:alerta_sincronizacionCabezales ;
    ns1:identificador "SYNCMASTER4" ;
    ns1:textoExtracto "SYNCMASTER4 [...] Esta marca se activa en el cabezal maestro e indica que ha comenzado una sincronización." .

ns1:se_al_SYNCMASTER5 a ns1:Sensor ;
    rdfs:label "SYNCMASTER5" ;
    ns1:activaAlarma ns1:alerta_sincronizacionCabezales ;
    ns1:identificador "SYNCMASTER5" ;
    ns1:textoExtracto "SYNCMASTER5 [...] Esta marca se activa en el cabezal maestro e indica que ha comenzado una sincronización." .

ns1:se_al_SYNCMASTER6 a ns1:Sensor ;
    rdfs:label "SYNCMASTER6" ;
    ns1:activaAlarma ns1:alerta_sincronizacionCabezales ;
    ns1:identificador "SYNCMASTER6" ;
    ns1:textoExtracto "SYNCMASTER6 [...] Esta marca se activa en el cabezal maestro e indica que ha comenzado una sincronización." .

ns1:alerta_sincronizacionCabezales a ns1:AvisoSeguridad ;
    rdfs:label "Sincronización de cabezales activa" ;
    ns1:textoExtracto "Cuando está activa una sincronización de cabezales, no se tienen en cuenta las señales PLCCNTL, INHIBIT y SPDLEREV ni del cabezal maestro ni del esclavo."@es .

ns1:parametro_revolucionesCabezal a ns1:Parametro ;
    rdfs:label "Revoluciones del cabezal" ;
    ns1:textoExtracto "Indica si las revoluciones reales del cabezal corresponden a las programadas (=1) o no (=0)." ;
    ns1:valor "UPSPDLIM y LOSPDLIM"@es .

