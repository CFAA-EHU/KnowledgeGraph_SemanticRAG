@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaSincronizacionCabezales a ns1:Sistema ;
    rdfs:label "Sistema de sincronización de cabezales" ;
    ns1:textoExtracto "Esta marca se activa en el cabezal esclavo e indica que ha comenzado una sincronización mediante la sentencia #SYNC. Cuando se activa una sincronización, se activa la señal ENABLE en los dos cabezales y se espera a la señal SERVOON" ;
    ns1:tieneComponente ns1:Se_al_ENABLE,
        ns1:Se_al_SERVOON,
        ns1:Se_al_SYNCHRON1,
        ns1:Se_al_SYNCHRON2,
        ns1:Se_al_SYNCHRON3,
        ns1:Se_al_SYNCHRON4,
        ns1:Se_al_SYNCHRON5,
        ns1:Se_al_SYNCHRON6 .

ns1:Se_al_ENABLE a ns1:ComponenteElectrico ;
    rdfs:label "ENABLE" ;
    ns1:identificador "ENABLE" ;
    ns1:textoExtracto "se activa la señal ENABLE en los dos cabezales" .

ns1:Se_al_SERVOON a ns1:ComponenteElectrico ;
    rdfs:label "SERVOON" ;
    ns1:identificador "SERVOON" ;
    ns1:textoExtracto "se espera a la señal SERVOON (en el caso de tener DWELL)" .

ns1:Se_al_SYNCHRON1 a ns1:ComponenteElectrico ;
    rdfs:label "SYNCHRON1" ;
    ns1:identificador "SYNCHRON1" ;
    ns1:textoExtracto "SYNCHRON1 [...] Esta marca se activa en el cabezal esclavo e indica que ha comenzado una sincronización mediante la sentencia #SYNC." .

ns1:Se_al_SYNCHRON2 a ns1:ComponenteElectrico ;
    rdfs:label "SYNCHRON2" ;
    ns1:identificador "SYNCHRON2" ;
    ns1:textoExtracto "SYNCHRON2" .

ns1:Se_al_SYNCHRON3 a ns1:ComponenteElectrico ;
    rdfs:label "SYNCHRON3" ;
    ns1:identificador "SYNCHRON3" ;
    ns1:textoExtracto "SYNCHRON3" .

ns1:Se_al_SYNCHRON4 a ns1:ComponenteElectrico ;
    rdfs:label "SYNCHRON4" ;
    ns1:identificador "SYNCHRON4" ;
    ns1:textoExtracto "SYNCHRON4" .

ns1:Se_al_SYNCHRON5 a ns1:ComponenteElectrico ;
    rdfs:label "SYNCHRON5" ;
    ns1:identificador "SYNCHRON5" ;
    ns1:textoExtracto "SYNCHRON5" .

ns1:Se_al_SYNCHRON6 a ns1:ComponenteElectrico ;
    rdfs:label "SYNCHRON6" ;
    ns1:identificador "SYNCHRON6" ;
    ns1:textoExtracto "SYNCHRON6" .

