@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Funcion_M41 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función M41"@es ;
    ns1:habilitadoPor ns1:Marca_GEAR1 ;
    ns1:textoExtracto "deberá estar activa la función M41 en el CNC"@es .

ns1:Marca_GEAROK a ns1:Sensor ;
    rdfs:label "Marca GEAROK"@es ;
    ns1:monitoreaParametro ns1:Parametro_DSYNCPOSW ;
    ns1:textoExtracto "Esta marca se pone a (=0) si se supera el máximo error en posición permitido [...] Hay una marca para cada cabezal. Los mnemónicos para cada canal son los siguientes: GEAROK1 (también se puede programar como GEAROK) GEAROK2 GEAROK3 GEAROK4 GEAROK5 GEAROK6"@es .

ns1:Marca_GEAROK1 a ns1:Sensor ;
    rdfs:label "Marca GEAROK1"@es ;
    ns1:textoExtracto "GEAROK1 (también se puede programar como GEAROK)"@es .

ns1:Marca_GEAROK2 a ns1:Sensor ;
    rdfs:label "Marca GEAROK2"@es ;
    ns1:textoExtracto "GEAROK2"@es .

ns1:Marca_GEAROK3 a ns1:Sensor ;
    rdfs:label "Marca GEAROK3"@es ;
    ns1:textoExtracto "GEAROK3"@es .

ns1:Marca_GEAROK4 a ns1:Sensor ;
    rdfs:label "Marca GEAROK4"@es ;
    ns1:textoExtracto "GEAROK4"@es .

ns1:Marca_GEAROK5 a ns1:Sensor ;
    rdfs:label "Marca GEAROK5"@es ;
    ns1:textoExtracto "GEAROK5"@es .

ns1:Marca_GEAROK6 a ns1:Sensor ;
    rdfs:label "Marca GEAROK6"@es ;
    ns1:textoExtracto "GEAROK6"@es .

ns1:Marca_GEAR1 a ns1:Sensor ;
    rdfs:label "Marca GEAR1"@es ;
    ns1:textoExtracto "la marca GEAR1"@es .

ns1:Parametro_DSYNCPOSW a ns1:Parametro ;
    rdfs:label "Parámetro máquina DSYNCPOSW"@es ;
    ns1:textoExtracto "valor por defecto se define en el parámetro máquina DSYNCPOSW"@es ;
    ns1:valor "máximo error en posición permitido"@es .

