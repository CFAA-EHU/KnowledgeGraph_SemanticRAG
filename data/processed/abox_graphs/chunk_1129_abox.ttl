@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterpoladorIndependiente_868 a ns1:Sistema ;
    rdfs:label "Interpolador independiente"@es ;
    ns1:activaAlarma ns1:MarcaLatcheo_868 ;
    ns1:textoExtracto "El interpolador independiente activa esta marca al activar un proceso de latcheo en el eje con el palpador indicado; la desactiva cuando finaliza el proceso de latcheo o cuando se cancela el proceso."@es ;
    ns1:tieneComponente ns1:Palpador_868 .

ns1:MarcaLatcheo_868 a ns1:AvisoSeguridad ;
    rdfs:label "Marca de latcheo"@es ;
    ns1:textoExtracto "El interpolador independiente activa esta marca al activar un proceso de latcheo... la desactiva cuando finaliza el proceso de latcheo o cuando se cancela el proceso."@es .

ns1:Palpador_868 a ns1:Sensor ;
    rdfs:label "Palpador"@es ;
    ns1:textoExtracto "eje con el palpador indicado"@es .

