@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:PlatoDivisor a ex:PiezaRecambio ;
    ex:identificador "DVPE-320" ;
    ex:textoExtracto "Plato divisor" ;
    ex:valor "1" .

ex:Servomotor a ex:ComponenteElectrico ;
    ex:identificador "1FK7060-5AF71-1EA5" ;
    ex:textoExtracto "Servomotor" ;
    ex:valor "1" .

ex:EsquemaChap8 a ex:Esquema ;
    ex:textoExtracto "Figura 8-2. Elementos comerciales y de desgaste del plato divisor" .

ex:EsquemaChap8 ex:tieneComponente ex:PlatoDivisor, ex:Servomotor .

ex:CilindroNeumatico a ex:ComponenteHidraulico ;
    ex:identificador "MGPM25TF 100Z" ;
    ex:textoExtracto "Cilindro neumático" ;
    ex:valor "1" .

ex:Cepillo a ex:PiezaRecambio ;
    ex:identificador "STRIP N3 5-19x45" ;
    ex:textoExtracto "Cepillo" ;
    ex:valor "12" .

ex:EsquemaChap8SistemaLimpieza a ex:Esquema ;
    ex:textoExtracto "Figura 8-3. Elementos comerciales y de desgaste del sistema limpieza brocha" .

ex:EsquemaChap8SistemaLimpieza ex:tieneComponente ex:CilindroNeumatico, ex:Cepillo .