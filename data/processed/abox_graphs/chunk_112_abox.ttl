@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:PlatoDivisor a owl:Class ;
    rdfs:label "Plato divisor"@es .

ex:Servomotor a owl:Class ;
    rdfs:label "Servomotor"@es .

ex:CilindroNeumatico a owl:Class ;
    rdfs:label "Cilindro neumático"@es .

ex:Cepillo a owl:Class ;
    rdfs:label "Cepillo"@es .

ex:BrochadoraElectromecanicaDeExteriores a owl:Class ;
    rdfs:label "Brochadora electromecánica de exteriores"@es .

ex:SistemaLimpiezaBrocha a owl:Class ;
    rdfs:label "Sistema de limpieza brocha"@es .

ex:Carenado a owl:Class ;
    rdfs:label "Carenado"@es .

ex:tieneElementoComercial a owl:ObjectProperty ;
    rdfs:domain ex:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range owl:Class .

ex:tieneElementoDeDesgaste a owl:ObjectProperty ;
    rdfs:domain ex:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range owl:Class .

ex:tieneProveedor a owl:ObjectProperty ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:string .

ex:tieneReferencia a owl:DatatypeProperty ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:string .

ex:tieneCantidad a owl:DatatypeProperty ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:integer .

ex:tieneDescripcion a owl:DatatypeProperty ;
    rdfs:domain owl:Class ;
    rdfs:range xsd:string .

ex:tieneModelo a owl:DatatypeProperty ;
    rdfs:domain ex:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range xsd:string ;
    rdfs:comment "Modelo A218 / RASHEM - 7x3000x500" .