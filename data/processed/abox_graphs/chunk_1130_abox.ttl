@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:ActivaEstaMarcaAlActivarUnProcesoDeLatcheoEnElEjeConElPalpadorIndicado a ns1:ComponenteMecanico ;
    ns1:textoExtracto "activa esta marca al activar un proceso de latcheo en el eje con el palpador indicado" .

ns1:ElPalpador1SeraElAsignadoAlParametroPRBDI1 a ns1:Sensor ;
    ns1:textoExtracto "el palpador 1 será el asignado al parámetro PRBDI1" .

ns1:ElPalpador1SeraElAsignadoAlParametroPRBDI1_1d1cafeae8 a ns1:Parametro ;
    ns1:textoExtracto "el palpador 1 será el asignado al parámetro PRBDI1" ;
    ns1:valor "PRBDI1" .

ns1:ElPalpador2SeraElAsignadoAlParametroPRBDI2 a ns1:Sensor ;
    ns1:textoExtracto "el palpador 2 será el asignado al parámetro PRBDI2" .

ns1:ElPalpador2SeraElAsignadoAlParametroPRBDI2_7b88d787ce a ns1:Parametro ;
    ns1:textoExtracto "el palpador 2 será el asignado al parámetro PRBDI2" ;
    ns1:valor "PRBDI2" .

ns1:Marca_FOLLOW_Axis a ns1:Parametro ;
    ns1:textoExtracto "el interpolador del eje activa esta marca cuando está activa la sincronización en el eje (#FOLLOW)" ;
    ns1:valor "FOLLOW(axis)" .

ns1:Marca_IRESET_Axis a ns1:Parametro ;
    ns1:textoExtracto "Si el PLC activa la marca IRESET(axis) se cancela el proceso de latcheo en el eje" ;
    ns1:valor "IRESET(axis)" .

ns1:Marca_LATCH1DONE_Axis a ns1:Parametro ;
    ns1:textoExtracto "activa esta marca al activar un proceso de latcheo en el eje con el palpador indicado; la desactiva cuando finaliza el proceso de latcheo o cuando se cancela el proceso" ;
    ns1:valor "LATCH1DONE(axis)" .

ns1:Marca_LATCH2DONE_Axis a ns1:Parametro ;
    ns1:textoExtracto "Se aplica al proceso de latcheo de la cota de un eje. Hay una marca para cada palpador" ;
    ns1:valor "LATCH2DONE(axis)" .

ns1:Marca_MOVCMD_Axis a ns1:Parametro ;
    ns1:textoExtracto "el interpolador del eje activa esta marca cuando está ejecutando un posicionamiento (#MOVE)" ;
    ns1:valor "MOVCMD(axis)" .

ns1:Proceso_Latcheo a ns1:TareaMantenimiento ;
    ns1:textoExtracto "activa esta marca al activar un proceso de latcheo en el eje con el palpador indicado; la desactiva cuando finaliza el proceso de latcheo o cuando se cancela el proceso" .

ns1:UnResetDelCanalCancelaLosProcesosDeLatcheoEnTodosLosEjesDelCanal a ns1:ComponenteElectrico ;
    ns1:textoExtracto "Un reset del canal cancela los procesos de latcheo en todos los ejes del canal" .

