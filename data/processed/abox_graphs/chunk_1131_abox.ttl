@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Marca_ACTIVEMATERIALON a ns1:Parametro ;
    rdfs:label "ACTIVEMATERIALON" ;
    ns1:textoExtracto "El CNC activa esta marca cuando hay un fichero de material activo (por la ejecución de #MATERIAL, #TECHTABLE, por activación desde HMI o por recuperación en el arranque)." ;
    ns1:valor true .

ns1:Subrutina_Cuttingoff.fst a ns1:TareaMantenimiento ;
    rdfs:label "Cuttingoff.fst" ;
    ns1:controla ns1:Marca_CUTTING ;
    ns1:textoExtracto "subrutina asociada al cutting (por defecto, Cuttingoff.fst)" .

ns1:Subrutina_Cuttingon.fst a ns1:TareaMantenimiento ;
    rdfs:label "Cuttingon.fst" ;
    ns1:controla ns1:Marca_CUTTING ;
    ns1:textoExtracto "subrutina asociada al cutting (por defecto, Cuttingon.fst)" .

ns1:Subrutina_Piercing.fst a ns1:TareaMantenimiento ;
    rdfs:label "Piercing.fst" ;
    ns1:controla ns1:Marca_PIERCING ;
    ns1:textoExtracto "subrutina asociada al piercing (por defecto, Piercing.fst)" .

ns1:Tabla_ParametrosPiercingCutting a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de piercing/cutting" ;
    ns1:documentadoEn ns1:Marca_COMVARACT,
        ns1:Marca_CUTVARACT ;
    ns1:textoExtracto "tabla de piercing o cutting activa" .

ns1:Variable_V.PLC.CUTTING a ns1:Parametro ;
    rdfs:label "V.PLC.CUTTING" ;
    ns1:monitoreaParametro ns1:Marca_CUTTING ;
    ns1:textoExtracto "Esta marca refleja el estado de la variable V.PLC.CUTTING. El OEM también puede utilizar esta variable en las subrutinas asociadas al cutting (por defecto, Cuttingon.fst / Cuttingoff.fst), para modificar el estado de esta marca." .

ns1:Variable_V.PLC.PIERCING a ns1:Parametro ;
    rdfs:label "V.PLC.PIERCING" ;
    ns1:monitoreaParametro ns1:Marca_PIERCING ;
    ns1:textoExtracto "Esta marca refleja el estado de la variable V.PLC.PIERCING. El OEM también puede utilizar esta variable en la subrutina asociada al piercing (por defecto, Piercing.fst), para modificar el estado de esta marca." .

ns1:Marca_COMVARACT a ns1:Parametro ;
    rdfs:label "COMVARACT" ;
    ns1:textoExtracto "El CNC activa esta marca cuando el usuario valida los parámetros comunes de la tabla de piercing o cutting activa. El PLC debe desactivar esta marca cuando termina su gestión con estas variables." ;
    ns1:valor true .

ns1:Marca_CUTVARACT a ns1:Parametro ;
    rdfs:label "CUTVARACT" ;
    ns1:textoExtracto "El CNC activa esta marca cuando el usuario valida los parámetros de cutting de la tabla activa. El PLC debe desactivar esta marca cuando termina su gestión con estas variables." ;
    ns1:valor true .

ns1:Marca_PIERCING a ns1:Parametro ;
    rdfs:label "PIERCING" ;
    ns1:textoExtracto "Piercing activo. El OEM debe gestionar esta marca desde la subrutina asociada al piercing (por defecto, Piercing.fst), para indicar al PLC cuando empieza (valor 1) y acaba (valor 0) la operación de piercing." ;
    ns1:valor false,
        true .

ns1:Marca_CUTTING a ns1:Parametro ;
    rdfs:label "CUTTING" ;
    ns1:textoExtracto "Cutting activo. El OEM debe gestionar esta marca desde las subrutinas asociadas al cutting (por defecto, Cuttingon.fst / Cuttingoff.fst), para indicar al PLC cuando empieza (valor 1) y acaba (valor 0) la operación de cutting." ;
    ns1:valor false,
        true .

