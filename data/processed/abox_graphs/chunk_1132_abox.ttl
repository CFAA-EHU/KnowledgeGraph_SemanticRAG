@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_CUTVARACT a ns1:ComponenteElectrico ;
    rdfs:label "Marca CUTVARACT" ;
    ns1:identificador "CUTVARACT" ;
    ns1:textoExtracto "El PLC debe desactivar esta marca cuando termina su gestión con estas variables. CUTVARACT El CNC activa esta marca cuando el usuario valida los parámetros de cutting de la tabla activa."@es .

ns1:Parametro_TipoCutting a ns1:Parametro ;
    rdfs:label "Parámetro tipo de cutting" ;
    ns1:identificador "#CUTTING ON" ;
    ns1:textoExtracto "el tipo de cutting (#CUTTING ON)"@es .

ns1:Subrutina_Cuttingon.fst a ns1:Sistema ;
    rdfs:label "Subrutina Cuttingon.fst" ;
    ns1:identificador "Cuttingon.fst" ;
    ns1:textoExtracto "Cuando la subrutina Cuttingon.fst sólo cambia el tipo de cutting (#CUTTING ON), el CNC no activa esta marca ya que la sincronización con el PLC es a través"@es .

