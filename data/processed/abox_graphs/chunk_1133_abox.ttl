@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC" ;
    ns1:controla ns1:Marca_INPOSGAP,
        ns1:Marca_PIRVARACT ;
    ns1:textoExtracto "El PLC gestiona los efectos de estas variables sobre los dispositivos de la máquina (salidas analógicas, digitales, etc)" ;
    ns1:tieneComponente ns1:Subrutina_Cuttingon_fst,
        ns1:Subrutina_Piercing_fst .

ns1:Parametro_GAPERRORCANCEL a ns1:Parametro ;
    rdfs:label "GAPERRORCANCEL" ;
    ns1:identificador "GAPERRORCANCEL" ;
    ns1:textoExtracto "El parámetro GAPERRORCANCEL establece el comportamiento del CNC cuando el gap sobrepasa el rango GAPMIN - GAPMAX" .

ns1:Parametro_GAPMAX a ns1:Parametro ;
    rdfs:label "GAPMAX" ;
    ns1:identificador "GAPMAX" ;
    ns1:textoExtracto "parámetro GAPMAX" .

ns1:Parametro_GAPMIN a ns1:Parametro ;
    rdfs:label "GAPMIN" ;
    ns1:identificador "GAPMIN" ;
    ns1:textoExtracto "parámetro GAPMIN" .

ns1:Tabla_Tecnologica a ns1:Tabla ;
    rdfs:label "Tabla tecnológica" ;
    ns1:documentadoEn ns1:Manual_Maquina ;
    ns1:textoExtracto "las variables asociadas a las tablas tecnológicas, operaciones que también pueden ser necesarias cuando el usuario modifique la tabla directamente" .

ns1:Manual_Maquina a ns1:Manual ;
    rdfs:label "Manual de la máquina" ;
    ns1:textoExtracto "Sección 6.5 Señales lógicas de consulta; láser" .

ns1:Marca_INPOSGAP a ns1:Parametro ;
    rdfs:label "INPOSGAP" ;
    ns1:identificador "INPOSGAP" ;
    ns1:textoExtracto "El CNC activa esta marca si el gap está dentro del rango definido por los parámetros GAPMIN-GAPMAX" .

ns1:Marca_PIRVARACT a ns1:Parametro ;
    rdfs:label "PIRVARACT" ;
    ns1:identificador "PIRVARACT" ;
    ns1:textoExtracto "El CNC activa esta marca cuando el usuario valida los parámetros de piercing de la tabla activa. El PLC debe desactivar esta marca cuando termina su gestión con estas variables" .

ns1:Parametro_TipoCutting a ns1:Parametro ;
    rdfs:label "#CUTTING ON" ;
    ns1:identificador "#CUTTING ON" ;
    ns1:textoExtracto "el tipo de cutting (#CUTTING ON)" .

ns1:Parametro_TipoPiercing a ns1:Parametro ;
    rdfs:label "#PIERCING" ;
    ns1:identificador "#PIERCING" ;
    ns1:textoExtracto "el tipo de piercing (#PIERCING)" .

ns1:Subrutina_Cuttingon_fst a ns1:Componente ;
    rdfs:label "Subrutina Cuttingon.fst" ;
    ns1:monitoreaParametro ns1:Parametro_TipoCutting ;
    ns1:textoExtracto "la subrutina Cuttingon.fst (o la asociada al proceso de cutting) realiza un serie de operaciones con las variables asociadas a las tablas tecnológicas" .

ns1:Subrutina_Piercing_fst a ns1:Componente ;
    rdfs:label "Subrutina Piercing.fst" ;
    ns1:monitoreaParametro ns1:Parametro_TipoPiercing ;
    ns1:textoExtracto "la subrutina Piercing.fst (o la asociada al proceso de piercing) realiza un serie de operaciones con las variables asociadas a las tablas tecnológicas" .

