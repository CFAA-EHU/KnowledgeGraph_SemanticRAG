@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_GAPERRORCANCEL a ns1:Parametro ;
    rdfs:label "GAPERRORCANCEL" ;
    ns1:documentadoEn ns1:Tabla_Se_alesLogicasConsultaLaser ;
    ns1:identificador "GAPERRORCANCEL" ;
    ns1:textoExtracto "| GAPERRORCANCEL | Significado. | --- | --- | Sí. | El CNC anula el error de gap fuera del rango y no detiene el movimiento de los ejes. | No | El CNC da error de gap fuera del rango y detiene el movimiento de los ejes, respetando la rampa de frenado y controlando el gap durante la rampa." .

ns1:Parametro_GAPTOLCANCEL a ns1:Parametro ;
    rdfs:label "GAPTOLCANCEL" ;
    ns1:documentadoEn ns1:Tabla_Se_alesLogicasConsultaLaser ;
    ns1:identificador "GAPTOLCANCEL" ;
    ns1:monitoreaParametro ns1:Parametro_GAPTOL ;
    ns1:textoExtracto "| GAPTOLCANCEL | Significado. | --- | --- | Sí. | El CNC anula el error de gap fuera del rango y no detiene el movimiento de los ejes. | No | El CNC da error de gap fuera del rango y detiene el movimiento de los ejes, respetando la rampa de frenado y controlando el gap durante la rampa." .

ns1:Parametro_POSLIMIT a ns1:Parametro ;
    rdfs:label "POSLIMIT" ;
    ns1:documentadoEn ns1:Tabla_Se_alesLogicasConsultaLaser ;
    ns1:identificador "POSLIMIT" ;
    ns1:textoExtracto "El CNC activa esta marca (cambio de 0 a 1) cuando el salto programado con un #LEAP alcanza el punto más alto (comando POSLIMIT)." .

ns1:Pagina_428_429 a ns1:Pagina ;
    rdfs:label "Páginas 428-429" ;
    ns1:identificador "428-429" ;
    ns1:textoExtracto "Sección 6.5 Señales lógicas de consulta; láser." .

ns1:Parametro_GAPTOL a ns1:Parametro ;
    rdfs:label "GAPTOL" ;
    ns1:documentadoEn ns1:Tabla_Se_alesLogicasConsultaLaser ;
    ns1:identificador "GAPTOL" ;
    ns1:textoExtracto "El CNC activa esta marca si el gap está dentro de la tolerancia definida por el parámetro GAPTOL, respecto el valor de gap programado." .

ns1:Tabla_Se_alesLogicasConsultaLaser a ns1:Tabla ;
    rdfs:label "Tabla de señales lógicas de consulta (láser)" ;
    ns1:documentadoEn ns1:Pagina_428_429 ;
    ns1:textoExtracto "Sección 6.5 Señales lógicas de consulta; láser." .

