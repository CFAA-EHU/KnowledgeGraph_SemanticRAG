    ns1:monitoreaParametro ns1:InterfazGestorHerramientas ;
    ns1:textoExtracto "TAKEPOSMZ4. Este registro indica la posición de almacén que ocupa la herramienta que hay que coger."@es .

ns1:Registro_TMOPERATIONC1 a ns1:Parametro ;
    rdfs:label "TMOPERATIONC1"@es ;
    ns1:identificador "TMOPERATIONC1" ;
    ns1:monitoreaParametro ns1:InterfazGestorHerramientas ;
    ns1:textoExtracto "TMOPERATIONC1 (equivalente a TMOPERATION). Este registro indica el tipo de operación que desea realizar el gestor de herramientas."@es .

ns1:Registro_TMOPERATIONC2 a ns1:Parametro ;
    rdfs:label "TMOPERATIONC2"@es ;
    ns1:identificador "TMOPERATIONC2" ;
    ns1:monitoreaParametro ns1:InterfazGestorHerramientas ;
    ns1:textoExtracto "TMOPERATIONC2. Este registro indica el tipo de operación que desea realizar el gestor de herramientas."@es .

ns1:Registro_TMOPERATIONC3 a ns1:Parametro ;
    rdfs:label "TMOPERATIONC3"@es ;
    ns1:identificador "TMOPERATIONC3" ;
