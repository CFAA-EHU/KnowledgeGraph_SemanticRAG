@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_TMOPSTROBEC1 a ns1:Parametro ;
    rdfs:label "TMOPSTROBEC1"@es ;
    ns1:identificador "TMOPSTROBEC1" ;
    ns1:monitoreaParametro ns1:InterfazGestorHerramientas ;
    ns1:textoExtracto "TMOPSTROBEC1 (equivalente a TMOPSTROBE). El canal del CNC pone esta marca a (=1) para indicar al PLC que debe ejecutar la operación indicada en TMOPERATION."@es .

ns1:Marca_TMOPSTROBEC2 a ns1:Parametro ;
    rdfs:label "TMOPSTROBEC2"@es ;
    ns1:identificador "TMOPSTROBEC2" ;
    ns1:monitoreaParametro ns1:InterfazGestorHerramientas ;
    ns1:textoExtracto "TMOPSTROBEC2. El canal del CNC pone esta marca a (=1) para indicar al PLC que debe ejecutar la operación indicada en TMOPERATION."@es .

ns1:Marca_TMOPSTROBEC3 a ns1:Parametro ;
    rdfs:label "TMOPSTROBEC3"@es ;
    ns1:identificador "TMOPSTROBEC3" ;
    ns1:monitoreaParametro ns1:InterfazGestorHerramientas ;
    ns1:textoExtracto "TMOPSTROBEC3. El canal del CNC pone esta marca a (=1) para indicar al PLC que debe ejecutar la operación indicada en TMOPERATION."@es .

ns1:Marca_TMOPSTROBEC4 a ns1:Parametro ;
    rdfs:label "TMOPSTROBEC4"@es ;
    ns1:identificador "TMOPSTROBEC4" ;
    ns1:monitoreaParametro ns1:InterfazGestorHerramientas ;
    ns1:textoExtracto "TMOPSTROBEC4. El canal del CNC pone esta marca a (=1) para indicar al PLC que debe ejecutar la operación indicada en TMOPERATION."@es .

ns1:Registro_LEAVEPOSMZ1 a ns1:Parametro ;
    rdfs:label "LEAVEPOSMZ1"@es ;
    ns1:identificador "LEAVEPOSMZ1" ;
    ns1:monitoreaParametro ns1:InterfazGestorHerramientas ;
    ns1:textoExtracto "LEAVEPOSMZ1 (también se puede programar como LEAVEPOS). Este registro indica la posición de almacén en la que hay que dejar la herramienta. Durante la selección de una posición de la torreta (sentencia #ROTATEMZ), este registro tomará valor ꞏ0ꞏ si es un posicionamiento relativo positivo y valor ꞏ1ꞏ si es un posicionamiento relativo negativo."@es .

ns1:Registro_LEAVEPOSMZ2 a ns1:Parametro ;
    rdfs:label "LEAVEPOSMZ2"@es ;
    ns1:identificador "LEAVEPOSMZ2" ;
    ns1:monitoreaParametro ns1:InterfazGestorHerramientas ;
    ns1:textoExtracto "LEAVEPOSMZ2. Este registro indica la posición de almacén en la que hay que dejar la herramienta."@es .

ns1:Registro_LEAVEPOSMZ3 a ns1:Parametro ;
    rdfs:label "LEAVEPOSMZ3"@es ;
    ns1:identificador "LEAVEPOSMZ3" ;
    ns1:monitoreaParametro ns1:InterfazGestorHerramientas ;
    ns1:textoExtracto "LEAVEPOSMZ3. Este registro indica la posición de almacén en la que hay que dejar la herramienta."@es .

ns1:Registro_LEAVEPOSMZ4 a ns1:Parametro ;
    rdfs:label "LEAVEPOSMZ4"@es ;
    ns1:identificador "LEAVEPOSMZ4" ;
    ns1:monitoreaParametro ns1:InterfazGestorHerramientas ;
    ns1:textoExtracto "LEAVEPOSMZ4. Este registro indica la posición de almacén en la que hay que dejar la herramienta."@es .

ns1:Registro_TAKEPOSMZ1 a ns1:Parametro ;
    rdfs:label "TAKEPOSMZ1"@es ;
    ns1:identificador "TAKEPOSMZ1" ;
    ns1:monitoreaParametro ns1:InterfazGestorHerramientas ;
    ns1:textoExtracto "TAKEPOSMZ1 (también se puede programar como TAKEPOS). Este registro indica la posición de almacén que ocupa la herramienta que hay que coger. Durante la selección de una posición de la torreta (sentencia #ROTATEMZ), este registro tomará valor ꞏ0ꞏ si es un posicionamiento absoluto y valor ꞏ1ꞏ si es un posicionamiento relativo."@es .

ns1:Registro_TAKEPOSMZ2 a ns1:Parametro ;
    rdfs:label "TAKEPOSMZ2"@es ;
    ns1:identificador "TAKEPOSMZ2" ;
    ns1:monitoreaParametro ns1:InterfazGestorHerramientas ;
    ns1:textoExtracto "TAKEPOSMZ2. Este registro indica la posición de almacén que ocupa la herramienta que hay que coger."@es .

