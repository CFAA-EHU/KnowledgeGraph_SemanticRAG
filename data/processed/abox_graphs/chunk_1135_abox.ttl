ns1:Registro_TMOPERATIONC4 a ns1:Parametro ;
    rdfs:label "TMOPERATIONC4"@es ;
    ns1:identificador "TMOPERATIONC4" ;
    ns1:monitoreaParametro ns1:InterfazGestorHerramientas ;
    ns1:textoExtracto "TMOPERATIONC4. Este registro indica el tipo de operación que desea realizar el gestor de herramientas."@es .

ns1:InterfazGestorHerramientas a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de señales del gestor de herramientas"@es ;
    ns1:textoExtracto "Señales de consulta del gestor de herramientas. TMOPERATION [...] TAKEPOS [...] NEXTPOS"@es ;
    ns1:tieneComponente ns1:Marca_TMOPSTROBEC1,
        ns1:Marca_TMOPSTROBEC2,
        ns1:Marca_TMOPSTROBEC3,
        ns1:Marca_TMOPSTROBEC4,
        ns1:Registro_LEAVEPOSMZ1,
        ns1:Registro_LEAVEPOSMZ2,
        ns1:Registro_LEAVEPOSMZ3,
        ns1:Registro_LEAVEPOSMZ4,
        ns1:Registro_TAKEPOSMZ1,
        ns1:Registro_TAKEPOSMZ2,
        ns1:Registro_TAKEPOSMZ3,
        ns1:Registro_TAKEPOSMZ4,
        ns1:Registro_TMOPERATIONC1,
        ns1:Registro_TMOPERATIONC2,
        ns1:Registro_TMOPERATIONC3,
        ns1:Registro_TMOPERATIONC4 .

