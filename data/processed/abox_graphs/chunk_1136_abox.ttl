@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:RegistroNEXTPOS a ns1:InterfazUsuario ;
    rdfs:label "Registro NEXTPOS" ;
    ns1:textoExtracto "NEXTPOS Hay un registro para cada almacén. Los mnemónicos para cada almacén son los siguientes. NEXTPOSMZ1 (también se puede programar como NEXTPOS) NEXTPOSMZ2 NEXTPOSMZ3 NEXTPOSMZ4 Este registro indica la posición de almacén que ocupa la siguiente herramienta." ;
    ns1:tieneComponente ns1:NEXTPOSMZ1,
        ns1:NEXTPOSMZ2,
        ns1:NEXTPOSMZ3,
        ns1:NEXTPOSMZ4 .

ns1:SentenciaROTATEMZ a ns1:ModoOperacion ;
    rdfs:label "#ROTATEMZ" ;
    ns1:identificador "#ROTATEMZ" ;
    ns1:monitoreaParametro ns1:NEXTPOSMZ1,
        ns1:NEXTPOSMZ2,
        ns1:NEXTPOSMZ3,
        ns1:NEXTPOSMZ4 ;
    ns1:textoExtracto "sentencia #ROTATEMZ" .

ns1:NEXTPOSMZ1 a ns1:Parametro ;
    rdfs:label "NEXTPOSMZ1" ;
    ns1:identificador "NEXTPOSMZ1" ;
    ns1:textoExtracto "NEXTPOSMZ1 (también se puede programar como NEXTPOS)" ;
    ns1:valor "Posición de almacén para siguiente herramienta"^^xsd:string .

ns1:NEXTPOSMZ2 a ns1:Parametro ;
    rdfs:label "NEXTPOSMZ2" ;
    ns1:identificador "NEXTPOSMZ2" ;
    ns1:textoExtracto "NEXTPOSMZ2" .

ns1:NEXTPOSMZ3 a ns1:Parametro ;
    rdfs:label "NEXTPOSMZ3" ;
    ns1:identificador "NEXTPOSMZ3" ;
    ns1:textoExtracto "NEXTPOSMZ3" .

ns1:NEXTPOSMZ4 a ns1:Parametro ;
    rdfs:label "NEXTPOSMZ4" ;
    ns1:identificador "NEXTPOSMZ4" ;
    ns1:textoExtracto "NEXTPOSMZ4" .

