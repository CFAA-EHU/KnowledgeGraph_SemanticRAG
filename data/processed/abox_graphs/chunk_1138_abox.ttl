@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RegistroMZID a ns1:InterfazUsuario ;
    rdfs:label "Registro MZID" ;
    ns1:textoExtracto "Hay un registro para cada canal. Los mnemónicos para cada canal son los siguientes. MZIDC1 MZIDC2 MZIDC3 MZIDC4 Este registro indica el almacén en el que se encuentra la herramienta que ha solicitado el canal." ;
    ns1:tieneComponente ns1:CanalMZIDC1,
        ns1:CanalMZIDC2,
        ns1:CanalMZIDC3,
        ns1:CanalMZIDC4 .

ns1:CanalMZIDC1 a ns1:Componente ;
    rdfs:label "Canal MZIDC1" ;
    ns1:identificador "MZIDC1" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. MZIDC1" .

ns1:CanalMZIDC2 a ns1:Componente ;
    rdfs:label "Canal MZIDC2" ;
    ns1:identificador "MZIDC2" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. MZIDC2" .

ns1:CanalMZIDC3 a ns1:Componente ;
    rdfs:label "Canal MZIDC3" ;
    ns1:identificador "MZIDC3" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. MZIDC3" .

ns1:CanalMZIDC4 a ns1:Componente ;
    rdfs:label "Canal MZIDC4" ;
    ns1:identificador "MZIDC4" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. MZIDC4" .

