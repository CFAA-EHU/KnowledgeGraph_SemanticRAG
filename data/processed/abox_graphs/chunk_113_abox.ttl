@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Lampara a owl:Class ;
    rdfs:label "Lámpara"@es ;
    rdfs:comment "Componente de iluminación"@es .

ex:InterruptorSeguridadCodificadoPorTransponder a owl:Class ;
    rdfs:label "Interruptor de seguridad codificado por transponder"@es ;
    rdfs:comment "Interruptor de seguridad con codificación por transponder"@es .

ex:InterruptorSeguridadConContactoDeMonitorizacionDePuerta a owl:Class ;
    rdfs:label "Interruptor de seguridad con contacto de monitorización de puerta"@es ;
    rdfs:comment "Interruptor de seguridad con contacto para monitorización de puerta"@es .

ex:tieneElementoDeSeguridad a owl:ObjectProperty ;
    rdfs:domain ex:Carenado ;
    rdfs:range owl:Thing .

ex:tieneElementoDeDesgaste a owl:ObjectProperty ;
    rdfs:domain ex:Carenado ;
    rdfs:range owl:Thing .

ex:tieneCantidad a owl:DatatypeProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:integer .

ex:tieneReferencia a owl:DatatypeProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string .

ex:tieneProveedor a owl:DatatypeProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string .