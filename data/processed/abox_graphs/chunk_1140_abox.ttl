@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:teclasGenericas_6_7 a ns1:InterfazUsuario ;
    rdfs:label "Teclas genéricas" ;
    ns1:identificador "KEYBD2 / KEYBD2_1 a KEYBD2_8" ;
    ns1:textoExtracto "Teclas genéricas. Registros KEYBD2 / KEYBD2_1 a KEYBD2_8." ;
    ns1:tieneComponente ns1:selectorFeedOverride_6_7,
        ns1:selectorMovimiento_6_7,
        ns1:selectorSpeedOverride_6_7,
        ns1:volanteHBLS1_6_7,
        ns1:volanteHBLS2_6_7 .

ns1:selectorFeedOverride_6_7 a ns1:Componente ;
    rdfs:label "Selector del feed override" ;
    ns1:identificador "KEYBD2 / KEYBD2_1 a KEYBD2_8" ;
    ns1:textoExtracto "Selector del feed override. Registros KEYBD2 / KEYBD2_1 a KEYBD2_8." .

ns1:selectorMovimiento_6_7 a ns1:Componente ;
    rdfs:label "Selector de movimiento" ;
    ns1:identificador "KEYBD3 / KEYBD3_1 a KEYBD3_8" ;
    ns1:textoExtracto "Selector de movimiento (volante, jog incremental o jog continuo). Registros KEYBD3 / KEYBD3_1 a KEYBD3_8." .

ns1:selectorSpeedOverride_6_7 a ns1:Componente ;
    rdfs:label "Selector del speed override" ;
    ns1:identificador "KEYBD3 / KEYBD3_1 a KEYBD3_8" ;
    ns1:textoExtracto "Selector del speed override." .

ns1:volanteHBLS1_6_7 a ns1:Componente ;
    rdfs:label "Volante HBLS 1" ;
    ns1:identificador "KEYHBLS1" ;
    ns1:textoExtracto "KEYHBLS1 [...] corresponde al primer volante y [...] indica qué tecla se ha pulsado (bit=1)." .

ns1:volanteHBLS2_6_7 a ns1:Componente ;
    rdfs:label "Volante HBLS 2" ;
    ns1:identificador "KEYHBLS2" ;
    ns1:textoExtracto "KEYHBLS2 [...] corresponde al segundo volante y [...] indica qué tecla se ha pulsado (bit=1)." .

