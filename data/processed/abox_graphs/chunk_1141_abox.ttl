@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CYSTART a ns1:Parametro ;
    rdfs:label "CYSTART" ;
    ns1:textoExtracto "Para poder continuar con la ejecución del programa, además de poner esta marca a a nivel lógico alto, el PLC debe activar la marca CYSTART. Ver en \"CYSTART\" la página 437." ;
    ns1:valor "marca de inicio de ciclo del CNC" .

ns1:EMERGEN a ns1:Parametro ;
    rdfs:label "_EMERGEN" ;
    ns1:textoExtracto "Las señales _EMERGEN, _STOP, _FEEDHOL, _XFERINH y CYSTART deben estar definidas en el programa de PLC. _ EMERGEN Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. _ EMERGENC1 (también se puede programar como _EMERGEN) _EMERGENC2 _EMERGENC3 _EMERGENC4 Si el PLC pone esta marca a (=0), el CNC detiene el avance de los ejes y el giro del cabezal, visualizando en la pantalla el error correspondiente. El CNC detiene el avance de los ejes dejando de enviarles consigna; los ejes no se detienen siguiendo una rampa de deceleración establecida. Mientras la marca _EMERGEN está a (=0) el canal del CNC prohíbe la ejecución de programas y aborta cualquier intento de movimiento de los ejes o de cabezal. I-EMERG AND (resto de condiciones) = _EMERGEN Si se pulsa la seta de emergencia (I-EMERG=0) o se produce cualquier otra causa de emergencia (=0), la marca _EMERGEN se pone a (=0), produciéndose emergencia en el CNC." ;
    ns1:valor "marca de emergencia del CNC" .

ns1:STOP a ns1:Parametro ;
    rdfs:label "_STOP" ;
    ns1:textoExtracto "Si el PLC pone esta marca a nivel lógico bajo, el canal del CNC detiene la ejecución del programa pieza. Para poder continuar con la ejecución del programa, además de poner esta marca a a nivel lógico alto, el PLC debe activar la marca CYSTART. Ver en \"CYSTART\" la página 437. • Esta marca no detiene el giro del cabezal. • Esta marca no afecta al movimiento independiente de un eje (interpolador independiente), al que tampoco afecta la tecla [STOP]. • Esta marca no apaga el láser. • Esta marca no desactiva el control del gap, excepto en el movimiento de aproximación." ;
    ns1:valor "marca de parada del CNC" .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "el CNC detiene el avance de los ejes y el giro del cabezal, visualizando en la pantalla el error correspondiente. El CNC detiene el avance de los ejes dejando de enviarles consigna; los ejes no se detienen siguiendo una rampa de deceleración establecida. Mientras la marca _EMERGEN está a (=0) el canal del CNC prohíbe la ejecución de programas y aborta cualquier intento de movimiento de los ejes o de cabezal." .

ns1:TeclaSTOP a ns1:InterfazUsuario ;
    rdfs:label "[STOP]" ;
    ns1:textoExtracto "al que tampoco afecta la tecla [STOP]" .

