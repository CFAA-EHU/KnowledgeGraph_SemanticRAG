@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Se_al_XFERINH a ns1:InterfazUsuario ;
    rdfs:label "Señal _XFERINH" ;
    ns1:documentadoEn ns1:SistemaControlCNC ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para _XFERINH" .

ns1:Se_al_STOP a ns1:InterfazUsuario ;
    rdfs:label "Señal _STOP" ;
    ns1:textoExtracto "El tratamiento que recibe la señal _STOP es similar al que recibe la tecla [STOP] del CNC. Con esta señal a nivel lógico bajo, todas las teclas permanecen habilitadas." .

ns1:SistemaControlCNC a ns1:Sistema ;
    rdfs:label "Sistema de control CNC" ;
    ns1:textoExtracto "El tratamiento que recibe la señal _STOP es similar al que recibe la tecla [STOP] del CNC." ;
    ns1:tieneComponente ns1:Se_al_STOP,
        ns1:Tecla_STOP .

ns1:Tecla_STOP a ns1:InterfazUsuario ;
    rdfs:label "Tecla [STOP]" ;
    ns1:textoExtracto "Esta marca no afecta al movimiento independiente de un eje (interpolador independiente), al que tampoco afecta la tecla [STOP]." .

