@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Bloque_CNC a ns1:Componente ;
    rdfs:label "bloque" ;
    ns1:textoExtracto "al final del bloque que se está ejecutando" .

ns1:Canal_CNC a ns1:Sistema ;
    rdfs:label "canal del CNC" ;
    ns1:textoExtracto "el canal del CNC detiene la ejecución del programa al final del bloque que se está ejecutando" .

ns1:Eje_CNC a ns1:ComponenteMecanico ;
    rdfs:label "eje" ;
    ns1:textoExtracto "el eje necesita para frenar más espacio del que dispone con el bloque en ejecución" .

ns1:Marca_XFERINH a ns1:Parametro ;
    rdfs:label "_XFERINH" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. _ XFERINHC1 (también se puede programar como _XFERINH) _XFERINHC2 _XFERINHC3 _XFERINHC4" .

ns1:Marca_XFERINHC1 a ns1:Parametro ;
    rdfs:label "_XFERINHC1" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. _ XFERINHC1 (también se puede programar como _XFERINH)" .

ns1:Marca_XFERINHC2 a ns1:Parametro ;
    rdfs:label "_XFERINHC2" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. ... _XFERINHC2 ..." .

ns1:Marca_XFERINHC3 a ns1:Parametro ;
    rdfs:label "_XFERINHC3" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. ... _XFERINHC3 ..." .

ns1:Marca_XFERINHC4 a ns1:Parametro ;
    rdfs:label "_XFERINHC4" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. ... _XFERINHC4" .

ns1:Movimiento_Jog a ns1:AccionProhibida ;
    rdfs:label "movimientos en jog" ;
    ns1:textoExtracto "Con la marca a (=0) el CNC no permite movimientos en jog para los ejes del canal; la pulsación de una tecla de jog no tiene efecto" .

ns1:PLC a ns1:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ns1:textoExtracto "Si el PLC pone esta marca a (=0)" .

ns1:Programa_CNC a ns1:Componente ;
    rdfs:label "programa" ;
    ns1:textoExtracto "detiene la ejecución del programa" .

ns1:Senal_STOP a ns1:Sensor ;
    rdfs:label "señal _STOP" ;
    ns1:textoExtracto "señal _STOP es similar al que recibe la tecla [STOP] del CNC" .

ns1:Tecla_Jog a ns1:InterfazUsuario ;
    rdfs:label "tecla de jog" ;
    ns1:textoExtracto "la pulsación de una tecla de jog no tiene efecto" .

ns1:Tecla_STOP a ns1:InterfazUsuario ;
    rdfs:label "[STOP]" ;
    ns1:textoExtracto "la tecla [STOP] del CNC" .

