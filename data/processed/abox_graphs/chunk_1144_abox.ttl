@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_XFERINH a ns1:Parametro ;
    rdfs:label "Marca _XFERINH" ;
    ns1:mitigaRiesgo ns1:MovimientoEjeIndependiente,
        ns1:MovimientoJog ;
    ns1:textoExtracto "la marca _XFERINH" ;
    ns1:valor "_XFERINH" .

ns1:Marca_a a ns1:Parametro ;
    rdfs:label "Marca a (=0)" ;
    ns1:textoExtracto "la marca a (=0)" ;
    ns1:valor "a (=0)" .

ns1:PLC a ns1:Sistema ;
    rdfs:label "PLC" ;
    ns1:controla ns1:MovimientoEjeIndependiente ;
    ns1:textoExtracto "el PLC" .

ns1:Parametro_XFITOIND a ns1:Parametro ;
    rdfs:label "Parámetro XFITOIND" ;
    ns1:controla ns1:MovimientoEjeIndependiente ;
    ns1:textoExtracto "el parámetro XFITOIND" ;
    ns1:valor "XFITOIND" .

ns1:TeclaJog a ns1:InterfazUsuario ;
    rdfs:label "Tecla de jog" ;
    ns1:ejecutadoPor ns1:CNC ;
    ns1:textoExtracto "una tecla de jog" .

ns1:CNC a ns1:Sistema ;
    rdfs:label "CNC" ;
    ns1:controla ns1:MovimientoEjeIndependiente,
        ns1:MovimientoJog ;
    ns1:textoExtracto "el CNC" .

ns1:MovimientoJog a ns1:AccionProhibida ;
    rdfs:label "Movimiento en jog" ;
    ns1:textoExtracto "movimientos en jog" .

ns1:MovimientoEjeIndependiente a ns1:AccionProhibida ;
    rdfs:label "Movimiento de eje independiente" ;
    ns1:textoExtracto "los movimientos de eje independiente" .

