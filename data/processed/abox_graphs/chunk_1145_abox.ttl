@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_XFERINH a ns1:Parametro ;
    rdfs:label "Marca _XFERINH"@es ;
    ns1:documentadoEn ns1:Tabla_XFITOIND ;
    ns1:identificador "_XFERINH" ;
    ns1:monitoreaParametro ns1:Sistema_CNC,
        ns1:Sistema_PLC ;
    ns1:textoExtracto "La marca _XFERINH afecta a los movimientos de eje independiente programados desde el PLC y CNC."@es .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "CNC"@es ;
    ns1:textoExtracto "movimientos de eje independiente programados desde el CNC"@es .

ns1:Sistema_PLC a ns1:Sistema ;
    rdfs:label "PLC"@es ;
    ns1:textoExtracto "movimientos de eje independiente programados desde el PLC"@es .

ns1:Tabla_XFITOIND a ns1:Tabla ;
    rdfs:label "Tabla de configuración de marca _XFITOIND"@es ;
    ns1:identificador "_XFITOIND" ;
    ns1:textoExtracto "XFITOIND | Significado." .

