@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_CYSTARTC1 a ns1:ComponenteElectrico ;
    rdfs:label "CYSTARTC1" ;
    ns1:identificador "CYSTARTC1" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. CYSTARTC1 (también se puede programar como CYSTART)."@es .

ns1:Marca_CYSTARTC2 a ns1:ComponenteElectrico ;
    rdfs:label "CYSTARTC2" ;
    ns1:identificador "CYSTARTC2" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. CYSTARTC2."@es .

ns1:Marca_CYSTARTC3 a ns1:ComponenteElectrico ;
    rdfs:label "CYSTARTC3" ;
    ns1:identificador "CYSTARTC3" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. CYSTARTC3."@es .

ns1:Marca_CYSTARTC4 a ns1:ComponenteElectrico ;
    rdfs:label "CYSTARTC4" ;
    ns1:identificador "CYSTARTC4" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. CYSTARTC4."@es .

ns1:Marca_FEEDHOLC1 a ns1:ComponenteElectrico ;
    rdfs:label "_FEEDHOLC1" ;
    ns1:controla ns1:Indicador_Freal ;
    ns1:identificador "_FEEDHOLC1" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. _FEEDHOLC1 (también se puede programar como _FEEDHOL)."@es .

ns1:Marca_FEEDHOLC2 a ns1:ComponenteElectrico ;
    rdfs:label "_FEEDHOLC2" ;
    ns1:controla ns1:Indicador_Freal ;
    ns1:identificador "_FEEDHOLC2" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. _FEEDHOLC2."@es .

ns1:Marca_FEEDHOLC3 a ns1:ComponenteElectrico ;
    rdfs:label "_FEEDHOLC3" ;
    ns1:controla ns1:Indicador_Freal ;
    ns1:identificador "_FEEDHOLC3" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. _FEEDHOLC3."@es .

ns1:Marca_FEEDHOLC4 a ns1:ComponenteElectrico ;
    rdfs:label "_FEEDHOLC4" ;
    ns1:controla ns1:Indicador_Freal ;
    ns1:identificador "_FEEDHOLC4" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. _FEEDHOLC4."@es .

ns1:Marca_IXFERINH a ns1:ComponenteElectrico ;
    rdfs:label "_IXFERINH(axis)" ;
    ns1:documentadoEn ns1:Pagina_457 ;
    ns1:identificador "_IXFERINH(axis)" ;
    ns1:textoExtracto "Para gestionar el transfer inhibit en un movimiento independiente, el PLC también dispone de una marca particular por eje (marca _IXFERINH(axis))."@es .

ns1:InterfazUsuario_ModoAutomatico a ns1:InterfazUsuario ;
    rdfs:label "Pantalla modo automático"@es ;
    ns1:textoExtracto "El texto \"Freal\" de las pantallas de los modos automático y manual muestra el estado de esta marca."@es .

ns1:InterfazUsuario_ModoManual a ns1:InterfazUsuario ;
    rdfs:label "Pantalla modo manual"@es ;
    ns1:textoExtracto "El texto \"Freal\" de las pantallas de los modos automático y manual muestra el estado de esta marca."@es .

ns1:Pagina_457 a ns1:Pagina ;
    rdfs:label "Página 457 (detalle _IXFERINH)" ;
    ns1:identificador "457" ;
    ns1:textoExtracto "Ver en la \"_IXFERINH(axis)\" página 457."@es .

ns1:Indicador_Freal a ns1:ComponenteElectrico ;
    rdfs:label "Indicador Freal"@es ;
    ns1:ilustradoEn ns1:InterfazUsuario_ModoAutomatico,
        ns1:InterfazUsuario_ModoManual ;
    ns1:textoExtracto "El texto \"Freal\" de las pantallas [...] aparece en color rojo cuando la marca _FEEDHOL está activa."@es .

