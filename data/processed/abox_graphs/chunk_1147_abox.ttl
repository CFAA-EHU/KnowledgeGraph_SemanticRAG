@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaControlEjecucion a ns1:Sistema ;
    rdfs:label "Sistema de control de ejecución CNC-PLC"@es ;
    ns1:textoExtracto "Cuando el operario pulsa la tecla [START] el canal del CNC se lo indica al PLC activando la marca START. Si se cumplen el resto de condiciones (hidráulico, seguridades, etc), el PLC debe activar la marca CYSTART para que comience la ejecución del programa."@es ;
    ns1:tieneComponente ns1:Marca_CYSTART,
        ns1:Marca_CYSTARTC1,
        ns1:Marca_CYSTARTC2,
        ns1:Marca_CYSTARTC3,
        ns1:Marca_CYSTARTC4,
        ns1:Marca_SBLOCK,
        ns1:Tecla_START .

ns1:Marca_CYSTART a ns1:ComponenteElectrico ;
    rdfs:label "Marca CYSTART (inicio de ejecución)"@es ;
    ns1:identificador "CYSTART" ;
    ns1:textoExtracto "Hay una marca para cada canal. [...] el PLC debe activar la marca CYSTART para que comience la ejecución del programa."@es .

ns1:Marca_CYSTARTC1 a ns1:ComponenteElectrico ;
    rdfs:label "Marca CYSTARTC1 (canal 1)"@es ;
    ns1:identificador "CYSTARTC1" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes: CYSTARTC1 (también se puede programar como CYSTART)"@es .

ns1:Marca_CYSTARTC2 a ns1:ComponenteElectrico ;
    rdfs:label "Marca CYSTARTC2 (canal 2)"@es ;
    ns1:identificador "CYSTARTC2" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes: CYSTARTC2"@es .

ns1:Marca_CYSTARTC3 a ns1:ComponenteElectrico ;
    rdfs:label "Marca CYSTARTC3 (canal 3)"@es ;
    ns1:identificador "CYSTARTC3" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes: CYSTARTC3"@es .

ns1:Marca_CYSTARTC4 a ns1:ComponenteElectrico ;
    rdfs:label "Marca CYSTARTC4 (canal 4)"@es ;
    ns1:identificador "CYSTARTC4" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes: CYSTARTC4"@es .

ns1:Marca_SBLOCK a ns1:ComponenteElectrico ;
    rdfs:label "Marca SBLOCK"@es ;
    ns1:identificador "SBLOCK" ;
    ns1:textoExtracto "SBLOCK. Hay una marca para cada canal."@es .

ns1:Tecla_START a ns1:InterfazUsuario ;
    rdfs:label "Tecla START"@es ;
    ns1:identificador "START" ;
    ns1:textoExtracto "Cuando el operario pulsa la tecla [START] el canal del CNC se lo indica al PLC activando la marca START."@es .

