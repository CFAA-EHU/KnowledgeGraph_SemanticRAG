@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_CYSTART a ns1:Parametro ;
    rdfs:label "Marca CYSTART" ;
    ns1:monitoreaParametro ns1:ModoEjecucion_Programa ;
    ns1:textoExtracto "PLC debe activar la marca CYSTART para que comience la ejecución del programa." .

ns1:Marca_MANRAPIDC1 a ns1:Parametro ;
    rdfs:label "Marca MANRAPIDC1 (MANRAPID)" ;
    ns1:identificador "MANRAPIDC1" ;
    ns1:monitoreaParametro ns1:ModoAvance_Rapido ;
    ns1:textoExtracto "MANRAPIDC1 (también se puede programar como MANRAPID). Si el PLC activa esta marca, el CNC selecciona el avance rápido para los movimientos en jog continuo que se realicen desde el modo manual." .

ns1:Marca_MANRAPIDC2 a ns1:Parametro ;
    rdfs:label "Marca MANRAPIDC2" ;
    ns1:identificador "MANRAPIDC2" ;
    ns1:monitoreaParametro ns1:ModoAvance_Rapido ;
    ns1:textoExtracto "MANRAPIDC2. Si el PLC activa esta marca, el CNC selecciona el avance rápido para los movimientos en jog continuo que se realicen desde el modo manual." .

ns1:Marca_MANRAPIDC3 a ns1:Parametro ;
    rdfs:label "Marca MANRAPIDC3" ;
    ns1:identificador "MANRAPIDC3" ;
    ns1:monitoreaParametro ns1:ModoAvance_Rapido ;
    ns1:textoExtracto "MANRAPIDC3. Si el PLC activa esta marca, el CNC selecciona el avance rápido para los movimientos en jog continuo que se realicen desde el modo manual." .

ns1:Marca_MANRAPIDC4 a ns1:Parametro ;
    rdfs:label "Marca MANRAPIDC4" ;
    ns1:identificador "MANRAPIDC4" ;
    ns1:monitoreaParametro ns1:ModoAvance_Rapido ;
    ns1:textoExtracto "MANRAPIDC4. Si el PLC activa esta marca, el CNC selecciona el avance rápido para los movimientos en jog continuo que se realicen desde el modo manual." .

ns1:Marca_OVRCANC1 a ns1:Parametro ;
    rdfs:label "Marca OVRCANC1 (OVRCAN)" ;
    ns1:identificador "OVRCANC1" ;
    ns1:monitoreaParametro ns1:ModoOverride_100 ;
    ns1:textoExtracto "OVRCANC1 (también se puede programar como OVRCAN). Si el PLC pone esta marca a (=1), el CNC aplica un override del 100% al avance de los ejes, independientemente del que se encuentre seleccionado." .

ns1:Marca_OVRCANC2 a ns1:Parametro ;
    rdfs:label "Marca OVRCANC2" ;
    ns1:identificador "OVRCANC2" ;
    ns1:monitoreaParametro ns1:ModoOverride_100 ;
    ns1:textoExtracto "OVRCANC2. Si el PLC pone esta marca a (=1), el CNC aplica un override del 100% al avance de los ejes, independientemente del que se encuentre seleccionado." .

ns1:Marca_OVRCANC3 a ns1:Parametro ;
    rdfs:label "Marca OVRCANC3" ;
    ns1:identificador "OVRCANC3" ;
    ns1:monitoreaParametro ns1:ModoOverride_100 ;
    ns1:textoExtracto "OVRCANC3. Si el PLC pone esta marca a (=1), el CNC aplica un override del 100% al avance de los ejes, independientemente del que se encuentre seleccionado." .

ns1:Marca_OVRCANC4 a ns1:Parametro ;
    rdfs:label "Marca OVRCANC4" ;
    ns1:identificador "OVRCANC4" ;
    ns1:monitoreaParametro ns1:ModoOverride_100 ;
    ns1:textoExtracto "OVRCANC4. Si el PLC pone esta marca a (=1), el CNC aplica un override del 100% al avance de los ejes, independientemente del que se encuentre seleccionado." .

ns1:Marca_RESETINC1 a ns1:Parametro ;
    rdfs:label "Marca RESETINC1 (RESETIN)" ;
    ns1:identificador "RESETINC1" ;
    ns1:monitoreaParametro ns1:ModoReset_CNC ;
    ns1:textoExtracto "RESETINC1 (también se puede programar como RESETIN). Con un flanco de subida (cambio de 0 a 1) de esta marca, el canal del CNC se resetea." .

ns1:Marca_RESETINC2 a ns1:Parametro ;
    rdfs:label "Marca RESETINC2" ;
    ns1:identificador "RESETINC2" ;
    ns1:monitoreaParametro ns1:ModoReset_CNC ;
    ns1:textoExtracto "RESETINC2. Con un flanco de subida (cambio de 0 a 1) de esta marca, el canal del CNC se resetea." .

ns1:Marca_RESETINC3 a ns1:Parametro ;
    rdfs:label "Marca RESETINC3" ;
    ns1:identificador "RESETINC3" ;
    ns1:monitoreaParametro ns1:ModoReset_CNC ;
    ns1:textoExtracto "RESETINC3. Con un flanco de subida (cambio de 0 a 1) de esta marca, el canal del CNC se resetea." .

ns1:Marca_RESETINC4 a ns1:Parametro ;
    rdfs:label "Marca RESETINC4" ;
    ns1:identificador "RESETINC4" ;
    ns1:monitoreaParametro ns1:ModoReset_CNC ;
    ns1:textoExtracto "RESETINC4. Con un flanco de subida (cambio de 0 a 1) de esta marca, el canal del CNC se resetea." .

ns1:Marca_SBLOCKC1 a ns1:Parametro ;
    rdfs:label "Marca SBLOCKC1 (SBLOCK)" ;
    ns1:identificador "SBLOCKC1" ;
    ns1:monitoreaParametro ns1:ModoEjecucion_BloqueABloque ;
    ns1:textoExtracto "SBLOCKC1 (también se puede programar como SBLOCK). Si el PLC pone esta marca a (=1), el canal del CNC pasa a operar en el modo de ejecución –bloque a bloque–." .

ns1:Marca_SBLOCKC2 a ns1:Parametro ;
    rdfs:label "Marca SBLOCKC2" ;
    ns1:identificador "SBLOCKC2" ;
    ns1:monitoreaParametro ns1:ModoEjecucion_BloqueABloque ;
    ns1:textoExtracto "SBLOCKC2. Si el PLC pone esta marca a (=1), el canal del CNC pasa a operar en el modo de ejecución –bloque a bloque–." .

ns1:Marca_SBLOCKC3 a ns1:Parametro ;
    rdfs:label "Marca SBLOCKC3" ;
    ns1:identificador "SBLOCKC3" ;
    ns1:monitoreaParametro ns1:ModoEjecucion_BloqueABloque ;
    ns1:textoExtracto "SBLOCKC3. Si el PLC pone esta marca a (=1), el canal del CNC pasa a operar en el modo de ejecución –bloque a bloque–." .

ns1:Marca_SBLOCKC4 a ns1:Parametro ;
    rdfs:label "Marca SBLOCKC4" ;
    ns1:identificador "SBLOCKC4" ;
    ns1:monitoreaParametro ns1:ModoEjecucion_BloqueABloque ;
    ns1:textoExtracto "SBLOCKC4. Si el PLC pone esta marca a (=1), el canal del CNC pasa a operar en el modo de ejecución –bloque a bloque–." .

ns1:ModoEjecucion_Programa a ns1:ModoOperacion ;
    rdfs:label "Modo de ejecución de programa" ;
    ns1:textoExtracto "PLC debe activar la marca CYSTART para que comience la ejecución del programa." .

ns1:ModoAvance_Rapido a ns1:ModoOperacion ;
    rdfs:label "Modo de avance rápido" ;
    ns1:textoExtracto "el CNC selecciona el avance rápido para los movimientos en jog continuo que se realicen desde el modo manual" .

ns1:ModoEjecucion_BloqueABloque a ns1:ModoOperacion ;
    rdfs:label "Modo de ejecución bloque a bloque" ;
    ns1:textoExtracto "el canal del CNC pasa a operar en el modo de ejecución –bloque a bloque–" .

ns1:ModoOverride_100 a ns1:ModoOperacion ;
    rdfs:label "Modo override 100%" ;
    ns1:textoExtracto "el CNC aplica un override del 100% al avance de los ejes, independientemente del que se encuentre seleccionado" .

ns1:ModoReset_CNC a ns1:ModoOperacion ;
    rdfs:label "Modo reset CNC" ;
    ns1:textoExtracto "Con un flanco de subida (cambio de 0 a 1) de esta marca, el canal del CNC se resetea" .

