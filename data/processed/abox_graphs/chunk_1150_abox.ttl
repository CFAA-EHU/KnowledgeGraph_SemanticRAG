@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:MarcaRESETIN a ns1:Parametro ;
    rdfs:label "Marca RESETIN" ;
    ns1:identificador "RESETIN" ;
    ns1:monitoreaParametro ns1:ProcesoResetCNC ;
    ns1:textoExtracto "el PLC activa la marca RESETIN" ;
    ns1:valor "0"^^xsd:string .

ns1:MarcaRESETOUT a ns1:Parametro ;
    rdfs:label "Marca RESETOUT" ;
    ns1:identificador "RESETOUT" ;
    ns1:monitoreaParametro ns1:ProcesoResetCNC ;
    ns1:textoExtracto "El canal activa la marca RESETOUT (RESETOUT=1) para indicar que ha finalizado el reset. Esta marca permanece activa el tiempo fijado en el parámetro general en la página 406. MINAENDW." ;
    ns1:valor "1"^^xsd:string .

ns1:PanelMandoCNC a ns1:InterfazUsuario ;
    rdfs:label "Panel de mando CNC" ;
    ns1:textoExtracto "El usuario pulsa la tecla [RESET] del panel de mando" ;
    ns1:tieneComponente ns1:TeclaReset .

ns1:ParametroMINAENDW a ns1:Parametro ;
    rdfs:label "Parámetro MINAENDW" ;
    ns1:identificador "MINAENDW" ;
    ns1:textoExtracto "tiempo fijado en el parámetro general en la página 406. MINAENDW" ;
    ns1:valor "página 406"^^xsd:string .

ns1:SubrutinaPROGRAM_RESET a ns1:ModoOperacion ;
    rdfs:label "Subrutina PROGRAM_RESET" ;
    ns1:ejecutadoPor ns1:ProcesoResetCNC ;
    ns1:identificador "PROGRAM_RESET" ;
    ns1:textoExtracto "El canal ejecuta la subrutina asociada al reset (PROGRAM_RESET), si existe." .

ns1:TeclaReset a ns1:InterfazUsuario ;
    rdfs:label "Tecla [RESET]" ;
    ns1:habilitadoPor ns1:ProcesoResetCNC ;
    ns1:textoExtracto "El usuario pulsa la tecla [RESET] del panel de mando" .

ns1:ProcesoResetCNC a ns1:ModoOperacion ;
    rdfs:label "Proceso de reset del canal CNC" ;
    ns1:textoExtracto "El proceso de reset es como sigue. 1 El usuario pulsa la tecla [RESET] del panel de mando o el PLC activa la marca RESETIN. 2 El canal asume las condiciones iniciales (las definidas en los parámetros máquina). 3 El canal activa la marca RESETOUT (RESETOUT=1) para indicar que ha finalizado el reset. Esta marca permanece activa el tiempo fijado en el parámetro general en la página 406. MINAENDW. 4 El canal ejecuta la subrutina asociada al reset (PROGRAM_RESET), si existe." .

