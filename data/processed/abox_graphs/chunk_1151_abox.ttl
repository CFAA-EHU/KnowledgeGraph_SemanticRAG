@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_Se_alesModificables a ns1:Sistema ;
    rdfs:label "Sistema de Señales Modificables Generales" ;
    ns1:compuestoPor ns1:Subrutina_PROGRAM_RESET ;
    ns1:monitoreaParametro ns1:Parametro_MINAENDW,
        ns1:Parametro_TiempoInicializacion ;
    ns1:textoExtracto "Señales modificables generales (Sección 6.8)" ;
    ns1:tieneComponente ns1:Marca_BLKSKIP1,
        ns1:Marca_BLKSKIP9,
        ns1:Marca_LATCHM,
        ns1:Marca_RESETIN,
        ns1:Marca_RESETOUT .

ns1:Marca_BLKSKIP1 a ns1:Componente ;
    rdfs:label "Marca BLKSKIP1" ;
    ns1:textoExtracto "BLKSKIP1 [...] Hay una marca para cada canal." .

ns1:Marca_BLKSKIP9 a ns1:Componente ;
    rdfs:label "Marca BLKSKIP9" ;
    ns1:textoExtracto "BLKSKIP9 [...] Hay una marca para cada canal." .

ns1:Marca_RESETIN a ns1:Componente ;
    rdfs:label "Marca RESETIN" ;
    ns1:monitoreaParametro ns1:Parametro_TiempoInicializacion ;
    ns1:textoExtracto "El PLC activa la marca RESETIN." .

ns1:Marca_RESETOUT a ns1:Componente ;
    rdfs:label "Marca RESETOUT" ;
    ns1:controla ns1:Subrutina_PROGRAM_RESET ;
    ns1:monitoreaParametro ns1:Parametro_MINAENDW ;
    ns1:textoExtracto "El canal activa la marca RESETOUT. Esta marca permanece activa el tiempo fijado en el parámetro general MINAENDW." .

ns1:ModoOperacion_JOG a ns1:ModoOperacion ;
    rdfs:label "Modo Manual (JOG)" ;
    ns1:habilitadoPor ns1:Marca_LATCHM ;
    ns1:textoExtracto "modo manual [...] teclas de JOG" .

ns1:Marca_LATCHM a ns1:Componente ;
    rdfs:label "Marca LATCHM" ;
    ns1:controla ns1:ModoOperacion_JOG ;
    ns1:textoExtracto "LATCHM [...] permite seleccionar el tipo de funcionamiento de las teclas de JOG en el modo manual." .

ns1:Parametro_MINAENDW a ns1:Parametro ;
    rdfs:label "Parámetro MINAENDW" ;
    ns1:identificador "MINAENDW" ;
    ns1:textoExtracto "tiempo fijado en el parámetro general MINAENDW" .

ns1:Parametro_TiempoInicializacion a ns1:Parametro ;
    rdfs:label "Tiempo para asumir condiciones iniciales" ;
    ns1:textoExtracto "Tiempo para asumir las condiciones iniciales." ;
    ns1:valor "Variable (depende del sistema)" .

ns1:Subrutina_PROGRAM_RESET a ns1:Sistema ;
    rdfs:label "Subrutina PROGRAM_RESET" ;
    ns1:identificador "PROGRAM_RESET" ;
    ns1:textoExtracto "El canal ejecuta la subrutina asociada al reset (PROGRAM_RESET)." .

