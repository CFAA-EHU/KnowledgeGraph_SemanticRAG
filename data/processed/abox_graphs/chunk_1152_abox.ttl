@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaSe_alesModificables a ns1:Sistema ;
    rdfs:label "Sistema de señales modificables generales" ;
    ns1:textoExtracto "Señales modificables generales. BLKSKIP1 BLKSKIP9 Hay una marca para cada canal. [...] AUXEND Hay una marca para cada canal." ;
    ns1:tieneComponente ns1:AUXEND,
        ns1:BLKSKIP1,
        ns1:BLKSKIP1C1,
        ns1:BLKSKIP1C2,
        ns1:BLKSKIP1C3,
        ns1:BLKSKIP1C4,
        ns1:M01STOP,
        ns1:M01STOPC1,
        ns1:M01STOPC2,
        ns1:M01STOPC3,
        ns1:M01STOPC4 .

ns1:AUXEND a ns1:Parametro ;
    rdfs:label "AUXEND" ;
    ns1:identificador "AUXEND" ;
    ns1:textoExtracto "AUXEND [...] Hay una marca para cada canal." .

ns1:BLKSKIP1 a ns1:Parametro ;
    rdfs:label "BLKSKIP1" ;
    ns1:identificador "BLKSKIP1" ;
    ns1:textoExtracto "BLKSKIP1 [...] El PLC pone esta marca a (=1) para indicar al canal del CNC que la condición de salto de bloque \"/\" se cumple, por lo que no se ejecutarán los bloques que tengan esta condición." .

ns1:BLKSKIP1C1 a ns1:Parametro ;
    rdfs:label "BLKSKIP1C1" ;
    ns1:identificador "BLKSKIP1C1" ;
    ns1:textoExtracto "BLKSKIP1C1 (también se puede programar como BLKSKIP1) [...] El PLC pone esta marca a (=1) para indicar al canal del CNC que la condición de salto de bloque \"/\" se cumple" .

ns1:BLKSKIP1C2 a ns1:Parametro ;
    rdfs:label "BLKSKIP1C2" ;
    ns1:identificador "BLKSKIP1C2" ;
    ns1:textoExtracto "BLKSKIP1C2" .

ns1:BLKSKIP1C3 a ns1:Parametro ;
    rdfs:label "BLKSKIP1C3" ;
    ns1:identificador "BLKSKIP1C3" ;
    ns1:textoExtracto "BLKSKIP1C3" .

ns1:BLKSKIP1C4 a ns1:Parametro ;
    rdfs:label "BLKSKIP1C4" ;
    ns1:identificador "BLKSKIP1C4" ;
    ns1:textoExtracto "BLKSKIP1C4" .

ns1:M01STOP a ns1:Parametro ;
    rdfs:label "M01STOP" ;
    ns1:identificador "M01STOP" ;
    ns1:textoExtracto "M01STOP [...] El PLC pone esta marca a (=1) para indicar al canal del CNC que tenga en cuenta las paradas condicionales (M01)." .

ns1:M01STOPC1 a ns1:Parametro ;
    rdfs:label "M01STOPC1" ;
    ns1:identificador "M01STOPC1" ;
    ns1:textoExtracto "M01STOPC1 (también se puede programar como M01STOP) [...] El PLC pone esta marca a (=1) para indicar al canal del CNC que tenga en cuenta las paradas condicionales (M01)." .

ns1:M01STOPC2 a ns1:Parametro ;
    rdfs:label "M01STOPC2" ;
    ns1:identificador "M01STOPC2" ;
    ns1:textoExtracto "M01STOPC2" .

ns1:M01STOPC3 a ns1:Parametro ;
    rdfs:label "M01STOPC3" ;
    ns1:identificador "M01STOPC3" ;
    ns1:textoExtracto "M01STOPC3" .

ns1:M01STOPC4 a ns1:Parametro ;
    rdfs:label "M01STOPC4" ;
    ns1:identificador "M01STOPC4" ;
    ns1:textoExtracto "M01STOPC4" .

