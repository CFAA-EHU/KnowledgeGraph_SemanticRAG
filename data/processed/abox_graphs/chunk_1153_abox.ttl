@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Seccion_6_8_SenalesModificablesGenerales a ns1:Capitulo ;
    rdfs:label "Sección 6.8 Señales modificables generales" ;
    ns1:documentadoEn ns1:Pagina_436 ;
    ns1:textoExtracto "Señales modificables generales. AUXEND Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes: AUXENDC1, AUXENDC2, AUXENDC3, AUXENDC4." .

ns1:Sistema_AUXEND a ns1:Sistema ;
    rdfs:label "Sistema AUXEND" ;
    ns1:documentadoEn ns1:Pagina_436 ;
    ns1:textoExtracto "AUXEND Hay una marca para cada canal. Se utiliza en la ejecución de las funciones auxiliares S y M con sincronización." ;
    ns1:tieneComponente ns1:Canal_AUXENDC1,
        ns1:Canal_AUXENDC2,
        ns1:Canal_AUXENDC3,
        ns1:Canal_AUXENDC4 .

ns1:Canal_AUXENDC1 a ns1:Componente ;
    rdfs:label "Canal AUXENDC1" ;
    ns1:documentadoEn ns1:Pagina_436 ;
    ns1:identificador "AUXENDC1" ;
    ns1:textoExtracto "AUXENDC1 (también se puede programar como AUXEND)" .

ns1:Canal_AUXENDC2 a ns1:Componente ;
    rdfs:label "Canal AUXENDC2" ;
    ns1:documentadoEn ns1:Pagina_436 ;
    ns1:identificador "AUXENDC2" ;
    ns1:textoExtracto "AUXENDC2" .

ns1:Canal_AUXENDC3 a ns1:Componente ;
    rdfs:label "Canal AUXENDC3" ;
    ns1:documentadoEn ns1:Pagina_436 ;
    ns1:identificador "AUXENDC3" ;
    ns1:textoExtracto "AUXENDC3" .

ns1:Canal_AUXENDC4 a ns1:Componente ;
    rdfs:label "Canal AUXENDC4" ;
    ns1:documentadoEn ns1:Pagina_436 ;
    ns1:identificador "AUXENDC4" ;
    ns1:textoExtracto "AUXENDC4" .

ns1:Pagina_436 a ns1:Pagina ;
    ns1:identificador "436" ;
    ns1:textoExtracto "AUXEND Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. AUXENDC1 (también se puede programar como AUXEND) AUXENDC2 AUXENDC3 AUXENDC4 Se utiliza en la ejecución de las funciones auxiliares S y M con sincronización." .

