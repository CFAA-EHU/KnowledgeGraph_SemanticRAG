@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_TIMERON a ns1:ComponenteElectrico ;
    rdfs:label "Marca TIMERON" ;
    ns1:controla ns1:Variable_TIMER_PLC ;
    ns1:identificador "TIMERON" ;
    ns1:textoExtracto "TIMERON [...] Su cuenta está en segundos y se habilita y deshabilita con esta marca. Estará habilitado (contando) con TIMERON a (=1)." .

ns1:SistemaComunicacionCNC_PLC_6_8 a ns1:Sistema ;
    rdfs:label "Sistema de comunicación CNC-PLC para señales modificables generales" ;
    ns1:textoExtracto "STROBE AUXEND MINAENDW 1 El canal del CNC indica al PLC en los registros MFUN y SFUN del canal las funciones que debe ejecutar y activa la marca MSTROBE o SSTROBE para que comience la ejecución." ;
    ns1:tieneComponente ns1:CanalCNC_Se_alesModificables,
        ns1:Marca_AUXEND,
        ns1:Marca_MSTROBE,
        ns1:Marca_SSTROBE,
        ns1:Parametro_MINAENDW,
        ns1:Variable_TIMER_PLC .

ns1:CanalCNC_Se_alesModificables a ns1:InterfazUsuario ;
    rdfs:label "Canal CNC para señales modificables generales" ;
    ns1:controla ns1:Marca_MSTROBE,
        ns1:Marca_SSTROBE ;
    ns1:monitoreaParametro ns1:Parametro_MINAENDW ;
    ns1:textoExtracto "El canal del CNC indica al PLC en los registros MFUN y SFUN del canal las funciones que debe ejecutar..." .

ns1:Marca_AUXEND a ns1:ComponenteElectrico ;
    rdfs:label "Marca AUXEND" ;
    ns1:identificador "AUXEND" ;
    ns1:textoExtracto "El PLC, al detectar la activación de una de estas marcas, debe desactivar la marca AUXEND para indicar al CNC que comienza la ejecución. 3 Una vez ejecutadas las funciones auxiliares requeridas, el PLC debe activar la marca AUXEND para indicar al CNC que ha finalizado." .

ns1:Marca_MSTROBE a ns1:ComponenteElectrico ;
    rdfs:label "Marca MSTROBE" ;
    ns1:identificador "MSTROBE" ;
    ns1:textoExtracto "activa la marca MSTROBE o SSTROBE para que comience la ejecución." .

ns1:Marca_SSTROBE a ns1:ComponenteElectrico ;
    rdfs:label "Marca SSTROBE" ;
    ns1:identificador "SSTROBE" ;
    ns1:textoExtracto "activa la marca MSTROBE o SSTROBE para que comience la ejecución." .

ns1:Parametro_MINAENDW a ns1:Parametro ;
    rdfs:label "Parámetro máquina MINAENDW" ;
    ns1:identificador "MINAENDW" ;
    ns1:textoExtracto "La marca AUXEND debe mantenerse a (=1) un tiempo superior al definido en el parámetro máquina MINAENDW." ;
    ns1:valor "Tiempo mínimo de activación de AUXEND (segundos)" .

ns1:Variable_TIMER_PLC a ns1:Parametro ;
    rdfs:label "Variable PLC.TIMER" ;
    ns1:identificador "PLC.TIMER" ;
    ns1:textoExtracto "Para inicializar y/o conocer su cuenta se debe utilizar la variable (V.)PLC.TIMER. Esta variable es accesible desde PLC, programa, MDI o Interface." ;
    ns1:valor "Contador de tiempo en segundos (accesible desde PLC/MDI/Interface)" .

