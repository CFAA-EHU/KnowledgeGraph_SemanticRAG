@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ControlMecanizado a ns1:Sistema ;
    rdfs:label "Sistema de control de mecanizado (AUTOMAT)" ;
    ns1:requiereMantenimiento ns1:TareaMantenimiento_RegistroContador ;
    ns1:textoExtracto "PRG: AUTOMAT AND INCYCLE = TIMERON [...] Contador activo durante el mecanizado."@es ;
    ns1:tieneComponente ns1:Parametro_TiempoMecanizado .

ns1:TareaMantenimiento_RegistroContador a ns1:TareaMantenimiento ;
    rdfs:label "Registro del contador de tiempo de mecanizado" ;
    ns1:monitoreaParametro ns1:Parametro_TiempoMecanizado ;
    ns1:textoExtracto "El registro R300 muestra el valor del contador."@es .

ns1:Parametro_TiempoMecanizado a ns1:Parametro ;
    rdfs:label "Tiempo de mecanizado (PLC.TIMER)" ;
    ns1:identificador "PLC.TIMER" ;
    ns1:textoExtracto "CY1: (...) CNCWR (R100, PLC.TIMER, M11) [...] PRG: CNCRD (PLC.TIMER, R300, M12)" ;
    ns1:valor "R300"@es .

