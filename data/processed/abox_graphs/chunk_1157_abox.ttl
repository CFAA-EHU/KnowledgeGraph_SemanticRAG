@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazPanelMando a ns1:InterfazUsuario ;
    rdfs:label "Panel de mando (tecla de avance rápido)"@es ;
    ns1:textoExtracto "El tratamiento de esta señal es similar al de la tecla de avance rápido del panel de mando"@es .

ns1:SenalPLCABORT a ns1:Parametro ;
    rdfs:label "Señal PLCABORT (por canal)"@es ;
    ns1:identificador "PLCABORT" ;
    ns1:textoExtracto "PLCABORT [...] Hay una marca para cada canal"@es .

ns1:SistemaControlAvance a ns1:Sistema ;
    rdfs:label "Sistema de control de avance rápido (CNC)"@es ;
    ns1:controla ns1:SenalEXRAPIDC1,
        ns1:SenalEXRAPIDC2,
        ns1:SenalEXRAPIDC3,
        ns1:SenalEXRAPIDC4 ;
    ns1:monitoreaParametro ns1:ParametroRAPIDEN ;
    ns1:textoExtracto "el canal del CNC habilita el avance rápido durante la ejecución de un programa, para los desplazamientos programados. El tratamiento de esta señal es similar al de la tecla de avance rápido del panel de mando"@es .

ns1:TablaCompensacionCruzada1 a ns1:Tabla ;
    rdfs:label "Tabla 1 de compensación cruzada"@es ;
    ns1:identificador "DISCROSS1" ;
    ns1:textoExtracto "DISCROSS1 [...] Hay una marca para cada tabla. El PLC pone la marca a (=1) para deshabilitar la tabla. La marca DISCROSS1 es para la tabla 1"@es .

ns1:TablaCompensacionCruzada17 a ns1:Tabla ;
    rdfs:label "Tabla 17 de compensación cruzada"@es ;
    ns1:identificador "DISCROSS17" ;
    ns1:textoExtracto "DISCROSS1 DISCROSS17 [...] definidas en los parámetros máquina"@es .

ns1:TablaCompensacionCruzada2 a ns1:Tabla ;
    rdfs:label "Tabla 2 de compensación cruzada"@es ;
    ns1:identificador "DISCROSS2" ;
    ns1:textoExtracto "DISCROSS2 para la tabla 2"@es .

ns1:ParametroRAPIDEN a ns1:Parametro ;
    rdfs:label "Parámetro RAPIDEN"@es ;
    ns1:identificador "RAPIDEN" ;
    ns1:textoExtracto "El funcionamiento de esta marca depende de cómo esté definido el parámetro RAPIDEN"@es .

ns1:SenalEXRAPIDC1 a ns1:Parametro ;
    rdfs:label "Señal EXRAPID (Canal 1)"@es ;
    ns1:identificador "EXRAPIDC1" ;
    ns1:textoExtracto "EXRAPIDC1 (también se puede programar como EXRAPID) [...] Si el PLC activa esta marca, el canal del CNC habilita el avance rápido durante la ejecución de un programa"@es .

ns1:SenalEXRAPIDC2 a ns1:Parametro ;
    rdfs:label "Señal EXRAPID (Canal 2)"@es ;
    ns1:identificador "EXRAPIDC2" ;
    ns1:textoExtracto "EXRAPIDC2"@es .

ns1:SenalEXRAPIDC3 a ns1:Parametro ;
    rdfs:label "Señal EXRAPID (Canal 3)"@es ;
    ns1:identificador "EXRAPIDC3" ;
    ns1:textoExtracto "EXRAPIDC3"@es .

ns1:SenalEXRAPIDC4 a ns1:Parametro ;
    rdfs:label "Señal EXRAPID (Canal 4)"@es ;
    ns1:identificador "EXRAPIDC4" ;
    ns1:textoExtracto "EXRAPIDC4"@es .

