@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaAbortoPLC a ns1:Sistema ;
    rdfs:label "Sistema de aborto PLC-CNC" ;
    ns1:compuestoPor ns1:PLCABORTC1,
        ns1:PLCABORTC2,
        ns1:PLCABORTC3,
        ns1:PLCABORTC4 ;
    ns1:textoExtracto "PLCABORT Hay una marca para cada canal. [...] Si el PLC pone esta marca a (=1), el canal del CNC aborta el comando CNCEX lanzado desde el PLC" ;
    ns1:tieneComponente ns1:CanalCNC1,
        ns1:CanalCNC2,
        ns1:CanalCNC3,
        ns1:CanalCNC4 .

ns1:ComandoCNCEX1 a ns1:Parametro ;
    rdfs:label "Comando CNCEX (Canal 1)" ;
    ns1:identificador "CNCEX" ;
    ns1:monitoreaParametro ns1:CanalCNC1 ;
    ns1:textoExtracto "el canal del CNC aborta el comando CNCEX lanzado desde el PLC" .

ns1:ComandoCNCEX2 a ns1:Parametro ;
    rdfs:label "Comando CNCEX (Canal 2)" ;
    ns1:identificador "CNCEX" ;
    ns1:monitoreaParametro ns1:CanalCNC2 ;
    ns1:textoExtracto "comando CNCEX" .

ns1:ComandoCNCEX3 a ns1:Parametro ;
    rdfs:label "Comando CNCEX (Canal 3)" ;
    ns1:identificador "CNCEX" ;
    ns1:monitoreaParametro ns1:CanalCNC3 ;
    ns1:textoExtracto "comando CNCEX" .

ns1:ComandoCNCEX4 a ns1:Parametro ;
    rdfs:label "Comando CNCEX (Canal 4)" ;
    ns1:identificador "CNCEX" ;
    ns1:monitoreaParametro ns1:CanalCNC4 ;
    ns1:textoExtracto "comando CNCEX" .

ns1:PLCABORTC1 a ns1:Parametro ;
    rdfs:label "PLCABORTC1" ;
    ns1:identificador "PLCABORTC1" ;
    ns1:monitoreaParametro ns1:CanalCNC1 ;
    ns1:textoExtracto "PLCABORTC1 (también se puede programar como PLCABORT)" .

ns1:PLCABORTC2 a ns1:Parametro ;
    rdfs:label "PLCABORTC2" ;
    ns1:identificador "PLCABORTC2" ;
    ns1:monitoreaParametro ns1:CanalCNC2 ;
    ns1:textoExtracto "PLCABORTC2" .

ns1:PLCABORTC3 a ns1:Parametro ;
    rdfs:label "PLCABORTC3" ;
    ns1:identificador "PLCABORTC3" ;
    ns1:monitoreaParametro ns1:CanalCNC3 ;
    ns1:textoExtracto "PLCABORTC3" .

ns1:PLCABORTC4 a ns1:Parametro ;
    rdfs:label "PLCABORTC4" ;
    ns1:identificador "PLCABORTC4" ;
    ns1:monitoreaParametro ns1:CanalCNC4 ;
    ns1:textoExtracto "PLCABORTC4" .

ns1:CanalCNC1 a ns1:ComponenteElectrico ;
    rdfs:label "Canal 1 CNC" ;
    ns1:controla ns1:ComandoCNCEX1 ;
    ns1:textoExtracto "Hay una marca para cada canal. [...] PLCABORTC1 (también se puede programar como PLCABORT)" .

ns1:CanalCNC2 a ns1:ComponenteElectrico ;
    rdfs:label "Canal 2 CNC" ;
    ns1:controla ns1:ComandoCNCEX2 ;
    ns1:textoExtracto "PLCABORTC2" .

ns1:CanalCNC3 a ns1:ComponenteElectrico ;
    rdfs:label "Canal 3 CNC" ;
    ns1:controla ns1:ComandoCNCEX3 ;
    ns1:textoExtracto "PLCABORTC3" .

ns1:CanalCNC4 a ns1:ComponenteElectrico ;
    rdfs:label "Canal 4 CNC" ;
    ns1:controla ns1:ComandoCNCEX4 ;
    ns1:textoExtracto "PLCABORTC4" .

