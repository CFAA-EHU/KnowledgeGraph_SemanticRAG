@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Manual_CNC a ns1:Manual ;
    rdfs:label "Manual del CNC" ;
    ns1:documentadoEn ns1:Pagina_414 ;
    ns1:textoExtracto "Ver en la página 414."@es .

ns1:Marca_FREE a ns1:Parametro ;
    rdfs:label "FREE" ;
    ns1:textoExtracto "Si se activa la marca PLCABORT sin estar lanzado un CNCEX, la marca permanece a (=1) hasta que se ejecute un CNCEX (el cual quedará abortado automáticamente) o hasta que se desactive (RES PLCABORT). FREE"@es ;
    ns1:valor "1" .

ns1:Marca_NEXTMPGAXIS a ns1:Parametro ;
    rdfs:label "NEXTMPGAXIS" ;
    ns1:textoExtracto "Esta marca permite seleccionar secuencialmente un eje para desplazarlo con el volante. [...] Con un flanco de subida de esta marca, cambio de (=0) a (=1), el CNC actúa de la siguiente manera."@es ;
    ns1:valor "1" .

ns1:Marca_PLCABORT a ns1:Parametro ;
    rdfs:label "PLCABORT" ;
    ns1:textoExtracto "Si se activa la marca PLCABORT sin estar lanzado un CNCEX, la marca permanece a (=1) hasta que se ejecute un CNCEX (el cual quedará abortado automáticamente) o hasta que se desactive (RES PLCABORT)."@es ;
    ns1:valor "1" .

ns1:Marca_PRGABORT a ns1:Parametro ;
    rdfs:label "PRGABORT" ;
    ns1:textoExtracto "Si el PLC pone esta marca a (=1), el canal del CNC aborta la ejecución del programa en curso pero sin afectar al cabezal; el resto de la historia se inicializa."@es ;
    ns1:valor "1" .

ns1:Marca_PRGABORTC1 a ns1:Parametro ;
    rdfs:label "PRGABORTC1" ;
    ns1:textoExtracto "PRGABORTC1 (también se puede programar como PRGABORT)"@es .

ns1:Marca_PRGABORTC2 a ns1:Parametro ;
    rdfs:label "PRGABORTC2" ;
    ns1:textoExtracto "PRGABORTC2"@es .

ns1:Marca_PRGABORTC3 a ns1:Parametro ;
    rdfs:label "PRGABORTC3" ;
    ns1:textoExtracto "PRGABORTC3"@es .

ns1:Marca_PRGABORTC4 a ns1:Parametro ;
    rdfs:label "PRGABORTC4" ;
    ns1:textoExtracto "PRGABORTC4"@es .

ns1:ModoManual_CNC a ns1:ModoOperacion ;
    rdfs:label "Modo manual (CNC)" ;
    ns1:textoExtracto "Esta marca sólo se tiene en cuenta cuando el CNC se encuentra en modo manual y el selector en modo volante."@es .

ns1:ProgramaPieza a ns1:Sistema ;
    rdfs:label "Programa pieza" ;
    ns1:textoExtracto "A continuación, el CNC reanuda la ejecución del programa a partir de la etiqueta indicada en la sentencia #ABORT activa en el programa pieza."@es .

ns1:Sentencia_ABORT a ns1:Parametro ;
    rdfs:label "#ABORT" ;
    ns1:textoExtracto "Si en el programa pieza no hay activa ninguna sentencia #ABORT, la marca PRGABORT no tiene ningún efecto."@es .

ns1:Pagina_414 a ns1:Pagina ;
    rdfs:label "Página 414" ;
    ns1:identificador "414" ;
    ns1:textoExtracto "Ver en la página 414."@es .

