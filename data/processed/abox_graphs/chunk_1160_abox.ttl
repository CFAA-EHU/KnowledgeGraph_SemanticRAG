@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SelectorMovimientos a ns1:InterfazUsuario ;
    rdfs:label "Selector de movimientos"@es ;
    ns1:habilitadoPor ns1:ModoSeleccionEjesVolante ;
    ns1:textoExtracto "La selección de ejes se anula al salir del modo volante con el selector de movimientos [...]."@es .

ns1:ModoSeleccionEjesVolante a ns1:ModoOperacion ;
    rdfs:label "Modo de selección de ejes (volante con pulsador)"@es ;
    ns1:textoExtracto "La selección de ejes se anula al salir del modo volante con el selector de movimientos y tras un reset. Esta marca está orientada a los volantes con pulsador."@es .

