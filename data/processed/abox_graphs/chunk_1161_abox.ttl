@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_NEXTMPGAXIS a ns1:Parametro ;
    rdfs:label "NEXTMPGAXIS" ;
    ns1:identificador "NEXTMPGAXIS" ;
    ns1:monitoreaParametro ns1:ComponenteElectrico_EntradaDigitalPulsador ;
    ns1:textoExtracto "Lo habitual en estos casos es conectar el pulsador del volante a una entrada digital, que será la encargada de gestionar la marca NEXTMPGAXIS."@es .

ns1:ModoOperacion_SeleccionEjesVolante a ns1:ModoOperacion ;
    rdfs:label "Modo de selección de ejes con volante y pulsador"@es ;
    ns1:textoExtracto "La selección de ejes se anula al salir del modo volante con el selector de movimientos. En este tipo de volantes, el pulsador permite seleccionar de forma secuencial el eje que se desea desplazar."@es .

ns1:Parametro_AddressBusCAN a ns1:Parametro ;
    rdfs:label "Conmutador Address (direccionamiento bus CAN)"@es ;
    ns1:textoExtracto "El orden de los elementos dentro del bus CAN lo determina el conmutador 'Address'. El primer elemento será el de numeración más baja y así sucesivamente."@es .

ns1:Parametro_PANELOFF a ns1:Parametro ;
    rdfs:label "PANELOFF" ;
    ns1:controla ns1:InterfazUsuario_PanelJog1 ;
    ns1:identificador "PANELOFF" ;
    ns1:textoExtracto "Se admite PANELOFF o PANELOFF1 para el primer panel de jog."@es .

ns1:Parametro_PANELOFF1 a ns1:Parametro ;
    rdfs:label "PANELOFF1" ;
    ns1:controla ns1:InterfazUsuario_PanelJog1 ;
    ns1:identificador "PANELOFF1" ;
    ns1:textoExtracto "Si el PLC activa una de estas marcas, se deshabilita el panel de jog correspondiente. La marca PANELOFF1 deshabilita el primero del bus"@es .

ns1:Sistema_PanelesJogBusCAN a ns1:Sistema ;
    rdfs:label "Sistema de paneles de jog en bus CAN"@es ;
    ns1:compuestoPor ns1:InterfazUsuario_PanelJog1,
        ns1:InterfazUsuario_PanelJog2,
        ns1:InterfazUsuario_PanelJog8 ;
    ns1:textoExtracto "Cada marca permite deshabilitar el panel de jog integrado en el bus CAN; el resto de elementos del bus no se ven afectados."@es .

ns1:ComponenteElectrico_EntradaDigitalPulsador a ns1:ComponenteElectrico ;
    rdfs:label "Entrada digital para pulsador de volante"@es ;
    ns1:textoExtracto "conectar el pulsador del volante a una entrada digital, que será la encargada de gestionar la marca NEXTMPGAXIS"@es .

ns1:InterfazUsuario_PanelJog2 a ns1:InterfazUsuario ;
    rdfs:label "Panel de jog 2" ;
    ns1:textoExtracto "La marca PANELOFF2 deshabilita el segundo [panel de jog]."@es .

ns1:InterfazUsuario_PanelJog8 a ns1:InterfazUsuario ;
    rdfs:label "Panel de jog 8" ;
    ns1:textoExtracto "PANELOFF1 PANELOFF8"@es .

ns1:InterfazUsuario_PanelJog1 a ns1:InterfazUsuario ;
    rdfs:label "Panel de jog 1 (PANELOFF1)" ;
    ns1:identificador "PANELOFF1" ;
    ns1:textoExtracto "La marca PANELOFF1 deshabilita el primero del bus. Se admite PANELOFF o PANELOFF1 para el primer panel de jog."@es .

