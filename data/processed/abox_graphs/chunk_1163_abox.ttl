@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_CNCOFF a ns1:Parametro ;
    rdfs:label "Marca CNCOFF" ;
    ns1:identificador "CNCOFF" ;
    ns1:textoExtracto "CNCOFF: Si el PLC pone esta marca a (=1) comienza la secuencia de apagado del CNC. Activar esta marca es equivalente a pulsar la combinación de teclas [ALT][F4]." .

ns1:Registro_SYNC a ns1:Parametro ;
    rdfs:label "Registro SYNC" ;
    ns1:detalladoEnEsquema ns1:Funcion_G33,
        ns1:Funcion_G95 ;
    ns1:identificador "SYNC" ;
    ns1:monitoreaParametro ns1:Cabezal_Sincronizacion ;
    ns1:textoExtracto "SYNC: Hay un registro para cada canal. Los mnemónicos para cada canal son los siguientes: SYNC1, SYNC2, SYNC3, SYNC4." .

ns1:Registro_SYNC1 a ns1:Parametro ;
    rdfs:label "Registro SYNC1" ;
    ns1:identificador "SYNC1" ;
    ns1:textoExtracto "SYNC1 (mnemonico para canal 1)" .

ns1:Registro_SYNC2 a ns1:Parametro ;
    rdfs:label "Registro SYNC2" ;
    ns1:identificador "SYNC2" ;
    ns1:textoExtracto "SYNC2 (mnemonico para canal 2)" .

ns1:Registro_SYNC3 a ns1:Parametro ;
    rdfs:label "Registro SYNC3" ;
    ns1:identificador "SYNC3" ;
    ns1:textoExtracto "SYNC3 (mnemonico para canal 3)" .

ns1:Registro_SYNC4 a ns1:Parametro ;
    rdfs:label "Registro SYNC4" ;
    ns1:identificador "SYNC4" ;
    ns1:textoExtracto "SYNC4 (mnemonico para canal 4)" .

ns1:Cabezal_Sincronizacion a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de sincronización" ;
    ns1:textoExtracto "Este registro se utiliza cuando desde un canal se desea utilizar un cabezal determinado a efectos de sincronización, aunque el cabezal se encuentre en otro canal. Por ejemplo, en el caso de un torno de doble torreta con un único cabezal." .

ns1:Funcion_G33 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G33 (roscado)" ;
    ns1:identificador "G33" ;
    ns1:textoExtracto "Con la función G33, cuando interesa roscar con un cabezal determinado." .

ns1:Funcion_G95 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G95 (avance por revolución)" ;
    ns1:identificador "G95" ;
    ns1:textoExtracto "Con la función G95, cuando se quiere programar el avance en función de la velocidad de giro de un cabezal determinado." .

