@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalMaster a ns1:ComponenteMecanico ;
    rdfs:label "cabezal master" ;
    ns1:textoExtracto "se utilizará el cabezal master del canal" .

ns1:FuncionRetrace a ns1:AccionProhibida ;
    rdfs:label "función retrace" ;
    ns1:textoExtracto "se activa la función retrace en el canal seleccionado. La función retrace detiene la ejecución del programa y comienza a ejecutar hacia atrás la trayectoria recorrida hasta ese momento en el bloque actual más los últimos n bloques ejecutados" .

ns1:MarcaRetraceC1 a ns1:Sensor ;
    rdfs:label "RETRACEC1" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. RETRACEC1 RETRACEC2 RETRACEC3 RETRACEC4" .

ns1:MarcaRetraceC2 a ns1:Sensor ;
    rdfs:label "RETRACEC2" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. RETRACEC1 RETRACEC2 RETRACEC3 RETRACEC4" .

ns1:MarcaRetraceC3 a ns1:Sensor ;
    rdfs:label "RETRACEC3" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. RETRACEC1 RETRACEC2 RETRACEC3 RETRACEC4" .

ns1:MarcaRetraceC4 a ns1:Sensor ;
    rdfs:label "RETRACEC4" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. RETRACEC1 RETRACEC2 RETRACEC3 RETRACEC4" .

ns1:ModoAutomatico a ns1:ModoOperacion ;
    rdfs:label "modo automático" ;
    ns1:textoExtracto "durante la ejecución de un programa en modo automático" .

ns1:RegistroSYNC a ns1:Parametro ;
    rdfs:label "SYNC" ;
    ns1:textoExtracto "el PLC indica en el registro SYNC del canal el cabezal que deberá utilizarse" ;
    ns1:valor "Si el PLC modifica este registro durante la ejecución del bloque, el cambio no será efectivo hasta el comienzo del bloque siguiente",
        "de ꞏ1ꞏ a ꞏ4ꞏ",
        "el CNC evaluará el contenido de este registro al comienzo de bloque",
        "si se asigna valor ꞏ0ꞏ, se utilizará el cabezal master del canal" .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "El CNC evaluará el contenido de este registro al comienzo de bloque" .

