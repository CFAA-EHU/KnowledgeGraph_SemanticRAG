@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_BlockToBlock a ns1:ModoOperacion ;
    rdfs:label "Modo bloque a bloque" ;
    ns1:textoExtracto "tanto si la ejecución está detenida por M0 como por el modo bloque a bloque." .

ns1:Sistema_PLC a ns1:Sistema ;
    rdfs:label "PLC" ;
    ns1:controla ns1:Funcion_Retrace ;
    ns1:textoExtracto "Si el PLC pone a (=0) esta marca, finaliza la función RETRACE." .

ns1:Funcion_Retrace a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función RETRACE" ;
    ns1:monitoreaParametro ns1:Parametro_NRETBLK ;
    ns1:textoExtracto "La función retrace se puede activar durante una interpolación, a mitad de un bloque, y también al final del bloque [...] Si el PLC pone a (=0) esta marca, finaliza la función RETRACE." .

ns1:Parametro_NRETBLK a ns1:Parametro ;
    rdfs:label "NRETBLK" ;
    ns1:identificador "NRETBLK" ;
    ns1:textoExtracto "El número máximo de bloques a ejecutar en retrace lo define el parámetro máquina NRETBLK." .

