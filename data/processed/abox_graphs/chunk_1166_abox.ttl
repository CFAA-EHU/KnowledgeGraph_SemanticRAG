@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MarcaRetraend a ns1:Parametro ;
    rdfs:label "Marca RETRAEND" ;
    ns1:identificador "RETRAEND" ;
    ns1:monitoreaParametro ns1:FuncionRetrace ;
    ns1:textoExtracto "La función retrace también finaliza [...] cuando el canal del CNC pone a (=1) la marca RETRAEND." .

ns1:ParametroRetracac a ns1:Parametro ;
    rdfs:label "Parámetro máquina RETRACAC" ;
    ns1:habilitadoPor ns1:FuncionRetrace ;
    ns1:identificador "RETRACAC" ;
    ns1:textoExtracto "La función retrace debe estar habilitada en el parámetro máquina RETRACAC." .

ns1:VariableVolante a ns1:Parametro ;
    rdfs:label "Variable asociada al volante" ;
    ns1:monitoreaParametro ns1:Volante1,
        ns1:Volante2 ;
    ns1:textoExtracto "Mientras el volante está inhibido, la variable asociada al volante no guarda los impulsos que envía el volante." .

ns1:MarcaInhibitmpg1 a ns1:Parametro ;
    rdfs:label "Marca INHIBITMPG1" ;
    ns1:identificador "INHIBITMPG1" ;
    ns1:textoExtracto "Si el PLC activa una de estas marcas, se deshabilita el volante correspondiente. [...] la marca INHIBITMPG1 deshabilita el primer volante" .

ns1:MarcaInhibitmpg2 a ns1:Parametro ;
    rdfs:label "Marca INHIBITMPG2" ;
    ns1:identificador "INHIBITMPG2" ;
    ns1:textoExtracto "la marca INHIBITMPG2 el segundo [volante] y así sucesivamente" .

ns1:Volante1 a ns1:InterfazUsuario ;
    rdfs:label "Primer volante (MPG1)" ;
    ns1:controla ns1:MarcaInhibitmpg1 ;
    ns1:textoExtracto "la marca INHIBITMPG1 deshabilita el primer volante" .

ns1:Volante2 a ns1:InterfazUsuario ;
    rdfs:label "Segundo volante (MPG2)" ;
    ns1:controla ns1:MarcaInhibitmpg2 ;
    ns1:textoExtracto "la marca INHIBITMPG2 el segundo [volante]" .

ns1:FuncionRetrace a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función RETRACE" ;
    ns1:identificador "RETRACE" ;
    ns1:textoExtracto "La función retrace también finaliza tras ejecutar M30, con un reset y cuando el canal del CNC pone a (=1) la marca RETRAEND. La función retrace debe estar habilitada en el parámetro máquina RETRACAC." .

