@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_AsignacionJog a ns1:Sistema ;
    rdfs:label "Sistema de asignación de paneles de jog por canal"@es ;
    ns1:documentadoEn ns1:Tabla_Se_alesModificablesGenerales ;
    ns1:textoExtracto "Sistema que asigna paneles de jog a canales específicos (1-4) o al canal activo (FF) mediante parámetros KEYBD1CH-KEYBD8CH."@es ;
    ns1:tieneComponente ns1:Parametro_KEYBD1CH,
        ns1:Parametro_KEYBD8CH .

ns1:Sistema_CompensacionVolumetrica a ns1:Sistema ;
    rdfs:label "Sistema de compensación volumétrica controlado por PLC"@es ;
    ns1:controla ns1:Parametro_VOLCOMP ;
    ns1:documentadoEn ns1:Tabla_Se_alesModificablesGenerales ;
    ns1:textoExtracto "Sistema donde el PLC activa/desactiva compensaciones volumétricas (VOLCOMP) mediante marcas VOLCOMP1-VOLCOMP4."@es ;
    ns1:tieneComponente ns1:Parametro_VOLCOMP,
        ns1:Parametro_VOLCOMP1,
        ns1:Parametro_VOLCOMP4 .

ns1:Parametro_KEYBD1CH a ns1:Parametro ;
    rdfs:label "KEYBD1CH" ;
    ns1:documentadoEn ns1:Tabla_Se_alesModificablesGenerales ;
    ns1:identificador "KEYBD1CH" ;
    ns1:textoExtracto "KEYBD1CH: Configuración de asignación de panel de jog (0=parámetros máquina, 1-4=canal específico, FF=canal activo)."@es .

ns1:Parametro_KEYBD8CH a ns1:Parametro ;
    rdfs:label "KEYBD8CH" ;
    ns1:documentadoEn ns1:Tabla_Se_alesModificablesGenerales ;
    ns1:identificador "KEYBD8CH" ;
    ns1:textoExtracto "KEYBD8CH: Configuración de asignación de panel de jog (rango KEYBD1CH-KEYBD8CH)."@es .

ns1:Parametro_VOLCOMP1 a ns1:Parametro ;
    rdfs:label "VOLCOMP1" ;
    ns1:documentadoEn ns1:Tabla_Se_alesModificablesGenerales ;
    ns1:identificador "VOLCOMP1" ;
    ns1:monitoreaParametro ns1:Parametro_VOLCOMP ;
    ns1:textoExtracto "VOLCOMP1: Marca de activación/desactivación de compensación volumétrica (controlada por PLC)."@es .

ns1:Parametro_VOLCOMP4 a ns1:Parametro ;
    rdfs:label "VOLCOMP4" ;
    ns1:documentadoEn ns1:Tabla_Se_alesModificablesGenerales ;
    ns1:identificador "VOLCOMP4" ;
    ns1:monitoreaParametro ns1:Parametro_VOLCOMP ;
    ns1:textoExtracto "VOLCOMP4: Marca de activación/desactivación de compensación volumétrica (rango VOLCOMP1-VOLCOMP4)."@es .

ns1:Parametro_VOLCOMP a ns1:Parametro ;
    rdfs:label "Compensación volumétrica (VOLCOMP)"@es ;
    ns1:documentadoEn ns1:Tabla_Se_alesModificablesGenerales ;
    ns1:textoExtracto "Parámetro VOLCOMP: Compensación volumétrica activada/desactivada por marcas VOLCOMP1-VOLCOMP4 según estado del PLC."@es .

ns1:Tabla_Se_alesModificablesGenerales a ns1:Tabla ;
    rdfs:label "Tabla de señales modificables generales (KEYBD1CH-KEYBD8CH, VOLCOMP1-VOLCOMP4)"@es ;
    ns1:documentadoEn ns1:Pagina_436_446 ;
    ns1:textoExtracto """
| KEYBD1CH-KEYBD8CH | Significado. |
| --- | --- |
| 0 | Configuración definida en los parámetros máquina. |
| 1 | Panel de jog asignado al canal 1. |
| 4 | Panel de jog asignado al canal 4. |
| FF | Panel de jog asignado al canal activo.
---
VOLCOMP1-VOLCOMP4
Si el PLC activa una de estas marcas (cambio de 0 a 1), el CNC activa la compensación volumétrica correspondiente (parámetro VOLCOMP)."""@es .

