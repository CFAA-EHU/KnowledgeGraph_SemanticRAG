@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:DepositoHidraulico_116_86 a ex:ComponenteHidraulico ;
    ex:textoExtracto "La capacidad del depósito hidráulico es de 120 litros." ;
    ex:identificador "Depósito hidráulico" ;
    ex:valor "120 litros" .

ex:FluidoHidraulico_116_86 a ex:Consumible ;
    ex:textoExtracto "El fluido a emplear debe ser Aceite ISO 3498 - HM46." ;
    ex:identificador "Aceite ISO 3498 - HM46" .