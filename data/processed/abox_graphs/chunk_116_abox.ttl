@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:DepositoHidraulico a owl:Class ;
    rdfs:label "DepositoHidraulico" ;
    rdfs:comment "Clase que representa un depósito hidráulico." .

ex:FluidoHidraulico a owl:Class ;
    rdfs:label "FluidoHidraulico" ;
    rdfs:comment "Clase que representa un fluido hidráulico." .

ex:tieneCapacidad a owl:DatatypeProperty ;
    rdfs:label "tieneCapacidad" ;
    rdfs:comment "Propiedad que indica la capacidad de un depósito hidráulico." ;
    rdfs:domain ex:DepositoHidraulico ;
    rdfs:range xsd:decimal .

ex:tieneFluido a owl:ObjectProperty ;
    rdfs:label "tieneFluido" ;
    rdfs:comment "Propiedad que indica el fluido hidráulico a emplear." ;
    rdfs:domain ex:DepositoHidraulico ;
    rdfs:range ex:FluidoHidraulico .

ex:AceiteISO3498HM46 a ex:FluidoHidraulico ;
    rdfs:label "Aceite ISO 3498 - HM46" ;
    rdfs:comment "Fluido hidráulico específico." .