@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_FLIMITAC a ns1:InterfazUsuario ;
    rdfs:label "FLIMITAC" ;
    ns1:controla ns1:Parametro_FLIMIT ;
    ns1:identificador "FLIMITAC" ;
    ns1:textoExtracto "Si el PLC activa esta marca, el CNC activa los límites de seguridad para el avance (parámetro FLIMIT) en todos los ejes del sistema" .

ns1:Marca_QWERTYOFF1 a ns1:InterfazUsuario ;
    rdfs:label "QWERTYOFF1" ;
    ns1:controla ns1:Interfaz_SoftkeysUSB_10K,
        ns1:Interfaz_TecladoUSB_10K ;
    ns1:identificador "QWERTYOFF1" ;
    ns1:textoExtracto "Si el PLC activa una de estas marcas, se deshabilita el teclado alfanumérico correspondiente. [...] En el modelo 10K, esta marca afecta al teclado alfanumérico y las softkeys del monitor (interface USB)" .

ns1:Marca_QWERTYOFF2 a ns1:InterfazUsuario ;
    rdfs:label "QWERTYOFF2" ;
    ns1:identificador "QWERTYOFF2" ;
    ns1:textoExtracto "Las marcas QWERTYOFF2 a QWERTYOFF8 actúan sobre el resto de teclados CAN, según la numeración lógica de los nodos, de menor a mayor" .

ns1:Marca_QWERTYOFF8 a ns1:InterfazUsuario ;
    rdfs:label "QWERTYOFF8" ;
    ns1:identificador "QWERTYOFF8" ;
    ns1:textoExtracto "Las marcas QWERTYOFF2 a QWERTYOFF8 actúan sobre el resto de teclados CAN, según la numeración lógica de los nodos, de menor a mayor" .

ns1:Parametro_FLIMITACCH a ns1:Parametro ;
    rdfs:label "FLIMITACCH" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "FLIMITACCH. Hay una marca para cada canal" .

ns1:Interfaz_TecladoCAN_15 a ns1:InterfazUsuario ;
    rdfs:label "Teclado CAN (modelo 15\")" ;
    ns1:identificador "modelo_15" ;
    ns1:textoExtracto "teclado integrado en el bus CAN (modelo 15\")" .

ns1:Parametro_FLIMIT a ns1:Parametro ;
    rdfs:label "FLIMIT" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "el CNC activa los límites de seguridad para el avance (parámetro FLIMIT) en todos los ejes del sistema" .

ns1:Interfaz_SoftkeysUSB_10K a ns1:InterfazUsuario ;
    rdfs:label "Softkeys del monitor (interface USB, modelo 10K)" ;
    ns1:identificador "softkeys_USB_10K" ;
    ns1:textoExtracto "las softkeys del monitor (interface USB)" .

ns1:Interfaz_TecladoUSB_10K a ns1:InterfazUsuario ;
    rdfs:label "Teclado alfanumérico USB (modelo 10K)" ;
    ns1:identificador "modelo_10K" ;
    ns1:textoExtracto "teclado alfanumérico USB (modelo 10K)" .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "El CNC aplica la compensación volumétrica después de aplicar la compensación de husillo y la compensación cruzada. [...] El límite de seguridad del avance se aplica a los movimientos en automático (G0, G1, etc) y en manual (jog, volantes, etc)" ;
    ns1:tieneComponente ns1:Interfaz_SoftkeysUSB_10K,
        ns1:Interfaz_TecladoCAN_15,
        ns1:Interfaz_TecladoUSB_10K .

