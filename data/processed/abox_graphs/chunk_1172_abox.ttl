@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PLC a ns1:Actuador ;
    rdfs:label "PLC (Controlador Lógico Programable)"@es ;
    ns1:controla ns1:FLIMITACCH,
        ns1:FLIMITACCH_C1,
        ns1:FLIMITACCH_C2,
        ns1:FLIMITACCH_C3,
        ns1:FLIMITACCH_C4,
        ns1:SLIMITAC ;
    ns1:textoExtracto "Si el PLC activa esta marca [...] Si el PLC desactiva esta marca"@es .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC (Control Numérico)"@es ;
    ns1:monitoreaParametro ns1:FLIMIT,
        ns1:FLIMITACCH,
        ns1:FLIMITACCH_C1,
        ns1:FLIMITACCH_C2,
        ns1:FLIMITACCH_C3,
        ns1:FLIMITACCH_C4,
        ns1:SLIMIT,
        ns1:SLIMITAC ;
    ns1:textoExtracto "el CNC activa los límites de seguridad para el avance [...] en todos los ejes del canal [...] en todos los cabezales del sistema"@es .

ns1:FLIMIT a ns1:Parametro ;
    rdfs:label "FLIMIT (Parámetro de límite de avance)"@es ;
    ns1:identificador "FLIMIT" ;
    ns1:textoExtracto "parámetro FLIMIT"@es .

ns1:ModoAutomatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático (G0, G1, etc.)"@es ;
    ns1:textoExtracto "movimientos en automático (G0, G1, etc)"@es .

ns1:ModoManual a ns1:ModoOperacion ;
    rdfs:label "Modo manual (jog, volantes, etc.)"@es ;
    ns1:textoExtracto "movimientos en manual (jog, volantes, etc)"@es .

ns1:SLIMIT a ns1:Parametro ;
    rdfs:label "SLIMIT (Parámetro de límite de velocidad)"@es ;
    ns1:identificador "SLIMIT" ;
    ns1:textoExtracto "parámetro SLIMIT"@es .

ns1:FLIMITACCH a ns1:Parametro ;
    rdfs:label "FLIMITACCH (Límite de avance por canal)"@es ;
    ns1:identificador "FLIMITACCH" ;
    ns1:mitigaRiesgo ns1:ModoAutomatico,
        ns1:ModoManual ;
    ns1:textoExtracto "FLIMITACCH [...] Si el PLC activa esta marca, el CNC activa los límites de seguridad para el avance (parámetro FLIMIT) en todos los ejes del canal, durante la ejecución del bloque."@es .

ns1:FLIMITACCH_C1 a ns1:Parametro ;
    rdfs:label "FLIMITACCHC1 (Límite de avance - Canal 1)"@es ;
    ns1:identificador "FLIMITACCHC1" ;
    ns1:textoExtracto "FLIMITACCHC1 (también se puede programar como FLIMITACCH)"@es .

ns1:FLIMITACCH_C2 a ns1:Parametro ;
    rdfs:label "FLIMITACCHC2 (Límite de avance - Canal 2)"@es ;
    ns1:identificador "FLIMITACCHC2" ;
    ns1:textoExtracto "FLIMITACCHC2"@es .

ns1:FLIMITACCH_C3 a ns1:Parametro ;
    rdfs:label "FLIMITACCHC3 (Límite de avance - Canal 3)"@es ;
    ns1:identificador "FLIMITACCHC3" ;
    ns1:textoExtracto "FLIMITACCHC3"@es .

ns1:FLIMITACCH_C4 a ns1:Parametro ;
    rdfs:label "FLIMITACCHC4 (Límite de avance - Canal 4)"@es ;
    ns1:identificador "FLIMITACCHC4" ;
    ns1:textoExtracto "FLIMITACCHC4"@es .

ns1:SLIMITAC a ns1:Parametro ;
    rdfs:label "SLIMITAC (Límite de velocidad del sistema)"@es ;
    ns1:identificador "SLIMITAC" ;
    ns1:textoExtracto "SLIMITAC [...] Si el PLC activa esta marca, el CNC activa los límites de seguridad para la velocidad (parámetro SLIMIT) en todos los cabezales del sistema, durante la ejecución del bloque actual."@es .

