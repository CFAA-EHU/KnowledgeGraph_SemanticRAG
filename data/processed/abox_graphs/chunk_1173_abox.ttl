@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ControlPT100 a ns1:Sistema ;
    ns1:controla ns1:Parametro_INT1,
        ns1:Parametro_INT4,
        ns1:Parametro_PT100OFF1,
        ns1:Parametro_PT100OFF2,
        ns1:Parametro_PT100OFF20 ;
    ns1:documentadoEn ns1:Pagina_6.8_SeñalesModificablesGenerales ;
    ns1:textoExtracto "Las entradas PT100 se activan desde los parámetro máquina. Si la entrada está activa en el parámetro máquina y no hay una sonda conectada, el CNC da el error correspondiente. El PLC dispone de las siguientes marcas para poder deshabilitar la sonda temporalmente (por ejemplo, en un cambio de cabezal)."@es ;
    ns1:tieneComponente ns1:Sensor_PT100_Entrada1,
        ns1:Sensor_PT100_Entrada2 .

ns1:Parametro_INT1 a ns1:Parametro ;
    ns1:documentadoEn ns1:Pagina_6.8_SeñalesModificablesGenerales ;
    ns1:identificador "INT1" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. Se muestra como ejemplo los mnemónicos de INT1; para el resto de marcas es equivalente."@es .

ns1:Parametro_INT4 a ns1:Parametro ;
    ns1:documentadoEn ns1:Pagina_6.8_SeñalesModificablesGenerales ;
    ns1:identificador "INT4" ;
    ns1:textoExtracto "Hay una marca para cada canal. [...] Se muestra como ejemplo los mnemónicos de INT1; para el resto de marcas es equivalente."@es .

ns1:Parametro_PT100OFF1 a ns1:Parametro ;
    ns1:documentadoEn ns1:Pagina_6.8_SeñalesModificablesGenerales ;
    ns1:identificador "PT100OFF1" ;
    ns1:monitoreaParametro ns1:Sensor_PT100_Entrada1 ;
    ns1:textoExtracto "El PLC dispone de las siguientes marcas para poder deshabilitar la sonda temporalmente (por ejemplo, en un cambio de cabezal). Si el PLC activa una de estas marcas, el CNC deshabilita la sonda correspondiente (parámetro PT100 n). La marca PT100OFF1 corresponde a la sonda de la entrada 1"@es .

ns1:Parametro_PT100OFF2 a ns1:Parametro ;
    ns1:documentadoEn ns1:Pagina_6.8_SeñalesModificablesGenerales ;
    ns1:identificador "PT100OFF2" ;
    ns1:monitoreaParametro ns1:Sensor_PT100_Entrada2 ;
    ns1:textoExtracto "La marca PT100OFF2 corresponde a la sonda de la entrada 2"@es .

ns1:Parametro_PT100OFF20 a ns1:Parametro ;
    ns1:documentadoEn ns1:Pagina_6.8_SeñalesModificablesGenerales ;
    ns1:identificador "PT100OFF20" ;
    ns1:textoExtracto "Las entradas PT100 se activan desde los parámetro máquina. [...] PT100OFF1 PT100OFF20"@es .

ns1:Sensor_PT100_Entrada1 a ns1:Sensor ;
    ns1:documentadoEn ns1:Pagina_6.8_SeñalesModificablesGenerales ;
    ns1:identificador "PT100_Entrada1" ;
    ns1:textoExtracto "Si la entrada está activa en el parámetro máquina y no hay una sonda conectada, el CNC da el error correspondiente. [...] La marca PT100OFF1 corresponde a la sonda de la entrada 1"@es .

ns1:Sensor_PT100_Entrada2 a ns1:Sensor ;
    ns1:documentadoEn ns1:Pagina_6.8_SeñalesModificablesGenerales ;
    ns1:identificador "PT100_Entrada2" ;
    ns1:textoExtracto "La marca PT100OFF2 corresponde a la sonda de la entrada 2"@es .

ns1:Pagina_6.8_SeñalesModificablesGenerales a ns1:Pagina ;
    rdfs:label "Sección 6.8: Señales modificables generales"@es ;
    ns1:identificador "6.8" ;
    ns1:textoExtracto "Señales modificables generales. Si el PLC desactiva esta marca, el CNC recupera la velocidad programada. [...] Hay una marca para cada canal." .

