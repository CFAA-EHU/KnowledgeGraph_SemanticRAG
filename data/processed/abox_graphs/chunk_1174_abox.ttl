@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_InterrupcionesPLC a ns1:Sistema ;
    rdfs:label "Sistema de interrupciones del PLC"@es ;
    ns1:documentadoEn ns1:Pagina_6.8_SeñalesModificablesGenerales ;
    ns1:textoExtracto "Si el PLC activa una de estas marcas, el canal interrumpe la ejecución del programa y ejecuta la subrutina de interrupción correspondiente"@es ;
    ns1:tieneComponente ns1:Parametro_INT1C1,
        ns1:Parametro_INT1C2,
        ns1:Parametro_INT1C3,
        ns1:Parametro_INT1C4,
        ns1:Parametro_INT1SUB,
        ns1:Parametro_INT4SUB .

ns1:Parametro_INT1C1 a ns1:Parametro ;
    rdfs:label "INT1C1" ;
    ns1:documentadoEn ns1:Pagina_6.8_SeñalesModificablesGenerales ;
    ns1:identificador "INT1C1" ;
    ns1:textoExtracto "INT1C1 (también se puede programar como INT1)"@es .

ns1:Parametro_INT1C2 a ns1:Parametro ;
    rdfs:label "INT1C2" ;
    ns1:documentadoEn ns1:Pagina_6.8_SeñalesModificablesGenerales ;
    ns1:identificador "INT1C2" ;
    ns1:textoExtracto "INT1C2"@es .

ns1:Parametro_INT1C3 a ns1:Parametro ;
    rdfs:label "INT1C3" ;
    ns1:documentadoEn ns1:Pagina_6.8_SeñalesModificablesGenerales ;
    ns1:identificador "INT1C3" ;
    ns1:textoExtracto "INT1C3"@es .

ns1:Parametro_INT1C4 a ns1:Parametro ;
    rdfs:label "INT1C4" ;
    ns1:documentadoEn ns1:Pagina_6.8_SeñalesModificablesGenerales ;
    ns1:identificador "INT1C4" ;
    ns1:textoExtracto "INT1C4"@es .

ns1:Parametro_INT1SUB a ns1:Parametro ;
    rdfs:label "INT1SUB" ;
    ns1:documentadoEn ns1:Pagina_6.8_SeñalesModificablesGenerales ;
    ns1:identificador "INT1SUB" ;
    ns1:textoExtracto "subrutina de interrupción correspondiente, asociada a los parámetros INT1SUB a INT4SUB"@es .

ns1:Parametro_INT4SUB a ns1:Parametro ;
    rdfs:label "INT4SUB" ;
    ns1:documentadoEn ns1:Pagina_6.8_SeñalesModificablesGenerales ;
    ns1:identificador "INT4SUB" ;
    ns1:textoExtracto "parámetros INT1SUB a INT4SUB"@es .

ns1:Pagina_6.8_SeñalesModificablesGenerales a ns1:Pagina ;
    rdfs:label "Sección 6.8: Señales modificables generales"@es ;
    ns1:identificador "6.8" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. Se muestra como ejemplo los mnemónicos de INT1; para el resto de marcas es equivalente. INT1C1 (también se puede programar como INT1) INT1C2 INT1C3 INT1C4 Si el PLC acti..."@es .

