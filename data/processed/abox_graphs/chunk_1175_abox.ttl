@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Comando_G100 a ns1:Parametro ;
    rdfs:label "G100" ;
    ns1:textoExtracto "Al ejecutar un comando G100 o G103, el CNC dará error si el palpador activo no tiene su marca habilitada" .

ns1:Comando_G103 a ns1:Parametro ;
    rdfs:label "G103" ;
    ns1:textoExtracto "Al ejecutar un comando G100 o G103, el CNC dará error si el palpador activo no tiene su marca habilitada" .

ns1:ModoOperacion_Automatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático" ;
    ns1:textoExtracto "no se permite ejecutar la subrutina desde el modo manual. [...] el canal debe estar en modo automático" .

ns1:ModoOperacion_Inspeccion a ns1:ModoOperacion ;
    rdfs:label "Modo inspección" ;
    ns1:textoExtracto "Cuando una subrutina esté interrumpida, no se podrá entrar en el modo inspección" .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo manual" ;
    ns1:textoExtracto "no se permite ejecutar la subrutina desde el modo manual" .

ns1:Parametro_INT1SUB a ns1:Parametro ;
    rdfs:label "INT1SUB" ;
    ns1:textoExtracto "subrutina de interrupción correspondiente, asociada a los parámetros INT1SUB a INT4SUB" .

ns1:Parametro_INT2SUB a ns1:Parametro ;
    rdfs:label "INT2SUB" ;
    ns1:textoExtracto "subrutina de interrupción correspondiente, asociada a los parámetros INT1SUB a INT4SUB" .

ns1:Parametro_INT3SUB a ns1:Parametro ;
    rdfs:label "INT3SUB" ;
    ns1:textoExtracto "subrutina de interrupción correspondiente, asociada a los parámetros INT1SUB a INT4SUB" .

ns1:Parametro_INT4SUB a ns1:Parametro ;
    rdfs:label "INT4SUB" ;
    ns1:textoExtracto "subrutina de interrupción correspondiente, asociada a los parámetros INT1SUB a INT4SUB" .

ns1:Parametro_PROBE1ENA a ns1:Parametro ;
    rdfs:label "PROBE1ENA" ;
    ns1:monitoreaParametro ns1:Componente_Palpador ;
    ns1:textoExtracto "PROBE1ENA PROBE2ENA Marcas activas por defecto. Estas marcas indican que el palpador está habilitado" ;
    ns1:valor "activo" .

ns1:Parametro_PROBE1MONIT a ns1:Parametro ;
    rdfs:label "PROBE1MONIT" ;
    ns1:habilitadoPor ns1:ModoOperacion_SeguroPalpador ;
    ns1:monitoreaParametro ns1:Componente_Palpador ;
    ns1:textoExtracto "PROBE1MONIT PROBE2MONIT Estas marcas están asociadas al modo seguro del palpador. Si la marca está activa, el palpador está en modo seguro monitorizando colisiones" ;
    ns1:valor "monitorizando" .

ns1:Parametro_PROBE2ENA a ns1:Parametro ;
    rdfs:label "PROBE2ENA" ;
    ns1:monitoreaParametro ns1:Componente_Palpador ;
    ns1:textoExtracto "PROBE1ENA PROBE2ENA Marcas activas por defecto. Estas marcas indican que el palpador está habilitado" ;
    ns1:valor "activo" .

ns1:Parametro_PROBE2MONIT a ns1:Parametro ;
    rdfs:label "PROBE2MONIT" ;
    ns1:habilitadoPor ns1:ModoOperacion_SeguroPalpador ;
    ns1:monitoreaParametro ns1:Componente_Palpador ;
    ns1:textoExtracto "PROBE1MONIT PROBE2MONIT Estas marcas están asociadas al modo seguro del palpador. Si la marca está activa, el palpador está en modo seguro monitorizando colisiones" ;
    ns1:valor "monitorizando" .

ns1:Parametro_SUBINTSTOP a ns1:Parametro ;
    rdfs:label "SUBINTSTOP" ;
    ns1:textoExtracto "Si el programa está interrumpido (STOP) o no hay programa en ejecución (canal en estado READY) la ejecución de la subrutina depende del parámetro SUBINTSTOP" .

ns1:Subrutina_Sub_Probe_Piece_Begin a ns1:TareaMantenimiento ;
    rdfs:label "Sub_Probe_Piece_Begin.fst" ;
    ns1:textoExtracto "Estas marcas se deberían testear en las subrutinas Sub_Probe_Tool_Begin.fst y Sub_Probe_Piece_Begin.fst" .

ns1:Subrutina_Sub_Probe_Tool_Begin a ns1:TareaMantenimiento ;
    rdfs:label "Sub_Probe_Tool_Begin.fst" ;
    ns1:textoExtracto "Estas marcas se deberían testear en las subrutinas Sub_Probe_Tool_Begin.fst y Sub_Probe_Piece_Begin.fst" .

ns1:ModoOperacion_SeguroPalpador a ns1:ModoOperacion ;
    rdfs:label "Modo seguro del palpador" ;
    ns1:textoExtracto "PROBE1MONIT PROBE2MONIT Estas marcas están asociadas al modo seguro del palpador" .

ns1:Componente_Palpador a ns1:Sensor ;
    rdfs:label "Palpador" ;
    ns1:textoExtracto "modo seguro del palpador" .

