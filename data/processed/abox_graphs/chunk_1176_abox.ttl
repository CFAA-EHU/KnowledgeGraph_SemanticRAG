@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaMonitorizacionColisiones a ns1:Sistema ;
    rdfs:label "sistema de monitorización de colisiones" ;
    ns1:compuestoPor ns1:PROBE1MONIT_2d7169cedb,
        ns1:PROBE2MONIT_5758d91c44 ;
    ns1:controla ns1:ModoSeguroPalpador ;
    ns1:textoExtracto "Monitorización a nivel de lazo, controlando todas las situaciones de colisión en cualquiera de los dos palpadores" .

ns1:ModoSeguroPalpador a ns1:ModoOperacion ;
    rdfs:label "modo seguro del palpador" ;
    ns1:textoExtracto "estas marcas están asociadas al modo seguro del palpador" .

ns1:PROBE1MONIT_2d7169cedb a ns1:Sensor ;
    rdfs:label "PROBE1MONIT" ;
    ns1:textoExtracto "PROBE1MONIT" .

ns1:PROBE2MONIT_5758d91c44 a ns1:Sensor ;
    rdfs:label "PROBE2MONIT" ;
    ns1:textoExtracto "PROBE2MONIT" .

