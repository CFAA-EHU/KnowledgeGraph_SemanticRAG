@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Registro_RKIN1_a_RKIN32 a ns1:InterfazUsuario ;
    rdfs:label "Registros RKIN1 a RKIN32" ;
    ns1:identificador "RKIN1-RKIN32" ;
    ns1:textoExtracto "Estos registros permiten la comunicación entre el PLC y las cinemáticas de usuario" .

ns1:Sistema_MonitorizacionPalpadores a ns1:Sistema ;
    rdfs:label "Sistema de monitorización de palpadores" ;
    ns1:controla ns1:Parametro_COLLISIONOFF,
        ns1:Parametro_LCOUNTALARMOFF1,
        ns1:Parametro_LCOUNTALARMOFF2 ;
    ns1:monitoreaParametro ns1:Parametro_FBACKAL ;
    ns1:textoExtracto "Monitorización a nivel de lazo, controlando todas las situaciones de colisión en cualquiera de los dos palpadores. El CNC monitoriza las 2 entradas de palpador a la vez" ;
    ns1:tieneComponente ns1:Palpador_EntradaLocal1,
        ns1:Palpador_EntradaLocal2,
        ns1:Palpador_EntradaRemotaCAN .

ns1:Subrutina_Sub_Probe_Piece_Begin a ns1:Componente ;
    rdfs:label "Sub_Probe_Piece_Begin.fst" ;
    ns1:identificador "Sub_Probe_Piece_Begin.fst" ;
    ns1:textoExtracto "Estas marcas se deberían testear en las subrutinas Sub_Probe_Tool_Begin.fst y Sub_Probe_Piece_Begin.fst, para avisar, si están desactivadas, que el palpador está en modo no seguro" .

ns1:Subrutina_Sub_Probe_Tool_Begin a ns1:Componente ;
    rdfs:label "Sub_Probe_Tool_Begin.fst" ;
    ns1:identificador "Sub_Probe_Tool_Begin.fst" ;
    ns1:textoExtracto "Estas marcas se deberían testear en las subrutinas Sub_Probe_Tool_Begin.fst y Sub_Probe_Piece_Begin.fst, para avisar, si están desactivadas, que el palpador está en modo no seguro" .

ns1:Alarma_ColisionCaptacion a ns1:Alarma ;
    rdfs:label "Alarma de colisión en captación" ;
    ns1:textoExtracto "No se detecta alarma en caso de configurar el contaje local como TTL no diferencial. El movimiento del cabezal puede producir una alarma en la captación C" .

ns1:Alarma_DesactivacionCaptacionLocal1 a ns1:Alarma ;
    rdfs:label "Alarma de desactivación de captación local 1" ;
    ns1:textoExtracto "deshabilita las alarmas de captación de la entrada local correspondiente [1] cuando el PLC activa LCOUNTALARMOFF1" .

ns1:Alarma_DesactivacionCaptacionLocal2 a ns1:Alarma ;
    rdfs:label "Alarma de desactivación de captación local 2" ;
    ns1:textoExtracto "deshabilita las alarmas de captación de la entrada local correspondiente [2] cuando el PLC activa LCOUNTALARMOFF2" .

ns1:Palpador_EntradaLocal1 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de palpador local 1" ;
    ns1:monitoreaParametro ns1:Parametro_LCOUNTALARMOFF1 ;
    ns1:textoExtracto "entrada de captación local 1 (LCOUNTALARMOFF1)" .

ns1:Palpador_EntradaLocal2 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de palpador local 2" ;
    ns1:monitoreaParametro ns1:Parametro_LCOUNTALARMOFF2 ;
    ns1:textoExtracto "entrada de captación local 2 (LCOUNTALARMOFF2)" .

ns1:Palpador_EntradaRemotaCAN a ns1:ComponenteElectrico ;
    rdfs:label "Entradas de palpador remotas CAN" ;
    ns1:textoExtracto "palpadores conectados a las entradas remotas CAN" .

ns1:Parametro_COLLISIONOFF a ns1:Parametro ;
    rdfs:label "COLLISIONOFF" ;
    ns1:identificador "COLLISIONOFF" ;
    ns1:textoExtracto "Hay una marca para cada canal. COLLISIONOFF permite deshabilitar detección de colisiones por canal" .

ns1:Parametro_FBACKAL a ns1:Parametro ;
    rdfs:label "FBACKAL" ;
    ns1:identificador "FBACKAL" ;
    ns1:mitigaRiesgo ns1:Alarma_ColisionCaptacion ;
    ns1:textoExtracto "El report de alarma está condicionado al parámetro FBACKAL" .

ns1:Parametro_LCOUNTALARMOFF1 a ns1:Parametro ;
    rdfs:label "LCOUNTALARMOFF1" ;
    ns1:activaAlarma ns1:Alarma_DesactivacionCaptacionLocal1 ;
    ns1:identificador "LCOUNTALARMOFF1" ;
    ns1:textoExtracto "marca referida a la entrada de captación local 1 (LCOUNTALARMOFF1). Si el PLC activa esta marca (cambio de 0 a 1), deshabilita las alarmas de captación de la entrada local correspondiente" .

ns1:Parametro_LCOUNTALARMOFF2 a ns1:Parametro ;
    rdfs:label "LCOUNTALARMOFF2" ;
    ns1:activaAlarma ns1:Alarma_DesactivacionCaptacionLocal2 ;
    ns1:identificador "LCOUNTALARMOFF2" ;
    ns1:textoExtracto "marca referida a la entrada de captación local 2 (LCOUNTALARMOFF2). Si el PLC activa esta marca (cambio de 0 a 1), deshabilita las alarmas de captación de la entrada local correspondiente" .

