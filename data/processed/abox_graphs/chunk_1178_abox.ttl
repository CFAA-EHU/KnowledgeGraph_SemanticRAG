@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_COLLISIONOFFC1 a ns1:Parametro ;
    rdfs:label "COLLISIONOFFC1 (FCAS control)"@es ;
    ns1:identificador "COLLISIONOFFC1" ;
    ns1:monitoreaParametro ns1:Sistema_FCAS ;
    ns1:textoExtracto "COLLISIONOFFC1 (también se puede programar como COLLISIONOFF). Si el PLC activa esta marca (cambio de 0 a 1), desactiva la opción FCAS (control de colisiones)."@es .

ns1:Parametro_COLLISIONOFFC2 a ns1:Parametro ;
    rdfs:label "COLLISIONOFFC2 (FCAS control)"@es ;
    ns1:identificador "COLLISIONOFFC2" ;
    ns1:monitoreaParametro ns1:Sistema_FCAS ;
    ns1:textoExtracto "COLLISIONOFFC2"@es .

ns1:Parametro_COLLISIONOFFC3 a ns1:Parametro ;
    rdfs:label "COLLISIONOFFC3 (FCAS control)"@es ;
    ns1:identificador "COLLISIONOFFC3" ;
    ns1:monitoreaParametro ns1:Sistema_FCAS ;
    ns1:textoExtracto "COLLISIONOFFC3"@es .

ns1:Parametro_COLLISIONOFFC4 a ns1:Parametro ;
    rdfs:label "COLLISIONOFFC4 (FCAS control)"@es ;
    ns1:identificador "COLLISIONOFFC4" ;
    ns1:monitoreaParametro ns1:Sistema_FCAS ;
    ns1:textoExtracto "COLLISIONOFFC4"@es .

ns1:Parametro_VIRTUALJOGENA a ns1:Parametro ;
    rdfs:label "VIRTUALJOGENA"@es ;
    ns1:identificador "VIRTUALJOGENA" ;
    ns1:textoExtracto "VIRTUALJOGENA. El PLC utiliza esta marca para habilitar"@es .

ns1:Registro_RKIN a ns1:InterfazUsuario ;
    rdfs:label "Registros RKIN1-RKIN32 (comunicación PLC-cinemáticas)"@es ;
    ns1:controla ns1:Sistema_FCAS ;
    ns1:identificador "RKIN1-RKIN32" ;
    ns1:textoExtracto "RKIN1 RKIN32. Estas registros permiten la comunicación entre el PLC y las cinemáticas de usuario."@es .

ns1:Sistema_FCAS a ns1:Sistema ;
    rdfs:label "Sistema FCAS (control de colisiones)"@es ;
    ns1:textoExtracto "opción FCAS (control de colisiones)"@es .

