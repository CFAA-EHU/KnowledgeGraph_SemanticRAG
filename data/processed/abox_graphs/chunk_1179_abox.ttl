@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FCAS a ns1:Parametro ;
    rdfs:label "FCAS (control de colisiones)" ;
    ns1:identificador "FCAS" ;
    ns1:textoExtracto "la opción FCAS (control de colisiones). Si el PLC desactiva esta marca (cambio de 1 a 0), activa la opción FCAS (control de colisiones)." .

ns1:InterfazJogVirtual a ns1:InterfazUsuario ;
    rdfs:label "Teclado virtual de jog" ;
    ns1:habilitadoPor ns1:VIRTUALJOGENA ;
    ns1:textoExtracto "teclado virtual de jog (teclado en pantalla)" .

ns1:SistemaDMC a ns1:Sistema ;
    rdfs:label "Sistema DMC (Dynamic Motion Control)" ;
    ns1:controla ns1:DMCONC1,
        ns1:DMCONC2,
        ns1:DMCONC3,
        ns1:DMCONC4 ;
    ns1:textoExtracto "el CNC desactiva el DMC. [...] el CNC reactiva el DMC" .

ns1:DMCONC1 a ns1:Parametro ;
    rdfs:label "DMCONC1 (canal 1)" ;
    ns1:identificador "DMCONC1" ;
    ns1:textoExtracto "DMCONC1 (también se puede programar como DMCON)" .

ns1:DMCONC2 a ns1:Parametro ;
    rdfs:label "DMCONC2 (canal 2)" ;
    ns1:identificador "DMCONC2" ;
    ns1:textoExtracto "DMCONC2" .

ns1:DMCONC3 a ns1:Parametro ;
    rdfs:label "DMCONC3 (canal 3)" ;
    ns1:identificador "DMCONC3" ;
    ns1:textoExtracto "DMCONC3" .

ns1:DMCONC4 a ns1:Parametro ;
    rdfs:label "DMCONC4 (canal 4)" ;
    ns1:identificador "DMCONC4" ;
    ns1:textoExtracto "DMCONC4" .

ns1:VIRTUALJOGENA a ns1:Parametro ;
    rdfs:label "VIRTUALJOGENA" ;
    ns1:identificador "VIRTUALJOGENA" ;
    ns1:textoExtracto "El PLC utiliza esta marca para habilitar (=1) o deshabilitar (=0) el teclado virtual de jog (teclado en pantalla)." .

