@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:AccionProhibidaSobrepasoLimite a ns1:AccionProhibida ;
    ns1:textoExtracto "el CNC entiende que el eje o cabezal correspondiente ha sobrepasado el límite de recorrido en el sentido positivo (POS) o negativo (NEG). Detiene el avance de los ejes y el giro del cabezal" .

ns1:LIMITNEG a ns1:Sensor ;
    ns1:textoExtracto "LIMITNEG(axis)" .

ns1:LIMITPOS a ns1:Sensor ;
    ns1:textoExtracto "LIMITPOS(axis)" .

ns1:LIMITPOS3 a ns1:Sensor ;
    ns1:textoExtracto "LIMITPOS3" .

ns1:LIMITPOS5 a ns1:Sensor ;
    ns1:textoExtracto "LIMITPOS5" .

ns1:LIMITPOSB a ns1:Sensor ;
    ns1:textoExtracto "LIMITPOSB" .

ns1:LIMITPOSS a ns1:Sensor ;
    ns1:textoExtracto "LIMITPOSS" .

ns1:LIMITPOSX a ns1:Sensor ;
    ns1:textoExtracto "LIMITPOSX" .

ns1:LIMITPOSZ2 a ns1:Sensor ;
    ns1:textoExtracto "LIMITPOSZ2" .

ns1:MaquinaEjeB a ns1:Maquina ;
    ns1:textoExtracto "corresponde al eje B" .

ns1:MaquinaEjeZ a ns1:Maquina ;
    ns1:textoExtracto "corresponde al eje Z" .

ns1:ModoOperacionLazoCerrado a ns1:ModoOperacion ;
    ns1:textoExtracto "Cuando el cabezal trabaja en lazo cerrado (M19 ó G63) se comporta como un eje" .

ns1:SistemaControlCNC a ns1:Sistema ;
    ns1:textoExtracto "el CNC entiende que el eje o cabezal correspondiente ha sobrepasado el límite de recorrido en el sentido positivo (POS) o negativo (NEG). Detiene el avance de los ejes y el giro del cabezal, visualizando en la pantalla el error correspondiente" .

