@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_EjeIndependiente a ns1:ComponenteMecanico ;
    rdfs:label "Eje independiente"@es ;
    ns1:controla ns1:Senal_INHIBIT_axis ;
    ns1:textoExtracto "Para los ejes independientes y leva electrónica, si el PLC pone esta señal a (=1), se detiene el movimiento de sincronización"@es .

ns1:Componente_LevaElectronica a ns1:ComponenteElectrico ;
    rdfs:label "Leva electrónica"@es ;
    ns1:controla ns1:Senal_INHIBIT_axis ;
    ns1:textoExtracto "Para los ejes independientes y leva electrónica, si el PLC pone esta señal a (=1), se detiene el movimiento de sincronización"@es .

ns1:ModoOperacion_BusquedaCero a ns1:ModoOperacion ;
    rdfs:label "Modo de búsqueda de cero"@es ;
    ns1:habilitadoPor ns1:Senal_INHIBIT_axis ;
    ns1:textoExtracto "En este caso, es necesario invertir el sentido de movimiento para continuar con la búsqueda de cero."@es .

ns1:SistemaControlMovimiento a ns1:Sistema ;
    rdfs:label "Sistema de control de movimiento de ejes y cabezales"@es ;
    ns1:controla ns1:Senal_INHIBIT_axis ;
    ns1:textoExtracto "Para los ejes independientes y leva electrónica, si el PLC pone esta señal a (=1), se detiene el movimiento de sincronización, pasando a velocidad nula. El sistema permanece en espera hasta que se desactive la señal para reanudar la"@es .

ns1:Senal_INHIBIT_axis a ns1:ComponenteElectrico ;
    rdfs:label "Señal INHIBIT(axis)"@es ;
    ns1:identificador "INHIBIT(axis)" ;
    ns1:textoExtracto "INHIBIT(axis) Si el PLC pone esta marca a (=1) el CNC impide cualquier movimiento del eje o cabezal correspondiente. Este movimiento continuará cuando el PLC vuelva a poner esta marca a (=0)."@es .

