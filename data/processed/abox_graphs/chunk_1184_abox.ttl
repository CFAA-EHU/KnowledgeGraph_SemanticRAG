@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CondicionReguladorOK a ns1:Parametro ;
    rdfs:label "Condición regulador OK"@es ;
    ns1:textoExtracto "(regulador OK)"@es ;
    ns1:valor "OK" .

ns1:ErrorMovimientoEjeBloqueado a ns1:AvisoSeguridad ;
    rdfs:label "Error por movimiento de eje bloqueado"@es ;
    ns1:textoExtracto "Si se mueve el eje cuando está bloqueado, el CNC almacena la desviación como error de"@es .

ns1:Se_alEnableEje a ns1:ComponenteElectrico ;
    rdfs:label "Señal ENABLE(axis)"@es ;
    ns1:identificador "ENABLE(axis)" ;
    ns1:textoExtracto "El CNC la pone a (=1) cada vez que quiere mover el eje. Ver \"ENABLE(axis)\" 418."@es .

