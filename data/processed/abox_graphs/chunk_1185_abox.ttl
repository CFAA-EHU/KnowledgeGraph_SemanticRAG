@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaControlEje a ns1:Sistema ;
    rdfs:label "Sistema de control de movimiento del eje" ;
    ns1:activaAlarma ns1:ErrorSeguimientoEje ;
    ns1:controla ns1:Se_alENABLE_Eje ;
    ns1:textoExtracto "Al volver a controlarlo (SERVOON=1) vuelve a posición." .

ns1:ErrorSeguimientoEje a ns1:AvisoSeguridad ;
    rdfs:label "Error de seguimiento del eje" ;
    ns1:mitigaRiesgo ns1:Se_alENABLE_Eje ;
    ns1:textoExtracto "Si se mueve el eje cuando está bloqueado, el CNC almacena la desviación como error de seguimiento." .

ns1:Se_alENABLE_Eje a ns1:Parametro ;
    rdfs:label "ENABLE(axis)" ;
    ns1:identificador "ENABLE" ;
    ns1:textoExtracto "Ver \"ENABLE(axis)\" 418. (no errores) AND (regulador OK) AND ENABLE = SERVOON" ;
    ns1:valor "SERVOON=1" .

