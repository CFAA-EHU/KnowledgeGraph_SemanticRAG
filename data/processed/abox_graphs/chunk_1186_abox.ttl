@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_AristaMatada a ns1:ModoOperacion ;
    rdfs:label "Modo de arista matada" ;
    ns1:identificador "G05, G50, HSC" ;
    ns1:textoExtracto "Cuando el CNC trabaja en cualquier modo de arista matada (G05, G50 o HSC)" .

ns1:ModoOperacion_EjeVisualizador a ns1:ModoOperacion ;
    rdfs:label "Modo eje/cabezal visualizador" ;
    ns1:habilitadoPor ns1:Parametro_DRO_axis,
        ns1:Parametro_SERVOnON ;
    ns1:textoExtracto "el eje o cabezal trabaje como visualizador, para ello la marca DRO debe estar a (=1) y SERVOnON a (=0)" .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:activaAlarma ns1:AvisoSeguridad_EjeBloqueado ;
    ns1:controla ns1:Sensor_SERVOnON ;
    ns1:textoExtracto "el CNC espera el tiempo indicado en el parámetro DWELL. [...] el CNC no tiene en cuenta los límites de software ni las zonas de trabajo" ;
    ns1:tieneComponente ns1:Parametro_DEAD_axis,
        ns1:Parametro_DRO_axis,
        ns1:Parametro_DWELL,
        ns1:Parametro_LIM_axis_OFF,
        ns1:Parametro_SERVOnON .

ns1:AvisoSeguridad_EjeBloqueado a ns1:AvisoSeguridad ;
    rdfs:label "Error 'eje bloqueado'" ;
    ns1:textoExtracto "el CNC muestra el error 'eje bloqueado'. [...] puede dar error de eje bloqueado en el empalme de bloques" .

ns1:Parametro_DEAD_axis a ns1:Parametro ;
    rdfs:label "Marca DEAD(axis)" ;
    ns1:textoExtracto "el PLC debe activar la marca DEAD(axis) para que el CNC no aplique el empalme de bloques en estos ejes muertos" ;
    ns1:valor "DEAD(axis)" .

ns1:Parametro_DWELL a ns1:Parametro ;
    rdfs:label "Parámetro DWELL" ;
    ns1:monitoreaParametro ns1:Sensor_SERVOnON ;
    ns1:textoExtracto "el parámetro DWELL solamente si SERVOnON está a (=0). [...] asignar al parámetro máquina DWELL un valor superior al tiempo entre 2 scan de PLC" .

ns1:Parametro_LIM_axis_OFF a ns1:Parametro ;
    rdfs:label "Marca LIM(axis)OFF" ;
    ns1:textoExtracto "Si el PLC activa esta marca, el CNC no tiene en cuenta los límites de software ni las zonas de trabajo fijadas para el eje correspondiente" ;
    ns1:valor "LIM(axis)OFF" .

ns1:Parametro_DRO_axis a ns1:Parametro ;
    rdfs:label "Marca DRO(axis)" ;
    ns1:textoExtracto "la marca DRO debe estar a (=1) y SERVOnON a (=0). [...] Si la marca DRO vuelve a (=0) el eje deja de ser eje visualizador" ;
    ns1:valor "DRO(axis)" .

ns1:Parametro_SERVOnON a ns1:Parametro ;
    rdfs:label "Marca SERVOnON" ;
    ns1:monitoreaParametro ns1:Sensor_SERVOnON ;
    ns1:textoExtracto "el CNC espera el tiempo indicado en el parámetro DWELL solamente si SERVOnON está a (=0). [...] la marca SERVOnON de antemano" ;
    ns1:valor "SERVOnON" .

ns1:Sensor_SERVOnON a ns1:Sensor ;
    rdfs:label "Sensor SERVOnON" ;
    ns1:textoExtracto "el CNC espera el tiempo indicado en el parámetro DWELL solamente si SERVOnON está a (=0)" .

