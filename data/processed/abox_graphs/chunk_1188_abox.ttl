@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ControlEjes a ns1:Sistema ;
    rdfs:label "Sistema de control de ejes y cabezales" ;
    ns1:controla ns1:Componente_Motor ;
    ns1:textoExtracto "El PLC utiliza estas marcas para habilitar los reguladores cuando la comunicación es vía Sercos o para habilitar los servos e inverters cuando la comunicación es vía Mechatrolink." ;
    ns1:tieneComponente ns1:Senal_DRENA,
        ns1:Senal_LUBRENA,
        ns1:Senal_LUBROK,
        ns1:Senal_PARKED,
        ns1:Senal_SPENA .

ns1:AccionProhibida_ZonaProhibida a ns1:AccionProhibida ;
    rdfs:label "Operación en zona prohibida" ;
    ns1:textoExtracto "una zona prohibida. Los límites de software se pueden fijar mediante los parámetros máquina, mediante las funciones G198/G199 o mediante variables." .

ns1:Componente_Motor a ns1:ComponenteMecanico ;
    rdfs:label "Motor de eje/cabezal" ;
    ns1:textoExtracto "El motor responderá a todas las variaciones de consigna. [...] el motor queda sin par. En esta situación el motor frena manteniendo el par, y una vez parado, se apaga el circuito de potencia del regulador y el motor queda sin par." .

ns1:Parametro_EstadoPotencia a ns1:Parametro ;
    rdfs:label "Estado del circuito de potencia" ;
    ns1:textoExtracto "Si el PLC desactiva la señal DRENA (drive enable), el circuito de potencia del dispositivo se apaga y el motor queda sin par." .

ns1:Parametro_Velocidad a ns1:Parametro ;
    rdfs:label "Consigna de velocidad" ;
    ns1:textoExtracto "Si el PLC desactiva la señal SPENA (speed enable), la consigna de velocidad interna del dispositivo se conmuta a 0 rpm." ;
    ns1:valor "0 rpm" .

ns1:Senal_DRENA a ns1:ComponenteElectrico ;
    rdfs:label "DRENA(axis)" ;
    ns1:monitoreaParametro ns1:Parametro_EstadoPotencia ;
    ns1:textoExtracto "La marca SPENA(axis) corresponde a la señal \"speed enable\" y la marca DRENA(axis) a la señal \"drive enable\" del dispositivo." .

ns1:Senal_LUBRENA a ns1:ComponenteElectrico ;
    rdfs:label "LUBRENA(axis)" ;
    ns1:textoExtracto "Estas marcas junto con la señal de consulta de ejes LUBR(axis) se deben utilizar para el engrase de los ejes." .

ns1:Senal_LUBROK a ns1:ComponenteElectrico ;
    rdfs:label "LUBROK(axis)" ;
    ns1:textoExtracto "Estas marcas junto con la señal de consulta de ejes LUBR(axis) se deben utilizar para el engrase de los ejes." .

ns1:Senal_PARKED a ns1:ComponenteElectrico ;
    rdfs:label "PARKED(axis)" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_ZonaProhibida ;
    ns1:textoExtracto "El PLC pone esta marca a (=1) para indicar al CNC que el eje o cabezal correspondiente está aparcado." .

ns1:Senal_SPENA a ns1:ComponenteElectrico ;
    rdfs:label "SPENA(axis)" ;
    ns1:monitoreaParametro ns1:Parametro_Velocidad ;
    ns1:textoExtracto "La marca SPENA(axis) corresponde a la señal \"speed enable\" y la marca DRENA(axis) a la señal \"drive enable\" del dispositivo." .

