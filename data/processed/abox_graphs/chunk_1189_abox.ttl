@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Pagina_420_EngraseEjes a ns1:Pagina ;
    rdfs:label "Página 420 - Engrase de ejes" ;
    ns1:documentadoEn ns1:Manual ;
    ns1:identificador "420" ;
    ns1:ilustradoEn ns1:Senal_LUBR,
        ns1:Senal_LUBRENA,
        ns1:Senal_LUBROK,
        ns1:Senal_PARK_UNPARK ;
    ns1:textoExtracto "Ver en la página 'PARK(axis) UNPARK(axis)' 420. [...] Ver 'LUBR(axis)'." .

ns1:Senal_LUBR a ns1:Parametro ;
    rdfs:label "LUBR(axis)" ;
    ns1:identificador "LUBR" ;
    ns1:textoExtracto "Estas marcas junto con la señal de consulta de ejes LUBR(axis) se deben utilizar para el engrase de los ejes." .

ns1:Senal_LUBRENA a ns1:Parametro ;
    rdfs:label "LUBRENA(axis)" ;
    ns1:identificador "LUBRENA" ;
    ns1:textoExtracto "La marca LUBRENA indica si se desea esta prestación (=1), o no (=0)." .

ns1:Senal_LUBROK a ns1:Parametro ;
    rdfs:label "LUBROK(axis)" ;
    ns1:identificador "LUBROK" ;
    ns1:textoExtracto "LUBRENA(axis) LUBROK(axis) Estas marcas [...] se deben utilizar para el engrase de los ejes." .

ns1:Senal_PARK_UNPARK a ns1:Parametro ;
    rdfs:label "PARK(axis) UNPARK(axis)" ;
    ns1:identificador "PARK/UNPARK" ;
    ns1:textoExtracto "Ver en la página 'PARK(axis) UNPARK(axis)' 420. Estas marcas [...] se deben utilizar para el engrase de los ejes." .

