@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:DepositoLubricacionManual_118 a ex:ComponenteMecanico ;
    ex:textoExtracto "La capacidad del depósito es de 5 litros." ;
    ex:identificador "Depósito de lubricación manual" ;
    ex:valor "5 litros" .

ex:FluidoLubricanteISO3498G220_118 a ex:Consumible ;
    ex:textoExtracto "El fluido a emplear debe ser Aceite ISO 3498 G220, de viscosidad 220 cSt a 40 C°." ;
    ex:identificador "Aceite ISO 3498 G220" ;
    ex:valor "220 cSt a 40 C°" .