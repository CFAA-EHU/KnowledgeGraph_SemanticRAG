@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:DepositoLubricacion a owl:Class ;
    rdfs:label "DepositoLubricacion" .

ex:FluidoLubricante a owl:Class ;
    rdfs:label "FluidoLubricante" .

ex:tieneCapacidad a owl:DatatypeProperty ;
    rdfs:domain ex:DepositoLubricacion ;
    rdfs:range xsd:decimal .

ex:tieneViscosidad a owl:DatatypeProperty ;
    rdfs:domain ex:FluidoLubricante ;
    rdfs:range xsd:decimal .

ex:tieneTemperatura a owl:DatatypeProperty ;
    rdfs:domain ex:FluidoLubricante ;
    rdfs:range xsd:decimal .

ex:tieneTipo a owl:DatatypeProperty ;
    rdfs:domain ex:FluidoLubricante ;
    rdfs:range xsd:string .