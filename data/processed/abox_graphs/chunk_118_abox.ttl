@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DepositoLubricacionManual_118 a ns1:ComponenteMecanico ;
    rdfs:label "Depósito de lubricación manual"@es ;
    ns1:textoExtracto "La capacidad del depósito es de 5 litros."@es ;
    ns1:valor "5 litros"@es .

ns1:FluidoLubricanteISO3498G220_118 a ns1:Consumible ;
    rdfs:label "Aceite ISO 3498 G220"@es ;
    ns1:identificador "ISO 3498 G220"@es ;
    ns1:textoExtracto "El fluido a emplear debe ser Aceite ISO 3498 G220, de viscosidad 220 cSt a 40 C°."@es ;
    ns1:valor "220 cSt a 40 C°"@es .

