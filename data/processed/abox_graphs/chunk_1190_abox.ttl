@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_REFPOIN a ns1:Parametro ;
    rdfs:label "REFPOIN" ;
    ns1:identificador "REFPOIN" ;
    ns1:textoExtracto "La marca REFPOIN(axis) de ambos ejes se activa cuando termina la corrección de la cota." ;
    ns1:valor "0,1" .

ns1:Marca_SERVO a ns1:Parametro ;
    rdfs:label "SERVO" ;
    ns1:identificador "SERVO" ;
    ns1:textoExtracto "Con el flanco de subida de SERVO(axis)ON si DIFFCOMP(axis) está activa (=1)." ;
    ns1:valor "0,1" .

ns1:Parametro_LUBRENA a ns1:Parametro ;
    rdfs:label "LUBRENA" ;
    ns1:identificador "LUBRENA" ;
    ns1:textoExtracto "La marca LUBRENA indica si se desea esta prestación (=1), o no (=0)." ;
    ns1:valor "0,1" .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:controla ns1:Marca_LUBROK ;
    ns1:textoExtracto "El PLC tras engrasar el eje pone la marca LUBROK(axis) a (=1) para indicar al CNC que ya se ha engrasado el eje." .

ns1:TareaMantenimiento_EngraseEjes a ns1:TareaMantenimiento ;
    rdfs:label "Engrase de ejes" ;
    ns1:documentadoEn ns1:Pagina_420 ;
    ns1:requiereMantenimiento ns1:SistemaCNC ;
    ns1:textoExtracto "LUBR(axis) se deben utilizar para [...] engrase de los ejes. [...] Ver 'LUBR(axis)'" .

ns1:Marca_DIFFCOMP a ns1:Parametro ;
    rdfs:label "DIFFCOMP" ;
    ns1:identificador "DIFFCOMP" ;
    ns1:textoExtracto "Esta marca se utiliza en los ejes gantry. [...] DIFFCOMP(axis) Esta marca corrige la diferencia de cota entre el eje maestro y esclavo" ;
    ns1:valor "0,1" .

ns1:Marca_FBACKSEL a ns1:Parametro ;
    rdfs:label "FBACKSEL" ;
    ns1:identificador "FBACKSEL" ;
    ns1:textoExtracto "El CNC utiliza esta marca cuando el sistema dispone de captación externa+interna. [...] Con el flanco de subida de esta marca se conmuta a la captación externa (captación directa) y con el flanco de bajada se conmuta a captación interna (captación motor)." ;
    ns1:valor "0,1" .

ns1:Marca_LUBR a ns1:Parametro ;
    rdfs:label "LUBR" ;
    ns1:identificador "LUBR" ;
    ns1:textoExtracto "el CNC pone la marca LUBR a (=1) para indicar al PLC que se debe engrasar el eje. [...] El CNC pone la marca LUBR a (=0) e inicializa la cuenta a 0." ;
    ns1:valor "0,1" .

ns1:Marca_LUBROK a ns1:Parametro ;
    rdfs:label "LUBROK" ;
    ns1:identificador "LUBROK" ;
    ns1:textoExtracto "El PLC tras engrasar el eje pone la marca LUBROK(axis) a (=1) para indicar al CNC que ya se ha engrasado el eje. [...] Se debe tener cuidado de poner la marca LUBROK a (=0) para que la prestación funcione correctamente" ;
    ns1:valor "0,1" .

ns1:Parametro_DISTLUBRI a ns1:Parametro ;
    rdfs:label "DISTLUBRI" ;
    ns1:identificador "DISTLUBRI" ;
    ns1:textoExtracto "el parámetro máquina DISTLUBRI [...] el CNC pone la marca LUBR a (=1) para indicar al PLC que se debe engrasar el eje." .

ns1:Parametro_FBACKSRC a ns1:Parametro ;
    rdfs:label "FBACKSRC" ;
    ns1:identificador "FBACKSRC" ;
    ns1:textoExtracto "Consultar el parámetro FBACKSRC." .

ns1:Parametro_FBMIXTIME a ns1:Parametro ;
    rdfs:label "FBMIXTIME" ;
    ns1:identificador "FBMIXTIME" ;
    ns1:textoExtracto "Si está activa la mezcla de captaciones (parámetro FBMIXTIME), con el flanco de subida de esta marca se utiliza la mezcla de captaciones." .

ns1:Parametro_REFFEED2 a ns1:Parametro ;
    rdfs:label "REFFEED2" ;
    ns1:identificador "REFFEED2" ;
    ns1:textoExtracto "El eje esclavo se moverá hasta alcanzar la cota del eje maestro, al avance especificado en el parámetro REFFEED2." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:controla ns1:Marca_DIFFCOMP,
        ns1:Marca_FBACKSEL,
        ns1:Marca_LUBR ;
    ns1:monitoreaParametro ns1:Parametro_DISTLUBRI,
        ns1:Parametro_FBACKSRC,
        ns1:Parametro_FBMIXTIME,
        ns1:Parametro_REFFEED2 ;
    ns1:textoExtracto "el CNC actúa del siguiente modo: [...] El CNC pone la marca LUBR a (=0) e inicializa la cuenta a 0." .

