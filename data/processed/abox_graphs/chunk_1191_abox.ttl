@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCaptacionMixta a ns1:Sistema ;
    rdfs:label "Sistema de mezcla de captaciones (interna+externa)" ;
    ns1:controla ns1:Parametro_FBMIXTIME ;
    ns1:ilustradoEn ns1:Marca_ACTFBACK ;
    ns1:textoExtracto "mezcla de captaciones [...] Cuando el tipo de captación es interna+externa, el CNC utiliza la captación interna (captación motor) en el encendido, cuando se resetea el regulador y cuando se inicializa el anillo Sercos" ;
    ns1:tieneComponente ns1:ComponenteElectrico_CaptacionMotor .

ns1:ComponenteElectrico_CaptacionMotor a ns1:ComponenteElectrico ;
    rdfs:label "Captación motor (interna)" ;
    ns1:textoExtracto "captación interna (captación motor)" .

ns1:Marca_ACTFBACK a ns1:InterfazUsuario ;
    rdfs:label "ACTFBACK(axis)" ;
    ns1:identificador "ACTFBACK(axis)" ;
    ns1:monitoreaParametro ns1:Parametro_FBMIXTIME ;
    ns1:textoExtracto "La marca ACTFBACK(axis) indica cuál es la captación activa" .

ns1:Parametro_FBMIXTIME a ns1:Parametro ;
    rdfs:label "FBMIXTIME" ;
    ns1:identificador "FBMIXTIME" ;
    ns1:textoExtracto "parámetro FBMIXTIME" .

