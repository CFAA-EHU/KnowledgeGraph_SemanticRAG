@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PLC_TandemEjeC a ns1:Actuador ;
    rdfs:label "PLC del sistema de tándem de eje C"@es ;
    ns1:controla ns1:MarcaDesacopleEjeC ;
    ns1:textoExtracto "Si el PLC activa esta marca, el eje esclavo se desacopla del maestro"@es .

ns1:SistemaTandemEjeC a ns1:Sistema ;
    rdfs:label "Sistema de tándem de eje C"@es ;
    ns1:textoExtracto "en un tándem de eje C donde es necesario engranar cada motor, para lo que hace falta generar un movimiento de oscilación en cada motor pero sin afectar al otro"@es ;
    ns1:tieneComponente ns1:MotorEsclavoEjeC,
        ns1:MotorMaestroEjeC .

ns1:MotorEsclavoEjeC a ns1:ComponenteMecanico ;
    rdfs:label "Motor esclavo del eje C"@es ;
    ns1:controla ns1:MarcaDesacopleEjeC ;
    ns1:textoExtracto "eje o cabezal esclavo del tándem [...] el eje esclavo se desacopla del maestro, y ambos ejes se pueden mover de forma independiente"@es .

ns1:MotorMaestroEjeC a ns1:ComponenteMecanico ;
    rdfs:label "Motor maestro del eje C"@es ;
    ns1:textoExtracto "eje esclavo del tándem [...] el eje esclavo se desacopla del maestro"@es .

ns1:MarcaDesacopleEjeC a ns1:Parametro ;
    rdfs:label "Marca de referencia para desacople del eje esclavo"@es ;
    ns1:identificador "Marca_desacople_tándem_eje_C" ;
    ns1:textoExtracto "Esta marca hace referencia al eje o cabezal esclavo del tándem. Si el PLC activa esta marca, el eje esclavo se desacopla del maestro"@es .

