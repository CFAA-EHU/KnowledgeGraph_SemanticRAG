@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_MarcaGantry a ns1:Parametro ;
    rdfs:label "Marca de control: Gantry" ;
    ns1:identificador "GANTRYOFF(axis)" ;
    ns1:monitoreaParametro ns1:ModoOperacion_GantryDesacoplado ;
    ns1:textoExtracto "GANTRYOFF(axis) Esta marca hace referencia al eje esclavo del gantry." .

ns1:Parametro_MarcaTandem a ns1:Parametro ;
    rdfs:label "Marca de control: Tándem" ;
    ns1:identificador "PLCOFFSET" ;
    ns1:monitoreaParametro ns1:ModoOperacion_TandemDesacoplado ;
    ns1:textoExtracto "El eje esclavo únicamente se puede mover desde el PLC a través del PLCOFFSET." .

ns1:Sistema_EjesGantry a ns1:Sistema ;
    rdfs:label "Sistema de ejes en gantry" ;
    ns1:controla ns1:ModoOperacion_GantryDesacoplado ;
    ns1:textoExtracto "el CNC desacopla el eje gantry y permite mover sólo el eje maestro. [...] permite corregir la posición de los ejes cuando estos se han cruzado y no se pueden recuperar automáticamente." ;
    ns1:tieneComponente ns1:Componente_EjeEsclavoGantry,
        ns1:Componente_EjeMaestroGantry .

ns1:Sistema_EjesTandem a ns1:Sistema ;
    rdfs:label "Sistema de ejes en tándem" ;
    ns1:controla ns1:ModoOperacion_TandemDesacoplado ;
    ns1:textoExtracto "El eje esclavo se desacopla del maestro, y ambos ejes se pueden mover de forma independiente. [...] El CNC visualiza las cotas del eje maestro, no permite programar sobre el eje esclavo y no se podrá aparcar ninguno de los ejes." ;
    ns1:tieneComponente ns1:Componente_EjeEsclavo,
        ns1:Componente_EjeMaestro .

ns1:Componente_EjeEsclavo a ns1:ComponenteMecanico ;
    rdfs:label "Eje esclavo (tándem)" ;
    ns1:textoExtracto "el eje esclavo se desacopla del maestro [...] El eje esclavo únicamente se puede mover desde el PLC a través del PLCOFFSET. [...] al finalizar la búsqueda [de referencia], el CNC también inicializará la cota del esclavo (con la cota del maestro)." .

ns1:Componente_EjeEsclavoGantry a ns1:ComponenteMecanico ;
    rdfs:label "Eje esclavo (gantry)" ;
    ns1:textoExtracto "GANTRYOFF(axis) Esta marca hace referencia al eje esclavo del gantry." .

ns1:Componente_EjeMaestro a ns1:ComponenteMecanico ;
    rdfs:label "Eje maestro (tándem)" ;
    ns1:textoExtracto "El eje maestro se puede mover de la forma habitual desde el panel de jog, modo MDI/MDA, etc. [...] El CNC podrá ejecutar una búsqueda de referencia del eje maestro." .

ns1:Componente_EjeMaestroGantry a ns1:ComponenteMecanico ;
    rdfs:label "Eje maestro (gantry)" ;
    ns1:textoExtracto "permite mover sólo el eje maestro [en modo gantry]." .

ns1:ModoOperacion_GantryDesacoplado a ns1:ModoOperacion ;
    rdfs:label "Modo de operación: Gantry desacoplado" ;
    ns1:textoExtracto "Si el PLC activa esta marca (cambio de 0 a 1), el CNC desacopla el eje gantry y permite mover sólo el eje maestro. Esta marca facilita el ajuste del gantry, y permite corregir la posición de los ejes cuando estos se han cruzado y no se pueden recuperar automáticamente." .

ns1:ModoOperacion_TandemDesacoplado a ns1:ModoOperacion ;
    rdfs:label "Modo de operación: Tándem desacoplado" ;
    ns1:textoExtracto "Si el PLC activa esta marca, el eje esclavo se desacopla del maestro, y ambos ejes se pueden mover de forma independiente. [...] Aunque el tándem esté desacoplado, desde el punto de vista de programación, visualización, etc el tándem está activo." .

