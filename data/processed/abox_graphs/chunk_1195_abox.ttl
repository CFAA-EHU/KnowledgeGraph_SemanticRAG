@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:GEAR1SP1 a ns1:Parametro ;
    rdfs:label "Parámetro SP1 de GEAR1" ;
    ns1:identificador "GEAR1SP1" ;
    ns1:textoExtracto "GEAR1SP1 (también se puede programar como GEAR1)" .

ns1:GEAR1SP2 a ns1:Parametro ;
    rdfs:label "Parámetro SP2 de GEAR1" ;
    ns1:identificador "GEAR1SP2" ;
    ns1:textoExtracto "GEAR1SP2" .

ns1:GEAR1SP3 a ns1:Parametro ;
    rdfs:label "Parámetro SP3 de GEAR1" ;
    ns1:identificador "GEAR1SP3" ;
    ns1:textoExtracto "GEAR1SP3" .

ns1:GEAR1SP4 a ns1:Parametro ;
    rdfs:label "Parámetro SP4 de GEAR1" ;
    ns1:identificador "GEAR1SP4" ;
    ns1:textoExtracto "GEAR1SP4" .

ns1:GEAR1SP5 a ns1:Parametro ;
    rdfs:label "Parámetro SP5 de GEAR1" ;
    ns1:identificador "GEAR1SP5" ;
    ns1:textoExtracto "GEAR1SP5" .

ns1:GEAR1SP6 a ns1:Parametro ;
    rdfs:label "Parámetro SP6 de GEAR1" ;
    ns1:identificador "GEAR1SP6" ;
    ns1:textoExtracto "GEAR1SP6" .

ns1:SistemaCambioGama a ns1:Sistema ;
    rdfs:label "Sistema de cambio de gama de cabezales" ;
    ns1:textoExtracto "El PLC utiliza estas marcas para indicar al CNC cuál de las gamas del cabezal está seleccionada [...] Cuando el set de parámetros seleccionado en el CNC y en el PLC coinciden" ;
    ns1:tieneComponente ns1:FuncionM41,
        ns1:FuncionM42,
        ns1:FuncionM43,
        ns1:FuncionM44,
        ns1:GEAR1,
        ns1:GEAR2,
        ns1:GEAR3,
        ns1:GEAR4,
        ns1:Parametro_INPUTREV,
        ns1:Parametro_NPULSES,
        ns1:Parametro_OUTPUTREV,
        ns1:Parametro_SZERO,
        ns1:Senal_AUXEND,
        ns1:Senal_GEAROK .

ns1:FuncionM41 a ns1:AccionProhibida,
        ns1:Tabla ;
    rdfs:label "Función auxiliar M41 (cambio a GEAR1)" ;
    ns1:identificador "M41" ;
    ns1:solucionaFallo ns1:Senal_GEAROK ;
    ns1:textoExtracto "el CNC se lo indica al PLC mediante las funciones auxiliares M41, M42, M43 o M44 [...] M41 con GEAR1" .

ns1:FuncionM42 a ns1:AccionProhibida,
        ns1:Tabla ;
    rdfs:label "Función auxiliar M42 (cambio a GEAR2)" ;
    ns1:identificador "M42" ;
    ns1:solucionaFallo ns1:Senal_GEAROK ;
    ns1:textoExtracto "M42 [...] Si estando activa la gama 1 se solicita la gama 2 (M42)" .

ns1:FuncionM43 a ns1:AccionProhibida,
        ns1:Tabla ;
    rdfs:label "Función auxiliar M43 (cambio a GEAR3)" ;
    ns1:identificador "M43" ;
    ns1:solucionaFallo ns1:Senal_GEAROK ;
    ns1:textoExtracto "M43" .

ns1:FuncionM44 a ns1:AccionProhibida,
        ns1:Tabla ;
    rdfs:label "Función auxiliar M44 (cambio a GEAR4)" ;
    ns1:identificador "M44" ;
    ns1:solucionaFallo ns1:Senal_GEAROK ;
    ns1:textoExtracto "M44" .

ns1:GEAR1 a ns1:ModoOperacion ;
    rdfs:label "Gama 1 del cabezal" ;
    ns1:identificador "GEAR1" ;
    ns1:requiereMantenimiento ns1:Parametro_SZERO ;
    ns1:textoExtracto "GEAR1 (también se puede programar como GEAR1)" .

ns1:GEAR2 a ns1:ModoOperacion ;
    rdfs:label "Gama 2 del cabezal" ;
    ns1:identificador "GEAR2" ;
    ns1:requiereMantenimiento ns1:Parametro_SZERO ;
    ns1:textoExtracto "M42 [...] Si estando activa la gama 1 se solicita la gama 2" .

ns1:GEAR3 a ns1:ModoOperacion ;
    rdfs:label "Gama 3 del cabezal" ;
    ns1:identificador "GEAR3" ;
    ns1:requiereMantenimiento ns1:Parametro_SZERO ;
    ns1:textoExtracto "M43 [...] Hay una marca para cada cabezal" .

ns1:GEAR4 a ns1:ModoOperacion ;
    rdfs:label "Gama 4 del cabezal" ;
    ns1:identificador "GEAR4" ;
    ns1:requiereMantenimiento ns1:Parametro_SZERO ;
    ns1:textoExtracto "M44 [...] Hay una marca para cada cabezal" .

ns1:Parametro_INPUTREV a ns1:Parametro ;
    rdfs:label "Parámetro INPUTREV (reducción en cabezales Sercos)" ;
    ns1:identificador "INPUTREV" ;
    ns1:textoExtracto "cambio en la reducción (NPULSES, INPUTREV, OUTPUTREV)" .

ns1:Parametro_NPULSES a ns1:Parametro ;
    rdfs:label "Parámetro NPULSES (reducción en cabezales Sercos)" ;
    ns1:identificador "NPULSES" ;
    ns1:textoExtracto "cambio en la reducción (NPULSES, INPUTREV, OUTPUTREV)" .

ns1:Parametro_OUTPUTREV a ns1:Parametro ;
    rdfs:label "Parámetro OUTPUTREV (reducción en cabezales Sercos)" ;
    ns1:identificador "OUTPUTREV" ;
    ns1:textoExtracto "cambio en la reducción (NPULSES, INPUTREV, OUTPUTREV)" .

ns1:Senal_AUXEND a ns1:Sensor ;
    rdfs:label "Señal AUXEND (confirmación de cambio)" ;
    ns1:identificador "AUXEND" ;
    ns1:textoExtracto "El cambio de gama se da por finalizado cuando el PLC recibe la confirmación de la señal AUXEND" .

ns1:Parametro_SZERO a ns1:Parametro ;
    rdfs:label "Parámetro SZERO (velocidad de confirmación)" ;
    ns1:identificador "SZERO" ;
    ns1:textoExtracto "cuando la velocidad del cabezal alcanza la velocidad definida en el parámetro SZERO" .

ns1:Senal_GEAROK a ns1:Sensor ;
    rdfs:label "Señal GEAROK (coincidencia de parámetros)" ;
    ns1:identificador "GEAROK" ;
    ns1:textoExtracto "el cabezal activa la marca GEAROK" .

