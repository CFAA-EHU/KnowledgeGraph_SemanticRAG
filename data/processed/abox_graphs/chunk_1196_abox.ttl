@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Senal_GEAR1 a ns1:Parametro ;
    rdfs:label "GEAR1" ;
    ns1:identificador "I21" ;
    ns1:monitoreaParametro ns1:CambioGama_Proceso ;
    ns1:textoExtracto "I21 = GEAR1" .

ns1:Senal_GEAR2 a ns1:Parametro ;
    rdfs:label "GEAR2" ;
    ns1:identificador "I22" ;
    ns1:monitoreaParametro ns1:CambioGama_Proceso ;
    ns1:textoExtracto "I22 = GEAR2" .

ns1:SistemaControlCabezales a ns1:Sistema ;
    rdfs:label "Sistema de control de cabezales (PLC-CNC)" ;
    ns1:controla ns1:CambioGama_Proceso ;
    ns1:textoExtracto "El CNC indica al PLC la gama solicitada [...] Cuando el PLC pone la marca PLCCNTL a (=1), el cabezal decelera con rampa hasta detenerse y pasa a estar controlado por el PLC" ;
    ns1:tieneComponente ns1:Cabezal_1,
        ns1:Cabezal_2,
        ns1:Cabezal_3,
        ns1:Cabezal_4,
        ns1:Cabezal_5,
        ns1:Cabezal_6,
        ns1:Indicativo_M1002,
        ns1:Marca_MSTROBE,
        ns1:Parametro_MINAENDW,
        ns1:Senal_AUXEND,
        ns1:Senal_MFUN1,
        ns1:Senal_PLCCNTL1,
        ns1:Senal_PLCCNTL2,
        ns1:Senal_PLCCNTL3,
        ns1:Senal_PLCCNTL4,
        ns1:Senal_PLCCNTL5,
        ns1:Senal_PLCCNTL6,
        ns1:Senal_SANALOG1,
        ns1:Senal_SANALOG2,
        ns1:Senal_SANALOG3,
        ns1:Senal_SANALOG4,
        ns1:Senal_SANALOG5,
        ns1:Senal_SANALOG6 .

ns1:Indicativo_M1002 a ns1:Parametro ;
    rdfs:label "M1002" ;
    ns1:monitoreaParametro ns1:CambioGama_Proceso ;
    ns1:textoExtracto "El PLC al detectar la solicitud pone un indicativo interno [...] SET M1002 [...] quita el indicativo (M1002) y se lo indica al CNC con AUXEND a (=1)" .

ns1:Marca_MSTROBE a ns1:Parametro ;
    rdfs:label "MSTROBE" ;
    ns1:monitoreaParametro ns1:CambioGama_Proceso ;
    ns1:textoExtracto "El CNC [...] pone la marca MSTROBE" .

ns1:Parametro_MINAENDW a ns1:Parametro ;
    rdfs:label "MINAENDW" ;
    ns1:textoExtracto "tiempo superior al definido en el parámetro máquina MINAENDW" .

ns1:Senal_AUXEND a ns1:Parametro ;
    rdfs:label "AUXEND" ;
    ns1:monitoreaParametro ns1:CambioGama_Proceso ;
    ns1:textoExtracto "se lo indica al CNC con AUXEND a (=0) [...] AUXEND a (=1) [...] La marca AUXEND debe mantenerse a (=1) un tiempo superior al definido en el parámetro máquina MINAENDW" .

ns1:Senal_MFUN1 a ns1:Parametro ;
    rdfs:label "MFUN1" ;
    ns1:identificador "42" ;
    ns1:monitoreaParametro ns1:CambioGama_Proceso ;
    ns1:textoExtracto "El CNC indica al PLC la gama solicitada con MFUN1=42" .

ns1:Senal_PLCCNTL1 a ns1:Parametro ;
    rdfs:label "PLCCNTL1 (PLCCNTL)" ;
    ns1:controla ns1:Cabezal_1 ;
    ns1:textoExtracto "PLCCNTL1 (también se puede programar como PLCCNTL)" .

ns1:Senal_PLCCNTL2 a ns1:Parametro ;
    rdfs:label "PLCCNTL2" ;
    ns1:controla ns1:Cabezal_2 ;
    ns1:textoExtracto "PLCCNTL2" .

ns1:Senal_PLCCNTL3 a ns1:Parametro ;
    rdfs:label "PLCCNTL3" ;
    ns1:controla ns1:Cabezal_3 ;
    ns1:textoExtracto "PLCCNTL3" .

ns1:Senal_PLCCNTL4 a ns1:Parametro ;
    rdfs:label "PLCCNTL4" ;
    ns1:controla ns1:Cabezal_4 ;
    ns1:textoExtracto "PLCCNTL4" .

ns1:Senal_PLCCNTL5 a ns1:Parametro ;
    rdfs:label "PLCCNTL5" ;
    ns1:controla ns1:Cabezal_5 ;
    ns1:textoExtracto "PLCCNTL5" .

ns1:Senal_PLCCNTL6 a ns1:Parametro ;
    rdfs:label "PLCCNTL6" ;
    ns1:controla ns1:Cabezal_6 ;
    ns1:textoExtracto "PLCCNTL6" .

ns1:Senal_SANALOG1 a ns1:Parametro ;
    rdfs:label "SANALOG1 (SANALOG)" ;
    ns1:monitoreaParametro ns1:Cabezal_1 ;
    ns1:textoExtracto "SANALOG1 (también se puede programar como SANALOG)" .

ns1:Senal_SANALOG2 a ns1:Parametro ;
    rdfs:label "SANALOG2" ;
    ns1:monitoreaParametro ns1:Cabezal_2 ;
    ns1:textoExtracto "SANALOG2" .

ns1:Senal_SANALOG3 a ns1:Parametro ;
    rdfs:label "SANALOG3" ;
    ns1:monitoreaParametro ns1:Cabezal_3 ;
    ns1:textoExtracto "SANALOG3" .

ns1:Senal_SANALOG4 a ns1:Parametro ;
    rdfs:label "SANALOG4" ;
    ns1:monitoreaParametro ns1:Cabezal_4 ;
    ns1:textoExtracto "SANALOG4" .

ns1:Senal_SANALOG5 a ns1:Parametro ;
    rdfs:label "SANALOG5" ;
    ns1:monitoreaParametro ns1:Cabezal_5 ;
    ns1:textoExtracto "SANALOG5" .

ns1:Senal_SANALOG6 a ns1:Parametro ;
    rdfs:label "SANALOG6" ;
    ns1:monitoreaParametro ns1:Cabezal_6 ;
    ns1:textoExtracto "SANALOG6" .

ns1:Cabezal_1 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal 1" ;
    ns1:textoExtracto "Se dispone de una señal para cada cabezal. PLCCNTL1 [...] SANALOG1" .

ns1:Cabezal_2 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal 2" ;
    ns1:textoExtracto "PLCCNTL2 [...] SANALOG2" .

ns1:Cabezal_3 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal 3" ;
    ns1:textoExtracto "PLCCNTL3 [...] SANALOG3" .

ns1:Cabezal_4 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal 4" ;
    ns1:textoExtracto "PLCCNTL4 [...] SANALOG4" .

ns1:Cabezal_5 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal 5" ;
    ns1:textoExtracto "PLCCNTL5 [...] SANALOG5" .

ns1:Cabezal_6 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal 6" ;
    ns1:textoExtracto "PLCCNTL6 [...] SANALOG6" .

ns1:CambioGama_Proceso a ns1:ModoOperacion ;
    rdfs:label "Cambio de gama entre cabezales" ;
    ns1:textoExtracto "Comienza el cambio y se lo indica al CNC [...] Durante el cambio se le indica al CNC que se deja la gama 1 y que se selecciona la gama 2 [...] Una vez que ha finalizado el cambio de gama quita el indicativo (M1002) y se lo indica al CNC con AUXEND a (=1)" .

