@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MarcaPLCCNTL a ns1:Parametro ;
    ns1:identificador "PLCCNTL" ;
    ns1:monitoreaParametro ns1:PLCControlCabezal ;
    ns1:textoExtracto "la marca PLCCNTL a (=1)" ;
    ns1:valor "1" .

ns1:CabezalAnalogico a ns1:ComponenteElectrico ;
    rdfs:label "Cabezal analógico (control por voltaje)" ;
    ns1:controla ns1:RegistroSANALOG ;
    ns1:textoExtracto "Cabezal analógico. A 10 V de consigna corresponde SANALOG = 32767." .

ns1:CabezalSercosPosicion a ns1:ComponenteElectrico ;
    rdfs:label "Cabezal Sercos (modo posición)" ;
    ns1:controla ns1:RegistroSANALOG ;
    ns1:textoExtracto "Cabezal Sercos en posición. La consigna en SANALOG vendrá expresada en diezmilésima de grado." .

ns1:CabezalSercosVelocidad a ns1:ComponenteElectrico ;
    rdfs:label "Cabezal Sercos (modo velocidad)" ;
    ns1:controla ns1:RegistroSANALOG ;
    ns1:textoExtracto "Cabezal Sercos en velocidad. La consigna en SANALOG vendrá expresada en diezmilésima de rpm." .

ns1:PLCControlCabezal a ns1:Sistema ;
    rdfs:label "Sistema de control PLC para cabezales" ;
    ns1:textoExtracto "Cuando el PLC pone la marca PLCCNTL a (=1), el cabezal decelera con rampa hasta detenerse y pasa a estar controlado por el PLC." ;
    ns1:tieneComponente ns1:CabezalAnalogico,
        ns1:CabezalSercosPosicion,
        ns1:CabezalSercosVelocidad .

ns1:RegistroSANALOG a ns1:Parametro ;
    ns1:identificador "SANALOG" ;
    ns1:monitoreaParametro ns1:PLCControlCabezal ;
    ns1:textoExtracto "El registro SANALOG fija la consigna de cabezal que se desea aplicar." .

