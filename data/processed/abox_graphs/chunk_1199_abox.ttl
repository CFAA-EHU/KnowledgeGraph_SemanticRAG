@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Funcion_M19 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "M19 (lazo cerrado)"@es ;
    ns1:identificador "M19" ;
    ns1:textoExtracto "en los cabezales en lazo cerrado (M19), depende del parámertro M19SPDLEREV."@es .

ns1:Funcion_M3 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "M3 (lazo abierto)"@es ;
    ns1:identificador "M3" ;
    ns1:textoExtracto "el PLC siempre aplica esta marca a los cabezales en lazo abierto (M3/M4)"@es .

ns1:Funcion_M4 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "M4 (lazo abierto)"@es ;
    ns1:identificador "M4" ;
    ns1:textoExtracto "el PLC siempre aplica esta marca a los cabezales en lazo abierto (M3/M4)"@es .

ns1:Marca_PLCCNTL a ns1:Parametro ;
    rdfs:label "PLCCNTL"@es ;
    ns1:controla ns1:Cabezal_Generico ;
    ns1:identificador "PLCCNTL" ;
    ns1:textoExtracto "El PLC [...] activa la marca PLCCNTL para indicar que el cabezal está controlado por el PLC. Una vez finalizado hay que poner PLCCNTL a (=0) [...]."@es ;
    ns1:valor "0"^^xsd:string,
        "1"^^xsd:string .

ns1:Marca_PLCM3 a ns1:Parametro ;
    rdfs:label "PLCM3"@es ;
    ns1:identificador "PLCM3" ;
    ns1:textoExtracto "PLCM3 [...] El PLC dispone de una marca para cada cabezal. Se muestra como ejemplo los mnemónicos para PLCM3; para el resto de los cabezales es igual."@es .

ns1:Marca_SPDLEREV2 a ns1:Parametro ;
    rdfs:label "SPDLEREV2"@es ;
    ns1:identificador "SPDLEREV2" ;
    ns1:textoExtracto "SPDLEREV2 [...] Los mnemónicos para cada cabezal son los siguientes."@es ;
    ns1:valor "0"^^xsd:string,
        "1"^^xsd:string .

ns1:Marca_SPDLEREV3 a ns1:Parametro ;
    rdfs:label "SPDLEREV3"@es ;
    ns1:identificador "SPDLEREV3" ;
    ns1:textoExtracto "SPDLEREV3 [...] Los mnemónicos para cada cabezal son los siguientes."@es ;
    ns1:valor "0"^^xsd:string,
        "1"^^xsd:string .

ns1:Marca_SPDLEREV4 a ns1:Parametro ;
    rdfs:label "SPDLEREV4"@es ;
    ns1:identificador "SPDLEREV4" ;
    ns1:textoExtracto "SPDLEREV4 [...] Los mnemónicos para cada cabezal son los siguientes."@es ;
    ns1:valor "0"^^xsd:string,
        "1"^^xsd:string .

ns1:Marca_SPDLEREV5 a ns1:Parametro ;
    rdfs:label "SPDLEREV5"@es ;
    ns1:identificador "SPDLEREV5" ;
    ns1:textoExtracto "SPDLEREV5 [...] Los mnemónicos para cada cabezal son los siguientes."@es ;
    ns1:valor "0"^^xsd:string,
        "1"^^xsd:string .

ns1:Marca_SPDLEREV6 a ns1:Parametro ;
    rdfs:label "SPDLEREV6"@es ;
    ns1:identificador "SPDLEREV6" ;
    ns1:textoExtracto "SPDLEREV6 [...] Los mnemónicos para cada cabezal son los siguientes."@es ;
    ns1:valor "0"^^xsd:string,
        "1"^^xsd:string .

ns1:Parametro_M19SPDLEREV a ns1:Parametro ;
    rdfs:label "M19SPDLEREV"@es ;
    ns1:identificador "M19SPDLEREV" ;
    ns1:textoExtracto "en los cabezales en lazo cerrado (M19), depende del parámertro M19SPDLEREV."@es .

ns1:Senal_GEAR1_4 a ns1:Parametro ;
    rdfs:label "Señales GEAR1 a GEAR4"@es ;
    ns1:controla ns1:Cabezal_Generico ;
    ns1:monitoreaParametro ns1:ConsignaResidual_SANALOG ;
    ns1:textoExtracto "En el ejemplo de las señales GEAR1 a GEAR4 se detalla cómo detectar y efectuar el cambio de gama. Aquí se muestra la forma de controlar la oscilación del cabezal durante el cambio de gama."@es .

ns1:ConsignaResidual_SANALOG a ns1:Parametro ;
    rdfs:label "SANALOG (consigna residual)"@es ;
    ns1:textoExtracto "El PLC pone en SANALOG el valor correspondiente a la consigna residual y activa la marca PLCCNTL para indicar que el cabezal está controlado por el PLC. Una vez finalizado hay que poner PLCCNTL a (=0) y asignarle a SANALOG el valor 0."@es ;
    ns1:valor "0"^^xsd:string .

ns1:Marca_SPDLEREV1 a ns1:Parametro ;
    rdfs:label "SPDLEREV1"@es ;
    ns1:controla ns1:Cabezal_Generico ;
    ns1:identificador "SPDLEREV1" ;
    ns1:textoExtracto "Cuando el PLC pone esta marca a (=1), el CNC invierte el sentido de giro del cabezal. Para ello decelera y acelera siguiendo las rampas establecidas en los parámetros máquina."@es ;
    ns1:valor "0"^^xsd:string,
        "1"^^xsd:string .

ns1:Cabezal_Generico a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal (genérico)"@es ;
    ns1:textoExtracto "se muestra la forma de controlar la oscilación del cabezal durante el cambio de gama."@es ;
    ns1:tieneComponente ns1:Marca_SPDLEREV1 .

