@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:DepositoRefrigerante_119_86 a ex:Componente ;
    rdfs:label "depósito" ;
    ex:identificador "260 litros" ;
    ex:textoExtracto "La capacidad del depósito es de 260 litros." .

ex:RefrigeranteCUTMAXS5029_1_119_86 a ex:Consumible ;
    rdfs:label "aceite de corte CUT-MAX S 5029-1" ;
    ex:identificador "CUT-MAX S 5029-1" ;
    ex:textoExtracto "Recomendamos utilizar el aceite de corte CUT-MAX S 5029-1, o en su defecto un aceite equivalente." .

ex:DepartamentoHerramientasEKIN_119_86 a ex:Personal ;
    rdfs:label "DEPARTAMENTO DE HERRAMIENTAS DE EKIN" ;
    ex:textoExtracto "ANTE CUALQUIER DUDA SOBRE EL TIPO DE REFRIGERANTE A UTILIZAR, PONERSE EN CONTACTO CON EL DEPARTAMENTO DE HERRAMIENTAS DE EKIN." .