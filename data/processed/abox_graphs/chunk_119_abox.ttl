@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Deposito a owl:Class ;
    rdfs:label "Deposito"@es ;
    rdfs:comment "Capacidad de 260 litros"@es .

ex:AceiteCorte a owl:Class ;
    rdfs:label "AceiteCorte"@es ;
    rdfs:comment "CUT-MAX S 5029-1 o equivalente"@es .

ex:DepartamentoHerramientas a owl:Class ;
    rdfs:label "DepartamentoHerramientas"@es ;
    rdfs:comment "Departamento de herramientas de EKIN"@es .

ex:Refrigerante a owl:Class ;
    rdfs:label "Refrigerante"@es .

ex:tieneCapacidad a owl:DatatypeProperty ;
    rdfs:domain ex:Deposito ;
    rdfs:range xsd:decimal .

ex:recomiendaUtilizar a owl:ObjectProperty ;
    rdfs:domain ex:DepartamentoHerramientas ;
    rdfs:range ex:AceiteCorte .

ex:requiereConsulta a owl:ObjectProperty ;
    rdfs:domain ex:Refrigerante ;
    rdfs:range ex:DepartamentoHerramientas .