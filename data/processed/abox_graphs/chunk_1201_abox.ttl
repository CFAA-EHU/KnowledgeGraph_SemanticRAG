@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoCanal_Ejecucion a ns1:ModoOperacion ;
    rdfs:label "Estado 'En ejecución' del canal" ;
    ns1:textoExtracto "El CNC admitirá las funciones M aunque el canal esté en ejecución (ejecutando un programa, moviendo algún eje en jog, etc)" .

ns1:EstadoCanal_Error a ns1:ModoOperacion ;
    rdfs:label "Estado 'En error' del canal" ;
    ns1:textoExtracto "siempre que el status del canal sea distinto de 'En error'" .

ns1:EstadoCanal_NoReady a ns1:ModoOperacion ;
    rdfs:label "Estado 'No ready' del canal" ;
    ns1:textoExtracto "siempre que el status del canal sea distinto de [...] 'No ready'" .

ns1:Senal_AUXEND a ns1:Sensor ;
    rdfs:label "Señal AUXEND (finalización sincronización)" ;
    ns1:textoExtracto "Tras finalizar la sincronización de la función M en el PLC (señal AUXEND), el CNC comienza a enviar consigna a dicho cabezal" .

ns1:Senal_MSTROBE a ns1:Sensor ;
    rdfs:label "Señal MSTROBE (sincronización función M)" ;
    ns1:monitoreaParametro ns1:Registro_MFUN ;
    ns1:textoExtracto "el CNC activa la marca MSTROBE y escribe en el registro MFUN la función M correspondiente" .

ns1:CNC_InterfazEjecucion a ns1:InterfazUsuario ;
    rdfs:label "Interfaz CNC para ejecución de funciones M" ;
    ns1:controla ns1:FuncionM_ModificacionVelocidad ;
    ns1:textoExtracto "Cuando el PLC activa una de estas marcas, el CNC activa la marca MSTROBE y escribe en el registro MFUN la función M correspondiente [...] El CNC admitirá las funciones M aunque el canal esté en ejecución" .

ns1:FuncionM_ModificacionVelocidad a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función M para modificación de velocidad (parámetro AUTOGEAR)" ;
    ns1:habilitadoPor ns1:PLC_ControlCabezales ;
    ns1:identificador "AUTOGEAR" ;
    ns1:textoExtracto "El PLC podrá modificar la velocidad del cabezal [...] aunque éste sea automático (parámetro AUTOGEAR)" .

ns1:PLC_ControlCabezales a ns1:Sistema ;
    rdfs:label "PLC de control de cabezales" ;
    ns1:controla ns1:CNC_InterfazEjecucion ;
    ns1:monitoreaParametro ns1:Parametro_VelocidadCabezal ;
    ns1:textoExtracto "El PLC podrá modificar la velocidad del cabezal mediante la variable (V.)PLC.S.sn [...] Tras finalizar la sincronización de la función M en el PLC (señal AUXEND), el CNC comienza a enviar consigna a dicho cabezal" .

ns1:Parametro_VelocidadCabezal a ns1:Parametro ;
    rdfs:label "Velocidad del cabezal (V.)PLC.S.sn" ;
    ns1:identificador "(V.)PLC.S.sn" ;
    ns1:monitoreaParametro ns1:Sensor_VelocidadCabezal ;
    ns1:textoExtracto "El PLC podrá modificar la velocidad del cabezal mediante la variable (V.)PLC.S.sn" .

ns1:Registro_MFUN a ns1:Parametro ;
    rdfs:label "Registro MFUN (función M activa)" ;
    ns1:textoExtracto "el CNC [...] escribe en el registro MFUN la función M correspondiente" .

