@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaSeguridadCNC a ns1:Sistema ;
    rdfs:label "Sistema de seguridad CNC para límites de cabezales" ;
    ns1:compuestoPor ns1:SLIMITACSPDL1,
        ns1:SLIMITACSPDL2,
        ns1:SLIMITACSPDL3,
        ns1:SLIMITACSPDL4,
        ns1:SLIMITACSPDL5,
        ns1:SLIMITACSPDL6 ;
    ns1:controla ns1:Cabezal1,
        ns1:Cabezal2,
        ns1:Cabezal3,
        ns1:Cabezal4,
        ns1:Cabezal5,
        ns1:Cabezal6 ;
    ns1:textoExtracto "Si el PLC activa esta marca, el CNC activa los límites de seguridad para la" .

ns1:Cabezal1 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal 1" ;
    ns1:controla ns1:SLIMITACSPDL1 ;
    ns1:textoExtracto "marca para cada cabezal" .

ns1:Cabezal2 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal 2" ;
    ns1:controla ns1:SLIMITACSPDL2 ;
    ns1:textoExtracto "marca para cada cabezal" .

ns1:Cabezal3 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal 3" ;
    ns1:controla ns1:SLIMITACSPDL3 ;
    ns1:textoExtracto "marca para cada cabezal" .

ns1:Cabezal4 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal 4" ;
    ns1:controla ns1:SLIMITACSPDL4 ;
    ns1:textoExtracto "marca para cada cabezal" .

ns1:Cabezal5 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal 5" ;
    ns1:controla ns1:SLIMITACSPDL5 ;
    ns1:textoExtracto "marca para cada cabezal" .

ns1:Cabezal6 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal 6" ;
    ns1:controla ns1:SLIMITACSPDL6 ;
    ns1:textoExtracto "marca para cada cabezal" .

ns1:SLIMITACSPDL1 a ns1:Parametro ;
    rdfs:label "SLIMITACSPDL1" ;
    ns1:identificador "SLIMITACSPDL1" ;
    ns1:monitoreaParametro ns1:Cabezal1 ;
    ns1:textoExtracto "SLIMITACSPDL1 (también se puede programar como SLIMITACSPDL)" .

ns1:SLIMITACSPDL2 a ns1:Parametro ;
    rdfs:label "SLIMITACSPDL2" ;
    ns1:identificador "SLIMITACSPDL2" ;
    ns1:monitoreaParametro ns1:Cabezal2 ;
    ns1:textoExtracto "SLIMITACSPDL2" .

ns1:SLIMITACSPDL3 a ns1:Parametro ;
    rdfs:label "SLIMITACSPDL3" ;
    ns1:identificador "SLIMITACSPDL3" ;
    ns1:monitoreaParametro ns1:Cabezal3 ;
    ns1:textoExtracto "SLIMITACSPDL3" .

ns1:SLIMITACSPDL4 a ns1:Parametro ;
    rdfs:label "SLIMITACSPDL4" ;
    ns1:identificador "SLIMITACSPDL4" ;
    ns1:monitoreaParametro ns1:Cabezal4 ;
    ns1:textoExtracto "SLIMITACSPDL4" .

ns1:SLIMITACSPDL5 a ns1:Parametro ;
    rdfs:label "SLIMITACSPDL5" ;
    ns1:identificador "SLIMITACSPDL5" ;
    ns1:monitoreaParametro ns1:Cabezal5 ;
    ns1:textoExtracto "SLIMITACSPDL5" .

ns1:SLIMITACSPDL6 a ns1:Parametro ;
    rdfs:label "SLIMITACSPDL6" ;
    ns1:identificador "SLIMITACSPDL6" ;
    ns1:monitoreaParametro ns1:Cabezal6 ;
    ns1:textoExtracto "SLIMITACSPDL6" .

