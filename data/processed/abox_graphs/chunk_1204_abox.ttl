@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Cabezales_Maquina a ns1:ComponenteMecanico ;
    rdfs:label "Cabezales de la máquina"@es ;
    ns1:monitoreaParametro ns1:Parametro_SLIMIT ;
    ns1:textoExtracto "el CNC activa los límites de seguridad para la velocidad [...] en el cabezal indicado"@es .

ns1:Sistema_ControlVelocidad a ns1:Sistema ;
    rdfs:label "Sistema de control de velocidad por marcas PLC"@es ;
    ns1:controla ns1:Parametro_SLIMIT ;
    ns1:monitoreaParametro ns1:Parametro_SLIMIT ;
    ns1:textoExtracto "Si el PLC activa esta marca, el CNC activa los límites de seguridad para la velocidad (parámetro SLIMIT) en el cabezal indicado, durante la ejecución del bloque actual. Si el PLC desactiva esta marca, el CNC recupera la velocidad programada."@es ;
    ns1:tieneComponente ns1:Marca_SLIMITACSPDL,
        ns1:Marca_SLIMITACSPDL2,
        ns1:Marca_SLIMITACSPDL3,
        ns1:Marca_SLIMITACSPDL4,
        ns1:Marca_SLIMITACSPDL5,
        ns1:Marca_SLIMITACSPDL6 .

ns1:Marca_SLIMITACSPDL a ns1:Parametro ;
    rdfs:label "SLIMITACSPDL (marca de limitación de velocidad)"@es ;
    ns1:identificador "SLIMITACSPDL" ;
    ns1:textoExtracto "Si el PLC activa esta marca, el CNC activa los límites de seguridad para la velocidad (parámetro SLIMIT) en el cabezal indicado, durante la ejecución del bloque actual."@es .

ns1:Marca_SLIMITACSPDL2 a ns1:Parametro ;
    rdfs:label "SLIMITACSPDL2"@es ;
    ns1:identificador "SLIMITACSPDL2" ;
    ns1:textoExtracto "SLIMITACSPDL2"@es .

ns1:Marca_SLIMITACSPDL3 a ns1:Parametro ;
    rdfs:label "SLIMITACSPDL3"@es ;
    ns1:identificador "SLIMITACSPDL3" ;
    ns1:textoExtracto "SLIMITACSPDL3"@es .

ns1:Marca_SLIMITACSPDL4 a ns1:Parametro ;
    rdfs:label "SLIMITACSPDL4"@es ;
    ns1:identificador "SLIMITACSPDL4" ;
    ns1:textoExtracto "SLIMITACSPDL4"@es .

ns1:Marca_SLIMITACSPDL5 a ns1:Parametro ;
    rdfs:label "SLIMITACSPDL5"@es ;
    ns1:identificador "SLIMITACSPDL5" ;
    ns1:textoExtracto "SLIMITACSPDL5"@es .

ns1:Marca_SLIMITACSPDL6 a ns1:Parametro ;
    rdfs:label "SLIMITACSPDL6"@es ;
    ns1:identificador "SLIMITACSPDL6" ;
    ns1:textoExtracto "SLIMITACSPDL6"@es .

ns1:Parametro_SLIMIT a ns1:Parametro ;
    rdfs:label "SLIMIT (límite de velocidad)"@es ;
    ns1:identificador "SLIMIT" ;
    ns1:textoExtracto "el CNC activa los límites de seguridad para la velocidad (parámetro SLIMIT) en el cabezal indicado"@es .

