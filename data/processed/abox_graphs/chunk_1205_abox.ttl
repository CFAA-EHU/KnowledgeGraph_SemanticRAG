@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Senal_LASERON a ns1:InterfazUsuario ;
    rdfs:label "LASERON" ;
    ns1:identificador "LASERON" ;
    ns1:textoExtracto "El PLC activa está marca para indicar que el láser está encendido." .

ns1:Senal_LASERREADY a ns1:InterfazUsuario ;
    rdfs:label "LASERREADY" ;
    ns1:identificador "LASERREADY" ;
    ns1:textoExtracto "El PLC activa está marca para indicar que el láser está preparado." .

ns1:Senal_PWMON a ns1:InterfazUsuario ;
    rdfs:label "PWMON" ;
    ns1:identificador "PWMON" ;
    ns1:textoExtracto "Esta marca permite activar y desactivar el PWM desde el PLC." .

ns1:Senal_SHUTTERON a ns1:InterfazUsuario ;
    rdfs:label "SHUTTERON" ;
    ns1:identificador "SHUTTERON" ;
    ns1:textoExtracto "El PLC activa está marca para indicar que el obturador de la fuente láser está abierto." .

ns1:Tabla_ConfiguracionPWM a ns1:Tabla ;
    rdfs:label "Configuración del PWM" ;
    ns1:textoExtracto "La configuración del PWM se realiza con los siguiente registros: PWMFREQ, PWMDUTY." ;
    ns1:tieneComponente ns1:Parametro_PWMDUTY,
        ns1:Parametro_PWMFREQ .

ns1:Parametro_PWMDUTY a ns1:Parametro ;
    rdfs:label "Ciclo de trabajo del PWM" ;
    ns1:identificador "PWMDUTY" ;
    ns1:textoExtracto "Ciclo de trabajo del PWM (entre 1 y 1000; por defecto, 500)." ;
    ns1:valor 500 .

ns1:Parametro_PWMFREQ a ns1:Parametro ;
    rdfs:label "Frecuencia del PWM" ;
    ns1:identificador "PWMFREQ" ;
    ns1:textoExtracto "Frecuencia del PWM (entre 2 y 5000 Hz; por defecto, 0)." ;
    ns1:valor 0 .

