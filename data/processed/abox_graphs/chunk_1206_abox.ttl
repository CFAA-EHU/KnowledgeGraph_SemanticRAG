@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteElectrico_CNC_PWM a ns1:ComponenteElectrico ;
    rdfs:label "Señal PWM desde CNC"@es ;
    ns1:compuestoPor ns1:SistemaControlPWM ;
    ns1:textoExtracto "Estado del PWM desde el CNC"@es .

ns1:ComponenteElectrico_PLC_PWM a ns1:ComponenteElectrico ;
    rdfs:label "Señal PWM desde PLC"@es ;
    ns1:compuestoPor ns1:SistemaControlPWM ;
    ns1:textoExtracto "Estado del PWM desde el PLC"@es .

ns1:Pagina_455_456 a ns1:Pagina ;
    rdfs:label "Páginas 455-456 (Sección 6.11: Señales lógicas modificables; láser)"@es ;
    ns1:textoExtracto "Señales lógicas modificables; láser"@es .

ns1:Tabla_Se_alesLogicasPWM_6_11 a ns1:Tabla ;
    rdfs:label "Tabla de estados lógicos del PWM (láser)"@es ;
    ns1:documentadoEn ns1:Pagina_455_456 ;
    ns1:textoExtracto """
| Estado del PWM desde el CNC. | Estado del PWM desde el PLC. | Estado de PWM. |
| --- | --- | --- |
| Apagado. | Apagado. | PWM apagado. |
| Activo. | Apagado. | PWM activo desde el CNC. |
| Apagado. | Activo. | PWM activo desde el PLC. |
| Activo. | Activo. | PWM activo desde el PLC. |
"""@es .

ns1:SistemaControlPWM a ns1:Sistema ;
    rdfs:label "Sistema de control PWM para láser"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_Se_alesLogicasPWM_6_11 ;
    ns1:textoExtracto "Estado del PWM desde el CNC [...] Estado del PWM desde el PLC [...] Estado de PWM"@es .

