@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ControlPWM a ns1:Sistema ;
    rdfs:label "Sistema de control PWM (PLC-CNC)"@es ;
    ns1:controla ns1:Parametro_PWMOUT ;
    ns1:textoExtracto "El PLC desactiva/activa esta marca para deshabilitar/habilitar el control de duty activo en el CNC."@es ;
    ns1:tieneComponente ns1:Marca_DutyPWM,
        ns1:Marca_FreqPWM .

ns1:Marca_DutyPWM a ns1:ComponenteElectrico ;
    rdfs:label "Marca asociada al control duty del PWM (#PWRCTRL ON [DUTY])"@es ;
    ns1:identificador "#PWRCTRL ON [DUTY]" ;
    ns1:textoExtracto "Esta marca está asociada al control duty del PWM (#PWRCTRL ON [DUTY]). El PLC desactiva esta marca para deshabilitar el control de duty activo. El PLC activa esta marca para habilitar el control de duty activo en el CNC..."@es .

ns1:Marca_FreqPWM a ns1:ComponenteElectrico ;
    rdfs:label "Marca ENABLEPWRFREQ (control de frecuencia del PWM)"@es ;
    ns1:identificador "ENABLEPWRFREQ" ;
    ns1:textoExtracto "ENABLEPWRFREQ Marca activa por defecto. Esta marca está asociada al control de la potencia del PWM (#PWRCTRL ON [FREQ])."@es .

ns1:Parametro_PWMOUT a ns1:Parametro ;
    rdfs:label "Parámetro de salida PWM (#PWMOUT)"@es ;
    ns1:identificador "#PWMOUT" ;
    ns1:textoExtracto "...el control de duty queda fijado al máximo definido en la sentencia #PWMOUT."@es .

