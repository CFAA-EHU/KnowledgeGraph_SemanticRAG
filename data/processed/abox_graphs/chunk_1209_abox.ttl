@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Interfaz_CNC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz CNC" ;
    ns1:controla ns1:Parametro_ControlGap,
        ns1:Parametro_CutView,
        ns1:Parametro_Leapfrog,
        ns1:Parametro_PotenciaPWM ;
    ns1:textoExtracto "CNC mostrará o no un error según lo definido en el parámetro GAPCOLLISION" .

ns1:Sensor_Gap a ns1:Sensor ;
    rdfs:label "Sensor de control del gap" ;
    ns1:monitoreaParametro ns1:Parametro_SenalColision ;
    ns1:textoExtracto "El sensor para el control del gap puede disponer de una señal de colisión que se conecta al CNC" .

ns1:Sistema_ControlPLC a ns1:Sistema ;
    rdfs:label "Sistema de control PLC" ;
    ns1:controla ns1:Marca_CVIEWREFRESH,
        ns1:Marca_ENABLEGAP,
        ns1:Marca_ENABLELEAP,
        ns1:Marca_ENABLEPWRFREQ,
        ns1:Marca_GAPCOLLISION ;
    ns1:textoExtracto "El PLC desactiva/activa marcas para habilitar o deshabilitar controles en el CNC" .

ns1:Marca_CVIEWREFRESH a ns1:Parametro ;
    rdfs:label "CVIEWREFRESH" ;
    ns1:identificador "CVIEWREFRESH" ;
    ns1:monitoreaParametro ns1:Parametro_CutView ;
    ns1:textoExtracto "CVIEWREFRESH El PLC activa esta marca para refrescar el Cut_View. Por ejemplo, el corte de chapas más largas que el recorrido de la mesa, en un único programa, se realiza en varias etapas, moviendo la chapa entre una etapa y otra. Al final de cada etapa, hay que refrescar el Cut_View para que muestre la nueva sección a cortar." .

ns1:Marca_ENABLEGAP a ns1:Parametro ;
    rdfs:label "ENABLEGAP" ;
    ns1:identificador "ENABLEGAP" ;
    ns1:monitoreaParametro ns1:Parametro_ControlGap ;
    ns1:textoExtracto "ENABLEGAP Marca activa por defecto. El PLC desactiva esta marca para deshabilitar el control del gap activo. El PLC activa esta marca para habilitar el control del gap activo en el CNC; si no hay un control del gap activo, esta marca no hace nada." .

ns1:Marca_ENABLELEAP a ns1:Parametro ;
    rdfs:label "ENABLELEAP" ;
    ns1:identificador "ENABLELEAP" ;
    ns1:monitoreaParametro ns1:Parametro_Leapfrog ;
    ns1:textoExtracto "ENABLELEAP El PLC desactiva esta marca para deshabilitar el leapfrog activo. El PLC activa esta marca para habilitar el leapfrog activo en el CNC; si no hay un control del gap activo, esta marca no hace nada." .

ns1:Marca_ENABLEPWRFREQ a ns1:Parametro ;
    rdfs:label "ENABLEPWRFREQ" ;
    ns1:identificador "ENABLEPWRFREQ" ;
    ns1:monitoreaParametro ns1:Parametro_PotenciaPWM ;
    ns1:textoExtracto "ENABLEPWRFREQ Marca activa por defecto. Esta marca está asociada al control de la potencia del PWM (#PWRCTRL ON [FREQ]). El PLC desactiva esta marca para deshabilitar el control de potencia activo. El PLC activa esta marca para habilitar el control de potencia activo en el CNC; si no hay un control de potencia activo, esta marca no hace nada." .

ns1:Marca_GAPCOLLISION a ns1:Parametro ;
    rdfs:label "GAPCOLLISION" ;
    ns1:identificador "GAPCOLLISION" ;
    ns1:monitoreaParametro ns1:Parametro_SenalColision ;
    ns1:textoExtracto "GAPCOLLISION El sensor para el control del gap puede disponer de una señal de colisión que se conecta al CNC, y que el PLC la debe gestionar a través de esta marca. El PLC activa esta marca para indicar que se ha recibido la señal de colisión del sensor. Esta marca no se memoriza. Con esta marca activa, el CNC mostrará o no un error según lo definido en el parámetro GAPCOLLISION." .

ns1:Parametro_ControlGap a ns1:Parametro ;
    rdfs:label "Control del gap" ;
    ns1:identificador "GAP" ;
    ns1:textoExtracto "control del gap activo" .

ns1:Parametro_CutView a ns1:Parametro ;
    rdfs:label "Cut_View" ;
    ns1:identificador "CUT_VIEW" ;
    ns1:textoExtracto "refrescar el Cut_View para que muestre la nueva sección a cortar" .

ns1:Parametro_Leapfrog a ns1:Parametro ;
    rdfs:label "Leapfrog" ;
    ns1:identificador "LEAP" ;
    ns1:textoExtracto "control del leapfrog activo" .

ns1:Parametro_PotenciaPWM a ns1:Parametro ;
    rdfs:label "Potencia del PWM" ;
    ns1:identificador "#PWRCTRL" ;
    ns1:textoExtracto "control de la potencia del PWM (#PWRCTRL ON [FREQ])" ;
    ns1:valor "Máximo definido en #PWMOUT" .

ns1:Parametro_SenalColision a ns1:Parametro ;
    rdfs:label "Señal de colisión del sensor de gap" ;
    ns1:textoExtracto "señal de colisión que se conecta al CNC" .

