@prefix ex: <https://vocab.cfaa.eus/broaching/>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.

ex:Presion a owl:Class ;
    rdfs:label "Presion" ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/>.

ex:Caudal a owl:Class ;
    rdfs:label "Caudal" ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/>.

ex:Filtro a owl:Class ;
    rdfs:label "Filtro" ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/>.

ex:SecadorDeAire a owl:Class ;
    rdfs:label "SecadorDeAire" ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/>.

ex:tienePresion a owl:ObjectProperty ;
    rdfs:domain ex:SistemaAireComprimido ;
    rdfs:range ex:Presion ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/>.

ex:tieneCaudal a owl:ObjectProperty ;
    rdfs:domain ex:SistemaAireComprimido ;
    rdfs:range ex:Caudal ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/>.

ex:tieneFiltro a owl:ObjectProperty ;
    rdfs:domain ex:SistemaAireComprimido ;
    rdfs:range ex:Filtro ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/>.

ex:tieneSecadorDeAire a owl:ObjectProperty ;
    rdfs:domain ex:SistemaAireComprimido ;
    rdfs:range ex:SecadorDeAire ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/>.

ex:SistemaAireComprimido a owl:Class ;
    rdfs:label "SistemaAireComprimido" ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/>.