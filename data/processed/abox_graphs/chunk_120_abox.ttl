@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ParametroCaudal225Lmin a ns1:Parametro ;
    rdfs:label "caudal de 225 L/min" ;
    ns1:textoExtracto "A una presión de 6 bar, un caudal de 225 L/min filtrado y secado." ;
    ns1:valor "225 L/min" .

ns1:ParametroPresion6bar a ns1:Parametro ;
    rdfs:label "presión de 6 bar" ;
    ns1:textoExtracto "A una presión de 6 bar, un caudal de 225 L/min filtrado y secado." ;
    ns1:valor "6 bar" .

