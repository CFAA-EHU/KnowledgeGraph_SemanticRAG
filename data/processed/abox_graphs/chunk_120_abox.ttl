@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:PresionAire a owl:Class ;
    rdfs:label "Presión de aire"@es ;
    rdfs:comment "Presión del sistema de aire comprimido"@es .

ex:Caudal a owl:Class ;
    rdfs:label "Caudal"@es ;
    rdfs:comment "Caudal del sistema de aire comprimido"@es .

ex:FiltroAire a owl:Class ;
    rdfs:label "Filtro de aire"@es ;
    rdfs:comment "Filtro del sistema de aire comprimido"@es .

ex:SecadorAire a owl:Class ;
    rdfs:label "Secador de aire"@es ;
    rdfs:comment "Secador del sistema de aire comprimido"@es .

ex:tienePresion a owl:ObjectProperty ;
    rdfs:domain ex:SistemaAireComprimido ;
    rdfs:range ex:PresionAire .

ex:tieneCaudal a owl:ObjectProperty ;
    rdfs:domain ex:SistemaAireComprimido ;
    rdfs:range ex:Caudal .

ex:tieneFiltro a owl:ObjectProperty ;
    rdfs:domain ex:SistemaAireComprimido ;
    rdfs:range ex:FiltroAire .

ex:tieneSecador a owl:ObjectProperty ;
    rdfs:domain ex:SistemaAireComprimido ;
    rdfs:range ex:SecadorAire .

ex:valorPresion a owl:DatatypeProperty ;
    rdfs:domain ex:PresionAire ;
    rdfs:range xsd:decimal .

ex:valorCaudal a owl:DatatypeProperty ;
    rdfs:domain ex:Caudal ;
    rdfs:range xsd:decimal .