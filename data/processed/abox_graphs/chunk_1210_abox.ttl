@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_Cut_View a ns1:InterfazUsuario ;
    rdfs:label "Interfaz Cut_View" ;
    ns1:identificador "Cut_View" ;
    ns1:textoExtracto "hay que refrescar el Cut_View para que muestre la nueva sección a cortar" .

ns1:Marca_OUTOFGAP a ns1:ComponenteElectrico ;
    rdfs:label "Marca OUTOFGAP" ;
    ns1:identificador "OUTOFGAP" ;
    ns1:textoExtracto "OUTOFGAP El PLC activa esta marca (cambio de 1 a 0) para indicar que la boquilla ha salido alguna vez del gap (parámetros GAPMIN y GAPMAX) durante la ejecución del programa." .

ns1:Marca_OUTOFTOL a ns1:ComponenteElectrico ;
    rdfs:label "Marca OUTOFTOL" ;
    ns1:identificador "OUTOFTOL" ;
    ns1:textoExtracto "OUTOFTOL El PLC activa esta marca para" .

ns1:Parametro_GAPMAX a ns1:Parametro ;
    rdfs:label "Parámetro GAPMAX" ;
    ns1:identificador "GAPMAX" ;
    ns1:textoExtracto "parámetros GAPMIN y GAPMAX" .

ns1:Parametro_GAPMIN a ns1:Parametro ;
    rdfs:label "Parámetro GAPMIN" ;
    ns1:identificador "GAPMIN" ;
    ns1:textoExtracto "parámetros GAPMIN y GAPMAX" .

