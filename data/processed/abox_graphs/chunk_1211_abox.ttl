@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_GAP a ns1:Alarma ;
    rdfs:label "Marca de salida del gap (GAPMIN/GAPMAX)"@es ;
    ns1:monitoreaParametro ns1:Marca_GAPMIN_GAPMAX ;
    ns1:textoExtracto "marca [...] ha salido alguna vez del gap (parámetros GAPMIN y GAPMAX) durante la ejecución del programa. Esta marca permanece activa hasta iniciar la ejecución de un programa."@es .

ns1:Alarma_OUTOFTOL a ns1:Alarma ;
    rdfs:label "Marca OUTOFTOL (fuera de tolerancia del gap)"@es ;
    ns1:monitoreaParametro ns1:Marca_GAPTOL ;
    ns1:textoExtracto "OUTOFTOL [...] indica que la boquilla ha salido alguna vez de la tolerancia del gap (parámetro GAPTOL) durante la ejecución del programa. Esta marca permanece activa hasta iniciar la ejecución de un programa."@es .

ns1:ProgramaEjecucion a ns1:ModoOperacion ;
    rdfs:label "Ejecución del programa"@es ;
    ns1:textoExtracto "durante la ejecución del programa"@es .

ns1:Marca_GAPMIN_GAPMAX a ns1:Parametro ;
    rdfs:label "Parámetros GAPMIN y GAPMAX"@es ;
    ns1:identificador "GAPMIN, GAPMAX" ;
    ns1:textoExtracto "parámetros GAPMIN y GAPMAX"@es .

ns1:Marca_GAPTOL a ns1:Parametro ;
    rdfs:label "Parámetro GAPTOL"@es ;
    ns1:identificador "GAPTOL" ;
    ns1:textoExtracto "parámetro GAPTOL"@es .

