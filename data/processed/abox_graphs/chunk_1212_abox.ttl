@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IABORT a ns1:Parametro ;
    rdfs:label "IABORT(axis)" ;
    ns1:textoExtracto "IABORT(axis) Para los movimientos de eje independiente, si el PLC pone esta marca a (=1), el bloque de posicionamiento que se está ejecutando (si lo hay) se detiene, sin eliminar el resto de bloques de posicionamiento pendientes de ejecución." .

ns1:IRESET a ns1:Parametro ;
    rdfs:label "IRESET(axis)" ;
    ns1:textoExtracto "IRESET(axis) Para los movimientos de eje independiente, si el PLC pone esta marca a (=1), se detiene la sentencia en ejecución y se eliminan las sentencias pendientes de ejecución." .

ns1:IXFERINH a ns1:Parametro ;
    rdfs:label "IXFERINH(axis)" ;
    ns1:textoExtracto "Sustituir el texto (axis) por el nombre o número lógico de eje. _ IXFERINH(axis)" .

ns1:Parametro_XFITOIND_No a ns1:Parametro ;
    rdfs:label "No" ;
    ns1:textoExtracto "No | El CNC sólo evalúa el transfer inhibit particular del eje (marca _IXFERINH(axis))." .

ns1:Parametro_XFITOIND_Si a ns1:Parametro ;
    rdfs:label "Sí" ;
    ns1:textoExtracto "Sí | El CNC primero evalúa el transfer inhibit del canal (marca _XFERINH) y a continuación el particular del eje (marca _IXFERINH(axis))." .

ns1:XFERINH a ns1:Parametro ;
    rdfs:label "_XFERINH" ;
    ns1:textoExtracto "el PLC también dispone de una marca general por canal (marca _XFERINH)" .

ns1:XFITOIND a ns1:Parametro ;
    rdfs:label "XFITOIND" ;
    ns1:textoExtracto "| XFITOIND | Significado |" .

