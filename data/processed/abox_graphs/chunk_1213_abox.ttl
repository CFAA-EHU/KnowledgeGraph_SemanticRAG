@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RegistroR300 a ns1:Parametro ;
    rdfs:label "Registro R300" ;
    ns1:documentadoEn ns1:SistemaGestorHerramientas ;
    ns1:identificador "R300" ;
    ns1:textoExtracto "El registro R300 muestra el estado de las funciones G."@es .

ns1:MarcaCUTTINGONC1 a ns1:ComponenteElectrico ;
    rdfs:label "CUTTINGONC1" ;
    ns1:identificador "CUTTINGONC1" ;
    ns1:textoExtracto "CUTTINGONC1 (equivalente a CUTTINGON) [...] Cuando se le asocia un tiempo máximo de vida (monitorización) a la herramienta el CNC consulta esta marca para saber si la herramienta está ejecutando (=1) o no (=0)."@es .

ns1:MarcaCUTTINGONC2 a ns1:ComponenteElectrico ;
    rdfs:label "CUTTINGONC2" ;
    ns1:identificador "CUTTINGONC2" ;
    ns1:textoExtracto "CUTTINGONC2"@es .

ns1:MarcaCUTTINGONC3 a ns1:ComponenteElectrico ;
    rdfs:label "CUTTINGONC3" ;
    ns1:identificador "CUTTINGONC3" ;
    ns1:textoExtracto "CUTTINGONC3"@es .

ns1:MarcaCUTTINGONC4 a ns1:ComponenteElectrico ;
    rdfs:label "CUTTINGONC4" ;
    ns1:identificador "CUTTINGONC4" ;
    ns1:textoExtracto "CUTTINGONC4"@es .

ns1:MarcaRESTMEMZ1 a ns1:ComponenteElectrico ;
    rdfs:label "RESTMEMZ1" ;
    ns1:identificador "RESTMEMZ1" ;
    ns1:textoExtracto "RESTMEMZ1 (también se puede programar como RESTMEM) [...] El PLC pone esta marca a (=1) para cancelar la emergencia del gestor de herramientas."@es .

ns1:MarcaRESTMEMZ2 a ns1:ComponenteElectrico ;
    rdfs:label "RESTMEMZ2" ;
    ns1:identificador "RESTMEMZ2" ;
    ns1:textoExtracto "RESTMEMZ2"@es .

ns1:MarcaRESTMEMZ3 a ns1:ComponenteElectrico ;
    rdfs:label "RESTMEMZ3" ;
    ns1:identificador "RESTMEMZ3" ;
    ns1:textoExtracto "RESTMEMZ3"@es .

ns1:MarcaRESTMEMZ4 a ns1:ComponenteElectrico ;
    rdfs:label "RESTMEMZ4" ;
    ns1:identificador "RESTMEMZ4" ;
    ns1:textoExtracto "RESTMEMZ4"@es .

ns1:MarcaSETTMEMZ1 a ns1:ComponenteElectrico ;
    rdfs:label "SETTMEMZ1" ;
    ns1:identificador "SETTMEMZ1" ;
    ns1:textoExtracto "SETTMEMZ1 (también se puede programar como SETTMEM) [...] El PLC pone esta marca a (=1) para activar la emergencia del gestor de herramientas."@es .

ns1:MarcaSETTMEMZ2 a ns1:ComponenteElectrico ;
    rdfs:label "SETTMEMZ2" ;
    ns1:identificador "SETTMEMZ2" ;
    ns1:textoExtracto "SETTMEMZ2"@es .

ns1:MarcaSETTMEMZ3 a ns1:ComponenteElectrico ;
    rdfs:label "SETTMEMZ3" ;
    ns1:identificador "SETTMEMZ3" ;
    ns1:textoExtracto "SETTMEMZ3"@es .

ns1:MarcaSETTMEMZ4 a ns1:ComponenteElectrico ;
    rdfs:label "SETTMEMZ4" ;
    ns1:identificador "SETTMEMZ4" ;
    ns1:textoExtracto "SETTMEMZ4"@es .

ns1:MarcaTREJECTC1 a ns1:ComponenteElectrico ;
    rdfs:label "TREJECTC1" ;
    ns1:identificador "TREJECTC1" ;
    ns1:textoExtracto "TREJECTC1 (también se puede programar como TREJECT) [...] Si el PLC pone esta marca a (=1) el CNC entiende que la herramienta debe ser rechazada."@es .

ns1:MarcaTREJECTC2 a ns1:ComponenteElectrico ;
    rdfs:label "TREJECTC2" ;
    ns1:identificador "TREJECTC2" ;
    ns1:textoExtracto "TREJECTC2"@es .

ns1:MarcaTREJECTC3 a ns1:ComponenteElectrico ;
    rdfs:label "TREJECTC3" ;
    ns1:identificador "TREJECTC3" ;
    ns1:textoExtracto "TREJECTC3"@es .

ns1:MarcaTREJECTC4 a ns1:ComponenteElectrico ;
    rdfs:label "TREJECTC4" ;
    ns1:identificador "TREJECTC4" ;
    ns1:textoExtracto "TREJECTC4"@es .

ns1:SistemaGestorHerramientas a ns1:Sistema ;
    rdfs:label "Sistema gestor de herramientas"@es ;
    ns1:textoExtracto "SETTMEM [...] RESTMEM [...] CUTTINGON [...] TREJECT [...] MZTOCH1 [...] Hay una marca para cada almacén. [...] Hay una marca para cada canal."@es ;
    ns1:tieneComponente ns1:MarcaCUTTINGONC1,
        ns1:MarcaCUTTINGONC2,
        ns1:MarcaCUTTINGONC3,
        ns1:MarcaCUTTINGONC4,
        ns1:MarcaRESTMEMZ1,
        ns1:MarcaRESTMEMZ2,
        ns1:MarcaRESTMEMZ3,
        ns1:MarcaRESTMEMZ4,
        ns1:MarcaSETTMEMZ1,
        ns1:MarcaSETTMEMZ2,
        ns1:MarcaSETTMEMZ3,
        ns1:MarcaSETTMEMZ4,
        ns1:MarcaTREJECTC1,
        ns1:MarcaTREJECTC2,
        ns1:MarcaTREJECTC3,
        ns1:MarcaTREJECTC4 .

