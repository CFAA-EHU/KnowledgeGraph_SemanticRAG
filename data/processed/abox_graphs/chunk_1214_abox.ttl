@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaGestorHerramientas a ns1:Sistema ;
    rdfs:label "Sistema de gestión de herramientas" ;
    ns1:monitoreaParametro ns1:CH1TOSPDL,
        ns1:CH1TOSPDLMZ1,
        ns1:CH1TOSPDLMZ2,
        ns1:CH1TOSPDLMZ3,
        ns1:CH1TOSPDLMZ4,
        ns1:MZTOCH1,
        ns1:MZTOCH1MZ1,
        ns1:MZTOCH1MZ2,
        ns1:MZTOCH1MZ3,
        ns1:MZTOCH1MZ4 ;
    ns1:textoExtracto "Señales modificables del gestor de herramientas. MZTOCH1 Hay una marca para cada almacén. [...] Utilizar con almacén asíncrono o síncrono con brazo." .

ns1:CH1TOSPDL a ns1:Parametro ;
    rdfs:label "CH1TOSPDL" ;
    ns1:identificador "CH1TOSPDL" ;
    ns1:textoExtracto "CH1TOSPDL Hay una marca para cada almacén. Los mnemónicos para cada almacén son los siguientes. CH1TOSPDLMZ1 (equivalente a CH1TOSPDL)" .

ns1:CH1TOSPDLMZ1 a ns1:Parametro ;
    rdfs:label "CH1TOSPDLMZ1" ;
    ns1:identificador "CH1TOSPDLMZ1" ;
    ns1:textoExtracto "CH1TOSPDLMZ1 (equivalente a CH1TOSPDL)" .

ns1:CH1TOSPDLMZ2 a ns1:Parametro ;
    rdfs:label "CH1TOSPDLMZ2" ;
    ns1:identificador "CH1TOSPDLMZ2" ;
    ns1:textoExtracto "CH1TOSPDLMZ2" .

ns1:CH1TOSPDLMZ3 a ns1:Parametro ;
    rdfs:label "CH1TOSPDLMZ3" ;
    ns1:identificador "CH1TOSPDLMZ3" ;
    ns1:textoExtracto "CH1TOSPDLMZ3" .

ns1:CH1TOSPDLMZ4 a ns1:Parametro ;
    rdfs:label "CH1TOSPDLMZ4" ;
    ns1:identificador "CH1TOSPDLMZ4" ;
    ns1:textoExtracto "CH1TOSPDLMZ4" .

ns1:MZTOCH1 a ns1:Parametro ;
    rdfs:label "MZTOCH1" ;
    ns1:identificador "MZTOCH1" ;
    ns1:textoExtracto "MZTOCH1 Hay una marca para cada almacén. Los mnemónicos para cada almacén son los siguientes. MZTOCH1MZ1 (también se puede programar como MZTOCH1) MZTOCH1MZ2 MZTOCH1MZ3 MZTOCH1MZ4" .

ns1:MZTOCH1MZ1 a ns1:Parametro ;
    rdfs:label "MZTOCH1MZ1" ;
    ns1:identificador "MZTOCH1MZ1" ;
    ns1:textoExtracto "MZTOCH1MZ1 (también se puede programar como MZTOCH1)" .

ns1:MZTOCH1MZ2 a ns1:Parametro ;
    rdfs:label "MZTOCH1MZ2" ;
    ns1:identificador "MZTOCH1MZ2" ;
    ns1:textoExtracto "MZTOCH1MZ2" .

ns1:MZTOCH1MZ3 a ns1:Parametro ;
    rdfs:label "MZTOCH1MZ3" ;
    ns1:identificador "MZTOCH1MZ3" ;
    ns1:textoExtracto "MZTOCH1MZ3" .

ns1:MZTOCH1MZ4 a ns1:Parametro ;
    rdfs:label "MZTOCH1MZ4" ;
    ns1:identificador "MZTOCH1MZ4" ;
    ns1:textoExtracto "MZTOCH1MZ4" .

