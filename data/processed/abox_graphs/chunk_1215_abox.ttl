@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:SistemaGestorHerramientas a ns1:Sistema ;
    rdfs:label "Sistema de gestión de herramientas" ;
    ns1:monitoreaParametro ns1:CH1TOMZ1,
        ns1:CH1TOMZ2,
        ns1:CH1TOMZ3,
        ns1:CH1TOMZ4,
        ns1:CH1TOSPDLMZ1,
        ns1:CH1TOSPDLMZ2,
        ns1:CH1TOSPDLMZ3,
        ns1:CH1TOSPDLMZ4,
        ns1:SPDLTOCH1MZ1,
        ns1:SPDLTOCH1MZ2,
        ns1:SPDLTOCH1MZ3,
        ns1:SPDLTOCH1MZ4,
        ns1:SPDLTOCH2MZ1,
        ns1:SPDLTOCH2MZ2,
        ns1:SPDLTOCH2MZ3,
        ns1:SPDLTOCH2MZ4 ;
    ns1:textoExtracto "Señales modificables del gestor de herramientas" .

ns1:CH1TOMZ1 a ns1:Parametro ;
    rdfs:label "CH1TOMZ1" ;
    ns1:identificador "CH1TOMZ1" ;
    ns1:textoExtracto "CH1TOMZ1 (también se puede programar como CH1TOMZ)" ;
    ns1:valor 1 .

ns1:CH1TOMZ2 a ns1:Parametro ;
    rdfs:label "CH1TOMZ2" ;
    ns1:identificador "CH1TOMZ2" ;
    ns1:textoExtracto "CH1TOMZ2" .

ns1:CH1TOMZ3 a ns1:Parametro ;
    rdfs:label "CH1TOMZ3" ;
    ns1:identificador "CH1TOMZ3" ;
    ns1:textoExtracto "CH1TOMZ3" .

ns1:CH1TOMZ4 a ns1:Parametro ;
    rdfs:label "CH1TOMZ4" ;
    ns1:identificador "CH1TOMZ4" ;
    ns1:textoExtracto "CH1TOMZ4" .

ns1:CH1TOSPDLMZ1 a ns1:Parametro ;
    rdfs:label "CH1TOSPDLMZ1" ;
    ns1:identificador "CH1TOSPDLMZ1" ;
    ns1:textoExtracto "mnemónicos para cada almacén son los siguientes. CH1TOSPDLMZ1 (equivalente a CH1TOSPDL)" ;
    ns1:valor 1 .

ns1:CH1TOSPDLMZ2 a ns1:Parametro ;
    rdfs:label "CH1TOSPDLMZ2" ;
    ns1:identificador "CH1TOSPDLMZ2" ;
    ns1:textoExtracto "CH1TOSPDLMZ2" .

ns1:CH1TOSPDLMZ3 a ns1:Parametro ;
    rdfs:label "CH1TOSPDLMZ3" ;
    ns1:identificador "CH1TOSPDLMZ3" ;
    ns1:textoExtracto "CH1TOSPDLMZ3" .

ns1:CH1TOSPDLMZ4 a ns1:Parametro ;
    rdfs:label "CH1TOSPDLMZ4" ;
    ns1:identificador "CH1TOSPDLMZ4" ;
    ns1:textoExtracto "CH1TOSPDLMZ4" .

ns1:SPDLTOCH1MZ1 a ns1:Parametro ;
    rdfs:label "SPDLTOCH1MZ1" ;
    ns1:identificador "SPDLTOCH1MZ1" ;
    ns1:textoExtracto "SPDLTOCH1MZ1 (equivalente a SPDLTOCH1)" ;
    ns1:valor 1 .

ns1:SPDLTOCH1MZ2 a ns1:Parametro ;
    rdfs:label "SPDLTOCH1MZ2" ;
    ns1:identificador "SPDLTOCH1MZ2" ;
    ns1:textoExtracto "SPDLTOCH1MZ2" .

ns1:SPDLTOCH1MZ3 a ns1:Parametro ;
    rdfs:label "SPDLTOCH1MZ3" ;
    ns1:identificador "SPDLTOCH1MZ3" ;
    ns1:textoExtracto "SPDLTOCH1MZ3" .

ns1:SPDLTOCH1MZ4 a ns1:Parametro ;
    rdfs:label "SPDLTOCH1MZ4" ;
    ns1:identificador "SPDLTOCH1MZ4" ;
    ns1:textoExtracto "SPDLTOCH1MZ4" .

ns1:SPDLTOCH2MZ1 a ns1:Parametro ;
    rdfs:label "SPDLTOCH2MZ1" ;
    ns1:identificador "SPDLTOCH2MZ1" ;
    ns1:textoExtracto "SPDLTOCH2MZ1 (equivalente a SPDLTOCH2)" ;
    ns1:valor 1 .

ns1:SPDLTOCH2MZ2 a ns1:Parametro ;
    rdfs:label "SPDLTOCH2MZ2" ;
    ns1:identificador "SPDLTOCH2MZ2" ;
    ns1:textoExtracto "SPDLTOCH2MZ2" .

ns1:SPDLTOCH2MZ3 a ns1:Parametro ;
    rdfs:label "SPDLTOCH2MZ3" ;
    ns1:identificador "SPDLTOCH2MZ3" ;
    ns1:textoExtracto "SPDLTOCH2MZ3" .

ns1:SPDLTOCH2MZ4 a ns1:Parametro ;
    rdfs:label "SPDLTOCH2MZ4" ;
    ns1:identificador "SPDLTOCH2MZ4" ;
    ns1:textoExtracto "SPDLTOCH2MZ4" .

