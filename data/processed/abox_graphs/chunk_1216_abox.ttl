@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_GestorHerramientas a ns1:Sistema ;
    rdfs:label "Sistema de gestión de herramientas" ;
    ns1:textoExtracto "Señales modificables del gestor de herramientas" ;
    ns1:tieneComponente ns1:SenalCH2TOMZ1Almacen1,
        ns1:SenalCH2TOMZ2Almacen2,
        ns1:SenalCH2TOMZ3Almacen3,
        ns1:SenalCH2TOMZ4Almacen4,
        ns1:SenalGRTOSPDLC1Canal1,
        ns1:SenalSPDLTOGRC1Canal1,
        ns1:SenalSPDLTOGRC2Canal2,
        ns1:SenalSPDLTOGRC3Canal3,
        ns1:SenalSPDLTOGRC4Canal4 .

ns1:SenalCH2TOMZ1Almacen1 a ns1:ComponenteElectrico ;
    rdfs:label "Señal CH2TOMZ1 (Almacén 1)" ;
    ns1:identificador "CH2TOMZ1" ;
    ns1:textoExtracto "CH2TOMZ1 (también se puede programar como CH2TOMZ)" .

ns1:SenalCH2TOMZ2Almacen2 a ns1:ComponenteElectrico ;
    rdfs:label "Señal CH2TOMZ2 (Almacén 2)" ;
    ns1:identificador "CH2TOMZ2" ;
    ns1:textoExtracto "CH2TOMZ2" .

ns1:SenalCH2TOMZ3Almacen3 a ns1:ComponenteElectrico ;
    rdfs:label "Señal CH2TOMZ3 (Almacén 3)" ;
    ns1:identificador "CH2TOMZ3" ;
    ns1:textoExtracto "CH2TOMZ3" .

ns1:SenalCH2TOMZ4Almacen4 a ns1:ComponenteElectrico ;
    rdfs:label "Señal CH2TOMZ4 (Almacén 4)" ;
    ns1:identificador "CH2TOMZ4" ;
    ns1:textoExtracto "CH2TOMZ4" .

ns1:SenalGRTOSPDLC1Canal1 a ns1:ComponenteElectrico ;
    rdfs:label "Señal GRTOSPDLC1 (Canal 1)" ;
    ns1:identificador "GRTOSPDLC1" ;
    ns1:textoExtracto "GRTOSPDLC1" .

ns1:SenalSPDLTOGRC1Canal1 a ns1:ComponenteElectrico ;
    rdfs:label "Señal SPDLTOGRC1 (Canal 1)" ;
    ns1:identificador "SPDLTOGRC1" ;
    ns1:textoExtracto "SPDLTOGRC1 (también se puede programar como SPDLTOGR)" .

ns1:SenalSPDLTOGRC2Canal2 a ns1:ComponenteElectrico ;
    rdfs:label "Señal SPDLTOGRC2 (Canal 2)" ;
    ns1:identificador "SPDLTOGRC2" ;
    ns1:textoExtracto "SPDLTOGRC2" .

ns1:SenalSPDLTOGRC3Canal3 a ns1:ComponenteElectrico ;
    rdfs:label "Señal SPDLTOGRC3 (Canal 3)" ;
    ns1:identificador "SPDLTOGRC3" ;
    ns1:textoExtracto "SPDLTOGRC3" .

ns1:SenalSPDLTOGRC4Canal4 a ns1:ComponenteElectrico ;
    rdfs:label "Señal SPDLTOGRC4 (Canal 4)" ;
    ns1:identificador "SPDLTOGRC4" ;
    ns1:textoExtracto "SPDLTOGRC4" .

