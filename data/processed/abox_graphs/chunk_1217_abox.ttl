@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaGestorHerramientas a ns1:Sistema ;
    rdfs:label "Sistema gestor de herramientas"@es ;
    ns1:textoExtracto "Señales modificables del gestor de herramientas."@es ;
    ns1:tieneComponente ns1:GRTOSPDL,
        ns1:GRTOSPDLC1,
        ns1:GRTOSPDLC2,
        ns1:GRTOSPDLC3,
        ns1:GRTOSPDLC4,
        ns1:MZROT,
        ns1:MZROTMZ1,
        ns1:MZROTMZ2,
        ns1:MZROTMZ3,
        ns1:MZROTMZ4,
        ns1:MZTOSPDL,
        ns1:MZTOSPDLMZ1,
        ns1:MZTOSPDLMZ2,
        ns1:MZTOSPDLMZ3,
        ns1:MZTOSPDLMZ4,
        ns1:SPDLTOMZ,
        ns1:SPDLTOMZ1,
        ns1:SPDLTOMZ2,
        ns1:SPDLTOMZ3,
        ns1:SPDLTOMZ4,
        ns1:TCHANGEOK,
        ns1:TCHANGEOKMZ1,
        ns1:TCHANGEOKMZ2,
        ns1:TCHANGEOKMZ3,
        ns1:TCHANGEOKMZ4 .

ns1:GRTOSPDL a ns1:Parametro ;
    rdfs:label "GRTOSPDL (marca de herramienta a tierra)"@es ;
    ns1:identificador "GRTOSPDL" ;
    ns1:textoExtracto "El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal a tierra. GRTOSPDL Hay una marca para cada canal."@es .

ns1:GRTOSPDLC1 a ns1:Parametro ;
    rdfs:label "GRTOSPDLC1 (canal 1)"@es ;
    ns1:identificador "GRTOSPDLC1" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. GRTOSPDLC1 (también se puede programar como GRTOSPDL)"@es .

ns1:GRTOSPDLC2 a ns1:Parametro ;
    rdfs:label "GRTOSPDLC2 (canal 2)"@es ;
    ns1:identificador "GRTOSPDLC2" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. GRTOSPDLC2"@es .

ns1:GRTOSPDLC3 a ns1:Parametro ;
    rdfs:label "GRTOSPDLC3 (canal 3)"@es ;
    ns1:identificador "GRTOSPDLC3" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. GRTOSPDLC3"@es .

ns1:GRTOSPDLC4 a ns1:Parametro ;
    rdfs:label "GRTOSPDLC4 (canal 4)"@es ;
    ns1:identificador "GRTOSPDLC4" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. GRTOSPDLC4"@es .

ns1:MZROT a ns1:Parametro ;
    rdfs:label "MZROT (marca de giro de torreta)"@es ;
    ns1:identificador "MZROT" ;
    ns1:textoExtracto "El PLC debe poner esta marca a (=1) cuando la torreta ha girado. MZROT Hay una marca para cada almacén."@es .

ns1:MZROTMZ1 a ns1:Parametro ;
    rdfs:label "MZROTMZ1 (torreta almacén 1)"@es ;
    ns1:identificador "MZROTMZ1" ;
    ns1:textoExtracto "Los mnemónicos para cada almacén son los siguientes. MZROTMZ1 (también se puede programar como MZROT)"@es .

ns1:MZROTMZ2 a ns1:Parametro ;
    rdfs:label "MZROTMZ2 (torreta almacén 2)"@es ;
    ns1:identificador "MZROTMZ2" ;
    ns1:textoExtracto "Los mnemónicos para cada almacén son los siguientes. MZROTMZ2"@es .

ns1:MZROTMZ3 a ns1:Parametro ;
    rdfs:label "MZROTMZ3 (torreta almacén 3)"@es ;
    ns1:identificador "MZROTMZ3" ;
    ns1:textoExtracto "Los mnemónicos para cada almacén son los siguientes. MZROTMZ3"@es .

ns1:MZROTMZ4 a ns1:Parametro ;
    rdfs:label "MZROTMZ4 (torreta almacén 4)"@es ;
    ns1:identificador "MZROTMZ4" ;
    ns1:textoExtracto "Los mnemónicos para cada almacén son los siguientes. MZROTMZ4"@es .

ns1:MZTOSPDL a ns1:Parametro ;
    rdfs:label "MZTOSPDL (marca de herramienta de tierra al cabezal)"@es ;
    ns1:identificador "MZTOSPDL" ;
    ns1:textoExtracto "El PLC debe poner esta marca a (=1) tras llevar la herramienta de tierra al cabezal. MZTOSPDL Hay una marca para cada almacén."@es .

ns1:MZTOSPDLMZ1 a ns1:Parametro ;
    rdfs:label "MZTOSPDLMZ1 (almacén 1)"@es ;
    ns1:identificador "MZTOSPDLMZ1" ;
    ns1:textoExtracto "Los mnemónicos para cada almacén son los siguientes. MZTOSPDLMZ1 (también se puede programar como MZTOSPDL)"@es .

ns1:MZTOSPDLMZ2 a ns1:Parametro ;
    rdfs:label "MZTOSPDLMZ2 (almacén 2)"@es ;
    ns1:identificador "MZTOSPDLMZ2" ;
    ns1:textoExtracto "Los mnemónicos para cada almacén son los siguientes. MZTOSPDLMZ2"@es .

ns1:MZTOSPDLMZ3 a ns1:Parametro ;
    rdfs:label "MZTOSPDLMZ3 (almacén 3)"@es ;
    ns1:identificador "MZTOSPDLMZ3" ;
    ns1:textoExtracto "Los mnemónicos para cada almacén son los siguientes. MZTOSPDLMZ3"@es .

ns1:MZTOSPDLMZ4 a ns1:Parametro ;
    rdfs:label "MZTOSPDLMZ4 (almacén 4)"@es ;
    ns1:identificador "MZTOSPDLMZ4" ;
    ns1:textoExtracto "Los mnemónicos para cada almacén son los siguientes. MZTOSPDLMZ4"@es .

ns1:SPDLTOMZ a ns1:Parametro ;
    rdfs:label "SPDLTOMZ (marca de herramienta del cabezal al almacén)"@es ;
    ns1:identificador "SPDLTOMZ" ;
    ns1:textoExtracto "El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal al almacén. SPDLTOMZ Hay una marca para cada almacén."@es .

ns1:SPDLTOMZ1 a ns1:Parametro ;
    rdfs:label "SPDLTOMZ1 (almacén 1)"@es ;
    ns1:identificador "SPDLTOMZ1" ;
    ns1:textoExtracto "Los mnemónicos para cada almacén son los siguientes. SPDLTOMZ1 (también se puede programar como SPDLTOMZ)"@es .

ns1:SPDLTOMZ2 a ns1:Parametro ;
    rdfs:label "SPDLTOMZ2 (almacén 2)"@es ;
    ns1:identificador "SPDLTOMZ2" ;
    ns1:textoExtracto "Los mnemónicos para cada almacén son los siguientes. SPDLTOMZ2"@es .

ns1:SPDLTOMZ3 a ns1:Parametro ;
    rdfs:label "SPDLTOMZ3 (almacén 3)"@es ;
    ns1:identificador "SPDLTOMZ3" ;
    ns1:textoExtracto "Los mnemónicos para cada almacén son los siguientes. SPDLTOMZ3"@es .

ns1:SPDLTOMZ4 a ns1:Parametro ;
    rdfs:label "SPDLTOMZ4 (almacén 4)"@es ;
    ns1:identificador "SPDLTOMZ4" ;
    ns1:textoExtracto "Los mnemónicos para cada almacén son los siguientes. SPDLTOMZ4"@es .

ns1:TCHANGEOK a ns1:Parametro ;
    rdfs:label "TCHANGEOK (marca de cambio de herramienta)"@es ;
    ns1:identificador "TCHANGEOK" ;
    ns1:textoExtracto "El PLC debe poner esta marca a (=1) cuando se ha efectuado el cambio de herramienta (M06). TCHANGEOK Hay una marca para cada almacén."@es .

ns1:TCHANGEOKMZ1 a ns1:Parametro ;
    rdfs:label "TCHANGEOKMZ1 (cambio de herramienta almacén 1)"@es ;
    ns1:identificador "TCHANGEOKMZ1" ;
    ns1:textoExtracto "Los mnemónicos para cada almacén son los siguientes. TCHANGEOKMZ1 (equivalente a TCHANGEOK)"@es .

ns1:TCHANGEOKMZ2 a ns1:Parametro ;
    rdfs:label "TCHANGEOKMZ2 (cambio de herramienta almacén 2)"@es ;
    ns1:identificador "TCHANGEOKMZ2" ;
    ns1:textoExtracto "Los mnemónicos para cada almacén son los siguientes. TCHANGEOKMZ2"@es .

ns1:TCHANGEOKMZ3 a ns1:Parametro ;
    rdfs:label "TCHANGEOKMZ3 (cambio de herramienta almacén 3)"@es ;
    ns1:identificador "TCHANGEOKMZ3" ;
    ns1:textoExtracto "Los mnemónicos para cada almacén son los siguientes. TCHANGEOKMZ3"@es .

ns1:TCHANGEOKMZ4 a ns1:Parametro ;
    rdfs:label "TCHANGEOKMZ4 (cambio de herramienta almacén 4)"@es ;
    ns1:identificador "TCHANGEOKMZ4" ;
    ns1:textoExtracto "Los mnemónicos para cada almacén son los siguientes. TCHANGEOKMZ4"@es .

