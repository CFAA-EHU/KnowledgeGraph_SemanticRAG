@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Se_alesGestorHerramientas_6_13 a ns1:Sistema ;
    rdfs:label "Señales modificables del gestor de herramientas (Sección 6.13)" ;
    ns1:textoExtracto "Señales modificables del gestor de herramientas: TCHANGEOKMZ1, TCHANGEOKMZ2, TCHANGEOKMZ3, TCHANGEOKMZ4 (cambio de herramienta), MZPOSMZ1, MZPOSMZ2, MZPOSMZ3, MZPOSMZ4 (posición del almacén)." ;
    ns1:tieneComponente ns1:Marca_TCHANGEOKMZ1,
        ns1:Marca_TCHANGEOKMZ2,
        ns1:Marca_TCHANGEOKMZ3,
        ns1:Marca_TCHANGEOKMZ4,
        ns1:Registro_MZPOSMZ1,
        ns1:Registro_MZPOSMZ2,
        ns1:Registro_MZPOSMZ3,
        ns1:Registro_MZPOSMZ4 .

ns1:Marca_TCHANGEOKMZ1 a ns1:ComponenteElectrico ;
    rdfs:label "TCHANGEOKMZ1 (Marca de cambio de herramienta - Almacén 1)" ;
    ns1:identificador "TCHANGEOKMZ1" ;
    ns1:textoExtracto "TCHANGEOKMZ1 (equivalente a TCHANGEOK). El PLC debe poner esta marca a (=1) cuando se ha efectuado el cambio de herramienta (M06)." .

ns1:Marca_TCHANGEOKMZ2 a ns1:ComponenteElectrico ;
    rdfs:label "TCHANGEOKMZ2 (Marca de cambio de herramienta - Almacén 2)" ;
    ns1:identificador "TCHANGEOKMZ2" ;
    ns1:textoExtracto "TCHANGEOKMZ2. El PLC debe poner esta marca a (=1) cuando se ha efectuado el cambio de herramienta (M06)." .

ns1:Marca_TCHANGEOKMZ3 a ns1:ComponenteElectrico ;
    rdfs:label "TCHANGEOKMZ3 (Marca de cambio de herramienta - Almacén 3)" ;
    ns1:identificador "TCHANGEOKMZ3" ;
    ns1:textoExtracto "TCHANGEOKMZ3. El PLC debe poner esta marca a (=1) cuando se ha efectuado el cambio de herramienta (M06)." .

ns1:Marca_TCHANGEOKMZ4 a ns1:ComponenteElectrico ;
    rdfs:label "TCHANGEOKMZ4 (Marca de cambio de herramienta - Almacén 4)" ;
    ns1:identificador "TCHANGEOKMZ4" ;
    ns1:textoExtracto "TCHANGEOKMZ4. El PLC debe poner esta marca a (=1) cuando se ha efectuado el cambio de herramienta (M06)." .

ns1:Registro_MZPOSMZ1 a ns1:ComponenteElectrico ;
    rdfs:label "MZPOSMZ1 (Registro de posición del almacén 1)" ;
    ns1:identificador "MZPOSMZ1" ;
    ns1:textoExtracto "MZPOSMZ1 (también se puede programar como MZPOS). El PLC debe indicar en este registro la posición actual del almacén." .

ns1:Registro_MZPOSMZ2 a ns1:ComponenteElectrico ;
    rdfs:label "MZPOSMZ2 (Registro de posición del almacén 2)" ;
    ns1:identificador "MZPOSMZ2" ;
    ns1:textoExtracto "MZPOSMZ2. El PLC debe indicar en este registro la posición actual del almacén." .

ns1:Registro_MZPOSMZ3 a ns1:ComponenteElectrico ;
    rdfs:label "MZPOSMZ3 (Registro de posición del almacén 3)" ;
    ns1:identificador "MZPOSMZ3" ;
    ns1:textoExtracto "MZPOSMZ3. El PLC debe indicar en este registro la posición actual del almacén." .

ns1:Registro_MZPOSMZ4 a ns1:ComponenteElectrico ;
    rdfs:label "MZPOSMZ4 (Registro de posición del almacén 4)" ;
    ns1:identificador "MZPOSMZ4" ;
    ns1:textoExtracto "MZPOSMZ4. El PLC debe indicar en este registro la posición actual del almacén." .

