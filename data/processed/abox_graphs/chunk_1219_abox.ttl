@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Instruccion_DFU_B0KEYBD1_2 a ns1:Parametro ;
    rdfs:label "Instrucción DFU B0KEYBD1_2" ;
    ns1:controla ns1:Registro_KEYLED1_2 ;
    ns1:textoExtracto "DFU B0KEYBD1_2 = CPL B0KEYLED1_2" ;
    ns1:valor "CPL B0KEYLED1_2" .

ns1:Modulo_OP_PANEL_H_E a ns1:InterfazUsuario ;
    rdfs:label "Módulo OP-PANEL-H/E" ;
    ns1:textoExtracto "módulos OP-PANEL-H/E" ;
    ns1:tieneComponente ns1:Registro_KEYLED2,
        ns1:Registro_KEYLED2_1,
        ns1:Registro_KEYLED2_2 .

ns1:PanelMando_1 a ns1:InterfazUsuario ;
    rdfs:label "Primer panel de mando" ;
    ns1:textoExtracto "primer panel de mando" ;
    ns1:tieneComponente ns1:Registro_KEYLED1_1,
        ns1:Registro_KEYLED2_1 .

ns1:PanelMando_2 a ns1:InterfazUsuario ;
    rdfs:label "Segundo panel de mando" ;
    ns1:textoExtracto "segundo panel de mando" ;
    ns1:tieneComponente ns1:Registro_KEYLED1_2,
        ns1:Registro_KEYLED2_2 .

ns1:Registro_KEYLED1 a ns1:ComponenteElectrico ;
    rdfs:label "Registro KEYLED1" ;
    ns1:identificador "KEYLED1" ;
    ns1:textoExtracto "KEYLED1 Este registro enciende el led (bit=1) de las teclas de usuario en todos los paneles de mando simultáneamente." .

ns1:Registro_KEYLED1_1 a ns1:ComponenteElectrico ;
    rdfs:label "Registro KEYLED1_1" ;
    ns1:identificador "KEYLED1_1" ;
    ns1:textoExtracto "KEYLED1_1 [...] El registro KEYLED1_1 corresponde al primer panel de mando" .

ns1:Registro_KEYLED2 a ns1:ComponenteElectrico ;
    rdfs:label "Registro KEYLED2" ;
    ns1:identificador "KEYLED2" ;
    ns1:textoExtracto "KEYLED2 Este registro enciende el led (bit=1) de las teclas en todos los módulos OP-PANEL-H/E simultáneamente." .

ns1:Registro_KEYLED1_2 a ns1:ComponenteElectrico ;
    rdfs:label "Registro KEYLED1_2" ;
    ns1:identificador "KEYLED1_2" ;
    ns1:textoExtracto "KEYLED1_2 al segundo [panel de mando] [...] DFU B0KEYBD1_2 = CPL B0KEYLED1_2" .

ns1:Registro_KEYLED2_1 a ns1:ComponenteElectrico ;
    rdfs:label "Registro KEYLED2_1" ;
    ns1:identificador "KEYLED2_1" ;
    ns1:textoExtracto "KEYLED2_1 [...] El registro KEYLED2_1 corresponde al primer panel de mando" .

ns1:Registro_KEYLED2_2 a ns1:ComponenteElectrico ;
    rdfs:label "Registro KEYLED2_2" ;
    ns1:identificador "KEYLED2_2" ;
    ns1:textoExtracto "KEYLED2_2 al segundo [panel de mando]" .

