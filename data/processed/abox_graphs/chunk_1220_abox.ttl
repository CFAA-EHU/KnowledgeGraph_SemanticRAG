@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Instruccion_InhibicionTeclaJog a ns1:TareaMantenimiento ;
    rdfs:label "Inhibición de tecla jog (bit 16, segundo teclado)" ;
    ns1:requiereMantenimiento ns1:Tecla_Jog16 ;
    ns1:textoExtracto "La siguiente instrucción inhibe la primera tecla de jog (bit 16) del segundo teclado: ( ) = B16KEYDIS1_2" .

ns1:InterfazUsuario_PanelMando1 a ns1:InterfazUsuario ;
    rdfs:label "Primer panel de mando" ;
    ns1:textoExtracto "Los registros KEYDIS1_1 a KEYDIS4_1 corresponden al primer panel de mando" ;
    ns1:tieneComponente ns1:Tecla_Jog1 .

ns1:InterfazUsuario_PanelMando2 a ns1:InterfazUsuario ;
    rdfs:label "Segundo panel de mando" ;
    ns1:textoExtracto "KEYDIS1_2 a KEYDIS4_2 al segundo [panel de mando]" ;
    ns1:tieneComponente ns1:Tecla_Jog16 .

ns1:Registro_KEYDIS1 a ns1:Parametro ;
    rdfs:label "KEYDIS1" ;
    ns1:identificador "KEYDIS1" ;
    ns1:textoExtracto "KEYDIS1 / KEYDIS2 / KEYDIS3 / KEYDIS4 [...] inhiben (bit=1) las teclas y los conmutadores en todos los paneles de mando simultáneamente" .

ns1:Registro_KEYDIS1_1 a ns1:Parametro ;
    rdfs:label "KEYDIS1_1" ;
    ns1:identificador "KEYDIS1_1" ;
    ns1:textoExtracto "KEYDIS1_1 / KEYDIS2_1 / KEYDIS3_1 / KEYDIS4_1 [...] inhiben (bit=1) las teclas y los conmutadores en cada panel de mando. Los registros KEYDIS1_1 a KEYDIS4_1 corresponden al primer panel de mando" .

ns1:Registro_KEYDIS1_2 a ns1:Parametro ;
    rdfs:label "KEYDIS1_2" ;
    ns1:identificador "KEYDIS1_2" ;
    ns1:textoExtracto "KEYDIS1_2 [...] corresponde al segundo panel de mando" .

ns1:Registro_KEYDIS1_8 a ns1:Parametro ;
    rdfs:label "KEYDIS1_8" ;
    ns1:identificador "KEYDIS1_8" ;
    ns1:textoExtracto "KEYDIS1_1 / KEYDIS2_1 / KEYDIS3_1 / KEYDIS4_1 [...] KEYDIS1_8 / KEYDIS2_8 / KEYDIS3_8 / KEYDIS4_8 [...] inhiben (bit=1) las teclas y los conmutadores en cada panel de mando" .

ns1:Registro_KEYDIS2 a ns1:Parametro ;
    rdfs:label "KEYDIS2" ;
    ns1:identificador "KEYDIS2" ;
    ns1:textoExtracto "KEYDIS1 / KEYDIS2 / KEYDIS3 / KEYDIS4 [...] inhiben (bit=1) las teclas y los conmutadores en todos los paneles de mando simultáneamente" .

ns1:Registro_KEYDIS3 a ns1:Parametro ;
    rdfs:label "KEYDIS3" ;
    ns1:identificador "KEYDIS3" ;
    ns1:textoExtracto "KEYDIS1 / KEYDIS2 / KEYDIS3 / KEYDIS4 [...] inhiben (bit=1) las teclas y los conmutadores en todos los paneles de mando simultáneamente" .

ns1:Registro_KEYDIS4 a ns1:Parametro ;
    rdfs:label "KEYDIS4" ;
    ns1:identificador "KEYDIS4" ;
    ns1:textoExtracto "KEYDIS1 / KEYDIS2 / KEYDIS3 / KEYDIS4 [...] inhiben (bit=1) las teclas y los conmutadores en todos los paneles de mando simultáneamente" .

ns1:Registro_KEYLEDHBLS1 a ns1:Parametro ;
    rdfs:label "KEYLEDHBLS1" ;
    ns1:identificador "KEYLEDHBLS1" ;
    ns1:textoExtracto "KEYLEDHBLS1 [...] encienden los led (bit=1) de las teclas del volante HBLS. El registro KEYLEDHBLS1 corresponde al primer volante" .

ns1:Registro_KEYLEDHBLS2 a ns1:Parametro ;
    rdfs:label "KEYLEDHBLS2" ;
    ns1:identificador "KEYLEDHBLS2" ;
    ns1:textoExtracto "KEYLEDHBLS2 [...] encienden los led (bit=1) de las teclas del volante HBLS. El registro KEYLEDHBLS2 corresponde al segundo volante" .

ns1:Tecla_Jog1 a ns1:ComponenteElectrico ;
    rdfs:label "Primera tecla de jog" ;
    ns1:textoExtracto "La siguiente instrucción inhibe la primera tecla de jog (bit 16) del segundo teclado: ( ) = B16KEYDIS1_2" .

ns1:Tecla_Jog16 a ns1:ComponenteElectrico ;
    rdfs:label "Tecla de jog (bit 16)" ;
    ns1:textoExtracto "La siguiente instrucción inhibe la primera tecla de jog (bit 16) del segundo teclado: ( ) = B16KEYDIS1_2" .

