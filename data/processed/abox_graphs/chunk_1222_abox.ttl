@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Registro_KEYDIS4 a ns1:Parametro ;
    rdfs:label "Registro KEYDIS4" ;
    ns1:identificador "KEYDIS4" ;
    ns1:textoExtracto "Registros KEYDIS4 / KEYDIS4_1 a KEYDIS4_8." .

ns1:Registro_KEYDIS4_1 a ns1:Parametro ;
    rdfs:label "Registro KEYDIS4_1" ;
    ns1:identificador "KEYDIS4_1" ;
    ns1:textoExtracto "Registros KEYDIS4 / KEYDIS4_1 a KEYDIS4_8." .

ns1:Registro_KEYDIS4_8 a ns1:Parametro ;
    rdfs:label "Registro KEYDIS4_8" ;
    ns1:identificador "KEYDIS4_8" ;
    ns1:textoExtracto "Registros KEYDIS4 / KEYDIS4_1 a KEYDIS4_8." .

ns1:Registro_KEYDISHBLS1 a ns1:Parametro ;
    rdfs:label "Registro KEYDISHBLS1" ;
    ns1:controla ns1:InterfazUsuario_VolanteHBLS1 ;
    ns1:identificador "KEYDISHBLS1" ;
    ns1:textoExtracto "KEYDISHBLS1 KEYDISHBLS2 Estos registros inhiben (bit=1) las teclas y los conmutadores en el volante HBLS." .

ns1:Registro_KEYDISHBLS2 a ns1:Parametro ;
    rdfs:label "Registro KEYDISHBLS2" ;
    ns1:controla ns1:InterfazUsuario_VolanteHBLS2 ;
    ns1:identificador "KEYDISHBLS2" ;
    ns1:textoExtracto "KEYDISHBLS1 KEYDISHBLS2 Estos registros inhiben (bit=1) las teclas y los conmutadores en el volante HBLS." .

ns1:InterfazUsuario_VolanteHBLS1 a ns1:InterfazUsuario ;
    rdfs:label "Volante HBLS (primer volante)" ;
    ns1:textoExtracto "El registro KEYDISHBLS1 corresponde al primer volante" .

ns1:InterfazUsuario_VolanteHBLS2 a ns1:InterfazUsuario ;
    rdfs:label "Volante HBLS (segundo volante)" ;
    ns1:textoExtracto "KEYDISHBLS2 al segundo." .

