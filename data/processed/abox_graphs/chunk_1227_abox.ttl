@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Comunicacion_966_1 a ns1:Sistema ;
    rdfs:label "comunicación entre el gestor y el PLC" ;
    ns1:compuestoPor ns1:Almacen_2edeb682ba,
        ns1:Canal_012b0b0560 ;
    ns1:textoExtracto "Para la comunicación entre el gestor de herramientas y el PLC" .

ns1:GestorHerramientas_966_1 a ns1:Sistema ;
    rdfs:label "gestor de herramientas" ;
    ns1:controla ns1:PLC_966_1 ;
    ns1:textoExtracto "el gestor de las acciones efectuadas" .

ns1:Herramienta_7946b2f1f1 a ns1:Herramienta ;
    rdfs:label "herramienta" ;
    ns1:textoExtracto "la herramienta del cabezal" .

ns1:SubrutinaCambioHerramienta_966_1 a ns1:TareaMantenimiento ;
    rdfs:label "subrutinas asociadas al cambio de herramienta" ;
    ns1:textoExtracto "Subrutinas asociadas al cambio de herramienta." .

ns1:SubrutinaHerramienta_966_1 a ns1:TareaMantenimiento ;
    rdfs:label "subrutina asociada a la herramienta" ;
    ns1:ejecutadoPor ns1:PLC_966_1 ;
    ns1:textoExtracto "La rutina asociada a la herramienta se ejecuta automáticamente cada vez que se ejecuta una función T (selección de herramienta)." .

ns1:BrazoCambiador_966_1 a ns1:ComponenteMecanico ;
    rdfs:label "brazo cambiador" ;
    ns1:textoExtracto "llevar la herramienta del cabezal al brazo cambiador" .

ns1:Cabezal_966_1 a ns1:ComponenteMecanico ;
    rdfs:label "cabezal" ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en tierra." .

ns1:Canal_012b0b0560 a ns1:ComponenteElectrico ;
    rdfs:label "canal" ;
    ns1:textoExtracto "cada canal y almacén dispone de un grupo de marcas y registros" .

ns1:Almacen_2edeb682ba a ns1:Sistema ;
    rdfs:label "almacén" ;
    ns1:compuestoPor ns1:BrazoCambiador_966_1,
        ns1:Cabezal_966_1 ;
    ns1:textoExtracto "el almacén y coger otra." .

ns1:PLC_966_1 a ns1:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ns1:controla ns1:Almacen_2edeb682ba ;
    ns1:textoExtracto "El PLC, que es el encargado de controlar dichos movimientos" .

