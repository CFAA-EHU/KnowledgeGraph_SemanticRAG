@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambiadorHerramienta_967_1 a ns1:ComponenteMecanico ;
    rdfs:label "cambiador de herramienta"@es ;
    ns1:controla ns1:TablaAlmacenHerramientas_967_1 ;
    ns1:textoExtracto "El CNC gestionará el cambiador de herramienta"@es .

ns1:Herramienta_883c551a35 a ns1:Herramienta ;
    rdfs:label "herramienta"@es ;
    ns1:textoExtracto "La rutina asociada a la herramienta se ejecuta automáticamente cada vez que se ejecuta una función T (selección de herramienta)."@es .

ns1:Subrutina_967_1 a ns1:TareaMantenimiento ;
    rdfs:label "subrutina"@es ;
    ns1:ejecutadoPor ns1:FuncionT_6c189c51f0 ;
    ns1:textoExtracto "Se dispone de una subrutina en cada canal."@es .

ns1:Subrutina_967_2 a ns1:TareaMantenimiento ;
    rdfs:label "subrutina asociada a la función M06"@es ;
    ns1:ejecutadoPor ns1:FuncionM06_b3415ea326 ;
    ns1:textoExtracto "Subrutinas asociadas a la función M06."@es .

ns1:TablaFuncionesM_967_1 a ns1:Tabla ;
    rdfs:label "tabla de funciones –M–"@es ;
    ns1:detalladoEnEsquema ns1:Sistema_967_1 ;
    ns1:textoExtracto "Se recomienda tener personalizada esta función en la tabla de funciones –M– de forma que ejecute la subrutina correspondiente al cambiador de herramientas instalado en la máquina."@es .

ns1:AlmacenDeHerramientas_5a9e4c6313 a ns1:Sistema ;
    rdfs:label "almacén de herramientas"@es ;
    ns1:textoExtracto "almacén de herramientas"@es .

ns1:FuncionM06_b3415ea326 a ns1:ModoOperacion ;
    rdfs:label "función M06"@es ;
    ns1:textoExtracto "La función M06 ejecuta el cambio de herramienta."@es .

ns1:FuncionT_6c189c51f0 a ns1:ModoOperacion ;
    rdfs:label "función T"@es ;
    ns1:textoExtracto "función T (selección de herramienta)"@es .

ns1:Sistema_967_1 a ns1:Sistema ;
    rdfs:label "sistema"@es ;
    ns1:textoExtracto "Esta subrutina es común a todo el sistema."@es .

ns1:TablaAlmacenHerramientas_967_1 a ns1:Tabla ;
    rdfs:label "tabla correspondiente al almacén de herramientas"@es ;
    ns1:compuestoPor ns1:AlmacenDeHerramientas_5a9e4c6313 ;
    ns1:textoExtracto "actualizará la tabla correspondiente al almacén de herramientas."@es .

