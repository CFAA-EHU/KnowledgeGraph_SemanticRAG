@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:TablaAlmacen a ns1:Esquema ;
    ns1:textoExtracto "Tabla de los almacenes. Se dispone de una tabla para cada almacén. En cada una de las tablas se muestra qué herramienta hay en cada posición del almacén y en cada una de las pinzas del brazo cambiador (si se dispone de él). Aunque la tabla de almacén se puede inicializar manualmente, es el gestor el que se encarga de actualizar dinámicamente todos sus datos." ;
    ns1:tieneComponente ns1:Entity10_28b7cf4996 .

ns1:TablaHerramientas a ns1:Esquema ;
    ns1:textoExtracto "Tabla de herramientas. En la tabla de herramientas se debe definir, entre otras cosas, la geometría, tipo de monitorización y tamaño de la herramienta. Hay que definir todas las herramientas, incluso las de tierra." ;
    ns1:tieneComponente ns1:T10_6b594ad6a0,
        ns1:T1_6795285939,
        ns1:T2_d7e4f49d85,
        ns1:T3_fcea27b833,
        ns1:T4_c914770612,
        ns1:T5_7b29ce931e,
        ns1:T6_53c8453b29,
        ns1:T7_a9fbcfea4c,
        ns1:T8_0305f1a2d4,
        ns1:T9_403fa36b2c .

ns1:TablaHerramientasActivas a ns1:Esquema ;
    ns1:textoExtracto "Tabla de las herramientas activas. La tabla de las herramientas activas muestra qué herramientas se encuentran activas en los cabezales." .

ns1:Entity10_28b7cf4996 a ns1:Componente ;
    ns1:identificador "10" ;
    ns1:textoExtracto "Se dispone de 10 herramientas y un almacén de 10 posiciones." .

ns1:T10_6b594ad6a0 a ns1:Herramienta ;
    ns1:identificador "T10" ;
    ns1:textoExtracto "Las herramientas T8, T9 y T10 no entran en el almacén y serán herramientas de tierra." ;
    ns1:valor "herramienta de tierra" .

ns1:T1_6795285939 a ns1:Herramienta ;
    ns1:identificador "T1" ;
    ns1:textoExtracto "La T1 en la posición 1." ;
    ns1:valor "tamaño pequeño" .

ns1:T2_d7e4f49d85 a ns1:Herramienta ;
    ns1:identificador "T2" ;
    ns1:textoExtracto "La T2 en la posición 3. Comprobar que en la posición 2 no se puede porque la herramienta es de tamaño grande. La T2 ocupa las posiciones 2-3-4." ;
    ns1:valor "tamaño grande" .

ns1:T3_fcea27b833 a ns1:Herramienta ;
    ns1:identificador "T3" ;
    ns1:textoExtracto "La T3 en la posición 5." ;
    ns1:valor "tamaño pequeño" .

ns1:T4_c914770612 a ns1:Herramienta ;
    ns1:identificador "T4" ;
    ns1:textoExtracto "La T4 en la posición 6. La T4 ocupa las posiciones 6-7." ;
    ns1:valor "tamaño personal (0 a la izquierda, 1 a la derecha)" .

ns1:T5_7b29ce931e a ns1:Herramienta ;
    ns1:identificador "T5" ;
    ns1:textoExtracto "La T5 en la posición 8." ;
    ns1:valor "tamaño pequeño" .

ns1:T6_53c8453b29 a ns1:Herramienta ;
    ns1:identificador "T6" ;
    ns1:textoExtracto "La T6 en la posición 9." ;
    ns1:valor "tamaño pequeño" .

ns1:T7_a9fbcfea4c a ns1:Herramienta ;
    ns1:identificador "T7" ;
    ns1:textoExtracto "La T7 en la posición 10." ;
    ns1:valor "tamaño pequeño" .

ns1:T8_0305f1a2d4 a ns1:Herramienta ;
    ns1:identificador "T8" ;
    ns1:textoExtracto "Las herramientas T8, T9 y T10 no entran en el almacén y serán herramientas de tierra." ;
    ns1:valor "herramienta de tierra" .

ns1:T9_403fa36b2c a ns1:Herramienta ;
    ns1:identificador "T9" ;
    ns1:textoExtracto "Las herramientas T8, T9 y T10 no entran en el almacén y serán herramientas de tierra." ;
    ns1:valor "herramienta de tierra" .

