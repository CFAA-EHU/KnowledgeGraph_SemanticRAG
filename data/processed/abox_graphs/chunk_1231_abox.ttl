@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Almacen a ns1:Componente ;
    rdfs:label "almacén" ;
    ns1:textoExtracto "almacén" .

ns1:AlmacenesAsincronos a ns1:Componente ;
    rdfs:label "almacenes asíncronos" ;
    ns1:textoExtracto "almacenes asíncronos" .

ns1:BrazoCambiador a ns1:ComponenteMecanico ;
    rdfs:label "brazo cambiador" ;
    ns1:textoExtracto "brazo cambiador" .

ns1:CNC a ns1:Maquina ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "CNC" .

ns1:Canal a ns1:Componente ;
    rdfs:label "canal" ;
    ns1:textoExtracto "canal" .

ns1:ComunicacionGestorPLC a ns1:Sistema ;
    ns1:compuestoPor ns1:GestorHerramientas,
        ns1:PLC ;
    ns1:textoExtracto "Para la comunicación entre el gestor de herramientas y el PLC" .

ns1:DesplazamientoAlmacen a ns1:ComponenteMecanico ;
    rdfs:label "desplazamiento almacén" ;
    ns1:textoExtracto "desplazamiento almacén" .

ns1:DispositivoExterno a ns1:Componente ;
    rdfs:label "dispositivos externos" ;
    ns1:textoExtracto "dispositivos externos" .

ns1:FuncionM06 a ns1:AccionProhibida ;
    rdfs:label "función M06" ;
    ns1:textoExtracto "función M06" .

ns1:FuncionT a ns1:AccionProhibida ;
    rdfs:label "función T" ;
    ns1:textoExtracto "función T" .

ns1:GiroAlmacen a ns1:ComponenteMecanico ;
    rdfs:label "giro almacén" ;
    ns1:textoExtracto "giro almacén" .

ns1:MarcaTCHANGEOK a ns1:Sensor ;
    rdfs:label "marca TCHANGEOK" ;
    ns1:textoExtracto "marca TCHANGEOK" .

ns1:RutinaAsociadaM06 a ns1:TareaMantenimiento ;
    rdfs:label "rutina asociada a M06" ;
    ns1:textoExtracto "rutina asociada a M06" .

ns1:VersionDeSoftwareV200 a ns1:Parametro ;
    rdfs:label "versión de software V2.00" ;
    ns1:identificador "V2.00" ;
    ns1:textoExtracto "A partir de la versión de software V2.00" .

ns1:GestorHerramientas a ns1:Sistema ;
    rdfs:label "gestor de herramientas" ;
    ns1:textoExtracto "gestor de herramientas" .

ns1:PLC a ns1:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ns1:textoExtracto "PLC" .

