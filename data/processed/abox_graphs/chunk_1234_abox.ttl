@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:ElPLCDebeEfectuarUnaOVariasAccionesParaEjecutarLaOperacionSolicitadaPorElGestor a ns1:AccionProhibida ;
    ns1:textoExtracto "el PLC debe efectuar una o varias acciones para ejecutar la operación solicitada por el gestor" .

ns1:Gestor_973 a ns1:InterfazUsuario ;
    ns1:textoExtracto "El PLC utiliza las siguientes marcas para informar al gestor de las operaciones que ha realizado." .

ns1:Marca_973_1 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "Se dispone de un grupo de marcas para cada almacén." .

ns1:Marca_973_2 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "Tras finalizar cada una de ellas debe informar al gestor, activando unas marcas, de que la acción ha finalizado." .

ns1:PLC_973 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "El PLC utiliza las siguientes marcas para informar al gestor de las operaciones que ha realizado." .

ns1:SeDisponeDeUnGrupoDeMarcasParaCadaAlmacen a ns1:Componente ;
    ns1:textoExtracto "Se dispone de un grupo de marcas para cada almacén." .

ns1:Tabla_973_7_3_2 a ns1:Tabla ;
    ns1:textoExtracto "En la siguiente tabla se muestran los mnemónicos de cada marca (M) o registro (R) en cada uno de los canales o almacenes." .

