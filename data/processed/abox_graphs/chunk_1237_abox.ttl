@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_CH2TOMZ a ns1:Parametro ;
    rdfs:label "CH2TOMZ" ;
    ns1:documentadoEn ns1:Tabla_MarcasComunicacionPLC_Gestor ;
    ns1:identificador "CH2TOMZ" ;
    ns1:textoExtracto "Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del brazo cambiador 2 al almacén."@es .

ns1:Marca_GRTOSPDL a ns1:Parametro ;
    rdfs:label "GRTOSPDL" ;
    ns1:documentadoEn ns1:Tabla_MarcasComunicacionPLC_Gestor ;
    ns1:identificador "GRTOSPDL" ;
    ns1:textoExtracto "Utilizar con almacén que permite herramientas de tierra. El PLC debe poner esta marca a (=1) tras llevar la herramienta de tierra al cabezal."@es .

ns1:Marca_MZROT a ns1:Parametro ;
    rdfs:label "MZROT" ;
    ns1:documentadoEn ns1:Tabla_MarcasComunicacionPLC_Gestor ;
    ns1:identificador "MZROT" ;
    ns1:textoExtracto "Utilizar con almacén tipo torreta y con almacén síncrono. El PLC debe poner esta marca a (=1) cuando la torreta ha girado. En el almacén síncrono se utiliza para optimizar el cambio orientando el almacén durante el mecanizado."@es .

ns1:Marca_MZTOSPDL a ns1:Parametro ;
    rdfs:label "MZTOSPDL" ;
    ns1:documentadoEn ns1:Tabla_MarcasComunicacionPLC_Gestor ;
    ns1:identificador "MZTOSPDL" ;
    ns1:textoExtracto "Utilizar con almacén síncrono (sin brazo). El PLC debe poner esta marca a (=1) tras llevar la herramienta del almacén al cabezal."@es .

ns1:Marca_SPDLTOGR a ns1:Parametro ;
    rdfs:label "SPDLTOGR" ;
    ns1:documentadoEn ns1:Tabla_MarcasComunicacionPLC_Gestor ;
    ns1:identificador "SPDLTOGR" ;
    ns1:textoExtracto "Utilizar con almacén que permite herramientas de tierra. El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal a tierra."@es .

ns1:Marca_SPDLTOMZ a ns1:Parametro ;
    rdfs:label "SPDLTOMZ" ;
    ns1:documentadoEn ns1:Tabla_MarcasComunicacionPLC_Gestor ;
    ns1:identificador "SPDLTOMZ" ;
    ns1:textoExtracto "Utilizar con almacén síncrono (sin brazo). El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal al almacén."@es .

ns1:Marca_TCHANGEOK a ns1:Parametro ;
    rdfs:label "TCHANGEOK" ;
    ns1:documentadoEn ns1:Tabla_MarcasComunicacionPLC_Gestor ;
    ns1:identificador "TCHANGEOK" ;
    ns1:textoExtracto "En almacenes asíncronos (con brazo cambiador de movimientos independientes) se puede activar la siguiente marca para que el CNC continúe con la ejecución del programa mientras se deja la herramienta en el almacén. El PLC debe poner esta marca a (=1) para indicar al gestor que debe continuar la ejecución del programa mientras se deja la herramienta en el almacén."@es .

ns1:Tabla_MarcasComunicacionPLC_Gestor a ns1:Tabla ;
    rdfs:label "Tabla de marcas/registros para comunicación PLC-Gestor (cambio de herramienta)"@es ;
    ns1:textoExtracto """
| Marcas / Registros. | Significado. |
| --- | --- |
| CH2TOMZ | Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del brazo cambiador 2 al almacén.
| SPDLTOGR | Utilizar con almacén que permite herramientas de tierra. El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal a tierra.
| GRTOSPDL | Utilizar con almacén que permite herramientas de tierra. El PLC debe poner esta marca a (=1) tras llevar la herramienta de tierra al cabezal.
| MZTOSPDL | Utilizar con almacén síncrono (sin brazo). El PLC debe poner esta marca a (=1) tras llevar la herramienta del almacén al cabezal.
| SPDLTOMZ | Utilizar con almacén síncrono (sin brazo). El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal al almacén.
| MZROT | Utilizar con almacén tipo torreta y con almacén síncrono. El PLC debe poner esta marca a (=1) cuando la torreta ha girado.
| TCHANGEOK | En almacenes asíncronos (con brazo cambiador) se puede activar esta marca para que el CNC continúe con la ejecución del programa mientras se deja la herramienta en el almacén.""" .

