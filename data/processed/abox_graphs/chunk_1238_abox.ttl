@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:EnAlmacenesRandomSePuedenOptimizarLasOrientacionesDelAlmacenSiElGestorConoceLaPosicionQueEstaSeleccionadaEnCadaMomento a ns1:Componente ;
    ns1:textoExtracto "En almacenes random se pueden optimizar las orientaciones del almacén si el gestor conoce la posición que está seleccionada en cada momento." .

ns1:EnAlmacenesTorretaSePuedeSeleccionarUnaPosicionSentenciaROTATEMZ a ns1:Componente ;
    ns1:textoExtracto "En almacenes torreta se puede seleccionar una posición (sentencia #ROTATEMZ)." .

ns1:PLC_Gestor_comunicacion a ns1:Sistema ;
    ns1:compuestoPor ns1:Gestor_PLC,
        ns1:MZPOS_50c19cebc6 ;
    ns1:textoExtracto "El PLC debe poner esta marca a (=1) para indicar al gestor que debe continuar la ejecución del programa mientras se deja la herramienta en el almacén." ;
    ns1:tieneComponente ns1:MZPOS_50c19cebc6 .

ns1:Gestor_PLC a ns1:Sistema ;
    ns1:textoExtracto "gestor que debe continuar la ejecución del programa mientras se deja la herramienta en el almacén" .

ns1:MZPOS_50c19cebc6 a ns1:Parametro ;
    ns1:identificador "MZPOS" ;
    ns1:textoExtracto "El PLC debe indicar en este registro la posición actual del almacén; si no se desea utilizar este registro, el PLC debe ponerlo a ꞏ0ꞏ." ;
    ns1:valor "1",
        "posición actual del almacén" .

