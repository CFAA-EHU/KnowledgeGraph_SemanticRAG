@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlmacenTorreta a ns1:ComponenteMecanico ;
    rdfs:label "almacén torreta" ;
    ns1:textoExtracto "En almacenes torreta se puede seleccionar una posición (sentencia #ROTATEMZ)." ;
    ns1:tieneComponente ns1:ROTATEMZ_026286d512 .

ns1:ROTATEMZ_026286d512 a ns1:Parametro ;
    ns1:identificador "#ROTATEMZ" ;
    ns1:textoExtracto "El PLC debe indicar en este registro la posición actual del almacén; si el registro tiene valor ꞏ0ꞏ, el PLC mostrará el error correspondiente." ;
    ns1:valor "0" .

