@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

ex:Terminal a owl:Class ;
    rdfs:label "Terminal" ;
    rdfs:comment "Componente mecánico o eléctrico utilizado en sistemas hidráulicos o neumáticos." .

ex:Racor a owl:Class ;
    rdfs:label "Racor" ;
    rdfs:comment "Componente utilizado para conectar tuberías en sistemas hidráulicos." .

ex:TomaPresion a owl:Class ;
    rdfs:label "Toma de presión" ;
    rdfs:comment "Dispositivo utilizado para medir la presión en sistemas hidráulicos." .

ex:Electrovalvula a owl:Class ;
    rdfs:label "Electroválvula" ;
    rdfs:comment "Válvula controlada eléctricamente utilizada en sistemas hidráulicos." .

ex:PlacaIntermedia a owl:Class ;
    rdfs:label "Placa intermedia" ;
    rdfs:comment "Componente utilizado en sistemas hidráulicos para conectar diferentes elementos." .

ex:Antirretorno a owl:Class ;
    rdfs:label "Antirretorno" ;
    rdfs:comment "Válvula que permite el flujo en una sola dirección en sistemas hidráulicos." .

ex:SensorPresion a owl:Class ;
    rdfs:label "Sensor de presión" ;
    rdfs:comment "Dispositivo utilizado para medir la presión en sistemas hidráulicos." .

ex:TapaProteccion a owl:Class ;
    rdfs:label "Tapa de protección" ;
    rdfs:comment "Cubierta protectora para sensores o dispositivos en sistemas hidráulicos." .

ex:AisladorManometro a owl:Class ;
    rdfs:label "Aislador de manómetro" ;
    rdfs:comment "Dispositivo utilizado para proteger el manómetro de sobrepresiones." .

ex:Manometro a owl:Class ;
    rdfs:label "Manómetro" ;
    rdfs:comment "Instrumento utilizado para medir la presión en sistemas hidráulicos." .

ex:FiltroRetorno a owl:Class ;
    rdfs:label "Filtro de retorno" ;
    rdfs:comment "Filtro utilizado para limpiar el fluido hidráulico antes de que regrese al depósito." .

ex:CilindroHidraulico a owl:Class ;
    rdfs:label "Cilindro hidráulico" ;
    rdfs:comment "Dispositivo utilizado para convertir la energía hidráulica en movimiento lineal." .

ex:tieneModelo a owl:DatatypeProperty ;
    rdfs:label "tiene modelo" ;
    rdfs:comment "Propiedad que relaciona un componente con su modelo específico." ;
    rdfs:domain ex:Componente ;
    rdfs:range rdfs:Literal .

ex:tieneFabricante a owl:DatatypeProperty ;
    rdfs:label "tiene fabricante" ;
    rdfs:comment "Propiedad que relaciona un componente con su fabricante." ;
    rdfs:domain ex:Componente ;
    rdfs:range rdfs:Literal .

ex:tieneCodigo a owl:DatatypeProperty ;
    rdfs:label "tiene código" ;
    rdfs:comment "Propiedad que relaciona un componente con su código de referencia." ;
    rdfs:domain ex:Componente ;
    rdfs:range rdfs:Literal .

ex:tieneCantidad a owl:DatatypeProperty ;
    rdfs:label "tiene cantidad" ;
    rdfs:comment "Propiedad que relaciona un componente con la cantidad requerida." ;
    rdfs:domain ex:Componente ;
    rdfs:range rdfs:Literal .

ex:tieneDescripcion a owl:DatatypeProperty ;
    rdfs:label "tiene descripción" ;
    rdfs:comment "Propiedad que relaciona un componente con su descripción." ;
    rdfs:domain ex:Componente ;
    rdfs:range rdfs:Literal .

ex:Componente a owl:Class ;
    rdfs:label "Componente" ;
    rdfs:comment "Clase base para todos los componentes mecánicos o eléctricos." .