@prefix ex: <https://vocab.cfaa.eus/broaching/>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.

ex:Terminal a owl:Class ;
    rdfs:label "Terminal" ;
    rdfs:comment "Componente mecánico o eléctrico" .

ex:Racor a owl:Class ;
    rdfs:label "Racor" ;
    rdfs:comment "Componente de conexión hidráulica" .

ex:TomaPresion a owl:Class ;
    rdfs:label "Toma de presión" ;
    rdfs:comment "Dispositivo para medir la presión en un sistema hidráulico" .

ex:Electrovalvula a owl:Class ;
    rdfs:label "Electroválvula" ;
    rdfs:comment "Válvula controlada eléctricamente para fluidos" .

ex:PlacaIntermedia a owl:Class ;
    rdfs:label "Placa intermedia" ;
    rdfs:comment "Componente estructural en sistemas hidráulicos" .

ex:Antirretorno a owl:Class ;
    rdfs:label "Antirretorno" ;
    rdfs:comment "Válvula que evita el flujo inverso en sistemas hidráulicos" .

ex:SensorPresion a owl:Class ;
    rdfs:label "Sensor de presión" ;
    rdfs:comment "Dispositivo para medir la presión en sistemas hidráulicos" .

ex:AisladorManometro a owl:Class ;
    rdfs:label "Aislador de manómetro" ;
    rdfs:comment "Dispositivo para proteger el manómetro de sobrepresiones" .

ex:Manometro a owl:Class ;
    rdfs:label "Manómetro" ;
    rdfs:comment "Instrumento para medir la presión de fluidos" .

ex:FiltroRetorno a owl:Class ;
    rdfs:label "Filtro de retorno" ;
    rdfs:comment "Filtro para limpiar el fluido en sistemas hidráulicos" .

ex:CilindroHidraulico a owl:Class ;
    rdfs:label "Cilindro hidráulico" ;
    rdfs:comment "Dispositivo que convierte la energía hidráulica en movimiento lineal" .

ex:MesaRotatoria a owl:Class ;
    rdfs:label "Mesa rotatoria" ;
    rdfs:comment "Componente que permite el movimiento rotatorio en sistemas mecánicos" .

ex:TapaProteccion a owl:Class ;
    rdfs:label "Tapa de protección" ;
    rdfs:comment "Cubierta protectora para componentes sensibles" .

ex:ProtectiveCover a owl:Class ;
    rdfs:label "Protective Cover" ;
    rdfs:comment "Tapa de protección para sensores de presión" .

