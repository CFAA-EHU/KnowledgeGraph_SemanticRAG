@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RESTMEMZ1 a ns1:ComponenteElectrico ;
    rdfs:label "Marca RESTMEMZ1 (Cancelación emergencia Almacén 1)"@es ;
    ns1:documentadoEn ns1:Tabla_MarcasEmergenciaGestor ;
    ns1:identificador "RESTMEMZ1" ;
    ns1:textoExtracto "Se dispone de un grupo de marcas para cada almacén [...] Almacén ꞏ1ꞏ: RESTMEM RESTMEMZ1"@es .

ns1:RESTMEMZ2 a ns1:ComponenteElectrico ;
    rdfs:label "Marca RESTMEMZ2 (Cancelación emergencia Almacén 2)"@es ;
    ns1:documentadoEn ns1:Tabla_MarcasEmergenciaGestor ;
    ns1:identificador "RESTMEMZ2" ;
    ns1:textoExtracto "Almacén ꞏ2ꞏ: RESTMEMZ2"@es .

ns1:RESTMEMZ3 a ns1:ComponenteElectrico ;
    rdfs:label "Marca RESTMEMZ3 (Cancelación emergencia Almacén 3)"@es ;
    ns1:documentadoEn ns1:Tabla_MarcasEmergenciaGestor ;
    ns1:identificador "RESTMEMZ3" ;
    ns1:textoExtracto "Almacén ꞏ3ꞏ: RESTMEMZ3"@es .

ns1:RESTMEMZ4 a ns1:ComponenteElectrico ;
    rdfs:label "Marca RESTMEMZ4 (Cancelación emergencia Almacén 4)"@es ;
    ns1:documentadoEn ns1:Tabla_MarcasEmergenciaGestor ;
    ns1:identificador "RESTMEMZ4" ;
    ns1:textoExtracto "Almacén ꞏ4ꞏ: RESTMEMZ4"@es .

ns1:SETTMEMZ1 a ns1:ComponenteElectrico ;
    rdfs:label "Marca SETTMEMZ1 (Activación emergencia Almacén 1)"@es ;
    ns1:documentadoEn ns1:Tabla_MarcasEmergenciaGestor ;
    ns1:identificador "SETTMEMZ1" ;
    ns1:textoExtracto "Se dispone de un grupo de marcas para cada almacén [...] Almacén ꞏ1ꞏ: SETTMEM SETTMEMZ1"@es .

ns1:SETTMEMZ2 a ns1:ComponenteElectrico ;
    rdfs:label "Marca SETTMEMZ2 (Activación emergencia Almacén 2)"@es ;
    ns1:documentadoEn ns1:Tabla_MarcasEmergenciaGestor ;
    ns1:identificador "SETTMEMZ2" ;
    ns1:textoExtracto "Almacén ꞏ2ꞏ: SETTMEMZ2"@es .

ns1:SETTMEMZ3 a ns1:ComponenteElectrico ;
    rdfs:label "Marca SETTMEMZ3 (Activación emergencia Almacén 3)"@es ;
    ns1:documentadoEn ns1:Tabla_MarcasEmergenciaGestor ;
    ns1:identificador "SETTMEMZ3" ;
    ns1:textoExtracto "Almacén ꞏ3ꞏ: SETTMEMZ3"@es .

ns1:SETTMEMZ4 a ns1:ComponenteElectrico ;
    rdfs:label "Marca SETTMEMZ4 (Activación emergencia Almacén 4)"@es ;
    ns1:documentadoEn ns1:Tabla_MarcasEmergenciaGestor ;
    ns1:identificador "SETTMEMZ4" ;
    ns1:textoExtracto "Almacén ꞏ4ꞏ: SETTMEMZ4"@es .

ns1:SistemaEmergenciaGestor a ns1:Sistema ;
    rdfs:label "Sistema de emergencia del gestor de herramientas"@es ;
    ns1:compuestoPor ns1:RESTMEM,
        ns1:SETTMEM,
        ns1:TMINEM ;
    ns1:detalladoEnEsquema ns1:Tabla_MarcasEmergenciaGestor ;
    ns1:textoExtracto "El gestor se puede poner en estado de emergencia si se produce una anomalía (el PLC ha ejecutado una acción equivocada, cambio no finalizado, etc) o si el PLC activa la emergencia."@es .

ns1:TMINEMZ1 a ns1:ComponenteElectrico ;
    rdfs:label "Marca TMINEMZ1 (Indicación emergencia Almacén 1)"@es ;
    ns1:documentadoEn ns1:Tabla_MarcasEmergenciaGestor ;
    ns1:identificador "TMINEMZ1" ;
    ns1:textoExtracto "Se dispone de un grupo de marcas para cada almacén [...] Almacén ꞏ1ꞏ: TMINEM TMINEMZ1"@es .

ns1:TMINEMZ2 a ns1:ComponenteElectrico ;
    rdfs:label "Marca TMINEMZ2 (Indicación emergencia Almacén 2)"@es ;
    ns1:documentadoEn ns1:Tabla_MarcasEmergenciaGestor ;
    ns1:identificador "TMINEMZ2" ;
    ns1:textoExtracto "Almacén ꞏ2ꞏ: TMINEMZ2"@es .

ns1:TMINEMZ3 a ns1:ComponenteElectrico ;
    rdfs:label "Marca TMINEMZ3 (Indicación emergencia Almacén 3)"@es ;
    ns1:documentadoEn ns1:Tabla_MarcasEmergenciaGestor ;
    ns1:identificador "TMINEMZ3" ;
    ns1:textoExtracto "Almacén ꞏ3ꞏ: TMINEMZ3"@es .

ns1:TMINEMZ4 a ns1:ComponenteElectrico ;
    rdfs:label "Marca TMINEMZ4 (Indicación emergencia Almacén 4)"@es ;
    ns1:documentadoEn ns1:Tabla_MarcasEmergenciaGestor ;
    ns1:identificador "TMINEMZ4" ;
    ns1:textoExtracto "Almacén ꞏ4ꞏ: TMINEMZ4"@es .

ns1:Frecuencia_ActivacionEmergencia a ns1:Frecuencia ;
    rdfs:label "Frecuencia de activación de emergencia (SETTMEM)"@es ;
    ns1:textoExtracto "Para generar una emergencia del gestor desde el PLC, se debe: (1)Activar la emergencia. DFU (condición de error) = SET SETTMEM"@es .

ns1:Frecuencia_CancelacionEmergencia a ns1:Frecuencia ;
    rdfs:label "Frecuencia de cancelación de emergencia (RESTMEM)"@es ;
    ns1:textoExtracto "Asegurarse que se ha producido la emergencia antes de cancelarla. TMINEM AND DFU (condición de quitar) = SET RESTMEM"@es .

ns1:Frecuencia_IndicacionEmergencia a ns1:Frecuencia ;
    rdfs:label "Frecuencia de indicación de emergencia (TMINEM)"@es ;
    ns1:textoExtracto "El CNC pone esta marca a (=1) para indicar al PLC que se ha producido una emergencia en el gestor de herramientas."@es .

ns1:Pagina_476 a ns1:Pagina ;
    ns1:documentadoEn ns1:ManualGestorHerramientas ;
    ns1:identificador "476" ;
    ns1:textoExtracto "El gestor se puede poner en estado de emergencia si se produce una anomalía [...] Las señales SETMEM y RESTMEM las pone a (=0) el gestor."@es .

ns1:RESTMEM a ns1:ComponenteElectrico ;
    rdfs:label "Marca RESTMEM (Cancelación emergencia)"@es ;
    ns1:documentadoEn ns1:Tabla_MarcasEmergenciaGestor ;
    ns1:identificador "RESTMEM" ;
    ns1:textoExtracto "El PLC pone esta marca a (=1) para cancelar la emergencia del gestor de herramientas."@es ;
    ns1:tieneFrecuencia ns1:Frecuencia_CancelacionEmergencia .

ns1:SETTMEM a ns1:ComponenteElectrico ;
    rdfs:label "Marca SETTMEM (Activación emergencia)"@es ;
    ns1:documentadoEn ns1:Tabla_MarcasEmergenciaGestor ;
    ns1:identificador "SETTMEM" ;
    ns1:textoExtracto "El PLC pone esta marca a (=1) para activar la emergencia del gestor de herramientas."@es ;
    ns1:tieneFrecuencia ns1:Frecuencia_ActivacionEmergencia .

ns1:TMINEM a ns1:ComponenteElectrico ;
    rdfs:label "Marca TMINEM (Indicación emergencia CNC)"@es ;
    ns1:documentadoEn ns1:Tabla_MarcasEmergenciaGestor ;
    ns1:identificador "TMINEM" ;
    ns1:textoExtracto "El CNC pone esta marca a (=1) para indicar al PLC que se ha producido una emergencia en el gestor de herramientas."@es ;
    ns1:tieneFrecuencia ns1:Frecuencia_IndicacionEmergencia .

ns1:Tabla_MarcasEmergenciaGestor a ns1:Tabla ;
    rdfs:label "Tabla de marcas de emergencia del gestor de herramientas"@es ;
    ns1:ilustradoEn ns1:Pagina_476 ;
    ns1:textoExtracto "En la siguiente tabla se muestran los mnemónicos de cada marca (M) en cada uno de los almacenes. [...] El significado de las marcas y registros es el siguiente."@es .

