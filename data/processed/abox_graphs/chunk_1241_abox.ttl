@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Marca_CUTTINGON a ns1:Parametro ;
    rdfs:label "CUTTINGON" ;
    ns1:documentadoEn ns1:Tabla_SignificadoMarcas ;
    ns1:identificador "CUTTINGONC1; CUTTINGONC2; CUTTINGONC3; CUTTINGONC4" ;
    ns1:monitoreaParametro ns1:Herramienta_Generica ;
    ns1:textoExtracto "Cuando se le asocia a la herramienta un tiempo máximo de vida (monitorización) el CNC consulta esta marca para saber si la herramienta está mecanizando (=1) o no (=0)."@es ;
    ns1:valor true .

ns1:Marca_TREJECT a ns1:Parametro ;
    rdfs:label "TREJECT" ;
    ns1:documentadoEn ns1:Tabla_SignificadoMarcas ;
    ns1:identificador "TREJECTC1; TREJECTC2; TREJECTC3; TREJECTC4" ;
    ns1:mitigaRiesgo ns1:AvisoSeguridad_RechazoHerramienta ;
    ns1:textoExtracto "Si el PLC pone esta marca a (=1) el CNC entiende que la herramienta debe ser rechazada."@es ;
    ns1:valor true .

ns1:Marca_TWORNOUT a ns1:Parametro ;
    rdfs:label "TWORNOUT" ;
    ns1:activaAlarma ns1:Alarma_VidaUtilExcedida ;
    ns1:documentadoEn ns1:Tabla_SignificadoMarcas ;
    ns1:identificador "TWORNOUTC1; TWORNOUTC2; TWORNOUTC3; TWORNOUTC4" ;
    ns1:textoExtracto "El CNC pone esta marca a (=1) para indicar al PLC que la herramienta ha sido rechazada porque se ha usado más tiempo del previsto (vida real > vida máxima)."@es ;
    ns1:valor true .

ns1:Tabla_MarcasMonitorizacionHerramientas a ns1:Tabla ;
    rdfs:label "Tabla de marcas de PLC para monitorización de herramientas"@es ;
    ns1:ilustradoEn ns1:Tabla_SignificadoMarcas ;
    ns1:textoExtracto "Las marcas de PLC relacionadas con la monitorización de herramientas son las siguientes. Se dispone de un grupo de marcas para cada canal. En la siguiente tabla se muestran los mnemónicos de cada marca (M) en cada uno de los almacenes."@es .

ns1:Alarma_VidaUtilExcedida a ns1:Alarma ;
    rdfs:label "Alarma por vida útil de herramienta excedida"@es ;
    ns1:textoExtracto "la herramienta ha sido rechazada porque se ha usado más tiempo del previsto (vida real > vida máxima)."@es .

ns1:AvisoSeguridad_RechazoHerramienta a ns1:AvisoSeguridad ;
    rdfs:label "Rechazo de herramienta por PLC"@es ;
    ns1:textoExtracto "Si el PLC pone esta marca a (=1) el CNC entiende que la herramienta debe ser rechazada."@es .

ns1:Herramienta_Generica a ns1:Herramienta ;
    rdfs:label "Herramienta monitorizada"@es ;
    ns1:requiereMantenimiento ns1:TareaMantenimiento_ReemplazoHerramienta ;
    ns1:textoExtracto "Cuando se le asocia a la herramienta un tiempo máximo de vida (monitorización) el CNC consulta esta marca para saber si la herramienta está mecanizando."@es .

ns1:TareaMantenimiento_ReemplazoHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Reemplazo de herramienta por desgaste o vida útil excedida"@es ;
    ns1:textoExtracto "monitorización de herramientas [...] vida real > vida máxima."@es .

ns1:Tabla_SignificadoMarcas a ns1:Tabla ;
    rdfs:label "Significado de marcas y registros de monitorización de herramientas"@es ;
    ns1:textoExtracto "| Marcas / Registros. | Significado. | --- | --- | CUTTINGON | Cuando se le asocia a la herramienta un tiempo máximo de vida (monitorización) el CNC consulta esta marca para saber si la herramienta está mecanizando (=1) o no (=0). [...] TWORNOUT | El CNC pone esta marca a (=1) para indicar al PLC que la herramienta ha sido rechazada porque se ha usado más tiempo del previsto (vida real > vida máxima)."@es .

