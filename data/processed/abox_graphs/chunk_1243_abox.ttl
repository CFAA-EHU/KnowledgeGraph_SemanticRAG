@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_Emergencia a ns1:ModoOperacion ;
    rdfs:label "Modo emergencia (valor 4)"@es ;
    ns1:controla ns1:Sistema_GestionHerramientas ;
    ns1:identificador "4" ;
    ns1:textoExtracto "Con valor ꞏ4ꞏ Emergencia."@es .

ns1:Parametro_MZRUN a ns1:Parametro ;
    rdfs:label "Gestor de herramientas en funcionamiento (V.[ch].TM.MZRUN)"@es ;
    ns1:monitoreaParametro ns1:Sistema_GestionHerramientas ;
    ns1:textoExtracto "V.[ch].TM.MZRUN Gestor de herramientas en funcionamiento. Con valor ꞏ0ꞏ No hay ninguna secuencia en ejecución. Con valor ꞏ1ꞏ Indica que hay una secuencia en ejecución."@es ;
    ns1:valor "0",
        "1",
        "4" .

ns1:Parametro_MZWAIT a ns1:Parametro ;
    rdfs:label "Gestor procesando una maniobra (V.[ch].TM.MZWAIT)"@es ;
    ns1:monitoreaParametro ns1:Sistema_GestionHerramientas ;
    ns1:textoExtracto "V.[ch].TM.MZWAIT Gestor procesando una maniobra. Indica si hay que esperar porque hay una maniobra en marcha. Con valor ꞏ0ꞏ No hay que esperar. Con valor ꞏ1ꞏ Hay que esperar."@es ;
    ns1:valor "0",
        "1" .

ns1:Subrutina_M06 a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina asociada a M06"@es ;
    ns1:ejecutadoPor ns1:Sistema_GestionHerramientas ;
    ns1:textoExtracto "En la subrutina asociada a M06 no es necesaria su programación. La propia subrutina espera a que finalicen las maniobras del gestor."@es .

ns1:Sistema_GestionHerramientas a ns1:Sistema ;
    rdfs:label "Sistema de gestión de herramientas y maniobras"@es ;
    ns1:textoExtracto "Gestor de herramientas en funcionamiento [...] Gestor procesando una maniobra [...] La propia subrutina espera a que finalicen las maniobras del gestor."@es .

