@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InstruccionTM6 a ns1:TareaMantenimiento ;
    rdfs:label "instrucción T1 M6" ;
    ns1:textoExtracto "Si a continuación se ejecuta la instrucción T1 M6 el gestor entiende que se desea llevar la herramienta T1 de tierra al almacén pasando por el cabezal y se lo comunicará al PLC con TMOPERATION=9." .

ns1:ManualOperacion1 a ns1:Manual ;
    rdfs:label "Manual de operación" ;
    ns1:textoExtracto "Consultar el manual de operación." .

ns1:SubrutinaM06 a ns1:TareaMantenimiento ;
    rdfs:label "subrutina asociada a la función M06" ;
    ns1:textoExtracto "En la subrutina asociada a la función M06 y en el programa del PLC deberá estar definida la maniobra necesaria para realizar el cambio." .

ns1:TMOPERATION_db01b0a340 a ns1:Parametro ;
    ns1:identificador "TMOPERATION" ;
    ns1:textoExtracto "se lo comunicará al PLC con TMOPERATION=10." ;
    ns1:valor "10",
        "9" .

ns1:TablaAlmacen1 a ns1:Tabla ;
    ns1:textoExtracto "En cada una de las tablas del almacén existen softkeys que permiten inicializar, cargar y descargar herramientas en el almacén de forma manual y automática." ;
    ns1:tieneComponente ns1:SoftkeyCargaDescarga1 .

ns1:TablaCabezal1 a ns1:Tabla ;
    ns1:textoExtracto "La carga y descarga de herramientas en el cabezal y en las pinzas del brazo cambiador hay que hacerlo siempre de forma manual desde la tabla del almacén." ;
    ns1:tieneComponente ns1:PinzaBrazoCambiador1 .

ns1:VTMMZMODE a ns1:Parametro ;
    ns1:identificador "V.TM.MZMODE" ;
    ns1:textoExtracto "Personalizar la variable V.TM.MZMODE=2, para indicar al gestor que se desea trabajar en modo descarga de almacén." ;
    ns1:valor "1",
        "2" .

ns1:PinzaBrazoCambiador1 a ns1:ComponenteMecanico ;
    rdfs:label "pinza del brazo cambiador" ;
    ns1:textoExtracto "La carga y descarga de herramientas en el cabezal y en las pinzas del brazo cambiador hay que hacerlo siempre de forma manual desde la tabla del almacén." .

ns1:SoftkeyCargaDescarga1 a ns1:InterfazUsuario ;
    rdfs:label "softkey de carga/descarga" ;
    ns1:textoExtracto "En cada una de las tablas del almacén existen softkeys que permiten inicializar, cargar y descargar herramientas en el almacén de forma manual y automática." .

