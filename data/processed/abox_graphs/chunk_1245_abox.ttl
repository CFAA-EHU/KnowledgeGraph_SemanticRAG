@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "Colocar una herramienta en el cabezal desde programa o MDI Personalizar la variable" .

ns1:Herramienta a ns1:PiezaRecambio ;
    rdfs:label "Herramienta" ;
    ns1:textoExtracto "Tras descargar la herramienta el gestor actualiza la tabla de almacén. Colocar una herramienta en el cabezal desde programa o MDI Personalizar la variable" .

ns1:Programa_PLC a ns1:Sistema ;
    rdfs:label "Programa del PLC" ;
    ns1:textoExtracto "En la subrutina asociada a la función M06 y en el programa del PLC deberá estar definida la maniobra necesaria para realizar el cambio." .

ns1:Subrutina_M06 a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina asociada a la función M06" ;
    ns1:textoExtracto "En la subrutina asociada a la función M06 y en el programa del PLC deberá estar definida la maniobra necesaria para realizar el cambio." .

ns1:Tabla_Almacen a ns1:Tabla ;
    rdfs:label "Tabla de almacén" ;
    ns1:textoExtracto "Tras descargar la herramienta el gestor actualiza la tabla de almacén." .

