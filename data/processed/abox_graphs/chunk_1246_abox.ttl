@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:CogerlaDeTierra a ns1:Herramienta ;
    ns1:textoExtracto "cogerla de tierra" .

ns1:GestorAlmacenHerramientas_985_479 a ns1:Sistema ;
    ns1:compuestoPor ns1:CabezalHerramienta_985_479,
        ns1:PLC_985_479 ;
    ns1:textoExtracto "el gestor actualiza la tabla de almacén" .

ns1:ModoNormal_985_479 a ns1:ModoOperacion ;
    ns1:identificador "modo normal" ;
    ns1:textoExtracto "trabajar en modo normal" .

ns1:SubrutinaM06_985_479 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "En la subrutina asociada a la función M06" .

ns1:T1M6 a ns1:TareaMantenimiento ;
    ns1:identificador "T1 M6" ;
    ns1:textoExtracto "ejecuta la instrucción T1 M6" .

ns1:TMOPERATION_db01b0a340 a ns1:Parametro ;
    ns1:identificador "TMOPERATION" ;
    ns1:textoExtracto "asignando a TMOPERATION el valor adecuado" .

ns1:TablaAlmacenHerramientas_985_479 a ns1:Tabla ;
    ns1:textoExtracto "Tras colocar la herramienta en el cabezal el gestor actualiza la tabla de almacén." .

ns1:VTMMZMODE a ns1:Parametro ;
    ns1:identificador "V.TM.MZMODE" ;
    ns1:textoExtracto "Colocar una herramienta en el cabezal desde programa o MDI Personalizar la variable V.TM.MZMODE=0" ;
    ns1:valor "0" .

ns1:CabezalHerramienta_985_479 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "colocar una herramienta en el cabezal" .

ns1:PLC_985_479 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "comunica al PLC la operación a efectuar" .

