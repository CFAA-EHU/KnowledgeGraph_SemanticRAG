@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:FuncionM6 a ns1:ModoOperacion ;
    ns1:textoExtracto "La función M6 no activará marcas de PLC (por ejemplo DM06) ni ejecutará nada relacionado con el cambio de herramienta (como la subrutina de cambio, etc)." ;
    ns1:tieneComponente ns1:CNC,
        ns1:PLC .

ns1:FuncionT a ns1:ModoOperacion ;
    ns1:textoExtracto "Cuando no hay almacén de herramientas, para realizar el cambio de herramienta sólo es necesario programar la función T, sin necesidad de M6." ;
    ns1:tieneComponente ns1:CNC,
        ns1:GestorCambioHerramienta .

ns1:MarcaPLC_DM06 a ns1:Parametro ;
    ns1:identificador "DM06" ;
    ns1:textoExtracto "La función M6 no activará marcas de PLC (por ejemplo DM06) ni ejecutará nada relacionado con el cambio de herramienta." .

ns1:SubrutinaCambioHerramienta a ns1:TareaMantenimiento ;
    ns1:textoExtracto "En la subrutina asociada a la función M6 (cuando la tenga), se ejecutarán ciclos fijos modales o subrutinas modales con los movimientos." .

ns1:GestorCambioHerramienta a ns1:Sistema ;
    ns1:textoExtracto "El gestor envía una orden al PLC para que pueda efectuar el cambio." ;
    ns1:tieneComponente ns1:PLC .

ns1:CNC a ns1:Maquina ;
    ns1:textoExtracto "Cuando el CNC ejecuta la función T, se lo indica al gestor." .

ns1:PLC a ns1:ComponenteElectrico ;
    ns1:textoExtracto "El gestor envía una orden al PLC para que pueda efectuar el cambio." .

