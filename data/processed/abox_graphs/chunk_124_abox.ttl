@prefix ex: <https://vocab.cfaa.eus/broaching/>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

ex:BrochadoraElectromecanicaDeExteriores a owl:Class ;
    rdfs:label "Brochadora Electromecánica de Exteriores"@es ;
    rdfs:comment "Clase que representa una brochadora electromecánica de exteriores."@es.

ex:A218Rashem7x3000x500 a owl:Class ;
    rdfs:label "A218/RASHEM 7x3000x500"@es ;
    rdfs:comment "Clase que representa el modelo específico A218/RASHEM 7x3000x500 de la brochadora electromecánica de exteriores."@es.

ex:Capitulo11 a owl:Class ;
    rdfs:label "Capítulo 11"@es ;
    rdfs:comment "Clase que representa el capítulo 11 del manual técnico."@es.