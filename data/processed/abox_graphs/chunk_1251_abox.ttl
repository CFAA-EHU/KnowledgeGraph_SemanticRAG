@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:GRTOSPDL a ns1:ModoOperacion ;
    rdfs:label "GRTOSPDL" ;
    ns1:textoExtracto "SET GRTOSPDL" .

ns1:SPDLTOGR a ns1:ModoOperacion ;
    rdfs:label "SPDLTOGR" ;
    ns1:textoExtracto "SET SPDLTOGR" .

ns1:T a ns1:ModoOperacion ;
    rdfs:label "T" ;
    ns1:textoExtracto "función T" .

ns1:cambio_herramienta_3 a ns1:AccionProhibida ;
    ns1:ejecutadoPor ns1:PLC ;
    ns1:mitigaRiesgo ns1:TMOPSTROBE ;
    ns1:monitoreaParametro ns1:TMOPERATION ;
    ns1:textoExtracto "petición de cambio de herramienta y TMOPERATION=3. El PLC ha llevado la herramienta desde tierra al cabezal" ;
    ns1:tieneComponente ns1:cabezal,
        ns1:herramienta .

ns1:cambio_herramienta_4 a ns1:AccionProhibida ;
    ns1:ejecutadoPor ns1:PLC ;
    ns1:mitigaRiesgo ns1:TMOPSTROBE ;
    ns1:monitoreaParametro ns1:TMOPERATION ;
    ns1:textoExtracto "petición de cambio de herramienta y TMOPERATION=4. El PLC ha llevado la herramienta desde el cabezal a tierra" ;
    ns1:tieneComponente ns1:cabezal,
        ns1:herramienta .

ns1:gestor a ns1:Sistema ;
    rdfs:label "gestor" ;
    ns1:textoExtracto "gestor" .

ns1:PLC a ns1:Sistema ;
    rdfs:label "PLC" ;
    ns1:textoExtracto "PLC" .

ns1:TMOPERATION a ns1:Parametro ;
    rdfs:label "TMOPERATION" ;
    ns1:textoExtracto "registro TMOPERATION" .

ns1:TMOPSTROBE a ns1:Sensor ;
    rdfs:label "TMOPSTROBE" ;
    ns1:textoExtracto "DFU TMOPSTROBE" .

ns1:cabezal a ns1:ComponenteMecanico ;
    rdfs:label "cabezal" ;
    ns1:textoExtracto "cabezal" .

ns1:herramienta a ns1:PiezaRecambio ;
    rdfs:label "herramienta" ;
    ns1:textoExtracto "herramienta" .

