@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_Cabezal_991 a ns1:Maquina ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "El PLC ha llevado la herramienta desde tierra al cabezal." .

ns1:Sistema_PLC_991 a ns1:Sistema ;
    rdfs:label "PLC" ;
    ns1:controla ns1:Herramienta_991 ;
    ns1:textoExtracto "El PLC ha llevado la herramienta desde tierra al cabezal." .

ns1:Herramienta_991 a ns1:Herramienta ;
    rdfs:label "Herramienta" ;
    ns1:textoExtracto "El PLC ha llevado la herramienta desde tierra al cabezal." .

