@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:CNCAlmacenTipoTorreta a ns1:Sistema ;
    ns1:textoExtracto "Cuando el CNC selecciona una herramienta"@es .

ns1: a ns1:Maquina ;
    ns1:textoExtracto "Es el almacén típico de torno. Para efectuar el cambio, el almacén gira hasta colocar la nueva herramienta en la posición de trabajo. No es posible efectuar el cambio de herramienta durante el mecanizado de la pieza. Hab..."@es .

ns1:GestorAlmacenTipoTorreta a ns1:Sistema ;
    ns1:textoExtracto "el gestor envía al PLC el código correspondiente a la operación que debe efectuar"@es .

ns1:PLCAlmacenTipoTorreta a ns1:ComponenteElectrico ;
    ns1:textoExtracto "el gestor envía al PLC el código correspondiente a la operación que debe efectuar"@es .

ns1:SubrutinaT a ns1:TareaMantenimiento ;
    ns1:compuestoPor ns1:LaRutinaAsociadaATEjecutaLaFuncionM06CambioDeHerramienta ;
    ns1:textoExtracto "la rutina asociada a T"@es .

ns1:T_01565545a9 a ns1:Herramienta ;
    ns1:identificador "T"@es ;
    ns1:textoExtracto "la nueva herramienta en la posición de trabajo"@es .

ns1:LaRutinaAsociadaATEjecutaLaFuncionM06CambioDeHerramienta a ns1:AccionProhibida ;
    ns1:textoExtracto "la rutina asociada a T ejecuta la función M06 (cambio de herramienta)"@es .

