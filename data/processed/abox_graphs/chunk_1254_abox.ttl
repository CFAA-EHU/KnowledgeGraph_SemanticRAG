@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlmacenTipoTorreta a ns1:Sistema ;
    rdfs:label "Almacén tipo torreta" ;
    ns1:textoExtracto "El gestor envía una orden al PLC para que seleccione la próxima herramienta en el almacén." .

ns1:BloqueM06 a ns1:ModoOperacion ;
    rdfs:label "Bloque M06" ;
    ns1:textoExtracto "El CNC ejecuta la función T y la subrutina el bloque M06." .

ns1:FuncionM06 a ns1:ModoOperacion ;
    rdfs:label "Función M06" ;
    ns1:textoExtracto "La rutina asociada a la función T ejecuta la función M06." .

ns1:FuncionT a ns1:ModoOperacion ;
    rdfs:label "Función T" ;
    ns1:textoExtracto "El CNC ejecuta la función T y la subrutina el bloque M06." .

ns1:GestorCambioHerramienta a ns1:Sistema ;
    rdfs:label "Gestor de cambio de herramienta" ;
    ns1:textoExtracto "El gestor envía una orden al PLC para que seleccione la próxima herramienta en el almacén." .

ns1:Herramienta a ns1:PiezaRecambio ;
    rdfs:label "Herramienta" ;
    ns1:textoExtracto "seleccione la próxima herramienta en el almacén" .

ns1:PLC a ns1:Sistema ;
    rdfs:label "PLC" ;
    ns1:textoExtracto "El gestor envía una orden al PLC para que seleccione la próxima herramienta en el almacén." .

ns1:SubrutinaAsociadaT a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina asociada a T" ;
    ns1:textoExtracto "Subrutina asociada a T." .

