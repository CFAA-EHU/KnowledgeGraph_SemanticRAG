@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:GestorPLC_994_1 a ns1:Personal ;
    rdfs:label "gestor"@es ;
    ns1:controla ns1:PLC_994_1 ;
    ns1:textoExtracto "El gestor envía una orden al PLC para efectuar el cambio."@es .

ns1:AlmacenTipoTorreta_e03f439551 a ns1:Sistema ;
    rdfs:label "almacén tipo torreta"@es ;
    ns1:textoExtracto "Herramientas de tierra en un almacén tipo torreta."@es ;
    ns1:tieneComponente ns1:BrazoCambiador_994_1,
        ns1:DesplazamientoAlmacen_994_2,
        ns1:GiroAlmacen_994_1,
        ns1:HerramientaDeTierra_88f3b7c91d .

ns1:BrazoCambiador_994_1 a ns1:ComponenteMecanico ;
    rdfs:label "brazo cambiador"@es ;
    ns1:controla ns1:Cabezal_994_1 ;
    ns1:textoExtracto "Utilizar funciones auxiliares para gobernar desde la rutina M06 los desplazamientos de los distintos dispositivos (giro almacén, desplazamiento almacén, brazo cambiador, etc.)."@es .

ns1:Cabezal_994_1 a ns1:ComponenteMecanico ;
    rdfs:label "cabezal"@es ;
    ns1:textoExtracto "La maniobra para cargar/descargar una herramienta en el cabezal (en la posición de trabajo) directamente o pasando por el cabezal es la misma."@es .

ns1:DesplazamientoAlmacen_994_2 a ns1:ComponenteMecanico ;
    rdfs:label "desplazamiento almacén"@es ;
    ns1:textoExtracto "Utilizar funciones auxiliares para gobernar desde la rutina M06 los desplazamientos de los distintos dispositivos (giro almacén, desplazamiento almacén, brazo cambiador, etc.)."@es .

ns1:GiroAlmacen_994_1 a ns1:ComponenteMecanico ;
    rdfs:label "giro almacén"@es ;
    ns1:textoExtracto "Utilizar funciones auxiliares para gobernar desde la rutina M06 los desplazamientos de los distintos dispositivos (giro almacén, desplazamiento almacén, brazo cambiador, etc.)."@es .

ns1:HerramientaDeTierra_88f3b7c91d a ns1:PiezaRecambio ;
    rdfs:label "herramienta de tierra"@es ;
    ns1:textoExtracto "Si en la posición de trabajo se encuentra una herramienta y se solicita otra que no se encuentra en la torreta, el CNC entiende que se trata de una herramienta de tierra."@es ;
    ns1:tieneComponente ns1:PosicionTrabajo_994_1 .

ns1:PLC_994_1 a ns1:ComponenteElectrico ;
    rdfs:label "PLC"@es ;
    ns1:controla ns1:ProgramaCNC_994_1 ;
    ns1:textoExtracto "El gestor envía una orden al PLC para efectuar el cambio."@es .

ns1:PosicionTrabajo_994_1 a ns1:Parametro ;
    rdfs:label "posición de trabajo"@es ;
    ns1:textoExtracto "Si en la posición de trabajo se encuentra una herramienta y se solicita otra que no se encuentra en la torreta, el CNC entiende que se trata de una herramienta de tierra."@es .

ns1:ProgramaCNC_994_1 a ns1:Sistema ;
    rdfs:label "CNC"@es ;
    ns1:ejecutadoPor ns1:RutinaM06_994_1 ;
    ns1:textoExtracto "El CNC espera a que el gestor de por finalizada la operación para continuar con la ejecución del programa."@es .

ns1:RutinaM06_994_1 a ns1:ModoOperacion ;
    rdfs:label "M06"@es ;
    ns1:controla ns1:AlmacenTipoTorreta_e03f439551 ;
    ns1:textoExtracto "Se aconseja incluir la gestión del cambio de herramienta en la rutina asociada a M06"@es .

