@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:cabezal_77_torreta a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de torreta"@es ;
    ns1:textoExtracto "La maniobra para cargar/descargar una herramienta en el cabezal (en la posición de trabajo) directamente o pasando por el cabezal..."@es .

ns1:herramienta_77_torreta a ns1:Herramienta ;
    rdfs:label "Herramienta de torreta"@es ;
    ns1:textoExtracto "cargar/descargar una herramienta en el cabezal"@es .

ns1:parametro_V_TM_MZMODE a ns1:Parametro ;
    rdfs:label "V.TM.MZMODE"@es ;
    ns1:identificador "V.TM.MZMODE" ;
    ns1:textoExtracto "la variable V.TM.MZMODE deberá tener el valor adecuado para realizar la carga o descarga"@es ;
    ns1:valor "valor adecuado para carga/descarga"@es .

ns1:posicion_trabajo_cabezal a ns1:ModoOperacion ;
    rdfs:label "Posición de trabajo del cabezal"@es ;
    ns1:textoExtracto "en la posición de trabajo"@es .

