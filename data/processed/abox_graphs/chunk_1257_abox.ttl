@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Entity0_6c5a58ce87 a ns1:ModoOperacion ;
    rdfs:label "0" ;
    ns1:textoExtracto "No hay que hacer nada." ;
    ns1:valor "0" .

ns1:Entity10_e48368f238 a ns1:ModoOperacion ;
    rdfs:label "10" ;
    ns1:textoExtracto "Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal." ;
    ns1:valor "10" .

ns1:Entity11_7f4a892ebe a ns1:ModoOperacion ;
    rdfs:label "11" ;
    ns1:textoExtracto "Orientar la torreta." ;
    ns1:valor "11" .

ns1:Entity15_ff10ecc5d8 a ns1:ModoOperacion ;
    rdfs:label "15" ;
    ns1:textoExtracto "Seleccionar una posición de la torreta." ;
    ns1:valor "15" .

ns1:Entity1_c87d73b6fb a ns1:ModoOperacion ;
    rdfs:label "1" ;
    ns1:textoExtracto "Asumir la herramienta actual como herramienta activa." ;
    ns1:valor "1" .

ns1:Entity3_2db3b4f0e0 a ns1:ModoOperacion ;
    rdfs:label "3" ;
    ns1:textoExtracto "Poner en el cabezal una herramienta de tierra." ;
    ns1:valor "3" .

ns1:Entity4_429e3e85ce a ns1:ModoOperacion ;
    rdfs:label "4" ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en tierra." ;
    ns1:valor "4" .

ns1:Entity9_8dc2f965d5 a ns1:ModoOperacion ;
    rdfs:label "9" ;
    ns1:textoExtracto "Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal." ;
    ns1:valor "9" .

ns1:Tabla_996_CasoEspecial a ns1:Tabla ;
    ns1:textoExtracto "El caso de TMOPERATION = 15 es un caso especial donde las señales TAKEPOS, LEAVEPOS y NEXTPOS pueden tomar los siguientes valores." ;
    ns1:tieneComponente ns1:LEAVEPOS_0,
        ns1:LEAVEPOS_1,
        ns1:NEXTPOS,
        ns1:TAKEPOS_0,
        ns1:TAKEPOS_1 .

ns1:Tabla_996_Resumen a ns1:Tabla ;
    ns1:textoExtracto "A continuación se muestra una tabla resumen de los valores TAKEPOS y LEAVEPOS que utiliza el gestor en cada una de las operaciones, así como las marcas que debe activar el PLC al finalizar cada operación." .

ns1:Tabla_996_ValoresRegistros a ns1:Tabla ;
    ns1:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor. Las señales TAKEPOS y LEAVEPOS pueden tomar los siguientes valores." ;
    ns1:tieneComponente ns1:LEAVEPOS_0,
        ns1:LEAVEPOS_1,
        ns1:TAKEPOS_0,
        ns1:TAKEPOS_1 .

ns1:NEXTPOS a ns1:Parametro ;
    rdfs:label "NEXTPOS" ;
    ns1:textoExtracto "En un posicionamiento absoluto este registro indica la posición a alcanzar y en un posicionamiento relativo indica el número de posiciones a girar." .

ns1:LEAVEPOS_0 a ns1:Parametro ;
    rdfs:label "LEAVEPOS" ;
    ns1:textoExtracto "Este registro tomará valor ꞏ0ꞏ si es un posicionamiento relativo positivo y valor ꞏ1ꞏ si es un posicionamiento relativo negativo." ;
    ns1:valor "0" .

ns1:LEAVEPOS_1 a ns1:Parametro ;
    rdfs:label "LEAVEPOS" ;
    ns1:textoExtracto "Este registro tomará valor ꞏ0ꞏ si es un posicionamiento relativo positivo y valor ꞏ1ꞏ si es un posicionamiento relativo negativo." ;
    ns1:valor "1" .

ns1:TAKEPOS_0 a ns1:Parametro ;
    rdfs:label "TAKEPOS" ;
    ns1:textoExtracto "Este registro tomará valor ꞏ0ꞏ si es un posicionamiento absoluto y valor ꞏ1ꞏ si es un posicionamiento relativo." ;
    ns1:valor "0" .

ns1:TAKEPOS_1 a ns1:Parametro ;
    rdfs:label "TAKEPOS" ;
    ns1:textoExtracto "Este registro tomará valor ꞏ0ꞏ si es un posicionamiento absoluto y valor ꞏ1ꞏ si es un posicionamiento relativo." ;
    ns1:valor "1" .

