@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlmacenNoRandom a ns1:Sistema ;
    rdfs:label "almacén no-random"@es ;
    ns1:compuestoPor ns1:T7_a9fbcfea4c ;
    ns1:textoExtracto "El almacén es no-random, cada herramienta ocupa la posición de su mismo número y la herramienta T7 es de tierra."@es .

ns1:T7_a9fbcfea4c a ns1:Herramienta ;
    rdfs:label "T7"@es ;
    ns1:identificador "T7" ;
    ns1:textoExtracto "la herramienta T7 es de tierra"@es .

