@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LEAVEPOS a ns1:Sensor ;
    rdfs:label "LEAVEPOS" ;
    ns1:textoExtracto "señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas" .

ns1:MZID a ns1:Sensor ;
    rdfs:label "MZID" ;
    ns1:textoExtracto "señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas" .

ns1:NEXTPOS a ns1:Sensor ;
    rdfs:label "NEXTPOS" ;
    ns1:textoExtracto "señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas" .

ns1:TAKEPOS a ns1:Sensor ;
    rdfs:label "TAKEPOS" ;
    ns1:textoExtracto "señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas" .

