@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Almacen a ns1:Sistema ;
    rdfs:label "almacén" ;
    ns1:textoExtracto "Posición en el almacén." .

ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "cabezal" ;
    ns1:textoExtracto "Poner en el cabezal una herramienta de tierra." .

ns1:HerramientaDeTierra_6e1d40f50a a ns1:ComponenteElectrico ;
    rdfs:label "Herramienta de tierra" ;
    ns1:textoExtracto "Herramienta de tierra." .

ns1:MarcaGRTOSPDL a ns1:Parametro ;
    rdfs:label "GRTOSPDL" ;
    ns1:textoExtracto "activar la marca GRTOSPDL" .

ns1:MarcaMZROT a ns1:Parametro ;
    rdfs:label "MZROT" ;
    ns1:textoExtracto "activar la marca MZROT" .

ns1:MarcaMZTOSPDL a ns1:Parametro ;
    rdfs:label "MZTOSPDL" ;
    ns1:textoExtracto "activar la marca MZTOSPDL" .

ns1:MarcaSPDLTOGR a ns1:Parametro ;
    rdfs:label "SPDLTOGR" ;
    ns1:textoExtracto "activar la marca SPDLTOGR" .

ns1:TMOPERATION10_4830b0c17b a ns1:ModoOperacion ;
    ns1:identificador "TMOPERATION = 10" ;
    ns1:textoExtracto "Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal. TAKEPOS Posición del almacén para coger la herramienta. LEAVEPOS Herramienta de tierra." .

ns1:TMOPERATION11_6414eda96d a ns1:ModoOperacion ;
    ns1:identificador "TMOPERATION = 11" ;
    ns1:textoExtracto "Orientar el almacén." .

ns1:TMOPERATION15_4bac49f666 a ns1:ModoOperacion ;
    ns1:identificador "TMOPERATION = 15" ;
    ns1:textoExtracto "Seleccionar una posición del almacén. TAKEPOS Este registro tomará valor ꞏ0ꞏ si es un posicionamiento absoluto y valor ꞏ1ꞏ si es un posicionamiento relativo." .

ns1:TMOPERATION1_9dcd4d10f0 a ns1:ModoOperacion ;
    ns1:identificador "TMOPERATION = 1" ;
    ns1:textoExtracto "Asumir la herramienta actual como herramienta activa." .

ns1:TMOPERATION3_fa25b3c4f6 a ns1:ModoOperacion ;
    ns1:identificador "TMOPERATION = 3" ;
    ns1:textoExtracto "Poner en el cabezal una herramienta de tierra." .

ns1:TMOPERATION4_fbece5fcef a ns1:ModoOperacion ;
    ns1:identificador "TMOPERATION = 4" ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en tierra." .

ns1:TMOPERATION9_280ffe1db0 a ns1:ModoOperacion ;
    ns1:identificador "TMOPERATION = 9" ;
    ns1:textoExtracto "Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal. TAKEPOS Herramienta de tierra. LEAVEPOS Posición del almacén para dejar la herramienta." .

