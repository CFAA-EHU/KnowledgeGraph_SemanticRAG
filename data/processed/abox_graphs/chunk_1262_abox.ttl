@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:ActivarLaMarcaMZROT a ns1:Sensor ;
    ns1:textoExtracto "activar la marca MZROT" .

ns1:LEAVEPOSEsteRegistroTomaraValor0SiEsUnPosicionamientoRelativoPositivoYValor1SiEsUnPosicionamientoRelativoNegativo a ns1:Parametro ;
    ns1:textoExtracto "LEAVEPOS Este registro tomará valor ꞏ0ꞏ si es un posicionamiento relativo positivo y valor ꞏ1ꞏ si es un posicionamiento relativo negativo." .

ns1:NEXTPOSEnUnPosicionamientoAbsolutoEsteRegistroIndicaLaPosicionAAlcanzarYEnUnPosicionamientoRelativoIndicaElNumeroDePosicionesAGirar a ns1:Parametro ;
    ns1:textoExtracto "NEXTPOS En un posicionamiento absoluto este registro indica la posición a alcanzar y en un posicionamiento relativo indica el número de posiciones a girar." .

ns1:TAKEPOSEsteRegistroTomaraValor0SiEsUnPosicionamientoAbsolutoYValor1SiEsUnPosicionamientoRelativo a ns1:Parametro ;
    ns1:textoExtracto "TAKEPOS Este registro tomará valor ꞏ0ꞏ si es un posicionamiento absoluto y valor ꞏ1ꞏ si es un posicionamiento relativo." .

ns1:TMOPERATION15_b908f25b4c a ns1:Parametro ;
    ns1:textoExtracto "TMOPERATION = 15" .

