@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlmacenDeHerramientas_813a389640 a ns1:Sistema ;
    rdfs:label "Almacén de herramientas" ;
    ns1:textoExtracto "Coger la herramienta del almacén y ponerla en el cabezal" .

ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "Colocar la herramienta de tierra en el cabezal" .

ns1:HerramientaDeTierra_bc9e2396ff a ns1:PiezaRecambio ;
    rdfs:label "Herramienta de tierra" ;
    ns1:textoExtracto "Quitar la herramienta del cabezal (llevarla a tierra)" .

ns1:HerramientaT a ns1:PiezaRecambio ;
    rdfs:label "Herramienta T" ;
    ns1:textoExtracto "Extraer herramienta T%D y pulsar MARCHA" .

ns1:ProgramaM06 a ns1:TareaMantenimiento ;
    rdfs:label "Rutina M06" ;
    ns1:textoExtracto "Programa de la rutina M06" .

ns1:PuntoCambioAutomatico a ns1:ModoOperacion ;
    rdfs:label "Punto de cambio automático" ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio automático" .

ns1:PuntoCambioManual a ns1:ModoOperacion ;
    rdfs:label "Punto de cambio manual" ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio manual" .

ns1:SubrutinaGR_TO_SPD a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina GR_TO_SPD" ;
    ns1:textoExtracto "%L SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal" .

ns1:SubrutinaMZROT a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina MZROT" ;
    ns1:textoExtracto "%L SUB_MZ_ROT V.PLC.M[1111]=1 #WAIT FOR [V.PLC.M[1111]==0]; Marca MZROT al gestor" .

ns1:SubrutinaMZ_TO_SPD a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina MZ_TO_SPD" ;
    ns1:textoExtracto "%L SUB_MZ_TO_SPD ; Coger la herramienta del almacén y ponerla en el cabezal" .

ns1:SubrutinaSPD_AUTCHG a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina SPD_AUTCHG" ;
    ns1:textoExtracto "%L SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático" .

ns1:SubrutinaSPD_GMCHG a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina SPD_GMCHG" ;
    ns1:textoExtracto "%L SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual" .

ns1:SubrutinaSPD_TO_GR a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina SPD_TO_GR" ;
    ns1:textoExtracto "%L SUB_SPD_TO_GR ; Quitar la herramienta del cabezal (llevarla a tierra)" .

ns1:SubrutinaSPD_TO_MZ a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina SPD_TO_MZ" ;
    ns1:textoExtracto "%L SUB_SPD_TO_MZ ; Dejar la herramienta del cabezal en el almacén" .

