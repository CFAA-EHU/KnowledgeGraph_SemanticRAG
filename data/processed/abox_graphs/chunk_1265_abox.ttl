@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:OperacionTipo1 a ns1:ModoOperacion ;
    rdfs:label "Operación tipo 1 (Herramienta activa)" ;
    ns1:textoExtracto "$CASE 1 ; Asumir la herramienta actual como herramienta activa." .

ns1:OperacionTipo3 a ns1:ModoOperacion ;
    rdfs:label "Operación tipo 3 (Colocación de herramienta)" ;
    ns1:textoExtracto "$CASE 3 ; Colocar la herramienta" .

ns1:RutinaM06_CambioHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Rutina M06 (Cambio de herramienta)" ;
    ns1:identificador "M06" ;
    ns1:requiereMantenimiento ns1:CabezalMaquina ;
    ns1:textoExtracto "G1 Z_ F_ ; Desplazar el cabezal. # RET %L SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático. [...] M6 ; Orden al gestor para comenzar el cambio de herramienta." .

ns1:SistemaControlCNC a ns1:Sistema ;
    rdfs:label "Sistema de control CNC" ;
    ns1:controla ns1:CabezalMaquina ;
    ns1:monitoreaParametro ns1:ParametroEjecucion ;
    ns1:textoExtracto "$IF [[V.G.FULLSTATUS & 255]<9] | [[V.G.FULLSTATUS & 255]>13]] [...] V.S.EXECUTION = 1 ; Ejecución" .

ns1:TeclaSTOP a ns1:InterfazUsuario ;
    rdfs:label "Tecla STOP" ;
    ns1:textoExtracto "#DSTOP ; Deshabilitar tecla STOP" .

ns1:ParametroEjecucion a ns1:Parametro ;
    rdfs:label "Estado de ejecución (V.S.EXECUTION)" ;
    ns1:textoExtracto "V.S.EXECUTION = 0 ; Ejecución simulada [...] V.S.EXECUTION = 1 ; Ejecución" ;
    ns1:valor "0,1" .

ns1:CabezalMaquina a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "G1 Z_ F_ ; Desplazar el cabezal. [...] Llevar el cabezal al punto de cambio automático." .

