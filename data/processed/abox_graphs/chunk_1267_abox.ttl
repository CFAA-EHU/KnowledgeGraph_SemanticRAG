@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Almacen_ef5c7d8896 a ns1:Sistema ;
    rdfs:label "Almacén" ;
    ns1:compuestoPor ns1:CabezalM06,
        ns1:Herramienta_d27853ed98 ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en el almacén." .

ns1:GestorAlmacen a ns1:Sistema ;
    rdfs:label "gestor del almacén" ;
    ns1:textoExtracto "Espera al gestor del almacén" .

ns1:PuntoCambioAutomatico a ns1:ModoOperacion ;
    rdfs:label "punto de cambio automático" ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio automático" .

ns1:TeclaSTOP a ns1:InterfazUsuario ;
    rdfs:label "tecla STOP" ;
    ns1:textoExtracto "Habilitar la tecla STOP" .

ns1:CabezalM06 a ns1:ComponenteMecanico ;
    rdfs:label "cabezal" ;
    ns1:textoExtracto "herramienta del cabezal" .

ns1:Herramienta_d27853ed98 a ns1:PiezaRecambio ;
    rdfs:label "herramienta" ;
    ns1:textoExtracto "herramienta del cabezal" .

