@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FuncionTTMOPERATION11_a63429d3de a ns1:ModoOperacion ;
    rdfs:label "Función T (TMOPERATION=11)" ;
    ns1:controla ns1:MarcaMZROT ;
    ns1:identificador "TMOPERATION=11" ;
    ns1:textoExtracto "Cuando se ejecuta la función T el gestor envía al PLC el código TMOPERATION=11. En general es una optimización del cambio que permite orientar el almacén durante el mecanizado." .

ns1:OperacionCambioHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Operación de cambio de herramienta (M06)" ;
    ns1:ejecutadoPor ns1:FuncionM06CambioDeHerramienta_8485775f3c ;
    ns1:requiereConsumible ns1:HerramientaGenericaCabezalAlmacenTierra_ad3d9e5c3f ;
    ns1:textoExtracto "optimización del cambio que permite orientar el almacén durante el mecanizado" .

ns1:FuncionM06CambioDeHerramienta_8485775f3c a ns1:ModoOperacion ;
    rdfs:label "Función M06 (cambio de herramienta)" ;
    ns1:controla ns1:MarcaGRTOSPDL,
        ns1:MarcaMZTOSPDL,
        ns1:MarcaSPDLTOGR ;
    ns1:identificador "M06" ;
    ns1:textoExtracto "Cada vez que la rutina M06 finaliza una acción se lo indica al PLC para que active la marca correspondiente del gestor." .

ns1:HerramientaGenericaCabezalAlmacenTierra_ad3d9e5c3f a ns1:Herramienta ;
    rdfs:label "Herramienta genérica (cabezal/almacén/tierra)" ;
    ns1:textoExtracto "La herramienta se ha llevado del cabezal a tierra / de tierra al cabezal / del almacén al cabezal." .

ns1:MarcaGRTOSPDL a ns1:InterfazUsuario ;
    rdfs:label "Marca GRTOSPDL" ;
    ns1:identificador "GRTOSPDL" ;
    ns1:textoExtracto "La herramienta se ha llevado de tierra al cabezal." .

ns1:MarcaMZROT a ns1:InterfazUsuario ;
    rdfs:label "Marca MZROT" ;
    ns1:identificador "MZROT" ;
    ns1:textoExtracto "Activar la marca MZROT para indicar al gestor que se ha finalizado la operación." .

ns1:MarcaMZTOSPDL a ns1:InterfazUsuario ;
    rdfs:label "Marca MZTOSPDL" ;
    ns1:identificador "MZTOSPDL" ;
    ns1:textoExtracto "La herramienta se ha llevado del almacén al cabezal." .

ns1:MarcaSPDLTOGR a ns1:InterfazUsuario ;
    rdfs:label "Marca SPDLTOGR" ;
    ns1:identificador "SPDLTOGR" ;
    ns1:textoExtracto "La herramienta se ha llevado del cabezal a tierra." .

