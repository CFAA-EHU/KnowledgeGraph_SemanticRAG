@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Rutina_M06 a ns1:ModoOperacion ;
    rdfs:label "Rutina de cambio automático de herramienta" ;
    ns1:compuestoPor ns1:FuncionAuxiliar_M109,
        ns1:FuncionAuxiliar_M110,
        ns1:FuncionAuxiliar_M1110,
        ns1:FuncionAuxiliar_M1111 ;
    ns1:identificador "M06" ;
    ns1:monitoreaParametro ns1:Registro_LEAVEPOS,
        ns1:Registro_TAKEPOS ;
    ns1:textoExtracto "La rutina M06 utiliza las siguientes funciones auxiliares M para indicar al PLC qué movimientos debe realizar." .

ns1:Se_alEmergencia_Gestor a ns1:AvisoSeguridad ;
    rdfs:label "Señal de emergencia del gestor" ;
    ns1:textoExtracto "Señal de emergencia del gestor." .

ns1:FuncionAuxiliar_M109 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Seleccionar posición TAKEPOS y cargar herramienta en cabezal" ;
    ns1:identificador "M109" ;
    ns1:textoExtracto "M109 Seleccionar en el almacén la posición que indica TAKEPOS y poner la herramienta en el cabezal." .

ns1:FuncionAuxiliar_M110 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Seleccionar posición LEAVEPOS y descargar herramienta del cabezal" ;
    ns1:identificador "M110" ;
    ns1:textoExtracto "M110 Seleccionar en el almacén la posición que indica LEAVEPOS y dejar la herramienta del cabezal." .

ns1:FuncionAuxiliar_M1110 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Transferencia de herramienta (cabezal → almacén)" ;
    ns1:identificador "M1110" ;
    ns1:textoExtracto "DFU M1110 = SET SPDLTOGR DFD SPDLTOGR = RES M1110 La herramienta se ha llevado del cabezal al almacén." .

ns1:FuncionAuxiliar_M1111 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Giro del almacén de herramientas" ;
    ns1:identificador "M1111" ;
    ns1:textoExtracto "DFU M1111 = SET MZROT DFD MZROT = RES M1111 Ya ha girado el almacén." .

ns1:Registro_LEAVEPOS a ns1:Parametro ;
    rdfs:label "Registro LEAVEPOS" ;
    ns1:textoExtracto "LEAVEPOS Este registro indica la posición de almacén en la que hay que dejar la herramienta." ;
    ns1:valor "posición_de_almacén_para_dejar_herramienta" .

ns1:Registro_TAKEPOS a ns1:Parametro ;
    rdfs:label "Registro TAKEPOS" ;
    ns1:textoExtracto "TAKEPOS Este registro indica la posición de almacén que ocupa la herramienta que hay que coger." ;
    ns1:valor "posición_de_almacén_para_tomar_herramienta" .

