@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Grafcet a owl:Class ;
    rdfs:label "Grafcet"@es ;
    rdfs:comment "Representación gráfica de un sistema secuencial." .

ex:ListaDeArticulos a owl:Class ;
    rdfs:label "Lista de artículos"@es ;
    rdfs:comment "Lista de artículos utilizados en el sistema." .

ex:PartListSumariced a owl:Class ;
    rdfs:label "Part List Sumariced"@es ;
    rdfs:comment "Lista detallada de partes y componentes." .

ex:ResumenDeRegletaDeBornes a owl:Class ;
    rdfs:label "Resumen de regleta de bornes"@es ;
    rdfs:comment "Resumen de la regleta de bornes." .

ex:PlanoDeBornes a owl:Class ;
    rdfs:label "Plano de bornes"@es ;
    rdfs:comment "Plano que muestra la disposición de los bornes." .

ex:EsquemaHidraulico a owl:Class ;
    rdfs:label "Esquema hidráulico"@es ;
    rdfs:comment "Esquema del sistema hidráulico." .

ex:PneumaticScheme a owl:Class ;
    rdfs:label "Pneumatic Scheme"@es ;
    rdfs:comment "Esquema del sistema neumático." .

ex:EsquemaDeRefrigeracion a owl:Class ;
    rdfs:label "Esquema de refrigeración"@es ;
    rdfs:comment "Esquema del sistema de refrigeración." .

ex:LubricationScheme a owl:Class ;
    rdfs:label "Lubrication Scheme"@es ;
    rdfs:comment "Esquema del sistema de lubricación." .

ex:ListaDeArticulosNeumatico a owl:Class ;
    rdfs:label "Lista de artículos neumático"@es ;
    rdfs:comment "Lista de artículos relacionados con el sistema neumático." .

ex:ListaDeArticulosRefrigerante a owl:Class ;
    rdfs:label "Lista de artículos refrigerante"@es ;
    rdfs:comment "Lista de artículos relacionados con el sistema de refrigeración." .

ex:ListaDeArticulosEngrase a owl:Class ;
    rdfs:label "Lista de artículos engrase"@es ;
    rdfs:comment "Lista de artículos relacionados con el sistema de engrase." .