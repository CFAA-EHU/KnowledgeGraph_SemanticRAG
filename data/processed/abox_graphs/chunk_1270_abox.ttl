@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Lampara_USER12 a ns1:InterfazUsuario ;
    rdfs:label "Lámpara de la tecla USER12" ;
    ns1:identificador "B11KEYLED1" ;
    ns1:textoExtracto "Lámpara de la tecla USER12 iluminada cuando hay" .

ns1:Registro_TAKEPOS a ns1:Parametro ;
    rdfs:label "Registro TAKEPOS" ;
    ns1:identificador "TAKEPOS" ;
    ns1:textoExtracto "TAKEPOS Este registro indica la posición de almacén que ocupa la herramienta que hay que coger." .

ns1:Tecla_USER12 a ns1:InterfazUsuario ;
    rdfs:label "Tecla USER12" ;
    ns1:activaAlarma ns1:SenalEmergencia_GestorHerramientas ;
    ns1:identificador "USER12" ;
    ns1:textoExtracto "Si se pulsa la tecla USER12 se activa la emergencia." .

ns1:SenalEmergencia_GestorHerramientas a ns1:Alarma ;
    rdfs:label "Señal de emergencia del gestor de herramientas" ;
    ns1:textoExtracto "Señal de emergencia del gestor. Tratamiento de la señal de emergencia del gestor de herramientas." .

