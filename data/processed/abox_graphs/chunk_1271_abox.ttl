@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LamparaTecla_USER12 a ns1:ComponenteElectrico ;
    rdfs:label "Lámpara de la tecla USER12" ;
    ns1:monitoreaParametro ns1:AlarmaEmergencia ;
    ns1:textoExtracto "Lámpara de la tecla USER12 iluminada cuando hay emergencia." .

ns1:Tecla_USER12 a ns1:ComponenteElectrico ;
    rdfs:label "Tecla USER12" ;
    ns1:activaAlarma ns1:AlarmaEmergencia ;
    ns1:textoExtracto "Si se pulsa la tecla USER12 se activa la emergencia." .

ns1:Tecla_USER13 a ns1:ComponenteElectrico ;
    rdfs:label "Tecla USER13" ;
    ns1:textoExtracto "Si se pulsa la tecla USER13 se quita la emergencia." .

ns1:AlarmaEmergencia a ns1:Alarma ;
    rdfs:label "Emergencia" ;
    ns1:textoExtracto "Si se pulsa la tecla USER12 se activa la emergencia. [...] Si se pulsa la tecla USER13 se quita la emergencia." .

