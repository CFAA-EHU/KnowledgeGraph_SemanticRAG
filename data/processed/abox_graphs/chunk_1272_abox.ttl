@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlmacenSincronoSinBrazoCambiador_2b6805a837 a ns1:Sistema ;
    rdfs:label "Almacén síncrono sin brazo cambiador" ;
    ns1:compuestoPor ns1:Almacen_f6715b45a8,
        ns1:Cabezal_1011_492 ;
    ns1:textoExtracto "En un almacén síncrono sin brazo cambiador el almacén debe desplazarse hasta el cabezal para efectuar el cambio." ;
    ns1:tieneComponente ns1:CNC_1011_492,
        ns1:PLC_1011_492 .

ns1:Almacen_f6715b45a8 a ns1:ComponenteMecanico ;
    rdfs:label "Almacén" ;
    ns1:textoExtracto "el almacén debe desplazarse hasta el cabezal para efectuar el cambio" .

ns1:CNC_1011_492 a ns1:ComponenteElectrico ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "Cuando el CNC ejecuta la función T, se lo indica al gestor" .

ns1:Cabezal_1011_492 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "el almacén debe desplazarse hasta el cabezal para efectuar el cambio" .

ns1:PLC_1011_492 a ns1:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ns1:textoExtracto "La comunicación entre el gestor y el PLC se realiza en 2 fases" .

