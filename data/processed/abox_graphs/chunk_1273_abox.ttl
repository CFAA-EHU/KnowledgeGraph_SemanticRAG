@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Entity0_fdee00c036 a ns1:ModoOperacion ;
    rdfs:label "0" ;
    ns1:textoExtracto "0 | No hay que hacer nada." .

ns1:Entity10_d49ab8b9d4 a ns1:ModoOperacion ;
    rdfs:label "10" ;
    ns1:textoExtracto "10 | Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal." .

ns1:Entity11_6dff16ca7d a ns1:ModoOperacion ;
    rdfs:label "11" ;
    ns1:textoExtracto "11 | Orientar el almacén." .

ns1:Entity12_c6cc787897 a ns1:ModoOperacion ;
    rdfs:label "12" ;
    ns1:textoExtracto "12 | Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén (como TMOPERATION=5). Es una operación optimizada, válida sólo cuando el almacén es random y la herramienta es especial." .

ns1:Entity13_0fd70815b4 a ns1:ModoOperacion ;
    rdfs:label "13" ;
    ns1:textoExtracto "13 | Orientar dos almacenes." .

ns1:Entity14_098cf9f127 a ns1:ModoOperacion ;
    rdfs:label "14" ;
    ns1:textoExtracto "14 | Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén." .

ns1:Entity1_67088f5a34 a ns1:ModoOperacion ;
    rdfs:label "1" ;
    ns1:textoExtracto "1 | Coger una herramienta del almacén y ponerla en el cabezal." .

ns1:Entity2_637dbee8e9 a ns1:ModoOperacion ;
    rdfs:label "2" ;
    ns1:textoExtracto "2 | Dejar la herramienta del cabezal en el almacén." .

ns1:Entity3_5114e32500 a ns1:ModoOperacion ;
    rdfs:label "3" ;
    ns1:textoExtracto "3 | Poner en el cabezal una herramienta de tierra." .

ns1:Entity4_b21aefb08b a ns1:ModoOperacion ;
    rdfs:label "4" ;
    ns1:textoExtracto "4 | Dejar la herramienta del cabezal en tierra." .

ns1:Entity5_6182589611 a ns1:ModoOperacion ;
    rdfs:label "5" ;
    ns1:textoExtracto "5 | Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén." .

ns1:Entity6_62c8bc5db2 a ns1:ModoOperacion ;
    rdfs:label "6" ;
    ns1:textoExtracto "6 | Dejar la herramienta del cabezal en el almacén y coger una herramienta de tierra." .

ns1:Entity7_4d783f44d0 a ns1:ModoOperacion ;
    rdfs:label "7" ;
    ns1:textoExtracto "7 | Dejar la herramienta del cabezal en tierra y coger una herramienta del almacén." .

ns1:Entity8_64ecf82032 a ns1:ModoOperacion ;
    rdfs:label "8" ;
    ns1:textoExtracto "8 | Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra." .

ns1:Entity9_82673fa6b6 a ns1:ModoOperacion ;
    rdfs:label "9" ;
    ns1:textoExtracto "9 | Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal." .

ns1:GestorHerramientasAlmacen a ns1:Sistema ;
    ns1:textoExtracto "Operaciones válidas del gestor de herramientas para este almacén. Las operaciones posibles en este tipo de almacén son las siguientes." ;
    ns1:tieneComponente ns1:Almacen_63e4f95a13,
        ns1:Cabezal_be0ce77e20,
        ns1:HerramientaDeTierra_4bac376cfd .

ns1:TAKEPOS_0 a ns1:Parametro ;
    rdfs:label "0" ;
    ns1:textoExtracto "0 | No hay que hacer nada." .

ns1:TAKEPOS_Valor a ns1:Parametro ;
    rdfs:label "#" ;
    ns1:textoExtracto "# | Posición en el almacén." .

ns1:Almacen_63e4f95a13 a ns1:Componente ;
    ns1:textoExtracto "almacén" .

ns1:Cabezal_be0ce77e20 a ns1:Componente ;
    ns1:textoExtracto "cabezal" .

ns1:HerramientaDeTierra_4bac376cfd a ns1:Componente ;
    ns1:textoExtracto "herramienta de tierra" .

