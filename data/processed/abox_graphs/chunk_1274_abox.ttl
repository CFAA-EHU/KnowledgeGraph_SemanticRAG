ns1:HerramientaDeTierra_6e1d40f50a a ns1:ComponenteElectrico ;
    rdfs:label "Herramienta de tierra" ;
    ns1:textoExtracto "Herramienta de tierra" .

ns1:LEAVEPOS a ns1:Parametro ;
    rdfs:label "LEAVEPOS" ;
    ns1:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor." ;
    ns1:valor "0, #, -4" .

ns1:LasMarcasQueDebeActivarElPLCAlFinalizarCadaOperacion a ns1:Actuador ;
    ns1:textoExtracto "las marcas que debe activar el PLC al finalizar cada operación" .

ns1:LasOperaciones a ns1:TareaMantenimiento ;
    ns1:textoExtracto "las operaciones" .

ns1:PosicionEnElAlmacen a ns1:Componente ;
    ns1:textoExtracto "Posición en el almacén" .

ns1:TAKEPOS a ns1:Parametro ;
    rdfs:label "TAKEPOS" ;
    ns1:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor." ;
    ns1:valor "0, #, -4" .

ns1:Tabla_7_8_1 a ns1:Tabla ;
    ns1:textoExtracto "A continuación se muestra una tabla resumen de los valores TAKEPOS y LEAVEPOS que utiliza el gestor en cada una de las operaciones, así como las marcas que debe activar el PLC al finalizar cada operación." .

ns1:ValoresDeLosRegistrosTAKEPOSYLEAVEPOSUtilizadosPorElGestor a ns1:Sistema ;
