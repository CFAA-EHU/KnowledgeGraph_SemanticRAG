@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:AContinuacionSeMuestraUnaDescripcionDetalladaDeLasOperacionesValidasParaEsteAlmacen a ns1:Sistema ;
    ns1:compuestoPor ns1:SenalesTAKEPOSLEAVEPOSNEXTPOSYMZIDEstanImplicadas ;
    ns1:textoExtracto "A continuación se muestra una descripción detallada de las operaciones válidas para este almacén." .

ns1:SenalesTAKEPOSLEAVEPOSNEXTPOSYMZIDEstanImplicadas a ns1:Sensor ;
    ns1:textoExtracto "señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas" .

