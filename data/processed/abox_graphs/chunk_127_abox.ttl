@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rittal: <http://www.rittal.com/> .
@prefix phoenix: <http://www.phoenixcontact.com/> .
@prefix ifm: <http://www.ifm.com/> .
@prefix secomea: <http://www.secomea.com/> .

owl:Ontology rdfs:comment "Modelo conceptual para planos mecánicos, esquemas de fluidos y esquemas eléctricos." .

ex:AcopladorDelBus a owl:Class ;
    rdfs:label "Acoplador del bus" ;
    rdfs:comment "Componente utilizado para la comunicación en el sistema." .

ex:IndustrialWiFiRouter a owl:Class ;
    rdfs:label "Industrial WiFi Router 1149" ;
    rdfs:comment "Router utilizado para comunicación a distancia (teleservice)." .

ex:ModuloInline a owl:Class ;
    rdfs:label "Módulo Inline" ;
    rdfs:comment "Módulo utilizado en el sistema de comunicación." .

ex:VXBayingEnclosureSystem a owl:Class ;
    rdfs:label "VX Baying enclosure system" ;
    rdfs:comment "Sistema de armario de bayas VX con dimensiones WHD: 1200x1800x500 mm y dos puertas." .

ex:VXSidePanel a owl:Class ;
    rdfs:label "VX Side panel" ;
    rdfs:comment "Panel lateral VX atornillado para HD: 1800x500 mm." .

ex:PortaEsquemasMetalico a owl:Class ;
    rdfs:label "SZ PORTAESQUEMAS METALICO 600MM RAL7035" ;
    rdfs:comment "Portaesquemas metálico de 600 mm de ancho, color RAL7035." .

ex:PSUtilityLectern a owl:Class ;
    rdfs:label "PS Utility lectern" ;
    rdfs:comment "Atril de utilidad PS para TS, SE, CM, PC, para ancho de puerta de 600 mm." .

ex:BasePlinthComponents a owl:Class ;
    rdfs:label "Base/plinth components" ;
    rdfs:comment "Componentes de base/plinto frontales y traseros, altura de 200 mm." .

ex:TrimPanel a owl:Class ;
    rdfs:label "TS Trim panel" ;
    rdfs:comment "Panel de recorte TS para lados, altura de 200 mm, para ancho de 500 mm, color RAL 7022, chapa de acero." .

ex:JuegoDeEscobillas a owl:Class ;
    rdfs:label "Juego de escobillas" ;
    rdfs:comment "Juego de escobillas utilizado en el sistema." .

ex:CaudalimetroMecatronico a owl:Class ;
    rdfs:label "Caudalímetro mecatrónico" ;
    rdfs:comment "Caudalímetro mecatrónico utilizado en el sistema." .

ex:tieneDesignacion a owl:ObjectProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range rdfs:Literal .

ex:tieneUtilizacion a owl:ObjectProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range rdfs:Literal .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range rdfs:Literal .

ex:tieneReferencias a owl:ObjectProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range rdfs:Literal .

ex:tieneCantidad a owl:ObjectProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range rdfs:Literal .

ex:tieneModelo a owl:ObjectProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range rdfs:Literal .

ex:Componente a owl:Class ;
    rdfs:label "Componente" ;
    rdfs:comment "Clase base para todos los componentes del sistema." .

phoenix:IL_EC_BK_PAC a owl:NamedIndividual ,
                    ex:AcopladorDelBus ;
    ex:tieneDesignacion "Acoplador del bus" ;
    ex:tieneFabricante "PHOENIX CONTACT" ;
    ex:tieneReferencias "IL EC BK-PAC" ;
    ex:tieneCantidad "1" .

