@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Almacen a ns1:Sistema ;
    rdfs:label "almacén"@es ;
    ns1:textoExtracto "Poner la herramienta del almacén en el cabezal"@es .

ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "cabezal"@es ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en tierra"@es .

ns1:HerramientaDeTierra_63d158bff7 a ns1:Herramienta ;
    rdfs:label "herramienta de tierra"@es ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra."@es .

ns1:HerramientaDelAlmacen_fe6f0468b8 a ns1:Herramienta ;
    rdfs:label "herramienta del almacén"@es ;
    ns1:textoExtracto "Poner la herramienta del almacén en el cabezal y activar la marca MZTOSPDL."@es .

ns1:HerramientaDelCabezal_8dc9b5510b a ns1:Herramienta ;
    rdfs:label "herramienta del cabezal"@es ;
    ns1:textoExtracto "La secuencia de esta operación es la siguiente. 1 Dejar la herramienta del cabezal en tierra y activar la marca SPDLTOGR."@es .

ns1:MarcaGRTOSPDL a ns1:Parametro ;
    rdfs:label "GRTOSPDL"@es ;
    ns1:textoExtracto "activar la marca GRTOSPDL"@es .

ns1:MarcaMZROT a ns1:Parametro ;
    rdfs:label "MZROT"@es ;
    ns1:textoExtracto "Activar la marca MZROT para indicar que ha finalizado la operación"@es .

ns1:MarcaMZTOSPDL a ns1:Parametro ;
    rdfs:label "MZTOSPDL"@es ;
    ns1:textoExtracto "activar la marca MZTOSPDL"@es .

ns1:MarcaSPDLTOGR a ns1:Parametro ;
    rdfs:label "SPDLTOGR"@es ;
    ns1:textoExtracto "activar la marca SPDLTOGR"@es .

ns1:MarcaSPDLTOMZ a ns1:Parametro ;
    rdfs:label "SPDLTOMZ"@es ;
    ns1:textoExtracto "activar la marca SPDLTOMZ"@es .

ns1:TMOPERATION10_0bf9fa835d a ns1:TareaMantenimiento ;
    rdfs:label "TMOPERATION = 10"@es ;
    ns1:textoExtracto "TMOPERATION = 10 Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal."@es .

ns1:TMOPERATION11_7453fed50f a ns1:TareaMantenimiento ;
    rdfs:label "TMOPERATION = 11"@es ;
    ns1:textoExtracto "TMOPERATION = 11 Orientar el almacén."@es .

ns1:TMOPERATION12_83f19cf10b a ns1:TareaMantenimiento ;
    rdfs:label "TMOPERATION = 12"@es ;
    ns1:textoExtracto "TMOPERATION = 12 Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén"@es .

ns1:TMOPERATION8_12c46d35b3 a ns1:TareaMantenimiento ;
    rdfs:label "TMOPERATION = 8"@es ;
    ns1:textoExtracto "TMOPERATION = 8 Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra."@es .

ns1:TMOPERATION9_d9c9b98d24 a ns1:TareaMantenimiento ;
    rdfs:label "TMOPERATION = 9"@es ;
    ns1:textoExtracto "TMOPERATION = 9 Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal."@es .

