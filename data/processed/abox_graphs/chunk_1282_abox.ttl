@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Almacen_71dee34f20 a ns1:Sistema ;
    rdfs:label "almacén" ;
    ns1:identificador "TAKEPOS" ;
    ns1:textoExtracto "Posición del almacén para coger la herramienta" .

ns1:Almacen_eaebdf9cb2 a ns1:Sistema ;
    rdfs:label "almacén" ;
    ns1:identificador "LEAVEPOS" ;
    ns1:textoExtracto "Posición del almacén para dejar la herramienta" .

ns1:Cabezal_fae8410d1a a ns1:ComponenteMecanico ;
    rdfs:label "cabezal" ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en el almacén" .

ns1:MarcaMZROT a ns1:Parametro ;
    rdfs:label "marca MZROT" ;
    ns1:identificador "MZROT" ;
    ns1:textoExtracto "Activar la marca MZROT en ambos almacenes para indicar que ha finalizado la operación" .

ns1:MarcaMZTOSPDL a ns1:Parametro ;
    rdfs:label "marca MZTOSPDL" ;
    ns1:identificador "MZTOSPDL" ;
    ns1:textoExtracto "activar la marca MZTOSPDL" .

ns1:MarcaSPDLTOMZ a ns1:Parametro ;
    rdfs:label "marca SPDLTOMZ" ;
    ns1:identificador "SPDLTOMZ" ;
    ns1:textoExtracto "activar la marca SPDLTOMZ" .

ns1:OperacionCambioHerramienta13 a ns1:TareaMantenimiento ;
    rdfs:label "Orientar dos almacenes" ;
    ns1:identificador "TMOPERATION = 13" ;
    ns1:textoExtracto "Esta operación es una optimización del cambio de herramienta que permite orientar dos almacenes durante el mecanizado. Activar la marca MZROT en ambos almacenes para indicar que ha finalizado la operación, se hayan orientado los almacenes o no." .

ns1:OperacionCambioHerramienta14 a ns1:TareaMantenimiento ;
    rdfs:label "Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén" ;
    ns1:identificador "TMOPERATION = 14" ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén. TAKEPOS=# Posición del almacén para coger la herramienta. LEAVEPOS=# Posición del almacén para dejar la herramienta. MZID En la parte baja de este registro se indica el almacén en el que hay que dejar la herramienta y en la parte alta el almacén del que hay que coger la herramienta. La secuencia de esta operación es la siguiente. 1 Dejar la herramienta del cabezal en el almacén y activar la marca SPDLTOMZ. 2 Poner la herramienta del almacén en el cabezal y activar la marca MZTOSPDL." .

ns1:RegistroMZID a ns1:Tabla ;
    rdfs:label "registro MZID" ;
    ns1:identificador "MZID" ;
    ns1:textoExtracto "En la parte baja de este registro se indica el almacén en el que hay que dejar la herramienta y en la parte alta el almacén del que hay que coger la herramienta." .

