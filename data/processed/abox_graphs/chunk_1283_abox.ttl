@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Funcion_M109 a ns1:ComponenteElectrico,
        ns1:Tabla ;
    rdfs:label "Función M109 (Selección de herramienta)"@es ;
    ns1:identificador "M109" ;
    ns1:ilustradoEn ns1:Tabla_ComunicacionM06_PLC ;
    ns1:textoExtracto "M109 | Seleccionar en el almacén la posición que indica TAKEPOS y poner la herramienta en el cabezal."@es .

ns1:Funcion_M110 a ns1:ComponenteElectrico,
        ns1:Tabla ;
    rdfs:label "Función M110 (Devolución de herramienta)"@es ;
    ns1:identificador "M110" ;
    ns1:ilustradoEn ns1:Tabla_ComunicacionM06_PLC ;
    ns1:textoExtracto "M110 | Seleccionar en el almacén la posición que indica LEAVEPOS y dejar la herramienta del cabezal."@es .

ns1:Marca_M1107 a ns1:ComponenteElectrico ;
    rdfs:label "Marca M1107 (SPDLTOGR)"@es ;
    ns1:identificador "M1107" ;
    ns1:ilustradoEn ns1:Tabla_ComunicacionM06_PLC ;
    ns1:textoExtracto "M1107 | SPDLTOGR | La herramienta se ha llevado del cabezal a tierra."@es .

ns1:Marca_M1108 a ns1:ComponenteElectrico ;
    rdfs:label "Marca M1108 (GRTOSPDL)"@es ;
    ns1:identificador "M1108" ;
    ns1:ilustradoEn ns1:Tabla_ComunicacionM06_PLC ;
    ns1:textoExtracto "M1108 | GRTOSPDL | La herramienta se ha llevado de tierra al cabezal."@es .

ns1:Marca_M1109 a ns1:ComponenteElectrico ;
    rdfs:label "Marca M1109 (MZTOSPDL)"@es ;
    ns1:identificador "M1109" ;
    ns1:ilustradoEn ns1:Tabla_ComunicacionM06_PLC ;
    ns1:textoExtracto "M1109 | MZTOSPDL | La herramienta se ha llevado del almacén al cabezal."@es .

ns1:Marca_M1110 a ns1:ComponenteElectrico ;
    rdfs:label "Marca M1110 (SPDLTOMZ)"@es ;
    ns1:identificador "M1110" ;
    ns1:ilustradoEn ns1:Tabla_ComunicacionM06_PLC ;
    ns1:textoExtracto "M1110 | SPDLTOMZ | La herramienta se ha llevado del cabezal al almacén."@es .

ns1:Pagina_498 a ns1:Pagina ;
    ns1:identificador "498" ;
    ns1:textoExtracto "La comunicación entre el PLC y la rutina M06 se realiza mediante una serie de marcas y registros genéricos."@es .

ns1:Tabla_ComunicacionM06_PLC a ns1:Tabla ;
    rdfs:label "Tabla de comunicación entre rutina M06 y PLC"@es ;
    ns1:documentadoEn ns1:Pagina_498 ;
    ns1:textoExtracto "Comunicación entre la rutina M06 y el PLC [...] Marcas que activa la rutina M06 para que el PLC active la marca correspondiente del gestor."@es .

