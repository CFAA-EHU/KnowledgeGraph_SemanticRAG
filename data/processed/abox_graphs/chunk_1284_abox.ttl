@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Almacen_63e4f95a13 a ns1:Componente ;
    ns1:textoExtracto "almacén" .

ns1:Cabezal_473f61fb80 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "cabezal" .

ns1:CogerLaHerramientaDelAlmacenYPonerlaEnElCabezalM109FuncionAuxiliarParaEjecutarAccionVPLCM11091MarcaMZTOSPDLAlGestorWAITFORVPLCM11090RET a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Coger la herramienta del almacén y ponerla en el cabezal. M109 ; Función auxiliar para ejecutar acción. V.PLC.M[1109]=1 ; Marca MZTOSPDL al gestor. # WAIT FOR [V.PLC.M[1109]==0] #RET" .

ns1:ColocarLaHerramientaDeTierraEnElCabezalMSGInsertarHerramientaTDYPulsarMARCHAVTMNXTOOLMensajeAlOperarioParaQuePongaLaHerramientaM0EsperarAQueFinaliceLaOperacionMSGQuitarMensajeVPLCM11081MarcaGRTOSPDLAlGestorWAITFORVPLCM11080RET a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Colocar la herramienta de tierra en el cabezal. # MSG [\"Insertar herramienta T%D y pulsar MARCHA\", V.TM.NXTOOL] ; Mensaje al operario para que ponga la herramienta. M0 ; Esperar a que finalice la operación. # MSG [\"\"] ; Quitar mensaje. V.PLC.M[1108]=1 ; Marca GRTOSPDL al gestor. # WAIT FOR [V.PLC.M[1108]==0] #RET" .

ns1:DejarLaHerramientaDelCabezalEnElAlmacenM110FuncionAuxiliarParaEjecutarAccionVPLCM11101MarcaSPDLTOGRAlGestorWAITFORVPLCM11100RET a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en el almacén. M110 ; Función auxiliar para ejecutar acción. V.PLC.M[1110]=1 ; Marca SPDLTOGR al gestor. # WAIT FOR [V.PLC.M[1110]==0] #RET" .

ns1:Herramienta_a382f60c4e a ns1:PiezaRecambio ;
    ns1:textoExtracto "herramienta" .

ns1:LlevarElCabezalAlPuntoDeCambioAutomaticoG1ZFDesplazarElCabezalRET a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio automático. G1 Z_ F_ ; Desplazar el cabezal. # RET" .

ns1:LlevarElCabezalAlPuntoDeCambioManualG1ZFDesplazarElCabezalRET a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio manual. G1 Z_ F_ ; Desplazar el cabezal. # RET" .

ns1:OrdenAlGestorParaComenzarElCambioDeHerramienta a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Orden al gestor para comenzar el cambio de herramienta." .

ns1:QuitarLaHerramientaDelCabezalLlevarlaATierraMSGExtraerHerramientaTDYPulsarMARCHAVTMTOOLMensajeAlOperarioParaQueQuiteLaHerramientaM0EsperarAQueFinaliceLaOperacionMSGQuitarMensajeVPLCM11071MarcaSPDLTOGRAlGestorWAITFORVPLCM11070RET a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Quitar la herramienta del cabezal (llevarla a tierra). # MSG [\"Extraer herramienta T%D y pulsar MARCHA\", V.TM.TOOL] ; Mensaje al operario para que quite la herramienta. M0 ; Esperar a que finalice la operación. # MSG [\"\"] ; Quitar mensaje. V.PLC.M[1107]=1 ; Marca SPDLTOGR al gestor. # WAIT FOR [V.PLC.M[1107]==0] #RET" .

ns1:tecla_STOP a ns1:InterfazUsuario ;
    ns1:textoExtracto "tecla STOP" .

