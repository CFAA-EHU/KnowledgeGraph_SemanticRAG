@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal"@es ;
    ns1:textoExtracto "ponerla en el cabezal" .

ns1:HerramientaDeTierra_4e82b75e3a a ns1:Herramienta ;
    rdfs:label "Herramienta de tierra"@es ;
    ns1:textoExtracto "Colocar la herramienta de tierra en el cabezal." .

ns1:HerramientaDelAlmacen_4f1cd5eb1d a ns1:Herramienta ;
    rdfs:label "Herramienta del almacén"@es ;
    ns1:textoExtracto "Coger una herramienta del almacén y ponerla en el cabezal." .

ns1:PuntoCambioAutomatico a ns1:ModoOperacion ;
    rdfs:label "Punto de cambio automático"@es ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio automático" .

ns1:PuntoCambioManual a ns1:ModoOperacion ;
    rdfs:label "Punto de cambio manual"@es ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio manual" .

ns1:RutinaM06 a ns1:TareaMantenimiento ;
    rdfs:label "Rutina M06"@es ;
    ns1:textoExtracto "Programa de la rutina M06" .

