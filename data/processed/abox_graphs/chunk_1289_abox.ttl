@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsperaAlGestorDelAlmacen a ns1:TareaMantenimiento ;
    rdfs:label "Espera al gestor del almacén" ;
    ns1:textoExtracto "$WHILE V.TM.MZWAIT == 1 $ENDWHILE ; Espera al gestor del almacén." .

ns1:FinDeTratamientoDeBloqueUnico a ns1:AccionProhibida ;
    rdfs:label "Fin de tratamiento de bloque único" ;
    ns1:textoExtracto "#DSBLK ; Fin de tratamiento de bloque único." .

ns1:LL_SUB_MZ_TO_SPD a ns1:TareaMantenimiento ;
    rdfs:label "Poner la herramienta del almacén en el cabezal" ;
    ns1:textoExtracto "LL SUB_MZ_TO_SPD ; Poner la herramienta del almacén en el cabezal." .

ns1:LL_SUB_SPD_AUTCHG a ns1:TareaMantenimiento ;
    rdfs:label "Llevar el cabezal al punto de cambio automático" ;
    ns1:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático." .

ns1:LL_SUB_SPD_GMCHG a ns1:TareaMantenimiento ;
    rdfs:label "Llevar el cabezal al punto de cambio manual" ;
    ns1:textoExtracto "LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual." .

ns1:LL_SUB_SPD_TO_GR a ns1:TareaMantenimiento ;
    rdfs:label "Quitar la herramienta del cabezal" ;
    ns1:textoExtracto "LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal." .

ns1:TeclaSTOP a ns1:InterfazUsuario ;
    rdfs:label "tecla STOP" ;
    ns1:textoExtracto "# ESTOP ; Habilitar la tecla STOP." .

