@prefix ex: <https://vocab.cfaa.eus/broaching/>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix sensor: <https://admin-shell.io/dictionary/Sensor>.

ex:CaudalimetroMecatronico rdf:type owl:Class ;
    rdfs:label "Caudalímetro mecatrónico"@es ;
    rdfs:comment "Caudalímetro mecatrónico de IFM electronic GmbH"@es.

ex:ElectronicLevelSensor rdf:type owl:Class ;
    rdfs:label "Electronic level sensor"@es ;
    rdfs:comment "Sensor de nivel electrónico de IFM electronic GmbH"@es.

ex:SensorNivelTON rdf:type owl:Class ;
    rdfs:label "Sensor de nivel TON"@es ;
    rdfs:comment "Sensor de nivel TON (salida digital) de IFM electronic GmbH"@es.

ex:SITOPModuloSeleccion rdf:type owl:Class ;
    rdfs:label "SITOP PSE200U 10 A Módulo de selección de 4 canales"@es ;
    rdfs:comment "Módulo de selección de SIEMENS AG"@es.

ex:IFMelectronicGmbH rdf:type owl:Class ;
    rdfs:label "IFM electronic GmbH"@es ;
    rdfs:comment "Fabricante de componentes electrónicos"@es.

ex:SIEMENSAG rdf:type owl:Class ;
    rdfs:label "SIEMENS AG"@es ;
    rdfs:comment "Fabricante de componentes electrónicos"@es.

ex:SBG54IF0FRKG rdf:type ex:CaudalimetroMecatronico ;
    rdfs:label "SBG54IF0FRKG"@es ;
    rdfs:comment "Modelo de caudalímetro mecatrónico de IFM electronic GmbH"@es.

ex:SBG12IF0FRKG rdf:type ex:CaudalimetroMecatronico ;
    rdfs:label "SBG12IF0FRKG"@es ;
    rdfs:comment "Modelo de caudalímetro mecatrónico de IFM electronic GmbH"@es.

ex:LK1022LK0264BB00KQPKGUS rdf:type ex:ElectronicLevelSensor ;
    rdfs:label "LK1022 LK0264B-B-00KQPKG/US"@es ;
    rdfs:comment "Modelo de sensor de nivel electrónico de IFM electronic GmbH"@es.

ex:LI0132K00KNPKGUS rdf:type ex:SensorNivelTON ;
    rdfs:label "LI0132--K-00KNPKG/US"@es ;
    rdfs:comment "Modelo de sensor de nivel TON (salida digital) de IFM electronic GmbH"@es.

ex:6EP19612BA21 rdf:type ex:SITOPModuloSeleccion ;
