@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix ifm: <http://www.ifm.com/> .
@prefix siemens: <http://www.siemens.com/> .

ex:CaudalimetroMecatronico a owl:Class ;
    rdfs:label "Caudalímetro mecatrónico" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Sensor> .

ex:ElectronicLevelSensor a owl:Class ;
    rdfs:label "Electronic level sensor" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Sensor> .

ex:SensorNivelTON a owl:Class ;
    rdfs:label "Sensor de nivel TON (salida digital)" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Sensor> .

ex:ModuloSeleccion4Canales a owl:Class ;
    rdfs:label "Módulo de selección de 4 canales" .

ex:SBG54IF0FRKG a ex:CaudalimetroMecatronico ;
    rdfs:label "SBG54IF0FRKG" ;
    rdfs:comment "Modelo de caudalímetro mecatrónico de IFM electronic GmbH" .

ex:SBG12IF0FRKG a ex:CaudalimetroMecatronico ;
    rdfs:label "SBG12IF0FRKG" ;
    rdfs:comment "Modelo de caudalímetro mecatrónico de IFM electronic GmbH" .

ex:LK1022LK0264BB00KQPKGUS a ex:ElectronicLevelSensor ;
    rdfs:label "LK1022 LK0264B-B-00KQPKG/US" ;
    rdfs:comment "Modelo de sensor de nivel electrónico de IFM electronic GmbH" .

ex:LI0132K00KNPKGUS a ex:SensorNivelTON ;
    rdfs:label "LI0132--K-00KNPKG/US" ;
    rdfs:comment "Modelo de sensor de nivel TON (salida digital) de IFM electronic GmbH" .

ex:SITOPPSE200U10A a ex:ModuloSeleccion4Canales ;
    rdfs:label "SITOP PSE200U 10 A" ;
    rdfs:comment "Módulo de selección de 4 canales de SIEMENS AG" .

ex:IFMelectronicGmbH a owl:Class ;
    rdfs:label "IFM electronic GmbH" ;
    rdfs:comment "Fabricante de componentes electrónicos" .

ex:SIEMENSAG a owl:Class ;
    rdfs:label "SIEMENS AG" ;
    rdfs:comment "Fabricante de componentes electrónicos" .

ex:tieneModelo a owl:ObjectProperty ;
    rdfs:domain ex:CaudalimetroMecatronico ;
    rdfs:range ex:CaudalimetroMecatronico .

ex:tieneModelo a owl:ObjectProperty ;
    rdfs:domain ex:ElectronicLevelSensor ;
    rdfs:range ex:ElectronicLevelSensor .

ex:tieneModelo a owl:ObjectProperty ;
    rdfs:domain ex:SensorNivelTON ;
    rdfs:range ex:SensorNivelTON .

ex:tieneModelo a owl:ObjectProperty ;
    rdfs:domain ex:ModuloSeleccion4Canales ;
    rdfs:range ex:ModuloSeleccion4Canales .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:CaudalimetroMecatronico ;
    rdfs:range ex:IFMelectronicGmbH .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:ElectronicLevelSensor ;
    rdfs:range ex:IFMelectronicGmbH .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:SensorNivelTON ;
    rdfs:range ex:IFMelectronicGmbH .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:ModuloSeleccion4Canales ;
    rdfs:range ex:SIEMENSAG .

ex:tieneCodigo a owl:DatatypeProperty ;
    rdfs:domain ex:CaudalimetroMecatronico ;
    rdfs:range rdfs:Literal .

ex:tieneCodigo a owl:DatatypeProperty ;
    rdfs:domain ex:ElectronicLevelSensor ;
    rdfs:range rdfs:Literal .

ex:tieneCodigo a owl:DatatypeProperty ;
    rdfs:domain ex:SensorNivelTON ;
    rdfs:range rdfs:Literal .

ex:tieneCodigo a owl:DatatypeProperty ;
    rdfs:domain ex:ModuloSeleccion4Canales ;
    rdfs:range rdfs:Literal .