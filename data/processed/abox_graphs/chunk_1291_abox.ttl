@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:M06_8a56fe550d a ns1:TareaMantenimiento ;
    ns1:identificador "M06" ;
    ns1:textoExtracto "La rutina M06 utiliza las siguientes funciones auxiliares M para indicar al PLC qué movimientos debe realizar." .

ns1:M1108_e6c352559b a ns1:TareaMantenimiento ;
    ns1:identificador "M1108" ;
    ns1:textoExtracto "DFU M1108 = SET GRTOSPDL DFD GRTOSPDL = RES M1108 La herramienta se ha llevado de tierra al cabezal." .

ns1:M1109_a198375d4e a ns1:TareaMantenimiento ;
    ns1:identificador "M1109" ;
    ns1:textoExtracto "DFU M1109 = SET MZTOSPDL DFD MZTOSPDL = RES M1109 La herramienta se ha llevado del almacén al cabezal." .

ns1:M1110_c1b2c23d23 a ns1:TareaMantenimiento ;
    ns1:identificador "M1110" ;
    ns1:textoExtracto "DFU M1110 = SET SPDLTOMZ DFD SPDLTOMZ = RES M1110 La herramienta se ha llevado del cabezal al almacén." .

ns1:M1111_5d4cbbad37 a ns1:TareaMantenimiento ;
    ns1:identificador "M1111" ;
    ns1:textoExtracto "DFU M1111 = SET MZROT DFD MZROT = RES M1111 Ya ha girado el almacén." .

ns1:MaquinaTipo a ns1:Maquina ;
    ns1:textoExtracto "Su programación depende del tipo de máquina." .

ns1:SeleccionarEnElAlmacenLaPosicionQueIndicaLEAVEPOSYDejarLaHerramientaDelCabezal a ns1:Parametro ;
    ns1:textoExtracto "Seleccionar en el almacén la posición que indica LEAVEPOS y dejar la herramienta del cabezal." .

ns1:SeleccionarEnElAlmacenLaPosicionQueIndicaTAKEPOSYPonerLaHerramientaEnElCabezal a ns1:Parametro ;
    ns1:textoExtracto "Seleccionar en el almacén la posición que indica TAKEPOS y poner la herramienta en el cabezal." .

