@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:GestorHerramientas a ns1:Sistema ;
    rdfs:label "gestor de herramientas" ;
    ns1:textoExtracto "En determinadas operaciones hay que utilizar la información que pasa el gestor en los siguientes registros: LEAVEPOS Este registro indica la posición de almacén en la que hay que dejar la herramienta. TAKEPOS Este registro indica la posición de almacén que ocupa la herramienta que hay que coger. Señal de emergencia del gestor. Tratamiento de la señal de emergencia del gestor de herramientas." .

ns1:LEAVEPOS a ns1:Parametro ;
    rdfs:label "LEAVEPOS" ;
    ns1:textoExtracto "LEAVEPOS Este registro indica la posición de almacén en la que hay que dejar la herramienta." ;
    ns1:valor "posición de almacén" .

ns1:ProgramacionPLC a ns1:AccionProhibida ;
    rdfs:label "programación básica del PLC" ;
    ns1:textoExtracto "Su programación depende del tipo de máquina. La función auxiliar se dará por finalizada tras ejecutar el movimiento solicitado." .

ns1:Se_alEmergenciaGestor a ns1:Sensor ;
    rdfs:label "Señal de emergencia del gestor" ;
    ns1:textoExtracto "Señal de emergencia del gestor. Tratamiento de la señal de emergencia del gestor de herramientas." .

ns1:TAKEPOS a ns1:Parametro ;
    rdfs:label "TAKEPOS" ;
    ns1:textoExtracto "TAKEPOS Este registro indica la posición de almacén que ocupa la herramienta que hay que coger." ;
    ns1:valor "posición de almacén" .

