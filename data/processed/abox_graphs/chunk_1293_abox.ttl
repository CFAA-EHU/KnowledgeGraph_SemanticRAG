@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:L_mparaUSER12 a ns1:ComponenteElectrico ;
    rdfs:label "Lámpara de la tecla USER12" ;
    ns1:ilustradoEn ns1:TeclaUSER12 ;
    ns1:textoExtracto "Lámpara de la tecla USER12 iluminada cuando hay emergencia." .

ns1:Se_alEmergenciaGestor a ns1:Sensor ;
    rdfs:label "Señal de emergencia del gestor" ;
    ns1:identificador "DFU B11KEYBD1" ;
    ns1:mitigaRiesgo ns1:Se_alEmergencia ;
    ns1:textoExtracto "Señal de emergencia del gestor. Tratamiento de la señal de emergencia del gestor de herramientas." .

ns1:TeclaUSER13 a ns1:InterfazUsuario ;
    rdfs:label "tecla USER13" ;
    ns1:controla ns1:Se_alEmergencia ;
    ns1:identificador "USER13" ;
    ns1:textoExtracto "Si se pulsa la tecla USER13 se quita la emergencia." .

ns1:TeclaUSER12 a ns1:InterfazUsuario ;
    rdfs:label "tecla USER12" ;
    ns1:controla ns1:Se_alEmergencia ;
    ns1:identificador "USER12" ;
    ns1:textoExtracto "Si se pulsa la tecla USER12 se activa la emergencia." .

ns1:Se_alEmergencia a ns1:AvisoSeguridad ;
    rdfs:label "emergencia" ;
    ns1:textoExtracto "Si se pulsa la tecla USER12 se activa la emergencia." .

