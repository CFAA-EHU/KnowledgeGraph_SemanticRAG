@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlmacenSincronoConBrazoCambiador_726ea95e0c a ns1:Maquina ;
    rdfs:label "almacén síncrono con brazo cambiador" ;
    ns1:textoExtracto "Los almacenes síncronos con brazo cambiador (1 o 2 pinzas) tienen el almacén próximo al cabezal y el cambio se realiza con ayuda del brazo cambiador." .

ns1:Almacen_92d600d42d a ns1:Componente ;
    rdfs:label "almacén" ;
    ns1:textoExtracto "el gestor envía una orden al PLC para que seleccione la próxima herramienta en el almacén" .

ns1:BrazoCambiador_1033_1 a ns1:ComponenteMecanico ;
    rdfs:label "brazo cambiador" ;
    ns1:textoExtracto "el cambio se realiza con ayuda del brazo cambiador" .

ns1:Cabezal_1033_1 a ns1:ComponenteMecanico ;
    rdfs:label "cabezal" ;
    ns1:textoExtracto "el almacén próximo al cabezal" .

ns1:DesplazamientoAlmacen_1033_1 a ns1:ComponenteMecanico ;
    rdfs:label "desplazamiento almacén" ;
    ns1:textoExtracto "los desplazamientos de los distintos dispositivos (giro almacén, desplazamiento almacén, brazo cambiador, etc.)" .

ns1:DispositivoExterno_1033_1 a ns1:Componente ;
    rdfs:label "dispositivos externos" ;
    ns1:textoExtracto "el control de los dispositivos externos" .

ns1:FuncionM06_cec08dead8 a ns1:Parametro ;
    rdfs:label "función M06" ;
    ns1:textoExtracto "la ejecución de la función M06" .

ns1:FuncionT_0594297a83 a ns1:Parametro ;
    rdfs:label "función T" ;
    ns1:textoExtracto "la ejecución de la función T" .

ns1:GestorHerramientas_1033_1 a ns1:Sistema ;
    rdfs:label "gestor" ;
    ns1:textoExtracto "la comunicación entre el gestor y el PLC" .

ns1:GiroAlmacen_1033_1 a ns1:ComponenteMecanico ;
    rdfs:label "giro almacén" ;
    ns1:textoExtracto "los desplazamientos de los distintos dispositivos (giro almacén, desplazamiento almacén, brazo cambiador, etc.)" .

ns1:Herramienta_d4409a4c73 a ns1:PiezaRecambio ;
    rdfs:label "herramienta" ;
    ns1:textoExtracto "el cambio de herramienta" .

ns1:PLC_1033_1 a ns1:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ns1:textoExtracto "la comunicación entre el gestor y el PLC" .

ns1:ProgramaCNC_1033_1 a ns1:Sistema ;
