@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Almacen a ns1:Sistema ;
    rdfs:label "almacén" ;
    ns1:textoExtracto "Operaciones válidas del gestor de herramientas para este almacén." .

ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "cabezal" ;
    ns1:textoExtracto "Operaciones válidas del gestor de herramientas para este almacén. Las operaciones posibles en este tipo de almacén son las siguientes. | TMOPERATION | Significado. | 1 | Coger una herramienta del almacén y ponerla en el cabezal." .

ns1:CogerUnaHerramientaDeTierraYLlevarlaAlAlmacenPasandoPorElCabezal a ns1:ModoOperacion ;
    rdfs:label "Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal" ;
    ns1:textoExtracto "9 | Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal." .

ns1:CogerUnaHerramientaDelAlmacenYDejarlaEnTierraPasandoPorElCabezal a ns1:ModoOperacion ;
    rdfs:label "Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal" ;
    ns1:textoExtracto "10 | Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal." .

ns1:CogerUnaHerramientaDelAlmacenYPonerlaEnElCabezal_f8d4941a16 a ns1:ModoOperacion ;
    rdfs:label "Coger una herramienta del almacén y ponerla en el cabezal" ;
    ns1:textoExtracto "1 | Coger una herramienta del almacén y ponerla en el cabezal." .

ns1:DejarLaHerramientaDelCabezalEnElAlmacenYCogerUnaHerramientaDeOtroAlmacen a ns1:ModoOperacion ;
    rdfs:label "Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén" ;
    ns1:textoExtracto "14 | Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén." .

ns1:DejarLaHerramientaDelCabezalEnElAlmacenYCogerUnaHerramientaDeTierra a ns1:ModoOperacion ;
    rdfs:label "Dejar la herramienta del cabezal en el almacén y coger una herramienta de tierra" ;
    ns1:textoExtracto "6 | Dejar la herramienta del cabezal en el almacén y coger una herramienta de tierra." .

ns1:DejarLaHerramientaDelCabezalEnElAlmacenYCogerUnaHerramientaDelMismoAlmacen a ns1:ModoOperacion ;
    rdfs:label "Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén" ;
    ns1:textoExtracto "5 | Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén." .

ns1:DejarLaHerramientaDelCabezalEnElAlmacen_e886c46e8f a ns1:ModoOperacion ;
    rdfs:label "Dejar la herramienta del cabezal en el almacén" ;
    ns1:textoExtracto "2 | Dejar la herramienta del cabezal en el almacén." .

ns1:DejarLaHerramientaDelCabezalEnTierra a ns1:ModoOperacion ;
    rdfs:label "Dejar la herramienta del cabezal en tierra" ;
    ns1:textoExtracto "4 | Dejar la herramienta del cabezal en tierra." .

ns1:DejarLaHerramientaDelCabezalEnTierraYCogerUnaHerramientaDeTierra a ns1:ModoOperacion ;
    rdfs:label "Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra" ;
    ns1:textoExtracto "8 | Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra." .

ns1:DejarLaHerramientaDelCabezalEnTierraYCogerUnaHerramientaDelAlmacen a ns1:ModoOperacion ;
    rdfs:label "Dejar la herramienta del cabezal en tierra y coger una herramienta del almacén" ;
    ns1:textoExtracto "7 | Dejar la herramienta del cabezal en tierra y coger una herramienta del almacén." .

ns1:HerramientaDeTierra_98cecb4511 a ns1:Componente ;
    rdfs:label "herramienta de tierra" ;
    ns1:textoExtracto "3 | Poner en el cabezal una herramienta de tierra. 4 | Dejar la herramienta del cabezal en tierra. 6 | Dejar la herramienta del cabezal en el almacén y coger una herramienta de tierra. 8 | Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra. 9 | Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal." .

ns1:NoHayQueHacerNada a ns1:ModoOperacion ;
    rdfs:label "No hay que hacer nada" ;
    ns1:identificador "0" ;
    ns1:textoExtracto "Operaciones válidas del gestor de herramientas para este almacén. Las operaciones posibles en este tipo de almacén son las siguientes. | TMOPERATION | Significado. | 0 | No hay que hacer nada." .

ns1:OrientarDosAlmacenes a ns1:ModoOperacion ;
    rdfs:label "Orientar dos almacenes" ;
    ns1:textoExtracto "13 | Orientar dos almacenes." .

ns1:OrientarElAlmacen a ns1:ModoOperacion ;
    rdfs:label "Orientar el almacén" ;
    ns1:textoExtracto "11 | Orientar el almacén." .

ns1:PonerEnElCabezalUnaHerramientaDeTierra a ns1:ModoOperacion ;
    rdfs:label "Poner en el cabezal una herramienta de tierra" ;
    ns1:textoExtracto "3 | Poner en el cabezal una herramienta de tierra." .

ns1:PosicionAlmacen a ns1:Parametro ;
    rdfs:label "Posición en el almacén" ;
    ns1:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor. | Valor | Significado | # | Posición en el almacén." .

ns1:PosicionTierra a ns1:Parametro ;
    rdfs:label "-4" ;
    ns1:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor. | Valor | Significado | -4 | Herramienta de tierra." ;
    ns1:valor "-4" .

ns1:RegistroLEAVEPOS a ns1:Parametro ;
    rdfs:label "LEAVEPOS" ;
    ns1:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor. Las señales TAKEPOS y LEAVEPOS pueden tomar los siguientes valores." .

ns1:RegistroTAKEPOS a ns1:Parametro ;
    rdfs:label "TAKEPOS" ;
    ns1:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor. Las señales TAKEPOS y LEAVEPOS pueden tomar los siguientes valores." .

