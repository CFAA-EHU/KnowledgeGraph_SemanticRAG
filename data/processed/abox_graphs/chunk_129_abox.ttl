@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix siemens: <http://www.siemens.com/> .
@prefix rittal: <http://www.rittal.com/> .
@prefix ccea: <http://www.ccea.it/> .

ex:ModuloSeleccionDe4Canales a owl:Class ;
    rdfs:label "Módulo de selección de 4 canales" ;
    rdfs:comment "Componente de selección de 4 canales" .

ex:SystemLightLED a owl:Class ;
    rdfs:label "System Light LED" ;
    rdfs:comment "Sistema de iluminación LED" .

ex:SoporteIluminacionMaquina a owl:Class ;
    rdfs:label "Soporte de iluminación máquina" ;
    rdfs:comment "Soporte para iluminación de máquina" .

ex:LamparaIluminacionMaquina a owl:Class ;
    rdfs:label "Lámpara de iluminación máquina" ;
    rdfs:comment "Lámpara para iluminación de máquina" .

ex:LamparaSeñalizacion a owl:Class ;
    rdfs:label "Lámpara de señalización" ;
    rdfs:comment "Lámpara para señalización de tensión" .

ex:tieneModelo a owl:ObjectProperty ;
    rdfs:domain ex:ModuloSeleccionDe4Canales ;
    rdfs:range rdfs:Literal .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:ModuloSeleccionDe4Canales ;
    rdfs:range rdfs:Literal .

ex:tieneCodigo a owl:ObjectProperty ;
    rdfs:domain ex:ModuloSeleccionDe4Canales ;
    rdfs:range rdfs:Literal .

ex:tieneLuminosidad a owl:ObjectProperty ;
    rdfs:domain ex:SystemLightLED ;
    rdfs:range rdfs:Literal .

ex:tieneLongitud a owl:ObjectProperty ;
    rdfs:domain ex:SystemLightLED ;
    rdfs:range rdfs:Literal .

ex:tieneVoltaje a owl:ObjectProperty ;
    rdfs:domain ex:SystemLightLED ;
    rdfs:range rdfs:Literal .

ex:tieneFabricanteIluminacion a owl:ObjectProperty ;
    rdfs:domain ex:SoporteIluminacionMaquina ;
    rdfs:range rdfs:Literal .

ex:tieneCodigoIluminacion a owl:ObjectProperty ;
    rdfs:domain ex:SoporteIluminacionMaquina ;
    rdfs:range rdfs:Literal .

ex:tieneVoltajeLampara a owl:ObjectProperty ;
    rdfs:domain ex:LamparaIluminacionMaquina ;
    rdfs:range rdfs:Literal .

ex:tienePotenciaLampara a owl:ObjectProperty ;
    rdfs:domain ex:LamparaIluminacionMaquina ;
    rdfs:range rdfs:Literal .

ex:tieneFabricanteSeñalizacion a owl:ObjectProperty ;
    rdfs:domain ex:LamparaSeñalizacion ;
    rdfs:range rdfs:Literal .

ex:tieneCodigoSeñalizacion a owl:ObjectProperty ;
    rdfs:domain ex:LamparaSeñalizacion ;
    rdfs:range rdfs:Literal .