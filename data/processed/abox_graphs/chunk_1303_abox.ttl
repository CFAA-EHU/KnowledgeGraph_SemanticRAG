@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Cabezal_1042 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de transferencia"@es ;
    ns1:textoExtracto "Poner la herramienta de tierra en el cabezal [...] Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal"@es .

ns1:Pinza1_b939c7c6c6 a ns1:ComponenteMecanico ;
    rdfs:label "Pinza ꞏ1ꞏ"@es ;
    ns1:ejecutadoPor ns1:Personal_1042 ;
    ns1:textoExtracto "Coger la herramienta del cabezal con la pinza ꞏ1ꞏ [...] Dejar la herramienta de la pinza ꞏ1ꞏ en el almacén"@es .

ns1:PosicionDeTierraLEAVEPOS4 a ns1:Parametro ;
    rdfs:label "Posición de tierra (LEAVEPOS=-4)"@es ;
    ns1:identificador "LEAVEPOS=-4" ;
    ns1:monitoreaParametro ns1:HerramientaGenericaParaOperacionDeAlmacen_5863e14065 ;
    ns1:textoExtracto "LEAVEPOS=-4 Herramienta de tierra."@es ;
    ns1:valor "-4" .

ns1:SistemaDeAlmacenDeHerramientas a ns1:Sistema ;
    rdfs:label "Sistema de almacén de herramientas"@es ;
    ns1:textoExtracto "Coger una herramienta del almacén [...] TAKEPOS=# Posición del almacén para coger la herramienta."@es ;
    ns1:tieneComponente ns1:HerramientaGenericaParaOperacionDeAlmacen_5863e14065 .

ns1:OperacionDeTransferenciaDeHerramientaTMOPERATION10 a ns1:TareaMantenimiento ;
    rdfs:label "Operación de transferencia de herramienta (TMOPERATION=10)"@es ;
    ns1:identificador "TMOPERATION=10" ;
    ns1:requiereMantenimiento ns1:HerramientaGenericaParaOperacionDeAlmacen_5863e14065 ;
    ns1:textoExtracto "TMOPERATION = 10 Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal."@es .

ns1:Personal_1042 a ns1:Personal ;
    rdfs:label "Operario de transferencia"@es ;
    ns1:ejecutadoPor ns1:OperacionDeTransferenciaDeHerramientaTMOPERATION10 ;
    ns1:textoExtracto "Coger la herramienta del almacén con la pinza ꞏ1ꞏ"@es .

ns1:HerramientaGenericaParaOperacionDeAlmacen_5863e14065 a ns1:Herramienta ;
    rdfs:label "Herramienta genérica para operación de almacén"@es ;
    ns1:textoExtracto "Coger la herramienta del almacén con la pinza ꞏ1ꞏ [...] Poner la herramienta de tierra en el cabezal"@es .

