ns1:MarcaCH1TOMZ a ns1:ModoOperacion ;
    rdfs:label "CH1TOMZ" ;
    ns1:textoExtracto "activar la marca CH1TOMZ"@es .

ns1:MarcaCH1TOSPDL a ns1:ModoOperacion ;
    rdfs:label "CH1TOSPDL" ;
    ns1:textoExtracto "activar la marca CH1TOSPDL"@es .

ns1:MarcaMZTOCH1 a ns1:ModoOperacion ;
    rdfs:label "MZTOCH1" ;
    ns1:textoExtracto "activar la marca MZTOCH1"@es .

ns1:MarcaSPDLTOCH1 a ns1:ModoOperacion ;
    rdfs:label "SPDLTOCH1" ;
    ns1:textoExtracto "activar la marca SPDLTOCH1"@es .

ns1:Pinza1 a ns1:Herramienta ;
    rdfs:label "pinza 1" ;
    ns1:textoExtracto "Dejar la herramienta de la pinza ꞏ1ꞏ en el almacén"@es .

