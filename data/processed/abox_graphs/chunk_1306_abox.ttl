@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FuncionM101 a ns1:Parametro ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:identificador "M101" ;
    ns1:textoExtracto "M101 | Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1." .

ns1:FuncionM102 a ns1:Parametro ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:identificador "M102" ;
    ns1:textoExtracto "M102 | Llevar la herramienta de la pinza 1 al cabezal." .

ns1:FuncionM103 a ns1:Parametro ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:identificador "M103" ;
    ns1:textoExtracto "M103 | Coger la herramienta del cabezal con la pinza 1." .

ns1:FuncionM105 a ns1:Parametro ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:identificador "M105" ;
    ns1:textoExtracto "M105 | Seleccionar en el almacén la posición que indica LEAVEPOS y dejar la herramienta de la pinza 1." .

ns1:MarcaM1101 a ns1:Parametro ;
    ns1:documentadoEn ns1:TablaMarcasM06 ;
    ns1:identificador "M1101" ;
    ns1:textoExtracto "M1101 | MZTOCH1 - La herramienta se ha llevado del almacén a la pinza 1." ;
    ns1:valor "MZTOCH1" .

ns1:MarcaM1102 a ns1:Parametro ;
    ns1:documentadoEn ns1:TablaMarcasM06 ;
    ns1:identificador "M1102" ;
    ns1:textoExtracto "M1102 | CH1TOSPDL - La herramienta se ha llevado de la pinza 1 al cabezal." ;
    ns1:valor "CH1TOSPDL" .

ns1:MarcaM1103 a ns1:Parametro ;
    ns1:documentadoEn ns1:TablaMarcasM06 ;
    ns1:identificador "M1103" ;
    ns1:textoExtracto "M1103 | SPDLTOCH1 - La herramienta se ha llevado del cabezal a la pinza 1." ;
    ns1:valor "SPDLTOCH1" .

ns1:MarcaM1105 a ns1:Parametro ;
    ns1:documentadoEn ns1:TablaMarcasM06 ;
    ns1:identificador "M1105" ;
    ns1:textoExtracto "M1105 | CH1TOMZ - La herramienta se ha llevado de la pinza 1 al almacén." ;
    ns1:valor "CH1TOMZ" .

ns1:MarcaM1107 a ns1:Parametro ;
    ns1:documentadoEn ns1:TablaMarcasM06 ;
    ns1:identificador "M1107" ;
    ns1:textoExtracto "M1107 | SPDLTOGR - La herramienta se ha llevado del cabezal a tierra." ;
    ns1:valor "SPDLTOGR" .

ns1:MarcaM1108 a ns1:Parametro ;
    ns1:documentadoEn ns1:TablaMarcasM06 ;
    ns1:identificador "M1108" ;
    ns1:textoExtracto "M1108 | GRTOSPDL - La herramienta se ha llevado de tierra al cabezal." ;
    ns1:valor "GRTOSPDL" .

ns1:ComunicacionPLC_M06 a ns1:Sistema ;
    rdfs:label "Sistema de comunicación PLC-M06" ;
    ns1:textoExtracto "La comunicación entre el PLC y la rutina M06 se realiza mediante una serie de marcas y registros genéricos." .

ns1:TablaFuncionesM a ns1:Tabla ;
    rdfs:label "Tabla de funciones M para control de movimientos" ;
    ns1:documentadoEn ns1:ComunicacionPLC_M06 ;
    ns1:textoExtracto "Funciones –M– en el PLC que implican movimientos controlados por el PLC." .

ns1:TablaMarcasM06 a ns1:Tabla ;
    rdfs:label "Tabla de marcas de comunicación M06-PLC" ;
    ns1:documentadoEn ns1:ComunicacionPLC_M06 ;
    ns1:textoExtracto "Marcas que activa la rutina M06 para que el PLC active la marca correspondiente del gestor." .

