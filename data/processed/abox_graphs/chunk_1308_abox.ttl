@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:GestorCambioHerramienta a ns1:Sistema ;
    ns1:textoExtracto "V.PLC.M[1108]=1 ; Marca GRTOSPDL al gestor." .

ns1:HerramientaT_D a ns1:PiezaRecambio ;
    rdfs:label "T%D" ;
    ns1:textoExtracto "Insertar herramienta T%D y pulsar MARCHA" .

ns1:MarcaGRTOSPDL a ns1:Parametro ;
    ns1:identificador "GRTOSPDL" ;
    ns1:textoExtracto "Marca GRTOSPDL al gestor." .

ns1:OrdenCambioHerramienta a ns1:AccionProhibida ;
    ns1:textoExtracto "M6 ; Orden al gestor para comenzar el cambio de herramienta." .

ns1:ParametroVGCNCAUTSTATUS a ns1:Parametro ;
    ns1:identificador "V.G.CNCAUTSTATUS" ;
    ns1:textoExtracto "V.G.CNCAUTSTATUS & 4096" .

ns1:ParametroVGCNCAUTSTATUS2 a ns1:Parametro ;
    ns1:identificador "V.G.CNCAUTSTATUS" ;
    ns1:textoExtracto "V.G.CNCAUTSTATUS & 8192" .

ns1:ParametroVGFULLSTATUS a ns1:Parametro ;
    ns1:identificador "V.G.FULLSTATUS" ;
    ns1:textoExtracto "V.G.FULLSTATUS & 255" .

ns1:ParametroVSExecution a ns1:Parametro ;
    ns1:identificador "V.S.EXECUTION" ;
    ns1:textoExtracto "V.S.EXECUTION = 0" .

ns1:PuntoCambioAutomatico a ns1:ModoOperacion ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio automático." .

ns1:PuntoCambioManual a ns1:ModoOperacion ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio manual." .

ns1:TeclaMARCHA a ns1:InterfazUsuario ;
    rdfs:label "MARCHA" ;
    ns1:textoExtracto "pulsar MARCHA" .

ns1:TeclaSTOP a ns1:InterfazUsuario ;
    rdfs:label "STOP" ;
    ns1:textoExtracto "Deshabilitar tecla STOP" .

