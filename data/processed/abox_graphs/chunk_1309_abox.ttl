@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Almacen_63e4f95a13 a ns1:Componente ;
    ns1:textoExtracto "almacén" .

ns1:Cabezal_be0ce77e20 a ns1:Componente ;
    ns1:textoExtracto "cabezal" .

ns1:HerramientaDeTierra_a4f289a80a a ns1:PiezaRecambio ;
    ns1:textoExtracto "herramienta de tierra" .

ns1:M06_8a56fe550d a ns1:TareaMantenimiento ;
    ns1:compuestoPor ns1:LLSUBMZTOCH1CogerLaHerramientaDelAlmacenConLaPinza1,
        ns1:LLSUBSPDTOCH1CogerLaHerramientaDelCabezalConLaPinza1,
        ns1:SubrutinaCH1TOMZ,
        ns1:SubrutinaCH1TOSPD,
        ns1:SubrutinaGRTOSPD,
        ns1:SubrutinaSPDAUTCHG,
        ns1:SubrutinaSPDGCHG,
        ns1:SubrutinaSPDTOGR ;
    ns1:identificador "M06" ;
    ns1:textoExtracto "Programa de la rutina M06." .

ns1:Pinza1_f2a3cf22da a ns1:Componente ;
    ns1:textoExtracto "pinza 1" .

ns1:PuntoCambioAutomatico a ns1:Componente ;
    ns1:textoExtracto "punto de cambio automático" .

ns1:PuntoCambioManual a ns1:Componente ;
    ns1:textoExtracto "punto de cambio manual" .

ns1:VGCNCAUTSTATUS4096 a ns1:Parametro ;
    ns1:textoExtracto "V.G.CNCAUTSTATUS & 4096" .

ns1:VGFULLSTATUS255 a ns1:Parametro ;
    ns1:textoExtracto "V.G.FULLSTATUS & 255" .

ns1:VPLCTMOPERATION a ns1:Parametro ;
    ns1:textoExtracto "V.PLC.TMOPERATION" .

ns1:VSEXECUTION a ns1:Parametro ;
