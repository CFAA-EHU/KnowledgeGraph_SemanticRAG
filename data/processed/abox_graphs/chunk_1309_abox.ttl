ns1:LLSUBMZTOCH1CogerLaHerramientaDelAlmacenConLaPinza1 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "LL SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1." .

ns1:LLSUBSPDTOCH1CogerLaHerramientaDelCabezalConLaPinza1 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "LL SUB_SPD_TO_CH1 ; Coger la herramienta del cabezal con la pinza 1." .

ns1:SubrutinaCH1TOMZ a ns1:TareaMantenimiento ;
    ns1:textoExtracto "LL SUB_CH1_TO_MZ ; Dejar la herramienta de la pinza 1 en el almacén." .

ns1:SubrutinaCH1TOSPD a ns1:TareaMantenimiento ;
    ns1:textoExtracto "LL SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal." .

ns1:SubrutinaGRTOSPD a ns1:TareaMantenimiento ;
    ns1:textoExtracto "LL SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal." .

ns1:SubrutinaSPDAUTCHG a ns1:TareaMantenimiento ;
    ns1:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático." .

ns1:SubrutinaSPDGCHG a ns1:TareaMantenimiento ;
    ns1:textoExtracto "LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual." .

ns1:SubrutinaSPDTOGR a ns1:TareaMantenimiento ;
    ns1:textoExtracto "LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal." .

