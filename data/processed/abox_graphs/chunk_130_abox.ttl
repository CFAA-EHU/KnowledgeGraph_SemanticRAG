@prefix ex: <https://vocab.cfaa.eus/broaching/>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix motor: <https://admin-shell.io/dictionary/Motor>.

ex:LamparaDeSeñalizacion a owl:Class ;
    rdfs:label "LamparaDeSeñalizacion" ;
    rdfs:comment "Lampara de señalización transparente" .

ex:Soporte a owl:Class ;
    rdfs:label "Soporte" .

ex:LedModul a owl:Class ;
    rdfs:label "LedModul" ;
    rdfs:comment "Módulo LED blanco" .

ex:Contacto a owl:Class ;
    rdfs:label "Contacto" ;
    rdfs:comment "Contacto AC-3, 5,5KW/400V, 1NA+1NC, DC 24V" .

ex:LimitadorSobretension a owl:Class ;
    rdfs:label "LimitadorSobretension" ;
    rdfs:comment "Limitador de sobretensión, varistor" .

ex:MotorEngrase a owl:Class ;
    rdfs:label "MotorEngrase" ;
    rdfs:comment "Motor de engrase" .

ex:MotorCintaEntrada a owl:Class ;
    rdfs:label "MotorCintaEntrada" ;
    rdfs:comment "Motor de cinta de entrada" .

ex:MotorRefrigeranteBrocha a owl:Class ;
    rdfs:label "MotorRefrigeranteBrocha" ;
    rdfs:comment "Motor refrigerante de brocha" .

ex:SiemensAG a owl:Class ;
    rdfs:label "SiemensAG" ;
    rdfs:comment "Siemens AG" .

ex:tension a owl:DatatypeProperty ;
    rdfs:label "tension" ;
    rdfs:domain ex:LamparaDeSeñalizacion ;
    rdfs:range xsd:string .

ex:fabricante a owl:DatatypeProperty ;
    rdfs:label "fabricante" ;
    rdfs:domain ex:LamparaDeSeñalizacion ;
    rdfs:range xsd:string .

ex:codigo a owl:DatatypeProperty ;
    rdfs:label "codigo" ;
    rdfs:domain ex:LamparaDeSeñalizacion ;
    rdfs:range xsd:string .

ex:cantidad a owl:DatatypeProperty ;
    rdfs:label "cantidad" ;
    rdfs:domain ex:LamparaDeSeñalizacion ;
    rdfs:range xsd:integer .

ex:tensionSoporte a owl:DatatypeProperty ;
    rdfs:label "tensionSoporte" ;
    rdfs:domain ex:Soporte ;
    rdfs:range xsd:string .

ex:fabricanteSoporte a owl:DatatypeProperty ;
    rdfs:label "fabricanteSoporte" ;
    rdfs:domain ex:Soporte ;
    rdfs:range xsd:string .

ex:codigoSoporte a owl:DatatypeProperty ;
    rdfs:label "codigoSoporte" ;
    rdfs:domain ex:Soporte ;
    rdfs:range xsd:string .

ex:cantidadSoporte a owl:DatatypeProperty ;
    rdfs:label "cantidadSoporte" ;
    rdfs:domain ex:Soporte ;
    rdfs:range xsd:integer .

ex:tensionLedModul a owl:DatatypeProperty ;
    rdfs:label "tensionLedModul" ;
    rdfs:domain ex:LedModul ;
    rdfs:range xsd:string .

ex:fabricanteLedModul a owl:DatatypeProperty ;
    rdfs:label "fabricanteLedModul" ;
    rdfs:domain ex:LedModul ;
    rdfs:range xsd:string .

ex:codigoLedModul a owl:DatatypeProperty ;
    rdfs:label "codigoLedModul" ;
    rdfs:domain ex:LedModul ;
    rdfs:range xsd:string .

ex:cantidadLedModul a owl:DatatypeProperty ;
    rdfs:label "cantidadLedModul" ;
    rdfs:domain ex:LedModul ;
    rdfs:range xsd:integer .

ex:funcionContacto a owl:DatatypeProperty ;
    rdfs:label "funcionContacto" ;
    rdfs:domain ex:Contacto ;
    rdfs:range xsd:string .

ex:fabricanteContacto a owl:DatatypeProperty ;
    rdfs:label "fabricanteContacto" ;
    rdfs:domain ex:Contacto ;
    rdfs:range xsd:string .

ex:codigoContacto a owl:DatatypeProperty ;
    rdfs:label "codigoContacto" ;
    rdfs:domain ex:Contacto ;
    rdfs:range xsd:string .

ex:cantidadContacto a owl:DatatypeProperty ;
    rdfs:label "cantidadContacto" ;
    rdfs:domain ex:Contacto ;
    rdfs:range xsd:integer .

ex:funcionLimitadorSobretension a owl:DatatypeProperty ;
    rdfs:label "funcionLimitadorSobretension" ;
    rdfs:domain ex:LimitadorSobretension ;
    rdfs:range xsd:string .

ex:fabricanteLimitadorSobretension a owl:DatatypeProperty ;
    rdfs:label "fabricanteLimitadorSobretension" ;
    rdfs:domain ex:LimitadorSobretension ;
    rdfs:range xsd:string .

ex:codigoLimitadorSobretension a owl:DatatypeProperty ;
    rdfs:label "codigoLimitadorSobretension" ;
    rdfs:domain ex:LimitadorSobretension ;
    rdfs:range xsd:string .

ex:cantidadLimitadorSobretension a owl:DatatypeProperty ;
    rdfs:label "cantidadLimitadorSobretension" ;
    rdfs:domain ex:LimitadorSobretension ;
    rdfs:range xsd:integer .

ex:Motor a owl:Class ;
    rdfs:label "Motor" ;
    rdfs:isDefinedBy motor:Motor .

ex:MotorEngrase a owl:Class ;
    rdfs:subClassOf ex:Motor ;
    rdfs:label "MotorEngrase" ;
    rdfs:comment "Motor de engrase" .

ex:MotorCintaEntrada a owl:Class ;
    rdfs:subClassOf ex:Motor ;
    rdfs:label "MotorCintaEntrada" ;
    rdfs:comment "Motor de cinta de entrada" .

ex:MotorRefrigeranteBrocha a owl:Class ;
    rdfs:subClassOf ex:Motor ;
    rdfs:label "MotorRefrigeranteBrocha" ;
    rdfs:comment "Motor refrigerante de brocha" .