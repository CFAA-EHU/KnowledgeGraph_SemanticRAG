@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:BREAKCASE6DejarLaHerramientaDelCabezalEnElAlmacenYCogerOtraDeTierra a ns1:Sistema ;
    ns1:textoExtracto "$BREAK $CASE 6 ; Dejar la herramienta del cabezal en el almacén y coger otra de tierra." ;
    ns1:tieneComponente ns1:LLSUBSPDTOGRQuitarLaHerramientaDelCabezal,
        ns1:LLSUBSPDTOGRQuitarLaHerramientaDelCabezalBREAKCASE5DejarLaHerramientaDelCabezalEnElAlmacenYCogerOtraDelAlmacen .

ns1:LLSUBCH1TOMZDejarLaHerramientaDeLaPinza1EnElAlmacenLLSUBMZTOCH1CogerLaHerramientaDelAlmacenConLaPinza1 a ns1:Sistema ;
    ns1:textoExtracto "LL SUB_CH1_TO_MZ ; Dejar la herramienta de la pinza 1 en el almacén. LL SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1." ;
    ns1:tieneComponente ns1:LLSUBSPDTOCH1CogerLaHerramientaDelCabezalConLaPinza1_54b4730bd0,
        ns1:LLSUBSPDTOGRQuitarLaHerramientaDelCabezalBREAKCASE5DejarLaHerramientaDelCabezalEnElAlmacenYCogerOtraDelAlmacen .

ns1:LLSUBCH1TOSPDLlevarLaHerramientaDeLaPinza1AlCabezal a ns1:Sistema ;
    ns1:textoExtracto "LL SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal." ;
    ns1:tieneComponente ns1:LLSUBSPDTOCH1CogerLaHerramientaDelCabezalConLaPinza1_54b4730bd0,
        ns1:LLSUBSPDTOGRQuitarLaHerramientaDelCabezal .

ns1:PuntoTierra1049 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "coger otra de tierra." .

ns1:PuntoCambioAutomatico1049 a ns1:InterfazUsuario ;
    ns1:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático." .

ns1:LLSUBSPDTOGRQuitarLaHerramientaDelCabezalBREAKCASE5DejarLaHerramientaDelCabezalEnElAlmacenYCogerOtraDelAlmacen a ns1:Sistema ;
    ns1:textoExtracto "LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal. $BREAK $CASE 5 ; Dejar la herramienta del cabezal en el almacén, y coger otra del almacén." ;
    ns1:tieneComponente ns1:LLSUBSPDTOCH1CogerLaHerramientaDelCabezalConLaPinza1_54b4730bd0,
        ns1:LLSUBSPDTOGRQuitarLaHerramientaDelCabezal,
        ns1:PuntoCambioAutomatico1049 .

ns1:LLSUBSPDTOCH1CogerLaHerramientaDelCabezalConLaPinza1_54b4730bd0 a ns1:Herramienta ;
    ns1:textoExtracto "LL SUB_SPD_TO_CH1 ; Coger la herramienta del cabezal con la pinza 1." .

ns1:LLSUBSPDTOGRQuitarLaHerramientaDelCabezal a ns1:ComponenteMecanico ;
    ns1:textoExtracto "LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal." .

