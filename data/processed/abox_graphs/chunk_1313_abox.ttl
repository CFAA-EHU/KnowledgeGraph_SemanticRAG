@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Cabezal_1052 a ns1:ComponenteMecanico ;
    rdfs:label "cabezal" ;
    ns1:textoExtracto "Quitar la herramienta del cabezal"@es .

ns1:CambioManual_1052 a ns1:ModoOperacion ;
    rdfs:label "cambio manual" ;
    ns1:textoExtracto "cambio manual. LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal. $BREAK $ENDSWITCH ; Fin análisis del tipo de operación. $WHILE V.TM.MZWAIT == 1 $ENDWHILE ; Espera al gestor del almacén. $ENDIF #DSBLK ; Fin de tratam..."@es .

ns1:GestorAlmacen_1052 a ns1:Sistema ;
    rdfs:label "gestor del almacén" ;
    ns1:textoExtracto "$WHILE V.TM.MZWAIT == 1 $ENDWHILE ; Espera al gestor del almacén"@es .

ns1:Herramienta_814cf4cb2c a ns1:Herramienta ;
    rdfs:label "herramienta" ;
    ns1:textoExtracto "Quitar la herramienta del cabezal"@es .

ns1:TeclaSTOP_1052 a ns1:InterfazUsuario ;
    rdfs:label "tecla STOP" ;
    ns1:textoExtracto "# ESTOP ; Habilitar la tecla STOP"@es .

