@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:CH1TOMZ a ns1:Sensor ;
    ns1:identificador "CH1TOMZ" ;
    ns1:textoExtracto "DFD CH1TOMZ = RES M1105" .

ns1:CH1TOSPDL a ns1:Sensor ;
    ns1:identificador "CH1TOSPDL" ;
    ns1:textoExtracto "DFD CH1TOSPDL = RES M1102" .

ns1:GRTOSPDL a ns1:Sensor ;
    ns1:identificador "GRTOSPDL" ;
    ns1:textoExtracto "DFD GRTOSPDL = RES M1108" .

ns1:M06 a ns1:TareaMantenimiento ;
    ns1:identificador "M06" ;
    ns1:textoExtracto "Cada vez que la rutina M06 finaliza una acción se lo indica al PLC para que active la marca correspondiente del gestor." .

ns1:M101 a ns1:TareaMantenimiento ;
    ns1:identificador "M101" ;
    ns1:textoExtracto "M101 Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1." .

ns1:M102 a ns1:TareaMantenimiento ;
    ns1:identificador "M102" ;
    ns1:textoExtracto "M102 Llevar la herramienta de la pinza 1 al cabezal." .

ns1:M103 a ns1:TareaMantenimiento ;
    ns1:identificador "M103" ;
    ns1:textoExtracto "M103 Coger la herramienta del cabezal con la pinza 1." .

ns1:M1101 a ns1:Sensor ;
    ns1:identificador "M1101" ;
    ns1:textoExtracto "DFU M1101 = SET MZTOCH1" .

ns1:M1102 a ns1:Sensor ;
    ns1:identificador "M1102" ;
    ns1:textoExtracto "DFU M1102 = SET CH1TOSPDL" .

ns1:M1103 a ns1:Sensor ;
    ns1:identificador "M1103" ;
    ns1:textoExtracto "DFU M1103 = SET SPDLTOCH1" .

ns1:M1105 a ns1:Sensor ;
    ns1:identificador "M1105" ;
    ns1:textoExtracto "DFU M1105 = SET CH1TOMZ" .

ns1:M1107 a ns1:Sensor ;
    ns1:identificador "M1107" ;
    ns1:textoExtracto "DFU M1107 = SET SPDLTOGR" .

ns1:M1108 a ns1:Sensor ;
    ns1:identificador "M1108" ;
    ns1:textoExtracto "DFU M1108 = SET GRTOSPDL" .

ns1:MZROT a ns1:Sensor ;
    ns1:identificador "MZROT" ;
    ns1:textoExtracto "Activar la marca MZROT para indicar al gestor que se ha finalizado la operación." .

ns1:MZTOCH1 a ns1:Sensor ;
    ns1:identificador "MZTOCH1" ;
    ns1:textoExtracto "DFD MZTOCH1 = RES M1101" .

ns1:PLC a ns1:Sistema ;
    ns1:identificador "PLC" ;
    ns1:textoExtracto "el gestor envía al PLC el código TMOPERATION=11" .

ns1:SPDLTOCH1 a ns1:Sensor ;
    ns1:identificador "SPDLTOCH1" ;
    ns1:textoExtracto "DFD SPDLTOCH1 = RES M1103" .

ns1:SPDLTOGR a ns1:Sensor ;
    ns1:identificador "SPDLTOGR" ;
    ns1:textoExtracto "DFD SPDLTOGR = RES M1107" .

ns1:TAKEPOS a ns1:Parametro ;
    ns1:identificador "TAKEPOS" ;
    ns1:textoExtracto "M101 Seleccionar en el almacén la posición que indica TAKEPOS" .

ns1:TMOPERATION a ns1:Parametro ;
    ns1:identificador "TMOPERATION" ;
    ns1:textoExtracto "Cuando se ejecuta la función –T– ... el gestor envía al PLC el código TMOPERATION=11." ;
    ns1:valor "11" .

ns1:almacen a ns1:Componente ;
    ns1:identificador "almacén" ;
    ns1:textoExtracto "orientar el almacén durante el mecanizado" .

ns1:cabezal a ns1:Componente ;
    ns1:identificador "cabezal" ;
    ns1:textoExtracto "Llevar la herramienta de la pinza 1 al cabezal" .

ns1:gestor a ns1:Sistema ;
    ns1:identificador "gestor" ;
    ns1:textoExtracto "el gestor envía al PLC el código TMOPERATION=11" .

ns1:pinza1 a ns1:Componente ;
    ns1:identificador "pinza 1" ;
    ns1:textoExtracto "coger la herramienta con la pinza 1" .

ns1:tierra a ns1:Componente ;
    ns1:identificador "tierra" ;
    ns1:textoExtracto "La herramienta se ha llevado del cabezal a tierra" .

