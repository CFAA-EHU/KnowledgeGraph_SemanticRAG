@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LEAVEPOS a ns1:Parametro ;
    rdfs:label "LEAVEPOS" ;
    ns1:textoExtracto "Este registro indica la posición de almacén en la que hay que dejar la herramienta." .

ns1:M101 a ns1:TareaMantenimiento ;
    rdfs:label "M101" ;
    ns1:identificador "M101" ;
    ns1:textoExtracto "Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1." .

ns1:M102 a ns1:TareaMantenimiento ;
    rdfs:label "M102" ;
    ns1:identificador "M102" ;
    ns1:textoExtracto "Llevar la herramienta de la pinza 1 al cabezal." .

ns1:M103 a ns1:TareaMantenimiento ;
    rdfs:label "M103" ;
    ns1:identificador "M103" ;
    ns1:textoExtracto "Coger la herramienta del cabezal con la pinza 1." .

ns1:M105 a ns1:TareaMantenimiento ;
    rdfs:label "M105" ;
    ns1:identificador "M105" ;
    ns1:textoExtracto "Seleccionar en el almacén la posición que indica LEAVEPOS y dejar la herramienta de la pinza 1." .

ns1:Pinza1_c77f536a49 a ns1:Componente ;
    rdfs:label "pinza 1" ;
    ns1:textoExtracto "dejar la herramienta de la pinza 1" .

ns1:TAKEPOS a ns1:Parametro ;
    rdfs:label "TAKEPOS" ;
    ns1:textoExtracto "Este registro indica la posición de almacén en la que hay que coger la herramienta." .

ns1:almacen a ns1:Componente ;
    rdfs:label "almacén" ;
    ns1:textoExtracto "Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1." .

ns1:cabezal a ns1:Componente ;
    rdfs:label "cabezal" ;
    ns1:textoExtracto "Llevar la herramienta de la pinza 1 al cabezal." .

