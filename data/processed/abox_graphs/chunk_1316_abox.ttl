@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:B11KEYBD1 a ns1:InterfazUsuario ;
    rdfs:label "B11KEYBD1" ;
    ns1:textoExtracto "DFU B11KEYBD1 AND NOT TMINEM = SET SETTMEM" .

ns1:B11KEYLED1 a ns1:ComponenteElectrico ;
    rdfs:label "B11KEYLED1" ;
    ns1:textoExtracto "B11KEYLED1 Lámpara de la tecla USER12 iluminada cuando hay emergencia." .

ns1:B12KEYBD1 a ns1:InterfazUsuario ;
    rdfs:label "B12KEYBD1" ;
    ns1:textoExtracto "TMINEM AND DFU B12KEYBD1 = SET RESTMEM" .

ns1:LEAVEPOS a ns1:Parametro ;
    rdfs:label "LEAVEPOS" ;
    ns1:textoExtracto "Este registro indica la posición de almacén en la que hay que dejar la herramienta." .

ns1:SenalEmergenciaGestor a ns1:Sensor ;
    rdfs:label "Señal de emergencia del gestor" ;
    ns1:textoExtracto "Señal de emergencia del gestor. Tratamiento de la señal de emergencia del gestor de herramientas." .

ns1:TAKEPOS a ns1:Parametro ;
    rdfs:label "TAKEPOS" ;
    ns1:textoExtracto "Este registro indica la posición de almacén que ocupa la herramienta que hay que coger." .

ns1:TMINEM a ns1:Parametro ;
    rdfs:label "TMINEM" ;
    ns1:textoExtracto "TMINEM = B11KEYLED1 Lámpara de la tecla USER12 iluminada cuando hay emergencia." .

ns1:USER12 a ns1:InterfazUsuario ;
    rdfs:label "tecla USER12" ;
    ns1:textoExtracto "Si se pulsa la tecla USER12 se activa la emergencia." .

ns1:USER13 a ns1:InterfazUsuario ;
    rdfs:label "tecla USER13" ;
    ns1:textoExtracto "Si se pulsa la tecla USER13 se quita la emergencia." .

