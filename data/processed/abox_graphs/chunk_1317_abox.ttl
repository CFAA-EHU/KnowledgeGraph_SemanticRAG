@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:BrazoCambiador a ns1:ComponenteMecanico ;
    ns1:textoExtracto "el cambio se realiza con ayuda del brazo cambiador" .

ns1:CuandoElCNCEjecutaLaFuncionT a ns1:Sistema ;
    ns1:textoExtracto "Cuando el CNC ejecuta la función T" .

ns1:DesplazamientoAlmacen a ns1:ComponenteMecanico ;
    ns1:textoExtracto "desplazamiento almacén" .

ns1:DispositivosExternos a ns1:Componente ;
    ns1:textoExtracto "el control de los dispositivos externos" .

ns1:GestorHerramientas a ns1:Sistema ;
    ns1:textoExtracto "La comunicación entre el gestor y el PLC se realiza en 2 fases; la primera con la ejecución de la función T y la segunda con la ejecución de la función M06." .

ns1:GiroAlmacen a ns1:ComponenteMecanico ;
    ns1:textoExtracto "giro almacén" .

ns1:LaComunicacionEntreElGestorYElPLCSeRealizaEn2Fases a ns1:ComponenteElectrico ;
    ns1:textoExtracto "La comunicación entre el gestor y el PLC se realiza en 2 fases" .

ns1:LaEjecucionDeLaFuncionM06 a ns1:ModoOperacion ;
    ns1:textoExtracto "la ejecución de la función M06" .

ns1:LaEjecucionDeLaFuncionT a ns1:ModoOperacion ;
    ns1:textoExtracto "la ejecución de la función T" .

ns1:LosAlmacenesSincronosConBrazoCambiador1O2PinzasTienenElAlmacenProximoAlCabezalYElCambioSeRealizaConAyudaDelBrazoCambiador a ns1:Sistema ;
    ns1:textoExtracto "Los almacenes síncronos con brazo cambiador (1 o 2 pinzas) tienen el almacén próximo al cabezal y el cambio se realiza con ayuda del brazo cambiador." .

ns1:RutinaAsociadaM06 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "realiza una llamada a la rutina asociada. Dentro de dicha rutina hay que volver a programar la función M06" .

ns1:SeleccioneLaProximaHerramientaEnElAlmacen a ns1:Componente ;
    ns1:textoExtracto "seleccione la próxima herramienta en el almacén" .

