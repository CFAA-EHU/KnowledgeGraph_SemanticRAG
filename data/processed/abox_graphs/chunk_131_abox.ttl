@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix siemens: <http://www.siemens.com/> .
@prefix weidmuller: <http://www.weidmuller.com/> .
@prefix admin: <https://admin-shell.io/dictionary/> .

ex:Motor a owl:Class ;
    rdfs:label "Motor" ;
    rdfs:isDefinedBy admin:Motor .

ex:Contacto a owl:Class ;
    rdfs:label "Contacto" .

ex:ContactModule a owl:Class ;
    rdfs:label "ContactModule" .

ex:Varistor a owl:Class ;
    rdfs:label "Varistor" .

ex:AcopladorPorRelé a owl:Class ;
    rdfs:label "AcopladorPorRelé" .

ex:Contactor a owl:Class ;
    rdfs:label "Contactor" .

ex:ContactorAuxiliar a owl:Class ;
    rdfs:label "ContactorAuxiliar" .

ex:LimitadorSobretension a owl:Class ;
    rdfs:label "LimitadorSobretension" .

ex:Climatizador a owl:Class ;
    rdfs:label "Climatizador" .

ex:PLC a owl:Class ;
    rdfs:label "PLC" .

ex:Iluminacion a owl:Class ;
    rdfs:label "Iluminacion" .

ex:MotorLimpiezaBastidor a owl:Class ;
    rdfs:subClassOf ex:Motor .

ex:MotorEngrase a owl:Class ;
    rdfs:subClassOf ex:Motor .

ex:MarchaMotorLimpiezaBastidor a owl:ObjectProperty ;
    rdfs:label "MarchaMotorLimpiezaBastidor" .

ex:MarchaMotorEngrase a owl:ObjectProperty ;
    rdfs:label "MarchaMotorEngrase" .

ex:IluminacionClimatizadorArmario a owl:ObjectProperty ;
    rdfs:label "IluminacionClimatizadorArmario" .

ex:PLC_OK a owl:ObjectProperty ;
    rdfs:label "PLC_OK" .

ex:fabricante a owl:DatatypeProperty ;
    rdfs:label "fabricante" ;
    rdfs:domain ex:Objeto ;
    rdfs:range rdfs:Literal .

ex:modelo a owl:DatatypeProperty ;
    rdfs:label "modelo" ;
    rdfs:domain ex:Objeto ;
    rdfs:range rdfs:Literal .

ex:cantidad a owl:DatatypeProperty ;
    rdfs:label "cantidad" ;
    rdfs:domain ex:Objeto ;
    rdfs:range rdfs:Literal .

ex:MotorLimpiezaBastidor1 a ex:MotorLimpiezaBastidor ;
    ex:fabricante "SIEMENS AG" ;
    ex:modelo "3RT2024-1BB40" ;
    ex:cantidad "1" .

ex:LimitadorSobretension1 a ex:LimitadorSobretension ;
    ex:fabricante "SIEMENS AG" ;
    ex:modelo "3RT2926-1BB00" ;
    ex:cantidad "1" .

ex:Varistor1 a ex:Varistor ;
    ex:fabricante "SIEMENS AG" ;
    ex:modelo "3RT2926-1BB00" ;
    ex:cantidad "1" .

ex:MotorEngrase1 a ex:MotorEngrase ;
    ex:fabricante "SIEMENS AG" ;
    ex:modelo "3RT2024-1BB40" ;
    ex:cantidad "1" .

ex:LimitadorSobretension2 a ex:LimitadorSobretension ;
    ex:fabricante "SIEMENS AG" ;
    ex:modelo "3RT2926-1BB00" ;
    ex:cantidad "1" .

ex:Varistor2 a ex:Varistor ;
    ex:fabricante "SIEMENS AG" ;
    ex:modelo "3RT2926-1BB00" ;
    ex:cantidad "1" .

ex:AcopladorPorRelé1 a ex:AcopladorPorRelé ;
    ex:fabricante "WEIDMÜLLER" ;
    ex:modelo "MRZ 24VDC 1CO" ;
    ex:cantidad "1" .

ex:AcopladorPorRelé2 a ex:AcopladorPorRelé ;
    ex:fabricante "WEIDMÜLLER" ;
    ex:modelo "MRZ 24VDC 1CO" ;
    ex:cantidad "1" .

ex:AcopladorPorRelé3 a ex:AcopladorPorRelé ;
    ex:fabricante "WEIDMÜLLER" ;
    ex:modelo "MRZ 24VDC 1CO" ;
    ex:cantidad "1" .

ex:Contacto1 a ex:Contacto ;
    ex:fabricante "SIEMENS AG" ;
    ex:modelo "5TT5800-0" ;
    ex:cantidad "1" .

ex:ContactModule1 a ex:ContactModule ;
    ex:fabricante "SIEMENS AG" ;
    ex:modelo "5TT5800-0" ;
    ex:cantidad "1" .

ex:ContactorAuxiliar1 a ex:ContactorAuxiliar ;
    ex:fabricante "SIEMENS AG" ;
    ex:modelo "3RH2140-1BB40" ;
    ex:cantidad "1" .

ex:PLC1 a ex:PLC ;
    ex:fabricante "SIEMENS AG" ;
    ex:modelo "3RH2140-1BB40" ;
    ex:cantidad "1" .