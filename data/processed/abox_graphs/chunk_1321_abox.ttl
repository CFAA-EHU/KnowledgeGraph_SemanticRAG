@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:OperacionAlmacen a ns1:InterfazUsuario ;
    rdfs:label "Descripción detallada de las operaciones del almacén" ;
    ns1:textoExtracto "A continuación se muestra una descripción detallada de las operaciones válidas para este almacén. Para cada operación se indica cuales de las señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas, así como su signif..." ;
    ns1:tieneComponente ns1:LEAVEPOS,
        ns1:MZID,
        ns1:NEXTPOS,
        ns1:TAKEPOS .

ns1:LEAVEPOS a ns1:Sensor ;
    rdfs:label "LEAVEPOS" ;
    ns1:textoExtracto "señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID" .

ns1:MZID a ns1:Sensor ;
    rdfs:label "MZID" ;
    ns1:textoExtracto "señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID" .

ns1:NEXTPOS a ns1:Sensor ;
    rdfs:label "NEXTPOS" ;
    ns1:textoExtracto "señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID" .

ns1:TAKEPOS a ns1:Sensor ;
    rdfs:label "TAKEPOS" ;
    ns1:textoExtracto "señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID" .

