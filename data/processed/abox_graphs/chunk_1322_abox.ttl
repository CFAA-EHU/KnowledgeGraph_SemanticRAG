@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Valor0 a ns1:Parametro ;
    rdfs:label "0" ;
    ns1:textoExtracto "Valor: 0 | Significado: No hay que hacer nada." ;
    ns1:valor "0" .

ns1:ValorMenos4 a ns1:Parametro ;
    rdfs:label "-4" ;
    ns1:textoExtracto "Valor: -4 | Significado: Herramienta de tierra." ;
    ns1:valor "-4" .

ns1:ValorNumeral a ns1:Parametro ;
    rdfs:label "#" ;
    ns1:textoExtracto "Valor: # | Significado: Posición en el almacén." ;
    ns1:valor "#" .

