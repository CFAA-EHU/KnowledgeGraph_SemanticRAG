@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Almacen_77304b8761 a ns1:Sistema ;
    rdfs:label "Almacén" ;
    ns1:textoExtracto "del almacén para dejar la herramienta. La secuencia de esta operación es la siguiente. El gestor también admite la secuencia 1-3-2. 1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 2 Deja..." ;
    ns1:tieneComponente ns1:HerramientaDeTierra_96fad5c1d5,
        ns1:Pinza1_ec27c38f9a,
        ns1:Pinza2_7fbf274966 .

ns1:HerramientaDeTierra_96fad5c1d5 a ns1:Herramienta ;
    rdfs:label "Herramienta de tierra" ;
    ns1:textoExtracto "Herramienta de tierra" .

ns1:Pinza1_ec27c38f9a a ns1:Herramienta ;
    rdfs:label "Pinza 1" ;
    ns1:textoExtracto "Coger la herramienta del almacén con la pinza ꞏ1ꞏ" .

ns1:Pinza2_7fbf274966 a ns1:Herramienta ;
    rdfs:label "Pinza 2" ;
    ns1:textoExtracto "Coger la herramienta del cabezal con la pinza ꞏ2ꞏ" .

