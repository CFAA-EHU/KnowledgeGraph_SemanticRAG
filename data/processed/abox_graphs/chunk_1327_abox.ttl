@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Almacen_93c58c237d a ns1:Sistema ;
    rdfs:label "almacén" ;
    ns1:textoExtracto "Orientar el almacén. Esta operación es una optimización del cambio de herramienta que permite orientar el almacén durante el mecanizado." .

ns1:Cabezal_4305496a44 a ns1:ComponenteMecanico ;
    rdfs:label "cabezal" ;
    ns1:textoExtracto "Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL." .

ns1:HerramientaDeTierra_e3daa42696 a ns1:ComponenteElectrico ;
    rdfs:label "Herramienta de tierra" ;
    ns1:textoExtracto "Herramienta de tierra. La secuencia de esta operación es la siguiente. 1 Coger la herramienta del almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1." .

ns1:MarcaCH1TOSPDL a ns1:Parametro ;
    rdfs:label "CH1TOSPDL" ;
    ns1:identificador "CH1TOSPDL" ;
    ns1:textoExtracto "activar la marca CH1TOSPDL" .

ns1:MarcaMZROT a ns1:Parametro ;
    rdfs:label "MZROT" ;
    ns1:identificador "MZROT" ;
    ns1:textoExtracto "Activar la marca MZROT para indicar que ha finalizado la operación, se haya orientado el almacén o no." .

ns1:MarcaMZROT_Almacen1 a ns1:Parametro ;
    rdfs:label "MZROT" ;
    ns1:identificador "MZROT" ;
    ns1:textoExtracto "Activar la marca MZROT en ambos almacenes para indicar que ha finalizado la operación, se hayan orientado los almacenes o no." .

ns1:MarcaMZTOCH1 a ns1:Parametro ;
    rdfs:label "MZTOCH1" ;
    ns1:identificador "MZTOCH1" ;
    ns1:textoExtracto "activar la marca MZTOCH1" .

ns1:MarcaSPDLTOGR a ns1:Parametro ;
    rdfs:label "SPDLTOGR" ;
    ns1:identificador "SPDLTOGR" ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en tierra y activar la marca SPDLTOGR." .

ns1:Pinza1_c596d2434b a ns1:ComponenteMecanico ;
    rdfs:label "pinza 1" ;
    ns1:textoExtracto "Coger la herramienta del almacén con la pinza ꞏ1ꞏ" .

ns1:RegistroMZID a ns1:Tabla ;
    rdfs:label "MZID" ;
    ns1:textoExtracto "En la parte baja de este registro se indica el almacén en el que hay que dejar la herramienta y en la parte alta el almacén del que hay que coger la herramienta." .

ns1:TMOPERATION11_6414eda96d a ns1:ModoOperacion ;
    rdfs:label "TMOPERATION 11" ;
    ns1:identificador "TMOPERATION = 11" ;
    ns1:textoExtracto "TMOPERATION = 11 Orientar el almacén." .

ns1:TMOPERATION12_d327e30722 a ns1:ModoOperacion ;
    rdfs:label "TMOPERATION 12" ;
    ns1:identificador "TMOPERATION = 12" ;
    ns1:textoExtracto "TMOPERATION = 12 Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén (como TMOPERATION=5)." .

ns1:TMOPERATION13_0a49faa450 a ns1:ModoOperacion ;
    rdfs:label "TMOPERATION 13" ;
    ns1:identificador "TMOPERATION = 13" ;
    ns1:textoExtracto "TMOPERATION = 13 Orientar dos almacenes." .

ns1:TMOPERATION14_aa09030a8d a ns1:ModoOperacion ;
    rdfs:label "TMOPERATION 14" ;
    ns1:identificador "TMOPERATION = 14" ;
    ns1:textoExtracto "TMOPERATION = 14 Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén." .

