@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:OperacionAlmacen a ns1:TareaMantenimiento ;
    ns1:compuestoPor ns1:Almacen_97f205a2c1,
        ns1:CH1TOSPDL_cdab9646c8,
        ns1:CH2TOMZ_fe1c2a051b,
        ns1:Cabezal_473f61fb80,
        ns1:Entity1_f77ec20ffb,
        ns1:Entity2_bf836a9e9f,
        ns1:MZTOCH1_fcbc0c8b30,
        ns1:SPDLTOCH2_95d3451f8b ;
    ns1:textoExtracto "La secuencia de esta operación es la siguiente. 1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 2 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ. 3 Coger la herramienta del otro almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1. 4 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL" .

ns1:Almacen_97f205a2c1 a ns1:Sistema ;
    ns1:textoExtracto "almacén" .

ns1:CH1TOSPDL_cdab9646c8 a ns1:Parametro ;
    ns1:identificador "CH1TOSPDL" ;
    ns1:textoExtracto "activar la marca CH1TOSPDL" .

ns1:CH2TOMZ_fe1c2a051b a ns1:Parametro ;
    ns1:identificador "CH2TOMZ" ;
    ns1:textoExtracto "activar la marca CH2TOMZ" .

ns1:Cabezal_473f61fb80 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "cabezal" .

ns1:Entity1_f77ec20ffb a ns1:Herramienta ;
    ns1:identificador "1" ;
    ns1:textoExtracto "pinza ꞏ1ꞏ" .

ns1:Entity2_bf836a9e9f a ns1:Herramienta ;
    ns1:identificador "2" ;
    ns1:textoExtracto "pinza ꞏ2ꞏ" .

ns1:MZTOCH1_fcbc0c8b30 a ns1:Parametro ;
    ns1:identificador "MZTOCH1" ;
    ns1:textoExtracto "activar la marca MZTOCH1" .

ns1:SPDLTOCH2_95d3451f8b a ns1:Parametro ;
