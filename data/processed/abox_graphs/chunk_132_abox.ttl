@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:LimitadorSobretension a owl:Class ;
    rdfs:label "Limitador Sobretension"@es ;
    rdfs:comment "Componente eléctrico que limita la sobretensión en el sistema."@es .

ex:VaristorConLed a owl:Class ;
    rdfs:label "Varistor Con LED"@es ;
    rdfs:comment "Componente eléctrico que limita la sobretensión y tiene un LED indicador."@es .

ex:ContactoAuxiliar a owl:Class ;
    rdfs:label "Contacto Auxiliar"@es ;
    rdfs:comment "Contacto auxiliar utilizado en sistemas eléctricos."@es .

ex:ContactoNormalmenteAbierto a owl:Class ;
    rdfs:label "Contacto Normalmente Abierto"@es ;
    rdfs:comment "Contacto que está abierto en su estado normal."@es .

ex:ContactoNormalmenteCerrado a owl:Class ;
    rdfs:label "Contacto Normalmente Cerrado"@es ;
    rdfs:comment "Contacto que está cerrado en su estado normal."@es .

ex:PLC a owl:Class ;
    rdfs:label "PLC"@es ;
    rdfs:comment "Controlador lógico programable."@es .

ex:SiemensAG a owl:Class ;
    rdfs:label "Siemens AG"@es ;
    rdfs:comment "Empresa fabricante de componentes eléctricos."@es .

ex:tieneDesignacion a owl:ObjectProperty ;
    rdfs:label "tieneDesignacion"@es ;
    rdfs:comment "Relación que indica la designación de un componente."@es .

ex:tieneUtilizacion a owl:ObjectProperty ;
    rdfs:label "tieneUtilizacion"@es ;
    rdfs:comment "Relación que indica la utilización de un componente."@es .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:label "tieneFabricante"@es ;
    rdfs:comment "Relación que indica el fabricante de un componente."@es .

ex:tieneReferencia a owl:ObjectProperty ;
    rdfs:label "tieneReferencia"@es ;
    rdfs:comment "Relación que indica la referencia de un componente."@es .

ex:tieneCantidad a owl:ObjectProperty ;
    rdfs:label "tieneCantidad"@es ;
    rdfs:comment "Relación que indica la cantidad de un componente."@es .

ex:tieneModelo a owl:ObjectProperty ;
    rdfs:label "tieneModelo"@es ;
    rdfs:comment "Relación que indica el modelo de un componente."@es .

ex:tieneVoltaje a owl:DatatypeProperty ;
    rdfs:label "tieneVoltaje"@es ;
    rdfs:comment "Relación que indica el voltaje de un componente."@es ;
    rdfs:range xsd:decimal .

ex:tieneNumeroContactos a owl:DatatypeProperty ;
    rdfs:label "tieneNumeroContactos"@es ;
    rdfs:comment "Relación que indica el número de contactos de un componente."@es ;
    rdfs:range xsd:integer .