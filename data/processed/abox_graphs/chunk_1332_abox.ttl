@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalMaquina a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de la máquina" ;
    ns1:textoExtracto "G1 Z_ F_ ; Desplazar el cabezal." ;
    ns1:tieneComponente ns1:PuntoCambioAutomatico,
        ns1:PuntoCambioManual .

ns1:HerramientaT a ns1:Herramienta ;
    rdfs:label "Herramienta T%D" ;
    ns1:identificador "T%D" ;
    ns1:textoExtracto "Insertar herramienta T%D" .

ns1:InterfazMensajeM06 a ns1:InterfazUsuario ;
    rdfs:label "Mensaje de inserción de herramienta (M06)" ;
    ns1:ilustradoEn ns1:RutinaM06 ;
    ns1:textoExtracto "MSG [\"Insertar herramienta T%D y pulsar MARCHA\", V.TM.NXTOOL] ; Mensaje al operario para que ponga la herramienta." .

ns1:MarcaGRTOSPDL a ns1:Parametro ;
    rdfs:label "Marca GRTOSPDL (M[1108])" ;
    ns1:identificador "M[1108]" ;
    ns1:monitoreaParametro ns1:RutinaM06 ;
    ns1:textoExtracto "V.PLC.M[1108]=1 ; Marca GRTOSPDL al gestor." ;
    ns1:valor "1" .

ns1:TeclaMarcha a ns1:ComponenteElectrico ;
    rdfs:label "Tecla MARCHA" ;
    ns1:textoExtracto "pulsar MARCHA" .

ns1:TeclaSTOP a ns1:ComponenteElectrico ;
    rdfs:label "Tecla STOP" ;
    ns1:controla ns1:RutinaM06 ;
    ns1:textoExtracto "Deshabilitar tecla STOP" .

ns1:CambioHerramienta a ns1:ModoOperacion ;
    rdfs:label "Cambio de herramienta (manual/automático)" ;
    ns1:ejecutadoPor ns1:PersonalOperario ;
    ns1:textoExtracto "SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual. [...] SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático." .

ns1:PersonalOperario a ns1:Personal ;
    rdfs:label "Operario de máquina" ;
    ns1:textoExtracto "MSG [\"Insertar herramienta T%D y pulsar MARCHA\", V.TM.NXTOOL] ; Mensaje al operario para que ponga la herramienta." .

ns1:PuntoCambioAutomatico a ns1:ComponenteMecanico ;
    rdfs:label "Punto de cambio automático de herramienta" ;
    ns1:textoExtracto "SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático." .

ns1:PuntoCambioManual a ns1:ComponenteMecanico ;
    rdfs:label "Punto de cambio manual de herramienta" ;
    ns1:textoExtracto "SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual." .

ns1:RutinaM06 a ns1:TareaMantenimiento ;
    rdfs:label "Rutina M06 (Cambio de herramienta)" ;
    ns1:identificador "M06" ;
    ns1:requiereMantenimiento ns1:CambioHerramienta ;
    ns1:textoExtracto "MSG [\"Insertar herramienta T%D y pulsar MARCHA\", V.TM.NXTOOL] ; [...] M6 ; Orden al gestor para comenzar el cambio de herramienta." .

