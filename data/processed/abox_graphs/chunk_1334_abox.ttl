@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LL_SUB_CH1_TO_SPD a ns1:TareaMantenimiento ;
    rdfs:label "LL SUB_CH1_TO_SPD" ;
    ns1:textoExtracto "LL SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal." ;
    ns1:tieneComponente ns1:Pinza1_77ce94a31d,
        ns1:cabezal,
        ns1:herramienta .

ns1:LL_SUB_CH2_TO_MZ a ns1:TareaMantenimiento ;
    rdfs:label "LL SUB_CH2_TO_MZ" ;
    ns1:textoExtracto "LL SUB_CH2_TO_MZ ; Dejar la herramienta de la pinza 2 en el almacén." ;
    ns1:tieneComponente ns1:Pinza2_78b2425d02,
        ns1:almacen,
        ns1:herramienta .

ns1:LL_SUB_MZ_TO_CH1 a ns1:TareaMantenimiento ;
    rdfs:label "LL SUB_MZ_TO_CH1" ;
    ns1:textoExtracto "LL SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1." ;
    ns1:tieneComponente ns1:Pinza1_77ce94a31d,
        ns1:almacen,
        ns1:herramienta .

ns1:LL_SUB_SPD_AUTCHG a ns1:TareaMantenimiento ;
    rdfs:label "LL SUB_SPD_AUTCHG" ;
    ns1:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático." ;
    ns1:tieneComponente ns1:cabezal,
        ns1:punto_de_cambio_automatico .

ns1:LL_SUB_SPD_TO_CH2 a ns1:TareaMantenimiento ;
    rdfs:label "LL SUB_SPD_TO_CH2" ;
    ns1:textoExtracto "LL SUB_SPD_TO_CH2 ; Coger la herramienta del cabezal con la pinza 2." ;
    ns1:tieneComponente ns1:Pinza2_78b2425d02,
        ns1:cabezal,
        ns1:herramienta .

ns1:LL_SUB_SPD_TO_GR a ns1:TareaMantenimiento ;
    rdfs:label "LL SUB_SPD_TO_GR" ;
    ns1:textoExtracto "LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal." ;
    ns1:tieneComponente ns1:cabezal,
        ns1:herramienta .

ns1:punto_de_cambio_automatico a ns1:ModoOperacion ;
    rdfs:label "punto de cambio automático" ;
    ns1:textoExtracto "punto de cambio automático" .

ns1:Pinza1_77ce94a31d a ns1:ComponenteMecanico ;
    rdfs:label "pinza 1" ;
    ns1:textoExtracto "pinza 1" .

ns1:Pinza2_78b2425d02 a ns1:ComponenteMecanico ;
    rdfs:label "pinza 2" ;
    ns1:textoExtracto "pinza 2" .

ns1:almacen a ns1:Sistema ;
    rdfs:label "almacén" ;
    ns1:textoExtracto "almacén" .

ns1:cabezal a ns1:ComponenteMecanico ;
    rdfs:label "cabezal" ;
    ns1:textoExtracto "cabezal" .

ns1:herramienta a ns1:PiezaRecambio ;
    rdfs:label "herramienta" ;
    ns1:textoExtracto "herramienta" .

