@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:ActivarLaMarcaMZROTParaIndicarAlGestorQueSeHaFinalizadoLaOperacion a ns1:Sensor ;
    ns1:textoExtracto "Activar la marca MZROT para indicar al gestor que se ha finalizado la operación." .

ns1:CadaVezQueLaRutinaM06FinalizaUnaAccionSeLoIndicaAlPLCParaQueActiveLaMarcaCorrespondienteDelGestor a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Cada vez que la rutina M06 finaliza una acción se lo indica al PLC para que active la marca correspondiente del gestor." .

ns1:CuandoSeEjecutaLaFuncionTCuandoSeEjecutaLaFuncionTElGestorEnviaAlPLCElCodigoTMOPERATION11 a ns1:Parametro ;
    ns1:textoExtracto "Cuando se ejecuta la función –T– Cuando se ejecuta la función T el gestor envía al PLC el código TMOPERATION=11." ;
    ns1:valor "11" .

ns1:DFUM1101SETMZTOCH1DFDMZTOCH1RESM1101LaHerramientaSeHaLlevadoDelAlmacenALaPinza1 a ns1:Sensor ;
    ns1:textoExtracto "DFU M1101 = SET MZTOCH1 DFD MZTOCH1 = RES M1101 La herramienta se ha llevado del almacén a la pinza 1." .

ns1:DFUM1102SETCH1TOSPDLDFDCH1TOSPDLRESM1102LaHerramientaSeHaLlevadoDeLaPinza1AlCabezal a ns1:Sensor ;
    ns1:textoExtracto "DFU M1102 = SET CH1TOSPDL DFD CH1TOSPDL = RES M1102 La herramienta se ha llevado de la pinza 1 al cabezal." .

ns1:DFUM1104SETSPDLTOCH2DFDSPDLTOCH2RESM1104LaHerramientaSeHaLlevadoDelCabezalALaPinza2 a ns1:Sensor ;
    ns1:textoExtracto "DFU M1104 = SET SPDLTOCH2 DFD SPDLTOCH2 = RES M1104 La herramienta se ha llevado del cabezal a la pinza 2." .

ns1:DFUM1106SETCH2TOMZDFDCH2TOMZRESM1106LaHerramientaSeHaLlevadoDeLaPinza2AlAlmacen a ns1:Sensor ;
    ns1:textoExtracto "DFU M1106 = SET CH2TOMZ DFD CH2TOMZ = RES M1106 La herramienta se ha llevado de la pinza 2 al almacén." .

ns1:DFUM1107SETSPDLTOGRDFDSPDLTOGRRESM1107LaHerramientaSeHaLlevadoDelCabezalATierra a ns1:Sensor ;
    ns1:textoExtracto "DFU M1107 = SET SPDLTOGR DFD SPDLTOGR = RES M1107 La herramienta se ha llevado del cabezal a tierra." .

ns1:DFUM1108SETGRTOSPDLDFDGRTOSPDLRESM1108LaHerramientaSeHaLlevadoDeTierraAlCabezal a ns1:Sensor ;
    ns1:textoExtracto "DFU M1108 = SET GRTOSPDL DFD GRTOSPDL = RES M1108 La herramienta se ha llevado de tierra al cabezal." .

ns1:M101SeleccionarEnElAlmacenLaPosicionQueIndicaTAKEPOSYCogerLaHerramientaConLaPinza1 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "M101 Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1." .

ns1:M101SeleccionarEnElAlmacenLaPosicionQueIndicaTAKEPOSYCogerLaHerramientaConLaPinza1_7e5e37b0d3 a ns1:Parametro ;
    ns1:textoExtracto "M101 Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1." .

ns1:M102LlevarLaHerramientaDeLaPinza1AlCabezal a ns1:TareaMantenimiento ;
    ns1:textoExtracto "M102 Llevar la herramienta de la pinza 1 al cabezal." .

ns1:M104CogerLaHerramientaDelCabezalConLaPinza2 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "M104 Coger la herramienta del cabezal con la pinza 2." .

