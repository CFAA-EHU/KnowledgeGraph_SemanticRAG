@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Almacen a ns1:Componente ;
    rdfs:label "almacén" ;
    ns1:textoExtracto "almacén" .

ns1:Cabezal a ns1:Componente ;
    rdfs:label "cabezal" ;
    ns1:textoExtracto "cabezal" .

ns1:LEAVEPOS a ns1:Parametro ;
    rdfs:label "LEAVEPOS" ;
    ns1:textoExtracto "LEAVEPOS" .

ns1:M101 a ns1:TareaMantenimiento ;
    rdfs:label "M101" ;
    ns1:identificador "M101" ;
    ns1:textoExtracto "Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1." .

ns1:M102 a ns1:TareaMantenimiento ;
    rdfs:label "M102" ;
    ns1:identificador "M102" ;
    ns1:textoExtracto "Llevar la herramienta de la pinza 1 al cabezal." .

ns1:M104 a ns1:TareaMantenimiento ;
    rdfs:label "M104" ;
    ns1:identificador "M104" ;
    ns1:textoExtracto "Coger la herramienta del cabezal con la pinza 2." .

ns1:M106 a ns1:TareaMantenimiento ;
    rdfs:label "M106" ;
    ns1:identificador "M106" ;
    ns1:textoExtracto "Seleccionar en el almacén la posición que indica LEAVEPOS y dejar la herramienta de la pinza 2." .

ns1:Pinza1_f2a3cf22da a ns1:Componente ;
    rdfs:label "pinza 1" ;
    ns1:textoExtracto "pinza 1" .

ns1:Pinza2_c04bc90632 a ns1:Componente ;
    rdfs:label "pinza 2" ;
    ns1:textoExtracto "pinza 2" .

ns1:ProgramacionBasicaPLC a ns1:TareaMantenimiento ;
    rdfs:label "Programación básica del PLC" ;
    ns1:textoExtracto "Su programación depende del tipo de máquina. La función auxiliar se dará por finalizada tras ejecutar el movimiento solicitado. En determinadas operaciones hay que utilizar la información que pasa el gestor en los siguientes registros: LEAVEPOS Este registro indica la posición de almacén en la que hay que dejar la herramienta. TAKEPOS Este registro indica la posición de almacén en la que hay que coger la herramienta." .

ns1:TAKEPOS a ns1:Parametro ;
    rdfs:label "TAKEPOS" ;
    ns1:textoExtracto "TAKEPOS" .

