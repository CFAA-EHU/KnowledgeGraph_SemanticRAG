@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:GestorHerramientas a ns1:Sistema ;
    rdfs:label "gestor de herramientas" ;
    ns1:textoExtracto "operaciones hay que utilizar la información que pasa el gestor en los siguientes registros: LEAVEPOS Este registro indica la posición de almacén en la que hay que dejar la herramienta. TAKEPOS Este registro indica la posición de almacén que ocupa la herramienta que hay que coger. Señal de emergencia del gestor. Tratamiento de la señal de emergencia del gestor de herramientas." ;
    ns1:tieneComponente ns1:B11KEYBD1,
        ns1:B11KEYLED1,
        ns1:B12KEYBD1,
        ns1:LEAVEPOS,
        ns1:TAKEPOS,
        ns1:TMINEM,
        ns1:USER12,
        ns1:USER13 .

ns1:B11KEYBD1 a ns1:Sensor ;
    rdfs:label "B11KEYBD1" ;
    ns1:identificador "B11KEYBD1" ;
    ns1:textoExtracto "DFU B11KEYBD1 AND NOT TMINEM = SET SETTMEM" .

ns1:B11KEYLED1 a ns1:Sensor ;
    rdfs:label "B11KEYLED1" ;
    ns1:identificador "B11KEYLED1" ;
    ns1:textoExtracto "Lámpara de la tecla USER12 iluminada cuando hay emergencia." .

ns1:B12KEYBD1 a ns1:Sensor ;
    rdfs:label "B12KEYBD1" ;
    ns1:identificador "B12KEYBD1" ;
    ns1:textoExtracto "TMINEM AND DFU B12KEYBD1 = SET RESTMEM" .

ns1:LEAVEPOS a ns1:Parametro ;
    rdfs:label "LEAVEPOS" ;
    ns1:identificador "LEAVEPOS" ;
    ns1:textoExtracto "Este registro indica la posición de almacén en la que hay que dejar la herramienta." .

ns1:TAKEPOS a ns1:Parametro ;
    rdfs:label "TAKEPOS" ;
    ns1:identificador "TAKEPOS" ;
    ns1:textoExtracto "Este registro indica la posición de almacén que ocupa la herramienta que hay que coger." .

ns1:TMINEM a ns1:Parametro ;
    rdfs:label "TMINEM" ;
    ns1:identificador "TMINEM" ;
    ns1:textoExtracto "Tratamiento de la señal de emergencia del gestor de herramientas. DFU B11KEYBD1 AND NOT TMINEM = SET SETTMEM DFU TMINEM = RES SETTMEM Si se pulsa la tecla USER12 se activa la emergencia. TMINEM = B11KEYLED1 Lámpara de la tecla USER12 iluminada cuando hay emergencia. TMINEM AND DFU B12KEYBD1 = SET RESTMEM Si se pulsa la tecla USER13 se quita la emergencia." .

ns1:USER12 a ns1:Sensor ;
    rdfs:label "USER12" ;
    ns1:identificador "USER12" ;
    ns1:textoExtracto "Si se pulsa la tecla USER12 se activa la emergencia." .

ns1:USER13 a ns1:Sensor ;
    rdfs:label "USER13" ;
    ns1:identificador "USER13" ;
    ns1:textoExtracto "Si se pulsa la tecla USER13 se quita la emergencia." .

