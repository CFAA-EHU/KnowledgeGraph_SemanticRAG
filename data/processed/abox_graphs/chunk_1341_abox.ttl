@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlmacenAsincronoConBrazoCambiador a ns1:Sistema ;
    rdfs:label "Almacén asíncrono con brazo cambiador" ;
    ns1:compuestoPor ns1:AlmacenAsincrono,
        ns1:BrazoCambiador ;
    ns1:textoExtracto "Los almacenes asíncronos tienen el almacén alejado del cabezal y el cambio se realiza con ayuda del brazo cambiador." ;
    ns1:tieneComponente ns1:CNC,
        ns1:PLC .

ns1:FuncionM06 a ns1:ModoOperacion ;
    rdfs:label "Función M06" ;
    ns1:controla ns1:PLC ;
    ns1:ejecutadoPor ns1:CNC ;
    ns1:textoExtracto "Cuando el CNC ejecuta la función M06, realiza una llamada a la rutina asociada. Dentro de dicha rutina hay que volver a programar la función M06 para que el CNC indique al gestor que debe comenzar el cambio de herramienta. El gestor envía una orden al PLC para efectuar el cambio. El CNC espera a que el gestor de por finalizada la operación para continuar con la ejecución del programa." .

ns1:FuncionT a ns1:ModoOperacion ;
    rdfs:label "Función T" ;
    ns1:controla ns1:PLC ;
    ns1:ejecutadoPor ns1:CNC ;
    ns1:textoExtracto "Cuando el CNC ejecuta la función T, se lo indica al gestor. El gestor envía una orden al PLC para que seleccione la próxima herramienta en el almacén. El CNC continúa con la ejecución del programa, no espera a que el gestor de por finalizada la operación." .

ns1:GestorHerramientas a ns1:Sistema ;
    rdfs:label "Gestor de herramientas" ;
    ns1:controla ns1:PLC ;
    ns1:textoExtracto "La comunicación entre el gestor y el PLC se realiza en 2 fases" .

ns1:AlmacenAsincrono a ns1:Componente ;
    rdfs:label "Almacén asíncrono" ;
    ns1:textoExtracto "Los almacenes asíncronos tienen el almacén alejado del cabezal" .

ns1:BrazoCambiador a ns1:ComponenteMecanico ;
    rdfs:label "Brazo cambiador" ;
    ns1:textoExtracto "el cambio se realiza con ayuda del brazo cambiador" .

ns1:CNC a ns1:ComponenteElectrico ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "Cuando el CNC ejecuta la función T, se lo indica al gestor" .

ns1:PLC a ns1:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ns1:textoExtracto "La comunicación entre el gestor y el PLC se realiza en 2 fases" .

