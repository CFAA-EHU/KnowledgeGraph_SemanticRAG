@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:HerramientaDeTierra_6e1d40f50a a ns1:ComponenteElectrico ;
    ns1:identificador "Herramienta de tierra" ;
    ns1:textoExtracto "Herramienta de tierra" .

ns1:Pinza1DelBrazoCambiador a ns1:ComponenteElectrico ;
    ns1:identificador "Pinza ꞏ1ꞏ del brazo cambiador" ;
    ns1:textoExtracto "Pinza ꞏ1ꞏ del brazo cambiador" .

ns1:Sistema_Gestor_1083 a ns1:Sistema ;
    ns1:textoExtracto "los valores TAKEPOS y LEAVEPOS que utiliza el gestor en cada una de las operaciones" .

ns1:Sistema_PLC_1083 a ns1:Sistema ;
    ns1:textoExtracto "las marcas que debe activar el PLC al finalizar cada operación" .

ns1:TCHANGEOK_19787e6c75 a ns1:AvisoSeguridad ;
    ns1:identificador "TCHANGEOK" ;
    ns1:textoExtracto "La marca TCHANGEOK es opcional y sólo se debe utilizar cuando es posible. Una vez efectuado el cambio y la herramienta está en el brazo, activar la marca TCHANGEOK para continuar la ejecución del programa mientras se deja la herramienta en el almacén." .

ns1:Tabla_1083_1 a ns1:Tabla ;
    ns1:textoExtracto "Valor | Significado | --- | --- | | 0 | No hay que hacer nada. | | # | Posición en el almacén. | | -1 | Pinza ꞏ1ꞏ del brazo cambiador. | | -4 | Herramienta de tierra." .

ns1:Tabla_1083_2 a ns1:Tabla ;
    ns1:textoExtracto "A continuación se muestra una tabla resumen de los valores TAKEPOS y LEAVEPOS que utiliza el gestor en cada una de las operaciones, así como las marcas que debe activar el PLC al finalizar cada operación. La marca TCHANGEOK es opcional y sólo se debe utilizar cuando es posible. Una vez efectuado el cambio y la herramienta está en el brazo, activar la marca TCHANGEOK para continuar la ejecución del programa mientras se deja la herramienta en el almacén." .

