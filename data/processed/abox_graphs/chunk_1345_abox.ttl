@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_TCHANGEOK a ns1:Parametro ;
    rdfs:label "TCHANGEOK" ;
    ns1:monitoreaParametro ns1:Tabla_OperacionesPLC ;
    ns1:textoExtracto "La marca TCHANGEOK es opcional y sólo se debe utilizar cuando es posible. Una vez efectuado el cambio y la herramienta está en el brazo, activar la marca TCHANGEOK para continuar la ejecución del programa mientras se deja la herramienta en el almacén."@es .

ns1:Operacion_CambioHerramienta a ns1:ModoOperacion ;
    rdfs:label "Cambio de herramienta (ejemplo)"@es ;
    ns1:documentadoEn ns1:Tabla_OperacionesPLC ;
    ns1:textoExtracto "Ejemplo de funcionamiento [para cambio de herramienta usando marcas PLC]."@es .

ns1:Pagina_527_529 a ns1:Pagina ;
    ns1:identificador "527-529" ;
    ns1:textoExtracto "7.11.1 Operaciones válidas y marcas que activa el PLC con cada una de ellas."@es .

ns1:Tabla_OperacionesPLC a ns1:Tabla ;
    rdfs:label "Tabla de operaciones válidas y marcas PLC"@es ;
    ns1:ilustradoEn ns1:Pagina_527_529 ;
    ns1:textoExtracto """
| TMOPERATION | TAKEPOS | LEAVEPOS |  |
| --- | --- | --- | --- |
| 1 | -1 | 0 | CH1TOSPDL |
| 2 | 0 | # | SPDLTOCH2 + TCHANGEOK + CH2TOMZ |
| ... [operaciones 3-16 omitidas para brevedad] ...
| 16 | # | # | CH2TOMZ + MZTOCH1 |
""" .

