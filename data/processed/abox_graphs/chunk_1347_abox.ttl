@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_Se_alesPLC a ns1:Sistema ;
    rdfs:label "Sistema de señales del PLC para operaciones de cambio de herramienta" ;
    ns1:activaAlarma ns1:Alarma_CH1TOMZ,
        ns1:Alarma_CH1TOSPDL,
        ns1:Alarma_CH2TOMZ,
        ns1:Alarma_GRTOSPDL,
        ns1:Alarma_MZTOCH1,
        ns1:Alarma_SPDLTOCH2,
        ns1:Alarma_SPDLTOGR,
        ns1:Alarma_TCHANGEOK ;
    ns1:documentadoEn ns1:Tabla_OperacionesPLC ;
    ns1:textoExtracto "marcas que activa el PLC con cada una de las operaciones válidas" .

ns1:Alarma_CH1TOMZ a ns1:Alarma ;
    rdfs:label "CH1TOMZ (señal de PLC)" ;
    ns1:identificador "CH1TOMZ" ;
    ns1:textoExtracto "CH1TOMZ" .

ns1:Alarma_CH1TOSPDL a ns1:Alarma ;
    rdfs:label "CH1TOSPDL (señal de PLC)" ;
    ns1:identificador "CH1TOSPDL" ;
    ns1:textoExtracto "CH1TOSPDL" .

ns1:Alarma_CH2TOMZ a ns1:Alarma ;
    rdfs:label "CH2TOMZ (señal de PLC)" ;
    ns1:identificador "CH2TOMZ" ;
    ns1:textoExtracto "CH2TOMZ" .

ns1:Alarma_GRTOSPDL a ns1:Alarma ;
    rdfs:label "GRTOSPDL (señal de PLC)" ;
    ns1:identificador "GRTOSPDL" ;
    ns1:textoExtracto "GRTOSPDL" .

ns1:Alarma_MZTOCH1 a ns1:Alarma ;
    rdfs:label "MZTOCH1 (señal de PLC)" ;
    ns1:identificador "MZTOCH1" ;
    ns1:textoExtracto "MZTOCH1" .

ns1:Alarma_SPDLTOCH2 a ns1:Alarma ;
    rdfs:label "SPDLTOCH2 (señal de PLC)" ;
    ns1:identificador "SPDLTOCH2" ;
    ns1:textoExtracto "SPDLTOCH2" .

ns1:Alarma_SPDLTOGR a ns1:Alarma ;
    rdfs:label "SPDLTOGR (señal de PLC)" ;
    ns1:identificador "SPDLTOGR" ;
    ns1:textoExtracto "SPDLTOGR" .

ns1:Alarma_TCHANGEOK a ns1:Alarma ;
    rdfs:label "TCHANGEOK (señal de confirmación de cambio)" ;
    ns1:identificador "TCHANGEOK" ;
    ns1:textoExtracto "(TCHANGEOK)" .

ns1:Tabla_OperacionesPLC a ns1:Tabla ;
    ns1:textoExtracto "CNC | TMOPERATION | TAKEPOS | LEAVEPOS" .

