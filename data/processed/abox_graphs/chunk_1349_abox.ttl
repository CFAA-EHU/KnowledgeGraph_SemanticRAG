@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Valor0 a ns1:Parametro ;
    rdfs:label "0" ;
    ns1:textoExtracto "Valor: 0 | Significado: No hay que hacer nada." ;
    ns1:valor "No hay que hacer nada." .

ns1:ValorHash a ns1:Parametro ;
    rdfs:label "#" ;
    ns1:textoExtracto "Valor: # | Significado: Posición en el almacén." ;
    ns1:valor "Posición en el almacén." .

ns1:ValorMenos1 a ns1:Parametro ;
    rdfs:label "-1" ;
    ns1:textoExtracto "Valor: -1 | Significado: Pinza ꞏ1ꞏ del brazo cambiador." ;
    ns1:valor "Pinza ꞏ1ꞏ del brazo cambiador." .

ns1:ValorMenos4 a ns1:Parametro ;
    rdfs:label "-4" ;
    ns1:textoExtracto "Valor: -4 | Significado: Herramienta de tierra." ;
    ns1:valor "Herramienta de tierra." .

