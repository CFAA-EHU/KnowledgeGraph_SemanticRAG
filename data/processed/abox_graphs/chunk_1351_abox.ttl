@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:GestorAlmacen_1090 a ns1:Sistema ;
    rdfs:label "Gestor del almacén" ;
    ns1:controla ns1:AlmacenDeHerramientas_7534de0da4 ;
    ns1:ejecutadoPor ns1:OperacionMecanizado_1090 ;
    ns1:textoExtracto "el gestor admite dos secuencias" .

ns1:MarcaCH2TOMZ_1090 a ns1:Parametro ;
    rdfs:label "Marca CH2TOMZ" ;
    ns1:textoExtracto "activar la marca CH2TOMZ" .

ns1:MarcaSPDLTOCH2_1090 a ns1:Parametro ;
    rdfs:label "Marca SPDLTOCH2" ;
    ns1:textoExtracto "activar la marca SPDLTOCH2" .

ns1:AlmacenDeHerramientas_7534de0da4 a ns1:Sistema ;
    rdfs:label "Almacén de herramientas" ;
    ns1:compuestoPor ns1:Pinza1_ee6f23d3ab,
        ns1:Pinza2_7fbf274966 ;
    ns1:textoExtracto "Las herramientas del cabezal y del brazo son del mismo almacén." ;
    ns1:tieneComponente ns1:BrazoCambiador_1090,
        ns1:Cabezal_1090 .

ns1:BrazoCambiador_1090 a ns1:ComponenteMecanico ;
    rdfs:label "Brazo cambiador" ;
    ns1:textoExtracto "herramientas del brazo son del mismo almacén" .

ns1:Cabezal_1090 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "herramientas del cabezal" .

ns1:OperacionMecanizado_1090 a ns1:AccionProhibida ;
    rdfs:label "Operación de mecanizado" ;
    ns1:textoExtracto "durante el mecanizado (al ejecutar la T)" .

ns1:Pinza1_ee6f23d3ab a ns1:Herramienta ;
    rdfs:label "Pinza 1" ;
    ns1:textoExtracto "Poner la herramienta de la pinza 1 en el cabezal" .

ns1:Pinza2_7fbf274966 a ns1:Herramienta ;
    rdfs:label "Pinza 2" ;
    ns1:textoExtracto "Coger la herramienta del cabezal con la pinza 2" .

