@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Almacen a ns1:Sistema ;
    rdfs:label "almacén" ;
    ns1:textoExtracto "Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén" .

ns1:BrazoCambiador a ns1:ComponenteMecanico ;
    rdfs:label "brazo cambiador" ;
    ns1:textoExtracto "Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza ꞏ2ꞏ" .

ns1:HerramientaDeLaPinza1_5f46d71889 a ns1:Herramienta ;
    rdfs:label "herramienta de la pinza 1" ;
    ns1:textoExtracto "Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal" .

ns1:HerramientaDeLaPinza2_26f5671dfb a ns1:Herramienta ;
    rdfs:label "herramienta de la pinza 2" ;
    ns1:textoExtracto "Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén" .

ns1:HerramientaDeTierra_257100a34c a ns1:Herramienta ;
    rdfs:label "herramienta de tierra" ;
    ns1:textoExtracto "coger una herramienta de tierra" .

ns1:MarcaCH1TOSPDL a ns1:Parametro ;
    rdfs:label "CH1TOSPDL" ;
    ns1:textoExtracto "activar la marca CH1TOSPDL" .

ns1:MarcaCH2TOMZ a ns1:Parametro ;
    rdfs:label "CH2TOMZ" ;
    ns1:textoExtracto "activar la marca CH2TOMZ" .

ns1:MarcaGRTOSPDL a ns1:Parametro ;
    rdfs:label "GRTOSPDL" ;
    ns1:textoExtracto "activar la marca GRTOSPDL" .

ns1:MarcaSPDLTOCH2 a ns1:Parametro ;
    rdfs:label "SPDLTOCH2" ;
    ns1:textoExtracto "activar la marca SPDLTOCH2" .

ns1:MarcaTCHANGEOK a ns1:Parametro ;
    rdfs:label "TCHANGEOK" ;
    ns1:textoExtracto "activar TCHANGEOK" .

ns1:Pinza1_36333c3fcd a ns1:ComponenteElectrico ;
    rdfs:label "pinza 1" ;
    ns1:textoExtracto "Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal" .

ns1:Pinza2_1a9cfeb23d a ns1:ComponenteElectrico ;
    rdfs:label "pinza 2" ;
    ns1:textoExtracto "del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2" .

ns1:SecuenciaOperacion1 a ns1:ModoOperacion ;
    rdfs:label "Primera secuencia" ;
    ns1:textoExtracto "Primera secuencia: 1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 2 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ. 3 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

ns1:SecuenciaOperacion2 a ns1:ModoOperacion ;
    rdfs:label "Segunda secuencia" ;
    ns1:textoExtracto "Segunda secuencia: 1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 2 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

