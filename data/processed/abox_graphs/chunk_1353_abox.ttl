@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Almacen a ns1:Sistema ;
    rdfs:label "almacén" ;
    ns1:textoExtracto "Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza ꞏ2ꞏ" .

ns1:BrazoCambiador a ns1:ComponenteMecanico ;
    rdfs:label "brazo cambiador" ;
    ns1:textoExtracto "Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza ꞏ2ꞏ" .

ns1:HerramientaDeTierra_8ce7870f23 a ns1:ComponenteElectrico ;
    rdfs:label "Herramienta de tierra" ;
    ns1:textoExtracto "Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL" .

ns1:HerramientaDelCabezalConLaPinza2_a3fe823e41 a ns1:ComponenteElectrico ;
    rdfs:label "Herramienta del cabezal con la pinza 2" ;
    ns1:textoExtracto "Coger la herramienta del cabezal con la pinza ꞏ2ꞏ" .

ns1:LEAVEPOS a ns1:Parametro ;
    rdfs:label "LEAVEPOS" ;
    ns1:textoExtracto "LEAVEPOS=-4" ;
    ns1:valor "-4" .

ns1:MarcaCH2TOMZ a ns1:Parametro ;
    rdfs:label "marca CH2TOMZ" ;
    ns1:textoExtracto "activar la marca CH2TOMZ" .

ns1:MarcaGRTOSPDL a ns1:Parametro ;
    rdfs:label "marca GRTOSPDL" ;
    ns1:textoExtracto "activar la marca GRTOSPDL" .

ns1:MarcaSPDLTOCH2 a ns1:Parametro ;
    rdfs:label "marca SPDLTOCH2" ;
    ns1:textoExtracto "activar la marca SPDLTOCH2" .

ns1:MarcaTCHANGEOK a ns1:Parametro ;
    rdfs:label "marca TCHANGEOK" ;
    ns1:textoExtracto "activar TCHANGEOK, si se desea, para que continúe la ejecución del programa" .

ns1:TAKEPOS a ns1:Parametro ;
    rdfs:label "TAKEPOS" ;
    ns1:textoExtracto "TAKEPOS=-1" ;
    ns1:valor "-1" .

ns1:TMOPERATION a ns1:Parametro ;
    rdfs:label "TMOPERATION" ;
    ns1:textoExtracto "TMOPERATION = 7" ;
    ns1:valor "7" .

