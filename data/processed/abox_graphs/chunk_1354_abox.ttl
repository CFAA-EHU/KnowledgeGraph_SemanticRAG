@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Almacen a ns1:Sistema ;
    rdfs:label "almacén" ;
    ns1:textoExtracto "almacén" .

ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "cabezal" ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en tierra" .

ns1:GestorOperacion a ns1:Sistema ;
    rdfs:label "gestor" ;
    ns1:textoExtracto "el gestor envía el código TMOPERATION=11" .

ns1:HerramientaDeTierra_980590e241 a ns1:ComponenteMecanico ;
    rdfs:label "Herramienta de tierra" ;
    ns1:textoExtracto "Herramienta de tierra." .

ns1:HerramientaEnElBrazoCambiador_05c05e3500 a ns1:ComponenteMecanico ;
    rdfs:label "Herramienta en el brazo cambiador" ;
    ns1:textoExtracto "Herramienta en el brazo cambiador. LEAVEPOS=-4 Herramienta de tierra." .

ns1:MarcaCH1TOSPDL a ns1:Parametro ;
    rdfs:label "marca CH1TOSPDL" ;
    ns1:textoExtracto "activar la marca CH1TOSPDL" .

ns1:MarcaCH2TOMZ a ns1:Parametro ;
    rdfs:label "marca CH2TOMZ" ;
    ns1:textoExtracto "activar la marca CH2TOMZ" .

ns1:MarcaGRTOSPDL a ns1:Parametro ;
    rdfs:label "marca GRTOSPDL" ;
    ns1:textoExtracto "activar la marca GRTOSPDL" .

ns1:MarcaSPDLTOCH2 a ns1:Parametro ;
    rdfs:label "marca SPDLTOCH2" ;
    ns1:textoExtracto "activar la marca SPDLTOCH2" .

ns1:MarcaSPDLTOGR a ns1:Parametro ;
    rdfs:label "marca SPDLTOGR" ;
    ns1:textoExtracto "activar la marca SPDLTOGR" .

ns1:MarcaTCHANGEOK a ns1:Parametro ;
    rdfs:label "marca TCHANGEOK" ;
    ns1:textoExtracto "activar TCHANGEOK" .

ns1:Pinza1_c596d2434b a ns1:ComponenteMecanico ;
    rdfs:label "pinza 1" ;
    ns1:textoExtracto "coger la herramienta del almacén con la pinza 1" .

ns1:Pinza2_7b0bff9e8f a ns1:ComponenteMecanico ;
    rdfs:label "pinza 2" ;
    ns1:textoExtracto "Coger la herramienta del cabezal con la pinza 2" .

ns1:SecuenciaDeTMOPERATION10 a ns1:TareaMantenimiento ;
    rdfs:label "secuencia de TMOPERATION = 10" ;
    ns1:textoExtracto "La secuencia de esta operación es la siguiente. TAKEPOS=# Posición del almacén para coger la herramienta. LEAVEPOS=-4 Herramienta de tierra." .

ns1:SecuenciaDeTMOPERATION11 a ns1:TareaMantenimiento ;
    rdfs:label "secuencia de TMOPERATION = 11" ;
    ns1:textoExtracto "La secuencia de esta operación es la siguiente. Previamente, durante el mecanizado (al ejecutar la T), el gestor envía el código TMOPERATION=11 para coger la herramienta del almacén con la pinza 1." .

ns1:SecuenciaDeTMOPERATION8 a ns1:TareaMantenimiento ;
    rdfs:label "secuencia de TMOPERATION = 8" ;
    ns1:textoExtracto "La secuencia de esta operación es la siguiente. 1 Dejar la herramienta del cabezal en tierra y activar la marca SPDLTOGR. 2 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

ns1:SecuenciaDeTMOPERATION9 a ns1:TareaMantenimiento ;
    rdfs:label "secuencia de TMOPERATION = 9" ;
    ns1:textoExtracto "La secuencia de esta operación es la siguiente. 1 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL. 2 Coger la herramienta del cabezal con la pinza 2 y activar la marca SPDLTOCH2. 3 Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza 2. 4 Al abandonar el brazo la zona de posible colisión activar TCHANGEOK, si se desea, para que continúe la ejecución del programa. 5 Dejar la herramienta de la pinza 2 en el almacén y activar la marca CH2TOMZ." .

ns1:TMOPERATION10_44d294f486 a ns1:ModoOperacion ;
    rdfs:label "TMOPERATION = 10" ;
    ns1:textoExtracto "TMOPERATION = 10 Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal." .

ns1:TMOPERATION11_318e334de6 a ns1:ModoOperacion ;
    rdfs:label "TMOPERATION = 11" ;
    ns1:textoExtracto "el gestor envía el código TMOPERATION=11" .

ns1:TMOPERATION8_a080eca418 a ns1:ModoOperacion ;
    rdfs:label "TMOPERATION = 8" ;
    ns1:textoExtracto "TMOPERATION = 8 Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra." .

ns1:TMOPERATION9_9c1e032d75 a ns1:ModoOperacion ;
    rdfs:label "TMOPERATION = 9" ;
    ns1:textoExtracto "TMOPERATION = 9 Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal." .

