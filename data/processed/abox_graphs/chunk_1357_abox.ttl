@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlmacenDeHerramientas_4d88ec0df6 a ns1:Sistema ;
    rdfs:label "almacén de herramientas" ;
    ns1:textoExtracto "el almacén en el que hay que dejar la herramienta y en la parte alta el almacén del que hay que coger la herramienta" .

ns1:Cabezal_1096 a ns1:ComponenteMecanico ;
    rdfs:label "cabezal" ;
    ns1:textoExtracto "Coger la herramienta del cabezal con la pinza 2" .

ns1:Pinza1_c596d2434b a ns1:ComponenteMecanico ;
    rdfs:label "pinza 1" ;
    ns1:textoExtracto "coger la herramienta del almacén con la pinza 1" .

ns1:Pinza2_7b0bff9e8f a ns1:ComponenteMecanico ;
    rdfs:label "pinza 2" ;
    ns1:textoExtracto "Coger la herramienta del cabezal con la pinza 2" .

ns1:PosicionAlmacen_1096 a ns1:Parametro ;
    rdfs:label "Posición del almacén para dejar la herramienta" ;
    ns1:identificador "LEAVEPOS" ;
    ns1:textoExtracto "LEAVEPOS=# Posición del almacén para dejar la herramienta. MZID En la parte baja de este registro se indica el almacén en el que hay que dejar la herramienta y en la parte alta el almacén del que hay que coger la herramienta." .

ns1:TMOPERATION11_cc7b80c476 a ns1:Parametro ;
    rdfs:label "TMOPERATION=11" ;
    ns1:identificador "TMOPERATION=11" ;
    ns1:textoExtracto "el gestor envía el código TMOPERATION=11 para coger la herramienta del almacén con la pinza 1" .

