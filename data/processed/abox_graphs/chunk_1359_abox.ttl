@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComunicacionPLC_M06 a ns1:Sistema ;
    rdfs:label "Sistema de comunicación PLC-M06"@es ;
    ns1:textoExtracto "La comunicación entre el PLC y la rutina M06 se realiza mediante una serie de marcas y registros genéricos."@es ;
    ns1:tieneComponente ns1:Funcion_M101,
        ns1:Funcion_M102,
        ns1:Funcion_M104,
        ns1:Funcion_M106,
        ns1:Funcion_M121,
        ns1:Funcion_M122,
        ns1:Funcion_M123,
        ns1:Marca_CH2TOMZ,
        ns1:Marca_M1100,
        ns1:Marca_M1101,
        ns1:Marca_M1102,
        ns1:Marca_M1104,
        ns1:Marca_M1107,
        ns1:Marca_M1108 .

ns1:Funcion_M101 a ns1:ComponenteElectrico ;
    rdfs:label "Función M101 (Selección de herramienta en almacén)"@es ;
    ns1:identificador "M101" ;
    ns1:textoExtracto "M101 | Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1."@es .

ns1:Funcion_M102 a ns1:ComponenteElectrico ;
    rdfs:label "Función M102 (Transferencia pinza 1 → cabezal)"@es ;
    ns1:identificador "M102" ;
    ns1:textoExtracto "M102 | Llevar la herramienta de la pinza 1 al cabezal."@es .

ns1:Funcion_M104 a ns1:ComponenteElectrico ;
    rdfs:label "Función M104 (Captura de herramienta en cabezal)"@es ;
    ns1:identificador "M104" ;
    ns1:textoExtracto "M104 | Coger la herramienta del cabezal con la pinza 2."@es .

ns1:Funcion_M106 a ns1:ComponenteElectrico ;
    rdfs:label "Función M106 (Devolución de herramienta al almacén)"@es ;
    ns1:identificador "M106" ;
    ns1:textoExtracto "M106 | Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza 2."@es .

ns1:Funcion_M121 a ns1:ComponenteElectrico ;
    rdfs:label "Función M121 (Posicionamiento en punto de cambio)"@es ;
    ns1:identificador "M121" ;
    ns1:textoExtracto "M121 | Llevar el brazo cambiador al punto de cambio."@es .

ns1:Funcion_M122 a ns1:ComponenteElectrico ;
    rdfs:label "Función M122 (Movimiento a almacén)"@es ;
    ns1:identificador "M122" ;
    ns1:textoExtracto "M122 | Llevar el brazo cambiador al almacén."@es .

ns1:Funcion_M123 a ns1:ComponenteElectrico ;
    rdfs:label "Función M123 (Retirada de brazo cambiador)"@es ;
    ns1:identificador "M123" ;
    ns1:textoExtracto "M123 | Retirar el brazo cambiador."@es .

ns1:Marca_CH2TOMZ a ns1:ComponenteElectrico ;
    rdfs:label "Marca CH2TOMZ"@es ;
    ns1:identificador "CH2TOMZ" ;
    ns1:textoExtracto "La marca CH2TOMZ la pondrá el PLC cuando se haya dejado la herramienta."@es .

ns1:Marca_M1100 a ns1:ComponenteElectrico ;
    rdfs:label "Marca TCHANGEOK (M1100)"@es ;
    ns1:identificador "M1100" ;
    ns1:textoExtracto "M1100 | TCHANGEOK: Se puede continuar con la ejecución del programa."@es .

ns1:Marca_M1101 a ns1:ComponenteElectrico ;
    rdfs:label "Marca MZTOCH1 (M1101)"@es ;
    ns1:identificador "M1101" ;
    ns1:textoExtracto "M1101 | MZTOCH1: La herramienta se ha llevado del almacén a la pinza 1."@es .

ns1:Marca_M1102 a ns1:ComponenteElectrico ;
    rdfs:label "Marca CH1TOSPDL (M1102)"@es ;
    ns1:identificador "M1102" ;
    ns1:textoExtracto "M1102 | CH1TOSPDL: La herramienta se ha llevado de la pinza 1 al cabezal."@es .

ns1:Marca_M1104 a ns1:ComponenteElectrico ;
    rdfs:label "Marca SPDLTOCH2 (M1104)"@es ;
    ns1:identificador "M1104" ;
    ns1:textoExtracto "M1104 | SPDLTOCH2: La herramienta se ha llevado del cabezal a la pinza 2."@es .

ns1:Marca_M1107 a ns1:ComponenteElectrico ;
    rdfs:label "Marca SPDLTOGR (M1107)"@es ;
    ns1:identificador "M1107" ;
    ns1:textoExtracto "M1107 | SPDLTOGR: La herramienta se ha llevado del cabezal a tierra."@es .

ns1:Marca_M1108 a ns1:ComponenteElectrico ;
    rdfs:label "Marca GRTOSPDL (M1108)"@es ;
    ns1:identificador "M1108" ;
    ns1:textoExtracto "M1108 | GRTOSPDL: La herramienta se ha llevado de tierra al cabezal."@es .

