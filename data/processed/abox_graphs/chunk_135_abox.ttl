@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix base: <https://vocab.cfaa.eus/broaching/base/> .
@prefix elec: <https://vocab.cfaa.eus/broaching/electrico/> .
@prefix meca: <https://vocab.cfaa.eus/broaching/mecanico/> .
@prefix norm: <https://vocab.cfaa.eus/broaching/normativa/> .

# =============================================================================
# Clases
# =============================================================================

elec:InterruptorProteccionSelectiva
    a owl:Class ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/InterruptorProteccionSelectiva> ;
    rdfs:label "Interruptor de Protección Selectiva"@es ;
    rdfs:comment "Interruptor de protección selectiva para circuitos eléctricos"@es .

elec:InterruptorAutomatico
    a owl:Class ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/InterruptorAutomatico> ;
    rdfs:label "Interruptor Automático"@es ;
    rdfs:comment "Dispositivo de protección contra sobrecorrientes y cortocircuitos"@es .

elec:BloqueCAuxTransversal
    a owl:Class ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/BloqueCAuxTransversal> ;
    rdfs:label "Bloque de Contactos Auxiliares Transversales"@es ;
    rdfs:comment "Bloque de contactos auxiliares para conexión transversal en cuadros eléctricos"@es .

elec:Guardamotor
    a owl:Class ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/Guardamotor> ;
    rdfs:label "Guardamotor"@es ;
    rdfs:comment "Dispositivo de protección para motores contra sobrecargas y cortocircuitos"@es .

# =============================================================================
# Propiedades
# =============================================================================

elec:tieneTensionNominal
    a owl:DatatypeProperty ;
    rdfs:domain elec:InterruptorProteccionSelectiva ;
    rdfs:range xsd:string ;
    rdfs:label "tiene tensión nominal"@es ;
    rdfs:comment "Tensión nominal de operación del interruptor de protección selectiva"@es .

elec:tieneCorrienteInterrupcion
    a owl:DatatypeProperty ;
    rdfs:domain elec:InterruptorProteccionSelectiva ;
    rdfs:range xsd:string ;
    rdfs:label "tiene corriente de interrupción"@es ;
    rdfs:comment "Capacidad de interrupción del interruptor de protección selectiva"@es .

elec:tienePolos
    a owl:DatatypeProperty ;
    rdfs:domain elec:InterruptorProteccionSelectiva ;
    rdfs:range xsd:string ;
    rdfs:label "tiene polos"@es ;
    rdfs:comment "Número de polos del interruptor de protección selectiva"@es .

elec:tieneCurvaCaracteristica
    a owl:DatatypeProperty ;
    rdfs:domain elec:InterruptorProteccionSelectiva ;
    rdfs:range xsd:string ;
    rdfs:label "tiene curva característica"@es ;
    rdfs:comment "Curva característica de disparo del interruptor de protección selectiva (ej. C)"@es .

elec:tieneCorrienteNominal
    a owl:DatatypeProperty ;
    rdfs:domain elec:InterruptorProteccionSelectiva ;
    rdfs:range xsd:string ;
    rdfs:label "tiene corriente nominal"@es ;
    rdfs:comment "Corriente nominal del interruptor de protección selectiva"@es .

elec:tienePaso
    a owl:DatatypeProperty ;
    rdfs:domain elec:InterruptorProteccionSelectiva ;
    rdfs:range xsd:string ;
    rdfs:label "tiene paso"@es ;
    rdfs:comment "Paso o separación entre bornes del interruptor de protección selectiva"@es .

elec:tieneTipoBornes
    a owl:DatatypeProperty ;
    rdfs:domain elec:InterruptorAutomatico ;
    rdfs:range xsd:string ;
    rdfs:label "tiene tipo de bornes"@es ;
    rdfs:comment "Tipo de bornes del interruptor automático (ej. bornes de tornillo)"@es .

elec:tieneCorrienteProteccion
    a owl:DatatypeProperty ;
    rdfs:domain elec:InterruptorAutomatico ;
    rdfs:range xsd:string ;
    rdfs:label "tiene corriente de protección"@es ;
    rdfs:comment "Corriente de protección del interruptor automático"@es .

elec:protegeComponente
    a owl:ObjectProperty ;
    rdfs:domain elec:InterruptorProteccionSelectiva ;
    rdfs:range meca:ComponenteElectrico ;
    rdfs:label "protege componente"@es ;
    rdfs:comment "Relación que indica qué componente eléctrico es protegido por el interruptor"@es .

elec:protegeSistema
    a owl:ObjectProperty ;
    rdfs:domain elec:InterruptorAutomatico ;
    rdfs:range meca:SistemaElectrico ;
    rdfs:label "protege sistema"@es ;
    rdfs:comment "Relación que indica qué sistema eléctrico es protegido por el interruptor automático"@es .

elec:tieneFabricante
    a owl:DatatypeProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (elec:InterruptorProteccionSelectiva elec:InterruptorAutomatico elec:BloqueCAuxTransversal elec:Guardamotor)
    ] ;
    rdfs:range xsd:string ;
    rdfs:label "tiene fabricante"@es ;
    rdfs:comment "Fabricante del componente eléctrico"@es .

elec:tieneReferenciaFabricante
    a owl:DatatypeProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (elec:InterruptorProteccionSelectiva elec:InterruptorAutomatico elec:BloqueCAuxTransversal elec:Guardamotor)
    ] ;
    rdfs:range xsd:string ;
    rdfs:label "tiene referencia de fabricante"@es ;
    rdfs:comment "Referencia del componente según el fabricante"@es .

elec:tieneCantidad
    a owl:DatatypeProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (elec:InterruptorProteccionSelectiva elec:InterruptorAutomatico elec:BloqueCAuxTransversal elec:Guardamotor)
    ] ;
    rdfs:range xsd:integer ;
    rdfs:label "tiene cantidad"@es ;
    rdfs:comment "Cantidad de unidades del componente en el sistema"@es .