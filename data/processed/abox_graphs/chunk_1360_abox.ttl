@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PLC_ComunicacionM06 a ns1:Sistema ;
    rdfs:label "Sistema de comunicación PLC-M06" ;
    ns1:controla ns1:M106,
        ns1:M121,
        ns1:M122,
        ns1:M123 ;
    ns1:textoExtracto "Comunicación entre el PLC y la rutina M06." .

ns1:M106 a ns1:ModoOperacion ;
    rdfs:label "M106" ;
    ns1:identificador "M106" ;
    ns1:textoExtracto "El PLC debe dar por finalizada la M106 cuando el brazo abandona la zona de posible colisión y se puede mecanizar." .

ns1:M121 a ns1:ModoOperacion ;
    rdfs:label "M121" ;
    ns1:identificador "M121" ;
    ns1:textoExtracto "Llevar el brazo cambiador al punto de cambio." .

ns1:M122 a ns1:ModoOperacion ;
    rdfs:label "M122" ;
    ns1:identificador "M122" ;
    ns1:textoExtracto "Llevar el brazo cambiador al almacén." .

ns1:M123 a ns1:ModoOperacion ;
    rdfs:label "M123" ;
    ns1:identificador "M123" ;
    ns1:textoExtracto "Retirar el brazo cambiador." .

