@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:ColocarLaHerramientaDeTierraEnElCabezalMSGInsertarHerramientaTDYPulsarMARCHAVTMNXTOOLMensajeAlOperarioParaQuePongaLaHerramienta a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Colocar la herramienta de tierra en el cabezal. # MSG [\"Insertar herramienta T%D y pulsar MARCHA\", V.TM.NXTOOL] ; Mensaje al operario para que ponga la herramienta." .

ns1:M0_34652f9fc0 a ns1:TareaMantenimiento ;
    ns1:identificador "M0" ;
    ns1:textoExtracto "Quitar la herramienta del cabezal (llevarla a tierra). # MSG [\"Extraer herramienta T%D y pulsar MARCHA\", V.TM.TOOL] ; Mensaje al operario para que quite la herramienta. M0 ; Esperar a que finalice la operación. # MSG [\"\"] ; Quitar mensaje. V.PLC.M[1107]=1 ; Marca SPDLTOGR al gestor." .

ns1:M101_7a55e240e4 a ns1:TareaMantenimiento ;
    ns1:identificador "M101" ;
    ns1:textoExtracto "Coger la herramienta del almacén con la pinza 1. M101 ; Función auxiliar para ejecutar acción. V.PLC.M[1101]=1 ; Marca MZTOCH1 al gestor." .

ns1:M102_f2bec6c9ee a ns1:TareaMantenimiento ;
    ns1:identificador "M102" ;
    ns1:textoExtracto "Llevar la herramienta de la pinza 1 al cabezal. M102 ; Función auxiliar para ejecutar acción. V.PLC.M[1102]=1 ; Marca CH1TOSPDL al gestor." .

ns1:M104_2613778da6 a ns1:TareaMantenimiento ;
    ns1:identificador "M104" ;
    ns1:textoExtracto "Coger la herramienta del cabezal con la pinza 2. M104 ; Función auxiliar para ejecutar acción. V.PLC.M[1104]=1 ; Marca SPDLTOCH2 al gestor." .

ns1:M106_3f9b4028ad a ns1:TareaMantenimiento ;
    ns1:identificador "M106" ;
    ns1:textoExtracto "Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza 2. M106 ; Función auxiliar para ejecutar acción. ; El PLC debe dar por finalizada la M106 cuando el brazo abandona la zona de posible colisión y se puede mecanizar. ; La marca CH2TOMZ la pondrá el PLC cuando se haya dejado la herramienta." .

