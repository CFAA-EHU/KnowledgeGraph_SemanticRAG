@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramaM06 a ns1:TareaMantenimiento ;
    rdfs:label "Programa de la rutina M06" ;
    ns1:detalladoEnEsquema ns1:ProgramaM06_Esquema ;
    ns1:textoExtracto "Programa de la rutina M06." .

ns1:Almacen a ns1:Componente ;
    rdfs:label "almacén" ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en el almacén, y coger otra del almacén." .

ns1:BrazoCambiador a ns1:ComponenteMecanico ;
    rdfs:label "brazo cambiador" ;
    ns1:textoExtracto "Llevar el brazo cambiador al punto de cambio." .

ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "cabezal" ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio manual." .

ns1:HerramientaDeTierra_5c8a51199a a ns1:ComponenteElectrico ;
    rdfs:label "herramienta de tierra" ;
    ns1:textoExtracto "Colocar la herramienta de tierra en el cabezal." .

ns1:Pinza1_02c02a1fc6 a ns1:ComponenteMecanico ;
    rdfs:label "pinza 1" ;
    ns1:textoExtracto "Previamente, durante el mecanizado (al ejecutar T), se pone la herramienta del almacén en la pinza 1." .

ns1:Pinza2_7b0bff9e8f a ns1:ComponenteMecanico ;
    rdfs:label "pinza 2" ;
    ns1:textoExtracto "Coger la herramienta del cabezal con la pinza 2." .

ns1:ProgramaM06_Esquema a ns1:Esquema ;
    ns1:textoExtracto "Sección 7.11.4 Programa de la rutina M06." ;
    ns1:tieneComponente ns1:Almacen,
        ns1:BrazoCambiador,
        ns1:Cabezal,
        ns1:HerramientaDeTierra_5c8a51199a,
        ns1:Pinza1_02c02a1fc6,
        ns1:Pinza2_7b0bff9e8f,
        ns1:PuntoCambioAutomatico,
        ns1:PuntoCambioManual .

ns1:PuntoCambioAutomatico a ns1:ModoOperacion ;
    rdfs:label "punto de cambio automático" ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio automático." .

ns1:PuntoCambioManual a ns1:ModoOperacion ;
    rdfs:label "punto de cambio manual" ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio manual." .

