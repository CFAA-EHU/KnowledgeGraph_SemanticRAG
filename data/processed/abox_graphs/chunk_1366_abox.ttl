@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Almacen a ns1:Sistema ;
    rdfs:label "almacén" ;
    ns1:textoExtracto "Comenzar el envío del brazo cambiador al almacén para dejar la herramienta." .

ns1:BrazoCambiador a ns1:Actuador ;
    rdfs:label "brazo cambiador" ;
    ns1:textoExtracto "Retirar el brazo cambiador." .

ns1:HerramientaDeTierra_e106bbaf1c a ns1:PiezaRecambio ;
    rdfs:label "herramienta de tierra" ;
    ns1:textoExtracto "Colocar la herramienta de tierra en el cabezal." .

ns1:MarcaTCHANGEOK a ns1:Parametro ;
    rdfs:label "TCHANGEOK" ;
    ns1:identificador "TCHANGEOK" ;
    ns1:textoExtracto "activar la marca TCHANGEOK, indicando al gestor que puede continuar la ejecución." .

ns1:Mecanizado a ns1:ModoOperacion ;
    rdfs:label "mecanizado" ;
    ns1:textoExtracto "Previamente, durante el mecanizado (al ejecutar T), se pone la herramienta del almacén en la pinza 1." .

ns1:PLC a ns1:Sistema ;
    rdfs:label "PLC" ;
    ns1:textoExtracto "Orden al PLC para que active la marca TCHANGEOK" .

ns1:Pinza2_7b0bff9e8f a ns1:ComponenteMecanico ;
    rdfs:label "pinza 2" ;
    ns1:textoExtracto "Coger la herramienta del cabezal con la pinza 2." .

ns1:PuntoCambioManual a ns1:Parametro ;
    rdfs:label "punto de cambio manual" ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio manual." .

