@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

ex:InterruptorAutomatico a owl:Class ;
    rdfs:label "InterruptorAutomatico" ;
    rdfs:comment "Interruptor automático con bornes de tornillo" .

ex:BloqueAuxiliarTransversal a owl:Class ;
    rdfs:label "BloqueAuxiliarTransversal" ;
    rdfs:comment "Bloque de contactos auxiliares transversal con 2 NA y bornes de tornillo" .

ex:Guardamotor a owl:Class ;
    rdfs:label "Guardamotor" ;
    rdfs:comment "Guardamotor para diferentes sistemas" .

ex:SiemensAG a owl:Class ;
    rdfs:label "SiemensAG" ;
    rdfs:comment "Empresa fabricante de componentes eléctricos" .

ex:tieneTipoDeProteccion a owl:DatatypeProperty ;
    rdfs:label "tieneTipoDeProteccion" ;
    rdfs:comment "Propiedad que indica el tipo de protección del componente" .

ex:tieneVoltaje a owl:DatatypeProperty ;
    rdfs:label "tieneVoltaje" ;
    rdfs:comment "Propiedad que indica el voltaje del componente" .

ex:tieneAmperaje a owl:DatatypeProperty ;
    rdfs:label "tieneAmperaje" ;
    rdfs:comment "Propiedad que indica el amperaje del componente" .

ex:tieneModelo a owl:DatatypeProperty ;
    rdfs:label "tieneModelo" ;
    rdfs:comment "Propiedad que indica el modelo del componente" .

ex:tieneCantidad a owl:DatatypeProperty ;
    rdfs:label "tieneCantidad" ;
    rdfs:comment "Propiedad que indica la cantidad del componente" .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:label "tieneFabricante" ;
    rdfs:comment "Propiedad que relaciona un componente con su fabricante" .

ex:tieneGuardamotor a owl:ObjectProperty ;
    rdfs:label "tieneGuardamotor" ;
    rdfs:comment "Propiedad que relaciona un sistema con su guardamotor" .