@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:AcercarlaAlCabezalDuranteElMecanizado a ns1:Componente ;
    ns1:textoExtracto "acercarla al cabezal durante el mecanizado" .

ns1:CadaVezQueLaRutinaM06FinalizaUnaAccionSeLoIndicaAlPLCParaQueActiveLaMarcaCorrespondienteDelGestor_815e3cfaad a ns1:AccionProhibida ;
    ns1:textoExtracto "Cada vez que la rutina M06 finaliza una acción se lo indica al PLC para que active la marca correspondiente del gestor." .

ns1:CogerConLaPinza1LaHerramienta a ns1:Componente ;
    ns1:textoExtracto "Coger con la pinza 1 la herramienta" .

ns1:CuandoSeEjecutaLaFuncionTCuandoSeEjecutaLaFuncionTElGestorEnviaAlPLCElCodigoTMOPERATION11ParaCogerLaProximaHerramientaEnElBrazoYAcercarlaAlCabezalDuranteElMecanizado a ns1:AccionProhibida ;
    ns1:textoExtracto "Cuando se ejecuta la función –T– Cuando se ejecuta la función T el gestor envía al PLC el código TMOPERATION=11 para coger la próxima herramienta en el brazo y acercarla al cabezal durante el mecanizado." .

ns1:ElGestorEnviaAlPLCElCodigoTMOPERATION11 a ns1:Sistema ;
    ns1:textoExtracto "el gestor envía al PLC el código TMOPERATION=11" .

ns1:EnviarElBrazoCambiadorAlAlmacen a ns1:Componente ;
    ns1:textoExtracto "Enviar el brazo cambiador al almacén." .

ns1:LaHerramientaSeHaLlevadoDelCabezalALaPinza2 a ns1:Componente ;
    ns1:textoExtracto "La herramienta se ha llevado del cabezal a la pinza 2." .

ns1:LaHerramientaSeHaLlevadoDelCabezalATierra a ns1:Componente ;
    ns1:textoExtracto "La herramienta se ha llevado del cabezal a tierra." .

ns1:M101SeleccionarEnElAlmacenLaPosicionQueIndicaTAKEPOSYCogerLaHerramientaConLaPinza1_1839268f24 a ns1:AccionProhibida ;
    ns1:textoExtracto "M101 Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1." .

ns1:MarcaCH1TOMZ a ns1:Parametro ;
    ns1:textoExtracto "activar la marca CH1TOMZ" .

ns1:MarcaCH1TOSPDL a ns1:Parametro ;
    ns1:textoExtracto "DFU M1102 = SET CH1TOSPDL DFD CH1TOSPDL = RES M1102" .

ns1:MarcaGRTOSPDL a ns1:Parametro ;
    ns1:textoExtracto "DFU M1108 = SET GRTOSPDL DFD GRTOSPDL = RES M1108" .

ns1:MarcaMZTOCH1 a ns1:Parametro ;
    ns1:textoExtracto "Activar la marca MZTOCH1 para indicar al gestor que se ha cogido la herramienta." .

ns1:MarcaMZTOCH1_2 a ns1:Parametro ;
    ns1:textoExtracto "DFU M1101 = SET MZTOCH1 DFD M1101 = RES M1101" .

ns1:MarcaSPDLTOCH2 a ns1:Parametro ;
    ns1:textoExtracto "DFU M1104 = SET SPDLTOCH2 DFD SPDLTOCH2 = RES M1104" .

ns1:MarcaSPDLTOGR a ns1:Parametro ;
    ns1:textoExtracto "DFU M1107 = SET SPDLTOGR DFD SPDLTOGR = RES M1107" .

ns1:MarcaTCHANGEOK a ns1:Parametro ;
    ns1:textoExtracto "DFU M1100 = SET TCHANGEOK DFD TCHANGEOK = RES M1100" .

