@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:M06 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "La rutina M06 utiliza las siguientes funciones auxiliares M para indicar al PLC qué movimientos debe realizar." .

ns1:M101 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "M101 Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1." .

ns1:M102 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "M102 Llevar la herramienta de la pinza 1 al cabezal." .

ns1:M104 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "M104 Coger la herramienta del cabezal con la pinza 2." .

ns1:M106 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "M106 Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza 2." .

ns1:M121 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "M121 Llevar el brazo cambiador al punto de cambio." .

ns1:M122 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "M122 Llevar el brazo cambiador al almacén." .

ns1:M123 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "M123 Retirar el brazo cambiador." .

ns1:TAKEPOS a ns1:Parametro ;
    ns1:textoExtracto "la posición que indica TAKEPOS" .

ns1:almacen a ns1:Sistema ;
    ns1:textoExtracto "el almacén" .

ns1:brazoCambiador a ns1:ComponenteMecanico ;
    ns1:textoExtracto "el brazo cambiador" .

ns1:cabezal a ns1:ComponenteMecanico ;
    ns1:textoExtracto "el cabezal" .

ns1:pinza1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "la pinza 1" .

ns1:pinza2 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "la pinza 2" .

ns1:puntoDeCambio a ns1:Parametro ;
    ns1:textoExtracto "el punto de cambio" .

