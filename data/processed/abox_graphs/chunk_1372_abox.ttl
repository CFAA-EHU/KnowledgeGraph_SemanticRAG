@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CH2TOMZ a ns1:Sensor ;
    rdfs:label "CH2TOMZ" ;
    ns1:textoExtracto "Activar la marca CH2TOMZ cuando se haya dejado la herramienta, para que el gestor sepa que la herramienta se ha llevado de la pinza 2 al almacén." .

ns1:LEAVEPOS a ns1:Parametro ;
    rdfs:label "LEAVEPOS" ;
    ns1:textoExtracto "LEAVEPOS Este registro indica la posición de almacén en la que hay que dejar la herramienta." .

ns1:M106 a ns1:TareaMantenimiento ;
    rdfs:label "M106" ;
    ns1:textoExtracto "Tratamiento de la función M106: • Dar por finalizada cuando el brazo abandona la zona de posible colisión y se puede mecanizar. • Activar la marca CH2TOMZ cuando se haya dejado la herramienta, para que el gestor sepa que la herramienta se ha llevado de la pinza 2 al almacén." .

ns1:M121 a ns1:TareaMantenimiento ;
    rdfs:label "M121" ;
    ns1:textoExtracto "Llevar el brazo cambiador al punto de cambio." .

ns1:M122 a ns1:TareaMantenimiento ;
    rdfs:label "M122" ;
    ns1:textoExtracto "Llevar el brazo cambiador al almacén." .

ns1:M123 a ns1:TareaMantenimiento ;
    rdfs:label "M123" ;
    ns1:textoExtracto "Retirar el brazo cambiador." .

ns1:TAKEPOS a ns1:Parametro ;
    rdfs:label "TAKEPOS" ;
    ns1:textoExtracto "TAKEPOS Este registro indica la posición de almacén que ocupa la herramienta que hay que coger." .

ns1:senalEmergenciaGestor a ns1:Alarma ;
    rdfs:label "Señal de emergencia del gestor de herramientas" ;
    ns1:textoExtracto "Señal de emergencia del gestor." .

