@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PLC_ConfiguracionTeclado a ns1:InterfazUsuario ;
    rdfs:label "Configuración de teclado y idioma de entrada en PLC"@es ;
    ns1:documentadoEn ns1:Manual_Pag541_542 ;
    ns1:textoExtracto "La distribución del teclado controla los caracteres que aparecen en la pantalla cuando se pulsan las teclas. [...] Para poder cambiar la distribución del teclado, hay que añadir a Windows el idioma de entrada y la distribución del teclado deseada."@es ;
    ns1:tieneComponente ns1:Teclado_Espanol_ES,
        ns1:Teclado_Ingles_US .

ns1:Manual_Pag541_542 a ns1:Pagina ;
    rdfs:label "Páginas 541-542: PLC. CÓDIGOS DE TECLAS. Seleccionar idioma y distribución de teclado"@es ;
    ns1:identificador "541-542" ;
    ns1:textoExtracto "La distribución del teclado controla los caracteres que aparecen en la pantalla cuando se pulsan las teclas. [...] Agregar un idioma de entrada y una distribución de teclado."@es .

ns1:Teclado_Espanol_ES a ns1:Componente ;
    rdfs:label "Teclado (Español - España)"@es ;
    ns1:identificador "Español (España)" ;
    ns1:textoExtracto "Español (España)."@es .

ns1:Teclado_Ingles_US a ns1:Componente ;
    rdfs:label "Teclado (Inglés - Estados Unidos)"@es ;
    ns1:identificador "Inglés (Estados Unidos)" ;
    ns1:textoExtracto "Inglés (Estados Unidos)."@es .

