@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tecla_LogoFagor a ns1:ComponenteElectrico ;
    rdfs:label "Tecla con logo Fagor"@es ;
    ns1:ilustradoEn ns1:InterfazUsuario_ScanCodes ;
    ns1:textoExtracto "La tecla con el logo Fagor no se puede simular. Esta tecla no está disponible en todos los teclados."@es .

ns1:Tecla_Reset a ns1:ComponenteElectrico ;
    rdfs:label "Tecla [RESET] del CNC"@es ;
    ns1:controla ns1:Maquina_CNC ;
    ns1:ilustradoEn ns1:InterfazUsuario_ScanCodes ;
    ns1:textoExtracto "Las teclas [START], [STOP] y [RESET] se pueden accionar desde el PLC mediante las marcas CYSTART, _STOP y RESETIN respectivamente."@es .

ns1:Tecla_Start a ns1:ComponenteElectrico ;
    rdfs:label "Tecla [START] del CNC"@es ;
    ns1:controla ns1:Maquina_CNC ;
    ns1:ilustradoEn ns1:InterfazUsuario_ScanCodes ;
    ns1:textoExtracto "Las teclas [START], [STOP] y [RESET] se pueden accionar desde el PLC mediante las marcas CYSTART, _STOP y RESETIN respectivamente."@es .

ns1:Tecla_Stop a ns1:ComponenteElectrico ;
    rdfs:label "Tecla [STOP] del CNC"@es ;
    ns1:controla ns1:Maquina_CNC ;
    ns1:ilustradoEn ns1:InterfazUsuario_ScanCodes ;
    ns1:textoExtracto "Las teclas [START], [STOP] y [RESET] se pueden accionar desde el PLC mediante las marcas CYSTART, _STOP y RESETIN respectivamente."@es .

ns1:VentanaTareas_Hotkeys a ns1:InterfazUsuario ;
    rdfs:label "Ventana de tareas ([CTRL]+[A]) - Lista de hotkeys"@es ;
    ns1:ilustradoEn ns1:InterfazUsuario_ScanCodes ;
    ns1:textoExtracto "La ventana de tareas ([CTRL]+[A]) muestra la lista de hotkeys disponibles en el CNC."@es .

ns1:Pagina_547 a ns1:Pagina ;
    ns1:identificador "547" ;
    ns1:textoExtracto "Página con la tabla de scan codes para distribución de teclado Español (España)."@es .

ns1:Pagina_548 a ns1:Pagina ;
    ns1:identificador "548" ;
    ns1:textoExtracto "Página con la tabla de scan codes para distribución de teclado Inglés (Estados Unidos)."@es .

ns1:Tabla_ScanCodes_EN a ns1:Tabla ;
    rdfs:label "Tabla de Scan Codes - Distribución de teclado Inglés (Estados Unidos)"@es ;
    ns1:documentadoEn ns1:Pagina_548 ;
    ns1:identificador "8.5.2" ;
    ns1:textoExtracto "Ver '8.5.2 Scan codes. Distribución de teclado Inglés (Estados Unidos)' en la página 548."@es .

ns1:Tabla_ScanCodes_ES a ns1:Tabla ;
    rdfs:label "Tabla de Scan Codes - Distribución de teclado Español (España)"@es ;
    ns1:documentadoEn ns1:Pagina_547 ;
    ns1:identificador "8.5.1" ;
    ns1:textoExtracto "Ver '8.5.1 Scan codes. Distribución de teclado Español (España)' en la página 547."@es .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC"@es ;
    ns1:textoExtracto "Las teclas [START], [STOP] y [RESET] se pueden accionar desde el PLC mediante las marcas CYSTART, _STOP y RESETIN respectivamente."@es ;
    ns1:tieneComponente ns1:InterfazUsuario_ScanCodes .

ns1:InterfazUsuario_ScanCodes a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de códigos de tecla (Scan Codes)"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_ScanCodes_EN,
        ns1:Tabla_ScanCodes_ES ;
    ns1:textoExtracto "Los códigos de tecla (scan codes) permiten conocer cuál ha sido la última tecla aceptada por el CNC y también permiten simular el teclado desde el PLC. A cada tecla le corresponden dos códigos; uno para la acción de pulsar tecla y otro para la acción de soltar tecla."@es .

