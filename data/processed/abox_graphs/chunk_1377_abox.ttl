    rdfs:label "CALC" ;
    ns1:identificador "CTRL+K" ;
    ns1:textoExtracto "Calculadora. | CALC | [CTRL]+[K]" .

ns1:TeclaCambioPantalla a ns1:InterfazUsuario ;
    rdfs:label "NEXT" ;
