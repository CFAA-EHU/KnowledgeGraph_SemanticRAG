    ns1:textoExtracto "Barra para modificar la dinámica de la máquina. |  | [CTRL]+[H]" .

ns1:TeclaMensajesCNC a ns1:InterfazUsuario ;
    rdfs:label "" ;
    ns1:identificador "CTRL+O" ;
    ns1:textoExtracto "Mostrar/Ocultar los mensajes del CNC. |  | [CTRL]+[O]" .

ns1:TeclaMensajesPLC a ns1:InterfazUsuario ;
    rdfs:label "" ;
    ns1:identificador "CTRL+M" ;
    ns1:textoExtracto "Mostrar/Ocultar los mensajes del PLC. |  | [CTRL]+[M]" .

