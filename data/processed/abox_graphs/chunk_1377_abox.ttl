@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoAutomatico a ns1:ModoOperacion ;
    rdfs:label "AUTO" ;
    ns1:identificador "CTRL+F6" ;
    ns1:textoExtracto "Modo automático. | AUTO | [CTRL]+[F6]" .

ns1:ModoEDISIMU a ns1:ModoOperacion ;
    rdfs:label "EDIT" ;
    ns1:identificador "CTRL+F9" ;
    ns1:textoExtracto "Modo EDISIMU. | EDIT | [CTRL]+[F9]" .

ns1:ModoMDI_MDA a ns1:ModoOperacion ;
    rdfs:label "MDI" ;
    ns1:identificador "CTRL+F8" ;
    ns1:textoExtracto "Modo MDI/MDA. | MDI | [CTRL]+[F8]" .

ns1:ModoManual a ns1:ModoOperacion ;
    rdfs:label "MANUAL" ;
    ns1:identificador "CTRL+F7" ;
    ns1:textoExtracto "Modo manual. | MANUAL | [CTRL]+[F7]" .

ns1:ModoUsuario a ns1:ModoOperacion ;
    rdfs:label "" ;
    ns1:identificador "SHIFT+F1" ;
    ns1:textoExtracto "Modo de usuario. |  | [SHIFT]+[F1]" .

ns1:ModoUtilidades a ns1:ModoOperacion ;
    rdfs:label "UTILITIES" ;
    ns1:identificador "CTRL+F12" ;
    ns1:textoExtracto "Modo utilidades. | UTILITIES | [CTRL]+[F12]" .

