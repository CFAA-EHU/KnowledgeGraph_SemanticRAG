    ns1:identificador "CTRL+F11" ;
    ns1:textoExtracto "Tabla de herramientas y del almacén. | TOOLS | [CTRL]+[F11]" .

ns1:TablaUsuario a ns1:Tabla ;
    rdfs:label "TABLES" ;
    ns1:identificador "CTRL+F10" ;
    ns1:textoExtracto "Tablas de usuario. | TABLES | [CTRL]+[F10]" .

ns1:TeclaAnteriorHorizontal a ns1:InterfazUsuario ;
    rdfs:label "BACK" ;
    ns1:identificador "CTRL+F1" ;
    ns1:textoExtracto "Menú anterior horizontal. | BACK | [CTRL]+[F1]" .

ns1:TeclaApagarCNC a ns1:InterfazUsuario ;
    rdfs:label "" ;
    ns1:identificador "ALT+F4" ;
    ns1:textoExtracto "Apagar el CNC. |  | [ALT]+[F4]" .

ns1:TeclaAyuda a ns1:InterfazUsuario ;
    rdfs:label "HELP ?" ;
    ns1:identificador "CTRL+F4" ;
    ns1:textoExtracto "Help. | HELP ? | [CTRL]+[F4]" .

ns1:TeclaBiColor a ns1:InterfazUsuario ;
    rdfs:label "" ;
    ns1:identificador "ALT+B" ;
    ns1:textoExtracto "Tecla bi-color. |  | [ALT]+[B]" .

ns1:TeclaBloqueABloque a ns1:InterfazUsuario ;
    rdfs:label "SINGLE" ;
    ns1:identificador "CTRL+B" ;
    ns1:textoExtracto "Modo bloque a bloque. | SINGLE | [CTRL]+[B]" .

