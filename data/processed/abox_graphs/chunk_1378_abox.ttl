@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Accion_ApagarCNC a ns1:AccionProhibida ;
    rdfs:label "[CTRL]+[W] Apagar el CNC"@es ;
    ns1:habilitadoPor ns1:InterfazUsuario_CNC_821 ;
    ns1:textoExtracto "[CTRL]+[W] | Apagar el CNC."@es .

ns1:Accion_MinimizarMaximizarCNC a ns1:AccionProhibida ;
    rdfs:label "[CTRL]+[O] Minimizar/Maximizar el CNC"@es ;
    ns1:habilitadoPor ns1:InterfazUsuario_CNC_821 ;
    ns1:textoExtracto "[CTRL]+[O] | Minimizar/Maximizar el CNC."@es .

ns1:Accion_MostrarOcultarErrores a ns1:AccionProhibida ;
    rdfs:label "[ALT]+[W] Mostrar/ocultar errores y warnings"@es ;
    ns1:habilitadoPor ns1:InterfazUsuario_CNC_821 ;
    ns1:textoExtracto "[ALT]+[W] | Mostrar / ocultar la ventana de errores y warnings."@es .

ns1:Accion_SincronizacionCanales a ns1:AccionProhibida ;
    rdfs:label "[ALT]+[S] Ventana de sincronización de canales"@es ;
    ns1:habilitadoPor ns1:InterfazUsuario_CNC_821 ;
    ns1:textoExtracto "[ALT]+[S] | Ventana de sincronización de canales."@es .

ns1:InterfazUsuario_CNC_821 a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de usuario del CNC (atajos de teclado)"@es ;
    ns1:identificador "8.2.1" ;
    ns1:textoExtracto "8.2.1 Atajos de teclado. Teclas propias del CNC."@es .

