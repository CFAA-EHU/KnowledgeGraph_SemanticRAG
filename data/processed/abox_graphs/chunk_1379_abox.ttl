@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_M100 a ns1:Parametro ;
    rdfs:label "Marca M100"@es ;
    ns1:identificador "M100" ;
    ns1:monitoreaParametro ns1:OperacionLectura_PLC ;
    ns1:textoExtracto "El PLC activa la marca M100 cuando comienza la operación y la mantiene así hasta que finaliza la misma."@es .

ns1:Registro_R100 a ns1:Parametro ;
    rdfs:label "Registro R100"@es ;
    ns1:identificador "R100" ;
    ns1:textoExtracto "El comando CNCRD guarda el código de la tecla en el registro R100."@es .

ns1:Comando_CNCRD a ns1:AccionProhibida ;
    rdfs:label "Comando CNCRD"@es ;
    ns1:controla ns1:Variable_G_KEY ;
    ns1:identificador "CNCRD" ;
    ns1:requiereMantenimiento ns1:OperacionLectura_PLC ;
    ns1:textoExtracto "El comando CNCRD guarda el código de la tecla en el registro R100. { condición} = CNCRD(G.KEY,R100,M100)"@es .

ns1:InterfazCNC_Teclado a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de teclado del CNC"@es ;
    ns1:textoExtracto "La última tecla aceptada por el CNC"@es .

ns1:PLC_Sistema a ns1:Sistema ;
    rdfs:label "Sistema PLC"@es ;
    ns1:controla ns1:Comando_CNCRD ;
    ns1:textoExtracto "El PLC activa la marca M100 cuando comienza la operación y la mantiene así hasta que finaliza la misma."@es .

ns1:Variable_G_KEY a ns1:Parametro ;
    rdfs:label "Variable G.KEY"@es ;
    ns1:identificador "G.KEY" ;
    ns1:monitoreaParametro ns1:InterfazCNC_Teclado ;
    ns1:textoExtracto "La variable (V.)G.KEY guarda el código de la última tecla aceptada por el CNC (código de tecla pulsada)."@es .

ns1:OperacionLectura_PLC a ns1:TareaMantenimiento ;
    rdfs:label "Operación de lectura desde PLC"@es ;
    ns1:ejecutadoPor ns1:PLC_Sistema ;
    ns1:textoExtracto "Para leer la variable desde el PLC utilizar el comando CNCRD. Lectura de una variable desde el PLC."@es .

