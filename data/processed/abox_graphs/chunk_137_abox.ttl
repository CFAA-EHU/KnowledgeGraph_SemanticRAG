@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix siemens: <http://www.siemens.com/> .
@prefix legrand: <http://www.legrand.com/> .

ex:BornesTornillo1A a owl:Class ;
    rdfs:label "Bornes Tornillo 1A" ;
    rdfs:comment "Componente eléctrico con bornes de tornillo tipo 1A" .

ex:GuardamotorCintaDeEntrada a owl:Class ;
    rdfs:label "Guardamotor Cinta de Entrada" ;
    rdfs:comment "Guardamotor para cinta de entrada" .

ex:BloqueAuxiliarTransversal a owl:Class ;
    rdfs:label "Bloque C. Aux. Transversal" ;
    rdfs:comment "Bloque de control auxiliar transversal con 2 NA y bornes de tornillo" .

ex:CircuitBreakerScrewType93A a owl:Class ;
    rdfs:label "Circuit Breaker, Screw-Type, 93 A" ;
    rdfs:comment "Interruptor de circuito de tornillo tipo 93 A" .

ex:ActuadorGiroParedLat a owl:Class ;
    rdfs:label "Actuador Giro Pared Lat." ;
    rdfs:comment "Actuador de giro para pared lateral estándar con escamoteo monitoreado" .

ex:TapaCubreBornesZocaloEnchuf a owl:Class ;
    rdfs:label "Tapa Cubre Bornes Zocalo Enchuf." ;
    rdfs:comment "Tapa que cubre bornes de zócalo y enchufes, con extensión prolongada" .

ex:MccbIecFs160 a owl:Class ;
    rdfs:label "MCCB_IEC_FS160_125A_3P_70KA_TM_ATFM" ;
    rdfs:comment "Interruptor de corte de corriente IEC FS160 con especificaciones técnicas detalladas" .

ex:RepartidorCorrienteUnipolar a owl:Class ;
    rdfs:label "Repartidor de corriente unipolar (125A)" ;
    rdfs:comment "Repartidor de corriente unipolar con capacidad de 125A" .

ex:SelectorOIBlanco a owl:Class ;
    rdfs:label "Selector, O-I, Blanco" ;
    rdfs:comment "Selector de tipo O-I de color blanco" .

ex:PulsadorSetaParoEmergencia a owl:Class ;
    rdfs:label "Pulsador Seta Paro Emerg." ;
    rdfs:comment "Pulsador de parada de emergencia con forma de seta" .

ex:tieneModelo a owl:ObjectProperty ;
    rdfs:domain ex:ComponenteElectrico ;
    rdfs:range xsd:string .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:ComponenteElectrico ;
    rdfs:range xsd:string .

ex:tieneCodigo a owl:ObjectProperty ;
    rdfs:domain ex:ComponenteElectrico ;
    rdfs:range xsd:string .

ex:tieneCantidad a owl:ObjectProperty ;
    rdfs:domain ex:ComponenteElectrico ;
    rdfs:range xsd:integer .

siemens:3RV2011-0JA10 a owl:NamedIndividual ,
                    ex:BornesTornillo1A ;
    ex:tieneModelo "3RV2011-0JA10" ;
    ex:tieneFabricante "SIEMENS" ;
    ex:tieneCantidad 1 .

siemens:3RV2901-1F a owl:NamedIndividual ,
                    ex:BloqueAuxiliarTransversal ;
    ex:tieneModelo "3RV2901-1F" ;
    ex:tieneFabricante "SIEMENS" ;
    ex:tieneCantidad 1 .

siemens:3RV2041-4YA10 a owl:NamedIndividual ,
                        ex:CircuitBreakerScrewType93A ;
    ex:tieneModelo "3RV2041-4YA10" ;
    ex:tieneFabricante "SIEMENS AG" ;
    ex:tieneCantidad 1 .

siemens:3VA9157-0PK51 a owl:NamedIndividual ,
                        ex:ActuadorGiroParedLat ;
    ex:tieneModelo "3VA9157-0PK51" ;
    ex:tieneFabricante "SIEMENS AG" ;
    ex:tieneCantidad 1 .

siemens:3VA9153-0KB04 a owl:NamedIndividual ,
                        ex:TapaCubreBornesZocaloEnchuf ;
    ex:tieneModelo "3VA9153-0KB04" ;
    ex:tieneFabricante "SIEMENS AG" ;
    ex:tieneCantidad 2 .

siemens:3VA1112-6EE36-0AA0 a owl:NamedIndividual ,
                              ex:MccbIecFs160 ;
    ex:tieneModelo "3VA1112-6EE36-0AA0" ;
    ex:tieneFabricante "SIEMENS AG" ;
    ex:tieneCantidad 1 .

legrand:04871 a owl:NamedIndividual ,
                  ex:RepartidorCorrienteUnipolar ;
    ex:tieneModelo "04871" ;
    ex:tieneFabricante "LEGRAND" ;
    ex:tieneCantidad 3 .

siemens:3SU1052-2CF60-0AA0 a owl:NamedIndividual ,
                              ex:SelectorOIBlanco ;
    ex:tieneModelo "3SU1052-2CF60-0AA0" ;
    ex:tieneFabricante "SIEMENS AG" ;
    ex:tieneCantidad 1 .

siemens:PulsadorSetaParoEmergencia a owl:NamedIndividual ,
                                      ex:PulsadorSetaParoEmergencia ;
    ex:tieneModelo "PulsadorSetaParoEmergencia" ;
    ex:tieneFabricante "SIEMENS AG" ;
    ex:tieneCantidad 1 .