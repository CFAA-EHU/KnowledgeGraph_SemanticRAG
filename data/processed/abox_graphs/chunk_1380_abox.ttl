@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Comando_CNCWR a ns1:AccionProhibida ;
    rdfs:label "Comando CNCWR" ;
    ns1:textoExtracto "Para escribir la variable desde el PLC utilizar el comando CNCWR." .

ns1:Marca_M101 a ns1:Parametro ;
    rdfs:label "Marca M101" ;
    ns1:textoExtracto "El PLC activa la marca M101 cuando comienza la operación y la mantiene así hasta que finaliza la misma." .

ns1:Registro_R101 a ns1:Parametro ;
    rdfs:label "Registro R101" ;
    ns1:textoExtracto "El comando CNCWR escribe en la variable el valor del registro registro R101." .

ns1:Tecla_Generica a ns1:Componente ;
    rdfs:label "Tecla genérica" ;
    ns1:textoExtracto "Enviar el código asociado a pulsar la tecla de la letra." .

ns1:Tecla_SHIFT a ns1:Componente ;
    rdfs:label "Tecla SHIFT" ;
    ns1:textoExtracto "añadir el código correspondiente a la tecla [SHIFT]" .

ns1:V_G_KEY a ns1:Parametro ;
    rdfs:label "Variable G.KEY" ;
    ns1:textoExtracto "Para simular el teclado desde el PLC, escribir en la variable (V.)G.KEY el código de la tecla." .

