@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaSimulacionTeclado_PLC a ns1:Sistema ;
    rdfs:label "Sistema de simulación de teclado desde PLC" ;
    ns1:textoExtracto "Simular el teclado desde el PLC (...) Inicializar los registros (...) DFU B0KEYBD1 = CNCWR(R204,G.KEY,M204)" ;
    ns1:tieneComponente ns1:CombinacionTeclas_B0KEYBD1,
        ns1:Registro_R204,
        ns1:Registro_R205,
        ns1:Registro_R206,
        ns1:Registro_R207 .

ns1:CombinacionTeclas_B0KEYBD1 a ns1:InterfazUsuario ;
    rdfs:label "Combinación de teclas B0KEYBD1 (CTRL+F1)" ;
    ns1:identificador "B0KEYBD1" ;
    ns1:textoExtracto "La primera tecla de usuario (B0KEYBD1) envía la combinación [CTRL]+[F1]" ;
    ns1:tieneComponente ns1:Tecla_CTRL,
        ns1:Tecla_F1 .

ns1:Registro_R204 a ns1:Parametro ;
    rdfs:label "Registro R204 (Pulsar CTRL)" ;
    ns1:identificador "R204" ;
    ns1:textoExtracto "MOV $1D R204 ; Pulsar la tecla [CTRL]" ;
    ns1:valor "$1D" .

ns1:Registro_R205 a ns1:Parametro ;
    rdfs:label "Registro R205 (Soltar CTRL)" ;
    ns1:identificador "R205" ;
    ns1:textoExtracto "MOV $9D R205 ; Soltar la tecla [CTRL]" ;
    ns1:valor "$9D" .

ns1:Registro_R206 a ns1:Parametro ;
    rdfs:label "Registro R206 (Pulsar F1)" ;
    ns1:identificador "R206" ;
    ns1:textoExtracto "MOV $3B R206 ; Pulsar la tecla [F1]" ;
    ns1:valor "$3B" .

ns1:Registro_R207 a ns1:Parametro ;
    rdfs:label "Registro R207 (Soltar F1)" ;
    ns1:identificador "R207" ;
    ns1:textoExtracto "MOV $BB R207 ; Soltar la tecla [F1]" ;
    ns1:valor "$BB" .

ns1:Tecla_CTRL a ns1:ComponenteElectrico ;
    rdfs:label "Tecla CTRL" ;
    ns1:identificador "$1D" ;
    ns1:textoExtracto "Pulsar la tecla [CTRL] (...) MOV $1D R204 ; Pulsar la tecla [CTRL]" .

ns1:Tecla_F1 a ns1:ComponenteElectrico ;
    rdfs:label "Tecla F1" ;
    ns1:identificador "$3B" ;
    ns1:textoExtracto "Pulsar la tecla [F1] (...) MOV $3B R206 ; Pulsar la tecla [F1]" .

