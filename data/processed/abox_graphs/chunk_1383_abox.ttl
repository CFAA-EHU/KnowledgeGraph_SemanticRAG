@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_TecladoEspanol a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de Teclado (Distribución Español - España)"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosTeclado_Espanol ;
    ns1:textoExtracto "Scan codes. Distribución de teclado 'Español (España)'."@es ;
    ns1:tieneComponente ns1:Tecla_Alt,
        ns1:Tecla_AltGr,
        ns1:Tecla_BarraEspaciadora,
        ns1:Tecla_BloquearMayusculas,
        ns1:Tecla_Control,
        ns1:Tecla_Mayusculas,
        ns1:Tecla_Retroceso .

ns1:Tecla_Alt a ns1:Componente ;
    rdfs:label "Tecla Alternativo (ALT)"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_CodigosTeclado_Espanol ;
    ns1:identificador "$38 (pulsar) / $B8 (soltar)" ;
    ns1:textoExtracto "Alternativo (ALT)."@es .

ns1:Tecla_AltGr a ns1:Componente ;
    rdfs:label "Tecla Alternativo Gráfico (ALT GR)"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_CodigosTeclado_Espanol ;
    ns1:identificador "$E0$38 (pulsar) / $E0$B8 (soltar)" ;
    ns1:textoExtracto "Alternativo gráfico (ALT GR)."@es .

ns1:Tecla_BarraEspaciadora a ns1:Componente ;
    rdfs:label "Tecla Barra Espaciadora"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_CodigosTeclado_Espanol ;
    ns1:identificador "$39 (pulsar) / $B9 (soltar)" ;
    ns1:textoExtracto "Barra espaciadora."@es .

ns1:Tecla_BloquearMayusculas a ns1:Componente ;
    rdfs:label "Tecla Bloquear Mayúsculas"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_CodigosTeclado_Espanol ;
    ns1:identificador "$3A (pulsar) / $BA (soltar)" ;
    ns1:textoExtracto "Bloquear mayúsculas."@es .

ns1:Tecla_Control a ns1:Componente ;
    rdfs:label "Tecla Control (CTRL)"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_CodigosTeclado_Espanol ;
    ns1:identificador "$1D (pulsar) / $9D (soltar)" ;
    ns1:textoExtracto "Control (CTRL)."@es .

ns1:Tecla_Mayusculas a ns1:Componente ;
    rdfs:label "Tecla Mayúsculas (SHIFT)"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_CodigosTeclado_Espanol ;
    ns1:identificador "$2A / $36 (pulsar) / $AA / $B6 (soltar)" ;
    ns1:textoExtracto "Mayúsculas (SHIFT)."@es .

ns1:Tecla_Retroceso a ns1:Componente ;
    rdfs:label "Tecla Retroceso (Backspace)"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_CodigosTeclado_Espanol ;
    ns1:identificador "$0E (pulsar) / $8E (soltar)" ;
    ns1:textoExtracto "Retroceso (backspace)."@es .

ns1:Tabla_CodigosTeclado_Espanol a ns1:Tabla ;
    rdfs:label "Tabla de códigos de tecla para distribución 'Español (España)'"@es ;
    ns1:documentadoEn ns1:Manual_Seccion8_5 ;
    ns1:identificador "8.5.1 Scan codes. Distribución de teclado 'Español (España)'" ;
    ns1:textoExtracto "En las teclas con varios caracteres, para enviar el primer carácter (minúscula), utilizar los códigos indicados; para el segundo carácter (mayúsculas), añadir el código correspondiente a la tecla [SHIFT], de la siguiente manera; para el tercer carácter, utilizar el código correspondiente a la tecla [ALT GR]."@es .

