@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_Teclado a ns1:InterfazUsuario ;
    rdfs:label "Teclado (distribución Inglés - Estados Unidos)"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_ScanCodes_InglesUS ;
    ns1:textoExtracto "Scan codes. Distribución de teclado \"Inglés (Estados Unidos)\""@es ;
    ns1:tieneComponente ns1:Tecla_Alt,
        ns1:Tecla_AltGr,
        ns1:Tecla_AvPag,
        ns1:Tecla_Backspace,
        ns1:Tecla_BarraEspaciadora,
        ns1:Tecla_BloquearMayusculas,
        ns1:Tecla_Ctrl,
        ns1:Tecla_Fin,
        ns1:Tecla_FlechaAbajo,
        ns1:Tecla_FlechaArriba,
        ns1:Tecla_FlechaDerecha,
        ns1:Tecla_FlechaIzquierda,
        ns1:Tecla_ImprimirPantalla,
        ns1:Tecla_Inicio,
        ns1:Tecla_RePag,
        ns1:Tecla_Shift .

ns1:Tabla_ScanCodes_InglesUS a ns1:Tabla ;
    rdfs:label "Tabla de scan codes para distribución de teclado Inglés (Estados Unidos)"@es ;
    ns1:identificador "8.5.2" ;
    ns1:textoExtracto "En las teclas con varios caracteres, para enviar el primer carácter (minúscula), utilizar los códigos indicados; para el segundo carácter (mayúsculas), añadir el código correspondiente a la tecla [SHIFT]."@es .

ns1:Tecla_Alt a ns1:Componente ;
    rdfs:label "Alternativo (ALT)"@es ;
    ns1:identificador "$38 (pulsar) / $B8 (soltar)" ;
    ns1:textoExtracto "Alternativo (ALT)"@es .

ns1:Tecla_AltGr a ns1:Componente ;
    rdfs:label "Alternativo gráfico (ALT GR)"@es ;
    ns1:identificador "$E0$38 (pulsar) / $E0$B8 (soltar)" ;
    ns1:textoExtracto "Alternativo gráfico (ALT GR)"@es .

ns1:Tecla_AvPag a ns1:Componente ;
    rdfs:label "Avanzar página"@es ;
    ns1:identificador "$E0$51 (pulsar) / $E0$D1 (soltar)" ;
    ns1:textoExtracto "Avanzar página"@es .

ns1:Tecla_Backspace a ns1:Componente ;
    rdfs:label "Retroceso (Backspace)"@es ;
    ns1:identificador "$0E (pulsar) / $8E (soltar)" ;
    ns1:textoExtracto "Retroceso (Backspace)"@es .

ns1:Tecla_BarraEspaciadora a ns1:Componente ;
    rdfs:label "Barra espaciadora"@es ;
    ns1:identificador "$39 (pulsar) / $B9 (soltar)" ;
    ns1:textoExtracto "Barra espaciadora"@es .

ns1:Tecla_BloquearMayusculas a ns1:Componente ;
    rdfs:label "Bloquear mayúsculas"@es ;
    ns1:identificador "$3A (pulsar) / $BA (soltar)" ;
    ns1:textoExtracto "Bloquear mayúsculas"@es .

ns1:Tecla_Ctrl a ns1:Componente ;
    rdfs:label "Control (CTRL)"@es ;
    ns1:identificador "$1D (pulsar) / $9D (soltar)" ;
    ns1:textoExtracto "Control (CTRL)"@es .

ns1:Tecla_Fin a ns1:Componente ;
    rdfs:label "Fin"@es ;
    ns1:identificador "$E0$4F (pulsar) / $E0$CF (soltar)" ;
    ns1:textoExtracto "Fin"@es .

ns1:Tecla_FlechaAbajo a ns1:Componente ;
    rdfs:label "Flecha abajo"@es ;
    ns1:identificador "$E0$50 (pulsar) / $E0$D0 (soltar)" ;
    ns1:textoExtracto "Flecha abajo"@es .

ns1:Tecla_FlechaArriba a ns1:Componente ;
    rdfs:label "Flecha arriba"@es ;
    ns1:identificador "$E0$48 (pulsar) / $E0$C8 (soltar)" ;
    ns1:textoExtracto "Flecha arriba"@es .

ns1:Tecla_FlechaDerecha a ns1:Componente ;
    rdfs:label "Flecha derecha"@es ;
    ns1:identificador "$E0$4D (pulsar) / $E0$CD (soltar)" ;
    ns1:textoExtracto "Flecha derecha"@es .

ns1:Tecla_FlechaIzquierda a ns1:Componente ;
    rdfs:label "Flecha izquierda"@es ;
    ns1:identificador "$E0$4B (pulsar) / $E0$CB (soltar)" ;
    ns1:textoExtracto "Flecha izquierda"@es .

ns1:Tecla_ImprimirPantalla a ns1:Componente ;
    rdfs:label "Imprimir pantalla"@es ;
    ns1:identificador "$E0$37 (pulsar) / $E0$B7 (soltar)" ;
    ns1:textoExtracto "Imprimir pantalla"@es .

ns1:Tecla_Inicio a ns1:Componente ;
    rdfs:label "Inicio"@es ;
    ns1:identificador "$E0$47 (pulsar) / $E0$C7 (soltar)" ;
    ns1:textoExtracto "Inicio"@es .

ns1:Tecla_RePag a ns1:Componente ;
    rdfs:label "Retroceder página"@es ;
    ns1:identificador "$E0$49 (pulsar) / $E0$C9 (soltar)" ;
    ns1:textoExtracto "Retroceder página"@es .

ns1:Tecla_Shift a ns1:Componente ;
    rdfs:label "Mayúsculas (SHIFT)"@es ;
    ns1:identificador "$2A / $36 (pulsar) / $AA / $B6 (soltar)" ;
    ns1:textoExtracto "Mayúsculas (SHIFT)"@es .

