@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:B0KEYBD1 a ns1:ComponenteElectrico ;
    rdfs:label "B0KEYBD1" ;
    ns1:compuestoPor ns1:BusquedaReferenciaEjeX,
        ns1:ModoMDI,
        ns1:ModoManual ;
    ns1:textoExtracto "La primera tecla de usuario (B0KEYBD1)" ;
    ns1:tieneComponente ns1:Retardo200ms .

ns1:BusquedaReferenciaEjeX a ns1:TareaMantenimiento ;
    ns1:textoExtracto "El CNC realiza una búsqueda de referencia máquina del eje X." .

ns1:ModoMDI a ns1:ModoOperacion ;
    ns1:textoExtracto "El CNC accede al modo MDI." .

ns1:ModoManual a ns1:ModoOperacion ;
    ns1:textoExtracto "El CNC accede al modo manual." .

ns1:Retardo200ms a ns1:Parametro ;
    ns1:textoExtracto "En el ejemplo se utiliza un retardo de 200ms entre el envío de ambos códigos (por seguridad)." ;
    ns1:valor "200ms" .

