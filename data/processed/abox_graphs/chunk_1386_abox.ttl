@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_TecladoSimulado a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de teclado simulado desde PLC"@es ;
    ns1:documentadoEn ns1:Pagina_549 ;
    ns1:textoExtracto "Simular el teclado desde el PLC"@es ;
    ns1:tieneComponente ns1:ModoOperacion_MDI,
        ns1:ModoOperacion_Manual .

ns1:TareaMantenimiento_InicializacionRegistros a ns1:TareaMantenimiento ;
    rdfs:label "Inicialización de registros para simulación de teclado"@es ;
    ns1:identificador "START OR DFU M313" ;
    ns1:textoExtracto "Inicializar los registros. START OR DFU M313 = CYSTART"@es .

ns1:ModoOperacion_MDI a ns1:ModoOperacion ;
    rdfs:label "Modo MDI"@es ;
    ns1:identificador "[CTRL]+[F8]" ;
    ns1:textoExtracto "El CNC accede al modo MDI. [CTRL]+[F8]"@es .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo manual"@es ;
    ns1:identificador "[CTRL]+[F7]" ;
    ns1:textoExtracto "El CNC accede al modo manual. [CTRL]+[F7]"@es .

