@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_TecladoSimulado a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de teclado simulado (G.KEY)" ;
    ns1:identificador "G.KEY" ;
    ns1:textoExtracto "CNCWR(R206,G.KEY,M206) [...] CNCWR(R214,G.KEY,M214)" .

ns1:Parametro_EstadoCNC a ns1:Parametro ;
    rdfs:label "Estado del CNC (R220)" ;
    ns1:monitoreaParametro ns1:Sistema_ComunicacionPLC_CNC ;
    ns1:textoExtracto "CPS R220 EQ 1) = CNCWR(R216,G.KEY,M216) [...] Estado del CNC (\"1\"=READY)" ;
    ns1:valor "1" .

ns1:ComponenteElectrico_Timer204 a ns1:ComponenteElectrico ;
    rdfs:label "Timer T204 (M304)" ;
    ns1:identificador "T204" ;
    ns1:textoExtracto "T204 = M304 [...] DFD M304 = CNCWR(R207,G.KEY,M207)" .

ns1:ComponenteElectrico_Timer205 a ns1:ComponenteElectrico ;
    rdfs:label "Timer T205 (M305)" ;
    ns1:identificador "T205" ;
    ns1:textoExtracto "T205 = M305 [...] DFD M305 = CNCWR(R208,G.KEY,M208)" .

ns1:ComponenteElectrico_Timer206 a ns1:ComponenteElectrico ;
    rdfs:label "Timer T206 (M306)" ;
    ns1:identificador "T206" ;
    ns1:textoExtracto "T206 = M306 [...] DFD M306 = CNCWR(R209,G.KEY,M209)" .

ns1:ComponenteElectrico_Timer207 a ns1:ComponenteElectrico ;
    rdfs:label "Timer T207 (M307)" ;
    ns1:identificador "T207" ;
    ns1:textoExtracto "T207 = M307 [...] DFD M307 = CNCWR(R210,G.KEY,M210)" .

ns1:ComponenteElectrico_Timer208 a ns1:ComponenteElectrico ;
    rdfs:label "Timer T208 (M308)" ;
    ns1:identificador "T208" ;
    ns1:textoExtracto "T208 = M308 [...] DFD M308 = CNCWR(R211,G.KEY,M211)" .

ns1:ComponenteElectrico_Timer209 a ns1:ComponenteElectrico ;
    rdfs:label "Timer T209 (M309)" ;
    ns1:identificador "T209" ;
    ns1:textoExtracto "T209 = M309 [...] DFD M309 = CNCWR(R212,G.KEY,M212)" .

ns1:ComponenteElectrico_Timer210 a ns1:ComponenteElectrico ;
    rdfs:label "Timer T210 (M310)" ;
    ns1:identificador "T210" ;
    ns1:textoExtracto "T210 = M310 [...] DFD M310 = CNCWR(R213,G.KEY,M213)" .

ns1:ComponenteElectrico_Timer211 a ns1:ComponenteElectrico ;
    rdfs:label "Timer T211 (M311)" ;
    ns1:identificador "T211" ;
    ns1:textoExtracto "T211 = M311 [...] DFD M311 = CNCWR(R214,G.KEY,M214)" .

ns1:ComponenteElectrico_Timer212 a ns1:ComponenteElectrico ;
    rdfs:label "Timer T212 (M312)" ;
    ns1:identificador "T212" ;
    ns1:textoExtracto "T212 = M312 [...] DFD M312 = CNCWR(R215,G.KEY,M215)" .

ns1:ComponenteElectrico_Timer213 a ns1:ComponenteElectrico ;
    rdfs:label "Timer T213 (M313)" ;
    ns1:identificador "T213" ;
    ns1:textoExtracto "T213 = M313 [...] DFD M313 = SET M500" .

ns1:ComponenteElectrico_Timer214 a ns1:ComponenteElectrico ;
    rdfs:label "Timer T214 (M314)" ;
    ns1:identificador "T214" ;
    ns1:textoExtracto "T214 = M314 [...] DFD M314 = CNCWR(R217,G.KEY,M217)" .

ns1:ModoOperacion_G74 a ns1:ModoOperacion ;
    rdfs:label "Modo de simulación del teclado desde PLC (G74)" ;
    ns1:identificador "G74" ;
    ns1:textoExtracto "G74 [...] El CNC sale del modo MDI." .

ns1:Sistema_ComunicacionPLC_CNC a ns1:Sistema ;
    rdfs:label "Sistema de comunicación PLC-CNC (T204-T214)" ;
    ns1:compuestoPor ns1:ComponenteElectrico_Timer204,
        ns1:ComponenteElectrico_Timer205,
        ns1:ComponenteElectrico_Timer206,
        ns1:ComponenteElectrico_Timer207,
        ns1:ComponenteElectrico_Timer208,
        ns1:ComponenteElectrico_Timer209,
        ns1:ComponenteElectrico_Timer210,
        ns1:ComponenteElectrico_Timer211,
        ns1:ComponenteElectrico_Timer212,
        ns1:ComponenteElectrico_Timer213,
        ns1:ComponenteElectrico_Timer214 ;
    ns1:ilustradoEn ns1:ModoOperacion_G74 ;
    ns1:textoExtracto "DFD M303 = CNCWR(R206,G.KEY,M206) = TG1 204 200 [...] T214 = M314" .

