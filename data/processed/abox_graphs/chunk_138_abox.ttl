@prefix ex: <https://vocab.cfaa.eus/broaching/>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

ex:EmergenciaPanelOperador a owl:Class ;
    rdfs:label "EmergenciaPanelOperador" ;
    rdfs:comment "Clase que representa el panel de operador de emergencia." .

ex:Soporte a owl:Class ;
    rdfs:label "Soporte" ;
    rdfs:comment "Clase que representa el soporte del panel de operador de emergencia." .

ex:ContactModule1NC a owl:Class ;
    rdfs:label "ContactModule1NC" ;
    rdfs:comment "Clase que representa el módulo de contacto 1NC del panel de operador de emergencia." .

ex:SiemensAG a owl:Class ;
    rdfs:label "SiemensAG" ;
    rdfs:comment "Clase que representa la empresa Siemens AG." .

ex:tieneModelo a owl:ObjectProperty ;
    rdfs:domain ex:EmergenciaPanelOperador ;
    rdfs:range xsd:string ;
    rdfs:comment "Propiedad que indica el modelo del panel de operador de emergencia." .

ex:tieneCodigo a owl:ObjectProperty ;
    rdfs:domain ex:EmergenciaPanelOperador ;
    rdfs:range xsd:string ;
    rdfs:comment "Propiedad que indica el código del panel de operador de emergencia." .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:EmergenciaPanelOperador ;
    rdfs:range ex:SiemensAG ;
    rdfs:comment "Propiedad que indica el fabricante del panel de operador de emergencia." .

ex:tieneCantidad a owl:ObjectProperty ;
    rdfs:domain ex:EmergenciaPanelOperador ;
    rdfs:range xsd:integer ;
    rdfs:comment "Propiedad que indica la cantidad del panel de operador de emergencia." .

ex:tieneColor a owl:ObjectProperty ;
    rdfs:domain ex:EmergenciaPanelOperador ;
    rdfs:range xsd:string ;
    rdfs:comment "Propiedad que indica el color del panel de operador de emergencia." .

ex:tieneTipo a owl:ObjectProperty ;
    rdfs:domain ex:EmergenciaPanelOperador ;
    rdfs:range xsd:string ;
    rdfs:comment "Propiedad que indica el tipo del panel de operador de emergencia." .