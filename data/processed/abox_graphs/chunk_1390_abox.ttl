ns1:NormaDIN66217 a ns1:Directiva ;
    rdfs:label "Norma DIN 66217" ;
    ns1:identificador "DIN66217" ;
    ns1:textoExtracto "Nombre de los ejes en función de su tipo. Norma DIN66217. El CNC permite asignar cualquier nombre de los anteriormente citados a cualquier tipo de eje (rotativos, auxiliares, etc). No obstante, en la medida de lo posible, es recomendable aplicar la norma DIN 66217 a la hora de denominar los ejes de la máquina." .

ns1:TablaConfiguracionEjes a ns1:Tabla ;
    rdfs:label "Tabla de configuración de ejes según DIN 66217" ;
    ns1:textoExtracto "Nombre de los ejes en función de su tipo. Norma DIN66217. | Nombre. | Tipo de eje según la norma DIN 66217. | | --- | --- | | Xn Yn Zn | Ejes principales. Dos ejes forman el plano de trabajo y el tercer eje corresponde al eje perpendicular al plano. | | Un Vn Wn | Ejes auxiliares, paralelos a X-Y-Z respectivamente. | | An Bn Cn | Ejes rotativos, sobre los ejes X-Y-Z respectivamente. |" ;
    ns1:tieneComponente ns1:EjeAuxiliarU,
        ns1:EjeAuxiliarV,
        ns1:EjeAuxiliarW,
        ns1:EjePrincipalX,
        ns1:EjePrincipalY,
        ns1:EjePrincipalZ,
        ns1:EjeRotativoA,
        ns1:EjeRotativoB,
        ns1:EjeRotativoC .

ns1:EjeAuxiliarU a ns1:Maquina ;
    rdfs:label "Eje auxiliar U" ;
    ns1:textoExtracto "Un Vn Wn | Ejes auxiliares, paralelos a X-Y-Z respectivamente." .

ns1:EjeAuxiliarV a ns1:Maquina ;
    rdfs:label "Eje auxiliar V" ;
    ns1:textoExtracto "Un Vn Wn | Ejes auxiliares, paralelos a X-Y-Z respectivamente." .

ns1:EjeAuxiliarW a ns1:Maquina ;
    rdfs:label "Eje auxiliar W" ;
    ns1:textoExtracto "Un Vn Wn | Ejes auxiliares, paralelos a X-Y-Z respectivamente." .

ns1:EjePrincipalX a ns1:Maquina ;
    rdfs:label "Eje principal X" ;
    ns1:textoExtracto "Xn Yn Zn | Ejes principales. Dos ejes forman el plano de trabajo y el tercer eje corresponde al eje perpendicular al plano." .

ns1:EjePrincipalY a ns1:Maquina ;
    rdfs:label "Eje principal Y" ;
    ns1:textoExtracto "Xn Yn Zn | Ejes principales. Dos ejes forman el plano de trabajo y el tercer eje corresponde al eje perpendicular al plano." .

ns1:EjePrincipalZ a ns1:Maquina ;
