ns1:EjeRotativoA a ns1:Maquina ;
    rdfs:label "Eje rotativo A" ;
    ns1:textoExtracto "An Bn Cn | Ejes rotativos, sobre los ejes X-Y-Z respectivamente." .

ns1:EjeRotativoB a ns1:Maquina ;
