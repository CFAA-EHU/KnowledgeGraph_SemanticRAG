@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_AXISNAME a ns1:Parametro ;
    rdfs:label "AXISNAME"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosConfiguracionEjesCabezales ;
    ns1:identificador "AXISNAME" ;
    ns1:monitoreaParametro ns1:Parametro_NAXIS ;
    ns1:textoExtracto "AXISNAME | Lista de ejes del sistema."@es .

ns1:Parametro_SPDLNAME a ns1:Parametro ;
    rdfs:label "SPDLNAME"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosConfiguracionEjesCabezales ;
    ns1:identificador "SPDLNAME" ;
    ns1:monitoreaParametro ns1:Parametro_NSPDL ;
    ns1:textoExtracto "SPDLNAME | Lista de cabezales del sistema."@es .

ns1:Sistema_LogicaNumeracionEjesCabezales a ns1:Sistema ;
    rdfs:label "Sistema de numeración lógica de ejes y cabezales"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_ParametrosConfiguracionEjesCabezales ;
    ns1:textoExtracto "El número lógico de los ejes y cabezales viene establecido por el orden en el que están definidos en los parámetros máquinas AXISNAME y SPDLNAME. [...] La numeración lógica de cabezales continúa a partir del último eje lógico; así, en un sistema con 3 ejes, el primer cabezal de la tabla SPDLNAME será el cabezal lógico ꞏ4ꞏ y así sucesivamente."@es .

ns1:Pagina_556 a ns1:Pagina ;
    rdfs:label "Página 556 - Configuración de ejes y cabezales"@es ;
    ns1:documentadoEn ns1:Manual ;
    ns1:textoExtracto "Sección 10.1.1 Configurar el número de ejes y cabezales del sistema."@es .

ns1:Parametro_NAXIS a ns1:Parametro ;
    rdfs:label "NAXIS"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosConfiguracionEjesCabezales ;
    ns1:identificador "NAXIS" ;
    ns1:textoExtracto "NAXIS | Número de ejes del sistema."@es .

ns1:Parametro_NSPDL a ns1:Parametro ;
    rdfs:label "NSPDL"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosConfiguracionEjesCabezales ;
    ns1:identificador "NSPDL" ;
    ns1:textoExtracto "NSPDL | Número de cabezales del sistema."@es .

ns1:Tabla_ParametrosConfiguracionEjesCabezales a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de configuración de ejes y cabezales"@es ;
    ns1:ilustradoEn ns1:Pagina_556 ;
    ns1:textoExtracto "La configuración de ejes y cabezales del sistema se define mediante los parámetros máquina NAXIS, AXISNAME, NSPDL y SPDLNAME."@es .

