@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Cabezal_Indice1 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal con índice 1"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionCabezales ;
    ns1:identificador "SPDLNAME_1" ;
    ns1:textoExtracto "SPDLNAME 1 | Número lógico ꞏ4ꞏ. | Cabezal con índice ꞏ1ꞏ."@es .

ns1:Cabezal_Indice2 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal con índice 2"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionCabezales ;
    ns1:identificador "SPDLNAME_2" ;
    ns1:textoExtracto "SPDLNAME 2 | Número lógico ꞏ5ꞏ. | Cabezal con índice ꞏ2ꞏ."@es .

ns1:Parametro_AXISNAME a ns1:Parametro ;
    rdfs:label "Parámetro AXISNAME"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_ConfiguracionCabezales ;
    ns1:identificador "AXISNAME" ;
    ns1:textoExtracto "AXISNAME 1 | Número lógico ꞏ1ꞏ. | AXISNAME 2 | Número lógico ꞏ2ꞏ. | AXISNAME 3 | Número lógico ꞏ3ꞏ."@es .

ns1:Parametro_SPDLNAME a ns1:Parametro ;
    rdfs:label "Parámetro máquina SPDLNAME"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_ConfiguracionCabezales ;
    ns1:identificador "SPDLNAME" ;
    ns1:textoExtracto "El índice de un cabezal en el sistema viene establecido por el orden en el que está definido en el parámetro máquina SPDLNAME."@es .

ns1:Tabla_ConfiguracionCabezales a ns1:Tabla ;
    rdfs:label "Tabla de configuración de cabezales y ejes (SPDLNAME/AXISNAME)"@es ;
    ns1:documentadoEn ns1:Pagina_556 ;
    ns1:textoExtracto "AXISNAME | SPDLNAME | Orden lógico. | Índice en el sistema. | --- | --- | --- | | AXISNAME 1 | Número lógico ꞏ1ꞏ. | | AXISNAME 2 | Número lógico ꞏ2ꞏ. | | AXISNAME 3 | Número lógico ꞏ3ꞏ. | | SPDLNAME 1 | Número lógico ꞏ4ꞏ. | Cabezal con índice ꞏ1ꞏ. | SPDLNAME 2 | Número lógico ꞏ5ꞏ. | Cabezal con índice ꞏ2ꞏ."@es .

