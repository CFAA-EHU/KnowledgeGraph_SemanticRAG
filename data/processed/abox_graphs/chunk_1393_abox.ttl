@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_Multicanal a ns1:Sistema ;
    rdfs:label "Sistema de configuración monocanal/multicanal" ;
    ns1:compuestoPor ns1:Parametro_CHAXISNAME,
        ns1:Parametro_CHNAXIS,
        ns1:Parametro_CHNSPDL,
        ns1:Parametro_CHSPDLNAME,
        ns1:Parametro_NAXIS ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionCanales ;
    ns1:textoExtracto "En un sistema monocanal o multicanal hay que distribuir los ejes y cabezales definidos en el sistema entre los diferentes canales." .

ns1:Parametro_CHNAXIS a ns1:Parametro ;
    rdfs:label "CHNAXIS" ;
    ns1:identificador "CHNAXIS" ;
    ns1:textoExtracto "CHNAXIS | Número de ejes del canal." .

ns1:Parametro_CHNSPDL a ns1:Parametro ;
    rdfs:label "CHNSPDL" ;
    ns1:identificador "CHNSPDL" ;
    ns1:textoExtracto "CHNSPDL | Número de cabezales del canal." .

ns1:Parametro_NAXIS a ns1:Parametro ;
    rdfs:label "NAXIS" ;
    ns1:identificador "NAXIS" ;
    ns1:textoExtracto "número de ejes del sistema, definido en el parámetro NAXIS" .

ns1:Tabla_ConfiguracionCanales a ns1:Tabla ;
    rdfs:label "Tabla de configuración de ejes y cabezales por canal" ;
    ns1:detalladoEnEsquema ns1:Parametro_CHAXISNAME,
        ns1:Parametro_CHSPDLNAME ;
    ns1:textoExtracto "CHAXISNAME | CHSPDLNAME | Índice en el canal." .

ns1:Parametro_CHAXISNAME a ns1:Parametro ;
    rdfs:label "CHAXISNAME" ;
    ns1:identificador "CHAXISNAME" ;
    ns1:textoExtracto "CHAXISNAME | Lista de ejes del canal." .

ns1:Parametro_CHSPDLNAME a ns1:Parametro ;
    rdfs:label "CHSPDLNAME" ;
    ns1:identificador "CHSPDLNAME" ;
    ns1:textoExtracto "CHSPDLNAME | Lista de cabezales del canal." .

