@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Cabezal_1 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal 1"@es ;
    ns1:documentadoEn ns1:TablaConfiguracionCanales ;
    ns1:identificador "CHSPDLNAME 1" ;
    ns1:textoExtracto "Cabezal con índice ꞏ1ꞏ."@es .

ns1:Cabezal_2 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal 2"@es ;
    ns1:documentadoEn ns1:TablaConfiguracionCanales ;
    ns1:identificador "CHSPDLNAME 2" ;
    ns1:textoExtracto "CHSPDLNAME 2"@es .

ns1:Eje_1 a ns1:ComponenteMecanico ;
    rdfs:label "Eje 1"@es ;
    ns1:documentadoEn ns1:TablaConfiguracionCanales ;
    ns1:identificador "CHAXISNAME 1" ;
    ns1:textoExtracto "Eje con índice ꞏ1ꞏ."@es .

ns1:Eje_2 a ns1:ComponenteMecanico ;
    rdfs:label "Eje 2"@es ;
    ns1:documentadoEn ns1:TablaConfiguracionCanales ;
    ns1:identificador "CHAXISNAME 2" ;
    ns1:textoExtracto "CHAXISNAME 2"@es .

ns1:Eje_3 a ns1:ComponenteMecanico ;
    rdfs:label "Eje 3"@es ;
    ns1:documentadoEn ns1:TablaConfiguracionCanales ;
    ns1:identificador "CHAXISNAME 3" ;
    ns1:textoExtracto "CHAXISNAME 3"@es .

ns1:TablaConfiguracionCanales a ns1:Tabla ;
    rdfs:label "Tabla de configuración de ejes y cabezales (CHSPDLNAME/CHAXISNAME)"@es ;
    ns1:identificador "CHSPDLNAME/CHAXISNAME" ;
    ns1:textoExtracto "El primer cabezal de la tabla CHSPDLNAME tendrá índice ꞏ1ꞏ y así sucesivamente. | CHAXISNAME | CHSPDLNAME | Índice en el canal. | [...] | CHAXISNAME 1 |  | Eje con índice ꞏ1ꞏ. |  |  | CHSPDLNAME 1 | Cabezal con índice ꞏ1ꞏ."@es .

