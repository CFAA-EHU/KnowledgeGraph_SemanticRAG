        ns1:Eje_2,
        ns1:Eje_3,
        ns1:Eje_4,
        ns1:Eje_5 .

ns1:Fresadora_3Canales_9Ejes_2Cabezales a ns1:Maquina ;
    rdfs:label "Fresadora con 3 canales, 9 ejes y 2 cabezales" ;
    ns1:textoExtracto "Fresadora con 3 canales, 9 ejes y 2 cabezales. Canal 1: 3 ejes y 1 cabezal. Canal 2: 4 ejes y 1 cabezal. Canal 3: 2 ejes y ningún cabezal." ;
    ns1:tieneComponente ns1:Cabezal_1,
        ns1:Cabezal_2,
        ns1:Canal1_cc59c95c18,
        ns1:Canal2_f4df604f1d,
        ns1:Canal3_678465ecf6,
        ns1:Eje_1,
        ns1:Eje_2,
        ns1:Eje_3,
        ns1:Eje_4,
        ns1:Eje_5,
        ns1:Eje_6,
        ns1:Eje_7,
        ns1:Eje_8,
        ns1:Eje_9 .

