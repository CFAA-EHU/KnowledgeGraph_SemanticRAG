ns1:Fresadora_1Canal_3Ejes_1Cabezal a ns1:Maquina ;
    rdfs:label "Fresadora con 1 canal, 3 ejes y 1 cabezal" ;
    ns1:textoExtracto "Fresadora con 1 canal, 3 ejes y 1 cabezal." ;
    ns1:tieneComponente ns1:Cabezal_1,
        ns1:Canal1_cc59c95c18,
        ns1:Eje_1,
        ns1:Eje_2,
        ns1:Eje_3 .

ns1:Fresadora_1Canal_5Ejes_1Cabezal a ns1:Maquina ;
    rdfs:label "Fresadora con 1 canal, 5 ejes (2 libres) y 1 cabezal" ;
