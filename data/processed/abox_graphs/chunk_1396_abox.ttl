@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Torno_3Canales_6Ejes_2Cabezales a ns1:Maquina ;
    rdfs:label "Torno con 3 canales, 6 ejes y 2 cabezales"@es ;
    ns1:compuestoPor ns1:Canal1_2Ejes1Cabezal_Plano,
        ns1:Canal2_2Ejes1Cabezal_Plano,
        ns1:Canal3_2Ejes0Cabezal ;
    ns1:textoExtracto "Torno con 3 canales, 6 ejes y 2 cabezales."@es .

ns1:Canal1_2Ejes1Cabezal_Plano a ns1:Sistema ;
    rdfs:label "Canal 1: 2 ejes y 1 cabezal (configuración plano)"@es ;
    ns1:textoExtracto "Canal 1: 2 ejes y 1 cabezal. Configuración de ejes tipo plano."@es ;
    ns1:tieneComponente ns1:Configuracion_2Ejes1Cabezal_Plano .

ns1:Canal2_2Ejes1Cabezal_Plano a ns1:Sistema ;
    rdfs:label "Canal 2: 2 ejes y 1 cabezal (configuración plano)"@es ;
    ns1:textoExtracto "Canal 2: 2 ejes y 1 cabezal. Configuración de ejes tipo plano."@es ;
    ns1:tieneComponente ns1:Configuracion_2Ejes1Cabezal_Plano .

ns1:Canal3_2Ejes0Cabezal a ns1:Sistema ;
    rdfs:label "Canal 3: 2 ejes y 0 cabezales"@es ;
    ns1:textoExtracto "Canal 3: 2 ejes y ningún cabezal."@es ;
    ns1:tieneComponente ns1:Configuracion_2Ejes0Cabezal .

ns1:Configuracion_2Ejes0Cabezal a ns1:Sistema ;
    rdfs:label "Configuración de 2 ejes y 0 cabezales"@es ;
    ns1:identificador "2ejes_0cabezales" ;
    ns1:textoExtracto "Canal 3: 2 ejes y ningún cabezal."@es .

ns1:Configuracion_2Ejes1Cabezal_Plano a ns1:Sistema ;
    rdfs:label "Configuración de 2 ejes y 1 cabezal (tipo plano)"@es ;
    ns1:identificador "tipo_plano_2ejes_1cabezal" ;
    ns1:textoExtracto "Configuración de ejes tipo plano. Canal 2: 2 ejes y 1 cabezal."@es .

