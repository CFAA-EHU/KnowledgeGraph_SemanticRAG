@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Canal1_8820df232b a ns1:Sistema ;
    rdfs:label "Canal 1" ;
    ns1:identificador "Canal ꞏ1ꞏ" ;
    ns1:textoExtracto "Configuración de los ejes y cabezales del canal ꞏ1ꞏ." ;
    ns1:tieneComponente ns1:CabezalSEnCanal1,
        ns1:EjeXEnCanal1,
        ns1:EjeYEnCanal1,
        ns1:EjeZEnCanal1 .

ns1:Fresadora_1Canal_3Ejes_1Cabezal a ns1:Maquina ;
    rdfs:label "Fresadora con 1 canal, 3 ejes y 1 cabezal" ;
    ns1:identificador "1Canal_3Ejes_1Cabezal" ;
    ns1:textoExtracto "Los ejes y cabezales están distribuidos de la siguiente manera. Canal ꞏ1ꞏ. 3 ejes (X Y Z) 1 cabezal (S). Configuración general de los canales, ejes y cabezales. Configuración de los ejes y cabezales del sistema." ;
    ns1:tieneComponente ns1:Cabezal_S,
        ns1:Eje_X,
        ns1:Eje_Y,
        ns1:Eje_Z .

