@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CHSPDLNAME1 a ns1:ComponenteMecanico ;
    rdfs:label "CHSPDLNAME 1" ;
    ns1:identificador "CHSPDLNAME 1" ;
    ns1:textoExtracto "Cabezal con índice ꞏ1ꞏ. Número lógico ꞏ4ꞏ. Selección de planos en el canal ꞏ1ꞏ." ;
    ns1:tieneComponente ns1:PlanoCualquierEjeLongitudinal,
        ns1:PlanoXY,
        ns1:PlanoYZ,
        ns1:PlanoZX .

ns1:PlanoCualquierEjeLongitudinal a ns1:Parametro ;
    rdfs:label "G20" ;
    ns1:textoExtracto "G20 Cualquier plano y/o eje longitudinal." .

ns1:PlanoXY a ns1:Parametro ;
    rdfs:label "G17" ;
    ns1:textoExtracto "G17 Plano X-Y. Eje perpendicular Z." .

ns1:PlanoYZ a ns1:Parametro ;
    rdfs:label "G19" ;
    ns1:textoExtracto "G19 Plano Y-Z. Eje perpendicular X." .

ns1:PlanoZX a ns1:Parametro ;
    rdfs:label "G18" ;
    ns1:textoExtracto "G18 Plano Z-X. Eje perpendicular Y." .

