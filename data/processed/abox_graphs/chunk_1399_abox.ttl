@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Configuracion_Canal_1_1138 a ns1:Esquema ;
    ns1:compuestoPor ns1:Cabezal_S1_1138,
        ns1:Eje_X_1138,
        ns1:Eje_Y_1138,
        ns1:Eje_Z_1138 ;
    ns1:textoExtracto "Configuración de los ejes y cabezales del canal ꞏ1ꞏ." .

ns1:Configuracion_Sistema_1138 a ns1:Esquema ;
    ns1:compuestoPor ns1:Cabezal_S1_1138,
        ns1:Eje_A_1138,
        ns1:Eje_B_1138,
        ns1:Eje_X_1138,
        ns1:Eje_Y_1138,
        ns1:Eje_Z_1138 ;
    ns1:textoExtracto "Configuración general de los canales, ejes y cabezales. Configuración de los ejes y cabezales del sistema." .

ns1:Maquina_1138_1 a ns1:Maquina ;
    ns1:textoExtracto "Supongamos una máquina de un canal con tres ejes y cabezal y dos ejes sin asignar inicialmente. Los ejes y cabezales están distribuidos de la siguiente manera. Canal ꞏ1ꞏ. 3 ejes (X Y Z) 1 cabezal (S). Sin asignar. 2 ejes (A B)" .

ns1:Eje_A_1138 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "AXISNAME 4 | A | Número lógico ꞏ4ꞏ." .

ns1:Eje_B_1138 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "AXISNAME 5 | B | Número lógico ꞏ5ꞏ." .

ns1:Cabezal_S1_1138 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "SPDLNAME 1 | S1 | Número lógico ꞏ6ꞏ. | Cabezal con índice ꞏ1ꞏ." .

ns1:Eje_X_1138 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "AXISNAME 1 | X | Número lógico ꞏ1ꞏ." .

ns1:Eje_Y_1138 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "AXISNAME 2 | Y | Número lógico ꞏ2ꞏ." .

ns1:Eje_Z_1138 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "AXISNAME 3 | Z | Número lógico ꞏ3ꞏ." .

