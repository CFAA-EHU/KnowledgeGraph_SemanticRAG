@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:SoporteEmergenciaPanelOperador a owl:Class ;
    rdfs:label "Soporte Emergencia Panel Operador" ;
    rdfs:comment "Modelo 3SU1550-0AA10-0AA0" .

ex:ContactModule1NC a owl:Class ;
    rdfs:label "Contact Module 1NC" ;
    rdfs:comment "Modelo 3SU1400-1AA10-3CA0" .

ex:PulsadorSetaParoEmergencia a owl:Class ;
    rdfs:label "Pulsador Seta Paro Emergencia" ;
    rdfs:comment "Modelo 3SU1050-1HB20-0AA0" .

ex:NotHaltUnterlegschild a owl:Class ;
    rdfs:label "Not-Halt-Unterlegschild" ;
    rdfs:comment "Modelo 3SU1900-0BC31-0DA0" .

ex:SoporteEmergenciaArmario a owl:Class ;
    rdfs:label "Soporte Emergencia Armario" ;
    rdfs:comment "Modelo 3SU1550-0AA10-0AA0" .

ex:ContactModule1NCArmario a owl:Class ;
    rdfs:label "Contact Module 1NC Armario" ;
    rdfs:comment "Modelo 3SU1400-1AA10-3CA0" .

ex:tieneModelo a owl:DatatypeProperty ;
    rdfs:domain ex:SoporteEmergenciaPanelOperador ;
    rdfs:range xsd:string .

ex:tieneModelo a owl:DatatypeProperty ;
    rdfs:domain ex:ContactModule1NC ;
    rdfs:range xsd:string .

ex:tieneModelo a owl:DatatypeProperty ;
    rdfs:domain ex:PulsadorSetaParoEmergencia ;
    rdfs:range xsd:string .

ex:tieneModelo a owl:DatatypeProperty ;
    rdfs:domain ex:NotHaltUnterlegschild ;
    rdfs:range xsd:string .

ex:tieneModelo a owl:DatatypeProperty ;
    rdfs:domain ex:SoporteEmergenciaArmario ;
    rdfs:range xsd:string .

ex:tieneModelo a owl:DatatypeProperty ;
    rdfs:domain ex:ContactModule1NCArmario ;
    rdfs:range xsd:string .