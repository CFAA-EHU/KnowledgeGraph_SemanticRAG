@prefix ex: <https://vocab.cfaa.eus/broaching/>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.

ex:EmergenciaPanelOperador a owl:Class ;
    rdfs:label "Emergencia Panel Operador" ;
    rdfs:comment "Clase para el panel de emergencia del operador" .

ex:ContactModule1NC a owl:Class ;
    rdfs:label "Contact Module 1NC" ;
    rdfs:comment "Módulo de contacto 1NC" .

ex:PulsadorSetaParoEmergencia a owl:Class ;
    rdfs:label "Pulsador Seta Paro Emergencia" ;
    rdfs:comment "Pulsador de parada de emergencia" .

ex:NotHaltUnterlegschild a owl:Class ;
    rdfs:label "Not-Halt-Unterlegschild" ;
    rdfs:comment "Not-Halt-Unterlegschild" .

ex:EmergenciaArmario a owl:Class ;
    rdfs:label "Emergencia Armario" ;
    rdfs:comment "Clase para la emergencia del armario" .

ex:Soporte a owl:Class ;
    rdfs:label "Soporte" ;
    rdfs:comment "Clase para soporte" .

ex:SoporteEmergenciaPanelOperador a ex:Soporte ;
    rdfs:label "Soporte Emergencia Panel Operador" ;
    rdfs:comment "Soporte para el panel de emergencia del operador" .

ex:ContactModule1NCEmergenciaPanelOperador a ex:ContactModule1NC ;
    rdfs:label "Contact Module 1NC Emergencia Panel Operador" ;
    rdfs:comment "Módulo de contacto 1NC para la emergencia del panel del operador" .

ex:PulsadorSetaParoEmergencia40mmRojo a ex:PulsadorSetaParoEmergencia ;
    rdfs:label "Pulsador Seta Paro Emergencia 40mm Rojo" ;
    rdfs:comment "Pulsador de parada de emergencia de 40mm de color rojo" .

ex:NotHaltUnterlegschildGelb a ex:NotHaltUnterlegschild ;
    rdfs:label "Not-Halt-Unterlegschild Gelb" ;
    rdfs:comment "Not-Halt-Unterlegschild de color amarillo" .

ex:SoporteEmergenciaArmario a ex:Soporte ;
    rdfs:label "Soporte Emergencia Armario" ;
    rdfs:comment "Soporte para la emergencia del armario" .

ex:ContactModule1NCEmergenciaArmario a ex:ContactModule1NC ;
    rdfs:label "Contact Module 1NC Emergencia Armario" ;
    rdfs:comment "Módulo de contacto 1NC para la emergencia del armario" .