@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SoporteEmergenciaPanelOperador a ex:ComponenteMecanico ;
    ex:identificador "26SB1" ;
    rdfs:label "SOPORTE" ;
    ex:textoExtracto "SOPORTE | EMERGENCIA PANEL OPERADOR" .

ex:ContactModule1NCEmergenciaPanelOperador a ex:ComponenteElectrico ;
    ex:identificador "3SU1400-1AA10-3CA0" ;
    rdfs:label "CONTACT MODULE 1NC" ;
    ex:textoExtracto "CONTACT MODULE 1NC | EMERGENCIA PANEL OPERADOR" .

ex:SoporteEmergenciaArmario a ex:ComponenteMecanico ;
    ex:identificador "26SB2" ;
    rdfs:label "SOPORTE" ;
    ex:textoExtracto "SOPORTE | EMERGENCIA ARMARIO" .

ex:PulsadorSetaParoEmergencia40mmRojo a ex:ComponenteElectrico ;
    ex:identificador "3SU1050-1HB20-0AA0" ;
    rdfs:label "PULSADOR SETA PARO EMERG., 40MM, ROJO" ;
    ex:textoExtracto "PULSADOR SETA PARO EMERG., 40MM, ROJO | EMERGENCIA ARMARIO" .

ex:NotHaltUnterlegschildGelb a ex:ComponenteElectrico ;
    ex:identificador "3SU1900-0BC31-0DA0" ;
    rdfs:label "NOT-HALT-UNTERLEGSCHILD, GELB" ;
    ex:textoExtracto "NOT-HALT-UNTERLEGSCHILD, GELB | EMERGENCIA ARMARIO" .

ex:ContactModule1NCEmergenciaArmario a ex:ComponenteElectrico ;
    ex:identificador "3SU1400-1AA10-3CA0" ;
    rdfs:label "CONTACT MODULE 1NC" ;
    ex:textoExtracto "CONTACT MODULE 1NC | EMERGENCIA ARMARIO" .

ex:EsquemaElectricoEmergencia a ex:Esquema ;
    ex:compuestoPor ex:SoporteEmergenciaPanelOperador, ex:ContactModule1NCEmergenciaPanelOperador, ex:SoporteEmergenciaArmario, ex:PulsadorSetaParoEmergencia40mmRojo, ex:NotHaltUnterlegschildGelb, ex:ContactModule1NCEmergenciaArmario ;
    ex:textoExtracto "Tabla de componentes eléctricos y mecánicos para sistemas de emergencia en esquemas eléctricos" .