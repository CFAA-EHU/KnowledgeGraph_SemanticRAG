@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Canal1 a ns1:ComponenteElectrico ;
    rdfs:label "Canal 1" ;
    ns1:compuestoPor ns1:CHSPDLNAME1,
        ns1:Cabezal1 ;
    ns1:textoExtracto "Selección de planos en el canal ꞏ1ꞏ. Cabezal con índice ꞏ1ꞏ." .

ns1:G17 a ns1:ModoOperacion ;
    rdfs:label "G17" ;
    ns1:controla ns1:PlanoXY ;
    ns1:textoExtracto "G17 Plano X-Y. Eje perpendicular Z." ;
    ns1:valor "G17" .

ns1:G18 a ns1:ModoOperacion ;
    rdfs:label "G18" ;
    ns1:controla ns1:PlanoZX ;
    ns1:textoExtracto "G18 Plano Z-X. Eje perpendicular Y." ;
    ns1:valor "G18" .

ns1:G19 a ns1:ModoOperacion ;
    rdfs:label "G19" ;
    ns1:controla ns1:PlanoYZ ;
    ns1:textoExtracto "G19 Plano Y-Z. Eje perpendicular X." ;
    ns1:valor "G19" .

ns1:G20 a ns1:ModoOperacion ;
    rdfs:label "G20" ;
    ns1:controla ns1:PlanoCualquier ;
    ns1:textoExtracto "G20 Cualquier plano y/o eje longitudinal." ;
    ns1:valor "G20" .

ns1:CHSPDLNAME1 a ns1:ComponenteElectrico ;
    rdfs:label "CHSPDLNAME 1" ;
    ns1:textoExtracto "CHSPDLNAME 1" .

ns1:Cabezal1 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal 1" ;
    ns1:textoExtracto "Cabezal con índice ꞏ1ꞏ" .

ns1:PlanoCualquier a ns1:Sistema ;
    rdfs:label "Plano cualquier" ;
    ns1:textoExtracto "Cualquier plano y/o eje longitudinal." .

ns1:PlanoXY a ns1:Sistema ;
    rdfs:label "Plano X-Y" ;
    ns1:textoExtracto "Plano X-Y. Eje perpendicular Z." .

ns1:PlanoYZ a ns1:Sistema ;
    rdfs:label "Plano Y-Z" ;
    ns1:textoExtracto "Plano Y-Z. Eje perpendicular X." .

ns1:PlanoZX a ns1:Sistema ;
    rdfs:label "Plano Z-X" ;
    ns1:textoExtracto "Plano Z-X. Eje perpendicular Y." .

