ns1:M_quina_1140_561 a ns1:Maquina ;
    ns1:textoExtracto "Supongamos una máquina con tres canales dónde los dos primeros canales disponen de ejes y cabezales para mecanizar y el tercer canal es un sistema de carga y descarga controlado por dos ejes." ;
    ns1:tieneComponente ns1:Canal1_8820df232b,
        ns1:Canal2_c56883bdf4,
        ns1:Canal3_66937b633d .

