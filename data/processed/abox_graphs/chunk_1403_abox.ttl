@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Cabezal_1_Canal2 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal 1 (índice 1, lógico 10)"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionCanales1142 ;
    ns1:identificador "CHSPDLNAME 1 / S1" ;
    ns1:textoExtracto "CHSPDLNAME 1 | S1 | Cabezal con índice ꞏ1ꞏ. | Número lógico ꞏ10ꞏ"@es ;
    ns1:valor "10"^^xsd:string .

ns1:Sistema_EjesCanal1 a ns1:Sistema ;
    rdfs:label "Sistema de ejes del canal 1"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionCanales1142 ;
    ns1:identificador "1" ;
    ns1:textoExtracto "Eje con índice ꞏ1ꞏ... Número lógico ꞏ1ꞏ"@es ;
    ns1:tieneComponente ns1:Eje_X_Canal1 .

ns1:Sistema_EjesCanal2 a ns1:Sistema ;
    rdfs:label "Sistema de ejes del canal 2"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionCanales1142 ;
    ns1:identificador "2" ;
    ns1:textoExtracto "Eje con índice ꞏ2ꞏ... Número lógico ꞏ2ꞏ"@es ;
    ns1:tieneComponente ns1:Eje_Y_Canal2 .

ns1:Sistema_EjesCanal3 a ns1:Sistema ;
    rdfs:label "Sistema de ejes del canal 3"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionCanales1142 ;
    ns1:identificador "3" ;
    ns1:textoExtracto "Eje con índice ꞏ3ꞏ... Número lógico ꞏ3ꞏ"@es ;
    ns1:tieneComponente ns1:Eje_Z_Canal3 .

ns1:Eje_X_Canal1 a ns1:ComponenteMecanico ;
    rdfs:label "Eje X (índice 1, lógico 1)"@es ;
    ns1:identificador "CHAXISNAME 1 / X" ;
    ns1:textoExtracto "CHAXISNAME 1 | X | Eje con índice ꞏ1ꞏ. | Número lógico ꞏ1ꞏ"@es ;
    ns1:valor "1"^^xsd:string .

ns1:Eje_Y_Canal2 a ns1:ComponenteMecanico ;
    rdfs:label "Eje Y (índice 2, lógico 2)"@es ;
    ns1:identificador "CHAXISNAME 2 / Y" ;
    ns1:textoExtracto "CHAXISNAME 2 | Y | Eje con índice ꞏ2ꞏ. | Número lógico ꞏ2ꞏ"@es ;
    ns1:valor "2"^^xsd:string .

ns1:Eje_Z_Canal3 a ns1:ComponenteMecanico ;
    rdfs:label "Eje Z (índice 3, lógico 3)"@es ;
    ns1:identificador "CHAXISNAME 3 / Z" ;
    ns1:textoExtracto "CHAXISNAME 3 | Z | Eje con índice ꞏ3ꞏ. | Número lógico ꞏ3ꞏ"@es ;
    ns1:valor "3"^^xsd:string .

ns1:Tabla_ConfiguracionCanales1142 a ns1:Tabla ;
    rdfs:label "Tabla de configuración de ejes y cabezales por canal"@es ;
    ns1:textoExtracto """
| Índice en el canal. | Orden lógico. |
| --- | --- | --- | --- |
| CHAXISNAME 1 | X | Eje con índice ꞏ1ꞏ. | Número lógico ꞏ1ꞏ.
| CHAXISNAME 2 | Y | Eje con índice ꞏ2ꞏ. | Número lógico ꞏ2ꞏ.
| CHAXISNAME 3 | Z | Eje con índice ꞏ3ꞏ. | Número lógico ꞏ3ꞏ.

| CHSPDLNAME | Valor. | Índice en el canal. | Orden lógico. |
| --- | --- | --- | --- |
| CHSPDLNAME 1 | S1 | Cabezal con índice ꞏ1ꞏ. | Número lógico ꞏ10ꞏ.
""" .

