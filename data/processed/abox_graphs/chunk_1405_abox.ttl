@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaConfiguracionTorno1Canal2Ejes1Cabezal a ns1:Sistema ;
    rdfs:label "Sistema de torno con 1 canal, 2 ejes y 1 cabezal"@es ;
    ns1:identificador "NCHANNEL=1; NAXIS=2; NSPDL=1; GEOCONFIG=Plano; IPLANE=G18" ;
    ns1:textoExtracto "TORNO CON 1 CANAL, 2 EJES Y 1 CABEZAL. CONFIGURACIÓN DE EJES TIPO PLANO. Los ejes y cabezales están distribuidos de la siguiente manera. Canal ꞏ1ꞏ. 2 ejes (X Z) 1 cabezal (S)."@es ;
    ns1:tieneComponente ns1:Cabezal_S,
        ns1:Eje_X,
        ns1:Eje_Z,
        ns1:Parametro_CHNAXIS,
        ns1:Parametro_CHNSPDL,
        ns1:Parametro_GEOCONFIG,
        ns1:Parametro_IPLANE,
        ns1:Parametro_NAXIS,
        ns1:Parametro_NCHANNEL,
        ns1:Parametro_NSPDL .

ns1:Cabezal_S a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal S"@es ;
    ns1:identificador "SPDLNAME=S; Índice lógico=3" ;
    ns1:textoExtracto "SPDLNAME 1: S. Número lógico ꞏ3ꞏ. Cabezal con índice ꞏ1ꞏ."@es .

ns1:Eje_X a ns1:ComponenteMecanico ;
    rdfs:label "Eje X"@es ;
    ns1:identificador "AXISNAME=X; Índice lógico=1" ;
    ns1:textoExtracto "AXISNAME 1: X. Número lógico ꞏ1ꞏ."@es .

ns1:Eje_Z a ns1:ComponenteMecanico ;
    rdfs:label "Eje Z"@es ;
    ns1:identificador "AXISNAME=Z; Índice lógico=2" ;
    ns1:textoExtracto "AXISNAME 2: Z. Número lógico ꞏ2ꞏ."@es .

ns1:Parametro_CHNAXIS a ns1:Parametro ;
    rdfs:label "Ejes por canal (CHNAXIS)"@es ;
    ns1:textoExtracto "CHNAXIS = 2"@es ;
    ns1:valor "2" .

ns1:Parametro_CHNSPDL a ns1:Parametro ;
    rdfs:label "Cabezales por canal (CHNSPDL)"@es ;
    ns1:textoExtracto "CHNSPDL = 1"@es ;
    ns1:valor "1" .

ns1:Parametro_GEOCONFIG a ns1:Parametro ;
    rdfs:label "Configuración geométrica (GEOCONFIG)"@es ;
    ns1:textoExtracto "GEOCONFIG = Plano"@es ;
    ns1:valor "Plano" .

ns1:Parametro_IPLANE a ns1:Parametro ;
    rdfs:label "Plano seleccionado (IPLANE)"@es ;
    ns1:textoExtracto "IPLANE = G18"@es ;
    ns1:valor "G18" .

ns1:Parametro_NAXIS a ns1:Parametro ;
    rdfs:label "Número de ejes (NAXIS)"@es ;
    ns1:textoExtracto "NAXIS = 2"@es ;
    ns1:valor "2" .

ns1:Parametro_NCHANNEL a ns1:Parametro ;
    rdfs:label "Número de canales (NCHANNEL)"@es ;
    ns1:textoExtracto "NCHANNEL = 1"@es ;
    ns1:valor "1" .

ns1:Parametro_NSPDL a ns1:Parametro ;
    rdfs:label "Número de cabezales (NSPDL)"@es ;
    ns1:textoExtracto "NSPDL = 1"@es ;
    ns1:valor "1" .

