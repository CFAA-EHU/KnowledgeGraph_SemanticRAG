@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_Fresadora_3Canales_1145 a ns1:Sistema ;
    rdfs:label "Sistema de fresadora con 3 canales, 9 ejes y 2 cabezales (configuración G18)" ;
    ns1:monitoreaParametro ns1:Parametro_PlanoTrabajo_G18_1145 ;
    ns1:textoExtracto "Fresadora con 3 canales, 9 ejes y 2 cabezales. Selección de planos en el canal ꞏ1ꞏ. Con esta configuración, el plano de trabajo siempre es G18 y estará formado por los dos primeros ejes definidos en el canal." ;
    ns1:tieneComponente ns1:Cabezal_S_1145,
        ns1:Eje_X_1145,
        ns1:Eje_Z_1145 .

ns1:Cabezal_S_1145 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal S (índice 1, orden lógico 3)" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionEjes1145 ;
    ns1:identificador "S" ;
    ns1:textoExtracto "Cabezal con índice ꞏ1ꞏ. Número lógico ꞏ3ꞏ." ;
    ns1:valor "3" .

ns1:Eje_X_1145 a ns1:ComponenteMecanico ;
    rdfs:label "Eje X (índice 1, orden lógico 1)" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionEjes1145 ;
    ns1:identificador "X" ;
    ns1:textoExtracto "Eje con índice ꞏ1ꞏ. Número lógico ꞏ1ꞏ." ;
    ns1:valor "1" .

ns1:Eje_Z_1145 a ns1:ComponenteMecanico ;
    rdfs:label "Eje Z (índice 2, orden lógico 2)" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionEjes1145 ;
    ns1:identificador "Z" ;
    ns1:textoExtracto "Eje con índice ꞏ2ꞏ. Número lógico ꞏ2ꞏ." ;
    ns1:valor "2" .

ns1:Parametro_PlanoTrabajo_G18_1145 a ns1:Parametro ;
    rdfs:label "Plano de trabajo G18 (ZX)" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionEjes1145 ;
    ns1:identificador "G18" ;
    ns1:textoExtracto "el plano de trabajo siempre es G18 y estará formado por los dos primeros ejes definidos en el canal. Si se han definido los ejes X (primer eje del canal) y Z (segundo eje del canal), el plano de trabajo será ZX (eje Z como abscisas y eje X como ordenadas)." ;
    ns1:valor "ZX" .

ns1:Tabla_ConfiguracionEjes1145 a ns1:Tabla ;
    rdfs:label "Tabla de configuración de ejes y cabezales (CHAXISNAME/CHSPDLNAME)" ;
    ns1:textoExtracto """
| CHAXISNAME | Valor | Índice en el canal. | Orden lógico. |
| --- | --- | --- | --- |
| CHAXISNAME 1 | X | Eje con índice ꞏ1ꞏ. | Número lógico ꞏ1ꞏ. |
| CHAXISNAME 2 | Z | Eje con índice ꞏ2ꞏ. | Número lógico ꞏ2ꞏ.

| CHSPDLNAME | Valor | Índice en el canal. | Orden lógico. |
| --- | --- | --- | --- |
| CHSPDLNAME 1 | S | Cabezal con índice ꞏ1ꞏ. | Número lógico ꞏ3ꞏ.
""" .

