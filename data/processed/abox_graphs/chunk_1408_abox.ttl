@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Funcion_G18 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G18 (selección de plano ZX)"@es ;
    ns1:identificador "G18" ;
    ns1:textoExtracto "G18 • Plano ZX. Eje Z para la compensación longitudinal."@es ;
    ns1:valor "Plano ZX"@es .

ns1:Funcion_G20 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G20 (compensación longitudinal en eje Y)"@es ;
    ns1:identificador "G20" ;
    ns1:textoExtracto "La función G20 permite seleccionar el resto de ejes (eje Y) como eje para la compensación longitudinal."@es ;
    ns1:valor "Eje Y (compensación longitudinal)"@es .

ns1:Cabezal_Indice1 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal con índice 1"@es ;
    ns1:identificador "CHSPDLNAME_1" ;
    ns1:textoExtracto "CHSPDLNAME 1 • S • Cabezal con índice •1•. Número lógico •4•."@es .

ns1:ConfiguracionEjes_Torno1Canal3Ejes1Cabezal a ns1:ModoOperacion ;
    rdfs:label "Configuración de ejes tipo plano (Torno 1 canal, 3 ejes, 1 cabezal)"@es ;
    ns1:documentadoEn ns1:Tabla_SeleccionPlanos_10_2_4 ;
    ns1:identificador "G18 (plano ZX por defecto)" ;
    ns1:textoExtracto "Con una configuración de ejes tipo plano, siempre está activo el plano G18; en este caso el plano ZX. Las funciones G17 y G19 no son válidas. La función G20 permite seleccionar el resto de ejes (eje Y) como eje para la compensación longitudinal."@es ;
    ns1:tieneComponente ns1:Cabezal_Indice1 .

ns1:Tabla_SeleccionPlanos_10_2_4 a ns1:Tabla ;
    rdfs:label "Tabla de selección de planos (Sección 10.2.4)"@es ;
    ns1:ilustradoEn ns1:ConfiguracionEjes_Torno1Canal3Ejes1Cabezal ;
    ns1:textoExtracto "Selección de planos en el canal 1. Función • G18 • Plano ZX. Eje Z para la compensación longitudinal."@es .

