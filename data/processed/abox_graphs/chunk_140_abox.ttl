@prefix ex: <https://vocab.cfaa.eus/broaching/>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix siemens: <http://www.siemens.com/>.
@prefix schneider: <http://www.schneider-electric.com/>.
@prefix rittal: <http://www.rittal.com/>.
@prefix euchner: <http://www.euchner.com/>.
@prefix admin: <https://admin-shell.io/dictionary/>.

ex:PulsadorNegro a owl:Class ;
    rdfs:label "Pulsador Negro" ;
    rdfs:comment "Pulsador negro para paro de servicio" .

ex:SoporteParoServicio a owl:Class ;
    rdfs:label "Soporte Paro Servicio" ;
    rdfs:comment "Soporte para pulsador de paro de servicio" .

ex:ContactModule1NC a owl:Class ;
    rdfs:label "Contact Module 1NC" ;
    rdfs:comment "Módulo de contacto 1NC para paro de servicio" .

ex:PulsadorIluminadoVerde a owl:Class ;
    rdfs:label "Pulsador Iluminado Verde" ;
    rdfs:comment "Pulsador iluminado verde" .

ex:PulsadorIluminadoBlanco a owl:Class ;
    rdfs:label "Pulsador Iluminado Blanco" ;
    rdfs:comment "Pulsador iluminado blanco para puesta en servicio" .

ex:ContactModule1NO a owl:Class ;
    rdfs:label "Contact Module 1NO" ;
    rdfs:comment "Módulo de contacto 1NO para puesta en servicio" .

ex:LedModulWeiss a owl:Class ;
    rdfs:label "LED-Modul Weiss" ;
    rdfs:comment "Módulo LED blanco para puesta en servicio" .

ex:PulsadorIluminadoVerdeMarchaCiclo a owl:Class ;
    rdfs:label "Pulsador Iluminado Verde Marcha Ciclo" ;
    rdfs:comment "Pulsador iluminado verde para marcha de ciclo" .

ex:LedModulGruen a owl:Class ;
    rdfs:label "LED-Modul Gruen" ;
    rdfs:comment "Módulo LED verde para marcha de ciclo" .

ex:FinalDeCarrera a owl:Class ;
    rdfs:label "Final de Carrera" ;
    rdfs:comment "Final de carrera para bloqueo de mesa arriba" .

ex:SZDoorOperatedSwitch a owl:Class ;
    rdfs:label "SZ Door-operated Switch" ;
    rdfs:comment "Interruptor de puerta SZ con accesorio para instalación interior" .

ex:STPTW3A2131AC024MS1 a owl:Class ;
    rdfs:label "STP-TW-3A-2131AC024M-S1" ;
    rdfs:comment "Interruptor de seguridad para puerta frontal" .

ex:LlaveParaBloqueoPuertaTwin a owl:Class ;
    rdfs:label "Llave para Bloqueo Puerta Twin" ;
    rdfs:comment "Llave para bloqueo de puerta frontal" .

ex:CTPL1APMHAAZSA a owl:Class ;
    rdfs:label "CTP-L1-AP-M-HA-AZ-SA" ;
    rdfs:comment "Interruptor de seguridad para puerta izquierda" .

ex:StraightActuator a owl:Class ;
    rdfs:label "Straight Actuator" ;
    rdfs:comment "Actuador recto para interruptor de seguridad codificado por transponder" .

ex:ConexionCabezaLectora a owl:Class ;
    rdfs:label "Conexion Cabeza Lectora" ;
    rdfs:comment "Conexión de cabeza lectora (20 metros) con sensor sin contacto" .

admin:Actuator a owl:Class ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Actuator> .

admin:Sensor a owl:Class ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Sensor> .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range ex:Fabricante .

ex:tieneReferencia a owl:ObjectProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range xsd:string .

ex:tieneCantidad a owl:ObjectProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range xsd:integer .

ex:tieneDesignacion a owl:ObjectProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range xsd:string .

ex:tieneUtilizacion a owl:ObjectProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range xsd:string .

ex:Componente a owl:Class ;
    rdfs:comment "Clase base para componentes" .

ex:Fabricante a owl:Class ;
    rdfs:comment "Clase para fabricantes" .

siemens:Siemens a ex:Fabricante ;
    rdfs:label "Siemens" .

schneider:Schneider a ex:Fabricante ;
    rdfs:label "Schneider" .

rittal:Rittal a ex:Fabricante ;
    rdfs:label "Rittal" .

euchner:Euchner a ex:Fabricante ;
    rdfs:label "Euchner" .

siemens:SiemensAG a ex:Fabricante ;
    rdfs:label "Siemens AG" .

ex:PulsadorNegro rdfs:subClassOf ex:Componente .
ex:SoporteParoServicio rdfs:subClassOf ex:Componente .
ex:ContactModule1NC rdfs:subClassOf ex:Componente .
ex:PulsadorIluminadoVerde rdfs:subClassOf ex:Componente .
ex:PulsadorIluminadoBlanco rdfs:subClassOf ex:Componente .
ex:ContactModule1NO rdfs:subClassOf ex:Componente .
ex:LedModulWeiss rdfs:subClassOf ex:Componente .
ex:PulsadorIluminadoVerdeMarchaCiclo rdfs:subClassOf ex:Componente .
ex:LedModulGruen rdfs:subClassOf ex:Componente .
ex:FinalDeCarrera rdfs:subClassOf ex:Componente .
ex:SZDoorOperatedSwitch rdfs:subClassOf ex:Componente .
ex:STPTW3A2131AC024MS1 rdfs:subClassOf ex:Componente .
ex:LlaveParaBloqueoPuertaTwin rdfs:subClassOf ex:Componente .
ex:CTPL1APMHAAZSA rdfs:subClassOf ex:Componente .
ex:StraightActuator rdfs:subClassOf ex:Componente, admin:Actuator .
ex:ConexionCabezaLectora rdfs:subClassOf ex:Componente, admin:Sensor .