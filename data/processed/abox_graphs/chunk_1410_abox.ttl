@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Funcion_G17 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G17 (Plano X-Y)"@es ;
    ns1:documentadoEn ns1:Tabla_PlanosG17_G20 ;
    ns1:identificador "G17" ;
    ns1:textoExtracto "G17: Plano X-Y. Eje perpendicular Z."@es ;
    ns1:valor "X-Y" .

ns1:Funcion_G18 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G18 (Plano Z-X)"@es ;
    ns1:documentadoEn ns1:Tabla_PlanosG17_G20 ;
    ns1:identificador "G18" ;
    ns1:textoExtracto "G18: Plano Z-X. Eje perpendicular Y."@es ;
    ns1:valor "Z-X" .

ns1:Funcion_G19 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G19 (Plano Y-Z)"@es ;
    ns1:documentadoEn ns1:Tabla_PlanosG17_G20 ;
    ns1:identificador "G19" ;
    ns1:textoExtracto "G19: Plano Y-Z. Eje perpendicular X."@es ;
    ns1:valor "Y-Z" .

ns1:Funcion_G20 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G20 (Plano libre)"@es ;
    ns1:documentadoEn ns1:Tabla_PlanosG17_G20 ;
    ns1:identificador "G20" ;
    ns1:textoExtracto "G20: Cualquier plano y/o eje longitudinal."@es ;
    ns1:valor "libre" .

ns1:Cabezal_Indice1 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal con índice 1"@es ;
    ns1:identificador "1" ;
    ns1:textoExtracto "Cabezal con índice ꞏ1ꞏ."@es .

ns1:Canal_Indice1 a ns1:Componente ;
    rdfs:label "Canal 1"@es ;
    ns1:identificador "1" ;
    ns1:textoExtracto "Selección de planos en el canal ꞏ1ꞏ."@es .

ns1:ConfiguracionEjes_Triedro_10_2_5 a ns1:ModoOperacion ;
    rdfs:label "Configuración de ejes tipo triedro (1 canal, 3 ejes, 1 cabezal)"@es ;
    ns1:monitoreaParametro ns1:Parametro_IPLANE ;
    ns1:textoExtracto "Con una configuración de ejes tipo triedro, el comportamiento de los planos es igual que en una fresadora, salvo que el plano habitual de trabajo será G18 (si se ha configurado así en el parámetro IPLANE)."@es ;
    ns1:tieneComponente ns1:Cabezal_Indice1,
        ns1:Canal_Indice1 .

ns1:Parametro_IPLANE a ns1:Parametro ;
    rdfs:label "Parámetro IPLANE"@es ;
    ns1:identificador "IPLANE" ;
    ns1:textoExtracto "el plano habitual de trabajo será G18 (si se ha configurado así en el parámetro IPLANE)."@es ;
    ns1:valor "G18" .

ns1:Tabla_PlanosG17_G20 a ns1:Tabla ;
    rdfs:label "Tabla de selección de planos (G17-G20)"@es ;
    ns1:documentadoEn ns1:ConfiguracionEjes_Triedro_10_2_5 ;
    ns1:textoExtracto "Función: G17 (Plano X-Y), G18 (Plano Z-X), G19 (Plano Y-Z), G20 (Cualquier plano y/o eje longitudinal)."@es .

