@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_ConfiguracionParametrosCanal1 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de configuración del canal 1"@es ;
    ns1:documentadoEn ns1:Sistema_ConfiguracionCanal1 ;
    ns1:textoExtracto "Configuración de los ejes y cabezales del sistema. | AXISNAME | Valor | Orden lógico. | Índice en el sistema. | [...] | CHAXISNAME | Valor | Índice en el canal. | Orden lógico."@es .

ns1:Cabezal_S_Canal1 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal S (Canal 1, índice 1)"@es ;
    ns1:identificador "SPDLNAME:S / CHSPDLNAME:S / Índice:1 / Lógico:4" ;
    ns1:textoExtracto "SPDLNAME 1 | S | Número lógico ꞏ4ꞏ. | Cabezal con índice ꞏ1ꞏ. | CHSPDLNAME 1 | S"@es .

ns1:Eje_U_Canal1 a ns1:ComponenteMecanico ;
    rdfs:label "Eje U (Canal 1, índice 3)"@es ;
    ns1:identificador "AXISNAME:U / Índice:3 / Lógico:3" ;
    ns1:textoExtracto "AXISNAME 3 | U | Número lógico ꞏ3ꞏ."@es .

ns1:Eje_X_Canal1 a ns1:ComponenteMecanico ;
    rdfs:label "Eje X (Canal 1, índice 1)"@es ;
    ns1:identificador "AXISNAME:X / CHAXISNAME:X / Índice:1 / Lógico:1" ;
    ns1:textoExtracto "AXISNAME 1 | X | Número lógico ꞏ1ꞏ. | CHAXISNAME 1 | X | Eje con índice ꞏ1ꞏ. | Número lógico ꞏ1ꞏ."@es .

ns1:Eje_Z_Canal1 a ns1:ComponenteMecanico ;
    rdfs:label "Eje Z (Canal 1, índice 2)"@es ;
    ns1:identificador "AXISNAME:Z / CHAXISNAME:Z / Índice:2 / Lógico:2" ;
    ns1:textoExtracto "AXISNAME 2 | Z | Número lógico ꞏ2ꞏ. | CHAXISNAME 2 | Z | Eje con índice ꞏ2ꞏ. | Número lógico ꞏ2ꞏ."@es .

ns1:Sistema_ConfiguracionCanal1 a ns1:Sistema ;
    rdfs:label "Sistema de configuración del canal 1 (3 ejes + 1 cabezal)"@es ;
    ns1:identificador "Canal ꞏ1ꞏ / GEOCONFIG=Plano / IPLANE=G18" ;
    ns1:textoExtracto "Configuración general de los canales, ejes y cabezales. | Sistema | Canal ꞏ1ꞏ | NCHANNEL = 1 | GEOCONFIG = Plano | NAXIS = 3 | CHNAXIS = 2 | NSPDL = 1 | CHNSPDL = 1 | IPLANE = G18"@es ;
    ns1:tieneComponente ns1:Cabezal_S_Canal1,
        ns1:Eje_U_Canal1,
        ns1:Eje_X_Canal1,
        ns1:Eje_Z_Canal1 .

