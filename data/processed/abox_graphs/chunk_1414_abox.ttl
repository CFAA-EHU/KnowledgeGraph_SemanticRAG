@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Torno_2Canales_4Ejes_2Cabezales a ns1:Maquina ;
    ns1:textoExtracto "Torno con 2 canales, 4 ejes y 2 cabezales. Configuración de ejes tipo" ;
    ns1:tieneComponente ns1:Cabezal_S,
        ns1:Eje_X,
        ns1:Eje_X1,
        ns1:Eje_Z,
        ns1:Eje_Z1 .

ns1:Cabezal_S a ns1:ComponenteMecanico ;
    ns1:identificador "CHSPDLNAME 1" ;
    ns1:textoExtracto "Cabezal con índice ꞏ1ꞏ. Número lógico ꞏ5ꞏ." ;
    ns1:valor "S" .

ns1:Eje_X a ns1:ComponenteMecanico ;
    ns1:identificador "CHAXISNAME 1" ;
    ns1:textoExtracto "Eje con índice ꞏ1ꞏ. Número lógico ꞏ1ꞏ." ;
    ns1:valor "X" .

ns1:Eje_X1 a ns1:ComponenteMecanico ;
    ns1:identificador "CHAXISNAME 1" ;
    ns1:textoExtracto "Eje con índice ꞏ1ꞏ. Número lógico ꞏ3ꞏ." ;
    ns1:valor "X1" .

ns1:Eje_Z a ns1:ComponenteMecanico ;
    ns1:identificador "CHAXISNAME 2" ;
    ns1:textoExtracto "Eje con índice ꞏ2ꞏ. Número lógico ꞏ2ꞏ." ;
    ns1:valor "Z" .

ns1:Eje_Z1 a ns1:ComponenteMecanico ;
    ns1:identificador "CHAXISNAME 2" ;
    ns1:textoExtracto "Eje con índice ꞏ2ꞏ. Número lógico ꞏ4ꞏ." ;
    ns1:valor "Z1" .

