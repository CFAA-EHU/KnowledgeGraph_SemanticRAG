@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Cabezal1 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal 1"@es ;
    ns1:controla ns1:Parametro_CHSPDLNAME1 ;
    ns1:identificador "1" ;
    ns1:textoExtracto "Cabezal con índice ꞏ1ꞏ."@es .

ns1:ConfiguracionEjes_Torno2Canales4Ejes2Cabezales a ns1:ModoOperacion ;
    rdfs:label "Configuración de ejes para torno con 2 canales, 4 ejes y 2 cabezales"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_ConfiguracionCanales ;
    ns1:identificador "G18" ;
    ns1:textoExtracto "Selección de planos en el canal ꞏ1ꞏ y ꞏ2ꞏ. Con esta configuración, el plano de trabajo siempre es G18 y estará formado por los dos primeros ejes definidos en el canal. Si se han definido los ejes X (primer eje del canal) y Z (segundo eje del canal), el plano de trabajo será ZX (eje Z como abscisas y eje X como ordenadas). Las funciones G17 y G19 no son válidas. Cómo sólo hay dos ejes, la función G20 no tiene sentido."@es .

ns1:Pagina_566 a ns1:Pagina ;
    rdfs:label "Página 566 - Configuración de ejes tipo"@es ;
    ns1:identificador "566" ;
    ns1:textoExtracto "10.2.7 Torno con 2 canales, 4 ejes y 2 cabezales. Configuración de ejes tipo"@es .

ns1:Parametro_CHSPDLNAME1 a ns1:Parametro ;
    rdfs:label "CHSPDLNAME 1"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionCanales ;
    ns1:identificador "CHSPDLNAME 1" ;
    ns1:textoExtracto "CHSPDLNAME 1 | S1 | Cabezal con índice ꞏ1ꞏ. | Número lógico ꞏ6ꞏ."@es ;
    ns1:valor "S1" .

ns1:Tabla_ConfiguracionCanales a ns1:Tabla ;
    rdfs:label "Tabla de configuración de canales y cabezales"@es ;
    ns1:documentadoEn ns1:Pagina_566 ;
    ns1:textoExtracto "CHSPDLNAME | Valor | Índice en el canal. | Orden lógico."@es .

