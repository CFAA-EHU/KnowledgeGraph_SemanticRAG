@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Torno_3Canales_6Ejes_2Cabezales a ns1:Sistema ;
    rdfs:label "Torno con 3 canales, 6 ejes y 2 cabezales"@es ;
    ns1:compuestoPor ns1:Cabezal_S,
        ns1:Cabezal_S1,
        ns1:Eje_U,
        ns1:Eje_V,
        ns1:Eje_X,
        ns1:Eje_X1,
        ns1:Eje_Z,
        ns1:Eje_Z1 ;
    ns1:textoExtracto "Configuración de ejes tipo"@es .

ns1:Cabezal_S a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal S"@es ;
    ns1:identificador "SPDLNAME 1" ;
    ns1:textoExtracto "SPDLNAME 1 | S | Número lógico ꞏ7ꞏ. | Cabezal con índice ꞏ1ꞏ."@es .

ns1:Cabezal_S1 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal S1"@es ;
    ns1:identificador "SPDLNAME 2" ;
    ns1:textoExtracto "SPDLNAME 2 | S1 | Número lógico ꞏ8ꞏ. | Cabezal con índice ꞏ2ꞏ."@es .

ns1:Eje_U a ns1:ComponenteMecanico ;
    rdfs:label "Eje U"@es ;
    ns1:identificador "AXISNAME 5" ;
    ns1:textoExtracto "AXISNAME 5 | U | Número lógico ꞏ5ꞏ."@es .

ns1:Eje_V a ns1:ComponenteMecanico ;
    rdfs:label "Eje V"@es ;
    ns1:identificador "AXISNAME 6" ;
    ns1:textoExtracto "AXISNAME 6 | V | Número lógico ꞏ6ꞏ."@es .

ns1:Eje_X a ns1:ComponenteMecanico ;
    rdfs:label "Eje X"@es ;
    ns1:identificador "AXISNAME 1" ;
    ns1:textoExtracto "AXISNAME 1 | X | Número lógico ꞏ1ꞏ."@es .

ns1:Eje_X1 a ns1:ComponenteMecanico ;
    rdfs:label "Eje X1"@es ;
    ns1:identificador "AXISNAME 3" ;
    ns1:textoExtracto "AXISNAME 3 | X1 | Número lógico ꞏ3ꞏ."@es .

ns1:Eje_Z a ns1:ComponenteMecanico ;
    rdfs:label "Eje Z"@es ;
    ns1:identificador "AXISNAME 2" ;
    ns1:textoExtracto "AXISNAME 2 | Z | Número lógico ꞏ2ꞏ."@es .

ns1:Eje_Z1 a ns1:ComponenteMecanico ;
    rdfs:label "Eje Z1"@es ;
    ns1:identificador "AXISNAME 4" ;
    ns1:textoExtracto "AXISNAME 4 | Z1 | Número lógico ꞏ4ꞏ."@es .

