@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ConfiguracionEjes_Torno3Canales6Ejes2Cabezales a ns1:Sistema ;
    rdfs:label "Configuración de ejes para torno con 3 canales, 6 ejes y 2 cabezales"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_ConfiguracionEjes_Torno3Canales6Ejes2Cabezales ;
    ns1:textoExtracto """
    Selección de planos en el canal ꞏ1ꞏ y ꞏ2ꞏ. Con esta configuración, el plano de trabajo siempre es G18 y estará formado por los dos primeros ejes definidos en el canal. Si se han definido los ejes X (primer eje del canal) y Z (segundo eje del canal), el plano de trabajo será ZX (eje Z como abscisas y eje X como ordenadas). Las funciones G17 y G19 no son válidas. Cómo sólo hay dos ejes, la función G20 no tiene sentido.
    """@es ;
    ns1:tieneComponente ns1:Eje_U_Indice1_Logico5,
        ns1:Eje_V_Indice2_Logico6 .

ns1:Eje_U_Indice1_Logico5 a ns1:ComponenteMecanico ;
    rdfs:label "Eje U (Índice 1, Número lógico 5)"@es ;
    ns1:identificador "U" ;
    ns1:textoExtracto "CHAXISNAME 1 | U | Eje con índice ꞏ1ꞏ. | Número lógico ꞏ5ꞏ."@es ;
    ns1:valor "1"^^xsd:string .

ns1:Eje_V_Indice2_Logico6 a ns1:ComponenteMecanico ;
    rdfs:label "Eje V (Índice 2, Número lógico 6)"@es ;
    ns1:identificador "V" ;
    ns1:textoExtracto "CHAXISNAME 2 | V | Eje con índice ꞏ2ꞏ. | Número lógico ꞏ6ꞏ."@es ;
    ns1:valor "2"^^xsd:string .

ns1:Tabla_ConfiguracionEjes_Torno3Canales6Ejes2Cabezales a ns1:Tabla ;
    rdfs:label "Tabla de configuración de ejes (CHAXISNAME) para torno con 3 canales, 6 ejes y 2 cabezales"@es ;
    ns1:textoExtracto """
    | CHAXISNAME | Valor | Índice en el canal. | Orden lógico. |
    | --- | --- | --- | --- |
    | CHAXISNAME 1 | U | Eje con índice ꞏ1ꞏ. | Número lógico ꞏ5ꞏ. |
    | CHAXISNAME 2 | V | Eje con índice ꞏ2ꞏ. | Número lógico ꞏ6ꞏ. |
    """@es .

