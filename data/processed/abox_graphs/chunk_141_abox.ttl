@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix base: <https://vocab.cfaa.eus/broaching/> .
@prefix elec: <https://vocab.cfaa.eus/broaching/electrico#> .
@prefix meca: <https://vocab.cfaa.eus/broaching/mecanico#> .
@prefix fluidos: <https://vocab.cfaa.eus/broaching/fluidos#> .
@prefix act: <https://admin-shell.io/dictionary/> .

base:ActuadorRectoParaTransponderCodificado
    a owl:Class ;
    rdfs:isDefinedBy act:Actuator ;
    rdfs:label "Actuador recto para interruptor de seguridad codificado por transponder"@es ;
    rdfs:comment "Clase que representa un actuador recto para interruptor de seguridad codificado por transponder (ej. CTP de EUCHNER)"@es .

base:SensorSinContacto
    a owl:Class ;
    rdfs:isDefinedBy act:Sensor ;
    rdfs:label "Sensor sin contacto"@es ;
    rdfs:comment "Clase que representa un sensor sin contacto (ej. tipo 100179 de EUCHNER)"@es .

base:TransformadorPrimario
    a owl:Class ;
    rdfs:label "Transformador primario"@es ;
    rdfs:comment "Clase que representa un transformador primario de 400 VAC con tolerancia +/-5%"@es .

base:FuenteAlimentacionSITOP
    a owl:Class ;
    rdfs:label "Fuente de alimentación SITOP"@es ;
    rdfs:comment "Clase que representa una fuente de alimentación SITOP modelo PSU300S"@es .

base:InterruptorSeguridadCodificadoTransponder
    a owl:Class ;
    rdfs:label "Interruptor de seguridad codificado por transponder"@es ;
    rdfs:comment "Clase que representa un interruptor de seguridad codificado por transponder (ej. CTP de EUCHNER)"@es .

base:PuertaSeguridad
    a owl:Class ;
    rdfs:label "Puerta de seguridad"@es ;
    rdfs:comment "Clase que representa una puerta de seguridad en la máquina brochadora"@es .

base:EscotillaInterior
    a owl:Class ;
    rdfs:label "Escotilla interior"@es ;
    rdfs:comment "Clase que representa una escotilla interior en la máquina brochadora"@es .

base:tieneActuador
    a owl:ObjectProperty ;
    rdfs:label "tiene actuador"@es ;
    rdfs:domain base:InterruptorSeguridadCodificadoTransponder ;
    rdfs:range base:ActuadorRectoParaTransponderCodificado ;
    rdfs:comment "Relación que indica que un interruptor de seguridad codificado por transponder tiene asociado un actuador recto"@es .

base:tieneSensor
    a owl:ObjectProperty ;
    rdfs:label "tiene sensor"@es ;
    rdfs:domain base:InterruptorSeguridadCodificadoTransponder ;
    rdfs:range base:SensorSinContacto ;
    rdfs:comment "Relación que indica que un interruptor de seguridad codificado por transponder tiene asociado un sensor sin contacto"@es .

base:tieneTransformador
    a owl:ObjectProperty ;
    rdfs:label "tiene transformador"@es ;
    rdfs:domain base:SistemaElectrico ;
    rdfs:range base:TransformadorPrimario ;
    rdfs:comment "Relación que indica que un sistema eléctrico tiene un transformador primario"@es .

base:tieneFuenteAlimentacion
    a owl:ObjectProperty ;
    rdfs:label "tiene fuente de alimentación"@es ;
    rdfs:domain base:SistemaElectrico ;
    rdfs:range base:FuenteAlimentacionSITOP ;
    rdfs:comment "Relación que indica que un sistema eléctrico tiene una fuente de alimentación SITOP"@es .

base:tieneConexionCabezaLectora
    a owl:ObjectProperty ;
    rdfs:label "tiene conexión cabeza lectora"@es ;
    rdfs:domain base:InterruptorSeguridadCodificadoTransponder ;
    rdfs:range base:SensorSinContacto ;
    rdfs:comment "Relación que indica que un interruptor de seguridad codificado por transponder tiene una conexión a cabeza lectora (sensor sin contacto)"@es .

base:estaAsociadoA
    a owl:ObjectProperty ;
    rdfs:label "está asociado a"@es ;
    rdfs:domain base:PuertaSeguridad ;
    rdfs:range base:InterruptorSeguridadCodificadoTransponder ;
    rdfs:comment "Relación que indica que una puerta de seguridad está asociada a un interruptor de seguridad codificado por transponder"@es .

base:estaAsociadoA
    a owl:ObjectProperty ;
    rdfs:label "está asociado a"@es ;
    rdfs:domain base:EscotillaInterior ;
    rdfs:range base:InterruptorSeguridadCodificadoTransponder ;
    rdfs:comment "Relación que indica que una escotilla interior está asociada a un interruptor de seguridad codificado por transponder"@es .

elec:tieneModelo
    a owl:DatatypeProperty ;
    rdfs:label "tiene modelo"@es ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (base:ActuadorRectoParaTransponderCodificado base:InterruptorSeguridadCodificadoTransponder base:FuenteAlimentacionSITOP base:TransformadorPrimario)
    ] ;
    rdfs:range xsd:string .

elec:tieneFabricante
    a owl:DatatypeProperty ;
    rdfs:label "tiene fabricante"@es ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (base:ActuadorRectoParaTransponderCodificado base:InterruptorSeguridadCodificadoTransponder base:FuenteAlimentacionSITOP base:TransformadorPrimario)
    ] ;
    rdfs:range xsd:string .

elec:tieneReferencia
    a owl:DatatypeProperty ;
    rdfs:label "tiene referencia"@es ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (base:ActuadorRectoParaTransponderCodificado base:InterruptorSeguridadCodificadoTransponder base:FuenteAlimentacionSITOP base:TransformadorPrimario)
    ] ;
    rdfs:range xsd:string .

elec:tieneCantidad
    a owl:DatatypeProperty ;
    rdfs:label "tiene cantidad"@es ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (base:ActuadorRectoParaTransponderCodificado base:InterruptorSeguridadCodificadoTransponder base:FuenteAlimentacionSITOP base:TransformadorPrimario)
    ] ;
    rdfs:range xsd:integer .