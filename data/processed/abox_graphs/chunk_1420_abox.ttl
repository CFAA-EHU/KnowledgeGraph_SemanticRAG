@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_ParametrosEjeRotativoLinearlike a ns1:Tabla ;
    rdfs:label "Tabla de parámetros para eje rotativo linearlike" ;
    ns1:documentadoEn ns1:ConfiguracionEjeRotativo_Linearlike ;
    ns1:textoExtracto "| Parámetro | Valor | --- | --- | AXISTYPE | Rotativo | AXISMODE | Linearlike | UNIDIR | Sin función | SHORTESTWAY | Sin función | LIMIT+ / LIMIT- | Límites de recorrido | MODUPLIM / MODLOWLIM | Sin función |" .

ns1:ConfiguracionEjeRotativo_Linearlike a ns1:ModoOperacion ;
    rdfs:label "Eje rotativo linearlike" ;
    ns1:textoExtracto "Eje rotativo linearlike. El eje se comporta como un eje lineal, pero las unidades de programación son grados. El CNC visualiza las cotas entre los límites de recorrido." ;
    ns1:tieneComponente ns1:Parametro_AXISMODE_Linearlike,
        ns1:Parametro_AXISTYPE,
        ns1:Parametro_LIMIT_Negativo,
        ns1:Parametro_LIMIT_Positivo,
        ns1:Parametro_MODLOWLIM_SinFuncion,
        ns1:Parametro_MODUPLIM_SinFuncion,
        ns1:Parametro_SHORTESTWAY_SinFuncion,
        ns1:Parametro_UNIDIR_SinFuncion .

ns1:Parametro_AXISMODE_Linearlike a ns1:Parametro ;
    rdfs:label "AXISMODE (Linearlike)" ;
    ns1:textoExtracto "AXISMODE | Linearlike." ;
    ns1:valor "Linearlike" .

ns1:Parametro_AXISTYPE a ns1:Parametro ;
    rdfs:label "AXISTYPE" ;
    ns1:textoExtracto "Parámetro: AXISTYPE | Valor: Rotativo." ;
    ns1:valor "Rotativo" .

ns1:Parametro_LIMIT_Negativo a ns1:Parametro ;
    rdfs:label "LIMIT-" ;
    ns1:identificador "LIMIT-" ;
    ns1:textoExtracto "LIMIT- | Límites de recorrido." .

ns1:Parametro_LIMIT_Positivo a ns1:Parametro ;
    rdfs:label "LIMIT+" ;
    ns1:identificador "LIMIT+" ;
    ns1:textoExtracto "LIMIT+ | Límites de recorrido." .

ns1:Parametro_MODLOWLIM_SinFuncion a ns1:Parametro ;
    rdfs:label "MODLOWLIM (Sin función)" ;
    ns1:textoExtracto "MODLOWLIM | Sin función." ;
    ns1:valor "Sin función" .

ns1:Parametro_MODUPLIM_SinFuncion a ns1:Parametro ;
    rdfs:label "MODUPLIM (Sin función)" ;
    ns1:textoExtracto "MODUPLIM | Sin función." ;
    ns1:valor "Sin función" .

ns1:Parametro_SHORTESTWAY_SinFuncion a ns1:Parametro ;
    rdfs:label "SHORTESTWAY (Sin función)" ;
    ns1:textoExtracto "SHORTESTWAY | Sin función." ;
    ns1:valor "Sin función" .

ns1:Parametro_UNIDIR_SinFuncion a ns1:Parametro ;
    rdfs:label "UNIDIR (Sin función)" ;
    ns1:textoExtracto "UNIDIR | Sin función." ;
    ns1:valor "Sin función" .

