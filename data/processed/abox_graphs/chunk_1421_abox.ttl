@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionEjeRotativo_ModoMultiVuelta a ns1:ModoOperacion ;
    rdfs:label "Configuración: eje rotativo (modo multi-vuelta)"@es ;
    ns1:textoExtracto "Si el desplazamiento programado es superior al módulo, el eje da más de una vuelta."@es .

ns1:ConfiguracionEjeRotativo_ModoUnicaVuelta a ns1:ModoOperacion ;
    rdfs:label "Configuración: eje rotativo (modo única vuelta)"@es ;
    ns1:textoExtracto "Aunque el desplazamiento programado sea superior al módulo, el eje nunca da más de una vuelta."@es .

ns1:Parametro_Cota a ns1:Parametro ;
    rdfs:label "Cota (sentido y valor de desplazamiento)"@es ;
    ns1:monitoreaParametro ns1:MovimientoIncrementalNormal ;
    ns1:textoExtracto "El signo de la cota indica el sentido del desplazamiento; el valor absoluto de la cota indica el incremento de posición."@es .

ns1:Parametro_Modulo a ns1:Parametro ;
    rdfs:label "Módulo (límite de vuelta)"@es ;
    ns1:monitoreaParametro ns1:MovimientoIncrementalNormal ;
    ns1:textoExtracto "Aunque el desplazamiento programado sea superior al módulo, el eje nunca da más de una vuelta."@es ;
    ns1:valor "1 vuelta"@es .

ns1:MovimientoIncrementalNormal a ns1:ModoOperacion ;
    rdfs:label "Movimiento incremental normal"@es ;
    ns1:textoExtracto "Movimiento incremental normal. El signo de la cota indica el sentido del desplazamiento; el valor absoluto de la cota indica el incremento de posición."@es .

