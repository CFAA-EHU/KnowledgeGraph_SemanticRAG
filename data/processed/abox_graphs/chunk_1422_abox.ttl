@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_G90 a ns1:ModoOperacion ;
    rdfs:label "Movimiento en G90" ;
    ns1:textoExtracto "Movimientos en G90. El eje se desplaza según su sentido predeterminado, hasta alcanzar la cota programada. Aunque el desplazamiento programado sea superior al módulo, el eje nunca da más de una vuelta." .

ns1:ModoOperacion_G91 a ns1:ModoOperacion ;
    rdfs:label "Movimiento en G91" ;
    ns1:textoExtracto "Movimientos en G91. El eje sólo admite movimientos según su sentido predeterminado. El signo de la cota indica el sentido del desplazamiento; el valor absoluto de la cota indica el incremento de posición. Si el desplazamiento programado es superior al módulo, el eje da más de una vuelta." .

ns1:Sistema_ConfiguracionEjeRotativo a ns1:Sistema ;
    rdfs:label "Configuración de eje rotativo" ;
    ns1:monitoreaParametro ns1:Parametro_MODLOWLIM,
        ns1:Parametro_MODUPLIM ;
    ns1:textoExtracto "Configuración de los parámetros máquina. Los parámetros máquina MODUPLIM y MODLOWLIM establecen los límites del módulo del eje; no hay límites de recorrido." ;
    ns1:tieneComponente ns1:Parametro_AXISMODE,
        ns1:Parametro_AXISTYPE,
        ns1:Parametro_LIMIT,
        ns1:Parametro_MODLOWLIM,
        ns1:Parametro_MODUPLIM,
        ns1:Parametro_SHORTESTWAY,
        ns1:Parametro_UNIDIR .

ns1:Parametro_AXISMODE a ns1:Parametro ;
    rdfs:label "AXISMODE" ;
    ns1:textoExtracto "AXISMODE | Módulo." ;
    ns1:valor "Módulo" .

ns1:Parametro_AXISTYPE a ns1:Parametro ;
    rdfs:label "AXISTYPE" ;
    ns1:textoExtracto "AXISTYPE | Rotativo." ;
    ns1:valor "Rotativo" .

ns1:Parametro_LIMIT a ns1:Parametro ;
    rdfs:label "LIMIT+",
        "LIMIT-" ;
    ns1:textoExtracto "LIMIT- | Sin función. No hay límites de recorrido." ;
    ns1:valor "Sin función" .

ns1:Parametro_SHORTESTWAY a ns1:Parametro ;
    rdfs:label "SHORTESTWAY" ;
    ns1:textoExtracto "SHORTESTWAY | No." ;
    ns1:valor "No" .

ns1:Parametro_UNIDIR a ns1:Parametro ;
    rdfs:label "UNIDIR" ;
    ns1:textoExtracto "UNIDIR | No. / Positivo / Negativo." ;
    ns1:valor "No / Positivo / Negativo" .

ns1:Parametro_MODLOWLIM a ns1:Parametro ;
    rdfs:label "MODLOWLIM" ;
    ns1:textoExtracto "MODLOWLIM | Límites del módulo. Límites para visualizar las cotas." ;
    ns1:valor "Límite inferior del módulo" .

ns1:Parametro_MODUPLIM a ns1:Parametro ;
    rdfs:label "MODUPLIM" ;
    ns1:textoExtracto "MODUPLIM | Límites del módulo. Límites para visualizar las cotas." ;
    ns1:valor "Límite superior del módulo" .

