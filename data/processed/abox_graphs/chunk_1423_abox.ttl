@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_EjeRotativoPosicionamiento a ns1:ModoOperacion ;
    rdfs:label "Eje rotativo de posicionamiento" ;
    ns1:textoExtracto "Eje rotativo de posicionamiento. Este tipo de eje rotativo se puede desplazar en ambos sentidos, pero en los movimientos absolutos se desplaza por el camino más corto. El CNC visualiza las cotas entre los límites del módulo." ;
    ns1:tieneComponente ns1:Parametro_MODLOWLIM,
        ns1:Parametro_MODUPLIM,
        ns1:Parametro_SHORTESTWAY,
        ns1:Parametro_UNIDIR .

ns1:Parametro_LIMIT a ns1:Parametro ;
    rdfs:label "LIMIT+",
        "LIMIT-" ;
    ns1:textoExtracto "LIMIT- | Sin función. No hay límites de recorrido." ;
    ns1:valor "Sin función" .

ns1:Parametro_MODLOWLIM a ns1:Parametro ;
    rdfs:label "MODLOWLIM" ;
    ns1:textoExtracto "MODLOWLIM | Límites del módulo. Límites para visualizar las cotas." ;
    ns1:valor "Límites del módulo" .

ns1:Parametro_MODUPLIM a ns1:Parametro ;
    rdfs:label "MODUPLIM" ;
    ns1:textoExtracto "MODUPLIM | Límites del módulo. Límites para visualizar las cotas." ;
    ns1:valor "Límites del módulo" .

ns1:Parametro_SHORTESTWAY a ns1:Parametro ;
    rdfs:label "SHORTESTWAY" ;
    ns1:textoExtracto "SHORTESTWAY | No." ;
    ns1:valor "No" .

ns1:Parametro_UNIDIR a ns1:Parametro ;
    rdfs:label "UNIDIR" ;
    ns1:textoExtracto "UNIDIR | Positivo / Negativo." ;
    ns1:valor "Positivo/Negativo" .

