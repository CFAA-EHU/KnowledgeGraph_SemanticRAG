@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionEjeRotativo_1163 a ns1:ModoOperacion ;
    rdfs:label "Configuración de eje rotativo (G90/G91)"@es ;
    ns1:textoExtracto """
    Movimientos en G90:
    - El eje se desplaza por el camino más corto, hasta alcanzar la cota programada.
    - Aunque el desplazamiento programado sea superior al módulo, el eje nunca da más de una vuelta.

    Movimientos en G91:
    - Movimiento incremental normal. El signo de la cota indica el sentido del desplazamiento; el valor absoluto de la cota indica el incremento de posición.
    - Si el desplazamiento programado es superior al módulo, el eje da más de una vuelta.

    Configuración de los parámetros máquina:
    AXISTYPE = Rotativo | AXISMODE = Módulo | UNIDIR = No | SHORTESTWAY = Sí.
    """ ;
    ns1:tieneComponente ns1:Parametro_AXISMODE_1163,
        ns1:Parametro_AXISTYPE_1163,
        ns1:Parametro_MODLOWLIM_1163,
        ns1:Parametro_MODUPLIM_1163,
        ns1:Parametro_SHORTESTWAY_1163,
        ns1:Parametro_UNIDIR_1163 .

ns1:Parametro_AXISMODE_1163 a ns1:Parametro ;
    rdfs:label "AXISMODE"@es ;
    ns1:textoExtracto "AXISMODE | Módulo"@es ;
    ns1:valor "Módulo"@es .

ns1:Parametro_AXISTYPE_1163 a ns1:Parametro ;
    rdfs:label "AXISTYPE"@es ;
    ns1:textoExtracto "AXISTYPE | Rotativo"@es ;
    ns1:valor "Rotativo"@es .

ns1:Parametro_MODLOWLIM_1163 a ns1:Parametro ;
    rdfs:label "MODLOWLIM"@es ;
    ns1:textoExtracto "Los parámetros máquina MODUPLIM y MODLOWLIM establecen los límites del módulo del eje"@es ;
    ns1:valor "Límite inferior del módulo"@es .

ns1:Parametro_MODUPLIM_1163 a ns1:Parametro ;
    rdfs:label "MODUPLIM"@es ;
    ns1:textoExtracto "Los parámetros máquina MODUPLIM [...] establecen los límites del módulo del eje"@es ;
    ns1:valor "Límite superior del módulo"@es .

ns1:Parametro_SHORTESTWAY_1163 a ns1:Parametro ;
    rdfs:label "SHORTESTWAY"@es ;
    ns1:textoExtracto "SHORTESTWAY | Sí"@es ;
    ns1:valor "Sí"@es .

ns1:Parametro_UNIDIR_1163 a ns1:Parametro ;
    rdfs:label "UNIDIR"@es ;
    ns1:textoExtracto "UNIDIR | No"@es ;
    ns1:valor "No"@es .

