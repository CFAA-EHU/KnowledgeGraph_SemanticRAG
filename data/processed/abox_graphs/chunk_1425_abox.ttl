@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_ConfiguracionEjeRotativo a ns1:Tabla ;
    rdfs:label "Tabla de configuración de parámetros para eje rotativo" ;
    ns1:detalladoEnEsquema ns1:Parametro_AXISMODE,
        ns1:Parametro_LIMIT,
        ns1:Parametro_MODLOWLIM,
        ns1:Parametro_MODUPLIM,
        ns1:Parametro_SHORTESTWAY,
        ns1:Parametro_UNIDIR ;
    ns1:textoExtracto "AXISMODE | Módulo. UNIDIR | No. SHORTESTWAY | Sí. LIMIT+ LIMIT- | Sin función. No hay límites de recorrido. MODUPLIM MODLOWLIM | Límites del módulo. Límites para visualizar las cotas." .

ns1:Parametro_AXISMODE a ns1:Parametro ;
    rdfs:label "AXISMODE" ;
    ns1:textoExtracto "AXISMODE | Módulo." ;
    ns1:valor "Módulo" .

ns1:Parametro_LIMIT a ns1:Parametro ;
    rdfs:label "LIMIT+",
        "LIMIT-" ;
    ns1:textoExtracto "LIMIT- | Sin función. No hay límites de recorrido." ;
    ns1:valor "Sin función" .

ns1:Parametro_MODLOWLIM a ns1:Parametro ;
    rdfs:label "MODLOWLIM" ;
    ns1:textoExtracto "MODLOWLIM | Límites del módulo. Límites para visualizar las cotas." ;
    ns1:valor "Límites del módulo" .

ns1:Parametro_MODUPLIM a ns1:Parametro ;
    rdfs:label "MODUPLIM" ;
    ns1:textoExtracto "MODUPLIM | Límites del módulo. Límites para visualizar las cotas." ;
    ns1:valor "Límites del módulo" .

ns1:Parametro_SHORTESTWAY a ns1:Parametro ;
    rdfs:label "SHORTESTWAY" ;
    ns1:textoExtracto "SHORTESTWAY | Sí." ;
    ns1:valor "Sí" .

ns1:Parametro_UNIDIR a ns1:Parametro ;
    rdfs:label "UNIDIR" ;
    ns1:textoExtracto "UNIDIR | No." ;
    ns1:valor "No" .

