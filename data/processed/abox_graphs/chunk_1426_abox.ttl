@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AplicacionGantry_1165 a ns1:ModoOperacion ;
    rdfs:label "Configuración gantry con ejes tándem"@es ;
    ns1:requiereMantenimiento ns1:ConfiguracionEjeTandem_1165 ;
    ns1:textoExtracto "Una de las muchas aplicaciones [...] se asocia a máquinas gantry. En el siguiente ejemplo se puede ver un eje gantry con dos ejes tándem."@es .

ns1:Parametro_AXISEXCH_1165 a ns1:Parametro ;
    rdfs:label "AXISEXCH (permiso de cambio de canal)"@es ;
    ns1:monitoreaParametro ns1:MotorTandemEsclavo_1165,
        ns1:MotorTandemMaestro_1165 ;
    ns1:textoExtracto "El permiso de cambio de canal (parámetro AXISEXCH) deberá ser igual en ambos ejes."@es .

ns1:Parametro_AXISTYPE_1165 a ns1:Parametro ;
    rdfs:label "AXISTYPE (tipo de eje)"@es ;
    ns1:monitoreaParametro ns1:MotorTandemEsclavo_1165,
        ns1:MotorTandemMaestro_1165 ;
    ns1:textoExtracto "Ambos ejes y reguladores deberán ser del mismo tipo (parámetros AXISTYPE [...] iguales para ambos ejes)."@es .

ns1:Parametro_DRIVETYPE_1165 a ns1:Parametro ;
    rdfs:label "DRIVETYPE (tipo de accionamiento)"@es ;
    ns1:monitoreaParametro ns1:MotorTandemEsclavo_1165,
        ns1:MotorTandemMaestro_1165 ;
    ns1:textoExtracto "Ambos ejes y reguladores deberán ser del mismo tipo (parámetros [...] DRIVETYPE iguales para ambos ejes)."@es .

ns1:Parametro_LIMIT_1165 a ns1:Parametro ;
    rdfs:label "LIMIT+ y LIMIT- (límites de software)"@es ;
    ns1:monitoreaParametro ns1:MotorTandemEsclavo_1165,
        ns1:MotorTandemMaestro_1165 ;
    ns1:textoExtracto "Ambos ejes deberán tener los mismos límites de software (parámetros LIMIT+ y LIMIT- iguales para ambos ejes)."@es .

ns1:ConfiguracionEjeTandem_1165 a ns1:Sistema ;
    rdfs:label "Configuración de eje tándem (maestro-esclavo)"@es ;
    ns1:compuestoPor ns1:MotorTandemEsclavo_1165,
        ns1:MotorTandemMaestro_1165 ;
    ns1:textoExtracto "Un eje tándem consiste en dos motores acoplados mecánicamente entre sí formando un único sistema de transmisión (eje o cabezal). En el CNC sólo se visualiza y se programa un eje (eje tándem maestro). El otro eje (eje tándem esclavo) no se visualiza y no es programable; es controlado por el CNC."@es ;
    ns1:tieneComponente ns1:PinonCremalleraSistema_1165 .

ns1:PinonCremalleraSistema_1165 a ns1:ComponenteMecanico ;
    rdfs:label "Sistema piñón-cremallera para eje tándem"@es ;
    ns1:textoExtracto "Ejemplo de un eje tándem compuesto por dos piñones y una cremallera."@es .

ns1:MotorTandemMaestro_1165 a ns1:ComponenteMecanico ;
    rdfs:label "Motor tándem maestro"@es ;
    ns1:controla ns1:MotorTandemEsclavo_1165 ;
    ns1:textoExtracto "eje (cabezal) tándem maestro [...] es visualiza y se programa un eje"@es .

ns1:MotorTandemEsclavo_1165 a ns1:ComponenteMecanico ;
    rdfs:label "Motor tándem esclavo"@es ;
    ns1:textoExtracto "eje (cabezal) tándem esclavo [...] no se visualiza y no es programable; es controlado por el CNC"@es .

