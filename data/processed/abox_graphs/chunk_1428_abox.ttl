@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionEjesTandem_1167 a ns1:ModoOperacion ;
    rdfs:label "Configuración de ejes tándem"@es ;
    ns1:textoExtracto "Cuando los ejes sean rotativos, ambos ejes deberán ser del mismo tipo (parámetros AXISMODE y SHORTESTWAY iguales para ambos ejes). La velocidad rápida y lenta de búsqueda de referencia máquina (parámetros REFFEED1 y REFF..."@es ;
    ns1:tieneComponente ns1:Parametro_AXISMODE_1167,
        ns1:Parametro_REFFEED1_1167,
        ns1:Parametro_REFFEED2_1167,
        ns1:Parametro_SHORTESTWAY_1167 .

ns1:Parametro_AXISMODE_1167 a ns1:Parametro ;
    rdfs:label "AXISMODE"@es ;
    ns1:identificador "AXISMODE" ;
    ns1:textoExtracto "parámetros AXISMODE"@es .

ns1:Parametro_REFFEED1_1167 a ns1:Parametro ;
    rdfs:label "REFFEED1 (velocidad rápida de búsqueda de referencia)"@es ;
    ns1:identificador "REFFEED1" ;
    ns1:textoExtracto "parámetros REFFEED1"@es .

ns1:Parametro_REFFEED2_1167 a ns1:Parametro ;
    rdfs:label "REFFEED2 (velocidad lenta de búsqueda de referencia)"@es ;
    ns1:identificador "REFFEED2" ;
    ns1:textoExtracto "parámetros REFFEED2"@es .

ns1:Parametro_SHORTESTWAY_1167 a ns1:Parametro ;
    rdfs:label "SHORTESTWAY"@es ;
    ns1:identificador "SHORTESTWAY" ;
    ns1:textoExtracto "parámetros SHORTESTWAY"@es .

