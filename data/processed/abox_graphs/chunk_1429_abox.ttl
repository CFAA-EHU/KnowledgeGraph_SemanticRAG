@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:configuracionTandem_1168 a ns1:Sistema ;
    rdfs:label "Configuración del eje tándem"@es ;
    ns1:monitoreaParametro ns1:parametrosMaquinaTandem_1168 ;
    ns1:textoExtracto "Las parejas tándem del sistema se configuran desde los parámetros máquina. Cada pareja tándem dispone de los siguientes parámetros máquina generales para su configuración."@es .

ns1:parametrosMaquinaTandem_1168 a ns1:Parametro ;
    rdfs:label "Parámetros máquina para configuración tándem"@es ;
    ns1:textoExtracto "parámetros máquina generales para su configuración"@es .

