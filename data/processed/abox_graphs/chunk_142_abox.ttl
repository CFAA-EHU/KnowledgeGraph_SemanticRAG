@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

ex:ReléGestiónEmergencias a owl:Class ;
    rdfs:label "Relé Gestión Emergencias" ;
    rdfs:comment "Componente de gestión de emergencias" .

ex:UnidadIluminada a owl:Class ;
    rdfs:label "Unidad Iluminada" ;
    rdfs:comment "Unidad iluminada para señalización del estado de la máquina" .

ex:PNOZmulti2BaseUnit a owl:Class ;
    rdfs:label "PNOZmulti 2 base unit" ;
    rdfs:comment "Unidad base de PNOZmulti 2" .

ex:SetOfSpringLoadedTerminals a owl:Class ;
    rdfs:label "Set of spring-loaded terminals" ;
    rdfs:comment "Conjunto de terminales con muelle" .

ex:ChipCard a owl:Class ;
    rdfs:label "ChipCard" ;
    rdfs:comment "Tarjeta de chip para PNOZ-mm01p" .

ex:PNOZmulti2InputModule a owl:Class ;
    rdfs:label "PNOZmulti 2 Input module" ;
    rdfs:comment "Módulo de entrada de PNOZmulti 2" .

ex:BornasDeResorte a owl:Class ;
    rdfs:label "Bornas de resorte" ;
    rdfs:comment "Bornas de resorte para PNOZ 4 pines" .

ex:UnidadIluminadaRoja a owl:Class ;
    rdfs:label "Unidad iluminada roja" ;
    rdfs:comment "Unidad iluminada de 70 mm, estable, roja, IP65, 24 V-LED" .

ex:UnidadIluminadaVerde a owl:Class ;
    rdfs:label "Unidad iluminada verde" ;
    rdfs:comment "Unidad iluminada de 70 mm, estable, verde, IP65, 24 V-LED" .

ex:UnidadIluminadaNaranja a owl:Class ;
    rdfs:label "Unidad iluminada naranja" ;
    rdfs:comment "Unidad iluminada de 70 mm, constante, naranja, IP65, 24 V-LED" .

ex:tieneModelo a owl:ObjectProperty ;
    rdfs:domain ex:ReléGestiónEmergencias ;
    rdfs:range xsd:string .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:ReléGestiónEmergencias ;
    rdfs:range xsd:string .

ex:tieneCodigo a owl:ObjectProperty ;
    rdfs:domain ex:ReléGestiónEmergencias ;
    rdfs:range xsd:string .

ex:tieneCantidad a owl:ObjectProperty ;
    rdfs:domain ex:ReléGestiónEmergencias ;
    rdfs:range xsd:integer .

ex:tieneColor a owl:ObjectProperty ;
    rdfs:domain ex:UnidadIluminada ;
    rdfs:range xsd:string .

ex:tieneTension a owl:ObjectProperty ;
    rdfs:domain ex:UnidadIluminada ;
    rdfs:range xsd:string .

ex:tieneIP a owl:ObjectProperty ;
    rdfs:domain ex:UnidadIluminada ;
    rdfs:range xsd:string .

ex:tieneDiametro a owl:ObjectProperty ;
    rdfs:domain ex:UnidadIluminada ;
    rdfs:range xsd:string .

ex:tieneTipoIluminacion a owl:ObjectProperty ;
    rdfs:domain ex:UnidadIluminada ;
    rdfs:range xsd:string .