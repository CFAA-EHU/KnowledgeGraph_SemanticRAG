@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_MASTERAXIS a ns1:Parametro ;
    rdfs:label "MASTERAXIS" ;
    ns1:documentadoEn ns1:TablaParametrosTandem_1169 ;
    ns1:identificador "MASTERAXIS" ;
    ns1:textoExtracto "Eje/cabezal maestro o principal."@es .

ns1:Parametro_PRELFITI a ns1:Parametro ;
    rdfs:label "PRELFITI" ;
    ns1:documentadoEn ns1:TablaParametrosTandem_1169 ;
    ns1:identificador "PRELFITI" ;
    ns1:textoExtracto "Tiempo del filtro para aplicar la precarga."@es .

ns1:Parametro_PRELOAD a ns1:Parametro ;
    rdfs:label "PRELOAD" ;
    ns1:documentadoEn ns1:TablaParametrosTandem_1169 ;
    ns1:identificador "PRELOAD" ;
    ns1:textoExtracto "Precarga entre ambos motores."@es .

ns1:Parametro_SLAVEAXIS a ns1:Parametro ;
    rdfs:label "SLAVEAXIS" ;
    ns1:documentadoEn ns1:TablaParametrosTandem_1169 ;
    ns1:identificador "SLAVEAXIS" ;
    ns1:textoExtracto "Eje/cabezal esclavo."@es .

ns1:Parametro_TANDEM a ns1:Parametro ;
    rdfs:label "TANDEM" ;
    ns1:documentadoEn ns1:TablaParametrosTandem_1169 ;
    ns1:identificador "TANDEM" ;
    ns1:textoExtracto "Tabla de ejes o cabezales tándem."@es .

ns1:Parametro_TCOMPLIM a ns1:Parametro ;
    rdfs:label "TCOMPLIM" ;
    ns1:documentadoEn ns1:TablaParametrosTandem_1169 ;
    ns1:identificador "TCOMPLIM" ;
    ns1:textoExtracto "Límite de la compensación."@es .

ns1:Parametro_TINTIME a ns1:Parametro ;
    rdfs:label "TINTIME" ;
    ns1:documentadoEn ns1:TablaParametrosTandem_1169 ;
    ns1:identificador "TINTIME" ;
    ns1:textoExtracto "Ganancia integral (Ki) para el tándem."@es .

ns1:Parametro_TORQDIST a ns1:Parametro ;
    rdfs:label "TORQDIST" ;
    ns1:documentadoEn ns1:TablaParametrosTandem_1169 ;
    ns1:identificador "TORQDIST" ;
    ns1:textoExtracto "Distribución del par."@es .

ns1:Parametro_TPROGAIN a ns1:Parametro ;
    rdfs:label "TPROGAIN" ;
    ns1:documentadoEn ns1:TablaParametrosTandem_1169 ;
    ns1:identificador "TPROGAIN" ;
    ns1:textoExtracto "Ganancia proporcional (Kp) para el tándem."@es .

ns1:TablaParametrosTandem_1169 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de configuración del eje tándem"@es ;
    ns1:identificador "11.2.1" ;
    ns1:textoExtracto "Tabla de ejes o cabezales tándem."@es ;
    ns1:tieneComponente ns1:Parametro_MASTERAXIS,
        ns1:Parametro_PRELFITI,
        ns1:Parametro_PRELOAD,
        ns1:Parametro_SLAVEAXIS,
        ns1:Parametro_TANDEM,
        ns1:Parametro_TCOMPLIM,
        ns1:Parametro_TINTIME,
        ns1:Parametro_TORQDIST,
        ns1:Parametro_TPROGAIN .

