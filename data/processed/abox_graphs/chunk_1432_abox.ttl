@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaTandem_573_574 a ns1:Sistema ;
    rdfs:label "Sistema de cabezales tándem" ;
    ns1:controla ns1:ParametroDistribucionPar_573 ;
    ns1:textoExtracto "Consideraciones para cabezales tándem. [...] La distribución del par establece el porcentaje de par que realiza cada motor para conseguir el par total necesario en el tándem." ;
    ns1:tieneComponente ns1:MotorEsclavo_573,
        ns1:MotorMaestro_573 .

ns1:MotorEsclavo_573 a ns1:ComponenteElectrico ;
    rdfs:label "Motor del cabezal esclavo (tándem)" ;
    ns1:monitoreaParametro ns1:ParametroDistribucionPar_573 ;
    ns1:textoExtracto "El PLC deba habilitar y deshabilitar las señales SPENA(axis) y DRENA(axis) de los cabezales maestro y esclavo simultáneamente." .

ns1:MotorMaestro_573 a ns1:ComponenteElectrico ;
    rdfs:label "Motor del cabezal maestro (tándem)" ;
    ns1:monitoreaParametro ns1:ParametroDistribucionPar_573 ;
    ns1:textoExtracto "El PLC deba habilitar y deshabilitar las señales SPENA(axis) y DRENA(axis) de los cabezales maestro y esclavo simultáneamente." .

ns1:ParametroDistribucionPar_573 a ns1:Parametro ;
    rdfs:label "Distribución del par en tándem" ;
    ns1:textoExtracto "La distribución del par establece el porcentaje de par que realiza cada motor para conseguir el par total necesario en el tándem." ;
    ns1:valor "Porcentaje de par por motor (ejemplo: 50%-50%)" .

