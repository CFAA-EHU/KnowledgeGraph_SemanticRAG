@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_PRELFITI a ns1:Parametro ;
    rdfs:label "PRELFITI" ;
    ns1:monitoreaParametro ns1:SistemaTandem ;
    ns1:textoExtracto "Para aplicar la precarga de una forma gradual [...] se puede definir el parámetro PRELFITI. Este parámetro habilita un filtro de primer orden que establece el tiempo que tarda el CNC en aplicar la precarga de forma progresiva." .

ns1:Parametro_PRELOAD a ns1:Parametro ;
    rdfs:label "PRELOAD" ;
    ns1:monitoreaParametro ns1:SistemaTandem ;
    ns1:textoExtracto "La precarga se define con el parámetro PRELOAD, el cual indica qué porcentaje del par nominal del motor maestro se aplicará como precarga." .

ns1:Parametro_TORQDIST a ns1:Parametro ;
    rdfs:label "TORQDIST" ;
    ns1:monitoreaParametro ns1:SistemaTandem ;
    ns1:textoExtracto "La distribución del par en el tándem se define con el parámetro TORQDIST, el cual indica qué porcentaje debe dar el motor maestro." .

ns1:Parametro_TPROGAIN a ns1:Parametro ;
    rdfs:label "TPROGAIN" ;
    ns1:monitoreaParametro ns1:SistemaTandem ;
    ns1:textoExtracto "La ganancia proporcional se puede definir con el parámetro TPROGAIN." .

ns1:MotorEsclavoTandem a ns1:ComponenteMecanico ;
    rdfs:label "Motor esclavo del tándem" ;
    ns1:textoExtracto "La diferencia entre el valor de este parámetro y el 100% es el porcentaje que se aplicará al motor esclavo." .

ns1:MotorMaestroTandem a ns1:ComponenteMecanico ;
    rdfs:label "Motor maestro del tándem" ;
    ns1:textoExtracto "el motor maestro. [...] qué porcentaje debe dar el motor maestro." .

ns1:SistemaTandem a ns1:Sistema ;
    rdfs:label "Sistema de control del eje tándem" ;
    ns1:textoExtracto "Distribución del par en el tándem. [...] La aplicación del valor de precarga implica necesariamente la unión mecánica entre los motores maestro y esclavo que forman el tándem." ;
    ns1:tieneComponente ns1:MotorEsclavoTandem,
        ns1:MotorMaestroTandem .

