@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_TPROGAIN a ns1:Parametro ;
    rdfs:label "Ganancia proporcional (Kp) para el eje tándem"@es ;
    ns1:identificador "TPROGAIN" ;
    ns1:monitoreaParametro ns1:Sistema_ControlTandem ;
    ns1:textoExtracto "Ganancia proporcional (Kp) para el tándem. [...] La ganancia proporcional se puede definir con el parámetro TPROGAIN."@es .

ns1:Sistema_ControlTandem a ns1:Sistema ;
    rdfs:label "Sistema de control del eje tándem"@es ;
    ns1:textoExtracto "El controlador proporcional genera una salida proporcional al error en par entre los dos motores."@es .

