@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ControlTandem a ns1:Sistema ;
    rdfs:label "Sistema de control del eje tándem"@es ;
    ns1:monitoreaParametro ns1:Parametro_TINTTIME,
        ns1:Parametro_TPROGAIN ;
    ns1:textoExtracto "genera una salida proporcional al error en par entre los dos motores. [...] El controlador integral genera una salida proporcional a la integral del error en par entre los dos motores."@es .

ns1:Parametro_TINTTIME a ns1:Parametro ;
    rdfs:label "Ganancia integral del eje tándem"@es ;
    ns1:identificador "TINTTIME" ;
    ns1:textoExtracto "La ganancia integral se puede definir con el parámetro TINTTIME."@es .

ns1:Parametro_TPROGAIN a ns1:Parametro ;
    rdfs:label "Ganancia proporcional del eje tándem"@es ;
    ns1:identificador "TPROGAIN" ;
    ns1:textoExtracto "La ganancia proporcional se puede definir con el parámetro TPROGAIN."@es .

