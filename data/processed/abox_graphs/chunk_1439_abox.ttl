@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CanalSercos_1178 a ns1:InterfazUsuario ;
    rdfs:label "Canal rápido Sercos (CNC)"@es ;
    ns1:monitoreaParametro ns1:ParametroParEsclavo_1178,
        ns1:ParametroParMaestro_1178 ;
    ns1:textoExtracto "En la definición de un eje tándem, en cada lazo se leen en el CNC vía Sercos, los pares suministrados por los motores maestro y esclavo. Esto puede ocasionar una disminución del número de variables de lectura y escritura en el canal rápido de Sercos."@es .

ns1:EjeTandem_1178 a ns1:Sistema ;
    rdfs:label "Eje tándem (configuración maestro-esclavo)"@es ;
    ns1:compuestoPor ns1:MotorEsclavo_1178,
        ns1:MotorMaestro_1178 ;
    ns1:textoExtracto "una tracción entre ellos con el fin de eliminar la holgura piñón-cremallera cuando se encuentra en reposo. Se determina como la diferencia de par que suministra cada uno de los ejes. La aplicación del valor de precarga implica necesariamente la unión mecánica entre los motores maestro y esclavo que forman el eje tándem."@es ;
    ns1:tieneComponente ns1:ControladorPI_1178,
        ns1:FiltroPrecarga_1178 .

ns1:ControladorPI_1178 a ns1:ComponenteElectrico ;
    rdfs:label "Controlador PI del tándem"@es ;
    ns1:controla ns1:MotorEsclavo_1178,
        ns1:MotorMaestro_1178 ;
    ns1:textoExtracto "PI del tándem. PI cuya función es conseguir que cada motor realice el par que le corresponde. Incrementa su consigna de velocidad si el par que se suministra es demasiado pequeño y la reduce si el par suministrado es demasiado elevado."@es .

ns1:FiltroPrecarga_1178 a ns1:ComponenteElectrico ;
    rdfs:label "Filtro de precarga (eje tándem)"@es ;
    ns1:textoExtracto "Filtro de precarga. Filtro de primer orden cuyo fin es evitar la entrada de escalones de par al configurar la precarga."@es .

ns1:MotorEsclavo_1178 a ns1:ComponenteMecanico ;
    rdfs:label "Motor esclavo (eje tándem)"@es ;
    ns1:monitoreaParametro ns1:ParametroParEsclavo_1178 ;
    ns1:textoExtracto "unión mecánica entre los motores maestro y esclavo que forman el eje tándem"@es .

ns1:MotorMaestro_1178 a ns1:ComponenteMecanico ;
    rdfs:label "Motor maestro (eje tándem)"@es ;
    ns1:monitoreaParametro ns1:ParametroParMaestro_1178 ;
    ns1:textoExtracto "unión mecánica entre los motores maestro y esclavo que forman el eje tándem"@es .

ns1:ParametroParEsclavo_1178 a ns1:Parametro ;
    rdfs:label "Par suministrado (motor esclavo)"@es ;
    ns1:textoExtracto "los pares suministrados por los motores maestro y esclavo"@es ;
    ns1:valor "variable"@es .

ns1:ParametroParMaestro_1178 a ns1:Parametro ;
    rdfs:label "Par suministrado (motor maestro)"@es ;
    ns1:textoExtracto "los pares suministrados por los motores maestro y esclavo"@es ;
    ns1:valor "variable"@es .

