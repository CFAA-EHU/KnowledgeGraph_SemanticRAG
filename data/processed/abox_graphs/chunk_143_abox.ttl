@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix admin: <https://admin-shell.io/dictionary/> .
@prefix rittal: <http://www.rittal.com/> .
@prefix phoenix: <http://www.phoenixcontact.com/> .
@prefix murrelektronik: <http://www.murrelektronik.com/> .
@prefix schneider: <http://www.schneider-electric.com/> .

ex:UnidadIluminada a owl:Class ;
    rdfs:label "Unidad Iluminada"@es ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:ColumnaLuminosa a owl:Class ;
    rdfs:label "Columna Luminosa"@es ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:BaseFijacion a owl:Class ;
    rdfs:label "Base de Fijación"@es ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:CajaMando a owl:Class ;
    rdfs:label "Caja de Mando"@es ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:ArticulacionMural a owl:Class ;
    rdfs:label "Articulación Mural"@es ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:AnglePiece a owl:Class ;
    rdfs:label "Angle Piece"@es ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:Coupling a owl:Class ;
    rdfs:label "Coupling"@es ;
    rdfs:isDefinedBy admin:Coupling .

ex:SupportSection a owl:Class ;
    rdfs:label "Support Section"@es ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:DispositivoESDescentralizado a owl:Class ;
    rdfs:label "Dispositivo E/S Descentralizado"@es ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:TCouplerSlimLine a owl:Class ;
    rdfs:label "T-coupler SlimLine"@es ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/> .

ex:UnidadIluminadaNaranja a ex:UnidadIluminada ;
    rdfs:label "Unidad Iluminada Naranja"@es .

ex:LightColumnBase a ex:ColumnaLuminosa ;
    rdfs:label "Light Column Base"@es .

ex:BaseFijacion80mm a ex:BaseFijacion ;
    rdfs:label "Base de Fijación 80mm"@es .

ex:CajaMando600x600x210 a ex:CajaMando ;
    rdfs:label "Caja de Mando 600x600x210"@es .

ex:ArticulacionMuralCP120 a ex:ArticulacionMural ;
    rdfs:label "Articulación Mural CP120"@es .

ex:AnglePiece90CP120 a ex:AnglePiece ;
    rdfs:label "Angle Piece 90°, CP 120"@es .

ex:CouplingCP120 a ex:Coupling ;
    rdfs:label "Coupling CP 120"@es .

ex:SupportSectionCP120 a ex:SupportSection ;
    rdfs:label "Support Section CP 120"@es .

ex:DispositivoESDescentralizadoPHOENIX a ex:DispositivoESDescentralizado ;
    rdfs:label "Dispositivo E/S Descentralizado PHOENIX"@es .

ex:TCouplerSlimLineMurrelektronik a ex:TCouplerSlimLine ;
    rdfs:label "T-coupler SlimLine Murrelektronik"@es .