@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rittal: <http://www.rittal.com/> .
@prefix schneider: <http://www.schneider-electric.com/> .
@prefix phoenix: <http://www.phoenixcontact.com/> .
@prefix murrelektronik: <http://www.murrelektronik.com/> .
@prefix admin: <https://admin-shell.io/dictionary/> .

ex:UnidadIluminada a owl:Class ;
    rdfs:label "Unidad iluminada" ;
    rdfs:comment "Unidad iluminada constante de color naranja con protección IP65 y alimentación de 24 V-LED." .

ex:ColumnaLuminosa a owl:Class ;
    rdfs:label "Columna luminosa" ;
    rdfs:comment "Componente de señalización del estado de la máquina." .

ex:BaseFijacion a owl:Class ;
    rdfs:label "Base de fijación" ;
    rdfs:comment "Base de fijación de 80 mm con tubo de soporte negro." .

ex:CajaDeMando a owl:Class ;
    rdfs:label "Caja de mando" ;
    rdfs:comment "Caja de mando con asas de dimensiones 600x600x210 mm." .

ex:ArticulacionMural a owl:Class ;
    rdfs:label "Articulación mural" ;
    rdfs:comment "Articulación mural CP120." .

ex:AnglePiece a owl:Class ;
    rdfs:label "Angle piece" ;
    rdfs:comment "Angle piece de 90° para CP120." .

ex:Coupling a owl:Class ;
    rdfs:isDefinedBy admin:Coupling ;
    rdfs:label "Coupling" ;
    rdfs:comment "Coupling CP120 para conexión de brazo de soporte de Ø130 mm." .

ex:SupportSection a owl:Class ;
    rdfs:label "Support section" ;
    rdfs:comment "Support section CP120 sólido, longitud 1000 mm." .

ex:DispositivoESDescentralizado a owl:Class ;
    rdfs:label "Dispositivo E/S descentralizado" ;
    rdfs:comment "Dispositivo de entrada/salida descentralizado." .

ex:TCouplerSlimLine a owl:Class ;
    rdfs:label "T-coupler SlimLine" ;
    rdfs:comment "T-coupler SlimLine M12-male 5p./ 2x M12-female 4p." .

ex:tieneModelo a owl:ObjectProperty ;
    rdfs:label "tiene modelo" ;
    rdfs:comment "Relación que indica el modelo de un componente." .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:label "tiene fabricante" ;
    rdfs:comment "Relación que indica el fabricante de un componente." .

ex:tieneCantidad a owl:DatatypeProperty ;
    rdfs:label "tiene cantidad" ;
    rdfs:comment "Relación que indica la cantidad de un componente." .

ex:tieneProteccion a owl:DatatypeProperty ;
    rdfs:label "tiene protección" ;
    rdfs:comment "Relación que indica el nivel de protección de un componente." .

ex:tieneAlimentacion a owl:DatatypeProperty ;
    rdfs:label "tiene alimentación" ;
    rdfs:comment "Relación que indica la alimentación de un componente." .

ex:tieneColor a owl:DatatypeProperty ;
    rdfs:label "tiene color" ;
    rdfs:comment "Relación que indica el color de un componente." .

ex:tieneDimensiones a owl:DatatypeProperty ;
    rdfs:label "tiene dimensiones" ;
    rdfs:comment "Relación que indica las dimensiones de un componente." .

ex:tieneLongitud a owl:DatatypeProperty ;
    rdfs:label "tiene longitud" ;
    rdfs:comment "Relación que indica la longitud de un componente." .