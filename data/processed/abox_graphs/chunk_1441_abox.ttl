@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_FTEO a ns1:Parametro ;
    rdfs:label "Consigna de velocidad para Sercos (FTEO)" ;
    ns1:documentadoEn ns1:Tabla_VariablesTandem_1180 ;
    ns1:identificador "(V.)[ch].A.FTEO.xn" ;
    ns1:textoExtracto "(V.)[ch].A.FTEO.xn | Consigna de velocidad para Sercos" ;
    ns1:valor "rpm"^^xsd:string .

ns1:Parametro_PRELOAD a ns1:Parametro ;
    rdfs:label "Precarga (PRELOAD)" ;
    ns1:documentadoEn ns1:Tabla_VariablesTandem_1180 ;
    ns1:identificador "(V.)[ch].A.PRELOAD.xn" ;
    ns1:textoExtracto "(V.)[ch].A.PRELOAD.xn | Precarga" .

ns1:Parametro_TFILTOUT a ns1:Parametro ;
    rdfs:label "Salida del filtro de precarga (TFILTOUT)" ;
    ns1:documentadoEn ns1:Tabla_VariablesTandem_1180 ;
    ns1:identificador "(V.)[ch].A.TFILTOUT.xn" ;
    ns1:textoExtracto "(V.)[ch].A.TFILTOUT.xn | Salida del filtro de precarga" .

ns1:Parametro_TORQUE a ns1:Parametro ;
    rdfs:label "Par de corriente en Sercos (TORQUE)" ;
    ns1:documentadoEn ns1:Tabla_VariablesTandem_1180 ;
    ns1:identificador "(V.)[ch].A.TORQUE.xn" ;
    ns1:textoExtracto "(V.)[ch].A.TORQUE.xn | Par de corriente en Sercos. La lectura desde el PLC de esta variable vendrá expresada en décimas (x10)." .

ns1:Parametro_TPIIN a ns1:Parametro ;
    rdfs:label "Entrada del PI del eje maestro del tándem (TPIIN)" ;
    ns1:documentadoEn ns1:Tabla_VariablesTandem_1180 ;
    ns1:identificador "(V.)[ch].A.TPIIN.xn" ;
    ns1:textoExtracto "(V.)[ch].A.TPIIN.xn | Entrada del PI del eje maestro del tándem (en rpm)" ;
    ns1:valor "rpm"^^xsd:string .

ns1:Parametro_TPIOUT a ns1:Parametro ;
    rdfs:label "Salida del PI del eje maestro del tándem (TPIOUT)" ;
    ns1:documentadoEn ns1:Tabla_VariablesTandem_1180 ;
    ns1:identificador "(V.)[ch].A.TPIOUT.xn" ;
    ns1:textoExtracto "(V.)[ch].A.TPIOUT.xn | Salida del PI del eje maestro del tándem (en rpm)" ;
    ns1:valor "rpm"^^xsd:string .

ns1:Tabla_VariablesTandem_1180 a ns1:Tabla ;
    rdfs:label "Tabla de variables asociadas al tándem (pág. 579)" ;
    ns1:documentadoEn ns1:Manual_1124 ;
    ns1:textoExtracto "Los mnemónicos de las variables son genéricos. • Sustituir el carácter \"xn\" por el nombre o número lógico del eje. • Sustituir el carácter \"ch\" por el número de canal, conservando los corchetes. |  | PRG | PLC | INT | --- | --- | --- | --- | (V.)[ch].A.TPIIN.xn | Entrada del PI del eje maestro del tándem (en rpm) | R | R | R | (V.)[ch].A.TPIOUT.xn | Salida del PI del eje maestro del tándem (en rpm) | R | R | R | ..." .

