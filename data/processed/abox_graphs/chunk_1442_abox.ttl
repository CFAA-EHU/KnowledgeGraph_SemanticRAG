@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProcesoAjusteTandem_1181 a ns1:TareaMantenimiento ;
    rdfs:label "Proceso de ajuste del tándem"@es ;
    ns1:requiereMantenimiento ns1:MaquinaTandem_1181 ;
    ns1:textoExtracto "En este proceso debe tenerse en cuenta el tipo de máquina de la que se dispone. En general, una máquina tándem posee frecuencia de resonancia baja; por lo tanto, el CNC debe generar consignas de posición sin componentes frecuenciales superiores a la frecuencia de resonancia. Es recomendable iniciar el proceso con valores de jerk bajos (menores de 10 m/sg3) y Kv baja. Siempre es posible aumentarlos en un reajuste posterior."@es ;
    ns1:tieneFrecuencia ns1:FrecuenciaResonanciaBaja_1181 .

ns1:EjeEsclavo_1181 a ns1:ComponenteMecanico ;
    rdfs:label "Eje esclavo"@es ;
    ns1:textoExtracto "asegurar un perfecto funcionamiento tanto del eje maestro como del eje esclavo de modo independiente"@es .

ns1:EjeMaestro_1181 a ns1:ComponenteMecanico ;
    rdfs:label "Eje maestro"@es ;
    ns1:textoExtracto "asegurar un perfecto funcionamiento tanto del eje maestro como del eje esclavo de modo independiente"@es .

ns1:FrecuenciaResonanciaBaja_1181 a ns1:Frecuencia ;
    rdfs:label "Frecuencia de resonancia baja"@es ;
    ns1:textoExtracto "una máquina tándem posee frecuencia de resonancia baja"@es .

ns1:MaquinaTandem_1181 a ns1:Maquina ;
    rdfs:label "Máquina tándem"@es ;
    ns1:textoExtracto "una máquina tándem posee frecuencia de resonancia baja"@es ;
    ns1:tieneComponente ns1:EjeEsclavo_1181,
        ns1:EjeMaestro_1181,
        ns1:MotorEje1_1181,
        ns1:MotorEje2_1181,
        ns1:ReguladorCNC_1181 .

ns1:ReguladorCNC_1181 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador CNC"@es ;
    ns1:controla ns1:MotorEje1_1181,
        ns1:MotorEje2_1181 ;
    ns1:textoExtracto "el CNC debe generar consignas de posición sin componentes frecuenciales superiores a la frecuencia de resonancia"@es .

ns1:MotorEje1_1181 a ns1:ComponenteElectrico ;
    rdfs:label "Motor del eje 1"@es ;
    ns1:monitoreaParametro ns1:ParametroSP43_1181,
        ns1:ParametroTP85_1181 ;
    ns1:textoExtracto "Comprobar que los sentidos de giro de ambos motores son coherentes una vez realizado el movimiento. [...] Comprobar que la reducción en ambos motores es la misma (a igual velocidad de giro igual avance)."@es .

ns1:MotorEje2_1181 a ns1:ComponenteElectrico ;
    rdfs:label "Motor del eje 2"@es ;
    ns1:monitoreaParametro ns1:ParametroSP43_1181,
        ns1:ParametroTP85_1181 ;
    ns1:textoExtracto "Comprobar que los sentidos de giro de ambos motores son coherentes una vez realizado el movimiento. [...] Comprobar que la reducción en ambos motores es la misma (a igual velocidad de giro igual avance)."@es .

ns1:ParametroSP43_1181 a ns1:Parametro ;
    rdfs:label "Parámetro SP43" ;
    ns1:identificador "SP43" ;
    ns1:textoExtracto "será necesario cambiar el signo de sus valores monitorizados mediante los parámetros SP43 y TP85 del regulador"@es .

ns1:ParametroTP85_1181 a ns1:Parametro ;
    rdfs:label "Parámetro TP85" ;
    ns1:identificador "TP85" ;
    ns1:textoExtracto "será necesario cambiar el signo de sus valores monitorizados mediante los parámetros SP43 y TP85 del regulador"@es .

