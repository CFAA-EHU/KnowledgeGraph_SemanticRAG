@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_ANAOUTID a ns1:Parametro ;
    rdfs:label "ANAOUTID" ;
    ns1:monitoreaParametro ns1:Sistema_EntradasSalidasAnalogicas ;
    ns1:textoExtracto "ANAOUTID | 101 -132 201 - 232. En este caso, este parámetro indica cuál es el número de la salida analógica y el regulador a utilizar. El parámetro se define mediante un número de tres dígitos; el primer dígito indica el número de la salida analógica a utilizar (1 ó 2) y los dos dígitos siguientes indican la dirección lógica del regulador (de 1 a 32)." ;
    ns1:valor "101-132, 201-232" .

ns1:Parametro_COUNTERID a ns1:Parametro ;
    rdfs:label "COUNTERID" ;
    ns1:textoExtracto "en el parámetro COUNTERID hay que indicar cuál es la entrada de captación a utilizar (si la captación es local o remota) o el número de regulador." .

ns1:Parametro_COUNTERTYPE a ns1:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ns1:textoExtracto "La selección se realiza mediante el parámetro COUNTERTYPE." .

ns1:Componente_ModulosRemotosCANfagor a ns1:ComponenteElectrico ;
    rdfs:label "Módulos remotos CANfagor" ;
    ns1:textoExtracto "Entrada de captación en los módulos remotos CANfagor." .

ns1:Componente_ReguladorSercos a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos" ;
    ns1:monitoreaParametro ns1:Parametro_PP5 ;
    ns1:textoExtracto "regulador Sercos" .

ns1:Componente_UnidadCentral a ns1:ComponenteElectrico ;
    rdfs:label "Unidad central" ;
    ns1:textoExtracto "la propia unidad central" .

ns1:Parametro_PP5 a ns1:Parametro ;
    rdfs:label "PP5" ;
    ns1:textoExtracto "Cuando se utilice la entrada de captación de un regulador Sercos, se debe parametrizar el parámetro del regulador PP5=-0,0001." ;
    ns1:valor "-0.0001" .

ns1:Sistema_EntradasSalidasAnalogicas a ns1:Sistema ;
    rdfs:label "Sistema de entradas/salidas analógicas" ;
    ns1:textoExtracto "Configurar el número de salida analógica y de la entrada de captación." ;
    ns1:tieneComponente ns1:Componente_ModulosRemotosCANfagor,
        ns1:Componente_ReguladorSercos,
        ns1:Componente_UnidadCentral .

