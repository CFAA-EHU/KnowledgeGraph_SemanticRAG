@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_ConfiguracionEntradasCaptacion a ns1:Tabla ;
    rdfs:label "Tabla de configuración de entradas de captación" ;
    ns1:detalladoEnEsquema ns1:Parametro_COUNTERID_Local,
        ns1:Parametro_COUNTERID_ModuloRemoto,
        ns1:Parametro_COUNTERID_Regulador,
        ns1:Parametro_COUNTERTYPE,
        ns1:Parametro_COUNTERTYPE_Local,
        ns1:Parametro_COUNTERTYPE_Regulador ;
    ns1:textoExtracto "Parámetro | Valor [...] Entrada de captación en los reguladores Sercos [...] Entrada de captación local."@es .

ns1:Parametro_COUNTERID_Local a ns1:Parametro ;
    rdfs:label "COUNTERID (unidad central)" ;
    ns1:textoExtracto "COUNTERID | Número de la entrada de captación. [...] La unidad central dispone de dos entradas de captación."@es ;
    ns1:valor "1-2" .

ns1:Parametro_COUNTERID_ModuloRemoto a ns1:Parametro ;
    rdfs:label "COUNTERID (módulo remoto)" ;
    ns1:textoExtracto "COUNTERID | Número de la entrada de captación. [...] Los módulos de las contadoras se numeran según el orden lógico de los grupos remotos (conmutador rotativo de la fuente de alimentación)."@es ;
    ns1:valor "1-32 (según orden lógico de grupos remotos)" .

ns1:Parametro_COUNTERID_Regulador a ns1:Parametro ;
    rdfs:label "COUNTERID (regulador Sercos)" ;
    ns1:textoExtracto "COUNTERID | Número de la entrada de captación. [...] El parámetro COUNTERID indica la dirección lógica del regulador (de 1 a 32)."@es ;
    ns1:valor "1-32 (dirección lógica del regulador)" .

ns1:Parametro_COUNTERTYPE a ns1:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ns1:textoExtracto "COUNTERTYPE | Remoto."@es ;
    ns1:valor "Remoto" .

ns1:Parametro_COUNTERTYPE_Local a ns1:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ns1:textoExtracto "COUNTERTYPE | Local."@es ;
    ns1:valor "Local" .

ns1:Parametro_COUNTERTYPE_Regulador a ns1:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ns1:textoExtracto "COUNTERTYPE | Regulador."@es ;
    ns1:valor "Regulador" .

