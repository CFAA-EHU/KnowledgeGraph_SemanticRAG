@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_ABSOFF a ns1:Parametro ;
    rdfs:label "ABSOFF" ;
    ns1:documentadoEn ns1:Tabla_ParametrosConfiguracion2Ejes ;
    ns1:identificador "ABSOFF" ;
    ns1:monitoreaParametro ns1:Parametro_ABSFEEDBACK ;
    ns1:textoExtracto "Offset del captador respecto a I0."@es .

ns1:Parametro_EXTMULT a ns1:Parametro ;
    rdfs:label "EXTMULT" ;
    ns1:documentadoEn ns1:Tabla_ParametrosConfiguracion2Ejes ;
    ns1:identificador "EXTMULT" ;
    ns1:textoExtracto "Factor multiplicador externo."@es .

ns1:Parametro_I0CODDI1 a ns1:Parametro ;
    rdfs:label "I0CODDI1" ;
    ns1:documentadoEn ns1:Tabla_ParametrosConfiguracion2Ejes ;
    ns1:identificador "I0CODDI1" ;
    ns1:textoExtracto "Paso entre señales de I0 fijas."@es .

ns1:Parametro_I0CODDI2 a ns1:Parametro ;
    rdfs:label "I0CODDI2" ;
    ns1:documentadoEn ns1:Tabla_ParametrosConfiguracion2Ejes ;
    ns1:identificador "I0CODDI2" ;
    ns1:textoExtracto "Paso entre señales de I0 variables."@es .

ns1:Parametro_I0TYPE a ns1:Parametro ;
    rdfs:label "I0TYPE" ;
    ns1:documentadoEn ns1:Tabla_ParametrosConfiguracion2Ejes ;
    ns1:identificador "I0TYPE" ;
    ns1:textoExtracto "Tipo de I0."@es .

ns1:Parametro_REFPULSE a ns1:Parametro ;
    rdfs:label "REFPULSE" ;
    ns1:documentadoEn ns1:Tabla_ParametrosConfiguracion2Ejes ;
    ns1:identificador "REFPULSE" ;
    ns1:textoExtracto "Flanco de la señal de I0."@es .

ns1:Parametro_SINMAGNI a ns1:Parametro ;
    rdfs:label "SINMAGNI" ;
    ns1:documentadoEn ns1:Tabla_ParametrosConfiguracion2Ejes ;
    ns1:identificador "SINMAGNI" ;
    ns1:textoExtracto "Factor multiplicador de la señal sinusoidal."@es .

ns1:CaptadorDePosicion a ns1:Sensor ;
    rdfs:label "Captador de posición"@es ;
    ns1:textoExtracto "Tipo de captación"@es .

ns1:Pagina_583 a ns1:Pagina ;
    ns1:identificador "583" ;
    ns1:textoExtracto "11.3.2 Configurar 2 ejes con la misma entrada captación y salida analógica."@es .

ns1:Parametro_ABSFEEDBACK a ns1:Parametro ;
    rdfs:label "ABSFEEDBACK" ;
    ns1:documentadoEn ns1:Tabla_ParametrosConfiguracion2Ejes ;
    ns1:identificador "ABSFEEDBACK" ;
    ns1:monitoreaParametro ns1:CaptadorDePosicion ;
    ns1:textoExtracto "Tipo de captación."@es .

ns1:Seccion_11.3.2 a ns1:Capitulo ;
    rdfs:label "Configurar 2 ejes con la misma entrada captación y salida analógica"@es ;
    ns1:identificador "11.3.2" ;
    ns1:textoExtracto "En la maniobra del PLC se debe incluir la detección del eje activo y la del eje aparcado."@es .

ns1:Tabla_ParametrosConfiguracion2Ejes a ns1:Tabla ;
    rdfs:label "Tabla de parámetros para configuración de 2 ejes con misma entrada analógica"@es ;
    ns1:documentadoEn ns1:Pagina_583 ;
    ns1:ilustradoEn ns1:Seccion_11.3.2 ;
    ns1:textoExtracto """
| Parámetro | Significado |
| --- | --- |
| ABSFEEDBACK | Tipo de captación. |
| SINMAGNI | Factor multiplicador de la señal sinusoidal. |
| I0TYPE | Tipo de I0. |
| REFPULSE | Flanco de la señal de I0. |
| ABSOFF | Offset del captador respecto a I0. |
| EXTMULT | Factor multiplicador externo. |
| I0CODDI1 | Paso entre señales de I0 fijas. |
| I0CODDI2 | Paso entre señales de I0 variables.
"""@es .

