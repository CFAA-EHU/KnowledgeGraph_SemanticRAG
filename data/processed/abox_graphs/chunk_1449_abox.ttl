@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ReguladorMultieje_1188 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador de grupo multieje"@es ;
    ns1:controla ns1:GrupoMultieje_1188 ;
    ns1:textoExtracto "Un grupo multieje consiste en varios ejes [...] controlados por un único regulador"@es .

ns1:Eje_AxisA1_1188 a ns1:ComponenteMecanico ;
    rdfs:label "Eje Axis A1"@es ;
    ns1:controla ns1:Motor_AxisA1_1188 ;
    ns1:identificador "Axis A1" ;
    ns1:textoExtracto "Axis A1"@es .

ns1:Eje_AxisA2_1188 a ns1:ComponenteMecanico ;
    rdfs:label "Eje Axis A2"@es ;
    ns1:controla ns1:Motor_AxisA2_1188 ;
    ns1:identificador "Axis A2" ;
    ns1:textoExtracto "Axis A2"@es .

ns1:GrupoMultieje_1188 a ns1:Sistema ;
    rdfs:label "Grupo multieje (Axis A1 + Axis A2)"@es ;
    ns1:controla ns1:Motor_AxisA1_1188,
        ns1:Motor_AxisA2_1188 ;
    ns1:textoExtracto "Grupo multieje compuesto por dos ejes, cada uno controlado por un motor."@es ;
    ns1:tieneComponente ns1:Eje_AxisA1_1188,
        ns1:Eje_AxisA2_1188 .

ns1:Motor_AxisA1_1188 a ns1:ComponenteElectrico ;
    rdfs:label "Motor del eje Axis A1"@es ;
    ns1:textoExtracto "cada uno controlado por un motor"@es .

ns1:Motor_AxisA2_1188 a ns1:ComponenteElectrico ;
    rdfs:label "Motor del eje Axis A2"@es ;
    ns1:textoExtracto "cada uno controlado por un motor"@es .

