@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:DispositivoESDescentralizado a owl:Class ;
    rdfs:label "Dispositivo E/S descentralizado"@es ;
    rdfs:comment "PHOENIX CONTACT"@es .

ex:TCouplerSlimLine a owl:Class ;
    rdfs:label "T-coupler SlimLine M12-male 5p./ 2x M12-female 4p"@es ;
    rdfs:comment "MURRELEKTRONIK"@es .

ex:PHOENIXCONTACT a owl:Class ;
    rdfs:label "PHOENIX CONTACT"@es .

ex:MURRELEKTRONIK a owl:Class ;
    rdfs:label "MURRELEKTRONIK"@es .