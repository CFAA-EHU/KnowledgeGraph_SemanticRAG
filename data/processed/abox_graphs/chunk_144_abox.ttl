ex:PHOENIXCONTACT a owl:Class ;
    rdfs:label "PHOENIX CONTACT" ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/>.

ex:MURRELEKTRONIK a owl:Class ;
