@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_SercosVelocidad a ns1:ModoOperacion ;
    rdfs:label "Modo Sercos velocidad" ;
    ns1:textoExtracto "el eje sólo podrá operar en modo Sercos velocidad"@es .

ns1:Sistema_ReguladorEje a ns1:Sistema ;
    rdfs:label "Regulador del eje" ;
    ns1:controla ns1:Parametro_VelocidadEje ;
    ns1:textoExtracto "el regulador desconoce que hay una búsqueda de referencia en marcha"@es .

ns1:TareaMantenimiento_BusquedaReferencia a ns1:TareaMantenimiento ;
    rdfs:label "Búsqueda de referencia del eje" ;
    ns1:requiereMantenimiento ns1:Sensor_CaptacionExterna ;
    ns1:textoExtracto "el CNC ejecuta la búsqueda de referencia como si el eje fuera analógico"@es .

ns1:Sensor_CaptacionExterna a ns1:Sensor ;
    rdfs:label "Captación externa (directa) del eje" ;
    ns1:monitoreaParametro ns1:Parametro_VelocidadEje ;
    ns1:textoExtracto "Si la captación externa (captación directa) del eje está conectada..."@es .

ns1:Parametro_VelocidadEje a ns1:Parametro ;
    rdfs:label "Velocidad del eje" ;
    ns1:textoExtracto "modo Sercos velocidad"@es .

