@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaGestionMultieje_1191 a ns1:Sistema ;
    rdfs:label "Sistema de gestión multieje CNC" ;
    ns1:controla ns1:EjeGrupo_1191,
        ns1:EjeMaestro_1191 ;
    ns1:textoExtracto "Si la captación externa es local o remota, el CNC ejecuta la búsqueda de referencia como si el eje fuera analógico; el regulador desconoce que hay una búsqueda de referencia en marcha y no actualiza su cota, sólo recibe consigna de velocidad. [...] Para un multieje donde el mismo motor controla varios ejes, el CNC permite realizar una gestión dinámica del multieje."@es ;
    ns1:tieneComponente ns1:CNC_1191,
        ns1:MotorMultieje_1191,
        ns1:PLC_1191,
        ns1:ReguladorMultieje_1191 .

ns1:CNC_1191 a ns1:Sistema ;
    rdfs:label "CNC (Control Numérico Computarizado)" ;
    ns1:monitoreaParametro ns1:ParametroDEFAULTSET_1191,
        ns1:ParametroDWELL_1191,
        ns1:ParametroMULAXISNAME_1_1191 ;
    ns1:textoExtracto "el CNC ejecuta la búsqueda de referencia como si el eje fuera analógico [...] el CNC permite realizar una gestión dinámica del multieje. [...] El CNC mantiene la vigilancia (error de seguimiento, test de tendencia, etc) de todos los ejes que comparten el regulador."@es .

ns1:MotorMultieje_1191 a ns1:ComponenteElectrico ;
    rdfs:label "Motor de multieje" ;
    ns1:alimenta ns1:EjeGrupo_1191 ;
    ns1:textoExtracto "Para un multieje donde el mismo motor controla varios ejes, el CNC permite realizar una gestión dinámica del multieje."@es .

ns1:PLC_1191 a ns1:InterfazUsuario ;
    rdfs:label "PLC (Controlador Lógico Programable)" ;
    ns1:controla ns1:ParametroENABLE_1191,
        ns1:ParametroSWITCH_1191 ;
    ns1:textoExtracto "La selección del eje que gobierna el regulador se realiza desde el PLC (marca SWITCH(axis)). [...] El PLC debe aparcar o poner como visualizador los ejes que no gobierna el regulador. [...] El PLC vigila qué marca ENABLE se activa, para engranar ese eje y activar su marca SWITCH, SERVOON, SPENA y DRENA."@es .

ns1:ParametroDEFAULTSET_1191 a ns1:Parametro ;
    rdfs:label "Parámetro DEFAULTSET" ;
    ns1:identificador "DEFAULTSET" ;
    ns1:textoExtracto "El CNC asume el set por defecto del eje (parámetro DEFAULTSET)."@es .

ns1:ParametroDWELL_1191 a ns1:Parametro ;
    rdfs:label "Parámetro DWELL" ;
    ns1:identificador "DWELL" ;
    ns1:textoExtracto "Los ejes utilizan el parámetro DWELL como tiempo de espera antes de dar error por no tener la marca SWITCH activa."@es ;
    ns1:valor ">0" .

ns1:ParametroENABLE_1191 a ns1:Parametro ;
    rdfs:label "Parámetro ENABLE" ;
    ns1:identificador "ENABLE" ;
    ns1:textoExtracto "El PLC vigila qué marca ENABLE se activa, para engranar ese eje y activar su marca SWITCH, SERVOON, SPENA y DRENA."@es .

ns1:ParametroMULAXISNAME_1_1191 a ns1:Parametro ;
    rdfs:label "Parámetro MULAXISNAME_1" ;
    ns1:identificador "MULAXISNAME_1" ;
    ns1:textoExtracto "el primer eje definido en el grupo (parámetro MULAXISNAME_1)."@es .

ns1:ReguladorMultieje_1191 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador de multieje" ;
    ns1:controla ns1:EjeMaestro_1191 ;
    ns1:monitoreaParametro ns1:ParametroSWITCH_1191 ;
    ns1:textoExtracto "el regulador desconoce que hay una búsqueda de referencia en marcha y no actualiza su cota, sólo recibe consigna de velocidad. [...] Tras el encendido, el regulador controla el eje maestro del grupo."@es .

ns1:EjeGrupo_1191 a ns1:ComponenteMecanico ;
    rdfs:label "Ejes del grupo multieje" ;
    ns1:textoExtracto "Para un multieje donde el mismo motor controla varios ejes [...] Los ejes utilizan el parámetro DWELL como tiempo de espera antes de dar error por no tener la marca SWITCH activa."@es .

ns1:EjeMaestro_1191 a ns1:ComponenteMecanico ;
    rdfs:label "Eje maestro del grupo multieje" ;
    ns1:identificador "MULAXISNAME_1" ;
    ns1:textoExtracto "Tras el encendido, el regulador controla el eje maestro del grupo, el primer eje definido en el grupo (parámetro MULAXISNAME_1)."@es .

ns1:ParametroSWITCH_1191 a ns1:Parametro ;
    rdfs:label "Parámetro SWITCH" ;
    ns1:identificador "SWITCH" ;
    ns1:textoExtracto "La selección del eje que gobierna el regulador se realiza desde el PLC (marca SWITCH(axis)). [...] El PLC vigila qué marca ENABLE se activa, para engranar ese eje y activar su marca SWITCH."@es .

