@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:controla ns1:Regulador_Sercos ;
    ns1:textoExtracto "cuando el PLC conmuta un eje y/o cabezal en el regulador" .

ns1:Parametro_DEFAULTSET a ns1:Parametro ;
    rdfs:label "Parámetro DEFAULTSET" ;
    ns1:identificador "DEFAULTSET" ;
    ns1:textoExtracto "El CNC asume el set por defecto del eje (parámetro DEFAULTSET)." .

ns1:Regulador_Sercos a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos" ;
    ns1:controla ns1:Sistema_CNC ;
    ns1:textoExtracto "Homogeneización de parámetros entre el CNC y el regulador Sercos." .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:monitoreaParametro ns1:Parametro_DEFAULTSET ;
    ns1:textoExtracto "El CNC asume el set por defecto del eje (parámetro DEFAULTSET)." .

