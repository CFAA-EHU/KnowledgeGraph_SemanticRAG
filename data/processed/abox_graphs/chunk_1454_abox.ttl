@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_Multieje a ns1:ModoOperacion ;
    rdfs:label "Operación multieje" ;
    ns1:textoExtracto "En un grupo multieje, el CNC homogeneiza el regulador con los parámetros generales y los parámetros del primer set del eje maestro." ;
    ns1:tieneComponente ns1:ComponenteElectrico_MotorMultieje,
        ns1:ComponenteElectrico_ReguladorSercos .

ns1:Sistema_HomogeneizacionCNC_Regulador a ns1:Sistema ;
    rdfs:label "Homogeneización de parámetros entre CNC y regulador Sercos" ;
    ns1:compuestoPor ns1:Parametro_DEFAULTSET,
        ns1:Parametro_GamasEjeMaestro,
        ns1:Parametro_GeneralesEjeMaestro,
        ns1:Parametro_PrimerSetEjeMaestro ;
    ns1:textoExtracto "Homogeneización de parámetros entre el CNC y el regulador Sercos. En un grupo multieje, el CNC homogeneiza el regulador con los parámetros generales y los parámetros del primer set del eje maestro." .

ns1:ComponenteElectrico_MotorMultieje a ns1:ComponenteElectrico ;
    rdfs:label "Motor de grupo multieje" ;
    ns1:controla ns1:ComponenteElectrico_ReguladorSercos ;
    ns1:textoExtracto "motor controlando dos ejes" .

ns1:ComponenteElectrico_ReguladorSercos a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos" ;
    ns1:monitoreaParametro ns1:Parametro_DEFAULTSET,
        ns1:Parametro_GamasEjeMaestro,
        ns1:Parametro_GeneralesEjeMaestro,
        ns1:Parametro_PrimerSetEjeMaestro ;
    ns1:textoExtracto "regulador Sercos" .

ns1:Parametro_DEFAULTSET a ns1:Parametro ;
    rdfs:label "DEFAULTSET" ;
    ns1:identificador "DEFAULTSET" ;
    ns1:textoExtracto "parámetro DEFAULTSET" .

ns1:Parametro_GamasEjeMaestro a ns1:Parametro ;
    rdfs:label "Parámetros de las gamas del eje maestro" ;
    ns1:textoExtracto "los parámetros de las gamas del eje maestro" .

ns1:Parametro_GeneralesEjeMaestro a ns1:Parametro ;
    rdfs:label "Parámetros generales del eje maestro" ;
    ns1:textoExtracto "los parámetros generales del eje maestro" .

ns1:Parametro_PrimerSetEjeMaestro a ns1:Parametro ;
    rdfs:label "Parámetros del primer set del eje maestro" ;
    ns1:textoExtracto "los parámetros del primer set del eje maestro" .

