@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_GROUP_n a ns1:Parametro ;
    rdfs:label "Grupo multieje n (GROUP_n)"@es ;
    ns1:documentadoEn ns1:TablaGruposMultieje ;
    ns1:identificador "GROUP_n" ;
    ns1:textoExtracto "La tabla muestra un parámetro GROUP_n por cada grupo multieje."@es .

ns1:Parametro_MULAXISNAME_n a ns1:Parametro ;
    rdfs:label "Nombre de eje/cabezal n (MULAXISNAME_n)"@es ;
    ns1:documentadoEn ns1:TablaGruposMultieje ;
    ns1:identificador "MULAXISNAME_n" ;
    ns1:textoExtracto "La tabla muestra un parámetro MULAXISNAME_n por cada eje o cabezal que forma parte del grupo multieje."@es .

ns1:Parametro_MULNGROUP a ns1:Parametro ;
    rdfs:label "Número de grupos multieje (MULNGROUP)"@es ;
    ns1:documentadoEn ns1:TablaGruposMultieje ;
    ns1:identificador "MULNGROUP" ;
    ns1:textoExtracto "El parámetro MULNGROUP establece el número de grupos multieje del sistema."@es .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC multieje"@es ;
    ns1:textoExtracto "Los grupos multieje se configuran desde los parámetros máquina. Cada grupo multieje dispone de parámetros generales para su configuración."@es ;
    ns1:tieneComponente ns1:ReguladorEjes .

ns1:Parametro_MULNAXIS a ns1:Parametro ;
    rdfs:label "Número de ejes/cabezales por grupo (MULNAXIS)"@es ;
    ns1:documentadoEn ns1:TablaGruposMultieje ;
    ns1:identificador "MULNAXIS" ;
    ns1:textoExtracto "El parámetro MULNAXIS establece el número de ejes y/o cabezales que forman el grupo multieje."@es .

ns1:ReguladorEjes a ns1:ComponenteElectrico ;
    rdfs:label "Regulador de sets de parámetros"@es ;
    ns1:monitoreaParametro ns1:Parametro_MULNAXIS ;
    ns1:textoExtracto "Los sets de parámetros del regulador estarán repartidos entre todos los ejes y/o cabezales que forman el grupo multieje, de manera que un grupo podrá estar formado por 8 ejes con 1 set de parámetros cada uno, con un cabezal con 4 sets más 2 ejes con 2 sets cada uno, etc."@es .

ns1:TablaGruposMultieje a ns1:Tabla ;
    rdfs:label "Tabla de grupos multieje (MULTIAXIS)"@es ;
    ns1:identificador "MULTIAXIS" ;
    ns1:textoExtracto "El parámetro MULTIAXIS muestra la tabla de definición de los grupos multieje, donde hay que definir el número de grupos del sistema y la composición de cada grupo."@es .

