@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:textoExtracto "el CNC utilizará los parámetros del eje maestro para realizar la homogeneización de parámetros con el regulador"@es ;
    ns1:tieneComponente ns1:EjeMaestro_GrupoMultieje,
        ns1:Regulador_GrupoMultieje .

ns1:EjeMaestro_GrupoMultieje a ns1:ComponenteMecanico ;
    rdfs:label "Eje maestro del grupo multieje"@es ;
    ns1:textoExtracto "El primer eje del grupo será el eje maestro, el que por defecto utilizará el regulador"@es ;
    ns1:tieneComponente ns1:Parametro_MUMLAXISNAME_n .

ns1:Regulador_GrupoMultieje a ns1:ComponenteElectrico ;
    rdfs:label "Regulador del grupo multieje"@es ;
    ns1:monitoreaParametro ns1:Parametro_MUMLAXISNAME_n ;
    ns1:textoExtracto "el regulador; el orden del resto de los ejes no es relevante. [...] Configurar el set del regulador a utilizar."@es .

ns1:Tabla_11_4_1_ParametrosGrupoMultieje a ns1:Tabla ;
    rdfs:label "Tabla de parámetros MUMLAXISNAME_n para configuración de grupo multieje"@es ;
    ns1:documentadoEn ns1:Pagina_586 ;
    ns1:textoExtracto "La tabla muestra un parámetro MUMLAXISNAME_n por cada eje o cabezal que forma parte del grupo multieje."@es .

ns1:Parametro_MUMLAXISNAME_n a ns1:Parametro ;
    rdfs:label "MUMLAXISNAME_n" ;
    ns1:documentadoEn ns1:Tabla_11_4_1_ParametrosGrupoMultieje ;
    ns1:identificador "MUMLAXISNAME_n" ;
    ns1:textoExtracto "parámetro MUMLAXISNAME_n por cada eje o cabezal que forma parte del grupo multieje"@es .

