@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CodigoCNC_G112 a ns1:AccionProhibida ;
    rdfs:label "G112 (cambio de set/gama en CNC)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosMultieje_1196 ;
    ns1:identificador "G112" ;
    ns1:textoExtracto "cambio de set o gama en el CNC (G112 y M41 a M44)"@es .

ns1:CodigoCNC_M41_M44 a ns1:ModoOperacion ;
    rdfs:label "M41-M44 (selección de gama/regulador)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosMultieje_1196 ;
    ns1:identificador "M41-M44" ;
    ns1:textoExtracto "M41 a M44"@es .

ns1:Sistema_HomogeneizacionParametros a ns1:Sistema ;
    rdfs:label "Homogeneización de parámetros en grupo multieje"@es ;
    ns1:controla ns1:Parametro_DRIVESET ;
    ns1:documentadoEn ns1:Tabla_ParametrosMultieje_1196 ;
    ns1:monitoreaParametro ns1:Parametro_ACFGAIN,
        ns1:Parametro_FFGAIN,
        ns1:Parametro_Kv ;
    ns1:textoExtracto """
Con la homogeneización activa, el CNC envía los parámetros del set ꞏ1ꞏ del eje maestro al set ꞏ0ꞏ y a la gama ꞏ1ꞏ (la primera) del regulador.
Para el resto de sets del eje maestro, el CNC sólo envía al regulador la información de la gama; el set ꞏ2ꞏ del CNC a la gama 2 del regulador, y así sucesivamente."""@es .

ns1:Parametro_ACFGAIN a ns1:Parametro ;
    rdfs:label "ACFGAIN (AC Forward)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosMultieje_1196 ;
    ns1:identificador "ACFGAIN" ;
    ns1:textoExtracto "AC forward (parámetro ACFGAIN)"@es .

ns1:Parametro_DRIVESET a ns1:Parametro ;
    rdfs:label "DRIVESET"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosMultieje_1196 ;
    ns1:identificador "DRIVESET" ;
    ns1:textoExtracto """
Set del regulador a utilizar.
En los ejes que pertenecen a un grupo multieje, el parámetro DRIVESET indica la gama a activar en el regulador tras un cambio de set o gama en el CNC (G112 y M41 a M44)."""@es ;
    ns1:valor "1..n (excluye 0 en grupos multieje)"@es .

ns1:Parametro_FFGAIN a ns1:Parametro ;
    rdfs:label "FFGAIN (Feed Forward)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosMultieje_1196 ;
    ns1:identificador "FFGAIN" ;
    ns1:textoExtracto "feed forward (parámetro FFGAIN)"@es .

ns1:Parametro_Kv a ns1:Parametro ;
    rdfs:label "Kv"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosMultieje_1196 ;
    ns1:identificador "Kv" ;
    ns1:textoExtracto "los cambios de Kv"@es .

ns1:Tabla_ParametrosMultieje_1196 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros para configuración multieje (DRIVESET)"@es ;
    ns1:documentadoEn ns1:Pagina_586 ;
    ns1:textoExtracto """
| Parámetro. | Significado. |
| --- | --- |
| DRIVESET | Set del regulador a utilizar. |
En los ejes que pertenecen a un grupo multieje, el parámetro DRIVESET indica la gama a activar en el regulador tras un cambio de set o gama en el CNC (G112 y M41 a M44)."""@es .

