@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_PP5 a ns1:Parametro ;
    rdfs:label "PP5" ;
    ns1:identificador "PP5" ;
    ns1:textoExtracto "parametrizar el parámetro PP5=-0,0001" ;
    ns1:valor "-0,0001" .

ns1:Sistema_EntradasCaptacion a ns1:Sistema ;
    rdfs:label "Sistema de entradas de captación" ;
    ns1:detalladoEnEsquema ns1:Tabla_ParametrosCaptacionEje ;
    ns1:textoExtracto "La captación interna (motor) de ambos ejes está ubicada en el regulador. [...] entradas de captación locales de la unidad central." ;
    ns1:tieneComponente ns1:ComponenteElectrico_EntradaCaptacionExterna,
        ns1:ComponenteElectrico_EntradaCaptacionInterna,
        ns1:ComponenteElectrico_EntradaCaptacionLocal,
        ns1:ComponenteElectrico_ModuloRemoto .

ns1:ComponenteElectrico_EntradaCaptacionExterna a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de captación externa (directa)" ;
    ns1:monitoreaParametro ns1:Parametro_COUNTERID ;
    ns1:textoExtracto "entrada para la captación externa (directa) del eje; en los módulos remotos (4 entradas por módulo, TTL diferencial y senoidal 1 Vpp), en la captación libre de un regulador Sercos o en las entradas de captación locales de la unidad central." .

ns1:ComponenteElectrico_EntradaCaptacionInterna a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de captación interna (motor)" ;
    ns1:monitoreaParametro ns1:Parametro_COUNTERTYPE ;
    ns1:textoExtracto "La captación interna (motor) de ambos ejes está ubicada en el regulador." .

ns1:ComponenteElectrico_EntradaCaptacionLocal a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de captación local (unidad central)" ;
    ns1:textoExtracto "entradas de captación locales de la unidad central" .

ns1:ComponenteElectrico_ModuloRemoto a ns1:ComponenteElectrico ;
    rdfs:label "Módulo remoto de entradas de captación" ;
    ns1:identificador "4_entradas_por_módulo" ;
    ns1:textoExtracto "módulos remotos (4 entradas por módulo, TTL diferencial y senoidal 1 Vpp)" .

ns1:Parametro_COUNTERID a ns1:Parametro ;
    rdfs:label "COUNTERID" ;
    ns1:identificador "COUNTERID" ;
    ns1:textoExtracto "Número de la entrada de captación del eje." .

ns1:Parametro_COUNTERTYPE a ns1:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ns1:identificador "COUNTERTYPE" ;
    ns1:textoExtracto "Tipo de entrada de captación del eje; regulador, local o remota." ;
    ns1:valor "Regulador" .

ns1:Tabla_ParametrosCaptacionEje a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de captación del eje" ;
    ns1:documentadoEn ns1:Pagina_586 ;
    ns1:textoExtracto "| Parámetro. | Significado. | --- | --- | COUNTERTYPE | Tipo de entrada de captación del eje; regulador, local o remota. | COUNTERID | Número de la entrada de captación del eje." .

