@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix admin: <https://admin-shell.io/dictionary/> .
@prefix base: <https://vocab.cfaa.eus/broaching/base#> .
@prefix mecanica: <https://vocab.cfaa.eus/broaching/mecanica#> .
@prefix elec: <https://vocab.cfaa.eus/broaching/elec#> .

# Clases
ex:AcopladorDelBus a owl:Class ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Connector> ;
    rdfs:label "Acoplador del bus"@es .

ex:IndustrialWiFiRouter a owl:Class ;
    rdfs:label "Industrial WiFi Router"@es .

ex:LlaveDeBola a owl:Class ;
    rdfs:label "Llave de bola"@es .

ex:DepositoAluminio a owl:Class ;
    rdfs:label "Deposito de aluminio"@es .

ex:PieParaDeposito a owl:Class ;
    rdfs:label "Pie para deposito"@es .

ex:Tapa a owl:Class ;
    rdfs:label "Tapa"@es .

ex:IndicadorDeNivelConTermometro a owl:Class ;
    rdfs:label "Indicador de nivel con termometro"@es .

ex:TaponDeAireacionYLlenado a owl:Class ;
    rdfs:label "Tapon de aireacion y llenado"@es .

ex:SensorDeNivel a owl:Class ;
    rdfs:isDefinedBy admin:Sensor ;
    rdfs:label "Sensor de nivel"@es .

ex:AdaptadorNivelesRegulables a owl:Class ;
    rdfs:label "Adaptador niveles regulables"@es .

ex:BombaDePistones a owl:Class ;
    rdfs:label "Bomba de pistones"@es .

ex:BombaCaudalVariable a owl:Class ;
    rdfs:label "Bomba caudal variable"@es .

ex:AdaptadorBocas a owl:Class ;
    rdfs:label "Adaptador bocas"@es .

ex:FuelleMFB a owl:Class ;
    rdfs:label "Fuelle MFB"@es .

ex:Soporte a owl:Class ;
    rdfs:label "Soporte"@es .

ex:SemiacoplamientoSpidexAlu a owl:Class ;
    rdfs:label "Semiacoplamiento Spidex Alu"@es .

ex:CoronaSpidex a owl:Class ;
    rdfs:label "Corona Spidex"@es .

ex:BancadaMotor a owl:Class ;
    rdfs:label "Bancada motor"@es .

ex:TacoSoporte a owl:Class ;
    rdfs:label "Taco soporte"@es .

ex:DinaflexCilindrico a owl:Class ;
    rdfs:label "Dinaflex cilindrico"@es .

# Propiedades de objeto
mecanica:tieneFabricante a owl:ObjectProperty .
mecanica:tieneDesignacion a owl:ObjectProperty .
mecanica:tieneCantidad a owl:ObjectProperty .

# Propiedades de datos
base:tieneModelo a owl:DatatypeProperty .
base:tieneCantidad a owl:DatatypeProperty .
base:tieneFabricante a owl:DatatypeProperty .
base:tieneDesignacion a owl:DatatypeProperty .