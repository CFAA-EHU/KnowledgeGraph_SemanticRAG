@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaMultieje_CNC a ns1:Sistema ;
    rdfs:label "Sistema de configuración multieje (CNC)"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_ConfiguracionCaptacion ;
    ns1:monitoreaParametro ns1:Parametro_EntradaCaptacionEje ;
    ns1:textoExtracto "Configuración de un grupo multieje. Los parámetros máquina [...] Cuando dos ejes no vayan a estar de forma simultánea en la configuración, el CNC permite que ambos ejes utilicen la misma entrada de captación."@es ;
    ns1:tieneComponente ns1:ModuloContadoras_CANfagor,
        ns1:Regulador_Sercos,
        ns1:UnidadCentral_CNC .

ns1:ModuloContadoras_CANfagor a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de contadoras en módulos remotos CANfagor"@es ;
    ns1:identificador "CANfagor (grupos remotos)"@es ;
    ns1:textoExtracto "Para la entrada de captación se utiliza un módulo de contadoras en los módulos remotos. [...] Los módulos de las contadoras se numeran según el orden lógico de los grupos remotos."@es .

ns1:Parametro_EntradaCaptacionEje a ns1:Parametro ;
    rdfs:label "Número de la entrada de captación del eje"@es ;
    ns1:textoExtracto "Número de la entrada de captación del eje. Dependiendo del tipo de captación, este parámetro indicará cuál es la entrada de captación a utilizar (si la captación es local o remota) o el número de regulador."@es ;
    ns1:valor "1-32 (dirección lógica)"@es .

ns1:Regulador_Sercos a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos"@es ;
    ns1:identificador "Sercos (dirección 1-32)"@es ;
    ns1:textoExtracto "Entrada de captación en los reguladores Sercos. [...] El parámetro indica la dirección lógica del regulador (de 1 a 32)."@es .

ns1:Tabla_ConfiguracionCaptacion a ns1:Tabla ;
    rdfs:label "Tabla: Configuración de entrada de captación por tipo"@es ;
    ns1:documentadoEn ns1:Manual ;
    ns1:ilustradoEn ns1:Pagina_586_588 ;
    ns1:textoExtracto "Tipo de captación | Número de la entrada de captación del eje"@es .

ns1:UnidadCentral_CNC a ns1:ComponenteElectrico ;
    rdfs:label "Unidad central (CNC)"@es ;
    ns1:textoExtracto "La unidad central dispone de dos entradas de captación. Este parámetro indica la entrada de captación que se utiliza."@es .

