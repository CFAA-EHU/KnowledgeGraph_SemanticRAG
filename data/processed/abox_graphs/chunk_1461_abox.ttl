@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:PLC_1200 a ns1:Sistema ;
    ns1:textoExtracto "Los grupos multieje se gestionan desde el PLC, para lo cual dispone de la siguiente marca." ;
    ns1:tieneComponente ns1:GV21_1200,
        ns1:GV25_1200,
        ns1:SERPLCAC_1200,
        ns1:SWITCH_axis_1200,
        ns1:regulador_1200 .

ns1:GV21_1200 a ns1:Parametro ;
    ns1:identificador "GV21" ;
    ns1:textoExtracto "parámetros GV21 y GV25 del regulador" .

ns1:GV25_1200 a ns1:Parametro ;
    ns1:identificador "GV25" ;
    ns1:textoExtracto "parámetros GV21 y GV25 del regulador" .

ns1:SERPLCAC_1200 a ns1:Sensor ;
    ns1:identificador "SERPLCAC" ;
    ns1:textoExtracto "Verificar que el cambio de set y/o gama ha terminado (marca SERPLCAC)" .

ns1:SWITCH_axis_1200 a ns1:Sensor ;
    ns1:identificador "SWITCH(axis)" ;
    ns1:textoExtracto "SWITCH(axis) | El PLC activa esta marca para indicar al CNC cuál es el eje o cabezal que debe gobernar." .

ns1:regulador_1200 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "el regulador tras el encendido, ... escribir los parámetros en el regulador ... cambiar el set y/o la gama en el regulador ... verificar ... los parámetros del regulador" .

