@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "Ejes y cabezales incluidos en un grupo multieje. [...] Cabezal y eje C." ;
    ns1:tieneFrecuencia ns1:Frecuencia_Multieje .

ns1:Componente_EjeC a ns1:ComponenteMecanico ;
    rdfs:label "Eje C" ;
    ns1:textoExtracto "Cabezal y eje C. [...] El CNC recupera el set que se encontraba activo antes de habilitar el cabezal como eje C." ;
    ns1:tieneFrecuencia ns1:Frecuencia_Multieje .

ns1:Funcion_A_SETGE_xn a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "(V.)A.SETGE.xn" ;
    ns1:controla ns1:Parametro_Gama,
        ns1:Parametro_Set ;
    ns1:habilitadoPor ns1:Regulador_CNC ;
    ns1:identificador "A.SETGE.xn" ;
    ns1:textoExtracto "El regulador activa el set y/o la gama programada." .

ns1:Funcion_G112 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G112 (solo ejes)" ;
    ns1:controla ns1:Parametro_Set ;
    ns1:habilitadoPor ns1:Sistema_CNC ;
    ns1:identificador "G112" ;
    ns1:textoExtracto "El CNC activa el set programado. [...] El regulador activa la gama definida en el parámetro DRIVESET del set programado." .

ns1:Funcion_M41_M44 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "M41-M44 (solo cabezales)" ;
    ns1:controla ns1:Parametro_Set ;
    ns1:habilitadoPor ns1:Sistema_CNC ;
    ns1:identificador "M41-M44" ;
    ns1:textoExtracto "El CNC activa el set programado. [...] El regulador activa la gama definida en el parámetro DRIVESET del set programado." .

ns1:Parametro_CAXSET a ns1:Parametro ;
    rdfs:label "CAXSET" ;
    ns1:monitoreaParametro ns1:Regulador_CNC ;
    ns1:textoExtracto "El CNC activa el set definido en el parámetro CAXSET. [...] El regulador activa la gama definida en el parámetro CAXSET." .

ns1:Parametro_DRIVESET a ns1:Parametro ;
    rdfs:label "DRIVESET" ;
    ns1:monitoreaParametro ns1:Regulador_CNC ;
    ns1:textoExtracto "El regulador activa la gama definida en el parámetro DRIVESET del set programado." .

ns1:Frecuencia_Multieje a ns1:Frecuencia ;
    rdfs:label "Configuración multieje" ;
    ns1:textoExtracto "Ejes y cabezales incluidos en un grupo multieje. [...] Si el eje o cabezal no forma parte de un grupo multieje, las funciones G112 y M41 a M44 actúan igual en el CNC pero en el regulador activan la gama programada, no la definida en el parámetro DRIVESET." .

ns1:Funcion_CAX_OFF a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "#CAX OFF" ;
    ns1:controla ns1:Parametro_Gama,
        ns1:Parametro_Set ;
    ns1:habilitadoPor ns1:Regulador_CNC,
        ns1:Sistema_CNC ;
    ns1:identificador "CAX_OFF" ;
    ns1:textoExtracto "El CNC recupera el set que se encontraba activo antes de habilitar el cabezal como eje C. [...] El regulador recupera la gama que se encontraba activa antes de habilitar el cabezal como eje C." .

ns1:Funcion_CAX_ON a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "#CAX ON" ;
    ns1:controla ns1:Parametro_Gama,
        ns1:Parametro_Set ;
    ns1:habilitadoPor ns1:Regulador_CNC,
        ns1:Sistema_CNC ;
    ns1:identificador "CAX_ON" ;
    ns1:textoExtracto "El CNC activa el set definido en el parámetro CAXSET. [...] El regulador activa la gama definida en el parámetro CAXSET." .

ns1:Parametro_Gama a ns1:Parametro ;
    rdfs:label "Gama" ;
    ns1:monitoreaParametro ns1:Regulador_CNC ;
    ns1:textoExtracto "Los parámetros que definen la gama están incluidos en el set, una gama por cada set. [...] Un cambio de gama sólo activa los parámetros específicos de la reducción." .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "CNC" ;
    ns1:controla ns1:Funcion_CAX_OFF,
        ns1:Funcion_CAX_ON,
        ns1:Funcion_G112,
        ns1:Funcion_M41_M44 ;
    ns1:textoExtracto "El CNC activa el set programado. [...] El CNC recupera el set que se encontraba activo antes de habilitar el cabezal como eje C." ;
    ns1:tieneComponente ns1:Componente_Cabezal,
        ns1:Componente_EjeC .

ns1:Parametro_Set a ns1:Parametro ;
    rdfs:label "Set" ;
    ns1:monitoreaParametro ns1:Regulador_CNC ;
    ns1:textoExtracto "Entendemos por set a un conjunto de parámetros susceptibles de ser activados [...] Un cambio de set activa todos los parámetros del mismo, incluidos los de la gama." .

ns1:Regulador_CNC a ns1:Sistema ;
    rdfs:label "Regulador" ;
    ns1:controla ns1:Funcion_A_SETGE_xn,
        ns1:Funcion_CAX_OFF,
        ns1:Funcion_CAX_ON ;
    ns1:monitoreaParametro ns1:Parametro_CAXSET,
        ns1:Parametro_DRIVESET,
        ns1:Parametro_Gama,
        ns1:Parametro_Set ;
    ns1:textoExtracto "El regulador activa la gama definida en el parámetro DRIVESET del set programado. [...] El regulador recupera la gama que se encontraba activa antes de habilitar el cabezal como eje C." .

