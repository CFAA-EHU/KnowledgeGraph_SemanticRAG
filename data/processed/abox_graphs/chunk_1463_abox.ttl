@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaMultieje_Ejemplo1 a ns1:Sistema ;
    rdfs:label "Sistema con dos ejes (Ejemplo 1)" ;
    ns1:compuestoPor ns1:EjeA1,
        ns1:EjeA2 ;
    ns1:detalladoEnEsquema ns1:EsquemaConfiguracion_Ejemplo1 ;
    ns1:textoExtracto "Ejemplo 1. Sistema con dos ejes, cada uno con su motor. El sistema tiene las siguientes características. • Un único regulador controla dos ejes, cada uno con su motor. • Cada eje utiliza un tipo de captación diferente." ;
    ns1:tieneComponente ns1:EjeA1,
        ns1:EjeA2,
        ns1:ReguladorMultieje_Ejemplo1 .

ns1:CaptacionRemota_A2 a ns1:ComponenteElectrico ;
    rdfs:label "Captación remota del Eje A2" ;
    ns1:textoExtracto "La captación externa (directa) está conectada a los módulos remotos." .

ns1:ReguladorMultieje_Ejemplo1 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador multieje" ;
    ns1:controla ns1:EjeA1,
        ns1:EjeA2 ;
    ns1:ilustradoEn ns1:EsquemaConfiguracion_Ejemplo1 ;
    ns1:textoExtracto "Un único regulador controla dos ejes, cada uno con su motor." .

ns1:CaptacionDirecta_A1 a ns1:ComponenteElectrico ;
    rdfs:label "Captación directa del Eje A1" ;
    ns1:textoExtracto "La captación externa (directa) está conectada al propio regulador." .

ns1:EsquemaConfiguracion_Ejemplo1 a ns1:Esquema ;
    rdfs:label "Esquema de configuración del sistema multieje (Ejemplo 1)" ;
    ns1:ilustradoEn ns1:Pagina_591 ;
    ns1:textoExtracto "Direct Feedback E L UD O M EV Axis A1 I RD Motor Feedback Feedback POWER SUPPLY COUNTER DIGITAL INPUT..." .

ns1:MotorA1 a ns1:ComponenteElectrico ;
    rdfs:label "Motor del Eje A1" ;
    ns1:controla ns1:CaptacionDirecta_A1 ;
    ns1:textoExtracto "cada uno con su motor" .

ns1:MotorA2 a ns1:ComponenteElectrico ;
    rdfs:label "Motor del Eje A2" ;
    ns1:textoExtracto "cada uno con su motor" .

ns1:TablaConfiguracionMultieje_Ejemplo1 a ns1:Tabla ;
    rdfs:label "Configuración del grupo multieje (Ejemplo 1)" ;
    ns1:documentadoEn ns1:Pagina_592 ;
    ns1:textoExtracto "| MULTIAXIS | GROUP_1 | --- | --- | MULNGROUP = 1 | MULNAXIS = 2 | MULAXISNAME_1 = A1 | MULAXISNAME_2 = A2 |" .

ns1:EjeA1 a ns1:ComponenteMecanico ;
    rdfs:label "Eje A1" ;
    ns1:compuestoPor ns1:MotorA1 ;
    ns1:documentadoEn ns1:TablaConfiguracionMultieje_Ejemplo1 ;
    ns1:identificador "A1" ;
    ns1:textoExtracto "Eje A1. La captación externa (directa) está conectada al propio regulador." ;
    ns1:tieneComponente ns1:CaptacionDirecta_A1,
        ns1:MotorA1 .

ns1:EjeA2 a ns1:ComponenteMecanico ;
    rdfs:label "Eje A2" ;
    ns1:compuestoPor ns1:MotorA2 ;
    ns1:documentadoEn ns1:TablaConfiguracionMultieje_Ejemplo1 ;
    ns1:identificador "A2" ;
    ns1:textoExtracto "Eje A2. La captación externa (directa) está conectada a los módulos remotos." ;
    ns1:tieneComponente ns1:CaptacionRemota_A2,
        ns1:MotorA2 .

