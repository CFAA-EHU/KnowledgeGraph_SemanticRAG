@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_ConfiguracionEjes_1204 a ns1:Tabla ;
    rdfs:label "Tabla de configuración de ejes (A1, A2)"@es ;
    ns1:documentadoEn ns1:ConfiguracionMultiEje_1204 ;
    ns1:textoExtracto """
    | DRIVEID | OPMODEP | FBACKSRC    | COUNTERTYPE | COUNTERID |
    |---------|---------|-------------|-------------|-----------|
    | Eje A1  | 1       | Velocidad   | Externa Remoto | 1         |
    | Eje A2  | 1       | Velocidad   | Externa Remoto | 2         |
    """@es .

ns1:ConfiguracionMultiEje_1204 a ns1:Sistema ;
    rdfs:label "Configuración del grupo multieje (GROUP_1)"@es ;
    ns1:identificador "GROUP_1" ;
    ns1:textoExtracto """
    Configuración del grupo multieje. | MULTIAXIS | GROUP_1 |
    MULNGROUP = 1
    """@es ;
    ns1:tieneComponente ns1:Eje_A1,
        ns1:Eje_A2 .

ns1:Parametro_Velocidad_A1 a ns1:Parametro ;
    rdfs:label "Velocidad (Eje A1)"@es ;
    ns1:monitoreaParametro ns1:Eje_A1 ;
    ns1:textoExtracto "OPMODEP: Velocidad"@es ;
    ns1:valor "Velocidad"@es .

ns1:Parametro_Velocidad_A2 a ns1:Parametro ;
    rdfs:label "Velocidad (Eje A2)"@es ;
    ns1:monitoreaParametro ns1:Eje_A2 ;
    ns1:textoExtracto "OPMODEP: Velocidad"@es ;
    ns1:valor "Velocidad"@es .

ns1:Eje_A1 a ns1:ComponenteMecanico ;
    rdfs:label "Eje A1"@es ;
    ns1:identificador "A1" ;
    ns1:monitoreaParametro ns1:Parametro_Velocidad_A1 ;
    ns1:textoExtracto """
    Eje A1 | DRIVEID: 1 | OPMODEP: Velocidad | FBACKSRC: Externa Remoto | COUNTERID: 1
    """@es .

ns1:Eje_A2 a ns1:ComponenteMecanico ;
    rdfs:label "Eje A2"@es ;
    ns1:identificador "A2" ;
    ns1:monitoreaParametro ns1:Parametro_Velocidad_A2 ;
    ns1:textoExtracto """
    Eje A2 | DRIVEID: 1 | OPMODEP: Velocidad | FBACKSRC: Externa Remoto | COUNTERID: 2
    """@es .

