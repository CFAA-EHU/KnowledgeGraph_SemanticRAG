@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BusquedaReferenciaM_quina_1205 a ns1:TareaMantenimiento ;
    rdfs:label "Búsqueda de referencia máquina"@es ;
    ns1:ejecutadoPor ns1:ModoManual_1205 ;
    ns1:identificador "G74" ;
    ns1:requiereMantenimiento ns1:SistemaCNC_1205 ;
    ns1:textoExtracto "La búsqueda de referencia es la operación mediante la cual se realiza la sincronización del sistema. Esta operación es necesaria cuando el CNC pierde la posición del origen (por ejemplo, apagando la máquina)."@es .

ns1:ModoMDI_1205 a ns1:ModoOperacion ;
    rdfs:label "Modo MDI"@es ;
    ns1:textoExtracto "Búsqueda de referencia por programa o MDI"@es .

ns1:SubrutinaG74_1205 a ns1:Parametro ;
    rdfs:label "Subrutina G74"@es ;
    ns1:identificador "G74" ;
    ns1:textoExtracto "subrutina de búsqueda de referencia asociada a la función G74"@es ;
    ns1:tieneFrecuencia ns1:FrecuenciaReferencia_1205 .

ns1:FrecuenciaReferencia_1205 a ns1:Frecuencia ;
    rdfs:label "Frecuencia de referencia automática"@es ;
    ns1:textoExtracto "Todos los ejes se referencian a la vez"@es .

ns1:ModoManual_1205 a ns1:ModoOperacion ;
    rdfs:label "Modo manual"@es ;
    ns1:textoExtracto "Búsqueda de referencia manual, desde el modo manual... Búsqueda de referencia automática, desde el modo manual"@es .

ns1:ParametroREFPSUB_1205 a ns1:Parametro ;
    rdfs:label "Parámetro REFPSUB"@es ;
    ns1:identificador "REFPSUB" ;
    ns1:textoExtracto "disponible cuando está definida la subrutina de búsqueda de referencia asociada a la función G74 (parámetro REFPSUB)"@es .

ns1:SistemaCNC_1205 a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:monitoreaParametro ns1:ParametroREFPSUB_1205 ;
    ns1:textoExtracto "sincronización del sistema... cuando el CNC pierde la posición del origen"@es .

