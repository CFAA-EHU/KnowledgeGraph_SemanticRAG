@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:OperacionBusquedaReferencia_1206 a ns1:ModoOperacion ;
    rdfs:label "Búsqueda de referencia máquina"@es ;
    ns1:controla ns1:SistemaReferenciaMaquina_1206 ;
    ns1:textoExtracto "Para realizar la operación de búsqueda de referencia máquina, el fabricante de la máquina tiene definidos dos puntos especiales en la máquina; cero máquina y punto de referencia máquina."@es .

ns1:SistemaCodificado_1206 a ns1:Sistema ;
    rdfs:label "Sistema de codificación absoluta (I0 codificados)"@es ;
    ns1:textoExtracto "Si el sistema dispone de I0 codificados o captación absoluta, los ejes sólo se desplazarán lo necesario para verificar su posición."@es .

ns1:CeroMaquina_1206 a ns1:Parametro ;
    rdfs:label "Cero máquina"@es ;
    ns1:textoExtracto "El cero máquina es el origen del sistema de referencia de la máquina, fijado por el fabricante de la máquina."@es ;
    ns1:valor "Origen del sistema de referencia"@es .

ns1:PuntoReferenciaMaquina_1206 a ns1:Parametro ;
    rdfs:label "Punto de referencia máquina"@es ;
    ns1:textoExtracto "El punto de referencia máquina es un punto de la máquina fijado por el fabricante y referenciado respecto al cero máquina. Este punto puede estar situado en cualquier parte de la máquina."@es .

ns1:SistemaReferenciaMaquina_1206 a ns1:Sistema ;
    rdfs:label "Sistema de referencia de máquina"@es ;
    ns1:textoExtracto "Sistema de referencia y el punto de referencia máquina. [...] El cero máquina es el origen del sistema de referencia de la máquina, fijado por el fabricante de la máquina."@es ;
    ns1:tieneComponente ns1:CeroMaquina_1206,
        ns1:PuntoReferenciaMaquina_1206 .

