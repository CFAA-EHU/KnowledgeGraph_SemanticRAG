@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PuntoReferenciaMaquina_1207 a ns1:Parametro ;
    rdfs:label "Punto de referencia de máquina"@es ;
    ns1:identificador "REFVALUE" ;
    ns1:monitoreaParametro ns1:PosicionEje_1207 ;
    ns1:textoExtracto "Este punto puede estar situado en cualquier parte de la máquina. La posición del punto de referencia, para cada eje, se parametriza en el parámetro REFVALUE."@es .

ns1:PosicionEje_1207 a ns1:Parametro ;
    rdfs:label "Posición por eje (X, Z, W, M, H, O)"@es ;
    ns1:textoExtracto "Z H Z MH Z MW O O M X W X MW X MH"@es .

