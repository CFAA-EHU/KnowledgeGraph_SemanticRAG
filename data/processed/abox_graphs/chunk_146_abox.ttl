@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix mec: <https://vocab.cfaa.eus/broaching/mecanica/> .
@prefix elec: <https://vocab.cfaa.eus/broaching/elec/> .
@prefix hid: <https://vocab.cfaa.eus/broaching/hidraulico/> .
@prefix base: <https://vocab.cfaa.eus/broaching/base/> .

ex:TacoSoporteM10 a owl:Class ;
    rdfs:label "Taco Soporte M10" ;
    rdfs:comment "40X26; S/PLANO" .

ex:DinaflexCilindrico a owl:Class ;
    rdfs:label "Dinaflex Cilindrico" ;
    rdfs:comment "REF.104/40; MACHO" .

ex:MangueraDN10 a owl:Class ;
    rdfs:label "Manguera DN10" ;
    rdfs:comment "492-6" .

ex:Terminal a owl:Class ;
    rdfs:label "Terminal" ;
    rdfs:comment "1CF46-12-6" .

ex:Antirretorno a owl:Class ;
    rdfs:label "Antirretorno" ;
    rdfs:comment "RHD12LOMDCF" .

ex:Racor a owl:Class ;
    rdfs:label "Racor" ;
    rdfs:comment "EW12LOMDCF CUERPO" .

ex:TomaPresion a owl:Class ;
    rdfs:label "Toma Presion" ;
    rdfs:comment "1/8\"G" .

ex:Electrovalvula a owl:Class ;
    rdfs:label "Electrovalvula" ;
    rdfs:comment "529764" .

ex:PlacaIntermedia a owl:Class ;
    rdfs:label "Placa Intermedia" ;
    rdfs:comment "C3 S/PLANO 10081.E" .

ex:AntirretornoC3 a owl:Class ;
    rdfs:label "Antirretorno C3" ;
    rdfs:comment "DGMDC-3-Y-PK-41" .

ex:ElectrovalvulaHidraulica a owl:Class ;
    rdfs:label "Electrovalvula Hidraulica" ;
    rdfs:comment "4/2" .

ex:SensorPresion a owl:Class ;
    rdfs:label "Sensor Presion" ;
    rdfs:comment "0..100bar Detector de presión electrónico Conexión por conector Conexión de proceso:" .

ex:TapaProteccion a owl:Class ;
    rdfs:label "Tapa Proteccion" ;
    rdfs:comment "Con posibilidad de precintado, para sensores de presión" .

ex:AisladorManometro a owl:Class ;
    rdfs:label "Aislador Manometro" ;
    rdfs:comment "FT 291-14" .

ex:ManometroGlicerina a owl:Class ;
    rdfs:label "Manometro Glicerina" ;
    rdfs:comment "S.I. D63 0…250 BAR" .

ex:FiltroRetorno a owl:Class ;
    rdfs:label "Filtro Retorno" ;
    rdfs:comment "PI 53005/2-144+852945 PS10 NBR" .

ex:AntirretornoLinea a owl:Class ;
    rdfs:label "Antirretorno Linea" ;
    rdfs:comment "RV-20-01.X/-0" .

ex:CilindroHidraulico a owl:Class ;
    rdfs:label "Cilindro Hidraulico" ;
    rdfs:comment "Ø145/Ø190/Ø145/C10" .

ex:ModuloInline a owl:Class ;
    rdfs:label "Modulo Inline" ;
    rdfs:comment "ECO, Módulo de entrada digital, Entradas digitales: 8, 24 V DC, técnica" .

ex:ModuloSalidaDigital a owl:Class ;
    rdfs:label "Modulo Salida Digital" ;
    rdfs:comment "ECO, Módulo de salida digital, Salidas digitales: 8, 24 V DC, 500 mA" .

mec:tieneProveedor a owl:ObjectProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range ex:Empresa .

elec:tieneModelo a owl:DatatypeProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range rdfs:Literal .

hid:tieneReferencia a owl:DatatypeProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range rdfs:Literal .

base:tieneDescripcion a owl:DatatypeProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range rdfs:Literal .