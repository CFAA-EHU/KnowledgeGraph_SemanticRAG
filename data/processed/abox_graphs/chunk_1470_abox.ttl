@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaBusquedaReferencia_1209 a ns1:Sistema ;
    rdfs:label "Sistema de búsqueda de referencia (ejes y cabezales)"@es ;
    ns1:monitoreaParametro ns1:Parametro_DECINPUT_1209,
        ns1:Parametro_I0TYPE_1209,
        ns1:Parametro_REFDIREC_1209,
        ns1:Parametro_REFFEED1_1209,
        ns1:Parametro_REFFEED2_1209 ;
    ns1:textoExtracto "Búsqueda de referencia con un sistema de captación que no dispone de I0s codificados. [...] la búsqueda de referencia se realiza en un determinado punto de la máquina denominado punto de referencia máquina."@es ;
    ns1:tieneComponente ns1:MicroReferencia_1209 .

ns1:MicroReferencia_1209 a ns1:ComponenteElectrico ;
    rdfs:label "Micro de referencia máquina"@es ;
    ns1:textoExtracto "El fabricante debe colocar, en cada eje, un micro de referencia en la posición que ocupa el punto de referencia máquina."@es .

ns1:Parametro_DECINPUT_1209 a ns1:Parametro ;
    rdfs:label "DECINPUT" ;
    ns1:identificador "DECINPUT" ;
    ns1:textoExtracto "| DECINPUT | El eje dispone de micro para la búsqueda de referencia. |"@es ;
    ns1:valor "El eje dispone de micro para la búsqueda de referencia."@es .

ns1:Parametro_I0TYPE_1209 a ns1:Parametro ;
    rdfs:label "I0TYPE" ;
    ns1:identificador "I0TYPE" ;
    ns1:textoExtracto "| I0TYPE | No codificado. |"@es ;
    ns1:valor "No codificado"@es .

ns1:Parametro_REFDIREC_1209 a ns1:Parametro ;
    rdfs:label "REFDIREC" ;
    ns1:identificador "REFDIREC" ;
    ns1:textoExtracto "| REFDIREC | Sentido del movimiento para la búsqueda de referencia. |"@es ;
    ns1:valor "Sentido del movimiento para la búsqueda de referencia"@es .

ns1:Parametro_REFFEED1_1209 a ns1:Parametro ;
    rdfs:label "REFFEED1" ;
    ns1:identificador "REFFEED1" ;
    ns1:textoExtracto "| REFFEED1 | Velocidad rápida de búsqueda de referencia. |"@es ;
    ns1:valor "Velocidad rápida de búsqueda de referencia"@es .

ns1:Parametro_REFFEED2_1209 a ns1:Parametro ;
    rdfs:label "REFFEED2" ;
    ns1:identificador "REFFEED2" ;
    ns1:textoExtracto "| REFFEED2 | Velocidad lenta de búsqueda de referencia. |"@es ;
    ns1:valor "Velocidad lenta de búsqueda de referencia"@es .

