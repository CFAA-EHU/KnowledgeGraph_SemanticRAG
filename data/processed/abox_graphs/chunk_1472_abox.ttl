@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_REFDIREC a ns1:Parametro ;
    rdfs:label "REFDIREC" ;
    ns1:identificador "REFDIREC" ;
    ns1:textoExtracto "Sentido del movimiento para la búsqueda de referencia." .

ns1:Parametro_REFFEED2 a ns1:Parametro ;
    rdfs:label "REFFEED2" ;
    ns1:identificador "REFFEED2" ;
    ns1:textoExtracto "Velocidad lenta de búsqueda de referencia." .

ns1:SistemaCaptacion_I0 a ns1:Sistema ;
    rdfs:label "Sistema de captación I0" ;
    ns1:monitoreaParametro ns1:Parametro_I0TYPE ;
    ns1:textoExtracto "Cuando el sistema de captación dispone de I0 codificado, la búsqueda de referencia se puede efectuar en cualquier punto de la máquina; no es necesario disponer de micro de referencia." .

ns1:Tabla_ParametrosBusquedaReferencia a ns1:Tabla ;
    rdfs:label "Parámetros de búsqueda de referencia (ejes y cabezales)" ;
    ns1:documentadoEn ns1:Pagina_595_597 ;
    ns1:textoExtracto "| Parámetro. | Valor. | --- | --- | I0TYPE | Codificado creciente. Codificado decreciente. | REFDIREC | Sentido del movimiento para la búsqueda de referencia. | REFFEED2 | Velocidad lenta de búsqueda de referencia." .

ns1:Pagina_595_597 a ns1:Pagina ;
    rdfs:label "Páginas 595-597: Búsqueda de referencia máquina (ejes y cabezales)" ;
    ns1:identificador "595-597" ;
    ns1:textoExtracto "Sección 11.5.1: Búsqueda de referencia máquina (ejes y cabezales)." .

ns1:Parametro_I0TYPE a ns1:Parametro ;
    rdfs:label "I0TYPE" ;
    ns1:identificador "I0TYPE" ;
    ns1:textoExtracto "Codificado creciente. Codificado decreciente." ;
    ns1:valor "Codificado creciente; Codificado decreciente" .

