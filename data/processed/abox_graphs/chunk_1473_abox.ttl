@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MicroReferenciaMaquina_1212 a ns1:Sensor ;
    rdfs:label "Micro de referencia máquina"@es ;
    ns1:activaAlarma ns1:AvisoInversionSentido_1212 ;
    ns1:textoExtracto "el eje pulsa el micro de referencia máquina"@es .

ns1:PuntoReferenciaMaquina_1212 a ns1:Parametro ;
    rdfs:label "Punto de referencia máquina"@es ;
    ns1:textoExtracto "Redefinir el punto de referencia máquina tras soltar el sistema de captación"@es .

ns1:SistemaCaptacion_1212 a ns1:Sistema ;
    rdfs:label "Sistema de captación (I0)"@es ;
    ns1:monitoreaParametro ns1:SenalI0_1212 ;
    ns1:textoExtracto "el CNC recibe un impulso de I0 del sistema de captación"@es .

ns1:AvisoInversionSentido_1212 a ns1:AvisoSeguridad ;
    rdfs:label "Inversión de sentido por detección prematura de referencia"@es ;
    ns1:textoExtracto "este invierte el sentido y continúa con el proceso, alejándose del micro"@es .

ns1:SenalI0_1212 a ns1:Parametro ;
    rdfs:label "Señal I0"@es ;
    ns1:identificador "I0" ;
    ns1:textoExtracto "la señal del I0"@es .

