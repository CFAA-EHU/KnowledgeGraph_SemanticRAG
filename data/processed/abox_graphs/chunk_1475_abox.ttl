@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_NPULSES a ns1:Parametro ;
    rdfs:label "NPULSES" ;
    ns1:documentadoEn ns1:Tabla_ParametrosBusquedaReferencia ;
    ns1:identificador "NPULSES" ;
    ns1:textoExtracto "NPULSES | Número de impulsos del encoder."@es ;
    ns1:valor "Número de impulsos del encoder"@es .

ns1:Parametro_NPULSES2 a ns1:Parametro ;
    rdfs:label "NPULSES2" ;
    ns1:documentadoEn ns1:Tabla_ParametrosBusquedaReferencia ;
    ns1:identificador "NPULSES2" ;
    ns1:textoExtracto "NPULSES2 | Número de impulsos del encoder (captación externa)."@es ;
    ns1:valor "Número de impulsos del encoder (captación externa)"@es .

ns1:Parametro_REFINI a ns1:Parametro ;
    rdfs:label "REFINI" ;
    ns1:documentadoEn ns1:Tabla_ParametrosBusquedaReferencia ;
    ns1:identificador "REFINI" ;
    ns1:textoExtracto "REFINI | Búsqueda de cero en el primer movimiento."@es ;
    ns1:valor "Búsqueda de cero en el primer movimiento"@es .

ns1:Tabla_ParametrosBusquedaReferencia a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de búsqueda de referencia (ejes y cabezales)"@es ;
    ns1:documentadoEn ns1:Pagina_595_597 ;
    ns1:textoExtracto """
| Parámetro. | Valor. |
| --- | --- |
| REFINI | Búsqueda de cero en el primer movimiento. |
| NPULSES | Número de impulsos del encoder. |
| NPULSES2 | Número de impulsos del encoder (captación externa)."""@es .

