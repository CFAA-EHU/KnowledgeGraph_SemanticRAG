@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Funcion_G74 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G74" ;
    ns1:ejecutadoPor ns1:SistemaCNC ;
    ns1:textoExtracto "Cuando se programa una nueva búsqueda de referencia con la función G74, desde el programa o modo MDI/MDA." .

ns1:MicrointerruptorReferencia a ns1:ComponenteElectrico ;
    rdfs:label "Micro (microinterruptor de referencia)" ;
    ns1:textoExtracto "Los ejes esperan sobre el micro hasta que todos los ejes implicados en la búsqueda encuentren el micro." .

ns1:Parametro_NPULSES a ns1:Parametro ;
    rdfs:label "Parámetro NPULSES" ;
    ns1:monitoreaParametro ns1:SistemaCNC ;
    ns1:textoExtracto "Este parámetro sólo se tiene en cuenta cuando los parámetros NPULSES y NPULSES2 se han definido con valor distinto de 0." .

ns1:Parametro_NPULSES2 a ns1:Parametro ;
    rdfs:label "Parámetro NPULSES2" ;
    ns1:monitoreaParametro ns1:SistemaCNC ;
    ns1:textoExtracto "Este parámetro sólo se tiene en cuenta cuando los parámetros NPULSES y NPULSES2 se han definido con valor distinto de 0." .

ns1:Parametro_REFFEED1 a ns1:Parametro ;
    rdfs:label "Parámetro REFFEED1" ;
    ns1:monitoreaParametro ns1:SistemaCNC ;
    ns1:textoExtracto "Todos los ejes avanzan a la vez, cada uno a su avance REFFEED1, hasta encontrar cada uno su micro." .

ns1:Parametro_REFFEED2 a ns1:Parametro ;
    rdfs:label "Parámetro REFFEED2" ;
    ns1:monitoreaParametro ns1:SistemaCNC ;
    ns1:textoExtracto "comienza secuencialmente la búsqueda de cero de cada eje, al avance REFFEED2, empezando por el último eje que ha llegado a su micro." .

ns1:Parametro_REFINI a ns1:Parametro ;
    rdfs:label "Parámetro REFINI" ;
    ns1:monitoreaParametro ns1:SistemaCNC ;
    ns1:textoExtracto "El parámetro REFINI establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento." .

ns1:SistemaTandem a ns1:Sistema ;
    rdfs:label "Sistema tándem" ;
    ns1:textoExtracto "En un sistema tándem, sólo se referencia el eje maestro; la búsqueda de cero es transparente para el esclavo que simplemente acompaña al maestro." ;
    ns1:tieneComponente ns1:EjeEsclavo,
        ns1:EjeMaestro .

ns1:CabezalMaquina a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:controla ns1:Encoder ;
    ns1:textoExtracto "El parámetro REFINI establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento." .

ns1:EjeEsclavo a ns1:ComponenteMecanico ;
    rdfs:label "Eje esclavo" ;
    ns1:textoExtracto "la búsqueda de cero es transparente para el esclavo que simplemente acompaña al maestro." .

ns1:EjeMaestro a ns1:ComponenteMecanico ;
    rdfs:label "Eje maestro" ;
    ns1:textoExtracto "En un sistema tándem, sólo se referencia el eje maestro." .

ns1:Encoder a ns1:ComponenteElectrico ;
    rdfs:label "Encoder" ;
    ns1:textoExtracto "Con cambio de encoder." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "El CNC realizará una nueva búsqueda de referencia del cabezal en las siguientes circunstancias." ;
    ns1:tieneComponente ns1:CabezalMaquina .

