@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BusquedaReferenciaEjesGantry a ns1:TareaMantenimiento ;
    rdfs:label "Búsqueda de referencia de ejes gantry" ;
    ns1:requiereMantenimiento ns1:SistemaCaptacionEjesGantry ;
    ns1:textoExtracto "La búsqueda de referencia de los ejes gantry se puede realizar de las tres formas explicadas para el resto de ejes y cabezales." .

ns1:ParametroDECINPUT a ns1:Parametro ;
    rdfs:label "DECINPUT" ;
    ns1:identificador "DECINPUT" ;
    ns1:monitoreaParametro ns1:EjeMaestroGantry ;
    ns1:textoExtracto "podrán tener micro de referencia (parámetro DECINPUT) ambos ejes o sólo el eje maestro." .

ns1:ParametroI0TYPE a ns1:Parametro ;
    rdfs:label "I0TYPE" ;
    ns1:identificador "I0TYPE" ;
    ns1:monitoreaParametro ns1:EjeEsclavoGantry,
        ns1:EjeMaestroGantry ;
    ns1:textoExtracto "El tipo de I0 (parámetro I0TYPE) deberá ser en ambos ejes el mismo." .

ns1:SistemaCaptacionEjesGantry a ns1:Sistema ;
    rdfs:label "Sistema de captación de ejes gantry" ;
    ns1:textoExtracto "Búsqueda de referencia con un sistema de captación que no dispone de I0s codificados." ;
    ns1:tieneComponente ns1:EjeEsclavoGantry,
        ns1:EjeMaestroGantry,
        ns1:ParametroDECINPUT,
        ns1:ParametroI0TYPE .

ns1:EjeEsclavoGantry a ns1:ComponenteMecanico ;
    rdfs:label "Eje esclavo gantry" ;
    ns1:textoExtracto "Los ejes maestro y esclavo tienen micro." .

ns1:EjeMaestroGantry a ns1:ComponenteMecanico ;
    rdfs:label "Eje maestro gantry" ;
    ns1:controla ns1:EjeEsclavoGantry ;
    ns1:textoExtracto "Los ejes maestro y esclavo tienen micro." .

