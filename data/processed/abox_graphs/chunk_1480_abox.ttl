@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_DECINPUT a ns1:Parametro ;
    rdfs:label "DECINPUT" ;
    ns1:documentadoEn ns1:Tabla_BusquedaReferenciaEjesGantry ;
    ns1:identificador "DECINPUT" ;
    ns1:textoExtracto "El eje dispone de micro para la búsqueda de referencia. A definir en los ejes maestro y esclavo."@es .

ns1:Parametro_I0TYPE a ns1:Parametro ;
    rdfs:label "I0TYPE" ;
    ns1:documentadoEn ns1:Tabla_BusquedaReferenciaEjesGantry ;
    ns1:identificador "I0TYPE" ;
    ns1:textoExtracto "Tipo de I0. No codificado en ambos ejes. A definir en los ejes maestro y esclavo."@es .

