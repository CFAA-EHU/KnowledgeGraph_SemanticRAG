@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProcesoBusquedaReferencia_Gantry a ns1:ModoOperacion ;
    rdfs:label "Búsqueda de referencia máquina (ejes gantry)"@es ;
    ns1:monitoreaParametro ns1:Param_REFDIREC,
        ns1:Param_REFFEED1,
        ns1:Param_REFFEED2,
        ns1:Param_REFSHIFT,
        ns1:Param_REFVALUE ;
    ns1:textoExtracto "El CNC comenzará el desplazamiento de ambos ejes en el sentido indicado por el parámetro REFDIREC del eje maestro. Este desplazamiento se realiza al avance indicado en el parámetro REFFEED1 del eje maestro, hasta que alguno de los ejes pulse su micro."@es .

ns1:SistemaCaptacionSinI0 a ns1:Sistema ;
    rdfs:label "Sistema de captación sin I0 codificados"@es ;
    ns1:textoExtracto "Búsqueda de referencia con un sistema de captación que no dispone de I0s codificados. Sólo el eje maestro tiene micro."@es ;
    ns1:tieneComponente ns1:MicroEjeMaestro .

ns1:MicroEjeMaestro a ns1:ComponenteElectrico ;
    rdfs:label "Micro del eje maestro"@es ;
    ns1:textoExtracto "hasta que éste pulse su micro"@es .

ns1:Param_REFDIREC a ns1:Parametro ;
    rdfs:label "REFDIREC" ;
    ns1:identificador "REFDIREC" ;
    ns1:textoExtracto "parámetro REFDIREC del eje maestro"@es ;
    ns1:valor "Dirección de desplazamiento inicial"@es .

ns1:Param_REFFEED1 a ns1:Parametro ;
    rdfs:label "REFFEED1" ;
    ns1:identificador "REFFEED1" ;
    ns1:textoExtracto "avance indicado en el parámetro REFFEED1 del eje maestro"@es ;
    ns1:valor "Avance inicial de búsqueda"@es .

ns1:Param_REFFEED2 a ns1:Parametro ;
    rdfs:label "REFFEED2" ;
    ns1:identificador "REFFEED2" ;
    ns1:textoExtracto "avance REFFEED2 del eje maestro"@es ;
    ns1:valor "Avance tras detección de micro"@es .

ns1:Param_REFSHIFT a ns1:Parametro ;
    rdfs:label "REFSHIFT" ;
    ns1:identificador "REFSHIFT" ;
    ns1:textoExtracto "parámetro REFSHIFT distinto de cero"@es ;
    ns1:valor "Desplazamiento adicional del eje maestro"@es .

ns1:Param_REFVALUE a ns1:Parametro ;
    rdfs:label "REFVALUE" ;
    ns1:identificador "REFVALUE" ;
    ns1:textoExtracto "valor definido en el parámetro REFVALUE"@es ;
    ns1:valor "Valor de inicialización de cota"@es .

