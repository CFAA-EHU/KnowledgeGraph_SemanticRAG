@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_BusquedaReferenciaEjesGantry a ns1:Sistema ;
    rdfs:label "Búsqueda de referencia máquina (ejes gantry)" ;
    ns1:monitoreaParametro ns1:Parametro_REFDIREC,
        ns1:Parametro_REFFEED1,
        ns1:Parametro_REFFEED2,
        ns1:Parametro_REFSHIFT,
        ns1:Parametro_REFVALUE ;
    ns1:textoExtracto "El CNC comenzará el desplazamiento de ambos ejes en el sentido indicado por el parámetro REFDIREC del eje maestro. Este desplazamiento se realiza al avance indicado en el parámetro REFFEED1 del eje maestro, hasta que éste pulse su micro. Tras pulsar el eje maestro su micro, ambos ejes se desplazan al avance REFFEED2 del eje maestro hasta que el eje esclavo encuentre el I0. Tras encontrar el I0, el eje esclavo inicializa su cota con el valor definido en el parámetro REFVALUE y teniendo en cuenta también el parámetro REFSHIFT." ;
    ns1:tieneComponente ns1:ComponenteElectrico_MicroEjeMaestro,
        ns1:Sensor_I0 .

ns1:ComponenteElectrico_MicroEjeMaestro a ns1:ComponenteElectrico ;
    rdfs:label "Micro del eje maestro" ;
    ns1:textoExtracto "pulse su micro" .

ns1:Parametro_REFDIREC a ns1:Parametro ;
    rdfs:label "REFDIREC" ;
    ns1:identificador "REFDIREC" ;
    ns1:textoExtracto "parámetro REFDIREC del eje maestro" .

ns1:Parametro_REFFEED1 a ns1:Parametro ;
    rdfs:label "REFFEED1" ;
    ns1:identificador "REFFEED1" ;
    ns1:textoExtracto "parámetro REFFEED1 del eje maestro" .

ns1:Parametro_REFFEED2 a ns1:Parametro ;
    rdfs:label "REFFEED2" ;
    ns1:identificador "REFFEED2" ;
    ns1:textoExtracto "avance REFFEED2 del eje maestro" .

ns1:Parametro_REFSHIFT a ns1:Parametro ;
    rdfs:label "REFSHIFT" ;
    ns1:identificador "REFSHIFT" ;
    ns1:textoExtracto "parámetro REFSHIFT" .

ns1:Parametro_REFVALUE a ns1:Parametro ;
    rdfs:label "REFVALUE" ;
    ns1:identificador "REFVALUE" ;
    ns1:textoExtracto "parámetro REFVALUE" .

ns1:Sensor_I0 a ns1:Sensor ;
    rdfs:label "I0" ;
    ns1:identificador "I0" ;
    ns1:textoExtracto "eje esclavo encuentre el I0" .

