@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ReguladorCNC a ns1:Actuador ;
    rdfs:label "Regulador CNC" ;
    ns1:controla ns1:EjeEsclavo_Gantry,
        ns1:EjeMaestro_Gantry ;
    ns1:textoExtracto "El CNC envía al regulador la orden de referenciar el eje esclavo" .

ns1:SistemaEjesSercos a ns1:Sistema ;
    rdfs:label "Sistema de ejes Sercos (posición)" ;
    ns1:compuestoPor ns1:SistemaCaptacion_I0 ;
    ns1:textoExtracto "Ejes Sercos posición. Para realizar la búsqueda de referencia es necesario disponer bien de un sistema con I0 codificados o bien que ambos ejes tengan micro" ;
    ns1:tieneComponente ns1:EjeEsclavo_Gantry,
        ns1:EjeMaestro_Gantry .

ns1:Parametro_REFDIREC a ns1:Parametro ;
    rdfs:label "REFDIREC" ;
    ns1:textoExtracto "sentido indicado por el parámetro REFDIREC del eje maestro" ;
    ns1:valor "dirección_de_búsqueda" .

ns1:Parametro_REFFEED2 a ns1:Parametro ;
    rdfs:label "REFFEED2" ;
    ns1:textoExtracto "avance indicado en el parámetro REFFEED2 del eje maestro" ;
    ns1:valor "avance_de_búsqueda" .

ns1:SistemaCaptacion_I0 a ns1:Sistema ;
    rdfs:label "Sistema de captación I0" ;
    ns1:textoExtracto "Búsqueda de referencia con un sistema de captación que dispone de I0s codificados" .

ns1:EjeEsclavo_Gantry a ns1:ComponenteMecanico ;
    rdfs:label "Eje esclavo (gantry)" ;
    ns1:monitoreaParametro ns1:Parametro_REFSHIFT,
        ns1:Parametro_REFVALUE ;
    ns1:textoExtracto "el eje esclavo inicializa su cota con el valor definido en el parámetro REFVALUE" .

ns1:EjeMaestro_Gantry a ns1:ComponenteMecanico ;
    rdfs:label "Eje maestro (gantry)" ;
    ns1:monitoreaParametro ns1:Parametro_REFDIREC,
        ns1:Parametro_REFFEED2,
        ns1:Parametro_REFSHIFT,
        ns1:Parametro_REFVALUE ;
    ns1:textoExtracto "el eje maestro busca la señal de I0" .

ns1:Parametro_REFSHIFT a ns1:Parametro ;
    rdfs:label "REFSHIFT" ;
    ns1:textoExtracto "teniendo en cuenta también el parámetro REFSHIFT" ;
    ns1:valor "desplazamiento_de_referencia" .

ns1:Parametro_REFVALUE a ns1:Parametro ;
    rdfs:label "REFVALUE" ;
    ns1:textoExtracto "el valor definido en el parámetro REFVALUE" ;
    ns1:valor "valor_de_referencia" .

