@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CotaTeoricaEjeMaestro a ns1:Parametro ;
    rdfs:label "cota teórica del eje maestro"@es ;
    ns1:textoExtracto "la envía al eje maestro como incremento de la cota teórica"@es .

ns1:SistemaReferenciadoEjesGantry a ns1:Sistema ;
    rdfs:label "Sistema de referencia de ejes gantry"@es ;
    ns1:controla ns1:ReguladorEjeGantry ;
    ns1:textoExtracto "El CNC envía al regulador la orden de referenciar el eje esclavo... haciendo así que el eje maestro siga al esclavo con tan solo el retraso entre la cota teórica y la real"@es ;
    ns1:tieneComponente ns1:ReguladorEjeGantry .

ns1:CotaRealEjeEsclavo a ns1:Parametro ;
    rdfs:label "cota real del eje esclavo"@es ;
    ns1:textoExtracto "el CNC lee el incremento en la cota real del eje esclavo"@es .

ns1:ReguladorEjeGantry a ns1:ComponenteElectrico ;
    rdfs:label "regulador de eje esclavo"@es ;
    ns1:monitoreaParametro ns1:CotaRealEjeEsclavo ;
    ns1:textoExtracto "El CNC envía al regulador la orden de referenciar el eje esclavo. Durante el proceso, el CNC lee el incremento en la cota real del eje esclavo y la envía al eje maestro como incremento de la cota teórica"@es .

