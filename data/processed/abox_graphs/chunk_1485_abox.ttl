@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TareaMantenimiento_CorreccionCota a ns1:TareaMantenimiento ;
    rdfs:label "Corrección de diferencia de cota (ejes maestro/esclavo)" ;
    ns1:requiereMantenimiento ns1:Sistema_CompensacionCota ;
    ns1:textoExtracto "El eje esclavo se moverá hasta alcanzar la cota del eje maestro, al avance especificado en el parámetro REFFEED2. El proceso sólo se puede interrumpir con reset." .

ns1:Marca_DIFFCOMP a ns1:ComponenteElectrico ;
    rdfs:label "DIFFCOMP(axis)" ;
    ns1:textoExtracto "La marca DIFFCOMP(axis) corrige la diferencia de cota entre el eje maestro y esclavo" .

ns1:Marca_SERVOxnON a ns1:ComponenteElectrico ;
    rdfs:label "SERVOxnON" ;
    ns1:textoExtracto "flanco de subida de la marca SERVOxnON del eje maestro o del esclavo" .

ns1:Parametro_DIFFCOMP a ns1:Parametro ;
    rdfs:label "DIFFCOMP" ;
    ns1:textoExtracto "el parámetro DIFFCOMP habilita la corrección de la diferencia de cota" ;
    ns1:valor "habilitación_compensación_diferencia_cota" .

ns1:Parametro_REFFEED1 a ns1:Parametro ;
    rdfs:label "REFFEED1" ;
    ns1:textoExtracto "el avance de búsqueda de referencia (parámetro REFFEED1)" ;
    ns1:valor "avance_búsqueda_referencia" .

ns1:Parametro_REFFEED2 a ns1:Parametro ;
    rdfs:label "REFFEED2" ;
    ns1:textoExtracto "al avance especificado en el parámetro REFFEED2" ;
    ns1:valor "avance_corrección_cota" .

ns1:Sistema_CompensacionCota a ns1:Sistema ;
    rdfs:label "Sistema de compensación de diferencia de cota (ejes gantry)" ;
    ns1:compuestoPor ns1:Parametro_DIFFCOMP,
        ns1:Parametro_REFFEED1,
        ns1:Parametro_REFFEED2 ;
    ns1:textoExtracto "Compensación de diferencia de cota tras buscar cero. La corrección de cota se puede aplicar a todo tipo eje; analógico, y Sercos." ;
    ns1:tieneComponente ns1:Marca_DIFFCOMP,
        ns1:Marca_SERVOxnON .

