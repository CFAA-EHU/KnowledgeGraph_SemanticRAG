@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:sistema_correccion_cota a ns1:Sistema ;
    rdfs:label "Sistema de corrección de cota (ejes gantry)" ;
    ns1:controla ns1:marca_DIFFCOMP,
        ns1:marca_REFPOIN,
        ns1:marca_SERVOON ;
    ns1:textoExtracto "La marca DIFFCOMP(axis) corrige la diferencia de cota entre el eje maestro y esclavo..." .

ns1:marca_DIFFCOMP a ns1:Parametro ;
    rdfs:label "DIFFCOMP(axis)" ;
    ns1:identificador "DIFFCOMP" ;
    ns1:textoExtracto "La marca DIFFCOMP(axis) corrige la diferencia de cota entre el eje maestro y esclavo..." .

ns1:marca_REFPOIN a ns1:Parametro ;
    rdfs:label "REFPOIN(axis)" ;
    ns1:identificador "REFPOIN" ;
    ns1:textoExtracto "La marca REFPOIN(axis) de ambos ejes se activa cuando termina la corrección de la cota." .

ns1:marca_SERVOON a ns1:Parametro ;
    rdfs:label "SERVO(axis)ON" ;
    ns1:identificador "SERVOON" ;
    ns1:textoExtracto "Con el flanco de subida de SERVO(axis)ON si DIFFCOMP(axis) está activa..." .

