@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjeX a ns1:Componente ;
    ns1:textoExtracto "límites de software en los ejes lineales y ejes rotativos linearlike. T Z SL X FL Y O M FL T" .

ns1:EjeY a ns1:Componente ;
    ns1:textoExtracto "límites de software en los ejes lineales y ejes rotativos linearlike. T Z SL X FL Y O M FL T" .

ns1:ErrorLimiteSoftware a ns1:DiagnosticoFallo ;
    ns1:textoExtracto "el CNC detiene la ejecución y muestra el error correspondiente" .

ns1:LimiteSoftwareSL1 a ns1:Parametro ;
    rdfs:label "SL1" ;
    ns1:textoExtracto "SL Límites de software, aplicados por el CNC." .

ns1:LimiteSoftwareSL2 a ns1:Parametro ;
    rdfs:label "SL2" ;
    ns1:textoExtracto "Y SL1 SL2 X" .

ns1:ModoManual a ns1:ModoOperacion ;
    ns1:textoExtracto "acceder al modo manual y mover el eje o cabezal que ha sobrepasado el límite" .

ns1:Portaherramientas a ns1:Componente ;
    ns1:textoExtracto "punto de referencia del portaherramientas" .

ns1:SistemaCNC a ns1:Maquina ;
    ns1:textoExtracto "El CNC permite definir límites de software en los ejes lineales y ejes rotativos linearlike." .

ns1:VariableLimiteSoftware a ns1:Parametro ;
    ns1:textoExtracto "El CNC dispone de la siguiente variable para indicar que alguno de los ejes alcanzado los límites de software." .

