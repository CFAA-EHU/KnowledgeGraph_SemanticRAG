@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_LIMITNEG a ns1:Parametro ;
    rdfs:label "LIMITNEG(axis)"@es ;
    ns1:activaAlarma ns1:Alarma_LimiteInferior ;
    ns1:documentadoEn ns1:Tabla_LimitesSoftwareEjes ;
    ns1:identificador "LIMITNEG(axis)" ;
    ns1:monitoreaParametro ns1:SistemaControlEjes ;
    ns1:textoExtracto "El eje ha alcanzado el límite inferior de software."@es .

ns1:Marca_LIMITPOS a ns1:Parametro ;
    rdfs:label "LIMITPOS(axis)"@es ;
    ns1:activaAlarma ns1:Alarma_LimiteSuperior ;
    ns1:documentadoEn ns1:Tabla_LimitesSoftwareEjes ;
    ns1:identificador "LIMITPOS(axis)" ;
    ns1:monitoreaParametro ns1:SistemaControlEjes ;
    ns1:textoExtracto "El eje ha alcanzado el límite superior de software."@es .

ns1:Variable_VchGSOFTLIMIT a ns1:Parametro ;
    rdfs:label "(V.)[ch].G.SOFTLIMIT"@es ;
    ns1:documentadoEn ns1:Tabla_LimitesSoftwareEjes ;
    ns1:identificador "(V.)[ch].G.SOFTLIMIT" ;
    ns1:monitoreaParametro ns1:SistemaControlEjes ;
    ns1:textoExtracto "Límites de software alcanzados."@es .

ns1:Alarma_LimiteInferior a ns1:Alarma ;
    rdfs:label "Alarma de límite inferior de software"@es ;
    ns1:textoExtracto "Indicación de que el eje ha alcanzado el límite inferior de software (LIMITNEG)."@es .

ns1:Alarma_LimiteSuperior a ns1:Alarma ;
    rdfs:label "Alarma de límite superior de software"@es ;
    ns1:textoExtracto "Indicación de que el eje ha alcanzado el límite superior de software (LIMITPOS)."@es .

ns1:SistemaControlEjes a ns1:Sistema ;
    rdfs:label "Sistema de control de ejes y cabezales (PLC-CNC)"@es ;
    ns1:textoExtracto "El PLC activa una de estas marcas para indicar al CNC que el eje o cabezal correspondiente ha alcanzado el límite de software en sentido positivo o negativo."@es .

ns1:Tabla_LimitesSoftwareEjes a ns1:Tabla ;
    rdfs:label "Tabla de límites de software de ejes (pág. 600-601)"@es ;
    ns1:textoExtracto """
| Variable. | Significado. |
| --- | --- |
| (V.)[ch].G.SOFTLIMIT | Límites de software alcanzados. |
| Marca de PLC. | Significado. |
| --- | --- |
| LIMITPOS(axis) | El eje ha alcanzado el límite superior de software. |
| LIMITNEG(axis) | El eje ha alcanzado el límite inferior de software."""@es .

