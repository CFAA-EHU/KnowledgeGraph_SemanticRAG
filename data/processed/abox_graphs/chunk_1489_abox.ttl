@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Funcion_G151_1228 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G151"@es ;
    ns1:controla ns1:Maquina_CNC_1228 ;
    ns1:textoExtracto "independientemente de [...] la función G151/G152 activa"@es .

ns1:Funcion_G152_1228 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G152"@es ;
    ns1:controla ns1:Maquina_CNC_1228 ;
    ns1:textoExtracto "independientemente de [...] la función G151/G152 activa"@es .

ns1:LimitesSoftware_1228 a ns1:Parametro ;
    rdfs:label "Límites de software (grupo por defecto)"@es ;
    ns1:identificador "LIMIT+, LIMIT-" ;
    ns1:monitoreaParametro ns1:Maquina_CNC_1228 ;
    ns1:textoExtracto "Los límites de software pueden ser positivos o negativos, pero los límites inferiores deben ser menores que los límites superiores; en caso contrario, puede suceder que el eje no se desplace en ninguna dirección. [...] Los límites de software por defecto, aquellos que asume el CNC en el encendido, están definidos en los parámetros máquina"@es .

ns1:Parametro_DIAMPROG_1228 a ns1:Parametro ;
    rdfs:label "Parámetro DIAMPROG"@es ;
    ns1:monitoreaParametro ns1:Maquina_CNC_1228 ;
    ns1:textoExtracto "Los límites de software siempre se aplican en radios, independientemente del parámetro DIAMPROG"@es .

ns1:Tabla_ParametrosLimites_1228 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de límites de software"@es ;
    ns1:documentadoEn ns1:Pagina_602_1228 ;
    ns1:textoExtracto "| Parámetro. | Significado. | --- | --- | LIMIT+ | Límites superiores de software. | LIMIT- | Límites inferiores de software."@es .

ns1:Pagina_602_1228 a ns1:Pagina ;
    rdfs:label "Página 602 - Límites de software"@es ;
    ns1:textoExtracto "Consideraciones para definir los límites de software. [...] Los límites de software por defecto (primeros límites de software)."@es .

ns1:Maquina_CNC_1228 a ns1:Maquina ;
    rdfs:label "CNC (Control Numérico Computarizado)"@es ;
    ns1:textoExtracto "el CNC anula dichos límites en ese eje y aplica los del otro grupo. [...] Los límites de software por defecto, aquellos que asume el CNC en el encendido"@es .

