@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sensor: <https://admin-shell.io/dictionary/Sensor> .

ex:CaudalimetroMecatronico a owl:Class ;
    rdfs:label "Caudalímetro mecatrónico" ;
    rdfs:comment "Caudalímetro mecatrónico, con válvula de retención, DC, Con pantalla" .

ex:ElectronicLevelSensor a owl:Class ;
    rdfs:label "Sensor electrónico de nivel" ;
    rdfs:comment "Sensor electrónico de nivel, DC PNP, Conexión por conector, Display" .

ex:SensorNivelTON a owl:Class ;
    rdfs:label "Sensor de nivel TON" ;
    rdfs:comment "Sensor de nivel TON (salida digital), DC PNP, contactos dorados, Conexión" .

ex:ManometroConSensor a owl:Class ;
    rdfs:label "Manómetro con sensor" ;
    rdfs:comment "Manómetro con sensor (D.E. 42.5) Rango manómetro: 10 (1.0 MPa) Rosca de conexión: 01 (R1/8) LED" .

ex:ModuloSeleccion a owl:Class ;
    rdfs:label "Módulo de selección" ;
    rdfs:comment "SITOP PSE200U 10 A Módulo de selección" .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:CaudalimetroMecatronico ;
    rdfs:range xsd:string .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:ElectronicLevelSensor ;
    rdfs:range xsd:string .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:SensorNivelTON ;
    rdfs:range xsd:string .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:ManometroConSensor ;
    rdfs:range xsd:string .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:ModuloSeleccion ;
    rdfs:range xsd:string .

ex:tieneDesignacion a owl:DatatypeProperty ;
    rdfs:domain ex:CaudalimetroMecatronico ;
    rdfs:range xsd:string .

ex:tieneDesignacion a owl:DatatypeProperty ;
    rdfs:domain ex:ElectronicLevelSensor ;
    rdfs:range xsd:string .

ex:tieneDesignacion a owl:DatatypeProperty ;
    rdfs:domain ex:SensorNivelTON ;
    rdfs:range xsd:string .

ex:tieneDesignacion a owl:DatatypeProperty ;
    rdfs:domain ex:ManometroConSensor ;
    rdfs:range xsd:string .

ex:tieneDesignacion a owl:DatatypeProperty ;
    rdfs:domain ex:ModuloSeleccion ;
    rdfs:range xsd:string .

ex:tieneCantidad a owl:DatatypeProperty ;
    rdfs:domain ex:CaudalimetroMecatronico ;
    rdfs:range xsd:integer .

ex:tieneCantidad a owl:DatatypeProperty ;
    rdfs:domain ex:ElectronicLevelSensor ;
    rdfs:range xsd:integer .

ex:tieneCantidad a owl:DatatypeProperty ;
    rdfs:domain ex:SensorNivelTON ;
    rdfs:range xsd:integer .

ex:tieneCantidad a owl:DatatypeProperty ;
    rdfs:domain ex:ManometroConSensor ;
    rdfs:range xsd:integer .

ex:tieneCantidad a owl:DatatypeProperty ;
    rdfs:domain ex:ModuloSeleccion ;
    rdfs:range xsd:integer .

sensor:Sensor a owl:Class ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Sensor> .