@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LimitesSoftwareSecundarios a ns1:Parametro ;
    rdfs:label "Segundos límites de software" ;
    ns1:textoExtracto "Segundos límites de software. Estos límites de software se definen mediante las siguientes variables, con permiso de escritura desde el programa pieza, MDI, PLC o interfaz." .

ns1:MaquinaCNC a ns1:Maquina ;
    rdfs:label "Máquina CNC" ;
    ns1:controla ns1:FuncionG198,
        ns1:FuncionG199,
        ns1:ModoG90,
        ns1:ModoG91 ;
    ns1:textoExtracto "el CNC entiende que las cotas de los ejes programadas a continuación de estas funciones definen la posición de los nuevos límites de software" ;
    ns1:tieneComponente ns1:InterfazUsuarioCNC,
        ns1:SistemaReferenciaMaquina .

ns1:FuncionG198 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G198 (límite inferior de software)" ;
    ns1:identificador "G198" ;
    ns1:textoExtracto "Modificar los límites de software mediante las funciones G198/G199. Cuando se programa una de las funciones G198 ó G199, el CNC entiende que las cotas de los ejes programadas a continuación de estas funciones definen la posición de los nuevos límites de software. G198 X-1000 Y-1000 (Nuevos límites inferiores X=-1000 Y=-1000)" .

ns1:FuncionG199 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G199 (límite superior de software)" ;
    ns1:identificador "G199" ;
    ns1:textoExtracto "G199 X1000 Y1000 (Nuevos límites superiores X=1000 Y=1000)" .

ns1:InterfazUsuarioCNC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de usuario del CNC" ;
    ns1:textoExtracto "con permiso de escritura desde el [...] interfaz" .

ns1:ModoG90 a ns1:ModoOperacion ;
    rdfs:label "Modo G90 (coordenadas absolutas)" ;
    ns1:identificador "G90" ;
    ns1:textoExtracto "Dependiendo del modo de trabajo activo G90 ó G91, la posición de los nuevos límites estará definida en coordenadas absolutas (G90) en el sistema de referencia de la máquina" .

ns1:ModoG91 a ns1:ModoOperacion ;
    rdfs:label "Modo G91 (coordenadas incrementales)" ;
    ns1:identificador "G91" ;
    ns1:textoExtracto "o en coordenadas incrementales (G91) respecto de los límites activos" .

ns1:SistemaReferenciaMaquina a ns1:Sistema ;
    rdfs:label "Sistema de referencia de la máquina" ;
    ns1:textoExtracto "en el sistema de referencia de la máquina" .

