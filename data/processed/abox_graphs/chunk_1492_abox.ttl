@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LimitesSoftware_1231 a ns1:Parametro ;
    rdfs:label "Límites de software configurables"@es ;
    ns1:monitoreaParametro ns1:SistemaCNC_1231 ;
    ns1:textoExtracto "Estos límites de software se definen mediante las siguientes variables, con permiso de escritura desde el programa pieza, MDI, PLC o interfaz. Estas variables se inicializan en el encendido, asumiendo el máximo valor posible."@es ;
    ns1:valor "máximo posible (inicialización por defecto)"@es .

ns1:InterfazUsuarioCNC_1231 a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de usuario del CNC"@es ;
    ns1:textoExtracto "permiso de escritura desde [...] interfaz"@es .

ns1:ModuloMDI_1231 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo MDI"@es ;
    ns1:textoExtracto "permiso de escritura desde [...] MDI"@es .

ns1:ModuloPLC_1231 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo PLC"@es ;
    ns1:textoExtracto "permiso de escritura desde [...] PLC"@es .

ns1:ProgramaPieza_1231 a ns1:ModoOperacion ;
    rdfs:label "Programa pieza"@es ;
    ns1:textoExtracto "permiso de escritura desde el programa pieza"@es .

ns1:SistemaCNC_1231 a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:textoExtracto "el CNC asume en adelante dichos valores como nuevos límites en este grupo"@es ;
    ns1:tieneComponente ns1:InterfazUsuarioCNC_1231,
        ns1:ModuloMDI_1231,
        ns1:ModuloPLC_1231,
        ns1:ProgramaPieza_1231 .

