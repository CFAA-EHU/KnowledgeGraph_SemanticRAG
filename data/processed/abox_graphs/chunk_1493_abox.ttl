@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Condicion_AnulacionLimites a ns1:AvisoSeguridad ;
    rdfs:label "Condición de anulación de segundos límites de software"@es ;
    ns1:documentadoEn ns1:Tabla_11_6_1_LimitesSoftware ;
    ns1:textoExtracto "Si ambos límites de un eje (inferior y superior) se definen con valor ꞏ0ꞏ, se anulan dichos límites y el CNC aplicará al eje los primeros límites de software."@es .

ns1:Param_LimiteInferiorSoftware a ns1:Parametro ;
    rdfs:label "(V.)[ch].A.RTNEGLIMIT.xn"@es ;
    ns1:documentadoEn ns1:Tabla_11_6_1_LimitesSoftware ;
    ns1:identificador "(V.)[ch].A.RTNEGLIMIT.xn" ;
    ns1:textoExtracto "Límites inferiores de software (segundos límites)."@es .

ns1:Param_LimiteSuperiorSoftware a ns1:Parametro ;
    rdfs:label "(V.)[ch].A.RTPOSLIMIT.xn"@es ;
    ns1:documentadoEn ns1:Tabla_11_6_1_LimitesSoftware ;
    ns1:identificador "(V.)[ch].A.RTPOSLIMIT.xn" ;
    ns1:textoExtracto "Límites superiores de software (segundos límites)."@es .

ns1:Tabla_11_6_1_LimitesSoftware a ns1:Tabla ;
    rdfs:label "Tabla 11.6.1: Límites de software (pág. 602-603)"@es ;
    ns1:textoExtracto """
| Variable. | Significado. |
| --- | --- |
| (V.)[ch].A.RTNEGLIMIT.xn | Límites inferiores de software (segundos límites). |
| (V.)[ch].A.RTPOSLIMIT.xn | Límites superiores de software (segundos límites)."""@es ;
    ns1:tieneComponente ns1:Param_LimiteInferiorSoftware,
        ns1:Param_LimiteSuperiorSoftware .

