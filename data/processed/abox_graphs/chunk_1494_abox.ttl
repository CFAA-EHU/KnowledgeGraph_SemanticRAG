@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC_11_6_2 a ns1:Maquina ;
    ns1:monitoreaParametro ns1:SWLIMITTOL ;
    ns1:textoExtracto "El CNC aplica esta tolerancia a los límites de software activos." .

ns1:SWLIMITTOL a ns1:Parametro ;
    rdfs:label "SWLIMITTOL" ;
    ns1:identificador "SWLIMITTOL" ;
    ns1:textoExtracto "La tolerancia para los límites de software se define mediante el parámetro máquina SWLIMITTOL." .

