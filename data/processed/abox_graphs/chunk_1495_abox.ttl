@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CompensacionVolumetrica_Grande a ns1:ModoOperacion ;
    rdfs:label "Compensación volumétrica grande" ;
    ns1:habilitadoPor ns1:OpcionSoftware_CompensacionVolumetricaGrande ;
    ns1:textoExtracto "El CNC dispone de tres tipos de compensación volumétrica, seleccionables mediante su opción de software correspondiente; básica, media o grande." ;
    ns1:tieneComponente ns1:CompensacionVolumetrica_Basica,
        ns1:CompensacionVolumetrica_Media .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC" ;
    ns1:textoExtracto "La compensación volumétrica corrige en gran medida estos errores geométricos, mejorando así la precisión de los posicionamientos." ;
    ns1:tieneComponente ns1:ArchivoCompensacionVolumetrica,
        ns1:ParametrosMaquina_VOLCOMP .

ns1:ArchivoCompensacionVolumetrica a ns1:InterfazUsuario ;
    rdfs:label "Archivo de compensación volumétrica" ;
    ns1:documentadoEn ns1:Pagina_605_606 ;
    ns1:textoExtracto "El error queda registrado en un fichero que posteriormente se carga en el CNC. [...] Las tablas que definen la compensación están definidas en un archivo externo." .

ns1:CompensacionVolumetrica_Basica a ns1:ModoOperacion ;
    rdfs:label "Compensación volumétrica básica" ;
    ns1:habilitadoPor ns1:OpcionSoftware_CompensacionVolumetricaBasica ;
    ns1:textoExtracto "El CNC dispone de tres tipos de compensación volumétrica, seleccionables mediante su opción de software correspondiente; básica, media o grande." .

ns1:CompensacionVolumetrica_Media a ns1:ModoOperacion ;
    rdfs:label "Compensación volumétrica media" ;
    ns1:habilitadoPor ns1:OpcionSoftware_CompensacionVolumetricaMedia ;
    ns1:textoExtracto "El CNC dispone de tres tipos de compensación volumétrica, seleccionables mediante su opción de software correspondiente; básica, media o grande." .

ns1:OpcionSoftware_CompensacionVolumetricaBasica a ns1:Parametro ;
    rdfs:label "Opción de software: Compensación volumétrica básica" ;
    ns1:identificador "CSV" ;
    ns1:textoExtracto "La opción 'Compensación volumétrica grande' también permite utilizar los otros dos tipos de compensación, media y básica." .

ns1:OpcionSoftware_CompensacionVolumetricaGrande a ns1:Parametro ;
    rdfs:label "Opción de software: Compensación volumétrica grande" ;
    ns1:textoExtracto "Si el CNC tiene activa la compensación volumétrica media o grande (opción de software), también permitirá definir una compensación volumétrica básica si el fichero tiene extensión csv." .

ns1:OpcionSoftware_CompensacionVolumetricaMedia a ns1:Parametro ;
    rdfs:label "Opción de software: Compensación volumétrica media" ;
    ns1:textoExtracto "El CNC puede tener configuradas cuatro compensaciones volumétricas, formadas por ejes lineales y rotativos." .

ns1:Pagina_605_606 a ns1:Pagina ;
    rdfs:label "Páginas 605-606: Compensación volumétrica" ;
    ns1:identificador "12 12" ;
    ns1:textoExtracto "Una de las causas de la falta de precisión en los posicionamientos viene dada por los errores geométricos de la máquina, surgidos durante su fabricación y montaje, desgastes, deformaciones elásticas, etc." .

ns1:ParametrosMaquina_VOLCOMP a ns1:Parametro ;
    rdfs:label "Parámetros máquina VOLCOMP1 a VOLCOMP4" ;
    ns1:identificador "VOLCOMP1, VOLCOMP2, VOLCOMP3, VOLCOMP4" ;
    ns1:textoExtracto "Las compensaciones volumétricas se configuran en los parámetros máquina y se activan desde el PLC (marcas VOLCOMP1 a VOLCOMP4)." .

