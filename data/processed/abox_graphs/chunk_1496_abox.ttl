@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CompensacionVolumetricaGrande a ns1:ModoOperacion ;
    rdfs:label "Compensación volumétrica grande" ;
    ns1:habilitadoPor ns1:CompensacionVolumetricaBasica,
        ns1:CompensacionVolumetricaMedia ;
    ns1:textoExtracto "La opción \"Compensación volumétrica grande\" también permite utilizar los otros dos tipos de compensación, media y básica." .

ns1:CompensacionVolumetricaMedia a ns1:ModoOperacion ;
    rdfs:label "Compensación volumétrica media" ;
    ns1:habilitadoPor ns1:CompensacionVolumetricaBasica ;
    ns1:textoExtracto "La opción \"Compensación volumétrica media\" también permite utilizar la opción básica." .

ns1:CompensacionVolumetricaBasica a ns1:ModoOperacion ;
    rdfs:label "Compensación volumétrica básica" ;
    ns1:textoExtracto "La opción básica de compensación volumétrica." .

