@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CompensacionCruzada a ns1:ModoOperacion ;
    rdfs:label "Compensación cruzada" ;
    ns1:textoExtracto "La compensación volumétrica incluye la compensación cruzada, por lo que no es necesario definir esta última; no obstante, si está definida, el CNC la tiene en cuenta. El CNC primero aplica la compensación cruzada y de husillo, y a continuación la compensación volumétrica." .

ns1:CompensacionHusillo a ns1:ModoOperacion ;
    rdfs:label "Compensación de husillo" ;
    ns1:textoExtracto "La compensación volumétrica incluye la compensación de husillo, por lo que no es necesario definir esta última; no obstante, si está definida, el CNC la tiene en cuenta. El CNC primero aplica la compensación cruzada y de husillo, y a continuación la compensación volumétrica." .

ns1:FicheroDatosCompensacion a ns1:InterfazUsuario ;
    rdfs:label "Fichero de datos de compensación" ;
    ns1:requiereMantenimiento ns1:CompensacionVolumetrica_Basica,
        ns1:CompensacionVolumetrica_Grande,
        ns1:CompensacionVolumetrica_Media ;
    ns1:textoExtracto "El OEM debe seleccionar el fichero que contiene los datos de la compensación." .

ns1:ParametrosMaquina_Compensacion a ns1:Parametro ;
    rdfs:label "Parámetros máquina para compensación" ;
    ns1:monitoreaParametro ns1:CompensacionVolumetrica_Basica ;
    ns1:textoExtracto "El OEM debe definir en los parámetros máquina todos los datos de la compensación (ejes que se mueven, ejes a compensar, posición y tamaño del volumen a compensar, etc) y seleccionar el fichero que contiene los datos de la compensación." .

ns1:TablaCompensacionVolumetrica a ns1:Tabla ;
    rdfs:label "Tabla de compensación volumétrica" ;
    ns1:documentadoEn ns1:CompensacionVolumetrica_Basica,
        ns1:CompensacionVolumetrica_Grande,
        ns1:CompensacionVolumetrica_Media ;
    ns1:textoExtracto "Las tablas de compensación las genera la aplicación de calibración; no son editables desde el CNC." .

ns1:CompensacionVolumetrica_Grande a ns1:ModoOperacion ;
    rdfs:label "Compensación volumétrica grande" ;
    ns1:textoExtracto "Volumen a compensar más de 10 m³ (grande). Esta compensación corrige los 21 componentes del error geométrico (traslación, rotación y cuadratura). Las tablas de compensación las genera la aplicación de calibración; no son editables desde el CNC. El OEM sólo debe definir en los parámetros máquina los ejes a compensar y seleccionar el fichero que contiene los datos de la calibración. La compensación grande es más precisa que la básica, pero es más lenta de calibrar." .

ns1:CompensacionVolumetrica_Media a ns1:ModoOperacion ;
    rdfs:label "Compensación volumétrica media" ;
    ns1:textoExtracto "Volumen a compensar hasta 10 m³ (media). Esta compensación corrige los 21 componentes del error geométrico (traslación, rotación y cuadratura). Las tablas de compensación las genera la aplicación de calibración; no son editables desde el CNC. El OEM sólo debe definir en los parámetros máquina los ejes a compensar y seleccionar el fichero que contiene los datos de la calibración. La compensación media es más precisa que la básica, pero es más lenta de calibrar." .

ns1:CompensacionVolumetrica_Basica a ns1:ModoOperacion ;
    rdfs:label "Compensación volumétrica básica" ;
    ns1:textoExtracto "El volumen a compensar está definido por hasta 25 puntos en cada eje. Esta compensación corrige los errores de traslación. Las tablas de compensación las genera la aplicación de calibración; no son editables desde el CNC. El OEM debe definir en los parámetros máquina todos los datos de la compensación (ejes que se mueven, ejes a compensar, posición y tamaño del volumen a compensar, etc) y seleccionar el fichero que contiene los datos de la compensación. La compensación básica es la más rápida de calibrar, pero puede ser menos precisa que las otras (corrige menos componentes de error)." .

