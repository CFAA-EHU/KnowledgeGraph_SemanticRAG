@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Compensacion2DCaidaCarnero a ns1:ModoOperacion ;
    rdfs:label "Compensación 2D de caída de carnero"@es ;
    ns1:textoExtracto "una compensación 2D de caída de carnero"@es .

ns1:CompensacionCruzada a ns1:ModoOperacion ;
    rdfs:label "Compensación cruzada"@es ;
    ns1:textoExtracto "una compensación cruzada habitual"@es .

ns1:CompensacionVolumetricaBasica a ns1:ModoOperacion ;
    rdfs:label "Compensación volumétrica básica"@es ;
    ns1:textoExtracto "En la compensación volumétrica básica hay que definir ambos ejes, el que se mueve y el que se compensa."@es .

