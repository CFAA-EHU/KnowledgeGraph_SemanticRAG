@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArchivoCSV a ns1:Consumible ;
    rdfs:label "Archivo CSV"@es ;
    ns1:identificador "csv" ;
    ns1:textoExtracto "archivo con extensión csv"@es .

ns1:InterfazUsuario_CNC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz CNC"@es ;
    ns1:monitoreaParametro ns1:Parametro_VCOMPFILE ;
    ns1:textoExtracto "El CNC muestra estos parámetros"@es .

ns1:Parametro_VCOMPFILE a ns1:Parametro ;
    rdfs:label "Parámetro VCOMPFILE"@es ;
    ns1:identificador "VCOMPFILE" ;
    ns1:textoExtracto "parámetro VCOMPFILE"@es .

