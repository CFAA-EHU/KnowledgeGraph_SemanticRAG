@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CompensacionVolumetrica a ns1:Sistema ;
    rdfs:label "Sistema de compensación volumétrica (PLC-CNC)"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_Se_alesPLC_VOLCOMP ;
    ns1:textoExtracto """
Si el PLC activa una de estas marcas (cambio de 0 a 1), el CNC activa la compensación volumétrica correspondiente...
Todas las compensaciones volumétricas pueden estar activas simultáneamente, siempre que no haya ejes comunes entre ellas.
"""@es ;
    ns1:tieneComponente ns1:Parametro_VOLCOMP1,
        ns1:Parametro_VOLCOMP2,
        ns1:Parametro_VOLCOMP3,
        ns1:Parametro_VOLCOMP4 .

ns1:Parametro_VOLCOMP1 a ns1:Parametro ;
    rdfs:label "VOLCOMP1"@es ;
    ns1:documentadoEn ns1:Tabla_Se_alesPLC_VOLCOMP ;
    ns1:identificador "VOLCOMP1" ;
    ns1:textoExtracto "marca VOLCOMP1 corresponde a la primera compensación volumétrica (parámetro VOLCOMP1)"@es .

ns1:Parametro_VOLCOMP2 a ns1:Parametro ;
    rdfs:label "VOLCOMP2"@es ;
    ns1:documentadoEn ns1:Tabla_Se_alesPLC_VOLCOMP ;
    ns1:identificador "VOLCOMP2" ;
    ns1:textoExtracto "marca VOLCOMP2 a la segunda [compensación volumétrica]"@es .

ns1:Parametro_VOLCOMP3 a ns1:Parametro ;
    rdfs:label "VOLCOMP3"@es ;
    ns1:documentadoEn ns1:Tabla_Se_alesPLC_VOLCOMP ;
    ns1:identificador "VOLCOMP3" ;
    ns1:textoExtracto "VOLCOMP3"@es .

ns1:Parametro_VOLCOMP4 a ns1:Parametro ;
    rdfs:label "VOLCOMP4"@es ;
    ns1:documentadoEn ns1:Tabla_Se_alesPLC_VOLCOMP ;
    ns1:identificador "VOLCOMP4" ;
    ns1:textoExtracto "VOLCOMP4"@es .

ns1:Tabla_Se_alesPLC_VOLCOMP a ns1:Tabla ;
    rdfs:label "Tabla de señales PLC para compensación volumétrica"@es ;
    ns1:textoExtracto """
| Señal de PLC. |  | Significado. |
| --- | --- | --- |
| VOLCOMP1 PLC_M |  | Si el PLC activa una de estas marcas (cambio de 0 a 1), el CNC activa la compensación volumétrica correspondiente (parámetro VOLCOMP)...
""" .

