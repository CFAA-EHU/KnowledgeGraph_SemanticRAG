@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CompensacionVolumetrica_CNC_1242 a ns1:Parametro ;
    rdfs:label "Compensación volumétrica (CNC)"@es ;
    ns1:monitoreaParametro ns1:SistemaCNC_1242 ;
    ns1:textoExtracto "El CNC aplica la compensación volumétrica después de aplicar la compensación de husillo y la compensación cruzada. La compensación volumétrica permanece activa tras un reset, error o fin de programa (M30)."@es .

ns1:ParametroCruzado_1242 a ns1:Parametro ;
    rdfs:label "Compensación cruzada"@es ;
    ns1:textoExtracto "compensación cruzada"@es .

ns1:ParametroHusillo_1242 a ns1:Parametro ;
    rdfs:label "Compensación de husillo"@es ;
    ns1:textoExtracto "compensación de husillo"@es .

ns1:SistemaCNC_1242 a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:textoExtracto "CNC"@es ;
    ns1:tieneComponente ns1:ParametroCruzado_1242,
        ns1:ParametroHusillo_1242 .

