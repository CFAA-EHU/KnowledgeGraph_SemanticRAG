@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_INCHES a ns1:Parametro ;
    rdfs:label "INCHES" ;
    ns1:identificador "INCHES" ;
    ns1:textoExtracto "parámetro INCHES" .

ns1:Parametro_NPOINTSAX1 a ns1:Parametro ;
    rdfs:label "NPOINTSAX1" ;
    ns1:identificador "NPOINTSAX1" ;
    ns1:textoExtracto "NPOINTSAX1=3" ;
    ns1:valor "3" .

ns1:Parametro_NPOINTSAX2 a ns1:Parametro ;
    rdfs:label "NPOINTSAX2" ;
    ns1:identificador "NPOINTSAX2" ;
    ns1:textoExtracto "NPOINTSAX2=2" ;
    ns1:valor "2" .

ns1:Parametro_NPOINTSAX3 a ns1:Parametro ;
    rdfs:label "NPOINTSAX3" ;
    ns1:identificador "NPOINTSAX3" ;
    ns1:textoExtracto "NPOINTSAX3=2" ;
    ns1:valor "2" .

ns1:Parametro_VCOMPAXIS1 a ns1:Parametro ;
    rdfs:label "VCOMPAXIS1" ;
    ns1:identificador "VCOMPAXIS1" ;
    ns1:textoExtracto "parámetro VCOMPAXIS1 (primera columna)" ;
    ns1:valor "X" .

ns1:Parametro_VCOMPAXIS2 a ns1:Parametro ;
    rdfs:label "VCOMPAXIS2" ;
    ns1:identificador "VCOMPAXIS2" ;
    ns1:textoExtracto "parámetro VCOMPAXIS2 (segunda columna)" ;
    ns1:valor "Y" .

ns1:Parametro_VCOMPAXIS3 a ns1:Parametro ;
    rdfs:label "VCOMPAXIS3" ;
    ns1:identificador "VCOMPAXIS3" ;
    ns1:textoExtracto "parámetro VCOMPAXIS3 (tercera columna)" ;
    ns1:valor "Z" .

ns1:Parametro_VCOMPFILE a ns1:Parametro ;
    rdfs:label "VCOMPFILE" ;
    ns1:identificador "VCOMPFILE" ;
    ns1:textoExtracto "parámetro máquina VCOMPFILE" .

ns1:Tabla_CompensacionVolumetrica a ns1:Tabla ;
    rdfs:label "Tabla de compensación volumétrica básica" ;
    ns1:documentadoEn ns1:Pagina_608 ;
    ns1:textoExtracto "archivo de texto formado por tres columnas de datos y tantas filas como puntos a compensar [...] Número de filas = NPOINTSAX1 × NPOINTSAX2 × NPOINTSAX3" .

ns1:Pagina_608 a ns1:Pagina ;
    rdfs:label "Página 608 - Archivo con los datos para la compensación volumétrica básica" ;
    ns1:identificador "608" ;
    ns1:textoExtracto "Sección 12.1.3 Archivo con los datos para la compensación volumétrica básica" .

