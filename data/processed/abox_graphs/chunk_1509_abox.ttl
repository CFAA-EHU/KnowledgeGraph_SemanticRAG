@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_INCREAX1 a ns1:Parametro ;
    rdfs:label "INCREAX1" ;
    ns1:textoExtracto "La distancia entre puntos del eje X está definida en el parámetro INCREAX1." .

ns1:Parametro_INCREAX2 a ns1:Parametro ;
    rdfs:label "INCREAX2" ;
    ns1:textoExtracto "La distancia entre puntos del eje Y está definida en el parámetro INCREAX2." .

ns1:Parametro_INIPOSAX1 a ns1:Parametro ;
    rdfs:label "INIPOSAX1" ;
    ns1:textoExtracto "Este punto corresponde al punto inicial del volumen a compensar (parámetros INIPOSAX1, INIPOSAX2, INIPOSAX3)." .

ns1:Parametro_INIPOSAX2 a ns1:Parametro ;
    rdfs:label "INIPOSAX2" ;
    ns1:textoExtracto "Este punto corresponde al punto inicial del volumen a compensar (parámetros INIPOSAX1, INIPOSAX2, INIPOSAX3)." .

ns1:Parametro_INIPOSAX3 a ns1:Parametro ;
    rdfs:label "INIPOSAX3" ;
    ns1:textoExtracto "Este punto corresponde al punto inicial del volumen a compensar (parámetros INIPOSAX1, INIPOSAX2, INIPOSAX3)." .

ns1:Parametro_NPOINTSAX1 a ns1:Parametro ;
    rdfs:label "NPOINTSAX1" ;
    ns1:textoExtracto "La segunda fila corresponde al punto ... hasta completar todos los puntos del X (parámetro NPOINTSAX1)." .

ns1:Parametro_NPOINTSAX2 a ns1:Parametro ;
    rdfs:label "NPOINTSAX2" ;
    ns1:textoExtracto "Repetir la misma operación para definir todos los puntos del eje X, desde el punto Y(P2) hasta el último punto del eje Y (parámetro NPOINTSAX2)." .

ns1:Parametro_NPOINTSAX3 a ns1:Parametro ;
    rdfs:label "NPOINTSAX3" ;
    ns1:textoExtracto "Una vez definidos todos los puntos del plano (cota Z(P1)), repetir la misma operación desde el punto ... hasta el último punto del eje Z (parámetro NPOINTSAX3)." .

