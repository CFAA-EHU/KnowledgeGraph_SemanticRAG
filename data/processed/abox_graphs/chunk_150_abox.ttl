@prefix ex: <https://vocab.cfaa.eus/broaching/>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

ex:Contacto a owl:Class ;
    rdfs:label "Contacto"@es ;
    rdfs:comment "Clase que representa un contacto eléctrico."@es .

ex:AcopladorPorRelé a owl:Class ;
    rdfs:label "AcopladorPorRelé"@es ;
    rdfs:comment "Clase que representa un acoplador por relé."@es .

ex:LimitadorSobretension a owl:Class ;
    rdfs:label "LimitadorSobretension"@es ;
    rdfs:comment "Clase que representa un limitador de sobretensión."@es .

ex:Varistor a owl:Class ;
    rdfs:label "Varistor"@es ;
    rdfs:comment "Clase que representa un varistor."@es .

ex:Relé a owl:Class ;
    rdfs:label "Relé"@es ;
    rdfs:comment "Clase que representa un relé."@es .

ex:ContactoNormalmenteAbierto a owl:Class ;
    rdfs:label "ContactoNormalmenteAbierto"@es ;
    rdfs:comment "Clase que representa un contacto normalmente abierto."@es .

ex:ContactoNormalmenteCerrado a owl:Class ;
    rdfs:label "ContactoNormalmenteCerrado"@es ;
    rdfs:comment "Clase que representa un contacto normalmente cerrado."@es .

ex:BornesDeResorte a owl:Class ;
    rdfs:label "BornesDeResorte"@es ;
    rdfs:comment "Clase que representa bornes de resorte."@es .

ex:SiemensAG a owl:Class ;
    rdfs:label "SiemensAG"@es ;
    rdfs:comment "Clase que representa la empresa Siemens AG."@es .

ex:Weidmüller a owl:Class ;
    rdfs:label "Weidmüller"@es ;
    rdfs:comment "Clase que representa la empresa Weidmüller."@es .