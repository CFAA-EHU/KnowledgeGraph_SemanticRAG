@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_INT a ns1:ModoOperacion ;
    rdfs:label "Modo INT (aplicación externa)" ;
    ns1:textoExtracto "accesibles desde [...] (INT) una aplicación externa"@es .

ns1:ModoOperacion_MDI_MDA a ns1:ModoOperacion ;
    rdfs:label "Modo MDI/MDA" ;
    ns1:textoExtracto "accesibles desde [...] modo MDI/MDA"@es .

ns1:ModoOperacion_PLC a ns1:ModoOperacion ;
    rdfs:label "Modo PLC" ;
    ns1:textoExtracto "El acceso a las variables desde el PLC, tanto para la lectura como para la escritura, será síncrono."@es .

ns1:ModoOperacion_PRG a ns1:ModoOperacion ;
    rdfs:label "Modo PRG (programa pieza)"@es ;
    ns1:textoExtracto "accesibles desde; (PRG) el programa pieza"@es .

ns1:Variable_MPG_NPOINTSAX1 a ns1:Parametro ;
    rdfs:label "MPG.NPOINTSAX1[tbl]" ;
    ns1:documentadoEn ns1:Tabla_12_1_5_VariablesMPG ;
    ns1:identificador "MPG.NPOINTSAX1" ;
    ns1:textoExtracto "(V.)MPG.NPOINTSAX1[tbl]. Número de puntos de la compensación volumétrica básica en cada eje."@es .

ns1:Variable_MPG_VCOMPFILE a ns1:Parametro ;
    rdfs:label "MPG.VCOMPFILE[tbl]" ;
    ns1:documentadoEn ns1:Tabla_12_1_5_VariablesMPG ;
    ns1:identificador "MPG.VCOMPFILE" ;
    ns1:textoExtracto "(V.)MPG.VCOMPFILE[tbl]. Archivo con los datos de la compensación volumétrica."@es .

ns1:Variable_MPG_VMOVAXIS1 a ns1:Parametro ;
    rdfs:label "MPG.VMOVAXIS1[tbl]" ;
    ns1:documentadoEn ns1:Tabla_12_1_5_VariablesMPG ;
    ns1:identificador "MPG.VMOVAXIS1" ;
    ns1:textoExtracto "(V.)MPG.VMOVAXIS1[tbl]. Nombre del eje que al moverse genera variaciones."@es .

ns1:Variable_MPG_VMOVAXIS2 a ns1:Parametro ;
    rdfs:label "MPG.VMOVAXIS2[tbl]" ;
    ns1:documentadoEn ns1:Tabla_12_1_5_VariablesMPG ;
    ns1:identificador "MPG.VMOVAXIS2" ;
    ns1:textoExtracto "(V.)MPG.VMOVAXIS2[tbl]. Nombre del eje que al moverse genera variaciones."@es .

ns1:Variable_MPG_VMOVAXIS3 a ns1:Parametro ;
    rdfs:label "MPG.VMOVAXIS3[tbl]" ;
    ns1:documentadoEn ns1:Tabla_12_1_5_VariablesMPG ;
    ns1:identificador "MPG.VMOVAXIS3" ;
    ns1:textoExtracto "(V.)MPG.VMOVAXIS3[tbl]. Nombre del eje que al moverse genera variaciones."@es .

ns1:Pagina_611_612 a ns1:Pagina ;
    ns1:identificador "611-612" ;
    ns1:textoExtracto "12.1.5 Variables. Las siguientes variables son accesibles desde; (PRG) el programa pieza..."@es .

ns1:Tabla_12_1_5_VariablesMPG a ns1:Tabla ;
    rdfs:label "Tabla de variables MPG para compensación volumétrica"@es ;
    ns1:documentadoEn ns1:Pagina_611_612 ;
    ns1:ilustradoEn ns1:Manual_Tecnico ;
    ns1:textoExtracto "La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W). [...] | Variables. | PRG | PLC | INT |"@es .

