@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_VMPG_NPOINTAX2_2 a ns1:Parametro ;
    rdfs:label "V.MPG.NPOINTAX2[2]"@es ;
    ns1:documentadoEn ns1:Tabla_CompensacionVolumetrica_2 ;
    ns1:identificador "V.MPG.NPOINTAX2[2]" ;
    ns1:textoExtracto "Número de puntos del segundo eje de la segunda tabla de compensación volumétrica."@es .

ns1:Parametro_VMPG_VCOMPFILE a ns1:Parametro ;
    rdfs:label "V.MPG.VCOMPFILE[tbl]"@es ;
    ns1:documentadoEn ns1:Tabla_CompensacionVolumetrica_1,
        ns1:Tabla_CompensacionVolumetrica_2 ;
    ns1:identificador "V.MPG.VCOMPFILE" ;
    ns1:textoExtracto "Archivo con los datos de la compensación volumétrica. Unidades: -. | R(*) | R | R | (*) El CNC evalúa la variable durante la ejecución (detiene la preparación de bloques). Sintaxis de la variable. ꞏtblꞏ Número de tabla."@es .

ns1:Parametro_VMPG_VMOVAXIS2_1 a ns1:Parametro ;
    rdfs:label "V.MPG.VMOVAXIS2[1]"@es ;
    ns1:documentadoEn ns1:Tabla_CompensacionVolumetrica_1 ;
    ns1:identificador "V.MPG.VMOVAXIS2[1]" ;
    ns1:textoExtracto "Nombre del segundo eje de la primera tabla de compensación volumétrica."@es .

ns1:Tabla_CompensacionVolumetrica_1 a ns1:Tabla ;
    rdfs:label "Tabla 1 de compensación volumétrica"@es ;
    ns1:identificador "1" ;
    ns1:textoExtracto "V.MPG.VMOVAXIS2[1] | Nombre del segundo eje de la primera tabla de compensación volumétrica."@es .

ns1:Tabla_CompensacionVolumetrica_2 a ns1:Tabla ;
    rdfs:label "Tabla 2 de compensación volumétrica"@es ;
    ns1:identificador "2" ;
    ns1:textoExtracto "V.MPG.NPOINTAX2[2] | Número de puntos del segundo eje de la segunda tabla de compensación volumétrica."@es .

