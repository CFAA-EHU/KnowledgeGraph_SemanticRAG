@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_VOLCOMP1 a ns1:Parametro ;
    rdfs:label "VOLCOMP1"@es ;
    ns1:documentadoEn ns1:Tabla_VariablesVolumetricas ;
    ns1:identificador "V.PLC.VOLCOMP1" ;
    ns1:monitoreaParametro ns1:Sistema_CompensacionVolumetrica ;
    ns1:textoExtracto "V.PLC.VOLCOMP1 | Compensación volumétrica ꞏ1ꞏ."@es ;
    ns1:valor "Compensación volumétrica 1"@es .

ns1:Parametro_VOLCOMP2 a ns1:Parametro ;
    rdfs:label "VOLCOMP2"@es ;
    ns1:documentadoEn ns1:Tabla_VariablesVolumetricas ;
    ns1:identificador "V.PLC.VOLCOMP2" ;
    ns1:monitoreaParametro ns1:Sistema_CompensacionVolumetrica ;
    ns1:textoExtracto "(V.)PLC.VOLCOMP2"@es .

ns1:Parametro_VOLCOMP3 a ns1:Parametro ;
    rdfs:label "VOLCOMP3"@es ;
    ns1:documentadoEn ns1:Tabla_VariablesVolumetricas ;
    ns1:identificador "V.PLC.VOLCOMP3" ;
    ns1:monitoreaParametro ns1:Sistema_CompensacionVolumetrica ;
    ns1:textoExtracto "(V.)PLC.VOLCOMP3"@es .

ns1:Parametro_VOLCOMP4 a ns1:Parametro ;
    rdfs:label "VOLCOMP4"@es ;
    ns1:documentadoEn ns1:Tabla_VariablesVolumetricas ;
    ns1:identificador "V.PLC.VOLCOMP4" ;
    ns1:monitoreaParametro ns1:Sistema_CompensacionVolumetrica ;
    ns1:textoExtracto "(V.)PLC.VOLCOMP4"@es .

ns1:Parametro_VOLCOMP_Canal2_Eje3 a ns1:Parametro ;
    rdfs:label "Compensación volumétrica (canal 2, eje índice 3)"@es ;
    ns1:documentadoEn ns1:Tabla_VariablesVolumetricas ;
    ns1:identificador "V.[2].A.VOLCOMP.3" ;
    ns1:monitoreaParametro ns1:Sistema_CompensacionVolumetrica ;
    ns1:textoExtracto "V.[2].A.VOLCOMP.3 | Eje con índice ꞏ3ꞏ en el canal ꞏ2ꞏ."@es .

ns1:Parametro_VOLCOMP_Eje3 a ns1:Parametro ;
    rdfs:label "Compensación volumétrica del eje lógico 3"@es ;
    ns1:documentadoEn ns1:Tabla_VariablesVolumetricas ;
    ns1:identificador "V.A.VOLCOMP.3" ;
    ns1:monitoreaParametro ns1:Sistema_CompensacionVolumetrica ;
    ns1:textoExtracto "V.A.VOLCOMP.3 | Eje con número lógico ꞏ3ꞏ."@es .

ns1:Parametro_VOLCOMP_EjeZ a ns1:Parametro ;
    rdfs:label "Compensación volumétrica del eje Z"@es ;
    ns1:documentadoEn ns1:Tabla_VariablesVolumetricas ;
    ns1:identificador "V.A.VOLCOMP.Z" ;
    ns1:monitoreaParametro ns1:Sistema_CompensacionVolumetrica ;
    ns1:textoExtracto "V.A.VOLCOMP.Z | Eje Z."@es ;
    ns1:valor "Milímetros, pulgadas o grados"@es .

ns1:Sistema_CompensacionVolumetrica a ns1:Sistema ;
    rdfs:label "Sistema de compensación volumétrica"@es ;
    ns1:documentadoEn ns1:Tabla_VariablesVolumetricas ;
    ns1:textoExtracto """
Estas variables refleja el valor de las marcas VOLCOMP1 a VOLCOMP4 del PLC. Si el PLC activa una de estas marcas (cambio de 0 a 1), el CNC activa la compensación volumétrica correspondiente (parámetro VOLCOMP).
...
Valor que está añadiendo la compensación volumétrica al eje. Si la compensación volumétrica no está activa, la variable devuelve valor 0 (cero).
"""@es .

ns1:Tabla_VariablesVolumetricas a ns1:Tabla ;
    rdfs:label "Tabla de variables de compensación volumétrica (Pág. 611-612)"@es ;
    ns1:textoExtracto """
| Variables. | PRG | PLC | INT |
| --- | --- | --- | --- |
| (V.)PLC.VOLCOMP1
(V.)PLC.VOLCOMP2
(V.)PLC.VOLCOMP3
(V.)PLC.VOLCOMP4
...
| (V.)[ch].A.VOLCOMP.xn
Valor que está añadiendo la compensación volumétrica al eje...
"""@es .

