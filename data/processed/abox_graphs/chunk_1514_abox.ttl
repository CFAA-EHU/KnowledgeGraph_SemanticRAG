@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_INCHES a ns1:Parametro ;
    rdfs:label "INCHES" ;
    ns1:identificador "INCHES" ;
    ns1:textoExtracto "Parámetro que define las unidades (milímetros o pulgadas) para los datos del archivo de compensación volumétrica."@es .

ns1:Parametro_VCOMPAXIS1_MPG a ns1:Parametro ;
    rdfs:label "VCOMPAXIS1 MPG" ;
    ns1:documentadoEn ns1:Tabla_ParametrosCompensacionVolumetrica_1253 ;
    ns1:identificador "VCOMPAXIS1 MPG" ;
    ns1:textoExtracto "Define los ejes a compensar mediante la compensación volumétrica (lineales o rotativos)."@es .

ns1:Parametro_VCOMPAXIS2 a ns1:Parametro ;
    rdfs:label "VCOMPAXIS2" ;
    ns1:documentadoEn ns1:Tabla_ParametrosCompensacionVolumetrica_1253 ;
    ns1:identificador "VCOMPAXIS2" ;
    ns1:textoExtracto "Define los ejes a compensar mediante la compensación volumétrica (lineales o rotativos)."@es .

ns1:Parametro_VCOMPAXIS3 a ns1:Parametro ;
    rdfs:label "VCOMPAXIS3" ;
    ns1:documentadoEn ns1:Tabla_ParametrosCompensacionVolumetrica_1253 ;
    ns1:identificador "VCOMPAXIS3" ;
    ns1:textoExtracto "Define los ejes a compensar mediante la compensación volumétrica (lineales o rotativos)."@es .

ns1:Parametro_VCOMPFILE_MPG a ns1:Parametro ;
    rdfs:label "VCOMPFILE MPG" ;
    ns1:documentadoEn ns1:Tabla_ParametrosCompensacionVolumetrica_1253 ;
    ns1:identificador "VCOMPFILE MPG" ;
    ns1:textoExtracto "Las tablas de compensación las genera la aplicación de calibración; no son editables desde el CNC. Las unidades (milímetros o pulgadas) deben coincidir con el parámetro INCHES."@es .

ns1:Parametro_VOLCOMP_MPG a ns1:Parametro ;
    rdfs:label "VOLCOMP MPG" ;
    ns1:documentadoEn ns1:Tabla_ParametrosCompensacionVolumetrica_1253 ;
    ns1:identificador "VOLCOMP MPG" ;
    ns1:textoExtracto "Este parámetro muestra las tablas de compensación volumétrica."@es .

ns1:Tabla_ParametrosCompensacionVolumetrica_1253 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de compensación volumétrica (Sección 12.2.1)"@es ;
    ns1:documentadoEn ns1:Pagina_613 ;
    ns1:textoExtracto """
| Parámetro. |  | Significado. |
| --- | --- | --- |
| VOLCOMP MPG |  | Este parámetro muestra las tablas de compensación volumétrica. |
| VCOMPAXIS1 MPG, VCOMPAXIS2, VCOMPAXIS3 |  | Estos parámetros definen los ejes a compensar mediante la compensación volumétrica... |
| VCOMPFILE MPG |  | Las tablas de compensación las genera la aplicación de calibración; no son editables desde el CNC...""" .

