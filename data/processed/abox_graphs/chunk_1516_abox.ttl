@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:monitoreaParametro ns1:CompensacionCruzada,
        ns1:CompensacionHusillo,
        ns1:CompensacionVolumetrica ;
    ns1:textoExtracto "El CNC aplica la compensación volumétrica" .

ns1:CompensacionCruzada a ns1:Parametro ;
    rdfs:label "Compensación cruzada" ;
    ns1:textoExtracto "compensación cruzada"@es .

ns1:CompensacionHusillo a ns1:Parametro ;
    rdfs:label "Compensación de husillo" ;
    ns1:textoExtracto "compensación de husillo"@es .

ns1:CompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Compensación volumétrica" ;
    ns1:textoExtracto "El CNC aplica la compensación volumétrica después de aplicar la compensación de husillo y la compensación cruzada. La compensación volumétrica permanece activa tras un reset, error o fin de programa (M30)." .

