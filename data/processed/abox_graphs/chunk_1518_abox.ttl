    ns1:documentadoEn ns1:Tabla_CompensacionVolumetrica_12_2_3 ;
    ns1:textoExtracto "Variable que refleja el valor de la marca VOLCOMP3 del PLC."@es .

ns1:Parametro_PLC_VOLCOMP4 a ns1:Parametro ;
