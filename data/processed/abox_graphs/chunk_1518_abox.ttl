    rdfs:label "PLC.VOLCOMP2" ;
    ns1:documentadoEn ns1:Tabla_CompensacionVolumetrica_12_2_3 ;
    ns1:textoExtracto "Variable que refleja el valor de la marca VOLCOMP2 del PLC."@es .

ns1:Parametro_PLC_VOLCOMP3 a ns1:Parametro ;
