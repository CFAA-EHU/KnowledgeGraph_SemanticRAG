ns1:Parametro_VMPG_NPOINTAX2_2 a ns1:Parametro ;
    rdfs:label "V.MPG.NPOINTAX2[2]" ;
    ns1:documentadoEn ns1:Tabla_CompensacionVolumetrica_12_2_3 ;
    ns1:textoExtracto "Número de puntos del segundo eje de la segunda tabla de compensación volumétrica."@es ;
    ns1:valor "2" .

ns1:Parametro_VMPG_VCOMPFILE a ns1:Parametro ;
    rdfs:label "V.MPG.VCOMPFILE[tbl]" ;
    ns1:documentadoEn ns1:Tabla_CompensacionVolumetrica_12_2_3 ;
    ns1:textoExtracto "Archivo con los datos de la compensación volumétrica. Unidades: -."@es ;
    ns1:valor "tbl" .

ns1:Parametro_VMPG_VMOVAXIS2_1 a ns1:Parametro ;
    rdfs:label "V.MPG.VMOVAXIS2[1]" ;
    ns1:documentadoEn ns1:Tabla_CompensacionVolumetrica_12_2_3 ;
    ns1:textoExtracto "Nombre del segundo eje de la primera tabla de compensación volumétrica."@es ;
    ns1:valor "1" .

ns1:Tabla_CompensacionVolumetrica_12_2_3 a ns1:Tabla ;
    rdfs:label "Tabla de compensación volumétrica (Sección 12.2.3)"@es ;
    ns1:identificador "12.2.3" ;
    ns1:textoExtracto "Archivo con los datos de la compensación volumétrica. [...] V.MPG.NPOINTAX2[2] | Número de puntos del segundo eje de la segunda tabla de compensación volumétrica."@es .

