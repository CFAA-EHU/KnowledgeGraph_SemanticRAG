ns1:Parametro_PLC_VOLCOMP1 a ns1:Parametro ;
    rdfs:label "PLC.VOLCOMP1" ;
    ns1:documentadoEn ns1:Tabla_CompensacionVolumetrica_12_2_3 ;
    ns1:textoExtracto "Variable que refleja el valor de la marca VOLCOMP1 del PLC."@es .

