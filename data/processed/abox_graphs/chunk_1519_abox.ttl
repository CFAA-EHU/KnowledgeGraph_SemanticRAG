@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Variable_V.PLC.VOLCOMP1 a ns1:Parametro ;
    rdfs:label "Variable V.PLC.VOLCOMP1"@es ;
    ns1:identificador "V.PLC.VOLCOMP1" ;
    ns1:monitoreaParametro ns1:Parametro_VOLCOMP ;
    ns1:textoExtracto "Sintaxis de la variable. | V.PLC.VOLCOMP1 | Compensación volumétrica ꞏ1ꞏ."@es .

ns1:Parametro_VOLCOMP a ns1:Parametro ;
    rdfs:label "Compensación volumétrica (VOLCOMP)"@es ;
    ns1:identificador "VOLCOMP" ;
    ns1:textoExtracto "compensación volumétrica correspondiente (parámetro VOLCOMP)."@es ;
    ns1:valor "R/W" .

