@prefix ex: <https://vocab.cfaa.eus/broaching/>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

ex:AcopladorPorRelé a owl:Class ;
    rdfs:label "Acoplador por relé"@es ;
    rdfs:comment "Componente eléctrico que actúa como acoplador por relé"@es.

ex:ContactorInsta a owl:Class ;
    rdfs:label "Contactor Insta"@es ;
    rdfs:comment "Contacto auxiliar con características específicas"@es.

ex:ContactorAux a owl:Class ;
    rdfs:label "Contactor Auxiliar"@es ;
    rdfs:comment "Contacto auxiliar con características específicas"@es.

ex:LimitadorSobretension a owl:Class ;
    rdfs:label "Limitador de sobretensión"@es ;
    rdfs:comment "Componente que limita la sobretensión en el sistema"@es.

ex:InterruptorSeccionadorFusible a owl:Class ;
    rdfs:label "Interruptor seccionador fusible"@es ;
    rdfs:comment "Interruptor que combina funciones de seccionador y fusible"@es.

ex:JuegoDeFusibles a owl:Class ;
    rdfs:label "Juego de fusibles"@es ;
    rdfs:comment "Conjunto de fusibles para protección de circuitos"@es.

ex:InterruptorProteccionSelectiva a owl:Class ;
    rdfs:label "Interruptor de protección selectiva"@es ;
    rdfs:comment "Interruptor que proporciona protección selectiva en el sistema"@es.

ex:InterruptorProteccionSelectiva a owl:Class ;
    rdfs:label "Interruptor de protección selectiva"@es ;
    rdfs:comment "Interruptor que proporciona protección selectiva en el sistema"@es.

ex:SiemensAG a owl:Class ;
    rdfs:label "Siemens AG"@es ;
    rdfs:comment "Fabricante de componentes eléctricos"@es.

ex:Weidmüller a owl:Class ;
    rdfs:label "Weidmüller"@es ;
    rdfs:comment "Fabricante de componentes eléctricos"@es.