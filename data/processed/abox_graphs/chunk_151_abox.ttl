@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:AcopladorPorRelé a owl:Class ;
    rdfs:label "Acoplador por relé MICROSERIES" ;
    rdfs:comment "Número de contactos: 1 Contacto" .

ex:ContactorInsta a owl:Class ;
    rdfs:label "CONTACTOR INSTA CON 2 CONTACTOS NA" ;
    rdfs:comment "CONTACTOR INSTA CON 2 CONTACTOS NA CONTACTO P. 230, 400 V AC" .

ex:ContactorAuxiliar a owl:Class ;
    rdfs:label "CONTACTOR AUX., 4NA DC 24V" ;
    rdfs:comment "TAMANO S00, BORNES DE TORNILLO" .

ex:LimitadorSobretension a owl:Class ;
    rdfs:label "LIMITADOR SOBRETENSION, VARISTOR CON LED" ;
    rdfs:comment "AC 48...127V, DC" .

ex:ContactorAuxiliar3NA1NC a owl:Class ;
    rdfs:label "CONTACTOR AUX., 3NA+1NC DC 24V" ;
    rdfs:comment "TAMANO S00, BORNES DE TORNILLO" .

ex:InterruptorSeccionadorFusible a owl:Class ;
    rdfs:label "INTERRUPTOR SECCIONADOR FUSIBLE" ;
    rdfs:comment "3 POLOS, NH00, 160 A, DISENO" .

ex:JuegoDeFusibles a owl:Class ;
    rdfs:label "JUEGO DE FUSIBLES SITOR 100A" ;
    rdfs:comment "AC 690V (DIN 43620, TAM. 00)" .

ex:InterruptorProteccionSelectiva a owl:Class ;
    rdfs:label "INT. PROTECCION SEL. 10KA 2POLOS D6" ;
    rdfs:comment "Automático magnetotérmico 400V 10kA, 2 polos, D, 6A, T=70 mm" .

ex:InterruptorProteccionSelectiva400V a owl:Class ;
    rdfs:label "INTERR. PROTEC. SELEC. 400V 10KA" ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

ex:Weidmüller a owl:Class ;
    rdfs:label "WEIDMÜLLER" .

ex:SiemensAG a owl:Class ;
    rdfs:label "SIEMENS AG" .