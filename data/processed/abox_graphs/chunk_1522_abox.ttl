@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_0046 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0046: 'Eje inexistente'"@es ;
    ns1:identificador "0046" ;
    ns1:monitoreaParametro ns1:Parametro_AXISNAME ;
    ns1:textoExtracto "0046 'Eje inexistente' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Las posibles causas son las siguientes: • El usuario ha asignado a un parámetro máquina el nombre de un eje que no existe. • En la compensación volumétrica básica, no se ha definido uno de los ejes VMOVAXIS o VCOMPAXIS. SOLUCIÓN Corregir los parámetros máquina. Los nombres de eje válidos son los definidos en el parámetro AXISNAME."@es .

ns1:Error_1445 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1445: 'Valor de parámetro no válido'"@es ;
    ns1:identificador "1445" ;
    ns1:textoExtracto "1445 'Valor de parámetro no válido' DETECCIÓN Durante la ejecución. CAUSA En una sentencia o en un ciclo fijo, un parámetro tiene un valor no válido. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1447 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1447: 'Opción de software no permitida'"@es ;
    ns1:identificador "1447" ;
    ns1:textoExtracto "1447 'Opción de software no permitida' DETECCIÓN Durante la ejecución. CAUSA El CNC no dispone de la opción de software necesaria para ejecutar la orden programada. SOLUCIÓN En el modo diagnosis se pueden consultar las opciones de software disponibles en el CNC."@es .

ns1:Modo_Diagnosis a ns1:ModoOperacion ;
    rdfs:label "Modo diagnosis"@es ;
    ns1:textoExtracto "En el modo diagnosis se pueden consultar las opciones de software disponibles en el CNC."@es .

ns1:Parametro_VCOMPAXIS a ns1:Parametro ;
    rdfs:label "Parámetro VCOMPAXIS"@es ;
    ns1:identificador "VCOMPAXIS" ;
    ns1:textoExtracto "En la compensación volumétrica básica, no se ha definido uno de los ejes VMOVAXIS o VCOMPAXIS."@es .

ns1:Parametro_VMOVAXIS a ns1:Parametro ;
    rdfs:label "Parámetro VMOVAXIS"@es ;
    ns1:identificador "VMOVAXIS" ;
    ns1:textoExtracto "En la compensación volumétrica básica, no se ha definido uno de los ejes VMOVAXIS o VCOMPAXIS."@es .

ns1:Parametro_AXISNAME a ns1:Parametro ;
    rdfs:label "Parámetro AXISNAME"@es ;
    ns1:identificador "AXISNAME" ;
    ns1:textoExtracto "Los nombres de eje válidos son los definidos en el parámetro AXISNAME."@es .

