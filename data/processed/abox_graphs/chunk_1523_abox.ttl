@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FicheroCompensacionVolumetrica a ns1:Consumible ;
    rdfs:label "Fichero de compensación volumétrica" ;
    ns1:textoExtracto "El fichero de definición de la compensación volumétrica no contiene los datos adecuados. [...] El fichero no es del tipo csv." .

ns1:ModoDiagnosis a ns1:ModoOperacion ;
    rdfs:label "Modo diagnosis" ;
    ns1:mitigaRiesgo ns1:Error_23101,
        ns1:Error_9347 ;
    ns1:textoExtracto "En el modo diagnosis se pueden consultar las opciones de software disponibles en el CNC." .

ns1:Error_23101 a ns1:AvisoSeguridad ;
    rdfs:label "Error 23101 'Error en el análisis del fichero de definición de la compensación volumétrica'" ;
    ns1:identificador "23101" ;
    ns1:solucionaFallo ns1:Parametro_VCOMPFILE ;
    ns1:textoExtracto "23101 'Error en el análisis del fichero de definición de la compensación volumétrica' [...] CAUSA El fichero de definición de la compensación volumétrica no contiene los datos adecuados." .

ns1:Error_9347 a ns1:AvisoSeguridad ;
    rdfs:label "Error 9347 'Eje repetido en VOLCOMP'" ;
    ns1:identificador "9347" ;
    ns1:solucionaFallo ns1:Parametro_VCOMPAXIS,
        ns1:Parametro_VMOVAXIS ;
    ns1:textoExtracto "9347 'Eje repetido en VOLCOMP' [...] CAUSA En los parámetros VMOVAXIS o VCOMPAXIS de la compensación volumétrica está definido el mismo eje dos veces." .

ns1:Parametro_VCOMPAXIS a ns1:Parametro ;
    rdfs:label "Parámetro VCOMPAXIS" ;
    ns1:identificador "VCOMPAXIS" ;
    ns1:textoExtracto "En los parámetros VMOVAXIS o VCOMPAXIS de la compensación volumétrica está definido el mismo eje dos veces." .

ns1:Parametro_VCOMPFILE a ns1:Parametro ;
    rdfs:label "Parámetro VCOMPFILE" ;
    ns1:identificador "VCOMPFILE" ;
    ns1:textoExtracto "El fichero definido en VCOMPFILE no es del tipo csv. [...] El fichero definido en VCOMPFILE no tiene definidos todos los puntos." .

ns1:Parametro_VMOVAXIS a ns1:Parametro ;
    rdfs:label "Parámetro VMOVAXIS" ;
    ns1:identificador "VMOVAXIS" ;
    ns1:textoExtracto "En los parámetros VMOVAXIS o VCOMPAXIS de la compensación volumétrica está definido el mismo eje dos veces." .

