@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCompensacionVolumetrica a ns1:Sistema ;
    rdfs:label "Sistema de compensación volumétrica"@es ;
    ns1:activaAlarma ns1:Error23102 ;
    ns1:textoExtracto "Error del sistema de compensación volumétrica"@es .

ns1:Error23102 a ns1:AvisoSeguridad ;
    rdfs:label "Error del sistema de compensación volumétrica"@es ;
    ns1:identificador "23102" ;
    ns1:solucionaFallo ns1:FalloCompensacionVolumetrica ;
    ns1:textoExtracto "23102 'Error del sistema de compensación volumétrica;"@es .

ns1:FalloCompensacionVolumetrica a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en compensación volumétrica por fichero VCOMPFILE incorrecto"@es ;
    ns1:textoExtracto "El formato del fichero definido en VCOMPFILE no es correcto. • El fichero definido en VCOMPFILE no tiene definidos todos los puntos. [...] SOLUCIÓN Seleccionar un fichero adecuado. En la compensación volumétrica básica, el fichero debe ser del tipo csv y tener todos los puntos definidos."@es .

