@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FicheroCSV_Compensacion a ns1:InterfazUsuario ;
    rdfs:label "Fichero CSV de compensación volumétrica" ;
    ns1:identificador "CSV_VOLCOMP" ;
    ns1:textoExtracto "Seleccionar un fichero adecuado. En la compensación volumétrica básica, el fichero debe ser del tipo csv y tener todos los puntos definidos." .

ns1:SistemaCompensacionVolumetrica a ns1:Sistema ;
    rdfs:label "Sistema de compensación volumétrica" ;
    ns1:activaAlarma ns1:Error23102,
        ns1:Error23103,
        ns1:Error23104 ;
    ns1:documentadoEn ns1:TablaVOLCOMP ;
    ns1:textoExtracto "compensación volumétrica básica [...] El CNC ha detectado un error interno en el cálculo de la compensación volumétrica" .

ns1:Error23102 a ns1:AvisoSeguridad ;
    rdfs:label "Error 23102: Error del sistema de compensación volumétrica; compensación desactivada" ;
    ns1:identificador "23102" ;
    ns1:textoExtracto "23102 'Error del sistema de compensación volumétrica; compensación desactivada' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado un error interno en el cálculo de la compensación volumétrica, y ha anulado los valores de la compensación. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error23103 a ns1:AvisoSeguridad ;
    rdfs:label "Error 23103: No se puede activar la marca VOLCOMP sin una tabla validada" ;
    ns1:identificador "23103" ;
    ns1:textoExtracto "23103 'No se puede activar la marca VOLCOMP sin una tabla validada' DETECCIÓN Durante la ejecución. CAUSA El PLC ha intentado activar una compensación volumétrica que no está definida de forma correcta y por lo tanto no es posible la compensación de la máquina. SOLUCIÓN Definir una compensación volumétrica adecuada en los parámetros máquina (parámetros VOLCOMP)." .

ns1:Error23104 a ns1:AvisoSeguridad ;
    rdfs:label "Error 23104: No se puede activar la marca VOLCOMP con otra tabla activa sobre ejes comunes" ;
    ns1:identificador "23104" ;
    ns1:textoExtracto "23104 'No se puede activar la marca VOLCOMP con otra tabla activa sobre ejes comunes' DETECCIÓN Durante la ejecución." .

ns1:TablaVOLCOMP a ns1:Tabla ;
    rdfs:label "Tabla de parámetros VOLCOMP para compensación volumétrica" ;
    ns1:identificador "VOLCOMP" ;
    ns1:textoExtracto "Definir una compensación volumétrica adecuada en los parámetros máquina (parámetros VOLCOMP)." .

