@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_VOLCOMP a ns1:ComponenteElectrico ;
    rdfs:label "Marca VOLCOMP" ;
    ns1:activaAlarma ns1:Error_23104 ;
    ns1:textoExtracto "marca VOLCOMP" .

ns1:Tabla_CompensacionesVolumetricas a ns1:Tabla ;
    rdfs:label "Tabla de compensaciones volumétricas" ;
    ns1:documentadoEn ns1:Error_23104 ;
    ns1:textoExtracto "otra tabla activa sobre ejes comunes" .

ns1:Error_23104 a ns1:AvisoSeguridad ;
    rdfs:label "Error 23104: Conflicto de compensación volumétrica" ;
    ns1:identificador "23104" ;
    ns1:textoExtracto "'No se puede activar la marca VOLCOMP con otra tabla activa sobre ejes comunes' DETECCIÓN Durante la ejecución. CAUSA El PLC ha intentado activar una compensación volumétrica con otra activa, y alguno de los ejes utilizados es común en ambas compensaciones. SOLUCIÓN No puede haber activas dos compensaciones volumétricas que tengan algún eje en común. Antes de activar una compensación, anular la activa mediante la marca de PLC correspondiente." .

