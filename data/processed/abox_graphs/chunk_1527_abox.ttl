@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InstruccionHSC a ns1:Parametro ;
    rdfs:label "Instrucción #HSC"@es ;
    ns1:habilitadoPor ns1:ModoHSC ;
    ns1:identificador "#HSC" ;
    ns1:textoExtracto "La orden para ejecutar programas [...] se realiza mediante una única instrucción, #HSC."@es .

ns1:ModoHSC_ContError a ns1:ModoOperacion ;
    rdfs:label "Modo CONTERROR (optimización de error de contorno)"@es ;
    ns1:textoExtracto "modo CONTERROR"@es .

ns1:ModoHSC_Fast a ns1:ModoOperacion ;
    rdfs:label "Modo FAST (optimización de velocidad de mecanizado)"@es ;
    ns1:textoExtracto "modo FAST"@es .

ns1:ModoHSC_Surface a ns1:ModoOperacion ;
    rdfs:label "Modo SURFACE (optimización de acabado superficial)"@es ;
    ns1:textoExtracto "modo SURFACE"@es .

ns1:TareaMecanizadoHSC a ns1:TareaMantenimiento ;
    rdfs:label "Mecanizado a alta velocidad (HSC)"@es ;
    ns1:requiereMantenimiento ns1:ModoHSC ;
    ns1:textoExtracto "mecanizado a alta velocidad"@es .

ns1:ModoHSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC"@es ;
    ns1:identificador "#HSC" ;
    ns1:textoExtracto "Modo HSC por defecto. La orden para ejecutar programas formados por muchos bloques pequeños, típicos del mecanizado a alta velocidad, se realiza mediante una única instrucción, #HSC."@es .

