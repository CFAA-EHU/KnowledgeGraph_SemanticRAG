@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC_Fagor a ns1:Maquina ;
    rdfs:label "Máquina CNC Fagor" ;
    ns1:controla ns1:ModoOperacion_HSCDEFAULTMODE_SURFACE ;
    ns1:textoExtracto "el CNC controla de una manera mucho más suave el movimiento de la máquina reduciendo notablemente las vibraciones originadas por la geometría de la pieza o la dinámica de la máquina" .

ns1:Parametro_HSCDEFAULTMODE a ns1:Parametro ;
    rdfs:label "Parámetro HSCDEFAULTMODE" ;
    ns1:identificador "HSCDEFAULTMODE" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSCDEFAULTMODE_SURFACE ;
    ns1:textoExtracto "El modo de mecanizado por defecto está definido en el parámetro HSCDEFAULTMODE" .

ns1:PiezaMecanizada_Generica a ns1:ComponenteMecanico ;
    rdfs:label "Pieza mecanizada (genérica)" ;
    ns1:textoExtracto "las vibraciones originadas por la geometría de la pieza" .

ns1:ModoOperacion_HSCDEFAULTMODE_SURFACE a ns1:ModoOperacion ;
    rdfs:label "Modo SURFACE (HSCDEFAULTMODE)" ;
    ns1:identificador "HSCDEFAULTMODE" ;
    ns1:textoExtracto "El modo de mecanizado por defecto está definido en el parámetro HSCDEFAULTMODE, donde Fagor ofrece el modo SURFACE como modo por defecto." .

