@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_CONTERROR a ns1:ModoOperacion ;
    rdfs:label "Modo CONTERROR (optimización de error cordal)" ;
    ns1:monitoreaParametro ns1:Parametro_SLOPETYPE ;
    ns1:textoExtracto "Mecanizado HSC optimizando el error cordal (modo CONTERROR). En este modo el CNC modifica la geometría mediante algoritmos inteligentes de eliminación de puntos innecesarios y generación de splines o transiciones polinómicas entre los bloques, respetando siempre los límites de error impuestos para este modo." .

ns1:Parametro_FiltrosResonancia a ns1:Parametro ;
    rdfs:label "Filtros de suavizado de trayectoria" ;
    ns1:textoExtracto "la activación de filtros para suavizar la trayectoria es innecesaria. Al no tener filtros, la pieza tendrá más precisión ya que la trayectoria pasa por los puntos programados." .

ns1:Parametro_Jerk a ns1:Parametro ;
    rdfs:label "Control de jerk" ;
    ns1:textoExtracto "Cuando el tipo de aceleración dispone de jerk, pueden darse las siguiente situaciones. • El control de jerk permite perfiles de velocidad y aceleración suficientemente suaves." .

ns1:Parametro_SLOPETYPE a ns1:Parametro ;
    rdfs:label "Parámetro SLOPETYPE (tipo de aceleración)" ;
    ns1:textoExtracto "Este modo utiliza el tipo de aceleración definido en el parámetro SLOPETYPE." .

