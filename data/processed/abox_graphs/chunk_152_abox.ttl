@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix siemens: <http://www.siemens.com/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:ProteccionSelectiva400V10KA a owl:Class ;
    rdfs:label "Protección Selectiva 400V 10KA" ;
    rdfs:comment "Interruptor de protección selectiva con voltaje de 400V y capacidad de 10KA." .

ex:InterruptorProteccionSelectiva230_400V10KA a owl:Class ;
    rdfs:label "Interruptor de Protección Selectiva 230/400V 10KA" ;
    rdfs:comment "Interruptor de protección selectiva con voltaje de 230/400V y capacidad de 10KA." .

ex:InterruptorProteccionSelectiva400V6KA a owl:Class ;
    rdfs:label "Interruptor de Protección Selectiva 400V 6KA" ;
    rdfs:comment "Interruptor de protección selectiva con voltaje de 400V y capacidad de 6KA." .

ex:InterruptorAutomaticoBornesTornillo a owl:Class ;
    rdfs:label "Interruptor Automático con Bornes de Tornillo" ;
    rdfs:comment "Interruptor automático con bornes de tornillo para protección de motores, clase 10, disposición." .

ex:BloqueProteccionDiferencial a owl:Class ;
    rdfs:label "Bloque de Protección Diferencial" ;
    rdfs:comment "Bloque de protección diferencial para interruptor de protección selectiva tipo 5SY." .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:ProteccionSelectiva400V10KA ;
    rdfs:range siemens:SiemensAG .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:InterruptorProteccionSelectiva230_400V10KA ;
    rdfs:range siemens:SiemensAG .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:InterruptorProteccionSelectiva400V6KA ;
    rdfs:range siemens:SiemensAG .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:InterruptorAutomaticoBornesTornillo ;
    rdfs:range siemens:SiemensAG .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:BloqueProteccionDiferencial ;
    rdfs:range siemens:SiemensAG .

ex:tieneModelo a owl:DatatypeProperty ;
    rdfs:domain ex:ProteccionSelectiva400V10KA ;
    rdfs:range xsd:string .

ex:tieneModelo a owl:DatatypeProperty ;
    rdfs:domain ex:InterruptorProteccionSelectiva230_400V10KA ;
    rdfs:range xsd:string .

ex:tieneModelo a owl:DatatypeProperty ;
    rdfs:domain ex:InterruptorProteccionSelectiva400V6KA ;
    rdfs:range xsd:string .

ex:tieneModelo a owl:DatatypeProperty ;
    rdfs:domain ex:InterruptorAutomaticoBornesTornillo ;
    rdfs:range xsd:string .

ex:tieneModelo a owl:DatatypeProperty ;
    rdfs:domain ex:BloqueProteccionDiferencial ;
    rdfs:range xsd:string .

ex:tieneNumeroDePolos a owl:DatatypeProperty ;
    rdfs:domain ex:ProteccionSelectiva400V10KA ;
    rdfs:range xsd:integer .

ex:tieneNumeroDePolos a owl:DatatypeProperty ;
    rdfs:domain ex:InterruptorProteccionSelectiva230_400V10KA ;
    rdfs:range xsd:integer .

ex:tieneNumeroDePolos a owl:DatatypeProperty ;
    rdfs:domain ex:InterruptorProteccionSelectiva400V6KA ;
    rdfs:range xsd:integer .

ex:tieneNumeroDePolos a owl:DatatypeProperty ;
    rdfs:domain ex:InterruptorAutomaticoBornesTornillo ;
    rdfs:range xsd:integer .

ex:tieneAmperaje a owl:DatatypeProperty ;
    rdfs:domain ex:ProteccionSelectiva400V10KA ;
    rdfs:range xsd:integer .

ex:tieneAmperaje a owl:DatatypeProperty ;
    rdfs:domain ex:InterruptorProteccionSelectiva230_400V10KA ;
    rdfs:range xsd:integer .

ex:tieneAmperaje a owl:DatatypeProperty ;
    rdfs:domain ex:InterruptorProteccionSelectiva400V6KA ;
    rdfs:range xsd:integer .

ex:tieneAmperaje a owl:DatatypeProperty ;
    rdfs:domain ex:InterruptorAutomaticoBornesTornillo ;
    rdfs:range xsd:integer .

ex:tieneProteccion a owl:DatatypeProperty ;
    rdfs:domain ex:ProteccionSelectiva400V10KA ;
    rdfs:range xsd:string .

ex:tieneProteccion a owl:DatatypeProperty ;
    rdfs:domain ex:InterruptorProteccionSelectiva230_400V10KA ;
    rdfs:range xsd:string .

ex:tieneProteccion a owl:DatatypeProperty ;
    rdfs:domain ex:InterruptorProteccionSelectiva400V6KA ;
    rdfs:range xsd:string .

ex:tieneProteccion a owl:DatatypeProperty ;
    rdfs:domain ex:InterruptorAutomaticoBornesTornillo ;
    rdfs:range xsd:string .

siemens:SiemensAG a owl:Class ;
    rdfs:label "Siemens AG" ;
    rdfs:comment "Empresa fabricante de los componentes listados." .