@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_HSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC (High Speed Cutting)" ;
    ns1:monitoreaParametro ns1:Parametro_CORNERJERK,
        ns1:Parametro_SMOOTHFREQ ;
    ns1:textoExtracto "Al intentar el modo HSC respetar el jerk a lo largo de la trayectoria pueden aparecer irregularidades más pronunciadas en el perfil de velocidad, sobre todo en las aristas, y por lo tanto afectar al acabado superficial." .

ns1:PolinomioRedondeo_CNC a ns1:Componente ;
    rdfs:label "Polinomio de redondeo del CNC" ;
    ns1:textoExtracto "ejecuta un polinomio de redondeo que pasa a una distancia del punto programado inferior al límite de error" .

ns1:Spline_CNC a ns1:Componente ;
    rdfs:label "Spline del CNC" ;
    ns1:textoExtracto "La excepción ocurre en los tramos donde el CNC desconecta la spline porque ésta supera el límite de error, en cuyo caso ejecuta un polinomio de redondeo que pasa a una distancia del punto programado inferior al límite de error." .

ns1:Parametro_CORNERJERK a ns1:Parametro ;
    rdfs:label "CORNERJERK" ;
    ns1:textoExtracto "se puede ampliar el jerk en las aristas (parámetro CORNERJERK)" ;
    ns1:valor "jerk en aristas" .

ns1:Parametro_SMOOTHFREQ a ns1:Parametro ;
    rdfs:label "SMOOTHFREQ" ;
    ns1:textoExtracto "aplicar la frecuencia de suavizado en la interpolación de la trayectoria (parámetro SMOOTHFREQ)" ;
    ns1:valor "frecuencia de suavizado" .

