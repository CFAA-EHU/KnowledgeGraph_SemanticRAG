@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Frecuencia_Suavizado a ns1:Frecuencia ;
    rdfs:label "Frecuencia de suavizado" ;
    ns1:textoExtracto "Al activar la frecuencia de suavizado se generan perfiles de velocidad y aceleración más suaves, pero aumenta el tiempo de ejecución." .

ns1:ModoOperacion_FAST a ns1:ModoOperacion ;
    rdfs:label "Modo FAST (optimización de avance)" ;
    ns1:habilitadoPor ns1:ModoOperacion_HSC ;
    ns1:identificador "FAST" ;
    ns1:textoExtracto "Mecanizado HSC optimizando el avance (modo FAST)." .

ns1:ModoOperacion_HSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC (High Speed Cutting)" ;
    ns1:identificador "HSC" ;
    ns1:monitoreaParametro ns1:Parametro_FILTER,
        ns1:Parametro_HSCFILTFREQ ;
    ns1:textoExtracto "Mecanizado HSC optimizando el avance (modo FAST). Es el modo recomendado de" .

ns1:Parametro_FILTER a ns1:Parametro ;
    rdfs:label "Parámetro de filtro (FILTER)" ;
    ns1:identificador "FILTER" ;
    ns1:textoExtracto "Los efectos de los filtros definidos mediante el parámetro FILTER" .

ns1:Parametro_HSCFILTFREQ a ns1:Parametro ;
    rdfs:label "Frecuencia de filtro para modo CONTERROR (HSCFILTFREQ)" ;
    ns1:identificador "HSCFILTFREQ" ;
    ns1:textoExtracto "parámetro HSCFILTFREQ para el modo CONTERROR." .

