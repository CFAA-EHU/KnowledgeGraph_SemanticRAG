@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_HSC a ns1:Maquina ;
    rdfs:label "Máquina HSC (High-Speed Cutting)" ;
    ns1:monitoreaParametro ns1:Parametro_FILTER,
        ns1:Parametro_HSCFILTFREQ ;
    ns1:textoExtracto "la dinámica de la máquina no responde en un margen amplio de frecuencias; es decir, la máquina presenta resonancias o un ancho de banda limitado." .

ns1:ModoOperacion_HSC_CONTERROR a ns1:ModoOperacion ;
    rdfs:label "Modo CONTERROR (HSC con filtro de error)" ;
    ns1:identificador "CONTERROR" ;
    ns1:textoExtracto "parámetro HSCFILTFREQ para el modo CONTERROR. [...] Cuando en el modo CONTERROR no se obtienen los resultados deseados. [...] la ejecución es más lenta y en las superficies mecanizadas puede aparecer el efecto de facetado." .

ns1:ModoOperacion_HSC_FAST a ns1:ModoOperacion ;
    rdfs:label "Modo FAST (HSC optimizado para avance)" ;
    ns1:identificador "FAST" ;
    ns1:textoExtracto "Mecanizado HSC optimizando el avance (modo FAST). Es el modo recomendado de trabajo en las siguientes circunstancias: [...] En el modo FAST se logra una superficie mecanizada más suave y una velocidad más continua." .

ns1:Parametro_FILTER a ns1:Parametro ;
    rdfs:label "Parámetro FILTER (filtros activos en HSC)" ;
    ns1:identificador "FILTER" ;
    ns1:textoExtracto "el parámetro FILTER se suman a los efectos de los filtros activos en HSC" .

ns1:Parametro_HSCFILTFREQ a ns1:Parametro ;
    rdfs:label "Parámetro HSCFILTFREQ (frecuencia de filtro en CONTERROR)" ;
    ns1:identificador "HSCFILTFREQ" ;
    ns1:textoExtracto "parámetro HSCFILTFREQ para el modo CONTERROR" .

