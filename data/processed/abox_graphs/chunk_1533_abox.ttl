@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC" ;
    ns1:controla ns1:ModoOperacion_FAST ;
    ns1:monitoreaParametro ns1:Parametro_FASTFACTOR,
        ns1:Parametro_LACC1,
        ns1:Parametro_LACC2,
        ns1:Parametro_SLOPETYPE ;
    ns1:textoExtracto "el máximo que es capaz de alcanzar el CNC en función de como se hayan parametrizado los parámetros LACC1 y LACC2." .

ns1:ModoOperacion_FAST a ns1:ModoOperacion ;
    rdfs:label "Modo FAST" ;
    ns1:monitoreaParametro ns1:Parametro_FASTFACTOR,
        ns1:Parametro_LACC1,
        ns1:Parametro_LACC2,
        ns1:Parametro_SLOPETYPE ;
    ns1:textoExtracto "En el modo FAST se logra una superficie mecanizada más suave y una velocidad más continua." .

ns1:Parametro_FASTFACTOR a ns1:Parametro ;
    rdfs:label "FASTFACTOR" ;
    ns1:identificador "FASTFACTOR" ;
    ns1:textoExtracto "si no se define, se asume el porcentaje definido en el parámetro FASTFACTOR." ;
    ns1:valor "porcentaje de avance por defecto en modo FAST" .

ns1:Parametro_LACC1 a ns1:Parametro ;
    rdfs:label "LACC1" ;
    ns1:identificador "LACC1" ;
    ns1:textoExtracto "el máximo que es capaz de alcanzar el CNC en función de como se hayan parametrizado los parámetros LACC1 y LACC2." ;
    ns1:valor "parámetro de aceleración lineal" .

ns1:Parametro_LACC2 a ns1:Parametro ;
    rdfs:label "LACC2" ;
    ns1:identificador "LACC2" ;
    ns1:textoExtracto "el máximo que es capaz de alcanzar el CNC en función de como se hayan parametrizado los parámetros LACC1 y LACC2." ;
    ns1:valor "parámetro de aceleración lineal" .

ns1:Parametro_SLOPETYPE a ns1:Parametro ;
    rdfs:label "SLOPETYPE" ;
    ns1:identificador "SLOPETYPE" ;
    ns1:textoExtracto "independientemente de lo definido en el parámetro SLOPETYPE." ;
    ns1:valor "tipo de pendiente de aceleración (ignorado en modo FAST)" .

