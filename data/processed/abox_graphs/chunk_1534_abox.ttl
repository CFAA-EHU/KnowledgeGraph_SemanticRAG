@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_HSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC (High Speed Cutting)" ;
    ns1:textoExtracto "modo HSC" ;
    ns1:tieneComponente ns1:FiltroEjes_HSC .

ns1:Parametro_FASTFILTFREQ a ns1:Parametro ;
    rdfs:label "FASTFILTFREQ" ;
    ns1:identificador "FASTFILTFREQ" ;
    ns1:monitoreaParametro ns1:FiltroEjes_HSC ;
    ns1:textoExtracto "La frecuencia de este filtro para todos los ejes se parametriza en el parámetro FASTFILTFREQ." .

ns1:PerfilAceleracion_HSC a ns1:Parametro ;
    rdfs:label "Perfil de aceleración en modo HSC" ;
    ns1:textoExtracto "perfiles de velocidad y aceleración más suaves pero de menor precisión en las esquinas" .

ns1:PerfilVelocidad_HSC a ns1:Parametro ;
    rdfs:label "Perfil de velocidad en modo HSC" ;
    ns1:textoExtracto "perfiles de velocidad y aceleración más suaves pero de menor precisión en las esquinas" .

ns1:FiltroEjes_HSC a ns1:ComponenteElectrico ;
    rdfs:label "Filtro de suavizado para ejes en modo HSC" ;
    ns1:controla ns1:PerfilAceleracion_HSC,
        ns1:PerfilVelocidad_HSC ;
    ns1:textoExtracto "filtro para todos los ejes, que se introduce automáticamente, para suavizar el movimiento de la máquina" .

