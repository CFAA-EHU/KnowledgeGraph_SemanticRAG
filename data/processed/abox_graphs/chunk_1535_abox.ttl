@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_FAST a ns1:ModoOperacion ;
    rdfs:label "Modo FAST" ;
    ns1:monitoreaParametro ns1:Parametro_FASTFILTFREQ ;
    ns1:textoExtracto "parámetro FASTFILTFREQ para el modo FAST" .

ns1:ModoOperacion_HSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC" ;
    ns1:monitoreaParametro ns1:Parametro_FILTER ;
    ns1:textoExtracto "efectos de los filtros definidos mediante el parámetro FILTER se suman a los efectos de los filtros activos en HSC" .

ns1:Sistema_ControlVelocidad a ns1:Sistema ;
    rdfs:label "Sistema de control de velocidad y aceleración" ;
    ns1:controla ns1:Maquina_Principal ;
    ns1:monitoreaParametro ns1:Parametro_FASTFILTFREQ,
        ns1:Parametro_FILTER ;
    ns1:textoExtracto "perfiles de velocidad y aceleración más suaves pero de menor precisión en las esquinas, dependiendo de la geometría y del tipo de filtro" .

ns1:Maquina_Principal a ns1:Maquina ;
    rdfs:label "Máquina" ;
    ns1:textoExtracto "margen de frecuencias de la máquina" .

ns1:Parametro_FASTFILTFREQ a ns1:Parametro ;
    rdfs:label "FASTFILTFREQ" ;
    ns1:textoExtracto "parámetro FASTFILTFREQ" ;
    ns1:valor "frecuencia de filtro rápido" .

ns1:Parametro_FILTER a ns1:Parametro ;
    rdfs:label "FILTER" ;
    ns1:textoExtracto "parámetro FILTER" ;
    ns1:valor "filtro de frecuencia" .

