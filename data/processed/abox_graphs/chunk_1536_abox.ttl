@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_CONTERROR a ns1:ModoOperacion ;
    rdfs:label "CONTERROR"@es ;
    ns1:habilitadoPor ns1:Parametro_HSCFILTFREQ ;
    ns1:textoExtracto "Modo de control de error de trayectoria activado durante la ejecución HSC, compatible con filtros de suavizado (HSCFILTFREQ)."@es .

ns1:ModoOperacion_HSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC"@es ;
    ns1:textoExtracto "Modo de alta velocidad de corte (HSC) con parámetros configurables para optimización de trayectorias y mecanizado."@es .

ns1:Parametro_CORNER a ns1:Parametro ;
    rdfs:label "CORNER"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosHSC_1275 ;
    ns1:identificador "CORNER MPG" ;
    ns1:textoExtracto "Este parámetro indica el ángulo máximo entre dos trayectorias, por debajo del cual se mecaniza en arista viva."@es .

ns1:Parametro_FEEDAVRG a ns1:Parametro ;
    rdfs:label "FEEDAVRG"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosHSC_1275 ;
    ns1:identificador "FEEDAVRG MPG" ;
    ns1:textoExtracto "Este parámetro habilita el ajuste del avance en función de la velocidad de lectura de bloques y del tamaño de los mismos. Este ajuste evita tener que frenar por un suministro inadecuado de bloques pequeños; aunque como consecuencia de ello la velocidad alcanzada sea menor, el tiempo total de mecanizado mejorará."@es .

ns1:Parametro_HSCDEFAULMODE a ns1:Parametro ;
    rdfs:label "HSCDEFAULMODE"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosHSC_1275 ;
    ns1:identificador "HSCDEFAULMODE MPG" ;
    ns1:textoExtracto "Modo por defecto al programar #HSC ON."@es .

ns1:Parametro_SMOOTHFREQ a ns1:Parametro ;
    rdfs:label "SMOOTHFREQ"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosHSC_1275 ;
    ns1:identificador "SMOOTHFREQ MPG" ;
    ns1:textoExtracto "Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias. Este parámetro evita acelerar y decelerar a lo largo de una trayectoria, por encima de una determinada frecuencia al generar una velocidad promediada."@es .

ns1:Parametro_HSCFILTFREQ a ns1:Parametro ;
    rdfs:label "HSCFILTFREQ"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosHSC_1275 ;
    ns1:identificador "HSCFILTFREQ MPG" ;
    ns1:textoExtracto "Este parámetro activa un filtro automático FIR para todos los ejes del canal durante la ejecución en modo CONTERROR. Este filtro permite suavizar la respuesta de los ejes generando una trayectoria más suave, y en caso necesario, reducir el avance para que el error de trayectoria se ajuste al programado."@es .

ns1:Tabla_ParametrosHSC_1275 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de configuración HSC (páginas 621-622)"@es ;
    ns1:documentadoEn ns1:Manual_ConfiguracionHSC ;
    ns1:textoExtracto """
| Parámetro. |  | Significado. |
| --- | --- | --- |
| HSCDEFAULMODE MPG |  | Modo por defecto al programar #HSC ON. |
| FEEDAVRG MPG |  | Este parámetro habilita el ajuste del avance en función de la velocidad de lectura de bloques... |
| SMOOTHFREQ MPG |  | Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias... |
| CORNER MPG |  | Este parámetro indica el ángulo máximo entre dos trayectorias... |
| HSCFILTFREQ MPG |  | Este parámetro activa un filtro automático FIR para todos los ejes del canal durante la ejecución en modo CONTERROR..."""@es .

