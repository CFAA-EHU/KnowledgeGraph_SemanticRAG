@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_FASTFILTFREQ_MPG a ns1:Parametro ;
    rdfs:label "FASTFILTFREQ MPG" ;
    ns1:documentadoEn ns1:Tabla_ParametrosHSC_1278 ;
    ns1:identificador "FASTFILTFREQ MPG" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC_FAST ;
    ns1:textoExtracto "Este parámetro activa un filtro \"paso bajo\" automático para todos los ejes del canal durante la ejecución en modo HSC FAST, el cuál permite suavizar la respuesta de los ejes generando una trayectoria más suave. Este filtro tiene el inconveniente de redondear ligeramente las aristas. Este parámetro introduce un desfase constante, independiente de las frecuencias."@es .

ns1:Parametro_FREQRES_MPG a ns1:Parametro ;
    rdfs:label "FREQRES MPG" ;
    ns1:documentadoEn ns1:Tabla_ParametrosHSC_1278 ;
    ns1:identificador "FREQRES MPG" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC_CONTERROR ;
    ns1:textoExtracto "Frecuencia de resonancia que el CNC debe eliminar en la generación de la consigna. Este parámetro sólo es válido cuando el perfil de aceleración es trapezoidal o seno cuadrado (parámetro SLOPETYPE), que es el perfil de aceleración por defecto para el modo HSC CONTERROR."@es .

ns1:Parametro_HSCROUND_MPG a ns1:Parametro ;
    rdfs:label "HSCROUND MPG" ;
    ns1:documentadoEn ns1:Tabla_ParametrosHSC_1278 ;
    ns1:identificador "HSCROUND MPG" ;
    ns1:textoExtracto "Valor por defecto del error máximo de la trayectoria en HSC."@es .

ns1:Parametro_SOFTFREQ_MPG a ns1:Parametro ;
    rdfs:label "SOFTFREQ MPG" ;
    ns1:documentadoEn ns1:Tabla_ParametrosHSC_1278 ;
    ns1:identificador "SOFTFREQ MPG" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC_FAST ;
    ns1:textoExtracto "Frecuencia del filtro de trayectoria para perfiles de aceleración lineal. Este parámetro permite suavizar el perfil de velocidad en modo HSC FAST, lo que permite mejorar el tiempo y la calidad superficial del mecanizado. Este parámetro se debe ajustar con ayuda de la aplicación FineTune."@es .

ns1:Parametro_SURFFILFREQ_MPG a ns1:Parametro ;
    rdfs:label "SURFFILFREQ MPG" ;
    ns1:documentadoEn ns1:Tabla_ParametrosHSC_1278 ;
    ns1:identificador "SURFFILFREQ MPG" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC_SURFACE ;
    ns1:textoExtracto "Este parámetro activa un filtro automático para todos los ejes del canal durante la ejecución en modo HSC SURFACE, el cuál permite suavizar la respuesta de los ejes generando una trayectoria más suave."@es .

ns1:ModoOperacion_HSC_CONTERROR a ns1:ModoOperacion ;
    rdfs:label "Modo HSC CONTERROR"@es ;
    ns1:textoExtracto "modo HSC CONTERROR"@es .

ns1:ModoOperacion_HSC_SURFACE a ns1:ModoOperacion ;
    rdfs:label "Modo HSC SURFACE"@es ;
    ns1:textoExtracto "modo HSC SURFACE"@es .

ns1:ModoOperacion_HSC_FAST a ns1:ModoOperacion ;
    rdfs:label "Modo HSC FAST"@es ;
    ns1:textoExtracto "modo HSC FAST"@es .

ns1:Tabla_ParametrosHSC_1278 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de configuración HSC (pág. 621-622)"@es ;
    ns1:documentadoEn ns1:Manual_ConfiguracionHSC ;
    ns1:textoExtracto """
| Parámetro. |  | Significado. |
| --- | --- | --- |
| FASTFILTFREQ MPG |  | Este parámetro activa un filtro "paso bajo" automático para todos los ejes del canal durante la ejecución en modo HSC FAST...
| FREQRES MPG |  | Frecuencia de resonancia que el CNC debe eliminar en la generación de la consigna...
| SOFTFREQ MPG |  | Frecuencia del filtro de trayectoria para perfiles de aceleración lineal...
| HSCROUND MPG |  | Valor por defecto del error máximo de la trayectoria en HSC...
| SURFFILFREQ MPG |  | Este parámetro activa un filtro automático para todos los ejes del canal durante la ejecución en modo HSC SURFACE..."""@es .

