@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_FAST a ns1:ModoOperacion ;
    rdfs:label "Modo FAST"@es ;
    ns1:monitoreaParametro ns1:Parametro_FASTACC_MPA ;
    ns1:textoExtracto "modo FAST"@es .

ns1:Parametro_CORNERACC_MPA a ns1:Parametro ;
    rdfs:label "CORNERACC MPA" ;
    ns1:documentadoEn ns1:Tabla_ParametrosEje_1279 ;
    ns1:identificador "CORNERACC MPA" ;
    ns1:textoExtracto "Este parámetro define la aceleración máxima que se va a permitir al eje en la transición de bloques. Si este parámetro se define con valor ꞏ0ꞏ, se respeta la aceleración máxima del eje."@es ;
    ns1:valor "0" .

ns1:Parametro_CORNERJERK_MPA a ns1:Parametro ;
    rdfs:label "CORNERJERK MPA" ;
    ns1:documentadoEn ns1:Tabla_ParametrosEje_1279 ;
    ns1:identificador "CORNERJERK MPA" ;
    ns1:textoExtracto "Jerk máximo permitido en las esquinas. Si este parámetro se define con valor ꞏ0ꞏ, se respeta el jerk máximo del eje."@es ;
    ns1:valor "0" .

ns1:Parametro_CURVACC_MPA a ns1:Parametro ;
    rdfs:label "CURVACC MPA" ;
    ns1:documentadoEn ns1:Tabla_ParametrosEje_1279 ;
    ns1:identificador "CURVACC MPA" ;
    ns1:textoExtracto "Aceleración máxima permitida en curvatura. Si este parámetro se define con valor ꞏ0ꞏ, se respeta la aceleración máxima del eje."@es ;
    ns1:valor "0" .

ns1:Parametro_CURVJERK_MPA a ns1:Parametro ;
    rdfs:label "CURVJERK MPA" ;
    ns1:documentadoEn ns1:Tabla_ParametrosEje_1279 ;
    ns1:identificador "CURVJERK MPA" ;
    ns1:textoExtracto "Jerk máximo permitido en curvatura. Si este parámetro se define con valor ꞏ0ꞏ, se respeta el jerk máximo del eje."@es ;
    ns1:valor "0" .

ns1:Parametro_MAXERROR_MPA a ns1:Parametro ;
    rdfs:label "MAXERROR MPA" ;
    ns1:documentadoEn ns1:Tabla_ParametrosEje_1279 ;
    ns1:identificador "MAXERROR MPA" ;
    ns1:textoExtracto "Error de posición. Máximo error de posición del eje en HSC cuando trabaja fuera del plano/triedo."@es .

ns1:Parametro_FASTACC_MPA a ns1:Parametro ;
    rdfs:label "FASTACC MPA" ;
    ns1:documentadoEn ns1:Tabla_ParametrosEje_1279 ;
    ns1:identificador "FASTACC MPA" ;
    ns1:textoExtracto "Aceleración máxima permitida (modo FAST). Si este parámetro se define con valor ꞏ0ꞏ, se respeta la aceleración máxima del eje."@es ;
    ns1:valor "0" .

ns1:Tabla_ParametrosEje_1279 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de eje (MPA)"@es ;
    ns1:documentadoEn ns1:Pagina_622 ;
    ns1:textoExtracto "CORNERACC MPA | CURVACC MPA | CORNERJERK MPA | CURVJERK MPA | FASTACC MPA | MAXERROR MPA"@es .

