@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_INT a ns1:ModoOperacion ;
    rdfs:label "Modo aplicación externa (INT)"@es ;
    ns1:documentadoEn ns1:Tabla_13.3_Variables ;
    ns1:textoExtracto "una aplicación externa (INT)"@es .

ns1:ModoOperacion_MDA a ns1:ModoOperacion ;
    rdfs:label "Modo MDA"@es ;
    ns1:textoExtracto "modo MDI/MDA"@es .

ns1:ModoOperacion_MDI a ns1:ModoOperacion ;
    rdfs:label "Modo MDI"@es ;
    ns1:textoExtracto "modo MDI/MDA"@es .

ns1:ModoOperacion_PLC a ns1:ModoOperacion ;
    rdfs:label "Modo PLC"@es ;
    ns1:documentadoEn ns1:Tabla_13.3_Variables ;
    ns1:textoExtracto "modo PLC"@es .

ns1:Parametro_AccesoSincrono a ns1:Parametro ;
    rdfs:label "Acceso síncrono a variables desde PLC"@es ;
    ns1:documentadoEn ns1:Tabla_13.3_Variables ;
    ns1:textoExtracto "El acceso a las variables desde el PLC, tanto para la lectura como para la escritura, será síncrono."@es .

ns1:Parametro_PreparacionBloques a ns1:Parametro ;
    rdfs:label "Valor de preparación de bloques"@es ;
    ns1:documentadoEn ns1:Tabla_13.3_Variables ;
    ns1:textoExtracto "El acceso a las variables desde el programa pieza devuelve el valor de la preparación de bloques"@es .

ns1:ProgramaPieza_PRG a ns1:InterfazUsuario ;
    rdfs:label "Programa pieza (PRG)"@es ;
    ns1:documentadoEn ns1:Tabla_13.3_Variables ;
    ns1:textoExtracto "programa pieza (PRG)"@es .

ns1:Tabla_13.3_Variables a ns1:Tabla ;
    rdfs:label "Tabla de variables accesibles desde PRG, MDI/MDA, PLC e INT"@es ;
    ns1:identificador "13.3" ;
    ns1:textoExtracto "La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W)."@es .

