@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_CNC_623 a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de usuario del CNC (pág. 623)" ;
    ns1:ilustradoEn ns1:Sistema_CNC_13_3_1 ;
    ns1:textoExtracto "Aplicaciones que necesitan tiempo del sistema operativo son, por ejemplo, [...] las aplicaciones de interface de usuario, el refresco de variables en la pantalla [...]" .

ns1:Parametro_LOOPTIME a ns1:Parametro ;
    rdfs:label "LOOPTIME" ;
    ns1:identificador "LOOPTIME" ;
    ns1:textoExtracto "Si el tiempo libre para las aplicaciones es insuficiente, se puede optar por [...] aumentar el parámetro LOOPTIME [...]" .

ns1:Parametro_PREPFREQ a ns1:Parametro ;
    rdfs:label "PREPFREQ" ;
    ns1:identificador "PREPFREQ" ;
    ns1:textoExtracto "Si el tiempo libre para las aplicaciones es insuficiente, se puede optar por disminuir el parámetro PREPFREQ [...]" .

ns1:Tabla_VariablesTiempoCiclo_623 a ns1:Tabla ;
    rdfs:label "Tabla de variables del tiempo de ciclo (pág. 623)" ;
    ns1:documentadoEn ns1:Sistema_CNC_13_3_1 ;
    ns1:identificador "Tabla 13.3.1-A" ;
    ns1:textoExtracto "Variables | PRG | PLC | INT --- (V.)G.NCTIMERATE [...]" .

ns1:Parametro_GNCTIMERATE a ns1:Parametro ;
    rdfs:label "G.NCTIMERATE" ;
    ns1:identificador "G.NCTIMERATE" ;
    ns1:textoExtracto "Porcentaje del tiempo de ciclo que utiliza la parte de tiempo real de CNC. Esta variable sirve para evaluar la carga del sistema y el tiempo que la interrupción periódica que controla el movimiento de los ejes deja al sistema operativo para gestionar otras aplicaciones que puedan ejecutarse en paralelo al CNC." ;
    ns1:valor "%" .

ns1:Sistema_CNC_13_3_1 a ns1:Sistema ;
    rdfs:label "Sistema CNC (Sección 13.3.1)" ;
    ns1:monitoreaParametro ns1:Parametro_GNCTIMERATE ;
    ns1:textoExtracto "Sistema CNC descrito en el análisis del tiempo de ciclo (Sección 13.3.1)." .

