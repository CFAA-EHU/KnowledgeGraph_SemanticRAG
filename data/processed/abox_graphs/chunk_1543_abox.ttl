@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:monitoreaParametro ns1:Parametro_V_G_LOOPTIMERATE,
        ns1:Parametro_V_G_NCTIMERATE ;
    ns1:textoExtracto "sistema está sobrecargado por los ejes y por tanto habrá que valorar la posibilidad de aumentar el parámetro LOOPTIME." .

ns1:Parametro_V_G_LOOPTIMERATE a ns1:Parametro ;
    rdfs:label "V.G.LOOPTIMERATE" ;
    ns1:identificador "V.G.LOOPTIMERATE" ;
    ns1:textoExtracto "Porcentaje del tiempo de ciclo que utiliza el lazo de posición. Esta variable sirve de referencia para saber si el consumo de tiempo de interrupción es debido al número de ejes o al propio proceso de preparación de la trayectoria." ;
    ns1:valor "%"^^xsd:string .

ns1:Parametro_V_G_NCTIMERATE a ns1:Parametro ;
    rdfs:label "V.G.NCTIMERATE" ;
    ns1:identificador "V.G.NCTIMERATE" ;
    ns1:textoExtracto "El CNC evalúa la variable durante la ejecución (detiene la preparación de bloques)." .

