@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_CHTIMERATE a ns1:Parametro ;
    rdfs:label "CHTIMERATE"@es ;
    ns1:documentadoEn ns1:Tabla_AnalisisTiempoCiclo_1283 ;
    ns1:identificador "V.[ch].G.CHTIMERATE" ;
    ns1:textoExtracto "Porcentaje del tiempo de ciclo que utiliza el canal. Esta variable ayuda a determinar si es la ejecución concreta de un canal la que está consumiendo demasiado tiempo. Unidades: %."@es ;
    ns1:valor "%" .

ns1:Parametro_IPOTIMERATE a ns1:Parametro ;
    rdfs:label "IPOTIMERATE"@es ;
    ns1:documentadoEn ns1:Tabla_AnalisisTiempoCiclo_1283 ;
    ns1:identificador "V.[ch].G.IPOTIMERATE" ;
    ns1:textoExtracto "Porcentaje del tiempo de ciclo que utiliza el interpolador del canal. Esta variable sirve para evaluar la sobrecarga en el algoritmo de generación de trayectoria y en el algoritmo de suavizado. Unidades: %."@es ;
    ns1:valor "%" .

ns1:Parametro_PREPFREQ a ns1:Parametro ;
    rdfs:label "PREPFREQ"@es ;
    ns1:documentadoEn ns1:Tabla_AnalisisTiempoCiclo_1283 ;
    ns1:textoExtracto "Parámetro mencionado en la descripción de PREPTIMERATE para evaluar la posibilidad de aumento en la preparación de bloques."@es .

ns1:Parametro_PREPTIMERATE a ns1:Parametro ;
    rdfs:label "PREPTIMERATE"@es ;
    ns1:documentadoEn ns1:Tabla_AnalisisTiempoCiclo_1283 ;
    ns1:identificador "V.[ch].G.PREPTIMERATE" ;
    ns1:textoExtracto "Porcentaje del tiempo de ciclo que utiliza el canal para la preparación de bloques. Esta variable sirve para evaluar la carga en la preparación de la trayectoria y saber si es posible aumentar el parámetro PREPFREQ. Unidades: %."@es ;
    ns1:valor "%" .

ns1:Tabla_AnalisisTiempoCiclo_1283 a ns1:Tabla ;
    rdfs:label "Tabla de variables de análisis del tiempo de ciclo en el canal"@es ;
    ns1:documentadoEn ns1:Pagina_624 ;
    ns1:textoExtracto """
| Variables. | PRG | PLC | INT |
| --- | --- | --- | --- |
| (V.)[ch].G.CHTIMERATE
Porcentaje del tiempo de ciclo que utiliza el canal. Esta variable ayuda
a determinar si es la ejecución concreta de un canal la que está
consumiendo demasiado tiempo. Unidades: %. | R(*) | R | R |
| (V.)[ch].G.PREPTIMERATE
Porcentaje del tiempo de ciclo que utiliza el canal para la preparación
de bloques. Esta variable sirve para evaluar la carga en la preparación
de la trayectoria y saber si es posible aumentar el parámetro
PREPFREQ. Unidades: %. | R(*) | R | R |
| (V.)[ch].G.IPOTIMERATE
Porcentaje del tiempo de ciclo que utiliza el interpolador del canal. Esta
variable sirve para evaluar la sobrecarga en el algoritmo de generación
de trayectoria y en el algoritmo de suavizado. Unidades: %. | R(*) | R | R |
 (*) El CNC evalúa la variable durante la ejecución (detiene la preparación de bloques)."""@es .

