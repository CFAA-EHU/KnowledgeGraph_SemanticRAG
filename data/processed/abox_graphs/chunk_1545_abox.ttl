@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_BLKN a ns1:Parametro ;
    rdfs:label "V.G.BLKN" ;
    ns1:documentadoEn ns1:Tabla_1284_VariablesAvance ;
    ns1:identificador "V.G.BLKN" ;
    ns1:textoExtracto "Variable para asociar cambios de avance con bloques de programa."@es .

ns1:Parametro_FREAL a ns1:Parametro ;
    rdfs:label "(V.)[ch].G.FREAL" ;
    ns1:documentadoEn ns1:Tabla_1284_VariablesAvance ;
    ns1:identificador "(V.)[ch].G.FREAL" ;
    ns1:monitoreaParametro ns1:Maquina_CNC ;
    ns1:textoExtracto "Avance real filtrado sobre la trayectoria. Esta variable tiene en cuenta el override y las aceleraciones y deceleraciones de la máquina. Unidades: Milímetros/minuto o pulgadas/minuto."@es ;
    ns1:valor "Milímetros/minuto o pulgadas/minuto"@es .

ns1:Parametro_LINEN a ns1:Parametro ;
    rdfs:label "V.G.LINEN" ;
    ns1:documentadoEn ns1:Tabla_1284_VariablesAvance ;
    ns1:identificador "V.G.LINEN" ;
    ns1:textoExtracto "Variable para asociar cambios de avance con líneas de programa."@es .

ns1:Parametro_PATHFEED a ns1:Parametro ;
    rdfs:label "(V.)[ch].G.PATHFEED" ;
    ns1:documentadoEn ns1:Tabla_1284_VariablesAvance ;
    ns1:identificador "(V.)[ch].G.PATHFEED" ;
    ns1:monitoreaParametro ns1:Maquina_CNC ;
    ns1:textoExtracto "Avance teórico sobre la trayectoria. Unidades: Milímetros/minuto o pulgadas/minuto."@es ;
    ns1:valor "Milímetros/minuto o pulgadas/minuto"@es .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "CNC"@es ;
    ns1:textoExtracto "El CNC evalúa la variable durante la ejecución (detiene la preparación de bloques). Comparando en el osciloscopio el avance real con el teórico a largo de la trayectoria se pueden detectar problemas de ajuste si ambos divergen en puntos concretos."@es .

ns1:Tabla_1284_VariablesAvance a ns1:Tabla ;
    rdfs:label "Tabla de variables de avance sobre trayectoria (pág. 624)"@es ;
    ns1:textoExtracto """
| Variables. | PRG | PLC | INT |
| --- | --- | --- | --- |
| (V.)[ch].G.PATHFEED
Avance teórico sobre la trayectoria. Unidades: Milímetros/minuto o pulgadas/minuto. | R(*) | R | R |
| (V.)[ch].G.FREAL
Avance real filtrado sobre la trayectoria. Esta variable tiene en cuenta
el override y las aceleraciones y deceleraciones de la máquina. Unidades: Milímetros/minuto o pulgadas/minuto. | R(*) | R | R
(*) El CNC evalúa la variable durante la ejecución (detiene la preparación de bloques)."""@es .

