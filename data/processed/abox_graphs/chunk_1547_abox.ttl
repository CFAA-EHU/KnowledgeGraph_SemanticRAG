@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ModoOperacion_CONTERROR a ns1:ModoOperacion ;
    rdfs:label "Modo CONTERROR" ;
    ns1:controla ns1:Sistema_CNC ;
    ns1:identificador "CONTERROR" ;
    ns1:textoExtracto "Modo de control de error que utiliza la variable LIMERROR para desactivar splines cuando se supera un umbral de error." .

ns1:ModoOperacion_HSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC" ;
    ns1:controla ns1:Sistema_CNC ;
    ns1:identificador "HSC" ;
    ns1:textoExtracto "Modo de alta velocidad de corte (HSC) donde variables como PERFRATE y DROPRATE determinan la optimización del avance." .

ns1:Parametro_DROPRATE a ns1:Parametro ;
    rdfs:label "Variable (V.)[ch].G.DROPRATE" ;
    ns1:identificador "(V.)[ch].G.DROPRATE" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "Porcentaje de reducción del avance máximo alcanzable. La reducción del avance puede ser debida a un suministro inadecuado de bloques o a un avance programado inferior al posible. Esta variable debe devolver un valor próximo a 100; si el valor es inferior al 100 %, es posible que el CNC pueda aumentar el avance si tuviera más bloques." ;
    ns1:valor 100 .

ns1:Parametro_LIMERROR a ns1:Parametro ;
    rdfs:label "Variable (V.)[ch].G.LIMERROR" ;
    ns1:identificador "(V.)[ch].G.LIMERROR" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "Valor del error que desactiva las splines (modo CONTERROR). Esta variable permite valorar si el programa está generado con más error del que pedimos al modo HSC." .

ns1:Parametro_NCTIMERATE a ns1:Parametro ;
    rdfs:label "Variable V.G.NCTIMERATE" ;
    ns1:identificador "V.G.NCTIMERATE" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "Porcentaje de tiempo de ciclo que utiliza el CNC. Esta información se puede consultar en la variable V.G.NCTIMERATE. Unidades: %." .

ns1:Parametro_PERFRATE a ns1:Parametro ;
    rdfs:label "Variable (V.)[ch].G.PERFRATE" ;
    ns1:identificador "(V.)[ch].G.PERFRATE" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "Porcentaje de bloques que gestiona el CNC en la preparación de bloques, respecto el óptimo alcanzable, para alcanzar el avance máximo en cada tramo. Esta variable debe devolver un valor próximo a 100; si el porcentaje de bloques es inferior al 100 %, puede que el HSC esté perdiendo espacio para aumentar el avance, respetando el espacio disponible para frenar." ;
    ns1:valor 100 .

ns1:Parametro_PREPFREQ a ns1:Parametro ;
    rdfs:label "Parámetro PREPFREQ" ;
    ns1:identificador "PREPFREQ" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "Si ambas variables (PERFRATE y DROPRATE) tienen un valor inferior a 100, se puede aumentar el parámetro PREPFREQ para que aumente el suministro de bloques, siempre que el sistema vaya holgado de tiempo." .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "Sistema de control numérico (CNC) que gestiona parámetros como PERFRATE, DROPRATE, LIMERROR, PREPFREQ y NCTIMERATE para optimizar el avance en modo HSC." .

