@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Modo_CONTERROR a ns1:ModoOperacion ;
    rdfs:label "Modo CONTERROR" ;
    ns1:habilitadoPor ns1:Variable_LIMERROR ;
    ns1:textoExtracto "modo CONTERROR" .

ns1:Modo_HSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC" ;
    ns1:controla ns1:Variable_LIMERROR ;
    ns1:textoExtracto "modo HSC" .

ns1:Variable_LIMERROR a ns1:Parametro ;
    rdfs:label "Variable (V.)[ch].G.LIMERROR" ;
    ns1:identificador "(V.)[ch].G.LIMERROR" ;
    ns1:monitoreaParametro ns1:Modo_HSC ;
    ns1:textoExtracto "Valor del error que desactiva las splines (modo CONTERROR). Esta variable permite valorar si el programa está generado con más error del que pedimos al modo HSC." ;
    ns1:valor "[-1], [#]" .

