@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix mecanica: <https://vocab.cfaa.eus/broaching/mecanica/> .
@prefix elec: <https://vocab.cfaa.eus/broaching/elec/> .
@prefix base: <https://vocab.cfaa.eus/broaching/base/> .

ex:BloqueCAuxTransversal a owl:Class ;
    rdfs:label "Bloque C. Aux. Transversal" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Motor> .

ex:CircuitBreaker a owl:Class ;
    rdfs:label "Circuit Breaker" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Motor> .

ex:ActuadorGiratorioParedLateral a owl:Class ;
    rdfs:label "Actuador Giratorio Pared Lateral" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Motor> .

ex:TapaCubreBornes a owl:Class ;
    rdfs:label "Tapa Cubrebornes" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Motor> .

ex:MccbIecFs160 a owl:Class ;
    rdfs:label "Mccb IEC FS160" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Motor> .

ex:RepartidorCorrienteUnipolar a owl:Class ;
    rdfs:label "Repartidor de corriente unipolar" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Motor> .

ex:SelectorOI a owl:Class ;
    rdfs:label "Selector O-I" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Motor> .

ex:tieneModelo a owl:ObjectProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range xsd:string .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range xsd:string .

ex:tieneClase a owl:ObjectProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range xsd:string .

ex:tieneCantidad a owl:ObjectProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range xsd:integer .

ex:tieneCodigo a owl:ObjectProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range xsd:string .

ex:tieneDescripcion a owl:ObjectProperty ;
    rdfs:domain ex:Componente ;
    rdfs:range xsd:string .