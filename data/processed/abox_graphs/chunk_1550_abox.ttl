@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_CONTERROR a ns1:ModoOperacion ;
    rdfs:label "Modo CONTERROR (error cordal)"@es ;
    ns1:controla ns1:Parametro_PARLIMC ;
    ns1:identificador "CONTERROR" ;
    ns1:textoExtracto "El error cordal en la esquina (modo CONTERROR)."@es .

ns1:ModoOperacion_FAST a ns1:ModoOperacion ;
    rdfs:label "Modo FAST (geometría de esquina)"@es ;
    ns1:controla ns1:Parametro_PARLIMC ;
    ns1:identificador "FAST" ;
    ns1:textoExtracto "Geometría de la esquina (modo FAST)."@es .

ns1:Parametro_CORNERACC a ns1:Parametro ;
    rdfs:label "Parámetro CORNERACC (aceleración en esquina)"@es ;
    ns1:identificador "CORNERACC" ;
    ns1:monitoreaParametro ns1:Parametro_PARLIMC ;
    ns1:textoExtracto "La aceleración en la esquina (parámetro CORNERACC)."@es .

ns1:Parametro_CORNERJERK a ns1:Parametro ;
    rdfs:label "Parámetro CORNERJERK (jerk en esquina)"@es ;
    ns1:identificador "CORNERJERK" ;
    ns1:monitoreaParametro ns1:Parametro_PARLIMC ;
    ns1:textoExtracto "El jerk en la esquina (parámetro CORNERJERK)."@es .

ns1:Parametro_PERFRATE a ns1:Parametro ;
    rdfs:label "Variable V.[2].G.PERFRATE"@es ;
    ns1:documentadoEn ns1:Tabla_1289_VariablesLimitacionAvance ;
    ns1:identificador "G.PERFRATE" ;
    ns1:textoExtracto "Sintaxis de la variable para canal 2: V.[2].G.PERFRATE"@es .

ns1:Tabla_1289_VariablesLimitacionAvance a ns1:Tabla ;
    rdfs:label "Tabla de variables asociadas a la limitación en el avance (PRG 13.3.4)"@es ;
    ns1:documentadoEn ns1:Pagina_625_626 ;
    ns1:textoExtracto "Variables. | PRG | PLC | INT"@es .

ns1:Parametro_PARLIMC a ns1:Parametro ;
    rdfs:label "Variable (V.)[ch].G.PARLIMC"@es ;
    ns1:documentadoEn ns1:Tabla_1289_VariablesLimitacionAvance ;
    ns1:identificador "G.PARLIMC" ;
    ns1:textoExtracto "Causa que limita el avance en la esquina, en el bloque en ejecución. La variable devuelve uno de los siguientes valores. [1] El avance máximo del eje. [4] La aceleración en la esquina (parámetro CORNERACC). [5] El jerk en la esquina (parámetro CORNERJERK). [8] El error cordal en la esquina (modo CONTERROR). [9] Geometría de la esquina (modo FAST)."@es .

