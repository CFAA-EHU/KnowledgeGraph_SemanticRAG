@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_1290 a ns1:Sistema ;
    ns1:textoExtracto "| Variables. | PRG | PLC | INT | | --- | --- | --- | --- | | (V.)[ch].G.BLKN Última etiqueta ejecutada (número). Si no se ha ejecutado ninguna etiqueta, la variable devuelve valor -1. Unidades: -. | R | R | R | | (V.)[ch..." ;
    ns1:tieneComponente ns1:Variable_1290_1,
        ns1:Variable_1290_2 .

ns1:Variable_1290_1 a ns1:Parametro ;
    rdfs:label "Última etiqueta ejecutada (número)" ;
    ns1:identificador "(V.)[ch].G.BLKN" ;
    ns1:textoExtracto "Última etiqueta ejecutada (número). Si no se ha ejecutado ninguna etiqueta, la variable devuelve valor -1. Unidades: -." ;
    ns1:valor "-1" .

ns1:Variable_1290_2 a ns1:Parametro ;
    rdfs:label "Número de bloques de programa ejecutados o preparados" ;
    ns1:identificador "(V.)[ch].G.LINEN" ;
    ns1:textoExtracto "Número de bloques de programa ejecutados o preparados. La lectura de la variable desde el PLC o interfaz devuelve el número de bloques ejecutados; la lectura desde el programa pieza o MDI devuelve el número de bloques preparados. Unidades: -." .

