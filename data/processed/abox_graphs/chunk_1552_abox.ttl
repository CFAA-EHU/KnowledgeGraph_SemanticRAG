@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_ADDMANOF a ns1:Parametro ;
    rdfs:label "Distancia movida con G201 (ADDMANOF)"@es ;
    ns1:documentadoEn ns1:Tabla_13_3_6_VariablesCotasLazo ;
    ns1:identificador "(V.)[ch].A.ADDMANOF.xn" ;
    ns1:textoExtracto "Distancia movida con G201. Unidades: Milímetros, pulgadas o grados."@es ;
    ns1:valor "Milímetros, pulgadas o grados"@es .

ns1:Parametro_FILTERIN a ns1:Parametro ;
    rdfs:label "Cota teórica del interpolador antes del filtro (FILTERIN)"@es ;
    ns1:documentadoEn ns1:Tabla_13_3_6_VariablesCotasLazo ;
    ns1:identificador "(V.)[ch].A.FILTERIN.xn / (V.)[ch].A.FILTERIN.sn / (V.)[ch].SP.FILTERIN.sn" ;
    ns1:textoExtracto "Cota teórica del interpolador antes del filtro. Unidades: Milímetros, pulgadas o grados."@es ;
    ns1:valor "Milímetros, pulgadas o grados"@es .

ns1:Parametro_FILTEROUT a ns1:Parametro ;
    rdfs:label "Cota teórica del interpolador después del filtro (FILTEROUT)"@es ;
    ns1:documentadoEn ns1:Tabla_13_3_6_VariablesCotasLazo ;
    ns1:identificador "(V.)[ch].A.FILTEROUT.xn / (V.)[ch].A.FILTEROUT.sn / (V.)[ch].SP.FILTEROUT.sn" ;
    ns1:textoExtracto "Cota teórica del interpolador después del filtro. Unidades: Milímetros, pulgadas o grados."@es ;
    ns1:valor "Milímetros, pulgadas o grados"@es .

ns1:Parametro_INDPOS a ns1:Parametro ;
    rdfs:label "Cota teórica del interpolador independiente (INDPOS)"@es ;
    ns1:documentadoEn ns1:Tabla_13_3_6_VariablesCotasLazo ;
    ns1:identificador "(V.)[ch].A.INDPOS.xn / (V.)[ch].A.INDPOS.sn / (V.)[ch].SP.INDPOS.sn" ;
    ns1:textoExtracto "Cota teórica del interpolador independiente. Unidades: Milímetros, pulgadas o grados."@es ;
    ns1:valor "Milímetros, pulgadas o grados"@es .

ns1:Parametro_IPOPOS a ns1:Parametro ;
    rdfs:label "Cota teórica a la salida del interpolador (IPOPOS)"@es ;
    ns1:documentadoEn ns1:Tabla_13_3_6_VariablesCotasLazo ;
    ns1:identificador "(V.)[ch].A.IPOPOS.xn / (V.)[ch].A.IPOPOS.sn / (V.)[ch].SP.IPOPOS.sn" ;
    ns1:textoExtracto "Cota teórica a la salida del interpolador, antes de la transformación; es decir, en cotas pieza. Unidades: Milímetros, pulgadas o grados."@es ;
    ns1:valor "Milímetros, pulgadas o grados"@es .

ns1:Parametro_LOOPPOS a ns1:Parametro ;
    rdfs:label "Cota real a la entrada del lazo de posición (LOOPPOS)"@es ;
    ns1:documentadoEn ns1:Tabla_13_3_6_VariablesCotasLazo ;
    ns1:identificador "(V.)[ch].A.LOOPPOS.xn / (V.)[ch].A.LOOPPOS.sn / (V.)[ch].SP.LOOPPOS.sn" ;
    ns1:textoExtracto "Cota real a la entrada del lazo de posición. Unidades: Milímetros, pulgadas o grados."@es ;
    ns1:valor "Milímetros, pulgadas o grados"@es .

ns1:Parametro_LOOPTPOS a ns1:Parametro ;
    rdfs:label "Cota teórica a la entrada del lazo de posición (LOOPTPOS)"@es ;
    ns1:documentadoEn ns1:Tabla_13_3_6_VariablesCotasLazo ;
    ns1:identificador "(V.)[ch].A.LOOPTPOS.xn / (V.)[ch].A.LOOPTPOS.sn / (V.)[ch].SP.LOOPTPOS.sn" ;
    ns1:textoExtracto "Cota teórica a la entrada del lazo de posición. Unidades: Milímetros, pulgadas o grados."@es ;
    ns1:valor "Milímetros, pulgadas o grados"@es .

ns1:Tabla_13_3_6_VariablesCotasLazo a ns1:Tabla ;
    rdfs:label "Tabla 13.3.6: Variables asociadas a las cotas en el lazo"@es ;
    ns1:textoExtracto """
| Variables. | PRG | PLC | INT |
| --- | --- | --- | --- |
| (V.)[ch].A.IPOPOS.xn
(V.)[ch].A.IPOPOS.sn
(V.)[ch].SP.IPOPOS.sn
Cota teórica a la salida del interpolador, antes de la transformación; es decir, en cotas pieza. Unidades: Milímetros, pulgadas o grados.
...
(V.)[ch].A.LOOPPOS.sn
Cota real a la entrada del lazo de posición. Unidades: Milímetros, pulgadas o grados."""@es .

