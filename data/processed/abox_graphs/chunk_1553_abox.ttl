    rdfs:label "Variable V.[2].A.IPOPOS.1"@es ;
    ns1:documentadoEn ns1:Tabla_13_3_6_VariablesCotasLazo ;
    ns1:identificador "[2].A.IPOPOS.1" ;
    ns1:textoExtracto "Cota asociada al eje con índice '1' en el canal '2'."@es .

