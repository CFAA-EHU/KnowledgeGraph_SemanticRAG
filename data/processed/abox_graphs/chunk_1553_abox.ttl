ns1:Parametro_LOOPPOS_sn a ns1:Parametro ;
    rdfs:label "Variable (V.)[ch].A.LOOPPOS.sn / (V.)[ch].SP.LOOPPOS.sn"@es ;
    ns1:documentadoEn ns1:Tabla_13_3_6_VariablesCotasLazo ;
    ns1:identificador "LOOPPOS.sn" ;
    ns1:textoExtracto "Cota real a la entrada del lazo de posición (cabezal específico). Unidades: Milímetros, pulgadas o grados."@es ;
    ns1:valor "Milímetros/pulgadas/grados"@es .

ns1:Parametro_LOOPPOS_xn a ns1:Parametro ;
    rdfs:label "Variable (V.)[ch].A.LOOPPOS.xn"@es ;
    ns1:documentadoEn ns1:Tabla_13_3_6_VariablesCotasLazo ;
    ns1:identificador "LOOPPOS.xn" ;
    ns1:textoExtracto "Cota real a la entrada del lazo de posición (eje específico). Unidades: Milímetros, pulgadas o grados."@es ;
    ns1:valor "Milímetros/pulgadas/grados"@es .

ns1:Tabla_13_3_6_VariablesCotasLazo a ns1:Tabla ;
    rdfs:label "Tabla de variables asociadas a cotas en el lazo de posición (Sección 13.3.6)"@es ;
    ns1:textoExtracto """
| (V.)[ch].A.LOOPPOS.xn
(V.)[ch].A.LOOPPOS.sn
(V.)[ch].SP.LOOPPOS.sn
Cota real a la entrada del lazo de posición. Unidades: Milímetros, pulgadas o grados.
---
V.A.IPOPOS.Z | Eje Z.
V.A.IPOPOS.S | Cabezal S.
V.SP.IPOPOS.S | Cabezal S.
V.SP.IPOPOS | Cabezal master.
V.A.IPOPOS.4 | Eje o cabezal con número lógico '4'.
V.[2].A.IPOPOS.1 | Eje con índice '1' en el canal '2'.
V.SP.IPOPOS.2 | Cabezal con índice '2' en el sistema.
V.[2].SP.IPOPOS.1 | Cabezal con índice '1' en el canal '2'.
"""@es .

