ns1:Parametro_IPOPOS_4 a ns1:Parametro ;
    rdfs:label "Variable V.A.IPOPOS.4"@es ;
    ns1:documentadoEn ns1:Tabla_13_3_6_VariablesCotasLazo ;
    ns1:identificador "IPOPOS.4" ;
    ns1:textoExtracto "Cota asociada al eje o cabezal con número lógico '4'."@es .

