@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_FEED_A_sn a ns1:Parametro ;
    rdfs:label "Variable (V.)[ch].A.FEED.sn (velocidad real instantánea por cabezal)"@es ;
    ns1:documentadoEn ns1:Tabla_1293_VariablesVelocidadLazoPosicion ;
    ns1:identificador "(V.)[ch].A.FEED.sn" ;
    ns1:textoExtracto "Valor instantáneo real de la velocidad a la entrada del lazo de posición. Unidades: -."@es .

