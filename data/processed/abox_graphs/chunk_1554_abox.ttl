ns1:Sistema_SintaxisVariablesVelocidad a ns1:Sistema ;
    rdfs:label "Sintaxis de variables de velocidad en lazo de posición"@es ;
    ns1:documentadoEn ns1:Tabla_1293_VariablesVelocidadLazoPosicion ;
    ns1:textoExtracto """
ꞏchꞏ Número de canal.
ꞏxnꞏ Nombre, número lógico o índice del eje.
ꞏsnꞏ Nombre, número lógico o índice del cabezal.
(*) El CNC evalúa la variable durante la ejecución (detiene la preparación de bloques)."""@es .

ns1:Tabla_1293_VariablesVelocidadLazoPosicion a ns1:Tabla ;
    rdfs:label "Tabla de variables asociadas a velocidad en lazo de posición (pág. 628)"@es ;
    ns1:textoExtracto """
| Variables. | PRG | PLC | INT |
| --- | --- | --- | --- |
