@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_V_2_A_TFEED_1 a ns1:Parametro ;
    rdfs:label "V.[2].A.TFEED.1" ;
    ns1:identificador "V.[2].A.TFEED.1" ;
    ns1:monitoreaParametro ns1:SistemaControlVelocidad ;
    ns1:textoExtracto "Eje con índice '1' en el canal '2'."@es .

ns1:Parametro_V_2_SP_TFEED_1 a ns1:Parametro ;
    rdfs:label "V.[2].SP.TFEED.1" ;
    ns1:identificador "V.[2].SP.TFEED.1" ;
    ns1:monitoreaParametro ns1:SistemaControlVelocidad ;
    ns1:textoExtracto "Cabezal con índice '1' en el canal '2'."@es .

ns1:Parametro_V_ATFEED_4 a ns1:Parametro ;
    rdfs:label "V.A.TFEED.4" ;
    ns1:identificador "V.A.TFEED.4" ;
    ns1:monitoreaParametro ns1:SistemaControlVelocidad ;
    ns1:textoExtracto "Eje o cabezal con número lógico '4'."@es .

ns1:Parametro_V_ATFEED_S a ns1:Parametro ;
    rdfs:label "V.A.TFEED.S" ;
    ns1:identificador "V.A.TFEED.S" ;
    ns1:monitoreaParametro ns1:SistemaControlVelocidad ;
    ns1:textoExtracto "Cabezal S."@es .

ns1:Parametro_V_ATFEED_Z a ns1:Parametro ;
    rdfs:label "V.A.TFEED.Z" ;
    ns1:identificador "V.A.TFEED.Z" ;
    ns1:monitoreaParametro ns1:SistemaControlVelocidad ;
    ns1:textoExtracto "Eje Z."@es .

ns1:Parametro_V_SP_TFEED a ns1:Parametro ;
    rdfs:label "V.SP.TFEED" ;
    ns1:identificador "V.SP.TFEED" ;
    ns1:monitoreaParametro ns1:SistemaControlVelocidad ;
    ns1:textoExtracto "Cabezal master."@es .

ns1:Parametro_V_SP_TFEED_2 a ns1:Parametro ;
    rdfs:label "V.SP.TFEED.2" ;
    ns1:identificador "V.SP.TFEED.2" ;
    ns1:monitoreaParametro ns1:SistemaControlVelocidad ;
    ns1:textoExtracto "Cabezal con índice '2' en el sistema."@es .

ns1:Parametro_V_SP_TFEED_S a ns1:Parametro ;
    rdfs:label "V.SP.TFEED.S" ;
    ns1:identificador "V.SP.TFEED.S" ;
    ns1:monitoreaParametro ns1:SistemaControlVelocidad ;
    ns1:textoExtracto "Cabezal S."@es .

ns1:SistemaControlVelocidad a ns1:Sistema ;
    rdfs:label "Sistema de control de velocidad en lazo"@es ;
    ns1:textoExtracto "Variables asociadas a la velocidad en el lazo."@es ;
    ns1:tieneComponente ns1:Parametro_V_2_A_TFEED_1,
        ns1:Parametro_V_2_SP_TFEED_1,
        ns1:Parametro_V_ATFEED_4,
        ns1:Parametro_V_ATFEED_S,
        ns1:Parametro_V_ATFEED_Z,
        ns1:Parametro_V_SP_TFEED,
        ns1:Parametro_V_SP_TFEED_2,
        ns1:Parametro_V_SP_TFEED_S .

