@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_Sercos a ns1:Sistema ;
    rdfs:label "Sistema Sercos"@es ;
    ns1:monitoreaParametro ns1:Parametro_FTEO,
        ns1:Parametro_POSCMD,
        ns1:Parametro_POSNC ;
    ns1:textoExtracto "Consigna de velocidad para Sercos (en rpm)"@es .

ns1:Parametro_FTEO a ns1:Parametro ;
    rdfs:label "Consigna de velocidad para Sercos (FTEO)"@es ;
    ns1:documentadoEn ns1:Tabla_VariablesConsignaFeedback ;
    ns1:identificador "(V.)[ch].A.FTEO.sn",
        "(V.)[ch].A.FTEO.xn",
        "(V.)[ch].SP.FTEO.sn" ;
    ns1:textoExtracto "Consigna de velocidad para Sercos (en rpm). Unidades: rpm."@es ;
    ns1:valor "rpm" .

ns1:Parametro_POSCMD a ns1:Parametro ;
    rdfs:label "Consigna de posición para Sercos (POSCMD)"@es ;
    ns1:documentadoEn ns1:Tabla_VariablesConsignaFeedback ;
    ns1:identificador "(V.)[ch].A.POSCMD.sn",
        "(V.)[ch].A.POSCMD.xn",
        "(V.)[ch].SP.POSCMD.sn" ;
    ns1:textoExtracto "Consigna de posición para Sercos. Unidades: -."@es .

ns1:Parametro_POSNC a ns1:Parametro ;
    rdfs:label "Feedback de posición (POSNC)"@es ;
    ns1:documentadoEn ns1:Tabla_VariablesConsignaFeedback ;
    ns1:identificador "(V.)[ch].A.POSNC.sn",
        "(V.)[ch].A.POSNC.xn",
        "(V.)[ch].SP.POSNC.sn" ;
    ns1:textoExtracto "Feedback de posición. Unidades: -."@es .

ns1:Tabla_VariablesConsignaFeedback a ns1:Tabla ;
    rdfs:label "Tabla de variables de consigna y feedback (Sercos)"@es ;
    ns1:textoExtracto """
| Variables. | PRG | PLC | INT |
| --- | --- | --- | --- |
| (V.)[ch].A.POSCMD.xn
(V.)[ch].A.POSCMD.sn
(V.)[ch].SP.POSCMD.sn
Consigna de posición para Sercos. Unidades: -.
| (V.)[ch].A.POSNC.xn
(V.)[ch].A.POSNC.sn
(V.)[ch].SP.POSNC.sn
Feedback de posición. Unidades: -.
| (V.)[ch].A.FTEO.xn
(V.)[ch].A.FTEO.sn
(V.)[ch].SP.FTEO.sn
Consigna de velocidad para Sercos (en rpm). Unidades: rpm.
(*) El CNC evalúa la variable durante la ejecución (detiene la preparación de bloques)."""@es .

