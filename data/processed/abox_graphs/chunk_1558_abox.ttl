@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Herramienta_Osciloscopio a ns1:Herramienta ;
    rdfs:label "Osciloscopio" ;
    ns1:textoExtracto "El osciloscopio servirá como herramienta análisis para ver la evolución del HSC durante el mecanizado." .

ns1:Parametro_ACCEL a ns1:Parametro ;
    rdfs:label "ACCEL" ;
    ns1:monitoreaParametro ns1:ModoHSC ;
    ns1:textoExtracto "parámetros G00FEED, ACCEL, LACC1, LACC2 y ACCJERK testeados y ajustados" .

ns1:Parametro_ACCJERK a ns1:Parametro ;
    rdfs:label "ACCJERK" ;
    ns1:monitoreaParametro ns1:ModoHSC ;
    ns1:textoExtracto "parámetros G00FEED, ACCEL, LACC1, LACC2 y ACCJERK testeados y ajustados" .

ns1:Parametro_G00FEED a ns1:Parametro ;
    rdfs:label "G00FEED" ;
    ns1:monitoreaParametro ns1:ModoHSC ;
    ns1:textoExtracto "parámetros G00FEED, ACCEL, LACC1, LACC2 y ACCJERK testeados y ajustados" .

ns1:Parametro_LACC1 a ns1:Parametro ;
    rdfs:label "LACC1" ;
    ns1:monitoreaParametro ns1:ModoHSC ;
    ns1:textoExtracto "parámetros G00FEED, ACCEL, LACC1, LACC2 y ACCJERK testeados y ajustados" .

ns1:Parametro_LACC2 a ns1:Parametro ;
    rdfs:label "LACC2" ;
    ns1:monitoreaParametro ns1:ModoHSC ;
    ns1:textoExtracto "parámetros G00FEED, ACCEL, LACC1, LACC2 y ACCJERK testeados y ajustados" .

ns1:TareaMantenimiento_AjusteHSC a ns1:TareaMantenimiento ;
    rdfs:label "Ajuste del modo HSC" ;
    ns1:ejecutadoPor ns1:Personal ;
    ns1:requiereMantenimiento ns1:ModoHSC ;
    ns1:textoExtracto "Para el ajuste del modo HSC, los ejes del CNC deben tener los parámetros G00FEED, ACCEL, LACC1, LACC2 y ACCJERK testeados y ajustados al máximo que la dinámica de la máquina permite." .

ns1:ModoHSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC" ;
    ns1:textoExtracto "Para el ajuste del modo HSC, los ejes del CNC deben tener los parámetros G00FEED, ACCEL, LACC1, LACC2 y ACCJERK testeados y ajustados al máximo que la dinámica de la máquina permite." .

