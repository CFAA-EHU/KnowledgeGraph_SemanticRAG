@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_V_G_CHTIMERATE a ns1:Parametro ;
    rdfs:label "V.G.CHTIMERATE" ;
    ns1:documentadoEn ns1:Tabla_1298_ParametrosHSC ;
    ns1:identificador "V.G.CHTIMERATE" ;
    ns1:textoExtracto "Porcentaje del tiempo de ciclo que utiliza el canal."@es .

ns1:Parametro_V_G_DROPRATE a ns1:Parametro ;
    rdfs:label "V.G.DROPRATE" ;
    ns1:documentadoEn ns1:Tabla_1298_ParametrosHSC ;
    ns1:identificador "V.G.DROPRATE" ;
    ns1:textoExtracto "Porcentaje de reducción del avance máximo alcanzable."@es .

ns1:Parametro_V_G_IPOTIMERATE a ns1:Parametro ;
    rdfs:label "V.G.IPOTIMERATE" ;
    ns1:documentadoEn ns1:Tabla_1298_ParametrosHSC ;
    ns1:identificador "V.G.IPOTIMERATE" ;
    ns1:textoExtracto "Porcentaje del tiempo de ciclo que utiliza el interpolador del canal."@es .

ns1:Parametro_V_G_LOOPTIMERATE a ns1:Parametro ;
    rdfs:label "V.G.LOOPTIMERATE" ;
    ns1:documentadoEn ns1:Tabla_1298_ParametrosHSC ;
    ns1:identificador "V.G.LOOPTIMERATE" ;
    ns1:textoExtracto "Porcentaje del tiempo de ciclo que utiliza el lazo de posición."@es .

ns1:Parametro_V_G_NCTIMERATE a ns1:Parametro ;
    rdfs:label "V.G.NCTIMERATE" ;
    ns1:documentadoEn ns1:Tabla_1298_ParametrosHSC ;
    ns1:identificador "V.G.NCTIMERATE" ;
    ns1:textoExtracto "Porcentaje del tiempo de ciclo que utiliza la parte de tiempo real de CNC."@es .

ns1:Parametro_V_G_PERFRATE a ns1:Parametro ;
    rdfs:label "V.G.PERFRATE" ;
    ns1:documentadoEn ns1:Tabla_1298_ParametrosHSC ;
    ns1:identificador "V.G.PERFRATE" ;
    ns1:textoExtracto "Porcentaje de bloques que gestiona el CNC en la preparación de bloques, respecto el óptimo alcanzable."@es .

ns1:Parametro_V_G_PREPTIMERATE a ns1:Parametro ;
    rdfs:label "V.G.PREPTIMERATE" ;
    ns1:documentadoEn ns1:Tabla_1298_ParametrosHSC ;
    ns1:identificador "V.G.PREPTIMERATE" ;
    ns1:textoExtracto "Porcentaje del tiempo de ciclo que utiliza el canal para la preparación de bloques."@es .

ns1:Tabla_1298_ParametrosHSC a ns1:Tabla ;
    rdfs:label "Tabla de parámetros del modo HSC (páginas 630-632)"@es ;
    ns1:documentadoEn ns1:Pagina_630,
        ns1:Pagina_631,
        ns1:Pagina_632 ;
    ns1:textoExtracto "Variable | Significado... V.G.PREPTIMERATE | Porcentaje del tiempo de ciclo que utiliza el canal para la preparación de bloques."@es .

