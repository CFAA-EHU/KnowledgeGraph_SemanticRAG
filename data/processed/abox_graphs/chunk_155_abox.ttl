ex:ContactModule1NC a owl:Class ;
    rdfs:label "Contact Module 1NC" ;
    rdfs:comment "Módulo de contactos con 1 contacto, 1NC, bornes de resorte" ;
    rdfs:isDefinedBy <https://www.siemens.com> .

