@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

ex:SelectorOIBlanco a owl:Class ;
    rdfs:label "Selector O-I Blanco"@es ;
    rdfs:comment "Selector, iluminable, 22 mm, redondo, metal, brillante, blanco, selector, largo"@es .

ex:PulsadorSetaParoEmergencia a owl:Class ;
    rdfs:label "Pulsador Seta Paro Emergencia"@es ;
    rdfs:comment "Pulsador de seta de PARADA DE EMERGENCIA, 22 mm, redondo, metal"@es .

ex:NotHaltUnterlegschild a owl:Class ;
    rdfs:label "Not-Halt-Unterlegschild"@es ;
    rdfs:comment "Placa de fondo redonda, para pulsador de seta de PARADA DE EMERGENCIA"@es .

ex:ContactModule1NC a owl:Class ;
    rdfs:label "Contact Module 1NC"@es ;
    rdfs:comment "Módulo de contactos con 1 contacto, 1NC, bornes de resorte"@es .

ex:PulsadorNegro a owl:Class ;
    rdfs:label "Pulsador Negro"@es ;
    rdfs:comment "Pulsador, 22 mm, redondo, metal, brillante, negro, botón"@es .

ex:PulsadorIluminadoVerde a owl:Class ;
    rdfs:label "Pulsador Iluminado Verde"@es ;
    rdfs:comment "Pulsador iluminado, 22 mm, redondo, metal, brillante, verde"@es .

ex:PulsadorIluminadoBlanco a owl:Class ;
    rdfs:label "Pulsador Iluminado Blanco"@es ;
    rdfs:comment "Pulsador iluminado, 22 mm, redondo, metal, brillante, blanco"@es .

ex:ContactModule1NO a owl:Class ;
    rdfs:label "Contact Module 1NO"@es ;
    rdfs:comment "Módulo de contactos con 1 contacto, 1NO, bornes de resorte"@es .

ex:LedModul a owl:Class ;
    rdfs:label "Led-Modul"@es ;
    rdfs:comment "Módulo de LED con LED integrado"@es .