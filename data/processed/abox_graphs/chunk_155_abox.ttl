@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:SelectorOIBlanco a owl:Class ;
    rdfs:label "Selector, O-I, Blanco" ;
    rdfs:comment "Selector, iluminable, 22 mm, redondo, metal, brillante, blanco, selector, largo" ;
    rdfs:isDefinedBy <https://www.siemens.com> .

