@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ModoOperacion_HSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC" ;
    ns1:controla ns1:Parametro_FEEDAVRG,
        ns1:Parametro_PREPFREQ ;
    ns1:monitoreaParametro ns1:Variable_V.G.IPOTIMERATE,
        ns1:Variable_V.G.NCTIMERATE,
        ns1:Variable_V.G.PREPTIMERATE ;
    ns1:textoExtracto "Para asegurar un suministro de bloques adecuado al HSC" .

ns1:Parametro_FEEDAVRG a ns1:Parametro ;
    rdfs:label "FEEDAVRG" ;
    ns1:identificador "ꞏNoꞏ" ;
    ns1:textoExtracto "definir el parámetro FEEDAVRG con valor ꞏNoꞏ, para evitar que el CNC limite el avance en función del suministro de bloques" .

ns1:Parametro_PREPFREQ a ns1:Parametro ;
    rdfs:label "PREPFREQ" ;
    ns1:monitoreaParametro ns1:Variable_V.G.DROPRATE,
        ns1:Variable_V.G.PERFRATE ;
    ns1:textoExtracto "parámetro PREPFREQ para que aumente el suministro de bloques" .

ns1:Variable_V.G.DROPRATE a ns1:Parametro ;
    rdfs:label "V.G.DROPRATE" ;
    ns1:textoExtracto "Un valor menor que 100 indica que el CNC podría aumentar el avance si tuviera más bloques." ;
    ns1:valor "<100%"^^xsd:string .

ns1:Variable_V.G.IPOTIMERATE a ns1:Parametro ;
    rdfs:label "V.G.IPOTIMERATE" ;
    ns1:textoExtracto "Porcentaje del tiempo de ciclo que utiliza el interpolador del canal." ;
    ns1:valor "100%"^^xsd:string .

ns1:Variable_V.G.NCTIMERATE a ns1:Parametro ;
    rdfs:label "V.G.NCTIMERATE" ;
    ns1:textoExtracto "Con un valor menor que 50, se puede aumentar el parámetro PREPFREQ." ;
    ns1:valor "<50%"^^xsd:string .

ns1:Variable_V.G.PERFRATE a ns1:Parametro ;
    rdfs:label "V.G.PERFRATE" ;
    ns1:textoExtracto "Un valor menor que 100 indica que el CNC puede tratar más bloques." ;
    ns1:valor "<100%"^^xsd:string .

ns1:Variable_V.G.PREPTIMERATE a ns1:Parametro ;
    rdfs:label "V.G.PREPTIMERATE" ;
    ns1:textoExtracto "Porcentaje del tiempo de ciclo que utiliza el canal para la preparación de bloques." ;
    ns1:valor "100%"^^xsd:string .

