@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_HSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC"@es ;
    ns1:monitoreaParametro ns1:Parametro_V_G_AXLIMC,
        ns1:Parametro_V_G_AXLIMF,
        ns1:Parametro_V_G_FREAL,
        ns1:Parametro_V_G_LIMERROR,
        ns1:Parametro_V_G_PARLIMC,
        ns1:Parametro_V_G_PARLIMF,
        ns1:Parametro_V_G_PATHFEED ;
    ns1:textoExtracto "Proceso de análisis y ajuste del modo HSC. Para analizar la causa de la disminución del avance, utilizar una traza del osciloscopio donde se observe una disminución de avance indeseada."@es .

ns1:Parametro_V_G_AXLIMC a ns1:Parametro ;
    rdfs:label "V.G.AXLIMC" ;
    ns1:documentadoEn ns1:Tabla_1300_VariablesModoHSC ;
    ns1:identificador "V.G.AXLIMC" ;
    ns1:textoExtracto "Número lógico del eje que limita el avance en la esquina, en el bloque en ejecución."@es .

ns1:Parametro_V_G_AXLIMF a ns1:Parametro ;
    rdfs:label "V.G.AXLIMF" ;
    ns1:documentadoEn ns1:Tabla_1300_VariablesModoHSC ;
    ns1:identificador "V.G.AXLIMF" ;
    ns1:textoExtracto "Número lógico del eje que limita el avance, en el bloque en ejecución."@es .

ns1:Parametro_V_G_FREAL a ns1:Parametro ;
    rdfs:label "V.G.FREAL" ;
    ns1:documentadoEn ns1:Tabla_1300_VariablesModoHSC ;
    ns1:identificador "V.G.FREAL" ;
    ns1:textoExtracto "Avance real sobre la trayectoria."@es .

ns1:Parametro_V_G_LIMERROR a ns1:Parametro ;
    rdfs:label "V.G.LIMERROR" ;
    ns1:documentadoEn ns1:Tabla_1300_VariablesModoHSC ;
    ns1:identificador "V.G.LIMERROR" ;
    ns1:textoExtracto "Valor del error que desactiva las splines (modo CONTERROR)."@es .

ns1:Parametro_V_G_PARLIMC a ns1:Parametro ;
    rdfs:label "V.G.PARLIMC" ;
    ns1:documentadoEn ns1:Tabla_1300_VariablesModoHSC ;
    ns1:identificador "V.G.PARLIMC" ;
    ns1:textoExtracto "Causa que limita el avance en la esquina, en el bloque actual."@es .

ns1:Parametro_V_G_PARLIMF a ns1:Parametro ;
    rdfs:label "V.G.PARLIMF" ;
    ns1:documentadoEn ns1:Tabla_1300_VariablesModoHSC ;
    ns1:identificador "V.G.PARLIMF" ;
    ns1:textoExtracto "Causa que limita el avance en el bloque en ejecución."@es .

ns1:Parametro_V_G_PATHFEED a ns1:Parametro ;
    rdfs:label "V.G.PATHFEED" ;
    ns1:documentadoEn ns1:Tabla_1300_VariablesModoHSC ;
    ns1:identificador "V.G.PATHFEED" ;
    ns1:textoExtracto "Avance teórico sobre la trayectoria."@es .

ns1:Tabla_1300_VariablesModoHSC a ns1:Tabla ;
    rdfs:label "Tabla de variables para análisis del modo HSC (páginas 630-632)"@es ;
    ns1:textoExtracto """
| Variable. | Significado. |
| --- | --- |
| V.G.PARLIMF | Causa que limita el avance en el bloque en ejecución. |
| V.G.AXLIMF | Número lógico del eje que limita el avance, en el bloque en ejecución. |
| V.G.PARLIMC | Causa que limita el avance en la esquina, en el bloque actual. |
| V.G.AXLIMC | Número lógico del eje que limita el avance en la esquina, en el bloque en ejecución. |
| V.G.LIMERROR | Valor del error que desactiva las splines (modo CONTERROR). |
| V.G.PATHFEED | Avance teórico sobre la trayectoria. |
| V.G.FREAL | Avance real sobre la trayectoria."""@es .

