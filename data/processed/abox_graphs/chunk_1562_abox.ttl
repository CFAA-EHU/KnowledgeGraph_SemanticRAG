@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Tabla_ParametrosHSC_1301 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros y variables del modo HSC (pág. 630-632)"@es ;
    ns1:detalladoEnEsquema ns1:ModoOperacion_HSC ;
    ns1:textoExtracto """
| Valor. | Significado. |
| --- | --- |
| 1 | El avance máximo del eje. |
| 2 | La aceleración debida a la curvatura (parámetro CURVACC). |
| 3 | El jerk debido a la curvatura (parámetro CURVJERK). |
| 6 | El error que comete el spline. |
| 7 | Espacio insuficiente por bloques muy pequeños y/o buffer lleno. |
| 10 | Máximo avance del eje en transformaciones. |
| 11 | Máxima aceleración del eje en transformaciones.
"""@es .

ns1:ModoOperacion_HSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC (High Speed Cutting)"@es ;
    ns1:monitoreaParametro ns1:Parametro_CORNERACC,
        ns1:Parametro_CORNERJERK,
        ns1:Parametro_CURVACC,
        ns1:Parametro_CURVJERK,
        ns1:Variable_VGAXLIMC,
        ns1:Variable_VGLIMERROR,
        ns1:Variable_VGPARLIMC ;
    ns1:textoExtracto "Proceso de análisis y ajuste del modo HSC"@es .

ns1:Parametro_CORNERACC a ns1:Parametro ;
    rdfs:label "CORNERACC"@es ;
    ns1:identificador "CORNERACC" ;
    ns1:textoExtracto "La aceleración en la esquina (parámetro CORNERACC)"@es ;
    ns1:valor 4 .

ns1:Parametro_CORNERJERK a ns1:Parametro ;
    rdfs:label "CORNERJERK"@es ;
    ns1:identificador "CORNERJERK" ;
    ns1:textoExtracto "El jerk en la esquina (parámetro CORNERJERK)"@es ;
    ns1:valor 5 .

ns1:Parametro_CURVACC a ns1:Parametro ;
    rdfs:label "CURVACC"@es ;
    ns1:identificador "CURVACC" ;
    ns1:textoExtracto "La aceleración debida a la curvatura (parámetro CURVACC)"@es ;
    ns1:valor 2 .

ns1:Parametro_CURVJERK a ns1:Parametro ;
    rdfs:label "CURVJERK"@es ;
    ns1:identificador "CURVJERK" ;
    ns1:textoExtracto "El jerk debido a la curvatura (parámetro CURVJERK)"@es ;
    ns1:valor 3 .

ns1:Variable_VGAXLIMC a ns1:Parametro ;
    rdfs:label "V.G.AXLIMC"@es ;
    ns1:identificador "V.G.AXLIMC" ;
    ns1:textoExtracto "Consultar la variable V.G.AXLIMC para conocer cuál es el eje que está limitando el avance"@es .

ns1:Variable_VGLIMERROR a ns1:Parametro ;
    rdfs:label "V.G.LIMERROR"@es ;
    ns1:identificador "V.G.LIMERROR" ;
    ns1:textoExtracto """
El error que comete el spline se puede consultar con la variable V.G.LIMERROR.
Comprobar si el error generado es superior al programado. Consultar la variable V.G.LIMERROR para conocer el valor del error que desactiva los splines.
"""@es ;
    ns1:valor 6 .

ns1:Variable_VGPARLIMC a ns1:Parametro ;
    rdfs:label "V.G.PARLIMC"@es ;
    ns1:identificador "V.G.PARLIMC" ;
    ns1:textoExtracto """
Consultar la variable V.G.PARLIMC para conocer la causa por la que este eje está limitando el avance.
Esta última variable devuelve uno de los siguientes valores: 1 (avance máximo del eje), 4 (aceleración en la esquina), 5 (jerk en la esquina), 8 (error cordal), 9 (geometría de la esquina).
"""@es .

