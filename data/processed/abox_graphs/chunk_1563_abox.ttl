@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Tabla_AnalisisVariablesHSC a ns1:Tabla ;
    rdfs:label "Tabla de variables para análisis de problemas en modo HSC" ;
    ns1:detalladoEnEsquema ns1:ModoHSC ;
    ns1:documentadoEn ns1:Pagina_630_632 ;
    ns1:textoExtracto "Analizar las diferentes variables de los ejes en la zona conflictiva, para determinar si hay un error en la trayectoria teórica, en el lazo de control o en la captación" .

ns1:ModoHSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC (High Speed Cutting)" ;
    ns1:monitoreaParametro ns1:Variable_VGAXLIMC,
        ns1:Variable_VGAXLIMF,
        ns1:Variable_VGBLKN,
        ns1:Variable_VGFREAL,
        ns1:Variable_VGLIMERROR,
        ns1:Variable_VGLINEN,
        ns1:Variable_VGPARLIMC,
        ns1:Variable_VGPARLIMF,
        ns1:Variable_VGPATHFEED ;
    ns1:textoExtracto "Proceso de análisis y ajuste del modo HSC" .

ns1:Pagina_630_632 a ns1:Pagina ;
    rdfs:label "Páginas 630-632: Proceso de análisis y ajuste del modo HSC" ;
    ns1:identificador "13.4" ;
    ns1:ilustradoEn ns1:Manual ;
    ns1:textoExtracto "Proceso de análisis y ajuste del modo HSC" .

ns1:Variable_VGAXLIMC a ns1:Parametro ;
    rdfs:label "V.G.AXLIMC" ;
    ns1:identificador "V.G.AXLIMC" ;
    ns1:textoExtracto "Número lógico del eje que limita el avance en la esquina, en el bloque en ejecución" .

ns1:Variable_VGAXLIMF a ns1:Parametro ;
    rdfs:label "V.G.AXLIMF" ;
    ns1:identificador "V.G.AXLIMF" ;
    ns1:textoExtracto "Número lógico del eje que limita el avance, en el bloque en ejecución" .

ns1:Variable_VGBLKN a ns1:Parametro ;
    rdfs:label "V.G.BLKN" ;
    ns1:identificador "V.G.BLKN" ;
    ns1:textoExtracto "Última etiqueta ejecutada (número)" ;
    ns1:valor "-1"^^xsd:string .

ns1:Variable_VGFREAL a ns1:Parametro ;
    rdfs:label "V.G.FREAL" ;
    ns1:identificador "V.G.FREAL" ;
    ns1:textoExtracto "Avance real sobre la trayectoria" .

ns1:Variable_VGLIMERROR a ns1:Parametro ;
    rdfs:label "V.G.LIMERROR" ;
    ns1:identificador "V.G.LIMERROR" ;
    ns1:textoExtracto "Valor del error que desactiva las splines (modo CONTERROR)" ;
    ns1:valor "-1"^^xsd:string .

ns1:Variable_VGLINEN a ns1:Parametro ;
    rdfs:label "V.G.LINEN" ;
    ns1:identificador "V.G.LINEN" ;
    ns1:textoExtracto "Número de bloques de programa ejecutados o preparados" .

ns1:Variable_VGPARLIMC a ns1:Parametro ;
    rdfs:label "V.G.PARLIMC" ;
    ns1:identificador "V.G.PARLIMC" ;
    ns1:textoExtracto "Causa que limita el avance en la esquina, en el bloque actual" .

ns1:Variable_VGPARLIMF a ns1:Parametro ;
    rdfs:label "V.G.PARLIMF" ;
    ns1:identificador "V.G.PARLIMF" ;
    ns1:textoExtracto "Causa que limita el avance en el bloque en ejecución" .

ns1:Variable_VGPATHFEED a ns1:Parametro ;
    rdfs:label "V.G.PATHFEED" ;
    ns1:identificador "V.G.PATHFEED" ;
    ns1:textoExtracto "Avance teórico sobre la trayectoria" .

