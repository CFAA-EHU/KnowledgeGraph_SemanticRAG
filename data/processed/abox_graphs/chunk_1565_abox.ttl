@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_HSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC"@es ;
    ns1:monitoreaParametro ns1:Parametro_V_A_ADDMANOF_xn,
        ns1:Parametro_V_A_FEED_xn,
        ns1:Parametro_V_A_FILTERIN_xn,
        ns1:Parametro_V_A_FILTEROUT_xn,
        ns1:Parametro_V_A_INDPOS_xn,
        ns1:Parametro_V_A_IPOPOS_xn,
        ns1:Parametro_V_A_LOOPPOS_xn,
        ns1:Parametro_V_A_LOOPTPOS_xn,
        ns1:Parametro_V_A_TFEED_xn ;
    ns1:textoExtracto "Proceso de análisis y ajuste del modo HSC"@es .

ns1:Parametro_V_A_ADDMANOF_xn a ns1:Parametro ;
    rdfs:label "V.A.ADDMANOF.xn" ;
    ns1:documentadoEn ns1:Tabla_1304_VariablesModoHSC ;
    ns1:identificador "V.A.ADDMANOF.xn" ;
    ns1:textoExtracto "Distancia movida con G201."@es .

ns1:Parametro_V_A_FEED_xn a ns1:Parametro ;
    rdfs:label "V.A.FEED.xn" ;
    ns1:documentadoEn ns1:Tabla_1304_VariablesModoHSC ;
    ns1:identificador "V.A.FEED.xn" ;
    ns1:textoExtracto "Valor instantáneo real de la velocidad a la entrada del lazo de posición."@es .

ns1:Parametro_V_A_FILTERIN_xn a ns1:Parametro ;
    rdfs:label "V.A.FILTERIN.xn" ;
    ns1:documentadoEn ns1:Tabla_1304_VariablesModoHSC ;
    ns1:identificador "V.A.FILTERIN.xn" ;
    ns1:textoExtracto "Cota teórica del interpolador antes del filtro."@es .

ns1:Parametro_V_A_FILTEROUT_xn a ns1:Parametro ;
    rdfs:label "V.A.FILTEROUT.xn" ;
    ns1:documentadoEn ns1:Tabla_1304_VariablesModoHSC ;
    ns1:identificador "V.A.FILTEROUT.xn" ;
    ns1:textoExtracto "Cota teórica del interpolador después del filtro."@es .

ns1:Parametro_V_A_INDPOS_xn a ns1:Parametro ;
    rdfs:label "V.A.INDPOS.xn" ;
    ns1:documentadoEn ns1:Tabla_1304_VariablesModoHSC ;
    ns1:identificador "V.A.INDPOS.xn" ;
    ns1:textoExtracto "Cota teórica del interpolador independiente."@es .

ns1:Parametro_V_A_IPOPOS_xn a ns1:Parametro ;
    rdfs:label "V.A.IPOPOS.xn" ;
    ns1:documentadoEn ns1:Tabla_1304_VariablesModoHSC ;
    ns1:identificador "V.A.IPOPOS.xn" ;
    ns1:textoExtracto "Cota teórica a la salida del interpolador, antes de la transformación; es decir, en cotas pieza."@es .

ns1:Parametro_V_A_LOOPPOS_xn a ns1:Parametro ;
    rdfs:label "V.A.LOOPPOS.xn" ;
    ns1:documentadoEn ns1:Tabla_1304_VariablesModoHSC ;
    ns1:identificador "V.A.LOOPPOS.xn" ;
    ns1:textoExtracto "Cota real a la entrada del lazo de posición."@es .

ns1:Parametro_V_A_LOOPTPOS_xn a ns1:Parametro ;
    rdfs:label "V.A.LOOPTPOS.xn" ;
    ns1:documentadoEn ns1:Tabla_1304_VariablesModoHSC ;
    ns1:identificador "V.A.LOOPTPOS.xn" ;
    ns1:textoExtracto "Cota teórica a la entrada del lazo de posición."@es .

ns1:Parametro_V_A_TFEED_xn a ns1:Parametro ;
    rdfs:label "V.A.TFEED.xn" ;
    ns1:documentadoEn ns1:Tabla_1304_VariablesModoHSC ;
    ns1:identificador "V.A.TFEED.xn" ;
    ns1:textoExtracto "Valor instantáneo teórico de la velocidad a la entrada del lazo de posición."@es .

ns1:Tabla_1304_VariablesModoHSC a ns1:Tabla ;
    rdfs:label "Tabla de variables del modo HSC (páginas 630-632)"@es ;
    ns1:textoExtracto "V.A.INDPOS.xn | Cota teórica del interpolador independiente."@es .

