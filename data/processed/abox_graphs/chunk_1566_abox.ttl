@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ModoHSC a ns1:Sistema ;
    rdfs:label "Sistema de control en modo HSC" ;
    ns1:monitoreaParametro ns1:Parametro_VAFEED_xn,
        ns1:Parametro_VAFTEO_xn,
        ns1:Parametro_VAPOSCMD_xn,
        ns1:Parametro_VAPOSNC_xn ;
    ns1:textoExtracto "Proceso de análisis y ajuste del modo HSC" .

ns1:Parametro_VAFEED_xn a ns1:Parametro ;
    rdfs:label "V.A.FEED.xn" ;
    ns1:identificador "V.A.FEED.xn" ;
    ns1:textoExtracto "Valor instantáneo real de la velocidad a la entrada del lazo de posición." ;
    ns1:valor "velocidad (instantánea)" .

ns1:Parametro_VAFTEO_xn a ns1:Parametro ;
    rdfs:label "V.A.FTEO.xn" ;
    ns1:identificador "V.A.FTEO.xn" ;
    ns1:textoExtracto "Consigna de velocidad para Sercos (en rpm)." ;
    ns1:valor "velocidad (consigna, rpm)" .

ns1:Parametro_VAPOSCMD_xn a ns1:Parametro ;
    rdfs:label "V.A.POSCMD.xn" ;
    ns1:identificador "V.A.POSCMD.xn" ;
    ns1:textoExtracto "Consigna de posición para Sercos." ;
    ns1:valor "posición (consigna)" .

ns1:Parametro_VAPOSNC_xn a ns1:Parametro ;
    rdfs:label "V.A.POSNC.xn" ;
    ns1:identificador "V.A.POSNC.xn" ;
    ns1:textoExtracto "Feedback de posición." ;
    ns1:valor "posición (feedback)" .

