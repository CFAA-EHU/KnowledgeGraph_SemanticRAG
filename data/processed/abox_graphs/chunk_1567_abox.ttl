@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_PosicionComando_1306 a ns1:Parametro ;
    rdfs:label "Posición comando (A.POSCMD.xn)"@es ;
    ns1:identificador "A.POSCMD.xn" ;
    ns1:monitoreaParametro ns1:SistemaControlMovimiento_1306 ;
    ns1:textoExtracto "(V.)A.POSCMD.xn" .

ns1:Parametro_VelocidadEje1_1306 a ns1:Parametro ;
    rdfs:label "Velocidad comando eje 1 (A.IPOPOS.1)"@es ;
    ns1:identificador "A.IPOPOS.1" ;
    ns1:monitoreaParametro ns1:SistemaControlMovimiento_1306 ;
    ns1:textoExtracto "Velocity command axis 1 (V.)A.IPOPOS.1" .

ns1:Componente_CompensacionCota_1306 a ns1:ComponenteMecanico ;
    rdfs:label "Compensación de cota (husillo/cruzada)"@es ;
    ns1:identificador "COMP" ;
    ns1:textoExtracto "COMP Compensación de cota debida a la compensación de husillo o a la compensación cruzada."@es .

ns1:Componente_FiltroEntrada_1306 a ns1:ComponenteElectrico ;
    rdfs:label "Filtro de entrada (A.FILTERIN.xn)"@es ;
    ns1:identificador "A.FILTERIN.xn" ;
    ns1:textoExtracto "(V.)A.FILTERIN.xn" .

ns1:Componente_FiltroSalida_1306 a ns1:ComponenteElectrico ;
    rdfs:label "Filtro de salida (A.FILTEROUT.xn)"@es ;
    ns1:identificador "A.FILTEROUT.xn" ;
    ns1:textoExtracto "(V.)A.FILTEROUT.xn" .

ns1:Componente_Interpolador_1306 a ns1:ComponenteElectrico ;
    rdfs:label "Interpolador (A.ITPOS.xn)"@es ;
    ns1:identificador "A.ITPOS.xn" ;
    ns1:textoExtracto "INTERPOLATOR (V.)A.ITPOS.xn" .

ns1:Esquema_ControlMovimiento_1306 a ns1:Esquema ;
    rdfs:label "Esquema de lazo de control de movimiento y variables de compensación"@es ;
    ns1:identificador "13.5 (Pág. 633)" ;
    ns1:textoExtracto """
    (V.)MPG.IMOVEMACH ... (V.)A.ITPOS.xn ... COMP Compensación de cota debida a la compensación de husillo o a la compensación cruzada.
    Velocity command axis 1 ... SLOPE INTERPOLATOR TRANSFOR FILTER ... +/- Analog Sercos Vel. Sercos Pos. DRIVE
    """ .

ns1:SistemaControlMovimiento_1306 a ns1:Sistema ;
    rdfs:label "Sistema de control de movimiento con compensación de cota"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_ControlMovimiento_1306 ;
    ns1:textoExtracto "INDEPENDENT INTERPOLATOR ... (V.)A.ITPOS.xn ... COMP Compensación de cota debida a la compensación de husillo o a la compensación cruzada."@es ;
    ns1:tieneComponente ns1:Componente_CompensacionCota_1306,
        ns1:Componente_FiltroEntrada_1306,
        ns1:Componente_FiltroSalida_1306,
        ns1:Componente_Interpolador_1306 .

