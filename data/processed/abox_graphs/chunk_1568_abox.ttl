@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_InterpoladorIndependiente a ns1:Sistema ;
    rdfs:label "Interpolador Independiente (Sercos Pos.)"@es ;
    ns1:monitoreaParametro ns1:Parametro_COMP,
        ns1:Parametro_DELTA ;
    ns1:textoExtracto "INDEPENDENT INTERPOLATOR (V.)A.ITPOS.xn"@es .

ns1:Parametro_COMP a ns1:Parametro ;
    rdfs:label "Compensación de cota (COMP)"@es ;
    ns1:identificador "COMP" ;
    ns1:textoExtracto "COMP Compensación de cota debida a la compensación de husillo o a la compensación cruzada."@es .

ns1:Parametro_DELTA a ns1:Parametro ;
    rdfs:label "Decalaje en el encendido (DELTA)"@es ;
    ns1:identificador "DELTA" ;
    ns1:textoExtracto "DELTA Decalaje en el encendido para mantener la cota del apagado."@es .

