@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SubrutinaBusquedaReferencia a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina asociada a la búsqueda de referencia"@es ;
    ns1:ejecutadoPor ns1:CNC ;
    ns1:textoExtracto "subrutina asociada a la búsqueda de referencia"@es .

ns1:SubrutinaCambioHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina asociada al cambio de herramienta"@es ;
    ns1:ejecutadoPor ns1:CNC ;
    ns1:textoExtracto "subrutina asociada al cambio de herramienta"@es .

ns1:CNC a ns1:Maquina ;
    rdfs:label "CNC"@es ;
    ns1:textoExtracto "El CNC dispone de una serie de subrutinas que, en función de la configuración de la máquina, deben estar definidas"@es .

