    rdfs:label "STPTW3A2131AC024MS1" ;
    rdfs:comment "STP-TW-3A-2131AC024M-S1 Actuating heads made of metal Simultaneous monitoring of two safety doors." .

ex:SIEMENSAG a owl:Class ;
    rdfs:label "SIEMENSAG" ;
    rdfs:comment "Fabricante SIEMENS AG." .

ex:SCHNEIDER a owl:Class ;
    rdfs:label "SCHNEIDER" ;
    rdfs:comment "Fabricante SCHNEIDER." .

ex:RITTAL a owl:Class ;
    rdfs:label "RITTAL" ;
    rdfs:comment "Fabricante RITTAL." .

ex:EUCHNER a owl:Class ;
    rdfs:label "EUCHNER" ;
    rdfs:comment "Fabricante EUCHNER." .