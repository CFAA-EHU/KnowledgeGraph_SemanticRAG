@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:SiemensAG a owl:Class ;
    rdfs:label "SIEMENS AG" ;
    rdfs:comment "Fabricante de componentes eléctricos" .

ex:Schneider a owl:Class ;
    rdfs:label "SCHNEIDER" ;
    rdfs:comment "Fabricante de componentes eléctricos" .

ex:Rittal a owl:Class ;
    rdfs:label "RITTAL" ;
    rdfs:comment "Fabricante de componentes eléctricos" .

ex:Euchner a owl:Class ;
    rdfs:label "EUCHNER" ;
    rdfs:comment "Fabricante de componentes de seguridad" .

ex:FinalDeCarrera a owl:Class ;
    rdfs:label "Final de carrera" ;
    rdfs:comment "Componente eléctrico" .

ex:InterruptorPuerta a owl:Class ;
    rdfs:label "SZ Door-operated switch" ;
    rdfs:comment "Interruptor operado por puerta con accesorios" .

ex:CabezalActuacion a owl:Class ;
    rdfs:label "STP-TW-3A-2131AC024M-S1" ;
    rdfs:comment "Cabezal de actuación de metal para monitoreo de dos puertas de seguridad" .

ex:BorneResorte a owl:Class ;
    rdfs:label "bornes de resorte" ;
    rdfs:comment "Bornes de resorte para conexiones eléctricas" .

ex:ComponenteElectronico a owl:Class ;
    rdfs:label "Componente electrónico" ;
    rdfs:comment "Componente electrónico genérico" .

ex:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain ex:ComponenteElectronico ;
    rdfs:range ex:Fabricante .

ex:Fabricante a owl:Class ;
    rdfs:label "Fabricante" ;
    rdfs:comment "Clase genérica para fabricantes" .

ex:tieneModelo a owl:ObjectProperty ;
    rdfs:domain ex:ComponenteElectronico ;
    rdfs:range xsd:string .

ex:tieneVoltaje a owl:ObjectProperty ;
    rdfs:domain ex:ComponenteElectronico ;
    rdfs:range xsd:string .

ex:tieneColor a owl:ObjectProperty ;
    rdfs:domain ex:ComponenteElectronico ;
    rdfs:range xsd:string .

ex:tieneTipo a owl:ObjectProperty ;
    rdfs:domain ex:ComponenteElectronico ;
    rdfs:range xsd:string .