@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_MPROGNAME a ns1:Parametro ;
    rdfs:label "Parámetro MPROGNAME"@es ;
    ns1:documentadoEn ns1:Tabla_SubrutinasFuncionesM ;
    ns1:identificador "MPROGNAME" ;
    ns1:textoExtracto "Parámetro MPROGNAME de la tabla de funciones M"@es .

ns1:Parametro_OEMSUB_G180 a ns1:Parametro ;
    rdfs:label "Parámetro OEMSUB(G180)"@es ;
    ns1:documentadoEn ns1:Tabla_SubrutinasFuncionesM ;
    ns1:identificador "OEMSUB(G180)" ;
    ns1:textoExtracto "Parámetro general OEMSUB(G180)"@es .

ns1:Parametro_OEMSUB_G189 a ns1:Parametro ;
    rdfs:label "Parámetro OEMSUB(G189)"@es ;
    ns1:documentadoEn ns1:Tabla_SubrutinasFuncionesM ;
    ns1:identificador "OEMSUB(G189)" ;
    ns1:textoExtracto "Parámetro general OEMSUB(G189)"@es .

ns1:Parametro_REFPSUB a ns1:Parametro ;
    rdfs:label "Parámetro general REFPSUB"@es ;
    ns1:documentadoEn ns1:Tabla_SubrutinasFuncionesM ;
    ns1:identificador "REFPSUB" ;
    ns1:textoExtracto "Nombre: Parámetro general REFPSUB. Canales: Subrutina por canal."@es .

ns1:Subrutina_G74 a ns1:ModoOperacion ;
    rdfs:label "Subrutina asociada a la función G74"@es ;
    ns1:identificador "G74" ;
    ns1:textoExtracto "Subrutina asociada a la función G74"@es .

ns1:Subrutina_OEM_G180aG189 a ns1:ModoOperacion ;
    rdfs:label "Subrutinas OEM asociadas a las funciones G180 a G189"@es ;
    ns1:identificador "OEMSUB(G180-G189)" ;
    ns1:textoExtracto "Subrutinas OEM asociadas a las funciones G180 a G189"@es .

ns1:Tabla_SubrutinasFuncionesM a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de subrutinas para funciones M"@es ;
    ns1:identificador "MPROGNAME" ;
    ns1:textoExtracto "Nombre: Parámetro MPROGNAME de la tabla de funciones M. Canales: Subrutina común a todos los canales. Path: ..\\Mtb\\Sub."@es .

