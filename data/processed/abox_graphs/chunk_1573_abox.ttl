@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_SETUP a ns1:ModoOperacion ;
    rdfs:label "Modo SETUP"@es ;
    ns1:textoExtracto "Con el CNC en modo SETUP (puesta a punto), las rutinas OEM cuya extensión sea fst se cargan en la memoria RAM durante la preparación de bloques."@es .

ns1:ModoOperacion_USER a ns1:ModoOperacion ;
    rdfs:label "Modo USER"@es ;
    ns1:textoExtracto "Con el CNC en modo USER, las rutinas OEM cuya extensión sea fst, se cargan en la memoria RAM en el arranque de la aplicación CNC."@es .

ns1:ProcesoCargaSubrutinas a ns1:TareaMantenimiento ;
    rdfs:label "Carga de subrutinas FST en memoria RAM"@es ;
    ns1:requiereMantenimiento ns1:MemoriaRAM_CNC ;
    ns1:textoExtracto "Para cargar una subrutina en la memoria RAM, está debe tener extensión fst. [...] El CNC comprueba si está cargada en memoria RAM, y si no lo está y hay espacio, la carga."@es .

ns1:SubrutinasFST_Fabricante a ns1:Componente ;
    rdfs:label "Subrutinas FST de fabricante"@es ;
    ns1:identificador "*.fst (OEM)" ;
    ns1:textoExtracto "Subrutinas fst de fabricante. Subrutinas con extensión fst guardadas en la carpeta ..mtb/sub."@es ;
    ns1:tieneComponente ns1:MemoriaRAM_CNC .

ns1:SubrutinasFST_Usuario a ns1:Componente ;
    rdfs:label "Subrutinas FST de usuario"@es ;
    ns1:identificador "*.fst (usuario)" ;
    ns1:textoExtracto "Subrutinas fst de usuario. Subrutinas con extensión fst que no están guardadas en la carpeta ..mtb/sub. Las rutinas de usuario cuya extensión sea fst, se cargan en la memoria RAM durante la preparación de bloques."@es ;
    ns1:tieneComponente ns1:MemoriaRAM_CNC .

ns1:MemoriaRAM_CNC a ns1:ComponenteElectrico ;
    rdfs:label "Memoria RAM del CNC"@es ;
    ns1:textoExtracto "espacio reservado en la memoria RAM para las subrutinas es 5 Mb"@es ;
    ns1:valor "5 Mb" .

