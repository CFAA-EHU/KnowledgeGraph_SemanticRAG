@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MemoriaRAM_CNC a ns1:ComponenteElectrico ;
    rdfs:label "Memoria RAM del CNC"@es ;
    ns1:textoExtracto "las rutinas OEM [...] se cargan en la memoria RAM durante la preparación de bloques."@es ;
    ns1:tieneComponente ns1:SubrutinasFST .

ns1:ModoSetup a ns1:ModoOperacion ;
    rdfs:label "Modo SETUP (puesta a punto)"@es ;
    ns1:textoExtracto "Con el CNC en modo SETUP (puesta a punto), las rutinas OEM cuya extensión sea fst se cargan en la memoria RAM durante la preparación de bloques."@es .

ns1:SubrutinasFST a ns1:Sistema ;
    rdfs:label "Sistema de subrutinas OEM (*.fst)"@es ;
    ns1:identificador "*.fst" ;
    ns1:requiereMantenimiento ns1:ModoSetup ;
    ns1:textoExtracto "las rutinas OEM cuya extensión sea fst se cargan en la memoria RAM durante la preparación de bloques."@es .

