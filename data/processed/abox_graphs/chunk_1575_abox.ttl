@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CanalCNC_1314 a ns1:InterfazUsuario ;
    rdfs:label "Canal de ejecución CNC"@es ;
    ns1:controla ns1:SubrutinaRAM_1314 ;
    ns1:textoExtracto "si ningún otro canal está ejecutando las subrutinas"@es .

ns1:ProgramaCNC_1314 a ns1:ModoOperacion ;
    rdfs:label "Programa CNC (finalización M02/M30)"@es ;
    ns1:habilitadoPor ns1:SubrutinaRAM_1314 ;
    ns1:textoExtracto "Cuando finaliza el programa (M02/M30)"@es .

ns1:SubrutinaRAM_1314 a ns1:Componente ;
    rdfs:label "Subrutina en memoria RAM"@es ;
    ns1:identificador "*.fst" ;
    ns1:textoExtracto "Cuando finaliza el programa (M02/M30) o tras un reset, si ningún otro canal está ejecutando las subrutinas, el CNC las borra de la memoria RAM. De esta forma, los cambios que se realicen en la subrutina serán tenidos en cuenta la próxima vez que se ejecute el programa."@es .

