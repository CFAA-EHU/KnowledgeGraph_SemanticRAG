@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BarraEstado_1315 a ns1:InterfazUsuario ;
    rdfs:label "Barra general de estado"@es ;
    ns1:ilustradoEn ns1:CNC_1315 ;
    ns1:textoExtracto "Durante la ejecución, el CNC muestra en la barra general de estado el nombre de la subrutina."@es .

ns1:ModoAutomatico_1315 a ns1:ModoOperacion ;
    rdfs:label "Modo automático"@es ;
    ns1:textoExtracto "desde el modo automático, para iniciar la ejecución del programa entero."@es .

ns1:SubrutinaStart_1315 a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina asociada al start"@es ;
    ns1:ejecutadoPor ns1:CNC_1315 ;
    ns1:identificador "SubrutinaStart" ;
    ns1:textoExtracto "En cada canal, el start de ejecución puede tener asociada una subrutina, que se ejecuta al pulsar la tecla [START], desde el modo automático, para iniciar la ejecución del programa entero [...] Esta subrutina permite, por ejemplo, tener definidas unas condiciones de mecanizado que condicionen la ejecución de los programas de usuario."@es .

ns1:TeclaSTART_1315 a ns1:InterfazUsuario ;
    rdfs:label "Tecla [START]"@es ;
    ns1:habilitadoPor ns1:CNC_1315 ;
    ns1:textoExtracto "subrutina, que se ejecuta al pulsar la tecla [START], desde el modo automático, para iniciar la ejecución del programa entero."@es .

ns1:CNC_1315 a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:textoExtracto "El CNC tampoco llama a la subrutina al ejecutar un ciclo desde el modo conversacional. [...] El CNC la ejecuta inmediatamente después de pulsar la tecla [START], antes de iniciar la ejecución del programa."@es .

