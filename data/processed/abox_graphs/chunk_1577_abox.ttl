@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PROGRAM_START a ns1:TareaMantenimiento ;
    rdfs:label "PROGRAM_START" ;
    ns1:identificador "PROGRAM_START" ;
    ns1:textoExtracto "Nombre y ubicación de la subrutina. El nombre de la subrutina debe ser PROGRAM_START (sin extensión) y estará guardada en la carpeta ..\\Users\\Sub." .

ns1:PROGRAM_START_C1 a ns1:TareaMantenimiento ;
    rdfs:label "PROGRAM_START_C1" ;
    ns1:identificador "PROGRAM_START_C1" ;
    ns1:textoExtracto "Nombre. | Canal. | PROGRAM_START PROGRAM_START_C1 | Canal 1. El CNC admite los dos nombres para la subrutina asociada al primer canal; si existen ambas subrutinas, el CNC ejecuta PROGRAM_START." .

ns1:PROGRAM_START_C2 a ns1:TareaMantenimiento ;
    rdfs:label "PROGRAM_START_C2" ;
    ns1:identificador "PROGRAM_START_C2" ;
    ns1:textoExtracto "Nombre. | Canal. | PROGRAM_START_C2 | Canal 2." .

ns1:PROGRAM_START_C3 a ns1:TareaMantenimiento ;
    rdfs:label "PROGRAM_START_C3" ;
    ns1:identificador "PROGRAM_START_C3" ;
    ns1:textoExtracto "Nombre. | Canal. | PROGRAM_START_C3 | Canal 3." .

ns1:PROGRAM_START_C4 a ns1:TareaMantenimiento ;
    rdfs:label "PROGRAM_START_C4" ;
    ns1:identificador "PROGRAM_START_C4" ;
    ns1:textoExtracto "Nombre. | Canal. | PROGRAM_START_C4 | Canal 4." .

