@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TeclaReset_1317 a ns1:InterfazUsuario ;
    rdfs:label "Tecla [RESET] del panel de mando"@es ;
    ns1:activaAlarma ns1:SubrutinaReset_1317 ;
    ns1:textoExtracto "al pulsar la tecla [RESET] del panel de mando"@es .

ns1:ModoEjecucionSimulada_1317 a ns1:ModoOperacion ;
    rdfs:label "Modo ejecución simulada (Funciones G)"@es ;
    ns1:textoExtracto "El CNC ejecuta la subrutina con la opción \"Funciones G\" del modo ejecución simulada."@es .

ns1:SubrutinaReset_1317 a ns1:Sistema ;
    rdfs:label "Subrutina asociada al reset"@es ;
    ns1:identificador "RESETIN" ;
    ns1:textoExtracto "En cada canal, el reset puede tener una subrutina asociada, que se ejecuta al pulsar la tecla [RESET] del panel de mando o cuando el PLC activa la marca RESETIN. Esta subrutina permite, por ejemplo, poner unas condiciones iniciales diferentes de las que fija el reset o condicionadas a la configuración de la máquina, activar operaciones/modos que deshabilita el reset, etc."@es ;
    ns1:tieneFrecuencia ns1:ModoEjecucionSimulada_1317 .

