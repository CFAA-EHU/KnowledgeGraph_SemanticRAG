@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CompensacionRadio_G41_G42 a ns1:Parametro ;
    rdfs:label "Compensación de radio (G41, G42)" ;
    ns1:identificador "G41, G42" ;
    ns1:monitoreaParametro ns1:SubrutinaReset ;
    ns1:textoExtracto "La ejecucíón tiene en cuenta la compensación de radio (funciones G41, G42), por lo que efectúa la representación gráfica correspondiente al centro de herramienta." .

ns1:ParadasPrograma_M00_M01 a ns1:Parametro ;
    rdfs:label "Paradas de programa (M00, M01)" ;
    ns1:identificador "M00, M01" ;
    ns1:monitoreaParametro ns1:SubrutinaReset ;
    ns1:textoExtracto "La ejecucíón tiene en cuenta las paradas de programa programadas mediante M00 y M01." .

ns1:Temporizaciones_G4 a ns1:Parametro ;
    rdfs:label "Temporizaciones (G4)" ;
    ns1:identificador "G4" ;
    ns1:monitoreaParametro ns1:SubrutinaReset ;
    ns1:textoExtracto "La ejecucíón tiene en cuenta las temporizaciones programadas mediante G4." .

ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "La ejecucíón no desplaza los ejes de la máquina, ni pone en marcha el cabezal." .

ns1:MaquinaCNC a ns1:Maquina ;
    rdfs:label "Máquina CNC" ;
    ns1:textoExtracto "El CNC ejecuta la subrutina... La ejecucíón no desplaza los ejes de la máquina, ni pone en marcha el cabezal." ;
    ns1:tieneComponente ns1:Cabezal .

ns1:ModoEjecucionSimulada a ns1:ModoOperacion ;
    rdfs:label "Modo ejecución simulada" ;
    ns1:textoExtracto "El CNC ejecuta la subrutina con la opción \"Funciones G\" del modo ejecución simulada." .

ns1:SubrutinaReset a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina asociada al reset" ;
    ns1:ejecutadoPor ns1:MaquinaCNC ;
    ns1:habilitadoPor ns1:ModoEjecucionSimulada ;
    ns1:textoExtracto "El CNC ejecuta la subrutina con la opción \"Funciones G\" del modo ejecución simulada." .

