@prefix ex: <https://vocab.cfaa.eus/broaching/>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix mech: <https://vocab.cfaa.eus/broaching/mechanic/>.
@prefix elec: <https://vocab.cfaa.eus/broaching/electric/>.
@prefix base: <https://vocab.cfaa.eus/broaching/base/>.

### Clases ###
ex:LlaveParaBloqueoPuertaTwin a owl:Class ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Actuator> ;
    rdfs:label "Llave para Bloqueo Puerta Twin" .

ex:InterruptorDeSeguridadConBloqueo a owl:Class ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Actuator> ;
    rdfs:label "Interruptor de seguridad con bloqueo y sistema electrónico de evaluación" .

ex:ActuadorRectoParaTransponderCodificado a owl:Class ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Actuator> ;
    rdfs:label "Straight actuator for Transponder-coded" .

ex:ConexionCabezaLectora a owl:Class ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Sensor> ;
    rdfs:label "Conexion Cabeza Lectora" .

ex:FuenteAlimentacionEstabilizada a owl:Class ;
    rdfs:label "Fuente de alimentación estabilizada" .

ex:TransformadorPrimario a owl:Class ;
    rdfs:label "Transformador primario" .

### Propiedades de Objeto ###
mech:tieneFabricante a owl:ObjectProperty .
mech:tieneDesignacion a owl:ObjectProperty .
mech:tieneCantidad a owl:ObjectProperty .

### Propiedades de Datos ###
base:tieneModelo a owl:DatatypeProperty .
base:tieneCodigo a owl:DatatypeProperty .
base:tieneFabricante a owl:DatatypeProperty .
base:tieneDesignacion a owl:DatatypeProperty .
base:tieneCantidad a owl:DatatypeProperty .