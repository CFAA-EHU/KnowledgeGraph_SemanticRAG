@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_RESETIN a ns1:Parametro ;
    rdfs:label "Marca RESETIN" ;
    ns1:documentadoEn ns1:Manual_Seccion14_3_1 ;
    ns1:identificador "RESETIN" ;
    ns1:textoExtracto "El PLC activa la marca RESETIN (RESETIN=1)." .

ns1:Marca_RESETOUT a ns1:Parametro ;
    rdfs:label "Marca RESETOUT" ;
    ns1:documentadoEn ns1:Manual_Seccion14_3_1 ;
    ns1:identificador "RESETOUT" ;
    ns1:textoExtracto "El canal activa la marca RESETOUT (RESETOUT=1) para indicar que ha finalizado el reset." .

ns1:Parametro_MINAENDW a ns1:Parametro ;
    rdfs:label "Parámetro general MINAENDW" ;
    ns1:documentadoEn ns1:Manual_Seccion14_3_1 ;
    ns1:identificador "MINAENDW" ;
    ns1:textoExtracto "Esta marca [RESETOUT] permanece activa el tiempo fijado en el parámetro general MINAENDW." .

ns1:Subrutina_PROGRAM_RESET a ns1:InterfazUsuario ;
    rdfs:label "Subrutina PROGRAM_RESET" ;
    ns1:documentadoEn ns1:Manual_Seccion14_3_1 ;
    ns1:identificador "PROGRAM_RESET" ;
    ns1:textoExtracto "El nombre de la subrutina debe ser PROGRAM_RESET (sin extensión) y estará guardada en la carpeta ..\\Users\\Sub." .

ns1:Subrutina_PROGRAM_RESET_C1 a ns1:InterfazUsuario ;
    rdfs:label "Subrutina PROGRAM_RESET_C1" ;
    ns1:documentadoEn ns1:Manual_Seccion14_3_1 ;
    ns1:identificador "PROGRAM_RESET_C1" ;
    ns1:textoExtracto "PROGRAM_RESET_C1 | Canal 1. El CNC admite los dos nombres para la subrutina asociada al primer canal; si existen ambas subrutinas, el CNC ejecuta PROGRAM_RESET." .

ns1:Subrutina_PROGRAM_RESET_C2 a ns1:InterfazUsuario ;
    rdfs:label "Subrutina PROGRAM_RESET_C2" ;
    ns1:documentadoEn ns1:Manual_Seccion14_3_1 ;
    ns1:identificador "PROGRAM_RESET_C2" ;
    ns1:textoExtracto "PROGRAM_RESET_C2 | Canal 2." .

ns1:Subrutina_PROGRAM_RESET_C3 a ns1:InterfazUsuario ;
    rdfs:label "Subrutina PROGRAM_RESET_C3" ;
    ns1:documentadoEn ns1:Manual_Seccion14_3_1 ;
    ns1:identificador "PROGRAM_RESET_C3" ;
    ns1:textoExtracto "PROGRAM_RESET_C3 | Canal 3." .

ns1:Subrutina_PROGRAM_RESET_C4 a ns1:InterfazUsuario ;
    rdfs:label "Subrutina PROGRAM_RESET_C4" ;
    ns1:documentadoEn ns1:Manual_Seccion14_3_1 ;
    ns1:identificador "PROGRAM_RESET_C4" ;
    ns1:textoExtracto "PROGRAM_RESET_C4 | Canal 4." .

ns1:Tecla_RESET a ns1:InterfazUsuario ;
    rdfs:label "Tecla [RESET]" ;
    ns1:documentadoEn ns1:Manual_Seccion14_3_1 ;
    ns1:identificador "RESET" ;
    ns1:textoExtracto "El usuario pulsa la tecla [RESET] del panel de mando" .

ns1:Manual_Seccion14_3_1 a ns1:Manual ;
    rdfs:label "Manual, Sección 14.3.1: Configurar las subrutinas" ;
    ns1:textoExtracto "Nombre y ubicación de la subrutina. El nombre de la subrutina debe ser PROGRAM_RESET (sin extensión) y estará guardada en la carpeta ..\\Users\\Sub." .

