@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Aviso_ErrorSubrutina a ns1:AvisoSeguridad ;
    rdfs:label "Error por subrutina no definida" ;
    ns1:textoExtracto "Si alguna de estas subrutinas no existe, el CNC mostrará un error cada vez que intente ejecutar un programa del 8055-MC y 8055-TC." .

ns1:Programa_8055_MC a ns1:ModoOperacion ;
    rdfs:label "Programa 8055-MC" ;
    ns1:identificador "8055-MC" ;
    ns1:requiereMantenimiento ns1:Subrutina_9998,
        ns1:Subrutina_9999 ;
    ns1:textoExtracto "programa del 8055-MC" .

ns1:Programa_8055_TC a ns1:ModoOperacion ;
    rdfs:label "Programa 8055-TC" ;
    ns1:identificador "8055-TC" ;
    ns1:requiereMantenimiento ns1:Subrutina_9998,
        ns1:Subrutina_9999 ;
    ns1:textoExtracto "programa del 8055-TC" .

ns1:Subrutina_9998 a ns1:Componente ;
    rdfs:label "Subrutina 9998" ;
    ns1:identificador "9998" ;
    ns1:textoExtracto "Rutina que ejecutará el CNC al principio de cada programa del 8055-MC y 8055-TC." .

ns1:Subrutina_9999 a ns1:Componente ;
    rdfs:label "Subrutina 9999" ;
    ns1:identificador "9999" ;
    ns1:textoExtracto "Rutina que ejecutará el CNC al final de cada programa del 8055-MC y 8055-TC." .

