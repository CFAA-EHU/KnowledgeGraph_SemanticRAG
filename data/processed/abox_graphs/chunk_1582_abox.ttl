@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_SUBPATH_CHN a ns1:Parametro ;
    rdfs:label "SUBPATH CHN" ;
    ns1:identificador "CHN" ;
    ns1:monitoreaParametro ns1:Maquina_8055 ;
    ns1:textoExtracto "Parámetro máquina; general del canal. Este parámetro indica el directorio por defecto para las subrutinas de usuario y las subrutinas necesarias para poder ejecutar programas del 8055-MC y 8055-TC." .

ns1:Maquina_8055 a ns1:Maquina ;
    rdfs:label "Máquina 8055 (modelos 8055-MC y 8055-TC)" ;
    ns1:identificador "8055" ;
    ns1:textoExtracto "subrutinas necesarias para poder ejecutar programas del 8055-MC y 8055-TC." ;
    ns1:tieneComponente ns1:Subrutina_9998,
        ns1:Subrutina_9999 .

ns1:Pagina_641 a ns1:Pagina ;
    rdfs:label "Página 641 (Sección 14.4.1)" ;
    ns1:identificador "641" ;
    ns1:textoExtracto "Configurar las subrutinas." .

ns1:Subrutina_9998 a ns1:Componente ;
    rdfs:label "Subrutina 9998" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionSubrutinas ;
    ns1:identificador "9998" ;
    ns1:textoExtracto "El nombre de las subrutinas es 9998 y 9999. Ambas subrutinas deben estar guardadas en el path indicado por el parámetro general SUBPATH." .

ns1:Subrutina_9999 a ns1:Componente ;
    rdfs:label "Subrutina 9999" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionSubrutinas ;
    ns1:identificador "9999" ;
    ns1:textoExtracto "El nombre de las subrutinas es 9998 y 9999. Ambas subrutinas deben estar guardadas en el path indicado por el parámetro general SUBPATH." .

ns1:Tabla_ConfiguracionSubrutinas a ns1:Tabla ;
    rdfs:label "Tabla de configuración de subrutinas (Sección 14.4.1)" ;
    ns1:ilustradoEn ns1:Pagina_641 ;
    ns1:textoExtracto "Nombre y ubicación de la subrutina. | Parámetro. |  | Significado. | --- | SUBPATH CHN | Este parámetro indica el directorio por defecto para las subrutinas de usuario..." .

