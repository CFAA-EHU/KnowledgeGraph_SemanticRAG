@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:subrutinaKinCal_Begin a ns1:Componente ;
    rdfs:label "KinCal_Begin.nc" ;
    ns1:documentadoEn ns1:cicloCalibracionCinematica ;
    ns1:identificador "KinCal_Begin.nc" ;
    ns1:textoExtracto "Subrutina asociada al inicio del ciclo de calibración de cinemática." .

ns1:subrutinaKinCal_End a ns1:Componente ;
    rdfs:label "KinCal_End.nc" ;
    ns1:documentadoEn ns1:cicloCalibracionCinematica ;
    ns1:identificador "KinCal_End.nc" ;
    ns1:textoExtracto "Subrutina asociada al final del ciclo de calibración de cinemática." .

ns1:cicloCalibracionCinematica a ns1:ModoOperacion ;
    rdfs:label "Ciclo de calibración de cinemática" ;
    ns1:textoExtracto "El ciclo de calibración de cinemática tiene asociadas dos subrutinas..." ;
    ns1:tieneComponente ns1:subrutinaKinCal_Begin,
        ns1:subrutinaKinCal_End .

