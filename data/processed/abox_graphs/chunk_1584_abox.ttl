@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:sistema_subrutinas_kinematicas a ns1:Sistema ;
    rdfs:label "Sistema de subrutinas cinemáticas" ;
    ns1:compuestoPor ns1:subrutina_KinCal_Begin,
        ns1:subrutina_KinCal_End ;
    ns1:textoExtracto "Todos los canales utilizan las mismas subrutinas." .

ns1:subrutina_KinCal_Begin a ns1:Componente ;
    rdfs:label "Subrutina KinCal_Begin" ;
    ns1:identificador "KinCal_Begin.nc" ;
    ns1:textoExtracto "El nombre de las subrutinas es KinCal_Begin.nc [...] Ambas subrutinas deben estar guardadas en la carpeta ..\\Mtb\\Sub." .

ns1:subrutina_KinCal_End a ns1:Componente ;
    rdfs:label "Subrutina KinCal_End" ;
    ns1:identificador "KinCal_End.nc" ;
    ns1:textoExtracto "El nombre de las subrutinas es [...] KinCal_End.nc. Ambas subrutinas deben estar guardadas en la carpeta ..\\Mtb\\Sub." .

