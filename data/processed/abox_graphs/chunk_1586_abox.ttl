@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoModoNoSeguroPalpador a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de modo no seguro del palpador" ;
    ns1:mitigaRiesgo ns1:ModoSeguroPalpador ;
    ns1:textoExtracto "para avisar, si están desactivadas, que el palpador está en modo no seguro" .

ns1:Marca_PROBE1MONIT a ns1:Parametro ;
    rdfs:label "Marca PROBE1MONIT" ;
    ns1:identificador "PROBE1MONIT" ;
    ns1:monitoreaParametro ns1:ModoSeguroPalpador ;
    ns1:textoExtracto "Gestión de las marcas PROBE1MONIT/PROBE2MONIT en la subrutina." .

ns1:Marca_PROBE2MONIT a ns1:Parametro ;
    rdfs:label "Marca PROBE2MONIT" ;
    ns1:identificador "PROBE2MONIT" ;
    ns1:monitoreaParametro ns1:ModoSeguroPalpador ;
    ns1:textoExtracto "Gestión de las marcas PROBE1MONIT/PROBE2MONIT en la subrutina." .

ns1:Subrutina_Sub_Probe_Tool_Begin_fst a ns1:ModoOperacion ;
    rdfs:label "Subrutina Sub_Probe_Tool_Begin.fst" ;
    ns1:identificador "Sub_Probe_Tool_Begin.fst" ;
    ns1:textoExtracto "Se recomienda que OEM gestione ambas marcas desde la subrutina Sub_Probe_Tool_Begin.fst para avisar, si están desactivadas, que el palpador está en modo no seguro." .

ns1:ModoSeguroPalpador a ns1:ModoOperacion ;
    rdfs:label "Modo seguro del palpador" ;
    ns1:textoExtracto "Estas marcas están asociadas al modo seguro del palpador." .

