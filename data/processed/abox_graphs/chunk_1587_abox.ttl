@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCNC a ns1:Sistema ;
    ns1:textoExtracto "el CNC carga esta subrutina en la memoria RAM del CNC" ;
    ns1:tieneComponente ns1:Sub_Probe_Tool_Begin,
        ns1:Sub_Probe_Tool_End .

ns1:Sub_Probe_Tool_Begin a ns1:InterfazUsuario ;
    rdfs:label "Sub_Probe_Tool_Begin.fst" ;
    ns1:identificador "Sub_Probe_Tool_Begin.fst" ;
    ns1:textoExtracto "El nombre de las subrutinas es Sub_Probe_Tool_Begin.fst [...] Al ser una subrutina OEM con extensión fst, el CNC carga esta subrutina en la memoria RAM del CNC." .

ns1:Sub_Probe_Tool_End a ns1:InterfazUsuario ;
    rdfs:label "Sub_Probe_Tool_End.fst" ;
    ns1:identificador "Sub_Probe_Tool_End.fst" ;
    ns1:textoExtracto "El nombre de las subrutinas es [...] Sub_Probe_Tool_End.fst. Ambas subrutinas deben estar guardadas en la carpeta ..\\Mtb\\Sub." .

