@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Aviso_PROBE1_SafeMode a ns1:AvisoSeguridad ;
    rdfs:label "PROBE NOT IN SAFE MODE" ;
    ns1:mitigaRiesgo ns1:Sensor_PROBE1 ;
    ns1:textoExtracto "$IF [V.PLC.PROBE1MONIT==0] #MSG[\"PROBE NOT IN SAFE MODE\"] $ENDIF"@en .

ns1:Aviso_PROBE1_Touching a ns1:AvisoSeguridad ;
    rdfs:label "PROBE1 SIGNAL TOUCHING" ;
    ns1:mitigaRiesgo ns1:Sensor_PROBE1 ;
    ns1:textoExtracto "$IF [V.G.PRBST1==1] #WARNING[\"PROBE1 SIGNAL TOUCHING\"] M0 $ENDIF"@en .

ns1:Subrutina_Sub_Probe_Tool_Begin a ns1:Sistema ;
    rdfs:label "Sub_Probe_Tool_Begin.fst" ;
    ns1:identificador "Sub_Probe_Tool_Begin.fst" ;
    ns1:textoExtracto "Ejemplo de subrutina Sub_Probe_Tool_Begin.fst suministrada por Fagor (a adaptar por el OEM). # ESBLK ; Activate PROBE1 Hardware by PLC output. ; Check PROBE is READY with PLC Input from Probe Hardware."@en ;
    ns1:tieneComponente ns1:Sensor_PROBE1 .

ns1:Subrutina_Sub_Probe_Tool_End a ns1:Sistema ;
    rdfs:label "Sub_Probe_Tool_End.fst" ;
    ns1:identificador "Sub_Probe_Tool_End.fst" ;
    ns1:textoExtracto "Ejemplo de subrutina Sub_Probe_Tool_End.fst suministrada por Fagor (a adaptar por el OEM). # ESBLK ;Deactivate PROBE1 Hardware by PLC output #RETDSBLK"@en ;
    ns1:tieneComponente ns1:Sensor_PROBE1 .

ns1:Parametro_PROBE1ENA a ns1:Parametro ;
    rdfs:label "PROBE1ENA" ;
    ns1:identificador "PROBE1ENA" ;
    ns1:textoExtracto "PROBE1ENA; PROBE1 is enabled confirmation signal to CNC. If not used in PLC, it is actived by default."@en ;
    ns1:valor "1" .

ns1:Parametro_PROBE1MONIT a ns1:Parametro ;
    rdfs:label "PROBE1MONIT" ;
    ns1:identificador "PROBE1MONIT" ;
    ns1:textoExtracto "PROBE1MONIT; It activates PROBE1 in SAFE mode. If probe is actived in no G100/3 motion, CNC will stop motion and shows an error."@en ;
    ns1:valor "0" .

ns1:Sensor_PROBE1 a ns1:Sensor ;
    rdfs:label "PROBE1" ;
    ns1:identificador "PROBE1" ;
    ns1:monitoreaParametro ns1:Parametro_PROBE1ENA,
        ns1:Parametro_PROBE1MONIT ;
    ns1:textoExtracto "Check PROBE is READY with PLC Input from Probe Hardware. [...] PROBE1ENA; PROBE1 is enabled confirmation signal to CNC."@en .

