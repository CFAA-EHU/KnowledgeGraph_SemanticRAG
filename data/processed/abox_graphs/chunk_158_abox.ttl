@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix siemens: <http://www.siemens.com/> .
@prefix murrelektronik: <http://www.murrelektronik.com/> .
@prefix pilz: <http://www.pilz.com/> .
@prefix schneider: <http://www.schneider-electric.com/> .
@prefix rittal: <http://www.rittal.com/> .
@prefix phoenix: <http://www.phoenixcontact.com/> .
@prefix admin: <https://admin-shell.io/dictionary/> .

ex:TransformadorPrimario a owl:Class ;
    rdfs:isDefinedBy <http://www.murrelektronik.com/> .

ex:PNOZmulti2BaseUnit a owl:Class ;
    rdfs:isDefinedBy <http://www.pilz.com/> .

ex:ChipCard a owl:Class ;
    rdfs:isDefinedBy <http://www.pilz.com/> .

ex:PNOZmulti2InputModule a owl:Class ;
    rdfs:isDefinedBy <http://www.pilz.com/> .

ex:BornasDeResorte a owl:Class ;
    rdfs:isDefinedBy <http://www.pilz.com/> .

ex:UnidadIluminada a owl:Class ;
    rdfs:isDefinedBy <http://www.schneider-electric.com/> .

ex:LightColumnBase a owl:Class ;
    rdfs:isDefinedBy <http://www.schneider-electric.com/> .

ex:BaseDeFijacion a owl:Class ;
    rdfs:isDefinedBy <http://www.schneider-electric.com/> .

ex:CajaDeMando a owl:Class ;
    rdfs:isDefinedBy <http://www.rittal.com/> .

ex:ArticulacionMural a owl:Class ;
    rdfs:isDefinedBy <http://www.rittal.com/> .

ex:AnglePiece a owl:Class ;
    rdfs:isDefinedBy <http://www.rittal.com/> .

ex:Coupling a owl:Class ;
    rdfs:isDefinedBy admin:Coupling .

ex:SupportSection a owl:Class ;
    rdfs:isDefinedBy <http://www.rittal.com/> .

ex:DispositivoESDescentralizado a owl:Class ;
    rdfs:isDefinedBy <http://www.phoenixcontact.com/> .

ex:TransformadorPrimario rdfs:subClassOf ex:Transformador .
ex:PNOZmulti2BaseUnit rdfs:subClassOf ex:BaseUnit .
ex:ChipCard rdfs:subClassOf ex:ChipCard .
ex:PNOZmulti2InputModule rdfs:subClassOf ex:InputModule .
ex:BornasDeResorte rdfs:subClassOf ex:Bornes .
ex:UnidadIluminada rdfs:subClassOf ex:UnidadIluminada .
ex:LightColumnBase rdfs:subClassOf ex:Base .
ex:BaseDeFijacion rdfs:subClassOf ex:Base .
ex:CajaDeMando rdfs:subClassOf ex:CajaDeMando .
ex:ArticulacionMural rdfs:subClassOf ex:Articulacion .
ex:AnglePiece rdfs:subClassOf ex:AnglePiece .
ex:Coupling rdfs:subClassOf ex:Coupling .
ex:SupportSection rdfs:subClassOf ex:SupportSection .
ex:DispositivoESDescentralizado rdfs:subClassOf ex:DispositivoESDescentralizado .