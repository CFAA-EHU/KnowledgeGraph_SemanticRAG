@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_CNC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de usuario del CNC (ejecución de subrutinas)"@es ;
    ns1:controla ns1:Subrutina_Probe_Piece_Begin,
        ns1:Subrutina_Probe_Piece_End ;
    ns1:textoExtracto "el CNC carga esta subrutina en la memoria RAM del CNC. Ver en la '14.1 Ejecutar subrutinas desde la memoria RAM (extensión *.fst).'"@es .

ns1:Pagina_637 a ns1:Pagina ;
    rdfs:label "Página 637: Ejecutar subrutinas desde la memoria RAM"@es ;
    ns1:documentadoEn ns1:Manual_CNC ;
    ns1:identificador "637" ;
    ns1:textoExtracto "Ver en la '14.1 Ejecutar subrutinas desde la memoria RAM (extensión *.fst).' página 637."@es .

ns1:Subrutina_Probe_Piece_Begin a ns1:Sistema ;
    rdfs:label "Subrutina Sub_Probe_Piece_Begin"@es ;
    ns1:identificador "Sub_Probe_Piece_Begin.fst" ;
    ns1:textoExtracto "El nombre de las subrutinas es Sub_Probe_Piece_Begin.fst [...] Al ser una subrutina OEM con extensión fst, el CNC carga esta subrutina en la memoria RAM del CNC."@es .

ns1:Subrutina_Probe_Piece_End a ns1:Sistema ;
    rdfs:label "Subrutina Sub_Probe_Piece_End"@es ;
    ns1:identificador "Sub_Probe_Piece_End.fst" ;
    ns1:textoExtracto "El nombre de las subrutinas es [...] Sub_Probe_Piece_End.fst. [...] Al ser una subrutina OEM con extensión fst, el CNC carga esta subrutina en la memoria RAM del CNC."@es .

