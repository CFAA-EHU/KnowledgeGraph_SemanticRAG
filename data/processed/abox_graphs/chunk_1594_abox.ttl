@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_Broaching a ns1:Maquina ;
    rdfs:label "Máquina de brochado (configuración multicanal)" ;
    ns1:textoExtracto "Si hay varios canales, puede haber una subrutina diferente para cada canal." ;
    ns1:tieneComponente ns1:Parametro_TOOLSUB_CHN .

ns1:Subrutina_T a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina asociada a la función T" ;
    ns1:documentadoEn ns1:Parametro_TOOLSUB_CHN ;
    ns1:textoExtracto "Subrutina asociada a la función T. Esta subrutina debe estar definida en el parámetro general TOOLSUB y estará guardada en la carpeta ..\\Mtb\\Sub." .

ns1:Parametro_TOOLSUB_CHN a ns1:Parametro ;
    rdfs:label "TOOLSUB CHN" ;
    ns1:identificador "TOOLSUB CHN" ;
    ns1:textoExtracto "TOOLSUB CHN | Subrutina asociada a la función T. [CHN].......Parámetro máquina; general del canal. Nombre y ubicación de la subrutina." ;
    ns1:valor "Nombre y ubicación de la subrutina asociada a la función T" .

