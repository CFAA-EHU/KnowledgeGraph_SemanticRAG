@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_FuncionesM a ns1:Tabla ;
    rdfs:label "Tabla de funciones M"@es ;
    ns1:documentadoEn ns1:Pagina_650 ;
    ns1:textoExtracto "Esta subrutina debe estar definida en la tabla de funciones \"M\" y estará guardada en la carpeta ..\\Mtb\\Sub."@es .

ns1:Pagina_650 a ns1:Pagina ;
    ns1:identificador "650" ;
    ns1:textoExtracto "14.11 Subrutinas asociadas a las funciones M."@es .

