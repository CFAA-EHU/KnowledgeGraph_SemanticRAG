@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Subrutina_G74 a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina asociada a G74"@es ;
    ns1:ejecutadoPor ns1:Funcion_G74 ;
    ns1:requiereMantenimiento ns1:Maquina_Generica ;
    ns1:textoExtracto "Dentro de esta subrutina deben programarse los ejes y el orden en el que se deben referenciar los ejes y el cabezal."@es .

ns1:Cabezal_Generico a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal (referenciado en G74)"@es ;
    ns1:textoExtracto "el orden en el que se deben referenciar [...] el cabezal"@es .

ns1:Funcion_G74 a ns1:ModoOperacion ;
    rdfs:label "G74 (búsqueda de referencia máquina)"@es ;
    ns1:identificador "G74" ;
    ns1:textoExtracto "La función G74 (búsqueda de referencia máquina) se puede programar de 2 formas; indicando los ejes y el orden en el que se referencia los ejes o programando sólo G74 (sin ejes)."@es .

ns1:Maquina_Generica a ns1:Maquina ;
    rdfs:label "Máquina (contexto de referencia G74)"@es ;
    ns1:textoExtracto "búsqueda de referencia máquina"@es ;
    ns1:tieneComponente ns1:Cabezal_Generico .

