@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Maquina_Configurable a ns1:Maquina ;
    rdfs:label "Máquina con canales configurables" ;
    ns1:textoExtracto "Si hay varios canales, puede haber una subrutina diferente para cada canal." ;
    ns1:tieneComponente ns1:Subrutina_G74 .

ns1:Parametro_REFPSUB_CHN a ns1:Parametro ;
    rdfs:label "REFPSUB CHN" ;
    ns1:identificador "REFPSUB CHN" ;
    ns1:textoExtracto "Subrutina asociada a la función G74. [CHN].......Parámetro máquina; general del canal. Nombre y ubicación de la subrutina." ;
    ns1:valor "sub_ref.nc"^^xsd:string .

ns1:Subrutina_G74 a ns1:Componente ;
    rdfs:label "Subrutina G74" ;
    ns1:monitoreaParametro ns1:Parametro_REFPSUB_CHN ;
    ns1:textoExtracto "Subrutina asociada a la función G74. Esta subrutina debe estar definida en el parámetro general REFPSUB (por defecto sub_ref.nc) y estará guardada en la carpeta ..\\Mtb\\Sub." .

