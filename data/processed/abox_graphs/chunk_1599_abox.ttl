@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC_1338 a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:controla ns1:FuncionM_1338 ;
    ns1:textoExtracto "el CNC ejecutará en lugar de la función"@es .

ns1:SubrutinaAsociada_1338 a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina asociada a función M"@es ;
    ns1:ejecutadoPor ns1:FuncionM_1338 ;
    ns1:textoExtracto "subrutina asociada, que el CNC ejecutará en lugar de la función"@es .

ns1:FuncionM_1338 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función auxiliar M"@es ;
    ns1:identificador "M" ;
    ns1:textoExtracto "Las funciones auxiliares \"M\" pueden tener una subrutina asociada, que el CNC ejecutará en lugar de la función."@es .

