@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ParametroFUNM a ns1:Parametro ;
    rdfs:label "FUNM"@es ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:identificador "FUNM" ;
    ns1:monitoreaParametro ns1:ParametroMPROGNAME ;
    ns1:textoExtracto "[FUNM]....Parámetro máquina; tabla de funciones \"M\"."@es .

ns1:SubrutinaM a ns1:Sistema ;
    rdfs:label "Subrutina asociada a función M"@es ;
    ns1:detalladoEnEsquema ns1:TablaFuncionesM ;
    ns1:textoExtracto "Nombre y ubicación de la subrutina. Estas subrutinas deben estar definidas en la tabla de funciones \"M\", en el campo MPROGNAME, y estarán guardadas en la carpeta ..\\Mtb\\Sub."@es .

ns1:ParametroMPROGNAME a ns1:Parametro ;
    rdfs:label "MPROGNAME" ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:identificador "MPROGNAME" ;
    ns1:textoExtracto "MPROGNAME FUNM | Nombre de subrutina asociada a la función M."@es .

ns1:TablaFuncionesM a ns1:Tabla ;
    rdfs:label "Tabla de funciones M"@es ;
    ns1:identificador "M" ;
    ns1:textoExtracto "tabla de funciones \"M\""@es .

