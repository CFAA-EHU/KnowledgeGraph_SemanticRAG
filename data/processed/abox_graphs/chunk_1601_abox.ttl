@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazExterna_INT a ns1:InterfazUsuario ;
    rdfs:label "Aplicación externa (INT)"@es ;
    ns1:monitoreaParametro ns1:Variable_MPM_MPROGNAME ;
    ns1:textoExtracto "(INT) una aplicación externa"@es .

ns1:ModoOperacion_MDI_MDA a ns1:ModoOperacion ;
    rdfs:label "Modo MDI/MDA"@es ;
    ns1:monitoreaParametro ns1:Variable_MPM_MPROGNAME ;
    ns1:textoExtracto "modo MDI/MDA"@es .

ns1:ModoOperacion_PLC a ns1:ModoOperacion ;
    rdfs:label "Modo PLC"@es ;
    ns1:monitoreaParametro ns1:Variable_MPM_MPROGNAME ;
    ns1:textoExtracto "PLC"@es .

ns1:ModoOperacion_PRG a ns1:ModoOperacion ;
    rdfs:label "Modo PRG (programa pieza)"@es ;
    ns1:monitoreaParametro ns1:Variable_MPM_MPROGNAME ;
    ns1:textoExtracto "el programa pieza"@es .

ns1:Tabla_14_11_2_Variables a ns1:Tabla ;
    rdfs:label "Tabla de variables accesibles desde PRG, MDI/MDA, PLC e INT (Sección 14.11.2)"@es ;
    ns1:identificador "14.11.2" ;
    ns1:textoExtracto "Las siguientes variables son accesibles desde; (PRG) el programa pieza y desde el modo MDI/MDA, PLC e (INT) una aplicación externa. La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W)."@es .

ns1:Variable_MPM_MPROGNAME a ns1:Parametro ;
    rdfs:label "MPM.MPROGNAME[pos]"@es ;
    ns1:documentadoEn ns1:Tabla_14_11_2_Variables ;
    ns1:identificador "MPM.MPROGNAME[pos]" ;
    ns1:textoExtracto "Nombre de subrutina asociada a la función M. Unidades: Texto. [...] Sintaxis: MPM.MPROGNAME[12] | Posición 12 de la tabla de funciones M."@es ;
    ns1:valor "Texto"@es .

