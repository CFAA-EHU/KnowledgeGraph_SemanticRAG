@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC (con parámetros OEMSUB)" ;
    ns1:documentadoEn ns1:Tabla_AsignacionSubrutinas_14_12_1 ;
    ns1:textoExtracto "Parámetro máquina; general del canal. [...] guardadas en la carpeta ..\\Mtb\\Sub. Estas subrutinas se pueden cargar en la memoria RAM (extensión fst)." ;
    ns1:tieneComponente ns1:Parametro_CHN,
        ns1:Parametro_OEMSUB_G180_G189,
        ns1:Parametro_OEMSUB_G380_G399 .

ns1:Pagina_651 a ns1:Pagina ;
    rdfs:label "Página 651 (Sección 14.12.1)" ;
    ns1:identificador "651" ;
    ns1:textoExtracto "Asignar las subrutinas a las funciones. [...] Estas subrutinas deben estar definidas en los parámetros generales OEMSUB y estarán guardadas en la carpeta ..\\Mtb\\Sub." .

ns1:Parametro_CHN a ns1:Parametro ;
    rdfs:label "CHN" ;
    ns1:identificador "CHN" ;
    ns1:textoExtracto "[CHN].......Parámetro máquina; general del canal. Nombre y ubicación de la subrutina." ;
    ns1:valor "Nombre/ubicación de subrutina (parámetro general de canal)" .

ns1:Parametro_OEMSUB_G180_G189 a ns1:Parametro ;
    rdfs:label "OEMSUB (G180-G189)" ;
    ns1:identificador "OEMSUB (G180-G189)" ;
    ns1:textoExtracto "OEMSUB (G180) CHN [...] OEMSUB (G189) | Subrutinas asociadas a las funciones G180 a G189." ;
    ns1:valor "Subrutinas asociadas a funciones G180-G189" .

ns1:Parametro_OEMSUB_G380_G399 a ns1:Parametro ;
    rdfs:label "OEMSUB (G380-G399)" ;
    ns1:identificador "OEMSUB (G380-G399)" ;
    ns1:textoExtracto "OEMSUB (G380) CHN [...] OEMSUB (G399) | Subrutinas asociadas a las funciones G380 a G399." ;
    ns1:valor "Subrutinas asociadas a funciones G380-G399" .

ns1:Tabla_AsignacionSubrutinas_14_12_1 a ns1:Tabla ;
    rdfs:label "Tabla de asignación de subrutinas (Sección 14.12.1)" ;
    ns1:documentadoEn ns1:Pagina_651 ;
    ns1:textoExtracto "Asignar las subrutinas a las funciones. | Parámetro. | Significado. | OEMSUB (G180) CHN [...] OEMSUB (G189) | Subrutinas asociadas a las funciones G180 a G189. | OEMSUB (G380) CHN [...] OEMSUB (G399) | Subrutinas asociadas a las funciones G380 a G399." .

