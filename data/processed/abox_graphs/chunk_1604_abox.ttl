@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_INT a ns1:ModoOperacion ;
    rdfs:label "Modo INT (aplicación externa)"@es ;
    ns1:textoExtracto "(INT) una aplicación externa"@es .

ns1:ModoOperacion_MDI_MDA a ns1:ModoOperacion ;
    rdfs:label "Modo MDI/MDA"@es ;
    ns1:textoExtracto "el programa pieza y desde el modo MDI/MDA"@es .

ns1:ModoOperacion_PLC a ns1:ModoOperacion ;
    rdfs:label "Modo PLC"@es ;
    ns1:textoExtracto "desde el modo [...] PLC"@es .

ns1:ModoOperacion_PRG a ns1:ModoOperacion ;
    rdfs:label "Modo PRG (programa pieza)"@es ;
    ns1:textoExtracto "(PRG) el programa pieza"@es .

ns1:Variable_OEMSUB1 a ns1:Parametro ;
    rdfs:label "V.[ch].MPG.OEMSUB1" ;
    ns1:documentadoEn ns1:Tabla_14_12_2_VariablesAccesibles ;
    ns1:identificador "V.[ch].MPG.OEMSUB1" ;
    ns1:textoExtracto "Subrutinas OEM asociadas a las funciones G180 a G189. Unidades: -."@es ;
    ns1:valor "R (solo lectura en INT)" .

ns1:Variable_OEMSUB10 a ns1:Parametro ;
    rdfs:label "V.[ch].MPG.OEMSUB10" ;
    ns1:documentadoEn ns1:Tabla_14_12_2_VariablesAccesibles ;
    ns1:identificador "V.[ch].MPG.OEMSUB10" ;
    ns1:textoExtracto "Subrutinas OEM asociadas a las funciones G180 a G189. Unidades: -."@es ;
    ns1:valor "R (solo lectura en INT)" .

ns1:Variable_OEMSUB11 a ns1:Parametro ;
    rdfs:label "V.[ch].MPG.OEMSUB11" ;
    ns1:documentadoEn ns1:Tabla_14_12_2_VariablesAccesibles ;
    ns1:identificador "V.[ch].MPG.OEMSUB11" ;
    ns1:textoExtracto "Subrutinas OEM asociadas a las funciones G380 a G399. Unidades: -."@es ;
    ns1:valor "R (solo lectura en INT)" .

ns1:Variable_OEMSUB30 a ns1:Parametro ;
    rdfs:label "V.[ch].MPG.OEMSUB30" ;
    ns1:documentadoEn ns1:Tabla_14_12_2_VariablesAccesibles ;
    ns1:identificador "V.[ch].MPG.OEMSUB30" ;
    ns1:textoExtracto "Subrutinas OEM asociadas a las funciones G380 a G399. Unidades: -."@es ;
    ns1:valor "R (solo lectura en INT)" .

ns1:Tabla_14_12_2_VariablesAccesibles a ns1:Tabla ;
    rdfs:label "Tabla de variables accesibles en PRG, MDI/MDA, PLC e INT"@es ;
    ns1:documentadoEn ns1:Pagina_651 ;
    ns1:textoExtracto "Las siguientes variables son accesibles desde; (PRG) el programa pieza y desde el modo MDI/MDA, PLC e (INT) una aplicación externa. La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W)."@es .

