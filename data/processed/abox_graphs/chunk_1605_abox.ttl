@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_1344 a ns1:Maquina ;
    rdfs:label "Máquina"@es ;
    ns1:textoExtracto "el fabricante de la máquina"@es ;
    ns1:tieneComponente ns1:PLC_1344 .

ns1:SubrutinaInterrupcion_1344 a ns1:Componente ;
    rdfs:label "Subrutina de interrupción"@es ;
    ns1:ejecutadoPor ns1:PLC_1344 ;
    ns1:textoExtracto "Las subrutinas de interrupción las define el fabricante de la máquina y se ejecutan desde el PLC. Cuando el PLC ordena la ejecución de una de estas subrutinas, el canal interrumpe la ejecución del programa y ejecuta la s..."@es .

ns1:PLC_1344 a ns1:ComponenteElectrico ;
    rdfs:label "PLC"@es ;
    ns1:controla ns1:SubrutinaInterrupcion_1344 ;
    ns1:textoExtracto "el PLC. Cuando el PLC ordena la ejecución de una de estas subrutinas"@es .

