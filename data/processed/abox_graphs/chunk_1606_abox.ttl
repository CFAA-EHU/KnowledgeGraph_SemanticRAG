@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_SistemaControl a ns1:Maquina ;
    rdfs:label "Máquina (sistema de control)" ;
    ns1:textoExtracto "[CHN].......Parámetro máquina; general del canal." ;
    ns1:tieneComponente ns1:Parametro_INIT1SUB,
        ns1:Parametro_INIT2SUB,
        ns1:Parametro_INIT3SUB,
        ns1:Parametro_INIT4SUB,
        ns1:Parametro_INT1SUB_CHN,
        ns1:Parametro_INT2SUB_CHN,
        ns1:Parametro_INT3SUB_CHN,
        ns1:Parametro_INT4SUB_CHN .

ns1:Tabla_ConfiguracionSubrutinas a ns1:Tabla ;
    rdfs:label "Tabla de configuración de subrutinas de interrupción" ;
    ns1:documentadoEn ns1:Pagina_652 ;
    ns1:textoExtracto "Asignar las subrutinas a las funciones. | Parámetro. |  | Significado. | --- | --- | --- | INT1SUB CHN ꞏꞏ INT4SUB |  | Subrutinas de interrupción. [CHN].......Parámetro máquina; general del canal. Nombre y ubicación de la subrutina." .

ns1:Pagina_652 a ns1:Pagina ;
    rdfs:label "Página 652 - Configuración de subrutinas" ;
    ns1:identificador "652" ;
    ns1:textoExtracto "Sección 14.13.1 Configurar las subrutinas. Asignar las subrutinas a las funciones." .

ns1:Parametro_INIT1SUB a ns1:Parametro ;
    rdfs:label "INIT1SUB" ;
    ns1:identificador "INIT1SUB" ;
    ns1:textoExtracto "Estas subrutinas deben estar definidas en los parámetros generales INIT1SUB a INIT4SUB" .

ns1:Parametro_INIT2SUB a ns1:Parametro ;
    rdfs:label "INIT2SUB" ;
    ns1:identificador "INIT2SUB" ;
    ns1:textoExtracto "Estas subrutinas deben estar definidas en los parámetros generales INIT1SUB a INIT4SUB" .

ns1:Parametro_INIT3SUB a ns1:Parametro ;
    rdfs:label "INIT3SUB" ;
    ns1:identificador "INIT3SUB" ;
    ns1:textoExtracto "Estas subrutinas deben estar definidas en los parámetros generales INIT1SUB a INIT4SUB" .

ns1:Parametro_INIT4SUB a ns1:Parametro ;
    rdfs:label "INIT4SUB" ;
    ns1:identificador "INIT4SUB" ;
    ns1:textoExtracto "Estas subrutinas deben estar definidas en los parámetros generales INIT1SUB a INIT4SUB" .

ns1:Parametro_INT1SUB_CHN a ns1:Parametro ;
    rdfs:label "INT1SUB CHN" ;
    ns1:identificador "INT1SUB" ;
    ns1:textoExtracto "INT1SUB CHN [...] Subrutinas de interrupción. [CHN].......Parámetro máquina; general del canal. Nombre y ubicación de la subrutina." .

ns1:Parametro_INT2SUB_CHN a ns1:Parametro ;
    rdfs:label "INT2SUB CHN" ;
    ns1:identificador "INT2SUB" ;
    ns1:textoExtracto "[...] INT4SUB |  | Subrutinas de interrupción. [CHN].......Parámetro máquina; general del canal." .

ns1:Parametro_INT3SUB_CHN a ns1:Parametro ;
    rdfs:label "INT3SUB CHN" ;
    ns1:identificador "INT3SUB" ;
    ns1:textoExtracto "[...] INT4SUB |  | Subrutinas de interrupción. [CHN].......Parámetro máquina; general del canal." .

ns1:Parametro_INT4SUB_CHN a ns1:Parametro ;
    rdfs:label "INT4SUB CHN" ;
    ns1:identificador "INT4SUB" ;
    ns1:textoExtracto "INT4SUB |  | Subrutinas de interrupción. [CHN].......Parámetro máquina; general del canal." .

