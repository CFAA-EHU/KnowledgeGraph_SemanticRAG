@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Tabla1346_652 a ns1:Tabla ;
    ns1:textoExtracto "Las siguientes variables son accesibles desde; (PRG) el programa pieza y desde el modo MDI/MDA, PLC e (INT) una aplicación externa. La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W)...." ;
    ns1:tieneComponente ns1:Variable_MPG_INT1SUB,
        ns1:Variable_MPG_INT2SUB,
        ns1:Variable_MPG_INT3SUB,
        ns1:Variable_MPG_INT4SUB .

ns1:Variable_MPG_INT1SUB a ns1:Parametro ;
    ns1:identificador "(V.)[ch].MPG.INT1SUB" ;
    ns1:textoExtracto "(V.)[ch].MPG.INT1SUB" .

ns1:Variable_MPG_INT2SUB a ns1:Parametro ;
    ns1:identificador "(V.)[ch].MPG.INT2SUB" ;
    ns1:textoExtracto "(V.)[ch].MPG.INT2SUB" .

ns1:Variable_MPG_INT3SUB a ns1:Parametro ;
    ns1:identificador "(V.)[ch].MPG.INT3SUB" ;
    ns1:textoExtracto "(V.)[ch].MPG.INT3SUB" .

ns1:Variable_MPG_INT4SUB a ns1:Parametro ;
    ns1:identificador "(V.)[ch].MPG.INT4SUB" ;
    ns1:textoExtracto "(V.)[ch].MPG.INT4SUB" .

