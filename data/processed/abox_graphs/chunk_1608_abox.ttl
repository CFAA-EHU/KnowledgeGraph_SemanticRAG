@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaquinaLaser a ns1:Maquina ;
    rdfs:label "Máquina láser" ;
    ns1:textoExtracto "comando orientado a máquina láser, donde esta subrutina debe realizar las operaciones iniciales del láser." .

ns1:SubrutinaInicializacionLaser a ns1:ModoOperacion ;
    rdfs:label "Subrutina asociada a #INITIALSUB" ;
    ns1:ejecutadoPor ns1:Comando_INITIALSUB ;
    ns1:textoExtracto "subrutina asociada, que el CNC ejecuta junto al comando. Este comando está orientado a máquina láser, donde esta subrutina debe realizar las operaciones iniciales del láser." .

ns1:Comando_INITIALSUB a ns1:InterfazUsuario ;
    rdfs:label "Comando #INITIALSUB" ;
    ns1:identificador "#INITIALSUB" ;
    ns1:textoExtracto "El comando #INITIALSUB tiene una subrutina asociada, que el CNC ejecuta junto al comando." .

