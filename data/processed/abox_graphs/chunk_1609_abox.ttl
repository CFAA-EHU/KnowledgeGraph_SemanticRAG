@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Manual_Seccion_14.1 a ns1:Manual ;
    rdfs:label "Sección 14.1: Ejecutar subrutinas desde la memoria RAM" ;
    ns1:documentadoEn ns1:Pagina_637 ;
    ns1:identificador "14.1" ;
    ns1:textoExtracto "Ver en la '14.1 Ejecutar subrutinas desde la memoria RAM (extensión *.fst).' página 637."@es .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "CNC" ;
    ns1:controla ns1:Parametro_INITIALSUB_CHN ;
    ns1:textoExtracto "Si se actualiza la versión, el CNC actúa de la siguiente manera. [...] el CNC carga esta subrutina en la memoria RAM del CNC."@es ;
    ns1:tieneComponente ns1:Subrutina_Initialsub_fst .

ns1:Pagina_637 a ns1:Pagina ;
    rdfs:label "Página 637" ;
    ns1:identificador "637" ;
    ns1:textoExtracto "Ver en la '14.1 Ejecutar subrutinas desde la memoria RAM (extensión *.fst).' página 637."@es .

ns1:Parametro_INITIALSUB_CHN a ns1:Parametro ;
    rdfs:label "INITIALSUB CHN" ;
    ns1:identificador "INITIALSUB CHN" ;
    ns1:textoExtracto "INITIALSUB CHN | Subrutina asociada al comando #INITIALSUB. [CHN].......Parámetro máquina; general del canal. Nombre y ubicación de la subrutina."@es ;
    ns1:valor "Initialsub.fst" .

ns1:Subrutina_Initialsub_fst a ns1:Componente ;
    rdfs:label "Subrutina Initialsub.fst" ;
    ns1:identificador "Initialsub.fst" ;
    ns1:textoExtracto "Esta subrutina debe estar definida en el parámetro general INITIALSUB (por defecto Initialsub.fst) y estará guardada en la carpeta ..\\Mtb\\Sub. Si hay varios canales, puede haber una subrutina diferente para cada canal. Al ser una subrutina OEM con extensión fst, el CNC carga esta subrutina en la memoria RAM del CNC."@es .

