@prefix ex: <https://vocab.cfaa.eus/broaching/>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.

ex:CentralDeEngrase a owl:Class ;
    rdfs:label "Central de engrase" ;
    rdfs:comment "Central de engrase" .

ex:CentralDeEngraseManual a owl:Class ;
    rdfs:label "Central de engrase manual" ;
    rdfs:comment "Central de engrase manual" .

ex:PassThrough a owl:Class ;
    rdfs:label "Pass-through" ;
    rdfs:comment "Pass-through 1 × RJ45, 8-pole metal, CAT5e MSDD INSTALLATION SOCKET RJ45 BU/BU Pass-through 1 × RJ45, 8-pole" .

ex:Carcasa a owl:Class ;
    rdfs:label "Carcasa" ;
    rdfs:comment "Carcasa (conectores industriales) HDC - cajas, Grupo: 3, Tipo de protección: IP65, Base cerrada" .

ex:ConectorDeContactos a owl:Class ;
    rdfs:label "Conector de contactos" ;
    rdfs:comment "Conector de contactos (conectores HDC - Conector, Macho, 500 V, 24 A, Número de polos: 6, PUSH IN, Grupo: 3" .

ex:Enchufe a owl:Class ;
    rdfs:label "Enchufe" ;
    rdfs:comment "Enchufe" .

ex:MarcoSimpleParaTomasDePupitre a owl:Class ;
    rdfs:label "Marco simple para tomas de pupitre" ;
    rdfs:comment "Marco simple para tomas de pupitre" .

ex:RefrigeradorMural a owl:Class ;
    rdfs:label "Refrigerador mural" ;
    rdfs:comment "Refrigerador mural 1000W" .

ex:BottleCollectingCondensate a owl:Class ;
    rdfs:label "Bottle collecting condensate" ;
    rdfs:comment "Bottle collecting condensate" .

ex:Ilustracion a owl:Class ;
    rdfs:label "Ilustración" ;
    rdfs:comment "Ilustración isométrica de la brochadora carenada con un operario frente al pupitre" .

ex:Operario a owl:Class ;
    rdfs:label "Operario" ;
    rdfs:comment "Operario frente al pupitre" .

ex:Pupitre a owl:Class ;
    rdfs:label "Pupitre" ;
    rdfs:comment "Pupitre de mando" .

ex:Brochadora a owl:Class ;
    rdfs:label "Brochadora" ;
    rdfs:comment "Brochadora carenada" .