@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_Variables_14_14_2 a ns1:Tabla ;
    ns1:textoExtracto "La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W). | Variable. | PRG | PLC | INT | | --- | --- | --- | --- | | (V.)[ch].MPG.INITIALSUB | - | - | R |" ;
    ns1:tieneComponente ns1:Variable_MPG_INITIALSUB .

ns1:Variable_MPG_INITIALSUB a ns1:Parametro ;
    rdfs:label "V.ch.MPG.INITIALSUB" ;
    ns1:identificador "ch" ;
    ns1:textoExtracto "Variable: (V.)[ch].MPG.INITIALSUB. Subrutina asociada al comando #INITIALSUB. Unidades: Texto." ;
    ns1:valor "Texto" .

