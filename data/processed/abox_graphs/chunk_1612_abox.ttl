@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_PIERCING_CHN a ns1:Parametro ;
    rdfs:label "PIERCING CHN" ;
    ns1:identificador "PIERCING CHN" ;
    ns1:monitoreaParametro ns1:Subrutina_Piercing ;
    ns1:textoExtracto "PIERCING CHN | Subrutina asociada al comando #PIERCING. [CHN].......Parámetro máquina; general del canal. Nombre y ubicación de la subrutina." .

ns1:Manual_Seccion14_1 a ns1:Pagina ;
    rdfs:label "14.1 Ejecutar subrutinas desde la memoria RAM" ;
    ns1:identificador "14.1" ;
    ns1:textoExtracto "Ver en la '14.1 Ejecutar subrutinas desde la memoria RAM (extensión *.fst).' página 637." .

ns1:Subrutina_Piercing a ns1:Componente ;
    rdfs:label "Piercing.fst" ;
    ns1:documentadoEn ns1:Manual_Seccion14_1 ;
    ns1:identificador "Piercing.fst" ;
    ns1:textoExtracto "Esta subrutina debe estar definida en el parámetro general PIERCING (por defecto Piercing.fst) y estará guardada en la carpeta ..\\Mtb\\Sub. Si hay varios canales, puede haber una subrutina diferente para cada canal." .

