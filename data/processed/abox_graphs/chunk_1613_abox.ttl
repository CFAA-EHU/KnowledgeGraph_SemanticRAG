@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_Variables_14_15_2 a ns1:Tabla ;
    ns1:textoExtracto "La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W). | Variable. | PRG | PLC | INT | | --- | --- | --- | --- | | (V.)[ch].MPG.PIERCING Subrutina asociada al comando #PIERCING. Unidades: Texto. | - | - | R | Sintaxis. ꞏchꞏ Número de canal. | [2].MPG.PIERCING | Canal ꞏ2ꞏ. |" ;
    ns1:tieneComponente ns1:Variable_MPG_PIERCING .

ns1:Variable_MPG_PIERCING a ns1:Parametro ;
    rdfs:label "V.ch.MPG.PIERCING" ;
    ns1:textoExtracto "Variable. (V.)[ch].MPG.PIERCING Subrutina asociada al comando #PIERCING. Unidades: Texto." ;
    ns1:valor "Texto" .

