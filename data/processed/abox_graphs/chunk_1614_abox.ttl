@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Comando_CUTTING_OFF a ns1:InterfazUsuario ;
    rdfs:label "Comando #CUTTING OFF"@es ;
    ns1:controla ns1:Subrutina_CuttingOff ;
    ns1:identificador "#CUTTING OFF" ;
    ns1:textoExtracto "El comando #CUTTING OFF sólo ejecuta la subrutina que tiene asociada."@es .

ns1:Comando_CUTTING_ON a ns1:InterfazUsuario ;
    rdfs:label "Comando #CUTTING ON"@es ;
    ns1:controla ns1:Subrutina_CuttingOn ;
    ns1:identificador "#CUTTING ON" ;
    ns1:textoExtracto "El comando #CUTTING ON ejecuta la subrutina que tiene asociada después de actualizar las variables del cutting ((V.)TTCUT.name)."@es .

ns1:Sistema_Laser a ns1:Sistema ;
    rdfs:label "Sistema de láser (máquina láser)"@es ;
    ns1:controla ns1:Marca_CUTTING ;
    ns1:textoExtracto "subrutinas suministradas por Fagor ofrecen una gestión básica del láser [...] orientados a máquina láser"@es ;
    ns1:tieneComponente ns1:Subrutina_CuttingOff,
        ns1:Subrutina_CuttingOn .

ns1:Variable_V.PLC.CUTTING a ns1:Parametro ;
    rdfs:label "Variable V.PLC.CUTTING"@es ;
    ns1:identificador "V.PLC.CUTTING" ;
    ns1:monitoreaParametro ns1:Marca_CUTTING ;
    ns1:textoExtracto "Esta marca refleja el estado de la variable V.PLC.CUTTING. [...] Escribir esta variable detiene la preparación de bloques."@es .

ns1:Manual_14_16 a ns1:Pagina ;
    rdfs:label "Sección 14.16: Subrutina asociada al comando #CUTTING ON y #CUTTING OFF"@es ;
    ns1:identificador "14.16" ;
    ns1:textoExtracto "Subrutinas orientadas al modelo láser. Las subrutinas suministradas por Fagor ofrecen una gestión básica del láser [...]"@es .

ns1:Marca_CUTTING a ns1:Parametro ;
    rdfs:label "Marca CUTTING"@es ;
    ns1:identificador "CUTTING" ;
    ns1:textoExtracto "El OEM debe gestionar la marca CUTTING desde estas subrutinas. [...] asignarle valor 1 [...] asignarle valor 0"@es ;
    ns1:valor 0,
        1 .

ns1:Subrutina_CuttingOff a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina CuttingOff.fst"@es ;
    ns1:documentadoEn ns1:Manual_14_16 ;
    ns1:identificador "Cuttingoff.fst" ;
    ns1:textoExtracto "subrutina asociada a #CUTTING OFF (por defecto, Cuttingoff.fst)"@es .

ns1:Subrutina_CuttingOn a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina CuttingOn.fst"@es ;
    ns1:documentadoEn ns1:Manual_14_16 ;
    ns1:identificador "Cuttingon.fst" ;
    ns1:textoExtracto "subrutina asociada a #CUTTING ON (por defecto, Cuttingon.fst)"@es .

