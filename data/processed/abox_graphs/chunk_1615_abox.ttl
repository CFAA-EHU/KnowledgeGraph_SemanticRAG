@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Carpeta_Mtb_Sub a ns1:Sistema ;
    rdfs:label "..\\Mtb\\Sub" ;
    ns1:textoExtracto "Ambas subrutinas deben estar guardadas en la carpeta ..\\Mtb\\Sub." .

ns1:Parametro_Canal a ns1:Parametro ;
    rdfs:label "CHN" ;
    ns1:textoExtracto "[CHN].......Parámetro máquina; general del canal. Nombre y ubicación de la subrutina." ;
    ns1:valor "CHN" .

ns1:Parametro_General_CUTTINGOFF a ns1:Parametro ;
    rdfs:label "CUTTINGOFF" ;
    ns1:textoExtracto "Estas subrutinas deben estar definidas en los parámetros generales CUTTINGOFF (por defecto Cuttingoff.fst)." ;
    ns1:valor "CUTTINGOFF" .

ns1:Parametro_General_CUTTINGON a ns1:Parametro ;
    rdfs:label "CUTTINGON" ;
    ns1:textoExtracto "Estas subrutinas deben estar definidas en los parámetros generales CUTTINGON (por defecto Cuttingon.fst)" ;
    ns1:valor "CUTTINGON" .

ns1:Parametro_General_Canal a ns1:Parametro ;
    rdfs:label "parámetro máquina; general del canal" ;
    ns1:textoExtracto "[CHN].......Parámetro máquina; general del canal. Nombre y ubicación de la subrutina." .

ns1:Sistema_CNC a ns1:Maquina ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "Si se actualiza la versión, el CNC actúa de la siguiente manera. ... el CNC carga esta subrutina en la memoria RAM del CNC." .

ns1:Subrutina_CUTTINGOFF_CHN a ns1:Parametro ;
    rdfs:label "CUTTINGOFF CHN" ;
    ns1:textoExtracto "Subrutina asociada al comando #CUTTING OFF." ;
    ns1:valor "CUTTINGOFF CHN" .

ns1:Subrutina_CUTTINGON_CHN a ns1:Parametro ;
    rdfs:label "CUTTINGON CHN" ;
    ns1:textoExtracto "Subrutina asociada al comando #CUTTING ON." ;
    ns1:valor "CUTTINGON CHN" .

ns1:Subrutina_Default_Cuttingoff_fst a ns1:TareaMantenimiento ;
    rdfs:label "Cuttingoff.fst" ;
    ns1:textoExtracto "Subrutina asociada al comando #CUTTING OFF. ... Ambas subrutinas deben estar guardadas en la carpeta ..\\Mtb\\Sub. ... el CNC carga esta subrutina en la memoria RAM del CNC." .

ns1:Subrutina_Default_Cuttingon_fst a ns1:TareaMantenimiento ;
    rdfs:label "Cuttingon.fst" ;
    ns1:textoExtracto "Subrutina asociada al comando #CUTTING ON. ... Ambas subrutinas deben estar guardadas en la carpeta ..\\Mtb\\Sub. ... el CNC carga esta subrutina en la memoria RAM del CNC." .

ns1:Subrutina_OEM_fst a ns1:TareaMantenimiento ;
    rdfs:label "subrutina OEM con extensión fst" ;
    ns1:textoExtracto "Al ser una subrutina OEM con extensión fst, el CNC carga esta subrutina en la memoria RAM del CNC." .

