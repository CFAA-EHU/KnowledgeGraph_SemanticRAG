@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:TablaVariablesAcceso a ns1:Tabla ;
    ns1:textoExtracto "Las siguientes variables son accesibles desde; (PRG) el programa pieza y desde el modo MDI/MDA, PLC e (INT) una aplicación externa. La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W)...." ;
    ns1:tieneComponente ns1:VariableMPGCUTTINGOFF,
        ns1:VariableMPGCUTTINGOFF_Canal2,
        ns1:VariableMPGCUTTINGON,
        ns1:VariableMPGCUTTINGON_Canal2 .

ns1:VariableMPGCUTTINGOFF a ns1:Parametro ;
    ns1:textoExtracto """(V.)[ch].MPG.CUTTINGON
Subrutina asociada al comando #CUTTINGOFF. Unidades: Texto.""" ;
    ns1:valor "R" .

ns1:VariableMPGCUTTINGOFF_Canal2 a ns1:Parametro ;
    ns1:textoExtracto "[2].MPG.CUTTINGOFF | Canal ꞏ2ꞏ." ;
    ns1:valor "2" .

ns1:VariableMPGCUTTINGON a ns1:Parametro ;
    ns1:textoExtracto """(V.)[ch].MPG.CUTTINGON
Subrutina asociada al comando #CUTTING ON. Unidades: Texto.""" ;
    ns1:valor "R" .

ns1:VariableMPGCUTTINGON_Canal2 a ns1:Parametro ;
    ns1:textoExtracto "[2].MPG.CUTTINGON | Canal ꞏ2ꞏ." ;
    ns1:valor "2" .

