@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:subrutina_FINALSUB a ns1:ModoOperacion ;
    rdfs:label "Subrutina asociada al comando #FINALSUB"@es ;
    ns1:ejecutadoPor ns1:maquina_laser ;
    ns1:identificador "#FINALSUB" ;
    ns1:textoExtracto "El comando #FINALSUB tiene una subrutina asociada, que el CNC ejecuta junto al comando. Este comando esta orientado a máquina láser, donde esta subrutina debe realizar las operaciones finales del láser."@es .

ns1:maquina_laser a ns1:Maquina ;
    rdfs:label "Máquina láser"@es ;
    ns1:textoExtracto "Subrutina orientada al modelo láser. [...] Este comando esta orientado a máquina láser, donde esta subrutina debe realizar las operaciones finales del láser."@es .

