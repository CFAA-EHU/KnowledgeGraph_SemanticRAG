@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_FINALSUB_CHN a ns1:Parametro ;
    rdfs:label "FINALSUB CHN" ;
    ns1:identificador "FINALSUB CHN" ;
    ns1:monitoreaParametro ns1:Subrutina_Finalsub_fst ;
    ns1:textoExtracto "FINALSUB CHN | Subrutina asociada al comando #FINALSUB. [CHN].......Parámetro máquina; general del canal. Nombre y ubicación de la subrutina." .

ns1:Pagina_637 a ns1:Pagina ;
    rdfs:label "14.1 Ejecutar subrutinas desde la memoria RAM" ;
    ns1:identificador "637" ;
    ns1:textoExtracto "Ver en la '14.1 Ejecutar subrutinas desde la memoria RAM (extensión *.fst).' página 637." .

ns1:Subrutina_Finalsub_fst a ns1:Componente ;
    rdfs:label "Finalsub.fst" ;
    ns1:documentadoEn ns1:Pagina_637 ;
    ns1:identificador "Finalsub.fst" ;
    ns1:textoExtracto "Esta subrutina debe estar definida en el parámetro general FINALSUB (por defecto Finalsub.fst) y estará guardada en la carpeta ..\\Mtb\\Sub. Al ser una subrutina OEM con extensión fst, el CNC carga esta subrutina en la memoria RAM del CNC." .

