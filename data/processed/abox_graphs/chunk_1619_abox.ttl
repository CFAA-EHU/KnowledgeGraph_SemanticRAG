@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_Variables_14_17_2 a ns1:Tabla ;
    ns1:textoExtracto "La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W). | Variable. | PRG | PLC | INT | | --- | --- | --- | --- | | (V.)[ch].MPG.FINALSUB Subrutina asociada al comando #FINALSUB. Unidades: Texto. | - | - | R | Sintaxis. ꞏchꞏ Número de canal. | [2].MPG.FINALSUB | Canal ꞏ2ꞏ." ;
    ns1:tieneComponente ns1:Variable_MPG_FINALSUB .

ns1:Variable_MPG_FINALSUB a ns1:Parametro ;
    rdfs:label "V.ch.MPG.FINALSUB" ;
    ns1:identificador "FINALSUB" ;
    ns1:textoExtracto "Variable (V.)[ch].MPG.FINALSUB. Subrutina asociada al comando #FINALSUB. Unidades: Texto." ;
    ns1:valor "Texto" .

