ex:tieneCumplimientoManual a owl:ObjectProperty ;
    rdfs:domain ex:RecuadroSTOP ;
    rdfs:range ex:CumplimientoManual .

ex:tieneCierreArmariosElectricos a owl:ObjectProperty ;
    rdfs:domain ex:RecuadroSTOP ;
