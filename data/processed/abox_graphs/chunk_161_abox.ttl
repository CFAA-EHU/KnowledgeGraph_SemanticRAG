    rdfs:range ex:Marcador .

ex:tieneInterruptorGeneral a owl:ObjectProperty ;
    rdfs:domain ex:Lamina ;
    rdfs:range ex:InterruptorGeneral .

ex:tieneParadaEmergencia a owl:ObjectProperty ;
