@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Puerta a owl:Class ;
    rdfs:label "Puerta" ;
    rdfs:comment "Puerta con ventanas, columna alta y zócalo con apoyos antivibratorios." .

ex:Ventana a owl:Class ;
    rdfs:label "Ventana" ;
    rdfs:comment "Ventana en la puerta." .

ex:ColumnaAlta a owl:Class ;
    rdfs:label "ColumnaAlta" ;
    rdfs:comment "Columna alta en la puerta." .

ex:ZocaloConApoyosAntivibratorios a owl:Class ;
    rdfs:label "ZocaloConApoyosAntivibratorios" ;
    rdfs:comment "Zócalo con apoyos antivibratorios en la puerta." .

ex:PaletaBlancoGris a owl:Class ;
    rdfs:label "PaletaBlancoGris" ;
    rdfs:comment "Paleta en blanco/gris con acentos azules corporativos." .

ex:FuncionIntroductoria a owl:Class ;
    rdfs:label "FuncionIntroductoria" ;
    rdfs:comment "Función claramente introductoria del equipo." .

ex:Diagrama a owl:Class ;
    rdfs:label "Diagrama" ;
    rdfs:comment "Diagrama con flechas y rótulos que identifican metadatos del documento." .

ex:Flecha a owl:Class ;
    rdfs:label "Flecha" ;
    rdfs:comment "Flecha en el diagrama." .

ex:Rotulo a owl:Class ;
    rdfs:label "Rotulo" ;
    rdfs:comment "Rótulo en el diagrama." .

ex:Cabecera a owl:Class ;
    rdfs:label "Cabecera" ;
    rdfs:comment "Cabecera del diagrama." .

ex:Pie a owl:Class ;
    rdfs:label "Pie" ;
    rdfs:comment "Pie del diagrama." .

ex:Fabricante a owl:Class ;
    rdfs:label "Fabricante" ;
    rdfs:comment "Fabricante en la cabecera del diagrama." .

ex:Numero a owl:Class ;
    rdfs:label "Numero" ;
    rdfs:comment "Número en la cabecera del diagrama." .

ex:NombreCapitulo a owl:Class ;
    rdfs:label "NombreCapitulo" ;
    rdfs:comment "Nombre de capítulo en la cabecera del diagrama." .

ex:ModeloMaquina a owl:Class ;
    rdfs:label "ModeloMaquina" ;
    rdfs:comment "Modelo de máquina en la cabecera del diagrama." .

ex:NombreFichero a owl:Class ;
    rdfs:label "NombreFichero" ;
    rdfs:comment "Nombre de fichero en la cabecera del diagrama." .

ex:Contenido a owl:Class ;
    rdfs:label "Contenido" ;
    rdfs:comment "Contenido en la cabecera del diagrama." .

ex:Paginacion a owl:Class ;
    rdfs:label "Paginacion" ;
    rdfs:comment "Paginación en el pie del diagrama." .

ex:JerarquiaVisualMetadatos a owl:Class ;
    rdfs:label "JerarquiaVisualMetadatos" ;
    rdfs:comment "Jerarquía visual de metadatos del documento." .

ex:PanelInfografico a owl:Class ;
    rdfs:label "PanelInfografico" ;
    rdfs:comment "Paneles infográficos con pictograma 'STOP' y avisos de seguridad." .

ex:PictogramaSTOP a owl:Class ;
    rdfs:label "PictogramaSTOP" ;
    rdfs:comment "Pictograma 'STOP' en los paneles infográficos." .

ex:AvisoSeguridad a owl:Class ;
    rdfs:label "AvisoSeguridad" ;
    rdfs:comment "Avisos de seguridad en los paneles infográficos." .

ex:Placa a owl:Class ;
    rdfs:label "Placa" ;
    rdfs:comment "Placas de seguridad en los paneles infográficos." .

ex:Enclavamiento a owl:Class ;
    rdfs:label "Enclavamiento" ;
    rdfs:comment "Enclavamientos de seguridad en los paneles infográficos." .

ex:ManipulacionSegura a owl:Class ;
    rdfs:label "ManipulacionSegura" ;
    rdfs:comment "Manipulación segura en los paneles infográficos." .

ex:UsoMediosElevacion a owl:Class ;
    rdfs:label "UsoMediosElevacion" ;
    rdfs:comment "Uso de medios de elevación en los paneles infográficos." .

ex:DiseñoBloquesRojos a owl:Class ;
    rdfs:label "DiseñoBloquesRojos" ;
    rdfs:comment "Diseño en bloques rojos con texto blanco para resaltar severidad." .

ex:TextoBlanco a owl:Class ;
    rdfs:label "TextoBlanco" ;
    rdfs:comment "Texto blanco en los bloques rojos." .

ex:RecuadroSTOP a owl:Class ;
    rdfs:label "RecuadroSTOP" ;
    rdfs:comment "Conjunto de recuadros 'STOP' que enfatizan aplicación prevista, cumplimiento del manual, cierre de armarios eléctricos, no sobrepasar capacidad y verificación de interior." .

ex:AplicacionPrevista a owl:Class ;
    rdfs:label "AplicacionPrevista" ;
    rdfs:comment "Aplicación prevista en los recuadros 'STOP'." .

ex:CumplimientoManual a owl:Class ;
    rdfs:label "CumplimientoManual" ;
    rdfs:comment "Cumplimiento del manual en los recuadros 'STOP'." .

ex:CierreArmariosElectricos a owl:Class ;
    rdfs:label "CierreArmariosElectricos" ;
    rdfs:comment "Cierre de armarios eléctricos en los recuadros 'STOP'." .

ex:NoSobrepasarCapacidad a owl:Class ;
    rdfs:label "NoSobrepasarCapacidad" ;
    rdfs:comment "No sobrepasar capacidad en los recuadros 'STOP'." .

ex:VerificacionInterior a owl:Class ;
    rdfs:label "VerificacionInterior" ;
    rdfs:comment "Verificación de interior en los recuadros 'STOP'." .

ex:Iconografia a owl:Class ;
    rdfs:label "Iconografia" ;
    rdfs:comment "Iconografía en los recuadros 'STOP'." .

ex:Color a owl:Class ;
    rdfs:label "Color" ;
    rdfs:comment "Color en los recuadros 'STOP'." .

ex:Lamina a owl:Class ;
    rdfs:label "Lamina" ;
    rdfs:comment "Lámina con varias vistas de la máquina." .

ex:VistaMaquina a owl:Class ;
    rdfs:label "VistaMaquina" ;
    rdfs:comment "Vistas de la máquina en la lámina." .

ex:Marcador a owl:Class ;
    rdfs:label "Marcador" ;
    rdfs:comment "Marcadores en la lámina." .

ex:InterruptorGeneral a owl:Class ;
    rdfs:label "InterruptorGeneral" ;
    rdfs:comment "Interruptor general en la lámina." .

ex:ParadaEmergencia a owl:Class ;
    rdfs:label "ParadaEmergencia" ;
    rdfs:comment "Paradas de emergencia en la lámina." .

ex:PanelFijo a owl:Class ;
    rdfs:label "PanelFijo" ;
    rdfs:comment "Paneles fijos en la lámina." .

ex:PanelDesmontable a owl:Class ;
    rdfs:label "PanelDesmontable" ;
    rdfs:comment "Paneles desmontables en la lámina." .

ex:Puerta a owl:Class ;
    rdfs:label "Puerta" ;
    rdfs:comment "Puertas en la lámina." .

ex:ZonaSegura a owl:Class ;
    rdfs:label "ZonaSegura" ;
    rdfs:comment "Zonas seguras en la lámina." .

ex:tieneVentana a owl:ObjectProperty ;
    rdfs:domain ex:Puerta ;
    rdfs:range ex:Ventana .

ex:tieneColumnaAlta a owl:ObjectProperty ;
    rdfs:domain ex:Puerta ;
    rdfs:range ex:ColumnaAlta .

ex:tieneZocaloConApoyosAntivibratorios a owl:ObjectProperty ;
    rdfs:domain ex:Puerta ;
    rdfs:range ex:ZocaloConApoyosAntivibratorios .

ex:tienePaletaBlancoGris a owl:ObjectProperty ;
    rdfs:domain ex:Puerta ;
