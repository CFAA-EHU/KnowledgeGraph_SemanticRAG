@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Figura_0_1_1 a ns1:Figura ;
    ns1:compuestoPor ns1:Contenido,
        ns1:Fabricante,
        ns1:ModeloMaquina,
        ns1:NombreCapitulo,
        ns1:NombreFichero,
        ns1:NumeroCapitulo,
        ns1:Paginacion ;
    ns1:textoExtracto "Diagrama con flechas y rótulos que identifican, en cabecera y pie, fabricante, número y nombre de capítulo, modelo de máquina, nombre de fichero, contenido y paginación; establece la jerarquía visual de metadatos del documento." .

ns1:Figura_2_1 a ns1:Figura ;
    ns1:compuestoPor ns1:InterruptorGeneral,
        ns1:PanelDesmontable,
        ns1:PanelFijo,
        ns1:ParadaEmergencia,
        ns1:Puerta ;
    ns1:textoExtracto "Lámina con varias vistas de la máquina; marcadores y colores señalan la ubicación de interruptor general, paradas de emergencia, paneles fijos/desmontables y puertas, ofreciendo un mapa visual de zonas seguras." .

ns1:Figura_2_2 a ns1:Figura ;
    ns1:compuestoPor ns1:AvisoSeguridad_STOP ;
    ns1:textoExtracto "Paneles infográficos con pictograma 'STOP' y avisos de seguridad (placas, enclavamientos, manipulación segura, uso de medios de elevación)." .

ns1:AvisoSeguridad_STOP a ns1:AvisoSeguridad ;
    ns1:textoExtracto "Paneles infográficos con pictograma 'STOP' y avisos de seguridad" .

ns1:InterruptorGeneral a ns1:ComponenteElectrico ;
    ns1:textoExtracto "marcadores y colores señalan la ubicación de interruptor general" .

ns1:PanelDesmontable a ns1:Componente ;
    ns1:textoExtracto "marcadores y colores señalan la ubicación de ... paneles desmontables" .

ns1:PanelFijo a ns1:Componente ;
    ns1:textoExtracto "marcadores y colores señalan la ubicación de ... paneles fijos" .

ns1:ParadaEmergencia a ns1:ElementoSeguridad ;
    ns1:textoExtracto "marcadores y colores señalan la ubicación de ... paradas de emergencia" .

ns1:Puerta a ns1:Componente ;
    ns1:textoExtracto "marcadores y colores señalan la ubicación de ... puertas" .

