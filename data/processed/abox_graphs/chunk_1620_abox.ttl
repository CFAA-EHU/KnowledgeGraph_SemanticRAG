@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Subrutina_G500 a ns1:ModoOperacion ;
    rdfs:label "Subrutina G500" ;
    ns1:identificador "G500" ;
    ns1:textoExtracto "G500 | Anulación de HSC." .

ns1:Subrutina_G501 a ns1:ModoOperacion ;
    rdfs:label "Subrutina G501" ;
    ns1:identificador "G501" ;
    ns1:textoExtracto "G501 | Activación de HSC para operaciones de desbaste." .

ns1:Tabla_SubrutinasG500_G599 a ns1:Tabla ;
    rdfs:label "Tabla de subrutinas de usuario G500-G599" ;
    ns1:documentadoEn ns1:Manual_CNC ;
    ns1:textoExtracto "Subrutinas suministradas por Fagor. | Subrutina. | Significado. | --- | --- | G500 | Anulación de HSC. | G501 | Activación de HSC para operaciones de desbaste." .

ns1:Manual_CNC a ns1:Manual ;
    rdfs:label "Manual del CNC" ;
    ns1:textoExtracto "El CNC permite al usuario definir hasta 100 subrutinas, comunes a todos los canales, y que estarán asociadas a las funciones G500 a G599..." .

