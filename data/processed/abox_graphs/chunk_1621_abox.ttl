@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaGestionSubrutinas_CNC a ns1:Sistema ;
    rdfs:label "Sistema de gestión de subrutinas del CNC" ;
    ns1:documentadoEn ns1:Carpeta_MtbSub,
        ns1:Carpeta_UsersSub ;
    ns1:textoExtracto "Si se actualiza la versión, el CNC actúa de la siguiente manera. [...] el CNC siempre actualiza las subrutinas." ;
    ns1:tieneComponente ns1:Subrutina_G500,
        ns1:Subrutina_G501,
        ns1:Subrutina_G599 .

ns1:Carpeta_MtbSub a ns1:InterfazUsuario ;
    rdfs:label "Carpeta ..\\Mtb\\Sub" ;
    ns1:textoExtracto "el CNC sólo copia las subrutinas a la carpeta ..\\Mtb\\Sub si no existen." .

ns1:Carpeta_UsersSub a ns1:InterfazUsuario ;
    rdfs:label "Carpeta ..\\Users\\Sub" ;
    ns1:textoExtracto "La subrutina [...] estarán guardadas en la carpeta ..\\Users\\Sub." .

ns1:Subrutina_G500 a ns1:Componente ;
    rdfs:label "Subrutina G500" ;
    ns1:identificador "G500" ;
    ns1:textoExtracto "G500 tendrá asociada la subrutina G500." .

ns1:Subrutina_G501 a ns1:Componente ;
    rdfs:label "Subrutina G501" ;
    ns1:identificador "G501" ;
    ns1:textoExtracto "G501 tendrá asociada la subrutina G501." .

ns1:Subrutina_G599 a ns1:Componente ;
    rdfs:label "Subrutina G599" ;
    ns1:identificador "G599" ;
    ns1:textoExtracto "G599 tendrá asociada la subrutina G599." .

