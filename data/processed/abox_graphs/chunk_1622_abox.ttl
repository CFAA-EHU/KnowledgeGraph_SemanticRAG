@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC a ns1:Sistema ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "El CNC permite al usuario definir hasta 1000 subrutinas" .

ns1:FuncionG8000 a ns1:Parametro ;
    rdfs:label "Función G8000" ;
    ns1:identificador "G8000" ;
    ns1:textoExtracto "asociadas a las funciones G8000 a G8999" .

ns1:FuncionG8999 a ns1:Parametro ;
    rdfs:label "Función G8999" ;
    ns1:identificador "G8999" ;
    ns1:textoExtracto "asociadas a las funciones G8000 a G8999" .

ns1:MacroProGTL3 a ns1:TareaMantenimiento ;
    rdfs:label "Macro del lenguaje ProGTL3" ;
    ns1:textoExtracto "Algunas de estas subrutinas tienen un funcionamiento preasignado por Fagor como macros del lenguaje ProGTL3" .

ns1:MemoriaRAM a ns1:Componente ;
    rdfs:label "Memoria RAM" ;
    ns1:textoExtracto "Estas subrutinas se cargan en la memoria RAM la primera vez que se ejecutan" .

ns1:ModoModal a ns1:ModoOperacion ;
    rdfs:label "Modo modal" ;
    ns1:textoExtracto "Estas subrutinas se podrán ejecutar de forma no-modal o de forma modal" .

ns1:ModoNoModal a ns1:ModoOperacion ;
    rdfs:label "Modo no-modal" ;
    ns1:textoExtracto "Estas subrutinas se podrán ejecutar de forma no-modal o de forma modal" .

ns1:ProgramaM30 a ns1:AccionProhibida ;
    rdfs:label "Programa M30" ;
    ns1:identificador "M30" ;
    ns1:textoExtracto "Cuando finaliza el programa (M30)" .

ns1:SubrutinaUsuario1 a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina de usuario" ;
    ns1:textoExtracto "El CNC permite al usuario definir hasta 1000 subrutinas, comunes a todos los canales, y que estarán asociadas a las funciones G8000 a G8999" .

