@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Carpeta_UsersSub a ns1:InterfazUsuario ;
    rdfs:label "Carpeta ..\\Users\\Sub" ;
    ns1:identificador "..\\Users\\Sub" ;
    ns1:textoExtracto "estarán guardadas en la carpeta ..\\Users\\Sub" .

ns1:RangoSubrutinas_G8000_G8999 a ns1:Sistema ;
    rdfs:label "Rango de subrutinas G8000-G8999" ;
    ns1:textoExtracto "La subrutina asociadas a las funciones G8000 a G8999 tendrán el mismo nombre que la función (sin extensión) y estarán guardadas en la carpeta ..\\Users\\Sub." ;
    ns1:tieneComponente ns1:Subrutina_G8000,
        ns1:Subrutina_G8001,
        ns1:Subrutina_G8999 .

ns1:Subrutina_G8000 a ns1:Componente ;
    rdfs:label "Subrutina G8000" ;
    ns1:identificador "G8000" ;
    ns1:textoExtracto "G8000 tendrá asociada la subrutina G8000." .

ns1:Subrutina_G8001 a ns1:Componente ;
    rdfs:label "Subrutina G8001" ;
    ns1:identificador "G8001" ;
    ns1:textoExtracto "G8001 tendrá asociada la subrutina G8001." .

ns1:Subrutina_G8999 a ns1:Componente ;
    rdfs:label "Subrutina G8999" ;
    ns1:identificador "G8999" ;
    ns1:textoExtracto "G8999 tendrá asociada la subrutina G8999." .

