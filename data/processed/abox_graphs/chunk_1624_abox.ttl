@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SubrutinaGlobal_MCALL a ns1:Componente ;
    rdfs:label "Subrutina global llamada mediante #MCALL" ;
    ns1:documentadoEn ns1:FicheroAyudaTextoSubrutina ;
    ns1:identificador "#MCALL" ;
    ns1:ilustradoEn ns1:FicheroAyudaDibujoSubrutina ;
    ns1:textoExtracto "subrutina global llamada mediante #MCALL ó #PCALL se les puede asociar ficheros de ayuda que se mostrarán durante la edición." .

ns1:SubrutinaGlobal_PCALL a ns1:Componente ;
    rdfs:label "Subrutina global llamada mediante #PCALL" ;
    ns1:documentadoEn ns1:FicheroAyudaTextoSubrutina ;
    ns1:identificador "#PCALL" ;
    ns1:ilustradoEn ns1:FicheroAyudaDibujoSubrutina ;
    ns1:textoExtracto "subrutina global llamada mediante #MCALL ó #PCALL se les puede asociar ficheros de ayuda que se mostrarán durante la edición." .

ns1:SubrutinaOEM_G180 a ns1:Componente ;
    rdfs:label "Subrutina OEM G180" ;
    ns1:documentadoEn ns1:FicheroAyudaTextoSubrutina ;
    ns1:identificador "G180" ;
    ns1:ilustradoEn ns1:FicheroAyudaDibujoSubrutina ;
    ns1:textoExtracto "A cada subrutina OEM (G180, G380, etc) [...] se les puede asociar ficheros de ayuda que se mostrarán durante la edición." .

ns1:SubrutinaOEM_G380 a ns1:Componente ;
    rdfs:label "Subrutina OEM G380" ;
    ns1:documentadoEn ns1:FicheroAyudaTextoSubrutina ;
    ns1:identificador "G380" ;
    ns1:ilustradoEn ns1:FicheroAyudaDibujoSubrutina ;
    ns1:textoExtracto "A cada subrutina OEM (G180, G380, etc) [...] se les puede asociar ficheros de ayuda que se mostrarán durante la edición." .

ns1:SubrutinaUsuario_G500 a ns1:Componente ;
    rdfs:label "Subrutina de usuario G500" ;
    ns1:documentadoEn ns1:FicheroAyudaTextoSubrutina ;
    ns1:identificador "G500" ;
    ns1:ilustradoEn ns1:FicheroAyudaDibujoSubrutina ;
    ns1:textoExtracto "subrutina de usuario (G500, G800, etc) [...] se les puede asociar ficheros de ayuda que se mostrarán durante la edición." .

ns1:SubrutinaUsuario_G800 a ns1:Componente ;
    rdfs:label "Subrutina de usuario G800" ;
    ns1:documentadoEn ns1:FicheroAyudaTextoSubrutina ;
    ns1:identificador "G800" ;
    ns1:ilustradoEn ns1:FicheroAyudaDibujoSubrutina ;
    ns1:textoExtracto "subrutina de usuario (G500, G800, etc) [...] se les puede asociar ficheros de ayuda que se mostrarán durante la edición." .

ns1:Tecla_ESC a ns1:InterfazUsuario ;
    rdfs:label "Tecla [ESC]" ;
    ns1:textoExtracto "La ventana de ayuda desaparece con [ESC], borrando la palabra clave o pasando a otra línea del programa." .

ns1:Tecla_INS a ns1:InterfazUsuario ;
    rdfs:label "Tecla [INS]" ;
    ns1:textoExtracto "el texto del mismo se puede insertar en el programa pieza mediante la tecla [INS]." .

ns1:VentanaAyudaSubrutinas a ns1:InterfazUsuario ;
    rdfs:label "Ventana de ayuda de subrutinas" ;
    ns1:textoExtracto "La ventana de ayuda se hace visible durante la edición, tras el espacio en blanco o tabulador posterior a la función G o al nombre de la subrutina. La ventana de ayuda es solamente informativa, no se puede acceder a ella con el cursor ni navegar por ella." .

ns1:FicheroAyudaDibujoSubrutina a ns1:Componente ;
    rdfs:label "Fichero de ayuda de dibujo (bmp) para subrutinas" ;
    ns1:ilustradoEn ns1:VentanaAyudaSubrutinas ;
    ns1:textoExtracto "Cada subrutina puede disponer de dos ficheros de ayuda; uno de texto (txt) y otro de dibujo (bmp)." .

ns1:FicheroAyudaTextoSubrutina a ns1:Componente ;
    rdfs:label "Fichero de ayuda de texto (txt) para subrutinas" ;
    ns1:ilustradoEn ns1:VentanaAyudaSubrutinas ;
    ns1:textoExtracto "Cada subrutina puede disponer de dos ficheros de ayuda; uno de texto (txt) y otro de dibujo (bmp)." .

