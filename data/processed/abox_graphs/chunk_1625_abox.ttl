@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CarpetaAyudaFabricante a ns1:Sistema ;
    rdfs:label "Directorio de ayuda del fabricante" ;
    ns1:identificador "..\\Mtb\\Sub\\Help" ;
    ns1:textoExtracto "El fabricante de la máquina podrá guardar los ficheros de ayuda en las carpetas ..\\Mtb\\Sub\\Help y ..\\Mtb\\Sub\\Help\\{idioma}" .

ns1:CarpetaAyudaUsuario a ns1:Sistema ;
    rdfs:label "Directorio de ayuda de usuario" ;
    ns1:documentadoEn ns1:G180_ArchivoAyuda ;
    ns1:identificador "..\\Users\\Sub\\Help" ;
    ns1:textoExtracto "El usuario deberá guardar sus ficheros de ayuda en las carpetas ..\\Users\\Sub\\Help y ..\\Users\\Sub\\Help\\{idioma}" .

ns1:Parametro_G180_P1 a ns1:Parametro ;
    rdfs:label "Movimiento en X (P1)" ;
    ns1:identificador "P1" ;
    ns1:monitoreaParametro ns1:G180_Subrutina ;
    ns1:textoExtracto "P1 = Movimiento en X" .

ns1:Parametro_G180_P2 a ns1:Parametro ;
    rdfs:label "Movimiento en Y (P2)" ;
    ns1:identificador "P2" ;
    ns1:monitoreaParametro ns1:G180_Subrutina ;
    ns1:textoExtracto "P2 = Movimiento en Y" .

ns1:Parametro_G180_P3 a ns1:Parametro ;
    rdfs:label "Movimiento en Z (P3)" ;
    ns1:identificador "P3" ;
    ns1:monitoreaParametro ns1:G180_Subrutina ;
    ns1:textoExtracto "P3 = Movimiento en Z" .

ns1:Parametro_G180_P4 a ns1:Parametro ;
    rdfs:label "Avance F (P4)" ;
    ns1:identificador "P4" ;
    ns1:monitoreaParametro ns1:G180_Subrutina ;
    ns1:textoExtracto "P4 = Avance F" .

ns1:Parametro_G180_P5 a ns1:Parametro ;
    rdfs:label "Velocidad S (P5)" ;
    ns1:identificador "P5" ;
    ns1:monitoreaParametro ns1:G180_Subrutina ;
    ns1:textoExtracto "P5 = Velocidad S" .

ns1:G180_EsquemaParametros a ns1:Tabla ;
    ns1:textoExtracto "#COMMENT BEGIN [...] P1 = Movimiento en X, P2 = Movimiento en Y, P3 = Movimiento en Z, P4 = Avance F, P5 = Velocidad S [...] #COMMENT END" .

ns1:G180_ArchivoAyuda a ns1:InterfazUsuario ;
    rdfs:label "G180.txt" ;
    ns1:identificador "G180.txt" ;
    ns1:ilustradoEn ns1:G180_EsquemaParametros ;
    ns1:textoExtracto "Nombre de los ficheros de ayuda [...] El nombre de los ficheros será la función a la que está asociada. Por ejemplo G180.txt y G180.bmp" .

ns1:G180_Subrutina a ns1:ModoOperacion ;
    rdfs:label "G180" ;
    ns1:documentadoEn ns1:G180_ArchivoAyuda ;
    ns1:identificador "G180" ;
    ns1:textoExtracto "G180 P0= P1= P2= P3= P4= P5= [...] P1 = Movimiento en X, P2 = Movimiento en Y, P3 = Movimiento en Z, P4 = Avance F, P5 = Velocidad S" .

