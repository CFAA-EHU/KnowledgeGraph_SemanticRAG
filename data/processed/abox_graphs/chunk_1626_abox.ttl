@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_AyudaSubrutinas_1365 a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de ayuda a subrutinas (ruta de archivos)"@es ;
    ns1:compuestoPor ns1:SistemaAyudaSubrutinas_1365 ;
    ns1:textoExtracto "\\Users\\Session\\Help\\{idioma} ..\\Mtb\\Sub\\Help\\{idioma}. .. \\Users\\Help\\{idioma}."@es .

ns1:SistemaAyudaSubrutinas_1365 a ns1:Sistema ;
    rdfs:label "Sistema de ayuda a subrutinas (versiones CNC)"@es ;
    ns1:identificador "V1.60 (8060), V5.60 (8065)" ;
    ns1:textoExtracto "En versiones anteriores a la V1.60 (8060) y V5.60 (8065), el CNC primero buscaba los archivos de ayuda a las carpetas de fabricante y a continuación en las carpetas de usuario. A partir de estas versiones, el criterio es el contrario."@es .

