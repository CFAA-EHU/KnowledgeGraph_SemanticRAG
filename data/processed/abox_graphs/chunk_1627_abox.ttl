@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Carpeta_MTB_Sub_Help a ns1:Componente ;
    rdfs:label "Carpeta ..\\Mtb\\Sub\\Help (almacenamiento predeterminado)"@es ;
    ns1:identificador "..\\Mtb\\Sub\\Help" ;
    ns1:textoExtracto "El fabricante de la máquina guardará el archivo en la carpeta ..\\Mtb\\Sub\\Help."@es .

ns1:Carpeta_Users_Sub_Help a ns1:Componente ;
    rdfs:label "Carpeta ..\\Users\\Sub\\Help (almacenamiento de usuario)"@es ;
    ns1:identificador "..\\Users\\Sub\\Help" ;
    ns1:textoExtracto "el usuario deberá guardar su archivo pcall.txt ..\\Users\\Sub\\Help."@es .

ns1:Sentencia_MCALL a ns1:Componente ;
    rdfs:label "Sentencia #MCALL (llamada a subrutina)"@es ;
    ns1:documentadoEn ns1:InterfazEditorCNC8070 ;
    ns1:identificador "#MCALL" ;
    ns1:textoExtracto "El editor muestra la lista de subrutinas durante la edición, tras el espacio en blanco o tabulador posterior las sentencias #PCALL o #MCALL."@es .

ns1:Sentencia_PCALL a ns1:Componente ;
    rdfs:label "Sentencia #PCALL (llamada a subrutina)"@es ;
    ns1:documentadoEn ns1:InterfazEditorCNC8070 ;
    ns1:identificador "#PCALL" ;
    ns1:textoExtracto "El editor muestra la lista de subrutinas durante la edición, tras el espacio en blanco o tabulador posterior las sentencias #PCALL o #MCALL."@es .

ns1:Subrutina_EXAMPLE_NC a ns1:Componente ;
    rdfs:label "Subrutina EXAMPLE.NC"@es ;
    ns1:identificador "EXAMPLE.NC" ;
    ns1:ilustradoEn ns1:ArchivoSubrutinas_PCALL_TXT ;
    ns1:textoExtracto "| Ejemplo de un fichero con una lista de subrutinas. | --- | EXAMPLE.NC |"@es .

ns1:Subrutina_FAGOR_NC a ns1:Componente ;
    rdfs:label "Subrutina FAGOR.NC"@es ;
    ns1:identificador "FAGOR.NC" ;
    ns1:ilustradoEn ns1:ArchivoSubrutinas_PCALL_TXT ;
    ns1:textoExtracto "| Ejemplo de un fichero con una lista de subrutinas. | --- | C:\\CNC8070\\USERS\\SUB\\FAGOR.NC |"@es .

ns1:Subrutina_POSITIONING_NC a ns1:Componente ;
    rdfs:label "Subrutina POSITIONING.NC"@es ;
    ns1:identificador "POSITIONING.NC" ;
    ns1:ilustradoEn ns1:ArchivoSubrutinas_PCALL_TXT ;
    ns1:textoExtracto "| Ejemplo de un fichero con una lista de subrutinas. | --- | POSITIONING.NC |"@es .

ns1:Subrutina_SUBROUTINE_NC a ns1:Componente ;
    rdfs:label "Subrutina SUBROUTINE.NC"@es ;
    ns1:identificador "SUBROUTINE.NC" ;
    ns1:ilustradoEn ns1:ArchivoSubrutinas_PCALL_TXT ;
    ns1:textoExtracto "| Ejemplo de un fichero con una lista de subrutinas. | --- | SUBROUTINE.NC |"@es .

ns1:InterfazEditorCNC8070 a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de edición de programas CNC 8070"@es ;
    ns1:identificador "CNC8070_Editor" ;
    ns1:textoExtracto "El editor permite tener en un archivo de texto (txt) una lista subrutinas que se mostrará durante la edición del programa pieza, cada vez que se edite una sentencia #PCALL ó #MCALL. [...] Esta ayuda está siempre activa, independientemente del estado de la softkey de ayudas al editor 'Ayuda prog'."@es .

ns1:ArchivoSubrutinas_PCALL_TXT a ns1:Componente ;
    rdfs:label "Archivo pcall.txt (lista de subrutinas)"@es ;
    ns1:documentadoEn ns1:InterfazEditorCNC8070 ;
    ns1:identificador "pcall.txt" ;
    ns1:textoExtracto "El nombre del fichero deberá ser .pcall.txt [...] El fichero se deberá editar de tal manera que cada línea sea el nombre de una posible subrutina a llamar."@es .

