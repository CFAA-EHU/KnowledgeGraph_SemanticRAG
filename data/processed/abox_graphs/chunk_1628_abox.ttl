@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Directiva_V1.60_8060 a ns1:Directiva ;
    rdfs:label "Versión V1.60 (8060)"@es ;
    ns1:identificador "V1.60 (8060)" ;
    ns1:textoExtracto "A partir de las versiones V1.60 (8060) y V5.60 (8065), el CNC ya no busca los archivos de ayuda en las siguientes carpetas"@es .

ns1:Directiva_V5.60_8065 a ns1:Directiva ;
    rdfs:label "Versión V5.60 (8065)"@es ;
    ns1:identificador "V5.60 (8065)" ;
    ns1:textoExtracto "A partir de las versiones V1.60 (8060) y V5.60 (8065), el CNC ya no busca los archivos de ayuda en las siguientes carpetas"@es .

ns1:Fichero_pcall_txt a ns1:InterfazUsuario ;
    rdfs:label "Fichero pcall.txt"@es ;
    ns1:identificador "pcall.txt" ;
    ns1:textoExtracto "la lista pcall.txt mostrará los nombres de subrutinas contenidos en ambos"@es .

