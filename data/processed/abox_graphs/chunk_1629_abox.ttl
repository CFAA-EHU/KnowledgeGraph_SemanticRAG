@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CanalActivo a ns1:ModoOperacion ;
    rdfs:label "canal activo" ;
    ns1:textoExtracto "canal activo" .

ns1:CanalConcreto a ns1:ModoOperacion ;
    rdfs:label "canal en concreto" ;
    ns1:textoExtracto "un canal en concreto" .

ns1:ConfiguracionComportamiento a ns1:AccionProhibida ;
    rdfs:label "configurar el comportamiento" ;
    ns1:detalladoEnEsquema ns1:Canales ;
    ns1:textoExtracto "configurar el comportamiento" .

ns1:MaquinaDosPuestos a ns1:Maquina ;
    rdfs:label "máquina con dos puestos de trabajo" ;
    ns1:textoExtracto "una máquina con dos puestos de trabajo" .

ns1:TornoTT a ns1:Maquina ;
    rdfs:label "torno TT" ;
    ns1:textoExtracto "torno TT" .

ns1:PanelJog1 a ns1:Componente ;
    rdfs:label "panel de jog" ;
    ns1:controla ns1:CNC ;
    ns1:textoExtracto "panel de jog" .

ns1:PanelJog2 a ns1:Componente ;
    rdfs:label "panel de jog" ;
    ns1:controla ns1:CNC ;
    ns1:textoExtracto "paneles de jog" .

ns1:CNC a ns1:Maquina ;
    rdfs:label "CNC" ;
    ns1:controla ns1:Canales ;
    ns1:textoExtracto "CNC" ;
    ns1:tieneComponente ns1:PanelJog1,
        ns1:PanelJog2 .

ns1:Canales a ns1:ModoOperacion ;
    rdfs:label "canales" ;
    ns1:textoExtracto "canales" .

