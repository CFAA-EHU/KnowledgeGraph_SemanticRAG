@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BusCAN_ConfiguracionPaneles a ns1:Sistema ;
    rdfs:label "Bus CAN para configuración de paneles de mando"@es ;
    ns1:identificador "CAN (Address)" ;
    ns1:textoExtracto "El CNC numera los paneles de mando según el orden que ocupan dentro del bus CAN (conmutador Address). El primer panel de jog será el de numeración más baja y así sucesivamente."@es ;
    ns1:tieneComponente ns1:PanelJog_Address0,
        ns1:PanelJog_Address1,
        ns1:PanelJog_Address2 .

ns1:Esquema_ConexionPanelesJog a ns1:Esquema ;
    rdfs:label "Esquema de conexión de paneles Jog al bus CAN"@es ;
    ns1:detalladoEnEsquema ns1:PanelJog_Address0,
        ns1:PanelJog_Address1,
        ns1:PanelJog_Address2 ;
    ns1:textoExtracto "POWER SUPPLY DIGITAL INPUT DIGITAL INPUT SRYESATDEYMC+GGH2NN4ADDVS [...] CNC Remote I/Os Jog-Panel (Address = 0) (Address = 1) (Address = 2)" .

ns1:ConectorAlimentacion_Jog0_X2 a ns1:ComponenteElectrico ;
    rdfs:label "Conector de alimentación y dirección (X2) - Panel Jog (Address 0)"@es ;
    ns1:identificador "X2" ;
    ns1:textoExtracto "ADDRESS RESET [...] X2 [...] +5V [...] GND" .

ns1:ConectorAlimentacion_Jog1_X2 a ns1:ComponenteElectrico ;
    rdfs:label "Conector de alimentación y dirección (X2) - Panel Jog (Address 1)"@es ;
    ns1:identificador "X2" ;
    ns1:textoExtracto "ADDRESS RESET [...] X2 [...] +5V [...] GND" .

ns1:ConectorAlimentacion_Jog2_X2 a ns1:ComponenteElectrico ;
    rdfs:label "Conector de alimentación y dirección (X2) - Panel Jog (Address 2)"@es ;
    ns1:identificador "X2" ;
    ns1:textoExtracto "ADDRESS RESET [...] X2 [...] +5V [...] GND" .

ns1:EntradaDigital_Jog0_X1 a ns1:ComponenteElectrico ;
    rdfs:label "Entradas digitales (X1) - Panel Jog (Address 0)"@es ;
    ns1:identificador "X1" ;
    ns1:textoExtracto "DIGITAL INPUT [...] X1 [...] IIIINNNS 1234567" .

ns1:EntradaDigital_Jog1_X1 a ns1:ComponenteElectrico ;
    rdfs:label "Entradas digitales (X1) - Panel Jog (Address 1)"@es ;
    ns1:identificador "X1" ;
    ns1:textoExtracto "DIGITAL INPUT [...] X1 [...] IIIINNNS 1234567" .

ns1:EntradaDigital_Jog2_X1 a ns1:ComponenteElectrico ;
    rdfs:label "Entradas digitales (X1) - Panel Jog (Address 2)"@es ;
    ns1:identificador "X1" ;
    ns1:textoExtracto "DIGITAL INPUT [...] X1 [...] IIIINNNS 1234567" .

ns1:SalidaDigital_Jog0_X1 a ns1:ComponenteElectrico ;
    rdfs:label "Salidas digitales (X1) - Panel Jog (Address 0)"@es ;
    ns1:identificador "X1" ;
    ns1:textoExtracto "DIGITAL OUTPUT [...] X1 [...] OOOOOOO 1234567" .

ns1:SalidaDigital_Jog1_X1 a ns1:ComponenteElectrico ;
    rdfs:label "Salidas digitales (X1) - Panel Jog (Address 1)"@es ;
    ns1:identificador "X1" ;
    ns1:textoExtracto "DIGITAL OUTPUT [...] X1 [...] OOOOOOO 1234567" .

ns1:SalidaDigital_Jog2_X1 a ns1:ComponenteElectrico ;
    rdfs:label "Salidas digitales (X1) - Panel Jog (Address 2)"@es ;
    ns1:identificador "X1" ;
    ns1:textoExtracto "DIGITAL OUTPUT [...] X1 [...] OOOOOOO 1234567" .

ns1:PanelJog_Address0 a ns1:InterfazUsuario ;
    rdfs:label "Panel de Jog (Address = 0)"@es ;
    ns1:compuestoPor ns1:ConectorAlimentacion_Jog0_X2,
        ns1:EntradaDigital_Jog0_X1,
        ns1:SalidaDigital_Jog0_X1 ;
    ns1:identificador "0" ;
    ns1:textoExtracto "CNC Remote I/Os Jog-Panel (Address = 0)" .

ns1:PanelJog_Address1 a ns1:InterfazUsuario ;
    rdfs:label "Panel de Jog (Address = 1)"@es ;
    ns1:compuestoPor ns1:ConectorAlimentacion_Jog1_X2,
        ns1:EntradaDigital_Jog1_X1,
        ns1:SalidaDigital_Jog1_X1 ;
    ns1:identificador "1" ;
    ns1:textoExtracto "Jog-Panel (Address = 1)" .

ns1:PanelJog_Address2 a ns1:InterfazUsuario ;
    rdfs:label "Panel de Jog (Address = 2)"@es ;
    ns1:compuestoPor ns1:ConectorAlimentacion_Jog2_X2,
        ns1:EntradaDigital_Jog2_X1,
        ns1:SalidaDigital_Jog2_X1 ;
    ns1:identificador "2" ;
    ns1:textoExtracto "Jog-Panel (Address = 2)" .

