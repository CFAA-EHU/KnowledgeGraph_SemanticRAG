@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_ConfiguracionPrestacion a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de configuración de prestación (CNC)"@es ;
    ns1:textoExtracto "C C B B D D A A E E F F 9 9 0 0 8 8 7 7 1 1 2 2 6 6 53 53 4 4" ;
    ns1:tieneComponente ns1:ComponenteElectrico_ConectorX1,
        ns1:ComponenteElectrico_ConectorX2,
        ns1:ComponenteElectrico_DigitalOutput,
        ns1:ComponenteElectrico_MERSMB01 .

ns1:ComponenteElectrico_ConectorX1 a ns1:ComponenteElectrico ;
    rdfs:label "Conector X1 (CNC)"@es ;
    ns1:identificador "X1" ;
    ns1:textoExtracto "X1 X1 X1 X1 X1 X1 OVE R V OS5OV VYL EST RTAE GM5U E" .

ns1:ComponenteElectrico_ConectorX2 a ns1:ComponenteElectrico ;
    rdfs:label "Conector X2 (ADDRESS/RESET)"@es ;
    ns1:identificador "X2" ;
    ns1:textoExtracto "X2 X2 X2 X2 ADDRESSRESET ADDRESSRESET 6 G N D G N D G N D G N D" .

ns1:ComponenteElectrico_DigitalOutput a ns1:ComponenteElectrico ;
    rdfs:label "Salidas digitales (24V)"@es ;
    ns1:identificador "DIGITAL_OUTPUT" ;
    ns1:textoExtracto "DIGITAL OUTPUT DIGITAL OUTPUT DIGITAL OUTPUT DIGITAL OUTPUT [...] + 24 V + 24 V + 24 V + 24 V" ;
    ns1:valor "24 V" .

ns1:ComponenteElectrico_MERSMB01 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo MERSMB01"@es ;
    ns1:identificador "MERSMB01" ;
    ns1:textoExtracto "LIANDED MERSMB01 LIANDED MERSMB01 21 21" .

