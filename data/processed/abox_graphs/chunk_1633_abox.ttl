@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaAsignacionCanales a ns1:Tabla ;
    rdfs:label "Tabla de asignación de paneles de jog a canales" ;
    ns1:documentadoEn ns1:SistemaPanelesJog ;
    ns1:textoExtracto "KEYBD1CH .. KEYBD8CH | Lista de paneles de jog del sistema. [...] Cada panel de jog podrá estar asignado a un canal en concreto o siempre al canal activo." .

ns1:TablaConfiguracionTeclas a ns1:Tabla ;
    rdfs:label "Tabla de configuración de teclas de jog" ;
    ns1:documentadoEn ns1:SistemaPanelesJog ;
    ns1:textoExtracto "JOGKEYDEF, JOGKEYBD2DEF... JOGKEYBD8DEF | Tablas para configurar las teclas de jog." .

ns1:PanelJog1 a ns1:InterfazUsuario ;
    rdfs:label "Primer panel de jog" ;
    ns1:identificador "KEYBD1CH" ;
    ns1:textoExtracto "Primer panel de mando del sistema." .

ns1:PanelJog2 a ns1:InterfazUsuario ;
    rdfs:label "Segundo panel de jog" ;
    ns1:identificador "KEYBD2CH" ;
    ns1:textoExtracto "Segundo panel de mando del sistema." .

ns1:PanelJog3 a ns1:InterfazUsuario ;
    rdfs:label "Tercer panel de jog" ;
    ns1:identificador "KEYBD8CH" ;
    ns1:textoExtracto "Tercer panel de mando del sistema." .

ns1:ParametroJOGKEYBD2DEF a ns1:Parametro ;
    rdfs:label "JOGKEYBD2DEF" ;
    ns1:identificador "JOGKEYBD2DEF" ;
    ns1:textoExtracto "JOGKEYBD2DEF al segundo [panel de jog] [...] definir la función de cada tecla de jog" ;
    ns1:valor "Configuración de teclas del segundo panel de jog" .

ns1:ParametroJOGKEYDEF a ns1:Parametro ;
    rdfs:label "JOGKEYDEF" ;
    ns1:identificador "JOGKEYDEF" ;
    ns1:textoExtracto "El parámetro JOGKEYDEF corresponde al primer panel de jog [...] definir la función de cada tecla de jog" ;
    ns1:valor "Configuración de teclas del primer panel de jog" .

ns1:ParametroKEYBD1CH a ns1:Parametro ;
    rdfs:label "KEYBD1CH" ;
    ns1:identificador "KEYBD1CH" ;
    ns1:textoExtracto "KEYBD1CH corresponde al primer panel de jog" ;
    ns1:valor "Asignación de canal del primer panel de jog" .

ns1:ParametroKEYBD2CH a ns1:Parametro ;
    rdfs:label "KEYBD2CH" ;
    ns1:identificador "KEYBD2CH" ;
    ns1:textoExtracto "KEYBD2CH al segundo [panel de jog]" ;
    ns1:valor "Asignación de canal del segundo panel de jog" .

ns1:ParametroKEYBD8CH a ns1:Parametro ;
    rdfs:label "KEYBD8CH" ;
    ns1:identificador "KEYBD8CH" ;
    ns1:textoExtracto "KEYBD8CH [...] así sucesivamente" ;
    ns1:valor "Asignación de canal del octavo panel de jog" .

ns1:ParametroNKEYBD a ns1:Parametro ;
    rdfs:label "NKEYBD" ;
    ns1:identificador "NKEYBD" ;
    ns1:textoExtracto "El parámetro NKEYBD establece el número de paneles de jog del sistema." ;
    ns1:valor "Número de paneles de jog" .

ns1:SistemaPanelesJog a ns1:Sistema ;
    rdfs:label "Sistema de paneles de jog" ;
    ns1:monitoreaParametro ns1:ParametroJOGKEYBD2DEF,
        ns1:ParametroJOGKEYDEF,
        ns1:ParametroKEYBD1CH,
        ns1:ParametroKEYBD2CH,
        ns1:ParametroKEYBD8CH,
        ns1:ParametroNKEYBD ;
    ns1:textoExtracto "Primer panel de mando del sistema... Tercer panel de mando del sistema." ;
    ns1:tieneComponente ns1:PanelJog1,
        ns1:PanelJog2,
        ns1:PanelJog3 .

