@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_USERKEYBD2DEF a ns1:Parametro ;
    rdfs:label "USERKEYBD2DEF" ;
    ns1:documentadoEn ns1:TablaConfiguracionTeclasUsuario ;
    ns1:identificador "USERKEYBD2DEF" ;
    ns1:textoExtracto "USERKEYBD2DEF al segundo panel de jog." .

ns1:Parametro_USERKEYDEF a ns1:Parametro ;
    rdfs:label "USERKEYDEF" ;
    ns1:documentadoEn ns1:TablaConfiguracionTeclasUsuario ;
    ns1:identificador "USERKEYDEF" ;
    ns1:textoExtracto "El parámetro USERKEYDEF corresponde al primer panel de jog, USERKEYBD2DEF al segundo y así sucesivamente." .

ns1:TecladoJOG a ns1:InterfazUsuario ;
    rdfs:label "Teclado de JOG" ;
    ns1:textoExtracto "El teclado de JOG puede estar compuesto por los siguientes tipos de teclas. Ambos tipos de teclas se pueden definir en el mismo teclado de JOG." ;
    ns1:tieneComponente ns1:Tecla_Rapido,
        ns1:Tecla_Sentido,
        ns1:Tecla_X,
        ns1:Tecla_Xmas .

ns1:EsquemaRelacionTeclasParametros a ns1:Esquema ;
    rdfs:label "Relación entre parámetros USERKEYDEF y teclas de usuario" ;
    ns1:textoExtracto "La relación entre estos parámetros y las teclas de usuario es la siguiente." .

ns1:ManualCNC a ns1:Manual ;
    ns1:textoExtracto "El CNC siempre ofrece 16 parámetros; si el teclado de jog dispone de menos teclas, los parámetros que no tengan asociada ninguna tecla no tendrán ninguna función." .

ns1:Tecla_Rapido a ns1:ComponenteElectrico ;
    rdfs:label "Tecla de rápido" ;
    ns1:textoExtracto "Tecla de rápido. El parámetro se define con el valor 'R'." .

ns1:Tecla_Sentido a ns1:ComponenteElectrico ;
    rdfs:label "Tecla de sentido (+/-)" ;
    ns1:textoExtracto "Teclas para definir el sentido de desplazamiento. El parámetro se define con uno de los valores '+' y '-', para indicar el sentido de desplazamiento." .

ns1:Tecla_X a ns1:ComponenteElectrico ;
    rdfs:label "Tecla X" ;
    ns1:monitoreaParametro ns1:ParametroAXISNAME ;
    ns1:textoExtracto "Teclas para definir el eje a desplazar. El parámetro se define con un valor comprendido entre 1 y 16 (sin signo), que corresponde al eje lógico, según el parámetro AXISNAME." .

ns1:Tecla_Xmas a ns1:ComponenteElectrico ;
    rdfs:label "Tecla X+" ;
    ns1:monitoreaParametro ns1:ParametroAXISNAME ;
    ns1:textoExtracto "Teclas para definir el eje y el sentido de desplazamiento. El parámetro se define con un valor comprendido entre -1 y +16 (con signo)." .

ns1:ParametroAXISNAME a ns1:Parametro ;
    rdfs:label "AXISNAME" ;
    ns1:textoExtracto "El número corresponde al eje lógico, según el parámetro AXISNAME." .

ns1:TablaConfiguracionTeclasUsuario a ns1:Tabla ;
    rdfs:label "Configuración de teclas de usuario como teclas de jog" ;
    ns1:detalladoEnEsquema ns1:EsquemaRelacionTeclasParametros ;
    ns1:documentadoEn ns1:ManualCNC ;
    ns1:textoExtracto "Tablas para configurar las teclas de usuario como teclas de jog." .

