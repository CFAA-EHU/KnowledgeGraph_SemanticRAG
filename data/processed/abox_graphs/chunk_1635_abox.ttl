@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionPrestacion_1374 a ns1:InterfazUsuario ;
    rdfs:label "Configuración de prestación del CNC"@es ;
    ns1:textoExtracto "El CNC siempre ofrece 16 parámetros; si el teclado de jog dispone de menos teclas, los parámetros que no tengan asociada ninguna tecla no tendrán ninguna función. La relación entre estos parámetros y las teclas de usuario es la siguiente."@es ;
    ns1:tieneComponente ns1:JogPanel_1374,
        ns1:TeclasGKEYS_1374 .

ns1:JogPanel_1374 a ns1:ComponenteElectrico ;
    rdfs:label "JOG-PANEL"@es ;
    ns1:identificador "JOG-PANEL" ;
    ns1:textoExtracto "JOG-PANEL | 1 2 15 16"@es .

ns1:TeclasGKEYS_1374 a ns1:ComponenteElectrico ;
    rdfs:label "Teclas GKEYS"@es ;
    ns1:identificador "GKEYS" ;
    ns1:textoExtracto "GKEYS | O J"@es .

