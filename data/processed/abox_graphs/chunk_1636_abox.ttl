@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModuloHardware_JOG_PANEL a ns1:ComponenteElectrico ;
    rdfs:label "Módulo hardware JOG-PANEL" ;
    ns1:identificador "JOG-PANEL" ;
    ns1:textoExtracto """JOG-PANEL
1 2 15 16""" ;
    ns1:tieneComponente ns1:TeclaUsuario_1,
        ns1:TeclaUsuario_15,
        ns1:TeclaUsuario_16,
        ns1:TeclaUsuario_2 .

ns1:Parametro_AXISNAME a ns1:Parametro ;
    rdfs:label "Parámetro AXISNAME" ;
    ns1:identificador "AXISNAME" ;
    ns1:textoExtracto "El número corresponde al eje lógico, según el parámetro AXISNAME." .

ns1:Parametro_JOGTYPE a ns1:Parametro ;
    rdfs:label "Parámetro máquina JOGTYPE" ;
    ns1:identificador "JOGTYPE" ;
    ns1:textoExtracto "Las teclas de usuario así definidas se comportan de la misma manera que las teclas de jog, bien se hayan definido con signo o sin signo, y respetando también lo definido en el parámetro máquina JOGTYPE." .

ns1:Registro_KEYBD1 a ns1:Parametro ;
    rdfs:label "Registro KEYBD1 (mapa de teclas pulsadas)" ;
    ns1:identificador "KEYBD1" ;
    ns1:textoExtracto "KEYBD1 / KEYBD2: Estos registros son una copia del mapa de teclas pulsadas del último teclado utilizado." .

ns1:Registro_KEYBD1_1 a ns1:Parametro ;
    rdfs:label "Registro KEYBD1_1 (teclas pulsadas en panel 1)" ;
    ns1:identificador "KEYBD1_1" ;
    ns1:textoExtracto "KEYBD1_1 / KEYBD2_1: Estos registros indican (bit=1) qué tecla se ha pulsado en cada panel de mando." .

ns1:Registro_KEYBD2 a ns1:Parametro ;
    rdfs:label "Registro KEYBD2 (mapa de teclas pulsadas)" ;
    ns1:identificador "KEYBD2" ;
    ns1:textoExtracto "KEYBD1 / KEYBD2: Estos registros son una copia del mapa de teclas pulsadas del último teclado utilizado." .

ns1:Registro_KEYBD2_1 a ns1:Parametro ;
    rdfs:label "Registro KEYBD2_1 (teclas pulsadas en panel 1)" ;
    ns1:identificador "KEYBD2_1" ;
    ns1:textoExtracto "KEYBD1_1 / KEYBD2_1: Estos registros indican (bit=1) qué tecla se ha pulsado en cada panel de mando." .

ns1:TeclaUsuario_1 a ns1:InterfazUsuario ;
    rdfs:label "Tecla de usuario 1 (JOG-PANEL)" ;
    ns1:monitoreaParametro ns1:Parametro_JOGKEYBDkbDEF ;
    ns1:textoExtracto "Se definen con un valor comprendido entre 1 y 16 (con signo) para las teclas que definen el eje y el sentido." .

ns1:TeclaUsuario_15 a ns1:InterfazUsuario ;
    rdfs:label "Tecla de usuario 15 (JOG-PANEL)" ;
    ns1:monitoreaParametro ns1:Parametro_JOGKEYBDkbDEF ;
    ns1:textoExtracto "Se definen con un valor comprendido entre 1 y 16 (con signo) para las teclas que definen el eje y el sentido." .

ns1:TeclaUsuario_16 a ns1:InterfazUsuario ;
    rdfs:label "Tecla de usuario 16 (JOG-PANEL)" ;
    ns1:monitoreaParametro ns1:Parametro_JOGKEYBDkbDEF ;
    ns1:textoExtracto "Se definen con un valor comprendido entre 1 y 16 (con signo) para las teclas que definen el eje y el sentido." .

ns1:TeclaUsuario_2 a ns1:InterfazUsuario ;
    rdfs:label "Tecla de usuario 2 (JOG-PANEL)" ;
    ns1:monitoreaParametro ns1:Parametro_JOGKEYBDkbDEF ;
    ns1:textoExtracto "Se definen con un valor comprendido entre 1 y 16 (con signo) para las teclas que definen el eje y el sentido." .

ns1:Parametro_JOGKEYBDkbDEF a ns1:Parametro ;
    rdfs:label "Parámetro máquina JOGKEYBDkbDEF" ;
    ns1:identificador "JOGKEYBDkbDEF" ;
    ns1:textoExtracto "El significado de este parámetro es similar al parámetro máquina JOGKEYBDkbDEF. Para definir el comportamiento de cada una de las teclas..." ;
    ns1:valor "1..16 (con/sin signo), '+', '-', 'R'"@es .

