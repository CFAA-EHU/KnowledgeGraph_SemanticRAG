@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaTeclados a ns1:Sistema ;
    rdfs:label "Sistema de gestión de teclados" ;
    ns1:compuestoPor ns1:Registro_KEYBD1,
        ns1:Registro_KEYBD1_1,
        ns1:Registro_KEYBD1_n,
        ns1:Registro_KEYBD2,
        ns1:Registro_KEYBD2_1,
        ns1:Registro_KEYBD2_n ;
    ns1:textoExtracto "Los registros KEYBD1 y KEYBD2 son una copia del mapa de teclas pulsadas del último teclado utilizado." ;
    ns1:tieneComponente ns1:PanelJog_1 .

ns1:Registro_KEYBD1 a ns1:ComponenteElectrico ;
    rdfs:label "Registro KEYBD1" ;
    ns1:textoExtracto "Los registros KEYBD1 y KEYBD2 son una copia del mapa de teclas pulsadas del último teclado utilizado. Estos registros indican qué tecla se ha pulsado (bit=1)." .

ns1:Registro_KEYBD1_1 a ns1:ComponenteElectrico ;
    rdfs:label "Registro KEYBD1_1" ;
    ns1:textoExtracto "Los registros KEYBD1_1 y KEYBD2_1 corresponden al primer panel de jog." ;
    ns1:tieneComponente ns1:PanelJog_1 .

ns1:Registro_KEYBD1_n a ns1:ComponenteElectrico ;
    rdfs:label "Registro KEYBD1_n (genérico)" ;
    ns1:textoExtracto "Los registros KEYBD1_n y KEYBD2_n indican (bit=1) qué tecla se ha pulsado en cada panel de mando." .

ns1:Registro_KEYBD2 a ns1:ComponenteElectrico ;
    rdfs:label "Registro KEYBD2" ;
    ns1:textoExtracto "Los registros KEYBD1 y KEYBD2 son una copia del mapa de teclas pulsadas del último teclado utilizado. Estos registros indican qué tecla se ha pulsado (bit=1)." .

ns1:Registro_KEYBD2_1 a ns1:ComponenteElectrico ;
    rdfs:label "Registro KEYBD2_1" ;
    ns1:textoExtracto "Los registros KEYBD1_1 y KEYBD2_1 corresponden al primer panel de jog." ;
    ns1:tieneComponente ns1:PanelJog_1 .

ns1:Registro_KEYBD2_n a ns1:ComponenteElectrico ;
    rdfs:label "Registro KEYBD2_n (genérico)" ;
    ns1:textoExtracto "Los registros KEYBD1_n y KEYBD2_n indican (bit=1) qué tecla se ha pulsado en cada panel de mando." .

ns1:PanelJog_1 a ns1:InterfazUsuario ;
    rdfs:label "Primer panel de jog" ;
    ns1:textoExtracto "Los registros KEYBD1_1 y KEYBD2_1 corresponden al primer panel de jog." .

