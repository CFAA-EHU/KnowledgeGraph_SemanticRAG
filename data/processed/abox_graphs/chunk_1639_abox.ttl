@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionComportamientoTeclados a ns1:Parametro ;
    rdfs:label "Configuración de comportamiento por defecto de teclados" ;
    ns1:textoExtracto "Modificar el comportamiento por defecto de los teclados respecto a los canales." .

ns1:Registro_KEYLED1 a ns1:ComponenteElectrico ;
    rdfs:label "Registro KEYLED1" ;
    ns1:controla ns1:LedsTeclasPanelesMando ;
    ns1:identificador "KEYLED1" ;
    ns1:textoExtracto "Los registros KEYLED1 y KEYLED2 controlan los led (lámparas) de las teclas de todos los paneles de mando simultáneamente." .

ns1:Registro_KEYLED1_1 a ns1:ComponenteElectrico ;
    rdfs:label "Registro KEYLED1_1 (primer panel de jog)" ;
    ns1:controla ns1:LedsPrimerPanelJog ;
    ns1:identificador "KEYLED1_1" ;
    ns1:textoExtracto "Los registros KEYLED1_1 y KEYLED2_1 corresponden al primer panel de jog" .

ns1:Registro_KEYLED1_n a ns1:ComponenteElectrico ;
    rdfs:label "Registro KEYLED1_n (por panel)" ;
    ns1:controla ns1:LedsTeclasPanelIndividual ;
    ns1:identificador "KEYLED1_n" ;
    ns1:textoExtracto "Los registros KEYLED1_n y KEYLED2_n controlan los led (lámparas) de las teclas de cada panel de mando." .

ns1:Registro_KEYLED2 a ns1:ComponenteElectrico ;
    rdfs:label "Registro KEYLED2" ;
    ns1:controla ns1:LedsTeclasPanelesMando ;
    ns1:identificador "KEYLED2" ;
    ns1:textoExtracto "Los registros KEYLED1 y KEYLED2 controlan los led (lámparas) de las teclas de todos los paneles de mando simultáneamente." .

ns1:Registro_KEYLED2_1 a ns1:ComponenteElectrico ;
    rdfs:label "Registro KEYLED2_1 (primer panel de jog)" ;
    ns1:controla ns1:LedsPrimerPanelJog ;
    ns1:identificador "KEYLED2_1" ;
    ns1:textoExtracto "Los registros KEYLED1_1 y KEYLED2_1 corresponden al primer panel de jog" .

ns1:Registro_KEYLED2_n a ns1:ComponenteElectrico ;
    rdfs:label "Registro KEYLED2_n (por panel)" ;
    ns1:controla ns1:LedsTeclasPanelIndividual ;
    ns1:identificador "KEYLED2_n" ;
    ns1:textoExtracto "Los registros KEYLED1_n y KEYLED2_n controlan los led (lámparas) de las teclas de cada panel de mando." .

ns1:LedsPrimerPanelJog a ns1:ComponenteElectrico ;
    rdfs:label "Lámparas/LEDs del primer panel de jog" ;
    ns1:textoExtracto "Los registros KEYLED1_1 y KEYLED2_1 corresponden al primer panel de jog" .

ns1:LedsTeclasPanelIndividual a ns1:ComponenteElectrico ;
    rdfs:label "Lámparas/LEDs de teclas por panel individual" ;
    ns1:textoExtracto "Los registros KEYLED1_n y KEYLED2_n controlan los led (lámparas) de las teclas de cada panel de mando." .

ns1:LedsTeclasPanelesMando a ns1:ComponenteElectrico ;
    rdfs:label "Lámparas/LEDs de teclas de paneles de mando" ;
    ns1:textoExtracto "Los registros KEYLED1 y KEYLED2 controlan los led (lámparas) de las teclas de todos los paneles de mando simultáneamente." .

