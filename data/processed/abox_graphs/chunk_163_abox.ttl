@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

ex:AlumbradoInteriorDeMaquina a owl:Class ;
    rdfs:label "Alumbrado interior de la máquina" ;
    rdfs:comment "Vista exterior con llamadas a tres recuadros de detalle: dos luminarias verticales enfocando al plato divisor y dos horizontales hacia la herramienta; menciona protección IP67 y función de visibilidad en zona de trabajo." .

ex:Zocalo a owl:Class ;
    rdfs:label "Zócalo" ;
    rdfs:comment "Vista isométrica del zócalo con recuadros que señalan la cubeta superior y los apoyos antivibratorios. El tono gris del cuerpo y los resaltados en rojo ayudan a identificar la base estructural y su función como depósito/retorno del refrigerante y virutas." .

ex:Columna a owl:Class ;
    rdfs:label "Columna" ;
    rdfs:comment "Corte 3D de la columna mostrando guías lineales, regla lineal, cremallera, piñón, servomotores y carro porta-piezas. Flechas y rótulos marcan la direccionalidad vertical del movimiento y la relación entre accionamientos y guiado." .

ex:CarroPortaPieza a owl:Class ;
    rdfs:label "Carro porta-piezas" ;
    rdfs:comment "Explosivo funcional del carro y las guías traseras de contrapesos. Se destacan patines y bloqueos hidráulicos; etiquetas laterales listan frenos MAYR por posiciones izquierda/derecha." .

ex:PlatoDivisor a owl:Class ;
    rdfs:label "Plato divisor" ;
    rdfs:comment "Perspectiva del plato con dentado Hirth, servomotor y torreta de micros (SQ46/SQ47). Colores cálidos resaltan el anillo dentado; flechas sugieren el giro tras el desbloqueo hidráulico." .

ex:LuminariaVertical a owl:Class ;
    rdfs:label "Luminaria vertical" ;
    rdfs:comment "Luminaria vertical enfocando al plato divisor." .

ex:LuminariaHorizontal a owl:Class ;
    rdfs:label "Luminaria horizontal" ;
    rdfs:comment "Luminaria horizontal hacia la herramienta." .

ex:CubetaSuperior a owl:Class ;
    rdfs:label "Cubeta superior" ;
    rdfs:comment "Cubeta superior del zócalo." .

ex:ApoyoAntivibratorio a owl:Class ;
    rdfs:label "Apoyo antivibratorio" ;
    rdfs:comment "Apoyos antivibratorios del zócalo." .

ex:GuiaLineal a owl:Class ;
    rdfs:label "Guía lineal" ;
    rdfs:comment "Guías lineales de la columna." .

ex:ReglaLineal a owl:Class ;
    rdfs:label "Regla lineal" ;
    rdfs:comment "Regla lineal de la columna." .

ex:Cremallera a owl:Class ;
    rdfs:label "Cremallera" ;
    rdfs:comment "Cremallera de la columna." .

ex:Pinon a owl:Class ;
    rdfs:label "Piñón" ;
    rdfs:comment "Piñón de la columna." .

ex:Servomotor a owl:Class ;
    rdfs:label "Servomotor" ;
    rdfs:comment "Servomotores de la columna." .

ex:CarroPortaPieza a owl:Class ;
    rdfs:label "Carro porta-piezas" ;
    rdfs:comment "Carro porta-piezas de la columna." .

ex:Patin a owl:Class ;
    rdfs:label "Patín" ;
    rdfs:comment "Patines del carro porta-piezas." .

ex:BloqueoHidraulico a owl:Class ;
    rdfs:label "Bloqueo hidráulico" ;
    rdfs:comment "Bloqueos hidráulicos del carro porta-piezas." .

ex:FrenoMayr a owl:Class ;
    rdfs:label "Freno MAYR" ;
    rdfs:comment "Frenos MAYR por posiciones izquierda/derecha del carro porta-piezas." .

ex:DentadoHirth a owl:Class ;
    rdfs:label "Dentado Hirth" ;
    rdfs:comment "Dentado Hirth del plato divisor." .

ex:TorretaDeMicros a owl:Class ;
    rdfs:label "Torreta de micros" ;
    rdfs:comment "Torreta de micros (SQ46/SQ47) del plato divisor." .

ex:AnilloDentado a owl:Class ;
    rdfs:label "Anillo dentado" ;
    rdfs:comment "Anillo dentado del plato divisor." .

ex:estaEnfocadoA a owl:ObjectProperty ;
    rdfs:domain ex:LuminariaVertical ;
    rdfs:range ex:PlatoDivisor .

ex:estaEnfocadoA a owl:ObjectProperty ;
    rdfs:domain ex:LuminariaHorizontal ;
    rdfs:range ex:Herramienta .

ex:tieneProteccion a owl:ObjectProperty ;
    rdfs:domain ex:AlumbradoInteriorDeMaquina ;
    rdfs:range ex:ProteccionIP67 .

ex:tieneFuncion a owl:ObjectProperty ;
    rdfs:domain ex:AlumbradoInteriorDeMaquina ;
    rdfs:range ex:FuncionVisibilidad .

ex:tieneCubetaSuperior a owl:ObjectProperty ;
    rdfs:domain ex:Zocalo ;
    rdfs:range ex:CubetaSuperior .

ex:tieneApoyoAntivibratorio a owl:ObjectProperty ;
    rdfs:domain ex:Zocalo ;
    rdfs:range ex:ApoyoAntivibratorio .

ex:tieneBaseEstructural a owl:ObjectProperty ;
    rdfs:domain ex:Zocalo ;
    rdfs:range ex:BaseEstructural .

ex:tieneDepositoRetorno a owl:ObjectProperty ;
    rdfs:domain ex:Zocalo ;
    rdfs:range ex:DepositoRetorno .

ex:tieneGuiaLineal a owl:ObjectProperty ;
    rdfs:domain ex:Columna ;
    rdfs:range ex:GuiaLineal .

ex:tieneReglaLineal a owl:ObjectProperty ;
    rdfs:domain ex:Columna ;
    rdfs:range ex:ReglaLineal .

ex:tieneCremallera a owl:ObjectProperty ;
    rdfs:domain ex:Columna ;
    rdfs:range ex:Cremallera .

ex:tienePinon a owl:ObjectProperty ;
    rdfs:domain ex:Columna ;
    rdfs:range ex:Pinon .

ex:tieneServomotor a owl:ObjectProperty ;
    rdfs:domain ex:Columna ;
    rdfs:range ex:Servomotor .

ex:tieneCarroPortaPieza a owl:ObjectProperty ;
    rdfs:domain ex:Columna ;
    rdfs:range ex:CarroPortaPieza .

ex:tieneDireccionalidadVertical a owl:ObjectProperty ;
    rdfs:domain ex:Columna ;
    rdfs:range ex:DireccionalidadVertical .

ex:tienePatin a owl:ObjectProperty ;
    rdfs:domain ex:CarroPortaPieza ;
    rdfs:range ex:Patin .

ex:tieneBloqueoHidraulico a owl:ObjectProperty ;
    rdfs:domain ex:CarroPortaPieza ;
    rdfs:range ex:BloqueoHidraulico .

ex:tieneFrenoMayr a owl:ObjectProperty ;
    rdfs:domain ex:CarroPortaPieza ;
    rdfs:range ex:FrenoMayr .

ex:tieneDentadoHirth a owl:ObjectProperty ;
    rdfs:domain ex:PlatoDivisor ;
    rdfs:range ex:DentadoHirth .

ex:tieneServomotor a owl:ObjectProperty ;
    rdfs:domain ex:PlatoDivisor ;
    rdfs:range ex:Servomotor .

ex:tieneTorretaDeMicros a owl:ObjectProperty ;
    rdfs:domain ex:PlatoDivisor ;
    rdfs:range ex:TorretaDeMicros .

ex:tieneAnilloDentado a owl:ObjectProperty ;
    rdfs:domain ex:PlatoDivisor ;
    rdfs:range ex:AnilloDentado .

ex:tieneDireccionalidadGiro a owl:ObjectProperty ;
    rdfs:domain ex:PlatoDivisor ;
    rdfs:range ex:DireccionalidadGiro .

ex:ProteccionIP67 a owl:Class ;
    rdfs:label "Protección IP67" ;
    rdfs:comment "Protección IP67 del alumbrado interior de la máquina." .

ex:FuncionVisibilidad a owl:Class ;
    rdfs:label "Función de visibilidad" ;
    rdfs:comment "Función de visibilidad en zona de trabajo del alumbrado interior de la máquina." .

ex:BaseEstructural a owl:Class ;
    rdfs:label "Base estructural" ;
    rdfs:comment "Base estructural del zócalo." .

ex:DepositoRetorno a owl:Class ;
    rdfs:label "Depósito/retorno" ;
    rdfs:comment "Depósito/retorno del refrigerante y virutas del zócalo." .

ex:DireccionalidadVertical a owl:Class ;
    rdfs:label "Direccionalidad vertical" ;
    rdfs:comment "Direccionalidad vertical del movimiento de la columna." .

ex:DireccionalidadGiro a owl:Class ;
    rdfs:label "Direccionalidad de giro" ;
    rdfs:comment "Direccionalidad de giro del plato divisor." .

ex:Herramienta a owl:Class ;
    rdfs:label "Herramienta" ;
    rdfs:comment "Herramienta a la que se enfoca la luminaria horizontal." .