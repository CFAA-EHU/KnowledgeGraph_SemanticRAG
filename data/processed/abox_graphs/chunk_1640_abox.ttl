@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_KEYBD8CH a ns1:Parametro ;
    rdfs:label "KEYBD8CH"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionPanelesJog_1379 ;
    ns1:identificador "KEYBD8CH" ;
    ns1:textoExtracto "Estos registros permiten modificar el comportamiento por defecto de los teclados respecto a los canales, definido en los parámetros máquina."@es ;
    ns1:valor "0",
        "1",
        "2",
        "3",
        "4",
        "FF" .

ns1:Parametro_PANELOFF a ns1:Parametro ;
    rdfs:label "PANELOFF"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionPanelesJog_1379 ;
    ns1:identificador "PANELOFF" ;
    ns1:textoExtracto "Se admite PANELOFF o PANELOFF1 para el primer panel de jog. Si el PLC activa esta marca (=1), se deshabilita el panel de jog correspondiente."@es ;
    ns1:valor "0",
        "1" .

ns1:Sistema_BusCAN a ns1:Sistema ;
    rdfs:label "Bus CAN de paneles de jog"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionPanelesJog_1379 ;
    ns1:textoExtracto "Bus CAN que integra los paneles de jog y teclados. Cada marca PANELOFF afecta solo al panel de jog correspondiente sin alterar otros elementos del bus."@es ;
    ns1:tieneComponente ns1:InterfazUsuario_PanelJog1 .

ns1:InterfazUsuario_PanelJog1 a ns1:InterfazUsuario ;
    rdfs:label "Panel de jog 1 (bus CAN)"@es ;
    ns1:controla ns1:Parametro_KEYBD1CH ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionPanelesJog_1379 ;
    ns1:habilitadoPor ns1:Parametro_PANELOFF1 ;
    ns1:textoExtracto "Panel de jog integrado en el bus CAN, controlable mediante KEYBD1CH y deshabilitable con PANELOFF1 o PANELOFF."@es .

ns1:Parametro_KEYBD1CH a ns1:Parametro ;
    rdfs:label "KEYBD1CH"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionPanelesJog_1379 ;
    ns1:identificador "KEYBD1CH" ;
    ns1:textoExtracto "Estos registros permiten modificar el comportamiento por defecto de los teclados respecto a los canales, definido en los parámetros máquina. Valor 0: Configuración definida en los parámetros máquina. Valor FF: Panel de jog asignado al canal activo."@es ;
    ns1:valor "0",
        "1",
        "2",
        "3",
        "4",
        "FF" .

ns1:Parametro_PANELOFF1 a ns1:Parametro ;
    rdfs:label "PANELOFF1"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionPanelesJog_1379 ;
    ns1:identificador "PANELOFF1" ;
    ns1:textoExtracto "Si el PLC pone una de estas marcas a (=1) se deshabilita el panel de jog correspondiente. La marca PANELOFF1 deshabilita el primero del bus CAN."@es ;
    ns1:valor "0",
        "1" .

ns1:Tabla_ConfiguracionPanelesJog_1379 a ns1:Tabla ;
    rdfs:label "Tabla de configuración de paneles de jog (KEYBD1CH-KEYBD8CH y PANELOFF1-PANELOFF8)"@es ;
    ns1:documentadoEn ns1:Pagina_665_669 ;
    ns1:textoExtracto """
| Marca y registros de PLC. | Significado. |
| --- | --- |
| KEYBD1CH a KEYBD8CH | Estos registros permiten modificar el comportamiento por defecto de los teclados respecto a los canales, definido en los parámetros máquina.
| PANELOFF PANELOFF1 a PANELOFF8 | Si el PLC pone una de estas marcas a (=1) se deshabilita el panel de jog correspondiente.
"""@es .

