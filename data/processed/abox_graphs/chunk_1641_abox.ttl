@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_PANELOFF a ns1:Parametro ;
    rdfs:label "Marca PANELOFF (genérica para primer panel)"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionPanelesJog ;
    ns1:identificador "PANELOFF" ;
    ns1:textoExtracto "Se admite PANELOFF o PANELOFF1 para el primer panel de jog"@es .

ns1:PanelJog_1 a ns1:InterfazUsuario ;
    rdfs:label "Primer panel de jog"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionPanelesJog ;
    ns1:identificador "PANELOFF1" ;
    ns1:textoExtracto "La marca PANELOFF1 deshabilita el primero del bus"@es .

ns1:PanelJog_2 a ns1:InterfazUsuario ;
    rdfs:label "Segundo panel de jog"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionPanelesJog ;
    ns1:identificador "PANELOFF2" ;
    ns1:textoExtracto "la marca PANELOFF2 el segundo"@es .

ns1:Tabla_ConfiguracionPanelesJog a ns1:Tabla ;
    rdfs:label "Tabla de configuración de marcas para paneles de jog"@es ;
    ns1:textoExtracto """
    | Address | Elemento | Marca de PLC |
    | --- | --- | --- |
    | 0 | CNC |  |
    | 1 | Grupo remoto (I/Os) |  |
    | 2 | Panel de jog | PANELOFF1 |
    | 3 | Grupo remoto (I/Os) |  |
    | 4 | Grupo remoto (I/Os) |  |
    | 5 | Panel de jog | PANELOFF2
    """@es .

