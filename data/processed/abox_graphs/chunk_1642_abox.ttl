@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_Automatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático"@es ;
    ns1:textoExtracto "modo de trabajo (automático, manual, etc)"@es .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo manual"@es ;
    ns1:textoExtracto "modo de trabajo (automático, manual, etc)"@es .

ns1:Sistema_ControlJog a ns1:Sistema ;
    rdfs:label "Sistema de control de paneles de jog"@es ;
    ns1:textoExtracto "Cada vez que cambia el teclado activo, el nuevo teclado actualiza en el PLC la información de todas las marcas y registros asociados al propio teclado (KEYBD1_n, KEYBD2_n, KEYDIS1_n a KEYDIS3_n, KEYLED1_n, KEYLED2_n) y también los genéricos asociados a todos los teclados (KEYBD1, KEYBD2, KEYDIS1 a KEYDIS3, KEYLED1, KEYLED2)."@es ;
    ns1:tieneComponente ns1:Conmutador_FeedOverride,
        ns1:Tecla_RESET,
        ns1:Teclado_PANELOFF,
        ns1:Teclas_ModoTrabajo .

ns1:Conmutador_FeedOverride a ns1:ComponenteElectrico ;
    rdfs:label "Conmutador feed override"@es ;
    ns1:textoExtracto "El conmutador feed override. Si el teclado está asociado a un canal en concreto, un cambio del override sólo afecta a ese canal, aunque forme parte de un grupo."@es .

ns1:Tecla_RESET a ns1:ComponenteElectrico ;
    rdfs:label "Tecla [RESET]"@es ;
    ns1:textoExtracto "La tecla [RESET] afecta al canal asociado al teclado desde el que se ha pulsado la tecla y a los canales que pertenecen a su mismo grupo."@es .

ns1:Teclado_PANELOFF a ns1:InterfazUsuario ;
    rdfs:label "Teclado (marca PANELOFF)"@es ;
    ns1:identificador "PANELOFF" ;
    ns1:textoExtracto "Al habilitar un teclado (marca PANELOFF) y cada vez que hay un cambio en un teclado (pulsar una tecla, modificar un conmutador, etc), el canal asume el estado de las teclas y la posición de los conmutadores del nuevo teclado como los valores activos."@es .

ns1:Teclas_ModoTrabajo a ns1:ComponenteElectrico ;
    rdfs:label "Teclas de modo de trabajo (automático, manual, etc)"@es ;
    ns1:textoExtracto "Las teclas para seleccionar el modo de trabajo (automático, manual, etc) sólo afectan al canal activo."@es .

