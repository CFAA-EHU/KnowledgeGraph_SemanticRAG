@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TeclaActivacionAvance_1382 a ns1:InterfazUsuario ;
    rdfs:label "Tecla/pulsador de activación del volante de avance"@es ;
    ns1:habilitadoPor ns1:SistemaControlAvance_1382 ;
    ns1:textoExtracto "Esta prestación se activa y desactiva mediante un pulsador externo o una tecla configurada a tal efecto."@es .

ns1:AvanceMecanizado_1382 a ns1:ModoOperacion ;
    rdfs:label "Control de avance por volante"@es ;
    ns1:textoExtracto "El avance se controla mediante el conmutador del panel de mando [...] El volante de avance permite utilizar uno de los volantes de la máquina para controlar dicho avance en función de lo rápido que gire el volante."@es .

ns1:SistemaControlAvance_1382 a ns1:Sistema ;
    rdfs:label "Gestión del volante de avance (PLC)"@es ;
    ns1:monitoreaParametro ns1:VariableImpulsosVolante_1382 ;
    ns1:textoExtracto "La gestión del volante de avance se debe realizar desde el PLC. [...] La maniobra del PLC debe contemplar: Inhibir desde el PLC todas las posiciones del conmutador feed override; Detectar cuánto gira el volante (lectura de los impulsos recibidos)."@es ;
    ns1:tieneComponente ns1:VolanteAvance_1382 .

ns1:VolanteAvance_1382 a ns1:ComponenteMecanico ;
    rdfs:label "Volante de avance"@es ;
    ns1:controla ns1:AvanceMecanizado_1382 ;
    ns1:monitoreaParametro ns1:VariableImpulsosVolante_1382 ;
    ns1:textoExtracto "El volante de avance permite utilizar uno de los volantes de la máquina para controlar dicho avance en función de lo rápido que gire el volante."@es .

ns1:VariableImpulsosVolante_1382 a ns1:Parametro ;
    rdfs:label "(V.)G.HANDP[hw]"@es ;
    ns1:identificador "(V.)G.HANDP[hw]" ;
    ns1:textoExtracto "Número de impulsos enviados por el volante desde el arranque del sistema."@es ;
    ns1:valor "Número de impulsos"@es .

