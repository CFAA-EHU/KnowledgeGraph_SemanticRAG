@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PLC_1383 a ns1:Sistema ;
    rdfs:label "PLC"@es ;
    ns1:controla ns1:FeedOverride_1383 ;
    ns1:textoExtracto "Fijar desde el PLC el feed override"@es .

ns1:VolanteAvance_1383 a ns1:ComponenteMecanico ;
    rdfs:label "Volante de avance"@es ;
    ns1:monitoreaParametro ns1:ImpulsosVolante_1383 ;
    ns1:textoExtracto "Detectar cuánto gira el volante (lectura de los impulsos recibidos)."@es .

ns1:ImpulsosVolante_1383 a ns1:Parametro ;
    rdfs:label "Impulsos de volante"@es ;
    ns1:controla ns1:FeedOverride_1383 ;
    ns1:textoExtracto "lectura de los impulsos recibidos"@es .

ns1:FeedOverride_1383 a ns1:Parametro ;
    rdfs:label "Feed override"@es ;
    ns1:textoExtracto "Fijar desde el PLC el feed override en función de los impulsos de volante."@es .

