@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramaPLC_ManiobraVolante a ns1:Sistema ;
    rdfs:label "Programa PLC para maniobra del volante de avance" ;
    ns1:controla ns1:MarcaAuxiliarM1001,
        ns1:MarcaM1000 ;
    ns1:monitoreaParametro ns1:RegistroR100,
        ns1:RegistroR101,
        ns1:RegistroR102,
        ns1:RegistroR103 ;
    ns1:textoExtracto "Ejemplo de maniobra del PLC. La máquina dispone de un pulsador para activar y desactivar el volante de avance (entrada I71) y el control del avance se efectúa con el segundo volante." ;
    ns1:tieneComponente ns1:PulsadorVolanteAvance_I71,
        ns1:VolanteAvance .

ns1:MarcaAuxiliarM1001 a ns1:Parametro ;
    rdfs:label "Marca auxiliar para control de volante" ;
    ns1:identificador "M1001" ;
    ns1:textoExtracto "M1001 _____ Marca auxiliar." .

ns1:MarcaM1000 a ns1:Parametro ;
    rdfs:label "Volante de avance activo" ;
    ns1:identificador "M1000" ;
    ns1:textoExtracto "M1000 _____ Volante de avance activo." ;
    ns1:valor "true/false" .

ns1:PulsadorVolanteAvance_I71 a ns1:ComponenteElectrico ;
    rdfs:label "Pulsador para activar/desactivar volante de avance" ;
    ns1:identificador "I71" ;
    ns1:textoExtracto "I71 _____ Pulsador para activar y desactivar el volante de avance." .

ns1:RegistroR100 a ns1:Parametro ;
    rdfs:label "Impulsos totales del volante" ;
    ns1:identificador "R100" ;
    ns1:textoExtracto "R100 _____ Impulsos totales del volante." .

ns1:RegistroR101 a ns1:Parametro ;
    rdfs:label "Impulsos del volante hasta la lectura anterior" ;
    ns1:identificador "R101" ;
    ns1:textoExtracto "R101 _____ Impulsos del volante hasta la lectura anterior." .

ns1:RegistroR102 a ns1:Parametro ;
    rdfs:label "Impulsos del volante desde la lectura anterior" ;
    ns1:identificador "R102" ;
    ns1:textoExtracto "R102 _____ Impulsos del volante desde la lectura anterior." .

ns1:RegistroR103 a ns1:Parametro ;
    rdfs:label "Porcentaje de avance calculado" ;
    ns1:identificador "R103" ;
    ns1:textoExtracto "R103 _____ Porcentaje de avance calculado." .

ns1:VolanteAvance a ns1:ComponenteMecanico ;
    rdfs:label "Volante de avance" ;
    ns1:textoExtracto "el control del avance se efectúa con el segundo volante." .

