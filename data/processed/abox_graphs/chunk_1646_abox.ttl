@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ControlAvance a ns1:Sistema ;
    rdfs:label "Sistema de control de feed override" ;
    ns1:controla ns1:Registro_R103 ;
    ns1:monitoreaParametro ns1:Parametro_FRO ;
    ns1:textoExtracto "CPS R103 LT 0 = SBS 0 R103 R103; CPS R103 GT 120 = MOV 120 R103; DFU CLK100 = CNCWR (R103,PLC.FRO, M1001)" ;
    ns1:tieneComponente ns1:Parametro_FRO,
        ns1:Registro_R103 .

ns1:Parametro_FRO a ns1:Parametro ;
    rdfs:label "PLC.FRO" ;
    ns1:identificador "PLC.FRO" ;
    ns1:textoExtracto "CNCWR (R103,PLC.FRO, M1001)" .

ns1:Registro_R103 a ns1:Parametro ;
    rdfs:label "Registro R103" ;
    ns1:identificador "R103" ;
    ns1:textoExtracto "Ajustar el valor del registro R103; ignorar el sentido de giro del volante (signo) y limitar el valor al 120%." ;
    ns1:valor "120%" .

