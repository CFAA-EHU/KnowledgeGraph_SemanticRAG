@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Estado_CNC_InError a ns1:Parametro ;
    rdfs:label "HMI_INERROR" ;
    ns1:documentadoEn ns1:Seccion_HMI ;
    ns1:identificador "HMI_INERROR" ;
    ns1:textoExtracto "HMI_INERROR=" .

ns1:Estado_CNC_InExecution a ns1:Parametro ;
    rdfs:label "HMI_INEXECUTION" ;
    ns1:documentadoEn ns1:Seccion_HMI ;
    ns1:identificador "HMI_INEXECUTION" ;
    ns1:textoExtracto "HMI_INEXECUTION=" .

ns1:Estado_CNC_Interrupted a ns1:Parametro ;
    rdfs:label "HMI_INTERRUPTED" ;
    ns1:documentadoEn ns1:Seccion_HMI ;
    ns1:identificador "HMI_INTERRUPTED" ;
    ns1:textoExtracto "HMI_INTERRUPTED=" .

ns1:Estado_CNC_NoReady a ns1:Parametro ;
    rdfs:label "HMI_NOREADY" ;
    ns1:documentadoEn ns1:Seccion_HMI ;
    ns1:identificador "HMI_NOREADY" ;
    ns1:textoExtracto "HMI_NOREADY=" .

ns1:Estado_CNC_Ready a ns1:Parametro ;
    rdfs:label "HMI_READY" ;
    ns1:documentadoEn ns1:Seccion_HMI ;
    ns1:identificador "HMI_READY" ;
    ns1:textoExtracto "HMI_READY=" .

ns1:ModoOperacion_Automatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático" ;
    ns1:documentadoEn ns1:SoftkeyHelper_txt ;
    ns1:identificador "AUTOMATIC MODE" ;
    ns1:textoExtracto "Por ejemplo, para el modo automático. [AUTOMATIC MODE] AUTO1=Seleccionar programa AUTO2=Prg en simulación AUTO3=Inspección AUTO4=Abandonar inspección AUTO5=Reposicionar AUTO6=Reposicionar inicio bloque AUTO7=Modo ejecución AUTO8=Cancelar bloque AUTO9=Gráficos" .

ns1:SoftkeyHelper_txt a ns1:InterfazUsuario ;
    rdfs:label "SoftkeyHelper.txt" ;
    ns1:identificador "SoftkeyHelper.txt" ;
    ns1:textoExtracto "Los textos de ayuda están definidos en el archivo SoftkeyHelper.txt, y puede haber un archivo por cada idioma, los cuales se guardan en la carpeta \"..\\MTB\\data\\Lang\". El archivo está en formato texto, por lo que se pueden ver y editar (y por lo tanto traducir a otros idiomas) en cualquier editor de texto." .

ns1:Seccion_HMI a ns1:InterfazUsuario ;
    rdfs:label "Sección HMI" ;
    ns1:documentadoEn ns1:SoftkeyHelper_txt ;
    ns1:identificador "HMI" ;
    ns1:textoExtracto "En el archivo SoftkeyHelper.txt también es posible asignar un texto de ayuda a los iconos que muestran el estado del CNC, en la parte superior de la pantalla. Estos textos de ayuda se definen en la sección [HMI]." .

