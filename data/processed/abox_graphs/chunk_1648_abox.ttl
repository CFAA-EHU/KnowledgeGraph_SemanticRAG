@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Software_RCS_S_v2.01 a ns1:Sistema ;
    rdfs:label "Software RCS-S v2.01" ;
    ns1:controla ns1:RCS_S ;
    ns1:identificador "v2.01" ;
    ns1:textoExtracto "El soporte de FeeDat/EnDat en el módulo RCS-S está disponible a partir de su versión de software i v2.01 y versión de hardware v2.01." .

ns1:Tabla_Especificaciones_RCS_S a ns1:Tabla ;
    rdfs:label "Tabla de especificaciones del módulo RCS-S" ;
    ns1:documentadoEn ns1:RCS_S_4F4AO ;
    ns1:textoExtracto "Módulo | Descripción. | --- | --- | RCS-S-4F4AO | 4 entradas de contaje. - Señal incremental TTL, TTL diferencial y Vpp. - Protocolo SSI, FeeDat, EnDat 2.1 y EnDat 2.2. 4 salidas analógicas ±10 V (16 bits) de propósito general." .

ns1:E21A a ns1:ComponenteElectrico ;
    rdfs:label "Conector E21A" ;
    ns1:identificador "E21A" ;
    ns1:textoExtracto "Conector ꞏE21Aꞏ. Entrada de contaje." .

ns1:E21B a ns1:ComponenteElectrico ;
    rdfs:label "Conector E21B" ;
    ns1:identificador "E21B" ;
    ns1:textoExtracto "Conector ꞏE21Bꞏ. Entrada de contaje." .

ns1:E21C a ns1:ComponenteElectrico ;
    rdfs:label "Conector E21C" ;
    ns1:identificador "E21C" ;
    ns1:textoExtracto "Conector ꞏE21Cꞏ. Entrada de contaje." .

ns1:E21D a ns1:ComponenteElectrico ;
    rdfs:label "Conector E21D" ;
    ns1:identificador "E21D" ;
    ns1:textoExtracto "Conector ꞏE21Dꞏ. Entrada de contaje." .

ns1:I37A a ns1:ComponenteElectrico ;
    rdfs:label "Conector I37A" ;
    ns1:identificador "I37A" ;
    ns1:textoExtracto "Conector ꞏI37Aꞏ. 2 salidas analógicas de propósito general." .

ns1:I37B a ns1:ComponenteElectrico ;
    rdfs:label "Conector I37B" ;
    ns1:identificador "I37B" ;
    ns1:textoExtracto "Conector ꞏI37Bꞏ. 2 salidas analógicas de propósito general." .

ns1:RCS_S a ns1:ComponenteElectrico ;
    rdfs:label "Módulo remoto RCS-S" ;
    ns1:identificador "RCS-S" ;
    ns1:textoExtracto "El módulo \"RCS-S\" permite disponer de un número adicional de entradas de contaje y salidas analógicas (I/Os remotas). Estos módulos se conectan a la unidad central a través del bus Sercos-II, siendo un nodo más dentro del bus." .

ns1:RCS_S_4F4AO a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S-4F4AO" ;
    ns1:compuestoPor ns1:E21A,
        ns1:E21B,
        ns1:E21C,
        ns1:E21D,
        ns1:I37A,
        ns1:I37B ;
    ns1:identificador "RCS-S-4F4AO" ;
    ns1:textoExtracto "4 entradas de contaje. - Señal incremental TTL, TTL diferencial y Vpp. - Protocolo SSI, FeeDat, EnDat 2.1 y EnDat 2.2. 4 salidas analógicas ±10 V (16 bits) de propósito general." .

