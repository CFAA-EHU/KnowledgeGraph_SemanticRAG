@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:PlatoDivisorHirth a ex:ComponenteMecanico ;
    ex:textoExtracto "Plato divisor --- Perspectiva del plato con dentado Hirth, servomotor y torreta de micros (SQ46/SQ47)." .

ex:ServomotorPlatoDivisor a ex:ComponenteElectrico ;
    ex:textoExtracto "servomotor y torreta de micros (SQ46/SQ47)" .

ex:TorretaMicrosSQ46 a ex:ComponenteMecanico ;
    ex:textoExtracto "torreta de micros (SQ46/SQ47)" .

ex:TorretaMicrosSQ47 a ex:ComponenteMecanico ;
    ex:textoExtracto "torreta de micros (SQ46/SQ47)" .

ex:AnilloDentadoHirth a ex:ComponenteMecanico ;
    ex:textoExtracto "plato con dentado Hirth" .

ex:Figura4_5BasesPlatoDivisor a ex:Figura ;
    ex:textoExtracto "Figura 4-5. Bases del plato divisor (0º y 15º)" .

ex:Base0Grados a ex:ComponenteMecanico ;
    ex:textoExtracto "Base 0º" .

ex:Base15Grados a ex:ComponenteMecanico ;
    ex:textoExtracto "Base 15º" .

ex:Figura4_6CambioBase1 a ex:Figura ;
    ex:textoExtracto "Figura 4-6. Cambio de base (1)" .

ex:Figura4_7CambioBase2 a ex:Figura ;
    ex:textoExtracto "Figura 4-7. Cambio de base (2)" .

ex:CableMotor a ex:ComponenteElectrico ;
    ex:textoExtracto "cables del motor" .

ex:CableTorretaMicros a ex:ComponenteElectrico ;
    ex:textoExtracto "cable torreta de micros" .

ex:TuboHidraulico a ex:ComponenteHidraulico ;
    ex:textoExtracto "tubos hidráulicos" .

ex:TuboNeumatico a ex:Componente ;
    ex:textoExtracto "tubo neumático" .

ex:Figura4_8CambioBase3 a ex:Figura ;
    ex:textoExtracto "Figura 4-8. Cambio de base (3)" .

ex:DiscoAgujerosRoscados a ex:ComponenteMecanico ;
    ex:textoExtracto "disco con agujeros roscados M12" .

ex:TornilloFijacion a ex:ComponenteMecanico ;
    ex:textoExtracto "tornillos de fijación" .

ex:TornilloAjuste a ex:ComponenteMecanico ;
    ex:textoExtracto "tornillos de ajuste" .

ex:EsquemaElectricoPlatoDivisor a ex:Esquema ;
    ex:textoExtracto "ESQUEMAS ELECTRICOS" ;
    ex:tieneComponente ex:ServomotorPlatoDivisor, ex:CableMotor, ex:CableTorretaMicros .

ex:EsquemaHidraulicoPlatoDivisor a ex:Esquema ;
    ex:textoExtracto "ESQUEMAS DE FLUIDOS" ;
    ex:tieneComponente ex:TuboHidraulico, ex:TuboNeumatico .