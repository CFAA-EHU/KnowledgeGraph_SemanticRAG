ns1:Base0 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Dos vistas comparativas con rótulos Base 0º y Base 15º." .

ns1:Base15 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Dos vistas comparativas con rótulos Base 0º y Base 15º." .

ns1:CableMotor a ns1:ComponenteElectrico ;
    ns1:textoExtracto "fotografías de detalle con recuadros y flechas hacia cables del motor" .

ns1:CableTorretaMicros a ns1:ComponenteElectrico ;
    ns1:textoExtracto "cable torreta de micros" .

ns1:DentadoHirth a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Perspectiva del plato con dentado Hirth" .

ns1:DiscoConAgujerosRoscados a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Vista superior del disco con agujeros roscados M12 para cáncamos y llamadas a tornillos de fijación y tornillos de ajuste." .

ns1:PlatoDivisor a ns1:ComponenteMecanico ;
    ns1:compuestoPor ns1:DentadoHirth,
        ns1:Servomotor,
        ns1:TorretaDeMicros ;
    ns1:textoExtracto "Plato divisor --- Perspectiva del plato con dentado Hirth, servomotor y torreta de micros (SQ46/SQ47)." .

