    ns1:textoExtracto "servomotor" .

ns1:TornilloAjuste a ns1:ComponenteMecanico ;
    ns1:textoExtracto "tornillos de ajuste" .

ns1:TornilloFijacion a ns1:ComponenteMecanico ;
    ns1:textoExtracto "tornillos de fijación" .

ns1:TorretaDeMicros a ns1:ComponenteMecanico ;
    ns1:identificador "SQ46/SQ47" ;
    ns1:textoExtracto "torreta de micros (SQ46/SQ47)" .

ns1:TuboHidraulico a ns1:ComponenteHidraulico ;
    ns1:textoExtracto "tubos hidráulicos" .

ns1:TuboNeumatico a ns1:ComponenteHidraulico ;
    ns1:textoExtracto "tubo neumático" .

