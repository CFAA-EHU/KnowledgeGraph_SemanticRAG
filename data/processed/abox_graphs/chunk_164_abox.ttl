@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix base: <https://vocab.cfaa.eus/broaching/base#> .
@prefix mecanica: <https://vocab.cfaa.eus/broaching/mecanica#> .
@prefix elec: <https://vocab.cfaa.eus/broaching/electrico#> .
@prefix fluidos: <https://vocab.cfaa.eus/broaching/fluidos#> .
@prefix fig: <https://vocab.cfaa.eus/broaching/figuras#> .

#################################################################
# Clases
#################################################################

base:PlatoDivisor a owl:Class ;
    rdfs:subClassOf ex:Pieza ;
    rdfs:label "Plato divisor" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Motor> ;
    rdfs:comment "Componente mecánico utilizado para posicionar piezas en operaciones de brochado con ajuste angular." .

base:DentadoHirth a owl:Class ;
    rdfs:subClassOf ex:DentadoPerimetral ;
    rdfs:label "Dentado Hirth" ;
    rdfs:comment "Tipo de dentado de precisión utilizado en platos divisores para garantizar posicionamiento angular exacto." .

base:Servomotor a owl:Class ;
    rdfs:subClassOf ex:Servomotor ;
    rdfs:label "Servomotor" ;
    rdfs:comment "Actuador eléctrico de alta precisión para el giro controlado del plato divisor." .

base:TorretaDeMicros a owl:Class ;
    rdfs:subClassOf ex:Sensor ;
    rdfs:label "Torreta de micros" ;
    rdfs:comment "Dispositivo de medición de precisión asociado al plato divisor para control de posición angular." .

base:AgujeroRoscado a owl:Class ;
    rdfs:subClassOf ex:AgujeroRoscado ;
    rdfs:label "Agujero roscado" ;
    rdfs:comment "Orificio con rosca para fijación de componentes o cáncamos." .

base:Cable a owl:Class ;
    rdfs:subClassOf ex:Cable ;
    rdfs:label "Cable" ;
    rdfs:comment "Conductor eléctrico para conexión de componentes." .

fluidos:TuboHidraulico a owl:Class ;
    rdfs:subClassOf ex:TuboHidraulico ;
    rdfs:label "Tubo hidráulico" ;
    rdfs:comment "Conducto para transporte de fluido hidráulico." .

fluidos:TuboNeumatico a owl:Class ;
    rdfs:subClassOf ex:TuboNeumatico ;
    rdfs:label "Tubo neumático" ;
    rdfs:comment "Conducto para transporte de aire comprimido." .

base:Tornillo a owl:Class ;
    rdfs:subClassOf ex:Tornillo ;
    rdfs:label "Tornillo" ;
    rdfs:comment "Elemento de fijación roscado." .

base:Cancamo a owl:Class ;
    rdfs:subClassOf ex:Cancamo ;
    rdfs:label "Cáncamo" ;
    rdfs:comment "Elemento de izado con rosca para sujeción temporal." .

mecanica:BaseInclinada a owl:Class ;
    rdfs:subClassOf ex:BaseInclinada ;
    rdfs:label "Base inclinada" ;
    rdfs:comment "Configuración del plato divisor con inclinación angular específica (0° o 15°)." .

mecanica:Flecha a owl:Class ;
    rdfs:subClassOf ex:Flecha ;
    rdfs:label "Flecha" ;
    rdfs:comment "Indicación gráfica de dirección o sentido de movimiento." .

mecanica:RecuadroSTOP a owl:Class ;
    rdfs:subClassOf ex:RecuadroSTOP ;
    rdfs:label "Recuadro STOP" ;
    rdfs:comment "Elemento gráfico de advertencia o punto de intervención." .

mecanica:Simetria a owl:Class ;
    rdfs:subClassOf ex:Simetria ;
    rdfs:label "Simetría" ;
    rdfs:comment "Propiedad geométrica de equilibrio en la distribución de elementos." .

mecanica:Amarradura a owl:Class ;
    rdfs:subClassOf ex:Amarradura ;
    rdfs:label "Amarradura" ;
    rdfs:comment "Sistema de sujeción o fijación de componentes." .

mecanica:ConfiguracionCromatica a owl:Class ;
    rdfs:subClassOf ex:ConfiguracionCromatica ;
    rdfs:label "Configuración cromática" ;
    rdfs:comment "Uso de colores para diferenciar configuraciones o estados." .

#################################################################
# Propiedades
#################################################################

mecanica:tieneDentadoHirth a owl:ObjectProperty ;
    rdfs:label "tiene dentado Hirth" ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range base:DentadoHirth ;
    rdfs:comment "Relación que indica la presencia de un dentado Hirth en el plato divisor." .

mecanica:tieneServomotor a owl:ObjectProperty ;
    rdfs:label "tiene servomotor" ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range base:Servomotor ;
    rdfs:comment "Relación que indica la presencia de un servomotor asociado al plato divisor." .

mecanica:tieneTorretaDeMicros a owl:ObjectProperty ;
    rdfs:label "tiene torreta de micros" ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range base:TorretaDeMicros ;
    rdfs:comment "Relación que indica la presencia de una torreta de micros en el plato divisor." .

mecanica:tieneAgujerosRoscados a owl:ObjectProperty ;
    rdfs:label "tiene agujeros roscados" ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range base:AgujeroRoscado ;
    rdfs:comment "Relación que indica la presencia de agujeros roscados en el plato divisor." .

mecanica:tieneCables a owl:ObjectProperty ;
    rdfs:label "tiene cables" ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range base:Cable ;
    rdfs:comment "Relación que indica la conexión de cables al plato divisor." .

fluidos:tieneTubosHidraulicos a owl:ObjectProperty ;
    rdfs:label "tiene tubos hidráulicos" ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range fluidos:TuboHidraulico ;
    rdfs:comment "Relación que indica la conexión de tubos hidráulicos al plato divisor." .

fluidos:tieneTubosNeumaticos a owl:ObjectProperty ;
    rdfs:label "tiene tubos neumáticos" ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range fluidos:TuboNeumatico ;
    rdfs:comment "Relación que indica la conexión de tubos neumáticos al plato divisor." .

base:tieneTornillos a owl:ObjectProperty ;
    rdfs:label "tiene tornillos" ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range base:Tornillo ;
    rdfs:comment "Relación que indica la presencia de tornillos de fijación en el plato divisor." .

base:tieneCancamos a owl:ObjectProperty ;
    rdfs:label "tiene cáncamos" ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range base:Cancamo ;
    rdfs:comment "Relación que indica la presencia de cáncamos en el plato divisor." .

mecanica:tieneBaseInclinada a owl:ObjectProperty ;
    rdfs:label "tiene base inclinada" ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range mecanica:BaseInclinada ;
    rdfs:comment "Relación que indica la configuración de base inclinada (0° o 15°) del plato divisor." .

mecanica:tieneFlechas a owl:ObjectProperty ;
    rdfs:label "tiene flechas" ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range mecanica:Flecha ;
    rdfs:comment "Relación que indica la presencia de flechas indicativas en el plato divisor." .

mecanica:tieneRecuadrosSTOP a owl:ObjectProperty ;
    rdfs:label "tiene recuadros STOP" ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range mecanica:RecuadroSTOP ;
    rdfs:comment "Relación que indica la presencia de recuadros STOP en el plato divisor." .

mecanica:tieneSimetria a owl:ObjectProperty ;
    rdfs:label "tiene simetría" ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range mecanica:Simetria ;
    rdfs:comment "Relación que indica la simetría en la distribución de elementos del plato divisor." .

mecanica:tieneAmarradura a owl:ObjectProperty ;
    rdfs:label "tiene amarradura" ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range mecanica:Amarradura ;
    rdfs:comment "Relación que indica el sistema de amarradura del plato divisor." .

mecanica:tieneConfiguracionCromatica a owl:ObjectProperty ;
    rdfs:label "tiene configuración cromática" ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range mecanica:ConfiguracionCromatica ;
    rdfs:comment "Relación que indica el uso de colores para diferenciar configuraciones del plato divisor." .

mecanica:indicaDireccionGiro a owl:ObjectProperty ;
    rdfs:label "indica dirección de giro" ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range mecanica:Flecha ;
    rdfs:comment "Relación que indica que las flechas señalan la dirección de giro tras el desbloqueo hidráulico." .

mecanica:resaltaAnilloDentado a owl:ObjectProperty ;
    rdfs:label "resalta anillo dentado" ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range base:DentadoHirth ;
    rdfs:comment "Relación que indica que el anillo dentado es resaltado visualmente en el plato divisor." .

mecanica:guiaOrdenActuacion a owl:ObjectProperty ;
    rdfs:label "guía orden de actuación" ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range base:Tornillo ;
    rdfs:comment "Relación que indica que las flechas guían el orden de actuación en los tornillos de fijación." .

mecanica:refuerzaExtraccionBase a owl:ObjectProperty ;
    rdfs:label "refuerza extracción de base" ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range base:Tornillo ;
    rdfs:comment "Relación que indica que los rótulos repetidos en tornillos refuerzan la extracción de la base del plato divisor." .

mecanica:diferenciaConfiguraciones a owl:ObjectProperty ;
    rdfs:label "diferencia configuraciones" ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range mecanica:ConfiguracionCromatica ;
    rdfs:comment "Relación que indica que la codificación cromática diferencia las configuraciones de base (0° y 15°)." .

mecanica:evidenciaAjusteAngular a owl:ObjectProperty ;
    rdfs:label "evidencia ajuste angular" ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range base:DentadoHirth ;
    rdfs:comment "Relación que indica que el dentado Hirth evidencia el ajuste angular disponible para el brochado." .

mecanica:desconectarComponentes a owl:ObjectProperty ;
    rdfs:label "requiere desconexión de componentes" ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range [ a owl:Class ;
        owl:unionOf ( base:Cable fluidos:TuboHidraulico fluidos:TuboNeumatico ) ] ;
    rdfs:comment "Relación que indica que el procedimiento de cambio de base requiere desconectar cables, tubos hidráulicos y neumáticos." .

mecanica:procedimientoCambioBase a owl:ObjectProperty ;
    rdfs:label "procedimiento de cambio de base" ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range [ a owl:Class ;
        owl:unionOf ( base:BaseInclinada base:Tornillo base:Cancamo ) ] ;
    rdfs:comment "Relación que indica que el procedimiento de cambio de base involucra configuraciones de base, tornillos y cáncamos." .