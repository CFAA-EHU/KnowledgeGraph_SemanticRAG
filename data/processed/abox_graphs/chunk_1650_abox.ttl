@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_ParametrosMaquina a ns1:InterfazUsuario ;
    rdfs:label "Parámetros máquina para configuración de salidas analógicas"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionSalidasAnalogicas ;
    ns1:textoExtracto "La salida analógica se configura desde los parámetros máquina. Cada eje dispone de los siguientes parámetros máquina para su configuración."@es ;
    ns1:tieneComponente ns1:Parametro_ANAOUTID,
        ns1:Parametro_ANAOUTTYPE .

ns1:Sistema_ModuloRCS_S a ns1:Sistema ;
    rdfs:label "Módulo RCS-S (contadora Sercos)"@es ;
    ns1:identificador "RCS-S" ;
    ns1:monitoreaParametro ns1:Parametro_ANAOUTID,
        ns1:Parametro_ANAOUTTYPE ;
    ns1:textoExtracto "Módulo RCS-S (contadora Sercos)"@es .

ns1:Tabla_ConfiguracionSalidasAnalogicas a ns1:Tabla ;
    rdfs:label "Tabla de configuración de salidas analógicas"@es ;
    ns1:detalladoEnEsquema ns1:Parametro_ANAOUTID,
        ns1:Parametro_ANAOUTTYPE ;
    ns1:textoExtracto "La consigna para un eje analógico se puede tomar desde una salida analógica de los módulos remotos, de un regulador Sercos o de una contadora Sercos."@es .

ns1:Parametro_ANAOUTID a ns1:Parametro ;
    rdfs:label "ANAOUTID" ;
    ns1:identificador "ANAOUTID" ;
    ns1:textoExtracto "ANAOUTID | 1 - 4."@es ;
    ns1:valor "1 - 4" .

ns1:Parametro_ANAOUTTYPE a ns1:Parametro ;
    rdfs:label "ANAOUTTYPE" ;
    ns1:identificador "ANAOUTTYPE" ;
    ns1:textoExtracto "ANAOUTTYPE | Tipo de salida analógica asociada al eje."@es ;
    ns1:valor "Módulo RCS-S (contadora Sercos)"@es .

