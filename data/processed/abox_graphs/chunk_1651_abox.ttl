@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_SalidasAnalogicas a ns1:Sistema ;
    rdfs:label "Salidas analógicas modulares" ;
    ns1:compuestoPor ns1:ComponenteElectrico_Modulo1,
        ns1:ComponenteElectrico_Modulo2 ;
    ns1:documentadoEn ns1:InterfazUsuario_ContadorasSercos ;
    ns1:textoExtracto "Las salidas analógicas del primer módulo serán 1 a 4, las del segundo 5 a 8 y así sucesivamente" .

ns1:ComponenteElectrico_Modulo1 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo 1 de salidas analógicas" ;
    ns1:identificador "1" ;
    ns1:textoExtracto "Las salidas analógicas del primer módulo serán 1 a 4" .

ns1:ComponenteElectrico_Modulo2 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo 2 de salidas analógicas" ;
    ns1:identificador "2" ;
    ns1:textoExtracto "las del segundo 5 a 8" .

ns1:InterfazUsuario_ContadorasSercos a ns1:InterfazUsuario ;
    rdfs:label "Contadoras Sercos" ;
    ns1:monitoreaParametro ns1:Parametro_ANAOUTID,
        ns1:Parametro_SERCOUNTID ;
    ns1:textoExtracto "Gestión de la consigna analógica desde la contadora Sercos" .

ns1:Parametro_ANAOUTID a ns1:Parametro ;
    rdfs:label "ANAOUTID" ;
    ns1:identificador "ANAOUTID" ;
    ns1:textoExtracto "el parámetro ANAOUTID indica el número de la salida analógica que se utiliza para la consigna" .

ns1:Parametro_SERCOUNTID a ns1:Parametro ;
    rdfs:label "SERCOUNTID" ;
    ns1:identificador "SERCOUNTID" ;
    ns1:textoExtracto "parámetro SERCOUNTID" .

