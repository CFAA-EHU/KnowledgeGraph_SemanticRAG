@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionEntradasCaptacion_1391 a ns1:Sistema ;
    rdfs:label "Configuración de entradas de captación por eje"@es ;
    ns1:textoExtracto "La entrada de captación se configura desde los parámetros máquina. Cada eje dispone de los siguientes parámetros máquina para su configuración..."@es ;
    ns1:tieneComponente ns1:Parametro_COUNTERID_1391,
        ns1:Parametro_COUNTERTYPE_1391 .

ns1:ModuloRCS_S_1391 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S (contadora Sercos)"@es ;
    ns1:monitoreaParametro ns1:Parametro_COUNTERID_1391,
        ns1:Parametro_COUNTERTYPE_1391 ;
    ns1:textoExtracto "La entrada de captación del eje puede estar ubicada en [...] una contadora Sercos. La selección se realiza mediante los parámetros COUNTERTYPE y COUNTERID."@es .

ns1:ModuloRemoto_1391 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo remoto"@es ;
    ns1:textoExtracto "La entrada de captación del eje puede estar ubicada en los módulos remotos [...]."@es .

ns1:ReguladorSercos_1391 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos (captación libre)"@es ;
    ns1:textoExtracto "La entrada de captación del eje puede estar ubicada en [...] la captación libre de un regulador Sercos."@es .

ns1:UnidadCentral_1391 a ns1:ComponenteElectrico ;
    rdfs:label "Unidad central (entradas de captación locales)"@es ;
    ns1:textoExtracto "La entrada de captación del eje puede estar ubicada en [...] las entradas de captación locales de la unidad central."@es .

ns1:Parametro_COUNTERID_1391 a ns1:Parametro ;
    rdfs:label "COUNTERID" ;
    ns1:identificador "COUNTERID" ;
    ns1:textoExtracto "Número de la entrada de captación del eje. El parámetro COUNTERID indica el número de la entrada de captación que se utiliza."@es ;
    ns1:valor "1 - 32" .

ns1:Parametro_COUNTERTYPE_1391 a ns1:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ns1:identificador "COUNTERTYPE" ;
    ns1:textoExtracto "Tipo de entrada de captación del eje."@es ;
    ns1:valor "Módulo RCS-S (contadora Sercos)"@es .

