@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaContadorasSercos a ns1:Sistema ;
    rdfs:label "Sistema de contadoras Sercos"@es ;
    ns1:monitoreaParametro ns1:Parametro_SERCOUNTID ;
    ns1:textoExtracto "Entrada de captación en la contadora Sercos"@es ;
    ns1:tieneComponente ns1:EntradaCaptacion_1_4,
        ns1:EntradaCaptacion_5_8 .

ns1:EntradaCaptacion_1_4 a ns1:ComponenteElectrico ;
    rdfs:label "Entradas de captación 1-4 (primer módulo)"@es ;
    ns1:identificador "1-4" ;
    ns1:monitoreaParametro ns1:Parametro_COUNTERID ;
    ns1:textoExtracto "Las entradas de captación del primer módulo serán 1 a 4"@es .

ns1:EntradaCaptacion_5_8 a ns1:ComponenteElectrico ;
    rdfs:label "Entradas de captación 5-8 (segundo módulo)"@es ;
    ns1:identificador "5-8" ;
    ns1:monitoreaParametro ns1:Parametro_COUNTERID ;
    ns1:textoExtracto "las del segundo 5 a 8"@es .

ns1:Parametro_SERCOUNTID a ns1:Parametro ;
    rdfs:label "SERCOUNTID" ;
    ns1:identificador "SERCOUNTID" ;
    ns1:textoExtracto "Las contadoras Sercos se numeran según su orden lógico (parámetro SERCOUNTID)"@es .

ns1:Parametro_COUNTERID a ns1:Parametro ;
    rdfs:label "COUNTERID" ;
    ns1:identificador "COUNTERID" ;
    ns1:textoExtracto "El parámetro COUNTERID indica el número de la entrada de captación que se utiliza"@es .

