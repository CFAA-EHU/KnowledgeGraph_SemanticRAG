@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ContadoraSercos a ns1:Sistema ;
    rdfs:label "Contadora Sercos (RCS-S)" ;
    ns1:monitoreaParametro ns1:Parametro_COUNTERID ;
    ns1:textoExtracto "Módulo RCS-S (contadora Sercos)." .

ns1:Tabla_ConfiguracionCaptacionVolante a ns1:Tabla ;
    rdfs:label "Configuración de entrada de captación del volante" ;
    ns1:documentadoEn ns1:ModoOperacion_Manual ;
    ns1:textoExtracto "Configurar la entrada de captación. [...] La selección se realiza mediante los parámetros COUNTERTYPE y COUNTERID." .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo manual" ;
    ns1:textoExtracto "El volante se configura desde los parámetros máquina del modo manual." ;
    ns1:tieneComponente ns1:Parametro_COUNTERID,
        ns1:Parametro_COUNTERTYPE .

ns1:Parametro_COUNTERTYPE a ns1:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ns1:textoExtracto "Tipo de entrada de captación del volante." ;
    ns1:valor "Módulo RCS-S (contadora Sercos)" .

ns1:Parametro_COUNTERID a ns1:Parametro ;
    rdfs:label "COUNTERID" ;
    ns1:textoExtracto "Entrada de captación asociada al volante. [...] El parámetro COUNTERID indica el número de la entrada de captación que se utiliza." ;
    ns1:valor "1 - 32" .

