@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Modulo_RCS_S a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S (contadora Sercos)"@es ;
    ns1:monitoreaParametro ns1:Parametro_DRIVEVAR_33348 ;
    ns1:textoExtracto "Las alarmas de las entradas de captación del módulo RCS-S (contadora Sercos) se pueden desactivar..."@es ;
    ns1:tieneComponente ns1:EntradaCaptacion_1 .

ns1:VariableDeshabilitacion_Alarmas a ns1:Parametro ;
    rdfs:label "Variable DRV.{mnemónico}.{nodo} para deshabilitar alarmas"@es ;
    ns1:documentadoEn ns1:Tabla_DRIVEVAR ;
    ns1:solucionaFallo ns1:Alarma_EntradaCaptacion_1 ;
    ns1:textoExtracto "El acceso a la variable será de la forma: (V.)DRV.{mnemónico}.{nodo}"@es .

ns1:AvisoSeguridad_MovimientoMultieje a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para movimiento en multiejes"@es ;
    ns1:textoExtracto "evitar que el eje no activo reporte alarmas que sean consecuencia del movimiento del eje activo (ejes/cabezales compartiendo señal de entrada, pero con diferentes resoluciones)"@es .

ns1:EntradaCaptacion_1 a ns1:Sensor ;
    rdfs:label "Entrada de captación 1"@es ;
    ns1:activaAlarma ns1:Alarma_EntradaCaptacion_1 ;
    ns1:monitoreaParametro ns1:Parametro_DRIVEVAR_33348 ;
    ns1:textoExtracto "IDN Sercos 33348 para la entrada de captación 1"@es .

ns1:Esquema_ParametrosOEM a ns1:Esquema ;
    rdfs:label "Esquema de parámetros máquina OEM"@es ;
    ns1:textoExtracto "En los parámetros máquina OEM, acceder a la tabla DRIVEVAR."@es .

ns1:Alarma_EntradaCaptacion_1 a ns1:Alarma ;
    rdfs:label "Alarma de entrada de captación 1 (IDN 33348)"@es ;
    ns1:mitigaRiesgo ns1:AvisoSeguridad_MovimientoMultieje ;
    ns1:textoExtracto "IDN Sercos 33348 para la entrada de captación 1"@es .

ns1:Parametro_DRIVEVAR_33348 a ns1:Parametro ;
    rdfs:label "Parámetro DRIVEVAR (IDN Sercos 33348)"@es ;
    ns1:documentadoEn ns1:Tabla_DRIVEVAR ;
    ns1:identificador "33348" ;
    ns1:textoExtracto "IDN Sercos 33348 para la entrada de captación 1. Definir la variable en la tabla DRIVEVAR."@es .

ns1:Tabla_DRIVEVAR a ns1:Tabla ;
    rdfs:label "Tabla DRIVEVAR"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_ParametrosOEM ;
    ns1:identificador "DRIVEVAR" ;
    ns1:textoExtracto "En los parámetros máquina OEM, acceder a la tabla DRIVEVAR. [...] Definir la variable en la tabla DRIVEVAR."@es .

