@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:EntradaCaptacion_1 a ns1:Sensor ;
    ns1:identificador "IDN Sercos 33348" ;
    ns1:textoExtracto "IDN Sercos 33348 para la entrada de captación 1." .

ns1:EntradaCaptacion_3 a ns1:Sensor ;
    ns1:identificador "IDN Sercos 33350" ;
    ns1:textoExtracto "IDN Sercos 33350 para la entrada de captación 3." .

ns1:EntradaCaptacion_4 a ns1:Sensor ;
    ns1:identificador "IDN Sercos 33351" ;
    ns1:textoExtracto "IDN Sercos 33351 para la entrada de captación 4." .

ns1:Modulo_SERCOUNTID_4 a ns1:ComponenteElectrico ;
    ns1:identificador "SERCOUNTID=4" ;
    ns1:textoExtracto "módulo configurado como SERCOUNTID=4" ;
    ns1:tieneComponente ns1:EntradaCaptacion_2 .

ns1:Alarma_EntradaCaptacion_2 a ns1:Alarma ;
    ns1:identificador "DRV.RCSALARM.4" ;
    ns1:monitoreaParametro ns1:Parametro_MascaraAlarma ;
    ns1:textoExtracto "El acceso desde el PLC será DRV.RCSALARM.4 [...] Las alarmas se pueden deshabilitar desde la maniobra de PLC, escribiendo (CNCWR) el valor 0 en la variable definida." .

ns1:EntradaCaptacion_2 a ns1:Sensor ;
    ns1:activaAlarma ns1:Alarma_EntradaCaptacion_2 ;
    ns1:identificador "IDN Sercos 33349" ;
    ns1:textoExtracto "IDN Sercos 33349 para la entrada de captación 2." .

ns1:Parametro_MascaraAlarma a ns1:Parametro ;
    ns1:textoExtracto "escribiendo (CNCWR) el valor 0 en la variable definida. Para habilitar de nuevo las alarmas, volver a escribir el valor original de la máscara." ;
    ns1:valor "0" .

