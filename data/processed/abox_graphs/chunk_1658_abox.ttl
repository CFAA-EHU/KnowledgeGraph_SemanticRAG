@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:sistema_ejemplo_parametrizacion_1397 a ns1:Sistema ;
    rdfs:label "Sistema de ejes y contadoras Sercos"@es ;
    ns1:compuestoPor ns1:nodo_1,
        ns1:nodo_2,
        ns1:nodo_3,
        ns1:nodo_4,
        ns1:nodo_5 ;
    ns1:textoExtracto "El sistema dispone de 2 contadoras Sercos (nodos 3, 5) y de 3 reguladores Sercos AXD (nodos 1, 2, 4). Además, el sistema se compone de los siguientes ejes..."@es ;
    ns1:tieneComponente ns1:cabezal_s,
        ns1:eje_u,
        ns1:eje_v,
        ns1:eje_x,
        ns1:eje_y,
        ns1:eje_z,
        ns1:volante_1 .

ns1:nodo_1 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos AXD (Nodo 1)"@es ;
    ns1:controla ns1:eje_v ;
    ns1:identificador "NODO 1" ;
    ns1:textoExtracto "NODO 1: Eje V Sercos."@es .

ns1:nodo_2 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos AXD (Nodo 2)"@es ;
    ns1:controla ns1:eje_u ;
    ns1:identificador "NODO 2" ;
    ns1:textoExtracto "NODO 2: Eje U Sercos. E21A / ANAOUT2"@es .

ns1:nodo_3 a ns1:ComponenteElectrico ;
    rdfs:label "Contadora Sercos (Nodo 3)"@es ;
    ns1:controla ns1:eje_x ;
    ns1:identificador "NODO 3" ;
    ns1:textoExtracto "NODO 3: Eje X analógico. E21B Volante 1. ANAOUT1 Eje Y analógico."@es .

ns1:nodo_4 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos AXD (Nodo 4)"@es ;
    ns1:controla ns1:cabezal_s ;
    ns1:identificador "NODO 4" ;
    ns1:textoExtracto "NODO 4: Cabezal S Sercos E21B"@es .

ns1:nodo_5 a ns1:ComponenteElectrico ;
    rdfs:label "Contadora Sercos (Nodo 5)"@es ;
    ns1:controla ns1:eje_u,
        ns1:eje_y,
        ns1:eje_z ;
    ns1:identificador "NODO 5" ;
    ns1:textoExtracto "NODO 5: Eje U (segunda captación) E21C Eje Y analógico. E21A / ANAOUT4 Eje Z analógico."@es .

ns1:volante_1 a ns1:ComponenteMecanico ;
    rdfs:label "Volante"@es ;
    ns1:identificador "Volante 1" ;
    ns1:textoExtracto "1 volante."@es .

ns1:cabezal_s a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal Sercos S"@es ;
    ns1:identificador "Cabezal S" ;
    ns1:textoExtracto "1 cabezal Sercos S."@es .

ns1:eje_v a ns1:ComponenteMecanico ;
    rdfs:label "Eje Sercos V"@es ;
    ns1:identificador "Eje V" ;
    ns1:textoExtracto "1 eje Sercos V."@es .

ns1:eje_x a ns1:ComponenteMecanico ;
    rdfs:label "Eje analógico X"@es ;
    ns1:identificador "Eje X" ;
    ns1:textoExtracto "3 ejes analógicos X Y Z."@es .

ns1:eje_y a ns1:ComponenteMecanico ;
    rdfs:label "Eje analógico Y"@es ;
    ns1:identificador "Eje Y" ;
    ns1:textoExtracto "3 ejes analógicos X Y Z."@es .

ns1:eje_z a ns1:ComponenteMecanico ;
    rdfs:label "Eje analógico Z"@es ;
    ns1:identificador "Eje Z" ;
    ns1:textoExtracto "3 ejes analógicos X Y Z."@es .

ns1:eje_u a ns1:ComponenteMecanico ;
    rdfs:label "Eje semisercos U"@es ;
    ns1:identificador "Eje U" ;
    ns1:textoExtracto "1 eje semisercos U."@es .

