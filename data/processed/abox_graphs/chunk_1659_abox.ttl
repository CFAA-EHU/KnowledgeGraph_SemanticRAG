@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaSercos_1398 a ns1:Sistema ;
    rdfs:label "Sistema de captación Sercos"@es ;
    ns1:textoExtracto "ANAOUT1 Eje Y analógico. NODO 4: Cabezal S Sercos E21B NODO 5: Eje U (segunda captación) E21C [...] Los parámetros SERCOUNTID1 a SERCOUNTID8 determinan el orden de las entradas de captación."@es ;
    ns1:tieneComponente ns1:Nodo4_1398,
        ns1:Nodo5_1398,
        ns1:Param_NSERCOUNT_1398,
        ns1:Param_SERCOUNTID1_1398,
        ns1:Param_SERCOUNTID2_1398 .

ns1:Nodo4_1398 a ns1:ComponenteElectrico ;
    rdfs:label "NODO 4: Cabezal S Sercos E21B"@es ;
    ns1:identificador "E21B" ;
    ns1:monitoreaParametro ns1:Param_ANAOUT1_1398 ;
    ns1:textoExtracto "NODO 4: Cabezal S Sercos E21B"@es .

ns1:Nodo5_1398 a ns1:ComponenteElectrico ;
    rdfs:label "NODO 5: Eje U (segunda captación) E21C"@es ;
    ns1:identificador "E21C" ;
    ns1:monitoreaParametro ns1:Param_ANAOUT4_1398 ;
    ns1:textoExtracto "NODO 5: Eje U (segunda captación) E21C"@es .

ns1:Param_ANAOUT1_1398 a ns1:Parametro ;
    rdfs:label "ANAOUT1 (Eje Y analógico)"@es ;
    ns1:textoExtracto "ANAOUT1 Eje Y analógico."@es .

ns1:Param_ANAOUT4_1398 a ns1:Parametro ;
    rdfs:label "ANAOUT4 (Eje Z analógico)"@es ;
    ns1:textoExtracto "ANAOUT4 Eje Z analógico."@es .

ns1:Param_NSERCOUNT_1398 a ns1:Parametro ;
    rdfs:label "NSERCOUNT (Número de contadoras Sercos)"@es ;
    ns1:textoExtracto "NSERCOUNT 2 Número de contadoras Sercos en el sistema"@es ;
    ns1:valor "2" .

ns1:Param_SERCOUNTID1_1398 a ns1:Parametro ;
    rdfs:label "SERCOUNTID1"@es ;
    ns1:textoExtracto "SERCOUNTID1 5 (No habitual, pero válido) [...] la primera entrada de captación será la primera del nodo 5."@es ;
    ns1:valor "5" .

ns1:Param_SERCOUNTID2_1398 a ns1:Parametro ;
    rdfs:label "SERCOUNTID2"@es ;
    ns1:textoExtracto "SERCOUNTID2 3"@es ;
    ns1:valor "3" .

