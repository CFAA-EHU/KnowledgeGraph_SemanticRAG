@prefix ex: <https://vocab.cfaa.eus/broaching/>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.

ex:CambioDeBase a owl:Class ;
    rdfs:label "Cambio de base" ;
    rdfs:comment "Procedimiento para cambiar la base de la máquina" .

ex:Plato a owl:Class ;
    rdfs:label "Plato" ;
    rdfs:comment "Componente utilizado en el cambio de base" .

ex:BasePlana a owl:Class ;
    rdfs:label "Base plana" ;
    rdfs:comment "Base plana sobre la cual se coloca el plato" .

ex:Tornillo a owl:Class ;
    rdfs:label "Tornillo" ;
    rdfs:comment "Elemento de fijación utilizado en el amarre del plato" .

ex:Grúa a owl:Class ;
    rdfs:label "Grúa" ;
    rdfs:comment "Equipo utilizado para la inserción del conjunto" .

ex:Plataforma a owl:Class ;
    rdfs:label "Plataforma" ;
    rdfs:comment "Estructura que permite el acceso y movimiento dentro de la máquina" .

ex:PuertaAcceso a owl:Class ;
    rdfs:label "Puerta de acceso" ;
    rdfs:comment "Puerta que permite el acceso al interior de la máquina" .

ex:PortaBrochas a owl:Class ;
    rdfs:label "Porta-brochas" ;
    rdfs:comment "Componente que sostiene las brochas en la máquina" .

ex:Columna a owl:Class ;
    rdfs:label "Columna" ;
    rdfs:comment "Estructura vertical que soporta el porta-brochas" .

ex:CarroPortaPieza a owl:Class ;
    rdfs:label "Carro porta-piezas" ;
    rdfs:comment "Componente que se mueve frente al porta-brochas" .

ex:PlataformaLaterales a owl:Class ;
    rdfs:label "Plataformas laterales" ;
    rdfs:comment "Plataformas situadas a distinta altura en los laterales de la máquina" .

ex:Tornilleria a owl:Class ;
    rdfs:label "Tornillería" ;
    rdfs:comment "Conjunto de tornillos utilizados en la máquina" .

ex:estaAlineadoCon a owl:ObjectProperty ;
    rdfs:label "está alineado con" ;
    rdfs:comment "Relación que indica alineación entre componentes" .

ex:tieneTornillos a owl:ObjectProperty ;
    rdfs:label "tiene tornillos" ;
    rdfs:comment "Relación que indica la presencia de tornillos en un componente" .

ex:tienePlataformas a owl:ObjectProperty ;
    rdfs:label "tiene plataformas" ;
    rdfs:comment "Relación que indica la presencia de plataformas en la máquina" .

ex:tienePuertaAcceso a owl:ObjectProperty ;
    rdfs:label "tiene puerta de acceso" ;
    rdfs:comment "Relación que indica la presencia de una puerta de acceso en la máquina" .

ex:tienePortaBrochas a owl:ObjectProperty ;
    rdfs:label "tiene porta-brochas" ;
    rdfs:comment "Relación que indica la presencia de un porta-brochas en la máquina" .

ex:tieneColumna a owl:ObjectProperty ;
    rdfs:label "tiene columna" ;
    rdfs:comment "Relación que indica la presencia de una columna en la máquina" .

ex:tieneCarroPortaPieza a owl:ObjectProperty ;
    rdfs:label "tiene carro porta-piezas" ;
    rdfs:comment "Relación que indica la presencia de un carro porta-piezas en la máquina" .

ex:tienePlataformaLaterales a owl:ObjectProperty ;
    rdfs:label "tiene plataformas laterales" ;
    rdfs:comment "Relación que indica la presencia de plataformas laterales en la máquina" .

ex:tieneTornilleria a owl:ObjectProperty ;
    rdfs:label "tiene tornillería" ;
    rdfs:comment "Relación que indica la presencia de tornillería en la máquina" .

ex:colocarEn a owl:ObjectProperty ;
    rdfs:label "colocar en" ;
    rdfs:comment "Relación que indica la colocación de un componente en otro" .

ex:insertarCon a owl:ObjectProperty ;
    rdfs:label "insertar con" ;
    rdfs:comment "Relación que indica la inserción de un componente utilizando otro" .

ex:resaltar a owl:ObjectProperty ;
    rdfs:label "resaltar" ;
    rdfs:comment "Relación que indica que un componente es resaltado en un diagrama" .

ex:mostrar a owl:ObjectProperty ;
    rdfs:label "mostrar" ;
    rdfs:comment "Relación que indica que un componente es mostrado en un diagrama" .

ex:indicar a owl:ObjectProperty ;
    rdfs:label "indicar" ;
    rdfs:comment "Relación que indica que un componente es indicado en un diagrama" .

ex:orientar a owl:ObjectProperty ;
    rdfs:label "orientar" ;
    rdfs:comment "Relación que indica que un componente es orientado en un diagrama" .

ex:señalar a owl:ObjectProperty ;
    rdfs:label "señalar" ;
    rdfs:comment "Relación que indica que un componente es señalado en un diagrama" .

ex:verificar a owl:ObjectProperty ;
    rdfs:label "verificar" ;
    rdfs:comment "Relación que indica que un componente es verificado en un diagrama" .

ex:tieneCodificacion a owl:ObjectProperty ;
    rdfs:label "tiene codificación" ;
    rdfs:comment "Relación que indica la presencia de codificación en un componente" .

ex:tieneMarca a owl:ObjectProperty ;
    rdfs:label "tiene marca" ;
    rdfs:comment "Relación que indica la presencia de una marca en un componente" .

ex:tieneLineas a owl:ObjectProperty ;
    rdfs:label "tiene líneas" ;
    rdfs:comment "Relación que indica la presencia de líneas en un diagrama" .

ex:tieneCirulos a owl:ObjectProperty ;
    rdfs:label "tiene círculos" ;
    rdfs:comment "Relación que indica la presencia de círculos en un diagrama" .

ex:tieneFlechas a owl:ObjectProperty ;
    rdfs:label "tiene flechas" ;
    rdfs:comment "Relación que indica la presencia de flechas en un diagrama" .

ex:tieneRecuadros a owl:ObjectProperty ;
    rdfs:label "tiene recuadros" ;
    rdfs:comment "Relación que indica la presencia de recuadros en un diagrama" .