@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:CambioDeBase a owl:Class ;
    rdfs:label "Cambio de base"@es .

ex:Plato a owl:Class ;
    rdfs:label "Plato"@es .

ex:BasePlana a owl:Class ;
    rdfs:label "Base plana"@es .

ex:Tornillo a owl:Class ;
    rdfs:label "Tornillo"@es .

ex:Grúa a owl:Class ;
    rdfs:label "Grúa"@es .

ex:Plataforma a owl:Class ;
    rdfs:label "Plataforma"@es .

ex:PortaBrochas a owl:Class ;
    rdfs:label "Porta-brochas"@es .

ex:Columna a owl:Class ;
    rdfs:label "Columna"@es .

ex:CarroPortaPiezas a owl:Class ;
    rdfs:label "Carro porta-piezas"@es .

ex:EjeVertical a owl:Class ;
    rdfs:label "Eje vertical"@es .

ex:Puerta a owl:Class ;
    rdfs:label "Puerta"@es .

ex:Tornilleria a owl:Class ;
    rdfs:label "Tornillería"@es .

ex:ProcedimientoCambioDeBase a owl:Class ;
    rdfs:label "Procedimiento cambio de base"@es .

ex:ProcedimientoCambioPortaCremalleras a owl:Class ;
    rdfs:label "Procedimiento cambio porta-cremalleras"@es .

ex:PlataformasLaterales a owl:Class ;
    rdfs:label "Plataformas laterales"@es .

ex:tieneTornillos a owl:ObjectProperty ;
    rdfs:domain ex:Plato ;
    rdfs:range ex:Tornillo .

ex:tieneBasePlana a owl:ObjectProperty ;
    rdfs:domain ex:Plato ;
    rdfs:range ex:BasePlana .

ex:tieneGrúa a owl:ObjectProperty ;
    rdfs:domain ex:Plato ;
    rdfs:range ex:Grúa .

ex:tienePlataforma a owl:ObjectProperty ;
    rdfs:domain ex:Plato ;
    rdfs:range ex:Plataforma .

ex:tienePortaBrochas a owl:ObjectProperty ;
    rdfs:domain ex:Columna ;
    rdfs:range ex:PortaBrochas .

ex:tieneEjeVertical a owl:ObjectProperty ;
    rdfs:domain ex:PortaBrochas ;
    rdfs:range ex:EjeVertical .

ex:tieneCarroPortaPiezas a owl:ObjectProperty ;
    rdfs:domain ex:PortaBrochas ;
    rdfs:range ex:CarroPortaPiezas .

ex:tienePuerta a owl:ObjectProperty ;
    rdfs:domain ex:PlataformasLaterales ;
    rdfs:range ex:Puerta .

ex:tieneTornilleria a owl:ObjectProperty ;
    rdfs:domain ex:PlataformasLaterales ;
    rdfs:range ex:Tornilleria .

ex:tieneProcedimientoCambioDeBase a owl:ObjectProperty ;
    rdfs:domain ex:CambioDeBase ;
    rdfs:range ex:ProcedimientoCambioDeBase .

ex:tieneProcedimientoCambioPortaCremalleras a owl:ObjectProperty ;
    rdfs:domain ex:CambioDeBase ;
    rdfs:range ex:ProcedimientoCambioPortaCremalleras .

ex:tienePlataformasLaterales a owl:ObjectProperty ;
    rdfs:domain ex:CambioDeBase ;
    rdfs:range ex:PlataformasLaterales .