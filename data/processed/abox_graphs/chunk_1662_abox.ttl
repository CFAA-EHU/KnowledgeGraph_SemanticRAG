@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Sistema_BusCANopen a ns1:Sistema ;
    rdfs:label "Sistema de bus CANopen para configuración de I/O digitales"@es ;
    ns1:textoExtracto """
La configuración debe cumplir los siguientes requisitos. Si la parametrización no se ajusta a estos requisitos, el CNC la ignora y numera las entradas digitales secuencialmente, según el orden en que se encuentren los módulos en el bus.
• Se deben parametrizar todos los nodos de I/Os del bus; no se pueden dejar nodos sin definir.
• Se deben parametrizar todos los recursos de un nodo; no se pueden dejar I/Os sin numerar.
• El máximo número de bloques lógicos en el nodo será 64, tanto para entradas como para salidas digitales.
• El número de I/Os de un bloque lógico no puede ser cero, y debe ser un múltiplo de 8.
• Los valores del índice base deben cumplir con la fórmula "8n + 1" (es decir, 1, 9, 17, 25 ...).
• Los bloques se pueden distribuir como se desee dentro del rango de recursos gestionados por PLC (1...1024).
"""@es ;
    ns1:tieneComponente ns1:Parametro_ADDRESS,
        ns1:Parametro_BLOCK,
        ns1:Parametro_DIMODADDR,
        ns1:Parametro_MNEMONIC,
        ns1:Parametro_NDI,
        ns1:Parametro_NDIMOD,
        ns1:Parametro_NODE .

ns1:Parametro_ADDRESS a ns1:Parametro ;
    rdfs:label "ADDRESS" ;
    ns1:documentadoEn ns1:Tabla_ParametrosCANopen_1401 ;
    ns1:identificador "ADDRESS" ;
    ns1:textoExtracto "Dirección base del bloque lógico. Valores posibles: De 1 a 1017 (por defecto; el primer valor válido)."@es .

ns1:Parametro_BLOCK a ns1:Parametro ;
    rdfs:label "BLOCK" ;
    ns1:documentadoEn ns1:Tabla_ParametrosCANopen_1401 ;
    ns1:identificador "BLOCK" ;
    ns1:textoExtracto "Número de bloque lógico. Valores posibles: De 1 a 64 (por defecto; 0)."@es ;
    ns1:valor 0 .

ns1:Parametro_DIMODADDR a ns1:Parametro ;
    rdfs:label "DIMODADDR" ;
    ns1:documentadoEn ns1:Tabla_ParametrosCANopen_1401 ;
    ns1:identificador "DIMODADDR" ;
    ns1:textoExtracto "Direcciones base de los bloques lógicos de entradas digitales."@es .

ns1:Parametro_MNEMONIC a ns1:Parametro ;
    rdfs:label "MNEMONIC" ;
    ns1:documentadoEn ns1:Tabla_ParametrosCANopen_1401 ;
    ns1:identificador "MNEMONIC" ;
    ns1:textoExtracto "Mnemónico del bloque lógico."@es .

ns1:Parametro_NDI a ns1:Parametro ;
    rdfs:label "NDI" ;
    ns1:documentadoEn ns1:Tabla_ParametrosCANopen_1401 ;
    ns1:identificador "NDI" ;
    ns1:textoExtracto "Número de entradas digitales del módulo. Valores posibles: De 8 a 1024 (por defecto; 0)."@es ;
    ns1:valor 0 .

ns1:Parametro_NDIMOD a ns1:Parametro ;
    rdfs:label "NDIMOD" ;
    ns1:documentadoEn ns1:Tabla_ParametrosCANopen_1401 ;
    ns1:identificador "NDIMOD" ;
    ns1:textoExtracto "Número de bloques lógicos de entradas digitales. Valores posibles: De 0 a 42 (por defecto; 0)."@es ;
    ns1:valor 0 .

ns1:Parametro_NODE a ns1:Parametro ;
    rdfs:label "NODE" ;
    ns1:documentadoEn ns1:Tabla_ParametrosCANopen_1401 ;
    ns1:identificador "NODE" ;
    ns1:textoExtracto "Número de nodo de la cabecera al que pertenece el bloque lógico. Valores posibles: De 1 a 126 (por defecto; 0)."@es ;
    ns1:valor 0 .

ns1:Tabla_ParametrosCANopen_1401 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros para configuración de entradas/salidas digitales en bus CANopen (pág. 680-681)"@es ;
    ns1:textoExtracto """
| Parámetro. | Significado. |
| --- | --- |
| NDIMOD | Número de bloques lógicos de entradas digitales. Valores posibles: De 0 a 42 (por defecto; 0). |
| DIMODADDR | Direcciones base de los bloques lógicos de entradas digitales. |
| MNEMONIC | Mnemónico del bloque lógico. |
| NODE | Número de nodo de la cabecera al que pertenece el bloque lógico. Valores posibles: De 1 a 126 (por defecto; 0). |
| BLOCK | Número de bloque lógico. Valores posibles: De 1 a 64 (por defecto; 0). |
| ADDRESS | Dirección base del bloque lógico. Valores posibles: De 1 a 1017 (por defecto; el primer valor válido). |
| NDI | Número de entradas digitales del módulo. Valores posibles: De 8 a 1024 (por defecto; 0).
"""@es .

