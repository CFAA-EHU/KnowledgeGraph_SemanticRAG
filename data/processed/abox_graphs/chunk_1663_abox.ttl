@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BusCANopen_1402 a ns1:Sistema ;
    rdfs:label "Bus CANopen" ;
    ns1:textoExtracto "Configurar las salidas digitales. [...] una entrada o salida digital de PLC sólo puede pertenecer a un único nodo-módulo del bus." ;
    ns1:tieneComponente ns1:NodoModulo_1402 .

ns1:PLC_1402 a ns1:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ns1:textoExtracto "El PLC admite huecos, pero nunca solapamiento entre los diferentes bloques; es decir, una entrada o salida digital de PLC sólo puede pertenecer a un único nodo-módulo del bus." .

ns1:EntradaSalidaDigital_1402 a ns1:ComponenteElectrico ;
    rdfs:label "Entradas y salidas digitales" ;
    ns1:monitoreaParametro ns1:ParametrosMaquina_1402 ;
    ns1:textoExtracto "Las entradas y salidas digitales se configuran desde los parámetros máquina." .

ns1:NodoModulo_1402 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo-módulo del bus CANopen" ;
    ns1:controla ns1:EntradaSalidaDigital_1402 ;
    ns1:textoExtracto "una entrada o salida digital de PLC sólo puede pertenecer a un único nodo-módulo del bus." .

ns1:ParametrosMaquina_1402 a ns1:Parametro ;
    rdfs:label "Parámetros máquina para configuración de E/S digitales" ;
    ns1:textoExtracto "Las entradas y salidas digitales se configuran desde los parámetros máquina." .

