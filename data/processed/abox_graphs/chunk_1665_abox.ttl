@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PLC_1404 a ns1:Sistema ;
    rdfs:label "PLC (controlador lógico programable)"@es ;
    ns1:identificador "1...1024" ;
    ns1:textoExtracto "El PLC admite huecos, pero nunca solapamiento entre los diferentes bloques; es decir, una entrada o salida digital de PLC sólo puede pertenecer a un único nodo-módulo del bus."@es ;
    ns1:tieneComponente ns1:NodoModulo_CANopen_1404 .

ns1:EntradaDigital_CANopen_1404 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada digital del bus CANopen"@es ;
    ns1:textoExtracto "entrada [...] digital de PLC"@es .

ns1:NodoModulo_CANopen_1404 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo-módulo del bus CANopen"@es ;
    ns1:compuestoPor ns1:EntradaDigital_CANopen_1404,
        ns1:SalidaDigital_CANopen_1404 ;
    ns1:textoExtracto "una entrada o salida digital de PLC sólo puede pertenecer a un único nodo-módulo del bus."@es .

ns1:SalidaDigital_CANopen_1404 a ns1:ComponenteElectrico ;
    rdfs:label "Salida digital del bus CANopen"@es ;
    ns1:textoExtracto "salida digital de PLC"@es .

