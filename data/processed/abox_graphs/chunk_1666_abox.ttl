@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CANopen_1405 a ns1:Sistema ;
    rdfs:label "Bus CANopen con nodos RIO5"@es ;
    ns1:textoExtracto "Ejemplo 1. Un bus CANopen dispone de los siguientes grupos remotos."@es ;
    ns1:tieneComponente ns1:Nodo_1_1405,
        ns1:Nodo_2_1405,
        ns1:Nodo_3_1405 .

ns1:Modulo_24ED_Nodo1_1405 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de 24 entradas digitales (Nodo 1)"@es ;
    ns1:textoExtracto "1 módulos de 24 entradas digitales"@es .

ns1:Modulo_24ED_Nodo2_1_1405 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de 24 entradas digitales 1 (Nodo 2)"@es ;
    ns1:textoExtracto "3 módulos de 24 entradas digitales cada uno"@es .

ns1:Modulo_24ED_Nodo2_2_1405 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de 24 entradas digitales 2 (Nodo 2)"@es ;
    ns1:textoExtracto "3 módulos de 24 entradas digitales cada uno"@es .

ns1:Modulo_24ED_Nodo2_3_1405 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de 24 entradas digitales 3 (Nodo 2)"@es ;
    ns1:textoExtracto "3 módulos de 24 entradas digitales cada uno"@es .

ns1:Modulo_24ED_Nodo3_1_1405 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de 24 entradas digitales 1 (Nodo 3)"@es ;
    ns1:textoExtracto "2 módulos de 24 entradas digitales cada uno"@es .

ns1:Modulo_24ED_Nodo3_2_1405 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de 24 entradas digitales 2 (Nodo 3)"@es ;
    ns1:textoExtracto "2 módulos de 24 entradas digitales cada uno"@es .

ns1:Nodo_1_1405 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo 1 (Grupo remoto RIO5)"@es ;
    ns1:identificador "Nodo 1" ;
    ns1:textoExtracto "Nodo 1: Grupo remoto RIO5 con 1 módulos de 24 entradas digitales."@es ;
    ns1:tieneComponente ns1:Modulo_24ED_Nodo1_1405 .

ns1:Nodo_2_1405 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo 2 (Grupo remoto RIO5)"@es ;
    ns1:identificador "Nodo 2" ;
    ns1:textoExtracto "Nodo 2: Grupo remoto RIO5 con 3 módulos de 24 entradas digitales cada uno."@es ;
    ns1:tieneComponente ns1:Modulo_24ED_Nodo2_1_1405,
        ns1:Modulo_24ED_Nodo2_2_1405,
        ns1:Modulo_24ED_Nodo2_3_1405 .

ns1:Nodo_3_1405 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo 3 (Grupo remoto RIO5)"@es ;
    ns1:identificador "Nodo 3" ;
    ns1:textoExtracto "Nodo 3: Grupo remoto RIO5 con 2 módulos de 24 entradas digitales cada uno."@es ;
    ns1:tieneComponente ns1:Modulo_24ED_Nodo3_1_1405,
        ns1:Modulo_24ED_Nodo3_2_1405 .

