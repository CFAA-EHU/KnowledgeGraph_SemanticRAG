@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_DIMODADDR_RIO5 a ns1:Parametro ;
    rdfs:label "DIMODADDR"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionRIO5_1407 ;
    ns1:textoExtracto "DIMODADDR | - - - | Ver tabla inferior."@es .

ns1:Parametro_NDIMOD_RIO5 a ns1:Parametro ;
    rdfs:label "NDIMOD"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionRIO5_1407 ;
    ns1:textoExtracto "NDIMOD | 6 | En la serie RIO5, cada módulo se debe configurar como un bloque lógico."@es ;
    ns1:valor "6" .

ns1:Sistema_RIO5_Modulo1 a ns1:Sistema ;
    rdfs:label "Primer nodo RIO5 (bloque de 24 entradas desde I1)"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_ConfiguracionRIO5_1407 ;
    ns1:textoExtracto "El primer nodo RIO5 como un bloque de 24 entradas a partir de la I1."@es .

ns1:Sistema_RIO5_Modulo2 a ns1:Sistema ;
    rdfs:label "Segundo nodo RIO5 (tres bloques de 24 entradas desde I49, I73, I97)"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_ConfiguracionRIO5_1407 ;
    ns1:textoExtracto "El segundo nodo RIO5 como tres bloques de 24 entradas a partir de la I49, I73 e I97."@es .

ns1:Sistema_RIO5_Modulo3 a ns1:Sistema ;
    rdfs:label "Tercer nodo RIO5 (dos bloques de 24 entradas desde I257, I129)"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_ConfiguracionRIO5_1407 ;
    ns1:textoExtracto "El tercer nodo RIO5 como dos bloques de 24 entradas a partir de la I257 e I129."@es .

ns1:Tabla_ConfiguracionRIO5_1407 a ns1:Tabla ;
    rdfs:label "Tabla de configuración de módulos RIO5"@es ;
    ns1:identificador "15.5.1 Ejemplo. Numeración de I/Os" ;
    ns1:textoExtracto "NDIMOD | 6 | En la serie RIO5, cada módulo se debe configurar como un bloque lógico. Cada módulo doble (módulo con dos placas) cuenta como dos bloques."@es .

