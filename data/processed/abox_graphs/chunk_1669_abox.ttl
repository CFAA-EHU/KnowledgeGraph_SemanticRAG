@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BusCANopen_Ejemplo2 a ns1:Sistema ;
    rdfs:label "Bus CANopen (Ejemplo 2)" ;
    ns1:compuestoPor ns1:Parametro_DIMODADDR_Ejemplo2,
        ns1:Parametro_DOMODADDR_Ejemplo2,
        ns1:Parametro_NDIMOD_Ejemplo2,
        ns1:Parametro_NDOMOD_Ejemplo2 ;
    ns1:textoExtracto "Ejemplo 2. Un bus CANopen dispone de los siguientes grupos remotos." ;
    ns1:tieneComponente ns1:Nodo1_RIOW_Ejemplo2,
        ns1:Nodo2_RIOW_Ejemplo2 .

ns1:BusCANopen_Ejemplo3 a ns1:Sistema ;
    rdfs:label "Bus CANopen (Ejemplo 3)" ;
    ns1:textoExtracto "Ejemplo 3. Un bus CANopen dispone de los siguientes grupos remotos." ;
    ns1:tieneComponente ns1:Nodo1_RIOR_Ejemplo3,
        ns1:Nodo2_RIOR_Ejemplo3 .

ns1:BloqueEntradas1_Nodo1_Ejemplo2 a ns1:ComponenteElectrico ;
    rdfs:label "Bloque de 8 entradas digitales (I1-I32, Nodo 1)" ;
    ns1:identificador "I1-I32" ;
    ns1:textoExtracto "El primer nodo RIOW como 2 bloques, uno de 8 entradas a partir de la I1" .

ns1:BloqueEntradas2_Nodo1_Ejemplo2 a ns1:ComponenteElectrico ;
    rdfs:label "Bloque de 8 entradas digitales (I33-I64, Nodo 1)" ;
    ns1:identificador "I33-I64" ;
    ns1:textoExtracto "el resto a partir de I33" .

ns1:BloqueEntradas_Nodo2_Ejemplo2 a ns1:ComponenteElectrico ;
    rdfs:label "Bloque de 8 entradas digitales (I113-I120, Nodo 2)" ;
    ns1:identificador "I113-I120" ;
    ns1:textoExtracto "un bloque de 8 entradas a partir de la I113" .

ns1:BloqueSalidas_Nodo1_Ejemplo2 a ns1:ComponenteElectrico ;
    rdfs:label "Bloque de 8 salidas digitales (O81-O88, Nodo 1)" ;
    ns1:identificador "O81-O88" ;
    ns1:textoExtracto "un bloque de 8 salidas a partir de la O81" .

ns1:BloqueSalidas_Nodo2_Ejemplo2 a ns1:ComponenteElectrico ;
    rdfs:label "Bloque de 8 salidas digitales (O49-O56, Nodo 2)" ;
    ns1:identificador "O49-O56" ;
    ns1:textoExtracto "un bloque de 8 salidas a partir de O49" .

ns1:Nodo1_RIOR_Ejemplo3 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo 1 (Grupo remoto RIOR)" ;
    ns1:identificador "Nodo 1" ;
    ns1:textoExtracto "Nodo 1: Grupo remoto RIOR con 48 entradas y 32 salidas digitales." .

ns1:Nodo1_RIOW_Ejemplo2 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo 1 (Grupo remoto RIOW)" ;
    ns1:identificador "Nodo 1" ;
    ns1:textoExtracto "Nodo 1: Grupo remoto RIOW con 16 entradas y 8 salidas digitales." ;
    ns1:tieneComponente ns1:BloqueEntradas1_Nodo1_Ejemplo2,
        ns1:BloqueEntradas2_Nodo1_Ejemplo2,
        ns1:BloqueSalidas_Nodo1_Ejemplo2 .

ns1:Nodo2_RIOR_Ejemplo3 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo 2 (Grupo remoto RIOR)" ;
    ns1:identificador "Nodo 2" ;
    ns1:textoExtracto "Nodo 2: Grupo remoto RIOR con 48 entradas y 32 salidas digitales." .

ns1:Nodo2_RIOW_Ejemplo2 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo 2 (Grupo remoto RIOW)" ;
    ns1:identificador "Nodo 2" ;
    ns1:textoExtracto "Nodo 2: Grupo remoto RIOW con 8 entradas y 8 salidas digitales." ;
    ns1:tieneComponente ns1:BloqueEntradas_Nodo2_Ejemplo2,
        ns1:BloqueSalidas_Nodo2_Ejemplo2 .

ns1:Parametro_DIMODADDR_Ejemplo2 a ns1:Parametro ;
    rdfs:label "DIMODADDR (Direcciones de bloques de entrada)" ;
    ns1:identificador "DIMODADDR" ;
    ns1:textoExtracto "DIMODADDR | - - - | Ver tabla inferior." .

ns1:Parametro_DOMODADDR_Ejemplo2 a ns1:Parametro ;
    rdfs:label "DOMODADDR (Direcciones de bloques de salida)" ;
    ns1:identificador "DOMODADDR" ;
    ns1:textoExtracto "DOMODADDR | - - - | Ver tabla inferior." .

ns1:Parametro_NDIMOD_Ejemplo2 a ns1:Parametro ;
    rdfs:label "NDIMOD (Número de bloques de entrada)" ;
    ns1:identificador "NDIMOD" ;
    ns1:textoExtracto "NDIMOD | 3 | 3 bloques; 2 para el primer nodo y 1 para el segundo." ;
    ns1:valor "3" .

ns1:Parametro_NDOMOD_Ejemplo2 a ns1:Parametro ;
    rdfs:label "NDOMOD (Número de bloques de salida)" ;
    ns1:identificador "NDOMOD" ;
    ns1:textoExtracto "NDOMOD | 2 | 2 bloques, uno para cada nodo RIOW." ;
    ns1:valor "2" .

