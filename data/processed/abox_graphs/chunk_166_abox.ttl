@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Figura4_13 a ns1:Figura ;
    ns1:ilustradoEn ns1:Manual ;
    ns1:textoExtracto "Sección frontal con codificación ROJO (tornillería superior a retirar) y AZUL (resto de tornillería). Flechas verticales y textos laterales describen la extracción del porta-cremalleras con cáncamos y grúa." .

ns1:Figura4_14 a ns1:Figura ;
    ns1:ilustradoEn ns1:Manual ;
    ns1:textoExtracto "Dos vistas: a la izquierda, el conjunto sobre el carro; a la derecha, módulo con cilindro y cepillos. Rótulos BQ740/BQ741 reflejan estados Avanzado/Retrocedido." .

ns1:Figura4_15 a ns1:Figura ;
    ns1:ilustradoEn ns1:Manual ;
    ns1:textoExtracto "Fotografía del armario neumático con etiquetas a YP801 (entrada), YP901/YP902 (avance/retroceso cepillo), YP903 (refrigerante), BP710/BP711 (presiones). Flechas y recuadros organizan flujos y funciones." .

ns1:Figura4_16 a ns1:Figura ;
    ns1:ilustradoEn ns1:Manual ;
    ns1:textoExtracto "Detalle con engrase automático (central + piñón aplicador) y engrase manual. Se evidencian depósitos, líneas y el piñón de espuma para lubricación continua del dentado." .

ns1:Figura4_17 a ns1:Figura ;
    ns1:ilustradoEn ns1:Manual ;
    ns1:textoExtracto "Conjunto sobre bancada con M6 (motor), BL726 (nivel), YP802/YP803 (mesa arriba/abajo), YP900 (freno), BP714/BP727 (presión). Flechas rojas y rótulos guían funciones y puntos de medida." .

