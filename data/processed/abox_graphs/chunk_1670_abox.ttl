@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Nodo1_RIOR a ns1:ComponenteElectrico ;
    rdfs:label "Nodo 1 (RIOR)" ;
    ns1:identificador "Nodo 1" ;
    ns1:textoExtracto "Nodo 1: Grupo remoto RIOR con 48 entradas y 32 salidas digitales." ;
    ns1:tieneComponente ns1:BloqueEntradas_Nodo1_RIOR,
        ns1:BloqueSalidas_Nodo1_RIOR .

ns1:Nodo2_RIOR a ns1:ComponenteElectrico ;
    rdfs:label "Nodo 2 (RIOR)" ;
    ns1:identificador "Nodo 2" ;
    ns1:textoExtracto "Nodo 2: Grupo remoto RIOR con 48 entradas y 32 salidas digitales." ;
    ns1:tieneComponente ns1:BloqueEntradas1_Nodo2_RIOR,
        ns1:BloqueEntradas2_Nodo2_RIOR,
        ns1:BloqueEntradas3_Nodo2_RIOR,
        ns1:BloqueSalidas_Nodo2_RIOR .

ns1:BloqueEntradas1_Nodo2_RIOR a ns1:ComponenteElectrico ;
    rdfs:label "Bloque 1 de 48 entradas (Nodo 2 RIOR)" ;
    ns1:identificador "I97-I144" ;
    ns1:textoExtracto "El segundo nodo RIOR como tres bloques de 48 entradas a partir de la I97." .

ns1:BloqueEntradas2_Nodo2_RIOR a ns1:ComponenteElectrico ;
    rdfs:label "Bloque 2 de 48 entradas (Nodo 2 RIOR)" ;
    ns1:identificador "I145-I192" ;
    ns1:textoExtracto "El segundo nodo RIOR como tres bloques de 48 entradas a partir de la I97." .

ns1:BloqueEntradas3_Nodo2_RIOR a ns1:ComponenteElectrico ;
    rdfs:label "Bloque 3 de 48 entradas (Nodo 2 RIOR)" ;
    ns1:identificador "I193-I240" ;
    ns1:textoExtracto "El segundo nodo RIOR como tres bloques de 48 entradas a partir de la I97." .

ns1:BloqueEntradas_Nodo1_RIOR a ns1:ComponenteElectrico ;
    rdfs:label "Bloque de 48 entradas (Nodo 1 RIOR)" ;
    ns1:identificador "I1-I48" ;
    ns1:textoExtracto "El primer nodo RIOR como un bloque de 48 entradas a partir de la I1." .

ns1:BloqueSalidas_Nodo1_RIOR a ns1:ComponenteElectrico ;
    rdfs:label "Bloque de 32 salidas (Nodo 1 RIOR)" ;
    ns1:identificador "O1-O32" ;
    ns1:textoExtracto "También un bloque de 32 salidas a partir de la O1." .

ns1:BloqueSalidas_Nodo2_RIOR a ns1:ComponenteElectrico ;
    rdfs:label "Bloque de 32 salidas (Nodo 2 RIOR)" ;
    ns1:identificador "O81-O112" ;
    ns1:textoExtracto "También un bloque de 32 salidas a partir de la O81." .

