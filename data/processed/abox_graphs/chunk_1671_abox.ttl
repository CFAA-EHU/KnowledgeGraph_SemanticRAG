@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_DIMODADDR a ns1:Parametro ;
    rdfs:label "DIMODADDR"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosNDIMOD_DIMODADDR ;
    ns1:identificador "DIMODADDR" ;
    ns1:textoExtracto "DIMODADDR | - - - | Ver tabla inferior."@es .

ns1:Parametro_DOMODADDR a ns1:Parametro ;
    rdfs:label "DOMODADDR"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosNDOMOD_DOMODADDR ;
    ns1:identificador "DOMODADDR" ;
    ns1:textoExtracto "DOMODADDR | - - - | Ver tabla inferior."@es .

ns1:Parametro_NDIMOD a ns1:Parametro ;
    rdfs:label "NDIMOD"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosNDIMOD_DIMODADDR ;
    ns1:identificador "NDIMOD" ;
    ns1:textoExtracto "NDIMOD | 2 | 2 bloques, uno para cada nodo RIOR. En la serie RIOR, cada módulo se debe configurar como un bloque lógico."@es ;
    ns1:valor "2" .

ns1:Parametro_NDOMOD a ns1:Parametro ;
    rdfs:label "NDOMOD"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosNDOMOD_DOMODADDR ;
    ns1:identificador "NDOMOD" ;
    ns1:textoExtracto "NDOMOD | 2 | 2 bloques, uno para cada nodo RIOR. En la serie RIOR, cada módulo se debe configurar como un bloque lógico."@es ;
    ns1:valor "2" .

ns1:Sistema_BusCANopen_Ejemplo4 a ns1:Sistema ;
    rdfs:label "Bus CANopen (Ejemplo 4)"@es ;
    ns1:textoExtracto "Ejemplo 4. Un bus CANopen dispone de los siguientes grupos remotos. • Nodo 1: Grupo remoto RIO5 con 3 módulos de 24 entradas digitales cada uno. • Nodo 2: Grupo remoto RIOW con 64 entradas digitales."@es ;
    ns1:tieneComponente ns1:Nodo1_RIO5,
        ns1:Nodo2_RIOW .

ns1:Modulo_RIO5_1 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo 1 (24 entradas digitales, Nodo RIO5)"@es ;
    ns1:textoExtracto "3 módulos de 24 entradas digitales cada uno"@es .

ns1:Modulo_RIO5_2 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo 2 (24 entradas digitales, Nodo RIO5)"@es ;
    ns1:textoExtracto "3 módulos de 24 entradas digitales cada uno"@es .

ns1:Modulo_RIO5_3 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo 3 (24 entradas digitales, Nodo RIO5)"@es ;
    ns1:textoExtracto "3 módulos de 24 entradas digitales cada uno"@es .

ns1:Nodo1_RIO5 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo 1 (Grupo remoto RIO5)"@es ;
    ns1:compuestoPor ns1:Modulo_RIO5_1,
        ns1:Modulo_RIO5_2,
        ns1:Modulo_RIO5_3 ;
    ns1:identificador "RIO5" ;
    ns1:textoExtracto "Nodo 1: Grupo remoto RIO5 con 3 módulos de 24 entradas digitales cada uno."@es .

ns1:Nodo2_RIOW a ns1:ComponenteElectrico ;
    rdfs:label "Nodo 2 (Grupo remoto RIOW)"@es ;
    ns1:identificador "RIOW" ;
    ns1:textoExtracto "Nodo 2: Grupo remoto RIOW con 64 entradas digitales."@es .

ns1:Tabla_ParametrosNDIMOD_DIMODADDR a ns1:Tabla ;
    rdfs:label "Tabla de parámetros NDIMOD y DIMODADDR"@es ;
    ns1:textoExtracto """
| Parámetro. | Valor. | Comentario. |
| --- | --- | --- |
| NDIMOD | 2 | 2 bloques, uno para cada nodo RIOR. En la serie RIOR, cada módulo se debe configurar como un bloque lógico. |
| DIMODADDR | - - - | Ver tabla inferior. |
""" .

ns1:Tabla_ParametrosNDOMOD_DOMODADDR a ns1:Tabla ;
    rdfs:label "Tabla de parámetros NDOMOD y DOMODADDR"@es ;
    ns1:textoExtracto """
| Parámetro. | Valor. | Comentario. |
| --- | --- | --- |
| NDOMOD | 2 | 2 bloques, uno para cada nodo RIOR. En la serie RIOR, cada módulo se debe configurar como un bloque lógico. |
| DOMODADDR | - - - | Ver tabla inferior. |
""" .

