@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Esquema_ConexionI_O a ns1:Esquema ;
    rdfs:label "Esquema de conexión I/O (Ejemplo 4)" ;
    ns1:detalladoEnEsquema ns1:BusCANopen_Ejemplo4 ;
    ns1:textoExtracto "POW X1 SP ADD 9AB 8 765 L C X2 X3 | ER 24I/16O CHS O+214V GND +24V X4 GON8D O+294V X5 EED10 GON16D 4 0 RESS CD 3 E 2F1 ERR I1 RUN X6 T 10 AN GLS ND SHH I 1 2 H I 1 3 GLS ND SHH H X7 I24 | DIGIT +2O4V1 X1 GNOD8 +2O4V9 X2 GON1D6 I1 X3 I12 I13 X4 I24 | AL IN/OUT O+214V X5 GON8D O+294V X6 GON16D I1 X7 I12 I13 X8 I24" .

ns1:ModuloEntradasDigitales_RIOW a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de 64 entradas digitales (RIOW)" ;
    ns1:textoExtracto "Grupo remoto RIOW con 64 entradas digitales." ;
    ns1:valor 64 .

ns1:BusCANopen_Ejemplo4 a ns1:Sistema ;
    rdfs:label "Bus CANopen (Ejemplo 4)" ;
    ns1:identificador "Ejemplo 4" ;
    ns1:textoExtracto "Ejemplo 4. Un bus CANopen dispone de los siguientes grupos remotos." ;
    ns1:tieneComponente ns1:Nodo1_RIO5,
        ns1:Nodo2_RIOW .

ns1:ModuloEntradasDigitales_RIO5_1 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de 24 entradas digitales (RIO5, módulo 1)" ;
    ns1:textoExtracto "3 módulos de 24 entradas digitales cada uno." ;
    ns1:valor 24 .

ns1:ModuloEntradasDigitales_RIO5_2 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de 24 entradas digitales (RIO5, módulo 2)" ;
    ns1:textoExtracto "3 módulos de 24 entradas digitales cada uno." ;
    ns1:valor 24 .

ns1:ModuloEntradasDigitales_RIO5_3 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de 24 entradas digitales (RIO5, módulo 3)" ;
    ns1:textoExtracto "3 módulos de 24 entradas digitales cada uno." ;
    ns1:valor 24 .

ns1:Nodo1_RIO5 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo 1 (Grupo remoto RIO5)" ;
    ns1:compuestoPor ns1:ModuloEntradasDigitales_RIO5_1,
        ns1:ModuloEntradasDigitales_RIO5_2,
        ns1:ModuloEntradasDigitales_RIO5_3 ;
    ns1:identificador "RIO5" ;
    ns1:textoExtracto "Nodo 1: Grupo remoto RIO5 con 3 módulos de 24 entradas digitales cada uno." .

ns1:Nodo2_RIOW a ns1:ComponenteElectrico ;
    rdfs:label "Nodo 2 (Grupo remoto RIOW)" ;
    ns1:identificador "RIOW" ;
    ns1:textoExtracto "Nodo 2: Grupo remoto RIOW con 64 entradas digitales." .

