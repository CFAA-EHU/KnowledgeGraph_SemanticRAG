@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_NDIMOD a ns1:Parametro ;
    rdfs:label "NDIMOD" ;
    ns1:identificador "NDIMOD" ;
    ns1:monitoreaParametro ns1:Nodo_RIOW_2 ;
    ns1:textoExtracto "NDIMOD | 5 | 2 bloques para el RIOW y 3 bloques para el RIO5"@es ;
    ns1:valor "5" .

ns1:Tabla_Configuracion_DIMODADDR a ns1:Tabla ;
    rdfs:label "Tabla de direccionamiento DIMODADDR"@es ;
    ns1:documentadoEn ns1:Manual_15_5_1 ;
    ns1:textoExtracto "DIMODADDR | - - - | Ver tabla inferior"@es .

ns1:Bloque_Entradas_I104 a ns1:ComponenteElectrico ;
    rdfs:label "Bloque de 24 entradas (I104-I127)"@es ;
    ns1:identificador "I104-I127" ;
    ns1:textoExtracto "bloque de 24 entradas a partir de la I104"@es .

ns1:Bloque_Entradas_I200 a ns1:ComponenteElectrico ;
    rdfs:label "Bloque de 40 entradas (I200-I239)"@es ;
    ns1:identificador "I200-I239" ;
    ns1:textoExtracto "el resto a partir de I200"@es .

ns1:Nodo_RIOW_2 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo 2 (RIOW)"@es ;
    ns1:identificador "Nodo 2 (RIOW)" ;
    ns1:textoExtracto "Nodo 2 (RIOW) | 64 entradas digitales"@es ;
    ns1:tieneComponente ns1:Bloque_Entradas_I104,
        ns1:Bloque_Entradas_I200 .

