@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:AvisoSeguridad_EntradasPT100 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso: Activación de entradas PT100" ;
    ns1:mitigaRiesgo ns1:Error_CNC_SinSonda ;
    ns1:textoExtracto "Estas entradas están desactivadas por defecto, y sólo se deben activar si tienen una sonda conectada. Así mismo, si la entrada está activa en el parámetro máquina y no hay una sonda conectada el CNC da el error correspondiente." .

ns1:Entrada_AI3_Nodo2 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada PT100 AI3 (nodo 2)" ;
    ns1:identificador "AI3 (address = 2)" ;
    ns1:textoExtracto "Entrada PT100 (AI3) en módulo RIOR (nodo 2)." .

ns1:Entrada_AI5 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada PT100 AI5" ;
    ns1:identificador "AI5" ;
    ns1:textoExtracto "Entrada PT100 (AI5) en módulo RIO5." .

ns1:Entrada_AI6 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada PT100 AI6" ;
    ns1:identificador "AI6" ;
    ns1:textoExtracto "Entrada PT100 (AI6) en módulo RIO5." .

ns1:Parametro_NPT100 a ns1:Parametro ;
    rdfs:label "NPT100" ;
    ns1:identificador "NPT100" ;
    ns1:textoExtracto "NPT100 | Número total de entradas PT100 activas. Valores posibles: De 0 a 10 (por defecto; 0)." ;
    ns1:valor 0 .

ns1:Parametro_PT100 a ns1:Parametro ;
    rdfs:label "PT100" ;
    ns1:identificador "PT100" ;
    ns1:textoExtracto "PT100 | Tabla de entradas PT100 activas." .

ns1:Parametro_PT100_n a ns1:Parametro ;
    rdfs:label "PT100_n" ;
    ns1:identificador "PT100_n" ;
    ns1:textoExtracto "PT100 n | Entrada analógica asociada a la entrada PT100. Valores posibles: De 0 a 32 (por defecto; 0)." ;
    ns1:valor 0 .

ns1:Sistema_ModulosRIO a ns1:Sistema ;
    rdfs:label "Sistema de módulos RIO5 y RIOR" ;
    ns1:compuestoPor ns1:Modulo_RIO5_Nodo1,
        ns1:Modulo_RIOR_Nodo2 ;
    ns1:detalladoEnEsquema ns1:Tabla_EntradasPT100 ;
    ns1:textoExtracto "En un sistema con un módulo RIO5 (nodo 1) y un RIOR (nodo 2), el CNC identifica las entradas analógicas de la siguiente manera." .

ns1:Modulo_RIO5_Nodo1 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RIO5 (nodo 1)" ;
    ns1:identificador "RIO5 (address = 1)" ;
    ns1:textoExtracto "Los módulos RIO5 tienen 6 entradas analógicas; las cuatro entradas analógicas (AI1..AI4) más las dos entradas PT100 (AI5..AI6)." .

ns1:Modulo_RIOR_Nodo2 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RIOR (nodo 2)" ;
    ns1:identificador "RIOR (address = 2)" ;
    ns1:textoExtracto "Los módulos RIOR tienen 4 entradas analógicas; las dos entradas analógicas (AI1..AI2) más las dos entradas PT100 (AI3..AI4)." .

ns1:Tabla_EntradasPT100 a ns1:Tabla ;
    rdfs:label "Tabla de configuración de entradas PT100" ;
    ns1:documentadoEn ns1:Pagina_686 ;
    ns1:textoExtracto "Tabla de entradas PT100 activas." .

