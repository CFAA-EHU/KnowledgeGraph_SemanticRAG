@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC a ns1:Maquina ;
    ns1:textoExtracto "el PLC dispone de las siguientes marcas... Para poder deshabilitar la sonda temporalmente (por ejemplo, en un cambio de cabezal)" ;
    ns1:tieneComponente ns1:ModuloPT100_PrimerModulo,
        ns1:ModuloPT100_SegundoModulo,
        ns1:ParametrosMaquina_PT100 .

ns1:Parametro_NPT100 a ns1:Parametro ;
    rdfs:label "NPT100" ;
    ns1:textoExtracto "NPT100 = 3" ;
    ns1:valor "3" .

ns1:ModuloPT100_PrimerModulo a ns1:ComponenteElectrico ;
    rdfs:label "Primer módulo de entradas PT100" ;
    ns1:textoExtracto "las dos del primer módulo" .

ns1:ModuloPT100_SegundoModulo a ns1:ComponenteElectrico ;
    rdfs:label "Segundo módulo de entradas PT100" ;
    ns1:textoExtracto "la primera del segundo módulo" .

ns1:Parametro_PT100_1 a ns1:Parametro ;
    rdfs:label "PT100 1" ;
    ns1:textoExtracto "PT100 1 = 5" ;
    ns1:valor "5" .

ns1:Parametro_PT100_2 a ns1:Parametro ;
    rdfs:label "PT100 2" ;
    ns1:textoExtracto "PT100 2 = 6" ;
    ns1:valor "6" .

ns1:Parametro_PT100_3 a ns1:Parametro ;
    rdfs:label "PT100 3" ;
    ns1:textoExtracto "PT100 3 = 9" ;
    ns1:valor "9" .

ns1:ParametrosMaquina_PT100 a ns1:InterfazUsuario ;
    rdfs:label "Parámetros máquina para configuración PT100" ;
    ns1:controla ns1:SondaPT100_Entrada5,
        ns1:SondaPT100_Entrada6,
        ns1:SondaPT100_Entrada9 ;
    ns1:textoExtracto "Las entradas PT100 se activan desde los parámetro máquina" .

ns1:SondaPT100_Entrada5 a ns1:Sensor ;
    rdfs:label "Sonda PT100 (dirección 5)" ;
    ns1:monitoreaParametro ns1:Parametro_PT100_1 ;
    ns1:textoExtracto "PT100 1 = 5" .

ns1:SondaPT100_Entrada6 a ns1:Sensor ;
    rdfs:label "Sonda PT100 (dirección 6)" ;
    ns1:monitoreaParametro ns1:Parametro_PT100_2 ;
    ns1:textoExtracto "PT100 2 = 6" .

ns1:SondaPT100_Entrada9 a ns1:Sensor ;
    rdfs:label "Sonda PT100 (dirección 9)" ;
    ns1:monitoreaParametro ns1:Parametro_PT100_3 ;
    ns1:textoExtracto "PT100 3 = 9" .

