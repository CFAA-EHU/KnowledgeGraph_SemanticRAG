@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_ParametrosPT100 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros PT100OFF"@es ;
    ns1:textoExtracto "| Parámetro. | Significado. | --- | --- | PT100OFF1 ꞏꞏ PT100OFF20 | Si el PLC activa una de estas marcas, el CNC deshabilita la sonda correspondiente (parámetro PT100 n)."@es ;
    ns1:tieneComponente ns1:Parametro_PT100OFF1,
        ns1:Parametro_PT100OFF20 .

ns1:Parametro_PT100OFF1 a ns1:Parametro ;
    rdfs:label "PT100OFF1" ;
    ns1:identificador "PT100OFF1" ;
    ns1:textoExtracto "Si el PLC activa una de estas marcas, el CNC deshabilita la sonda correspondiente (parámetro PT100 n)."@es .

ns1:Parametro_PT100OFF20 a ns1:Parametro ;
    rdfs:label "PT100OFF20" ;
    ns1:identificador "PT100OFF20" ;
    ns1:textoExtracto "Si el PLC activa una de estas marcas, el CNC deshabilita la sonda correspondiente (parámetro PT100 n)."@es .

