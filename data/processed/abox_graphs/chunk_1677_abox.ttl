@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Modo_MDI_MDA a ns1:ModoOperacion ;
    rdfs:label "Modo MDI/MDA"@es ;
    ns1:habilitadoPor ns1:Variable_G.ANAI,
        ns1:Variable_G.ANAO ;
    ns1:textoExtracto "Las variables son accesibles desde el programa pieza y desde el modo MDI/MDA."@es .

ns1:ProgramaPieza a ns1:InterfazUsuario ;
    rdfs:label "Programa pieza (CNC)"@es ;
    ns1:habilitadoPor ns1:Variable_G.ANAI,
        ns1:Variable_G.ANAO ;
    ns1:textoExtracto "Las variables son accesibles desde el programa pieza y desde el modo MDI/MDA."@es .

ns1:EntradaAnalogica_n a ns1:Sensor ;
    rdfs:label "Entrada analógica [n] (tensión/temperatura)"@es ;
    ns1:textoExtracto "Tensión en voltios de la entrada analógica [n] o temperatura en décimas de grado si es una sonda de temperatura PT100."@es .

ns1:SalidaAnalogica_n a ns1:ComponenteElectrico ;
    rdfs:label "Salida analógica [n]"@es ;
    ns1:textoExtracto "Tensión en voltios de la salida [n]."@es .

ns1:Tabla_15.6.1_VariablesCNC a ns1:Tabla ;
    rdfs:label "Tabla de variables accesibles del CNC (Sección 15.6.1)"@es ;
    ns1:identificador "15.6.1" ;
    ns1:textoExtracto "Las siguientes variables son accesibles desde el programa pieza y desde el modo MDI/MDA. Para cada una de ellas se indica si el acceso es de lectura (R) o de escritura (W)."@es .

ns1:Variable_G.ANAI a ns1:Parametro ;
    rdfs:label "Variable G.ANAI[n] (entrada analógica)"@es ;
    ns1:documentadoEn ns1:Tabla_15.6.1_VariablesCNC ;
    ns1:monitoreaParametro ns1:EntradaAnalogica_n ;
    ns1:textoExtracto "(V.)G.ANAI[n] | R | Tensión en voltios de la entrada analógica [n] o temperatura en décimas de grado si es una sonda de temperatura PT100. Unidades: Voltios / décimas de grado."@es ;
    ns1:valor "R" .

ns1:Variable_G.ANAO a ns1:Parametro ;
    rdfs:label "Variable G.ANAO[n] (salida analógica)"@es ;
    ns1:controla ns1:SalidaAnalogica_n ;
    ns1:documentadoEn ns1:Tabla_15.6.1_VariablesCNC ;
    ns1:textoExtracto "(V.)G.ANAO[n] | R/W | Tensión en voltios de la salida [n]. Unidades: Voltios."@es ;
    ns1:valor "R/W" .

