@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_LantekExpertInside a ns1:InterfazUsuario ;
    rdfs:label "Interfaz táctil de Lantek Expert Inside" ;
    ns1:textoExtracto "La sencilla interfaz, adecuada para pantallas táctiles, facilita la revisión del corte en tiempo real y las modificaciones a pie de máquina."@es ;
    ns1:tieneComponente ns1:Sistema_LantekExpertInside .

ns1:Maquina_CNC8060 a ns1:Maquina ;
    rdfs:label "CNC 8060 (Fagor)" ;
    ns1:identificador "CNC 8060" ;
    ns1:textoExtracto "modelos CNC 8060 y 8070"@es ;
    ns1:tieneComponente ns1:Sistema_LantekExpertInside .

ns1:Maquina_CNC8070 a ns1:Maquina ;
    rdfs:label "CNC 8070 (Fagor)" ;
    ns1:identificador "CNC 8070" ;
    ns1:textoExtracto "modelos CNC 8060 y 8070"@es ;
    ns1:tieneComponente ns1:Sistema_LantekExpertInside .

ns1:ModoOperacion_NestingAutomatico a ns1:ModoOperacion ;
    rdfs:label "Nesting automático (Lantek Expert Inside)" ;
    ns1:documentadoEn ns1:Manual_CNC8060_8070 ;
    ns1:textoExtracto "nesting automático (el software coloca la piezas en la chapa basándose en sus parámetros de configuración)"@es .

ns1:ModoOperacion_NestingManual a ns1:ModoOperacion ;
    rdfs:label "Nesting manual (Lantek Expert Inside)" ;
    ns1:documentadoEn ns1:Manual_CNC8060_8070 ;
    ns1:textoExtracto "nesting manual (el usuario coloca las piezas en la chapa como le resulte conveniente)"@es .

ns1:Parametro_ConfiguracionNesting a ns1:Parametro ;
    rdfs:label "Parámetros de configuración de nesting" ;
    ns1:documentadoEn ns1:Manual_CNC8060_8070 ;
    ns1:textoExtracto "material, espesor, longitud y anchura de la chapa, márgenes izquierdo/derecho y superior/inferior"@es .

ns1:Software_LantekExpertInside a ns1:Sistema ;
    rdfs:label "Lantek Expert Inside" ;
    ns1:documentadoEn ns1:Manual_CNC8060_8070 ;
    ns1:identificador "Lantek Expert Inside" ;
    ns1:textoExtracto "Fagor Automation y Lantek han colaborado en la integración del software Lantek Expert Inside para los modelos CNC 8060 y 8070. A partir de figuras en formato dxf, dwg o ficheros paramétricos, este software permite distribuirlas en un chapa optimizando el aprovechamiento de la misma, definir la estrategia de entrada/salida (lead-in/lead-out), etc para finalmente generar un programa pieza en lenguaje Fagor."@es .

ns1:TareaMantenimiento_RepeticionPiezas a ns1:TareaMantenimiento ;
    rdfs:label "Repetición de piezas individuales" ;
    ns1:documentadoEn ns1:Manual_CNC8060_8070 ;
    ns1:ejecutadoPor ns1:Personal_OperadorCNC ;
    ns1:textoExtracto "tareas como la repetición de piezas individuales o la reutilización de retales de chapa sin necesidad de procedimientos intermedios"@es .

ns1:Personal_OperadorCNC a ns1:Personal ;
    rdfs:label "Operador de CNC" ;
    ns1:textoExtracto "modificaciones a pie de máquina"@es .

ns1:Manual_CNC8060_8070 a ns1:Manual ;
    rdfs:label "Manual de los modelos CNC 8060 y 8070" ;
    ns1:identificador "CNC 8060/8070" ;
    ns1:textoExtracto "Fagor Automation y Lantek han colaborado en la integración del software Lantek Expert Inside para los modelos CNC 8060 y 8070."@es .

