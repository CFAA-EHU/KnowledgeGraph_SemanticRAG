mec:tieneVistas a owl:ObjectProperty ;
    rdfs:label "tieneVistas" ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:Vista .

mec:tieneSecuencia a owl:ObjectProperty ;
    rdfs:label "tieneSecuencia" ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:Secuencia .

mec:tieneFlechasVerticales a owl:ObjectProperty ;
    rdfs:label "tieneFlechasVerticales" ;
    rdfs:domain ex:Secuencia ;
    rdfs:range ex:Flecha .

mec:tieneCurva a owl:ObjectProperty ;
    rdfs:label "tieneCurva" ;
    rdfs:domain ex:Secuencia ;
    rdfs:range ex:Curva .

mec:tieneVistasFrontal a owl:ObjectProperty ;
