    rdfs:label "tieneMesa" ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:Mesa .

mec:tieneFreno a owl:ObjectProperty ;
    rdfs:label "tieneFreno" ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:Freno .

mec:tienePresion a owl:ObjectProperty ;
    rdfs:label "tienePresion" ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:Presion .

mec:tieneMotor a owl:ObjectProperty ;
    rdfs:label "tieneMotor" ;
    rdfs:domain ex:SistemaRefrigeracion ;
    rdfs:range ex:Motor .

mec:tieneNivel a owl:ObjectProperty ;
    rdfs:label "tieneNivel" ;
    rdfs:domain ex:SistemaRefrigeracion ;
    rdfs:range ex:Nivel .

mec:tienePapel a owl:ObjectProperty ;
    rdfs:label "tienePapel" ;
    rdfs:domain ex:SistemaRefrigeracion ;
    rdfs:range ex:Papel .

mec:tieneCaudal a owl:ObjectProperty ;
    rdfs:label "tieneCaudal" ;
    rdfs:domain ex:SistemaRefrigeracion ;
    rdfs:range ex:Caudal .

mec:tieneArmarioElectrico a owl:ObjectProperty ;
    rdfs:label "tieneArmarioElectrico" ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:ArmarioElectrico .

mec:tienePanelInfografico a owl:ObjectProperty ;
    rdfs:label "tienePanelInfografico" ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:PanelInfografico .

mec:tieneCancamo a owl:ObjectProperty ;
    rdfs:label "tieneCancamo" ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:Cancamo .

mec:tieneGrúa a owl:ObjectProperty ;
    rdfs:label "tieneGrúa" ;
    rdfs:domain ex:Maquina ;
    rdfs:range ex:Grúa .

mec:tieneFlechasRojas a owl:ObjectProperty ;
    rdfs:label "tieneFlechasRojas" ;
