ex:Flecha a owl:Class ;
    rdfs:label "Flecha" .

ex:Rótulo a owl:Class ;
    rdfs:label "Rótulo" .

ex:Foto a owl:Class ;
    rdfs:label "Foto" .

ex:Señaletica a owl:Class ;
    rdfs:label "Señaletica" .

ex:Ventilacion a owl:Class ;
    rdfs:label "Ventilacion" .

ex:Plano a owl:Class ;
    rdfs:label "Plano" .

ex:Iconografia a owl:Class ;
    rdfs:label "Iconografia" .

ex:BloqueTexto a owl:Class ;
    rdfs:label "BloqueTexto" .

ex:Vista a owl:Class ;
