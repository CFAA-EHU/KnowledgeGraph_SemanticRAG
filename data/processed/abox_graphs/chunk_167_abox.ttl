mec:tieneRótulos a owl:ObjectProperty ;
    rdfs:label "tieneRótulos" ;
    rdfs:domain ex:SistemaHidraulico ;
    rdfs:range ex:Rótulo .

mec:tieneFotos a owl:ObjectProperty ;
    rdfs:label "tieneFotos" ;
    rdfs:domain ex:SistemaRefrigeracion ;
    rdfs:range ex:Foto .

mec:tieneSeñaletica a owl:ObjectProperty ;
    rdfs:label "tieneSeñaletica" ;
    rdfs:domain ex:ArmarioElectrico ;
    rdfs:range ex:Señaletica .

mec:tieneVentilacion a owl:ObjectProperty ;
    rdfs:label "tieneVentilacion" ;
    rdfs:domain ex:ArmarioElectrico ;
    rdfs:range ex:Ventilacion .

mec:tienePlanoFrontal a owl:ObjectProperty ;
    rdfs:label "tienePlanoFrontal" ;
    rdfs:domain ex:ArmarioElectrico ;
