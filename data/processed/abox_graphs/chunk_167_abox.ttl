@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix hidraulico: <https://vocab.cfaa.eus/broaching/hidraulico/> .
@prefix refrigeracion: <https://vocab.cfaa.eus/broaching/refrigeracion/> .
@prefix electrico: <https://vocab.cfaa.eus/broaching/electrico/> .
@prefix mecanica: <https://vocab.cfaa.eus/broaching/mecanica/> .
@prefix seguridad: <https://vocab.cfaa.eus/broaching/seguridad/> .
@prefix transporte: <https://vocab.cfaa.eus/broaching/transporte/> .

hidraulico:SistemaHidraulico a owl:Class ;
    rdfs:label "Sistema Hidráulico" ;
    rdfs:comment "Conjunto sobre bancada con componentes hidráulicos" .

hidraulico:Motor a owl:Class ;
    rdfs:label "Motor" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Motor> .

hidraulico:Nivel a owl:Class ;
    rdfs:label "Nivel" .

hidraulico:Mesa a owl:Class ;
    rdfs:label "Mesa" .

hidraulico:Freno a owl:Class ;
    rdfs:label "Freno" .

hidraulico:Presion a owl:Class ;
    rdfs:label "Presión" .

hidraulico:Flecha a owl:Class ;
    rdfs:label "Flecha" ;
    rdfs:comment "Indica funciones y puntos de medida" .

hidraulico:Rotulo a owl:Class ;
    rdfs:label "Rótulo" ;
    rdfs:comment "Guía funciones y puntos de medida" .

refrigeracion:SistemaRefrigeracion a owl:Class ;
    rdfs:label "Sistema de Refrigeración" ;
    rdfs:comment "Circuito de filtración y retorno de aceite de corte" .

refrigeracion:MotorRefrigeracion a owl:Class ;
    rdfs:label "Motor de Refrigeración" .

refrigeracion:NivelRefrigeracion a owl:Class ;
    rdfs:label "Nivel de Refrigeración" .

refrigeracion:PapelFiltro a owl:Class ;
    rdfs:label "Papel de Filtro" .

refrigeracion:Caudal a owl:Class ;
    rdfs:label "Caudal" .

electrico:ArmarioElectrico a owl:Class ;
    rdfs:label "Armario Eléctrico" ;
    rdfs:comment "Gabinete lateral con señalética de alta tensión y ventilación" .

electrico:PlanoFrontal a owl:Class ;
    rdfs:label "Plano Frontal" ;
    rdfs:comment "Contextualiza ubicación y acceso para control/diagnóstico" .

seguridad:PanelInfografico a owl:Class ;
    rdfs:label "Panel Infográfico" ;
    rdfs:comment "Advertencias con iconografía y bloques de texto en rojo" .

seguridad:Iconografia a owl:Class ;
    rdfs:label "Iconografía" ;
    rdfs:comment "STOP, triángulos de peligro" .

seguridad:BloqueTexto a owl:Class ;
    rdfs:label "Bloque de Texto" ;
    rdfs:comment "Jerarquizan riesgos y condiciones de elevación/transporte" .

transporte:Cancamo a owl:Class ;
    rdfs:label "Cáncamo" ;
    rdfs:comment "Posiciones para eslingado" .

transporte:FlechaTransporte a owl:Class ;
    rdfs:label "Flecha de Transporte" ;
    rdfs:comment "Indica posiciones para eslingado" .

transporte:Recuadro a owl:Class ;
    rdfs:label "Recuadro" ;
    rdfs:comment "Ubica accesos y portones" .

transporte:SecuenciaVolteo a owl:Class ;
    rdfs:label "Secuencia de Volteo" ;
    rdfs:comment "Secuencia 1–2–3 con flechas verticales y curva" .

mecanica:VistaMaquina a owl:Class ;
    rdfs:label "Vista de la Máquina" ;
    rdfs:comment "Destaca cáncamos superiores y frontales" .

mecanica:FlechaRoja a owl:Class ;
    rdfs:label "Flecha Roja" ;
    rdfs:comment "Indica posiciones para eslingado" .

mecanica:Acceso a owl:Class ;
    rdfs:label "Acceso" ;
    rdfs:comment "Ubica accesos y portones" .

mecanica:Porton a owl:Class ;
    rdfs:label "Portón" ;
    rdfs:comment "Ubica accesos y portones" .

hidraulico:tieneComponente a owl:ObjectProperty ;
    rdfs:label "tiene componente" ;
    rdfs:domain hidraulico:SistemaHidraulico ;
    rdfs:range owl:Class .

hidraulico:tieneFlecha a owl:ObjectProperty ;
    rdfs:label "tiene flecha" ;
    rdfs:domain hidraulico:SistemaHidraulico ;
    rdfs:range hidraulico:Flecha .

hidraulico:tieneRotulo a owl:ObjectProperty ;
    rdfs:label "tiene rótulo" ;
    rdfs:domain hidraulico:SistemaHidraulico ;
    rdfs:range hidraulico:Rotulo .

refrigeracion:tieneMotor a owl:ObjectProperty ;
    rdfs:label "tiene motor" ;
    rdfs:domain refrigeracion:SistemaRefrigeracion ;
    rdfs:range refrigeracion:MotorRefrigeracion .

refrigeracion:tieneNivel a owl:ObjectProperty ;
    rdfs:label "tiene nivel" ;
    rdfs:domain refrigeracion:SistemaRefrigeracion ;
    rdfs:range refrigeracion:NivelRefrigeracion .

refrigeracion:tienePapelFiltro a owl:ObjectProperty ;
    rdfs:label "tiene papel de filtro" ;
    rdfs:domain refrigeracion:SistemaRefrigeracion ;
    rdfs:range refrigeracion:PapelFiltro .

refrigeracion:tieneCaudal a owl:ObjectProperty ;
    rdfs:label "tiene caudal" ;
    rdfs:domain refrigeracion:SistemaRefrigeracion ;
    rdfs:range refrigeracion:Caudal .

electrico:tienePlanoFrontal a owl:ObjectProperty ;
    rdfs:label "tiene plano frontal" ;
    rdfs:domain electrico:ArmarioElectrico ;
    rdfs:range electrico:PlanoFrontal .

seguridad:tieneIconografia a owl:ObjectProperty ;
    rdfs:label "tiene iconografía" ;
    rdfs:domain seguridad:PanelInfografico ;
    rdfs:range seguridad:Iconografia .

seguridad:tieneBloqueTexto a owl:ObjectProperty ;
    rdfs:label "tiene bloque de texto" ;
    rdfs:domain seguridad:PanelInfografico ;
    rdfs:range seguridad:BloqueTexto .

transporte:tieneCancamo a owl:ObjectProperty ;
    rdfs:label "tiene cáncamo" ;
    rdfs:domain transporte:VistaMaquina ;
    rdfs:range transporte:Cancamo .

transporte:tieneFlechaTransporte a owl:ObjectProperty ;
    rdfs:label "tiene flecha de transporte" ;
    rdfs:domain transporte:VistaMaquina ;
    rdfs:range transporte:FlechaTransporte .

transporte:tieneRecuadro a owl:ObjectProperty ;
    rdfs:label "tiene recuadro" ;
    rdfs:domain transporte:VistaMaquina ;
    rdfs:range transporte:Recuadro .

transporte:tieneSecuenciaVolteo a owl:ObjectProperty ;
    rdfs:label "tiene secuencia de volteo" ;
    rdfs:domain transporte:VistaMaquina ;
    rdfs:range transporte:SecuenciaVolteo .

mecanica:tieneAcceso a owl:ObjectProperty ;
    rdfs:label "tiene acceso" ;
    rdfs:domain mecanica:VistaMaquina ;
    rdfs:range mecanica:Acceso .

mecanica:tienePorton a owl:ObjectProperty ;
    rdfs:label "tiene portón" ;
    rdfs:domain mecanica:VistaMaquina ;
    rdfs:range mecanica:Porton .