@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:ArmarioElectrico a ns1:Sistema ;
    ns1:textoExtracto "Fotografía del gabinete lateral con señalética de alta tensión y ventilación. Plano frontal que contextualiza su ubicación y acceso para control/diagnóstico." .

ns1:FiguraCanamosTransporte a ns1:Figura ;
    ns1:textoExtracto "Vista de la máquina destacando cáncamos superiores y frontales mediante flechas rojas. Indica posiciones para eslingado; recuadros ubican accesos y portones." .

ns1:FiguraVolteoMaquina a ns1:Figura ;
    ns1:textoExtracto "Secuencia 1–2–3 con flechas verticales y curva que ilustran el volteo desde vertical a horizontal con dos grúas; vistas frontal y lateral para claridad espacial." .

ns1:PanelAdvertenciasTransporte a ns1:InterfazUsuario ;
    ns1:textoExtracto "Panel infográfico de advertencias con iconografía (STOP, triángulos de peligro) y bloques de texto en rojo que jerarquizan riesgos y condiciones de elevación/transporte." .

ns1:SistemaHidraulico1 a ns1:Sistema ;
    ns1:textoExtracto "Sistema hidráulico --- Conjunto sobre bancada con M6 (motor), BL726 (nivel), YP802/YP803 (mesa arriba/abajo), YP900 (freno), BP714/BP727 (presión)." ;
    ns1:tieneComponente ns1:MotorM6,
        ns1:NivelBL726,
        ns1:PresionBP714,
        ns1:PresionBP727,
        ns1:YP802,
        ns1:YP803,
        ns1:YP900 .

ns1:SistemaRefrigeracion a ns1:Sistema ;
    ns1:textoExtracto "Sistema de refrigeración --- Dos fotos con recuadros a M1/M3/M4/M5 (motores), BN41/BN42 (niveles), SQ40 (papel) y BC44 (caudal)." ;
    ns1:tieneComponente ns1:BC44,
        ns1:MotorM1,
        ns1:MotorM3,
        ns1:MotorM4,
        ns1:MotorM5,
        ns1:NivelBN41,
        ns1:NivelBN42,
        ns1:SQ40 .

ns1:BC44 a ns1:Sensor ;
    ns1:identificador "BC44" ;
    ns1:textoExtracto "BC44 (caudal)" .

