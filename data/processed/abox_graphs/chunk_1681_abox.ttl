@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Archivo_Apps_ini a ns1:Componente ;
    rdfs:label "Archivo Apps.ini" ;
    ns1:identificador "Apps.ini" ;
    ns1:textoExtracto "En el archivo ..\\MTB\\MMC\\Config\\Apps.ini añadir la línea \"Lantek=c:\\Lantek\\Expert\\Expert.exe\"." .

ns1:Archivo_CNC8070L_bat a ns1:Componente ;
    rdfs:label "Archivo CNC8070L.bat" ;
    ns1:identificador "CNC8070L.bat" ;
    ns1:textoExtracto "El CNC arranca a través de un archivo bat (por ejemplo CNC8070L.bat). En este archivo bat, añadir la línea \"start c:\\Lantek\\Expert\\Expert.exe\"." .

ns1:InterfazUsuario_HMI a ns1:InterfazUsuario ;
    rdfs:label "Interfaz HMI" ;
    ns1:habilitadoPor ns1:Tecla_CUSTOM ;
    ns1:textoExtracto "En los parámetros máquina HMI, configurar la tecla USERKEY como \"Aplicación\" y asignarle el path \"c:\\Lantek\\Expert\\Expert.exe\"." .

ns1:ModoOperacion_Diagnosis a ns1:ModoOperacion ;
    rdfs:label "Modo Diagnosis" ;
    ns1:textoExtracto "Para arrancar el nesting, ir al modo Diagnosis, y en el menú horizontal seleccionar Apps > Lantek." .

ns1:Software_Expert a ns1:Sistema ;
    rdfs:label "Software Lantek Expert" ;
    ns1:identificador "Expert.exe" ;
    ns1:textoExtracto "El software del nesting (Lantek Expert) arranca a través de diferentes configuraciones: archivo bat, tecla USERKEY o selección en el menú Apps." .

ns1:Tecla_CUSTOM a ns1:ComponenteElectrico ;
    rdfs:label "Tecla [CUSTOM]" ;
    ns1:textoExtracto "El software del nesting arranca cuando el usuario pulsa la tecla [CUSTOM]." .

