@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_CNC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz CNC" ;
    ns1:textoExtracto "Para pasar del CNC a la aplicación de nesting: • Si sólo está abierta la aplicación de nesting y el CNC, las teclas [CTRL]+[W] cambian alternativamente de una o otra." ;
    ns1:tieneComponente ns1:Tecla_CTRL_W .

ns1:ModoOperacion_Diagnosis a ns1:ModoOperacion ;
    rdfs:label "Modo Diagnosis" ;
    ns1:textoExtracto "En el modo Diagnosis, en el menú horizontal seleccionar Apps > Lantek (si lo OEM lo ha configurado así)." .

ns1:Tecla_CUSTOM a ns1:ComponenteElectrico ;
    rdfs:label "Tecla [CUSTOM]" ;
    ns1:habilitadoPor ns1:InterfazUsuario_Nesting ;
    ns1:textoExtracto "La tecla [CUSTOM] accede al software de nesting (si lo OEM lo ha configurado así)." .

ns1:InterfazUsuario_Nesting a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de Nesting" ;
    ns1:textoExtracto "Para pasar del CNC a la aplicación de nesting: • Si sólo está abierta la aplicación de nesting y el CNC, las teclas [CTRL]+[W] cambian alternativamente de una o otra." .

ns1:Tecla_CTRL_W a ns1:ComponenteElectrico ;
    rdfs:label "Tecla [CTRL]+[W]" ;
    ns1:textoExtracto "las teclas [CTRL]+[W] cambian alternativamente de una o otra." .

