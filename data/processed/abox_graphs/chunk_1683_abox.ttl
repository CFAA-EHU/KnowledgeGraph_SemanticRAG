@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_ConfiguracionIdioma a ns1:InterfazUsuario ;
    rdfs:label "Configuración de idioma en menú principal" ;
    ns1:documentadoEn ns1:Tabla_IdiomasDisponibles ;
    ns1:textoExtracto "En el botón general, seleccionar uno de los idiomas." .

ns1:Parametro_Language a ns1:Parametro ;
    rdfs:label "Language" ;
    ns1:identificador "Language" ;
    ns1:textoExtracto "<setting name=\"Language\" serializeAs=\"String\"> <value>en</value>" ;
    ns1:valor "en" .

ns1:Parametro_LocalLanguage a ns1:Parametro ;
    rdfs:label "LocalLanguage" ;
    ns1:identificador "LocalLanguage" ;
    ns1:textoExtracto "<setting name=\"LocalLanguage\" serializeAs=\"String\"> <value>zh-CHS</value>" ;
    ns1:valor "zh-CHS" .

ns1:Tabla_IdiomasDisponibles a ns1:Tabla ;
    rdfs:label "Lista de idiomas disponibles" ;
    ns1:textoExtracto "| Código. | Idioma. | ... Cs | Checo. | de | Alemán. | en | Inglés (Reino Unido). | ..." .

