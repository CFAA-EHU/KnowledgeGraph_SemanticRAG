@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_Gap a ns1:Parametro ;
    rdfs:label "GAP" ;
    ns1:identificador "GAP" ;
    ns1:textoExtracto "<GAP{gap}> Opcional (por defecto, el último valor programado). Distancia (gap) a mantener respecto de la superficie. Unidades: Milímetros o pulgadas." ;
    ns1:valor "Distancia a mantener respecto de la superficie" .

