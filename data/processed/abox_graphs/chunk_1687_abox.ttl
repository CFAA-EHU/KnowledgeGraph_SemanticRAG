@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ControlGap a ns1:Sistema ;
    rdfs:label "Sistema de Control del Gap" ;
    ns1:compuestoPor ns1:Comando_CNCEX,
        ns1:Comando_GAPCTRL_OFF,
        ns1:Comando_GAPCTRL_ON ;
    ns1:textoExtracto "Control del gap. Programación desde el PLC." ;
    ns1:tieneComponente ns1:Parametro_Block,
        ns1:Parametro_Channel,
        ns1:Parametro_Condition,
        ns1:Parametro_PlcMark .

ns1:Comando_CNCEX a ns1:InterfazUsuario ;
    rdfs:label "Comando CNCEX" ;
    ns1:identificador "CNCEX" ;
    ns1:textoExtracto "El PLC puede activar el control del gap ejecutando con el comando CNCEX el bloque de CNC correspondiente." .

ns1:Comando_GAPCTRL_OFF a ns1:InterfazUsuario ;
    rdfs:label "Comando GAPCTRL OFF" ;
    ns1:identificador "GAPCTRL OFF" ;
    ns1:textoExtracto "Anular el control del gap. #GAPCTRL OFF" .

ns1:Comando_GAPCTRL_ON a ns1:InterfazUsuario ;
    rdfs:label "Comando GAPCTRL ON" ;
    ns1:identificador "GAPCTRL ON" ;
    ns1:textoExtracto "#GAPCTRL ON [Z, GAP 1], #GAPCTRL ON [Z-11, GAP 2], #GAPCTRL ON [GAP 5], #GAPCTRL ON [Z-10], #GAPCTRL ON" .

ns1:Parametro_Block a ns1:Parametro ;
    rdfs:label "Parámetro block" ;
    ns1:identificador "block" ;
    ns1:textoExtracto "{block} = Bloque a ejecutar." .

ns1:Parametro_Channel a ns1:Parametro ;
    rdfs:label "Parámetro channel" ;
    ns1:identificador "channel" ;
    ns1:textoExtracto "{channel} = Opcional (por defecto, el primer canal). Canal donde el PLC debe ejecutar el bloque." .

ns1:Parametro_Condition a ns1:Parametro ;
    rdfs:label "Parámetro condition" ;
    ns1:identificador "condition" ;
    ns1:textoExtracto "{condition} = Condición para ejecutar el comando CNCEX." .

ns1:Parametro_PlcMark a ns1:Parametro ;
    rdfs:label "Parámetro plc_mark" ;
    ns1:identificador "plc_mark" ;
    ns1:textoExtracto "{plc_mark} = Marca de control. El PLC activa la marca cuando comienza la operación y la mantiene así hasta que finaliza la misma." .

