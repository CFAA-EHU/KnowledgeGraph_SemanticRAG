@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Comando_GAPCTRL_OFF_1427 a ns1:AccionProhibida ;
    rdfs:label "#GAPCTRL OFF"@es ;
    ns1:ejecutadoPor ns1:MaquinaCNC_1427 ;
    ns1:identificador "#GAPCTRL OFF" ;
    ns1:textoExtracto "CNCEX [#GAPCTRL OFF], M123]"@es .

ns1:Comando_GAPCTRL_ON_1427 a ns1:AccionProhibida ;
    rdfs:label "#GAPCTRL ON"@es ;
    ns1:ejecutadoPor ns1:MaquinaCNC_1427 ;
    ns1:identificador "#GAPCTRL ON" ;
    ns1:textoExtracto "CNCEX [#GAPCTRL ON [Z, GAP 2], M123]"@es .

ns1:ControlGap_1427 a ns1:ModoOperacion ;
    rdfs:label "Control de gap (GAPCTRL)"@es ;
    ns1:controla ns1:SensorGap_1427 ;
    ns1:ejecutadoPor ns1:MaquinaCNC_1427 ;
    ns1:monitoreaParametro ns1:Parametro_GAPTOLCANCEL_1427,
        ns1:Parametro_GAPTOL_1427 ;
    ns1:textoExtracto """Tras activar el control de gap, el eje asociado al sensor se mueve al avance programado [...] hasta detectar la pieza con el sensor o bien hasta la cota programada (POS).
        El CNC considera que el bloque de aproximación ha terminado cuando el sensor alcanza el gap con la tolerancia definida en el parámetro máquina GAPTOL.
        Una vez detectada la pieza, el CNC mantendrá el gap definido"""@es .

ns1:Parametro_GAPTOLCANCEL_1427 a ns1:Parametro ;
    rdfs:label "GAPTOLCANCEL"@es ;
    ns1:identificador "GAPTOLCANCEL" ;
    ns1:textoExtracto "dependiendo del parámetro máquina GAPTOLCANCEL [...] si el eje alcanza la cota programada, sin recibir la señal del sensor, el CNC mostrará el error correspondiente o no"@es ;
    ns1:valor "Configuración de cancelación de error por tolerancia (booleano o código de máquina)"@es .

ns1:Parametro_GAPTOL_1427 a ns1:Parametro ;
    rdfs:label "GAPTOL"@es ;
    ns1:identificador "GAPTOL" ;
    ns1:textoExtracto "tolerancia definida en el parámetro máquina GAPTOL"@es ;
    ns1:valor "Tolerancia de detección del gap (unidad implícita en máquina)"@es .

ns1:SensorGap_1427 a ns1:Sensor ;
    rdfs:label "Sensor de detección de gap"@es ;
    ns1:textoExtracto "eje asociado al sensor se mueve [...] hasta detectar la pieza con el sensor [...] cuando el sensor alcanza el gap con la tolerancia definida"@es .

ns1:MaquinaCNC_1427 a ns1:Maquina ;
    rdfs:label "Máquina CNC"@es ;
    ns1:textoExtracto "el CNC mostrará el error correspondiente [...] El CNC considera que el bloque de aproximación ha terminado [...] el CNC mantendrá el gap definido"@es .

