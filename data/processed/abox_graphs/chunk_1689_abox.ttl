@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ControlGap a ns1:Parametro ;
    rdfs:label "control del gap"@es ;
    ns1:textoExtracto "sin control del gap"@es .

ns1:Eje a ns1:ComponenteMecanico ;
    rdfs:label "eje"@es ;
    ns1:textoExtracto "el eje permanecerá parado y sin control del gap hasta que se reanude el movimiento."@es .

ns1:MovimientoAproximacion a ns1:ModoOperacion ;
    rdfs:label "movimiento de aproximación"@es ;
    ns1:textoExtracto "Durante el movimiento de aproximación, el CNC permite detener el movimiento (señales _STOP o _FEEDHOL). En este caso el eje permanecerá parado y sin control del gap hasta que se reanude el movimiento."@es .

ns1:SenalFEEDHOL a ns1:Sensor ;
    rdfs:label "_FEEDHOL"@en ;
    ns1:textoExtracto "señales _STOP o _FEEDHOL"@es .

ns1:SenalSTOP a ns1:Sensor ;
    rdfs:label "_STOP"@en ;
    ns1:textoExtracto "señales _STOP o _FEEDHOL"@es .

