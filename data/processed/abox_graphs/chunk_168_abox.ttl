@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

ex:VolteoMaquina a owl:Class ;
    rdfs:label "VolteoMaquina" ;
    rdfs:comment "Clase que representa el volteo de la máquina" .

ex:Secuencia a owl:Class ;
    rdfs:label "Secuencia" ;
    rdfs:comment "Clase que representa una secuencia de acciones" .

ex:Flecha a owl:Class ;
    rdfs:label "Flecha" ;
    rdfs:comment "Clase que representa una flecha en un diagrama" .

ex:Grúa a owl:Class ;
    rdfs:label "Grúa" ;
    rdfs:comment "Clase que representa una grúa" .

ex:Vista a owl:Class ;
    rdfs:label "Vista" ;
    rdfs:comment "Clase que representa una vista en un plano" .

ex:Plano a owl:Class ;
    rdfs:label "Plano" ;
    rdfs:comment "Clase que representa un plano mecánico" .

ex:Rejilla a owl:Class ;
    rdfs:label "Rejilla" ;
    rdfs:comment "Clase que representa una rejilla en un plano" .

ex:CartelaTecnica a owl:Class ;
    rdfs:label "CartelaTecnica" ;
    rdfs:comment "Clase que representa una cartela técnica en un plano" .

ex:InterruptorGeneral a owl:Class ;
    rdfs:label "InterruptorGeneral" ;
    rdfs:comment "Clase que representa un interruptor general" .

ex:ArmarioElectrico a owl:Class ;
    rdfs:label "ArmarioElectrico" ;
    rdfs:comment "Clase que representa un armario eléctrico" .

ex:LuzPiloto a owl:Class ;
    rdfs:label "LuzPiloto" ;
    rdfs:comment "Clase que representa una luz piloto" .

ex:Marcaje a owl:Class ;
    rdfs:label "Marcaje" ;
    rdfs:comment "Clase que representa un marcaje en un interruptor" .

ex:PanelOperador a owl:Class ;
    rdfs:label "PanelOperador" ;
    rdfs:comment "Clase que representa un panel operador" .

ex:Boton a owl:Class ;
    rdfs:label "Boton" ;
    rdfs:comment "Clase que representa un botón en un panel operador" .

ex:Pupitre a owl:Class ;
    rdfs:label "Pupitre" ;
    rdfs:comment "Clase que representa un pupitre de control" .

ex:Teclado a owl:Class ;
    rdfs:label "Teclado" ;
    rdfs:comment "Clase que representa un teclado de control" .

ex:Tecla a owl:Class ;
    rdfs:label "Tecla" ;
    rdfs:comment "Clase que representa una tecla en un teclado" .

ex:ControlJog a owl:Class ;
    rdfs:label "ControlJog" ;
    rdfs:comment "Clase que representa un control JOG" .

ex:ZonaEstado a owl:Class ;
    rdfs:label "ZonaEstado" ;
    rdfs:comment "Clase que representa una zona de estado en un control" .

ex:tieneSecuencia a owl:ObjectProperty ;
    rdfs:label "tieneSecuencia" ;
    rdfs:comment "Propiedad que relaciona una máquina con una secuencia de acciones" .

ex:tieneFlecha a owl:ObjectProperty ;
    rdfs:label "tieneFlecha" ;
    rdfs:comment "Propiedad que relaciona un diagrama con una flecha" .

ex:tieneGrúa a owl:ObjectProperty ;
    rdfs:label "tieneGrúa" ;
    rdfs:comment "Propiedad que relaciona un volteo con una grúa" .

ex:tieneVista a owl:ObjectProperty ;
    rdfs:label "tieneVista" ;
    rdfs:comment "Propiedad que relaciona un plano con una vista" .

ex:tienePlano a owl:ObjectProperty ;
    rdfs:label "tienePlano" ;
    rdfs:comment "Propiedad que relaciona una máquina con un plano" .

ex:tieneRejilla a owl:ObjectProperty ;
    rdfs:label "tieneRejilla" ;
    rdfs:comment "Propiedad que relaciona un plano con una rejilla" .

ex:tieneCartelaTecnica a owl:ObjectProperty ;
    rdfs:label "tieneCartelaTecnica" ;
    rdfs:comment "Propiedad que relaciona un plano con una cartela técnica" .

ex:tieneInterruptorGeneral a owl:ObjectProperty ;
    rdfs:label "tieneInterruptorGeneral" ;
    rdfs:comment "Propiedad que relaciona un armario eléctrico con un interruptor general" .

ex:tieneLuzPiloto a owl:ObjectProperty ;
    rdfs:label "tieneLuzPiloto" ;
    rdfs:comment "Propiedad que relaciona un interruptor con una luz piloto" .

ex:tieneMarcaje a owl:ObjectProperty ;
    rdfs:label "tieneMarcaje" ;
    rdfs:comment "Propiedad que relaciona un interruptor con un marcaje" .

ex:tienePanelOperador a owl:ObjectProperty ;
    rdfs:label "tienePanelOperador" ;
    rdfs:comment "Propiedad que relaciona una máquina con un panel operador" .

ex:tieneBoton a owl:ObjectProperty ;
    rdfs:label "tieneBoton" ;
    rdfs:comment "Propiedad que relaciona un panel operador con un botón" .

ex:tienePupitre a owl:ObjectProperty ;
    rdfs:label "tienePupitre" ;
    rdfs:comment "Propiedad que relaciona una máquina con un pupitre" .

ex:tieneTeclado a owl:ObjectProperty ;
    rdfs:label "tieneTeclado" ;
    rdfs:comment "Propiedad que relaciona un pupitre con un teclado" .

ex:tieneTecla a owl:ObjectProperty ;
    rdfs:label "tieneTecla" ;
    rdfs:comment "Propiedad que relaciona un teclado con una tecla" .

ex:tieneControlJog a owl:ObjectProperty ;
    rdfs:label "tieneControlJog" ;
    rdfs:comment "Propiedad que relaciona un pupitre con un control JOG" .

ex:tieneZonaEstado a owl:ObjectProperty ;
    rdfs:label "tieneZonaEstado" ;
    rdfs:comment "Propiedad que relaciona un control con una zona de estado" .

ex:tieneClaridadEspacial a owl:DatatypeProperty ;
    rdfs:label "tieneClaridadEspacial" ;
    rdfs:comment "Propiedad que indica la claridad espacial de una vista" .

ex:tieneDimensiones a owl:DatatypeProperty ;
    rdfs:label "tieneDimensiones" ;
    rdfs:comment "Propiedad que indica las dimensiones de una máquina" .

ex:tienePeso a owl:DatatypeProperty ;
    rdfs:label "tienePeso" ;
    rdfs:comment "Propiedad que indica el peso de una máquina" .

ex:tieneAccion a owl:DatatypeProperty ;
    rdfs:label "tieneAccion" ;
    rdfs:comment "Propiedad que indica la acción de un botón" .

ex:tieneFuncion a owl:DatatypeProperty ;
    rdfs:label "tieneFuncion" ;
    rdfs:comment "Propiedad que indica la función de un botón" .

ex:tieneJerarquia a owl:DatatypeProperty ;
    rdfs:label "tieneJerarquia" ;
    rdfs:comment "Propiedad que indica la jerarquía de los mandos en un panel operador" .