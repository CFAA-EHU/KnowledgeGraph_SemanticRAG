@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaConexionSensorGap_1429 a ns1:Esquema ;
    rdfs:label "Esquema eléctrico: Conexión del sensor del gap"@es ;
    ns1:detalladoEnEsquema ns1:EntradaAnalogica_Regulador_1_1429,
        ns1:SensorGap_1429 ;
    ns1:documentadoEn ns1:Pagina_696_1429 ;
    ns1:textoExtracto "Esquema eléctrico. Conexión del sensor a una entrada analógica del regulador Sercos."@es .

ns1:ModuloRemoto_CAN_RIO5_1429 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo remoto CAN RIO5"@es ;
    ns1:textoExtracto "Las entradas analógicas están disponibles en los módulos RIO5 y RIOR."@es ;
    ns1:tieneComponente ns1:EntradaAnalogica_ModuloRIO5_1429 .

ns1:ModuloRemoto_CAN_RIOR_1429 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo remoto CAN RIOR"@es ;
    ns1:textoExtracto "Las entradas analógicas están disponibles en los módulos [...] RIOR."@es ;
    ns1:tieneComponente ns1:EntradaAnalogica_ModuloRIOR_1429 .

ns1:ReguladorSercos_1429 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos"@es ;
    ns1:textoExtracto "entrada del regulador Sercos... Las entradas analógicas del regulador son una opción de hardware; para disponer de ellas, el regulador debe disponer de una interfaz de comunicación con entradas analógicas A1 o SI."@es ;
    ns1:tieneComponente ns1:EntradaAnalogica_Regulador_1_1429,
        ns1:EntradaAnalogica_Regulador_2_1429,
        ns1:InterfazAnalogica_A1_1429,
        ns1:InterfazAnalogica_SI_1429 .

ns1:EntradaAnalogica_ModuloRIO5_1429 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada analógica del módulo RIO5"@es ;
    ns1:textoExtracto "Conexión del sensor a una entrada analógica de los módulos remotos."@es .

ns1:EntradaAnalogica_ModuloRIOR_1429 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada analógica del módulo RIOR"@es ;
    ns1:textoExtracto "Conexión del sensor a una entrada analógica de los módulos remotos."@es .

ns1:EntradaAnalogica_Regulador_2_1429 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada analógica 2 (pines 2 y 3) del regulador Sercos"@es ;
    ns1:identificador "Pines 2 y 3" ;
    ns1:textoExtracto "para utilizar la segunda [entrada], utilizar los pines 2 y 3"@es .

ns1:InterfazAnalogica_A1_1429 a ns1:ComponenteElectrico ;
    rdfs:label "Interfaz analógica A1"@es ;
    ns1:textoExtracto "interfaz de comunicación con entradas analógicas A1"@es .

ns1:InterfazAnalogica_SI_1429 a ns1:ComponenteElectrico ;
    rdfs:label "Interfaz analógica SI"@es ;
    ns1:textoExtracto "interfaz de comunicación con entradas analógicas [...] SI"@es .

ns1:Pagina_696_1429 a ns1:Pagina ;
    rdfs:label "Página 696 (Sección 16.2.1)"@es ;
    ns1:identificador "696" ;
    ns1:textoExtracto "16.2.1 Conexionado del sensor del gap"@es .

ns1:ParametroGap_1429 a ns1:Parametro ;
    rdfs:label "GAPANAINTYPE y GAPANAINID"@es ;
    ns1:identificador "GAPANAINTYPE, GAPANAINID" ;
    ns1:textoExtracto "Utilizar los parámetros máquina GAPANAINTYPE y GAPANAINID para definir en el CNC dónde está la entrada del sensor."@es .

ns1:EntradaAnalogica_Regulador_1_1429 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada analógica 1 (pines 4 y 5) del regulador Sercos"@es ;
    ns1:controla ns1:SensorGap_1429 ;
    ns1:identificador "Pines 4 y 5" ;
    ns1:textoExtracto "El ejemplo utiliza la primera entrada analógica del regulador (pines 4 y 5)"@es .

ns1:SensorGap_1429 a ns1:Sensor ;
    rdfs:label "Sensor del gap"@es ;
    ns1:monitoreaParametro ns1:ParametroGap_1429 ;
    ns1:textoExtracto "La entrada analógica para el sensor..."@es .

