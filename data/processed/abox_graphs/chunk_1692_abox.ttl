@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ControlGap a ns1:Sistema ;
    rdfs:label "Sistema de control del gap en CNC" ;
    ns1:monitoreaParametro ns1:Parametro_GAPMAX,
        ns1:Parametro_GAPMIN,
        ns1:Parametro_GAPTOL ;
    ns1:textoExtracto "Si el gap sobrepasa el rango definido en los parámetros GAPMIN y GAPMAX, el PLC desactiva la marca INPOSGAP. [...] En caso de error, el CNC detiene el movimiento de los ejes respetando la rampa de frenado y controlando el GAP durante la rampa." ;
    ns1:tieneComponente ns1:Parametro_GAPERRORCANCEL,
        ns1:Parametro_GAPMAX,
        ns1:Parametro_GAPMIN,
        ns1:Parametro_GAPTOL,
        ns1:Parametro_GAPTOLCANCEL .

ns1:Tabla_ParametrosGap a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de configuración del gap" ;
    ns1:textoExtracto "Configurar los límites del gap. | Parámetro. | Significado. | --- | GAPMIN | Mínimo valor permitido para el gap... [fragmento truncado para brevedad]..." ;
    ns1:tieneComponente ns1:Parametro_GAPERRORCANCEL,
        ns1:Parametro_GAPMAX,
        ns1:Parametro_GAPMIN,
        ns1:Parametro_GAPTOL,
        ns1:Parametro_GAPTOLCANCEL .

ns1:Parametro_GAPERRORCANCEL a ns1:Parametro ;
    rdfs:label "GAPERRORCANCEL" ;
    ns1:identificador "GAPERRORCANCEL" ;
    ns1:textoExtracto "Este parámetro indica si el CNC debe anular el error de gap fuera del rango, cuando el gap sobrepasa el rango GAPMIN - GAPMAX. Independientemente del valor de este parámetro, el CNC sigue vigilando la marca INPOSGAP." ;
    ns1:valor "control_error_rango" .

ns1:Parametro_GAPTOLCANCEL a ns1:Parametro ;
    rdfs:label "GAPTOLCANCEL" ;
    ns1:identificador "GAPTOLCANCEL" ;
    ns1:textoExtracto "Este parámetro indica si el CNC debe anular el error de gap fuera de tolerancia, cuando el gap supera el margen definido en el parámetro GAPTOL." ;
    ns1:valor "control_error_tolerancia" .

ns1:Parametro_GAPMAX a ns1:Parametro ;
    rdfs:label "GAPMAX" ;
    ns1:identificador "GAPMAX" ;
    ns1:textoExtracto "Máximo valor permitido para el gap; por encima de este valor, el CNC mostrará o no un error según lo definido en el parámetro GAPERRORCANCEL. Este parámetro debe ser inferior a GAPDISTLIMIT." ;
    ns1:valor "valor_máximo_permitido" .

ns1:Parametro_GAPMIN a ns1:Parametro ;
    rdfs:label "GAPMIN" ;
    ns1:identificador "GAPMIN" ;
    ns1:textoExtracto "Mínimo valor permitido para el gap; por debajo de este valor, el CNC mostrará o no un error según lo definido en el parámetro GAPERRORCANCEL." ;
    ns1:valor "valor_mínimo_permitido" .

ns1:Parametro_GAPTOL a ns1:Parametro ;
    rdfs:label "GAPTOL" ;
    ns1:identificador "GAPTOL" ;
    ns1:textoExtracto "Este parámetro define una ventana de posicionamiento, sobre el gap programado, para dar por finalizado el bloque de aproximación." ;
    ns1:valor "tolerancia_posicionamiento" .

