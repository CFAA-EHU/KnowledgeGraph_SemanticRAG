@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionSensorGap a ns1:Sistema ;
    rdfs:label "Configuración del sensor del gap"@es ;
    ns1:textoExtracto "Configurar la entrada analógica a la que está conectado el sensor. [...] Ajustar la señal de colisión del sensor."@es ;
    ns1:tieneComponente ns1:Parametro_GAPANAINID,
        ns1:Parametro_GAPANAINTYPE,
        ns1:Parametro_GAPDISTLIMIT,
        ns1:Parametro_GAPSENSORCH,
        ns1:Parametro_GAPSENSOROFFSET,
        ns1:Parametro_GAPVOLTLIMIT,
        ns1:SensorGap .

ns1:SensorGap a ns1:Sensor ;
    rdfs:label "Sensor del gap"@es ;
    ns1:monitoreaParametro ns1:Parametro_GAPANAINID,
        ns1:Parametro_GAPANAINTYPE,
        ns1:Parametro_GAPDISTLIMIT,
        ns1:Parametro_GAPSENSORCH,
        ns1:Parametro_GAPSENSOROFFSET,
        ns1:Parametro_GAPVOLTLIMIT ;
    ns1:textoExtracto "Configurar la entrada analógica a la que está conectado el sensor."@es .

ns1:Parametro_GAPANAINID a ns1:Parametro ;
    rdfs:label "GAPANAINID"@es ;
    ns1:identificador "GAPANAINID" ;
    ns1:textoExtracto "Este parámetro identifica la entrada analógica donde está conectado el sensor; si remoto CAN, de 1 a 60; si regulador, de 101 a 132 o de 201 a 232. [...] El parámetro se define mediante un número de tres dígitos; el primer dígito indica el número de la entrada analógica a utilizar (1 ó 2) y los dos dígitos siguientes indican la dirección lógica del regulador (de 1 a 32)."@es ;
    ns1:valor "1-60 (CAN) / 101-132 o 201-232 (Sercos)"@es .

ns1:Parametro_GAPANAINTYPE a ns1:Parametro ;
    rdfs:label "GAPANAINTYPE"@es ;
    ns1:identificador "GAPANAINTYPE" ;
    ns1:textoExtracto "Este parámetro indica dónde está ubicada la entrada analógica conectada al sensor; en los módulos remotos CAN o en un regulador Sercos. Se recomienda utilizar una entrada del regulador."@es ;
    ns1:valor "Ubicación de la entrada analógica (módulo remoto CAN o regulador Sercos)"@es .

ns1:Parametro_GAPDISTLIMIT a ns1:Parametro ;
    rdfs:label "GAPDISTLIMIT"@es ;
    ns1:identificador "GAPDISTLIMIT" ;
    ns1:textoExtracto "Distancia que corresponde a señal analógica límite del sensor (parámetro GAPVOLTLIMIT)."@es ;
    ns1:valor "Distancia límite (mm)"@es .

ns1:Parametro_GAPSENSORCH a ns1:Parametro ;
    rdfs:label "GAPSENSORCH"@es ;
    ns1:identificador "GAPSENSORCH" ;
    ns1:textoExtracto "Cambiar el signo de la señal del sensor."@es ;
    ns1:valor "Inversión de polaridad de la señal"@es .

ns1:Parametro_GAPSENSOROFFSET a ns1:Parametro ;
    rdfs:label "GAPSENSOROFFSET"@es ;
    ns1:identificador "GAPSENSOROFFSET" ;
    ns1:textoExtracto "Offset (en milivoltios) a aplicar al sensor desde el CNC. Si se utiliza una entrada analógica Fagor, no es necesario definir este parámetro, ya que todas ellas disponen de un offset propio."@es ;
    ns1:valor "Offset en milivoltios (opcional para entradas Fagor)"@es .

ns1:Parametro_GAPVOLTLIMIT a ns1:Parametro ;
    rdfs:label "GAPVOLTLIMIT"@es ;
    ns1:identificador "GAPVOLTLIMIT" ;
    ns1:textoExtracto "Voltaje (en milivoltios) que corresponde al recorrido límite del sensor (parámetro GAPDISTLIMIT)."@es ;
    ns1:valor "Voltaje límite (mV)"@es .

