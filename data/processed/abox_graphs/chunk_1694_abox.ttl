@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Senal_GAPCOLLISIONMODE a ns1:Parametro ;
    rdfs:label "GAPCOLLISIONMODE" ;
    ns1:identificador "GAPCOLLISION" ;
    ns1:monitoreaParametro ns1:SensorGap ;
    ns1:textoExtracto "El sensor para el control del gap puede disponer de una señal de colisión que se conecta al CNC, y que el PLC la debe gestionar a través de la marca GAPCOLLISION. Si el PLC activa la marca GAPCOLLISION, el CNC mostrará o no un error según lo definido en este parámetro." .

ns1:AvisoColisionGap a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de colisión en el gap" ;
    ns1:textoExtracto "el CNC mostrará o no un error según lo definido en este parámetro. El error no activa la emergencia." .

ns1:SensorGap a ns1:Sensor ;
    rdfs:label "Sensor del gap" ;
    ns1:activaAlarma ns1:AvisoColisionGap ;
    ns1:textoExtracto "El sensor para el control del gap puede disponer de una señal de colisión que se conecta al CNC" .

