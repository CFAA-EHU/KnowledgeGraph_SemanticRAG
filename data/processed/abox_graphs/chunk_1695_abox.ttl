@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:SistemaGapControl a ns1:Sistema ;
    rdfs:label "Sistema de control de posición GAP"@es ;
    ns1:monitoreaParametro ns1:Parametro_GAPGAIN,
        ns1:Parametro_GAPSENSORFILTER ;
    ns1:textoExtracto "GAPCONTROL [...] GAP SENSOR POSITION FEEDBACK LOOP GAP P-GAIN V.G.GAP CUTOF FILTER Ajuste con ayuda del osciloscopio."@es ;
    ns1:tieneComponente ns1:Parametro_FREQUENCY,
        ns1:Parametro_GAPAPPROACHDYN,
        ns1:Parametro_GAPGAIN,
        ns1:Parametro_GAPSENSORFILTER,
        ns1:Parametro_ORDER,
        ns1:Sensor_GAP .

ns1:Parametro_FREQUENCY a ns1:Parametro ;
    rdfs:label "FREQUENCY"@es ;
    ns1:identificador "FREQUENCY" ;
    ns1:textoExtracto "Frecuencia de corte."@es ;
    ns1:valor "30"^^xsd:string .

ns1:Parametro_ORDER a ns1:Parametro ;
    rdfs:label "ORDER"@es ;
    ns1:identificador "ORDER" ;
    ns1:textoExtracto "Orden del filtro."@es ;
    ns1:valor 2 .

ns1:Sensor_GAP a ns1:Sensor ;
    rdfs:label "Sensor de posición GAP"@es ;
    ns1:monitoreaParametro ns1:Parametro_GAPAPPROACHDYN,
        ns1:Parametro_GAPGAIN ;
    ns1:textoExtracto "(V.)G.GAP Valor real del gap, detectado por el sensor."@es .

ns1:Parametro_GAPAPPROACHDYN a ns1:Parametro ;
    rdfs:label "GAPAPPROACHDYN"@es ;
    ns1:identificador "GAPAPPROACHDYN" ;
    ns1:textoExtracto "Respuesta dinámica durante la parte final del movimiento de aproximación a la chapa."@es .

ns1:Parametro_GAPSENSORFILTER a ns1:Parametro ;
    rdfs:label "GAPSENSORFILTER"@es ;
    ns1:identificador "GAPSENSORFILTER" ;
    ns1:textoExtracto "Filtro paso bajo; se recomienda definir un filtro de orden 2 y frecuencia de corte de 30 Hz."@es ;
    ns1:valor "30"^^xsd:string .

ns1:Parametro_GAPGAIN a ns1:Parametro ;
    rdfs:label "GAPGAIN"@es ;
    ns1:identificador "GAPGAIN" ;
    ns1:textoExtracto "Ganancia proporcional aplicada a la señal del sensor, en posición. Para utilizar valores mayores de 0.2 (cercanos a 1) se recomienda utilizar el parámetro GAPSENSORFILTER."@es ;
    ns1:valor "0.2"^^xsd:float .

