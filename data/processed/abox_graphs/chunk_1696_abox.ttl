@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC" ;
    ns1:controla ns1:Parametro_A_GAPCOMP_Z,
        ns1:Parametro_FREQUENCY,
        ns1:Parametro_GAPAPPROACHDYN,
        ns1:Parametro_GAPGAIN,
        ns1:Parametro_G_GAP ;
    ns1:textoExtracto "cuando el CNC ha detectado la señal del sensor" ;
    ns1:tieneComponente ns1:Sensor_Gap .

ns1:Parametro_A_GAPCOMP_Z a ns1:Parametro ;
    rdfs:label "A.GAPCOMP.Z" ;
    ns1:monitoreaParametro ns1:Sensor_Gap ;
    ns1:textoExtracto "V.)A.GAPCOMP.Z Compensación que introduce el control del gap en el eje asociado al sensor para mantener el gap." .

ns1:Parametro_FREQUENCY a ns1:Parametro ;
    rdfs:label "FREQUENCY" ;
    ns1:textoExtracto "Reducir la frecuencia del filtro (parámetro máquina FREQUENCY) para obtener una respuesta más suave." .

ns1:Parametro_GAPAPPROACHDYN a ns1:Parametro ;
    rdfs:label "GAPAPPROACHDYN" ;
    ns1:textoExtracto "Utilizar el parámetro GAPAPPROACHDYN para ajustar el valor de GAPGAIN durante la parte final de aproximación a la chapa, cuando el CNC ha detectado la señal del sensor." .

ns1:Parametro_GAPGAIN a ns1:Parametro ;
    rdfs:label "GAPGAIN" ;
    ns1:textoExtracto "parámetro GAPGAIN" .

ns1:Parametro_G_GAP a ns1:Parametro ;
    rdfs:label "G.GAP" ;
    ns1:monitoreaParametro ns1:Sensor_Gap ;
    ns1:textoExtracto "V.)G.GAP Valor real del gap, detectado por el sensor." .

ns1:Sensor_Gap a ns1:Sensor ;
    rdfs:label "Sensor de gap" ;
    ns1:textoExtracto "Valor real del gap, detectado por el sensor." .

