@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_GAPERRORCANCEL a ns1:Parametro ;
    rdfs:label "GAPERRORCANCEL" ;
    ns1:identificador "GAPERRORCANCEL" ;
    ns1:textoExtracto "Parámetro que define si el CNC mostrará o no un error cuando el gap sobrepasa el rango GAPMIN-GAPMAX." .

ns1:Parametro_GAPTOLCANCEL a ns1:Parametro ;
    rdfs:label "GAPTOLCANCEL" ;
    ns1:identificador "GAPTOLCANCEL" ;
    ns1:textoExtracto "Parámetro que define si el CNC mostrará o no un error cuando el gap sobrepasa la tolerancia GAPTOL." .

ns1:Senal_INPOSGAP a ns1:Parametro ;
    rdfs:label "INPOSGAP" ;
    ns1:documentadoEn ns1:TablaSenalesPLC_16_2_6 ;
    ns1:identificador "INPOSGAP" ;
    ns1:monitoreaParametro ns1:Parametro_GAPMIN_GAPMAX ;
    ns1:textoExtracto "El CNC activa esta marca si el gap está dentro del rango definido por los parámetros GAPMIN-GAPMAX. Si el gap sobrepasa el rango definido en los parámetros GAPMIN-GAPMAX, el CNC desactiva la marca INPOSGAP y detiene el movimiento de los ejes." .

ns1:Senal_INTOL a ns1:Parametro ;
    rdfs:label "INTOL" ;
    ns1:documentadoEn ns1:TablaSenalesPLC_16_2_6 ;
    ns1:identificador "INTOL" ;
    ns1:monitoreaParametro ns1:Parametro_GAPTOL ;
    ns1:textoExtracto "El CNC activa esta marca si el gap está dentro de la tolerancia definida por el parámetro GAPTOL, respecto el valor de gap programado. Si el eje sobrepasa la tolerancia definida en el parámetro GAPTOL, el CNC desactiva la marca INTOL." .

ns1:Parametro_GAPMIN_GAPMAX a ns1:Parametro ;
    rdfs:label "GAPMIN-GAPMAX" ;
    ns1:identificador "GAPMIN-GAPMAX" ;
    ns1:textoExtracto "Rango de gap definido por los parámetros GAPMIN-GAPMAX, usado para activar/desactivar la marca INPOSGAP." .

ns1:Parametro_GAPTOL a ns1:Parametro ;
    rdfs:label "GAPTOL" ;
    ns1:identificador "GAPTOL" ;
    ns1:textoExtracto "Tolerancia de gap definida por el parámetro GAPTOL, usada para activar/desactivar la marca INTOL." .

ns1:TablaSenalesPLC_16_2_6 a ns1:Tabla ;
    rdfs:label "Tabla de señales lógicas del PLC (16.2.6)" ;
    ns1:textoExtracto "Señales lógicas de consulta. | Señales del PLC. | Significado. | [...] | INPOSGAP | El CNC activa esta marca si el gap está dentro del rango definido por los parámetros GAPMIN-GAPMAX... | INTOL | El CNC activa esta marca si el gap está dentro de la tolerancia definida por el parámetro GAPTOL..." .

