@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ControlGap a ns1:ModoOperacion ;
    rdfs:label "control del gap" ;
    ns1:textoExtracto "Esta marca no desactiva el control del gap, excepto en el movimiento de aproximación." .

ns1:Marca_ENABLEGAP a ns1:Parametro ;
    rdfs:label "ENABLEGAP" ;
    ns1:textoExtracto "Marca activa por defecto. El PLC desactiva esta marca para deshabilitar" .

ns1:MovimientoAproximacion a ns1:AccionProhibida ;
    rdfs:label "movimiento de aproximación" ;
    ns1:textoExtracto "En este caso, el eje permanecerá parado y sin control del gap hasta que se reanude el movimiento." .

ns1:Senal_STOP a ns1:Parametro ;
    rdfs:label "_STOP" ;
    ns1:textoExtracto "Con esta señal a nivel lógico bajo, todas las teclas permanecen habilitadas." .

ns1:Tecla_STOP_CNC a ns1:InterfazUsuario ;
    rdfs:label "[STOP]" ;
    ns1:textoExtracto "El tratamiento que recibe la señal _STOP es similar al que recibe la tecla [STOP] del CNC." .

