@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix mec: <https://vocab.cfaa.eus/mecanica/> .
@prefix elec: <https://vocab.cfaa.eus/electrica/> .
@prefix base: <https://vocab.cfaa.eus/base/> .

ex:TecladoJOG a owl:Class ;
    rdfs:label "TecladoJOG" ;
    rdfs:comment "Captura JOG con controles Z+/Z- y C+/C- destacados. Zonas de estado en la parte inferior y lateral; contraste claro entre teclas activas/inactivas para la conducción manual de ejes." .

ex:PantallaPrincipal a owl:Class ;
    rdfs:label "PantallaPrincipal" ;
    rdfs:comment "Sinóptico con lecturas de ejes Z, Z1 y C, avance y propiedades del ciclo. Softkeys resaltadas (Inspección, Ciclo brochado). Estructura por paneles oscuros con texto claro que prioriza valores en tiempo real." .

ex:InterfazMovimientosManuales a owl:Class ;
    rdfs:label "InterfazMovimientosManuales" ;
    rdfs:comment "Interfaz para llevar el carro a posiciones superior/intermedia/inferior y subir/bajar/girar la mesa. Indicadores de frenos MAYR, consumos y temperaturas; flechas y etiquetas guían direccionalidad y estados." .

ex:PanelArranqueMotores a owl:Class ;
    rdfs:label "PanelArranqueMotores" ;
    rdfs:comment "Panel con cuatro columnas (Marcha, Motor, Disyuntor, Señales). Indicadores circulares para estado de motores (refrigerante, trasvase, hidráulico, extractor, engrase) y alarmas de nivel/caudal; jerarquía orientada a diagnóstico." .

ex:PantallaCicloCambioBrocha a owl:Class ;
    rdfs:label "PantallaCicloCambioBrocha" ;
    rdfs:comment "Secuencia guiada de pasos con conmutadores de verificación; disposición en dos columnas que ordena la ejecución del procedimiento sin habilitar movimientos desde esta pantalla." .

ex:PantallaCondicionesMaquina a owl:Class ;
    rdfs:label "PantallaCondicionesMaquina" ;
    rdfs:comment "Matriz de señalizadores de diagnóstico OK/Error. Presentación plana y repetitiva que facilita la detección rápida de incidencias de sensores y subsistemas." .

mec:tieneControles a owl:ObjectProperty ;
    rdfs:domain ex:TecladoJOG ;
    rdfs:range ex:Control .

mec:tieneZonasDeEstado a owl:ObjectProperty ;
    rdfs:domain ex:TecladoJOG ;
    rdfs:range ex:ZonaDeEstado .

mec:tieneContraste a owl:ObjectProperty ;
    rdfs:domain ex:TecladoJOG ;
    rdfs:range ex:Contraste .

mec:tieneLecturasDeEjes a owl:ObjectProperty ;
    rdfs:domain ex:PantallaPrincipal ;
    rdfs:range ex:LecturaDeEje .

mec:tieneAvance a owl:ObjectProperty ;
    rdfs:domain ex:PantallaPrincipal ;
    rdfs:range ex:Avance .

mec:tienePropiedadesDelCiclo a owl:ObjectProperty ;
    rdfs:domain ex:PantallaPrincipal ;
    rdfs:range ex:PropiedadDelCiclo .

mec:tieneSoftkeys a owl:ObjectProperty ;
    rdfs:domain ex:PantallaPrincipal ;
    rdfs:range ex:Softkey .

mec:tieneEstructuraPorPaneles a owl:ObjectProperty ;
    rdfs:domain ex:PantallaPrincipal ;
    rdfs:range ex:EstructuraPorPaneles .

mec:tieneTextoClaro a owl:ObjectProperty ;
    rdfs:domain ex:PantallaPrincipal ;
    rdfs:range ex:TextoClaro .

mec:tieneValoresEnTiempoReal a owl:ObjectProperty ;
    rdfs:domain ex:PantallaPrincipal ;
    rdfs:range ex:ValorEnTiempoReal .

mec:tieneInterfazParaLlevarElCarro a owl:ObjectProperty ;
    rdfs:domain ex:InterfazMovimientosManuales ;
    rdfs:range ex:InterfazParaLlevarElCarro .

mec:tieneIndicadoresDeFrenos a owl:ObjectProperty ;
    rdfs:domain ex:InterfazMovimientosManuales ;
    rdfs:range ex:IndicadorDeFrenos .

mec:tieneConsumos a owl:ObjectProperty ;
    rdfs:domain ex:InterfazMovimientosManuales ;
    rdfs:range ex:Consumo .

mec:tieneTemperaturas a owl:ObjectProperty ;
    rdfs:domain ex:InterfazMovimientosManuales ;
    rdfs:range ex:Temperatura .

mec:tieneFlechas a owl:ObjectProperty ;
    rdfs:domain ex:InterfazMovimientosManuales ;
    rdfs:range ex:Flecha .

mec:tieneEtiquetas a owl:ObjectProperty ;
    rdfs:domain ex:InterfazMovimientosManuales ;
    rdfs:range ex:Etiqueta .

mec:tienePanelConCuatroColumnas a owl:ObjectProperty ;
    rdfs:domain ex:PanelArranqueMotores ;
    rdfs:range ex:PanelConCuatroColumnas .

mec:tieneIndicadoresCirculares a owl:ObjectProperty ;
    rdfs:domain ex:PanelArranqueMotores ;
    rdfs:range ex:IndicadorCircular .

mec:tieneAlarmasDeNivelCaudal a owl:ObjectProperty ;
    rdfs:domain ex:PanelArranqueMotores ;
    rdfs:range ex:AlarmaDeNivelCaudal .

mec:tieneJerarquíaOrientadaADiagnóstico a owl:ObjectProperty ;
    rdfs:domain ex:PanelArranqueMotores ;
    rdfs:range ex:JerarquíaOrientadaADiagnóstico .

mec:tieneSecuenciaGuiadaDePasos a owl:ObjectProperty ;
    rdfs:domain ex:PantallaCicloCambioBrocha ;
    rdfs:range ex:SecuenciaGuiadaDePasos .

mec:tieneConmutadoresDeVerificación a owl:ObjectProperty ;
    rdfs:domain ex:PantallaCicloCambioBrocha ;
    rdfs:range ex:ConmutadorDeVerificación .

mec:tieneDisposiciónEnDosColumnas a owl:ObjectProperty ;
    rdfs:domain ex:PantallaCicloCambioBrocha ;
    rdfs:range ex:DisposiciónEnDosColumnas .

mec:tieneMatrizDeSeñalizadores a owl:ObjectProperty ;
    rdfs:domain ex:PantallaCondicionesMaquina ;
    rdfs:range ex:MatrizDeSeñalizadores .

mec:tienePresentaciónPlana a owl:ObjectProperty ;
    rdfs:domain ex:PantallaCondicionesMaquina ;
    rdfs:range ex:PresentaciónPlana .

mec:facilitaDetecciónRápidaDeIncidencias a owl:ObjectProperty ;
    rdfs:domain ex:PantallaCondicionesMaquina ;
    rdfs:range ex:DetecciónRápidaDeIncidencias .

