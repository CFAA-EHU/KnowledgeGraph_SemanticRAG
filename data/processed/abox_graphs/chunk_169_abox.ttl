@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlarmaCaudal a ns1:Alarma ;
    rdfs:label "Alarma de caudal" ;
    ns1:textoExtracto "alarmas de nivel/caudal" .

ns1:AlarmaNivel a ns1:Alarma ;
    rdfs:label "Alarma de nivel" ;
    ns1:textoExtracto "alarmas de nivel/caudal" .

ns1:IndicadorMotorEngrase a ns1:Sensor ;
    rdfs:label "Indicador motor engrase" ;
    ns1:textoExtracto "Indicadores circulares para estado de motores (refrigerante, trasvase, hidráulico, extractor, engrase)" .

ns1:IndicadorMotorExtractor a ns1:Sensor ;
    rdfs:label "Indicador motor extractor" ;
    ns1:textoExtracto "Indicadores circulares para estado de motores (refrigerante, trasvase, hidráulico, extractor, engrase)" .

ns1:IndicadorMotorHidraulico a ns1:Sensor ;
    rdfs:label "Indicador motor hidráulico" ;
    ns1:textoExtracto "Indicadores circulares para estado de motores (refrigerante, trasvase, hidráulico, extractor, engrase)" .

ns1:IndicadorMotorRefrigerante a ns1:Sensor ;
    rdfs:label "Indicador motor refrigerante" ;
    ns1:textoExtracto "Indicadores circulares para estado de motores (refrigerante, trasvase, hidráulico, extractor, engrase)" .

ns1:IndicadorMotorTrasvase a ns1:Sensor ;
    rdfs:label "Indicador motor trasvase" ;
    ns1:textoExtracto "Indicadores circulares para estado de motores (refrigerante, trasvase, hidráulico, extractor, engrase)" .

ns1:InterfazMovimientosManuales a ns1:InterfazUsuario ;
    rdfs:label "Interfaz movimientos manuales" ;
    ns1:textoExtracto "Interfaz para llevar el carro a posiciones superior/intermedia/inferior y subir/bajar/girar la mesa. Indicadores de frenos MAYR, consumos y temperaturas; flechas y etiquetas guían direccionalidad y estados." .

ns1:MatrizDiagnostico a ns1:InterfazUsuario ;
    rdfs:label "Matriz de diagnóstico" ;
    ns1:textoExtracto "Matriz de señalizadores de diagnóstico OK/Error. Presentación plana y repetitiva que facilita la detección rápida de incidencias de sensores y subsistemas." .

ns1:PanelArranqueMotores a ns1:InterfazUsuario ;
    rdfs:label "Panel arranque motores" ;
    ns1:textoExtracto "Panel con cuatro columnas (Marcha, Motor, Disyuntor, Señales). Indicadores circulares para estado de motores (refrigerante, trasvase, hidráulico, extractor, engrase) y alarmas de nivel/caudal; jerarquía orientada a diagnóstico." .

ns1:PantallaCicloCambioBrocha a ns1:InterfazUsuario ;
    rdfs:label "Pantalla ciclo cambio de brocha" ;
    ns1:textoExtracto "Secuencia guiada de pasos con conmutadores de verificación; disposición en dos columnas que ordena la ejecución del procedimiento sin habilitar movimientos desde esta pantalla." .

ns1:PantallaPrincipal a ns1:InterfazUsuario ;
    rdfs:label "Pantalla principal" ;
    ns1:textoExtracto "Sinóptico con lecturas de ejes Z, Z1 y C, avance y propiedades del ciclo. Softkeys resaltadas (Inspección, Ciclo brochado). Estructura por paneles oscuros con texto claro que prioriza valores en tiempo real." .

ns1:SensorConsumo a ns1:Sensor ;
    rdfs:label "Sensor de consumo" ;
    ns1:textoExtracto "Indicadores de frenos MAYR, consumos y temperaturas" .

ns1:SensorFrenosMAYR a ns1:Sensor ;
    rdfs:label "Sensor frenos MAYR" ;
    ns1:textoExtracto "Indicadores de frenos MAYR, consumos y temperaturas" .

ns1:SensorTemperatura a ns1:Sensor ;
    rdfs:label "Sensor de temperatura" ;
    ns1:textoExtracto "Indicadores de frenos MAYR, consumos y temperaturas" .

ns1:SoftkeyCicloBrochado a ns1:InterfazUsuario ;
    rdfs:label "Softkey Ciclo brochado" ;
    ns1:textoExtracto "Softkeys resaltadas (Inspección, Ciclo brochado)" .

ns1:SoftkeyInspeccion a ns1:InterfazUsuario ;
    rdfs:label "Softkey Inspección" ;
    ns1:textoExtracto "Softkeys resaltadas (Inspección, Ciclo brochado)" .

ns1:TecladoJOG a ns1:InterfazUsuario ;
    rdfs:label "Teclado JOG" ;
    ns1:textoExtracto "Captura JOG con controles Z+/Z- y C+/C- destacados. Zonas de estado en la parte inferior y lateral; contraste claro entre teclas activas/inactivas para la conducción manual de ejes." .

