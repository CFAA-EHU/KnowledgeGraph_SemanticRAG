@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_PosicionX_1440 a ns1:Parametro ;
    rdfs:label "Cotas máquina reales en eje X (A.POS.X)" ;
    ns1:textoExtracto "(V.)A.POS.X Eje X. Cotas máquina reales." ;
    ns1:valor "A.POS.X" .

ns1:Parametro_PosicionZ_1440 a ns1:Parametro ;
    rdfs:label "Cotas máquina reales del sensor en eje Z (A.POS.Z)" ;
    ns1:textoExtracto "(V.)A.POS.Z Eje Z. Cotas máquina reales del sensor." ;
    ns1:valor "A.POS.Z" .

ns1:Sensor_Gap_1440 a ns1:Sensor ;
    rdfs:label "Sensor de detección del gap" ;
    ns1:monitoreaParametro ns1:Parametro_Gap_1440 ;
    ns1:textoExtracto "(V.)G.GAP Valor real del gap, detectado por el sensor." .

ns1:Sistema_ControlGap_1440 a ns1:Sistema ;
    rdfs:label "Sistema de control del gap" ;
    ns1:controla ns1:Parametro_CompensacionGapZ_1440 ;
    ns1:monitoreaParametro ns1:Parametro_Gap_1440 ;
    ns1:textoExtracto "Compensación que introduce el control del gap en el eje asociado al sensor para mantener el gap." .

ns1:Parametro_CompensacionGapZ_1440 a ns1:Parametro ;
    rdfs:label "Compensación del gap en eje Z (A.GAPCOMP.Z)" ;
    ns1:textoExtracto "(V.)A.GAPCOMP.Z Compensación que introduce el control del gap en el eje asociado al sensor para mantener el gap." ;
    ns1:valor "A.GAPCOMP.Z" .

ns1:Parametro_Gap_1440 a ns1:Parametro ;
    rdfs:label "Valor real del gap (G.GAP)" ;
    ns1:textoExtracto "(V.)G.GAP Valor real del gap, detectado por el sensor." ;
    ns1:valor "G.GAP" .

