@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_TG1_333_12ms a ns1:Parametro ;
    rdfs:label "TG1 333 (12 ms)" ;
    ns1:monitoreaParametro ns1:Sistema_ControlGap ;
    ns1:textoExtracto "TG1 333 12 ; Tiempo de espera, 12 milisegundos." ;
    ns1:valor "12" .

ns1:ComponenteElectrico_B10KEYLED1 a ns1:ComponenteElectrico ;
    rdfs:label "B10KEYLED1" ;
    ns1:identificador "B10KEYLED1" ;
    ns1:textoExtracto "B10KEYLED1" .

ns1:ComponenteElectrico_ENABLEGAP a ns1:ComponenteElectrico ;
    rdfs:label "ENABLEGAP" ;
    ns1:identificador "ENABLEGAP" ;
    ns1:textoExtracto "ENABLEGAP" .

ns1:ComponenteElectrico_ENABLELEAP a ns1:ComponenteElectrico ;
    rdfs:label "ENABLELEAP" ;
    ns1:identificador "ENABLELEAP" ;
    ns1:textoExtracto "ENABLELEAP" .

ns1:ComponenteElectrico_IRESETZ a ns1:ComponenteElectrico ;
    rdfs:label "IRESETZ" ;
    ns1:identificador "IRESETZ" ;
    ns1:textoExtracto "IRESETZ" .

ns1:ComponenteElectrico_M666 a ns1:ComponenteElectrico ;
    rdfs:label "M666" ;
    ns1:identificador "M666" ;
    ns1:textoExtracto "M666" .

ns1:Sistema_ControlGap a ns1:Sistema ;
    rdfs:label "Sistema de control del eje Gap" ;
    ns1:textoExtracto "Maniobra del PLC para retirar el eje asociado al control del gap" ;
    ns1:tieneComponente ns1:ComponenteElectrico_B10KEYLED1,
        ns1:ComponenteElectrico_ENABLEGAP,
        ns1:ComponenteElectrico_ENABLELEAP,
        ns1:ComponenteElectrico_IRESETZ,
        ns1:ComponenteElectrico_M666 .

