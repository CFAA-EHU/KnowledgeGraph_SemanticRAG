@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_CalculoConPalpador a ns1:ModoOperacion ;
    rdfs:label "Cálculo de cinemática con palpador" ;
    ns1:requiereMantenimiento ns1:Componente_Palpador ;
    ns1:textoExtracto "métodos para calcular las dimensiones de una cinemática con ayuda de un palpador" .

ns1:ModoOperacion_CalculoConRelojComparador a ns1:ModoOperacion ;
    rdfs:label "Cálculo de cinemática con reloj comparador" ;
    ns1:requiereMantenimiento ns1:Componente_RelojComparador ;
    ns1:textoExtracto "métodos para calcular las dimensiones de una cinemática con ayuda de [...] reloj comparador" .

ns1:Sistema_CinematicasAdicionales a ns1:Sistema ;
    rdfs:label "Cinemáticas adicionales OEM" ;
    ns1:textoExtracto "el OEM puede integrar 6 cinemáticas adicionales" .

ns1:Sistema_CinematicasPredefinidas a ns1:Sistema ;
    rdfs:label "Cinemáticas predefinidas del CNC" ;
    ns1:compuestoPor ns1:Maquina_CNC ;
    ns1:textoExtracto "El CNC ofrece una serie de cinemáticas predefinidas" .

ns1:Componente_Palpador a ns1:Componente ;
    rdfs:label "Palpador" ;
    ns1:textoExtracto "métodos para calcular las dimensiones de una cinemática con ayuda de un palpador" .

ns1:Componente_RelojComparador a ns1:Componente ;
    rdfs:label "Reloj comparador" ;
    ns1:textoExtracto "métodos para calcular las dimensiones de una cinemática con ayuda de [...] reloj comparador" .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "El CNC ofrece una serie de cinemáticas predefinidas y que se pueden configurar fácilmente desde los parámetros máquina" ;
    ns1:tieneComponente ns1:Parametro_TYPE .

ns1:Parametro_TYPE a ns1:Parametro ;
    rdfs:label "TYPE" ;
    ns1:identificador "TYPE" ;
    ns1:textoExtracto "el tipo de cinemática, definido en el parámetro TYPE" .

