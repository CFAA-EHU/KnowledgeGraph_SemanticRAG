@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Aviso_RupturaPalpador a ns1:AvisoSeguridad ;
    rdfs:label "Riesgo de ruptura del palpador por falta de activación"@es ;
    ns1:documentadoEn ns1:Fragmento_1443_CabezalAngular ;
    ns1:mitigaRiesgo ns1:Accion_MovimientoSinPalpadorActivo ;
    ns1:textoExtracto "Si se realiza un movimiento de palpación sin activar el palpador, éste no enviará ninguna señal al CNC cuando haga contacto. Esta circunstancia puede ocasionar la ruptura del palpador, ya que no se detendrá el movimiento de palpación."@es .

ns1:CabezalAngular_YZ_45 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal angular YZ de 45°"@es ;
    ns1:documentadoEn ns1:Fragmento_1443_CabezalAngular ;
    ns1:identificador "TYPE=6" ;
    ns1:monitoreaParametro ns1:Parametro_TYPE_CabezalAngular ;
    ns1:textoExtracto "En este ejemplo se calculan las dimensiones de un cabezal angular YZ de 45º, parámetro TYPE con valor ꞏ6ꞏ."@es .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC"@es ;
    ns1:documentadoEn ns1:Fragmento_1443_CabezalAngular ;
    ns1:textoExtracto "Los parámetros máquina asociados al movimiento del palpador deben estar definidos y el palpador debe estar correctamente calibrado."@es ;
    ns1:tieneComponente ns1:Palpador_CNC .

ns1:Sentencia_SELECT_PROBE a ns1:InterfazUsuario ;
    rdfs:label "Sentencia #SELECT PROBE"@es ;
    ns1:documentadoEn ns1:Fragmento_1443_CabezalAngular ;
    ns1:identificador "#SELECT PROBE" ;
    ns1:textoExtracto "La selección se realiza desde el programa pieza o desde MDI mediante la sentencia #SELECT PROBE."@es .

ns1:Accion_MovimientoSinPalpadorActivo a ns1:AccionProhibida ;
    rdfs:label "Movimiento de palpación sin palpador activo"@es ;
    ns1:documentadoEn ns1:Fragmento_1443_CabezalAngular ;
    ns1:textoExtracto "Si se realiza un movimiento de palpación sin activar el palpador, éste no enviará ninguna señal al CNC cuando haga contacto. Esta circunstancia puede ocasionar la ruptura del palpador, ya que no se detendrá el movimiento de palpación."@es .

ns1:Palpador_CNC a ns1:Sensor ;
    rdfs:label "Palpador del CNC"@es ;
    ns1:documentadoEn ns1:Fragmento_1443_CabezalAngular ;
    ns1:monitoreaParametro ns1:Parametro_Longitud_Palpador,
        ns1:Parametro_Radio_Palpador ;
    ns1:textoExtracto "En el siguiente ejemplo se utiliza un palpador y una pieza patrón amarrada a la mesa, con sus caras alineadas con los ejes principales de la máquina. Los parámetros máquina asociados al movimiento del palpador deben estar definidos y el palpador debe estar correctamente calibrado. Hay que conocer la longitud y el radio y del palpador para calcular las dimensiones del cabezal."@es .

ns1:Parametro_Longitud_Palpador a ns1:Parametro ;
    rdfs:label "Longitud del palpador (L)"@es ;
    ns1:documentadoEn ns1:Fragmento_1443_CabezalAngular ;
    ns1:identificador "L" ;
    ns1:textoExtracto "Hay que conocer la longitud y el radio y del palpador para calcular las dimensiones del cabezal. L R"@es .

ns1:Parametro_Radio_Palpador a ns1:Parametro ;
    rdfs:label "Radio del palpador (R)"@es ;
    ns1:documentadoEn ns1:Fragmento_1443_CabezalAngular ;
    ns1:identificador "R" ;
    ns1:textoExtracto "Hay que conocer la longitud y el radio y del palpador para calcular las dimensiones del cabezal. L R"@es .

ns1:Parametro_TYPE_CabezalAngular a ns1:Parametro ;
    rdfs:label "Parámetro TYPE del cabezal angular"@es ;
    ns1:documentadoEn ns1:Fragmento_1443_CabezalAngular ;
    ns1:identificador "TYPE" ;
    ns1:textoExtracto "parámetro TYPE con valor ꞏ6ꞏ"@es ;
    ns1:valor "6" .

ns1:Fragmento_1443_CabezalAngular a ns1:Pagina ;
    ns1:textoExtracto "palpador. En este ejemplo se calculan las dimensiones de un cabezal angular YZ de 45º, parámetro TYPE con valor ꞏ6ꞏ. En el siguiente ejemplo se utiliza un palpador y una pieza patrón amarrada a la mesa, con sus caras ali..."@es .

