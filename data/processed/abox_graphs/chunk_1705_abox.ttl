@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalAngular_TYPE6 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal angular YZ (TYPE=6)"@es ;
    ns1:identificador "TYPE=6" ;
    ns1:textoExtracto "Dimensiones a calcular en un cabezal angular YZ (TYPE=6). En este tipo de cinemática hay que definir las siguientes dimensiones."@es ;
    ns1:tieneComponente ns1:Param_TDATA1,
        ns1:Param_TDATA2,
        ns1:Param_TDATA3,
        ns1:Param_TDATA5,
        ns1:Param_TDATA6,
        ns1:Param_TDATA7 .

ns1:Param_TDATA1 a ns1:Parametro ;
    rdfs:label "TDATA1" ;
    ns1:textoExtracto "TDATA1 Indica la distancia entre la nariz del mandrino y el eje rotativo secundario, según el eje Z."@es ;
    ns1:valor "DATA 1(+)" .

ns1:Param_TDATA2 a ns1:Parametro ;
    rdfs:label "TDATA2" ;
    ns1:textoExtracto "TDATA2 Indica la distancia entre el eje rotativo secundario y el principal según el eje X."@es ;
    ns1:valor "DATA 2(-)" .

ns1:Param_TDATA3 a ns1:Parametro ;
    rdfs:label "TDATA3" ;
    ns1:textoExtracto "TDATA3 Indica la distancia entre el eje rotativo secundario y el principal según el eje Y."@es ;
    ns1:valor "DATA 3(+)" .

ns1:Param_TDATA5 a ns1:Parametro ;
    rdfs:label "TDATA5" ;
    ns1:textoExtracto "TDATA5 Indica la distancia entre el eje de la herramienta y el eje rotativo secundario según el eje X."@es .

ns1:Param_TDATA6 a ns1:Parametro ;
    rdfs:label "TDATA6" ;
    ns1:textoExtracto "TDATA6 Indica la distancia entre el eje de la herramienta y el eje rotativo secundario según el eje Y."@es .

ns1:Param_TDATA7 a ns1:Parametro ;
    rdfs:label "TDATA7" ;
    ns1:textoExtracto "TDATA7 Indica el ángulo entre los ejes rotativos principal y secundario, en los cabezales rotativos (en este caso TDATA7 = 45)."@es ;
    ns1:valor "45" .

