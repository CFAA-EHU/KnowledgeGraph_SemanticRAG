@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_TDATA7 a ns1:Parametro ;
    rdfs:label "TDATA7 (Ángulo entre ejes rotativos principal/secundario)"@es ;
    ns1:identificador "TDATA7" ;
    ns1:textoExtracto "TDATA7 Indica el ángulo entre los ejes rotativos principal y secundario, en los cabezales rotativos (en este caso TDATA7 = 45)."@es ;
    ns1:valor "45" .

ns1:TareaMantenimiento_PalpacionCaraZ a ns1:TareaMantenimiento ;
    rdfs:label "Procedimiento de palpación para cálculo de TDATA1"@es ;
    ns1:monitoreaParametro ns1:Parametro_TDATA1 ;
    ns1:requiereMantenimiento ns1:Sistema_CabezalesRotativos ;
    ns1:textoExtracto "Primera palpación. Con los ejes rotativos B y C posicionados en 0º realizar un movimiento de palpación sobre la cara Z y preseleccionar la cota Z=0. Segunda palpación. Con el eje rotativo B posicionado en 0º y el eje C en 180º realizar un movimiento de palpación sobre la misma cara."@es .

ns1:EjeRotativo_B a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo B"@es ;
    ns1:identificador "B" ;
    ns1:textoExtracto "Con los ejes rotativos B y C posicionados en 0º..."@es .

ns1:EjeRotativo_C a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo C"@es ;
    ns1:identificador "C" ;
    ns1:textoExtracto "Con el eje rotativo B posicionado en 0º y el eje C en 180º..."@es .

ns1:Parametro_TDATA1 a ns1:Parametro ;
    rdfs:label "TDATA1 (Parámetro de cálculo para cabezal angular)"@es ;
    ns1:identificador "TDATA1" ;
    ns1:textoExtracto "Cálculo del parámetro TDATA1. Primera palpación... el único dato desconocido tras ambos palpaciones es TDATA1."@es .

ns1:Sistema_CabezalesRotativos a ns1:Sistema ;
    rdfs:label "Sistema de cabezales rotativos (ejes B y C)"@es ;
    ns1:textoExtracto "Con los ejes rotativos B y C posicionados en 0º realizar un movimiento de palpación..."@es ;
    ns1:tieneComponente ns1:EjeRotativo_B,
        ns1:EjeRotativo_C .

