@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:PuntoReferencia_OT a ns1:Parametro ;
    rdfs:label "Punto de referencia OT" ;
    ns1:identificador "OT" ;
    ns1:textoExtracto "OT: Punto de referencia de las herramientas." .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:monitoreaParametro ns1:Parametro_TDATA1,
        ns1:Parametro_TDATA5,
        ns1:Parametro_TDATA6 ;
    ns1:textoExtracto "ΔZ: Cota que indica el CNC. ΔX: Cota que indica el CNC." .

ns1:TareaMantenimiento_CalculoTDATA1 a ns1:TareaMantenimiento ;
    rdfs:label "Cálculo de TDATA1" ;
    ns1:documentadoEn ns1:Pagina_706_711 ;
    ns1:requiereMantenimiento ns1:Componente_Palpador ;
    ns1:textoExtracto "TDATA1 = ΔZ + R – L" .

ns1:TareaMantenimiento_CalculoTDATA5 a ns1:TareaMantenimiento ;
    rdfs:label "Cálculo de TDATA5" ;
    ns1:documentadoEn ns1:Pagina_706_711 ;
    ns1:requiereMantenimiento ns1:Componente_Palpador ;
    ns1:textoExtracto "TDATA5 = 0,5 × ΔZ [...] Primera palpación: B=0º C=0º. Segunda palpación: B=0º C=180º." .

ns1:TareaMantenimiento_CalculoTDATA6 a ns1:TareaMantenimiento ;
    rdfs:label "Cálculo de TDATA6" ;
    ns1:documentadoEn ns1:Pagina_706_711 ;
    ns1:requiereMantenimiento ns1:Componente_Palpador ;
    ns1:textoExtracto "Primera palpación: B=0º C=0º. Segunda palpación: B=-90º C=0º." .

ns1:Parametro_TDATA1 a ns1:Parametro ;
    rdfs:label "TDATA1" ;
    ns1:textoExtracto "TDATA1 = ΔZ + R – L [...] TDATA1: Dimensión a calcular." ;
    ns1:valor "ΔZ + R – L"^^xsd:string .

ns1:Parametro_TDATA5 a ns1:Parametro ;
    rdfs:label "TDATA5" ;
    ns1:textoExtracto "TDATA5 = 0,5 × ΔZ [...] TDATA5: Dimensión a calcular." ;
    ns1:valor "0,5 × ΔX"^^xsd:string .

ns1:Parametro_TDATA6 a ns1:Parametro ;
    rdfs:label "TDATA6" ;
    ns1:textoExtracto "Cálculo del parámetro TDATA6 [...] cuya dimensión será la cota indicada en el CNC menos el diámetro de la bola del palpador." ;
    ns1:valor "X=D+2R"^^xsd:string .

ns1:Componente_Palpador a ns1:ComponenteMecanico ;
    rdfs:label "Palpador" ;
    ns1:textoExtracto "L: Longitud del palpador. R: Radio de la bola del palpador." .

ns1:Pagina_706_711 a ns1:Pagina ;
    rdfs:label "Páginas 706-711: Cabezal angular. Cálculo de dimensiones" ;
    ns1:identificador "706-711" ;
    ns1:textoExtracto "Sección 17.1 Cabezal angular. Cálculo de las dimensiones con ayuda de un palpador." .

