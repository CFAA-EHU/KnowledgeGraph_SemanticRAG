@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjeRotativoB_17_1 a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo B del cabezal angular"@es ;
    ns1:textoExtracto "eje rotativo [...] B posicionado en 0º [...] B en -90º [...] B en 90º"@es .

ns1:EjeRotativoC_17_1 a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo C del cabezal angular"@es ;
    ns1:textoExtracto "eje rotativo C posicionado en 0º"@es .

ns1:EsquemaPosicionamiento_17_1 a ns1:Esquema ;
    rdfs:label "Esquema de palpación y posicionamiento del cabezal angular"@es ;
    ns1:ilustradoEn ns1:ProcesoCalibracionCabezalAngular_17_1 ;
    ns1:textoExtracto "B=0º C=0º Z X X=D+2R [...] B=-90º B=90º C=0º C=0º 2 1 2 1 Z X"@es .

ns1:ParametroTDATA1_17_1 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA1 (referencia de posición)"@es ;
    ns1:textoExtracto "TDATA1"@es ;
    ns1:valor "TDATA1" .

ns1:ParametroTDATA6_17_1 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA6 (distancia corregida por cos45°)"@es ;
    ns1:textoExtracto "el único dato desconocido tras ambos palpaciones es TDATA6 [...] TDATA6 cos45"@es ;
    ns1:valor "TDATA6" .

ns1:ProcesoCalibracionCabezalAngular_17_1 a ns1:TareaMantenimiento ;
    rdfs:label "Proceso de cálculo de dimensiones del cabezal angular"@es ;
    ns1:identificador "17.1" ;
    ns1:ilustradoEn ns1:EsquemaPosicionamiento_17_1 ;
    ns1:requiereMantenimiento ns1:SistemaCabezalAngular_17_1 ;
    ns1:textoExtracto "Cálculo de las dimensiones con ayuda de un [...] TDATA6 cos45 ."@es .

ns1:SistemaCabezalAngular_17_1 a ns1:Sistema ;
    rdfs:label "Sistema de cabezal angular con ejes rotativos B y C"@es ;
    ns1:monitoreaParametro ns1:ParametroTDATA1_17_1,
        ns1:ParametroTDATA6_17_1 ;
    ns1:textoExtracto "Con el eje rotativo C posicionado en 0º y B en -90º [...] B=90º C=0º"@es ;
    ns1:tieneComponente ns1:EjeRotativoB_17_1,
        ns1:EjeRotativoC_17_1 .

