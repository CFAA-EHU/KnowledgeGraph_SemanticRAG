@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_R a ns1:Parametro ;
    rdfs:label "R (Radio de la bola del palpador)" ;
    ns1:identificador "R" ;
    ns1:monitoreaParametro ns1:Componente_Palpador ;
    ns1:textoExtracto "R | Radio de la bola del palpador." .

ns1:Sistema_PalpacionCabezalAngular a ns1:Sistema ;
    rdfs:label "Sistema de palpación para cabezal angular" ;
    ns1:detalladoEnEsquema ns1:Tabla_CalculoTDATA2,
        ns1:Tabla_CalculoTDATA6 ;
    ns1:monitoreaParametro ns1:Parametro_D,
        ns1:Parametro_L,
        ns1:Parametro_TDATA1,
        ns1:Parametro_TDATA2,
        ns1:Parametro_TDATA5,
        ns1:Parametro_TDATA6,
        ns1:Parametro_X,
        ns1:Parametro_X_prima,
        ns1:Parametro_Z ;
    ns1:textoExtracto "Con el eje rotativo C posicionado en 0º y el eje B en 90º realizar un movimiento de palpación sobre la cara Z" ;
    ns1:tieneComponente ns1:Componente_Palpador .

ns1:Parametro_D a ns1:Parametro ;
    rdfs:label "D (Longitud de la pieza)" ;
    ns1:identificador "D" ;
    ns1:textoExtracto "D | Longitud de la pieza." .

ns1:Parametro_L a ns1:Parametro ;
    rdfs:label "L (Longitud del palpador)" ;
    ns1:identificador "L" ;
    ns1:textoExtracto "L | Longitud del palpador." .

ns1:Parametro_TDATA1 a ns1:Parametro ;
    rdfs:label "TDATA1" ;
    ns1:identificador "TDATA1" ;
    ns1:textoExtracto "TDATA1 | Dimensión conocida." .

ns1:Parametro_TDATA2 a ns1:Parametro ;
    rdfs:label "TDATA2" ;
    ns1:identificador "TDATA2" ;
    ns1:textoExtracto "TDATA2 = 0,5·ΔZ – TDATA5" .

ns1:Parametro_TDATA5 a ns1:Parametro ;
    rdfs:label "TDATA5" ;
    ns1:identificador "TDATA5" ;
    ns1:textoExtracto "TDATA5 | Dimensión conocida." .

ns1:Parametro_TDATA6 a ns1:Parametro ;
    rdfs:label "TDATA6" ;
    ns1:identificador "TDATA6" ;
    ns1:textoExtracto "TDATA6 | Dimensión a calcular." .

ns1:Parametro_X a ns1:Parametro ;
    rdfs:label "ΔX (Cota CNC)" ;
    ns1:identificador "ΔX" ;
    ns1:textoExtracto "ΔX | Cotas que indica el CNC." .

ns1:Parametro_X_prima a ns1:Parametro ;
    rdfs:label "ΔX' (Cota CNC)" ;
    ns1:identificador "ΔX'" ;
    ns1:textoExtracto "ΔX' | Cotas que indica el CNC." .

ns1:Parametro_Z a ns1:Parametro ;
    rdfs:label "ΔZ (Cota CNC)" ;
    ns1:identificador "ΔZ" ;
    ns1:textoExtracto "ΔZ | Cota que indica el CNC." .

ns1:Tabla_CalculoTDATA2 a ns1:Tabla ;
    rdfs:label "Cálculo de TDATA2" ;
    ns1:documentadoEn ns1:Pagina_710 ;
    ns1:textoExtracto "TDATA2 = 0,5·ΔZ – TDATA5" .

ns1:Tabla_CalculoTDATA6 a ns1:Tabla ;
    rdfs:label "Cálculo de TDATA6" ;
    ns1:documentadoEn ns1:Pagina_706 ;
    ns1:textoExtracto "TDATA6 = (ΔX + ΔX' – D – 2L – 2TDATA1) / (2·cos45)" .

ns1:Componente_Palpador a ns1:ComponenteMecanico ;
    rdfs:label "Palpador" ;
    ns1:textoExtracto "Radio de la bola del palpador" .

