@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Selector a owl:Class ;
    rdfs:label "Selector con iconos conmutables" ;
    rdfs:comment "Selector con iconos conmutables de pieza (ANILLO/PLANA), operación (DESBASTE/ACABADO) y refrigeración (CON/SIN)" .

ex:GraficoCircular a owl:Class ;
    rdfs:label "Gráfico circular" ;
    rdfs:comment "Gráfico circular contextualiza trayectorias" .

ex:Botoneria a owl:Class ;
    rdfs:label "Botonería" ;
    rdfs:comment "Botonería con softkeys para ejecutar/simular/memorizar" .

ex:Teclado a owl:Class ;
    rdfs:label "Teclado" ;
    rdfs:comment "Fragmento de teclado con Reset / Auto / Manual enfatizados por color (rojo/amarillo/verde)" .

ex:PanelInfografico a owl:Class ;
    rdfs:label "Panel infográfico" ;
    rdfs:comment "Panel infográfico de advertencias con pictogramas STOP y triángulos de peligro; bloques rojos con texto blanco destacan consignación, prohibición de aire a presión y uso de mástil anticaídas" .

ex:Columna a owl:Class ;
    rdfs:label "Columna" ;
    rdfs:comment "Vista 3D a color de la columna y el carro con globos numerados y recuadros en rojo; identifica cremalleras, servomotores, guías, frenos, fuelles y sensores" .

ex:CarroPortaPiezas a owl:Class ;
    rdfs:label "Carro porta-piezas" ;
    rdfs:comment "Vista 3D a color de la columna y el carro con globos numerados y recuadros en rojo; identifica cremalleras, servomotores, guías, frenos, fuelles y sensores" .

ex:PlatoDivisor a owl:Class ;
    rdfs:label "Plato divisor" ;
    rdfs:comment "Perspectiva del conjunto del plato sobre bancada con resaltado del plato (1) y servomotor (2). Paleta de colores separa elementos y facilita la correspondencia con referencias comerciales" .

ex:tieneIconos a owl:ObjectProperty ;
    rdfs:domain ex:Selector ;
    rdfs:range ex:Icono .

