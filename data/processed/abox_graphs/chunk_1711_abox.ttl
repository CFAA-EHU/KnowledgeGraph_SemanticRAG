@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ProcesoCalibracionCabezalAngular_1450 a ns1:TareaMantenimiento ;
    rdfs:label "Calibración del cabezal angular con reloj comparador"@es ;
    ns1:ejecutadoPor ns1:PersonalTecnico_1450 ;
    ns1:ilustradoEn ns1:InterfazCNC_TDAT1_1450 ;
    ns1:requiereMantenimiento ns1:CabezalAngular_1450 ;
    ns1:textoExtracto "Preseleccionar Y=R, para que Y=0 coincida con el eje del cilindro colocado en el cabezal. [...] Apuntar la cota que aparece en el CNC (Y)."@es .

ns1:PuntoContacto_2_1450 a ns1:ComponenteMecanico ;
    rdfs:label "Punto de contacto 2"@es ;
    ns1:identificador "2" ;
    ns1:textoExtracto "Tocar con el reloj en el punto 2"@es .

ns1:RelojComparador_1450 a ns1:Herramienta ;
    rdfs:label "Reloj comparador"@es ;
    ns1:textoExtracto "Retirar el reloj, sin soltarlo [...] Tocar con el reloj en el punto 2"@es .

ns1:CabezalAngular_1450 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal angular"@es ;
    ns1:textoExtracto "eje del cilindro colocado en el cabezal"@es ;
    ns1:tieneComponente ns1:EjeRotativoC_1450 .

ns1:EjeRotativoC_1450 a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo C"@es ;
    ns1:identificador "C" ;
    ns1:textoExtracto "eje rotativo C en 180º. C=180º"@es .

ns1:InterfazCNC_TDAT1_1450 a ns1:InterfazUsuario ;
    rdfs:label "Interfaz CNC (pantalla TDATA1)"@es ;
    ns1:identificador "TDATA1" ;
    ns1:monitoreaParametro ns1:ParametroY_1450 ;
    ns1:textoExtracto "Apuntar la cota que aparece en el CNC (Y). TDATA1 Y"@es .

ns1:ParametroY_1450 a ns1:Parametro ;
    rdfs:label "Cota Y (posición radial)"@es ;
    ns1:identificador "Y" ;
    ns1:textoExtracto "Preseleccionar Y=R [...] Apuntar la cota que aparece en el CNC (Y)"@es ;
    ns1:valor "R"^^xsd:string .

ns1:PersonalTecnico_1450 a ns1:Personal ;
    rdfs:label "Técnico de calibración"@es ;
    ns1:textoExtracto "Retirar el reloj, sin soltarlo, y posicionar el eje rotativo C en 180º"@es .

