@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CalculoCabezalAngular a ns1:Sistema ;
    rdfs:label "Sistema de cálculo del cabezal angular con reloj" ;
    ns1:compuestoPor ns1:PuntoContacto_1,
        ns1:PuntoContacto_2 ;
    ns1:monitoreaParametro ns1:Parametro_DeltaX,
        ns1:Parametro_DeltaY,
        ns1:Parametro_TDATA1,
        ns1:Parametro_TDATA2,
        ns1:Parametro_TDATA5 ;
    ns1:textoExtracto "Procedimiento para calcular TDATA1, TDATA5 y TDATA2 usando contactos en puntos 1 y 2 con reloj comparador."@es .

ns1:Parametro_TDATA1 a ns1:Parametro ;
    rdfs:label "TDATA1" ;
    ns1:monitoreaParametro ns1:Parametro_DeltaY ;
    ns1:textoExtracto "TDATA1 = ΔY ; TDATA1: Dimensión a calcular."@es ;
    ns1:valor "ΔY" .

ns1:Parametro_TDATA2 a ns1:Parametro ;
    rdfs:label "TDATA2" ;
    ns1:textoExtracto "TDATA2: Dimensión calculada a partir de contactos en puntos 1 y 2 (usando preselección de TDATA5)."@es .

ns1:Parametro_TDATA5 a ns1:Parametro ;
    rdfs:label "TDATA5" ;
    ns1:monitoreaParametro ns1:Parametro_DeltaX ;
    ns1:textoExtracto "TDATA5 = 0,5·ΔX ; TDATA5: Dimensión a calcular."@es ;
    ns1:valor "0,5·ΔX" .

ns1:PuntoContacto_1 a ns1:ComponenteMecanico ;
    rdfs:label "Punto de contacto 1" ;
    ns1:textoExtracto "Punto 1: Primer contacto entre reloj y cilindro (B=0°, C=0°)."@es .

ns1:PuntoContacto_2 a ns1:ComponenteMecanico ;
    rdfs:label "Punto de contacto 2" ;
    ns1:textoExtracto "Punto 2: Segundo contacto (B=0°, C=180° para TDATA5; B=180°, C=0° para TDATA2)."@es .

ns1:Parametro_DeltaX a ns1:Parametro ;
    rdfs:label "ΔX" ;
    ns1:identificador "ΔX" ;
    ns1:textoExtracto "ΔX: Cota que indica el CNC."@es .

ns1:Parametro_DeltaY a ns1:Parametro ;
    rdfs:label "ΔY" ;
    ns1:identificador "ΔY" ;
    ns1:textoExtracto "ΔY: Cota que indica el CNC."@es .

