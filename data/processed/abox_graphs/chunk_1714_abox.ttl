@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_DeltaX a ns1:Parametro ;
    rdfs:label "ΔX" ;
    ns1:identificador "ΔX" ;
    ns1:textoExtracto "ΔX | Cota que indica el CNC." .

ns1:Parametro_TDATA1 a ns1:Parametro ;
    rdfs:label "TDATA1" ;
    ns1:identificador "TDATA1" ;
    ns1:textoExtracto "TDATA6 = 2·(X_M – TDATA1)" .

ns1:Parametro_TDATA5 a ns1:Parametro ;
    rdfs:label "TDATA5" ;
    ns1:identificador "TDATA5" ;
    ns1:textoExtracto "TDATA5 | Dimensión a calcular." .

ns1:Parametro_TDATA6 a ns1:Parametro ;
    rdfs:label "TDATA6" ;
    ns1:identificador "TDATA6" ;
    ns1:textoExtracto "TDATA6 = 2·(X_M – TDATA1)" ;
    ns1:valor "2·(X_M – TDATA1)" .

ns1:Parametro_XM a ns1:Parametro ;
    rdfs:label "X_M" ;
    ns1:identificador "X_M" ;
    ns1:textoExtracto "X = 0,5·(X_B + X_A) ; TDATA6 = 2·(X_M – TDATA1)" .

ns1:Tabla_17_2_CalculoDimensiones a ns1:Tabla ;
    rdfs:label "Tabla de cálculo de dimensiones (Sección 17.2)" ;
    ns1:detalladoEnEsquema ns1:Esquema_CabezalAngular ;
    ns1:ilustradoEn ns1:Pagina_712_715 ;
    ns1:textoExtracto "X = 0,5·(X + X) ; TDATA6 = 2·(X – TDATA1)" .

ns1:Esquema_CabezalAngular a ns1:Esquema ;
    rdfs:label "Esquema de cálculo para cabezal angular" ;
    ns1:identificador "Figura_17.2" ;
    ns1:textoExtracto "T D A T A 6 45 O X M Z TDATA1 Y" .

ns1:Pagina_712_715 a ns1:Pagina ;
    rdfs:label "Páginas 712-715 (Cálculo de dimensiones con reloj)" ;
    ns1:identificador "712-715" ;
    ns1:textoExtracto "Sección 17.2 Cabezal angular. Cálculo de las dimensiones con ayuda de un reloj" .

