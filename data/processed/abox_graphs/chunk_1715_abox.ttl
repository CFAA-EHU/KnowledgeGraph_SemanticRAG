@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Accion_MovimientoSinPalpadorActivo a ns1:AccionProhibida ;
    rdfs:label "Movimiento de palpación sin activar el palpador"@es ;
    ns1:textoExtracto "Si se realiza un movimiento de palpación sin activar el palpador, éste no enviará ninguna señal al CNC cuando haga contacto. Esta circunstancia puede ocasionar la ruptura del palpador, ya que no se detendrá el movimiento de palpación."@es .

ns1:MesaRotativa_AB_TYPE9 a ns1:ComponenteMecanico ;
    rdfs:label "Mesa rotativa AB (TYPE=9)"@es ;
    ns1:identificador "TYPE=9" ;
    ns1:monitoreaParametro ns1:Parametro_TDATA2,
        ns1:Parametro_TDATA3,
        ns1:Parametro_TDATA4,
        ns1:Parametro_TDATA5 ;
    ns1:textoExtracto "En este ejemplo se calculan las dimensiones de una mesa rotativa AB con un rango de movimientos del eje A -90º a 90º y del eje B de 0º a -90º; parámetro TYPE con valor ꞏ9ꞏ. [...] Dimensiones a calcular en una mesa rotativa AB (TYPE=9)."@es ;
    ns1:tieneComponente ns1:EjeRotativoA,
        ns1:EjeRotativoB .

ns1:Sentencia_SELECT_PROBE a ns1:InterfazUsuario ;
    rdfs:label "Sentencia #SELECT PROBE"@es ;
    ns1:controla ns1:Palpador_CNC ;
    ns1:textoExtracto "La selección [del palpador activo] se realiza desde el programa pieza o desde MDI mediante la sentencia #SELECT PROBE."@es .

ns1:EjeRotativoA a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo A"@es ;
    ns1:identificador "Eje A" ;
    ns1:textoExtracto "mesa rotativa AB con un rango de movimientos del eje A -90º a 90º"@es .

ns1:EjeRotativoB a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo B"@es ;
    ns1:identificador "Eje B" ;
    ns1:textoExtracto "rango de movimientos [...] del eje B de 0º a -90º"@es .

ns1:Palpador_CNC a ns1:Sensor ;
    rdfs:label "Palpador para CNC"@es ;
    ns1:monitoreaParametro ns1:Parametro_LongitudPalpador,
        ns1:Parametro_RadioPalpador ;
    ns1:textoExtracto "En el siguiente ejemplo se utiliza un palpador y un cilindro de diámetro conocido amarrado a la mesa. Los parámetros máquina asociados al movimiento del palpador deben estar definidos y el palpador debe estar correctamente calibrado. Hay que conocer la longitud y el radio del palpador para calcular las dimensiones del cabezal."@es .

ns1:Parametro_LongitudPalpador a ns1:Parametro ;
    rdfs:label "Longitud del palpador (L)"@es ;
    ns1:identificador "L" ;
    ns1:textoExtracto "Hay que conocer la longitud [...] del palpador"@es .

ns1:Parametro_RadioPalpador a ns1:Parametro ;
    rdfs:label "Radio del palpador (R)"@es ;
    ns1:identificador "R" ;
    ns1:textoExtracto "Hay que conocer [...] el radio del palpador"@es .

ns1:Parametro_TDATA2 a ns1:Parametro ;
    rdfs:label "Posición del eje rotativo secundario (X) - TDATA2"@es ;
    ns1:identificador "TDATA2" ;
    ns1:textoExtracto "TDATA2 Indica la posición del eje rotativo secundario o la intersección con el eje primario según el eje X."@es .

ns1:Parametro_TDATA3 a ns1:Parametro ;
    rdfs:label "Posición del eje rotativo secundario (Y) - TDATA3"@es ;
    ns1:identificador "TDATA3" ;
    ns1:textoExtracto "TDATA3 Indica la posición del eje rotativo secundario o la intersección con el eje primario según el eje Y."@es .

ns1:Parametro_TDATA4 a ns1:Parametro ;
    rdfs:label "Posición del eje rotativo secundario (Z) - TDATA4"@es ;
    ns1:identificador "TDATA4" ;
    ns1:textoExtracto "TDATA4 Indica la posición del eje rotativo secundario o la intersección con el eje primario según el eje Z."@es .

ns1:Parametro_TDATA5 a ns1:Parametro ;
    rdfs:label "Distancia entre ejes rotativos - TDATA5"@es ;
    ns1:identificador "TDATA5" ;
    ns1:textoExtracto "TDATA5 Indica la distancia entre el eje rotativo secundario y el principal."@es .

