@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Figura_17_3 a ns1:Figura ;
    rdfs:label "Dibujo de posiciones del eje A (pág. 716-719)"@es ;
    ns1:ilustradoEn ns1:Pagina_716,
        ns1:Pagina_717,
        ns1:Pagina_718,
        ns1:Pagina_719 ;
    ns1:textoExtracto "En el dibujo se muestran dos posiciones distintas que tienen en común el centro del eje A"@es .

ns1:Parametro_TDATA2 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA2"@es ;
    ns1:identificador "TDATA2" ;
    ns1:textoExtracto "TDATA 2(+)"@es .

ns1:Parametro_TDATA3 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA3 (coordenada Y del eje A)"@es ;
    ns1:identificador "TDATA3" ;
    ns1:textoExtracto "La coordenada en el eje Y es el parámetro TDATA3"@es .

ns1:Parametro_TDATA4 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA4"@es ;
    ns1:identificador "TDATA4" ;
    ns1:textoExtracto "TDATA 4(+)"@es .

ns1:Parametro_TDATA5 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA5"@es ;
    ns1:identificador "TDATA5" ;
    ns1:textoExtracto "TDATA 5(+)"@es .

