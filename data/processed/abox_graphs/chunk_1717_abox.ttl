@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_PalpacionPunto1 a ns1:ModoOperacion ;
    rdfs:label "Palpación en punto 1 (A=-90°, B=-90°)"@es ;
    ns1:habilitadoPor ns1:TareaMantenimiento_CalculoCoordenadasEjeA ;
    ns1:textoExtracto "1 Posicionar los ejes rotativos A y B en -90º. 2 Realizar un movimiento de palpación en la dirección del eje Y, sobre el punto 1. 3 Realizar un movimiento de palpación en la dirección del eje Z, sobre el punto 1."@es .

ns1:ModoOperacion_PalpacionPunto2 a ns1:ModoOperacion ;
    rdfs:label "Palpación en punto 2 (A=90°, B=-90°)"@es ;
    ns1:habilitadoPor ns1:TareaMantenimiento_CalculoCoordenadasEjeA ;
    ns1:textoExtracto "1 Posicionar el eje rotativo A en 90º y el eje B en -90º. 2 Realizar un movimiento de palpación en la dirección del eje Y, sobre el punto 3. 3 Realizar un movimiento de palpación en la dirección del eje Z, sobre el punto 4."@es .

ns1:Parametro_DeltaY1 a ns1:Parametro ;
    rdfs:label "ΔY1 (cota Y en posición 1)"@es ;
    ns1:textoExtracto "Anotar Y1. la cota que aparece en el CNC, denominada en el dibujo ΔY1"@es ;
    ns1:valor "ΔY1" .

ns1:Parametro_DeltaY2 a ns1:Parametro ;
    rdfs:label "ΔY2 (cota Y en posición 2)"@es ;
    ns1:textoExtracto "Anotar Y2. la cota que aparece en el CNC, denominada en el dibujo ΔY2"@es ;
    ns1:valor "ΔY2" .

ns1:Parametro_DeltaZ1 a ns1:Parametro ;
    rdfs:label "ΔZ1 (cota Z en posición 1)"@es ;
    ns1:textoExtracto "Anotar Z1. la cota que aparece en el CNC, denominada en el dibujo ΔZ1"@es ;
    ns1:valor "ΔZ1" .

ns1:Parametro_DeltaZ2 a ns1:Parametro ;
    rdfs:label "ΔZ2 (cota Z en posición 2)"@es ;
    ns1:textoExtracto "Anotar la cota que aparece en el CNC, denominada en el dibujo ΔZ2"@es ;
    ns1:valor "ΔZ2" .

ns1:Parametro_Pz a ns1:Parametro ;
    rdfs:label "Parámetro Pz (coordenada Z del eje A)"@es ;
    ns1:textoExtracto "la coordenada en el eje Z es Pz"@es ;
    ns1:valor "Pz" .

ns1:Parametro_TDATA3 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA3 (coordenada Y del eje A)"@es ;
    ns1:textoExtracto "La coordenada en el eje Y es el parámetro TDATA3"@es ;
    ns1:valor "TDATA3" .

ns1:TareaMantenimiento_CalculoCoordenadasEjeA a ns1:TareaMantenimiento ;
    rdfs:label "Cálculo de coordenadas del eje A (mesa rotativa)"@es ;
    ns1:monitoreaParametro ns1:Parametro_DeltaY1,
        ns1:Parametro_DeltaY2,
        ns1:Parametro_DeltaZ1,
        ns1:Parametro_DeltaZ2,
        ns1:Parametro_Pz,
        ns1:Parametro_TDATA3 ;
    ns1:textoExtracto "Cálculo de las coordenadas del eje A. En el dibujo se muestran dos posiciones distintas que tienen en común el centro del eje A. [...] Cálculos matemáticos."@es .

