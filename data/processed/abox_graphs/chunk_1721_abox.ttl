@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DMC_ControlDinamicoMecanizado a ns1:ModoOperacion ;
    rdfs:label "DMC (Control Dinámico del Mecanizado)"@es ;
    ns1:controla ns1:Herramienta_Fresado,
        ns1:Herramienta_Planeado ;
    ns1:monitoreaParametro ns1:Avance_Parametro,
        ns1:PasoLateral_Parametro,
        ns1:PotenciaCorte_Parametro,
        ns1:ProfundidadPasada_Parametro,
        ns1:VelocidadGiroCabezal_Parametro ;
    ns1:textoExtracto "El DMC adapta el avance modificando el override. El DMC optimiza el uso de la máquina y la herramienta, lo que permite aumentar la tasa de arranque de material (MRR o material removal rate), sin perjudicar la vida de la herramienta, ya que ésta trabaja en sus condiciones nominales."@es ;
    ns1:tieneFrecuencia ns1:Frecuencia_Acabado,
        ns1:Frecuencia_Desbaste .

ns1:Avance_Parametro a ns1:Parametro ;
    rdfs:label "Avance"@es ;
    ns1:textoExtracto "avance"@es .

ns1:Frecuencia_Acabado a ns1:Frecuencia ;
    rdfs:label "Frecuencia de aplicación en acabado"@es ;
    ns1:textoExtracto "Esta función se puede aplicar a operaciones de desbaste y acabado"@es .

ns1:Frecuencia_Desbaste a ns1:Frecuencia ;
    rdfs:label "Frecuencia de aplicación en desbaste"@es ;
    ns1:textoExtracto "Esta función se puede aplicar a operaciones de desbaste y acabado, pero será en operaciones de desbaste donde esta función aporte mayores beneficios en tiempo de mecanizado y vida de herramienta."@es .

ns1:Herramienta_Fresado a ns1:Herramienta ;
    rdfs:label "Herramienta de tipo Fresado"@es ;
    ns1:textoExtracto "El DMC sólo está disponible para operaciones de fresado con herramientas de tipo 'Fresado'"@es .

ns1:Herramienta_Planeado a ns1:Herramienta ;
    rdfs:label "Herramienta de tipo Planeado"@es ;
    ns1:textoExtracto "El DMC sólo está disponible para operaciones de fresado con herramientas de tipo 'Planeado'"@es .

ns1:PasoLateral_Parametro a ns1:Parametro ;
    rdfs:label "Paso lateral"@es ;
    ns1:textoExtracto "paso lateral"@es .

ns1:PotenciaCorte_Parametro a ns1:Parametro ;
    rdfs:label "Potencia de corte (potencia objetivo)"@es ;
    ns1:textoExtracto "La base para la optimización es la potencia de corte a alcanzar, también llamada potencia objetivo. Esta potencia no solo depende de la herramienta, sino también del material y de las condiciones de corte (avance, velocidad de giro del cabezal, profundidad de pasada y paso lateral), por lo que su valor debe ir unido al conjunto herramienta+material+condiciones de corte."@es .

ns1:ProfundidadPasada_Parametro a ns1:Parametro ;
    rdfs:label "Profundidad de pasada"@es ;
    ns1:textoExtracto "profundidad de pasada"@es .

ns1:VelocidadGiroCabezal_Parametro a ns1:Parametro ;
    rdfs:label "Velocidad de giro del cabezal"@es ;
    ns1:textoExtracto "velocidad de giro del cabezal"@es .

