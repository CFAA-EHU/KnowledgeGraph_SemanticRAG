@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Cabezal_DMC a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal con control de potencia" ;
    ns1:controla ns1:ModoOperacion_DMC ;
    ns1:textoExtracto "Cabezal con control de potencia habilitable" .

ns1:ModoOperacion_DMC a ns1:ModoOperacion ;
    rdfs:label "DMC (Dynamic Milling Control)" ;
    ns1:habilitadoPor ns1:Parametro_DMCSPDL ;
    ns1:textoExtracto "DMC" .

ns1:Parametro_DMCSPDL a ns1:Parametro ;
    rdfs:label "DMCSPDL" ;
    ns1:identificador "DMCSPDL" ;
    ns1:monitoreaParametro ns1:Cabezal_DMC ;
    ns1:textoExtracto "DMCSPDL | Cabezal con control de potencia habilitable. Si este parámetro se define con valor ꞏNoꞏ, el CNC no podrá habilitar el DMC en el cabezal." ;
    ns1:valor "No"@es .

