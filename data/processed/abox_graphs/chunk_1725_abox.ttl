@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_G_DMCACTPWR a ns1:Parametro ;
    rdfs:label "G.DMCACTPWR" ;
    ns1:documentadoEn ns1:Tabla_18_4_4_VariablesDMC ;
    ns1:identificador "G.DMCACTPWR" ;
    ns1:monitoreaParametro ns1:ComponenteMecanico_Cabezal ;
    ns1:textoExtracto "(V.)G.DMCACTPWR | Potencia activa en el cabezal, medida por el DMC (porcentaje de la potencia nominal). Unidades: Porcentaje."@es ;
    ns1:valor "Potencia activa en el cabezal (medida por DMC)"@es .

ns1:Parametro_G_DMCOVR a ns1:Parametro ;
    rdfs:label "G.DMCOVR" ;
    ns1:documentadoEn ns1:Tabla_18_4_4_VariablesDMC ;
    ns1:identificador "G.DMCOVR" ;
    ns1:monitoreaParametro ns1:Sistema_DMC ;
    ns1:textoExtracto "(V.)G.DMCOVR | Porcentaje de avance (feed override) calculado por el DMC. Unidades: Porcentaje."@es ;
    ns1:valor "Porcentaje de avance (feed override) calculado por DMC"@es .

ns1:Parametro_G_LEARNEDPWRSP a ns1:Parametro ;
    rdfs:label "G.LEARNEDPWRSP" ;
    ns1:documentadoEn ns1:Tabla_18_4_4_VariablesDMC ;
    ns1:identificador "G.LEARNEDPWRSP" ;
    ns1:monitoreaParametro ns1:Sistema_DMC ;
    ns1:textoExtracto "(V.)G.LEARNEDPWRSP | Potencia objetivo calculada por el DMC en la fase de aprendizaje (porcentaje de la potencia nominal). Unidades: Porcentaje."@es ;
    ns1:valor "Potencia objetivo calculada por el DMC en fase de aprendizaje"@es .

ns1:Esquema_ConfigDMC a ns1:Esquema ;
    rdfs:label "ConfigDMC.osc" ;
    ns1:identificador "ConfigDMC.osc" ;
    ns1:textoExtracto "archivo ConfigDMC.osc (en la carpeta ../Fagor/Tuning) [...] se puede cargar en el osciloscopio desde el menú de softkeys"@es .

ns1:Pagina_733 a ns1:Pagina ;
    ns1:identificador "733" ;
    ns1:textoExtracto "18.4.4 Análisis de un mecanizado [...] Las siguientes variables permiten visualizar el comportamiento del DMC en el osciloscopio."@es .

ns1:ComponenteMecanico_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de mecanizado"@es ;
    ns1:textoExtracto "Potencia activa en el cabezal, medida por el DMC"@es .

ns1:Sistema_DMC a ns1:Sistema ;
    rdfs:label "Sistema DMC"@es ;
    ns1:textoExtracto "comportamiento del DMC en el osciloscopio [...] variables permiten visualizar [...] Potencia objetivo calculada por el DMC [...] Porcentaje de avance calculado por el DMC"@es ;
    ns1:tieneComponente ns1:ComponenteMecanico_Cabezal .

ns1:Tabla_18_4_4_VariablesDMC a ns1:Tabla ;
    rdfs:label "Tabla 18.4.4 - Variables para análisis de DMC"@es ;
    ns1:documentadoEn ns1:Pagina_733 ;
    ns1:ilustradoEn ns1:Esquema_ConfigDMC ;
    ns1:textoExtracto "Variables [...] Descripción [...] (V.)G.LEARNEDPWRSP | Potencia objetivo calculada por el DMC en la fase de aprendizaje [...] (V.)G.DMCACTPWR | Potencia activa en el cabezal [...] (V.)G.DMCOVR | Porcentaje de avance (feed override) calculado por el DMC."@es .

