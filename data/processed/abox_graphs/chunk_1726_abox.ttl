@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Herramienta_Fresado a ns1:Herramienta ;
    rdfs:label "Herramienta de fresado"@es ;
    ns1:requiereMantenimiento ns1:Funcion_DMC ;
    ns1:textoExtracto "herramientas de tipo \"Fresado\""@es .

ns1:Herramienta_Planeado a ns1:Herramienta ;
    rdfs:label "Herramienta de planeado"@es ;
    ns1:requiereMantenimiento ns1:Funcion_DMC ;
    ns1:textoExtracto "herramientas de tipo [...] \"Planeado\""@es .

ns1:Operacion_Acabado a ns1:TareaMantenimiento ;
    rdfs:label "Operación de acabado con DMC"@es ;
    ns1:ejecutadoPor ns1:Funcion_DMC ;
    ns1:textoExtracto "operaciones de [...] acabado"@es .

ns1:Operacion_Desbaste a ns1:TareaMantenimiento ;
    rdfs:label "Operación de desbaste con DMC"@es ;
    ns1:ejecutadoPor ns1:Funcion_DMC ;
    ns1:textoExtracto "operaciones de desbaste donde esta función aporte mayores beneficios en tiempo de mecanizado y vida de herramienta"@es .

ns1:Parametro_FZMAX a ns1:Parametro ;
    rdfs:label "FZMAX (Avance máximo en DMC)"@es ;
    ns1:monitoreaParametro ns1:Funcion_DMC ;
    ns1:textoExtracto "FZMAX{feed}"@es .

ns1:Parametro_FZMIN a ns1:Parametro ;
    rdfs:label "FZMIN (Avance mínimo en DMC)"@es ;
    ns1:monitoreaParametro ns1:Funcion_DMC ;
    ns1:textoExtracto "FZMIN{feed}"@es .

ns1:Parametro_OVRMAX a ns1:Parametro ;
    rdfs:label "OVRMAX (Límite máximo de override en DMC)"@es ;
    ns1:monitoreaParametro ns1:Funcion_DMC ;
    ns1:textoExtracto "OVRMAX{%}"@es .

ns1:Parametro_OVRMIN a ns1:Parametro ;
    rdfs:label "OVRMIN (Límite mínimo de override en DMC)"@es ;
    ns1:monitoreaParametro ns1:Funcion_DMC ;
    ns1:textoExtracto "OVRMIN{%}"@es .

ns1:Parametro_PWRSP a ns1:Parametro ;
    rdfs:label "PWRSP (Potencia objetivo en DMC)"@es ;
    ns1:monitoreaParametro ns1:Funcion_DMC ;
    ns1:textoExtracto "PWRSP{power} Potencia objetivo o potencia de corte idónea, definida como porcentaje de la potencia nominal del cabezal."@es ;
    ns1:valor "porcentaje"@es .

ns1:Sentencia_DMCON a ns1:AccionProhibida ;
    rdfs:label "Sentencia #DMCON"@es ;
    ns1:controla ns1:Funcion_DMC ;
    ns1:identificador "#DMCON" ;
    ns1:textoExtracto "La sentencia #DMCON activa el DMC, siempre sobre el cabezal master."@es .

ns1:Tarea_Programacion_DMC a ns1:TareaMantenimiento ;
    rdfs:label "Programación de la sentencia DMC"@es ;
    ns1:textoExtracto "Esta sentencia se debe programar sola en el bloque. A la hora de definir esta sentencia, todos los comandos son opcionales. Formato de programación: # DMC ON [<PWRSP {power}> <,OVRMIN{%}> <,OVRMAX{%}> <,FZMIN{feed}> <,FZMAX{feed}>]."@es .

ns1:Funcion_DMC a ns1:ModoOperacion ;
    rdfs:label "Dynamic Milling Control (DMC)"@es ;
    ns1:requiereMantenimiento ns1:Tarea_Programacion_DMC ;
    ns1:textoExtracto "El DMC sólo está disponible para operaciones de fresado con herramientas de tipo \"Fresado\" y \"Planeado\". El DMC se puede aplicar a operaciones de desbaste y acabado, pero será en operaciones de desbaste donde esta función aporte mayores beneficios en tiempo de mecanizado y vida de herramienta."@es .

