@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:A21811000_II a ns1:ComponenteMecanico ;
    rdfs:label "Carro Porta-piezas (Subconjunto II)" ;
    ns1:compuestoPor ns1:A21811005,
        ns1:A21811006 ;
    ns1:identificador "A21811000_II" ;
    ns1:textoExtracto "Se distinguen columnas con guías, patines y cableado de sensores; el isométrico resalta la jerarquía de componentes." .

ns1:A21811030 a ns1:ComponenteMecanico ;
    rdfs:label "Piñones contrapeso — Conjunto" ;
    ns1:identificador "A21811030" ;
    ns1:textoExtracto "Vistas múltiples del soporte de piñón con cotas de referencia (distancias entre ejes y alturas). El isométrico facilita la lectura del posicionamiento respecto a la estructura del carro." .

ns1:A21811005 a ns1:ComponenteMecanico ;
    rdfs:label "Guías carro porta-pieza derecha" ;
    ns1:identificador "A21811005" ;
    ns1:textoExtracto "Vistas parciales del zócalo del carro con soportes, alojamientos mecanizados y componentes morados resaltados. Detalles ampliados y sección de perfil muestran roscas, asientos y taladrados de referencia." .

ns1:A21811006 a ns1:ComponenteMecanico ;
    rdfs:label "Guías carro porta-pieza izquierda" ;
    ns1:identificador "A21811006" ;
    ns1:textoExtracto "Lámina simétrica a la anterior: vista longitudinal con esquema de tres patines y sección de anclaje. Se señalan tolerancias de rectitud/planitud y cotas de referencia para montaje." .

