@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix mecanica: <https://vocab.cfaa.eus/broaching/mecanica/> .
@prefix elec: <https://vocab.cfaa.eus/broaching/elec/> .
@prefix base: <https://vocab.cfaa.eus/broaching/base/> .

# Clases
mecanica:CarroPortaPiezas a owl:Class ;
    rdfs:label "Carro Porta-piezas"@es ;
    rdfs:comment "Subconjunto II"@es .

mecanica:ZocaloCarro a owl:Class ;
    rdfs:label "Zócalo del carro"@es .

mecanica:Soporte a owl:Class ;
    rdfs:label "Soporte"@es .

mecanica:AlojamientoMecanizado a owl:Class ;
    rdfs:label "Alojamiento mecanizado"@es .

mecanica:ComponenteMorado a owl:Class ;
    rdfs:label "Componente morado"@es .

mecanica:Roscas a owl:Class ;
    rdfs:label "Roscas"@es .

mecanica:Asiento a owl:Class ;
    rdfs:label "Asiento"@es .

mecanica:TaladradoReferencia a owl:Class ;
    rdfs:label "Taladrado de referencia"@es .

mecanica:GuiaCarroPortaPiezaDerecha a owl:Class ;
    rdfs:label "Guía carro porta-pieza derecha"@es .

mecanica:Deslizadera a owl:Class ;
    rdfs:label "Deslizadera"@es .

mecanica:PatronTaladros a owl:Class ;
    rdfs:label "Patrón de taladros"@es .

mecanica:NotaPrecision a owl:Class ;
    rdfs:label "Nota de precisión"@es .

mecanica:CotaCritica a owl:Class ;
    rdfs:label "Cota crítica"@es .

mecanica:GuiaCarroPortaPiezaIzquierda a owl:Class ;
    rdfs:label "Guía carro porta-pieza izquierda"@es .

mecanica:Patin a owl:Class ;
    rdfs:label "Patín"@es .

mecanica:SeccionAnclaje a owl:Class ;
    rdfs:label "Sección de anclaje"@es .

mecanica:ToleranciaRectitud a owl:Class ;
    rdfs:label "Tolerancia de rectitud"@es .

mecanica:ToleranciaPlanitud a owl:Class ;
    rdfs:label "Tolerancia de planitud"@es .

mecanica:CotaReferencia a owl:Class ;
    rdfs:label "Cota de referencia"@es .

mecanica:PinonContrapeso a owl:Class ;
    rdfs:label "Piñón contrapeso"@es .

mecanica:SoportePinon a owl:Class ;
    rdfs:label "Soporte de piñón"@es .

mecanica:CotaReferenciaSoportePinon a owl:Class ;
    rdfs:label "Cota de referencia del soporte de piñón"@es .

# Propiedades de objeto
mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:label "tiene componente"@es .

mecanica:tieneSoporte a owl:ObjectProperty ;
    rdfs:label "tiene soporte"@es .

mecanica:tieneAlojamientoMecanizado a owl:ObjectProperty ;
    rdfs:label "tiene alojamiento mecanizado"@es .

mecanica:tieneComponenteMorado a owl:ObjectProperty ;
    rdfs:label "tiene componente morado"@es .

mecanica:tieneRoscas a owl:ObjectProperty ;
    rdfs:label "tiene roscas"@es .

mecanica:tieneAsiento a owl:ObjectProperty ;
    rdfs:label "tiene asiento"@es .

mecanica:tieneTaladradoReferencia a owl:ObjectProperty ;
    rdfs:label "tiene taladrado de referencia"@es .

mecanica:tieneDeslizadera a owl:ObjectProperty ;
    rdfs:label "tiene deslizadera"@es .

mecanica:tienePatronTaladros a owl:ObjectProperty ;
    rdfs:label "tiene patrón de taladros"@es .

mecanica:tieneNotaPrecision a owl:ObjectProperty ;
    rdfs:label "tiene nota de precisión"@es .

mecanica:tieneCotaCritica a owl:ObjectProperty ;
    rdfs:label "tiene cota crítica"@es .

mecanica:tienePatin a owl:ObjectProperty ;
    rdfs:label "tiene patín"@es .

mecanica:tieneSeccionAnclaje a owl:ObjectProperty ;
    rdfs:label "tiene sección de anclaje"@es .

mecanica:tieneToleranciaRectitud a owl:ObjectProperty ;
    rdfs:label "tiene tolerancia de rectitud"@es .

mecanica:tieneToleranciaPlanitud a owl:ObjectProperty ;
    rdfs:label "tiene tolerancia de planitud"@es .

mecanica:tieneCotaReferencia a owl:ObjectProperty ;
    rdfs:label "tiene cota de referencia"@es .

mecanica:tienePinonContrapeso a owl:ObjectProperty ;
    rdfs:label "tiene piñón contrapeso"@es .

mecanica:tieneSoportePinon a owl:ObjectProperty ;
    rdfs:label "tiene soporte de piñón"@es .

mecanica:tieneCotaReferenciaSoportePinon a owl:ObjectProperty ;
    rdfs:label "tiene cota de referencia del soporte de piñón"@es .

# Propiedades de datos
mecanica:tieneDiametro a owl:DatatypeProperty ;
    rdfs:label "tiene diámetro"@es ;
    rdfs:range xsd:decimal .

mecanica:tieneLongitud a owl:DatatypeProperty ;
    rdfs:label "tiene longitud"@es ;
    rdfs:range xsd:decimal .

mecanica:tieneClase a owl:DatatypeProperty ;
    rdfs:label "tiene clase"@es ;
    rdfs:range xsd:string .

mecanica:tieneCota a owl:DatatypeProperty ;
    rdfs:label "tiene cota"@es ;
    rdfs:range xsd:decimal .

mecanica:tieneNumero a owl:DatatypeProperty ;
    rdfs:label "tiene número"@es ;
    rdfs:range xsd:integer .

mecanica:tieneModelo a owl:DatatypeProperty ;
    rdfs:label "tiene modelo"@es ;
    rdfs:range xsd:string .

mecanica:tieneCodigo a owl:DatatypeProperty ;
    rdfs:label "tiene código"@es ;
    rdfs:range xsd:string .