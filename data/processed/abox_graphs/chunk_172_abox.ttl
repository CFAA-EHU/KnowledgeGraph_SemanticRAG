ex:tieneAlojamientosMecanizados a owl:ObjectProperty ;
    rdfs:label "tiene alojamientos mecanizados" ;
    rdfs:domain ex:CarroPortaPieza ;
    rdfs:range ex:AlojamientoMecanizado ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/>.

ex:tieneComponentesMorados a owl:ObjectProperty ;
    rdfs:label "tiene componentes morados" ;
    rdfs:domain ex:CarroPortaPieza ;
    rdfs:range ex:ComponenteMorado ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/>.