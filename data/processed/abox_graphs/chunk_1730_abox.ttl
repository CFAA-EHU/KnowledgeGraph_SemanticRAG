@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DMC_ModoAutomatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático (DMC)" ;
    ns1:textoExtracto "El DMC sólo puede estar activo en modo automático; no se activa en modo manual." .

ns1:DMC_ModoEjecucion a ns1:ModoOperacion ;
    rdfs:label "Modo ejecución (DMC)" ;
    ns1:textoExtracto "El DMC sólo puede estar activo en ejecución; en simulación, el CNC analizará las sentencias de activación y desactivación, pero no pondrá en marcha el DMC." .

ns1:DMC_SistemaControl a ns1:Sistema ;
    rdfs:label "Sistema DMC" ;
    ns1:controla ns1:DMC_ParametroAvancePorDiente,
        ns1:DMC_ParametroPotenciaObjetivo ;
    ns1:requiereMantenimiento ns1:DMC_FaseAprendizaje ;
    ns1:textoExtracto "El DMC es incompatible con algunos tipos de operaciones, como roscados, taladrados, etc." .

ns1:Softkey_AprendizajeDMC a ns1:InterfazUsuario ;
    rdfs:label "Softkey 'Aprendizaje DMC'" ;
    ns1:habilitadoPor ns1:DMC_ModoInspeccionHerramienta ;
    ns1:textoExtracto "permite repetir la fase de aprendizaje pulsando la softkey 'Aprendizaje DMC'." .

ns1:TablaHerramientas_DMC a ns1:Tabla ;
    rdfs:label "Tabla de herramientas (DMC)" ;
    ns1:documentadoEn ns1:Manual_DMC ;
    ns1:textoExtracto "definir el número de dientes de la herramienta en la tabla de herramientas." .

ns1:DMC_FaseAprendizaje a ns1:TareaMantenimiento ;
    rdfs:label "Fase de aprendizaje (DMC)" ;
    ns1:textoExtracto "permite repetir la fase de aprendizaje pulsando la softkey 'Aprendizaje DMC'." .

ns1:DMC_ModoInspeccionHerramienta a ns1:ModoOperacion ;
    rdfs:label "Modo inspección de herramienta" ;
    ns1:textoExtracto "Al entrar en la inspección de herramienta se desactiva y se recupera tras la reposición de ejes." .

ns1:DMC_ParametroAvancePorDiente a ns1:Parametro ;
    rdfs:label "Avance por diente (DMC)" ;
    ns1:textoExtracto "El avance modificado con el override respeta el avance por diente mínimo y máximo fijado para la herramienta." .

ns1:DMC_ParametroPotenciaObjetivo a ns1:Parametro ;
    rdfs:label "Potencia objetivo (DMC)" ;
    ns1:textoExtracto "La potencia objetivo se programa como un porcentaje de la potencia nominal del cabezal." .

ns1:Manual_DMC a ns1:Manual ;
    rdfs:label "Manual de programación DMC" ;
    ns1:textoExtracto "Ver en la página '18.4.1 Funcionamiento del DMC.' 728." .

