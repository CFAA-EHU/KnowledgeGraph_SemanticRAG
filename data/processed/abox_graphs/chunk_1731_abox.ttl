@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SoftkeyAprendizajeDMC a ns1:InterfazUsuario ;
    rdfs:label "Softkey 'Aprendizaje DMC'"@es ;
    ns1:habilitadoPor ns1:ModoInspeccionHerramienta ;
    ns1:textoExtracto "permite repetir la fase de aprendizaje pulsando la softkey 'Aprendizaje DMC'"@es .

ns1:ModoInspeccionHerramienta a ns1:ModoOperacion ;
    rdfs:label "Modo de inspección de herramienta"@es ;
    ns1:textoExtracto "El entrar en el modo de inspección de herramienta, el DMC se desactiva. Al finalizar la inspección de herramienta, el DMC se activa automáticamente..."@es .

