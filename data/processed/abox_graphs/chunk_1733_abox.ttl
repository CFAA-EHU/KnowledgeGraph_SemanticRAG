@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Funcion_M02 a ns1:AccionProhibida,
        ns1:Tabla ;
    rdfs:label "Función M02 (fin de programa)" ;
    ns1:identificador "M02" ;
    ns1:solucionaFallo ns1:DMC_Activado ;
    ns1:textoExtracto "Las funciones M02 o M30 (fin de programa) [...] desactivan el DMC." .

ns1:Funcion_M30 a ns1:AccionProhibida,
        ns1:Tabla ;
    rdfs:label "Función M30 (fin de programa)" ;
    ns1:identificador "M30" ;
    ns1:solucionaFallo ns1:DMC_Activado ;
    ns1:textoExtracto "Las funciones M02 o M30 (fin de programa) [...] desactivan el DMC." .

ns1:Funcion_M5 a ns1:AccionProhibida,
        ns1:Tabla ;
    rdfs:label "Función M5 (parada de cabezal)" ;
    ns1:identificador "M5" ;
    ns1:solucionaFallo ns1:DMC_Activado ;
    ns1:textoExtracto "Una parada de cabezal, función M5, desactiva el DMC." .

ns1:Reset_CNC a ns1:AccionProhibida ;
    rdfs:label "Reset del CNC" ;
    ns1:solucionaFallo ns1:DMC_Activado ;
    ns1:textoExtracto "el reset también desactivan el DMC." .

ns1:Sentencia_DMCOFF a ns1:AccionProhibida ;
    rdfs:label "Sentencia #DMCOFF" ;
    ns1:identificador "#DMCOFF" ;
    ns1:solucionaFallo ns1:DMC_Activado ;
    ns1:textoExtracto "La sentencia #DMCOFF desactiva el DMC. [...] # DMC OFF #DMC OFF (El CNC desactiva el DMC)." .

ns1:DMC_Activado a ns1:AvisoSeguridad ;
    rdfs:label "DMC activado" ;
    ns1:textoExtracto "La sentencia #DMCOFF desactiva el DMC." .

