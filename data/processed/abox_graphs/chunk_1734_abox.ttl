@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_G_CNCFRO a ns1:Parametro ;
    rdfs:label "Porcentaje de avance (feed override) seleccionado en el conmutador del panel (G.CNCFRO)"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables1823 ;
    ns1:textoExtracto "(V.)[ch].G.CNCFRO - Porcentaje de avance (feed override) seleccionado en el conmutador del panel de mando. Unidades: Porcentaje."@es ;
    ns1:valor "Porcentaje" .

ns1:Parametro_G_FRO a ns1:Parametro ;
    rdfs:label "Porcentaje de avance (feed override) activo (G.FRO)"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables1823 ;
    ns1:textoExtracto "(V.)[ch].G.FRO - Porcentaje de avance (feed override) activo. Unidades: Porcentaje."@es ;
    ns1:valor "Porcentaje" .

ns1:Parametro_G_NCUTTERS a ns1:Parametro ;
    rdfs:label "Número de dientes de la herramienta en preparación (G.NCUTTERS)"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables1823 ;
    ns1:textoExtracto "(V.)[ch].G.NCUTTERS - Herramienta en preparación. Número de dientes. Unidades: Dientes."@es ;
    ns1:valor "Dientes" .

