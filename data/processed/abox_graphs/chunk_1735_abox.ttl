@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:HerramientaActiva a ns1:Herramienta ;
    rdfs:label "Herramienta activa con corrector de offset"@es ;
    ns1:monitoreaParametro ns1:Variable_TM_NCUTTERS ;
    ns1:textoExtracto "Corrector [offset] de la herramienta activa. Número de dientes."@es .

ns1:Variable_TM_NCUTTERS a ns1:Parametro ;
    rdfs:label "Número de dientes de la herramienta activa"@es ;
    ns1:identificador "TM.NCUTTERS[offset]" ;
    ns1:textoExtracto "Número de dientes. Unidades: Dientes. | R/W | R | R | (V.)[ch].TM.NCUTTERS[offset] Corrector [offset] de la herramienta activa. Número de dientes."@es ;
    ns1:valor "Dientes"^^xsd:string .

