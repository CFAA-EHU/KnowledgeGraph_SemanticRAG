@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de máquina"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables_18_2_3 ;
    ns1:textoExtracto "potencia nominal del cabezal"@es .

ns1:Herramienta_DMC a ns1:Herramienta ;
    rdfs:label "Herramienta genérica para DMC"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables_18_2_3 ;
    ns1:textoExtracto "Corrector [offset] de la herramienta [tool]."@es .

ns1:Parametro_DMCFZMAX a ns1:Parametro ;
    rdfs:label "Avance máximo por diente (DMCFZMAX)"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables_18_2_3 ;
    ns1:identificador "[ch].G.DMCFZMAX" ;
    ns1:textoExtracto "Máximo avance por diente permitido durante el DMC. Valor programado en el comando FZMAX de la sentencia #DMCON. Unidades: Milímetros/diente o pulgadas/diente."@es ;
    ns1:valor "Milímetros/diente o pulgadas/diente" .

ns1:Parametro_DMCFZMIN a ns1:Parametro ;
    rdfs:label "Avance mínimo por diente (DMCFZMIN)"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables_18_2_3 ;
    ns1:identificador "[ch].G.DMCFZMIN" ;
    ns1:textoExtracto "Mínimo avance por diente permitido durante el DMC. Valor programado en el comando FZMIN de la sentencia #DMCON. Unidades: Milímetros/diente o pulgadas/diente."@es ;
    ns1:valor "Milímetros/diente o pulgadas/diente" .

ns1:Parametro_DMCON a ns1:Parametro ;
    rdfs:label "Estado del DMC (DMCON)"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables_18_2_3 ;
    ns1:identificador "[ch].G.DMCON" ;
    ns1:textoExtracto "Estado del DMC. Unidades: -."@es .

ns1:Parametro_DMCOVRMAX a ns1:Parametro ;
    rdfs:label "Avance máximo permitido (DMCOVRMAX)"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables_18_2_3 ;
    ns1:identificador "[ch].G.DMCOVRMAX" ;
    ns1:textoExtracto "Máximo porcentaje de avance (feed override) permitido para el DMC. Valor programado en el comando OVRMAX de la sentencia #DMCON. Unidades: Porcentaje."@es ;
    ns1:valor "Porcentaje máximo de feed override" .

ns1:Parametro_DMCOVRMIN a ns1:Parametro ;
    rdfs:label "Avance mínimo permitido (DMCOVRMIN)"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables_18_2_3 ;
    ns1:identificador "[ch].G.DMCOVRMIN" ;
    ns1:textoExtracto "Mínimo porcentaje de avance (feed override) permitido para el DMC. Valor programado en el comando OVRMIN de la sentencia #DMCON. Unidades: Porcentaje."@es ;
    ns1:valor "Porcentaje mínimo de feed override" .

ns1:Parametro_DMCPWRSP a ns1:Parametro ;
    rdfs:label "Potencia objetivo DMC (DMCPWRSP)"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables_18_2_3 ;
    ns1:identificador "[ch].G.DMCPWRSP" ;
    ns1:textoExtracto "Potencia objetivo, definida como porcentaje de la potencia nominal del cabezal. Valor programado en el comando PWRSP de la sentencia #DMCON. Unidades: Porcentaje."@es ;
    ns1:valor "Porcentaje de potencia nominal" .

ns1:Parametro_LEARNEDPWRSP a ns1:Parametro ;
    rdfs:label "Potencia objetivo aprendida (LEARNEDPWRSP)"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables_18_2_3 ;
    ns1:identificador "[ch].G.LEARNEDPWRSP" ;
    ns1:textoExtracto "Potencia objetivo calculada por el DMC en la fase de aprendizaje (porcentaje de la potencia nominal). Unidades: Porcentaje."@es ;
    ns1:valor "Porcentaje de potencia nominal" .

ns1:Parametro_TM_NCUTTERST a ns1:Parametro ;
    rdfs:label "Corrector de herramienta (TM.NCUTTERST[tool][offset])"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables_18_2_3 ;
    ns1:identificador "TM.NCUTTERST[tool][offset]" ;
    ns1:textoExtracto "Corrector [offset] de la herramienta [tool]. Número de dientes. Unidades: Dientes."@es ;
    ns1:valor "Número de dientes" .

ns1:Tabla_ResumenVariables_18_2_3 a ns1:Tabla ;
    rdfs:label "Tabla de resumen de variables DMC (páginas 725-726)"@es ;
    ns1:documentadoEn ns1:Pagina_725_726 ;
    ns1:textoExtracto """
| Variables. | PRG | PLC | INT |
| --- | --- | --- | --- |
| (V.)TM.NCUTTERST[tool][offset] ... (V.)[ch].G.LEARNEDPWRSP
"""@es .

