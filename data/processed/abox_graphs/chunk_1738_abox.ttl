@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_EjecucionCNC a ns1:ModoOperacion ;
    rdfs:label "Ejecución de bloques por el CNC"@es ;
    ns1:controla ns1:Parametro_PotenciaCabezalVacio,
        ns1:Parametro_TiempoAhorradoDMC ;
    ns1:textoExtracto "El CNC evalúa la variable durante la ejecución (detiene la preparación de bloques)... El CNC evalúa la variable durante la ejecución, pero no detiene la preparación de bloques"@es .

ns1:Parametro_PotenciaCabezalVacio a ns1:Parametro ;
    rdfs:label "Potencia del cabezal en vacío medida por el DMC"@es ;
    ns1:identificador "R" ;
    ns1:monitoreaParametro ns1:Sistema_DMC ;
    ns1:textoExtracto "Potencia del cabezal en vacío medida por el DMC. Unidades: Kilowatios."@es ;
    ns1:valor "Kilowatios"@es .

ns1:Parametro_TiempoAhorradoDMC a ns1:Parametro ;
    rdfs:label "Tiempo ahorrado por acción del DMC"@es ;
    ns1:identificador "V.[ch].G.DMCSAVEDTIME" ;
    ns1:monitoreaParametro ns1:Sistema_DMC ;
    ns1:textoExtracto "Tiempo ahorrado por acción del DMC. Unidades: Segundos."@es ;
    ns1:valor "Segundos"@es .

ns1:Sistema_DMC a ns1:Sistema ;
    rdfs:label "DMC (Dynamic Machining Control)"@es ;
    ns1:textoExtracto "Potencia del cabezal en vacío medida por el DMC... Tiempo ahorrado por acción del DMC"@es .

