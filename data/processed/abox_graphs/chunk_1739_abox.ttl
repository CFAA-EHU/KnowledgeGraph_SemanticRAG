@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaDatosHerramientas_18_3 a ns1:Tabla ;
    rdfs:label "Tabla de herramientas (Sección 18.3)"@es ;
    ns1:detalladoEnEsquema ns1:Parametro_NCUTTERS ;
    ns1:documentadoEn ns1:Pagina_727 ;
    ns1:textoExtracto "Tabla de herramientas. A B (A)Tipo de herramienta. (B)Número de dientes (entre 1 y 100)."@es .

ns1:Herramienta_Escariado a ns1:Herramienta ;
    rdfs:label "Herramienta de escariado"@es ;
    ns1:requiereMantenimiento ns1:TareaMantenimiento_DefinirDatos ;
    ns1:textoExtracto "Este dato sólo está disponible para las herramientas de tipo 'Escariado'."@es .

ns1:Herramienta_Fresado a ns1:Herramienta ;
    rdfs:label "Herramienta de fresado"@es ;
    ns1:requiereMantenimiento ns1:TareaMantenimiento_DefinirDatos ;
    ns1:textoExtracto "Este dato sólo está disponible para las herramientas de tipo 'Fresado'."@es .

ns1:Herramienta_Otros a ns1:Herramienta ;
    rdfs:label "Herramienta (tipo Otros)"@es ;
    ns1:requiereMantenimiento ns1:TareaMantenimiento_DefinirDatos ;
    ns1:textoExtracto "Este dato sólo está disponible para las herramientas de tipo 'Otros'."@es .

ns1:Herramienta_Planeado a ns1:Herramienta ;
    rdfs:label "Herramienta de planeado"@es ;
    ns1:requiereMantenimiento ns1:TareaMantenimiento_DefinirDatos ;
    ns1:textoExtracto "Este dato sólo está disponible para las herramientas de tipo 'Planeado'."@es .

ns1:Herramienta_Taladrado a ns1:Herramienta ;
    rdfs:label "Herramienta de taladrado"@es ;
    ns1:requiereMantenimiento ns1:TareaMantenimiento_DefinirDatos ;
    ns1:textoExtracto "Este dato sólo está disponible para las herramientas de tipo 'Taladrado'."@es .

ns1:Parametro_NCUTTERS a ns1:Parametro ;
    rdfs:label "Número de dientes (NCUTTERS)"@es ;
    ns1:identificador "NCUTTERS" ;
    ns1:monitoreaParametro ns1:Herramienta_Escariado,
        ns1:Herramienta_Fresado,
        ns1:Herramienta_Otros,
        ns1:Herramienta_Planeado,
        ns1:Herramienta_Taladrado ;
    ns1:textoExtracto "Número de dientes (entre 1 y 100). [...] (V.)[ch].G.NCUTTERS | Herramienta en preparación. Número de dientes. Unidades: Dientes."@es ;
    ns1:valor "1-100" .

ns1:Pagina_727 a ns1:Pagina ;
    ns1:identificador "727" ;
    ns1:textoExtracto "18.3 Definir los datos de la herramienta."@es .

ns1:TareaMantenimiento_DefinirDatos a ns1:TareaMantenimiento ;
    rdfs:label "Definir número de dientes en herramienta"@es ;
    ns1:documentadoEn ns1:Pagina_727 ;
    ns1:textoExtracto "Para que el CNC pueda limitar el avance por diente entre el mínimo y el máximo definido en la sentencia #DMCON, hay que definir el número de dientes de la herramienta, bien en la tabla de herramientas o bien mediante variables."@es .

