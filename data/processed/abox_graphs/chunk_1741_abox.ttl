@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FaseAprendizaje_DMC a ns1:TareaMantenimiento ;
    rdfs:label "Fase de aprendizaje del DMC" ;
    ns1:requiereMantenimiento ns1:DMC_ModoAutomatico ;
    ns1:textoExtracto "comenzará una fase de aprendizaje, tanto si al activar DMC se había programado PWRSP como si no. [...] La fase de aprendizaje dura un minuto, a partir de que la herramienta entre en la pieza una distancia igual al radio." .

ns1:Parametro_AvanceProgramado a ns1:Parametro ;
    rdfs:label "Valor de avance programado (DMC)" ;
    ns1:textoExtracto "El DMC espera a que el avance alcance el valor programado" .

ns1:Parametro_DistanciaEntradaPieza a ns1:Parametro ;
    rdfs:label "Distancia de entrada a pieza (radio)" ;
    ns1:textoExtracto "a partir de que la herramienta entre en la pieza una distancia igual al radio" ;
    ns1:valor "radio" .

ns1:Parametro_PotenciaObjetivo a ns1:Parametro ;
    rdfs:label "Potencia objetivo (DMC)" ;
    ns1:textoExtracto "calcula la potencia objetivo ('potencia consumida' – 'potencia en vacío')." ;
    ns1:valor "potencia consumida – potencia en vacío" .

ns1:Parametro_TiempoAprendizaje a ns1:Parametro ;
    rdfs:label "Duración de fase de aprendizaje (DMC)" ;
    ns1:textoExtracto "La fase de aprendizaje dura un minuto" ;
    ns1:valor "1 minuto" .

ns1:Softkey_AprendizajeDMC a ns1:InterfazUsuario ;
    rdfs:label "Softkey 'Aprendizaje DMC'" ;
    ns1:habilitadoPor ns1:DMC_ModoAutomatico ;
    ns1:textoExtracto "pulsando la softkey 'Aprendizaje DMC' del modo automático." .

ns1:DMC_ModoAutomatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático del DMC" ;
    ns1:textoExtracto "La fase de aprendizaje se puede repetir en cualquier momento, con el DMC activo, pulsando la softkey 'Aprendizaje DMC' del modo automático." .

