@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:DMC_ModoOperacion_18_4_1 a ns1:ModoOperacion ;
    rdfs:label "Funcionamiento del DMC (Dynamic Milling Control)"@es ;
    ns1:activaAlarma ns1:AvisoSeguridad_3100,
        ns1:AvisoSeguridad_3101 ;
    ns1:monitoreaParametro ns1:Parametro_PotenciaConsumida_Cabezal ;
    ns1:textoExtracto "vacío y la potencia objetivo durante el mecanizado son parecidos, es posible que el DMC no pueda distinguir con exactitud las entradas y salidas de la pieza, o que detecte falsas entradas o salidas. [...] Vigilancia de la potencia consumida. Durante el funcionamiento, el DMC vigila continuamente la potencia consumida por el cabezal, para detectar problemas con la herramienta o en el mecanizado."@es .

ns1:Herramienta_Mecanizado a ns1:Herramienta ;
    rdfs:label "Herramienta de mecanizado (genérica)"@es ;
    ns1:textoExtracto "problemas con la herramienta o en el mecanizado. [...] sustituir la herramienta dañada. [...] la herramienta está desgastada o deteriorada."@es .

ns1:Parametro_PotenciaObjetivo a ns1:Parametro ;
    rdfs:label "Potencia objetivo (DMC)"@es ;
    ns1:textoExtracto "revisar el valor de la potencia objetivo. [...] Programar una potencia objetivo mayor, que no se va a alcanzar realmente, puede tener como consecuencia que el DMC no detecte nunca entradas a la pieza."@es ;
    ns1:valor "20%"^^xsd:string .

ns1:AvisoSeguridad_3100 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de herramienta desgastada (DMC)"@es ;
    ns1:identificador "3100" ;
    ns1:textoExtracto "Si el DMC detecta un consumo de potencia excesivo durante cierto tiempo, considera que la herramienta está desgastada o deteriorada y muestra el aviso 3100 sin detener la ejecución."@es .

ns1:AvisoSeguridad_3101 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de colisión (DMC)"@es ;
    ns1:identificador "3101" ;
    ns1:textoExtracto "Si la potencia instantánea supera la potencia objetivo en un rango prefijado, el CNC considera que ha habido un colisión. En este caso, el CNC muestra el aviso 3101, detiene el avance de los ejes manteniendo el giro del cabezal."@es .

ns1:Parametro_PotenciaConsumida_Cabezal a ns1:Parametro ;
    rdfs:label "Potencia consumida por el cabezal"@es ;
    ns1:textoExtracto "el DMC vigila continuamente la potencia consumida por el cabezal, para detectar problemas con la herramienta o en el mecanizado."@es .

