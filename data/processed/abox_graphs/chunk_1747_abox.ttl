@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_DMC_ModoAutomatico a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de usuario del DMC (modo automático)"@es ;
    ns1:textoExtracto "Opciones del DMC (menú desplegable). • Repetir la fase de aprendizaje del DMC. • Desactivar el DMC."@es ;
    ns1:tieneComponente ns1:Softkey_DesactivarDMC,
        ns1:Softkey_ReactivarDMC,
        ns1:Softkey_RepetirAprendizajeDMC .

ns1:Softkey_DesactivarDMC a ns1:Componente ;
    rdfs:label "Softkey 'Desactivar DMC'"@es ;
    ns1:textoExtracto "Esta softkey permite desactivar el DMC."@es .

ns1:Softkey_ReactivarDMC a ns1:Componente ;
    rdfs:label "Softkey 'Re-activar DMC'"@es ;
    ns1:textoExtracto "Esta softkey permite re-activar el DMC."@es .

ns1:Softkey_RepetirAprendizajeDMC a ns1:Componente ;
    rdfs:label "Softkey 'Repetir fase de aprendizaje del DMC'"@es ;
    ns1:textoExtracto "Esta softkey permite repetir la fase de aprendizaje del DMC en cualquier momento, siempre que el DMC esté activo."@es .

