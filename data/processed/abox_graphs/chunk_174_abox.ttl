@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConjuntoCepillos a ns1:ComponenteMecanico ;
    rdfs:label "Conjunto cepillos" ;
    ns1:compuestoPor ns1:CartuchoCepillos,
        ns1:CilindroNeumatico,
        ns1:CuerpoCepillos,
        ns1:GuiaCepillos,
        ns1:PasoAire,
        ns1:TornilleriaCepillos ;
    ns1:identificador "A21816000" ;
    ns1:textoExtracto "Conjunto con secciones A-A y B-B de un módulo de limpieza: cuerpo, cilindro neumático y cartucho de cepillos. Los isométricos y vistas planas muestran guías, tornillería y pasos de aire; cotas 'REF' sitúan longitudes clave." .

ns1:ConjuntoContrapeso a ns1:ComponenteMecanico ;
    rdfs:label "Conjunto contrapeso" ;
    ns1:compuestoPor ns1:BloqueDoble,
        ns1:Deslizador,
        ns1:GuiaLateral ;
    ns1:identificador "A21811090" ;
    ns1:textoExtracto "Isométricos y alzados del bloque doble con guías laterales; detalle A (1:5) y detalle B (1:1) enseñan fijaciones y paso de cableado. La sección A-A muestra el apilamiento y anclaje de los deslizadores." .

ns1:EsquemaHidraulico a ns1:Esquema ;
    rdfs:label "Esquema hidráulico del grupo" ;
    ns1:textoExtracto "Esquema hidráulico del grupo: depósito 130 L con sensor de nivel (BL726), M6 motor del grupo, bomba y retorno al tanque." ;
    ns1:tieneComponente ns1:BombaHidraulica,
        ns1:Deposito130L,
        ns1:MotorGrupoM6,
        ns1:SensorNivelBL726 .

ns1:PlatoDivisor0 a ns1:ComponenteMecanico ;
    rdfs:label "Plato divisor 0º" ;
    ns1:compuestoPor ns1:AlojamientoCentral,
        ns1:CoronaDentada,
        ns1:PatronFijacion ;
    ns1:identificador "A21813100" ;
    ns1:textoExtracto "Vistas lateral, frontal y planta del divisor con corona dentada exterior y alojamiento central taladrado. Se aprecia el acoplamiento al servomotor y el patrón circular de fijación en la mesa." .

ns1:PlatoDivisor15 a ns1:ComponenteMecanico ;
    rdfs:label "Plato divisor 15º" ;
    ns1:compuestoPor ns1:DentadoPerimetral,
        ns1:PatronAgujeros ;
    ns1:identificador "A21813115" ;
    ns1:textoExtracto "Misma familia de vistas con inclinación de 15°. Trazas y ejes indican la basculación; se mantiene el dentado perimetral y el patrón de agujeros para el amarre de utillajes." .

ns1:AlojamientoCentral a ns1:ComponenteMecanico ;
    rdfs:label "alojamiento central taladrado" ;
    ns1:textoExtracto "alojamiento central taladrado" .

ns1:BloqueDoble a ns1:ComponenteMecanico ;
    rdfs:label "bloque doble" ;
    ns1:textoExtracto "bloque doble con guías laterales" .

ns1:BombaHidraulica a ns1:ComponenteHidraulico ;
    rdfs:label "bomba" ;
    ns1:textoExtracto "bomba" .

ns1:CartuchoCepillos a ns1:ComponenteMecanico ;
    rdfs:label "cartucho de cepillos" ;
    ns1:textoExtracto "cartucho de cepillos" .

ns1:CilindroNeumatico a ns1:ComponenteMecanico ;
    rdfs:label "cilindro neumático" ;
    ns1:textoExtracto "cilindro neumático" .

ns1:CoronaDentada a ns1:ComponenteMecanico ;
    rdfs:label "corona dentada exterior" ;
    ns1:textoExtracto "corona dentada exterior" .

ns1:CuerpoCepillos a ns1:ComponenteMecanico ;
    rdfs:label "cuerpo" ;
    ns1:textoExtracto "cuerpo" .

ns1:DentadoPerimetral a ns1:ComponenteMecanico ;
    rdfs:label "dentado perimetral" ;
    ns1:textoExtracto "dentado perimetral" .

ns1:Deposito130L a ns1:ComponenteHidraulico ;
    rdfs:label "depósito 130 L" ;
    ns1:textoExtracto "depósito 130 L" .

ns1:Deslizador a ns1:ComponenteMecanico ;
    rdfs:label "deslizadores" ;
    ns1:textoExtracto "apilamiento y anclaje de los deslizadores" .

ns1:GuiaCepillos a ns1:ComponenteMecanico ;
    rdfs:label "guías" ;
    ns1:textoExtracto "guías" .

ns1:GuiaLateral a ns1:ComponenteMecanico ;
    rdfs:label "guías laterales" ;
    ns1:textoExtracto "guías laterales" .

ns1:MotorGrupoM6 a ns1:ComponenteMecanico ;
    rdfs:label "M6 motor del grupo" ;
    ns1:identificador "M6" ;
    ns1:textoExtracto "M6 motor del grupo" .

ns1:PasoAire a ns1:ComponenteMecanico ;
    rdfs:label "pasos de aire" ;
    ns1:textoExtracto "pasos de aire" .

ns1:PatronAgujeros a ns1:ComponenteMecanico ;
    rdfs:label "patrón de agujeros" ;
    ns1:textoExtracto "patrón de agujeros para el amarre de utillajes" .

ns1:PatronFijacion a ns1:ComponenteMecanico ;
    rdfs:label "patrón circular de fijación" ;
    ns1:textoExtracto "patrón circular de fijación en la mesa" .

ns1:SensorNivelBL726 a ns1:Sensor ;
    rdfs:label "sensor de nivel (BL726)" ;
    ns1:identificador "BL726" ;
    ns1:textoExtracto "sensor de nivel (BL726)" .

ns1:TornilleriaCepillos a ns1:ComponenteMecanico ;
    rdfs:label "tornillería" ;
    ns1:textoExtracto "tornillería" .

