@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_OverrideControl a ns1:InterfazUsuario ;
    rdfs:label "Control del override para optimizar la potencia"@es ;
    ns1:monitoreaParametro ns1:Parametro_MaxDMCovr ;
    ns1:textoExtracto "Control del override para optimizar la potencia"@es .

ns1:ModoOperacion_AvanceMaximoPorDiente a ns1:ModoOperacion ;
    rdfs:label "Mecanizado al avance máximo por diente"@es ;
    ns1:textoExtracto "Mecanizado al avance máximo por diente"@es .

ns1:ModoOperacion_AvanceMinimoPorDiente a ns1:ModoOperacion ;
    rdfs:label "Mecanizado al avance mínimo por diente"@es ;
    ns1:textoExtracto "Mecanizado al avance mínimo por diente"@es .

ns1:ModoOperacion_G00 a ns1:ModoOperacion ;
    rdfs:label "Mecanizado en G00"@es ;
    ns1:identificador "G00" ;
    ns1:textoExtracto "Mecanizado en G00"@es .

ns1:TareaMantenimiento_EntradaPieza a ns1:TareaMantenimiento ;
    rdfs:label "Entrada a la pieza"@es ;
    ns1:textoExtracto "Entrada a la pieza"@es .

ns1:TareaMantenimiento_MovimientoVacio a ns1:TareaMantenimiento ;
    rdfs:label "Movimiento en vacío"@es ;
    ns1:habilitadoPor ns1:Parametro_MaxDMCovr ;
    ns1:textoExtracto "Movimiento en vacío"@es .

ns1:Parametro_MaxDMCovr a ns1:Parametro ;
    rdfs:label "Parámetro máquina MAXDMCOVR"@es ;
    ns1:identificador "MAXDMCOVR" ;
    ns1:textoExtracto "override máximo (parámetro máquina MAXDMCOVR)"@es .

