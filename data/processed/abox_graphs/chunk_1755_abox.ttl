@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Comando_DMCOFF a ns1:InterfazUsuario ;
    rdfs:label "#DMCOFF"@es ;
    ns1:textoExtracto "comando OFF para anularla (por ejemplo, #DMC OFF)"@es .

ns1:Comando_DMCON a ns1:InterfazUsuario ;
    rdfs:label "#DMCON"@es ;
    ns1:textoExtracto "comando ON para activar la función (por ejemplo, #DMCON [...])"@es .

ns1:Error_2458 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2458: Falta comando ON/OFF para función DMC"@es ;
    ns1:identificador "2458" ;
    ns1:solucionaFallo ns1:Fallo_DMC_NoProgramado ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Falta programar el comando ON/OFF para activar o anular la función. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. Incluir el comando ON para activar la función (por ejemplo, #DMCON [...]) o el comando OFF para anularla (por ejemplo, #DMC OFF)."@es .

ns1:Error_2458_DMCSPDL a ns1:AvisoSeguridad ;
    rdfs:label "Error 2458: Parámetro DMCSPDL no configurado para cabezal master"@es ;
    ns1:identificador "2458" ;
    ns1:solucionaFallo ns1:Fallo_DMCSPDL_NoConfigurado ;
    ns1:textoExtracto "#DMC ON:El cabezal master debe tener el parámetro DMCSPDL = Sí"@es .

ns1:Error_3100 a ns1:AvisoSeguridad ;
    rdfs:label "Error 3100: Potencia"@es ;
    ns1:identificador "3100" ;
    ns1:textoExtracto "3100 Potencia"@es .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación"@es ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:Parametro_DMCSPDL a ns1:Parametro ;
    rdfs:label "DMCSPDL"@es ;
    ns1:monitoreaParametro ns1:Cabezal_Master ;
    ns1:textoExtracto "parámetro máquina DMCSPDL=Sí"@es ;
    ns1:valor "Sí" .

ns1:Cabezal_Master a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal master"@es ;
    ns1:textoExtracto "El cabezal master debe tener el parámetro DMCSPDL = Sí"@es .

ns1:Fallo_DMCSPDL_NoConfigurado a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Parámetro DMCSPDL no está configurado como 'Sí' en cabezal"@es ;
    ns1:textoExtracto "Se ha intentado activar el DMC en un cabezal que no tiene permiso para ello. Para activar el DMC sobre un cabezal, éste debe tener su parámetro máquina DMCSPDL=Sí."@es .

ns1:Fallo_DMC_NoProgramado a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Comando ON/OFF no programado para función DMC"@es ;
    ns1:textoExtracto "Falta programar el comando ON/OFF para activar o anular la función."@es .

