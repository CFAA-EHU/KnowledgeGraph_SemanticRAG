@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_3100 a ns1:AvisoSeguridad ;
    rdfs:label "Error 3100: Potencia excesiva en el cabezal detectada durante DMC"@es ;
    ns1:activaAlarma ns1:Alarma_PotenciaExcesiva_Cabezal ;
    ns1:identificador "3100" ;
    ns1:monitoreaParametro ns1:Parametro_TV51 ;
    ns1:textoExtracto "3100 Potencia excesiva en el cabezal detectada durante DMC. DETECCIÓN Durante la ejecución. CAUSA El DMC ha detectado un consumo de potencia (variable TV51 del regulador) excesivo durante cierto tiempo. Esto puede indicar que la herramienta está desgastada o deteriorada. SOLUCIÓN Comprobar el estado de la herramienta."@es .

ns1:Error_3101 a ns1:AvisoSeguridad ;
    rdfs:label "Error 3101: Potencia excesiva en el cabezal detectada durante DMC"@es ;
    ns1:activaAlarma ns1:Alarma_PotenciaInstantanea_Excedida ;
    ns1:identificador "3101" ;
    ns1:monitoreaParametro ns1:Parametro_TV51 ;
    ns1:textoExtracto "3101 Potencia excesiva en el cabezal detectada durante DMC. Pulse MARCHA para continuar. DETECCIÓN Durante la ejecución. CAUSA El DMC ha detectado que la potencia instantánea (variable TV51 del regulador) ha superado la potencia objetivo en un rango prefijado."@es .

ns1:Error_PermisoDMC a ns1:AvisoSeguridad ;
    rdfs:label "Error: Cabezal sin permiso para activar DMC"@es ;
    ns1:monitoreaParametro ns1:Parametro_DMCSPDL ;
    ns1:textoExtracto "Se ha intentado activar el DMC en un cabezal que no tiene permiso para ello. SOLUCIÓN Para activar el DMC sobre un cabezal, éste debe tener su parámetro máquina DMCSPDL=Sí."@es .

ns1:Herramienta_Cabezal a ns1:Herramienta ;
    rdfs:label "Herramienta del cabezal (sujeta a desgaste)"@es ;
    ns1:textoExtracto "Esto puede indicar que la herramienta está desgastada o deteriorada. SOLUCIÓN Comprobar el estado de la herramienta."@es .

ns1:Alarma_PotenciaExcesiva_Cabezal a ns1:Alarma ;
    rdfs:label "Alarma por potencia excesiva en cabezal (TV51)"@es ;
    ns1:textoExtracto "El DMC ha detectado un consumo de potencia (variable TV51 del regulador) excesivo durante cierto tiempo."@es .

ns1:Alarma_PotenciaInstantanea_Excedida a ns1:Alarma ;
    rdfs:label "Alarma por potencia instantánea excedida en cabezal (TV51)"@es ;
    ns1:textoExtracto "El DMC ha detectado que la potencia instantánea (variable TV51 del regulador) ha superado la potencia objetivo en un rango prefijado."@es .

ns1:Parametro_DMCSPDL a ns1:Parametro ;
    rdfs:label "DMCSPDL (permiso de activación DMC en cabezal)"@es ;
    ns1:textoExtracto "parámetro máquina DMCSPDL=Sí"@es ;
    ns1:valor "DMCSPDL" .

ns1:Parametro_TV51 a ns1:Parametro ;
    rdfs:label "TV51 (potencia del regulador)"@es ;
    ns1:textoExtracto "variable TV51 del regulador"@es ;
    ns1:valor "TV51" .

