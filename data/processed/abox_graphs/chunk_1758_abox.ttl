@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_PotenciaEnVacio_1497 a ns1:Parametro ;
    rdfs:label "Potencia en vacío"@es ;
    ns1:textoExtracto "20 % de la potencia en vacío"@es .

ns1:Parametro_PotenciaObjetivo_1497 a ns1:Parametro ;
    rdfs:label "Potencia objetivo"@es ;
    ns1:monitoreaParametro ns1:FuncionDMC_1497 ;
    ns1:textoExtracto "La potencia objetivo (programada u obtenida mediante el aprendizaje) debe ser al menos un 20 % de la potencia en vacío"@es ;
    ns1:valor ">=20% de potencia en vacío"@es .

ns1:TareaMantenimiento_ProgramacionPotencia_1497 a ns1:TareaMantenimiento ;
    rdfs:label "Programación de potencia objetivo"@es ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_DeteccionEntradas_1497 ;
    ns1:textoExtracto "Programar una potencia objetivo mayor, que no se va a alcanzar realmente"@es .

ns1:AvisoSeguridad_MecanizadoEnVacio_1497 a ns1:AvisoSeguridad ;
    rdfs:label "Mecanizado en vacío no detectado"@es ;
    ns1:textoExtracto "realice todo el mecanizado como si la herramienta trabajara en vacío"@es .

ns1:DiagnosticoFallo_DeteccionEntradas_1497 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en detección de entradas a la pieza"@es ;
    ns1:mitigaRiesgo ns1:AvisoSeguridad_MecanizadoEnVacio_1497 ;
    ns1:textoExtracto "el DMC no detecte nunca entradas a la pieza, y realice todo el mecanizado como si la herramienta trabajara en vacío"@es .

ns1:FuncionDMC_1497 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función DMC"@es ;
    ns1:identificador "DMC" ;
    ns1:textoExtracto "desactivar la función DMC en este mecanizado"@es .

