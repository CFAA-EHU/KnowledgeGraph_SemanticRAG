@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaFuncionalMesaFreno a ns1:Esquema ;
    ns1:textoExtracto "Diagrama funcional de mesa rotatoria subir/bajar (válvulas YP802/YP803, TN10) y desbloqueo freno MAYR del carro (YP900). Incluye presostatos (BP714, BP727), detectores (SQ46/SQ47) y válvulas con referencias (BQ715/717/720/721/723/724). Flechas y rótulos indican direccionalidad de flujo y puntos de medida." ;
    ns1:tieneComponente ns1:DetectorSQ46,
        ns1:DetectorSQ47,
        ns1:FrenoMAYR,
        ns1:PresostatoBP714,
        ns1:PresostatoBP727,
        ns1:ValvulaBQ715,
        ns1:ValvulaBQ717,
        ns1:ValvulaBQ720,
        ns1:ValvulaBQ721,
        ns1:ValvulaBQ723,
        ns1:ValvulaBQ724,
        ns1:ValvulaTN10,
        ns1:ValvulaYP802,
        ns1:ValvulaYP803 .

ns1:EsquemaHidraulicoGrupo a ns1:Esquema ;
    ns1:textoExtracto "Esquema hidráulico del grupo: depósito 130 L con sensor de nivel (BL726), M6 motor del grupo, bomba y retorno al tanque. Líneas rojas/azules identifican presión (2P) y retorno (2T); se muestran longitudes de latiguillos, secciones y elementos de sensórica. Cartela inferior con metadatos (proyecto, fecha, autor)." ;
    ns1:tieneComponente ns1:BombaHidraulica,
        ns1:Deposito130L,
        ns1:LatiguillosHidraulicos,
        ns1:MotorM6,
        ns1:SensorNivelBL726 .

ns1:EsquemaNeumatico a ns1:Esquema ;
    ns1:textoExtracto "Esquema neumático con unidad FRL (AW40, manómetros BP710/BP711), regulación de presiones y circuitos para cepillo de limpieza (cilindro MGPM25-175Z; válvulas YP901/YP902) y refrigerante limpieza bastidor (YP903). Se representan diámetros de tubería, puntos de presurización y estados (BQ740/BQ741)." ;
    ns1:tieneComponente ns1:CilindroMGPM25_175Z,
        ns1:EstadoBQ740,
        ns1:EstadoBQ741,
        ns1:ManometroBP710,
        ns1:ManometroBP711,
        ns1:TuberiasNeumaticas,
        ns1:UnidadFRL_AW40,
        ns1:ValvulaYP901,
        ns1:ValvulaYP902,
        ns1:ValvulaYP903 .

ns1:EsquemaRefrigeracion a ns1:Esquema ;
    ns1:textoExtracto "Circuito de refrigeración con capacidad 200 L. Motores: M3 (refrigerante máquina), M4 (trasvase), M5 (extractor de viruta) y grupo de filtro de papel (SQ40). Sensores de nivel (BN41/BN42) y caudal BC44." ;
    ns1:tieneComponente ns1:DepositoRefrigeracion200L,
        ns1:FiltroPapelSQ40,
        ns1:MotorM3,
        ns1:MotorM4,
        ns1:MotorM5,
        ns1:SensorCaudalBC44,
        ns1:SensorNivelBN41,
        ns1:SensorNivelBN42 .

