@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_PlatoDivisor_X a ns1:Maquina ;
    rdfs:label "Máquina con plato divisor en eje X"@es ;
    ns1:documentadoEn ns1:Tabla_GraficosHD_19_1 ;
    ns1:identificador "Mill A@table B,C@spindle.xca" ;
    ns1:textoExtracto "Máquina con plato divisor en X."@es .

ns1:Maquina_PlatoDivisor_Y a ns1:Maquina ;
    rdfs:label "Máquina con plato divisor en eje Y"@es ;
    ns1:documentadoEn ns1:Tabla_GraficosHD_19_1 ;
    ns1:identificador "Mill B@table A,C@spindle.xca" ;
    ns1:textoExtracto "Máquina con plato divisor en Y."@es .

ns1:Maquina_PlatoDivisor_Z a ns1:Maquina ;
    rdfs:label "Máquina con plato divisor en eje Z"@es ;
    ns1:documentadoEn ns1:Tabla_GraficosHD_19_1 ;
    ns1:identificador "Mill C@table A,B@spindle.xca" ;
    ns1:textoExtracto "Máquina con plato divisor en Z."@es .

ns1:Tabla_GraficosHD_19_1 a ns1:Tabla ;
    rdfs:label "Tabla de configuración de gráficos para ciclos de ejes rotativos"@es ;
    ns1:identificador "19.1" ;
    ns1:textoExtracto "Mill A@table B,C@spindle.xca | Máquina con plato divisor en X. Mill B@table A,C@spindle.xca | Máquina con plato divisor en Y. Mill C@table A,B@spindle.xca | Máquina con plato divisor en Z."@es .

