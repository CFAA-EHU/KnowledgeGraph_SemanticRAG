@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Archivo_Mill_A_table_B_C_spindle_xca a ns1:Esquema ;
    ns1:textoExtracto "Para un eje rotativo A está el archivo \"Mill A@table B, C@spindle.xca\"" .

ns1:Archivo_def a ns1:Esquema ;
    ns1:textoExtracto "editar un segundo archivo (con el mismo nombre y extensión def), con la asociación correcta entre los ejes del CNC y los definidos en el archivo xca. En la carpeta de cada máquina hay un archivo def de ejemplo" .

ns1:Archivo_def_ejemplo a ns1:Esquema ;
    ns1:textoExtracto "En la carpeta de cada máquina hay un archivo def de ejemplo" .

ns1:Archivo_xca_default a ns1:Esquema ;
    ns1:textoExtracto "La configuración de ejes por defecto en los archivos xca es la siguiente. Eje 4: Eje rotativo del plato divisor. Eje 1: X Eje 5: Primer eje rotativo del cabezal. Eje 2: Y Eje 6: Segundo eje rotativo del cabezal. Eje 3: Z" .

ns1:Connection_plug_stdPlug_A1_socket_stdSocket_home_translation_0_0_0 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "<Connection plug=\"stdPlug@A1\" socket=\"stdSocket@home\" translation=\"0 0 0\"/>" .

ns1:Connection_plug_stdPlug_A1_socket_stdSocket_home_translation_300_100_250 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "<Connection plug=\"stdPlug@A1\" socket=\"stdSocket@home\" translation=\"-300 -100 -250\"/>" .

ns1:Connection_plug_stdPlug_SYS_Tool1_socket_stdSocket_S1_rotation_0_1_0_90 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "<Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@S1\" rotation=\"0 1 0 -90\"/>" .

ns1:Eje1 a ns1:Parametro ;
    ns1:textoExtracto "Eje 1: X" ;
    ns1:valor "X" .

ns1:Eje2 a ns1:Parametro ;
    ns1:textoExtracto "Eje 2: Y" ;
    ns1:valor "Y" .

ns1:Eje3 a ns1:Parametro ;
    ns1:textoExtracto "Eje 3: Z" ;
    ns1:valor "Z" .

ns1:Eje4 a ns1:Parametro ;
    ns1:textoExtracto "Eje 4: Eje rotativo del plato divisor" ;
    ns1:valor "Eje rotativo del plato divisor" .

ns1:Eje5 a ns1:Parametro ;
    ns1:textoExtracto "Eje 5: Primer eje rotativo del cabezal" ;
    ns1:valor "Primer eje rotativo del cabezal" .

ns1:Eje6 a ns1:Parametro ;
    ns1:textoExtracto "Eje 6: Segundo eje rotativo del cabezal" ;
    ns1:valor "Segundo eje rotativo del cabezal" .

ns1:Pieza_cilindrica a ns1:ComponenteMecanico ;
    ns1:textoExtracto "En piezas cilíndricas, su eje de rotación debe ser el mismo que el del plato divisor" .

