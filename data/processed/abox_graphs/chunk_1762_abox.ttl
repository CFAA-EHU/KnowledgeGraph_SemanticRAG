@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:HerramientaPosicionable a ns1:Herramienta ;
    rdfs:label "Herramienta posicionable por gráficos de ejes rotativos"@es ;
    ns1:requiereMantenimiento ns1:ConfiguracionGraficosEjesRotativos_19_1 ;
    ns1:textoExtracto "Posicionar la herramienta. Los gráficos posicionan la herramienta según el eje frontal o longitudinal"@es .

ns1:TablaHerramientas_19_1 a ns1:Tabla ;
    rdfs:label "Tabla de herramientas para posicionamiento gráfico"@es ;
    ns1:documentadoEn ns1:Pagina_737_738 ;
    ns1:textoExtracto "según la opción elegida en la tabla de herramientas"@es .

ns1:ConfiguracionGraficosEjesRotativos_19_1 a ns1:InterfazUsuario ;
    rdfs:label "Configuración de gráficos para ciclos de ejes rotativos"@es ;
    ns1:detalladoEnEsquema ns1:EsquemaConexion_1501 ;
    ns1:monitoreaParametro ns1:Parametro_FACEAXIS,
        ns1:Parametro_LONGAXIS ;
    ns1:textoExtracto "GRÁFICOS HD. - 19.1 Configurar los gráficos para los ciclos de ejes rotativos [...] Los gráficos posicionan la herramienta según el eje frontal o longitudinal definido en los parámetros máquina"@es .

ns1:EsquemaConexion_1501 a ns1:Esquema ;
    rdfs:label "Esquema de conexión para posicionamiento de herramienta (stdPlug@A1 → stdSocket@home)"@es ;
    ns1:ilustradoEn ns1:Pagina_737_738 ;
    ns1:textoExtracto "<Connection plug=\"stdPlug@A1\" socket=\"stdSocket@home\" translation=\"-300 -100 -250\"/>"@es .

ns1:Parametro_FACEAXIS a ns1:Parametro ;
    rdfs:label "FACEAXIS" ;
    ns1:documentadoEn ns1:ManualCNC ;
    ns1:identificador "FACEAXIS" ;
    ns1:textoExtracto "parámetros máquina de los ejes lineales (FACEAXIS [...]). Si los parámetros máquina [...] FACEAXIS cambian, hay que reiniciar el CNC"@es .

ns1:Parametro_LONGAXIS a ns1:Parametro ;
    rdfs:label "LONGAXIS" ;
    ns1:documentadoEn ns1:ManualCNC ;
    ns1:identificador "LONGAXIS" ;
    ns1:textoExtracto "parámetros máquina de los ejes lineales [...](LONGAXIS) [...] Si los parámetros máquina LONGAXIS [...] cambian"@es .

ns1:Pagina_737_738 a ns1:Pagina ;
    ns1:identificador "737-738" ;
    ns1:textoExtracto "GRÁFICOS HD. - 19.1 Configurar los gráficos para los ciclos de ejes rotativos"@es .

