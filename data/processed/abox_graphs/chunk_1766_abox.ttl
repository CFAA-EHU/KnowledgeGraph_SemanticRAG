@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fagor_EtherCAT_Mapper a ns1:Herramienta ;
    rdfs:label "Fagor EtherCAT Mapper" ;
    ns1:identificador "Fagor EtherCAT Mapper" ;
    ns1:textoExtracto "Este fichero también lo utiliza el programa \"Fagor EtherCAT Mapper\" para conocer los recursos disponibles en el bus." .

ns1:Fichero_ENI a ns1:Componente ;
    rdfs:label "Fichero ENI (fagor_ethercatConfFile.xml)" ;
    ns1:identificador "fagor_ethercatConfFile.xml" ;
    ns1:textoExtracto "El configurador de la topología genera el fichero ENI que contiene la información de los dispositivos EtherCAT conectados al CNC. Este fichero se debe copiar a la carpeta ../Mtb/Data del CNC con el nombre \"fagor_ethercatConfFile.xml\"." .

ns1:KPA_EtherCAT_Studio a ns1:Herramienta ;
    rdfs:label "KPA EtherCAT Studio" ;
    ns1:identificador "KPA EtherCAT Studio" ;
    ns1:textoExtracto "Fagor suministra bajo licencia el configurador \"KPA EtherCAT Studio\" (de Koening-pa GmbH), que puede funcionar tanto en modo online como offline; en ambos casos es necesaria la licencia." .

ns1:ModoOperacion_Offline a ns1:ModoOperacion ;
    rdfs:label "Modo offline" ;
    ns1:textoExtracto "En modo offline, el configurador no accede al bus EtherCAT. El usuario debe construir manualmente la topología del bus a partir de los módulos almacenados en la librería del programa." .

ns1:ModoOperacion_Online a ns1:ModoOperacion ;
    rdfs:label "Modo online" ;
    ns1:textoExtracto "En modo online, el configurador se conecta al bus EtherCAT y lo escanea para detectar los módulos presentes en el bus." .

ns1:Pendrive_Licencia_KPA a ns1:Componente ;
    rdfs:label "Pendrive con licencia de KPA EtherCAT Studio" ;
    ns1:textoExtracto "Fagor entrega un pendrive con el instalador y la licencia del configurador \"KPA EtherCAT Studio\". Esta licencia está vinculada al pendrive; el usuario podrá tener el configurador instalado en varios equipos, pero necesitará conectar el pendrive para utilizarlo." .

