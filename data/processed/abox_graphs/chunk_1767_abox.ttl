@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Archivo_SetupKPA a ns1:Componente ;
    rdfs:label "Archivo de instalación SetupKPA_xx_xx.exe"@es ;
    ns1:identificador "SetupKPA_xx_xx.exe" ;
    ns1:textoExtracto "hacer doble clic en el archivo 'SetupKPA_xx_xx.exe' (donde xx_xx indica la versión) para iniciar la instalación"@es .

ns1:Tabla_IconosConfigurador a ns1:Tabla ;
    rdfs:label "Tabla de iconos del configurador EtherCAT"@es ;
    ns1:ilustradoEn ns1:ConfiguradorEtherCAT_Studio,
        ns1:KPA_LicensingUtilities,
        ns1:MasterWin64_EtherCAT ;
    ns1:textoExtracto "| Icono. | Función. | --- | --- |  | Studio. Configurador EtherCAT. |  | Master (Win64). Acceso a los módulos EtherCAT a través de la red Ethernet. |  | KPA Licensing utilities. Acceso a la licencia de uso."@es .

ns1:ConfiguradorEtherCAT_Studio a ns1:InterfazUsuario ;
    rdfs:label "Studio. Configurador EtherCAT"@es ;
    ns1:identificador "Studio" ;
    ns1:textoExtracto "Studio. Configurador EtherCAT."@es .

ns1:KPA_LicensingUtilities a ns1:InterfazUsuario ;
    rdfs:label "KPA Licensing utilities. Acceso a la licencia de uso"@es ;
    ns1:identificador "KPA Licensing utilities" ;
    ns1:textoExtracto "KPA Licensing utilities. Acceso a la licencia de uso."@es .

ns1:MasterWin64_EtherCAT a ns1:InterfazUsuario ;
    rdfs:label "Master (Win64). Acceso a los módulos EtherCAT a través de la red Ethernet"@es ;
    ns1:identificador "Master (Win64)" ;
    ns1:textoExtracto "Master (Win64). Acceso a los módulos EtherCAT a través de la red Ethernet."@es .

