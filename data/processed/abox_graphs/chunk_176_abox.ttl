@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:SensorNivel a owl:Class ;
    rdfs:label "Sensor de nivel" ;
    rdfs:comment "Clase para sensores de nivel BN41/BN42" .

ex:SensorCaudal a owl:Class ;
    rdfs:label "Sensor de caudal" ;
    rdfs:comment "Clase para sensores de caudal BC44" .

