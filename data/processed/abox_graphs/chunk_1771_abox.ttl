@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_MasterTopologia a ns1:Componente ;
    rdfs:label "Máster de la topología"@es ;
    ns1:textoExtracto "colocar el ratón sobre el **máster de la topología** (ventana izquierda)"@es ;
    ns1:tieneComponente ns1:Sistema_TopologiaBus .

ns1:TareaMantenimiento_AgregarCabeceras a ns1:TareaMantenimiento ;
    rdfs:label "Agregar cabeceras a la topología del bus"@es ;
    ns1:documentadoEn ns1:InterfazUsuario_ConfiguradorTopologiaBus ;
    ns1:ejecutadoPor ns1:Personal_TecnicoConfigurador ;
    ns1:textoExtracto "Para añadir cabeceras, [...] seleccionar la opción 'Append Slave'. [...] Arrastrar los módulos desde la ventana derecha a la ventana izquierda."@es .

ns1:Personal_TecnicoConfigurador a ns1:Personal ;
    rdfs:label "Técnico configurador del sistema"@es ;
    ns1:textoExtracto "colocar el ratón [...], pulsar el botón derecho del ratón y seleccionar la opción"@es .

ns1:Sistema_TopologiaBus a ns1:Sistema ;
    rdfs:label "Sistema de topología del bus (modo construcción manual)"@es ;
    ns1:ilustradoEn ns1:InterfazUsuario_ConfiguradorTopologiaBus ;
    ns1:textoExtracto "Construir manualmente la topología del bus"@es .

ns1:InterfazUsuario_ConfiguradorTopologiaBus a ns1:InterfazUsuario ;
    rdfs:label "Configurador de topología del bus (modo offline)"@es ;
    ns1:identificador "20.1.5_ModoOffline_ConfiguradorTopologia" ;
    ns1:textoExtracto "colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción 'Append Slave'. El configurador muestra los dispositivos disponibles. [...] Arrastrar los módulos desde la ventana derecha a la ventana izquierda."@es .

