@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FormatoArchivo_ECSN a ns1:Parametro ;
    rdfs:label "Formato *.ecsn"@es ;
    ns1:textoExtracto "Guardar el proyecto con cualquier nombre (extensión *.ecsn)"@es ;
    ns1:valor "*.ecsn" .

ns1:InterfazMenuArchivo a ns1:InterfazUsuario ;
    rdfs:label "Menú File"@es ;
    ns1:habilitadoPor ns1:AccionGuardarProyecto ;
    ns1:textoExtracto "seleccionar la opción File > Save"@es .

ns1:AccionGuardarProyecto a ns1:AccionProhibida ;
    rdfs:label "Guardar proyecto"@es ;
    ns1:identificador "File > Save"@es ;
    ns1:textoExtracto "El proyecto se puede guardar aunque no esté finalizado. En una sesión posterior, se puede recuperar la configuración guardada y continuar a partir de ese punto. Para guardar el proyecto, seleccionar la opción File > Save..."@es .

