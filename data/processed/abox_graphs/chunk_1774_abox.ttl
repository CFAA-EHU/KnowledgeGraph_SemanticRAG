@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Archivo_fagor_ethercatConfFile_xml a ns1:Componente ;
    rdfs:label "fagor_ethercatConfFile.xml" ;
    ns1:identificador "fagor_ethercatConfFile.xml" ;
    ns1:textoExtracto "archivo xml [...] renombrarlo como \"fagor_ethercatConfFile.xml\""@es .

ns1:Tarea_CopiarArchivoConfiguracionCNC a ns1:TareaMantenimiento ;
    rdfs:label "Copiar archivo de configuración al CNC"@es ;
    ns1:identificador "20.1.8" ;
    ns1:textoExtracto "Para copiar el archivo de configuración al CNC (archivo xml), renombrarlo como \"fagor_ethercatConfFile.xml\" y copiarlo a la carpeta ../Mtb/Data."@es .

