@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_1517 a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de configuración del bus" ;
    ns1:textoExtracto "A. Barra de iconos y nombre del archivo ENI cargado. B. Barra de configuración por defecto para el mapeo de recursos. C. Validación de la opción \"Overlapped\". D. Topología del bus (vista de árbol). E. Topología del bus (vista de bloques)." ;
    ns1:tieneComponente ns1:BarraConfiguracion_1517_B,
        ns1:BarraIconos_1517_A,
        ns1:OpcionValidacion_1517_C,
        ns1:TopologiaArbol_1517_D,
        ns1:TopologiaBloques_1517_E .

ns1:BarraConfiguracion_1517_B a ns1:Componente ;
    rdfs:label "Barra de configuración por defecto" ;
    ns1:textoExtracto "B. Barra de configuración por defecto para el mapeo de recursos." .

ns1:BarraIconos_1517_A a ns1:Componente ;
    rdfs:label "Barra de iconos y nombre del archivo ENI" ;
    ns1:textoExtracto "A. Barra de iconos y nombre del archivo ENI cargado." .

ns1:OpcionValidacion_1517_C a ns1:Componente ;
    rdfs:label "Validación de la opción 'Overlapped'" ;
    ns1:textoExtracto "C. Validación de la opción \"Overlapped\"." .

ns1:TopologiaArbol_1517_D a ns1:Componente ;
    rdfs:label "Topología del bus (vista de árbol)" ;
    ns1:textoExtracto "D. Topología del bus (vista de árbol)." .

ns1:TopologiaBloques_1517_E a ns1:Componente ;
    rdfs:label "Topología del bus (vista de bloques)" ;
    ns1:textoExtracto "E. Topología del bus (vista de bloques)." .

