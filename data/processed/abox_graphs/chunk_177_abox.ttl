@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix elec: <https://vocab.cfaa.eus/broaching/electricidad/> .
@prefix mecanica: <https://vocab.cfaa.eus/broaching/mecanica/> .
@prefix base: <https://vocab.cfaa.eus/broaching/base/> .

ex:AlimentacionGeneral a owl:Class ;
    rdfs:label "Alimentación general" ;
    rdfs:comment "Esquema de servicios a 230 VAC (iluminación máquina/pupitre, tomas de corriente, transformador 11TR1 1000 VA, luminarias 11HL3–5). Bloques con magnetotérmicos (11QF1–6) y reles (11KA1); cableado rotulado y pasos por XT1/XT2." .

ex:Alimentacion24VDC a owl:Class ;
    rdfs:label "Alimentación 24VDC" ;
    rdfs:comment "Arquitectura 24 V DC: SITOP 12T1 40 A y módulos 12F1/12F2 (4 salidas/10 A). Distribución a PLC, Safety, Panel, CNC, I/O Externos (rótulos 24API/24EBC/24VAN/24E/24SAFE/24PNL/24S/24CNC). Bornes XT1/XTP1, piloto 12HL1; líneas rojas (positivo) y verdes (retorno/PE)." .

ex:ClimatizadorArmario a owl:Class ;
    rdfs:label "Climatizador armario" ;
    rdfs:comment "Bloque funcional de climatizador 1000 W (Rittal SK.3304540) con protección 13QF1 y señal “Climatizador ON”. Representación del módulo con bornes X1–X3, conexión trifásica y control por 24E; flechas de flujo eléctrico hacia el equipo." .

ex:MotoresCA a owl:Class ;
    rdfs:label "Motores de C.A" ;
    rdfs:comment "Cadena de magnetotérmicos (14QM1–5) y contactores (KA00–KA04) alimentando M1–M6 (refrigerante, extractor viruta, trasvase, filtro, hidráulico)." .

elec:tieneMagnetotermico a owl:ObjectProperty ;
    rdfs:domain ex:AlimentacionGeneral ;
    rdfs:range ex:Magnetotermico .

