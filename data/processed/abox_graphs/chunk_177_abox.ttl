ex:EsquemaAlimentacionGeneral a ex:Esquema ;
    ex:identificador "Esquema eléctricos — Potencia y servicios" ;
    ex:textoExtracto "Esquema de servicios a 230 VAC (iluminación máquina/pupitre, tomas de corriente, transformador 11TR1 1000 VA, luminarias 11HL3–5). Bloques con magnetotérmicos (11QF1–6) y reles (11KA1); cableado rotulado y pasos por XT1/XT2." ;
    ex:tieneComponente ex:XT1, ex:XT2, ex:11TR1, ex:11HL3, ex:11HL4, ex:11HL5, ex:11QF1, ex:11QF2, ex:11QF3, ex:11QF4, ex:11QF5, ex:11QF6, ex:11KA1 .

ex:EsquemaAlimentacion24VDC a ex:Esquema ;
    ex:identificador "Esquema eléctricos — 24 V DC" ;
    ex:textoExtracto "Arquitectura 24 V DC: SITOP 12T1 40 A y módulos 12F1/12F2 (4 salidas/10 A). Distribución a PLC, Safety, Panel, CNC, I/O Externos (rótulos 24API/24EBC/24VAN/24E/24SAFE/24PNL/24S/24CNC). Bornes XT1/XTP1, piloto 12HL1; líneas rojas (positivo) y verdes (retorno/PE)." ;
    ex:tieneComponente ex:XT1, ex:XT1P1, ex:12T1, ex:12F1, ex:12F2, ex:12HL1 .

ex:EsquemaClimatizadorArmario a ex:Esquema ;
    ex:identificador "Esquema eléctricos — Servicios de armario" ;
    ex:textoExtracto "Bloque funcional de climatizador 1000 W (Rittal SK.3304540) con protección 13QF1 y señal “Climatizador ON”. Representación del módulo con bornes X1–X3, conexión trifásica y control por 24E; flechas de flujo eléctrico hacia el equipo." ;
    ex:tieneComponente ex:13QF1 .

ex:EsquemaMotoresCA a ex:Esquema ;
    ex:identificador "Esquema eléctricos — Motores CA" ;
    ex:textoExtracto "Cadena de magnetotérmicos (14QM1–5) y contactores (KA00–KA04) alimentando M1–M6 (refrigerante, extractor viruta, trasvase, filtro, hidráulico)." ;
    ex:tieneComponente ex:14QM1, ex:14QM2, ex:14QM3, ex:14QM4, ex:14QM5, ex:KA00, ex:KA01, ex:KA02, ex:KA03, ex:KA04, ex:M1, ex:M2, ex:M3, ex:M4, ex:M5, ex:M6 .