@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazEtherCAT_PLC_749_751 a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de mapeo EtherCAT-PLC" ;
    ns1:textoExtracto "| Bloque. | Color y tipo de recurso. | --- | --- | Color azul. Entradas digitales. | Color morado. Salidas digitales. | Color rojo. Mapeo de recursos EtherCAT a registros de PLC. | Color gris. Mapeo de registros de PLC a recursos EtherCAT. | Color verde. Registros de las entradas analógicas Fagor. | Color amarillo. Registros de las salidas analógicas Fagor." ;
    ns1:tieneComponente ns1:EntradasAnalogicas_Fagor_Verde_749_751,
        ns1:EntradasDigitales_Azul_749_751,
        ns1:MapeoEtherCAT_PLC_Rojo_749_751,
        ns1:MapeoPLC_EtherCAT_Gris_749_751,
        ns1:SalidasAnalogicas_Fagor_Amarillo_749_751,
        ns1:SalidasDigitales_Morado_749_751 .

ns1:EntradasAnalogicas_Fagor_Verde_749_751 a ns1:ComponenteElectrico ;
    rdfs:label "Registros de entradas analógicas Fagor (bloque verde)" ;
    ns1:identificador "verde" ;
    ns1:textoExtracto "Color verde. Registros de las entradas analógicas Fagor." .

ns1:EntradasDigitales_Azul_749_751 a ns1:ComponenteElectrico ;
    rdfs:label "Entradas digitales (bloque azul)" ;
    ns1:identificador "azul" ;
    ns1:textoExtracto "Color azul. Entradas digitales." .

ns1:MapeoEtherCAT_PLC_Rojo_749_751 a ns1:Sistema ;
    rdfs:label "Mapeo de recursos EtherCAT a registros de PLC (bloque rojo)" ;
    ns1:identificador "rojo" ;
    ns1:textoExtracto "Color rojo. Mapeo de recursos EtherCAT a registros de PLC." .

ns1:MapeoPLC_EtherCAT_Gris_749_751 a ns1:Sistema ;
    rdfs:label "Mapeo de registros de PLC a recursos EtherCAT (bloque gris)" ;
    ns1:identificador "gris" ;
    ns1:textoExtracto "Color gris. Mapeo de registros de PLC a recursos EtherCAT." .

ns1:SalidasAnalogicas_Fagor_Amarillo_749_751 a ns1:ComponenteElectrico ;
    rdfs:label "Registros de salidas analógicas Fagor (bloque amarillo)" ;
    ns1:identificador "amarillo" ;
    ns1:textoExtracto "Color amarillo. Registros de las salidas analógicas Fagor." .

ns1:SalidasDigitales_Morado_749_751 a ns1:ComponenteElectrico ;
    rdfs:label "Salidas digitales (bloque morado)" ;
    ns1:identificador "morado" ;
    ns1:textoExtracto "Color morado. Salidas digitales." .

