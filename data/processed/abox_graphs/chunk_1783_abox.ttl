@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionNumeracionRecursosBus a ns1:Sistema ;
    rdfs:label "Configuración de numeración de recursos del bus"@es ;
    ns1:textoExtracto "Modificar la numeración de los recursos de todo el bus. Modificar los recursos en la barra superior y el programa actualiza los recursos de todo el bus."@es ;
    ns1:tieneComponente ns1:EntradasDigitalesBus,
        ns1:SalidasDigitalesBus .

ns1:ConfiguracionNumeracionRecursosModulo a ns1:Sistema ;
    rdfs:label "Configuración de numeración de recursos por módulo"@es ;
    ns1:textoExtracto "Modificar la numeración de los recursos de un módulo. En la vista de bloques, hacer clic sobre un módulo y definir el número con el que empiezan sus recursos; el resto de recursos se numeran de forma correlativa."@es .

ns1:ConfiguracionNumeracionRecursosNodo a ns1:Sistema ;
    rdfs:label "Configuración de numeración de recursos por nodo"@es ;
    ns1:textoExtracto "Modificar la numeración de los recursos de un nodo. En la vista de bloques, hacer clic sobre el nombre de la cabecera y definir el número con el que empiezan los recursos del nodo."@es .

ns1:EntradasDigitalesBus a ns1:ComponenteElectrico ;
    rdfs:label "Entradas digitales del bus"@es ;
    ns1:textoExtracto "Entradas digitales. Primera = 10 Offset = 100"@es ;
    ns1:valor "Primera: 10, Offset: 100" .

ns1:SalidasDigitalesBus a ns1:ComponenteElectrico ;
    rdfs:label "Salidas digitales del bus"@es ;
    ns1:textoExtracto "Salidas digitales. Primera = 21 Offset = 50 Offset = 100 Offset = 100"@es ;
    ns1:valor "Primera: 21, Offset: 50/100" .

