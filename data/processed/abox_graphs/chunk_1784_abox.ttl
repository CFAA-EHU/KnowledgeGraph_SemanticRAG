@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Overlapped_Configuracion a ns1:InterfazUsuario ;
    rdfs:label "Ficha Overlapped" ;
    ns1:documentadoEn ns1:Aviso_ErrorRecursoDuplicado,
        ns1:Aviso_ReordenRecursos ;
    ns1:identificador "Overlapped" ;
    ns1:requiereMantenimiento ns1:Accion_LoadFilter ;
    ns1:textoExtracto "La ficha \"Overlapped\" define si se permite la superposición de recursos en diferentes módulos." ;
    ns1:tieneComponente ns1:Parametro_Overlapped,
        ns1:Parametro_Starts .

ns1:Accion_LoadFilter a ns1:AccionProhibida ;
    rdfs:label "Validación Load filter" ;
    ns1:identificador "Load filter" ;
    ns1:textoExtracto "Cada vez que se modifica está opción, hay que validarla con el icono \"Load filter\" situado en la parte superior derecha." .

ns1:Aviso_ErrorRecursoDuplicado a ns1:AvisoSeguridad ;
    rdfs:label "Error por recurso duplicado" ;
    ns1:identificador "I33" ;
    ns1:textoExtracto "En el caso de asignar a un recurso un número que ya existe en el bus, el programa dará error." .

ns1:Aviso_ReordenRecursos a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de reordenación de recursos" ;
    ns1:textoExtracto "En el caso de asignar a un recurso un número que ya existe en el bus, el programa reordena los recursos siguientes (numeración superior). Los recursos con numeración anteriores (numeración inferior) no se modifican." .

ns1:Parametro_Overlapped a ns1:Parametro ;
    rdfs:label "Parámetro Overlapped" ;
    ns1:identificador "Overlapped" ;
    ns1:textoExtracto "Overlapped = Right. [...] Overlapped = No." ;
    ns1:valor "No",
        "Right" .

ns1:Parametro_Starts a ns1:Parametro ;
    rdfs:label "Parámetro Starts" ;
    ns1:identificador "Starts" ;
    ns1:textoExtracto "Starts=81" ;
    ns1:valor "81" .

