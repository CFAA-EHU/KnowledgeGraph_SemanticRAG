@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_Mapeador a ns1:InterfazUsuario ;
    rdfs:label "Mapeador (vista de bloques)" ;
    ns1:ilustradoEn ns1:ModuloEntradaAnalogica_Fagor_IB_IL_AI4_U_PAC,
        ns1:ModuloSalidaAnalogica_Fagor_IB_IL_AO2_U_PAC ;
    ns1:textoExtracto "La configuración [...] se realiza desde el mapeador. En la vista de bloques, hacer clic sobre un módulo para acceder a sus propiedades." .

ns1:ModoOperacion_ConfiguracionAnalogica a ns1:ModoOperacion ;
    rdfs:label "Configuración de modo de trabajo (rango de medición)" ;
    ns1:controla ns1:Parametro_FrecuenciaMuestreo_Entrada,
        ns1:Parametro_RangoMedicion_Entrada,
        ns1:Parametro_RangoMedicion_Salida ;
    ns1:textoExtracto "La configuración del modo de trabajo (rango de medición) de estos módulos se realiza desde el mapeador." .

ns1:ModuloEntradaAnalogica_Fagor_IB_IL_AI4_U_PAC a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de entradas analógicas Fagor IB IL AI 4 - U-PAC" ;
    ns1:identificador "Fagor IB IL AI 4 - U-PAC" ;
    ns1:textoExtracto "Entradas analógicas Fagor (por ejemplo, el módulo Fagor IB IL AI 4 - U-PAC). Estos módulos, además del número de la primera entrada, permiten configurar el rango de medición de cada entrada, así como la frecuencia del muestreo." ;
    ns1:tieneComponente ns1:Parametro_FrecuenciaMuestreo_Entrada,
        ns1:Parametro_NumeroPrimeraEntrada,
        ns1:Parametro_RangoMedicion_Entrada .

ns1:ModuloSalidaAnalogica_Fagor_IB_IL_AO2_U_PAC a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de salidas analógicas Fagor IB IL AO 2 - U-PAC" ;
    ns1:identificador "Fagor IB IL AO 2 - U-PAC" ;
    ns1:textoExtracto "Salidas analógicas Fagor (por ejemplo, el módulo Fagor IB IL AO 2 - U-PAC). Estos módulos, además del número de la primera salida, permiten configurar el rango de medición de cada salida." ;
    ns1:tieneComponente ns1:Parametro_NumeroPrimeraSalida,
        ns1:Parametro_RangoMedicion_Salida .

ns1:Parametro_NumeroPrimeraEntrada a ns1:Parametro ;
    rdfs:label "Número de la primera entrada" ;
    ns1:textoExtracto "además del número de la primera entrada" .

ns1:Parametro_NumeroPrimeraSalida a ns1:Parametro ;
    rdfs:label "Número de la primera salida" ;
    ns1:textoExtracto "además del número de la primera salida" .

ns1:Parametro_FrecuenciaMuestreo_Entrada a ns1:Parametro ;
    rdfs:label "Frecuencia de muestreo" ;
    ns1:textoExtracto "permiten configurar [...] la frecuencia del muestreo" .

ns1:Parametro_RangoMedicion_Entrada a ns1:Parametro ;
    rdfs:label "Rango de medición (entrada)" ;
    ns1:textoExtracto "permiten configurar el rango de medición de cada entrada" .

ns1:Parametro_RangoMedicion_Salida a ns1:Parametro ;
    rdfs:label "Rango de medición (salida)" ;
    ns1:textoExtracto "permiten configurar el rango de medición de cada salida" .

