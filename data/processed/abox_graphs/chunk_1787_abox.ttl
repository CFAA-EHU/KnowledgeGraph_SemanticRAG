@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Accion_GuardarProyecto_1526 a ns1:AccionProhibida ;
    rdfs:label "Guardar proyecto"@es ;
    ns1:habilitadoPor ns1:Interfaz_GenerateProject_1526 ;
    ns1:textoExtracto "El proyecto se puede guardar aunque no esté finalizado. En una sesión posterior, se puede recuperar la configuración guardada y continuar a partir de ese punto. Para guardar el proyecto, seleccionar la opción 'Generate p..."@es .

ns1:Interfaz_GenerateProject_1526 a ns1:InterfazUsuario ;
    rdfs:label "Opción 'Generate project'"@es ;
    ns1:identificador "Generate project" ;
    ns1:textoExtracto "seleccionar la opción 'Generate project'"@es .

