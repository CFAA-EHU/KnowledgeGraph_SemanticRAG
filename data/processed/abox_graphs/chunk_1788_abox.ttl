@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tarea_CopiarArchivoRutado_1527 a ns1:TareaMantenimiento ;
    rdfs:label "Copiar archivo de rutado al CNC"@es ;
    ns1:requiereMantenimiento ns1:ArchivoRutado_CNC_1527 ;
    ns1:textoExtracto "Para copiar el archivo de rutado al CNC (archivo xml), renombrarlo como \"resourceRouterConf.xml\" y copiarlo a la carpeta ../Mtb/Data."@es .

ns1:ArchivoRutado_CNC_1527 a ns1:Componente ;
    rdfs:label "Archivo de rutado para CNC"@es ;
    ns1:identificador "resourceRouterConf.xml" ;
    ns1:textoExtracto "archivo de rutado al CNC (archivo xml), renombrarlo como \"resourceRouterConf.xml\" y copiarlo a la carpeta ../Mtb/Data."@es .

