@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazDiagnostico_EtherCAT a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de diagnóstico EtherCAT" ;
    ns1:ilustradoEn ns1:Error24499 ;
    ns1:textoExtracto "El árbol de configuración identifica el nodo en error. La ventana derecha muestra la información disponible para el módulo y el error." .

ns1:Error24499 a ns1:AvisoSeguridad ;
    rdfs:label "Error 24499" ;
    ns1:identificador "24499" ;
    ns1:mitigaRiesgo ns1:ModoDiagnosis_EtherCAT ;
    ns1:textoExtracto "Error 24499. Error genérico de EtherCAT. El CNC muestra el siguiente error genérico cuando detecta un error en un nodo." .

ns1:ModoDiagnosis_EtherCAT a ns1:ModoOperacion ;
    rdfs:label "Modo diagnosis (EtherCAT)" ;
    ns1:textoExtracto "Para conocer los detalles del error, consultar el modo diagnosis." .

