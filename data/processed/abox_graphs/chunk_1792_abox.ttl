@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CartelaEstado_Administrador a ns1:InterfazUsuario ;
    rdfs:label "Cartela de estado 'ADMINISTRATOR MODE'"@es ;
    ns1:ilustradoEn ns1:ModoAdministrador ;
    ns1:textoExtracto "imagen de escritorio [...] fondo rojo y texto 'ADMINISTRATOR MODE'. Funciona como señalización visual del modo activo"@es .

ns1:CartelaEstado_Setup a ns1:InterfazUsuario ;
    rdfs:label "Cartela de estado 'SETUP MODE'"@es ;
    ns1:ilustradoEn ns1:ModoSetup ;
    ns1:textoExtracto "imagen de escritorio [...] fondo amarillo y texto 'SETUP MODE'. Funciona como señalización visual del modo activo"@es .

ns1:InterfazConfiguracion_Disk a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de configuración 'Configuration > Disk'"@es ;
    ns1:monitoreaParametro ns1:Parametro_Disco_M2_SATA ;
    ns1:textoExtracto "Captura de interfaz del panel 'Configuration > Disk' con lectura S.M.A.R.T. del disco M2-SATA. Se muestra una lista de atributos (modelo, firmware, recuento de errores, temperatura, horas de encendido, etc.) en un cuadro con iconos y valores por columna."@es .

ns1:PaginaDescargas_FagorAutomation a ns1:InterfazUsuario ;
    rdfs:label "Página de descargas de Fagor Automation"@es ;
    ns1:documentadoEn ns1:Software_CNC_Help_Language_Changer ;
    ns1:textoExtracto "Captura de un navegador en la página de descargas de Fagor Automation. Se aprecian campos de búsqueda/filtrado y el listado donde figura 'CNC Help Language Changer'."@es .

ns1:VentanaReinicio_Sistema a ns1:InterfazUsuario ;
    rdfs:label "Ventana 'RESTART WINDOWS'"@es ;
    ns1:habilitadoPor ns1:ModoAdministrador,
        ns1:ModoSetup,
        ns1:ModoUsuario ;
    ns1:textoExtracto "Ventana de sistema 'RESTART WINDOWS' con tres botones que representan los modos de trabajo: 'Restart Windows in Administrator Mode', 'Restart Windows in Setup Mode' y 'Restart Windows in User Mode'."@es .

ns1:ModoUsuario a ns1:ModoOperacion ;
    rdfs:label "User Mode"@en ;
    ns1:textoExtracto "botón 'Restart Windows in User Mode'"@es .

ns1:Parametro_Disco_M2_SATA a ns1:Parametro ;
    rdfs:label "Parámetros S.M.A.R.T. del disco M2-SATA"@es ;
    ns1:textoExtracto "atributos (modelo, firmware, recuento de errores, temperatura, horas de encendido, etc.)"@es ;
    ns1:valor "Estado/vida útil (>75% aviso, >90% error)"@es .

ns1:Software_CNC_Help_Language_Changer a ns1:Manual ;
    rdfs:label "CNC Help Language Changer (SetupHelp_Vxx.xx.exe)"@es ;
    ns1:identificador "SetupHelp_Vxx.xx.exe" ;
    ns1:textoExtracto "procedimiento de obtención del instalador SetupHelp_Vxx.xx.exe y los tipos/idiomas de ayuda soportados."@es .

ns1:ModoAdministrador a ns1:ModoOperacion ;
    rdfs:label "Administrator Mode"@en ;
    ns1:textoExtracto "botón 'Restart Windows in Administrator Mode' [...] cartela de estado con fondo rojo y texto 'ADMINISTRATOR MODE' [...] entornos no protegidos."@es .

ns1:ModoSetup a ns1:ModoOperacion ;
    rdfs:label "Setup Mode"@en ;
    ns1:textoExtracto "botón 'Restart Windows in Setup Mode' [...] cartela de estado con fondo amarillo y texto 'SETUP MODE' [...] entornos no protegidos."@es .

