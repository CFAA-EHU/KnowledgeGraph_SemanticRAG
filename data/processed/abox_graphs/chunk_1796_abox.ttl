@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Esquema_CompensacionLaserCO2 a ns1:Esquema ;
    rdfs:label "Diagrama de compensación con eje esclavo (SLAVE) y trayectorias del rayo láser"@es ;
    ns1:ilustradoEn ns1:Pagina_105 ;
    ns1:textoExtracto "Diagrama de compensación con eje esclavo (SLAVE) y trayectorias del rayo láser. Muestra triedro X-Y y el efecto del seguimiento (#FOLLOW): líneas sólidas y discontinuas marcan el recorrido óptico y el desplazamiento del eje esclavo para mantener constante la longitud del haz, minimizando variaciones en el punto de corte."@es .

ns1:Esquema_ConfigEjesPlanoTorno a ns1:Esquema ;
    rdfs:label "Configuración de ejes tipo plano (torno)"@es ;
    ns1:ilustradoEn ns1:Pagina_114 ;
    ns1:textoExtracto "Ilustración 'Configuración de ejes tipo plano (torno)': máquina con dos ejes principales (Z+ y X+) representados; el plano de trabajo habitual es G18 (ZX). La vista ayuda a interpretar qué ejes forman abscisas/ordenadas y cómo afecta al mecanizado y a la definición del eje longitudinal."@es .

ns1:Esquema_ConfigEjesTriedroFresadora a ns1:Esquema ;
    rdfs:label "Configuración de ejes tipo triedro (fresadora)"@es ;
    ns1:ilustradoEn ns1:Pagina_114 ;
    ns1:textoExtracto "Ilustración 'Configuración de ejes tipo triedro': máquina con tres ejes (X+, Y+, Z+), propia de fresadora. Sirve para visualizar el triedro cartesiano y los planos G17/G18/G19 según el orden de ejes del canal, base para programar trayectorias en 3D."@es .

ns1:Secuencia_AlignC_Diametral a ns1:ModoOperacion ;
    rdfs:label "ALIGNC = Sí (mecanizado diametral)"@es ;
    ns1:documentadoEn ns1:Pagina_117 ;
    ns1:textoExtracto "Secuencia 'ALIGNC = Sí' (3 viñetas): mecanizado diametral con herramienta que sólo cubre media superficie; se muestra (1) avance hasta el centro, (2) giro de 180° del eje C y (3) retroceso para completar el mecanizado, indicando la necesidad de reorientar el eje para cubrir todo el diámetro."@es .

ns1:Pagina_105 a ns1:Pagina ;
    ns1:identificador "105" ;
    ns1:textoExtracto "Sección 2.3.33: Compensar la dispersión por el recorrido del láser de CO₂."@es .

ns1:Pagina_117 a ns1:Pagina ;
    ns1:identificador "117" ;
    ns1:textoExtracto "Sección 2.4.4: Configuración del eje C."@es .

ns1:Pagina_114 a ns1:Pagina ;
    ns1:identificador "114" ;
    ns1:textoExtracto "Sección 2.4.1–2.4.2: Configuración del canal (geométrica)."@es .

