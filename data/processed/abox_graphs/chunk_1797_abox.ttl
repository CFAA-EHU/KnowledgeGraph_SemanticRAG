@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionEjeC a ns1:Esquema ;
    rdfs:label "Secuencia ALIGNC = No"@es ;
    ns1:textoExtracto "Secuencia 'ALIGNC = No' (2 viñetas): la herramienta puede mecanizar diametralmente toda la superficie sin girar el eje C. Las viñetas muestran la trayectoria continua sobre el cilindro, resaltando la ausencia de realineamiento intermedio."@es .

ns1:DiagramaIsometrico a ns1:Esquema ;
    rdfs:label "Diagrama isométrico del husillo y su entorno inmediato"@es ;
    ns1:textoExtracto "Diagrama isométrico del husillo y su entorno inmediato que identifica la relación entre los parámetros LONGAXIS (eje longitudinal), FACEAXIS (eje transversal) y CAXIS (eje rotativo)."@es .

ns1:EsquemaLimites a ns1:Esquema ;
    rdfs:label "Esquema de límites PRB1/PRB2/PRB3 (máximos y mínimos) del palpador sobre los tres primeros ejes del canal"@es ;
    ns1:textoExtracto "Esquema de límites PRB1/PRB2/PRB3 (máximos y mínimos) del palpador sobre los tres primeros ejes del canal. Incluye un triedro X-Y-Z y vistas en planta con un bloque de referencia; flechas bidireccionales marcan cotas máximas y mínimas de cada eje, indicando que las posiciones se definen en coordenadas máquina (en torno, en radios)."@es .

ns1:GraficosComparativos a ns1:Tabla ;
    rdfs:label "Conjunto de tres gráficos comparativos de perfiles de movimiento: LINEAR, TRAPEZOIDAL y SQUARE SINE"@es ;
    ns1:textoExtracto "Conjunto de tres gráficos comparativos de perfiles de movimiento: LINEAR, TRAPEZOIDAL y SQUARE SINE. Para cada uno se representan velocidad v(t), aceleración a(t) y jerk j(t). La aceleración trapezoidal y seno-cuadrado suavizan cambios (jerk limitado), mientras que la lineal muestra transiciones bruscas; sirve para elegir el tipo de aceleración por defecto según dinámica y suavidad mecánica."@es .

