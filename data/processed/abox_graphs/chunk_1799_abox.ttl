@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FrecuenciaCentral_Notch a ns1:Frecuencia ;
    rdfs:label "Frecuencia central del filtro notch"@es ;
    ns1:monitoreaParametro ns1:Filtro_Notch_Antirresonante ;
    ns1:textoExtracto "frecuencia central (FREQUENCY)"@es ;
    ns1:valor "FREQUENCY" .

ns1:FrecuenciaCorte_PasoBajo a ns1:Frecuencia ;
    rdfs:label "Frecuencia de corte (–3 dB) del filtro paso bajo"@es ;
    ns1:monitoreaParametro ns1:Filtro_PasoBajo ;
    ns1:textoExtracto "caída a partir de la frecuencia de corte 'FREQUENCY', con marca de –3 dB (0,707·Ao)"@es ;
    ns1:valor "FREQUENCY" .

ns1:Herramienta_Frontal a ns1:Herramienta ;
    rdfs:label "Herramienta frontal para plano ZC"@es ;
    ns1:documentadoEn ns1:PlanoTrabajo_ZC ;
    ns1:textoExtracto "Render 3D [...] con una herramienta frontal. Se enfatiza la rotación del eje C y la traslación sobre Z para operaciones de fresado/posicionamiento angular"@es .

ns1:Regulador_EjesMuertos a ns1:ComponenteElectrico ;
    rdfs:label "Regulador para ejes muertos (tándem/verticales)"@es ;
    ns1:detalladoEnEsquema ns1:Diagrama_TemporizacionDwell ;
    ns1:textoExtracto "habilitar regulador [...] útil en ejes verticales pesados o tándem"@es .

ns1:Diagrama_TemporizacionDwell a ns1:Esquema ;
    rdfs:label "Diagrama temporal para temporización DWELL (ejes muertos)"@es ;
    ns1:identificador "DWELL" ;
    ns1:textoExtracto "Diagrama temporal que alinea las señales SERVOON y ENABLE con la 'Velocity Command', marcando el intervalo DWELL. Ilustra la secuencia de quitar freno, habilitar regulador y retardar el inicio de movimiento en ejes 'muertos'"@es .

ns1:Filtro_Notch_Antirresonante a ns1:ComponenteElectrico ;
    rdfs:label "Filtro notch (banda eliminada) para frecuencias de resonancia"@es ;
    ns1:controla ns1:SistemaCoordenadas_Torno ;
    ns1:identificador "Notch" ;
    ns1:textoExtracto "Curva de magnitud con una hendidura estrecha entre f1 y f2 que suprime la frecuencia de resonancia dentro de la banda pasante. Se destacan la frecuencia central (FREQUENCY) y el ancho de banda efectivo del notch para eliminar vibraciones específicas."@es .

ns1:Filtro_PasoBajo a ns1:ComponenteElectrico ;
    rdfs:label "Filtro paso bajo para resonancias"@es ;
    ns1:controla ns1:SistemaCoordenadas_Torno ;
    ns1:identificador "PasoBajo" ;
    ns1:textoExtracto "Curva de magnitud típica de un filtro paso bajo: respuesta plana (Ao) y caída a partir de la frecuencia de corte 'FREQUENCY', con marca de –3 dB (0,707·Ao). El gráfico explica el efecto de limitar banda para suavizar movimientos y evitar resonancias altas."@es .

ns1:PlanoTrabajo_XC a ns1:ModoOperacion ;
    rdfs:label "Plano de trabajo XC (ejes X–C)"@es ;
    ns1:identificador "XC" ;
    ns1:textoExtracto "Render 3D del torno mostrando el eje C activado y el plano de trabajo XC (ejes X–C con Z visible al fondo). El gráfico contextualiza el mecanizado con eje C, destacando la orientación de la herramienta respecto al plato y el sistema de coordenadas."@es .

ns1:PlanoTrabajo_ZC a ns1:ModoOperacion ;
    rdfs:label "Plano de trabajo ZC (ejes Z–C)"@es ;
    ns1:identificador "ZC" ;
    ns1:textoExtracto "Render 3D que representa el plano de trabajo ZC (ejes Z–C) con una herramienta frontal. Se enfatiza la rotación del eje C y la traslación sobre Z para operaciones de fresado/posicionamiento angular, diferenciando el plano respecto al caso XC."@es .

ns1:SistemaCoordenadas_Torno a ns1:Sistema ;
    rdfs:label "Sistema de coordenadas del torno (ejes X, Z, C)"@es ;
    ns1:ilustradoEn ns1:PlanoTrabajo_XC,
        ns1:PlanoTrabajo_ZC ;
    ns1:textoExtracto "destacando la orientación de la herramienta respecto al plato y el sistema de coordenadas"@es .

