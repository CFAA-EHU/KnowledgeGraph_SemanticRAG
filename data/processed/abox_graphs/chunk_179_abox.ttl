ex:EnlaceXT1 a owl:Class ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/>.

ex:Señal24S24SAFE a owl:Class ;
    rdfs:isDefinedBy <https://vocab.cfaa.eus/broaching/>.

