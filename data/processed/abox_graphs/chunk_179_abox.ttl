ex:tieneSeñalesDigitales a owl:ObjectProperty ;
    rdfs:domain ex:ServomotorDERECHAAXD2 ;
    rdfs:range ex:Señal24S24SAFE.

ex:tieneRelésAsociados a owl:ObjectProperty ;
    rdfs:domain ex:ServomotorDERECHAAXD2 ;
    rdfs:range ex:Relé27KAx.

ex:tieneEnlaces a owl:ObjectProperty ;
    rdfs:domain ex:ServomotorDERECHAAXD2 ;
    rdfs:range ex:EnlaceXT1.

ex:tieneLineasRoja a owl:ObjectProperty ;
    rdfs:domain ex:ServomotorDERECHAAXD1 ;
    rdfs:range ex:LineaRoja.

ex:tieneLineasVerdeAzul a owl:ObjectProperty ;
    rdfs:domain ex:ServomotorDERECHAAXD1 ;
    rdfs:range ex:LineaVerdeAzul.

ex:tieneDrive a owl:ObjectProperty ;
    rdfs:domain ex:ServomotorMESAAXD1 ;
    rdfs:range admin:Drive.

ex:tieneRelésAsociados a owl:ObjectProperty ;
    rdfs:domain ex:ServomotorMESAAXD1 ;
    rdfs:range ex:Relé27KAx.

ex:tieneEnlaces a owl:ObjectProperty ;
    rdfs:domain ex:ServomotorMESAAXD1 ;
    rdfs:range ex:EnlaceXT1.

ex:tieneSensor a owl:ObjectProperty ;
    rdfs:domain ex:PuertaSeguridad ;
    rdfs:range admin:Sensor.

ex:tieneBloqueCTPL1APMHAAS a owl:ObjectProperty ;
    rdfs:domain ex:PuertaSeguridad ;
    rdfs:range ex:BloqueCTPL1APMHAAS.

ex:tieneMonitoringOutputs a owl:ObjectProperty ;
