@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Figura_AvanceVsErrorSeguimiento a ns1:Figura ;
    rdfs:label "Gráfico de avance real vs. error de seguimiento"@es ;
    ns1:ilustradoEn ns1:Parametro_PROGAIN ;
    ns1:textoExtracto "gráfico con fondo cuadriculado que muestra 'Actual Feed' (avance real) y 'Following Error (E)' (error de seguimiento) durante una maniobra de aceleración y parada."@es .

ns1:Figura_HisteresisInversion a ns1:Figura ;
    rdfs:label "Diagrama temporal de histéresis REVEHYST"@es ;
    ns1:ilustradoEn ns1:Parametro_REVEHYST ;
    ns1:textoExtracto "diagrama temporal 'Posición' frente a 't' que ilustra la histéresis REVEHYST en inversiones de movimiento. Se marcan con flechas los instantes de inversión de consigna (1), el umbral REVEHYST que habilita la compensación de holgura (2) y la cancelación de la compensación (3)."@es .

ns1:Figura_RespuestaMaquina a ns1:Figura ;
    rdfs:label "Gráfico de respuesta de máquina (amplitud vs. frecuencia)"@es ;
    ns1:ilustradoEn ns1:Parametro_Ao,
        ns1:Parametro_Ar,
        ns1:Parametro_SHARE,
        ns1:Parametro_fr ;
    ns1:textoExtracto "Gráfico de respuesta de máquina que muestra amplitud base (Ao), sobrepasamiento en resonancia (Ar) y frecuencia de resonancia (fr), acompañado de la fórmula SHARE=100(Ar–Ao)/Ar."@es .

ns1:Parametro_AnchoBandaNotch a ns1:Parametro ;
    rdfs:label "Ancho de banda efectivo del notch"@es ;
    ns1:textoExtracto "Se destacan la frecuencia central (FREQUENCY) y el ancho de banda efectivo del notch para eliminar vibraciones específicas."@es .

ns1:Parametro_FREQUENCY a ns1:Parametro ;
    rdfs:label "Frecuencia central (FREQUENCY)"@es ;
    ns1:textoExtracto "Se destacan la frecuencia central (FREQUENCY) y el ancho de banda efectivo del notch para eliminar vibraciones específicas."@es ;
    ns1:valor "FREQUENCY" .

ns1:Parametro_Ao a ns1:Parametro ;
    rdfs:label "Amplitud base (Ao)"@es ;
    ns1:identificador "Ao" ;
    ns1:textoExtracto "Gráfico de respuesta de máquina que muestra amplitud base (Ao), sobrepasamiento en resonancia (Ar) y frecuencia de resonancia (fr)"@es .

ns1:Parametro_Ar a ns1:Parametro ;
    rdfs:label "Sobrepasamiento en resonancia (Ar)"@es ;
    ns1:identificador "Ar" ;
    ns1:textoExtracto "Gráfico de respuesta de máquina que muestra amplitud base (Ao), sobrepasamiento en resonancia (Ar) y frecuencia de resonancia (fr)"@es .

ns1:Parametro_PROGAIN a ns1:Parametro ;
    rdfs:label "Ganancia proporcional (PROGAIN)"@es ;
    ns1:identificador "PROGAIN" ;
    ns1:textoExtracto "útil para visualizar el ajuste de la ganancia proporcional (PROGAIN)."@es .

ns1:Parametro_REVEHYST a ns1:Parametro ;
    rdfs:label "Histéresis de inversión (REVEHYST)"@es ;
    ns1:identificador "REVEHYST" ;
    ns1:textoExtracto "diagrama temporal 'Posición' frente a 't' que ilustra la histéresis REVEHYST en inversiones de movimiento."@es .

ns1:Parametro_SHARE a ns1:Parametro ;
    rdfs:label "SHARE"@es ;
    ns1:textoExtracto "Gráfico de respuesta de máquina que muestra [...] la fórmula SHARE=100(Ar–Ao)/Ar."@es ;
    ns1:valor "SHARE=100(Ar–Ao)/Ar" .

ns1:Parametro_fr a ns1:Parametro ;
    rdfs:label "Frecuencia de resonancia (fr)"@es ;
    ns1:identificador "fr" ;
    ns1:textoExtracto "Gráfico de respuesta de máquina que muestra amplitud base (Ao), sobrepasamiento en resonancia (Ar) y frecuencia de resonancia (fr)"@es .

