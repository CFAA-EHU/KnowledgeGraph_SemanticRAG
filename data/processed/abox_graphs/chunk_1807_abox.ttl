@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:HeadRef a ns1:Pagina ;
    rdfs:label "Parámetros máquina de las cinemáticas – 2.9.1 HEADREF"@es ;
    ns1:documentadoEn ns1:DefinicionCinematicas,
        ns1:EsquemasComparativos,
        ns1:PlanchasCotas ;
    ns1:identificador "254" ;
    ns1:textoExtracto "y los modos de eje C (TYPE=41–43) y definiciones vectoriales (TYPE=50–52). Las imágenes esquematizan la cadena cinemática y el reparto de grados de libertad."@es .

ns1:DefinicionCinematicas a ns1:Pagina ;
    rdfs:label "Parámetros máquina de las cinemáticas – 2.9.2 Definición de las cinemáticas del cabezal"@es ;
    ns1:identificador "256" ;
    ns1:textoExtracto "Doble esquema de 'posición de referencia HEAD/TOOL' que compara 'Tool base/Auto tool base' frente a 'Head base'. Se marca la nariz del portaherramientas y vectores de referencia para visualizar dónde se sitúa el punto de referencia tras calibración o activación."@es .

ns1:EsquemasComparativos a ns1:Pagina ;
    rdfs:label "Parámetros máquina de las cinemáticas – 2.9.2 (TDATA para TYPE 1–5)"@es ;
    ns1:identificador "257" ;
    ns1:textoExtracto "Tríptico A-B-C con siluetas de 'cabezal esférico', 'cabezal ortogonal' y 'cabezal angular', seguido de dos esquemas comparativos que muestran la condición geométrica correcta/incorrecta del eje rotativo principal respecto a los ejes X/Y/Z. Incluye letras A/B/C y ángulo α para orientar distancias TDATA."@es .

ns1:PlanchasCotas a ns1:Pagina ;
    rdfs:label "Parámetros máquina de las cinemáticas – 2.9.2 (TDATA para TYPE 6–8)"@es ;
    ns1:identificador "258" ;
    ns1:textoExtracto "Tres viñetas (TYPE=6…8) con la misma gramática gráfica de cotas y signos para cabezales angulares YZ/ZX/ZY."@es .

