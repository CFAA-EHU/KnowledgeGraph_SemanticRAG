@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "cabezal" ;
    ns1:identificador "cabezal" ;
    ns1:textoExtracto "posición del cabezal respecto al punto de referencia" .

ns1:EjeRotativo a ns1:ComponenteMecanico ;
    rdfs:label "eje rotativo" ;
    ns1:identificador "eje rotativo" ;
    ns1:textoExtracto "Ilustra el criterio de signo para TDATA10/TDATA11 en ejes rotativos" .

ns1:EjeSecundario a ns1:ComponenteMecanico ;
    rdfs:label "eje secundario" ;
    ns1:identificador "eje secundario" ;
    ns1:textoExtracto "desplazamientos de herramienta vs. eje secundario" .

ns1:Herramienta a ns1:ComponenteMecanico ;
    rdfs:label "herramienta" ;
    ns1:identificador "herramienta" ;
    ns1:textoExtracto "diagramas del sentido de giro (TDATA10/TDATA11) desde el punto de vista de la herramienta" .

ns1:MesaAC a ns1:ComponenteMecanico ;
    rdfs:label "mesa AC" ;
    ns1:identificador "mesa AC" ;
    ns1:textoExtracto "Dos bloques de viñetas para mesas AC y BA con cotas TDATA2–TDATA5 y pares de dibujos que comparan configuraciones de sentido de giro (TDATA10/TDATA11 = 0/1)" .

ns1:MesaBA a ns1:ComponenteMecanico ;
    rdfs:label "mesa BA" ;
    ns1:identificador "mesa BA" ;
    ns1:textoExtracto "Dos bloques de viñetas para mesas AC y BA con cotas TDATA2–TDATA5 y pares de dibujos que comparan configuraciones de sentido de giro (TDATA10/TDATA11 = 0/1)" .

ns1:MesaBC a ns1:ComponenteMecanico ;
    rdfs:label "mesa BC" ;
    ns1:identificador "mesa BC" ;
    ns1:textoExtracto "Viñetas de mesa BC con distancias TDATA2–TDATA5 y los dos casos de sentido de giro posibles" .

ns1:MesaRotativa a ns1:ComponenteMecanico ;
    rdfs:label "mesa rotativa" ;
    ns1:identificador "mesa rotativa" ;
    ns1:textoExtracto "Conjunto de esquemas de mesa rotativa AB: vista iso con distancias TDATA2–TDATA5 hacia el punto de referencia, y diagramas del sentido de giro (TDATA10/TDATA11) desde el punto de vista de la herramienta" .

ns1:PuntoReferencia a ns1:ComponenteMecanico ;
    rdfs:label "punto de referencia" ;
    ns1:identificador "punto de referencia" ;
    ns1:textoExtracto "posición del cabezal respecto al punto de referencia" .

ns1:SentidoGiro a ns1:Parametro ;
    rdfs:label "sentido de giro" ;
    ns1:identificador "sentido de giro" ;
    ns1:textoExtracto "los dos casos de sentido de giro posibles" .

ns1:TDATA10 a ns1:Parametro ;
    rdfs:label "TDATA10" ;
    ns1:identificador "TDATA10" ;
    ns1:textoExtracto "Ilustra el criterio de signo para TDATA10/TDATA11 en ejes rotativos" .

ns1:TDATA11 a ns1:Parametro ;
    rdfs:label "TDATA11" ;
    ns1:identificador "TDATA11" ;
    ns1:textoExtracto "Ilustra el criterio de signo para TDATA10/TDATA11 en ejes rotativos" .

ns1:TDATA12 a ns1:Parametro ;
    rdfs:label "TDATA12" ;
    ns1:identificador "TDATA12" ;
    ns1:textoExtracto "Dos bloques de viñetas para mesas AC y BA con cotas TDATA2–TDATA5 y pares de dibujos que comparan configuraciones de sentido de giro (TDATA10/TDATA11 = 0/1)" .

ns1:TDATA13 a ns1:Parametro ;
    rdfs:label "TDATA13" ;
    ns1:identificador "TDATA13" ;
    ns1:textoExtracto "Se destacan TDATA13–TDATA15 (posición del cabezal respecto al punto de referencia)" .

ns1:TDATA14 a ns1:Parametro ;
    rdfs:label "TDATA14" ;
    ns1:identificador "TDATA14" ;
    ns1:textoExtracto "Se destacan TDATA13–TDATA15 (posición del cabezal respecto al punto de referencia)" .

ns1:TDATA15 a ns1:Parametro ;
    rdfs:label "TDATA15" ;
    ns1:identificador "TDATA15" ;
    ns1:textoExtracto "Se destacan TDATA13–TDATA15 (posición del cabezal respecto al punto de referencia)" .

ns1:TDATA2 a ns1:Parametro ;
    rdfs:label "TDATA2" ;
    ns1:identificador "TDATA2" ;
    ns1:textoExtracto "Conjunto de esquemas de mesa rotativa AB: vista iso con distancias TDATA2–TDATA5 hacia el punto de referencia" .

ns1:TDATA3 a ns1:Parametro ;
    rdfs:label "TDATA3" ;
    ns1:identificador "TDATA3" ;
    ns1:textoExtracto "Viñetas de mesa BC con distancias TDATA2–TDATA5 y los dos casos de sentido de giro posibles" .

ns1:TDATA4 a ns1:Parametro ;
    rdfs:label "TDATA4" ;
    ns1:identificador "TDATA4" ;
    ns1:textoExtracto "Viñetas de mesa BC con distancias TDATA2–TDATA5 y los dos casos de sentido de giro posibles" .

ns1:TDATA5 a ns1:Parametro ;
    rdfs:label "TDATA5" ;
    ns1:identificador "TDATA5" ;
    ns1:textoExtracto "Viñetas de mesa BC con distancias TDATA2–TDATA5 y los dos casos de sentido de giro posibles" .

ns1:TDATA6 a ns1:Parametro ;
    rdfs:label "TDATA6" ;
    ns1:identificador "TDATA6" ;
    ns1:textoExtracto "Se destacan TDATA5–TDATA7 (desplazamientos de herramienta vs. eje secundario)" .

ns1:TDATA7 a ns1:Parametro ;
    rdfs:label "TDATA7" ;
    ns1:identificador "TDATA7" ;
    ns1:textoExtracto "Se destacan TDATA5–TDATA7 (desplazamientos de herramienta vs. eje secundario)" .

