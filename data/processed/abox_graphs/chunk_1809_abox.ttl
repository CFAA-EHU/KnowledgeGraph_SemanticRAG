@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FiguraIconosIntroductorios a ns1:Figura ;
    ns1:ilustradoEn ns1:IconosIntroductorios ;
    ns1:textoExtracto "Tres iconos introductorios que representan, en perspectiva, combinaciones de cabezal y mesa con un eje de giro en el cabezal y otro en la mesa." .

ns1:IconosIntroductorios a ns1:AvisoSeguridad ;
    rdfs:label "Tres iconos introductorios que representan, en perspectiva, combinaciones de cabezal y mesa con un eje de giro en el cabezal y otro en la mesa." ;
    ns1:ilustradoEn ns1:FiguraIconosIntroductorios ;
    ns1:textoExtracto "Tres iconos introductorios que representan, en perspectiva, combinaciones de cabezal y mesa con un eje de giro en el cabezal y otro en la mesa." .

ns1:DiagramaComparativoADiagramaComparativoB a ns1:AvisoSeguridad ;
    rdfs:label "Gráfico comparativo \"#RTCP ON B-30\"" ;
    ns1:detalladoEnEsquema ns1:EsquemaComparativoRTCP ;
    ns1:ilustradoEn ns1:FiguraComparativaRTCP ;
    ns1:textoExtracto "Un diagrama adicional contrasta el origen de RTCP respecto a cero máquina/pieza (TDATA7) mediante ejes X′-Y′." .

ns1:EsquemaComparativoRTCP a ns1:Esquema ;
    ns1:detalladoEnEsquema ns1:DiagramaComparativoADiagramaComparativoB ;
    ns1:ilustradoEn ns1:FiguraComparativaRTCP ;
    ns1:textoExtracto "Gráfico comparativo \"#RTCP ON B-30\" con dos escenas: TDATA16=0 (el sistema de coordenadas pieza gira con la pieza) frente a TDATA16=1 (el sistema pieza se mantiene paralelo al sistema máquina). Se visualizan ejes X′-Z′ y vector de inclinación B." .

ns1:EsquemaVi_etasCombinaciones a ns1:Esquema ;
    ns1:detalladoEnEsquema ns1:Vi_etasCombinacionesA_B ;
    ns1:ilustradoEn ns1:FiguraVi_etasCombinaciones ;
    ns1:textoExtracto "Dos conjuntos de viñetas para las combinaciones A-B y A-C: cotas TDATA1…TDATA6 para separar nariz, ejes de rotación y referencia máquina, más TDATA13…TDATA15 para colocación del cabezal. Incluye croquis de inversión del sentido de giro (TDATA11=0/1)." .

ns1:FiguraComparativaRTCP a ns1:Figura ;
    ns1:ilustradoEn ns1:DiagramaComparativoADiagramaComparativoB,
        ns1:EsquemaComparativoRTCP ;
    ns1:textoExtracto "Se visualizan ejes X′-Z′ y vector de inclinación B." .

ns1:FiguraVi_etasCombinaciones a ns1:Figura ;
    ns1:ilustradoEn ns1:EsquemaVi_etasCombinaciones,
        ns1:Vi_etasCombinacionesA_B ;
    ns1:textoExtracto "Incluye croquis de inversión del sentido de giro (TDATA11=0/1)." .

ns1:Vi_etasCombinacionesA_B a ns1:AvisoSeguridad ;
    rdfs:label "Dos conjuntos de viñetas para las combinaciones A-B y A-C" ;
    ns1:detalladoEnEsquema ns1:EsquemaVi_etasCombinaciones ;
    ns1:ilustradoEn ns1:FiguraVi_etasCombinaciones ;
    ns1:textoExtracto "Dos conjuntos de viñetas para las combinaciones A-B y A-C: cotas TDATA1…TDATA6 para separar nariz, ejes de rotación y referencia máquina, más TDATA13…TDATA15 para colocación del cabezal. Incluye croquis de inversión del sentido de giro (TDATA11=0/1)." .

