@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix elec: <https://vocab.cfaa.eus/broaching/electricidad/> .
@prefix mecanica: <https://vocab.cfaa.eus/broaching/mecanica/> .

### Clases ###
elec:BloqueCTPL1APMHAAS a owl:Class ;
    rdfs:label "Bloque CTP-L1-AP-M-HA-AZ-SA" .

elec:BloqueCTP25SQ1 a owl:Class ;
    rdfs:label "Bloque CTP para escotilla interior (25SQ1)" .

elec:PNOZmultiBaseUnit a owl:Class ;
    rdfs:label "Arquitectura PNOZ m B0 + EF 16DI" .

elec:Relé27KAx a owl:Class ;
    rdfs:label "Relé 27KA1–8" .

elec:PletinaDeBornes a owl:Class ;
    rdfs:label "Pletina de bornes" .

elec:SalidaSegura a owl:Class ;
    rdfs:label "Salida segura" .

### Propiedades de Objeto ###
elec:tieneSafetyOutputs a owl:ObjectProperty ;
    rdfs:domain elec:BloqueCTPL1APMHAAS ;
    rdfs:range elec:SafetyOutput .

elec:tieneMonitoringOutputs a owl:ObjectProperty ;
    rdfs:domain elec:BloqueCTPL1APMHAAS ;
    rdfs:range elec:MonitoringOutput .

