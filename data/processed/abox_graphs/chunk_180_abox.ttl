@prefix ex: <https://vocab.cfaa.eus/broaching/>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

ex:BloqueCTPL1APMHAAS a owl:Class ;
    rdfs:label "Bloque CTP-L1-AP-M-HA-AZ-SA" ;
    rdfs:comment "Bloque CTP-L1-AP-M-HA-AZ-SA para puertas de seguridad" .

ex:SafetyOutput a owl:Class ;
    rdfs:label "Safety Output" ;
    rdfs:comment "Salida de seguridad" .

ex:MonitoringOutput a owl:Class ;
    rdfs:label "Monitoring Output" ;
    rdfs:comment "Salida de monitorización" .

ex:BloqueCTP25SQ1 a owl:Class ;
    rdfs:label "Bloque CTP 25SQ1" ;
    rdfs:comment "Bloque CTP para escotilla interior" .

ex:PNOZmultiBaseUnit a owl:Class ;
    rdfs:label "PNOZ m B0 + EF 16DI" ;
    rdfs:comment "Arquitectura PNOZ m B0 + EF 16DI" .

ex:Relé27KAx a owl:Class ;
    rdfs:label "Relé 27KA1–8" ;
    rdfs:comment "Relés de potencia 27KA1–8" .

ex:PletinaDeBornes a owl:Class ;
    rdfs:label "Pletina de bornes" ;
    rdfs:comment "Pletina de bornes" .

ex:SalidaDeSeguridad a owl:Class ;
    rdfs:label "Salida de seguridad" ;
    rdfs:comment "Salida de seguridad" .

ex:SalidaDeDiagnostico a owl:Class ;
    rdfs:label "Salida de diagnóstico" ;
    rdfs:comment "Salida de diagnóstico" .

ex:ParadaDeEmergencia a owl:Class ;
    rdfs:label "Parada de emergencia" ;
    rdfs:comment "Parada de emergencia" .

ex:Pupitre a owl:Class ;
    rdfs:label "Pupitre" ;
    rdfs:comment "Pupitre de mando" .

ex:Armario a owl:Class ;
    rdfs:label "Armario" ;
    rdfs:comment "Armario eléctrico" .

ex:PuestaServicio a owl:Class ;
    rdfs:label "Puesta de servicio" ;
    rdfs:comment "Puesta de servicio" .

ex:ParoServicio a owl:Class ;
    rdfs:label "Paro de servicio" ;
    rdfs:comment "Paro de servicio" .

ex:PLCOK a owl:Class ;
    rdfs:label "PLC OK" ;
    rdfs:comment "Estado PLC OK" .

ex:EnlaceXT1 a owl:Class ;
    rdfs:label "Enlace XT1" ;
    rdfs:comment "Enlace XT1" .

ex:EnlaceXT13 a owl:Class ;
    rdfs:label "Enlace XT1.3" ;
    rdfs:comment "Enlace XT1.3" .

ex:EnlaceXT2 a owl:Class ;
    rdfs:label "Enlace XT2" ;
    rdfs:comment "Enlace XT2" .

ex:LeyendaDeBitsFunciones a owl:Class ;
    rdfs:label "Leyenda de bits/funciones" ;
    rdfs:comment "Leyenda de bits/funciones" .

ex:BancoRelés27KA18 a owl:Class ;
    rdfs:label "Banco de relés 27KA1–8" ;
    rdfs:comment "Banco de relés de potencia 27KA1–8" .

ex:EmergenciaCH1CH2 a owl:Class ;
    rdfs:label "Emergencia CH1/CH2" ;
    rdfs:comment "Parada de emergencia CH1/CH2" .

ex:EmergenciaRetardadaCH1CH2 a owl:Class ;
    rdfs:label "Emergencia retardada CH1/CH2" ;
    rdfs:comment "Parada de emergencia retardada CH1/CH2" .

ex:PuertasCH1CH2 a owl:Class ;
    rdfs:label "Puertas CH1/CH2" ;
    rdfs:comment "Control de puertas CH1/CH2" .

ex:FrenoCH1CH2 a owl:Class ;
    rdfs:label "Freno CH1/CH2" ;
    rdfs:comment "Control de frenos CH1/CH2" .

ex:ConexionComun0SAFE a owl:Class ;
    rdfs:label "Conexión común a 0SAFE" ;
    rdfs:comment "Conexión común a 0SAFE" .

ex:SimbologiaContactosBobinas a owl:Class ;
    rdfs:label "Simbología de contactos y bobinas" ;
    rdfs:comment "Simbología de contactos y bobinas" .

ex:tieneSafetyOutputs a owl:ObjectProperty ;
    rdfs:domain ex:BloqueCTPL1APMHAAS ;
    rdfs:range ex:SafetyOutput .

ex:tieneMonitoringOutputs a owl:ObjectProperty ;
    rdfs:domain ex:BloqueCTPL1APMHAAS ;
    rdfs:range ex:MonitoringOutput .

ex:tieneCableadoMulticolor a owl:ObjectProperty ;
    rdfs:domain ex:BloqueCTPL1APMHAAS ;
    rdfs:range xsd:string .

ex:tieneRótulos a owl:ObjectProperty ;
    rdfs:domain ex:BloqueCTPL1APMHAAS ;
    rdfs:range xsd:string .

ex:tieneEnlaces a owl:ObjectProperty ;
    rdfs:domain ex:BloqueCTPL1APMHAAS ;
    rdfs:range xsd:string .

ex:tieneSalidasDeSeguridad a owl:ObjectProperty ;
    rdfs:domain ex:BloqueCTP25SQ1 ;
    rdfs:range ex:SalidaDeSeguridad .

ex:tieneSalidasDeDiagnostico a owl:ObjectProperty ;
    rdfs:domain ex:BloqueCTP25SQ1 ;
    rdfs:range ex:SalidaDeDiagnostico .

