    rdfs:domain ex:PNOZmultiBaseUnit ;
    rdfs:range ex:Armario .

ex:tienePuestaServicio a owl:ObjectProperty ;
    rdfs:domain ex:PNOZmultiBaseUnit ;
    rdfs:range ex:PuestaServicio .

ex:tieneParoServicio a owl:ObjectProperty ;
    rdfs:domain ex:PNOZmultiBaseUnit ;
    rdfs:range ex:ParoServicio .

ex:tienePLCOK a owl:ObjectProperty ;
    rdfs:domain ex:PNOZmultiBaseUnit ;
    rdfs:range ex:PLCOK .

ex:tieneSalidasRelés a owl:ObjectProperty ;
    rdfs:domain ex:PNOZmultiBaseUnit ;
    rdfs:range ex:Relé27KAx .

ex:tienePletinasDeBornes a owl:ObjectProperty ;
    rdfs:domain ex:PNOZmultiBaseUnit ;
    rdfs:range ex:PletinaDeBornes .

