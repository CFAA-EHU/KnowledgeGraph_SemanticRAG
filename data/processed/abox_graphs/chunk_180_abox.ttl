    rdfs:domain ex:BloqueCTP25SQ1 ;
    rdfs:range xsd:string .

ex:tieneSimbologia a owl:ObjectProperty ;
    rdfs:domain ex:BloqueCTP25SQ1 ;
    rdfs:range ex:SimbologiaContactosBobinas .

ex:tieneEntradasSalidas a owl:ObjectProperty ;
    rdfs:domain ex:PNOZmultiBaseUnit ;
    rdfs:range xsd:string .

ex:tieneParadasDeEmergencia a owl:ObjectProperty ;
    rdfs:domain ex:PNOZmultiBaseUnit ;
    rdfs:range ex:ParadaDeEmergencia .

