elec:tieneSalidasSeguridad a owl:ObjectProperty ;
    rdfs:domain elec:BloqueCTP25SQ1 ;
    rdfs:range elec:SalidaSegura .

elec:tieneDiagnostico a owl:ObjectProperty ;
    rdfs:domain elec:BloqueCTP25SQ1 ;
    rdfs:range elec:Diagnostico .

