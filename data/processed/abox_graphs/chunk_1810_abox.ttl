@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina1516 a ns1:Maquina ;
    rdfs:label "TYPE=15 y TYPE=16"@es ;
    ns1:detalladoEnEsquema ns1:MaquinaTYPE17 ;
    ns1:identificador "TYPE=15 y TYPE=16" ;
    ns1:textoExtracto "Incluye croquis de inversión del sentido de giro (TDATA11=0/1). --- Páginas: 268 | Sección: Parámetros máquina de las cinemáticas – 2.9.4 Cabezal-mesa (tipos 15 y 16) | Título: TYPE=15 y TYPE=16 ---"@es .

ns1:Maquina3Ejes a ns1:Maquina ;
    rdfs:label "cabezal ortogonal con tres ejes de giro (principal, secundario, terciario)"@es ;
    ns1:identificador "cabezal ortogonal con tres ejes de giro" ;
    ns1:textoExtracto "Ilustración del cabezal ortogonal con tres ejes de giro (principal, secundario, terciario). Acompañada de la enumeración TDATA1…TDATA12, el gráfico identifica la nariz del mandrino, los centros de giro 1º–3º y las distancias entre centros y eje de herramienta, con indicación del signo positivo en cada eje. --- Páginas: 271 | Sección: 2. PARÁMETROS MÁQUINA · Parámetros máquina de las cinemáticas | Título: — ---"@es .

ns1:MaquinaTYPE17 a ns1:Maquina ;
    rdfs:label "cinemática TYPE=17"@es ;
    ns1:identificador "cinemática TYPE=17" ;
    ns1:textoExtracto "Esquema de cinemática TYPE=17 para cabezal/mesa con ejes lineales X-Y-Z y rotativos A/B/C. Se muestran los tres órdenes de rotación (1º, 2º, 3º) y las distancias/offsets etiquetadas como TDATA (1, 2, 3, 4, 6, 7, 8, 9, 10, 11, 12). Las flechas indican sentidos positivos (+/−) y la disposición espacial del conjunto. --- Páginas: 271 | Sección: 2."@es .

