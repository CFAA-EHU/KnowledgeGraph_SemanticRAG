@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Esquema_21_21_1 a ns1:Esquema ;
    ns1:textoExtracto "Conjunto de diagramas de mesa basados en vectores T1/T2 y V1/V2. Se representan dos configuraciones espaciales con ejes X-Y-Z, flechas de giro y etiquetas TDATA1–16 para posiciones, direcciones y reposo/sentido del eje principal." ;
    ns1:tieneComponente ns1:Etiqueta_TDATA1_16,
        ns1:Vector_T1,
        ns1:Vector_T2,
        ns1:Vector_V1,
        ns1:Vector_V2 .

ns1:Esquema_21_21_2 a ns1:Esquema ;
    ns1:textoExtracto "Vista detallada de los vectores T1/T2 y V1/V2 con componentes TDATA1–6 y TDATA11–16. Se marcan con signos (+/−) las proyecciones sobre cada eje y se indica la relación geométrica entre los dos ejes rotativos de la mesa." ;
    ns1:tieneComponente ns1:Componente_TDATA11_16,
        ns1:Componente_TDATA1_6,
        ns1:Vector_T1,
        ns1:Vector_T2,
        ns1:Vector_V1,
        ns1:Vector_V2 .

ns1:Esquema_21_21_3 a ns1:Esquema ;
    ns1:textoExtracto "Ilustración de mano y ejes para sentido de giro, complementada por dos diagramas circulares comparativos que muestran el origen RTCP respecto a cero máquina (C=0°) frente a cero pieza (C'=0°). Incluye ejes X-Y y referencias X'-Y'." ;
    ns1:tieneComponente ns1:Diagrama_RTCP,
        ns1:Eje_X_Prima_Y_Prima,
        ns1:Eje_X_Y .

ns1:Esquema_21_21_4 a ns1:Esquema ;
    ns1:textoExtracto "Esquemas de RTCP con pieza girando alrededor de B y dos escenarios del sistema de coordenadas pieza (TDATA31=0/1). Se dibujan X', Z' y la orientación B-30°, explicando si el sistema gira con la pieza o permanece paralelo al de máquina." ;
    ns1:tieneComponente ns1:Diagrama_RTCP,
        ns1:Eje_B,
        ns1:Eje_X_Prima,
        ns1:Eje_Z_Prima .

ns1:Componente_TDATA11_16 a ns1:Componente ;
    ns1:textoExtracto "componentes TDATA11–16" .

ns1:Componente_TDATA1_6 a ns1:Componente ;
    ns1:textoExtracto "componentes TDATA1–6" .

ns1:Eje_B a ns1:ComponenteMecanico ;
    ns1:textoExtracto "eje B" .

ns1:Eje_X_Prima a ns1:ComponenteMecanico ;
    ns1:textoExtracto "X'" .

ns1:Eje_X_Prima_Y_Prima a ns1:ComponenteMecanico ;
    ns1:textoExtracto "referencias X'-Y'" .

ns1:Eje_X_Y a ns1:ComponenteMecanico ;
    ns1:textoExtracto "ejes X-Y" .

ns1:Eje_Z_Prima a ns1:ComponenteMecanico ;
    ns1:textoExtracto "Z'" .

ns1:Etiqueta_TDATA1_16 a ns1:Componente ;
    ns1:textoExtracto "etiquetas TDATA1–16" .

ns1:Diagrama_RTCP a ns1:Esquema ;
    ns1:textoExtracto "diagramas circulares comparativos que muestran el origen RTCP" .

ns1:Vector_T1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "vectores T1/T2" .

ns1:Vector_T2 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "vectores T1/T2" .

ns1:Vector_V1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "vectores V1/V2" .

ns1:Vector_V2 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "vectores V1/V2" .

