@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:T1 a ns1:ComponenteElectrico ;
    ns1:identificador "T1" ;
    ns1:textoExtracto "Se representan ejes X-Y-Z, flechas, y jerarquía de elementos (cabezal vs mesa). --- Páginas: 286 | Sección: 2. PARÁMETROS MÁQUINA · Definición vectorial de cinemáticas cabezal-mesa (tipo 52) | Título: — ---" .

