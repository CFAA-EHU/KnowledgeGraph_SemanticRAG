@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Figura_ConvencionManosTDATA38 a ns1:Figura ;
    rdfs:label "Ilustración de convención de mano derecha para TDATA38" ;
    ns1:ilustradoEn ns1:Parametro_TDATA38 ;
    ns1:textoExtracto "Ilustraciones de mano con ejes para sentido de giro del eje rotativo principal de la mesa (TDATA38), reforzando la convención de la mano derecha para signos y direcciones." .

ns1:Figura_DiagramaRTCP a ns1:Figura ;
    rdfs:label "Diagrama comparativo de origen RTCP (cero máquina vs. cero pieza)" ;
    ns1:ilustradoEn ns1:Parametro_CinematicaTipo52 ;
    ns1:textoExtracto "Doble diagrama circular comparando origen RTCP en la mesa: aplicación respecto a cero máquina (C=0°) frente a cero pieza (C'=0°). Se muestran sistemas X-Y y X'-Y', marcando equivalencias X=X', Y=Y' en cada caso." .

ns1:Figura_EsquemaRTCP_B30 a ns1:Figura ;
    rdfs:label "Esquema RTCP ON con pieza girada B-30°" ;
    ns1:ilustradoEn ns1:Parametro_TDATA51 ;
    ns1:textoExtracto "Esquemas RTCP ON con pieza girada B-30° y comparación TDATA51=0/1. Se representan X', Z' y la posición de la herramienta" .

ns1:Figura_TransformacionEjeInclinado a ns1:Figura ;
    rdfs:label "Esquema de transformación angular en torno (eje X' inclinado)" ;
    ns1:ilustradoEn ns1:Parametro_TransformacionEjeInclinado ;
    ns1:textoExtracto "Esquema de torno con representación de transformación angular de eje inclinado: se ven los ejes Z y X cartesianos y el eje X' inclinado; líneas y flechas azules marcan la direccionalidad" .

ns1:Maquina_TornoCinematicaTipo52 a ns1:Maquina ;
    rdfs:label "Máquina-herramienta con cinemática cabezal-mesa tipo 52" ;
    ns1:documentadoEn ns1:Parametro_CinematicaTipo52,
        ns1:Parametro_TDATA38,
        ns1:Parametro_TDATA51,
        ns1:Parametro_TransformacionEjeInclinado ;
    ns1:textoExtracto "PARÁMETROS MÁQUINA · Definición vectorial de cinemáticas cabezal-mesa (tipo 52)" ;
    ns1:tieneComponente ns1:SistemaCoordenadasMaquina,
        ns1:SistemaCoordenadasPieza .

ns1:Sistema_RTCPCompleto a ns1:Sistema ;
    rdfs:label "Sistema RTCP completo (pieza gira con mesa)" ;
    ns1:textoExtracto "Se representan X', Z' y la posición de la herramienta, indicando si el sistema pieza gira con la mesa (RTCP completo)" .

ns1:Sistema_RTCPParcial a ns1:Sistema ;
    rdfs:label "Sistema RTCP parcial (paralelismo con coordenadas máquina)" ;
    ns1:textoExtracto "o mantiene paralelismo con coordenadas máquina" .

ns1:SistemaCoordenadasMaquina a ns1:Sistema ;
    rdfs:label "Sistema de coordenadas máquina (X-Y-Z)" ;
    ns1:textoExtracto "Doble diagrama circular comparando origen RTCP en la mesa: aplicación respecto a cero máquina (C=0°)" .

ns1:SistemaCoordenadasPieza a ns1:Sistema ;
    rdfs:label "Sistema de coordenadas pieza (X'-Y'-Z')" ;
    ns1:identificador "C'=0°" ;
    ns1:textoExtracto "Doble diagrama circular comparando origen RTCP en la mesa: aplicación respecto a cero pieza (C'=0°)" .

ns1:Parametro_CinematicaTipo52 a ns1:Parametro ;
    rdfs:label "Definición vectorial de cinemáticas cabezal-mesa (tipo 52)" ;
    ns1:identificador "tipo 52" ;
    ns1:textoExtracto "Definición vectorial de cinemáticas cabezal-mesa (tipo 52)" .

ns1:Parametro_TDATA38 a ns1:Parametro ;
    rdfs:label "Convención de giro del eje rotativo principal de la mesa (TDATA38)" ;
    ns1:identificador "TDATA38" ;
    ns1:textoExtracto "Ilustraciones de mano con ejes para sentido de giro del eje rotativo principal de la mesa (TDATA38), reforzando la convención de la mano derecha para signos y direcciones." .

ns1:Parametro_TDATA51 a ns1:Parametro ;
    rdfs:label "Modo RTCP (TDATA51)" ;
    ns1:identificador "TDATA51" ;
    ns1:textoExtracto "Esquemas RTCP ON con pieza girada B-30° y comparación TDATA51=0/1." ;
    ns1:valor "0/1" .

ns1:Parametro_TransformacionEjeInclinado a ns1:Parametro ;
    rdfs:label "Transformación angular de eje inclinado en torno" ;
    ns1:textoExtracto "Esquema de torno con representación de transformación angular de eje inclinado: se ven los ejes Z y X cartesianos y el eje X' inclinado; líneas y flechas azules marcan la direccionalidad, mostrando cómo un movimiento programado en X se descompone en componentes sobre Z y X'." .

