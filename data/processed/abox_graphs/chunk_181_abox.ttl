    rdfs:comment "Clase que representa el riel DIN." .

ex:Borne a owl:Class ;
    rdfs:label "Borne"@es ;
    rdfs:comment "Clase que representa los bornes XT1/XT2/XTP1." .

ex:Señal a owl:Class ;
    rdfs:label "Señal"@es ;
    rdfs:comment "Clase que representa las señales cruzadas." .

ex:EntradaDigital a owl:Class ;
    rdfs:label "EntradaDigital"@es ;
    rdfs:comment "Clase que representa las entradas digitales E00–E07." .

ex:FalloClimatizadorArmario a owl:Class ;
    rdfs:label "FalloClimatizadorArmario"@es ;
    rdfs:comment "Clase que representa el fallo del climatizador del armario." .

ex:PuestaEnServicio a owl:Class ;
