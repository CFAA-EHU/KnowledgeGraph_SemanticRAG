@prefix ex: <https://vocab.cfaa.eus/broaching/>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

ex:IOExterno a owl:Class ;
    rdfs:label "IOExterno"@es ;
    rdfs:comment "Clase que representa el I/O de máquina vista." .

ex:PowerModule a owl:Class ;
    rdfs:label "PowerModule"@es ;
    rdfs:comment "Clase que representa el módulo de potencia y alimentación de bus." .

ex:BorneEntradaDigital a owl:Class ;
    rdfs:label "BorneEntradaDigital"@es ;
    rdfs:comment "Clase que representa el borne de entrada digital." .

ex:IL_EC_BK_PAC a owl:Class ;
    rdfs:label "IL_EC_BK_PAC"@es ;
    rdfs:comment "Clase que representa el módulo IL EC BK-PAC." .

ex:DI_8_HD_ECO a owl:Class ;
    rdfs:label "DI_8_HD_ECO"@es ;
    rdfs:comment "Clase que representa el módulo DI 8/HD-ECO." .

ex:DO_8_HD_ECO a owl:Class ;
    rdfs:label "DO_8_HD_ECO"@es ;
    rdfs:comment "Clase que representa el módulo DO 8/HD-ECO." .

ex:PWR_IN a owl:Class ;
    rdfs:label "PWR_IN"@es ;
    rdfs:comment "Clase que representa el módulo PWR IN." .

ex:AI_4_U_PAC a owl:Class ;
    rdfs:label "AI_4_U_PAC"@es ;
    rdfs:comment "Clase que representa el módulo AI 4/U-PAC." .

