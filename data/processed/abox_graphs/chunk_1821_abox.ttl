@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:T a ns1:Parametro ;
    ns1:identificador "T" ;
    ns1:textoExtracto "tras un flanco de subida en TG1, T pasa a 1 y t asciende linealmente hasta la constante de tiempo; al alcanzarla, T retorna a 0 y t se mantiene."@es .

ns1:TEN a ns1:Parametro ;
    ns1:identificador "TEN" ;
    ns1:textoExtracto "con el temporizador ya activo, forzar TEN=0 detiene la rampa de t (línea horizontal) y congela T; al restablecer TEN=1, la temporización continúa hasta completar el tiempo programado."@es .

ns1:TG1 a ns1:ModoOperacion ;
    ns1:identificador "TG1" ;
    ns1:textoExtracto "Diagrama del modo monoestable (TG1): tras un flanco de subida en TG1, T pasa a 1 y t asciende linealmente hasta la constante de tiempo; al alcanzarla, T retorna a 0 y t se mantiene. Se indican flancos adicionales en TG1 sin efecto durante la temporización."@es .

ns1:TG2 a ns1:ModoOperacion ;
    ns1:identificador "TG2" ;
    ns1:textoExtracto "Diagrama del retardo a la conexión: un flanco de subida en TG2 inicia t desde 0 mientras T permanece a 0; al cumplirse la constante de tiempo, T pasa a 1 y se mantiene hasta un flanco de bajada en TG2. Si TG2 baja antes de completar el tiempo, la temporización se cancela y t mantiene el valor alcanzado."@es .

ns1:TGx a ns1:ModoOperacion ;
    ns1:identificador "TGx" ;
    ns1:textoExtracto "Las trazas incluyen TGx, TRS, la evolución de t (repuesta a 0) y el estado T que se fuerza a nivel bajo tras el reset."@es .

ns1:TRS a ns1:ModoOperacion ;
    ns1:identificador "TRS" ;
    ns1:textoExtracto "Las trazas incluyen TGx, TRS, la evolución de t (repuesta a 0) y el estado T que se fuerza a nivel bajo tras el reset."@es .

ns1:t a ns1:Parametro ;
    ns1:identificador "t" ;
    ns1:textoExtracto "tras un flanco de subida en TG1, T pasa a 1 y t asciende linealmente hasta la constante de tiempo; al alcanzarla, T retorna a 0 y t se mantiene."@es .

