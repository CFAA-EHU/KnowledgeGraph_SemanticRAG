@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TG2 a ns1:Alarma ;
    rdfs:label "TG2" ;
    ns1:activaAlarma ns1:TEN ;
    ns1:identificador "TG2" ;
    ns1:textoExtracto "Si TG2 baja antes de completar el tiempo, la temporización se cancela y t mantiene el valor alcanzado." .

ns1:TG3 a ns1:Alarma ;
    rdfs:label "TG3" ;
    ns1:activaAlarma ns1:TRS ;
    ns1:controla ns1:T,
        ns1:t ;
    ns1:identificador "TG3" ;
    ns1:textoExtracto "tras un flanco de subida en TG3, T=1; el retardo comienza con el flanco de bajada de TG3 (t sube desde 0) y, al agotarse el tiempo, T pasa a 0." .

ns1:T a ns1:Parametro ;
    rdfs:label "T" ;
    ns1:identificador "T" ;
    ns1:textoExtracto "T=1; el retardo comienza con el flanco de bajada de TG3 (t sube desde 0) y, al agotarse el tiempo, T pasa a 0." .

ns1:TEN a ns1:Parametro ;
    rdfs:label "TEN" ;
    ns1:identificador "TEN" ;
    ns1:textoExtracto "con el retardo en marcha, poner TEN=0 pausa la rampa de t; al devolver TEN=1, la temporización se reanuda." .

ns1:TRS a ns1:Parametro ;
    rdfs:label "TRS" ;
    ns1:identificador "TRS" ;
    ns1:textoExtracto "un flanco de subida en TRS inicializa el temporizador (T=0, t=0) y exige una nueva activación por TG3 para reiniciar la secuencia." .

ns1:t a ns1:Parametro ;
    rdfs:label "t" ;
    ns1:identificador "t" ;
    ns1:textoExtracto "t sube desde 0 y, al agotarse el tiempo, T pasa a 0." .

