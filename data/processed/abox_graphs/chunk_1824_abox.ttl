ns1:Pagina_373 a ns1:Pagina ;
    ns1:identificador "373" ;
    ns1:textoExtracto "Sección 4.4.5 Instrucciones de acción lógicas (rotaciones)"@es .

ns1:Pagina_381 a ns1:Pagina ;
    ns1:identificador "381" ;
    ns1:textoExtracto "Sección 4.4.8 Movimiento independiente; posicionamiento"@es .

ns1:Grafico_MovimientoPosicionamiento_MOVE_ABS a ns1:Esquema ;
    rdfs:label "Gráfico 'F vs Pos' para bloques MOVE ABS"@es ;
    ns1:ilustradoEn ns1:Pagina_381 ;
    ns1:textoExtracto "ejemplifica tres bloques consecutivos MOVE ABS con distintos parámetros de enlace (PRESENT, NEXT, NULL): el eje horizontal es la posición (marcas en 50 mm, 100 mm, 150 mm) y el vertical el avance F (niveles 125, 250, 500)."@es .

