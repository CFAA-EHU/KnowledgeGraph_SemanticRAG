    ns1:textoExtracto "niveles 250"@es ;
    ns1:valor 250 .

ns1:Parametro_Avance_500 a ns1:Parametro ;
    rdfs:label "Avance F 500"@es ;
    ns1:documentadoEn ns1:Grafico_MovimientoPosicionamiento_MOVE_ABS ;
    ns1:textoExtracto "niveles 500"@es ;
    ns1:valor 500 .

ns1:Parametro_Posicion_100mm a ns1:Parametro ;
    rdfs:label "Posición 100 mm"@es ;
    ns1:documentadoEn ns1:Grafico_MovimientoPosicionamiento_MOVE_ABS ;
    ns1:textoExtracto "marcas en 100 mm"@es ;
    ns1:valor 100 .

ns1:Parametro_Posicion_150mm a ns1:Parametro ;
    rdfs:label "Posición 150 mm"@es ;
    ns1:documentadoEn ns1:Grafico_MovimientoPosicionamiento_MOVE_ABS ;
    ns1:textoExtracto "marcas en 150 mm"@es ;
    ns1:valor 150 .

ns1:Parametro_Posicion_50mm a ns1:Parametro ;
    rdfs:label "Posición 50 mm"@es ;
    ns1:documentadoEn ns1:Grafico_MovimientoPosicionamiento_MOVE_ABS ;
    ns1:textoExtracto "marcas en 50 mm"@es ;
