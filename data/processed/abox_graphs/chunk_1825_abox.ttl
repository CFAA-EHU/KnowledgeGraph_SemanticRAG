@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:DiagramaTemporalNoSincronizado a ns1:Figura ;
    ns1:detalladoEnEsquema ns1:Seccion55VisualizacionDeErroresYMensajesDelPLC ;
    ns1:ilustradoEn ns1:Pagina403 ;
    ns1:textoExtracto "Diagrama temporal con SSTROBE/MSTROBE y la traza 'PLC EXECUTION', incluyendo una cota de duración MINAENDW. Muestra que, en transferencias no sincronizadas (H y M sin sincronización), el CNC mantiene el 'strobe' durante el tiempo mínimo y continúa la ejecución sin esperar confirmación del PLC; la ejecución del PLC puede finalizar más tarde."@es .

ns1:DiagramaTemporalSincronizado a ns1:Figura ;
    ns1:detalladoEnEsquema ns1:Seccion542TransferenciaNoSincronizada ;
    ns1:ilustradoEn ns1:Pagina402 ;
    ns1:textoExtracto "Diagrama temporal con tres señales digitales (SSTROBE, MSTROBE y AUXEND) representadas en forma de trenes de impulsos y numeradas (1–4) para indicar la secuencia de ejecución. Se resalta el parámetro de temporización MINAENDW mediante una cota horizontal. El gráfico ilustra que, al solicitar varias funciones M o S, el CNC activa SSTROBE/MSTROBE y espera una única AUXEND a nivel alto el tiempo mínimo definido antes de concluir la operación."@es .

ns1:Polilinea a ns1:Figura ;
    ns1:detalladoEnEsquema ns1:Seccion541TransferenciaSincronizada ;
    ns1:ilustradoEn ns1:Pagina401 ;
    ns1:textoExtracto "La polilínea muestra cómo se alcanza cada posición con el avance del propio bloque, el del siguiente o avance nulo, evidenciando los cambios de consigna entre tramos."@es .

ns1:Seccion541TransferenciaSincronizada a ns1:Capitulo ;
    ns1:detalladoEnEsquema ns1:Polilinea ;
    ns1:documentadoEn ns1:Pagina401 ;
    ns1:textoExtracto "Sección 5.4.1 Transferencia sincronizada"@es .

