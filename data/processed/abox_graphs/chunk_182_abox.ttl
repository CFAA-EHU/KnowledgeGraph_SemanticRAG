@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:EntradasE10E17 a ex:ComponenteElectrico ;
    rdfs:label "Entradas E10–E17 (módulo 19A3)" ;
    ex:textoExtracto "Entradas E10–E17 (módulo 19A3) para monitorizar alimentaciones internas: CNC, salidas ET200SP, I/O externos (cabecero/salidas), panel operador, safety, entradas."@es .

ex:EntradasE20E27 a ex:ComponenteElectrico ;
    rdfs:label "Entradas E20–E27 (módulo 19A4)" ;
    ex:textoExtracto "Entradas E20–E27 (módulo 19A4) asociadas a disyuntores y protecciones: motores de refrigerante, trasvase, limpieza bastidor, extractor de virutas, grupo hidráulico, protección fuente y enfriador de armario."@es .

ex:EntradasE30E37 a ex:ComponenteElectrico ;
    rdfs:label "Entradas E30–E37 (módulo 19A5)" ;
    ex:textoExtracto "Entradas E30–E37 (módulo 19A5) para estados de motores en marcha (refrigerante, extractor, limpieza, trasvase, hidráulico), feedback frenos IZQ/DCH, modo setup y enable puertas."@es .

ex:Modulo19A3 a ex:ComponenteElectrico ;
    rdfs:label "módulo 19A3" ;
    ex:textoExtracto "módulo 19A3"@es .

ex:Modulo19A4 a ex:ComponenteElectrico ;
    rdfs:label "módulo 19A4" ;
    ex:textoExtracto "módulo 19A4"@es .

ex:Modulo19A5 a ex:ComponenteElectrico ;
    rdfs:label "módulo 19A5" ;
    ex:textoExtracto "módulo 19A5"@es .

ex:EsquemaElectricoBorneEntradaDigital a ex:Esquema ;
    rdfs:label "Esquema eléctrico — Borne de entrada digital" ;
    ex:textoExtracto "Discordancia relés de seguridad, PILZ OK. Las flechas desde 24E/0E y los rótulos en magenta sobre cada ramal clarifican la función de cada canal. --- Páginas: 137 | Sección: Esquemas eléctricos — Borne de entrada digital | Título: Borne de entrada digital ---"@es ;
    ex:tieneComponente ex:EntradasE10E17, ex:EntradasE20E27, ex:EntradasE30E37, ex:Modulo19A3, ex:Modulo19A4, ex:Modulo19A5 .

ex:RelaySeguridadPilz a ex:ComponenteElectrico ;
    rdfs:label "relés de seguridad PILZ" ;
    ex:textoExtracto "Discordancia relés de seguridad, PILZ OK."@es .