@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlmacenAsincronoConBrazoCambiador_a001082e6a a ns1:Sistema ;
    rdfs:label "Almacén asíncrono con brazo cambiador"@es ;
    ns1:compuestoPor ns1:BrazoDoblePinza,
        ns1:CadenaCrawler ;
    ns1:textoExtracto "Ilustración de un almacén asíncrono con brazo cambiador: cadena tipo 'crawler' o almacén lineal alejado del cabezal y un brazo de doble pinza desplazándose de forma independiente." .

ns1:AlmacenSincronoConBrazoCambiador_41819ed9c4 a ns1:Sistema ;
    rdfs:label "Almacén síncrono con brazo cambiador"@es ;
    ns1:compuestoPor ns1:BrazoBasculanteConPinzas,
        ns1:DiscoPortaherramientas ;
    ns1:textoExtracto "Ilustración de un almacén síncrono con brazo cambiador (1–2 pinzas): se aprecia un disco portaherramientas cercano al cabezal y un brazo basculante con pinzas que transfieren la herramienta entre carrusel y husillo." .

ns1:AlmacenSincronoSinBrazoCambiador_9ff2b83903 a ns1:Sistema ;
    rdfs:label "Almacén síncrono sin brazo cambiador"@es ;
    ns1:textoExtracto "Ilustración de un almacén síncrono sin brazo cambiador: carrusel de herramientas dispuesto bajo una boquilla de husillo/cabezal; el carrusel se posiciona frente al husillo para realizar el intercambio directamente, sin intervención de brazo." .

ns1:Husillo a ns1:Componente ;
    rdfs:label "Husillo"@es ;
    ns1:textoExtracto "husillo" .

ns1:SoftwareVersion2_00 a ns1:Parametro ;
    rdfs:label "Versión 2.00 del software"@es ;
    ns1:identificador "V2.00" ;
    ns1:textoExtracto "desde V2.00, las señales sin referencia explícita pasan a referirse al primer canal o almacén" .

ns1:BrazoBasculanteConPinzas a ns1:Actuador ;
    rdfs:label "Brazo basculante con pinzas"@es ;
    ns1:textoExtracto "brazo basculante con pinzas que transfieren la herramienta entre carrusel y husillo" .

ns1:BrazoDoblePinza a ns1:Actuador ;
    rdfs:label "Brazo de doble pinza"@es ;
    ns1:textoExtracto "brazo de doble pinza" .

ns1:CadenaCrawler a ns1:Componente ;
    rdfs:label "Cadena crawler"@es ;
    ns1:textoExtracto "cadena tipo 'crawler' o almacén lineal" .

ns1:DiscoPortaherramientas a ns1:Componente ;
    rdfs:label "Disco portaherramientas"@es ;
    ns1:textoExtracto "disco portaherramientas" .

