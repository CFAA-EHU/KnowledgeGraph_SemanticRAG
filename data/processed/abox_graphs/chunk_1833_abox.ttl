@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlmacenAsincronoTipoCadena a ns1:Sistema ;
    rdfs:label "almacén asíncrono tipo cadena" ;
    ns1:compuestoPor ns1:BrazoCambiador,
        ns1:CintaPortaherramientas ;
    ns1:textoExtracto "Ilustración de almacén asíncrono tipo cadena con brazo cambiador desplazado del cabezal." ;
    ns1:tieneComponente ns1:Cabezal,
        ns1:Husillo .

ns1:MarcaContinuacionTCHANGEOK a ns1:AvisoSeguridad ;
    rdfs:label "marca de continuación (TCHANGEOK)" ;
    ns1:textoExtracto "posibilidad de activar la marca de continuación (TCHANGEOK) tras el intercambio en el husillo" .

ns1:PanelControlWindows a ns1:InterfazUsuario ;
    rdfs:label "Panel de control de Windows" ;
    ns1:textoExtracto "Pareja de capturas del Panel de control de Windows (iconos 'Clock, Language, and Region' y enlace 'Change keyboard or other input methods')" .

ns1:TecladoCNC a ns1:InterfazUsuario ;
    rdfs:label "teclado CNC" ;
    ns1:textoExtracto "Galería comparativa de cuatro teclados CNC según distribución" .

ns1:TecladoEspa_olEspa_a1 a ns1:InterfazUsuario ;
    rdfs:label "teclado Español (España)" ;
    ns1:textoExtracto "tres variantes rotuladas 'Español (España)'" .

ns1:TecladoInglesEstadosUnidos1 a ns1:InterfazUsuario ;
    rdfs:label "teclado Inglés (Estados Unidos)" ;
    ns1:textoExtracto "una 'Inglés (Estados Unidos)'" .

ns1:VentanaTecladosIdiomas a ns1:InterfazUsuario ;
    rdfs:label "ventana Teclados e idiomas" ;
    ns1:textoExtracto "Captura de la ventana 'Teclados e idiomas' con el botón 'Cambiar teclados…'" .

ns1:BrazoCambiador a ns1:ComponenteMecanico ;
    rdfs:label "brazo cambiador" ;
    ns1:textoExtracto "brazo cambiador desplazado del cabezal" .

ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "cabezal" ;
    ns1:textoExtracto "cabezal" .

ns1:CintaPortaherramientas a ns1:Componente ;
    rdfs:label "cinta portaherramientas" ;
    ns1:textoExtracto "cinta portaherramientas serpenteante" .

ns1:Husillo a ns1:ComponenteMecanico ;
    rdfs:label "husillo" ;
    ns1:textoExtracto "husillo" .

