@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:TecladoADistancia a ns1:ComponenteElectrico ;
    ns1:identificador "TecladoADistancia" ;
    ns1:textoExtracto "Simular un teclado desde el PLC. Códigos de teclas. ( 8.1 Seleccionar el idioma y la distribución de teclado)" ;
    ns1:tieneComponente ns1:DistribucionDeTeclado,
        ns1:IdiomaDeEntrada .

ns1:DistribucionDeTeclado a ns1:Frecuencia ;
    ns1:identificador "DistribucionDeTeclado" ;
    ns1:textoExtracto "Distribución del teclado" .

ns1:IdiomaDeEntrada a ns1:Frecuencia ;
    ns1:identificador "IdiomaDeEntrada" ;
    ns1:textoExtracto "Idioma de entrada" .

