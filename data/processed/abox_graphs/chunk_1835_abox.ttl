@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagramaComportamientoEjeRotativo a ns1:Esquema ;
    rdfs:label "Comportamiento de eje rotativo de posicionamiento" ;
    ns1:textoExtracto "Tres diagramas polares comparan el comportamiento de un eje rotativo 'de posicionamiento' (camino más corto), mostrando arcos de 60° y 300° con flechas que indican trayectorias mínima y alternativa; los rótulos B300/–B300 señalan límites de módulo y la cota visible." .

ns1:InterfazOpenPCSRemoto a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de búsqueda OPENPCS Remoto" ;
    ns1:ilustradoEn ns1:EsquemaNomenclaturaEjes ;
    ns1:textoExtracto "Se ven campos de búsqueda, filtros y área de resultados, como referencia visual para acceder a la documentación de variables." .

ns1:SistemaEjeTandem a ns1:Sistema ;
    rdfs:label "Ejemplo de eje tándem con piñones y cremallera" ;
    ns1:compuestoPor ns1:CremalleraEjeTandem,
        ns1:MotorEsclavoEjeTandem,
        ns1:MotorMaestroEjeTandem ;
    ns1:textoExtracto "Ejemplo de un eje tándem compuesto por dos piñones y una cremallera. Ilustración de arquitectura gantry con dos motores (maestro y esclavo) engranados sobre la misma cremallera." .

ns1:CremalleraEjeTandem a ns1:ComponenteMecanico ;
    rdfs:label "Cremallera del eje tándem" ;
    ns1:textoExtracto "Ejemplo de un eje tándem compuesto por dos piñones y una cremallera." .

ns1:EsquemaNomenclaturaEjes a ns1:Esquema ;
    rdfs:label "Norma DIN 66217 para nomenclatura de ejes" ;
    ns1:detalladoEnEsquema ns1:VisualizacionCotasEjesRotativos ;
    ns1:identificador "DIN 66217" ;
    ns1:textoExtracto "Ilustración conceptual de la norma DIN 66217 para nomenclatura de ejes: dibujos con triedro XYZ y flechas que indican ejes principales (X, Y, Z), auxiliares paralelos (U, V, W) y rotativos (A, B, C) alrededor de X, Y, Z respectivamente. La gráfica sitúa los ejes respecto al plano de trabajo y el eje perpendicular, ayudando a identificar la función de cada eje en la máquina." .

ns1:MotorEsclavoEjeTandem a ns1:ComponenteMecanico ;
    rdfs:label "Motor esclavo del eje tándem" ;
    ns1:textoExtracto "Ilustración de arquitectura gantry con dos motores (maestro y esclavo) engranados sobre la misma cremallera." .

ns1:MotorMaestroEjeTandem a ns1:ComponenteMecanico ;
    rdfs:label "Motor maestro del eje tándem" ;
    ns1:textoExtracto "Ilustración de arquitectura gantry con dos motores (maestro y esclavo) engranados sobre la misma cremallera." .

ns1:VisualizacionCotasEjesRotativos a ns1:Esquema ;
    rdfs:label "Visualización de cotas en ejes rotativos (modo módulo)" ;
    ns1:textoExtracto "Conjunto de tres esquemas circulares que representan la visualización de cotas en ejes rotativos en modo 'módulo', con marcas de ±300° y flechas de sentido de giro. Se ilustran límites superior e inferior del módulo y cómo se mapea la posición angular alrededor de 0°, destacando sectores sombreados y anotaciones de 30° para indicar direccionalidad y rango visible." .

