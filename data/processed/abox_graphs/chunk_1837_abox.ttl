@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaMultieje_584 a ns1:Sistema ;
    rdfs:label "Grupo multieje con dos motores independientes"@es ;
    ns1:compuestoPor ns1:MotorEje1_584,
        ns1:MotorEje2_584,
        ns1:ReguladorMultieje_584 ;
    ns1:ilustradoEn ns1:EsquemaMultieje_584 ;
    ns1:textoExtracto "Grupo multieje compuesto por dos ejes, cada uno controlado por un motor. Esquema con dos motores y dos husillos independientes conectados a un mismo módulo de regulador."@es .

ns1:SistemaTandem_577 a ns1:Sistema ;
    rdfs:label "Sistema de control tándem con CNC y dos ejes (MASTER DRIVE/SLAVE DRIVE)"@es ;
    ns1:compuestoPor ns1:MotorEsclavo_577,
        ns1:MotorMaestro_577,
        ns1:ReguladorTandem_577 ;
    ns1:ilustradoEn ns1:EsquemaTandem_577 ;
    ns1:textoExtracto "Diagrama de bloques del sistema con CNC, regulador y dos ejes (MASTER DRIVE y SLAVE DRIVE). Se detallan lazos de posición y velocidad, señales de consigna y realimentación, y el bloque 'Tandem control' que aplica precarga y distribución de par."@es ;
    ns1:tieneComponente ns1:BloqueTandemControl_577,
        ns1:LazoPosicion_577,
        ns1:LazoVelocidad_577 .

ns1:BloqueTandemControl_577 a ns1:ComponenteElectrico ;
    rdfs:label "Bloque 'Tandem control'"@es ;
    ns1:controla ns1:ParametroPar_578,
        ns1:ParametroPrecarga_578 ;
    ns1:textoExtracto "bloque 'Tandem control' que aplica precarga y distribución de par."@es .

ns1:EsquemaMultieje_584 a ns1:Esquema ;
    rdfs:label "Esquema de gestión multieje (pág. 584)"@es ;
    ns1:textoExtracto "Esquema con dos motores y dos husillos independientes conectados a un mismo módulo de regulador."@es .

ns1:EsquemaTandem_577 a ns1:Esquema ;
    rdfs:label "Diagrama de bloques del sistema tándem (pág. 577)"@es ;
    ns1:textoExtracto "Diagrama de bloques del sistema con CNC, regulador y dos ejes (MASTER DRIVE y SLAVE DRIVE)."@es .

ns1:LazoPosicion_577 a ns1:ComponenteElectrico ;
    rdfs:label "Lazo de posición del sistema tándem"@es ;
    ns1:monitoreaParametro ns1:ParametroPosicion_577 ;
    ns1:textoExtracto "lazos de posición y velocidad, señales de consigna y realimentación."@es .

ns1:LazoVelocidad_577 a ns1:ComponenteElectrico ;
    rdfs:label "Lazo de velocidad del sistema tándem"@es ;
    ns1:monitoreaParametro ns1:ParametroVelocidad_577 ;
    ns1:textoExtracto "lazos de posición y velocidad, señales de consigna y realimentación."@es .

ns1:ReguladorMultieje_584 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo regulador multieje"@es ;
    ns1:controla ns1:MotorEje1_584,
        ns1:MotorEje2_584 ;
    ns1:textoExtracto "conectados a un mismo módulo de regulador."@es .

ns1:ReguladorTandem_577 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador del sistema tándem"@es ;
    ns1:controla ns1:MotorEsclavo_577,
        ns1:MotorMaestro_577 ;
    ns1:monitoreaParametro ns1:ParametroPar_578,
        ns1:ParametroPrecarga_578 ;
    ns1:textoExtracto "regulador y dos ejes (MASTER DRIVE y SLAVE DRIVE)."@es .

ns1:MotorEje1_584 a ns1:ComponenteMecanico ;
    rdfs:label "Motor del Eje 1"@es ;
    ns1:textoExtracto "dos motores y dos husillos independientes."@es .

ns1:MotorEje2_584 a ns1:ComponenteMecanico ;
    rdfs:label "Motor del Eje 2"@es ;
    ns1:textoExtracto "dos motores y dos husillos independientes."@es .

ns1:MotorEsclavo_577 a ns1:ComponenteMecanico ;
    rdfs:label "SLAVE DRIVE"@es ;
    ns1:controla ns1:ParametroVelocidad_577 ;
    ns1:identificador "SLAVE DRIVE" ;
    ns1:textoExtracto "dos ejes (MASTER DRIVE y SLAVE DRIVE)."@es .

ns1:MotorMaestro_577 a ns1:ComponenteMecanico ;
    rdfs:label "MASTER DRIVE"@es ;
    ns1:controla ns1:ParametroPosicion_577,
        ns1:ParametroVelocidad_577 ;
    ns1:identificador "MASTER DRIVE" ;
    ns1:textoExtracto "dos ejes (MASTER DRIVE y SLAVE DRIVE)."@es .

ns1:ParametroPar_578 a ns1:Parametro ;
    rdfs:label "Distribución de par"@es ;
    ns1:textoExtracto "distribución de par."@es .

ns1:ParametroPosicion_577 a ns1:Parametro ;
    rdfs:label "Posición del eje maestro"@es ;
    ns1:textoExtracto "el lazo se cierra únicamente con la posición del eje maestro."@es .

ns1:ParametroPrecarga_578 a ns1:Parametro ;
    rdfs:label "Precarga (preload)"@es ;
    ns1:textoExtracto "bloque 'Tandem control' que aplica precarga y distribución de par."@es ;
    ns1:valor "Preload" .

ns1:ParametroVelocidad_577 a ns1:Parametro ;
    rdfs:label "Velocidad (maestro/esclavo)"@es ;
    ns1:textoExtracto "'Velocity command' hacia maestro y esclavo."@es .

