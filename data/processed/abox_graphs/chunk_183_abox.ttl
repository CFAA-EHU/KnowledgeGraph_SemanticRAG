@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix elec: <https://vocab.cfaa.eus/broaching/electricos/> .
@prefix mecanica: <https://vocab.cfaa.eus/broaching/mecanica/> .

### Clases ###
elec:ContactoIntermedio a owl:Class ;
    rdfs:label "ContactoIntermedio" ;
    rdfs:comment "Clase para representar contactos intermedios en esquemas eléctricos." .

elec:Bobina a owl:Class ;
    rdfs:label "Bobina" ;
    rdfs:comment "Clase para representar bobinas en esquemas eléctricos." .

elec:EntradaDigital a owl:Class ;
    rdfs:label "EntradaDigital" ;
    rdfs:comment "Clase para representar entradas digitales en esquemas eléctricos." .

elec:Sensor a owl:Class ;
    rdfs:label "Sensor" ;
    rdfs:comment "Clase para representar sensores en esquemas eléctricos." .

elec:Conector a owl:Class ;
    rdfs:label "Conector" ;
    rdfs:comment "Clase para representar conectores en esquemas eléctricos." .

elec:SalidaDigital a owl:Class ;
    rdfs:label "SalidaDigital" ;
    rdfs:comment "Clase para representar salidas digitales en esquemas eléctricos." .

elec:Piloto a owl:Class ;
    rdfs:label "Piloto" ;
    rdfs:comment "Clase para representar pilotos en esquemas eléctricos." .

elec:Lampara a owl:Class ;
    rdfs:label "Lampara" ;
    rdfs:comment "Clase para representar lámparas en esquemas eléctricos." .

### Propiedades de Objeto ###
elec:enlaza a owl:ObjectProperty ;
    rdfs:label "enlaza" ;
    rdfs:comment "Propiedad que indica que un componente enlaza la lógica con otro." ;
    rdfs:domain elec:ContactoIntermedio ;
    rdfs:range elec:Bobina .

elec:representa a owl:ObjectProperty ;
    rdfs:label "representa" ;
    rdfs:comment "Propiedad que indica que un símbolo representa un sensor." ;
    rdfs:domain elec:Sensor ;
    rdfs:range elec:Sensor .

elec:tieneConector a owl:ObjectProperty ;
    rdfs:label "tieneConector" ;
    rdfs:comment "Propiedad que indica que un componente tiene un conector." ;
    rdfs:domain elec:Sensor ;
    rdfs:range elec:Conector .

elec:tieneLongitudCable a owl:ObjectProperty ;
    rdfs:label "tieneLongitudCable" ;
    rdfs:comment "Propiedad que indica la longitud del cable de un componente." ;
    rdfs:domain elec:Sensor ;
    rdfs:range xsd:string .

elec:tieneSalidaDigital a owl:ObjectProperty ;
    rdfs:label "tieneSalidaDigital" ;
    rdfs:comment "Propiedad que indica que un módulo tiene una salida digital." ;
    rdfs:domain elec:Modulo ;
    rdfs:range elec:SalidaDigital .

elec:tienePiloto a owl:ObjectProperty ;
    rdfs:label "tienePiloto" ;
    rdfs:comment "Propiedad que indica que un bloque tiene un piloto." ;
    rdfs:domain elec:Bloque ;
    rdfs:range elec:Piloto .

elec:tieneLampara a owl:ObjectProperty ;
    rdfs:label "tieneLampara" ;
    rdfs:comment "Propiedad que indica que un piloto tiene una lámpara." ;
    rdfs:domain elec:Piloto ;
    rdfs:range elec:Lampara .

### Propiedades de Datos ###
elec:tieneCodigo a owl:DatatypeProperty ;
    rdfs:label "tieneCodigo" ;
    rdfs:comment "Propiedad que indica el código de un componente." ;
    rdfs:domain elec:ContactoIntermedio ;
    rdfs:range xsd:string .

elec:tieneModulo a owl:DatatypeProperty ;
    rdfs:label "tieneModulo" ;
    rdfs:comment "Propiedad que indica el módulo de una entrada digital." ;
    rdfs:domain elec:EntradaDigital ;
    rdfs:range xsd:string .

elec:tieneReferencia a owl:DatatypeProperty ;
    rdfs:label "tieneReferencia" ;
    rdfs:comment "Propiedad que indica la referencia de una entrada digital." ;
    rdfs:domain elec:EntradaDigital ;
    rdfs:range xsd:string .

elec:tieneEtiqueta a owl:DatatypeProperty ;
    rdfs:label "tieneEtiqueta" ;
    rdfs:comment "Propiedad que indica la etiqueta de una entrada digital." ;
    rdfs:domain elec:EntradaDigital ;
    rdfs:range xsd:string .

elec:tieneColor a owl:DatatypeProperty ;
    rdfs:label "tieneColor" ;
    rdfs:comment "Propiedad que indica el color de una lámpara." ;
    rdfs:domain elec:Lampara ;
    rdfs:range xsd:string .