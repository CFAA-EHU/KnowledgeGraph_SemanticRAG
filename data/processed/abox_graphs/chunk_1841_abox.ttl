@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_INCREAX1 a ns1:Parametro ;
    rdfs:label "INCREAX1" ;
    ns1:documentadoEn ns1:Esquema_SecuenciaCompensacionVolumetrica ;
    ns1:textoExtracto "incrementos entre puntos (INCREAX1/2/3)"@es .

ns1:Parametro_INCREAX2 a ns1:Parametro ;
    rdfs:label "INCREAX2" ;
    ns1:documentadoEn ns1:Esquema_SecuenciaCompensacionVolumetrica ;
    ns1:textoExtracto "incrementos entre puntos (INCREAX1/2/3)"@es .

ns1:Parametro_INCREAX3 a ns1:Parametro ;
    rdfs:label "INCREAX3" ;
    ns1:documentadoEn ns1:Esquema_SecuenciaCompensacionVolumetrica ;
    ns1:textoExtracto "incrementos entre puntos (INCREAX1/2/3)"@es .

ns1:Parametro_INIPOSAX1 a ns1:Parametro ;
    rdfs:label "INIPOSAX1" ;
    ns1:documentadoEn ns1:Esquema_SecuenciaCompensacionVolumetrica ;
    ns1:textoExtracto "posición inicial sobre cada eje (INIPOSAX1/2/3)"@es .

ns1:Parametro_INIPOSAX2 a ns1:Parametro ;
    rdfs:label "INIPOSAX2" ;
    ns1:documentadoEn ns1:Esquema_SecuenciaCompensacionVolumetrica ;
    ns1:textoExtracto "posición inicial sobre cada eje (INIPOSAX1/2/3)"@es .

ns1:Parametro_INIPOSAX3 a ns1:Parametro ;
    rdfs:label "INIPOSAX3" ;
    ns1:documentadoEn ns1:Esquema_SecuenciaCompensacionVolumetrica ;
    ns1:textoExtracto "posición inicial sobre cada eje (INIPOSAX1/2/3)"@es .

ns1:Parametro_NPOINTSAX1 a ns1:Parametro ;
    rdfs:label "NPOINTSAX1" ;
    ns1:documentadoEn ns1:Esquema_SecuenciaCompensacionVolumetrica ;
    ns1:textoExtracto "distribución NPOINTSAX1×NPOINTSAX2×NPOINTSAX3"@es .

ns1:Parametro_NPOINTSAX2 a ns1:Parametro ;
    rdfs:label "NPOINTSAX2" ;
    ns1:documentadoEn ns1:Esquema_SecuenciaCompensacionVolumetrica ;
    ns1:textoExtracto "distribución NPOINTSAX1×NPOINTSAX2×NPOINTSAX3"@es .

ns1:Parametro_NPOINTSAX3 a ns1:Parametro ;
    rdfs:label "NPOINTSAX3" ;
    ns1:documentadoEn ns1:Esquema_SecuenciaCompensacionVolumetrica ;
    ns1:textoExtracto "distribución NPOINTSAX1×NPOINTSAX2×NPOINTSAX3"@es .

ns1:Tabla_CompensacionVolumetrica_Basica a ns1:Tabla ;
    rdfs:label "Tabla de compensación volumétrica básica"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_SecuenciaCompensacionVolumetrica ;
    ns1:identificador "12.1.3" ;
    ns1:textoExtracto "filas de valores decimales separadas por comas, que corresponden a los errores medidos en cada punto de la malla volumétrica. La imagen ejemplifica el formato de archivo exigido para cargar la tabla de compensación en el CNC."@es .

ns1:Esquema_SecuenciaCompensacionVolumetrica a ns1:Esquema ;
    rdfs:label "Esquema de secuencia para compensación volumétrica"@es ;
    ns1:identificador "12.1.4" ;
    ns1:textoExtracto "Diagrama 3D de una malla de puntos dentro de un triedro X-Y-Z con números (1…12) que indican el orden de recorrido de las mediciones. Se muestra la posición inicial sobre cada eje (INIPOSAX1/2/3), incrementos entre puntos (INCREAX1/2/3) y la distribución NPOINTSAX1×NPOINTSAX2×NPOINTSAX3, con flechas que marcan la secuencia de avance primero en X, luego en Y y finalmente en Z."@es .

