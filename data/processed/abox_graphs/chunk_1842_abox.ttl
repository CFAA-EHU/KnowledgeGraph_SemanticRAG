@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_NPOINTSAX1 a ns1:Parametro ;
    rdfs:label "NPOINTSAX1" ;
    ns1:ilustradoEn ns1:Esquema_Paso3_CompensacionVolumetrica ;
    ns1:textoExtracto "Se resaltan los contadores NPOINTSAX1 y NPOINTSAX2"@es .

ns1:Parametro_NPOINTSAX2 a ns1:Parametro ;
    rdfs:label "NPOINTSAX2" ;
    ns1:ilustradoEn ns1:Esquema_Paso3_CompensacionVolumetrica ;
    ns1:textoExtracto "Se resaltan los contadores NPOINTSAX1 y NPOINTSAX2"@es .

ns1:Parametro_Z_P2 a ns1:Parametro ;
    rdfs:label "Z(P2)" ;
    ns1:ilustradoEn ns1:Esquema_Paso4_CompensacionVolumetrica ;
    ns1:textoExtracto "Flechas y etiquetas Z(P2) señalan el cambio de cota y la replicación del patrón del primer plano."@es .

ns1:Parametro_Z_Pn a ns1:Parametro ;
    rdfs:label "Z(Pn)" ;
    ns1:ilustradoEn ns1:Esquema_Paso6_CompensacionVolumetrica ;
    ns1:textoExtracto "Esquema 3D (Paso 6) del volumen totalmente relleno hasta Z(Pn)."@es .

ns1:Sistema_CompensacionVolumetrica a ns1:Sistema ;
    rdfs:label "Sistema de compensación volumétrica"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_Paso3_CompensacionVolumetrica,
        ns1:Esquema_Paso4_CompensacionVolumetrica,
        ns1:Esquema_Paso5_CompensacionVolumetrica,
        ns1:Esquema_Paso6_CompensacionVolumetrica ;
    ns1:textoExtracto "Sección: 12. Compensación volumétrica — 12.1.4 Secuencia para definir los valores en el archivo"@es .

ns1:Esquema_Paso5_CompensacionVolumetrica a ns1:Esquema ;
    rdfs:label "Esquema 3D (Paso 5) - Planos intermedios Z"@es ;
    ns1:identificador "Paso 5" ;
    ns1:textoExtracto "Esquema 3D (Paso 5) mostrando varios planos intermedios Z con la malla de puntos y las rutas de avance. La representación enfatiza la construcción volumétrica por capas, manteniendo los incrementos definidos para cada eje."@es .

ns1:Esquema_Paso4_CompensacionVolumetrica a ns1:Esquema ;
    rdfs:label "Esquema 3D (Paso 4) - Segundo nivel Z(P2)"@es ;
    ns1:identificador "Paso 4" ;
    ns1:textoExtracto "Esquema 3D (Paso 4) que inicia el segundo nivel Z(P2): desde X(P1), Y(P1), Z(P2) se repite el barrido en X e Y. Flechas y etiquetas Z(P2) señalan el cambio de cota y la replicación del patrón del primer plano."@es .

ns1:Esquema_Paso6_CompensacionVolumetrica a ns1:Esquema ;
    rdfs:label "Esquema 3D (Paso 6) - Volumen relleno hasta Z(Pn)"@es ;
    ns1:identificador "Paso 6" ;
    ns1:textoExtracto "Esquema 3D (Paso 6) del volumen totalmente relleno hasta Z(Pn). Se observan todas las capas Z apiladas, el patrón de serpenteo por planos y la malla completa que sustenta la interpolación de errores dentro del volumen."@es .

ns1:Esquema_Paso3_CompensacionVolumetrica a ns1:Esquema ;
    rdfs:label "Esquema 3D (Paso 3) del plano XY"@es ;
    ns1:identificador "Paso 3" ;
    ns1:textoExtracto "Esquema 3D (Paso 3) del plano XY con el patrón de relleno completo en X para cada fila Y(Pn). Se resaltan los contadores NPOINTSAX1 y NPOINTSAX2 y cómo se genera la lista ordenada de puntos antes de subir de cota Z."@es .

