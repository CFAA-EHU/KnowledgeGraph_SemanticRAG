@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Dispositivo_CNC_BusCAN a ns1:InterfazUsuario ;
    rdfs:label "CNC (Address=0)" ;
    ns1:detalladoEnEsquema ns1:EsquemaBusCAN ;
    ns1:textoExtracto "iconos del CNC (Address=0)"@es .

ns1:Dispositivo_ESRemota_1 a ns1:InterfazUsuario ;
    rdfs:label "Módulo E/S Remota (Address=1)" ;
    ns1:detalladoEnEsquema ns1:EsquemaBusCAN ;
    ns1:textoExtracto "módulos de E/S remotas (Address=1,3,4)"@es .

ns1:Dispositivo_ESRemota_2 a ns1:InterfazUsuario ;
    rdfs:label "Módulo E/S Remota (Address=3)" ;
    ns1:detalladoEnEsquema ns1:EsquemaBusCAN ;
    ns1:textoExtracto "módulos de E/S remotas (Address=1,3,4)"@es .

ns1:Dispositivo_ESRemota_3 a ns1:InterfazUsuario ;
    rdfs:label "Módulo E/S Remota (Address=4)" ;
    ns1:detalladoEnEsquema ns1:EsquemaBusCAN ;
    ns1:textoExtracto "módulos de E/S remotas (Address=1,3,4)"@es .

ns1:Dispositivo_JogPanel_1 a ns1:InterfazUsuario ;
    rdfs:label "Jog-Panel (Address=2)" ;
    ns1:detalladoEnEsquema ns1:EsquemaBusCAN ;
    ns1:textoExtracto "dos 'Jog-Panel' (Address=2 y 5)"@es .

ns1:Dispositivo_JogPanel_2 a ns1:InterfazUsuario ;
    rdfs:label "Jog-Panel (Address=5)" ;
    ns1:detalladoEnEsquema ns1:EsquemaBusCAN ;
    ns1:textoExtracto "dos 'Jog-Panel' (Address=2 y 5)"@es .

ns1:Componente_COMP a ns1:ComponenteElectrico ;
    rdfs:label "Sumador/Compensador (COMP)" ;
    ns1:detalladoEnEsquema ns1:DiagramaLazoControlCNC ;
    ns1:textoExtracto "Incluye sumadores/compensadores (COMP, DELTA)"@es .

ns1:Componente_DELTA a ns1:ComponenteElectrico ;
    rdfs:label "Sumador/Compensador (DELTA)" ;
    ns1:detalladoEnEsquema ns1:DiagramaLazoControlCNC ;
    ns1:textoExtracto "Incluye sumadores/compensadores (COMP, DELTA)"@es .

ns1:Componente_FILTER a ns1:ComponenteElectrico ;
    rdfs:label "FILTER" ;
    ns1:detalladoEnEsquema ns1:DiagramaLazoControlCNC ;
    ns1:textoExtracto "lazo de control del CNC que encadena SLOPE, INTERPOLATOR, TRANSFOR y FILTER"@es .

ns1:Componente_INTERPOLATOR a ns1:ComponenteElectrico ;
    rdfs:label "INTERPOLATOR" ;
    ns1:detalladoEnEsquema ns1:DiagramaLazoControlCNC ;
    ns1:textoExtracto "lazo de control del CNC que encadena SLOPE, INTERPOLATOR, TRANSFOR y FILTER"@es .

ns1:Componente_SLOPE a ns1:ComponenteElectrico ;
    rdfs:label "SLOPE" ;
    ns1:detalladoEnEsquema ns1:DiagramaLazoControlCNC ;
    ns1:textoExtracto "lazo de control del CNC que encadena SLOPE, INTERPOLATOR, TRANSFOR y FILTER"@es .

ns1:Componente_TRANSFOR a ns1:ComponenteElectrico ;
    rdfs:label "TRANSFOR" ;
    ns1:detalladoEnEsquema ns1:DiagramaLazoControlCNC ;
    ns1:textoExtracto "lazo de control del CNC que encadena SLOPE, INTERPOLATOR, TRANSFOR y FILTER"@es .

ns1:Parametro_FTEO a ns1:Parametro ;
    rdfs:label "Consigna FTEO" ;
    ns1:detalladoEnEsquema ns1:DiagramaLazoControlCNC ;
    ns1:textoExtracto "consignas (POSCMD, FTEO)"@es .

ns1:Parametro_MINAENDW a ns1:Parametro ;
    rdfs:label "Ventana temporal MINAENDW" ;
    ns1:detalladoEnEsquema ns1:DiagramaResetCNC ;
    ns1:textoExtracto "ventana MINAENDW marcada sobre RESETOUT"@es .

ns1:Parametro_POSCMD a ns1:Parametro ;
    rdfs:label "Consigna POSCMD" ;
    ns1:detalladoEnEsquema ns1:DiagramaLazoControlCNC ;
    ns1:textoExtracto "consignas (POSCMD, FTEO)"@es .

ns1:Parametro_POSNC a ns1:Parametro ;
    rdfs:label "Retroalimentación POSNC" ;
    ns1:detalladoEnEsquema ns1:DiagramaLazoControlCNC ;
    ns1:textoExtracto "señales de retroalimentación (POSNC)"@es .

ns1:Parametro_VALOOPTPOS a ns1:Parametro ;
    rdfs:label "Variable V.A.LOOPTPOS.xn" ;
    ns1:detalladoEnEsquema ns1:DiagramaLazoControlCNC ;
    ns1:textoExtracto "etiquetas de variables (p. ej., V.A.LOOPTPOS.xn)"@es .

ns1:Parametro_VGPATHFEED a ns1:Parametro ;
    rdfs:label "Variable V.G.PATHFEED" ;
    ns1:detalladoEnEsquema ns1:DiagramaLazoControlCNC ;
    ns1:textoExtracto "etiquetas de variables (p. ej., V.G.PATHFEED)"@es .

ns1:Senal_RESETIN a ns1:Sensor ;
    rdfs:label "Señal RESETIN" ;
    ns1:detalladoEnEsquema ns1:DiagramaResetCNC ;
    ns1:textoExtracto "trazas digitales (RESETIN y RESETOUT)"@es .

ns1:Senal_RESETOUT a ns1:Sensor ;
    rdfs:label "Señal RESETOUT" ;
    ns1:detalladoEnEsquema ns1:DiagramaResetCNC ;
    ns1:textoExtracto "trazas digitales (RESETIN y RESETOUT)"@es .

ns1:Subrutina_PROGRAM_RESET a ns1:ModoOperacion ;
    rdfs:label "Subrutina PROGRAM_RESET" ;
    ns1:detalladoEnEsquema ns1:DiagramaResetCNC ;
    ns1:textoExtracto "tras lo cual se ejecuta la subrutina PROGRAM_RESET"@es .

ns1:DiagramaResetCNC a ns1:Esquema ;
    rdfs:label "Diagrama temporal del proceso de reset"@es ;
    ns1:identificador "15.1_ResetTemporal" ;
    ns1:monitoreaParametro ns1:Parametro_MINAENDW,
        ns1:Senal_RESETIN,
        ns1:Senal_RESETOUT ;
    ns1:solucionaFallo ns1:Subrutina_PROGRAM_RESET ;
    ns1:textoExtracto "Diagrama temporal del proceso de reset con dos trazas digitales (RESETIN y RESETOUT) y la ventana MINAENDW marcada sobre RESETOUT. La línea de tiempo (t) indica cuatro hitos numerados: activación de RESETIN, tiempo para asumir condiciones iniciales, activación de RESETOUT y final de reset, tras lo cual se ejecuta la subrutina PROGRAM_RESET."@es .

ns1:EsquemaBusCAN a ns1:Esquema ;
    rdfs:label "Diagrama del bus CAN"@es ;
    ns1:identificador "15.1_BusCAN" ;
    ns1:textoExtracto "Diagrama del bus CAN que ilustra la numeración y orden de los paneles de mando y grupos de E/S remotas. Se muestran iconos del CNC (Address=0), módulos de E/S remotas (Address=1,3,4) y dos 'Jog-Panel' (Address=2 y 5)."@es .

ns1:DiagramaLazoControlCNC a ns1:Esquema ;
    rdfs:label "Diagrama de bloques del lazo de control del CNC"@es ;
    ns1:identificador "14.3_ControlCNC" ;
    ns1:monitoreaParametro ns1:Parametro_FTEO,
        ns1:Parametro_POSCMD,
        ns1:Parametro_POSNC,
        ns1:Parametro_VALOOPTPOS,
        ns1:Parametro_VGPATHFEED ;
    ns1:textoExtracto "Diagrama de bloques del lazo de control del CNC que encadena SLOPE, INTERPOLATOR, TRANSFOR y FILTER, seguido de la entrada al lazo de posición. Incluye sumadores/compensadores (COMP, DELTA), consignas (POSCMD, FTEO), señales de retroalimentación (POSNC), y rutas para salidas analógicas y buses (Sercos Vel./Pos.)."@es ;
    ns1:tieneComponente ns1:Componente_COMP,
        ns1:Componente_DELTA,
        ns1:Componente_FILTER,
        ns1:Componente_INTERPOLATOR,
        ns1:Componente_SLOPE,
        ns1:Componente_TRANSFOR .

