    ns1:textoExtracto "dos contadoras RCS-S (nodos 3 y 5)"@es .

ns1:Sistema_Sercos_RCS_AXD a ns1:Sistema ;
    rdfs:label "Sistema Sercos con contadoras RCS-S y reguladores AXD"@es ;
    ns1:textoExtracto "sistema Sercos con dos contadoras RCS-S (nodos 3 y 5) y tres reguladores AXD (nodos 1, 2 y 4)"@es ;
    ns1:tieneComponente ns1:Cabezal_S,
        ns1:Conector_ANAOUT2,
        ns1:Conector_E21A,
        ns1:Conector_E21B,
        ns1:Conector_E21C,
        ns1:EjeAnalogico_X,
        ns1:EjeAnalogico_Y,
        ns1:EjeAnalogico_Z,
        ns1:EjeSercos_U,
        ns1:EjeSercos_V,
        ns1:Nodo_AXD_1,
        ns1:Nodo_AXD_2,
        ns1:Nodo_AXD_4,
        ns1:Nodo_RCS_S_3,
        ns1:Nodo_RCS_S_5,
        ns1:Volante_Control .

ns1:Volante_Control a ns1:ComponenteMecanico ;
    rdfs:label "Volante de control"@es ;
    ns1:textoExtracto "un volante"@es .

