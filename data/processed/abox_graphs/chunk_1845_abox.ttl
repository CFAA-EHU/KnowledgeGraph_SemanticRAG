@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Esquema_Interconexion_Sercos_RCS_AXD a ns1:Esquema ;
    rdfs:label "Esquema de interconexión Sercos con nodos RCS-S y AXD"@es ;
    ns1:detalladoEnEsquema ns1:Sistema_Sercos_RCS_AXD ;
    ns1:textoExtracto "Esquema de interconexión del sistema Sercos con dos contadoras RCS-S (nodos 3 y 5) y tres reguladores AXD (nodos 1, 2 y 4). Se muestran bloques para ejes analógicos (X, Y, Z), ejes Sercos (U, V), un volante y un cabezal S, con líneas que conectan salidas analógicas (ANAOUT) y entradas de captación (E21A/B/C)."@es .

ns1:Esquema_RIO5_Grupo1 a ns1:Esquema ;
    rdfs:label "Esquema del Grupo 1 RIO5 (24ED/16SD)"@es ;
    ns1:detalladoEnEsquema ns1:Modulo_RIO5_Grupo1 ;
    ns1:textoExtracto "Imagen 'Grupo 1': conjunto RIO5 con 24 entradas digitales y 16 salidas digitales. Se muestran bastidores con conectores X1–X8 y leyendas de borneado (+24 V, GND), enfatizando el formato de módulo y su rol como bloque lógico único."@es .

ns1:Cabezal_S a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal S"@es ;
    ns1:textoExtracto "un cabezal S"@es .

ns1:Conector_ANAOUT2 a ns1:ComponenteElectrico ;
    rdfs:label "Conector de salida analógica ANAOUT2"@es ;
    ns1:identificador "ANAOUT2" ;
    ns1:textoExtracto "salidas analógicas (ANAOUT)"@es .

ns1:Conector_E21A a ns1:ComponenteElectrico ;
    rdfs:label "Conector de entrada de captación E21A"@es ;
    ns1:identificador "E21A" ;
    ns1:textoExtracto "entradas de captación (E21A/B/C)"@es .

