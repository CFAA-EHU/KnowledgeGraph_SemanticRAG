    ns1:textoExtracto "ejes Sercos (U, V)"@es .

ns1:Modulo_RIO5_Grupo1 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RIO5 Grupo 1 (24ED/16SD)"@es ;
    ns1:textoExtracto "conjunto RIO5 con 24 entradas digitales y 16 salidas digitales"@es ;
    ns1:tieneComponente ns1:Conector_RIO5_X1,
        ns1:Conector_RIO5_X2,
        ns1:Conector_RIO5_X3,
        ns1:Conector_RIO5_X4,
        ns1:Conector_RIO5_X5,
        ns1:Conector_RIO5_X6,
        ns1:Conector_RIO5_X7,
        ns1:Conector_RIO5_X8 .

