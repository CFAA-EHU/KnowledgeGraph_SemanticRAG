    rdfs:label "Contadora RCS-S (nodo 3)"@es ;
    ns1:identificador "3" ;
    ns1:textoExtracto "dos contadoras RCS-S (nodos 3 y 5)"@es .

ns1:Nodo_RCS_S_5 a ns1:ComponenteElectrico ;
    rdfs:label "Contadora RCS-S (nodo 5)"@es ;
