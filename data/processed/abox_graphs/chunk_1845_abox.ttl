ns1:EjeAnalogico_X a ns1:ComponenteMecanico ;
    rdfs:label "Eje analógico X"@es ;
    ns1:textoExtracto "bloques para ejes analógicos (X, Y, Z)"@es .

ns1:EjeAnalogico_Y a ns1:ComponenteMecanico ;
    rdfs:label "Eje analógico Y"@es ;
    ns1:textoExtracto "bloques para ejes analógicos (X, Y, Z)"@es .

