@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:A00_A07 a ns1:ComponenteElectrico ;
    rdfs:label "salidas A00–A07" ;
    ns1:identificador "A00–A07" ;
    ns1:textoExtracto "Salidas A00–A07 (módulo 19A21) que accionan contactores KA00–KA04 (motores de refrigeración brocha, limpieza, trasvase, extractor, grupo hidráulico) y una línea 'Activación freno desde PLC a PILZ'." .

ns1:A30_A37 a ns1:ComponenteElectrico ;
    rdfs:label "salidas A30–A37" ;
    ns1:identificador "A30–A37" ;
    ns1:textoExtracto "Salidas A30–A37 (módulo 19A9) para marcha ciclo, enable puertas, apertura puerta, puesta en servicio, reset fuente drives, emergencia CNC." .

ns1:HL33 a ns1:ComponenteElectrico ;
    rdfs:label "piloto HL33" ;
    ns1:identificador "HL33" ;
    ns1:textoExtracto "Se incluyen pilotos HL33/HL34 y contactos intermedios (26SBL1, 34SBL2), con retorno a 0S por línea verde." .

