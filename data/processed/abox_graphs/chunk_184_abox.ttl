@prefix ex: <https://vocab.cfaa.eus/broaching/>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.

ex:Piloto a owl:Class ;
    rdfs:label "Piloto" ;
    rdfs:comment "Clase que representa un piloto en el sistema eléctrico.".

ex:BorneDeSalidaDigital a owl:Class ;
    rdfs:label "BorneDeSalidaDigital" ;
    rdfs:comment "Clase que representa un borne de salida digital en el sistema eléctrico.".

ex:Módulo a owl:Class ;
    rdfs:label "Módulo" ;
    rdfs:comment "Clase que representa un módulo en el sistema eléctrico.".

ex:ContactoIntermedio a owl:Class ;
    rdfs:label "ContactoIntermedio" ;
    rdfs:comment "Clase que representa un contacto intermedio en el sistema eléctrico.".

ex:Relé a owl:Class ;
    rdfs:label "Relé" ;
    rdfs:comment "Clase que representa un relé en el sistema eléctrico.".

ex:Contactor a owl:Class ;
    rdfs:label "Contactor" ;
    rdfs:comment "Clase que representa un contactor en el sistema eléctrico.".

ex:BloqueDeEntradasDiferenciales a owl:Class ;
    rdfs:label "BloqueDeEntradasDiferenciales" ;
    rdfs:comment "Clase que representa un bloque de entradas diferenciales en el sistema eléctrico.".

ex:PowerModule a owl:Class ;
    rdfs:label "PowerModule" ;
    rdfs:comment "Clase que representa un módulo de alimentación de riel en el sistema eléctrico.".

ex:tieneCodificaciónCromática a owl:ObjectProperty ;
    rdfs:label "tieneCodificaciónCromática" ;
    rdfs:comment "Propiedad que indica la codificación cromática de un elemento.".

ex:tieneRótulo a owl:ObjectProperty ;
    rdfs:label "tieneRótulo" ;
    rdfs:comment "Propiedad que indica el rótulo de un elemento.".

ex:tieneSalidas a owl:ObjectProperty ;
    rdfs:label "tieneSalidas" ;
    rdfs:comment "Propiedad que indica las salidas de un módulo.".

ex:tieneContactosIntermedios a owl:ObjectProperty ;
    rdfs:label "tieneContactosIntermedios" ;
    rdfs:comment "Propiedad que indica los contactos intermedios de un elemento.".

ex:tieneRelés a owl:ObjectProperty ;
    rdfs:label "tieneRelés" ;
    rdfs:comment "Propiedad que indica los relés de un módulo.".

ex:tieneBornes a owl:ObjectProperty ;
