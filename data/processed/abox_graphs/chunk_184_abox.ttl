    ns1:compuestoPor ns1:HL23,
        ns1:HL25 ;
    ns1:identificador "bloque" ;
    ns1:textoExtracto "Los pilotos HL23–HL25 se agrupan en un bloque; la codificación cromática está indicada por el rótulo de cada lámpara." .

