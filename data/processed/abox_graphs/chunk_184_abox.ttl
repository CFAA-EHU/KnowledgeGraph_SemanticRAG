@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix elec: <https://vocab.cfaa.eus/broaching/electric/> .
@prefix mecanica: <https://vocab.cfaa.eus/broaching/mecanica/> .

### Clases ###
elec:Piloto a owl:Class ;
    rdfs:label "Piloto" ;
    rdfs:comment "Componente eléctrico de señalización" .

elec:BorneSalidaDigital a owl:Class ;
    rdfs:label "Borne de salida digital" ;
    rdfs:comment "Punto de conexión para salidas digitales" .

elec:ModuloAlimentacion a owl:Class ;
    rdfs:label "Módulo de alimentación" ;
    rdfs:comment "Módulo que proporciona alimentación eléctrica" .

elec:Relé a owl:Class ;
    rdfs:label "Relé" ;
    rdfs:comment "Dispositivo electromecánico para conmutar circuitos" .

elec:ContactoIntermedio a owl:Class ;
    rdfs:label "Contacto intermedio" ;
    rdfs:comment "Contacto auxiliar en relés o contactores" .

elec:Contacto a owl:Class ;
    rdfs:label "Contacto" ;
    rdfs:comment "Punto de conexión en un relé o contactor" .

elec:Bobina a owl:Class ;
    rdfs:label "Bobina" ;
    rdfs:comment "Componente que activa un relé o contactor" .

elec:Contacto a owl:Class ;
    rdfs:label "Contacto" ;
    rdfs:comment "Punto de conexión en un relé o contactor" .

elec:BloqueEntradasDiferenciales a owl:Class ;
    rdfs:label "Bloque de entradas diferenciales" ;
    rdfs:comment "Bloque que gestiona entradas diferenciales" .

### Propiedades de Objeto ###
elec:agrupaEn a owl:ObjectProperty ;
    rdfs:label "agrupa en" ;
    rdfs:comment "Relación que indica que un componente se agrupa en otro" .

elec:acciona a owl:ObjectProperty ;
    rdfs:label "acciona" ;
    rdfs:comment "Relación que indica que un componente acciona otro" .

elec:seMuestraAlimentadoDesde a owl:ObjectProperty ;
    rdfs:label "se muestra alimentado desde" ;
    rdfs:comment "Relación que indica la fuente de alimentación de un componente" .

elec:tieneConexion a owl:ObjectProperty ;
    rdfs:label "tiene conexión" ;
    rdfs:comment "Relación que indica la conexión de un componente" .

elec:tienePolaridad a owl:ObjectProperty ;
    rdfs:label "tiene polaridad" ;
    rdfs:comment "Relación que indica la polaridad de un componente" .

elec:tieneReferencia a owl:ObjectProperty ;
    rdfs:label "tiene referencia" ;
    rdfs:comment "Relación que indica la referencia de un componente" .

elec:tieneAsignacion a owl:ObjectProperty ;
    rdfs:label "tiene asignación" ;
    rdfs:comment "Relación que indica la asignación de un componente" .

### Propiedades de Datos ###
elec:tieneCodificacionCromatica a owl:DatatypeProperty ;
    rdfs:label "tiene codificación cromática" ;
    rdfs:comment "Indica la codificación cromática de un componente" ;
    rdfs:range xsd:string .

elec:tieneRótulo a owl:DatatypeProperty ;
    rdfs:label "tiene rótulo" ;
    rdfs:comment "Indica el rótulo de un componente" ;
    rdfs:range xsd:string .

elec:tieneSalidas a owl:DatatypeProperty ;
    rdfs:label "tiene salidas" ;
    rdfs:comment "Indica las salidas de un módulo" ;
    rdfs:range xsd:string .

elec:tieneBornes a owl:DatatypeProperty ;
    rdfs:label "tiene bornes" ;
    rdfs:comment "Indica los bornes de un módulo" ;
    rdfs:range xsd:string .

elec:tieneRelés a owl:DatatypeProperty ;
    rdfs:label "tiene relés" ;
    rdfs:comment "Indica los relés de un módulo" ;
    rdfs:range xsd:string .

elec:tieneContactos a owl:DatatypeProperty ;
    rdfs:label "tiene contactos" ;
    rdfs:comment "Indica los contactos de un módulo" ;
    rdfs:range xsd:string .

elec:tieneBobinas a owl:DatatypeProperty ;
    rdfs:label "tiene bobinas" ;
    rdfs:comment "Indica las bobinas de un módulo" ;
    rdfs:range xsd:string .

elec:tieneCanales a owl:DatatypeProperty ;
    rdfs:label "tiene canales" ;
    rdfs:comment "Indica los canales de un módulo" ;
    rdfs:range xsd:string .

elec:tienePolaridadIndicada a owl:DatatypeProperty ;
    rdfs:label "tiene polaridad indicada" ;
    rdfs:comment "Indica la polaridad de un canal" ;
    rdfs:range xsd:string .