@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalAngular_TYPE6 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal angular YZ 45° (TYPE=6)"@es ;
    ns1:controla ns1:Parametro_GAP,
        ns1:Parametro_GAPCOMP_Z ;
    ns1:detalladoEnEsquema ns1:Esquema_CabezalAngular_TYPE6,
        ns1:Esquema_DimensionesTDATA ;
    ns1:identificador "TYPE=6" ;
    ns1:textoExtracto "Cabezal angular YZ de 45° (TYPE=6) con cinemática parametrizable mediante TDATA."@es ;
    ns1:tieneComponente ns1:Palpador .

ns1:Diagrama_PrimeraPalpacion a ns1:Figura ;
    rdfs:label "Diagrama 'Primera palpación'"@es ;
    ns1:textoExtracto "Diagrama 'Primera palpación': B=0°, C=0°, contacto sobre cara Z y preselección Z=0; flechas indican sentido de palpación y referencias OT y ejes Y-Z."@es .

ns1:Esquema_DimensionesTDATA a ns1:Esquema ;
    rdfs:label "Esquema de dimensiones TDATA (1,2,3,5,6,7)"@es ;
    ns1:identificador "TDATA" ;
    ns1:textoExtracto "Esquema de dimensiones TDATA (1,2,3,5,6,7) sobre ejes X-Y-Z y rotaciones B/C, con signos positivos indicados. Muestra relaciones espaciales entre nariz de husillo, ejes rotativos y eje de herramienta para parametrizar la cinemática TYPE=6."@es .

ns1:Palpador a ns1:Sensor ;
    rdfs:label "Palpador de medición"@es ;
    ns1:ilustradoEn ns1:Esquema_CabezalAngular_TYPE6 ;
    ns1:monitoreaParametro ns1:Parametro_RadioBolaPalpador,
        ns1:Parametro_TDATA1 ;
    ns1:textoExtracto "Medición con palpador y la necesidad de conocer radio y longitud de la bola del palpador."@es .

ns1:Parametro_GAP a ns1:Parametro ;
    rdfs:label "Parámetro G.GAP"@es ;
    ns1:identificador "G.GAP" ;
    ns1:textoExtracto "Trazas de ejemplo para 'Pieza con una irregularidad en el perfil': se muestran G.GAP, A.POS.Z, A.POS.X y A.GAPCOMP.Z."@es .

ns1:Parametro_GAPCOMP_Z a ns1:Parametro ;
    rdfs:label "Parámetro A.GAPCOMP.Z"@es ;
    ns1:identificador "A.GAPCOMP.Z" ;
    ns1:textoExtracto "La compensación del eje del sensor se ve como correcciones sincronizadas ante cambios abruptos de perfil (A.GAPCOMP.Z)."@es .

ns1:Parametro_RadioBolaPalpador a ns1:Parametro ;
    rdfs:label "Radio de la bola del palpador"@es ;
    ns1:textoExtracto "Necesidad de conocer radio y longitud de la bola del palpador."@es .

ns1:Parametro_TDATA1 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA1"@es ;
    ns1:documentadoEn ns1:Diagrama_PrimeraPalpacion ;
    ns1:identificador "TDATA1" ;
    ns1:textoExtracto "Cálculo del parámetro TDATA1 mediante palpación en B=0°, C=0°."@es .

ns1:Esquema_CabezalAngular_TYPE6 a ns1:Esquema ;
    rdfs:label "Esquema de cabezal angular YZ 45° (TYPE=6)"@es ;
    ns1:identificador "TYPE=6" ;
    ns1:textoExtracto "Ilustración del cabezal angular YZ de 45° (TYPE=6) con iconografía de ejes y geometría; introduce el contexto de medición con palpador y la necesidad de conocer radio y longitud de la bola del palpador."@es .

