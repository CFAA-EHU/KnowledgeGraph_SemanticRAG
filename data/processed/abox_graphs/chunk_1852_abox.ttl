@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteMecanico_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de palpación"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_SegundaPalpacion_TDATA1,
        ns1:Esquema_SegundaPalpacion_TDATA5 ;
    ns1:textoExtracto "cambio de orientación del cabezal respecto al centro de giro ②"@es .

ns1:Esquema_Combinado_TDATA1 a ns1:Esquema ;
    rdfs:label "Esquema combinado para cálculo de TDATA1"@es ;
    ns1:ilustradoEn ns1:Parametro_TDATA1 ;
    ns1:textoExtracto "Esquema combinado con variables TDATA1, ΔZ, L y R, y anotación de la solución TDATA1 = |ΔZ| − R − L; se incluye vista de referencias y vectores de medición."@es .

ns1:Esquema_PrimeraPalpacion_TDATA5 a ns1:Esquema ;
    rdfs:label "Diagrama 'Primera palpación' para TDATA5"@es ;
    ns1:ilustradoEn ns1:Parametro_TDATA5 ;
    ns1:textoExtracto "Diagrama 'Primera palpación': B=0°, C=0°, contacto sobre cara X próxima al origen y preselección X=0; se señalan ejes X-Z y posición ①."@es .

ns1:Esquema_PrimeraPalpacion_TDATA6 a ns1:Esquema ;
    rdfs:label "Diagrama 'Primera palpación' para TDATA6"@es ;
    ns1:ilustradoEn ns1:Parametro_TDATA6 ;
    ns1:textoExtracto "Diagrama 'Primera palpación': B=0°, C=0°, medición del ancho D entre dos caras X con corrección 2R (bola); se indica X = D + 2R."@es .

ns1:Herramienta_EjeHerramienta a ns1:Herramienta ;
    rdfs:label "Eje herramienta"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_Solucion_TDATA5 ;
    ns1:textoExtracto "desfase geométrico del eje herramienta"@es .

ns1:Esquema_SegundaPalpacion_TDATA1 a ns1:Esquema ;
    rdfs:label "Diagrama 'Segunda palpación' para TDATA1"@es ;
    ns1:ilustradoEn ns1:Parametro_TDATA1 ;
    ns1:textoExtracto "Diagrama 'Segunda palpación': B=0°, C=180°, repetición sobre misma cara con lectura ΔZ; se remarca el cambio de orientación del cabezal respecto al centro de giro ②."@es .

ns1:Esquema_SegundaPalpacion_TDATA5 a ns1:Esquema ;
    rdfs:label "Diagrama 'Segunda palpación' para TDATA5"@es ;
    ns1:ilustradoEn ns1:Parametro_TDATA5 ;
    ns1:textoExtracto "Diagrama 'Segunda palpación': B=0°, C=180°, contacto sobre misma cara con lectura ΔX, resaltando el giro alrededor de 2 y el desplazamiento resultante."@es .

ns1:Esquema_Solucion_TDATA5 a ns1:Esquema ;
    rdfs:label "Esquema de solución para TDATA5"@es ;
    ns1:ilustradoEn ns1:Parametro_TDATA5 ;
    ns1:textoExtracto "Esquema de solución con marcadores de B/C y anotación TDATA5 = 0,5·|ΔX|; la figura asocia gráficamente la variación de lectura con el desfase geométrico del eje herramienta."@es .

ns1:Parametro_TDATA6 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA6"@es ;
    ns1:identificador "TDATA6" ;
    ns1:textoExtracto "X = D + 2R (medición del ancho D entre dos caras X con corrección 2R)"@es .

ns1:Parametro_TDATA1 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA1"@es ;
    ns1:identificador "TDATA1" ;
    ns1:textoExtracto "TDATA1 = |ΔZ| − R − L"@es .

ns1:Parametro_TDATA5 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA5"@es ;
    ns1:identificador "TDATA5" ;
    ns1:textoExtracto "TDATA5 = 0,5·|ΔX|"@es .

