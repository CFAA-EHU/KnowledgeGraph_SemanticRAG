@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:AvisoSeguridad_ColocacionIncorrectaPalpador a ns1:AvisoSeguridad ;
    rdfs:label "Errores de colocación del reloj comparador"@es ;
    ns1:documentadoEn ns1:Esquema_17_2_CabezalAngular_TYPE6 ;
    ns1:mitigaRiesgo ns1:Herramienta_RelojComparador ;
    ns1:textoExtracto "Dos esquemas con marcas de error (cruz) que ejemplifican colocaciones incorrectas del reloj comparador sobre el cilindro, indicando direccionalidad y geometría de contacto que producen errores al asignar el radio."@es .

ns1:Parametro_DeltaZ a ns1:Parametro ;
    ns1:documentadoEn ns1:Esquema_17_1_SolucionDobleVista ;
    ns1:identificador "ΔZ" ;
    ns1:textoExtracto "anotaciones [...] ΔZ"@es .

ns1:Componente_CabezalAngular_TYPE6 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal angular YZ 45°"@es ;
    ns1:identificador "TYPE=6" ;
    ns1:monitoreaParametro ns1:Parametro_TDATA1,
        ns1:Parametro_TDATA2,
        ns1:Parametro_TDATA3,
        ns1:Parametro_TDATA5,
        ns1:Parametro_TDATA6,
        ns1:Parametro_TDATA7 ;
    ns1:textoExtracto "Cabezal angular TYPE=6 (YZ 45°)"@es ;
    ns1:tieneComponente ns1:Componente_CilindroPatron,
        ns1:Sensor_Palpador .

ns1:Componente_CilindroPatron a ns1:ComponenteMecanico ;
    rdfs:label "Cilindro patrón"@es ;
    ns1:ilustradoEn ns1:Esquema_17_2_CabezalAngular_TYPE6 ;
    ns1:textoExtracto "cilindro patrón montado en el cabezal"@es .

ns1:Herramienta_RelojComparador a ns1:Herramienta ;
    rdfs:label "Reloj comparador"@es ;
    ns1:ilustradoEn ns1:Esquema_17_2_CabezalAngular_TYPE6 ;
    ns1:textoExtracto "uso correcto del reloj comparador sobre un cilindro: palpado tangencial [...] con el palpador lo más perpendicular posible a la tangente."@es .

ns1:Pagina_711 a ns1:Pagina ;
    ns1:identificador "711" ;
    ns1:textoExtracto "Sección: 17.1 Cálculo del parámetro TDATA2."@es .

ns1:Pagina_712 a ns1:Pagina ;
    ns1:identificador "712" ;
    ns1:textoExtracto "Sección: 17.2 Cabezal angular. Cálculo de las dimensiones con ayuda de un reloj comparador."@es .

ns1:Parametro_TDATA1 a ns1:Parametro ;
    ns1:documentadoEn ns1:Esquema_17_2_CabezalAngular_TYPE6 ;
    ns1:identificador "TDATA1" ;
    ns1:textoExtracto "parámetros TDATA (1, 2, 3, 5, 6, 7)"@es .

ns1:Parametro_TDATA2 a ns1:Parametro ;
    ns1:documentadoEn ns1:Esquema_17_1_SolucionDobleVista ;
    ns1:identificador "TDATA2" ;
    ns1:textoExtracto "relación TDATA2 = 0,5·|ΔZ| − |TDATA5|"@es ;
    ns1:valor "0.5·|ΔZ| − |TDATA5|"^^xsd:string .

ns1:Parametro_TDATA3 a ns1:Parametro ;
    ns1:documentadoEn ns1:Esquema_17_2_CabezalAngular_TYPE6 ;
    ns1:identificador "TDATA3" ;
    ns1:textoExtracto "parámetros TDATA (1, 2, 3, 5, 6, 7)"@es .

ns1:Parametro_TDATA5 a ns1:Parametro ;
    ns1:documentadoEn ns1:Esquema_17_1_SolucionDobleVista ;
    ns1:identificador "TDATA5" ;
    ns1:textoExtracto "anotaciones TDATA5"@es .

ns1:Parametro_TDATA6 a ns1:Parametro ;
    ns1:documentadoEn ns1:Esquema_17_2_CabezalAngular_TYPE6 ;
    ns1:identificador "TDATA6" ;
    ns1:textoExtracto "parámetros TDATA (1, 2, 3, 5, 6, 7)"@es .

ns1:Parametro_TDATA7 a ns1:Parametro ;
    ns1:documentadoEn ns1:Esquema_17_2_CabezalAngular_TYPE6 ;
    ns1:identificador "TDATA7" ;
    ns1:textoExtracto "parámetros TDATA (1, 2, 3, 5, 6, 7)"@es .

ns1:Sensor_Palpador a ns1:Sensor ;
    rdfs:label "Palpador de reloj comparador"@es ;
    ns1:ilustradoEn ns1:Esquema_17_2_CabezalAngular_TYPE6 ;
    ns1:textoExtracto "palpado tangencial en la línea exterior del cilindro con el palpador lo más perpendicular posible a la tangente."@es .

ns1:Esquema_17_1_SolucionDobleVista a ns1:Esquema ;
    rdfs:label "Esquema de solución con doble vista B=±90°"@es ;
    ns1:identificador "17.1" ;
    ns1:ilustradoEn ns1:Pagina_711 ;
    ns1:textoExtracto "Esquema de solución con doble vista B=±90° y anotaciones TDATA5 y ΔZ, junto a la relación TDATA2 = 0,5·|ΔZ| − |TDATA5|; se visualizan vectores y signos de las cotas para el cálculo final."@es .

ns1:Esquema_17_2_CabezalAngular_TYPE6 a ns1:Esquema ;
    rdfs:label "Cabezal angular TYPE=6 (YZ 45°)"@es ;
    ns1:detalladoEnEsquema ns1:Componente_CabezalAngular_TYPE6 ;
    ns1:identificador "17.2 (TYPE=6)" ;
    ns1:ilustradoEn ns1:Pagina_712 ;
    ns1:textoExtracto "Esquema del cabezal angular TYPE=6 (YZ 45°) con representación de ejes X-Y-Z y sentidos positivos de parámetros TDATA (1, 2, 3, 5, 6, 7)."@es .

