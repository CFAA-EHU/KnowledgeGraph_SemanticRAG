@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalAngular a ns1:Maquina ;
    rdfs:label "Cabezal angular" ;
    ns1:textoExtracto "Método gráfico para localizar la 'línea más exterior' del cilindro: desplazamiento del reloj sobre la circunferencia hasta detectar cambio de giro de la aguja y retorno al valor inicial, señalando que el punto exterior está a mitad del recorrido del eje." .

ns1:EsquemaPrimerContactoTDATA5 a ns1:Esquema ;
    rdfs:label "Esquema 'Primer contacto' para TDATA5" ;
    ns1:ilustradoEn ns1:Pagina714 ;
    ns1:textoExtracto "Esquema 'Primer contacto' para TDATA5 con B=0°, C=0°, palpado en eje X (punto 1) y preselección X=0. Se presenta la geometría de referencia X-Z y el punto de lectura." .

ns1:EsquemaSegundoContactoTDATA1 a ns1:Esquema ;
    rdfs:label "Esquema 'Segundo contacto' para TDATA1" ;
    ns1:ilustradoEn ns1:Pagina713 ;
    ns1:textoExtracto "Diagrama 'Segundo contacto' para TDATA1 con C=180°, palpado en punto 2 y lectura de ΔY. Se destaca la relación TDATA1 = |ΔY| mediante flechas y cotas asociadas al eje Y." .

ns1:EsquemaSegundoContactoTDATA5 a ns1:Esquema ;
    rdfs:label "Esquema 'Segundo contacto' para TDATA5" ;
    ns1:ilustradoEn ns1:Pagina714 ;
    ns1:textoExtracto "Esquema 'Segundo contacto' para TDATA5 con C=180°, palpado en punto 2 y lectura de ΔX." .

ns1:RelojComparador a ns1:Herramienta ;
    rdfs:label "reloj comparador" ;
    ns1:detalladoEnEsquema ns1:EsquemaPrimerContactoTDATA1 ;
    ns1:textoExtracto "desplazamiento del reloj sobre la circunferencia hasta detectar cambio de giro de la aguja y retorno al valor inicial, señalando que el punto exterior está a mitad del recorrido del eje." .

ns1:EsquemaPrimerContactoTDATA1 a ns1:Esquema ;
    rdfs:label "Esquema 'Primer contacto' para TDATA1" ;
    ns1:ilustradoEn ns1:Pagina713 ;
    ns1:textoExtracto "Diagrama 'Primer contacto' para TDATA1 con B=0°, C=0° y palpado en eje Y sobre cilindro (punto 1), mostrando preselección Y=R para centrar el eje del cilindro. Incluye iconografía de reloj y vectores de movimiento." .

