@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:PanelOperadorVistaExterior a ex:InterfazUsuario ;
    ex:textoExtracto "Canales reservados (etiqueta RESERVA) con polaridad indicada y referencias a bornes XT1; se representa la asignación +U/–U por canal." ;
    ex:tieneComponente ex:BornesXT1 .

ex:BornesXT1 a ex:ComponenteElectrico ;
    ex:textoExtracto "referencias a bornes XT1" .

ex:AlzadoHMI a ex:InterfazUsuario ;
    ex:textoExtracto "Alzado del HMI con cotas (558×350 mm, separación de 79 mm entre elementos) y rotulado de teclas: Puesta en servicio, Paro servicio, Marcha ciclo, Setup, Enable puertas, Apertura puertas. A la derecha, vista del selector 51XS1; flechas y recuadros asocian cada pulsador con su señal (p. ej., 26SBL1, 34SBL2, SA36, SBL37)." ;
    ex:tieneComponente ex:Selector51XS1, ex:TeclaPuestaEnServicio, ex:TeclaParoServicio, ex:TeclaMarchaCiclo, ex:TeclaSetup, ex:TeclaEnablePuertas, ex:TeclaAperturaPuertas .

ex:Selector51XS1 a ex:ComponenteElectrico ;
    ex:identificador "51XS1" ;
    ex:textoExtracto "vistas del selector 51XS1" .

ex:TeclaPuestaEnServicio a ex:ComponenteElectrico ;
    ex:textoExtracto "rotulado de teclas: Puesta en servicio" .

ex:TeclaParoServicio a ex:ComponenteElectrico ;
    ex:textoExtracto "rotulado de teclas: Paro servicio" .

ex:TeclaMarchaCiclo a ex:ComponenteElectrico ;
    ex:textoExtracto "rotulado de teclas: Marcha ciclo" .

ex:TeclaSetup a ex:ComponenteElectrico ;
    ex:textoExtracto "rotulado de teclas: Setup" .

ex:TeclaEnablePuertas a ex:ComponenteElectrico ;
    ex:textoExtracto "rotulado de teclas: Enable puertas" .

ex:TeclaAperturaPuertas a ex:ComponenteElectrico ;
    ex:textoExtracto "rotulado de teclas: Apertura puertas" .

ex:ExternalIO_AXL_EC_DI16_M12_6P_60U1 a ex:Sistema ;
    ex:identificador "AXL E EC DI16 M12 6P (60U1)" ;
    ex:textoExtracto "Lámina de asignación de conectores M12 del módulo 60U1. En el centro se dibuja el dispositivo con pines X01–X08 y, a ambos lados, columnas con Us/GND/FE/IN1…IN16 y referencias cruzadas (62.xx/63.xx/61.xx). Se indican BUS IN/OUT y correspondencias de UA/US para cada conector." ;
    ex:compuestoPor ex:ConectorM12_60U1_X01, ex:ConectorM12_60U1_X02, ex:ConectorM12_60U1_X03, ex:ConectorM12_60U1_X04, ex:ConectorM12_60U1_X05, ex:ConectorM12_60U1_X06, ex:ConectorM12_60U1_X07, ex:ConectorM12_60U1_X08 ;
    ex:tieneComponente ex:Latiguillo61WAL1 .

