@prefix ex: <https://vocab.cfaa.eus/broaching/>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.

ex:PanelOperador a owl:Class ;
    rdfs:label "Panel Operador" ;
    rdfs:comment "Panel Operador Vista Exterior" .

ex:Teclado a owl:Class ;
    rdfs:label "Teclado" .

ex:Pulsador a owl:Class ;
    rdfs:label "Pulsador" .

ex:Selector a owl:Class ;
    rdfs:label "Selector" .

ex:Conector a owl:Class ;
    rdfs:label "Conector" .

ex:Módulo a owl:Class ;
    rdfs:label "Módulo" .

ex:Latiguillo a owl:Class ;
    rdfs:label "Latiguillo" .

ex:Bloque a owl:Class ;
    rdfs:label "Bloque" .

ex:tienePulsador a owl:ObjectProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range ex:Pulsador .

ex:tieneSelector a owl:ObjectProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range ex:Selector .

ex:tieneConector a owl:ObjectProperty ;
    rdfs:domain ex:Módulo ;
    rdfs:range ex:Conector .

ex:tieneLatiguillo a owl:ObjectProperty ;
    rdfs:domain ex:Módulo ;
    rdfs:range ex:Latiguillo .

ex:tieneBloque a owl:ObjectProperty ;
    rdfs:domain ex:Módulo ;
    rdfs:range ex:Bloque .

ex:tieneAlimentacion a owl:ObjectProperty ;
    rdfs:domain ex:Módulo ;
    rdfs:range ex:Bloque .

ex:tieneComunicaciones a owl:ObjectProperty ;
    rdfs:domain ex:Módulo ;
    rdfs:range ex:Bloque .

ex:tieneEntradas a owl:ObjectProperty ;
    rdfs:domain ex:Módulo ;
    rdfs:range ex:Bloque .

ex:tieneBusIn a owl:ObjectProperty ;
    rdfs:domain ex:Módulo ;
    rdfs:range ex:Bloque .

ex:tieneBusOut a owl:ObjectProperty ;
    rdfs:domain ex:Módulo ;
    rdfs:range ex:Bloque .

ex:tieneReferenciasCruzadas a owl:ObjectProperty ;
    rdfs:domain ex:Módulo ;
    rdfs:range ex:Conector .

ex:tienePines a owl:ObjectProperty ;
    rdfs:domain ex:Módulo ;
    rdfs:range ex:Conector .

ex:tieneCotas a owl:ObjectProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range ex:Teclado .

ex:tieneRotulado a owl:ObjectProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range ex:Teclado .

ex:tieneSeñal a owl:ObjectProperty ;
    rdfs:domain ex:Pulsador ;
    rdfs:range ex:Selector .

ex:tieneFlechas a owl:ObjectProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range ex:Pulsador .

ex:tieneRecuadros a owl:ObjectProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range ex:Pulsador .

ex:tieneAsignacion a owl:ObjectProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range ex:Pulsador .

ex:tieneReferencia a owl:ObjectProperty ;
    rdfs:domain ex:Pulsador ;
    rdfs:range ex:Selector .

ex:tieneDispositivo a owl:ObjectProperty ;
    rdfs:domain ex:Módulo ;
    rdfs:range ex:Conector .

ex:tieneColumnas a owl:ObjectProperty ;
    rdfs:domain ex:Módulo ;
    rdfs:range ex:Conector .

ex:tieneCorrespondencias a owl:ObjectProperty ;
    rdfs:domain ex:Módulo ;
    rdfs:range ex:Conector .

ex:tieneBloques a owl:ObjectProperty ;
    rdfs:domain ex:Módulo ;
    rdfs:range ex:Bloque .

ex:tieneEntradas24VAN a owl:ObjectProperty ;
    rdfs:domain ex:Módulo ;
    rdfs:range ex:Bloque .

ex:tieneEntradas0VAN a owl:ObjectProperty ;
    rdfs:domain ex:Módulo ;
    rdfs:range ex:Bloque .

ex:tieneEntradas24EBC a owl:ObjectProperty ;
    rdfs:domain ex:Módulo ;
    rdfs:range ex:Bloque .

ex:tieneEntradas0EBC a owl:ObjectProperty ;
    rdfs:domain ex:Módulo ;
    rdfs:range ex:Bloque .

ex:tieneBUSIN a owl:ObjectProperty ;
    rdfs:domain ex:Módulo ;
    rdfs:range ex:Bloque .

ex:tieneBUSOUT a owl:ObjectProperty ;
    rdfs:domain ex:Módulo ;
    rdfs:range ex:Bloque .

ex:tieneLatiguillo75m a owl:ObjectProperty ;
    rdfs:domain ex:Módulo ;
    rdfs:range ex:Latiguillo .

ex:tieneReferencias a owl:ObjectProperty ;
    rdfs:domain ex:Módulo ;
    rdfs:range ex:Bloque .

ex:tieneUS a owl:ObjectProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range ex:Bloque .

ex:tieneUA a owl:ObjectProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range ex:Bloque .

ex:tieneGND a owl:ObjectProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range ex:Bloque .