@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix mecanica: <https://vocab.cfaa.eus/broaching/mecanica/> .
@prefix elec: <https://vocab.cfaa.eus/broaching/elec/> .
@prefix base: <https://vocab.cfaa.eus/broaching/base/> .

# Clases
ex:PanelOperador a owl:Class ;
    rdfs:label "Panel Operador" ;
    rdfs:comment "Panel de operación y control de la máquina" .

ex:Selector a owl:Class ;
    rdfs:label "Selector" ;
    rdfs:comment "Dispositivo de selección en el panel operador" .

ex:Pulsador a owl:Class ;
    rdfs:label "Pulsador" ;
    rdfs:comment "Botón de control en el panel operador" .

ex:DispositivoEntradaSalida a owl:Class ;
    rdfs:label "Dispositivo de Entrada/Salida" ;
    rdfs:comment "Módulo de entrada/salida en el sistema eléctrico" .

ex:Conector a owl:Class ;
    rdfs:label "Conector" ;
    rdfs:comment "Conector M12 en el módulo de entrada/salida" .

ex:Bloque a owl:Class ;
    rdfs:label "Bloque" ;
    rdfs:comment "Bloque de alimentación y comunicaciones" .

# Propiedades de objeto
mecanica:tieneElementoDeMando a owl:ObjectProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range ex:Pulsador .

mecanica:tieneSelector a owl:ObjectProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range ex:Selector .

mecanica:tieneDispositivoEntradaSalida a owl:ObjectProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range ex:DispositivoEntradaSalida .

elec:tieneConector a owl:ObjectProperty ;
    rdfs:domain ex:DispositivoEntradaSalida ;
    rdfs:range ex:Conector .

elec:tieneBloque a owl:ObjectProperty ;
    rdfs:domain ex:DispositivoEntradaSalida ;
    rdfs:range ex:Bloque .

# Propiedades de datos
base:tieneCotas a owl:DatatypeProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range xsd:string .

base:tienePolaridad a owl:DatatypeProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range xsd:string .

base:tieneReferencia a owl:DatatypeProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range xsd:string .

base:tieneDimensiones a owl:DatatypeProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range xsd:string .

base:tieneSeparacion a owl:DatatypeProperty ;
    rdfs:domain ex:PanelOperador ;
    rdfs:range xsd:string .

base:tieneRotulo a owl:DatatypeProperty ;
    rdfs:domain ex:Pulsador ;
    rdfs:range xsd:string .

base:tienePin a owl:DatatypeProperty ;
    rdfs:domain ex:Conector ;
    rdfs:range xsd:string .

base:tieneReferenciaCruzada a owl:DatatypeProperty ;
    rdfs:domain ex:Conector ;
    rdfs:range xsd:string .

base:tieneAlimentacion a owl:DatatypeProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range xsd:string .

base:tieneComunicaciones a owl:DatatypeProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range xsd:string .