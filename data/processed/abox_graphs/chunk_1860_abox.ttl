@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ControlOverride a ns1:Alarma ;
    rdfs:label "Control del override" ;
    ns1:textoExtracto "Se señalan hitos A–F (control del override, vacío, entrada, vacío con override máximo, mecanizado a FZ máx. y a FZ mín.) con leyenda y ejes temporales." .

