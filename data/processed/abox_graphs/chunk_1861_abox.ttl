@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DialogoExportacion1 a ns1:InterfazUsuario ;
    rdfs:label "Diálogo de exportación 1" ;
    ns1:textoExtracto "(Arriba) Diálogo de exportación 'Export → Export Master Configuration ETG Standard' para generar el XML de configuración; (abajo) opción 'File → Save' para guardar proyecto *.ecsn. Se observan rutas de archivo, nombres propuestos y botones de confirmación." .

ns1:FagorEthercatMapper1 a ns1:Sistema ;
    rdfs:label "Fagor EtherCAT Mapper 1" ;
    ns1:textoExtracto "Vista general del 'Fagor EtherCAT Mapper': captura con (A) barra de iconos y nombre del ENI cargado, (B) barra de configuración por defecto (fichas de entradas/salidas y registros), (C) validación 'Overlapped', (D) topología en árbol, y (E) topología en bloques. Los bloques codifican tipo de recurso por color (DI/DO, registros, analógicas)." .

ns1:ModoOffline1 a ns1:ModoOperacion ;
    rdfs:label "Modo offline 1" ;
    ns1:textoExtracto "Modo offline en dos pasos ilustrados: (1) 'Append Slave' para añadir cabeceras desde el catálogo, (2) arrastrar módulos desde 'MDP modules' (derecha) a la topología (izquierda). Flechas curvas indican el 'drag & drop' y se ven tarjetas de módulo con nombre y tipo." .

ns1:Modulo1 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo 1" ;
    ns1:textoExtracto "la vista de árbol se expande para facilitar la detección y el panel derecho lista módulos con iconografía por tipo." ;
    ns1:tieneComponente ns1:NodoEsclavo1 .

ns1:VistaArbol1 a ns1:InterfazUsuario ;
    rdfs:label "Vista de árbol 1" ;
    ns1:ilustradoEn ns1:FlechaAzul1 ;
    ns1:textoExtracto "la vista de árbol muestra nodos esclavos y módulos hallados." .

ns1:FlechaAzul1 a ns1:AvisoSeguridad ;
    rdfs:label "Flecha azul 1" ;
    ns1:textoExtracto "Flechas azules indican el flujo de pasos; la vista de árbol muestra nodos esclavos y módulos hallados." .

ns1:NodoEsclavo1 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo esclavo 1" ;
    ns1:textoExtracto "la vista de árbol se expande para facilitar la detección y el panel derecho lista módulos con iconografía por tipo." .

