@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:BarraConfiguracion a ns1:InterfazUsuario ;
    ns1:detalladoEnEsquema ns1:Esquema1 ;
    ns1:textoExtracto "barra de configuración por defecto para mapeo (fichas Digital Input/Output, Register Input/Output y Overlapped con campos 'Starts/Offset/Visible') y vista de árbol que despliega esclavos y módulos mostrando sus recursos; indicadores 'Starts/Offset' para numeración y opción 'Ver esclavos'."@es .

ns1:Bloque1 a ns1:AccionProhibida ;
    ns1:identificador "DI" ;
    ns1:textoExtracto "Los bloques codifican tipo de recurso por color (DI/DO, registros, analógicas)."@es .

ns1:Bloque2 a ns1:AccionProhibida ;
    ns1:identificador "DO" ;
    ns1:textoExtracto "Los bloques codifican tipo de recurso por color (DI/DO, registros, analógicas)."@es .

ns1:Bloque3 a ns1:AccionProhibida ;
    ns1:identificador "registros" ;
    ns1:textoExtracto "Los bloques codifican tipo de recurso por color (DI/DO, registros, analógicas)."@es .

ns1:Bloque4 a ns1:AccionProhibida ;
    ns1:identificador "analógicas" ;
    ns1:textoExtracto "Los bloques codifican tipo de recurso por color (DI/DO, registros, analógicas)."@es .

ns1:CuadroPropiedades a ns1:InterfazUsuario ;
    ns1:detalladoEnEsquema ns1:Esquema3 ;
    ns1:textoExtracto "Cuadro de propiedades de un módulo en vista de bloques para redefinir el número inicial de sus recursos, numerándose el resto de forma correlativa. Se observan campos editables y previsualización del bloque afectado."@es .

ns1:EjemploAbajo a ns1:Figura ;
    ns1:ilustradoEn ns1:Pagina753 ;
    ns1:textoExtracto "Dos ejemplos gráficos: (arriba) cambio global de numeración (DI primera=10, offset=100; DO primera=21, offset=50) aplicados desde la barra superior; (abajo) ajuste por nodo haciendo clic en el nombre de la cabecera para definir el inicio de sus recursos. Flechas indican dónde editar."@es .

ns1:EjemploArriba a ns1:Figura ;
    ns1:ilustradoEn ns1:Pagina753 ;
    ns1:textoExtracto "Dos ejemplos gráficos: (arriba) cambio global de numeración (DI primera=10, offset=100; DO primera=21, offset=50) aplicados desde la barra superior; (abajo) ajuste por nodo haciendo clic en el nombre de la cabecera para definir el inicio de sus recursos. Flechas indican dónde editar."@es .

ns1:VistaBloques a ns1:InterfazUsuario ;
    ns1:detalladoEnEsquema ns1:Esquema2 ;
    ns1:textoExtracto "Vista en bloques del bus con leyenda cromática: azul (entradas digitales), morado (salidas digitales), rojo/gris (mapeos a/desde registros PLC), verde/amarillo (AI/AO Fagor). La captura muestra tarjetas alineadas por cabecera, con numeración visible y separación por módulos."@es .

