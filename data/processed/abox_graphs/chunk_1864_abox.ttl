@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazOpenPCS_ConfiguracionConexion a ns1:InterfazUsuario ;
    rdfs:label "Diálogo de configuración de conexión FagorCNCTCP en OpenPCS"@es ;
    ns1:textoExtracto "Diálogo 'Connections → FagorCNCTCP → Edit' del OpenPCS para configurar conexión, con campos de nombre y parámetros. Se destaca el acceso a 'Settings'."@es .

ns1:NodoEtherCAT_EnError a ns1:Componente ;
    rdfs:label "Nodo EtherCAT en error"@es ;
    ns1:compuestoPor ns1:SistemaEtherCAT ;
    ns1:textoExtracto "Vista de árbol de configuración localizando el nodo en error y panel derecho con 'Info/Value' del módulo afectado, para análisis detallado."@es .

ns1:Parametro_PLCREADY a ns1:Parametro ;
    rdfs:label "Estado PLCREADY"@es ;
    ns1:ilustradoEn ns1:InterfazOpenPCS_ParametrizacionPLC ;
    ns1:textoExtracto "efectos RUN/STOP/PLCREADY"@es .

ns1:Parametro_PLCTYPE a ns1:Parametro ;
    rdfs:label "PLCTYPE (IEC/Fagor/IEC+Fagor)"@es ;
    ns1:ilustradoEn ns1:InterfazOpenPCS_ParametrizacionPLC ;
    ns1:textoExtracto "tabla de significados para PLCTYPE (IEC/Fagor/IEC+Fagor)"@es .

ns1:Alarma_24499 a ns1:Alarma ;
    rdfs:label "ERROR 24499 – EtherCAT: Error in slave"@es ;
    ns1:identificador "24499" ;
    ns1:textoExtracto "Captura de alarma 'ERROR 24499 – EtherCAT: Error in slave. More information in diagnostic' en la HMI del CNC, con barra roja, código y botones de navegación. Resalta el identificador del error y la indicación de consultar diagnosis."@es .

ns1:InterfazDiagnosisEtherCAT a ns1:InterfazUsuario ;
    rdfs:label "Pantalla de diagnosis EtherCAT en CNC"@es ;
    ns1:activaAlarma ns1:Alarma_24499 ;
    ns1:textoExtracto "Pantalla de diagnosis con tres paneles: información general del bus (estado del máster, contadores), detalle de esclavos (lista con estado/Info/Value) y detalle de módulos (árbol de dispositivos y panel derecho con valores). Disposición jerárquica y uso de iconos de estado."@es .

ns1:SistemaEtherCAT a ns1:Sistema ;
    rdfs:label "Sistema EtherCAT (máster y esclavos)"@es ;
    ns1:documentadoEn ns1:InterfazDiagnosisEtherCAT ;
    ns1:textoExtracto "detalle de esclavos (lista con estado/Info/Value) y detalle de módulos (árbol de dispositivos y panel derecho con valores)"@es .

ns1:InterfazOpenPCS_ParametrizacionPLC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de parametrización del PLC remoto en OpenPCS"@es ;
    ns1:textoExtracto "Captura del interfaz de parametrización del PLC remoto: tabla de significados para PLCTYPE (IEC/Fagor/IEC+Fagor) y efectos RUN/STOP/PLCREADY, junto a panel de opciones del CNC (IEC-61131) y botones aplicados. Se muestra también un cuadro con ruta de proyecto/plantilla de hardware."@es .

