@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlarmaCaptacionEjes_001 a ns1:Alarma ;
    rdfs:label "Alarma de captación para ejes analógicos"@es ;
    ns1:activaAlarma ns1:SistemaSeguridadCNC_001 ;
    ns1:textoExtracto "Alarma de captación para ejes analógicos."@es .

ns1:ComponenteMecanico_Cabezal_001 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal"@es ;
    ns1:textoExtracto "Monitorización del error de seguimiento para ejes analógicos y sercos (excepto el cabezal)."@es .

ns1:ParametroErrorSeguimiento_001 a ns1:Parametro ;
    rdfs:label "Monitorización del error de seguimiento para ejes analógicos y sercos"@es ;
    ns1:monitoreaParametro ns1:SistemaSeguridadCNC_001 ;
    ns1:textoExtracto "Monitorización del error de seguimiento para ejes analógicos y sercos (excepto el cabezal), tanto en el CNC como en los reguladores."@es .

ns1:ParametroLimitesSoftware_001 a ns1:Parametro ;
    rdfs:label "Límites de software para ejes lineales analógicos y sercos"@es ;
    ns1:monitoreaParametro ns1:SistemaSeguridadCNC_001 ;
    ns1:textoExtracto "Límites de software para ejes lineales analógicos y sercos."@es .

ns1:TestTendenciaEjes_001 a ns1:Parametro ;
    rdfs:label "Test de tendencia en los ejes analógicos"@es ;
    ns1:monitoreaParametro ns1:SistemaSeguridadCNC_001 ;
    ns1:textoExtracto "Test de tendencia en los ejes analógicos."@es .

ns1:ManualSeguridadCNC_001 a ns1:Manual ;
    rdfs:label "Manual de seguridad del CNC"@es ;
    ns1:identificador "ManualSeguridadCNC" ;
    ns1:textoExtracto "MANUAL ORIGINAL. Este manual, así como los documentos que deriven del mismo, han sido redactados en español. [...] SEGURIDADES DE LA MÁQUINA. Es responsabilidad del fabricante de la máquina que las seguridades de la máquina estén habilitadas, con objeto de evitar lesiones a personas y prevenir daños al CNC o a los productos conectados a él."@es .

ns1:SistemaSeguridadCNC_001 a ns1:Sistema ;
    rdfs:label "Sistema de seguridad del CNC"@es ;
    ns1:documentadoEn ns1:ManualSeguridadCNC_001 ;
    ns1:textoExtracto "Durante el arranque y la validación de parámetros del CNC, se comprueba el estado de las siguientes seguridades. Si alguna de ellas está deshabilitada el CNC muestra un mensaje de advertencia."@es .

