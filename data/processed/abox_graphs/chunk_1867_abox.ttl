@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_8028_1 a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia sobre modificación no autorizada de hardware" ;
    ns1:mitigaRiesgo ns1:SistemaHardware_8028_1 ;
    ns1:textoExtracto "FAGOR AUTOMATION no se responsabiliza de lesiones a personas, daños físicos o materiales que pudiera sufrir o provocar el CNC, y que sean imputables a una modificación del hardware por personal no autorizado por Fagor Automation."@es .

ns1:AvisoSeguridad_8028_2 a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia sobre virus informáticos" ;
    ns1:mitigaRiesgo ns1:SistemaSoftware_8028_1 ;
    ns1:textoExtracto "FAGOR AUTOMATION no se responsabiliza de lesiones a personas, daños físicos o materiales que pudiera sufrir o provocar el CNC, y que sean imputables a la presencia de un virus informático en el sistema."@es .

ns1:AvisoSeguridad_8028_3 a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia sobre anulación de seguridades" ;
    ns1:mitigaRiesgo ns1:CNC_8028 ;
    ns1:textoExtracto "FAGOR AUTOMATION no se responsabiliza de lesiones a personas, daños físicos o materiales que pueda sufrir o provocar el CNC, y que sean imputables a la anulación de alguna de las seguridades."@es .

ns1:CNC_8028 a ns1:Maquina ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "FAGOR AUTOMATION no se responsabiliza de lesiones a personas, daños físicos o materiales que pueda sufrir o provocar el CNC, y que sean imputables a la anulación de alguna de las seguridades. [...] La modificación del hardware del CNC por personal no autorizado por Fagor Automation implica la pérdida de la garantía."@es ;
    ns1:tieneComponente ns1:SistemaHardware_8028_1,
        ns1:SistemaSoftware_8028_1 .

ns1:DirectivaUE_428_2009 a ns1:Directiva ;
    rdfs:label "Reglamento (UE) 428/2009 sobre productos de doble uso" ;
    ns1:identificador "UE 428/2009" ;
    ns1:textoExtracto "Los productos fabricados por FAGOR AUTOMATION a partir del 1 de abril de 2014, si el producto según el reglamento UE 428/2009 está incluido en la lista de productos de doble uso, incluye en la identificación de producto el texto -MDU y necesita licencia de exportación según destino."@es .

ns1:SistemaHardware_8028_1 a ns1:Sistema ;
    rdfs:label "Hardware del CNC" ;
    ns1:textoExtracto "La modificación del hardware del CNC por personal no autorizado por Fagor Automation implica la pérdida de la garantía."@es .

ns1:SistemaSoftware_8028_1 a ns1:Sistema ;
    rdfs:label "Software del CNC" ;
    ns1:cumpleNormativa ns1:DirectivaUE_428_2009 ;
    ns1:textoExtracto "FAGOR AUTOMATION garantiza que el software instalado no contiene ningún virus informático. [...] La presencia de virus informáticos en el CNC puede provocar su mal funcionamiento."@es .

