@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_Manual_CNC a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad sobre uso del CNC según documentación" ;
    ns1:documentadoEn ns1:Manual_FagorAutomation_CNC ;
    ns1:textoExtracto "Fagor Automation no se responsabiliza de lesiones, daños físicos o materiales que pudiera sufrir o provocar el CNC si éste se utiliza de manera diferente a la explicada en la documentación relacionada." .

ns1:Directiva_CumplimientoNormativasIndustriales a ns1:Directiva ;
    rdfs:label "Directiva de adaptación a normas de seguridad industriales" ;
    ns1:documentadoEn ns1:Manual_FagorAutomation_CNC ;
    ns1:textoExtracto "Antes de utilizarlos en aplicaciones industriales deben ser convenientemente adaptados y además se debe asegurar el cumplimiento de las normas de seguridad." .

ns1:Manual_FagorAutomation_CNC a ns1:Manual ;
    rdfs:label "Manual de CNC Fagor Automation" ;
    ns1:identificador "Edición actual (sujeta a correcciones en ediciones posteriores)" ;
    ns1:textoExtracto "CNC que no se encuentre recogida en la documentación se debe considerar como \"imposible\"... Los ejemplos descritos en este manual están orientados al aprendizaje." .

