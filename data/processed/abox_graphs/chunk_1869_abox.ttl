@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArchivoOrgData a ns1:InterfazUsuario ;
    rdfs:label "orgdata.tab" ;
    ns1:identificador "orgdata.tab" ;
    ns1:textoExtracto "El fichero orgdata.tab que contiene estos datos no existe, no es accesible o está corrupto." .

ns1:ErrorChecksumPLC_0004 a ns1:AvisoSeguridad ;
    rdfs:label "Error de checksum en los datos de PLC" ;
    ns1:activaAlarma ns1:AlarmaPLC_0004 ;
    ns1:identificador "0004" ;
    ns1:textoExtracto "'Error de checksum en los datos de PLC' DETECCIÓN Durante el arranque del CNC. CAUSA Los datos del PLC relativos a marcas, contadores, temporizadores y registros salvados a disco no son válidos. El archivo plcdata.bin que contiene estos datos no existe, no es accesible o está corrupto." .

ns1:ErrorMemoria_0003 a ns1:AvisoSeguridad ;
    rdfs:label "Error en la petición de memoria" ;
    ns1:activaAlarma ns1:AlarmaMemoria_0003 ;
    ns1:identificador "0003" ;
    ns1:textoExtracto "'Error en la petición de memoria. Reiniciar Windows y CNC' DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no dispone de suficiente memoria o la memoria se encuentra excesivamente fragmentada." .

ns1:ErrorReferencia_0005 a ns1:AvisoSeguridad ;
    rdfs:label "El CNC no se apagó correctamente, es necesario referenciar" ;
    ns1:activaAlarma ns1:AlarmaReferencia_0005 ;
    ns1:identificador "0005" ;
    ns1:textoExtracto "'El CNC no se apagó correctamente, es necesario referenciar' DETECCIÓN Durante el arranque del CNC. CAUSA Los datos del CNC relativos a las cotas, traslados de orígenes, etc que se salvan a disco no son válidos. El fichero orgdata.tab que contiene estos datos no existe, no es accesible o está corrupto." .

ns1:ErrorSistema_0001 a ns1:AvisoSeguridad ;
    rdfs:label "ERROR DEL SISTEMA" ;
    ns1:activaAlarma ns1:AlarmaSistema_0001 ;
    ns1:identificador "0001" ;
    ns1:textoExtracto "'ERROR DEL SISTEMA' DETECCIÓN Durante la ejecución. CAUSA Errores de software o hardware que provocan datos corruptos y/o resultados incongruentes. SOLUCIÓN Este tipo de errores normalmente fuerzan la salida del CNC." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "CNC (Control Numérico Computarizado)" ;
    ns1:tieneComponente ns1:ComponenteSoftwarePLC .

ns1:WarningSistema_0002 a ns1:AvisoSeguridad ;
    rdfs:label "WARNING DEL SISTEMA" ;
    ns1:activaAlarma ns1:AlarmaSistema_0002 ;
    ns1:identificador "0002" ;
    ns1:textoExtracto "'WARNING DEL SISTEMA' DETECCIÓN Durante la ejecución. CAUSA Aviso de situaciones internas que pueden acabar en errores del sistema. SOLUCIÓN Normalmente el CNC se recupera cerrando el warning." .

ns1:AlarmaMemoria_0003 a ns1:Alarma ;
    rdfs:label "Alarma de memoria insuficiente" ;
    ns1:textoExtracto "El CNC no dispone de suficiente memoria o la memoria se encuentra excesivamente fragmentada." .

ns1:AlarmaPLC_0004 a ns1:Alarma ;
    rdfs:label "Alarma de checksum PLC inválido" ;
    ns1:textoExtracto "Los datos del PLC relativos a marcas, contadores, temporizadores y registros salvados a disco no son válidos." .

ns1:AlarmaReferencia_0005 a ns1:Alarma ;
    rdfs:label "Alarma de referencia de cotas inválida" ;
    ns1:textoExtracto "Los datos del CNC relativos a las cotas, traslados de orígenes, etc que se salvan a disco no son válidos." .

ns1:AlarmaSistema_0001 a ns1:Alarma ;
    rdfs:label "Alarma de error crítico del sistema" ;
    ns1:textoExtracto "Errores de software o hardware que provocan datos corruptos y/o resultados incongruentes." .

ns1:AlarmaSistema_0002 a ns1:Alarma ;
    rdfs:label "Alarma de advertencia del sistema" ;
    ns1:textoExtracto "Aviso de situaciones internas que pueden acabar en errores del sistema." .

ns1:ArchivoPLCData a ns1:InterfazUsuario ;
    rdfs:label "plcdata.bin" ;
    ns1:identificador "plcdata.bin" ;
    ns1:textoExtracto "El archivo plcdata.bin que contiene estos datos no existe, no es accesible o está corrupto." .

ns1:ComponenteSoftwarePLC a ns1:Componente ;
    rdfs:label "Software PLC" ;
    ns1:documentadoEn ns1:ArchivoPLCData ;
    ns1:textoExtracto "datos del PLC relativos a marcas, contadores, temporizadores y registros salvados a disco" .

