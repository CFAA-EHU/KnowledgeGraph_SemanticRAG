@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:BloqueX31 a owl:Class ;
    rdfs:label "Bloque X31" ;
    rdfs:comment "Bloque X31 con US/UA/GND" .

ex:BloqueX32 a owl:Class ;
    rdfs:label "Bloque X32" ;
    rdfs:comment "Bloque X32 con US/UA/GND" .

ex:UnidadLubricacion a owl:Class ;
    rdfs:label "Unidad de Lubricación" ;
    rdfs:comment "Unidad de lubricación WA800/WE700" .

ex:BloqueEstadoLubricacion a owl:Class ;
    rdfs:label "Bloque de Estado Lubricación" ;
    rdfs:comment "Bloque de estado lubricación 515U1 → 515.03" .

ex:ConectorX01 a owl:Class ;
    rdfs:label "Conector X01" ;
    rdfs:comment "Conector X01 para cableado IN1–IN8" .

ex:ConectorX02 a owl:Class ;
    rdfs:label "Conector X02" ;
    rdfs:comment "Conector X02 para cableado IN1–IN8" .

ex:ConectorX03 a owl:Class ;
    rdfs:label "Conector X03" ;
    rdfs:comment "Conector X03 para cableado IN1–IN8" .

ex:ConectorX04 a owl:Class ;
    rdfs:label "Conector X04" ;
    rdfs:comment "Conector X04 para cableado IN1–IN8" .

ex:ConectorX05 a owl:Class ;
    rdfs:label "Conector X05" ;
    rdfs:comment "Conector X05 para cableado IN9–IN16" .

ex:ConectorX06 a owl:Class ;
    rdfs:label "Conector X06" ;
    rdfs:comment "Conector X06 para cableado IN9–IN16" .

ex:ConectorX07 a owl:Class ;
    rdfs:label "Conector X07" ;
    rdfs:comment "Conector X07 para cableado IN9–IN16" .

ex:ConectorX08 a owl:Class ;
    rdfs:label "Conector X08" ;
    rdfs:comment "Conector X08 para cableado IN9–IN16" .

ex:BP710 a owl:Class ;
    rdfs:label "BP710" ;
    rdfs:comment "Sensor de presión BP710 para aire de reglas lineales" .

ex:BP711 a owl:Class ;
    rdfs:label "BP711" ;
    rdfs:comment "Sensor de presión BP711" .

ex:BP714 a owl:Class ;
    rdfs:label "BP714" ;
    rdfs:comment "Presostato BP714" .

ex:FrenoMayr a owl:Class ;
    rdfs:label "Freno MAYR" ;
    rdfs:comment "Frenos MAYR (frontal/compensación IZQ)" .

ex:Bloque63U1 a owl:Class ;
    rdfs:label "Bloque 63U1" ;
    rdfs:comment "Bloque 63U1" .

ex:Bloque63U3 a owl:Class ;
    rdfs:label "Bloque 63U3" ;
    rdfs:comment "Bloque 63U3" .

ex:Bloque63U4 a owl:Class ;
    rdfs:label "Bloque 63U4" ;
    rdfs:comment "Bloque 63U4" .

ex:Latiguillo a owl:Class ;
    rdfs:label "Latiguillo" ;
    rdfs:comment "Latiguillo con longitud 1,5 m 5×0,34 y colores WH/BL" .

ex:ModuloDescentralizado a owl:Class ;
    rdfs:label "Módulo Descentralizado" ;
    rdfs:comment "Módulo descentralizado 70U1" .

ex:ConectorM12 a owl:Class ;
    rdfs:label "Conector M12" ;
    rdfs:comment "Conector M12 para módulo descentralizado" .

ex:BUSIN a owl:Class ;
    rdfs:label "BUS IN" ;
    rdfs:comment "BUS IN para módulo descentralizado" .

ex:BUSOUT a owl:Class ;
    rdfs:label "BUS OUT" ;
    rdfs:comment "BUS OUT para módulo descentralizado" .

ex:BorneAlimentacion a owl:Class ;
    rdfs:label "Borne de Alimentación" ;
    rdfs:comment "Bornes de alimentación para módulo descentralizado" .

ex:BorneMasa a owl:Class ;
    rdfs:label "Borne de Masa" ;
    rdfs:comment "Bornes de masa para módulo descentralizado" .

ex:Pin a owl:Class ;
    rdfs:label "Pin" ;
    rdfs:comment "Pines IN1–IN8, OUT1–OUT7 para módulo descentralizado" .

ex:JerarquiaVisual a owl:Class ;
    rdfs:label "Jerarquía Visual" ;
    rdfs:comment "Jerarquía visual para módulo descentralizado" .

ex:tieneConector a owl:ObjectProperty ;
    rdfs:domain ex:ModuloDescentralizado ;
    rdfs:range ex:ConectorM12 .

ex:tieneBUSIN a owl:ObjectProperty ;
    rdfs:domain ex:ModuloDescentralizado ;
    rdfs:range ex:BUSIN .

ex:tieneBUSOUT a owl:ObjectProperty ;
    rdfs:domain ex:ModuloDescentralizado ;
    rdfs:range ex:BUSOUT .

ex:tieneBornesAlimentacion a owl:ObjectProperty ;
    rdfs:domain ex:ModuloDescentralizado ;
    rdfs:range ex:BorneAlimentacion .

ex:tieneBornesMasa a owl:ObjectProperty ;
    rdfs:domain ex:ModuloDescentralizado ;
    rdfs:range ex:BorneMasa .

ex:tienePines a owl:ObjectProperty ;
    rdfs:domain ex:ModuloDescentralizado ;
    rdfs:range ex:Pin .

ex:tieneJerarquiaVisual a owl:ObjectProperty ;
    rdfs:domain ex:ModuloDescentralizado ;
    rdfs:range ex:JerarquiaVisual .

ex:tieneLongitud a owl:DatatypeProperty ;
    rdfs:domain ex:Latiguillo ;
    rdfs:range xsd:string .

ex:tieneColores a owl:DatatypeProperty ;
    rdfs:domain ex:Latiguillo ;
    rdfs:range xsd:string .

ex:tieneReferencia a owl:DatatypeProperty ;
    rdfs:domain ex:Bloque63U1 ;
    rdfs:range xsd:string .

ex:tieneReferencia a owl:DatatypeProperty ;
    rdfs:domain ex:Bloque63U3 ;
    rdfs:range xsd:string .

ex:tieneReferencia a owl:DatatypeProperty ;
    rdfs:domain ex:Bloque63U4 ;
    rdfs:range xsd:string .