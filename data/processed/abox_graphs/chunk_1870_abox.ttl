@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_DatosCNC_orgdata_tab a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en datos CNC (orgdata.tab)" ;
    ns1:identificador "orgdata.tab" ;
    ns1:solucionaFallo ns1:Accion_RecuperacionDatosCNC ;
    ns1:textoExtracto "Los datos del CNC relativos a las cotas, traslados de orígenes, etc que se salvan a disco no son válidos. El fichero orgdata.tab que contiene estos datos no existe, no es accesible o está corrupto." .

ns1:Accion_RecuperacionDatosCNC a ns1:TareaMantenimiento ;
    rdfs:label "Recuperación de datos CNC" ;
    ns1:textoExtracto "Si el error se repite en sucesivos arranques del CNC, póngase en contacto con soporte técnico para recuperar los datos de cotas, traslados de orígenes y cinemáticas." .

