@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:activaAlarma ns1:Error_0009,
        ns1:Error_0010 ;
    ns1:textoExtracto "Si el error se repite en sucesivos arranques del CNC" .

ns1:Error_0009 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de sistema: fallo en la gestión de la FIFO de AEP" ;
    ns1:identificador "0009" ;
    ns1:textoExtracto "0009 Aviso de sistema: fallo en la gestión de la fifo de aep. DETECCIÓN Durante la ejecución. CAUSA El programa tiene un gran número de funciones G o parámetros aritméticos. SOLUCIÓN Reducir el número de parámetros aritméticos usados o programar #FLUSH (vaciado del canal) en puntos de programa donde pequeñas esperas no tengan importancia." .

ns1:Error_0010 a ns1:AvisoSeguridad ;
    rdfs:label "Error en test de RAM con batería" ;
    ns1:identificador "0010" ;
    ns1:textoExtracto "'Error en test de RAM con batería' DETECCIÓN Durante el arranque del CNC. CAUSA El test de arranque ha detectado un error de" .

