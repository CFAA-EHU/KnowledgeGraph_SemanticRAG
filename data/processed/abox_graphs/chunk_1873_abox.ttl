@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error_0010 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en test de RAM con batería" ;
    ns1:identificador "0010" ;
    ns1:textoExtracto "0010 'Error en test de RAM con batería' DETECCIÓN Durante el arranque del CNC. CAUSA El test de arranque ha detectado un error de checksum en los datos de la NVRAM y por lo tanto un fallo en la misma. CONSECUENCIA Los datos guardados pueden no ser correctos (datos relativos a las cotas, traslados de orígenes, contador de piezas, cinemáticas, etc). SOLUCIÓN Si el error se repite en sucesivos arranques del CNC, póngase en contacto con su proveedor." .

ns1:Error_0011 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de checksum en los datos de búsqueda de bloque" ;
    ns1:identificador "0011" ;
    ns1:textoExtracto "0011 'Error de checksum en los datos de búsqueda de bloque' DETECCIÓN Durante el arranque del CNC. CAUSA Error de cheksum de los datos necesarios para ejecutar una búsqueda de bloque automática. CONSECUENCIA No es posible ejecutar una búsqueda de bloque automática. SOLUCIÓN Si el error se repite en sucesivos arranques del CNC, póngase en contacto con su proveedor." .

ns1:Error_0013 a ns1:DiagnosticoFallo ;
    rdfs:label "ASSERT DEL SISTEMA" ;
    ns1:identificador "0013" ;
    ns1:textoExtracto "0013 ASSERT DEL SISTEMA. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC ha generado un error sin determinar. SOLUCIÓN Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error_0014 a ns1:DiagnosticoFallo ;
    rdfs:label "Detectado Watchdog en la última sesión" ;
    ns1:identificador "0014" ;
    ns1:textoExtracto "0014 Detectado Watchdog en la última sesión. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC se ha cerrado debido a un reset por watchdog. SOLUCIÓN Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error_0015 a ns1:DiagnosticoFallo ;
    rdfs:label "Detectado apagado/reinicio del equipo" ;
    ns1:identificador "0015" ;
    ns1:textoExtracto "0015 Detectado apagado/reinicio del equipo. DETECCIÓN Durante el arranque del CNC. CAUSA Una causa indeterminada ha provocado un apagado/reinicio del equipo. SOLUCIÓN Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error_0016 a ns1:DiagnosticoFallo ;
    rdfs:label "Detectado apagado/reinicio durante el arranque del sistema operativo" ;
    ns1:identificador "0016" ;
    ns1:textoExtracto "0016 Detectado apagado/reinicio durante el arranque del sistema operativo." .

ns1:Parametro_PREPFREQ a ns1:Parametro ;
    ns1:identificador "PREPFREQ" ;
    ns1:monitoreaParametro ns1:Error_0012 ;
    ns1:textoExtracto "Reducir el número de bloques a preparar por ciclo (parámetro PREPFREQ)." .

ns1:Error_0012 a ns1:DiagnosticoFallo ;
    rdfs:label "No hay tiempo de CPU para ejecutar todos los PREPFREQ" ;
    ns1:identificador "0012" ;
    ns1:textoExtracto "0012 No hay tiempo de CPU para ejecutar todos los PREPFREQ. DETECCIÓN Durante la ejecución. CAUSA El CNC necesita demasiado tiempo para analizar el programa. SOLUCIÓN Reducir el número de bloques a preparar por ciclo (parámetro PREPFREQ)." .

