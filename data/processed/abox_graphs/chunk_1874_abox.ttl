@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_ApagadoIndeterminado a ns1:DiagnosticoFallo ;
    rdfs:label "Apagado/reinicio indeterminado en arranque CNC"@es ;
    ns1:solucionaFallo ns1:Accion_ContactoSoporte ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA Una causa indeterminada ha provocado un apagado/reinicio del equipo."@es .

ns1:Fallo_CaidaAlimentacion a ns1:DiagnosticoFallo ;
    rdfs:label "Apagado por caída de alimentación en arranque"@es ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El CNC ha detectado un apagado inesperado por una caída de alimentación, durante el arranque del sistema operativo."@es .

ns1:SistemaOperativo_CNC a ns1:Sistema ;
    rdfs:label "Sistema operativo del CNC"@es ;
    ns1:activaAlarma ns1:Error_0016 ;
    ns1:textoExtracto "arranque del sistema operativo"@es .

ns1:Accion_ContactoSoporte a ns1:AccionProhibida ;
    rdfs:label "Contactar con Fagor Automation para error persistente"@es ;
    ns1:textoExtracto "SOLUCIÓN Si el error persiste, póngase en contacto con Fagor Automation."@es .

ns1:Error_0016 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0016: Apagado/reinicio durante arranque"@es ;
    ns1:identificador "0016" ;
    ns1:textoExtracto "0016 Detectado apagado/reinicio durante el arranque del sistema operativo."@es .

