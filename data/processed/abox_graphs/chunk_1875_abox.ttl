@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_0017 a ns1:AvisoSeguridad ;
    rdfs:label "Detectado apagado/reinicio por caída de alimentación" ;
    ns1:identificador "0017" ;
    ns1:mitigaRiesgo ns1:Solucion_0017 ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El CNC ha detectado un apagado inesperado por una caída de alimentación. SOLUCIÓN Revisar la alimentación del CNC. Los datos del CNC relativos a las cotas, traslados de orígenes, contador de piezas, cinemáticas, etc se pueden haber perdido." .

ns1:Error_0018 a ns1:AvisoSeguridad ;
    rdfs:label "Detectado apagado/reinicio por pantalla azul" ;
    ns1:identificador "0018" ;
    ns1:mitigaRiesgo ns1:Solucion_0018 ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El cierre anterior del CNC fue debido a una excepción de bajo nivel (pantalla azul). SOLUCIÓN Los datos del CNC relativos a las cotas, traslados de orígenes, contador de piezas, cinemáticas, etc se pueden haber perdido." .

ns1:Error_0020 a ns1:AvisoSeguridad ;
    rdfs:label "Acceso a variable incorrecto" ;
    ns1:identificador "0020" ;
    ns1:mitigaRiesgo ns1:Solucion_0020 ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC o al cambiar de página. CAUSA El CNC está accediendo a una variable de interfaz que no existe. SOLUCIÓN Póngase en contacto con el fabricante de la máquina o con el diseñador de las páginas de su interfaz para eliminar o corregir el acceso a la variable." .

ns1:Error_0021 a ns1:AvisoSeguridad ;
    rdfs:label "No hay teclado de CAN" ;
    ns1:identificador "0021" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha detectado el teclado CAN." .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation" ;
    ns1:textoExtracto "póngase en contacto con Fagor Automation." .

ns1:InterfazUsuario_CNC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de usuario del CNC" ;
    ns1:textoExtracto "El CNC está accediendo a una variable de interfaz que no existe." .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "El CNC ha detectado un apagado inesperado por una caída de alimentación, durante el arranque del sistema operativo." ;
    ns1:tieneComponente ns1:InterfazUsuario_CNC .

ns1:Solucion_0017 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de alimentación del CNC" ;
    ns1:requiereMantenimiento ns1:Maquina_CNC ;
    ns1:textoExtracto "Revisar la alimentación del CNC." .

ns1:Solucion_0018 a ns1:TareaMantenimiento ;
    rdfs:label "Contacto con soporte técnico por pantalla azul" ;
    ns1:ejecutadoPor ns1:Empresa_FagorAutomation ;
    ns1:textoExtracto "Si el error se repite en sucesivos arranques del CNC, póngase en contacto con Fagor Automation." .

ns1:Solucion_0020 a ns1:TareaMantenimiento ;
    rdfs:label "Corrección de acceso a variable de interfaz" ;
    ns1:textoExtracto "Póngase en contacto con el fabricante de la máquina o con el diseñador de las páginas de su interfaz para eliminar o corregir el acceso a la variable." .

