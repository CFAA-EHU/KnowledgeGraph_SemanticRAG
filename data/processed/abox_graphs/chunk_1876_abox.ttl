@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC" ;
    ns1:activaAlarma ns1:Error_0021,
        ns1:Error_0022 ;
    ns1:textoExtracto "Póngase en contacto con el fabricante de la máquina" ;
    ns1:tieneComponente ns1:BusCAN,
        ns1:InterfazUsuario_CNC,
        ns1:TecladoCAN .

ns1:BusCAN a ns1:ComponenteElectrico ;
    rdfs:label "Bus CAN" ;
    ns1:textoExtracto "Comprobar en el modo diagnosis el estado del bus CAN" .

ns1:Error_0022 a ns1:AvisoSeguridad ;
    rdfs:label "Variable no permitida en el entorno de la puesta a punto" ;
    ns1:identificador "0022" ;
    ns1:textoExtracto "0022 'Variable no permitida en el entorno de la puesta a punto'" .

ns1:InterfazUsuario_CNC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de usuario del CNC" ;
    ns1:textoExtracto "Póngase en contacto con el fabricante de la máquina o con el diseñador de las páginas de su interfaz para eliminar o corregir el acceso a la variable." .

ns1:ModoDiagnosis a ns1:ModoOperacion ;
    rdfs:label "Modo diagnosis" ;
    ns1:mitigaRiesgo ns1:Error_0021 ;
    ns1:textoExtracto "Comprobar en el modo diagnosis el estado del bus CAN y si el CNC reconoce el teclado." .

ns1:TecladoCAN a ns1:ComponenteElectrico ;
    rdfs:label "Teclado CAN" ;
    ns1:monitoreaParametro ns1:VariableInterfaz ;
    ns1:textoExtracto "El CNC no ha detectado el teclado CAN." .

ns1:VariableInterfaz a ns1:Parametro ;
    rdfs:label "Variable de interfaz" ;
    ns1:textoExtracto "eliminar o corregir el acceso a la variable" .

ns1:Error_0021 a ns1:AvisoSeguridad ;
    rdfs:label "No hay teclado de CAN" ;
    ns1:identificador "0021" ;
    ns1:solucionaFallo ns1:ModoDiagnosis ;
    ns1:textoExtracto "0021 No hay teclado de CAN. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha detectado el teclado CAN." .

