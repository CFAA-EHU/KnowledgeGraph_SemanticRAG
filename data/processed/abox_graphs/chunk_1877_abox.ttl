@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_0022 a ns1:AvisoSeguridad ;
    rdfs:label "Variable no permitida en el entorno de la puesta a punto"@es ;
    ns1:identificador "0022" ;
    ns1:solucionaFallo ns1:Solucion_0022 ;
    ns1:textoExtracto "DETECCIÓN Al definir variables en el entorno de puesta a punto. CAUSA En el entorno de puesta a punto hay definida una variable no permitida. SOLUCIÓN Consultar en el manual de operación la lista de variables permitidas."@es .

ns1:Error_0023 a ns1:AvisoSeguridad ;
    rdfs:label "Es necesario parar el programa para iniciar la traza por primera vez"@es ;
    ns1:identificador "0023" ;
    ns1:solucionaFallo ns1:Solucion_0023 ;
    ns1:textoExtracto "DETECCIÓN Al iniciar una traza en el osciloscopio. CAUSA Es la primera vez que el osciloscopio inicia una traza y hay un programa en ejecución. La traza utiliza variables del regulador que o bien no están en la tabla de parámetros máquina o bien están en dicha tabla pero son asíncronas. SOLUCIÓN Parar el programa en ejecución."@es .

ns1:Error_0024 a ns1:AvisoSeguridad ;
    rdfs:label "Error iniciando la traza"@es ;
    ns1:identificador "0024" ;
    ns1:textoExtracto "DETECCIÓN Al iniciar una traza en el osciloscopio."@es .

ns1:InterfazOsciloscopio a ns1:InterfazUsuario ;
    ns1:documentadoEn ns1:ManualOperacion ;
    ns1:textoExtracto "osciloscopio"@es .

ns1:TablaParametrosMaquina a ns1:Tabla ;
    ns1:monitoreaParametro ns1:VariableRegulador ;
    ns1:textoExtracto "tabla de parámetros máquina"@es .

ns1:Solucion_0022 a ns1:TareaMantenimiento ;
    ns1:requiereMantenimiento ns1:ManualOperacion ;
    ns1:textoExtracto "Consultar en el manual de operación la lista de variables permitidas."@es .

ns1:Solucion_0023 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Parar el programa en ejecución."@es .

ns1:VariableRegulador a ns1:Parametro ;
    ns1:textoExtracto "variables del regulador"@es .

ns1:ManualOperacion a ns1:Manual ;
    ns1:textoExtracto "lista de variables permitidas"@es .

