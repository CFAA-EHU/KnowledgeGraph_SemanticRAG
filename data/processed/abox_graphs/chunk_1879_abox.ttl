@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_0026 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0026: Variable no permitida en el entorno del osciloscopio" ;
    ns1:identificador "0026" ;
    ns1:solucionaFallo ns1:ConsultarDocumentacionDeVariablesPermitidas ;
    ns1:textoExtracto "'Variable no permitida en el entorno del oscilo' DETECCIÓN Al definir variables en un canal del osciloscopio. CAUSA La variable definida en el osciloscopio es de simulación, binaria, string o está protegida por contraseña." .

ns1:Sistema_Osciloscopio a ns1:Sistema ;
    rdfs:label "Sistema de osciloscopio (entorno de variables)" ;
    ns1:textoExtracto "entorno del osciloscopio [...] variables en un canal del osciloscopio" ;
    ns1:tieneComponente ns1:CanalDeOsciloscopio .

ns1:CanalDeOsciloscopio a ns1:ComponenteElectrico ;
    rdfs:label "Canal de osciloscopio" ;
    ns1:textoExtracto "canal del osciloscopio" .

ns1:ConsultarDocumentacionDeVariablesPermitidas a ns1:AvisoSeguridad ;
    rdfs:label "Consultar documentación de variables permitidas" ;
    ns1:textoExtracto "Consultar en la documentación la lista de variables" .

