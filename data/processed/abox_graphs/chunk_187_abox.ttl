@prefix ex: <https://vocab.cfaa.eus/broaching/>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

ex:Puerto a owl:Class ;
    rdfs:label "Puerto" ;
    rdfs:comment "Clase que representa un puerto en el esquema de cableado." .

ex:Pin a owl:Class ;
    rdfs:label "Pin" ;
    rdfs:comment "Clase que representa un pin en el esquema de cableado." .

ex:ReferenciaCruzada a owl:Class ;
    rdfs:label "ReferenciaCruzada" ;
    rdfs:comment "Clase que representa una referencia cruzada en el esquema de cableado." .

ex:CodigoCableado a owl:Class ;
    rdfs:label "CodigoCableado" ;
    rdfs:comment "Clase que representa un código de cableado en el esquema de cableado." .

ex:JerarquiaVisual a owl:Class ;
    rdfs:label "JerarquiaVisual" ;
    rdfs:comment "Clase que representa una jerarquía visual en el esquema de cableado." .

ex:Alimentacion a owl:Class ;
    rdfs:label "Alimentacion" ;
    rdfs:comment "Clase que representa la alimentación en el esquema de cableado." .

ex:Señal a owl:Class ;
    rdfs:label "Señal" ;
    rdfs:comment "Clase que representa una señal en el esquema de cableado." .

ex:Tierra a owl:Class ;
    rdfs:label "Tierra" ;
    rdfs:comment "Clase que representa la tierra en el esquema de cableado." .

ex:EsquemaCableado a owl:Class ;
    rdfs:label "EsquemaCableado" ;
    rdfs:comment "Clase que representa un esquema de cableado." .

ex:Linea a owl:Class ;
    rdfs:label "Linea" ;
    rdfs:comment "Clase que representa una línea en el esquema de cableado." .

ex:Conector a owl:Class ;
    rdfs:label "Conector" ;
    rdfs:comment "Clase que representa un conector en el esquema de cableado." .

ex:Latiguillo a owl:Class ;
    rdfs:label "Latiguillo" ;
    rdfs:comment "Clase que representa un latiguillo en el esquema de cableado." .

ex:Direccionalidad a owl:Class ;
    rdfs:label "Direccionalidad" ;
    rdfs:comment "Clase que representa la direccionalidad de una señal en el esquema de cableado." .

ex:Bloque a owl:Class ;
    rdfs:label "Bloque" ;
    rdfs:comment "Clase que representa un bloque en el esquema de cableado." .

ex:EntradaDigital a owl:Class ;
    rdfs:label "EntradaDigital" ;
    rdfs:comment "Clase que representa una entrada digital en el esquema de cableado." .

ex:Sensor a owl:Class ;
    rdfs:label "Sensor" ;
    rdfs:comment "Clase que representa un sensor en el esquema de cableado." .

ex:Actuador a owl:Class ;
    rdfs:label "Actuador" ;
    rdfs:comment "Clase que representa un actuador en el esquema de cableado." .

ex:Freno a owl:Class ;
    rdfs:label "Freno" ;
    rdfs:comment "Clase que representa un freno en el esquema de cableado." .

ex:TensadoCadena a owl:Class ;
    rdfs:label "TensadoCadena" ;
    rdfs:comment "Clase que representa el tensado de cadena en el esquema de cableado." .

ex:Nivel a owl:Class ;
    rdfs:label "Nivel" ;
    rdfs:comment "Clase que representa un nivel en el esquema de cableado." .

ex:Pressostato a owl:Class ;
    rdfs:label "Pressostato" ;
    rdfs:comment "Clase que representa un pressostato en el esquema de cableado." .

ex:SeñalBloqueo a owl:Class ;
    rdfs:label "SeñalBloqueo" ;
    rdfs:comment "Clase que representa una señal de bloqueo en el esquema de cableado." .

ex:SeñalDesbloqueo a owl:Class ;
    rdfs:label "SeñalDesbloqueo" ;
    rdfs:comment "Clase que representa una señal de desbloqueo en el esquema de cableado." .

ex:IconoBorna a owl:Class ;
    rdfs:label "IconoBorna" ;
    rdfs:comment "Clase que representa un icono de borna en el esquema de cableado." .

ex:NotaLongitud a owl:Class ;
    rdfs:label "NotaLongitud" ;
    rdfs:comment "Clase que representa una nota de longitud en el esquema de cableado." .

ex:NotaSeccionCable a owl:Class ;
    rdfs:label "NotaSeccionCable" ;
    rdfs:comment "Clase que representa una nota de sección de cable en el esquema de cableado." .

ex:Polaridad a owl:Class ;
    rdfs:label "Polaridad" ;
    rdfs:comment "Clase que representa la polaridad en el esquema de cableado." .

ex:Retorno a owl:Class ;
    rdfs:label "Retorno" ;
    rdfs:comment "Clase que representa el retorno en el esquema de cableado." .

ex:SalidaDigital a owl:Class ;
    rdfs:label "SalidaDigital" ;
    rdfs:comment "Clase que representa una salida digital en el esquema de cableado." .

ex:ValvulaNeumatica a owl:Class ;
    rdfs:label "ValvulaNeumatica" ;
    rdfs:comment "Clase que representa una válvula neumática en el esquema de cableado." .

ex:Funcion a owl:Class ;
    rdfs:label "Funcion" ;
    rdfs:comment "Clase que representa una función en el esquema de cableado." .

ex:Bobina a owl:Class ;
    rdfs:label "Bobina" ;
    rdfs:comment "Clase que representa una bobina en el esquema de cableado." .

ex:Masa a owl:Class ;
    rdfs:label "Masa" ;
    rdfs:comment "Clase que representa la masa en el esquema de cableado." .

ex:tienePines a owl:ObjectProperty ;
    rdfs:domain ex:Puerto ;
    rdfs:range ex:Pin .

ex:tieneReferenciasCruzadas a owl:ObjectProperty ;
    rdfs:domain ex:Puerto ;
    rdfs:range ex:ReferenciaCruzada .

ex:tieneCodigosCableado a owl:ObjectProperty ;
    rdfs:domain ex:Puerto ;
    rdfs:range ex:CodigoCableado .

ex:separaJerarquiaVisual a owl:ObjectProperty ;
    rdfs:domain ex:JerarquiaVisual ;
    rdfs:range ex:Alimentacion .

ex:separaJerarquiaVisual a owl:ObjectProperty ;
    rdfs:domain ex:JerarquiaVisual ;
    rdfs:range ex:Señal .

ex:separaJerarquiaVisual a owl:ObjectProperty ;
    rdfs:domain ex:JerarquiaVisual ;
    rdfs:range ex:Tierra .

ex:tieneLineas a owl:ObjectProperty ;
    rdfs:domain ex:EsquemaCableado ;
    rdfs:range ex:Linea .

ex:tieneConectores a owl:ObjectProperty ;
    rdfs:domain ex:EsquemaCableado ;
    rdfs:range ex:Conector .

ex:tieneLatiguillo a owl:ObjectProperty ;
    rdfs:domain ex:EsquemaCableado ;
    rdfs:range ex:Latiguillo .

ex:indicaDireccionalidad a owl:ObjectProperty ;
    rdfs:domain ex:EsquemaCableado ;
    rdfs:range ex:Direccionalidad .

ex:tieneBloques a owl:ObjectProperty ;
    rdfs:domain ex:EsquemaCableado ;
    rdfs:range ex:Bloque .

ex:tieneEntradasDigitales a owl:ObjectProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range ex:EntradaDigital .

ex:tieneSensores a owl:ObjectProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range ex:Sensor .

ex:tieneActuadores a owl:ObjectProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range ex:Actuador .

ex:tieneFrenos a owl:ObjectProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range ex:Freno .

ex:tieneTensadoCadena a owl:ObjectProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range ex:TensadoCadena .

ex:tieneNiveles a owl:ObjectProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range ex:Nivel .

ex:tienePressostatos a owl:ObjectProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range ex:Pressostato .

ex:tieneSeñalesBloqueo a owl:ObjectProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range ex:SeñalBloqueo .

ex:tieneSeñalesDesbloqueo a owl:ObjectProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range ex:SeñalDesbloqueo .

ex:tieneIconosBornas a owl:ObjectProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range ex:IconoBorna .

ex:tieneNotasLongitud a owl:ObjectProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range ex:NotaLongitud .

ex:tieneNotasSeccionCable a owl:ObjectProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range ex:NotaSeccionCable .

ex:tienePolaridades a owl:ObjectProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range ex:Polaridad .

ex:tieneRetornos a owl:ObjectProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range ex:Retorno .

ex:tieneSalidasDigitales a owl:ObjectProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range ex:SalidaDigital .

ex:tieneValvulasNeumaticas a owl:ObjectProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range ex:ValvulaNeumatica .

ex:tieneFunciones a owl:ObjectProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range ex:Funcion .

ex:tieneBobinas a owl:ObjectProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range ex:Bobina .

ex:tieneMasa a owl:ObjectProperty ;
    rdfs:domain ex:Bloque ;
    rdfs:range ex:Masa .