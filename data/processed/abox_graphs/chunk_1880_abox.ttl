@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CanalOsciloscopio a ns1:InterfazUsuario ;
    rdfs:label "Canal de osciloscopio para definición de variables/parámetros" ;
    ns1:monitoreaParametro ns1:VariableProtegidaSimulada ;
    ns1:textoExtracto "canal del osciloscopio. [...] Al definir variables en un canal del osciloscopio." .

ns1:Error0027 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0027: Eje no Mechatrolink" ;
    ns1:identificador "0027" ;
    ns1:solucionaFallo ns1:VariableParametroDeEjeMechatrolink ;
    ns1:textoExtracto "El eje no es mechatrolink. [...] SOLUCIÓN Seleccionar un eje Mechatrolink. La variable o parámetro de eje debe existir para el eje pedido." .

ns1:Error0028 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0028: Parámetro Mechatrolink no asociable a canal de osciloscopio" ;
    ns1:identificador "0028" ;
    ns1:solucionaFallo ns1:ModoMlinkII32Bytes ;
    ns1:textoExtracto "No se permite asociar un parámetro mechatrolink a un canal del oscilo. [...] SOLUCIÓN El acceso a variables y/o parámetros de los dispositivos Mechatrolink sólo está disponible para el modo Mlink-II a 32 bytes." .

ns1:Error0029 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0029: Variables DRV/MLINK requieren modo Mlink-II" ;
    ns1:identificador "0029" ;
    ns1:solucionaFallo ns1:Error0028_modosMlinkII ;
    ns1:textoExtracto "'Sólo MLINKII permite variables DRV o MLINK en un canal del oscilo' [...] SOLUCIÓN El acceso a variables y/o parámetros de los dispositivos Mechatrolink sólo está disponible para el modo Mlink-II a 32 bytes." .

ns1:Error0030 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0030: Programación de eje por nombre (no por número lógico)" ;
    ns1:identificador "0030" ;
    ns1:solucionaFallo ns1:VariableDeReguladorDRVConReferenciaAEje ;
    ns1:textoExtracto "'Se debe programar el eje de la variable mediante su nombre' [...] SOLUCIÓN En estas variables, el eje se debe programar mediante su nombre." .

ns1:Error0031 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0031: Parámetros Mechatrolink requieren modo Mlink-II en osciloscopio" ;
    ns1:identificador "0031" ;
    ns1:solucionaFallo ns1:Error0028_modosMlinkII ;
    ns1:textoExtracto "'Sólo MLINKII permite parámetros mechatrolink en el oscilo' [...] DETECCIÓN Al definir parámetros en un canal del osciloscopio." .

ns1:VariableDRV a ns1:Parametro ;
    rdfs:label "Variable DRV (regulador)" ;
    ns1:textoExtracto "variable DRV. [...] variable del regulador (DRV)" .

ns1:VariableMechatrolink a ns1:Parametro ;
    rdfs:label "Variable Mechatrolink" ;
    ns1:textoExtracto "variable Mechatrolink o una variable DRV asociada a un parámetro mechatrolink" .

ns1:ModoMlinkII32Bytes a ns1:ModoOperacion ;
    rdfs:label "Modo Mlink-II (32 bytes)" ;
    ns1:requiereMantenimiento ns1:ParametroMechatrolink ;
    ns1:textoExtracto "modo Mlink-II a 32 bytes" .

ns1:ParametroDeConfiguracionMLINK a ns1:Parametro ;
    rdfs:label "Parámetro de configuración MLINK" ;
    ns1:identificador "MLINK" ;
    ns1:textoExtracto "parámetro MLINK" .

ns1:ParametroMechatrolink a ns1:Parametro ;
    rdfs:label "Parámetro Mechatrolink" ;
    ns1:textoExtracto "parámetro Mechatrolink o una variable DRV asociada a un parámetro mechatrolink" .

ns1:VariableDeReguladorDRVConReferenciaAEje a ns1:Parametro ;
    rdfs:label "Variable de regulador (DRV) con referencia a eje" ;
    ns1:textoExtracto "variable del regulador (DRV), el eje está programado mediante su número lógico o indice" .

ns1:VariableParametroDeEjeMechatrolink a ns1:Parametro ;
    rdfs:label "Variable/parámetro de eje Mechatrolink" ;
    ns1:textoExtracto "variable o parámetro es exclusivo de un eje mechatrolink" .

ns1:VariableProtegidaSimulada a ns1:Parametro ;
    rdfs:label "Variable protegida/simulada" ;
    ns1:textoExtracto "variable definida en el osciloscopio es de simulación, binaria, string o está protegida por contraseña" .

ns1:Error0028_modosMlinkII a ns1:ModoOperacion ;
    rdfs:label "Modo Mlink-II (32 bytes para acceso a Mechatrolink)" ;
    ns1:requiereMantenimiento ns1:ParametroDeConfiguracionMLINK ;
    ns1:textoExtracto "modo Mlink-II a 32 bytes" .

