@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_0031 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de acceso a parámetros Mechatrolink (0031)" ;
    ns1:solucionaFallo ns1:Parametro_Mechatrolink_0031 ;
    ns1:textoExtracto "DETECCIÓN Al definir parámetros en un canal del osciloscopio. [...] SOLUCIÓN El acceso a variables y/o parámetros de los dispositivos Mechatrolink sólo está" .

ns1:ModoOperacion_MLINK_I a ns1:ModoOperacion ;
    rdfs:label "Modo Mlink-I" ;
    ns1:identificador "MLINK" ;
    ns1:textoExtracto "en el CNC está activo el modo Mlink-I (parámetro MLINK)" .

ns1:Parametro_Mechatrolink_0031 a ns1:Parametro ;
    rdfs:label "Parámetro Mechatrolink 0031" ;
    ns1:identificador "0031" ;
    ns1:textoExtracto "Sólo MLINKII permite parámetros mechatrolink en el oscilo [...] En el osciloscopio hay definido un parámetro Mechatrolink, pero en el CNC está activo el modo Mlink-I (parámetro MLINK)" .

