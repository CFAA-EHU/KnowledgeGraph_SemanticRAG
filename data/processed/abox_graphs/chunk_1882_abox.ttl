@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC con parámetros Mechatrolink" ;
    ns1:requiereMantenimiento ns1:DiagnosticoFallo_0032,
        ns1:DiagnosticoFallo_0033 ;
    ns1:textoExtracto "en el CNC está activo el modo Mlink-I (parámetro MLINK)" ;
    ns1:tieneComponente ns1:Parametro_MLINK .

ns1:ModoOperacion_Mlink_I a ns1:ModoOperacion ;
    rdfs:label "Modo Mlink-I" ;
    ns1:textoExtracto "modo Mlink-I (parámetro MLINK)" .

ns1:ModoOperacion_Mlink_II a ns1:ModoOperacion ;
    rdfs:label "Modo Mlink-II" ;
    ns1:habilitadoPor ns1:Parametro_MLINK ;
    ns1:textoExtracto "modo Mlink-II a 32 bytes" ;
    ns1:valor "32 bytes" .

ns1:DiagnosticoFallo_0032 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0032: Parámetro o variable Mechatrolink fuera de rango" ;
    ns1:identificador "0032" ;
    ns1:solucionaFallo ns1:Parametro_MLINK0_a_MLINKF,
        ns1:Variable_P0_a_PFFFF ;
    ns1:textoExtracto "0032 Parámetro o variable mechatrolink fuera de rango. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El parámetro o variable tiene un valor no válido." .

ns1:DiagnosticoFallo_0033 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0033: Array no permitido en parámetros y variables Mechatrolink" ;
    ns1:identificador "0033" ;
    ns1:textoExtracto "0033 Array no permitido en parámetros y variables Mechatrolink. DETECCIÓN Durante la ejecución. CAUSA Los parámetros y variables Mechatrolink (parámetros máquina OEM) no admiten arrays. SOLUCIÓN Revisar la programación." .

ns1:Parametro_MLINK a ns1:Parametro ;
    rdfs:label "Parámetro MLINK (modo Mechatrolink)" ;
    ns1:identificador "MLINK" ;
    ns1:monitoreaParametro ns1:Parametro_MLINK0_a_MLINKF,
        ns1:Variable_P0_a_PFFFF ;
    ns1:textoExtracto "parámetro Mechatrolink [...] parámetro MLINK [...] modo Mlink-I (parámetro MLINK)" .

ns1:Parametro_MLINK0_a_MLINKF a ns1:Parametro ;
    rdfs:label "Rango de parámetros Mechatrolink (MLINK0 a MLINKF)" ;
    ns1:textoExtracto "El rango de parámetros Mechatrolink válido es MLINK0 a MLINKF" ;
    ns1:valor "MLINK0 a MLINKF" .

ns1:Variable_P0_a_PFFFF a ns1:Parametro ;
    rdfs:label "Rango de variables Mechatrolink (P0 a PFFFF)" ;
    ns1:textoExtracto "El rango de variables Mechatrolink válido es P0 a PFFFF" ;
    ns1:valor "P0 a PFFFF" .

