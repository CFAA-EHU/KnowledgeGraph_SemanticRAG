@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Fallo_0034 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta programar el eje en el parámetro o variable Mechatrolink" ;
    ns1:identificador "0034" ;
    ns1:monitoreaParametro ns1:ParametroOVariableMechatrolink ;
    ns1:solucionaFallo ns1:RevisarLaProgramacionDeParametrosMechatrolink ;
    ns1:textoExtracto "Falta programar el eje en el parámetro o variable Mechatrolink. DETECCIÓN Durante la ejecución. CAUSA Falta programar el eje en el parámetro o variable Mechatrolink (parámetros máquina OEM). SOLUCIÓN Revisar la programación. Los parámetros y variables Mechatrolink tienen que estar asociadas a un eje." .

ns1:Fallo_0035 a ns1:DiagnosticoFallo ;
    rdfs:label "Número máximo de variables en oscilo sobrepasado" ;
    ns1:identificador "0035" ;
    ns1:monitoreaParametro ns1:VariablesDelReguladorEnOsciloscopio ;
    ns1:solucionaFallo ns1:LimitarVariablesDelReguladorEnOsciloscopio ;
    ns1:textoExtracto "Número máximo de variables en oscilo sobrepasado. DETECCIÓN En el osciloscopio. CAUSA Hay más de dos canales del oscilo con variables del mismo regulador. SOLUCIÓN El número máximo de variables del mismo regulador que se pueden tracear simultáneamente en el oscilo es dos." .

ns1:Fallo_0036 a ns1:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en la recuperación de la herramienta activa" ;
    ns1:identificador "0036" ;
    ns1:requiereConsumible ns1:HerramientaActivaDelCNC ;
    ns1:textoExtracto "Inconsistencia en la recuperación de la herramienta activa. DETECCIÓN Durante el arranque del CNC." .

ns1:HerramientaCNC a ns1:Herramienta ;
    rdfs:label "Herramienta activa del CNC" ;
    ns1:textoExtracto "herramienta activa [recuperación en arranque]" .

ns1:ReguladorOscilo a ns1:ComponenteElectrico ;
    rdfs:label "Regulador monitorizado en osciloscopio" ;
    ns1:monitoreaParametro ns1:ParametrosMechatrolink ;
    ns1:textoExtracto "regulador [con variables traceadas en osciloscopio]" .

ns1:HerramientaActivaDelCNC a ns1:Herramienta ;
    rdfs:label "Herramienta activa del CNC" ;
    ns1:textoExtracto "herramienta activa" .

ns1:LimitarVariablesDelReguladorEnOsciloscopio a ns1:TareaMantenimiento ;
    rdfs:label "Limitar variables del regulador en osciloscopio" ;
    ns1:textoExtracto "El número máximo de variables del mismo regulador que se pueden tracear simultáneamente en el oscilo es dos." .

ns1:ParametroOVariableMechatrolink a ns1:Parametro ;
    rdfs:label "Parámetro o variable Mechatrolink" ;
    ns1:textoExtracto "parámetro o variable Mechatrolink" ;
    ns1:valor "No asignado a eje"^^xsd:string .

ns1:ParametrosMechatrolink a ns1:Parametro ;
    rdfs:label "Parámetros y variables Mechatrolink" ;
    ns1:textoExtracto "parámetros y variables Mechatrolink" ;
    ns1:valor "Asociados a eje único"^^xsd:string .

ns1:RevisarLaProgramacionDeParametrosMechatrolink a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación de parámetros Mechatrolink" ;
    ns1:textoExtracto "Revisar la programación. Los parámetros y variables Mechatrolink tienen que estar asociadas a un eje." .

ns1:VariablesDelReguladorEnOsciloscopio a ns1:Parametro ;
    rdfs:label "Variables del regulador en osciloscopio" ;
    ns1:textoExtracto "variables del mismo regulador" ;
    ns1:valor ">2"^^xsd:string .

