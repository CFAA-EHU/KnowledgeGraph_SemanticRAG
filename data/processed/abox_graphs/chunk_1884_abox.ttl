@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:textoExtracto "fallo del sistema"@es ;
    ns1:tieneComponente ns1:GestorHerramientas_CNC .

ns1:TablaHerramientas_CNC a ns1:Tabla ;
    rdfs:label "Tabla de herramientas del CNC"@es ;
    ns1:documentadoEn ns1:Manual_CNC ;
    ns1:textoExtracto "Definir en la tabla de herramientas cuál es la herramienta activa"@es .

ns1:TareaMantenimiento_0036_CorreccionHerramientaActiva a ns1:TareaMantenimiento ;
    rdfs:label "Corrección de herramienta activa (Código 0036)"@es ;
    ns1:identificador "0036" ;
    ns1:solucionaFallo ns1:Fallo_0036_InconsistenciaRecuperacionHerramientaActiva ;
    ns1:textoExtracto "Comprobar cuál es la herramienta correcta antes de continuar. Definir en la tabla de herramientas cuál es la herramienta activa, y en caso necesario, realizar un cambio de herramienta."@es .

ns1:Fallo_0036_InconsistenciaRecuperacionHerramientaActiva a ns1:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en la recuperación de la herramienta activa (0036)"@es ;
    ns1:identificador "0036" ;
    ns1:textoExtracto "Inconsistencia en la recuperación de la herramienta activa. DETECCIÓN Durante el arranque del CNC. CAUSA La información de la herramienta activa guardada en el disco no se corresponde con la guardada por el gestor de herramientas, por un mal apagado o por un fallo del sistema. El fichero que contiene estos datos no existe, no es accesible o está corrupto. SOLUCIÓN Comprobar cuál es la herramienta correcta antes de continuar. Definir en la tabla de herramientas cuál es la herramienta activa, y en caso necesario, realizar un cambio de herramienta."@es .

ns1:GestorHerramientas_CNC a ns1:Sistema ;
    rdfs:label "Gestor de herramientas del CNC"@es ;
    ns1:controla ns1:Herramienta_Activa_CNC ;
    ns1:textoExtracto "el gestor de herramientas"@es .

ns1:Herramienta_Activa_CNC a ns1:Herramienta ;
    ns1:textoExtracto "la herramienta activa guardada en el disco no se corresponde con la guardada por el gestor de herramientas"@es .

