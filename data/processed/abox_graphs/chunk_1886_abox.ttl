@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FalloDetectadoArranqueCNC a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de detección en arranque del CNC"@es ;
    ns1:solucionaFallo ns1:FalloSistemaHerramientas ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA La posición de almacén de la herramienta que está en el cabezal no se corresponde con la guardada por el gestor de herramientas, por un mal apagado o por una fallo del sistema."@es .

ns1:FicheroDatosHerramientas a ns1:InterfazUsuario ;
    rdfs:label "Fichero de datos de herramientas"@es ;
    ns1:documentadoEn ns1:ManualCNC ;
    ns1:textoExtracto "El fichero que contiene estos datos no existe, no es accesible o está corrupto."@es .

ns1:FalloSistemaHerramientas a ns1:AvisoSeguridad ;
    rdfs:label "Inconsistencia en posición de herramienta"@es ;
    ns1:mitigaRiesgo ns1:SistemaGestionHerramientas ;
    ns1:textoExtracto "La posición de almacén de la herramienta que está en el cabezal no se corresponde con la guardada por el gestor de herramientas"@es .

ns1:HerramientaCNC a ns1:Herramienta ;
    rdfs:label "Herramienta en cabezal"@es ;
    ns1:textoExtracto "herramienta que está en el cabezal"@es .

ns1:SistemaGestionHerramientas a ns1:Sistema ;
    rdfs:label "Gestor de herramientas del CNC"@es ;
    ns1:controla ns1:HerramientaCNC ;
    ns1:textoExtracto "gestor de herramientas"@es .

