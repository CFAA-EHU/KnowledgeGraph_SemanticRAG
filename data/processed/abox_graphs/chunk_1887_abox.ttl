@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FuncionM_Subrutina a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función M con subrutina asociada"@es ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:textoExtracto "función con subrutina asociada y tipo de sincronización Antes-Antes o Antes-Después"@es .

ns1:Solucion_0040 a ns1:TareaMantenimiento ;
    rdfs:label "Redefinir sincronización de función M"@es ;
    ns1:solucionaFallo ns1:Error_0040 ;
    ns1:textoExtracto "Definir la función M sin sincronización o bien con sincronización Después-Después."@es .

ns1:Solucion_FicheroCorrupto a ns1:TareaMantenimiento ;
    rdfs:label "Verificación de posición correcta y contacto con soporte técnico"@es ;
    ns1:solucionaFallo ns1:Error_FicheroCorrupto ;
    ns1:textoExtracto "Comprobar cuál es la posición correcta antes de continuar. Si el error se repite en sucesivos arranques del CNC, póngase en contacto con Fagor Automation."@es .

ns1:Error_0040 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0040: 'M Antes-Antes o Antes-Después con subrutina no admite movimientos en el bloque'"@es ;
    ns1:identificador "0040" ;
    ns1:textoExtracto "0040 'M Antes-Antes o Antes-Después con subrutina no admite movimientos en el bloque' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En la tabla de funciones M, hay una función con subrutina asociada y tipo de sincronización Antes-Antes o Antes-Después."@es .

ns1:Error_FicheroCorrupto a ns1:AvisoSeguridad ;
    rdfs:label "Error de fichero de datos de máquina corrupto o inaccesible"@es ;
    ns1:identificador "sin_código" ;
    ns1:textoExtracto "El fichero que contiene estos datos no existe, no es accesible o está corrupto."@es .

ns1:TablaFuncionesM a ns1:Tabla ;
    rdfs:label "Tabla de funciones M"@es ;
    ns1:textoExtracto "En la tabla de funciones M, hay una función con subrutina asociada y tipo de sincronización Antes-Antes o Antes-Después."@es .

