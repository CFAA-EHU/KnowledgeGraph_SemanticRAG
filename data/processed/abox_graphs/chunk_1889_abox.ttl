@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC"@es ;
    ns1:textoExtracto "la aplicación CNC"@es ;
    ns1:tieneComponente ns1:Parametro_0044 .

ns1:TareaMantenimiento_ReinicioCNC a ns1:TareaMantenimiento ;
    rdfs:label "Reinicio de aplicación CNC"@es ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_0044 ;
    ns1:textoExtracto "SOLUCIÓN Reiniciar el CNC."@es .

ns1:DiagnosticoFallo_0044 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 0044: Nombre de eje inválido"@es ;
    ns1:identificador "0044" ;
    ns1:monitoreaParametro ns1:Parametro_0044 ;
    ns1:solucionaFallo ns1:Parametro_0044 ;
    ns1:textoExtracto "0044 'Nombre de eje no válido o nombre de eje sin definir' [...] DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El parámetro máquina está sin definir o tiene un nombre de eje incorrecto. SOLUCIÓN Corregir los parámetros máquina."@es .

ns1:Parametro_0044 a ns1:Parametro ;
    rdfs:label "Parámetro de nombre de eje"@es ;
    ns1:identificador "0044" ;
    ns1:textoExtracto "'Nombre de eje no válido o nombre de eje sin definir' [...] El parámetro máquina está sin definir o tiene un nombre de eje incorrecto."@es .

