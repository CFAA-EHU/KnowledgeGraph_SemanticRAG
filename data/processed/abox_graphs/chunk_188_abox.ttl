@prefix ex: <https://vocab.cfaa.eus/broaching/>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.

ex:Conector a owl:Class ;
    rdfs:label "Conector" ;
    rdfs:comment "Clase para representar conectores en esquemas eléctricos." .

ex:Actuador a owl:Class ;
    rdfs:label "Actuador" ;
    rdfs:comment "Clase para representar actuadores en esquemas eléctricos." .

ex:Bloque a owl:Class ;
    rdfs:label "Bloque" ;
    rdfs:comment "Clase para representar bloques en esquemas eléctricos." .

