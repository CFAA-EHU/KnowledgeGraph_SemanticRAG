    rdfs:label "Relé" ;
    rdfs:comment "Clase para representar relés en esquemas eléctricos." .

ex:Latiguillo a owl:Class ;
    rdfs:label "Latiguillo" ;
    rdfs:comment "Clase para representar latiguillos en esquemas eléctricos." .

ex:Sensor a owl:Class ;
    rdfs:label "Sensor" ;
    rdfs:comment "Clase para representar sensores en esquemas eléctricos." .

ex:Pin a owl:Class ;
    rdfs:label "Pin" ;
    rdfs:comment "Clase para representar pines en esquemas eléctricos." .

