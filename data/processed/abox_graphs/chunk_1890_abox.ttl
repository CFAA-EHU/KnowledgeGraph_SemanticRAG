@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_0045 a ns1:AvisoSeguridad ;
    rdfs:label "'Nombre de cabezal no válido'" ;
    ns1:identificador "0045" ;
    ns1:mitigaRiesgo ns1:Parametro_SPDLNAME ;
    ns1:textoExtracto "0045 'Nombre de cabezal no válido' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El usuario ha definido el parámetro máquina con un nombre de cabezal incorrecto. SOLUCIÓN Corregir los parámetros máquina." .

ns1:AvisoSeguridad_0046 a ns1:AvisoSeguridad ;
    rdfs:label "'Eje inexistente'" ;
    ns1:identificador "0046" ;
    ns1:mitigaRiesgo ns1:Parametro_AXISNAME,
        ns1:Parametro_VCOMPAXIS,
        ns1:Parametro_VMOVAXIS ;
    ns1:textoExtracto "0046 'Eje inexistente' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Las posibles causas son las siguientes: • El usuario ha asignado a un parámetro máquina el nombre de un eje que no existe. • En la compensación volumétrica básica, no se ha definido uno de los ejes VMOVAXIS o VCOMPAXIS. SOLUCIÓN Corregir los parámetros máquina." .

ns1:AvisoSeguridad_0047 a ns1:AvisoSeguridad ;
    rdfs:label "'Un eje principal no puede definirse como esclavo'" ;
    ns1:identificador "0047" ;
    ns1:mitigaRiesgo ns1:Parametro_AXISNAME ;
    ns1:textoExtracto "0047 'Un eje principal no puede definirse como esclavo' DETECCIÓN Durante la validación de los parámetros máquina." .

ns1:Parametro_SPDLNAME a ns1:Parametro ;
    rdfs:label "SPDLNAME" ;
    ns1:monitoreaParametro ns1:Maquina_Generica ;
    ns1:textoExtracto "El primer carácter debe ser la letra S. El segundo carácter es opcional y será un sufijo numérico entre 1 y 9. De esta forma el nombre de los cabezales podrá ser cualquiera del rango S, S1…S9." .

ns1:Parametro_VCOMPAXIS a ns1:Parametro ;
    rdfs:label "VCOMPAXIS" ;
    ns1:monitoreaParametro ns1:Maquina_Generica ;
    ns1:textoExtracto "En la compensación volumétrica básica, no se ha definido uno de los ejes VMOVAXIS o VCOMPAXIS." .

ns1:Parametro_VMOVAXIS a ns1:Parametro ;
    rdfs:label "VMOVAXIS" ;
    ns1:monitoreaParametro ns1:Maquina_Generica ;
    ns1:textoExtracto "En la compensación volumétrica básica, no se ha definido uno de los ejes VMOVAXIS o VCOMPAXIS." .

ns1:Parametro_AXISNAME a ns1:Parametro ;
    rdfs:label "AXISNAME" ;
    ns1:monitoreaParametro ns1:Maquina_Generica ;
    ns1:textoExtracto "El primer carácter debe ser una de las letras X - Y - Z - U - V - W - A - B - C. El segundo carácter es opcional y será un sufijo numérico entre 1 y 9. De esta forma el nombre de los ejes podrá ser cualquiera del rango X, X1…X9,...C, C1…C9." .

ns1:Maquina_Generica a ns1:Maquina ;
    rdfs:label "Máquina (genérica)" ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina." ;
    ns1:tieneComponente ns1:Parametro_AXISNAME,
        ns1:Parametro_SPDLNAME,
        ns1:Parametro_VCOMPAXIS,
        ns1:Parametro_VMOVAXIS .

