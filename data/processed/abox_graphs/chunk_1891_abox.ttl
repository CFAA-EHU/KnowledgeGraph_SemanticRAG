@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_0047 a ns1:AvisoSeguridad ;
    rdfs:label "'Un eje principal no puede definirse como esclavo'" ;
    ns1:identificador "0047" ;
    ns1:mitigaRiesgo ns1:Maquina_Principal ;
    ns1:textoExtracto "0047 'Un eje principal no puede definirse como esclavo' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El eje esclavo de un eje gantry es el eje maestro de otro eje gantry." .

ns1:AvisoSeguridad_0048 a ns1:AvisoSeguridad ;
    rdfs:label "'Un eje no puede ser esclavo de varios maestros'" ;
    ns1:identificador "0048" ;
    ns1:mitigaRiesgo ns1:Maquina_Principal ;
    ns1:textoExtracto "0048 'Un eje no puede ser esclavo de varios maestros' DETECCIÓN Durante la validación de los parámetros máquina." .

ns1:Parametro_AXISNAME a ns1:Parametro ;
    rdfs:label "AXISNAME" ;
    ns1:monitoreaParametro ns1:Maquina_Principal ;
    ns1:textoExtracto "Los nombres de eje válidos son los definidos en el parámetro AXISNAME." .

ns1:Manual_0000_0999 a ns1:Manual ;
    ns1:identificador "0000-0999" ;
    ns1:textoExtracto "Sección 0000-0999 del manual técnico." .

ns1:Tabla_EjesGantry a ns1:Tabla ;
    rdfs:label "Tabla de ejes gantry" ;
    ns1:documentadoEn ns1:Manual_0000_0999 ;
    ns1:textoExtracto "Corregir la tabla de ejes gantry. El eje maestro de un eje gantry no puede ser esclavo en otro eje gantry." .

ns1:Maquina_Principal a ns1:Maquina ;
    ns1:textoExtracto "Corregir los parámetros máquina." ;
    ns1:tieneComponente ns1:Tabla_EjesGantry .

