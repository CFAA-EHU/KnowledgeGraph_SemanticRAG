@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_0048 a ns1:Alarma ;
    rdfs:label "Alarma 0048: Un eje no puede ser esclavo de varios maestros" ;
    ns1:monitoreaParametro ns1:Parametro_TablaEjesGantry ;
    ns1:textoExtracto "0048 'Un eje no puede ser esclavo de varios maestros' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El eje esclavo de un eje gantry ya está definido como eje esclavo en otro eje gantry. SOLUCIÓN Corregir la tabla de ejes gantry." .

ns1:Alarma_0049 a ns1:Alarma ;
    rdfs:label "Alarma 0049: Un eje maestro no puede ser a su vez esclavo y viceversa" ;
    ns1:monitoreaParametro ns1:Parametro_TablaEjesGantry ;
    ns1:textoExtracto "0049 'Un eje maestro no puede ser a su vez esclavo y viceversa' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El eje maestro de un eje gantry es el eje esclavo en otro eje gantry o viceversa. SOLUCIÓN Corregir la tabla de ejes gantry." .

ns1:Alarma_0050 a ns1:Alarma ;
    rdfs:label "Alarma 0050: Los ejes maestro y esclavo deben ser del mismo tipo (AXISTYPE)" ;
    ns1:monitoreaParametro ns1:Parametro_AXISTYPE ;
    ns1:textoExtracto "0050 'Los ejes maestro y esclavo deben ser del mismo tipo (AXISTYPE)' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Ambos ejes de una pareja gantry no son del mismo tipo; lineales o rotativos. SOLUCIÓN Los ejes de una pareja gantry tienen que ser del mismo tipo, lineales o rotativos (parámetro AXISTYPE)." .

ns1:Alarma_0051 a ns1:Alarma ;
    rdfs:label "Alarma 0051: Los ejes maestro y esclavo deben tener ciertos parámetros con el mismo valor" ;
    ns1:monitoreaParametro ns1:Parametro_AXISMODE,
        ns1:Parametro_CAXIS,
        ns1:Parametro_FACEAXIS,
        ns1:Parametro_LONGAXIS,
        ns1:Parametro_SHORTESTWAY ;
    ns1:textoExtracto "0051 'Los ejes maestro y esclavo deben tener ciertos parámetros con el mismo valor' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Ambos ejes de un eje gantry no tienen las mismas propiedades. SOLUCIÓN Revisar la tabla de ejes gantry y/o los siguientes parámetros máquina de los ejes." .

ns1:Manual_Maquina a ns1:Manual ;
    rdfs:label "Manual de parámetros máquina" ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina." .

ns1:Parametro_AXISMODE a ns1:Parametro ;
    rdfs:label "AXISMODE (modo de eje)" ;
    ns1:detalladoEnEsquema ns1:TablaEjesGantry ;
    ns1:textoExtracto "Los ejes lineales deben tener los parámetros AXISMODE, FACEAXIS y LONGAXIS iguales." .

ns1:Parametro_AXISTYPE a ns1:Parametro ;
    rdfs:label "AXISTYPE (tipo de eje: lineal o rotativo)" ;
    ns1:detalladoEnEsquema ns1:TablaEjesGantry ;
    ns1:textoExtracto "Los ejes de una pareja gantry tienen que ser del mismo tipo, lineales o rotativos (parámetro AXISTYPE)." .

ns1:Parametro_CAXIS a ns1:Parametro ;
    rdfs:label "CAXIS (eje de control)" ;
    ns1:detalladoEnEsquema ns1:TablaEjesGantry ;
    ns1:textoExtracto "Los ejes rotativos deben tener los parámetros AXISMODE, SHORTESTWAY y CAXIS iguales." .

ns1:Parametro_FACEAXIS a ns1:Parametro ;
    rdfs:label "FACEAXIS (eje de cara)" ;
    ns1:detalladoEnEsquema ns1:TablaEjesGantry ;
    ns1:textoExtracto "Los ejes lineales deben tener los parámetros AXISMODE, FACEAXIS y LONGAXIS iguales." .

ns1:Parametro_LONGAXIS a ns1:Parametro ;
    rdfs:label "LONGAXIS (eje longitudinal)" ;
    ns1:detalladoEnEsquema ns1:TablaEjesGantry ;
    ns1:textoExtracto "Los ejes lineales deben tener los parámetros AXISMODE, FACEAXIS y LONGAXIS iguales." .

ns1:Parametro_SHORTESTWAY a ns1:Parametro ;
    rdfs:label "SHORTESTWAY (camino más corto)" ;
    ns1:detalladoEnEsquema ns1:TablaEjesGantry ;
    ns1:textoExtracto "Los ejes rotativos deben tener los parámetros AXISMODE, SHORTESTWAY y CAXIS iguales." .

ns1:Parametro_TablaEjesGantry a ns1:Parametro ;
    rdfs:label "Parámetro de configuración de la tabla de ejes gantry" ;
    ns1:detalladoEnEsquema ns1:TablaEjesGantry ;
    ns1:textoExtracto "Revisar la tabla de ejes gantry y/o el parámetro AXISTYPE de ambos ejes." .

ns1:TablaEjesGantry a ns1:Tabla ;
    rdfs:label "Tabla de ejes gantry" ;
    ns1:documentadoEn ns1:Manual_Maquina ;
    ns1:textoExtracto "Corregir la tabla de ejes gantry." .

