@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_0052 a ns1:AvisoSeguridad ;
    rdfs:label "Diferencia de módulos demasiado pequeña" ;
    ns1:identificador "0052" ;
    ns1:monitoreaParametro ns1:Parametro_MODLOWLIM,
        ns1:Parametro_MODUPLIM ;
    ns1:textoExtracto "0052 'Diferencia de módulos demasiado pequeña' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA La diferencia entre los parámetros máquina MODUPLIM y MODLOWLIM es menor que la resolución del eje. SOLUCIÓN Comprobar la resolución del eje; si es correcta, aumentar MODUPLIM o disminuir MODLOWLIM." .

ns1:AvisoSeguridad_0053 a ns1:AvisoSeguridad ;
    rdfs:label "Parámetro MPGAXIS repetido en varios volantes" ;
    ns1:identificador "0053" ;
    ns1:monitoreaParametro ns1:Parametro_MPGAXIS ;
    ns1:textoExtracto "0053 'Parámetro MPGAXIS repetido en varios volantes' DETECCIÓN Durante la validación de los parámetros" .

ns1:Parametro_AXISMODE a ns1:Parametro ;
    rdfs:label "AXISMODE" ;
    ns1:textoExtracto "Los ejes lineales deben tener los parámetros AXISMODE, FACEAXIS y LONGAXIS iguales." .

ns1:Parametro_CAXIS a ns1:Parametro ;
    rdfs:label "CAXIS" ;
    ns1:textoExtracto "Los ejes rotativos deben tener los parámetros AXISMODE, SHORTESTWAY y CAXIS iguales." .

ns1:Parametro_FACEAXIS a ns1:Parametro ;
    rdfs:label "FACEAXIS" ;
    ns1:textoExtracto "Los ejes lineales deben tener los parámetros AXISMODE, FACEAXIS y LONGAXIS iguales." .

ns1:Parametro_LONGAXIS a ns1:Parametro ;
    rdfs:label "LONGAXIS" ;
    ns1:textoExtracto "Los ejes lineales deben tener los parámetros AXISMODE, FACEAXIS y LONGAXIS iguales." .

ns1:Parametro_SHORTESTWAY a ns1:Parametro ;
    rdfs:label "SHORTESTWAY" ;
    ns1:textoExtracto "Los ejes rotativos deben tener los parámetros AXISMODE, SHORTESTWAY y CAXIS iguales." .

ns1:Parametro_MODLOWLIM a ns1:Parametro ;
    rdfs:label "MODLOWLIM" ;
    ns1:textoExtracto "La diferencia entre los parámetros máquina MODUPLIM y MODLOWLIM es menor que la resolución del eje." .

ns1:Parametro_MODUPLIM a ns1:Parametro ;
    rdfs:label "MODUPLIM" ;
    ns1:textoExtracto "La diferencia entre los parámetros máquina MODUPLIM y MODLOWLIM es menor que la resolución del eje." .

ns1:Parametro_MPGAXIS a ns1:Parametro ;
    rdfs:label "MPGAXIS" ;
    ns1:textoExtracto "'Parámetro MPGAXIS repetido en varios volantes'." .

