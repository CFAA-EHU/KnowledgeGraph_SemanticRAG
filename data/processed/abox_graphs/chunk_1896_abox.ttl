@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ParametroJOGFEED a ns1:Parametro ;
    rdfs:label "JOGFEED" ;
    ns1:identificador "JOGFEED" ;
    ns1:solucionaFallo ns1:Diagnostico_0062 ;
    ns1:textoExtracto "El parámetro JOGFEED es superior a G00FEED."@es ;
    ns1:valor ns1:ParametroG00FEED .

ns1:ParametroJOGRAPFEED a ns1:Parametro ;
    rdfs:label "JOGRAPFEED" ;
    ns1:identificador "JOGRAPFEED" ;
    ns1:solucionaFallo ns1:Diagnostico_0061 ;
    ns1:textoExtracto "El parámetro JOGRAPFEED es superior a G00FEED."@es ;
    ns1:valor ns1:ParametroG00FEED .

ns1:ParametroMAXMANFEED a ns1:Parametro ;
    rdfs:label "MAXMANFEED" ;
    ns1:identificador "MAXMANFEED" ;
    ns1:solucionaFallo ns1:Diagnostico_0060 ;
    ns1:textoExtracto "El parámetro MAXMANFEED es superior a G00FEED."@es ;
    ns1:valor ns1:ParametroG00FEED .

ns1:TablaAlmacen a ns1:Tabla ;
    rdfs:label "Tabla del almacén"@es ;
    ns1:identificador "Almacén" ;
    ns1:requiereMantenimiento ns1:ReinicioCNC_0059 ;
    ns1:textoExtracto "'Para asumir los cambios en la tabla del almacén es necesario rearrancar el CNC'"@es .

ns1:TablaCompensacionHusillo a ns1:Tabla ;
    rdfs:label "Tabla de compensación de husillo"@es ;
    ns1:monitoreaParametro ns1:ParametroErrorHusillo ;
    ns1:textoExtracto "parámetros máquina (tabla de compensación de husillo). En las tablas de compensación de husillo, la diferencia entre dos errores consecutivos es mayor que la distancia que separa ambos puntos."@es .

ns1:TablaHMI a ns1:Tabla ;
    rdfs:label "Tabla de HMI"@es ;
    ns1:identificador "HMI" ;
    ns1:requiereMantenimiento ns1:ReinicioCNC_0058 ;
    ns1:textoExtracto "'Para asumir los cambios en la tabla de HMI es necesario rearrancar el CNC'"@es .

ns1:Diagnostico_0060 a ns1:DiagnosticoFallo ;
    rdfs:label "Velocidad manual supera velocidad máxima del eje (0060)"@es ;
    ns1:identificador "0060" ;
    ns1:textoExtracto "'La velocidad máxima de manual supera la velocidad máxima del eje' [...] SOLUCIÓN Disminuir el valor del parámetro MAXMANFEED; debe ser inferior a G00FEED."@es .

ns1:Diagnostico_0061 a ns1:DiagnosticoFallo ;
    rdfs:label "Velocidad rápida de manual supera velocidad máxima (0061)"@es ;
    ns1:identificador "0061" ;
    ns1:textoExtracto "'La velocidad rápida de manual supera la velocidad máxima del eje' [...] SOLUCIÓN Disminuir el valor del parámetro JOGRAPFEED; debe ser inferior a G00FEED."@es .

ns1:Diagnostico_0062 a ns1:DiagnosticoFallo ;
    rdfs:label "Velocidad de jog continuo supera velocidad máxima (0062)"@es ;
    ns1:identificador "0062" ;
    ns1:textoExtracto "'La velocidad de jog continuo supera la velocidad máxima del eje' [...] SOLUCIÓN Disminuir el valor del parámetro JOGFEED; debe ser inferior a G00FEED."@es .

ns1:ParametroErrorHusillo a ns1:Parametro ;
    rdfs:label "Pendiente de error en compensación de husillo"@es ;
    ns1:textoExtracto "la pendiente del error no puede ser mayor que 1"@es ;
    ns1:valor "1" .

ns1:ReinicioCNC_0058 a ns1:TareaMantenimiento ;
    rdfs:label "Reinicio de CNC para tabla HMI (0058)"@es ;
    ns1:identificador "0058" ;
    ns1:textoExtracto "SOLUCIÓN Reiniciar el CNC."@es .

ns1:ReinicioCNC_0059 a ns1:TareaMantenimiento ;
    rdfs:label "Reinicio de CNC para tabla almacén (0059)"@es ;
    ns1:identificador "0059" ;
    ns1:textoExtracto "SOLUCIÓN Reiniciar el CNC."@es .

ns1:ParametroG00FEED a ns1:Parametro ;
    rdfs:label "G00FEED" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "velocidad máxima del eje"@es .

