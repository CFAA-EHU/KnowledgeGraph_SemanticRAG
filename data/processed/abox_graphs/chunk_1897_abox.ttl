@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:diagnostico_incjogfeed a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Velocidad incremental de jog excesiva"@es ;
    ns1:monitoreaParametro ns1:parametro_G00FEED,
        ns1:parametro_INCJOGFEED ;
    ns1:solucionaFallo ns1:alarma_0063 ;
    ns1:textoExtracto "CAUSA El parámetro INCJOGFEED es superior a G00FEED."@es .

ns1:diagnostico_velocidad_jog a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Velocidad de jog incremental excesiva"@es ;
    ns1:monitoreaParametro ns1:parametro_G00FEED,
        ns1:parametro_JOGFEED ;
    ns1:solucionaFallo ns1:alarma_0063 ;
    ns1:textoExtracto "CAUSA El parámetro JOGFEED es superior a G00FEED. SOLUCIÓN Disminuir el valor del parámetro JOGFEED; debe ser inferior a G00FEED."@es .

ns1:parametro_INCJOGFEED a ns1:Parametro ;
    rdfs:label "Parámetro INCJOGFEED"@es ;
    ns1:identificador "INCJOGFEED" ;
    ns1:textoExtracto "parámetro INCJOGFEED"@es ;
    ns1:valor "valor numérico"@es .

ns1:parametro_JOGFEED a ns1:Parametro ;
    rdfs:label "Parámetro JOGFEED"@es ;
    ns1:identificador "JOGFEED" ;
    ns1:textoExtracto "parámetro JOGFEED"@es ;
    ns1:valor "valor numérico"@es .

ns1:alarma_0063 a ns1:Alarma ;
    rdfs:label "Alarma 0063: Velocidad de jog incremental"@es ;
    ns1:identificador "0063" ;
    ns1:mitigaRiesgo ns1:diagnostico_velocidad_jog ;
    ns1:textoExtracto "0063 'La velocidad de jog incremental supera la velocidad máxima del eje'"@es .

ns1:parametro_G00FEED a ns1:Parametro ;
    rdfs:label "Parámetro G00FEED"@es ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "G00FEED"@es ;
    ns1:valor "valor numérico"@es .

