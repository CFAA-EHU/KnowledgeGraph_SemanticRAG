@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_0063 a ns1:DiagnosticoFallo ;
    rdfs:label "Velocidad de jog incremental supera velocidad máxima del eje"@es ;
    ns1:identificador "0063" ;
    ns1:monitoreaParametro ns1:Parametro_G00FEED,
        ns1:Parametro_INCJOGFEED ;
    ns1:solucionaFallo ns1:ValorINCJOGFEEDG00FEED ;
    ns1:textoExtracto "'La velocidad de jog incremental supera la velocidad máxima del eje' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El parámetro INCJOGFEED es superior a G00FEED. SOLUCIÓN Disminuir el valor del parámetro INCJOGFEED; debe ser inferior a G00FEED."@es .

ns1:DiagnosticoFallo_0064 a ns1:DiagnosticoFallo ;
    rdfs:label "Ejes maestro/esclavo con I0TYPE distinto"@es ;
    ns1:identificador "0064" ;
    ns1:monitoreaParametro ns1:Parametro_I0TYPE ;
    ns1:solucionaFallo ns1:I0TYPEDesigualEnEjesGantry ;
    ns1:textoExtracto "'Los ejes maestro y esclavo deben tener el mismo I0TYPE' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA No coinciden el tipo de I0 en ambos ejes de la pareja gantry. SOLUCIÓN Ambos ejes deben tener el mismo tipo de I0 (parámetro I0TYPE)."@es .

ns1:DiagnosticoFallo_0065 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje Hirth en configuración Gantry"@es ;
    ns1:identificador "0065" ;
    ns1:monitoreaParametro ns1:Parametro_HIRTH ;
    ns1:solucionaFallo ns1:UsoDeEjeHirthEnGantry ;
    ns1:textoExtracto "'Un eje Hirth no puede ser Gantry' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Un eje hirth no puede formar parte de un eje gantry. SOLUCIÓN El eje no puede ser hirth (parámetro HIRTH). Utilizar otro tipo de eje para construir el eje gantry."@es .

ns1:DiagnosticoFallo_0066 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje Gantry con REFSHIFT ≠ 0"@es ;
    ns1:identificador "0066" ;
    ns1:monitoreaParametro ns1:Parametro_REFSHIFT ;
    ns1:solucionaFallo ns1:REFSHIFT0EnEjeGantry ;
    ns1:textoExtracto "'Un eje Gantry no puede tener REFSHIFT' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Alguno de los ejes que forman el eje gantry, en algún set de parámetros tiene definido el parámetro REFSHIFT con un valor distinto de 0. SOLUCIÓN Definir el parámetro REFSHIFT de todas las gamas con valor 0."@es .

ns1:DiagnosticoFallo_0067 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje Gantry unidireccional"@es ;
    ns1:identificador "0067" ;
    ns1:monitoreaParametro ns1:Parametro_UNIDIR ;
    ns1:solucionaFallo ns1:EjeUnidireccionalEnGantry ;
    ns1:textoExtracto "'Un eje Gantry no puede ser unidireccional' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Un eje rotativo unidireccional no puede formar parte de un eje gantry. SOLUCIÓN El eje no puede ser unidireccional (parámetro UNIDIR). Utilizar otro tipo de eje para construir el eje gantry."@es .

ns1:DiagnosticoFallo_0068 a ns1:DiagnosticoFallo ;
    rdfs:label "Orden AXISNAME incorrecto en ejes Gantry/Tandem"@es ;
    ns1:identificador "0068" ;
    ns1:textoExtracto "'Ejes Gantrys/Tandem: El esclavo no puede preceder al maestro en AXISNAME' DETECCIÓN Durante la validación de los parámetros máquina."@es .

ns1:EjeUnidireccionalEnGantry a ns1:AccionProhibida ;
    rdfs:label "Eje unidireccional en gantry"@es ;
    ns1:textoExtracto "Un eje rotativo unidireccional no puede formar parte de un eje gantry."@es .

ns1:I0TYPEDesigualEnEjesGantry a ns1:AccionProhibida ;
    rdfs:label "I0TYPE desigual en ejes gantry"@es ;
    ns1:textoExtracto "No coinciden el tipo de I0 en ambos ejes de la pareja gantry."@es .

ns1:Parametro_G00FEED a ns1:Parametro ;
    rdfs:label "G00FEED" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "parámetro G00FEED"@es .

ns1:Parametro_HIRTH a ns1:Parametro ;
    rdfs:label "HIRTH" ;
    ns1:identificador "HIRTH" ;
    ns1:textoExtracto "parámetro HIRTH"@es .

ns1:Parametro_I0TYPE a ns1:Parametro ;
    rdfs:label "I0TYPE" ;
    ns1:identificador "I0TYPE" ;
    ns1:textoExtracto "parámetro I0TYPE"@es .

ns1:Parametro_INCJOGFEED a ns1:Parametro ;
    rdfs:label "INCJOGFEED" ;
    ns1:identificador "INCJOGFEED" ;
    ns1:textoExtracto "parámetro INCJOGFEED"@es .

ns1:Parametro_REFSHIFT a ns1:Parametro ;
    rdfs:label "REFSHIFT" ;
    ns1:identificador "REFSHIFT" ;
    ns1:textoExtracto "parámetro REFSHIFT"@es .

ns1:Parametro_UNIDIR a ns1:Parametro ;
    rdfs:label "UNIDIR" ;
    ns1:identificador "UNIDIR" ;
    ns1:textoExtracto "parámetro UNIDIR"@es .

ns1:REFSHIFT0EnEjeGantry a ns1:AccionProhibida ;
    rdfs:label "REFSHIFT ≠ 0 en eje gantry"@es ;
    ns1:textoExtracto "parámetro REFSHIFT con un valor distinto de 0 en eje gantry."@es .

ns1:UsoDeEjeHirthEnGantry a ns1:AccionProhibida ;
    rdfs:label "Uso de eje Hirth en gantry"@es ;
    ns1:textoExtracto "Un eje hirth no puede formar parte de un eje gantry."@es .

ns1:ValorINCJOGFEEDG00FEED a ns1:AccionProhibida ;
    rdfs:label "Valor INCJOGFEED > G00FEED"@es ;
    ns1:textoExtracto "El parámetro INCJOGFEED es superior a G00FEED."@es .

