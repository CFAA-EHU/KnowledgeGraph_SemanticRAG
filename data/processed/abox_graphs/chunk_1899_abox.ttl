@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_0068 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0068: Ejes Gantry/Tandem - Esclavo precede a maestro"@es ;
    ns1:identificador "0068" ;
    ns1:monitoreaParametro ns1:Parametro_AXISNAME ;
    ns1:textoExtracto "0068 'Ejes Gantrys/Tandem: El esclavo no puede preceder al maestro en AXISNAME' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En las tablas de asignación de nombres de ejes (parámetro AXISNAME), el eje esclavo está definido antes del eje maestro. SOLUCIÓN Definir en la tabla el eje maestro antes que el eje esclavo o intercambiar el eje maestro y esclavo en la pareja gantry o tándem."@es .

ns1:Error_0069 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0069: Ejes Gantry - DECINPUT en esclavo sin maestro"@es ;
    ns1:identificador "0069" ;
    ns1:monitoreaParametro ns1:Parametro_DECINPUT ;
    ns1:textoExtracto "0069 'Ejes Gantry: El esclavo no puede tener DECINPUT (micro de referencia) si el maestro no lo tiene' DETECCIÓN Durante la validación de los parámetros máquina."@es .

ns1:TablaAsignacionEjes a ns1:Tabla ;
    rdfs:label "Tabla de asignación de nombres de ejes (AXISNAME)"@es ;
    ns1:documentadoEn ns1:ManualMaquina ;
    ns1:textoExtracto "tablas de asignación de nombres de ejes (parámetro AXISNAME)"@es .

ns1:ManualMaquina a ns1:Manual ;
    ns1:textoExtracto "Sección 0000-0999: Validación de parámetros máquina (páginas 5-23)"@es .

ns1:Parametro_AXISNAME a ns1:Parametro ;
    rdfs:label "Parámetro AXISNAME (asignación de nombres de ejes)"@es ;
    ns1:textoExtracto "parámetro AXISNAME [...] tablas de asignación de nombres de ejes"@es .

ns1:Parametro_DECINPUT a ns1:Parametro ;
    rdfs:label "Parámetro DECINPUT (micro de referencia)"@es ;
    ns1:textoExtracto "DECINPUT (micro de referencia)"@es .

