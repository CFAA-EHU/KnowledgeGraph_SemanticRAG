@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Armario_Electrico a ns1:ComponenteElectrico ;
    ns1:textoExtracto "Alzado frontal y lateral del armario con dimensiones principales (alto 1800 mm, ancho 1200 mm, fondo 500 mm aprox.)." ;
    ns1:valor "1200 mm",
        "1800 mm",
        "500 mm" .

ns1:Axioline a ns1:ComponenteElectrico ;
