@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_0069 a ns1:DiagnosticoFallo ;
    rdfs:label "Ejes Gantry: El esclavo no puede tener DECINPUT (micro de referencia) si el maestro no lo tiene"@es ;
    ns1:identificador "0069" ;
    ns1:monitoreaParametro ns1:Param_DECINPUT ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina. [...] SOLUCIÓN En un eje gantry podrá tener micro de referencia el eje maestro, ambos ejes o ninguno (parámetro DECINPUT)."@es .

ns1:Error_0070 a ns1:DiagnosticoFallo ;
    rdfs:label "Ejes Gantrys/Tandem: LIMIT+ y LIMIT- no pueden ser distintos en el maestro y esclavo"@es ;
    ns1:identificador "0070" ;
    ns1:monitoreaParametro ns1:Param_LIMIT ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina. [...] SOLUCIÓN Definir ambos ejes con los mismos límites de software (parámetros LIMIT+ y LIMIT-)."@es .

ns1:Error_0071 a ns1:DiagnosticoFallo ;
    rdfs:label "Vigilancia de error de seguimiento no activa en el CNC"@es ;
    ns1:identificador "0071" ;
    ns1:monitoreaParametro ns1:Param_FLWEMONITOR ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina. [...] SOLUCIÓN Activar la vigilancia del error de seguimiento en todos los sets de parámetros (parámetro FLWEMONITOR)."@es .

ns1:Error_0072 a ns1:DiagnosticoFallo ;
    rdfs:label "Alarma de captación sin activar"@es ;
    ns1:activaAlarma ns1:AlarmaCaptacion ;
    ns1:identificador "0072" ;
    ns1:monitoreaParametro ns1:Param_FBACKAL ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina. [...] SOLUCIÓN En los ejes y cabezales analógicos, activar la alarma de captación en todos los sets (parámetro FBACKAL)."@es .

ns1:AlarmaCaptacion a ns1:Alarma ;
    rdfs:label "Alarma de captación de ejes/cabezales analógicos"@es ;
    ns1:textoExtracto "alarma de captación [...] debe estar habilitada."@es .

ns1:Param_DECINPUT a ns1:Parametro ;
    rdfs:label "DECINPUT (micro de referencia)"@es ;
    ns1:identificador "DECINPUT" ;
    ns1:textoExtracto "parámetro DECINPUT"@es .

ns1:Param_FBACKAL a ns1:Parametro ;
    rdfs:label "Alarma de captación (FBACKAL)"@es ;
    ns1:identificador "FBACKAL" ;
    ns1:textoExtracto "parámetro FBACKAL"@es .

ns1:Param_FLWEMONITOR a ns1:Parametro ;
    rdfs:label "Vigilancia de error de seguimiento (FLWEMONITOR)"@es ;
    ns1:identificador "FLWEMONITOR" ;
    ns1:textoExtracto "parámetro FLWEMONITOR"@es .

ns1:Param_LIMIT a ns1:Parametro ;
    rdfs:label "Límite de software negativo (LIMIT-)"@es,
        "Límite de software positivo (LIMIT+)"@es ;
    ns1:identificador "LIMIT+",
        "LIMIT-" ;
    ns1:textoExtracto "parámetros LIMIT+ y LIMIT-"@es .

