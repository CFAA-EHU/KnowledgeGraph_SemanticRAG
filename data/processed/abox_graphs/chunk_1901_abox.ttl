@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_0074 a ns1:Alarma ;
    rdfs:label "Alarma 0074 'Test de tendencia sin activar'"@es ;
    ns1:identificador "0074" ;
    ns1:textoExtracto "0074 'Test de tendencia sin activar'"@es .

ns1:DiagnosticoFallo_0073 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 0073 (límites de software inactivos)"@es ;
    ns1:monitoreaParametro ns1:Parametro_LIMIT ;
    ns1:solucionaFallo ns1:Alarma_0073 ;
    ns1:textoExtracto "CAUSA En algún eje, los límites de software no están activados. SOLUCIÓN Definir los límites de software de todos los ejes (parámetros LIMIT+ y LIMIT-)."@es .

ns1:Maquina_Analogica a ns1:Maquina ;
    rdfs:label "Máquina con ejes y cabezales analógicos"@es ;
    ns1:activaAlarma ns1:Alarma_0073 ;
    ns1:textoExtracto "En los ejes y cabezales analógicos, activar la alarma de captación"@es ;
    ns1:tieneComponente ns1:Parametro_FBACKAL,
        ns1:Parametro_LIMIT .

ns1:Parametro_FBACKAL a ns1:Parametro ;
    rdfs:label "Parámetro FBACKAL (alarma de captación)"@es ;
    ns1:identificador "FBACKAL" ;
    ns1:textoExtracto "activar la alarma de captación en todos los sets (parámetro FBACKAL)"@es .

ns1:Alarma_0073 a ns1:Alarma ;
    rdfs:label "Alarma 0073 'Límites de soft sin activar'"@es ;
    ns1:identificador "0073" ;
    ns1:textoExtracto "0073 'Límites de soft sin activar' DETECCIÓN Durante la validación de los parámetros máquina."@es .

ns1:Parametro_LIMIT a ns1:Parametro ;
    rdfs:label "Parámetro LIMIT+ (límite de software)"@es,
        "Parámetro LIMIT- (límite de software)"@es ;
    ns1:identificador "LIMIT+",
        "LIMIT-" ;
    ns1:textoExtracto "Los parámetros LIMIT+ y LIMIT- del eje tienen ambos valor 0"@es ;
    ns1:valor "0" .

