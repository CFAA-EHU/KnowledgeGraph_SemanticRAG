@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_0078 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de canal en eje gantry"@es ;
    ns1:identificador "0078" ;
    ns1:solucionaFallo ns1:Maquina_CNC ;
    ns1:textoExtracto "Los ejes maestro y esclavo deben pertenecer al mismo canal. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Algún eje gantry está formado por ejes de canales distintos. SOLUCIÓN En un eje gantry, ambos ejes deben pertenecer al mismo canal."@es .

ns1:Fallo_0079 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje esclavo Gantry aparcado"@es ;
    ns1:identificador "0079" ;
    ns1:solucionaFallo ns1:Maquina_CNC ;
    ns1:textoExtracto "Un eje esclavo Gantry no puede estar aparcado. DETECCIÓN Durante el arranque del CNC o la validación de los parámetros máquina. CAUSA El CNC ha detectado que el eje esclavo de una pareja gantry está aparcado; la señal"@es .

ns1:Maquina_CNC a ns1:Maquina ;
    ns1:textoExtracto "validación de los parámetros máquina... arranque del CNC"@es .

