@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_CabezalSinAsignacion a ns1:DiagnosticoFallo ;
    rdfs:label "Cabezal o eje sin asignación a canal"@es ;
    ns1:textoExtracto "0084 'Un eje o cabezal no intercambiable no puede quedar sin asignar a un canal' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Hay un eje o cabezal sin permiso de intercambio que no está asignado a ningún canal."@es .

ns1:Fallo_ReguladorIncompatibleGantry a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad de reguladores en pareja gantry"@es ;
    ns1:solucionaFallo ns1:DRIVETYPE_b1986548bf ;
    ns1:textoExtracto "CAUSA Ambos ejes de una pareja gantry no tienen el mismo tipo de regulador; analógico, Sercos o Mechatrolink. SOLUCIÓN Los ejes de una pareja gantry tienen que tener el mismo tipo de regulador (parámetro DRIVETYPE)."@es .

ns1:Parametro_DRIVETYPE a ns1:Parametro ;
    rdfs:label "DRIVETYPE" ;
    ns1:identificador "DRIVETYPE" ;
    ns1:monitoreaParametro ns1:Sistema_Gantry ;
    ns1:textoExtracto "parámetro DRIVETYPE"@es .

ns1:Parametro_DeteccionValidacion a ns1:Parametro ;
    rdfs:label "Validación de parámetros máquina"@es ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina"@es .

ns1:CabezalGantry a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal gantry"@es ;
    ns1:textoExtracto "cabezal"@es .

ns1:DRIVETYPE_b1986548bf a ns1:Parametro ;
    rdfs:label "DRIVETYPE" ;
    ns1:identificador "DRIVETYPE" ;
    ns1:textoExtracto "parámetro DRIVETYPE"@es .

ns1:EjeGantry a ns1:ComponenteMecanico ;
    rdfs:label "Eje gantry"@es ;
    ns1:textoExtracto "ejes de una pareja gantry"@es .

ns1:Sistema_Gantry a ns1:Sistema ;
    rdfs:label "Sistema de pareja gantry"@es ;
    ns1:textoExtracto "ejes de una pareja gantry"@es ;
    ns1:tieneComponente ns1:CabezalGantry,
        ns1:EjeGantry .

