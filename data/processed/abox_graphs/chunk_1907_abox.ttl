@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_0087 a ns1:DiagnosticoFallo ;
    rdfs:label "Número máximo de variables DRV sobrepasado"@es ;
    ns1:identificador "0087" ;
    ns1:solucionaFallo ns1:Parametro_DRV ;
    ns1:textoExtracto "0087 'Número máximo de variables DRV sobrepasado' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En la tabla de parámetros OEM hay definidas más variables de regulador (DRV) de las permitidas. SOLUCIÓN En la tabla de parámetros OEM puede haber 100 variables de regulador."@es .

ns1:Fallo_0088 a ns1:DiagnosticoFallo ;
    rdfs:label "Traza de variables internas activada"@es ;
    ns1:identificador "0088" ;
    ns1:solucionaFallo ns1:Maquina_CNC ;
    ns1:textoExtracto "0088 'Traza de variables internas activada' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El CNC está ejecutando la traza de una variable interna. SOLUCIÓN Póngase en contacto con Fagor."@es .

ns1:Fallo_0089 a ns1:DiagnosticoFallo ;
    rdfs:label "Se arranca con un único canal debido a errores detectados en parámetros máquina"@es ;
    ns1:identificador "0089" ;
    ns1:solucionaFallo ns1:ParametrosMaquina ;
    ns1:textoExtracto "0089 'Se arranca con un único canal debido a errores detectados en parámetros máquina' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA La validación de parámetros máquina ha detectado errores o warnings relacionados con los ejes o cabezales de algún canal."@es .

ns1:Fallo_VariableDRV_NoDigital a ns1:DiagnosticoFallo ;
    rdfs:label "Variable de regulador (DRV) definida para eje no digital"@es ;
    ns1:textoExtracto "CAUSA Hay definida una variable de regulador (DRV) para un eje que no es digital (Sercos/Mechatrolink). SOLUCIÓN Eliminar la variable de ese eje."@es .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "CNC"@es ;
    ns1:textoExtracto "El CNC está ejecutando la traza de una variable interna."@es .

ns1:ParametrosMaquina a ns1:Parametro ;
    rdfs:label "Parámetros máquina"@es ;
    ns1:monitoreaParametro ns1:Parametro_DRV ;
    ns1:textoExtracto "validación de los parámetros máquina"@es .

ns1:Tabla_ParametrosOEM a ns1:Tabla ;
    rdfs:label "Tabla de parámetros OEM"@es ;
    ns1:textoExtracto "En la tabla de parámetros OEM hay definidas más variables de regulador (DRV) de las permitidas. En la tabla de parámetros OEM puede haber 100 variables de regulador."@es .

ns1:Parametro_DRV a ns1:Parametro ;
    rdfs:label "Variable de regulador (DRV)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosOEM ;
    ns1:textoExtracto "variable de regulador (DRV)"@es .

