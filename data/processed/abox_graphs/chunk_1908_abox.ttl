@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ParametrosMaquina_43 a ns1:Parametro ;
    rdfs:label "Parámetros de configuración de ejes/cabezales"@es ;
    ns1:monitoreaParametro ns1:ErrorConfiguracionEjes_43 ;
    ns1:textoExtracto "configuración de parámetros máquina"@es .

ns1:SistemaCNC_43 a ns1:Sistema ;
    rdfs:label "Sistema CNC con validación de configuración"@es ;
    ns1:textoExtracto "el CNC arranca con la configuración por defecto"@es ;
    ns1:tieneComponente ns1:EjeNoRegistrado .

ns1:ArranqueConConfiguracionDeUsuario a ns1:AccionProhibida ;
    rdfs:label "Arranque con configuración de usuario"@es ;
    ns1:textoExtracto "Al ser imposible arrancar con la configuración del usuario, el CNC arranca con la configuración por defecto."@es .

ns1:CorreccionDeParametrosMaquina a ns1:TareaMantenimiento ;
    rdfs:label "Corrección de parámetros máquina"@es ;
    ns1:textoExtracto "Corregir la configuración de parámetros máquina para eliminar el resto de errores y warnings."@es .

ns1:EjeNoRegistrado a ns1:ComponenteMecanico ;
    rdfs:label "Eje no registrado"@es ;
    ns1:textoExtracto "un canal tiene asociado un eje que no se encuentra en la lista de ejes del sistema"@es .

ns1:ErrorConfiguracionEjes_43 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de validación: eje no asociado en lista de sistema"@es ;
    ns1:solucionaFallo ns1:ArranqueConConfiguracionDeUsuario,
        ns1:CorreccionDeParametrosMaquina ;
    ns1:textoExtracto "La validación de parámetros máquina ha detectado errores o warnings relacionados con los ejes o cabezales de algún canal. Por ejemplo, un canal tiene asociado un eje que no se encuentra en la lista de ejes del sistema."@es .

