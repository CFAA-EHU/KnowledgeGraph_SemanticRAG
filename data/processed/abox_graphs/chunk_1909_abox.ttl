@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_Default a ns1:ModoOperacion ;
    rdfs:label "Configuración por defecto (arranque CNC)"@es ;
    ns1:habilitadoPor ns1:AvisoSeguridad_0090 ;
    ns1:textoExtracto "el CNC arranca con la configuración por defecto."@es .

ns1:SistemaValidacionParametros a ns1:Sistema ;
    rdfs:label "Sistema de validación de parámetros máquina"@es ;
    ns1:activaAlarma ns1:AvisoSeguridad_0090,
        ns1:AvisoSeguridad_0091,
        ns1:AvisoSeguridad_0092,
        ns1:AvisoSeguridad_0093 ;
    ns1:monitoreaParametro ns1:Parametro_AXISNAME,
        ns1:Parametro_NCHANNEL ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina."@es .

ns1:AvisoSeguridad_0091 a ns1:AvisoSeguridad ;
    rdfs:label "Warning 0091: Conflicto en identificadores DRV"@es ;
    ns1:identificador "0091" ;
    ns1:textoExtracto "0091 'Variables DRV con igual identificador (ID) no pueden tener diferente mnemónico' [...] En los parámetros máquina OEM, hay variables de regulador (DRV) que tienen el mismo identificador (ID) y diferente mnemónico."@es .

ns1:AvisoSeguridad_0092 a ns1:AvisoSeguridad ;
    rdfs:label "Warning 0092: Inconsistencia en TYPE/MODE de variables DRV"@es ;
    ns1:identificador "0092" ;
    ns1:textoExtracto "0092 'Variables DRV con igual identificador (ID) no pueden tener diferente MODE o TYPE' [...] hay variables de regulador (DRV) que tienen el mismo identificador Sercos (ID) y diferente tipo de acceso (síncrono o asíncrono) o diferente modo de acceso (lectura o escritura)."@es .

ns1:AvisoSeguridad_0093 a ns1:AvisoSeguridad ;
    rdfs:label "Warning 0093: Conflicto en mnemónicos DRV"@es ;
    ns1:identificador "0093" ;
    ns1:textoExtracto "0093 'Variables DRV con igual nombre (MNEMONIC) no pueden tener diferente ID, MODE o TYPE' [...] hay variables de regulador (DRV) que tienen el mismo mnemónico y diferente"@es .

ns1:AvisoSeguridad_0090 a ns1:AvisoSeguridad ;
    rdfs:label "Warning 0090: Configuración de ejes por defecto"@es ;
    ns1:identificador "0090" ;
    ns1:mitigaRiesgo ns1:Parametro_AXISNAME,
        ns1:Parametro_NCHANNEL ;
    ns1:textoExtracto "0090 'Se arranca con la configuración de ejes por defecto debido a errores en parámetros máquina' [...] Durante la validación de los parámetros máquina. [...] La validación de parámetros máquina ha detectado errores o warnings relacionados con los ejes o cabezales de algún canal."@es .

ns1:Parametro_AXISNAME a ns1:Parametro ;
    rdfs:label "AXISNAME (nombres de ejes)"@es ;
    ns1:textoExtracto "el número de ejes en el sistema es mayor que el número de ejes definidos en el parámetro AXISNAME."@es .

ns1:Parametro_NCHANNEL a ns1:Parametro ;
    rdfs:label "NCHANNEL (número de canales)"@es ;
    ns1:textoExtracto "el parámetro NCHANNEL (número de canales)."@es .

