@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix mecanica: <https://vocab.cfaa.eus/broaching/mecanica/> .
@prefix elec: <https://vocab.cfaa.eus/broaching/elec/> .
@prefix base: <https://vocab.cfaa.eus/broaching/base/> .

### Clases ###
ex:ArmarioEléctrico a owl:Class ;
    rdfs:label "Armario Eléctrico"@es ;
    rdfs:comment "Armario eléctrico con vistas y cotas"@es .

ex:Selector a owl:Class ;
    rdfs:label "Selector"@es .

ex:SetaDeEmergencia a owl:Class ;
    rdfs:label "Seta de Emergencia"@es .

ex:Climatizador a owl:Class ;
    rdfs:label "Climatizador"@es .

ex:Pasamuros a owl:Class ;
    rdfs:label "Pasamuros"@es .

ex:PlacaDeMontaje a owl:Class ;
    rdfs:label "Placa de Montaje"@es .

ex:Seccionador a owl:Class ;
    rdfs:label "Seccionador"@es .

ex:Contactor a owl:Class ;
    rdfs:label "Contactor"@es .

ex:FuenteSITOP a owl:Class ;
    rdfs:label "Fuente SITOP"@es .

ex:ModuloPhoenix a owl:Class ;
    rdfs:label "Módulo Phoenix"@es .

ex:Relé a owl:Class ;
    rdfs:label "Relé"@es .

ex:Pasacables a owl:Class ;
    rdfs:label "Pasacables"@es .

ex:PlacaDeCaracteristicas a owl:Class ;
    rdfs:label "Placa de Características"@es .

ex:Grafcet a owl:Class ;
    rdfs:label "Grafcet"@es .

ex:Brochadora a owl:Class ;
    rdfs:label "Brochadora"@es .

ex:MesaGiratoria a owl:Class ;
    rdfs:label "Mesa Giratoria"@es .

ex:CarroDeTracion a owl:Class ;
    rdfs:label "Carro de Tración"@es .

ex:Cepillo a owl:Class ;
    rdfs:label "Cepillo"@es .

### Propiedades de Objeto ###
mecanica:tieneElementoDeSeguridad a owl:ObjectProperty ;
    rdfs:domain ex:ArmarioEléctrico ;
    rdfs:range ex:Selector .

mecanica:tieneElementoDeSeguridad a owl:ObjectProperty ;
    rdfs:domain ex:ArmarioEléctrico ;
    rdfs:range ex:SetaDeEmergencia .

mecanica:tieneElementoDeSeguridad a owl:ObjectProperty ;
    rdfs:domain ex:ArmarioEléctrico ;
    rdfs:range ex:Climatizador .

mecanica:tieneElementoDeSeguridad a owl:ObjectProperty ;
    rdfs:domain ex:ArmarioEléctrico ;
    rdfs:range ex:Pasamuros .

mecanica:tieneDisposicion a owl:ObjectProperty ;
    rdfs:domain ex:PlacaDeMontaje ;
    rdfs:range ex:Seccionador .

mecanica:tieneDisposicion a owl:ObjectProperty ;
    rdfs:domain ex:PlacaDeMontaje ;
    rdfs:range ex:Contactor .

mecanica:tieneDisposicion a owl:ObjectProperty ;
    rdfs:domain ex:PlacaDeMontaje ;
    rdfs:range ex:FuenteSITOP .

mecanica:tieneDisposicion a owl:ObjectProperty ;
    rdfs:domain ex:PlacaDeMontaje ;
    rdfs:range ex:ModuloPhoenix .

mecanica:tieneDisposicion a owl:ObjectProperty ;
    rdfs:domain ex:PlacaDeMontaje ;
    rdfs:range ex:Relé .

mecanica:tieneDisposicion a owl:ObjectProperty ;
    rdfs:domain ex:PlacaDeMontaje ;
    rdfs:range ex:Climatizador .

mecanica:tieneDisposicion a owl:ObjectProperty ;
    rdfs:domain ex:PlacaDeMontaje ;
    rdfs:range ex:Pasacables .

elec:tieneDatosDePlaca a owl:ObjectProperty ;
    rdfs:domain ex:PlacaDeCaracteristicas ;
    rdfs:range xsd:string .

elec:tieneDatosDePlaca a owl:ObjectProperty ;
    rdfs:domain ex:PlacaDeCaracteristicas ;
    rdfs:range xsd:integer .

elec:tieneDatosDePlaca a owl:ObjectProperty ;
    rdfs:domain ex:PlacaDeCaracteristicas ;
    rdfs:range xsd:decimal .

mecanica:tieneSecuencia a owl:ObjectProperty ;
    rdfs:domain ex:Grafcet ;
    rdfs:range ex:Brochadora .

mecanica:tieneSecuencia a owl:ObjectProperty ;
    rdfs:domain ex:Grafcet ;
    rdfs:range ex:MesaGiratoria .

mecanica:tieneSecuencia a owl:ObjectProperty ;
    rdfs:domain ex:Grafcet ;
    rdfs:range ex:CarroDeTracion .

mecanica:tieneSecuencia a owl:ObjectProperty ;
    rdfs:domain ex:Grafcet ;
    rdfs:range ex:Cepillo .

### Propiedades de Datos ###
elec:tieneDatosDePlaca a owl:DatatypeProperty ;
    rdfs:domain ex:PlacaDeCaracteristicas ;
    rdfs:range xsd:string .

elec:tieneDatosDePlaca a owl:DatatypeProperty ;
    rdfs:domain ex:PlacaDeCaracteristicas ;
    rdfs:range xsd:integer .

elec:tieneDatosDePlaca a owl:DatatypeProperty ;
    rdfs:domain ex:PlacaDeCaracteristicas ;
    rdfs:range xsd:decimal .

### Anotaciones ###
ex:PlacaDeCaracteristicas rdfs:comment "Modelo A218"@es .