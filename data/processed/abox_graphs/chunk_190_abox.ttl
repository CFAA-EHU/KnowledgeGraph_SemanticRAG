@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:ArmarioElectrico_VistasYCotas a ns1:Esquema ;
    ns1:textoExtracto "Alzado frontal y lateral del armario con dimensiones principales (alto 1800 mm, ancho 1200 mm, fondo 500 mm aprox.) y ubicación de elementos exteriores (selector, seta de emergencia, climatizador, pasamuros). Cotas y símbolos de seguridad se representan con flechas y etiquetas." ;
    ns1:tieneComponente ns1:Climatizador_1,
        ns1:Pasamuros_1,
        ns1:Selector_1,
        ns1:SetaEmergencia_1 .

ns1:Grafcet_SecuenciaCiclo a ns1:Esquema ;
    ns1:textoExtracto "Diagrama de etapas/acciones numeradas (0–15) para la broachadora: origen, subir/girar/bajar mesa giratoria, movimiento del carro de tracción, avance/retroceso de cepillos y fin de ciclo. Flechas y ramas paralelas representan transiciones y condiciones; cada etapa se anota con su precondición (110.x/111.x)." .

ns1:PlacaCaracteristicas_A218 a ns1:Esquema ;
    ns1:identificador "A218" ;
    ns1:textoExtracto "control (220 V/24 V =)" .

ns1:PlacaMontaje_DisposicionEquipos a ns1:Esquema ;
    ns1:textoExtracto "Vista interior del armario con disposición y cotas entre carriles y equipos: se distinguen seccionadores, contactores, fuentes SITOP, módulos Phoenix, relés, climatizador y pasacables. Líneas de cota (mm) y rótulos de referencia (p. ej., 19A1…19A9, 27KAx) dan jerarquía y ubicación precisa." ;
    ns1:tieneComponente ns1:Climatizador_2,
        ns1:Contactor_1,
        ns1:FuenteSITOP_1,
        ns1:ModuloPhoenix_1,
        ns1:Pasacables_1,
        ns1:Rel_1,
        ns1:Seccionador_1 .

ns1:Climatizador_1 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "climatizador" .

ns1:Climatizador_2 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "climatizador" .

ns1:Contactor_1 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "contactores" .

ns1:FuenteSITOP_1 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "fuentes SITOP" .

ns1:ModuloPhoenix_1 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "módulos Phoenix" .

ns1:Pasacables_1 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "pasacables" .

ns1:Pasamuros_1 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "pasamuros" .

ns1:Rel_1 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "relés" .

ns1:Seccionador_1 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "seccionadores" .

ns1:Selector_1 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "selector" .

ns1:SetaEmergencia_1 a ns1:ElementoSeguridad ;
    ns1:textoExtracto "seta de emergencia" .

