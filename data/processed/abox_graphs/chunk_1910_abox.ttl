@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_0093 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0093: Inconsistencia en parámetros DRV (ID/TYPE/MODE)"@es ;
    ns1:identificador "0093" ;
    ns1:solucionaFallo ns1:Parametro_0093_ID,
        ns1:Parametro_0093_MODE,
        ns1:Parametro_0093_TYPE ;
    ns1:textoExtracto "diferente ID, MODE o TYPE' [...] CAUSA En los parámetros máquina OEM, hay variables de regulador (DRV) que tienen el mismo mnemónico y diferente identificador Sercos (ID), diferente tipo de acceso (síncrono o asíncrono) o diferente modo de acceso (lectura o escritura). SOLUCIÓN Las variables DRV con el mismo mnemónico deben tener el mismo identificador Sercos (parámetro ID), el mismo tipo de acceso (parámetro TYPE) y el mismo modo de acceso (parámetro MODE)."@es .

ns1:DiagnosticoFallo_0094 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0094: Todos los canales ocultos (HIDDENCH)"@es ;
    ns1:identificador "0094" ;
    ns1:solucionaFallo ns1:Parametro_0094 ;
    ns1:textoExtracto "0094 'Alguno de los canales debe tener el parámetro HIDDENCH = No' [...] CAUSA Todos los canales del sistema están definidos como ocultos. SOLUCIÓN El CNC no permite que todos los canales del sistema sean ocultos; alguno de ellos debe ser visible (parámetro HIDDENCH)."@es .

ns1:DiagnosticoFallo_0096 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0096: Configuración incorrecta de ejes tándem (DRIVETYPE/OPMODEP)"@es ;
    ns1:identificador "0096" ;
    ns1:solucionaFallo ns1:Parametro_0096_DRIVETYPE,
        ns1:Parametro_0096_OPMODEP ;
    ns1:textoExtracto "0096 Un eje tandem tiene que ser Sercos y con el mismo OPMODEP que el maestro. [...] CAUSA Los ejes de un eje tándem no son Sercos velocidad. SOLUCIÓN Ambos ejes de un eje tándem deben ser Sercos velocidad (parámetros DRIVETYPE y OPMODEP)."@es .

ns1:Sistema_ValidacionParametros a ns1:Sistema ;
    rdfs:label "Sistema de validación de parámetros máquina"@es ;
    ns1:monitoreaParametro ns1:Parametro_0093_ID,
        ns1:Parametro_0093_MODE,
        ns1:Parametro_0093_TYPE,
        ns1:Parametro_0094,
        ns1:Parametro_0096_DRIVETYPE,
        ns1:Parametro_0096_OPMODEP ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina. [...] SOLUCIÓN Las variables DRV con el mismo mnemónico deben tener el mismo identificador Sercos (parámetro ID), el mismo tipo de acceso (parámetro TYPE) y el mismo modo de acceso (parámetro MODE)."@es .

ns1:Parametro_0093_ID a ns1:Parametro ;
    rdfs:label "Parámetro ID (identificador Sercos)"@es ;
    ns1:identificador "ID" ;
    ns1:textoExtracto "Las variables DRV con el mismo mnemónico deben tener el mismo identificador Sercos (parámetro ID), el mismo tipo de acceso (parámetro TYPE) y el mismo modo de acceso (parámetro MODE)."@es .

ns1:Parametro_0093_MODE a ns1:Parametro ;
    rdfs:label "Parámetro MODE (modo de acceso)"@es ;
    ns1:identificador "MODE" ;
    ns1:textoExtracto "Las variables DRV con el mismo mnemónico deben tener [...] el mismo modo de acceso (parámetro MODE)."@es ;
    ns1:valor "lectura/escritura" .

ns1:Parametro_0093_TYPE a ns1:Parametro ;
    rdfs:label "Parámetro TYPE (tipo de acceso)"@es ;
    ns1:identificador "TYPE" ;
    ns1:textoExtracto "Las variables DRV con el mismo mnemónico deben tener [...] el mismo tipo de acceso (parámetro TYPE) [...]."@es ;
    ns1:valor "síncrono/asíncrono" .

ns1:Parametro_0094 a ns1:Parametro ;
    rdfs:label "Parámetro HIDDENCH"@es ;
    ns1:identificador "HIDDENCH" ;
    ns1:textoExtracto "'Alguno de los canales debe tener el parámetro HIDDENCH = No' [...] SOLUCIÓN El CNC no permite que todos los canales del sistema sean ocultos; alguno de ellos debe ser visible (parámetro HIDDENCH)."@es ;
    ns1:valor "No" .

ns1:Parametro_0096_DRIVETYPE a ns1:Parametro ;
    rdfs:label "Parámetro DRIVETYPE para ejes tándem"@es ;
    ns1:identificador "DRIVETYPE" ;
    ns1:textoExtracto "Los ejes de un eje tándem no son Sercos velocidad. [...] Ambos ejes de un eje tándem deben ser Sercos velocidad (parámetros DRIVETYPE y OPMODEP)."@es ;
    ns1:valor "Sercos velocidad" .

ns1:Parametro_0096_OPMODEP a ns1:Parametro ;
    rdfs:label "Parámetro OPMODEP para ejes tándem"@es ;
    ns1:identificador "OPMODEP" ;
    ns1:textoExtracto "Un eje tandem tiene que ser Sercos y con el mismo OPMODEP que el maestro. [...] Ambos ejes de un eje tándem deben ser Sercos velocidad (parámetros DRIVETYPE y OPMODEP)."@es ;
    ns1:valor "Sercos velocidad" .

