@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_0098 a ns1:Alarma ;
    rdfs:label "Error 0098: Diferencia en parámetro AXISEXCH" ;
    ns1:identificador "0098" ;
    ns1:monitoreaParametro ns1:Parametro_AXISEXCH ;
    ns1:textoExtracto "El eje maestro y el esclavo tienen diferente parámetro AXISEXCH. DETECCIÓN: Durante la validación de los parámetros máquina. CAUSA: Hay una pareja gantry o tándem cuyos ejes maestro y esclavo tienen el parámetro AXISEXCH con diferente valor. SOLUCIÓN: Asignar el mismo valor al parámetro AXISEXCH de ambos ejes." .

ns1:Alarma_0099 a ns1:Alarma ;
    rdfs:label "Error 0099: PROBEFEED demasiado alto" ;
    ns1:identificador "0099" ;
    ns1:monitoreaParametro ns1:Parametro_DECEL,
        ns1:Parametro_JERK,
        ns1:Parametro_PROBEFEED,
        ns1:Parametro_PROBERANGE ;
    ns1:textoExtracto "EL valor del PROBEFEED es demasiado alto para frenar respetando DECEL y JERK. DETECCIÓN: Durante la validación de los parámetros máquina. CAUSA: El avance máximo de palpado (parámetro PROBEFEED) es superior al avance necesario para frenar en el espacio definido en PROBERANGE, respetando los valores de aceleración y de jerk del eje. SOLUCIÓN: El valor de este parámetro debe ser inferior que el avance necesario para frenar en el espacio definido en PROBERANGE con los valores de aceleración y de jerk del eje." .

ns1:Alarma_0100 a ns1:Alarma ;
    rdfs:label "Error 0100: Variables pendientes de reporte" ;
    ns1:identificador "0100" ;
    ns1:textoExtracto "Demasiadas variables esperando ser reportadas. DETECCIÓN: Durante la ejecución. CAUSA: El número de variables modificadas en el CNC y que hay que reportar hacia el interface supera el máximo permitido. SOLUCIÓN: Si el error persiste, póngase en contacto con su proveedor." .

ns1:Alarma_0103 a ns1:Alarma ;
    rdfs:label "Error 0103: Timeout en validación de parámetros" ;
    ns1:identificador "0103" ;
    ns1:textoExtracto "Validación de parámetros máquina no finalizada (timeout). DETECCIÓN: Durante la validación de los parámetros máquina. CAUSA: La parametrización ha producido un bloqueo en la validación de parámetros máquina. SOLUCIÓN: Revisar los parámetros máquina que han provocado el bloqueo (si se conocen) o reiniciar el CNC." .

ns1:Alarma_0104 a ns1:Alarma ;
    rdfs:label "Error 0104: Timeout de comunicación" ;
    ns1:identificador "0104" ;
    ns1:textoExtracto "Time out de comunicación. DETECCIÓN: Durante la ejecución. CAUSA: El CNC no finaliza con éxito la lectura o escritura de una variable externa. SOLUCIÓN: Si el error persiste, póngase en contacto con su proveedor." .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "CNC" ;
    ns1:tieneComponente ns1:InterfazUsuario_CNC .

ns1:InterfazUsuario_CNC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de usuario del CNC" ;
    ns1:textoExtracto "interface" .

ns1:Parametro_AXISEXCH a ns1:Parametro ;
    rdfs:label "AXISEXCH" ;
    ns1:textoExtracto "parámetro AXISEXCH" .

ns1:Parametro_DECEL a ns1:Parametro ;
    rdfs:label "DECEL" ;
    ns1:textoExtracto "valores de aceleración (DECEL)" .

ns1:Parametro_JERK a ns1:Parametro ;
    rdfs:label "JERK" ;
    ns1:textoExtracto "valores de jerk (JERK)" .

ns1:Parametro_PROBEFEED a ns1:Parametro ;
    rdfs:label "PROBEFEED" ;
    ns1:textoExtracto "parámetro PROBEFEED (avance máximo de palpado)" .

ns1:Parametro_PROBERANGE a ns1:Parametro ;
    rdfs:label "PROBERANGE" ;
    ns1:textoExtracto "espacio definido en PROBERANGE" .

