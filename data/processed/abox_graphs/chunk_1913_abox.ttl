@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_0104 a ns1:Alarma ;
    rdfs:label "Time out de comunicación" ;
    ns1:identificador "0104" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_0104 ;
    ns1:textoExtracto "0104 'Time out de comunicación' DETECCIÓN Durante la ejecución. CAUSA El CNC no finaliza con éxito la lectura o escritura de una variable externa." .

ns1:Alarma_0105 a ns1:Alarma ;
    rdfs:label "Validación de parámetros bloqueada" ;
    ns1:activaAlarma ns1:AccionProhibida_ValidacionDuranteEjecucion ;
    ns1:identificador "0105" ;
    ns1:textoExtracto "0105 'No es posible validar parámetros durante la ejecución de un programa' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El usuario ha intentado validar una tabla de parámetros máquina mientras hay un programa" .

ns1:Tabla_ParametrosMaquina a ns1:Tabla ;
    rdfs:label "Tabla de parámetros máquina" ;
    ns1:documentadoEn ns1:Manual_Principal ;
    ns1:textoExtracto "tabla de parámetros máquina" .

ns1:DiagnosticoFallo_0104 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de comunicación con variable externa" ;
    ns1:solucionaFallo ns1:AccionProhibida_ValidacionDuranteEjecucion ;
    ns1:textoExtracto "El CNC no finaliza con éxito la lectura o escritura de una variable externa." .

ns1:Manual_Principal a ns1:Manual ;
    ns1:textoExtracto "Sección 0000-0999 (páginas 5-23)" .

ns1:AccionProhibida_ValidacionDuranteEjecucion a ns1:AccionProhibida ;
    rdfs:label "Validación de parámetros durante ejecución" ;
    ns1:textoExtracto "No es posible validar parámetros durante la ejecución de un programa" .

