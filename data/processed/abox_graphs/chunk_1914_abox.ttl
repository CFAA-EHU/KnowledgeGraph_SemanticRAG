@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_0106 a ns1:DiagnosticoFallo ;
    rdfs:label "Validación bloqueada por movimiento activo" ;
    ns1:monitoreaParametro ns1:Parametro_TablaParametrosMaquina ;
    ns1:solucionaFallo ns1:AvisoSeguridad_0106 ;
    ns1:textoExtracto "El usuario ha intentado validar una tabla de parámetros máquina mientras hay un cabezal o un eje en movimiento. Un eje puede estar en moviendo como consecuencia de un comando de eje independiente." .

ns1:DiagnosticoFallo_0107 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de registro de variables DRV en CNC" ;
    ns1:monitoreaParametro ns1:Parametro_VariablesDRV ;
    ns1:solucionaFallo ns1:AvisoSeguridad_0107 ;
    ns1:textoExtracto "El CNC ha generado un error al intentar registrar las variables definidas en la tabla de parámetros OEM." .

ns1:AvisoSeguridad_0106 a ns1:AvisoSeguridad ;
    rdfs:label "No es posible validar parámetros: Cabezal o eje en movimiento o en sincronización" ;
    ns1:documentadoEn ns1:Parametro_TablaParametrosMaquina ;
    ns1:identificador "0106" ;
    ns1:mitigaRiesgo ns1:ComponenteMecanico_Cabezal,
        ns1:ComponenteMecanico_Eje ;
    ns1:textoExtracto "0106 'No es posible validar parámetros: Cabezal o eje movimiento o en sincronización' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El usuario ha intentado validar una tabla de parámetros máquina mientras hay un cabezal o un eje en movimiento. Un eje puede estar en moviendo como consecuencia de un comando de eje independiente. SOLUCIÓN Detener el movimiento del eje o cabezal." .

ns1:AvisoSeguridad_0107 a ns1:AvisoSeguridad ;
    rdfs:label "Error al registrar variables DRV" ;
    ns1:documentadoEn ns1:Parametro_VariablesDRV ;
    ns1:identificador "0107" ;
    ns1:textoExtracto "0107 'Error al registrar variables DRV' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El CNC ha generado un error al intentar registrar las variables definidas en la tabla de parámetros OEM." .

ns1:ComponenteMecanico_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "hay un cabezal o un eje en movimiento" .

ns1:ComponenteMecanico_Eje a ns1:ComponenteMecanico ;
    rdfs:label "Eje" ;
    ns1:textoExtracto "hay un cabezal o un eje en movimiento" .

ns1:Parametro_TablaParametrosMaquina a ns1:Parametro ;
    rdfs:label "Tabla de parámetros máquina" ;
    ns1:textoExtracto "validar una tabla de parámetros máquina" .

ns1:Parametro_VariablesDRV a ns1:Parametro ;
    rdfs:label "Variables DRV" ;
    ns1:textoExtracto "variables definidas en la tabla de parámetros OEM" .

