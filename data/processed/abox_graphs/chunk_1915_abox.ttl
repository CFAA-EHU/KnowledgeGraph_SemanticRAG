@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Aviso_Osciloscopio a ns1:AvisoSeguridad ;
    rdfs:label "Warning de osciloscopio sin traza validada"@es ;
    ns1:textoExtracto "El warning dejará de aparecer cuando el usuario ejecute una traza en el osciloscopio."@es .

ns1:ErrorCNC_0108 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0108: Osciloscopio - Reajuste de LOOPTIME"@es ;
    ns1:identificador "0108" ;
    ns1:monitoreaParametro ns1:Parametro_LOOPTIME ;
    ns1:solucionaFallo ns1:Parametro_LOOPTIME ;
    ns1:textoExtracto "0108 'Oscilo: No es posible reajustar tiempo de muestreo con el nuevo LOOPTIME' [...] El ajuste del tiempo de muestreo de una traza del osciloscopio depende del parámetro LOOPTIME. Para que el CNC pueda realizar este ajuste necesita tener una traza del osciloscopio validada; es decir, que la traza se haya ejecutado al menos una vez."@es .

ns1:ErrorCNC_0109 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0109: Validación de parámetros con cabezal sincronizado"@es ;
    ns1:identificador "0109" ;
    ns1:textoExtracto "0109 'No es posible validar parámetros: cabezal en sincronización' [...] DETECCIÓN Durante la validación de los parámetros máquina o compilación del programa PLC."@es .

ns1:TablaParametrosOEM a ns1:Tabla ;
    rdfs:label "Tabla de parámetros OEM"@es ;
    ns1:documentadoEn ns1:Manual_Tecnico ;
    ns1:textoExtracto "CAUSA El CNC ha generado un error al intentar registrar las variables definidas en la tabla de parámetros OEM."@es .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de máquina"@es ;
    ns1:textoExtracto "0109 'No es posible validar parámetros: cabezal en sincronización'"@es .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC"@es ;
    ns1:textoExtracto "El CNC ha generado un error [...] Para que el CNC pueda realizar este ajuste [...]"@es ;
    ns1:tieneComponente ns1:Componente_Cabezal .

ns1:Parametro_LOOPTIME a ns1:Parametro ;
    rdfs:label "Parámetro LOOPTIME"@es ;
    ns1:identificador "LOOPTIME" ;
    ns1:monitoreaParametro ns1:Maquina_CNC ;
    ns1:textoExtracto "El ajuste del tiempo de muestreo [...] depende del parámetro LOOPTIME."@es .

