@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramaPLC a ns1:Sistema ;
    rdfs:label "Programa PLC"@es ;
    ns1:monitoreaParametro ns1:ParametrosPLC ;
    ns1:textoExtracto "compilación del programa PLC"@es .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC con cabezales sincronizados"@es ;
    ns1:textoExtracto "CNC con cabezales sincronizados activos"@es ;
    ns1:tieneComponente ns1:CabezalesSincronizados .

ns1:SolucionValidacionPrevia a ns1:TareaMantenimiento ;
    rdfs:label "Validación previa de parámetros PLC"@es ;
    ns1:solucionaFallo ns1:FalloSincronizacionCNC ;
    ns1:textoExtracto "La validación de parámetros o compilación del programa PLC debe ser previa a la sincronización"@es .

ns1:CabezalesSincronizados a ns1:ComponenteMecanico ;
    rdfs:label "Cabezales sincronizados"@es ;
    ns1:textoExtracto "cabezales sincronizados activos"@es .

ns1:FalloSincronizacionCNC a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo al sincronizar cabezales activos en CNC"@es ;
    ns1:identificador "CAUSA_51" ;
    ns1:textoExtracto "El CNC no admite este tipo de acciones con cabezales sincronizados activos, ya que implican un reset del sistema."@es .

ns1:ParametrosPLC a ns1:Parametro ;
    rdfs:label "Parámetros PLC para validación"@es ;
    ns1:textoExtracto "validación de parámetros o compilación del programa PLC"@es .

