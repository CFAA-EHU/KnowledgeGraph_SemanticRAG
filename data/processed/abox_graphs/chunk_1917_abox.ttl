@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_0110 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0110: 'No se pudo cargar la cinemática de usuario'" ;
    ns1:identificador "0110" ;
    ns1:textoExtracto "0110 'No se pudo cargar la cinemática de usuario' DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no encuentra el fichero c:\\FagorCNC\\drivers\\kinematic.sys (o c:\\Cnc8070\\drivers\\kinematic.sys). SOLUCIÓN Compruebe que al hacer el make de cinemática de usuario no se producen errores y que el driver kinematic.sys se genera correctamente." .

ns1:Error_0111 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0111: 'Error en la inicialización de datos de la cinemática de usuario'" ;
    ns1:identificador "0111" ;
    ns1:textoExtracto "0111 'Error en la inicialización de datos de la cinemática de usuario' DETECCIÓN Durante el arranque del CNC. CAUSA Error en la función de inicialización y carga de datos de la cinemática de usuario (UserTransforDataInit) implementada en el fichero Kin_iniData.c. SOLUCIÓN Analizar y corregir los posibles motivos por los que la función da error." .

ns1:Error_0112 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0112: 'Error en la inicialización de la cinemática de usuario'" ;
    ns1:identificador "0112" ;
    ns1:textoExtracto "0112 'Error en la inicialización de la cinemática de usuario' DETECCIÓN Al activar una cinemática de usuario. CAUSA Error en la función de inicialización de la cinemática (UserTransforInit) implementada en el fichero Kin_impl.c. SOLUCIÓN Analizar y corregir los posibles motivos por los que la función da error." .

ns1:Error_0113 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0113: 'Error en la inicialización de parámetros de la cinemática de usuario'" ;
    ns1:identificador "0113" ;
    ns1:textoExtracto "0113 'Error en la inicialización de parámetros de la cinemática de usuario' DETECCIÓN Al activar una cinemática de usuario. CAUSA Error en la función de inicialización de la cinemática (UserTransforParamInit) implementada en el fichero Kin_impl.c. SOLUCIÓN Analizar y corregir los posibles motivos por los que la función da error." .

ns1:Error_0114 a ns1:AvisoSeguridad ;
    rdfs:label "Error 0114: 'No es posible validar parámetros durante la simulación de un programa en el canal'" ;
    ns1:identificador "0114" ;
    ns1:textoExtracto "0114 No es posible validar parámetros durante la simulación de un programa en el canal. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El usuario ha intentado validar los parámetros durante la simulación de un programa. SOLUCIÓN Detener la simulación del programa para validar los parámetros." .

ns1:ParametrosMaquina a ns1:Parametro ;
    rdfs:label "Parámetros máquina" ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina." .

ns1:ProgramaPLC a ns1:Parametro ;
    rdfs:label "Programa PLC" ;
    ns1:textoExtracto "La validación de parámetros o compilación del programa PLC debe ser previa a la sincronización de cabezales." .

ns1:SimulacionPrograma a ns1:ModoOperacion ;
    rdfs:label "Simulación de programa" ;
    ns1:textoExtracto "El usuario ha intentado validar los parámetros durante la simulación de un programa." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "tipo de acciones con cabezales sincronizados activos, ya que implican un reset del sistema. SOLUCIÓN La validación de parámetros o compilación del programa PLC debe ser previa a la sincronización de cabezales, o desincronizar los cabezales momentáneamente para llevar a cabo la acción deseada." ;
    ns1:tieneComponente ns1:CabezalesSincronizados .

ns1:CabezalesSincronizados a ns1:ComponenteMecanico ;
    rdfs:label "Cabezales sincronizados" ;
    ns1:textoExtracto "tipo de acciones con cabezales sincronizados activos, ya que implican un reset del sistema." .

