@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_0115 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0115: Incoherencia en código de validación de CPU"@es ;
    ns1:identificador "0115" ;
    ns1:textoExtracto "Código de validación -tipo de CPU-, NO coherente con el"@es .

ns1:ErrorValidacion_0114 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0114: Validación de parámetros durante simulación"@es ;
    ns1:identificador "0114" ;
    ns1:solucionaFallo ns1:AccionProhibida_ValidarEnSimulacion ;
    ns1:textoExtracto "No es posible validar parámetros durante la simulación de un programa en el canal. [...] SOLUCIÓN Detener la simulación del programa para validar los parámetros."@es .

ns1:ParametroMaquina_ValidacionCPU a ns1:Parametro ;
    rdfs:label "Código de validación (tipo de CPU)"@es ;
    ns1:identificador "0115" ;
    ns1:textoExtracto "Código de validación -tipo de CPU-, NO coherente con el"@es .

ns1:AccionProhibida_ValidarEnSimulacion a ns1:AccionProhibida ;
    rdfs:label "Validar parámetros máquina durante simulación de programa"@es ;
    ns1:textoExtracto "El usuario ha intentado validar los parámetros durante la simulación de un programa."@es .

