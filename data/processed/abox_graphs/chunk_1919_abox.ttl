@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_0115 a ns1:DiagnosticoFallo ;
    rdfs:label "Código de validación -tipo de CPU- no coherente con el hardware" ;
    ns1:identificador "0115" ;
    ns1:textoExtracto "0115 Código de validación -tipo de CPU-, NO coherente con el hardware. DETECCIÓN Durante el arranque del CNC. CAUSA El tipo de CPU definido en el código de validación no es válido para ese hardware. SOLUCIÓN Póngase en contacto con Fagor para obtener un código de validación válido." .

ns1:Error_0116 a ns1:DiagnosticoFallo ;
    rdfs:label "Error al leer la tabla tecnológica" ;
    ns1:identificador "0116" ;
    ns1:solucionaFallo ns1:TablaTecnologica ;
    ns1:textoExtracto "'Error al leer la tabla tecnológica' DETECCIÓN Durante el arranque del CNC, acceso a la tabla tecnológica o ejecución del comando #TECHTABLE. CAUSA El fichero ..\\mtb\\data\\techTable\\TTDsc.xml que define la tabla o tabla no existe o no es ..\\mtb\\data\\techTable\\Material Files\\*xml con los datos de la correcto. Es posible que haya cambios en la tabla (nuevas variables, nuevos tipos enumerados) y no se ha reiniciado el CNC. SOLUCIÓN Comprobar el nombre y contenido de la tabla. Si la tabla existe, reiniciar el CNC." .

ns1:Error_0117 a ns1:DiagnosticoFallo ;
    rdfs:label "Número de cores no coherente con el hardware" ;
    ns1:identificador "0117" ;
    ns1:textoExtracto "0117 El número de cores definidos en el código de validación NO es coherente con el hardware. DETECCIÓN Durante el arranque del CNC. CAUSA El número de cores definido en el código de validación no es válido para ese hardware. SOLUCIÓN Póngase en contacto con Fagor para obtener un código de validación válido." .

ns1:Error_0118 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en hardware de SERCOS III o error en driver" ;
    ns1:identificador "0118" ;
    ns1:solucionaFallo ns1:HardwareSERCOSIII ;
    ns1:textoExtracto "0118 No hay hardware de SERCOS III o error en la carga del driver. DETECCIÓN Durante el arranque del CNC o la validación de los parámetros máquina. CAUSA El CNC no detecta el hardware asociado a Sercos III o no puede cargar el driver. SOLUCIÓN Reiniciar el CNC. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error_0119 a ns1:DiagnosticoFallo ;
    rdfs:label "Actualización de SW correcta de dispositivos PwC conectados a SERCOS3" ;
    ns1:identificador "0119" ;
    ns1:solucionaFallo ns1:DispositivosPwC ;
    ns1:textoExtracto "0119 Actualización de SW correcta de los dispositivos PwC conectados a SERCOS3 - OK. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC ha actualizado el software de los PwC. SOLUCIÓN El CNC informa de la actualización; no es necesaria ninguna acción." .

ns1:ProcesoValidacionParametros a ns1:TareaMantenimiento ;
    rdfs:label "Validación de parámetros durante simulación" ;
    ns1:textoExtracto "validar los parámetros durante la simulación de un programa. SOLUCIÓN Detener la simulación del programa para validar los parámetros." .

ns1:DispositivosPwC a ns1:ComponenteElectrico ;
    rdfs:label "Dispositivos PwC conectados a SERCOS3" ;
    ns1:textoExtracto "Actualización de SW correcta de los dispositivos PwC conectados a SERCOS3." .

ns1:HardwareSERCOSIII a ns1:ComponenteElectrico ;
    rdfs:label "Hardware de SERCOS III" ;
    ns1:textoExtracto "El CNC no detecta el hardware asociado a Sercos III o no puede cargar el driver." .

ns1:TablaTecnologica a ns1:Tabla ;
    rdfs:label "Tabla tecnológica (TTDsc.xml)" ;
    ns1:identificador "TTDsc.xml" ;
    ns1:textoExtracto "El fichero ..\\mtb\\data\\techTable\\TTDsc.xml que define la tabla o tabla no existe o no es ..\\mtb\\data\\techTable\\Material Files\\*xml con los datos de la correcto." .

