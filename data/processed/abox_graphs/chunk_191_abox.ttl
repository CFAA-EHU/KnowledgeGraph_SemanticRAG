@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix plano: <https://vocab.cfaa.eus/broaching/plano/> .
@prefix bornes: <https://vocab.cfaa.eus/broaching/bornes/> .
@prefix sistema: <https://vocab.cfaa.eus/broaching/sistema/> .
@prefix conexion: <https://vocab.cfaa.eus/broaching/conexion/> .
@prefix funcion: <https://vocab.cfaa.eus/broaching/funcion/> .
@prefix alimentacion: <https://vocab.cfaa.eus/broaching/alimentacion/> .
@prefix seguridad: <https://vocab.cfaa.eus/broaching/seguridad/> .
@prefix motor: <https://vocab.cfaa.eus/broaching/motor/> .
@prefix señal: <https://vocab.cfaa.eus/broaching/señal/> .
@prefix diagrama: <https://vocab.cfaa.eus/broaching/diagrama/> .

# Clases
plano:PlanoDeBornes a owl:Class ;
    rdfs:label "Plano de bornes" ;
    rdfs:comment "Representa un plano de bornes en el sistema de la máquina." .

bornes:Borne a owl:Class ;
    rdfs:label "Borne" ;
    rdfs:comment "Representa un borne en el plano de bornes." .

sistema:Sistema a owl:Class ;
    rdfs:label "Sistema" ;
    rdfs:comment "Representa un sistema en la máquina." .

conexion:Conexion a owl:Class ;
    rdfs:label "Conexion" ;
    rdfs:comment "Representa una conexión en el plano de bornes." .

funcion:Funcion a owl:Class ;
    rdfs:label "Funcion" ;
    rdfs:comment "Representa una función en la máquina." .

alimentacion:Alimentacion a owl:Class ;
    rdfs:label "Alimentacion" ;
    rdfs:comment "Representa una alimentación en la máquina." .

seguridad:Seguridad a owl:Class ;
    rdfs:label "Seguridad" ;
    rdfs:comment "Representa un componente de seguridad en la máquina." .

motor:Motor a owl:Class ;
    rdfs:label "Motor" ;
    rdfs:comment "Representa un motor en la máquina." .

señal:Señal a owl:Class ;
    rdfs:label "Señal" ;
    rdfs:comment "Representa una señal en la máquina." .

diagrama:Diagrama a owl:Class ;
    rdfs:label "Diagrama" ;
    rdfs:comment "Representa un diagrama en el sistema de la máquina." .

# Propiedades de objeto
plano:tieneBorne a owl:ObjectProperty ;
    rdfs:domain plano:PlanoDeBornes ;
    rdfs:range bornes:Borne ;
    rdfs:label "tieneBorne" ;
    rdfs:comment "Relaciona un plano de bornes con un borne." .

bornes:estaAsignadoA a owl:ObjectProperty ;
    rdfs:domain bornes:Borne ;
    rdfs:range sistema:Sistema ;
    rdfs:label "estaAsignadoA" ;
    rdfs:comment "Relaciona un borne con un sistema." .

bornes:estaConectadoA a owl:ObjectProperty ;
    rdfs:domain bornes:Borne ;
    rdfs:range conexion:Conexion ;
    rdfs:label "estaConectadoA" ;
    rdfs:comment "Relaciona un borne con una conexión." .

conexion:tieneFuncion a owl:ObjectProperty ;
    rdfs:domain conexion:Conexion ;
    rdfs:range funcion:Funcion ;
    rdfs:label "tieneFuncion" ;
    rdfs:comment "Relaciona una conexión con una función." .

funcion:requiereAlimentacion a owl:ObjectProperty ;
    rdfs:domain funcion:Funcion ;
    rdfs:range alimentacion:Alimentacion ;
    rdfs:label "requiereAlimentacion" ;
    rdfs:comment "Relaciona una función con una alimentación." .

alimentacion:tieneSeguridad a owl:ObjectProperty ;
    rdfs:domain alimentacion:Alimentacion ;
    rdfs:range seguridad:Seguridad ;
    rdfs:label "tieneSeguridad" ;
    rdfs:comment "Relaciona una alimentación con un componente de seguridad." .

motor:tieneSeñal a owl:ObjectProperty ;
    rdfs:domain motor:Motor ;
    rdfs:range señal:Señal ;
    rdfs:label "tieneSeñal" ;
    rdfs:comment "Relaciona un motor con una señal." .

señal:estaEnDiagrama a owl:ObjectProperty ;
    rdfs:domain señal:Señal ;
    rdfs:range diagrama:Diagrama ;
    rdfs:label "estaEnDiagrama" ;
    rdfs:comment "Relaciona una señal con un diagrama." .

# Propiedades de datos
bornes:tieneReferencia a owl:DatatypeProperty ;
    rdfs:domain bornes:Borne ;
    rdfs:range xsd:string ;
    rdfs:label "tieneReferencia" ;
    rdfs:comment "Indica la referencia de un borne." .

bornes:tieneNumero a owl:DatatypeProperty ;
    rdfs:domain bornes:Borne ;
    rdfs:range xsd:integer ;
    rdfs:label "tieneNumero" ;
    rdfs:comment "Indica el número de un borne." .

conexion:tieneEtiqueta a owl:DatatypeProperty ;
    rdfs:domain conexion:Conexion ;
    rdfs:range xsd:string ;
    rdfs:label "tieneEtiqueta" ;
    rdfs:comment "Indica la etiqueta de una conexión." .

funcion:tieneDescripcion a owl:DatatypeProperty ;
    rdfs:domain funcion:Funcion ;
    rdfs:range xsd:string ;
    rdfs:label "tieneDescripcion" ;
    rdfs:comment "Indica la descripción de una función." .

alimentacion:tieneVoltaje a owl:DatatypeProperty ;
    rdfs:domain alimentacion:Alimentacion ;
    rdfs:range xsd:decimal ;
    rdfs:label "tieneVoltaje" ;
    rdfs:comment "Indica el voltaje de una alimentación." .

seguridad:tieneTipo a owl:DatatypeProperty ;
    rdfs:domain seguridad:Seguridad ;
    rdfs:range xsd:string ;
    rdfs:label "tieneTipo" ;
    rdfs:comment "Indica el tipo de un componente de seguridad." .

motor:tieneModelo a owl:DatatypeProperty ;
    rdfs:domain motor:Motor ;
    rdfs:range xsd:string ;
    rdfs:label "tieneModelo" ;
    rdfs:comment "Indica el modelo de un motor." .

señal:tieneValor a owl:DatatypeProperty ;
    rdfs:domain señal:Señal ;
    rdfs:range xsd:decimal ;
    rdfs:label "tieneValor" ;
    rdfs:comment "Indica el valor de una señal." .

diagrama:tienePagina a owl:DatatypeProperty ;
    rdfs:domain diagrama:Diagrama ;
    rdfs:range xsd:integer ;
    rdfs:label "tienePagina" ;
    rdfs:comment "Indica la página de un diagrama." .