@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_0119 a ns1:DiagnosticoFallo ;
    rdfs:label "Actualización de SW correcta de dispositivos PwC (SERCOS3)"@es ;
    ns1:identificador "0119" ;
    ns1:solucionaFallo ns1:Componente_PwC ;
    ns1:textoExtracto "Actualización de SW correcta de los dispositivos PwC conectados a SERCOS3 - OK. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC ha actualizado el software de los PwC. SOLUCIÓN El CNC informa de la actualización; no es necesaria ninguna acción."@es .

ns1:DiagnosticoFallo_0120 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en actualización de SW de dispositivos SERCOS3"@es ;
    ns1:identificador "0120" ;
    ns1:solucionaFallo ns1:Componente_PwC ;
    ns1:textoExtracto "Error en la actualización de SW de los dispositivos conectados a SERCOS3 - FAILED. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha podido actualizar el"@es .

ns1:Sistema_SERCOS3 a ns1:Sistema ;
    rdfs:label "Sistema SERCOS3"@es ;
    ns1:textoExtracto "dispositivos conectados a SERCOS3"@es .

ns1:Componente_PwC a ns1:Componente ;
    rdfs:label "Dispositivo PwC"@es ;
    ns1:textoExtracto "dispositivos PwC conectados a SERCOS3"@es ;
    ns1:tieneComponente ns1:Sistema_SERCOS3 .

