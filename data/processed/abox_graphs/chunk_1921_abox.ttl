@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EmpresaFagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ns1:textoExtracto "Fagor Automation"@es .

ns1:Error0120 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la actualización de SW de los dispositivos conectados a SERCOS3 - FAILED"@es ;
    ns1:identificador "0120" ;
    ns1:monitoreaParametro ns1:ParametroSW_SercosIII ;
    ns1:textoExtracto "0120 Error en la actualización de SW de los dispositivos conectados a SERCOS3 - FAILED. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha podido actualizar el software de los dispositivos conectados al bus Sercos III. SOLUCIÓN El CNC informa que la actualización ha fallado. El dispositivo funciona con la versión de software anterior. Si el error se repite en sucesivos arranques del CNC, póngase en contacto con Fagor Automation."@es .

ns1:Error0121 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la actualización de SW de los dispositivos conectados a SERCOS3 - S3 connect FAILED"@es ;
    ns1:identificador "0121" ;
    ns1:monitoreaParametro ns1:ParametroSW_SercosIII ;
    ns1:textoExtracto "0121 Error en la actualización de SW de los dispositivos conectados a SERCOS3 - S3 connect FAILED. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha podido actualizar el software de los dispositivos conectados al bus Sercos III. SOLUCIÓN El CNC informa que la actualización ha fallado. El dispositivo funciona con la versión de software anterior. Si el error se repite en sucesivos arranques del CNC, póngase en contacto con Fagor Automation."@es .

ns1:Error0122 a ns1:DiagnosticoFallo ;
    rdfs:label "No es posible validar cambio de parámetro máquina"@es ;
    ns1:identificador "0122" ;
    ns1:monitoreaParametro ns1:ParametroMaquina ;
    ns1:textoExtracto "0122 No es posible validar cambio de parámetro máquina. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no puede validar los parámetros máquina porque no ha terminado de arrancar. SOLUCIÓN Esperar a que el CNC arranque para validar los parámetros máquina."@es .

ns1:Error0123 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la actualización de SW de los dispositivos conectados a SERCOS3 - Cheksum error"@es ;
    ns1:identificador "0123" ;
    ns1:monitoreaParametro ns1:ParametroSW_SercosIII ;
    ns1:textoExtracto "0123 Error en la actualización de SW de los dispositivos conectados a SERCOS3 - Cheksum error. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha podido actualizar el software de los dispositivos conectados al bus Sercos III. SOLUCIÓN El CNC informa que la actualización ha fallado. El dispositivo funciona con la versión de software anterior. Si el error se repite en sucesivos arranques del CNC, póngase en contacto con Fagor Automation."@es .

ns1:Error0124 a ns1:DiagnosticoFallo ;
    rdfs:label "El número de cores definidos en el código de validación NO es coherente con el hardware"@es ;
    ns1:identificador "0124" ;
    ns1:monitoreaParametro ns1:ParametroCores_Hardware ;
    ns1:textoExtracto "0124 El número de cores definidos en el código de validación NO es coherente con el hardware. DETECCIÓN Durante el arranque del CNC. CAUSA El número de cores definido en el código de validación no es válido para ese hardware. SOLUCIÓN Póngase en contacto con Fagor para obtener un código de validación válido."@es .

ns1:MaquinaCNC a ns1:Maquina ;
    rdfs:label "CNC"@es ;
    ns1:controla ns1:DispositivosSercosIII ;
    ns1:textoExtracto "CNC"@es ;
    ns1:tieneComponente ns1:SistemaSercosIII .

ns1:ParametroCores_Hardware a ns1:Parametro ;
    rdfs:label "Número de cores en código de validación"@es ;
    ns1:textoExtracto "número de cores definidos en el código de validación"@es .

ns1:ParametroMaquina a ns1:Parametro ;
    rdfs:label "Parámetro máquina"@es ;
    ns1:textoExtracto "parámetros máquina"@es .

ns1:SistemaSercosIII a ns1:Sistema ;
    rdfs:label "Bus SERCOS III"@es ;
    ns1:textoExtracto "dispositivos conectados al bus Sercos III"@es ;
    ns1:tieneComponente ns1:DispositivosSercosIII .

ns1:DispositivosSercosIII a ns1:ComponenteElectrico ;
    rdfs:label "Dispositivos conectados a SERCOS III"@es ;
    ns1:textoExtracto "dispositivos conectados al bus Sercos III"@es .

ns1:ParametroSW_SercosIII a ns1:Parametro ;
    rdfs:label "Parámetro de software de dispositivos SERCOS III"@es ;
    ns1:textoExtracto "software de los dispositivos conectados al bus Sercos III"@es .

