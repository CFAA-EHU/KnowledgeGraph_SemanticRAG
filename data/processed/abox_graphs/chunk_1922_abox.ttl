@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Accion_ContactoFagor a ns1:TareaMantenimiento ;
    rdfs:label "Contactar con Fagor para código de validación" ;
    ns1:solucionaFallo ns1:Fallo_ValidacionCores ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor para obtener un código de validación válido." .

ns1:Empresa_Fagor a ns1:Empresa ;
    rdfs:label "Fagor" ;
    ns1:textoExtracto "Póngase en contacto con Fagor para obtener un código de validación válido." .

ns1:Fallo_ValidacionCores a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en validación de cores" ;
    ns1:identificador "0125" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El número de cores definido en el código de validación no es válido para ese hardware." .

