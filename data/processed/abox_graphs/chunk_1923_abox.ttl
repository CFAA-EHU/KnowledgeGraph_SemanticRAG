@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Empresa_Fagor a ns1:Empresa ;
    rdfs:label "Fagor"@es ;
    ns1:textoExtracto "Póngase en contacto con Fagor para obtener un código de validación válido."@es .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ns1:textoExtracto "póngase en contacto con Fagor Automation."@es .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "CNC"@es ;
    ns1:activaAlarma ns1:Error_0125,
        ns1:Error_0126,
        ns1:Error_0127,
        ns1:Error_ValidacionHardware ;
    ns1:textoExtracto "El CNC ha encontrado datos incorrectos en el archivo que está cargando; por ejemplo, al cargar los datos de calibración no-lineal del gap (#LOAD)."@es .

ns1:Error_0125 a ns1:DiagnosticoFallo ;
    rdfs:label "Valor leído de fichero no válido"@es ;
    ns1:identificador "0125" ;
    ns1:textoExtracto "Valor leído de fichero no válido. DETECCIÓN Durante la ejecución. CAUSA El CNC ha encontrado datos incorrectos en el archivo que está cargando; por ejemplo, al cargar los datos de calibración no-lineal del gap (#LOAD). SOLUCIÓN Definir los datos correctamente. Consultar en la ventana de error los valores máximo y mínimo."@es .

ns1:Error_0126 a ns1:DiagnosticoFallo ;
    rdfs:label "Lectura/escritura de variable no finalizada (timeout)"@es ;
    ns1:identificador "0126" ;
    ns1:textoExtracto "Lectura/escritura de variable no finalizada (timeout). DETECCIÓN Durante la ejecución. CAUSA Se ha superado el tiempo mínimo de espera asignado al proceso de lectura/escritura de la variable. SOLUCIÓN Resetear el error. Si el error se repite en sucesivos arranques del CNC, póngase en contacto con Fagor Automation."@es .

ns1:Error_0127 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en grabación PLD dispositivo S3, dispositivo no válido para versión PLD"@es ;
    ns1:identificador "0127" ;
    ns1:textoExtracto "Error en grabación PLD dispositivo S3, dispositivo no válido para versión PLD. DETECCIÓN Durante el arranque del CNC."@es .

ns1:Error_ValidacionHardware a ns1:DiagnosticoFallo ;
    rdfs:label "Código de validación no válido para ese hardware"@es ;
    ns1:textoExtracto "el código de validación no es válido para ese hardware. SOLUCIÓN Póngase en contacto con Fagor para obtener un código de validación válido."@es .

