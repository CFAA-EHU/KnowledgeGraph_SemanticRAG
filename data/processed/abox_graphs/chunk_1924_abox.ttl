@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ns1:solucionaFallo ns1:Error_0127,
        ns1:Error_0128,
        ns1:Error_0129,
        ns1:Error_0130 ;
    ns1:textoExtracto "Fagor Automation"@es .

ns1:Variable_Regulador a ns1:Parametro ;
    rdfs:label "Variable de regulador"@es ;
    ns1:monitoreaParametro ns1:Parametros_DRV ;
    ns1:textoExtracto "variable de regulador que se quiere leer o escribir"@es .

ns1:Error_0127 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0127: Error en grabación PLD dispositivo S3"@es ;
    ns1:identificador "0127" ;
    ns1:textoExtracto "0127 Error en grabación PLD dispositivo S3, dispositivo no válido para versión PLD. DETECCIÓN Durante el arranque del CNC. CAUSA Alguno de los dispositivos SercosIII no es válido para esta versión de PLD. SOLUCIÓN Póngase en contacto con Fagor Automation."@es .

ns1:Error_0128 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0128: Error en grabación PLD dispositivo S3, fichero de versión PLD no válido"@es ;
    ns1:identificador "0128" ;
    ns1:textoExtracto "0128 Error en grabación PLD dispositivo S3, fichero de versión PLD no válido. DETECCIÓN Durante el arranque del CNC. CAUSA La versión de PLD del CNC no es válida para el dispositivo SercosIII. SOLUCIÓN Póngase en contacto con Fagor Automation."@es .

ns1:Error_0130 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0130: EtherCAT no disponible"@es ;
    ns1:identificador "0130" ;
    ns1:textoExtracto "0130 EtherCAT no disponible."@es .

ns1:Parametros_DRV a ns1:Parametro ;
    rdfs:label "Parámetros asociados a variables en tabla DRV"@es ;
    ns1:documentadoEn ns1:Tabla_DRV ;
    ns1:textoExtracto "los parámetros asociados a la variable en dicha tabla"@es .

ns1:Tabla_DRV a ns1:Tabla ;
    rdfs:label "Tabla DRV"@es ;
    ns1:documentadoEn ns1:Error_0129 ;
    ns1:textoExtracto "tabla DRV"@es .

ns1:Error_0129 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0129: Dispositivo inválido"@es ;
    ns1:identificador "0129" ;
    ns1:textoExtracto "0129 Dispositivo inválido. DETECCIÓN Durante la ejecución. CAUSA El dispositivo asociado a la variable de regulador que se quiere leer o escribir no es válido. SOLUCIÓN Si el error se ha generado en la lectura de una variable de la tabla DRV, repasar los parámetros asociados a la variable en dicha tabla. Si el error persiste, póngase en contacto con Fagor Automation."@es .

