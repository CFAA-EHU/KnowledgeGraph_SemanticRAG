@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_0130_EtherCAT_NoDisponible a ns1:AvisoSeguridad ;
    rdfs:label "Error 0130: EtherCAT no disponible"@es ;
    ns1:identificador "0130" ;
    ns1:solucionaFallo ns1:Solucion_ContactoFagorAutomation ;
    ns1:textoExtracto "0130 EtherCAT no disponible. DETECCIÓN Durante la ejecución. CAUSA La variable del regulador EtherCAT no se puede leer o escribir porque el bus no está operativo."@es .

ns1:Error_0131_LecturaVariableRegulador a ns1:AvisoSeguridad ;
    rdfs:label "Error 0131: Error en la lectura de variable de regulador"@es ;
    ns1:identificador "0131" ;
    ns1:solucionaFallo ns1:Solucion_ContactoFagorAutomation ;
    ns1:textoExtracto "0131 Error en la lectura de variable de regulador. DETECCIÓN Durante la ejecución. CAUSA La función de lectura de las"@es .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ns1:textoExtracto "Fagor Automation"@es .

ns1:Solucion_ContactoFagorAutomation a ns1:TareaMantenimiento ;
    rdfs:label "Contactar con Fagor Automation"@es ;
    ns1:ejecutadoPor ns1:Empresa_FagorAutomation ;
    ns1:textoExtracto "Póngase en contacto con Fagor Automation."@es .

