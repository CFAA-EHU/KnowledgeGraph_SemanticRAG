@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_0131 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0131: Error en la lectura de variable de regulador"@es ;
    ns1:identificador "0131" ;
    ns1:solucionaFallo ns1:Solucion_0131 ;
    ns1:textoExtracto "0131 Error en la lectura de variable de regulador. DETECCIÓN Durante la ejecución. CAUSA La función de lectura de las variables del regulador ha generado error. SOLUCIÓN Si el error se ha generado en la la lectura de una variable de la tabla DRV, repasar los parámetros asociados a la variable en dicha tabla. Si el error persiste, póngase en contacto con Fagor Automation."@es .

ns1:Error_0132 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0132: Error en la escritura de variable de regulador"@es ;
    ns1:identificador "0132" ;
    ns1:solucionaFallo ns1:Solucion_0132 ;
    ns1:textoExtracto "0132 Error en la escritura de variable de regulador. DETECCIÓN Durante la ejecución. CAUSA La función de escritura de las variables del regulador ha generado error. SOLUCIÓN Si el error se ha generado en la escritura de una variable de la tabla DRV, repasar los parámetros asociados a la variable en dicha tabla. Si el error persiste, póngase en contacto con Fagor Automation."@es .

ns1:Error_0150_Handle a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0150: #OPEN: handle de fichero en uso"@es ;
    ns1:identificador "0150" ;
    ns1:solucionaFallo ns1:Solucion_0150_Handle ;
    ns1:textoExtracto "0150 #OPEN: handle de fichero en uso. DETECCIÓN Durante la ejecución. CAUSA El handle de fichero indicado en la sentencia #OPEN está siendo usado por el #OPEN de otro fichero. SOLUCIÓN Utilizar un handle de fichero diferente."@es .

ns1:Error_0150_MaxFicheros a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0150: Número máximo de ficheros abiertos sobrepasado"@es ;
    ns1:identificador "0150" ;
    ns1:solucionaFallo ns1:Solucion_0150_MaxFicheros ;
    ns1:textoExtracto "0150 'Número máximo de ficheros abiertos sobrepasado' DETECCIÓN Durante la ejecución de un programa pieza con subrutinas globales. CAUSA El número de ficheros abiertos (programa principal más subrutinas externas) es superior a 20. SOLUCIÓN Reducir el número de subrutinas externas abiertas simultáneamente en el programa pieza."@es .

ns1:Error_0151_Archivo a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0151: #WRITE: texto o fichero cncWrite.txt no encontrado"@es ;
    ns1:identificador "0151" ;
    ns1:solucionaFallo ns1:Solucion_0151_Archivo ;
    ns1:textoExtracto "0151 #WRITE: texto o fichero cncWrite.txt no encontrado. DETECCIÓN Durante la ejecución. CAUSA No se encuentra el texto correspondiente al identificador programado. Es posible que no exista el archivo cncWrite.txt o que no esté definido el identificador. SOLUCIÓN Comprobar que existe el archivo cncWrite.txt y que contiene el identificador."@es .

ns1:Error_0151_Permiso a ns1:DiagnosticoFallo ;
    rdfs:label "Error 0151: Acceso de escritura denegado"@es ;
    ns1:identificador "0151" ;
    ns1:textoExtracto "0151 'Acceso de escritura denegado' DETECCIÓN Al acceder a un archivo. CAUSA El CNC ha intentado escribir en un archivo que no tiene permiso de escritura."@es .

ns1:Variable_Regulador_0132 a ns1:Parametro ;
    rdfs:label "Variable de regulador (escritura, tabla DRV)"@es ;
    ns1:textoExtracto "variable de la tabla DRV"@es .

ns1:Archivo_cncWrite a ns1:Componente ;
    rdfs:label "cncWrite.txt" ;
    ns1:textoExtracto "archivo cncWrite.txt"@es .

ns1:Solucion_0131 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de parámetros en tabla DRV para error 0131"@es ;
    ns1:requiereMantenimiento ns1:Tabla_DRV ;
    ns1:textoExtracto "repasar los parámetros asociados a la variable en dicha tabla"@es .

ns1:Solucion_0132 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de parámetros en tabla DRV para error 0132"@es ;
    ns1:requiereMantenimiento ns1:Tabla_DRV ;
    ns1:textoExtracto "repasar los parámetros asociados a la variable en dicha tabla"@es .

ns1:Solucion_0150_Handle a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de handle de fichero para error 0150"@es ;
    ns1:textoExtracto "Utilizar un handle de fichero diferente"@es .

ns1:Solucion_0150_MaxFicheros a ns1:TareaMantenimiento ;
    rdfs:label "Reducción de subrutinas externas para error 0150"@es ;
    ns1:textoExtracto "Reducir el número de subrutinas externas abiertas simultáneamente en el programa pieza"@es .

ns1:Solucion_0151_Archivo a ns1:TareaMantenimiento ;
    rdfs:label "Verificación de archivo cncWrite.txt para error 0151"@es ;
    ns1:requiereMantenimiento ns1:Archivo_cncWrite ;
    ns1:textoExtracto "Comprobar que existe el archivo cncWrite.txt y que contiene el identificador"@es .

ns1:Variable_Regulador_0131 a ns1:Parametro ;
    rdfs:label "Variable de regulador (tabla DRV)"@es ;
    ns1:textoExtracto "variable de la tabla DRV"@es .

ns1:Tabla_DRV a ns1:Tabla ;
    rdfs:label "Tabla DRV"@es ;
    ns1:monitoreaParametro ns1:Variable_Regulador_0131 ;
    ns1:textoExtracto "tabla DRV"@es .

