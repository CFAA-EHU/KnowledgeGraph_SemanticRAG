@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_0151 a ns1:DiagnosticoFallo ;
    rdfs:label "Acceso de escritura denegado" ;
    ns1:identificador "0151" ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que existe el archivo cncWrite.txt y que contiene el identificador. 0151 'Acceso de escritura denegado' DETECCIÓN Al acceder a un archivo. CAUSA El CNC ha intentado escribir en un archivo que no tiene permiso de escritura. SOLUCIÓN Dar al fichero permiso de escritura." .

ns1:Fallo_0152 a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede abrir el fichero" ;
    ns1:identificador "0152" ;
    ns1:textoExtracto "0152 'No se puede abrir el fichero' DETECCIÓN Al acceder a un archivo." .

