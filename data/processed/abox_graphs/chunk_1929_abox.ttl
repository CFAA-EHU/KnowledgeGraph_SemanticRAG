@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IdentificadorArchivo_F1aF4 a ns1:Parametro ;
    rdfs:label "Identificadores de archivo (F1-F4)"@es ;
    ns1:documentadoEn ns1:ManualProgramacionCNC ;
    ns1:textoExtracto "Los identificadores válidos son F1 a F4, y su programación es opcional."@es ;
    ns1:valor "F1-F4" .

ns1:FalloEscrituraArchivoCerrado a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo al intentar escribir en archivo no abierto"@es ;
    ns1:identificador "0158" ;
    ns1:textoExtracto "El CNC ha intentado escribir (#WRITE) en un archivo que no está abierto. [...] 0158 #WRITE necesita un #OPEN previo."@es .

ns1:ManualProgramacionCNC a ns1:Manual ;
    rdfs:label "Manual de programación CNC"@es ;
    ns1:documentadoEn ns1:Sentencia_OPEN,
        ns1:Sentencia_WRITE ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:Sentencia_OPEN a ns1:Parametro ;
    rdfs:label "Sentencia #OPEN"@es ;
    ns1:identificador "#OPEN" ;
    ns1:textoExtracto "#WRITE necesita un #OPEN previo."@es .

ns1:Sentencia_WRITE a ns1:Parametro ;
    rdfs:label "Sentencia #WRITE"@es ;
    ns1:identificador "#WRITE" ;
    ns1:monitoreaParametro ns1:FalloEscrituraArchivoCerrado ;
    ns1:textoExtracto "0158 #WRITE necesita un #OPEN previo."@es .

