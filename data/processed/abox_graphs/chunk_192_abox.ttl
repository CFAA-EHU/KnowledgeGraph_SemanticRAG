@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PlanoConexionesXT1 a ns1:Esquema ;
    rdfs:label "Plano de conexiones — XT1" ;
    ns1:detalladoEnEsquema ns1:XT1 ;
    ns1:textoExtracto "Último tramo de XT1 con salidas A20–A37 (desbloqueos de puertas, columna luminosa, marcha ciclo, reset drives, enable, etc.) y entradas E00–E17."@es .

ns1:PlanoConexionesXT1_3 a ns1:Esquema ;
    rdfs:label "Plano de conexiones — XT1.3" ;
    ns1:detalladoEnEsquema ns1:XT1_3 ;
    ns1:textoExtracto "Bloque XT1.3 para entradas E26–E57 y analógicas E80–E86, incluyendo señales de estado (feedback frenos, setup, enable puertas), proceso (presencia de papel, niveles, caudal, mesa) y safety."@es .

ns1:PlanoConexionesXT2_XTP1 a ns1:Esquema ;
    rdfs:label "Plano de conexiones — XT2 y XTP1" ;
    ns1:detalladoEnEsquema ns1:XT2,
        ns1:XTP1 ;
    ns1:textoExtracto "Bloques de bornes XT2 y XTP1 con asignaciones a 1204 (tensión 24 V) y enlaces T0M20/T1M21."@es .

ns1:XT1 a ns1:ComponenteElectrico ;
    rdfs:label "XT1" ;
    ns1:compuestoPor ns1:XT1_A20_A37,
        ns1:XT1_E00_E17 ;
    ns1:identificador "XT1" ;
    ns1:textoExtracto "Último tramo de XT1 con salidas A20–A37 (desbloqueos de puertas, columna luminosa, marcha ciclo, reset drives, enable, etc.) y entradas E00–E17."@es .

ns1:XT1_3 a ns1:ComponenteElectrico ;
    rdfs:label "XT1.3" ;
    ns1:compuestoPor ns1:XT1_3_E26_E57,
        ns1:XT1_3_E80_E86 ;
    ns1:identificador "XT1.3" ;
    ns1:textoExtracto "Bloque XT1.3 para entradas E26–E57 y analógicas E80–E86, incluyendo señales de estado (feedback frenos, setup, enable puertas), proceso (presencia de papel, niveles, caudal, mesa) y safety."@es .

ns1:XT1_3_E26_E57 a ns1:ComponenteElectrico ;
    ns1:identificador "E26–E57" ;
    ns1:textoExtracto "Bloque XT1.3 para entradas E26–E57"@es .

ns1:XT1_3_E80_E86 a ns1:ComponenteElectrico ;
    ns1:identificador "E80–E86" ;
    ns1:textoExtracto "Bloque XT1.3 para ... analógicas E80–E86"@es .

ns1:XT1_A20_A37 a ns1:ComponenteElectrico ;
    ns1:identificador "A20–A37" ;
    ns1:textoExtracto "Último tramo de XT1 con salidas A20–A37 (desbloqueos de puertas, columna luminosa, marcha ciclo, reset drives, enable, etc.)"@es .

ns1:XT1_E00_E17 a ns1:ComponenteElectrico ;
    ns1:identificador "E00–E17" ;
    ns1:textoExtracto "Último tramo de XT1 con ... entradas E00–E17."@es .

ns1:XT2 a ns1:ComponenteElectrico ;
    rdfs:label "XT2" ;
    ns1:compuestoPor ns1:XT2_1204 ;
    ns1:identificador "XT2" ;
    ns1:textoExtracto "Bloques de bornes XT2 y XTP1 con asignaciones a 1204 (tensión 24 V) y enlaces T0M20/T1M21."@es .

ns1:XT2_1204 a ns1:ComponenteElectrico ;
    ns1:identificador "1204" ;
    ns1:textoExtracto "Bloques de bornes XT2 y XTP1 con asignaciones a 1204 (tensión 24 V)"@es .

ns1:XTP1 a ns1:ComponenteElectrico ;
    rdfs:label "XTP1" ;
    ns1:compuestoPor ns1:XTP1_T0M20,
        ns1:XTP1_T1M21 ;
    ns1:identificador "XTP1" ;
    ns1:textoExtracto "Bloques de bornes XT2 y XTP1 con asignaciones a 1204 (tensión 24 V) y enlaces T0M20/T1M21."@es .

ns1:XTP1_T0M20 a ns1:ComponenteElectrico ;
    ns1:identificador "T0M20" ;
    ns1:textoExtracto "Bloques de bornes XT2 y XTP1 ... enlaces T0M20/T1M21."@es .

ns1:XTP1_T1M21 a ns1:ComponenteElectrico ;
    ns1:identificador "T1M21" ;
    ns1:textoExtracto "Bloques de bornes XT2 y XTP1 ... enlaces T0M20/T1M21."@es .

