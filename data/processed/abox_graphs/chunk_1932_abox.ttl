@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Comando_D a ns1:Parametro ;
    ns1:textoExtracto "Abrir un archivo con el comando \"D\" (DELETE). El CNC borra el archivo y crea uno nuevo en el formato especificado en el comando TYPE." .

ns1:Comando_MUTED a ns1:Parametro ;
    ns1:textoExtracto "Para continuar con la ejecución sin dar error, utilizar el comando \"MUTED\"." .

ns1:Comando_OPEN a ns1:Parametro ;
    ns1:textoExtracto "La sentencia #OPEN está programada para mostrar este error." .

ns1:Comando_TYPE a ns1:Parametro ;
    ns1:textoExtracto "TYPE debe coincidir con el formato del archivo. Si el archivo no existe, el CNC crea uno nuevo en el formato especificado en el comando TYPE." .

ns1:Error_0163 a ns1:DiagnosticoFallo ;
    ns1:textoExtracto "0163 #OPEN:El fichero o path indicado no existe. DETECCIÓN Durante la ejecución. CAUSA La sentencia #OPEN ha comprobado que el archivo no existe (comando \"R\"). SOLUCIÓN La sentencia #OPEN está programada para mostrar este error. Para continuar con la ejecución sin dar error, utilizar el comando \"MUTED\"." .

ns1:Error_RT_IT_Overflow a ns1:DiagnosticoFallo ;
    ns1:textoExtracto "0165 'RT IT Overflow' DETECCIÓN Durante el funcionamiento del CNC. CAUSA Las interrupciones de tiempo real superan el tiempo permitido. Algunas posibles causas pueden ser la instalación de algún dispositivo, driver o aplicación incompatible con el CNC. SOLUCIÓN Si el error se repite con frecuencia, puede ser necesario ajustar el parámetro LOOPTIME." .

ns1:Parametro_LOOPTIME a ns1:Parametro ;
    ns1:textoExtracto "Si el error se repite con frecuencia, puede ser necesario ajustar el parámetro LOOPTIME." .

