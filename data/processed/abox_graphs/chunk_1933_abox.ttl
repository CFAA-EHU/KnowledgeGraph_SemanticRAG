@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_0169 a ns1:DiagnosticoFallo ;
    rdfs:label "Sobrepasada temperatura de seguridad" ;
    ns1:identificador "0169" ;
    ns1:textoExtracto "0169 Sobrepasada temperatura de seguridad." .

ns1:Solucion_AjusteLOOPTIME a ns1:TareaMantenimiento ;
    rdfs:label "Ajustar parámetro LOOPTIME" ;
    ns1:solucionaFallo ns1:Error_0166,
        ns1:Error_0168 ;
    ns1:textoExtracto "Ajustar el parámetro LOOPTIME." .

ns1:Solucion_ContactoFabricante a ns1:TareaMantenimiento ;
    rdfs:label "Contactar con fabricante" ;
    ns1:solucionaFallo ns1:Error_0166 ;
    ns1:textoExtracto "Póngase en contacto con el fabricante de la máquina." .

ns1:Solucion_ContactoProveedor a ns1:TareaMantenimiento ;
    rdfs:label "Contactar con proveedor" ;
    ns1:solucionaFallo ns1:Error_0166,
        ns1:Error_0167 ;
    ns1:textoExtracto "Póngase en contacto con su proveedor." .

ns1:Solucion_ReinicioCNC a ns1:TareaMantenimiento ;
    rdfs:label "Reiniciar el CNC" ;
    ns1:solucionaFallo ns1:Error_0167 ;
    ns1:textoExtracto "Reiniciar el CNC." .

ns1:Parametro_JerckLimite a ns1:Parametro ;
    rdfs:label "Límite de jerk" ;
    ns1:textoExtracto "El eje está sobrepasando su límite de jerk permitido." .

ns1:Parametro_LOOPTIME a ns1:Parametro ;
    rdfs:label "LOOPTIME" ;
    ns1:solucionaFallo ns1:Error_0166,
        ns1:Error_0168 ;
    ns1:textoExtracto "Ajustar el parámetro LOOPTIME." .

ns1:Error_0167 a ns1:DiagnosticoFallo ;
    rdfs:label "No RT IT" ;
    ns1:identificador "0167" ;
    ns1:textoExtracto "0167 'No RT IT' DETECCIÓN Durante el funcionamiento del CNC. CAUSA No entra la interrupción de tiempo real." .

ns1:Error_0168 a ns1:DiagnosticoFallo ;
    rdfs:label "Position Loop Overflow" ;
    ns1:identificador "0168" ;
    ns1:monitoreaParametro ns1:Parametro_LOOPTIME ;
    ns1:textoExtracto "0168 Position Loop Overflow. DETECCIÓN Durante el funcionamiento del CNC. CAUSA El tiempo del lazo de posición de los ejes Sercos supera el tiempo permitido." .

ns1:Error_0166 a ns1:DiagnosticoFallo ;
    rdfs:label "Límite de jerk sobrepasado" ;
    ns1:identificador "0166" ;
    ns1:monitoreaParametro ns1:Parametro_JerckLimite ;
    ns1:textoExtracto "0166 'Límite de jerk sobrepasado' DETECCIÓN Durante la ejecución de un programa pieza. CAUSA El eje está sobrepasando su límite de jerk permitido." .

