@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:alarma_0171_looptime a ns1:Alarma ;
    rdfs:label "Sobrepasamiento del LOOPTIME (Código 0171)"@es ;
    ns1:identificador "0171" ;
    ns1:monitoreaParametro ns1:param_looptime ;
    ns1:textoExtracto "0171 'Sobrepasamiento del LOOPTIME' [...] Las interrupciones de tiempo real superan el tiempo permitido."@es .

ns1:diagnostico_0170_bateria a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para tensión de pila baja (Código 0170)"@es ;
    ns1:solucionaFallo ns1:alarma_0170_bateria_baja ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con el fabricante para cambiar la pila."@es .

ns1:diagnostico_0170_overtemp a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para sobretemperatura (OVERTEMP)"@es ;
    ns1:solucionaFallo ns1:alarma_0170_overtemp ;
    ns1:textoExtracto "SOLUCIÓN Respetar las dimensiones recomendadas para el habitáculo y las distancia mínima recomendada entre las paredes del habitáculo y la unidad central. En caso necesario, instalar ventiladores para airear el habitáculo."@es .

ns1:diagnostico_0172_ventilador a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para ventilador de CPU parado (Código 0172)"@es ;
    ns1:solucionaFallo ns1:alarma_0172_ventilador_cpu ;
    ns1:textoExtracto "Contactar con el SAT."@es .

ns1:sistema_refrigeracion_cnc a ns1:Sistema ;
    rdfs:label "Sistema de refrigeración del hardware del CNC"@es ;
    ns1:textoExtracto "La causa del aumento de temperatura puede ser un fallo en el **sistema de refrigeración del hardware**"@es ;
    ns1:tieneComponente ns1:ventilador_cpu .

ns1:alarma_0170_bateria_baja a ns1:Alarma ;
    rdfs:label "Tensión de pila baja (Código 0170)"@es ;
    ns1:identificador "0170" ;
    ns1:monitoreaParametro ns1:param_tension_pila ;
    ns1:textoExtracto "0170 'Tensión de pila baja' [...] La pila está descargada; ha terminado su ciclo de vida útil."@es .

ns1:alarma_0170_overtemp a ns1:Alarma ;
    rdfs:label "Aviso de sobretemperatura (OVERTEMP)"@es ;
    ns1:identificador "OVERTEMP" ;
    ns1:monitoreaParametro ns1:param_temperatura_ambiente ;
    ns1:textoExtracto "El CNC realiza cada minuto un chequeo de la temperatura ambiente del equipo; si en tres muestras seguidas la temperatura supera los 60ºC (140ºF), el CNC muestra este aviso y activa la marca OVERTEMP. [...] El warning muestra la temperatura actual."@es .

ns1:alarma_0172_ventilador_cpu a ns1:Alarma ;
    rdfs:label "Ventilador de la CPU parado (Código 0172)"@es ;
    ns1:activaAlarma ns1:sensor_ventilador_cpu ;
    ns1:identificador "0172" ;
    ns1:textoExtracto "0172 Ventilador de la cpu parado. Riesgo de sobretemperatura. [...] El CNC ha detectado que el ventilador de la CPU está parado."@es .

ns1:param_estado_ventilador_cpu a ns1:Parametro ;
    rdfs:label "Estado del ventilador de la CPU"@es ;
    ns1:textoExtracto "vigila que dicho ventilador esté en marcha"@es .

ns1:param_looptime a ns1:Parametro ;
    rdfs:label "Parámetro LOOPTIME"@es ;
    ns1:textoExtracto "ajustar el parámetro LOOPTIME"@es .

ns1:param_temperatura_ambiente a ns1:Parametro ;
    rdfs:label "Temperatura ambiente del equipo"@es ;
    ns1:textoExtracto "temperatura ambiente del equipo; si en tres muestras seguidas la temperatura supera los 60ºC (140ºF)"@es ;
    ns1:valor 60 .

ns1:param_tension_pila a ns1:Parametro ;
    rdfs:label "Tensión de la pila del CNC"@es ;
    ns1:textoExtracto "El CNC chequea la tensión de la pila en el proceso de arranque y en cada reset."@es .

ns1:sensor_ventilador_cpu a ns1:Sensor ;
    rdfs:label "Sensor de estado del ventilador de la CPU"@es ;
    ns1:monitoreaParametro ns1:param_estado_ventilador_cpu ;
    ns1:textoExtracto "el CNC [...] monitoriza y vigila que dicho ventilador esté en marcha"@es .

ns1:ventilador_cpu a ns1:ComponenteElectrico ;
    rdfs:label "Ventilador de la CPU"@es ;
    ns1:textoExtracto "ventilador de la CPU [...] monitoriza y vigila que dicho ventilador esté en marcha"@es .

