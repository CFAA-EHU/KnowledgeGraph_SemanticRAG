@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Diagnostico_FalloVentilador_CPU a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Fallo en ventilador de CPU"@es ;
    ns1:solucionaFallo ns1:Error_71_Sobretemperatura_CPU ;
    ns1:textoExtracto "El CNC ha detectado que el ventilador de la CPU está parado"@es .

ns1:Sistema_Monitorizacion_CNC a ns1:Sistema ;
    rdfs:label "Sistema de monitorización del CNC"@es ;
    ns1:activaAlarma ns1:Error_71_Sobretemperatura_CPU ;
    ns1:controla ns1:Ventilador_CPU ;
    ns1:monitoreaParametro ns1:Parametro_Temperatura_CPU ;
    ns1:textoExtracto "el CNC [...] monitoriza y vigila que dicho ventilador esté en marcha. Dicho testeo se realizará cada minuto"@es .

ns1:Ventilador_CPU a ns1:ComponenteElectrico ;
    rdfs:label "Ventilador de la CPU"@es ;
    ns1:monitoreaParametro ns1:Parametro_Temperatura_CPU ;
    ns1:textoExtracto "ventilador de la CPU"@es .

ns1:Error_71_Sobretemperatura_CPU a ns1:AvisoSeguridad ;
    rdfs:label "Riesgo de sobretemperatura del equipo (ventilador CPU parado)"@es ;
    ns1:identificador "71" ;
    ns1:textoExtracto "Riesgo de sobretemperatura del equipo. El CNC ha detectado que el ventilador de la CPU está parado."@es .

ns1:Parametro_Temperatura_CPU a ns1:Parametro ;
    rdfs:label "Temperatura de la CPU"@es ;
    ns1:textoExtracto "vigilancia de temperatura"@es ;
    ns1:valor "monitorizado cada minuto"@es .

