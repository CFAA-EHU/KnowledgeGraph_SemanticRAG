@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlarmaBateriaEmergencia_0201 a ns1:Alarma ;
    rdfs:label "Corte en la red. PC alimentado con batería" ;
    ns1:identificador "0201" ;
    ns1:textoExtracto "DETECCIÓN Al leer el estado de la batería. CAUSA Hay un corte en la alimentación del CNC y la batería de emergencia está alimentado el CNC." .

ns1:BateriaEmergencia a ns1:ComponenteElectrico ;
    rdfs:label "Batería de emergencia" ;
    ns1:alimenta ns1:CNC ;
    ns1:textoExtracto "la batería de emergencia está alimentado el CNC" .

ns1:FalloConexionVcompciD_0200 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de conexión CNC-VcompciD" ;
    ns1:identificador "0200" ;
    ns1:textoExtracto "CAUSA El CNC no se puede conectar con VcompciD. SOLUCIÓN Póngase en contacto con su proveedor." .

ns1:CNC a ns1:Sistema ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "el CNC no se puede conectar con VcompciD" .

