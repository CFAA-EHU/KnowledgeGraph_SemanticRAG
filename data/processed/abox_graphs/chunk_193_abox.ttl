@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:EstructuraCasillas a owl:Class ;
    rdfs:label "Estructura de casillas alineadas por hilera" ;
    rdfs:comment "Representa físicamente cada posición de borne y su destino, útil para montaje y verificación de cableado." .

ex:LaminaIdentificacion a owl:Class ;
    rdfs:label "Lámina de identificación del manual" ;
    rdfs:comment "Contiene el logotipo del fabricante, denominación de la máquina y datos de contacto. Diseño limpio con bloques de texto centrados, actuando como carátula final del dossier técnico." .

ex:BrochadoraElectromecanicaDeExteriores a owl:Class ;
    rdfs:label "BROCHADORA ELECTROMECÁNICA DE EXTERIORES — A218/ RASHEM 7×3000×500" ;
    rdfs:comment "Modelo A218 / RASHEM - 7x3000x500" .

ex:CaratulaFinal a owl:Class ;
    rdfs:label "Carátula final del dossier técnico" ;
    rdfs:comment "Actúa como carátula final del dossier técnico." .

ex:LogotipoFabricante a owl:Class ;
    rdfs:label "Logotipo del fabricante" .

ex:DenominacionMaquina a owl:Class ;
    rdfs:label "Denominación de la máquina" .

ex:DatosContacto a owl:Class ;
    rdfs:label "Datos de contacto" .

ex:BloqueTexto a owl:Class ;
    rdfs:label "Bloque de texto" ;
    rdfs:comment "Diseño limpio con bloques de texto centrados." .