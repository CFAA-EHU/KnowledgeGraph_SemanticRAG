@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_0252 a ns1:Alarma ;
    rdfs:label "Variable inexistente sin un material activo" ;
    ns1:identificador "0252" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Se ha intentado leer el nombre del material activo y no hay ninguno. SOLUCIÓN Activar un material desde las tablas tecnológicas." .

ns1:Alarma_0253 a ns1:Alarma ;
    rdfs:label "COMPID no válido" ;
    ns1:identificador "0253" ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El parámetro COMPID de la cinemática tiene que ser menor que 7 y no puede haber más de una cinemática con el mismo COMPID. SOLUCIÓN Revisar el parámetro COMPID." .

ns1:Alarma_CompensacionVolumetricaInexistente a ns1:Alarma ;
    rdfs:label "Compensación volumétrica inexistente" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El PLC ha intentado activar una compensación volumétrica que no existe. SOLUCIÓN Comprobar que está activa la opción de software asociada a la compensación volumétrica. Comprobar la lista de compensaciones volumétricas definidas (parámetro VOLCOMPn)." .

ns1:AvisoSeguridad_ValidacionParametros a ns1:AvisoSeguridad ;
    rdfs:label "Validación de parámetros máquina" ;
    ns1:textoExtracto "DETECCIÓN Durante la **validación de los parámetros máquina**." .

ns1:InterfazUsuario_TablasTecnologicas a ns1:InterfazUsuario ;
    rdfs:label "Tablas tecnológicas de materiales" ;
    ns1:textoExtracto "Activar un material desde las **tablas tecnológicas**." .

ns1:Parametro_VOLCOMPn a ns1:Parametro ;
    rdfs:label "Lista de compensaciones volumétricas definidas" ;
    ns1:identificador "VOLCOMPn" ;
    ns1:textoExtracto "Comprobar la lista de compensaciones volumétricas definidas (parámetro VOLCOMPn)." .

ns1:Sistema_Cinematica a ns1:Sistema ;
    rdfs:label "Sistema de cinemática de la máquina" ;
    ns1:textoExtracto "El parámetro COMPID de la **cinemática** tiene que ser menor que 7 y no puede haber más de una cinemática con el mismo COMPID." ;
    ns1:tieneComponente ns1:Parametro_COMPID .

ns1:Parametro_COMPID a ns1:Parametro ;
    rdfs:label "Identificador de cinemática" ;
    ns1:identificador "COMPID" ;
    ns1:textoExtracto "El parámetro COMPID de la cinemática tiene que ser menor que 7 y no puede haber más de una cinemática con el mismo COMPID." ;
    ns1:valor "Menor que 7" .

