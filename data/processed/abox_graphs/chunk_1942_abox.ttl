ns1:Fallo_1007 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1007: Función programada requiere eje principal no existente" ;
    ns1:identificador "1007" ;
    ns1:textoExtracto "1007 'La función programada requiere algún eje principal no existente' DETECCIÓN Durante la ejecución. CAUSA La función programada necesita uno o dos ejes principales y estos no existen o están aparcados." .

ns1:Fallo_1008 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1008: Coordenadas fuera de rango" ;
    ns1:identificador "1008" ;
    ns1:textoExtracto "1008 'Coordenadas fuera de rango' DETECCIÓN Durante la ejecución." .

