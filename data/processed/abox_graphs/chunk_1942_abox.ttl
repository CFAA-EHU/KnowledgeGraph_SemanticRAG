ns1:Parametro_DeteccionColisiones a ns1:Parametro ;
    rdfs:label "Detección de colisiones (#CD)" ;
    ns1:textoExtracto "También hacen falta los dos ejes del plano principal para activar la detección de colisiones (#CD) y para la función G20 cuando la detección de colisiones está activa." ;
    ns1:valor "#CD" .

ns1:Sentencia_CALL_AX a ns1:Parametro ;
    rdfs:label "Sentencia #CALL AX/#SET AX" ;
    ns1:textoExtracto "Recuperar mediante la sentencia #CALL AX/#SET AX el eje que falta." ;
    ns1:valor "#CALL AX/#SET AX" .

ns1:Sentencia_UNPARK a ns1:Parametro ;
    rdfs:label "Sentencia #UNPARK" ;
    ns1:textoExtracto "Desaparcar el eje (#UNPARK)." ;
    ns1:valor "#UNPARK" .

ns1:Tarea_RevisionProgramacion_1007 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación para fallo 1007" ;
    ns1:solucionaFallo ns1:Fallo_1007 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:Tarea_RevisionProgramacion_1008 a ns1:TareaMantenimiento ;
