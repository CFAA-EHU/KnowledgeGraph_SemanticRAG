@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Fallo_1010 a ns1:DiagnosticoFallo ;
    rdfs:label "'Programar G4 K'" ;
    ns1:identificador "1010" ;
    ns1:solucionaFallo ns1:Parametro_G4_TiempoEspera ;
    ns1:textoExtracto "En el mismo bloque, la función G4 tiene programado dos veces el tiempo de espera, directamente con un número y con el parámetro K. SOLUCIÓN Programar una única vez el tiempo de espera de la función G4."@es .

ns1:Fallo_1011 a ns1:DiagnosticoFallo ;
    rdfs:label "'G4: tiempo de espera fuera de rango'" ;
    ns1:identificador "1011" ;
    ns1:solucionaFallo ns1:Parametro_G4_TiempoEspera ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El tiempo de espera programado en la función G4 es demasiado grande. SOLUCIÓN El máximo valor admisible para el tiempo de espera es 2147483646."@es .

ns1:Fallo_1012 a ns1:DiagnosticoFallo ;
    rdfs:label "'G4: no es posible programar el tiempo de espera con K'" ;
    ns1:identificador "1012" ;
    ns1:solucionaFallo ns1:Parametro_G4_TiempoEspera ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La letra K va asociada al tercer eje del canal y en este caso no existe tercer eje. SOLUCIÓN Si no se desea tener tercer eje en el canal se puede programar el tiempo de espera directamente con un número."@es .

ns1:Fallo_1013 a ns1:DiagnosticoFallo ;
    rdfs:label "'G4: no se admite tiempo de espera negativo'" ;
    ns1:identificador "1013" ;
    ns1:solucionaFallo ns1:Parametro_G4_TiempoEspera ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El tiempo de espera en la función G4 es negativo. SOLUCIÓN Programar un valor mayor o igual que cero."@es .

ns1:Fallo_1014 a ns1:DiagnosticoFallo ;
    rdfs:label "'No se admite programación en diámetros con imagen espejo en el eje frontal'" ;
    ns1:identificador "1014" ;
    ns1:solucionaFallo ns1:Parametro_FACEAXIS ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El eje frontal (parámetro FACEAXIS) no puede tener activa la imagen espejo y la programación en diámetros simultáneamente. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1015 a ns1:DiagnosticoFallo ;
    rdfs:label "'Coordenadas del centro fuera de rango'" ;
    ns1:identificador "1015" ;
    ns1:solucionaFallo ns1:Parametro_InterpolacionCircular_I,
        ns1:Parametro_InterpolacionCircular_J,
        ns1:Parametro_InterpolacionCircular_K ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Uno de los valores I, J, K es demasiado alto como el centro de una interpolación circular o centro de un giro del sistema de coordenadas. SOLUCIÓN Programar un valor menor."@es .

ns1:Parametro_FACEAXIS a ns1:Parametro ;
    rdfs:label "Eje frontal (FACEAXIS)" ;
    ns1:textoExtracto "El eje frontal (parámetro FACEAXIS) no puede tener activa la imagen espejo y la programación en diámetros simultáneamente."@es .

ns1:Parametro_InterpolacionCircular_I a ns1:Parametro ;
    rdfs:label "Valor I (centro de interpolación circular)" ;
    ns1:textoExtracto "Uno de los valores I, J, K es demasiado alto como el centro de una interpolación circular o centro de un giro del sistema de coordenadas."@es .

ns1:Parametro_InterpolacionCircular_J a ns1:Parametro ;
    rdfs:label "Valor J (centro de interpolación circular)" ;
    ns1:textoExtracto "Uno de los valores I, J, K es demasiado alto como el centro de una interpolación circular o centro de un giro del sistema de coordenadas."@es .

ns1:Parametro_InterpolacionCircular_K a ns1:Parametro ;
    rdfs:label "Valor K (centro de interpolación circular)" ;
    ns1:textoExtracto "Uno de los valores I, J, K es demasiado alto como el centro de una interpolación circular o centro de un giro del sistema de coordenadas."@es .

ns1:Parametro_G4_TiempoEspera a ns1:Parametro ;
    rdfs:label "Tiempo de espera de la función G4" ;
    ns1:textoExtracto "la función G4 tiene programado dos veces el tiempo de espera, directamente con un número y con el parámetro K. [...] Programar la función G4 de la forma G4 <time> ó G4 K<time>, donde el parámetro <time> será el tiempo de espera, en segundos."@es ;
    ns1:valor 2147483646 .

