@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoProgramacionDiametros a ns1:ModoOperacion ;
    rdfs:label "Modo de programación en diámetros (G90)" ;
    ns1:activaAlarma ns1:Alarma_1016 ;
    ns1:textoExtracto "programación en diámetros" .

ns1:SistemaCoordenadas a ns1:Sistema ;
    rdfs:label "Sistema de coordenadas de la máquina" ;
    ns1:activaAlarma ns1:Alarma_1015 ;
    ns1:monitoreaParametro ns1:Parametro_I,
        ns1:Parametro_J,
        ns1:Parametro_K ;
    ns1:textoExtracto "centro de un giro del sistema de coordenadas" .

ns1:Alarma_1015 a ns1:Alarma ;
    rdfs:label "Alarma 1015: Coordenadas del centro fuera de rango" ;
    ns1:identificador "1015" ;
    ns1:textoExtracto "'Coordenadas del centro fuera de rango' DETECCIÓN Durante la ejecución. CAUSA Uno de los valores I, J, K es demasiado alto como el centro de una interpolación circular o centro de un giro del sistema de coordenadas. SOLUCIÓN Programar un valor menor." .

ns1:Alarma_1016 a ns1:Alarma ;
    rdfs:label "Alarma 1016: No se admiten valores negativos en la programación de un eje en diámetros" ;
    ns1:identificador "1016" ;
    ns1:textoExtracto "'No se admiten valores negativos en la programación de un eje en diámetros' DETECCIÓN Durante la ejecución. CAUSA No es posible programar cotas negativas en coordenadas absolutas (G90) y la programación en diámetros" .

ns1:Parametro_I a ns1:Parametro ;
    rdfs:label "Parámetro I (coordenada circular)" ;
    ns1:textoExtracto "Uno de los valores I, J, K es demasiado alto como el centro de una interpolación circular" .

ns1:Parametro_J a ns1:Parametro ;
    rdfs:label "Parámetro J (coordenada circular)" ;
    ns1:textoExtracto "Uno de los valores I, J, K es demasiado alto como el centro de una interpolación circular" .

ns1:Parametro_K a ns1:Parametro ;
    rdfs:label "Parámetro K (coordenada circular)" ;
    ns1:textoExtracto "Uno de los valores I, J, K es demasiado alto como el centro de una interpolación circular" .

