@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1023 a ns1:DiagnosticoFallo ;
    rdfs:label "Número de gama no válido" ;
    ns1:identificador "1023" ;
    ns1:solucionaFallo ns1:Parametro_NPARSETS ;
    ns1:textoExtracto "1023 'Número de gama no válido' DETECCIÓN Durante la ejecución. CAUSA El número de gama (set) del eje es incorrecto." .

ns1:Fallo_1024 a ns1:DiagnosticoFallo ;
    rdfs:label "Número de gama fuera de rango" ;
    ns1:identificador "1024" ;
    ns1:solucionaFallo ns1:Parametro_NPARSETS ;
    ns1:textoExtracto "1024 'Número de gama fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El número de gama (set) del eje es demasiado alto." .

ns1:Maquina_Eje a ns1:Maquina ;
    rdfs:label "Eje de la máquina" ;
    ns1:monitoreaParametro ns1:Parametro_AC_Forward,
        ns1:Parametro_NPARSETS ;
    ns1:textoExtracto "El número de gama (set) del eje es incorrecto." .

ns1:Parametro_AC_Forward a ns1:Parametro ;
    rdfs:label "Porcentaje de feed forward (AC forward)" ;
    ns1:textoExtracto "El porcentaje de feed forward o AC forward debe ser mayor que cero y menor que 120." ;
    ns1:valor "0 < AC forward < 120" .

ns1:Parametro_NPARSETS a ns1:Parametro ;
    rdfs:label "Parámetro máquina NPARSETS" ;
    ns1:textoExtracto "La gama (set) programada para el eje debe ser mayor que cero y menor o igual que el parámetro máquina NPARSETS del eje." ;
    ns1:valor "0 < gama ≤ NPARSETS" .

