@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1024 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1024: Número de gama fuera de rango"@es ;
    ns1:identificador "1024" ;
    ns1:solucionaFallo ns1:Parametro_NPARSETS ;
    ns1:textoExtracto "1024 'Número de gama fuera de rango' [...] SOLUCIÓN La gama (set) programada para el eje debe ser mayor que cero y menor o igual que el parámetro máquina NPARSETS del eje"@es .

ns1:DiagnosticoFallo_1025 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1025: Distancia programada igual a cero"@es ;
    ns1:identificador "1025" ;
    ns1:textoExtracto "1025 'Distancia programada igual a cero' [...] SOLUCIÓN Revisar la programación"@es .

ns1:DiagnosticoFallo_1026 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1026: Trayectoria circular incorrecta con el radio programado"@es ;
    ns1:identificador "1026" ;
    ns1:textoExtracto "1026 'Trayectoria circular incorrecta con el radio programado' [...] SOLUCIÓN Revisar la programación"@es .

ns1:DiagnosticoFallo_1027 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1027: Punto inicial y final de trayectoria circular idénticos"@es ;
    ns1:identificador "1027" ;
    ns1:textoExtracto "1027 'Punto inicial y final de trayectoria circular idénticos (infinitas soluciones)' [...] SOLUCIÓN Revisar la programación"@es .

ns1:DiagnosticoFallo_1028 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1028: Diferencia entre el centro programado y el calculado demasiado grande"@es ;
    ns1:identificador "1028" ;
    ns1:solucionaFallo ns1:Parametro_CIRINERR,
        ns1:Parametro_CIRINFACT ;
    ns1:textoExtracto "1028 'Diferencia entre el centro programado y el calculado demasiado grande' [...] SOLUCIÓN Revisar la programación"@es .

ns1:DiagnosticoFallo_1029 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1029: Radio nulo en trayectoria circular"@es ;
    ns1:identificador "1029" ;
    ns1:textoExtracto "1029 'Radio nulo en trayectoria circular' [...] SOLUCIÓN El radio de una interpolación circular no puede ser nulo"@es .

ns1:DiagnosticoFallo_1030 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1030: #AXIS programado sin G200/201/202"@es ;
    ns1:identificador "1030" ;
    ns1:textoExtracto "1030 '#AXIS programado sin G200/201/202' DETECCIÓN Durante la ejecución"@es .

ns1:Funcion_G200 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G200"@es ;
    ns1:identificador "G200" ;
    ns1:textoExtracto "#AXIS programado sin G200/201/202"@es .

ns1:Funcion_G201 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G201"@es ;
    ns1:identificador "G201" ;
    ns1:textoExtracto "#AXIS programado sin G200/201/202"@es .

ns1:Funcion_G202 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G202"@es ;
    ns1:identificador "G202" ;
    ns1:textoExtracto "#AXIS programado sin G200/201/202"@es .

ns1:Funcion_G264 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G264 (interpolación circular)"@es ;
    ns1:identificador "G264" ;
    ns1:textoExtracto "Con la función G264 activa, ambas coordenadas del centro son cero"@es .

ns1:Funcion_G265 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G265 (interpolación circular)"@es ;
    ns1:identificador "G265" ;
    ns1:textoExtracto "Con la función G265 activa, la diferencia entre radio inicial y final supera los parámetros máquina CIRINERR y CIRINFACT"@es .

ns1:Funcion_G63 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G63 (bloque de movimiento)"@es ;
    ns1:identificador "G63" ;
    ns1:textoExtracto "Movimiento nulo en el bloque de G63"@es .

ns1:Parametro_CIRINERR a ns1:Parametro ;
    rdfs:label "Parámetro máquina CIRINERR"@es ;
    ns1:identificador "CIRINERR" ;
    ns1:textoExtracto "la diferencia entre radio inicial y final supera los parámetros máquina CIRINERR y CIRINFACT"@es .

ns1:Parametro_CIRINFACT a ns1:Parametro ;
    rdfs:label "Parámetro máquina CIRINFACT"@es ;
    ns1:identificador "CIRINFACT" ;
    ns1:textoExtracto "la diferencia entre radio inicial y final supera los parámetros máquina CIRINERR y CIRINFACT"@es .

ns1:Parametro_NPARSETS a ns1:Parametro ;
    rdfs:label "Parámetro máquina NPARSETS"@es ;
    ns1:identificador "NPARSETS" ;
    ns1:textoExtracto "mayor que cero y menor o igual que el parámetro máquina NPARSETS del eje"@es .

