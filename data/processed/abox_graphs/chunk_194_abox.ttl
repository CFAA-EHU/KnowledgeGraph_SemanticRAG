@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_MonitorYTeclado a ns1:InterfazUsuario ;
    rdfs:label "Monitor & Keyboard Interface" ;
    ns1:ilustradoEn ns1:Manual_DescripcionInterfaz ;
    ns1:textoExtracto "Function keys. Softkeys. F1 Keys F1 through F12 select the options of the softkey menus. Browsing keys. NEXT key. NEXT OEM configurable table. FOCUS key. FOCUS It is used to switch between the different windows of the screen. BACK key. BACK On the horizontal softkey menu, it may be used to go from a softkey submenu up to the previous menu. Help key. HELP key. HELP Display CNC help." ;
    ns1:tieneComponente ns1:Tecla_BACK,
        ns1:Tecla_CALC,
        ns1:Tecla_DEL,
        ns1:Tecla_ENTER,
        ns1:Tecla_ESC,
        ns1:Tecla_F1,
        ns1:Tecla_FOCUS,
        ns1:Tecla_HELP,
        ns1:Tecla_INS,
        ns1:Tecla_NEXT,
        ns1:Tecla_RECALL .

ns1:ModoOperacion_Automatico a ns1:ModoOperacion ;
    rdfs:label "Automatic Mode" ;
    ns1:identificador "AUTO" ;
    ns1:textoExtracto "Automatic mode. AUTO" .

ns1:ModoOperacion_EDISIMU a ns1:ModoOperacion ;
    rdfs:label "EDISIMU Mode" ;
    ns1:identificador "EDIT" ;
    ns1:textoExtracto "EDISIMU mode. EDIT" .

ns1:ModoOperacion_Jog a ns1:ModoOperacion ;
    rdfs:label "Jog Mode" ;
    ns1:identificador "MANUAL" ;
    ns1:textoExtracto "Jog mode. MANUAL" .

ns1:ModoOperacion_MDI_MDA a ns1:ModoOperacion ;
    rdfs:label "MDI/MDA Mode" ;
    ns1:identificador "MDI" ;
    ns1:textoExtracto "MDI/MDA mode. MDI" .

ns1:ModoOperacion_Personalizable a ns1:ModoOperacion ;
    rdfs:label "Configurable Mode" ;
    ns1:identificador "CUSTOM" ;
    ns1:textoExtracto "Configurable mode. CUSTOM" .

ns1:ModoOperacion_Utilidades a ns1:ModoOperacion ;
    rdfs:label "Utilities Mode" ;
    ns1:identificador "UTILITIES" ;
    ns1:textoExtracto "Utilities mode. UTILITIES" .

ns1:Manual_DescripcionInterfaz a ns1:Manual ;
    rdfs:label "Monitor & Keyboard Description" ;
    ns1:textoExtracto "DESCRIPTION OF THE - MONITOR & KEYBOARD." .

ns1:Tecla_BACK a ns1:ComponenteElectrico ;
    rdfs:label "BACK Key" ;
    ns1:identificador "BACK" ;
    ns1:textoExtracto "BACK key. BACK On the horizontal softkey menu, it may be used to go from a softkey submenu up to the previous menu." .

ns1:Tecla_CALC a ns1:ComponenteElectrico ;
    rdfs:label "Calculator Key" ;
    ns1:identificador "CALC" ;
    ns1:textoExtracto "Calculator (*). CALC (*) The calculator key is not available on all keyboards." .

ns1:Tecla_DEL a ns1:ComponenteElectrico ;
    rdfs:label "Delete Key" ;
    ns1:identificador "DEL" ;
    ns1:textoExtracto "Delete. Delete. DEL" .

ns1:Tecla_ENTER a ns1:ComponenteElectrico ;
    rdfs:label "ENTER Key" ;
    ns1:identificador "ENTER" ;
    ns1:textoExtracto "Key to validate commands, data and ENTER program blocks of the editor." .

ns1:Tecla_ESC a ns1:ComponenteElectrico ;
    rdfs:label "Escape Key" ;
    ns1:identificador "ESC" ;
    ns1:textoExtracto "Escape key, to cancel the current action ESC without assuming the changes." .

ns1:Tecla_F1 a ns1:ComponenteElectrico ;
    rdfs:label "F1 Key" ;
    ns1:identificador "F1" ;
    ns1:textoExtracto "F1 Keys F1 through F12 select the options of the softkey menus." .

ns1:Tecla_FOCUS a ns1:ComponenteElectrico ;
    rdfs:label "FOCUS Key" ;
    ns1:identificador "FOCUS" ;
    ns1:textoExtracto "FOCUS key. FOCUS It is used to switch between the different windows of the screen." .

ns1:Tecla_HELP a ns1:ComponenteElectrico ;
    rdfs:label "HELP Key" ;
    ns1:identificador "HELP" ;
    ns1:textoExtracto "Help key. HELP key. HELP Display CNC help." .

ns1:Tecla_INS a ns1:ComponenteElectrico ;
    rdfs:label "Insert Key" ;
    ns1:identificador "INS" ;
    ns1:textoExtracto "Insert or overwrite. INS" .

ns1:Tecla_NEXT a ns1:ComponenteElectrico ;
    rdfs:label "NEXT Key" ;
    ns1:identificador "NEXT" ;
    ns1:textoExtracto "NEXT key. NEXT OEM configurable table." .

ns1:Tecla_RECALL a ns1:ComponenteElectrico ;
    rdfs:label "Recall Key" ;
    ns1:identificador "RECALL" ;
    ns1:textoExtracto "Recover data. RECALL" .

