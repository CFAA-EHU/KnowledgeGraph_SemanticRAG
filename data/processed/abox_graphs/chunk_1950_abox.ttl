@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_1031 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1031: 'Se espera #AXIS'" ;
    ns1:identificador "1031" ;
    ns1:monitoreaParametro ns1:Funcion_G201,
        ns1:Sentencia_AXIS ;
    ns1:textoExtracto "'Se espera #AXIS' DETECCIÓN Durante la ejecución. CAUSA En el mismo bloque que la función G201 falta programar la sentencia #AXIS. SOLUCIÓN Revisar la programación." .

ns1:Error_1032 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1032: 'Falta posición del cabezal para M19'" ;
    ns1:identificador "1032" ;
    ns1:monitoreaParametro ns1:Funcion_M19 ;
    ns1:textoExtracto "'Falta posición del cabezal para M19' DETECCIÓN Durante la ejecución. CAUSA En el mismo bloque que la función M19 falta programar la posición del cabezal. SOLUCIÓN Revisar la programación." .

ns1:Error_1035 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1035: '#SLOPE: parámetro fuera de rango'" ;
    ns1:identificador "1035" ;
    ns1:monitoreaParametro ns1:Parametro_SLOPE ;
    ns1:textoExtracto "'#SLOPE: parámetro fuera de rango' DETECCIÓN Durante la ejecución. CAUSA En la sentencia #SLOPE algún parámetro tiene un valor demasiado alto. SOLUCIÓN Programar valores menores." .

ns1:Error_1037 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1037: 'Coordenadas del centro ignoradas con G0/G1/G100/G63 activas'" ;
    ns1:identificador "1037" ;
    ns1:textoExtracto "'Coordenadas del centro ignoradas con G0/G1/G100/G63 activas' DETECCIÓN Durante la ejecución." .

ns1:Funcion_G201 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G201" ;
    ns1:identificador "G201" ;
    ns1:textoExtracto "En el mismo bloque que la función G201 falta programar la sentencia #AXIS." .

ns1:Funcion_M19 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función M19" ;
    ns1:identificador "M19" ;
    ns1:textoExtracto "En el mismo bloque que la función M19 falta programar la posición del cabezal." .

ns1:Parametro_SLOPE a ns1:Parametro ;
    rdfs:label "Parámetro #SLOPE" ;
    ns1:identificador "#SLOPE" ;
    ns1:textoExtracto "En la sentencia #SLOPE algún parámetro tiene un valor demasiado alto." .

ns1:Sentencia_AXIS a ns1:Parametro ;
    rdfs:label "Sentencia #AXIS" ;
    ns1:identificador "#AXIS" ;
    ns1:textoExtracto "En el mismo bloque que la sentencia #AXIS falta programar G200, G201 o G202." .

