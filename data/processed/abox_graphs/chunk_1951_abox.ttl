@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1037 a ns1:Alarma ;
    rdfs:label "Alarma 1037: Coordenadas del centro ignoradas con G0/G1/G100/G63 activas" ;
    ns1:activaAlarma ns1:Funcion_G0,
        ns1:Funcion_G1,
        ns1:Funcion_G100,
        ns1:Funcion_G63 ;
    ns1:identificador "1037" ;
    ns1:monitoreaParametro ns1:Parametro_I,
        ns1:Parametro_J,
        ns1:Parametro_K ;
    ns1:textoExtracto "'Coordenadas del centro ignoradas con G0/G1/G100/G63 activas' DETECCIÓN Durante la ejecución. CAUSA El CNC ha encontrado los parámetros I, J, K con la función G0, G1, G100 o G63 activa. El CNC ignora estos parámetros. SOLUCIÓN Estas funciones no necesitan estos parámetros." .

ns1:Alarma_1038 a ns1:Alarma ;
    rdfs:label "Alarma 1038: No se admite compensación de radio activa en medición" ;
    ns1:activaAlarma ns1:Funcion_G100 ;
    ns1:identificador "1038" ;
    ns1:monitoreaParametro ns1:Funcion_G41,
        ns1:Funcion_G42 ;
    ns1:textoExtracto "'No se admite compensación de radio activa en medición' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta ejecutar la función G100 con la compensación de radio activa (G41/G42). SOLUCIÓN Revisar la programación." .

ns1:Alarma_1039 a ns1:Alarma ;
    rdfs:label "Alarma 1039: Existe un valor de medición previo para el eje(s)" ;
    ns1:activaAlarma ns1:Funcion_G100 ;
    ns1:identificador "1039" ;
    ns1:solucionaFallo ns1:Funcion_G102 ;
    ns1:textoExtracto "'Existe un valor de medición previo para el eje(s)' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta realizar un medición (G100) en un eje que tiene un offset de medición anterior. SOLUCIÓN Utilizar la función G102 para anular el offset de medición incluido en el eje." .

ns1:Funcion_G0 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G0 (movimiento rápido)" ;
    ns1:identificador "G0" ;
    ns1:textoExtracto "función G0" .

ns1:Funcion_G1 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G1 (interpolación lineal)" ;
    ns1:identificador "G1" ;
    ns1:textoExtracto "función G1" .

ns1:Funcion_G102 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G102 (anulación de offset de medición)" ;
    ns1:identificador "G102" ;
    ns1:textoExtracto "función G102 para anular el offset de medición" .

ns1:Funcion_G41 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G41 (compensación de radio izquierda)" ;
    ns1:identificador "G41" ;
    ns1:textoExtracto "compensación de radio activa (G41/G42)" .

ns1:Funcion_G42 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G42 (compensación de radio derecha)" ;
    ns1:identificador "G42" ;
    ns1:textoExtracto "compensación de radio activa (G41/G42)" .

ns1:Funcion_G63 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G63 (roscado)" ;
    ns1:identificador "G63" ;
    ns1:textoExtracto "función G63" .

ns1:Parametro_I a ns1:Parametro ;
    rdfs:label "Parámetro I (coordenada de centro)" ;
    ns1:textoExtracto "parámetros I, J, K" .

ns1:Parametro_J a ns1:Parametro ;
    rdfs:label "Parámetro J (coordenada de centro)" ;
    ns1:textoExtracto "parámetros I, J, K" .

ns1:Parametro_K a ns1:Parametro ;
    rdfs:label "Parámetro K (coordenada de centro)" ;
    ns1:textoExtracto "parámetros I, J, K" .

ns1:Funcion_G100 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G100 (medición)" ;
    ns1:identificador "G100" ;
    ns1:textoExtracto "función G100" .

