@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1041 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1041: Centro de la trayectoria circular corregida fuera de rango" ;
    ns1:identificador "1041" ;
    ns1:textoExtracto "1041 'Centro de la trayectoria circular corregida fuera de rango' DETECCIÓN Durante la ejecución. CAUSA En una interpolación circular programada bien mediante el radio" .

ns1:ModoOperacion_G201 a ns1:ModoOperacion ;
    rdfs:label "Modo manual aditivo (G201)" ;
    ns1:identificador "G201" ;
    ns1:requiereMantenimiento ns1:Fallo_1040 ;
    ns1:textoExtracto "modo manual aditivo (G201)" .

ns1:Fallo_1040 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1040: No se permite búsqueda de cero de un eje activo en G201" ;
    ns1:identificador "1040" ;
    ns1:solucionaFallo ns1:Funcion_G102,
        ns1:ModoOperacion_G202 ;
    ns1:textoExtracto "1040 'No se permite búsqueda de cero de un eje activo en G201' DETECCIÓN Durante la ejecución. CAUSA El CNC no puede realizar la búsqueda de referencia de un eje que está en modo manual aditivo (G201)." .

ns1:Funcion_G102 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G102 (anulación de offset de medición)" ;
    ns1:identificador "G102" ;
    ns1:textoExtracto "Utilizar la función G102 para anular el offset de medición incluido en el eje" .

ns1:ModoOperacion_G202 a ns1:ModoOperacion ;
    rdfs:label "Modo de anulación manual aditiva (G202)" ;
    ns1:identificador "G202" ;
    ns1:textoExtracto "Anular el modo manual aditivo del eje mediante la función G202" .

