@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_1041 a ns1:AvisoSeguridad ;
    rdfs:label "Centro de la trayectoria circular corregida fuera de rango (1041)" ;
    ns1:identificador "1041" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_G201 ;
    ns1:textoExtracto "'Centro de la trayectoria circular corregida fuera de rango' DETECCIÓN Durante la ejecución. CAUSA En una interpolación circular programada bien mediante el radio y las coordenadas del punto final o bien mediante las coordenadas del punto medio, del punto final y con la función G265 activa. Las coordenadas del centro de la interpolación calculadas por el CNC son demasiado grandes. Las coordenadas programadas para el centro, el punto medio o el radio son demasiado grandes. SOLUCIÓN Revisar la programación." .

ns1:AvisoSeguridad_1043 a ns1:AvisoSeguridad ;
    rdfs:label "El tercer eje del plano no puede coincidir con el primero o segundo (1043)" ;
    ns1:identificador "1043" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_G201 ;
    ns1:textoExtracto "'El tercer eje del plano no puede coincidir con el primero o segundo' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano), el parámetro 5 coincide con el 1 o con el 2. SOLUCIÓN Si el eje longitudinal de la herramienta (parámetro 3) coincide con el primer o segundo eje del plano (parámetros 1 y 2) es necesario programar el tercer eje con el parámetro 5. Este parámetro no deberá coincidir ni con el primero ni con el segundo." .

ns1:AvisoSeguridad_1044 a ns1:AvisoSeguridad ;
    rdfs:label "El primer y segundo eje del plano no pueden coincidir (1044)" ;
    ns1:identificador "1044" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_G201 ;
    ns1:textoExtracto "'El primer y segundo eje del plano no pueden coincidir' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano), el primer eje del plano (parámetro 1) y el segundo (parámetro 2) son el mismo eje. SOLUCIÓN Revisar la programación." .

ns1:AvisoSeguridad_1045 a ns1:AvisoSeguridad ;
    rdfs:label "Programación incorrecta del primer eje del plano (1045)" ;
    ns1:identificador "1045" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_G201 ;
    ns1:textoExtracto "'Programación incorrecta del primer eje del plano' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano) el primer eje del plano (parámetro 1) es incorrecto. SOLUCIÓN El primer eje del plano debe ser uno de los tres primeros ejes del canal." .

ns1:AvisoSeguridad_1046 a ns1:AvisoSeguridad ;
    rdfs:label "Programación incorrecta del segundo eje del plano (1046)" ;
    ns1:identificador "1046" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_G201 ;
    ns1:textoExtracto "'Programación incorrecta del segundo eje del plano' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano) el segundo eje del plano (parámetro 2) es incorrecto. SOLUCIÓN El segundo eje del plano debe ser uno de los tres primeros ejes del canal." .

ns1:Herramienta_G20 a ns1:Herramienta ;
    rdfs:label "Herramienta configurada en G20" ;
    ns1:textoExtracto "el eje longitudinal de la herramienta (parámetro 3)" .

ns1:Parametro_G20_Param1 a ns1:Parametro ;
    rdfs:label "Primer eje del plano (parámetro 1 en G20)" ;
    ns1:identificador "parámetro 1" ;
    ns1:textoExtracto "el primer eje del plano (parámetro 1)" .

ns1:Parametro_G20_Param2 a ns1:Parametro ;
    rdfs:label "Segundo eje del plano (parámetro 2 en G20)" ;
    ns1:identificador "parámetro 2" ;
    ns1:textoExtracto "el segundo (parámetro 2)" .

ns1:Parametro_G20_Param3 a ns1:Parametro ;
    rdfs:label "Eje longitudinal de la herramienta (parámetro 3 en G20)" ;
    ns1:identificador "parámetro 3" ;
    ns1:textoExtracto "el eje longitudinal de la herramienta (parámetro 3)" .

ns1:Parametro_G20_Param5 a ns1:Parametro ;
    rdfs:label "Tercer eje del plano (parámetro 5 en G20)" ;
    ns1:identificador "parámetro 5" ;
    ns1:textoExtracto "el tercer eje con el parámetro 5" .

ns1:ModoOperacion_G201 a ns1:ModoOperacion ;
    rdfs:label "Modo manual aditivo (G201)" ;
    ns1:textoExtracto "el modo manual aditivo (G201)" .

