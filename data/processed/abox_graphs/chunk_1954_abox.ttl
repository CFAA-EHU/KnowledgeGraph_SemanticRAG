@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1046 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación incorrecta del segundo eje del plano"@es ;
    ns1:identificador "1046" ;
    ns1:solucionaFallo ns1:Parametro_G20_Param2 ;
    ns1:textoExtracto "1046 'Programación incorrecta del segundo eje del plano' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano) el segundo eje del plano (parámetro 2) es incorrecto. SOLUCIÓN El segundo eje del plano debe ser uno de los tres primeros ejes del canal."@es .

ns1:DiagnosticoFallo_1047 a ns1:DiagnosticoFallo ;
    rdfs:label "Es necesario un tercer eje para el plano (índice 5)"@es ;
    ns1:identificador "1047" ;
    ns1:solucionaFallo ns1:Parametro_G20_EjeTercero ;
    ns1:textoExtracto "1047 'Es necesario un tercer eje para el plano (índice 5)' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano) falta el tercer eje del plano o éste es incorrecto."@es .

ns1:Funcion_G20 a ns1:Componente,
        ns1:Tabla ;
    rdfs:label "Función G20 (cambio de plano)"@es ;
    ns1:identificador "G20" ;
    ns1:monitoreaParametro ns1:Parametro_G20_EjeTercero,
        ns1:Parametro_G20_Param2 ;
    ns1:textoExtracto "En la función G20 (cambio de plano) el segundo eje del plano (parámetro 2) es incorrecto"@es .

ns1:Parametro_G20_EjeTercero a ns1:Parametro ;
    rdfs:label "Tercer eje del plano (índice 5 en función G20)"@es ;
    ns1:identificador "G20-5" ;
    ns1:textoExtracto "falta el tercer eje del plano o éste es incorrecto"@es ;
    ns1:valor "Eje_Faltante_O_Incorrecto" .

ns1:Parametro_G20_Param2 a ns1:Parametro ;
    rdfs:label "Parámetro 2 (segundo eje del plano en función G20)"@es ;
    ns1:identificador "G20-2" ;
    ns1:textoExtracto "el segundo eje del plano (parámetro 2) es incorrecto"@es ;
    ns1:valor "Eje_Incorrecto" .

