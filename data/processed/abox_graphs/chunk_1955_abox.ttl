@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_1048 a ns1:AvisoSeguridad ;
    rdfs:label "Compensación de longitud de herramienta con radio fuera de rango" ;
    ns1:identificador "1048" ;
    ns1:mitigaRiesgo ns1:Parametro_3 ;
    ns1:textoExtracto "'Compensación de longitud de herramienta con radio fuera de rango' DETECCIÓN Durante la ejecución. CAUSA Las dimensiones de la herramienta exceden los valores máximos. SOLUCIÓN Modificar las dimensiones de la herramienta." .

ns1:AvisoSeguridad_1049 a ns1:AvisoSeguridad ;
    rdfs:label "Eje frontal (FACEAXIS) definido dos veces en el plano activo" ;
    ns1:identificador "1049" ;
    ns1:textoExtracto "'Eje frontal (FACEAXIS) definido dos veces en el plano activo' DETECCIÓN Durante la ejecución. CAUSA Los dos ejes del plano principal son ejes frontales (parámetro FACEAXIS)." .

ns1:Funcion_G20 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G20 (cambio de plano)" ;
    ns1:identificador "G20" ;
    ns1:requiereMantenimiento ns1:AvisoSeguridad_1047 ;
    ns1:textoExtracto "En la función G20 (cambio de plano) falta el tercer eje del plano o éste es incorrecto." .

ns1:Herramienta_G20 a ns1:Herramienta ;
    rdfs:label "Herramienta con función G20 (cambio de plano)" ;
    ns1:requiereMantenimiento ns1:AvisoSeguridad_1047 ;
    ns1:textoExtracto "En la función G20 (cambio de plano) falta el tercer eje del plano o éste es incorrecto." .

ns1:Parametro_1 a ns1:Parametro ;
    rdfs:label "Primer eje del plano" ;
    ns1:identificador "1" ;
    ns1:textoExtracto "primer eje del plano (parámetros 1 y 2)" .

ns1:Parametro_2 a ns1:Parametro ;
    rdfs:label "Segundo eje del plano" ;
    ns1:identificador "2" ;
    ns1:textoExtracto "segundo eje del plano (parámetros 1 y 2)" .

ns1:Parametro_3 a ns1:Parametro ;
    rdfs:label "Eje longitudinal de la herramienta" ;
    ns1:identificador "3" ;
    ns1:textoExtracto "eje longitudinal de la herramienta (parámetro 3)" .

ns1:Parametro_5 a ns1:Parametro ;
    rdfs:label "Tercer eje del plano" ;
    ns1:identificador "5" ;
    ns1:textoExtracto "programar el tercer eje con el parámetro 5" .

ns1:AvisoSeguridad_1047 a ns1:AvisoSeguridad ;
    rdfs:label "Falta tercer eje para el plano" ;
    ns1:identificador "1047" ;
    ns1:mitigaRiesgo ns1:Parametro_5 ;
    ns1:textoExtracto "'Es necesario un tercer eje para el plano (índice 5)' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano) falta el tercer eje del plano o éste es incorrecto. SOLUCIÓN Si el eje longitudinal de la herramienta (parámetro 3) coincide con el primer o segundo eje del plano (parámetros 1 y 2) es necesario programar el tercer eje con el parámetro 5. El parámetro no deberá coincidir ni con el primero ni con el segundo y deberá ser uno de los tres primeros ejes del canal." .

