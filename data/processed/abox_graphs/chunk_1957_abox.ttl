@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1053 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de medición con función G100"@es ;
    ns1:identificador "1053" ;
    ns1:solucionaFallo ns1:RangoValidoDePalpacion ;
    ns1:textoExtracto "CAUSA El CNC ha realizado una medición con la función G100 y la cota o el offset obtenido es demasiado grande. SOLUCIÓN El valor obtenido en la palpación debe estar entre -2147483647 y 2147483646."@es .

ns1:DiagnosticoFallo_1054 a ns1:DiagnosticoFallo ;
    rdfs:label "Garra inexistente"@es ;
    ns1:identificador "1054" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El número de garra programado no existe."@es .

ns1:RangoValidoDePalpacion a ns1:Parametro ;
    rdfs:label "Rango válido de palpación"@es ;
    ns1:textoExtracto "El valor obtenido en la palpación debe estar entre -2147483647 y 2147483646."@es ;
    ns1:valor "-2147483647 a 2147483646" .

