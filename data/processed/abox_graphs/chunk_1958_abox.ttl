@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_1054 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1054: Garra inexistente" ;
    ns1:identificador "1054" ;
    ns1:textoExtracto "1054 'Garra inexistente' DETECCIÓN Durante la ejecución. CAUSA El número de garra programado no existe. SOLUCIÓN El número de garra debe ser un valor entre cero y diez." .

ns1:AvisoSeguridad_1055 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1055: Modificación no permitida de radio de herramienta" ;
    ns1:identificador "1055" ;
    ns1:textoExtracto "1055 'No se permite modificar D y el radio de la herramienta en el mismo bloque' DETECCIÓN Durante la ejecución. CAUSA El CNC no permite modificar el radio de la herramienta (variable (V.)G.TOR) y programar un cambio de herramienta y/o corrector en el mismo bloque. SOLUCIÓN Programar ambas instrucciones en bloques diferentes." .

ns1:AvisoSeguridad_1056 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1056: Número de variables externas sobrepasado" ;
    ns1:identificador "1056" ;
    ns1:textoExtracto "1056 'Número de variables externas sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha alcanzado el número de variables externas admisibles. SOLUCIÓN Revisar la programación. El CNC admite 500 variables externas." ;
    ns1:valor "500" .

ns1:AvisoSeguridad_1057 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1057: Variable sin permiso de lectura" ;
    ns1:identificador "1057" ;
    ns1:textoExtracto "1057 'Variable sin permiso de lectura' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado leer desde el programa pieza o MDI una variable que no tiene permiso de lectura por programa. SOLUCIÓN No es posible leer la variable desde programa pieza o MDI. Consultar en la documentación los permisos de la variable." .

ns1:AvisoSeguridad_1058 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1058: Variable de usuario sin inicializar" ;
    ns1:identificador "1058" ;
    ns1:textoExtracto "1058 'Variable de usuario sin inicializar' DETECCIÓN Durante la ejecución. CAUSA La variable de usuario V.P.name o V.S.name no ha sido definida. SOLUCIÓN Revisar la programación. Definir adecuadamente la variable." .

ns1:AvisoSeguridad_1059 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1059: Variable sin permiso de escritura" ;
    ns1:identificador "1059" ;
    ns1:textoExtracto "1059 'Variable sin permiso de escritura' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado escribir desde el programa pieza o MDI una variable que no tiene permiso de escritura por programa. SOLUCIÓN No es posible escribir esta variable desde programa pieza o MDI. Consultar en la documentación los permisos de la variable." .

ns1:AvisoSeguridad_1060 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1060: Valor de etiqueta N fuera de rango" ;
    ns1:identificador "1060" ;
    ns1:textoExtracto "1060 'Valor de etiqueta N fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El número de bloque \"N\" no es válido. SOLUCIÓN El número de bloque debe ser un valor positivo y menor que 2147483646." ;
    ns1:valor "2147483646" .

ns1:Parametro_EtiquetaN a ns1:Parametro ;
    rdfs:label "Rango válido para etiqueta N" ;
    ns1:textoExtracto "El número de bloque debe ser un valor positivo y menor que 2147483646." ;
    ns1:valor "1-2147483645" .

ns1:Parametro_Garra a ns1:Parametro ;
    rdfs:label "Número de garra" ;
    ns1:textoExtracto "El número de garra programado no existe. SOLUCIÓN El número de garra debe ser un valor entre cero y diez." ;
    ns1:valor "0-10" .

ns1:Parametro_VariablesExternas a ns1:Parametro ;
    rdfs:label "Número máximo de variables externas" ;
    ns1:textoExtracto "El CNC admite 500 variables externas." ;
    ns1:valor "500" .

ns1:Herramienta a ns1:Herramienta ;
    rdfs:label "Herramienta CNC" ;
    ns1:textoExtracto "El radio de la herramienta (variable (V.)G.TOR)" .

