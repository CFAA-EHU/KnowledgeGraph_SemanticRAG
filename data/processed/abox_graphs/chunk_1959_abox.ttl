@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Alarma_1060 a ns1:Alarma ;
    rdfs:label "Alarma 1060: Valor de etiqueta N fuera de rango" ;
    ns1:identificador "1060" ;
    ns1:monitoreaParametro ns1:Parametro_NumeroBloque ;
    ns1:textoExtracto "'Valor de etiqueta N fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El número de bloque \"N\" no es válido. SOLUCIÓN El número de bloque debe ser un valor positivo y menor que 2147483646." .

ns1:Alarma_1061 a ns1:Alarma ;
    rdfs:label "Alarma 1061: Función G inexistente" ;
    ns1:identificador "1061" ;
    ns1:monitoreaParametro ns1:Parametro_FuncionG ;
    ns1:textoExtracto "'Función G inexistente' DETECCIÓN Durante la ejecución. CAUSA La función G programada no existe. SOLUCIÓN Revisar la programación." .

ns1:Parametro_FuncionG a ns1:Parametro ;
    rdfs:label "Función G programada" ;
    ns1:textoExtracto "La función G programada no existe." .

ns1:Parametro_NumeroBloque a ns1:Parametro ;
    rdfs:label "Número de bloque (N)" ;
    ns1:textoExtracto "El número de bloque \"N\" no es válido. [...] El número de bloque debe ser un valor positivo y menor que 2147483646." ;
    ns1:valor 2147483646 .

