@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:JogPanel_5 a ns1:InterfazUsuario ;
    rdfs:label "JOG PANEL"@en ;
    ns1:textoExtracto "Jog keyboard for jogging the axes. Keys to select axes and jog them in the positive direction. Keys to select axes and jog them in the negative direction. Keys to select the axes and keys to select the jogging direction. Both keys (axis and direction) must be pressed to jog the axis."@en ;
    ns1:tieneComponente ns1:CycleStartKey_5,
        ns1:CycleStopKey_5,
        ns1:ExecutionKeys_5,
        ns1:FeedSelector_5,
        ns1:HomeSearchKey_5,
        ns1:JogTypeSector_5,
        ns1:RapidKey_5,
        ns1:ResetKey_5,
        ns1:SingleBlockKey_5,
        ns1:SpindleControl_5,
        ns1:SpindleSpeedOverride_5 .

ns1:ExecutionKeys_5 a ns1:ComponenteElectrico ;
    rdfs:label "Execution keys"@en ;
    ns1:compuestoPor ns1:CycleStartKey_5,
        ns1:CycleStopKey_5,
        ns1:HomeSearchKey_5,
        ns1:ResetKey_5,
        ns1:SingleBlockKey_5 ;
    ns1:textoExtracto "Execution keys."@en .

ns1:RapidKey_5 a ns1:ComponenteElectrico ;
    rdfs:label "Rapid key"@en ;
    ns1:controla ns1:FeedSelector_5 ;
    ns1:textoExtracto "Rapid key. When pressing this key while moving an axis, the CNC applies the rapid feedrate."@en .

ns1:SpindleControl_5 a ns1:ComponenteElectrico ;
    rdfs:label "Spindle control"@en ;
    ns1:controla ns1:SpindleSpeedOverride_5 ;
    ns1:textoExtracto "Spindle control. Start the spindle clockwise. Stop the spindle. Start the spindle counteclockwise."@en .

ns1:CycleStartKey_5 a ns1:ComponenteElectrico ;
    rdfs:label "Cycle start key"@en ;
    ns1:identificador "START" ;
    ns1:textoExtracto "Cycle start key (START). Execute the selected program in automatic mode, a block in MDI/MDA mode, etc."@en .

ns1:CycleStopKey_5 a ns1:ComponenteElectrico ;
    rdfs:label "Cycle stop key"@en ;
    ns1:identificador "STOP" ;
    ns1:textoExtracto "Cycle stop key (STOP). Interrupt the execution of the CNC."@en .

ns1:FeedSelector_5 a ns1:ComponenteElectrico ;
    rdfs:label "Feed selectors"@en ;
    ns1:controla ns1:JogTypeSector_5 ;
    ns1:textoExtracto "Feed selectors. jog 1 1 10 10 100 100 1000 10000"@en ;
    ns1:valor "1, 10, 100, 1000, 10000" .

ns1:HomeSearchKey_5 a ns1:ComponenteElectrico ;
    rdfs:label "Home search key"@en ;
    ns1:identificador "ZERO" ;
    ns1:textoExtracto "Home search. ZERO"@en .

ns1:JogTypeSector_5 a ns1:InterfazUsuario ;
    rdfs:label "Jog type sector"@en ;
    ns1:textoExtracto "Sector for the type of jog; continuous / incremental jog or handwheels. • In handwheel mode, it selects the multiplying for the handwheel pulses (x1, x10 o x100). • In incremental mode, it selects the incremental value of the axis movements."@en .

ns1:ResetKey_5 a ns1:ComponenteElectrico ;
    rdfs:label "Reset key"@en ;
    ns1:identificador "RESET" ;
    ns1:textoExtracto "Reset key. RESET It initializes the system setting the initial conditions as defined by machine parameters."@en .

ns1:SingleBlockKey_5 a ns1:ComponenteElectrico ;
    rdfs:label "Single-block execution mode key"@en ;
    ns1:identificador "SINGLE" ;
    ns1:textoExtracto "Single-block execution mode. SINGLE When selecting the 'single block' execution mode, the program simulation will be interrupted at the end of each block."@en .

ns1:SpindleSpeedOverride_5 a ns1:Parametro ;
    rdfs:label "Spindle speed override"@en ;
    ns1:textoExtracto "To vary the spindle speed percentually. Selector of percentage of spindle speed override between 0% and 200%."@en ;
    ns1:valor "0-200%" .

