@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1061 a ns1:Alarma ;
    rdfs:label "Función G inexistente" ;
    ns1:identificador "1061" ;
    ns1:textoExtracto "1061 'Función G inexistente' DETECCIÓN Durante la ejecución. CAUSA La función G programada no existe. SOLUCIÓN Revisar la programación." .

ns1:Alarma_1062 a ns1:Alarma ;
    rdfs:label "Funciones G incompatibles" ;
    ns1:identificador "1062" ;
    ns1:textoExtracto "1062 'Funciones G incompatibles' DETECCIÓN Durante la ejecución. CAUSA En el bloque hay programadas dos funciones G que son contrarias entre sí. SOLUCIÓN Programar las funciones en bloques diferentes." .

