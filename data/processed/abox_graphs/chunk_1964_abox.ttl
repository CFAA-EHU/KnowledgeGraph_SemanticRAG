ns1:Fallo_1084 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite cambio de plano con compensación de radio activa"@es ;
    ns1:identificador "1084" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado cambiar el plano de trabajo o los ejes que componen el plano, con la compensación del radio activa. SOLUCIÓN Anular la compensación para definir el nuevo plano de trabajo."@es .

ns1:Fallo_1085 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite G41/G42 si falta el primer o segundo eje del plano activo"@es ;
    ns1:identificador "1085" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Es imposible compensar el radio de herramienta si falta uno de los dos ejes del plano activo en el canal."@es .

ns1:Herramienta_CNC a ns1:Herramienta ;
    ns1:textoExtracto "compensar el radio de herramienta"@es .

