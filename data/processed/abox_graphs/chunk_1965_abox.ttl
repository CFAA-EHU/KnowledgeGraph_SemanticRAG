@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_1085_Solucion a ns1:AvisoSeguridad ;
    rdfs:label "Solución para alarma 1085"@es ;
    ns1:mitigaRiesgo ns1:Alarma_1085 ;
    ns1:textoExtracto "SOLUCIÓN Definir el plano de trabajo. Si el canal ha cedido sus ejes a otro canales, recuperar el eje que falta"@es .

ns1:Parametro_PlanoTrabajo a ns1:Parametro ;
    rdfs:label "Plano de trabajo (ejes activos)"@es ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "plano de trabajo [...] eje del plano activo en el canal"@es .

ns1:Parametro_RadioHerramienta a ns1:Parametro ;
    rdfs:label "Radio de herramienta (compensación G41/G42)"@es ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "compensar el radio de herramienta"@es .

ns1:Alarma_1085 a ns1:Alarma ;
    rdfs:label "Alarma 1085: Falta eje en plano activo"@es ;
    ns1:activaAlarma ns1:Sistema_CNC ;
    ns1:identificador "1085" ;
    ns1:textoExtracto "'No se admite G41/G42 si falta el primer o segundo eje del plano activo' DETECCIÓN Durante la ejecución. CAUSA Es imposible compensar el radio de herramienta si falta uno de los dos ejes del plano activo en el canal."@es .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC (Control Numérico Computarizado)"@es ;
    ns1:textoExtracto "compensar el radio de herramienta [...] plano de trabajo [...] canal"@es .

