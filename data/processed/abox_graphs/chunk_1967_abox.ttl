@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FuncionD_doblemente_programada a ns1:DiagnosticoFallo ;
    rdfs:label "1093 'Función D doblemente programada'" ;
    ns1:solucionaFallo ns1:FuncionD_unica_por_bloque ;
    ns1:textoExtracto "1093 'Función D doblemente programada' DETECCIÓN Durante la ejecución. CAUSA Hay más de una función D en el mismo bloque. SOLUCIÓN Sólo puede haber una función D en cada bloque. Programar ambas funciones en bloques diferentes." .

ns1:FuncionH_inexistente a ns1:DiagnosticoFallo ;
    rdfs:label "1090 'Función H inexistente'" ;
    ns1:solucionaFallo ns1:FuncionH_no_existente ;
    ns1:textoExtracto "1090 'Función H inexistente' DETECCIÓN Durante la ejecución. CAUSA La función H no existe. SOLUCIÓN El número de la función deberá estar entre 1 y 65534." .

ns1:FuncionT_doblemente_programada a ns1:DiagnosticoFallo ;
    rdfs:label "1091 'Función T doblemente programada'" ;
    ns1:solucionaFallo ns1:FuncionT_unica_por_bloque ;
    ns1:textoExtracto "1091 'Función T doblemente programada' DETECCIÓN Durante la ejecución. CAUSA Hay más de una función T en el mismo bloque. SOLUCIÓN Sólo puede haber una función T en cada bloque. Programar ambas funciones en bloques diferentes." .

ns1:VelocidadF_doblemente_programada a ns1:DiagnosticoFallo ;
    rdfs:label "1094 'Velocidad F doblemente programada'" ;
    ns1:solucionaFallo ns1:VelocidadF_unica_por_bloque ;
    ns1:textoExtracto "1094 'Velocidad F doblemente programada' DETECCIÓN Durante la ejecución. CAUSA Hay más de una función F en el mismo bloque. SOLUCIÓN Sólo puede haber una función F en cada bloque. Programar ambas funciones en bloques diferentes." .

ns1:FuncionD_unica_por_bloque a ns1:AccionProhibida ;
    rdfs:label "Función D doblemente programada" ;
    ns1:textoExtracto "CAUSA Hay más de una función D en el mismo bloque. SOLUCIÓN Sólo puede haber una función D en cada bloque." .

ns1:FuncionH_no_existente a ns1:AccionProhibida ;
    rdfs:label "Función H inexistente" ;
    ns1:textoExtracto "CAUSA La función H no existe." .

ns1:FuncionT_unica_por_bloque a ns1:AccionProhibida ;
    rdfs:label "Función T doblemente programada" ;
    ns1:textoExtracto "CAUSA Hay más de una función T en el mismo bloque. SOLUCIÓN Sólo puede haber una función T en cada bloque." .

ns1:VelocidadF_unica_por_bloque a ns1:AccionProhibida ;
    rdfs:label "Velocidad F doblemente programada" ;
    ns1:textoExtracto "CAUSA Hay más de una función F en el mismo bloque. SOLUCIÓN Sólo puede haber una función F en cada bloque." .

