@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1095 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite programar velocidad F negativa o cero"@es ;
    ns1:identificador "1095" ;
    ns1:solucionaFallo ns1:AccionProhibida_1095 ;
    ns1:textoExtracto "1095 'No se admite programar velocidad F negativa o cero' DETECCIÓN Durante la ejecución. CAUSA El avance (F) debe ser un valor positivo y no nulo. SOLUCIÓN Revisar la programación."@es .

ns1:DiagnosticoFallo_1096 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite programar la velocidad con E"@es ;
    ns1:identificador "1096" ;
    ns1:solucionaFallo ns1:AccionProhibida_1096 ;
    ns1:textoExtracto "1096 'No se admite programar la velocidad con E' DETECCIÓN Durante la ejecución. CAUSA El avance se ha programado con la función E."@es .

ns1:Parametro_AvanceF a ns1:Parametro ;
    rdfs:label "Avance (F)"@es ;
    ns1:textoExtracto "El avance (F) debe ser un valor positivo y no nulo"@es ;
    ns1:valor "positivo y no nulo"@es .

ns1:AccionProhibida_1095 a ns1:AccionProhibida ;
    rdfs:label "Programar velocidad F negativa o cero"@es ;
    ns1:textoExtracto "No se admite programar velocidad F negativa o cero"@es .

ns1:AccionProhibida_1096 a ns1:AccionProhibida ;
    rdfs:label "Programar velocidad con función E"@es ;
    ns1:textoExtracto "No se admite programar la velocidad con E"@es .

