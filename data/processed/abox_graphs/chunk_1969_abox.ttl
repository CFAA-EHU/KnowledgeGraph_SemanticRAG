@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_Velocidad_E a ns1:Parametro ;
    rdfs:label "Parámetro de velocidad (función E - inválida)" ;
    ns1:solucionaFallo ns1:Error_1096 ;
    ns1:textoExtracto "El avance se ha programado con la función E." ;
    ns1:valor "E" .

ns1:SistemaControl a ns1:Sistema ;
    rdfs:label "Sistema de control de cabezales" ;
    ns1:monitoreaParametro ns1:Parametro_Avance,
        ns1:Parametro_Velocidad_S ;
    ns1:textoExtracto "El cabezal programado en el bloque debe existir en la configuración del sistema, y según de qué sentencia, también en la configuración del canal. Un canal sólo puede controlar sus cabezales." ;
    ns1:tieneComponente ns1:Cabezal_S,
        ns1:Cabezal_S1,
        ns1:Cabezal_S9 .

ns1:Cabezal_S a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal S (genérico)" ;
    ns1:controla ns1:Error_1097 ;
    ns1:textoExtracto "Los nombres válidos para el cabezal son S, S1, …, S9." .

ns1:Cabezal_S1 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal S1" ;
    ns1:textoExtracto "Los nombres válidos para el cabezal son S, S1, …, S9." .

ns1:Cabezal_S9 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal S9" ;
    ns1:textoExtracto "Los nombres válidos para el cabezal son S, S1, …, S9." .

ns1:Error_1096 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1096: 'No se admite programar la velocidad con E'" ;
    ns1:identificador "1096" ;
    ns1:textoExtracto "1096 'No se admite programar la velocidad con E' DETECCIÓN Durante la ejecución. CAUSA El avance se ha programado con la función E. SOLUCIÓN Programar el avance con la función F." .

ns1:Error_1097 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1097: 'Nombre de cabezal desconocido'" ;
    ns1:identificador "1097" ;
    ns1:textoExtracto "1097 'Nombre de cabezal desconocido' DETECCIÓN Durante la ejecución. CAUSA El nombre del cabezal no es válido, el cabezal no existe en el sistema o el cabezal no pertenece al canal. SOLUCIÓN Los nombres válidos para el cabezal son S, S1, …, S9. El cabezal programado en el bloque debe existir en la configuración del sistema, y según de qué sentencia, también en la configuración del canal. Un canal sólo puede controlar sus cabezales." .

ns1:Error_1098 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1098: 'Velocidad S doblemente programada'" ;
    ns1:identificador "1098" ;
    ns1:textoExtracto "1098 'Velocidad S doblemente programada' DETECCIÓN Durante la ejecución." .

ns1:Parametro_Avance a ns1:Parametro ;
    rdfs:label "Parámetro de avance (función F)" ;
    ns1:textoExtracto "Programar el avance con la función F." ;
    ns1:valor "F" .

ns1:Parametro_Velocidad_S a ns1:Parametro ;
    rdfs:label "Parámetro de velocidad S" ;
    ns1:solucionaFallo ns1:Error_1098 ;
    ns1:textoExtracto "Velocidad S doblemente programada" ;
    ns1:valor "S" .

