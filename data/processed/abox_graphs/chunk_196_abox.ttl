@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_ResetSimulador a ns1:AccionProhibida ;
    rdfs:label "Reset (Simulator Only)" ;
    ns1:documentadoEn ns1:InterfazUsuario_CNC ;
    ns1:identificador "[CTRL]+[R]" ;
    ns1:textoExtracto "The shortcuts for the [START] [STOP] and [RESET] keys are only available when the CNC is installed as simulator on a PC." .

ns1:AccionProhibida_StartSimulador a ns1:AccionProhibida ;
    rdfs:label "Cycle Start (Simulator Only)" ;
    ns1:documentadoEn ns1:InterfazUsuario_CNC ;
    ns1:identificador "[CTRL]+[S]" ;
    ns1:textoExtracto "The shortcuts for the [START] [STOP] and [RESET] keys are only available when the CNC is installed as simulator on a PC." .

ns1:AccionProhibida_StopSimulador a ns1:AccionProhibida ;
    rdfs:label "Cycle Stop (Simulator Only)" ;
    ns1:documentadoEn ns1:InterfazUsuario_CNC ;
    ns1:identificador "[CTRL]+[P]" ;
    ns1:textoExtracto "The shortcuts for the [START] [STOP] and [RESET] keys are only available when the CNC is installed as simulator on a PC." .

ns1:ModoOperacion_AUTOMATICO a ns1:ModoOperacion ;
    rdfs:label "AUTO (Automatic mode)" ;
    ns1:habilitadoPor ns1:InterfazUsuario_CNC ;
    ns1:textoExtracto "AUTO Automatic mode." .

ns1:ModoOperacion_EDIT a ns1:ModoOperacion ;
    rdfs:label "EDIT (EDISIMU mode)" ;
    ns1:habilitadoPor ns1:InterfazUsuario_CNC ;
    ns1:textoExtracto "EDIT EDISIMU mode." .

ns1:ModoOperacion_MANUAL a ns1:ModoOperacion ;
    rdfs:label "MANUAL (Jog mode)" ;
    ns1:habilitadoPor ns1:InterfazUsuario_CNC ;
    ns1:textoExtracto "MANUAL Jog mode." .

ns1:ModoOperacion_MDI a ns1:ModoOperacion ;
    rdfs:label "MDI (MDI/MDA mode)" ;
    ns1:habilitadoPor ns1:InterfazUsuario_CNC ;
    ns1:textoExtracto "MDI MDI/MDA mode." .

ns1:Sistema_HerramientasYRevista a ns1:Sistema ;
    rdfs:label "Tool and Magazine Table" ;
    ns1:identificador "TOOLS" ;
    ns1:ilustradoEn ns1:InterfazUsuario_CNC ;
    ns1:textoExtracto "[ CTRL] + [F11] TOOLS Tool and magazine table." .

ns1:Sistema_TablasUsuario a ns1:Sistema ;
    rdfs:label "User Tables" ;
    ns1:identificador "TABLES" ;
    ns1:ilustradoEn ns1:InterfazUsuario_CNC ;
    ns1:textoExtracto "[ CTRL] + [F10] TABLES User tables." .

ns1:Sistema_Utilidades a ns1:Sistema ;
    rdfs:label "Utilities Mode" ;
    ns1:identificador "UTILITIES" ;
    ns1:ilustradoEn ns1:InterfazUsuario_CNC ;
    ns1:textoExtracto "[ CTRL] + [F12] UTILITIES Utilities mode." .

ns1:InterfazUsuario_CNC a ns1:InterfazUsuario ;
    rdfs:label "CNC Interface" ;
    ns1:textoExtracto "Operations at the interface. Minimize/Maximize the CNC. Show / hide the virtual operator panel. Show / hide the PLC message list. Show / hide the CNC message list. Show / hide the window for errors and warnings. Turn the CNC off." .

