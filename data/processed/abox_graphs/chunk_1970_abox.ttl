@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1098 a ns1:Alarma ;
    rdfs:label "Velocidad S doblemente programada"@es ;
    ns1:identificador "1098" ;
    ns1:monitoreaParametro ns1:Parametro_VelocidadS ;
    ns1:textoExtracto "1098 'Velocidad S doblemente programada' DETECCIÓN Durante la ejecución. CAUSA En un bloque hay programadas para el mismo cabezal dos o más funciones S. SOLUCIÓN En un mismo bloque sólo puede haber una velocidad para cada cabezal."@es .

ns1:Alarma_1100 a ns1:Alarma ;
    rdfs:label "Índice de parámetro fuera de rango"@es ;
    ns1:identificador "1100" ;
    ns1:monitoreaParametro ns1:Parametro_IndiceAritmetico ;
    ns1:textoExtracto "1100 'Indice de parámetro fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El parámetro aritmético no existe; no está dentro del rango permitido por los parámetros máquina. SOLUCIÓN Revisar la programación. Revisar en los parámetros máquina el rango de parámetros aritméticos valido."@es .

ns1:Maquina_Brochadora a ns1:Maquina ;
    rdfs:label "Máquina brochadora"@es ;
    ns1:controla ns1:Parametro_IndiceAritmetico,
        ns1:Parametro_VelocidadS ;
    ns1:textoExtracto "parámetros máquina"@es ;
    ns1:tieneComponente ns1:Cabezal_Maquina .

ns1:Cabezal_Maquina a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal"@es ;
    ns1:textoExtracto "cabezal"@es .

ns1:Parametro_IndiceAritmetico a ns1:Parametro ;
    rdfs:label "Parámetro aritmético"@es ;
    ns1:textoExtracto "parámetro aritmético"@es ;
    ns1:valor "índice"@es .

ns1:Parametro_VelocidadS a ns1:Parametro ;
    rdfs:label "Velocidad S"@es ;
    ns1:textoExtracto "funciones S"@es ;
    ns1:valor "velocidad"@es .

