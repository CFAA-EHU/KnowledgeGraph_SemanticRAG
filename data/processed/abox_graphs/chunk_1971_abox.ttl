@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_MAXCOMP a ns1:Parametro ;
    rdfs:label "MAXCOMP" ;
    ns1:documentadoEn ns1:TablaParametrosMaquina_106 ;
    ns1:identificador "MAXCOMP" ;
    ns1:textoExtracto "MINCOMP - MAXCOMP: Parámetros aritméticos comunes."@es .

ns1:Parametro_MAXGLBP a ns1:Parametro ;
    rdfs:label "MAXGLBP" ;
    ns1:documentadoEn ns1:TablaParametrosMaquina_106 ;
    ns1:identificador "MAXGLBP" ;
    ns1:textoExtracto "MINGLBP - MAXGLBP: Parámetros aritméticos globales."@es .

ns1:Parametro_MAXLOCP a ns1:Parametro ;
    rdfs:label "MAXLOCP" ;
    ns1:documentadoEn ns1:TablaParametrosMaquina_106 ;
    ns1:identificador "MAXLOCP" ;
    ns1:textoExtracto "MINLOCP - MAXLOCP: Parámetros aritméticos locales."@es .

ns1:Parametro_MINCOMP a ns1:Parametro ;
    rdfs:label "MINCOMP" ;
    ns1:documentadoEn ns1:TablaParametrosMaquina_106 ;
    ns1:identificador "MINCOMP" ;
    ns1:textoExtracto "MINCOMP - MAXCOMP: Parámetros aritméticos comunes."@es .

ns1:Parametro_MINGLBP a ns1:Parametro ;
    rdfs:label "MINGLBP" ;
    ns1:documentadoEn ns1:TablaParametrosMaquina_106 ;
    ns1:identificador "MINGLBP" ;
    ns1:textoExtracto "MINGLBP - MAXGLBP: Parámetros aritméticos globales."@es .

ns1:Parametro_MINLOCP a ns1:Parametro ;
    rdfs:label "MINLOCP" ;
    ns1:documentadoEn ns1:TablaParametrosMaquina_106 ;
    ns1:identificador "MINLOCP" ;
    ns1:textoExtracto "MINLOCP - MAXLOCP: Parámetros aritméticos locales."@es .

ns1:TablaParametrosMaquina_106 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros aritméticos de máquina"@es ;
    ns1:textoExtracto """
| Parámetros máquina. | Rango válido. |
| --- | --- |
| MINLOCP - MAXLOCP | Parámetros aritméticos locales. |
| MINGLBP - MAXGLBP | Parámetros aritméticos globales. |
| MINCOMP - MAXCOMP | Parámetros aritméticos comunes. """ .

