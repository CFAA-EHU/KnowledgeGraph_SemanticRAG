@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1101 a ns1:DiagnosticoFallo ;
    rdfs:label "Sintaxis incorrecta en sentencia #SET IPOPOS" ;
    ns1:solucionaFallo ns1:Alarma_1101 ;
    ns1:textoExtracto "La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque." .

ns1:DiagnosticoFallo_1102 a ns1:DiagnosticoFallo ;
    rdfs:label "Índice R no permitido" ;
    ns1:solucionaFallo ns1:Alarma_1102 ;
    ns1:textoExtracto "Sólo se permite programar el radio con R o R1." .

ns1:DiagnosticoFallo_1103 a ns1:DiagnosticoFallo ;
    rdfs:label "Función O no implementada" ;
    ns1:solucionaFallo ns1:Alarma_1103 ;
    ns1:textoExtracto "La función O no existe." .

ns1:DiagnosticoFallo_1104 a ns1:DiagnosticoFallo ;
    rdfs:label "Uso incorrecto del carácter '%'" ;
    ns1:solucionaFallo ns1:Alarma_1104 ;
    ns1:textoExtracto "Sólo se permite usar el carácter \"%\" como primer carácter en la definición del nombre del programa principal o de una subrutina local." .

ns1:Alarma_1101 a ns1:Alarma ;
    rdfs:label "Sentencia #SET IPOPOS mal programada" ;
    ns1:identificador "1101" ;
    ns1:textoExtracto "1101 'Sentencia #SET IPOPOS mal programada' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque." .

ns1:Alarma_1102 a ns1:Alarma ;
    rdfs:label "No se admite índice para R distinto de 1" ;
    ns1:identificador "1102" ;
    ns1:textoExtracto "1102 'No se admite índice para R distinto de 1' DETECCIÓN Durante la ejecución. CAUSA Sólo se permite programar el radio con R o R1. SOLUCIÓN Revisar la programación." .

ns1:Alarma_1103 a ns1:Alarma ;
    rdfs:label "Función O inexistente" ;
    ns1:identificador "1103" ;
    ns1:textoExtracto "1103 'Función O inexistente' DETECCIÓN Durante la ejecución. CAUSA La función O no existe. SOLUCIÓN Revisar la programación." .

ns1:Alarma_1104 a ns1:Alarma ;
    rdfs:label "No se admite el carácter '%' dentro del programa principal" ;
    ns1:identificador "1104" ;
    ns1:textoExtracto "1104 'No se admite el carácter \"%\" dentro del programa principal' DETECCIÓN Durante la ejecución. CAUSA Sólo se permite usar el carácter \"%\" como primer carácter en la definición del nombre del programa principal o de una subrutina local. SOLUCIÓN Eliminar este carácter del programa." .

