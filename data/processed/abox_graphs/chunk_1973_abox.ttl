@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error1105 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1105: 'Se espera operador de asignación'" ;
    ns1:textoExtracto "1105 'Se espera operador de asignación' DETECCIÓN Durante la ejecución. CAUSA Falta un operador de asignación tras la variable o parámetro. SOLUCIÓN Los operadores de asignación válidos son \"=\", \"+=\", \"-=\", \"*=\", \"/=\"." .

ns1:Error1106 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1106: 'Se espera \"]\"'" ;
    ns1:textoExtracto "1106 'Se espera \"]\"' DETECCIÓN Durante la ejecución. CAUSA En la expresión o sentencia programada falta el corchete de cierre \"]\". SOLUCIÓN Revisar la programación." .

ns1:Error1107 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1107: 'Eje inexistente o no disponible'" ;
    ns1:textoExtracto "1107 'Eje inexistente o no disponible' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta mover un eje que no existe o que no está disponible en el sistema o en el canal. El eje programado en una sentencia o variable no existe en el sistema o en el canal. SOLUCIÓN Comprobar que el eje programado existe en el canal y que está disponible (que no está aparcado)." .

ns1:Error1108 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1108: 'Eje doblemente programado'" ;
    ns1:textoExtracto "1108 'Eje doblemente programado' DETECCIÓN Durante la ejecución." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:compuestoPor ns1:CanalCNC ;
    ns1:textoExtracto "El CNC intenta mover un eje que no existe o que no está disponible en el sistema o en el canal." .

ns1:CanalCNC a ns1:Componente ;
    rdfs:label "Canal CNC" ;
    ns1:textoExtracto "El eje programado en una sentencia o variable no existe en el sistema o en el canal." .

