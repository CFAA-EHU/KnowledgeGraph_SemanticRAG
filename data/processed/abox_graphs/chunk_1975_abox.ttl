@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_I a ns1:Parametro ;
    rdfs:label "Parámetro I" ;
    ns1:identificador "I" ;
    ns1:monitoreaParametro ns1:Error_1110 ;
    ns1:textoExtracto "Alguno de los parámetros I, J, K está programado más de una vez en el mismo bloque." .

ns1:Parametro_J a ns1:Parametro ;
    rdfs:label "Parámetro J" ;
    ns1:identificador "J" ;
    ns1:monitoreaParametro ns1:Error_1110 ;
    ns1:textoExtracto "Alguno de los parámetros I, J, K está programado más de una vez en el mismo bloque." .

ns1:Parametro_K a ns1:Parametro ;
    rdfs:label "Parámetro K" ;
    ns1:identificador "K" ;
    ns1:monitoreaParametro ns1:Error_1110 ;
    ns1:textoExtracto "Alguno de los parámetros I, J, K está programado más de una vez en el mismo bloque." .

ns1:SistemaControlNumerico a ns1:Sistema ;
    rdfs:label "Sistema de control numérico" ;
    ns1:textoExtracto "el número máximo de ejes del sistema o del canal" ;
    ns1:tieneComponente ns1:Funcion_G20,
        ns1:Funcion_G74 .

ns1:Funcion_G20 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G20 (Selección de plano)" ;
    ns1:identificador "G20" ;
    ns1:monitoreaParametro ns1:Error_1109 ;
    ns1:textoExtracto "Selección de plano, G20." .

ns1:Funcion_G74 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G74" ;
    ns1:identificador "G74" ;
    ns1:monitoreaParametro ns1:Error_1109 ;
    ns1:textoExtracto "En las funciones G20 y G74, el índice programado junto al nombre del eje es incorrecto." .

ns1:Error_1109 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1109: Índice de eje incorrecto" ;
    ns1:identificador "1109" ;
    ns1:textoExtracto "1109 'Indice de eje incorrecto' DETECCIÓN Durante la ejecución. CAUSA En las funciones G20 y G74, el índice programado junto al nombre del eje es incorrecto. SOLUCIÓN El índice del eje debe ser un valor entre 1 y el número máximo de ejes del sistema o del canal." .

ns1:Error_1110 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1110: Valores para I, J, K doblemente programados" ;
    ns1:identificador "1110" ;
    ns1:textoExtracto "1110 'Valores para I, J, K doblemente programados' DETECCIÓN Durante la ejecución. CAUSA Alguno de los parámetros I, J, K está programado más de una vez en el mismo bloque. SOLUCIÓN Revisar la programación." .

