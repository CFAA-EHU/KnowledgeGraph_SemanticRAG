@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorProgramacion_1111 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1111: Sentencias de control $ no programadas solas en el bloque"@es ;
    ns1:identificador "1111" ;
    ns1:solucionaFallo ns1:BloqueProgramacion ;
    ns1:textoExtracto "'Las sentencias de control $ se programan solas en el bloque' DETECCIÓN Durante la ejecución. CAUSA Alguna sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque. La única excepción es programar $IF y $GOTO en el mismo bloque."@es .

ns1:ErrorProgramacion_1112 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1112: Sentencia $IF no seguida exclusivamente por $GOTO"@es ;
    ns1:identificador "1112" ;
    ns1:solucionaFallo ns1:BloqueProgramacion ;
    ns1:textoExtracto "'La sentencia $IF <condición> sólo puede ir seguida de $GOTO' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque y la información adicional no es un $GOTO. SOLUCIÓN Revisar la programación."@es .

ns1:Parametro_I a ns1:Parametro ;
    rdfs:label "Parámetro I"@es ;
    ns1:textoExtracto "Alguno de los parámetros I, J, K está programado más de una vez en el mismo bloque."@es .

ns1:Parametro_J a ns1:Parametro ;
    rdfs:label "Parámetro J"@es ;
    ns1:textoExtracto "Alguno de los parámetros I, J, K está programado más de una vez en el mismo bloque."@es .

ns1:Parametro_K a ns1:Parametro ;
    rdfs:label "Parámetro K"@es ;
    ns1:textoExtracto "Alguno de los parámetros I, J, K está programado más de una vez en el mismo bloque."@es .

ns1:SentenciaControl a ns1:Componente ;
    rdfs:label "Sentencia de control $"@es ;
    ns1:textoExtracto "'Las sentencias de control $ se programan solas en el bloque'."@es .

ns1:Sentencia_GOTO a ns1:Componente ;
    rdfs:label "Sentencia $GOTO"@es ;
    ns1:textoExtracto "La única excepción es programar $IF y $GOTO en el mismo bloque."@es .

ns1:Sentencia_IF a ns1:Componente ;
    rdfs:label "Sentencia $IF"@es ;
    ns1:textoExtracto "La única excepción es programar $IF y $GOTO en el mismo bloque."@es .

ns1:BloqueProgramacion a ns1:Sistema ;
    rdfs:label "Bloque de programación"@es ;
    ns1:monitoreaParametro ns1:Parametro_I,
        ns1:Parametro_J,
        ns1:Parametro_K ;
    ns1:textoExtracto "Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque."@es ;
    ns1:tieneComponente ns1:SentenciaControl,
        ns1:Sentencia_GOTO,
        ns1:Sentencia_IF .

