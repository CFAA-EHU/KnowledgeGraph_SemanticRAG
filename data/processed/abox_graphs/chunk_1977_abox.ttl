@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:activaAlarma ns1:AvisoSeguridad_1113,
        ns1:AvisoSeguridad_1114,
        ns1:AvisoSeguridad_1115 ;
    ns1:textoExtracto "El CNC ha detectado una instrucción $ELSE sin una instrucción $IF previa"@es .

ns1:AvisoSeguridad_1113 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1113: 'No se espera $ELSE'"@es ;
    ns1:identificador "1113" ;
    ns1:textoExtracto "1113 'No se espera $ELSE' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $ELSE sin una instrucción $IF previa. SOLUCIÓN Revisar la programación."@es .

ns1:AvisoSeguridad_1114 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1114: 'La sentencia $ELSE se programa sola en el bloque'"@es ;
    ns1:identificador "1114" ;
    ns1:textoExtracto "1114 'La sentencia $ELSE se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:AvisoSeguridad_1115 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1115: 'No se espera $ELSEIF'"@es ;
    ns1:identificador "1115" ;
    ns1:textoExtracto "1115 'No se espera $ELSEIF' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $ELSEIF sin"@es .

