@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TareaRevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación"@es ;
    ns1:solucionaFallo ns1:Error1115,
        ns1:Error1116,
        ns1:Error1117,
        ns1:Error1118,
        ns1:Error1119,
        ns1:Error1120,
        ns1:Error1121,
        ns1:Error1122,
        ns1:Error1123 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación."@es .

ns1:Error1115 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1115: 'No se espera $ELSEIF'"@es ;
    ns1:identificador "1115" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $ELSEIF sin una instrucción $IF previa. SOLUCIÓN Revisar la programación."@es .

ns1:Error1116 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1116: 'La sentencia $ELSEIF <condición> se programa sola en el bloque'"@es ;
    ns1:identificador "1116" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Error1117 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1117: 'No se espera $ENDIF'"@es ;
    ns1:identificador "1117" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $ENDIF sin una instrucción $IF previa. SOLUCIÓN Revisar la programación."@es .

ns1:Error1118 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1118: 'La sentencia $ENDIF se programa sola en el bloque'"@es ;
    ns1:identificador "1118" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Error1119 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1119: 'La sentencia $SWITCH <expresión> se programa sola en el bloque'"@es ;
    ns1:identificador "1119" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Error1120 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1120: 'No se espera $CASE'"@es ;
    ns1:identificador "1120" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $CASE sin una instrucción $SWITCH previa. SOLUCIÓN Revisar la programación."@es .

ns1:Error1121 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1121: 'La sentencia $CASE <expresión> se programa sola en el bloque'"@es ;
    ns1:identificador "1121" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Error1122 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1122: 'No se espera $DEFAULT'"@es ;
    ns1:identificador "1122" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $DEFAULT sin una instrucción $SWITCH previa. SOLUCIÓN Revisar la programación."@es .

ns1:Error1123 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1123: 'La sentencia $DEFAULT se programa sola en el bloque'"@es ;
    ns1:identificador "1123" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

