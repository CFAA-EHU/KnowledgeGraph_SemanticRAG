@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tarea_RevisionProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación del CNC" ;
    ns1:solucionaFallo ns1:Fallo_1123,
        ns1:Fallo_1124,
        ns1:Fallo_1125 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1123 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1123: Sentencia $DEFAULT mal programada" ;
    ns1:identificador "1123" ;
    ns1:textoExtracto "'La sentencia $DEFAULT se programa sola en el bloque' [...] CAUSA La sentencia no está programada sola en el bloque."@es .

ns1:Fallo_1124 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1124: Instrucción $ENDSWITCH inesperada" ;
    ns1:identificador "1124" ;
    ns1:textoExtracto "'No se espera $ENDSWITCH' [...] CAUSA El CNC ha detectado una instrucción $ENDSWITCH sin una instrucción $SWITCH previa."@es .

ns1:Fallo_1125 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1125: Sentencia $ENDSWITCH mal programada" ;
    ns1:identificador "1125" ;
    ns1:textoExtracto "'La sentencia $ENDSWITCH se programa sola en el bloque'"@es .

