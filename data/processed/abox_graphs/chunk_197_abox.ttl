@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_4_AxisCoordinate a ns1:Parametro ;
    rdfs:label "Axis coordinate highlight"@en ;
    ns1:documentadoEn ns1:Manual_4 ;
    ns1:monitoreaParametro ns1:TareaMantenimiento_4_HomeSearchAutomatic,
        ns1:TareaMantenimiento_4_HomeSearchManual ;
    ns1:textoExtracto "The CNC will highlight the coordinate of that axis."@en .

ns1:Parametro_4_NumericSymbol1 a ns1:Parametro ;
    rdfs:label "Numeric area symbol '1'"@en ;
    ns1:documentadoEn ns1:Manual_4 ;
    ns1:monitoreaParametro ns1:TareaMantenimiento_4_HomeSearchAutomatic,
        ns1:TareaMantenimiento_4_HomeSearchManual ;
    ns1:textoExtracto "The CNC will display the symbol '1' in the numeric area."@en .

ns1:InterfazUsuario_4_Keyboard a ns1:InterfazUsuario ;
    rdfs:label "Keyboard interface for home search"@en ;
    ns1:documentadoEn ns1:Manual_4 ;
    ns1:textoExtracto "Select the axis to be homed (on alphanumeric keyboard). The CNC will highlight the coordinate of that axis. [...] Press the homing key [ZERO]. The CNC will display the symbol '1' in the numeric area."@en .

ns1:InterfazUsuario_4_SoftkeyMenu a ns1:InterfazUsuario ;
    rdfs:label "Softkey menu for home search"@en ;
    ns1:documentadoEn ns1:Manual_4 ;
    ns1:textoExtracto "Press the home search softkey to show the list of axes of the channel. [...] Select the axis to be homed on the softkey menu."@en .

ns1:TareaMantenimiento_4_HomeSearchAutomatic a ns1:TareaMantenimiento ;
    rdfs:label "Automatic home search (with subroutine)"@en ;
    ns1:documentadoEn ns1:Manual_4 ;
    ns1:ejecutadoPor ns1:InterfazUsuario_4_Keyboard,
        ns1:InterfazUsuario_4_SoftkeyMenu ;
    ns1:textoExtracto "Automatic home search (with subroutine). [...] Select the 'All' option on the softkey menu. [...] Press [START] to go ahead with the home search or [ESC] to cancel the operation."@en .

ns1:TareaMantenimiento_4_HomeSearchManual a ns1:TareaMantenimiento ;
    rdfs:label "Manual home search (one axis at a time)"@en ;
    ns1:documentadoEn ns1:Manual_4 ;
    ns1:ejecutadoPor ns1:InterfazUsuario_4_Keyboard,
        ns1:InterfazUsuario_4_SoftkeyMenu ;
    ns1:textoExtracto "The axis-by-axis home search cancels the zero offset, the fixture offset and the measuring offset. [...] Press [START] to go ahead with the home search or [ESC] to cancel the operation."@en .

ns1:Manual_4 a ns1:Manual ;
    rdfs:label "Manual home search (one axis at a time)"@en ;
    ns1:identificador "HOME SEARCH" ;
    ns1:textoExtracto "Manual home search (one axis at a time). The axis-by-axis home search cancels the zero offset, the fixture offset and the measuring offset. The CNC assumes the machine reference zero point (home) as the new part zero."@en .

