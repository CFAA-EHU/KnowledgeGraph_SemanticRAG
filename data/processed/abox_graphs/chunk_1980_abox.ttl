@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1124 a ns1:Alarma ;
    rdfs:label "Alarma 1124: Instrucción $ENDSWITCH sin $SWITCH previa"@es ;
    ns1:identificador "1124" ;
    ns1:textoExtracto "El CNC ha detectado una instrucción $ENDSWITCH sin una instrucción $SWITCH previa. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_1125 a ns1:Alarma ;
    rdfs:label "Alarma 1125: Sentencia $ENDSWITCH no programada sola en bloque"@es ;
    ns1:identificador "1125" ;
    ns1:monitoreaParametro ns1:Parametro_ENDSWITCH ;
    ns1:textoExtracto "'La sentencia $ENDSWITCH se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_1126 a ns1:Alarma ;
    rdfs:label "Alarma 1126: Variable contador $FOR no válida"@es ;
    ns1:identificador "1126" ;
    ns1:monitoreaParametro ns1:Parametro_FOR_Contador ;
    ns1:textoExtracto "'$FOR: variable contador no válida' DETECCIÓN Durante la ejecución. CAUSA El contador de la instrucción $FOR no es válido. SOLUCIÓN El contador de la instrucción $FOR podrá ser una variable o parámetro aritmético."@es .

ns1:Alarma_1127 a ns1:Alarma ;
    rdfs:label "Alarma 1127: Sentencia $FOR <condición> no programada sola en bloque"@es ;
    ns1:identificador "1127" ;
    ns1:monitoreaParametro ns1:Parametro_FOR_Condicion ;
    ns1:textoExtracto "'La sentencia $FOR <condición> se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_1128 a ns1:Alarma ;
    rdfs:label "Alarma 1128: Exceso de caracteres en condición $FOR"@es ;
    ns1:identificador "1128" ;
    ns1:monitoreaParametro ns1:Parametro_FOR_LongitudMaxima ;
    ns1:textoExtracto "'$FOR: demasiados caracteres en la condición' DETECCIÓN Durante la ejecución. CAUSA El bloque que contiene la instrucción $FOR tiene más de 5100 caracteres. SOLUCIÓN Escribir el bloque que contiene la instrucción $FOR más breve."@es .

ns1:Alarma_1129 a ns1:Alarma ;
    rdfs:label "Alarma 1129: Instrucción $ENDFOR sin $FOR previa"@es ;
    ns1:identificador "1129" ;
    ns1:monitoreaParametro ns1:Parametro_ENDFOR ;
    ns1:textoExtracto "'No se espera $ENDFOR' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $ENDFOR sin una instrucción $FOR previa. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_1130 a ns1:Alarma ;
    rdfs:label "Alarma 1130: Sentencia $ENDFOR no programada sola en bloque"@es ;
    ns1:identificador "1130" ;
    ns1:monitoreaParametro ns1:Parametro_ENDFOR ;
    ns1:textoExtracto "'La sentencia $ENDFOR se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_1131 a ns1:Alarma ;
    rdfs:label "Alarma 1131: Sentencia $WHILE <condición> no programada sola en bloque"@es ;
    ns1:identificador "1131" ;
    ns1:monitoreaParametro ns1:Parametro_WHILE_Condicion ;
    ns1:textoExtracto "'La sentencia $WHILE <condición> se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_1132 a ns1:Alarma ;
    rdfs:label "Alarma 1132: Exceso de caracteres en condición $WHILE"@es ;
    ns1:identificador "1132" ;
    ns1:monitoreaParametro ns1:Parametro_WHILE_LongitudMaxima ;
    ns1:textoExtracto "'$WHILE: demasiados caracteres en la condición' DETECCIÓN Durante la ejecución. CAUSA La condición de la instrucción $WHILE supera el máximo número de caracteres permitidos. SOLUCIÓN El máximo número de caracteres permitidos es 5000."@es .

ns1:Alarma_1133 a ns1:Alarma ;
    rdfs:label "Alarma 1133: Instrucción $ENDWHILE sin $WHILE previa"@es ;
    ns1:identificador "1133" ;
    ns1:textoExtracto "'No se espera $ENDWHILE' DETECCIÓN Durante la ejecución."@es .

ns1:Parametro_ENDSWITCH a ns1:Parametro ;
    rdfs:label "Parámetro: Instrucción $ENDSWITCH"@es ;
    ns1:textoExtracto "instrucción $ENDSWITCH"@es ;
    ns1:valor "$ENDSWITCH" .

ns1:Parametro_FOR_Condicion a ns1:Parametro ;
    rdfs:label "Parámetro: Condición $FOR"@es ;
    ns1:textoExtracto "sentencia $FOR <condición>"@es ;
    ns1:valor "<condición>" .

ns1:Parametro_FOR_Contador a ns1:Parametro ;
    rdfs:label "Parámetro: Variable contador $FOR"@es ;
    ns1:textoExtracto "El contador de la instrucción $FOR podrá ser una variable o parámetro aritmético."@es ;
    ns1:valor "variable/parámetro aritmético" .

ns1:Parametro_FOR_LongitudMaxima a ns1:Parametro ;
    rdfs:label "Parámetro: Longitud máxima bloque $FOR"@es ;
    ns1:textoExtracto "El bloque que contiene la instrucción $FOR tiene más de 5100 caracteres."@es ;
    ns1:valor "5100" .

ns1:Parametro_WHILE_Condicion a ns1:Parametro ;
    rdfs:label "Parámetro: Condición $WHILE"@es ;
    ns1:textoExtracto "sentencia $WHILE <condición>"@es ;
    ns1:valor "<condición>" .

ns1:Parametro_WHILE_LongitudMaxima a ns1:Parametro ;
    rdfs:label "Parámetro: Longitud máxima condición $WHILE"@es ;
    ns1:textoExtracto "El máximo número de caracteres permitidos es 5000."@es ;
    ns1:valor "5000" .

ns1:Parametro_ENDFOR a ns1:Parametro ;
    rdfs:label "Parámetro: Instrucción $ENDFOR"@es ;
    ns1:textoExtracto "instrucción $ENDFOR"@es ;
    ns1:valor "$ENDFOR" .

