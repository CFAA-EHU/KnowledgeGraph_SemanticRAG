@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error1132 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1132: Condición $WHILE excede caracteres permitidos" ;
    ns1:identificador "1132" ;
    ns1:textoExtracto "CAUSA La condición de la instrucción $WHILE supera el máximo número de caracteres permitidos. SOLUCIÓN El máximo número de caracteres permitidos es 5000." ;
    ns1:valor "5000" .

ns1:Error1133 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1133: 'No se espera $ENDWHILE'" ;
    ns1:identificador "1133" ;
    ns1:textoExtracto "1133 'No se espera $ENDWHILE' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una instrucción $ENDWHILE sin una instrucción $WHILE previa. SOLUCIÓN Revisar la programación." .

ns1:Error1134 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1134: 'La sentencia $ENDWHILE se programa sola en el bloque'" ;
    ns1:identificador "1134" ;
    ns1:textoExtracto "1134 'La sentencia $ENDWHILE se programa sola en el bloque' DETECCIÓN Durante la" .

