@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_ProgramacionEntreGYPrimerMovimiento a ns1:AccionProhibida ;
    rdfs:label "Programar bloque entre función G de empalme y primer movimiento" ;
    ns1:textoExtracto "SOLUCIÓN No programar ningún bloque entre la función G que define la trayectoria de empalme y el primer bloque de movimiento." .

ns1:AvisoSeguridad_1152 a ns1:AvisoSeguridad ;
    rdfs:label "Anidamiento de subrutinas sobrepasado" ;
    ns1:identificador "1152" ;
    ns1:textoExtracto "1152 'Anidamiento de subrutinas sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha superado el número de niveles de imbricación permitido. SOLUCIÓN Corregir el programa reduciendo el número de llamadas a subrutinas (locales y globales) que implican un nuevo nivel de imbricación. El CNC permite 20 niveles de imbricación." .

ns1:AvisoSeguridad_1153 a ns1:AvisoSeguridad ;
    rdfs:label "Demasiadas subrutinas" ;
    ns1:identificador "1153" ;
    ns1:textoExtracto "1153 'Demasiadas subrutinas" .

