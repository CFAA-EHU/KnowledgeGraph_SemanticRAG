@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_1156 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1156: Programa principal no encontrado" ;
    ns1:identificador "1156" ;
    ns1:solucionaFallo ns1:Solucion_1156 ;
    ns1:textoExtracto "'Programa principal no encontrado' DETECCIÓN Durante la ejecución. CAUSA El CNC no encuentra el programa principal." .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación del CNC" ;
    ns1:documentadoEn ns1:Error_1155 ;
    ns1:textoExtracto "consulte el manual de programación" .

ns1:Error_1155 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1155: Acceso denegado a fichero" ;
    ns1:identificador "1155" ;
    ns1:solucionaFallo ns1:Solucion_1155 ;
    ns1:textoExtracto "No se puede acceder al fichero. DETECCIÓN Durante la ejecución. CAUSA No es posible abrir el fichero programado en la instrucción. La programación del fichero puede ser directa o estar asociado a un elemento del bloque (función G con subrutina asociada)." .

ns1:Solucion_1155 a ns1:TareaMantenimiento ;
    rdfs:label "Solución para error 1155" ;
    ns1:textoExtracto "Comprobar que el archivo existe, es válido y no está corrupto. En el caso de las llamadas a subrutinas comprobar que el nombre y el path son correctos. Si en la llamada a la subrutina no está definido el path, el CNC aplicará el criterio de búsqueda por defecto (consulte el manual de programación)." .

ns1:Solucion_1156 a ns1:TareaMantenimiento ;
    rdfs:label "Solución para error 1156" ;
    ns1:textoExtracto "En un programa con subrutinas locales, el programa principal debe tener un nombre (%nombre)." .

