@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ControlEjesJog a ns1:Sistema ;
    rdfs:label "Axis Jog Control System" ;
    ns1:compuestoPor ns1:Actuador_VolanteGeneral,
        ns1:Actuador_VolanteIndividual,
        ns1:InterfazUsuario_PanelJog,
        ns1:InterfazUsuario_SelectorJog ;
    ns1:controla ns1:ModoOperacion_JogConVolanteGeneral,
        ns1:ModoOperacion_JogConVolanteIndividual,
        ns1:ModoOperacion_JogContinuo,
        ns1:ModoOperacion_JogIncremental ;
    ns1:textoExtracto "The CNC will move [the axis] as the handwheel is turned... The CNC moves each axis as its relevant handwheel is turned." .

ns1:Actuador_VolanteGeneral a ns1:Actuador ;
    rdfs:label "General Handwheel" ;
    ns1:textoExtracto "General handwheel (it may be used to jog any axis of the machine)." .

ns1:Actuador_VolanteIndividual a ns1:Actuador ;
    rdfs:label "Individual Handwheel" ;
    ns1:textoExtracto "Individual handwheel (it is associated with a particular axis)." .

ns1:InterfazUsuario_PanelJog a ns1:InterfazUsuario ;
    rdfs:label "JOG Panel (Keypad)" ;
    ns1:textoExtracto "Jog the desired axis using the JOG panel (keypad)... The CNC will highlight the selected axes on the jog keyboard." .

ns1:InterfazUsuario_SelectorJog a ns1:InterfazUsuario ;
    rdfs:label "Jog Selector Switch" ;
    ns1:textoExtracto "Turn the jog selector switch to the continuous JOG position... Turn the jog selector switch to one of the incremental jog positions... Turn the jog selector switch to one of the handwheel positions." .

ns1:ModoOperacion_JogConVolanteGeneral a ns1:ModoOperacion ;
    rdfs:label "Handwheel Jog Mode (General)" ;
    ns1:textoExtracto "Jogging the axes with handwheels. General handwheel (it may be used to jog any axis of the machine)." .

ns1:ModoOperacion_JogConVolanteIndividual a ns1:ModoOperacion ;
    rdfs:label "Handwheel Jog Mode (Individual)" ;
    ns1:textoExtracto "Individual handwheel (it is associated with a particular axis). The CNC moves each axis as its relevant handwheel is turned depending on the setting of the selector switch and on the turning direction of the handwheel." .

ns1:ModoOperacion_JogContinuo a ns1:ModoOperacion ;
    rdfs:label "Continuous Jog Mode" ;
    ns1:textoExtracto "Movement in continuous jog. In continuous jog, the axes keep moving while the jog keyboard is acted upon." .

ns1:ModoOperacion_JogIncremental a ns1:ModoOperacion ;
    rdfs:label "Incremental Jog Mode" ;
    ns1:textoExtracto "Movement in incremental jog. In incremental jog, the axis moves a specific distance every time the key is pressed." .

