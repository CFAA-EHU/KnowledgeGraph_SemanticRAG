@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1160_1 a ns1:DiagnosticoFallo ;
    rdfs:label "Subrutina local no definida en programa principal" ;
    ns1:solucionaFallo ns1:Alarma_1160 ;
    ns1:textoExtracto "La subrutina local no está definida al principio del programa principal." .

ns1:DiagnosticoFallo_1160_2 a ns1:DiagnosticoFallo ;
    rdfs:label "Conflicto entre subrutina local modal y subrutina de usuario" ;
    ns1:solucionaFallo ns1:Alarma_1160 ;
    ns1:textoExtracto "El programa ha activado un subrutina local como modal, y a continuación ha ejecutado una subrutina de usuario (por ejemplo, G500 a G599) con bloques de movimiento. La subrutina de usuario no encuentra la subrutina local porque pertenece a otro programa." .

ns1:Solucion_1160_1 a ns1:TareaMantenimiento ;
    rdfs:label "Verificar coincidencia de nombres de subrutina" ;
    ns1:solucionaFallo ns1:Alarma_1160 ;
    ns1:textoExtracto "Comprobar que el nombre de la subrutina local en el bloque de llamada es idéntico al nombre que aparece en su definición." .

ns1:Solucion_1160_2 a ns1:TareaMantenimiento ;
    rdfs:label "Definir subrutina local al inicio del programa" ;
    ns1:solucionaFallo ns1:Alarma_1160 ;
    ns1:textoExtracto "Las subrutinas locales deben estar definidas al principio del programa." .

ns1:Solucion_1160_3 a ns1:TareaMantenimiento ;
    rdfs:label "Redefinir subrutina local como global" ;
    ns1:solucionaFallo ns1:Alarma_1160 ;
    ns1:textoExtracto "Definir la subrutina local como global." .

ns1:Solucion_NombreSubrutina a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación de nombres de subrutina" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_NombreSubrutinaInvalido ;
    ns1:textoExtracto "Revisar la programación." .

ns1:DiagnosticoFallo_NombreSubrutinaInvalido a ns1:DiagnosticoFallo ;
    rdfs:label "Nombre de subrutina excede límite de caracteres" ;
    ns1:activaAlarma ns1:Alarma_1160 ;
    ns1:textoExtracto "El nombre de la subrutina supera el número de caracteres permitido por el CNC. El nombre de una subrutina puede tener un máximo de 63 caracteres." .

ns1:Alarma_1160 a ns1:Alarma ;
    rdfs:label "Alarma 1160: Subrutina local no encontrada" ;
    ns1:identificador "1160" ;
    ns1:textoExtracto "'1160 'Subrutina local no encontrada' DETECCIÓN Durante la ejecución. CAUSA El CNC no encuentra la subrutina local." .

