@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:activaAlarma ns1:Alarma_1161,
        ns1:Alarma_1162 ;
    ns1:textoExtracto "El CNC ha encontrado un bloque de control \"$\" que no tiene su correspondiente instrucción de cierre." .

ns1:Alarma_1161 a ns1:Alarma ;
    rdfs:label "Bloques de control $ abiertos" ;
    ns1:identificador "1161" ;
    ns1:textoExtracto "1161 'Bloques de control $ abiertos' DETECCIÓN Durante la ejecución. CAUSA El CNC ha encontrado un bloque de control \"$\" que no tiene su correspondiente instrucción de cierre. SOLUCIÓN Revisar la programación." .

ns1:Alarma_1162 a ns1:Alarma ;
    rdfs:label "No se espera M17/M29/#RET" ;
    ns1:identificador "1162" ;
    ns1:textoExtracto "1162 'No se espera M17/M29/#RET' DETECCIÓN Durante la ejecución. CAUSA El CNC ha" .

