@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BloqueControlIncompleto a ns1:DiagnosticoFallo ;
    rdfs:label "Bloque de control '$' sin instrucción de cierre" ;
    ns1:textoExtracto "un bloque de control \"$\" que no tiene su correspondiente instrucción de cierre. SOLUCIÓN Revisar la programación." .

ns1:CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "El CNC ha detectado una función M17, M29 o #RET como final de programa." .

ns1:Error1162 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1162: 'No se espera M17/M29/#RET'" ;
    ns1:identificador "1162" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una función M17, M29 o #RET como final de programa. SOLUCIÓN Programar M30/M02 como final de programa principal. Si el error persiste, comprobar que todas las subrutinas locales finalizan con M17, M29 o #RET." .

ns1:Error1163 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1163: 'No se espera M30/M02'" ;
    ns1:identificador "1163" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado una función M02 o M30 como final de subrutina. SOLUCIÓN Comprobar que todas las subrutinas locales y globales finalizan con M17, M29 o #RET." .

ns1:Error1164 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1164: 'Término desconocido en expresión matemática'" ;
    ns1:identificador "1164" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La expresión matemática es incorrecta. SOLUCIÓN Revisar todos los términos de la expresión; variables, parámetros, operadores, etc." .

ns1:Error1165 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1165: 'Variable inexistente'" ;
    ns1:identificador "1165" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • La variable pedida no existe. • Error sintáctico en el nombre de la variable. • La variable es un array y no se ha indicado índice de array. • Se ha pedido una variable general para un eje determinado o a la inversa. SOLUCIÓN Revisar la programación." .

ns1:Error1166 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1166: 'Raíz de un número negativo'" ;
    ns1:identificador "1166" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA En la expresión matemática hay una raíz cuadrada (SQRT) de un número negativo. SOLUCIÓN Revisar la programación." .

ns1:Error1167 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1167: 'Logaritmo de un número negativo o cero'" ;
    ns1:identificador "1167" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA En la expresión matemática hay un logaritmo (LOG/LN) de un número negativo o cero. SOLUCIÓN Revisar la programación." .

ns1:Error1168 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1168: 'Índice de variable fuera de rango'" ;
    ns1:identificador "1168" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución." .

