@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_1168 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1168: Índice de variable fuera de rango"@es ;
    ns1:identificador "1168" ;
    ns1:textoExtracto "1168 'Indice de variable fuera de rango' [...] DETECCIÓN Durante la ejecución. CAUSA Alguno de los índices definidos en la variable de array es incorrecto. SOLUCIÓN El índice mínimo admisible para una variable de array es 1 y el máximo depende de la variable de la que se trate. Hay algunos casos particulares en los que el índice 0 es admitido: G.GS, G.MS, G.LUP1 a G.LUP7, G.LUPACT y MTB.P."@es .

ns1:Error_1169 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1169: Logaritmo de número no válido"@es ;
    ns1:identificador "1169" ;
    ns1:textoExtracto "CAUSA En la expresión matemática hay un logaritmo (LOG/LN) de un número negativo o cero. SOLUCIÓN Revisar la programación."@es .

ns1:Variable_G_GS a ns1:Parametro ;
    rdfs:label "G.GS" ;
    ns1:identificador "G.GS" ;
    ns1:textoExtracto "casos particulares en los que el índice 0 es admitido: G.GS, [...]"@es .

ns1:Variable_G_LUP1 a ns1:Parametro ;
    rdfs:label "G.LUP1" ;
    ns1:identificador "G.LUP1" ;
    ns1:textoExtracto "casos particulares en los que el índice 0 es admitido: [...], G.LUP1 a G.LUP7, [...]"@es .

ns1:Variable_G_LUP7 a ns1:Parametro ;
    rdfs:label "G.LUP7" ;
    ns1:identificador "G.LUP7" ;
    ns1:textoExtracto "casos particulares en los que el índice 0 es admitido: [...], G.LUP1 a G.LUP7, [...]"@es .

ns1:Variable_G_LUPACT a ns1:Parametro ;
    rdfs:label "G.LUPACT" ;
    ns1:identificador "G.LUPACT" ;
    ns1:textoExtracto "casos particulares en los que el índice 0 es admitido: [...], G.LUPACT, [...]"@es .

ns1:Variable_G_MS a ns1:Parametro ;
    rdfs:label "G.MS" ;
    ns1:identificador "G.MS" ;
    ns1:textoExtracto "casos particulares en los que el índice 0 es admitido: [...], G.MS, [...]"@es .

ns1:Variable_MTB_P a ns1:Parametro ;
    rdfs:label "MTB.P" ;
    ns1:identificador "MTB.P" ;
    ns1:textoExtracto "casos particulares en los que el índice 0 es admitido: [...], MTB.P."@es .

