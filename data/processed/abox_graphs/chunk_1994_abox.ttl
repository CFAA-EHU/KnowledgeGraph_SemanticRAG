@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_1169 a ns1:AvisoSeguridad ;
    rdfs:label "Error de programación: Sentencia #GET IPOOFFSET no programada sola en el bloque"@es ;
    ns1:identificador "1169" ;
    ns1:textoExtracto "La sentencia #GET IPOOFFSET se programa sola en el bloque. DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque."@es .

ns1:AvisoSeguridad_1170 a ns1:AvisoSeguridad ;
    rdfs:label "Error de programación: Sentencia #SYNC POS no programada sola en el bloque"@es ;
    ns1:identificador "1170" ;
    ns1:textoExtracto "'La sentencia #SYNC POS se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque."@es .

ns1:AvisoSeguridad_1171 a ns1:AvisoSeguridad ;
    rdfs:label "Error de programación: Sentencias # no programadas solas en el bloque"@es ;
    ns1:identificador "1171" ;
    ns1:textoExtracto "'Las sentencias # se programan solas en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque. La única excepción es la sentencia #AXIS que se debe programar en el mismo bloque que la función G201."@es .

ns1:AvisoSeguridad_1172 a ns1:AvisoSeguridad ;
    rdfs:label "Error de compensación: Sentencia no permitida con compensación de radio de herramienta activa"@es ;
    ns1:identificador "1172" ;
    ns1:requiereMantenimiento ns1:TareaMantenimiento_DesactivarCompensacionRadio ;
    ns1:textoExtracto "'Sentencia no permitida con compensación de radio de herramienta activa' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar una sentencia incompatible con la compensación de radio. SOLUCIÓN Desactivar la compensación de radio para ejecutar la sentencia."@es .

ns1:AvisoSeguridad_1173 a ns1:AvisoSeguridad ;
    rdfs:label "Error de programación: Sentencia #UNLINK no programada sola en el bloque"@es ;
    ns1:identificador "1173" ;
    ns1:textoExtracto "'La sentencia #UNLINK se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:AvisoSeguridad_1174 a ns1:AvisoSeguridad ;
    rdfs:label "Error de acoplo: Definición de nuevo acoplo con uno anterior activo"@es ;
    ns1:identificador "1174" ;
    ns1:textoExtracto "'#LINK: no se permite definir un nuevo acoplo con uno anterior activo' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar un segundo acoplo de ejes sin desactivar el primero. SOLUCIÓN Revisar la programación."@es .

ns1:Herramienta_CNC a ns1:Herramienta ;
    rdfs:label "Herramienta CNC con compensación de radio"@es ;
    ns1:requiereMantenimiento ns1:TareaMantenimiento_DesactivarCompensacionRadio ;
    ns1:textoExtracto "compensación de radio de herramienta activa"@es .

ns1:TareaMantenimiento_DesactivarCompensacionRadio a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar compensación de radio de herramienta"@es ;
    ns1:textoExtracto "Desactivar la compensación de radio para ejecutar la sentencia."@es .

