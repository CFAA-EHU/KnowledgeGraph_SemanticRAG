@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Solucion_1174_DesactivarAcoplo a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar acoplo previo antes de activar nuevo"@es ;
    ns1:solucionaFallo ns1:Fallo_1174 ;
    ns1:textoExtracto "Desactivar el primer acoplo antes de activar el segundo."@es .

ns1:Solucion_1174_RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación de acoplos"@es ;
    ns1:solucionaFallo ns1:Fallo_1174,
        ns1:Fallo_1175 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación."@es .

ns1:Solucion_1174_SentenciaUnica a ns1:TareaMantenimiento ;
    rdfs:label "Activar acoplos con sentencia única #LINK"@es ;
    ns1:solucionaFallo ns1:Fallo_1174 ;
    ns1:textoExtracto "Para tener ambos acoplos, desactivar el primer acoplo y activar ambos con una única sentencia #LINK."@es .

ns1:Fallo_1175 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de acoplo de ejes incompleto"@es ;
    ns1:identificador "1175" ;
    ns1:textoExtracto "'#LINK: no"@es .

ns1:Fallo_1174 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de acoplo de ejes activo"@es ;
    ns1:identificador "1174" ;
    ns1:textoExtracto "Durante la ejecución. El CNC ha intentado activar un segundo acoplo de ejes sin desactivar el primero."@es .

