@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1180 a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad de tipo de eje (AXISTYPE)" ;
    ns1:identificador "1180" ;
    ns1:monitoreaParametro ns1:Parametro_AXISTYPE ;
    ns1:textoExtracto "Los ejes maestro y esclavo del acoplo no son del mismo tipo, lineal o rotativo. Ambos ejes de un acoplo deben ser del mismo tipo (parámetro AXISTYPE)." .

ns1:Fallo_1181 a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad de modo de eje rotativo (AXISMODE)" ;
    ns1:identificador "1181" ;
    ns1:monitoreaParametro ns1:Parametro_AXISMODE ;
    ns1:textoExtracto "Los ejes maestro y esclavo del acoplo son rotativos pero no son del mismo tipo, linearlike o modulo. Ambos ejes de un acoplo deben ser del mismo tipo (parámetro AXISMODE)." .

ns1:ModoOperacion_Ejecucion a ns1:ModoOperacion ;
    rdfs:label "Ejecución" ;
    ns1:textoExtracto "Durante la ejecución." .

ns1:Parametro_AXISMODE a ns1:Parametro ;
    rdfs:label "AXISMODE" ;
    ns1:textoExtracto "parámetro AXISMODE" .

ns1:Parametro_AXISTYPE a ns1:Parametro ;
    rdfs:label "AXISTYPE" ;
    ns1:textoExtracto "parámetro AXISTYPE" .

