@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error1187 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1187: '#AXIS: nombre de eje repetido'" ;
    ns1:identificador "1187" ;
    ns1:textoExtracto "1187 '#AXIS: nombre de eje repetido' [...] DETECCIÓN Durante la ejecución. CAUSA El mismo eje se ha programado más de una vez en la sentencia. SOLUCIÓN Revisar la programación." .

ns1:Error1188 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1188: 'No se espera \"[\"'" ;
    ns1:identificador "1188" ;
    ns1:textoExtracto "1188 'No se espera \"[\"' [...] DETECCIÓN Durante la ejecución. CAUSA Error en la sintaxis de la sentencia. SOLUCIÓN Revisar la programación." .

ns1:Error1189 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1189: '#MPG: demasiados parámetros'" ;
    ns1:identificador "1189" ;
    ns1:textoExtracto "1189 '#MPG: demasiados parámetros' [...] DETECCIÓN Durante la ejecución. CAUSA La sentencia tiene más parámetros de los permitidos. SOLUCIÓN La sentencia #MPG admite un máximo de tres" .

ns1:ParametroMPG a ns1:Parametro ;
    rdfs:label "Parámetro #MPG" ;
    ns1:textoExtracto "La sentencia #MPG admite un máximo de tres [parámetros]" ;
    ns1:valor "3" .

