@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_Keyboard_CoordinatePreset a ns1:InterfazUsuario ;
    rdfs:label "Keyboard Interface for Coordinate Preset"@en ;
    ns1:textoExtracto "The [ESC] key may be used to cancel the operation at any time. [...] 1 Select the axis to be preset (on alphanumeric keyboard). The CNC will highlight the coordinate of that axis. [...] 2 Key in the desired preset value. [...] 3 Press [ENTER] to assume the entered value."@en ;
    ns1:tieneComponente ns1:Tecla_ENTER,
        ns1:Tecla_ESC .

ns1:InterfazUsuario_SoftkeyMenu_CoordinatePreset a ns1:InterfazUsuario ;
    rdfs:label "Softkey Menu for Coordinate Preset"@en ;
    ns1:textoExtracto "1 Press the softkey for presetting axes to show the list of axes of the channel and select an axis. [...] 2 Key in the desired preset value. [...] 3 Press [ENTER] to assume the entered value."@en .

ns1:Tecla_ENTER a ns1:ComponenteElectrico ;
    rdfs:label "ENTER Key"@en ;
    ns1:textoExtracto "3 Press [ENTER] to assume the entered value."@en .

ns1:Tecla_ESC a ns1:ComponenteElectrico ;
    rdfs:label "ESC Key"@en ;
    ns1:textoExtracto "The [ESC] key may be used to cancel the operation at any time."@en .

