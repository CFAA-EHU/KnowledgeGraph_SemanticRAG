@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_1189 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1189: '#MPG: demasiados parámetros'"@es ;
    ns1:identificador "1189" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sentencia tiene más parámetros de los permitidos. SOLUCIÓN La sentencia #MPG admite un máximo de tres parámetros. Cada uno de ellos representa el desplazamiento por impulso del volante en cada posición del conmutador."@es .

ns1:Error_1190 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1190: '#MPG: no se permiten resoluciones de volante negativas o cero'"@es ;
    ns1:identificador "1190" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sentencia #MPG intenta definir una resolución de volante negativa o nula. SOLUCIÓN El desplazamiento por impulso del volante debe ser un valor positivo y no nulo."@es .

ns1:Error_1191 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1191: '#INCJOG: no se permiten distancias de jog incremental negativas o cero'"@es ;
    ns1:identificador "1191" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sentencia #INCJOG intenta definir una distancia negativa o nula. SOLUCIÓN El desplazamiento incremental del eje en cada posición del conmutador debe ser un valor positivo y no nulo."@es .

ns1:Error_1192 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1192: '#INCJOG: no se permiten velocidades de jog incremental negativas o cero'"@es ;
    ns1:identificador "1192" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sentencia #INCJOG intenta definir un avance negativo o nulo. SOLUCIÓN El avance del eje en cada posición del conmutador debe ser un valor positivo y no nulo."@es .

ns1:Error_1193 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1193: '#CONTJOG/#INCJOG: avance programado fuera de rango'"@es ;
    ns1:identificador "1193" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El avance programado es demasiado alto. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1194 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1194: '#INCJOG: demasiados parámetros'"@es ;
    ns1:identificador "1194" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sentencia tiene más parámetros de los permitidos. SOLUCIÓN La sentencia #INCJOG admite un máximo de cinco grupos de parámetros. Cada uno de ellos representa el avance y el desplazamiento del eje para cada posición del conmutador en jog incremental."@es .

ns1:Error_1195 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1195: '#CONTJOG: demasiados parámetros'"@es ;
    ns1:identificador "1195" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución."@es .

ns1:Parametro_INCJOG_Desplazamiento a ns1:Parametro ;
    rdfs:label "Parámetro de desplazamiento incremental del eje (INCJOG)"@es ;
    ns1:textoExtracto "El desplazamiento incremental del eje en cada posición del conmutador debe ser un valor positivo y no nulo."@es .

ns1:Parametro_INCJOG_Velocidad a ns1:Parametro ;
    rdfs:label "Parámetro de avance/velocidad del eje (INCJOG)"@es ;
    ns1:textoExtracto "El avance del eje en cada posición del conmutador debe ser un valor positivo y no nulo."@es .

ns1:Parametro_MPG_Desplazamiento a ns1:Parametro ;
    rdfs:label "Parámetro de desplazamiento por impulso del volante (MPG)"@es ;
    ns1:textoExtracto "Cada uno de ellos representa el desplazamiento por impulso del volante en cada posición del conmutador."@es .

ns1:Parametro_MPG_ResolucionVolante a ns1:Parametro ;
    rdfs:label "Parámetro de resolución de volante (MPG)"@es ;
    ns1:textoExtracto "El desplazamiento por impulso del volante debe ser un valor positivo y no nulo."@es .

