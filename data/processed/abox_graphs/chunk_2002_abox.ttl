@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_1196 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1196: '#CONTJOG: no se permiten velocidades de jog continuo negativas o cero'"@es ;
    ns1:identificador "1196" ;
    ns1:monitoreaParametro ns1:Parametro_AvanceJogContinuo ;
    ns1:textoExtracto "La sentencia #CONTJOG sólo admite un parámetro, que representa el avance del eje cuando el conmutador está en jog continuo. [...] DETECCIÓN Durante la ejecución. CAUSA La sentencia #CONTJOG intenta definir un avance negativo o nulo. SOLUCIÓN El avance del eje en jog continuo debe ser un valor positivo y no nulo."@es .

ns1:Error_1197 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1197: '#SET OFFSET: offset inferior positivo'"@es ;
    ns1:identificador "1197" ;
    ns1:monitoreaParametro ns1:Parametro_LimiteInferiorOffset ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El límite de recorrido inferior del eje para el desplazamiento manual tiene un valor positivo. SOLUCIÓN El límite de recorrido inferior para el desplazamiento manual ser un valor negativo o cero."@es .

ns1:Error_1198 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1198: '#SET OFFSET: límite negativo fuera de rango'"@es ;
    ns1:identificador "1198" ;
    ns1:monitoreaParametro ns1:Parametro_LimiteInferiorOffset ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El valor del límite de recorrido inferior es demasiado bajo. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1199 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1199: '#SET OFFSET: offset superior negativo'"@es ;
    ns1:identificador "1199" ;
    ns1:monitoreaParametro ns1:Parametro_LimiteSuperiorOffset ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El límite de recorrido superior del eje para el desplazamiento manual tiene un valor negativo. SOLUCIÓN El límite de recorrido superior para el desplazamiento manual ser un valor positivo o cero."@es .

ns1:Error_1200 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1200: '#SET OFFSET: límite positivo fuera de rango'"@es ;
    ns1:identificador "1200" ;
    ns1:monitoreaParametro ns1:Parametro_LimiteSuperiorOffset ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El valor del límite de recorrido superior es demasiado alto. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1201 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1201: '#SET OFFSET: offset superior e inferior nulos'"@es ;
    ns1:identificador "1201" ;
    ns1:monitoreaParametro ns1:Parametro_LimiteInferiorOffset,
        ns1:Parametro_LimiteSuperiorOffset ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Los límites de recorrido del eje para el desplazamiento manual son nulos. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1202 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1202: '#SET IPOPOS: demasiados parámetros'"@es ;
    ns1:identificador "1202" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sentencia tiene demasiados parámetros. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1203 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1203: 'La sentencia #SET IPOPOS se programa sola en el bloque'"@es ;
    ns1:identificador "1203" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución."@es .

ns1:Parametro_AvanceJogContinuo a ns1:Parametro ;
    rdfs:label "Parámetro de avance en jog continuo"@es ;
    ns1:textoExtracto "La sentencia #CONTJOG sólo admite un parámetro, que representa el avance del eje cuando el conmutador está en jog continuo."@es ;
    ns1:valor "positivo y no nulo"@es .

ns1:Parametro_LimiteInferiorOffset a ns1:Parametro ;
    rdfs:label "Límite de recorrido inferior (offset)"@es ;
    ns1:textoExtracto "El límite de recorrido inferior del eje para el desplazamiento manual."@es .

ns1:Parametro_LimiteSuperiorOffset a ns1:Parametro ;
    rdfs:label "Límite de recorrido superior (offset)"@es ;
    ns1:textoExtracto "El límite de recorrido superior del eje para el desplazamiento manual."@es .

