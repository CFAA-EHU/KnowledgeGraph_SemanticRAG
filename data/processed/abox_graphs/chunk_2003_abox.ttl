@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_1202 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1202: Demasiados parámetros en #SET IPOPOS"@es ;
    ns1:identificador "1202" ;
    ns1:textoExtracto "#SET IPOPOS: demasiados parámetros. DETECCIÓN Durante la ejecución. CAUSA La sentencia tiene demasiados parámetros. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1203 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1203: Sentencia #SET IPOPOS no programada sola en el bloque"@es ;
    ns1:identificador "1203" ;
    ns1:textoExtracto "'La sentencia #SET IPOPOS se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1204 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1204: Sentencia mal programada o inexistente"@es ;
    ns1:identificador "1204" ;
    ns1:textoExtracto "'Sentencia mal programada o inexistente' DETECCIÓN Durante la ejecución. CAUSA La sentencia no existe o está mal programada. SOLUCIÓN Revisar la"@es .

