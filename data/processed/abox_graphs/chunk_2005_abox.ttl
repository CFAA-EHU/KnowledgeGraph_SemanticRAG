@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1214 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1214: Demasiados ejes en configuración"@es ;
    ns1:identificador "1214" ;
    ns1:textoExtracto "#CALL AX/#SET AX: demasiados ejes"@es .

ns1:Funcion_G63 a ns1:ModoOperacion ;
    rdfs:label "Función G63 (roscado)"@es ;
    ns1:identificador "G63" ;
    ns1:textoExtracto "No se permite programar #CALL AX con la función G63 activa."@es .

ns1:Tarea_DesactivarG63 a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar roscado G63"@es ;
    ns1:solucionaFallo ns1:Fallo_1213 ;
    ns1:textoExtracto "SOLUCIÓN Desactivar el roscado G63 antes de modificar la configuración de ejes."@es .

ns1:Tarea_RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación de ejes"@es ;
    ns1:solucionaFallo ns1:Fallo_1212 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1212 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1212: Número de eje repetido en canal"@es ;
    ns1:identificador "1212" ;
    ns1:textoExtracto "#CALL AX/#SET AX: número de eje repetido. DETECCIÓN Durante la ejecución. CAUSA Dos ejes intentan ocupar la mismo posición en el canal. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1213 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1213: Conflicto con función G63 activa"@es ;
    ns1:identificador "1213" ;
    ns1:textoExtracto "#CALL AX/#SET AX: no se admite con G63 activa. DETECCIÓN Durante la ejecución. CAUSA No se permite programar #CALL AX con la función G63 activa. SOLUCIÓN Desactivar el roscado G63 antes de modificar la configuración de ejes."@es .

