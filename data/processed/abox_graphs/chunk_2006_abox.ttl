@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1213 a ns1:Alarma ;
    rdfs:label "Alarma 1213: Programación no permitida con G63 activa"@es ;
    ns1:identificador "1213" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_1213 ;
    ns1:textoExtracto "#CALL AX con la función G63 activa. SOLUCIÓN Desactivar el roscado G63 antes de modificar la configuración de ejes."@es .

ns1:Alarma_1214 a ns1:Alarma ;
    rdfs:label "Alarma 1214: Demasiados ejes requeridos"@es ;
    ns1:identificador "1214" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_1214 ;
    ns1:textoExtracto "#CALL AX/#SET AX: demasiados ejes requeridos. SOLUCIÓN Repasar la configuración de ejes definida para el canal."@es .

ns1:Alarma_1215 a ns1:Alarma ;
    rdfs:label "Alarma 1215: Sentencia no programada sola en bloque"@es ;
    ns1:identificador "1215" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_1215 ;
    ns1:textoExtracto "La sentencia #CALL AX/#SET AX se programa sola en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_1216 a ns1:Alarma ;
    rdfs:label "Alarma 1216: Nombre de eje en uso"@es ;
    ns1:identificador "1216" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_1216 ;
    ns1:textoExtracto "#CALL AX/#CAX: nombre de eje en uso. SOLUCIÓN Revisar la programación."@es .

ns1:Sistema_ConfiguracionEjes a ns1:Sistema ;
    rdfs:label "Sistema de configuración de ejes"@es ;
    ns1:textoExtracto "El número de ejes de un canal no puede superar el número de ejes del sistema."@es ;
    ns1:tieneComponente ns1:Parametro_NumEjesSistema .

ns1:AccionProhibida_1213 a ns1:AccionProhibida ;
    rdfs:label "Programar #CALL AX con G63 activa"@es ;
    ns1:textoExtracto "No se permite programar #CALL AX con la función G63 activa."@es .

ns1:AccionProhibida_1214 a ns1:AccionProhibida ;
    rdfs:label "Superar número de ejes del sistema"@es ;
    ns1:textoExtracto "Demasiados ejes programados; el número de ejes supera el número de ejes del sistema."@es .

ns1:AccionProhibida_1215 a ns1:AccionProhibida ;
    rdfs:label "Programar sentencia #CALL AX/#SET AX sin bloque exclusivo"@es ;
    ns1:textoExtracto "La sentencia no está programada sola en el bloque."@es .

ns1:AccionProhibida_1216 a ns1:AccionProhibida ;
    rdfs:label "Usar nombre de eje ya asignado a eje C"@es ;
    ns1:textoExtracto "El nombre de uno de los ejes está siendo utilizado por un eje C."@es .

ns1:Parametro_NumEjesSistema a ns1:Parametro ;
    rdfs:label "Número máximo de ejes del sistema"@es ;
    ns1:textoExtracto "número de ejes del sistema"@es .

