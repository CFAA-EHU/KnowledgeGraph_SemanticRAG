@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_1217 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1217: '#CALL AX: índice en uso'" ;
    ns1:identificador "1217" ;
    ns1:solucionaFallo ns1:UsoDuplicadoDeNombreDeEjeEnProgramacion ;
    ns1:textoExtracto "CAUSA El nombre de uno de los ejes está siendo utilizado por un eje C. SOLUCIÓN Revisar la programación." .

ns1:Error_1217_ConfiguracionEjes a ns1:DiagnosticoFallo ;
    rdfs:label "Conflicto de posición de ejes (Error 1217)" ;
    ns1:solucionaFallo ns1:PosicionDeEjeDuplicadaEnConfiguracionDeCanal ;
    ns1:textoExtracto "CAUSA Una de las posiciones está ocupada por otro eje. SOLUCIÓN Repasar la configuración de ejes definida para el canal; dos ejes no pueden estar en la misma posición. Un eje puede utilizar cualquier posición libre comprendida entre 1 y un número igual al máximo de ejes más cabezales permitido por el sistema." .

ns1:Error_1218 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1218: 'La sentencia #FREE AX se programa sola en el bloque'" ;
    ns1:identificador "1218" ;
    ns1:solucionaFallo ns1:SentenciaFREEAXNoProgramadaEnBloqueExclusivo ;
    ns1:textoExtracto "CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la programación." .

ns1:Error_1219 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1219: 'Se espera \",\" o \"]\"'" ;
    ns1:identificador "1219" ;
    ns1:solucionaFallo ns1:ErrorDeSintaxisPorDelimitadorFaltante ;
    ns1:textoExtracto "CAUSA Error en la sintaxis de la sentencia. SOLUCIÓN Revisar la programación." .

ns1:Error_1220 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1220: '#FREE AX: no se permite eliminar un eje activo en modo manual'" ;
    ns1:identificador "1220" ;
    ns1:solucionaFallo ns1:EliminacionDeEjeActivoEnModoManual ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA [implícita: intento de eliminar eje activo en modo manual]." .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo de operación manual" ;
    ns1:habilitadoPor ns1:SistemaControlEjes ;
    ns1:textoExtracto "modo manual" .

ns1:CanalDeProgramacionDeEjes a ns1:Componente ;
    rdfs:label "Canal de programación de ejes" ;
    ns1:textoExtracto "configuración de ejes definida para el canal" .

ns1:EliminacionDeEjeActivoEnModoManual a ns1:AccionProhibida ;
    rdfs:label "Eliminación de eje activo en modo manual" ;
    ns1:textoExtracto "no se permite eliminar un eje activo en modo manual" .

ns1:ErrorDeSintaxisPorDelimitadorFaltante a ns1:AccionProhibida ;
    rdfs:label "Error de sintaxis por delimitador faltante" ;
    ns1:textoExtracto "Error en la sintaxis de la sentencia." .

ns1:PosicionDeEjeDuplicadaEnConfiguracionDeCanal a ns1:AccionProhibida ;
    rdfs:label "Posición de eje duplicada en configuración de canal" ;
    ns1:textoExtracto "dos ejes no pueden estar en la misma posición" .

ns1:SentenciaFREEAXNoProgramadaEnBloqueExclusivo a ns1:AccionProhibida ;
    rdfs:label "Sentencia #FREE AX no programada en bloque exclusivo" ;
    ns1:textoExtracto "La sentencia no está programada sola en el bloque." .

ns1:SistemaControlEjes a ns1:Sistema ;
    rdfs:label "Sistema de control de ejes y cabezales" ;
    ns1:textoExtracto "Un eje puede utilizar cualquier posición libre comprendida entre 1 y un número igual al máximo de ejes más cabezales permitido por el sistema." ;
    ns1:tieneComponente ns1:CanalDeProgramacionDeEjes .

ns1:UsoDuplicadoDeNombreDeEjeEnProgramacion a ns1:AccionProhibida ;
    rdfs:label "Uso duplicado de nombre de eje en programación" ;
    ns1:textoExtracto "El nombre de uno de los ejes está siendo utilizado por un eje C." .

