@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_EliminarEjeActivo a ns1:AccionProhibida ;
    rdfs:label "Eliminación de eje activo en modo manual"@es ;
    ns1:activaAlarma ns1:Alarma_1220 ;
    ns1:textoExtracto "no se permite eliminar un eje activo en modo manual"@es .

ns1:AccionProhibida_SentenciaSET_AX_NoSola a ns1:AccionProhibida ;
    rdfs:label "Programación incorrecta de la sentencia #SET AX"@es ;
    ns1:activaAlarma ns1:Alarma_1221 ;
    ns1:textoExtracto "La sentencia #SET AX se programa sola en el bloque"@es .

ns1:ModoOperacion_ManualAditivo_G201 a ns1:ModoOperacion ;
    rdfs:label "Modo manual aditivo (G201)"@es ;
    ns1:activaAlarma ns1:Alarma_1220 ;
    ns1:identificador "G201" ;
    ns1:textoExtracto "Un eje en modo manual aditivo (G201) no se puede eliminar del canal."@es .

ns1:ModoOperacion_ManualAnulacion_G202 a ns1:ModoOperacion ;
    rdfs:label "Función de anulación de modo manual (G202)"@es ;
    ns1:identificador "G202" ;
    ns1:solucionaFallo ns1:Alarma_1220 ;
    ns1:textoExtracto "Anular el modo manual aditivo del eje mediante la función G202 para realizar eliminar el eje del canal."@es .

ns1:Alarma_1221 a ns1:Alarma ;
    rdfs:label "Alarma 1221: 'La sentencia #SET AX se programa sola en el bloque'"@es ;
    ns1:identificador "1221" ;
    ns1:textoExtracto "'La sentencia #SET AX se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA La sentencia no está programada sola en el bloque. SOLUCIÓN Revisar la"@es .

ns1:Alarma_1220 a ns1:Alarma ;
    rdfs:label "Alarma 1220: '#FREE AX: no se permite eliminar un eje activo en modo manual'"@es ;
    ns1:identificador "1220" ;
    ns1:textoExtracto "'#FREE AX: no se permite eliminar un eje activo en modo manual' DETECCIÓN Durante la ejecución. CAUSA Un eje en modo manual aditivo (G201) no se puede eliminar del canal. SOLUCIÓN Anular el modo manual aditivo del eje mediante la función G202 para realizar eliminar el eje del canal."@es .

