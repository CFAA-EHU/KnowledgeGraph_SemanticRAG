@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazTecladoAlfanumerico a ns1:InterfazUsuario ;
    rdfs:label "Alphanumeric keyboard"@en ;
    ns1:ilustradoEn ns1:ProcedimientoMovimientoEje ;
    ns1:textoExtracto "Select the axis to be moved (on alphanumeric keyboard)."@en .

ns1:InterfazTeclasProgramables a ns1:InterfazUsuario ;
    rdfs:label "Softkey menu"@en ;
    ns1:ilustradoEn ns1:ProcedimientoMovimientoEje ;
    ns1:textoExtracto "Press the softkey for presetting axes to show the list of axes of the channel and select an axis."@en .

ns1:TeclaESC a ns1:ComponenteElectrico ;
    rdfs:label "[ESC] key"@en ;
    ns1:ilustradoEn ns1:ProcedimientoMovimientoEje ;
    ns1:textoExtracto "The [ESC] key may be used to cancel the operation at any time."@en .

ns1:TeclaSTART a ns1:ComponenteElectrico ;
    rdfs:label "[START]"@en ;
    ns1:ilustradoEn ns1:ProcedimientoMovimientoEje ;
    ns1:textoExtracto "Press [START] to make the move."@en .

ns1:ProcedimientoMovimientoEje a ns1:TareaMantenimiento ;
    rdfs:label "Move an axis to a particular position"@en ;
    ns1:ejecutadoPor ns1:Personal ;
    ns1:requiereMantenimiento ns1:Maquina ;
    ns1:textoExtracto "Select the axis to be moved... Enter the coordinate of the target point... Press [START] to make the move."@en .

