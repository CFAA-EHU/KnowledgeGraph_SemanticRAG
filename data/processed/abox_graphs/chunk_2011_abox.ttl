@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_1229 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1229: Anidamiento de sentencias condicionales sobrepasado"@es ;
    ns1:identificador "1229" ;
    ns1:textoExtracto "1229 Anidamiento de sentencias condicionales sobrepasado. DETECCIÓN Durante la ejecución. CAUSA Demasiados anidamientos de sentencias $IF, $SWITCH, $FOR, $WHILE y $DO. SOLUCIÓN Revisar la programación. El máximo número de anidamientos es 20."@es .

ns1:AvisoSeguridad_1233 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1233: Traslado programado excede el rango de datos"@es ;
    ns1:identificador "1233" ;
    ns1:monitoreaParametro ns1:Parametro_LONGAXIS ;
    ns1:textoExtracto "1233 'El traslado programado excede el rango de datos' DETECCIÓN Durante la ejecución. CAUSA El traslado de origen definido supera al máximo permitido. SOLUCIÓN Revisar la programación."@es .

ns1:AvisoSeguridad_1236 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1236: Nombre de macro demasiado largo"@es ;
    ns1:identificador "1236" ;
    ns1:textoExtracto "1236 'Nombre de macro demasiado largo' DETECCIÓN Durante la ejecución. CAUSA El nombre de la macro supera el máximo número de caracteres permitidos. SOLUCIÓN El máximo número de caracteres permitidos es 30."@es .

ns1:AvisoSeguridad_1237 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1237: Falta '\\' en texto asociado a macro"@es ;
    ns1:identificador "1237" ;
    ns1:textoExtracto "1237 'Se espera \"\\\" en el texto asociado a la macro' DETECCIÓN Durante la ejecución. CAUSA En el texto de sustitución de una macro, se ha incluido una macro que no comienza por el carácter \"\\\". SOLUCIÓN El texto de sustitución de una macro debe ir entre comillas y puede incluir otras macros, las cuales deben estar delimitadas por los caracteres \\\"; por ejemplo \"macro\"=\"\\\"macro1\\\" \\\"macro2\\\"\""@es .

ns1:AvisoSeguridad_1238 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1238: Texto de sustitución de macro demasiado largo"@es ;
    ns1:identificador "1238" ;
    ns1:textoExtracto "1238 'Texto de sustitución de la macro demasiado largo' DETECCIÓN Durante la ejecución. CAUSA El número de caracteres del texto de sustitución de la macro supera el máximo permitido. SOLUCIÓN El máximo número de caracteres permitidos es 140."@es .

ns1:AvisoSeguridad_1240 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1240: Macro inexistente"@es ;
    ns1:identificador "1240" ;
    ns1:textoExtracto "1240 'Macro inexistente' DETECCIÓN Durante la ejecución. CAUSA La macro no está definida en el programa. SOLUCIÓN Definir la macro antes de utilizarla."@es .

ns1:Tabla_MacrosCNC a ns1:Tabla ;
    rdfs:label "Tabla de macros del CNC"@es ;
    ns1:documentadoEn ns1:AvisoSeguridad_1239 ;
    ns1:textoExtracto "Puede borrar la tabla de macros mediante la sentencia #INIT MACROTAB."@es .

ns1:AvisoSeguridad_1239 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1239: Número máximo de macros sobrepasado"@es ;
    ns1:identificador "1239" ;
    ns1:textoExtracto "1239 'Número máximo de macros sobrepasado' DETECCIÓN Durante la ejecución. CAUSA Superado el máximo número de macros en el CNC. SOLUCIÓN El máximo es 50 macros. Puede borrar la tabla de macros mediante la sentencia #INIT MACROTAB."@es .

ns1:Parametro_LONGAXIS a ns1:Parametro ;
    rdfs:label "Parámetro LONGAXIS (eje longitudinal)"@es ;
    ns1:identificador "LONGAXIS" ;
    ns1:textoExtracto "como eje longitudinal (parámetro LONGAXIS)."@es .

