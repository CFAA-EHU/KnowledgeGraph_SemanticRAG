@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoMacroInexistente_1240 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1240 'Macro inexistente'"@es ;
    ns1:identificador "1240" ;
    ns1:textoExtracto "1240 'Macro inexistente'"@es .

ns1:ModoOperacionArranque a ns1:ModoOperacion ;
    rdfs:label "Modo de arranque del CNC"@es ;
    ns1:textoExtracto "El CNC inicializa la tabla de macros en el arranque"@es .

ns1:ModoOperacionMDI_MDA a ns1:ModoOperacion ;
    rdfs:label "Modo MDI/MDA"@es ;
    ns1:textoExtracto "modo MDI/MDA"@es .

ns1:SentenciaINIT_MACROTAB a ns1:AccionProhibida ;
    rdfs:label "Sentencia #INIT MACROTAB"@es ;
    ns1:identificador "#INIT MACROTAB" ;
    ns1:textoExtracto "Puede borrar la tabla de macros mediante la sentencia #INIT MACROTAB. [...] El CNC inicializa la tabla de macros en el arranque o mediante la sentencia"@es .

ns1:TablaMacrosCNC a ns1:Tabla ;
    rdfs:label "Tabla de macros del CNC"@es ;
    ns1:identificador "MACROTAB" ;
    ns1:textoExtracto "El CNC almacena en una tabla las macros definidas desde un programa o desde el modo MDI/MDA, de manera que están disponibles para todos los programas ejecutados a continuación."@es .

