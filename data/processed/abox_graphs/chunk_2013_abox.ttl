@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1241 a ns1:Alarma ;
    rdfs:label "Alarma 1241: Falta texto de sustitución de macro" ;
    ns1:identificador "1241" ;
    ns1:textoExtracto "1241 'Falta el texto de sustitución de la macro' DETECCIÓN Durante la ejecución. CAUSA El texto de sustitución asociado a la macro es una cadena de caracteres vacía. SOLUCIÓN Asociar a la macro el texto de sustitución adecuado según la funcionalidad que se le quiera dar. El texto de sustitución debe ir escrito entre comillas." .

ns1:Alarma_1244 a ns1:Alarma ;
    rdfs:label "Alarma 1244: Velocidad del cabezal limitada en G96" ;
    ns1:activaAlarma ns1:ComponenteMecanico_Cabezal ;
    ns1:identificador "1244" ;
    ns1:monitoreaParametro ns1:Parametro_G96 ;
    ns1:textoExtracto "1244 'Eje frontal próximo al centro: la velocidad del cabezal en G96 ha sido limitada' DETECCIÓN Durante la ejecución. CAUSA Trabajando en velocidad de corte constante (G96), el CNC ha limitado la velocidad del cabezal debido a la proximidad del eje frontal al centro de giro. SOLUCIÓN Aumentar el límite de velocidad (G192) o aceptar la limitación." .

ns1:ModoOperacion_MDI_MDA a ns1:ModoOperacion ;
    rdfs:label "Modo MDI/MDA" ;
    ns1:textoExtracto "un programa o desde el modo MDI/MDA, de manera que están disponibles para todos los programas ejecutados a continuación." .

ns1:Parametro_G192 a ns1:Parametro ;
    rdfs:label "Límite de velocidad (G192)" ;
    ns1:identificador "G192" ;
    ns1:textoExtracto "Aumentar el límite de velocidad (G192)" .

ns1:Tabla_Macros a ns1:Tabla ;
    rdfs:label "Tabla de macros del CNC" ;
    ns1:textoExtracto "El CNC inicializa la tabla de macros en el arranque o mediante la sentencia #INIT MACROTAB." .

ns1:ComponenteMecanico_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "la velocidad del cabezal en G96 ha sido limitada" .

ns1:Parametro_G96 a ns1:Parametro ;
    rdfs:label "Velocidad de corte constante (G96)" ;
    ns1:identificador "G96" ;
    ns1:textoExtracto "Trabajando en velocidad de corte constante (G96), el CNC ha limitado la velocidad del cabezal" .

