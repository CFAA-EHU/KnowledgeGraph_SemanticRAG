@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_1245 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1245: No hay eje frontal (FACEAXIS) definido en el plano activo" ;
    ns1:identificador "1245" ;
    ns1:solucionaFallo ns1:Parametro_FACEAXIS ;
    ns1:textoExtracto "'G96: no hay eje frontal (FACEAXIS) definido en el plano activo' DETECCIÓN Durante la ejecución. CAUSA Ningún eje del plano está definido como eje frontal." .

ns1:AvisoSeguridad_1246 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1246: No se admite roscado con avance en G95" ;
    ns1:identificador "1246" ;
    ns1:solucionaFallo ns1:Parametro_G94 ;
    ns1:textoExtracto "'No se admite roscado con avance en G95' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar un roscado rígido (G63) teniendo activa la función G95 (avance por vuelta del cabezal)." .

ns1:AvisoSeguridad_1247 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1247: No se admite roscado con G96 activa" ;
    ns1:identificador "1247" ;
    ns1:solucionaFallo ns1:Parametro_G94 ;
    ns1:textoExtracto "'No se admite roscado con G96 activa' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar un roscado rígido (G63) teniendo activa la función G96 (velocidad de corte constante)." .

ns1:Parametro_G192 a ns1:Parametro ;
    rdfs:label "Límite de velocidad (G192)" ;
    ns1:identificador "G192" ;
    ns1:textoExtracto "Aumentar el límite de velocidad (G192) o aceptar la limitación." .

ns1:Parametro_G63 a ns1:Parametro ;
    rdfs:label "Roscado rígido (G63)" ;
    ns1:identificador "G63" ;
    ns1:textoExtracto "El CNC ha intentado ejecutar un roscado rígido (G63) teniendo activa la función G95 (avance por vuelta del cabezal)." .

ns1:Parametro_G95 a ns1:Parametro ;
    rdfs:label "Avance por vuelta del cabezal (G95)" ;
    ns1:identificador "G95" ;
    ns1:textoExtracto "El CNC ha intentado ejecutar un roscado rígido (G63) teniendo activa la función G95 (avance por vuelta del cabezal)." .

ns1:Parametro_G96 a ns1:Parametro ;
    rdfs:label "Velocidad de corte constante (G96)" ;
    ns1:identificador "G96" ;
    ns1:textoExtracto "El CNC ha intentado ejecutar un roscado rígido (G63) teniendo activa la función G96 (velocidad de corte constante)." .

ns1:Parametro_FACEAXIS a ns1:Parametro ;
    rdfs:label "Eje frontal (FACEAXIS)" ;
    ns1:identificador "FACEAXIS" ;
    ns1:textoExtracto "Definir uno de los ejes del plano como eje frontal (parámetro FACEAXIS)." .

ns1:Parametro_G94 a ns1:Parametro ;
    rdfs:label "Avance en función del tiempo (G94)" ;
    ns1:identificador "G94" ;
    ns1:textoExtracto "Activar el avance en función del tiempo (G94)." .

