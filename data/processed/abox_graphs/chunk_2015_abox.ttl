@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1249 a ns1:Alarma ;
    rdfs:label "Alarma 1249: 'No se admite cambio de gama con G96 activa'"@es ;
    ns1:identificador "1249" ;
    ns1:textoExtracto "1249 'No se admite cambio de gama con G96 activa' DETECCIÓN Durante"@es .

ns1:DiagnosticoFallo_G63_G96 a ns1:DiagnosticoFallo ;
    rdfs:label "Conflicto entre G63 (roscado rígido) y G96 (velocidad de corte constante)"@es ;
    ns1:solucionaFallo ns1:Alarma_1248 ;
    ns1:textoExtracto "CAUSA El CNC ha intentado ejecutar un roscado rígido (G63) teniendo activa la función G96 (velocidad de corte constante). SOLUCIÓN Activar el modo de velocidad de giro constante (G97)."@es .

ns1:ModoOperacion_G192 a ns1:ModoOperacion ;
    rdfs:label "G192: Limitación de la velocidad de giro"@es ;
    ns1:identificador "G192" ;
    ns1:textoExtracto "G192 (limitación de la velocidad de giro)"@es .

ns1:ModoOperacion_G63 a ns1:ModoOperacion ;
    rdfs:label "G63: Roscado rígido"@es ;
    ns1:identificador "G63" ;
    ns1:textoExtracto "G63 (roscado rígido)"@es .

ns1:ModoOperacion_G96 a ns1:ModoOperacion ;
    rdfs:label "G96: Velocidad de corte constante"@es ;
    ns1:identificador "G96" ;
    ns1:textoExtracto "G96 (velocidad de corte constante)"@es .

ns1:ModoOperacion_G97 a ns1:ModoOperacion ;
    rdfs:label "G97: Velocidad de giro constante"@es ;
    ns1:identificador "G97" ;
    ns1:textoExtracto "modo de velocidad de giro constante (G97)"@es .

ns1:Alarma_1248 a ns1:Alarma ;
    rdfs:label "Alarma 1248: 'No se admite roscado y G192 en el mismo bloque'"@es ;
    ns1:identificador "1248" ;
    ns1:textoExtracto "1248 'No se admite roscado y G192 en el mismo bloque' DETECCIÓN Durante la ejecución. CAUSA El CNC no permite programar las funciones G63 (roscado rígido) y G192 (limitación de la velocidad de giro) en el mismo bloque. SOLUCIÓN Programar ambas instrucciones en bloques diferentes."@es .

