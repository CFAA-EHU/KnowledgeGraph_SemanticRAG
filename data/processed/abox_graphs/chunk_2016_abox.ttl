@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_1249 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1249: No se admite cambio de gama con G96 activa"@es ;
    ns1:identificador "1249" ;
    ns1:textoExtracto "1249 'No se admite cambio de gama con G96 activa' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado cambiar la gama del cabezal (G112) con la función G96 activa. SOLUCIÓN Desactivar la función G96 para realizar el cambio de gama del cabezal."@es .

ns1:Error_1251 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1251: No se admite modo manual con G96 activa"@es ;
    ns1:identificador "1251" ;
    ns1:textoExtracto "1251 'No se admite modo manual con G96 activa' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado acceder al modo manual con la función G96 activa. SOLUCIÓN Desactivar la función G96 para acceder al modo manual."@es .

ns1:Error_1252 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1252: No se permite eliminar el eje de giro frontal con G96 activa"@es ;
    ns1:identificador "1252" ;
    ns1:textoExtracto "1252 '#FREE AX: no se permite eliminar el eje de giro frontal con G96 activa' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado eliminar el eje frontal de la configuración del canal (#FREE AX) con la función G96 activa. SOLUCIÓN Desactivar la función G96 para eliminar el eje frontal de la configuración del canal."@es .

ns1:Error_1254 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1254: No se admite G192 y M19 en el mismo bloque"@es ;
    ns1:identificador "1254" ;
    ns1:textoExtracto "1254 'No se admite G192 y M19 en el mismo bloque' DETECCIÓN Durante la ejecución. CAUSA El CNC no permite programar las funciones M19 (posicionamiento del cabezal) y G192 (limitación de la velocidad de giro) en el mismo bloque. SOLUCIÓN Programar ambas instrucciones en bloques diferentes."@es .

ns1:Error_1255 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1255: Porcentaje de aceleración negativo"@es ;
    ns1:identificador "1255" ;
    ns1:textoExtracto "1255 'Porcentaje de aceleración negativo' DETECCIÓN Durante la ejecución. CAUSA En la función G130, el porcentaje de aceleración programado es negativo. SOLUCIÓN El porcentaje de aceleración debe ser mayor o igual que cero."@es .

ns1:Error_1256 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1256: Porcentaje de aceleración fuera de rango"@es ;
    ns1:identificador "1256" ;
    ns1:textoExtracto "1256 'Porcentaje de aceleración fuera de rango' DETECCIÓN Durante la ejecución. CAUSA En la función G130, el porcentaje de aceleración programado es demasiado alto. SOLUCIÓN Revisar la programación."@es .

ns1:Error_1257 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1257: Doble programación del paso de husillo"@es ;
    ns1:identificador "1257" ;
    ns1:textoExtracto "1257 'Doble programación del paso de husillo' DETECCIÓN Durante la ejecución. CAUSA En la función G33, el paso de la rosca está programado más de una vez."@es .

ns1:Funcion_G112 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G112: Cambio de gama del cabezal"@es ;
    ns1:identificador "G112" ;
    ns1:textoExtracto "cambiar la gama del cabezal (G112)"@es .

ns1:Funcion_G192 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G192: Limitación de velocidad de giro"@es ;
    ns1:identificador "G192" ;
    ns1:textoExtracto "G192 (limitación de la velocidad de giro)"@es .

ns1:Funcion_G96 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G96: Velocidad constante de corte"@es ;
    ns1:identificador "G96" ;
    ns1:textoExtracto "función G96 activa"@es .

ns1:Funcion_M19 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función M19: Posicionamiento del cabezal"@es ;
    ns1:identificador "M19" ;
    ns1:textoExtracto "M19 (posicionamiento del cabezal)"@es .

ns1:Parametro_PasoHusillo a ns1:Parametro ;
    rdfs:label "Paso de husillo (G33)"@es ;
    ns1:monitoreaParametro ns1:Funcion_G33 ;
    ns1:textoExtracto "paso de la rosca"@es .

ns1:Parametro_PorcentajeAceleracion a ns1:Parametro ;
    rdfs:label "Porcentaje de aceleración (G130)"@es ;
    ns1:monitoreaParametro ns1:Funcion_G130 ;
    ns1:textoExtracto "porcentaje de aceleración programado"@es .

ns1:Funcion_G130 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G130: Control de aceleración"@es ;
    ns1:identificador "G130" ;
    ns1:textoExtracto "En la función G130, el porcentaje de aceleración programado"@es .

ns1:Funcion_G33 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G33: Roscado"@es ;
    ns1:identificador "G33" ;
    ns1:textoExtracto "En la función G33, el paso de la rosca"@es .

