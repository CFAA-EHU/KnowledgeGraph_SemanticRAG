@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:B1258 a ns1:DiagnosticoFallo ;
    ns1:identificador "1258" ;
    ns1:textoExtracto "Paso de husillo igual cero" ;
    ns1:valor "Paso de husillo igual cero" .

ns1:B1259 a ns1:DiagnosticoFallo ;
    ns1:identificador "1259" ;
    ns1:textoExtracto "Paso de husillo fuera de rango" ;
    ns1:valor "Paso de husillo fuera de rango" .

ns1:B1261 a ns1:DiagnosticoFallo ;
    ns1:identificador "1261" ;
    ns1:textoExtracto "Tipo de cinemática desconocida" ;
    ns1:valor "Tipo de cinemática desconocida" .

ns1:FuncionG33 a ns1:Parametro ;
    ns1:textoExtracto "En la función G33, el paso de la rosca tiene valor 0" .

ns1:FuncionRTCP a ns1:Parametro ;
    ns1:textoExtracto "activar la función RTCP" .

ns1:FuncionTLC a ns1:Parametro ;
    ns1:textoExtracto "activar la función TLC" .

ns1:Modo6 a ns1:ModoOperacion ;
    ns1:textoExtracto "en modo 6 sin tener una cinematica activa" .

ns1:ParametroCinematica a ns1:Parametro ;
    ns1:textoExtracto "activar una cinemática no definida en parámetros máquina" .

ns1:ParametroPasoRosca a ns1:Parametro ;
    ns1:textoExtracto "el paso de la rosca programado es demasiado alto" .

ns1:TransformacionCoordenadas a ns1:Parametro ;
    ns1:textoExtracto "activar una transformación de coordenadas (CS/ACS)" .

