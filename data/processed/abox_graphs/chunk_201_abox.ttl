@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterruptorSobrescritura a ns1:Componente ;
    rdfs:label "Speed override switch" ;
    ns1:compuestoPor ns1:PanelOperador ;
    ns1:controla ns1:Parametro_SobrescrituraVelocidad ;
    ns1:textoExtracto "Switch. It sets the percentage of turning speed to be applied." .

ns1:Parametro_Avance a ns1:Parametro ;
    rdfs:label "Feedrate" ;
    ns1:ilustradoEn ns1:InterfazTecladoAlfanumerico ;
    ns1:textoExtracto "F [...] Enter the new feedrate." .

ns1:Parametro_Herramienta a ns1:Parametro ;
    rdfs:label "Tool selection" ;
    ns1:ilustradoEn ns1:InterfazTecladoAlfanumerico ;
    ns1:textoExtracto "T [...] Enter the tool to be selected." .

ns1:TablaValoresSobrescritura a ns1:Tabla ;
    rdfs:label "Speed override percentage values" ;
    ns1:documentadoEn ns1:Manual ;
    ns1:textoExtracto "70 80 90 100 110 [...] 50 120 [...] 4 180 [...] 200 190" .

ns1:Tecla_ESC a ns1:Componente ;
    rdfs:label "ESC key" ;
    ns1:compuestoPor ns1:InterfazTecladoAlfanumerico ;
    ns1:textoExtracto "Press [START] to assume the entered value or [ESC] to cancel the operation." .

ns1:Tecla_F a ns1:Componente ;
    rdfs:label "F key" ;
    ns1:compuestoPor ns1:InterfazTecladoAlfanumerico ;
    ns1:textoExtracto "Press [F] at the alphanumeric keyboard." .

ns1:Tecla_S a ns1:Componente ;
    rdfs:label "S key" ;
    ns1:compuestoPor ns1:InterfazTecladoAlfanumerico ;
    ns1:textoExtracto "Press [S] at the alphanumeric keyboard until selecting the desired spindle." .

ns1:Tecla_START a ns1:Componente ;
    rdfs:label "START key" ;
    ns1:compuestoPor ns1:InterfazTecladoAlfanumerico ;
    ns1:textoExtracto "Press [START] to assume the entered value or [ESC] to cancel the operation." .

ns1:Tecla_T a ns1:Componente ;
    rdfs:label "T key" ;
    ns1:compuestoPor ns1:InterfazTecladoAlfanumerico ;
    ns1:textoExtracto "Press [T] on the alphanumeric keyboard." .

ns1:TecladoJog a ns1:InterfazUsuario ;
    rdfs:label "JOG keypad" ;
    ns1:compuestoPor ns1:PanelOperador ;
    ns1:textoExtracto "JOG keypad. Increases or decreases the percentage of spindle speed." .

ns1:Parametro_SobrescrituraVelocidad a ns1:Parametro ;
    rdfs:label "Speed override" ;
    ns1:ilustradoEn ns1:PanelOperador ;
    ns1:monitoreaParametro ns1:Parametro_VelocidadHusillo ;
    ns1:textoExtracto "Vary the speed override from the operator panel. [...] Increases or decreases the percentage of spindle speed." .

ns1:Parametro_VelocidadHusillo a ns1:Parametro ;
    rdfs:label "Spindle speed" ;
    ns1:ilustradoEn ns1:InterfazTecladoAlfanumerico ;
    ns1:textoExtracto "S [...] Enter the new spindle speed." .

ns1:PanelOperador a ns1:InterfazUsuario ;
    rdfs:label "Operator panel" ;
    ns1:textoExtracto "Vary the speed override from the operator panel. With the operator panel, it is possible to change the percentage of spindle speed using the jog keyboard or a switch." .

ns1:InterfazTecladoAlfanumerico a ns1:InterfazUsuario ;
    rdfs:label "Alphanumeric keyboard" ;
    ns1:textoExtracto "Press [F] at the alphanumeric keyboard. [...] Press [S] at the alphanumeric keyboard. [...] Press [T] on the alphanumeric keyboard." .

