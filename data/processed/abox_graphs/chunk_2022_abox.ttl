@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_TransformacionCoordenadas a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en transformación de coordenadas (pieza-máquina)"@es ;
    ns1:solucionaFallo ns1:Alarma_1271 ;
    ns1:textoExtracto "CAUSA El CNC no ha podido resolver una transformación de coordenadas pieza a coordenadas máquina o al revés. SOLUCIÓN Desactivar la transformación, cambiar la posición de los ejes y volver a activar la transformación."@es .

ns1:Alarma_1271 a ns1:Alarma ;
    rdfs:label "Alarma 1271: Cinemática activa"@es ;
    ns1:identificador "1271" ;
    ns1:textoExtracto "'Los ejes de la cinemática activa no pueden excluirse o ser modificados'"@es .

