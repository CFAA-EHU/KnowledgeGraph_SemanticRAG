@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_PosicionTransformada a ns1:Parametro ;
    rdfs:label "Posición calculada por transformación cinemática inversa"@es ;
    ns1:monitoreaParametro ns1:Sistema_CinematicaActiva ;
    ns1:textoExtracto "Posición calculada por la transformada cinemática inversa fuera de rango."@es .

ns1:Sistema_TransformacionPlanoInclinado a ns1:Sistema ;
    rdfs:label "Sistema de transformación de plano inclinado (CNC)"@es ;
    ns1:activaAlarma ns1:Alarma_1275_Transformacion ;
    ns1:textoExtracto "Los ejes de la transformación activa (plano inclinado) no pueden excluirse o ser modificados durante la ejecución."@es .

ns1:Alarma_1272 a ns1:Alarma ;
    rdfs:label "Alarma 1272: Ejes de cinemática activa no modificables"@es ;
    ns1:identificador "1272" ;
    ns1:textoExtracto "'Los ejes de la cinemática activa no pueden excluirse o ser modificados' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado modificar la configuración de ejes de una cinemática mientras ésta estaba activa. SOLUCIÓN Desactivar la cinemática para modificar la configuración de ejes del canal."@es .

ns1:Alarma_1275 a ns1:Alarma ;
    rdfs:label "Alarma 1275: Posición calculada fuera de rango en transformación cinemática inversa"@es ;
    ns1:identificador "1275" ;
    ns1:textoExtracto "'Posición calculada por la transformada cinemática inversa fuera de rango' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado hacer una transformación de coordenadas máquina a coordenadas pieza no resuelta. SOLUCIÓN Desactivar la transformación, cambiar la posición a la que se quiere acceder y volver a activar la transformación."@es .

ns1:Alarma_1275_Transformacion a ns1:AvisoSeguridad ;
    rdfs:label "Transformación de plano inclinado activa no modificable"@es ;
    ns1:identificador "1275_transformacion" ;
    ns1:mitigaRiesgo ns1:Alarma_1275 ;
    ns1:textoExtracto "'Los ejes de la transformación activa no pueden excluirse o ser modificados' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado modificar la configuración de ejes de un plano inclinado mientras éste estaba activo. SOLUCIÓN Desactivar la transformación de plano inclinado para modificar la configuración de ejes del canal."@es .

ns1:Sistema_CinematicaActiva a ns1:Sistema ;
    rdfs:label "Sistema de cinemática activa (CNC)"@es ;
    ns1:activaAlarma ns1:Alarma_1272 ;
    ns1:textoExtracto "Los ejes de la cinemática activa no pueden excluirse o ser modificados durante la ejecución."@es .

