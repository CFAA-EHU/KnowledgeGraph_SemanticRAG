@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1281 a ns1:Alarma ;
    rdfs:label "Alarma 1281: No coincide el número de parámetros y de especificadores de formato" ;
    ns1:identificador "1281" ;
    ns1:textoExtracto "1281 'No coincide el número de parámetros y de especificadores de formato' DETECCIÓN Durante la ejecución." .

ns1:DiagnosticoFallo_1277 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1277" ;
    ns1:solucionaFallo ns1:Alarma_1277 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:DiagnosticoFallo_1278 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1278" ;
    ns1:solucionaFallo ns1:Alarma_1278 ;
    ns1:textoExtracto "SOLUCIÓN Programar un porcentaje de aceleración o jerk positivo y menor o igual a 100." .

ns1:DiagnosticoFallo_1279 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1279" ;
    ns1:solucionaFallo ns1:Alarma_1279 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:DiagnosticoFallo_Transformacion a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para error de transformación" ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la transformación, cambiar la posición a la que se quiere acceder y volver a activar la transformación. Revisar la transformada en caso de transformación de usuario." .

ns1:Parametro_G131_G133 a ns1:Parametro ;
    rdfs:label "Parámetro G131/G133 (porcentaje de aceleración o jerk)" ;
    ns1:monitoreaParametro ns1:Alarma_1278 ;
    ns1:textoExtracto "En la función G131 o G133, el porcentaje de aceleración o jerk programado no es válido." ;
    ns1:valor "0-100" .

ns1:Parametro_G92 a ns1:Parametro ;
    rdfs:label "Parámetro G92 (cotas programadas)" ;
    ns1:monitoreaParametro ns1:Alarma_1277 ;
    ns1:textoExtracto "El traslado calculado a partir de las cotas programadas en la función G92 es demasiado grande." .

ns1:Alarma_1279 a ns1:Alarma ;
    rdfs:label "Alarma 1279: Se espera comillas" ;
    ns1:identificador "1279" ;
    ns1:textoExtracto "1279 'Se espera \"'\"' DETECCIÓN Durante la ejecución. CAUSA En la expresión o sentencia programada faltan las comillas. SOLUCIÓN Revisar la programación." .

ns1:Alarma_1277 a ns1:Alarma ;
    rdfs:label "Alarma 1277: El traslado resultante excede el rango de datos" ;
    ns1:identificador "1277" ;
    ns1:textoExtracto "1277 'El traslado resultante excede el rango de datos' DETECCIÓN Durante la ejecución. CAUSA El traslado calculado a partir de las cotas programadas en la función G92 es demasiado grande. SOLUCIÓN Revisar la programación." .

ns1:Alarma_1278 a ns1:Alarma ;
    rdfs:label "Alarma 1278: G131/G133: valor no válido" ;
    ns1:identificador "1278" ;
    ns1:textoExtracto "1278 'G131/G133: valor no válido' DETECCIÓN Durante la ejecución. CAUSA En la función G131 o G133, el porcentaje de aceleración o jerk programado no es válido. SOLUCIÓN Programar un porcentaje de aceleración o jerk positivo y menor o igual a 100." .

