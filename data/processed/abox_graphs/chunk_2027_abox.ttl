@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_1288 a ns1:DiagnosticoFallo ;
    rdfs:label "Demasiados parámetros programados en la sentencia" ;
    ns1:identificador "1288" ;
    ns1:textoExtracto "Demasiados parámetros programados en la sentencia. DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar la programación." .

ns1:Parametro_LongitudMaximaMensaje a ns1:Parametro ;
    rdfs:label "Longitud máxima del texto en sentencias #MSG/#WARNING/#ERROR" ;
    ns1:monitoreaParametro ns1:Error_1289 ;
    ns1:textoExtracto "La longitud máxima del texto en estas sentencias es de 70 caracteres." ;
    ns1:valor "70" .

ns1:Error_1289 a ns1:DiagnosticoFallo ;
    rdfs:label "Mensaje del comando #MSG demasiado largo" ;
    ns1:identificador "1289" ;
    ns1:textoExtracto "El mensaje del comando #MSG es demasiado largo. DETECCIÓN Durante la ejecución. CAUSA El mensaje programado en la sentencia #MSG/#WARNING/#ERROR es demasiado largo. SOLUCIÓN La longitud máxima del texto en estas sentencias es de 70 caracteres." .

