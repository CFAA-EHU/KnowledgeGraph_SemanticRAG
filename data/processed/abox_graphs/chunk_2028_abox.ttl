@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FuncionG264 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G264 (interpolación circular)" ;
    ns1:controla ns1:SistemaControlNumerico ;
    ns1:textoExtracto "Los valores programados para el centro de una interpolación circular, con la función G264 activa, son incorrectos." .

ns1:Error1290 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1290: Programación de coordenadas I, J, K incorrecta" ;
    ns1:identificador "1290" ;
    ns1:textoExtracto "1290 'Programación de coordenadas I, J, K incorrecta' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • Los valores programados para el centro de una interpolación circular, origen polar o centro de giro del sistema de coordenadas son demasiado altos. • Los valores programados para el centro de una interpolación circular, con la función G264 activa, son incorrectos. SOLUCIÓN Revisar la programación." .

ns1:Error1291 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1291: No se admiten más funciones S" ;
    ns1:identificador "1291" ;
    ns1:textoExtracto "1291 'No se admiten más funciones S' DETECCIÓN Durante la ejecución. CAUSA En un mismo bloque hay más funciones S de las permitidas. SOLUCIÓN El máximo número de funciones S admitido en un mismo bloque es 4." .

ns1:Error1292 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1292: Función M doblemente programada" ;
    ns1:identificador "1292" ;
    ns1:textoExtracto "1292 'Función M doblemente programada' DETECCIÓN Durante la ejecución. CAUSA La misma función M está programada más de una vez en el bloque." .

ns1:SistemaControlNumerico a ns1:Sistema ;
    rdfs:label "Sistema de control numérico" ;
    ns1:activaAlarma ns1:Error1290,
        ns1:Error1291,
        ns1:Error1292 ;
    ns1:textoExtracto "Las posibles causas son las siguientes: • Los valores programados para el centro de una interpolación circular, origen polar o centro de giro del sistema de coordenadas son demasiado altos. • Los valores programados para el centro de una interpolación circular, con la función G264 activa, son incorrectos." .

