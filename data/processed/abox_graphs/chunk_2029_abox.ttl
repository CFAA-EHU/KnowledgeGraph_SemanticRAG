@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1293 a ns1:Alarma ;
    rdfs:label "Función H doblemente programada" ;
    ns1:identificador "1293" ;
    ns1:textoExtracto "1293 'Función H doblemente programada' DETECCIÓN Durante la ejecución. CAUSA La misma función H está programada más de una vez en el bloque. SOLUCIÓN Programar ambas funciones en bloques diferentes." .

ns1:Alarma_1301 a ns1:Alarma ;
    rdfs:label "La transformación de longitud de herramienta excede el formato numérico válido" ;
    ns1:identificador "1301" ;
    ns1:textoExtracto "1301 'La transformación de longitud de herramienta excede el formato numérico válido' DETECCIÓN Durante la ejecución. CAUSA La transformación de longitud de herramienta excede el formato numérico válido. SOLUCIÓN Modificar los valores de la transformación de longitud o los de la herramienta." .

ns1:Alarma_1302 a ns1:Alarma ;
    rdfs:label "Carácter no válido en el nombre" ;
    ns1:identificador "1302" ;
    ns1:textoExtracto "1302 'Carácter no válido en el nombre' DETECCIÓN Durante la ejecución. CAUSA Carácter no válido en el nombre de una etiqueta, subrutina o variable. SOLUCIÓN Revisar la programación." .

ns1:Alarma_1303 a ns1:Alarma ;
    rdfs:label "Nombre de variable demasiado largo" ;
    ns1:identificador "1303" ;
    ns1:textoExtracto "1303 'Nombre de variable demasiado largo' DETECCIÓN Durante la ejecución. CAUSA Superado el máximo número de caracteres permitido para el nombre de la variable." .

ns1:Alarma_Anonima a ns1:Alarma ;
    rdfs:label "Función M doblemente programada" ;
    ns1:textoExtracto "CAUSA La misma función M está programada más de una vez en el bloque. SOLUCIÓN Programar ambas funciones en bloques diferentes." .

ns1:Herramienta_Anonima a ns1:Herramienta ;
    ns1:monitoreaParametro ns1:Parametro_TransformacionLongitud ;
    ns1:textoExtracto "La transformación de longitud de herramienta excede el formato numérico válido." .

ns1:Subrutina_Anonima a ns1:Parametro ;
    ns1:textoExtracto "Carácter no válido en el nombre de una etiqueta, subrutina o variable." .

ns1:Variable_Anonima a ns1:Parametro ;
    ns1:textoExtracto "Nombre de variable demasiado largo" .

ns1:Parametro_TransformacionLongitud a ns1:Parametro ;
    rdfs:label "Transformación de longitud de herramienta" ;
    ns1:textoExtracto "La transformación de longitud de herramienta excede el formato numérico válido." .

