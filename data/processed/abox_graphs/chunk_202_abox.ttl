@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TareaCalibracionFresadora a ns1:TareaMantenimiento ;
    rdfs:label "Tool calibration (mill model)"@en ;
    ns1:documentadoEn ns1:TablaCalibracionHerramientas ;
    ns1:textoExtracto "Tool calibration in a mill model."@en .

ns1:TareaCalibracionTorno a ns1:TareaMantenimiento ;
    rdfs:label "Tool calibration (lathe model)"@en ;
    ns1:documentadoEn ns1:TablaCalibracionHerramientas ;
    ns1:textoExtracto "Tool calibration in a lathe model."@en .

ns1:TablaCalibracionHerramientas a ns1:Tabla ;
    rdfs:label "Tool calibration reference"@en ;
    ns1:ilustradoEn ns1:ManualMaquina ;
    ns1:textoExtracto "Tool calibration in a mill model. | Tool calibration in a lathe model."@en .

