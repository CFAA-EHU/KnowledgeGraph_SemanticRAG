@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_1303 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1303: 'Nombre de variable demasiado largo'" ;
    ns1:identificador "1303" ;
    ns1:textoExtracto "1303 'Nombre de variable demasiado largo' DETECCIÓN Durante la ejecución. CAUSA Superado el máximo número de caracteres permitido para el nombre de la variable. SOLUCIÓN El máximo número de caracteres permitido es 13." .

ns1:AvisoSeguridad_1304 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1304: 'Velocidad de cabezal no válida'" ;
    ns1:identificador "1304" ;
    ns1:monitoreaParametro ns1:Parametro_VelocidadCabezal ;
    ns1:textoExtracto "1304 'Velocidad de cabezal no válida' DETECCIÓN Durante la ejecución." .

ns1:Parametro_VelocidadCabezal a ns1:Parametro ;
    rdfs:label "Velocidad de cabezal" ;
    ns1:textoExtracto "Velocidad de cabezal no válida" .

