@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC (Control Numérico Computarizado)" ;
    ns1:activaAlarma ns1:Alerta_1306,
        ns1:Alerta_1308 ;
    ns1:textoExtracto "El CNC ha intentado cambiar la cinemática con la compensación de radio activa." ;
    ns1:tieneComponente ns1:ModoFactorEscala,
        ns1:ModoGiroSistema,
        ns1:ModoOrigenPolar,
        ns1:ModoProgramacionIncremental,
        ns1:ModoProgramacionMilimetros,
        ns1:ModoProgramacionPolar,
        ns1:ModoProgramacionPulgadas,
        ns1:SentenciaCYL,
        ns1:SentenciaFACE,
        ns1:SentenciaRTCP .

ns1:Alerta_1306 a ns1:AvisoSeguridad ;
    rdfs:label "Alerta 1306: 'No se admite cambio de cinemática con compensación de radio activa'" ;
    ns1:identificador "1306" ;
    ns1:textoExtracto "1306 'No se admite cambio de cinemática con compensación de radio activa'" .

ns1:Alerta_1308 a ns1:AvisoSeguridad ;
    rdfs:label "Alerta 1308: 'Un eje de la transformación cinemática activa no puede ser esclavo'" ;
    ns1:identificador "1308" ;
    ns1:textoExtracto "1308 'Un eje de la transformación cinemática activa no puede ser esclavo'" .

ns1:ModoFactorEscala a ns1:ModoOperacion ;
    rdfs:label "Modo de factor de escala (G72)" ;
    ns1:identificador "G72" ;
    ns1:textoExtracto "Factor de escala (G72)." .

ns1:ModoGiroSistema a ns1:ModoOperacion ;
    rdfs:label "Modo de giro del sistema (G73)" ;
    ns1:identificador "G73" ;
    ns1:textoExtracto "Giro del sistema (G73)." .

ns1:ModoOrigenPolar a ns1:ModoOperacion ;
    rdfs:label "Modo de origen polar (G30)" ;
    ns1:identificador "G30" ;
    ns1:textoExtracto "Origen polar (G30)." .

ns1:ModoProgramacionIncremental a ns1:ModoOperacion ;
    rdfs:label "Modo de programación incremental (G91)" ;
    ns1:identificador "G91" ;
    ns1:textoExtracto "Activación de la programación incremental (G91)." .

ns1:ModoProgramacionMilimetros a ns1:ModoOperacion ;
    rdfs:label "Modo de programación en milímetros (G70)" ;
    ns1:identificador "G70" ;
    ns1:textoExtracto "Programación en milímetros/pulgadas (G70/G71)." .

ns1:ModoProgramacionPolar a ns1:ModoOperacion ;
    rdfs:label "Modo de programación en polares (G0, G1, G2, G3, G8, G9, G63, G33)" ;
    ns1:identificador "G0-G33" ;
    ns1:textoExtracto "Movimiento G0, G1, G2, G3, G8 ó G9 en polares. Roscado G63 ó G33 en polares." .

ns1:ModoProgramacionPulgadas a ns1:ModoOperacion ;
    rdfs:label "Modo de programación en pulgadas (G71)" ;
    ns1:identificador "G71" ;
    ns1:textoExtracto "Programación en milímetros/pulgadas (G70/G71)." .

ns1:SentenciaCYL a ns1:Parametro ;
    rdfs:label "Sentencia #CYL" ;
    ns1:identificador "#CYL" ;
    ns1:textoExtracto "Sentencias #FACE, #CYL y #RTCP." .

ns1:SentenciaFACE a ns1:Parametro ;
    rdfs:label "Sentencia #FACE" ;
    ns1:identificador "#FACE" ;
    ns1:textoExtracto "Sentencias #FACE, #CYL y #RTCP." .

ns1:SentenciaRTCP a ns1:Parametro ;
    rdfs:label "Sentencia #RTCP" ;
    ns1:identificador "#RTCP" ;
    ns1:textoExtracto "Sentencias #FACE, #CYL y #RTCP." .

