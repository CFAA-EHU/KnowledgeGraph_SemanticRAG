@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Aviso_CinematicaAcoplo a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia: Desactivar cinemática para acoplamiento de eje esclavo"@es ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la cinemática para poder acoplar el eje. El eje participante en la cinemática activa sí puede ser eje maestro de un acoplo."@es .

ns1:Fallo_1309 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1309: 'Se espera nombre de fichero'"@es ;
    ns1:identificador "1309" ;
    ns1:textoExtracto "1309 'Se espera nombre de fichero' [...] DETECCIÓN Durante la ejecución. CAUSA No hay ningún programa seleccionado para la ejecución. SOLUCIÓN Seleccionar el programa a ejecutar."@es .

ns1:Fallo_1310 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1310: 'Línea de programa demasiado larga'"@es ;
    ns1:identificador "1310" ;
    ns1:textoExtracto "1310 'Línea de programa demasiado larga' [...] DETECCIÓN Durante la ejecución. CAUSA El número de caracteres en la"@es .

ns1:SistemaCinematicoActivo a ns1:Sistema ;
    rdfs:label "Cinemática activa"@es ;
    ns1:textoExtracto "El eje esclavo de un acoplo forma parte de la cinemática activa. [...] Desactivar la cinemática para poder acoplar el eje."@es .

