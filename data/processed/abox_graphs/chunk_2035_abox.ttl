@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_ProgramacionCNC a ns1:AvisoSeguridad ;
    rdfs:label "Revisión de programación en CNC"@es ;
    ns1:mitigaRiesgo ns1:AccionProhibida_ModificacionParametrosActivos ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación."@es .

ns1:ParametrosSistemaCoordenadas a ns1:Parametro ;
    rdfs:label "Parámetros de sistema de coordenadas"@es ;
    ns1:monitoreaParametro ns1:SistemaCoordenadasActivo ;
    ns1:textoExtracto "modificar los parámetros de un sistema de coordenadas activo; si permite modificar los parámetros de un sistema de coordenadas ya definido pero no activo."@es .

ns1:AccionProhibida_ModificacionParametrosActivos a ns1:AccionProhibida ;
    rdfs:label "Modificación de parámetros en sistema de coordenadas activo"@es ;
    ns1:solucionaFallo ns1:Fallo_1319 ;
    ns1:textoExtracto "El CNC no permite modificar los parámetros de un sistema de coordenadas activo"@es .

ns1:Fallo_1319 a ns1:DiagnosticoFallo ;
    rdfs:label "Anidamiento de sentencias #CS ON/#ACS ON sobrepasado"@es ;
    ns1:identificador "1319" ;
    ns1:textoExtracto "1319 'Anidamiento de sentencias #CS ON/#ACS ON sobrepasado' [...] DETECCIÓN Durante la ejecución."@es .

ns1:SistemaCoordenadasActivo a ns1:Sistema ;
    rdfs:label "Sistema de coordenadas activo"@es ;
    ns1:textoExtracto "El CNC ha intentado cambiar los parámetros de un sistema de coordenadas activo."@es .

