@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1326 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1326: Valor erróneo para asignar a variable" ;
    ns1:identificador "1326" ;
    ns1:textoExtracto "1326 'Valor erróneo para asignar a variable' DETECCIÓN Durante la ejecución." .

ns1:Solucion_1325 a ns1:TareaMantenimiento ;
    rdfs:label "Solución para fallo 1325" ;
    ns1:solucionaFallo ns1:Fallo_1325 ;
    ns1:textoExtracto "No repetir el número de bloque." .

ns1:Fallo_1325 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1325: Número de bloque definido varias veces" ;
    ns1:identificador "1325" ;
    ns1:textoExtracto "1325 'Número de bloque definido varias veces' DETECCIÓN Durante la ejecución. CAUSA El número de bloque \"N\" está repetido en el programa. SOLUCIÓN No repetir el número de bloque." .

