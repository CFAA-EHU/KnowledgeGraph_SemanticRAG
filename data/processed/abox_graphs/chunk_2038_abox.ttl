@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:monitoreaParametro ns1:Parametro_VelocidadPosicionamiento ;
    ns1:textoExtracto "La velocidad de posicionamiento del cabezal (M19) se ha programado más de una vez en el bloque." .

ns1:Fallo_1326 a ns1:DiagnosticoFallo ;
    rdfs:label "Valor erróneo para asignar a variable" ;
    ns1:identificador "1326" ;
    ns1:textoExtracto "1326 'Valor erróneo para asignar a variable' DETECCIÓN Durante la ejecución. CAUSA La variable tiene un valor demasiado alto. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1327 a ns1:DiagnosticoFallo ;
    rdfs:label "Posición del cabezal doblemente programada" ;
    ns1:identificador "1327" ;
    ns1:textoExtracto "1327 Posición del cabezal doblemente programada. DETECCIÓN Durante la ejecución. CAUSA La velocidad de posicionamiento del cabezal (M19) se ha programado más de una vez en el bloque. SOLUCIÓN Revisar la programación. Programar la velocidad de posicionamiento una única vez en el bloque." .

ns1:Fallo_1328 a ns1:DiagnosticoFallo ;
    rdfs:label "Sentencia $FOR sin $ENDFOR" ;
    ns1:identificador "1328" ;
    ns1:textoExtracto "1328 'Sentencia $FOR sin $ENDFOR' DETECCIÓN Durante la ejecución. CAUSA Hay programada una instrucción $FOR pero falta su $ENDFOR. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1330 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación de imagen espejo incorrecta" ;
    ns1:identificador "1330" ;
    ns1:textoExtracto "1330 'Programación de imagen espejo incorrecta' DETECCIÓN Durante la ejecución. CAUSA Programación incorrecta de la función G14 (imagen espejo). SOLUCIÓN Revisar la programación." .

ns1:Fallo_RepeticionBloque a ns1:DiagnosticoFallo ;
    rdfs:label "Número de bloque repetido" ;
    ns1:identificador "RepeticionBloque" ;
    ns1:textoExtracto "Durante la ejecución. CAUSA El número de bloque \"N\" está repetido en el programa. SOLUCIÓN No repetir el número de bloque." .

ns1:Funcion_ImagenEspejo a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G14 (imagen espejo)" ;
    ns1:identificador "G14" ;
    ns1:textoExtracto "Programación incorrecta de la función G14 (imagen espejo)." .

ns1:Parametro_VelocidadPosicionamiento a ns1:Parametro ;
    rdfs:label "Velocidad de posicionamiento (M19)" ;
    ns1:identificador "M19" ;
    ns1:textoExtracto "La velocidad de posicionamiento del cabezal (M19) se ha programado más de una vez en el bloque." .

