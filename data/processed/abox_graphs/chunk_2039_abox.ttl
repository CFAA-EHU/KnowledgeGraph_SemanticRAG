@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_1331 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1331: '#TANGFEED RMIN: radio negativo no permitido'" ;
    ns1:identificador "1331" ;
    ns1:solucionaFallo ns1:Funcion_G14 ;
    ns1:textoExtracto "1331 '#TANGFEED RMIN: radio negativo no permitido' [...] CAUSA El radio programado es menor o igual que cero. SOLUCIÓN Revisar la programación." .

ns1:Error_1332 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1332: '#TOOL AX: se espera orientación +/- tras la designación del eje'" ;
    ns1:identificador "1332" ;
    ns1:solucionaFallo ns1:Herramienta_CNC ;
    ns1:textoExtracto "1332 '#TOOL AX: se espera orientación +/- tras la designación del eje' [...] CAUSA Falta programar la orientación de la herramienta. SOLUCIÓN Revisar la programación." .

ns1:Error_1333 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1333: 'Cambio del primer y/o segundo eje del plano con compensación de radio activa'" ;
    ns1:identificador "1333" ;
    ns1:solucionaFallo ns1:CompensacionRadio ;
    ns1:textoExtracto "1333 'Cambio del primer y/o segundo eje del plano con compensación de radio activa' [...] CAUSA Con la compensación de radio activa, el CNC ha intentado cambiar la configuración de ejes del canal y el cambio afecta a los dos primeros ejes del plano de trabajo. SOLUCIÓN Desactivar la compensación de radio para realizar cambios en la configuración de ejes del canal que afectan al plano de trabajo." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "el CNC ha intentado cambiar la configuración de ejes del canal..." ;
    ns1:tieneComponente ns1:CompensacionRadio .

ns1:Funcion_G14 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G14 (imagen espejo)" ;
    ns1:identificador "G14" ;
    ns1:textoExtracto "CAUSA Programación incorrecta de la función G14 (imagen espejo)." .

ns1:Herramienta_CNC a ns1:Herramienta ;
    rdfs:label "Herramienta CNC" ;
    ns1:textoExtracto "CAUSA Falta programar la orientación de la herramienta." .

ns1:CompensacionRadio a ns1:Parametro ;
    rdfs:label "Compensación de radio" ;
    ns1:textoExtracto "Con la compensación de radio activa, el CNC ha intentado cambiar la configuración de ejes del canal..." .

