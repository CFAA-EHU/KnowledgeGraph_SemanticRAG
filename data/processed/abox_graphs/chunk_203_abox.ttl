@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MenuSoftkeyVertical a ns1:InterfazUsuario ;
    rdfs:label "Vertical softkey menu"@en ;
    ns1:habilitadoPor ns1:CalibracionManual ;
    ns1:textoExtracto "The different calibration methods may be selected from the vertical softkey menu."@en .

ns1:CalibracionManual a ns1:TareaMantenimiento ;
    rdfs:label "Manual calibration"@en ;
    ns1:requiereMantenimiento ns1:SondaTabletop ;
    ns1:textoExtracto "If there is no tabletop probe, only manual calibration is available."@en .

ns1:SondaTabletop a ns1:Componente ;
    rdfs:label "Table-top probe"@en ;
    ns1:textoExtracto "All types of calibration are available when using a table-top probe."@en .

