@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_CompensacionRadioActiva a ns1:AccionProhibida ;
    rdfs:label "Ejecutar cambios en configuración de ejes con compensación de radio activa" ;
    ns1:activaAlarma ns1:Alarma_1334 ;
    ns1:textoExtracto "Desactivar la compensación de radio para realizar cambios en la configuración de ejes del canal que afectan al plano de trabajo." .

ns1:DiagnosticoFallo_1334 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1334 (G200)" ;
    ns1:solucionaFallo ns1:AccionProhibida_MovimientoMismoBloqueG200 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Hay programado un movimiento de ejes en el mismo bloque que la función G200. SOLUCIÓN Revisar la programación." .

ns1:DiagnosticoFallo_1336 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1336 (CAXIS)" ;
    ns1:solucionaFallo ns1:AccionProhibida_DosEjesCAXIS ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Los dos ejes" .

ns1:AccionProhibida_DosEjesCAXIS a ns1:AccionProhibida ;
    rdfs:label "Configurar dos ejes CAXIS simultáneamente" ;
    ns1:activaAlarma ns1:Alarma_1336 ;
    ns1:textoExtracto "Configuración errónea: dos ejes CAXIS" .

ns1:AccionProhibida_MovimientoMismoBloqueG200 a ns1:AccionProhibida ;
    rdfs:label "Programar movimiento de ejes en el mismo bloque que la función G200" ;
    ns1:activaAlarma ns1:Alarma_1334 ;
    ns1:textoExtracto "Hay programado un movimiento de ejes en el mismo bloque que la función G200." .

ns1:Alarma_1336 a ns1:Alarma ;
    rdfs:label "Alarma 1336: 'Configuración errónea: dos ejes CAXIS'" ;
    ns1:identificador "1336" ;
    ns1:textoExtracto "1336 'Configuración errónea: dos ejes CAXIS' DETECCIÓN Durante la ejecución. CAUSA Los dos ejes" .

ns1:Alarma_1334 a ns1:Alarma ;
    rdfs:label "Alarma 1334: 'G200: no admite movimiento en el mismo bloque'" ;
    ns1:identificador "1334" ;
    ns1:textoExtracto "1334 'G200: no admite movimiento en el mismo bloque' DETECCIÓN Durante la ejecución. CAUSA Hay programado un movimiento de ejes en el mismo bloque que la función G200. SOLUCIÓN Revisar la programación." .

