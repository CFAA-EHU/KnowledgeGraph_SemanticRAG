@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:controla ns1:Alarma_1340,
        ns1:Alarma_1342,
        ns1:Alarma_1343,
        ns1:Alarma_1344 ;
    ns1:textoExtracto "El CNC ha intentado ejecutar la sentencia #CAX OFF"@es ;
    ns1:tieneComponente ns1:Componente_Cabezal .

ns1:Alarma_1340 a ns1:Alarma ;
    rdfs:label "Alarma 1340: 'La deselección no tiene efecto'"@es ;
    ns1:identificador "1340" ;
    ns1:mitigaRiesgo ns1:FalloDeProgramacionCAXOFFSinEjeCActivo ;
    ns1:textoExtracto "1340 'La deselección no tiene efecto' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar la sentencia #CAX OFF y no hay ningún cabezal trabajando como eje C."@es .

ns1:Alarma_1342 a ns1:Alarma ;
    rdfs:label "Alarma 1342: 'No se admite #CAX OFF si alguna transformación está activa'"@es ;
    ns1:identificador "1342" ;
    ns1:mitigaRiesgo ns1:FalloDeProgramacionCAXOFFConRTCPTLCActiva ;
    ns1:textoExtracto "1342 'No se admite #CAX OFF si alguna transformación esta activa' DETECCIÓN Durante la ejecución. CAUSA El CNC no permite desactivar el eje C con la función RTCP o TLC activa."@es .

ns1:Alarma_1343 a ns1:Alarma ;
    rdfs:label "Alarma 1343: 'No se admite #FACE OFF con el tipo de cinemática activa'"@es ;
    ns1:identificador "1343" ;
    ns1:mitigaRiesgo ns1:FalloDeProgramacionFACEOFFSinMecanizadoFrontal ;
    ns1:textoExtracto "1343 'No se admite #FACE OFF con el tipo de cinemática activa' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar la sentencia #FACE OFF y no hay activo ningún mecanizado en la superficie frontal."@es .

ns1:Alarma_1344 a ns1:Alarma ;
    rdfs:label "Alarma 1344: 'No se admite cambio de plano durante el mecanizado en superficie lateral'"@es ;
    ns1:identificador "1344" ;
    ns1:mitigaRiesgo ns1:FalloDeProgramacionCambioDePlanoNoPermitido ;
    ns1:textoExtracto "1344 'No se admite cambio de plano durante el mecanizado en superficie lateral' DETECCIÓN Durante la ejecución."@es .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal (eje C)"@es ;
    ns1:textoExtracto "no hay ningún cabezal trabajando como eje C"@es .

ns1:FalloDeProgramacionCAXOFFConRTCPTLCActiva a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de programación: #CAX OFF con RTCP/TLC activa"@es ;
    ns1:solucionaFallo ns1:RevisionDeProgramacionParaAlarma1342 ;
    ns1:textoExtracto "El CNC no permite desactivar el eje C con la función RTCP o TLC activa."@es .

ns1:FalloDeProgramacionCAXOFFSinEjeCActivo a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de programación: #CAX OFF sin eje C activo"@es ;
    ns1:solucionaFallo ns1:RevisionDeProgramacionParaAlarma1340 ;
    ns1:textoExtracto "El CNC ha intentado ejecutar la sentencia #CAX OFF y no hay ningún cabezal trabajando como eje C."@es .

ns1:FalloDeProgramacionCambioDePlanoNoPermitido a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de programación: cambio de plano no permitido"@es ;
    ns1:solucionaFallo ns1:RevisionDeProgramacionParaAlarma1344 ;
    ns1:textoExtracto "No se admite cambio de plano durante el mecanizado en superficie lateral."@es .

ns1:FalloDeProgramacionFACEOFFSinMecanizadoFrontal a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de programación: #FACE OFF sin mecanizado frontal"@es ;
    ns1:solucionaFallo ns1:RevisionDeProgramacionParaAlarma1343 ;
    ns1:textoExtracto "El CNC ha intentado ejecutar la sentencia #FACE OFF y no hay activo ningún mecanizado en la superficie frontal."@es .

ns1:RevisionDeProgramacionParaAlarma1340 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación para alarma 1340"@es ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación."@es .

ns1:RevisionDeProgramacionParaAlarma1342 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación para alarma 1342"@es ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación."@es .

ns1:RevisionDeProgramacionParaAlarma1343 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación para alarma 1343"@es ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación."@es .

ns1:RevisionDeProgramacionParaAlarma1344 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación para alarma 1344"@es ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación."@es .

