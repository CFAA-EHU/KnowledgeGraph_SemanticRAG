@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1344 a ns1:Alarma ;
    rdfs:label "Alarma 1344: Cambio de plano no admitido durante mecanizado lateral"@es ;
    ns1:identificador "1344" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_CambioPlanoMecanizadoLateral ;
    ns1:textoExtracto "'No se admite cambio de plano durante el mecanizado en superficie lateral' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado cambiar el plano de trabajo (G17-G20) mientras está activo el mecanizado en la superficie lateral. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_1345 a ns1:Alarma ;
    rdfs:label "Alarma 1345: Programación incorrecta de ejes en G20"@es ;
    ns1:identificador "1345" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_ProgramacionIncorrectaEjesG20 ;
    ns1:textoExtracto "'G20: programación incorrecta de ejes' DETECCIÓN Durante la ejecución. CAUSA En la función G20 (cambio de plano), los dos primeros ejes del plano (parámetros 1 y 2) son incorrectos. SOLUCIÓN Ambos ejes han de ser diferentes y estar entre los tres primeros ejes"@es .

ns1:Parametro_G20_Param1 a ns1:Parametro ;
    rdfs:label "Parámetro 1 de la función G20 (primer eje del plano)"@es ;
    ns1:textoExtracto "parámetros 1 y 2"@es ;
    ns1:valor "1" .

ns1:Parametro_G20_Param2 a ns1:Parametro ;
    rdfs:label "Parámetro 2 de la función G20 (segundo eje del plano)"@es ;
    ns1:textoExtracto "parámetros 1 y 2"@es ;
    ns1:valor "2" .

ns1:AccionProhibida_CambioPlanoMecanizadoLateral a ns1:AccionProhibida ;
    rdfs:label "Cambio de plano de trabajo (G17-G20) durante mecanizado en superficie lateral"@es ;
    ns1:textoExtracto "cambio de plano durante el mecanizado en superficie lateral"@es .

ns1:AccionProhibida_ProgramacionIncorrectaEjesG20 a ns1:AccionProhibida ;
    rdfs:label "Programación incorrecta de ejes en función G20 (parámetros 1 y 2 no válidos)"@es ;
    ns1:textoExtracto "En la función G20 (cambio de plano), los dos primeros ejes del plano (parámetros 1 y 2) son incorrectos"@es .

