@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1347 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite #CYL OFF con el tipo de cinemática activa" ;
    ns1:identificador "1347" ;
    ns1:solucionaFallo ns1:Sentencia_CYL_OFF ;
    ns1:textoExtracto "1347 'No se admite #CYL OFF con el tipo de cinemática activa' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar la sentencia #CYL OFF y no hay activo ningún mecanizado en la superficie cilíndrica. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1348 a ns1:DiagnosticoFallo ;
    rdfs:label "#CYL: radio no válido" ;
    ns1:identificador "1348" ;
    ns1:solucionaFallo ns1:Sentencia_CYL_Radio ;
    ns1:textoExtracto "1348 '#CYL: radio no válido' DETECCIÓN Durante la ejecución. CAUSA El radio programado en la sentencia #CYL es negativo o cero. Si el radio es variable, este intenta pasar por el centro del cilindro generando un radio nulo. SOLUCIÓN Revisar la programación. El radio debe ser positivo y en el caso de ser un radio variable, este no puede pasar por el centro del cilindro." .

ns1:Fallo_G20 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en parámetros de plano (G20)" ;
    ns1:solucionaFallo ns1:Parametro_G20_1,
        ns1:Parametro_G20_2 ;
    ns1:textoExtracto "CAUSA En la función G20 (cambio de plano), los dos primeros ejes del plano (parámetros 1 y 2) son incorrectos. SOLUCIÓN Ambos ejes han de ser diferentes y estar entre los tres primeros ejes del canal." .

ns1:Parametro_G20_1 a ns1:Parametro ;
    rdfs:label "Primer eje del plano (G20)" ;
    ns1:identificador "1" ;
    ns1:textoExtracto "los dos primeros ejes del plano (parámetros 1 y 2) son incorrectos" .

ns1:Parametro_G20_2 a ns1:Parametro ;
    rdfs:label "Segundo eje del plano (G20)" ;
    ns1:identificador "2" ;
    ns1:textoExtracto "los dos primeros ejes del plano (parámetros 1 y 2) son incorrectos" .

ns1:Sentencia_CYL_OFF a ns1:Parametro ;
    rdfs:label "Sentencia #CYL OFF" ;
    ns1:textoExtracto "El CNC ha intentado ejecutar la sentencia #CYL OFF y no hay activo ningún mecanizado en la superficie cilíndrica." .

ns1:Sentencia_CYL_Radio a ns1:Parametro ;
    rdfs:label "Radio en sentencia #CYL" ;
    ns1:textoExtracto "El radio programado en la sentencia #CYL es negativo o cero. Si el radio es variable, este intenta pasar por el centro del cilindro generando un radio nulo." .

