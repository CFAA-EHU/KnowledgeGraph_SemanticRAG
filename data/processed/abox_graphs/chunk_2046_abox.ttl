@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:activaAlarma ns1:Alarma_1351,
        ns1:Alarma_1352 ;
    ns1:textoExtracto "El CNC ha intentado definir o borrar una variable que no es de usuario." .

ns1:Alarma_1351 a ns1:Alarma ;
    rdfs:label "Alarma 1351: Tipo de variable no permitida" ;
    ns1:identificador "1351" ;
    ns1:textoExtracto "'#VAR/#ENDVAR/#DELETE: tipo de variable no permitida' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado definir o borrar una variable que no es de usuario. SOLUCIÓN Revisar la programación." .

ns1:Alarma_1352 a ns1:Alarma ;
    rdfs:label "Alarma 1352: Variable definida ya existe" ;
    ns1:identificador "1352" ;
    ns1:textoExtracto "'#VAR/#ENDVAR: la variable definida ya existe' DETECCIÓN Durante la ejecución. CAUSA La variable de usuario ya existe. SOLUCIÓN Revisar la programación." .

