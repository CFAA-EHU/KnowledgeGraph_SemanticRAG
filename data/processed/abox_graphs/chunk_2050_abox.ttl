@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1365 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1365: Velocidad del cabezal negativa" ;
    ns1:identificador "1365" ;
    ns1:solucionaFallo ns1:Funcion_G63,
        ns1:Parametro_VelocidadCabezal ;
    ns1:textoExtracto "1365 'No se admite velocidad del cabezal negativa' [...] CAUSA Velocidad de cabezal negativa. SOLUCIÓN La velocidad de cabezal debe ser positiva; sólo se permite un valor negativo si se programa en el mismo bloque que la función G63." .

ns1:Fallo_1367 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1367: Cambio de gama y movimiento del cabezal simultáneos" ;
    ns1:identificador "1367" ;
    ns1:solucionaFallo ns1:Funcion_G112,
        ns1:Funcion_M_MovimientoCabezal ;
    ns1:textoExtracto "1367 'No se permite un cambio de gama y movimiento del cabezal simultáneos' [...] CAUSA En el mismo bloque hay programada una función M de movimiento de cabezal y la función G112 de cambio del set de parámetros." .

ns1:Fallo_1368 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1368: Centro y radio del círculo programados simultáneamente" ;
    ns1:identificador "1368" ;
    ns1:solucionaFallo ns1:Parametro_CentroCirculo,
        ns1:Parametro_RadioCirculo ;
    ns1:textoExtracto "1368 'No se permite programar centro y radio del círculo simultáneamente' [...] CAUSA La interpolación circular está definida con el radio y el centro. SOLUCIÓN En una interpolación circular hay que programar las cotas del punto final y además el radio o el centro del círculo." .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "velocidad del cabezal negativa [...] velocidad de cabezal debe ser positiva [...] movimiento de cabezal" .

ns1:Funcion_G112 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G112 (cambio de set de parámetros)" ;
    ns1:identificador "G112" ;
    ns1:textoExtracto "función G112 de cambio del set de parámetros" .

ns1:Funcion_G63 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G63" ;
    ns1:identificador "G63" ;
    ns1:textoExtracto "función G63" .

ns1:Funcion_M_MovimientoCabezal a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función M (movimiento de cabezal)" ;
    ns1:textoExtracto "función M de movimiento de cabezal" .

ns1:Parametro_CentroCirculo a ns1:Parametro ;
    rdfs:label "Centro del círculo" ;
    ns1:textoExtracto "centro del círculo" .

ns1:Parametro_RadioCirculo a ns1:Parametro ;
    rdfs:label "Radio del círculo" ;
    ns1:textoExtracto "radio del círculo" .

ns1:Parametro_VelocidadCabezal a ns1:Parametro ;
    rdfs:label "Velocidad del cabezal" ;
    ns1:monitoreaParametro ns1:Componente_Cabezal ;
    ns1:textoExtracto "velocidad de cabezal negativa [...] velocidad de cabezal debe ser positiva" .

