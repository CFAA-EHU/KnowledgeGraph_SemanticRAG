@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación"@es ;
    ns1:documentadoEn ns1:Fallo_1369,
        ns1:Fallo_1370 ;
    ns1:textoExtracto "Revisar en el manual de [programación]"@es .

ns1:SistemaControlNumerico a ns1:Sistema ;
    rdfs:label "Sistema de control numérico"@es ;
    ns1:activaAlarma ns1:Fallo_1369,
        ns1:Fallo_1370 ;
    ns1:textoExtracto "programación [...] ejecución [...] sintaxis de la sentencia"@es ;
    ns1:tieneComponente ns1:Modo_HSC .

ns1:Modo_HSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC"@es ;
    ns1:textoExtracto "modo HSC"@es .

ns1:Fallo_1369 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1369: '#HSC: programación no permitida'"@es ;
    ns1:identificador "1369" ;
    ns1:textoExtracto "1369 '#HSC: programación no permitida' [...] CAUSA La sintaxis de la sentencia no es correcta."@es .

ns1:Fallo_1370 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1370: '#HSC: doble programación'"@es ;
    ns1:identificador "1370" ;
    ns1:textoExtracto "1370 '#HSC: doble programación' [...] CAUSA En un mismo bloque está programada la activación y desactivación del modo HSC."@es .

