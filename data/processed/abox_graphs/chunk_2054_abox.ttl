@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ParametroAritmetico_InexistenteOProtegido a ns1:Parametro ;
    rdfs:label "Parámetro aritmético no existente o protegido contra escritura"@es ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_ParametroAritmetico ;
    ns1:textoExtracto "El parámetro aritmético no existe o está protegido contra escritura."@es .

ns1:TareaMantenimiento_RevisionProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación de parámetros máquina"@es ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_ParametroAritmetico ;
    ns1:textoExtracto "Revisar la programación."@es .

ns1:TareaMantenimiento_RevisionRangoParametros a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de rango de parámetros aritméticos válidos"@es ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_ParametroAritmetico ;
    ns1:textoExtracto "Revisar en los parámetros máquina el rango de parámetros aritméticos valido."@es .

ns1:DiagnosticoFallo_ParametroAritmetico a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Parámetro aritmético inválido o protegido"@es ;
    ns1:textoExtracto "CAUSA El parámetro aritmético no existe o está protegido contra escritura. SOLUCIÓN Revisar la programación. Revisar en los parámetros máquina el rango de parámetros aritméticos valido."@es .

