@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1384 a ns1:Alarma ;
    rdfs:label "Función M no permitida con movimiento" ;
    ns1:identificador "1384" ;
    ns1:textoExtracto "1384 'Función M no permitida con movimiento' DETECCIÓN Durante la ejecución. CAUSA En el mismo bloque se ha programado un movimiento y una función M con subrutina asociada y ejecución antes del movimiento. Las subrutinas se ejecutan siempre al final del bloque y por tanto, nunca se ejecutará la función M antes del movimiento programado." .

ns1:Alarma_1385 a ns1:Alarma ;
    rdfs:label "No se admite modificar D y la longitud de la herramienta en el mismo bloque" ;
    ns1:identificador "1385" ;
    ns1:textoExtracto "1385 'No se admite modificar D y la longitud de la herramienta en el mismo bloque' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado escribir la variable 'V.G.TOL' en el mismo bloque en el que se ha programado un cambio de herramienta o corrector." .

ns1:Alarma_1386 a ns1:Alarma ;
    rdfs:label "No se admite modificar D y los offsets de la herramienta en el mismo bloque" ;
    ns1:identificador "1386" ;
    ns1:textoExtracto "1386 'No se admite modificar D y los offsets de la herramienta en el mismo bloque' DETECCIÓN Durante la ejecución." .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC" ;
    ns1:textoExtracto "Programar la función M en un bloque sin movimiento o definir la función M en los parámetros máquina con ejecución después del movimiento." ;
    ns1:tieneComponente ns1:Herramienta .

ns1:Parametro_VGTOL a ns1:Parametro ;
    rdfs:label "V.G.TOL" ;
    ns1:textoExtracto "El CNC ha intentado escribir la variable 'V.G.TOL' en el mismo bloque en el que se ha programado un cambio de herramienta o corrector." .

ns1:ParametrosCicloFijo a ns1:Parametro ;
    rdfs:label "Parámetros obligatorios y permitidos para ciclo fijo" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:textoExtracto "Revisar en el manual de programación los parámetros obligatorios y permitidos para cada ciclo fijo." .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación" ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación los parámetros obligatorios y permitidos para cada ciclo fijo." .

ns1:Herramienta a ns1:Herramienta ;
    rdfs:label "Herramienta (con longitud y offsets)" ;
    ns1:textoExtracto "No se admite modificar D y la longitud de la herramienta en el mismo bloque" .

