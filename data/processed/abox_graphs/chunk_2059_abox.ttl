@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1387 a ns1:Alarma ;
    rdfs:label "Alarma 1387: Límite de funciones M en un mismo bloque"@es ;
    ns1:activaAlarma ns1:Sistema_CNC ;
    ns1:identificador "1387" ;
    ns1:textoExtracto "Límite de funciones M en un mismo bloque"@es .

ns1:DiagnosticoFallo_1386 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico de fallo 1386: Conflicto en programación de herramienta"@es ;
    ns1:solucionaFallo ns1:Alarma_1386 ;
    ns1:textoExtracto "CAUSA El CNC ha intentado escribir la variable \"V.G.TOFL.xn\" en el mismo bloque en el que se ha programado un cambio de herramienta o corrector. SOLUCIÓN Revisar la programación."@es .

ns1:Herramienta_Gen_rica a ns1:Herramienta ;
    rdfs:label "Herramienta (genérica)"@es ;
    ns1:textoExtracto "modificar D y los offsets de la herramienta"@es .

ns1:Variable_VGTFLXN a ns1:Parametro ;
    rdfs:label "Variable V.G.TOFL.xn"@es ;
    ns1:identificador "V.G.TOFL.xn" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "la variable \"V.G.TOFL.xn\""@es .

ns1:Alarma_1386 a ns1:Alarma ;
    rdfs:label "Alarma 1386: Modificación no admitida de D y offsets de herramienta"@es ;
    ns1:activaAlarma ns1:Sistema_CNC ;
    ns1:identificador "1386" ;
    ns1:textoExtracto "'No se admite modificar D y los offsets de la herramienta en el mismo bloque' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado escribir la variable \"V.G.TOFL.xn\" en el mismo bloque en el que se ha programado un cambio de herramienta o corrector. SOLUCIÓN Revisar la programación."@es .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:textoExtracto "El CNC ha intentado escribir la variable \"V.G.TOFL.xn\" en el mismo bloque en el que se ha programado un cambio de herramienta o corrector."@es .

