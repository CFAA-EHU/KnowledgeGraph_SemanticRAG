@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CalibracionHerramienta_Automatica a ns1:TareaMantenimiento ;
    rdfs:label "Automatic tool calibration"@en ;
    ns1:ejecutadoPor ns1:InterfazCNC_ProcesoCalibracion ;
    ns1:textoExtracto "Automatic calibration. Calibration with a probe and a canned cycle. The calibration is done using a probing canned cycle. The CNC moves the tool until touching the probe and validates the calibration on each"@en .

ns1:CalibracionHerramienta_SemiAutomatica a ns1:TareaMantenimiento ;
    rdfs:label "Semi-automatic tool calibration"@en ;
    ns1:ejecutadoPor ns1:InterfazCNC_ProcesoCalibracion ;
    ns1:requiereMantenimiento ns1:Herramienta_Fresa,
        ns1:Herramienta_Torno ;
    ns1:textoExtracto "Semi-automatic calibration. Calibration with a probe. The positioning movements are carried out manually and the CNC executes the probing movements. The CNC will move the tool on the selected axis until it touches the probe and validates the calibration only on that axis."@en .

ns1:SondaCalibracion a ns1:Sensor ;
    rdfs:label "Probe"@en ;
    ns1:textoExtracto "The CNC will move the tool on the selected axis until it touches the probe and validates the calibration only on that axis."@en .

ns1:TablaHerramientas a ns1:Tabla ;
    rdfs:label "Tool table"@en ;
    ns1:documentadoEn ns1:ManualCNC ;
    ns1:textoExtracto "the new values are saved in the tool table. [...] The data is stored in the tool table."@en .

ns1:Herramienta_Fresa a ns1:ComponenteMecanico ;
    rdfs:label "Endmill tool"@en ;
    ns1:textoExtracto "Milling model. Calibrate the length or radius of the endmills and the offsets of the lathe tools."@en .

ns1:Herramienta_Torno a ns1:ComponenteMecanico ;
    rdfs:label "Lathe tool"@en ;
    ns1:textoExtracto "Lathe model. Calibrate the offset of any tool."@en .

ns1:InterfazCNC_ProcesoCalibracion a ns1:InterfazUsuario ;
    rdfs:label "CNC calibration interface"@en ;
    ns1:textoExtracto "Press [START] for the CNC to assume the new values of the offset. [...] Select the axis and the probing direction on the softkey menu and press [START]."@en .

