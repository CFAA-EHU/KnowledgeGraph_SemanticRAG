@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1388 a ns1:Alarma ;
    rdfs:label "Alarma 1388: No se admiten más funciones H" ;
    ns1:identificador "1388" ;
    ns1:textoExtracto "'No se admiten más funciones H' DETECCIÓN Durante la ejecución. CAUSA En un mismo bloque hay más funciones H de las permitidas." .

ns1:Alarma_1389 a ns1:Alarma ;
    rdfs:label "Alarma 1389: Funciones G incompatibles (G10/G11/G12/G13/G14)" ;
    ns1:identificador "1389" ;
    ns1:textoExtracto "'Funciones G incompatibles (G10/G11/G12/G13/G14)' DETECCIÓN Durante la ejecución. CAUSA En el bloque hay programadas dos funciones G que son contrarias entre sí." .

ns1:DiagnosticoFallo_Variable_VGTOFLXn a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en programación de variable V.G.TOFL.xn" ;
    ns1:solucionaFallo ns1:Alarma_1387 ;
    ns1:textoExtracto "escribir la variable \"V.G.TOFL.xn\" en el mismo bloque en el que se ha programado un cambio de herramienta o corrector. SOLUCIÓN Revisar la programación." .

ns1:Parametro_LimiteFuncionesH a ns1:Parametro ;
    rdfs:label "Límite de funciones H por bloque" ;
    ns1:textoExtracto "El máximo número de funciones H admitido en un mismo bloque es 7." ;
    ns1:valor "7" .

ns1:Parametro_LimiteFuncionesM a ns1:Parametro ;
    rdfs:label "Límite de funciones M por bloque" ;
    ns1:textoExtracto "el CNC permite hasta 14 funciones M por bloque; en versiones anteriores, el límite era 7 funciones por bloque." ;
    ns1:valor "14 (versión >= V2.00), 7 (versión < V2.00)" .

ns1:Alarma_1387 a ns1:Alarma ;
    rdfs:label "Alarma 1387: Límite de funciones M en un mismo bloque sobrepasado" ;
    ns1:identificador "1387" ;
    ns1:textoExtracto "'Límite de funciones M en un mismo bloque sobrepasado' DETECCIÓN Durante la ejecución. CAUSA En un mismo bloque hay más funciones M de las permitidas." .

