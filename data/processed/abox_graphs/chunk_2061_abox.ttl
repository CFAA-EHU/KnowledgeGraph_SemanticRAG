@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1390 a ns1:DiagnosticoFallo ;
    rdfs:label "Funciones G incompatibles (G98/G99)" ;
    ns1:identificador "1390" ;
    ns1:solucionaFallo ns1:Parametro_G98,
        ns1:Parametro_G99 ;
    ns1:textoExtracto "CAUSA En el bloque hay programadas dos funciones G que son contrarias entre sí. SOLUCIÓN Programar las funciones en bloques diferentes." .

ns1:DiagnosticoFallo_1392 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro doblemente programado" ;
    ns1:identificador "1392" ;
    ns1:textoExtracto "CAUSA El mismo parámetro está programado más de una vez en la sentencia o función. SOLUCIÓN Revisar la programación." .

ns1:DiagnosticoFallo_1393 a ns1:DiagnosticoFallo ;
    rdfs:label "La herramienta y corrector actuales no coinciden con los programados" ;
    ns1:identificador "1393" ;
    ns1:solucionaFallo ns1:Herramienta_CNC,
        ns1:Parametro_CorrectorD ;
    ns1:textoExtracto "CAUSA Tras una inspección de herramienta, el corrector D activo no coincide con la corrector D programado antes de detener la ejecución. El CNC tiene preparados los bloques de movimiento, con los que va a mecanizar la pieza después de la reposición, con el radio de la herramienta programada." .

ns1:Herramienta_CNC a ns1:Herramienta ;
    rdfs:label "Herramienta CNC" ;
    ns1:textoExtracto "El CNC tiene preparados los bloques de movimiento, con los que va a mecanizar la pieza después de la reposición, con el radio de la herramienta programada." .

ns1:Parametro_CorrectorD a ns1:Parametro ;
    rdfs:label "Corrector D" ;
    ns1:identificador "D" ;
    ns1:textoExtracto "el corrector D activo no coincide con la corrector D programado antes de detener la ejecución." .

ns1:Parametro_G98 a ns1:Parametro ;
    rdfs:label "Función G98" ;
    ns1:identificador "G98" ;
    ns1:textoExtracto "Funciones G incompatibles (G98/G99)" .

ns1:Parametro_G99 a ns1:Parametro ;
    rdfs:label "Función G99" ;
    ns1:identificador "G99" ;
    ns1:textoExtracto "Funciones G incompatibles (G98/G99)" .

