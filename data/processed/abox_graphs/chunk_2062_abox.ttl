@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CodigoError_1394 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1394: Subrutina G no existe"@es ;
    ns1:identificador "1394" ;
    ns1:textoExtracto "'No existe la subrutina asociada a la función G'"@es .

ns1:Fallo_CompensacionRadio a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Radio de herramienta no compensado"@es ;
    ns1:solucionaFallo ns1:Solucion_CambioHerramienta ;
    ns1:textoExtracto "Si la herramienta que hay en el cabezal es distinta y en el programa no está compensando el radio de la herramienta, el CNC va a mecanizar una pieza distinta"@es .

ns1:Herramienta_CNC_Programada a ns1:Herramienta ;
    rdfs:label "Herramienta programada en CNC"@es ;
    ns1:textoExtracto "el radio de la herramienta programada"@es .

ns1:Pieza_Mecanizada a ns1:Consumible ;
    rdfs:label "Pieza a mecanizar"@es ;
    ns1:textoExtracto "la pieza después de la reposición"@es .

ns1:Programa_CNC a ns1:InterfazUsuario ;
    rdfs:label "Programa CNC (compensación de radio)"@es ;
    ns1:textoExtracto "el programa no está compensando el radio de la herramienta"@es .

ns1:Cabezal_CNC a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal del CNC"@es ;
    ns1:textoExtracto "el cabezal"@es ;
    ns1:tieneComponente ns1:Herramienta_Cabezal_Actual .

ns1:Herramienta_Cabezal_Actual a ns1:Herramienta ;
    rdfs:label "Herramienta actual en cabezal"@es ;
    ns1:textoExtracto "la herramienta que hay en el cabezal"@es .

ns1:Solucion_CambioHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Cambiar herramienta del cabezal"@es ;
    ns1:requiereMantenimiento ns1:Cabezal_CNC ;
    ns1:textoExtracto "SOLUCIÓN Cambiar la herramienta del cabezal para que coincida con la programada"@es .

