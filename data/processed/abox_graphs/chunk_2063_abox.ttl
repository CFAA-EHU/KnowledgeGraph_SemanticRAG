@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_OEMSUB a ns1:Parametro ;
    rdfs:label "Parámetro OEMSUB"@es ;
    ns1:identificador "OEMSUB" ;
    ns1:textoExtracto "Para las funciones G180 a G189 definir la subrutina asociada (parámetro OEMSUB)."@es .

ns1:Parametro_REFPSUB a ns1:Parametro ;
    rdfs:label "Parámetro REFPSUB"@es ;
    ns1:identificador "REFPSUB" ;
    ns1:textoExtracto "Programar junto a la función G74 los ejes a referenciar o definir la subrutina asociada (parámetro REFPSUB)."@es .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:activaAlarma ns1:Alarma_1394,
        ns1:Alarma_1395 ;
    ns1:textoExtracto "el CNC va a mecanizar una pieza distinta."@es ;
    ns1:tieneComponente ns1:Herramienta_CNC .

ns1:TareaMantenimiento_CambioHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta en cabezal CNC"@es ;
    ns1:requiereMantenimiento ns1:Herramienta_CNC ;
    ns1:solucionaFallo ns1:Alarma_1394 ;
    ns1:textoExtracto "Cambiar la herramienta del cabezal para que coincida con la programada."@es .

ns1:Alarma_1395 a ns1:Alarma ;
    rdfs:label "Alarma 1395: 'La función G74 con subrutina asociada se programa sola en el bloque'"@es ;
    ns1:identificador "1395" ;
    ns1:textoExtracto "'La función G74 con subrutina asociada se programa sola en el bloque' DETECCIÓN Durante la ejecución. CAUSA Si la función G74 tiene subrutina asociada, se debe programar sola en el bloque o junto a la etiqueta del bloque."@es .

ns1:Alarma_1394 a ns1:Alarma ;
    rdfs:label "Alarma 1394: 'No existe la subrutina asociada a la función G'"@es ;
    ns1:identificador "1394" ;
    ns1:textoExtracto "'No existe la subrutina asociada a la función G' DETECCIÓN Durante la ejecución. CAUSA Hay programada una función G180 a G189 y no existe la subrutina asociada. Hay programada una función G74 sola en el bloque y no existe la subrutina asociada."@es .

ns1:Herramienta_CNC a ns1:Herramienta ;
    rdfs:label "Herramienta del cabezal CNC"@es ;
    ns1:textoExtracto "Cambiar la herramienta del cabezal para que coincida con la programada."@es .

