@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1396 a ns1:Alarma ;
    rdfs:label "Alarma 1396: Programación no permitida en MDI" ;
    ns1:identificador "1396" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_1396 ;
    ns1:textoExtracto "1396 'Programación no permitida en MDI' DETECCIÓN Durante la ejecución. CAUSA No se permite ejecutar esa orden en MDI. SOLUCIÓN Ejecutar esa orden dentro de un programa." .

ns1:Alarma_1397 a ns1:Alarma ;
    rdfs:label "Alarma 1397: Posición incorrecta para el eje Hirth" ;
    ns1:identificador "1397" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_1397 ;
    ns1:textoExtracto "1397 'La posición programada para el eje Hirth es incorrecta' DETECCIÓN Durante la ejecución. CAUSA La cota programada para el eje Hirth no se corresponde a un paso entero. SOLUCIÓN El eje hirth sólo admite cotas múltiplo de su paso." .

ns1:Alarma_1398 a ns1:Alarma ;
    rdfs:label "Alarma 1398: Eje no configurado como Hirth" ;
    ns1:identificador "1398" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_1398 ;
    ns1:textoExtracto "1398 'No se admite activar como Hirth un eje con el parámetro HIRTH = NO' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar (G171) o desactivar (G170) como eje hirth un eje que no lo es (parámetro HIRTH). SOLUCIÓN Revisar la programación. El eje no se puede activar como eje hirth." .

ns1:Alarma_1399 a ns1:Alarma ;
    rdfs:label "Alarma 1399: Activación fallida del eje Hirth" ;
    ns1:identificador "1399" ;
    ns1:textoExtracto "1399 'No puede activarse el eje como Hirth' DETECCIÓN Durante la ejecución." .

ns1:Parametro_HIRTH a ns1:Parametro ;
    rdfs:label "Parámetro HIRTH" ;
    ns1:identificador "HIRTH" ;
    ns1:textoExtracto "parámetro HIRTH" ;
    ns1:valor "NO" .

ns1:DiagnosticoFallo_1396 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación no permitida en MDI" ;
    ns1:textoExtracto "No se permite ejecutar esa orden en MDI. SOLUCIÓN Ejecutar esa orden dentro de un programa." .

ns1:DiagnosticoFallo_1397 a ns1:DiagnosticoFallo ;
    rdfs:label "Posición incorrecta para el eje Hirth" ;
    ns1:textoExtracto "La cota programada para el eje Hirth no se corresponde a un paso entero. SOLUCIÓN El eje hirth sólo admite cotas múltiplo de su paso." .

ns1:DiagnosticoFallo_1398 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje no configurado como Hirth" ;
    ns1:textoExtracto "El CNC ha intentado activar (G171) o desactivar (G170) como eje hirth un eje que no lo es (parámetro HIRTH). SOLUCIÓN Revisar la programación. El eje no se puede activar como eje hirth." .

