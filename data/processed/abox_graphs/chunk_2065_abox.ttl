@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Causa_CinematicaRTCP a ns1:Parametro ;
    rdfs:label "Cinemática activa con sentencia #RTCP, #TLC o #TOOL ORI"@es ;
    ns1:monitoreaParametro ns1:Fallo_ActivacionEjeHirth_1399 ;
    ns1:textoExtracto "El eje hirth forma parte de la cinemática activa y además hay activa una sentencia #RTCP, #TLC ó #TOOL ORI."@es .

ns1:Causa_CompensacionRadio a ns1:Parametro ;
    rdfs:label "Compensación de radio activa"@es ;
    ns1:monitoreaParametro ns1:Fallo_ActivacionEjeHirth_1399 ;
    ns1:textoExtracto "El eje hirth es uno de los ejes del plano y está activa la compensación de radio y/o la detección de colisiones."@es .

ns1:Causa_TransformacionCoordenadas a ns1:Parametro ;
    rdfs:label "Transformación de coordenadas activa"@es ;
    ns1:monitoreaParametro ns1:Fallo_ActivacionEjeHirth_1399 ;
    ns1:textoExtracto "El eje hirth forma parte de la transformación de coordenadas activa."@es .

ns1:EjeHirth a ns1:ComponenteMecanico ;
    rdfs:label "Eje Hirth"@es ;
    ns1:controla ns1:Fallo_ActivacionEjeHirth_1399 ;
    ns1:textoExtracto "El eje hirth es uno de los ejes del plano"@es .

ns1:Fallo_ActivacionEjeHirth_1399 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1399: No puede activarse el eje como Hirth"@es ;
    ns1:identificador "1399" ;
    ns1:textoExtracto "El eje no se puede activar como eje hirth. 1399 'No puede activarse el eje como Hirth'"@es .

