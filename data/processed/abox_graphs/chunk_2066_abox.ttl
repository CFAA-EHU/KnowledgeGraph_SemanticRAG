@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1400 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite cambio de longitud de herramienta con RTCP activo" ;
    ns1:identificador "1400" ;
    ns1:textoExtracto "1400 'No se admite cambio de longitud de herramienta con RTCP activo' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado hacer un cambio de herramienta con la función RTCP activa. SOLUCIÓN Desactivar la función RTCP para hacer el cambio de herramienta." .

ns1:DiagnosticoFallo_1401 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite #TLC ON sin deselección previa" ;
    ns1:identificador "1401" ;
    ns1:textoExtracto "1401 'No se admite #TLC ON sin deselección previa' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar la función TLC y ésta ya está activa. SOLUCIÓN Revisar la programación." .

ns1:DiagnosticoFallo_1402 a ns1:DiagnosticoFallo ;
    rdfs:label "#LINK: los ejes maestro y esclavo deben tener los mismos parámetros HIRTH y HPITCH" ;
    ns1:identificador "1402" ;
    ns1:textoExtracto "1402 '#LINK: los ejes maestro y esclavo deben tener los mismos parámetros HIRTH y HPITCH' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado acoplar dos ejes hirth pero uno de ellos no es hirth o ambos ejes tienen paso diferente. SOLUCIÓN Para poder incluir un eje hirth en un acoplo, ambos ejes deben ser hirth (parámetro HIRTH) y tener el mismo paso (parámetro HPITCH)." .

ns1:DiagnosticoFallo_1403 a ns1:DiagnosticoFallo ;
    rdfs:label "#LINK: no se puede definir un acoplo con un eje Hirth desactivado" ;
    ns1:identificador "1403" ;
    ns1:textoExtracto "1403 '#LINK: no se puede definir un acoplo con un eje Hirth desactivado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado acoplar dos ejes hirth pero uno de ellos está desactivado. SOLUCIÓN Para poder acoplar dos ejes hirth, ambos ejes deben estar activos (G171)." .

ns1:DiagnosticoFallo_1404 a ns1:DiagnosticoFallo ;
    rdfs:label "La gama asociada a la M programada no existe" ;
    ns1:identificador "1404" ;
    ns1:textoExtracto "1404 'La gama asociada a la M programada no existe' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado realizar un cambio de gama de cabezal mediante una función M41 a M44 y la gama no existe. SOLUCIÓN El número de gamas disponibles en el cabezal viene definido en los parámetros máquina (parámetro NPARSETS). El CNC sólo aceptará las funciones M41 a M44 de las gamas de cabezal que existan." .

ns1:EjeHirth_1402 a ns1:ComponenteMecanico ;
    rdfs:label "eje hirth" ;
    ns1:textoExtracto "El eje hirth forma parte de la transformación de coordenadas activa. • El eje hirth forma parte de la cinemática activa y además hay activa una sentencia #RTCP, #TLC ó #TOOL ORI. SOLUCIÓN Revisar la programación. 1402 '#LINK: los ejes maestro y esclavo deben tener los mismos parámetros HIRTH y HPITCH' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado acoplar dos ejes hirth pero uno de ellos no es hirth o ambos ejes tienen paso diferente. SOLUCIÓN Para poder incluir un eje hirth en un acoplo, ambos ejes deben ser hirth (parámetro HIRTH) y tener el mismo paso (parámetro HPITCH)." .

ns1:EjeHirth_1403 a ns1:ComponenteMecanico ;
    rdfs:label "eje hirth" ;
    ns1:textoExtracto "1403 '#LINK: no se puede definir un acoplo con un eje Hirth desactivado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado acoplar dos ejes hirth pero uno de ellos está desactivado. SOLUCIÓN Para poder acoplar dos ejes hirth, ambos ejes deben estar activos (G171)." .

ns1:FuncionRTCP a ns1:ModoOperacion ;
    rdfs:label "RTCP" ;
    ns1:textoExtracto "El eje hirth forma parte de la transformación de coordenadas activa. • El eje hirth forma parte de la cinemática activa y además hay activa una sentencia #RTCP, #TLC ó #TOOL ORI. SOLUCIÓN Revisar la programación. 1400 'No se admite cambio de longitud de herramienta con RTCP activo' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado hacer un cambio de herramienta con la función RTCP activa. SOLUCIÓN Desactivar la función RTCP para hacer el cambio de herramienta." .

ns1:FuncionTLC a ns1:ModoOperacion ;
    rdfs:label "TLC" ;
    ns1:textoExtracto "El eje hirth forma parte de la transformación de coordenadas activa. • El eje hirth forma parte de la cinemática activa y además hay activa una sentencia #RTCP, #TLC ó #TOOL ORI. SOLUCIÓN Revisar la programación. 1401 'No se admite #TLC ON sin deselección previa' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar la función TLC y ésta ya está activa. SOLUCIÓN Revisar la programación." .

ns1:FuncionTOOLORI a ns1:ModoOperacion ;
    rdfs:label "TOOL ORI" ;
    ns1:textoExtracto "El eje hirth forma parte de la transformación de coordenadas activa. • El eje hirth forma parte de la cinemática activa y además hay activa una sentencia #RTCP, #TLC ó #TOOL ORI. SOLUCIÓN Revisar la programación." .

ns1:GamaCabezal a ns1:ComponenteMecanico ;
    rdfs:label "gama de cabezal" ;
    ns1:textoExtracto "1404 'La gama asociada a la M programada no existe' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado realizar un cambio de gama de cabezal mediante una función M41 a M44 y la gama no existe. SOLUCIÓN El número de gamas disponibles en el cabezal viene definido en los parámetros máquina (parámetro NPARSETS). El CNC sólo aceptará las funciones M41 a M44 de las gamas de cabezal que existan." .

ns1:ParametroHIRTH a ns1:Parametro ;
    rdfs:label "HIRTH" ;
    ns1:textoExtracto "1402 '#LINK: los ejes maestro y esclavo deben tener los mismos parámetros HIRTH y HPITCH' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado acoplar dos ejes hirth pero uno de ellos no es hirth o ambos ejes tienen paso diferente. SOLUCIÓN Para poder incluir un eje hirth en un acoplo, ambos ejes deben ser hirth (parámetro HIRTH) y tener el mismo paso (parámetro HPITCH)." .

ns1:ParametroHPITCH a ns1:Parametro ;
    rdfs:label "HPITCH" ;
    ns1:textoExtracto "1402 '#LINK: los ejes maestro y esclavo deben tener los mismos parámetros HIRTH y HPITCH' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado acoplar dos ejes hirth pero uno de ellos no es hirth o ambos ejes tienen paso diferente. SOLUCIÓN Para poder incluir un eje hirth en un acoplo, ambos ejes deben ser hirth (parámetro HIRTH) y tener el mismo paso (parámetro HPITCH)." .

ns1:ParametroNPARSETS a ns1:Parametro ;
    rdfs:label "NPARSETS" ;
    ns1:textoExtracto "1404 'La gama asociada a la M programada no existe' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado realizar un cambio de gama de cabezal mediante una función M41 a M44 y la gama no existe. SOLUCIÓN El número de gamas disponibles en el cabezal viene definido en los parámetros máquina (parámetro NPARSETS). El CNC sólo aceptará las funciones M41 a M44 de las gamas de cabezal que existan." .

