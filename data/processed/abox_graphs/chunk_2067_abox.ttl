@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "El CNC sólo aceptará las funciones M41 a M44 de las gamas de cabezal que existan." ;
    ns1:tieneComponente ns1:Cabezal_Maquina .

ns1:Alarma_1405 a ns1:Alarma ;
    rdfs:label "Alarma 1405" ;
    ns1:identificador "1405" ;
    ns1:textoExtracto "'El valor de la S supera la gama máxima' DETECCIÓN Durante la ejecución." .

ns1:Cabezal_Maquina a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:activaAlarma ns1:Alarma_1405 ;
    ns1:monitoreaParametro ns1:Parametro_AUTOGEAR,
        ns1:Parametro_NPARSETS ;
    ns1:textoExtracto "El número de gamas disponibles en el cabezal viene definido en los parámetros máquina (parámetro NPARSETS)." .

ns1:Parametro_AUTOGEAR a ns1:Parametro ;
    rdfs:label "Parámetro AUTOGEAR" ;
    ns1:identificador "AUTOGEAR" ;
    ns1:textoExtracto "El cabezal tiene cambio de gama automático (parámetro AUTOGEAR)." .

ns1:Parametro_NPARSETS a ns1:Parametro ;
    rdfs:label "Parámetro NPARSETS" ;
    ns1:identificador "NPARSETS" ;
    ns1:textoExtracto "El número de gamas disponibles en el cabezal viene definido en los parámetros máquina (parámetro NPARSETS)." .

