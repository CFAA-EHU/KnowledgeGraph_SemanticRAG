@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:cabezal_001 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "El cabezal tiene cambio de gama automático (parámetro AUTOGEAR) y hay programada una velocidad superior a la máxima de cualquiera de las gamas existentes para ese cabezal." .

ns1:cajera_2D_3D a ns1:Componente ;
    ns1:textoExtracto "Al ejecutar una cajera 2D ó 3D, el CNC no ha podido decodificar alguno de los datos." .

ns1:error_1406 a ns1:DiagnosticoFallo ;
    ns1:identificador "1406" ;
    ns1:textoExtracto "'#CALL: no admite programación de parámetros'" .

ns1:error_1407 a ns1:DiagnosticoFallo ;
    ns1:identificador "1407" ;
    ns1:textoExtracto "'Error en la lectura de datos de la cajera'" .

ns1:parametro_AUTOGEAR a ns1:Parametro ;
    ns1:identificador "AUTOGEAR" ;
    ns1:textoExtracto "cambio de gama automático (parámetro AUTOGEAR)" .

ns1:sentencia_CALL a ns1:Parametro ;
    ns1:identificador "#CALL" ;
    ns1:textoExtracto "La sentencia #CALL no admite programación de parámetros." .

ns1:velocidad_cabezal_001 a ns1:Parametro ;
    ns1:textoExtracto "programada una velocidad superior a la máxima de cualquiera de las gamas existentes para ese cabezal" ;
    ns1:valor "velocidad programada" .

