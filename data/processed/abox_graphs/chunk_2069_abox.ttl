@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:CAUSA_1408 a ns1:DiagnosticoFallo ;
    ns1:solucionaFallo ns1:SOLUCION_1408 ;
    ns1:textoExtracto "1408 G63/G74/M19/CAX: Programación no permitida si no hay encóder en el cabezal." .

ns1:CAUSA_1409 a ns1:DiagnosticoFallo ;
    ns1:solucionaFallo ns1:SOLUCION_1409 ;
    ns1:textoExtracto "'Anidamiento de funciones T con subrutina no permitido'" .

ns1:Cabezal_1408 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "encóder en el cabezal" .

ns1:Cabezal_1409 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "cabezal" .

ns1:SOLUCION_1408 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Es necesario que haya encoder en el cabezal." .

ns1:SOLUCION_1409 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Volver a editar la cajera con el editor de ciclos." .

