@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC_13 a ns1:Actuador ;
    rdfs:label "CNC control unit"@en ;
    ns1:textoExtracto "Press the [CYCLE START] key to start the calibration. The CNC calibrates the tool making all the necessary movements; [...] After the calibration it updates the tool table data. Also, the CNC assumes the new values."@en .

ns1:HerramientaFresado_13 a ns1:ComponenteMecanico ;
    rdfs:label "Endmill tool (milling model)"@en ;
    ns1:requiereMantenimiento ns1:CalibracionHerramienta_13 ;
    ns1:textoExtracto "Milling model. Calibrate the length, the radius or offsets of the endmills [...]."@en .

ns1:HerramientaTorno_13 a ns1:ComponenteMecanico ;
    rdfs:label "Lathe tool"@en ;
    ns1:requiereMantenimiento ns1:CalibracionHerramienta_13 ;
    ns1:textoExtracto "Lathe model (plane). Calibrate the offset of any tool. [...] Lathe model (trihedron). Calibrate the length, the radius or offsets of the endmills and the offsets of the lathe tools."@en .

ns1:ParametroLongitud_13 a ns1:Parametro ;
    rdfs:label "Tool length parameter"@en ;
    ns1:textoExtracto "Calibrate the length, the radius or offsets of the endmills [...]."@en .

ns1:ParametroOffset_13 a ns1:Parametro ;
    rdfs:label "Tool offset parameter"@en ;
    ns1:textoExtracto "Calibrate the [...] offsets of the endmills and the offsets of the lathe tools."@en .

ns1:ParametroRadio_13 a ns1:Parametro ;
    rdfs:label "Tool radius parameter"@en ;
    ns1:textoExtracto "Calibrate the length, the radius or offsets of the endmills [...]."@en .

ns1:SistemaCNC_13 a ns1:Sistema ;
    rdfs:label "CNC tool calibration system"@en ;
    ns1:controla ns1:HerramientaFresado_13,
        ns1:HerramientaTorno_13 ;
    ns1:monitoreaParametro ns1:ParametroLongitud_13,
        ns1:ParametroOffset_13,
        ns1:ParametroRadio_13 ;
    ns1:textoExtracto "The CNC moves the tool until touching the probe and validates the calibration on each axis. [...] The CNC calibrates the tool making all the necessary movements; there is no need to manually approach the tool. If necessary, the CNC makes the tool change."@en .

ns1:CalibracionHerramienta_13 a ns1:TareaMantenimiento ;
    rdfs:label "Tool calibration with probe and canned cycle"@en ;
    ns1:ejecutadoPor ns1:CNC_13 ;
    ns1:requiereMantenimiento ns1:SistemaCNC_13 ;
    ns1:textoExtracto "Calibration with a probe and a canned cycle. The calibration is done using a probing canned cycle. The CNC moves the tool until touching the probe and validates the calibration on each axis. This mode may be used to calibrate any tool."@en .

