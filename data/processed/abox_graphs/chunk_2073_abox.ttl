@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1420 a ns1:DiagnosticoFallo ;
    ns1:solucionaFallo ns1:Alarma_1420 ;
    ns1:textoExtracto "CAUSA Alguna instrucción $IF, $FOR, etc no tiene su correspondiente instrucción de cierre. SOLUCIÓN Revisar la programación." .

ns1:DiagnosticoFallo_1421 a ns1:DiagnosticoFallo ;
    ns1:solucionaFallo ns1:Alarma_1421 ;
    ns1:textoExtracto "CAUSA Alguno de los ejes participantes en la transformación de coordenadas programada está aparcado, es esclavo de una pareja gantry o es esclavo de un acoplo activo. SOLUCIÓN Desaparcar, desactivar el acoplo activo o deshacer la pareja gantry para poder utilizar el eje en la transformación de coordenadas." .

ns1:TareaMantenimiento_RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación" ;
    ns1:ejecutadoPor ns1:Personal ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:Alarma_1420 a ns1:Alarma ;
    rdfs:label "Bloques de control abiertos al final de programa" ;
    ns1:identificador "1420" ;
    ns1:textoExtracto "1420 'Bloques de control abiertos al final de programa' DETECCIÓN Durante la ejecución. CAUSA Alguna instrucción $IF, $FOR, etc no tiene su correspondiente instrucción de cierre. SOLUCIÓN Revisar la programación." .

ns1:Alarma_1421 a ns1:Alarma ;
    rdfs:label "Los ejes de la transformación activa no pueden ser esclavos o estar aparcados" ;
    ns1:identificador "1421" ;
    ns1:textoExtracto "1421 'Los ejes de la transformación activa no pueden ser esclavos o estar aparcados' DETECCIÓN Durante la ejecución. CAUSA Alguno de los ejes participantes en la transformación de coordenadas programada está aparcado, es esclavo de una pareja gantry o es esclavo de un acoplo activo. SOLUCIÓN Desaparcar, desactivar el acoplo activo o deshacer la pareja gantry para poder utilizar el eje en la transformación de coordenadas." .

