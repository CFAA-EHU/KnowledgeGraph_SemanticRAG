@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error1422 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1422: '#CS ON/#ACS ON: modo programado no válido'" ;
    ns1:identificador "1422" ;
    ns1:monitoreaParametro ns1:ParametroMODE ;
    ns1:textoExtracto "'#CS ON/#ACS ON: modo programado no válido' DETECCIÓN Durante la ejecución. CAUSA El parámetro MODE programado no es válido. SOLUCIÓN El valor del parámetro MODE debe ser estar comprendido entre 1 y 6." .

ns1:Error1423 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1423: '#CS ON/#ACS ON: el parámetro de eje alineado ha de ser 0 o 1'" ;
    ns1:identificador "1423" ;
    ns1:monitoreaParametro ns1:ParametroEjeAlineado ;
    ns1:textoExtracto "'#CS ON/#ACS ON: el parámetro de eje alineado ha de ser 0 o 1' DETECCIÓN Durante la ejecución. CAUSA El valor programado como modo para alinear el plano no es válido. SOLUCIÓN Revisar la programación." .

ns1:Error1424 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1424: 'Función G no permitida con MCS activo'" ;
    ns1:identificador "1424" ;
    ns1:monitoreaParametro ns1:ParametroFuncionG ;
    ns1:textoExtracto "'Función G no permitida con MCS activo' DETECCIÓN Durante la ejecución. CAUSA No es posible ejecutar la función G programada con #MCS activo. SOLUCIÓN Revisar la programación." .

ns1:Error1425 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1425: 'El salto de bloque sólo se admite al comienzo de la línea'" ;
    ns1:identificador "1425" ;
    ns1:monitoreaParametro ns1:ParametroSaltoBloque ;
    ns1:textoExtracto "'El salto de bloque sólo se admite al comienzo de la línea' DETECCIÓN Durante la ejecución. CAUSA El carácter \"/\" solo se admite al comienzo de la línea de programa. SOLUCIÓN Revisar la programación." .

ns1:ParametroEjeAlineado a ns1:Parametro ;
    rdfs:label "Parámetro de eje alineado" ;
    ns1:textoExtracto "el parámetro de eje alineado ha de ser 0 o 1" ;
    ns1:valor "0,1" .

ns1:ParametroFuncionG a ns1:Parametro ;
    rdfs:label "Parámetro de función G" ;
    ns1:textoExtracto "Función G no permitida con MCS activo" .

ns1:ParametroMODE a ns1:Parametro ;
    rdfs:label "Parámetro MODE" ;
    ns1:textoExtracto "El parámetro MODE programado no es válido. [...] El valor del parámetro MODE debe ser estar comprendido entre 1 y 6." ;
    ns1:valor "1-6" .

ns1:ParametroSaltoBloque a ns1:Parametro ;
    rdfs:label "Parámetro de salto de bloque" ;
    ns1:textoExtracto "El salto de bloque sólo se admite al comienzo de la línea. [...] El carácter \"/\" solo se admite al comienzo de la línea de programa." .

