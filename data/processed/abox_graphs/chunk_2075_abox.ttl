@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error1426 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1426: 'La cajera fue resuelta con diferente radio de herramienta'"@es ;
    ns1:identificador "1426" ;
    ns1:solucionaFallo ns1:HerramientaCNC ;
    ns1:textoExtracto "1426 'La cajera fue resuelta con diferente radio de herramienta' DETECCIÓN Durante la ejecución. CAUSA El CNC generó la cajera con un radio de herramienta diferente al actual. SOLUCIÓN Generar de nuevo la cajera."@es .

ns1:Error1427 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1427: 'Eje mal programado'"@es ;
    ns1:identificador "1427" ;
    ns1:solucionaFallo ns1:ProgramaCNC ;
    ns1:textoExtracto "1427 'Eje mal programado' DETECCIÓN Durante la ejecución. CAUSA Error en la sintaxis de programación de la sentencia o función G; en un desplazamiento está"@es .

ns1:ErrorSintaxisProgramacion a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en programación"@es ;
    ns1:solucionaFallo ns1:ProgramaCNC ;
    ns1:textoExtracto "CAUSA El carácter \"/\" solo se admite al comienzo de la línea de programa. SOLUCIÓN Revisar la programación."@es .

ns1:HerramientaCNC a ns1:Herramienta ;
    rdfs:label "Herramienta de radio para cajera (CNC)"@es ;
    ns1:textoExtracto "radio de herramienta"@es .

ns1:ProgramaCNC a ns1:Sistema ;
    rdfs:label "Programa CNC"@es ;
    ns1:textoExtracto "sentencia o función G"@es .

