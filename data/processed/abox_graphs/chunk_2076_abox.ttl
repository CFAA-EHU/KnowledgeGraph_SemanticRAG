@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_Programacion a ns1:Sistema ;
    rdfs:label "Sistema de programación de funciones G"@es ;
    ns1:activaAlarma ns1:Alarma_1427,
        ns1:Alarma_1428,
        ns1:Alarma_1429 ;
    ns1:textoExtracto "Error en la sintaxis de programación de la sentencia o función G; [...] función G74 [...] función G20 [...] función G que define el ciclo."@es .

ns1:Alarma_1427 a ns1:Alarma ;
    rdfs:label "Alarma 1427: 'Eje mal programado'"@es ;
    ns1:identificador "1427" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_1427 ;
    ns1:textoExtracto "1427 'Eje mal programado' DETECCIÓN Durante la ejecución. CAUSA Error en la sintaxis de programación de la sentencia o función G; en un desplazamiento está repetido algún eje, en la función G74 falta programar el orden de la búsqueda de cero de los ejes o en la función G20 falta programar el orden de los ejes en el sistema. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_1428 a ns1:Alarma ;
    rdfs:label "Alarma 1428: 'El movimiento en el plano principal debe programarse antes de la G del ciclo'"@es ;
    ns1:identificador "1428" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_1428 ;
    ns1:textoExtracto "1428 'El movimiento en el plano principal debe programarse antes de la G del ciclo' DETECCIÓN Durante la ejecución. CAUSA Las coordenadas del punto inicial del ciclo están definidas después de la función G que define el ciclo. El ciclo considera las coordenadas del punto inicial como parámetros propios. SOLUCIÓN Programar las cotas de los ejes antes de la función G del ciclo."@es .

ns1:Alarma_1429 a ns1:Alarma ;
    rdfs:label "Alarma 1429: 'Límite de subrutinas en un mismo bloque sobrepasado'"@es ;
    ns1:identificador "1429" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_1429 ;
    ns1:textoExtracto "1429 'Límite de subrutinas en un mismo bloque sobrepasado' DETECCIÓN Durante la ejecución. CAUSA Se ha superado el máximo número de subrutinas que se pueden ejecutar en un mismo bloque."@es .

ns1:DiagnosticoFallo_1427 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de programación de eje (G74/G20)"@es ;
    ns1:textoExtracto "Error en la sintaxis de programación de la sentencia o función G; en un desplazamiento está repetido algún eje, en la función G74 falta programar el orden de la búsqueda de cero de los ejes o en la función G20 falta programar el orden de los ejes en el sistema."@es .

ns1:DiagnosticoFallo_1428 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de secuencia en programación de ciclo"@es ;
    ns1:textoExtracto "Las coordenadas del punto inicial del ciclo están definidas después de la función G que define el ciclo. El ciclo considera las coordenadas del punto inicial como parámetros propios."@es .

ns1:DiagnosticoFallo_1429 a ns1:DiagnosticoFallo ;
    rdfs:label "Exceso de subrutinas en bloque"@es ;
    ns1:textoExtracto "Se ha superado el máximo número de subrutinas que se pueden ejecutar en un mismo bloque."@es .

