@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_1432 a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede programar un eje esclavo de un acoplo o Gantry" ;
    ns1:identificador "1432" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA En la sentencia está programado el eje esclavo de un acoplo activo o de una pareja Gantry." .

ns1:Parametro_FormatoNumerico a ns1:Parametro ;
    rdfs:label "Formato numérico de dato/variable/parámetro" ;
    ns1:monitoreaParametro ns1:Error_1430 ;
    ns1:textoExtracto "El valor asignado a un dato, variable o parámetro es superior al formato establecido." .

ns1:Parametro_PosicionCabezalM19 a ns1:Parametro ;
    rdfs:label "Posición de cabezal en M19" ;
    ns1:monitoreaParametro ns1:Error_1431 ;
    ns1:textoExtracto "El valor programado para la posición de cabezal en M19 es demasiado alto." .

ns1:Parametro_SubrutinasPorBloque a ns1:Parametro ;
    rdfs:label "Número máximo de subrutinas por bloque" ;
    ns1:monitoreaParametro ns1:Error_SubrutinasExcedidas ;
    ns1:textoExtracto "El máximo número de subrutinas que se pueden ejecutar en un mismo bloque es 5." ;
    ns1:valor "5" .

ns1:Error_1430 a ns1:DiagnosticoFallo ;
    rdfs:label "Formato numérico sobrepasado" ;
    ns1:identificador "1430" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El valor asignado a un dato, variable o parámetro es superior al formato establecido. SOLUCIÓN Revisar la programación." .

ns1:Error_1431 a ns1:DiagnosticoFallo ;
    rdfs:label "Posición de cabezal en M19 no válida" ;
    ns1:identificador "1431" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El valor programado para la posición de cabezal en M19 es demasiado alto. SOLUCIÓN Programar un valor más pequeño." .

ns1:Error_SubrutinasExcedidas a ns1:DiagnosticoFallo ;
    rdfs:label "Máximo número de subrutinas en bloque excedido" ;
    ns1:textoExtracto "CAUSA Se ha superado el máximo número de subrutinas que se pueden ejecutar en un mismo bloque. SOLUCIÓN El máximo número de subrutinas que se pueden ejecutar en un mismo bloque es 5. Programar las subrutinas en bloques diferentes o utilizar la imbricación de subrutinas, según interese." .

