@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Comando_UNLINK a ns1:Parametro ;
    rdfs:label "Comando #UNLINK para desactivar acoplo activo"@es ;
    ns1:solucionaFallo ns1:Fallo_1433 ;
    ns1:textoExtracto "desactivar el acoplo activo (#UNLINK)"@es .

ns1:Maquina_CNC a ns1:Maquina ;
    ns1:textoExtracto "parámetro máquina"@es ;
    ns1:tieneComponente ns1:Parametro_DesacoploGantry .

ns1:Sentencia_ProgramacionEje a ns1:Parametro ;
    rdfs:label "Sentencia con eje esclavo programado en acoplo activo o pareja Gantry"@es ;
    ns1:textoExtracto "En la sentencia está programado el eje esclavo de un acoplo activo o de una pareja Gantry."@es .

ns1:Fallo_1433 a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede modificar la configuración de un eje aparcado"@es ;
    ns1:identificador "1433" ;
    ns1:textoExtracto "1433 No se puede modificar la configuración de un eje aparcado. DETECCIÓN Durante la ejecución."@es .

ns1:Parametro_DesacoploGantry a ns1:Parametro ;
    rdfs:label "Parámetro máquina para deshacer pareja Gantry"@es ;
    ns1:textoExtracto "deshacer la pareja Gantry (por parámetro máquina)."@es .

