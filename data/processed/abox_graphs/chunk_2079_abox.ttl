@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error1433 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1433: Configuración de eje aparcado" ;
    ns1:identificador "1433" ;
    ns1:solucionaFallo ns1:Parametro_UNPARK ;
    ns1:textoExtracto "No se puede modificar la configuración de un eje aparcado. DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado incluir (#CALL / #SET) entre los tres primeros ejes del canal un eje aparcado. SOLUCIÓN Un eje aparcado no puede formar parte de los tres primeros ejes del canal; desaparcar el eje (#UNPARK)." .

ns1:Error1434 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1434: Inclusión de eje esclavo asociado" ;
    ns1:identificador "1434" ;
    ns1:solucionaFallo ns1:Parametro_UNLINK ;
    ns1:textoExtracto "'No se ha podido incluir en la configuración un eje esclavo asociado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado incluir en la configuración del canal (#CALL o #SET) el eje maestro de un acoplo activo o de una pareja Gantry. Al incluir el eje maestro, el CNC también incluye el eje esclavo, que nunca puede ocupar una de las tres posiciones principales del canal. El CNC da error porque no existe una posición libre para el eje esclavo distinta de las tres principales. SOLUCIÓN Para poder incluir únicamente el eje maestro hay que desactivar primero el acoplo activo (#UNLINK) o deshacer la pareja Gantry. Para poder incluir los ejes maestro y esclavo hay que eliminar del canal algún otro eje o bien aumentar el número de ejes del canal." .

ns1:Error1435 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1435: Nombre de eje esclavo repetido" ;
    ns1:identificador "1435" ;
    ns1:textoExtracto "'No se ha podido asignar nombre a un eje esclavo asociado por estar repetido' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado incluir en la configuración del canal (#CALL o #SET) el eje maestro de un acoplo activo o de una pareja Gantry. Al incluir el eje maestro, el CNC también incluye el eje esclavo, que nunca puede ocupar una de las tres posiciones principales del canal. El CNC da error porque el nombre del eje esclavo ya está ocupado por otro eje en la configuración actual del canal. SOLUCIÓN Renombrar el eje esclavo a incluir o el ya existente en la configuración." .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC" ;
    ns1:textoExtracto "El CNC ha intentado incluir en la configuración del canal (#CALL o #SET) el eje maestro de un acoplo activo o de una pareja Gantry." ;
    ns1:tieneComponente ns1:Parametro_CALL,
        ns1:Parametro_SET,
        ns1:Parametro_UNLINK,
        ns1:Parametro_UNPARK .

ns1:Parametro_CALL a ns1:Parametro ;
    rdfs:label "Parámetro #CALL (inclusión en configuración)" ;
    ns1:identificador "#CALL" ;
    ns1:textoExtracto "El CNC ha intentado incluir (#CALL / #SET) entre los tres primeros ejes del canal un eje aparcado." .

ns1:Parametro_SET a ns1:Parametro ;
    rdfs:label "Parámetro #SET (inclusión en configuración)" ;
    ns1:identificador "#SET" ;
    ns1:textoExtracto "El CNC ha intentado incluir (#CALL / #SET) entre los tres primeros ejes del canal un eje aparcado." .

ns1:Parametro_UNLINK a ns1:Parametro ;
    rdfs:label "Parámetro #UNLINK (desactivar acoplo activo)" ;
    ns1:identificador "#UNLINK" ;
    ns1:textoExtracto "desactivar el acoplo activo (#UNLINK) o deshacer la pareja Gantry (por parámetro máquina)." .

ns1:Parametro_UNPARK a ns1:Parametro ;
    rdfs:label "Parámetro #UNPARK (desaparcar eje)" ;
    ns1:identificador "#UNPARK" ;
    ns1:textoExtracto "Un eje aparcado no puede formar parte de los tres primeros ejes del canal; desaparcar el eje (#UNPARK)." .

