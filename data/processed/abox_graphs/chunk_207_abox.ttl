@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_Softkeys_MDI_MDA a ns1:Tabla ;
    rdfs:label "Softkey functions table (MDI/MDA mode)" ;
    ns1:documentadoEn ns1:ModoOperacion_MDA,
        ns1:ModoOperacion_MDI ;
    ns1:textoExtracto "| Softkey. | Description. | --- | --- |  | Select a program for execution. |  | Begin tool inspection. [...] |  | Select the program that is being edited. |" .

ns1:TareaMantenimiento_InspeccionHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Tool inspection" ;
    ns1:requiereMantenimiento ns1:ModoOperacion_MDA,
        ns1:ModoOperacion_MDI ;
    ns1:textoExtracto "Begin tool inspection. Tool inspection is only available when program execution is interrupted." .

ns1:InterfazUsuario_HistorialBloques_MDA a ns1:InterfazUsuario ;
    rdfs:label "Block history (MDA mode)" ;
    ns1:ilustradoEn ns1:ModoOperacion_MDA ;
    ns1:textoExtracto "use the [][] keys, select a block from the history and use the 'modify' option from the softkey menu." .

ns1:InterfazUsuario_HistorialBloques_MDI a ns1:InterfazUsuario ;
    rdfs:label "Block history (MDI mode)" ;
    ns1:ilustradoEn ns1:ModoOperacion_MDI ;
    ns1:textoExtracto "In MDI mode, use the [][] keys to pop-up the history and scroll it." .

ns1:InterfazUsuario_LineaEdicion_MDI a ns1:InterfazUsuario ;
    rdfs:label "Edit line (MDI mode)" ;
    ns1:ilustradoEn ns1:ModoOperacion_MDI ;
    ns1:textoExtracto "In MDI mode, the edit line is always visible." .

ns1:InterfazUsuario_MenuSoftkey_MDA a ns1:InterfazUsuario ;
    rdfs:label "Softkey menu (MDA mode)" ;
    ns1:ilustradoEn ns1:ModoOperacion_MDA ;
    ns1:textoExtracto "In MDA mode, one must select the 'new block' option from the softkey menu." .

ns1:InterfazUsuario_TeclaRESET_MDI a ns1:InterfazUsuario ;
    rdfs:label "[RESET] key (MDI/MDA)" ;
    ns1:ilustradoEn ns1:ModoOperacion_MDA,
        ns1:ModoOperacion_MDI ;
    ns1:textoExtracto "The [RESET] key cancels the execution of the block and resets the CNC to its initial conditions." .

ns1:InterfazUsuario_TeclaSTART_MDI a ns1:InterfazUsuario ;
    rdfs:label "[START] key (MDI/MDA)" ;
    ns1:ilustradoEn ns1:ModoOperacion_MDA,
        ns1:ModoOperacion_MDI ;
    ns1:textoExtracto "The [START] key executes the block currently displayed on the editing line. [...] Press [START] again to resume execution from where it was interrupted." .

ns1:InterfazUsuario_TeclaSTOP_MDI a ns1:InterfazUsuario ;
    rdfs:label "[STOP] key (MDI/MDA)" ;
    ns1:ilustradoEn ns1:ModoOperacion_MDA,
        ns1:ModoOperacion_MDI ;
    ns1:textoExtracto "The [STOP] key interrupts the execution of the block." .

ns1:ModoOperacion_MDA a ns1:ModoOperacion ;
    rdfs:label "MDA mode" ;
    ns1:textoExtracto "In MDA mode, one must select the 'new block' option from the softkey menu. [...] use the [][] keys, select a block from the history and use the 'modify' option from the softkey menu." ;
    ns1:tieneComponente ns1:InterfazUsuario_HistorialBloques_MDA,
        ns1:InterfazUsuario_MenuSoftkey_MDA,
        ns1:InterfazUsuario_TeclaRESET_MDA,
        ns1:InterfazUsuario_TeclaSTART_MDA,
        ns1:InterfazUsuario_TeclaSTOP_MDA .

ns1:ModoOperacion_MDI a ns1:ModoOperacion ;
    rdfs:label "MDI mode" ;
    ns1:textoExtracto "In MDI mode, the edit line is always visible. [...] The [ENTER] key restores from the history the block selected with the cursor and insert it in the edit line." ;
    ns1:tieneComponente ns1:InterfazUsuario_HistorialBloques_MDI,
        ns1:InterfazUsuario_LineaEdicion_MDI,
        ns1:InterfazUsuario_TeclaRESET_MDI,
        ns1:InterfazUsuario_TeclaSTART_MDI,
        ns1:InterfazUsuario_TeclaSTOP_MDI .

