@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Solucion_DefinirBloqueParada a ns1:TareaMantenimiento ;
    rdfs:label "Definir bloque de parada en búsqueda de bloque"@es ;
    ns1:solucionaFallo ns1:Error_1436 ;
    ns1:textoExtracto "SOLUCIÓN Una vez seleccionada la opción de búsqueda de bloque, en [definir el bloque de parada]."@es .

ns1:Solucion_RenombrarEjeEsclavo a ns1:TareaMantenimiento ;
    rdfs:label "Renombrar eje esclavo en configuración de canal"@es ;
    ns1:solucionaFallo ns1:Error_EjeEsclavoDuplicado ;
    ns1:textoExtracto "SOLUCIÓN Renombrar el eje esclavo a incluir o el ya existente en la configuración."@es .

ns1:Error_1436 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1436: No se ha programado bloque de parada en búsqueda de bloque"@es ;
    ns1:identificador "1436" ;
    ns1:textoExtracto "1436 'No se ha programado bloque de parada en búsqueda de bloque' DETECCIÓN Durante la ejecución. CAUSA Falta definir el bloque de parada de la búsqueda de bloque."@es .

ns1:Error_EjeEsclavoDuplicado a ns1:AvisoSeguridad ;
    rdfs:label "Error: Nombre de eje esclavo duplicado en configuración de canal"@es ;
    ns1:textoExtracto "El CNC da error porque el nombre del eje esclavo ya está ocupado por otro eje en la configuración actual del canal."@es .

