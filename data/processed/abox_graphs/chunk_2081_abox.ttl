@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1439 a ns1:DiagnosticoFallo ;
    rdfs:label "Los ejes de la transformación activa no pueden ser Hirth"@es ;
    ns1:identificador "1439" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar una transformación de coordenadas (#TLC, #RTCP, #TOOL ORI, #CS o #ACS) y uno de los ejes que intervienen en la transformación es Hirth. SOLUCIÓN Un eje hirth no puede formar parte de la transformación de coordenadas. Para que el eje pueda intervenir en la transformación es necesario que deje de ser Hirth (G170)."@es .

ns1:DiagnosticoFallo_1440 a ns1:DiagnosticoFallo ;
    rdfs:label "Herramienta o filo no válido"@es ;
    ns1:identificador "1440" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La herramienta y/o corrector indicado en la variable no existe."@es .

ns1:DiagnosticoFallo_ParadaBusquedaBloque a ns1:DiagnosticoFallo ;
    ns1:textoExtracto "de parada en búsqueda de bloque' DETECCIÓN Durante la ejecución. CAUSA Falta definir el bloque de parada de la búsqueda de bloque. SOLUCIÓN Una vez seleccionada la opción de búsqueda de bloque, en el menú de softkeys aparece la opción para seleccionar el bloque parada. Seleccionar el bloque en el que se desea finalizar la búsqueda de bloque."@es .

ns1:Herramienta_1440 a ns1:Herramienta ;
    ns1:textoExtracto "La herramienta y/o corrector indicado en la variable no existe."@es .

ns1:InterfazUsuario_CNC a ns1:InterfazUsuario ;
    ns1:textoExtracto "en el menú de softkeys aparece la opción para seleccionar el bloque parada"@es .

ns1:Variable_Herramienta a ns1:Parametro ;
    ns1:textoExtracto "La herramienta y/o corrector indicado en la variable no existe"@es .

