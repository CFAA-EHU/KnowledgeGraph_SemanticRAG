@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_HerramientaDesconocida a ns1:DiagnosticoFallo ;
    rdfs:label "Error: Herramienta y/o corrector no existe" ;
    ns1:textoExtracto "CAUSA La herramienta y/o corrector indicado en la variable no existe. SOLUCIÓN Revisar la programación. Consultar las herramientas y correctores existentes." .

ns1:ProgramaPieza a ns1:InterfazUsuario ;
    rdfs:label "Programa pieza (ejecución CNC)" ;
    ns1:activaAlarma ns1:Error_1442 ;
    ns1:textoExtracto "ejecución de un programa pieza" .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:activaAlarma ns1:Error_1441,
        ns1:Error_1442 ;
    ns1:textoExtracto "arranque del CNC" ;
    ns1:tieneComponente ns1:Parametro_KINID .

ns1:Error_1441 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1441: No se ha activado la cinemática" ;
    ns1:identificador "1441" ;
    ns1:textoExtracto "1441 'No se ha activado la cinemática' DETECCIÓN Durante el arranque del CNC o la validación de los parámetros máquina. CAUSA La cinemática que aplica el CNC por defecto (parámetro KINID) es desconocida o los ejes necesarios para la cinemática no son los adecuados." .

ns1:Parametro_KINID a ns1:Parametro ;
    rdfs:label "Parámetro KINID (identificador de cinemática)" ;
    ns1:identificador "KINID" ;
    ns1:textoExtracto "parámetro KINID" .

ns1:Error_1442 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1442: Se ha desactivado la cinemática" ;
    ns1:identificador "1442" ;
    ns1:textoExtracto "1442 'Se ha desactivado la cinemática' DETECCIÓN Tras un reset del CNC o al iniciar la ejecución de un programa pieza." .

