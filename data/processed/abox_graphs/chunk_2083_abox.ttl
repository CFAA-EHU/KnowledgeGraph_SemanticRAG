@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_EjesCanal a ns1:Parametro ;
    rdfs:label "Ejes del canal cinemático"@es ;
    ns1:monitoreaParametro ns1:ComponenteMecanico_Cinematica ;
    ns1:textoExtracto "Los ejes deben [estar] bien definidos y formar parte del canal."@es .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:activaAlarma ns1:AvisoSeguridad_1442 ;
    ns1:textoExtracto "Tras un reset del CNC o al iniciar la ejecución de un programa pieza."@es ;
    ns1:tieneComponente ns1:ComponenteMecanico_Cinematica .

ns1:AvisoSeguridad_1442 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1442: Cinemática desactivada"@es ;
    ns1:identificador "1442" ;
    ns1:textoExtracto "'Se ha desactivado la cinemática' DETECCIÓN Tras un reset del CNC o al iniciar la ejecución de un programa pieza. CAUSA El CNC ha desactivado una cinemática, bien porque es una cinemática desconocida ó bien porque los ejes necesarios para esa cinemática no son los adecuados. SOLUCIÓN Comprobar que el tipo de cinemática es correcto y que los ejes que intervienen en ella están bien definidos y forman parte del canal."@es .

ns1:ComponenteMecanico_Cinematica a ns1:ComponenteMecanico ;
    rdfs:label "Cinemática del sistema CNC"@es ;
    ns1:textoExtracto "El CNC ha desactivado una cinemática, bien porque es una cinemática desconocida ó bien porque los ejes necesarios para esa cinemática no son los adecuados."@es .

