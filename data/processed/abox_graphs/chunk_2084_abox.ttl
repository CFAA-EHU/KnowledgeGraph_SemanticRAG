@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Funcion_CSACS a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función #CS/ACS"@es ;
    ns1:identificador "#CS/ACS" ;
    ns1:monitoreaParametro ns1:Error_1443 ;
    ns1:textoExtracto "El CNC ha intentado hacer una búsqueda de referencia con la función #CS/ACS activa. Para ejecutar un búsqueda de referencia hay que desactivar las funciones #CS/ACS."@es .

ns1:PlanoInclinado a ns1:Sistema ;
    rdfs:label "Plano inclinado"@es ;
    ns1:compuestoPor ns1:Cinematica_Canal ;
    ns1:textoExtracto "Para construir un plano inclinado, los tres primeros ejes del canal deben estar definidos, ser lineales, no estar aparcados y no ser esclavos de un acoplo o de un gantry."@es .

ns1:Solucion_Error1443 a ns1:DiagnosticoFallo ;
    rdfs:label "Solución para error 1443"@es ;
    ns1:solucionaFallo ns1:Error_1443 ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que el tipo de cinemática es correcto y que los ejes que intervienen en ella están bien definidos y forman parte del canal. Los ejes deben ser siempre los primeros del canal, no ser ejes hirth, no estar aparcados y no ser esclavos de un acoplo o de un gantry. Para construir un plano inclinado, los tres primeros ejes del canal deben estar definidos, ser lineales, no estar aparcados y no ser esclavos de un acoplo o de un gantry. Para ejecutar un búsqueda de referencia hay que desactivar las funciones #CS/ACS."@es .

ns1:Cinematica_Canal a ns1:Sistema ;
    rdfs:label "Cinemática de canal"@es ;
    ns1:textoExtracto "Comprobar que el tipo de cinemática es correcto y que los ejes que intervienen en ella están bien definidos y forman parte del canal. Los ejes deben ser siempre los primeros del canal, no ser ejes hirth, no estar aparcados y no ser esclavos de un acoplo o de un gantry."@es .

ns1:Error_1443 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1443: 'Se ha desactivado #CS/ACS'"@es ;
    ns1:identificador "1443" ;
    ns1:textoExtracto "1443 'Se ha desactivado #CS/ACS' DETECCIÓN Tras un reset del CNC, al iniciar la ejecución de un programa pieza o durante la búsqueda de referencia. CAUSA Los ejes utilizados en el plano inclinado no son los adecuados. El CNC ha intentado hacer una búsqueda de referencia con la función #CS/ACS activa."@es .

