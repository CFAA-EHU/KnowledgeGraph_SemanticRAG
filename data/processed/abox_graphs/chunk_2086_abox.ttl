@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_G00FEED a ns1:Parametro ;
    rdfs:label "Parámetro G00FEED"@es ;
    ns1:monitoreaParametro ns1:Regulador_MDU ;
    ns1:textoExtracto "superar los 550 Hz para alcanzar G00FEED"@es ;
    ns1:valor "550" .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:activaAlarma ns1:Error_1447 ;
    ns1:textoExtracto "El CNC no dispone de la opción de software necesaria para ejecutar la orden programada."@es ;
    ns1:tieneComponente ns1:Regulador_MDU .

ns1:Error_1447 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1447: 'Opción de software no permitida'"@es ;
    ns1:identificador "1447" ;
    ns1:textoExtracto "1447 'Opción de software no permitida' [...] Durante la ejecución."@es .

ns1:Regulador_MDU a ns1:ComponenteElectrico ;
    rdfs:label "Regulador de lista de productos doble uso (-MDU)"@es ;
    ns1:identificador "-MDU" ;
    ns1:textoExtracto "Un regulador incluido en la lista de productos doble uso (identificados con el texto -MDU) ha intentado superar los 550 Hz para alcanzar G00FEED."@es .

