@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1449 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1449: 'Sentencia #PATH mal programada'"@es ;
    ns1:identificador "1449" ;
    ns1:textoExtracto "'Sentencia #PATH mal programada'"@es .

ns1:Regulador_MDU a ns1:ComponenteElectrico ;
    rdfs:label "Regulador incluido en lista de productos doble uso (-MDU)"@es ;
    ns1:identificador "-MDU" ;
    ns1:textoExtracto "Un regulador incluido en la lista de productos doble uso (identificados con el texto -MDU) ha intentado superar los 550 Hz para alcanzar G00FEED."@es .

ns1:Software_CNC a ns1:Sistema ;
    rdfs:label "Software CNC"@es ;
    ns1:detalladoEnEsquema ns1:Modo_Diagnosis ;
    ns1:textoExtracto "opciones de software disponibles en el CNC"@es .

ns1:Cabezal_Angular a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal angular"@es ;
    ns1:textoExtracto "El tipo de cabezal no permite colocar la herramienta perpendicular al plano, como puede ser el caso de los cabezales angulares."@es .

ns1:DiagnosticoFallo_1448 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1448: 'No se puede colocar la herramienta perpendicular al plano activo'"@es ;
    ns1:identificador "1448" ;
    ns1:requiereMantenimiento ns1:Cabezal_Angular,
        ns1:Herramienta_1448 ;
    ns1:textoExtracto "'No se puede colocar la herramienta perpendicular al plano activo'"@es .

ns1:Herramienta_1448 a ns1:Herramienta ;
    rdfs:label "Herramienta afectada por fallo 1448"@es ;
    ns1:textoExtracto "No se puede colocar la herramienta perpendicular al plano activo"@es .

ns1:Modo_Diagnosis a ns1:ModoOperacion ;
    rdfs:label "Modo diagnosis"@es ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_1448 ;
    ns1:textoExtracto "En el modo diagnosis se pueden consultar las opciones de software disponibles en el CNC."@es .

