@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1449 a ns1:DiagnosticoFallo ;
    rdfs:label "Sentencia #PATH mal programada" ;
    ns1:identificador "1449" ;
    ns1:textoExtracto "1449 'Sentencia #PATH mal programada' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia #PATH no es correcta. SOLUCIÓN Revisar la programación." .

ns1:DiagnosticoFallo_1450 a ns1:DiagnosticoFallo ;
    rdfs:label "Solución no válida de cabezal perpendicular al plano activo" ;
    ns1:identificador "1450" ;
    ns1:solucionaFallo ns1:Cabezal_Angular,
        ns1:Herramienta_Gen_rica ;
    ns1:textoExtracto "1450 'Solución no válida de cabezal perpendicular al plano activo' DETECCIÓN Durante la ejecución. CAUSA El valor de la variable V.G.TOOLORIF1 o V.G.TOOLORIF2 no es válido porque el CNC no puede colocar la herramienta perpendicular al plano activo. Las posibles causas son las siguientes: • El tipo de cabezal no permite colocar la herramienta perpendicular al plano, como puede ser el caso de los cabezales angulares. • Colocar la herramienta perpendicular al plano activo implica sobrepasar los límites. SOLUCIÓN Definir otro plano o colocar la herramienta en otro punto. Si es posible, utilizar otro cabezal." .

ns1:DiagnosticoFallo_1451 a ns1:DiagnosticoFallo ;
    rdfs:label "Variable inexistente para el tipo de eje" ;
    ns1:identificador "1451" ;
    ns1:textoExtracto "1451 'Variable inexistente para el tipo de eje' DETECCIÓN Durante la ejecución." .

ns1:Variable_VGTOOLORIF1 a ns1:Parametro ;
    rdfs:label "V.G.TOOLORIF1" ;
    ns1:textoExtracto "El valor de la variable V.G.TOOLORIF1 o V.G.TOOLORIF2 no es válido"@es .

ns1:Variable_VGTOOLORIF2 a ns1:Parametro ;
    rdfs:label "V.G.TOOLORIF2" ;
    ns1:textoExtracto "El valor de la variable V.G.TOOLORIF1 o V.G.TOOLORIF2 no es válido"@es .

ns1:Cabezal_Angular a ns1:ComponenteMecanico ;
    rdfs:label "cabezal angular"@es ;
    ns1:textoExtracto "El tipo de cabezal no permite colocar la herramienta perpendicular al plano, como puede ser el caso de los cabezales angulares."@es .

ns1:Herramienta_Gen_rica a ns1:Herramienta ;
    ns1:textoExtracto "colocar la herramienta perpendicular al plano activo"@es .

