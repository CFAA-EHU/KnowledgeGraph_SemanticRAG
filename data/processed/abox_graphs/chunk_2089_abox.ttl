@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1451 a ns1:Alarma ;
    rdfs:label "Variable inexistente para el tipo de eje"@es ;
    ns1:identificador "1451" ;
    ns1:mitigaRiesgo ns1:Parametro_VariableEje ;
    ns1:textoExtracto "1451 'Variable inexistente para el tipo de eje' DETECCIÓN Durante la ejecución. CAUSA La variable no existe para el tipo de eje programado (lineal, rotativo o cabezal). SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_1452 a ns1:Alarma ;
    rdfs:label "Variable inexistente para el tipo de regulador"@es ;
    ns1:identificador "1452" ;
    ns1:mitigaRiesgo ns1:Parametro_VariableRegulador ;
    ns1:textoExtracto "1452 'Variable inexistente para el tipo de regulador' DETECCIÓN Durante la ejecución. CAUSA La variable no existe para el tipo de"@es .

ns1:ComponenteMecanico_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal"@es ;
    ns1:textoExtracto "Si es posible, utilizar otro cabezal."@es .

ns1:Parametro_VariableEje a ns1:Parametro ;
    rdfs:label "Variable de eje"@es ;
    ns1:textoExtracto "La variable no existe para el tipo de eje programado (lineal, rotativo o cabezal)."@es .

ns1:Parametro_VariableRegulador a ns1:Parametro ;
    rdfs:label "Variable de regulador"@es ;
    ns1:textoExtracto "La variable no existe para el tipo de regulador"@es .

