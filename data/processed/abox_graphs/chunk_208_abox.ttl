@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_ProgramExecution a ns1:InterfazUsuario ;
    rdfs:label "Program Execution Interface"@en ;
    ns1:textoExtracto "Select a program. Each channel executes the program selected in it. To select a program, press one of the following softkeys of the vertical menu. [...] The [RESET] key cancels the execution of the program and resets the CNC to its initial conditions."@en ;
    ns1:tieneComponente ns1:Key_RESET,
        ns1:Key_SINGLE,
        ns1:Key_START,
        ns1:Key_STOP,
        ns1:Softkey_EDISIMU,
        ns1:Softkey_ProgramList .

ns1:ModoOperacion_Automatic a ns1:ModoOperacion ;
    rdfs:label "Automatic Execution Mode"@en ;
    ns1:textoExtracto "The program may be executed in –single block– or –automatic– mode; the mode may be selected even while executing the program."@en .

ns1:ModoOperacion_SingleBlock a ns1:ModoOperacion ;
    rdfs:label "Single-Block Execution Mode"@en ;
    ns1:habilitadoPor ns1:Key_SINGLE ;
    ns1:textoExtracto "Single-block execution mode. The program may be executed in –single block– or –automatic– mode; the mode may be selected even while executing the program."@en .

ns1:Key_RESET a ns1:Componente ;
    rdfs:label "RESET Key"@en ;
    ns1:textoExtracto "The [RESET] key cancels the execution of the program and resets the CNC to its initial conditions."@en .

ns1:Key_START a ns1:Componente ;
    rdfs:label "START Key"@en ;
    ns1:textoExtracto "To start the execution of the program, press [START] on the Operator Panel. [...] Press [START] again to resume execution from where it was interrupted."@en .

ns1:Key_STOP a ns1:Componente ;
    rdfs:label "STOP Key"@en ;
    ns1:textoExtracto "The [STOP] key interrupts the execution of the program."@en .

ns1:Softkey_EDISIMU a ns1:Componente ;
    rdfs:label "EDISIMU Mode Softkey"@en ;
    ns1:textoExtracto "This softkey directly selects the program of the EDISIMU mode."@en .

ns1:Softkey_ProgramList a ns1:Componente ;
    rdfs:label "Program List Softkey"@en ;
    ns1:textoExtracto "This softkey shows the list of available programs."@en .

ns1:Key_SINGLE a ns1:Componente ;
    rdfs:label "SINGLE Key"@en ;
    ns1:textoExtracto "Single-block execution mode. The program may be executed in –single block– or –automatic– mode; the mode may be selected even while executing the program."@en .

