@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Error_1452 a ns1:DiagnosticoFallo ;
    rdfs:label "Variable inexistente para el tipo de regulador" ;
    ns1:identificador "1452" ;
    ns1:textoExtracto "1452 'Variable inexistente para el tipo de regulador' DETECCIÓN Durante la ejecución. CAUSA La variable no existe para el tipo de regulador programado (analógico, simulado o Sercos). SOLUCIÓN Revisar la programación." .

ns1:Error_1453 a ns1:DiagnosticoFallo ;
    rdfs:label "Nombre de eje demasiado largo" ;
    ns1:identificador "1453" ;
    ns1:textoExtracto "1453 'Nombre de eje demasiado largo' DETECCIÓN Durante la ejecución. CAUSA El nombre del eje supera la longitud máxima permitida de dos caracteres. SOLUCIÓN El nombre del eje estará definido por 1 ó 2 caracteres. El primer carácter debe ser una de las letras X - Y - Z - U - V - W - A - B - C. El segundo carácter es opcional y será un sufijo numérico entre 1 y 9. De esta forma el nombre de los ejes podrá ser cualquiera del rango X, X1…X9,...C, C1…C9." .

ns1:Error_1455 a ns1:DiagnosticoFallo ;
    rdfs:label "PERFIL: Perfil nulo" ;
    ns1:identificador "1455" ;
    ns1:textoExtracto "1455 'PERFIL: Perfil nulo' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • En el ciclo de perfil del editor de ciclos no se ha indicado el fichero que contiene el perfil. • El fichero indicado en el ciclo de perfil del editor de ciclos está vacío. SOLUCIÓN En el ciclo de perfil del editor de ciclos hay que indicar el fichero que contiene el perfil." .

ns1:Error_1456 a ns1:DiagnosticoFallo ;
    rdfs:label "#POLY: Faltan parámetros" ;
    ns1:identificador "1456" ;
    ns1:textoExtracto "1456 '#POLY: Faltan parámetros' DETECCIÓN Durante la ejecución. CAUSA En la programación de la sentencia #POLY falta algún parámetro obligatorio. SOLUCIÓN Revisar la programación." .

ns1:Error_1457 a ns1:DiagnosticoFallo ;
    rdfs:label "#POLY: Valor de parámetro no válido" ;
    ns1:identificador "1457" ;
    ns1:textoExtracto "1457 '#POLY: Valor de parámetro no válido' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • Los parámetros de interpolación del polinomio no son correctos. • El radio de curvatura es menor o igual que cero." .

ns1:Fichero_Perfil a ns1:Parametro ;
    rdfs:label "Fichero de perfil" ;
    ns1:textoExtracto "En el ciclo de perfil del editor de ciclos no se ha indicado el fichero que contiene el perfil. El fichero indicado en el ciclo de perfil del editor de ciclos está vacío." .

ns1:Nombre_Eje a ns1:Parametro ;
    rdfs:label "Nombre de eje" ;
    ns1:textoExtracto "El nombre del eje supera la longitud máxima permitida de dos caracteres. El nombre del eje estará definido por 1 ó 2 caracteres. El primer carácter debe ser una de las letras X - Y - Z - U - V - W - A - B - C. El segundo carácter es opcional y será un sufijo numérico entre 1 y 9." ;
    ns1:valor "X, X1, ..., X9, ..., C, C1, ..., C9" .

ns1:Parametro_InterpolacionPolinomica a ns1:Parametro ;
    rdfs:label "Parámetros de interpolación del polinomio" ;
    ns1:textoExtracto "Los parámetros de interpolación del polinomio no son correctos." .

ns1:Parametro_RadioCurvatura a ns1:Parametro ;
    rdfs:label "Radio de curvatura" ;
    ns1:textoExtracto "El radio de curvatura es menor o igual que cero." ;
    ns1:valor 0.0 .

ns1:Variable_Regulador a ns1:Parametro ;
    rdfs:label "Variable de regulador" ;
    ns1:textoExtracto "La variable no existe para el tipo de regulador programado (analógico, simulado o Sercos)." .

