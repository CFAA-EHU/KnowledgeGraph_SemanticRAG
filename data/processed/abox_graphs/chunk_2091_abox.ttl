@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Alarma_1457 a ns1:Alarma ;
    rdfs:label "Alarma #POLY: Valor de parámetro no válido" ;
    ns1:identificador "#POLY" ;
    ns1:monitoreaParametro ns1:Parametro_InterpolacionPolinomio_1457,
        ns1:Parametro_RadioCurvatura_1457 ;
    ns1:textoExtracto "'#POLY: Valor de parámetro no válido' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • Los parámetros de interpolación del polinomio no son correctos. • El radio de curvatura es menor o igual que cero. SOLUCIÓN Los parámetros de interpolación del polinomio deben ser positivos, el parámetro inicial de la interpolación (SP) debe ser menor que el parámetro final (EP) y el radio de curvatura debe ser mayor que cero." .

ns1:Alarma_1458 a ns1:Alarma ;
    rdfs:label "Alarma #POLY: Demasiados ejes programados" ;
    ns1:identificador "#POLY" ;
    ns1:monitoreaParametro ns1:Parametro_EjesPolinomio_1458 ;
    ns1:textoExtracto "'#POLY: Demasiados ejes programados' DETECCIÓN Durante la ejecución. CAUSA Hay más de tres ejes en el polinomio. SOLUCIÓN En la interpolación polinómica sólo pueden intervenir tres ejes." .

ns1:Alarma_1459 a ns1:Alarma ;
    rdfs:label "Alarma #POLY: Punto inicial no válido" ;
    ns1:identificador "#POLY" ;
    ns1:textoExtracto "'#POLY: Punto inicial no válido' DETECCIÓN Durante la ejecución." .

ns1:Parametro_EP_1457 a ns1:Parametro ;
    rdfs:label "Parámetro final de interpolación (EP)" ;
    ns1:textoExtracto "el parámetro inicial de la interpolación (SP) debe ser menor que el parámetro final (EP)" .

ns1:Parametro_SP_1457 a ns1:Parametro ;
    rdfs:label "Parámetro inicial de interpolación (SP)" ;
    ns1:textoExtracto "el parámetro inicial de la interpolación (SP) debe ser menor que el parámetro final (EP)" .

ns1:Parametro_EjesPolinomio_1458 a ns1:Parametro ;
    rdfs:label "Número de ejes en interpolación polinómica" ;
    ns1:textoExtracto "Hay más de tres ejes en el polinomio. [...] sólo pueden intervenir tres ejes." ;
    ns1:valor 3 .

ns1:Parametro_InterpolacionPolinomio_1457 a ns1:Parametro ;
    rdfs:label "Parámetro de interpolación polinómica" ;
    ns1:textoExtracto "Los parámetros de interpolación del polinomio no son correctos. [...] Los parámetros de interpolación del polinomio deben ser positivos, el parámetro inicial de la interpolación (SP) debe ser menor que el parámetro final (EP)" .

ns1:Parametro_RadioCurvatura_1457 a ns1:Parametro ;
    rdfs:label "Radio de curvatura" ;
    ns1:textoExtracto "El radio de curvatura es menor o igual que cero. [...] el radio de curvatura debe ser mayor que cero." ;
    ns1:valor "0.0"^^xsd:float .

