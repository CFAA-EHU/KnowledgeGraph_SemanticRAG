@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjeRotativoModulo a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo de tipo módulo" ;
    ns1:textoExtracto "eje rotativo tipo MODULO" .

ns1:FuncionRTCP a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función RTCP" ;
    ns1:textoExtracto "funciones RTCP y TLC" .

ns1:FuncionTLC a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función TLC" ;
    ns1:textoExtracto "funciones RTCP y TLC" .

ns1:ParametroModuloInferior a ns1:Parametro ;
    rdfs:label "Límite inferior del módulo" ;
    ns1:textoExtracto "parámetros máquina MODLOWLIM" .

ns1:ParametroModuloSuperior a ns1:Parametro ;
    rdfs:label "Límite superior del módulo" ;
    ns1:textoExtracto "límites fijados por sus parámetros máquina MODUPLIM" .

ns1:PolinomioInterp a ns1:Parametro ;
    rdfs:label "Polinomio de interpolación con restricción de ejes" ;
    ns1:textoExtracto "En la interpolación polinómica sólo pueden intervenir tres ejes." .

ns1:PosicionActual a ns1:Parametro ;
    rdfs:label "Posición actual de la máquina" ;
    ns1:textoExtracto "el punto inicial del polinomio coincida con la posición actual" .

ns1:PosicionFinalBloqueAnterior a ns1:Parametro ;
    rdfs:label "Posición final del bloque anterior" ;
    ns1:textoExtracto "coincida con la posición final del bloque anterior" .

ns1:PuntoFinalMovimientoAnterior a ns1:Parametro ;
    rdfs:label "Punto final del movimiento anterior" ;
    ns1:textoExtracto "junto con el punto final del movimiento anterior definan un arco" .

ns1:PuntoIntermedioArco a ns1:Parametro ;
    rdfs:label "Punto intermedio del arco" ;
    ns1:textoExtracto "programación de las dos coordenadas del punto intermedio del arco" .

ns1:RadioTrayectoria a ns1:Parametro ;
    rdfs:label "Radio de trayectoria" ;
    ns1:textoExtracto "arco tangente a la trayectoria anterior con el radio y punto final programados" .

