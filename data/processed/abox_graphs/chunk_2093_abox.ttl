@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1465 a ns1:DiagnosticoFallo ;
    rdfs:label "Conflicto de activación simultánea RTCP/TLC"@es ;
    ns1:solucionaFallo ns1:Alarma_1465 ;
    ns1:textoExtracto "El CNC ha intentado activar una de las funciones estando la otra activa. No es posible tener ambas funciones activas simultáneamente."@es .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:activaAlarma ns1:Alarma_1465,
        ns1:Alarma_1466 ;
    ns1:textoExtracto "El CNC ha intentado activar una de las funciones (RTCP/TLC)."@es .

ns1:Alarma_1466 a ns1:Alarma ;
    rdfs:label "Alarma 1466: Restricción de programación G8 en bloques G36/G37/G38/G39"@es ;
    ns1:identificador "1466" ;
    ns1:textoExtracto "'No se puede programar G8 como segundo bloque de movimiento para G36/G37/G38/G39' DETECCIÓN Durante la ejecución."@es .

ns1:Alarma_1465 a ns1:Alarma ;
    rdfs:label "Alarma 1465: Incompatibilidad RTCP/TLC"@es ;
    ns1:identificador "1465" ;
    ns1:textoExtracto "'Las funciones RTCP y TLC son incompatibles' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar una de las funciones estando la otra activa. SOLUCIÓN No es posible tener ambas funciones activas simultáneamente."@es .

