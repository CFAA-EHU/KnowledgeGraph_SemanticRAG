@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Solucion_1470 a ns1:TareaMantenimiento ;
    rdfs:label "Corrección de cota incremental para eje rotativo UNIDIR"@es ;
    ns1:solucionaFallo ns1:Fallo_1470 ;
    ns1:textoExtracto "Si el parámetro máquina UNIDIR del eje rotativo es POSITIVO la cota incremental programada debe ser positiva o nula. Si el parámetro máquina UNIDIR del eje rotativo es NEGATIVO la cota incremental programada debe ser negativa o nula."@es .

ns1:Fallo_1470 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje rotativo UNIDIR con programación incremental incorrecta"@es ;
    ns1:identificador "1470" ;
    ns1:monitoreaParametro ns1:Parametro_UNIDIR ;
    ns1:textoExtracto "'Eje rotativo UNIDIR con programación incremental incorrecta' DETECCIÓN Durante la ejecución. CAUSA La cota incremental programada para el eje rotativo unidireccional (parámetro UNIDIR) no es válida."@es .

ns1:Parametro_UNIDIR a ns1:Parametro ;
    rdfs:label "Parámetro máquina UNIDIR"@es ;
    ns1:identificador "UNIDIR" ;
    ns1:textoExtracto "parámetro máquina UNIDIR del eje rotativo"@es ;
    ns1:valor "POSITIVO/NEGATIVO"@es .

