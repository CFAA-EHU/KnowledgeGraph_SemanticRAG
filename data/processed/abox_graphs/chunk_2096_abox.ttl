@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1471 a ns1:Alarma ;
    rdfs:label "Alarma 1471: G73 - Programación incorrecta del centro de giro"@es ;
    ns1:identificador "1471" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_1471 ;
    ns1:textoExtracto "1471 'G73: programación incorrecta del centro de giro' DETECCIÓN Durante la ejecución. CAUSA En la función G73 falta programar una de las dos coordenadas del centro de giro. SOLUCIÓN Revisar la programación. Es necesario programar las coordenadas del centro de giro en los dos ejes principales."@es .

ns1:Alarma_1472 a ns1:Alarma ;
    rdfs:label "Alarma 1472: G73 - Falta programar ángulo de giro"@es ;
    ns1:identificador "1472" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_1472 ;
    ns1:textoExtracto "1472 'G73: falta programar ángulo de giro' DETECCIÓN Durante la ejecución. CAUSA En la función G73 falta programar el ángulo de giro. SOLUCIÓN Revisar la programación. Es necesario programar el ángulo de giro del sistema de coordenadas junto con las coordenadas del centro de giro en los dos ejes principales."@es .

ns1:Alarma_1473 a ns1:Alarma ;
    rdfs:label "Alarma 1473: Programación #POLY no permitida con giro activo"@es ;
    ns1:identificador "1473" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_1473 ;
    ns1:textoExtracto "1473 'Programación #POLY no permitida con giro activo' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar la sentencia #POLY con un giro del sistema de coordenadas activo (G73). SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_1475 a ns1:Alarma ;
    rdfs:label "Alarma 1475: Radio doblemente programado"@es ;
    ns1:identificador "1475" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_1475 ;
    ns1:textoExtracto "1475 'Radio doblemente programado' DETECCIÓN Durante la ejecución. CAUSA El radio (\"R\" o \"R1\") está programado más de una vez en el mismo bloque. SOLUCIÓN Definir un solo radio en el bloque."@es .

ns1:Alarma_1476 a ns1:Alarma ;
    rdfs:label "Alarma 1476: Radio de punta de herramienta inconsistente"@es ;
    ns1:identificador "1476" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_1476 ;
    ns1:textoExtracto "1476 'La cajera fue resuelta con diferente radio de la punta de herramienta' DETECCIÓN Durante la ejecución. CAUSA El CNC generó la cajera con un radio de herramienta diferente al actual. SOLUCIÓN Generar de nuevo la cajera."@es .

ns1:Alarma_1477 a ns1:Alarma ;
    rdfs:label "Alarma 1477: Longitud de corte de herramienta inconsistente"@es ;
    ns1:identificador "1477" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_1477 ;
    ns1:textoExtracto "1477 'La cajera fue resuelta con diferente longitud de corte de herramienta' DETECCIÓN Durante la ejecución. CAUSA El CNC generó la cajera con una longitud de corte de herramienta diferente a la actual. SOLUCIÓN Generar de nuevo la cajera."@es .

ns1:Herramienta_CNC a ns1:Herramienta ;
    rdfs:label "Herramienta de CNC (radio y longitud)"@es ;
    ns1:textoExtracto "radio de la punta de herramienta" .

ns1:SistemaCoordenadas_G73 a ns1:Sistema ;
    rdfs:label "Sistema de coordenadas con función G73"@es ;
    ns1:textoExtracto "función G73" ;
    ns1:tieneComponente ns1:Parametro_UNIDIR .

ns1:AvisoSeguridad_1471_Solucion a ns1:AvisoSeguridad ;
    rdfs:label "Solución para alarma 1471"@es ;
    ns1:textoExtracto "Revisar la programación. Es necesario programar las coordenadas del centro de giro en los dos ejes principales."@es .

ns1:AvisoSeguridad_1472_Solucion a ns1:AvisoSeguridad ;
    rdfs:label "Solución para alarma 1472"@es ;
    ns1:textoExtracto "Revisar la programación. Es necesario programar el ángulo de giro del sistema de coordenadas junto con las coordenadas del centro de giro en los dos ejes principales."@es .

ns1:AvisoSeguridad_1473_Solucion a ns1:AvisoSeguridad ;
    rdfs:label "Solución para alarma 1473"@es ;
    ns1:textoExtracto "Revisar la programación."@es .

ns1:AvisoSeguridad_1475_Solucion a ns1:AvisoSeguridad ;
    rdfs:label "Solución para alarma 1475"@es ;
    ns1:textoExtracto "Definir un solo radio en el bloque."@es .

ns1:AvisoSeguridad_1476_Solucion a ns1:AvisoSeguridad ;
    rdfs:label "Solución para alarma 1476"@es ;
    ns1:textoExtracto "Generar de nuevo la cajera."@es .

ns1:AvisoSeguridad_1477_Solucion a ns1:AvisoSeguridad ;
    rdfs:label "Solución para alarma 1477"@es ;
    ns1:textoExtracto "Generar de nuevo la cajera."@es .

ns1:DiagnosticoFallo_1471 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta programación de coordenadas en G73"@es ;
    ns1:solucionaFallo ns1:AvisoSeguridad_1471_Solucion ;
    ns1:textoExtracto "En la función G73 falta programar una de las dos coordenadas del centro de giro."@es .

ns1:DiagnosticoFallo_1472 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta programación de ángulo en G73"@es ;
    ns1:solucionaFallo ns1:AvisoSeguridad_1472_Solucion ;
    ns1:textoExtracto "En la función G73 falta programar el ángulo de giro."@es .

ns1:DiagnosticoFallo_1473 a ns1:DiagnosticoFallo ;
    rdfs:label "Conflicto entre #POLY y G73"@es ;
    ns1:solucionaFallo ns1:AvisoSeguridad_1473_Solucion ;
    ns1:textoExtracto "El CNC ha intentado ejecutar la sentencia #POLY con un giro del sistema de coordenadas activo (G73)."@es .

ns1:DiagnosticoFallo_1475 a ns1:DiagnosticoFallo ;
    rdfs:label "Radio duplicado en bloque"@es ;
    ns1:solucionaFallo ns1:AvisoSeguridad_1475_Solucion ;
    ns1:textoExtracto "El radio (\"R\" o \"R1\") está programado más de una vez en el mismo bloque."@es .

ns1:DiagnosticoFallo_1476 a ns1:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en radio de herramienta"@es ;
    ns1:solucionaFallo ns1:AvisoSeguridad_1476_Solucion ;
    ns1:textoExtracto "El CNC generó la cajera con un radio de herramienta diferente al actual."@es .

ns1:DiagnosticoFallo_1477 a ns1:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en longitud de corte"@es ;
    ns1:solucionaFallo ns1:AvisoSeguridad_1477_Solucion ;
    ns1:textoExtracto "El CNC generó la cajera con una longitud de corte de herramienta diferente a la actual."@es .

ns1:Parametro_UNIDIR a ns1:Parametro ;
    rdfs:label "Parámetro UNIDIR del eje rotativo"@es ;
    ns1:textoExtracto "Si el parámetro máquina UNIDIR del eje rotativo es NEGATIVO la cota incremental programada debe ser negativa o nula."@es ;
    ns1:valor "NEGATIVO/POSITIVO"@es .

