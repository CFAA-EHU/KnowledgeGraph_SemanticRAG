@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tarea_RegenerarCajera a ns1:TareaMantenimiento ;
    rdfs:label "Regenerar cajera" ;
    ns1:ejecutadoPor ns1:Herramienta_CNC ;
    ns1:solucionaFallo ns1:Fallo_1478,
        ns1:Fallo_1479 ;
    ns1:textoExtracto "Generar de nuevo la cajera" .

ns1:Fallo_1478 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1478: Cajera con ángulo de entrada de herramienta incorrecto" ;
    ns1:identificador "1478" ;
    ns1:textoExtracto "'La cajera fue resuelta con diferente ángulo de entrada de herramienta'" .

ns1:Fallo_1479 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1479: G74 - Falta asociación de subrutina" ;
    ns1:identificador "1479" ;
    ns1:textoExtracto "'G74: falta asociar subrutina'" .

ns1:Herramienta_CNC a ns1:Herramienta ;
    rdfs:label "Herramienta de corte CNC" ;
    ns1:textoExtracto "longitud de corte de herramienta" .

