@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Funcion_G74 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G74" ;
    ns1:solucionaFallo ns1:Error_1479 ;
    ns1:textoExtracto "Hay programada una función G74 sola en el bloque y no existe la subrutina asociada." .

ns1:Parametro_REFPSUB a ns1:Parametro ;
    rdfs:label "Parámetro REFPSUB" ;
    ns1:textoExtracto "definir la subrutina asociada (parámetro REFPSUB)" .

ns1:Sentencia_EXEC a ns1:Parametro ;
    rdfs:label "Sentencia #EXEC" ;
    ns1:solucionaFallo ns1:Error_1480 ;
    ns1:textoExtracto "La sintaxis de la sentencia no es correcta o hay más información en el bloque." .

ns1:Sentencia_MEET a ns1:Parametro ;
    rdfs:label "Sentencia #MEET" ;
    ns1:solucionaFallo ns1:Error_1481 ;
    ns1:textoExtracto "Número de canal no válido en la sentencia [...] #MEET" .

ns1:Sentencia_WAIT a ns1:Parametro ;
    rdfs:label "Sentencia #WAIT" ;
    ns1:solucionaFallo ns1:Error_1481 ;
    ns1:textoExtracto "Número de canal no válido en la sentencia [...] #WAIT" .

ns1:Error_1479 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1479: 'G74: falta asociar subrutina'" ;
    ns1:identificador "1479" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Hay programada una función G74 sola en el bloque y no existe la subrutina asociada. SOLUCIÓN Programar junto a la función G74 los ejes a referenciar o definir la subrutina asociada (parámetro REFPSUB)." .

ns1:Error_1480 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1480: 'Programar: #EXEC [\"path+programa\",canal]'" ;
    ns1:identificador "1480" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque." .

ns1:Error_1481 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1481: 'Número de canal no válido'" ;
    ns1:identificador "1481" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Número de canal no válido en la sentencia #EXEC, #MEET o #WAIT." .

