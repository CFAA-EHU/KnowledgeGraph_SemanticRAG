@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1483 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1483: Sintaxis incorrecta en sentencia #WAIT/#MEET"@es ;
    ns1:identificador "1483" ;
    ns1:solucionaFallo ns1:AccionProhibida_1483 ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque."@es .

ns1:DiagnosticoFallo_1483_CanalInvalido a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1483: Número de canal no válido"@es ;
    ns1:identificador "1483-Canal" ;
    ns1:solucionaFallo ns1:Parametro_1483_CanalesValidos ;
    ns1:textoExtracto "CAUSA Número de canal no válido en la sentencia #EXEC, #MEET o #WAIT. SOLUCIÓN El número de canal debe estar comprendido entre 1 y 4."@es .

ns1:DiagnosticoFallo_1484 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1484: Número de señal fuera de rango"@es ;
    ns1:identificador "1484" ;
    ns1:textoExtracto "CAUSA El número de señal programada en la sentencia #WAIT, #MEET o #SIGNAL no es correcto. SOLUCIÓN Revisar la programación."@es .

ns1:DiagnosticoFallo_1485 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1485: #WAIT/#MEET no efectivo"@es ;
    ns1:identificador "1485" ;
    ns1:solucionaFallo ns1:AccionProhibida_1485 ;
    ns1:textoExtracto "CAUSA La sentencia #WAIT o #MEET no va a generar ninguna espera, porque la marca de sincronización está programada para el mismo canal que las sentencias."@es .

ns1:AccionProhibida_1483 a ns1:AccionProhibida ;
    rdfs:label "Programar múltiples sentencias en un mismo bloque"@es ;
    ns1:textoExtracto "Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque."@es .

ns1:AccionProhibida_1485 a ns1:AccionProhibida ;
    rdfs:label "Programar marca de sincronización en el mismo canal que la sentencia #WAIT/#MEET"@es ;
    ns1:textoExtracto "la marca de sincronización está programada para el mismo canal que las sentencias"@es .

ns1:Parametro_1483_CanalesValidos a ns1:Parametro ;
    rdfs:label "Rango válido de canales (1-4)"@es ;
    ns1:textoExtracto "El número de canal debe estar comprendido entre 1 y 4."@es ;
    ns1:valor "1-4" .

