@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BlockExecutionMode a ns1:ModoOperacion ;
    rdfs:label "Execute Blocks Separately mode" ;
    ns1:habilitadoPor ns1:EXBLK_Softkey ;
    ns1:textoExtracto "Being this option active, every time the [START] key is pressed, it only executes the block selected in the active program." .

ns1:M_G_Functions_History a ns1:Parametro ;
    rdfs:label "M and G functions history" ;
    ns1:textoExtracto "Blocks executed like this change the history of the M and G functions." .

ns1:START_Key a ns1:InterfazUsuario ;
    rdfs:label "START key" ;
    ns1:identificador "START" ;
    ns1:textoExtracto "[START] key" .

ns1:EXBLK_Softkey a ns1:InterfazUsuario ;
    rdfs:label "EXBLK softkey" ;
    ns1:identificador "EXBLK" ;
    ns1:textoExtracto "Press the 'EXBLK' softkey of the horizontal menu." .

