@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error1487 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1487: Sintaxis incorrecta en programación de bloque" ;
    ns1:identificador "1487" ;
    ns1:solucionaFallo ns1:Sentencia_CLEAR ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque. 1487 'Programar: #CLEAR [señal, señal, señal, ...]'" .

ns1:Error1489 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1489: Nombre de eje repetido en grupo" ;
    ns1:identificador "1489" ;
    ns1:solucionaFallo ns1:Sentencia_RENAME ;
    ns1:textoExtracto "1489 'Nombre de eje repetido en el grupo resultante'" .

ns1:Error1490 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1490: Secuencia incorrecta de programación (G63/M19)" ;
    ns1:identificador "1490" ;
    ns1:solucionaFallo ns1:Sentencia_M19 ;
    ns1:textoExtracto "1490 'G63 necesita programar previamente M19'" .

ns1:Sentencia_G63 a ns1:Parametro ;
    rdfs:label "Sentencia G63" ;
    ns1:textoExtracto "G63 necesita programar previamente M19" ;
    ns1:valor "G63" .

ns1:Sentencia_CLEAR a ns1:Parametro ;
    rdfs:label "Sentencia #CLEAR" ;
    ns1:textoExtracto "Programar: #CLEAR [señal, señal, señal, ...]" ;
    ns1:valor "#CLEAR" .

ns1:Sentencia_M19 a ns1:Parametro ;
    rdfs:label "Sentencia M19" ;
    ns1:textoExtracto "G63 necesita programar previamente M19" ;
    ns1:valor "M19" .

ns1:Sentencia_RENAME a ns1:Parametro ;
    rdfs:label "Sentencia #RENAME" ;
    ns1:textoExtracto "La sentencia #RENAME ha intentado renombrar más de un eje con el mismo nombre" ;
    ns1:valor "#RENAME" .

