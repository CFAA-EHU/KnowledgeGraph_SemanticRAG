@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Ciclo_PROBE1 a ns1:ModoOperacion ;
    rdfs:label "Ciclo PROBE1"@es ;
    ns1:activaAlarma ns1:Error_1495,
        ns1:Error_1496 ;
    ns1:textoExtracto "ciclo PROBE1"@es .

ns1:Herramienta_CNC a ns1:Herramienta ;
    rdfs:label "Herramienta CNC con orientación de eje"@es ;
    ns1:textoExtracto "la herramienta orientada en el sentido negativo del eje"@es .

ns1:VariableProgramacion a ns1:Parametro ;
    rdfs:label "Variable de programación CNC"@es ;
    ns1:activaAlarma ns1:Error_1497 ;
    ns1:textoExtracto "tipo de variable"@es .

ns1:Error_1495 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1495: '#PROBE1: eje no válido para ciclo de palpador'"@es ;
    ns1:identificador "1495" ;
    ns1:textoExtracto "1495 '#PROBE1: eje no válido para ciclo de palpador' DETECCIÓN Durante la ejecución. CAUSA El ciclo PROBE1 da error porque los tres primeros ejes de la configuración actual no coinciden con los tres primeros ejes de la configuración inicial. SOLUCIÓN Restaurar la configuración inicial de los tres primeros ejes del canal."@es .

ns1:Error_1496 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1496: '#PROBE1: programación no permitida con #TOOL AX[-] activo'"@es ;
    ns1:identificador "1496" ;
    ns1:textoExtracto "1496 '#PROBE1: programación no permitida con #TOOL AX[-] activo' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar el ciclo PROBE1 teniendo la herramienta orientada en el sentido negativo del eje. SOLUCIÓN Programar #TOOL AX[+] antes de ejecutar el ciclo PROBE1 para orientar la herramienta en el sentido positivo del eje."@es .

ns1:Error_1497 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1497: 'Operador incorrecto para el tipo de variable'"@es ;
    ns1:identificador "1497" ;
    ns1:textoExtracto "1497 'Operador incorrecto para el tipo de variable' DETECCIÓN Durante la ejecución."@es .

