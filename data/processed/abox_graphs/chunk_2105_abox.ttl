@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Error1497 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1497: Operador incorrecto para el tipo de variable" ;
    ns1:identificador "1497" ;
    ns1:textoExtracto "'Operador incorrecto para el tipo de variable' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado modificar mediante los operadores \"+=\", \"-=\", \"*=\" y \"/=\" alguna variable no numérica. SOLUCIÓN Revisar la programación." .

ns1:ModoAutomatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático" ;
    ns1:textoExtracto "modo automático" .

ns1:SentenciaEXEC a ns1:Parametro ;
    rdfs:label "Sentencia #EXEC" ;
    ns1:activaAlarma ns1:Error1500 ;
    ns1:identificador "#EXEC" ;
    ns1:textoExtracto "sentencia #EXEC" .

ns1:SentenciaRPT a ns1:Parametro ;
    rdfs:label "Sentencia #RPT" ;
    ns1:activaAlarma ns1:Error1499 ;
    ns1:identificador "#RPT" ;
    ns1:textoExtracto "sentencia #RPT" .

ns1:Error1499 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1499: Número de anidamientos de #RPT y subrutinas sobrepasado" ;
    ns1:identificador "1499" ;
    ns1:textoExtracto "'Número de anidamientos de #RPT y subrutinas sobrepasado' DETECCIÓN Durante la ejecución. CAUSA Se considera anidamiento cuando la sentencia #RPT se programa entre dos etiquetas que definen el radio de acción de otra sentencia #RPT. El CNC da error cuando sobrepasa el número de anidamientos de sentencias RPT y subrutinas, si las hay. SOLUCIÓN El máximo número de anidamientos permitido es 20." ;
    ns1:valor 20 .

ns1:Error1500 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1500: #EXEC: no se puede ejecutar el programa en el canal indicado" ;
    ns1:identificador "1500" ;
    ns1:mitigaRiesgo ns1:ModoManual ;
    ns1:textoExtracto "'#EXEC: no se puede ejecutar el programa en el canal indicado' DETECCIÓN Durante la ejecución. CAUSA Mediante la sentencia #EXEC, el CNC ha intentado ejecutar un programa en un canal que está en error, que está ejecutando otro programa o que está en modo manual y no puede pasar a modo automático." .

ns1:ModoManual a ns1:ModoOperacion ;
    rdfs:label "Modo manual" ;
    ns1:textoExtracto "modo manual" .

