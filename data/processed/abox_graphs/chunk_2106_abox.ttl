@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error1501 a ns1:AvisoSeguridad ;
    rdfs:label "Etiquetas repetidas en #RPT"@es ;
    ns1:identificador "1501" ;
    ns1:textoExtracto "1501 'Etiquetas repetidas en #RPT' DETECCIÓN Durante la ejecución. CAUSA En la sentencia #RPT la etiqueta inicial y final es la misma. SOLUCIÓN Definir etiquetas inicial y final diferentes."@es .

ns1:Error1502 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1502"@es ;
    ns1:identificador "1502" ;
    ns1:textoExtracto "1502"@es .

