@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BloqueProgramacion a ns1:Componente ;
    ns1:textoExtracto "La etiqueta final se debe programar sola en el bloque"@es ;
    ns1:tieneComponente ns1:SistemaControlNumerico .

ns1:Error_G201_EjeC a ns1:AvisoSeguridad ;
    rdfs:label "Error 1508: 'No se admiten G201 y eje C activo en los ejes del plano principal'"@es ;
    ns1:identificador "1508" ;
    ns1:textoExtracto "1508 'No se admiten G201 y eje C activo en los ejes del plano principal'"@es .

ns1:SistemaControlNumerico a ns1:Sistema ;
    ns1:activaAlarma ns1:Error_G201_EjeC ;
    ns1:textoExtracto "Programar el comando en la línea anterior si se desea que se ejecute con el #RPT o en la línea inferior si no se desea que se ejecute con el #RPT"@es .

