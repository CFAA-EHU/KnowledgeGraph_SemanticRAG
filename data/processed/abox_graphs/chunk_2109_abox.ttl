@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_RPT1508 a ns1:Alarma ;
    rdfs:label "Alarma RPT 1508" ;
    ns1:activaAlarma ns1:Componente_EjeC,
        ns1:ModoOperacion_G201 ;
    ns1:identificador "RPT.1508" ;
    ns1:textoExtracto "'No se admiten G201 y eje C activo en los ejes del plano principal' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • Uno de los ejes implicados en la función G201 es eje C y forma parte de los tres primeros ejes del canal. • Uno de los ejes programados en la sentencia #FACE está en modo manual aditivo, G201. SOLUCIÓN Anular el eje C o el modo manual aditivo." .

ns1:Alarma_RPT1509 a ns1:Alarma ;
    rdfs:label "Alarma RPT 1509" ;
    ns1:activaAlarma ns1:Sistema_ConfiguracionEjes ;
    ns1:identificador "RPT.1509" ;
    ns1:textoExtracto "'#SET AX/#CALL AX: la programación de offsets no tiene efecto' DETECCIÓN Durante la ejecución. CAUSA Todos los ejes programados en la sentencia pertenecían ya a la configuración actual y por tanto, la sentencia sólo supone un cambio de orden. En este caso la opción de offsets programada no tiene efecto. SOLUCIÓN Revisar la programación." .

ns1:Alarma_RPT1510 a ns1:Alarma ;
    rdfs:label "Alarma RPT 1510" ;
    ns1:identificador "RPT.1510" ;
    ns1:textoExtracto "'Eje inexistente o no disponible en el canal' DETECCIÓN Durante la ejecución." .

ns1:ModoOperacion_ManualAditivo a ns1:ModoOperacion ;
    rdfs:label "Modo manual aditivo" ;
    ns1:textoExtracto "modo manual aditivo" .

ns1:ModoOperacion_G201 a ns1:ModoOperacion ;
    rdfs:label "Modo G201" ;
    ns1:identificador "G201" ;
    ns1:textoExtracto "modo manual aditivo, G201" .

ns1:Sistema_ConfiguracionEjes a ns1:Sistema ;
    rdfs:label "Configuración de ejes del canal" ;
    ns1:textoExtracto "configuración actual" ;
    ns1:tieneComponente ns1:Componente_EjeC .

ns1:Componente_EjeC a ns1:Componente ;
    rdfs:label "Eje C" ;
    ns1:identificador "eje C" ;
    ns1:textoExtracto "eje C" .

