@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ControlEjeHusillo a ns1:ComponenteMecanico ;
    rdfs:label "Spindle control"@en ;
    ns1:textoExtracto "movement of axes, spindle"@en .

ns1:InterfazUsuario_CNC a ns1:InterfazUsuario ;
    rdfs:label "CNC operator panel"@en ;
    ns1:textoExtracto "On the horizontal softkey menu, select the desired type of simulation. [...] The vertical softkey menu offers two options."@en ;
    ns1:tieneComponente ns1:BotonStart,
        ns1:BotonStop,
        ns1:MenuSoftkeyHorizontal,
        ns1:MenuSoftkeyVertical .

ns1:ModoSimulacion_GFunctions a ns1:ModoOperacion ;
    rdfs:label "G functions simulation mode"@en ;
    ns1:textoExtracto "G functions. | Tool center | No | No | No | Yes | Yes"@en ;
    ns1:tieneComponente ns1:TrayectoriaHerramienta_CentroHerramienta .

ns1:ModoSimulacion_GMSFunctions a ns1:ModoOperacion ;
    rdfs:label "G M S T functions simulation mode"@en ;
    ns1:textoExtracto "G M S T functions. | Tool center | No | No | Yes | Yes | Yes"@en ;
    ns1:tieneComponente ns1:TrayectoriaHerramienta_CentroHerramienta .

ns1:ModoSimulacion_MainPlane a ns1:ModoOperacion ;
    rdfs:label "Main plane simulation mode"@en ;
    ns1:textoExtracto "Main plane. | Tool center | Yes (plane) | Yes | Yes | No | Yes"@en ;
    ns1:tieneComponente ns1:TrayectoriaHerramienta_CentroHerramienta .

ns1:ModoSimulacion_Rapid a ns1:ModoOperacion ;
    rdfs:label "Rapid simulation mode"@en ;
    ns1:textoExtracto "Rapid. | Tool center | Yes | Yes | Yes | No | Yes"@en ;
    ns1:tieneComponente ns1:TrayectoriaHerramienta_CentroHerramienta .

ns1:ModoSimulacion_RapidS0 a ns1:ModoOperacion ;
    rdfs:label "Rapid [S=0] simulation mode"@en ;
    ns1:textoExtracto "Rapid [S=0]. | Tool center | Yes | No | Yes | No | Yes"@en ;
    ns1:tieneComponente ns1:TrayectoriaHerramienta_CentroHerramienta .

ns1:ModoSimulacion_TeoreticalTravel a ns1:ModoOperacion ;
    rdfs:label "Theoretical travel simulation mode"@en ;
    ns1:textoExtracto "Theoretical travel. | Programmed tool path | No | No | No | Yes | Yes"@en ;
    ns1:tieneComponente ns1:TrayectoriaHerramienta_Programada .

ns1:OpcionReposicionEjes_PuntoBloqueInterrumpido a ns1:Parametro ;
    rdfs:label "Repositioning the axes at the interrupted block point"@en ;
    ns1:textoExtracto "Repositioning the axes at the point of the interrupted block."@en .

ns1:OpcionReposicionEjes_PuntoInterrupcion a ns1:Parametro ;
    rdfs:label "Repositioning the axes at the interruption point"@en ;
    ns1:textoExtracto "Repositioning the axes at the starting interruption point."@en .

ns1:SimulacionEjecucionPrograma a ns1:ModoOperacion ;
    rdfs:label "Simulated execution of a program"@en ;
    ns1:textoExtracto "With simulated execution, it is possible to simulate a program, interrupt it at a point and start execution from that point on. Depending on the type of simulation selected, it can involve movement of axes, spindle, etc."@en .

ns1:BotonStart a ns1:ComponenteElectrico ;
    rdfs:label "START key"@en ;
    ns1:textoExtracto "Press the [START] key to start the simulation. [...] Press the [START] key to start the execution."@en .

ns1:BotonStop a ns1:ComponenteElectrico ;
    rdfs:label "STOP key"@en ;
    ns1:textoExtracto "Press the [STOP] of the operator panel to interrupt the simulation."@en .

ns1:MenuSoftkeyHorizontal a ns1:ComponenteElectrico ;
    rdfs:label "Horizontal softkey menu"@en ;
    ns1:textoExtracto "On the horizontal softkey menu, select the desired type of simulation."@en .

ns1:MenuSoftkeyVertical a ns1:ComponenteElectrico ;
    rdfs:label "Vertical softkey menu"@en ;
    ns1:textoExtracto "The vertical softkey menu offers two options."@en .

ns1:TrayectoriaHerramienta_Programada a ns1:Parametro ;
    rdfs:label "Programmed tool path"@en ;
    ns1:textoExtracto "Programmed tool path"@en .

ns1:TrayectoriaHerramienta_CentroHerramienta a ns1:Parametro ;
    rdfs:label "Tool center path"@en ;
    ns1:textoExtracto "Tool center"@en .

