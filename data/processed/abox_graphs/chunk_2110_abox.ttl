@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlmacenHerramientas a ns1:ComponenteMecanico ;
    rdfs:label "Almacén de herramientas" ;
    ns1:textoExtracto "posición en el almacén de una herramienta que no está presente en el mismo" .

ns1:Fallo_1510 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje inexistente o no disponible en el canal" ;
    ns1:identificador "1510" ;
    ns1:textoExtracto "1510 'Eje inexistente o no disponible en el canal' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • El CNC ha intentado mover un eje que no existe o que no está disponible en el canal. • El CNC ha intentado ejecutar una sentencia que involucra a un eje que no existe o que no está disponible en el canal. • El CNC ha intentado leer o escribir una variable de un eje que no existe o que no está disponible en el canal." .

ns1:Fallo_1512 a ns1:DiagnosticoFallo ;
    rdfs:label "Posición del almacén libre o inexistente" ;
    ns1:identificador "1512" ;
    ns1:textoExtracto "1512 'Posición del almacén libre o inexistente' DETECCIÓN Durante la ejecución." .

ns1:Variable_V_TM_P a ns1:Parametro ;
    rdfs:label "Variable de posición de herramienta en almacén (V.TM.P)" ;
    ns1:monitoreaParametro ns1:Fallo_1511 ;
    ns1:textoExtracto "El CNC ha intentado leer mediante la variable V.TM.P la posición en el almacén de una herramienta que no está presente en el mismo." .

ns1:Solucion_1511 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación para herramientas en almacén" ;
    ns1:requiereMantenimiento ns1:Fallo_1511 ;
    ns1:textoExtracto "SOLUCIÓN Sólo es posible leer la posición de herramientas que existen en el almacén." .

ns1:Fallo_1511 a ns1:DiagnosticoFallo ;
    rdfs:label "Herramienta no disponible en el almacén" ;
    ns1:identificador "1511" ;
    ns1:solucionaFallo ns1:Solucion_1511 ;
    ns1:textoExtracto "1511 'La herramienta no está en el almacén' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado leer mediante la variable V.TM.P la posición en el almacén de una herramienta que no está presente en el mismo." .

