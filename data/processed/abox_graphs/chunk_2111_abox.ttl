@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1512 a ns1:Alarma ;
    rdfs:label "Posición del almacén libre o inexistente" ;
    ns1:identificador "1512" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_LeerHerramientaInvalida ;
    ns1:textoExtracto "'Posición del almacén libre o inexistente' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado leer mediante la variable V.TM.T el número de herramienta situada en una posición del almacén que no existe. SOLUCIÓN Sólo es posible leer la herramienta que está en una posición válida del almacén." .

ns1:Alarma_1513 a ns1:Alarma ;
    rdfs:label "Error en la escritura de la variable" ;
    ns1:identificador "1513" ;
    ns1:textoExtracto "'Error en la escritura de la variable' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • La variable no existe. • La" .

ns1:Variable_V.TM.T a ns1:Parametro ;
    rdfs:label "Variable V.TM.T" ;
    ns1:identificador "V.TM.T" ;
    ns1:monitoreaParametro ns1:Herramienta_Almacenada ;
    ns1:textoExtracto "la variable V.TM.T el número de herramienta situada en una posición del almacén" .

ns1:AccionProhibida_LeerHerramientaInvalida a ns1:AccionProhibida ;
    rdfs:label "Leer herramienta en posición inválida del almacén" ;
    ns1:textoExtracto "El CNC ha intentado leer mediante la variable V.TM.T el número de herramienta situada en una posición del almacén que no existe." .

ns1:Herramienta_Almacenada a ns1:Herramienta ;
    rdfs:label "Herramienta en almacén" ;
    ns1:textoExtracto "número de herramienta situada en una posición del almacén" .

