@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error1513 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1513: Error en la escritura de la variable" ;
    ns1:identificador "1513" ;
    ns1:textoExtracto "1513 'Error en la escritura de la variable' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • La variable no existe. • La variable es de eje pero el eje no existe. • La variable es de eje pero no existe para el tipo de eje (lineal o rotativo). • La variable es de eje pero no existe para el tipo de regulador del eje. • El operador compuesto (+= -= *= /=) no está permitido para esa variable. • El valor de la variable no es válido. SOLUCIÓN Revisar la programación." .

ns1:Error1514 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1514: No es posible ejecutar una cajera 2D-3D con G72 activo" ;
    ns1:identificador "1514" ;
    ns1:solucionaFallo ns1:EjecutarCajera2D3DConG72Activo ;
    ns1:textoExtracto "1514 'No es posible ejecutar una cajera 2D-3D con G72 activo' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar la cajera con un factor de escala activo. SOLUCIÓN Anular el factor de escala." .

ns1:Error1515 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1515: Uno o varios ejes de la configuración original no están disponibles" ;
    ns1:identificador "1515" ;
    ns1:textoExtracto "1515 'Uno o varios ejes de la configuración original no están disponibles' DETECCIÓN Durante la ejecución." .

ns1:Parametro_G72 a ns1:Parametro ;
    rdfs:label "Factor de escala G72" ;
    ns1:textoExtracto "El CNC ha intentado ejecutar la cajera con un factor de escala activo." ;
    ns1:valor "activo" .

ns1:EjecutarCajera2D3DConG72Activo a ns1:AccionProhibida ;
    rdfs:label "Ejecutar cajera 2D-3D con G72 activo" ;
    ns1:textoExtracto "No es posible ejecutar una cajera 2D-3D con G72 activo" .

