@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Funcion_G a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G"@es ;
    ns1:identificador "G" ;
    ns1:monitoreaParametro ns1:Alarma_1517 ;
    ns1:textoExtracto "sentencia o función G"@es .

ns1:Parametro_AXISEXCH a ns1:Parametro ;
    rdfs:label "Parámetro AXISEXCH"@es ;
    ns1:identificador "AXISEXCH" ;
    ns1:monitoreaParametro ns1:Alarma_1515 ;
    ns1:textoExtracto "permiso de cambio temporal (parámetro AXISEXCH)"@es .

ns1:Subrutina_G180_189 a ns1:Parametro ;
    rdfs:label "Subrutina G180-189"@es ;
    ns1:identificador "G180-189" ;
    ns1:monitoreaParametro ns1:Alarma_1516 ;
    ns1:textoExtracto "lista de parámetros de llamada a una subrutina con #PCALL o G180-189"@es .

ns1:Alarma_1515 a ns1:Alarma ;
    rdfs:label "Alarma 1515: Ejes no disponibles"@es ;
    ns1:identificador "1515" ;
    ns1:mitigaRiesgo ns1:Solucion_1515 ;
    ns1:textoExtracto "'Uno o varios ejes de la configuración original no están disponibles' DETECCIÓN Durante la ejecución. CAUSA Un canal ha cedido algún eje con permiso de cambio temporal (parámetro AXISEXCH) y no se puede recuperarlo con el reset o al comienzo de programa porque el canal que lo cogió aún no lo ha liberado."@es .

ns1:Alarma_1516 a ns1:Alarma ;
    rdfs:label "Alarma 1516: Valor esperado"@es ;
    ns1:identificador "1516" ;
    ns1:mitigaRiesgo ns1:Solucion_1516 ;
    ns1:textoExtracto "'Se esperaba valor' DETECCIÓN Durante la ejecución. CAUSA Se ha programado incorrectamente la lista de parámetros de llamada a una subrutina con #PCALL o G180-189."@es .

ns1:Alarma_1517 a ns1:Alarma ;
    rdfs:label "Alarma 1517: Valor cero no admitido"@es ;
    ns1:identificador "1517" ;
    ns1:mitigaRiesgo ns1:Solucion_1517 ;
    ns1:textoExtracto "No se admite valor cero. DETECCIÓN Durante la ejecución. CAUSA Se ha programado un valor nulo en una sentencia o función G."@es .

ns1:Solucion_1515 a ns1:TareaMantenimiento ;
    rdfs:label "Solución para alarma 1515"@es ;
    ns1:textoExtracto "El otro canal cederá el eje con reset o con el inicio de otro programa. También es posible programar explícitamente la liberación del eje con la sentencia #FREE AX."@es .

ns1:Solucion_1516 a ns1:TareaMantenimiento ;
    rdfs:label "Solución para alarma 1516"@es ;
    ns1:textoExtracto "Revisar la programación."@es .

ns1:Solucion_1517 a ns1:TareaMantenimiento ;
    rdfs:label "Solución para alarma 1517"@es ;
    ns1:textoExtracto "Revisar la programación."@es .

