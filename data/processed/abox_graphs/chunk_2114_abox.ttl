@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_ProgramacionValorNulo a ns1:AccionProhibida ;
    rdfs:label "Programación de valor nulo en sentencia o función G"@es ;
    ns1:mitigaRiesgo ns1:AvisoSeguridad_1518 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Se ha programado un valor nulo en una sentencia o función G. SOLUCIÓN Revisar la programación."@es .

ns1:AccionProhibida_RepeticionNRsinMovimiento a ns1:AccionProhibida ;
    rdfs:label "Repetición de bloques (NR) sin movimiento programado"@es ;
    ns1:mitigaRiesgo ns1:AvisoSeguridad_1518 ;
    ns1:textoExtracto "Hay programada una repetición de bloques (NR) en un bloque que no implica movimiento."@es .

ns1:AvisoSeguridad_1518 a ns1:AvisoSeguridad ;
    rdfs:label "NR exige programar movimiento en el bloque"@es ;
    ns1:identificador "1518" ;
    ns1:textoExtracto "1518 'NR exige programar movimiento en el bloque' DETECCIÓN Durante la ejecución. CAUSA Hay programada una repetición de bloques (NR) en un bloque que no implica movimiento. SOLUCIÓN La programación de la repetición de bloques con NR solo es válida con bloques que implican movimiento. La repetición de otro tipo de bloques deberá hacerse mediante las instrucciones de control de flujo que ofrece"@es .

