@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1523 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta programar T en el bloque"@es ;
    ns1:identificador "1523" ;
    ns1:textoExtracto "1523 Falta programar T en el bloque. DETECCIÓN Durante la ejecución."@es .

ns1:Fallo_1525 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación incorrecta de comandos POS/MZ sin herramienta"@es ;
    ns1:identificador "1525" ;
    ns1:solucionaFallo ns1:Herramienta_Programacion ;
    ns1:textoExtracto "1525 'No está permitido... CAUSA Se ha programado POS y/o MZ en un bloque sin programar la herramienta. SOLUCIÓN Los comandos POS y MZ se deben programar en el mismo bloque que la herramienta."@es .

ns1:Fallo_NR_Negativo a ns1:DiagnosticoFallo ;
    rdfs:label "Número negativo de repeticiones de bloque (NR)"@es ;
    ns1:textoExtracto "CAUSA Se ha programado un número negativo de repeticiones de bloque (NR). SOLUCIÓN Revisar la programación."@es .

ns1:Herramienta_Programacion a ns1:Herramienta ;
    rdfs:label "Herramienta de programación CNC"@es ;
    ns1:textoExtracto "Los comandos POS y MZ se deben programar en el mismo bloque que la herramienta."@es .

