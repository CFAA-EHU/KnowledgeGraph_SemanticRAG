@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1526 a ns1:Alarma ;
    rdfs:label "Alarma 1526: '#EXEC: el canal indicado no es de CNC'"@es ;
    ns1:identificador "1526" ;
    ns1:textoExtracto "1526 '#EXEC: el canal indicado no es de CNC' DETECCIÓN Durante la ejecución."@es .

ns1:DiagnosticoFallo_1525 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1525"@es ;
    ns1:solucionaFallo ns1:Alarma_1525 ;
    ns1:textoExtracto "CAUSA El CNC ha intentado cambiar un eje de canal (#CALL, #SET o #FREE) y el eje no tiene permiso de cambio (parámetro AXISEXCH). SOLUCIÓN Para que el CNC pueda cambiar los ejes y cabezales de canal, estos deben tener permiso."@es .

ns1:DiagnosticoFallo_ProgramacionHerramienta a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Programación incorrecta de POS/MZ sin herramienta"@es ;
    ns1:textoExtracto "CAUSA Se ha programado POS y/o MZ en un bloque sin programar la herramienta. SOLUCIÓN Los comandos POS y MZ se deben programar en el mismo bloque que la herramienta."@es .

ns1:Parametro_AXISEXCH a ns1:Parametro ;
    rdfs:label "Parámetro AXISEXCH"@es ;
    ns1:identificador "AXISEXCH" ;
    ns1:monitoreaParametro ns1:Componente_Cabezal,
        ns1:Componente_Eje ;
    ns1:textoExtracto "El parámetro AXISEXCH establece si el eje o cabezal tiene permiso para cambiar de canal, y en caso afirmativo, si el cambio es temporal o permanente; es decir, si el cambio se mantiene al reiniciar el programa pieza, tras un reset o tras reiniciar el CNC."@es .

ns1:Alarma_1525 a ns1:Alarma ;
    rdfs:label "Alarma 1525: 'No está permitido intercambiar el eje'"@es ;
    ns1:identificador "1525" ;
    ns1:textoExtracto "1525 'No está permitido intercambiar el eje' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado cambiar un eje de canal (#CALL, #SET o #FREE) y el eje no tiene permiso de cambio (parámetro AXISEXCH)."@es .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de canal"@es ;
    ns1:textoExtracto "El parámetro AXISEXCH establece si el eje o cabezal tiene permiso para cambiar de canal"@es .

ns1:Componente_Eje a ns1:ComponenteMecanico ;
    rdfs:label "Eje de canal"@es ;
    ns1:textoExtracto "El CNC ha intentado cambiar un eje de canal (#CALL, #SET o #FREE)"@es .

