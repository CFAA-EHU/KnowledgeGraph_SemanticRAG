@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BusquedaAutomaticaBloques a ns1:ModoOperacion ;
    rdfs:label "Automatic Block Search"@en ;
    ns1:habilitadoPor ns1:Funcion_BloqueBusqueda ;
    ns1:textoExtracto "The automatic block search may be used to recover the program history up to the block where the previous execution was canceled. The CNC remembers the block where interruption was canceled, thus not being necessary to set the stop block."@en .

ns1:BusquedaManualBloques a ns1:ModoOperacion ;
    rdfs:label "Manual Block Search"@en ;
    ns1:habilitadoPor ns1:Funcion_BloqueBusqueda ;
    ns1:textoExtracto "The manual block search may be used to recover the program history up to a particular block of the program or of the subroutine, set by the operator."@en .

ns1:Modo_ReposicionamientoAutomatico a ns1:ModoOperacion ;
    rdfs:label "Automatic Axis Repositioning"@en ;
    ns1:habilitadoPor ns1:Funcion_ReposicionamientoEjes ;
    ns1:textoExtracto "Automatic repositioning of axes. Select the axes with the relevant softkey and press [START]."@en .

ns1:Modo_ReposicionamientoManual a ns1:ModoOperacion ;
    rdfs:label "Manual Axis Repositioning"@en ;
    ns1:habilitadoPor ns1:Funcion_ReposicionamientoEjes ;
    ns1:textoExtracto "Manual repositioning of axes. Jog the axes with the handwheels or with the JOG keys. The movement is limited by the repositioning end point and the corresponding software limit."@en .

ns1:Parametro_Funciones_F a ns1:Parametro ;
    rdfs:label "F Function Parameter"@en ;
    ns1:identificador "F" ;
    ns1:textoExtracto "Depending on how the treatment of functions M, H, F, S is configured, it may be necessary to decide which ones are sent out to the PLC."@en .

ns1:Parametro_Funciones_H a ns1:Parametro ;
    rdfs:label "H Function Parameter"@en ;
    ns1:identificador "H" ;
    ns1:textoExtracto "Depending on how the treatment of functions M, H, F, S is configured, it may be necessary to decide which ones are sent out to the PLC."@en .

ns1:Parametro_Funciones_M a ns1:Parametro ;
    rdfs:label "M Function Parameter"@en ;
    ns1:identificador "M" ;
    ns1:textoExtracto "Depending on how the treatment of functions M, H, F, S is configured, it may be necessary to decide which ones are sent out to the PLC."@en .

ns1:Parametro_Funciones_S a ns1:Parametro ;
    rdfs:label "S Function Parameter"@en ;
    ns1:identificador "S" ;
    ns1:textoExtracto "Depending on how the treatment of functions M, H, F, S is configured, it may be necessary to decide which ones are sent out to the PLC."@en .

ns1:Tecla_CYCLE_START a ns1:ComponenteElectrico ;
    rdfs:label "[CYCLE START] key"@en ;
    ns1:textoExtracto "Press the [CYCLE START] key to start the block search."@en ;
    ns1:tieneComponente ns1:InterfazUsuario_CNC .

ns1:Tecla_START a ns1:ComponenteElectrico ;
    rdfs:label "[START] key"@en ;
    ns1:textoExtracto "Press [START] to execute the program."@en ;
    ns1:tieneComponente ns1:InterfazUsuario_CNC .

ns1:Tecla_STOP a ns1:ComponenteElectrico ;
    rdfs:label "[STOP] key"@en ;
    ns1:textoExtracto "Repositioning may be interrupted (using the [STOP] key) to select other axes."@en ;
    ns1:tieneComponente ns1:InterfazUsuario_CNC .

ns1:Funcion_ReposicionamientoEjes a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Axis Repositioning"@en ;
    ns1:habilitadoPor ns1:Funcion_BloqueBusqueda ;
    ns1:textoExtracto "Once the block search is finished, the CNC will show the axes that are out of position. The axes may be repositioned individually or several at the same time in one of the following ways: Manual repositioning of axes. Jog the axes with the handwheels or with the JOG keys. [...] Automatic repositioning of axes."@en .

ns1:Funcion_BloqueBusqueda a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Block Search"@en ;
    ns1:ilustradoEn ns1:InterfazUsuario_CNC ;
    ns1:textoExtracto "With block search, it is possible to recover the program history up to a particular block in such way that if program execution is resumed at that block, it will do so with the same conditions as if it were executed from the beginning."@en .

ns1:InterfazUsuario_CNC a ns1:InterfazUsuario ;
    rdfs:label "CNC Interface"@en ;
    ns1:textoExtracto "Selecting the type of search: automatic or manual. [...] Press the [CYCLE START] key to start the block search. [...] Press [START] to execute the program."@en .

