@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error1531 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1531: Programar #EXBLK"@es ;
    ns1:identificador "1531" ;
    ns1:textoExtracto "1531 'Programar: #EXBLK [bloque, canal]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque."@es .

ns1:Error1532 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1532: Programar #MASTER"@es ;
    ns1:identificador "1532" ;
    ns1:textoExtracto "1532 'Programar: #MASTER <nombre de cabezal>' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque."@es .

ns1:Error1533 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1533: Programar #FREESP"@es ;
    ns1:identificador "1533" ;
    ns1:textoExtracto "1533 'Programar: #FREESP [sp1, sp2, ..]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque."@es .

ns1:Error1534 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1534: Programar #CALLSP"@es ;
    ns1:identificador "1534" ;
    ns1:textoExtracto "1534 'Programar: #CALLSP [sp1, sp2, ..]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque."@es .

ns1:Error1535 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1535: Programar #SETSP"@es ;
    ns1:identificador "1535" ;
    ns1:textoExtracto "1535 'Programar: #SETSP [sp1, sp2, ..]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Las sentencias se deben programar solas en el bloque, sólo se puede añadir la etiqueta del bloque."@es .

ns1:ParametroAXISEXCH a ns1:Parametro ;
    rdfs:label "Parámetro AXISEXCH"@es ;
    ns1:identificador "AXISEXCH" ;
    ns1:monitoreaParametro ns1:Error1538 ;
    ns1:textoExtracto "permiso de cambio temporal (parámetro AXISEXCH)"@es .

ns1:Error1538 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1538: Recuperación de cabezal"@es ;
    ns1:identificador "1538" ;
    ns1:textoExtracto "1538 'No se puede recuperar algún cabezal del canal' DETECCIÓN Durante la ejecución. CAUSA Un canal ha cedido algún cabezal con permiso de cambio temporal (parámetro AXISEXCH) y no se puede recuperarlo con el reset o al comienzo de programa porque el canal que lo cogió aún no lo ha liberado."@es .

