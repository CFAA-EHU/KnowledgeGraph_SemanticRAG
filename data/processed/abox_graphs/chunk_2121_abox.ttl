@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:AccionProhibidaLiberacionCabezal a ns1:AccionProhibida ;
    ns1:textoExtracto "no se puede recuperarlo con el reset o al comienzo de programa porque el canal que lo cogió aún no lo ha liberado" .

ns1:Cabezal a ns1:Componente ;
    ns1:textoExtracto "Un canal ha cedido algún cabezal" .

ns1:Canal a ns1:Componente ;
    ns1:textoExtracto "Un canal ha cedido algún cabezal" .

ns1:ParametroAXISEXCH a ns1:Parametro ;
    ns1:identificador "AXISEXCH" ;
    ns1:textoExtracto "Un canal ha cedido algún cabezal con permiso de cambio temporal (parámetro AXISEXCH)" .

ns1:SentenciaFREE_SP a ns1:Figura ;
    ns1:identificador "#FREE SP" ;
    ns1:textoExtracto "También es posible programar explícitamente la liberación del cabezal con la sentencia #FREE SP. 1539" .

ns1:TareaMantenimientoLiberacionCabezal a ns1:TareaMantenimiento ;
    ns1:textoExtracto "El otro canal cederá el cabezal con reset o con el inicio de otro programa" .

