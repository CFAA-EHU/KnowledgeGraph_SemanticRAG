@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteMecanico_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "el eje o cabezal tiene permiso para cambiar de canal" .

ns1:DiagnosticoFallo_Incompatibilidad_G63_M a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad entre G63 y funciones M (M3/M4/M5/M19/M41-M44)" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_1544 ;
    ns1:textoExtracto "No se permite ninguna función M asociada al cabezal en el mismo bloque en el que se programa un roscado rígido G63." .

ns1:Parametro_AXISEXCH a ns1:Parametro ;
    rdfs:label "AXISEXCH" ;
    ns1:identificador "AXISEXCH" ;
    ns1:textoExtracto "El parámetro AXISEXCH establece si el eje o cabezal tiene permiso para cambiar de canal, y en caso afirmativo, si el cambio es temporal o permanente; es decir, si el cambio se mantiene al reiniciar el programa pieza, tras un reset o tras reiniciar el CNC." .

ns1:AvisoSeguridad_1544 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1544: Incompatibilidad G63 y funciones M" ;
    ns1:identificador "1544" ;
    ns1:textoExtracto "'No se admite G63 y M3/M4/M5/M19/M41-M44 en el mismo bloque' DETECCIÓN Durante la ejecución. CAUSA No se permite ninguna función M asociada al cabezal en el mismo bloque en el que se programa un roscado rígido G63. SOLUCIÓN Se puede hacer en el bloque anterior o posterior según el resultado que se quiera" .

