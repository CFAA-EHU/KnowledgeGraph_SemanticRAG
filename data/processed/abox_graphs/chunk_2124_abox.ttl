@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal"@es ;
    ns1:textoExtracto "el cabezal está trabajando como eje C"@es .

ns1:Fallo_1545 a ns1:DiagnosticoFallo ;
    rdfs:label "Cambio de gama de cabezal con G63 o #CAX activos"@es ;
    ns1:identificador "1545" ;
    ns1:textoExtracto "No se admite cambio de gama de cabezal con G63 o #CAX activos. DETECCIÓN: Durante la ejecución. CAUSA: El CNC no puede cambiar la gama del cabezal si está activo el roscado G63 o el cabezal está trabajando como eje C. SOLUCIÓN: Para cambiar la gama del cabezal, desactivar el roscado y el eje C."@es .

ns1:Fallo_1546 a ns1:DiagnosticoFallo ;
    rdfs:label "G63 sin gama previa en el cabezal"@es ;
    ns1:identificador "1546" ;
    ns1:textoExtracto "No se admite G63 sin gama previa en el cabezal. DETECCIÓN: Durante la ejecución. CAUSA: Esta situación sólo es posible si tras el arranque del sistema o un reset, el PLC no indica ninguna gama con GEAR1 a GEAR4 para el cabezal. SOLUCIÓN: Antes de iniciar un roscado G63 el cabezal debe tener una gama activada."@es .

ns1:Fallo_1547 a ns1:DiagnosticoFallo ;
    rdfs:label "#CAX con G63 activa"@es ;
    ns1:identificador "1547" ;
    ns1:textoExtracto "No se admite #CAX con G63 activa. DETECCIÓN: Durante la ejecución. CAUSA: No se puede activar un cabezal como eje C si éste mismo está siendo usado por la función G63. SOLUCIÓN: Desactivar G63 antes desactivar el eje C o utilizar otro cabezal del canal para eje C."@es .

ns1:Fallo_1548 a ns1:DiagnosticoFallo ;
    rdfs:label "Cambio de cabezal master con G33/G63/G95/G96 activas"@es ;
    ns1:identificador "1548" ;
    ns1:textoExtracto "No se admite cambiar el cabezal master con G33/G63/G95/G96 activas. DETECCIÓN: Durante la ejecución."@es .

ns1:ModoOperacion_CAX a ns1:ModoOperacion ;
    rdfs:label "Eje C (#CAX)"@es ;
    ns1:identificador "#CAX" ;
    ns1:textoExtracto "activar un cabezal como eje C"@es .

ns1:ModoOperacion_G63 a ns1:ModoOperacion ;
    rdfs:label "Roscado rígido (G63)"@es ;
    ns1:identificador "G63" ;
    ns1:textoExtracto "función M asociada al cabezal en el mismo bloque en el que se programa un roscado rígido G63"@es .

ns1:Parametro_AUTOGEAR a ns1:Parametro ;
    rdfs:label "Cambio de gama automático del cabezal"@es ;
    ns1:identificador "AUTOGEAR" ;
    ns1:textoExtracto "Si el cabezal tiene cambio de gama automático (parámetro AUTOGEAR), el CNC genera la gama al programar una velocidad."@es .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:textoExtracto "tras el arranque del sistema o un reset, el PLC no indica ninguna gama con GEAR1 a GEAR4 para el cabezal"@es .

