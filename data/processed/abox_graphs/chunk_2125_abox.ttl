@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1548 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite cambiar el cabezal master con G33/G63/G95/G96 activas"@es ;
    ns1:identificador "1548" ;
    ns1:textoExtracto "SOLUCIÓN Desactivar G63 antes desactivar el eje C o utilizar otro cabezal del canal para eje C. 1548 'No se admite cambiar el cabezal master con G33/G63/G95/G96 activas' DETECCIÓN Durante la ejecución. CAUSA Las funciones G63 y G96 utilizan el cabezal master del canal. El canal no puede eliminar este cabezal mientras las funciones estén activas. SOLUCIÓN Desactivar G63 o G96 antes ceder el cabezal."@es .

ns1:DiagnosticoFallo_1549 a ns1:DiagnosticoFallo ;
    rdfs:label "Nombre de cajera nulo o incorrecto"@es ;
    ns1:identificador "1549" ;
    ns1:textoExtracto "1549 'Nombre de cajera nulo o incorrecto' DETECCIÓN Durante la ejecución. CAUSA Cuando"@es .

ns1:ModoOperacion_G63 a ns1:ModoOperacion ;
    rdfs:label "Modo de operación G63"@es ;
    ns1:controla ns1:ComponenteMecanico_CabezalMaster ;
    ns1:identificador "G63" ;
    ns1:textoExtracto "Las funciones G63 y G96 utilizan el cabezal master del canal."@es .

ns1:ModoOperacion_G96 a ns1:ModoOperacion ;
    rdfs:label "Modo de operación G96"@es ;
    ns1:controla ns1:ComponenteMecanico_CabezalMaster ;
    ns1:identificador "G96" ;
    ns1:textoExtracto "Las funciones G63 y G96 utilizan el cabezal master del canal."@es .

ns1:ComponenteMecanico_CabezalMaster a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal master del canal"@es ;
    ns1:textoExtracto "Las funciones G63 y G96 utilizan el cabezal master del canal."@es .

