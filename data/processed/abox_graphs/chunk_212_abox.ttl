@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_InterruptRepositioning a ns1:AccionProhibida ;
    rdfs:label "Interrupt Repositioning Without Justification" ;
    ns1:mitigaRiesgo ns1:TareaMantenimiento_ToolInspection ;
    ns1:textoExtracto "Repositioning may be interrupted (using the [STOP] key)" .

ns1:ModoOperacion_MDI a ns1:ModoOperacion ;
    rdfs:label "MDI/MDA Mode" ;
    ns1:habilitadoPor ns1:InterfazUsuario_BlockSearch ;
    ns1:textoExtracto "execute blocks in MDI/MDA mode" .

ns1:Parametro_Feedrate a ns1:Parametro ;
    rdfs:label "Feedrate" ;
    ns1:monitoreaParametro ns1:InterfazUsuario_BlockSearch ;
    ns1:textoExtracto "change the feedrate" .

ns1:Parametro_SpindleSpeed a ns1:Parametro ;
    rdfs:label "Spindle Speed" ;
    ns1:monitoreaParametro ns1:InterfazUsuario_BlockSearch ;
    ns1:textoExtracto "change the spindle speed" .

ns1:TareaMantenimiento_ToolInspection a ns1:TareaMantenimiento ;
    rdfs:label "Tool Inspection" ;
    ns1:ejecutadoPor ns1:Personal ;
    ns1:requiereMantenimiento ns1:InterfazUsuario_BlockSearch ;
    ns1:textoExtracto "tool inspection may be accessed to change the machining conditions" .

ns1:InterfazUsuario_BlockSearch a ns1:InterfazUsuario ;
    rdfs:label "Block Search Interface" ;
    ns1:textoExtracto "Select the axes with the relevant softkey and press [START]. Repositioning may be interrupted (using the [STOP] key) to select other axes." .

