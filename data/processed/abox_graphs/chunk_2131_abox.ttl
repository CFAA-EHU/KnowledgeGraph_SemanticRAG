@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1567 a ns1:DiagnosticoFallo ;
    rdfs:label "El radio polar sólo se puede programar con R"@es ;
    ns1:identificador "1567" ;
    ns1:textoExtracto "1567 'El radio polar sólo se puede programar con R' [...] DETECCIÓN Durante la ejecución."@es .

ns1:Parametro_CAXIS a ns1:Parametro ;
    rdfs:label "Parámetro CAXIS (permiso de cabezal como eje C)"@es ;
    ns1:identificador "CAXIS" ;
    ns1:monitoreaParametro ns1:DiagnosticoFallo_1565 ;
    ns1:textoExtracto "parámetro CAXIS"@es .

ns1:Parametro_UNIDIR a ns1:Parametro ;
    rdfs:label "Parámetro UNIDIR (eje rotativo unidireccional)"@es ;
    ns1:identificador "UNIDIR" ;
    ns1:monitoreaParametro ns1:DiagnosticoFallo_1566 ;
    ns1:textoExtracto "parámetro UNIDIR"@es .

ns1:DiagnosticoFallo_1565 a ns1:DiagnosticoFallo ;
    rdfs:label "El cabezal no puede funcionar como eje C, CAXIS = No"@es ;
    ns1:identificador "1565" ;
    ns1:solucionaFallo ns1:ProgramacionIncorrectaDeCabezalComoEjeC ;
    ns1:textoExtracto "1565 'El cabezal no puede funcionar como eje C, CAXIS = No' [...] CAUSA En la instrucción #CAX hay programado un cabezal que no tiene permiso para trabajar como eje C (parámetro CAXIS)."@es .

ns1:DiagnosticoFallo_1566 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite imagen espejo con ejes UNIDIR"@es ;
    ns1:identificador "1566" ;
    ns1:solucionaFallo ns1:ProgramacionDeImagenEspejoEnEjeUNIDIR ;
    ns1:textoExtracto "1566 'No se admite imagen espejo con ejes UNIDIR' [...] CAUSA No se puede programar imagen espejo sobre un eje rotativo unidireccional (parámetro UNIDIR), ya que este tipo de ejes no puede girar en sentido contrario al que tienen definido."@es .

ns1:ProgramacionDeImagenEspejoEnEjeUNIDIR a ns1:AccionProhibida ;
    rdfs:label "Programación de imagen espejo en eje UNIDIR"@es ;
    ns1:textoExtracto "Cambiar el tipo de eje o no programar la imagen espejo."@es .

ns1:ProgramacionIncorrectaDeCabezalComoEjeC a ns1:AccionProhibida ;
    rdfs:label "Programación incorrecta de cabezal como eje C"@es ;
    ns1:textoExtracto "Revisar la programación."@es .

