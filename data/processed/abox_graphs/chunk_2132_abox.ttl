@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_Almacen_MZ a ns1:Parametro ;
    rdfs:label "Número de almacén (comando MZ)"@es ;
    ns1:identificador "MZ" ;
    ns1:textoExtracto "El número de almacén programado en el comando MZ [...] debe ser un valor entre 1 y 4."@es ;
    ns1:valor "1-4" .

ns1:Parametro_R a ns1:Parametro ;
    rdfs:label "Parámetro R (radio polar)"@es ;
    ns1:identificador "R" ;
    ns1:textoExtracto "Programar el radio polar con el parámetro R."@es .

ns1:Parametro_R1 a ns1:Parametro ;
    rdfs:label "Parámetro R1"@es ;
    ns1:identificador "R1" ;
    ns1:textoExtracto "El radio de un movimiento en coordenadas polares está programado con el parámetro R1."@es .

ns1:AccionProhibida_AlmacenInvalido_MZ a ns1:AccionProhibida ;
    rdfs:label "Programar número de almacén fuera de rango (1-4) en comando MZ"@es ;
    ns1:activaAlarma ns1:Alarma_1568 ;
    ns1:textoExtracto "El número de almacén programado en el comando MZ no es válido. [...] debe ser un valor entre 1 y 4."@es .

ns1:AccionProhibida_EjecucionEnCanalPLC a ns1:AccionProhibida ;
    rdfs:label "Ejecución en canal exclusivo de PLC"@es ;
    ns1:activaAlarma ns1:Alarma_1569 ;
    ns1:textoExtracto "Ejecución no permitida, el canal es exclusivo de PLC."@es .

ns1:AccionProhibida_ProgramarRadioPolarConR1_G263 a ns1:AccionProhibida ;
    rdfs:label "Programar radio polar con parámetro R1 o función G263"@es ;
    ns1:activaAlarma ns1:Alarma_1567 ;
    ns1:textoExtracto "El radio de un movimiento en coordenadas polares está programado con el parámetro R1 o con la función G263."@es .

ns1:Alarma_1567 a ns1:Alarma ;
    rdfs:label "Alarma 1567: Radio polar programado con R1 o G263"@es ;
    ns1:identificador "1567" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_ProgramarRadioPolarConR1_G263 ;
    ns1:textoExtracto "El radio polar sólo se puede programar con R. DETECCIÓN Durante la ejecución. CAUSA El radio de un movimiento en coordenadas polares está programado con el parámetro R1 o con la función G263. SOLUCIÓN Programar el radio polar con el parámetro R."@es .

ns1:Alarma_1568 a ns1:Alarma ;
    rdfs:label "Alarma 1568: Número de almacén incorrecto en comando MZ"@es ;
    ns1:identificador "1568" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_AlmacenInvalido_MZ ;
    ns1:textoExtracto "Número de almacén incorrecto. DETECCIÓN Durante la ejecución. CAUSA El número de almacén programado en el comando MZ no es válido. SOLUCIÓN El número de almacén debe ser un valor entre 1 y 4."@es .

ns1:Alarma_1569 a ns1:Alarma ;
    rdfs:label "Alarma 1569: Ejecución no permitida en canal exclusivo de PLC"@es ;
    ns1:identificador "1569" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_EjecucionEnCanalPLC ;
    ns1:textoExtracto "Ejecución no permitida, el canal es exclusivo de PLC. DETECCIÓN Durante la ejecución."@es .

