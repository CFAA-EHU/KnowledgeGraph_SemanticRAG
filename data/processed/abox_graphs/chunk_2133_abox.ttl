@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1571 a ns1:Alarma ;
    rdfs:label "Alarma 1571: No se admite el carácter '%' dentro de subrutina global" ;
    ns1:identificador "1571" ;
    ns1:textoExtracto "1571 'No se admite el carácter \"%\" dentro de subrutina global' DETECCIÓN Durante la ejecución." .

ns1:AvisoSeguridad_AlmacenMZ a ns1:AvisoSeguridad ;
    rdfs:label "Aviso: Número de almacén en comando MZ" ;
    ns1:mitigaRiesgo ns1:Alarma_1569 ;
    ns1:textoExtracto "El número de almacén programado en el comando MZ no es válido. SOLUCIÓN El número de almacén debe ser un valor entre 1 y 4." .

ns1:Funcion_G74 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G74 (búsqueda de cero)" ;
    ns1:identificador "G74" ;
    ns1:monitoreaParametro ns1:Alarma_1570 ;
    ns1:textoExtracto "En el mismo bloque hay programada [...] la función G74 de búsqueda de cero." .

ns1:Funcion_M_MovimientoCabezal a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función M (movimiento de cabezal)" ;
    ns1:identificador "M" ;
    ns1:monitoreaParametro ns1:Alarma_1570 ;
    ns1:textoExtracto "En el mismo bloque hay programada una función M de movimiento de cabezal [...]." .

ns1:ModoOperacion_Automatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático (ejecución de subrutinas globales)" ;
    ns1:textoExtracto "No se admite el carácter \"%\" dentro de subrutina global." .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo manual (ejecución de programas, MDI, jog)" ;
    ns1:textoExtracto "el CNC no tiene permiso para ejecutar en él programas, bloques de MDI, movimientos de jog o cualquier otra acción desde el modo manual." .

ns1:Parametro_CHTYPE a ns1:Parametro ;
    rdfs:label "Parámetro CHTYPE (configuración de canal CNC/PLC)" ;
    ns1:identificador "CHTYPE" ;
    ns1:monitoreaParametro ns1:Alarma_1569 ;
    ns1:textoExtracto "Si se desea ejecutar dichas acciones en ese canal habrá que configurarlo como canal de CNC o de CNC+PLC (parámetro CHTYPE)." .

ns1:Alarma_1569 a ns1:Alarma ;
    rdfs:label "Alarma 1569: Ejecución no permitida, el canal es exclusivo de PLC" ;
    ns1:identificador "1569" ;
    ns1:textoExtracto "1569 'Ejecución no permitida, el canal es exclusivo de PLC' DETECCIÓN Durante la ejecución. CAUSA Cuando el canal es sólo de PLC, el CNC no tiene permiso para ejecutar en él programas, bloques de MDI, movimientos de jog o cualquier otra acción desde el modo manual. SOLUCIÓN Si se desea ejecutar dichas acciones en ese canal habrá que configurarlo como canal de CNC o de CNC+PLC (parámetro CHTYPE)." .

ns1:Alarma_1570 a ns1:Alarma ;
    rdfs:label "Alarma 1570: No se permite G74 y movimiento del cabezal simultáneos" ;
    ns1:identificador "1570" ;
    ns1:textoExtracto "1570 'No se permite G74 y movimiento del cabezal simultáneos' DETECCIÓN Durante la ejecución. CAUSA En el mismo bloque hay programada una función M de movimiento de cabezal y la función G74 de búsqueda de cero. SOLUCIÓN Revisar la programación." .

