@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1575 a ns1:Alarma ;
    rdfs:label "Sentencia sólo válida en programas con extensión FBS"@es ;
    ns1:identificador "1575" ;
    ns1:textoExtracto "1575 'Sentencia sólo válida en programas con extensión FBS' DETECCIÓN Durante la ejecución."@es .

ns1:InterfazOsciloscopio a ns1:InterfazUsuario ;
    rdfs:label "pantalla del osciloscopio"@es ;
    ns1:activaAlarma ns1:Alarma_1574 ;
    ns1:textoExtracto "pantalla del osciloscopio"@es .

ns1:Alarma_1574 a ns1:Alarma ;
    rdfs:label "Parámetro no modificable desde el oscilo"@es ;
    ns1:identificador "1574" ;
    ns1:monitoreaParametro ns1:ParametroMaquina_1574 ;
    ns1:textoExtracto "1574 'Parámetro no modificable desde el oscilo' DETECCIÓN Durante la ejecución. CAUSA El usuario ha intentado modificar desde la pantalla del osciloscopio un parámetro máquina que no tiene permiso de escritura. SOLUCIÓN Ese parámetro sólo se puede modificar desde la tabla de parámetros máquina."@es .

ns1:ParametroMaquina_1574 a ns1:Parametro ;
    ns1:documentadoEn ns1:TablaParametrosMaquina ;
    ns1:textoExtracto "parámetro máquina que no tiene permiso de escritura"@es .

ns1:TablaParametrosMaquina a ns1:Tabla ;
    rdfs:label "Tabla de parámetros máquina"@es ;
    ns1:textoExtracto "Ese parámetro sólo se puede modificar desde la tabla de parámetros máquina."@es .

