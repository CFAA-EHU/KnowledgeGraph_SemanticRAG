@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_1580 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1580: Programación previa de M19 en Sercos de posición" ;
    ns1:identificador "1580" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_1580_ActivarCabezalSinM19 ;
    ns1:textoExtracto "'#CAX: Necesita programación previa de M19 en Sercos de posición' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado hacer activar un cabezal Sercos como eje C sin posicionarlo previamente con M19. SOLUCIÓN Programar M19 antes de activar el cabezal como eje C." .

ns1:AvisoSeguridad_1581 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1581: Eliminación de eje C activo" ;
    ns1:identificador "1581" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_1581_EliminarEjeCActivo ;
    ns1:textoExtracto "'No está permitido eliminar un eje C activo' DETECCIÓN Durante la ejecución. CAUSA Las sentencias #SET AX y #FREE AX no pueden eliminar el eje C de la configuración si está activo. SOLUCIÓN Desactivar el eje C antes de eliminarlo de la configuración." .

ns1:AvisoSeguridad_1582 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1582: Doble programación del número de repeticiones" ;
    ns1:identificador "1582" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_1582_DobleProgramacionNR ;
    ns1:textoExtracto "'NR: doble programación del número de repeticiones' DETECCIÓN" .

ns1:Componente_1580_CabezalSercos a ns1:Componente ;
    rdfs:label "Cabezal Sercos" ;
    ns1:textoExtracto "cabezal Sercos como eje C" .

ns1:Componente_1581_EjeC a ns1:Componente ;
    rdfs:label "Eje C" ;
    ns1:textoExtracto "eje C" .

ns1:Parametro_1582_NR a ns1:Parametro ;
    rdfs:label "Número de repeticiones (NR)" ;
    ns1:identificador "NR" ;
    ns1:textoExtracto "número de repeticiones" .

ns1:AccionProhibida_1580_ActivarCabezalSinM19 a ns1:AccionProhibida ;
    rdfs:label "Activar cabezal Sercos como eje C sin posicionarlo previamente con M19" ;
    ns1:textoExtracto "El CNC ha intentado hacer activar un cabezal Sercos como eje C sin posicionarlo previamente con M19." .

ns1:AccionProhibida_1581_EliminarEjeCActivo a ns1:AccionProhibida ;
    rdfs:label "Eliminar eje C activo mediante #SET AX o #FREE AX" ;
    ns1:textoExtracto "Las sentencias #SET AX y #FREE AX no pueden eliminar el eje C de la configuración si está activo." .

ns1:AccionProhibida_1582_DobleProgramacionNR a ns1:AccionProhibida ;
    rdfs:label "Doble programación del número de repeticiones (NR)" ;
    ns1:textoExtracto "doble programación del número de repeticiones" .

