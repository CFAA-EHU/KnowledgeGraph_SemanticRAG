@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:DETECCION_1582 a ns1:Alarma ;
    ns1:activaAlarma ns1:SOLUCION_1582 ;
    ns1:identificador "1582" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La instrucción NR está programada más de una vez en el mismo bloque. SOLUCIÓN Revisar la programación."@es .

ns1:DETECCION_1583 a ns1:Alarma ;
    ns1:activaAlarma ns1:SOLUCION_1583 ;
    ns1:identificador "1583" ;
    ns1:textoExtracto "'#FOLLOW ON: el eje maestro y esclavo no pueden ser iguales' DETECCIÓN Durante la ejecución. CAUSA Los ejes maestro y el esclavo son el mismo. SOLUCIÓN Revisar la programación."@es .

ns1:DETECCION_1584 a ns1:Alarma ;
    ns1:activaAlarma ns1:SOLUCION_1584 ;
    ns1:identificador "1584" ;
    ns1:textoExtracto "'#FOLLOW ON: el numerador y denominador deben ser números enteros' DETECCIÓN Durante la ejecución. CAUSA El numerador y/o denominador están programados con decimales. SOLUCIÓN Programar números enteros en los parámetros que definen el numerador y denominador de la relación de transmisión."@es .

ns1:SOLUCION_1582 a ns1:AvisoSeguridad ;
    ns1:identificador "1582" ;
    ns1:textoExtracto "pueden eliminar el eje C de la configuración si está activo. SOLUCIÓN Desactivar el eje C antes de eliminarlo de la configuración."@es .

ns1:SOLUCION_1583 a ns1:AvisoSeguridad ;
    ns1:identificador "1583" ;
    ns1:textoExtracto "'#FOLLOW ON: el eje maestro y esclavo no pueden ser iguales' DETECCIÓN Durante la ejecución. CAUSA Los ejes maestro y el esclavo son el mismo. SOLUCIÓN Revisar la programación."@es .

ns1:SOLUCION_1584 a ns1:AvisoSeguridad ;
    ns1:identificador "1584" ;
    ns1:textoExtracto "'#FOLLOW ON: el numerador y denominador deben ser números enteros' DETECCIÓN Durante la ejecución. CAUSA El numerador y/o denominador están programados con decimales. SOLUCIÓN Programar números enteros en los parámetros que definen el numerador y denominador de la relación de transmisión."@es .

