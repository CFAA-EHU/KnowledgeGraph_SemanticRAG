@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FuncionG00_20 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "G00 (Rapid Positioning)"@en ;
    ns1:identificador "G00"@en ;
    ns1:monitoreaParametro ns1:ModoMDI_MDA_20 ;
    ns1:textoExtracto "type of interpolation (G00, G01, G02, G03, G33 or G63)"@en .

ns1:FuncionG01_20 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "G01 (Linear Interpolation)"@en ;
    ns1:identificador "G01"@en ;
    ns1:monitoreaParametro ns1:ModoMDI_MDA_20 ;
    ns1:textoExtracto "type of interpolation (G00, G01, G02, G03, G33 or G63)"@en .

ns1:FuncionG90_20 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "G90 (Absolute Programming)"@en ;
    ns1:identificador "G90"@en ;
    ns1:monitoreaParametro ns1:ModoMDI_MDA_20 ;
    ns1:textoExtracto "G90/G91 function"@en .

ns1:FuncionG91_20 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "G91 (Incremental Programming)"@en ;
    ns1:identificador "G91"@en ;
    ns1:monitoreaParametro ns1:ModoMDI_MDA_20 ;
    ns1:textoExtracto "G90/G91 function"@en .

ns1:InterfazUsuarioCNC_20 a ns1:InterfazUsuario ;
    rdfs:label "CNC Vertical Softkey Menu"@en ;
    ns1:habilitadoPor ns1:ModoInspeccionHerramienta ;
    ns1:textoExtracto "Tool inspection may be accessed from the vertical softkey menu only when the execution of the program has been interrupted ([STOP] key)."@en .

ns1:PanelOperador_20 a ns1:InterfazUsuario ;
    rdfs:label "Operator Panel"@en ;
    ns1:textoExtracto "act upon the master spindle of the channel from the operator panel"@en .

ns1:TablaReposicionamiento_20 a ns1:Tabla ;
    rdfs:label "Axis Repositioning Options After Tool Inspection"@en ;
    ns1:documentadoEn ns1:ModoInspeccionHerramienta ;
    ns1:textoExtracto "| Repositioning the axes at the interruption point. | --- | Repositioning the axes at the starting point of the interrupted block. |"@en .

ns1:TecladoJog_20 a ns1:InterfazUsuario ;
    rdfs:label "Jog Keyboard"@en ;
    ns1:textoExtracto "After activating tool inspection, it is possible to jog the axes using the jog keyboard"@en .

ns1:ModoInspeccionHerramienta a ns1:ModoOperacion ;
    rdfs:label "Tool Inspection Mode"@en ;
    ns1:identificador "Tool Inspection"@en ;
    ns1:textoExtracto "Begin tool inspection. Tool inspection may be accessed from the vertical softkey menu only when the execution of the program has been interrupted ([STOP] key)."@en .

ns1:ModoMDI_MDA_20 a ns1:ModoOperacion ;
    rdfs:label "MDI/MDA Mode"@en ;
    ns1:requiereMantenimiento ns1:ModoInspeccionHerramienta ;
    ns1:textoExtracto "execute blocks from the MDI/MDA mode. Execute blocks in MDI/MDA mode. Any program block may be executed in MDI/MDA mode."@en .

