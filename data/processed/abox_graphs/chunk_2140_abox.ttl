@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_1585 a ns1:AccionProhibida ;
    rdfs:label "Prohibición: ejes de intercambio temporal en transformación activa" ;
    ns1:textoExtracto "Los ejes de la transformación activa no pueden ser ejes de intercambio temporal" .

ns1:AccionProhibida_1586 a ns1:AccionProhibida ;
    rdfs:label "Prohibición: ejes de intercambio temporal en transformada mantenida" ;
    ns1:textoExtracto "Los ejes de la transformada no pueden ser ejes de intercambio temporal, ya que la transformada definida se mantiene una vez activada." .

ns1:Parametro_1585 a ns1:Parametro ;
    rdfs:label "Parámetro de relación de transmisión" ;
    ns1:textoExtracto "Programar números enteros en los parámetros que definen el numerador y denominador de la relación de transmisión." .

ns1:Parametro_1586 a ns1:Parametro ;
    rdfs:label "Número de almacén (MZ)" ;
    ns1:textoExtracto "Falta programar el número de almacén (MZ)" .

ns1:Sistema_1585 a ns1:Sistema ;
    rdfs:label "Sistema de transformadas #FACE y #CYL" ;
    ns1:textoExtracto "En las transformadas #FACE y #CYL se pueden utilizar ejes de intercambio temporal, porque estas transformadas se anulan con M30 y tras un reset." .

ns1:TareaMantenimiento_1585 a ns1:TareaMantenimiento ;
    rdfs:label "Ajuste de ejes para transformación" ;
    ns1:textoExtracto "Si es posible, definir los ejes como de intercambio mantenido; si no, utilizar otros ejes para la transformada." .

ns1:TareaMantenimiento_1586 a ns1:TareaMantenimiento ;
    rdfs:label "Configuración de ejes de intercambio temporal" ;
    ns1:textoExtracto "Los ejes de intercambio temporal sólo se pueden utilizar en su canal, y cuando los ejes están en sus posiciones originales dentro del canal." .

