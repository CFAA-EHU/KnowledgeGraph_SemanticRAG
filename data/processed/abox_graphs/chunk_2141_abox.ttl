@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1586 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta programar el número de almacén (MZ)"@es ;
    ns1:identificador "1586" ;
    ns1:solucionaFallo ns1:SistemaMultialmacen ;
    ns1:textoExtracto "1586 'Falta programar el número de almacén (MZ)' DETECCIÓN Durante la ejecución. CAUSA En un sistema con varios almacenes, hay programar en el mismo bloque la herramienta y la posición, pero no el almacén al que se desea llevar dicha herramienta. SOLUCIÓN En un sistema multialmacén, hay que programar en el mismo bloque la herramienta, la posición y el almacén."@es .

ns1:Fallo_1587 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro no modificable desde la puesta a punto"@es ;
    ns1:identificador "1587" ;
    ns1:monitoreaParametro ns1:ParametroMaquina_1587 ;
    ns1:textoExtracto "1587 'Parámetro no modificable desde la puesta a punto' DETECCIÓN Durante la ejecución. CAUSA El parámetro máquina no tiene permiso de escritura desde el entorno de"@es .

ns1:Almacen_SMA a ns1:Parametro ;
    rdfs:label "Número de almacén (MZ)"@es ;
    ns1:identificador "MZ" ;
    ns1:textoExtracto "el número de almacén (MZ)"@es .

ns1:Herramienta_SMA a ns1:Herramienta ;
    rdfs:label "Herramienta (Sistema Multialmacén)"@es ;
    ns1:textoExtracto "la herramienta"@es .

ns1:ParametroMaquina_1587 a ns1:Parametro ;
    rdfs:label "Parámetro máquina (no modificable en puesta a punto)"@es ;
    ns1:textoExtracto "El parámetro máquina no tiene permiso de escritura desde el entorno de"@es .

ns1:Posicion_SMA a ns1:Parametro ;
    rdfs:label "Posición (Sistema Multialmacén)"@es ;
    ns1:textoExtracto "la posición"@es .

ns1:SistemaMultialmacen a ns1:Sistema ;
    rdfs:label "Sistema con varios almacenes"@es ;
    ns1:textoExtracto "En un sistema con varios almacenes, hay programar en el mismo bloque la herramienta y la posición, pero no el almacén al que se desea llevar dicha herramienta."@es ;
    ns1:tieneComponente ns1:Almacen_SMA,
        ns1:Herramienta_SMA,
        ns1:Posicion_SMA .

