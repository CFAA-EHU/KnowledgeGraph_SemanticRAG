@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1587 a ns1:Alarma ;
    rdfs:label "Alarma 1587: Parámetro no modificable desde la puesta a punto" ;
    ns1:identificador "1587" ;
    ns1:monitoreaParametro ns1:ParametroMaquina_1587 ;
    ns1:textoExtracto "1587 'Parámetro no modificable desde la puesta a punto' DETECCIÓN Durante la ejecución. CAUSA El parámetro máquina no tiene permiso de escritura desde el entorno de puesta a punto. SOLUCIÓN El parámetro máquina se podrá modificar directamente en la tabla de parámetros máquina." .

ns1:Alarma_1588 a ns1:Alarma ;
    rdfs:label "Alarma 1588: Cabezal esclavo debe pertenecer al canal" ;
    ns1:activaAlarma ns1:SistemaSincronizacion ;
    ns1:identificador "1588" ;
    ns1:textoExtracto "1588 'El cabezal esclavo a sincronizar debe pertenecer al canal' DETECCIÓN Durante la ejecución. CAUSA El cabezal master de una sincronización puede ser de cualquier canal, pero el cabezal esclavo debe ser del canal en el que se programa la sincronización. SOLUCIÓN Sincronizar el cabezal esclavo desde su canal, añadirlo a la configuración del canal actual o utilizar otro cabezal del canal como esclavo." .

ns1:Alarma_1589 a ns1:Alarma ;
    rdfs:label "Alarma 1589: Cabezal esclavo coincide con el maestro" ;
    ns1:activaAlarma ns1:SistemaSincronizacion ;
    ns1:identificador "1589" ;
    ns1:textoExtracto "1589 'El cabezal esclavo no puede coincidir con el maestro' DETECCIÓN Durante la ejecución. CAUSA En la sincronización, el cabezal esclavo es el mismo que el maestro." .

ns1:TablaParametrosMaquina a ns1:Tabla ;
    rdfs:label "Tabla de parámetros máquina" ;
    ns1:documentadoEn ns1:Manual_1000_1999 ;
    ns1:textoExtracto "El parámetro máquina se podrá modificar directamente en la tabla de parámetros máquina." .

ns1:CabezalEsclavo_1588 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal esclavo (sincronización)" ;
    ns1:textoExtracto "El cabezal esclavo debe ser del canal en el que se programa la sincronización." .

ns1:CabezalMaster_1588 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal master (sincronización)" ;
    ns1:textoExtracto "El cabezal master de una sincronización puede ser de cualquier canal" .

ns1:ParametroMaquina_1587 a ns1:Parametro ;
    rdfs:label "Parámetro máquina (no modificable desde puesta a punto)" ;
    ns1:textoExtracto "El parámetro máquina no tiene permiso de escritura desde el entorno de puesta a punto." .

ns1:SistemaSincronizacion a ns1:Sistema ;
    rdfs:label "Sistema de sincronización de cabezales" ;
    ns1:compuestoPor ns1:CabezalEsclavo_1588,
        ns1:CabezalMaster_1588 ;
    ns1:textoExtracto "El cabezal master de una sincronización puede ser de cualquier canal, pero el cabezal esclavo debe ser del canal en el que se programa la sincronización." .

