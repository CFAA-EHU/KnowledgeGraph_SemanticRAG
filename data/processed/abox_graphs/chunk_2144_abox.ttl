@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FalloSincronizacion_1593 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1593: Cabezal esclavo no perteneciente al canal"@es ;
    ns1:identificador "1593" ;
    ns1:solucionaFallo ns1:Componente_CabezalEsclavo ;
    ns1:textoExtracto "1593 'El cabezal esclavo a desincronizar debe pertenecer al canal' DETECCIÓN Durante la ejecución. CAUSA Un canal no puede cancelar la sincronización de un cabezal esclavo que pertenece a otro canal. SOLUCIÓN Cancelar la sincronización desde el canal al que pertenece el cabezal."@es .

ns1:FalloSincronizacion_1594 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1594: Denominador de relación de transmisión inválido"@es ;
    ns1:identificador "1594" ;
    ns1:solucionaFallo ns1:Parametro_DenominadorRelacionTransmision ;
    ns1:textoExtracto "CAUSA En la sincronización de cabezales, el valor del denominador de la relación de transmisión no es válido; por ejemplo, es cero. SOLUCIÓN El valor puede ser positivo o negativo, no necesariamente entero, pero distinto de cero."@es .

ns1:Sistema_CanalSincronizacion a ns1:Sistema ;
    rdfs:label "Canal de sincronización"@es ;
    ns1:monitoreaParametro ns1:Parametro_DenominadorRelacionTransmision ;
    ns1:textoExtracto "Un canal no puede cancelar la sincronización de un cabezal esclavo que pertenece a otro canal"@es ;
    ns1:tieneComponente ns1:Componente_CabezalEsclavo .

ns1:Componente_CabezalEsclavo a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal esclavo"@es ;
    ns1:textoExtracto "El cabezal esclavo a desincronizar debe pertenecer al canal"@es .

ns1:Parametro_DenominadorRelacionTransmision a ns1:Parametro ;
    rdfs:label "Denominador de relación de transmisión"@es ;
    ns1:textoExtracto "el valor del denominador de la relación de transmisión no es válido; por ejemplo, es cero. El valor puede ser positivo o negativo, no necesariamente entero, pero distinto de cero."@es ;
    ns1:valor "≠ 0" .

