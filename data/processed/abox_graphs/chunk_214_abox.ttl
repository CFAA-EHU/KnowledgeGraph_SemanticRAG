@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_ReanudacionPrograma a ns1:ModoOperacion ;
    rdfs:label "Program resumption after tool inspection"@en ;
    ns1:habilitadoPor ns1:InterfazUsuario_ReposicionamientoEjes ;
    ns1:textoExtracto "If tool inspection has ended by repositioning all the axes, when pressing [START], the CNC completes the interrupted path and goes on with the rest of the program. If tool inspection has ended after canceling the repositioning of the axes, when pressing [START], the axes move from their current position to the end point of the interrupted path and then the CNC goes on with the rest of the program."@en .

ns1:TareaMantenimiento_InspeccionHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Tool inspection task"@en ;
    ns1:requiereMantenimiento ns1:InterfazUsuario_ReposicionamientoEjes ;
    ns1:textoExtracto "TOOL INSPECTION. [...] Resuming the execution of the program. Once all the axes are repositioned or after canceling repositioning, press [START] to resume program execution."@en .

ns1:InterfazUsuario_ReposicionamientoEjes a ns1:InterfazUsuario ;
    rdfs:label "Repositioning interface for axes and spindle"@en ;
    ns1:textoExtracto "The CNC allows repositioning the axes either one by one or in groups. Use the vertical softkeys to select the axes to be repositioned and press [START]. The CNC will reposition the axes at the selected point (according to the softkey selected earlier) at the feedrate set by the machine manufacturer. Once one axis has reached its position, it will no longer be available. Repositioning the master spindle. If the status of the master spindle has changed during the inspection, the softkeys will show the M3, M4, M5 or M19 function to restore."@en .

