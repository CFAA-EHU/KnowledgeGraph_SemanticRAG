@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1612 a ns1:Alarma ;
    rdfs:label "Alarma 1612: Ejes de transformación angular no excluibles"@es ;
    ns1:identificador "1612" ;
    ns1:mitigaRiesgo ns1:TransformacionAngular_ANGAX ;
    ns1:textoExtracto "'Los ejes de la transformación angular activa, #ANGAX, no pueden excluirse'"@es .

ns1:Alarma_1613 a ns1:Alarma ;
    rdfs:label "Alarma 1613: Transformación angular desactivada"@es ;
    ns1:identificador "1613" ;
    ns1:mitigaRiesgo ns1:TransformacionAngular_ANGAX ;
    ns1:textoExtracto "'Se ha desactivado la transformación angular #ANGAX'"@es .

ns1:ConfiguracionEjesPlano_G18 a ns1:ModoOperacion ;
    rdfs:label "Configuración de ejes tipo plano (G18)"@es ;
    ns1:identificador "G18" ;
    ns1:textoExtracto "En un torno con configuración de ejes tipo plano, el plano activo siempre es G18."@es .

ns1:FuncionCambioEjeLongitudinal_G20 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función de cambio de eje longitudinal (G20)"@es ;
    ns1:identificador "G20" ;
    ns1:textoExtracto "Si sólo se desea cambiar el eje longitudinal, utilizar la función G20."@es .

ns1:TransformacionAngular_ANGAX a ns1:Parametro ;
    rdfs:label "Transformación angular activa (#ANGAX)"@es ;
    ns1:identificador "#ANGAX" ;
    ns1:textoExtracto "Los ejes de la transformación angular activa, #ANGAX, no pueden excluirse"@es .

