@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_Q a ns1:Parametro ;
    rdfs:label "Parámetro Q (programación en polares)" ;
    ns1:identificador "Q" ;
    ns1:textoExtracto "Para la programación en polares utilizar el parámetro Q" .

ns1:Parametro_Q1 a ns1:Parametro ;
    rdfs:label "Parámetro Q1 (función G33)" ;
    ns1:identificador "Q1" ;
    ns1:textoExtracto "Para la función G33 utilizar el parámetro Q1" .

ns1:TareaMantenimiento_RevisionProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación (parámetros Q/Q1)" ;
    ns1:solucionaFallo ns1:Alarma_1618,
        ns1:Alarma_1619 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:Alarma_1618 a ns1:Alarma ;
    rdfs:label "Alarma 1618: Valor Q doblemente programado" ;
    ns1:identificador "1618" ;
    ns1:textoExtracto "1618 'Valor Q doblemente programado' DETECCIÓN Durante la ejecución. CAUSA El parámetro Q está programado más de una vez en el mismo bloque." .

ns1:Alarma_1619 a ns1:Alarma ;
    rdfs:label "Alarma 1619: Valor Q1 doblemente programado" ;
    ns1:identificador "1619" ;
    ns1:textoExtracto "1619 'Valor Q1 doblemente" .

