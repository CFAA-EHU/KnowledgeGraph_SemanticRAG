@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1619 a ns1:Alarma ;
    rdfs:label "Valor Q doblemente programado" ;
    ns1:identificador "1619" ;
    ns1:monitoreaParametro ns1:Parametro_Q ;
    ns1:textoExtracto "'Valor Q doblemente programado' DETECCIÓN Durante la ejecución. CAUSA El parámetro Q está programado más de una vez en el mismo bloque. SOLUCIÓN Revisar la programación." .

ns1:Alarma_1620 a ns1:Alarma ;
    rdfs:label "Valor Q1 doblemente programado" ;
    ns1:identificador "1620" ;
    ns1:monitoreaParametro ns1:Parametro_Q1 ;
    ns1:textoExtracto "'Valor Q1 doblemente programado' DETECCIÓN Durante la ejecución. CAUSA El parámetro Q1 está programado más de una vez en el mismo bloque. SOLUCIÓN Revisar la programación." .

ns1:Alarma_1621 a ns1:Alarma ;
    rdfs:label "No se admite #SERVO ON para eje o cabezal SERCOS POSICION" ;
    ns1:identificador "1621" ;
    ns1:monitoreaParametro ns1:Parametro_SERVO_ON ;
    ns1:textoExtracto "'No se admite #SERVO ON para eje o cabezal SERCOS POSICION' DETECCIÓN Durante la ejecución. CAUSA El eje o cabezal es Sercos posición. SOLUCIÓN Esta sentencia sólo permite ejes Sercos velocidad." .

ns1:Alarma_1622 a ns1:Alarma ;
    rdfs:label "No se admite Q1 sin G33 en el bloque o G63 activa" ;
    ns1:identificador "1622" ;
    ns1:monitoreaParametro ns1:Parametro_Q1 ;
    ns1:textoExtracto "'No se admite Q1 sin G33 en el bloque o G63 activa' DETECCIÓN Durante la ejecución. CAUSA Hay programado un parámetro Q1 sin G33 en el bloque o sin la función G63 activa. SOLUCIÓN El parámetro Q debe ir en el mismo bloque que G33. El parámetro Q sólo puede ir solo en el bloque si está activa la función G63." .

ns1:Alarma_1623 a ns1:Alarma ;
    rdfs:label "Un cabezal de intercambio temporal no puede funcionar como eje C mantenido" ;
    ns1:identificador "1623" ;
    ns1:monitoreaParametro ns1:Parametro_PERCAX ;
    ns1:textoExtracto "'Un cabezal de intercambio temporal no puede funcionar como eje C mantenido' DETECCIÓN Durante la ejecución. CAUSA El CNC puede activar como eje C mantenido (parámetro PERCAX) un cabezal de intercambio temporal. SOLUCIÓN Si es posible, definir el cabezal como de intercambio mantenido; si no, utilizar otro cabezal como eje C." .

ns1:Alarma_1624 a ns1:Alarma ;
    rdfs:label "Gama para sincronización SYNCSET no válida" ;
    ns1:identificador "1624" ;
    ns1:monitoreaParametro ns1:Parametro_SYNCSET ;
    ns1:textoExtracto "'Gama para sincronización SYNCSET no valida' DETECCIÓN Durante la ejecución. CAUSA El parámetro SYNCSET tiene un valor no valido. SOLUCIÓN Asignar al parámetro un valor correcto." .

ns1:Alarma_1625 a ns1:Alarma ;
    rdfs:label "Programar #TANGCTRL ON/OFF/SUSP [ ]" ;
    ns1:identificador "1625" ;
    ns1:monitoreaParametro ns1:Parametro_TANGCTRL ;
    ns1:textoExtracto "'Programar #TANGCTRL ON/OFF/SUSP [ ]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación." .

ns1:ComponenteElectrico_CabezalIntercambioTemporal a ns1:ComponenteElectrico ;
    rdfs:label "Cabezal de intercambio temporal" ;
    ns1:textoExtracto "Un cabezal de intercambio temporal no puede funcionar como eje C mantenido." .

ns1:ComponenteElectrico_CabezalSERCOS a ns1:ComponenteElectrico ;
    rdfs:label "Cabezal SERCOS" ;
    ns1:textoExtracto "El eje o cabezal es Sercos posición. Esta sentencia sólo permite ejes Sercos velocidad." .

ns1:Parametro_PERCAX a ns1:Parametro ;
    rdfs:label "Parámetro PERCAX" ;
    ns1:textoExtracto "El CNC puede activar como eje C mantenido (parámetro PERCAX) un cabezal de intercambio temporal." .

ns1:Parametro_Q a ns1:Parametro ;
    rdfs:label "Parámetro Q" ;
    ns1:textoExtracto "El parámetro Q está programado más de una vez en el mismo bloque." .

ns1:Parametro_SERVO_ON a ns1:Parametro ;
    rdfs:label "Parámetro #SERVO ON" ;
    ns1:textoExtracto "No se admite #SERVO ON para eje o cabezal SERCOS POSICION." .

ns1:Parametro_SYNCSET a ns1:Parametro ;
    rdfs:label "Parámetro SYNCSET" ;
    ns1:textoExtracto "El parámetro SYNCSET tiene un valor no válido." .

ns1:Parametro_TANGCTRL a ns1:Parametro ;
    rdfs:label "Parámetro #TANGCTRL" ;
    ns1:textoExtracto "La sintaxis de la sentencia #TANGCTRL ON/OFF/SUSP no es correcta." .

ns1:Parametro_Q1 a ns1:Parametro ;
    rdfs:label "Parámetro Q1" ;
    ns1:textoExtracto "El parámetro Q1 está programado más de una vez en el mismo bloque." .

