@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1625 a ns1:DiagnosticoFallo ;
    rdfs:label "Validación de eje en control tangencial" ;
    ns1:identificador "1625" ;
    ns1:textoExtracto "1625 'Un eje en control tangencial activo debe ser rotativo no HIRTH y no pertenecer al triedro activo' [...] Los ejes a activar en el control tangencial debe ser" .

ns1:Parametro_TANGCTRL a ns1:Parametro ;
    rdfs:label "Parámetro TANGCTRL" ;
    ns1:monitoreaParametro ns1:DiagnosticoFallo_1624 ;
    ns1:textoExtracto "#TANGCTRL ON/OFF/SUSP [ ]" ;
    ns1:valor "ON/OFF/SUSP" .

ns1:DiagnosticoFallo_1624 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en programación TANGCTRL" ;
    ns1:identificador "1624" ;
    ns1:solucionaFallo ns1:ParametroDeControlTangencial ;
    ns1:textoExtracto "1624 'Programar #TANGCTRL ON/OFF/SUSP [ ]' [...] SOLUCIÓN Revisar la programación. Junto a la sentencia hay que programar uno de los comandos ON/SUSP/OFF y a continuación los parámetros de llamada entre corchetes. También se permite la programación de uno de los comandos SUSP/OFF sin parámetros de llamada." .

ns1:ParametroDeControlTangencial a ns1:Parametro ;
    rdfs:label "Parámetro de control tangencial" ;
    ns1:textoExtracto "Asignar al parámetro un valor correcto" ;
    ns1:valor "#TANGCTRL ON/OFF/SUSP [ ]" .

