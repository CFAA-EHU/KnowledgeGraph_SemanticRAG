@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1630 a ns1:DiagnosticoFallo ;
    rdfs:label "Asignación incorrecta de parámetros S/E en programación de perfil" ;
    ns1:monitoreaParametro ns1:Parametro_E,
        ns1:Parametro_S ;
    ns1:solucionaFallo ns1:Alarma_1630 ;
    ns1:textoExtracto "En la llamada al ciclo se han designado de forma incorrecta los parámetros que definen el comienzo y el final del perfil (parámetros S y E). SOLUCIÓN Asignar un valor correcto a los parámetros S y E." .

ns1:DiagnosticoFallo_1631 a ns1:DiagnosticoFallo ;
    rdfs:label "Sintaxis no permitida en programación de perfil ([S,E,<Q>] o [P,<Q>])" ;
    ns1:monitoreaParametro ns1:Parametro_E,
        ns1:Parametro_S ;
    ns1:solucionaFallo ns1:Alarma_1631 ;
    ns1:textoExtracto "En la llamada al ciclo se han designado de forma incorrecta los parámetros que definen el comienzo y el final del perfil (parámetros S y E), la" .

ns1:Alarma_1630 a ns1:Alarma ;
    rdfs:label "Programación de perfil mediante etiquetas incorrecta" ;
    ns1:identificador "1630" ;
    ns1:textoExtracto "1630 'Programación de perfil mediante etiquetas incorrecta' DETECCIÓN Durante la ejecución. CAUSA En la llamada al ciclo se han designado de forma incorrecta los parámetros que definen el comienzo y el final del perfil (parámetros S y E)." .

ns1:Alarma_1631 a ns1:Alarma ;
    rdfs:label "Programación de perfil no permitida: [S,E,<Q>] o [P,<Q>]" ;
    ns1:identificador "1631" ;
    ns1:textoExtracto "1631 'Programación de perfil no permitida: [S,E,<Q>] o [P,<Q>]' DETECCIÓN Durante la ejecución. CAUSA En la llamada al ciclo se han designado de forma incorrecta los parámetros que definen el comienzo y el final del perfil (parámetros S y E), la" .

ns1:Parametro_E a ns1:Parametro ;
    rdfs:label "Parámetro E (final de perfil)" ;
    ns1:textoExtracto "parámetros que definen el [...] final del perfil (parámetros S y E)" .

ns1:Parametro_S a ns1:Parametro ;
    rdfs:label "Parámetro S (comienzo de perfil)" ;
    ns1:textoExtracto "parámetros que definen el comienzo [...] del perfil (parámetros S y E)" .

