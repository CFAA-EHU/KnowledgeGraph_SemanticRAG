@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1633 a ns1:Alarma ;
    rdfs:label "Alarma 1633: Error de sintaxis en programación de cabezal"@es ;
    ns1:identificador "1633" ;
    ns1:monitoreaParametro ns1:Parametro_ProgramacionCabezales ;
    ns1:textoExtracto "'Programar: #DGSPSL <nombre de cabezal>' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_1634 a ns1:Alarma ;
    rdfs:label "Alarma 1634: Error en sentencia #MOVE (eje/canal inválido)"@es ;
    ns1:identificador "1634" ;
    ns1:monitoreaParametro ns1:Parametro_EjeCanal ;
    ns1:textoExtracto "'La sentencia #MOVE sólo admite un eje y debe pertenecer al canal' DETECCIÓN Durante la ejecución. CAUSA No se ha programado un nombre de eje correcto, el eje está en otro canal o no es un eje del sistema. No se permite la programación de cabezales, excepto cuando estén trabajando como eje C, en cuyo caso se debe programar con el nombre del eje C. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_1635 a ns1:Alarma ;
    rdfs:label "Alarma 1635: Exceso de ejes en transformación de coordenadas"@es ;
    ns1:identificador "1635" ;
    ns1:monitoreaParametro ns1:Parametro_NKINAX ;
    ns1:textoExtracto "'El número de ejes en la transformación excede al permitido' DETECCIÓN Durante la ejecución. CAUSA La transformación de coordenadas tiene definido en el parámetro NKINAX más ejes de los permitidos en el CNC. SOLUCIÓN Corregir el parámetro máquina NKINAX."@es .

ns1:Maquina a ns1:Maquina ;
    rdfs:label "Máquina-herramienta con control CNC"@es ;
    ns1:textoExtracto "Corregir el parámetro máquina NKINAX"@es ;
    ns1:tieneComponente ns1:SistemaCNC .

ns1:Parametro_EjeCanal a ns1:Parametro ;
    rdfs:label "Parámetro de asignación eje/canal (sentencia #MOVE)"@es ;
    ns1:textoExtracto "el eje está en otro canal o no es un eje del sistema [...] excepto cuando estén trabajando como eje C"@es .

ns1:Parametro_ProgramacionCabezales a ns1:Parametro ;
    rdfs:label "Parámetro de programación de cabezales (#DGSPSL)"@es ;
    ns1:textoExtracto "sintaxis de la sentencia #DGSPSL <nombre de cabezal>"@es .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC de la máquina"@es ;
    ns1:textoExtracto "el eje está en otro canal o no es un eje del sistema [...] más ejes de los permitidos en el CNC"@es ;
    ns1:tieneComponente ns1:Parametro_NKINAX .

ns1:Parametro_NKINAX a ns1:Parametro ;
    rdfs:label "Parámetro NKINAX (número de ejes en transformación de coordenadas)"@es ;
    ns1:identificador "NKINAX" ;
    ns1:textoExtracto "parámetro NKINAX [...] más ejes de los permitidos en el CNC"@es .

