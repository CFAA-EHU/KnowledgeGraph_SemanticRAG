@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_EDISIMU a ns1:ModoOperacion ;
    rdfs:label "EDISIMU MODE"@en ;
    ns1:textoExtracto "Softkey... | ...Configuring simulation options."@en ;
    ns1:tieneComponente ns1:InterfazUsuario_EDISIMU_Softkeys .

ns1:AccionProhibida_EDISIMU_Analyze a ns1:AccionProhibida ;
    rdfs:label "Syntax error analysis"@en ;
    ns1:identificador "ANALYZE"@en ;
    ns1:textoExtracto "Analyze the program looking for syntax errors. The syntax check is not available for programs written in 8055 CNC language."@en .

ns1:AccionProhibida_EDISIMU_Reset a ns1:AccionProhibida ;
    rdfs:label "RESET simulation"@en ;
    ns1:identificador "RESET"@en ;
    ns1:solucionaFallo ns1:AvisoSeguridad_EDISIMU_ErrorStatus ;
    ns1:textoExtracto "RESET (simulation). Cancel program simulation. If an error occurs during simulation, reset eliminates the error status and returns the simulation mode to its initial conditions."@en .

ns1:AccionProhibida_EDISIMU_StartStop a ns1:AccionProhibida ;
    rdfs:label "START/STOP simulation toggle"@en ;
    ns1:identificador "START/STOP"@en ;
    ns1:textoExtracto "START (simulation). Starts program simulation or resume it if it was interrupted. STOP (simulation). Interrupt program simulation."@en .

ns1:AvisoSeguridad_EDISIMU_ErrorStatus a ns1:AvisoSeguridad ;
    rdfs:label "EDISIMU error status"@en ;
    ns1:textoExtracto "If an error occurs during simulation, reset eliminates the error status..."@en .

ns1:InterfazUsuario_EDISIMU_Softkeys a ns1:InterfazUsuario ;
    rdfs:label "EDISIMU simulation softkeys"@en ;
    ns1:textoExtracto "Softkey. | Description. | START (simulation)... | ...Configuring simulation options."@en ;
    ns1:tieneComponente ns1:AccionProhibida_EDISIMU_Analyze,
        ns1:AccionProhibida_EDISIMU_Reset,
        ns1:AccionProhibida_EDISIMU_StartStop,
        ns1:Parametro_EDISIMU_ChannelSelection,
        ns1:Parametro_EDISIMU_ExecutionMode,
        ns1:Parametro_EDISIMU_ExecutionTimeEstimate .

ns1:Parametro_EDISIMU_ChannelSelection a ns1:Parametro ;
    rdfs:label "Channel selection for editing/simulation"@en ;
    ns1:identificador "channel selection"@en ;
    ns1:textoExtracto "Change the channel being displayed for editing and simulation. It does not affect the active channel at the CNC."@en .

ns1:Parametro_EDISIMU_ExecutionMode a ns1:Parametro ;
    rdfs:label "Single block/Continuous execution mode"@en ;
    ns1:identificador "single block/continuous"@en ;
    ns1:textoExtracto "Select the 'single block' or 'continuous' execution mode. When 'single block' mode is active, program simulation will be interrupted at the end of each block."@en .

ns1:Parametro_EDISIMU_ExecutionTimeEstimate a ns1:Parametro ;
    rdfs:label "Total execution time estimate"@en ;
    ns1:identificador "execution time estimate"@en ;
    ns1:textoExtracto "Offer an estimate of the total execution time at 100% of the programmed feedrate. The result will appear at the statistics window."@en ;
    ns1:valor "100% feedrate"@en .

