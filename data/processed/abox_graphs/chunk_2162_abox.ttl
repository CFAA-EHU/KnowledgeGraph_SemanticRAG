@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Diagnostico_1643 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para error 1643 (cabezales tándem)"@es ;
    ns1:solucionaFallo ns1:ErrorTandem_1643 ;
    ns1:textoExtracto "CAUSA El usuario ha intentado mover o hacer referencia al cabezal esclavo de una pareja tándem. SOLUCIÓN El cabezal esclavo de una pareja tándem es controlado por el CNC, no se puede desplazar individualmente. Para desplazar un cabezal esclavo, hay que desplazar el cabezal maestro al que se encuentra asociado."@es .

ns1:SistemaTandem a ns1:Sistema ;
    rdfs:label "Sistema de cabezales tándem"@es ;
    ns1:controla ns1:CabezalEsclavo ;
    ns1:textoExtracto "pareja tándem"@es ;
    ns1:tieneComponente ns1:CabezalEsclavo,
        ns1:CabezalMaestro .

ns1:CabezalMaestro a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal maestro (tándem)"@es ;
    ns1:textoExtracto "Para desplazar un cabezal esclavo, hay que desplazar el cabezal maestro al que se encuentra asociado"@es .

ns1:ErrorTandem_1643 a ns1:AvisoSeguridad ;
    rdfs:label "Error 1643: No se permite aparcar cabezales TANDEM"@es ;
    ns1:identificador "1643" ;
    ns1:textoExtracto "1643 'No se permite aparcar cabezales TANDEM'"@es .

ns1:CabezalEsclavo a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal esclavo (tándem)"@es ;
    ns1:textoExtracto "El usuario ha intentado mover o hacer referencia al cabezal esclavo de una pareja tándem. [...] El cabezal esclavo de una pareja tándem es controlado por el CNC"@es .

