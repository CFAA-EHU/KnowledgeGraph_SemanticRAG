@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1650 a ns1:AvisoSeguridad ;
    rdfs:label "Falta la función de coordenadas McsToPcs"@es ;
    ns1:solucionaFallo ns1:Sistema_CinematicaUsuario ;
    ns1:textoExtracto "Falta la función de coordenadas McsToPcs al intentar realizar la transformación de coordenadas máquina a pieza en una cinemática de usuario. SOLUCIÓN Revisar el proceso de integración de cinemáticas de usuario."@es .

ns1:Fallo_1651 a ns1:AvisoSeguridad ;
    rdfs:label "No se admite LINK mantenido con ejes temporales de otro canal"@es ;
    ns1:identificador "1651" ;
    ns1:textoExtracto "El CNC no puede acoplar ejes con permiso de intercambio temporal (parámetro AXISEXCH) si pertenecen a otro canal y los acoplos del canal están definidos como mantenidos (parámetro LINKCANCEL). SOLUCIÓN Acoplar los ejes en su canal."@es .

ns1:Fallo_1652 a ns1:AvisoSeguridad ;
    rdfs:label "Se esperaba #DEF 'macro'='comando' 'macro'='comando'..."@es ;
    ns1:identificador "1652" ;
    ns1:textoExtracto "Sentencia mal programada. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1653 a ns1:AvisoSeguridad ;
    rdfs:label "Un eje de la transformación de plano inclinado no puede ser esclavo"@es ;
    ns1:identificador "1653" ;
    ns1:textoExtracto "El CNC ha intentado definir como eje esclavo de un acoplo, un eje que forma parte del plano inclinado. SOLUCIÓN Desactivar el plano inclinado para poder activar el acoplo. Un eje que forma parte de un plano inclinado no puede ser el eje esclavo en un acoplo; sí puede ser el eje maestro de un acoplo."@es .

ns1:Fallo_1654 a ns1:AvisoSeguridad ;
    rdfs:label "Bus digital (Sercos/Mechatrolink) no preparado para la lectura de la variable"@es ;
    ns1:identificador "1654" ;
    ns1:mitigaRiesgo ns1:Marca_MLINKRDY,
        ns1:Marca_SERCOSRDY ;
    ns1:textoExtracto "Con bus Sercos, el anillo no está en fase 4. Con bus Mechatrolink, el bus no ha alcanzado la fase 3. SOLUCIÓN Condicionar la escritura de la variable a la marca SERCOSRDY en Sercos o a la marca MLINKRDY en Mechatrolink."@es .

ns1:Fallo_1655 a ns1:AvisoSeguridad ;
    rdfs:label "Bus digital (Sercos/Mechatrolink) no preparado para la escritura de la variable"@es ;
    ns1:identificador "1655" ;
    ns1:textoExtracto "Durante la ejecución."@es .

ns1:Parametro_AXISEXCH a ns1:Parametro ;
    rdfs:label "AXISEXCH" ;
    ns1:textoExtracto "parámetro AXISEXCH"@es ;
    ns1:valor "AXISEXCH" .

ns1:Parametro_LINKCANCEL a ns1:Parametro ;
    rdfs:label "LINKCANCEL" ;
    ns1:textoExtracto "parámetro LINKCANCEL"@es ;
    ns1:valor "LINKCANCEL" .

ns1:Sistema_BusMechatrolink a ns1:Sistema ;
    rdfs:label "Bus Mechatrolink"@es ;
    ns1:textoExtracto "Con bus Mechatrolink, el bus no ha alcanzado la fase 3."@es .

ns1:Sistema_BusSercos a ns1:Sistema ;
    rdfs:label "Bus Sercos"@es ;
    ns1:textoExtracto "Con bus Sercos, el anillo no está en fase 4."@es .

ns1:Marca_MLINKRDY a ns1:Parametro ;
    rdfs:label "MLINKRDY" ;
    ns1:textoExtracto "marca MLINKRDY"@es ;
    ns1:valor "MLINKRDY" .

ns1:Marca_SERCOSRDY a ns1:Parametro ;
    rdfs:label "SERCOSRDY" ;
    ns1:textoExtracto "marca SERCOSRDY"@es ;
    ns1:valor "SERCOSRDY" .

ns1:Sistema_CinematicaUsuario a ns1:Sistema ;
    rdfs:label "Cinemática de usuario"@es ;
    ns1:textoExtracto "transformación de coordenadas máquina a pieza en una cinemática de usuario"@es .

