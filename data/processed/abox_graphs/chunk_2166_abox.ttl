@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1655 a ns1:DiagnosticoFallo ;
    rdfs:label "Bus digital (Sercos/Mechatrolink) no preparado para la escritura de la variable"@es ;
    ns1:identificador "1655" ;
    ns1:solucionaFallo ns1:Marca_MLINKRDY,
        ns1:Marca_SERCOSRDY ;
    ns1:textoExtracto "1655 'Bus digital (Sercos/Mechatrolink) no preparado para la escritura de la variable' DETECCIÓN Durante la ejecución. CAUSA Con bus Sercos, el anillo no está en fase 4. Con bus Mechatrolink, el bus no ha alcanzado la fase 3. SOLUCIÓN Condicionar la escritura de la variable a la marca SERCOSRDY en Sercos o a la marca MLINKRDY en Mechatrolink."@es .

ns1:Fallo_1656 a ns1:DiagnosticoFallo ;
    rdfs:label "Alguno de los ejes del plano está en diámetros"@es ;
    ns1:identificador "1656" ;
    ns1:textoExtracto "1656 'Alguno de los ejes del plano esta en diámetros' DETECCIÓN Al simular o ejecutar en un torno un ciclo fijo de fresadora"@es .

ns1:Sistema_Mechatrolink a ns1:Sistema ;
    rdfs:label "Bus Mechatrolink"@es ;
    ns1:monitoreaParametro ns1:Marca_MLINKRDY ;
    ns1:textoExtracto "Con bus Mechatrolink, el bus no ha alcanzado la fase 3"@es .

ns1:Sistema_Sercos a ns1:Sistema ;
    rdfs:label "Bus Sercos"@es ;
    ns1:monitoreaParametro ns1:Marca_SERCOSRDY ;
    ns1:textoExtracto "Con bus Sercos, el anillo no está en fase 4"@es .

ns1:Marca_MLINKRDY a ns1:Parametro ;
    rdfs:label "MLINKRDY" ;
    ns1:textoExtracto "Condicionar la escritura de la variable a la marca MLINKRDY en Mechatrolink"@es .

ns1:Marca_SERCOSRDY a ns1:Parametro ;
    rdfs:label "SERCOSRDY" ;
    ns1:textoExtracto "Condicionar la escritura de la variable a la marca SERCOSRDY en Sercos"@es .

