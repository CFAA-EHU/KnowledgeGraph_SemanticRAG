@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Comando_CNCRD a ns1:ComponenteElectrico ;
    ns1:textoExtracto "CAUSA Comandos CNCRD o CNCWR." .

ns1:Comando_CNCWR a ns1:ComponenteElectrico ;
    ns1:textoExtracto "CAUSA Comandos CNCRD o CNCWR." .

ns1:Comando_DEF_FIX a ns1:ComponenteElectrico ;
    ns1:textoExtracto "Las macros definidas mediante el comando #DEF FIX no se borran tras un reset." .

ns1:Comando_INIT_MACROTAB a ns1:ComponenteElectrico ;
    ns1:textoExtracto "Utilizar el comando #INIT MACROTAB para reiniciar la tabla de macros" .

ns1:FaltaProgramarPunto a ns1:DiagnosticoFallo ;
    ns1:textoExtracto "'Falta programar \".\" tras [númeroCanal]' DETECCIÓN Durante la ejecución. CAUSA Comandos CNCRD o CNCWR." .

ns1:IndiceArrayIncorrecto a ns1:DiagnosticoFallo ;
    ns1:textoExtracto "'Indice de array incorrecto' DETECCIÓN Durante la ejecución. CAUSA Comandos CNCRD o CNCWR. Algún índice de array programado en la variable está fuera de rango." .

ns1:MacroTab a ns1:Tabla ;
    ns1:textoExtracto "Utilizar el comando #INIT MACROTAB para reiniciar la tabla de macros, el cuál borra todas las macros definidas tanto con #DEF como con #DEF FIX." .

ns1:Variable a ns1:Parametro ;
    ns1:textoExtracto "Consultar la variable y su rango de valores." .

