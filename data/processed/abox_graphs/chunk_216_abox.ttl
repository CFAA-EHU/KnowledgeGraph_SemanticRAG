@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoSimulacionAutomatica a ns1:ModoOperacion ;
    rdfs:label "Automatic simulation mode" ;
    ns1:documentadoEn ns1:ModoEDISIMU ;
    ns1:textoExtracto "The program may be simulated in –single block– or –automatic– mode; the mode may be selected even while simulating the program." .

ns1:ModoSimulacionBloqueUnico a ns1:ModoOperacion ;
    rdfs:label "Single block simulation mode" ;
    ns1:documentadoEn ns1:ModoEDISIMU ;
    ns1:textoExtracto "The program may be simulated in –single block– or –automatic– mode; the mode may be selected even while simulating the program." .

ns1:OpcionConfirmacionPrograma a ns1:AccionProhibida ;
    rdfs:label "Program confirmation step" ;
    ns1:documentadoEn ns1:InterfazSeleccionPrograma_EDISIMU ;
    ns1:textoExtracto "3 Press [ENTER] to accept the selection and open the program or [ESC] to cancel it and close the program listing." .

ns1:OpcionDetenerSimulacion a ns1:AccionProhibida ;
    rdfs:label "STOP simulation option" ;
    ns1:documentadoEn ns1:InterfazSimulacion_EDISIMU ;
    ns1:textoExtracto "The simulation may be interrupted with the STOP icon or canceled with the RESET icon." .

ns1:OpcionIniciarSimulacion a ns1:AccionProhibida ;
    rdfs:label "START simulation option" ;
    ns1:documentadoEn ns1:InterfazSimulacion_EDISIMU ;
    ns1:textoExtracto "Press the START icon to start the simulation." .

ns1:OpcionReiniciarSimulacion a ns1:AccionProhibida ;
    rdfs:label "RESET simulation option" ;
    ns1:documentadoEn ns1:InterfazSimulacion_EDISIMU ;
    ns1:textoExtracto "The simulation may be interrupted with the STOP icon or canceled with the RESET icon." .

ns1:OpcionSeleccionCarpeta a ns1:AccionProhibida ;
    rdfs:label "Folder selection step" ;
    ns1:documentadoEn ns1:InterfazSeleccionPrograma_EDISIMU ;
    ns1:textoExtracto "1 Select the folder that contains the program. If it is a new program, it will be saved in this folder." .

ns1:OpcionSeleccionPrograma a ns1:AccionProhibida ;
    rdfs:label "Program selection step" ;
    ns1:documentadoEn ns1:InterfazSeleccionPrograma_EDISIMU ;
    ns1:textoExtracto "2 Select the program from the list or write its name in the bottom window. To edit a new program, write the name of the program in the lower window and the CNC will open an empty program or a predefined template depending on how the editor is configured." .

ns1:ParametroRepresentacionGrafica a ns1:Parametro ;
    rdfs:label "Graphic representation dimensions" ;
    ns1:monitoreaParametro ns1:InterfazSimulacion_EDISIMU ;
    ns1:textoExtracto "Choose the type of graphic representation, its dimensions and the point of view." .

ns1:InterfazSeleccionPrograma_EDISIMU a ns1:InterfazUsuario ;
    rdfs:label "Open program softkey interface" ;
    ns1:ilustradoEn ns1:ModoEDISIMU ;
    ns1:textoExtracto "The 'Open program' softkey is used to select a program in EDISIMU mode and may be a new program or an existing one. A different program may be edited and executed in each channel. When selecting this option, the CNC shows a list of the available programs." .

ns1:InterfazSimulacion_EDISIMU a ns1:InterfazUsuario ;
    rdfs:label "EDISIMU simulation interface" ;
    ns1:ilustradoEn ns1:ModoEDISIMU ;
    ns1:textoExtracto "Simulating a program. 1 Choose the type of graphic representation, its dimensions and the point of view. This data may also be modified during the simulation of the program. 2 Activate the desired simulation options using the icon menu. 3 Press the START icon to start the simulation." .

ns1:ModoEDISIMU a ns1:ModoOperacion ;
    rdfs:label "EDISIMU MODE" ;
    ns1:textoExtracto "Select a program. The 'Open program' softkey is used to select a program in EDISIMU mode and may be a new program or an existing one." .

