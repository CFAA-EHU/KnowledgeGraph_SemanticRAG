@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_1661 a ns1:AvisoSeguridad ;
    rdfs:label "Falta programar '.' tras [númeroCanal]"@es ;
    ns1:identificador "1661" ;
    ns1:textoExtracto "1661 'Falta programar \".\" tras [númeroCanal]' DETECCIÓN Durante la ejecución. CAUSA Comandos CNCRD o CNCWR. El número de canal debe ir entre corchetes y seguido del carácter \".\". SOLUCIÓN Revisar la programación."@es .

ns1:AvisoSeguridad_1662 a ns1:AvisoSeguridad ;
    rdfs:label "Tipo de variable desconocido"@es ;
    ns1:identificador "1662" ;
    ns1:textoExtracto "1662 'Tipo de variable desconocido' DETECCIÓN Durante la ejecución. CAUSA Comandos CNCRD o CNCWR. No existe el tipo de variable programado. SOLUCIÓN Revisar la programación."@es .

ns1:AvisoSeguridad_1663 a ns1:AvisoSeguridad ;
    rdfs:label "Falta indicar variable(s) a borrar en #DELETE"@es ;
    ns1:identificador "1663" ;
    ns1:textoExtracto "1663 '#DELETE: falta indicar variable(s) a borrar' DETECCIÓN Durante la ejecución. CAUSA En la sentencia #DELETE falta indicar las variables a borrar. SOLUCIÓN Indicar junto a la sentencia #DELETE las variables a borrar."@es .

ns1:AvisoSeguridad_1664 a ns1:AvisoSeguridad ;
    rdfs:label "Herramienta en uso en otro canal"@es ;
    ns1:identificador "1664" ;
    ns1:textoExtracto "1664 La herramienta pedida está siendo utilizada en otro canal. DETECCIÓN Durante la ejecución. CAUSA La herramienta programada está activa en otro canal. SOLUCIÓN Esperar a que el canal libere la herramienta. Si la herramienta no está en uso, descargar la herramienta del otro canal."@es .

ns1:AvisoSeguridad_1665 a ns1:AvisoSeguridad ;
    rdfs:label "Función G174 admite solo un eje o cabezal"@es ;
    ns1:identificador "1665" ;
    ns1:textoExtracto "1665 'La función G174 sólo admite un eje o cabezal' DETECCIÓN Durante la ejecución. CAUSA En la función G174 hay programado más de un eje o cabezal. SOLUCIÓN Programar una función G174 por cada eje o cabezal."@es .

ns1:AvisoSeguridad_1666 a ns1:AvisoSeguridad ;
    rdfs:label "G174 no admite ejes acoplados (GANTRY/TANDEM)"@es ;
    ns1:identificador "1666" ;
    ns1:textoExtracto "1666 'G174: no se admiten ejes acoplados, GANTRY o TANDEM' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado inicializar cota máquina (G174) de un eje que forma parte de una pareja de ejes gantry, tándem o de un acoplo activo (#LINK). SOLUCIÓN Para inicializar cota máquina en dicho eje, desactivar el acoplo. No se puede inicializar la cota máquina de ejes gantry o tándem."@es .

ns1:AvisoSeguridad_1667 a ns1:AvisoSeguridad ;
    rdfs:label "G174 no admite ejes de cinemática activa"@es ;
    ns1:identificador "1667" ;
    ns1:textoExtracto "1667 'G174: no se admiten ejes de la cinemática o transformadas activas' DETECCIÓN Durante la ejecución."@es .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC"@es ;
    ns1:textoExtracto "El CNC ha intentado inicializar cota máquina (G174)"@es ;
    ns1:tieneComponente ns1:ComponenteMecanico_Cabezal,
        ns1:ComponenteMecanico_Eje .

ns1:Parametro_NumeroCanal a ns1:Parametro ;
    rdfs:label "Número de canal"@es ;
    ns1:textoExtracto "El número de canal debe ir entre corchetes y seguido del carácter \".\""@es .

ns1:Parametro_Variable a ns1:Parametro ;
    rdfs:label "Variable"@es ;
    ns1:textoExtracto "Consultar la variable y su rango de valores"@es .

ns1:ComponenteMecanico_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal"@es ;
    ns1:textoExtracto "La función G174 sólo admite un eje o cabezal"@es .

ns1:ComponenteMecanico_Eje a ns1:ComponenteMecanico ;
    rdfs:label "Eje"@es ;
    ns1:textoExtracto "En la función G174 hay programado más de un eje o cabezal"@es .

ns1:Herramienta a ns1:Herramienta ;
    rdfs:label "Herramienta"@es ;
    ns1:textoExtracto "La herramienta pedida está siendo utilizada en otro canal"@es .

