@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_InicializarCotaMaquinaConCinematicaActiva a ns1:AccionProhibida ;
    rdfs:label "Inicializar cota máquina con cinemática o transformadas activas"@es ;
    ns1:activaAlarma ns1:AvisoSeguridad_1667 ;
    ns1:textoExtracto "No se puede inicializar la cota máquina de ejes gantry o tándem. [...] SOLUCIÓN Para inicializar cota máquina en dicho eje, desactivar la cinemática o transformación activa."@es .

ns1:AvisoSeguridad_1668 a ns1:AvisoSeguridad ;
    rdfs:label "Grupo multieje fuera de rango"@es ;
    ns1:identificador "1668" ;
    ns1:textoExtracto "1668 'Grupo multieje fuera de rango' DETECCIÓN Durante la"@es .

ns1:Maquina_CNC a ns1:Maquina ;
    ns1:textoExtracto "El CNC ha intentado inicializar la cota máquina (G174) de un eje que forma parte de la cinemática activa o de las transformadas #CS, #ACS, #ANGAX, #TANGCTRL."@es .

ns1:AvisoSeguridad_1667 a ns1:AvisoSeguridad ;
    rdfs:label "G174: no se admiten ejes de la cinemática o transformadas activas"@es ;
    ns1:identificador "1667" ;
    ns1:textoExtracto "1667 'G174: no se admiten ejes de la cinemática o transformadas activas' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado inicializar la cota máquina (G174) de un eje que forma parte de la cinemática activa o de las transformadas #CS, #ACS, #ANGAX, #TANGCTRL."@es .

