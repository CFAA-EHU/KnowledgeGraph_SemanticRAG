@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_1668 a ns1:AvisoSeguridad ;
    rdfs:label "Grupo multieje fuera de rango" ;
    ns1:identificador "1668" ;
    ns1:mitigaRiesgo ns1:Maquina_CNC ;
    ns1:textoExtracto "1668 'Grupo multieje fuera de rango' DETECCIÓN Durante la ejecución. CAUSA Variable (V.)MPG.MULAXISNAMExn[grupo] o (V.)MPG.KEEPPOSxn[grupo]. El índice (grupo) no corresponde a ningún grupo multieje definido en los parámetros máquina. SOLUCIÓN Revisar la programación. Programar adecuadamente el número del grupo multieje." .

ns1:Error_1669 a ns1:AvisoSeguridad ;
    rdfs:label "Programar #ROTATEMZ1-4 Pn/+n/-n" ;
    ns1:identificador "1669" ;
    ns1:mitigaRiesgo ns1:Maquina_CNC ;
    ns1:textoExtracto "1669 'Programar #ROTATEMZ1-4 Pn/+n/-n' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación. Programar la posición a seleccionar en la torreta o el número de posiciones a girar." .

ns1:Sentencia_ROTATEMZ a ns1:Parametro ;
    rdfs:label "Sentencia #ROTATEMZ1-4" ;
    ns1:identificador "#ROTATEMZ1-4" ;
    ns1:textoExtracto "Programar #ROTATEMZ1-4 Pn/+n/-n" .

ns1:Variable_MPG_KEEPPOS a ns1:Parametro ;
    rdfs:label "Variable MPG.KEEPPOSxn[grupo]" ;
    ns1:identificador "MPG.KEEPPOSxn" ;
    ns1:textoExtracto "Variable (V.)MPG.MULAXISNAMExn[grupo] o (V.)MPG.KEEPPOSxn[grupo]." .

ns1:Variable_MPG_MULAXISNAME a ns1:Parametro ;
    rdfs:label "Variable MPG.MULAXISNAMExn[grupo]" ;
    ns1:identificador "MPG.MULAXISNAMExn" ;
    ns1:textoExtracto "Variable (V.)MPG.MULAXISNAMExn[grupo] o (V.)MPG.KEEPPOSxn[grupo]." .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC (multieje)" ;
    ns1:textoExtracto "grupo multieje definido en los parámetros máquina" .

