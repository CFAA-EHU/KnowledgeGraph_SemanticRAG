@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_CabezalesSincronizados a ns1:ComponenteMecanico ;
    rdfs:label "Cabezales sincronizados"@es ;
    ns1:activaAlarma ns1:Alarma_1672 ;
    ns1:textoExtracto "sincronización de cabezales"@es .

ns1:DiagnosticoFallo_1672 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1672: Sincronización de cabezales"@es ;
    ns1:solucionaFallo ns1:Alarma_1672 ;
    ns1:textoExtracto "CAUSA Una vez realizada la sincronización de cabezales, el CNC no permite programar una búsqueda de cero ni forzar cota en ninguno de ellos. SOLUCIÓN El CNC referencia los cabezales antes de sincronizarlos. Para realizar una nueva búsqueda de referencia o forzar la cota, desactivar la sincronización."@es .

ns1:DiagnosticoFallo_1673 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 1673: Permisos de variable"@es ;
    ns1:solucionaFallo ns1:Alarma_1673 ;
    ns1:textoExtracto "CAUSA La variable programada existe, pero no tiene permiso de acceso desde el programa o MDI, o es una variable de texto. SOLUCIÓN Consultar en los manuales los permisos de acceso de las variables."@es .

ns1:Parametro_G74_G174 a ns1:Parametro ;
    rdfs:label "Código G74-G174 (búsqueda de cero/forzar cota)"@es ;
    ns1:identificador "G74-G174" ;
    ns1:textoExtracto "programar una búsqueda de cero ni forzar cota"@es .

ns1:VariableInaccesible a ns1:Parametro ;
    rdfs:label "Variable sin permisos de acceso (programa/MDI)"@es ;
    ns1:activaAlarma ns1:Alarma_1673 ;
    ns1:textoExtracto "variable programada [...] no tiene permiso de acceso desde el programa o MDI"@es .

ns1:Alarma_1672 a ns1:Alarma ;
    rdfs:label "Alarma 1672: No se admite G74-G174 para cabezales sincronizados"@es ;
    ns1:identificador "1672" ;
    ns1:textoExtracto "'No se admite G74-G174 para cabezales sincronizados' DETECCIÓN Durante la ejecución. CAUSA Una vez realizada la sincronización de cabezales, el CNC no permite programar una búsqueda de cero ni forzar cota en ninguno de ellos. SOLUCIÓN El CNC referencia los cabezales antes de sincronizarlos. Para realizar una nueva búsqueda de referencia o forzar la cota, desactivar la sincronización."@es .

ns1:Alarma_1673 a ns1:Alarma ;
    rdfs:label "Alarma 1673: Variable no accesible por programa o MDI"@es ;
    ns1:identificador "1673" ;
    ns1:textoExtracto "'Variable no accesible por programa o MDI' DETECCIÓN Durante la ejecución. CAUSA La variable programada existe, pero no tiene permiso de acceso desde el programa o MDI, o es una variable de texto. SOLUCIÓN Consultar en los manuales los permisos de acceso de las variables."@es .

