@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1674 a ns1:Alarma ;
    rdfs:label "Alarma 1674: Error de sintaxis en programación de palpador"@es ;
    ns1:identificador "1674" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_ProgramacionIncorrectaPalpador ;
    ns1:textoExtracto "1674 'Programar #SELECT PROBE [ Nº palpador, POS/NEG]' [...] DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_1675 a ns1:Alarma ;
    rdfs:label "Alarma 1675: Variable no accesible para canal"@es ;
    ns1:identificador "1675" ;
    ns1:textoExtracto "1675 Variable no accesible para su canal. [...] DETECCIÓN Durante la ejecución. CAUSA La variable no es accesible desde el canal. SOLUCIÓN Consultar en los manuales los permisos de acceso de las variables."@es .

ns1:Alarma_1677 a ns1:Alarma ;
    rdfs:label "Alarma 1677: Desactivación de #RTCP/TLC"@es ;
    ns1:identificador "1677" ;
    ns1:textoExtracto "1677 'Se ha desactivado #RTCP/TLC' [...] DETECCIÓN Durante la ejecución."@es .

ns1:AvisoSeguridad_AccesoVariables a ns1:AvisoSeguridad ;
    rdfs:label "Restricción de acceso a variables por canal"@es ;
    ns1:documentadoEn ns1:Manual_ProgramacionCNC ;
    ns1:textoExtracto "Variable no accesible para su canal [...] Consultar en los manuales los permisos de acceso de las variables"@es .

ns1:Parametro_PlanoInclinado a ns1:Parametro ;
    rdfs:label "Plano inclinado activo"@es ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "plano inclinado que se encontraba activo al apagarlo"@es .

ns1:Parametro_RTCP_TLC a ns1:Parametro ;
    rdfs:label "Parámetro #RTCP/TLC"@es ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "Se ha desactivado #RTCP/TLC"@es .

ns1:Sensor_Palpador a ns1:Sensor ;
    rdfs:label "Palpador"@es ;
    ns1:textoExtracto "Programar #SELECT PROBE [ Nº palpador, POS/NEG]"@es .

ns1:AccionProhibida_ProgramacionIncorrectaPalpador a ns1:AccionProhibida ;
    rdfs:label "Programación incorrecta de sentencia #SELECT PROBE"@es ;
    ns1:textoExtracto "La sintaxis de la sentencia no es correcta o hay más información en el bloque."@es .

ns1:Alarma_1676 a ns1:Alarma ;
    rdfs:label "Alarma 1676: Recuperación de plano inclinado activo"@es ;
    ns1:identificador "1676" ;
    ns1:textoExtracto "1676 'Se ha recuperado el plano inclinado activo' [...] DETECCIÓN Durante la ejecución. CAUSA Tras el encendido, el CNC ha recuperado el plano inclinado que se encontraba activo al apagarlo. SOLUCIÓN El plano inclinado se puede desactivar con la sentencia #CS OFF."@es .

ns1:Manual_ProgramacionCNC a ns1:Manual ;
    rdfs:label "Manual de programación CNC"@es ;
    ns1:textoExtracto "Consultar en los manuales los permisos de acceso de las variables"@es .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:activaAlarma ns1:Alarma_1676 ;
    ns1:textoExtracto "el CNC ha recuperado el plano inclinado"@es .

