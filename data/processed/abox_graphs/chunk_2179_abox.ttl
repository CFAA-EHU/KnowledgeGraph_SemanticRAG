@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Fallo_1686 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de longitud de path en programación" ;
    ns1:identificador "1686" ;
    ns1:monitoreaParametro ns1:Parametro_PathLongitud ;
    ns1:textoExtracto "El path del fichero es demasiado largo. [...] La longitud máxima permitida para el path es de 120 caracteres." .

ns1:Fallo_1687 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en sentencia #REPOS" ;
    ns1:identificador "1687" ;
    ns1:monitoreaParametro ns1:Parametro_REPOS ;
    ns1:textoExtracto "'Programar: #REPOS <INT/INI> <secuencia de ejes/cabezales>' [...] La sentencia #REPOS está mal programada." .

ns1:Parametro_PathLongitud a ns1:Parametro ;
    rdfs:label "Longitud máxima de path" ;
    ns1:textoExtracto "La longitud máxima permitida para el path es de 120 caracteres." ;
    ns1:valor "120" .

ns1:Parametro_REPOS a ns1:Parametro ;
    rdfs:label "Sintaxis de sentencia #REPOS" ;
    ns1:textoExtracto "'Programar: #REPOS <INT/INI> <secuencia de ejes/cabezales>' [...] seguido de una secuencia de ejes y/o cabezales del canal sin un orden" ;
    ns1:valor "#REPOS <INT/INI> <secuencia de ejes/cabezales>"^^xsd:string .

