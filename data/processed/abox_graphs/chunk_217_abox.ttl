@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_EDISIMU a ns1:ModoOperacion ;
    rdfs:label "EDISIMU MODE - PROGRAM SIMULATION" ;
    ns1:textoExtracto "EDISIMU MODE. - PROGRAM SIMULATION." ;
    ns1:tieneComponente ns1:InterfazUsuario_CancelarSincronizacionCanal,
        ns1:InterfazUsuario_CompensacionRadioHerramienta,
        ns1:InterfazUsuario_LimitesSoftware,
        ns1:InterfazUsuario_OrigenesActivos,
        ns1:InterfazUsuario_ParadaCondicional,
        ns1:InterfazUsuario_SaltoBloque,
        ns1:InterfazUsuario_SincronizacionHusillos .

ns1:InterfazUsuario_CancelarSincronizacionCanal a ns1:InterfazUsuario ;
    rdfs:label "Cancel channel synchronization" ;
    ns1:textoExtracto "Cancel channel synchronization. There is one icon per channel that cancels the wait for synchronism with the channel during simulation." .

ns1:InterfazUsuario_CompensacionRadioHerramienta a ns1:InterfazUsuario ;
    rdfs:label "Tool radius compensation" ;
    ns1:textoExtracto "Tool radius compensation. Activate or cancel tool radius compensation to simulate the program." .

ns1:InterfazUsuario_LimitesSoftware a ns1:InterfazUsuario ;
    rdfs:label "Software limits" ;
    ns1:textoExtracto "Software limits. Activate or deactivate the software limits for program simulation." .

ns1:InterfazUsuario_OrigenesActivos a ns1:InterfazUsuario ;
    rdfs:label "Assume the active origins for execution" ;
    ns1:textoExtracto "Assume the active origins for execution. When starting the simulation or pressing the simulation reset, the CNC applies to the simulation the origins set in the execution environment (for example, the part zero set in jog mode)." .

ns1:InterfazUsuario_ParadaCondicional a ns1:InterfazUsuario ;
    rdfs:label "Conditional stop during simulation" ;
    ns1:textoExtracto "Conditional stop during simulation. Option to simulate the external 'conditional stop' switch. Being this option active, the CNC interrupts the simulation in the blocks where the 'M01' function is programmed." .

ns1:InterfazUsuario_SaltoBloque a ns1:InterfazUsuario ;
    rdfs:label "Block skip" ;
    ns1:textoExtracto "Block skip. Option to simulate the external 'block skip' switch. Being this option active, the CNC does not simulate the blocks containing the block-skip character '/'." .

ns1:InterfazUsuario_SincronizacionHusillos a ns1:InterfazUsuario ;
    rdfs:label "Synchronizing spindles" ;
    ns1:textoExtracto "Synchronizing spindles. There is an icon for each spindle where to indicate the spindle to synchronize with. The ·0· value cancels the synchronization." .

