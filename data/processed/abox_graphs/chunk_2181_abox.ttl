@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1693 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de programación de #RTCP con cinemática incompatible" ;
    ns1:identificador "1693" ;
    ns1:solucionaFallo ns1:Parametro_CYL,
        ns1:Parametro_FACE ;
    ns1:textoExtracto "'No se permite programar #RTCP con la actual cinemática. Programar #FACE o #CYL'" .

ns1:Fallo_1694 a ns1:DiagnosticoFallo ;
    rdfs:label "Cota fuera de rango en G174" ;
    ns1:identificador "1694" ;
    ns1:monitoreaParametro ns1:Parametro_G174 ;
    ns1:textoExtracto "Cota fuera de rango en G174." .

ns1:Parametro_RTCP a ns1:Parametro ;
    rdfs:label "Parámetro #RTCP" ;
    ns1:identificador "#RTCP" ;
    ns1:textoExtracto "#RTCP"@es .

ns1:Parametro_CYL a ns1:Parametro ;
    rdfs:label "Parámetro #CYL" ;
    ns1:identificador "#CYL" ;
    ns1:textoExtracto "#CYL"@es .

ns1:Parametro_FACE a ns1:Parametro ;
    rdfs:label "Parámetro #FACE" ;
    ns1:identificador "#FACE" ;
    ns1:textoExtracto "#FACE"@es .

ns1:Parametro_G174 a ns1:Parametro ;
    rdfs:label "Parámetro G174 (cota)" ;
    ns1:identificador "G174" ;
    ns1:textoExtracto "cota programada en G174"@es .

