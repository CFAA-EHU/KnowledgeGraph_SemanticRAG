@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_G174 a ns1:Parametro ;
    rdfs:label "Cota en G174"@es ;
    ns1:monitoreaParametro ns1:Fallo_1694 ;
    ns1:textoExtracto "Programar una cota comprendida entre los valores ±2147483647."@es ;
    ns1:valor "±2147483647" .

ns1:Sentencia_CSROT a ns1:Parametro ;
    rdfs:label "#CSROT" ;
    ns1:monitoreaParametro ns1:Fallo_1697 ;
    ns1:textoExtracto "'Programar #CSROT [ON]/OFF'"@es .

ns1:Sentencia_FACE_CYL a ns1:Parametro ;
    rdfs:label "#FACE / #CYL" ;
    ns1:textoExtracto "SOLUCIÓN Programar la sentencia #FACE ó #CYL para activar dicha transformada."@es .

ns1:Sentencia_SWTOUT a ns1:Parametro ;
    rdfs:label "#SWTOUT" ;
    ns1:monitoreaParametro ns1:Fallo_1695 ;
    ns1:textoExtracto "Programar #SWTOUT ON [<TONvalor> <,TOFvalor> <,PONvalor> <,POFvalo> <,G0/G1>] /OFF."@es .

ns1:Subrutina_FST a ns1:Componente ;
    rdfs:label "Subrutina *.fst"@es ;
    ns1:requiereMantenimiento ns1:Fallo_1696 ;
    ns1:textoExtracto "No se pueden borrar subrutinas *.fst cuando una de ellas está en ejecución."@es .

ns1:Fallo_1694 a ns1:DiagnosticoFallo ;
    rdfs:label "Cota fuera de rango en G174"@es ;
    ns1:identificador "1694" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La cota programada en G174 está fuera de rango. SOLUCIÓN Programar una cota comprendida entre los valores ±2147483647."@es .

ns1:Fallo_1695 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en #SWTOUT"@es ;
    ns1:identificador "1695" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_1696 a ns1:DiagnosticoFallo ;
    rdfs:label "Borrado de subrutina *.fst en ejecución"@es ;
    ns1:identificador "1696" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Se ha intentado borrar una subrutina fst mientras está en ejecución. SOLUCIÓN Esperar a que finaliza la ejecución del programa."@es .

ns1:Fallo_1697 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de programación en #CSROT"@es ;
    ns1:identificador "1697" ;
    ns1:textoExtracto "SOLUCIÓN Programar #CSROT [ON]/OFF. DETECCIÓN Durante la ejecución."@es .

