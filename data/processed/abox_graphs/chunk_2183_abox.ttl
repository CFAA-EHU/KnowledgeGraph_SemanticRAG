@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1697 a ns1:Alarma ;
    rdfs:label "Alarma 1697: Programar #CSROT [ON]/OFF"@es ;
    ns1:identificador "1697" ;
    ns1:monitoreaParametro ns1:Parametro_CSROT ;
    ns1:textoExtracto "'Programar #CSROT [ON]/OFF' DETECCIÓN Durante la ejecución. CAUSA La sentencia y/o alguno de sus parámetros están mal programados. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_1698 a ns1:Alarma ;
    rdfs:label "Alarma 1698: Programar #DEFROT [actuación, criterio, ángulo]"@es ;
    ns1:identificador "1698" ;
    ns1:monitoreaParametro ns1:Parametro_DEFROT_Actuacion,
        ns1:Parametro_DEFROT_Angulo,
        ns1:Parametro_DEFROT_Criterio ;
    ns1:textoExtracto "'Programar #DEFROT [actuación, criterio, ángulo]' DETECCIÓN Durante la ejecución. CAUSA La sentencia y/o alguno de sus parámetros están mal programados. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_1699 a ns1:Alarma ;
    rdfs:label "Alarma 1699: La función CSROT no es aplicable a cinemáticas con ejes manuales o Hirth"@es ;
    ns1:identificador "1699" ;
    ns1:monitoreaParametro ns1:Parametro_CSROT ;
    ns1:textoExtracto "'La función CSROT no es aplicable a cinemáticas con ejes manuales o Hirth' DETECCIÓN Durante la ejecución. CAUSA Los ejes rotativos de la cinemática tienen que ser servocontrolados de forma continua. SOLUCIÓN Desactivar la sentencia #CSROT."@es .

ns1:Alarma_1700 a ns1:Alarma ;
    rdfs:label "Alarma 1700: PUNTEADO: F = 0"@es ;
    ns1:identificador "1700" ;
    ns1:monitoreaParametro ns1:Parametro_F_Avance ;
    ns1:textoExtracto "'PUNTEADO: F = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro F tiene valor 0. No hay avance programado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Parametro_DEFROT_Actuacion a ns1:Parametro ;
    rdfs:label "Parámetro #DEFROT [actuación]"@es ;
    ns1:identificador "#DEFROT_actuacion" ;
    ns1:textoExtracto "Programar #DEFROT [actuación, criterio, ángulo]"@es .

ns1:Parametro_DEFROT_Angulo a ns1:Parametro ;
    rdfs:label "Parámetro #DEFROT [ángulo]"@es ;
    ns1:identificador "#DEFROT_angulo" ;
    ns1:textoExtracto "Programar #DEFROT [actuación, criterio, ángulo]"@es .

ns1:Parametro_DEFROT_Criterio a ns1:Parametro ;
    rdfs:label "Parámetro #DEFROT [criterio]"@es ;
    ns1:identificador "#DEFROT_criterio" ;
    ns1:textoExtracto "Programar #DEFROT [actuación, criterio, ángulo]"@es .

ns1:Parametro_F_Avance a ns1:Parametro ;
    rdfs:label "Parámetro F (avance)"@es ;
    ns1:identificador "F" ;
    ns1:textoExtracto "El parámetro F tiene valor 0. No hay avance programado."@es ;
    ns1:valor "0" .

ns1:Parametro_CSROT a ns1:Parametro ;
    rdfs:label "Parámetro #CSROT"@es ;
    ns1:identificador "#CSROT" ;
    ns1:textoExtracto "Programar #CSROT [ON]/OFF"@es .

