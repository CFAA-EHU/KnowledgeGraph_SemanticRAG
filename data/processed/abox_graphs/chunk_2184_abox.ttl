@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1701 a ns1:Alarma ;
    rdfs:label "Alarma 1701: PUNTEADO: S = 0" ;
    ns1:activaAlarma ns1:Parametro_S ;
    ns1:textoExtracto "1701 'PUNTEADO: S = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro S tiene valor 0. No hay velocidad programada." .

ns1:Alarma_1702 a ns1:Alarma ;
    rdfs:label "Alarma 1702: PUNTEADO: T = 0" ;
    ns1:activaAlarma ns1:Parametro_T ;
    ns1:textoExtracto "1702 'PUNTEADO: T = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro T tiene valor 0. No hay herramienta programada." .

ns1:Alarma_1703 a ns1:Alarma ;
    rdfs:label "Alarma 1703: PUNTEADO: P = 0" ;
    ns1:activaAlarma ns1:Parametro_P ;
    ns1:textoExtracto "1703 'PUNTEADO: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P" .

ns1:DiagnosticoFallo_Avance a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Avance no programado (F=0)" ;
    ns1:solucionaFallo ns1:Parametro_F ;
    ns1:textoExtracto "CAUSA El parámetro F tiene valor 0. No hay avance programado. SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:DiagnosticoFallo_Herramienta a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Herramienta no programada (T=0)" ;
    ns1:solucionaFallo ns1:Parametro_T ;
    ns1:textoExtracto "CAUSA El parámetro T tiene valor 0. No hay herramienta programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:DiagnosticoFallo_Velocidad a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Velocidad no programada (S=0)" ;
    ns1:solucionaFallo ns1:Parametro_S ;
    ns1:textoExtracto "CAUSA El parámetro S tiene valor 0. No hay velocidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:Parametro_F a ns1:Parametro ;
    rdfs:label "Parámetro F (avance)" ;
    ns1:textoExtracto "El parámetro F tiene valor 0. No hay avance programado." ;
    ns1:valor "0" .

ns1:Parametro_P a ns1:Parametro ;
    rdfs:label "Parámetro P" ;
    ns1:textoExtracto "El parámetro P tiene valor 0." ;
    ns1:valor "0" .

ns1:Parametro_S a ns1:Parametro ;
    rdfs:label "Parámetro S (velocidad)" ;
    ns1:textoExtracto "El parámetro S tiene valor 0. No hay velocidad programada." ;
    ns1:valor "0" .

ns1:Parametro_T a ns1:Parametro ;
    rdfs:label "Parámetro T (herramienta)" ;
    ns1:textoExtracto "El parámetro T tiene valor 0. No hay herramienta programada." ;
    ns1:valor "0" .

