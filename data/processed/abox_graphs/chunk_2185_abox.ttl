    ns1:solucionaFallo ns1:Diagnostico_1707 ;
    ns1:textoExtracto "El parámetro S tiene valor 0. No hay velocidad programada."@es ;
    ns1:valor "0" .

ns1:Parametro_T a ns1:Parametro ;
    rdfs:label "Parámetro T (herramienta)"@es ;
    ns1:solucionaFallo ns1:Diagnostico_1703,
        ns1:Diagnostico_1708 ;
    ns1:textoExtracto "El parámetro T tiene valor 0. No hay herramienta programada."@es ;
    ns1:valor "0" .

ns1:Diagnostico_1704 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1704: PUNTEADO: ALFA = 0"@es ;
    ns1:identificador "1704" ;
    ns1:textoExtracto "1704 'PUNTEADO: ALFA = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro alfa tiene valor 0. No hay ángulo programado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

