@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Diagnostico_1710 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1710: TALADRADO 2: F = 0"@es ;
    ns1:identificador "1710" ;
    ns1:textoExtracto "1710 'TALADRADO 2: F = 0' DETECCIÓN Durante la ejecución del ciclo."@es .

ns1:Parametro_Alfa a ns1:Parametro ;
    rdfs:label "Parámetro alfa (ángulo)"@es ;
    ns1:solucionaFallo ns1:Diagnostico_1704 ;
    ns1:textoExtracto "El parámetro alfa tiene valor 0. No hay ángulo programado."@es ;
    ns1:valor "0" .

ns1:Parametro_Diametro a ns1:Parametro ;
    rdfs:label "Parámetro diámetro"@es ;
    ns1:solucionaFallo ns1:Diagnostico_1705 ;
    ns1:textoExtracto "El parámetro para definir el diámetro tiene valor 0."@es ;
    ns1:valor "0" .

ns1:Parametro_F_Taladrado1 a ns1:Parametro ;
    rdfs:label "Parámetro F (avance en taladrado 1)"@es ;
    ns1:solucionaFallo ns1:Diagnostico_1706 ;
    ns1:textoExtracto "El parámetro F tiene valor 0. No hay avance programado."@es ;
    ns1:valor "0" .

ns1:Parametro_F_Taladrado2 a ns1:Parametro ;
    rdfs:label "Parámetro F (avance en taladrado 2)"@es ;
    ns1:textoExtracto "TALADRADO 2: F = 0"@es ;
    ns1:valor "0" .

ns1:Parametro_P_Punteado a ns1:Parametro ;
    rdfs:label "Parámetro P (profundidad en punteado)"@es ;
    ns1:solucionaFallo ns1:Diagnostico_1703,
        ns1:Diagnostico_1709 ;
    ns1:textoExtracto "El parámetro P tiene valor 0. No hay profundidad programada."@es ;
    ns1:valor "0" .

ns1:Parametro_S_Taladrado1 a ns1:Parametro ;
