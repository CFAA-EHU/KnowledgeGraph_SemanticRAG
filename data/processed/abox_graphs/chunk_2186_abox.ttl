@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Par_metroF a ns1:Parametro ;
    ns1:identificador "F" ;
    ns1:textoExtracto "El parámetro F tiene valor 0. No hay avance programado. SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:Par_metroP a ns1:Parametro ;
    ns1:identificador "P" ;
    ns1:textoExtracto "El parámetro P tiene valor 0. No hay profundidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:Par_metroS a ns1:Parametro ;
    ns1:identificador "S" ;
    ns1:textoExtracto "El parámetro S tiene valor 0. No hay velocidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:Par_metroT a ns1:Parametro ;
    ns1:identificador "T" ;
    ns1:textoExtracto "El parámetro T tiene valor 0. No hay herramienta programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

