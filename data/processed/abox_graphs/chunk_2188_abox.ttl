@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_Escariado a ns1:ModoOperacion ;
    rdfs:label "Modo de operación: Escariado"@es ;
    ns1:requiereMantenimiento ns1:DiagnosticoFallo_1720_Avance,
        ns1:DiagnosticoFallo_1720_Velocidad,
        ns1:DiagnosticoFallo_1721_Herramienta,
        ns1:DiagnosticoFallo_1722_Profundidad ;
    ns1:textoExtracto "ESCARIADO"@es .

ns1:DiagnosticoFallo_1720_Avance a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1720: Escariado sin avance programado"@es ;
    ns1:identificador "1720" ;
    ns1:solucionaFallo ns1:Parametro_F_1720 ;
    ns1:textoExtracto "1720 'ESCARIADO: S = 0' [...] CAUSA El parámetro F tiene valor 0. No hay avance programado."@es .

ns1:DiagnosticoFallo_1720_Velocidad a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1720: Escariado sin velocidad programada"@es ;
    ns1:identificador "1720" ;
    ns1:solucionaFallo ns1:Parametro_S_1720 ;
    ns1:textoExtracto "1720 'ESCARIADO: S = 0' [...] CAUSA El parámetro S tiene valor 0. No hay velocidad programada."@es .

ns1:DiagnosticoFallo_1721_Herramienta a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1721: Escariado sin herramienta programada"@es ;
    ns1:identificador "1721" ;
    ns1:solucionaFallo ns1:Parametro_T_1721 ;
    ns1:textoExtracto "1721 'ESCARIADO: T = 0' [...] CAUSA El parámetro T tiene valor 0. No hay herramienta programada."@es .

ns1:DiagnosticoFallo_1722_Profundidad a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1722: Escariado sin profundidad programada"@es ;
    ns1:identificador "1722" ;
    ns1:solucionaFallo ns1:Parametro_P_1722 ;
    ns1:textoExtracto "1722 'ESCARIADO: P = 0' [...] CAUSA El parámetro P tiene valor 0. No hay profundidad programada."@es .

ns1:Parametro_F_1720 a ns1:Parametro ;
    rdfs:label "Parámetro F (avance)"@es ;
    ns1:identificador "F" ;
    ns1:textoExtracto "El parámetro F tiene valor 0. No hay avance programado."@es ;
    ns1:valor "0" .

ns1:Parametro_P_1722 a ns1:Parametro ;
    rdfs:label "Parámetro P (profundidad)"@es ;
    ns1:identificador "P" ;
    ns1:textoExtracto "El parámetro P tiene valor 0. No hay profundidad programada."@es ;
    ns1:valor "0" .

ns1:Parametro_S_1720 a ns1:Parametro ;
    rdfs:label "Parámetro S (velocidad)"@es ;
    ns1:identificador "S" ;
    ns1:textoExtracto "El parámetro S tiene valor 0. No hay velocidad programada."@es ;
    ns1:valor "0" .

ns1:Parametro_T_1721 a ns1:Parametro ;
    rdfs:label "Parámetro T (herramienta)"@es ;
    ns1:identificador "T" ;
    ns1:textoExtracto "El parámetro T tiene valor 0. No hay herramienta programada."@es ;
    ns1:valor "0" .

