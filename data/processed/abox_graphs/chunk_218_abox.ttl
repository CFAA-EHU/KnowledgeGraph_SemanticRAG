@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MenuHorizontal a ns1:InterfazUsuario ;
    rdfs:label "Horizontal menu"@en ;
    ns1:textoExtracto "the horizontal menu"@en ;
    ns1:tieneComponente ns1:EXBLK_Softkey .

ns1:ModoSimulacionBloques a ns1:ModoOperacion ;
    rdfs:label "Execute Blocks Separately Mode"@en ;
    ns1:habilitadoPor ns1:EXBLK_Softkey ;
    ns1:textoExtracto "Being this option active, every time the START icon key is pressed, it only simulates the block selected in the active program."@en .

ns1:START_IconKey a ns1:InterfazUsuario ;
    rdfs:label "START icon key"@en ;
    ns1:textoExtracto "every time the START icon key is pressed, it only simulates the block selected in the active program."@en .

ns1:EXBLK_Softkey a ns1:InterfazUsuario ;
    rdfs:label "EXBLK softkey"@en ;
    ns1:textoExtracto "Press the 'EXBLK' softkey of the horizontal menu."@en .

