@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1732 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Velocidad no programada en mandrinado 2"@es ;
    ns1:solucionaFallo ns1:Parametro_1732 ;
    ns1:textoExtracto "1732 'MANDRINADO 2: S = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro S tiene valor 0. No hay velocidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:DiagnosticoFallo_1733 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Herramienta no programada en mandrinado 2"@es ;
    ns1:solucionaFallo ns1:Parametro_1733 ;
    ns1:textoExtracto "1733 'MANDRINADO 2: T = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro T tiene valor 0. No hay herramienta programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:DiagnosticoFallo_1734 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Profundidad no programada en mandrinado 2"@es ;
    ns1:solucionaFallo ns1:Parametro_1734 ;
    ns1:textoExtracto "1734 'MANDRINADO 2: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:DiagnosticoFallo_1735 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Avance no programado en cajera rectangular"@es ;
    ns1:solucionaFallo ns1:Parametro_1735 ;
    ns1:textoExtracto "1735 'CAJERA RECTANGULAR: F = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:DiagnosticoFallo_1736 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Velocidad no programada en cajera rectangular"@es ;
    ns1:solucionaFallo ns1:Parametro_1736 ;
    ns1:textoExtracto "1736 'CAJERA RECTANGULAR: S = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:DiagnosticoFallo_1737 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Herramienta no programada en cajera rectangular"@es ;
    ns1:solucionaFallo ns1:Parametro_1737 ;
    ns1:textoExtracto "1737 'CAJERA RECTANGULAR: T = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada. SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado."@es .

ns1:ModoOperacion_CajeraRectangular a ns1:ModoOperacion ;
    rdfs:label "Modo de operación: Cajera rectangular"@es ;
    ns1:requiereMantenimiento ns1:Herramienta_Acabado_Cajera,
        ns1:Herramienta_Desbaste_Cajera ;
    ns1:textoExtracto "CAJERA RECTANGULAR: F = 0 [...] CAJERA RECTANGULAR: S = 0 [...] CAJERA RECTANGULAR: T = 0"@es .

ns1:ModoOperacion_Mandrinado2 a ns1:ModoOperacion ;
    rdfs:label "Modo de operación: Mandrinado 2"@es ;
    ns1:textoExtracto "MANDRINADO 2: S = 0 [...] MANDRINADO 2: T = 0 [...] MANDRINADO 2: P = 0"@es .

ns1:Herramienta_Acabado_Cajera a ns1:Herramienta ;
    rdfs:label "Herramienta para operación de acabado en cajera rectangular"@es ;
    ns1:textoExtracto "Programar una herramienta para la operación de desbaste o acabado."@es .

ns1:Herramienta_Desbaste_Cajera a ns1:Herramienta ;
    rdfs:label "Herramienta para operación de desbaste en cajera rectangular"@es ;
    ns1:textoExtracto "Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta."@es .

ns1:Parametro_1732 a ns1:Parametro ;
    rdfs:label "Parámetro S (velocidad) en mandrinado 2"@es ;
    ns1:identificador "1732" ;
    ns1:textoExtracto "1732 'MANDRINADO 2: S = 0' [...] CAUSA El parámetro S tiene valor 0. No hay velocidad programada."@es ;
    ns1:valor "0" .

ns1:Parametro_1733 a ns1:Parametro ;
    rdfs:label "Parámetro T (herramienta) en mandrinado 2"@es ;
    ns1:identificador "1733" ;
    ns1:textoExtracto "1733 'MANDRINADO 2: T = 0' [...] CAUSA El parámetro T tiene valor 0. No hay herramienta programada."@es ;
    ns1:valor "0" .

ns1:Parametro_1734 a ns1:Parametro ;
    rdfs:label "Parámetro P (profundidad) en mandrinado 2"@es ;
    ns1:identificador "1734" ;
    ns1:textoExtracto "1734 'MANDRINADO 2: P = 0' [...] CAUSA El parámetro P tiene valor 0. No hay profundidad programada."@es ;
    ns1:valor "0" .

ns1:Parametro_1735 a ns1:Parametro ;
    rdfs:label "Parámetro F (avance) en cajera rectangular"@es ;
    ns1:identificador "1735" ;
    ns1:textoExtracto "1735 'CAJERA RECTANGULAR: F = 0' [...] CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z."@es ;
    ns1:valor "0" .

ns1:Parametro_1736 a ns1:Parametro ;
    rdfs:label "Parámetro S (velocidad) en cajera rectangular"@es ;
    ns1:identificador "1736" ;
    ns1:textoExtracto "1736 'CAJERA RECTANGULAR: S = 0' [...] CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado."@es ;
    ns1:valor "0" .

ns1:Parametro_1737 a ns1:Parametro ;
    rdfs:label "Parámetro T (herramienta) en cajera rectangular"@es ;
    ns1:identificador "1737" ;
    ns1:textoExtracto "1737 'CAJERA RECTANGULAR: T = 0' [...] CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada."@es ;
    ns1:valor "0" .

