@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Herramienta_Acabado a ns1:Herramienta ;
    rdfs:label "Herramienta de acabado"@es ;
    ns1:solucionaFallo ns1:Fallo_1741 ;
    ns1:textoExtracto "herramienta de mayor diámetro para la pasada de acabado"@es .

ns1:Herramienta_Desbaste a ns1:Herramienta ;
    rdfs:label "Herramienta de desbaste"@es ;
    ns1:solucionaFallo ns1:Fallo_1740 ;
    ns1:textoExtracto "herramienta de diámetro mayor"@es .

ns1:Herramienta_Programada a ns1:Herramienta ;
    rdfs:label "Herramienta programada (T)"@es ;
    ns1:solucionaFallo ns1:Fallo_1744 ;
    ns1:textoExtracto "Programar una herramienta para la operación de desbaste o acabado"@es .

ns1:Parametro_Avance_F a ns1:Parametro ;
    rdfs:label "Avance (F)"@es ;
    ns1:identificador "F" ;
    ns1:monitoreaParametro ns1:Fallo_1742 ;
    ns1:textoExtracto "parámetro F"@es ;
    ns1:valor "0" .

ns1:Parametro_DemasiasParedes a ns1:Parametro ;
    rdfs:label "Demasías en paredes laterales (δ)"@es ;
    ns1:identificador "δ" ;
    ns1:monitoreaParametro ns1:Fallo_1741 ;
    ns1:textoExtracto "parámetro δ"@es .

ns1:Parametro_DimensionCajera_H a ns1:Parametro ;
    rdfs:label "Dimensión H de cajera rectangular"@es ;
    ns1:identificador "H" ;
    ns1:monitoreaParametro ns1:Fallo_1740 ;
    ns1:textoExtracto "parámetros L ó H"@es .

ns1:Parametro_DimensionCajera_L a ns1:Parametro ;
    rdfs:label "Dimensión L de cajera rectangular"@es ;
    ns1:identificador "L" ;
    ns1:monitoreaParametro ns1:Fallo_1740 ;
    ns1:textoExtracto "parámetros L ó H"@es .

ns1:Parametro_Herramienta_T a ns1:Parametro ;
    rdfs:label "Herramienta (T)"@es ;
    ns1:identificador "T" ;
    ns1:monitoreaParametro ns1:Fallo_1744 ;
    ns1:textoExtracto "parámetro T"@es ;
    ns1:valor "0" .

ns1:Parametro_PasoFresado a ns1:Parametro ;
    rdfs:label "Paso de fresado (Δ)"@es ;
    ns1:identificador "Δ" ;
    ns1:monitoreaParametro ns1:Fallo_1740 ;
    ns1:textoExtracto "parámetro Δ"@es .

ns1:Parametro_Velocidad_S a ns1:Parametro ;
    rdfs:label "Velocidad (S)"@es ;
    ns1:identificador "S" ;
    ns1:monitoreaParametro ns1:Fallo_1743 ;
    ns1:textoExtracto "parámetro S"@es ;
    ns1:valor "0" .

ns1:Fallo_1742 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA PREVACIADA: F = 0"@es ;
    ns1:identificador "1742" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Fallo_1743 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA PREVACIADA: S = 0"@es ;
    ns1:identificador "1743" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Fallo_1741 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA RECTANGULAR: Diámetro de herramienta ACABADO menor que delta"@es ;
    ns1:identificador "1741" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El diámetro de la herramienta de acabado es menor que las demasías en las paredes laterales (parámetro δ). SOLUCIÓN Elegir una herramienta de mayor diámetro para la pasada de acabado."@es .

ns1:Fallo_1744 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA PREVACIADA: T = 0"@es ;
    ns1:identificador "1744" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada. SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado. Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta."@es .

ns1:Fallo_1740 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA RECTANGULAR: Diámetro de herramienta mayor que cajera"@es ;
    ns1:identificador "1740" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA En la operación de desbaste o acabado, el diámetro de la herramienta es mayor que las dimensiones de la cajera (parámetros L ó H). SOLUCIÓN Elegir una herramienta de menor diámetro."@es .

