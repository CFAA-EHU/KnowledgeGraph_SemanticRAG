@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error1746 a ns1:AvisoSeguridad ;
    rdfs:label "CAJERA PREVACIADA: Diámetro de herramienta menor que DELTA" ;
    ns1:identificador "1746" ;
    ns1:textoExtracto "1746 'CAJERA PREVACIADA: Diámetro de herramienta menor que DELTA' DETECCIÓN Durante la ejecución del ciclo." .

ns1:HerramientaDesbasteAcabado a ns1:Herramienta ;
    rdfs:label "Herramienta para desbaste o acabado" ;
    ns1:requiereMantenimiento ns1:OperacionAcabado,
        ns1:OperacionDesbaste ;
    ns1:textoExtracto "No hay herramienta programada. SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado." .

ns1:ParametroP a ns1:Parametro ;
    rdfs:label "Parámetro P (profundidad)" ;
    ns1:monitoreaParametro ns1:Error1745 ;
    ns1:textoExtracto "El parámetro P tiene valor 0. No hay profundidad programada." ;
    ns1:valor "0" .

ns1:SolucionError1745 a ns1:DiagnosticoFallo ;
    rdfs:label "Solución para error 1745 (P=0)" ;
    ns1:solucionaFallo ns1:Error1745 ;
    ns1:textoExtracto "Asignar al parámetro un valor mayor que 0." .

ns1:SolucionHerramientaFaltante a ns1:DiagnosticoFallo ;
    rdfs:label "Solución para falta de herramienta" ;
    ns1:solucionaFallo ns1:OperacionAcabado,
        ns1:OperacionDesbaste ;
    ns1:textoExtracto "Programar una herramienta para la operación de desbaste o acabado." .

ns1:Error1745 a ns1:AvisoSeguridad ;
    rdfs:label "CAJERA PREVACIADA: P = 0" ;
    ns1:identificador "1745" ;
    ns1:textoExtracto "1745 'CAJERA PREVACIADA: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada." .

ns1:OperacionAcabado a ns1:TareaMantenimiento ;
    rdfs:label "Operación de acabado" ;
    ns1:textoExtracto "Programar una herramienta para la operación de desbaste o acabado." .

ns1:OperacionDesbaste a ns1:TareaMantenimiento ;
    rdfs:label "Operación de desbaste" ;
    ns1:textoExtracto "Programar una herramienta para la operación de desbaste o acabado." .

