@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1747 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA PREVACIADA: Diámetro de herramienta mayor que cajera"@es ;
    ns1:identificador "1747" ;
    ns1:textoExtracto "Durante la ejecución del ciclo. CAUSA: En la operación de desbaste o acabado, el diámetro de la herramienta es mayor que las dimensiones de la cajera (parámetros L ó H). SOLUCIÓN: Elegir una herramienta de menor diámetro."@es .

ns1:Herramienta_Acabado a ns1:Herramienta ;
    rdfs:label "Herramienta de acabado"@es ;
    ns1:solucionaFallo ns1:Fallo_1748 ;
    ns1:textoExtracto "Elegir una herramienta de mayor diámetro para la pasada de acabado"@es .

ns1:Herramienta_Desbaste a ns1:Herramienta ;
    rdfs:label "Herramienta de desbaste"@es ;
    ns1:solucionaFallo ns1:Fallo_1746 ;
    ns1:textoExtracto "utilizar una herramienta de diámetro mayor"@es .

ns1:Parametro_Delta a ns1:Parametro ;
    rdfs:label "Paso de fresado (Δ)"@es ;
    ns1:monitoreaParametro ns1:Fallo_1746,
        ns1:Fallo_1748 ;
    ns1:textoExtracto "parámetro Δ (paso de fresado)"@es .

ns1:Parametro_F a ns1:Parametro ;
    rdfs:label "Avance (F)"@es ;
    ns1:monitoreaParametro ns1:Fallo_1750 ;
    ns1:textoExtracto "parámetro F (avance de desbaste, acabado o profundización en Z)"@es .

ns1:Parametro_R a ns1:Parametro ;
    rdfs:label "Radio de cajera (R)"@es ;
    ns1:monitoreaParametro ns1:Fallo_1749 ;
    ns1:textoExtracto "parámetro R (radio de la cajera)"@es .

ns1:Parametro_S a ns1:Parametro ;
    rdfs:label "Velocidad de husillo (S)"@es ;
    ns1:monitoreaParametro ns1:Fallo_1751 ;
    ns1:textoExtracto "parámetro S"@es .

ns1:Parametro_r a ns1:Parametro ;
    rdfs:label "Radio de prevaciado (r)"@es ;
    ns1:monitoreaParametro ns1:Fallo_1749 ;
    ns1:textoExtracto "parámetro r (radio de prevaciado)"@es .

ns1:Fallo_1750 a ns1:DiagnosticoFallo ;
    rdfs:label "MOYU RECTANGULAR: F = 0"@es ;
    ns1:identificador "1750" ;
    ns1:textoExtracto "Durante la ejecución del ciclo. CAUSA: Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z. SOLUCIÓN: Asignar al parámetro un valor mayor que 0."@es .

ns1:Fallo_1751 a ns1:DiagnosticoFallo ;
    rdfs:label "MOYU RECTANGULAR: S = 0"@es ;
    ns1:identificador "1751" ;
    ns1:textoExtracto "Durante la ejecución del ciclo."@es .

ns1:Fallo_1746 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA PREVACIADA: Diámetro de herramienta menor que DELTA"@es ;
    ns1:identificador "1746" ;
    ns1:textoExtracto "Durante la ejecución del ciclo. CAUSA: En la operación de desbaste o acabado, el diámetro de la herramienta es menor que el paso de fresado (parámetro Δ). SOLUCIÓN: Reducir el paso de fresado o utilizar una herramienta de diámetro mayor."@es .

ns1:Fallo_1748 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA PREVACIADA: Diámetro de herramienta ACABADO menor que delta"@es ;
    ns1:identificador "1748" ;
    ns1:textoExtracto "Durante la ejecución del ciclo. CAUSA: El diámetro de la herramienta de acabado es menor que las demasías en las paredes laterales (parámetro δ). SOLUCIÓN: Elegir una herramienta de mayor diámetro para la pasada de acabado."@es .

ns1:Fallo_1749 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA PREVACIADA: R < r"@es ;
    ns1:identificador "1749" ;
    ns1:textoExtracto "Durante la ejecución del ciclo. CAUSA: El radio de la cajera (parámetro R) es menor que el radio de prevaciado (parámetro r). SOLUCIÓN: El radio de la cajera (radio exterior) debe ser mayor que el radio de prevaciado (radio interior)."@es .

