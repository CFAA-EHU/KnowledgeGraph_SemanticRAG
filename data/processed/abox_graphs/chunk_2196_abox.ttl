@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_ParametroF_1750 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Parámetro F = 0 (avance no programado)"@es ;
    ns1:identificador "1750" ;
    ns1:monitoreaParametro ns1:Parametro_F_Avance ;
    ns1:textoExtracto "CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Fallo_ParametroS_1751 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Parámetro S = 0 (velocidad no programada)"@es ;
    ns1:identificador "1751" ;
    ns1:monitoreaParametro ns1:Parametro_S_Velocidad ;
    ns1:textoExtracto "CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Fallo_ParametroT_1752 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Parámetro T = 0 (herramienta no programada)"@es ;
    ns1:identificador "1752" ;
    ns1:monitoreaParametro ns1:Parametro_T_Herramienta ;
    ns1:requiereConsumible ns1:Herramienta_MoyuRectangular ;
    ns1:textoExtracto "CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada. SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado."@es .

ns1:Herramienta_MoyuRectangular a ns1:Herramienta ;
    rdfs:label "Herramienta para operación de moyu rectangular"@es ;
    ns1:textoExtracto "Programar una herramienta para la operación de desbaste o acabado"@es .

ns1:Parametro_F_Avance a ns1:Parametro ;
    rdfs:label "Parámetro F (avance en Z)"@es ;
    ns1:identificador "F" ;
    ns1:textoExtracto "parámetro F [...] avance de desbaste, acabado o profundización en Z"@es ;
    ns1:valor "0" .

ns1:Parametro_S_Velocidad a ns1:Parametro ;
    rdfs:label "Parámetro S (velocidad)"@es ;
    ns1:identificador "S" ;
    ns1:textoExtracto "parámetro S [...] velocidad para el desbaste o acabado"@es ;
    ns1:valor "0" .

ns1:Parametro_T_Herramienta a ns1:Parametro ;
    rdfs:label "Parámetro T (herramienta)"@es ;
    ns1:identificador "T" ;
    ns1:textoExtracto "parámetro T [...] operaciones de desbaste y acabado"@es ;
    ns1:valor "0" .

