@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Herramienta_Acabado_1761 a ns1:Herramienta ;
    rdfs:label "Herramienta de acabado"@es ;
    ns1:textoExtracto "El diámetro de la herramienta de acabado es menor que las demasías en las paredes laterales."@es .

ns1:Herramienta_Desbaste_1761 a ns1:Herramienta ;
    rdfs:label "Herramienta de desbaste"@es ;
    ns1:textoExtracto "En la operación de desbaste o acabado, el diámetro de la herramienta es menor que el paso de fresado."@es .

ns1:ModoOperacion_MOYU_Circular a ns1:ModoOperacion ;
    rdfs:label "Modo de operación MOYU CIRCULAR"@es ;
    ns1:requiereMantenimiento ns1:AvisoSeguridad_1759,
        ns1:AvisoSeguridad_1760,
        ns1:AvisoSeguridad_1761,
        ns1:AvisoSeguridad_1762 ;
    ns1:textoExtracto "operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta."@es .

ns1:ModoOperacion_Planeado a ns1:ModoOperacion ;
    rdfs:label "Modo de operación PLANEADO"@es ;
    ns1:requiereMantenimiento ns1:AvisoSeguridad_1763,
        ns1:AvisoSeguridad_1764,
        ns1:AvisoSeguridad_1765 ;
    ns1:textoExtracto "Detección durante la ejecución del ciclo de planeado."@es .

ns1:AvisoSeguridad_1759 a ns1:AvisoSeguridad ;
    rdfs:label "MOYU CIRCULAR: P = 0"@es ;
    ns1:identificador "1759" ;
    ns1:monitoreaParametro ns1:Parametro_P_1759 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:AvisoSeguridad_1760 a ns1:AvisoSeguridad ;
    rdfs:label "MOYU CIRCULAR: R = 0"@es ;
    ns1:identificador "1760" ;
    ns1:monitoreaParametro ns1:Parametro_R_1760 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro R tiene valor 0. No hay radio programado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:AvisoSeguridad_1761 a ns1:AvisoSeguridad ;
    rdfs:label "MOYU CIRCULAR: Diámetro de herramienta menor que DELTA"@es ;
    ns1:identificador "1761" ;
    ns1:monitoreaParametro ns1:Parametro_Delta_1761 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA En la operación de desbaste o acabado, el diámetro de la herramienta es menor que el paso de fresado (parámetro Δ). SOLUCIÓN Reducir el paso de fresado o utilizar una herramienta de diámetro mayor."@es .

ns1:AvisoSeguridad_1762 a ns1:AvisoSeguridad ;
    rdfs:label "MOYU CIRCULAR: Diámetro de herramienta ACABADO menor que delta"@es ;
    ns1:identificador "1762" ;
    ns1:monitoreaParametro ns1:Parametro_DeltaAcabado_1762 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El diámetro de la herramienta de acabado es menor que las demasías en las paredes laterales (parámetro δ). SOLUCIÓN Elegir una herramienta de mayor diámetro para la pasada de acabado."@es .

ns1:AvisoSeguridad_1763 a ns1:AvisoSeguridad ;
    rdfs:label "PLANEADO: F = 0"@es ;
    ns1:identificador "1763" ;
    ns1:monitoreaParametro ns1:Parametro_F_1763 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:AvisoSeguridad_1764 a ns1:AvisoSeguridad ;
    rdfs:label "PLANEADO: S = 0"@es ;
    ns1:identificador "1764" ;
    ns1:monitoreaParametro ns1:Parametro_S_1764 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:AvisoSeguridad_1765 a ns1:AvisoSeguridad ;
    rdfs:label "PLANEADO: T = 0"@es ;
    ns1:identificador "1765" ;
    ns1:monitoreaParametro ns1:Parametro_T_1765 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro T tiene valor 0."@es .

ns1:Parametro_DeltaAcabado_1762 a ns1:Parametro ;
    rdfs:label "Parámetro δ (demasías en paredes laterales)"@es ;
    ns1:identificador "δ" ;
    ns1:textoExtracto "El diámetro de la herramienta de acabado es menor que las demasías en las paredes laterales (parámetro δ)."@es .

ns1:Parametro_Delta_1761 a ns1:Parametro ;
    rdfs:label "Parámetro Δ (paso de fresado)"@es ;
    ns1:identificador "Δ" ;
    ns1:textoExtracto "El diámetro de la herramienta es menor que el paso de fresado (parámetro Δ)."@es .

ns1:Parametro_F_1763 a ns1:Parametro ;
    rdfs:label "Parámetro F (avance)"@es ;
    ns1:identificador "F" ;
    ns1:textoExtracto "Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z."@es ;
    ns1:valor "0" .

ns1:Parametro_P_1759 a ns1:Parametro ;
    rdfs:label "Parámetro P (profundidad)"@es ;
    ns1:identificador "P" ;
    ns1:textoExtracto "El parámetro P tiene valor 0. No hay profundidad programada."@es ;
    ns1:valor "0" .

ns1:Parametro_R_1760 a ns1:Parametro ;
    rdfs:label "Parámetro R (radio)"@es ;
    ns1:identificador "R" ;
    ns1:textoExtracto "El parámetro R tiene valor 0. No hay radio programado."@es ;
    ns1:valor "0" .

ns1:Parametro_S_1764 a ns1:Parametro ;
    rdfs:label "Parámetro S (velocidad)"@es ;
    ns1:identificador "S" ;
    ns1:textoExtracto "Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado."@es ;
    ns1:valor "0" .

ns1:Parametro_T_1765 a ns1:Parametro ;
    rdfs:label "Parámetro T (herramienta)"@es ;
    ns1:identificador "T" ;
    ns1:textoExtracto "Algún parámetro T tiene valor 0."@es ;
    ns1:valor "0" .

