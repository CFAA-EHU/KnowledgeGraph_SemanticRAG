@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_TablasUsuario a ns1:InterfazUsuario ;
    rdfs:label "User Tables Interface"@en ;
    ns1:textoExtracto "Softkey descriptions for USER TABLES section: Change units, initialize table, search values, access other channels, select axes, save/restore values, print tables."@en ;
    ns1:tieneComponente ns1:Softkey_Buscar,
        ns1:Softkey_Canales,
        ns1:Softkey_Ejes,
        ns1:Softkey_Guardar,
        ns1:Softkey_Imprimir,
        ns1:Softkey_Inicializar,
        ns1:Softkey_Restaurar,
        ns1:Softkey_Unidades .

ns1:Softkey_Buscar a ns1:Componente ;
    rdfs:label "Search Softkey"@en ;
    ns1:textoExtracto "Search a text or a value in the table."@en .

ns1:Softkey_Canales a ns1:Componente ;
    rdfs:label "Channels Softkey"@en ;
    ns1:textoExtracto "Accessing the tables of other channels. With some tables, only the data of the active channel are displayed, this softkey is used to show the tables of the other channels. This softkey will only be available when using channels."@en .

ns1:Softkey_Ejes a ns1:Componente ;
    rdfs:label "Axes Softkey"@en ;
    ns1:textoExtracto "Select the axes to be displayed in the tables. When using several channels, only those axes assigned to the active channel may be accessed."@en .

ns1:Softkey_Guardar a ns1:Componente ;
    rdfs:label "Save Softkey"@en ;
    ns1:textoExtracto "Save the values of the table into a file."@en .

ns1:Softkey_Imprimir a ns1:Componente ;
    rdfs:label "Print Softkey"@en ;
    ns1:textoExtracto "Print the table in the pre-determined printer or save it as a file (prn format) at the CNC."@en .

ns1:Softkey_Inicializar a ns1:Componente ;
    rdfs:label "Initialize Softkey"@en ;
    ns1:textoExtracto "Initialize the table. Reset all the table data to '0'."@en .

ns1:Softkey_Restaurar a ns1:Componente ;
    rdfs:label "Restore Softkey"@en ;
    ns1:textoExtracto "Restore the values of the table previously saved into a file."@en .

ns1:Softkey_Unidades a ns1:Componente ;
    rdfs:label "Units Softkey"@en ;
    ns1:textoExtracto "Change the units for data display (mm or inches). For programming, the CNC assumes the units defined with the active function G70 or G71, or, when not programmed, the units set by the machine manufacturer (INCHES parameter)."@en .

