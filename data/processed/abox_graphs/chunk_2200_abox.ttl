@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_Parametro_S a ns1:AvisoSeguridad ;
    rdfs:label "Aviso: Parámetro S con valor 0" ;
    ns1:mitigaRiesgo ns1:Parametro_S ;
    ns1:textoExtracto "Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado. SOLUCIÓN Asignar al parámetro un valor mayor que 0." .

ns1:DiagnosticoFallo_1765 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1765: 'PLANEADO: T = 0'" ;
    ns1:identificador "1765" ;
    ns1:requiereConsumible ns1:Herramienta_Desbaste_Acabado ;
    ns1:solucionaFallo ns1:Parametro_T ;
    ns1:textoExtracto "1765 'PLANEADO: T = 0' [...] CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada." .

ns1:DiagnosticoFallo_1766 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1766: 'PLANEADO: P = 0'" ;
    ns1:identificador "1766" ;
    ns1:solucionaFallo ns1:Parametro_P ;
    ns1:textoExtracto "1766 'PLANEADO: P = 0' [...] CAUSA El parámetro P tiene valor 0." .

ns1:Herramienta_Desbaste_Acabado a ns1:Herramienta ;
    rdfs:label "Herramienta para desbaste o acabado" ;
    ns1:textoExtracto "Programar una herramienta para la operación de desbaste o acabado. Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta." .

ns1:Parametro_P a ns1:Parametro ;
    rdfs:label "Parámetro P" ;
    ns1:identificador "P" ;
    ns1:textoExtracto "El parámetro P tiene valor 0." ;
    ns1:valor "0" .

ns1:Parametro_S a ns1:Parametro ;
    rdfs:label "Parámetro S" ;
    ns1:textoExtracto "Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado." ;
    ns1:valor "0" .

ns1:Parametro_T a ns1:Parametro ;
    rdfs:label "Parámetro T" ;
    ns1:identificador "T" ;
    ns1:textoExtracto "El parámetro T de las operaciones de desbaste y acabado tiene valor 0." ;
    ns1:valor "0" .

