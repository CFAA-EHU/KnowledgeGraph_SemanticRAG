@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1766 a ns1:DiagnosticoFallo ;
    rdfs:label "PLANEADO: P = 0"@es ;
    ns1:identificador "1766" ;
    ns1:solucionaFallo ns1:Parametro_P_Profundidad ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Fallo_1767 a ns1:DiagnosticoFallo ;
    rdfs:label "PLANEADO: L = 0 y H = 0"@es ;
    ns1:identificador "1767" ;
    ns1:solucionaFallo ns1:Parametro_H_Anchura,
        ns1:Parametro_L_Longitud ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA La longitud (parámetro L) y/o la anchura del planeado (parámetro H) son 0. SOLUCIÓN Definir ambas dimensiones del planeado con un valor distinto de cero."@es .

ns1:Fallo_1768 a ns1:DiagnosticoFallo ;
    rdfs:label "PERFIL DE PUNTOS: F = 0"@es ;
    ns1:identificador "1768" ;
    ns1:solucionaFallo ns1:Parametro_F_Avance ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Fallo_1769 a ns1:DiagnosticoFallo ;
    rdfs:label "PERFIL DE PUNTOS: S = 0"@es ;
    ns1:identificador "1769" ;
    ns1:solucionaFallo ns1:Parametro_S_Velocidad ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Fallo_1770 a ns1:DiagnosticoFallo ;
    rdfs:label "PERFIL DE PUNTOS: T = 0"@es ;
    ns1:identificador "1770" ;
    ns1:requiereConsumible ns1:Herramienta_Operacion ;
    ns1:solucionaFallo ns1:Parametro_T_Herramienta ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada. SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado. Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta."@es .

ns1:Fallo_1771 a ns1:DiagnosticoFallo ;
    rdfs:label "PERFIL DE PUNTOS: P = 0"@es ;
    ns1:identificador "1771" ;
    ns1:solucionaFallo ns1:Parametro_P_Profundidad ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Herramienta_Operacion a ns1:Herramienta ;
    rdfs:label "Herramienta para operación de desbaste/acabado"@es ;
    ns1:textoExtracto "Programar una herramienta para la operación de desbaste o acabado. Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta."@es .

ns1:Parametro_F_Avance a ns1:Parametro ;
    rdfs:label "Parámetro F (Avance)"@es ;
    ns1:identificador "F" ;
    ns1:textoExtracto "parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z."@es ;
    ns1:valor "0" .

ns1:Parametro_H_Anchura a ns1:Parametro ;
    rdfs:label "Parámetro H (Anchura)"@es ;
    ns1:identificador "H" ;
    ns1:textoExtracto "anchura del planeado (parámetro H) son 0."@es ;
    ns1:valor "0" .

ns1:Parametro_L_Longitud a ns1:Parametro ;
    rdfs:label "Parámetro L (Longitud)"@es ;
    ns1:identificador "L" ;
    ns1:textoExtracto "parámetro L [...] son 0."@es ;
    ns1:valor "0" .

ns1:Parametro_S_Velocidad a ns1:Parametro ;
    rdfs:label "Parámetro S (Velocidad)"@es ;
    ns1:identificador "S" ;
    ns1:textoExtracto "parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado."@es ;
    ns1:valor "0" .

ns1:Parametro_T_Herramienta a ns1:Parametro ;
    rdfs:label "Parámetro T (Herramienta)"@es ;
    ns1:identificador "T" ;
    ns1:textoExtracto "parámetro T [...] tiene valor 0. No hay herramienta programada."@es ;
    ns1:valor "0" .

ns1:Parametro_P_Profundidad a ns1:Parametro ;
    rdfs:label "Parámetro P (Profundidad)"@es ;
    ns1:identificador "P" ;
    ns1:textoExtracto "parámetro P tiene valor 0. No hay profundidad programada."@es ;
    ns1:valor "0" .

