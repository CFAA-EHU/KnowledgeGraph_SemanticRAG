@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1773 a ns1:Alarma ;
    rdfs:label "PERFIL DE PUNTOS: Radio de herramienta mayor o igual que radio de entrada/salida tangencial"@es ;
    ns1:identificador "1773" ;
    ns1:mitigaRiesgo ns1:Parametro_RadioHerramienta_1773 ;
    ns1:textoExtracto "1773 'PERFIL DE PUNTOS: Radio de herramienta mayor o igual que radio de entrada/salida tangencial' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de una de las herramientas usadas en el ciclo es igual o mayor que el radio de la entrada tangencial (radio del punto P1) o de la salida tangencial (radio del punto P12)."@es .

ns1:Alarma_1774 a ns1:Alarma ;
    rdfs:label "PERFIL: F = 0"@es ;
    ns1:identificador "1774" ;
    ns1:mitigaRiesgo ns1:Parametro_AvanceF_1774 ;
    ns1:textoExtracto "1774 'PERFIL: F = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z."@es .

ns1:Alarma_1775 a ns1:Alarma ;
    rdfs:label "PERFIL: S = 0"@es ;
    ns1:identificador "1775" ;
    ns1:mitigaRiesgo ns1:Parametro_VelocidadS_1775 ;
    ns1:textoExtracto "1775 'PERFIL: S = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado."@es .

ns1:Alarma_1776 a ns1:Alarma ;
    rdfs:label "PERFIL: T = 0"@es ;
    ns1:identificador "1776" ;
    ns1:mitigaRiesgo ns1:Parametro_HerramientaT_1776 ;
    ns1:textoExtracto "1776 'PERFIL: T = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada."@es .

ns1:Alarma_1777 a ns1:Alarma ;
    rdfs:label "PERFIL: P = 0"@es ;
    ns1:identificador "1777" ;
    ns1:mitigaRiesgo ns1:Parametro_ProfundidadP_1777 ;
    ns1:textoExtracto "1777 'PERFIL: P = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada."@es .

ns1:Alarma_1778 a ns1:Alarma ;
    rdfs:label "PERFIL: (ACABADO): Longitud de corte de herramienta < P"@es ;
    ns1:identificador "1778" ;
    ns1:mitigaRiesgo ns1:Parametro_LongitudCorte_1778 ;
    ns1:textoExtracto "1778 'PERFIL: (ACABADO): Longitud de corte de herramienta < P' DETECCIÓN Durante la ejecución del ciclo. CAUSA La longitud de corte de la herramienta de acabado es menor que la profundidad del perfil (parámetro P)."@es .

ns1:Parametro_RadioEntradaSalida_1773 a ns1:Parametro ;
    rdfs:label "Radio de entrada/salida tangencial"@es ;
    ns1:textoExtracto "radio de la entrada tangencial (radio del punto P1) o de la salida tangencial (radio del punto P12)."@es .

ns1:Parametro_AvanceF_1774 a ns1:Parametro ;
    rdfs:label "Parámetro F (avance)"@es ;
    ns1:textoExtracto "parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z."@es ;
    ns1:valor "0" .

ns1:Parametro_HerramientaT_1776 a ns1:Parametro ;
    rdfs:label "Parámetro T (herramienta)"@es ;
    ns1:textoExtracto "parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada."@es ;
    ns1:valor "0" .

ns1:Parametro_LongitudCorte_1778 a ns1:Parametro ;
    rdfs:label "Longitud de corte de herramienta de acabado"@es ;
    ns1:textoExtracto "longitud de corte de la herramienta de acabado es menor que la profundidad del perfil (parámetro P)."@es .

ns1:Parametro_ProfundidadP_1777 a ns1:Parametro ;
    rdfs:label "Parámetro P (profundidad)"@es ;
    ns1:textoExtracto "parámetro P tiene valor 0. No hay profundidad programada."@es ;
    ns1:valor "0" .

ns1:Parametro_RadioHerramienta_1773 a ns1:Parametro ;
    rdfs:label "Radio de herramienta"@es ;
    ns1:textoExtracto "El radio de una de las herramientas usadas en el ciclo es igual o mayor que el radio de la entrada tangencial (radio del punto P1) o de la salida tangencial (radio del punto P12)."@es .

ns1:Parametro_VelocidadS_1775 a ns1:Parametro ;
    rdfs:label "Parámetro S (velocidad)"@es ;
    ns1:textoExtracto "parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado."@es ;
    ns1:valor "0" .

