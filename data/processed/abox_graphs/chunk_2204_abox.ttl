@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1778 a ns1:DiagnosticoFallo ;
    rdfs:label "Perfil (acabado): Longitud de corte de herramienta < P"@es ;
    ns1:identificador "1778" ;
    ns1:solucionaFallo ns1:Solucion_1778 ;
    ns1:textoExtracto "'PERFIL: (ACABADO): Longitud de corte de herramienta < P' DETECCIÓN Durante la ejecución del ciclo. CAUSA La longitud de corte de la herramienta de acabado es menor que la profundidad del perfil (parámetro P). SOLUCIÓN Elegir como herramienta de acabado una herramienta de mayor longitud de corte."@es .

ns1:Fallo_1779 a ns1:DiagnosticoFallo ;
    rdfs:label "Ranurado: F = 0"@es ;
    ns1:identificador "1779" ;
    ns1:monitoreaParametro ns1:Parametro_F_1779 ;
    ns1:solucionaFallo ns1:Solucion_1779 ;
    ns1:textoExtracto "'RANURADO: F = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Parametro_P_1778 a ns1:Parametro ;
    rdfs:label "Parámetro P (profundidad de perfil)"@es ;
    ns1:identificador "P" ;
    ns1:textoExtracto "profundidad del perfil (parámetro P)"@es .

ns1:Herramienta_1778 a ns1:Herramienta ;
    rdfs:label "Herramienta de acabado (longitud insuficiente)"@es ;
    ns1:textoExtracto "longitud de corte de la herramienta de acabado es menor que la profundidad del perfil"@es .

ns1:Solucion_1778 a ns1:TareaMantenimiento ;
    rdfs:label "Seleccionar herramienta de mayor longitud de corte"@es ;
    ns1:requiereConsumible ns1:Herramienta_1778 ;
    ns1:textoExtracto "Elegir como herramienta de acabado una herramienta de mayor longitud de corte"@es .

ns1:Solucion_1779 a ns1:TareaMantenimiento ;
    rdfs:label "Asignar valor > 0 al parámetro F"@es ;
    ns1:monitoreaParametro ns1:Parametro_F_1779 ;
    ns1:textoExtracto "Asignar al parámetro un valor mayor que 0"@es .

ns1:Parametro_F_1779 a ns1:Parametro ;
    rdfs:label "Parámetro F (avance)"@es ;
    ns1:identificador "F" ;
    ns1:textoExtracto "parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z"@es ;
    ns1:valor "0" .

