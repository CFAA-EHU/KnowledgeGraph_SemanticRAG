@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FalloRanurado_1785 a ns1:DiagnosticoFallo ;
    rdfs:label "RANURADO: Diámetro de herramienta mayor que cajera"@es ;
    ns1:identificador "1785" ;
    ns1:solucionaFallo ns1:HerramientaDeMenorDiametro ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA En la operación de desbaste o acabado, el diámetro de la herramienta es mayor que las dimensiones de la ranura (parámetros L ó H). SOLUCIÓN Elegir una herramienta de menor diámetro."@es .

ns1:FalloRanurado_1786 a ns1:DiagnosticoFallo ;
    rdfs:label "RANURADO: Diámetro de herramienta ACABADO menor que delta"@es ;
    ns1:identificador "1786" ;
    ns1:solucionaFallo ns1:HerramientaDeMayorDiametro ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El diámetro de la herramienta de acabado es menor que las demasías en las paredes laterales (parámetro δ). SOLUCIÓN Elegir una herramienta de mayor diámetro para la pasada de"@es .

ns1:HerramientaFresado a ns1:Herramienta ;
    ns1:textoExtracto "Reducir el paso de fresado o utilizar una herramienta de diámetro mayor."@es .

ns1:Parametro_Delta a ns1:Parametro ;
    rdfs:label "Parámetro δ (demasía en paredes laterales)"@es ;
    ns1:textoExtracto "parámetro δ"@es ;
    ns1:valor "δ" .

ns1:Parametro_H a ns1:Parametro ;
    rdfs:label "Parámetro H (dimensión de ranura)"@es ;
    ns1:textoExtracto "parámetros L ó H"@es .

ns1:Parametro_L a ns1:Parametro ;
    rdfs:label "Parámetro L (dimensión de ranura)"@es ;
    ns1:textoExtracto "parámetros L ó H"@es .

ns1:HerramientaDeMayorDiametro a ns1:Herramienta ;
    rdfs:label "Herramienta de mayor diámetro"@es ;
    ns1:textoExtracto "Elegir una herramienta de mayor diámetro para la pasada de"@es .

ns1:HerramientaDeMenorDiametro a ns1:Herramienta ;
    rdfs:label "Herramienta de menor diámetro"@es ;
    ns1:textoExtracto "Elegir una herramienta de menor diámetro."@es .

