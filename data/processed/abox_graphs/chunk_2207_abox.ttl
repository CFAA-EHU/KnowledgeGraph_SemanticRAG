@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1787 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA CIRCULAR: F = 0"@es ;
    ns1:identificador "1787" ;
    ns1:solucionaFallo ns1:Parametro_F_Avance ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Fallo_1788 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA CIRCULAR: S = 0"@es ;
    ns1:identificador "1788" ;
    ns1:solucionaFallo ns1:Parametro_S_Velocidad ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Algún parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Fallo_1789 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA CIRCULAR: T = 0"@es ;
    ns1:identificador "1789" ;
    ns1:solucionaFallo ns1:Herramienta_Desbaste_Acabado ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada. SOLUCIÓN Programar una herramienta para la operación de desbaste o acabado. Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta."@es .

ns1:Fallo_1790 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA CIRCULAR: P = 0"@es ;
    ns1:identificador "1790" ;
    ns1:solucionaFallo ns1:Parametro_P_Profundidad ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro P tiene valor 0. No hay profundidad programada. SOLUCIÓN Asignar al parámetro un valor mayor que 0."@es .

ns1:Fallo_1791 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA CIRCULAR: Diámetro de herramienta menor que DELTA"@es ;
    ns1:identificador "1791" ;
    ns1:solucionaFallo ns1:Parametro_Delta_PasoFresado ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA En la operación de desbaste o acabado, el diámetro de la herramienta es menor que el paso de fresado (parámetro ). SOLUCIÓN Reducir el paso de fresado o utilizar una herramienta de diámetro mayor."@es .

ns1:Fallo_1792 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA CIRCULAR: Diámetro de herramienta mayor que cajera"@es ;
    ns1:identificador "1792" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo."@es .

ns1:Fallo_HerramientaAcabado a ns1:DiagnosticoFallo ;
    ns1:solucionaFallo ns1:Herramienta_Acabado ;
    ns1:textoExtracto "CAUSA El diámetro de la herramienta de acabado es menor que las demasías en las paredes laterales (parámetro ). SOLUCIÓN Elegir una herramienta de mayor diámetro para la pasada de acabado."@es .

ns1:Parametro_Delta_WallTolerance a ns1:Parametro ;
    rdfs:label "Parámetro δ (demasías en paredes laterales)"@es ;
    ns1:textoExtracto "parámetro "@es .

ns1:Parametro_T_Herramienta a ns1:Parametro ;
    rdfs:label "Parámetro T (herramienta)"@es ;
    ns1:textoExtracto "parámetro T de las operaciones de desbaste y acabado tiene valor 0. No hay herramienta programada"@es ;
    ns1:valor "0" .

ns1:Herramienta_Acabado a ns1:Herramienta ;
    ns1:textoExtracto "herramienta de acabado"@es .

ns1:Herramienta_Desbaste_Acabado a ns1:Herramienta ;
    ns1:textoExtracto "herramienta para la operación de desbaste o acabado"@es .

ns1:Parametro_Delta_PasoFresado a ns1:Parametro ;
    rdfs:label "Parámetro Δ (paso de fresado)"@es ;
    ns1:textoExtracto "el diámetro de la herramienta es menor que el paso de fresado (parámetro )"@es .

ns1:Parametro_F_Avance a ns1:Parametro ;
    rdfs:label "Parámetro F (avance)"@es ;
    ns1:textoExtracto "parámetro F tiene valor 0; falta programar el avance de desbaste, acabado o profundización en Z"@es ;
    ns1:valor "0" .

ns1:Parametro_P_Profundidad a ns1:Parametro ;
    rdfs:label "Parámetro P (profundidad)"@es ;
    ns1:textoExtracto "parámetro P tiene valor 0. No hay profundidad programada"@es ;
    ns1:valor "0" .

ns1:Parametro_S_Velocidad a ns1:Parametro ;
    rdfs:label "Parámetro S (velocidad)"@es ;
    ns1:textoExtracto "parámetro S tiene valor 0; falta programar la velocidad para el desbaste o acabado"@es ;
    ns1:valor "0" .

