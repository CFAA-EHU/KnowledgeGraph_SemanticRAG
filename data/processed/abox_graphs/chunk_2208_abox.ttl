@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Ciclo_Fresado a ns1:ModoOperacion ;
    rdfs:label "Ciclo de fresado"@es ;
    ns1:requiereMantenimiento ns1:Fallo_1792,
        ns1:Fallo_1793 ;
    ns1:textoExtracto "ejecución del ciclo"@es .

ns1:Herramienta_Acabado_1792 a ns1:Herramienta ;
    ns1:solucionaFallo ns1:Fallo_1792 ;
    ns1:textoExtracto "radio de la herramienta es mayor que el radio de la cajera (parámetro R)"@es .

ns1:Herramienta_Acabado_1793 a ns1:Herramienta ;
    ns1:solucionaFallo ns1:Fallo_1793 ;
    ns1:textoExtracto "herramienta de menor diámetro"@es .

ns1:Herramienta_Desbaste a ns1:Herramienta ;
    ns1:solucionaFallo ns1:Fallo_1792 ;
    ns1:textoExtracto "herramienta de diámetro mayor"@es .

ns1:Operacion_Acabado a ns1:ModoOperacion ;
    rdfs:label "Operación de acabado"@es ;
    ns1:requiereMantenimiento ns1:Fallo_1792,
        ns1:Fallo_1793 ;
    ns1:textoExtracto "operación de acabado"@es .

ns1:Operacion_Desbaste a ns1:ModoOperacion ;
    rdfs:label "Operación de desbaste"@es ;
    ns1:requiereMantenimiento ns1:Fallo_1792 ;
    ns1:textoExtracto "operación de desbaste"@es .

ns1:Parametro_R a ns1:Parametro ;
    rdfs:label "Radio de la cajera (R)"@es ;
    ns1:identificador "R" ;
    ns1:monitoreaParametro ns1:Fallo_1792 ;
    ns1:textoExtracto "radio de la cajera (parámetro R)"@es .

ns1:Fallo_1793 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA CIRCULAR: Diámetro de herramienta ACABADO menor que delta"@es ;
    ns1:identificador "1793" ;
    ns1:textoExtracto "CAJERA CIRCULAR: Diámetro de herramienta ACABADO menor que delta. DETECCIÓN Durante la ejecución del ciclo. CAUSA El diámetro de la herramienta de acabado es menor que las demasías en las"@es .

ns1:Fallo_1792 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA CIRCULAR: Diámetro de herramienta mayor que cajera"@es ;
    ns1:identificador "1792" ;
    ns1:textoExtracto "CAJERA CIRCULAR: Diámetro de herramienta mayor que cajera. DETECCIÓN Durante la ejecución del ciclo. CAUSA En la operación de desbaste o acabado, el radio de la herramienta es mayor que el radio de la cajera (parámetro R)."@es .

