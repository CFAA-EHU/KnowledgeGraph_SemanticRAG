@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_AbsoluteZeroOffset a ns1:Parametro ;
    rdfs:label "Absolute zero offset"@en ;
    ns1:documentadoEn ns1:Tabla_ZeroOffsets ;
    ns1:textoExtracto "Absolute zero offsets besides being set directly in the table may also be set from the PLC or via part-program using variables. The zero offsets are used to place the part zero at different positions of the machine."@en ;
    ns1:valor "Set directly in table, from PLC, or via part-program"@en .

ns1:Parametro_ClampOffset a ns1:Parametro ;
    rdfs:label "Clamp offset"@en ;
    ns1:documentadoEn ns1:Tabla_FixtureOffsets ;
    ns1:textoExtracto "The clamp offsets are used to set the position of the clamping system of the machine. To apply a clamp offset it must be activated from the program using the relevant variable."@en ;
    ns1:valor "Set directly in table, from PLC, or via part-program"@en .

ns1:Parametro_CommonParameters a ns1:Parametro ;
    rdfs:label "Common parameters"@en ;
    ns1:documentadoEn ns1:Tabla_ParametrosAritmeticos ;
    ns1:textoExtracto "Common parameters. The table is common to all the channels."@en ;
    ns1:valor "Shared across all channels"@en .

ns1:Parametro_GlobalParameters a ns1:Parametro ;
    rdfs:label "Global parameters"@en ;
    ns1:documentadoEn ns1:Tabla_ParametrosAritmeticos ;
    ns1:textoExtracto "Global parameters. There is a table for each channel."@en ;
    ns1:valor "One table per channel"@en .

ns1:Parametro_LocalParameters a ns1:Parametro ;
    rdfs:label "Local parameters"@en ;
    ns1:documentadoEn ns1:Tabla_ParametrosAritmeticos ;
    ns1:textoExtracto "Local parameters. There are seven tables for each channel, one table per nesting level (7 levels)."@en ;
    ns1:valor "Seven tables per channel (one per nesting level)"@en .

ns1:Parametro_PLC_Offset a ns1:Parametro ;
    rdfs:label "PLC offset"@en ;
    ns1:documentadoEn ns1:Tabla_ZeroOffsets ;
    ns1:textoExtracto "PLC offset (PLC offset). The PLC offset may not be set directly in the table, its values are set from the PLC or via part-program using variables. The CNC always adds the PLC offset to the selected zero offset."@en ;
    ns1:valor "Set from PLC or part-program using variables"@en .

ns1:Tabla_FixtureOffsets a ns1:Tabla ;
    rdfs:label "Fixture table"@en ;
    ns1:identificador "Fixture table"@en ;
    ns1:textoExtracto "Fixture table. This table stores the clamp offsets for each axis. The fixture offset besides being set directly in the table may also be set from the PLC or via part-program using variables. The clamp offsets are used to set the position of the clamping system of the machine."@en .

ns1:Tabla_ZeroOffsets a ns1:Tabla ;
    rdfs:label "Zero offset tables"@en ;
    ns1:identificador "Zero offset tables"@en ;
    ns1:textoExtracto "Zero offset tables. This table contains the absolute zero offsets and the PLC offset of all the axes and spindles that may be activated as C axis. The zero offsets associated with the possible C axes are always visible, even when the C axis is not active."@en .

ns1:Tabla_ParametrosAritmeticos a ns1:Tabla ;
    rdfs:label "Arithmetic parameter tables"@en ;
    ns1:identificador "Arithmetic parameter tables"@en ;
    ns1:textoExtracto "Arithmetic parameter tables. There are the following arithmetic parameter tables: Common parameters. The table is common to all the channels. Global parameters. There is a table for each channel. Local parameters. There are seven tables for each channel, one table per nesting level (7 levels)."@en .

