@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Herramienta_DesbasteAcabado a ns1:Herramienta ;
    rdfs:label "Herramienta de desbaste o acabado"@es ;
    ns1:requiereMantenimiento ns1:Fallo_1799,
        ns1:Fallo_1800 ;
    ns1:textoExtracto "La herramienta de desbaste o acabado tiene radio 0."@es .

ns1:Parametro_RadioHerramienta a ns1:Parametro ;
    rdfs:label "Radio de herramienta"@es ;
    ns1:monitoreaParametro ns1:Fallo_1799,
        ns1:Fallo_1800 ;
    ns1:textoExtracto "Diámetro de herramienta = 0"@es ;
    ns1:valor "0" .

ns1:TablaHerramientas a ns1:Tabla ;
    rdfs:label "Tabla de herramientas"@es ;
    ns1:documentadoEn ns1:ManualOperacion ;
    ns1:textoExtracto "Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta."@es .

ns1:Tarea_CorreccionRadio a ns1:TareaMantenimiento ;
    rdfs:label "Corrección de radio en tabla de herramientas"@es ;
    ns1:solucionaFallo ns1:Fallo_1799,
        ns1:Fallo_1800 ;
    ns1:textoExtracto "Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta."@es .

ns1:Fallo_1799 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1799: Diámetro de herramienta = 0 (planeado)"@es ;
    ns1:identificador "1799" ;
    ns1:textoExtracto "'PLANEADO: Diámetro de herramienta = 0' DETECCIÓN Durante la ejecución de un ciclo. CAUSA La herramienta de desbaste o acabado tiene radio 0."@es .

ns1:Fallo_1800 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1800: Diámetro de herramienta = 0 (ranurado)"@es ;
    ns1:identificador "1800" ;
    ns1:textoExtracto "'RANURADO: Diámetro de herramienta = 0' DETECCIÓN Durante la ejecución de un ciclo. CAUSA La herramienta de desbaste o acabado tiene radio 0."@es .

