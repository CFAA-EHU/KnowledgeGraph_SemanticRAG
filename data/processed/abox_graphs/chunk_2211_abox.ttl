@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:alarma_1800 a ns1:Alarma ;
    rdfs:label "Alarma 1800: RANURADO - Radio de herramienta = 0" ;
    ns1:identificador "1800" ;
    ns1:monitoreaParametro ns1:parametro_radio_herramienta ;
    ns1:textoExtracto "'RANURADO: Diámetro de herramienta = 0' DETECCIÓN Durante la ejecución de un ciclo. CAUSA La herramienta de desbaste o acabado tiene radio 0. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ns1:alarma_1801 a ns1:Alarma ;
    rdfs:label "Alarma 1801: CAJERA RECTANGULAR - Ángulo β/θ fuera de rango" ;
    ns1:identificador "1801" ;
    ns1:monitoreaParametro ns1:parametro_angulo_beta,
        ns1:parametro_angulo_theta ;
    ns1:textoExtracto "'CAJERA RECTANGULAR: Beta o theta < 0 ó Beta o theta > 90' DETECCIÓN Durante la ejecución de una cajera. CAUSA En el ciclo de cajera, el ángulo de profundización lateral para el desbaste (parámetro β) o para el acabado (parámetro θ) no está comprendido entre 0º y 90º. SOLUCIÓN Corregir el ángulo de profundización lateral; programar un valor entre 0º y 90º." .

ns1:alarma_1802 a ns1:Alarma ;
    rdfs:label "Alarma 1802: CAJERA CIRCULAR - Ángulo β/θ fuera de rango" ;
    ns1:identificador "1802" ;
    ns1:monitoreaParametro ns1:parametro_angulo_beta,
        ns1:parametro_angulo_theta ;
    ns1:textoExtracto "'CAJERA CIRCULAR: Beta o theta < 0 ó Beta o theta > 90' DETECCIÓN Durante la ejecución de una cajera. CAUSA En el ciclo de cajera, el ángulo de profundización lateral para el desbaste (parámetro β) o para el acabado (parámetro θ) no está comprendido entre 0º y 90º. SOLUCIÓN Corregir el ángulo de profundización lateral; programar un valor entre 0º y 90º." .

ns1:alarma_1803 a ns1:Alarma ;
    rdfs:label "Alarma 1803: CAJERA PREVACIADA - Ángulo β/θ fuera de rango" ;
    ns1:identificador "1803" ;
    ns1:monitoreaParametro ns1:parametro_angulo_beta,
        ns1:parametro_angulo_theta ;
    ns1:textoExtracto "'CAJERA PREVACIADA: Beta o theta < 0 ó Beta o theta > 90' DETECCIÓN Durante la ejecución de una cajera. CAUSA En el ciclo de cajera, el ángulo de profundización lateral para el desbaste (parámetro β) o para el acabado (parámetro θ) no está comprendido entre 0º y 90º. SOLUCIÓN Corregir el ángulo de profundización lateral; programar un valor entre 0º y 90º." .

ns1:alarma_1804 a ns1:Alarma ;
    rdfs:label "Alarma 1804: G87 - Profundidad = 0" ;
    ns1:identificador "1804" ;
    ns1:monitoreaParametro ns1:parametro_profundidad_G87 ;
    ns1:textoExtracto "'G87: Profundidad = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA La profundidad resultante de la cajera es cero." .

ns1:ciclo_G87 a ns1:ModoOperacion ;
    rdfs:label "Ciclo G87" ;
    ns1:textoExtracto "Durante la ejecución del ciclo" .

ns1:ciclo_cajera_circular a ns1:ModoOperacion ;
    rdfs:label "Ciclo de cajera circular" ;
    ns1:textoExtracto "Durante la ejecución de una cajera" .

ns1:ciclo_cajera_prevaciada a ns1:ModoOperacion ;
    rdfs:label "Ciclo de cajera prevaciada" ;
    ns1:textoExtracto "Durante la ejecución de una cajera" .

ns1:ciclo_cajera_rectangular a ns1:ModoOperacion ;
    rdfs:label "Ciclo de cajera rectangular" ;
    ns1:textoExtracto "Durante la ejecución de una cajera" .

ns1:ciclo_ranurado a ns1:ModoOperacion ;
    rdfs:label "Ciclo de ranurado" ;
    ns1:textoExtracto "Durante la ejecución de un ciclo" .

ns1:herramienta_acabado a ns1:Herramienta ;
    rdfs:label "Herramienta de acabado" ;
    ns1:documentadoEn ns1:tabla_herramientas ;
    ns1:textoExtracto "La herramienta de desbaste o acabado tiene radio 0" .

ns1:herramienta_desbaste a ns1:Herramienta ;
    rdfs:label "Herramienta de desbaste" ;
    ns1:documentadoEn ns1:tabla_herramientas ;
    ns1:textoExtracto "La herramienta de desbaste o acabado tiene radio 0" .

ns1:parametro_profundidad_G87 a ns1:Parametro ;
    rdfs:label "Profundidad de cajera (G87)" ;
    ns1:textoExtracto "Profundidad = 0" ;
    ns1:valor "0" .

ns1:parametro_radio_herramienta a ns1:Parametro ;
    rdfs:label "Radio de herramienta" ;
    ns1:textoExtracto "Diámetro de herramienta = 0" ;
    ns1:valor "0" .

ns1:tabla_herramientas a ns1:Tabla ;
    rdfs:label "Tabla de herramientas" ;
    ns1:textoExtracto "Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta" .

ns1:parametro_angulo_beta a ns1:Parametro ;
    rdfs:label "Ángulo de profundización lateral (β)" ;
    ns1:textoExtracto "el ángulo de profundización lateral para el desbaste (parámetro β)" ;
    ns1:valor "0-90"^^xsd:string .

ns1:parametro_angulo_theta a ns1:Parametro ;
    rdfs:label "Ángulo de profundización lateral (θ)" ;
    ns1:textoExtracto "el ángulo de profundización lateral para el acabado (parámetro θ)" ;
    ns1:valor "0-90"^^xsd:string .

