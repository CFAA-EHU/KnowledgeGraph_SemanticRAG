@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1805 a ns1:DiagnosticoFallo ;
    rdfs:label "G87: Diámetro de herramienta mayor que cajera"@es ;
    ns1:identificador "1805" ;
    ns1:solucionaFallo ns1:SeleccionarHerramientaDeDiametroMenor ;
    ns1:textoExtracto "1805 'G87: Diámetro de herramienta mayor que cajera' [...] CAUSA El radio de la herramienta es mayor que las dimensiones de la cajera (parámetros [...] SOLUCIÓN Seleccionar una herramienta de diámetro menor."@es .

ns1:Fallo_1806 a ns1:DiagnosticoFallo ;
    rdfs:label "G87: Diámetro de herramienta menor que L"@es ;
    ns1:identificador "1806" ;
    ns1:textoExtracto "1806 'G87: Diámetro de herramienta menor que L'"@es .

ns1:Fallo_ProfundidadCero a ns1:DiagnosticoFallo ;
    rdfs:label "Profundidad de cajera resultante cero"@es ;
    ns1:solucionaFallo ns1:CorregirProgramacionDeParametrosIZD ;
    ns1:textoExtracto "CAUSA La profundidad resultante de la cajera es cero. La profundidad programada (parámetro I) coincide con la suma de los parámetros Z y D; si no se ha programado el parámetro Z, la profundidad programada (parámetro I) coincide con el parámetro D. SOLUCIÓN Corregir la programación de los parámetros I Z D."@es .

ns1:Herramienta_G87 a ns1:Herramienta ;
    rdfs:label "Herramienta para ciclo G87"@es ;
    ns1:textoExtracto "radio de la herramienta [...] diámetro de herramienta"@es .

ns1:Parametro_D a ns1:Parametro ;
    rdfs:label "Parámetro D"@es ;
    ns1:identificador "D" ;
    ns1:textoExtracto "parámetro D"@es .

ns1:Parametro_I a ns1:Parametro ;
    rdfs:label "Parámetro I (profundidad programada)"@es ;
    ns1:identificador "I" ;
    ns1:textoExtracto "parámetro I"@es ;
    ns1:valor "profundidad programada"@es .

ns1:Parametro_Z a ns1:Parametro ;
    rdfs:label "Parámetro Z"@es ;
    ns1:identificador "Z" ;
    ns1:textoExtracto "parámetro Z"@es .

ns1:CorregirProgramacionDeParametrosIZD a ns1:TareaMantenimiento ;
    rdfs:label "Corregir programación de parámetros I, Z, D"@es ;
    ns1:textoExtracto "SOLUCIÓN Corregir la programación de los parámetros I Z D."@es .

ns1:SeleccionarHerramientaDeDiametroMenor a ns1:TareaMantenimiento ;
    rdfs:label "Seleccionar herramienta de diámetro menor"@es ;
    ns1:textoExtracto "SOLUCIÓN Seleccionar una herramienta de diámetro menor."@es .

