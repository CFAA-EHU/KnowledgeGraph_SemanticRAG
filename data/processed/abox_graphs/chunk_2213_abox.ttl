@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error1806 a ns1:DiagnosticoFallo ;
    rdfs:label "G87: Diámetro de herramienta menor que L"@es ;
    ns1:identificador "1806" ;
    ns1:monitoreaParametro ns1:Parametro_L ;
    ns1:textoExtracto "1806 'G87: Diámetro de herramienta menor que L' DETECCIÓN Durante la ejecución del ciclo. CAUSA El diámetro de la herramienta es menor que la demasía de acabado (parámetro L). SOLUCIÓN Seleccionar una herramienta de diámetro mayor."@es .

ns1:Error1807 a ns1:DiagnosticoFallo ;
    rdfs:label "G87: Diámetro de herramienta = 0"@es ;
    ns1:identificador "1807" ;
    ns1:monitoreaParametro ns1:TablaHerramientas ;
    ns1:textoExtracto "1807 'G87: Diámetro de herramienta = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA La herramienta tiene diámetro 0. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta."@es .

ns1:Error1808 a ns1:DiagnosticoFallo ;
    rdfs:label "G87: No hay herramienta"@es ;
    ns1:identificador "1808" ;
    ns1:solucionaFallo ns1:HerramientaCNC ;
    ns1:textoExtracto "1808 'G87: No hay herramienta' DETECCIÓN Durante la ejecución del ciclo. CAUSA No hay herramienta en el cabezal. SOLUCIÓN Programar una herramienta antes del ciclo o cargar una herramienta en el cabezal."@es .

ns1:Error1809 a ns1:DiagnosticoFallo ;
    rdfs:label "G87: Diámetro de herramienta menor que C"@es ;
    ns1:identificador "1809" ;
    ns1:monitoreaParametro ns1:Parametro_C ;
    ns1:textoExtracto "1809 'G87: Diámetro de herramienta menor que C' DETECCIÓN Durante la ejecución del ciclo. CAUSA El diámetro de la herramienta es menor que el paso de fresado (parámetro C). SOLUCIÓN Reducir el paso de fresado o utilizar una herramienta de diámetro mayor."@es .

ns1:Error1810 a ns1:DiagnosticoFallo ;
    rdfs:label "G88: Profundidad = 0"@es ;
    ns1:identificador "1810" ;
    ns1:monitoreaParametro ns1:Parametro_D,
        ns1:Parametro_I,
        ns1:Parametro_Z ;
    ns1:textoExtracto "1810 'G88: Profundidad = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA La profundidad resultante de la cajera es cero. La profundidad programada (parámetro I) coincide con la suma de los parámetros Z y D; si no se ha programado el parámetro Z, la profundidad programada (parámetro I) coincide con el parámetro D. SOLUCIÓN Corregir la programación de los parámetros I Z D."@es .

ns1:Error1811 a ns1:DiagnosticoFallo ;
    rdfs:label "G88: Diámetro de herramienta mayor que cajera"@es ;
    ns1:identificador "1811" ;
    ns1:monitoreaParametro ns1:Parametro_J ;
    ns1:textoExtracto "1811 'G88: Diámetro de herramienta mayor que cajera' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta es mayor que las dimensiones de la cajera (parámetro J). SOLUCIÓN Seleccionar una herramienta de diámetro menor."@es .

ns1:HerramientaCNC a ns1:Herramienta ;
    rdfs:label "Herramienta de fresado"@es ;
    ns1:textoExtracto "No hay herramienta en el cabezal. SOLUCIÓN Programar una herramienta antes del ciclo o cargar una herramienta en el cabezal."@es .

ns1:Parametro_C a ns1:Parametro ;
    rdfs:label "Parámetro C (paso de fresado)"@es ;
    ns1:textoExtracto "El diámetro de la herramienta es menor que el paso de fresado (parámetro C)."@es .

ns1:Parametro_D a ns1:Parametro ;
    rdfs:label "Parámetro D (profundidad)"@es ;
    ns1:textoExtracto "La profundidad programada (parámetro I) coincide con la suma de los parámetros Z y D; si no se ha programado el parámetro Z, la profundidad programada (parámetro I) coincide con el parámetro D."@es .

ns1:Parametro_I a ns1:Parametro ;
    rdfs:label "Parámetro I (profundidad programada)"@es ;
    ns1:textoExtracto "La profundidad programada (parámetro I) coincide con la suma de los parámetros Z y D; si no se ha programado el parámetro Z, la profundidad programada (parámetro I) coincide con el parámetro D."@es .

ns1:Parametro_J a ns1:Parametro ;
    rdfs:label "Parámetro J (dimensiones de la cajera)"@es ;
    ns1:textoExtracto "El radio de la herramienta es mayor que las dimensiones de la cajera (parámetro J)."@es .

ns1:Parametro_L a ns1:Parametro ;
    rdfs:label "Parámetro L (demasía de acabado)"@es ;
    ns1:textoExtracto "El diámetro de la herramienta es menor que la demasía de acabado (parámetro L)."@es .

ns1:Parametro_Z a ns1:Parametro ;
    rdfs:label "Parámetro Z (profundidad)"@es ;
    ns1:textoExtracto "La profundidad programada (parámetro I) coincide con la suma de los parámetros Z y D."@es .

ns1:TablaHerramientas a ns1:Tabla ;
    rdfs:label "Tabla de herramientas"@es ;
    ns1:textoExtracto "Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta."@es .

