@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_1813 a ns1:AvisoSeguridad ;
    rdfs:label "G88: Diámetro de herramienta = 0"@es ;
    ns1:identificador "1813" ;
    ns1:textoExtracto "1813 'G88: Diámetro de herramienta = 0'"@es .

ns1:DiagnosticoFallo_1812 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Diámetro de herramienta menor que demasía de acabado (L)"@es ;
    ns1:requiereConsumible ns1:Herramienta_DiametroMayor ;
    ns1:solucionaFallo ns1:AvisoSeguridad_1812 ;
    ns1:textoExtracto "El diámetro de la herramienta es menor que la demasía de acabado (parámetro L). SOLUCIÓN Seleccionar una herramienta de diámetro mayor."@es .

ns1:DiagnosticoFallo_1813 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Diámetro de herramienta = 0"@es ;
    ns1:textoExtracto "La"@es .

ns1:DiagnosticoFallo_RadioHerramienta a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Radio de herramienta mayor que dimensiones de cajera (J)"@es ;
    ns1:monitoreaParametro ns1:Parametro_J ;
    ns1:requiereConsumible ns1:Herramienta_DiametroMenor ;
    ns1:textoExtracto "El radio de la herramienta es mayor que las dimensiones de la cajera (parámetro J). SOLUCIÓN Seleccionar una herramienta de diámetro menor."@es .

ns1:Parametro_L a ns1:Parametro ;
    rdfs:label "Parámetro L (demasía de acabado)"@es ;
    ns1:textoExtracto "parámetro L"@es ;
    ns1:valor "demasía de acabado"@es .

ns1:AvisoSeguridad_1812 a ns1:AvisoSeguridad ;
    rdfs:label "G88: Diámetro de herramienta menor que L"@es ;
    ns1:identificador "1812" ;
    ns1:textoExtracto "1812 'G88: Diámetro de herramienta menor que L'"@es .

ns1:Herramienta_DiametroMayor a ns1:Herramienta ;
    rdfs:label "Herramienta de diámetro mayor"@es ;
    ns1:textoExtracto "Seleccionar una herramienta de diámetro mayor"@es .

ns1:Herramienta_DiametroMenor a ns1:Herramienta ;
    rdfs:label "Herramienta de diámetro menor"@es ;
    ns1:textoExtracto "Seleccionar una herramienta de diámetro menor"@es .

ns1:Parametro_J a ns1:Parametro ;
    rdfs:label "Parámetro J (dimensiones de la cajera)"@es ;
    ns1:textoExtracto "parámetro J"@es ;
    ns1:valor "dimensiones de la cajera"@es .

