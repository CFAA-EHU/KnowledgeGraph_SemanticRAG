@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1813 a ns1:DiagnosticoFallo ;
    rdfs:label "G88: Diámetro de herramienta = 0"@es ;
    ns1:identificador "1813" ;
    ns1:monitoreaParametro ns1:Parametro_L ;
    ns1:textoExtracto "'G88: Diámetro de herramienta = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA La herramienta tiene diámetro 0. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta."@es .

ns1:Fallo_1814 a ns1:DiagnosticoFallo ;
    rdfs:label "G88: No hay herramienta"@es ;
    ns1:identificador "1814" ;
    ns1:textoExtracto "'G88: No hay herramienta' DETECCIÓN Durante la ejecución del ciclo. CAUSA No hay herramienta en el cabezal. SOLUCIÓN Programar una herramienta antes del ciclo o cargar una herramienta en el cabezal."@es .

ns1:Fallo_1815 a ns1:DiagnosticoFallo ;
    rdfs:label "G88: Diámetro de herramienta menor que C"@es ;
    ns1:identificador "1815" ;
    ns1:monitoreaParametro ns1:Parametro_C ;
    ns1:textoExtracto "'G88: Diámetro de herramienta menor que C' DETECCIÓN Durante la ejecución del ciclo. CAUSA El diámetro de la herramienta es menor que el paso de fresado (parámetro C). SOLUCIÓN Reducir el paso de fresado o utilizar una herramienta de diámetro mayor."@es .

ns1:Fallo_1816 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro X no múltiplo de I"@es ;
    ns1:identificador "1816" ;
    ns1:monitoreaParametro ns1:Parametro_I,
        ns1:Parametro_X ;
    ns1:textoExtracto "'El parámetro X ha de ser múltiplo del parámetro I' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA La longitud del mecanizado (parámetro X) ha de ser múltiplo del paso entre mecanizados (parámetro I). SOLUCIÓN Asignar un valor correcto a los parámetros."@es .

ns1:Fallo_1817 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta parámetro I o K"@es ;
    ns1:identificador "1817" ;
    ns1:monitoreaParametro ns1:Parametro_I,
        ns1:Parametro_K ;
    ns1:textoExtracto "'Uno de los parámetros I, K ha de ser programado' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA Falta programar el paso entre mecanizados (parámetro I) o el número de mecanizados (parámetro K). SOLUCIÓN Asignar un valor correcto al parámetro."@es .

ns1:Fallo_1818 a ns1:DiagnosticoFallo ;
    rdfs:label "J = 0 en mecanizado múltiple"@es ;
    ns1:identificador "1818" ;
    ns1:monitoreaParametro ns1:Parametro_J ;
    ns1:textoExtracto "'J = 0' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA En un mecanizado múltiple, el parámetro J (paso entre mecanizados en el eje de ordenadas) tiene valor 0. SOLUCIÓN Asignar un valor correcto al parámetro."@es .

ns1:Herramienta_Mecanizado a ns1:Herramienta ;
    rdfs:label "Herramienta de mecanizado"@es ;
    ns1:textoExtracto "Seleccionar una herramienta de diámetro mayor [...] utilizar una herramienta de diámetro mayor [...] cargar una herramienta en el cabezal."@es .

ns1:Parametro_C a ns1:Parametro ;
    rdfs:label "Parámetro C (paso de fresado)"@es ;
    ns1:identificador "C" ;
    ns1:textoExtracto "El diámetro de la herramienta es menor que el paso de fresado (parámetro C)."@es .

ns1:Parametro_J a ns1:Parametro ;
    rdfs:label "Parámetro J (paso en eje de ordenadas)"@es ;
    ns1:identificador "J" ;
    ns1:textoExtracto "parámetro J (paso entre mecanizados en el eje de ordenadas)"@es .

ns1:Parametro_K a ns1:Parametro ;
    rdfs:label "Parámetro K (número de mecanizados)"@es ;
    ns1:identificador "K" ;
    ns1:textoExtracto "número de mecanizados (parámetro K)"@es .

ns1:Parametro_L a ns1:Parametro ;
    rdfs:label "Parámetro L (demasía de acabado)"@es ;
    ns1:identificador "L" ;
    ns1:textoExtracto "es menor que la demasía de acabado (parámetro L). SOLUCIÓN Seleccionar una herramienta de diámetro mayor."@es .

ns1:Parametro_X a ns1:Parametro ;
    rdfs:label "Parámetro X (longitud de mecanizado)"@es ;
    ns1:identificador "X" ;
    ns1:textoExtracto "La longitud del mecanizado (parámetro X) ha de ser múltiplo del paso entre mecanizados (parámetro I)."@es .

ns1:Parametro_I a ns1:Parametro ;
    rdfs:label "Parámetro I (paso entre mecanizados)"@es ;
    ns1:identificador "I" ;
    ns1:textoExtracto "paso entre mecanizados (parámetro I)"@es .

