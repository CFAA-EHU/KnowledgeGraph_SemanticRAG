    ns1:textoExtracto "'Uno de los parámetros I, A ha de ser programado' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple."@es .

ns1:ModoOperacion_CicloMecanizadoMultiple a ns1:ModoOperacion ;
    rdfs:label "Ciclo de mecanizado múltiple"@es ;
    ns1:textoExtracto "ejecución de un ciclo de mecanizado múltiple"@es .

