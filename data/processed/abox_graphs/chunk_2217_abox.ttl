@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1820 a ns1:Alarma ;
    rdfs:label "Alarma 1820: Parámetros X, I, K no programados"@es ;
    ns1:identificador "1820" ;
    ns1:monitoreaParametro ns1:Parametro_I_1820,
        ns1:Parametro_K_1820,
        ns1:Parametro_X_1820 ;
    ns1:textoExtracto "'Dos de los parámetros X, I, K han de ser programados' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA Falta programar dos de los siguientes parámetros; X (longitud del mecanizado), I (paso entre mecanizados), K (número de mecanizados). SOLUCIÓN Asignar un valor correcto a los parámetros."@es .

ns1:Alarma_1821 a ns1:Alarma ;
    rdfs:label "Alarma 1821: Parámetro B no múltiplo de I"@es ;
    ns1:identificador "1821" ;
    ns1:monitoreaParametro ns1:Parametro_B_1821,
        ns1:Parametro_I_1821 ;
    ns1:textoExtracto "'B debe ser múltiplo de I' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA La longitud angular del mecanizado (parámetro B) ha de ser múltiplo del paso angular entre mecanizados (parámetro I). SOLUCIÓN Asignar un valor correcto a los parámetros."@es .

ns1:Alarma_1822 a ns1:Alarma ;
    rdfs:label "Alarma 1822: Parámetro Y no múltiplo de J"@es ;
    ns1:identificador "1822" ;
    ns1:monitoreaParametro ns1:Parametro_J_1822,
        ns1:Parametro_Y_1822 ;
    ns1:textoExtracto "'El parámetro Y ha de ser múltiplo del parámetro J' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA La longitud del mecanizado (parámetro Y) ha de ser múltiplo del paso entre mecanizados (parámetro J). SOLUCIÓN Asignar un valor correcto a los parámetros."@es .

ns1:Alarma_1823 a ns1:Alarma ;
    rdfs:label "Alarma 1823: Parámetros Y, J, D no programados"@es ;
    ns1:identificador "1823" ;
    ns1:monitoreaParametro ns1:Parametro_D_1823,
        ns1:Parametro_J_1823,
        ns1:Parametro_Y_1823 ;
    ns1:textoExtracto "'Dos de los parámetros Y, J, D han de ser programados' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA Falta programar dos de los siguientes parámetros; Y (longitud del mecanizado), J (paso entre mecanizados), D (número de mecanizados). SOLUCIÓN Asignar un valor correcto a los parámetros."@es .

ns1:Alarma_1824 a ns1:Alarma ;
    rdfs:label "Alarma 1824: Parámetros I, K no programados"@es ;
    ns1:identificador "1824" ;
    ns1:monitoreaParametro ns1:Parametro_I_1824,
        ns1:Parametro_K_1824 ;
    ns1:textoExtracto "'Uno de los parámetros I, K ha de ser programado' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA Falta programar uno de los siguientes parámetros; I (paso entre mecanizados), K (número de mecanizados). SOLUCIÓN Asignar un valor correcto a los parámetros."@es .

ns1:Alarma_1825 a ns1:Alarma ;
    rdfs:label "Alarma 1825: Parámetros I, A no programados"@es ;
