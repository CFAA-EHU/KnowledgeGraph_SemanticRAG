@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1825 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta programar parámetros I o A en ciclo de mecanizado múltiple" ;
    ns1:identificador "1825" ;
    ns1:solucionaFallo ns1:ParametroANumeroDeMecanizados,
        ns1:ParametroIPasoAngularEntreMecanizados ;
    ns1:textoExtracto "1825 'Uno de los parámetros I, A ha de ser programado' [...] Falta programar dos de los siguientes parámetros; I (paso angular entre mecanizados), A (número de mecanizados)." .

ns1:DiagnosticoFallo_1826 a ns1:DiagnosticoFallo ;
    rdfs:label "Validación de parámetros I y K en ciclo de mecanizado múltiple" ;
    ns1:identificador "1826" ;
    ns1:solucionaFallo ns1:ParametroIPasoAngularEntreMecanizados,
        ns1:ParametroKFactorDeValidacion ;
    ns1:textoExtracto "1826 'El parámetro I multiplicado por K ha de ser igual a 360' [...] El paso angular entre mecanizados (parámetro I) por el número de mecanizados" .

ns1:ModoOperacion_CicloMecanizadoMultiple a ns1:ModoOperacion ;
    rdfs:label "Ciclo de mecanizado múltiple" ;
    ns1:monitoreaParametro ns1:Parametro_A,
        ns1:Parametro_I,
        ns1:Parametro_K ;
    ns1:textoExtracto "ejecución de un ciclo de mecanizado múltiple" .

ns1:ParametroANumeroDeMecanizados a ns1:Parametro ;
    rdfs:label "Parámetro A (número de mecanizados)" ;
    ns1:textoExtracto "A (número de mecanizados)" ;
    ns1:valor "A" .

ns1:ParametroKFactorDeValidacion a ns1:Parametro ;
    rdfs:label "Parámetro K (factor de validación)" ;
    ns1:textoExtracto "K" ;
    ns1:valor "K" .

ns1:Parametro_A a ns1:Parametro ;
    rdfs:label "Parámetro A (número de mecanizados)" ;
    ns1:textoExtracto "A (número de mecanizados)" ;
    ns1:valor "A" .

ns1:Parametro_I a ns1:Parametro ;
    rdfs:label "Parámetro I (paso angular entre mecanizados)" ;
    ns1:textoExtracto "I (paso angular entre mecanizados)" ;
    ns1:valor "I" .

ns1:Parametro_K a ns1:Parametro ;
    rdfs:label "Parámetro K (factor de validación)" ;
    ns1:textoExtracto "K" ;
    ns1:valor "K" .

ns1:ParametroIPasoAngularEntreMecanizados a ns1:Parametro ;
    rdfs:label "Parámetro I (paso angular entre mecanizados)" ;
    ns1:textoExtracto "I (paso angular entre mecanizados)" ;
    ns1:valor "I" .

