@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1826 a ns1:Alarma ;
    rdfs:label "Alarma 1826: Producto I*K distinto de 360"@es ;
    ns1:identificador "1826" ;
    ns1:textoExtracto "I multiplicado por K ha de ser igual a 360' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA El paso angular entre mecanizados (parámetro I) por el número de mecanizados (parámetro K) debe ser 360º. SOLUCIÓN Asignar un valor correcto al parámetro."@es .

ns1:Alarma_1827 a ns1:Alarma ;
    rdfs:label "Alarma 1827: Parámetros X e Y iguales a 0"@es ;
    ns1:identificador "1827" ;
    ns1:textoExtracto "'Los parámetros X e Y son iguales a 0' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA Los parámetros X Y (centro del arco de mecanizado) tienen valor 0. SOLUCIÓN Asignar un valor correcto al parámetro."@es .

ns1:Alarma_1828 a ns1:Alarma ;
    rdfs:label "Alarma 1828: 360 no es múltiplo del parámetro I"@es ;
    ns1:identificador "1828" ;
    ns1:textoExtracto "'360 ha de ser múltiplo del parámetro I' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA El paso angular (parámetro I) ha de ser submúltiplo de 360º. SOLUCIÓN Asignar un valor correcto al parámetro."@es .

ns1:Alarma_1829 a ns1:Alarma ;
    rdfs:label "Alarma 1829: Parámetro I igual a 0"@es ;
    ns1:identificador "1829" ;
    ns1:textoExtracto "'I = 0' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA En un mecanizado múltiple, el parámetro I (paso entre mecanizados) tiene valor 0. SOLUCIÓN Asignar al parámetro un valor distinto de cero."@es .

ns1:Alarma_1830 a ns1:Alarma ;
    rdfs:label "Alarma 1830: Diámetro de herramienta igual a 0"@es ;
    ns1:identificador "1830" ;
    ns1:mitigaRiesgo ns1:Herramienta_G82 ;
    ns1:textoExtracto "'Diámetro de herramienta = 0' DETECCIÓN Durante la ejecución de un ciclo. CAUSA La herramienta tiene diámetro 0. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta."@es .

ns1:Alarma_1831 a ns1:Alarma ;
    rdfs:label "Alarma 1831: Parámetro C (cota de aproximación) igual a 0"@es ;
    ns1:identificador "1831" ;
    ns1:textoExtracto "'G82: C = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro C (cota de aproximación) tiene valor 0. SOLUCIÓN Asignar al parámetro un valor distinto de cero."@es .

ns1:Alarma_1832 a ns1:Alarma ;
    rdfs:label "Alarma 1832: Parámetro I (paso máximo de profundización) igual a 0"@es ;
    ns1:identificador "1832" ;
    ns1:textoExtracto "'DESBASTE: I = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro I (paso máximo de profundización) tiene valor 0. SOLUCIÓN Asignar al parámetro un valor distinto de cero y menor que la longitud de corte de la herramienta."@es .

ns1:Parametro_C a ns1:Parametro ;
    rdfs:label "Parámetro C (cota de aproximación)"@es ;
    ns1:textoExtracto "parámetro C (cota de aproximación)"@es .

ns1:Parametro_I a ns1:Parametro ;
    rdfs:label "Parámetro I (paso angular o paso máximo de profundización)"@es ;
    ns1:textoExtracto "parámetro I (paso máximo de profundización)"@es .

ns1:Parametro_K a ns1:Parametro ;
    rdfs:label "Parámetro K (número de mecanizados)"@es ;
    ns1:textoExtracto "número de mecanizados (parámetro K)"@es .

ns1:Parametro_X a ns1:Parametro ;
    rdfs:label "Parámetro X (coordenada X del centro del arco)"@es ;
    ns1:textoExtracto "parámetros X Y (centro del arco de mecanizado)"@es .

ns1:Parametro_Y a ns1:Parametro ;
    rdfs:label "Parámetro Y (coordenada Y del centro del arco)"@es ;
    ns1:textoExtracto "parámetros X Y (centro del arco de mecanizado)"@es .

ns1:Herramienta_G82 a ns1:Herramienta ;
    rdfs:label "Herramienta con diámetro configurado"@es ;
    ns1:documentadoEn ns1:TablaHerramientas ;
    ns1:textoExtracto "La herramienta tiene diámetro 0. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta."@es .

ns1:TablaHerramientas a ns1:Tabla ;
    rdfs:label "Tabla de herramientas"@es ;
    ns1:textoExtracto "Corregir el valor del radio en la tabla de herramientas"@es .

