@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Accion_ChangeHiddenAttribute a ns1:AccionProhibida ;
    rdfs:label "Change 'hidden' attribute (-H-)"@en ;
    ns1:habilitadoPor ns1:InterfazUsuario_UtilitiesMode ;
    ns1:textoExtracto "Change the 'hidden' attribute of the selected files. The attributes column shows the letter -H- indicating that the program will be hidden (not visible). This attribute allows protecting the files so they are not displayed when selecting a program to be edited or executed."@en .

ns1:Accion_ChangeModifiableAttribute a ns1:AccionProhibida ;
    rdfs:label "Change 'modifiable' attribute (-M-)"@en ;
    ns1:habilitadoPor ns1:InterfazUsuario_UtilitiesMode ;
    ns1:textoExtracto "Change the 'modifiable' attribute of the selected files. The attributes column shows the letter -M- indicating that the program may be modified. This attribute is used to protect the files so they can't be modified from the EDISIMU mode."@en .

ns1:Accion_Copy a ns1:AccionProhibida ;
    rdfs:label "Copy files"@en ;
    ns1:habilitadoPor ns1:InterfazUsuario_UtilitiesMode ;
    ns1:textoExtracto "Copy the selected files onto the clipboard."@en .

ns1:Accion_Cut a ns1:AccionProhibida ;
    rdfs:label "Cut files"@en ;
    ns1:habilitadoPor ns1:InterfazUsuario_UtilitiesMode ;
    ns1:textoExtracto "Cut the selected files onto the clipboard. With this option, when pasting the files to their new location, they are erased from the current folder."@en .

ns1:Accion_Delete a ns1:AccionProhibida ;
    rdfs:label "Delete file/folder"@en ;
    ns1:habilitadoPor ns1:InterfazUsuario_UtilitiesMode ;
    ns1:textoExtracto "Delete the selected folder or files. The folders can only be deleted if they are empty."@en .

ns1:Accion_Encrypt a ns1:AccionProhibida ;
    rdfs:label "Encrypt files"@en ;
    ns1:habilitadoPor ns1:InterfazUsuario_UtilitiesMode ;
    ns1:textoExtracto "Encrypt files. Encrypting may be used to protect any file (part-program, subroutine, etc.) making it illegible so it cannot be used by anyone else."@en .

ns1:Accion_Paste a ns1:AccionProhibida ;
    rdfs:label "Paste files"@en ;
    ns1:habilitadoPor ns1:InterfazUsuario_UtilitiesMode ;
    ns1:textoExtracto "Paste the files from the clipboard into the selected folder. If the files were placed using the 'Cut' option, they will be removed from their original location."@en .

ns1:Accion_Rename a ns1:AccionProhibida ;
    rdfs:label "Rename file/folder"@en ;
    ns1:habilitadoPor ns1:InterfazUsuario_UtilitiesMode ;
    ns1:textoExtracto "Rename the selected folder or file."@en .

ns1:InterfazUsuario_UtilitiesMode a ns1:InterfazUsuario ;
    rdfs:label "Utilities Mode Interface"@en ;
    ns1:textoExtracto "Softkey table describing file operations: Cut, Copy, Paste, Rename, Change 'modifiable' attribute (-M-), Change 'hidden' attribute (-H-), Encrypt, Delete."@en ;
    ns1:tieneComponente ns1:Accion_ChangeHiddenAttribute,
        ns1:Accion_ChangeModifiableAttribute,
        ns1:Accion_Copy,
        ns1:Accion_Cut,
        ns1:Accion_Delete,
        ns1:Accion_Encrypt,
        ns1:Accion_Paste,
        ns1:Accion_Rename .

