@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1832 a ns1:DiagnosticoFallo ;
    rdfs:label "DESBASTE: I = 0"@es ;
    ns1:identificador "1832" ;
    ns1:monitoreaParametro ns1:Parametro_I_1832 ;
    ns1:textoExtracto "1832 'DESBASTE: I = 0' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro I (paso máximo de profundización) tiene valor 0. SOLUCIÓN Asignar al parámetro un valor distinto de cero y menor que la longitud de corte de la herramienta."@es .

ns1:Fallo_1833 a ns1:DiagnosticoFallo ;
    rdfs:label "ACABADO: N = 0 y longitud de corte de herramienta no definida"@es ;
    ns1:identificador "1833" ;
    ns1:monitoreaParametro ns1:Parametro_N_1833 ;
    ns1:textoExtracto "1833 'ACABADO: N = 0 y longitud de corte de herramienta no definida' DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro N (número de pasadas de profundización) tiene valor 0 y la herramienta de acabado no tiene una longitud de corte definida. SOLUCIÓN Programar el número de pasadas de profundización (parámetro N) o definir la longitud de corte en la tabla de herramientas."@es .

ns1:Herramienta_Acabado_1833 a ns1:Herramienta ;
    ns1:textoExtracto "herramienta de acabado no tiene una longitud de corte definida"@es .

ns1:Herramienta_Desbaste_1832 a ns1:Herramienta ;
    ns1:textoExtracto "longitud de corte de la herramienta"@es .

ns1:Tabla_Herramientas a ns1:Tabla ;
    rdfs:label "Tabla de herramientas"@es ;
    ns1:textoExtracto "definir la longitud de corte en la tabla de herramientas"@es .

ns1:Parametro_I_1832 a ns1:Parametro ;
    rdfs:label "Parámetro I (paso máximo de profundización)"@es ;
    ns1:identificador "I" ;
    ns1:textoExtracto "El parámetro I (paso máximo de profundización) tiene valor 0."@es ;
    ns1:valor "0" .

ns1:Parametro_N_1833 a ns1:Parametro ;
    rdfs:label "Parámetro N (número de pasadas de profundización)"@es ;
    ns1:identificador "N" ;
    ns1:textoExtracto "El parámetro N (número de pasadas de profundización) tiene valor 0."@es ;
    ns1:valor "0" .

