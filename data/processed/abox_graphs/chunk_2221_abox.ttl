@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1834 a ns1:DiagnosticoFallo ;
    rdfs:label "ACABADO: Delta z mayor que longitud de corte de herramienta"@es ;
    ns1:solucionaFallo ns1:HerramientaDeAcabadoAlternativa,
        ns1:ParametroZDemasiaDeAcabado,
        ns1:TablaHerramientas ;
    ns1:textoExtracto "1834 'ACABADO: Delta z mayor que longitud de corte de herramienta' [...] CAUSA El parámetro δz (demasía de acabado en el fondo) supera la longitud de corte de la herramienta de acabado."@es .

ns1:Fallo_1835 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Z de seguridad no válida"@es ;
    ns1:solucionaFallo ns1:ParametroZsPlanoDeSeguridad ;
    ns1:textoExtracto "1835 'Cajera con islas: Z de seguridad no válida' [...] CAUSA El plano de seguridad (parámetro Zs) se encuentra dentro de la pieza."@es .

ns1:Fallo_1836 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Perfil en Z no válido"@es ;
    ns1:solucionaFallo ns1:Herramienta,
        ns1:VerificacionDePerfilesDeProfundidad ;
    ns1:textoExtracto "1836 'Cajera con islas: Perfil en Z no válido' [...] CAUSA Algún perfil de profundidad es cerrado o el ciclo no puede mecanizar algún perfil de profundidad con la herramienta programada."@es .

ns1:Fallo_1837 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Perfil en XY se corta a sí mismo"@es ;
    ns1:solucionaFallo ns1:ValidacionDePerfilesXYAutoIntersecciones ;
    ns1:textoExtracto "1837 'Cajera con islas: Perfil en XY se corta a si mismo' [...] CAUSA Algún perfil de superficie forma más de un perfil cerrado."@es .

ns1:Fallo_1838 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Perfil en XY no es cerrado"@es ;
    ns1:solucionaFallo ns1:CierreDePerfilesXY ;
    ns1:textoExtracto "1838 'Cajera con islas: Perfil en XY no es cerrado' [...] CAUSA Algún perfil de superficie no es un perfil cerrado, sus puntos inicial y final no son el mismo."@es .

ns1:Fallo_1839 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Intersección de perfiles en XY no válida"@es ;
    ns1:textoExtracto "1839 'Cajera con islas: Intersección de perfiles en XY no válida' [...] CAUSA Dos perfiles de superficie tienen algún tramo, recto o curvo, en común."@es .

ns1:Parametro_N a ns1:Parametro ;
    rdfs:label "Número de pasadas de profundización (N)"@es ;
    ns1:requiereMantenimiento ns1:ProgramacionDePasadasDeProfundizacion ;
    ns1:textoExtracto "Programar el número de pasadas de profundización (parámetro N) o definir la longitud de corte en la tabla de herramientas."@es ;
    ns1:valor "N" .

ns1:AjusteDeParametroZEnCicloDeAcabado a ns1:TareaMantenimiento ;
    rdfs:label "Ajuste de parámetro δz en ciclo de acabado"@es ;
    ns1:textoExtracto "Programar una demasía de acabado menor (parámetro δz) o utilizar otra herramienta."@es .

ns1:CierreDePerfilesXY a ns1:TareaMantenimiento ;
    rdfs:label "Cierre de perfiles XY"@es ;
    ns1:textoExtracto "Comprobar que todos los perfiles de superficie sean cerrados."@es .

ns1:CorreccionDePlanoDeSeguridadZs a ns1:TareaMantenimiento ;
    rdfs:label "Corrección de plano de seguridad (Zs)"@es ;
    ns1:textoExtracto "Asignar un valor correcto al parámetro."@es .

ns1:HerramientaDeAcabadoAlternativa a ns1:Herramienta ;
    rdfs:label "Herramienta de acabado alternativa"@es ;
    ns1:textoExtracto "utilizar otra herramienta."@es .

ns1:LongitudDeCorteDeHerramienta a ns1:Parametro ;
    rdfs:label "Longitud de corte de herramienta"@es ;
    ns1:textoExtracto "longitud de corte de la herramienta"@es .

ns1:ParametroZDemasiaDeAcabado a ns1:Parametro ;
    rdfs:label "Parámetro δz (demasía de acabado)"@es ;
    ns1:requiereMantenimiento ns1:AjusteDeParametroZEnCicloDeAcabado ;
    ns1:textoExtracto "Programar una demasía de acabado menor (parámetro δz)."@es ;
    ns1:valor "δz" .

ns1:ParametroZsPlanoDeSeguridad a ns1:Parametro ;
    rdfs:label "Parámetro Zs (plano de seguridad)"@es ;
    ns1:requiereMantenimiento ns1:CorreccionDePlanoDeSeguridadZs ;
    ns1:textoExtracto "Asignar un valor correcto al parámetro [Zs]."@es ;
    ns1:valor "Zs" .

ns1:ProgramacionDePasadasDeProfundizacion a ns1:TareaMantenimiento ;
    rdfs:label "Programación de pasadas de profundización"@es ;
    ns1:textoExtracto "Programar el número de pasadas de profundización (parámetro N)."@es .

ns1:TablaHerramientas a ns1:Tabla ;
    rdfs:label "Tabla de herramientas de mecanizado"@es ;
    ns1:documentadoEn ns1:LongitudDeCorteDeHerramienta ;
    ns1:textoExtracto "definir la longitud de corte en la tabla de herramientas."@es .

ns1:ValidacionDePerfilesXYAutoIntersecciones a ns1:TareaMantenimiento ;
    rdfs:label "Validación de perfiles XY (auto-intersecciones)"@es ;
    ns1:textoExtracto "Comprobar que los perfiles de superficie no se cortan a sí mismos y que sólo tienen el punto inicial en común."@es .

ns1:VerificacionDePerfilesDeProfundidad a ns1:TareaMantenimiento ;
    rdfs:label "Verificación de perfiles de profundidad"@es ;
    ns1:textoExtracto "Comprobar que los perfiles de profundidad son correctos."@es .

