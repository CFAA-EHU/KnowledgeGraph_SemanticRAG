@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CicloEjecucion a ns1:Sistema ;
    rdfs:label "Sistema de ejecución del ciclo" ;
    ns1:activaAlarma ns1:DiagnosticoFallo_1839,
        ns1:DiagnosticoFallo_1840 ;
    ns1:textoExtracto "Durante la ejecución del ciclo" .

ns1:DiagnosticoFallo_1839 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Intersección de perfiles en XY no válida" ;
    ns1:identificador "1839" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Dos perfiles de superficie tienen algún tramo, recto o curvo, en común. SOLUCIÓN Comprobar que los perfiles de superficie no tienen tramos en común, la intersección de los perfiles se deben producir en puntos." .

ns1:DiagnosticoFallo_1840 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Memoria insuficiente para su resolución" ;
    ns1:identificador "1840" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El sistema no" .

