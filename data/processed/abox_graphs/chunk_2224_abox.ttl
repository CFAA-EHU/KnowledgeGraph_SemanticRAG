@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1845 a ns1:DiagnosticoFallo ;
    rdfs:label "G165: Longitud de la cuerda (I) mayor que diámetro"@es ;
    ns1:identificador "1845" ;
    ns1:monitoreaParametro ns1:Parametro_I ;
    ns1:textoExtracto "1845 'G165: Longitud de la cuerda (I) mayor que diámetro' DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA La longitud de la cuerda (parámetro I) es mayor que el diámetro del círculo. SOLUCIÓN Asignar un valor correcto al parámetro."@es .

ns1:Fallo_1846 a ns1:DiagnosticoFallo ;
    rdfs:label "Radio del arco nulo"@es ;
    ns1:identificador "1846" ;
    ns1:textoExtracto "1846 'Radio del arco nulo' DETECCIÓN Durante la ejecución de un ciclo de mecanizado"@es .

ns1:HerramientaAlternativa a ns1:Herramienta ;
    ns1:textoExtracto "seleccionar otra herramienta"@es .

ns1:Parametro_Radio a ns1:Parametro ;
    rdfs:label "Radio"@es ;
    ns1:textoExtracto "valor del radio"@es .

ns1:TablaHerramientas a ns1:Tabla ;
    rdfs:label "Tabla de herramientas"@es ;
    ns1:textoExtracto "SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta."@es .

ns1:Parametro_I a ns1:Parametro ;
    rdfs:label "Longitud de la cuerda (I)"@es ;
    ns1:textoExtracto "parámetro I"@es ;
    ns1:valor "I" .

