@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Herramienta_CajeraRectangular a ns1:Herramienta ;
    rdfs:label "Herramienta para cajera rectangular" ;
    ns1:textoExtracto "el diámetro de la herramienta" .

ns1:Parametro_Delta a ns1:Parametro ;
    rdfs:label "Parámetro δ (demasía de acabado lateral)" ;
    ns1:solucionaFallo ns1:Fallo_1849 ;
    ns1:textoExtracto "dos veces el parámetro δ" .

ns1:Parametro_I a ns1:Parametro ;
    rdfs:label "Parámetro I (longitud de la cuerda)" ;
    ns1:solucionaFallo ns1:Fallo_1846 ;
    ns1:textoExtracto "la cuerda (parámetro I) es mayor que el diámetro del círculo" .

ns1:Parametro_Ix a ns1:Parametro ;
    rdfs:label "Parámetro Ix (distancia entre mecanizados en eje X)" ;
    ns1:solucionaFallo ns1:Fallo_1850 ;
    ns1:textoExtracto "distancia entre mecanizados (parámetro Ix)" .

ns1:Parametro_Iy a ns1:Parametro ;
    rdfs:label "Parámetro Iy (distancia entre mecanizados en eje Y)" ;
    ns1:solucionaFallo ns1:Fallo_1851 ;
    ns1:textoExtracto "Ly ha de ser múltiplo de Iy" .

ns1:Parametro_Lx a ns1:Parametro ;
    rdfs:label "Parámetro Lx (longitud del mecanizado)" ;
    ns1:solucionaFallo ns1:Fallo_1850 ;
    ns1:textoExtracto "La longitud del mecanizado (parámetro Lx)" .

ns1:Parametro_Ly a ns1:Parametro ;
    rdfs:label "Parámetro Ly (longitud del mecanizado en eje Y)" ;
    ns1:solucionaFallo ns1:Fallo_1851 ;
    ns1:textoExtracto "Ly ha de ser múltiplo de Iy" .

ns1:Parametro_Q_MOYU_Circular a ns1:Parametro ;
    rdfs:label "Parámetro Q (material a eliminar, MOYU circular)" ;
    ns1:solucionaFallo ns1:Fallo_1848 ;
    ns1:textoExtracto "El parámetro Q (material a eliminar) tiene valor 0." ;
    ns1:valor "0" .

ns1:Parametro_Q_MOYU_Rectangular a ns1:Parametro ;
    rdfs:label "Parámetro Q (material a eliminar, MOYU rectangular)" ;
    ns1:solucionaFallo ns1:Fallo_1847 ;
    ns1:textoExtracto "El parámetro Q (material a eliminar) tiene valor 0." ;
    ns1:valor "0" .

ns1:Fallo_1846 a ns1:DiagnosticoFallo ;
    rdfs:label "Radio del arco nulo" ;
    ns1:identificador "1846" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA Las posibles causas son las siguientes: • En el perfil hay un tramo curvo con radio cero. • En un mecanizado múltiple en arco o circunferencia, ambas coordenadas del centro coinciden con el punto inicial. SOLUCIÓN Revisar la programación." .

ns1:Fallo_1847 a ns1:DiagnosticoFallo ;
    rdfs:label "MOYU RECTANGULAR: Q = 0" ;
    ns1:identificador "1847" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro Q (material a eliminar) tiene valor 0. SOLUCIÓN Asignar al parámetro un valor distinto de cero." .

ns1:Fallo_1848 a ns1:DiagnosticoFallo ;
    rdfs:label "MOYU CIRCULAR: Q = 0" ;
    ns1:identificador "1848" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El parámetro Q (material a eliminar) tiene valor 0. SOLUCIÓN Asignar al parámetro un valor distinto de cero." .

ns1:Fallo_1849 a ns1:DiagnosticoFallo ;
    rdfs:label "CAJERA RECTANGULAR: Demasía de acabado DELTA mayor que cajera" ;
    ns1:identificador "1849" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El tamaño de la cajera menos el diámetro de la herramienta es menor que las demasías de acabado laterales (dos veces el parámetro δ). SOLUCIÓN Asignar un valor correcto al parámetro." .

ns1:Fallo_1850 a ns1:DiagnosticoFallo ;
    rdfs:label "Lx ha de ser múltiplo de Ix" ;
    ns1:identificador "1850" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple. CAUSA La longitud del mecanizado (parámetro Lx) ha de ser múltiplo de la distancia entre mecanizados (parámetro Ix). SOLUCIÓN Asignar un valor correcto a los parámetros." .

ns1:Fallo_1851 a ns1:DiagnosticoFallo ;
    rdfs:label "Ly ha de ser múltiplo de Iy" ;
    ns1:identificador "1851" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución de un ciclo de mecanizado múltiple." .

