@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1851 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1851: 'Ly ha de ser múltiplo de Iy'" ;
    ns1:identificador "1851" ;
    ns1:monitoreaParametro ns1:Parametro_Iy,
        ns1:Parametro_Ly ;
    ns1:solucionaFallo ns1:AccionProhibida_AsignacionIncorrectaLyIy ;
    ns1:textoExtracto "1851 'Ly ha de ser múltiplo de Iy' [...] La longitud del mecanizado (parámetro Ly) ha de ser múltiplo de la distancia entre mecanizados (parámetro Iy)." .

ns1:DiagnosticoFallo_1852 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1852: 'No hay herramienta programada'" ;
    ns1:identificador "1852" ;
    ns1:requiereConsumible ns1:Herramienta_Cabezal,
        ns1:Palpador_Cabezal ;
    ns1:solucionaFallo ns1:AccionProhibida_FaltaHerramientaPalpador ;
    ns1:textoExtracto "1852 'No hay herramienta programada' [...] No hay herramienta o palpador en el cabezal para poder ejecutar el ciclo fijo." .

ns1:DiagnosticoFallo_1853 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1853: 'No se ha recibido señal del palpador'" ;
    ns1:identificador "1853" ;
    ns1:monitoreaParametro ns1:Sensor_Palpador ;
    ns1:textoExtracto "1853 'No se ha recibido señal del palpador' [...] Durante la" .

ns1:AccionProhibida_AsignacionIncorrectaLyIy a ns1:AccionProhibida ;
    rdfs:label "Asignación incorrecta de valores a Ly/Iy" ;
    ns1:textoExtracto "Asignar un valor correcto a los parámetros." .

ns1:AccionProhibida_FaltaHerramientaPalpador a ns1:AccionProhibida ;
    rdfs:label "Ejecutar ciclo fijo sin herramienta/palpador en cabezal" ;
    ns1:textoExtracto "Colocar una herramienta o un palpador en el cabezal, dependiendo del ciclo fijo." .

ns1:Herramienta_Cabezal a ns1:Herramienta ;
    rdfs:label "Herramienta en cabezal" ;
    ns1:textoExtracto "No hay herramienta [...] en el cabezal para poder ejecutar el ciclo fijo." .

ns1:Palpador_Cabezal a ns1:Herramienta ;
    rdfs:label "Palpador en cabezal" ;
    ns1:textoExtracto "No hay [...] palpador en el cabezal para poder ejecutar el ciclo fijo." .

ns1:Parametro_Iy a ns1:Parametro ;
    rdfs:label "Parámetro Iy (distancia entre mecanizados)" ;
    ns1:textoExtracto "distancia entre mecanizados (parámetro Iy)" ;
    ns1:valor "Iy" .

ns1:Parametro_Ly a ns1:Parametro ;
    rdfs:label "Parámetro Ly (longitud del mecanizado)" ;
    ns1:textoExtracto "La longitud del mecanizado (parámetro Ly)" ;
    ns1:valor "Ly" .

