@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alerta_1853 a ns1:AvisoSeguridad ;
    rdfs:label "No se ha recibido señal del palpador"@es ;
    ns1:identificador "1853" ;
    ns1:solucionaFallo ns1:Palpador ;
    ns1:textoExtracto "1853 'No se ha recibido señal del palpador' DETECCIÓN Durante la ejecución de un ciclo de palpador #PROBE. CAUSA El palpador no ha tocado la pieza durante el movimiento de palpación."@es .

ns1:Alerta_1854 a ns1:AvisoSeguridad ;
    rdfs:label "El diámetro J debe ser mayor que cero"@es ;
    ns1:identificador "1854" ;
    ns1:monitoreaParametro ns1:Parametro_J ;
    ns1:textoExtracto "1854 'El diámetro J debe ser mayor que cero' DETECCIÓN Durante la ejecución del ciclo de palpador #PROBE 2 o #PROBE 9. CAUSA El parámetro J (diámetro teórico del agujero) tiene un valor incorrecto."@es .

ns1:Alerta_1855 a ns1:AvisoSeguridad ;
    rdfs:label "Diámetro de herramienta mayor que el del agujero"@es ;
    ns1:identificador "1855" ;
    ns1:monitoreaParametro ns1:Parametro_J ;
    ns1:textoExtracto "1855 'Diámetro de herramienta mayor que el del agujero' DETECCIÓN Durante la ejecución del ciclo de palpador #PROBE 2 o #PROBE 9. CAUSA El diámetro del palpador es mayor que el diámetro del agujero a medir o que el agujero utilizado para calibrar el palpador."@es .

ns1:Alerta_1856 a ns1:AvisoSeguridad ;
    rdfs:label "Distancia de retroceso E incorrecta"@es ;
    ns1:identificador "1856" ;
    ns1:monitoreaParametro ns1:Parametro_E ;
    ns1:textoExtracto "1856 'Distancia de retroceso E incorrecta' DETECCIÓN Durante la ejecución del ciclo de palpador #PROBE 2 o #PROBE 9. CAUSA El parámetro E (distancia de retroceso) tiene un valor incorrecto."@es .

ns1:Alerta_1857 a ns1:AvisoSeguridad ;
    rdfs:label "No hay corrector seleccionado"@es ;
    ns1:identificador "1857" ;
    ns1:monitoreaParametro ns1:CorrectorHerramienta ;
    ns1:textoExtracto "1857 'No hay corrector seleccionado' DETECCIÓN Durante la ejecución del ciclo de palpador #PROBE 1 o #PROBE 2. CAUSA No hay corrector de herramienta activo para el ciclo de calibración de herramienta."@es .

ns1:Alerta_1858 a ns1:AvisoSeguridad ;
    rdfs:label "Programar I = 0/1"@es ;
    ns1:identificador "1858" ;
    ns1:monitoreaParametro ns1:Parametro_I ;
    ns1:textoExtracto "1858 'Programar I = 0/1' DETECCIÓN Durante la ejecución de un ciclo de palpador #PROBE. CAUSA El parámetro I (tipo de calibración) tiene un valor incorrecto."@es .

ns1:CicloPROBE a ns1:ModoOperacion ;
    rdfs:label "Ciclo de palpador #PROBE"@es ;
    ns1:identificador "#PROBE" ;
    ns1:requiereMantenimiento ns1:Palpador ;
    ns1:textoExtracto "ciclo de palpador #PROBE"@es .

ns1:CicloPROBE1 a ns1:ModoOperacion ;
    rdfs:label "Ciclo de palpador #PROBE 1"@es ;
    ns1:identificador "#PROBE 1" ;
    ns1:requiereMantenimiento ns1:Palpador ;
    ns1:textoExtracto "ciclo de palpador #PROBE 1"@es .

ns1:CicloPROBE2 a ns1:ModoOperacion ;
    rdfs:label "Ciclo de palpador #PROBE 2"@es ;
    ns1:identificador "#PROBE 2" ;
    ns1:requiereMantenimiento ns1:Palpador ;
    ns1:textoExtracto "ciclo de palpador #PROBE 2"@es .

ns1:CicloPROBE9 a ns1:ModoOperacion ;
    rdfs:label "Ciclo de palpador #PROBE 9"@es ;
    ns1:identificador "#PROBE 9" ;
    ns1:requiereMantenimiento ns1:Palpador ;
    ns1:textoExtracto "ciclo de palpador #PROBE 9"@es .

ns1:CorrectorHerramienta a ns1:Parametro ;
    rdfs:label "Corrector de herramienta (función D)"@es ;
    ns1:identificador "D" ;
    ns1:textoExtracto "No hay corrector de herramienta activo para el ciclo de calibración de herramienta. SOLUCIÓN Programar el corrector (función D) antes del ciclo."@es .

ns1:Herramienta a ns1:Herramienta ;
    rdfs:label "Herramienta para cabezal"@es ;
    ns1:textoExtracto "Colocar una herramienta o un palpador en el cabezal, dependiendo del ciclo fijo."@es .

ns1:Parametro_E a ns1:Parametro ;
    rdfs:label "Distancia de retroceso (E)"@es ;
    ns1:identificador "E" ;
    ns1:textoExtracto "El parámetro E (distancia de retroceso) tiene un valor incorrecto."@es ;
    ns1:valor "0..diámetro_agujero" .

ns1:Parametro_I a ns1:Parametro ;
    rdfs:label "Tipo de calibración (I)"@es ;
    ns1:identificador "I" ;
    ns1:textoExtracto "El parámetro I (tipo de calibración) tiene un valor incorrecto."@es ;
    ns1:valor "0/1" .

ns1:Parametro_J a ns1:Parametro ;
    rdfs:label "Diámetro teórico del agujero (J)"@es ;
    ns1:identificador "J" ;
    ns1:textoExtracto "El parámetro J (diámetro teórico del agujero) tiene un valor incorrecto."@es ;
    ns1:valor ">0" .

ns1:Palpador a ns1:Sensor ;
    rdfs:label "Palpador"@es ;
    ns1:textoExtracto "Colocar una herramienta o un palpador en el cabezal, dependiendo del ciclo fijo. [...] El palpador no ha tocado la pieza durante el movimiento de palpación."@es .

