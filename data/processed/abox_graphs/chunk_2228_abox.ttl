@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Aviso_ParametroI_Incorrecto_1858 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1858: Valor incorrecto en parámetro I"@es ;
    ns1:identificador "1858" ;
    ns1:mitigaRiesgo ns1:Parametro_I ;
    ns1:textoExtracto "'Programar I = 0/1' [...] El parámetro I (tipo de calibración) tiene un valor incorrecto."@es .

ns1:Aviso_PlanoInvalido_1859 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1859: Plano activo incorrecto para calibrado de palpador"@es ;
    ns1:identificador "1859" ;
    ns1:mitigaRiesgo ns1:CicloPalpador_PROBE ;
    ns1:textoExtracto "'El plano activo para calibrado de palpador debe ser G17, G18 o G19' [...] Activar un plano principal G17, G18 o G19 para ejecutar el ciclo."@es .

ns1:Parametro_I a ns1:Parametro ;
    rdfs:label "Parámetro I (tipo de calibración)"@es ;
    ns1:monitoreaParametro ns1:CicloPalpador_PROBE ;
    ns1:textoExtracto "El parámetro I (tipo de calibración) tiene un valor incorrecto. [...] El parámetro I sólo admite los valores 0 (calibración simple) ó 1 (calibración doble)."@es ;
    ns1:valor "0,1" .

ns1:Tarea_CalibracionPalpador a ns1:TareaMantenimiento ;
    rdfs:label "Calibración de palpador"@es ;
    ns1:textoExtracto "Programar el corrector (función D) antes del ciclo. [...] El parámetro I sólo admite los valores 0 (calibración simple) ó 1 (calibración doble)."@es .

ns1:CicloPalpador_PROBE a ns1:ModoOperacion ;
    rdfs:label "Ciclo de palpador #PROBE"@es ;
    ns1:requiereMantenimiento ns1:Tarea_CalibracionPalpador ;
    ns1:textoExtracto "Durante la ejecución de un ciclo de palpador #PROBE. [...] Durante la ejecución del ciclo de palpador #PROBE 2."@es .

