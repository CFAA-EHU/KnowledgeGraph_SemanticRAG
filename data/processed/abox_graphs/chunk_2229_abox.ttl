@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1860 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de plano de trabajo en ciclo #PROBE 2"@es ;
    ns1:identificador "1860" ;
    ns1:solucionaFallo ns1:Parametro_G20_PlanoTrabajo ;
    ns1:textoExtracto "CAUSA: A la hora de ejecutar el ciclo, hay activo un plano de trabajo definido con G20. SOLUCIÓN: Activar un plano principal G17, G18 o G19 para ejecutar el ciclo."@es .

ns1:Fallo_1861 a ns1:DiagnosticoFallo ;
    rdfs:label "Valor incorrecto del parámetro K en ciclo #PROBE 3"@es ;
    ns1:identificador "1861" ;
    ns1:solucionaFallo ns1:Parametro_K_EjePalpacion ;
    ns1:textoExtracto "CAUSA: El parámetro K (eje de palpación) tiene un valor incorrecto. SOLUCIÓN: El parámetro K sólo admite los valores 0 (eje de abscisas), 1 (eje de ordenadas) ó 2 (eje longitudinal)."@es .

ns1:Fallo_1862 a ns1:DiagnosticoFallo ;
    rdfs:label "Plano G20 no admitido en ciclo #PROBE 1"@es ;
    ns1:identificador "1862" ;
    ns1:solucionaFallo ns1:Parametro_G20_PlanoTrabajo ;
    ns1:textoExtracto "CAUSA: A la hora de ejecutar el ciclo, hay activo un plano de trabajo definido con G20. SOLUCIÓN: Activar un plano principal G17, G18 o G19 para ejecutar el ciclo."@es .

ns1:Fallo_1863 a ns1:DiagnosticoFallo ;
    rdfs:label "Herramienta gastada detectada en ciclo #PROBE 1"@es ;
    ns1:identificador "1863" ;
    ns1:requiereMantenimiento ns1:Tarea_CambioHerramienta ;
    ns1:solucionaFallo ns1:Parametro_M_ToleranciaDesgaste ;
    ns1:textoExtracto "CAUSA: El ciclo ha detectado que la herramienta está gastada. El desgaste medido es mayor que la tolerancia permitida (parámetro M). SOLUCIÓN: Cambiar de herramienta y volver a ejecutar el ciclo."@es .

ns1:Fallo_1864 a ns1:DiagnosticoFallo ;
    rdfs:label "Posición incorrecta del palpador en ciclo #PROBE 1"@es ;
    ns1:identificador "1864" ;
    ns1:solucionaFallo ns1:Parametro_UVW_CotasMaximas,
        ns1:Parametro_XYZ_CotasMinimas ;
    ns1:textoExtracto "CAUSA: En el ciclo está mal definida la posición del palpador de sobremesa. Alguno de los parámetros X Y Z es mayor que su correspondiente parámetro U V W. Los parámetros X Y Z hacen referencia a las cotas mínimas del palpador y los parámetros U V W hacen referencia a las cotas máximas."@es .

ns1:Herramienta_Gastada a ns1:Consumible ;
    rdfs:label "Herramienta con desgaste de radio"@es ;
    ns1:requiereMantenimiento ns1:Tarea_CambioHerramienta ;
    ns1:textoExtracto "El ciclo ha detectado que la herramienta está gastada."@es .

ns1:Palpador_Sobremesa a ns1:Sensor ;
    rdfs:label "Palpador de sobremesa"@es ;
    ns1:monitoreaParametro ns1:Parametro_UVW_CotasMaximas,
        ns1:Parametro_XYZ_CotasMinimas ;
    ns1:textoExtracto "posición del palpador de sobremesa"@es .

ns1:Parametro_B_DistanciaSeguridad a ns1:Parametro ;
    rdfs:label "Parámetro B (distancia de seguridad)"@es ;
    ns1:identificador "B" ;
    ns1:textoExtracto "El parámetro B tiene valor negativo. [...] Asignar al parámetro un valor positivo."@es ;
    ns1:valor ">0" .

ns1:Parametro_K_EjePalpacion a ns1:Parametro ;
    rdfs:label "Parámetro K (eje de palpación)"@es ;
    ns1:identificador "K" ;
    ns1:textoExtracto "El parámetro K (eje de palpación) tiene un valor incorrecto. [...] 0 (eje de abscisas), 1 (eje de ordenadas) ó 2 (eje longitudinal)."@es ;
    ns1:valor "0|1|2" .

ns1:Parametro_M_ToleranciaDesgaste a ns1:Parametro ;
    rdfs:label "Parámetro M (tolerancia de desgaste de herramienta)"@es ;
    ns1:identificador "M" ;
    ns1:textoExtracto "El desgaste medido es mayor que la tolerancia permitida (parámetro M)."@es .

ns1:Parametro_G20_PlanoTrabajo a ns1:Parametro ;
    rdfs:label "Parámetro G20 (plano de trabajo secundario)"@es ;
    ns1:identificador "G20" ;
    ns1:textoExtracto "plano de trabajo definido con G20"@es ;
    ns1:valor "plano_secundario" .

ns1:Parametro_UVW_CotasMaximas a ns1:Parametro ;
    rdfs:label "Parámetros U, V, W (cotas máximas del palpador)"@es ;
    ns1:identificador "U|V|W" ;
    ns1:textoExtracto "los parámetros U V W hacen referencia a las cotas máximas."@es .

ns1:Parametro_XYZ_CotasMinimas a ns1:Parametro ;
    rdfs:label "Parámetros X, Y, Z (cotas mínimas del palpador)"@es ;
    ns1:identificador "X|Y|Z" ;
    ns1:textoExtracto "Los parámetros X Y Z hacen referencia a las cotas mínimas del palpador"@es .

ns1:Tarea_CambioHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta por desgaste"@es ;
    ns1:textoExtracto "Cambiar de herramienta y volver a ejecutar el ciclo."@es .

