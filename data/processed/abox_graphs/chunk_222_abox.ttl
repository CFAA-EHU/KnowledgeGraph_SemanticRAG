@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_UTILITIES a ns1:ModoOperacion ;
    rdfs:label "UTILITIES MODE"@en ;
    ns1:documentadoEn ns1:Tabla_ComandosProgramacion_UTILITIES_MODE ;
    ns1:textoExtracto "UTILITIES MODE. - PROGRAMMING COMMANDS."@en .

ns1:Tabla_ComandosProgramacion_UTILITIES_MODE a ns1:Tabla ;
    rdfs:label "Programming Commands Table (UTILITIES MODE)"@en ;
    ns1:identificador "UTILITIES_MODE_Programming_Commands" ;
    ns1:textoExtracto "Command. | Meaning. | Format. | | --- | --- | --- | | / | Block skip condition. | | # | Programming instructions. | | $ | Flow controlling instructions. | | % | Program header. | 14 characters. ( 1) | ; (semi-colon) | Bl..."@en .

