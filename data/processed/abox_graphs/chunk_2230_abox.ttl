@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1865 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1865: Cajera con islas - No existe T de desbaste"@es ;
    ns1:identificador "1865" ;
    ns1:textoExtracto "1865 'Cajera con islas: No existe T de desbaste' DETECCIÓN Durante la ejecución del ciclo. CAUSA La herramienta programada no existe en la tabla de herramientas. SOLUCIÓN Definir la herramienta en la tabla o seleccionar otra herramienta."@es .

ns1:Herramienta_Desbaste a ns1:Herramienta ;
    rdfs:label "Herramienta de desbaste (T)"@es ;
    ns1:documentadoEn ns1:TablaHerramientas ;
    ns1:textoExtracto "No existe T de desbaste"@es .

ns1:Sensor_Palpador a ns1:Sensor ;
    rdfs:label "Palpador"@es ;
    ns1:monitoreaParametro ns1:Parametro_U,
        ns1:Parametro_V,
        ns1:Parametro_W,
        ns1:Parametro_X,
        ns1:Parametro_Y,
        ns1:Parametro_Z ;
    ns1:textoExtracto "Los parámetros X Y Z hacen referencia a las cotas mínimas del palpador y los parámetros U V W hacen referencia a las cotas máximas"@es .

ns1:Parametro_U a ns1:Parametro ;
    rdfs:label "Parámetro U (cota máxima del palpador)"@es ;
    ns1:textoExtracto "los parámetros U V W hacen referencia a las cotas máximas"@es ;
    ns1:valor "cota_máxima_U" .

ns1:Parametro_V a ns1:Parametro ;
    rdfs:label "Parámetro V (cota máxima del palpador)"@es ;
    ns1:textoExtracto "los parámetros U V W hacen referencia a las cotas máximas"@es ;
    ns1:valor "cota_máxima_V" .

ns1:Parametro_W a ns1:Parametro ;
    rdfs:label "Parámetro W (cota máxima del palpador)"@es ;
    ns1:textoExtracto "los parámetros U V W hacen referencia a las cotas máximas"@es ;
    ns1:valor "cota_máxima_W" .

ns1:Parametro_X a ns1:Parametro ;
    rdfs:label "Parámetro X (cota mínima del palpador)"@es ;
    ns1:textoExtracto "Los parámetros X Y Z hacen referencia a las cotas mínimas del palpador"@es ;
    ns1:valor "cota_mínima_X" .

ns1:Parametro_Y a ns1:Parametro ;
    rdfs:label "Parámetro Y (cota mínima del palpador)"@es ;
    ns1:textoExtracto "Los parámetros X Y Z hacen referencia a las cotas mínimas del palpador"@es ;
    ns1:valor "cota_mínima_Y" .

ns1:Parametro_Z a ns1:Parametro ;
    rdfs:label "Parámetro Z (cota mínima del palpador)"@es ;
    ns1:textoExtracto "Los parámetros X Y Z hacen referencia a las cotas mínimas del palpador"@es ;
    ns1:valor "cota_mínima_Z" .

ns1:TablaHerramientas a ns1:Tabla ;
    rdfs:label "Tabla de herramientas"@es ;
    ns1:textoExtracto "La herramienta programada no existe en la tabla de herramientas"@es .

