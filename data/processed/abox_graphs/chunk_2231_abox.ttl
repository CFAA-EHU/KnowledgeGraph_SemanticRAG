@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_1866 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1866: 'Cajera con islas: F de desbaste no válida'"@es ;
    ns1:mitigaRiesgo ns1:Parametro_AvanceDesbaste_1866 ;
    ns1:textoExtracto "1866 'Cajera con islas: F de desbaste no válida' [...] SOLUCIÓN Definir un avance mayor que 0."@es .

ns1:AvisoSeguridad_1867 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1867: 'Cajera con islas: S de desbaste no válida'"@es ;
    ns1:mitigaRiesgo ns1:Parametro_VelocidadDesbaste_1867 ;
    ns1:textoExtracto "1867 'Cajera con islas: S de desbaste no válida' [...] SOLUCIÓN Definir una velocidad mayor que 0."@es .

ns1:AvisoSeguridad_1868 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1868: 'Cajera con islas: No existe T de acabado'"@es ;
    ns1:mitigaRiesgo ns1:Herramienta_Acabado_1868 ;
    ns1:textoExtracto "1868 'Cajera con islas: No existe T de acabado' [...] SOLUCIÓN Definir la herramienta en la tabla o seleccionar otra herramienta."@es .

ns1:AvisoSeguridad_1871 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 1871: 'Cajera con islas: Paso de desbaste no válido'"@es ;
    ns1:mitigaRiesgo ns1:Parametro_PasoDesbaste_1871 ;
    ns1:textoExtracto "1871 'Cajera con islas: Paso de desbaste no válido' [...] SOLUCIÓN Corregir el paso de mecanizado o seleccionar otra herramienta."@es .

ns1:ModoOperacion_CajeraConIslas a ns1:ModoOperacion ;
    rdfs:label "Operación: Cajera con islas"@es ;
    ns1:requiereMantenimiento ns1:TablaHerramientas_CajeraConIslas ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo."@es .

ns1:Parametro_AvanceAcabado_1869 a ns1:Parametro ;
    rdfs:label "Avance de acabado (F)"@es ;
    ns1:documentadoEn ns1:TablaHerramientas_CajeraConIslas ;
    ns1:textoExtracto "El avance para la operación de acabado tiene valor 0."@es ;
    ns1:valor "0" .

ns1:Parametro_VelocidadAcabado_1870 a ns1:Parametro ;
    rdfs:label "Velocidad de acabado (S)"@es ;
    ns1:documentadoEn ns1:TablaHerramientas_CajeraConIslas ;
    ns1:textoExtracto "La velocidad para la operación de acabado tiene valor 0."@es ;
    ns1:valor "0" .

ns1:Herramienta_Acabado_1868 a ns1:Herramienta ;
    rdfs:label "Herramienta de acabado (T)"@es ;
    ns1:documentadoEn ns1:TablaHerramientas_CajeraConIslas ;
    ns1:textoExtracto "La herramienta programada no existe en la tabla de herramientas."@es .

ns1:Parametro_AvanceDesbaste_1866 a ns1:Parametro ;
    rdfs:label "Avance de desbaste (F)"@es ;
    ns1:documentadoEn ns1:TablaHerramientas_CajeraConIslas ;
    ns1:textoExtracto "El avance para la operación de desbaste tiene valor 0."@es ;
    ns1:valor "0" .

ns1:Parametro_PasoDesbaste_1871 a ns1:Parametro ;
    rdfs:label "Paso de mecanizado para desbaste (Δ)"@es ;
    ns1:documentadoEn ns1:TablaHerramientas_CajeraConIslas ;
    ns1:textoExtracto "El paso de mecanizado para el desbaste (parámetro Δ) es mayor que el diámetro de la herramienta."@es .

ns1:Parametro_VelocidadDesbaste_1867 a ns1:Parametro ;
    rdfs:label "Velocidad de desbaste (S)"@es ;
    ns1:documentadoEn ns1:TablaHerramientas_CajeraConIslas ;
    ns1:textoExtracto "La velocidad para la operación de desbaste tiene valor 0."@es ;
    ns1:valor "0" .

ns1:TablaHerramientas_CajeraConIslas a ns1:Tabla ;
    rdfs:label "Tabla de herramientas para operación 'Cajera con islas'"@es ;
    ns1:identificador "Tabla_Herramientas_CajeraConIslas" ;
    ns1:textoExtracto "La herramienta programada no existe en la tabla de herramientas."@es .

