@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Fallo_1873 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Demasía lateral no válida" ;
    ns1:identificador "1873" ;
    ns1:monitoreaParametro ns1:Parametro_Delta_1873 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA La demasía lateral para el acabado (parámetro δ) es mayor que el diámetro de la herramienta." .

ns1:TareaMantenimiento_CorreccionPaso a ns1:TareaMantenimiento ;
    rdfs:label "Corregir paso de mecanizado" ;
    ns1:solucionaFallo ns1:Fallo_1872 ;
    ns1:textoExtracto "SOLUCIÓN Corregir el paso de mecanizado." .

ns1:TareaMantenimiento_SeleccionHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Seleccionar otra herramienta" ;
    ns1:requiereConsumible ns1:Herramienta_Mecanizado ;
    ns1:solucionaFallo ns1:Fallo_1872 ;
    ns1:textoExtracto "SOLUCIÓN Corregir el paso de mecanizado o seleccionar otra herramienta." .

ns1:Herramienta_Mecanizado a ns1:Herramienta ;
    rdfs:label "Herramienta de mecanizado" ;
    ns1:textoExtracto "seleccionar otra herramienta" .

ns1:Parametro_Delta a ns1:Parametro ;
    rdfs:label "Paso de mecanizado para acabado (Δ)" ;
    ns1:textoExtracto "parámetro Δ" ;
    ns1:valor "mayor que el diámetro de la herramienta"^^xsd:string .

ns1:Parametro_Delta_1873 a ns1:Parametro ;
    rdfs:label "Demasía lateral para acabado (δ)" ;
    ns1:textoExtracto "parámetro δ" ;
    ns1:valor "mayor que el diámetro de la herramienta"^^xsd:string .

ns1:Parametro_Epsilon a ns1:Parametro ;
    rdfs:label "Paso de mecanizado para acabado (ε)" ;
    ns1:textoExtracto "parámetro ε" ;
    ns1:valor "cero"^^xsd:string .

ns1:Fallo_1872 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Paso de acabado no válido" ;
    ns1:identificador "1872" ;
    ns1:monitoreaParametro ns1:Parametro_Delta,
        ns1:Parametro_Epsilon ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA En una cajera 2D, el paso de mecanizado para el acabado (parámetro Δ) es mayor que el diámetro de la herramienta. En una cajera 3D, el paso de mecanizado para el acabado (parámetro ε) es cero." .

