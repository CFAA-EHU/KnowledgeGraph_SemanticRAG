@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1873 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Demasía lateral no válida" ;
    ns1:identificador "1873" ;
    ns1:monitoreaParametro ns1:Parametro_Demas_aLateral ;
    ns1:solucionaFallo ns1:Herramienta_Acabado ;
    ns1:textoExtracto "Durante la ejecución del ciclo. La demasía lateral para el acabado (parámetro δ) es mayor que el diámetro de la herramienta. Corregir la demasía lateral para el acabado o seleccionar otra herramienta." .

ns1:Fallo_1874 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Profundidad no válida" ;
    ns1:identificador "1874" ;
    ns1:monitoreaParametro ns1:Parametro_ProfundidadCajera_P ;
    ns1:textoExtracto "Durante la ejecución del ciclo. El parámetro P (profundidad de la cajera) tiene valor 0. Asignar un valor correcto al parámetro." .

ns1:Fallo_1875 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Perfil en XY no existe" ;
    ns1:identificador "1875" ;
    ns1:textoExtracto "Durante la ejecución del ciclo. No existe el perfil de superficie programado. Seleccionar un perfil existente o generar el perfil programado." .

ns1:Fallo_1876 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Perfil en XY no válido" ;
    ns1:identificador "1876" ;
    ns1:textoExtracto "Durante la ejecución del ciclo. Geometría del perfil de superficie mal programada. Corregir la geometría del perfil desde el editor de perfiles." .

ns1:Fallo_1877 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Perfil en Z no existe" ;
    ns1:identificador "1877" ;
    ns1:textoExtracto "Durante la ejecución del ciclo. No existe el perfil de profundidad programado. Seleccionar un perfil existente o generar el perfil programado." .

ns1:Fallo_1878 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Radio de la punta de la herramienta de acabado no válido" ;
    ns1:identificador "1878" ;
    ns1:monitoreaParametro ns1:Parametro_RadioPunta_Rp ;
    ns1:textoExtracto "Durante la ejecución del ciclo. El radio de la punta (Rp) de la herramienta de acabado es mayor que su radio (R). Corregir el valor del radio de la punta." .

ns1:Fallo_1879 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Radio de la herramienta de semiacabado no válido" ;
    ns1:identificador "1879" ;
    ns1:monitoreaParametro ns1:Parametro_RadioHerramientaSemiacabado ;
    ns1:solucionaFallo ns1:Herramienta_Semiacabado ;
    ns1:textoExtracto "Durante la ejecución del ciclo. El radio de la herramienta de semiacabado tiene valor 0 o es demasiado grande para la geometría de la cajera. Definir la herramienta en la tabla o seleccionar otra herramienta." .

ns1:Herramienta_Acabado a ns1:Herramienta ;
    rdfs:label "Herramienta de acabado" ;
    ns1:textoExtracto "herramienta de acabado (radio R, radio de punta Rp)" .

ns1:Herramienta_Semiacabado a ns1:Herramienta ;
    rdfs:label "Herramienta de semiacabado" ;
    ns1:textoExtracto "herramienta de semiacabado (radio)" .

ns1:Parametro_Demas_aLateral a ns1:Parametro ;
    rdfs:label "Demasía lateral (δ)" ;
    ns1:textoExtracto "parámetro δ (demasía lateral para el acabado)" ;
    ns1:valor "δ" .

ns1:Parametro_ProfundidadCajera_P a ns1:Parametro ;
    rdfs:label "Profundidad de la cajera (P)" ;
    ns1:textoExtracto "parámetro P (profundidad de la cajera)" ;
    ns1:valor "P" .

ns1:Parametro_RadioHerramientaSemiacabado a ns1:Parametro ;
    rdfs:label "Radio de la herramienta de semiacabado" ;
    ns1:textoExtracto "radio de la herramienta de semiacabado" .

ns1:Parametro_RadioPunta_Rp a ns1:Parametro ;
    rdfs:label "Radio de la punta (Rp)" ;
    ns1:textoExtracto "radio de la punta (Rp) de la herramienta de acabado" ;
    ns1:valor "Rp" .

