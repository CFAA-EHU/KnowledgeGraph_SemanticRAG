@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1880 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: No existe T de semiacabado" ;
    ns1:documentadoEn ns1:Tabla_Herramientas ;
    ns1:identificador "1880" ;
    ns1:solucionaFallo ns1:Herramienta_Semiacabado ;
    ns1:textoExtracto "1880 'Cajera con islas: No existe T de semiacabado' DETECCIÓN Durante la ejecución del ciclo. CAUSA La herramienta programada no existe en la tabla de herramientas. SOLUCIÓN Definir la herramienta en la tabla o seleccionar otra herramienta." .

ns1:Fallo_1881 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: F de semiacabado no válida" ;
    ns1:documentadoEn ns1:Tabla_Herramientas ;
    ns1:identificador "1881" ;
    ns1:textoExtracto "1881 'Cajera con islas: F de semiacabado no válida' DETECCIÓN" .

ns1:Parametro_RadioHerramienta a ns1:Parametro ;
    rdfs:label "Radio de la herramienta de semiacabado" ;
    ns1:monitoreaParametro ns1:Herramienta_Semiacabado ;
    ns1:textoExtracto "El radio de la herramienta de semiacabado tiene valor 0 o es demasiado grande para la geometría de la cajera." ;
    ns1:valor "0" .

ns1:Herramienta_Semiacabado a ns1:Herramienta ;
    rdfs:label "Herramienta de semiacabado" ;
    ns1:textoExtracto "El radio de la herramienta de semiacabado tiene valor 0 o es demasiado grande para la geometría de la cajera." .

ns1:Tabla_Herramientas a ns1:Tabla ;
    rdfs:label "Tabla de herramientas" ;
    ns1:textoExtracto "La herramienta programada no existe en la tabla de herramientas. SOLUCIÓN Definir la herramienta en la tabla o seleccionar otra herramienta." .

