@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1886 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Ángulo de profundización de la herramienta de desbaste no válido"@es ;
    ns1:identificador "1886" ;
    ns1:monitoreaParametro ns1:Parametro_1886_beta ;
    ns1:textoExtracto "1886 'Cajera con islas: Angulo de profundización de la herramienta de desbaste no válido' DETECCIÓN Durante la ejecución del ciclo. CAUSA El ángulo de profundización para el desbaste (parámetro β) no está comprendido entre 0º y 90º."@es .

ns1:DiagnosticoFallo_1887 a ns1:DiagnosticoFallo ;
    rdfs:label "Cajera con islas: Ángulo de profundización de la herramienta de semiacabado no válido"@es ;
    ns1:identificador "1887" ;
    ns1:monitoreaParametro ns1:Parametro_1887_theta ;
    ns1:textoExtracto "1887 'Cajera con islas: Angulo de profundización de la herramienta de semiacabado no válido' DETECCIÓN Durante la ejecución del ciclo. CAUSA El ángulo de profundización para el acabado (parámetro θ) no está comprendido entre 0º y 90º."@es .

ns1:Herramienta_Desbaste a ns1:Herramienta ;
    rdfs:label "Herramienta de desbaste"@es ;
    ns1:textoExtracto "herramienta de desbaste"@es .

ns1:Herramienta_Semiacabado a ns1:Herramienta ;
    rdfs:label "Herramienta de semiacabado"@es ;
    ns1:textoExtracto "herramienta de semiacabado"@es .

ns1:ModoOperacion_CicloCajeraIslas a ns1:ModoOperacion ;
    rdfs:label "Ciclo de cajera con islas"@es ;
    ns1:textoExtracto "ejecución del ciclo"@es .

ns1:Parametro_1886_beta a ns1:Parametro ;
    rdfs:label "Ángulo de profundización para desbaste (β)"@es ;
    ns1:textoExtracto "parámetro β"@es ;
    ns1:valor "[0,90] °" .

ns1:Parametro_1887_theta a ns1:Parametro ;
    rdfs:label "Ángulo de profundización para semiacabado (θ)"@es ;
    ns1:textoExtracto "parámetro θ"@es ;
    ns1:valor "[0,90] °" .

