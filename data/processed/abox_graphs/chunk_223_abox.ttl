@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_AvanceMecanizado a ns1:Parametro ;
    rdfs:label "Machining feedrate"@en ;
    ns1:identificador "F" ;
    ns1:monitoreaParametro ns1:ModoOperacion_G93,
        ns1:ModoOperacion_G94,
        ns1:ModoOperacion_G95 ;
    ns1:textoExtracto "The machining feedrate may be selected by programmed using the \"F\" code which remains active until another value is programmed."@en .

ns1:Parametro_CompensacionHerramienta a ns1:Parametro ;
    rdfs:label "Tool offset number"@en ;
    ns1:textoExtracto "The tool offset contains the tool dimensions. Each tool may have several offsets associated with it."@en .

ns1:Parametro_NumeroHerramienta a ns1:Parametro ;
    rdfs:label "Tool number"@en ;
    ns1:identificador "T" ;
    ns1:textoExtracto "The \"T\" code identifies the tool to be selected."@en .

ns1:Parametro_VelocidadHusillo a ns1:Parametro ;
    rdfs:label "Spindle speed"@en ;
    ns1:monitoreaParametro ns1:ModoOperacion_G96 ;
    ns1:textoExtracto "The spindle speed is selected by program using the spindle name followed by the desired speed. The programmed speed stays active until another value is programmed."@en ;
    ns1:valor "RPM"@en .

ns1:ModoOperacion_G93 a ns1:ModoOperacion ;
    ns1:identificador "G93" ;
    ns1:textoExtracto "The programming units depend on the active work mode (G93, G94 or G95)."@en .

ns1:ModoOperacion_G94 a ns1:ModoOperacion ;
    ns1:identificador "G94" ;
    ns1:textoExtracto "The programming units depend on the active work mode (G93, G94 or G95)."@en .

ns1:ModoOperacion_G95 a ns1:ModoOperacion ;
    ns1:identificador "G95" ;
    ns1:textoExtracto "The programming units depend on the active work mode (G93, G94 or G95)."@en .

ns1:ModoOperacion_G96 a ns1:ModoOperacion ;
    ns1:identificador "G96" ;
    ns1:textoExtracto "If G96 is active, the programming units will be m/min."@en .

