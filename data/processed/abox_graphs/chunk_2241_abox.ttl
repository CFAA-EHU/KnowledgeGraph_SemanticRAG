    rdfs:label "F de acabado no válida"@es ;
    ns1:identificador "1915" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_1915 ;
    ns1:textoExtracto "1915 'F de acabado no válida' DETECCIÓN Durante la ejecución del ciclo. CAUSA El avance para la operación de acabado tiene valor 0. SOLUCIÓN Definir un avance mayor que 0."@es .

ns1:Alarma_1916 a ns1:Alarma ;
    rdfs:label "S de desbaste no válida"@es ;
    ns1:identificador "1916" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_1916 ;
    ns1:textoExtracto "1916 'S de desbaste no válida' DETECCIÓN Durante la ejecución del ciclo. CAUSA La velocidad para la operación de desbaste tiene valor 0. SOLUCIÓN Definir una velocidad mayor que 0."@es .

ns1:Alarma_1917 a ns1:Alarma ;
    rdfs:label "S de acabado no válida"@es ;
    ns1:identificador "1917" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_1917 ;
    ns1:textoExtracto "1917 'S de acabado no válida' DETECCIÓN Durante la ejecución del ciclo. CAUSA La velocidad para la operación de acabado tiene valor 0. SOLUCIÓN Definir una velocidad mayor que 0."@es .

ns1:Alarma_1918 a ns1:Alarma ;
    rdfs:label "Perfil programado es cerrado"@es ;
    ns1:identificador "1918" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_1918 ;
    ns1:textoExtracto "1918 'Perfil programado es cerrado' DETECCIÓN Durante la ejecución del ciclo. CAUSA El perfil definido en el ciclo fijo no es válido porque es un perfil cerrado. SOLUCIÓN Programar un perfil que no sea cerrado."@es .

