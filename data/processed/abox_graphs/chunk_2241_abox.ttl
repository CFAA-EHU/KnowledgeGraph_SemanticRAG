@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1919 a ns1:Alarma ;
    rdfs:label "Perfil programado se corta a sí mismo"@es ;
    ns1:identificador "1919" ;
    ns1:textoExtracto "1919 'Perfil programado se corta a si mismo' DETECCIÓN Durante la ejecución del ciclo."@es .

ns1:Herramienta_SeleccionAlternativa_1911 a ns1:Herramienta ;
    ns1:textoExtracto "seleccionar otra herramienta"@es .

ns1:Parametro_AnguloCorte a ns1:Parametro ;
    ns1:monitoreaParametro ns1:Alarma_1913 ;
    ns1:textoExtracto "ángulo de corte"@es .

ns1:Parametro_AnguloCuchilla a ns1:Parametro ;
    ns1:monitoreaParametro ns1:Alarma_1912 ;
    ns1:textoExtracto "ángulo de la cuchilla"@es .

ns1:Parametro_AvanceAcabado a ns1:Parametro ;
    ns1:monitoreaParametro ns1:Alarma_1915 ;
    ns1:textoExtracto "avance para la operación de acabado"@es ;
    ns1:valor "0" .

ns1:Parametro_AvanceDesbaste a ns1:Parametro ;
    ns1:monitoreaParametro ns1:Alarma_1914 ;
    ns1:textoExtracto "avance para la operación de desbaste"@es ;
    ns1:valor "0" .

ns1:Parametro_FactorForma a ns1:Parametro ;
    ns1:monitoreaParametro ns1:Alarma_1911 ;
    ns1:textoExtracto "factor de forma"@es .

ns1:Parametro_PerfilCiclo a ns1:Parametro ;
    ns1:monitoreaParametro ns1:Alarma_1918 ;
    ns1:textoExtracto "perfil definido en el ciclo fijo"@es .

ns1:Parametro_VelocidadAcabado a ns1:Parametro ;
    ns1:monitoreaParametro ns1:Alarma_1917 ;
    ns1:textoExtracto "velocidad para la operación de acabado"@es ;
    ns1:valor "0" .

ns1:Parametro_VelocidadDesbaste a ns1:Parametro ;
    ns1:monitoreaParametro ns1:Alarma_1916 ;
    ns1:textoExtracto "velocidad para la operación de desbaste"@es ;
    ns1:valor "0" .

ns1:AccionProhibida_1911 a ns1:AccionProhibida ;
    ns1:textoExtracto "factor de forma no válido para el ciclo programado"@es .

ns1:AccionProhibida_1912 a ns1:AccionProhibida ;
    ns1:textoExtracto "ángulo de la cuchilla no válido para el ciclo programado"@es .

ns1:AccionProhibida_1913 a ns1:AccionProhibida ;
    ns1:textoExtracto "ángulo de corte no válido para el ciclo programado"@es .

ns1:AccionProhibida_1914 a ns1:AccionProhibida ;
    ns1:textoExtracto "avance para la operación de desbaste con valor 0"@es .

ns1:AccionProhibida_1915 a ns1:AccionProhibida ;
    ns1:textoExtracto "avance para la operación de acabado con valor 0"@es .

ns1:AccionProhibida_1916 a ns1:AccionProhibida ;
    ns1:textoExtracto "velocidad para la operación de desbaste con valor 0"@es .

ns1:AccionProhibida_1917 a ns1:AccionProhibida ;
    ns1:textoExtracto "velocidad para la operación de acabado con valor 0"@es .

ns1:AccionProhibida_1918 a ns1:AccionProhibida ;
    ns1:textoExtracto "perfil cerrado en ciclo fijo"@es .

ns1:Alarma_1911 a ns1:Alarma ;
    rdfs:label "Factor de forma no válido en ciclo de desbaste"@es ;
    ns1:identificador "1911" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_1911 ;
    ns1:textoExtracto "1911 'Factor de forma no válido en ciclo de desbaste' DETECCIÓN Durante la ejecución del ciclo. CAUSA El factor de forma no es válido para el ciclo programado. SOLUCIÓN Corregir el factor de forma o seleccionar otra herramienta."@es .

ns1:Alarma_1912 a ns1:Alarma ;
    rdfs:label "Ángulo de la cuchilla no válido"@es ;
    ns1:identificador "1912" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_1912 ;
    ns1:textoExtracto "1912 'Angulo de la cuchilla no válido' DETECCIÓN Durante la ejecución del ciclo. CAUSA El ángulo de la cuchilla no es válido para el ciclo programado. SOLUCIÓN Corregir el ángulo de la cuchilla o seleccionar otra herramienta."@es .

ns1:Alarma_1913 a ns1:Alarma ;
