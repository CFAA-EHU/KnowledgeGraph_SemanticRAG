    rdfs:label "F de desbaste no válida"@es ;
    ns1:identificador "1914" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_1914 ;
    ns1:textoExtracto "1914 'F de desbaste no válida' DETECCIÓN Durante la ejecución del ciclo. CAUSA El avance para la operación de desbaste tiene valor 0. SOLUCIÓN Definir un avance mayor que 0."@es .

