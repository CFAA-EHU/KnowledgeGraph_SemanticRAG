@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1920 a ns1:Alarma ;
    rdfs:label "Alarma 1920: 'No se ha programado perfil'"@es ;
    ns1:identificador "1920" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_1920 ;
    ns1:textoExtracto "'No se ha programado perfil' DETECCIÓN Durante la ejecución del ciclo. CAUSA Falta programar el perfil que define la geometría del ciclo fijo. SOLUCIÓN Definir el perfil que define la geometría del ciclo."@es .

ns1:Alarma_1921 a ns1:Alarma ;
    rdfs:label "Alarma 1921: 'Geometría programada no exterior'"@es ;
    ns1:identificador "1921" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_1921 ;
    ns1:textoExtracto "'Geometría programada no exterior' DETECCIÓN Durante la ejecución del ciclo. CAUSA La geometría programada en el ciclo fijo no se corresponde a una geometría exterior, tal y como se indica en el ciclo. SOLUCIÓN Cambiar la geometría o definir en el ciclo que la geometría es interior."@es .

ns1:Alarma_1922 a ns1:Alarma ;
    rdfs:label "Alarma 1922: 'Geometría programada no interior'"@es ;
    ns1:identificador "1922" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_1922 ;
    ns1:textoExtracto "'Geometría programada no interior' DETECCIÓN Durante la ejecución del ciclo. CAUSA La geometría programada en el ciclo fijo no se corresponde a una geometría interior, tal y como se indica en el ciclo. SOLUCIÓN Cambiar la geometría o definir en el ciclo que la geometría es exterior."@es .

ns1:Alarma_1923 a ns1:Alarma ;
    rdfs:label "Alarma 1923: 'Geometría no válida'"@es ;
    ns1:identificador "1923" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_1923 ;
    ns1:textoExtracto "'Geometría no valida' DETECCIÓN Durante la ejecución del ciclo. CAUSA La geometría del ciclo fijo es incorrecta. SOLUCIÓN Corregir la programación."@es .

ns1:Alarma_1924 a ns1:Alarma ;
    rdfs:label "Alarma 1924: 'Memoria insuficiente'"@es ;
    ns1:identificador "1924" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_1924 ;
    ns1:textoExtracto "'Memoria insuficiente' DETECCIÓN Durante la ejecución del ciclo. CAUSA El sistema no dispone de memoria para seguir resolviendo la cajera. SOLUCIÓN Póngase en contacto con FAGOR."@es .

ns1:Alarma_1925 a ns1:Alarma ;
    rdfs:label "Alarma 1925: 'No programado desbaste ni acabado'"@es ;
    ns1:identificador "1925" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_1925 ;
    ns1:textoExtracto "'No programado desbaste ni acabado' DETECCIÓN Durante la ejecución del ciclo. CAUSA No hay definida ninguna operación en el ciclo fijo. SOLUCIÓN En el ciclo fijo debe estar definida la operación de desbaste o acabado. Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta."@es .

ns1:Alarma_1926 a ns1:Alarma ;
    rdfs:label "Alarma 1926: 'Vértice mal programado'"@es ;
    ns1:identificador "1926" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_1926 ;
    ns1:textoExtracto "'Vértice mal programado' DETECCIÓN Durante la ejecución del ciclo. CAUSA La geometría del ciclo fijo es incorrecta. SOLUCIÓN Corregir la programación."@es .

ns1:Alarma_1927 a ns1:Alarma ;
    rdfs:label "Alarma 1927: 'Cuchilla no válida para perfil programado'"@es ;
    ns1:identificador "1927" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_1927 ;
    ns1:textoExtracto "'Cuchilla no valida para perfil programado' DETECCIÓN Durante la ejecución del ciclo."@es .

ns1:DiagnosticoFallo_1920 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta de programación de perfil en ciclo fijo"@es ;
    ns1:solucionaFallo ns1:Alarma_1920 ;
    ns1:textoExtracto "Falta programar el perfil que define la geometría del ciclo fijo."@es .

ns1:DiagnosticoFallo_1921 a ns1:DiagnosticoFallo ;
    rdfs:label "Geometría programada no válida (exterior)"@es ;
    ns1:solucionaFallo ns1:Alarma_1921 ;
    ns1:textoExtracto "La geometría programada en el ciclo fijo no se corresponde a una geometría exterior, tal y como se indica en el ciclo."@es .

ns1:DiagnosticoFallo_1922 a ns1:DiagnosticoFallo ;
    rdfs:label "Geometría programada no válida (interior)"@es ;
    ns1:solucionaFallo ns1:Alarma_1922 ;
    ns1:textoExtracto "La geometría programada en el ciclo fijo no se corresponde a una geometría interior, tal y como se indica en el ciclo."@es .

ns1:DiagnosticoFallo_1923 a ns1:DiagnosticoFallo ;
    rdfs:label "Geometría incorrecta en ciclo fijo"@es ;
    ns1:solucionaFallo ns1:Alarma_1923 ;
    ns1:textoExtracto "La geometría del ciclo fijo es incorrecta."@es .

ns1:DiagnosticoFallo_1924 a ns1:DiagnosticoFallo ;
    rdfs:label "Memoria insuficiente en sistema"@es ;
    ns1:solucionaFallo ns1:Alarma_1924 ;
    ns1:textoExtracto "El sistema no dispone de memoria para seguir resolviendo la cajera."@es .

ns1:DiagnosticoFallo_1925 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta de programación de operaciones (desbaste/acabado)"@es ;
    ns1:requiereConsumible ns1:Herramienta_DesbasteAcabado ;
    ns1:solucionaFallo ns1:Alarma_1925 ;
    ns1:textoExtracto "No hay definida ninguna operación en el ciclo fijo. [...] al menos una operación tiene que tener herramienta."@es .

ns1:DiagnosticoFallo_1926 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de programación en vértice de geometría"@es ;
    ns1:solucionaFallo ns1:Alarma_1926 ;
    ns1:textoExtracto "La geometría del ciclo fijo es incorrecta."@es .

ns1:DiagnosticoFallo_1927 a ns1:DiagnosticoFallo ;
    rdfs:label "Cuchilla incompatible con perfil programado"@es ;
    ns1:requiereConsumible ns1:Herramienta_CuchillaValida ;
    ns1:solucionaFallo ns1:Alarma_1927 ;
    ns1:textoExtracto "'Cuchilla no valida para perfil programado' DETECCIÓN Durante la ejecución del ciclo."@es .

ns1:Herramienta_CuchillaValida a ns1:Herramienta ;
    rdfs:label "Cuchilla válida para perfil programado"@es ;
    ns1:textoExtracto "'Cuchilla no valida para perfil programado' (implica necesidad de cuchilla compatible)."@es .

ns1:Herramienta_DesbasteAcabado a ns1:Herramienta ;
    rdfs:label "Herramienta para desbaste o acabado en ciclo fijo"@es ;
    ns1:textoExtracto "Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta."@es .

