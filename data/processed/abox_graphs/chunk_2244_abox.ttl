@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1926 a ns1:DiagnosticoFallo ;
    rdfs:label "Vértice mal programado" ;
    ns1:identificador "1926" ;
    ns1:textoExtracto "'Vértice mal programado' DETECCIÓN Durante la ejecución del ciclo. CAUSA La geometría del ciclo fijo es incorrecta. SOLUCIÓN Corregir la programación." .

ns1:Fallo_1927 a ns1:DiagnosticoFallo ;
    rdfs:label "Cuchilla no válida para perfil programado" ;
    ns1:identificador "1927" ;
    ns1:solucionaFallo ns1:Herramienta_1927 ;
    ns1:textoExtracto "'Cuchilla no valida para perfil programado' DETECCIÓN Durante la ejecución del ciclo. CAUSA La herramienta no es válida para la geometría del ciclo programado. SOLUCIÓN Seleccionar otra herramienta." .

ns1:Fallo_1928 a ns1:DiagnosticoFallo ;
    rdfs:label "Paso de ranurado mayor que la anchura de la cuchilla" ;
    ns1:identificador "1928" ;
    ns1:solucionaFallo ns1:Herramienta_1928 ;
    ns1:textoExtracto "'Paso de ranurado mayor que la anchura de la cuchilla' DETECCIÓN Durante la ejecución del ciclo. CAUSA El paso de ranurado es mayor" .

ns1:Herramienta_1927 a ns1:Herramienta ;
    ns1:textoExtracto "La herramienta no es válida para la geometría del ciclo programado." .

ns1:Herramienta_1928 a ns1:Herramienta ;
    ns1:textoExtracto "anchura de la cuchilla" .

