@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1928 a ns1:DiagnosticoFallo ;
    rdfs:label "Paso de ranurado mayor que la anchura de la cuchilla" ;
    ns1:identificador "1928" ;
    ns1:solucionaFallo ns1:Herramienta_Seleccionada_1928 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El paso de ranurado es mayor que la anchura de la cuchilla. SOLUCIÓN Programar un paso de ranurado menor o igual que la anchura de la cuchilla." .

ns1:Fallo_1929 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha programado avance del cabezal" ;
    ns1:identificador "1929" ;
    ns1:solucionaFallo ns1:Parametro_Avance_Cabezal_1929 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA La velocidad del cabezal tiene valor 0. SOLUCIÓN Definir un avance mayor que 0." .

ns1:Fallo_1930 a ns1:DiagnosticoFallo ;
    rdfs:label "Programado paso de taladrado nulo" ;
    ns1:identificador "1930" ;
    ns1:solucionaFallo ns1:Parametro_Paso_Taladrado_1930 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El paso de taladrado tiene valor 0. SOLUCIÓN Definir un paso de taladrado diferente de 0." .

ns1:Fallo_1931 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha programado profundidad" ;
    ns1:identificador "1931" ;
    ns1:solucionaFallo ns1:Parametro_Profundidad_Mecanizado_1931 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA La profundidad de mecanizado tiene valor 0. SOLUCIÓN Definir una profundidad de mecanizado diferente de 0." .

ns1:Fallo_1932 a ns1:DiagnosticoFallo ;
    rdfs:label "No hay cabezal para ejecutar el ciclo" ;
    ns1:identificador "1932" ;
    ns1:solucionaFallo ns1:Componente_Cabezal_1932 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El canal que ejecuta el ciclo no dispone de cabezal. SOLUCIÓN Ceder un cabezal al canal o ejecutar el ciclo en un canal con cabezal." .

ns1:Fallo_1933 a ns1:DiagnosticoFallo ;
    rdfs:label "No hay herramienta motorizada para ejecutar el ciclo" ;
    ns1:identificador "1933" ;
    ns1:solucionaFallo ns1:Herramienta_Motorizada_1933 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El canal que ejecuta el ciclo no dispone de cabezal para la herramienta motorizada. SOLUCIÓN Ceder una herramienta motorizada al canal o ejecutar el ciclo en un canal con herramienta motorizada." .

ns1:Fallo_1934 a ns1:DiagnosticoFallo ;
    rdfs:label "Anchura de la cuchilla no válida" ;
    ns1:identificador "1934" ;
    ns1:solucionaFallo ns1:Herramienta_Cuchilla_1934 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA La anchura de la cuchilla es mayor que la ranura o el ciclo no puede dejar la demasía programada. SOLUCIÓN Comprobar que la herramienta seleccionada puede mecanizar la ranura programada, dejando la demasía de acabado programada." .

ns1:Componente_Cabezal_1932 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "El canal que ejecuta el ciclo no dispone de cabezal." .

ns1:Herramienta_Cuchilla_1934 a ns1:Herramienta ;
    rdfs:label "Cuchilla" ;
    ns1:textoExtracto "La anchura de la cuchilla es mayor que la ranura." .

ns1:Herramienta_Motorizada_1933 a ns1:Herramienta ;
    rdfs:label "Herramienta motorizada" ;
    ns1:textoExtracto "El canal que ejecuta el ciclo no dispone de cabezal para la herramienta motorizada." .

ns1:Herramienta_Seleccionada_1928 a ns1:Herramienta ;
    ns1:textoExtracto "Seleccionar otra herramienta." .

ns1:Parametro_Avance_Cabezal_1929 a ns1:Parametro ;
    rdfs:label "Avance del cabezal" ;
    ns1:textoExtracto "La velocidad del cabezal tiene valor 0." ;
    ns1:valor "0" .

ns1:Parametro_Paso_Taladrado_1930 a ns1:Parametro ;
    rdfs:label "Paso de taladrado" ;
    ns1:textoExtracto "El paso de taladrado tiene valor 0." ;
    ns1:valor "0" .

ns1:Parametro_Profundidad_Mecanizado_1931 a ns1:Parametro ;
    rdfs:label "Profundidad de mecanizado" ;
    ns1:textoExtracto "La profundidad de mecanizado tiene valor 0." ;
    ns1:valor "0" .

