@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Ciclo_EjeC a ns1:ModoOperacion ;
    rdfs:label "Ciclo de eje C"@es ;
    ns1:requiereMantenimiento ns1:Fallo_1935 ;
    ns1:textoExtracto "1935 'No se ha definido ningún eje como LONGAXIS en ciclo de eje C' [...] DETECCIÓN Durante la ejecución del ciclo."@es .

ns1:Fallo_1936 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1936: Parámetro no configurado"@es ;
    ns1:identificador "1936" ;
    ns1:textoExtracto "1936 'No se ha definido ningún"@es .

ns1:Herramienta_Ranurado a ns1:Herramienta ;
    rdfs:label "Herramienta de ranurado"@es ;
    ns1:solucionaFallo ns1:Fallo_1935 ;
    ns1:textoExtracto "Comprobar que la herramienta seleccionada puede mecanizar la ranura programada, dejando la demasía de acabado programada."@es .

ns1:Parametro_LONGAXIS a ns1:Parametro ;
    rdfs:label "Parámetro máquina LONGAXIS"@es ;
    ns1:solucionaFallo ns1:Fallo_1935 ;
    ns1:textoExtracto "Poner el parámetro máquina LONGAXIS a TRUE para el eje que sea el eje longitudinal."@es ;
    ns1:valor "TRUE" .

ns1:Fallo_1935 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1935: Eje LONGAXIS no definido en ciclo de eje C"@es ;
    ns1:identificador "1935" ;
    ns1:textoExtracto "1935 'No se ha definido ningún eje como LONGAXIS en ciclo de eje C' [...] CAUSA No hay definido ningún eje longitudinal en el canal."@es .

