@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1936 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha definido ningún eje como FACEAXIS en ciclo de eje C"@es ;
    ns1:identificador "1936" ;
    ns1:solucionaFallo ns1:FACEAXIS_dc77a4579e ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA No hay definido ningún eje frontal en el canal. SOLUCIÓN Poner el parámetro máquina FACEAXIS a TRUE para el eje que sea el eje frontal."@es .

ns1:Fallo_1937 a ns1:DiagnosticoFallo ;
    rdfs:label "No hay definido ningún eje o cabezal para eje C"@es ;
    ns1:identificador "1937" ;
    ns1:solucionaFallo ns1:CAXIS_1d2b14891b ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El ciclo fijo está programado para el eje C, y no hay ningún eje C en el canal. SOLUCIÓN Definir algún eje o cabezal del canal como eje C (parámetro CAXIS)."@es .

ns1:Fallo_1938 a ns1:DiagnosticoFallo ;
    rdfs:label "No hay definido ningún eje para eje Y"@es ;
    ns1:identificador "1938" ;
    ns1:solucionaFallo ns1:GEOCONFIG_00b0965fe1 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA El ciclo fijo está programado para el eje Y, y no hay ningún eje Y en el canal. SOLUCIÓN Definir una configuración de ejes tipo triedro en el canal (parámetro GEOCONFIG) con un eje Y."@es .

ns1:Fallo_1949 a ns1:DiagnosticoFallo ;
    rdfs:label "La cuchilla no puede mecanizar el perfil completamente"@es ;
    ns1:identificador "1949" ;
    ns1:solucionaFallo ns1:CuchillaDeTorno ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución de un ciclo fijo de desbaste seguimiento de perfil de torno. CAUSA La geometria de la herramienta no permite que ésta pueda mecanizar todo el perfil programado. CONSECUENCIA El ciclo no puede mecanizar completamente el perfil programado. SOLUCIÓN Modificar el perfil o cambiar de herramienta para que ésta pueda mecanizar el perfil."@es .

ns1:Fallo_1950 a ns1:DiagnosticoFallo ;
    rdfs:label "No programada la cota Z de la superficie de la pieza"@es ;
    ns1:identificador "1950" ;
    ns1:solucionaFallo ns1:ZCotaSuperficiePieza ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Falta programar la cota de la superficie de la pieza (parámetro Z). SOLUCIÓN Corregir la programación."@es .

ns1:Fallo_1951 a ns1:DiagnosticoFallo ;
    rdfs:label "No programada la cota Z de seguridad"@es ;
    ns1:identificador "1951" ;
    ns1:solucionaFallo ns1:ZsPlanoDeSeguridad ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución del ciclo. CAUSA Falta programar el plano de seguridad (parámetro Zs)."@es .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC (contexto de ciclos fijos)"@es ;
    ns1:textoExtracto "ciclo fijo de desbaste seguimiento de perfil de torno"@es ;
    ns1:tieneComponente ns1:CabezalParaEjeC .

ns1:Param_LONGAXIS a ns1:Parametro ;
    rdfs:label "LONGAXIS"@es ;
    ns1:textoExtracto "parámetro máquina LONGAXIS a TRUE para el eje que sea el eje longitudinal"@es ;
    ns1:valor "TRUE" .

ns1:CAXIS_1d2b14891b a ns1:Parametro ;
    rdfs:label "CAXIS"@es ;
    ns1:textoExtracto "parámetro CAXIS"@es .

ns1:CabezalParaEjeC a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal para eje C"@es ;
    ns1:textoExtracto "eje o cabezal del canal como eje C"@es .

ns1:CuchillaDeTorno a ns1:Herramienta ;
    rdfs:label "Cuchilla de torno"@es ;
    ns1:textoExtracto "La geometria de la herramienta no permite que ésta pueda mecanizar todo el perfil programado"@es .

ns1:FACEAXIS_dc77a4579e a ns1:Parametro ;
    rdfs:label "FACEAXIS"@es ;
    ns1:textoExtracto "parámetro máquina FACEAXIS"@es ;
    ns1:valor "TRUE" .

ns1:GEOCONFIG_00b0965fe1 a ns1:Parametro ;
    rdfs:label "GEOCONFIG"@es ;
    ns1:textoExtracto "parámetro GEOCONFIG"@es .

ns1:ZCotaSuperficiePieza a ns1:Parametro ;
    rdfs:label "Z (cota superficie pieza)"@es ;
    ns1:identificador "Z" ;
    ns1:textoExtracto "parámetro Z"@es .

ns1:ZsPlanoDeSeguridad a ns1:Parametro ;
    rdfs:label "Zs (plano de seguridad)"@es ;
    ns1:identificador "Zs" ;
    ns1:textoExtracto "parámetro Zs"@es .

