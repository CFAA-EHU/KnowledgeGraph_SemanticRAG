@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1951 a ns1:DiagnosticoFallo ;
    rdfs:label "No programada la cota Z de seguridad"@es ;
    ns1:identificador "1951" ;
    ns1:monitoreaParametro ns1:Parametro_Z ;
    ns1:solucionaFallo ns1:Tarea_CorreccionProgramacion ;
    ns1:textoExtracto "1951 'No programada la cota Z de seguridad' [...] CAUSA Falta programar la cota de la superficie de la pieza (parámetro Z). SOLUCIÓN Corregir la programación."@es .

ns1:Fallo_1952 a ns1:DiagnosticoFallo ;
    rdfs:label "No programada la profundidad de la pieza"@es ;
    ns1:identificador "1952" ;
    ns1:monitoreaParametro ns1:Parametro_Profundidad ;
    ns1:solucionaFallo ns1:Tarea_CorreccionProgramacion ;
    ns1:textoExtracto "1952 'No programada la profundidad de la pieza' [...] CAUSA Falta programar la profundidad de la pieza (parámetro P). SOLUCIÓN Corregir la programación."@es .

ns1:Fallo_1953 a ns1:DiagnosticoFallo ;
    rdfs:label "No programado el paso de [parámetro]"@es ;
    ns1:identificador "1953" ;
    ns1:solucionaFallo ns1:Tarea_CorreccionProgramacion ;
    ns1:textoExtracto "1953 'No programado el paso de [...]'"@es .

ns1:Parametro_Zs a ns1:Parametro ;
    rdfs:label "Plano de seguridad (Zs)"@es ;
    ns1:identificador "Zs" ;
    ns1:textoExtracto "parámetro Zs [...] plano de seguridad"@es .

ns1:Parametro_Profundidad a ns1:Parametro ;
    rdfs:label "Profundidad de la pieza (P)"@es ;
    ns1:identificador "P" ;
    ns1:textoExtracto "parámetro P [...] profundidad de la pieza"@es .

ns1:Parametro_Z a ns1:Parametro ;
    rdfs:label "Cota Z (superficie de la pieza)"@es ;
    ns1:identificador "Z" ;
    ns1:textoExtracto "parámetro Z [...] cota de la superficie de la pieza"@es .

ns1:Tarea_CorreccionProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Corregir la programación"@es ;
    ns1:textoExtracto "SOLUCIÓN Corregir la programación."@es .

