@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Fallo_1953 a ns1:DiagnosticoFallo ;
    rdfs:label "No programado el paso de profundidad" ;
    ns1:identificador "1953" ;
    ns1:solucionaFallo ns1:Parametro_P ;
    ns1:textoExtracto "'No programado el paso de profundidad' DETECCIÓN Durante la ejecución del ciclo. CAUSA Falta programar el paso de profundización (parámetro P). SOLUCIÓN Corregir la programación." .

ns1:Fallo_1954 a ns1:DiagnosticoFallo ;
    rdfs:label "No programado el paso de desbaste" ;
    ns1:identificador "1954" ;
    ns1:solucionaFallo ns1:Parametro_D ;
    ns1:textoExtracto "'No programado el paso de desbaste' DETECCIÓN Durante la ejecución del ciclo. CAUSA Falta programar el paso de desbaste (parámetro D). SOLUCIÓN Corregir la programación." .

ns1:Fallo_1955 a ns1:DiagnosticoFallo ;
    rdfs:label "Radio de herramienta de desbaste nulo" ;
    ns1:identificador "1955" ;
    ns1:solucionaFallo ns1:Herramienta_Desbaste ;
    ns1:textoExtracto "'Radio de herramienta de desbaste nulo' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta de desbaste tiene valor 0. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ns1:Fallo_1956 a ns1:DiagnosticoFallo ;
    rdfs:label "Radio de herramienta de acabado nulo" ;
    ns1:identificador "1956" ;
    ns1:solucionaFallo ns1:Herramienta_Acabado ;
    ns1:textoExtracto "'Radio de herramienta de acabado nulo' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta de acabado tiene valor 0. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ns1:Fallo_1957 a ns1:DiagnosticoFallo ;
    rdfs:label "Radio de herramienta de semiacabado nulo" ;
    ns1:identificador "1957" ;
    ns1:solucionaFallo ns1:Herramienta_Semiacabado ;
    ns1:textoExtracto "'Radio de herramienta de semiacabado nulo' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta de semiacabado tiene valor 0. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ns1:Fallo_1958 a ns1:DiagnosticoFallo ;
    rdfs:label "Radio de herramienta de desbaste demasiado grande" ;
    ns1:identificador "1958" ;
    ns1:solucionaFallo ns1:Herramienta_Desbaste ;
    ns1:textoExtracto "'Radio de herramienta de desbaste demasiado grande' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta de desbaste es demasiado grande para la geometría de la cajera. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ns1:Fallo_1959 a ns1:DiagnosticoFallo ;
    rdfs:label "Radio de herramienta de acabado demasiado grande" ;
    ns1:identificador "1959" ;
    ns1:solucionaFallo ns1:Herramienta_Acabado ;
    ns1:textoExtracto "'Radio de herramienta de acabado demasiado grande' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta de acabado es demasiado grande para la geometría de la cajera. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ns1:Parametro_I a ns1:Parametro ;
    rdfs:label "Parámetro I (paso de profundización)" ;
    ns1:identificador "I" ;
    ns1:textoExtracto "Falta programar el paso de profundización (parámetro I)." .

ns1:Herramienta_Semiacabado a ns1:Herramienta ;
    rdfs:label "Herramienta de semiacabado" ;
    ns1:monitoreaParametro ns1:Parametro_RadioSemiacabado ;
    ns1:textoExtracto "El radio de la herramienta de semiacabado tiene valor 0." .

ns1:Parametro_D a ns1:Parametro ;
    rdfs:label "Parámetro D (paso de desbaste)" ;
    ns1:identificador "D" ;
    ns1:textoExtracto "Falta programar el paso de desbaste (parámetro D)." .

ns1:Parametro_P a ns1:Parametro ;
    rdfs:label "Parámetro P (profundidad de la pieza)" ;
    ns1:identificador "P" ;
    ns1:textoExtracto "Falta programar la profundidad de la pieza (parámetro P)." .

ns1:Parametro_RadioAcabado a ns1:Parametro ;
    rdfs:label "Radio de herramienta de acabado" ;
    ns1:documentadoEn ns1:TablaHerramientas ;
    ns1:textoExtracto "El radio de la herramienta de acabado tiene valor 0." ;
    ns1:valor "0.0"^^xsd:float .

ns1:Parametro_RadioDesbaste a ns1:Parametro ;
    rdfs:label "Radio de herramienta de desbaste" ;
    ns1:documentadoEn ns1:TablaHerramientas ;
    ns1:textoExtracto "El radio de la herramienta de desbaste tiene valor 0." ;
    ns1:valor "0.0"^^xsd:float .

ns1:Parametro_RadioSemiacabado a ns1:Parametro ;
    rdfs:label "Radio de herramienta de semiacabado" ;
    ns1:documentadoEn ns1:TablaHerramientas ;
    ns1:textoExtracto "El radio de la herramienta de semiacabado tiene valor 0." ;
    ns1:valor "0.0"^^xsd:float .

ns1:Herramienta_Acabado a ns1:Herramienta ;
    rdfs:label "Herramienta de acabado" ;
    ns1:monitoreaParametro ns1:Parametro_RadioAcabado ;
    ns1:textoExtracto "El radio de la herramienta de acabado tiene valor 0." .

ns1:Herramienta_Desbaste a ns1:Herramienta ;
    rdfs:label "Herramienta de desbaste" ;
    ns1:monitoreaParametro ns1:Parametro_RadioDesbaste ;
    ns1:textoExtracto "El radio de la herramienta de desbaste tiene valor 0." .

ns1:TablaHerramientas a ns1:Tabla ;
    rdfs:label "Tabla de herramientas" ;
    ns1:textoExtracto "Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

