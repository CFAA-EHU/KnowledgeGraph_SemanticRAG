@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1959 a ns1:DiagnosticoFallo ;
    rdfs:label "Radio de herramienta de acabado demasiado grande"@es ;
    ns1:identificador "1959" ;
    ns1:solucionaFallo ns1:Parametro_RadioHerramientaAcabado ;
    ns1:textoExtracto "'Radio de herramienta de acabado demasiado grande' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta de acabado es demasiado grande para la geometría de la cajera. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta."@es .

ns1:DiagnosticoFallo_1960 a ns1:DiagnosticoFallo ;
    rdfs:label "Radio de herramienta de semiacabado demasiado grande"@es ;
    ns1:identificador "1960" ;
    ns1:textoExtracto "'Radio de herramienta de semiacabado demasiado grande' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta de semiacabado"@es .

ns1:Herramienta_Acabado a ns1:Herramienta ;
    rdfs:label "Herramienta de acabado"@es ;
    ns1:monitoreaParametro ns1:Parametro_RadioHerramientaAcabado ;
    ns1:textoExtracto "herramienta de acabado"@es .

ns1:Tabla_Herramientas a ns1:Tabla ;
    rdfs:label "Tabla de herramientas"@es ;
    ns1:documentadoEn ns1:Manual_Principal ;
    ns1:textoExtracto "tabla de herramientas"@es .

ns1:Parametro_RadioHerramientaAcabado a ns1:Parametro ;
    rdfs:label "Radio de herramienta de acabado"@es ;
    ns1:textoExtracto "radio de la herramienta de acabado"@es ;
    ns1:valor "demasiado grande"@es .

