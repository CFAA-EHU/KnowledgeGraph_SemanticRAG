@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1960 a ns1:DiagnosticoFallo ;
    rdfs:label "Radio de herramienta de semiacabado demasiado grande"@es ;
    ns1:identificador "1960" ;
    ns1:solucionaFallo ns1:Parametro_RadioHerramientaSemiacabado ;
    ns1:textoExtracto "1960 'Radio de herramienta de semiacabado demasiado grande' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la herramienta de semiacabado es demasiado grande para la geometría de la cajera. SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta."@es .

ns1:Fallo_1961 a ns1:DiagnosticoFallo ;
    rdfs:label "Radio de la punta de la herramienta de acabado no válido"@es ;
    ns1:identificador "1961" ;
    ns1:solucionaFallo ns1:Parametro_RadioPuntaHerramientaAcabado ;
    ns1:textoExtracto "1961 'Radio de la punta de la herramienta de acabado no valido' DETECCIÓN Durante la ejecución del ciclo. CAUSA El radio de la punta (Rp) de la herramienta de acabado es mayor que su radio (R). SOLUCIÓN Corregir el valor del radio de la punta."@es .

ns1:Fallo_1962 a ns1:DiagnosticoFallo ;
    rdfs:label "Ángulo de profundización en el desbaste no válido"@es ;
    ns1:identificador "1962" ;
    ns1:solucionaFallo ns1:Parametro_AnguloProfundizacionDesbaste ;
    ns1:textoExtracto "1962 'Angulo de profundización en el desbaste no valido' DETECCIÓN Durante la ejecución del ciclo. CAUSA El ángulo de profundización para el desbaste no está comprendido entre 0º y 90º. SOLUCIÓN Corregir el ángulo de profundización; programar un valor entre 0º y 90º."@es .

ns1:Fallo_1963 a ns1:DiagnosticoFallo ;
    rdfs:label "Ángulo de profundización en el semiacabado no válido"@es ;
    ns1:identificador "1963" ;
    ns1:solucionaFallo ns1:Parametro_AnguloProfundizacionSemiacabado ;
    ns1:textoExtracto "1963 'Angulo de profundización en el semiacabado no valido' DETECCIÓN Durante la ejecución del ciclo. CAUSA El ángulo de profundización para el semiacabado no está comprendido entre 0º y 90º. SOLUCIÓN Corregir el ángulo de profundización; programar un valor entre 0º y 90º."@es .

ns1:Fallo_1964 a ns1:DiagnosticoFallo ;
    rdfs:label "Paso de desbaste mayor que el diámetro de la herramienta"@es ;
    ns1:identificador "1964" ;
    ns1:solucionaFallo ns1:Parametro_PasoMecanizadoDesbaste ;
    ns1:textoExtracto "1964 'Programado paso de desbaste mayor que el diámetro de la herramienta' DETECCIÓN Durante la ejecución del ciclo. CAUSA El paso de mecanizado para el desbaste es mayor que el diámetro de la herramienta. SOLUCIÓN Corregir el paso de mecanizado o seleccionar otra herramienta."@es .

ns1:Fallo_1965 a ns1:DiagnosticoFallo ;
    rdfs:label "Paso de acabado mayor que el diámetro de la herramienta"@es ;
    ns1:identificador "1965" ;
    ns1:solucionaFallo ns1:Parametro_PasoMecanizadoAcabado ;
    ns1:textoExtracto "1965 'Programado paso de acabado mayor que el diámetro de la herramienta' DETECCIÓN Durante la ejecución del ciclo. CAUSA El paso de mecanizado para el acabado es mayor que el diámetro de la herramienta. SOLUCIÓN Corregir el paso de mecanizado o seleccionar otra herramienta."@es .

ns1:Fallo_1966 a ns1:DiagnosticoFallo ;
    rdfs:label "Tipo de acabado no válido"@es ;
    ns1:identificador "1966" ;
    ns1:textoExtracto "1966 'Tipo de acabado no válido' DETECCIÓN Durante la ejecución del ciclo."@es .

ns1:TablaHerramientas a ns1:Tabla ;
    rdfs:label "Tabla de herramientas"@es ;
    ns1:textoExtracto "Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta."@es .

ns1:Parametro_AnguloProfundizacionDesbaste a ns1:Parametro ;
    rdfs:label "Ángulo de profundización para el desbaste"@es ;
    ns1:textoExtracto "El ángulo de profundización para el desbaste no está comprendido entre 0º y 90º."@es ;
    ns1:valor "0º-90º" .

ns1:Parametro_AnguloProfundizacionSemiacabado a ns1:Parametro ;
    rdfs:label "Ángulo de profundización para el semiacabado"@es ;
    ns1:textoExtracto "El ángulo de profundización para el semiacabado no está comprendido entre 0º y 90º."@es ;
    ns1:valor "0º-90º" .

ns1:Parametro_PasoMecanizadoAcabado a ns1:Parametro ;
    rdfs:label "Paso de mecanizado para el acabado"@es ;
    ns1:textoExtracto "El paso de mecanizado para el acabado es mayor que el diámetro de la herramienta."@es .

ns1:Parametro_PasoMecanizadoDesbaste a ns1:Parametro ;
    rdfs:label "Paso de mecanizado para el desbaste"@es ;
    ns1:textoExtracto "El paso de mecanizado para el desbaste es mayor que el diámetro de la herramienta."@es .

ns1:Parametro_RadioHerramientaSemiacabado a ns1:Parametro ;
    rdfs:label "Radio de herramienta de semiacabado"@es ;
    ns1:textoExtracto "Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta."@es .

ns1:Parametro_RadioPuntaHerramientaAcabado a ns1:Parametro ;
    rdfs:label "Radio de la punta (Rp) de la herramienta de acabado"@es ;
    ns1:textoExtracto "El radio de la punta (Rp) de la herramienta de acabado es mayor que su radio (R)."@es .

