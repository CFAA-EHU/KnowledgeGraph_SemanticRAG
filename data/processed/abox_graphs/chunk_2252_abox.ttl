@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Herramienta_Mecanizado a ns1:Herramienta ;
    rdfs:label "Herramienta de mecanizado" ;
    ns1:textoExtracto "El paso de mecanizado para el acabado es mayor que el diámetro de la herramienta. SOLUCIÓN Corregir el paso de mecanizado o seleccionar otra herramienta." .

ns1:Parametro_CotaZ a ns1:Parametro ;
    rdfs:label "Cota Z del plano de partida" ;
    ns1:monitoreaParametro ns1:AvisoSeguridad_1967 ;
    ns1:textoExtracto "La cota Z de comienzo del ciclo se encuentra dentro" .

ns1:Parametro_TipoAcabado a ns1:Parametro ;
    rdfs:label "Tipo de acabado" ;
    ns1:monitoreaParametro ns1:AvisoSeguridad_1966 ;
    ns1:textoExtracto "El tipo de acabado no es válido. SOLUCIÓN Asignar un valor correcto a los parámetros." .

ns1:TareaMantenimiento_AsignacionValorParametro a ns1:TareaMantenimiento ;
    rdfs:label "Asignación de valor correcto a parámetros" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_1966 ;
    ns1:textoExtracto "Asignar un valor correcto a los parámetros." .

ns1:TareaMantenimiento_CorreccionPasoMecanizado a ns1:TareaMantenimiento ;
    rdfs:label "Corrección del paso de mecanizado" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_1966 ;
    ns1:textoExtracto "Corregir el paso de mecanizado o seleccionar otra herramienta." .

ns1:AvisoSeguridad_1967 a ns1:AvisoSeguridad ;
    rdfs:label "Cota Z del plano de partida no válida" ;
    ns1:identificador "1967" ;
    ns1:textoExtracto "1967 'Cota Z del plano de partida no valida' DETECCIÓN Durante la ejecución del ciclo. CAUSA La cota Z de comienzo del ciclo se encuentra dentro" .

ns1:AvisoSeguridad_1966 a ns1:AvisoSeguridad ;
    rdfs:label "Tipo de acabado no válido" ;
    ns1:identificador "1966" ;
    ns1:textoExtracto "1966 'Tipo de acabado no válido' DETECCIÓN Durante la ejecución del ciclo. CAUSA El tipo de acabado no es válido. SOLUCIÓN Asignar un valor correcto a los parámetros." .

