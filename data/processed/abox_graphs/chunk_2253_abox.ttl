@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1967 a ns1:DiagnosticoFallo ;
    rdfs:label "Cota Z del plano de partida no válida" ;
    ns1:identificador "1967" ;
    ns1:solucionaFallo ns1:Parametro_CotaZ_PlanoPartida ;
    ns1:textoExtracto "1967 'Cota Z del plano de partida no valida' [...] CAUSA La cota Z de comienzo del ciclo se encuentra dentro de la pieza. SOLUCIÓN La cota Z de comienzo del ciclo debe estar por encima del plano de referencia." .

ns1:Fallo_1968 a ns1:DiagnosticoFallo ;
    rdfs:label "Cota Z de seguridad no válida" ;
    ns1:identificador "1968" ;
    ns1:solucionaFallo ns1:Parametro_PlanoSeguridad ;
    ns1:textoExtracto "1968 'Cota Z de seguridad no valida' [...] CAUSA El plano de seguridad se encuentra dentro de la pieza. SOLUCIÓN Asignar un valor correcto al parámetro." .

ns1:Fallo_1969 a ns1:DiagnosticoFallo ;
    rdfs:label "Perfil en XY programado no existe" ;
    ns1:identificador "1969" ;
    ns1:solucionaFallo ns1:Parametro_PerfilXY ;
    ns1:textoExtracto "1969 'No existe el perfil en XY programado' [...] CAUSA El perfil de superficie no existe. SOLUCIÓN Editar el perfil. El CNC guarda los perfiles en la carpeta ..\\Users\\Profile." .

ns1:Fallo_1970 a ns1:DiagnosticoFallo ;
    rdfs:label "Perfil en Z programado no existe" ;
    ns1:identificador "1970" ;
    ns1:solucionaFallo ns1:Parametro_PerfilZ ;
    ns1:textoExtracto "1970 'No existe el perfil en Z programado' [...] CAUSA El perfil de profundidad no existe. SOLUCIÓN Editar el perfil. El CNC guarda los perfiles en la carpeta ..\\Users\\Profile." .

ns1:Fallo_1971 a ns1:DiagnosticoFallo ;
    rdfs:label "Perfil en XY abierto" ;
    ns1:identificador "1971" ;
    ns1:solucionaFallo ns1:Parametro_PerfilXY ;
    ns1:textoExtracto "1971 'Programado perfil en XY abierto' [...] CAUSA Algún perfil de superficie no es un perfil cerrado, sus puntos inicial y final no son el mismo. SOLUCIÓN Comprobar que todos los perfiles de superficie sean cerrados." .

ns1:Fallo_1972 a ns1:DiagnosticoFallo ;
    rdfs:label "Perfil en XY no válido" ;
    ns1:identificador "1972" ;
    ns1:solucionaFallo ns1:Parametro_PerfilXY ;
    ns1:textoExtracto "1972 'Perfil en XY no valido' [...] CAUSA El perfil de superficie no existe. SOLUCIÓN Editar el perfil. El CNC guarda los perfiles en la carpeta ..\\Users\\Profile." .

ns1:Fallo_1973 a ns1:DiagnosticoFallo ;
    rdfs:label "Perfil en Z no válido" ;
    ns1:identificador "1973" ;
    ns1:solucionaFallo ns1:Parametro_PerfilZ ;
    ns1:textoExtracto "1973 'Perfil en Z no valido' [...] CAUSA Algún perfil de profundidad es cerrado o el ciclo no puede mecanizar algún perfil de profundidad con la herramienta programada. SOLUCIÓN Comprobar que los perfiles de profundidad son correctos." .

ns1:Fallo_1974 a ns1:DiagnosticoFallo ;
    rdfs:label "Intersección de perfiles no válida" ;
    ns1:identificador "1974" ;
    ns1:textoExtracto "1974 'Intersección de perfiles no valida' [...] CAUSA Dos perfiles de superficie generan alguna intersección no válida." .

ns1:Parametro_CotaZ_PlanoPartida a ns1:Parametro ;
    rdfs:label "Cota Z del plano de partida" ;
    ns1:textoExtracto "La cota Z de comienzo del ciclo debe estar por encima del plano de referencia." ;
    ns1:valor "Por encima del plano de referencia" .

ns1:Parametro_PlanoSeguridad a ns1:Parametro ;
    rdfs:label "Plano de seguridad (Cota Z)" ;
    ns1:textoExtracto "El plano de seguridad se encuentra dentro de la pieza." ;
    ns1:valor "Fuera de la pieza" .

ns1:Parametro_PerfilZ a ns1:Parametro ;
    rdfs:label "Perfil de profundidad (Z)" ;
    ns1:textoExtracto "El perfil de profundidad no existe [...] El CNC guarda los perfiles en la carpeta ..\\Users\\Profile." .

ns1:Parametro_PerfilXY a ns1:Parametro ;
    rdfs:label "Perfil de superficie (XY)" ;
    ns1:textoExtracto "El perfil de superficie no existe [...] El CNC guarda los perfiles en la carpeta ..\\Users\\Profile." .

