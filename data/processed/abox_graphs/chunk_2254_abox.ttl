@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1974 a ns1:DiagnosticoFallo ;
    rdfs:label "Intersección de perfiles no válida" ;
    ns1:identificador "1974" ;
    ns1:textoExtracto "Durante la ejecución del ciclo. Dos perfiles de superficie generan alguna intersección no válida." .

ns1:Fallo_1975 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha producido palpación" ;
    ns1:identificador "1975" ;
    ns1:textoExtracto "Durante la ejecución" .

