@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_1976 a ns1:Alarma ;
    rdfs:label "Alarma 1976: Operación no programada"@es ;
    ns1:identificador "1976" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_1976 ;
    ns1:textoExtracto "'No programado DESBASTE ni ACABADO' DETECCIÓN Durante la ejecución del ciclo. CAUSA No hay definida ninguna operación en el ciclo fijo."@es .

ns1:Alarma_1977 a ns1:Alarma ;
    rdfs:label "Alarma 1977: Radio de herramienta excesivo"@es ;
    ns1:identificador "1977" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_1977 ;
    ns1:textoExtracto "'Radio de herramienta de taladrado demasiado grande' DETECCIÓN Durante la ejecución. CAUSA El radio de la herramienta de taladrado es demasiado grande para la geometría de la cajera."@es .

ns1:Componente_Pieza a ns1:Componente ;
    rdfs:label "Pieza a palpar"@es ;
    ns1:textoExtracto "el palpador no ha tocado la pieza"@es .

ns1:Parametro_RadioHerramienta a ns1:Parametro ;
    rdfs:label "Radio de herramienta de taladrado"@es ;
    ns1:monitoreaParametro ns1:Herramienta_Taladrado ;
    ns1:textoExtracto "El radio de la herramienta de taladrado es demasiado grande para la geometría de la cajera"@es ;
    ns1:valor "demasiado grande"@es .

ns1:Sensor_Palpador a ns1:Sensor ;
    rdfs:label "Palpador"@es ;
    ns1:activaAlarma ns1:Alarma_1975 ;
    ns1:textoExtracto "el palpador no ha tocado la pieza durante el movimiento de palpación"@es .

ns1:Alarma_1975 a ns1:Alarma ;
    rdfs:label "Alarma 1975: No se ha producido palpación"@es ;
    ns1:identificador "1975" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_1975 ;
    ns1:textoExtracto "'No se ha producido palpación' DETECCIÓN Durante la ejecución de un ciclo de palpador. CAUSA El palpador no ha tocado la pieza durante el movimiento de palpación."@es .

ns1:DiagnosticoFallo_1975 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en palpación: ciclo mal definido"@es ;
    ns1:textoExtracto "El palpador no ha tocado la pieza durante el movimiento de palpación. SOLUCIÓN Corregir la definición del ciclo fijo."@es .

ns1:DiagnosticoFallo_1976 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en ciclo: operación no definida"@es ;
    ns1:requiereConsumible ns1:Herramienta_Desbaste_Acabado ;
    ns1:textoExtracto "No hay definida ninguna operación en el ciclo fijo. SOLUCIÓN En el ciclo fijo debe estar definida la operación de desbaste o acabado. Si una operación no tiene herramienta, el ciclo no la ejecuta; al menos una operación tiene que tener herramienta."@es .

ns1:DiagnosticoFallo_1977 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en taladrado: radio de herramienta incompatible"@es ;
    ns1:textoExtracto "El radio de la herramienta de taladrado es demasiado grande para la geometría de la cajera."@es .

ns1:Herramienta_Desbaste_Acabado a ns1:Herramienta ;
    rdfs:label "Herramienta para desbaste o acabado"@es ;
    ns1:textoExtracto "al menos una operación tiene que tener herramienta"@es .

ns1:Herramienta_Taladrado a ns1:Herramienta ;
    rdfs:label "Herramienta de taladrado"@es ;
    ns1:textoExtracto "El radio de la herramienta de taladrado"@es .

