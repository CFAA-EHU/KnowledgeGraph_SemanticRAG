@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Esfera_Calibracion a ns1:ComponenteMecanico ;
    rdfs:label "Esfera de referencia para calibración" ;
    ns1:textoExtracto "el palpador no ha tocado la esfera" .

ns1:Palpador_Calibracion a ns1:ComponenteMecanico ;
    rdfs:label "Palpador de calibración cinemática" ;
    ns1:textoExtracto "colocar el palpador en la posición correcta; encima de la bola, a una distancia de unas 10 mm (0.4 pulgadas) aproximadamente" .

ns1:Solucion_1985 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación y posicionamiento del palpador" ;
    ns1:solucionaFallo ns1:Fallo_1985 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Antes de ejecutar el ciclo, colocar el palpador en la posición correcta; encima de la bola, a una distancia de unas 10 mm (0.4 pulgadas) aproximadamente." .

ns1:Solucion_1986 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación del ciclo de calibración" ;
    ns1:solucionaFallo ns1:Fallo_1986 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:Solucion_RadioHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Corrección del radio en tabla de herramientas" ;
    ns1:documentadoEn ns1:Tabla_Herramientas ;
    ns1:requiereConsumible ns1:Herramienta_Taladrado_Defectuosa ;
    ns1:textoExtracto "SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

ns1:Fallo_1985 a ns1:DiagnosticoFallo ;
    rdfs:label "El palpador no ha tocado la esfera" ;
    ns1:identificador "1985" ;
    ns1:textoExtracto "1985 'El palpador no ha tocado la esfera' DETECCIÓN Durante la ejecución. CAUSA Al ejecutar el ciclo de calibración de cinemáticas, el palpador no ha tocado la esfera. SOLUCIÓN Revisar la programación. Antes de ejecutar el ciclo, colocar el palpador en la posición correcta; encima de la bola, a una distancia de unas 10 mm (0.4 pulgadas) aproximadamente." .

ns1:Fallo_1986 a ns1:DiagnosticoFallo ;
    rdfs:label "El palpador ha tocado la esfera cuando no se esperaba" ;
    ns1:identificador "1986" ;
    ns1:textoExtracto "1986 'El palpador ha tocado la esfera cuando no se esperaba' DETECCIÓN Durante la ejecución. CAUSA Al ejecutar el ciclo de calibración de cinemáticas, el palpador ha tocado la esfera cuando no debía hacerlo. SOLUCIÓN Revisar la programación." .

ns1:Herramienta_Taladrado_Defectuosa a ns1:Herramienta ;
    rdfs:label "Herramienta de taladrado con radio excesivo" ;
    ns1:textoExtracto "CAUSA El radio de la herramienta de taladrado es demasiado grande para la geometría de la cajera." .

ns1:Tabla_Herramientas a ns1:Tabla ;
    rdfs:label "Tabla de herramientas" ;
    ns1:textoExtracto "SOLUCIÓN Corregir el valor del radio en la tabla de herramientas o seleccionar otra herramienta." .

