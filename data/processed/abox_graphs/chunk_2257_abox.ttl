@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_1987 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso: Posicionamiento previo del palpador"@es ;
    ns1:mitigaRiesgo ns1:AccionProhibida_1987 ;
    ns1:textoExtracto "Antes de ejecutar el ciclo, colocar el palpador en la posición correcta; encima de la bola, a una distancia de unas 10 mm (0.4 pulgadas) aproximadamente."@es .

ns1:DiagnosticoFallo_1987 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1987: 'No hay contacto con la esfera'"@es ;
    ns1:identificador "1987" ;
    ns1:solucionaFallo ns1:AccionProhibida_1987 ;
    ns1:textoExtracto "1987 'No hay contacto con la esfera' [...] No ha llegado señal de palpado cuando se esperaba tocar la esfera."@es .

ns1:DiagnosticoFallo_1988 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 1988: 'El tipo de palpador no es válido (P6)'"@es ;
    ns1:identificador "1988" ;
    ns1:textoExtracto "1988 'El tipo de palpador no es valido (P6)'"@es .

ns1:Sensor_Palpador a ns1:Sensor ;
    rdfs:label "Palpador"@es ;
    ns1:monitoreaParametro ns1:Parametro_Cinematica ;
    ns1:textoExtracto "palpador"@es .

ns1:Parametro_Cinematica a ns1:Parametro ;
    rdfs:label "Parámetro de error máximo de cinemática"@es ;
    ns1:textoExtracto "Asegúrese de que los parámetros de cinemática tienen un error máximo de 1 mm."@es ;
    ns1:valor "1 mm" .

ns1:AccionProhibida_1987 a ns1:AccionProhibida ;
    rdfs:label "Ejecutar ciclo sin posicionar correctamente el palpador"@es ;
    ns1:textoExtracto "Antes de ejecutar el ciclo, colocar el palpador en la posición correcta; encima de la bola, a una distancia de unas 10 mm (0.4 pulgadas) aproximadamente."@es .

