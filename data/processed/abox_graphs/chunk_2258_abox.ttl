@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1989 a ns1:DiagnosticoFallo ;
    rdfs:label "Error: Cinemática no calibrable"@es ;
    ns1:identificador "1989" ;
    ns1:textoExtracto "1989 'No se puede calibrar este tipo de cinemática' DETECCIÓN Durante la ejecución. CAUSA La calibración de este tipo de cinemática no esta implementada."@es .

ns1:Fallo_1991 a ns1:DiagnosticoFallo ;
    rdfs:label "Error: Posiciones inicial y final iguales en ejes rotativos"@es ;
    ns1:identificador "1991" ;
    ns1:textoExtracto "1991 'Error de parametrización. La posición inicial y final no pueden ser iguales' DETECCIÓN Durante la ejecución. CAUSA La posición inicial y final de los ejes rotativos es la misma. SOLUCIÓN La posición final de los ejes rotativos debe ser diferente de la posición inicial."@es .

ns1:Fallo_1992 a ns1:DiagnosticoFallo ;
    rdfs:label "Error: Ejes rotativos no en posición de reposo"@es ;
    ns1:identificador "1992" ;
    ns1:textoExtracto "1992 'Los ejes rotativos de la cinemática tienen que estar en su posición de reposo' DETECCIÓN Durante la ejecución. CAUSA Los ejes rotativos no están en su posición de reposo. SOLUCIÓN Posicionar los ejes rotativos en su posición de reposo."@es .

ns1:Parametro_P6 a ns1:Parametro ;
    rdfs:label "Parámetro P6 (Tipo de palpador)"@es ;
    ns1:monitoreaParametro ns1:Fallo_1988 ;
    ns1:textoExtracto "El parámetro P6 sólo admite valores 0 y 1."@es ;
    ns1:valor "0,1" .

ns1:SistemaCinematico a ns1:Sistema ;
    rdfs:label "Sistema de cinemática"@es ;
    ns1:monitoreaParametro ns1:Parametro_ErrorMaximoCinematica,
        ns1:Parametro_PosicionReposoEjes ;
    ns1:textoExtracto "ejes rotativos de la cinemática"@es ;
    ns1:tieneComponente ns1:Sensor_Palpador .

ns1:Variable_VGPOSROTx a ns1:Parametro ;
    rdfs:label "Variable V.G.POSROTx (Posición ejes rotativos manuales)"@es ;
    ns1:monitoreaParametro ns1:Fallo_1994 ;
    ns1:textoExtracto "La posición de los ejes rotativos manuales de la cinemática, tiene que ser 0 y estar indicado en las variables V.G.POSROTx."@es ;
    ns1:valor "0" .

ns1:Fallo_1988 a ns1:DiagnosticoFallo ;
    rdfs:label "Error: Tipo de palpador no válido (P6)"@es ;
    ns1:identificador "1988" ;
    ns1:textoExtracto "1988 'El tipo de palpador no es valido (P6)' DETECCIÓN Durante la ejecución. CAUSA El tipo de palpador seleccionado no es válido. SOLUCIÓN El parámetro P6 sólo admite valores 0 y 1."@es .

ns1:Fallo_1990 a ns1:DiagnosticoFallo ;
    rdfs:label "Error: Falta contacto con esfera de palpado"@es ;
    ns1:identificador "1990" ;
    ns1:textoExtracto "No ha llegado señal de palpado cuando se esperaba tocar la esfera. SOLUCIÓN Asegúrese de que los parámetros de cinemática tienen un error máximo de 1 mm."@es .

ns1:Fallo_1993 a ns1:DiagnosticoFallo ;
    rdfs:label "Error: Posición de reposo de ejes rotativos no es cero"@es ;
    ns1:identificador "1993" ;
    ns1:textoExtracto "1993 'La posición de reposo de los ejes rotativos de la cinemática tiene que ser cero' DETECCIÓN Durante la ejecución. CAUSA En los parámetros máquina de la cinemática la posición de reposo de los ejes tiene que ser 0. SOLUCIÓN Poner a cero la posición de reposo en los parámetros máquina."@es .

ns1:Fallo_1994 a ns1:DiagnosticoFallo ;
    rdfs:label "Error: Posición de ejes rotativos manuales no es cero"@es ;
    ns1:identificador "1994" ;
    ns1:textoExtracto "1994 La posición de los ejes rotativos manuales de la cinemática, tiene que ser 0 y estar indicado en las variables V.G.POSROTx."@es .

ns1:Parametro_ErrorMaximoCinematica a ns1:Parametro ;
    rdfs:label "Error máximo permitido en parámetros de cinemática"@es ;
    ns1:monitoreaParametro ns1:Fallo_1990 ;
    ns1:textoExtracto "Asegúrese de que los parámetros de cinemática tienen un error máximo de 1 mm."@es ;
    ns1:valor "1 mm" .

ns1:Parametro_PosicionReposoEjes a ns1:Parametro ;
    rdfs:label "Posición de reposo de ejes rotativos"@es ;
    ns1:monitoreaParametro ns1:Fallo_1993 ;
    ns1:textoExtracto "En los parámetros máquina de la cinemática la posición de reposo de los ejes tiene que ser 0."@es ;
    ns1:valor "0" .

ns1:Sensor_Palpador a ns1:Sensor ;
    rdfs:label "Palpador de contacto"@es ;
    ns1:textoExtracto "El palpador no está colocado encima de la bola o está muy lejos."@es .

