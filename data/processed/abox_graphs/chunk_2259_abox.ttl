@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_1994 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 1994: Posición de reposo no cero en ejes rotativos"@es ;
    ns1:identificador "1994" ;
    ns1:monitoreaParametro ns1:Parametro_VG_POSROTF,
        ns1:Parametro_VG_POSROTO,
        ns1:Parametro_VG_POSROTS,
        ns1:Parametro_VG_POSROTT,
        ns1:Parametro_VG_POSROTx ;
    ns1:solucionaFallo ns1:PonerACeroLaPosicionDeReposoEnParametrosMaquina ;
    ns1:textoExtracto "SOLUCIÓN Poner a cero la posición de reposo en los parámetros máquina. 1994 La posición de los ejes rotativos manuales de la cinemática, tiene que ser 0 y estar indicado en las variables V.G.POSROTx. DETECCIÓN Durante la ejecución. CAUSA Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero."@es .

ns1:Maquina_Cinematica a ns1:Maquina ;
    rdfs:label "Cinemática de la máquina"@es ;
    ns1:textoExtracto "La posición de los ejes rotativos manuales de la cinemática"@es ;
    ns1:tieneComponente ns1:EjesRotativosManuales .

ns1:EjesRotativosManuales a ns1:ComponenteMecanico ;
    rdfs:label "Ejes rotativos manuales"@es ;
    ns1:textoExtracto "ejes rotativos manuales de la cinemática"@es .

ns1:Parametro_VG_POSROTF a ns1:Parametro ;
    rdfs:label "Variable de posición de reposo (V.G.POSROTF)"@es ;
    ns1:identificador "V.G.POSROTF" ;
    ns1:textoExtracto "Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero."@es .

ns1:Parametro_VG_POSROTO a ns1:Parametro ;
    rdfs:label "Variable de posición de reposo (V.G.POSROTO)"@es ;
    ns1:identificador "V.G.POSROTO" ;
    ns1:textoExtracto "Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero."@es .

ns1:Parametro_VG_POSROTS a ns1:Parametro ;
    rdfs:label "Variable de posición de reposo (V.G.POSROTS)"@es ;
    ns1:identificador "V.G.POSROTS" ;
    ns1:textoExtracto "Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero."@es .

ns1:Parametro_VG_POSROTT a ns1:Parametro ;
    rdfs:label "Variable de posición de reposo (V.G.POSROTT)"@es ;
    ns1:identificador "V.G.POSROTT" ;
    ns1:textoExtracto "Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero."@es .

ns1:Parametro_VG_POSROTx a ns1:Parametro ;
    rdfs:label "Variable de posición de reposo (V.G.POSROTx)"@es ;
    ns1:identificador "V.G.POSROTx" ;
    ns1:textoExtracto "La posición de los ejes rotativos manuales de la cinemática, tiene que ser 0 y estar indicado en las variables V.G.POSROTx."@es ;
    ns1:valor "0" .

ns1:PonerACeroLaPosicionDeReposoEnParametrosMaquina a ns1:AccionProhibida ;
    rdfs:label "Poner a cero la posición de reposo en parámetros máquina"@es ;
    ns1:textoExtracto "Poner a cero la posición de reposo en los parámetros máquina."@es .

