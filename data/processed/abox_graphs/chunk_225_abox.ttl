@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Funcion_G00 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G00 (Rapid traverse)"@en ;
    ns1:documentadoEn ns1:Tabla_CodigosG_M ;
    ns1:identificador "G00" ;
    ns1:textoExtracto "Rapid traverse."@en .

ns1:Funcion_G01 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G01 (Linear interpolation)"@en ;
    ns1:documentadoEn ns1:Tabla_CodigosG_M ;
    ns1:identificador "G01" ;
    ns1:textoExtracto "Linear interpolation."@en .

ns1:Funcion_G02 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G02 (Clockwise circular interpolation)"@en ;
    ns1:documentadoEn ns1:Tabla_CodigosG_M ;
    ns1:identificador "G02" ;
    ns1:textoExtracto "Clockwise circular (helical) interpolation."@en .

ns1:Funcion_G03 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G03 (Counterclockwise circular interpolation)"@en ;
    ns1:documentadoEn ns1:Tabla_CodigosG_M ;
    ns1:identificador "G03" ;
    ns1:textoExtracto "Counterclockwise circular (helical) interpolation."@en .

ns1:Funcion_G05 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G05 (Controlled corner rounding)"@en ;
    ns1:documentadoEn ns1:Tabla_CodigosG_M ;
    ns1:identificador "G05" ;
    ns1:textoExtracto "Controlled corner rounding (modal)."@en .

ns1:Funcion_G10 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G10 (Cancel mirror image)"@en ;
    ns1:documentadoEn ns1:Tabla_CodigosG_M ;
    ns1:identificador "G10" ;
    ns1:textoExtracto "Cancel mirror image on all the axes."@en .

ns1:Funcion_G17 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G17 (Main plane selection)"@en ;
    ns1:documentadoEn ns1:Tabla_CodigosG_M ;
    ns1:identificador "G17" ;
    ns1:textoExtracto "Main plane formed by the first axis (abscissa), second (ordinate) and third axis (perpendicular) of the channel."@en .

ns1:Tabla_CodigosG_M a ns1:Tabla ;
    rdfs:label "Tabla de funciones G y M modales en CNC"@es ;
    ns1:textoExtracto """
·M· Modal function. Those cases indicated with "!", mean the function remains active even after an M02, M30 or a reset and after the CNC is powered off and back on.
· D· Default function. Those cases indicated with "?" mean that the default quality of the function depends on the settings of the CNC machine parameters.
· V· This function is displayed in the G-code history.
| Function | M | D | V | Meaning |
| G00 | * | ? | * | Rapid traverse. |
| G01 | * | ? | * | Linear interpolation. |
| G02 | * |  | * | Clockwise circular (helical) interpolation. |
| G03 | * |  | * | Counterclockwise circular (helical) interpolation. |
| G04 |  |  | * | Dwell. |
| G05 | * | ? | * | Controlled corner rounding (modal). |
| G17 | * | ? | * | Main plane formed by the first axis (abscissa), second (ordinate) and third axis (perpendicular) of the channel.
""" .

