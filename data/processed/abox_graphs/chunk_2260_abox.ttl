@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_1995 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha elegido ningún eje para la calibración"@es ;
    ns1:identificador "1995" ;
    ns1:textoExtracto "1995 No se ha elegido ningún eje para la calibración. DETECCIÓN Durante la ejecución. CAUSA No se ha elegido ningún eje para la calibración. SOLUCIÓN Elegir un eje."@es .

ns1:Fallo_1996 a ns1:DiagnosticoFallo ;
    rdfs:label "El COMPID está siendo utilizado por otro KINID"@es ;
    ns1:identificador "1996" ;
    ns1:textoExtracto "1996 El COMPID está siendo utilizado por otro KINID. DETECCIÓN Durante la ejecución. CAUSA El COMPID está siendo utilizado por otro KINID. SOLUCIÓN Seleccionar otro COMPID."@es .

ns1:Fallo_VariablesCinematica a ns1:DiagnosticoFallo ;
    rdfs:label "Variables de posición rotativa no nulas en cinemática"@es ;
    ns1:monitoreaParametro ns1:Parametro_VG_POSROTF,
        ns1:Parametro_VG_POSROTO,
        ns1:Parametro_VG_POSROTS,
        ns1:Parametro_VG_POSROTT ;
    ns1:textoExtracto "Durante la ejecución. CAUSA Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero. SOLUCIÓN El valor de estas variables debe ser cero."@es .

ns1:Parametro_VG_POSROTF a ns1:Parametro ;
    rdfs:label "V.G.POSROTF" ;
    ns1:textoExtracto "Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero."@es ;
    ns1:valor "0" .

ns1:Parametro_VG_POSROTO a ns1:Parametro ;
    rdfs:label "V.G.POSROTO" ;
    ns1:textoExtracto "Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero."@es ;
    ns1:valor "0" .

ns1:Parametro_VG_POSROTS a ns1:Parametro ;
    rdfs:label "V.G.POSROTS" ;
    ns1:textoExtracto "Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero."@es ;
    ns1:valor "0" .

ns1:Parametro_VG_POSROTT a ns1:Parametro ;
    rdfs:label "V.G.POSROTT" ;
    ns1:textoExtracto "Las variables V.G.POSROTF/V.G.POSROTS/V.G.POSROTT/V.G.POSROTO de los ejes rotativos manuales de la cinemática no son cero."@es ;
    ns1:valor "0" .

