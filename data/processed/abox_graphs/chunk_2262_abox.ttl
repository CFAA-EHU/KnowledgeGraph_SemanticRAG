@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Solucion_CompensacionRadio_Lineal a ns1:AvisoSeguridad ;
    rdfs:label "Solución: bloque lineal para compensación de radio"@es ;
    ns1:solucionaFallo ns1:Fallo_CompensacionRadio_G40 ;
    ns1:textoExtracto "SOLUCIÓN La compensación de radio debe acabar en un bloque lineal."@es .

ns1:Fallo_CompensacionRadio_G40 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en compensación de radio (G40)"@es ;
    ns1:identificador "G40" ;
    ns1:textoExtracto "Durante la ejecución. CAUSA Después de desactivar la compensación de radio (G40), el siguiente bloque de movimiento es un bloque circular. La compensación de radio no puede acabar en un bloque circular."@es .

