@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_2006 a ns1:Alarma ;
    rdfs:label "Cambio de compensación de radio en trayectoria no lineal" ;
    ns1:identificador "2006" ;
    ns1:textoExtracto "'El cambio de compensación (G41/G42) debe hacerse en una trayectoria lineal' DETECCIÓN Durante la ejecución. CAUSA El programa ha cambiado el tipo de compensación de radio (de G41 a G42 o viceversa) y el siguiente bloque de movimiento es un bloque circular." .

ns1:Alarma_2007 a ns1:Alarma ;
    rdfs:label "Cancelación prematura de compensación de radio en modo directo (G138)" ;
    ns1:identificador "2007" ;
    ns1:textoExtracto "'Con G138 no se admite G40 tras el primer bloque de compensación' DETECCIÓN Durante la ejecución. CAUSA Tras activar la compensación de radio con el modo directo (G138), hay programada una cancelación de la compensación antes del primer bloque de desplazamiento." .

ns1:Alarma_2008 a ns1:Alarma ;
    rdfs:label "Cambio prematuro de tipo de compensación (G41/G42) en modo directo (G138)" ;
    ns1:identificador "2008" ;
    ns1:textoExtracto "'Con G138 no se admite cambio G41/G42 tras el primer bloque de compensación' DETECCIÓN Durante la ejecución. CAUSA Tras activar la compensación de radio con el modo directo (G138), hay programado un cambio del tipo de compensación (de G41 a G42 o viceversa) antes del primer bloque de desplazamiento." .

ns1:AvisoSeguridad_CompensacionRadio a ns1:AvisoSeguridad ;
    rdfs:label "Requisitos para compensación de radio en bloques de movimiento" ;
    ns1:textoExtracto "La compensación de radio no puede acabar en un bloque circular. SOLUCIÓN La compensación de radio debe acabar en un bloque de movimiento lineal. Por tanto, el bloque de movimiento que vaya a continuación de G40 debe ser un bloque de movimiento lineal." .

ns1:ModoOperacion_G138 a ns1:ModoOperacion ;
    rdfs:label "Modo directo de compensación de radio" ;
    ns1:identificador "G138" ;
    ns1:textoExtracto "compensación de radio con el modo directo (G138)" .

ns1:ModoOperacion_G139 a ns1:ModoOperacion ;
    rdfs:label "Modo indirecto de compensación de radio" ;
    ns1:identificador "G139" ;
    ns1:textoExtracto "utiliza el modo indirecto (G139) para activar la compensación de radio" .

ns1:Parametro_G40 a ns1:Parametro ;
    rdfs:label "Cancelación de compensación de radio" ;
    ns1:identificador "G40" ;
    ns1:textoExtracto "cancelación de la compensación (G40)" ;
    ns1:valor "Cancelación" .

ns1:Parametro_G41 a ns1:Parametro ;
    rdfs:label "Compensación de radio a izquierda" ;
    ns1:identificador "G41" ;
    ns1:textoExtracto "cambio del tipo de compensación (de G41 a G42 o viceversa)" ;
    ns1:valor "Izquierda" .

ns1:Parametro_G42 a ns1:Parametro ;
    rdfs:label "Compensación de radio a derecha" ;
    ns1:identificador "G42" ;
    ns1:textoExtracto "cambio del tipo de compensación (de G41 a G42 o viceversa)" ;
    ns1:valor "Derecha" .

