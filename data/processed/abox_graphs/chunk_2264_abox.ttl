@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_2009 a ns1:Alarma ;
    rdfs:label "Diferencia entre el radio inicial y final del arco demasiado grande" ;
    ns1:identificador "2009" ;
    ns1:textoExtracto "2009 'Diferencia entre el radio inicial y final del arco demasiado grande' DETECCIÓN Durante la ejecución. CAUSA En el arco programado, la diferencia entre el radio inicial y final es mayor que la tolerancia permitida. SOLUCIÓN Revisar la programación del arco." .

ns1:Alarma_2010 a ns1:Alarma ;
    rdfs:label "Radio de herramienta demasiado grande al calcular compensación entre arcos" ;
    ns1:identificador "2010" ;
    ns1:textoExtracto "2010 'Radio de herramienta demasiado grande al calcular compensación entre arcos' DETECCIÓN Durante la ejecución. CAUSA El radio de la herramienta es demasiado grande para el arco programado. SOLUCIÓN Utilizar una herramienta de menor radio, eliminar el arco del perfil o programar un arco más grande." .

ns1:Alarma_2011 a ns1:Alarma ;
    rdfs:label "Movimiento de compensación en trayectoria circular (perfil dañado)" ;
    ns1:identificador "2011" ;
    ns1:textoExtracto "2011 'Movimiento de compensación en trayectoria circular (perfil dañado)' DETECCIÓN Durante la ejecución. CAUSA El radio de la herramienta es demasiado grande para el arco programado. SOLUCIÓN Utilizar una herramienta de menor radio, eliminar el arco del perfil o programar un arco más grande." .

ns1:Alarma_2012 a ns1:Alarma ;
    rdfs:label "Bloque de transición no relevante eliminado" ;
    ns1:identificador "2012" ;
    ns1:textoExtracto "2012 Se ha eliminado un bloque de transición no relevante. DETECCIÓN Durante la ejecución. CAUSA La compensación de radio ha eliminado un bloque innecesario. SOLUCIÓN Aceptar la modificación propuesta y continuar con la ejecución." .

ns1:Alarma_2013 a ns1:Alarma ;
    rdfs:label "Diferente radio de herramienta entre la trayectoria anterior y una circular" ;
    ns1:identificador "2013" ;
    ns1:textoExtracto "2013 'Diferente radio de herramienta entre la trayectoria anterior y una circular' DETECCIÓN Durante la ejecución. CAUSA Al mecanizar un arco con la compensación de radio activa, el radio de la herramienta ha cambiado respecto al bloque anterior. SOLUCIÓN Con la compensación de radio activa, no cambiar el radio de la herramienta durante la ejecución de un arco." .

ns1:Alarma_2014 a ns1:Alarma ;
    rdfs:label "No hay intersección entre línea y arco: radio de herramienta demasiado grande" ;
    ns1:identificador "2014" ;
    ns1:textoExtracto "2014 No hay intersección entre línea y arco: radio de herramienta demasiado grande. DETECCIÓN Durante la ejecución. CAUSA El radio de la herramienta es demasiado grande para mecanizar la parte del perfil indicada. SOLUCIÓN Usar una herramienta de menor" .

ns1:Herramienta_CompensacionRadio a ns1:Herramienta ;
    rdfs:label "Herramienta para compensación de radio" ;
    ns1:textoExtracto "Utilizar una herramienta de menor radio, eliminar el arco del perfil o programar un arco más grande." .

ns1:ModoOperacion_G139 a ns1:ModoOperacion ;
    rdfs:label "Modo indirecto (G139) para compensación de radio" ;
    ns1:identificador "G139" ;
    ns1:textoExtracto "Si no es posible programar este bloque, utiliza el modo indirecto (G139) para activar la compensación de radio." .

