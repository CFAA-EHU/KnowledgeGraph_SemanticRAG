@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_2100 a ns1:AvisoSeguridad ;
    rdfs:label "Límite software positivo sobrepasado (2100)" ;
    ns1:identificador "2100" ;
    ns1:textoExtracto "'Límite software positivo sobrepasado en G5, G60 o HSC' DETECCIÓN Durante la ejecución." .

ns1:DiagnosticoFallo_2015 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Radio de herramienta excesivo" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_2015 ;
    ns1:textoExtracto "El radio de la herramienta es demasiado grande para mecanizar la parte del perfil indicada. SOLUCIÓN Usar una herramienta de menor radio." .

ns1:DiagnosticoFallo_2016 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Colisión en compensación de radio" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_2016 ;
    ns1:textoExtracto "La detección de colisiones durante la compensación de radio ha detectado una trayectoria que daña el perfil programado y la ha eliminado. SOLUCIÓN Dependiendo de la colisión detectada su solución puede ser utilizar una herramienta de radio menor, programar el perfil de otra forma o simplemente aceptar la modificación propuesta por el proceso de detección de colisiones." .

ns1:DiagnosticoFallo_2017 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Procesos incompatibles con detección de colisiones" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_2017 ;
    ns1:textoExtracto "La detección de colisiones no admite ciertos procesos como búsqueda de cero, movimiento con palpador, etc. SOLUCIÓN No activar la detección de colisiones si hay alguno de estos procesos programado." .

ns1:DiagnosticoFallo_2021 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Sobrecarga de CPU por modelo complejo" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_2021 ;
    ns1:textoExtracto "El modelo de la máquina y/o elementos colisionables es demasiado complejo. SOLUCIÓN Simplificar el modelo de la máquina." .

ns1:DiagnosticoFallo_2051 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Incompatibilidad entre splines y control tangencial" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_2051 ;
    ns1:textoExtracto "El CNC no permite activar el control tangencial con las splines activas ni viceversa. SOLUCIÓN Desactivar los splines antes activar el control tangencial o viceversa." .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC" ;
    ns1:textoExtracto "El modelo de la máquina y/o elementos colisionables es demasiado complejo" .

ns1:AvisoSeguridad_2015 a ns1:AvisoSeguridad ;
    rdfs:label "Radio de herramienta demasiado grande (2015)" ;
    ns1:identificador "2015" ;
    ns1:textoExtracto "No hay intersección entre arco y línea: radio de herramienta demasiado grande. DETECCIÓN Durante la ejecución. CAUSA El radio de la herramienta es demasiado grande para mecanizar la parte del perfil indicada. SOLUCIÓN Usar una herramienta de menor radio." .

ns1:AvisoSeguridad_2016 a ns1:AvisoSeguridad ;
    rdfs:label "Modificación de perfil por colisión (2016)" ;
    ns1:identificador "2016" ;
    ns1:textoExtracto "'Se ha modificado el perfil para evitar una colisión' DETECCIÓN Durante la ejecución. CAUSA La detección de colisiones durante la compensación de radio ha detectado una trayectoria que daña el perfil programado y la ha eliminado." .

ns1:AvisoSeguridad_2017 a ns1:AvisoSeguridad ;
    rdfs:label "Programación no permitida con detección de colisiones activa (2017)" ;
    ns1:identificador "2017" ;
    ns1:textoExtracto "'Programación no permitida con detección de colisiones activa' DETECCIÓN Durante la ejecución. CAUSA La detección de colisiones no admite ciertos procesos como búsqueda de cero, movimiento con palpador, etc." .

ns1:AvisoSeguridad_2021 a ns1:AvisoSeguridad ;
    rdfs:label "Sobrecarga de CPU en detección de colisiones (2021)" ;
    ns1:identificador "2021" ;
    ns1:textoExtracto "Sobrecarga de CPU en el cálculo de detección de colisiones. DETECCIÓN Durante la preparación de bloques. CAUSA El modelo de la máquina y/o elementos colisionables es demasiado complejo." .

ns1:AvisoSeguridad_2051 a ns1:AvisoSeguridad ;
    rdfs:label "Splines y control tangencial incompatibles (2051)" ;
    ns1:identificador "2051" ;
    ns1:textoExtracto "'Programación de splines y control tangencial incompatibles' DETECCIÓN Durante la ejecución. CAUSA El CNC no permite activar el control tangencial con las splines activas ni viceversa." .

ns1:Herramienta a ns1:Herramienta ;
    rdfs:label "Herramienta de mecanizado" ;
    ns1:textoExtracto "radio de la herramienta es demasiado grande para mecanizar la parte del perfil indicada" .

