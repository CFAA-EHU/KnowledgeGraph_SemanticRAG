@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_DesactivarSplinesConControlTangencial a ns1:AccionProhibida ;
    rdfs:label "Desactivar los splines antes de activar el control tangencial o viceversa"@es ;
    ns1:solucionaFallo ns1:AvisoSeguridad_2100 ;
    ns1:textoExtracto "SOLUCIÓN Desactivar los splines antes activar el control tangencial o viceversa."@es .

ns1:AvisoSeguridad_2100 a ns1:AvisoSeguridad ;
    rdfs:label "Límite software positivo sobrepasado en G5, G60 o HSC"@es ;
    ns1:identificador "2100" ;
    ns1:textoExtracto "2100 'Límite software positivo sobrepasado en G5, G60 o HSC' DETECCIÓN Durante la ejecución. CAUSA La trayectoria que genera el CNC en G05, G60 o HSC queda fuera de los límites de recorrido activos."@es .

