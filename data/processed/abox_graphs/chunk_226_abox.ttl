@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FuncionG18 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G18" ;
    ns1:documentadoEn ns1:Tabla_FuncionesG ;
    ns1:identificador "G18" ;
    ns1:textoExtracto "Main plane formed by the third axis (abscissa), first axis (ordinate) and second axis (perpendicular) of the channel."@en .

ns1:FuncionG19 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G19" ;
    ns1:documentadoEn ns1:Tabla_FuncionesG ;
    ns1:identificador "G19" ;
    ns1:textoExtracto "Main plane formed by the second axis (abscissa), third axis (ordinate) and first axis (perpendicular) of the channel."@en .

ns1:FuncionG20 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G20" ;
    ns1:documentadoEn ns1:Tabla_FuncionesG ;
    ns1:identificador "G20" ;
    ns1:textoExtracto "Select any work plane formed by the first three axes of the channel."@en .

ns1:FuncionG33 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G33" ;
    ns1:documentadoEn ns1:Tabla_FuncionesG ;
    ns1:identificador "G33" ;
    ns1:textoExtracto "Electronic threading with constant pitch."@en .

ns1:FuncionG40 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G40" ;
    ns1:documentadoEn ns1:Tabla_FuncionesG ;
    ns1:identificador "G40" ;
    ns1:textoExtracto "Cancel tool radius compensation."@en .

ns1:FuncionG41 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G41" ;
    ns1:documentadoEn ns1:Tabla_FuncionesG ;
    ns1:identificador "G41" ;
    ns1:textoExtracto "Left-hand tool radius compensation."@en .

ns1:FuncionG42 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G42" ;
    ns1:documentadoEn ns1:Tabla_FuncionesG ;
    ns1:identificador "G42" ;
    ns1:textoExtracto "Right-hand tool radius compensation."@en .

ns1:FuncionG53 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G53" ;
    ns1:documentadoEn ns1:Tabla_FuncionesG ;
    ns1:identificador "G53" ;
    ns1:textoExtracto "Cancel zero offset."@en .

ns1:FuncionG54 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G54" ;
    ns1:documentadoEn ns1:Tabla_FuncionesG ;
    ns1:identificador "G54" ;
    ns1:textoExtracto "Zero offset. Absolute zero offset 1."@en .

ns1:FuncionG63 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G63" ;
    ns1:documentadoEn ns1:Tabla_FuncionesG ;
    ns1:identificador "G63" ;
    ns1:textoExtracto "Rigid tapping."@en .

ns1:Tabla_FuncionesG a ns1:Tabla ;
    rdfs:label "Tabla de funciones G para control de máquina"@es ;
    ns1:documentadoEn ns1:Manual_Tecnologico ;
    ns1:textoExtracto "Function | M | D | V | Meaning. | G18 | * | ? | * | Main plane formed by the third axis (abscissa), first axis (ordinate) and second axis (perpendicular) of the channel. | G19 | * |  | * | Main plane formed by the second axis (abscissa), third axis (ordinate) and first axis (perpendicular) of the channel. [...] G63 | * |  | * | Rigid tapping." .

