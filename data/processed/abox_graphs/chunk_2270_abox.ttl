@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_2113 a ns1:DiagnosticoFallo ;
    rdfs:label "SPLINE: Tangente final indeterminada"@es ;
    ns1:identificador "2113" ;
    ns1:textoExtracto "2113 SPLINE:Tangente final indeterminada. DETECCIÓN Durante la ejecución. CAUSA El punto final del spline coincide con el punto anterior y queda la tangente indeterminada o bien se ha programado sólo un eje de la tangente."@es .

ns1:DiagnosticoFallo_2114 a ns1:DiagnosticoFallo ;
    rdfs:label "SPLINE: Activación no completada"@es ;
    ns1:identificador "2114" ;
    ns1:textoExtracto "2114 SPLINE:Activación no"@es .

