@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_2123 a ns1:AvisoSeguridad ;
    rdfs:label "Programación no permitida con splines activos" ;
    ns1:identificador "2123" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_ProgramarConSplinesActivos ;
    ns1:textoExtracto "2123 'Programación no permitida con splines activos'" .

ns1:ModoOperacion_Spline a ns1:ModoOperacion ;
    rdfs:label "Modo spline" ;
    ns1:textoExtracto "modo spline activo" .

ns1:Sistema_Coordenadas a ns1:Sistema ;
    rdfs:label "Sistema de coordenadas" ;
    ns1:textoExtracto "cambio de sistema de coordenadas" .

ns1:AccionProhibida_ProgramarConSplinesActivos a ns1:AccionProhibida ;
    rdfs:label "Programar con modo spline activo" ;
    ns1:textoExtracto "Con el modo spline activo, hay programado un cambio de sistema de coordenadas o sentencias que detienen la preparación de bloques." .

