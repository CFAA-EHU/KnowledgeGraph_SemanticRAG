@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_2130 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la transformación de plano inclinado" ;
    ns1:identificador "2130" ;
    ns1:textoExtracto "2130 'Error en la transformación de plano inclinado' DETECCIÓN Durante la ejecución. CAUSA Hay programado un plano inclinado y no hay tres ejes en el canal. SOLUCIÓN Antes de activar el plano inclinado, configurar el canal con los ejes necesarios." .

ns1:Error_2131 a ns1:DiagnosticoFallo ;
    rdfs:label "Error interno en modo eje C" ;
    ns1:identificador "2131" ;
    ns1:textoExtracto "2131 'Error interno en modo eje C' DETECCIÓN Durante la ejecución. CAUSA No es posible la transformación de eje C para el bloque. SOLUCIÓN Eliminar el bloque o bloques que provocan el error." .

ns1:Error_2132 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro máquina PROBERANGE no programado" ;
    ns1:identificador "2132" ;
    ns1:monitoreaParametro ns1:Parametro_PROBERANGE ;
    ns1:textoExtracto "2132 Parámetro máquina PROBERANGE no programado. DETECCIÓN Durante la ejecución. CAUSA No se ha definido el parámetro PROBERANGE. SOLUCIÓN Definir el parámetro PROBERANGE." .

ns1:Error_2133 a ns1:DiagnosticoFallo ;
    rdfs:label "El eje maestro no existe" ;
    ns1:identificador "2133" ;
    ns1:textoExtracto "2133 El eje maestro no existe. DETECCIÓN Durante la ejecución. CAUSA El eje maestro del acoplo no está disponible en el canal. SOLUCIÓN Programar los acoplos con ejes del canal." .

ns1:Error_2134 a ns1:DiagnosticoFallo ;
    rdfs:label "El eje esclavo no existe" ;
    ns1:identificador "2134" ;
    ns1:textoExtracto "2134 El eje esclavo no existe. DETECCIÓN Durante la ejecución. CAUSA El eje esclavo del acoplo no está disponible en el canal. SOLUCIÓN Programar los acoplos con ejes del canal." .

ns1:Error_2135 a ns1:DiagnosticoFallo ;
    rdfs:label "Programada velocidad máxima de cabezal nula" ;
    ns1:identificador "2135" ;
    ns1:monitoreaParametro ns1:Parametro_VelocidadMaximaCabezal ;
    ns1:textoExtracto "2135 'Programada velocidad máxima de cabezal nula' DETECCIÓN Durante la ejecución. CAUSA En velocidad de corte constante no se ha programado la velocidad máxima de cabezal. SOLUCIÓN Programar las revoluciones máximas del cabezal." .

ns1:Error_2136 a ns1:DiagnosticoFallo ;
    rdfs:label "Programada velocidad máxima de corte nula" ;
    ns1:identificador "2136" ;
    ns1:monitoreaParametro ns1:Parametro_VelocidadMaximaCorte ;
    ns1:textoExtracto "2136 'Programada velocidad máxima de corte nula' DETECCIÓN Durante la ejecución. CAUSA En velocidad de corte constante no se ha programado la velocidad de corte. SOLUCIÓN Programar la velocidad de corte." .

ns1:Error_2137 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha definido FACEAXIS" ;
    ns1:identificador "2137" ;
    ns1:monitoreaParametro ns1:Parametro_FACEAXIS ;
    ns1:textoExtracto "2137 No se ha definido FACEAXIS. DETECCIÓN Durante la ejecución. CAUSA No hay definido un eje frontal." .

ns1:Parametro_FACEAXIS a ns1:Parametro ;
    rdfs:label "FACEAXIS" ;
    ns1:textoExtracto "No se ha definido FACEAXIS." .

ns1:Parametro_PROBERANGE a ns1:Parametro ;
    rdfs:label "PROBERANGE" ;
    ns1:textoExtracto "Parámetro máquina PROBERANGE no programado." .

ns1:Parametro_VelocidadMaximaCabezal a ns1:Parametro ;
    rdfs:label "Velocidad máxima de cabezal" ;
    ns1:textoExtracto "velocidad máxima de cabezal" .

ns1:Parametro_VelocidadMaximaCorte a ns1:Parametro ;
    rdfs:label "Velocidad máxima de corte" ;
    ns1:textoExtracto "velocidad de corte" .

