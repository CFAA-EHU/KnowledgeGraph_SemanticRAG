@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Fallo_2137 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 2137: Eje frontal no definido" ;
    ns1:identificador "2137" ;
    ns1:solucionaFallo ns1:FACEAXIS_dc77a4579e ;
    ns1:textoExtracto "2137 No se ha definido FACEAXIS. [...] CAUSA No hay definido un eje frontal. SOLUCIÓN Poner el parámetro máquina FACEAXIS a TRUE para el eje que sea el eje frontal." .

ns1:Fallo_2138 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 2138: Eje de roscado no configurado" ;
    ns1:identificador "2138" ;
    ns1:textoExtracto "2138 No se ha definido eje de roscado. [...] CAUSA El eje de roscado no se encuentra en el canal. SOLUCIÓN Programar el roscado con los ejes disponibles o configurar los ejes del canal para poder realizar" .

ns1:Fallo_VelocidadCorteNoProgramada a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Velocidad de corte no programada" ;
    ns1:solucionaFallo ns1:Parametro_VelocidadCorte ;
    ns1:textoExtracto "CAUSA En velocidad de corte constante no se ha programado la velocidad de corte. SOLUCIÓN Programar la velocidad de corte." .

ns1:FACEAXIS_dc77a4579e a ns1:Parametro ;
    rdfs:label "FACEAXIS" ;
    ns1:textoExtracto "parámetro máquina FACEAXIS" ;
    ns1:valor true .

ns1:Parametro_VelocidadCorte a ns1:Parametro ;
    rdfs:label "Velocidad de corte" ;
    ns1:textoExtracto "velocidad de corte constante no se ha programado la velocidad de corte. SOLUCIÓN Programar la velocidad de corte." .

