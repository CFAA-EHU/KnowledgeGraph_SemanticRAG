@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_2141 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2141: Trayectorias circulares no permitidas" ;
    ns1:identificador "2141" ;
    ns1:textoExtracto "CAUSA No se permiten trayectorias circulares si no hay al menos dos ejes en el canal. SOLUCIÓN Configurar el canal con al menos dos ejes." .

ns1:AvisoSeguridad_2142 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2142: Programación no permitida con eje(s) Hirth" ;
    ns1:identificador "2142" ;
    ns1:textoExtracto "2142 'Programación no permitida con eje(s) Hirth' DETECCIÓN Durante la ejecución. CAUSA Se ha programado un comando incompatible con un eje hirth. SOLUCIÓN Revisar programación." .

ns1:AvisoSeguridad_2143 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2143: No se puede calcular la tangente al spline" ;
    ns1:identificador "2143" ;
    ns1:textoExtracto "2143 'No se puede calcular la tangente al spline' DETECCIÓN Durante la ejecución. CAUSA No se puede calcular la tangente para deseleccionar el spline. SOLUCIÓN Deseleccionar el spline en otro punto o programar otra tangente." .

ns1:AvisoSeguridad_2144 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2144: Error en la generación del spline" ;
    ns1:identificador "2144" ;
    ns1:textoExtracto "2144 'Error en la generación del spline' DETECCIÓN Durante la ejecución. CAUSA No se ha programado el primer bloque para activar el spline. SOLUCIÓN Programar un movimiento antes de activar el spline." .

ns1:AvisoSeguridad_2145 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2145: Final del programa sin desactivar splines" ;
    ns1:identificador "2145" ;
    ns1:textoExtracto "2145 'Final del programa sin desactivar splines' DETECCIÓN Durante la ejecución. CAUSA El CNC ha alcanzado el final del programa con el modo spline activo." .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "El CNC ha alcanzado el final del programa con el modo spline activo" ;
    ns1:tieneComponente ns1:ModoOperacion_Spline .

ns1:ModoOperacion_Spline a ns1:ModoOperacion ;
    rdfs:label "Modo spline" ;
    ns1:textoExtracto "modo spline activo" .

