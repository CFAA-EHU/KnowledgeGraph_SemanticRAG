@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_2146 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 2146: Bloques insuficientes para desactivar spline" ;
    ns1:solucionaFallo ns1:Alarma_2146 ;
    ns1:textoExtracto "CAUSA Número insuficiente de bloques para desactivar el spline. SOLUCIÓN No programar el spline para ejecutar un solo bloque." .

ns1:DiagnosticoFallo_2147 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 2147: Spline no permitido en modo HSC" ;
    ns1:solucionaFallo ns1:Alarma_2147 ;
    ns1:textoExtracto "CAUSA No se permite activar el spline con el" .

ns1:DiagnosticoFallo_ModoSplineActivo a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Spline activo al final del programa" ;
    ns1:textoExtracto "CAUSA El CNC ha alcanzado el final del programa con el modo spline activo. SOLUCIÓN Anular el spline antes de finalizar el programa." .

ns1:ModoOperacion_HSC a ns1:ModoOperacion ;
    rdfs:label "Modo de operación HSC" ;
    ns1:textoExtracto "modo HSC" .

ns1:Alarma_2146 a ns1:Alarma ;
    rdfs:label "Alarma 2146: No es posible la desactivación del spline" ;
    ns1:identificador "2146" ;
    ns1:textoExtracto "2146 'No es posible la desactivación del spline' DETECCIÓN Durante la ejecución. CAUSA Número insuficiente de bloques para desactivar el spline. SOLUCIÓN No programar el spline para ejecutar un solo bloque." .

ns1:Alarma_2147 a ns1:Alarma ;
    rdfs:label "Alarma 2147: Programación de splines no permitida en modo HSC" ;
    ns1:identificador "2147" ;
    ns1:textoExtracto "2147 'Programación de splines no permitida en modo HSC' DETECCIÓN Durante la ejecución. CAUSA No se permite activar el spline con el" .

