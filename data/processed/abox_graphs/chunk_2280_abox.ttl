@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_2147 a ns1:Alarma ;
    rdfs:label "Alarma 2147: Programación de splines no permitida en modo HSC" ;
    ns1:identificador "2147" ;
    ns1:solucionaFallo ns1:ModoOperacion_HSC ;
    ns1:textoExtracto "2147 'Programación de splines no permitida en modo HSC' DETECCIÓN Durante la ejecución. CAUSA No se permite activar el spline con el modo HSC activo." .

ns1:Alarma_2148 a ns1:Alarma ;
    rdfs:label "Alarma 2148: Demasiados bloques sin movimiento en modo spline" ;
    ns1:identificador "2148" ;
    ns1:solucionaFallo ns1:ModoOperacion_Spline ;
    ns1:textoExtracto "2148 'Demasiados bloques sin movimiento entre dos bloques en modo spline' DETECCIÓN Durante la ejecución. CAUSA Con el modo spline activo, hay demasiados bloques de no movimiento (asignaciones de parámetros P, variables, etc) entre dos bloques de movimiento." .

ns1:Alarma_2150 a ns1:Alarma ;
    rdfs:label "Alarma 2150: Bloque adicional entre dos polinomios (#TANGCTRL)" ;
    ns1:identificador "2150" ;
    ns1:textoExtracto "2150 #TANGCTRL:Bloque adicional entre dos polinomios." .

ns1:DiagnosticoFallo_2149 a ns1:DiagnosticoFallo ;
    rdfs:label "Solución para error #TANGCTRL" ;
    ns1:solucionaFallo ns1:Alarma_2149 ;
    ns1:textoExtracto "SOLUCIÓN Eliminar el bloque que provoca el error. Póngase en contacto con Fagor Automation." .

ns1:Alarma_2149 a ns1:Alarma ;
    rdfs:label "Alarma 2149: Error interno en control tangencial (#TANGCTRL)" ;
    ns1:identificador "2149" ;
    ns1:solucionaFallo ns1:Sistema_ControlTangencial ;
    ns1:textoExtracto "2149 #TANGCTRL:Error interno en control tangencial. DETECCIÓN Durante la ejecución. CAUSA No es posible realizar el control tangencial." .

ns1:ModoOperacion_HSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC" ;
    ns1:textoExtracto "modo HSC activo" .

ns1:ModoOperacion_Spline a ns1:ModoOperacion ;
    rdfs:label "Modo Spline" ;
    ns1:textoExtracto "modo spline" .

ns1:Sistema_ControlTangencial a ns1:Sistema ;
    rdfs:label "Control Tangencial (#TANGCTRL)" ;
    ns1:textoExtracto "#TANGCTRL:Error interno en control tangencial" .

