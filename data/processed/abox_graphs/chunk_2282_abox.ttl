@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_2154 a ns1:DiagnosticoFallo ;
    rdfs:label "Retardo del palpador mal configurado" ;
    ns1:identificador "2154" ;
    ns1:textoExtracto "2154 Retardo del palpador mal" .

ns1:Herramienta_Mecanizado a ns1:Herramienta ;
    ns1:textoExtracto "trabajar sin desalineamiento de herramienta" .

ns1:Sensor_Palpador a ns1:Sensor ;
    rdfs:label "Palpador" ;
    ns1:monitoreaParametro ns1:Parametro_RetardoPalpador ;
    ns1:textoExtracto "Retardo del palpador mal" .

ns1:TareaMantenimiento_CambiarTrayectoria a ns1:TareaMantenimiento ;
    rdfs:label "Cambiar trayectoria de mecanizado" ;
    ns1:solucionaFallo ns1:Fallo_2153 ;
    ns1:textoExtracto "SOLUCIÓN Cambiar la trayectoria de mecanizado" .

ns1:TareaMantenimiento_CorregirDesalineamiento a ns1:TareaMantenimiento ;
    rdfs:label "Trabajar sin desalineamiento de herramienta" ;
    ns1:solucionaFallo ns1:Fallo_2153 ;
    ns1:textoExtracto "SOLUCIÓN [...] trabajar sin desalineamiento de herramienta" .

ns1:Parametro_RetardoPalpador a ns1:Parametro ;
    rdfs:label "Retardo del palpador" ;
    ns1:textoExtracto "Retardo del palpador mal" .

ns1:Fallo_2153 a ns1:DiagnosticoFallo ;
    rdfs:label "Trayectoria helicoidal cercana al centro de giro del FACE" ;
    ns1:identificador "2153" ;
    ns1:textoExtracto "2153 'Trayectoria helicoidal cercana al centro de giro del FACE' DETECCIÓN Durante la ejecución. CAUSA Se ha programado una trayectoria helicoidal de más de una vuelta, en una zona cercana al centro de giro del FACE. SOLUCIÓN Cambiar la trayectoria de mecanizado." .

