@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CicloCalibracionPalpador a ns1:TareaMantenimiento ;
    rdfs:label "Ciclo de calibración de palpador (#PROBE 2)" ;
    ns1:identificador "#PROBE 2" ;
    ns1:requiereMantenimiento ns1:Parametro_PROBEDELAY ;
    ns1:textoExtracto "ciclo de calibración de palpador (#PROBE 2) para calcular el valor correcto." .

ns1:Fallo_2154 a ns1:DiagnosticoFallo ;
    rdfs:label "Retardo del palpador mal ajustado" ;
    ns1:solucionaFallo ns1:Parametro_PROBEDELAY ;
    ns1:textoExtracto "2154 Retardo del palpador mal ajustado. Parametrizar PROBEDELAY %f." .

ns1:Fallo_2300 a ns1:DiagnosticoFallo ;
    rdfs:label "'Solución de orientación #CSROT no válida ó no encontrada'" ;
    ns1:identificador "2300" ;
    ns1:textoExtracto "'Solución de orientación #CSROT no válida ó no encontrada'" .

ns1:TrayectoriaHelicoidal a ns1:Parametro ;
    rdfs:label "Trayectoria helicoidal" ;
    ns1:documentadoEn ns1:Maquina_FACE ;
    ns1:textoExtracto "Se ha programado una trayectoria helicoidal de más de una vuelta, en una zona cercana al centro de giro del FACE." .

ns1:Funcion_CSROT a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "#CSROT" ;
    ns1:identificador "#CSROT" ;
    ns1:textoExtracto "Desactivar la función #CSROT o cambiar de orientación." .

ns1:Maquina_FACE a ns1:Maquina ;
    rdfs:label "FACE" ;
    ns1:textoExtracto "CAUSA Se ha programado una trayectoria helicoidal de más de una vuelta, en una zona cercana al centro de giro del FACE." ;
    ns1:tieneComponente ns1:SistemaCinematico .

ns1:SistemaCinematico a ns1:Sistema ;
    rdfs:label "Sistema de cinemática de la máquina" ;
    ns1:controla ns1:Funcion_CSROT ;
    ns1:textoExtracto "Los ejes rotativos de la cinemática no se han podido orientar en la posición programada, en el sistema de referencia maquina." .

ns1:Parametro_PROBEDELAY a ns1:Parametro ;
    rdfs:label "PROBEDELAY" ;
    ns1:identificador "PROBEDELAY" ;
    ns1:textoExtracto "El valor calculado de PROBEDELAY no coincide con el valor definido en el parámetro máquina." .

