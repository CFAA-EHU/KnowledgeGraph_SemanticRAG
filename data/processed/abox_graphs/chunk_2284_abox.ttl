@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_2301 a ns1:AvisoSeguridad ;
    rdfs:label "Solución de orientación #CSROT no encontrada según criterio definido en #DEFROT"@es ;
    ns1:identificador "2301" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_2301 ;
    ns1:textoExtracto "2301 'Solución de orientación #CSROT no encontrada según criterio definido en #DEFROT' DETECCIÓN Durante la ejecución. CAUSA Los ejes rotativos de la cinemática no se han podido orientar en la posición programada, en el sistema de referencia maquina, según el criterio seleccionado en #DEFROT."@es .

ns1:AvisoSeguridad_2302 a ns1:AvisoSeguridad ;
    rdfs:label "Solución de orientación #CSROT discontinua respecto lo programado. Rotativo principal / Rotativo secundario"@es ;
    ns1:identificador "2302" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_2302 ;
    ns1:textoExtracto "2302 'Solución de orientación #CSROT discontinua respecto lo programado. Rotativo principal / Rotativo secundario' DETECCIÓN Durante la ejecución. CAUSA La orientación de los ejes rotativos de la cinemática en el sistema de referencia máquina, requiere un movimiento respecto al valor programado, superior al ángulo definido #DEFROT."@es .

ns1:Sistema_Cinematica a ns1:Sistema ;
    rdfs:label "Sistema de cinemática de ejes rotativos"@es ;
    ns1:controla ns1:Parametro_CSROT,
        ns1:Parametro_DEFROT ;
    ns1:textoExtracto "Los ejes rotativos de la cinemática no se han podido orientar en la posición programada, en el sistema de referencia maquina."@es ;
    ns1:tieneComponente ns1:ComponenteMecanico_EjeRotativoPrincipal,
        ns1:ComponenteMecanico_EjeRotativoSecundario .

ns1:ComponenteMecanico_EjeRotativoPrincipal a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo principal"@es ;
    ns1:textoExtracto "Rotativo principal"@es .

ns1:ComponenteMecanico_EjeRotativoSecundario a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo secundario"@es ;
    ns1:textoExtracto "Rotativo secundario"@es .

ns1:DiagnosticoFallo_2301 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de orientación en ejes rotativos según criterio #DEFROT"@es ;
    ns1:solucionaFallo ns1:Parametro_CSROT ;
    ns1:textoExtracto "Los ejes rotativos de la cinemática no se han podido orientar en la posición programada, en el sistema de referencia maquina, según el criterio seleccionado en #DEFROT."@es .

ns1:DiagnosticoFallo_2302 a ns1:DiagnosticoFallo ;
    rdfs:label "Discontinuidad en orientación de ejes rotativos respecto a valor programado"@es ;
    ns1:solucionaFallo ns1:Parametro_DEFROT ;
    ns1:textoExtracto "La orientación de los ejes rotativos de la cinemática en el sistema de referencia máquina, requiere un movimiento respecto al valor programado, superior al ángulo definido #DEFROT."@es .

ns1:Parametro_CSROT a ns1:Parametro ;
    rdfs:label "Función de orientación #CSROT"@es ;
    ns1:identificador "#CSROT" ;
    ns1:textoExtracto "Desactivar la función #CSROT o cambiar de orientación."@es .

ns1:Parametro_DEFROT a ns1:Parametro ;
    rdfs:label "Ángulo de tolerancia de orientación #DEFROT"@es ;
    ns1:identificador "#DEFROT" ;
    ns1:textoExtracto "Aumentar el valor del ángulo definido en #DEFROT."@es ;
    ns1:valor "Ángulo de tolerancia"@es .

