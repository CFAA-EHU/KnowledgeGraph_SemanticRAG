@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_2304 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #PWMOUT"@es ;
    ns1:identificador "2304" ;
    ns1:solucionaFallo ns1:ParametroPWMOUTFrecuenciaCiclo ;
    ns1:textoExtracto "Programar #PWMOUT ON<[FREQ/F valor, DUTY/D valor]>/OFF. [...] CAUSA La sintaxis de la sentencia no es correcta o hay más información en el"@es .

ns1:Funcion_CSROT a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función #CSROT"@es ;
    ns1:identificador "#CSROT" ;
    ns1:requiereMantenimiento ns1:Fallo_2303 ;
    ns1:textoExtracto "La función CSROT solo es aplicable a cinemáticas de dos ejes de tipo cabezal, mesa ó cabezal-mesa"@es .

ns1:SistemaCinematico a ns1:Sistema ;
    rdfs:label "Sistema de cinemática de dos ejes (cabezal/mesa)"@es ;
    ns1:textoExtracto "cinemáticas de dos ejes de tipo cabezal, mesa ó cabezal-mesa"@es ;
    ns1:tieneComponente ns1:EjeDeTipoCabezal,
        ns1:EjeDeTipoMesa .

ns1:EjeDeTipoCabezal a ns1:ComponenteMecanico ;
    rdfs:label "Eje de tipo cabezal"@es ;
    ns1:textoExtracto "cinemática [...] de tipo cabezal"@es .

ns1:EjeDeTipoMesa a ns1:ComponenteMecanico ;
    rdfs:label "Eje de tipo mesa"@es ;
    ns1:textoExtracto "cinemática [...] de tipo mesa"@es .

ns1:Fallo_2303 a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad de cinemática con función #CSROT"@es ;
    ns1:identificador "2303" ;
    ns1:solucionaFallo ns1:ParametroDEFROTAngulo ;
    ns1:textoExtracto "La función CSROT solo es aplicable a cinemáticas de dos ejes de tipo cabezal, mesa ó cabezal-mesa. [...] CAUSA El tipo de cinemática no es compatible con la función #CSROT."@es .

ns1:ParametroDEFROTAngulo a ns1:Parametro ;
    rdfs:label "Parámetro #DEFROT (ángulo)"@es ;
    ns1:identificador "#DEFROT" ;
    ns1:textoExtracto "SOLUCIÓN Aumentar el valor del ángulo definido en #DEFROT."@es .

ns1:ParametroPWMOUTFrecuenciaCiclo a ns1:Parametro ;
    rdfs:label "Parámetro #PWMOUT (frecuencia/ciclo)"@es ;
    ns1:identificador "#PWMOUT" ;
    ns1:textoExtracto "Programar #PWMOUT ON<[FREQ/F valor, DUTY/D valor]>/OFF."@es .

