@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_2304 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en programación #PWMOUT"@es ;
    ns1:identificador "2304" ;
    ns1:solucionaFallo ns1:Parametro_PWMOUT_DUTY,
        ns1:Parametro_PWMOUT_FREQ ;
    ns1:textoExtracto "Programar #PWMOUT ON<[FREQ/F valor, DUTY/D valor]>/OFF. DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta o hay más información en el bloque. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_2305 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro PWM fuera de rango"@es ;
    ns1:identificador "2305" ;
    ns1:solucionaFallo ns1:Parametro_PWMOUT_DUTY,
        ns1:Parametro_PWMOUT_FREQ ;
    ns1:textoExtracto "2305 Parámetro PWM fuera de rango. DETECCIÓN Durante la ejecución. CAUSA Alguno de los comandos de la sentencia #PWMOUT tiene un valor incorrecto. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_2306 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro máquina PWMOUTPUT no configurado"@es ;
    ns1:identificador "2306" ;
    ns1:solucionaFallo ns1:Parametro_PWMOUTPUT ;
    ns1:textoExtracto "2306 El parámetro máquina PWMOUTPUT es 0. DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar el PWM, pero no tiene ninguna salida digital local asignada. SOLUCIÓN Definir en los parámetros máquinas cuál es la salida digital local asociada al PWM (parámetro PWMOUTPUT)."@es .

ns1:Fallo_2307 a ns1:DiagnosticoFallo ;
    rdfs:label "Conflicto de eje Hirth en transformación #VIRTAX"@es ;
    ns1:identificador "2307" ;
    ns1:textoExtracto "'No se puede activar el eje como Hirth, por formar parte de la transformación #VIRTAX'. DETECCIÓN Durante la ejecución."@es .

ns1:Funcion_CSROT a ns1:ModoOperacion ;
    rdfs:label "Función #CSROT"@es ;
    ns1:requiereMantenimiento ns1:Tarea_RevisarProgramacion ;
    ns1:textoExtracto "Desactivar la función #CSROT"@es .

ns1:Actuador_PWM a ns1:Actuador ;
    rdfs:label "Actuador controlado por señal PWM"@es ;
    ns1:textoExtracto "salida digital local asociada al PWM"@es .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC"@es ;
    ns1:textoExtracto "El CNC ha intentado activar el PWM"@es ;
    ns1:tieneComponente ns1:Sistema_PWM .

ns1:Parametro_PWMOUTPUT a ns1:Parametro ;
    rdfs:label "PWMOUTPUT (salida digital local para PWM)"@es ;
    ns1:monitoreaParametro ns1:Maquina_CNC ;
    ns1:textoExtracto "parámetro PWMOUTPUT"@es ;
    ns1:valor "0" .

ns1:Parametro_PWMOUT_DUTY a ns1:Parametro ;
    rdfs:label "DUTY (ciclo de trabajo PWM)"@es ;
    ns1:monitoreaParametro ns1:Sistema_PWM ;
    ns1:textoExtracto "DUTY/D valor"@es .

ns1:Parametro_PWMOUT_FREQ a ns1:Parametro ;
    rdfs:label "FREQ (frecuencia PWM)"@es ;
    ns1:monitoreaParametro ns1:Sistema_PWM ;
    ns1:textoExtracto "FREQ/F valor"@es .

ns1:Sistema_PWM a ns1:Sistema ;
    rdfs:label "Sistema de modulación por ancho de pulsos (PWM)"@es ;
    ns1:controla ns1:Actuador_PWM ;
    ns1:textoExtracto "Programar #PWMOUT ON<[FREQ/F valor, DUTY/D valor]>/OFF"@es .

