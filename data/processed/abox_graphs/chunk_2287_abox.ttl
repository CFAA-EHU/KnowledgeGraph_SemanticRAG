@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_2307_Solucion a ns1:AvisoSeguridad ;
    rdfs:label "Procedimiento para activar eje Hirth con #VIRTAX"@es ;
    ns1:solucionaFallo ns1:Alarma_2307 ;
    ns1:textoExtracto "Desactivar primero la transformación del eje virtual de la herramienta #VIRTAX y a continuación activar el eje como eje Hirth."@es .

ns1:Sistema_VIRTAX a ns1:Sistema ;
    rdfs:label "Sistema de transformación del eje virtual de la herramienta (#VIRTAX)"@es ;
    ns1:activaAlarma ns1:Alarma_2307,
        ns1:Alarma_2308,
        ns1:Alarma_2309 ;
    ns1:identificador "#VIRTAX" ;
    ns1:textoExtracto "transformación del eje virtual de la herramienta, #VIRTAX"@es .

ns1:TareaMantenimiento_RevisarProgramacionVIRTAX a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación tras desactivación de #VIRTAX"@es ;
    ns1:solucionaFallo ns1:Alarma_2308 ;
    ns1:textoExtracto "Revisar la programación."@es .

ns1:AccionProhibida_2307_ActivarEjeHirthConVIRTAX a ns1:AccionProhibida ;
    rdfs:label "Activar eje como Hirth mientras la transformación #VIRTAX está activa"@es ;
    ns1:textoExtracto "El CNC ha intentado activar un eje Hirth cuando formaba parte de la transformación del eje virtual de la herramienta, #VIRTAX."@es .

ns1:Alarma_2309 a ns1:Alarma ;
    rdfs:label "Alarma 2309: Programación no permitida con #VIRTAX activo"@es ;
    ns1:identificador "2309" ;
    ns1:textoExtracto "#VIRTAX: Programación no permitida con el eje virtual de la herramienta activo."@es .

ns1:Alarma_2307 a ns1:Alarma ;
    rdfs:label "Alarma 2307: Activación de eje Hirth con transformación #VIRTAX activa"@es ;
    ns1:identificador "2307" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_2307_ActivarEjeHirthConVIRTAX ;
    ns1:textoExtracto "'No se puede activar el eje como Hirth, por formar parte de la transformación #VIRTAX' [...] SOLUCIÓN Desactivar primero la transformación del eje virtual de la herramienta #VIRTAX y a continuación activar el eje como eje Hirth."@es .

ns1:Alarma_2308 a ns1:Alarma ;
    rdfs:label "Alarma 2308: Desactivación de transformación #VIRTAX"@es ;
    ns1:identificador "2308" ;
    ns1:textoExtracto "Se ha desactivado la transformación del eje virtual de la herramienta, #VIRTAX. [...] CAUSA Ha habido algún cambio en la situación de los ejes que forman parte de la transformación del eje virtual de la herramienta (#VIRTAX)."@es .

