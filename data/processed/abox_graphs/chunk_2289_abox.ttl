@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_2310 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 2310: Eje virtual #VIRTAX no configurado" ;
    ns1:identificador "2310" ;
    ns1:solucionaFallo ns1:Parametro_VIRTAXISNAME ;
    ns1:textoExtracto "2310 #VIRTAX: El eje virtual de la herramienta deben ser lineal y pertenecer al canal. [...] SOLUCIÓN Revisar la configuración. El eje virtual de la herramienta debe estar definido (parámetro VIRTAXISNAME), ser un eje lineal y pertenecer al canal." .

ns1:Fallo_2311 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 2311: Eje virtual #VIRTAX en cinemática principal" ;
    ns1:identificador "2311" ;
    ns1:textoExtracto "2311 #VIRTAX:El eje virtual de la herramienta no puede ser primario ni formar parte de una cinemática. [...] SOLUCIÓN Revisar la programación." .

ns1:Fallo_2313 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 2313: Funciones G no permitidas fuera de perfil PROGTL3" ;
    ns1:identificador "2313" ;
    ns1:textoExtracto "2313 Programación no permitida fuera de un perfil PROGTL3 o MACRO. [...] SOLUCIÓN Programar la función G tras el inicio de un perfil con G841 o G842." .

ns1:Fallo_2314 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 2314: Función no permitida dentro de perfil PROGTL3" ;
    ns1:identificador "2314" ;
    ns1:textoExtracto "2314 Programación no permitida dentro de un perfil PROGTL3. [...] La función programada no está permitida dentro de la definición de un perfil ProGTL3." .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC" ;
    ns1:textoExtracto "CNC" ;
    ns1:tieneComponente ns1:Parametro_NKIN,
        ns1:Parametro_VIRTAXISNAME,
        ns1:Tabla_Cinematicas .

ns1:Fallo_2312 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 2312: Cinemática no definida en tabla NKIN" ;
    ns1:identificador "2312" ;
    ns1:solucionaFallo ns1:Tabla_Cinematicas ;
    ns1:textoExtracto "2312 '#KIN ID[]:Programar valores comprendidos entre 0 y el parámetro máquina NKIN' [...] SOLUCIÓN Revisar programación." .

ns1:Parametro_NKIN a ns1:Parametro ;
    rdfs:label "Parámetro máquina NKIN" ;
    ns1:identificador "NKIN" ;
    ns1:textoExtracto "parámetro máquina NKIN" .

ns1:Parametro_VIRTAXISNAME a ns1:Parametro ;
    rdfs:label "Parámetro VIRTAXISNAME" ;
    ns1:identificador "VIRTAXISNAME" ;
    ns1:textoExtracto "parámetro VIRTAXISNAME" .

ns1:Tabla_Cinematicas a ns1:Tabla ;
    rdfs:label "Tabla de cinemáticas de parámetros máquina" ;
    ns1:documentadoEn ns1:Fallo_2312 ;
    ns1:textoExtracto "tabla de cinemáticas de los parámetros máquina" .

