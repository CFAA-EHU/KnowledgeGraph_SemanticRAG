@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_G_Funciones a ns1:Tabla ;
    rdfs:label "List of G-functions" ;
    ns1:textoExtracto "LIST OF –G- FUNCTIONS." ;
    ns1:tieneComponente ns1:G71,
        ns1:G72,
        ns1:G73,
        ns1:G74,
        ns1:G80,
        ns1:G81_M,
        ns1:G81_T,
        ns1:G82_M,
        ns1:G82_T,
        ns1:G83_M,
        ns1:G83_T,
        ns1:G84_M .

ns1:G71 a ns1:Parametro ;
    rdfs:label "G71" ;
    ns1:identificador "G71" ;
    ns1:textoExtracto "Programming in millimeters." ;
    ns1:valor "millimeters" .

ns1:G72 a ns1:Parametro ;
    rdfs:label "G72" ;
    ns1:identificador "G72" ;
    ns1:textoExtracto "Scaling factor." ;
    ns1:valor "scaling" .

ns1:G73 a ns1:Parametro ;
    rdfs:label "G73" ;
    ns1:identificador "G73" ;
    ns1:textoExtracto "Coordinate system rotation." ;
    ns1:valor "rotation" .

ns1:G74 a ns1:Parametro ;
    rdfs:label "G74" ;
    ns1:identificador "G74" ;
    ns1:textoExtracto "Home search." ;
    ns1:valor "home_search" .

ns1:G80 a ns1:Parametro ;
    rdfs:label "G80 (M model)" ;
    ns1:identificador "G80" ;
    ns1:textoExtracto "(·M· model). Cancel the canned cycle." ;
    ns1:valor "cancel_canned_cycle" .

ns1:G81_M a ns1:Parametro ;
    rdfs:label "G81 (M model)" ;
    ns1:identificador "G81_M" ;
    ns1:textoExtracto "(·M· model). Drilling canned cycle." ;
    ns1:valor "drilling_canned_cycle" .

ns1:G81_T a ns1:Parametro ;
    rdfs:label "G81 (T model)" ;
    ns1:identificador "G81_T" ;
    ns1:textoExtracto "(·T· model). Turning canned cycle with straight sections." ;
    ns1:valor "turning_canned_cycle" .

ns1:G82_M a ns1:Parametro ;
    rdfs:label "G82 (M model)" ;
    ns1:identificador "G82_M" ;
    ns1:textoExtracto "(·M· model). Drilling canned cycle with a variable peck." ;
    ns1:valor "drilling_variable_peck" .

ns1:G82_T a ns1:Parametro ;
    rdfs:label "G82 (T model)" ;
    ns1:identificador "G82_T" ;
    ns1:textoExtracto "(·T· model). Facing canned cycle with straight sections." ;
    ns1:valor "facing_canned_cycle" .

ns1:G83_M a ns1:Parametro ;
    rdfs:label "G83 (M model)" ;
    ns1:identificador "G83_M" ;
    ns1:textoExtracto "(·M· model). Deep-hole drilling canned cycle with constant peck." ;
    ns1:valor "deep_hole_constant_peck" .

ns1:G83_T a ns1:Parametro ;
    rdfs:label "G83 (T model)" ;
    ns1:identificador "G83_T" ;
    ns1:textoExtracto "(·T· model). Drilling / tapping canned cycle." ;
    ns1:valor "drilling_tapping_cycle" .

ns1:G84_M a ns1:Parametro ;
    rdfs:label "G84 (M model)" ;
    ns1:identificador "G84_M" ;
    ns1:textoExtracto "(·M· model). Tapping canned cycle." ;
    ns1:valor "tapping_canned_cycle" .

