@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibidaProgramacionEnPerfil a ns1:AccionProhibida ;
    ns1:textoExtracto "Programación no permitida dentro de un perfil PROGTL3." .

ns1:ErrorProcesoResolucionPerfil a ns1:DiagnosticoFallo ;
    ns1:identificador "2315" ;
    ns1:textoExtracto "'Error en el proceso de resolución del perfil PROGTL3'" ;
    ns1:valor "Error en el proceso de resolución del perfil PROGTL3" .

ns1:PerfilProGTL3Incorrecto a ns1:DiagnosticoFallo ;
    ns1:textoExtracto "El perfil ProGTL3 programado es incorrecto o no tiene solución." ;
    ns1:valor "Perfil ProGTL3 incorrecto o sin solución" .

ns1:ProgTL3 a ns1:ModoOperacion ;
    ns1:identificador "PROGTL3" ;
    ns1:textoExtracto "Programación no permitida dentro de un perfil PROGTL3." .

ns1:SolucionProgramarFuncionG a ns1:TareaMantenimiento ;
    rdfs:label "Programar función G tras inicio de perfil con G841 o G842" ;
    ns1:textoExtracto "Programar la función G tras el inicio de un perfil con G841 o G842." .

