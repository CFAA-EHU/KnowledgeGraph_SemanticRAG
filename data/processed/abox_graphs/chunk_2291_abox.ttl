@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_2315 a ns1:AvisoSeguridad ;
    rdfs:label "Error en el proceso de resolución del perfil PROGTL3" ;
    ns1:identificador "2315" ;
    ns1:textoExtracto "2315 'Error en el proceso de resolución del perfil PROGTL3' DETECCIÓN Durante la ejecución. CAUSA El perfil ProGTL3 programado es incorrecto o no tiene solución. SOLUCIÓN Revisar la programación." .

ns1:AvisoSeguridad_2316 a ns1:AvisoSeguridad ;
    rdfs:label "Finalizado perfil PROGTL3 no resuelto" ;
    ns1:identificador "2316" ;
    ns1:textoExtracto "2316 'Finalizado perfil PROGTL3 no resuelto' DETECCIÓN Durante la ejecución. CAUSA El perfil ProGTL3 programado finaliza sin resolverse por completo. SOLUCIÓN Revisar la programación." .

ns1:AvisoSeguridad_2317 a ns1:AvisoSeguridad ;
    rdfs:label "No se admiten más puntos en la función G809-G820" ;
    ns1:identificador "2317" ;
    ns1:textoExtracto "2317 'No se admiten más puntos en la función G809-G820' DETECCIÓN Durante la ejecución. CAUSA En las función G809 o G820 hay programados más puntos de los permitidos. SOLUCIÓN Revisar la programación." .

ns1:AvisoSeguridad_2318 a ns1:AvisoSeguridad ;
    rdfs:label "Ente geométrico no definido" ;
    ns1:identificador "2318" ;
    ns1:textoExtracto "2318 'Ente geométrico no definido' DETECCIÓN Durante la ejecución. CAUSA El ente programado no está definido o inicializado. SOLUCIÓN Antes de utilizar un ente, éste debe estar previamente definido." .

ns1:AvisoSeguridad_2319 a ns1:AvisoSeguridad ;
    rdfs:label "No se admiten más elementos en la definición del ente geométrico" ;
    ns1:identificador "2319" ;
    ns1:textoExtracto "2319 'No se admiten más elementos en la definición del ente geométrico' DETECCIÓN Durante la ejecución. CAUSA Se ha sobrepasado el número máximo de elementos que se admiten para definir un ente geométrico. SOLUCIÓN Modificar el ente o utilizar varios." .

ns1:AvisoSeguridad_2320 a ns1:AvisoSeguridad ;
    rdfs:label "El elemento no es tangente" ;
    ns1:identificador "2320" ;
    ns1:textoExtracto "2320 'El elemento no es tangente' DETECCIÓN Durante la ejecución. CAUSA El elemento indicado no es tangente al anterior. SOLUCIÓN Revisar la programación." .

ns1:AvisoSeguridad_2321 a ns1:AvisoSeguridad ;
    rdfs:label "La tangencia no es posible" ;
    ns1:identificador "2321" ;
    ns1:textoExtracto "2321 'La tangencia no es posible' DETECCIÓN Durante la ejecución. CAUSA El elemento programado no puede ser tangente al anterior. SOLUCIÓN Revisar la programación." .

ns1:AvisoSeguridad_2322 a ns1:AvisoSeguridad ;
    rdfs:label "El elemento no es válido" ;
    ns1:identificador "2322" ;
    ns1:textoExtracto "2322 'El elemento no es válido' DETECCIÓN Durante la ejecución. CAUSA El elemento indicado está mal programado. SOLUCIÓN Revisar la programación." .

ns1:AvisoSeguridad_2323 a ns1:AvisoSeguridad ;
    rdfs:label "El arco no es posible" ;
    ns1:identificador "2323" ;
    ns1:textoExtracto "2323 'El arco no es posible' DETECCIÓN Durante la ejecución. CAUSA El arco programado no es posible con los datos dados. SOLUCIÓN Revisar la programación." .

ns1:AvisoSeguridad_2324 a ns1:AvisoSeguridad ;
    rdfs:label "El punto inicial no pertenece al círculo" ;
    ns1:identificador "2324" ;
    ns1:textoExtracto "2324 'El punto inicial no pertenece al círculo' DETECCIÓN Durante la ejecución." .

