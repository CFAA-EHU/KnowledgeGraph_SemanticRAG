@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_2323 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 2323: 'El arco no es posible'"@es ;
    ns1:identificador "2323" ;
    ns1:mitigaRiesgo ns1:FalloDeProgramacionArcoNoPosible ;
    ns1:textoExtracto "'El arco no es posible' DETECCIÓN Durante la ejecución. CAUSA El arco programado no es posible con los datos dados. SOLUCIÓN Revisar la programación."@es .

ns1:AvisoSeguridad_2324 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 2324: 'El punto inicial no pertenece al círculo'"@es ;
    ns1:identificador "2324" ;
    ns1:mitigaRiesgo ns1:FalloDeProgramacionPuntoInicialFueraDelCirculo ;
    ns1:textoExtracto "'El punto inicial no pertenece al círculo' DETECCIÓN Durante la ejecución. CAUSA El punto inicial no pertenece al círculo. SOLUCIÓN Revisar la programación."@es .

ns1:AvisoSeguridad_2325 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 2325: 'El punto final no pertenece al círculo'"@es ;
    ns1:identificador "2325" ;
    ns1:mitigaRiesgo ns1:FalloDeProgramacionPuntoFinalFueraDelCirculo ;
    ns1:textoExtracto "'El punto final no pertenece al círculo' DETECCIÓN Durante la ejecución. CAUSA El punto final no pertenece al círculo. SOLUCIÓN Revisar la programación."@es .

ns1:FalloDeProgramacionArcoNoPosible a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de programación: arco no posible"@es ;
    ns1:solucionaFallo ns1:RevisarProgramacion ;
    ns1:textoExtracto "El arco programado no es posible con los datos dados."@es .

ns1:FalloDeProgramacionPuntoFinalFueraDelCirculo a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de programación: punto final fuera del círculo"@es ;
    ns1:solucionaFallo ns1:RevisarProgramacion ;
    ns1:textoExtracto "El punto final no pertenece al círculo."@es .

ns1:FalloDeProgramacionPuntoInicialFueraDelCirculo a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de programación: punto inicial fuera del círculo"@es ;
    ns1:solucionaFallo ns1:RevisarProgramacion ;
    ns1:textoExtracto "El punto inicial no pertenece al círculo."@es .

ns1:RevisarProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar programación"@es ;
    ns1:textoExtracto "Revisar la programación."@es .

