ns1:Fallo_2333 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 2333: 'Programación no permitida fuera de una macro G8736'"@es ;
    ns1:identificador "2333" ;
    ns1:solucionaFallo ns1:RevisarLaProgramacionYUbicarG8737G8738TrasMacroG8736 ;
    ns1:textoExtracto "2333 'Programación no permitida fuera de una macro G8736' DETECCIÓN Durante la ejecución. CAUSA Hay alguna función G8737 o G8738 programada fuera de una macro G8736. SOLUCIÓN Revisar la programación. Las funciones G8737 o G8738 se deben programar a continuación de la macro G8736."@es .

ns1:RevisarLaProgramacionYProgramarElElementoAnterior a ns1:TareaMantenimiento ;
    rdfs:label "Revisar la programación y programar el elemento anterior"@es ;
    ns1:textoExtracto "Revisar la programación. Programar el elemento anterior."@es .

ns1:RevisarLaProgramacionYUbicarG8737G8738TrasMacroG8736 a ns1:TareaMantenimiento ;
