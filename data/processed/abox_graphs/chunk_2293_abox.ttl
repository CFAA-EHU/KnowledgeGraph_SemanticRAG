@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_2325 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 2325: 'El punto final no pertenece al círculo'"@es ;
    ns1:identificador "2325" ;
    ns1:solucionaFallo ns1:RevisarLaProgramacion ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. 2325 'El punto final no pertenece al círculo' DETECCIÓN Durante la ejecución. CAUSA El punto final no pertenece al círculo. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_2326 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 2326: 'Falta punto final en G802/G803'"@es ;
