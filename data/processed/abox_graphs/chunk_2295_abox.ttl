@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_2335 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 2335: Programación no permitida fuera de una macro G8725" ;
    ns1:identificador "2335" ;
    ns1:textoExtracto "2335 'Programación no permitida fuera de una macro G8725' DETECCIÓN Durante la ejecución. CAUSA Hay alguna función G8734 programada fuera de una macro G8735. SOLUCIÓN Revisar la programación. La función G8734 se debe programar a continuación de la macro G8735." .

ns1:AvisoSeguridad_2336 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 2336: Programación no permitida fuera de una macro G8725" ;
    ns1:identificador "2336" ;
    ns1:textoExtracto "2336 'Programación no permitida fuera de una macro G8725' DETECCIÓN Durante la ejecución. CAUSA Hay alguna función G8724 programada fuera de una macro G8725. SOLUCIÓN Revisar la programación. La función G8724 se debe programar a continuación de la macro G8725." .

ns1:AvisoSeguridad_2337 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 2337: Programación no permitida fuera de una macro G8726" ;
    ns1:identificador "2337" ;
    ns1:textoExtracto "2337 'Programación no permitida fuera de una macro G8726' DETECCIÓN Durante la ejecución. CAUSA Hay alguna función G8727 o G8728 programada fuera de una macro G8726. SOLUCIÓN Revisar la programación. Las funciones G8727 o G8728 se deben programar a continuación de la macro G8726." .

ns1:AvisoSeguridad_2338 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 2338: Programación PROGTL3 no permitida en perfil ISO" ;
    ns1:identificador "2338" ;
    ns1:textoExtracto "2338 'Programación PROGTL3 no permitida en un perfil ISO' DETECCIÓN Durante la ejecución. CAUSA El perfil de la macro está escrito en dos lenguajes, ProGTL3 e ISO. SOLUCIÓN Los perfiles de las macros se pueden definir en lenguaje ProGTL3 o ISO, pero no se permite mezclar ambos en un mismo perfil. Programar el perfil para la macro en un único lenguaje ProGTL3 o ISO." .

ns1:AvisoSeguridad_2339 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 2339: Incompatibilidad entre compensación de radio y 3D" ;
    ns1:identificador "2339" ;
    ns1:mitigaRiesgo ns1:Parametro_COMP3D,
        ns1:Parametro_G41,
        ns1:Parametro_G42 ;
    ns1:textoExtracto "2339 'No es compatible la compensación de radio activa y la 3D' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar la compensación de radio (G41/G42) mientras la compensación de herramienta 3D (#COMP3D ON) está activa, o viceversa. SOLUCIÓN Revisar la programación. Ambos tipos de compensación son incompatibles." .

ns1:Parametro_COMP3D a ns1:Parametro ;
    rdfs:label "Parámetro #COMP3D: Compensación de herramienta 3D" ;
    ns1:identificador "#COMP3D" ;
    ns1:textoExtracto "compensación de herramienta 3D (#COMP3D ON)" .

ns1:Parametro_G41 a ns1:Parametro ;
    rdfs:label "Parámetro G41: Compensación de radio (izquierda)" ;
    ns1:identificador "G41" ;
    ns1:textoExtracto "compensación de radio (G41/G42)" .

ns1:Parametro_G42 a ns1:Parametro ;
    rdfs:label "Parámetro G42: Compensación de radio (derecha)" ;
    ns1:identificador "G42" ;
    ns1:textoExtracto "compensación de radio (G41/G42)" .

