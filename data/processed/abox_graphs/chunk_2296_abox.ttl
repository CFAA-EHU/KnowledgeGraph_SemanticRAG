@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CompensacionHerramienta3D a ns1:Parametro ;
    rdfs:label "Compensación de herramienta 3D (#COMP3D ON)" ;
    ns1:identificador "#COMP3D ON" ;
    ns1:textoExtracto "compensación de herramienta 3D (#COMP3D ON)" .

ns1:CompensacionRadio a ns1:Parametro ;
    rdfs:label "Compensación de radio (G41/G42)" ;
    ns1:identificador "G41/G42" ;
    ns1:textoExtracto "compensación de radio (G41/G42)" .

ns1:Error2341 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2341: Programación de vector incorrecta" ;
    ns1:identificador "2341" ;
    ns1:textoExtracto "2341 'Programación de vector incorrecta' DETECCIÓN Durante la ejecución." .

ns1:ProgramacionCNC a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación CNC" ;
    ns1:requiereMantenimiento ns1:IncompatibilidadCompensaciones ;
    ns1:textoExtracto "Revisar la programación." .

ns1:Error2340 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2340: Vector doblemente definido" ;
    ns1:identificador "2340" ;
    ns1:textoExtracto "2340 'Vector doblemente definido' [...] SOLUCIÓN Revisar la programación. Programar un único vector por bloque." .

ns1:IncompatibilidadCompensaciones a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad entre compensación de radio y compensación 3D" ;
    ns1:solucionaFallo ns1:Error2340 ;
    ns1:textoExtracto "El CNC ha intentado activar la compensación de radio (G41/G42) mientras la compensación de herramienta 3D (#COMP3D ON) está activa, o viceversa. SOLUCIÓN Revisar la programación. Ambos tipos de compensación son incompatibles." .

