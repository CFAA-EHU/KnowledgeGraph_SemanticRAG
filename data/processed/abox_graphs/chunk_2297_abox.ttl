@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Alarma_2341 a ns1:Alarma ;
    rdfs:label "Alarma 2341: Programación de vector incorrecta" ;
    ns1:identificador "2341" ;
    ns1:textoExtracto "2341 'Programación de vector incorrecta' [...] SOLUCIÓN Revisar la programación. Programar un único vector por bloque." .

ns1:Alarma_2342 a ns1:Alarma ;
    rdfs:label "Alarma 2342: Vector N[-,-,-] no programado para compensación 3D" ;
    ns1:identificador "2342" ;
    ns1:textoExtracto "2342 'Es necesario programar el vector N[-,-,-] para la compensación 3D' [...] SOLUCIÓN Revisar la programación. Con la compensación de herramienta 3D activa, es obligatorio programar un vector en cada bloque de movimiento." .

ns1:Alarma_2343 a ns1:Alarma ;
    rdfs:label "Alarma 2343: Herramienta activa no adecuada para compensación 3D" ;
    ns1:identificador "2343" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_Compensacion3D_Normal ;
    ns1:textoExtracto "2343 'Herramienta activa no adecuada para compensación 3D' [...] SOLUCIÓN La compensación de herramienta 3D en modo \"NORMAL\" sólo admite herramientas de fresado planas, tóricas o esféricas." .

ns1:Alarma_2344 a ns1:Alarma ;
    rdfs:label "Alarma 2344: Sintaxis incorrecta en #COMP3D" ;
    ns1:identificador "2344" ;
    ns1:textoExtracto "2344 'Programar #COMP3D ON/OFF [PARAX/NORMAL]' [...] SOLUCIÓN Revisar la programación." .

ns1:Alarma_2345 a ns1:Alarma ;
    rdfs:label "Alarma 2345: Perfil doblemente definido" ;
    ns1:identificador "2345" ;
    ns1:textoExtracto "2345 'Perfil doblemente definido' [...] SOLUCIÓN Revisar la programación. Definir un único perfil." .

ns1:Alarma_2346 a ns1:Alarma ;
    rdfs:label "Alarma 2346: Máximo de bloques para visualización 2D superado" ;
    ns1:identificador "2346" ;
    ns1:textoExtracto "2346 'Superado el máximo de bloques para la visualización 2D' [...] SOLUCIÓN Modificar el programa o visualizarlo por partes." ;
    ns1:valor 500 .

ns1:Alarma_2347 a ns1:Alarma ;
    rdfs:label "Alarma 2347: Perfil PROGTL3 incompatible con G91 activa" ;
    ns1:identificador "2347" ;
    ns1:textoExtracto "2347 'No se admite perfil PROGTL3 con G91 activa' [...] DETECCIÓN Durante la ejecución." .

ns1:Herramienta_Esferica a ns1:Herramienta ;
    rdfs:label "Herramienta esférica para compensación 3D" ;
    ns1:textoExtracto "herramientas [...] esféricas" .

ns1:Herramienta_FresadoPlana a ns1:Herramienta ;
    rdfs:label "Herramienta de fresado plana para compensación 3D" ;
    ns1:textoExtracto "herramientas de fresado planas" .

ns1:Herramienta_Torica a ns1:Herramienta ;
    rdfs:label "Herramienta tórica para compensación 3D" ;
    ns1:textoExtracto "herramientas [...] tóricas" .

ns1:ModoOperacion_Compensacion3D_Normal a ns1:ModoOperacion ;
    rdfs:label "Modo NORMAL para compensación de herramienta 3D" ;
    ns1:habilitadoPor ns1:Herramienta_Esferica,
        ns1:Herramienta_FresadoPlana,
        ns1:Herramienta_Torica ;
    ns1:textoExtracto "La compensación de herramienta 3D en modo \"NORMAL\" sólo admite herramientas de fresado planas, tóricas o esféricas." .

