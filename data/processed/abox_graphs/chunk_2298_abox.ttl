@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_2347 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2347: 'No se admite perfil PROGTL3 con G91 activa'"@es ;
    ns1:solucionaFallo ns1:Fallo_2347_G91_Activa ;
    ns1:textoExtracto "2347 'No se admite perfil PROGTL3 con G91 activa' DETECCIÓN Durante la ejecución. CAUSA No se permite iniciar un perfil con G91 activa, ni programar G91 dentro de un perfil G841-G842."@es .

ns1:Parametro_G90 a ns1:Parametro ;
    rdfs:label "Código G90 (programación absoluta)"@es ;
    ns1:identificador "G90" ;
    ns1:textoExtracto "Programar G90 antes del inicio del perfil."@es .

ns1:Parametro_G91 a ns1:Parametro ;
    rdfs:label "Código G91 (programación incremental)"@es ;
    ns1:identificador "G91" ;
    ns1:textoExtracto "No se admite perfil PROGTL3 con G91 activa"@es .

ns1:Perfil_G841_G842 a ns1:ModoOperacion ;
    rdfs:label "Perfiles G841-G842"@es ;
    ns1:identificador "G841-G842" ;
    ns1:textoExtracto "ni programar G91 dentro de un perfil G841-G842"@es .

ns1:Perfil_PROGTL3 a ns1:ModoOperacion ;
    rdfs:label "Perfil PROGTL3"@es ;
    ns1:identificador "PROGTL3" ;
    ns1:textoExtracto "No se admite perfil PROGTL3 con G91 activa"@es .

ns1:Solucion_2347_G90 a ns1:TareaMantenimiento ;
    rdfs:label "Programar G90 antes del inicio del perfil"@es ;
    ns1:solucionaFallo ns1:Fallo_2347_G91_Activa ;
    ns1:textoExtracto "SOLUCIÓN Programar G90 antes del inicio del perfil. Si se desea programar cotas incrementales dentro de los perfiles utilizar la programación específica para ello."@es .

ns1:Fallo_2347_G91_Activa a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad entre perfil PROGTL3 y código G91"@es ;
    ns1:textoExtracto "No se permite iniciar un perfil con G91 activa, ni programar G91 dentro de un perfil G841-G842."@es .

