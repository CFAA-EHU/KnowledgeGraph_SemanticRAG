@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Diagnostico_TIPO_LSFIT a ns1:DiagnosticoFallo ;
    rdfs:label "Error en parámetro TIPO de #LSFIT" ;
    ns1:monitoreaParametro ns1:Parametro_TIPO_LSFIT ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El parámetro TIPO de la sentencia #LSFIT no es válido. SOLUCIÓN Revisar la programación." .

ns1:Error_2355 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en proceso #LSFIT" ;
    ns1:identificador "2355" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Error interno genérico del proceso #LSFIT. SOLUCIÓN Revisar la programación." .

ns1:Error_2356 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en #SELECT ORI" ;
    ns1:identificador "2356" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:Parametro_TIPO_LSFIT a ns1:Parametro ;
    rdfs:label "Parámetro TIPO de la sentencia #LSFIT" ;
    ns1:identificador "TIPO" ;
    ns1:textoExtracto "El parámetro TIPO de la sentencia #LSFIT no es válido." .

