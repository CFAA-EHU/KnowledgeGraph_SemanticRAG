@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_2362 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje de rotación no programado en DGWZ CYL" ;
    ns1:identificador "2362" ;
    ns1:textoExtracto "Eliminar el eje de rotación de la programación de DGWZ o DGWZ RECT. 2362 #DGWZ CYL: Eje de rotación no programado. DETECCIÓN Durante la ejecución. CAUSA En DGWZ CYL es obligatorio programar un eje de rotación y no se ha programado. SOLUCIÓN Programar eje de rotación para DGWZ CYL." .

ns1:Fallo_2363 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación incorrecta del punto final del arco (G8/G9)" ;
    ns1:identificador "2363" ;
    ns1:textoExtracto "2363 G8/G9: Programación incorrecta del punto final del arco. DETECCIÓN Durante la ejecución. CAUSA En las funciones G8 y G9 es obligatoria la programación del punto final del arco. SOLUCIÓN Programar el punto final del arco." .

ns1:Fallo_2364 a ns1:DiagnosticoFallo ;
    rdfs:label "Punto final de movimiento inexistente" ;
    ns1:identificador "2364" ;
    ns1:textoExtracto "2364 Punto final de movimiento inexistente. DETECCIÓN Durante la ejecución. CAUSA La cota programada" .

