@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TareaMantenimiento_CalibracionCinematicas a ns1:TareaMantenimiento ;
    rdfs:label "Calibración de cinemáticas" ;
    ns1:solucionaFallo ns1:Error_2376_LSFIT ;
    ns1:textoExtracto "CAUSA Calibración de cinemáticas. El ciclo no puede finalizar el ajuste con las palpaciones realizadas o los datos de entrada." .

ns1:Error_2376_LSFIT a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2376 #LSFIT (SVBK)" ;
    ns1:identificador "2376 #LSFIT" ;
    ns1:textoExtracto "2376 #LSFIT, error de cálculo (SVBK), compruebe los datos de entrada." .

