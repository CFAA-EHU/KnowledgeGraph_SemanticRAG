@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_2377 a ns1:Alarma ;
    rdfs:label "#LSFIT - Instrucción no válida" ;
    ns1:identificador "2377" ;
    ns1:monitoreaParametro ns1:Parametro_LSFIT ;
    ns1:textoExtracto "#LSFIT, la instrucción no es válida. DETECCIÓN Durante la ejecución. CAUSA La sentencia #LSFIT no se ha programado correctamente. SOLUCIÓN Revisar la programación." .

ns1:Alarma_2378 a ns1:Alarma ;
    rdfs:label "#GAPCTRL - Eje o GAP no programado" ;
    ns1:identificador "2378" ;
    ns1:monitoreaParametro ns1:Parametro_GAPCTRL_Eje,
        ns1:Parametro_GAPCTRL_GAP ;
    ns1:textoExtracto "#GAPCTRL: Falta programar el eje o el GAP. DETECCIÓN Durante la ejecución. CAUSA En el comando #GAPCTRL no se ha programado el eje o la distancia (gap). SOLUCIÓN Programar el eje y/o el GAP." .

ns1:Alarma_2379 a ns1:Alarma ;
    rdfs:label "#GAPCTRL - Parámetro GAPANAINID no asignado" ;
    ns1:identificador "2379" ;
    ns1:monitoreaParametro ns1:Parametro_GAPANAINID ;
    ns1:textoExtracto "#GAPCTRL: Parámetro máquina GAPANAINID nulo o sin asignar. DETECCIÓN Durante la ejecución. CAUSA No se ha definido la entrada analógica a la que está asociado el sensor del gap (parámetro GAPANAINID)." .

ns1:Alarma_CalibracionCinematica a ns1:Alarma ;
    rdfs:label "Alarma de calibración de cinemáticas" ;
    ns1:monitoreaParametro ns1:Parametro_DatosEntrada,
        ns1:Parametro_Palpaciones ;
    ns1:textoExtracto "El ciclo no puede finalizar el ajuste con las palpaciones realizadas o los datos de entrada. SOLUCIÓN Corregir los datos de entrada o el número y/o posiciones de palpación." .

ns1:Sensor_GAP a ns1:Sensor ;
    rdfs:label "Sensor de GAP" ;
    ns1:monitoreaParametro ns1:Parametro_GAPANAINID ;
    ns1:textoExtracto "entrada analógica a la que está asociado el sensor del gap (parámetro GAPANAINID)." .

ns1:Parametro_DatosEntrada a ns1:Parametro ;
    rdfs:label "Datos de entrada (calibración)" ;
    ns1:textoExtracto "Corregir los datos de entrada o el número y/o posiciones de palpación." .

ns1:Parametro_GAPCTRL_Eje a ns1:Parametro ;
    rdfs:label "Parámetro Eje en #GAPCTRL" ;
    ns1:textoExtracto "Falta programar el eje o el GAP." .

ns1:Parametro_GAPCTRL_GAP a ns1:Parametro ;
    rdfs:label "Parámetro GAP en #GAPCTRL" ;
    ns1:textoExtracto "Falta programar el eje o el GAP." .

ns1:Parametro_LSFIT a ns1:Parametro ;
    rdfs:label "Parámetro #LSFIT" ;
    ns1:textoExtracto "La sentencia #LSFIT no se ha programado correctamente." .

ns1:Parametro_Palpaciones a ns1:Parametro ;
    rdfs:label "Parámetro de palpaciones" ;
    ns1:textoExtracto "Corregir los datos de entrada o el número y/o posiciones de palpación." .

ns1:Parametro_GAPANAINID a ns1:Parametro ;
    rdfs:label "Parámetro GAPANAINID" ;
    ns1:textoExtracto "Parámetro máquina GAPANAINID nulo o sin asignar. No se ha definido la entrada analógica a la que está asociado el sensor del gap." .

