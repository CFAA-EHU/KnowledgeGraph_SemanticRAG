@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Diagnostico_SensorGap a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en asignación de entrada analógica para sensor del gap" ;
    ns1:solucionaFallo ns1:Parametro_GAPANAINID ;
    ns1:textoExtracto "CAUSA No se ha definido la entrada analógica a la que está asociado el sensor del gap (parámetro GAPANAINID). SOLUCIÓN Asignar el valor correcto al parámetro máquina GAPANAINID." .

ns1:Error_2380 a ns1:DiagnosticoFallo ;
    rdfs:label "Error #LSFIT (2380)" ;
    ns1:solucionaFallo ns1:DatosDeEntradaONumeroPosicionesDePalpacion ;
    ns1:textoExtracto "2380 #LSFIT, error interno. DETECCIÓN Durante la ejecución. CAUSA Calibración de cinemáticas. Datos incoherentes en el ciclo. SOLUCIÓN Corregir los datos de entrada o el número y/o posiciones de palpación." .

ns1:Error_2381 a ns1:DiagnosticoFallo ;
    rdfs:label "Error #ABORT OFF no programado (2381)" ;
    ns1:identificador "2381" ;
    ns1:solucionaFallo ns1:ComandoABORTOFF ;
    ns1:textoExtracto "2381 #ABORT OFF no programado en la misma subrutina que #ABORT. DETECCIÓN Durante la ejecución. CAUSA No se ha programado el comando #ABORT OFF. Si se programa el comando #ABORT solo en el bloque, al abortar el programa la ejecución continúa en el comando #ABORT OFF. SOLUCIÓN Programar #ABORT OFF." .

ns1:Error_2382 a ns1:DiagnosticoFallo ;
    rdfs:label "Error #ISO ON[] (2382)" ;
    ns1:identificador "2382" ;
    ns1:textoExtracto "2382 #ISO ON[]. Sintaxis incorrecta. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:ComandoABORTOFF a ns1:Parametro ;
    rdfs:label "Comando #ABORT OFF" ;
    ns1:textoExtracto "Programar #ABORT OFF." .

ns1:DatosDeEntradaONumeroPosicionesDePalpacion a ns1:Parametro ;
    rdfs:label "Datos de entrada o número/posiciones de palpación" ;
    ns1:textoExtracto "Corregir los datos de entrada o el número y/o posiciones de palpación." .

ns1:Parametro_GAPANAINID a ns1:Parametro ;
    rdfs:label "GAPANAINID" ;
    ns1:monitoreaParametro ns1:SensorDelGap ;
    ns1:textoExtracto "parámetro máquina GAPANAINID. SOLUCIÓN Asignar el valor correcto al parámetro máquina GAPANAINID." .

ns1:SensorDelGap a ns1:Sensor ;
    rdfs:label "Sensor del gap" ;
    ns1:textoExtracto "sensor del gap (parámetro GAPANAINID)." .

