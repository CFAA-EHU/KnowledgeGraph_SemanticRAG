@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_2384 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2384: Conflicto de movimiento con ciclo modal y subrutina"@es ;
    ns1:documentadoEn ns1:Manual_Programacion ;
    ns1:identificador "2384" ;
    ns1:textoExtracto "2384 Movimiento con ciclo modal activo y llamada a subrutina en el mismo bloque. DETECCIÓN Durante la ejecución. CAUSA Hay programada una llamada a subrutina y un"@es .

ns1:DiagnosticoFallo_SintaxisIncorrecta a ns1:DiagnosticoFallo ;
    rdfs:label "Sintaxis incorrecta"@es ;
    ns1:solucionaFallo ns1:AvisoSeguridad_2383 ;
    ns1:textoExtracto "Sintaxis incorrecta. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:AvisoSeguridad_2383 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2383: Nombre de fichero no válido"@es ;
    ns1:documentadoEn ns1:Manual_Programacion ;
    ns1:identificador "2383" ;
    ns1:textoExtracto "2383 #ISO ON[]. Nombre de fichero no valido. DETECCIÓN Durante la ejecución. CAUSA La carpeta destino no existe o el nombre del fichero es incorrecto. SOLUCIÓN Seleccionar una carpeta que exista y un nombre de fichero correcto."@es .

ns1:Manual_Programacion a ns1:Manual ;
    rdfs:label "Manual de programación"@es ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia."@es .

