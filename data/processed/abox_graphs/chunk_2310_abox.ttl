@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_2384 a ns1:Alarma ;
    rdfs:label "Alarma 2384: Movimiento con ciclo modal activo y llamada a subrutina en el mismo bloque"@es ;
    ns1:identificador "2384" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_ProgramarCicloFijoDentroDeOtroCicloFijo ;
    ns1:textoExtracto "2384 Movimiento con ciclo modal activo y llamada a subrutina en el mismo bloque. DETECCIÓN Durante la ejecución. CAUSA Hay programada una llamada a subrutina y un ciclo modal en el mismo bloque, o se ha intentado ejecutar un ciclo fijo dentro durante la ejecución de otro ciclo fijo. SOLUCIÓN Revisar programación. Anular el ciclo modal o programar la llamada a subrutina en un bloque posterior. No es posible ejecutar un ciclo fijo dentro de otro ciclo fijo."@es .

ns1:Alarma_2385 a ns1:Alarma ;
    rdfs:label "Alarma 2385: Zona de trabajo no programada"@es ;
    ns1:identificador "2385" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_OmitirParametroZonaEnG120_G123 ;
    ns1:textoExtracto "2385 Zona de trabajo no programada. DETECCIÓN Durante la preparación de bloques. CAUSA No se ha programado el número de zona en G120/G121/G122/G123. SOLUCIÓN Programar el número de zona en el parámetro \"K\"; de 1 a 5."@es .

ns1:Alarma_2386 a ns1:Alarma ;
    rdfs:label "Alarma 2386: Zona de trabajo inexistente"@es ;
    ns1:identificador "2386" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_UsarValorZonaInvalidoEnG120_G123 ;
    ns1:textoExtracto "2386 Zona de trabajo inexistente. DETECCIÓN Durante la preparación de bloques. CAUSA El número de zona programado en G120/G121/G122/G123 no tiene un valor correcto."@es .

ns1:Sistema_ComandosG120_G123 a ns1:Sistema ;
    rdfs:label "Sistema de comandos G120-G123 (gestión de zonas de trabajo)"@es ;
    ns1:identificador "G120/G121/G122/G123" ;
    ns1:textoExtracto "Zona de trabajo programada en G120/G121/G122/G123."@es ;
    ns1:tieneComponente ns1:Parametro_K_ZonaTrabajo .

ns1:AccionProhibida_OmitirParametroZonaEnG120_G123 a ns1:AccionProhibida ;
    rdfs:label "Omitir el parámetro de zona (K) en comandos G120-G123"@es ;
    ns1:textoExtracto "No se ha programado el número de zona en G120/G121/G122/G123."@es .

ns1:AccionProhibida_ProgramarCicloFijoDentroDeOtroCicloFijo a ns1:AccionProhibida ;
    rdfs:label "Programar un ciclo fijo dentro de otro ciclo fijo"@es ;
    ns1:textoExtracto "No es posible ejecutar un ciclo fijo dentro de otro ciclo fijo."@es .

ns1:AccionProhibida_UsarValorZonaInvalidoEnG120_G123 a ns1:AccionProhibida ;
    rdfs:label "Usar un valor de zona inválido en comandos G120-G123"@es ;
    ns1:textoExtracto "El número de zona programado en G120/G121/G122/G123 no tiene un valor correcto."@es .

ns1:Parametro_K_ZonaTrabajo a ns1:Parametro ;
    rdfs:label "Parámetro K (número de zona de trabajo)"@es ;
    ns1:identificador "K" ;
    ns1:textoExtracto "Programar el número de zona en el parámetro \"K\"; de 1 a 5."@es ;
    ns1:valor "1-5" .

