@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_2387 a ns1:DiagnosticoFallo ;
    rdfs:label "Vigilancia de herramienta no válida en zona de trabajo"@es ;
    ns1:identificador "2387" ;
    ns1:solucionaFallo ns1:ParametroIDeG122VigilanciaDeHerramienta,
        ns1:VariablePLCGZONETOOLWATCHZone ;
    ns1:textoExtracto "2387 Vigilancia de herramienta no válida en zona de trabajo. DETECCIÓN Durante la preparación de bloques. CAUSA La vigilancia de herramienta en la zona de trabajo no tiene un valor correcto. Existen dos posibilidades. • El valor programado en G122 no es correcto. • El valor recuperado tras algún proceso de recuperación de datos (arranque, reset, inspección) no es correcto. SOLUCIÓN Programar un valor correcto para la vigilancia de herramienta; de 0 a 2. • En el primer caso, programar un valor correcto en el parámetro \"I\" de la función G122. • En el segundo caso, escribir desde el PLC el valor correcto en la variable \"G.ZONETOOLWATCH[zone]\""@es .

ns1:Fallo_2388 a ns1:DiagnosticoFallo ;
    rdfs:label "Estado de zona de trabajo no válido"@es ;
    ns1:identificador "2388" ;
    ns1:textoExtracto "2388 Estado de zona de trabajo no válido."@es .

ns1:Herramienta_Vigilada a ns1:Herramienta ;
    rdfs:label "Herramienta bajo vigilancia en zona de trabajo"@es ;
    ns1:textoExtracto "Vigilancia de herramienta en la zona de trabajo"@es .

ns1:Parametro_G122 a ns1:Parametro ;
    rdfs:label "Función G122 (vigilancia de herramienta)"@es ;
    ns1:monitoreaParametro ns1:Sistema_ZonaTrabajo ;
    ns1:textoExtracto "El valor programado en G122 no es correcto"@es .

ns1:ParametroIDeG122VigilanciaDeHerramienta a ns1:Parametro ;
    rdfs:label "Parámetro \"I\" de G122 (vigilancia de herramienta)"@es ;
    ns1:monitoreaParametro ns1:Sistema_ZonaTrabajo ;
    ns1:textoExtracto "Programar un valor correcto en el parámetro \"I\" de la función G122; de 0 a 2"@es ;
    ns1:valor "0-2" .

ns1:ParametroKNumeroDeZona a ns1:Parametro ;
    rdfs:label "Parámetro \"K\" (número de zona)"@es ;
    ns1:textoExtracto "Programar el número de zona en el parámetro \"K\"; de 1 a 5"@es ;
    ns1:valor "1-5" .

ns1:VariablePLCGZONETOOLWATCHZone a ns1:Parametro ;
    rdfs:label "Variable PLC G.ZONETOOLWATCH[zone]"@es ;
    ns1:monitoreaParametro ns1:Sistema_ZonaTrabajo ;
    ns1:textoExtracto "Escribir desde el PLC el valor correcto en la variable \"G.ZONETOOLWATCH[zone]\""@es ;
    ns1:valor "0-2" .

ns1:Sistema_ZonaTrabajo a ns1:Sistema ;
    rdfs:label "Sistema de zona de trabajo (G120/G121/G122/G123)"@es ;
    ns1:textoExtracto "El número de zona programado en G120/G121/G122/G123 no tiene un valor correcto. Programar el número de zona en el parámetro \"K\"; de 1 a 5"@es ;
    ns1:tieneComponente ns1:ParametroKNumeroDeZona .

