@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:AccionProhibida_ValorIncorrecto_G122 a ns1:AccionProhibida ;
    rdfs:label "Valor incorrecto en G122" ;
    ns1:activaAlarma ns1:Alarma_2388 ;
    ns1:textoExtracto "El valor programado en G122 no es correcto." .

ns1:AccionProhibida_ValorIncorrecto_Recuperacion a ns1:AccionProhibida ;
    rdfs:label "Valor incorrecto tras recuperación de datos" ;
    ns1:activaAlarma ns1:Alarma_2388 ;
    ns1:textoExtracto "El valor recuperado tras algún proceso de recuperación de datos (arranque, reset, inspección) no es correcto." .

ns1:Parametro_G122 a ns1:Parametro ;
    rdfs:label "G122" ;
    ns1:textoExtracto "El valor programado en G122 no es correcto." .

ns1:TareaMantenimiento_ProgramarValorZona a ns1:TareaMantenimiento ;
    rdfs:label "Programar valor correcto para estado de zona" ;
    ns1:solucionaFallo ns1:Alarma_2388 ;
    ns1:textoExtracto "SOLUCIÓN Programar un valor correcto para el estado de la zona; de 0" .

ns1:Parametro_G_ZONETOOLWATCH a ns1:Parametro ;
    rdfs:label "G.ZONETOOLWATCH[zone]" ;
    ns1:textoExtracto "escribir desde el PLC el valor correcto en la variable 'G.ZONETOOLWATCH[zone]'" ;
    ns1:valor "0"^^xsd:string .

ns1:Alarma_2388 a ns1:Alarma ;
    rdfs:label "Estado de zona de trabajo no válido" ;
    ns1:identificador "2388" ;
    ns1:monitoreaParametro ns1:Parametro_G_ZONETOOLWATCH ;
    ns1:textoExtracto "2388 Estado de zona de trabajo no válido. DETECCIÓN Durante la preparación de bloques. CAUSA El estado de la zona de trabajo no tiene un valor correcto." .

