@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_2389 a ns1:DiagnosticoFallo ;
    rdfs:label "El radio sólo se puede programar con R"@es ;
    ns1:identificador "2389" ;
    ns1:solucionaFallo ns1:InstruccionDeRadioR ;
    ns1:textoExtracto "DETECCIÓN Durante la preparación de bloques. CAUSA La instrucción programada sólo permite programar el radio con 'R'; no admite 'R1' ni G263. SOLUCIÓN Programar el radio con 'R'."@es .

ns1:Fallo_2390 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta programar el radio"@es ;
    ns1:identificador "2390" ;
    ns1:solucionaFallo ns1:RadioNoProgramado ;
    ns1:textoExtracto "DETECCIÓN Durante la preparación de bloques. CAUSA No se ha programado el radio. SOLUCIÓN Programar el radio."@es .

ns1:Fallo_2391 a ns1:DiagnosticoFallo ;
    rdfs:label "Zona circular: Centro mal programado"@es ;
    ns1:identificador "2391" ;
    ns1:solucionaFallo ns1:CentroDeZonaCircularG123 ;
    ns1:textoExtracto "DETECCIÓN Durante la preparación de bloques. CAUSA En la función G123 no se ha programado correctamente el centro de la zona circular. SOLUCIÓN El centro de la zona circular G123 se debe definir con dos ejes del canal."@es .

ns1:Fallo_2392 a ns1:DiagnosticoFallo ;
    rdfs:label "Zona lineal: Límites de eje inválidos"@es ;
    ns1:identificador "2392" ;
    ns1:solucionaFallo ns1:LimiteInferiorDeEjeG120,
        ns1:LimiteSuperiorDeEjeG121 ;
    ns1:textoExtracto "DETECCIÓN Durante la preparación de bloques. CAUSA El CNC ha intentado habilitar una zona de trabajo donde el límite inferior en un eje es mayor que el límite superior. SOLUCIÓN En una zona lineal, el límite inferior del eje debe ser menor que límite superior."@es .

ns1:Fallo_2393 a ns1:DiagnosticoFallo ;
    rdfs:label "Función E doblemente programada"@es ;
    ns1:identificador "2393" ;
    ns1:solucionaFallo ns1:ParametroEFuncionG122 ;
    ns1:textoExtracto "DETECCIÓN Durante la preparación de bloques. CAUSA El parámetro 'E' está programado más de una vez en el bloque."@es .

ns1:Fallo_ValorZonaIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "Valor de zona recuperado incorrecto"@es ;
    ns1:solucionaFallo ns1:EstadoDeZonaParametroEEnG122,
        ns1:VariableGZONESTZone ;
    ns1:textoExtracto "El valor recuperado tras algún proceso de recuperación de datos (arranque, reset, inspección) no es correcto. SOLUCIÓN Programar un valor correcto para el estado de la zona; de 0 a 2."@es .

ns1:CentroDeZonaCircularG123 a ns1:Parametro ;
    rdfs:label "Centro de zona circular (G123)"@es ;
    ns1:identificador "G123" ;
    ns1:textoExtracto "El centro de la zona circular G123 se debe definir con dos ejes del canal. La función G123 sólo admite dos ejes, que deben ser diferentes, y pertenecer al canal en el que se activa la zona."@es .

ns1:EstadoDeZonaParametroEEnG122 a ns1:Parametro ;
    rdfs:label "Estado de zona (parámetro E en G122)"@es ;
    ns1:identificador "E" ;
    ns1:textoExtracto "Programar un valor correcto en el parámetro 'E' de la función G122 (rango: 0 a 2)."@es ;
    ns1:valor "0-2" .

ns1:InstruccionDeRadioR a ns1:Parametro ;
    rdfs:label "Instrucción de radio (R)"@es ;
    ns1:textoExtracto "La instrucción programada sólo permite programar el radio con 'R'."@es ;
    ns1:valor "R" .

ns1:LimiteInferiorDeEjeG120 a ns1:Parametro ;
    rdfs:label "Límite inferior de eje (G120)"@es ;
    ns1:identificador "G120" ;
    ns1:textoExtracto "Modificar el límite inferior (G120) del eje."@es .

ns1:LimiteSuperiorDeEjeG121 a ns1:Parametro ;
    rdfs:label "Límite superior de eje (G121)"@es ;
    ns1:identificador "G121" ;
    ns1:textoExtracto "Modificar el límite superior (G121) del eje."@es .

ns1:ParametroEFuncionG122 a ns1:Parametro ;
    rdfs:label "Parámetro E (función G122)"@es ;
    ns1:identificador "E" ;
    ns1:textoExtracto "El parámetro 'E' de la función G122 programado más de una vez en el bloque."@es .

ns1:RadioNoProgramado a ns1:Parametro ;
    rdfs:label "Radio no programado"@es ;
    ns1:textoExtracto "No se ha programado el radio."@es .

ns1:VariableGZONESTZone a ns1:Parametro ;
    rdfs:label "Variable G.ZONEST[zone]"@es ;
    ns1:identificador "G.ZONEST" ;
    ns1:textoExtracto "Escribir desde el PLC el valor correcto en la variable 'G.ZONEST[zone]'."@es .

