@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_2394 a ns1:AvisoSeguridad ;
    rdfs:label "Estado de la zona de trabajo no programado" ;
    ns1:identificador "2394" ;
    ns1:textoExtracto "2394 Estado de la zona de trabajo no programado. DETECCIÓN Durante la preparación de bloques. CAUSA No se ha programado el estado de la zona de trabajo en" .

ns1:Parametro_E a ns1:Parametro ;
    rdfs:label "Parámetro E" ;
    ns1:monitoreaParametro ns1:AvisoSeguridad_2393 ;
    ns1:textoExtracto "El parámetro \"E\" está programado más de una vez en el bloque." ;
    ns1:valor "E" .

ns1:AvisoSeguridad_2393 a ns1:AvisoSeguridad ;
    rdfs:label "Función E doblemente programada" ;
    ns1:identificador "2393" ;
    ns1:textoExtracto "2393 'Función E doblemente programada' DETECCIÓN Durante la preparación de bloques. CAUSA El parámetro \"E\" está programado más de una vez en el bloque. SOLUCIÓN Programar el parámetro \"E\" una sola vez en el bloque." .

