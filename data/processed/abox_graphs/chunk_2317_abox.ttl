@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Diagnostico_2401 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para error 2401: Eje lógico incorrecto o zona activa"@es ;
    ns1:mitigaRiesgo ns1:ConfiguracionEjesCNC ;
    ns1:solucionaFallo ns1:Error_2401 ;
    ns1:textoExtracto "CAUSA El número lógico programado en la variable no es correcto. SOLUCIÓN Programar un eje lógico correcto; de 1 hasta el número máximo de ejes (parámetro NAXIS)"@es .

ns1:Error_2401 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2401: '#FREE/SET AX: No se permite liberar un eje que define una zona de trabajo activa'"@es ;
    ns1:detalladoEnEsquema ns1:ConfiguracionEjesCNC ;
    ns1:identificador "2401" ;
    ns1:textoExtracto "2401 '#FREE/SET AX: No se permite liberar un eje que define una zona de trabajo activa'"@es .

ns1:Parametro_NAXIS a ns1:Parametro ;
    rdfs:label "Parámetro NAXIS (número máximo de ejes)"@es ;
    ns1:identificador "NAXIS" ;
    ns1:textoExtracto "número máximo de ejes (parámetro NAXIS)"@es ;
    ns1:valor "número máximo de ejes"@es .

ns1:VariableEjeLogico a ns1:Parametro ;
    rdfs:label "Variable de eje lógico (1 a NAXIS)"@es ;
    ns1:textoExtracto "Programar un eje lógico correcto; de 1 hasta el número máximo de ejes (parámetro NAXIS)"@es .

ns1:ConfiguracionEjesCNC a ns1:Sistema ;
    rdfs:label "Configuración de ejes del CNC"@es ;
    ns1:monitoreaParametro ns1:Parametro_NAXIS ;
    ns1:textoExtracto "configuración un eje que forma parte de una zona de trabajo activa"@es ;
    ns1:tieneComponente ns1:VariableEjeLogico .

