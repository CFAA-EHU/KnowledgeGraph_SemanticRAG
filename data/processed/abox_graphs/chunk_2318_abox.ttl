@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_2404 a ns1:Alarma ;
    rdfs:label "Alarma 2404: Índice alterado en canal de eje" ;
    ns1:identificador "2404" ;
    ns1:textoExtracto "'#GAPCTRL: Se ha alterado el índice en el canal del eje controlado." .

ns1:AccionProhibida_2401 a ns1:AccionProhibida ;
    rdfs:label "Liberar eje sin desactivar zona de trabajo" ;
    ns1:activaAlarma ns1:Alarma_2401 ;
    ns1:textoExtracto "quitar de la configuración un eje que forma parte de una zona de trabajo activa" .

ns1:AccionProhibida_2402 a ns1:AccionProhibida ;
    rdfs:label "Aparcar eje sin desactivar zona de trabajo" ;
    ns1:activaAlarma ns1:Alarma_2402 ;
    ns1:textoExtracto "aparcar un eje que forma parte de una zona de trabajo activa" .

ns1:AccionProhibida_2403 a ns1:AccionProhibida ;
    rdfs:label "Activar zona con eje aparcado" ;
    ns1:activaAlarma ns1:Alarma_2403 ;
    ns1:textoExtracto "activar una zona de trabajo, pero uno de los ejes que la definen está aparcado" .

ns1:Alarma_2401 a ns1:Alarma ;
    rdfs:label "Alarma 2401: Eje en zona de trabajo activa" ;
    ns1:identificador "2401" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_2401 ;
    ns1:textoExtracto "un eje que define una zona de trabajo activa' DETECCIÓN Durante la preparación de bloques. CAUSA El CNC ha intentado quitar de la configuración un eje que forma parte de una zona de trabajo activa. SOLUCIÓN Desactivar la zona de trabajo antes de liberar el eje." .

ns1:Alarma_2402 a ns1:Alarma ;
    rdfs:label "Alarma 2402: Aparcamiento de eje en zona activa" ;
    ns1:identificador "2402" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_2402 ;
    ns1:textoExtracto "'#PARK: No se permite aparcar un eje que define una zona de trabajo activa' DETECCIÓN Durante la preparación de bloques. CAUSA El CNC ha intentado aparcar un eje que forma parte de una zona de trabajo activa. SOLUCIÓN Desactivar la zona de trabajo antes de aparcar el eje." .

ns1:Alarma_2403 a ns1:Alarma ;
    rdfs:label "Alarma 2403: Activación de zona con eje aparcado" ;
    ns1:identificador "2403" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_2403 ;
    ns1:textoExtracto "'No se permite activar una zona con uno de sus ejes aparcado' DETECCIÓN Durante la preparación de bloques. CAUSA El CNC ha intentado activar una zona de trabajo, pero uno de los ejes que la definen está aparcado. SOLUCIÓN Desaparcar el eje antes de activar la zona de trabajo." .

ns1:Componente_Eje a ns1:ComponenteMecanico ;
    rdfs:label "Eje de zona de trabajo" ;
    ns1:textoExtracto "eje que define una zona de trabajo activa" ;
    ns1:tieneComponente ns1:Sistema_ZonaTrabajo .

ns1:Sistema_ZonaTrabajo a ns1:Sistema ;
    rdfs:label "Sistema de zonas de trabajo activas" ;
    ns1:controla ns1:Componente_Eje ;
    ns1:textoExtracto "eje que define una zona de trabajo activa" .

