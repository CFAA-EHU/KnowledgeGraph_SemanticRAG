@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_2404 a ns1:Alarma ;
    rdfs:label "#GAPCTRL: Índice alterado en canal de eje controlado"@es ;
    ns1:identificador "2404" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_ModificarEjeConGapActivo ;
    ns1:textoExtracto """
    2404 #GAPCTRL: Se ha alterado el índice en el canal del eje controlado.
    DETECCIÓN Durante la preparación de bloques.
    CAUSA Las posibles causas son las siguientes:
    • Con el control del gap activo (#GAPCTRLON), se ha programado una instrucción que altera el índice de dicho eje en el canal (#SETAX, #CALLAX, #FREEAX).
    • Si el parámetro máquina GAPCTRLCANCEL tiene valor "NO", el eje sigue controlado después de acabar el programa o tras un reset. Si en estas condiciones se altera el índice del eje, también se produce este error.
    """@es .

ns1:Comando_GAPCTROFF a ns1:Parametro ;
    rdfs:label "Comando #GAPCTRL OFF"@es ;
    ns1:identificador "#GAPCTRL OFF" ;
    ns1:solucionaFallo ns1:Alarma_2405 ;
    ns1:textoExtracto "Programar #GAPCTRL OFF."@es .

ns1:ModoOperacion_MDI a ns1:ModoOperacion ;
    rdfs:label "Modo MDI (Manual Data Input)"@es ;
    ns1:identificador "MDI" ;
    ns1:textoExtracto "modo MDI"@es .

ns1:Parametro_GAPCTRLCANCEL a ns1:Parametro ;
    rdfs:label "GAPCTRLCANCEL"@es ;
    ns1:identificador "GAPCTRLCANCEL" ;
    ns1:monitoreaParametro ns1:Maquina_ControlEjes ;
    ns1:textoExtracto "Si el parámetro máquina GAPCTRLCANCEL tiene valor \"NO\", el eje sigue controlado después de acabar el programa o tras un reset."@es ;
    ns1:valor "NO" .

ns1:AccionProhibida_ModificarEjeConGapActivo a ns1:AccionProhibida ;
    rdfs:label "Modificar posición de ejes con control de gap activo (#GAPCTRLON)"@es ;
    ns1:textoExtracto "No es posible modificar la posición de los ejes en el canal con el control de gap activo."@es .

ns1:AccionProhibida_MoverEjeMDIConGapActivo a ns1:AccionProhibida ;
    rdfs:label "Mover eje en modo MDI con comando #GAPCTRL activo"@es ;
    ns1:textoExtracto "Se ha intentado mover en MDI un eje que está siendo controlado mediante el comando #GAPCTRL."@es .

ns1:Alarma_2405 a ns1:Alarma ;
    rdfs:label "Bloque de movimiento anulado por eje con #GAPCTRL"@es ;
    ns1:identificador "2405" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_MoverEjeMDIConGapActivo ;
    ns1:textoExtracto """
    2405 Bloque de movimiento anulado por tener un eje con #GAPCTRL.
    DETECCIÓN Durante la inspección de herramienta o modo MDI.
    CAUSA Se ha intentado mover en MDI un eje que está siendo controlado mediante el comando #GAPCTRL.
    """@es .

ns1:Componente_EjeControlado a ns1:ComponenteMecanico ;
    rdfs:label "Eje controlado por comando #GAPCTRL"@es ;
    ns1:textoExtracto "eje controlado mediante el comando #GAPCTRL"@es .

ns1:Maquina_ControlEjes a ns1:Maquina ;
    rdfs:label "Sistema de control de ejes con comando #GAPCTRL"@es ;
    ns1:textoExtracto """
    Con el control del gap activo (#GAPCTRLON), se ha programado una instrucción que altera el índice de dicho eje en el canal.
    El eje sigue controlado después de acabar el programa o tras un reset si GAPCTRLCANCEL = "NO".
    """@es ;
    ns1:tieneComponente ns1:Componente_EjeControlado .

