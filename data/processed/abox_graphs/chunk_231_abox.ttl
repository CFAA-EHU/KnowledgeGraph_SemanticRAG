@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_G_Functions a ns1:Tabla ;
    rdfs:label "List of G-Functions" ;
    ns1:documentadoEn ns1:Manual ;
    ns1:textoExtracto "TECHNOLOGICAL FUNCTIONS. - LIST OF AUXILIARY (MISCELLANEOUS) –M- - FUNCTIONS. - LIST OF –G- FUNCTIONS." ;
    ns1:tieneComponente ns1:G130,
        ns1:G131,
        ns1:G132,
        ns1:G133,
        ns1:G134,
        ns1:G135,
        ns1:G136,
        ns1:G137,
        ns1:G138,
        ns1:G139,
        ns1:G145,
        ns1:G151,
        ns1:G152,
        ns1:G157 .

ns1:G130 a ns1:Parametro ;
    rdfs:label "G130" ;
    ns1:identificador "G130" ;
    ns1:monitoreaParametro ns1:Maquina ;
    ns1:textoExtracto "Percentage of acceleration to be applied per axis or spindle." .

ns1:G131 a ns1:Parametro ;
    rdfs:label "G131" ;
    ns1:identificador "G131" ;
    ns1:monitoreaParametro ns1:Maquina ;
    ns1:textoExtracto "Percentage of acceleration to be applied to all the axes." .

