    rdfs:label "G137" ;
    ns1:identificador "G137" ;
    ns1:monitoreaParametro ns1:Maquina ;
    ns1:textoExtracto "Linear transition between blocks." .

ns1:G138 a ns1:Parametro ;
    rdfs:label "G138" ;
    ns1:identificador "G138" ;
    ns1:monitoreaParametro ns1:Maquina ;
    ns1:textoExtracto "Direct activation/cancellation of tool compensation." .

ns1:G139 a ns1:Parametro ;
    rdfs:label "G139" ;
    ns1:identificador "G139" ;
    ns1:monitoreaParametro ns1:Maquina ;
    ns1:textoExtracto "Indirect activation/cancellation of tool compensation." .

