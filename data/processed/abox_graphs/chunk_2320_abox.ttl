@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Comando_GAPCTRL a ns1:Parametro ;
    rdfs:label "Comando de control de eje #GAPCTRL"@es ;
    ns1:identificador "#GAPCTRL" ;
    ns1:textoExtracto "eje que está siendo controlado mediante el comando #GAPCTRL" ;
    ns1:valor "ON/OFF" .

ns1:Comando_LEAP a ns1:Parametro ;
    rdfs:label "Instrucción de salto #LEAP"@es ;
    ns1:identificador "#LEAP" ;
    ns1:textoExtracto "instrucción #LEAP para ejecutar un salto cuya cota inicial y final"@es .

ns1:Fallo_2406 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2406: #LEAP con #GAPCTRL ON"@es ;
    ns1:identificador "2406" ;
    ns1:solucionaFallo ns1:Solucion_GAPCTRL_OFF ;
    ns1:textoExtracto "2406 #LEAP con #GAPCTRL ON: El salto debe empezar y acabar en la misma cota. DETECCIÓN Durante la preparación de bloques. CAUSA Hay un eje controlado mediante la instrucción #GAPCTRL ON. En esta situación se ha programado la instrucción #LEAP para ejecutar un salto cuya cota inicial y final"@es .

ns1:Fallo_GAPCTRL_MDI a ns1:DiagnosticoFallo ;
    rdfs:label "Intento de movimiento en MDI con eje bajo #GAPCTRL"@es ;
    ns1:solucionaFallo ns1:Solucion_GAPCTRL_OFF ;
    ns1:textoExtracto "CAUSA Se ha intentado mover en MDI un eje que está siendo controlado mediante el comando #GAPCTRL. SOLUCIÓN Programar #GAPCTRL OFF."@es .

ns1:Solucion_GAPCTRL_OFF a ns1:AccionProhibida ;
    rdfs:label "Desactivación de control #GAPCTRL"@es ;
    ns1:identificador "#GAPCTRL OFF" ;
    ns1:textoExtracto "Programar #GAPCTRL OFF."@es .

