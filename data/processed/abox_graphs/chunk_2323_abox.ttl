@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_2411 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia PWRCTRL"@es ;
    ns1:identificador "2411" ;
    ns1:monitoreaParametro ns1:ParametroPWRCTRLDUTYDOUTO ;
    ns1:solucionaFallo ns1:RevisionDeSintaxisEnManualDeProgramacion ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta. [...] 2411 #PWRCTRL OFF<[DUTY/D/OUT/O]>"@es .

ns1:Fallo_2412 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro PWRCTRL fuera de rango"@es ;
    ns1:identificador "2412" ;
    ns1:monitoreaParametro ns1:Parametro_PWRCTRL_2411 ;
    ns1:textoExtracto "2412 Parámetro PWRCTRL fuera de rango."@es .

ns1:Manual_Programacion a ns1:Manual ;
    rdfs:label "Manual de programación"@es ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:ParametroPWRCTRLDUTYDOUTO a ns1:Parametro ;
    rdfs:label "Parámetro PWRCTRL (DUTY/D/OUT/O)"@es ;
    ns1:identificador "PWRCTRL" ;
    ns1:textoExtracto "#PWRCTRL OFF<[DUTY/D/OUT/O]>"@es ;
    ns1:valor "OFF<[DUTY/D/OUT/O]>" .

ns1:RevisionDeSintaxisEnManualDeProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de sintaxis en manual de programación"@es ;
    ns1:requiereMantenimiento ns1:Manual_Programacion ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia."@es .

