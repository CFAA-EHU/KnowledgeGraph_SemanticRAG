@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_2412 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro PWRCTRL fuera de rango"@es ;
    ns1:identificador "2412" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "2412 Parámetro PWRCTRL fuera de rango. DETECCIÓN Durante la edición y ejecución. CAUSA Algún comando de la sentencia #PERCTRL tiene un valor no válido. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:Fallo_2413 a ns1:DiagnosticoFallo ;
    rdfs:label "Es obligatorio programar DUTY/OUT"@es ;
    ns1:identificador "2413" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "2413 Es obligatorio programar DUTY/OUT. DETECCIÓN Durante la edición y ejecución. CAUSA Falta programar el comando DUTY/OUT en la función #PWRCTRL. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. Para activar el control de potencia (#PWRCTRL) es obligatorio programar uno de los comandos DUTY o OUT."@es .

ns1:Fallo_2414 a ns1:DiagnosticoFallo ;
    rdfs:label "PWCTRL DUTY no permitido si no hay opción de software PWM"@es ;
    ns1:identificador "2414" ;
    ns1:solucionaFallo ns1:OpcionSoftware_PWM ;
    ns1:textoExtracto "2414 PWCTRL DUTY no permitido si no hay opción de software PWM. DETECCIÓN Durante la ejecución. CAUSA Para activar el control del duty del PWM, es necesario disponer de la opción de software \"PWM\"."@es .

ns1:Fallo_Sintaxis a ns1:DiagnosticoFallo ;
    rdfs:label "Sintaxis de la sentencia incorrecta"@es ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:Funcion_PWRCTRL a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "#PWRCTRL" ;
    ns1:identificador "#PWRCTRL" ;
    ns1:monitoreaParametro ns1:Parametro_DUTY,
        ns1:Parametro_OUT,
        ns1:Parametro_PWRCTRL ;
    ns1:textoExtracto "función #PWRCTRL"@es .

ns1:OpcionSoftware_PWM a ns1:Sistema ;
    rdfs:label "Opción de software PWM"@es ;
    ns1:identificador "PWM" ;
    ns1:textoExtracto "opción de software \"PWM\""@es .

ns1:Parametro_DUTY a ns1:Parametro ;
    rdfs:label "DUTY" ;
    ns1:identificador "DUTY" ;
    ns1:textoExtracto "comando DUTY/OUT"@es .

ns1:Parametro_OUT a ns1:Parametro ;
    rdfs:label "OUT" ;
    ns1:identificador "OUT" ;
    ns1:textoExtracto "comando DUTY/OUT"@es .

ns1:Parametro_PWRCTRL a ns1:Parametro ;
    rdfs:label "PWRCTRL" ;
    ns1:identificador "PWRCTRL" ;
    ns1:textoExtracto "2412 Parámetro PWRCTRL fuera de rango."@es .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación"@es ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia."@es .

