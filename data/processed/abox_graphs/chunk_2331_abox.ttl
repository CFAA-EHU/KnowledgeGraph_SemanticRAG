@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_2429 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro DMC fuera de rango" ;
    ns1:documentadoEn ns1:Manual_Programacion ;
    ns1:identificador "2429" ;
    ns1:solucionaFallo ns1:RevisionDeSintaxisEnManualDeProgramacion ;
    ns1:textoExtracto "2429 Parámetro DMC fuera de rango. DETECCIÓN Durante la edición y ejecución. CAUSA Algún comando de la sentencia #DMC tiene un valor no válido. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Fallo_2431 a ns1:DiagnosticoFallo ;
    rdfs:label "#DMC ON: Error de parámetros no especificado" ;
    ns1:documentadoEn ns1:Manual_Programacion ;
    ns1:identificador "2431" ;
    ns1:textoExtracto "#DMC ON:" .

ns1:Parametro_FZMAX a ns1:Parametro ;
    rdfs:label "Avance máximo (FZMAX)" ;
    ns1:monitoreaParametro ns1:Fallo_2430 ;
    ns1:textoExtracto "avance máximo (FZMAX)" .

ns1:Parametro_FZMIN a ns1:Parametro ;
    rdfs:label "Avance mínimo (FZMIN)" ;
    ns1:monitoreaParametro ns1:Fallo_2430 ;
    ns1:textoExtracto "avance mínimo (FZMIN)" .

ns1:FZMINFZMAX a ns1:Parametro ;
    rdfs:label "FZMIN < FZMAX" ;
    ns1:textoExtracto "El avance mínimo (FZMIN) debe ser menor que el avance máximo (FZMAX)." ;
    ns1:valor "FZMIN < FZMAX" .

ns1:RevisionDeSintaxisEnManualDeProgramacion a ns1:AccionProhibida ;
    rdfs:label "Revisión de sintaxis en manual de programación" ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Fallo_2430 a ns1:DiagnosticoFallo ;
    rdfs:label "#DMC ON: FZMIN debe ser menor que FZMAX" ;
    ns1:documentadoEn ns1:Manual_Programacion ;
    ns1:identificador "2430" ;
    ns1:solucionaFallo ns1:FZMINFZMAX ;
    ns1:textoExtracto "2430 #DMC ON: FZMIN debe ser menor que FZMAX. DETECCIÓN Durante la ejecución. CAUSA En la función #DMC, el avance mínimo es mayor que el avance máximo. SOLUCIÓN El avance mínimo (FZMIN) debe ser menor que el avance máximo (FZMAX)." .

ns1:Manual_Programacion a ns1:Manual ;
    rdfs:label "Manual de programación" ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

