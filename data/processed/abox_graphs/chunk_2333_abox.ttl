@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error2436 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2436: Programación no permitida fuera de macro G8777"@es ;
    ns1:identificador "2436" ;
    ns1:mitigaRiesgo ns1:Macro_G8777 ;
    ns1:solucionaFallo ns1:Funcion_G8701,
        ns1:Funcion_G8702,
        ns1:Funcion_G8778 ;
    ns1:textoExtracto "2436 Programación no permitida fuera de una macro G8777. DETECCIÓN Durante la ejecución. CAUSA Hay alguna función G8778, G8701 o G8702 programada fuera de una macro G8777. SOLUCIÓN Revisar la programación. Las funciones G8778, G8701 o G8702 se deben programar a continuación de la macro G8777."@es .

ns1:Error2437 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2437: Perfil poligonal en macro G8077"@es ;
    ns1:identificador "2437" ;
    ns1:textoExtracto "2437 El perfil de la macro G8077 es poligonal. DETECCIÓN Durante la ejecución. CAUSA El perfil debe estar construido con tramos rectos. SOLUCIÓN Modificar el perfil."@es .

ns1:Macro_G8077 a ns1:ModoOperacion ;
    rdfs:label "Macro G8077"@es ;
    ns1:identificador "G8077" ;
    ns1:textoExtracto "macro G8077"@es .

ns1:Funcion_G8701 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G8701"@es ;
    ns1:identificador "G8701" ;
    ns1:textoExtracto "función G8701"@es .

ns1:Funcion_G8702 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G8702"@es ;
    ns1:identificador "G8702" ;
    ns1:textoExtracto "función G8702"@es .

ns1:Funcion_G8778 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G8778"@es ;
    ns1:identificador "G8778" ;
    ns1:textoExtracto "función G8778"@es .

ns1:Macro_G8777 a ns1:ModoOperacion ;
    rdfs:label "Macro G8777"@es ;
    ns1:identificador "G8777" ;
    ns1:textoExtracto "macro G8777"@es .

