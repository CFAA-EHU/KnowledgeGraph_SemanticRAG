@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Comando_LEAP a ns1:Parametro ;
    rdfs:label "Comando #LEAP" ;
    ns1:textoExtracto "comando #LEAP, que debe acabar a una determinada distancia sobre la chapa (parámetro GAP)" .

ns1:Error_2437 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2437: Perfil no poligonal en macro G8077" ;
    ns1:identificador "2437" ;
    ns1:textoExtracto "El perfil de la macro G8077 es poligonal. [...] SOLUCIÓN Modificar el perfil." .

ns1:Error_2438 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2438: #LEAP[GAP] XY sin #GAPCTRL ON" ;
    ns1:identificador "2438" ;
    ns1:solucionaFallo ns1:Comando_GAPCTRL_ON,
        ns1:Parametro_GAP ;
    ns1:textoExtracto "#LEAP[GAP] XY sin programar previamente #GAPCTRL ON. [...] SOLUCIÓN Las posibles soluciones son las siguientes: • Programar #GAPCTRL ON antes del #LEAP donde se detecta el error • Eliminar el parámetro GAP de los comandos #LEAP." .

ns1:Error_2439 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2439: Nodo no programado tras \".\"" ;
    ns1:identificador "2439" ;
    ns1:solucionaFallo ns1:Nodo_Sercos ;
    ns1:textoExtracto "Programar el número de nodo tras el \".\". [...] SOLUCIÓN Programar un nodo entre 1 y 32." .

ns1:Error_2440 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2440: Nodo Sercos inexistente" ;
    ns1:identificador "2440" ;
    ns1:solucionaFallo ns1:Nodo_Sercos,
        ns1:Variable_DRV ;
    ns1:textoExtracto "Nodo inexistente. [...] SOLUCIÓN Programar un nodo entre 1 y 32." .

ns1:Error_2441 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2441: Doble programación de #FINALSUB" ;
    ns1:identificador "2441" ;
    ns1:solucionaFallo ns1:Comando_FINALSUB ;
    ns1:textoExtracto "Doble programación de #FINALSUB. [...] SOLUCIÓN Programar una única vez #FINALSUB." .

ns1:Error_2442 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2442: Función G8753 fuera de macro G8754" ;
    ns1:identificador "2442" ;
    ns1:solucionaFallo ns1:Funcion_G8753,
        ns1:Macro_G8754 ;
    ns1:textoExtracto "Programación no permitida fuera de una macro G8754. [...] SOLUCIÓN Revisar la programación." .

ns1:Comando_FINALSUB a ns1:Parametro ;
    rdfs:label "Comando #FINALSUB" ;
    ns1:textoExtracto "#FINALSUB [...] Solo se permite una única programación." .

ns1:Comando_GAPCTRL_ON a ns1:Parametro ;
    rdfs:label "Comando #GAPCTRL ON" ;
    ns1:textoExtracto "#GAPCTRL ON" .

ns1:Funcion_G8753 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G8753" ;
    ns1:textoExtracto "función G8753 programada fuera de una macro G8754" .

ns1:Macro_G8754 a ns1:Parametro ;
    rdfs:label "Macro G8754" ;
    ns1:textoExtracto "macro G8754" .

ns1:Parametro_GAP a ns1:Parametro ;
    rdfs:label "Parámetro GAP" ;
    ns1:textoExtracto "parámetro GAP [...] distancia sobre la chapa" .

ns1:Variable_DRV a ns1:Parametro ;
    rdfs:label "Variable del regulador (DRV)" ;
    ns1:textoExtracto "La variable del regulador (DRV) asociada al nodo Sercos (regulador o RCS-S) es incorrecta." .

ns1:Nodo_Sercos a ns1:Componente ;
    rdfs:label "Nodo Sercos (regulador o RCS-S)" ;
    ns1:textoExtracto "nodo Sercos (regulador o RCS-S)" ;
    ns1:valor "1-32"^^xsd:string .

