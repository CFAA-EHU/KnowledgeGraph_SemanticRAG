@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Comando_FINALSUB a ns1:AccionProhibida ;
    rdfs:label "Comando #FINALSUB" ;
    ns1:identificador "#FINALSUB" ;
    ns1:solucionaFallo ns1:Fallo_2442 ;
    ns1:textoExtracto "SOLUCIÓN Programar una única vez #FINALSUB." .

ns1:Comando_MATERIAL a ns1:Parametro ;
    rdfs:label "Comando #MATERIAL" ;
    ns1:identificador "#MATERIAL" ;
    ns1:textoExtracto "Durante la ejecución del comando #MATERIAL o al activar/validar una tabla tecnológica." .

ns1:Fallo_2443 a ns1:DiagnosticoFallo ;
    rdfs:label "Reinicio necesario para cambios en fichero de material" ;
    ns1:identificador "2443" ;
    ns1:textoExtracto "Para asumir cambios en el fichero de material es necesario reiniciar el CNC. DETECCIÓN Durante la ejecución del comando #MATERIAL o al activar/validar una tabla tecnológica." .

ns1:Funcion_G8753 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G8753" ;
    ns1:identificador "G8753" ;
    ns1:textoExtracto "Las funciones G8753 se deben programar a continuación de la macro G8754." .

ns1:Macro_G8754 a ns1:Parametro ;
    rdfs:label "Macro G8754" ;
    ns1:identificador "G8754" ;
    ns1:textoExtracto "Programación no permitida fuera de una macro G8754." .

ns1:TablaTecnologica a ns1:Tabla ;
    rdfs:label "Tabla tecnológica" ;
    ns1:textoExtracto "al activar/validar una tabla tecnológica." .

ns1:Fallo_2442 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación no permitida fuera de una macro G8754" ;
    ns1:identificador "2442" ;
    ns1:textoExtracto "Programación no permitida fuera de una macro G8754. DETECCIÓN Durante la ejecución. CAUSA Hay alguna función G8753 programada fuera de una macro G8754." .

