@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_2449 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2449: Eje Hirth en transformación #PARALAX" ;
    ns1:identificador "2449" ;
    ns1:solucionaFallo ns1:Transformacion_PARALAX ;
    ns1:textoExtracto "2449 No se puede activar el eje como Hirth, por formar parte de la transformación #PARALAX. DETECCIÓN Durante la ejecución. CAUSA Alguno de los ejes programados es un eje Hirth. SOLUCIÓN Los ejes programados no pueden ser Hirth." .

ns1:Error_2450 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2450: Exclusión de ejes en transformación #PARALAX" ;
    ns1:identificador "2450" ;
    ns1:solucionaFallo ns1:Transformacion_PARALAX ;
    ns1:textoExtracto "2450 #PARALAX: Los ejes de la transformación activa, no pueden excluirse. DETECCIÓN Durante la ejecución. CAUSA Una sentencia #SETAX o #FREEAX ha intentado cambiar los eje incluidos en una" .

ns1:Transformacion_PARALAX a ns1:ModoOperacion ;
    rdfs:label "Transformación #PARALAX" ;
    ns1:identificador "#PARALAX" ;
    ns1:textoExtracto "transformación #PARALAX" .

