@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Comando_TYPE a ns1:Parametro ;
    rdfs:label "Parámetro TYPE" ;
    ns1:textoExtracto "comando TYPE" .

ns1:Error_2456 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2456: Conflicto con #GAPPOS y modificación de ejes" ;
    ns1:identificador "2456" ;
    ns1:textoExtracto "2456 Con #GAPPOS activo no se permite cambiar los tres primeros ejes. DETECCIÓN Durante la preparación de bloques. CAUSA Se ha intentado modificar los tres primeros ejes del canal (#FREEAX o #SETAX) mientras la sentencia #GAPPOS está activa. SOLUCIÓN No modificar los tres primeros ejes del canal antes de la sentencia #GAPPOS o #GAPCTRL esté activa." .

ns1:Error_2457 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2457: Exceso de parámetros en #GAPPOS" ;
    ns1:identificador "2457" ;
    ns1:textoExtracto "2457 #GAPPOS: demasiados parámetros. DETECCIÓN Durante la preparación de bloques. CAUSA Se han definido más de tres ejes en la sentencia #GAPPOS. SOLUCIÓN En la sentencia #GAPPOS sólo hay que definir los tres primeros ejes del canal." .

ns1:Error_2458 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2458: Parámetro DMCSPDL no configurado en cabezal master" ;
    ns1:identificador "2458" ;
    ns1:solucionaFallo ns1:CabezalMaster ;
    ns1:textoExtracto "2458 #DMC ON:El cabezal master debe tener el parámetro DMCSPDL = Sí. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado activar el DMC en un cabezal que no tiene permiso para ello. SOLUCIÓN Para activar el DMC sobre un cabezal, éste debe tener su parámetro máquina DMCSPDL=Sí." .

ns1:Error_2459 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2459: Valor inválido en parámetro TYPE (#OPEN)" ;
    ns1:identificador "2459" ;
    ns1:textoExtracto "2459 #OPEN: valor de parámetro TYPE no válido. DETECCIÓN Durante la ejecución. CAUSA El comando TYPE tiene un valor no válido. SOLUCIÓN Revisar la programación de la sentencia #OPEN." .

ns1:Error_2461 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2461: Conflicto entre eje #GAPCTRL y transformadas" ;
    ns1:identificador "2461" ;
    ns1:textoExtracto "2461 El eje del #GAPCTRL, no puede formar parte de los ejes de la transformada. DETECCIÓN Durante la ejecución. CAUSA El eje para el control de gap (#GAPCTRL) coincide con algún eje de las transformaciones #CS/#ACS, #RTCP, #ANGAX o #VIRTAX. SOLUCIÓN Programar el control de gap con un eje simulado." .

ns1:Error_2462 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2462: Eje fuera de plano o triedro" ;
    ns1:identificador "2462" ;
    ns1:textoExtracto "2462 El eje programado debe pertenecer al plano o triedro. DETECCIÓN Durante la ejecución. CAUSA El eje no pertenece al plano principal o triedro. SOLUCIÓN Revisar la programación." .

ns1:Error_2463 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2463: Incompatibilidad entre #LEAP y GAP3D" ;
    ns1:identificador "2463" ;
    ns1:textoExtracto "2463 #LEAP incompatible con GAP3D. DETECCIÓN Durante la ejecución." .

ns1:Sentencia_GAPCTRL a ns1:InterfazUsuario ;
    rdfs:label "Sentencia #GAPCTRL" ;
    ns1:textoExtracto "sentencia #GAPCTRL" .

ns1:Sentencia_GAPPOS a ns1:InterfazUsuario ;
    rdfs:label "Sentencia #GAPPOS" ;
    ns1:textoExtracto "sentencia #GAPPOS" .

ns1:Sentencia_OPEN a ns1:InterfazUsuario ;
    rdfs:label "Sentencia #OPEN" ;
    ns1:textoExtracto "sentencia #OPEN" .

ns1:CabezalMaster a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal master" ;
    ns1:requiereMantenimiento ns1:Parametro_DMCSPDL ;
    ns1:textoExtracto "cabezal master" .

ns1:Parametro_DMCSPDL a ns1:Parametro ;
    rdfs:label "Parámetro máquina DMCSPDL" ;
    ns1:textoExtracto "el parámetro máquina DMCSPDL=Sí" ;
    ns1:valor "Sí" .

