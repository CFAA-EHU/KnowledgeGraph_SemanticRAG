@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_2462 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 2462: Eje no pertenece al plano o triedro"@es ;
    ns1:identificador "2462" ;
    ns1:textoExtracto "2462 El eje programado debe pertenecer al plano o triedro. DETECCIÓN Durante la ejecución. CAUSA El eje no pertenece al plano principal o triedro. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_2463 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 2463: #LEAP incompatible con GAP3D"@es ;
    ns1:identificador "2463" ;
    ns1:solucionaFallo ns1:Comando_LEAP ;
    ns1:textoExtracto "2463 #LEAP incompatible con GAP3D. DETECCIÓN Durante la ejecución. CAUSA El comando #LEAP no es compatible con el control de gap en varios ejes. SOLUCIÓN No programar #LEAP o realizar el control de gap sobre una superficie."@es .

ns1:Fallo_2464 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 2464: Movimiento no permitido en selección de piercing con G92"@es ;
    ns1:identificador "2464" ;
    ns1:solucionaFallo ns1:Comando_MOVE ;
    ns1:textoExtracto "2464 Movimiento no permitido en selección de piercing con G92. Programar #MOVE. DETECCIÓN Durante la ejecución. CAUSA En la selección de piercing, se ha elegido la opción de repetir el programa en"@es .

ns1:Parametro_G92 a ns1:Parametro ;
    rdfs:label "G92" ;
    ns1:textoExtracto "selección de piercing con G92"@es ;
    ns1:valor "G92" .

ns1:Comando_LEAP a ns1:Parametro ;
    rdfs:label "#LEAP" ;
    ns1:textoExtracto "El comando #LEAP no es compatible con el control de gap en varios ejes"@es ;
    ns1:valor "#LEAP" .

ns1:Comando_MOVE a ns1:Parametro ;
    rdfs:label "#MOVE" ;
    ns1:textoExtracto "Programar #MOVE"@es ;
    ns1:valor "#MOVE" .

