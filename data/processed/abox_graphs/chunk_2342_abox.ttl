@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_2466 a ns1:Alarma ;
    rdfs:label "Se espera nombre de subrutina"@es ;
    ns1:identificador "2466" ;
    ns1:textoExtracto "2466 Se espera nombre de subrutina. DETECCIÓN Durante la ejecución."@es .

ns1:InterfazUsuario_SeleccionPiercing a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de selección de piercing"@es ;
    ns1:activaAlarma ns1:Alarma_2464 ;
    ns1:textoExtracto "opción de repetir el programa en el mismo punto que la ejecución anterior"@es .

ns1:Parametro_G92 a ns1:Parametro ;
    rdfs:label "Preselección G92"@es ;
    ns1:identificador "G92" ;
    ns1:monitoreaParametro ns1:Alarma_2464 ;
    ns1:textoExtracto "el programa realiza una preselección (G92) en los bloques iniciales"@es .

ns1:Parametro_RPT_N a ns1:Parametro ;
    rdfs:label "Etiqueta N en #RPT"@es ;
    ns1:identificador "N" ;
    ns1:monitoreaParametro ns1:Alarma_2465 ;
    ns1:textoExtracto "la etiqueta N y el número de repeticiones deben ser números enteros"@es .

ns1:Parametro_RPT_Repeticiones a ns1:Parametro ;
    rdfs:label "Número de repeticiones en #RPT"@es ;
    ns1:monitoreaParametro ns1:Alarma_2465 ;
    ns1:textoExtracto "el número de repeticiones deben ser números enteros"@es ;
    ns1:valor "integer" .

ns1:Sistema_ProgramacionPiercing a ns1:Sistema ;
    rdfs:label "Sistema de programación de piercing"@es ;
    ns1:activaAlarma ns1:Alarma_2464 ;
    ns1:textoExtracto "En la selección de piercing, se ha elegido la opción de repetir el programa en el mismo punto que la ejecución anterior"@es .

ns1:Alarma_2465 a ns1:Alarma ;
    rdfs:label "#RPT: la etiqueta N y el número de repeticiones deben ser números enteros"@es ;
    ns1:identificador "2465" ;
    ns1:textoExtracto "2465 #RPT: la etiqueta N y el número de repeticiones deben ser números enteros. DETECCIÓN Durante la ejecución. CAUSA En la sentencia #RPT se ha programado para la etiqueta N o para el número de repeticiones un valor no entero. SOLUCIÓN El valor de la etiqueta N y el número de repeticiones deben ser números enteros."@es .

ns1:Alarma_2464 a ns1:Alarma ;
    rdfs:label "Movimiento no permitido en selección de piercing con G92"@es ;
    ns1:identificador "2464" ;
    ns1:textoExtracto "2464 Movimiento no permitido en selección de piercing con G92. Programar #MOVE. DETECCIÓN Durante la ejecución. CAUSA En la selección de piercing, se ha elegido la opción de repetir el programa en el mismo punto que la ejecución anterior, y el programa realiza una preselección (G92) en los bloques iniciales. El programa tiene un bloque de movimiento anterior en #INITIALSUB o antes de la primera G1 del programa. SOLUCIÓN Realizar otra selección de piercing o sustituir el movimiento por un movimiento independiente (#MOVE)."@es .

