@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_2466 a ns1:Alarma ;
    rdfs:label "Alarma 2466: Nombre de subrutina esperado"@es ;
    ns1:identificador "2466" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_2466 ;
    ns1:textoExtracto "2466 Se espera nombre de subrutina. DETECCIÓN Durante la ejecución. CAUSA Se ha programado una subrutina local (%L) sin definir su nombre. SOLUCIÓN Definir el inicio de la subrutina local con \"%L nombre\"."@es .

ns1:Alarma_2467 a ns1:Alarma ;
    rdfs:label "Alarma 2467: Subrutina local duplicada"@es ;
    ns1:identificador "2467" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_2467 ;
    ns1:textoExtracto "2467 Subrutina local ya existente. DETECCIÓN Durante la ejecución. CAUSA Hay definidas más de una subrutina local (%L) con el mismo nombre. SOLUCIÓN En un programa no puede haber dos subrutinas locales con el mismo nombre."@es .

ns1:Alarma_2468 a ns1:Alarma ;
    rdfs:label "Alarma 2468: Programación COROT=FIX no permitida"@es ;
    ns1:identificador "2468" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_2468 ;
    ns1:textoExtracto "2468 Programación COROT=FIX no permitida en cinemáticas cabezal-mesa, TYPE=13..16. DETECCIÓN Durante la ejecución. CAUSA Se ha programado un RTCP sin giro del sistema de coordenadas para una cinemática cabezal+mesa (TYPE=13..16). SOLUCIÓN Este tipo de cinemática no admite esa programación. Programar el RTCP con giro del sistema de coordenadas o redefinir la cinemática como vectorial (TYPE 52)."@es .

ns1:Alarma_2469 a ns1:Alarma ;
    rdfs:label "Alarma 2469: Programación HEAD no permitida"@es ;
    ns1:identificador "2469" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_2469 ;
    ns1:textoExtracto "2469 Programación HEAD no permitida en cinemáticas sin cabezal."@es .

ns1:AccionProhibida_2466 a ns1:AccionProhibida ;
    rdfs:label "Programar subrutina local (%L) sin nombre"@es ;
    ns1:solucionaFallo ns1:AvisoSeguridad_2466 ;
    ns1:textoExtracto "Se ha programado una subrutina local (%L) sin definir su nombre."@es .

ns1:AccionProhibida_2467 a ns1:AccionProhibida ;
    rdfs:label "Duplicar nombres de subrutinas locales (%L)"@es ;
    ns1:solucionaFallo ns1:AvisoSeguridad_2467 ;
    ns1:textoExtracto "Hay definidas más de una subrutina local (%L) con el mismo nombre."@es .

ns1:AccionProhibida_2468 a ns1:AccionProhibida ;
    rdfs:label "Usar COROT=FIX en cinemáticas cabezal-mesa (TYPE=13..16)"@es ;
    ns1:solucionaFallo ns1:AvisoSeguridad_2468 ;
    ns1:textoExtracto "Se ha programado un RTCP sin giro del sistema de coordenadas para una cinemática cabezal+mesa (TYPE=13..16)."@es .

ns1:AccionProhibida_2469 a ns1:AccionProhibida ;
    rdfs:label "Usar programación HEAD en cinemáticas sin cabezal"@es ;
    ns1:textoExtracto "Programación HEAD no permitida en cinemáticas sin cabezal."@es .

ns1:AvisoSeguridad_2466 a ns1:AvisoSeguridad ;
    rdfs:label "Definición obligatoria de nombre en subrutinas locales (%L)"@es ;
    ns1:textoExtracto "Definir el inicio de la subrutina local con \"%L nombre\"."@es .

ns1:AvisoSeguridad_2467 a ns1:AvisoSeguridad ;
    rdfs:label "Unicidad de nombres en subrutinas locales (%L)"@es ;
    ns1:textoExtracto "En un programa no puede haber dos subrutinas locales con el mismo nombre."@es .

ns1:AvisoSeguridad_2468 a ns1:AvisoSeguridad ;
    rdfs:label "Requisitos de programación RTCP para cinemáticas cabezal-mesa"@es ;
    ns1:textoExtracto "Programar el RTCP con giro del sistema de coordenadas o redefinir la cinemática como vectorial (TYPE 52)."@es .

