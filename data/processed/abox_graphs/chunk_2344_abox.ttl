@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_2469 a ns1:Alarma ;
    rdfs:label "Alarma 2469: Programación HEAD no permitida"@es ;
    ns1:identificador "2469" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_2469 ;
    ns1:textoExtracto "2469 Programación HEAD no permitida en cinemáticas sin cabezal. DETECCIÓN Durante la ejecución. CAUSA Se ha programado un RTCP con la opción HEAD para una cinemática sin cabezal."@es .

ns1:Alarma_2470 a ns1:Alarma ;
    rdfs:label "Alarma 2470: Programación TABLE/COROT no permitida"@es ;
    ns1:identificador "2470" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_2470 ;
    ns1:textoExtracto "2470 Programación TABLE o COROT no permitida en cinemáticas sin mesa. DETECCIÓN Durante la ejecución."@es .

ns1:AccionProhibida_2469 a ns1:AccionProhibida ;
    rdfs:label "Programación HEAD en cinemática sin cabezal"@es ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_2469 ;
    ns1:textoExtracto "Programación HEAD no permitida en cinemáticas sin cabezal"@es .

ns1:AccionProhibida_2470 a ns1:AccionProhibida ;
    rdfs:label "Programación TABLE/COROT en cinemática sin mesa"@es ;
    ns1:textoExtracto "Programación TABLE o COROT no permitida en cinemáticas sin mesa"@es .

ns1:DiagnosticoFallo_2469 a ns1:DiagnosticoFallo ;
    rdfs:label "Revisión de programación RTCP con opción HEAD"@es ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación."@es .

