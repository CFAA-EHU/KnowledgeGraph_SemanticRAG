@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_2470 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2470: Programación TABLE/COROT no permitida" ;
    ns1:identificador "2470" ;
    ns1:mitigaRiesgo ns1:Sistema_CinematicaSinMesa ;
    ns1:textoExtracto "Programación TABLE o COROT no permitida en cinemáticas sin mesa. DETECCIÓN Durante la ejecución. CAUSA Se ha programado un RTCP con la opción TABLE o COROT para una cinemática sin mesa. SOLUCIÓN Revisar la programación." .

ns1:AvisoSeguridad_2471 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2471: Fichero de material/tabla obligatorio" ;
    ns1:documentadoEn ns1:Tabla_TechTable ;
    ns1:identificador "2471" ;
    ns1:textoExtracto "Es obligatorio programar el nombre del fichero de material y/o la tabla seleccionada. DETECCIÓN Durante la ejecución. CAUSA Se ha programado la sentencia #TECHTABLE sin indicar el fichero de material ni la tabla seleccionada. SOLUCIÓN Revisar la programación. Tanto el fichero de material como la tabla tecnológica son opcionales, pero hay que programar uno de ellos." .

ns1:AvisoSeguridad_2472 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2472: Fichero de material inactivo" ;
    ns1:identificador "2472" ;
    ns1:textoExtracto "No hay fichero de material activo. DETECCIÓN Durante la ejecución. CAUSA Se ha programado la sentencia #TECHTABLE sin indicar el fichero de material, y no hay ninguno activo. SOLUCIÓN Activar un fichero de material. La programación del fichero de material sólo es opcional cuando hay uno activo." .

ns1:AvisoSeguridad_2473 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2473: Número de set fuera de rango" ;
    ns1:identificador "2473" ;
    ns1:textoExtracto "Número de set fuera de rango. DETECCIÓN Durante la ejecución. CAUSA El número de set (grupo de parámetros) programado en la sentencia #TECHTABLE no es válido o no existe. SOLUCIÓN Revisar la programación. Comprobar que el grupo de parámetros programado existe en la tabla. El rango válido es 1..256." .

ns1:AvisoSeguridad_2474 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2474: Variable Piercing sin material válido" ;
    ns1:identificador "2474" ;
    ns1:monitoreaParametro ns1:Parametro_TTPIR ;
    ns1:textoExtracto "Variable inexistente sin un material activo que tenga tabla Piercing. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado leer una variable \"TTPIR.name\" pero no hay un fichero de material activo, o el fichero activo tiene tabla de Piercing. SOLUCIÓN Activar un fichero de material que tenga una tabla de Piercing." .

ns1:AvisoSeguridad_2475 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2475: Variable Cutting sin material válido" ;
    ns1:identificador "2475" ;
    ns1:monitoreaParametro ns1:Parametro_TTCUT ;
    ns1:textoExtracto "Variable inexistente sin un material activo que tenga tabla Cutting. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado leer una variable \"TTCUT.name\" pero no hay un fichero de material activo, o el fichero activo tiene tabla de Cutting." .

ns1:Sistema_CinematicaSinCabezal a ns1:Sistema ;
    rdfs:label "Cinemática sin cabezal" ;
    ns1:textoExtracto "cinemática sin cabezal" .

ns1:Parametro_TTCUT a ns1:Parametro ;
    rdfs:label "Variable TTCUT.name (tabla Cutting)" ;
    ns1:textoExtracto "variable \"TTCUT.name\"" ;
    ns1:valor "TTCUT.name" .

ns1:Parametro_TTPIR a ns1:Parametro ;
    rdfs:label "Variable TTPIR.name (tabla Piercing)" ;
    ns1:textoExtracto "variable \"TTPIR.name\"" ;
    ns1:valor "TTPIR.name" .

ns1:Sistema_CinematicaSinMesa a ns1:Sistema ;
    rdfs:label "Cinemática sin mesa" ;
    ns1:textoExtracto "cinemática sin mesa" .

ns1:Tabla_TechTable a ns1:Tabla ;
    rdfs:label "Tabla tecnológica (#TECHTABLE)" ;
    ns1:identificador "#TECHTABLE" ;
    ns1:textoExtracto "sentencia #TECHTABLE" .

