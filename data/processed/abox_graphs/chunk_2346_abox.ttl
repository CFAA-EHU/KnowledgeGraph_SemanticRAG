@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_2476 a ns1:AvisoSeguridad ;
    rdfs:label "Tabla inexistente en fichero de material activo"@es ;
    ns1:identificador "2476" ;
    ns1:textoExtracto "Tabla inexistente en el fichero de material activo. DETECCIÓN"@es .

ns1:Variable_TTCUT_name a ns1:Parametro ;
    rdfs:label "Variable TTCUT.name"@es ;
    ns1:identificador "TTCUT.name" ;
    ns1:monitoreaParametro ns1:Tabla_Cutting ;
    ns1:textoExtracto "variable \"TTCUT.name\""@es .

ns1:Error_2475 a ns1:AvisoSeguridad ;
    rdfs:label "Variable inexistente sin material activo con tabla Cutting"@es ;
    ns1:identificador "2475" ;
    ns1:textoExtracto "Variable inexistente sin un material activo que tenga tabla Cutting. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado leer una variable \"TTCUT.name\" pero no hay un fichero de material activo, o el fichero activo tiene tabla de Cutting. SOLUCIÓN Activar un fichero de material que tenga una tabla de Cutting."@es .

ns1:Tabla_Cutting a ns1:Tabla ;
    rdfs:label "Tabla Cutting"@es ;
    ns1:documentadoEn ns1:Error_2475 ;
    ns1:textoExtracto "tabla Cutting"@es .

