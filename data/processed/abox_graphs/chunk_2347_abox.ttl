@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_2476 a ns1:AvisoSeguridad ;
    rdfs:label "Tabla inexistente en el fichero de material activo"@es ;
    ns1:identificador "2476" ;
    ns1:solucionaFallo ns1:Solucion_2476 ;
    ns1:textoExtracto "Tabla inexistente en el fichero de material activo. DETECCIÓN Durante la ejecución. CAUSA Se ha programado una tabla tecnológica que no existe en el fichero de material activo. SOLUCIÓN Revisar la programación y qué tablas existen."@es .

ns1:Error_2477 a ns1:AvisoSeguridad ;
    rdfs:label "Nombre de tabla no permitido"@es ;
    ns1:identificador "2477" ;
    ns1:solucionaFallo ns1:Solucion_2477 ;
    ns1:textoExtracto "Nombre de tabla no permitido. DETECCIÓN Durante la ejecución. CAUSA La sentencia #TECHTABLE ha intentado activar las tablas de Piercing y Cutting. SOLUCIÓN La sentencia #TECHTABLE permite activar una tabla tecnológica genérica. Esta sentencia no permite cargar las tablas de Piercing y Cutting, las cuales se gestionan con las sentencias #PIERCING y #CUTTING."@es .

ns1:Error_2478 a ns1:AvisoSeguridad ;
    rdfs:label "Sentencia no permitida sin tabla PIERCING en el fichero de material activo"@es ;
    ns1:identificador "2478" ;
    ns1:textoExtracto "Sentencia no permitida sin tabla PIERCING en el fichero de material activo. DETECCIÓN Durante la ejecución."@es .

ns1:FicheroMaterialActivo a ns1:InterfazUsuario ;
    rdfs:label "Fichero de material activo"@es ;
    ns1:textoExtracto "fichero de material activo"@es ;
    ns1:tieneComponente ns1:TablaCutting .

ns1:Sentencia_CUTTING a ns1:Parametro ;
    rdfs:label "Sentencia #CUTTING"@es ;
    ns1:textoExtracto "las cuales se gestionan con las sentencias [...] #CUTTING"@es .

ns1:Sentencia_PIERCING a ns1:Parametro ;
    rdfs:label "Sentencia #PIERCING"@es ;
    ns1:textoExtracto "las cuales se gestionan con las sentencias #PIERCING"@es .

ns1:Sentencia_TECHTABLE a ns1:Parametro ;
    rdfs:label "Sentencia #TECHTABLE"@es ;
    ns1:textoExtracto "La sentencia #TECHTABLE ha intentado activar las tablas de Piercing y Cutting. [...] Esta sentencia no permite cargar las tablas de Piercing y Cutting"@es .

ns1:TablaPiercing a ns1:Tabla ;
    rdfs:label "Tabla de Piercing"@es ;
    ns1:textoExtracto "tablas de Piercing"@es .

ns1:TablaTecnologica a ns1:Tabla ;
    rdfs:label "Tabla tecnológica"@es ;
    ns1:textoExtracto "tabla tecnológica"@es .

ns1:Solucion_2476 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación de tablas tecnológicas"@es ;
    ns1:textoExtracto "Revisar la programación y qué tablas existen."@es .

ns1:Solucion_2477 a ns1:TareaMantenimiento ;
    rdfs:label "Uso correcto de sentencias #PIERCING y #CUTTING"@es ;
    ns1:textoExtracto "La sentencia #TECHTABLE permite activar una tabla tecnológica genérica. Esta sentencia no permite cargar las tablas de Piercing y Cutting, las cuales se gestionan con las sentencias #PIERCING y #CUTTING."@es .

ns1:TablaCutting a ns1:Tabla ;
    rdfs:label "Tabla de Cutting"@es ;
    ns1:textoExtracto "tabla de Cutting"@es .

