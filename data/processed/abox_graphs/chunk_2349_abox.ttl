@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_2481 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2481: Valor de TIP no válido"@es ;
    ns1:identificador "2481" ;
    ns1:mitigaRiesgo ns1:Sentencia_KINID ;
    ns1:solucionaFallo ns1:Parametro_TIP ;
    ns1:textoExtracto "2481 Valor de TIP no válido. DETECCIÓN Durante la ejecución. CAUSA Se ha programado la sentencia #KINID con un valor de TIP no válido. SOLUCIÓN Revisar la programación. El rango de valores admitido para TIP es 0/1."@es .

ns1:Error_2482 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2482: Número de origen"@es ;
    ns1:identificador "2482" ;
    ns1:textoExtracto "2482 Número de origen"@es .

ns1:Parametro_TIP a ns1:Parametro ;
    rdfs:label "Parámetro TIP"@es ;
    ns1:textoExtracto "valor de TIP" ;
    ns1:valor "0/1" .

ns1:Sentencia_KINID a ns1:Componente ;
    rdfs:label "Sentencia #KINID"@es ;
    ns1:textoExtracto "sentencia #KINID con un valor de TIP no válido"@es .

