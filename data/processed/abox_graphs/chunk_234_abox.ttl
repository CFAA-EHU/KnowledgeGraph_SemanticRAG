@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaFuncionesG a ns1:Tabla ;
    rdfs:label "Tabla de funciones G (G211-G266, G500-G599)" ;
    ns1:documentadoEn ns1:Manual ;
    ns1:textoExtracto "TECHNOLOGICAL FUNCTIONS. - LIST OF AUXILIARY (MISCELLANEOUS) –M- FUNCTIONS. - LIST OF –G- FUNCTIONS." ;
    ns1:tieneComponente ns1:G211,
        ns1:G212,
        ns1:G261,
        ns1:G262,
        ns1:G263,
        ns1:G264,
        ns1:G265,
        ns1:G266,
        ns1:G500_G599 .

ns1:G211 a ns1:ModoOperacion ;
    rdfs:label "G211" ;
    ns1:identificador "G211" ;
    ns1:textoExtracto "(·M· model). Inside thread milling cycle." .

ns1:G212 a ns1:ModoOperacion ;
    rdfs:label "G212" ;
    ns1:identificador "G212" ;
    ns1:textoExtracto "(·M· model). Outside thread milling cycle." .

ns1:G261 a ns1:ModoOperacion ;
    rdfs:label "G261" ;
    ns1:identificador "G261" ;
    ns1:textoExtracto "Arc center in absolute coordinates (modal)." .

ns1:G262 a ns1:ModoOperacion ;
    rdfs:label "G262" ;
    ns1:identificador "G262" ;
    ns1:textoExtracto "Arc center referred to starting point." .

ns1:G263 a ns1:ModoOperacion ;
    rdfs:label "G263" ;
    ns1:identificador "G263" ;
    ns1:textoExtracto "Arc radius programming." .

ns1:G264 a ns1:ModoOperacion ;
    rdfs:label "G264" ;
    ns1:identificador "G264" ;
    ns1:textoExtracto "Cancel arc center correction." .

ns1:G265 a ns1:ModoOperacion ;
    rdfs:label "G265" ;
    ns1:identificador "G265" ;
    ns1:textoExtracto "Activate arc center correction." .

ns1:G266 a ns1:ModoOperacion ;
    rdfs:label "G266" ;
    ns1:identificador "G266" ;
    ns1:textoExtracto "Set feedrate percentage at 100%" .

ns1:G500_G599 a ns1:ModoOperacion ;
    rdfs:label "G500-G599" ;
    ns1:identificador "G500-G599" ;
    ns1:textoExtracto "Generic user subroutines." .

