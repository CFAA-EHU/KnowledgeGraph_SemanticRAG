@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_2481 a ns1:Alarma ;
    rdfs:label "Alarma 2481: Valor TIP no válido en #KINID" ;
    ns1:identificador "2481" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_ProgramacionTIPInvalido ;
    ns1:textoExtracto "CAUSA Se ha programado la sentencia #KINID con un valor de TIP no válido. SOLUCIÓN Revisar la programación. El rango de valores admitido para TIP es 0/1." .

ns1:Alarma_2482 a ns1:Alarma ;
    rdfs:label "Alarma 2482: Número de origen no válido en #KINORG" ;
    ns1:identificador "2482" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_OrigenInvalidoKINORG ;
    ns1:textoExtracto "CAUSA Se ha programado la sentencia #KINORG con un origen no válido. SOLUCIÓN Revisar la programación. El rango de valores admitido para el origen es 1..99." .

ns1:Alarma_2483 a ns1:Alarma ;
    rdfs:label "Alarma 2483: Origen activo no admitido en #KINORG" ;
    ns1:identificador "2483" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_OrigenActivoKINORG ;
    ns1:textoExtracto "CAUSA En la sentencia #KINORG no se permite programar el origen activo. SOLUCIÓN Revisar la programación. Programar un origen distinto del activo. El rango de valores admitido para el origen es 1..99." .

ns1:Alarma_2484 a ns1:Alarma ;
    rdfs:label "Alarma 2484: Movimiento rotativo no permitido con compensación de radio activa" ;
    ns1:identificador "2484" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_MovimientoRotativoG41G42 ;
    ns1:textoExtracto "Movimiento de eje rotativo no permitido con KIN ID TIP activo y compensación de radio activa (G41/G42)." .

ns1:Parametro_OrigenKINORG a ns1:Parametro ;
    rdfs:label "Parámetro de origen en sentencia #KINORG" ;
    ns1:textoExtracto "origen" ;
    ns1:valor "1..99" .

ns1:Parametro_TIP a ns1:Parametro ;
    rdfs:label "Parámetro TIP en sentencia #KINID" ;
    ns1:textoExtracto "valor de TIP" ;
    ns1:valor "0/1" .

ns1:Sistema_CompensacionRadio a ns1:Sistema ;
    rdfs:label "Sistema de compensación de radio (G41/G42)" ;
    ns1:identificador "G41/G42" ;
    ns1:textoExtracto "compensación de radio activa (G41/G42)" .

ns1:AccionProhibida_MovimientoRotativoG41G42 a ns1:AccionProhibida ;
    rdfs:label "Movimiento de eje rotativo con compensación de radio activa (G41/G42) y KIN ID TIP activo" ;
    ns1:textoExtracto "Movimiento de eje rotativo no permitido con KIN ID TIP activo y compensación de radio activa (G41/G42)." .

ns1:AccionProhibida_OrigenActivoKINORG a ns1:AccionProhibida ;
    rdfs:label "Programación de origen activo en #KINORG" ;
    ns1:textoExtracto "En la sentencia #KINORG no se permite programar el origen activo." .

ns1:AccionProhibida_OrigenInvalidoKINORG a ns1:AccionProhibida ;
    rdfs:label "Programación de origen fuera de rango (1..99) en #KINORG" ;
    ns1:textoExtracto "Se ha programado la sentencia #KINORG con un origen no válido. El rango de valores admitido para el origen es 1..99." .

ns1:AccionProhibida_ProgramacionTIPInvalido a ns1:AccionProhibida ;
    rdfs:label "Programación de TIP con valor fuera de rango (0/1) en #KINID" ;
    ns1:textoExtracto "Se ha programado la sentencia #KINID con un valor de TIP no válido. El rango de valores admitido para TIP es 0/1." .

