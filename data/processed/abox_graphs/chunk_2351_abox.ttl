@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_2485 a ns1:AvisoSeguridad ;
    rdfs:label "Restricción de programación con KIN ID TIP activo"@es ;
    ns1:identificador "2485" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_2485 ;
    ns1:textoExtracto "No se permite programar en el mismo bloque eje lineal y rotativo, con KIN ID TIP activo. [...] SOLUCIÓN Mover el eje rotativo y el eje lineal individualmente."@es .

ns1:AvisoSeguridad_2486 a ns1:AvisoSeguridad ;
    rdfs:label "Restricción de #RENAME en modo eje C"@es ;
    ns1:identificador "2486" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_2486 ;
    ns1:textoExtracto "No se admite #RENAME del cabezal en modo eje C."@es .

ns1:ComponenteMecanico_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal"@es ;
    ns1:textoExtracto "cabezal"@es .

ns1:ComponenteMecanico_EjeLineal a ns1:ComponenteMecanico ;
    rdfs:label "Eje lineal"@es ;
    ns1:textoExtracto "eje lineal"@es .

ns1:ComponenteMecanico_EjeRotativo a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo"@es ;
    ns1:textoExtracto "eje rotativo que afecta a la posición de la herramienta"@es .

ns1:ComponenteMecanico_Herramienta a ns1:ComponenteMecanico ;
    rdfs:label "Herramienta"@es ;
    ns1:textoExtracto "posición de la herramienta"@es .

ns1:DiagnosticoFallo_CompensacionRadio a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo por compensación de radio activa (G41/G42) al mover eje rotativo"@es ;
    ns1:solucionaFallo ns1:AccionProhibida_CompensacionRadio ;
    ns1:textoExtracto "Se ha intentado mover un eje rotativo que afecta a la posición de la herramienta, y está activo #KINID[TIP] y la compensación de radio (G41/G42). SOLUCIÓN Desactivar la compensación de radio para mover el eje rotativo."@es .

ns1:ModoOperacion_EjeC a ns1:ModoOperacion ;
    rdfs:label "Modo eje C"@es ;
    ns1:identificador "eje_C" ;
    ns1:textoExtracto "modo eje C"@es .

ns1:ModoOperacion_KINID_TIP a ns1:ModoOperacion ;
    rdfs:label "Modo KIN ID TIP"@es ;
    ns1:identificador "KINID[TIP]" ;
    ns1:textoExtracto "#KINID[TIP]"@es .

ns1:Parametro_CompensacionRadio_G41 a ns1:Parametro ;
    rdfs:label "Compensación de radio (G41)"@es ;
    ns1:identificador "G41" ;
    ns1:textoExtracto "compensación de radio (G41)"@es .

ns1:Parametro_CompensacionRadio_G42 a ns1:Parametro ;
    rdfs:label "Compensación de radio (G42)"@es ;
    ns1:identificador "G42" ;
    ns1:textoExtracto "compensación de radio (G42)"@es .

ns1:AccionProhibida_2485 a ns1:AccionProhibida ;
    rdfs:label "Programación simultánea de eje lineal y rotativo con KIN ID TIP"@es ;
    ns1:textoExtracto "programar en el mismo bloque eje lineal y rotativo, con KIN ID TIP activo"@es .

ns1:AccionProhibida_2486 a ns1:AccionProhibida ;
    rdfs:label "Renombrado del cabezal en modo eje C"@es ;
    ns1:textoExtracto "#RENAME del cabezal en modo eje C"@es .

ns1:AccionProhibida_CompensacionRadio a ns1:AccionProhibida ;
    rdfs:label "Movimiento de eje rotativo con compensación de radio (G41/G42) activa"@es ;
    ns1:textoExtracto "mover un eje rotativo [...] con la compensación de radio (G41/G42) activa"@es .

