@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_2486 a ns1:Alarma ;
    rdfs:label "Alarma 2486: Renombrado de cabezal en modo eje C no admitido"@es ;
    ns1:identificador "2486" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_RenombrarEjeC ;
    ns1:textoExtracto "No se admite #RENAME del cabezal en modo eje C. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado renombrar el cabezal que está trabajando como eje C. SOLUCIÓN No se permite renombrar el eje activo como eje C."@es .

ns1:Alarma_2487 a ns1:Alarma ;
    rdfs:label "Alarma 2487: Cinemática no válida para #FACE/#CYL"@es ;
    ns1:identificador "2487" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_CinematicaInvalidaFACE_CYL ;
    ns1:textoExtracto "El CNC ha intentado activar #FACE/#CYL con un tipo de cinemática que no se corresponde. DETECCIÓN Durante la ejecución. CAUSA La cinemática programada en las sentencias #FACE/#CYL no es del tipo adecuado. SOLUCIÓN Activar #FACE/#CYL sin cinemática o con una cinemática del tipo 41/42/43."@es .

ns1:Alarma_2488 a ns1:Alarma ;
    rdfs:label "Alarma 2488: Falta carga de GAPTABLE antes de GAPCTRL/LEAP"@es ;
    ns1:identificador "2488" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_OmisionGAPTABLE ;
    ns1:textoExtracto "Programar #LOAD GAPTABLE antes de #GAPCTRL ON o #LEAP. DETECCIÓN Durante la ejecución. CAUSA Por parámetro máquina"@es .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "CNC (Control Numérico Computarizado)"@es ;
    ns1:textoExtracto "El CNC ha intentado activar #FACE/#CYL"@es ;
    ns1:tieneComponente ns1:Componente_Cabezal .

ns1:ModoOperacion_EjeC a ns1:ModoOperacion ;
    rdfs:label "Modo eje C"@es ;
    ns1:textoExtracto "modo eje C"@es .

ns1:Parametro_CinematicaFACE_CYL a ns1:Parametro ;
    rdfs:label "Parámetro de cinemática para #FACE/#CYL"@es ;
    ns1:textoExtracto "cinemática del tipo 41/42/43"@es ;
    ns1:valor "41/42/43" .

ns1:Parametro_GAPTABLE a ns1:Parametro ;
    rdfs:label "Parámetro GAPTABLE"@es ;
    ns1:identificador "#LOAD GAPTABLE" ;
    ns1:textoExtracto "#LOAD GAPTABLE"@es .

ns1:AccionProhibida_CinematicaInvalidaFACE_CYL a ns1:AccionProhibida ;
    rdfs:label "Uso de cinemática no válida en #FACE/#CYL"@es ;
    ns1:textoExtracto "La cinemática programada en las sentencias #FACE/#CYL no es del tipo adecuado."@es .

ns1:AccionProhibida_OmisionGAPTABLE a ns1:AccionProhibida ;
    rdfs:label "Omisión de #LOAD GAPTABLE antes de #GAPCTRL/LEAP"@es ;
    ns1:textoExtracto "Programar #LOAD GAPTABLE antes de #GAPCTRL ON o #LEAP."@es .

ns1:AccionProhibida_RenombrarEjeC a ns1:AccionProhibida ;
    rdfs:label "Renombrar cabezal activo como eje C"@es ;
    ns1:textoExtracto "No se permite renombrar el eje activo como eje C."@es .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de máquina"@es ;
    ns1:textoExtracto "cabezal que está trabajando como eje C"@es .

