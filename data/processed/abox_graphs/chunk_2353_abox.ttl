@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_CAXSUB a ns1:Parametro ;
    rdfs:label "Parámetro CAXSUB" ;
    ns1:identificador "CAXSUB" ;
    ns1:monitoreaParametro ns1:DiagnosticoFallo_2492 ;
    ns1:textoExtracto "parámetro máquina CAXSUB" .

ns1:Parametro_GAPTABLE a ns1:Parametro ;
    rdfs:label "Parámetro GAPTABLE" ;
    ns1:identificador "GAPTABLE" ;
    ns1:monitoreaParametro ns1:DiagnosticoFallo_2488 ;
    ns1:textoExtracto "tabla de calibración del gap mediante el comando #LOAD GAPTABLE" .

ns1:Parametro_KINID_TIP a ns1:Parametro ;
    rdfs:label "Parámetro KINID TIP" ;
    ns1:identificador "KINID_TIP" ;
    ns1:monitoreaParametro ns1:DiagnosticoFallo_2489 ;
    ns1:textoExtracto "KINID TIP activo" .

ns1:Tarea_Programacion_CAX a ns1:TareaMantenimiento ;
    rdfs:label "Corregir programación en subrutina #CAX" ;
    ns1:requiereMantenimiento ns1:DiagnosticoFallo_2491 ;
    ns1:textoExtracto "Dentro de la subrutina, programar #CAX sin parámetros" .

ns1:Tarea_Programacion_GAPTABLE a ns1:TareaMantenimiento ;
    rdfs:label "Cargar tabla de calibración de gap" ;
    ns1:requiereMantenimiento ns1:DiagnosticoFallo_2488 ;
    ns1:textoExtracto "Activar una tabla de calibración del gap mediante el comando #LOAD GAPTABLE" .

ns1:Tarea_Programacion_RTCP a ns1:TareaMantenimiento ;
    rdfs:label "Revisar secuencia RTCP/CS" ;
    ns1:requiereMantenimiento ns1:DiagnosticoFallo_2490 ;
    ns1:textoExtracto "Programar la secuencia correcta: #RTCPON, #CS/ACSON, #CS/ACSOFF, #RTCPOFF" .

ns1:Alarma_2488 a ns1:Alarma ;
    rdfs:label "Alarma 2488: Calibración de gap no activada" ;
    ns1:identificador "2488" ;
    ns1:textoExtracto "Activar #FACE/#CYL sin cinemática o con una cinemática del tipo 41/42/43. [...] SOLUCIÓN Activar una tabla de calibración del gap mediante el comando #LOAD GAPTABLE." .

ns1:Alarma_2489 a ns1:Alarma ;
    rdfs:label "Alarma 2489: RTCP no permitido en inspección con KINID TIP" ;
    ns1:identificador "2489" ;
    ns1:textoExtracto "No se permite programar #RTCP en INSPECCIÓN, con KINID TIP activo. [...] SOLUCIÓN Mantener en el sistema #KIN ID [TIP] o #RTCP durante la inspección de herramienta." .

ns1:Alarma_2490 a ns1:Alarma ;
    rdfs:label "Alarma 2490: Secuencia incorrecta de RTCP/CS" ;
    ns1:identificador "2490" ;
    ns1:textoExtracto "#RTCP ON/OFF: Programación no permitida con CS/ACS activo. [...] SOLUCIÓN Revisar la programación. Programar la secuencia correcta." .

ns1:Alarma_2491 a ns1:Alarma ;
    rdfs:label "Alarma 2491: Programación inválida en subrutina #CAX" ;
    ns1:identificador "2491" ;
    ns1:textoExtracto "Programación no permitida dentro de la subrutina asociada a #CAX. [...] SOLUCIÓN Revisar la programación. Dentro de la subrutina, programar #CAX sin parámetros." .

ns1:Alarma_2492 a ns1:Alarma ;
    rdfs:label "Alarma 2492: Comodín fuera de subrutina #CAX" ;
    ns1:identificador "2492" ;
    ns1:textoExtracto "Comodín no permitido fuera de la subrutina asociada a #CAX. [...] SOLUCIÓN Se ha programado el comodín @S o @C fuera de la subrutina asociada a la sentencia #CAX (parámetro máquina CAXSUB)." .

ns1:DiagnosticoFallo_2489 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 2489: Conflicto RTCP/KINID TIP en inspección" ;
    ns1:solucionaFallo ns1:Alarma_2489 ;
    ns1:textoExtracto "CAUSA Durante la inspección de herramienta, se ha intenta rehacer el sistema de coordenadas en un orden distinto en el que ha activado." .

ns1:DiagnosticoFallo_2490 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 2490: Secuencia RTCP/CS incorrecta" ;
    ns1:solucionaFallo ns1:Alarma_2490 ;
    ns1:textoExtracto "CAUSA La secuencia de activación y desactivación del RTCP y CS/ACS, en las cinemáticas de mesas sin giro del sistema de coordenadas, es fija; #RTCPON, #CS/ACSON, #CS/ACSOFF, #RTCPOFF." .

ns1:DiagnosticoFallo_2491 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 2491: Parámetros en subrutina #CAX" ;
    ns1:solucionaFallo ns1:Alarma_2491 ;
    ns1:textoExtracto "CAUSA Se ha programado la sentencia #CAX con parámetros de llamada, dentro de la subrutina asociada a #CAX." .

ns1:DiagnosticoFallo_2492 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 2492: Comodín @S/@C fuera de subrutina #CAX" ;
    ns1:solucionaFallo ns1:Alarma_2492 ;
    ns1:textoExtracto "CAUSA Se ha programado el comodín @S o @C fuera de la subrutina asociada a la sentencia #CAX (parámetro máquina CAXSUB)." .

ns1:DiagnosticoFallo_2488 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 2488: Tabla de calibración de gap no cargada" ;
    ns1:solucionaFallo ns1:Alarma_2488 ;
    ns1:textoExtracto "CAUSA Por parámetro máquina se ha definido una calibración no lineal de gap. Se ha intentado usar la sonda del gap (#GAPCTRL ON o #LEAP) sin activar dicha tabla." .

