@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error2492 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2492: Comodín no permitido fuera de subrutina #CAX" ;
    ns1:monitoreaParametro ns1:ParametroCAXSUB ;
    ns1:textoExtracto "2492 Comodín no permitido fuera de la subrutina asociada a #CAX. DETECCIÓN Durante la ejecución. CAUSA Se ha programado el comodín @S o @C fuera de la subrutina asociada a la sentencia #CAX (parámetro máquina CAXSUB). SOLUCIÓN Revisar la programación. No se permite el uso de estos comodines fuera de la subrutina asociada a #CAX." .

ns1:Error2493 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2493: Falta programación del origen del eje C en #FACECYL" ;
    ns1:monitoreaParametro ns1:ParametroEjeC ;
    ns1:textoExtracto "2493 #FACE/CYL: se espera \"Q\", programación del origen del eje C, en grados. DETECCIÓN Durante la ejecución. CAUSA No se ha programado el origen del eje C en la instrucción #FACECYL. SOLUCIÓN Revisar la programación." .

ns1:InstruccionCAX a ns1:Parametro ;
    rdfs:label "Sentencia #CAX" ;
    ns1:identificador "#CAX" ;
    ns1:textoExtracto "sentencia #CAX" .

ns1:InstruccionDMC a ns1:Parametro ;
    rdfs:label "Instrucción #DMC ON" ;
    ns1:identificador "#DMC" ;
    ns1:textoExtracto "#DMC ON [<PWRSP> <,OVRMIN> <,OVRMAX> <,FZMIN>" .

ns1:InstruccionFACECYL a ns1:Parametro ;
    rdfs:label "Instrucción #FACECYL" ;
    ns1:identificador "#FACECYL" ;
    ns1:textoExtracto "#FACECYL" .

ns1:ParametroFZMIN a ns1:Parametro ;
    rdfs:label "Parámetro FZMIN" ;
    ns1:identificador "FZMIN" ;
    ns1:textoExtracto "FZMIN" .

ns1:ParametroOVRMAX a ns1:Parametro ;
    rdfs:label "Parámetro OVRMAX" ;
    ns1:identificador "OVRMAX" ;
    ns1:textoExtracto "OVRMAX" .

ns1:ParametroOVRMIN a ns1:Parametro ;
    rdfs:label "Parámetro OVRMIN" ;
    ns1:identificador "OVRMIN" ;
    ns1:textoExtracto "OVRMIN" .

ns1:ParametroPWRSP a ns1:Parametro ;
    rdfs:label "Parámetro PWRSP" ;
    ns1:identificador "PWRSP" ;
    ns1:textoExtracto "PWRSP" .

ns1:ParametroCAXSUB a ns1:Parametro ;
    rdfs:label "Parámetro máquina CAXSUB" ;
    ns1:identificador "CAXSUB" ;
    ns1:textoExtracto "parámetro máquina CAXSUB" .

ns1:ParametroEjeC a ns1:Parametro ;
    rdfs:label "Origen del eje C (grados)" ;
    ns1:identificador "EjeC_Origen" ;
    ns1:textoExtracto "programación del origen del eje C, en grados" .

