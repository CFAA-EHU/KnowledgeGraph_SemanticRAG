@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_2500 a ns1:DiagnosticoFallo ;
    rdfs:label "Movimiento de eje rotativo no permitido con RTCP STATIC activo y compensación de radio activa (G41/G42)"@es ;
    ns1:identificador "2500" ;
    ns1:solucionaFallo ns1:Parametro_CompensacionRadio ;
    ns1:textoExtracto "2500 Movimiento de eje rotativo no permitido con RTCP STATIC activo y compensación de radio activa (G41/G42). DETECCIÓN Durante la ejecución. CAUSA Se ha intentado mover un eje rotativo de la cinemática, con RTCP STATIC y compensación de radio activa. SOLUCIÓN Desactivar la compensación de radio para mover el eje rotativo."@es .

ns1:Fallo_2501 a ns1:DiagnosticoFallo ;
    rdfs:label "No se permite programar en el mismo bloque eje lineal y rotativo, con RTCP STATIC activo"@es ;
    ns1:identificador "2501" ;
    ns1:solucionaFallo ns1:Componente_EjeLineal,
        ns1:Componente_EjeRotativo ;
    ns1:textoExtracto "2501 No se permite programar en el mismo bloque eje lineal y rotativo, con RTCP STATIC activo. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado mover un eje lineal junto a un eje rotativo de la cinemática, con RTCP STATIC activo. SOLUCIÓN Mover el eje rotativo y el eje lineal individualmente."@es .

ns1:Componente_EjeLineal a ns1:ComponenteMecanico ;
    rdfs:label "Eje lineal de la cinemática"@es ;
    ns1:textoExtracto "eje lineal de la cinemática"@es .

ns1:Componente_EjeRotativo a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo de la cinemática"@es ;
    ns1:controla ns1:Sistema_RTCP ;
    ns1:textoExtracto "eje rotativo de la cinemática"@es .

ns1:Parametro_CompensacionRadio a ns1:Parametro ;
    rdfs:label "Compensación de radio (G41/G42)"@es ;
    ns1:monitoreaParametro ns1:Sistema_RTCP ;
    ns1:textoExtracto "compensación de radio activa (G41/G42)"@es .

ns1:Sistema_RTCP a ns1:Sistema ;
    rdfs:label "RTCP (Rotary Tool Center Point)"@es ;
    ns1:textoExtracto "RTCP STATIC activo y compensación de radio activa (G41/G42)"@es .

