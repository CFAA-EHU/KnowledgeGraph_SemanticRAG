@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_2501 a ns1:Alarma ;
    rdfs:label "Alarma 2501: Movimiento de eje lineal/rotativo no permitido con RTCP STATIC"@es ;
    ns1:activaAlarma ns1:Componente_EjeLineal,
        ns1:Componente_EjeRotativo ;
    ns1:identificador "2501" ;
    ns1:textoExtracto "CAUSA Se ha intentado mover un eje lineal junto a un eje rotativo de la cinemática, con RTCP STATIC activo. SOLUCIÓN Mover el eje rotativo y el eje lineal individualmente."@es .

ns1:Alarma_2502 a ns1:Alarma ;
    rdfs:label "Alarma 2502: Movimiento de eje rotativo no permitido en inspección con RTCP STATIC"@es ;
    ns1:activaAlarma ns1:Componente_EjeRotativo ;
    ns1:identificador "2502" ;
    ns1:mitigaRiesgo ns1:Herramienta_Inspeccion ;
    ns1:textoExtracto "CAUSA Durante la inspección de herramienta, se ha intentado mover un eje rotativo de la cinemática RTCP STATIC activo. SOLUCIÓN Desactivar la funcionalidad de RTCP STATIC para poder mover el eje rotativo."@es .

ns1:Alarma_2503 a ns1:Alarma ;
    rdfs:label "Alarma 2503: Radio programado incorrectamente en G36/37/38/39"@es ;
    ns1:activaAlarma ns1:Parametro_Radio_G36_39 ;
    ns1:identificador "2503" ;
    ns1:textoExtracto "CAUSA Se ha programado incorrectamente el radio del redondeo (G36), chaflán (G39) o entrada/salida tangencial (G37/G38). SOLUCIÓN Revisar la programación. Programar el radio o chaflán con el comando \"I\"."@es .

ns1:Alarma_2504 a ns1:Alarma ;
    rdfs:label "Alarma 2504: Falta programación del segundo punto en G107"@es ;
    ns1:identificador "2504" ;
    ns1:textoExtracto "G107: Falta programar el segundo punto (XYZ)."@es .

ns1:Componente_EjeLineal a ns1:ComponenteMecanico ;
    rdfs:label "Eje lineal de la cinemática"@es ;
    ns1:controla ns1:Sistema_RTCP ;
    ns1:textoExtracto "eje lineal"@es .

ns1:Parametro_Radio_G36_39 a ns1:Parametro ;
    rdfs:label "Parámetro de radio para G36/G37/G38/G39"@es ;
    ns1:textoExtracto "radio del redondeo (G36), chaflán (G39) o entrada/salida tangencial (G37/G38)"@es ;
    ns1:valor "I" .

ns1:Componente_EjeRotativo a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo de la cinemática"@es ;
    ns1:controla ns1:Sistema_RTCP ;
    ns1:requiereMantenimiento ns1:Herramienta_Inspeccion ;
    ns1:textoExtracto "eje rotativo de la cinemática"@es .

ns1:Herramienta_Inspeccion a ns1:Herramienta ;
    rdfs:label "Herramienta de inspección"@es ;
    ns1:textoExtracto "inspección de herramienta"@es .

ns1:Sistema_RTCP a ns1:Sistema ;
    rdfs:label "Sistema RTCP (Rotary Tool Center Point)"@es ;
    ns1:identificador "RTCP" ;
    ns1:textoExtracto "RTCP STATIC activo"@es .

