@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_G106 a ns1:Parametro ;
    rdfs:label "Comando G106 (incompatibilidad con G107)"@es ;
    ns1:textoExtracto "G107 incompatible con G106 y #SPLINE ON."@es .

ns1:Parametro_G107 a ns1:Parametro ;
    rdfs:label "Comando G107 (programación de radio/chaflán)"@es ;
    ns1:monitoreaParametro ns1:Alarma_2504,
        ns1:Alarma_2505,
        ns1:Alarma_2506,
        ns1:Alarma_2507 ;
    ns1:textoExtracto "Programar el radio o chaflán con el comando \"I\"."@es .

ns1:Parametro_SPLINE a ns1:Parametro ;
    rdfs:label "Parámetro #SPLINE (incompatibilidad con G107)"@es ;
    ns1:textoExtracto "No es posible programar splines con G107 activa."@es .

ns1:AccionProhibida_G107_ConG106_Spline a ns1:AccionProhibida ;
    rdfs:label "Activar G107 con G106 activa o #SPLINE ON"@es ;
    ns1:textoExtracto "No es posible programar splines con G107 activa. Tampoco es posible programar G107 sin desactivar previamente G106 mediante una G0, G1."@es .

ns1:AccionProhibida_G107_ConRQ_XZQ a ns1:AccionProhibida ;
    rdfs:label "Usar coordenadas polares RQ o cartesianas/ángulo (X..ZQ) en G107"@es ;
    ns1:textoExtracto "Coordenadas polares RQ o coordenada cartesiana/ángulo (X..ZQ) no permitidas."@es .

ns1:AccionProhibida_G107_SinPuntoIJK a ns1:AccionProhibida ;
    rdfs:label "Programar G107 sin definir coordenadas IJK del primer punto"@es ;
    ns1:textoExtracto "Falta programar una o varias de las coordenadas IJK para definir el primer punto de G107."@es .

ns1:AccionProhibida_G107_SinPuntoXYZ a ns1:AccionProhibida ;
    rdfs:label "Programar G107 sin definir coordenadas XYZ del segundo punto"@es ;
    ns1:textoExtracto "Falta programar una o varias de las coordenadas XYZ para definir el segundo punto de G107."@es .

ns1:Alarma_2504 a ns1:Alarma ;
    rdfs:label "Alarma 2504: Falta programar el segundo punto (XYZ)"@es ;
    ns1:identificador "2504" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_G107_SinPuntoXYZ ;
    ns1:textoExtracto "2504 G107: Falta programar el segundo punto (XYZ). DETECCIÓN Durante la ejecución. CAUSA Falta programar una o varias de las coordenadas XYZ para definir el segundo punto de G107. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_2505 a ns1:Alarma ;
    rdfs:label "Alarma 2505: Falta programar el primer punto (IJK)"@es ;
    ns1:identificador "2505" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_G107_SinPuntoIJK ;
    ns1:textoExtracto "2505 G107: Falta programar el primer punto (IJK). DETECCIÓN Durante la ejecución. CAUSA Falta programar una o varias de las coordenadas IJK para definir el primer punto de G107. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_2506 a ns1:Alarma ;
    rdfs:label "Alarma 2506: G107 incompatible con G106 y #SPLINE ON"@es ;
    ns1:identificador "2506" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_G107_ConG106_Spline ;
    ns1:textoExtracto "2506 G107 incompatible con G106 y #SPLINE ON. DETECCIÓN Durante la ejecución. CAUSA No es posible programar splines con G107 activa. Tampoco es posible programar G107 sin desactivar previamente G106 mediante una G0, G1. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_2507 a ns1:Alarma ;
    rdfs:label "Alarma 2507: Coordenadas polares RQ o cartesiana/ángulo (X..ZQ) no permitidas"@es ;
    ns1:identificador "2507" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_G107_ConRQ_XZQ ;
    ns1:textoExtracto "2507 G107: Coordenadas polares RQ o coordenada cartesiana/ángulo (X..ZQ) no permitidas. DETECCIÓN Durante la ejecución."@es .

