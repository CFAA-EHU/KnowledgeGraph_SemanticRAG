@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_CicloFijoTalonadrado_42 a ns1:ModoOperacion ;
    rdfs:label "Fixed cycle: drilling (G81)"@en ;
    ns1:documentadoEn ns1:BloqueCicloFijo_42 ;
    ns1:identificador "G81" ;
    ns1:textoExtracto "G81"@en .

ns1:ModoOperacion_GiroHusillo_42 a ns1:ModoOperacion ;
    rdfs:label "Spindle rotation (M4)"@en ;
    ns1:documentadoEn ns1:BloqueCicloFijo_42 ;
    ns1:identificador "M4" ;
    ns1:textoExtracto "M4"@en .

ns1:ModoOperacion_InterpolacionLineal_42 a ns1:ModoOperacion ;
    rdfs:label "Linear interpolation (G1)"@en ;
    ns1:documentadoEn ns1:BloqueCicloFijo_42 ;
    ns1:identificador "G1" ;
    ns1:textoExtracto "G1"@en .

ns1:ModoOperacion_RetornoPlanoInicial_42 a ns1:ModoOperacion ;
    rdfs:label "Return to initial plane (G99)"@en ;
    ns1:documentadoEn ns1:BloqueCicloFijo_42 ;
    ns1:identificador "G99" ;
    ns1:textoExtracto "G99"@en .

ns1:Parametro_Avance_42 a ns1:Parametro ;
    rdfs:label "Feed rate (F parameter)"@en ;
    ns1:documentadoEn ns1:BloqueCicloFijo_42 ;
    ns1:textoExtracto "F1000"@en ;
    ns1:valor "1000" .

ns1:Parametro_CoordenadaX_42 a ns1:Parametro ;
    rdfs:label "X-axis machining coordinate"@en ;
    ns1:documentadoEn ns1:BloqueCicloFijo_42 ;
    ns1:textoExtracto "X60"@en ;
    ns1:valor "60" .

ns1:Parametro_CoordenadaY_42 a ns1:Parametro ;
    rdfs:label "Y-axis machining coordinate"@en ;
    ns1:documentadoEn ns1:BloqueCicloFijo_42 ;
    ns1:textoExtracto "Y0"@en ;
    ns1:valor "0" .

ns1:Parametro_CoordenadaZ_42 a ns1:Parametro ;
    rdfs:label "Z-axis machining depth"@en ;
    ns1:documentadoEn ns1:BloqueCicloFijo_42 ;
    ns1:textoExtracto "Z2"@en ;
    ns1:valor "2" .

ns1:Parametro_ProfundidadInicial_42 a ns1:Parametro ;
    rdfs:label "Initial depth (I parameter)"@en ;
    ns1:documentadoEn ns1:BloqueCicloFijo_42 ;
    ns1:textoExtracto "I-20"@en ;
    ns1:valor "-20" .

ns1:Parametro_VelocidadHusillo_42 a ns1:Parametro ;
    rdfs:label "Spindle speed (S parameter)"@en ;
    ns1:documentadoEn ns1:BloqueCicloFijo_42 ;
    ns1:textoExtracto "S2000"@en ;
    ns1:valor "2000" .

ns1:BloqueCicloFijo_42 a ns1:InterfazUsuario ;
    rdfs:label "Canned cycle defining block (G81 example)"@en ;
    ns1:identificador "G81" ;
    ns1:textoExtracto "the structure of a canned cycle defining block is the following... N10 G99 G1 G81 X60 Y0 Z2 I-20 F1000 S2000 M4"@en .

