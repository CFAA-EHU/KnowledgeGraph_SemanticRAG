@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_2508 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2508: Valor de escritura fuera de rango"@es ;
    ns1:identificador "2508" ;
    ns1:textoExtracto "2508 Valor de escritura fuera de rango. DETECCIÓN Durante la ejecución. CAUSA No es posible escribir ese valor en la variable. SOLUCIÓN Modificar el valor a escribir."@es .

ns1:Fallo_2509 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2509: Sintaxis incorrecta en comando #ORBIT"@es ;
    ns1:identificador "2509" ;
    ns1:textoExtracto "2509 #ORBIT ON[Rvalor, Jvalor ,Kvalor]."@es .

ns1:Fallo_G107 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de programación en G107 con coordenadas polares/ángulo"@es ;
    ns1:identificador "G107_coordenadas_inválidas" ;
    ns1:solucionaFallo ns1:Parametro_Jvalor,
        ns1:Parametro_Kvalor,
        ns1:Parametro_Rvalor ;
    ns1:textoExtracto "CAUSA No es posible programar las cotas de un bloque en G107 con coordenadas polares o mediante coordenadas cartesianas y ángulo. SOLUCIÓN Programar las cotas en coordenadas cartesianas."@es .

ns1:Variable_FueraRango_2508 a ns1:Parametro ;
    rdfs:label "Variable con valor fuera de rango (Error 2508)"@es ;
    ns1:textoExtracto "No es posible escribir ese valor en la variable"@es .

ns1:Parametro_Jvalor a ns1:Parametro ;
    rdfs:label "Parámetro J en comando #ORBIT"@es ;
    ns1:identificador "Jvalor" ;
    ns1:textoExtracto "#ORBIT ON[Rvalor, Jvalor ,Kvalor]"@es .

ns1:Parametro_Kvalor a ns1:Parametro ;
    rdfs:label "Parámetro K en comando #ORBIT"@es ;
    ns1:identificador "Kvalor" ;
    ns1:textoExtracto "#ORBIT ON[Rvalor, Jvalor ,Kvalor]"@es .

ns1:Parametro_Rvalor a ns1:Parametro ;
    rdfs:label "Parámetro R en comando #ORBIT"@es ;
    ns1:identificador "Rvalor" ;
    ns1:textoExtracto "#ORBIT ON[Rvalor, Jvalor ,Kvalor]"@es .

