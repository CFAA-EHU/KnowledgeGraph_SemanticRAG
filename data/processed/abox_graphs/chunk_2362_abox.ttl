@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error2512 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2512: Anchura de ranura insuficiente (#ORBIT)"@es ;
    ns1:identificador "2512" ;
    ns1:monitoreaParametro ns1:Parametro_K_2512,
        ns1:Parametro_R_2512 ;
    ns1:solucionaFallo ns1:Solucion_AnchuraRanura_2512 ;
    ns1:textoExtracto "2512 #ORBIT: la anchura de la ranura debe ser mayor que el doble del radio de la herramienta activa. [...] SOLUCIÓN Programar una anchura mayor que el radio de la herramienta."@es .

ns1:Error2513 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2513: #ORBIT ON ya activo"@es ;
    ns1:identificador "2513" ;
    ns1:solucionaFallo ns1:Solucion_DesactivarORBIT_2513 ;
    ns1:textoExtracto "2513 #ORBIT ON ya activo. [...] SOLUCIÓN Para modificar algún parámetro de la sentencia #ORBIT, es necesario desactivarla primero."@es .

ns1:Error2514 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 2514: Movimiento G0 con #ORBIT activo"@es ;
    ns1:identificador "2514" ;
    ns1:solucionaFallo ns1:Solucion_EliminarG0_2514 ;
    ns1:textoExtracto "2514 #ORBIT ON: movimiento en G0 no permitido. [...] SOLUCIÓN Eliminar el bloque en G0 o desactivar #ORBIT."@es .

ns1:Herramienta_Orbit a ns1:Herramienta ;
    rdfs:label "Herramienta activa en modo #ORBIT"@es ;
    ns1:textoExtracto "la anchura de la ranura debe ser mayor que el doble del radio de la herramienta activa."@es .

ns1:ModoORBIT a ns1:ModoOperacion ;
    rdfs:label "Modo de operación #ORBIT"@es ;
    ns1:requiereMantenimiento ns1:Solucion_EliminarG0_2514 ;
    ns1:textoExtracto "#ORBIT ON: movimiento en G0 no permitido. [...] Se ha programado un movimiento en G0 con #ORBIT activo."@es .

ns1:Parametro_K_2512 a ns1:Parametro ;
    rdfs:label "Parámetro K (factor)"@es ;
    ns1:textoExtracto "El valor de K debe ser 1 o 2."@es ;
    ns1:valor "1|2" .

ns1:Parametro_R_2512 a ns1:Parametro ;
    rdfs:label "Parámetro R (anchura de ranura)"@es ;
    ns1:textoExtracto "El valor de R debe ser mayor que el diámetro de la herramienta. [...] la anchura de la ranura (R) es menor o igual que el diámetro de la herramienta."@es ;
    ns1:valor "R > diámetro_herramienta"@es .

ns1:Solucion_AnchuraRanura_2512 a ns1:TareaMantenimiento ;
    rdfs:label "Solución: Programar anchura de ranura > radio de herramienta"@es ;
    ns1:textoExtracto "SOLUCIÓN Programar una anchura mayor que el radio de la herramienta."@es .

ns1:Solucion_DesactivarORBIT_2513 a ns1:TareaMantenimiento ;
    rdfs:label "Solución: Desactivar #ORBIT antes de modificar parámetros"@es ;
    ns1:textoExtracto "SOLUCIÓN Para modificar algún parámetro de la sentencia #ORBIT, es necesario desactivarla primero."@es .

ns1:Solucion_EliminarG0_2514 a ns1:TareaMantenimiento ;
    rdfs:label "Solución: Eliminar bloque G0 o desactivar #ORBIT"@es ;
    ns1:textoExtracto "SOLUCIÓN Eliminar el bloque en G0 o desactivar #ORBIT."@es .

