@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_2515 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 2515: #ORBIT ON - Movimiento no permitido"@es ;
    ns1:identificador "2515" ;
    ns1:textoExtracto "#ORBIT ON: movimiento del eje perpendicular al plano no permitido."@es .

ns1:Fallo_G0_Orbit a ns1:DiagnosticoFallo ;
    rdfs:label "Movimiento en G0 con #ORBIT activo"@es ;
    ns1:textoExtracto "CAUSA Se ha programado un movimiento en G0 con #ORBIT activo. SOLUCIÓN Eliminar el bloque en G0 o desactivar #ORBIT."@es .

ns1:Modo_Orbit a ns1:ModoOperacion ;
    rdfs:label "#ORBIT"@es ;
    ns1:identificador "#ORBIT" ;
    ns1:textoExtracto "#ORBIT activo"@es .

