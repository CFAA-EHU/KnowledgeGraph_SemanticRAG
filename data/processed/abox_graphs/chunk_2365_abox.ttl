@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error3005 a ns1:DiagnosticoFallo ;
    rdfs:label "Error del control de posición en la inicialización del proceso de palpador"@es ;
    ns1:identificador "3005" ;
    ns1:textoExtracto "3005 'Error del control de posición en la inicialización del proceso de palpador' DETECCIÓN En la inicialización del proceso de palpado. CAUSA Es una seguridad de habilitación del proceso de palpado. Algún eje programado no es válido o no está disponible. SOLUCIÓN Comprobar la validez y disponibilidad de los ejes programados."@es .

ns1:SenalPalpadorPrematura a ns1:DiagnosticoFallo ;
    rdfs:label "Señal del palpador recibida antes del inicio esperado"@es ;
    ns1:identificador "3007" ;
    ns1:textoExtracto "3007 'Se ha recibido señal del palpador antes del"@es .

