@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_3010 a ns1:DiagnosticoFallo ;
    rdfs:label "El eje no se ha definido como palpador (PROBEAXIS)"@es ;
    ns1:identificador "3010" ;
    ns1:textoExtracto "3010 'El eje no se ha definido como palpador (PROBEAXIS)' DETECCIÓN Durante la ejecución."@es .

ns1:Parametro_PROBEAXIS a ns1:Parametro ;
    rdfs:label "PROBEAXIS (Definición de eje como palpador)"@es ;
    ns1:monitoreaParametro ns1:Sensor_Palpador ;
    ns1:textoExtracto "El eje no se ha definido como palpador (PROBEAXIS)"@es .

ns1:ContactarConProveedorParaConfiguracionDePalpado a ns1:AccionProhibida ;
    rdfs:label "Contactar con proveedor para configuración de palpado"@es ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con su proveedor."@es .

ns1:Fallo_3007 a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha recibido señal del palpador antes del movimiento"@es ;
    ns1:identificador "3007" ;
    ns1:solucionaFallo ns1:ContactarConProveedorParaConfiguracionDePalpado ;
    ns1:textoExtracto "proceso de palpado. [...] 3007 'Se ha recibido señal del palpador antes del movimiento' DETECCIÓN Tras detectar la señal de palpador. CAUSA Proceso de palpado habilitado sin G100 programada. SOLUCIÓN Póngase en contacto con su proveedor."@es .

ns1:Fallo_3008 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el proceso de palpador"@es ;
    ns1:identificador "3008" ;
    ns1:solucionaFallo ns1:VerificacionDeEjesProgramadosEnPalpado ;
    ns1:textoExtracto "3008 'Error en el proceso de palpador' DETECCIÓN Tras detectar la señal de palpador. CAUSA Es una seguridad de habilitación del proceso de palpado. SOLUCIÓN Comprobar la validez y disponibilidad de los ejes programados."@es .

ns1:Fallo_3009 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha recibido señal del palpador"@es ;
    ns1:identificador "3009" ;
    ns1:solucionaFallo ns1:RevisionDeParametrizacionYSenalesFisicasDelPalpador ;
    ns1:textoExtracto "3009 No se ha recibido señal del palpador. DETECCIÓN Durante la ejecución. CAUSA No ha llegado la señal del palpador tras un movimiento de palpado. SOLUCIÓN Revisar la parametrización del palpador y señales físicas."@es .

ns1:RevisionDeParametrizacionYSenalesFisicasDelPalpador a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de parametrización y señales físicas del palpador"@es ;
    ns1:textoExtracto "SOLUCIÓN Revisar la parametrización del palpador y señales físicas."@es .

ns1:Sensor_Palpador a ns1:Sensor ;
    rdfs:label "Palpador"@es ;
    ns1:activaAlarma ns1:Fallo_3007,
        ns1:Fallo_3008,
        ns1:Fallo_3009 ;
    ns1:textoExtracto "proceso de palpado [...] señal del palpador [...] señal de palpador [...] parametrización del palpador"@es .

ns1:VerificacionDeEjesProgramadosEnPalpado a ns1:TareaMantenimiento ;
    rdfs:label "Verificación de ejes programados en palpado"@es ;
    ns1:textoExtracto "SOLUCIÓN Comprobar la validez y disponibilidad de los ejes programados."@es .

