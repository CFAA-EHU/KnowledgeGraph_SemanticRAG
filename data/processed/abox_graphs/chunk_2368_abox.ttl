@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_3016 a ns1:AvisoSeguridad ;
    rdfs:label "Error en búsqueda de referencia (3016)"@es ;
    ns1:identificador "3016" ;
    ns1:textoExtracto "'En búsqueda de"@es .

ns1:DiagnosticoFallo_3015 a ns1:DiagnosticoFallo ;
    rdfs:label "Solución para búsqueda de referencia omitida (3015)"@es ;
    ns1:identificador "3015" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_3015 ;
    ns1:textoExtracto "SOLUCIÓN Hacer la búsqueda de referencia máquina fuera del programa."@es .

ns1:DiagnosticoFallo_3016 a ns1:DiagnosticoFallo ;
    rdfs:label "Solución para error de búsqueda (3016)"@es ;
    ns1:identificador "3016" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_3015 ;
    ns1:textoExtracto "Disminuir el avance de palpado o disminuir el error de seguimiento."@es .

ns1:AvisoSeguridad_3015 a ns1:AvisoSeguridad ;
    rdfs:label "Búsqueda de referencia máquina omitida en búsqueda de bloque"@es ;
    ns1:identificador "3015" ;
    ns1:textoExtracto "'En búsqueda de bloque la búsqueda de referencia máquina es omitida'"@es .

