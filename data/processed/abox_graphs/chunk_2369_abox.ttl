@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_3016 a ns1:DiagnosticoFallo ;
    rdfs:label "En búsqueda de bloque el modo manual es omitido"@es ;
    ns1:identificador "3016" ;
    ns1:monitoreaParametro ns1:Modo_BusquedaBloque,
        ns1:Modo_Manual ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El usuario ha intentado activar el modo manual durante una búsqueda de bloque y el CNC lo ha ignorado. SOLUCIÓN El CNC no permite activar el modo manual durante la búsqueda de bloque."@es .

ns1:Fallo_3017 a ns1:DiagnosticoFallo ;
    rdfs:label "Búsqueda de bloque ya activada"@es ;
    ns1:identificador "3017" ;
    ns1:textoExtracto "DETECCIÓN Durante la búsqueda de bloque. CAUSA El CNC ha intentado activar una búsqueda de bloque estando con otra activa. SOLUCIÓN Póngase en contacto con su proveedor."@es .

ns1:Fallo_3018 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha alcanzado aún la velocidad de corte constante"@es ;
    ns1:identificador "3018" ;
    ns1:monitoreaParametro ns1:Componente_Cabezal,
        ns1:Parametro_VelocidadCorte ;
    ns1:solucionaFallo ns1:Parametro_Avance,
        ns1:Parametro_VelocidadCabezal ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El cabezal no ha tenido tiempo para alcanzar la velocidad programada. SOLUCIÓN Disminuir el avance, disminuir la velocidad del cabezal o programar la velocidad antes para darle tiempo al cabezal a alcanzar su velocidad."@es .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal"@es ;
    ns1:textoExtracto "El cabezal no ha tenido tiempo para alcanzar la velocidad programada"@es .

ns1:Modo_BusquedaBloque a ns1:ModoOperacion ;
    rdfs:label "Búsqueda de bloque"@es ;
    ns1:textoExtracto "búsqueda de bloque"@es .

ns1:Modo_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo manual"@es ;
    ns1:textoExtracto "modo manual"@es .

ns1:Parametro_Avance a ns1:Parametro ;
    rdfs:label "Avance"@es ;
    ns1:textoExtracto "Disminuir el avance"@es .

ns1:Parametro_VelocidadCabezal a ns1:Parametro ;
    rdfs:label "Velocidad del cabezal"@es ;
    ns1:textoExtracto "velocidad del cabezal"@es .

ns1:Parametro_VelocidadCorte a ns1:Parametro ;
    rdfs:label "Velocidad de corte constante"@es ;
    ns1:textoExtracto "velocidad de corte constante"@es .

