@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_P a ns1:Parametro ;
    rdfs:label "Parameter P"@en ;
    ns1:identificador "P" ;
    ns1:monitoreaParametro ns1:ModoOperacion_MultipleMachining ;
    ns1:textoExtracto "Parameters P, Q, R, S, T, U and V are optional parameters that may be used in any type of multiple positioning. Thus, programming 'P7' means that no machining operation takes place at point 7."@en ;
    ns1:valor "skip point"@en .

ns1:Parametro_Q a ns1:Parametro ;
    rdfs:label "Parameter Q"@en ;
    ns1:identificador "Q" ;
    ns1:monitoreaParametro ns1:ModoOperacion_MultipleMachining ;
    ns1:textoExtracto "Programming 'Q10.013' means that no machining operation takes place at points 10, 11, 12 and 13."@en ;
    ns1:valor "skip range"@en .

ns1:Parametro_R a ns1:Parametro ;
    rdfs:label "Parameter R"@en ;
    ns1:identificador "R" ;
    ns1:monitoreaParametro ns1:ModoOperacion_MultipleMachining ;
    ns1:textoExtracto "Parameters P, Q, R, S, T, U and V are optional parameters that may be used in any type of multiple positioning."@en .

ns1:Parametro_S a ns1:Parametro ;
    rdfs:label "Parameter S"@en ;
    ns1:identificador "S" ;
    ns1:monitoreaParametro ns1:ModoOperacion_MultipleMachining ;
    ns1:textoExtracto "Parameters P, Q, R, S, T, U and V are optional parameters that may be used in any type of multiple positioning."@en .

ns1:Parametro_T a ns1:Parametro ;
    rdfs:label "Parameter T"@en ;
    ns1:identificador "T" ;
    ns1:monitoreaParametro ns1:ModoOperacion_MultipleMachining ;
    ns1:textoExtracto "Parameters P, Q, R, S, T, U and V are optional parameters that may be used in any type of multiple positioning."@en .

ns1:Parametro_U a ns1:Parametro ;
    rdfs:label "Parameter U"@en ;
    ns1:identificador "U" ;
    ns1:monitoreaParametro ns1:ModoOperacion_MultipleMachining ;
    ns1:textoExtracto "Parameters P, Q, R, S, T, U and V are optional parameters that may be used in any type of multiple positioning."@en .

ns1:Parametro_V a ns1:Parametro ;
    rdfs:label "Parameter V"@en ;
    ns1:identificador "V" ;
    ns1:monitoreaParametro ns1:ModoOperacion_MultipleMachining ;
    ns1:textoExtracto "Parameters P, Q, R, S, T, U and V are optional parameters that may be used in any type of multiple positioning."@en .

ns1:ModoOperacion_MultipleMachining a ns1:ModoOperacion ;
    rdfs:label "Multiple Machining Mode (M)"@en ;
    ns1:identificador "M" ;
    ns1:textoExtracto "MULTIPLE MACHINING (·M· MODEL). [...] If these parameters are not programmed, the CNC executes the machining operation at all the points of the programmed path."@en .

