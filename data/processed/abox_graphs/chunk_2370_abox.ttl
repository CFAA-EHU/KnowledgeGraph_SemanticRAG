@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_3019 a ns1:Alarma ;
    rdfs:label "Avance programado en G95 demasiado pequeño" ;
    ns1:identificador "3019" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_3019 ;
    ns1:textoExtracto "'Avance programado en G95 demasiado pequeño' DETECCIÓN Durante la ejecución. CAUSA El avance resultante es muy pequeño para la velocidad programada. SOLUCIÓN Aumentar el avance o aumentar las revoluciones del cabezal." .

ns1:Alarma_3020 a ns1:Alarma ;
    rdfs:label "No se ha programado S en G96" ;
    ns1:identificador "3020" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_3020 ;
    ns1:textoExtracto "'No se ha programado S en G96' DETECCIÓN Durante la ejecución. CAUSA La velocidad del cabezal es igual a cero. SOLUCIÓN Programar una velocidad." .

ns1:Alarma_3021 a ns1:Alarma ;
    rdfs:label "Máxima velocidad de corte constante igual a cero" ;
    ns1:identificador "3021" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_3021 ;
    ns1:textoExtracto "'Máxima velocidad de corte constante igual a cero' DETECCIÓN Durante la ejecución. CAUSA La velocidad máxima del cabezal es igual a cero. SOLUCIÓN Programar una velocidad." .

ns1:Alarma_3022 a ns1:Alarma ;
    rdfs:label "Error al inicializar las cotas de los ejes" ;
    ns1:identificador "3022" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_3022 ;
    ns1:textoExtracto "'Error al inicializar las cotas de los ejes' DETECCIÓN Durante la ejecución. CAUSA No coinciden las cotas de algún eje. SOLUCIÓN Póngase en contacto con Fagor." .

ns1:Alarma_3023 a ns1:Alarma ;
    rdfs:label "Falta eje(s) en el nuevo sistema de coordenadas" ;
    ns1:identificador "3023" ;
    ns1:textoExtracto "'Falta eje(s) en el nuevo sistema de coordenadas' DETECCIÓN Durante la ejecución." .

ns1:AvisoSeguridad_3019 a ns1:AvisoSeguridad ;
    rdfs:label "Solución para alarma 3019" ;
    ns1:textoExtracto "Aumentar el avance o aumentar las revoluciones del cabezal." .

ns1:AvisoSeguridad_3020 a ns1:AvisoSeguridad ;
    rdfs:label "Solución para alarma 3020" ;
    ns1:textoExtracto "Programar una velocidad." .

ns1:AvisoSeguridad_3021 a ns1:AvisoSeguridad ;
    rdfs:label "Solución para alarma 3021" ;
    ns1:textoExtracto "Programar una velocidad." .

ns1:AvisoSeguridad_3022 a ns1:AvisoSeguridad ;
    rdfs:label "Solución para alarma 3022" ;
    ns1:textoExtracto "Póngase en contacto con Fagor." .

ns1:AccionProhibida_3019 a ns1:AccionProhibida ;
    rdfs:label "Avance insuficiente en G95" ;
    ns1:textoExtracto "El avance resultante es muy pequeño para la velocidad programada." .

ns1:AccionProhibida_3020 a ns1:AccionProhibida ;
    rdfs:label "Velocidad no programada en G96" ;
    ns1:textoExtracto "La velocidad del cabezal es igual a cero." .

ns1:AccionProhibida_3021 a ns1:AccionProhibida ;
    rdfs:label "Velocidad máxima no configurada" ;
    ns1:textoExtracto "La velocidad máxima del cabezal es igual a cero." .

ns1:AccionProhibida_3022 a ns1:AccionProhibida ;
    rdfs:label "Inconsistencia en cotas de ejes" ;
    ns1:textoExtracto "No coinciden las cotas de algún eje." .

