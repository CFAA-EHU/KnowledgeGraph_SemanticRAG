@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_3023 a ns1:AvisoSeguridad ;
    rdfs:label "Falta eje(s) en el nuevo sistema de coordenadas"@es ;
    ns1:identificador "3023" ;
    ns1:mitigaRiesgo ns1:OperarSinDefinirLosTresPrimerosEjesDelCanal ;
    ns1:textoExtracto "'Falta eje(s) en el nuevo sistema de coordenadas' DETECCIÓN Durante la ejecución. CAUSA No existe alguno de los tres primeros ejes del nuevo sistema de coordenadas."@es .

ns1:AvisoSeguridad_3025 a ns1:AvisoSeguridad ;
    rdfs:label "Límite positivo de software sobrepasado"@es ;
    ns1:identificador "3025" ;
    ns1:textoExtracto "'Límite positivo de software sobrepasado' DETECCIÓN"@es .

ns1:DefinirLosTresPrimerosEjesDelCanalMedianteSETAX a ns1:TareaMantenimiento ;
    rdfs:label "Definir los tres primeros ejes del canal mediante #SET AX"@es ;
    ns1:textoExtracto "Definir los tres primeros del canal mediante la sentencia #SET AX."@es .

ns1:OperarSinDefinirLosTresPrimerosEjesDelCanal a ns1:AccionProhibida ;
    rdfs:label "Operar sin definir los tres primeros ejes del canal"@es ;
    ns1:solucionaFallo ns1:DefinirLosTresPrimerosEjesDelCanalMedianteSETAX ;
    ns1:textoExtracto "No existe alguno de los tres primeros ejes del nuevo sistema de coordenadas."@es .

