@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_3025 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 3025" ;
    ns1:solucionaFallo ns1:Alarma_3025 ;
    ns1:textoExtracto "SOLUCIÓN Los ejes deben estar siempre dentro de los límites de software. Comprobar que los límites de software son correctos, que no han sido modificados desde el programa pieza o PLC." .

ns1:DiagnosticoFallo_3026 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 3026" ;
    ns1:solucionaFallo ns1:Alarma_3026 ;
    ns1:textoExtracto "SOLUCIÓN Los ejes deben estar siempre dentro de los límites de software. Comprobar que los límites de software son correctos, que no han sido modificados desde el programa pieza o PLC." .

ns1:Sistema_Coordenadas a ns1:Sistema ;
    rdfs:label "Sistema de coordenadas del CNC" ;
    ns1:textoExtracto "alguno de los tres primeros ejes del nuevo sistema de coordenadas." ;
    ns1:tieneComponente ns1:Parametro_LimiteSoftware .

ns1:Parametro_LimiteSoftware a ns1:Parametro ;
    rdfs:label "Límites de software del sistema de coordenadas" ;
    ns1:monitoreaParametro ns1:Alarma_3025,
        ns1:Alarma_3026 ;
    ns1:textoExtracto "Los ejes deben estar siempre dentro de los límites de software. Comprobar que los límites de software son correctos, que no han sido modificados desde el programa pieza o PLC." .

ns1:Alarma_3025 a ns1:Alarma ;
    rdfs:label "Límite positivo de software sobrepasado" ;
    ns1:identificador "3025" ;
    ns1:textoExtracto "3025 'Límite positivo de software sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado desplazar un eje a un punto que se encuentra fuera de los límites de software." .

ns1:Alarma_3026 a ns1:Alarma ;
    rdfs:label "Límite negativo de software sobrepasado" ;
    ns1:identificador "3026" ;
    ns1:textoExtracto "3026 'Límite negativo de software sobrepasado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado desplazar un eje a un punto que se encuentra fuera de los límites de software." .

