@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error3027 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 3027: Transformada inversa de RTCP" ;
    ns1:identificador "3027" ;
    ns1:solucionaFallo ns1:ContactarConFagorParaError3027 ;
    ns1:textoExtracto "'Error en el cálculo de la transformada inversa de RTCP' DETECCIÓN Durante la ejecución. CAUSA El CNC no puede ejecutar la transformación de coordenadas pieza a coordenadas máquina." .

ns1:Error3029 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 3029: Transformada directa de RTCP" ;
    ns1:identificador "3029" ;
    ns1:solucionaFallo ns1:ContactarConFagorParaError3029 ;
    ns1:textoExtracto "'Error en el cálculo de la transformada directa de RTCP' DETECCIÓN Durante la ejecución. CAUSA El CNC no puede ejecutar la transformación de coordenadas máquina a coordenadas pieza." .

ns1:Error3030 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 3030: Mezcla de ejes simulados/no simulados" ;
    ns1:identificador "3030" ;
    ns1:solucionaFallo ns1:RequisitoDeUniformidadDeEjesEnMedicionConPalpador ;
    ns1:textoExtracto "'No se pueden mezclar ejes simulados con no simulados' DETECCIÓN Durante la ejecución. CAUSA En el proceso de medición con palpador hay ejes simulados y no simulados." .

ns1:Palpador a ns1:Sensor ;
    rdfs:label "Palpador de medición" ;
    ns1:monitoreaParametro ns1:TipoDeEjeSimuladoNoSimulado ;
    ns1:textoExtracto "proceso de medición con palpador" .

ns1:SistemaRTCP a ns1:Sistema ;
    rdfs:label "Sistema de Transformación RTCP (Robot Tool Center Point)" ;
    ns1:controla ns1:MaquinaCNC ;
    ns1:monitoreaParametro ns1:LimitesDeSoftwareEnRTCP ;
    ns1:textoExtracto "transformación de coordenadas pieza a coordenadas máquina... transformación de coordenadas máquina a coordenadas pieza" .

ns1:ContactarConFagorParaError3027 a ns1:AccionProhibida ;
    rdfs:label "Contactar con Fagor para error 3027" ;
    ns1:textoExtracto "Póngase en contacto con Fagor." .

ns1:ContactarConFagorParaError3029 a ns1:AccionProhibida ;
    rdfs:label "Contactar con Fagor para error 3029" ;
    ns1:textoExtracto "Póngase en contacto con Fagor." .

ns1:LimitesDeSoftwareEnRTCP a ns1:Parametro ;
    rdfs:label "Límites de software en RTCP" ;
    ns1:textoExtracto "Comprobar que los límites de software son correctos, que no han sido modificados desde el programa pieza o PLC." .

ns1:MaquinaCNC a ns1:Maquina ;
    rdfs:label "CNC (Control Numérico Computarizado)" ;
    ns1:textoExtracto "El CNC no puede ejecutar la transformación..." .

ns1:RequisitoDeUniformidadDeEjesEnMedicionConPalpador a ns1:AvisoSeguridad ;
    rdfs:label "Requisito de uniformidad de ejes en medición con palpador" ;
    ns1:textoExtracto "Todos los ejes que intervienen en un proceso de medición con palpador deben ser del mismo tipo." .

ns1:TipoDeEjeSimuladoNoSimulado a ns1:Parametro ;
    rdfs:label "Tipo de eje (simulado/no simulado)" ;
    ns1:textoExtracto "ejes simulados y no simulados" .

