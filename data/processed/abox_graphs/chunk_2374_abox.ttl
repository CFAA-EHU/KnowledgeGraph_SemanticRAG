@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error3032 a ns1:AvisoSeguridad ;
    rdfs:label "No se admite búsqueda de cero en modo"@es ;
    ns1:identificador "3032" ;
    ns1:textoExtracto "3032 'No se admite búsqueda de cero en modo"@es .

ns1:Palpador a ns1:Componente ;
    rdfs:label "palpador"@es ;
    ns1:textoExtracto "Todos los ejes que intervienen en un proceso de medición con palpador deben ser del mismo tipo"@es .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "CNC"@es ;
    ns1:activaAlarma ns1:Error3031 ;
    ns1:controla ns1:ModoRTCP,
        ns1:ModoTLC ;
    ns1:textoExtracto "El CNC ha intentado activar una de las compensaciones RTCP o TLC"@es .

ns1:Error3031 a ns1:AvisoSeguridad ;
    rdfs:label "Compensación (RTCP/TLC) no permitida en el estado actual"@es ;
    ns1:identificador "3031" ;
    ns1:textoExtracto "3031 'Compensación (RTCP/TLC) no permitida en el estado actual' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado activar una de las compensaciones RTCP o TLC estando la otra activa."@es .

ns1:ModoRTCP a ns1:ModoOperacion ;
    rdfs:label "RTCP"@es ;
    ns1:textoExtracto "compensaciones RTCP"@es .

ns1:ModoTLC a ns1:ModoOperacion ;
    rdfs:label "TLC"@es ;
    ns1:textoExtracto "compensaciones TLC"@es .

