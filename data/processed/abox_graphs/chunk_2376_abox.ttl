@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_DWELL a ns1:Parametro ;
    rdfs:label "Parámetro DWELL del eje" ;
    ns1:monitoreaParametro ns1:Fallo_3037_EjeBloqueado ;
    ns1:textoExtracto "aumentar el valor del parámetro DWELL del eje" .

ns1:Programa_PLC_Eje a ns1:Sistema ;
    rdfs:label "Programa de PLC para tratamiento de eje" ;
    ns1:solucionaFallo ns1:Fallo_3037_EjeBloqueado ;
    ns1:textoExtracto "Comprobar en el programa de PLC el tratamiento de la señal SERVO(axis)ON" ;
    ns1:tieneComponente ns1:Senal_SERVO_axis_ON .

ns1:Senal_SERVO_axis_ON a ns1:ComponenteElectrico ;
    rdfs:label "Señal SERVO(axis)ON" ;
    ns1:controla ns1:Fallo_3037_EjeBloqueado ;
    ns1:textoExtracto "el PLC no ha puesto la señal SERVO(axis)ON" .

ns1:Fallo_3037_EjeBloqueado a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 3037: Eje bloqueado" ;
    ns1:identificador "3037" ;
    ns1:textoExtracto "3037 'Eje bloqueado' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta mover un eje, pero el PLC no ha puesto la señal SERVO(axis)ON." .

