@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_3041 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 3041: Cabezal no definido para G33/G34/G95" ;
    ns1:identificador "3041" ;
    ns1:solucionaFallo ns1:Componente_CabezalMaster ;
    ns1:textoExtracto "'No se ha definido cabezal para G33/G34/G95' DETECCIÓN Durante la ejecución. CAUSA Las funciones G33, G34 y G95 necesitan un cabezal para trabajar. Este cabezal es por defecto el cabezal master del canal, pero si el registro SYNC del PLC indica otro cabezal, el canal utilizará este último. El CNC mostrará error si no está definido ninguno de los dos cabezales. SOLUCIÓN Definir un cabezal master en el canal o asignar un cabezal al registro SYNC del PLC." .

ns1:Fallo_3042 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 3042: Cabezal en SYNC no válido" ;
    ns1:identificador "3042" ;
    ns1:monitoreaParametro ns1:Parametro_SYNC ;
    ns1:textoExtracto "'El cabezal indicado en el registro SYNC no existe' DETECCIÓN Durante la ejecución. CAUSA Hay una función G33, G34 o G95 activa y el valor del registro SYNC del PLC no es válido." .

ns1:Fallo_EjeHirth a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Eje Hirth mal posicionado" ;
    ns1:solucionaFallo ns1:Componente_EjeHirth ;
    ns1:textoExtracto "CAUSA El eje hirth no se encuentra posicionado en un número múltiplo de su paso. SOLUCIÓN Posicionar correctamente el eje hirth en una posición válida o desactivarlo como eje hirth." .

ns1:Funcion_G33 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G33" ;
    ns1:identificador "G33" ;
    ns1:requiereMantenimiento ns1:Componente_CabezalMaster ;
    ns1:textoExtracto "Las funciones G33, G34 y G95 necesitan un cabezal para trabajar" .

ns1:Funcion_G34 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G34" ;
    ns1:identificador "G34" ;
    ns1:requiereMantenimiento ns1:Componente_CabezalMaster ;
    ns1:textoExtracto "Las funciones G33, G34 y G95 necesitan un cabezal para trabajar" .

ns1:Funcion_G95 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G95" ;
    ns1:identificador "G95" ;
    ns1:requiereMantenimiento ns1:Componente_CabezalMaster ;
    ns1:textoExtracto "Las funciones G33, G34 y G95 necesitan un cabezal para trabajar" .

ns1:Componente_EjeHirth a ns1:ComponenteMecanico ;
    rdfs:label "Eje Hirth" ;
    ns1:textoExtracto "El eje hirth no se encuentra posicionado en un número múltiplo de su paso" .

ns1:Parametro_SYNC a ns1:Parametro ;
    rdfs:label "Registro SYNC (PLC)" ;
    ns1:identificador "SYNC" ;
    ns1:textoExtracto "registro SYNC del PLC" .

ns1:Componente_CabezalMaster a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal Master" ;
    ns1:textoExtracto "cabezal master del canal" .

