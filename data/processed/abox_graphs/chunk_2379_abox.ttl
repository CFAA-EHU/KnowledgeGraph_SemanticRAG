@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_3043 a ns1:DiagnosticoFallo ;
    rdfs:label "Cabezal en M5 al activar roscado electrónico"@es ;
    ns1:identificador "3043" ;
    ns1:solucionaFallo ns1:Parametro_SYNC ;
    ns1:textoExtracto "3043 'Cabezal en M5 al activar roscado electrónico' [...] CAUSA El cabezal utilizado para un roscado electrónico (G33/G34) está parado o se ha programado una M5 en el mismo bloque que G33/G34."@es .

ns1:SistemaRoscado a ns1:Sistema ;
    rdfs:label "Sistema de roscado electrónico (G33/G34)"@es ;
    ns1:monitoreaParametro ns1:Parametro_SYNC ;
    ns1:textoExtracto "función G33, G34 [...] número de cabezales del sistema [...] cabezal utilizado para un roscado electrónico (G33/G34)"@es ;
    ns1:tieneComponente ns1:CabezalRoscado .

ns1:CabezalRoscado a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de roscado electrónico"@es ;
    ns1:textoExtracto "El cabezal utilizado para un roscado electrónico (G33/G34) está parado o se ha programado una M5 en el mismo bloque que G33/G34."@es .

ns1:Parametro_SYNC a ns1:Parametro ;
    rdfs:label "Registro SYNC del PLC"@es ;
    ns1:textoExtracto "el valor del registro SYNC del PLC no es válido. [...] El valor del registro SYNC del PLC debe ser un valor comprendido entre 1 y el número de cabezales del sistema. También puede tener valor cero."@es ;
    ns1:valor "0 ≤ SYNC ≤ [número de cabezales]"@es .

