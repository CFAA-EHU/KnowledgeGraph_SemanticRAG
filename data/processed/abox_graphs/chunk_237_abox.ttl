@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Instruccion_ABORT a ns1:Parametro ;
    rdfs:label "Program abort instruction"@en ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHLL ;
    ns1:identificador "#ABORT" ;
    ns1:textoExtracto "#ABORT | Abort the execution of the program and resume it in another block or program."@en .

ns1:Instruccion_DO a ns1:Parametro ;
    rdfs:label "DO-ENDDO loop"@en ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHLL ;
    ns1:identificador "$DO/$ENDDO" ;
    ns1:textoExtracto "$DO $ENDDO $BREAK $CONTINUE | Conditional block repetition."@en .

ns1:Instruccion_FOR a ns1:Parametro ;
    rdfs:label "FOR loop"@en ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHLL ;
    ns1:identificador "$FOR/$ENDFOR/$BREAK/$CONTINUE" ;
    ns1:textoExtracto "$FOR $ENDFOR $BREAK $CONTINUE | Block repetition."@en .

ns1:Instruccion_GOTO a ns1:Parametro ;
    rdfs:label "GOTO instruction"@en ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHLL ;
    ns1:identificador "$GOTO" ;
    ns1:textoExtracto "$GOTO | Block skip."@en .

ns1:Instruccion_IF a ns1:Parametro ;
    rdfs:label "Conditional IF-ELSE block"@en ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHLL ;
    ns1:identificador "$IF/$ENDIF/$ELSEIF/$ELSE" ;
    ns1:textoExtracto "$IF $ENDIF $ELSEIF $ELSE | Conditional execution."@en .

ns1:Instruccion_L a ns1:Parametro ;
    rdfs:label "Global subroutine call (L)"@en ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHLL ;
    ns1:identificador "L" ;
    ns1:textoExtracto "L | Call to a global subroutine."@en .

ns1:Instruccion_LL a ns1:Parametro ;
    rdfs:label "Local subroutine call (LL)"@en ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHLL ;
    ns1:identificador "LL" ;
    ns1:textoExtracto "LL | Call to a local subroutine."@en .

ns1:Instruccion_SWITCH a ns1:Parametro ;
    rdfs:label "SWITCH-CASE block"@en ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHLL ;
    ns1:identificador "$SWITCH/$CASE/$ENDSWITCH/$BREAK/$DEFAULT" ;
    ns1:textoExtracto "$SWITCH $CASE $ENDSWITCH $BREAK $DEFAULT | Conditional execution."@en .

ns1:Instruccion_WHILE a ns1:Parametro ;
    rdfs:label "WHILE loop"@en ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHLL ;
    ns1:identificador "$WHILE/$ENDWHILE" ;
    ns1:textoExtracto "$WHILE $ENDWHILE $BREAK $CONTINUE | Conditional block repetition."@en .

ns1:Parametro_ACS a ns1:Parametro ;
    rdfs:label "Fixture coordinate system parameter"@en ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHLL ;
    ns1:identificador "#ACS" ;
    ns1:textoExtracto "#ACS | Fixture coordinate system."@en .

ns1:Parametro_ANGAX a ns1:Parametro ;
    rdfs:label "Angular transformation control"@en ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHLL ;
    ns1:identificador "#ANGAX" ;
    ns1:textoExtracto "#ANGAX OFF | Turn angular transformation off. #ANGAX ON | Turn angular transformation on. #ANGAX SUSP | Freeze angular transformation."@en ;
    ns1:valor "OFF/ON/SUSP" .

ns1:Parametro_ASPLINE a ns1:Parametro ;
    rdfs:label "Akima spline tangent configuration"@en ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHLL ;
    ns1:identificador "#ASPLINE" ;
    ns1:textoExtracto "#ASPLINE ENDTANG | Type of final tangent. #ASPLINE MODE | Selection of tangent type. #ASPLINE STARTTANG | Type of starting tangent."@en ;
    ns1:valor "ENDTANG/MODE/STARTTANG" .

ns1:Tabla_InstruccionesHLL a ns1:Tabla ;
    rdfs:label "High-Level Language (HLL) Instruction Table"@en ;
    ns1:textoExtracto """
| Instruction. | Meaning. |
| --- | --- |
| $GOTO | Block skip. |
| $IF $ENDIF $ELSEIF $ELSE | Conditional execution. |
| $SWITCH $CASE $ENDSWITCH $BREAK $DEFAULT | Conditional execution. |
| $FOR $ENDFOR $BREAK $CONTINUE | Block repetition. |
| $WHILE $ENDWHILE $BREAK $CONTINUE | Conditional block repetition. |
| $DO $ENDDO $BREAK $CONTINUE | Conditional block repetition. |
| L | Call to a global subroutine. |
| LL | Call to a local subroutine. |
| #ABORT | Abort the execution of the program and resume it in another block or program. |
| #ACS | Fixture coordinate system. |
| #ANGAX OFF/ON/SUSP | Turn angular transformation off/on/freeze. |
| #ASPLINE ENDTANG/STARTTANG/MODE | Akima splines. Tangent type selection. |
| #AXIS | Axis for additive manual intervention. |
| #CALL | Call to a global or local subroutine. |
| #CALL AX/SP | Add axis/spindle to channel configuration. |
| #CAM ON/OFF | Activate/cancel electronic cam. |
| #CAX | Activate spindle as "C" axis. |
| #CD ON/OFF | Activate/cancel collision detection. |
| #CLEAR | Clear synchronism marks of the channel. |
| #CONTJOG | Feedrate in continuous jog. |
| #COMMENT BEGIN/END | Comment delimiters.""" .

