@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_3044 a ns1:Alarma ;
    rdfs:label "No se permite búsqueda de cero de un eje activo como eje independiente"@es ;
    ns1:identificador "3044" ;
    ns1:mitigaRiesgo ns1:Sistema_CNC ;
    ns1:textoExtracto "3044 'No se permite búsqueda de cero de un eje activo como eje independiente' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta realizar la búsqueda de referencia de un eje independiente."@es .

ns1:Alarma_3045 a ns1:Alarma ;
    rdfs:label "No se admite M6"@es ;
    ns1:identificador "3045" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_MHFS ;
    ns1:textoExtracto "3045 'No se admite M6' DETECCIÓN Durante la ejecución. CAUSA Tras interrumpir un programa y cambiar al modo MHFS, el usuario ha editado una M6 no permitida."@es .

ns1:Alarma_3046 a ns1:Alarma ;
    rdfs:label "El cabezal asociado no pertenece al canal"@es ;
    ns1:identificador "3046" ;
    ns1:mitigaRiesgo ns1:Componente_CabezalRoscado ;
    ns1:textoExtracto "3046 'El cabezal asociado no pertenece al canal' DETECCIÓN Durante la ejecución. CAUSA Tras interrumpir un programa y cambiar al modo MHFS, el usuario ha editado una M o una S referida a un cabezal que no existe en el canal o en el sistema."@es .

ns1:Alarma_3047 a ns1:Alarma ;
    rdfs:label "No se admite M3/M4/M5/M19/M41-M44 con G63 activa"@es ;
    ns1:identificador "3047" ;
    ns1:mitigaRiesgo ns1:Parametro_G63 ;
    ns1:textoExtracto "3047 'No se admite M3/M4/M5/M19/M41-M44 con G63 activa' DETECCIÓN Durante la ejecución. CAUSA Tras interrumpir un programa con G63 activa y cambiar al modo MHFS, el usuario ha editado una función M3, M4, M5, M19 ó M41 a M44 no permitida para G63."@es .

ns1:Alarma_RoscadoElectronico a ns1:Alarma ;
    rdfs:label "Cabezal parado en roscado electrónico (G33/G34)"@es ;
    ns1:identificador "Alarma_Roscado_G33_G34" ;
    ns1:mitigaRiesgo ns1:Componente_CabezalRoscado ;
    ns1:textoExtracto "electrónico' DETECCIÓN Durante la ejecución. CAUSA El cabezal utilizado para un roscado electrónico (G33/G34) está parado o se ha programado una M5 en el mismo bloque que G33/G34. SOLUCIÓN El cabezal utilizado para el roscado electrónico debe estar en marcha."@es .

ns1:ModoOperacion_MDI a ns1:ModoOperacion ;
    rdfs:label "Modo MDI"@es ;
    ns1:identificador "MDI" ;
    ns1:textoExtracto "Pulsar reset y ejecutar M6 desde el modo MDI."@es .

ns1:Parametro_M19 a ns1:Parametro ;
    rdfs:label "Función M19"@es ;
    ns1:identificador "M19" ;
    ns1:textoExtracto "el usuario ha editado una función M3, M4, M5, M19 ó M41 a M44 no permitida para G63."@es .

ns1:Parametro_M3 a ns1:Parametro ;
    rdfs:label "Función M3"@es ;
    ns1:identificador "M3" ;
    ns1:textoExtracto "el usuario ha editado una función M3, M4, M5, M19 ó M41 a M44 no permitida para G63."@es .

ns1:Parametro_M4 a ns1:Parametro ;
    rdfs:label "Función M4"@es ;
    ns1:identificador "M4" ;
    ns1:textoExtracto "el usuario ha editado una función M3, M4, M5, M19 ó M41 a M44 no permitida para G63."@es .

ns1:Parametro_M5 a ns1:Parametro ;
    rdfs:label "Función M5"@es ;
    ns1:identificador "M5" ;
    ns1:textoExtracto "el usuario ha editado una función M3, M4, M5, M19 ó M41 a M44 no permitida para G63."@es .

ns1:Parametro_M6 a ns1:Parametro ;
    rdfs:label "Función M6 (cambio de herramienta)"@es ;
    ns1:identificador "M6" ;
    ns1:textoExtracto "el usuario ha editado una M6 no permitida."@es .

ns1:ModoOperacion_MHFS a ns1:ModoOperacion ;
    rdfs:label "Modo MHFS"@es ;
    ns1:identificador "MHFS" ;
    ns1:textoExtracto "Tras interrumpir un programa y cambiar al modo MHFS, el usuario ha editado una M6 no permitida."@es .

ns1:Parametro_G33 a ns1:Parametro ;
    rdfs:label "Función G33 (roscado electrónico)"@es ;
    ns1:identificador "G33" ;
    ns1:textoExtracto "El cabezal utilizado para un roscado electrónico (G33/G34) está parado"@es .

ns1:Parametro_G34 a ns1:Parametro ;
    rdfs:label "Función G34 (roscado electrónico)"@es ;
    ns1:identificador "G34" ;
    ns1:textoExtracto "El cabezal utilizado para un roscado electrónico (G33/G34) está parado"@es .

ns1:Parametro_G63 a ns1:Parametro ;
    rdfs:label "Función G63"@es ;
    ns1:identificador "G63" ;
    ns1:textoExtracto "Tras interrumpir un programa con G63 activa y cambiar al modo MHFS, el usuario ha editado una función M3, M4, M5, M19 ó M41 a M44 no permitida para G63."@es .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:textoExtracto "El CNC intenta realizar la búsqueda de referencia de un eje independiente."@es .

ns1:Componente_CabezalRoscado a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de roscado electrónico"@es ;
    ns1:controla ns1:Parametro_G33,
        ns1:Parametro_G34 ;
    ns1:textoExtracto "El cabezal utilizado para un roscado electrónico (G33/G34) está parado o se ha programado una M5 en el mismo bloque que G33/G34."@es .

