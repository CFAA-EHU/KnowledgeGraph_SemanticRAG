@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_3048_GamaInexistente a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 3048: La gama programada no existe"@es ;
    ns1:identificador "3048" ;
    ns1:textoExtracto "'La gama programada no existe' DETECCIÓN Durante la ejecución. CAUSA Tras interrumpir un programa y cambiar al modo MHFS, el usuario ha editado una función M asociada a una gama que no existe en el cabezal."@es .

ns1:Fallo_G63_FuncionM_Incompatible a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo por función M no permitida con G63 activa"@es ;
    ns1:solucionaFallo ns1:Funcion_G63,
        ns1:Funcion_M19,
        ns1:Funcion_M3,
        ns1:Funcion_M4,
        ns1:Funcion_M41,
        ns1:Funcion_M44,
        ns1:Funcion_M5 ;
    ns1:textoExtracto "CAUSA Tras interrumpir un programa con G63 activa y cambiar al modo MHFS, el usuario ha editado una función M3, M4, M5, M19 ó M41 a M44 no permitida para G63. SOLUCIÓN Desactivar la función G63 o esperar a que finalice esta función antes de interrumpir el programa."@es .

ns1:Modo_MHFS a ns1:ModoOperacion ;
    rdfs:label "Modo MHFS"@es ;
    ns1:textoExtracto "cambiar al modo MHFS"@es .

ns1:Funcion_G63 a ns1:Parametro ;
    rdfs:label "Función G63"@es ;
    ns1:identificador "G63" ;
    ns1:textoExtracto "G63 activa"@es .

ns1:Funcion_M19 a ns1:Parametro ;
    rdfs:label "Función M19"@es ;
    ns1:identificador "M19" ;
    ns1:textoExtracto "función M19"@es .

ns1:Funcion_M3 a ns1:Parametro ;
    rdfs:label "Función M3"@es ;
    ns1:identificador "M3" ;
    ns1:textoExtracto "función M3"@es .

ns1:Funcion_M4 a ns1:Parametro ;
    rdfs:label "Función M4"@es ;
    ns1:identificador "M4" ;
    ns1:textoExtracto "función M4"@es .

ns1:Funcion_M41 a ns1:Parametro ;
    rdfs:label "Función M41"@es ;
    ns1:identificador "M41" ;
    ns1:textoExtracto "función M41"@es .

ns1:Funcion_M44 a ns1:Parametro ;
    rdfs:label "Función M44"@es ;
    ns1:identificador "M44" ;
    ns1:textoExtracto "función M44"@es .

ns1:Funcion_M5 a ns1:Parametro ;
    rdfs:label "Función M5"@es ;
    ns1:identificador "M5" ;
    ns1:textoExtracto "función M5"@es .

