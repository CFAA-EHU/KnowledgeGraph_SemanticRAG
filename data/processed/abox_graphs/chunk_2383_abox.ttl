@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Solucion_3057_TransformacionAngular a ns1:AccionProhibida ;
    rdfs:label "Anulación de transformación angular (#ANGAX OFF) cuando ejes forman 90°"@es ;
    ns1:solucionaFallo ns1:Error_3057 ;
    ns1:textoExtracto "Si los ejes forman un ángulo de 90º, no es necesaria la transformación angular. Anular la transformación angular (#ANGAX OFF) o definir un ángulo diferente de 90º."@es .

ns1:Error_3057 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el cálculo de la transformada directa del eje inclinado #ANGAX"@es ;
    ns1:identificador "3057" ;
    ns1:textoExtracto "3057 'Error en el cálculo de la transformada directa del eje inclinado #ANGAX' DETECCIÓN Durante la ejecución. CAUSA En una transformación angular, el eje inclinado y el ortogonal forma un ángulo de 90º."@es .

