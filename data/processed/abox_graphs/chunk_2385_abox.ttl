@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSincronizacionLazoAbierto a ns1:AvisoSeguridad ;
    rdfs:label "Aviso: cabezal master pasa a lazo abierto" ;
    ns1:identificador "3062" ;
    ns1:mitigaRiesgo ns1:SincronizacionLazoAbierto ;
    ns1:textoExtracto "'El cabezal master de la sincronización pasa a lazo abierto'" .

ns1:FalloSincronizacionCabezalesMaster a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de sincronización en cabezales master" ;
    ns1:identificador "3062" ;
    ns1:solucionaFallo ns1:CabezalMaster ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El CNC no puede sincronizar en lazo cerrado un cabezal master, si éste no ha sido previamente referenciado. SOLUCIÓN Realizar una búsqueda de referencia del cabezal master antes de sincronizar los cabezales." .

ns1:CabezalMaster a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal master" ;
    ns1:textoExtracto "El CNC no puede sincronizar en lazo cerrado un cabezal master, si éste no ha sido previamente referenciado." .

ns1:SincronizacionLazoAbierto a ns1:ModoOperacion ;
    rdfs:label "Sincronización en lazo abierto (OLOOP)" ;
    ns1:textoExtracto "El usuario ha programado una sincronización en lazo abierto (OLOOP) para el cabezal maestro, pero éste estaba trabajando en lazo cerrado." .

