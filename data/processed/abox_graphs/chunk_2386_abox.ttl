@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:activaAlarma ns1:Fallo_3063,
        ns1:Fallo_3064 ;
    ns1:controla ns1:CabezalMaestro ;
    ns1:textoExtracto "El CNC informa del cambio" .

ns1:CabezalMaestro a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal maestro" ;
    ns1:textoExtracto "El cabezal maestro de la sincronización" .

ns1:Fallo_3063 a ns1:DiagnosticoFallo ;
    rdfs:label "El cabezal master de la sincronización pasa a lazo cerrado" ;
    ns1:identificador "3063" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El usuario ha programado una sincronización en lazo cerrado (CLOOP) para el cabezal maestro, pero éste estaba trabajando en lazo abierto. SOLUCIÓN El CNC informa del cambio; no es necesaria ninguna acción." .

ns1:Fallo_3064 a ns1:DiagnosticoFallo ;
    rdfs:label "El cabezal para roscar con G33/G34 debe de estar referenciado" ;
    ns1:identificador "3064" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA El cabezal utilizado en el roscado G33/G34 no está referenciado. SOLUCIÓN Si el CNC utiliza el cabezal master del canal, siempre realiza una búsqueda de referencia antes de G33/G34." .

