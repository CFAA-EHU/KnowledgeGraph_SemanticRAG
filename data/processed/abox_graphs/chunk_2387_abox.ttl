@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalMaster a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal master (canal CNC)"@es ;
    ns1:textoExtracto "Si el CNC utiliza el cabezal master del canal, siempre realiza una búsqueda de referencia antes de G33/G34."@es .

ns1:CabezalSync a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal marca SYNC"@es ;
    ns1:textoExtracto "Si el PLC selecciona otro cabezal (marca SYNC), realizar una búsqueda de referencia del cabezal."@es .

ns1:EncoderCabezal a ns1:Sensor ;
    rdfs:label "Encoder de velocidad del cabezal"@es ;
    ns1:monitoreaParametro ns1:Parametro_VelocidadGiro ;
    ns1:textoExtracto "el encóder instalado en el cabezal. Superar el umbral de velocidad del encóder supone un error en la lectura del contaje del cabezal."@es .

ns1:Error_3066 a ns1:AvisoSeguridad ;
    rdfs:label "Error en el seguimiento del eje tangencial sobre la trayectoria"@es ;
    ns1:identificador "3066" ;
    ns1:textoExtracto "3066 'Error en el seguimiento del eje tangencial sobre la trayectoria' DETECCIÓN Durante la ejecución."@es .

ns1:Funcion_G33_G34 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Funciones G33/G34 (roscado)"@es ;
    ns1:requiereMantenimiento ns1:Solucion_3065 ;
    ns1:textoExtracto "velocidad programada para la función G33/G34"@es .

ns1:Error_3065 a ns1:AvisoSeguridad ;
    rdfs:label "Velocidad de giro de cabezal programada para G33/G34 supera el umbral del encóder"@es ;
    ns1:identificador "3065" ;
    ns1:mitigaRiesgo ns1:Solucion_3065 ;
    ns1:textoExtracto "3065 'Velocidad de giro de cabezal programada para G33/G34 supera el umbral del encóder' DETECCIÓN Durante la ejecución. umbral permitido por CAUSA La velocidad programada para la función G33/G34 superó el el encóder instalado en el cabezal. Superar el umbral de velocidad del encóder supone un error en la lectura del contaje del cabezal."@es .

ns1:Parametro_VelocidadGiro a ns1:Parametro ;
    rdfs:label "Velocidad de giro programada para G33/G34"@es ;
    ns1:textoExtracto "La velocidad programada para la función G33/G34 superó el umbral permitido por el encóder instalado en el cabezal."@es ;
    ns1:valor "umbral_excedido"@es .

ns1:Solucion_3065 a ns1:DiagnosticoFallo ;
    rdfs:label "Referenciar cabezal tras superar umbral de velocidad en G33/G34"@es ;
    ns1:solucionaFallo ns1:Error_3065 ;
    ns1:textoExtracto "El CNC no permite ejecutar la G33/G34 con la velocidad programada, ya que no puede garantizar la validez de la rosca. Si el cabezal ha superado la velocidad umbral, el CNC necesita referenciar el cabezal para recuperar la cota."@es .

