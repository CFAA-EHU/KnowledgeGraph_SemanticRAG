@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error3066 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el seguimiento del eje tangencial sobre la trayectoria"@es ;
    ns1:identificador "3066" ;
    ns1:solucionaFallo ns1:ContactarConFAGORParaSolucion ;
    ns1:textoExtracto "3066 'Error en el seguimiento del eje tangencial sobre la trayectoria' DETECCIÓN Durante la ejecución. CAUSA El eje tangencial no está siguiendo fielmente la trayectoria del plano de trabajo."@es .

ns1:Error3067 a ns1:DiagnosticoFallo ;
    rdfs:label "G33/G34: Programación no permitida sin cabezal controlado en posición"@es ;
    ns1:identificador "3067" ;
    ns1:textoExtracto "3067 'G33/G34:Programación no permitida sin cabezal controlado en posición' DETECCIÓN Durante la ejecución. CAUSA La función programada necesita que el cabezal esté controlado en posición. El CNC no puede controlar el cabezal en posición porque éste"@es .

ns1:FuncionG33_G34 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G33/G34"@es ;
    ns1:identificador "G33/G34" ;
    ns1:requiereMantenimiento ns1:Cabezal ;
    ns1:textoExtracto "La función programada necesita que el cabezal esté controlado en posición."@es .

ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal controlado en posición"@es ;
    ns1:controla ns1:PosicionDelEjeTangencial ;
    ns1:textoExtracto "La función programada necesita que el cabezal esté controlado en posición."@es .

ns1:ContactarConFAGORParaSolucion a ns1:AccionProhibida ;
    rdfs:label "Contactar con FAGOR para solución"@es ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con FAGOR."@es .

ns1:PosicionDelEjeTangencial a ns1:Parametro ;
    rdfs:label "Posición del eje tangencial"@es ;
    ns1:textoExtracto "seguimiento del eje tangencial sobre la trayectoria"@es .

