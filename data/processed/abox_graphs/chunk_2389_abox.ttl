@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_3068 a ns1:DiagnosticoFallo ;
    rdfs:label "RETRACE finalizado, desactivar marca para continuar" ;
    ns1:identificador "3068" ;
    ns1:textoExtracto "3068 'RETRACE finalizado, desactivar marca para continuar' DETECCIÓN Durante la ejecución. CAUSA Tras finalizar la ejecución en retrace, la marca RETRACE del PLC sigue activa. SOLUCIÓN El PLC debe desactivar la marca RETRACE para que el programa continúe." .

ns1:Fallo_3069 a ns1:DiagnosticoFallo ;
    rdfs:label "Cambio de gama incorrecto, el regulador no responde" ;
    ns1:identificador "3069" ;
    ns1:textoExtracto "3069 Cambio de gama incorrecto, el regulador no responde. DETECCIÓN Durante la ejecución. CAUSA El CNC no ha finalizado correctamente el cambio de gama de un eje o cabezal porque el regulador no responde a la petición de cambio de gama. SOLUCIÓN Comprobar estado del regulador." ;
    ns1:tieneComponente ns1:Componente_Regulador .

ns1:Fallo_CabezalSinEncoder a ns1:DiagnosticoFallo ;
    rdfs:label "Cabezal sin encóder para control de posición" ;
    ns1:solucionaFallo ns1:Componente_Encoder ;
    ns1:textoExtracto "controlado en posición' DETECCIÓN Durante la ejecución. CAUSA La función programada necesita que el cabezal esté controlado en posición. El CNC no puede controlar el cabezal en posición porque éste no dispone de encóder. SOLUCIÓN El cabezal necesita un encóder. Póngase en contacto con su proveedor." ;
    ns1:tieneComponente ns1:Componente_Cabezal .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "El CNC no puede controlar el cabezal en posición porque éste no dispone de encóder." .

ns1:Componente_Encoder a ns1:ComponenteElectrico ;
    rdfs:label "Encóder" ;
    ns1:textoExtracto "El cabezal necesita un encóder." .

ns1:Componente_Regulador a ns1:ComponenteElectrico ;
    rdfs:label "Regulador" ;
    ns1:textoExtracto "el regulador no responde a la petición de cambio de gama." .

