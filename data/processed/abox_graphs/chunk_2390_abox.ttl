@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_3070 a ns1:DiagnosticoFallo ;
    rdfs:label "Velocidad del cabezal asociado a G33/G34/G95 nula"@es ;
    ns1:identificador "3070" ;
    ns1:solucionaFallo ns1:TareaMantenimiento_ComprobarEstadoRegulador_3070 ;
    ns1:textoExtracto "SOLUCIÓN Comprobar estado del regulador. 3070 'Velocidad del cabezal asociado a G33/G34/G95 nula' DETECCIÓN Durante la ejecución. CAUSA El cabezal asociado a la función G33, G34 o G95 está parado."@es .

ns1:Fallo_3071 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admiten S, ni funciones M o H con proceso de cambio de gama activo"@es ;
    ns1:identificador "3071" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_ContinuarEjecucionCambioGama_3071 ;
    ns1:textoExtracto "3071 'No se admiten S, ni funciones M o H con proceso de cambio de gama activo' DETECCIÓN Durante la ejecución. CAUSA El usuario ha interrumpido el programa durante el cambio de gama y ha intentado cambiar las funciones S, M ó H desde el modo MHFS."@es .

ns1:Funcion_G33 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G33" ;
    ns1:identificador "G33" ;
    ns1:textoExtracto "El cabezal asociado a la función G33, G34 o G95 está parado."@es .

ns1:Funcion_G34 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G34" ;
    ns1:identificador "G34" ;
    ns1:textoExtracto "El cabezal asociado a la función G33, G34 o G95 está parado."@es .

ns1:Funcion_G95 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G95" ;
    ns1:identificador "G95" ;
    ns1:textoExtracto "El cabezal asociado a la función G33, G34 o G95 está parado."@es .

ns1:ModoOperacion_MHFS a ns1:ModoOperacion ;
    rdfs:label "Modo MHFS" ;
    ns1:textoExtracto "El usuario ha interrumpido el programa durante el cambio de gama y ha intentado cambiar las funciones S, M ó H desde el modo MHFS."@es .

ns1:Parametro_VelocidadCabezal a ns1:Parametro ;
    rdfs:label "Velocidad del cabezal"@es ;
    ns1:monitoreaParametro ns1:Componente_CabezalMaster ;
    ns1:textoExtracto "Comprobar la velocidad del cabezal asociado a estas funciones, que será el cabezal master del canal o el cabezal indicado en el registro SYNC, asociado al canal."@es .

ns1:AvisoSeguridad_ContinuarEjecucionCambioGama_3071 a ns1:AvisoSeguridad ;
    rdfs:label "Continuar ejecución hasta finalizar cambio de gama"@es ;
    ns1:textoExtracto "SOLUCIÓN Continuar la ejecución hasta que finalice el cambio de gama. A continuación interrumpir el programa y enviar las funciones deseadas al cabezal."@es .

ns1:Componente_CabezalMaster a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal master del canal"@es ;
    ns1:textoExtracto "el cabezal master del canal o el cabezal indicado en el registro SYNC, asociado al canal."@es .

ns1:TareaMantenimiento_ComprobarEstadoRegulador_3070 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar estado del regulador"@es ;
    ns1:textoExtracto "SOLUCIÓN Comprobar estado del regulador."@es .

