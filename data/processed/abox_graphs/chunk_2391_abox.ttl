@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_3072 a ns1:DiagnosticoFallo ;
    rdfs:label "Paso y S de cabezal programados para G33/G34 superan avance máximo permitido" ;
    ns1:identificador "3072" ;
    ns1:solucionaFallo ns1:Accion_RevisarProgramacionG33G34 ;
    ns1:textoExtracto "3072 'Paso y S de cabezal programados para G33/G34 superan avance máximo permitido' DETECCIÓN Durante la ejecución. CAUSA Al empezar un roscado G33/G34, el CNC ha detectado que el paso y la velocidad programados implican un avance que supera el máximo permitido. El avance máximo puede estar limitado por los parámetros máquina o por PLC." .

ns1:Accion_RevisarProgramacionG33G34 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Revisar la programación de la función G33/G34. Para mantener el paso programado," .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    ns1:controla ns1:Parametro_AvanceMaximo ;
    ns1:textoExtracto "Paso y S de cabezal programados para G33/G34" .

ns1:Maquina_CNC a ns1:Maquina ;
    ns1:textoExtracto "el CNC ha detectado que el paso y la velocidad programados implican un avance que supera el máximo permitido." ;
    ns1:tieneComponente ns1:Componente_Cabezal .

ns1:Parametro_AvanceMaximo a ns1:Parametro ;
    ns1:monitoreaParametro ns1:Maquina_CNC ;
    ns1:textoExtracto "El avance máximo puede estar limitado por los parámetros máquina o por PLC." .

