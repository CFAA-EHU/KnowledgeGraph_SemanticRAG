@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_3075 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 3075: Eje desactivado en grupo multieje" ;
    ns1:solucionaFallo ns1:Alarma_3075 ;
    ns1:textoExtracto "SOLUCIÓN Activar el eje para poder moverlo (marca SWITCH del PLC)." .

ns1:DiagnosticoFallo_3076 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 3076: RETRACE activo en modo MHFS" ;
    ns1:solucionaFallo ns1:Alarma_3076 ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la marca RETRACE del PLC antes de salir del modo MHFS." .

ns1:DiagnosticoFallo_3077 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico para alarma 3077: Bloque a Bloque no admitido en RETRACE" ;
    ns1:solucionaFallo ns1:Alarma_3077 ;
    ns1:textoExtracto "SOLUCIÓN Desactivar Bloque a Bloque" .

ns1:ModoOperacion_BloqueABloque a ns1:ModoOperacion ;
    rdfs:label "Modo de operación Bloque a Bloque" ;
    ns1:textoExtracto "Se ha intentado activar el modo bloque a bloque durante el retrace" .

ns1:ModoOperacion_MHFS a ns1:ModoOperacion ;
    rdfs:label "Modo de operación MHFS" ;
    ns1:textoExtracto "El usuario ha intentado salir del modo MHFS mientras la marca RETRACE del PLC está activa" .

ns1:Parametro_RETRACE_PLC a ns1:Parametro ;
    rdfs:label "Marca RETRACE del PLC" ;
    ns1:monitoreaParametro ns1:Alarma_3076 ;
    ns1:textoExtracto "la marca RETRACE del PLC está activa" .

ns1:Parametro_SWITCH_PLC a ns1:Parametro ;
    rdfs:label "Marca SWITCH del PLC" ;
    ns1:monitoreaParametro ns1:Alarma_3075 ;
    ns1:textoExtracto "Activar el eje para poder moverlo (marca SWITCH del PLC)" .

ns1:Sistema_MotionControl a ns1:Sistema ;
    rdfs:label "Sistema de Motion Control" ;
    ns1:activaAlarma ns1:Alarma_3075 ;
    ns1:textoExtracto "Deshabilitar las funciones de motion control antes de cambiar el sistema de coordenadas o la transformación de coordenadas" .

ns1:Alarma_3077 a ns1:Alarma ;
    rdfs:label "Alarma 3077: No se admite Bloque a Bloque en este proceso de RETRACE" ;
    ns1:identificador "3077" ;
    ns1:textoExtracto "'No se admite Bloque a Bloque en este proceso de RETRACE; desactivar Bloque a Bloque' DETECCIÓN Durante la ejecución. CAUSA Se ha intentado activar el modo bloque a bloque durante el retrace, en un programa con muchos bloques con movimientos muy cortos." .

ns1:Alarma_3076 a ns1:Alarma ;
    rdfs:label "Alarma 3076: No es posible salir de MHFS con Retrace activo" ;
    ns1:identificador "3076" ;
    ns1:textoExtracto "'No es posible salir de MHFS con Retrace activo. Desactivar' DETECCIÓN Durante la ejecución. CAUSA El usuario ha intentado salir del modo MHFS mientras la marca RETRACE del PLC está activa" .

ns1:Alarma_3075 a ns1:Alarma ;
    rdfs:label "Alarma 3075: Eje múltiple desactivado" ;
    ns1:identificador "3075" ;
    ns1:textoExtracto "'Eje múltiple desactivado' DETECCIÓN Durante la ejecución. multieje y está desactivado. CAUSA El eje no se puede mover porque pertenece a un grupo" .

