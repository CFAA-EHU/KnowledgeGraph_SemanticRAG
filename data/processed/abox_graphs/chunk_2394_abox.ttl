@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_SaturacionRecursos a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia de saturación de recursos en modo bloque a bloque"@es ;
    ns1:mitigaRiesgo ns1:Fallo_3078 ;
    ns1:textoExtracto "Para evitar saturar los recursos del sistema, el CNC no permite la función bloque a bloque en este tipo de programas"@es .

ns1:ModoOperacion_BloqueABloque a ns1:ModoOperacion ;
    rdfs:label "Modo bloque a bloque"@es ;
    ns1:textoExtracto "modo bloque a bloque"@es .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:activaAlarma ns1:Fallo_3078 ;
    ns1:controla ns1:Componente_CabezalMaster ;
    ns1:textoExtracto "el CNC no permite la función bloque a bloque en este tipo de programas"@es .

ns1:Componente_CabezalMaster a ns1:Componente ;
    rdfs:label "Cabezal master de sincronización"@es ;
    ns1:textoExtracto "El cabezal master de la sincronización"@es .

ns1:Fallo_3078 a ns1:DiagnosticoFallo ;
    rdfs:label "El cabezal master de la sincronización no pasa a lazo abierto"@es ;
    ns1:identificador "3078" ;
    ns1:textoExtracto "3078 'El cabezal master de la sincronización no pasa a lazo abierto'"@es .

