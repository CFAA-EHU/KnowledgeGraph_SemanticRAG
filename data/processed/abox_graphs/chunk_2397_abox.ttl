@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_3083 a ns1:DiagnosticoFallo ;
    rdfs:label "No es posible tanto retardo para activar la salida digital" ;
    ns1:identificador "3083" ;
    ns1:monitoreaParametro ns1:Parametro_TON_TOF ;
    ns1:textoExtracto "3083 'No es posible tanto retardo para activar la salida digital' DETECCIÓN Durante la ejecución del corte por láser (conmutación sincronizada). CAUSA El retardo programado para el láser es excesivo. SOLUCIÓN Revisar el valor de los parámetros de anticipación TON / TOF." .

ns1:Fallo_3084 a ns1:DiagnosticoFallo ;
    rdfs:label "Error del driver en la activación/desactivación del láser" ;
    ns1:identificador "3084" ;
    ns1:monitoreaParametro ns1:Parametro_NLOCOUT ;
    ns1:solucionaFallo ns1:Solucion_PlacaSercos ;
    ns1:textoExtracto "3084 'Error del driver en la activación/desactivación del láser' DETECCIÓN Durante la ejecución del corte por láser (conmutación sincronizada). CAUSA No se cumplen las condiciones hardware o de parametrización necesarias para poder utilizar la prestación de corte por láser. SOLUCIÓN Verificar las siguientes condiciones: • Debe existir una placa de expansión tipo Sercos, con ID software igual o superior a 1.2. • El parámetro NLOCOUT debe ser 8." .

ns1:Fallo_CicloInsuficiente a ns1:DiagnosticoFallo ;
    rdfs:label "Margen insuficiente de ciclos para la anticipación" ;
    ns1:monitoreaParametro ns1:Parametro_TiempoCiclo ;
    ns1:textoExtracto "no queda margen suficiente de ciclos para la anticipación. SOLUCIÓN Disminuir el tiempo de ciclo o el valor de los parámetros de anticipación." .

ns1:Parametro_NLOCOUT a ns1:Parametro ;
    rdfs:label "Parámetro NLOCOUT" ;
    ns1:textoExtracto "El parámetro NLOCOUT debe ser 8." ;
    ns1:valor "8" .

ns1:Parametro_TON_TOF a ns1:Parametro ;
    rdfs:label "Parámetros de anticipación TON/TOF" ;
    ns1:textoExtracto "Revisar el valor de los parámetros de anticipación TON / TOF." ;
    ns1:valor "TON/TOF" .

ns1:Parametro_TiempoCiclo a ns1:Parametro ;
    rdfs:label "Tiempo de ciclo" ;
    ns1:textoExtracto "Disminuir el tiempo de ciclo o el valor de los parámetros de anticipación." .

ns1:Solucion_PlacaSercos a ns1:ComponenteElectrico ;
    rdfs:label "Placa de expansión tipo Sercos" ;
    ns1:identificador "Sercos v1.2+" ;
    ns1:textoExtracto "Debe existir una placa de expansión tipo Sercos, con ID software igual o superior a 1.2." .

