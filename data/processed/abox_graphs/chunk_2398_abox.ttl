@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_CambioPlanoEjecucionSimulada a ns1:AccionProhibida ;
    rdfs:label "Cambio de plano durante ejecución simulada" ;
    ns1:mitigaRiesgo ns1:AvisoSeguridad_3086 ;
    ns1:textoExtracto "No se admite cambio de ejes del plano activo en modo ejecución simulada: Plano Principal." .

ns1:DiagnosticoFallo_3087 a ns1:DiagnosticoFallo ;
    rdfs:label "'PWM activado en otro canal'" ;
    ns1:identificador "3087" ;
    ns1:textoExtracto "'PWM activado en otro canal' DETECCIÓN Durante la ejecución del corte por láser (PWM). CAUSA La prestación PWM ya está activada en un canal diferente al que se desea. SOLUCIÓN Revisar la programación del PWM." .

ns1:DiagnosticoFallo_3088 a ns1:DiagnosticoFallo ;
    rdfs:label "'Error en la programación de la máscara del láser'" ;
    ns1:identificador "3088" ;
    ns1:textoExtracto "'Error en la programación de la máscara del láser' DETECCIÓN Durante la ejecución del corte por láser (conmutación sincronizada). CAUSA No se cumplen las condiciones hardware o de parametrización necesarias para poder utilizar la prestación de corte por láser." .

ns1:ModoOperacion_CorteLaserConmutacionSincronizada a ns1:ModoOperacion ;
    rdfs:label "Corte por láser (conmutación sincronizada)" ;
    ns1:textoExtracto "Durante la ejecución del corte por láser (conmutación sincronizada)." .

ns1:ModoOperacion_CorteLaserPWM a ns1:ModoOperacion ;
    rdfs:label "Corte por láser (PWM)" ;
    ns1:textoExtracto "Durante la ejecución del corte por láser (PWM)." .

ns1:ModoOperacion_EjecucionSimulada a ns1:ModoOperacion ;
    rdfs:label "Modo ejecución simulada" ;
    ns1:textoExtracto "No se admite cambio de ejes del plano activo en modo ejecución simulada: Plano Principal." .

ns1:Parametro_NLOCOUT a ns1:Parametro ;
    rdfs:label "NLOCOUT" ;
    ns1:textoExtracto "El parámetro NLOCOUT debe ser 8." ;
    ns1:valor "8" .

ns1:Parametro_PWMOUTPUT a ns1:Parametro ;
    rdfs:label "PWMOUTPUT" ;
    ns1:textoExtracto "El parámetro PWMOUTPUT no puede ser superior a 2 (0, 1, 2)." ;
    ns1:valor "0, 1, 2" .

ns1:AvisoSeguridad_3086 a ns1:AvisoSeguridad ;
    rdfs:label "Cambio de ejes del plano activo en modo ejecución simulada" ;
    ns1:identificador "3086" ;
    ns1:textoExtracto "No se admite cambio de ejes del plano activo en modo ejecución simulada: Plano Principal. DETECCIÓN Durante la ejecución simulada. CAUSA Se ha realizado un cambio de plano durante la ejecución simulada. SOLUCIÓN Revisar la programación." .

