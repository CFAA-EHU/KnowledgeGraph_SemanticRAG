@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:ActivateToolOrientation a ns1:Actuador ;
    ns1:activaAlarma ns1:MachiningCoordinateSystem ;
    ns1:identificador "CSROT ON" ;
    ns1:textoExtracto "Activate tool orientation in the part coordinate system." .

ns1:CAxis a ns1:Actuador ;
    ns1:activaAlarma ns1:MachiningCoordinateSystem ;
    ns1:identificador "CYL" ;
    ns1:textoExtracto "\"C\" axis. Machining of the turning side of the part." .

ns1:CancelToolOrientation a ns1:Actuador ;
    ns1:activaAlarma ns1:MachiningCoordinateSystem ;
    ns1:identificador "CSROT OFF" ;
    ns1:textoExtracto "Cancel tool orientation in the part coordinate system." .

ns1:DefineMacro a ns1:Actuador ;
    ns1:activaAlarma ns1:MachiningCoordinateSystem ;
    ns1:identificador "DEF" ;
    ns1:textoExtracto "Macros. Define a macro." .

ns1:MachiningCoordinateSystem a ns1:Sistema ;
    ns1:identificador "CS" ;
    ns1:textoExtracto "Machining coordinate system." .

