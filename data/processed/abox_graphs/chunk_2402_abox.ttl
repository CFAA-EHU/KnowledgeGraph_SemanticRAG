@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Herramienta_3000_3999 a ns1:Herramienta ;
    ns1:textoExtracto "Si la herramienta está dentro de la zona prohibida"@es .

ns1:SistemaControl_3000_3999 a ns1:Sistema ;
    rdfs:label "Sistema de control por programa/PLC"@es ;
    ns1:controla ns1:ZonaProhibida_3000_3999 ;
    ns1:textoExtracto "La zona puede estar definida por programa ó por PLC (mediante las variables relativas a zonas de trabajo)"@es .

ns1:Solucion_DesactivarZonaProhibida a ns1:AvisoSeguridad ;
    rdfs:label "Solución: Desactivar zona prohibida temporalmente"@es ;
    ns1:mitigaRiesgo ns1:ZonaProhibida_3000_3999 ;
    ns1:textoExtracto "desactivar temporalmente dicha zona, mover el eje en el sentido adecuado"@es .

ns1:ZonaProhibida_3000_3999 a ns1:AccionProhibida ;
    rdfs:label "Zona de no entrada"@es ;
    ns1:identificador "3000-3999" ;
    ns1:textoExtracto "zona de trabajo de no entrada"@es .

