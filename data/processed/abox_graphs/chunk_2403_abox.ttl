@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_3094 a ns1:DiagnosticoFallo ;
    rdfs:label "Sensor detecta distancia negativa" ;
    ns1:identificador "3094" ;
    ns1:textoExtracto "3094 El sensor detecta distancia negativa. DETECCIÓN Durante la ejecución. CAUSA Con el control de gap activo, el sensor muestra distancia negativa. SOLUCIÓN Revisar la calibración del sensor." .

ns1:Fallo_3095 a ns1:DiagnosticoFallo ;
    rdfs:label "Punto final mal programado en #GAPCTRL o #LEAP" ;
    ns1:identificador "3095" ;
    ns1:textoExtracto "3095 Punto final mal programado en #GAPCTRL o #LEAP. DETECCIÓN Durante la ejecución. CAUSA Durante la sentencia #GAPCTRL o #LEAP, el CNC no puede corregir la posición tras recibir la señal del sensor. SOLUCIÓN Comprobar que el punto final indicado en las sentencias #GAPCTRL o #LEAP es correcto." .

ns1:Fallo_3096 a ns1:DiagnosticoFallo ;
    rdfs:label "PWRCTRL DUTY activado en otro canal" ;
    ns1:identificador "3096" ;
    ns1:textoExtracto "3096 PWRCTRL DUTY activado en otro canal. DETECCIÓN Durante la ejecución." .

ns1:Herramienta_Desconocida a ns1:Herramienta ;
    rdfs:label "Herramienta en zona de trabajo" ;
    ns1:textoExtracto "Si la herramienta está dentro de la zona prohibida" .

ns1:Interfaz_TecladoJog a ns1:InterfazUsuario ;
    rdfs:label "Teclado de jog" ;
    ns1:textoExtracto "mover el eje en el sentido adecuado mediante el teclado de jog" .

ns1:Parametro_PWRCTRL_DUTY a ns1:Parametro ;
    rdfs:label "Parámetro PWRCTRL DUTY" ;
    ns1:textoExtracto "PWRCTRL DUTY activado en otro canal" .

ns1:Parametro_PuntoFinal_GAPCTRL a ns1:Parametro ;
    rdfs:label "Punto final en sentencia #GAPCTRL" ;
    ns1:textoExtracto "punto final indicado en las sentencias #GAPCTRL" .

ns1:Parametro_PuntoFinal_LEAP a ns1:Parametro ;
    rdfs:label "Punto final en sentencia #LEAP" ;
    ns1:textoExtracto "punto final indicado en las sentencias #LEAP" .

ns1:Sensor_3094 a ns1:Sensor ;
    rdfs:label "Sensor de control de gap" ;
    ns1:monitoreaParametro ns1:Parametro_DistanciaGap ;
    ns1:textoExtracto "el sensor muestra distancia negativa" .

ns1:ZonaProhibida_Ejes a ns1:AccionProhibida ;
    rdfs:label "Zona de no entrada para ejes" ;
    ns1:textoExtracto "ejes fuera de los límites de la zona de trabajo de no entrada. Si la herramienta está dentro de la zona prohibida, desactivar temporalmente dicha zona, mover el eje en el sentido adecuado mediante el teclado de jog hasta que salga de la zona prohibida y volver a activar la zona de no entrada." .

ns1:Parametro_DistanciaGap a ns1:Parametro ;
    rdfs:label "Distancia de gap" ;
    ns1:textoExtracto "control de gap activo" .

