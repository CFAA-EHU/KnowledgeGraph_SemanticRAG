@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_3096 a ns1:Alarma ;
    rdfs:label "PWRCTRL DUTY activado en otro canal" ;
    ns1:identificador "3096" ;
    ns1:monitoreaParametro ns1:Parametro_PWRCTRL_DUTY ;
    ns1:textoExtracto "PWRCTRL DUTY activado en otro canal. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado activar #PWRCTRL DUTY en un canal mientras está activo en otro. SOLUCIÓN El #PWRCTRL DUTY sólo puede estar activo en un canal." .

ns1:Alarma_3097 a ns1:Alarma ;
    rdfs:label "PWRCTRL OUT activado en otro canal" ;
    ns1:identificador "3097" ;
    ns1:monitoreaParametro ns1:Parametro_PWRCTRL_OUT ;
    ns1:textoExtracto "PWRCTRL OUT activado en otro canal. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado activar #PWRCTRL OUT en un canal mientras está activo en otro. SOLUCIÓN El #PWRCTRL OUT sólo puede estar activo en un canal." .

ns1:Alarma_3098 a ns1:Alarma ;
    rdfs:label "PWRCTRL DUTY requiere PWM activo en el mismo canal" ;
    ns1:identificador "3098" ;
    ns1:monitoreaParametro ns1:Parametro_PWM,
        ns1:Parametro_PWRCTRL_DUTY ;
    ns1:textoExtracto "PWRCTRL DUTY requiere PWM activo en el mismo canal. DETECCIÓN Durante la ejecución. CAUSA Se ha intentado activar #PWRCTRL DUTY en un canal sin haber activado previamente el PWM en el mismo canal. SOLUCIÓN Activar el PWM antes de activar #PWRCTRL DUTY." .

ns1:Alarma_3099 a ns1:Alarma ;
    rdfs:label "LEAP no activado por altura de salto inferior a un mínimo" ;
    ns1:identificador "3099" ;
    ns1:monitoreaParametro ns1:Parametro_LEAP ;
    ns1:textoExtracto "LEAP no activado por altura de salto inferior a un mínimo. DETECCIÓN Durante la ejecución." .

ns1:Parametro_LEAP a ns1:Parametro ;
    rdfs:label "LEAP" ;
    ns1:identificador "LEAP" ;
    ns1:textoExtracto "LEAP" .

ns1:Parametro_PWM a ns1:Parametro ;
    rdfs:label "PWM" ;
    ns1:identificador "PWM" ;
    ns1:textoExtracto "PWM" .

ns1:Parametro_PWRCTRL_OUT a ns1:Parametro ;
    rdfs:label "PWRCTRL OUT" ;
    ns1:identificador "#PWRCTRL OUT" ;
    ns1:textoExtracto "#PWRCTRL OUT" .

ns1:Parametro_PWRCTRL_DUTY a ns1:Parametro ;
    rdfs:label "PWRCTRL DUTY" ;
    ns1:identificador "#PWRCTRL DUTY" ;
    ns1:textoExtracto "#PWRCTRL DUTY" .

