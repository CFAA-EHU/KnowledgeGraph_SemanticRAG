@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_3099 a ns1:DiagnosticoFallo ;
    rdfs:label "LEAP no activado por altura de salto inferior a un mínimo"@es ;
    ns1:identificador "3099" ;
    ns1:textoExtracto "3099 LEAP no activado por altura de salto inferior a un mínimo. DETECCIÓN Durante la ejecución. CAUSA La altura máxima del salto es muy cercana a la posición inicial. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_3100 a ns1:DiagnosticoFallo ;
    rdfs:label "'Potencia excesiva en el cabezal detectada durante DMC'"@es ;
    ns1:identificador "3100" ;
    ns1:solucionaFallo ns1:Herramienta_Gastada,
        ns1:Pieza_Colision ;
    ns1:textoExtracto "3100 'Potencia excesiva en el cabezal detectada durante DMC' DETECCIÓN Durante la ejecución. CAUSA El DMC ha detectado un consumo de potencia (variable TV51 del regulador) excesivo durante cierto tiempo. Esto puede indicar que la herramienta está gastada, deteriorada o que ha colisionado con la pieza."@es .

ns1:Regulador_DMC a ns1:ComponenteElectrico ;
    rdfs:label "Regulador DMC"@es ;
    ns1:identificador "DMC" ;
    ns1:monitoreaParametro ns1:Parametro_TV51 ;
    ns1:textoExtracto "variable TV51 del regulador"@es .

ns1:Herramienta_Gastada a ns1:Herramienta ;
    rdfs:label "Herramienta gastada o deteriorada"@es ;
    ns1:textoExtracto "Esto puede indicar que la herramienta está gastada, deteriorada o que ha colisionado con la pieza."@es .

ns1:Parametro_TV51 a ns1:Parametro ;
    rdfs:label "TV51 (consumo de potencia del regulador)"@es ;
    ns1:identificador "TV51" ;
    ns1:textoExtracto "variable TV51 del regulador"@es .

ns1:Pieza_Colision a ns1:Consumible ;
    rdfs:label "Pieza afectada por colisión"@es ;
    ns1:textoExtracto "que ha colisionado con la pieza"@es .

