@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalMecanizado a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de mecanizado"@es ;
    ns1:compuestoPor ns1:SistemaDMC ;
    ns1:textoExtracto "Potencia excesiva en el cabezal detectada"@es .

ns1:HerramientaMecanizado a ns1:Herramienta ;
    rdfs:label "Herramienta de mecanizado"@es ;
    ns1:requiereMantenimiento ns1:TareaRevisionHerramienta ;
    ns1:textoExtracto "la herramienta está gastada, deteriorada o que ha colisionado con la pieza"@es .

ns1:ModoInspeccionHerramienta a ns1:ModoOperacion ;
    rdfs:label "Modo inspección de herramienta"@es ;
    ns1:habilitadoPor ns1:AlertaPotenciaExcesiva_3101 ;
    ns1:textoExtracto "entrar en modo inspección de herramienta"@es .

ns1:SistemaDMC a ns1:Sistema ;
    rdfs:label "Sistema DMC (Control Numérico)"@es ;
    ns1:activaAlarma ns1:AlertaPotenciaExcesiva_3101 ;
    ns1:controla ns1:VariableTV51 ;
    ns1:textoExtracto "El DMC ha detectado que la potencia instantánea [...] por lo que el CNC detiene los ejes manteniendo el giro del cabezal."@es .

ns1:TareaRevisionHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de herramienta y programación"@es ;
    ns1:solucionaFallo ns1:AlertaPotenciaExcesiva_3101 ;
    ns1:textoExtracto "SOLUCIÓN Revisar la herramienta y/o la programación de la pasada de profundización y la pasada radial."@es .

ns1:VariableTV51 a ns1:Parametro ;
    rdfs:label "Variable TV51 (potencia instantánea del regulador)"@es ;
    ns1:identificador "TV51" ;
    ns1:monitoreaParametro ns1:AlertaPotenciaExcesiva_3101 ;
    ns1:textoExtracto "variable TV51 del regulador"@es .

ns1:AlertaPotenciaExcesiva_3101 a ns1:AvisoSeguridad ;
    rdfs:label "Alerta 3101: Potencia excesiva en el cabezal"@es ;
    ns1:identificador "3101" ;
    ns1:textoExtracto "3101 'Potencia excesiva en el cabezal detectada durante DMC.Pulse MARCHA para continuar' DETECCIÓN Durante la ejecución. CAUSA El DMC ha detectado que la potencia instantánea (variable TV51 del regulador) ha superado la potencia objetivo en un rango prefijado."@es .

