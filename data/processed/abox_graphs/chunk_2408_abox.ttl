@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoColision_3104 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de colisión 3104"@es ;
    ns1:identificador "3104" ;
    ns1:mitigaRiesgo ns1:FuncionDMC_3104 ;
    ns1:textoExtracto "3104 Se ha detectado una colisión. DETECCIÓN Durante la ejecución o la simulación de un programa pieza."@es .

ns1:ProgramaPieza_3000 a ns1:InterfazUsuario ;
    rdfs:label "Programa pieza"@es ;
    ns1:controla ns1:FuncionDMC_3104 ;
    ns1:textoExtracto "Durante la ejecución o la simulación de un programa pieza."@es .

ns1:FuncionDMC_3104 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función DMC"@es ;
    ns1:identificador "DMC" ;
    ns1:textoExtracto "En este caso se recomienda desactivar la función DMC en este mecanizado. Programar una potencia objetivo mayor, que no se va a alcanzar realmente, puede tener como consecuencia que el DMC no detecte nunca entradas a la pieza, y realice todo el mecanizado como si la herramienta trabajara en vacío."@es .

