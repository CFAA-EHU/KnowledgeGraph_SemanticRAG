@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_ABORT a ns1:Parametro ;
    rdfs:label "Marca ABORT (abortar operaciones pendientes)"@es ;
    ns1:mitigaRiesgo ns1:Error_3403 ;
    ns1:textoExtracto "abortar las sentencias pendientes (marca ABORT)"@es .

ns1:Marca_BUSY a ns1:Parametro ;
    rdfs:label "Marca BUSY (estado de interpolador independiente)"@es ;
    ns1:monitoreaParametro ns1:Error_3403 ;
    ns1:textoExtracto "Para saber si el interpolador independiente ha terminado todas las operaciones, consultar la marca BUSY."@es .

ns1:Marca_FREE a ns1:Parametro ;
    rdfs:label "Marca FREE (espacio disponible para operaciones)"@es ;
    ns1:mitigaRiesgo ns1:Error_3403 ;
    ns1:textoExtracto "esperar a que haya espacio para almacenarla (marca FREE)"@es .

ns1:Error_3403 a ns1:AvisoSeguridad ;
    rdfs:label "Error 3403: No se admiten más operaciones con ejes independientes. En sincronización"@es ;
    ns1:identificador "3403" ;
    ns1:textoExtracto "3403 'No se admiten mas operaciones con ejes independientes. En sincronización'"@es .

