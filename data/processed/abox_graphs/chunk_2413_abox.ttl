@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ControlEjes a ns1:Sistema ;
    rdfs:label "Sistema de control de ejes (PLC/software)"@es ;
    ns1:monitoreaParametro ns1:Parametro_LimiteSoftwareEje ;
    ns1:solucionaFallo ns1:Fallo_3408 ;
    ns1:textoExtracto "Comprobar que los límites de software son correctos, que no han sido modificados desde el programa pieza o PLC."@es .

ns1:Fallo_3408 a ns1:DiagnosticoFallo ;
    rdfs:label "Cota programada para eje independiente inferior al límite negativo"@es ;
    ns1:identificador "3408" ;
    ns1:textoExtracto "3408 'Cota programada para eje independiente inferior al límite negativo' DETECCIÓN Durante la ejecución. CAUSA La cota programada en la sentencia #MOVE está fuera de los límites de software."@es .

ns1:Parametro_LimiteSoftwareEje a ns1:Parametro ;
    rdfs:label "Límite de software para eje"@es ;
    ns1:textoExtracto "Los ejes deben estar siempre dentro de los límites de software. Comprobar que los límites de software son correctos, que no han sido modificados desde el programa pieza o PLC."@es .

