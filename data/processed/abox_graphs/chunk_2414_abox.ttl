@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_LimiteSoftware a ns1:Parametro ;
    rdfs:label "Límites de software del CNC"@es ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "Los ejes deben estar siempre dentro de los límites de software. Comprobar que los límites de software son correctos..."@es .

ns1:AccionProhibida_3408_ModificacionLimites a ns1:AccionProhibida ;
    rdfs:label "Modificación no autorizada de límites de software desde programa pieza o PLC"@es ;
    ns1:textoExtracto "Comprobar que los límites de software son correctos, que no han sido modificados desde el programa pieza o PLC."@es .

ns1:AccionProhibida_3409_EjecucionEjeInvalido a ns1:AccionProhibida ;
    rdfs:label "Ejecución de operaciones en ejes gantry/acoplados/transformados sin desactivar acoplamientos"@es ;
    ns1:textoExtracto "El CNC intenta ejecutar una operación de eje independiente en la que interviene un eje que depende de otros o del que dependen otros (por ejemplo ejes gantry, acoplados o que forman parte de una transformación)."@es .

ns1:AvisoSeguridad_3408 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 3408: 'Cota inferior al límite negativo'"@es ;
    ns1:identificador "3408" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_3408_ModificacionLimites ;
    ns1:textoExtracto "inferior al límite negativo' DETECCIÓN Durante la ejecución. CAUSA La cota programada en la sentencia #MOVE está fuera de los límites de software. SOLUCIÓN Los ejes deben estar siempre dentro de los límites de software. Comprobar que los límites de software son correctos, que no han sido modificados desde el programa pieza o PLC."@es .

ns1:AvisoSeguridad_3409 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 3409: 'El eje no es válido como eje independiente'"@es ;
    ns1:identificador "3409" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_3409_EjecucionEjeInvalido ;
    ns1:textoExtracto "3409 'El eje no es válido como eje independiente' DETECCIÓN Durante la ejecución. CAUSA El CNC intenta ejecutar una operación de eje independiente en la que interviene un eje que depende de otros o del que dependen otros (por ejemplo ejes gantry, acoplados o que forman parte de una transformación) o bien porque es un eje visualizador, o es módulo y el límite inferior del módulo es negativo."@es .

ns1:AvisoSeguridad_3410 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 3410: 'Tiempo máximo de sincronización superado'"@es ;
    ns1:identificador "3410" ;
    ns1:textoExtracto "3410 'Se ha superado el tiempo máximo permitido para sincronizar' DETECCIÓN Durante la ejecución."@es .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:activaAlarma ns1:AvisoSeguridad_3408,
        ns1:AvisoSeguridad_3409,
        ns1:AvisoSeguridad_3410 ;
    ns1:textoExtracto "El CNC intenta ejecutar una operación de eje independiente..."@es .

