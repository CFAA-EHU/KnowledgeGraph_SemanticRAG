@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_3410 a ns1:Alarma ;
    rdfs:label "Se ha superado el tiempo máximo permitido para sincronizar" ;
    ns1:identificador "3410" ;
    ns1:monitoreaParametro ns1:Parametro_TiempoSincronizacion ;
    ns1:textoExtracto "3410 'Se ha superado el tiempo máximo permitido para sincronizar' DETECCIÓN Durante la ejecución. CAUSA La sincronización no alcanza la posición deseada en el tiempo definido. SOLUCIÓN Aumentar el tiempo de sincronización, comenzar la sincronización a velocidades más parecidas o aumentar la aceleración del esclavo." .

ns1:Alarma_3411 a ns1:Alarma ;
    rdfs:label "Se intenta superar la velocidad máxima MAXFEED" ;
    ns1:identificador "3411" ;
    ns1:monitoreaParametro ns1:Parametro_VelocidadMaestra ;
    ns1:textoExtracto "3411 'Se intenta superar la velocidad máxima MAXFEED' DETECCIÓN Durante la ejecución. CAUSA Hay programado un movimiento de eje independiente con una sincronización activa y la suma de ambas componentes de velocidad supera la máxima permitida del eje. SOLUCIÓN Si la velocidad del eje maestro es alta, hay que programar el movimiento adicional con una velocidad más pequeña." .

ns1:Alarma_3412 a ns1:Alarma ;
    rdfs:label "No se puede programar denominador 0 en sincronización" ;
    ns1:identificador "3412" ;
    ns1:monitoreaParametro ns1:Parametro_RatioTransmision ;
    ns1:textoExtracto "3412 'No se puede programar denominador 0 en sincronización' DETECCIÓN Durante la ejecución. CAUSA En la sincronización, el denominador del ratio de transmisión tiene valor cero. SOLUCIÓN El denominador del ratio no puede valer cero." .

ns1:Parametro_RatioTransmision a ns1:Parametro ;
    rdfs:label "Denominador del ratio de transmisión" ;
    ns1:textoExtracto "En la sincronización, el denominador del ratio de transmisión tiene valor cero" ;
    ns1:valor "0" .

ns1:Parametro_TiempoSincronizacion a ns1:Parametro ;
    rdfs:label "Tiempo de sincronización" ;
    ns1:textoExtracto "Aumentar el tiempo de sincronización" ;
    ns1:valor "Tiempo máximo permitido para sincronizar" .

ns1:Parametro_VelocidadMaestra a ns1:Parametro ;
    rdfs:label "Velocidad del eje maestro" ;
    ns1:textoExtracto "Si la velocidad del eje maestro es alta, hay que programar el movimiento adicional con una velocidad más pequeña" ;
    ns1:valor "Velocidad máxima MAXFEED" .

