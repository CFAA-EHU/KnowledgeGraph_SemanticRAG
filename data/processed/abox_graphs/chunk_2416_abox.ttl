@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:SistemaSincronizacionPosicion a ns1:Sistema ;
    rdfs:label "Sistema de sincronización en posición"@es ;
    ns1:activaAlarma ns1:FalloSincronizacion_ModuloRatioNo1,
        ns1:FalloSincronizacion_RatioCero ;
    ns1:monitoreaParametro ns1:Parametro_ModuloEjeMaestro,
        ns1:Parametro_RatioTransmision ;
    ns1:textoExtracto "sincronización en posición"@es .

ns1:FalloSincronizacion_ModuloRatioNo1 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Sincronización en posición con módulo y ratio ≠ 1"@es ;
    ns1:identificador "3413-modulo-ratio-no1" ;
    ns1:textoExtracto "3413 'No se puede sincronizar en posición con módulo y ratio diferente de 1' [...] CAUSA En la sincronización en posición, el eje maestro tiene módulo y el ratio de transmisión es diferente de 1."@es .

ns1:FalloSincronizacion_RatioCero a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Ratio de transmisión con denominador cero"@es ;
    ns1:identificador "3413-ratio-cero" ;
    ns1:textoExtracto "CAUSA En la sincronización, el denominador del ratio de transmisión tiene valor cero. SOLUCIÓN El denominador del ratio no puede valer cero."@es .

ns1:Parametro_ModuloEjeMaestro a ns1:Parametro ;
    rdfs:label "Módulo del eje maestro"@es ;
    ns1:textoExtracto "el eje maestro tiene módulo"@es .

ns1:Parametro_RatioTransmision a ns1:Parametro ;
    rdfs:label "Ratio de transmisión"@es ;
    ns1:textoExtracto "denominador del ratio de transmisión"@es ;
    ns1:valor "0.0"^^xsd:float .

