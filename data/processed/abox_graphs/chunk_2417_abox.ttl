@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_3414 a ns1:DiagnosticoFallo ;
    rdfs:label "'No se puede programar leva para ejes con diferente valor de módulo'"@es ;
    ns1:identificador "3414" ;
    ns1:textoExtracto "CAUSA En la sincronización de la leva, el eje maestro y esclavo tienen módulos diferentes. SOLUCIÓN Ambos ejes deben tener el mismo módulo (parámetros MODUPLIM y MODLOWLIM iguales)."@es .

ns1:Fallo_3415 a ns1:DiagnosticoFallo ;
    rdfs:label "'Búsqueda de cero independiente no permitida en ejecución'"@es ;
    ns1:identificador "3415" ;
    ns1:textoExtracto "CAUSA El PLC intenta realizar una búsqueda de referencia mientras el CNC está ejecutado otra. SOLUCIÓN El PLC debe esperar a que el CNC termine su búsqueda de referencia."@es .

ns1:Fallo_3417 a ns1:DiagnosticoFallo ;
    rdfs:label "LEAPFROG no posible con las cotas dadas"@es ;
    ns1:identificador "3417" ;
    ns1:textoExtracto "CAUSA El CNC no puede ejecutar el salto (#LEAP/#LEAPBEGIN) con los datos programados. SOLUCIÓN Revisar la programación."@es .

ns1:Fallo_3500 a ns1:DiagnosticoFallo ;
    rdfs:label "'Aceleración lineal del tramo 1 menor o igual a cero'"@es ;
    ns1:identificador "3500" ;
    ns1:textoExtracto "CAUSA La aceleración programada tiene valor cero. SOLUCIÓN Programar un valor positivo para la aceleración."@es .

ns1:Fallo_3501 a ns1:DiagnosticoFallo ;
    rdfs:label "'Aceleración lineal del tramo 1 mayor que la máxima'"@es ;
    ns1:identificador "3501" ;
    ns1:textoExtracto "CAUSA La aceleración programada es mayor que la máxima. SOLUCIÓN Programar un valor menor que el máximo para la aceleración."@es .

ns1:Fallo_3502 a ns1:DiagnosticoFallo ;
    rdfs:label "'Aceleración lineal del tramo 2 menor o igual a cero'"@es ;
    ns1:identificador "3502" ;
    ns1:textoExtracto "CAUSA La aceleración programada tiene valor cero. SOLUCIÓN Programar un valor positivo para la aceleración."@es .

ns1:Parametro_AceleracionMaxima a ns1:Parametro ;
    rdfs:label "aceleración máxima"@es ;
    ns1:textoExtracto "La aceleración programada es mayor que la máxima"@es .

ns1:Parametro_AceleracionTramo1 a ns1:Parametro ;
    rdfs:label "aceleración lineal del tramo 1"@es ;
    ns1:textoExtracto "La aceleración programada tiene valor cero"@es .

ns1:Parametro_AceleracionTramo2 a ns1:Parametro ;
    rdfs:label "aceleración lineal del tramo 2"@es ;
    ns1:textoExtracto "La aceleración programada tiene valor cero"@es .

ns1:Parametro_MODLOWLIM a ns1:Parametro ;
    ns1:identificador "MODLOWLIM" ;
    ns1:textoExtracto "parámetros MODUPLIM y MODLOWLIM iguales"@es .

ns1:Parametro_MODUPLIM a ns1:Parametro ;
    ns1:identificador "MODUPLIM" ;
    ns1:textoExtracto "parámetros MODUPLIM y MODLOWLIM iguales"@es .

ns1:Parametro_RatioTransmision a ns1:Parametro ;
    rdfs:label "ratio de transmisión"@es ;
    ns1:textoExtracto "el ratio de transmisión debe valor 1"@es ;
    ns1:valor "1" .

