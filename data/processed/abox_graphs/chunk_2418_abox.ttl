@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_3502 a ns1:DiagnosticoFallo ;
    rdfs:label "Aceleración lineal del tramo 2 ≤ 0" ;
    ns1:solucionaFallo ns1:Alarma_3502 ;
    ns1:textoExtracto "CAUSA La aceleración programada tiene valor cero. SOLUCIÓN Programar un valor positivo para la aceleración." .

ns1:DiagnosticoFallo_3503 a ns1:DiagnosticoFallo ;
    rdfs:label "Aceleración lineal del tramo 2 > valor máximo" ;
    ns1:solucionaFallo ns1:Alarma_3503 ;
    ns1:textoExtracto "CAUSA La aceleración programada es mayor que la máxima. SOLUCIÓN Programar un valor menor que el máximo para la aceleración." .

ns1:Parametro_AceleracionTramo2_3502 a ns1:Parametro ;
    rdfs:label "Aceleración programada del tramo 2" ;
    ns1:monitoreaParametro ns1:Alarma_3502 ;
    ns1:textoExtracto "La aceleración programada tiene valor cero." ;
    ns1:valor "0" .

ns1:Parametro_AceleracionTramo2_3503 a ns1:Parametro ;
    rdfs:label "Aceleración programada del tramo 2" ;
    ns1:monitoreaParametro ns1:Alarma_3503 ;
    ns1:textoExtracto "La aceleración programada es mayor que la máxima." .

ns1:Alarma_3502 a ns1:Alarma ;
    rdfs:label "Aceleración lineal del tramo 2 menor o igual a cero" ;
    ns1:identificador "3502" ;
    ns1:textoExtracto "'Aceleración lineal del tramo 2 menor o igual a cero' DETECCIÓN Durante el arranque o durante la ejecución. CAUSA La aceleración programada tiene valor cero. SOLUCIÓN Programar un valor positivo para la aceleración." .

ns1:Alarma_3503 a ns1:Alarma ;
    rdfs:label "Aceleración lineal del tramo 2 mayor que la máxima" ;
    ns1:identificador "3503" ;
    ns1:textoExtracto "'Aceleración lineal del tramo 2 mayor que la máxima' DETECCIÓN Durante el arranque o la ejecución. CAUSA La aceleración programada es mayor que la máxima. SOLUCIÓN Programar un valor menor que el máximo para la aceleración." .

