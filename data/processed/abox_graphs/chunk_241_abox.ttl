@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_HighLevelLanguage a ns1:ModoOperacion ;
    rdfs:label "High Level Language Mode"@en ;
    ns1:habilitadoPor ns1:Comando_MCS,
        ns1:Comando_MCS_OFF,
        ns1:Comando_MCS_ON,
        ns1:Comando_MDOFF,
        ns1:Comando_MEET ;
    ns1:textoExtracto "HIGH LEVEL LANGUAGE"@en .

ns1:Comando_MCS a ns1:AccionProhibida ;
    rdfs:label "Program a movement referred to machine zero"@en ;
    ns1:identificador "#MCS" ;
    ns1:textoExtracto "#MCS | Program a movement referred to machine zero."@en .

ns1:Comando_MCS_OFF a ns1:AccionProhibida ;
    rdfs:label "Cancel the machine coordinate system"@en ;
    ns1:identificador "#MCS OFF" ;
    ns1:textoExtracto "#MCS OFF | Cancel the machine coordinate system."@en .

ns1:Comando_MCS_ON a ns1:AccionProhibida ;
    rdfs:label "Activate the machine coordinate system"@en ;
    ns1:identificador "#MCS ON" ;
    ns1:textoExtracto "#MCS ON | Activate the machine coordinate system."@en .

ns1:Comando_MDOFF a ns1:AccionProhibida ;
    rdfs:label "Turning the subroutine into non-modal"@en ;
    ns1:identificador "#MDOFF" ;
    ns1:textoExtracto "#MDOFF | Turning the subroutine into non-modal."@en .

ns1:Comando_MEET a ns1:AccionProhibida ;
    rdfs:label "Activate the mark in the indicated channel"@en ;
    ns1:identificador "#MEET" ;
    ns1:textoExtracto "#MEET | Channels. Activate the mark in the indicated channel."@en .

