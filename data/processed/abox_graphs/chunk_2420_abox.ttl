@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_3511 a ns1:Alarma ;
    rdfs:label "Cancelación M3/M4 en G96 sin S programada" ;
    ns1:identificador "3511" ;
    ns1:textoExtracto "Cancelada M3 o M4 de PLC en G96 sin S programada. DETECCIÓN Durante la ejecución." .

ns1:DiagnosticoFallo_3510 a ns1:DiagnosticoFallo ;
    rdfs:label "Revisión de movimiento post-palpación" ;
    ns1:identificador "3510_SOL" ;
    ns1:solucionaFallo ns1:Alarma_3510 ;
    ns1:textoExtracto "Revisar el movimiento posterior a la palpación." .

ns1:Alarma_3510 a ns1:Alarma ;
    rdfs:label "Colisión con sonda de palpado" ;
    ns1:identificador "3510" ;
    ns1:textoExtracto "El movimiento programado va a colisionar con la sonda de palpado. DETECCIÓN Durante la ejecución. CAUSA El movimiento del eje va a superar los límites fijados por el movimiento de palpado anterior. El CNC detiene el movimiento antes de que haya una colisión." .

