@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_3604_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal (afectado por parámetro UNIDIR)"@es ;
    ns1:monitoreaParametro ns1:Fallo_3604 ;
    ns1:textoExtracto "El posicionamiento programado requiere un movimiento del cabezal en sentido contrario al indicado por parámetro máquina con UNIDIR."@es .

ns1:Fallo_3605 a ns1:DiagnosticoFallo ;
    rdfs:label "Sentido del giro de cabezal contrario al de parámetro máquina"@es ;
    ns1:identificador "3605" ;
    ns1:textoExtracto "3605 'Sentido del giro de cabezal contrario al de parámetro máquina' DETECCIÓN Durante la ejecución."@es .

ns1:Fallo_3604 a ns1:DiagnosticoFallo ;
    rdfs:label "Sentido del posicionamiento de cabezal contrario al de parámetro máquina"@es ;
    ns1:identificador "3604" ;
    ns1:solucionaFallo ns1:MODLOWLIM_5a256ee4b3,
        ns1:MODUPLIM_bc11789e7d,
        ns1:UNIDIRParametroMaquinaDelCabezal ;
    ns1:textoExtracto "3604 'Sentido del posicionamiento de cabezal contrario al de parámetro máquina' DETECCIÓN Durante la ejecución. CAUSA El posicionamiento programado requiere un movimiento del cabezal en sentido contrario al indicado por parámetro máquina con UNIDIR."@es .

ns1:MODLOWLIM_5a256ee4b3 a ns1:Parametro ;
    rdfs:label "MODLOWLIM" ;
    ns1:textoExtracto "Revisar los parámetros MODUPLIM y MODLOWLIM."@es .

ns1:MODUPLIM_bc11789e7d a ns1:Parametro ;
    rdfs:label "MODUPLIM" ;
    ns1:textoExtracto "Revisar los parámetros MODUPLIM y MODLOWLIM."@es .

ns1:UNIDIRParametroMaquinaDelCabezal a ns1:Parametro ;
    rdfs:label "UNIDIR (parámetro máquina del cabezal)"@es ;
    ns1:textoExtracto "Revisar la programación y el parámetro máquina UNIDIR del cabezal."@es .

