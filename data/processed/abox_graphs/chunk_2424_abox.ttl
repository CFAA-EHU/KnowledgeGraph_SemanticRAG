@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalMaster a ns1:Componente ;
    rdfs:label "Cabezal master de sincronización"@es ;
    ns1:identificador "Cabezal_Master_Sync" ;
    ns1:textoExtracto "El cabezal master de la sincronización no está en la gama adecuada (SYNCSET)"@es .

ns1:Fallo_SyncSet a ns1:DiagnosticoFallo ;
    rdfs:label "Cabezal fuera de gama SYNCSET"@es ;
    ns1:identificador "3611" ;
    ns1:textoExtracto "El cabezal master de la sincronización no está en la gama adecuada (SYNCSET"@es .

ns1:ModoOperacion_M19 a ns1:ModoOperacion ;
    rdfs:label "M19"@es ;
    ns1:identificador "M19" ;
    ns1:textoExtracto "el cabezal estaba en M19 antes de #SERVOON [...] Si el cabezal está en M19"@es .

ns1:ModoOperacion_M3 a ns1:ModoOperacion ;
    rdfs:label "M3"@es ;
    ns1:identificador "M3" ;
    ns1:textoExtracto "programar M3, M4, M5"@es .

ns1:ModoOperacion_M4 a ns1:ModoOperacion ;
    rdfs:label "M4"@es ;
    ns1:identificador "M4" ;
    ns1:textoExtracto "programar M3, M4, M5"@es .

ns1:ModoOperacion_M5 a ns1:ModoOperacion ;
    rdfs:label "M5"@es ;
    ns1:identificador "M5" ;
    ns1:textoExtracto "programar M3, M4, M5"@es .

ns1:Sentencia_SERVO_OFF a ns1:Parametro ;
    rdfs:label "#SERVO OFF"@es ;
    ns1:textoExtracto "sentencia #SERVO OFF"@es ;
    ns1:valor "#SERVO OFF" .

ns1:Sentencia_SERVO_ON a ns1:Parametro ;
    rdfs:label "#SERVO ON"@es ;
    ns1:textoExtracto "sentencia #SERVO ON"@es ;
    ns1:valor "#SERVO ON" .

ns1:Solucion_ResetLazo a ns1:TareaMantenimiento ;
    rdfs:label "Reset para abrir lazo en cabezal"@es ;
    ns1:solucionaFallo ns1:Fallo_ServoOff_M19 ;
    ns1:textoExtracto "para abrir el lazo, programar M3, M4, M5 o hacer un reset"@es .

ns1:Fallo_ServoOff_M19 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo al abrir lazo con cabezal en M19 tras #SERVO OFF"@es ;
    ns1:identificador "CAUSA_3611" ;
    ns1:textoExtracto "Hay programada una sentencia #SERVO OFF pero no se puede abrir el lazo porque el cabezal estaba en M19 antes de #SERVOON. [...] Si el cabezal está en M19, la sentencia #SERVO OFF no puede abrir el lazo; para abrir el lazo, programar M3, M4, M5 o hacer un reset."@es .

