@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_3701 a ns1:AvisoSeguridad ;
    rdfs:label "Posición de referencia sobrepasa límites de software" ;
    ns1:identificador "3701" ;
    ns1:mitigaRiesgo ns1:ValidacionDeREFVALUEYLimitesDeSoftware ;
    ns1:monitoreaParametro ns1:REFVALUE_94a2c4e7e3 ;
    ns1:textoExtracto "3701 'La posición de referencia sobrepasa los límites de software' DETECCIÓN Durante la validación de parámetros máquina. CAUSA El valor del parámetro REFVALUE sobrepasa los límites de software del eje. SOLUCIÓN Revisar el parámetro REFVALUE y los límites de software." .

ns1:AvisoSeguridad_3702 a ns1:AvisoSeguridad ;
    rdfs:label "Error de seguimiento del eje fuera de límite" ;
    ns1:identificador "3702" ;
    ns1:monitoreaParametro ns1:Parametro_ESTDELAY,
        ns1:Parametro_FEDYNFAC,
        ns1:Parametro_MAXFLWE,
        ns1:Parametro_MINFLWE ;
    ns1:textoExtracto "3702 'Error de seguimiento del eje fuera de límite' DETECCIÓN Durante la ejecución. CAUSA El eje ha superado el error de seguimiento permitido, definido en los parámetros máquina (MAXFLWE, MINFLWE, FEDYNFAC, ESTDELAY)." .

ns1:DiagnosticoFallo_DesactivarSPDLEREV a ns1:DiagnosticoFallo ;
    rdfs:label "Desactivar marca SPDLEREV del PLC" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_3700 ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la marca SPDLEREV del PLC." .

ns1:AvisoSeguridad_3700 a ns1:AvisoSeguridad ;
    rdfs:label "Límite de recorrido del eje sobrepasado (PLC)" ;
    ns1:identificador "3700" ;
    ns1:mitigaRiesgo ns1:RevisionDeProgramacionPLCParaLimitesDeRecorrido ;
    ns1:textoExtracto "3700 'Límite de recorrido del eje sobrepasado (PLC)' DETECCIÓN Durante el movimiento del eje. CAUSA El PLC ha intentado sobrepasar los límites de recorrido. SOLUCIÓN Revisar la programación." .

ns1:Parametro_ESTDELAY a ns1:Parametro ;
    rdfs:label "ESTDELAY" ;
    ns1:identificador "ESTDELAY" ;
    ns1:textoExtracto "parámetro máquina (..., ESTDELAY)" .

ns1:Parametro_FEDYNFAC a ns1:Parametro ;
    rdfs:label "FEDYNFAC" ;
    ns1:identificador "FEDYNFAC" ;
    ns1:textoExtracto "parámetro máquina (..., FEDYNFAC, ...)" .

ns1:Parametro_MAXFLWE a ns1:Parametro ;
    rdfs:label "MAXFLWE" ;
    ns1:identificador "MAXFLWE" ;
    ns1:textoExtracto "parámetro máquina (MAXFLWE, ...)" .

ns1:Parametro_MINFLWE a ns1:Parametro ;
    rdfs:label "MINFLWE" ;
    ns1:identificador "MINFLWE" ;
    ns1:textoExtracto "parámetro máquina (..., MINFLWE, ...)" .

ns1:REFVALUE_94a2c4e7e3 a ns1:Parametro ;
    rdfs:label "REFVALUE" ;
    ns1:identificador "REFVALUE" ;
    ns1:textoExtracto "parámetro REFVALUE" .

ns1:RevisionDeProgramacionPLCParaLimitesDeRecorrido a ns1:DiagnosticoFallo ;
    rdfs:label "Revisión de programación PLC para límites de recorrido" ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:ValidacionDeREFVALUEYLimitesDeSoftware a ns1:DiagnosticoFallo ;
    rdfs:label "Validación de REFVALUE y límites de software" ;
    ns1:textoExtracto "SOLUCIÓN Revisar el parámetro REFVALUE y los límites de software." .

