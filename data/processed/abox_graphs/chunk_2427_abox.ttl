@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteMecanico_Eje a ns1:ComponenteMecanico ;
    rdfs:label "Eje con fallo 3703"@es ;
    ns1:controla ns1:Fallo_3703 ;
    ns1:textoExtracto "ajuste inadecuado del eje, falta habilitar el eje, movimiento del eje"@es .

ns1:Motor_Fallo3703 a ns1:ComponenteElectrico ;
    rdfs:label "Motor asociado al fallo 3703"@es ;
    ns1:compuestoPor ns1:SistemaCaptacionMotor ;
    ns1:textoExtracto "fallo en el motor"@es .

ns1:Parametro_LIMIT a ns1:Parametro ;
    rdfs:label "LIMIT+"@es ;
    ns1:identificador "LIMIT+" ;
    ns1:monitoreaParametro ns1:Fallo_3703 ;
    ns1:textoExtracto "cota definida por el parámetro máquina LIMIT+"@es .

ns1:ParametrosMaquina_General a ns1:Parametro ;
    rdfs:label "Parámetros máquina (fallo 3703)"@es ;
    ns1:monitoreaParametro ns1:Fallo_3703 ;
    ns1:textoExtracto "parámetros máquina"@es .

ns1:Regulador_Fallo3703 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador asociado al fallo 3703"@es ;
    ns1:compuestoPor ns1:SistemaCaptacionMotor ;
    ns1:textoExtracto "estado del regulador"@es .

ns1:Variable_VARTPOSLIMIT a ns1:Parametro ;
    rdfs:label "V.A.RTPOSLIMIT.xn" ;
    ns1:identificador "V.A.RTPOSLIMIT.xn" ;
    ns1:monitoreaParametro ns1:Fallo_3703 ;
    ns1:textoExtracto "variable V.A.RTPOSLIMIT.xn"@es .

ns1:SistemaCaptacionMotor a ns1:Sistema ;
    rdfs:label "Sistema de captación-motor"@es ;
    ns1:controla ns1:Fallo_3703 ;
    ns1:textoExtracto "sistema captación-motor"@es .

ns1:Fallo_3703 a ns1:DiagnosticoFallo ;
    rdfs:label "Límite de software positivo sobrepasado"@es ;
    ns1:identificador "3703" ;
    ns1:textoExtracto "3703 'Límite de software positivo sobrepasado' DETECCIÓN Durante el movimiento del eje. CAUSA El eje ha superado la cota definida por el parámetro máquina LIMIT+ o por la variable V.A.RTPOSLIMIT.xn."@es .

