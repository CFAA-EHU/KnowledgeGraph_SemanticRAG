@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_3704 a ns1:Alarma ;
    rdfs:label "Límite de software positivo sobrepasado" ;
    ns1:identificador "3704" ;
    ns1:monitoreaParametro ns1:Parametro_LIMIT ;
    ns1:textoExtracto "'Límite de software positivo sobrepasado' DETECCIÓN Durante el movimiento del eje. CAUSA El eje ha superado la cota definida por el parámetro máquina LIMIT+ o por la variable V.A.RTPOSLIMIT.xn." .

ns1:Alarma_3705 a ns1:Alarma ;
    rdfs:label "Límite de software negativo sobrepasado" ;
    ns1:identificador "3705" ;
    ns1:monitoreaParametro ns1:Parametro_LIMIT ;
    ns1:textoExtracto "'Límite de software negativo sobrepasado' DETECCIÓN Durante el movimiento del eje. CAUSA El eje ha superado la cota definida por el parámetro máquina LIMIT- o por la variable V.A.RTNEGLIMIT.xn." .

ns1:Alarma_3707 a ns1:Alarma ;
    rdfs:label "Error en la operación con palpador" ;
    ns1:identificador "3707" ;
    ns1:textoExtracto "'Error en la operación con palpador' DETECCIÓN Durante la inicialización del palpador. CAUSA La entrada digital asignada al palpador no es válida." .

ns1:AvisoSeguridad_3706 a ns1:AvisoSeguridad ;
    rdfs:label "Contactar con proveedor para pérdida de referencia del cabezal" ;
    ns1:mitigaRiesgo ns1:Alarma_3706 ;
    ns1:textoExtracto "Póngase en contacto con su proveedor" .

ns1:Sensor_Palpador a ns1:Sensor ;
    rdfs:label "Palpador" ;
    ns1:textoExtracto "operación con palpador [...] entrada digital asignada al palpador" .

ns1:Variable_VARTNEGLIMIT a ns1:Parametro ;
    rdfs:label "V.A.RTNEGLIMIT.xn" ;
    ns1:textoExtracto "variable V.A.RTNEGLIMIT.xn" ;
    ns1:valor "V.A.RTNEGLIMIT.xn" .

ns1:Variable_VARTPOSLIMIT a ns1:Parametro ;
    rdfs:label "V.A.RTPOSLIMIT.xn" ;
    ns1:textoExtracto "variable V.A.RTPOSLIMIT.xn" ;
    ns1:valor "V.A.RTPOSLIMIT.xn" .

ns1:Alarma_3706 a ns1:Alarma ;
    rdfs:label "Es necesaria la búsqueda de cero" ;
    ns1:identificador "3706" ;
    ns1:textoExtracto "'Es necesaria la búsqueda de cero' DETECCIÓN Durante la ejecución. CAUSA El CNC ha perdido la referencia del cabezal en la transición de lazo abierto a lazo cerrado." .

ns1:Parametro_LIMIT a ns1:Parametro ;
    rdfs:label "LIMIT+",
        "LIMIT-" ;
    ns1:textoExtracto "parámetro máquina LIMIT-" ;
    ns1:valor "LIMIT+",
        "LIMIT-" .

