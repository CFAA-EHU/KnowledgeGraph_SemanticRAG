@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_3707 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la búsqueda de cero"@es ;
    ns1:identificador "3707" ;
    ns1:solucionaFallo ns1:Conexionado,
        ns1:ModuloContaje,
        ns1:Parametro_ReferenciaEje,
        ns1:ReguladorSercos,
        ns1:SistemaCaptacion ;
    ns1:textoExtracto "3707 'Error en la búsqueda de cero' [...] CAUSA Error en el proceso de búsqueda de referencia. Puede ser debido a una parametrización inadecuada del eje, a un fallo en el módulo de contaje o en el regulador Sercos, en el sistema de captación o a un error en el conexionado."@es .

ns1:Error_3708 a ns1:DiagnosticoFallo ;
    rdfs:label "Tiempo máximo para entrar en banda de muerte superado"@es ;
    ns1:identificador "3708" ;
    ns1:solucionaFallo ns1:Parametro_INPOMAX ;
    ns1:textoExtracto "3708 'Tiempo máximo para entrar en banda de muerte superado' [...] CAUSA El tiempo que necesita el eje para entrar en la banda de muerte, para que el CNC considere que está en posición, supera al definido en el parámetro INPOMAX."@es .

ns1:Error_Palpador a ns1:DiagnosticoFallo ;
    rdfs:label "Entrada digital del palpador no válida"@es ;
    ns1:solucionaFallo ns1:Parametro_Palpador ;
    ns1:textoExtracto "CAUSA La entrada digital asignada al palpador no es válida. SOLUCIÓN Revisar los parámetros del palpador."@es .

ns1:Conexionado a ns1:ComponenteElectrico ;
    rdfs:label "Conexionado eléctrico"@es ;
    ns1:textoExtracto "error en el conexionado"@es .

ns1:ModuloContaje a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de contaje"@es ;
    ns1:textoExtracto "fallo en el módulo de contaje"@es .

ns1:Parametro_INPOMAX a ns1:Parametro ;
    rdfs:label "Tiempo máximo para banda de muerte (INPOMAX)"@es ;
    ns1:identificador "INPOMAX" ;
    ns1:textoExtracto "el tiempo [...] supera al definido en el parámetro INPOMAX. SOLUCIÓN Ajustar el parámetro INPOMAX."@es ;
    ns1:valor "Tiempo"@es .

ns1:Parametro_Palpador a ns1:Parametro ;
    rdfs:label "Parámetros del palpador"@es ;
    ns1:textoExtracto "Revisar los parámetros del palpador."@es .

ns1:Parametro_ReferenciaEje a ns1:Parametro ;
    rdfs:label "Parámetros de búsqueda de referencia del eje"@es ;
    ns1:textoExtracto "Revisar los parámetros relacionados con la búsqueda de referencia"@es .

ns1:ReguladorSercos a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos"@es ;
    ns1:identificador "Sercos" ;
    ns1:textoExtracto "fallo en [...] el regulador Sercos"@es .

ns1:SistemaCaptacion a ns1:Sensor ;
    rdfs:label "Sistema de captación"@es ;
    ns1:textoExtracto "fallo en [...] el sistema de captación"@es .

