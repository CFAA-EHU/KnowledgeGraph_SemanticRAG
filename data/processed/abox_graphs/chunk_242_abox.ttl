@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_HLL a ns1:InterfazUsuario ;
    rdfs:label "High Level Language Interface" ;
    ns1:textoExtracto "HIGH LEVEL LANGUAGE commands for machine operation." ;
    ns1:tieneComponente ns1:Comando_MCS_ON,
        ns1:Comando_MDOFF,
        ns1:Comando_MEET,
        ns1:Comando_MOVE,
        ns1:Comando_MPG,
        ns1:Comando_MSG,
        ns1:Comando_PARK,
        ns1:Comando_PATH,
        ns1:Comando_PCALL,
        ns1:Comando_POLY,
        ns1:Comando_PROBE1 .

ns1:Comando_MCS_ON a ns1:ModoOperacion ;
    rdfs:label "#MCS ON" ;
    ns1:identificador "#MCS ON" ;
    ns1:textoExtracto "Activate the machine coordinate system." .

ns1:Comando_MDOFF a ns1:ModoOperacion ;
    rdfs:label "#MDOFF" ;
    ns1:identificador "#MDOFF" ;
    ns1:textoExtracto "Turning the subroutine into non-modal." .

ns1:Comando_MEET a ns1:ModoOperacion ;
    rdfs:label "#MEET" ;
    ns1:identificador "#MEET" ;
    ns1:textoExtracto "Channels. Activate the mark in the indicated channel." .

ns1:Comando_MOVE a ns1:ModoOperacion ;
    rdfs:label "#MOVE" ;
    ns1:identificador "#MOVE" ;
    ns1:textoExtracto "Independent axis. Positioning move." .

ns1:Comando_MPG a ns1:ModoOperacion ;
    rdfs:label "#MPG" ;
    ns1:identificador "#MPG" ;
    ns1:textoExtracto "Manual intervention. Resolution of the handwheels." .

ns1:Comando_MSG a ns1:ModoOperacion ;
    rdfs:label "#MSG" ;
    ns1:identificador "#MSG" ;
    ns1:textoExtracto "Display a message on the screen." .

ns1:Comando_PARK a ns1:ModoOperacion ;
    rdfs:label "#PARK" ;
    ns1:identificador "#PARK" ;
    ns1:textoExtracto "Park an axis or spindle." .

ns1:Comando_PATH a ns1:ModoOperacion ;
    rdfs:label "#PATH" ;
    ns1:identificador "#PATH" ;
    ns1:textoExtracto "Define the location of the global subroutines." .

ns1:Comando_PCALL a ns1:ModoOperacion ;
    rdfs:label "#PCALL" ;
    ns1:identificador "#PCALL" ;
    ns1:textoExtracto "Call to a global or local subroutine initializing parameters." .

ns1:Comando_POLY a ns1:ModoOperacion ;
    rdfs:label "#POLY" ;
    ns1:identificador "#POLY" ;
    ns1:textoExtracto "Polynomial interpolation." .

ns1:Comando_PROBE1 a ns1:ModoOperacion ;
    rdfs:label "#PROBE 1" ;
    ns1:identificador "#PROBE 1" ;
    ns1:textoExtracto "(·M· model). Tool calibration (dimensions and wear). (·T· model). Tool calibration." .

