@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_AparcamientoEjesGantryTandem a ns1:DiagnosticoFallo ;
    rdfs:label "Imposibilidad de aparcar ejes gantry/tándem o habilitados (DRENA/SPENA)"@es ;
    ns1:identificador "3714" ;
    ns1:textoExtracto "3714 No se pueden aparcar ejes gantry o tándem ni ejes habilitados con DRENA o SPENA. DETECCIÓN Aparcando un eje o cabezal desde PLC. CAUSA El PLC intenta aparcar un eje que forma parte de una pareja gantry, un eje o cabezal que forma parte de una pareja tándem o un eje habilitado (DRENA/SPENA)."@es .

ns1:Fallo_InicializacionParametroTandem a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en inicialización de control de par adicional (eje tándem)"@es ;
    ns1:solucionaFallo ns1:Accion_DefinirParametrosTandem,
        ns1:Accion_HabilitarEjeEsclavo,
        ns1:Accion_ResetCNC ;
    ns1:textoExtracto "El CNC no ha podido inicializar el control de par adicional porque la información de algún parámetro no está disponible. SOLUCIÓN Definir y validar los parámetros máquina del eje tándem o habilitar el eje esclavo y reseatear el CNC."@es .

ns1:Modo_DRENA a ns1:ModoOperacion ;
    rdfs:label "Modo DRENA"@es ;
    ns1:identificador "DRENA" ;
    ns1:textoExtracto "ejes habilitados con DRENA"@es .

ns1:Modo_SPENA a ns1:ModoOperacion ;
    rdfs:label "Modo SPENA"@es ;
    ns1:identificador "SPENA" ;
    ns1:textoExtracto "ejes habilitados con SPENA"@es .

ns1:Parametro_ControlParAdicional a ns1:Parametro ;
    rdfs:label "Parámetro de control de par adicional (eje tándem)"@es ;
    ns1:monitoreaParametro ns1:Sistema_EjesTandem ;
    ns1:textoExtracto "información de algún parámetro no está disponible"@es .

ns1:Sistema_EjesGantry a ns1:Sistema ;
    rdfs:label "Sistema de ejes gantry"@es ;
    ns1:textoExtracto "eje que forma parte de una pareja gantry"@es .

ns1:Accion_DefinirParametrosTandem a ns1:TareaMantenimiento ;
    rdfs:label "Definir y validar parámetros máquina del eje tándem"@es ;
    ns1:textoExtracto "Definir y validar los parámetros máquina del eje tándem"@es .

ns1:Accion_HabilitarEjeEsclavo a ns1:TareaMantenimiento ;
    rdfs:label "Habilitar eje esclavo"@es ;
    ns1:textoExtracto "habilitar el eje esclavo"@es .

ns1:Accion_ResetCNC a ns1:TareaMantenimiento ;
    rdfs:label "Reseatear el CNC"@es ;
    ns1:textoExtracto "reseatear el CNC"@es .

ns1:Sistema_EjesTandem a ns1:Sistema ;
    rdfs:label "Sistema de ejes tándem"@es ;
    ns1:textoExtracto "eje o cabezal que forma parte de una pareja tándem"@es .

