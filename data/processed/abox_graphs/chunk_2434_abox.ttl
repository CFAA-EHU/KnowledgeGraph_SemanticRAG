@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_3716 a ns1:DiagnosticoFallo ;
    rdfs:label "Máxima consigna de velocidad superada" ;
    ns1:identificador "3716" ;
    ns1:solucionaFallo ns1:Solucion_3716 ;
    ns1:textoExtracto "Máxima consigna de velocidad superada. Durante el movimiento de un eje o cabezal. En los ejes Sercos velocidad, el CNC envía la consigna al regulador en diezmilésimas de rpm; el valor de la consigna ha sobrepasado el rango permitido. Aunque la velocidad programada no supere G00FEED, la consigna enviada al regulador tras aplicar Kv supera el máximo permitido." .

ns1:Fallo_3717 a ns1:DiagnosticoFallo ;
    rdfs:label "Superado umbral de contaje del encoder" ;
    ns1:identificador "3717" ;
    ns1:solucionaFallo ns1:Solucion_3717 ;
    ns1:textoExtracto "Superado umbral de contaje del encoder. Buscar cero para recuperar cota. Durante la ejecución. El encóder del eje o cabezal ha superado la velocidad de giro máxima permitida." .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC con ejes Sercos" ;
    ns1:textoExtracto "Máquina con ejes Sercos velocidad, donde el CNC envía la consigna al regulador en diezmilésimas de rpm." ;
    ns1:tieneComponente ns1:Encoder_Eje,
        ns1:Regulador_Sercos .

ns1:Encoder_Eje a ns1:Sensor ;
    rdfs:label "Encoder de eje o cabezal" ;
    ns1:monitoreaParametro ns1:Parametro_G00FEED ;
    ns1:textoExtracto "Encoder del eje o cabezal que mide velocidad de giro." .

ns1:Parametro_INPUTREV a ns1:Parametro ;
    rdfs:label "INPUTREV" ;
    ns1:textoExtracto "Parámetro máquina INPUTREV." .

ns1:Parametro_OUTPUTREV a ns1:Parametro ;
    rdfs:label "OUTPUTREV" ;
    ns1:textoExtracto "Parámetro máquina OUTPUTREV." .

ns1:Parametro_PITCH a ns1:Parametro ;
    rdfs:label "PITCH" ;
    ns1:textoExtracto "Parámetro máquina PITCH." .

ns1:Parametro_PROGAIN a ns1:Parametro ;
    rdfs:label "PROGAIN" ;
    ns1:textoExtracto "Parámetro máquina PROGAIN." .

ns1:Regulador_Sercos a ns1:ComponenteElectrico ;
    rdfs:label "Regulador de velocidad Sercos" ;
    ns1:monitoreaParametro ns1:Parametro_G00FEED ;
    ns1:textoExtracto "Regulador al que el CNC envía la consigna de velocidad en diezmilésimas de rpm." .

ns1:Solucion_3716 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de parámetros de velocidad" ;
    ns1:requiereMantenimiento ns1:Parametro_G00FEED,
        ns1:Parametro_INPUTREV,
        ns1:Parametro_OUTPUTREV,
        ns1:Parametro_PITCH,
        ns1:Parametro_PROGAIN ;
    ns1:textoExtracto "Revisar los parámetros máquina PITCH, INPUTREV, OUTPUTREV y PROGAIN. Limitar la velocidad máxima (parámetro G00FEED) al valor que indica el warning para evitar el sobrepasamiento." .

ns1:Solucion_3717 a ns1:TareaMantenimiento ;
    rdfs:label "Búsqueda de cero para recuperar cota" ;
    ns1:textoExtracto "Buscar cero para recuperar cota." .

ns1:Parametro_G00FEED a ns1:Parametro ;
    rdfs:label "G00FEED" ;
    ns1:textoExtracto "Parámetro G00FEED (velocidad máxima)." ;
    ns1:valor "límite de velocidad máxima" .

