@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EncoderEje a ns1:Sensor ;
    rdfs:label "Encoder de eje/cabezal"@es ;
    ns1:monitoreaParametro ns1:ParametroVelocidadGiro ;
    ns1:textoExtracto "el encóder del eje o cabezal"@es .

ns1:FalloAparcamientoEjeActivo a ns1:DiagnosticoFallo ;
    rdfs:label "Aparcamiento de eje en movimiento"@es ;
    ns1:identificador "3718" ;
    ns1:textoExtracto "DETECCIÓN Aparcando un eje desde PLC. CAUSA El PLC intenta aparcar un eje en movimiento, que forma parte de la cinemática"@es .

ns1:FalloEncoderVelocidadMaxima a ns1:DiagnosticoFallo ;
    rdfs:label "Encoder supera velocidad máxima"@es ;
    ns1:solucionaFallo ns1:BusquedaReferenciaMaquina ;
    ns1:textoExtracto "Durante la ejecución. CAUSA El encóder del eje o cabezal ha superado la velocidad de giro máxima permitida. Al superar este límite, el eje o cabezal ha perdido el punto de referencia, por lo que las cotas leídas no son correctas."@es .

ns1:PuntoReferencia a ns1:Parametro ;
    rdfs:label "Punto de referencia"@es ;
    ns1:textoExtracto "ha perdido el punto de referencia"@es .

ns1:SistemaCinematico a ns1:Sistema ;
    rdfs:label "Cinemática de máquina"@es ;
    ns1:textoExtracto "eje en movimiento, que forma parte de la cinemática"@es ;
    ns1:tieneComponente ns1:EjeControlado .

ns1:BusquedaReferenciaMaquina a ns1:TareaMantenimiento ;
    rdfs:label "Búsqueda de referencia máquina"@es ;
    ns1:textoExtracto "SOLUCIÓN Realizar una búsqueda de referencia máquina para trabajar en lazo cerrado."@es .

ns1:EjeControlado a ns1:ComponenteMecanico ;
    rdfs:label "Eje con encoder"@es ;
    ns1:textoExtracto "el encóder del eje o cabezal ha superado la velocidad de giro máxima permitida"@es .

ns1:ParametroVelocidadGiro a ns1:Parametro ;
    rdfs:label "Velocidad de giro máxima"@es ;
    ns1:textoExtracto "velocidad de giro máxima permitida"@es .

