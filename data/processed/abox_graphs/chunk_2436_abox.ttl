@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_3719_ResetCabezales a ns1:AvisoSeguridad ;
    rdfs:label "RESET para aparcar cabezales en movimiento o G33/G34/G63/G95/G96/#CAX/#SYNC"@es ;
    ns1:identificador "3719" ;
    ns1:mitigaRiesgo ns1:ComponenteMecanico_Cabezal,
        ns1:ModoOperacion_CAX,
        ns1:ModoOperacion_G33,
        ns1:ModoOperacion_G34,
        ns1:ModoOperacion_G63,
        ns1:ModoOperacion_G95,
        ns1:ModoOperacion_G96,
        ns1:ModoOperacion_SYNC ;
    ns1:textoExtracto "RESET para aparcar cabezales en movimiento o G33/G34/G63/G95/G96/#CAX/#SYNC. DETECCIÓN: Aparcando un eje desde PLC. CAUSA: El PLC intenta aparcar un cabezal en movimiento, sincronizado, activado como eje C o con algunas de las funciones G33, G34, G63, G95 o G96 activa."@es .

ns1:AvisoSeguridad_3719_ResetEjes a ns1:AvisoSeguridad ;
    rdfs:label "RESET para aparcar ejes en movimiento o de la transformación/acoplo activo"@es ;
    ns1:identificador "3719" ;
    ns1:mitigaRiesgo ns1:Sistema_CinematicaActiva,
        ns1:Sistema_ControlTangencial,
        ns1:Sistema_TransformacionCoordenadas ;
    ns1:textoExtracto "RESET para aparcar ejes en movimiento o de la transformación/acoplo activo. DETECCIÓN: Aparcando un eje desde PLC. CAUSA: El PLC intenta aparcar un eje en movimiento, que forma parte de la cinemática activa, de un eje angular activo, del control tangencial activo o de una transformación de coordenadas #CS o #ACS. SOLUCIÓN: El PLC no puede aparcar el eje en esa situación. Pulsar reset para detener el movimiento o desactivar la cinemática activa, el eje angular activo, el control tangencial activo o la transformación de coordenadas #CS o #ACS."@es .

ns1:ComponenteMecanico_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal"@es ;
    ns1:textoExtracto "El PLC intenta aparcar un cabezal en movimiento, sincronizado, activado como eje C o con algunas de las funciones G33, G34, G63, G95 o G96 activa."@es .

ns1:ModoOperacion_CAX a ns1:ModoOperacion ;
    rdfs:label "Modo #CAX"@es ;
    ns1:identificador "#CAX" ;
    ns1:textoExtracto "RESET para aparcar cabezales en movimiento o [...] #CAX/#SYNC"@es .

ns1:ModoOperacion_G33 a ns1:ModoOperacion ;
    rdfs:label "Función G33"@es ;
    ns1:identificador "G33" ;
    ns1:textoExtracto "cabezal en movimiento, sincronizado, activado como eje C o con algunas de las funciones G33, G34, G63, G95 o G96 activa"@es .

ns1:ModoOperacion_G34 a ns1:ModoOperacion ;
    rdfs:label "Función G34"@es ;
    ns1:identificador "G34" ;
    ns1:textoExtracto "cabezal en movimiento, sincronizado, activado como eje C o con algunas de las funciones G33, G34, G63, G95 o G96 activa"@es .

ns1:ModoOperacion_G63 a ns1:ModoOperacion ;
    rdfs:label "Función G63"@es ;
    ns1:identificador "G63" ;
    ns1:textoExtracto "cabezal en movimiento, sincronizado, activado como eje C o con algunas de las funciones G33, G34, G63, G95 o G96 activa"@es .

ns1:ModoOperacion_G95 a ns1:ModoOperacion ;
    rdfs:label "Función G95"@es ;
    ns1:identificador "G95" ;
    ns1:textoExtracto "cabezal en movimiento, sincronizado, activado como eje C o con algunas de las funciones G33, G34, G63, G95 o G96 activa"@es .

ns1:ModoOperacion_G96 a ns1:ModoOperacion ;
    rdfs:label "Función G96"@es ;
    ns1:identificador "G96" ;
    ns1:textoExtracto "cabezal en movimiento, sincronizado, activado como eje C o con algunas de las funciones G33, G34, G63, G95 o G96 activa"@es .

ns1:ModoOperacion_SYNC a ns1:ModoOperacion ;
    rdfs:label "Modo #SYNC"@es ;
    ns1:identificador "#SYNC" ;
    ns1:textoExtracto "RESET para aparcar cabezales en movimiento o [...] #CAX/#SYNC"@es .

ns1:Sistema_CinematicaActiva a ns1:Sistema ;
    rdfs:label "Cinemática activa"@es ;
    ns1:textoExtracto "El PLC intenta aparcar un eje en movimiento, que forma parte de la cinemática activa"@es ;
    ns1:tieneComponente ns1:ComponenteMecanico_Eje .

ns1:Sistema_ControlTangencial a ns1:Sistema ;
    rdfs:label "Control tangencial activo"@es ;
    ns1:textoExtracto "El PLC intenta aparcar un eje en movimiento, que forma parte de [...] del control tangencial activo"@es ;
    ns1:tieneComponente ns1:ComponenteMecanico_Eje .

ns1:Sistema_TransformacionCoordenadas a ns1:Sistema ;
    rdfs:label "Transformación de coordenadas #CS/#ACS"@es ;
    ns1:identificador "#CS/#ACS" ;
    ns1:textoExtracto "El PLC intenta aparcar un eje en movimiento, que forma parte de [...] una transformación de coordenadas #CS o #ACS"@es ;
    ns1:tieneComponente ns1:ComponenteMecanico_Eje .

ns1:ComponenteMecanico_Eje a ns1:ComponenteMecanico ;
    rdfs:label "Eje"@es ;
    ns1:textoExtracto "El PLC intenta aparcar un eje en movimiento, que forma parte de la cinemática activa, de un eje angular activo, del control tangencial activo o de una transformación de coordenadas #CS o #ACS."@es .

