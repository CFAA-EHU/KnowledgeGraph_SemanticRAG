@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Comando_TOUCHPROBE a ns1:ModoOperacion ;
    rdfs:label "TOUCHPROBE" ;
    ns1:identificador "TOUCHPROBE" ;
    ns1:textoExtracto "palpador está siendo utilizado por un proceso previo (G100 o comando TOUCHPROBE)" .

ns1:Error_3721 a ns1:AvisoSeguridad ;
    rdfs:label "Error en la inicialización del palpador" ;
    ns1:identificador "3721" ;
    ns1:textoExtracto "3721 Error en la inicialización del palpador. DETECCIÓN Durante la ejecución. CAUSA Los parámetros del palpador no son coherentes. SOLUCIÓN Revisar los parámetros del palpador (PROBETYPE, PRBDI, PRBPULSE)." .

ns1:Error_3722 a ns1:AvisoSeguridad ;
    rdfs:label "Error en los límites de la ventana de palpado desde PLC" ;
    ns1:identificador "3722" ;
    ns1:textoExtracto "3722 Error en los límites de la ventana de palpado desde PLC. DETECCIÓN Durante la ejecución." .

ns1:Fallo_EjeC a ns1:DiagnosticoFallo ;
    rdfs:label "PLC no puede aparcar el cabezal" ;
    ns1:solucionaFallo ns1:Error_3720 ;
    ns1:textoExtracto "SOLUCIÓN El PLC no puede aparcar el cabezal en esa situación. Pulsar reset para detener el movimiento, la sincronización, desactivar el eje C o desactivar las funciones G33, G34, G63, G95 o G96." .

ns1:Funcion_G100 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G100" ;
    ns1:identificador "G100" ;
    ns1:textoExtracto "palpador está siendo utilizado por un proceso previo (G100 o comando TOUCHPROBE)" .

ns1:Funcion_G33 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G33" ;
    ns1:identificador "G33" ;
    ns1:textoExtracto "desactivar las funciones G33, G34, G63, G95 o G96" .

ns1:Funcion_G34 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G34" ;
    ns1:identificador "G34" ;
    ns1:textoExtracto "desactivar las funciones G33, G34, G63, G95 o G96" .

ns1:Funcion_G63 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G63" ;
    ns1:identificador "G63" ;
    ns1:textoExtracto "desactivar las funciones G33, G34, G63, G95 o G96" .

ns1:Funcion_G95 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G95" ;
    ns1:identificador "G95" ;
    ns1:textoExtracto "desactivar las funciones G33, G34, G63, G95 o G96" .

ns1:Funcion_G96 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G96" ;
    ns1:identificador "G96" ;
    ns1:textoExtracto "desactivar las funciones G33, G34, G63, G95 o G96" .

ns1:Parametro_PRBDI a ns1:Parametro ;
    rdfs:label "PRBDI" ;
    ns1:monitoreaParametro ns1:Componente_Palpador ;
    ns1:textoExtracto "Revisar los parámetros del palpador (PROBETYPE, PRBDI, PRBPULSE)" .

ns1:Parametro_PRBPULSE a ns1:Parametro ;
    rdfs:label "PRBPULSE" ;
    ns1:monitoreaParametro ns1:Componente_Palpador ;
    ns1:textoExtracto "Revisar los parámetros del palpador (PROBETYPE, PRBDI, PRBPULSE)" .

ns1:Parametro_PROBETYPE a ns1:Parametro ;
    rdfs:label "PROBETYPE" ;
    ns1:monitoreaParametro ns1:Componente_Palpador ;
    ns1:textoExtracto "Revisar los parámetros del palpador (PROBETYPE, PRBDI, PRBPULSE)" .

ns1:Error_3720 a ns1:AvisoSeguridad ;
    rdfs:label "Palpador no disponible. Ocupado por otro proceso" ;
    ns1:identificador "3720" ;
    ns1:textoExtracto "3720 'Palpador no disponible. Ocupado por otro proceso' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado ejecutar una palpación pero el palpador está siendo utilizado por un proceso previo (G100 o comando TOUCHPROBE). SOLUCIÓN Esperar a que finalice una palpación antes de ejecutar la siguiente." .

ns1:Componente_Palpador a ns1:Sensor ;
    rdfs:label "Palpador" ;
    ns1:textoExtracto "palpador está siendo utilizado por un proceso previo (G100 o comando TOUCHPROBE)" .

