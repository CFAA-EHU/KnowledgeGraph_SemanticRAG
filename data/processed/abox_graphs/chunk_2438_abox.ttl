@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Comando_TOUCHPROBE a ns1:Parametro ;
    rdfs:label "Comando TOUCHPROBE"@es ;
    ns1:solucionaFallo ns1:Error_3722 ;
    ns1:textoExtracto "Revisar la programación del comando TOUCHPROBE en el programa PLC."@es .

ns1:Funcion_G174 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G174"@es ;
    ns1:solucionaFallo ns1:Error_3723 ;
    ns1:textoExtracto "El CNC ha detectado la función G174 para un eje que está en modo visualizador"@es .

ns1:Modo_Visualizador a ns1:ModoOperacion ;
    rdfs:label "Modo visualizador"@es ;
    ns1:textoExtracto "eje que está en modo visualizador"@es .

ns1:Error_3722 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en los límites de la ventana de palpado desde PLC"@es ;
    ns1:identificador "3722" ;
    ns1:textoExtracto "Error en los límites de la ventana de palpado desde PLC. DETECCIÓN Durante la ejecución. CAUSA En el palpado desde PLC están mal definidos los límites de la ventana de palpado (límite inferior > límite superior). SOLUCIÓN Revisar la programación del comando TOUCHPROBE en el programa PLC."@es .

ns1:Error_3723 a ns1:DiagnosticoFallo ;
    rdfs:label "'No se admite G174 para eje en modo visualizador'"@es ;
    ns1:identificador "3723" ;
    ns1:textoExtracto "'No se admite G174 para eje en modo visualizador'. DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado la función G174 para un eje que está en modo visualizador (marca"@es .

