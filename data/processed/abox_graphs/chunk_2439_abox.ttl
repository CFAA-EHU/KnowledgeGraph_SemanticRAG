@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_3723 a ns1:Alarma ;
    rdfs:label "Alarma 3723: No se admite G174 para eje en modo visualizador"@es ;
    ns1:identificador "3723" ;
    ns1:textoExtracto "3723 'No se admite G174 para eje en modo visualizador' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado la función G174 para un eje que está en modo visualizador (marca DRO). SOLUCIÓN Revisar la programación. Para forzar la cota de un eje (G174), éste no puede estar en modo visualizador; es decir, hay que desactivar su marca DRO(axis) y activar su marca SERVO(axis)ON."@es .

ns1:Alarma_3724 a ns1:Alarma ;
    rdfs:label "Alarma 3724: No se permite G174 si el eje no está en posición"@es ;
    ns1:identificador "3724" ;
    ns1:textoExtracto "3724 'No se permite G174 si el eje no está en posición' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado la función G174 para un eje que no está en posición. SOLUCIÓN Revisar la programación. Para forzar cota de un eje (G174) es preciso que el eje esté en posición; es decir, que no esté en movimiento y que tenga su marca INPOS(axis) activa."@es .

ns1:Alarma_3725 a ns1:Alarma ;
    rdfs:label "Alarma 3725: No se permite G174 para un eje que está sincronizado"@es ;
    ns1:identificador "3725" ;
    ns1:textoExtracto "3725 'No se permite G174 para un eje que está sincronizado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado la función G174 para un eje que está sincronizado. SOLUCIÓN Revisar la programación. Para forzar cota de un eje (G174) es preciso que el eje no esté sincronizado con otro. Desincronizar eje antes de forzar cota o comprobar en el programa de PLC la lógica de la marca INSYNC del eje."@es .

ns1:Alarma_3726 a ns1:Alarma ;
    rdfs:label "Alarma 3726: Falta Drive Status Ready (DRSTAF/DRSTAS) del eje esclavo del tandem"@es ;
    ns1:identificador "3726" ;
    ns1:textoExtracto "3726 'Falta Drive Status Ready (DRSTAF/DRSTAS) del eje esclavo del tandem' DETECCIÓN Al iniciar el movimiento de un eje tandem. CAUSA El CNC ha intentado mover el eje maestro del tandem sin esperar a que el eje esclavo esté habilitado. SOLUCIÓN En la maniobra del PLC, condicionar el permiso del movimiento a que ambos ejes del tandem estén habilitados."@es .

ns1:Alarma_3727 a ns1:Alarma ;
    rdfs:label "Alarma 3727: No se permite desactivar un eje múltiple sin entrar en posición"@es ;
    ns1:identificador "3727" ;
    ns1:textoExtracto "3727 'No se permite desactivar un eje múltiple sin entrar en posición' DETECCIÓN Al desactivar la marca SWITCH del eje."@es .

ns1:ModoOperacion_DriveStatusReady a ns1:ModoOperacion ;
    rdfs:label "Drive Status Ready (DRSTAF/DRSTAS)"@es ;
    ns1:textoExtracto "Drive Status Ready (DRSTAF/DRSTAS)"@es .

ns1:ModoOperacion_EjeEnPosicion a ns1:ModoOperacion ;
    rdfs:label "Eje en posición (INPOS(axis))"@es ;
    ns1:textoExtracto "marca INPOS(axis) activa"@es .

ns1:ModoOperacion_EjeSincronizado a ns1:ModoOperacion ;
    rdfs:label "Eje sincronizado (INSYNC)"@es ;
    ns1:textoExtracto "marca INSYNC del eje"@es .

ns1:ModoOperacion_ServoActivado a ns1:ModoOperacion ;
    rdfs:label "Modo servo activado (SERVO(axis)ON)"@es ;
    ns1:textoExtracto "marca SERVO(axis)ON"@es .

ns1:ModoOperacion_Visualizador a ns1:ModoOperacion ;
    rdfs:label "Modo visualizador (DRO)"@es ;
    ns1:textoExtracto "modo visualizador (marca DRO)"@es .

ns1:Parametro_G174 a ns1:Parametro ;
    rdfs:label "Función G174 (forzar cota de eje)"@es ;
    ns1:identificador "G174" ;
    ns1:textoExtracto "función G174 para forzar la cota de un eje"@es .

