@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Instruccion_PROBE12 a ns1:Parametro ;
    rdfs:label "#PROBE 12" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#PROBE12" ;
    ns1:textoExtracto "(·M· model). Tabletop probe calibration"@en .

ns1:Instruccion_PROBE2 a ns1:Parametro ;
    rdfs:label "#PROBE 2" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#PROBE2" ;
    ns1:textoExtracto "(·M· model). Probe calibration (·T· model). Tabletop probe calibration"@en .

ns1:Instruccion_PROBE3 a ns1:Parametro ;
    rdfs:label "#PROBE 3" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#PROBE3" ;
    ns1:textoExtracto "(·M· model). Surfacing measuring. (·T· model). Part measuring along the ordinate axis."@en .

ns1:Instruccion_PROBE4 a ns1:Parametro ;
    rdfs:label "#PROBE 4" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#PROBE4" ;
    ns1:textoExtracto "(·M· model). Outside corner measuring. (·T· model). Part measuring along the abscissa axis."@en .

ns1:Instruccion_PROBE5 a ns1:Parametro ;
    rdfs:label "#PROBE 5" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#PROBE5" ;
    ns1:textoExtracto "(·M· model). Inside corner measuring."@en .

ns1:Instruccion_RENAME_AX a ns1:Parametro ;
    rdfs:label "#RENAME AX" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#RENAME_AX" ;
    ns1:textoExtracto "Rename the axes of the channel."@en .

ns1:Instruccion_SERVO_OFF a ns1:Parametro ;
    rdfs:label "#SERVO OFF" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#SERVO_OFF" ;
    ns1:textoExtracto "Activate the open loop mode."@en .

ns1:Instruccion_SERVO_ON a ns1:Parametro ;
    rdfs:label "#SERVO ON" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#SERVO_ON" ;
    ns1:textoExtracto "Activate the closed loop mode."@en .

ns1:Instruccion_SLOPE a ns1:Parametro ;
    rdfs:label "#SLOPE" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#SLOPE" ;
    ns1:textoExtracto "Acceleration control."@en .

ns1:Tabla_InstruccionesHighLevelLanguage a ns1:Tabla ;
    rdfs:label "Tabla de instrucciones de alto nivel (HLL)"@es ;
    ns1:identificador "HLL_Instructions_Table" ;
    ns1:textoExtracto """
| Instruction. | Meaning. |
| --- | --- |
| #PROBE 2 | (·M· model). Probe calibration (·T· model). Tabletop probe calibration |
| #PROBE 3 | (·M· model). Surfacing measuring. (·T· model). Part measuring along the ordinate axis. |
| ... """ .

