@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_3732 a ns1:Alarma ;
    rdfs:label "Error en el refresco de contajes locales" ;
    ns1:identificador "3732" ;
    ns1:textoExtracto "3732 Error en el refresco de contajes locales. DETECCIÓN En la lectura de los contajes analógicos locales desde el lazo de posición. CAUSA Alarma en alguna de las entradas de captación locales." .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:activaAlarma ns1:Alarma_3728,
        ns1:Alarma_3729,
        ns1:Alarma_3731 ;
    ns1:textoExtracto "El CNC ha intentado desactivar un eje de un grupo múltiple" .

ns1:Sistema_PLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:activaAlarma ns1:Alarma_3730 ;
    ns1:controla ns1:ComponenteElectrico_Palpador ;
    ns1:textoExtracto "En la maniobra del PLC, condicionar la desactivación del eje" .

ns1:Sistema_Regulador a ns1:Sistema ;
    rdfs:label "Regulador del eje" ;
    ns1:monitoreaParametro ns1:Parametro_G174_Desplazamiento ;
    ns1:textoExtracto "comando Sercos de aparcar, desaparcar o cambio de gama o set" .

ns1:Alarma_3728 a ns1:Alarma ;
    rdfs:label "Eje múltiple con un comando en el regulador en ejecución, SWITCH no permitido" ;
    ns1:identificador "3728" ;
    ns1:textoExtracto "3728 'Eje múltiple con un comando en el regulador en ejecución, SWITCH no permitido' DETECCIÓN Al desactivar la marca SWITCH del eje. CAUSA El CNC ha intentado desactivar un eje de un grupo múltiple, antes de que termine un comando Sercos de aparcar, desaparcar o cambio de gama o set." .

ns1:Alarma_3729 a ns1:Alarma ;
    rdfs:label "No se permite más de un eje del grupo múltiple activo" ;
    ns1:identificador "3729" ;
    ns1:textoExtracto "3729 'No se permite más de un eje del grupo múltiple activo' DETECCIÓN Al activar la marca SWITCH del eje. CAUSA El CNC ha intentado activar un eje de un grupo múltiple, antes de desactivar el eje anterior." .

ns1:Alarma_3730 a ns1:Alarma ;
    rdfs:label "TOUCHPROBE: El flanco seleccionado se va a ignorar al ser diferente del activo" ;
    ns1:identificador "3730" ;
    ns1:textoExtracto "3730 'TOUCHPROBE: El flanco seleccionado se va a ignorar al ser diferente del activo' DETECCIÓN Al ejecutar el PLC un comando TOUCHPROBE. CAUSA El PLC ha intentado activar un palpado, pero el palpador está siendo utilizado por un comando TOUCHPROBE previo y ambos comandos utilizan flancos diferentes." .

ns1:Alarma_3731 a ns1:Alarma ;
    rdfs:label "G174: Desplazamiento no válido, valor demasiado grande" ;
    ns1:identificador "3731" ;
    ns1:textoExtracto "3731 'G174: Desplazamiento no válido, valor demasiado grande' DETECCIÓN Al ejecutar G174 CAUSA Al calcular el desplazamiento programado en unidades del regulador, se obtiene un valor fuera del rango admitido por el regulador." .

ns1:ComponenteElectrico_Palpador a ns1:ComponenteElectrico ;
    rdfs:label "Palpador TOUCHPROBE" ;
    ns1:textoExtracto "El PLC ha intentado activar un palpado, pero el palpador está siendo utilizado por un comando TOUCHPROBE previo y ambos comandos utilizan flancos diferentes." .

ns1:Parametro_G174_Desplazamiento a ns1:Parametro ;
    rdfs:label "Desplazamiento programado en G174" ;
    ns1:textoExtracto "Al calcular el desplazamiento programado en unidades del regulador, se obtiene un valor fuera del rango admitido por el regulador." ;
    ns1:valor "Fuera de rango" .

