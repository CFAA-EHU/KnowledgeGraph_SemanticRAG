@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_3732 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el refresco de contajes locales" ;
    ns1:identificador "3732" ;
    ns1:solucionaFallo ns1:Solucion_3732 ;
    ns1:textoExtracto "3732 Error en el refresco de contajes locales. DETECCIÓN En la lectura de los contajes analógicos locales desde el lazo de posición. CAUSA Alarma en alguna de las entradas de captación locales." .

ns1:Error_3733 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el refresco de entradas analógicas locales" ;
    ns1:identificador "3733" ;
    ns1:solucionaFallo ns1:Solucion_3733 ;
    ns1:textoExtracto "3733 Error en el refresco de entradas analógicas locales. DETECCIÓN En la lectura de las entradas" .

ns1:Parametro_G174 a ns1:Parametro ;
    rdfs:label "Parámetro G174" ;
    ns1:identificador "G174" ;
    ns1:monitoreaParametro ns1:Solucion_3733 ;
    ns1:textoExtracto "Modificar el valor programado en la G174" .

ns1:Solucion_3732 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de conexionado y nivel de señales para contajes locales" ;
    ns1:textoExtracto "SOLUCIÓN Revisar el conexionado de los contajes locales y el nivel de las señales." .

ns1:Solucion_3733 a ns1:TareaMantenimiento ;
    rdfs:label "Modificación del valor programado en G174" ;
    ns1:textoExtracto "SOLUCIÓN Modificar el valor programado en la G174." .

