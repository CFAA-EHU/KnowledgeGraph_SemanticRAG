@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_3738 a ns1:DiagnosticoFallo ;
    rdfs:label "El eje se ha movido con el CNC apagado"@es ;
    ns1:identificador "3738" ;
    ns1:monitoreaParametro ns1:Parametro_MAXDIFREF ;
    ns1:textoExtracto "El eje se ha movido con el CNC apagado. DETECCIÓN Durante el arranque del CNC. CAUSA La cota absoluta del regulador no se corresponde con la cota salvada en la última sesión de CNC. El eje se ha movido más de lo indicado en el parámetro MAXDIFREF. SOLUCIÓN Verificar que la posición del eje es correcta."@es .

ns1:Fallo_3739 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la señal de la sonda durante el proceso de #GAPCTRL"@es ;
    ns1:identificador "3739" ;
    ns1:textoExtracto "Error en la señal de la sonda durante el proceso de #GAPCTRL. DETECCIÓN Durante la ejecución. CAUSA Con el control de gap activo, el CNC lee una distancia mayor que el máximo posible"@es .

ns1:Parametro_MAXDIFREF a ns1:Parametro ;
    rdfs:label "Parámetro MAXDIFREF"@es ;
    ns1:textoExtracto "El eje se ha movido más de lo indicado en el parámetro MAXDIFREF"@es .

