@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Param_GAPERRORCANCEL a ns1:Parametro ;
    rdfs:label "GAPERRORCANCEL"@es ;
    ns1:identificador "GAPERRORCANCEL" ;
    ns1:textoExtracto "Cambiar el valor del parámetro GAPERRORCANCEL para que el CNC no de error"@es .

ns1:Param_GAPTOLCANCEL a ns1:Parametro ;
    rdfs:label "GAPTOLCANCEL"@es ;
    ns1:identificador "GAPTOLCANCEL" ;
    ns1:textoExtracto "Cambiar el valor del parámetro GAPTOLCANCEL para que el CNC no de error"@es .

ns1:Sonda_GAPCTRL a ns1:Sensor ;
    rdfs:label "Sonda de control de gap (#GAPCTRL)"@es ;
    ns1:activaAlarma ns1:Error_3739,
        ns1:Error_3740,
        ns1:Error_3741,
        ns1:Error_3742,
        ns1:Error_3743 ;
    ns1:monitoreaParametro ns1:Param_GAPDISTLIMIT,
        ns1:Param_GAPMAX,
        ns1:Param_GAPMIN,
        ns1:Param_GAPTOL,
        ns1:Param_GAPVOLTLIMIT ;
    ns1:textoExtracto "Con el control de gap activo, el CNC lee una distancia mayor que el máximo posible (parámetro GAPDISTLIMIT). Las posibles causas son las siguientes: • La sonda funciona mal. • La señal que recibe el CNC no es de la sonda (sonda mal conectada). • La sonda esté mal parametrizada (parámetros GAPDISTLIMIT y GAPVOLTLIMIT)."@es .

ns1:Error_3739 a ns1:AvisoSeguridad ;
    rdfs:label "Error en la señal de la sonda durante #GAPCTRL"@es ;
    ns1:identificador "3739" ;
    ns1:mitigaRiesgo ns1:Solucion_3739 ;
    ns1:textoExtracto "3739 Error en la señal de la sonda durante el proceso de #GAPCTRL. DETECCIÓN Durante la ejecución. CAUSA Con el control de gap activo, el CNC lee una distancia mayor que el máximo posible (parámetro GAPDISTLIMIT). Las posibles causas son: • La sonda funciona mal. • La señal que recibe el CNC no es de la sonda (sonda mal conectada). • La sonda esté mal parametrizada (parámetros GAPDISTLIMIT y GAPVOLTLIMIT). SOLUCIÓN Revisar la conexión y la parametrización de la sonda."@es .

ns1:Error_3740 a ns1:AvisoSeguridad ;
    rdfs:label "ENABLEGAP: No se puede activar #GAPCTRL por estar alejado del GAP programado"@es ;
    ns1:identificador "3740" ;
    ns1:mitigaRiesgo ns1:Solucion_3740 ;
    ns1:textoExtracto "3740 ENABLEGAP: No se puede activar #GAPCTRL por estar alejado del GAP programado. DETECCIÓN Durante la ejecución. CAUSA El control del gap está activo (#GAPCTRL) pero deshabilitado por PLC (marca ENABLEGAP). El CNC no puede habilitar el control del gap porque la sonda está fuera del gap. SOLUCIÓN Acercar la sonda al gap programado."@es .

ns1:Error_3741 a ns1:AvisoSeguridad ;
    rdfs:label "#GAPCTRL: fuera del rango [GAPMAX - GAPMIN]"@es ;
    ns1:identificador "3741" ;
    ns1:mitigaRiesgo ns1:Solucion_3741 ;
    ns1:textoExtracto "3741 #GAPCTRL: fuera del rango [GAPMAX - GAPMIN]. DETECCIÓN Durante la ejecución. CAUSA El gap ha sobrepasado los valores máximo o mínimo permitido, fijado por GAPMAX o GAPMIN. Es posible que el sensor no de una lectura correcta. SOLUCIÓN Revisar la programación. Cambiar el valor del parámetro GAPERRORCANCEL para que el CNC no de error."@es .

ns1:Error_3742 a ns1:AvisoSeguridad ;
    rdfs:label "#GAPCTRL: fuera del rango GAPTOL"@es ;
    ns1:identificador "3742" ;
    ns1:mitigaRiesgo ns1:Solucion_3742 ;
    ns1:textoExtracto "3742 #GAPCTRL: fuera del rango GAPTOL. DETECCIÓN Durante la ejecución. CAUSA La diferencia entre la señal del gap y el gap programado es superior a la tolerancia permitida (parámetro GAPTOL). SOLUCIÓN Revisar la programación. Cambiar el valor del parámetro GAPTOLCANCEL para que el CNC no de error."@es .

ns1:Error_3743 a ns1:AvisoSeguridad ;
    rdfs:label "Colisión de palpador"@es ;
    ns1:identificador "3743" ;
    ns1:mitigaRiesgo ns1:Solucion_3743 ;
    ns1:textoExtracto "3743 Colisión de palpador. DETECCIÓN Durante la ejecución. CAUSA Ha llegado señal de la sonda de palpado cuando no se esperaba. SOLUCIÓN Comprobar que no hay ningún obstáculo en el recorrido de los ejes."@es .

ns1:Param_GAPDISTLIMIT a ns1:Parametro ;
    rdfs:label "GAPDISTLIMIT"@es ;
    ns1:identificador "GAPDISTLIMIT" ;
    ns1:textoExtracto "parámetro GAPDISTLIMIT"@es ;
    ns1:valor "Límite máximo de distancia del gap"@es .

ns1:Param_GAPMAX a ns1:Parametro ;
    rdfs:label "GAPMAX"@es ;
    ns1:identificador "GAPMAX" ;
    ns1:textoExtracto "El gap ha sobrepasado los valores máximo o mínimo permitido, fijado por GAPMAX o GAPMIN"@es ;
    ns1:valor "Valor máximo permitido del gap"@es .

ns1:Param_GAPMIN a ns1:Parametro ;
    rdfs:label "GAPMIN"@es ;
    ns1:identificador "GAPMIN" ;
    ns1:textoExtracto "fijado por GAPMAX o GAPMIN"@es ;
    ns1:valor "Valor mínimo permitido del gap"@es .

ns1:Param_GAPTOL a ns1:Parametro ;
    rdfs:label "GAPTOL"@es ;
    ns1:identificador "GAPTOL" ;
    ns1:textoExtracto "tolerancia permitida (parámetro GAPTOL)"@es ;
    ns1:valor "Tolerancia permitida del gap"@es .

ns1:Param_GAPVOLTLIMIT a ns1:Parametro ;
    rdfs:label "GAPVOLTLIMIT"@es ;
    ns1:identificador "GAPVOLTLIMIT" ;
    ns1:textoExtracto "parámetros GAPDISTLIMIT y GAPVOLTLIMIT"@es ;
    ns1:valor "Límite de voltaje de la sonda"@es .

ns1:Solucion_3739 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de conexión y parametrización de la sonda GAPCTRL"@es ;
    ns1:textoExtracto "SOLUCIÓN Revisar la conexión y la parametrización de la sonda. Si el error persiste, póngase en contacto con su proveedor."@es .

ns1:Solucion_3740 a ns1:TareaMantenimiento ;
    rdfs:label "Ajuste de posición de la sonda al gap programado"@es ;
    ns1:textoExtracto "SOLUCIÓN Acercar la sonda al gap programado."@es .

ns1:Solucion_3741 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación y ajuste de GAPERRORCANCEL"@es ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Cambiar el valor del parámetro GAPERRORCANCEL para que el CNC no de error."@es .

ns1:Solucion_3742 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación y ajuste de GAPTOLCANCEL"@es ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación. Cambiar el valor del parámetro GAPTOLCANCEL para que el CNC no de error."@es .

ns1:Solucion_3743 a ns1:TareaMantenimiento ;
    rdfs:label "Verificación de obstáculos en recorrido de ejes"@es ;
    ns1:textoExtracto "SOLUCIÓN Comprobar que no hay ningún obstáculo en el recorrido de los ejes."@es .

