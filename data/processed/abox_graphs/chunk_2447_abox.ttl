@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_3743 a ns1:DiagnosticoFallo ;
    rdfs:label "Colisión de palpador" ;
    ns1:identificador "3743" ;
    ns1:solucionaFallo ns1:TareaMantenimiento_3743 ;
    ns1:textoExtracto "3743 Colisión de palpador. DETECCIÓN Durante la ejecución. CAUSA Ha llegado señal de la sonda de palpado cuando no se esperaba." .

ns1:Fallo_3744 a ns1:DiagnosticoFallo ;
    rdfs:label "#GAPCTRL: No hay señal de la sonda" ;
    ns1:identificador "3744" ;
    ns1:solucionaFallo ns1:TareaMantenimiento_3744 ;
    ns1:textoExtracto "3744 #GAPCTRL: No hay señal de la sonda. DETECCIÓN Durante la ejecución. CAUSA No hay señal del sensor, a partir de la cual el CNC calcula la distancia." .

ns1:Sensor_SondaPalpado a ns1:Sensor ;
    rdfs:label "Sonda de palpado" ;
    ns1:monitoreaParametro ns1:Parametro_Distancia ;
    ns1:textoExtracto "señal de la sonda de palpado" .

ns1:Parametro_Distancia a ns1:Parametro ;
    rdfs:label "Distancia calculada por CNC" ;
    ns1:textoExtracto "la distancia. SOLUCIÓN Verificar que las conexiones de la sonda y los parámetros máquina relacionados con la sonda" .

ns1:TareaMantenimiento_3743 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobación de obstáculos en ejes" ;
    ns1:textoExtracto "Comprobar que no hay ningún obstáculo en el recorrido de los ejes." .

ns1:TareaMantenimiento_3744 a ns1:TareaMantenimiento ;
    rdfs:label "Verificación de conexiones y parámetros de sonda" ;
    ns1:textoExtracto "Verificar que las conexiones de la sonda y los parámetros máquina relacionados con la sonda" .

