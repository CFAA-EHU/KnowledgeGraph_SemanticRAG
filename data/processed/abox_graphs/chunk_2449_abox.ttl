@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_3747 a ns1:DiagnosticoFallo ;
    rdfs:label "Hardware no compatible con SWT" ;
    ns1:identificador "3747" ;
    ns1:solucionaFallo ns1:Sistema_CNC ;
    ns1:textoExtracto "Hardware no compatible con SWT. DETECCIÓN Durante la ejecución del corte en rejilla. CAUSA El hardware no está preparado para la prestación \"Conmutación sincronizada\". SOLUCIÓN Verificar que el CNC dispone de 2 salidas digitales locales preparadas para conmutación rápida." .

ns1:Fallo_3748 a ns1:DiagnosticoFallo ;
    rdfs:label "Hardware no compatible con PWM" ;
    ns1:identificador "3748" ;
    ns1:solucionaFallo ns1:Sistema_CNC ;
    ns1:textoExtracto "Hardware no compatible con PWM. DETECCIÓN Durante la ejecución del PWM. CAUSA El hardware no está preparado para la prestación PWM. SOLUCIÓN Verificar que el CNC dispone de 2 salidas digitales locales preparadas para conmutación rápida." .

ns1:Fallo_3749 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha detectado señal de sonda en #GAPCTRL o #LEAP" ;
    ns1:identificador "3749" ;
    ns1:solucionaFallo ns1:Sensor_Sonda ;
    ns1:textoExtracto "No se ha detectado señal de sonda en #GAPCTRL o #LEAP. DETECCIÓN Durante la ejecución. CAUSA Durante #GAPCTRL o #LEAP, el eje ha alcanzado el punto de acercamiento sin recibir la señal de sonda. SOLUCIÓN Cambiar la posición de acercamiento a la pieza." .

ns1:Fallo_3750 a ns1:DiagnosticoFallo ;
    rdfs:label "El contaje de este eje no es susceptible de ser inhibido" ;
    ns1:identificador "3750" ;
    ns1:textoExtracto "El contaje de este eje no es susceptible de ser inhibido. DETECCIÓN Al desactivar un eje." .

ns1:Parametro_ConmutacionSincronizada a ns1:Parametro ;
    ns1:textoExtracto "prestación \"Conmutación sincronizada\"" .

ns1:Parametro_PWM a ns1:Parametro ;
    ns1:textoExtracto "prestación PWM" .

ns1:Parametro_PosicionEje a ns1:Parametro ;
    ns1:textoExtracto "punto de acercamiento a la pieza" .

ns1:SalidasDigitales_ConmutacionRapida a ns1:ComponenteElectrico ;
    ns1:monitoreaParametro ns1:Parametro_ConmutacionSincronizada,
        ns1:Parametro_PWM ;
    ns1:textoExtracto "2 salidas digitales locales preparadas para conmutación rápida" .

ns1:Sensor_Sonda a ns1:Sensor ;
    ns1:monitoreaParametro ns1:Parametro_PosicionEje ;
    ns1:textoExtracto "señal de sonda en #GAPCTRL o #LEAP" .

ns1:Sistema_CNC a ns1:Sistema ;
    ns1:textoExtracto "Verificar que el CNC dispone de 2 salidas digitales locales preparadas para conmutación rápida." ;
    ns1:tieneComponente ns1:SalidasDigitales_ConmutacionRapida .

