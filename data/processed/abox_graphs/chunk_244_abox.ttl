@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_AdaptacionSplineActivada a ns1:ModoOperacion ;
    rdfs:label "Activate spline adaptation." ;
    ns1:textoExtracto "Activate spline adaptation." .

ns1:ModoOperacion_AdaptacionSplineCancelada a ns1:ModoOperacion ;
    rdfs:label "Cancels spline adaptation." ;
    ns1:textoExtracto "Cancels spline adaptation." .

ns1:ModoOperacion_BucleAbierto a ns1:ModoOperacion ;
    rdfs:label "Activate the open loop mode." ;
    ns1:textoExtracto "Activate the open loop mode." .

ns1:ModoOperacion_ConmutacionSincronizadaActivada a ns1:ModoOperacion ;
    rdfs:label "Activate synchronized switching." ;
    ns1:textoExtracto "Activate synchronized switching." .

ns1:ModoOperacion_ConmutacionSincronizadaCancelada a ns1:ModoOperacion ;
    rdfs:label "Cancel synchronized switching." ;
    ns1:textoExtracto "Cancel synchronized switching." .

ns1:ModoOperacion_ControlAceleracion a ns1:ModoOperacion ;
    rdfs:label "Acceleration control." ;
    ns1:textoExtracto "Acceleration control." .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Manual intervention. Moving limits." ;
    ns1:textoExtracto "Manual intervention. Moving limits." .

