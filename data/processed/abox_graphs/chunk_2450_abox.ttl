@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_3750 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 3750: Contaje de eje no inhibible"@es ;
    ns1:identificador "3750" ;
    ns1:solucionaFallo ns1:Bit_AXISOPTION_0x80000000 ;
    ns1:textoExtracto "El contaje de este eje no es susceptible de ser inhibido. DETECCIÓN Al desactivar un eje. CAUSA El eje que se desactiva no tiene una captación en el módulo RCS-S. SOLUCIÓN Sólo puede inhibirse un contaje del módulo RCS-S. Revisar el bit 0x80000000 de AXISOPTION del eje involucrado en la maniobra de desactivación."@es .

ns1:Fallo_3751 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 3751: Drive Feedback no válido"@es ;
    ns1:identificador "3751" ;
    ns1:textoExtracto "Drive Feedback no válido. DETECCIÓN Durante el arranque del CNC o tras un reset."@es .

ns1:Bit_AXISOPTION_0x80000000 a ns1:Parametro ;
    rdfs:label "Bit 0x80000000 de AXISOPTION"@es ;
    ns1:monitoreaParametro ns1:Modulo_RCS_S ;
    ns1:textoExtracto "bit 0x80000000 de AXISOPTION"@es ;
    ns1:valor "0x80000000" .

ns1:Modulo_RCS_S a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S"@es ;
    ns1:textoExtracto "módulo RCS-S"@es .

