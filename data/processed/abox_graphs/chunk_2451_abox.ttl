@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteElectrico_Regulador a ns1:ComponenteElectrico ;
    rdfs:label "Regulador del eje" ;
    ns1:controla ns1:Sensor_FeedbackEje ;
    ns1:textoExtracto "El regulador no está inicializado correctamente." .

ns1:Parametro_MAXDIFREF a ns1:Parametro ;
    rdfs:label "Límite máximo de diferencia de posición (MAXDIFREF)" ;
    ns1:textoExtracto "Diferencia de posición mayor que MAXDIFREF" .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:activaAlarma ns1:Alarma_3751,
        ns1:Alarma_3752,
        ns1:Alarma_3753 ;
    ns1:textoExtracto "arranque del CNC" ;
    ns1:tieneComponente ns1:Sensor_FeedbackEje .

ns1:Alarma_3751 a ns1:Alarma ;
    rdfs:label "Drive Feedback no válido" ;
    ns1:identificador "3751" ;
    ns1:textoExtracto "3751 Drive Feedback no válido. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA No se ha podido calcular correctamente el feedback de posición para el eje. El regulador no está inicializado correctamente. SOLUCIÓN Revisar el conexionado y parametrización de los feedbacks, y reiniciar el sistema." .

ns1:Alarma_3752 a ns1:Alarma ;
    rdfs:label "Gap fuera de rango en el límite de posición" ;
    ns1:identificador "3752" ;
    ns1:textoExtracto "3752 Gap fuera de rango en el límite de posición. DETECCIÓN Durante la ejecución. CAUSA Durante #GAPCTRL o #LEAP, el eje ha alcanzado el punto de acercamiento sin recibir la señal de sonda. SOLUCIÓN Cambiar la posición de acercamiento a la pieza." .

ns1:Alarma_3753 a ns1:Alarma ;
    rdfs:label "Diferencia de posición mayor que MAXDIFREF" ;
    ns1:identificador "3753" ;
    ns1:textoExtracto "3753 Diferencia de posición mayor que MAXDIFREF. Pulsar ENTER + RESET para confirmar. DETECCIÓN Durante el arranque del CNC. CAUSA La cota absoluta del captador no se corresponde con la cota salvada en la última sesión del CNC." .

ns1:Parametro_PosicionEje a ns1:Parametro ;
    rdfs:label "Posición del eje" ;
    ns1:textoExtracto "feedback de posición para el eje" .

ns1:Sensor_FeedbackEje a ns1:Sensor ;
    rdfs:label "Sensor de feedback de posición del eje" ;
    ns1:monitoreaParametro ns1:Parametro_PosicionEje ;
    ns1:textoExtracto "No se ha podido calcular correctamente el feedback de posición para el eje." .

