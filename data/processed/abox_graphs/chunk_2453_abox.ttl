@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_GAPCTRL a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad ángulo compensación gap con dirección sensor"@es ;
    ns1:monitoreaParametro ns1:SensorDireccionGap ;
    ns1:solucionaFallo ns1:AnguloProgramacionCompensacionGap ;
    ns1:textoExtracto "Con el control de gap en n ejes activo (#GAPCTRL), el ángulo programado para la compensación del gap es incompatible con la dirección del sensor. SOLUCIÓN Cambiar el ángulo de programación."@es .

ns1:Solucion_3755 a ns1:TareaMantenimiento ;
    rdfs:label "Actualización versión regulador o ajuste PLOOPRESOL"@es ;
    ns1:solucionaFallo ns1:Fallo_PLOOPRESOL ;
    ns1:textoExtracto "El regulador no tiene la versión adecuada para el valor de PLOOPRESOL"@es .

ns1:AnguloProgramacionCompensacionGap a ns1:Parametro ;
    rdfs:label "Ángulo programación compensación gap"@es ;
    ns1:textoExtracto "ángulo programado para la compensación del gap"@es .

ns1:Fallo_PLOOPRESOL a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad PLOOPRESOL con versión regulador"@es ;
    ns1:controla ns1:ReguladorCNC ;
    ns1:identificador "3755" ;
    ns1:monitoreaParametro ns1:PLOOPRESOL_2d2d57977e ;
    ns1:textoExtracto "3755 Parámetro máquina PLOOPRESOL incompatible con versión del regulador. DETECCIÓN Durante el arranque del CNC o validación de los parámetros máquina. CAUSA El regulador no tiene la versión adecuada para el valor de PLOOPRESOL."@es .

ns1:PLOOPRESOL_2d2d57977e a ns1:Parametro ;
    rdfs:label "PLOOPRESOL" ;
    ns1:identificador "PLOOPRESOL" ;
    ns1:textoExtracto "Parámetro máquina PLOOPRESOL"@es .

ns1:ReguladorCNC a ns1:ComponenteElectrico ;
    rdfs:label "Regulador CNC"@es ;
    ns1:textoExtracto "versión del regulador"@es .

ns1:SensorDireccionGap a ns1:Sensor ;
    rdfs:label "Sensor dirección gap"@es ;
    ns1:textoExtracto "dirección del sensor"@es .

