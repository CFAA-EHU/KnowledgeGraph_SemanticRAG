@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_3756 a ns1:DiagnosticoFallo ;
    rdfs:label "3756 RPS, tiempo de parámetro SSTIME alcanzado sin tensión de bus estable" ;
    ns1:solucionaFallo ns1:ComponenteElectrico_EquipoSoftstartBusDC,
        ns1:ComponenteElectrico_Se_alSoftstart,
        ns1:Parametro_SSTIME ;
    ns1:textoExtracto "3756 RPS, tiempo de parámetro SSTIME alcanzado sin tener una tensión de bus estable. DETECCIÓN Al arrancar la maniobra de la RPS con las marcas PWSENAF y PWSENAS. CAUSA No se carga la tensión de bus en el tiempo estimado. SOLUCIÓN Las posibles soluciones son las siguientes: • Aumentar el tiempo SSTIME. • Verificar que llega la señal de softstart a la RPS. • Verificar la tensión de red en el equipo que realiza el softstart del bus DC." .

ns1:Fallo_3757 a ns1:DiagnosticoFallo ;
    rdfs:label "3757 RPS, error en la ejecución del comando de sincronización de la placa sense" ;
    ns1:solucionaFallo ns1:ComponenteElectrico_ConectorX11,
        ns1:ComponenteElectrico_ConectorX60,
        ns1:ComponenteElectrico_PlacaSense ;
    ns1:textoExtracto "3757 RPS, error en la ejecución del comando de sincronización de la placa sense. DETECCIÓN Al arrancar la maniobra de la RPS con las marcas PWSENAF y PWSENAS. CAUSA No se detecta tensión en alguna de las ramas de la placa sense durante el comando de sincronización. SOLUCIÓN Revisar el conexionado, la placa sense, el conector X60 (captación de la tensión de línea) y el conector X11 (cable de potencia X11)." .

ns1:Fallo_3758 a ns1:DiagnosticoFallo ;
    rdfs:label "3758 RPS, regulador en error o en un estado incorrecto" ;
    ns1:solucionaFallo ns1:ComponenteElectrico_ReguladorRPS ;
    ns1:textoExtracto "3758 RPS, regulador en error o en un estado incorrecto. DETECCIÓN Al arrancar la maniobra de la RPS con las marcas PWSENAF y PWSENAS. CAUSA El regulador se encuentra en error o en un estado no esperado por el CNC. SOLUCIÓN Revisar el conexionado y la parametrización del regulador." .

ns1:Fallo_3759 a ns1:DiagnosticoFallo ;
    rdfs:label "3759 RPS, fallo en el control del contactor, sobrecorriente en la salida X12 freno-contactor" ;
    ns1:solucionaFallo ns1:ComponenteElectrico_ContactorX12 ;
    ns1:textoExtracto "3759 RPS, fallo en el control del contactor, sobrecorriente en la salida X12 freno-contactor. DETECCIÓN Al arrancar la maniobra de la RPS con las marcas PWSENAF y PWSENAS. CAUSA Sobrecorriente en la salida del freno-contactor." .

ns1:Fallo_VersionRegulador a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad de versión del regulador con PLOOPRESOL" ;
    ns1:solucionaFallo ns1:ComponenteElectrico_ReguladorRPS,
        ns1:Parametro_PLOOPRESOL ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC o validación de los parámetros máquina. CAUSA El regulador no tiene la versión adecuada para el valor de PLOOPRESOL. SOLUCIÓN Verificar el valor del parámetro PLOOPRESOL y la versión del regulador." .

ns1:ComponenteElectrico_ConectorX11 a ns1:ComponenteElectrico ;
    rdfs:label "Conector X11" ;
    ns1:identificador "X11" ;
    ns1:textoExtracto "conector X11 (cable de potencia X11)" .

ns1:ComponenteElectrico_ConectorX60 a ns1:ComponenteElectrico ;
    rdfs:label "Conector X60" ;
    ns1:identificador "X60" ;
    ns1:textoExtracto "conector X60 (captación de la tensión de línea)" .

ns1:ComponenteElectrico_ContactorX12 a ns1:ComponenteElectrico ;
    rdfs:label "Contactor X12 (freno-contactor)" ;
    ns1:identificador "X12" ;
    ns1:textoExtracto "salida X12 freno-contactor ; Sobrecorriente en la salida del freno-contactor" .

ns1:ComponenteElectrico_EquipoSoftstartBusDC a ns1:ComponenteElectrico ;
    rdfs:label "Equipo de softstart del bus DC" ;
    ns1:textoExtracto "Verificar la tensión de red en el equipo que realiza el softstart del bus DC" .

ns1:ComponenteElectrico_PlacaSense a ns1:ComponenteElectrico ;
    rdfs:label "Placa sense" ;
    ns1:textoExtracto "error en la ejecución del comando de sincronización de la placa sense ; No se detecta tensión en alguna de las ramas de la placa sense durante el comando de sincronización" .

ns1:ComponenteElectrico_Se_alSoftstart a ns1:ComponenteElectrico ;
    rdfs:label "Señal de softstart a RPS" ;
    ns1:textoExtracto "Verificar que llega la señal de softstart a la RPS" .

ns1:Parametro_PLOOPRESOL a ns1:Parametro ;
    rdfs:label "PLOOPRESOL" ;
    ns1:identificador "PLOOPRESOL" ;
    ns1:textoExtracto "valor de PLOOPRESOL" .

ns1:Parametro_SSTIME a ns1:Parametro ;
    rdfs:label "SSTIME" ;
    ns1:identificador "SSTIME" ;
    ns1:textoExtracto "tiempo de parámetro SSTIME alcanzado sin tener una tensión de bus estable" .

ns1:ComponenteElectrico_ReguladorRPS a ns1:ComponenteElectrico ;
    rdfs:label "Regulador RPS" ;
    ns1:textoExtracto "regulador no tiene la versión adecuada para el valor de PLOOPRESOL ; El regulador se encuentra en error o en un estado no esperado por el CNC" .

