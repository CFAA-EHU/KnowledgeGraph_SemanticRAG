@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_3759_RPS a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en control del contactor (RPS 3759)"@es ;
    ns1:identificador "3759" ;
    ns1:solucionaFallo ns1:Solucion_3759_AlimentacionX12,
        ns1:Solucion_3759_ContactorEstropeado,
        ns1:Solucion_3759_RevisarCableado ;
    ns1:textoExtracto "3759 RPS, fallo en el control del contactor, sobrecorriente en la salida X12 freno-contactor. DETECCIÓN Al arrancar la maniobra de la RPS con las marcas PWSENAF y PWSENAS. CAUSA Sobrecorriente en la salida del freno-contactor."@es .

ns1:Fallo_3760_RPS a ns1:DiagnosticoFallo ;
    rdfs:label "Tensión de bus por debajo de la deseada (RPS 3760)"@es ;
    ns1:identificador "3760" ;
    ns1:textoExtracto "3760 RPS, tensión de bus por debajo de la deseada. DETECCIÓN Al arrancar la maniobra de la RPS con las marcas PWSENAF y PWSENAS."@es .

ns1:Solucion_3759_AlimentacionX12 a ns1:TareaMantenimiento ;
    rdfs:label "Verificar alimentación de 24 Vdc en conector X12"@es ;
    ns1:requiereMantenimiento ns1:Componente_X12 ;
    ns1:textoExtracto "Falta la alimentación de 24 Vdc en el conector X12 o es superior a 26 Vdc."@es .

ns1:Solucion_3759_ContactorEstropeado a ns1:TareaMantenimiento ;
    rdfs:label "Reemplazar contactor estropeado"@es ;
    ns1:requiereMantenimiento ns1:ContactorPotencia_3759 ;
    ns1:textoExtracto "Contactor estropeado."@es .

ns1:Solucion_3759_RevisarCableado a ns1:TareaMantenimiento ;
    rdfs:label "Revisar cableado del conector X12 y contactor de potencia"@es ;
    ns1:requiereMantenimiento ns1:Componente_X12,
        ns1:ContactorPotencia_3759 ;
    ns1:textoExtracto "Revisar el cableado del conector X12 y del contactor de potencia."@es .

ns1:Componente_X12 a ns1:ComponenteElectrico ;
    rdfs:label "Conector X12 (freno-contactor)"@es ;
    ns1:identificador "X12" ;
    ns1:textoExtracto "salida X12 freno-contactor"@es .

ns1:ContactorPotencia_3759 a ns1:ComponenteElectrico ;
    rdfs:label "Contactor de potencia (freno)"@es ;
    ns1:textoExtracto "contactor de potencia"@es .

