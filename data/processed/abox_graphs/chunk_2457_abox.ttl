@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CAUSA1 a ns1:DiagnosticoFallo ;
    rdfs:label "El avance o la distancia a moverse en jog incremental es cero. No hay programado ningún avance para el modo manual y el parámetro máquina INCJOGFEED es cero, o el parámetro máquina INCJOGDIST es cero." ;
    ns1:solucionaFallo ns1:SOLUCION1 ;
    ns1:textoExtracto "CAUSA El avance o la distancia a moverse en jog incremental es cero. No hay programado ningún avance para el modo manual y el parámetro máquina INCJOGFEED es cero, o el parámetro máquina INCJOGDIST es cero." .

ns1:MAQUINA1 a ns1:Maquina ;
    rdfs:label "máquina" ;
    ns1:ejecutadoPor ns1:MODOMANUAL ;
    ns1:textoExtracto "máquina" ;
    ns1:tieneComponente ns1:PARAMETRO1,
        ns1:PARAMETRO2 .

ns1:MODOMANUAL a ns1:ModoOperacion ;
    rdfs:label "modo manual" ;
    ns1:requiereMantenimiento ns1:SOLUCION1 ;
    ns1:textoExtracto "modo manual" .

ns1:PARAMETRO1 a ns1:Parametro ;
    rdfs:label "parámetro máquina de ejes JOGFEED" ;
    ns1:monitoreaParametro ns1:DETECCION1 ;
    ns1:textoExtracto "parámetro máquina de ejes JOGFEED" .

ns1:PARAMETRO2 a ns1:Parametro ;
    rdfs:label "parámetros máquina de ejes INCJOGFEED e" ;
    ns1:monitoreaParametro ns1:DETECCION1 ;
    ns1:textoExtracto "parámetros máquina de ejes INCJOGFEED e" .

ns1:DETECCION1 a ns1:Alarma ;
    rdfs:label "Durante la ejecución" ;
    ns1:activaAlarma ns1:SOLUCION1 ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución" .

ns1:SOLUCION1 a ns1:AccionProhibida ;
    rdfs:label "Definir un nuevo avance desde el modo manual. Revisar el parámetro máquina de ejes JOGFEED. 3801 'Distancia o velocidad en jog incremental igual a cero'" ;
    ns1:textoExtracto "SOLUCIÓN Definir un nuevo avance desde el modo manual. Revisar el parámetro máquina de ejes JOGFEED. 3801 'Distancia o velocidad en jog incremental igual a cero'" .

