@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_3808 a ns1:Alarma ;
    rdfs:label "Eje inexistente o no disponible"@es ;
    ns1:identificador "3808" ;
    ns1:textoExtracto "3808 'Eje inexistente o no disponible' DETECCIÓN Durante la ejecución."@es .

ns1:Parametro_INCJOGIDX a ns1:Parametro ;
    rdfs:label "Variable (V.)PLC.INCJOGIDX"@es ;
    ns1:monitoreaParametro ns1:Alarma_3807 ;
    ns1:textoExtracto "variable (V.)PLC.INCJOGIDX"@es .

ns1:DiagnosticoFallo_3807 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en variable (V.)PLC.INCJOGIDX"@es ;
    ns1:solucionaFallo ns1:Alarma_3807 ;
    ns1:textoExtracto "Revisar en el programa de PLC la escritura de la variable (V.)PLC.INCJOGIDX."@es .

ns1:Alarma_3807 a ns1:Alarma ;
    rdfs:label "Índice de jog incremental fuera de rango (posiciones del conmutador 1-5)"@es ;
    ns1:identificador "3807" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_3807 ;
    ns1:textoExtracto "3807 'Índice de jog incremental fuera de rango (posiciones del conmutador 1-5)' DETECCIÓN Durante la ejecución. CAUSA El PLC ha intentado seleccionar una posición de jog incremental que está fuera rango permitido. SOLUCIÓN Revisar en el programa de PLC la escritura de la variable (V.)PLC.INCJOGIDX."@es .

