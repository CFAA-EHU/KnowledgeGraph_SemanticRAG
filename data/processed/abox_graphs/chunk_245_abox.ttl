@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:ConmutacionSincronizada a ns1:ModoOperacion ;
    ns1:identificador "#SWTOUT" ;
    ns1:textoExtracto "#SWTOUT OFF | Cancel synchronized switching." .

ns1:ControlTangencial a ns1:ModoOperacion ;
    ns1:identificador "#TANGCTRL" ;
    ns1:textoExtracto "#TANGCTRL OFF | Cancel tangential control." .

ns1:IntervencionManual a ns1:ModoOperacion ;
    ns1:identificador "#SYNC POS" ;
    ns1:textoExtracto "#SYNC POS | Manual intervention. Coordinate synchronization." .

ns1:SistemaControlSincronizado a ns1:Sistema ;
    ns1:textoExtracto "Spindle synchronization based on the real (actual) coordinate." ;
    ns1:tieneComponente ns1:SincronizacionEje .

ns1:SplineAdaptacion a ns1:ModoOperacion ;
    ns1:identificador "#SPLINE ON" ;
    ns1:textoExtracto "#SPLINE ON | Akima splines. Activate spline adaptation." .

ns1:SincronizacionEje a ns1:ModoOperacion ;
    ns1:identificador "#SYNC" ;
    ns1:textoExtracto "#SYNC | Spindle synchronization based on the real (actual) coordinate." .

