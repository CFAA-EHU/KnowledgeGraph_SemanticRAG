@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Funcion_G95 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G95"@es ;
    ns1:identificador "G95" ;
    ns1:monitoreaParametro ns1:Fallo_3809 ;
    ns1:textoExtracto "Velocidad programada de cabezal nula en G95"@es .

ns1:ModoManual a ns1:ModoOperacion ;
    rdfs:label "Modo manual"@es ;
    ns1:textoExtracto "El eje no estaba en modo manual al abandonar dicho modo."@es .

ns1:Sentencia_TANGCTRLON a ns1:Parametro ;
    rdfs:label "Sentencia #TANGCTRLON"@es ;
    ns1:identificador "#TANGCTRLON" ;
    ns1:textoExtracto "Nombre de eje no válido en la sentencia #TANGCTRLON."@es .

ns1:SistemaGantry a ns1:Sistema ;
    rdfs:label "Sistema de pareja gantry"@es ;
    ns1:textoExtracto "Las funciones G101 y G102 se deben programar para el eje maestro de la pareja gantry."@es ;
    ns1:tieneComponente ns1:Funcion_G101,
        ns1:Funcion_G102 .

ns1:Variable_PLC_INCJOGIDX a ns1:Parametro ;
    rdfs:label "Variable PLC.INCJOGIDX"@es ;
    ns1:identificador "V.PLC.INCJOGIDX" ;
    ns1:monitoreaParametro ns1:Fallo_3808 ;
    ns1:textoExtracto "Revisar en el programa de PLC la escritura de la variable (V.)PLC.INCJOGIDX."@es .

ns1:Fallo_3808 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje inexistente o no disponible"@es ;
    ns1:identificador "3808" ;
    ns1:textoExtracto "3808 'Eje inexistente o no disponible' DETECCIÓN Durante la ejecución. CAUSA Las posibles causas son las siguientes: • El eje no estaba en modo manual al abandonar dicho modo. • El CNC ha detectado la función G101 o G102 para el eje esclavo de una pareja gantry. • Nombre de eje no válido en la sentencia #TANGCTRLON. SOLUCIÓN Las posibles soluciones son las siguientes: • Pulsar reset para poder salir del modo manual. • Las funciones G101 y G102 se deben programar para el eje maestro de la pareja gantry. • Revisar la programación de la sentencia #TANGCTRLON."@es .

ns1:Fallo_3809 a ns1:DiagnosticoFallo ;
    rdfs:label "Velocidad programada de cabezal nula en G95"@es ;
    ns1:identificador "3809" ;
    ns1:textoExtracto "3809 'Velocidad programada de cabezal nula en G95' DETECCIÓN Durante la ejecución."@es .

ns1:Funcion_G101 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G101"@es ;
    ns1:identificador "G101" ;
    ns1:textoExtracto "El CNC ha detectado la función G101 o G102 para el eje esclavo de una pareja gantry."@es .

ns1:Funcion_G102 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G102"@es ;
    ns1:identificador "G102" ;
    ns1:textoExtracto "El CNC ha detectado la función G101 o G102 para el eje esclavo de una pareja gantry."@es .

