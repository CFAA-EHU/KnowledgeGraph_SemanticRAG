@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:componente_eje_hirth a ns1:ComponenteMecanico ;
    rdfs:label "Eje Hirth" ;
    ns1:activaAlarma ns1:alarma_3810 ;
    ns1:textoExtracto "eje Hirth" .

ns1:modo_operacion_G95 a ns1:ModoOperacion ;
    rdfs:label "Función G95" ;
    ns1:activaAlarma ns1:alarma_3809 ;
    ns1:textoExtracto "función G95 activa" .

ns1:modo_operacion_jog_continuo a ns1:ModoOperacion ;
    rdfs:label "Modo Jog Continuo" ;
    ns1:textoExtracto "modo jog continuo" .

ns1:modo_operacion_jog_incremental a ns1:ModoOperacion ;
    rdfs:label "Modo Jog Incremental" ;
    ns1:textoExtracto "modo jog incremental" .

ns1:modo_operacion_volante a ns1:ModoOperacion ;
    rdfs:label "Modo Volante" ;
    ns1:activaAlarma ns1:alarma_3810 ;
    ns1:textoExtracto "modo volante" .

ns1:parametro_incremento_volante a ns1:Parametro ;
    rdfs:label "Incremento de Volante" ;
    ns1:activaAlarma ns1:alarma_3811 ;
    ns1:textoExtracto "incremento demasiado grande en el contaje de volante" .

ns1:parametro_velocidad_cabezal a ns1:Parametro ;
    rdfs:label "Velocidad del Cabezal" ;
    ns1:monitoreaParametro ns1:componente_cabezal_master ;
    ns1:textoExtracto "velocidad cero en el cabezal" ;
    ns1:valor "0" .

ns1:alarma_3811 a ns1:Alarma ;
    rdfs:label "Límite de incremento de volante superado" ;
    ns1:identificador "3811" ;
    ns1:textoExtracto "3811 'Límite de incremento de volante superado' DETECCIÓN En modo manual, durante la lectura del contaje de un volante. CAUSA Incremento demasiado grande en el contaje de volante." .

ns1:componente_cabezal_master a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal Master" ;
    ns1:activaAlarma ns1:alarma_3809 ;
    ns1:textoExtracto "cabezal master del canal" .

ns1:alarma_3809 a ns1:Alarma ;
    rdfs:label "Velocidad programada de cabezal nula en G95" ;
    ns1:identificador "3809" ;
    ns1:textoExtracto "3809 'Velocidad programada de cabezal nula en G95' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado mover un eje en jog continuo o incremental con la función G95 activa y velocidad cero en el cabezal utilizado para la sincronización. SOLUCIÓN Programar una velocidad para el cabezal master del canal o para el cabezal utilizado para la sincronización (registro SYNC)." .

ns1:alarma_3810 a ns1:Alarma ;
    rdfs:label "Modo Volante no permitido con eje Hirth" ;
    ns1:identificador "3810" ;
    ns1:textoExtracto "3810 'Modo Volante no permitido con eje Hirth' DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado seleccionar en eje Hirth para desplazarlo en modo volante. SOLUCIÓN No está permitido mover en modo volante un eje Hirth; puede moverse en modo jog continuo y jog incremental." .

