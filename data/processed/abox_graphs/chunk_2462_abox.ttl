@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_IncrementoContajeVolante a ns1:DiagnosticoFallo ;
    ns1:textoExtracto "CAUSA Incremento demasiado grande en el contaje de volante. SOLUCIÓN Revisar la captación conectada en la entrada de volante; niveles de señal, frecuencia, etc." .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "modo manual" ;
    ns1:activaAlarma ns1:Error_3812 ;
    ns1:textoExtracto "En modo manual, durante la lectura del contaje de un volante." .

ns1:Modulo_RCS_S a ns1:ComponenteElectrico ;
    rdfs:label "módulo RCS-S" ;
    ns1:textoExtracto "En función del tipo de volante (teclado CAN, contadora CAN, local, módulo RCS-S, etc)" .

ns1:Volante_ContadoraCAN a ns1:Componente ;
    rdfs:label "volante (contadora CAN)" ;
    ns1:textoExtracto "En función del tipo de volante (teclado CAN, contadora CAN, local, módulo RCS-S, etc)" .

ns1:Volante_Local a ns1:Componente ;
    rdfs:label "volante (local)" ;
    ns1:textoExtracto "En función del tipo de volante (teclado CAN, contadora CAN, local, módulo RCS-S, etc)" .

ns1:Volante_TecladoCAN a ns1:Componente ;
    rdfs:label "volante (teclado CAN)" ;
    ns1:textoExtracto "En función del tipo de volante (teclado CAN, contadora CAN, local, módulo RCS-S, etc)" .

ns1:BusComunicacion_CAN a ns1:Sistema ;
    rdfs:label "bus CAN" ;
    ns1:textoExtracto "revisar la coherencia y el nivel de comunicación del bus correspondiente" .

ns1:EntradaVolante a ns1:ComponenteElectrico ;
    rdfs:label "entrada de volante" ;
    ns1:textoExtracto "Revisar la captación conectada en la entrada de volante; niveles de señal, frecuencia, etc." .

ns1:Error_3812 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en refresco de volantes" ;
    ns1:identificador "3812" ;
    ns1:solucionaFallo ns1:BusComunicacion_CAN,
        ns1:EntradaVolante ;
    ns1:textoExtracto "3812 'Error en refresco de volantes' DETECCIÓN En modo manual, durante la lectura del contaje de un volante. CAUSA Lectura incorrecta del volante." .

