@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BusComunicacion_3000 a ns1:Sistema ;
    rdfs:label "Bus de comunicación" ;
    ns1:textoExtracto "nivel de comunicación del bus correspondiente"@es ;
    ns1:tieneComponente ns1:ContadoraCAN_3000,
        ns1:ModuloRCS_S_3000,
        ns1:TecladoCAN_3000 .

ns1:EntradaCaptacion_3000 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de captación" ;
    ns1:controla ns1:ModuloRCS_S_3000 ;
    ns1:textoExtracto "parametrización y conexión de la entrada de captación"@es .

ns1:ContadoraCAN_3000 a ns1:InterfazUsuario ;
    rdfs:label "Contadora CAN" ;
    ns1:textoExtracto "contadora CAN"@es .

ns1:TecladoCAN_3000 a ns1:InterfazUsuario ;
    rdfs:label "Teclado CAN" ;
    ns1:textoExtracto "teclado CAN"@es .

ns1:ModuloRCS_S_3000 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S" ;
    ns1:identificador "RCS-S" ;
    ns1:textoExtracto "módulo RCS-S"@es .

