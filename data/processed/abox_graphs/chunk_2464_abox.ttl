@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error4000_1 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización del anillo Sercos (CLASE 0)"@es ;
    ns1:identificador "4000(1)" ;
    ns1:solucionaFallo ns1:ComprobacionDePlacaSercos,
        ns1:ContactoConAsistenciaTecnica40001 ;
    ns1:textoExtracto "Error en la fase inicialización del chip. El CNC no detecta la placa Sercos u overflow en la DPRAM del SERCON por un número excesivo de ejes y datos a transmitir en el canal cíclico."@es .

ns1:Error4000_2 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización del anillo Sercos (CLASE 1)"@es ;
    ns1:identificador "4000(2)" ;
    ns1:solucionaFallo ns1:ContactoConAsistenciaTecnica40002 ;
    ns1:textoExtracto "Timeout en la petición de inicialización del anillo Sercos."@es .

ns1:ManualRegulador a ns1:Manual ;
    rdfs:label "Manual del regulador"@es ;
    ns1:documentadoEn ns1:Error4000_3 ;
    ns1:textoExtracto "Consultar el manual del regulador."@es .

ns1:PuntoError_4000_0 a ns1:Parametro ;
    rdfs:label "Punto 0: Timeout"@es ;
    ns1:documentadoEn ns1:TablaPuntosError4000 ;
    ns1:identificador "0" ;
    ns1:textoExtracto "Timeout."@es ;
    ns1:valor "Timeout"@es .

ns1:PuntoError_4000_1 a ns1:DiagnosticoFallo ;
    rdfs:label "Punto 1: Error en Fase 0 (Fibra óptica)"@es ;
    ns1:documentadoEn ns1:TablaPuntosError4000 ;
    ns1:identificador "1" ;
    ns1:textoExtracto "Error en cambio a Fase 0. (Problema en la fibra óptica)"@es ;
    ns1:valor "Error en cambio a Fase 0"@es .

ns1:PuntoError_4000_13 a ns1:Parametro ;
    rdfs:label "Punto 13: Password de fabricante"@es ;
    ns1:documentadoEn ns1:TablaPuntosError4000 ;
    ns1:identificador "13" ;
    ns1:textoExtracto "Error en escritura del password de fabricante."@es ;
    ns1:valor "Error en escritura del password de fabricante"@es .

ns1:PuntoError_4000_2 a ns1:DiagnosticoFallo ;
    rdfs:label "Punto 2: Error en Fase 1 (Regulador/Selector de nodo)"@es ;
    ns1:documentadoEn ns1:TablaPuntosError4000 ;
    ns1:identificador "2" ;
    ns1:textoExtracto "Error en cambio a Fase 1. (Un regulador no responde; fallo de hardware o selector de nodo mal puesto)"@es ;
    ns1:valor "Error en cambio a Fase 1"@es .

ns1:PuntoError_4000_4 a ns1:Parametro ;
    rdfs:label "Punto 4: Versión del fabricante"@es ;
    ns1:documentadoEn ns1:TablaPuntosError4000 ;
    ns1:identificador "4" ;
    ns1:textoExtracto "Error en lectura de la versión del fabricante."@es ;
    ns1:valor "Error en lectura de la versión del fabricante"@es .

ns1:ComprobacionDePlacaSercos a ns1:AccionProhibida ;
    rdfs:label "Comprobación de placa Sercos"@es ;
    ns1:textoExtracto "Comprobar que la placa está instalada y que el CNC la detecta correctamente."@es .

ns1:ContactoConAsistenciaTecnica40001 a ns1:AvisoSeguridad ;
    rdfs:label "Contacto con asistencia técnica (4000-1)"@es ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con el servicio de asistencia técnica."@es .

ns1:ContactoConAsistenciaTecnica40002 a ns1:AvisoSeguridad ;
    rdfs:label "Contacto con asistencia técnica (4000-2)"@es ;
    ns1:textoExtracto "Póngase en contacto con el servicio de asistencia técnica."@es .

ns1:Error4000_3 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización del anillo Sercos (Eje específico)"@es ;
    ns1:identificador "4000(3)" ;
    ns1:textoExtracto "Nombre del eje que da error. TRANSICIÓN 1: ID Sercos que provoca el error. Consultar el manual del regulador."@es .

ns1:TablaPuntosError4000 a ns1:Tabla ;
    rdfs:label "Tabla de puntos de error en inicialización Sercos"@es ;
    ns1:documentadoEn ns1:Error4000_3 ;
    ns1:textoExtracto """
| Punto. | Significado. |
| --- | --- |
| 0 | Timeout. |
| 1 | Error en cambio a Fase 0. (Problema en la fibra óptica) |
| 2 | Error en cambio a Fase 1. (Un regulador no responde; fallo de hardware o selector de nodo mal puesto) |
| 3 | Error en cambio a Fase 2. |
| 4 | Error en lectura de la versión del fabricante. |
| 5 | Error en lectura de T1mim. |
| 6 | Error en lectura de Tatmt. |
| 7 | Error en lectura de T4min. |
| 8 | Error en lectura de Tmtsy. |
| 9 | Error en lectura de Tmtsg. |
| 10 | Error en lectura de SlaveNr. |
| 11 | Error en lectura de Tatat. |
| 12 | Error en el cálculo de tiempos. |
| 13 | Error en escritura del password de fabricante. |
| 14 | Error en escritura de T1.
"""@es .

