@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_CodigosError a ns1:Tabla ;
    rdfs:label "Tabla de códigos de error (10-23)"@es ;
    ns1:documentadoEn ns1:Error_10,
        ns1:Error_11,
        ns1:Error_12,
        ns1:Error_13,
        ns1:Error_14,
        ns1:Error_15,
        ns1:Error_16,
        ns1:Error_17,
        ns1:Error_18,
        ns1:Error_19,
        ns1:Error_20,
        ns1:Error_21,
        ns1:Error_22,
        ns1:Error_23 ;
    ns1:textoExtracto "10 | Error en lectura de SlaveNr. | 11 | Error en lectura de Tatat. | 12 | Error en el cálculo de tiempos. | 13 | Error en escritura del password de fabricante. | 14 | Error en escritura de T1. | 15 | Error en escritura..."@es .

ns1:Error_10 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en lectura de SlaveNr."@es ;
    ns1:identificador "10" ;
    ns1:textoExtracto "Error en lectura de SlaveNr."@es .

