@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Aviso_WARNING a ns1:AvisoSeguridad ;
    rdfs:label "#WARNING" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#WARNING" ;
    ns1:textoExtracto "Display a warning on the screen." .

ns1:Aviso_WARNINGSTOP a ns1:AvisoSeguridad ;
    rdfs:label "#WARNINGSTOP" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#WARNINGSTOP" ;
    ns1:textoExtracto "Display a warning on the screen and interrupt the program." .

ns1:Instruccion_TANGFEED_RMIN a ns1:Parametro ;
    rdfs:label "#TANGFEED RMIN" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#TANGFEED RMIN" ;
    ns1:textoExtracto "Minimum radius for applying constant tangential feedrate." .

ns1:Instruccion_TCAM_ON a ns1:Parametro ;
    rdfs:label "#TCAM ON" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#TCAM ON" ;
    ns1:textoExtracto "Activate the electronic cam (theoretical coordinates)." .

ns1:Instruccion_TFOLLOW_ON a ns1:Parametro ;
    rdfs:label "#TFOLLOW ON" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#TFOLLOW ON" ;
    ns1:textoExtracto "Independent axis. Begin the synchronization movement (theoretical coordinates)." .

ns1:Instruccion_TIME a ns1:Parametro ;
    rdfs:label "#TIME" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#TIME" ;
    ns1:textoExtracto "Dwell." .

ns1:Instruccion_TLC a ns1:Parametro ;
    rdfs:label "#TLC" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#TLC" ;
    ns1:textoExtracto "Correct the implicit tool length compensation of the program." .

ns1:Instruccion_TOOL_AX a ns1:Parametro ;
    rdfs:label "#TOOL AX" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#TOOL AX" ;
    ns1:textoExtracto "Select the longitudinal axis of the tool." .

ns1:Instruccion_TOOL_ORI a ns1:Parametro ;
    rdfs:label "#TOOL ORI" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#TOOL ORI" ;
    ns1:textoExtracto "Tool perpendicular to the inclined plane." .

ns1:Instruccion_TSYNC a ns1:Parametro ;
    rdfs:label "#TSYNC" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#TSYNC" ;
    ns1:textoExtracto "Spindle synchronization based on the theoretical coordinate." .

ns1:Instruccion_UNLINK a ns1:Parametro ;
    rdfs:label "#UNLINK" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#UNLINK" ;
    ns1:textoExtracto "Cancel the electronic coupling (slaving) of axes." .

ns1:Instruccion_UNPARK a ns1:Parametro ;
    rdfs:label "#UNPARK" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#UNPARK" ;
    ns1:textoExtracto "Unpark an axis or spindle." .

ns1:Instruccion_UNSYNC a ns1:Parametro ;
    rdfs:label "#UNSYNC" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#UNSYNC" ;
    ns1:textoExtracto "Cancel the spindle synchronization." .

ns1:Instruccion_VIRTAX_ON a ns1:Parametro ;
    rdfs:label "#VIRTAX ON" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#VIRTAX ON" ;
    ns1:textoExtracto "Activate the virtual tool axis." .

ns1:Instruccion_WAIT a ns1:Parametro ;
    rdfs:label "#WAIT" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#WAIT" ;
    ns1:textoExtracto "Channels. It waits for a mark to be activated in the indicated channel." .

ns1:Instruccion_WAIT_FOR a ns1:Parametro ;
    rdfs:label "#WAIT FOR" ;
    ns1:documentadoEn ns1:Tabla_InstruccionesHighLevelLanguage ;
    ns1:identificador "#WAIT FOR" ;
    ns1:textoExtracto "Wait for an event before resuming execution." .

ns1:Tabla_InstruccionesHighLevelLanguage a ns1:Tabla ;
    rdfs:label "High Level Language Instructions Table" ;
    ns1:textoExtracto "#TANGFEED RMIN | Minimum radius for applying constant tangential feedrate. [...] #WARNINGSTOP | Display a warning on the screen and interrupt the program." .

