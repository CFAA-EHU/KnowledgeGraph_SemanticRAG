@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_4000_2 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización del anillo Sercos (Valor 2)"@es ;
    ns1:identificador "4000(2)" ;
    ns1:textoExtracto "VALOR 2 Sin uso actual. CAUSA Fallo en el proceso de inicialización del anillo Sercos debido a problemas de conexión en la fibra óptica, parametrización en CNC y regulador, problemas en las placas de Sercos o reguladores, etc. SOLUCIÓN Realizar las siguientes comprobaciones: • Analizar los códigos de error para intentar determinar la fuente del error. • Garantizar el buen conexionado e integridad de la fibra óptica. • Comprobar la parametrización en el CNC y reguladores. Selector de nodo del regulador (DriveID), parámetros LOOPTIME, SERPOWSE, SERBRATE, OPMODE, etc."@es .

ns1:Error_4000_4 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización del anillo Sercos (Valor 4)"@es ;
    ns1:identificador "4000(4)" ;
    ns1:textoExtracto "4000(4) 'Error en la inicialización del anillo Sercos' CAUSA Timeout en el reset de errores tras inicializar el anillo Sercos. SOLUCIÓN Póngase en contacto con el servicio de asistencia técnica."@es .

ns1:Error_4000_5 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización del anillo Sercos (Valor 5, Transición 3, Valor 35)"@es ;
    ns1:identificador "4000(5)" ;
    ns1:textoExtracto "4000(5) 'Error en la inicialización del anillo Sercos' VALOR 5. TRANSICIÓN 3. VALOR 35. CAUSA Error en el reset de errores tras inicializar el anillo Sercos. SOLUCIÓN Póngase en contacto con el servicio de asistencia técnica."@es .

ns1:Parametro_AXISMODE a ns1:Parametro ;
    rdfs:label "AXISMODE" ;
    ns1:monitoreaParametro ns1:Error_4003 ;
    ns1:textoExtracto "parámetro AXISMODE"@es .

ns1:Parametro_LOOPTIME a ns1:Parametro ;
    rdfs:label "LOOPTIME" ;
    ns1:monitoreaParametro ns1:Error_4001 ;
    ns1:textoExtracto "parámetro LOOPTIME"@es .

ns1:Parametro_OPMODE a ns1:Parametro ;
    rdfs:label "OPMODE" ;
    ns1:monitoreaParametro ns1:Error_4002 ;
    ns1:textoExtracto "parámetro OPMODE"@es .

ns1:Parametro_SERBRATE a ns1:Parametro ;
    rdfs:label "SERBRATE" ;
    ns1:textoExtracto "parámetro SERBRATE"@es .

ns1:Parametro_SERPOWSE a ns1:Parametro ;
    rdfs:label "SERPOWSE" ;
    ns1:textoExtracto "parámetro SERPOWSE"@es .

ns1:Placas_Sercos a ns1:ComponenteElectrico ;
    rdfs:label "Placas de Sercos"@es ;
    ns1:textoExtracto "problemas en las placas de Sercos"@es .

ns1:Regulador_DriveID a ns1:ComponenteElectrico ;
    rdfs:label "Selector de nodo del regulador (DriveID)"@es ;
    ns1:textoExtracto "Selector de nodo del regulador (DriveID)"@es .

ns1:Sistema_Sercos a ns1:Sistema ;
    rdfs:label "Anillo Sercos"@es ;
    ns1:textoExtracto "anillo Sercos"@es ;
    ns1:tieneComponente ns1:FibraOptica_Sercos .

ns1:Error_4001 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro LOOPTIME diferente en CNC y regulador"@es ;
    ns1:identificador "4001" ;
    ns1:textoExtracto "4001 'Parámetro LOOPTIME diferente en CNC y regulador' VALOR Valor del parámetro en el CNC. VALOR Valor del parámetro en el regulador. EJE Número lógico del eje. CAUSA Valor del parámetro LOOPTIME diferente en el CNC y en el regulador. SOLUCIÓN Poner en mismo valor en el CNC y el regulador."@es .

ns1:Error_4002 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro OPMODE diferente en CNC y regulador"@es ;
    ns1:identificador "4002" ;
    ns1:textoExtracto "4002 'Parámetro OPMODE diferente en CNC y regulador' VALOR Valor del parámetro en el CNC. VALOR Valor del parámetro en el regulador. EJE Número lógico del eje. CAUSA Valor del parámetro OPMODE diferente en el CNC y en el regulador. SOLUCIÓN Poner en mismo valor en el CNC y el regulador."@es .

ns1:Error_4003 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro AXISMODE diferente en CNC y regulador"@es ;
    ns1:identificador "4003" ;
    ns1:textoExtracto "4003 'Parámetro AXISMODE diferente en CNC y regulador' VALOR Valor del parámetro en el CNC. VALOR Valor del parámetro en el regulador. EJE Número lógico del eje."@es .

ns1:FibraOptica_Sercos a ns1:ComponenteElectrico ;
    rdfs:label "Fibra óptica del anillo Sercos"@es ;
    ns1:textoExtracto "problemas de conexión en la fibra óptica"@es .

