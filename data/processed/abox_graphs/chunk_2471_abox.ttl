@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_AXISMODE_CNC a ns1:Parametro ;
    rdfs:label "AXISMODE (CNC)"@es ;
    ns1:monitoreaParametro ns1:Fallo_4003 ;
    ns1:textoExtracto "Valor del parámetro en el CNC"@es .

ns1:Parametro_AXISMODE_Regulador a ns1:Parametro ;
    rdfs:label "AXISMODE (Regulador)"@es ;
    ns1:monitoreaParametro ns1:Fallo_4003 ;
    ns1:textoExtracto "Valor del parámetro en el regulador"@es .

ns1:Parametro_AXISTYPE_CNC a ns1:Parametro ;
    rdfs:label "AXISTYPE (CNC)"@es ;
    ns1:textoExtracto "Valor del parámetro AXISTYPE diferente en el CNC"@es .

ns1:Parametro_AXISTYPE_Regulador a ns1:Parametro ;
    rdfs:label "AXISTYPE (Regulador)"@es ;
    ns1:textoExtracto "Valor del parámetro AXISTYPE [...] en el regulador"@es .

ns1:Parametro_G00FEED_CNC a ns1:Parametro ;
    rdfs:label "G00FEED (CNC)"@es ;
    ns1:monitoreaParametro ns1:Fallo_4004 ;
    ns1:textoExtracto "Valor del parámetro en el CNC"@es .

ns1:Parametro_G00FEED_Regulador a ns1:Parametro ;
    rdfs:label "G00FEED (Regulador)"@es ;
    ns1:monitoreaParametro ns1:Fallo_4004 ;
    ns1:textoExtracto "Valor del parámetro en el regulador"@es .

ns1:Fallo_4003 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro AXISMODE diferente en CNC y regulador"@es ;
    ns1:identificador "4003" ;
    ns1:textoExtracto "4003 'Parámetro AXISMODE diferente en CNC y regulador' [...] SOLUCIÓN Poner en mismo valor en el CNC y el regulador."@es .

ns1:Fallo_4004 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro G00FEED mayor en CNC que en Regulador"@es ;
    ns1:identificador "4004" ;
    ns1:textoExtracto "4004 'Parámetro G00FEED mayor en CNC que en Regulador' [...] Valor del parámetro en el CNC."@es .

