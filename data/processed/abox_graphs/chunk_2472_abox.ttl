@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_4004 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro G00FEED mayor en CNC que en Regulador"@es ;
    ns1:identificador "4004" ;
    ns1:monitoreaParametro ns1:Parametro_G00FEED_CNC,
        ns1:Parametro_G00FEED_Regulador ;
    ns1:solucionaFallo ns1:Solucion_4004 ;
    ns1:textoExtracto "4004 'Parámetro G00FEED mayor en CNC que en Regulador' VALOR Valor del parámetro en el CNC. VALOR Valor del parámetro en el regulador. EJE Número lógico del eje. CAUSA Valor del parámetro G00FEED diferente en el CNC y en el regulador. SOLUCIÓN Poner en mismo valor en el CNC y el regulador."@es .

ns1:Error_4005 a ns1:DiagnosticoFallo ;
    rdfs:label "Vigilancia de error de seguimiento no activa en el regulador"@es ;
    ns1:identificador "4005" ;
    ns1:monitoreaParametro ns1:Parametro_PP159_Regulador ;
    ns1:solucionaFallo ns1:Solucion_4005 ;
    ns1:textoExtracto "4005 'Vigilancia de error de seguimiento no activa en el regulador' VALOR 0. VALOR Valor del parámetro PP159 en el regulador. EJE Número lógico del eje. CAUSA Vigilancia de error de seguimiento desactivada en el regulador. SOLUCIÓN Activar parámetro PP159 en el regulador."@es .

ns1:Error_4006 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro SP100 del regulador debe ser 0"@es ;
    ns1:identificador "4006" ;
    ns1:monitoreaParametro ns1:Parametro_SP100_Regulador ;
    ns1:solucionaFallo ns1:Solucion_4006 ;
    ns1:textoExtracto "4006 'Parámetro SP100 del regulador debe ser 0' VALOR 0. VALOR Valor del parámetro SP100 en el regulador. EJE Número lógico del eje. CAUSA El regulador tiene habilitada una consigna adicional. SOLUCIÓN Poner el parámetro SP100 del regulador a 0."@es .

ns1:Error_4007 a ns1:DiagnosticoFallo ;
    rdfs:label "Cabezal Sercos necesita una ganancia distinta de 0"@es ;
    ns1:identificador "4007" ;
    ns1:monitoreaParametro ns1:Parametro_KV_Regulador ;
    ns1:solucionaFallo ns1:Solucion_4007 ;
    ns1:textoExtracto "4007 'Cabezal Sercos necesita una ganancia distinta de 0' VALOR 0. VALOR Valor de la KV en el regulador. EJE Número lógico del eje. CAUSA La KV del cabezal es 0. SOLUCIÓN Definir la KV del regulador con un valor distinto de 0."@es .

ns1:Error_4008 a ns1:DiagnosticoFallo ;
    rdfs:label "Error+ en el anillo Sercos debido a un reset del regulador"@es ;
    ns1:identificador "4008" ;
    ns1:solucionaFallo ns1:Solucion_4008 ;
    ns1:textoExtracto "4008 'Error+ en el anillo Sercos debido a un reset del regulador' EJE Número lógico del eje. CAUSA Aviso de que el regulador se ha reseteado. SOLUCIÓN Descartar reset voluntarios del regulador desde botón de reset, WinDDS (grabación de versión, soft reset) o problemas hardware en el regulador. Si el error persiste, póngase en contacto con el servicio de asistencia técnica."@es .

ns1:Error_4009 a ns1:DiagnosticoFallo ;
    rdfs:label "Superado el número de variables permitidas en un telegrama Sercos"@es ;
    ns1:identificador "4009" ;
    ns1:textoExtracto "4009 'Superado el número de variables permitidas en un telegrama Sercos' EJE Número lógico del eje al que afecta el error."@es .

ns1:Parametro_G00FEED_CNC a ns1:Parametro ;
    rdfs:label "Parámetro G00FEED en CNC"@es ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "Valor del parámetro G00FEED en el CNC"@es .

ns1:Parametro_G00FEED_Regulador a ns1:Parametro ;
    rdfs:label "Parámetro G00FEED en regulador"@es ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "Valor del parámetro G00FEED en el regulador"@es .

ns1:Parametro_KV_Regulador a ns1:Parametro ;
    rdfs:label "Parámetro KV (ganancia) en regulador"@es ;
    ns1:identificador "KV" ;
    ns1:textoExtracto "Valor de la KV en el regulador"@es .

ns1:Parametro_PP159_Regulador a ns1:Parametro ;
    rdfs:label "Parámetro PP159 en regulador"@es ;
    ns1:identificador "PP159" ;
    ns1:textoExtracto "Valor del parámetro PP159 en el regulador"@es .

ns1:Parametro_SP100_Regulador a ns1:Parametro ;
    rdfs:label "Parámetro SP100 en regulador"@es ;
    ns1:identificador "SP100" ;
    ns1:textoExtracto "Valor del parámetro SP100 en el regulador"@es .

ns1:Solucion_4004 a ns1:TareaMantenimiento ;
    rdfs:label "Ajustar G00FEED en CNC y regulador"@es ;
    ns1:textoExtracto "Poner en mismo valor en el CNC y el regulador"@es .

ns1:Solucion_4005 a ns1:TareaMantenimiento ;
    rdfs:label "Activar PP159 en regulador"@es ;
    ns1:textoExtracto "Activar parámetro PP159 en el regulador"@es .

ns1:Solucion_4006 a ns1:TareaMantenimiento ;
    rdfs:label "Poner SP100 a 0 en regulador"@es ;
    ns1:textoExtracto "Poner el parámetro SP100 del regulador a 0"@es .

ns1:Solucion_4007 a ns1:TareaMantenimiento ;
    rdfs:label "Configurar KV en regulador"@es ;
    ns1:textoExtracto "Definir la KV del regulador con un valor distinto de 0"@es .

ns1:Solucion_4008 a ns1:TareaMantenimiento ;
    rdfs:label "Verificar reset del regulador"@es ;
    ns1:textoExtracto "Descartar reset voluntarios del regulador desde botón de reset, WinDDS (grabación de versión, soft reset) o problemas hardware en el regulador. Si el error persiste, póngase en contacto con el servicio de asistencia técnica."@es .

