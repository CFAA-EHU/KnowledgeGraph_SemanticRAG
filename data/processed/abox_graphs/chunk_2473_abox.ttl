@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Solucion_4009 a ns1:TareaMantenimiento ;
    rdfs:label "Reducción de variables síncronas en eje Sercos"@es ;
    ns1:solucionaFallo ns1:Error_4009 ;
    ns1:textoExtracto "Reducir el número de variables síncronas a tratar en ese eje. Definir algunas de dichas variables como de acceso asíncrono."@es .

ns1:Tabla_VariablesSercos a ns1:Tabla ;
    rdfs:label "Tabla de variables Sercos"@es ;
    ns1:documentadoEn ns1:Manual_Broaching ;
    ns1:identificador "Tabla_VariablesSercos" ;
    ns1:textoExtracto "En la tabla de variables Sercos hay definidas más de 6/7 variables de lectura escritura síncrona para un mismo eje."@es .

ns1:Error_4009 a ns1:AvisoSeguridad ;
    rdfs:label "Error 4009: Superado el número de variables permitidas en un telegrama Sercos"@es ;
    ns1:identificador "4009" ;
    ns1:monitoreaParametro ns1:Parametro_VariablesSercos_4009 ;
    ns1:textoExtracto "4009 'Superado el número de variables permitidas en un telegrama Sercos' [...] El número máximo de variables Sercos a procesar cíclicamente en un telegrama está limitado a 8. En la tabla de variables Sercos hay definidas más de 6/7 variables de lectura escritura síncrona para un mismo eje."@es .

ns1:Parametro_VariablesSercos_4009 a ns1:Parametro ;
    rdfs:label "Número de variables Sercos (límite: 8 por eje)"@es ;
    ns1:textoExtracto "El número máximo de variables Sercos a procesar cíclicamente en un telegrama está limitado a 8."@es ;
    ns1:valor 8 .

