@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_4010 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4010: 'No se puede escribir parámetro en el regulador'"@es ;
    ns1:identificador "4010" ;
    ns1:solucionaFallo ns1:ParametroDelReguladorGenerico ;
    ns1:textoExtracto "4010 'No se puede escribir parámetro en el regulador' [...] SOLUCIÓN Revisar el estado de la comunicación con el regulador, versión de software y opciones de parametrización permitidas."@es .

ns1:Error_4011 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4011: 'No se puede escribir parámetro en el regulador: No IDN'"@es ;
    ns1:identificador "4011" ;
    ns1:solucionaFallo ns1:ParametroIDNNoExistenteEnElRegulador ;
    ns1:textoExtracto "4011 'No se puede escribir parámetro en el regulador:No IDN' [...] SOLUCIÓN Actualizar versión de software del regulador."@es .

ns1:Error_4012 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4012: 'No se puede escribir parámetro en el regulador: Fuera de rango'"@es ;
    ns1:identificador "4012" ;
    ns1:solucionaFallo ns1:ParametroMaquinaFueraDeRango ;
    ns1:textoExtracto "4012 'No se puede escribir parámetro en el regulador:Fuera de rango' [...] SOLUCIÓN Corregir el valor del parámetro en el CNC."@es .

ns1:Error_4013 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4013: 'No se puede escribir parámetro en el regulador: Protegido'"@es ;
    ns1:identificador "4013" ;
    ns1:solucionaFallo ns1:ParametroProtegidoContraEscritura ;
    ns1:textoExtracto "4013 'No se puede escribir parámetro en el regulador:Protegido' [...] SOLUCIÓN Revisar los permisos y el nivel de acceso en el regulador."@es .

ns1:Error_4014 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4014: 'Error en la inicialización del SERCON'"@es ;
    ns1:identificador "4014" ;
    ns1:solucionaFallo ns1:ParametroDeConfiguracionSERCONEjesTiempos ;
    ns1:textoExtracto "4014 'Error en la inicialización del SERCON' [...] CAUSA Número de ejes Sercos o tiempos de Sercos erróneos."@es .

ns1:Regulador a ns1:ComponenteElectrico ;
    rdfs:label "regulador (dispositivo de control)"@es ;
    ns1:monitoreaParametro ns1:Error_4010_ex_solucionaFallo,
        ns1:Error_4011_ex_solucionaFallo,
        ns1:Error_4012_ex_solucionaFallo,
        ns1:Error_4013_ex_solucionaFallo ;
    ns1:textoExtracto "parámetros del regulador durante la inicialización del anillo Sercos"@es .

ns1:SistemaSercos a ns1:Sistema ;
    rdfs:label "Sistema de comunicación Sercos"@es ;
    ns1:textoExtracto "inicialización del anillo Sercos; arranque del CNC, validación de los parámetros máquina y reset."@es ;
    ns1:tieneComponente ns1:ChipSERCON .

ns1:ChipSERCON a ns1:ComponenteElectrico ;
    rdfs:label "chip SERCON"@es ;
    ns1:textoExtracto "chip de Sercos"@es .

ns1:ParametroDeConfiguracionSERCONEjesTiempos a ns1:Parametro ;
    rdfs:label "parámetro de configuración SERCON (ejes/tiempos)"@es ;
    ns1:textoExtracto "Número de ejes Sercos o tiempos de Sercos erróneos."@es .

ns1:ParametroDelReguladorGenerico a ns1:Parametro ;
    rdfs:label "parámetro del regulador (genérico)"@es ;
    ns1:textoExtracto "Fallo genérico en la escritura del parámetro."@es .

ns1:ParametroIDNNoExistenteEnElRegulador a ns1:Parametro ;
    rdfs:label "parámetro IDN no existente en el regulador"@es ;
    ns1:textoExtracto "No existe el parámetro en el regulador."@es .

ns1:ParametroMaquinaFueraDeRango a ns1:Parametro ;
    rdfs:label "parámetro máquina fuera de rango"@es ;
    ns1:textoExtracto "El valor del parámetro máquina está fuera del rango permitido."@es ;
    ns1:valor "fuera_de_rango" .

ns1:ParametroProtegidoContraEscritura a ns1:Parametro ;
    rdfs:label "parámetro protegido contra escritura"@es ;
    ns1:textoExtracto "Parámetro protegido contra escritura."@es .

