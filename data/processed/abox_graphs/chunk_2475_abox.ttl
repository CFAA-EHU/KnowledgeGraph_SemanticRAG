@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_4014 a ns1:AvisoSeguridad ;
    rdfs:label "Error 4014: Error en la inicialización del SERCON" ;
    ns1:activaAlarma ns1:SistemaSERCON ;
    ns1:identificador "4014" ;
    ns1:textoExtracto "4014 'Error en la inicialización del SERCON' DETECCIÓN Al inicializar el chip de Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA Número de ejes Sercos o tiempos de Sercos erróneos. Memoria insuficiente en el chip SERCON para la configuración de Sercos parametrizada." .

ns1:Error_4015 a ns1:AvisoSeguridad ;
    rdfs:label "Error 4015: TimeOut en la inicialización del anillo Sercos" ;
    ns1:activaAlarma ns1:SistemaSERCON ;
    ns1:identificador "4015" ;
    ns1:textoExtracto "4015 'TimeOut en la inicialización del anillo Sercos' DETECCIÓN Al inicializar el" .

ns1:Parametro_EjesSercos a ns1:Parametro ;
    rdfs:label "Número de ejes Sercos" ;
    ns1:monitoreaParametro ns1:SistemaSERCON ;
    ns1:textoExtracto "Número de ejes Sercos" .

ns1:Parametro_TiemposSercos a ns1:Parametro ;
    rdfs:label "Tiempos de Sercos" ;
    ns1:monitoreaParametro ns1:SistemaSERCON ;
    ns1:textoExtracto "tiempos de Sercos" .

ns1:SistemaSERCON a ns1:Sistema ;
    rdfs:label "Sistema SERCON (Sercos)" ;
    ns1:textoExtracto "chip de Sercos; [...] configuración de Sercos parametrizada; anillo Sercos" .

