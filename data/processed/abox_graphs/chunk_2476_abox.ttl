@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TareaMantenimiento_ActivarOpcionSoftware_4016 a ns1:TareaMantenimiento ;
    rdfs:label "Activar opción de regulación digital no Fagor (4016)"@es ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_4016 ;
    ns1:textoExtracto "Es necesario activar en el CNC la opción de regulación digital no Fagor para poder conectar regulación Sercos de terceros."@es .

ns1:TareaMantenimiento_RecalcularPP4 a ns1:TareaMantenimiento ;
    rdfs:label "Recalcular PP4 (HomingSwitchOffset)"@es ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_4017 ;
    ns1:textoExtracto "Es necesario recalcular el valor del parámetro PP4(HomingSwitchOffset) del regulador"@es .

ns1:TareaMantenimiento_RevisarConfigSercos_4015 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar configuración y parametrización de Sercos (4015)"@es ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_4015 ;
    ns1:textoExtracto "Revisar configuración y parametrización de Sercos"@es .

ns1:DiagnosticoFallo_4015 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 4015: TimeOut en inicialización de Sercos"@es ;
    ns1:solucionaFallo ns1:SistemaSercos_4015 ;
    ns1:textoExtracto "SOLUCIÓN Revisar configuración y parametrización de Sercos."@es .

ns1:DiagnosticoFallo_4016 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 4016: Regulador no Fagor"@es ;
    ns1:solucionaFallo ns1:SistemaSercos_4016 ;
    ns1:textoExtracto "CAUSA El sistema ha detectado un regulador no Fagor, sin disponer de la opción de software correspondiente. SOLUCIÓN Es necesario activar en el CNC la opción de regulación digital no Fagor para poder conectar regulación Sercos de terceros."@es .

ns1:DiagnosticoFallo_4017 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 4017: Recalcular PP4 (HomingSwitchOffset)"@es ;
    ns1:identificador "4017" ;
    ns1:solucionaFallo ns1:Parametro_PP4_HomingSwitchOffset ;
    ns1:textoExtracto "'Es necesario recalcular el valor del parámetro PP4(HomingSwitchOffset) del regulador' DETECCIÓN En el encendido del CNC."@es .

ns1:Parametro_PP4_HomingSwitchOffset a ns1:Parametro ;
    rdfs:label "PP4 (HomingSwitchOffset)"@es ;
    ns1:textoExtracto "valor del parámetro PP4(HomingSwitchOffset) del regulador"@es ;
    ns1:valor "HomingSwitchOffset"@es .

ns1:Parametro_TimeOutSercos a ns1:Parametro ;
    rdfs:label "TimeOut en inicialización del anillo Sercos"@es ;
    ns1:textoExtracto "TimeOut en la inicialización del anillo Sercos"@es .

ns1:ReguladorNoFagor_4016 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador no Fagor (detectado en 4016)"@es ;
    ns1:textoExtracto "El sistema ha detectado un regulador no Fagor, sin disponer de la opción de software correspondiente."@es .

ns1:SistemaSercos_4015 a ns1:Sistema ;
    rdfs:label "Sistema Sercos (TimeOut en inicialización)"@es ;
    ns1:identificador "4015" ;
    ns1:monitoreaParametro ns1:Parametro_TimeOutSercos ;
    ns1:textoExtracto "'TimeOut en la inicialización del anillo Sercos' DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset."@es .

ns1:SistemaSercos_4016 a ns1:Sistema ;
    rdfs:label "Sistema Sercos (Regulador no Fagor)"@es ;
    ns1:identificador "4016" ;
    ns1:textoExtracto "'El Regulador no es Fagor. Opción de software no permitida' DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset."@es ;
    ns1:tieneComponente ns1:ReguladorNoFagor_4016 .

