@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error4019 a ns1:AvisoSeguridad ;
    rdfs:label "Error en el anillo Sercos debido a un Reset de contadora"@es ;
    ns1:activaAlarma ns1:SistemaSercos ;
    ns1:identificador "4019" ;
    ns1:textoExtracto "4019 Error en el anillo Sercos debido a un Reset de contadora."@es .

ns1:TareaCorreccionParametrizacion a ns1:TareaMantenimiento ;
    rdfs:label "Corrección de parametrización del FEEDBACKTYPE"@es ;
    ns1:solucionaFallo ns1:Error4018 ;
    ns1:textoExtracto "SOLUCIÓN Corregir la parametrización."@es .

ns1:EntradaCaptacion_RCS_S a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de captación del módulo RCS-S"@es ;
    ns1:monitoreaParametro ns1:Parametro_FEEDBACKTYPE ;
    ns1:textoExtracto "entrada de captación del módulo RCS-S"@es .

ns1:Error4018 a ns1:AvisoSeguridad ;
    rdfs:label "Captación remota Sercos con FEEDBACKTYPE incoherente"@es ;
    ns1:activaAlarma ns1:SistemaSercos ;
    ns1:identificador "4018" ;
    ns1:monitoreaParametro ns1:Parametro_FEEDBACKTYPE ;
    ns1:textoExtracto "4018 Captación remota Sercos con FEEDBACKTYPE incoherente en diferentes gamas. DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA En alguna entrada de captación del módulo RCS-S, el tipo de captación (parámetro FEEDBACKTYPE) no es igual en todos lo sets. SOLUCIÓN Corregir la parametrización."@es .

ns1:Modulo_RCS_S a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S"@es ;
    ns1:textoExtracto "módulo RCS-S"@es ;
    ns1:tieneComponente ns1:EntradaCaptacion_RCS_S .

ns1:Parametro_FEEDBACKTYPE a ns1:Parametro ;
    rdfs:label "FEEDBACKTYPE" ;
    ns1:textoExtracto "parámetro FEEDBACKTYPE"@es ;
    ns1:valor "incoherente en diferentes gamas"@es .

ns1:SistemaSercos a ns1:Sistema ;
    rdfs:label "Sistema de bus Sercos"@es ;
    ns1:textoExtracto "bus Sercos"@es ;
    ns1:tieneComponente ns1:Modulo_RCS_S .

