@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Pagina_51 a ns1:Pagina ;
    rdfs:label "Página 51 - High Level Language Operators" ;
    ns1:documentadoEn ns1:Manual ;
    ns1:textoExtracto "Arithmetic operators, Relational operators, Logic operators, Boolean constants, Trigonometric functions, Mathematical functions" .

ns1:Tabla_ConstantesBooleanas a ns1:Tabla ;
    rdfs:label "Tabla de constantes booleanas" ;
    ns1:textoExtracto "TRUE True | FALSE Not true" .

ns1:Tabla_FuncionesMatematicas a ns1:Tabla ;
    rdfs:label "Tabla de funciones matemáticas" ;
    ns1:textoExtracto "ABS[...] Absolute value | SQR[...] Square function | SQRT[...] Square root | LOG[...] Decimal logarithm | LN[...] Neperian logarithm | EXP[...] \"e\" function | DEXP[...] Decimal exponent" .

ns1:Tabla_FuncionesTrigonometricas a ns1:Tabla ;
    rdfs:label "Tabla de funciones trigonométricas" ;
    ns1:textoExtracto "SIN[...] Sine | COS[...] Cosine | TAN[...] Tangent | ASIN[...] Arc-sine | ACOS[...] Arc-cosine | ATAN[...] Arc-tangent (within ±90º) | ARG[...] Arc-tangent (within 0-360º)" .

ns1:Tabla_OperadoresAritmeticos a ns1:Tabla ;
    rdfs:label "Tabla de operadores aritméticos" ;
    ns1:textoExtracto "+ Add | - Subtract / change sign | * Multiply | / Divide | += Compounded addition | -= Compounded subtraction | *= Compounded multiplication | /= Compounded division | MOD Remainder of the division | ** Exponent" .

ns1:Tabla_OperadoresLogicos a ns1:Tabla ;
    rdfs:label "Tabla de operadores lógicos" ;
    ns1:textoExtracto "* Logic AND | + Logic OR" .

ns1:Tabla_OperadoresLogicosBinarios a ns1:Tabla ;
    rdfs:label "Tabla de operadores lógicos binarios" ;
    ns1:textoExtracto "& Binary AND | | Binary OR | ^ Exclusive OR (XOR) | INV[...] Inverse" .

ns1:Tabla_OperadoresRelacionales a ns1:Tabla ;
    rdfs:label "Tabla de operadores relacionales" ;
    ns1:textoExtracto "== Equal to | ! = Different | > Greater than | < Smaller than | >= Greater than or equal to | <= Smaller than or equal to" .

