@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_SERBRATE a ns1:Parametro ;
    rdfs:label "Frecuencia SERBRATE" ;
    ns1:monitoreaParametro ns1:Modulo_RCS_S ;
    ns1:textoExtracto "subir la frecuencia SERBRATE" .

ns1:Solucion4022 a ns1:AccionProhibida ;
    rdfs:label "Contactar con Fagor para error 4022" ;
    ns1:solucionaFallo ns1:Error4022 ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor." .

ns1:Solucion4023 a ns1:TareaMantenimiento ;
    rdfs:label "Ajuste de parámetros para traza Sercos (Error 4023)" ;
    ns1:solucionaFallo ns1:Error4023 ;
    ns1:textoExtracto "SOLUCIÓN Reducir el número de variables en el telegrama. Si el ancho de banda está limitado, subir la frecuencia SERBRATE o eliminar reguladores del anillo." .

ns1:Telegrama_AT_MDT a ns1:ComponenteElectrico ;
    rdfs:label "Telegrama AT-MDT" ;
    ns1:controla ns1:Modulo_RCS_S ;
    ns1:textoExtracto "Error durante la configuración de los telegramas AT-MDT para capturar la traza programada." .

ns1:Error4022 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4022: Reset de contadora por Watchdog en anillo Sercos" ;
    ns1:identificador "4022" ;
    ns1:textoExtracto "Error en el anillo Sercos debido a un Reset de contadora por Watchdog. DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA Se ha producido un reset por watchdog en el módulo RCS-S, por una causa interna del software del nodo." .

ns1:Error4023 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4023: Configuración fallida de traza programada en Sercos" ;
    ns1:identificador "4023" ;
    ns1:textoExtracto "No puede configurarse la traza programada en Sercos. DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA Error durante la configuración de los telegramas AT-MDT para capturar la traza programada. La traza programada no puede hacerse efectiva, bien porque se trata de un regulador no-Fagor o bien porque no hay hueco disponible para ella." .

ns1:Modulo_RCS_S a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S" ;
    ns1:textoExtracto "Se ha producido un reset por watchdog en el módulo RCS-S, por una causa interna del software del nodo." .

