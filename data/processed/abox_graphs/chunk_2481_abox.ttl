@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_4024 a ns1:DiagnosticoFallo ;
    rdfs:label "Versión no válida del Regulador para eje TANDEM en posición o para REFMODE CNC"@es ;
    ns1:controla ns1:Modo_RefMode_CNC ;
    ns1:detalladoEnEsquema ns1:Bus_Sercos ;
    ns1:identificador "4024" ;
    ns1:monitoreaParametro ns1:Regulador_TANDEM ;
    ns1:solucionaFallo ns1:Parametro_SERBRATE ;
    ns1:textoExtracto "4024 Versión no válida del Regulador para eje TANDEM en posición o para REFMODE CNC. DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA La versión de un regulador no soporta el tandem con control de par o el modo de referencia CNC."@es .

ns1:Bus_Sercos a ns1:Sistema ;
    rdfs:label "Bus Sercos"@es ;
    ns1:textoExtracto "inicializar el bus Sercos"@es .

ns1:Modo_RefMode_CNC a ns1:ModoOperacion ;
    rdfs:label "Modo REFMODE CNC"@es ;
    ns1:identificador "REFMODE" ;
    ns1:textoExtracto "modo de referencia CNC"@es .

ns1:Parametro_SERBRATE a ns1:Parametro ;
    rdfs:label "Frecuencia SERBRATE"@es ;
    ns1:identificador "SERBRATE" ;
    ns1:textoExtracto "subir la frecuencia SERBRATE"@es .

ns1:Regulador_TANDEM a ns1:ComponenteElectrico ;
    rdfs:label "Regulador para eje TANDEM"@es ;
    ns1:textoExtracto "versión de un regulador no soporta el tandem con control de par o el modo de referencia CNC"@es .

