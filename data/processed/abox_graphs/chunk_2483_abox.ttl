@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_4026 a ns1:DiagnosticoFallo ;
    rdfs:label "Incoherencia en datos de encoder FeeDat/EnDat"@es ;
    ns1:identificador "4026" ;
    ns1:solucionaFallo ns1:Encoder_FeeDat_EnDat_4026 ;
    ns1:textoExtracto "Incoherencia en datos de encoder FeeDat/EnDat. Es necesario validar la nueva configuración. DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA Los datos leídos de un encoder FeeDat/EnDat son diferentes a los guardados en el CNC. El encoder es diferente del que se validó durante la puesta a punto. SOLUCIÓN Volver a conectar el encoder que se validó en la puesta a punto o validar el nuevo encoder."@es .

ns1:Fallo_4027 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación FeeDat/EnDat parametrizada en contadora Sercos no compatible"@es ;
    ns1:identificador "4027" ;
    ns1:solucionaFallo ns1:Modulo_RCS_S_4027 ;
    ns1:textoExtracto "Captación FeeDat/EnDat parametrizada en contadora Sercos que no soporta el protocolo. DETECCIÓN Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset. CAUSA Se ha parametrizado una captación FeeDat/EnDat en un módulo RCS-S que no lo permite. SOLUCIÓN Es necesario actualizar el módulo RCS-S, o cambiarlo por otro nodo que soporte los protocolos digitales FeeDat/EnDat."@es .

ns1:Modulo_RCS_S_4026 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S (nodo Sercos)"@es ;
    ns1:textoExtracto "módulo RCS-S"@es .

ns1:Protocolo_FeeDat_EnDat a ns1:Parametro ;
    rdfs:label "Protocolo FeeDat/EnDat"@es ;
    ns1:monitoreaParametro ns1:Contadora_Sercos_4027 ;
    ns1:textoExtracto "protocolos digitales FeeDat/EnDat"@es .

ns1:Encoder_FeeDat_EnDat_4026 a ns1:Sensor ;
    rdfs:label "Encoder FeeDat/EnDat"@es ;
    ns1:monitoreaParametro ns1:Parametro_Encoder_4026 ;
    ns1:textoExtracto "encoder FeeDat/EnDat"@es .

ns1:Modulo_RCS_S_4027 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S (sin soporte FeeDat/EnDat)"@es ;
    ns1:textoExtracto "módulo RCS-S que no [soporta FeeDat/EnDat]"@es ;
    ns1:tieneComponente ns1:Contadora_Sercos_4027 .

ns1:Parametro_Encoder_4026 a ns1:Parametro ;
    rdfs:label "Datos de configuración del encoder"@es ;
    ns1:textoExtracto "datos leídos de un encoder FeeDat/EnDat son diferentes a los guardados en el CNC"@es .

ns1:Contadora_Sercos_4027 a ns1:ComponenteElectrico ;
    rdfs:label "Contadora Sercos (en módulo RCS-S)"@es ;
    ns1:textoExtracto "contadora Sercos que no soporta el protocolo [FeeDat/EnDat]"@es .

