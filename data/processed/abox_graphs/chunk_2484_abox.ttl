@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Diagnostico_FalloBusSercos a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en inicialización del bus Sercos" ;
    ns1:requiereMantenimiento ns1:Tarea_RevisarTablaDRVVAR ;
    ns1:solucionaFallo ns1:Bus_Sercos ;
    ns1:textoExtracto "La inicialización del bus Sercos ha fallado porque una variable DRVVAR tiene IDN incorrecto." .

ns1:Tarea_ActualizarModuloRCS_S a ns1:TareaMantenimiento ;
    rdfs:label "Actualizar módulo RCS-S" ;
    ns1:solucionaFallo ns1:Modulo_RCS_S ;
    ns1:textoExtracto "Es necesario actualizar el módulo RCS-S, o cambiarlo por otro nodo que soporte los protocolos digitales FeeDat/EnDat." .

ns1:Modulo_RCS_S a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S" ;
    ns1:cumpleNormativa ns1:Protocolo_EnDat,
        ns1:Protocolo_FeeDat ;
    ns1:textoExtracto "Es necesario actualizar el módulo RCS-S, o cambiarlo por otro nodo que soporte los protocolos digitales FeeDat/EnDat." .

ns1:Nodo_Sercos a ns1:ComponenteElectrico ;
    rdfs:label "Nodo Sercos" ;
    ns1:monitoreaParametro ns1:Variable_DRV ;
    ns1:textoExtracto "variable DRV cuyo IDN no existe en el nodo Sercos" .

ns1:Protocolo_EnDat a ns1:Parametro ;
    rdfs:label "Protocolo EnDat" ;
    ns1:textoExtracto "módulo que soporte los protocolos digitales FeeDat/EnDat" .

ns1:Protocolo_FeeDat a ns1:Parametro ;
    rdfs:label "Protocolo FeeDat" ;
    ns1:textoExtracto "módulo que soporte los protocolos digitales FeeDat/EnDat" .

ns1:Tabla_DRVVAR a ns1:Tabla ;
    rdfs:label "Tabla DRVVAR" ;
    ns1:documentadoEn ns1:Manual_4000_4999 ;
    ns1:textoExtracto "Revisar la tabla DRVVAR y corregir la parametrización." .

ns1:Tarea_RevisarTablaDRVVAR a ns1:TareaMantenimiento ;
    rdfs:label "Revisar y corregir tabla DRVVAR" ;
    ns1:documentadoEn ns1:Tabla_DRVVAR ;
    ns1:textoExtracto "Revisar la tabla DRVVAR y corregir la parametrización." .

ns1:Variable_DRV a ns1:Parametro ;
    rdfs:label "Variable DRV" ;
    ns1:identificador "DRV" ;
    ns1:monitoreaParametro ns1:Bus_Sercos ;
    ns1:textoExtracto "variable DRV cuyo IDN no existe en el nodo Sercos" .

ns1:Variable_DRVVAR a ns1:Parametro ;
    rdfs:label "Variable DRVVAR" ;
    ns1:identificador "DRVVAR" ;
    ns1:textoExtracto "una variable DRVVAR tiene IDN incorrecto" ;
    ns1:valor "IDN incorrecto" .

ns1:Bus_Sercos a ns1:Sistema ;
    rdfs:label "Bus Sercos" ;
    ns1:controla ns1:Variable_DRVVAR ;
    ns1:textoExtracto "Al inicializar el bus Sercos; arranque del CNC, validación de los parámetros máquina y reset." ;
    ns1:tieneComponente ns1:Nodo_Sercos .

