@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_SincronismoSercos a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de sincronismo en Sercos" ;
    ns1:detalladoEnEsquema ns1:PaginaDiagnosis_Sercos ;
    ns1:textoExtracto "El diagrama de tiempos de Sercos no es bastante óptimo para garantizar el sincronismo del sistema"@es .

ns1:SistemaSercos a ns1:Sistema ;
    rdfs:label "Sistema Sercos" ;
    ns1:monitoreaParametro ns1:ParametroTiempo_Sercos ;
    ns1:textoExtracto "bus Sercos"@es ;
    ns1:tieneFrecuencia ns1:FrecuenciaReajuste_Sercos .

ns1:TareaReajusteTiempos_Sercos a ns1:TareaMantenimiento ;
    rdfs:label "Reajuste de tiempos Sercos" ;
    ns1:ejecutadoPor ns1:ModoDiagnosis_Sercos ;
    ns1:solucionaFallo ns1:ParametroTiempo_Sercos ;
    ns1:textoExtracto "realizar el reajuste de tiempos y aceptar"@es .

ns1:FrecuenciaReajuste_Sercos a ns1:Frecuencia ;
    rdfs:label "Frecuencia de reajuste de tiempos Sercos" ;
    ns1:textoExtracto "reajustar el time-scheduling de Sercos"@es .

ns1:ModoDiagnosis_Sercos a ns1:ModoOperacion ;
    rdfs:label "Modo Diagnosis de Sercos" ;
    ns1:identificador "Diagnosis" ;
    ns1:textoExtracto "modo Diagnosis"@es .

ns1:PaginaDiagnosis_Sercos a ns1:Pagina ;
    rdfs:label "Página de diagnosis Sercos" ;
    ns1:documentadoEn ns1:ManualMantenimiento ;
    ns1:textoExtracto "Desde la página de diagnosis Sercos"@es .

ns1:ParametroTiempo_Sercos a ns1:Parametro ;
    rdfs:label "Diagrama de tiempos de Sercos" ;
    ns1:textoExtracto "El diagrama de tiempos de Sercos no es bastante óptimo para garantizar el sincronismo del sistema"@es ;
    ns1:valor "no óptimo" .

