@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_4200 a ns1:AvisoSeguridad ;
    rdfs:label "Error en el canal cíclico de Sercos"@es ;
    ns1:identificador "4200" ;
    ns1:textoExtracto "'Error en el canal cíclico de Sercos' EJE Número lógico del eje. CAUSA Error en los procesos de lectura o escritura del canal cíclico"@es .

ns1:Parametro_IDN296 a ns1:Parametro ;
    rdfs:label "IDN296 (FFGAIN)"@es ;
    ns1:documentadoEn ns1:Tabla_DRVVAR ;
    ns1:identificador "IDN296" ;
    ns1:textoExtracto "se ha parametrizado el IDN296 (FFGAIN) como de escritura síncrona"@es ;
    ns1:valor "FFGAIN" .

ns1:Variable_FFGAIN a ns1:Parametro ;
    rdfs:label "Variable FFGAIN (síncrona)"@es ;
    ns1:documentadoEn ns1:Tabla_DRVVAR ;
    ns1:monitoreaParametro ns1:Regulador_AXD ;
    ns1:textoExtracto "Eliminar la variable síncrona de la tabla DRVVAR"@es .

ns1:ActualizacionDeSoftwareDelReguladorAXD a ns1:TareaMantenimiento ;
    rdfs:label "Actualización de software del regulador AXD"@es ;
    ns1:textoExtracto "utilizar un regulador AXD con una versión de software v9.10 o superior"@es ;
    ns1:valor "v9.10" .

ns1:Regulador_AXD a ns1:ComponenteElectrico ;
    rdfs:label "Regulador AXD"@es ;
    ns1:requiereMantenimiento ns1:ActualizacionDeSoftwareDelReguladorAXD ;
    ns1:textoExtracto "el regulador no es AXD o la versión de software es incompatible"@es .

ns1:Tabla_DRVVAR a ns1:Tabla ;
    rdfs:label "Tabla DRVVAR"@es ;
    ns1:textoExtracto "En la tabla DRVVAR, se ha parametrizado el IDN296 (FFGAIN) como de escritura síncrona"@es .

