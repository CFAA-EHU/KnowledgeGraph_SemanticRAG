@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_4000 a ns1:AvisoSeguridad ;
    rdfs:label "Error 4000 (referenciado en Error 4201)"@es ;
    ns1:identificador "4000" ;
    ns1:textoExtracto "Ver códigos de error descritos en el error 4000."@es .

ns1:Error_4200 a ns1:AvisoSeguridad ;
    rdfs:label "Error 4200: Error en el canal cíclico de Sercos"@es ;
    ns1:identificador "4200" ;
    ns1:mitigaRiesgo ns1:ContactoServicioTecnico_4200 ;
    ns1:textoExtracto "4200 'Error en el canal cíclico de Sercos' [...] SOLUCIÓN Póngase en contacto con el servicio de asistencia técnica."@es .

ns1:Error_4201 a ns1:AvisoSeguridad ;
    rdfs:label "Error 4201: Error en el canal de servicio de Sercos"@es ;
    ns1:documentadoEn ns1:Regulador_AXD_v9.10 ;
    ns1:identificador "4201" ;
    ns1:mitigaRiesgo ns1:ContactoServicioTecnico_4201 ;
    ns1:solucionaFallo ns1:AnalisisCodigosError_4201 ;
    ns1:textoExtracto "4201 'Error en el canal de servicio de Sercos' [...] SOLUCIÓN Analizar los códigos de error para intentar determinar la fuente del error. Póngase en contacto con el servicio de asistencia técnica."@es .

ns1:Error_4202 a ns1:AvisoSeguridad ;
    rdfs:label "Error 4202: Falta Drive Enable (DRENA)"@es ;
    ns1:documentadoEn ns1:Regulador_AXD_v9.10 ;
    ns1:identificador "4202" ;
    ns1:solucionaFallo ns1:AnalisisManiobraPLC_DRENA ;
    ns1:textoExtracto "4202 'Falta Drive Enable (DRENA)' [...] SOLUCIÓN Analizar la maniobra de PLC para determinar que provoca la caída de la señal DRENA."@es .

ns1:Error_4203 a ns1:AvisoSeguridad ;
    rdfs:label "Error 4203: Falta Speed Enable (SPENA)"@es ;
    ns1:documentadoEn ns1:Regulador_AXD_v9.10 ;
    ns1:identificador "4203" ;
    ns1:solucionaFallo ns1:AnalisisManiobraPLC_SPENA ;
    ns1:textoExtracto "4203 'Falta Speed Enable (SPENA)' [...] SOLUCIÓN Analizar la maniobra de PLC para determinar que provoca la caída de la señal SPENA."@es .

ns1:Error_4204 a ns1:AvisoSeguridad ;
    rdfs:label "Error 4204: Error al resetear el driver de SERCOS"@es ;
    ns1:documentadoEn ns1:Regulador_AXD_v9.10 ;
    ns1:identificador "4204" ;
    ns1:textoExtracto "4204 'Error al resetear el driver de SERCOS' [...] VALOR 1 Errores en el driver de Sercos."@es .

ns1:AnalisisCodigosError_4201 a ns1:DiagnosticoFallo ;
    rdfs:label "Analizar códigos de error (Error 4201)"@es ;
    ns1:textoExtracto "SOLUCIÓN Analizar los códigos de error para intentar determinar la fuente del error."@es .

ns1:AnalisisManiobraPLC_DRENA a ns1:TareaMantenimiento ;
    rdfs:label "Analizar maniobra de PLC para señal DRENA"@es ;
    ns1:textoExtracto "SOLUCIÓN Analizar la maniobra de PLC para determinar que provoca la caída de la señal DRENA."@es .

ns1:AnalisisManiobraPLC_SPENA a ns1:TareaMantenimiento ;
    rdfs:label "Analizar maniobra de PLC para señal SPENA"@es ;
    ns1:textoExtracto "SOLUCIÓN Analizar la maniobra de PLC para determinar que provoca la caída de la señal SPENA."@es .

ns1:ContactoServicioTecnico_4200 a ns1:AccionProhibida ;
    rdfs:label "Contactar con servicio técnico (Error 4200)"@es ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con el servicio de asistencia técnica."@es .

ns1:ContactoServicioTecnico_4201 a ns1:AccionProhibida ;
    rdfs:label "Contactar con servicio técnico (Error 4201)"@es ;
    ns1:textoExtracto "SOLUCIÓN [...] Póngase en contacto con el servicio de asistencia técnica."@es .

ns1:DriverSERCOS a ns1:ComponenteElectrico ;
    rdfs:label "Driver de SERCOS"@es ;
    ns1:textoExtracto "Errores en el driver de Sercos."@es .

ns1:Senal_DRENA a ns1:ComponenteElectrico ;
    rdfs:label "Señal Drive Enable (DRENA)"@es ;
    ns1:textoExtracto "Falta Drive Enable (DRENA)"@es .

ns1:Senal_SPENA a ns1:ComponenteElectrico ;
    rdfs:label "Señal Speed Enable (SPENA)"@es ;
    ns1:textoExtracto "Falta Speed Enable (SPENA)"@es .

ns1:Regulador_AXD_v9.10 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador AXD (software v9.10 o superior)"@es ;
    ns1:controla ns1:Senal_DRENA,
        ns1:Senal_SPENA ;
    ns1:identificador "AXD v9.10+" ;
    ns1:textoExtracto "regulador AXD con una versión de software v9.10 o superior."@es ;
    ns1:tieneComponente ns1:DriverSERCOS .

