@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_CNC_51 a ns1:InterfazUsuario ;
    rdfs:label "Interfaz CNC (pantalla principal)"@es ;
    ns1:ilustradoEn ns1:Esquema_MockupPantalla_CNC_51 ;
    ns1:textoExtracto "Vista general de la interfaz del CNC con un mockup de pantalla etiquetado por letras A–H. Se distinguen: barra de estado superior (icono de fabricante, estado del programa, número de bloque, canales y modo activo), área central para el modo de trabajo, y menús de softkeys vertical y horizontal."@es .

ns1:ModoOperacion_AUTO a ns1:ModoOperacion ;
    rdfs:label "Modo AUTO"@es ;
    ns1:habilitadoPor ns1:Sistema_TecladoCNC_5 ;
    ns1:textoExtracto "Work modes (AUTO, MANUAL, EDIT, MDI, TABLES, TOOLS, UTILITIES, CUSTOM)"@es .

ns1:ModoOperacion_EDIT a ns1:ModoOperacion ;
    rdfs:label "Modo EDIT"@es ;
    ns1:habilitadoPor ns1:Sistema_TecladoCNC_5 ;
    ns1:textoExtracto "Work modes (AUTO, MANUAL, EDIT, MDI, TABLES, TOOLS, UTILITIES, CUSTOM)"@es .

ns1:ModoOperacion_MANUAL a ns1:ModoOperacion ;
    rdfs:label "Modo MANUAL"@es ;
    ns1:habilitadoPor ns1:Sistema_TecladoCNC_5 ;
    ns1:textoExtracto "Work modes (AUTO, MANUAL, EDIT, MDI, TABLES, TOOLS, UTILITIES, CUSTOM)"@es .

ns1:ModoOperacion_MDI a ns1:ModoOperacion ;
    rdfs:label "Modo MDI"@es ;
    ns1:habilitadoPor ns1:Sistema_TecladoCNC_5 ;
    ns1:textoExtracto "Work modes (AUTO, MANUAL, EDIT, MDI, TABLES, TOOLS, UTILITIES, CUSTOM)"@es .

ns1:Esquema_MockupPantalla_CNC_51 a ns1:Esquema ;
    rdfs:label "Esquema de mockup de pantalla CNC (pág. 51)"@es ;
    ns1:textoExtracto "Las marcas circulares sobre la maqueta señalan cada zona funcional y su leyenda explica la función (cambio de página, mensajes CNC/PLC, reloj del sistema), guiando la jerarquía visual de navegación."@es .

ns1:Esquema_TecladoCNC_5 a ns1:Esquema ;
    rdfs:label "Esquema de teclado CNC (pág. 5)"@es ;
    ns1:textoExtracto "Cada icono aparece en un recuadro con su rótulo y una breve leyenda funcional, estableciendo una codificación visual consistente para localizar acciones en la HMI."@es .

ns1:Sistema_TecladoCNC_5 a ns1:Sistema ;
    rdfs:label "Teclado CNC (descripción de teclas)"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_TecladoCNC_5 ;
    ns1:textoExtracto "Lámina de iconografía del teclado con pictogramas de teclas y grupos: Function keys (F1–F12/Softkeys), Browsing keys (MAIN MENU, NEXT, FOCUS, BACK), Help, Work modes (AUTO, MANUAL, EDIT, MDI, TABLES, TOOLS, UTILITIES, CUSTOM), y Editing keys (DEL, INS, ESC, ENTER, RECALL, CALC)."@es .

