@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_4000 a ns1:AvisoSeguridad ;
    rdfs:label "Códigos de error del driver SERCOS" ;
    ns1:identificador "4000" ;
    ns1:textoExtracto "Ver códigos de error descritos en el error 4000." .

ns1:Parametro_EjeLogico a ns1:Parametro ;
    rdfs:label "Número lógico del eje" ;
    ns1:monitoreaParametro ns1:Regulador_ID99 ;
    ns1:textoExtracto "EJE Número lógico del eje." ;
    ns1:valor "1",
        "2" .

ns1:Diagnostico_4204 a ns1:DiagnosticoFallo ;
    rdfs:label "Análisis de caída de señal SPENA y errores en driver SERCOS" ;
    ns1:mitigaRiesgo ns1:Error_4204 ;
    ns1:textoExtracto "SOLUCIÓN Analizar la maniobra de PLC para determinar que provoca la caída de la señal SPENA. [...] SOLUCIÓN Analizar los códigos de error para intentar determinar la fuente." .

ns1:Regulador_ID99 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador (ID 99)" ;
    ns1:activaAlarma ns1:Error_4204 ;
    ns1:identificador "99" ;
    ns1:textoExtracto "Error al ejecutar el comando reset de errores de un regulador (ID 99)." .

ns1:Error_4204 a ns1:AvisoSeguridad ;
    rdfs:label "Error al resetear el driver de SERCOS" ;
    ns1:identificador "4204" ;
    ns1:solucionaFallo ns1:Diagnostico_4204 ;
    ns1:textoExtracto "4204 'Error al resetear el driver de SERCOS' [...] Error al ejecutar el comando reset de errores de un regulador (ID 99)." .

