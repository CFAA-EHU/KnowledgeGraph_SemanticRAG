@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionContactoAsistenciaTecnica a ns1:AccionProhibida ;
    rdfs:label "Contactar con servicio de asistencia técnica para errores del regulador"@es ;
    ns1:mitigaRiesgo ns1:ErrorAnilloSERCOS_4205 ;
    ns1:textoExtracto "Póngase en contacto con el servicio de asistencia técnica."@es .

ns1:TareaAnalisisCodigosError a ns1:TareaMantenimiento ;
    rdfs:label "Análisis de códigos de error del regulador"@es ;
    ns1:requiereMantenimiento ns1:DiagnosticoErrorRegulador_ID99 ;
    ns1:textoExtracto "Analizar los códigos de error para intentar determinar la fuente del error."@es .

ns1:DiagnosticoErrorRegulador_ID99 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico de error en regulador durante reset CNC"@es ;
    ns1:identificador "ID 99" ;
    ns1:solucionaFallo ns1:ErrorAnilloSERCOS_4205 ;
    ns1:textoExtracto "El lazo ejecuta este comando durante el tratamiento de un reset del CNC si el regulador está reportando errores. SOLUCIÓN Analizar los códigos de error para intentar determinar la fuente del error."@es .

ns1:ErrorAnilloSERCOS_4205 a ns1:AvisoSeguridad ;
    rdfs:label "Error en el anillo SERCOS"@es ;
    ns1:identificador "4205" ;
    ns1:textoExtracto "4205 'Error en el anillo SERCOS' VALOR Códigos de error que identifican la fuente o fuentes del problema."@es ;
    ns1:valor "Códigos de error que identifican la fuente o fuentes del problema en el anillo SERCOS"@es .

