@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Diagnostico_4206 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en regulador SERCOS (Código 4206)"@es ;
    ns1:identificador "4206" ;
    ns1:textoExtracto """
'Error en regulador SERCOS'
EJE Número lógico del eje.
CAUSA El regulador reporta error.
SOLUCIÓN Analizar códigos de error. Consultar el manual del regulador.
"""@es .

ns1:Diagnostico_4207 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta Drive Status Ready (Código 4207)"@es ;
    ns1:identificador "4207" ;
    ns1:textoExtracto """
'Falta Drive Status Ready (DRSTAF/DRSTAS)'
DETECCIÓN Durante la ejecución.
CAUSA Vigilancia DRSTAF, DRSTAS o del tandem, cuando el eje está en movimiento.
SOLUCIÓN Comprobar las señales de habilitación y el estado del regulador.
"""@es .

ns1:Diagnostico_4210 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en anillo Sercos (MST perdido, Código 4210)"@es ;
    ns1:identificador "4210" ;
    ns1:textoExtracto """
'Error en el anillo Sercos (MST perdido)'
VALOR Códigos de error que identifican la fuente o fuentes del problema.
"""@es .

ns1:Error_0x00000002 a ns1:AvisoSeguridad ;
    rdfs:label "Rotura de fibra óptica"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorSercos ;
    ns1:identificador "0x00000002" ;
    ns1:textoExtracto "Rotura de fibra óptica."@es .

ns1:Error_0x00000100 a ns1:AvisoSeguridad ;
    rdfs:label "Pérdida de ATs"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorSercos ;
    ns1:identificador "0x00000100" ;
    ns1:textoExtracto "Pérdida de ATs."@es .

ns1:Error_0x00000200 a ns1:AvisoSeguridad ;
    rdfs:label "Pérdida de MSTs"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorSercos ;
    ns1:identificador "0x00000200" ;
    ns1:textoExtracto "Pérdida de MSTs."@es .

ns1:Error_0x00008000 a ns1:AvisoSeguridad ;
    rdfs:label "Error en transmisión de ATs"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorSercos ;
    ns1:identificador "0x00008000" ;
    ns1:textoExtracto "Error en la transmisión de ATs. (Fibra óptica o regulador reseteado)"@es .

ns1:Error_0xFFFF0000 a ns1:AvisoSeguridad ;
    rdfs:label "Fallo en RAM común del SERCON"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorSercos ;
    ns1:identificador "0xFFFF0000" ;
    ns1:textoExtracto "Fallo en accesos a la RAM común del SERCON."@es .

ns1:Parametro_DriveID a ns1:Parametro ;
    rdfs:label "Selector de nodo del regulador (DriveID)"@es ;
    ns1:documentadoEn ns1:Diagnostico_4209 ;
    ns1:textoExtracto "Selector de nodo del regulador (DriveID)"@es .

ns1:Parametro_LOOPTIME a ns1:Parametro ;
    rdfs:label "LOOPTIME" ;
    ns1:documentadoEn ns1:Diagnostico_4209 ;
    ns1:textoExtracto "LOOPTIME" .

ns1:Parametro_OPMODE a ns1:Parametro ;
    rdfs:label "OPMODE" ;
    ns1:documentadoEn ns1:Diagnostico_4209 ;
    ns1:textoExtracto "OPMODE" .

ns1:Parametro_SERBRATE a ns1:Parametro ;
    rdfs:label "SERBRATE" ;
    ns1:documentadoEn ns1:Diagnostico_4209 ;
    ns1:textoExtracto "SERBRATE" .

ns1:Parametro_SERPOWSE a ns1:Parametro ;
    rdfs:label "SERPOWSE" ;
    ns1:documentadoEn ns1:Diagnostico_4209 ;
    ns1:textoExtracto "SERPOWSE" .

ns1:Sistema_Sercos a ns1:Sistema ;
    rdfs:label "Sistema SERCOS (anillo de comunicación)"@es ;
    ns1:textoExtracto """
Error en el bus Sercos que provoca pérdida de fase 4.
Ruptura del anillo Sercos, que provoca pérdida de fase 4.
"""@es .

ns1:Diagnostico_4209 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en anillo Sercos (fibra óptica, Código 4209)"@es ;
    ns1:identificador "4209" ;
    ns1:textoExtracto """
'Error en el anillo Sercos (fibra óptica)'
VALOR Códigos de error que identifican la fuente o fuentes del problema.
CAUSA Ruptura del anillo Sercos, que provoca pérdida de fase 4.
SOLUCIÓN Realizar comprobaciones: garantizar conexionado e integridad de la fibra óptica; comprobar parametrización en CNC y reguladores (DriveID, LOOPTIME, SERPOWSE, SERBRATE, OPMODE, etc.).
"""@es .

ns1:Tabla_CodigosErrorSercos a ns1:Tabla ;
    rdfs:label "Tabla de códigos de error SERCOS"@es ;
    ns1:textoExtracto """
| Código. | Significado. |
| --- | --- |
| 0x00000002 | Rotura de fibra óptica. |
| 0x00000100 | Pérdida de ATs. |
| 0x00000200 | Pérdida de MSTs. |
| 0x00008000 | Error en la transmisión de ATs. (Fibra óptica o regulador reseteado) |
| 0xFFFF0000 | Fallo en accesos a la RAM común del SERCON.
"""@es .

