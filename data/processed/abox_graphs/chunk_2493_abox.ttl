@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CodigoError_0x00000200 a ns1:Parametro ;
    rdfs:label "Pérdida de MSTs" ;
    ns1:identificador "0x00000200" ;
    ns1:monitoreaParametro ns1:Error_4210 ;
    ns1:textoExtracto "0x00000200 | Pérdida de MSTs." ;
    ns1:valor "Pérdida de MSTs" .

ns1:Error_4211 a ns1:AvisoSeguridad ;
    rdfs:label "Error en el anillo Sercos (2 ATs perdidos)" ;
    ns1:identificador "4211" ;
    ns1:textoExtracto "4211 'Error en el anillo Sercos (2 ATs perdidos)' EJE Número lógico del eje. VALOR Códigos de error que identifican la fuente o fuentes del problema." .

ns1:Parametro_LOOPTIME a ns1:Parametro ;
    rdfs:label "LOOPTIME" ;
    ns1:textoExtracto "Selector de nodo del regulador (DriveID), parámetros LOOPTIME, SERPOWSE, SERBRATE, OPMODE, etc." .

ns1:Parametro_OPMODE a ns1:Parametro ;
    rdfs:label "OPMODE" ;
    ns1:textoExtracto "Selector de nodo del regulador (DriveID), parámetros LOOPTIME, SERPOWSE, SERBRATE, OPMODE, etc." .

ns1:Parametro_SERBRATE a ns1:Parametro ;
    rdfs:label "SERBRATE" ;
    ns1:textoExtracto "Selector de nodo del regulador (DriveID), parámetros LOOPTIME, SERPOWSE, SERBRATE, OPMODE, etc." .

ns1:Parametro_SERPOWSE a ns1:Parametro ;
    rdfs:label "SERPOWSE" ;
    ns1:textoExtracto "Selector de nodo del regulador (DriveID), parámetros LOOPTIME, SERPOWSE, SERBRATE, OPMODE, etc." .

ns1:Solucion_4210 a ns1:TareaMantenimiento ;
    rdfs:label "Garantizar conectividad en anillo Sercos" ;
    ns1:solucionaFallo ns1:Error_4210 ;
    ns1:textoExtracto "SOLUCIÓN Garantizar la conectividad a través de todo el anillo (fibra óptica, master y esclavos)." .

ns1:Error_4210 a ns1:AvisoSeguridad ;
    rdfs:label "Error en el anillo Sercos (MST perdido)" ;
    ns1:identificador "4210" ;
    ns1:solucionaFallo ns1:Solucion_4210 ;
    ns1:textoExtracto "4210 'Error en el anillo Sercos (MST perdido)' VALOR Códigos de error que identifican la fuente o fuentes del problema. | Código. | Significado. | --- | --- | 0x00000200 | Pérdida de MSTs." .

