@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_0x00000100 a ns1:DiagnosticoFallo ;
    rdfs:label "Pérdida de ATs"@es ;
    ns1:identificador "0x00000100" ;
    ns1:solucionaFallo ns1:CambioNoAutorizadoDePlacaSercosOReguladorSinDiagnosticoPrevio ;
    ns1:textoExtracto "0x00000100 | Pérdida de ATs. CAUSA Pérdida de respuestas de algún regulador, que provoca pérdida de fase 4. SOLUCIÓN Determinar el regulador defectuoso y cambiar la placa Sercos o el mismo regulador."@es .

ns1:Error_4212 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el anillo Sercos (recepción de AT)"@es ;
    ns1:identificador "4212" ;
    ns1:monitoreaParametro ns1:CodigosDeErrorDelAnilloSercos,
        ns1:NumeroLogicoDelEje ;
    ns1:textoExtracto "4212 'Error en el anillo Sercos (recepción de AT)' EJE Número lógico del eje. VALOR Códigos de error que identifican la fuente o fuentes del problema."@es .

ns1:Tabla_CodigosError_4000_4999 a ns1:Tabla ;
    rdfs:label "Tabla de códigos de error (sección 4000-4999)"@es ;
    ns1:documentadoEn ns1:Seccion40004999Paginas162179 ;
    ns1:textoExtracto "| Código. | Significado. | --- | --- | 0x00000100 | Pérdida de ATs. | 4212 | Error en el anillo Sercos (recepción de AT)"@es .

ns1:CambioNoAutorizadoDePlacaSercosOReguladorSinDiagnosticoPrevio a ns1:AccionProhibida ;
    rdfs:label "Cambio no autorizado de placa Sercos o regulador sin diagnóstico previo"@es ;
    ns1:textoExtracto "Póngase en contacto con el servicio de asistencia técnica."@es .

ns1:CodigosDeErrorDelAnilloSercos a ns1:Parametro ;
    rdfs:label "Códigos de error del anillo Sercos"@es ;
    ns1:textoExtracto "VALOR Códigos de error que identifican la fuente o fuentes del problema."@es .

ns1:NumeroLogicoDelEje a ns1:Parametro ;
    rdfs:label "Número lógico del eje"@es ;
    ns1:textoExtracto "EJE Número lógico del eje."@es .

ns1:Seccion40004999Paginas162179 a ns1:Manual ;
    ns1:textoExtracto "Sección: 4000-4999. Páginas: 162-179"@es .

