@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorTransmisionATs_0x00008000 a ns1:AvisoSeguridad ;
    rdfs:label "Error en la transmisión de ATs (0x00008000)"@es ;
    ns1:identificador "0x00008000" ;
    ns1:textoExtracto "Error en la transmisión de ATs. ( Fibra óptica o regulador reseteado)"@es .

ns1:FibraOptica_0x00008000 a ns1:ComponenteElectrico ;
    rdfs:label "Fibra óptica asociada al error 0x00008000"@es ;
    ns1:textoExtracto "Fibra óptica"@es .

ns1:Regulador_0x00008000 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador asociado al error 0x00008000"@es ;
    ns1:textoExtracto "regulador reseteado"@es .

