@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnilloSercos a ns1:Sistema ;
    rdfs:label "Anillo Sercos (fibra óptica, master y esclavos)" ;
    ns1:compuestoPor ns1:EsclavosSercos,
        ns1:FibraOpticaSercos,
        ns1:MasterSercos ;
    ns1:textoExtracto "anillo (fibra óptica, master y esclavos)" .

ns1:BusSercosIII a ns1:Sistema ;
    rdfs:label "Bus Sercos III" ;
    ns1:textoExtracto "bus Sercos III" ;
    ns1:tieneComponente ns1:PlacasSercos .

ns1:Error4213 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en contadora Sercos (4213)" ;
    ns1:identificador "4213" ;
    ns1:solucionaFallo ns1:ErrorContadoraSercos ;
    ns1:textoExtracto "4213 'Error en contadora Sercos' [...] CAUSA La contadora reporta error. SOLUCIÓN Analizar códigos de error (ver manual de la contadora)." .

ns1:Error4214 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en búsqueda de I0 de contadora Sercos (4214)" ;
    ns1:identificador "4214" ;
    ns1:solucionaFallo ns1:ErrorBusquedaI0 ;
    ns1:textoExtracto "4214 'Error en búsqueda de I0 de contadora Sercos' [...] CAUSA Error durante la búsqueda de I0 de un eje con captación remota Sercos. SOLUCIÓN Analizar la parametrización del proceso; en concreto, el parámetro REFPULSE." .

ns1:Error4215 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en anillo Sercos (Recepción de MDT, 4215)" ;
    ns1:identificador "4215" ;
    ns1:solucionaFallo ns1:ErrorAnilloSercosMDT ;
    ns1:textoExtracto "4215 Error en el anillo Sercos (Recepción de MDT). [...] CAUSA Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc." .

ns1:Error4216 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en anillo Sercos (sincronismo, 4216)" ;
    ns1:identificador "4216" ;
    ns1:solucionaFallo ns1:ErrorAnilloSercosSync ;
    ns1:textoExtracto "4216 Error en el anillo Sercos (sincronismo). [...] CAUSA Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc." .

ns1:Error4217 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en anillo Sercos (Escritura de MDT, 4217)" ;
    ns1:identificador "4217" ;
    ns1:textoExtracto "4217 Error en el anillo Sercos (Escritura de MDT, buffer 0)." .

ns1:ModuloRCS_S a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S" ;
    ns1:documentadoEn ns1:Pagina312 ;
    ns1:identificador "RCS-S" ;
    ns1:textoExtracto "Ver 'Módulo RCS-S.' en la página 312." .

ns1:ParametroREFPLUSE a ns1:Parametro ;
    rdfs:label "REFPLUSE" ;
    ns1:identificador "REFPLUSE" ;
    ns1:textoExtracto "parámetro REFPULSE" .

ns1:ErrorAnilloSercosSync a ns1:AvisoSeguridad ;
    rdfs:label "Error en anillo Sercos (sincronismo)" ;
    ns1:mitigaRiesgo ns1:RevisarConexionSercosIII ;
    ns1:textoExtracto "Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc." .

ns1:ErrorBusSercosFase4 a ns1:AvisoSeguridad ;
    rdfs:label "Pérdida de fase en bus Sercos" ;
    ns1:mitigaRiesgo ns1:GarantizarConectividadAnillo ;
    ns1:textoExtracto "Error en el bus Sercos que provoca pérdida de fase 4." .

ns1:EsclavosSercos a ns1:ComponenteElectrico ;
    rdfs:label "Esclavos Sercos" ;
    ns1:textoExtracto "esclavos" .

ns1:FibraOpticaSercos a ns1:ComponenteElectrico ;
    rdfs:label "Fibra óptica del bus Sercos" ;
    ns1:textoExtracto "fibra óptica" .

ns1:GarantizarConectividadAnillo a ns1:TareaMantenimiento ;
    rdfs:label "Garantizar conectividad del anillo Sercos" ;
    ns1:requiereMantenimiento ns1:ErrorBusSercosFase4 ;
    ns1:textoExtracto "Garantizar la conectividad a través de todo el anillo (fibra óptica, master y esclavos)." .

ns1:ManualContadora a ns1:Manual ;
    rdfs:label "Manual de la contadora" ;
    ns1:textoExtracto "ver manual de la contadora" .

ns1:MasterSercos a ns1:ComponenteElectrico ;
    rdfs:label "Master Sercos" ;
    ns1:textoExtracto "master" .

ns1:Pagina312 a ns1:Pagina ;
    rdfs:label "Página 312 (Módulo RCS-S)" ;
    ns1:identificador "312" ;
    ns1:textoExtracto "Ver 'Módulo RCS-S.' en la página 312." .

ns1:PlacasSercos a ns1:ComponenteElectrico ;
    rdfs:label "Placas de Sercos" ;
    ns1:textoExtracto "problemas en las placas de Sercos" .

ns1:RevisarParametroREFPLUSE a ns1:TareaMantenimiento ;
    rdfs:label "Analizar parametrización de REFPULSE" ;
    ns1:requiereMantenimiento ns1:ErrorBusquedaI0 ;
    ns1:textoExtracto "Analizar la parametrización del proceso; en concreto, el parámetro REFPULSE." .

ns1:RevisarParametrosContadora a ns1:TareaMantenimiento ;
    rdfs:label "Analizar códigos de error de contadora" ;
    ns1:documentadoEn ns1:ManualContadora ;
    ns1:requiereMantenimiento ns1:ErrorContadoraSercos ;
    ns1:textoExtracto "Analizar códigos de error (ver manual de la contadora)." .

ns1:ErrorAnilloSercosMDT a ns1:AvisoSeguridad ;
    rdfs:label "Error en anillo Sercos (Recepción MDT)" ;
    ns1:mitigaRiesgo ns1:RevisarConexionSercosIII ;
    ns1:textoExtracto "Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc." .

ns1:ErrorBusquedaI0 a ns1:AvisoSeguridad ;
    rdfs:label "Error en búsqueda de I0 (Sercos)" ;
    ns1:mitigaRiesgo ns1:RevisarParametroREFPLUSE ;
    ns1:textoExtracto "Error durante la búsqueda de I0 de un eje con captación remota Sercos." .

ns1:ErrorContadoraSercos a ns1:AvisoSeguridad ;
    rdfs:label "Error en contadora Sercos" ;
    ns1:mitigaRiesgo ns1:RevisarParametrosContadora ;
    ns1:textoExtracto "La contadora reporta error." .

ns1:RevisarConexionSercosIII a ns1:TareaMantenimiento ;
    rdfs:label "Revisar conexión del bus Sercos III" ;
    ns1:requiereMantenimiento ns1:ErrorAnilloSercosMDT ;
    ns1:textoExtracto "Revisar la conexión del bus Sercos III. Si el error persiste, póngase en contacto con Fagor Automation." .

