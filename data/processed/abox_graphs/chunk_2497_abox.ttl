@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation."@es .

ns1:Error4217_Sercos a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4217: Error en el anillo Sercos (Escritura de MDT, buffer 0)"@es ;
    ns1:identificador "4217" ;
    ns1:solucionaFallo ns1:Tarea_RevisionConexionBusSercosIII ;
    ns1:textoExtracto "4217 Error en el anillo Sercos (Escritura de MDT, buffer 0). DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc."@es .

ns1:Error4218_Sercos a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4218: Error en el anillo Sercos (Escritura de MDT, buffer 1)"@es ;
    ns1:identificador "4218" ;
    ns1:solucionaFallo ns1:Tarea_RevisionConexionBusSercosIII ;
    ns1:textoExtracto "4218 Error en el anillo Sercos (Escritura de MDT, buffer 1). DETECCIÓN Durante el arranque o"@es .

ns1:Tarea_RevisionConexionBusSercosIII a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de la conexión del bus Sercos III"@es ;
    ns1:textoExtracto "Revisar la conexión del bus Sercos III."@es .

