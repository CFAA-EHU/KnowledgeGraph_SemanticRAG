@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation"@es .

ns1:Placas_Sercos a ns1:ComponenteElectrico ;
    rdfs:label "Placas de Sercos"@es ;
    ns1:compuestoPor ns1:Sistema_BusSercosIII ;
    ns1:textoExtracto "problemas en las placas de Sercos"@es .

ns1:Solucion_RevisionConexionSercosIII a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de conexión del bus Sercos III"@es ;
    ns1:solucionaFallo ns1:Error_4218_SercosIII,
        ns1:Error_4219_SercosIII,
        ns1:Error_4220_SercosIII,
        ns1:Error_4221_SercosIII,
        ns1:Error_4222_SercosIII ;
    ns1:textoExtracto "Revisar la conexión del bus Sercos III"@es .

ns1:Error_4218_SercosIII a ns1:AvisoSeguridad ;
    rdfs:label "Error 4218: Error en el anillo Sercos (Escritura de MDT, buffer 1)"@es ;
    ns1:identificador "4218" ;
    ns1:textoExtracto "4218 Error en el anillo Sercos (Escritura de MDT, buffer 1). DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc."@es .

ns1:Error_4219_SercosIII a ns1:AvisoSeguridad ;
    rdfs:label "Error 4219: errDoubleMSTMiss"@es ;
    ns1:identificador "4219" ;
    ns1:textoExtracto "4219 errDoubleMSTMiss. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc."@es .

ns1:Error_4220_SercosIII a ns1:AvisoSeguridad ;
    rdfs:label "Error 4220: errMSTValidMiss"@es ;
    ns1:identificador "4220" ;
    ns1:textoExtracto "4220 errMSTValidMiss. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc."@es .

ns1:Error_4221_SercosIII a ns1:AvisoSeguridad ;
    rdfs:label "Error 4221: errMDTValidMiss"@es ;
    ns1:identificador "4221" ;
    ns1:textoExtracto "4221 errMDTValidMiss. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc."@es .

ns1:Error_4222_SercosIII a ns1:AvisoSeguridad ;
    rdfs:label "Error 4222: errATValidMiss"@es ;
    ns1:identificador "4222" ;
    ns1:textoExtracto "4222 errATValidMiss. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc."@es .

ns1:Sistema_BusSercosIII a ns1:Sistema ;
    rdfs:label "Bus Sercos III"@es ;
    ns1:textoExtracto "Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc."@es .

