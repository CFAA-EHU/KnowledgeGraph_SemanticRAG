@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ContactoSoporteFagor a ns1:AvisoSeguridad ;
    rdfs:label "Contacto con soporte técnico (Fagor Automation)"@es ;
    ns1:mitigaRiesgo ns1:ErrorBusSercos_4300 ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation."@es .

ns1:PlacasSercos a ns1:ComponenteElectrico ;
    rdfs:label "Placas de Sercos"@es ;
    ns1:textoExtracto "problemas en las placas de Sercos"@es ;
    ns1:tieneComponente ns1:BusSercos .

ns1:SolucionError4300 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de conexión del bus Sercos"@es ;
    ns1:solucionaFallo ns1:ErrorBusSercos_4300 ;
    ns1:textoExtracto "Revisar la conexión del bus Sercos III. Si el error persiste, póngase en contacto con Fagor Automation."@es .

ns1:VariableSercos a ns1:Parametro ;
    rdfs:label "Variable Sercos"@es ;
    ns1:monitoreaParametro ns1:BusSercos ;
    ns1:textoExtracto "hay definida una variable Sercos"@es .

ns1:BusSercos a ns1:ComponenteElectrico ;
    rdfs:label "Bus Sercos III"@es ;
    ns1:textoExtracto "Revisar la conexión del bus Sercos III. [...] Error en el bus Sercos, debido a problemas de conexión, parametrización, problemas en las placas de Sercos, etc."@es .

ns1:ErrorBusSercos_4300 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4300: No hay registrado ningún servidor de variables Sercos"@es ;
    ns1:identificador "4300" ;
    ns1:textoExtracto "4300 'No hay registrado ningún servidor de variables Sercos' [...] En un canal del osciloscopio hay definida una variable Sercos, pero no hay ningún servidor de variables Sercos para responder a la petición."@es .

