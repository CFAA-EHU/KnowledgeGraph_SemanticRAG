@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazOperador_JogPanel a ns1:InterfazUsuario ;
    rdfs:label "Panel de operador (JOG PANEL)"@es ;
    ns1:ilustradoEn ns1:DiagramaIconosHMI ;
    ns1:textoExtracto "Panel de operador con diagramas circulares tipo selector: uno para modo de jog (continuo/incremental/volantes con factores ×1/×10/×100) y otro para override de avance (0–200%). A la derecha, bloque de teclas de ejecución (START, STOP, RESET, SINGLE, ZERO) y control del husillo maestro (giro horario/antihorario, parada, orientación) con iconos cuadrados."@es ;
    ns1:tieneComponente ns1:BloqueTeclasEjecucion,
        ns1:ControlHusilloMaestro,
        ns1:SelectorModoJog,
        ns1:SelectorOverrideAvance .

ns1:InterfazOperador_SoftkeysHome a ns1:InterfazUsuario ;
    rdfs:label "Tabla de softkeys y búsqueda de referencia (JOG MODE - Softkeys + HOME SEARCH)"@es ;
    ns1:ilustradoEn ns1:TablaSecuenciaHome ;
    ns1:textoExtracto "Tabla visual de softkeys (cambio de unidades, orígenes/cotas, calibración de herramientas, centrado) y, debajo, dos diagramas de búsqueda de referencia (home): 'manual por eje' y 'automática (subrutina)'."@es ;
    ns1:tieneComponente ns1:DiagramaHomeAutomatico,
        ns1:DiagramaHomeManual,
        ns1:SoftkeyCalibracionHerramientas,
        ns1:SoftkeyCambioUnidades,
        ns1:SoftkeyCentrado,
        ns1:SoftkeyOrigenesCotas .

ns1:InterfazOperador_TeclasRapidas a ns1:InterfazUsuario ;
    rdfs:label "Mosaico de atajos de teclado (KEYBOARD SHORTCUTS)"@es ;
    ns1:textoExtracto "Mosaico de atajos con etiquetas de teclas (CTRL/ALT/Fx) y mini-iconos de los mismos pictogramas de modos (AUTO, MANUAL, EDIT, MDI, TABLES, TOOLS, UTILITIES). Incluye un bloque de Execution keys con equivalentes de START/STOP/RESET/SINGLE."@es ;
    ns1:tieneComponente ns1:BloqueTeclasEjecucion_Rapidas,
        ns1:BloqueTeclasModo .

ns1:BloqueTeclasEjecucion a ns1:Componente ;
    rdfs:label "Bloque de teclas de ejecución (START, STOP, RESET, SINGLE, ZERO)"@es ;
    ns1:textoExtracto "bloque de teclas de ejecución (START, STOP, RESET, SINGLE, ZERO)"@es .

ns1:BloqueTeclasEjecucion_Rapidas a ns1:Componente ;
    rdfs:label "Bloque de Execution Keys (START/STOP/RESET/SINGLE) en atajos"@es ;
    ns1:textoExtracto "Incluye un bloque de Execution keys con equivalentes de START/STOP/RESET/SINGLE"@es .

ns1:BloqueTeclasModo a ns1:Componente ;
    rdfs:label "Bloque de teclas de modo (AUTO, MANUAL, EDIT, MDI, TABLES, TOOLS, UTILITIES)"@es ;
    ns1:textoExtracto "mini-iconos de los mismos pictogramas de modos (AUTO, MANUAL, EDIT, MDI, TABLES, TOOLS, UTILITIES)"@es .

ns1:ControlHusilloMaestro a ns1:Componente ;
    rdfs:label "Control del husillo maestro (giro horario/antihorario, parada, orientación)"@es ;
    ns1:textoExtracto "control del husillo maestro (giro horario/antihorario, parada, orientación) con iconos cuadrados"@es .

ns1:DiagramaHomeAutomatico a ns1:Componente ;
    rdfs:label "Diagrama de búsqueda de referencia automática (subrutina)"@es ;
    ns1:textoExtracto "'automática (subrutina)'"@es .

ns1:DiagramaHomeManual a ns1:Componente ;
    rdfs:label "Diagrama de búsqueda de referencia manual por eje"@es ;
    ns1:textoExtracto "dos diagramas de búsqueda de referencia (home): 'manual por eje'"@es .

ns1:DiagramaIconosHMI a ns1:Esquema ;
    rdfs:label "Codificación visual de iconos en HMI"@es ;
    ns1:textoExtracto "Cada icono aparece en un recuadro con su rótulo y una breve leyenda funcional, estableciendo una codificación visual consistente para localizar acciones en la HMI."@es .

ns1:SelectorModoJog a ns1:Componente ;
    rdfs:label "Selector de modo JOG (×1/×10/×100)"@es ;
    ns1:textoExtracto "diagramas circulares tipo selector: uno para modo de jog (continuo/incremental/volantes con factores ×1/×10/×100)"@es .

ns1:SelectorOverrideAvance a ns1:Componente ;
    rdfs:label "Selector de override de avance (0–200%)"@es ;
    ns1:textoExtracto "otro para override de avance (0–200%)"@es .

ns1:SoftkeyCalibracionHerramientas a ns1:Componente ;
    rdfs:label "Softkey para calibración de herramientas"@es ;
    ns1:textoExtracto "softkeys (cambio de unidades, orígenes/cotas, calibración de herramientas, centrado)"@es .

ns1:SoftkeyCambioUnidades a ns1:Componente ;
    rdfs:label "Softkey para cambio de unidades"@es ;
    ns1:textoExtracto "softkeys (cambio de unidades, orígenes/cotas, calibración de herramientas, centrado)"@es .

ns1:SoftkeyCentrado a ns1:Componente ;
    rdfs:label "Softkey para centrado"@es ;
    ns1:textoExtracto "softkeys (cambio de unidades, orígenes/cotas, calibración de herramientas, centrado)"@es .

ns1:SoftkeyOrigenesCotas a ns1:Componente ;
    rdfs:label "Softkey para orígenes/cotas"@es ;
    ns1:textoExtracto "softkeys (cambio de unidades, orígenes/cotas, calibración de herramientas, centrado)"@es .

ns1:TablaSecuenciaHome a ns1:Tabla ;
    rdfs:label "Secuencia numerada para búsqueda de referencia (HOME)"@es ;
    ns1:textoExtracto "Cada diagrama presenta secuencia numerada 1–3 con teclas involucradas (ZERO, START, ESC) y un recuadro que lista ejes del canal."@es .

