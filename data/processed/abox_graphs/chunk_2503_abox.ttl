@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FaltaPotenciaEsclavoMechatrolink_4506 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta potencia en esclavo Mechatrolink"@es ;
    ns1:identificador "4506" ;
    ns1:solucionaFallo ns1:RevisarConexionadoPotencia_4506 ;
    ns1:textoExtracto "'Falta potencia en esclavo Mechatrolink' DETECCIÓN Durante la ejecución del CNC, una vez que ha entrado en estado de movimiento interpolado. CAUSA Alguno de los esclavos Mechatrolink no puede completar un comando de movimiento por falta de potencia."@es .

ns1:RevisarConexionadoPotencia_4506 a ns1:TareaMantenimiento ;
    ns1:requiereMantenimiento ns1:SistemaMechatrolink ;
    ns1:textoExtracto "Revisar el conexionado de potencia del armario y la maniobra de PLC encargada de habilitar los [esclavos Mechatrolink]."@es .

