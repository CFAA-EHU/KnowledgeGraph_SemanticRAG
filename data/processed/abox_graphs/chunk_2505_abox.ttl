@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:textoExtracto "arranque del CNC"@es ;
    ns1:tieneComponente ns1:BusEtherCAT .

ns1:TareaMantenimiento_RevisionCableado a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de cableado, conexionado y alimentación de esclavos"@es ;
    ns1:solucionaFallo ns1:ErrorConfiguracionBus_4603 ;
    ns1:textoExtracto "Revisar el cableado, conexionado y alimentación de los esclavos."@es .

ns1:TareaMantenimiento_RevisionConfiguracion a ns1:TareaMantenimiento ;
    rdfs:label "Revisión del archivo de configuración del bus EtherCAT"@es ;
    ns1:solucionaFallo ns1:ErrorConfiguracionBus_4603 ;
    ns1:textoExtracto "revisar el archivo de configuración"@es .

ns1:BusEtherCAT a ns1:Sistema ;
    rdfs:label "Bus EtherCAT"@es ;
    ns1:textoExtracto "bus EtherCAT"@es .

ns1:ErrorConfiguracionBus_4603 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4603: Error en fase de configuración del bus EtherCAT"@es ;
    ns1:identificador "4603" ;
    ns1:textoExtracto "4603 Error en la fase de configuración del bus. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno durante la fase de configuración de esclavos conectados al bus."@es .

