@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorConfiguracionBus_4603 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4603: Error en fase de configuración del bus" ;
    ns1:identificador "4603" ;
    ns1:textoExtracto "4603 Error en la fase de configuración del bus. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno durante la fase de configuración de esclavos conectados al bus." .

ns1:ErrorOperacionalBus_4605 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4605: Error en fase operacional del bus" ;
    ns1:identificador "4605" ;
    ns1:solucionaFallo ns1:HerramientaKPA ;
    ns1:textoExtracto "4605 Error en la fase operacional del bus. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno durante la transición a la fase operacional del bus. En el caso de EtherCAT (código adicional de error ID 330-xxx), es posible que algún nodo esté en estado de error o que el archivo ENI de configuración sea incorrecto." .

ns1:ErrorPreoperacionalBus_4604 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4604: Error en fase preoperacional del bus" ;
    ns1:identificador "4604" ;
    ns1:solucionaFallo ns1:HerramientaKPA ;
    ns1:textoExtracto "4604 Error en la fase preoperacional del bus. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno durante la transición a la fase preoperacional del bus. En el caso de EtherCAT (código adicional de error ID 330-xxx), es posible que el archivo ENI de configuración sea incorrecto porque algún archivo ESI de los esclavos no sea adecuado." .

ns1:ErrorPreparacionBus_4606 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4606: Error en comando de preparación del bus" ;
    ns1:identificador "4606" ;
    ns1:textoExtracto "4606 Error en comando de preparación del bus. DETECCIÓN Durante el arranque del CNC." .

ns1:ArchivoENI a ns1:InterfazUsuario ;
    rdfs:label "Archivo ENI (configuración de bus EtherCAT)" ;
    ns1:compuestoPor ns1:ArchivoESI ;
    ns1:identificador "ENI" ;
    ns1:textoExtracto "archivo ENI de configuración" .

ns1:ArchivoESI a ns1:InterfazUsuario ;
    rdfs:label "Archivo ESI (descripción de esclavos EtherCAT)" ;
    ns1:identificador "ESI" ;
    ns1:textoExtracto "archivo ESI de los esclavos" .

ns1:HerramientaKPA a ns1:Herramienta ;
    rdfs:label "KPA (Herramienta de configuración de bus)" ;
    ns1:requiereMantenimiento ns1:ArchivoENI ;
    ns1:textoExtracto "Volver a generar el archivo ENI de configuración utilizando la herramienta KPA, siguiendo los pasos adecuados para generar el archivo. Realizar un \"Detach Master\" en el configurador KPA antes de exportar el fichero ENI." .

