@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ns1:textoExtracto "Si el error se repite, póngase en contacto con Fagor Automation."@es .

ns1:Procedimiento_ExportacionENI a ns1:ModoOperacion ;
    rdfs:label "Procedimiento de exportación del fichero ENI"@es ;
    ns1:requiereMantenimiento ns1:Accion_DetachMaster ;
    ns1:textoExtracto "Realizar un \"Detach Master\" en el configurador KPA antes de exportar el fichero ENI."@es .

ns1:Accion_DetachMaster a ns1:TareaMantenimiento ;
    rdfs:label "Realizar 'Detach Master' en configurador KPA"@es ;
    ns1:solucionaFallo ns1:Error_4606 ;
    ns1:textoExtracto "Realizar un \"Detach Master\" en el configurador KPA antes de exportar el fichero ENI."@es .

ns1:Error_4606 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4606: Error en comando de preparación del bus"@es ;
    ns1:identificador "4606" ;
    ns1:textoExtracto "4606 Error en comando de preparación del bus. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno durante la preparación de los parámetros del bus"@es .

