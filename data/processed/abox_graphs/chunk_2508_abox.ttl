@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation" ;
    ns1:textoExtracto "Fagor Automation" .

ns1:Error4606 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en comando de preparación del bus" ;
    ns1:identificador "4606" ;
    ns1:textoExtracto "Error en comando de preparación del bus. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno durante la preparación de los parámetros del bus. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error4607 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en comando de actualización del bus" ;
    ns1:identificador "4607" ;
    ns1:textoExtracto "Error en comando de actualización del bus. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno durante la activación de los parámetros del bus. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error4608 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización de la captación" ;
    ns1:identificador "4608" ;
    ns1:textoExtracto "Error en la inicialización de la captación. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno durante el reconocimiento de las captaciones. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error4609 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el reset del bus" ;
    ns1:identificador "4609" ;
    ns1:textoExtracto "Error en el reset del bus. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA Se ha producido un error interno durante el proceso de reset del bus. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error4610 a ns1:DiagnosticoFallo ;
    rdfs:label "Error bus sin conexión" ;
    ns1:identificador "4610" ;
    ns1:solucionaFallo ns1:ComponenteElectrico_BusSercosIII ;
    ns1:textoExtracto "Error bus sin conexión. DETECCIÓN Durante el arranque del CNC o la ejecución. CAUSA Se ha perdido la conexión física en el bus Sercos III; cable desconectado o esclavo apagado sin alimentación. SOLUCIÓN Revisar el cableado, conexionado y alimentación del CNC." .

ns1:Error4611 a ns1:DiagnosticoFallo ;
    rdfs:label "Error Bus, mensaje de bus no válido en fase 0" ;
    ns1:identificador "4611" ;
    ns1:solucionaFallo ns1:ComponenteElectrico_BusSercosIII ;
    ns1:textoExtracto "Error Bus, mensaje de bus no válido en fase 0. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA Se ha producido un error durante la comunicación con los esclavos en el bus Sercos III. SOLUCIÓN Revisar el cableado, conexionado y alimentación de los esclavos. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error4612 a ns1:DiagnosticoFallo ;
    rdfs:label "Error bus mensaje no recibido en fase 0" ;
    ns1:identificador "4612" ;
    ns1:solucionaFallo ns1:ComponenteElectrico_BusSercosIII ;
    ns1:textoExtracto "Error bus mensaje no recibido en fase 0. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA Se ha producido un error durante la detección de esclavos en el bus Sercos III. Alguno de los esclavos se encuentra en error o desconectado." .

ns1:ComponenteElectrico_BusSercosIII a ns1:ComponenteElectrico ;
    rdfs:label "Bus Sercos III" ;
    ns1:textoExtracto "bus Sercos III" .

