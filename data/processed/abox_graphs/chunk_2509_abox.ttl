@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ns1:textoExtracto "Fagor Automation"@es .

ns1:Error4613 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4613: Número de nodos detectados incorrectos"@es ;
    ns1:identificador "4613" ;
    ns1:textoExtracto "4613 Error bus número de nodos detectados incorrectos. DETECCIÓN Durante el arranque del CNC."@es .

ns1:SistemaBusSercosIII a ns1:Sistema ;
    rdfs:label "Bus Sercos III"@es ;
    ns1:textoExtracto "bus Sercos III"@es .

ns1:TareaMantenimiento_CableadoSercos a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de cableado, conexionado y alimentación de esclavos Sercos III"@es ;
    ns1:solucionaFallo ns1:Error4612 ;
    ns1:textoExtracto "Revisar el cableado, conexionado y alimentación de los esclavos."@es .

ns1:Error4612 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4612: Bus mensaje no recibido en fase 0"@es ;
    ns1:identificador "4612" ;
    ns1:textoExtracto "4612 Error bus mensaje no recibido en fase 0. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA Se ha producido un error durante la detección de esclavos en el bus Sercos III. Alguno de los esclavos se encuentra en error o desconectado."@es .

