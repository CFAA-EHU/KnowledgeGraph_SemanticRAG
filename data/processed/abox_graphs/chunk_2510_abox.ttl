@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BusEtherCAT a ns1:Sistema ;
    rdfs:label "Bus EtherCAT" ;
    ns1:textoExtracto "En el caso del bus EtherCAT, revisar el archivo de configuración." .

ns1:BusSercosIII a ns1:Sistema ;
    rdfs:label "Bus Sercos III" ;
    ns1:textoExtracto "Se ha producido un error inesperado en el bus Sercos III." .

ns1:EmpresaFagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error4613 a ns1:AvisoSeguridad ;
    rdfs:label "Error bus: número de nodos detectados incorrectos" ;
    ns1:identificador "4613" ;
    ns1:textoExtracto "4613 Error bus número de nodos detectados incorrectos. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno durante la fase de detección de nodos en el bus. SOLUCIÓN Corregir la configuración del bus simulado. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error4614 a ns1:AvisoSeguridad ;
    rdfs:label "Error bus indefinido" ;
    ns1:identificador "4614" ;
    ns1:textoExtracto "4614 Error bus indefinido. DETECCIÓN Durante el arranque del CNC, durante la ejecución o tras un reset. CAUSA Se ha producido un error inesperado en el bus Sercos III. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error4615 a ns1:AvisoSeguridad ;
    rdfs:label "Error bus timeout" ;
    ns1:identificador "4615" ;
    ns1:textoExtracto "4615 Error bus timeout. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA Se ha producido un error de timeout durante el arranque o reset del bus de comunicaciones. SOLUCIÓN Revisar el cableado, conexionado y alimentación de los esclavos. En el caso del bus EtherCAT, revisar el archivo de configuración. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error4616 a ns1:AvisoSeguridad ;
    rdfs:label "Error Node Module sin definir" ;
    ns1:identificador "4616" ;
    ns1:textoExtracto "4616 Error Node Module sin definir. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno durante la fase de detección de nodos en el bus. SOLUCIÓN Corregir la configuración del bus simulado. Si no hay bus simulado, póngase en contacto con Fagor Automation." .

ns1:Error4630 a ns1:AvisoSeguridad ;
    rdfs:label "Error de configuración del número de serie" ;
    ns1:identificador "4630" ;
    ns1:textoExtracto "4630 Error de configuración del número de serie. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error en la lectura de los números de serie de un nodo Sercos III o números de serie incorrectos. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error4631 a ns1:AvisoSeguridad ;
    rdfs:label "Nombre de conexión no encontrado" ;
    ns1:identificador "4631" ;
    ns1:textoExtracto "4631 Nombre de conexión no encontrado. DETECCIÓN Durante el arranque del CNC, la validación de parámetros máquina o tras un reset. CAUSA La conexión especificada en el parámetro no existe. SOLUCIÓN Revisar el apartado conexiones del CNC y comprobar que existen todas las conexiones que se van a utilizar." .

ns1:ParametroConfiguracionBus a ns1:Parametro ;
    rdfs:label "Configuración del bus" ;
    ns1:textoExtracto "Corregir la configuración del bus simulado." .

ns1:ParametroNombreConexion a ns1:Parametro ;
    rdfs:label "Nombre de conexión" ;
    ns1:textoExtracto "La conexión especificada en el parámetro no existe." .

ns1:ParametroNumeroSerie a ns1:Parametro ;
    rdfs:label "Número de serie del nodo" ;
    ns1:textoExtracto "Se ha producido un error en la lectura de los números de serie de un nodo Sercos III o números de serie incorrectos." .

