@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC"@es ;
    ns1:activaAlarma ns1:Fallo_ParametrosConexion ;
    ns1:textoExtracto "arranque del CNC"@es ;
    ns1:tieneComponente ns1:SistemaSercosIII .

ns1:Parametro_ConexionCNC a ns1:Parametro ;
    rdfs:label "Parámetro de conexión máquina CNC"@es ;
    ns1:monitoreaParametro ns1:Fallo_ParametrosConexion ;
    ns1:textoExtracto "La conexión especificada en el parámetro no existe."@es .

ns1:Fallo_4632 a ns1:DiagnosticoFallo ;
    rdfs:label "Node hardware ID desconocido"@es ;
    ns1:identificador "4632" ;
    ns1:textoExtracto "4632 Node hardware id desconocido. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno en la detección de nodos Sercos III."@es .

ns1:SistemaSercosIII a ns1:Sistema ;
    rdfs:label "Sistema de nodos Sercos III"@es ;
    ns1:activaAlarma ns1:Fallo_4632 ;
    ns1:textoExtracto "Se ha producido un error interno en la detección de nodos Sercos III."@es .

ns1:Fallo_ParametrosConexion a ns1:DiagnosticoFallo ;
    rdfs:label "Conexión no existente en parámetro máquina"@es ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC, la validación de parámetros máquina o tras un reset. CAUSA La conexión especificada en el parámetro no existe. SOLUCIÓN Revisar el apartado conexiones del CNC y comprobar que existen todas las conexiones que se van a utilizar."@es .

