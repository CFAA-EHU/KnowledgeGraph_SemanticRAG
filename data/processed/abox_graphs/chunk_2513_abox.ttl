@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation" ;
    ns1:textoExtracto "Póngase en contacto con Fagor Automation." .

ns1:Error_4639 a ns1:AvisoSeguridad ;
    rdfs:label "Nodo encontrado no definido" ;
    ns1:activaAlarma ns1:Alarma_4639 ;
    ns1:identificador "4639" ;
    ns1:textoExtracto "4639 Nodo encontrado no definido. DETECCIÓN" .

ns1:Solucion_4638 a ns1:TareaMantenimiento ;
    ns1:solucionaFallo ns1:Error_4638 ;
    ns1:textoExtracto "Actualizar la topología de acuerdo con los nodos conectados (eliminar nodo de la topología) o revisar cableado, conexionado y alimentación de los esclavos del bus." .

ns1:Alarma_4638 a ns1:Alarma ;
    ns1:textoExtracto "Nodo no detectado. DETECCIÓN Durante el arranque del CNC." .

ns1:Alarma_4639 a ns1:Alarma ;
    ns1:textoExtracto "Nodo encontrado no definido." .

ns1:Error_4638 a ns1:AvisoSeguridad ;
    rdfs:label "Nodo no detectado" ;
    ns1:activaAlarma ns1:Alarma_4638 ;
    ns1:identificador "4638" ;
    ns1:textoExtracto "4638 Nodo no detectado. DETECCIÓN Durante el arranque del CNC. CAUSA No se ha detectado un nodo de la topología durante el arranque del CNC." .

