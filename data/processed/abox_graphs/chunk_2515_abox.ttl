@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaComunicacionHiperface a ns1:Sistema ;
    rdfs:label "Sistema de comunicación Hiperface"@es ;
    ns1:textoExtracto "Error interno en la comunicación Hiperface"@es ;
    ns1:tieneComponente ns1:ErrorChecksumHiperface_4662,
        ns1:ErrorComunicacionHiperface_4661,
        ns1:ErrorMaquinaEstadosHiperface .

ns1:ErrorChecksumHiperface_4662 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de checksum Hiperface"@es ;
    ns1:identificador "4662" ;
    ns1:textoExtracto "4662 Error de checksum Hiperface."@es .

ns1:ErrorComunicacionHiperface_4661 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de comunicaciones con driver Hiperface"@es ;
    ns1:identificador "4661" ;
    ns1:solucionaFallo ns1:FagorAutomation ;
    ns1:textoExtracto "4661 Error de comunicaciones con driver Hiperface. DETECCIÓN Durante el arranque del CNC. CAUSA Error interno en la comunicación Hiperface. SOLUCIÓN Póngase en contacto con Fagor Automation."@es .

ns1:ErrorMaquinaEstadosHiperface a ns1:DiagnosticoFallo ;
    rdfs:label "Error interno en máquina de estados de la comunicación Hiperface"@es ;
    ns1:solucionaFallo ns1:FagorAutomation ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA Error interno en máquina de estados de la comunicación Hiperface. SOLUCIÓN Póngase en contacto con Fagor Automation."@es .

ns1:FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ns1:textoExtracto "Póngase en contacto con Fagor Automation."@es .

