@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error4662 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de checksum Hiperface" ;
    ns1:identificador "4662" ;
    ns1:solucionaFallo ns1:SistemaFeedbackHiperface ;
    ns1:textoExtracto "4662 Error de checksum Hiperface. DETECCIÓN Durante el arranque del CNC. CAUSA Error interno de checksum en la comunicación Hiperface. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error4663 a ns1:DiagnosticoFallo ;
    rdfs:label "Encóder Hiperface desconocido" ;
    ns1:identificador "4663" ;
    ns1:solucionaFallo ns1:EncoderHiperface ;
    ns1:textoExtracto "4663 Encóder Hiperface desconocido. DETECCIÓN Durante el arranque del CNC. CAUSA Feedback hiperface desconocido. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error4664 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de inicialización de Feedback" ;
    ns1:identificador "4664" ;
    ns1:solucionaFallo ns1:SistemaFeedbackHiperface ;
    ns1:textoExtracto "4664 Error de inicialización de Feedback. DETECCIÓN Durante el arranque del CNC. CAUSA Error interno en la inicialización de feedback. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error4665 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de comunicaciones con driver de comunicaciones" ;
    ns1:identificador "4665" ;
    ns1:solucionaFallo ns1:SistemaFeedbackHiperface ;
    ns1:textoExtracto "4665 Error de comunicaciones con driver de comunicaciones. DETECCIÓN Durante el arranque del CNC. CAUSA Error interno en las comunicaciones de feedbacks. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error4666 a ns1:DiagnosticoFallo ;
    rdfs:label "Encóder Hiperface virgen sin formato de EEPROM" ;
    ns1:identificador "4666" ;
    ns1:solucionaFallo ns1:EncoderHiperface ;
    ns1:textoExtracto "4666 Encóder Hiperface virgen sin formato de EEPROM. DETECCIÓN Durante el arranque del CNC. CAUSA Encóder Hiperface sin formato en la EEPROM. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error4670 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de comunicaciones con driver feedback SSI" ;
    ns1:identificador "4670" ;
    ns1:solucionaFallo ns1:SistemaFeedbackSSI ;
    ns1:textoExtracto "4670 Error de comunicaciones con driver feedback SSI. DETECCIÓN Durante el arranque del CNC. CAUSA Error en la comunicación con feedbacks SSI. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error4671 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de crc/checksum SSI" ;
    ns1:identificador "4671" ;
    ns1:solucionaFallo ns1:SistemaFeedbackSSI ;
    ns1:textoExtracto "4671 Error de crc/checksum SSI. DETECCIÓN Durante el arranque del CNC o la ejecución. CAUSA Error de checksum en la comunicación con feedbacks SSI. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error4672 a ns1:DiagnosticoFallo ;
    rdfs:label "Feedback SSI error interno" ;
    ns1:identificador "4672" ;
    ns1:solucionaFallo ns1:FeedbackSSI ;
    ns1:textoExtracto "4672 Feedback SSI error interno. DETECCIÓN Durante el arranque del CNC o la ejecución. CAUSA Error interno en un feedback SSI. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error4673 a ns1:DiagnosticoFallo ;
    rdfs:label "Error scknowledge feedback SSI" ;
    ns1:identificador "4673" ;
    ns1:textoExtracto "4673 Error scknowledge feedback SSI. DETECCIÓN Durante el arranque del CNC o la ejecución." .

ns1:FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation" ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:FeedbackSSI a ns1:ComponenteElectrico ;
    rdfs:label "Feedback SSI" ;
    ns1:textoExtracto "Error de checksum en la comunicación con feedbacks SSI... Error interno en un feedback SSI" .

ns1:SistemaFeedbackSSI a ns1:Sistema ;
    rdfs:label "Sistema de feedback SSI" ;
    ns1:textoExtracto "Error en la comunicación con feedbacks SSI" ;
    ns1:tieneComponente ns1:FeedbackSSI .

ns1:EncoderHiperface a ns1:ComponenteElectrico ;
    rdfs:label "Encóder Hiperface" ;
    ns1:textoExtracto "Encóder Hiperface desconocido... Encóder Hiperface virgen sin formato de EEPROM" .

ns1:SistemaFeedbackHiperface a ns1:Sistema ;
    rdfs:label "Sistema de feedback Hiperface" ;
    ns1:textoExtracto "Error interno en la comunicación Hiperface" ;
    ns1:tieneComponente ns1:EncoderHiperface .

