@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation" ;
    ns1:textoExtracto "Fagor Automation" .

ns1:EncoderDigital a ns1:ComponenteElectrico ;
    rdfs:label "Encóder digital" ;
    ns1:activaAlarma ns1:Error_4674 ;
    ns1:textoExtracto "encóder digital"@es .

ns1:SistemaFeedbackSSI a ns1:Sistema ;
    rdfs:label "Sistema de feedback SSI" ;
    ns1:activaAlarma ns1:Error_4673 ;
    ns1:textoExtracto "feedback SSI"@es .

ns1:Error_4673 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4673: Fallo en acknowledge de feedback SSI" ;
    ns1:identificador "4673" ;
    ns1:textoExtracto "Error scknowledge feedback SSI. DETECCIÓN Durante el arranque del CNC o la ejecución. CAUSA Error de acknowledge en un feedback SSI. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error_4674 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4674: Fallo en lectura de parámetros de encóder digital" ;
    ns1:identificador "4674" ;
    ns1:textoExtracto "Error leyendo los parámetros del encóder digital. DETECCIÓN Durante el arranque del CNC. CAUSA Error durante la lectura de parámetros de" .

