@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BusMechatrolink a ns1:InterfazUsuario ;
    rdfs:label "Bus Mechatrolink" ;
    ns1:textoExtracto "La ejecución de un subcomando Mechatrolink desde el master a un determinado esclavo provoca una situación de warning en dicho dispositivo." .

ns1:DispositivoPwC a ns1:ComponenteElectrico ;
    rdfs:label "Dispositivo PwC" ;
    ns1:textoExtracto "Error en la actualización de SW de los dispositivos PwC conectados al bus." .

ns1:EncoderDigital a ns1:ComponenteElectrico ;
    rdfs:label "Encóder digital" ;
    ns1:textoExtracto "Error durante la lectura de parámetros de un encóder digital o los datos leídos no son correctos." .

ns1:Error4674 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4674: Error leyendo los parámetros del encóder digital" ;
    ns1:identificador "4674" ;
    ns1:mitigaRiesgo ns1:FagorAutomation ;
    ns1:textoExtracto "4674 Error leyendo los parámetros del encóder digital. DETECCIÓN Durante el arranque del CNC. CAUSA Error durante la lectura de parámetros de un encóder digital o los datos leídos no son correctos." .

ns1:Error4675 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4675: Encóder digital no soportado" ;
    ns1:identificador "4675" ;
    ns1:mitigaRiesgo ns1:FagorAutomation ;
    ns1:textoExtracto "4675 Encóder digital no soportado. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha detectado un encóder digital no soportado o con protocolo digital no soportado." .

ns1:Error4680 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4680: Error configurando referencia" ;
    ns1:identificador "4680" ;
    ns1:mitigaRiesgo ns1:FagorAutomation ;
    ns1:solucionaFallo ns1:Error4680_Solucion ;
    ns1:textoExtracto "4680 Error configurando referencia. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error interno durante la configuración de una referencia." .

ns1:Error4681 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4681: Error de comunicaciones con referencia" ;
    ns1:identificador "4681" ;
    ns1:mitigaRiesgo ns1:FagorAutomation ;
    ns1:solucionaFallo ns1:Error4681_Solucion ;
    ns1:textoExtracto "4681 Error de comunicaciones con referencia. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha producido un error de comunicación con una referencia." .

ns1:Error4682 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4682: Error de identificación de referencia" ;
    ns1:identificador "4682" ;
    ns1:mitigaRiesgo ns1:FagorAutomation ;
    ns1:solucionaFallo ns1:Error4682_Solucion ;
    ns1:textoExtracto "4682 Error de identificación de referencia. DETECCIÓN Durante el arranque del CNC. CAUSA Se ha detectado una referencia no soportada." .

ns1:Error4683 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4683: Error en la actualización de SW de los dispositivos PwC conectados al bus" ;
    ns1:identificador "4683" ;
    ns1:solucionaFallo ns1:Error4683_Solucion ;
    ns1:textoExtracto "4683 Error en la actualización de SW de los dispositivos PwC conectados al bus. DETECCIÓN Durante la ejecución. CAUSA La ejecución de un subcomando Mechatrolink desde el master a un determinado esclavo provoca una situación de warning en dicho dispositivo." .

ns1:Error4684 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 4684: SW de regulador asociado a la referencia no coincide con el tipo de motor conectado" ;
    ns1:identificador "4684" ;
    ns1:textoExtracto "4684 SW de regulador asociado a la referencia no coincide con el tipo de motor conectado." .

ns1:Motor a ns1:ComponenteElectrico ;
    rdfs:label "Motor" ;
    ns1:textoExtracto "SW de regulador asociado a la referencia no coincide con el tipo de motor conectado." .

ns1:Regulador a ns1:ComponenteElectrico ;
    rdfs:label "Regulador" ;
    ns1:textoExtracto "SW de regulador asociado a la referencia no coincide con el tipo de motor conectado." .

ns1:Error4680_Solucion a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de configuración de conexiones CNC" ;
    ns1:textoExtracto "Revisar la configuración de las conexiones del CNC y asegurarse que la referencia existe." .

ns1:Error4681_Solucion a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de configuración de conexiones CNC" ;
    ns1:textoExtracto "Revisar la configuración de las conexiones del CNC." .

ns1:Error4682_Solucion a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de configuración de conexiones CNC" ;
    ns1:textoExtracto "Revisar la configuración de las conexiones del CNC." .

ns1:Error4683_Solucion a ns1:TareaMantenimiento ;
    rdfs:label "Identificación de código de warning en manual del esclavo Mechatrolink" ;
    ns1:textoExtracto "Identificar el código del warning en el manual del esclavo Mechatrolink para obtener información más específica." .

ns1:FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation" ;
    ns1:textoExtracto "Póngase en contacto con Fagor Automation." .

