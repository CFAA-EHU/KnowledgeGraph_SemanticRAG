@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Regulador_Asociado a ns1:ComponenteElectrico ;
    ns1:controla ns1:Motor_Conectado ;
    ns1:textoExtracto "SW de regulador asociado a la referencia no coincide con el tipo de motor conectado."@es .

ns1:Warning_4684 a ns1:AvisoSeguridad ;
    rdfs:label "Warning 4684" ;
    ns1:documentadoEn ns1:Manual_Mechatrolink_Esclavo ;
    ns1:identificador "4684" ;
    ns1:textoExtracto "SW de regulador asociado a la referencia no coincide con el tipo de motor conectado."@es .

ns1:Manual_Mechatrolink_Esclavo a ns1:Manual ;
    ns1:textoExtracto "Identificar el código del warning en el manual del esclavo Mechatrolink para obtener información más específica."@es .

ns1:Motor_Conectado a ns1:ComponenteElectrico ;
    ns1:textoExtracto "tipo de motor conectado"@es .

