@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_InspeccionHerramienta a ns1:InterfazUsuario ;
    rdfs:label "Diagrama de inspección de herramienta"@es ;
    ns1:identificador "TOOL INSPECTION" ;
    ns1:textoExtracto "Diagrama de inspección de herramienta con bloques para: acceso tras STOP, ejecución MDI/MDA durante la inspección, reposición de ejes (al punto de interrupción o al inicio del bloque) y restauración del estado del husillo (M3/M4/M5/M19)."@es ;
    ns1:tieneComponente ns1:Boton_STOP_Inspeccion,
        ns1:Opcion_ReposicionEjes,
        ns1:Opcion_RestaurarHusillo .

ns1:InterfazUsuario_ModoAutomatico a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de selección/ejecución de programa (Modo Automático)"@es ;
    ns1:identificador "AUTOMATIC MODE - Select/Execute program" ;
    ns1:textoExtracto "Tira de softkeys para seleccionar y ejecutar programa (selección, inspección de herramienta, fin de simulación→ejecución, 'program being edited'). Se resaltan START/STOP/RESET y Single-block como estados con icono."@es ;
    ns1:tieneComponente ns1:Boton_RESET_Auto,
        ns1:Boton_START_Auto,
        ns1:Boton_STOP_Auto,
        ns1:Boton_SingleBlock .

ns1:InterfazUsuario_Simulacion a ns1:InterfazUsuario ;
    rdfs:label "Panel de simulación de programa"@es ;
    ns1:identificador "SIMULATED EXECUTION OF A PROGRAM" ;
    ns1:textoExtracto "Panel de opciones de simulación con iconos por tipo (trayectoria, movimiento de ejes, control de husillo, envío a PLC, paradas G04/M00/M01). Se muestran también modos (single block/continuous) y el flujo para arrancar, interrumpir y pasar de simulación a ejecución con reposición de ejes."@es ;
    ns1:tieneComponente ns1:Icono_Husillo,
        ns1:Icono_Trayectoria,
        ns1:Opcion_Continuous_Sim,
        ns1:Opcion_SingleBlock_Sim .

ns1:Boton_RESET_Auto a ns1:Componente ;
    rdfs:label "Boton RESET (Modo Automático)"@es ;
    ns1:textoExtracto "Se resaltan START/STOP/RESET."@es .

ns1:Boton_RESET_MDI a ns1:Componente ;
    rdfs:label "Boton RESET (Modo MDI/MDA)"@es ;
    ns1:textoExtracto "uso de teclas representadas (START/RESET)."@es .

ns1:Boton_START_Auto a ns1:Componente ;
    rdfs:label "Boton START (Modo Automático)"@es ;
    ns1:textoExtracto "Se resaltan START/STOP/RESET."@es .

ns1:Boton_START_MDI a ns1:Componente ;
    rdfs:label "Boton START (Modo MDI/MDA)"@es ;
    ns1:textoExtracto "uso de teclas representadas (START/RESET)."@es .

ns1:Boton_STOP_Auto a ns1:Componente ;
    rdfs:label "Boton STOP (Modo Automático)"@es ;
    ns1:textoExtracto "Se resaltan START/STOP/RESET."@es .

ns1:Boton_STOP_Inspeccion a ns1:Componente ;
    rdfs:label "Boton STOP (Inspección de Herramienta)"@es ;
    ns1:textoExtracto "acceso tras STOP [en inspección de herramienta]."@es .

ns1:Boton_SingleBlock a ns1:Componente ;
    rdfs:label "Boton Single-block (Modo Automático)"@es ;
    ns1:textoExtracto "Single-block como estados con icono."@es .

ns1:Icono_Husillo a ns1:Componente ;
    rdfs:label "Icono de control de husillo (Simulación)"@es ;
    ns1:textoExtracto "iconos por tipo (..., control de husillo, ...)."@es .

ns1:Icono_Trayectoria a ns1:Componente ;
    rdfs:label "Icono de trayectoria (Simulación)"@es ;
    ns1:textoExtracto "iconos por tipo (trayectoria, movimiento de ejes...)."@es .

ns1:InterfazUsuario_ModoMDI_MDA a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de calibración automática (MDI/MDA)"@es ;
    ns1:identificador "MDI/MDA MODE - Automatic calibration" ;
    ns1:textoExtracto "Esquema procedimental con pasos numerados para la calibración automática (selección de herramienta/offset, datos de calibración, START, actualización de tabla). La maquetación por bloques y uso de teclas representadas (START/RESET) ofrecen una direccionalidad clara sin gráficos de ejes; funciona como diagrama textual de la rutina de sondeo."@es ;
    ns1:tieneComponente ns1:Boton_RESET_MDI,
        ns1:Boton_START_MDI,
        ns1:Tabla_DatosCalibracion .

ns1:Opcion_Continuous_Sim a ns1:Componente ;
    rdfs:label "Opción Continuous (Simulación)"@es ;
    ns1:textoExtracto "modos (single block/continuous)."@es .

ns1:Opcion_ReposicionEjes a ns1:Componente ;
    rdfs:label "Opción de reposición de ejes"@es ;
    ns1:textoExtracto "reposición de ejes (al punto de interrupción o al inicio del bloque)."@es .

ns1:Opcion_RestaurarHusillo a ns1:Componente ;
    rdfs:label "Opción de restauración de husillo"@es ;
    ns1:textoExtracto "restauración del estado del husillo (M3/M4/M5/M19)."@es .

ns1:Opcion_SingleBlock_Sim a ns1:Componente ;
    rdfs:label "Opción Single Block (Simulación)"@es ;
    ns1:textoExtracto "modos (single block/continuous)."@es .

ns1:Tabla_DatosCalibracion a ns1:Tabla ;
    rdfs:label "Tabla de datos de calibración"@es ;
    ns1:documentadoEn ns1:InterfazUsuario_ModoMDI_MDA ;
    ns1:textoExtracto "actualización de tabla [en el contexto de calibración automática]."@es .

