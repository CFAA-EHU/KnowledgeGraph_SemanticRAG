@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_4702 a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad entre tipo de motor y control del regulador" ;
    ns1:identificador "4702" ;
    ns1:solucionaFallo ns1:SistemaControlMotores ;
    ns1:textoExtracto "no coincide con el tipo de motor conectado. DETECCIÓN Durante la puesta en marcha, asignación de conexiones y/o cambio en los tipos de motor o fuente RPS. CAUSA El tipo motor conectado a la referencia no coincide con el tipo de control del regulador asociado. SOLUCIÓN Validar la topología." .

ns1:Fallo_4703 a ns1:DiagnosticoFallo ;
    rdfs:label "Referencia de eje no encontrada" ;
    ns1:identificador "4703" ;
    ns1:solucionaFallo ns1:Eje_Mecanico ;
    ns1:textoExtracto "No se encuentra la referencia del eje. DETECCIÓN Durante la preparación de los datos de tiempo real. CAUSA No se ha definido correctamente la referencia del eje (identificador del nodo). SOLUCIÓN Revisar la definición de la referencia y el identificador del nodo." .

ns1:Fallo_4704 a ns1:DiagnosticoFallo ;
    rdfs:label "Feedback de eje no definido" ;
    ns1:identificador "4704" ;
    ns1:solucionaFallo ns1:Eje_Mecanico ;
    ns1:textoExtracto "No se encuentra el feedback del eje. DETECCIÓN Durante la preparación de los datos de tiempo real. CAUSA El feedback del eje no se ha definido correctamente (identificador del nodo). SOLUCIÓN Revisar la definición de la referencia y el identificador del nodo." .

ns1:Fallo_4705 a ns1:DiagnosticoFallo ;
    rdfs:label "Variable de bus no encontrada" ;
    ns1:identificador "4705" ;
    ns1:solucionaFallo ns1:VariableBus ;
    ns1:textoExtracto "No se encuentra una variable de bus. DETECCIÓN Durante la preparación de los datos de tiempo real. CAUSA La variable de bus no se ha definido correctamente." .

ns1:Nodo_Comunicacion a ns1:ComponenteElectrico ;
    rdfs:label "Nodo de comunicación" ;
    ns1:textoExtracto "identificador del nodo" .

ns1:Regulador_Generico a ns1:ComponenteElectrico ;
    rdfs:label "Regulador de motor" ;
    ns1:textoExtracto "tipo de control del regulador asociado" .

ns1:VariableBus a ns1:Parametro ;
    rdfs:label "Variable de bus de tiempo real" ;
    ns1:monitoreaParametro ns1:SistemaControlMotores ;
    ns1:textoExtracto "variable de bus" .

ns1:Eje_Mecanico a ns1:ComponenteMecanico ;
    rdfs:label "Eje mecánico con referencia de nodo" ;
    ns1:textoExtracto "referencia del eje (identificador del nodo)" .

ns1:SistemaControlMotores a ns1:Sistema ;
    rdfs:label "Sistema de control de motores y reguladores" ;
    ns1:textoExtracto "tipo de motor conectado a la referencia no coincide con el tipo de control del regulador asociado" ;
    ns1:tieneComponente ns1:Regulador_Generico .

