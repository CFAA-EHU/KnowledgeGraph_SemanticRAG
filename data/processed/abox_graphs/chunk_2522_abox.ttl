@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaComunicacionNodos a ns1:Sistema ;
    rdfs:label "Sistema de comunicación entre nodos del CNC"@es ;
    ns1:requiereMantenimiento ns1:TareaVerificacionConexionesFisicas_4709 ;
    ns1:textoExtracto "La conexión entre nodos no es correcta."@es .

ns1:FalloComunicacionNodo_4709 a ns1:DiagnosticoFallo ;
    rdfs:label "Problema de comunicación entre nodos (4709)"@es ;
    ns1:identificador "4709" ;
    ns1:textoExtracto "El nodo tiene problemas de comunicación con el nodo anterior. DETECCIÓN Durante el arranque del CNC. CAUSA La conexión entre nodos no es correcta."@es .

ns1:TareaVerificacionConexionesFisicas_4709 a ns1:TareaMantenimiento ;
    rdfs:label "Verificación de conexiones físicas entre nodos"@es ;
    ns1:solucionaFallo ns1:FalloComunicacionNodo_4709 ;
    ns1:textoExtracto "SOLUCIÓN Comprobar conexiones físicas."@es .

