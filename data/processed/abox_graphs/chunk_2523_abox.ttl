@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_5000 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de PLC: No existe temporizador" ;
    ns1:identificador "5000" ;
    ns1:textoExtracto "5000 'Error de PLC: No existe temporizador' DETECCIÓN Procesos de lectura de los datos de temporizadores de PLC. CAUSA Petición de lectura de un temporizador que no existe. SOLUCIÓN Comprobar el número del temporizador; temporizadores válidos, T1 a T256." .

ns1:Error_5001 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de PLC: No existe contador" ;
    ns1:identificador "5001" ;
    ns1:textoExtracto "5001 'Error de PLC: No existe contador' DETECCIÓN Procesos de lectura de los datos de contadores de PLC. CAUSA Petición de lectura de un contador que no existe. SOLUCIÓN Comprobar el número del contador; contadores válidos, T1 a T256." .

ns1:Error_5002 a ns1:DiagnosticoFallo ;
    rdfs:label "CNCRD: Variable no identificada" ;
    ns1:identificador "5002" ;
    ns1:textoExtracto "5002 'CNCRD: Variable no identificada' DETECCIÓN Al ejecutar una instrucción CNCRD. CAUSA La variable no existe. Si el error se produce durante el arranque, es posible que el PLC esté intentando ejecutar una instrucción CNCRD antes de que la marca SERCOSRDY esté activa. SOLUCIÓN Verificar la sintaxis de la variable. Si el error se produce durante el arranque, condicionar la lectura de la variable a que la marca SERCOSRDY esté activa." .

ns1:Error_5003 a ns1:DiagnosticoFallo ;
    rdfs:label "CNCWR: Variable no identificada" ;
    ns1:identificador "5003" ;
    ns1:textoExtracto "5003 'CNCWR: Variable no identificada' DETECCIÓN Al ejecutar una instrucción CNCWR. CAUSA La variable no existe. SOLUCIÓN Verificar la sintaxis de la variable." .

ns1:Error_5004 a ns1:DiagnosticoFallo ;
    rdfs:label "Variable sin permiso de lectura para PLC" ;
    ns1:identificador "5004" ;
    ns1:textoExtracto "5004 'Variable sin permiso de lectura para PLC' DETECCIÓN Al ejecutar una instrucción CNCRD. CAUSA Lectura de una variable que no tiene permiso de lectura desde el PLC. SOLUCIÓN Comprobar los permisos de la variable." .

ns1:Error_5005 a ns1:DiagnosticoFallo ;
    rdfs:label "Variable sin permiso de escritura para PLC" ;
    ns1:identificador "5005" ;
    ns1:textoExtracto "5005 'Variable sin permiso de escritura para PLC' DETECCIÓN Al ejecutar una instrucción CNCWR. CAUSA Escritura de una variable que no tiene permiso de escritura desde el PLC. SOLUCIÓN Comprobar los permisos de la variable." .

ns1:Error_5006 a ns1:DiagnosticoFallo ;
    rdfs:label "Escritura de variable desde PLC fuera de rango" ;
    ns1:identificador "5006" ;
    ns1:textoExtracto "5006 'Escritura de variable desde PLC fuera de rango' DETECCIÓN Al ejecutar una instrucción CNCWR. CAUSA El valor asignado a la variable no es válido. SOLUCIÓN Verificar la sintaxis de la variable y los valores válidos." .

ns1:Marca_SERCOSRDY a ns1:Parametro ;
    rdfs:label "SERCOSRDY" ;
    ns1:textoExtracto "marca SERCOSRDY" ;
    ns1:valor "activa/inactiva" .

