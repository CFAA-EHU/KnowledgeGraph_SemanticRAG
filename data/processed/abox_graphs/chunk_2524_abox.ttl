@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Instruccion_CNCWR a ns1:InterfazUsuario ;
    rdfs:label "Instrucción CNCWR"@es ;
    ns1:activaAlarma ns1:Error_5006,
        ns1:Error_5007 ;
    ns1:textoExtracto "Al ejecutar una instrucción CNCWR."@es .

ns1:Error_5006 a ns1:DiagnosticoFallo ;
    rdfs:label "Escritura de variable desde PLC fuera de rango"@es ;
    ns1:identificador "5006" ;
    ns1:solucionaFallo ns1:VerificarSintaxisYValoresValidosDeVariable ;
    ns1:textoExtracto "5006 'Escritura de variable desde PLC fuera de rango' [...] El valor asignado a la variable no es válido."@es .

ns1:Error_5007 a ns1:DiagnosticoFallo ;
    rdfs:label "Error sintáctico en escritura de variable desde PLC"@es ;
    ns1:identificador "5007" ;
    ns1:solucionaFallo ns1:VerificarSintaxisYPermisosDeVariable ;
    ns1:textoExtracto "5007 'Error sintáctico en la escritura de variable desde PLC' [...] La variable no existe o no tiene permiso de escritura desde el PLC."@es .

ns1:VerificarSintaxisYPermisosDeVariable a ns1:AccionProhibida ;
    rdfs:label "Verificar sintaxis y permisos de variable"@es ;
    ns1:textoExtracto "SOLUCIÓN Verificar la sintaxis y los permisos de la variable."@es .

ns1:VerificarSintaxisYValoresValidosDeVariable a ns1:AccionProhibida ;
    rdfs:label "Verificar sintaxis y valores válidos de variable"@es ;
    ns1:textoExtracto "SOLUCIÓN Verificar la sintaxis de la variable y los valores válidos."@es .

