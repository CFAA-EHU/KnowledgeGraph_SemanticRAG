@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_5008 a ns1:Alarma ;
    rdfs:label "Error 5008: Escritura de variable fallida"@es ;
    ns1:identificador "5008" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_5008 ;
    ns1:textoExtracto "'La escritura de la variable desde PLC no pudo realizarse' DETECCIÓN Al ejecutar una instrucción CNCWR. CAUSA Escritura de un parámetro aritmético global o local que no existe. SOLUCIÓN Comprobar la parametrización de los parámetros globales y locales, así como el programa de PLC."@es .

ns1:Alarma_5009 a ns1:Alarma ;
    rdfs:label "Error 5009: Lectura de variable fallida"@es ;
    ns1:identificador "5009" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_5009 ;
    ns1:textoExtracto "'Error sintáctico en la lectura de variable desde PLC' DETECCIÓN Al ejecutar una instrucción CNCRD. CAUSA La variable no existe o no tiene permiso de lectura desde el PLC. SOLUCIÓN Verificar la sintaxis y los permisos de la variable."@es .

ns1:Alarma_5010 a ns1:Alarma ;
    rdfs:label "Error 5010: División por cero"@es ;
    ns1:identificador "5010" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_5010 ;
    ns1:textoExtracto "'División por cero en el PLC' DETECCIÓN Al ejecutar una instrucción DVS o MDS. CAUSA El denominador de una operación DVS o MDS es 0. SOLUCIÓN Revisar el programa PLC. No realizar divisiones por 0."@es .

ns1:Alarma_5013 a ns1:Alarma ;
    rdfs:label "Error 5013: Fallo en entradas digitales"@es ;
    ns1:identificador "5013" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_5013 ;
    ns1:monitoreaParametro ns1:Parametro_NDIMOD ;
    ns1:textoExtracto "'Error en la lectura de entradas digitales del PLC' DETECCIÓN Al leer las entradas digitales del PLC. CAUSA Fallo en la lectura de las entradas digitales remotas de PLC. SOLUCIÓN Revisar tabla de configuración de I/Os digitales (parámetro NDIMOD) y comprobar la integridad del bus."@es .

ns1:Alarma_5014 a ns1:Alarma ;
    rdfs:label "Error 5014: Fallo en salidas digitales"@es ;
    ns1:identificador "5014" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_5014 ;
    ns1:monitoreaParametro ns1:Parametro_NDOMOD,
        ns1:Parametro_PLCFREQ ;
    ns1:textoExtracto "'Error en la escritura de salidas digitales del PLC' DETECCIÓN Al escribir las salidas digitales del PLC. CAUSA Fallo en la escritura de las salidas digitales remotas de PLC. La tabla de configuración de las I/Os digitales no es válida (parámetro NDOMOD) o el PLC ha recibido una petición de escritura antes de finalizar la anterior. SOLUCIÓN Revisar tabla de configuración de I/Os digitales (parámetro NDOMOD), comprobar la integridad del bus o aumentar el tiempo de ciclo en el parámetro PLCFREQ."@es .

ns1:DiagnosticoFallo_5008 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en escritura de variable CNCWR"@es ;
    ns1:solucionaFallo ns1:Alarma_5008 ;
    ns1:textoExtracto "CAUSA Escritura de un parámetro aritmético global o local que no existe. SOLUCIÓN Comprobar la parametrización de los parámetros globales y locales, así como el programa de PLC."@es .

ns1:DiagnosticoFallo_5009 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en lectura de variable CNCRD"@es ;
    ns1:solucionaFallo ns1:Alarma_5009 ;
    ns1:textoExtracto "CAUSA La variable no existe o no tiene permiso de lectura desde el PLC. SOLUCIÓN Verificar la sintaxis y los permisos de la variable."@es .

ns1:DiagnosticoFallo_5010 a ns1:DiagnosticoFallo ;
    rdfs:label "División por cero en instrucción DVS/MDS"@es ;
    ns1:solucionaFallo ns1:Alarma_5010 ;
    ns1:textoExtracto "CAUSA El denominador de una operación DVS o MDS es 0. SOLUCIÓN Revisar el programa PLC. No realizar divisiones por 0."@es .

ns1:DiagnosticoFallo_5013 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en lectura de I/Os digitales remotas"@es ;
    ns1:solucionaFallo ns1:Alarma_5013 ;
    ns1:textoExtracto "CAUSA Fallo en la lectura de las entradas digitales remotas de PLC. SOLUCIÓN Revisar tabla de configuración de I/Os digitales (parámetro NDIMOD) y comprobar la integridad del bus."@es .

ns1:DiagnosticoFallo_5014 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en escritura de I/Os digitales remotas"@es ;
    ns1:solucionaFallo ns1:Alarma_5014 ;
    ns1:textoExtracto "CAUSA La tabla de configuración de las I/Os digitales no es válida (parámetro NDOMOD) o el PLC ha recibido una petición de escritura antes de finalizar la anterior. SOLUCIÓN Revisar tabla de configuración de I/Os digitales (parámetro NDOMOD), comprobar la integridad del bus o aumentar el tiempo de ciclo en el parámetro PLCFREQ."@es .

ns1:Parametro_NDIMOD a ns1:Parametro ;
    rdfs:label "Parámetro NDIMOD (configuración I/Os digitales)"@es ;
    ns1:identificador "NDIMOD" ;
    ns1:textoExtracto "tabla de configuración de I/Os digitales (parámetro NDIMOD)"@es .

ns1:Parametro_NDOMOD a ns1:Parametro ;
    rdfs:label "Parámetro NDOMOD (configuración I/Os digitales)"@es ;
    ns1:identificador "NDOMOD" ;
    ns1:textoExtracto "tabla de configuración de las I/Os digitales (parámetro NDOMOD)"@es .

ns1:Parametro_PLCFREQ a ns1:Parametro ;
    rdfs:label "Parámetro PLCFREQ (tiempo de ciclo PLC)"@es ;
    ns1:identificador "PLCFREQ" ;
    ns1:textoExtracto "aumentar el tiempo de ciclo en el parámetro PLCFREQ"@es .

