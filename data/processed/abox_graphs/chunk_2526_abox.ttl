@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Instruccion_CNCRD a ns1:AccionProhibida ;
    rdfs:label "Instrucción CNCRD (lectura de parámetros)" ;
    ns1:activaAlarma ns1:Error_5015 ;
    ns1:textoExtracto "Al ejecutar una instrucción CNCRD" .

ns1:Parametro_NDOMOD a ns1:Parametro ;
    rdfs:label "Parámetro NDOMOD (configuración de I/Os digitales)" ;
    ns1:identificador "NDOMOD" ;
    ns1:textoExtracto "tabla de configuración de I/Os digitales (parámetro NDOMOD)" .

ns1:Parametro_PLCFREQ a ns1:Parametro ;
    rdfs:label "Parámetro PLCFREQ (tiempo de ciclo)" ;
    ns1:identificador "PLCFREQ" ;
    ns1:textoExtracto "aumentar el tiempo de ciclo en el parámetro PLCFREQ" .

ns1:Tabla_ConfiguracionIO a ns1:Tabla ;
    rdfs:label "Tabla de configuración de I/Os digitales" ;
    ns1:documentadoEn ns1:Error_5015 ;
    ns1:textoExtracto "Revisar tabla de configuración de I/Os digitales" .

ns1:Error_5015 a ns1:AvisoSeguridad ;
    rdfs:label "Error 5015: Fallo en lectura de variable desde PLC" ;
    ns1:identificador "5015" ;
    ns1:textoExtracto "'La lectura de la variable desde PLC no pudo realizarse'" .

