@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_5015 a ns1:AvisoSeguridad ;
    rdfs:label "Error 5015: Lectura de variable desde PLC"@es ;
    ns1:identificador "5015" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_5015 ;
    ns1:textoExtracto "'La lectura de la variable desde PLC no pudo realizarse' DETECCIÓN Al ejecutar una instrucción CNCRD. CAUSA Lectura de un parámetro aritmético global o local que no existe. SOLUCIÓN Comprobar la parametrización de los parámetros globales y locales, así como el programa de PLC."@es .

ns1:AvisoSeguridad_5016 a ns1:AvisoSeguridad ;
    rdfs:label "Error 5016: Valor de lectura fuera de rango"@es ;
    ns1:identificador "5016" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_5016 ;
    ns1:textoExtracto "'Valor de lectura fuera de rango' DETECCIÓN Al ejecutar una instrucción CNCRD. CAUSA Dato leído fuera de rango. SOLUCIÓN Comprobar la sintaxis de la instrucción."@es .

ns1:AvisoSeguridad_5017 a ns1:AvisoSeguridad ;
    rdfs:label "Error 5017: Bloque nulo de CNCEX"@es ;
    ns1:identificador "5017" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_5017 ;
    ns1:textoExtracto "'Bloque nulo de CNCEX' DETECCIÓN Al ejecutar una instrucción CNCEX. CAUSA El bloque programado en la instrucción CNCEX es nulo o la canal programado no está disponible. SOLUCIÓN Revisar el bloque a ejecutar y el estado del canal."@es .

ns1:AvisoSeguridad_5018 a ns1:AvisoSeguridad ;
    rdfs:label "Error 5018: Marca de comunicación activa"@es ;
    ns1:identificador "5018" ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_5018 ;
    ns1:textoExtracto "'No se ha ejecutado CNCEX por estar la marca de comunicación a \"1\"' DETECCIÓN Al ejecutar una instrucción CNCEX."@es .

ns1:DiagnosticoFallo_5015 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en lectura de parámetro CNCRD"@es ;
    ns1:solucionaFallo ns1:Parametro_GlobalLocal_Desconocido ;
    ns1:textoExtracto "Lectura de un parámetro aritmético global o local que no existe."@es .

ns1:DiagnosticoFallo_5016 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en rango de dato CNCRD"@es ;
    ns1:monitoreaParametro ns1:Parametro_FueraRango ;
    ns1:textoExtracto "Dato leído fuera de rango."@es .

ns1:DiagnosticoFallo_5017 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en ejecución CNCEX"@es ;
    ns1:textoExtracto "El bloque programado en la instrucción CNCEX es nulo o la canal programado no está disponible."@es .

ns1:DiagnosticoFallo_5018 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo por marca de comunicación activa"@es ;
    ns1:textoExtracto "No se ha ejecutado CNCEX por estar la marca de comunicación a \"1\"."@es .

ns1:Parametro_FueraRango a ns1:Parametro ;
    rdfs:label "Parámetro con valor fuera de rango"@es ;
    ns1:textoExtracto "Valor de lectura fuera de rango"@es .

ns1:Parametro_GlobalLocal_Desconocido a ns1:Parametro ;
    rdfs:label "Parámetro aritmético global/local no definido"@es ;
    ns1:textoExtracto "parámetro aritmético global o local que no existe"@es .

