@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC"@es ;
    ns1:textoExtracto "parámetros máquina"@es ;
    ns1:tieneComponente ns1:Sistema_CNCEX .

ns1:Alarma_5020 a ns1:Alarma ;
    rdfs:label "CNCEX: Ejecución no finalizada"@es ;
    ns1:identificador "5020" ;
    ns1:monitoreaParametro ns1:Parametro_Canal_CNCEX ;
    ns1:textoExtracto "5020 'CNCEX: Ejecución no finalizada' DETECCIÓN Al ejecutar una instrucción CNCEX. CAUSA La instrucción CNCEX no puede ejecutar el bloque en el canal indicado."@es .

ns1:Alarma_5021 a ns1:Alarma ;
    rdfs:label "CNCEX: El canal indicado no es de PLC"@es ;
    ns1:identificador "5021" ;
    ns1:monitoreaParametro ns1:Parametro_CHTYPE ;
    ns1:textoExtracto "5021 'CNCEX: El canal indicado no es de PLC' DETECCIÓN Al ejecutar una instrucción CNCEX. CAUSA El canal programado en la instrucción CNCEX no es de PLC."@es .

ns1:Sistema_CNCEX a ns1:Sistema ;
    rdfs:label "Sistema de ejecución CNCEX"@es ;
    ns1:activaAlarma ns1:Alarma_5020,
        ns1:Alarma_5021 ;
    ns1:monitoreaParametro ns1:Parametro_CHTYPE,
        ns1:Parametro_Canal_CNCEX ;
    ns1:textoExtracto "instrucción CNCEX"@es .

ns1:Parametro_CHTYPE a ns1:Parametro ;
    rdfs:label "Tipo de canal (parámetro CHTYPE)"@es ;
    ns1:identificador "CHTYPE" ;
    ns1:textoExtracto "Revisar en los parámetros máquina el tipo de canal (parámetro CHTYPE)."@es ;
    ns1:valor "tipo_canal" .

ns1:Parametro_Canal_CNCEX a ns1:Parametro ;
    rdfs:label "Canal programado en instrucción CNCEX"@es ;
    ns1:textoExtracto "el bloque en el canal indicado"@es ;
    ns1:valor "canal_CNCEX" .

