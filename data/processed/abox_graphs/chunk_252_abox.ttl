@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorteSeccional a ns1:Esquema ;
    rdfs:label "Corte seccional del taladro con broca descendiendo desde un plano de referencia 'Z'" ;
    ns1:textoExtracto "Corte seccional del taladro con broca descendiendo desde un plano de referencia 'Z', mostrando dos viñetas (G90/G91) con flechas verticales que indican profundidad 'I' y permanencia 'K' al fondo. El sombreado de la pieza y las cotas ayudan a entender el avance y el retorno del husillo según sistema absoluto o incremental." .

ns1:EsquemaTaladrado a ns1:Esquema ;
    rdfs:label "Dos esquemas de taladrado a pecks con pasos 'B/H', plano de referencia 'Z' y retorno rápido (G0)" ;
    ns1:textoExtracto "Dos esquemas de taladrado a pecks con pasos 'B/H', plano de referencia 'Z' y retorno rápido (G0). Flechas segmentadas representan pecks sucesivos; el texto lateral ancla parámetros (R, L, J) y la geometría ilustra la retirada periódica para evacuar viruta." .

ns1:HojaReferencia a ns1:Tabla ;
    rdfs:label "Hoja de referencia con iconos de acciones sobre tablas de orígenes y utillajes" ;
    ns1:textoExtracto "Hoja de referencia con iconos de acciones sobre tablas de orígenes y utillajes: cambio de unidades, inicializar, buscar, ver otros canales, filtrar ejes, guardar/restaurar y imprimir. Los bloques explican el significado de PLC offset vs absolute zero offsets, usando tipografía y viñetas como elementos visuales para separar funciones y estados. ( Se evita describir matrices tabulares)." .

ns1:Softkey a ns1:Alarma ;
    rdfs:label "Softkey" ;
    ns1:textoExtracto "Las softkeys actúan como nodos de decisión; la jerarquía visual guía la recuperación del estado antes de reanudar." .

