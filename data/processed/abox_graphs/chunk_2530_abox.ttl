@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Almacen a ns1:Componente ;
    rdfs:label "almacén" ;
    ns1:textoExtracto "Comando CNCRD de variables de herramientas que no se encuentran en el almacén." .

ns1:ComandoCNCRD a ns1:ComponenteElectrico ;
    rdfs:label "CNCRD" ;
    ns1:textoExtracto "Comando CNCRD y CNCWR de variables asíncronas" .

ns1:ComandoCNCRDHerramientas a ns1:ComponenteElectrico ;
    rdfs:label "CNCRD de variables de herramientas" ;
    ns1:textoExtracto "• Comando CNCRD de variables de herramientas que no se encuentran en el almacén." .

ns1:ComandoCNCWR a ns1:ComponenteElectrico ;
    rdfs:label "CNCWR" ;
    ns1:textoExtracto "Comando CNCRD y CNCWR de variables asíncronas" .

ns1:ComandoCNCWRHerramientas a ns1:ComponenteElectrico ;
    rdfs:label "CNCWR de variables de herramientas" ;
    ns1:textoExtracto "• Comando CNCWR de variables de herramientas." .

ns1:Error5022 a ns1:DiagnosticoFallo ;
    rdfs:label "5022 'PLC:Demasiados CNCRD y CNCWR de variables asíncronas'" ;
    ns1:textoExtracto "5022 'PLC:Demasiados CNCRD y CNCWR de variables asíncronas'" .

ns1:InstruccionCNCEX a ns1:ComponenteElectrico ;
    rdfs:label "CNCEX" ;
    ns1:textoExtracto "El canal programado en la instrucción CNCEX no es de PLC." .

ns1:ParametroCHTYPE a ns1:Parametro ;
    rdfs:label "CHTYPE" ;
    ns1:textoExtracto "Revisar en los parámetros máquina el tipo de canal (parámetro CHTYPE)." .

