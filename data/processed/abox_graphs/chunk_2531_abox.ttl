@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_5023 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 5023: Error en la lectura de entradas digitales locales" ;
    ns1:identificador "5023" ;
    ns1:solucionaFallo ns1:ContactoConSoporteTecnicoDeFagorAutomation,
        ns1:RevisionDeInstalacionDeAplicacionYDriversDelCNC ;
    ns1:textoExtracto "5023 'Error en la lectura de entradas digitales locales' DETECCIÓN Error en la lectura de entradas digitales locales. CAUSA Fallo en la lectura de las entradas digitales locales de PLC." .

ns1:Error_5024 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 5024: Error en la escritura de salidas digitales locales" ;
    ns1:identificador "5024" ;
    ns1:solucionaFallo ns1:ContactoConSoporteTecnicoDeFagorAutomation,
        ns1:RevisionDeInstalacionDeAplicacionYDriversDelCNC ;
    ns1:textoExtracto "5024 'Error en la escritura de salidas digitales locales' DETECCIÓN Error en la escritura de salidas digitales locales. CAUSA Fallo en la escritura de las salidas digitales locales de PLC." .

ns1:Error_5025 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 5025: Contador de PLC deshabilitado" ;
    ns1:identificador "5025" ;
    ns1:solucionaFallo ns1:RevisionDeManiobraDelPLCParaEvitarPeticionesAsincronas ;
    ns1:textoExtracto "5025 'Contador de PLC deshabilitado' DETECCIÓN Durante el arranque del CNC. CAUSA El contador está deshabilitado, desde el programa de PLC o desde monitorización." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC con controlador Fagor Automation" ;
    ns1:documentadoEn ns1:DocumentacionDeErrores50235025DelSistemaCNC ;
    ns1:textoExtracto "CNC con PLC y aplicación controlada por Fagor Automation" ;
    ns1:tieneComponente ns1:PLC_CNC .

ns1:ContadorDePLC a ns1:Parametro ;
    rdfs:label "Contador de PLC" ;
    ns1:textoExtracto "El contador está deshabilitado, desde el programa de PLC o desde monitorización." .

ns1:DocumentacionDeErrores50235025DelSistemaCNC a ns1:DiagnosticoFallo ;
    rdfs:label "Documentación de errores 5023-5025 del sistema CNC" ;
    ns1:textoExtracto "Errores 5023, 5024 y 5025 relacionados con el PLC del CNC." .

ns1:EntradasDigitalesLocalesDelPLC a ns1:Parametro ;
    rdfs:label "Entradas digitales locales del PLC" ;
    ns1:textoExtracto "entradas digitales locales de PLC" .

ns1:PLC_CNC a ns1:ComponenteElectrico ;
    rdfs:label "PLC del sistema CNC" ;
    ns1:monitoreaParametro ns1:ContadorDePLC,
        ns1:EntradasDigitalesLocalesDelPLC,
        ns1:SalidasDigitalesLocalesDelPLC ;
    ns1:textoExtracto "Fallo en la lectura/escritura de las entradas/salidas digitales locales de PLC." .

ns1:RevisionDeManiobraDelPLCParaEvitarPeticionesAsincronas a ns1:AccionProhibida ;
    rdfs:label "Revisión de maniobra del PLC para evitar peticiones asíncronas" ;
    ns1:textoExtracto "Para eliminar el error, revisar la maniobra del PLC para que no sucedan tantas peticiones asíncronas a la vez." .

ns1:SalidasDigitalesLocalesDelPLC a ns1:Parametro ;
    rdfs:label "Salidas digitales locales del PLC" ;
    ns1:textoExtracto "salidas digitales locales de PLC" .

ns1:ContactoConSoporteTecnicoDeFagorAutomation a ns1:AvisoSeguridad ;
    rdfs:label "Contacto con soporte técnico de Fagor Automation" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:RevisionDeInstalacionDeAplicacionYDriversDelCNC a ns1:AccionProhibida ;
    rdfs:label "Revisión de instalación de aplicación y drivers del CNC" ;
    ns1:textoExtracto "Revisar la instalación de la aplicación y los drivers del CNC." .

