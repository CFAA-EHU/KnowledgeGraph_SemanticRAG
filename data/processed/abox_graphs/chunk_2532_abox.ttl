@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorVariableCNCWR a ns1:DiagnosticoFallo ;
    rdfs:label "Error CNCWR: Variable con valor no permitido" ;
    ns1:identificador "5026" ;
    ns1:monitoreaParametro ns1:ParametroCNCWR_ValorCero ;
    ns1:textoExtracto "5026 'CNCWR:La variable únicamente admite el valor '0'' DETECCIÓN Durante la ejecución de comandos CNCWR. CAUSA El PLC ha intentado escribir un valor diferente de 0 en una variable" .

ns1:FalloContadorDeshabilitado a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Contador deshabilitado" ;
    ns1:solucionaFallo ns1:AccionHabilitacionContador ;
    ns1:textoExtracto "CAUSA El contador está deshabilitado, desde el programa de PLC o desde monitorización. SOLUCIÓN Tras este aviso, el PLC fuerza la habilitación del contador (CEN = 1) de forma automática." .

ns1:AccionHabilitacionContador a ns1:AccionProhibida ;
    rdfs:label "Habilitación forzada del contador (CEN = 1)" ;
    ns1:textoExtracto "el PLC fuerza la habilitación del contador (CEN = 1) de forma automática" .

ns1:ParametroCNCWR_ValorCero a ns1:Parametro ;
    rdfs:label "Parámetro CNCWR (valor permitido: 0)" ;
    ns1:textoExtracto "La variable únicamente admite el valor '0'" ;
    ns1:valor "0" .

