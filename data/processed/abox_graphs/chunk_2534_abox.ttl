@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CanalInexistente a ns1:Parametro ;
    rdfs:label "Canal inexistente"@es ;
    ns1:monitoreaParametro ns1:ModuloRemoto ;
    ns1:textoExtracto "Algún módulo remoto está utilizando un canal que no existe."@es .

ns1:Fallo_5033 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la configuración del router de recursos remotos"@es ;
    ns1:identificador "5033" ;
    ns1:textoExtracto "5033 Error en la configuración del router de recursos remotos. DETECCIÓN Durante el arranque del sistema. CAUSA Error a la hora de configurar los módulos remotos. Algún módulo remoto está utilizando un canal que no existe."@es .

ns1:Fallo_ConfiguracionModulosRemotos a ns1:DiagnosticoFallo ;
    rdfs:label "Error en configuración de módulos remotos"@es ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA Error a la hora de configurar los módulos remotos. El orden de los comandos de inicialización del router de recursos no es correcto. SOLUCIÓN Revisar la configuración de los módulos remotos."@es .

ns1:Sistema_Arranque a ns1:Sistema ;
    rdfs:label "Sistema de arranque"@es ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema."@es ;
    ns1:tieneComponente ns1:RouterRecursos .

ns1:ModuloRemoto a ns1:ComponenteElectrico ;
    rdfs:label "Módulo remoto"@es ;
    ns1:textoExtracto "Error a la hora de configurar los módulos remotos. Algún módulo remoto está utilizando un canal que no existe."@es .

ns1:RouterRecursos a ns1:ComponenteElectrico ;
    rdfs:label "Router de recursos"@es ;
    ns1:textoExtracto "El orden de los comandos de inicialización del router de recursos no es correcto."@es .

