@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error5034 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de parametrización de recurso remoto (5034)" ;
    ns1:identificador "5034" ;
    ns1:solucionaFallo ns1:ModuloRemoto ;
    ns1:textoExtracto "Error en la parametrización de algún recurso remoto. DETECCIÓN Durante el arranque del sistema. CAUSA Error a la hora de configurar los módulos remotos. Algún parámetro de los recursos remotos no es correcto. SOLUCIÓN Revisar la configuración de los módulos remotos." .

ns1:Error5035 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de circuito abierto en salida analógica remota (5035)" ;
    ns1:identificador "5035" ;
    ns1:solucionaFallo ns1:SalidaAnalogicaRemota ;
    ns1:textoExtracto "Error de circuito abierto en una salida analógica remota. DETECCIÓN Durante el funcionamiento del PLC. CAUSA Se ha abierto el circuito conectado a una salida analógica remota. SOLUCIÓN Revisar el conexionado de la salida analógica remota." .

ns1:Error5036 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de cortocircuito en salida analógica remota (5036)" ;
    ns1:identificador "5036" ;
    ns1:solucionaFallo ns1:SalidaAnalogicaRemota ;
    ns1:textoExtracto "Error de corto circuito en una salida analógica remota. DETECCIÓN Durante el funcionamiento del PLC. CAUSA Se ha producido un cortocircuito en una salida analógica remota. SOLUCIÓN Revisar el conexionado de la salida analógica remota." .

ns1:Error5037 a ns1:DiagnosticoFallo ;
    rdfs:label "Configuración incorrecta de salida analógica remota (5037)" ;
    ns1:identificador "5037" ;
    ns1:solucionaFallo ns1:SalidaAnalogicaRemota ;
    ns1:textoExtracto "Una salida analógica remota esta configurada incorrectamente. DETECCIÓN Durante el funcionamiento del PLC. CAUSA La configuración de una salida analógica remota no es correcta. SOLUCIÓN Revisar configuración de la salida analógica remota." .

ns1:Error5038 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de alimentación en salida analógica remota (5038)" ;
    ns1:identificador "5038" ;
    ns1:solucionaFallo ns1:SalidaAnalogicaRemota ;
    ns1:textoExtracto "Una salida analógica remota ha detectado un error de alimentación. DETECCIÓN Durante el funcionamiento del PLC. CAUSA La alimentación de la salida analógica remota no es correcta. SOLUCIÓN Revisar la alimentación de la salida analógica remota." .

ns1:Error5039 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en módulo de salidas analógicas remotas (5039)" ;
    ns1:identificador "5039" ;
    ns1:solucionaFallo ns1:ModuloRemoto ;
    ns1:textoExtracto "Una salida analógica remota ha detectado un error en el módulo. DETECCIÓN Durante el funcionamiento del PLC. CAUSA El módulo remoto de salidas analógicas no funciona correctamente. SOLUCIÓN Revisar módulo remoto." .

ns1:Error5040 a ns1:DiagnosticoFallo ;
    rdfs:label "Error desconocido en salida analógica remota (5040)" ;
    ns1:identificador "5040" ;
    ns1:textoExtracto "Una salida analógica remota ha detectado un error desconocido. DETECCIÓN Durante el funcionamiento del PLC." .

ns1:ErrorConfiguracionModulosRemotos a ns1:DiagnosticoFallo ;
    rdfs:label "Error de configuración de módulos remotos (canal inexistente)" ;
    ns1:identificador "5034-base" ;
    ns1:solucionaFallo ns1:ModuloRemoto ;
    ns1:textoExtracto "Error a la hora de configurar los módulos remotos. Algún módulo remoto está utilizando un canal que no existe. DETECCIÓN Durante el arranque del sistema. SOLUCIÓN Revisar la configuración de los módulos remotos." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC con módulos remotos" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema... Durante el funcionamiento del PLC." .

ns1:ModuloRemoto a ns1:ComponenteElectrico ;
    rdfs:label "Módulo remoto de sistema PLC" ;
    ns1:compuestoPor ns1:SistemaPLC ;
    ns1:textoExtracto "módulo remoto... módulo remoto de salidas analógicas" ;
    ns1:tieneComponente ns1:SalidaAnalogicaRemota .

ns1:SalidaAnalogicaRemota a ns1:ComponenteElectrico ;
    rdfs:label "Salida analógica remota" ;
    ns1:compuestoPor ns1:ModuloRemoto ;
    ns1:textoExtracto "salida analógica remota... circuito conectado a una salida analógica remota... configuración de una salida analógica remota" .

