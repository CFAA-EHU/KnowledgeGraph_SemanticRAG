@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModuloEntradasAnalogicas a ns1:ComponenteElectrico ;
    rdfs:label "Módulo remoto de entradas analógicas"@es ;
    ns1:solucionaFallo ns1:Fallo_5041 ;
    ns1:textoExtracto "El módulo remoto de salidas analógicas tiene un error."@es .

ns1:ModuloSalidasAnalogicas a ns1:ComponenteElectrico ;
    rdfs:label "Módulo remoto de salidas analógicas"@es ;
    ns1:solucionaFallo ns1:Fallo_5040 ;
    ns1:textoExtracto "El módulo remoto de salidas analógicas no funciona correctamente."@es .

ns1:Fallo_5040 a ns1:DiagnosticoFallo ;
    rdfs:label "Error desconocido en salida analógica remota"@es ;
    ns1:identificador "5040" ;
    ns1:textoExtracto "Una salida analógica remota ha detectado un error desconocido."@es .

ns1:Fallo_5041 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de rango excedido en entrada analógica remota"@es ;
    ns1:identificador "5041" ;
    ns1:textoExtracto "Una entrada analógica remota ha detectado un error de rango excedido."@es .

