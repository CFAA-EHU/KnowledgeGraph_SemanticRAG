@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tarea_RevisionModuloRemoto a ns1:TareaMantenimiento ;
    rdfs:label "Revisar módulo remoto"@es ;
    ns1:solucionaFallo ns1:Error_5047,
        ns1:Error_5048 ;
    ns1:textoExtracto "SOLUCIÓN Revisar módulo remoto."@es .

ns1:Error_5047 a ns1:DiagnosticoFallo ;
    rdfs:label "Error desconocido en entrada analógica remota"@es ;
    ns1:identificador "5047" ;
    ns1:monitoreaParametro ns1:ModuloEntradasAnalogicas_5047 ;
    ns1:textoExtracto "Una entrada analógica remota ha detectado un error desconocido. DETECCIÓN Durante el funcionamiento del PLC. CAUSA El módulo remoto de entradas analógicas tiene un error."@es .

ns1:Error_5048 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de circuito abierto en sensor de temperatura remoto"@es ;
    ns1:identificador "5048" ;
    ns1:monitoreaParametro ns1:SensorTemperatura_5048 ;
    ns1:textoExtracto "Error de circuito abierto en un sensor de temperatura remoto. DETECCIÓN Durante el funcionamiento del PLC."@es .

ns1:ModuloEntradasAnalogicas_5047 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo remoto de entradas analógicas (error 5047)"@es ;
    ns1:textoExtracto "módulo remoto de entradas analógicas"@es .

ns1:SensorTemperatura_5048 a ns1:Sensor ;
    rdfs:label "Sensor de temperatura remoto (error 5048)"@es ;
    ns1:textoExtracto "sensor de temperatura remoto"@es .

