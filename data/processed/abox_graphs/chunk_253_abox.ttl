@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Esquema_G87_BolsilloRectangular a ns1:Esquema ;
    rdfs:label "Esquema de ciclo fijo G87 (Bolsillo rectangular)"@es ;
    ns1:identificador "G87" ;
    ns1:ilustradoEn ns1:Pagina_28 ;
    ns1:textoExtracto "Representación del ciclo fijo G87 para mecanizado de bolsillos rectangulares."@es .

ns1:Herramienta_Escariador a ns1:Herramienta ;
    rdfs:label "Herramienta escariadora (ciclo G85)"@es ;
    ns1:ilustradoEn ns1:Esquema_G85_Escariado ;
    ns1:textoExtracto "herramienta cilíndrica [para escariado]"@es .

ns1:Herramienta_MachoRoscado a ns1:Herramienta ;
    rdfs:label "Macho de roscar (ciclo G84)"@es ;
    ns1:ilustradoEn ns1:Esquema_G84_Roscado ;
    ns1:textoExtracto "roscado con macho"@es .

ns1:Herramienta_Mandrinadora a ns1:Herramienta ;
    rdfs:label "Herramienta de mandrinado (ciclo G86)"@es ;
    ns1:ilustradoEn ns1:Esquema_G86_Mandrinado ;
    ns1:textoExtracto "mandrinado con parámetros de retirada 'R'"@es .

ns1:Herramienta_TaladroProfundo a ns1:Herramienta ;
    rdfs:label "Herramienta de taladro profundo (ciclo G83)"@es ;
    ns1:ilustradoEn ns1:Esquema_G83_TaladroProfundo ;
    ns1:textoExtracto "taladro profundo con pecks constantes"@es .

ns1:Parametro_FactorRetirada_J a ns1:Parametro ;
    rdfs:label "Parámetro de factor de retirada 'J'"@es ;
    ns1:documentadoEn ns1:Esquema_G84_Roscado ;
    ns1:identificador "J" ;
    ns1:textoExtracto "factor de retirada 'J'"@es .

ns1:Parametro_Orientacion_Q a ns1:Parametro ;
    rdfs:label "Parámetro de orientación 'Q'"@es ;
    ns1:documentadoEn ns1:Esquema_G86_Mandrinado ;
    ns1:identificador "Q" ;
    ns1:textoExtracto "orientación 'Q'"@es .

ns1:Parametro_Permanencia_K a ns1:Parametro ;
    rdfs:label "Parámetro de permanencia 'K'"@es ;
    ns1:documentadoEn ns1:Esquema_G83_TaladroProfundo,
        ns1:Esquema_G84_Roscado,
        ns1:Esquema_G85_Escariado ;
    ns1:identificador "K" ;
    ns1:textoExtracto "permanencia 'K'"@es .

ns1:Parametro_Profundidad_I a ns1:Parametro ;
    rdfs:label "Parámetro de profundidad 'I'"@es ;
    ns1:documentadoEn ns1:Esquema_G83_TaladroProfundo,
        ns1:Esquema_G84_Roscado,
        ns1:Esquema_G85_Escariado ;
    ns1:identificador "I" ;
    ns1:textoExtracto "profundidad 'I'"@es .

ns1:Parametro_Retirada_B a ns1:Parametro ;
    rdfs:label "Parámetro de retirada 'B'"@es ;
    ns1:documentadoEn ns1:Esquema_G83_TaladroProfundo ;
    ns1:identificador "B" ;
    ns1:textoExtracto "retiradas 'B' tras cada paso"@es .

ns1:Esquema_G86_Mandrinado a ns1:Esquema ;
    rdfs:label "Esquema de ciclo fijo G86 (Mandrinado)"@es ;
    ns1:identificador "G86" ;
    ns1:ilustradoEn ns1:Pagina_28 ;
    ns1:textoExtracto "Dos viñetas de mandrinado con parámetros de retirada 'R' y separación de pared mediante orientación 'Q' y desplazamientos laterales 'D/E'. Flechas curvas y rectas señalan salida del útil para evitar roce."@es .

ns1:Pagina_27 a ns1:Pagina ;
    rdfs:label "Página 27 (Canned Cycles - Model M)"@es ;
    ns1:identificador "27" ;
    ns1:textoExtracto "Sección: CANNED CYCLES (·M· MODEL). Ciclos G83, G84."@es .

ns1:Esquema_G85_Escariado a ns1:Esquema ;
    rdfs:label "Esquema de ciclo fijo G85 (Escariado)"@es ;
    ns1:identificador "G85" ;
    ns1:ilustradoEn ns1:Pagina_28 ;
    ns1:textoExtracto "Representación de escariado con herramienta cilíndrica; líneas de guía indican avance hasta 'I' y permanencia 'K'. Se mantiene la lectura por plano de referencia 'Z' y retorno."@es .

ns1:Pagina_28 a ns1:Pagina ;
    rdfs:label "Página 28 (Canned Cycles - Model M)"@es ;
    ns1:identificador "28" ;
    ns1:textoExtracto "Sección: CANNED CYCLES (·M· MODEL). Ciclos G85, G86, G87."@es .

ns1:Esquema_G83_TaladroProfundo a ns1:Esquema ;
    rdfs:label "Esquema de ciclo fijo G83 (Taladro profundo con peck constante)"@es ;
    ns1:identificador "G83" ;
    ns1:ilustradoEn ns1:Pagina_27 ;
    ns1:textoExtracto "Vista seccional del taladro profundo con pecks constantes 'I' y retiradas 'B' tras cada paso. Dos viñetas muestran programación absoluta/incremental; las flechas y cotas marcan fondo, peck y permanencia 'K'."@es .

ns1:Esquema_G84_Roscado a ns1:Esquema ;
    rdfs:label "Esquema de ciclo fijo G84 (Roscado con macho)"@es ;
    ns1:identificador "G84" ;
    ns1:ilustradoEn ns1:Pagina_27 ;
    ns1:textoExtracto "Esquema del roscado con macho, con plano 'Z', profundidad 'I' y pausa 'K'. La simbología de sentido y el bloque de texto asocian tipo de roscado (R0 normal/R1 rígido) y factor de retirada 'J'."@es .

