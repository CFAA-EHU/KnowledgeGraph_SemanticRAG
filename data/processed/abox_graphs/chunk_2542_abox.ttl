@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Bus_CAN a ns1:ComponenteElectrico ;
    rdfs:label "Bus CAN" ;
    ns1:textoExtracto "Error en la inicialización del bus CAN" ;
    ns1:tieneComponente ns1:Error_6004 .

ns1:Senal_EMERGEN a ns1:Sensor ;
    rdfs:label "_EMERGEN" ;
    ns1:monitoreaParametro ns1:Error_6003 ;
    ns1:textoExtracto "La marca _EMERGEN del PLC está desactivada." .

ns1:Error_6003 a ns1:DiagnosticoFallo ;
    rdfs:label "Emergencia externa activada" ;
    ns1:identificador "6003" ;
    ns1:textoExtracto "6003 'Emergencia externa activada' DETECCIÓN Durante el arranque del CNC o la monitorización del programa del PLC. CAUSA La marca _EMERGEN del PLC está desactivada." .

ns1:Error_6004 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización del Bus CAN" ;
    ns1:identificador "6004" ;
    ns1:textoExtracto "6004 'Error en la inicialización del Bus CAN' DETECCIÓN Durante el arranque del CNC. CAUSA Error en la inicialización del bus CAN que tiene" .

