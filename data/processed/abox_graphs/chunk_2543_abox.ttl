@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BusCANfagor a ns1:ComponenteElectrico ;
    rdfs:label "Bus CANfagor" ;
    ns1:activaAlarma ns1:ErrorBusCAN_6004 ;
    ns1:textoExtracto "Los códigos de error son diferentes para los casos de bus CANfagor y del bus CANopen" .

ns1:Senal_EMERGEN a ns1:Sensor ;
    rdfs:label "Señal _EMERGEN" ;
    ns1:monitoreaParametro ns1:ErrorBusCAN_6004 ;
    ns1:textoExtracto "la lógica de la señal _EMERGEN en el programa de PLC" .

ns1:TecladoCAN a ns1:InterfazUsuario ;
    rdfs:label "Teclado de CAN" ;
    ns1:controla ns1:BusCANopen ;
    ns1:textoExtracto "con objeto de poner en marcha el teclado de CAN" .

ns1:BusCANopen a ns1:ComponenteElectrico ;
    rdfs:label "Bus CANopen" ;
    ns1:activaAlarma ns1:ErrorBusCAN_6004 ;
    ns1:textoExtracto "Códigos de error para el bus CANopen" .

ns1:ErrorBusCAN_6004 a ns1:AvisoSeguridad ;
    rdfs:label "Error 6004: Error en la inicialización del Bus CAN" ;
    ns1:identificador "6004" ;
    ns1:textoExtracto "6004 'Error en la inicialización del Bus CAN'" .

