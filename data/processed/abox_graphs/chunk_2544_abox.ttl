@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_6006 a ns1:DiagnosticoFallo ;
    rdfs:label "Uno o varios nodos CAN no responden (6006)"@es ;
    ns1:documentadoEn ns1:Pagina_187 ;
    ns1:identificador "6006" ;
    ns1:textoExtracto """
'Uno o varios nodos CAN no responden'
DETECCIÓN Durante la ejecución.
CAUSA Uno o varios nodos remotos dejan de responder por reset, cortocircuitos, mal funcionamiento, etc."""@es .

ns1:Herramienta_itfcCAN a ns1:Herramienta ;
    rdfs:label "itfcCAN.exe" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_6005 ;
    ns1:textoExtracto "Utilizar la herramienta itfcCAN.exe para comprobar el bus CAN (sólo servicio de asistencia técnica)."@es .

ns1:ModoOperacion_Diagnosis a ns1:ModoOperacion ;
    rdfs:label "Modo diagnosis"@es ;
    ns1:textoExtracto "Comprobar en el modo diagnosis que el CNC reconoce todos los módulos."@es .

ns1:Sistema_BusCAN a ns1:Sistema ;
    rdfs:label "Bus CAN"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_CodigosErrorCOMPCI ;
    ns1:textoExtracto "frecuencia parametrizada del BUS CAN"@es ;
    ns1:tieneComponente ns1:Componente_COMPCI .

ns1:Componente_COMPCI a ns1:ComponenteElectrico ;
    rdfs:label "COMPCI" ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorCOMPCI ;
    ns1:textoExtracto """
Fallo en el reset del micro de la COMPCI (mal funcionamiento del micro, contactos inadecuados, etc).
165 en estado de error o no responde (problema en la COMPCI).
Fallo en test de hardware de la COMPCI."""@es .

ns1:DiagnosticoFallo_6005 a ns1:DiagnosticoFallo ;
    rdfs:label "Error al seleccionar frecuencia de trabajo del BUS CAN (6005)"@es ;
    ns1:documentadoEn ns1:Pagina_187 ;
    ns1:identificador "6005" ;
    ns1:textoExtracto """
'Error al seleccionar frecuencia de trabajo del BUS CAN'
DETECCIÓN Durante el arranque del sistema.
CAUSA Uno o varios nodos no se sintonizan a la frecuencia parametrizada.
SOLUCIÓN Realizar las siguientes comprobaciones:
• Comprobar que la longitud del cable CAN es la adecuada para la frecuencia.
• Comprobar en el modo diagnosis que el CNC reconoce todos los módulos.
• Utilizar la herramienta itfcCAN.exe para comprobar el bus CAN (sólo servicio de asistencia técnica)."""@es .

ns1:Tabla_CodigosErrorCOMPCI a ns1:Tabla ;
    rdfs:label "Tabla de códigos de error para COMPCI y bus CANfagor"@es ;
    ns1:documentadoEn ns1:Pagina_186 ;
    ns1:textoExtracto """
| Código. | Significado. |
| --- | --- |
| 14 | Fallo en el reset del micro de la COMPCI (mal funcionamiento del micro, contactos inadecuados, etc). |
| 15 | Problemas en la conexión o en la configuración de los esclavos CANopen. |
| -1 / -2 / -3 | 165 en estado de error o no responde (problema en la COMPCI). |
| -4 / -5 | Estructura de memoria diferente para PC y COMPCI (posibles diferencia de versiones). |
| -6 | Error en EnableCyclicRead(MD_JOG). |
| -7 | Problemas en la identificación de nodos (mismo grupo y número de nodo). |
| -8 | Problemas en la identificación de nodos (detectado un nodo extra). |
| -9 | Password de acceso a IniCan no válido. |
| -10 | Fallo en test de hardware de la COMPCI. |
| -11 | Fallo en test de hardware del nodo remoto."""@es .

