@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BusCANfagor a ns1:Sistema ;
    rdfs:label "Bus CANfagor"@es ;
    ns1:activaAlarma ns1:Fallo_6006 ;
    ns1:textoExtracto "Los códigos de error son diferentes para los casos de bus CANfagor y del bus CANopen."@es .

ns1:BusCANopen a ns1:Sistema ;
    rdfs:label "Bus CANopen"@es ;
    ns1:activaAlarma ns1:Fallo_6006 ;
    ns1:textoExtracto "Para el bus CANopen, la ventana de error indica cuál es el módulo provoca el error."@es .

ns1:VentanaErrorCANopen a ns1:InterfazUsuario ;
    rdfs:label "Ventana de error CANopen"@es ;
    ns1:monitoreaParametro ns1:ModuloFalloCANopen ;
    ns1:textoExtracto "la ventana de error indica cuál es el módulo provoca el error"@es .

ns1:ModuloFalloCANopen a ns1:ComponenteElectrico ;
    rdfs:label "Módulo con fallo en CANopen"@es ;
    ns1:textoExtracto "el módulo [que] provoca el error"@es .

ns1:Fallo_6006 a ns1:DiagnosticoFallo ;
    rdfs:label "Uno o varios nodos CAN no responden"@es ;
    ns1:identificador "6006" ;
    ns1:textoExtracto "6006 'Uno o varios nodos CAN no responden' DETECCIÓN Durante la ejecución. CAUSA Uno o varios nodos remotos dejan de responder por reset, cortocircuitos, mal funcionamiento, etc."@es .

