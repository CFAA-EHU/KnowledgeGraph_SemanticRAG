@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_6010 a ns1:DiagnosticoFallo ;
    rdfs:label "'Error en procesos de la COMPCI' (Código 6010)"@es ;
    ns1:identificador "6010" ;
    ns1:textoExtracto """
    DETECCIÓN: Durante la ejecución.
    CAUSA: Errores varios en los procesos que gestiona la COMPCI.
    SOLUCIÓN: Si el error persiste, póngase en contacto con el servicio de asistencia técnica."""@es .

ns1:DiagnosticoFallo_6011 a ns1:DiagnosticoFallo ;
    rdfs:label "'Error de CAN en nodo remoto' (Código 6011)"@es ;
    ns1:identificador "6011" ;
    ns1:textoExtracto "DETECCIÓN: Durante la ejecución."@es .

ns1:Solucion_ComprobacionModoDiagnosis a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar en modo diagnosis la configuración del bus CAN y módulos"@es ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_6007,
        ns1:DiagnosticoFallo_6008,
        ns1:DiagnosticoFallo_6009,
        ns1:Error_1_6,
        ns1:Error_2,
        ns1:Error_3,
        ns1:Error_4,
        ns1:Error_5 ;
    ns1:textoExtracto """
    SOLUCIÓN: Comprobar en el modo diagnosis que el CNC reconoce todos los módulos. Comprobar el pinout del cable CAN.
    SOLUCIÓN: Comprobar en el modo diagnosis la configuración del bus CAN y si se producen pérdidas de ITs."""@es .

ns1:DiagnosticoFallo_6007 a ns1:DiagnosticoFallo ;
    rdfs:label "'Watchdog en la COMPCI' (Código 6007)"@es ;
    ns1:identificador "6007" ;
    ns1:textoExtracto """
    DETECCIÓN: Durante la ejecución.
    CAUSA: La COMPCI no responde; posible mal funcionamiento, contactos, etc.
    SOLUCIÓN: Si el error persiste, póngase en contacto con el servicio de asistencia técnica."""@es .

ns1:DiagnosticoFallo_6008 a ns1:DiagnosticoFallo ;
    rdfs:label "'Watchdog en PC + COMPCI' (Código 6008)"@es ;
    ns1:identificador "6008" ;
    ns1:textoExtracto """
    DETECCIÓN: Durante la ejecución.
    CAUSA: La COMPCI y el PC no responden por mal funcionamiento, contactos, pérdidas de RT IT, etc.
    SOLUCIÓN: Comprobar en el modo diagnosis la configuración del bus CAN y si se producen pérdidas de ITs. Si el error persiste, póngase en contacto con el servicio de asistencia técnica."""@es .

ns1:DiagnosticoFallo_6009 a ns1:DiagnosticoFallo ;
    rdfs:label "'Watchdog en PC' (Código 6009)"@es ;
    ns1:identificador "6009" ;
    ns1:textoExtracto """
    DETECCIÓN: Durante la ejecución.
    CAUSA: El PC no responde por pérdidas de RT IT.
    SOLUCIÓN: Comprobar en el modo diagnosis si se producen pérdidas de ITs y la configuración del bus CAN. Si el error persiste, póngase en contacto con el servicio de asistencia técnica."""@es .

ns1:Error_1_6 a ns1:AvisoSeguridad ;
    rdfs:label "Más de tres nodos perdidos (CANopen)"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorCANopen ;
    ns1:identificador "-1 / -6" ;
    ns1:textoExtracto "Más de tres nodos perdidos."@es .

ns1:Error_2 a ns1:AvisoSeguridad ;
    rdfs:label "Timeout en nodo CANopen"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorCANopen ;
    ns1:identificador "2" ;
    ns1:textoExtracto "Timeout (el nodo responde)."@es .

ns1:Error_3 a ns1:AvisoSeguridad ;
    rdfs:label "1 nodo perdido (CANopen)"@es,
        "Error en bit de toggle (CANopen)"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorCANopen ;
    ns1:identificador "-3",
        "3" ;
    ns1:textoExtracto "Error en el bit de toggle."@es .

ns1:Error_4 a ns1:AvisoSeguridad ;
    rdfs:label "2 nodos perdidos (CANopen)"@es,
        "Nodo responde con estado incorrecto (CANopen)"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorCANopen ;
    ns1:identificador "-4",
        "4" ;
    ns1:textoExtracto "El nodo responde pero su estado no es correcto."@es .

ns1:Error_5 a ns1:AvisoSeguridad ;
    rdfs:label "3 nodos perdidos (CANopen)"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorCANopen ;
    ns1:identificador "-5" ;
    ns1:textoExtracto "3 nodo perdido."@es .

ns1:Tabla_CodigosErrorCANopen a ns1:Tabla ;
    rdfs:label "Tabla de códigos de error para el bus CANopen"@es ;
    ns1:textoExtracto """
| Código. | Significado. |
| --- | --- |
| -1 / -6 | Más de tres nodos perdidos. |
| -3 | 1 nodo perdido. |
| -4 | 2 nodo perdido. |
| -5 | 3 nodo perdido.
---
| Código. | Significado. |
| --- | --- |
| 2 | Timeout (el nodo responde). |
| 3 | Error en el bit de toggle. |
| 4 | El nodo responde pero su estado no es correcto."""@es .

