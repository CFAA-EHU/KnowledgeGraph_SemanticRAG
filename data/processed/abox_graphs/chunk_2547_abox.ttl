@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Accion_ContactoAsistenciaTecnica a ns1:AccionProhibida ;
    rdfs:label "Contactar con asistencia técnica"@es ;
    ns1:solucionaFallo ns1:Error_CAN_6011 ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con el servicio de asistencia técnica."@es .

ns1:Modulo_Generico a ns1:ComponenteElectrico ;
    rdfs:label "Módulo (genérico)"@es ;
    ns1:monitoreaParametro ns1:Error_CAN_6011 ;
    ns1:textoExtracto "La ventana de error indica cuál es el módulo provoca el error."@es .

ns1:Sistema_CANfagor a ns1:Sistema ;
    rdfs:label "Bus CANfagor"@es ;
    ns1:textoExtracto "Los códigos de error son diferentes para los casos de bus CANfagor y del bus CANopen."@es .

ns1:Sistema_CANopen a ns1:Sistema ;
    rdfs:label "Bus CANopen"@es ;
    ns1:textoExtracto "Los códigos de error son diferentes para los casos de bus CANfagor y del bus CANopen."@es .

ns1:Error_CAN_6011 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de CAN en nodo remoto"@es ;
    ns1:identificador "6011" ;
    ns1:textoExtracto "6011 'Error de CAN en nodo remoto' [...] Error reportado por un nodo. Los códigos de error son diferentes para los casos de bus CANfagor y del bus CANopen. La ventana de error indica cuál es el módulo provoca el error."@es .

