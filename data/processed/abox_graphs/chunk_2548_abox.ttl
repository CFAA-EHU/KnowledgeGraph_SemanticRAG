@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_CAN_001 a ns1:AvisoSeguridad ;
    rdfs:label "Overrun en controlador CAN (pérdida de mensajes)"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorCAN ;
    ns1:identificador "1" ;
    ns1:textoExtracto "Overrun en el controlador de CAN. Posible pérdida de mensajes recibidos."@es .

ns1:Error_CAN_002 a ns1:AvisoSeguridad ;
    rdfs:label "BusOFF (caída del bus detectada por nodo)"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorCAN ;
    ns1:identificador "2" ;
    ns1:textoExtracto "BusOFF. El nodo detecta que cae el bus."@es .

ns1:Error_CAN_003 a ns1:AvisoSeguridad ;
    rdfs:label "Overrun en FIFO de recepción CAN"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorCAN ;
    ns1:identificador "3" ;
    ns1:textoExtracto "Overrun en la fifo de recepción. Posible pérdida de mensajes recibidos."@es .

ns1:Error_CAN_004 a ns1:AvisoSeguridad ;
    rdfs:label "Warning: contador de tramas de error > 96 (nivel 1)"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorCAN ;
    ns1:identificador "4" ;
    ns1:textoExtracto "Warning. Contador de tramas de error supera el nivel 1 (96)."@es .

ns1:Error_CAN_011 a ns1:AvisoSeguridad ;
    rdfs:label "Fallo COMPCI (sin respuesta a controles de presencia)"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorCAN ;
    ns1:identificador "11" ;
    ns1:textoExtracto "El nodo informa que la COMPCI no responde a los controles de presencia."@es .

ns1:Error_CAN_012 a ns1:AvisoSeguridad ;
    rdfs:label "Reset de nodo (alimentación, cortos, watchdog)"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorCAN ;
    ns1:identificador "12" ;
    ns1:textoExtracto "Reset del nodo (problemas de alimentación, cortos, watchdog, etc)."@es .

ns1:Error_CAN_013 a ns1:AvisoSeguridad ;
    rdfs:label "Fallo en transmisión de mensaje CAN"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorCAN ;
    ns1:identificador "13" ;
    ns1:textoExtracto "Fallo en la transmisión de un mensaje."@es .

ns1:Modulo_CAN_Fagor a ns1:ComponenteElectrico ;
    rdfs:label "Módulo generador de errores para bus CAN (Fagor)"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosErrorCAN ;
    ns1:textoExtracto "Tipo de módulo que genera el error para el bus CANfagor."@es .

ns1:Tabla_CodigosErrorCAN a ns1:Tabla ;
    rdfs:label "Tabla de códigos de error para bus CAN (Fagor)"@es ;
    ns1:textoExtracto "Tipo de módulo que genera el error para el bus CANfagor."@es .

