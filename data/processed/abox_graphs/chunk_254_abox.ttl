@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Esquema_G161_Rectangular a ns1:Esquema ;
    rdfs:label "Esquema de ciclo G161 (maquinado múltiple rectangular)"@es ;
    ns1:identificador "G161" ;
    ns1:textoExtracto "Paralelepípedo/paralelogramo con dos direcciones de maquinado (ángulos A y B). Se visualizan pasos 'I/J' en X/Y y totales 'K/D'; la cuadricula ligera ordena las posiciones."@es .

ns1:Esquema_G162_Grid a ns1:Esquema ;
    rdfs:label "Esquema de ciclo G162 (maquinado en retícula)"@es ;
    ns1:identificador "G162" ;
    ns1:textoExtracto "Retícula ortogonal con distribución regular de puntos; se identifican longitudes 'X/Y' y pasos 'I/J'. La malla enfatiza la generación de matrices de taladros."@es .

ns1:Parametro_AnguloA_G87 a ns1:Parametro ;
    rdfs:label "Ángulo 'A' (orientación respecto a eje X)"@es ;
    ns1:documentadoEn ns1:Esquema_G87_RectangularPocket ;
    ns1:textoExtracto "ángulo 'A' respecto a X"@es ;
    ns1:valor "A" .

ns1:Parametro_LongitudX_G160 a ns1:Parametro ;
    rdfs:label "Longitud total 'X'"@es ;
    ns1:documentadoEn ns1:Esquema_G160_Lineal ;
    ns1:textoExtracto "longitud 'X'"@es ;
    ns1:valor "X" .

ns1:Parametro_PasoI_G160 a ns1:Parametro ;
    rdfs:label "Paso entre operaciones 'I'"@es ;
    ns1:documentadoEn ns1:Esquema_G160_Lineal ;
    ns1:textoExtracto "paso 'I'"@es ;
    ns1:valor "I" .

ns1:Parametro_ProfundidadI_G88 a ns1:Parametro ;
    rdfs:label "Profundidad de corte 'I'"@es ;
    ns1:documentadoEn ns1:Esquema_G88_CircularPocket ;
    ns1:textoExtracto "profundidad 'I'"@es ;
    ns1:valor "I" .

ns1:Parametro_RadioJ_G88 a ns1:Parametro ;
    rdfs:label "Radio del bolsillo 'J'"@es ;
    ns1:documentadoEn ns1:Esquema_G88_CircularPocket ;
    ns1:textoExtracto "radio 'J'"@es ;
    ns1:valor "J" .

ns1:Parametro_RadioQ_G87 a ns1:Parametro ;
    rdfs:label "Radio de esquina 'Q'"@es ;
    ns1:documentadoEn ns1:Esquema_G87_RectangularPocket ;
    ns1:textoExtracto "radios 'Q'"@es ;
    ns1:valor "Q" .

ns1:Esquema_G160_Lineal a ns1:Esquema ;
    rdfs:label "Esquema de ciclo G160 (maquinado múltiple lineal)"@es ;
    ns1:identificador "G160" ;
    ns1:textoExtracto "Patrón lineal con puntos numerados y flechas de avance; ángulo 'A' define la dirección, longitud 'X', paso 'I' y número de operaciones 'K'. La línea punteada marca el trazado de centros."@es .

ns1:Esquema_G87_RectangularPocket a ns1:Esquema ;
    rdfs:label "Esquema de ciclo G87 (bolsillo rectangular)"@es ;
    ns1:identificador "G87" ;
    ns1:textoExtracto "Vista superior de un cajetín rectangular con ángulo 'A' respecto a X, semiejes 'J/K', tipo de esquina 'M' (viva/redondeada/chaflán) y radios 'Q'. Flechas muestran pasadas 'B/C' y pasada de acabado 'L/H'."@es .

ns1:Esquema_G88_CircularPocket a ns1:Esquema ;
    rdfs:label "Esquema de ciclo G88 (bolsillo circular)"@es ;
    ns1:identificador "G88" ;
    ns1:textoExtracto "Esquema de bolsillo circular con radio 'J' y pasadas radiales 'B/C'; se anotan profundidad 'I', plano 'Z' y acabado 'L/H'. La sección de pieza clarifica penetración 'V'."@es .

