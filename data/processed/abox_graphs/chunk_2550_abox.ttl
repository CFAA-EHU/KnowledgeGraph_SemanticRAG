@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FalloNodoIO_12 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en nodo de I/Os (ID: 12)"@es ;
    ns1:identificador "12" ;
    ns1:mitigaRiesgo ns1:Solucion_ContactoAsistenciaTecnica_6011 ;
    ns1:textoExtracto "Fallo en algún nodo de I/Os."@es .

ns1:SistemaEntradas_5_7_8_9_10_11 a ns1:Sistema ;
    rdfs:label "Sistema de entradas de control (analógicas, PT100, CAN, palpadores, teclados)"@es ;
    ns1:textoExtracto "5: Entradas analógicas. 7: Entradas PT100. 8: Volante de teclado CAN. 9: Palpadores. 10: Teclado jog. 11: Teclado alfanumérico."@es ;
    ns1:tieneComponente ns1:EntradasAnalogicas_5,
        ns1:EntradasPT100_7,
        ns1:Palpadores_9,
        ns1:TecladoAlfanumerico_11,
        ns1:TecladoJog_10,
        ns1:VolanteTecladoCAN_8 .

ns1:EntradasAnalogicas_5 a ns1:ComponenteElectrico ;
    rdfs:label "Entradas analógicas (ID: 5)"@es ;
    ns1:identificador "5" ;
    ns1:textoExtracto "Entradas analógicas."@es .

ns1:EntradasPT100_7 a ns1:Sensor ;
    rdfs:label "Entradas PT100 (ID: 7)"@es ;
    ns1:identificador "7" ;
    ns1:textoExtracto "Entradas PT100."@es .

ns1:ErrorNodoCANopen_6011 a ns1:AvisoSeguridad ;
    rdfs:label "Error de nodo CANopen (código 6011)"@es ;
    ns1:identificador "6011" ;
    ns1:mitigaRiesgo ns1:Solucion_ContactoAsistenciaTecnica_6011 ;
    ns1:textoExtracto "Report de nodo CANopen: Emergencia indeterminada. [...] Error de protocolo. PDO demasiado corto. PDO demasiado largo. Emergencia externa. Emergencia específica de fabricante."@es .

ns1:Palpadores_9 a ns1:Sensor ;
    rdfs:label "Palpadores (ID: 9)"@es ;
    ns1:identificador "9" ;
    ns1:textoExtracto "Palpadores."@es .

ns1:TecladoAlfanumerico_11 a ns1:InterfazUsuario ;
    rdfs:label "Teclado alfanumérico (ID: 11)"@es ;
    ns1:identificador "11" ;
    ns1:textoExtracto "Teclado alfanumérico."@es .

ns1:TecladoJog_10 a ns1:InterfazUsuario ;
    rdfs:label "Teclado jog (ID: 10)"@es ;
    ns1:identificador "10" ;
    ns1:textoExtracto "Teclado jog."@es .

ns1:VolanteTecladoCAN_8 a ns1:InterfazUsuario ;
    rdfs:label "Volante de teclado CAN (ID: 8)"@es ;
    ns1:identificador "8" ;
    ns1:textoExtracto "Volante de teclado CAN."@es .

ns1:Solucion_ContactoAsistenciaTecnica_6011 a ns1:TareaMantenimiento ;
    rdfs:label "Contactar con servicio de asistencia técnica para fallo en nodo CANopen"@es ;
    ns1:solucionaFallo ns1:ErrorNodoCANopen_6011 ;
    ns1:textoExtracto "SOLUCIÓN: Póngase en contacto con el servicio de asistencia técnica."@es .

