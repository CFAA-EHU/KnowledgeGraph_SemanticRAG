@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CANopen a ns1:Sistema ;
    rdfs:label "Sistema de comunicación CANopen"@es ;
    ns1:monitoreaParametro ns1:Parametro_CodigosErrorCANopen,
        ns1:Parametro_NumeroNodoCANopen ;
    ns1:textoExtracto "nodo CANopen [...] mensaje de emergencia [...] bus CANopen"@es ;
    ns1:tieneComponente ns1:ErrorCANopen_EmergenciaExterna,
        ns1:ErrorCANopen_EmergenciaFabricante .

ns1:ErrorCANopen_EmergenciaExterna a ns1:AvisoSeguridad ;
    rdfs:label "Error CANopen: Emergencia externa"@es ;
    ns1:identificador "3" ;
    ns1:textoExtracto "Report de nodo CANopen: 'Emergencia externa.' [...] Este error indica que un nodo CANopen ha enviado un mensaje de emergencia."@es .

ns1:ErrorCANopen_EmergenciaFabricante a ns1:AvisoSeguridad ;
    rdfs:label "Error CANopen: Emergencia específica de fabricante"@es ;
    ns1:identificador "3" ;
    ns1:textoExtracto "Report de nodo CANopen: 'Emergencia específica de fabricante.' [...] El texto del error depende del código específico de la emergencia enviada (valor 3)."@es .

ns1:Parametro_CodigosErrorCANopen a ns1:Parametro ;
    rdfs:label "Códigos de error para el bus CANopen"@es ;
    ns1:textoExtracto "VALOR 2 Códigos de error para el bus CANopen (codificación en base a bits)."@es ;
    ns1:valor "2" .

ns1:Parametro_NumeroNodoCANopen a ns1:Parametro ;
    rdfs:label "Número de nodo CANopen"@es ;
    ns1:textoExtracto "VALOR 1 Número de nodo."@es ;
    ns1:valor "1" .

