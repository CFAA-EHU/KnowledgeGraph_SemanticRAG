@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_ErrorControladorCAN_6012 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en controlador de CAN (6012)"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosEmergencia_6000_6999 ;
    ns1:identificador "6012" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_ContactoAsistenciaTecnica_6012 ;
    ns1:textoExtracto """
6012 'Error en controlador de CAN'
DETECCIÓN Durante la ejecución.
CAUSA La COMPCI detecta BUSOFF y el bus cae.
Códigos de error para el bus CANopen.
"""@es .

ns1:Sistema_BusCANopen a ns1:Sistema ;
    rdfs:label "Bus CANopen"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosEmergencia_6000_6999 ;
    ns1:monitoreaParametro ns1:ComponenteElectrico_PT100 ;
    ns1:textoExtracto """
Error de control de presencia detectado por el nodo.
Recuperado de BUS OFF.
Error en controlador de CAN (6012).
"""@es .

ns1:AvisoSeguridad_ContactoAsistenciaTecnica_6012 a ns1:AvisoSeguridad ;
    rdfs:label "Solución para error 6012: Contactar con asistencia técnica"@es ;
    ns1:identificador "6012" ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con el servicio de asistencia técnica."@es .

ns1:ComponenteElectrico_PT100 a ns1:ComponenteElectrico ;
    rdfs:label "Sensor PT100"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosEmergencia_6000_6999 ;
    ns1:textoExtracto "PT100 rota o no conectada."@es .

ns1:Tabla_CodigosEmergencia_6000_6999 a ns1:Tabla ;
    rdfs:label "Tabla de códigos de emergencia (6000-6999)"@es ;
    ns1:textoExtracto """
| Emergencia. | Significado. |
| --- | --- |
| 0x5000 | Hardware del dispositivo. |
| 0x5030 | PT100 rota o no conectada. |
| 0x5031 | Error en entrada analógica o PT100 (RIOW). |
| 0x5112 | Tensión de alimentación de las salidas. |
| 0x6000 | Software del dispositivo. |
| 0x6100 | Software interno. |
| 0x6200 | Software de usuario. |
| 0x6300 | Conjunto de datos. |
| 0x7000 | Módulos adicionales. |
| 0x8000 | Monitorización. |
| 0x8100 | Comunicación. |
| 0x8110 | Mensajes perdidos. |
| 0x8120 | Demasiados errores en el bus. |
| 0x8130 | Error de control de presencia detectado por el nodo. |
| 0x8140 | Recuperado de BUS OFF. |
| 0x8200 | Error de protocolo. |
| 0x8210 | PDO no procesado por error en su longitud. |
| 0x8220 | PDO con demasiadas variables. |
| 0x9000 | Error externo. |
| 0xF000 | Funciones adicionales. |
| 0xFF00 | Emergencia específica del fabricante.
""" .

