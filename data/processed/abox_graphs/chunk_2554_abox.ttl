@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorCAN_1 a ns1:AvisoSeguridad ;
    rdfs:label "Error de CAN (Código 1)"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosError ;
    ns1:identificador "1" ;
    ns1:textoExtracto "Error de CAN."@es .

ns1:ErrorColasTxRx_2 a ns1:AvisoSeguridad ;
    rdfs:label "Error en colas Tx/Rx (Código 2)"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosError ;
    ns1:identificador "2" ;
    ns1:textoExtracto "Error en las colas Tx/Rx."@es .

ns1:ErrorSistema_0 a ns1:AvisoSeguridad ;
    rdfs:label "Error de sistema (Código 0)"@es ;
    ns1:documentadoEn ns1:Tabla_CodigosError ;
    ns1:identificador "0" ;
    ns1:textoExtracto "Error de sistema."@es .

ns1:Tabla_CodigosError a ns1:Tabla ;
    rdfs:label "Tabla de códigos de error del sistema"@es ;
    ns1:documentadoEn ns1:Pagina_186 ;
    ns1:textoExtracto """
| Código. | Significado. |
| --- | --- |
| 0 | Error de sistema. |
| 1 | Error de CAN. |
| 2 | Error en las colas Tx/Rx.
"""@es .

