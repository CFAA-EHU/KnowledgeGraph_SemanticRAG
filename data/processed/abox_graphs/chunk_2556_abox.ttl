@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Aviso_6015_ContactoAsistencia a ns1:AvisoSeguridad ;
    rdfs:label "Contactar con asistencia técnica si persiste el error CAN"@es ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con el servicio de asistencia técnica."@es .

ns1:Fallo_6015 a ns1:DiagnosticoFallo ;
    rdfs:label "Contador de errores CAN sobrepaso nivel 1"@es ;
    ns1:identificador "6015" ;
    ns1:textoExtracto "'Contador de errores CAN sobrepaso nivel 1' DETECCIÓN Durante la ejecución. CAUSA El contador de tramas de error (Rx/Tx) supera el nivel 1 (96). SOLUCIÓN Realizar las comprobaciones oportunas para garantizar la integridad del bus CAN. Si el error persiste, póngase en contacto con el servicio de asistencia técnica."@es .

