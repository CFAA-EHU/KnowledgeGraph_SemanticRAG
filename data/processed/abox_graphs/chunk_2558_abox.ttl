@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_Contadores a ns1:ComponenteElectrico ;
    rdfs:label "Contadores"@es ;
    ns1:compuestoPor ns1:SistemaCAN ;
    ns1:textoExtracto "contadores"@es .

ns1:Componente_EntradasAnalogicas a ns1:ComponenteElectrico ;
    rdfs:label "Entradas analógicas"@es ;
    ns1:compuestoPor ns1:SistemaCAN ;
    ns1:textoExtracto "entradas analógicas"@es .

ns1:Componente_EntradasDigitales a ns1:ComponenteElectrico ;
    rdfs:label "Entradas digitales"@es ;
    ns1:compuestoPor ns1:SistemaCAN ;
    ns1:textoExtracto "entradas digitales"@es .

ns1:Componente_VolantesTeclado a ns1:ComponenteElectrico ;
    rdfs:label "Volantes de teclado"@es ;
    ns1:compuestoPor ns1:SistemaCAN ;
    ns1:textoExtracto "volantes de teclado"@es .

ns1:ModoDiagnosis_CNC a ns1:ModoOperacion ;
    rdfs:label "Modo diagnosis"@es ;
    ns1:solucionaFallo ns1:Fallo_6020_CicloCAN ;
    ns1:textoExtracto "Comprobar en el modo diagnosis que el CNC reconoce todos los módulos y el contador de errores CAN"@es .

ns1:Fallo_6020_CicloCAN a ns1:DiagnosticoFallo ;
    rdfs:label "Solapamiento del ciclo de CAN"@es ;
    ns1:identificador "6020" ;
    ns1:textoExtracto "6020 'Solapamiento del ciclo de CAN' DETECCIÓN Durante la ejecución. CAUSA Fallo en los procesos cíclicos de lectura de las entradas digitales, analógicas, contadores y volantes de teclado. Alguno de los nodos no envió el mensaje a tiempo."@es .

ns1:Parametro_ContadorErroresCAN a ns1:Parametro ;
    rdfs:label "Contador de errores CAN"@es ;
    ns1:textoExtracto "contador de errores CAN"@es .

ns1:SistemaCAN a ns1:Sistema ;
    rdfs:label "Sistema CAN"@es ;
    ns1:monitoreaParametro ns1:Parametro_ContadorErroresCAN ;
    ns1:textoExtracto "procesos cíclicos de lectura de las entradas digitales, analógicas, contadores y volantes de teclado"@es .

