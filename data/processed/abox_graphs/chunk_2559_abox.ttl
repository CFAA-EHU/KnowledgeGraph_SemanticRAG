@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BusCAN a ns1:ComponenteElectrico ;
    rdfs:label "Bus CAN" ;
    ns1:textoExtracto "garantizar la integridad del bus CAN." .

ns1:ContadorErroresCAN a ns1:ComponenteElectrico ;
    rdfs:label "Contador de errores CAN" ;
    ns1:textoExtracto "el contador de errores CAN;" .

ns1:ErrorInicializacionContadorEje_6022 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización del contador del eje" ;
    ns1:identificador "6022" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El contador no existe. La ventana de error indica cuál es el contador que provoca el error. SOLUCIÓN Revisar los parámetros máquina." .

ns1:ErrorInicializacionContadorVolante_6023 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización del contador del volante" ;
    ns1:identificador "6023" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA El contador no existe. La ventana de error indica cuál es el contador que provoca el error. SOLUCIÓN Revisar los parámetros máquina." .

ns1:ErrorInicializacionVolanteTeclado_6024 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la inicialización del volante del teclado" ;
    ns1:identificador "6024" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del CNC. CAUSA La entrada de volante no existe. La ventana de error indica cuál es el volante que provoca el error. SOLUCIÓN Revisar los parámetros máquina." .

ns1:ErrorTransmisionCAN_6021 a ns1:DiagnosticoFallo ;
    rdfs:label "Problemas en la transmisión de CAN" ;
    ns1:identificador "6021" ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Fallo en los procesos transmisión de salidas digitales, analógicas, etc. Posible colapso del bus. SOLUCIÓN Comprobar en el modo diagnosis que el CNC reconoce todos los módulos y el contador de errores CAN; si existen errores, realizar las comprobaciones oportunas para garantizar la integridad del bus CAN. En caso necesario, aumentar los tiempos de ciclo (parámetros LOOPTIME y PLCFREQ)." .

ns1:ModoDiagnosis a ns1:ModoOperacion ;
    rdfs:label "Modo diagnosis" ;
    ns1:textoExtracto "Comprobar en el modo diagnosis que el CNC reconoce todos los módulos y el contador de errores CAN;" .

ns1:Parametro_LOOPTIME a ns1:Parametro ;
    rdfs:label "LOOPTIME" ;
    ns1:textoExtracto "En caso necesario, aumentar los tiempos de ciclo (parámetros LOOPTIME y PLCFREQ)." .

ns1:Parametro_PLCFREQ a ns1:Parametro ;
    rdfs:label "PLCFREQ" ;
    ns1:textoExtracto "En caso necesario, aumentar los tiempos de ciclo (parámetros LOOPTIME y PLCFREQ)." .

