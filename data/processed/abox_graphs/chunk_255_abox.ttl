@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_G69 a ns1:ModoOperacion ;
    rdfs:label "Stock removal canned cycle along Z axis (G69)" ;
    ns1:identificador "G69" ;
    ns1:textoExtracto "Stock removal canned cycle along Z axis." .

ns1:Parametro_G163_NumPuntos a ns1:Parametro ;
    rdfs:label "Número total 'K' (G163)" ;
    ns1:monitoreaParametro ns1:ModoOperacion_G163 ;
    ns1:textoExtracto "número total 'K'" .

ns1:Parametro_G163_PasoAngular a ns1:Parametro ;
    rdfs:label "Paso angular 'I' (G163)" ;
    ns1:monitoreaParametro ns1:ModoOperacion_G163 ;
    ns1:textoExtracto "paso angular 'I' o número total 'K'" .

ns1:Parametro_G163_Radio a ns1:Parametro ;
    rdfs:label "Radio (G163)" ;
    ns1:monitoreaParametro ns1:ModoOperacion_G163 ;
    ns1:textoExtracto "el centro y radio se obtienen desde el punto de partida (X,Y)" .

ns1:Parametro_G164_AnguloB a ns1:Parametro ;
    rdfs:label "Ángulo 'B' (G164)" ;
    ns1:monitoreaParametro ns1:ModoOperacion_G164 ;
    ns1:textoExtracto "puntos distribuidos entre ángulo 'B' y paso 'I'" .

ns1:Parametro_G164_PasoI a ns1:Parametro ;
    rdfs:label "Paso 'I' (G164)" ;
    ns1:monitoreaParametro ns1:ModoOperacion_G164 ;
    ns1:textoExtracto "paso 'I' (o total 'K')" .

ns1:Parametro_G165_AnguloA a ns1:Parametro ;
    rdfs:label "Ángulo 'A' (G165)" ;
    ns1:monitoreaParametro ns1:ModoOperacion_G165 ;
    ns1:textoExtracto "mediatriz a ángulo 'A'" .

ns1:Parametro_G165_LongitudI a ns1:Parametro ;
    rdfs:label "Longitud 'I' (G165)" ;
    ns1:monitoreaParametro ns1:ModoOperacion_G165 ;
    ns1:textoExtracto "longitud 'I'" .

ns1:Parametro_G66_ExcesoI a ns1:Parametro ;
    rdfs:label "Exceso 'I' (G66)" ;
    ns1:monitoreaParametro ns1:ModoOperacion_G66 ;
    ns1:textoExtracto "se destacan exceso 'I'" .

ns1:Parametro_G66_PasadaC a ns1:Parametro ;
    rdfs:label "Pasada 'C' (G66)" ;
    ns1:monitoreaParametro ns1:ModoOperacion_G66 ;
    ns1:textoExtracto "pasada 'C'" .

ns1:Parametro_G68_AvanceK a ns1:Parametro ;
    rdfs:label "Avance 'K' (G68)" ;
    ns1:monitoreaParametro ns1:ModoOperacion_G68 ;
    ns1:textoExtracto "avances 'K/F/H'" .

ns1:Parametro_G68_RetiradaD a ns1:Parametro ;
    rdfs:label "Retirada 'D' (G68)" ;
    ns1:monitoreaParametro ns1:ModoOperacion_G68 ;
    ns1:textoExtracto "retirada 'D' tras cada pasada" .

ns1:ModoOperacion_G164 a ns1:ModoOperacion ;
    rdfs:label "Multiple machining in arc pattern (G164)" ;
    ns1:identificador "G164" ;
    ns1:textoExtracto "Arco con puntos distribuidos entre ángulo 'B' y paso 'I' (o total 'K'). Se muestran vectores desde el origen (X,Y) al centro." .

ns1:ModoOperacion_G165 a ns1:ModoOperacion ;
    rdfs:label "Machining programmed with an arc-chord (G165)" ;
    ns1:identificador "G165" ;
    ns1:textoExtracto "Construcción de cuerda con mediatriz a ángulo 'A' y longitud 'I'; flechas indican interpolación entre puntos sobre el arco." .

ns1:ModoOperacion_G66 a ns1:ModoOperacion ;
    rdfs:label "Pattern repeat canned cycle (G66)" ;
    ns1:identificador "G66" ;
    ns1:textoExtracto "Perfil torneado en sección longitudinal con pasadas repetitivas; se destacan exceso 'I', pasada 'C', ejes principales y bloques S–E que delimitan la geometría." .

ns1:ModoOperacion_G68 a ns1:ModoOperacion ;
    rdfs:label "Stock removal cycle along X axis (G68)" ;
    ns1:identificador "G68" ;
    ns1:textoExtracto "Desbaste por capas en eje X con retirada 'D' tras cada pasada; se rotulan existencias de acabado 'L/M' y avances 'K/F/H'." .

ns1:ModoOperacion_G163 a ns1:ModoOperacion ;
    rdfs:label "Multiple machining in a full circle (G163)" ;
    ns1:identificador "G163" ;
    ns1:textoExtracto "Corona circular con puntos equiangularmente espaciados; el centro y radio se obtienen desde el punto de partida (X,Y), con paso angular 'I' o número total 'K' y tipo de movimiento 'C'." .

