@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Accion_ContactoAsistenciaTecnica a ns1:AccionProhibida ;
    rdfs:label "Contactar con asistencia técnica si el error persiste"@es ;
    ns1:mitigaRiesgo ns1:Error_6025_EntradaVolanteInexistente ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con el servicio de asistencia técnica."@es .

ns1:Error_6025_ChecksumCOMPCI a ns1:AvisoSeguridad ;
    rdfs:label "Error de checksum en la COMPCI"@es ;
    ns1:identificador "6025" ;
    ns1:textoExtracto "6025 'Error de checksum en la COMPCI' [...] CAUSA Error en el cheksum de los datos"@es .

ns1:Solucion_RevisionParametrosMaquina a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de parámetros máquina"@es ;
    ns1:solucionaFallo ns1:Error_6025_EntradaVolanteInexistente ;
    ns1:textoExtracto "SOLUCIÓN Revisar los parámetros máquina."@es .

ns1:Error_6025_EntradaVolanteInexistente a ns1:AvisoSeguridad ;
    rdfs:label "Error: Entrada de volante no existe"@es ;
    ns1:identificador "6025" ;
    ns1:textoExtracto "CAUSA La entrada de volante no existe. La ventana de error indica cuál es el volante que provoca el error."@es .

