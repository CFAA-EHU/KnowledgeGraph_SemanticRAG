@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Accion_ContactoAsistenciaTecnica a ns1:AccionProhibida ;
    rdfs:label "Ponerse en contacto con el servicio de asistencia técnica"@es ;
    ns1:mitigaRiesgo ns1:ErrorChecksumCOMPCI ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con el servicio de asistencia técnica."@es .

ns1:SistemaCOMPCI a ns1:Sistema ;
    rdfs:label "COMPCI"@es ;
    ns1:textoExtracto "Error en el cheksum de los datos de las salidas digitales o analógicas que han sido enviados desde el PC a la COMPCI, a través de la memoria RAM común."@es .

ns1:ErrorChecksumCOMPCI a ns1:DiagnosticoFallo ;
    rdfs:label "Error de checksum en la COMPCI"@es ;
    ns1:identificador "6025" ;
    ns1:textoExtracto "6025 'Error de checksum en la COMPCI' DETECCIÓN Durante la ejecución. CAUSA Error en el cheksum de los datos de las salidas digitales o analógicas que han sido enviados desde el PC a la COMPCI, a través de la memoria RAM común."@es .

