@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_CodigosSalidas a ns1:Tabla ;
    rdfs:label "Tabla de códigos de salidas"@es ;
    ns1:textoExtracto """
| Código. | Significado. |
| --- | --- |
| 1 | Salidas analógicas. |
| 3 | Salidas digitales. |
"""@es ;
    ns1:tieneComponente ns1:SalidaAnalogica_1,
        ns1:SalidaDigital_3 .

ns1:SalidaAnalogica_1 a ns1:ComponenteElectrico ;
    rdfs:label "Salida analógica (código 1)"@es ;
    ns1:identificador "1" ;
    ns1:textoExtracto "Salidas analógicas."@es .

ns1:SalidaDigital_3 a ns1:ComponenteElectrico ;
    rdfs:label "Salida digital (código 3)"@es ;
    ns1:identificador "3" ;
    ns1:textoExtracto "Salidas digitales."@es .

