@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_6031 a ns1:DiagnosticoFallo ;
    rdfs:label "Versión de software incompatible" ;
    ns1:identificador "6031" ;
    ns1:solucionaFallo ns1:ConsultarConElServicioDeAsistenciaTecnica ;
    ns1:textoExtracto "6031 'Versión de soft incompatible en" .

ns1:NodoContadora_CAN a ns1:ComponenteElectrico ;
    rdfs:label "Nodo contadora de CAN" ;
    ns1:activaAlarma ns1:Fallo_6030 ;
    ns1:textoExtracto "nodo contadora de CAN" .

ns1:Fallo_6030 a ns1:DiagnosticoFallo ;
    rdfs:label "Límite de incremento de posición superado en el nodo contadora de CAN" ;
    ns1:identificador "6030" ;
    ns1:solucionaFallo ns1:ConsultarConElServicioDeAsistenciaTecnica ;
    ns1:textoExtracto "6030 'Límite de incremento de posición superado en el nodo contadora de CAN' DETECCIÓN Durante la ejecución. CAUSA Incremento de posición excesivo en un eje analógico. Fallo de hardware del nodo contadora." .

ns1:ConsultarConElServicioDeAsistenciaTecnica a ns1:AvisoSeguridad ;
    rdfs:label "Consultar con el servicio de asistencia técnica" ;
    ns1:textoExtracto "SOLUCIÓN Consultar con el servicio de asistencia técnica." .

