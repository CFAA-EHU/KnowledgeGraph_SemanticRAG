@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alimentacion24V a ns1:Parametro ;
    rdfs:label "Alimentación 24 V para I/Os locales" ;
    ns1:solucionaFallo ns1:FaltaAlimentacionIOsLocales_6036 ;
    ns1:textoExtracto "Alimentar las I/Os locales con 24 V" ;
    ns1:valor "24 V" .

ns1:Parametro_LoopTime a ns1:Parametro ;
    rdfs:label "LOOPTIME" ;
    ns1:monitoreaParametro ns1:ParametroLoopTimeInvalido_6037 ;
    ns1:textoExtracto "Parámetro LOOPTIME" .

ns1:SistemaIOsLocales a ns1:Sistema ;
    rdfs:label "Sistema de I/Os locales (ICU y MCU)" ;
    ns1:activaAlarma ns1:FaltaAlimentacionIOsLocales_6036 ;
    ns1:textoExtracto "I/Os locales (unidades centrales ICU y MCU)" ;
    ns1:tieneComponente ns1:UnidadCentral_ICU,
        ns1:UnidadCentral_MCU .

ns1:ParametroLoopTimeInvalido_6037 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro LOOPTIME no es válido (6037)" ;
    ns1:identificador "6037" ;
    ns1:textoExtracto "6037 'Parámetro LOOPTIME no es válido" .

ns1:UnidadCentral_ICU a ns1:ComponenteElectrico ;
    rdfs:label "Unidad central ICU" ;
    ns1:textoExtracto "unidades centrales ICU" .

ns1:UnidadCentral_MCU a ns1:ComponenteElectrico ;
    rdfs:label "Unidad central MCU" ;
    ns1:textoExtracto "unidades centrales MCU" .

ns1:FaltaAlimentacionIOsLocales_6036 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta alimentación de IOs locales (6036)" ;
    ns1:identificador "6036" ;
    ns1:textoExtracto "6036 'Falta alimentación de IOs locales' DETECCIÓN Durante la ejecución. CAUSA Falta la alimentación en las I/Os locales (unidades centrales ICU y MCU). SOLUCIÓN Alimentar las I/Os locales con 24 V." .

