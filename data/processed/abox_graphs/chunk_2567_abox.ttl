@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_6037 a ns1:DiagnosticoFallo ;
    rdfs:label "Parámetro LOOPTIME no es válido para la configuración de CAN"@es ;
    ns1:identificador "6037" ;
    ns1:monitoreaParametro ns1:Parametro_LOOPTIME ;
    ns1:textoExtracto "6037 'Parámetro LOOPTIME no es válido para la configuración de CAN' DETECCIÓN Durante el arranque del sistema. CAUSA El valor del parámetro LOOPTIME es demasiado pequeño o no es válido. SOLUCIÓN Comprobar que el valor asignado al parámetro LOOPTIME es múltiplo de 0,5 ms y mayor de 1,5 ms. Aumentar el valor si la configuración CAN así lo aconseja."@es .

ns1:Fallo_6038 a ns1:DiagnosticoFallo ;
    rdfs:label "Sobrepasado el límite máximo de elementos CAN en el sistema"@es ;
    ns1:documentadoEn ns1:Sistema_CAN ;
    ns1:identificador "6038" ;
    ns1:textoExtracto "6038 'Sobrepasado el límite máximo de elementos CAN en el sistema' DETECCIÓN Durante el arranque del sistema. CAUSA Algún elemento del bus CAN supera el máximo permitido; número entradas o salidas analógicas, entradas o salidas digitales o contadoras. SOLUCIÓN Apagar el CNC y quitar elementos del bus hasta entrar en los límites."@es .

ns1:Fallo_Alimentacion_IOs a ns1:DiagnosticoFallo ;
    rdfs:label "Falta de alimentación en I/Os locales (ICU y MCU)"@es ;
    ns1:documentadoEn ns1:Sistema_IOsLocales ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Falta la alimentación en las I/Os locales (unidades centrales ICU y MCU). SOLUCIÓN Alimentar las I/Os locales con 24 V."@es .

ns1:Componente_ICU a ns1:ComponenteElectrico ;
    rdfs:label "Unidad central ICU"@es ;
    ns1:textoExtracto "I/Os locales (unidades centrales ICU y MCU)"@es .

ns1:Componente_MCU a ns1:ComponenteElectrico ;
    rdfs:label "Unidad central MCU"@es ;
    ns1:textoExtracto "I/Os locales (unidades centrales ICU y MCU)"@es .

ns1:Parametro_LOOPTIME a ns1:Parametro ;
    rdfs:label "LOOPTIME" ;
    ns1:textoExtracto "El valor del parámetro LOOPTIME es demasiado pequeño o no es válido. Comprobar que el valor asignado al parámetro LOOPTIME es múltiplo de 0,5 ms y mayor de 1,5 ms."@es ;
    ns1:valor "múltiplo de 0,5 ms y > 1,5 ms"@es .

ns1:Sistema_CAN a ns1:Sistema ;
    rdfs:label "Bus CAN"@es ;
    ns1:textoExtracto "elemento del bus CAN supera el máximo permitido; número entradas o salidas analógicas, entradas o salidas digitales o contadoras"@es .

ns1:Sistema_IOsLocales a ns1:Sistema ;
    rdfs:label "I/Os locales"@es ;
    ns1:textoExtracto "Falta la alimentación en las I/Os locales (unidades centrales ICU y MCU). Alimentar las I/Os locales con 24 V."@es ;
    ns1:tieneComponente ns1:Componente_ICU,
        ns1:Componente_MCU .

