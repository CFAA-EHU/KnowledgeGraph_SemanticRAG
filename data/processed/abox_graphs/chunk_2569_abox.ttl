@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_6043 a ns1:Alarma ;
    rdfs:label "Alarma de cable roto" ;
    ns1:identificador "6043" ;
    ns1:textoExtracto "'Alarma de cable roto' DETECCIÓN El lazo ha" .

ns1:ComponenteElectrico_Cableado_CNC a ns1:ComponenteElectrico ;
    rdfs:label "Cableado de captación local del CNC" ;
    ns1:requiereMantenimiento ns1:TareaMantenimiento_RevisionConexionado_6042 ;
    ns1:textoExtracto "el correcto conexionado y niveles de señal de la captación local del CNC" .

ns1:DiagnosticoFallo_6042 a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico de sobrecorriente en CNC" ;
    ns1:solucionaFallo ns1:Alarma_6042 ;
    ns1:textoExtracto "Cortocircuito en el contaje local del CNC. SOLUCIÓN Revisar el correcto conexionado y niveles de señal de la captación local del CNC." .

ns1:Alarma_6042 a ns1:Alarma ;
    rdfs:label "Alarma de sobrecorriente" ;
    ns1:activaAlarma ns1:Sensor_CaptacionLocal_CNC ;
    ns1:identificador "6042" ;
    ns1:textoExtracto "'Alarma de sobrecorriente' DETECCIÓN El lazo ha detectado una alarma de sobrecorriente en la lectura de la entrada local de captación." .

ns1:Parametro_Corriente_CNC a ns1:Parametro ;
    rdfs:label "Corriente en el contaje local del CNC" ;
    ns1:textoExtracto "la lectura de la entrada local de captación" ;
    ns1:valor "sobrecorriente" .

ns1:Sensor_CaptacionLocal_CNC a ns1:Sensor ;
    rdfs:label "Sensor de captación local del CNC" ;
    ns1:monitoreaParametro ns1:Parametro_Corriente_CNC ;
    ns1:textoExtracto "la lectura de la entrada local de captación del CNC" .

ns1:TareaMantenimiento_RevisionConexionado_6042 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de conexionado y niveles de señal en CNC" ;
    ns1:ejecutadoPor ns1:Personal_TecnicoAsistencia ;
    ns1:textoExtracto "Revisar el correcto conexionado y niveles de señal de la captación local del CNC" .

