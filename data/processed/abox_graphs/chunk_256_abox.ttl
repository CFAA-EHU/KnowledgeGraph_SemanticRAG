@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Seccion_CannedCycles_ModeloT a ns1:Capitulo ;
    rdfs:label "CANNED CYCLES (·T· MODEL)" ;
    ns1:documentadoEn ns1:G69_CicloDesbasteEjeZ,
        ns1:G81_CicloTorneadoTramosRectos,
        ns1:G82_CicloRefrentadoTramosRectos,
        ns1:G83_CicloTaladradoRoscadoAxial,
        ns1:G84_CicloTorneadoArcos,
        ns1:G85_CicloRefrentadoArcos,
        ns1:G86_CicloRoscadoLongitudinal ;
    ns1:textoExtracto "Sección del manual que describe ciclos fijos para operaciones de torneado, refrentado, taladrado y roscado en el modelo T." .

ns1:G69_CicloDesbasteEjeZ a ns1:ModoOperacion ;
    rdfs:label "G69. Stock removal canned cycle along Z axis" ;
    ns1:identificador "G69" ;
    ns1:textoExtracto "Desbaste análogo al anterior pero a lo largo de Z; diagramación con franjas de material y retracciones controladas." .

ns1:G81_CicloTorneadoTramosRectos a ns1:ModoOperacion ;
    rdfs:label "G81. Turning canned cycle with straight sections" ;
    ns1:identificador "G81" ;
    ns1:textoExtracto "Perfil con tramos rectos (cilindrado/planeado) entre puntos (X,Z)–(Q,R). Capas de desbaste 'C' y retiradas 'D' con stocks 'L/M'." .

ns1:G82_CicloRefrentadoTramosRectos a ns1:ModoOperacion ;
    rdfs:label "G82. Facing canned cycle with straight sections" ;
    ns1:identificador "G82" ;
    ns1:textoExtracto "Planeado en Z con franjas de pasada; mismo código visual de stocks y avances que G81, pero orientado al frente." .

ns1:G83_CicloTaladradoRoscadoAxial a ns1:ModoOperacion ;
    rdfs:label "G83. Axial drilling and tapping canned cycle" ;
    ns1:identificador "G83" ;
    ns1:textoExtracto "Taladrado/roscado axial en torno: dos bloques (drilling/tapping). Se muestran seguridad 'D', pecks 'H/C/R' y profundidad 'I'." .

ns1:G84_CicloTorneadoArcos a ns1:ModoOperacion ;
    rdfs:label "G84. Turning canned cycle with arcs" ;
    ns1:identificador "G84" ;
    ns1:textoExtracto "Perfil con transición por arco; vectores 'I/K' desde el origen al centro del arco y franjas de desbaste." .

ns1:G85_CicloRefrentadoArcos a ns1:ModoOperacion ;
    rdfs:label "G85. Facing canned cycle with arcs" ;
    ns1:identificador "G85" ;
    ns1:textoExtracto "Variante de planeado con arco de unión; misma simbología de stocks y retirada." .

ns1:G86_CicloRoscadoLongitudinal a ns1:ModoOperacion ;
    rdfs:label "G86. Longitudinal threading or thread repair canned cycle" ;
    ns1:identificador "G86" ;
    ns1:textoExtracto "Rosca longitudinal con penetraciones escalonadas 'B/E' y ángulo de penetración 'A'. Se marcan inicio/fin (Q/R) y posición angular 'W'." .

