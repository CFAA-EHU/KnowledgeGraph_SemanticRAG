@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteElectrico_SenalA a ns1:ComponenteElectrico ;
    rdfs:label "Señal A del contaje local" ;
    ns1:monitoreaParametro ns1:SistemaCaptacionLocalCNC ;
    ns1:textoExtracto "señal A del contaje local" .

ns1:ComponenteElectrico_SenalAL a ns1:ComponenteElectrico ;
    rdfs:label "Señal AL del contaje local" ;
    ns1:monitoreaParametro ns1:SistemaCaptacionLocalCNC ;
    ns1:textoExtracto "señal AL del contaje local" .

ns1:ComponenteElectrico_SenalB a ns1:ComponenteElectrico ;
    rdfs:label "Señal B del contaje local" ;
    ns1:monitoreaParametro ns1:SistemaCaptacionLocalCNC ;
    ns1:textoExtracto "señal B del contaje local" .

ns1:ComponenteElectrico_SenalI0 a ns1:ComponenteElectrico ;
    rdfs:label "Señal I0 del contaje local" ;
    ns1:monitoreaParametro ns1:SistemaCaptacionLocalCNC ;
    ns1:textoExtracto "señal I0 del contaje local" .

ns1:Sensor_CaptadorExterno a ns1:Sensor ;
    rdfs:label "Captador conectado al contaje local" ;
    ns1:monitoreaParametro ns1:SistemaCaptacionLocalCNC ;
    ns1:textoExtracto "captador conectado al contaje local" .

ns1:Alarma_6043 a ns1:Alarma ;
    rdfs:label "Alarma de cable roto" ;
    ns1:identificador "6043" ;
    ns1:textoExtracto "'Alarma de cable roto' DETECCIÓN El lazo ha detectado una alarma genérica de cable roto en la entrada local de captación. CAUSA El contaje local del CNC tiene alguna de sus señales rota. SOLUCIÓN Revisar el correcto conexionado y niveles de señal de la captación local del CNC." .

ns1:Alarma_6044 a ns1:Alarma ;
    rdfs:label "Alarma de cable roto en señal A" ;
    ns1:identificador "6044" ;
    ns1:textoExtracto "'Alarma de cable roto en señal A' DETECCIÓN El lazo ha detectado cable roto en la señal A del contaje local. CAUSA El contaje local del CNC no recibe la señal A. SOLUCIÓN Revisar la señal A de la captación local del CNC." .

ns1:Alarma_6045 a ns1:Alarma ;
    rdfs:label "Alarma de cable roto en señal B" ;
    ns1:identificador "6045" ;
    ns1:textoExtracto "'Alarma de cable roto en señal B' DETECCIÓN El lazo ha detectado cable roto en la señal B del contaje local. CAUSA El contaje local del CNC no recibe la señal B. SOLUCIÓN Revisar la señal B de la captación local del CNC." .

ns1:Alarma_6046 a ns1:Alarma ;
    rdfs:label "Alarma de cable roto en señal I0" ;
    ns1:identificador "6046" ;
    ns1:textoExtracto "'Alarma de cable roto en señal I0' DETECCIÓN El lazo ha detectado cable roto en la señal I0 del contaje local. CAUSA El contaje local del CNC no recibe la señal I0. SOLUCIÓN Revisar la señal I0 de la captación local del CNC." .

ns1:Alarma_6047 a ns1:Alarma ;
    rdfs:label "Alarma de cable roto en señal AL" ;
    ns1:identificador "6047" ;
    ns1:textoExtracto "'Alarma de cable roto en señal AL' DETECCIÓN El lazo ha detectado cable roto en la señal AL del contaje local. CAUSA El contaje local del CNC no recibe la señal AL. SOLUCIÓN Revisar la señal AL de la captación local del CNC." .

ns1:Alarma_6048 a ns1:Alarma ;
    rdfs:label "Alarma externa del captador" ;
    ns1:identificador "6048" ;
    ns1:textoExtracto "'Alarma externa del captador' DETECCIÓN El lazo ha detectado alarma externa en el contaje local. CAUSA El captador conectado al contaje local reporta alarma. SOLUCIÓN Revisar el captador conectado a la captación local del CNC." .

ns1:SistemaCaptacionLocalCNC a ns1:Sistema ;
    rdfs:label "Sistema de captación local del CNC" ;
    ns1:activaAlarma ns1:Alarma_6043,
        ns1:Alarma_6044,
        ns1:Alarma_6045,
        ns1:Alarma_6046,
        ns1:Alarma_6047,
        ns1:Alarma_6048 ;
    ns1:textoExtracto "captación local del CNC" .

