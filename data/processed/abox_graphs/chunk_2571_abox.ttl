@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_6050 a ns1:Alarma ;
    rdfs:label "Cortocircuito en las IOs locales (alarma de sobrecorriente)" ;
    ns1:identificador "6050" ;
    ns1:textoExtracto "'Cortocircuito en las IOs locales (alarma de sobrecorriente)' DETECCIÓN Durante el funcionamiento del CNC." .

ns1:Alarma_6048 a ns1:Alarma ;
    rdfs:label "Alarma externa del captador" ;
    ns1:identificador "6048" ;
    ns1:mitigaRiesgo ns1:Diagnostico_6048 ;
    ns1:textoExtracto "'Alarma externa del captador' DETECCIÓN El lazo ha detectado alarma externa en el contaje local. CAUSA El captador conectado al contaje local reporta alarma. SOLUCIÓN Revisar el captador conectado a la captación local del CNC." .

ns1:Alarma_6049 a ns1:Alarma ;
    rdfs:label "Alarma de amplitud" ;
    ns1:identificador "6049" ;
    ns1:mitigaRiesgo ns1:Diagnostico_6049 ;
    ns1:textoExtracto "'Alarma de amplitud' DETECCIÓN El lazo ha detectado alarma de amplitud Vpp en el contaje local. CAUSA La señal senoidal conectada al contaje local tiene una amplitud fuera de límites, demasiado pequeña o demasiado grande. SOLUCIÓN Revisar los niveles de la señal Vpp en la captación local del CNC." .

ns1:Diagnostico_6048 a ns1:DiagnosticoFallo ;
    rdfs:label "Revisión de captador en contaje local" ;
    ns1:solucionaFallo ns1:Alarma_6048 ;
    ns1:textoExtracto "Revisar el captador conectado a la captación local del CNC." .

ns1:Diagnostico_6049 a ns1:DiagnosticoFallo ;
    rdfs:label "Revisión de niveles de señal Vpp" ;
    ns1:solucionaFallo ns1:Alarma_6049 ;
    ns1:textoExtracto "Revisar los niveles de la señal Vpp en la captación local del CNC." .

