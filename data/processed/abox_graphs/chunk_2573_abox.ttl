@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_6056 a ns1:DiagnosticoFallo ;
    rdfs:label "Cortocircuito en volante de jog (alarma de sobrecorriente)"@es ;
    ns1:activaAlarma ns1:Alarma_6056 ;
    ns1:identificador "6056" ;
    ns1:solucionaFallo ns1:TareaMantenimiento_RevisionVolantesJog ;
    ns1:textoExtracto "6056 'Cortocircuito en volante de jog (alarma de sobrecorriente)' DETECCIÓN Durante la ejecución del CNC. CAUSA Alarma de sobrecorriente en el volante conectado al jog local. SOLUCIÓN Revisar el conexionado y alimentación de los volantes locales."@es .

ns1:DiagnosticoFallo_6057 a ns1:DiagnosticoFallo ;
    rdfs:label "Alarma de captación en volante"@es ;
    ns1:activaAlarma ns1:Alarma_6057 ;
    ns1:identificador "6057" ;
    ns1:solucionaFallo ns1:TareaMantenimiento_RevisionVolantesCaptacion ;
    ns1:textoExtracto "6057 'Alarma de Captación en volante' DETECCIÓN Durante la ejecución del CNC. CAUSA Alarma de captación en volante conectado al contaje local. SOLUCIÓN Revisar el conexionado y alimentación de los volantes locales."@es .

ns1:Alarma_6056 a ns1:Alarma ;
    rdfs:label "Alarma de sobrecorriente en volante de jog"@es ;
    ns1:textoExtracto "Alarma de sobrecorriente en el volante conectado al jog local."@es .

ns1:Alarma_6057 a ns1:Alarma ;
    rdfs:label "Alarma de captación en volante"@es ;
    ns1:textoExtracto "Alarma de captación en volante conectado al contaje local."@es .

ns1:ComponenteElectrico_VolanteCaptacion a ns1:ComponenteElectrico ;
    rdfs:label "Volante de contaje local"@es ;
    ns1:textoExtracto "volante conectado al contaje local"@es .

ns1:ComponenteElectrico_VolanteJog a ns1:ComponenteElectrico ;
    rdfs:label "Volante de jog"@es ;
    ns1:textoExtracto "volante conectado al jog local"@es .

ns1:TareaMantenimiento_RevisionVolantesCaptacion a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de conexionado y alimentación de volantes de contaje"@es ;
    ns1:requiereMantenimiento ns1:ComponenteElectrico_VolanteCaptacion ;
    ns1:textoExtracto "Revisar el conexionado y alimentación de los volantes locales."@es .

ns1:TareaMantenimiento_RevisionVolantesJog a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de conexionado y alimentación de volantes locales"@es ;
    ns1:requiereMantenimiento ns1:ComponenteElectrico_VolanteJog ;
    ns1:textoExtracto "Revisar el conexionado y alimentación de los volantes locales."@es .

