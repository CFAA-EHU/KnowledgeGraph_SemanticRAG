@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnilloSercos_710 a ns1:ComponenteElectrico ;
    rdfs:label "anillo Sercos"@es ;
    ns1:textoExtracto "error durante el rearme del [...] anillo Sercos"@es .

ns1:BusCAN_710 a ns1:ComponenteElectrico ;
    rdfs:label "bus CAN"@es ;
    ns1:textoExtracto "error durante el rearme del bus CAN"@es .

ns1:ProcesoValidacionParametros_710 a ns1:ModoOperacion ;
    rdfs:label "validación de parámetros máquina"@es ;
    ns1:activaAlarma ns1:ErrorSercos_710 ;
    ns1:textoExtracto "validación de parámetros máquina"@es .

ns1:ResetCNC_710 a ns1:ModoOperacion ;
    rdfs:label "reset del CNC"@es ;
    ns1:activaAlarma ns1:ErrorSercos_710 ;
    ns1:textoExtracto "reset del CNC"@es .

ns1:ReleEmergencia_710 a ns1:ComponenteElectrico ;
    rdfs:label "relé de emergencia"@es ;
    ns1:textoExtracto "el relé de emergencia ha quedado abierto"@es .

ns1:ErrorSercos_710 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en Sercos durante un proceso"@es ;
    ns1:identificador "1" ;
    ns1:solucionaFallo ns1:ReleEmergencia_710 ;
    ns1:textoExtracto "Error en Sercos durante un proceso"@es .

