@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProcesoRearmeAnilloSercos a ns1:ModoOperacion ;
    rdfs:label "rearme del anillo Sercos"@es ;
    ns1:textoExtracto "ejecución de dicho proceso debido a un error durante el rearme del bus CAN o del anillo Sercos"@es .

ns1:ProcesoRearmeBusCAN a ns1:ModoOperacion ;
    rdfs:label "rearme del bus CAN"@es ;
    ns1:textoExtracto "ejecución de dicho proceso debido a un error durante el rearme del bus CAN"@es .

ns1:SistemaComunicacionMaquina a ns1:Sistema ;
    rdfs:label "Sistema de comunicación máquina (CAN/Sercos)"@es ;
    ns1:activaAlarma ns1:ErrorCANResetCNC,
        ns1:ErrorCANValidacionParametros,
        ns1:ErrorSercosCANResetCNC,
        ns1:ErrorSercosCANValidacionParametros,
        ns1:ErrorSercosResetCNC,
        ns1:ErrorSercosValidacionParametros ;
    ns1:textoExtracto "Error en Sercos y CAN durante un proceso de reset CNC"@es ;
    ns1:tieneComponente ns1:ReleEmergencia .

ns1:SolucionErrorCAN_Sercos a ns1:TareaMantenimiento ;
    rdfs:label "Corregir el problema en CAN o Sercos que impide que se cierre el relé de emergencia"@es ;
    ns1:controla ns1:ReleEmergencia ;
    ns1:solucionaFallo ns1:ErrorCANResetCNC,
        ns1:ErrorCANValidacionParametros,
        ns1:ErrorSercosCANResetCNC,
        ns1:ErrorSercosCANValidacionParametros,
        ns1:ErrorSercosResetCNC,
        ns1:ErrorSercosValidacionParametros ;
    ns1:textoExtracto "SOLUCIÓN Corregir el problema en CAN o Sercos que impide que se cierre el relé de emergencia."@es .

ns1:ErrorCANResetCNC a ns1:AvisoSeguridad ;
    rdfs:label "Error en CAN durante un proceso de reset CNC"@es ;
    ns1:identificador "2" ;
    ns1:textoExtracto "VALOR 2 Error en CAN durante un proceso de reset CNC."@es .

ns1:ErrorCANValidacionParametros a ns1:AvisoSeguridad ;
    rdfs:label "Error en CAN durante un proceso de validación de parámetros máquina"@es ;
    ns1:identificador "8" ;
    ns1:textoExtracto "VALOR 8 Error en CAN durante un proceso de validación de parámetros máquina."@es .

ns1:ErrorSercosCANResetCNC a ns1:AvisoSeguridad ;
    rdfs:label "Error en Sercos y CAN durante un proceso de reset CNC"@es ;
    ns1:identificador "3" ;
    ns1:textoExtracto "VALOR 3 Error en Sercos y CAN durante un proceso de reset CNC."@es .

ns1:ErrorSercosCANValidacionParametros a ns1:AvisoSeguridad ;
    rdfs:label "Error en Sercos y CAN durante un proceso de validación de parámetros máquina"@es ;
    ns1:identificador "12" ;
    ns1:textoExtracto "VALOR 12 Error en Sercos y CAN durante un proceso de validación de parámetros máquina."@es .

ns1:ErrorSercosResetCNC a ns1:AvisoSeguridad ;
    rdfs:label "Error en Sercos durante un proceso de reset CNC"@es ;
    ns1:identificador "1" ;
    ns1:textoExtracto "VALOR 1 Error en Sercos durante un proceso de reset CNC."@es .

ns1:ErrorSercosValidacionParametros a ns1:AvisoSeguridad ;
    rdfs:label "Error en Sercos durante un proceso de validación de parámetros máquina"@es ;
    ns1:identificador "4" ;
    ns1:textoExtracto "VALOR 4 Error en Sercos durante un proceso de validación de parámetros máquina."@es .

ns1:ReleEmergencia a ns1:ComponenteElectrico ;
    rdfs:label "relé de emergencia"@es ;
    ns1:textoExtracto "el relé de emergencia ha quedado abierto"@es .

