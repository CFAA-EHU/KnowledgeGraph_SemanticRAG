@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlmacenCiclico a ns1:ComponenteMecanico ;
    rdfs:label "almacén cíclico" ;
    ns1:textoExtracto "El almacén es cíclico" .

ns1:CorrectorHerramienta a ns1:Parametro ;
    rdfs:label "corrector de herramienta" ;
    ns1:textoExtracto "Corrector de herramienta" .

ns1:HerramientaTierra a ns1:ComponenteElectrico ;
    rdfs:label "herramienta de tierra" ;
    ns1:textoExtracto "herramientas de tierra" .

ns1:PLC a ns1:Sistema ;
    rdfs:label "PLC" ;
    ns1:textoExtracto "rechazada por el PLC" .

ns1:ParametroMaquinaTierra a ns1:Parametro ;
    rdfs:label "parámetro máquina tierra" ;
    ns1:textoExtracto "parámetros máquina está especificado que no se admiten herramientas de tierra" .

ns1:TablaAlmacen a ns1:Tabla ;
    ns1:textoExtracto "tabla del almacén" .

ns1:TablaHerramientas a ns1:Tabla ;
    ns1:textoExtracto "tabla de herramientas" .

