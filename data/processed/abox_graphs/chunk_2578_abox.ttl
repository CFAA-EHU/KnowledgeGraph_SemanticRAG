@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:aviso7006 a ns1:AvisoSeguridad ;
    rdfs:label "D no admitida para esta herramienta"@es ;
    ns1:identificador "7006" ;
    ns1:textoExtracto "7006 'D no admitida para esta herramienta' DETECCIÓN Durante la ejecución. CAUSA Corrector de herramienta no válido. La herramienta tiene menos correctores que el programado."@es .

ns1:aviso7007 a ns1:AvisoSeguridad ;
    rdfs:label "En modo carga: T0 no admitida"@es ;
    ns1:identificador "7007" ;
    ns1:mitigaRiesgo ns1:almacenModoCarga ;
    ns1:textoExtracto "7007 'En modo carga:T0 no admitida' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo carga. No se permite programar T0."@es .

ns1:tareaProgramacionCorrectores a ns1:TareaMantenimiento ;
    rdfs:label "Programar correctores"@es ;
    ns1:ejecutadoPor ns1:herramientaConCorrectores ;
    ns1:textoExtracto "SOLUCIÓN Programar un corrector existente o añadir nuevos correctores a la herramienta."@es .

ns1:almacenModoCarga a ns1:ModoOperacion ;
    rdfs:label "Modo carga"@es ;
    ns1:identificador "7007" ;
    ns1:textoExtracto "Almacén en modo carga. No se permite programar T0."@es .

ns1:herramientaConCorrectores a ns1:Herramienta ;
    ns1:textoExtracto "La herramienta tiene menos correctores que el programado."@es .

