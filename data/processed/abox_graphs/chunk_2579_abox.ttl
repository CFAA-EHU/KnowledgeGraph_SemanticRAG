@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_7007 a ns1:AvisoSeguridad ;
    rdfs:label "'En modo carga:T0 no admitida'" ;
    ns1:identificador "7007" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_Carga ;
    ns1:textoExtracto "7007 'En modo carga:T0 no admitida' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo carga. No se permite programar T0. SOLUCIÓN Programar la herramienta a cargar en el almacén." .

ns1:AvisoSeguridad_7008 a ns1:AvisoSeguridad ;
    rdfs:label "'En modo carga:Esta herramienta ya esta cargada'" ;
    ns1:identificador "7008" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_Carga ;
    ns1:textoExtracto "7008 'En modo carga:Esta herramienta ya esta cargada' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo carga. La herramienta programada ya está en el almacén. SOLUCIÓN Programar una herramienta que no esté ya cargada." .

ns1:AvisoSeguridad_7009 a ns1:AvisoSeguridad ;
    rdfs:label "'En modo carga:M6 sin T'" ;
    ns1:identificador "7009" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_Carga ;
    ns1:textoExtracto "7009 'En modo carga:M6 sin T' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo carga. No se permite programar una M6 sin herramienta. SOLUCIÓN Programar la herramienta a cargar y a continuación la función M6." .

ns1:AvisoSeguridad_7010 a ns1:AvisoSeguridad ;
    rdfs:label "'En modo carga:T con dos M6'" ;
    ns1:identificador "7010" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_Carga ;
    ns1:textoExtracto "7010 'En modo carga:T con dos M6' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo carga. Hay programadas dos M6 consecutivas sin herramienta. SOLUCIÓN Programar la herramienta a cargar y a continuación la función M6." .

ns1:AvisoSeguridad_7011 a ns1:AvisoSeguridad ;
    rdfs:label "'En modo carga:D sola no admitida'" ;
    ns1:identificador "7011" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_Carga ;
    ns1:textoExtracto "7011 'En modo carga:D sola no admitida' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo carga. No se permite programar solo el corrector. SOLUCIÓN No se admite esta programación." .

ns1:AvisoSeguridad_7012 a ns1:AvisoSeguridad ;
    rdfs:label "'En modo carga:La herramienta esta gastada o rechazada'" ;
    ns1:identificador "7012" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_Carga ;
    ns1:textoExtracto "7012 'En modo carga:La herramienta esta gastada o rechazada' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo carga. La herramienta a cargar en el almacén está gastada o rechazada. SOLUCIÓN Programar una herramienta válida." .

ns1:AvisoSeguridad_7013 a ns1:AvisoSeguridad ;
    rdfs:label "'En modo carga:Posición inválida o no hay sitio en el almacén'" ;
    ns1:identificador "7013" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_Carga ;
    ns1:textoExtracto "7013 'En modo carga:Posición inválida o no hay sitio en el almacén' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo carga. El almacén está lleno o la posición especificada está ocupada. SOLUCIÓN Si no hay sitio en el almacén habrá que descargar previamente alguna herramienta. Si la posición especificada está ocupada, habrá que elegir otra ubicación." .

ns1:AvisoSeguridad_7014 a ns1:AvisoSeguridad ;
    rdfs:label "'En modo descarga:T no esta en el almacén'" ;
    ns1:identificador "7014" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_Descarga ;
    ns1:textoExtracto "7014 'En modo descarga:T no esta en el almacén' DETECCIÓN Durante la ejecución." .

ns1:Herramienta a ns1:Herramienta ;
    ns1:textoExtracto "Programar la herramienta a cargar en el almacén." .

ns1:ModoOperacion_Descarga a ns1:ModoOperacion ;
    rdfs:label "Modo descarga" ;
    ns1:textoExtracto "7014 'En modo descarga:T no esta en el almacén' DETECCIÓN Durante la ejecución." .

ns1:ModoOperacion_Carga a ns1:ModoOperacion ;
    rdfs:label "Modo carga" ;
    ns1:textoExtracto "Almacén en modo carga." .

