@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CicloG87 a ns1:TareaMantenimiento ;
    rdfs:label "G87. Face threading or thread repair canned cycle" ;
    ns1:identificador "G87" ;
    ns1:textoExtracto "Rosca frontal (en cara): análogo al anterior pero referenciado a coordenadas en X; retirada 'J' y tolerancias de penetración." .

ns1:CicloG88 a ns1:TareaMantenimiento ;
    rdfs:label "G88. Grooving canned cycle along the X axis" ;
    ns1:identificador "G88" ;
    ns1:textoExtracto "Ranurado axial con varias penetraciones 'C', seguridad 'D' y demora 'K'; el esquema muestra los escalones en X con fin en (Q,R)." .

ns1:CicloG89 a ns1:TareaMantenimiento ;
    rdfs:label "G89. Grooving canned cycle along the Z axis" ;
    ns1:identificador "G89" ;
    ns1:textoExtracto "Ranurado frontal con penetraciones en Z; idéntica representación de pasadas y retirada." .

ns1:HerramientaMotorizada_G160_G161_G162 a ns1:Herramienta ;
    rdfs:label "Herramienta motorizada para ciclos G160, G161 y G162" ;
    ns1:requiereMantenimiento ns1:CicloG160,
        ns1:CicloG161,
        ns1:CicloG162 ;
    ns1:textoExtracto "Iconografía de herramienta motorizada (S/N)" .

ns1:Parametro_C a ns1:Parametro ;
    rdfs:label "Parámetro C (penetraciones)" ;
    ns1:textoExtracto "varias penetraciones 'C' (G88)" ;
    ns1:valor "C" .

ns1:Parametro_D a ns1:Parametro ;
    rdfs:label "Parámetro D (seguridad)" ;
    ns1:textoExtracto "seguridad 'D' (G88, G160)" ;
    ns1:valor "D" .

ns1:Parametro_I a ns1:Parametro ;
    rdfs:label "Parámetro I (profundidad)" ;
    ns1:textoExtracto "profundidad 'I' (G162)" ;
    ns1:valor "I" .

ns1:Parametro_J a ns1:Parametro ;
    rdfs:label "Parámetro J (retirada o distribución angular)" ;
    ns1:textoExtracto "retirada 'J' (G87, G161), reparto angular (Q/A/J) (G160, G161, G162)" ;
    ns1:valor "J" .

ns1:Parametro_K a ns1:Parametro ;
    rdfs:label "Parámetro K (demora)" ;
    ns1:textoExtracto "demora 'K' (G88)" ;
    ns1:valor "K" .

ns1:Parametro_L a ns1:Parametro ;
    rdfs:label "Parámetro L (longitud)" ;
    ns1:textoExtracto "longitud 'L' (G162)" ;
    ns1:valor "L" .

ns1:Parametro_Q a ns1:Parametro ;
    rdfs:label "Parámetro Q (posición angular o inicio/fin)" ;
    ns1:textoExtracto "posición angular 'W' (G87), reparto angular (Q/A/J) (G160, G161, G162)" ;
    ns1:valor "Q" .

ns1:Parametro_R a ns1:Parametro ;
    rdfs:label "Parámetro R (fin de trayectoria)" ;
    ns1:textoExtracto "fin en (Q,R) (G87, G88)" ;
    ns1:valor "R" .

ns1:CicloG160 a ns1:TareaMantenimiento ;
    rdfs:label "G160. Drilling/tapping on the face of the part" ;
    ns1:identificador "G160" ;
    ns1:textoExtracto "Cilindro en cara con múltiples taladros repartidos angularmente (Q/A/J). Iconografía de herramienta motorizada (S/N) y seguridad 'D/H/C/R'." .

ns1:CicloG161 a ns1:TareaMantenimiento ;
    rdfs:label "G161. Drilling/tapping on the side of the part" ;
    ns1:identificador "G161" ;
    ns1:textoExtracto "Taladrado radial en el lateral del cilindro; distribución angular y parámetros análogos con seguridad a lo largo de X." .

ns1:CicloG162 a ns1:TareaMantenimiento ;
    rdfs:label "G162. Slot milling along the side of the part" ;
    ns1:identificador "G162" ;
    ns1:textoExtracto "Fresado ranura lateral: longitud 'L', profundidad 'I' y reparto angular (Q/A/J); se ilustra herramienta motorizada y sentido." .

