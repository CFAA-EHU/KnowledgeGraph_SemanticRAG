@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Almacen a ns1:Sistema ;
    rdfs:label "Almacén"@es ;
    ns1:textoExtracto "Si no hay sitio en el almacén habrá que descargar previamente alguna herramienta. [...] Almacén en modo descarga."@es ;
    ns1:tieneComponente ns1:HerramientaGenerica .

ns1:ModoDescarga a ns1:ModoOperacion ;
    rdfs:label "Modo descarga"@es ;
    ns1:activaAlarma ns1:Fallo_7014,
        ns1:Fallo_7015 ;
    ns1:textoExtracto "Almacén en modo descarga."@es .

ns1:Fallo_7014 a ns1:DiagnosticoFallo ;
    rdfs:label "En modo descarga: T no está en el almacén"@es ;
    ns1:identificador "7014" ;
    ns1:textoExtracto "7014 'En modo descarga:T no esta en el almacén' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo descarga. La herramienta no está en el almacén. SOLUCIÓN Programar una herramienta válida."@es .

ns1:Fallo_7015 a ns1:DiagnosticoFallo ;
    rdfs:label "En modo descarga: D no admitida junto con T"@es ;
    ns1:identificador "7015" ;
    ns1:textoExtracto "7015 'En modo descarga:D no admitida junto con T' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo descarga."@es .

ns1:HerramientaGenerica a ns1:Herramienta ;
    rdfs:label "Herramienta"@es ;
    ns1:textoExtracto "La herramienta no está en el almacén. SOLUCIÓN Programar una herramienta válida."@es .

