@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Almacen a ns1:Sistema ;
    rdfs:label "Almacén" ;
    ns1:textoExtracto "Almacén en modo descarga." .

ns1:CorrectorD a ns1:Parametro ;
    rdfs:label "Corrector D" ;
    ns1:identificador "D" ;
    ns1:textoExtracto "No se permite programar el corrector junto a la herramienta." .

ns1:Error7015 a ns1:AvisoSeguridad ;
    rdfs:label "Error 7015: 'En modo descarga: D no admitida junto con T'" ;
    ns1:identificador "7015" ;
    ns1:textoExtracto "7015 'En modo descarga:D no admitida junto con T' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo descarga. No se permite programar el corrector junto a la herramienta. SOLUCIÓN No se admite esta programación." .

ns1:Error7016 a ns1:AvisoSeguridad ;
    rdfs:label "Error 7016: 'En modo descarga: D sola no admitida'" ;
    ns1:identificador "7016" ;
    ns1:textoExtracto "7016 'En modo descarga:D sola no admitida' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo descarga. No se permite programar solo el corrector. SOLUCIÓN No se admite esta programación." .

ns1:Error7017 a ns1:AvisoSeguridad ;
    rdfs:label "Error 7017: 'En modo descarga: M6 sin T'" ;
    ns1:identificador "7017" ;
    ns1:textoExtracto "7017 'En modo descarga:M6 sin T' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo descarga. No se permite programar una M6 sin herramienta. SOLUCIÓN Programar la herramienta a descargar y a continuación la función M6." .

ns1:Error7018 a ns1:AvisoSeguridad ;
    rdfs:label "Error 7018: 'En modo descarga: T con dos M6'" ;
    ns1:identificador "7018" ;
    ns1:textoExtracto "7018 'En modo descarga:T con dos M6' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo descarga. Hay programadas dos M06 consecutivas para una misma herramienta. SOLUCIÓN Programar la herramienta a descargar y a continuación la función M6." .

ns1:Error7019 a ns1:AvisoSeguridad ;
    rdfs:label "Error 7019: 'En modo setting: T0 no admitida'" ;
    ns1:identificador "7019" ;
    ns1:textoExtracto "7019 'En modo setting:T0 no admitida' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo setting. No se permite programar T0. SOLUCIÓN Programar una herramienta diferente de 0." .

ns1:Error7020 a ns1:AvisoSeguridad ;
    rdfs:label "Error 7020: 'En modo setting: D obligatoria'" ;
    ns1:identificador "7020" ;
    ns1:textoExtracto "7020 'En modo setting:D obligatoria' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo setting. Falta programar el corrector. SOLUCIÓN Programar el corrector." .

ns1:Error7021 a ns1:AvisoSeguridad ;
    rdfs:label "Error 7021: 'En modo setting: D sola no admitida'" ;
    ns1:identificador "7021" ;
    ns1:textoExtracto "7021 'En modo setting:D sola no admitida' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo setting. No se permite programar solo el corrector. SOLUCIÓN No se admite esta programación." .

ns1:Error7022 a ns1:AvisoSeguridad ;
    rdfs:label "Error 7022: 'En modo setting: M6 no admitida'" ;
    ns1:identificador "7022" ;
    ns1:textoExtracto "7022 'En modo setting:M6 no admitida' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo setting. No se permite programar M06. SOLUCIÓN No se admite esta programación." .

ns1:Error7023 a ns1:AvisoSeguridad ;
    rdfs:label "Error 7023: 'En modo carga: M6 obligatoria'" ;
    ns1:identificador "7023" ;
    ns1:textoExtracto "2023 'En modo carga:M6 obligatoria' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo carga." .

ns1:FuncionM6 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función M6" ;
    ns1:identificador "M6" ;
    ns1:textoExtracto "Programar la herramienta a descargar y a continuación la función M6." .

ns1:ModoCarga a ns1:ModoOperacion ;
    rdfs:label "Modo carga" ;
    ns1:textoExtracto "Almacén en modo carga." .

ns1:ModoDescarga a ns1:ModoOperacion ;
    rdfs:label "Modo descarga" ;
    ns1:textoExtracto "Almacén en modo descarga." .

ns1:ModoSetting a ns1:ModoOperacion ;
    rdfs:label "Modo setting" ;
    ns1:textoExtracto "Almacén en modo setting." .

ns1:Herramienta a ns1:Herramienta ;
    rdfs:label "Herramienta" ;
    ns1:textoExtracto "herramienta no está en el almacén. SOLUCIÓN Programar una herramienta válida." .

