@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error7023 a ns1:AvisoSeguridad ;
    rdfs:label "Error 7023: 'En modo carga: M6 obligatoria'" ;
    ns1:identificador "7023" ;
    ns1:mitigaRiesgo ns1:HerramientaM06 ;
    ns1:textoExtracto "7023 'En modo carga:M6 obligatoria' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo carga. Hay programadas dos herramientas consecutivas sin M06 SOLUCIÓN Programar M06 detrás de cada herramienta." .

ns1:Error7024 a ns1:AvisoSeguridad ;
    rdfs:label "Error 7024: 'En modo descarga: T0 no admitida'" ;
    ns1:identificador "7024" ;
    ns1:mitigaRiesgo ns1:HerramientaT0 ;
    ns1:textoExtracto "7024 'En modo descarga:T0 no admitida' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo descarga. No se permite programar T0." .

ns1:ErrorModoSetting a ns1:AvisoSeguridad ;
    rdfs:label "Error: Almacén en modo setting (M06 no permitido)" ;
    ns1:textoExtracto "CAUSA Almacén en modo setting. No se permite programar M06. SOLUCIÓN No se admite esta programación." .

ns1:ModoCarga a ns1:ModoOperacion ;
    rdfs:label "Modo carga" ;
    ns1:textoExtracto "Almacén en modo carga. Hay programadas dos herramientas consecutivas sin M06" .

ns1:ModoDescarga a ns1:ModoOperacion ;
    rdfs:label "Modo descarga" ;
    ns1:textoExtracto "Almacén en modo descarga. No se permite programar T0" .

ns1:ModoSetting a ns1:ModoOperacion ;
    rdfs:label "Modo setting" ;
    ns1:textoExtracto "Almacén en modo setting. No se permite programar M06" .

ns1:HerramientaM06 a ns1:Herramienta ;
    rdfs:label "Herramienta M06" ;
    ns1:identificador "M06" ;
    ns1:textoExtracto "Programar M06 detrás de cada herramienta" .

ns1:HerramientaT0 a ns1:Herramienta ;
    rdfs:label "Herramienta T0" ;
    ns1:identificador "T0" ;
    ns1:textoExtracto "No se permite programar T0" .

