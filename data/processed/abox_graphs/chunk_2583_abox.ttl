@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_ProgramarT0EnModoDescarga a ns1:AccionProhibida ;
    rdfs:label "Programar T0 en modo descarga" ;
    ns1:documentadoEn ns1:AvisoSeguridad_7024 ;
    ns1:textoExtracto "No se permite programar T0." .

ns1:AvisoSeguridad_7026 a ns1:AvisoSeguridad ;
    rdfs:label "'En modo descarga:Esta herramienta ya está descargada'" ;
    ns1:identificador "7026" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_Descarga ;
    ns1:textoExtracto "7026 'En modo descarga:Esta herramienta ya está descargada' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo descarga. La herramienta no está en el almacén. SOLUCIÓN Programar la herramienta a descargar en el almacén." .

ns1:AvisoSeguridad_7027 a ns1:AvisoSeguridad ;
    rdfs:label "'M6 sin T'" ;
    ns1:identificador "7027" ;
    ns1:textoExtracto "7027 'M6 sin T' DETECCIÓN Durante la ejecución. CAUSA Hay programada una M06 sin su correspondiente herramienta." .

ns1:Herramienta_Gen_rica a ns1:Herramienta ;
    rdfs:label "Herramienta" ;
    ns1:textoExtracto "Programar la herramienta a descargar en el almacén." .

ns1:TareaMantenimiento_ProgramarM06 a ns1:TareaMantenimiento ;
    rdfs:label "Programar M06 detrás de cada herramienta" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_7024,
        ns1:AvisoSeguridad_7025 ;
    ns1:textoExtracto "Programar M06 detrás de cada herramienta." .

ns1:AvisoSeguridad_7025 a ns1:AvisoSeguridad ;
    rdfs:label "'En modo descarga:M6 obligatoria'" ;
    ns1:identificador "7025" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_Descarga ;
    ns1:textoExtracto "7025 'En modo descarga:M6 obligatoria' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo descarga. Hay programadas dos herramientas consecutivas sin M06. SOLUCIÓN Programar M06 detrás de cada herramienta." .

ns1:AvisoSeguridad_7024 a ns1:AvisoSeguridad ;
    rdfs:label "'En modo descarga:T0 no admitida'" ;
    ns1:identificador "7024" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_Descarga ;
    ns1:textoExtracto "7024 'En modo descarga:T0 no admitida' DETECCIÓN Durante la ejecución. CAUSA Almacén en modo descarga. No se permite programar T0. SOLUCIÓN Programar la herramienta a descargar en el almacén." .

ns1:ModoOperacion_Descarga a ns1:ModoOperacion ;
    rdfs:label "Modo descarga" ;
    ns1:textoExtracto "Almacén en modo descarga." .

