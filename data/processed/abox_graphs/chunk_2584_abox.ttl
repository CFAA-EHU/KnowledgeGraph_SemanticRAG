@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_7027 a ns1:AvisoSeguridad ;
    rdfs:label "Error 'M6 sin T'"@es ;
    ns1:identificador "7027" ;
    ns1:solucionaFallo ns1:Solucion_7027 ;
    ns1:textoExtracto "Durante la ejecución. CAUSA Hay programada una M06 sin su correspondiente herramienta. Hay un parámetro máquina que indica al CNC qué hacer en esta situación, mostrar un error, un warning o no hacer nada."@es .

ns1:Error_7028 a ns1:AvisoSeguridad ;
    rdfs:label "Error 'T0 no admitida'"@es ;
    ns1:identificador "7028" ;
    ns1:textoExtracto "Durante la ejecución. CAUSA El almacén de tipo torreta no admite T0. En un almacén tipo torreta, el cambio de herramienta se realiza girando la torreta; basta con programar la herramienta."@es .

ns1:Error_7029 a ns1:Alarma ;
    rdfs:label "Error 'Gestor de herramientas en estado de error'"@es ;
    ns1:activaAlarma ns1:Sistema_GestionHerramientas ;
    ns1:identificador "7029" ;
    ns1:textoExtracto "Durante la ejecución. CAUSA Almacén en estado de emergencia. El PLC ha activado una marca no válida de la maniobra, el PLC ha activado la marca SETTMEM o hay un error en la maniobra."@es .

ns1:Herramienta_7027 a ns1:Herramienta ;
    rdfs:label "Herramienta requerida para M06"@es ;
    ns1:textoExtracto "Hay programada una M06 sin su correspondiente herramienta."@es .

ns1:Parametro_7027 a ns1:Parametro ;
    rdfs:label "Parámetro máquina para M06 sin herramienta"@es ;
    ns1:monitoreaParametro ns1:Maquina_CNC ;
    ns1:textoExtracto "Hay un parámetro máquina que indica al CNC qué hacer en esta situación, mostrar un error, un warning o no hacer nada."@es .

ns1:Sistema_GestionHerramientas a ns1:Sistema ;
    rdfs:label "Gestor de herramientas"@es ;
    ns1:controla ns1:Almacen_Torreta ;
    ns1:textoExtracto "Gestor de herramientas en estado de error"@es .

ns1:Solucion_7027 a ns1:TareaMantenimiento ;
    rdfs:label "Solución para error 7027"@es ;
    ns1:textoExtracto "Programar una herramienta y a continuación la función M06 o modificar el parámetro máquina para cambiar el comportamiento del CNC."@es .

ns1:Almacen_Torreta a ns1:ComponenteMecanico ;
    rdfs:label "Almacén de herramientas tipo torreta"@es ;
    ns1:textoExtracto "El almacén de tipo torreta no admite T0. En un almacén tipo torreta, el cambio de herramienta se realiza girando la torreta."@es ;
    ns1:tieneComponente ns1:Maquina_CNC .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC"@es ;
    ns1:textoExtracto "parámetro máquina que indica al CNC qué hacer"@es ;
    ns1:tieneComponente ns1:Almacen_Torreta .

