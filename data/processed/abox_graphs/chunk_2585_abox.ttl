@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_7030_M6sinT a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 7030 'M6 sin T'" ;
    ns1:identificador "7030" ;
    ns1:solucionaFallo ns1:CorreccionDeProgramaPLCParaManiobraDeCambioDeHerramienta ;
    ns1:textoExtracto "7030 'M6 sin T' DETECCIÓN Durante la ejecución. CAUSA Hay programada una M06 sin su correspondiente herramienta." .

ns1:MarcaSETTMEM a ns1:Parametro ;
    rdfs:label "Marca SETTMEM (señal de emergencia)" ;
    ns1:monitoreaParametro ns1:SenalDeEmergenciaActivadaPorSETTMEM ;
    ns1:textoExtracto "el PLC ha activado la marca SETTMEM" .

ns1:ParametroMaquina_M06 a ns1:Parametro ;
    rdfs:label "Parámetro máquina para M06 sin herramienta" ;
    ns1:textoExtracto "Hay un parámetro máquina que indica al CNC qué hacer en esta situación, mostrar un error, un warning o no" ;
    ns1:valor "error/warning/ninguno" .

ns1:CorreccionDeProgramaPLCParaManiobraDeCambioDeHerramienta a ns1:AccionProhibida ;
    rdfs:label "Corrección de programa PLC para maniobra de cambio de herramienta" ;
    ns1:textoExtracto "SOLUCIÓN Corregir en el programa de PLC la maniobra de cambio de herramienta." .

ns1:SenalDeEmergenciaActivadaPorSETTMEM a ns1:AvisoSeguridad ;
    rdfs:label "Señal de emergencia activada por SETTMEM" ;
    ns1:textoExtracto "corregir la causa por la que el PLC ha puesto la señal de emergencia." .

