@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_7034 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de operación: No se pudo encontrar sitio en almacén"@es ;
    ns1:identificador "7034" ;
    ns1:solucionaFallo ns1:Accion_ComprobarProgramaPLC ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA La maniobra del PLC genera error. SOLUCIÓN Comprobar el programa de PLC."@es .

ns1:Fallo_7035 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la tabla de almacenamiento"@es ;
    ns1:identificador "7035" ;
    ns1:solucionaFallo ns1:Accion_ComprobarEstadoAlmacen ;
    ns1:textoExtracto "DETECCIÓN Durante la ejecución. CAUSA Error en el almacén durante una maniobra. SOLUCIÓN Comprobar el estado del almacén. Es posible que no haya sitio libre en el almacén."@es .

ns1:Fallo_7036 a ns1:DiagnosticoFallo ;
    rdfs:label "No se admite cambio de familia para herramientas en el almacén o en el cabezal"@es ;
    ns1:identificador "7036" ;
    ns1:solucionaFallo ns1:Accion_DescargarHerramienta ;
    ns1:textoExtracto "DETECCIÓN Durante la edición de tablas o durante la ejecución. CAUSA Por motivos de seguridad no se puede cambiar la familia de una herramienta que está en el almacén. SOLUCIÓN Descargar primero la herramienta."@es .

ns1:Fallo_EmergenciaPLC a ns1:DiagnosticoFallo ;
    rdfs:label "Señal de emergencia activada por PLC en gestor de herramientas"@es ;
    ns1:solucionaFallo ns1:Accion_AnalizarCausasEmergencia ;
    ns1:textoExtracto "CAUSA El PLC activa la señal de emergencia en el gestor de herramientas. SOLUCIÓN Quitar la emergencia y analizar las causas por las que el PLC la ha activado."@es .

ns1:SistemaGestorHerramientas a ns1:Sistema ;
    rdfs:label "Gestor de herramientas"@es ;
    ns1:textoExtracto "El PLC activa la señal de emergencia en el gestor de herramientas."@es ;
    ns1:tieneComponente ns1:Componente_PLC .

ns1:Accion_AnalizarCausasEmergencia a ns1:TareaMantenimiento ;
    rdfs:label "Quitar la emergencia y analizar las causas por las que el PLC la ha activado"@es ;
    ns1:textoExtracto "SOLUCIÓN Quitar la emergencia y analizar las causas por las que el PLC la ha activado."@es .

ns1:Accion_ComprobarEstadoAlmacen a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar el estado del almacén"@es ;
    ns1:textoExtracto "SOLUCIÓN Comprobar el estado del almacén."@es .

ns1:Accion_ComprobarProgramaPLC a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar el programa de PLC"@es ;
    ns1:textoExtracto "SOLUCIÓN Comprobar el programa de PLC."@es .

ns1:Accion_DescargarHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Descargar primero la herramienta"@es ;
    ns1:textoExtracto "SOLUCIÓN Descargar primero la herramienta."@es .

ns1:Alarma_Emergencia a ns1:Alarma ;
    rdfs:label "Señal de emergencia"@es ;
    ns1:textoExtracto "El PLC activa la señal de emergencia en el gestor de herramientas."@es .

ns1:Componente_PLC a ns1:ComponenteElectrico ;
    rdfs:label "PLC del sistema"@es ;
    ns1:activaAlarma ns1:Alarma_Emergencia ;
    ns1:textoExtracto "El PLC activa la señal de emergencia en el gestor de herramientas."@es .

