@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_CambioHerramientaEnAlmacen a ns1:AccionProhibida ;
    rdfs:label "Cambiar familia de herramienta en almacén sin descarga previa"@es ;
    ns1:textoExtracto "Por motivos de seguridad no se puede cambiar la familia de una herramienta que está en el almacén. SOLUCIÓN Descargar primero la herramienta."@es .

ns1:ModoOperacion_CARGA a ns1:ModoOperacion ;
    rdfs:label "Modo CARGA"@es ;
    ns1:textoExtracto "modo carga"@es .

ns1:ModoOperacion_DESCARGA a ns1:ModoOperacion ;
    rdfs:label "Modo DESCARGA"@es ;
    ns1:textoExtracto "modo descarga"@es .

ns1:Sistema_Almacen a ns1:Sistema ;
    rdfs:label "Sistema de almacén"@es ;
    ns1:requiereMantenimiento ns1:TareaMantenimiento_VaciarCabezal ;
    ns1:textoExtracto "almacén"@es ;
    ns1:tieneComponente ns1:Componente_Cabezal .

ns1:TareaMantenimiento_DescargarHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Descargar herramienta del almacén"@es ;
    ns1:solucionaFallo ns1:Fallo_7037 ;
    ns1:textoExtracto "Descargar primero la herramienta"@es .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal del almacén"@es ;
    ns1:textoExtracto "el cabezal (y los brazos en los almacenes donde proceda) vacíos"@es .

ns1:Fallo_7039 a ns1:DiagnosticoFallo ;
    rdfs:label "No puede cambiarse el modo del almacén con cabezal ocupado"@es ;
    ns1:identificador "7039" ;
    ns1:textoExtracto "No puede [cambiarse el modo del almacén a modo carga o descarga si el cabezal no está vacío]."@es .

ns1:TareaMantenimiento_VaciarCabezal a ns1:TareaMantenimiento ;
    rdfs:label "Vaciar cabezal y brazos del almacén"@es ;
    ns1:solucionaFallo ns1:Fallo_7037,
        ns1:Fallo_7039 ;
    ns1:textoExtracto "Vaciar el cabezal y los brazos"@es .

ns1:Fallo_7037 a ns1:DiagnosticoFallo ;
    rdfs:label "El cabezal tiene que estar vacío para los modos CARGA o DESCARGA"@es ;
    ns1:identificador "7037" ;
    ns1:textoExtracto "El cabezal tiene que estar vacío para los modos CARGA o DESCARGA. DETECCIÓN Durante la ejecución. CAUSA Para cambiar el modo del almacén a modo carga o descarga hay que tener el cabezal (y los brazos en los almacenes donde proceda) vacíos."@es .

