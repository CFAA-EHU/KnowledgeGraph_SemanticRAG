@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Herramienta_HerramientaMotorizada_G163 a ns1:Herramienta ;
    rdfs:label "Herramienta motorizada para fresado de ranura (G163)"@es ;
    ns1:textoExtracto "se ilustra herramienta motorizada y sentido."@es .

ns1:Herramienta_SondaPalpado a ns1:Herramienta ;
    rdfs:label "Sonda de palpado para ciclos #PROBE"@es ;
    ns1:textoExtracto "Tres viñetas (sonda en eje y contactos laterales) con cotas de seguridad 'B', velocidades de palpado y posiciones relativas."@es .

ns1:Parametro_Seguridad_B a ns1:Parametro ;
    rdfs:label "Cota de seguridad 'B' (distancia)"@es ;
    ns1:textoExtracto "cotas de seguridad 'B'."@es ;
    ns1:valor "B" .

ns1:Parametro_Seguridad_D a ns1:Parametro ;
    rdfs:label "Seguridad 'D' en eje Z"@es ;
    ns1:textoExtracto "seguridad 'D' en Z."@es ;
    ns1:valor "D" .

ns1:Parametro_Seguridad_E a ns1:Parametro ;
    rdfs:label "Retirada 'E' (distancia)"@es ;
    ns1:textoExtracto "retirada 'E'."@es ;
    ns1:valor "E" .

ns1:Parametro_Tolerancia_L a ns1:Parametro ;
    rdfs:label "Tolerancia 'L' (planitud)"@es ;
    ns1:textoExtracto "tolerancia 'L'."@es ;
    ns1:valor "L" .

ns1:TareaMantenimiento_G163_SlotMilling a ns1:TareaMantenimiento ;
    rdfs:label "Fresado de ranura lateral (G163)"@es ;
    ns1:ilustradoEn ns1:Figura_G163_SlotMilling ;
    ns1:textoExtracto "Fresado ranura lateral: longitud 'L', profundidad 'I' y reparto angular (Q/A/J); se ilustra herramienta motorizada y sentido."@es .

ns1:TareaMantenimiento_Probe1_ToolCalibration a ns1:TareaMantenimiento ;
    rdfs:label "#PROBE 1. Calibración de herramienta (dimensiones y desgaste)"@es ;
    ns1:ilustradoEn ns1:Figura_Probe1_ToolCalibration ;
    ns1:requiereEPI ns1:EPI_SondaPalpado ;
    ns1:textoExtracto "Tres viñetas (sonda en eje y contactos laterales) con cotas de seguridad 'B', velocidades de palpado y posiciones relativas; flechas muestran la trayectoria de la sonda respecto a herramienta y mesa."@es .

ns1:TareaMantenimiento_Probe2_OrificioPatron a ns1:TareaMantenimiento ;
    rdfs:label "#PROBE 2. Palpado de orificio patrón"@es ;
    ns1:ilustradoEn ns1:Figura_Probe2_OrificioPatron ;
    ns1:textoExtracto "Palpado de un orificio patrón: plano XY con centro (X,Y), profundidad Z y retirada 'E'; se ven dos velocidades de palpado y distancias de seguridad."@es .

ns1:TareaMantenimiento_Probe3_Surfacing a ns1:TareaMantenimiento ;
    rdfs:label "#PROBE 3. Medición de planitud"@es ;
    ns1:ilustradoEn ns1:Figura_Probe3_Surfacing ;
    ns1:textoExtracto "Medición de planitud con sonda recorriendo una cara; se señalan tolerancia 'L', eje de palpado 'K' y correcciones de desgaste (T/D)."@es .

ns1:TareaMantenimiento_Probe4_OutsideCorner a ns1:TareaMantenimiento ;
    rdfs:label "#PROBE 4. Palpado de esquina exterior"@es ;
    ns1:ilustradoEn ns1:Figura_Probe4_OutsideCorner ;
    ns1:textoExtracto "Palpado de esquina exterior con flechas hacia caras X/Y; se destaca distancia de seguridad 'B' y avance de palpado 'F'."@es .

ns1:TareaMantenimiento_Probe5_InsideCorner a ns1:TareaMantenimiento ;
    rdfs:label "#PROBE 5. Palpado de esquina interior"@es ;
    ns1:ilustradoEn ns1:Figura_Probe5_InsideCorner ;
    ns1:textoExtracto "Palpado de esquina interior (descripción implícita en contexto de ciclos de palpado)."@es .

ns1:EPI_SondaPalpado a ns1:EPI ;
    rdfs:label "Equipo de protección para operaciones de palpado"@es ;
    ns1:textoExtracto "Operaciones de palpado con sonda (implícito uso de EPI estándar para fresadora CNC)."@es .

ns1:Figura_G163_SlotMilling a ns1:Figura ;
    rdfs:label "Esquema de fresado de ranura lateral (G163)"@es ;
    ns1:textoExtracto "Fresado ranura lateral: longitud 'L', profundidad 'I' y reparto angular (Q/A/J); esquema con pieza en vista lateral."@es .

ns1:Figura_Probe1_ToolCalibration a ns1:Figura ;
    rdfs:label "Diagrama de calibración de herramienta (#PROBE 1)"@es ;
    ns1:textoExtracto "Tres viñetas (sonda en eje y contactos laterales) con cotas de seguridad 'B'."@es .

ns1:Figura_Probe2_OrificioPatron a ns1:Figura ;
    rdfs:label "Esquema de palpado de orificio patrón (#PROBE 2)"@es ;
    ns1:textoExtracto "Plano XY con centro (X,Y), profundidad Z y retirada 'E'."@es .

ns1:Figura_Probe3_Surfacing a ns1:Figura ;
    rdfs:label "Representación de medición de planitud (#PROBE 3)"@es ;
    ns1:textoExtracto "Sonda recorriendo una cara; tolerancia 'L', eje de palpado 'K'."@es .

ns1:Figura_Probe4_OutsideCorner a ns1:Figura ;
    rdfs:label "Palpado de esquina exterior (#PROBE 4)"@es ;
    ns1:textoExtracto "Flechas hacia caras X/Y; distancia de seguridad 'B' y avance 'F'."@es .

ns1:Figura_Probe5_InsideCorner a ns1:Figura ;
    rdfs:label "Palpado de esquina interior (#PROBE 5)"@es ;
    ns1:textoExtracto "Esquema implícito en descripción de ciclo #PROBE 5."@es .

