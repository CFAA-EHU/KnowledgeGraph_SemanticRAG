@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error7044 a ns1:AvisoSeguridad ;
    rdfs:label "Error 7044: No se puede modificar el número de filos de la herramienta activa"@es ;
    ns1:solucionaFallo ns1:Solucion7044_AlmacenTierra ;
    ns1:textoExtracto "7044 'No se puede modificar el número de filos de la herramienta activa' DETECCIÓN Durante la ejecución. CAUSA Ha intentado cambiar el numero de filos de una herramienta y esa herramienta está activa en algún canal."@es .

ns1:Error7045 a ns1:AvisoSeguridad ;
    rdfs:label "Error 7045: Información insuficiente para operación (almacén no determinado)"@es ;
    ns1:textoExtracto "7045 No hay suficiente información para la operación, el almacén no esta determinado. DETECCIÓN Durante la ejecución. CAUSA La herramienta programada no está en el almacén."@es .

ns1:HerramientaProgramada7045 a ns1:Herramienta ;
    ns1:textoExtracto "herramienta programada no está en el almacén"@es .

ns1:HerramientaActiva7044 a ns1:Herramienta ;
    ns1:textoExtracto "herramienta activa en algún canal"@es .

ns1:Solucion7044_AlmacenTierra a ns1:TareaMantenimiento ;
    rdfs:label "Colocar herramienta en almacén o en tierra para modificar número de filos"@es ;
    ns1:ejecutadoPor ns1:Personal ;
    ns1:requiereMantenimiento ns1:HerramientaActiva7044 ;
    ns1:textoExtracto "SOLUCIÓN Colocar la herramienta en el almacén o en tierra para modificar el número de filos."@es .

