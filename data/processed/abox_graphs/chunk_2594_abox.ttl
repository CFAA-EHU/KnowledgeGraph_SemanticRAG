@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:alarma7050 a ns1:Alarma ;
    rdfs:label "7050 ROTATEMZ: Posición no válida" ;
    ns1:activaAlarma ns1:almacenTorreta ;
    ns1:identificador "7050" ;
    ns1:textoExtracto "7050 ROTATEMZ: Posición no válida. DETECCIÓN Durante la ejecución. CAUSA La posición programada en #ROTATEMZ no es válida. SOLUCIÓN Revisar la programación." .

ns1:herramientaFilos a ns1:Herramienta ;
    rdfs:label "Herramienta de filos" ;
    ns1:activaAlarma ns1:alarma7051 ;
    ns1:textoExtracto "La herramienta tiene menos filos que el programado" .

ns1:alarma7051 a ns1:Alarma ;
    rdfs:label "7051 Número de filo no válido" ;
    ns1:identificador "7051" ;
    ns1:textoExtracto "7051 'Número de filo no válido' DETECCIÓN Durante la ejecución. CAUSA La herramienta tiene menos filos que el programado. SOLUCIÓN Programar un filo existente o añadir nuevos filos a la herramienta." .

ns1:almacenTorreta a ns1:ComponenteMecanico ;
    rdfs:label "Almacén torreta" ;
    ns1:textoExtracto "almacén torreta" .

