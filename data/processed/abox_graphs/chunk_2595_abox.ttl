@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:activaAlarma ns1:Error_8000,
        ns1:Error_8001,
        ns1:Error_8002,
        ns1:Error_8003,
        ns1:Error_8004,
        ns1:Error_8005,
        ns1:Error_8006 ;
    ns1:textoExtracto "CNC (referenciado en errores 8000-8006 como sistema principal de control numérico)" .

ns1:Error_8000 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8000: Kernel de simulación no activado" ;
    ns1:identificador "8000" ;
    ns1:solucionaFallo ns1:SolucionParaError8000 ;
    ns1:textoExtracto "'El Kernel de simulación no se encuentra activado' DETECCIÓN Durante el arranque del sistema. CAUSA El kernel de simulación está arrancado pero no está activado." .

ns1:Error_8001 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8001: Kernel de simulación no activado" ;
    ns1:identificador "8001" ;
    ns1:solucionaFallo ns1:SolucionParaError8001 ;
    ns1:textoExtracto "'El Kernel de simulación no se encuentra activado' DETECCIÓN Durante el arranque del sistema. CAUSA El kernel de simulación está arrancado pero no está activado." .

ns1:Error_8002 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8002: Fallo en registro de tecla" ;
    ns1:identificador "8002" ;
    ns1:solucionaFallo ns1:SolucionParaError8002 ;
    ns1:textoExtracto "'Error registrando tecla' DETECCIÓN Durante el arranque del sistema. CAUSA EL CNC no ha podido registrar alguna de las softkeys o de las teclas de acceso rápido." .

ns1:Error_8003 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8003: Cierre no permitido durante ejecución" ;
    ns1:identificador "8003" ;
    ns1:solucionaFallo ns1:SolucionParaError8003 ;
    ns1:textoExtracto "'Cierre no permitido mientras se encuentre en ejecución o interrumpido' DETECCIÓN Durante la ejecución. CAUSA No está permitido cerrar el CNC si se encuentra en ejecución, interrumpido o tiene algún eje ocupado en motion control." .

ns1:Error_8004 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8004: Cierre no permitido por canal en ejecución" ;
    ns1:identificador "8004" ;
    ns1:solucionaFallo ns1:SolucionParaError8004 ;
    ns1:textoExtracto "'Cierre no permitido mientras algún canal se encuentre en ejecución o interrumpido' DETECCIÓN Durante la ejecución. CAUSA No está permitido cerrar el CNC si algún canal se encuentra en ejecución, interrumpido o tiene algún eje ocupado en motion control." .

ns1:Error_8005 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8005: Cambio de modo no permitido" ;
    ns1:identificador "8005" ;
    ns1:solucionaFallo ns1:SolucionParaError8005 ;
    ns1:textoExtracto "'Cambio de modo no permitido mientras algún canal del grupo se encuentre en ejecución' DETECCIÓN Durante la ejecución. CAUSA No está permitido cambiar de modo si algún canal del grupo se encuentra en ejecución." .

ns1:Error_8006 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8006: Fallo en proceso de carga" ;
    ns1:identificador "8006" ;
    ns1:textoExtracto "'Error iniciando proceso de carga' DETECCIÓN Durante el arranque del sistema. CAUSA Error en la preparación del proceso de carga de la COMPCI o los módulos remotos." .

ns1:SolucionParaError8000 a ns1:DiagnosticoFallo ;
    rdfs:label "Solución para error 8000" ;
    ns1:textoExtracto "Comprobar si el CNC ha arrancado correctamente. Apagar y encender el CNC. Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:SolucionParaError8001 a ns1:DiagnosticoFallo ;
    rdfs:label "Solución para error 8001" ;
    ns1:textoExtracto "Comprobar si el CNC ha arrancado correctamente." .

ns1:SolucionParaError8002 a ns1:DiagnosticoFallo ;
    rdfs:label "Solución para error 8002" ;
    ns1:textoExtracto "Comprobar si el CNC ha arrancado correctamente." .

ns1:SolucionParaError8003 a ns1:DiagnosticoFallo ;
    rdfs:label "Solución para error 8003" ;
    ns1:textoExtracto "Detener los programas en ejecución." .

ns1:SolucionParaError8004 a ns1:DiagnosticoFallo ;
    rdfs:label "Solución para error 8004" ;
    ns1:textoExtracto "Detener los programas en ejecución." .

ns1:SolucionParaError8005 a ns1:DiagnosticoFallo ;
    rdfs:label "Solución para error 8005" ;
    ns1:textoExtracto "Detener los programas en ejecución de todos los canales del grupo." .

