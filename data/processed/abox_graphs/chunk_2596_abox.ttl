@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_Arranque a ns1:Sistema ;
    rdfs:label "Sistema de arranque y carga de programas"@es ;
    ns1:activaAlarma ns1:Error_8006,
        ns1:Error_8007 ;
    ns1:monitoreaParametro ns1:Parametro_CANMODE ;
    ns1:textoExtracto "Durante el arranque del sistema... proceso de carga de la COMPCI o los módulos remotos... Error cargando programa de la COMPCI"@es .

ns1:TareaMantenimiento_VerificacionCOMPCI a ns1:TareaMantenimiento ;
    rdfs:label "Verificación de COMPCI y driver de comunicaciones"@es ;
    ns1:solucionaFallo ns1:Error_8006 ;
    ns1:textoExtracto "Verificar el reconocimiento de la COMPCI... y la instalación del driver de comunicaciones."@es .

ns1:Error_8007 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8007: Error cargando programa de la COMPCI"@es ;
    ns1:identificador "8007" ;
    ns1:textoExtracto "'Error cargando programa de la COMPCI'"@es .

ns1:Parametro_CANMODE a ns1:Parametro ;
    rdfs:label "Parámetro CANMODE"@es ;
    ns1:textoExtracto "el valor del parámetro CANMODE"@es .

ns1:Error_8006 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8006: Error iniciando proceso de carga"@es ;
    ns1:identificador "8006" ;
    ns1:textoExtracto "'Error iniciando proceso de carga' DETECCIÓN Durante el arranque del sistema. CAUSA Error en la preparación del proceso de carga de la COMPCI o los módulos remotos."@es .

