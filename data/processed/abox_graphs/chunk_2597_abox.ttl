@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8007 a ns1:DiagnosticoFallo ;
    rdfs:label "Error cargando programa de la COMPCI" ;
    ns1:identificador "8007" ;
    ns1:solucionaFallo ns1:COMPCI ;
    ns1:textoExtracto "'Error cargando programa de la COMPCI' DETECCIÓN Durante el arranque del sistema. CAUSA Error durante el proceso de carga de la COMPCI. SOLUCIÓN Verificar el reconocimiento y correcta instalación de la COMPCI." .

ns1:Error_8008 a ns1:DiagnosticoFallo ;
    rdfs:label "Error almacenado configuración del sistema" ;
    ns1:identificador "8008" ;
    ns1:monitoreaParametro ns1:Parametro_CANMODE ;
    ns1:textoExtracto "'Error almacenado configuración del sistema' DETECCIÓN Durante el arranque del sistema. CAUSA Error en la configuración CAN durante el proceso de carga. SOLUCIÓN Desde el modo diagnosis comprobar la configuración CAN y compararla con la real, para determinar si hay algún problema en la detección de los nodos." .

ns1:Error_8009 a ns1:DiagnosticoFallo ;
    rdfs:label "Error cargando software de los nodos IO" ;
    ns1:identificador "8009" ;
    ns1:solucionaFallo ns1:Nodo_IO ;
    ns1:textoExtracto "'Error cargando software de los nodos IO' DETECCIÓN Durante el arranque del sistema. CAUSA Error durante el proceso de carga de los nodos de I/Os. SOLUCIÓN Verificar la configuración CAN, la conexión del sistema y las versiones de boot de los nodos remotos." .

ns1:Error_8010 a ns1:DiagnosticoFallo ;
    rdfs:label "Error cargando software de teclado" ;
    ns1:identificador "8010" ;
    ns1:solucionaFallo ns1:Nodo_Teclado_12 ;
    ns1:textoExtracto "'Error cargando software de teclado' DETECCIÓN Durante el arranque del sistema. CAUSA Error durante el proceso de carga del nodo del teclado de 12\". SOLUCIÓN Verificar la configuración CAN, la conexión del sistema y las versiones de boot de los nodos remotos." .

ns1:Error_8011 a ns1:DiagnosticoFallo ;
    rdfs:label "Error cargando software de las contadoras" ;
    ns1:identificador "8011" ;
    ns1:solucionaFallo ns1:Nodo_Contadoras ;
    ns1:textoExtracto "'Error cargando software de las contadoras' DETECCIÓN Durante el arranque del sistema. CAUSA Error durante el proceso de carga de los nodos contadora. SOLUCIÓN Verificar la configuración CAN, la conexión del sistema y las versiones de boot de los nodos remotos." .

ns1:Error_8012 a ns1:DiagnosticoFallo ;
    rdfs:label "Error cargando software de las contadoras" ;
    ns1:identificador "8012" ;
    ns1:solucionaFallo ns1:Nodo_Contadoras ;
    ns1:textoExtracto "'Error cargando software de las contadoras' DETECCIÓN Durante el arranque del sistema. CAUSA Error durante el proceso de carga de los nodos contadora." .

ns1:Modo_Diagnosis a ns1:ModoOperacion ;
    rdfs:label "Modo diagnosis" ;
    ns1:controla ns1:Sistema_CAN ;
    ns1:textoExtracto "Desde el modo diagnosis comprobar la configuración CAN y compararla con la real, para determinar si hay algún problema en la detección de los nodos." .

ns1:COMPCI a ns1:Componente ;
    rdfs:label "COMPCI" ;
    ns1:textoExtracto "Verificar el reconocimiento y correcta instalación de la COMPCI." .

ns1:Nodo_IO a ns1:Componente ;
    rdfs:label "Nodos de I/Os" ;
    ns1:textoExtracto "Error durante el proceso de carga de los nodos de I/Os." .

ns1:Nodo_Teclado_12 a ns1:InterfazUsuario ;
    rdfs:label "Nodo del teclado de 12\"" ;
    ns1:textoExtracto "Error durante el proceso de carga del nodo del teclado de 12\"." .

ns1:Parametro_CANMODE a ns1:Parametro ;
    rdfs:label "Parámetro CANMODE" ;
    ns1:textoExtracto "Verificar el reconocimiento de la COMPCI, el valor del parámetro CANMODE y la instalación del driver de comunicaciones." .

ns1:Sistema_CAN a ns1:Sistema ;
    rdfs:label "Sistema CAN" ;
    ns1:textoExtracto "Verificar la configuración CAN, la conexión del sistema y las versiones de boot de los nodos remotos." .

ns1:Nodo_Contadoras a ns1:Componente ;
    rdfs:label "Nodos contadora" ;
    ns1:textoExtracto "Error durante el proceso de carga de los nodos contadora." .

