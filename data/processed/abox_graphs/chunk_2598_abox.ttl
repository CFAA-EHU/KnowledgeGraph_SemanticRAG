@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8012_Solucion a ns1:TareaMantenimiento ;
    rdfs:label "Verificación de configuración CAN y conexión"@es ;
    ns1:solucionaFallo ns1:Error_8012 ;
    ns1:textoExtracto "Verificar la configuración CAN, la conexión del"@es .

ns1:SistemaContadoras a ns1:Sistema ;
    ns1:textoExtracto "software de las contadoras"@es ;
    ns1:tieneComponente ns1:NodosContadora .

ns1:Error_8012 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8012: Error cargando software de las contadoras"@es ;
    ns1:identificador "8012" ;
    ns1:textoExtracto "'Error cargando software de las contadoras' DETECCIÓN Durante el arranque del sistema. CAUSA Error durante el proceso de carga de los nodos contadora."@es .

ns1:NodosContadora a ns1:ComponenteElectrico ;
    ns1:textoExtracto "nodos contadora"@es .

