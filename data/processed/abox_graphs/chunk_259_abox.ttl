@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TareaMantenimiento_Probe10_CentradoPiezaRectangular a ns1:TareaMantenimiento ;
    rdfs:label "Centrado de pieza rectangular (#PROBE 10)" ;
    ns1:identificador "#PROBE 10" ;
    ns1:monitoreaParametro ns1:Parametro_DistanciaSeguridad_B,
        ns1:Parametro_Longitud_I,
        ns1:Parametro_Longitud_J_2,
        ns1:Parametro_MedicionSuperficie_L,
        ns1:Parametro_OrdenPrimerPalpado_K,
        ns1:Parametro_Retirada_D,
        ns1:Parametro_Retirada_E ;
    ns1:textoExtracto "Centrado de pieza rectangular: se muestran longitudes 'I/J', orden del primer palpado 'K' y medición opcional de superficie 'L'. Varios vectores indican aproximaciones y retiradas (B/D/E)." .

ns1:TareaMantenimiento_Probe5_PalpadoRinconInterior a ns1:TareaMantenimiento ;
    rdfs:label "Palpado de rincón interior (#PROBE 5)" ;
    ns1:identificador "#PROBE 5" ;
    ns1:monitoreaParametro ns1:Parametro_AvancePalpado_F,
        ns1:Parametro_DistanciaSeguridad_B ;
    ns1:textoExtracto "Palpado de rincón interior con trayectorias hacia caras internas; idéntica codificación de B y F." .

ns1:TareaMantenimiento_Probe6_MedicionAngulo a ns1:TareaMantenimiento ;
    rdfs:label "Medición de ángulo relativo a X (#PROBE 6)" ;
    ns1:identificador "#PROBE 6" ;
    ns1:monitoreaParametro ns1:Parametro_DistanciaSeguridad_2B ;
    ns1:textoExtracto "Medición de ángulo relativo a X mediante contactos en dos puntos; acotaciones 2B y trayectorias de aproximación." .

ns1:TareaMantenimiento_Probe7_PalpadoEsquinaAngulo a ns1:TareaMantenimiento ;
    rdfs:label "Palpado de esquina exterior y ángulo (#PROBE 7)" ;
    ns1:identificador "#PROBE 7" ;
    ns1:textoExtracto "Variante combinada de esquina exterior + ángulo; flechas de palpado y distancias de seguridad repetidas." .

ns1:TareaMantenimiento_Probe8_PalpadoCircular a ns1:TareaMantenimiento ;
    rdfs:label "Palpado circular de agujero (#PROBE 8)" ;
    ns1:identificador "#PROBE 8" ;
    ns1:monitoreaParametro ns1:Parametro_DiametroTeorico_J,
        ns1:Parametro_PuntoFinal_C0,
        ns1:Parametro_PuntoFinal_C1,
        ns1:Parametro_Retirada_E,
        ns1:Parametro_VelocidadAlta_H,
        ns1:Parametro_VelocidadBaja_F_2 ;
    ns1:textoExtracto "Palpado circular con centro (X,Y), diámetro teórico 'J' y retiradas 'E'; se indican dos velocidades H/F y elección del punto final (C0/C1)." .

ns1:TareaMantenimiento_Probe9_PalpadoResalteCircular a ns1:TareaMantenimiento ;
    rdfs:label "Medición de resalte circular (#PROBE 9)" ;
    ns1:identificador "#PROBE 9" ;
    ns1:textoExtracto "Medición de resalte circular (boss) con estrategia similar a #8, referida al centro del resalte." .

ns1:Parametro_AvancePalpado_F a ns1:Parametro ;
    rdfs:label "Avance de palpado F" ;
    ns1:identificador "F" ;
    ns1:textoExtracto "avance de palpado 'F'" .

ns1:Parametro_DiametroTeorico_J a ns1:Parametro ;
    rdfs:label "Diámetro teórico J" ;
    ns1:identificador "J" ;
    ns1:textoExtracto "diámetro teórico 'J'" .

ns1:Parametro_DistanciaSeguridad_2B a ns1:Parametro ;
    rdfs:label "Distancia de seguridad 2B" ;
    ns1:identificador "2B" ;
    ns1:textoExtracto "acotaciones 2B" .

ns1:Parametro_Longitud_I a ns1:Parametro ;
    rdfs:label "Longitud I" ;
    ns1:identificador "I" ;
    ns1:textoExtracto "longitudes 'I/J'" .

ns1:Parametro_Longitud_J_2 a ns1:Parametro ;
    rdfs:label "Longitud J" ;
    ns1:identificador "J" ;
    ns1:textoExtracto "longitudes 'I/J'" .

ns1:Parametro_MedicionSuperficie_L a ns1:Parametro ;
    rdfs:label "Medición opcional de superficie L" ;
    ns1:identificador "L" ;
    ns1:textoExtracto "medición opcional de superficie 'L'" .

ns1:Parametro_OrdenPrimerPalpado_K a ns1:Parametro ;
    rdfs:label "Orden del primer palpado K" ;
    ns1:identificador "K" ;
    ns1:textoExtracto "orden del primer palpado 'K'" .

ns1:Parametro_PuntoFinal_C0 a ns1:Parametro ;
    rdfs:label "Punto final C0" ;
    ns1:identificador "C0" ;
    ns1:textoExtracto "elección del punto final (C0/C1)" .

ns1:Parametro_PuntoFinal_C1 a ns1:Parametro ;
    rdfs:label "Punto final C1" ;
    ns1:identificador "C1" ;
    ns1:textoExtracto "elección del punto final (C0/C1)" .

ns1:Parametro_Retirada_D a ns1:Parametro ;
    rdfs:label "Retirada D" ;
    ns1:identificador "D" ;
    ns1:textoExtracto "retiradas (B/D/E)" .

ns1:Parametro_VelocidadAlta_H a ns1:Parametro ;
    rdfs:label "Velocidad alta H" ;
    ns1:identificador "H" ;
    ns1:textoExtracto "dos velocidades H/F" .

ns1:Parametro_VelocidadBaja_F_2 a ns1:Parametro ;
    rdfs:label "Velocidad baja F" ;
    ns1:identificador "F" ;
    ns1:textoExtracto "dos velocidades H/F" .

ns1:Parametro_DistanciaSeguridad_B a ns1:Parametro ;
    rdfs:label "Distancia de seguridad B" ;
    ns1:identificador "B" ;
    ns1:textoExtracto "se destaca distancia de seguridad 'B'" .

ns1:Parametro_Retirada_E a ns1:Parametro ;
    rdfs:label "Retirada E" ;
    ns1:identificador "E" ;
    ns1:textoExtracto "retiradas 'E'" .

