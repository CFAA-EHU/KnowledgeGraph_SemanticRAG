@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8019 a ns1:DiagnosticoFallo ;
    rdfs:label "No se permite generar el PLC mientras algún canal se encuentre en ejecución o interrumpido" ;
    ns1:identificador "8019" ;
    ns1:textoExtracto "DETECCIÓN Al intentar compilar el PLC. CAUSA No se permite compilar el PLC si algún canal se encuentra en ejecución o interrumpido. SOLUCIÓN Detener los programas en ejecución." .

ns1:Error_8020 a ns1:DiagnosticoFallo ;
    rdfs:label "No se permite generar el PLC: Eje en movimiento o en sincronización" ;
    ns1:identificador "8020" ;
    ns1:textoExtracto "DETECCIÓN Al intentar compilar el PLC. CAUSA No se permite compilar el PLC si hay algún eje en movimiento o sincronizado. SOLUCIÓN Detener el movimiento de los ejes o desincronizar el eje." .

ns1:Error_8021 a ns1:DiagnosticoFallo ;
    rdfs:label "No se permite generar el PLC: Cabezal en marcha" ;
    ns1:identificador "8021" ;
    ns1:textoExtracto "DETECCIÓN Al intentar compilar el PLC. CAUSA No se permite compilar el PLC si hay algún cabezal en movimiento. SOLUCIÓN Detener el movimiento del cabezal." .

ns1:Error_8022 a ns1:DiagnosticoFallo ;
    rdfs:label "No se permite generar el PLC: Cabezal en sincronización" ;
    ns1:identificador "8022" ;
    ns1:textoExtracto "DETECCIÓN Al intentar compilar el PLC. CAUSA No se permite compilar el PLC si hay algún cabezal sincronizado. SOLUCIÓN Desincronizar el cabezal." .

ns1:Error_8023 a ns1:DiagnosticoFallo ;
    rdfs:label "Memoria en disco por debajo del mínimo recomendado" ;
    ns1:identificador "8023" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema. CAUSA El CNC ha detectado menos de 50 MB de memoria libre en disco. SOLUCIÓN Comprobar si hay arrancada alguna aplicación de terceros que esté consumiendo recursos del sistema, y si es así, cerrarla. Apagar y encender el CNC. Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:Error_8024 a ns1:DiagnosticoFallo ;
    rdfs:label "CNC trabajando en Modo Puesta a Punto" ;
    ns1:identificador "8024" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema, en modo puesta a punto. CAUSA El CNC ha arrancado en modo puesta a punto y está trabajando con el disco desprotegido." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema." ;
    ns1:tieneComponente ns1:ModoPuestaPunto .

ns1:ModoPuestaPunto a ns1:ModoOperacion ;
    rdfs:label "Modo Puesta a Punto" ;
    ns1:textoExtracto "El CNC ha arrancado en modo puesta a punto y está trabajando con el disco desprotegido." .

