@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_8024_DiscoDesprotegido a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia: Disco desprotegido en modo puesta a punto"@es ;
    ns1:mitigaRiesgo ns1:DiagnosticoFallo_8024_ArranqueModoPuestaPunto ;
    ns1:textoExtracto "El CNC ha arrancado en modo puesta a punto y está trabajando con el disco desprotegido."@es .

ns1:ModoOperacion_8024_PuestaPunto a ns1:ModoOperacion ;
    rdfs:label "Modo Puesta a Punto"@es ;
    ns1:identificador "8024" ;
    ns1:textoExtracto "'CNC trabajando en Modo Puesta a Punto' [...] El CNC ha arrancado en modo puesta a punto y está trabajando con el disco desprotegido."@es .

ns1:Sistema_DiskMonitor a ns1:Sistema ;
    rdfs:label "DiskMonitor"@es ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_8024_ArranqueModoPuestaPunto ;
    ns1:textoExtracto "utilice la utilidad DiskMonitor para pasar a modo usuario y trabajar con el disco protegido."@es .

ns1:DiagnosticoFallo_8024_ArranqueModoPuestaPunto a ns1:DiagnosticoFallo ;
    rdfs:label "CNC en Modo Puesta a Punto con disco desprotegido"@es ;
    ns1:identificador "8024" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema, en modo puesta a punto. [...] SOLUCIÓN Si no va a realizar la puesta a punto del CNC, apaguelo y utilice la utilidad DiskMonitor para pasar a modo usuario y trabajar con el disco protegido."@es .

