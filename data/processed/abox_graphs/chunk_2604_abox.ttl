@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_8030 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 8030: Librerías del PLC no disponibles" ;
    ns1:identificador "8030" ;
    ns1:solucionaFallo ns1:ContactarConServicioDeAsistenciaTecnica ;
    ns1:textoExtracto "'Librerias del PLC no disponibles' DETECCIÓN Durante el arranque del sistema. CAUSA El CNC no ha encontrado la carpeta en la que se encuentran instaladas las librerías necesarias para compilar el PLC." .

ns1:Fallo_8031 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 8031: Carpeta no accesible" ;
    ns1:identificador "8031" ;
    ns1:solucionaFallo ns1:ContactarConServicioDeAsistenciaTecnica ;
    ns1:textoExtracto "'La carpeta" .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:controla ns1:PLCControladorLogicoProgramable ;
    ns1:textoExtracto "el CNC no ha encontrado la carpeta en la que se encuentran instaladas las librerías necesarias para compilar el PLC" .

ns1:PLCControladorLogicoProgramable a ns1:ComponenteElectrico ;
    rdfs:label "PLC (Controlador Lógico Programable)" ;
    ns1:textoExtracto "librerías necesarias para compilar el PLC" .

ns1:ContactarConServicioDeAsistenciaTecnica a ns1:AccionProhibida ;
    rdfs:label "Contactar con servicio de asistencia técnica" ;
    ns1:textoExtracto "Póngase en contacto con el servicio de asistencia técnica." .

