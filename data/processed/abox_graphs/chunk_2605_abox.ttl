@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8031 a ns1:AvisoSeguridad ;
    rdfs:label "'La carpeta DRIVERS no existe'" ;
    ns1:identificador "8031" ;
    ns1:mitigaRiesgo ns1:Solucion_8031 ;
    ns1:textoExtracto "CNC no ha encontrado la carpeta en la que se ubicará el PLC una vez generado (C:\\CNC8070\\Drivers). DETECCIÓN Durante el arranque del sistema."@es .

ns1:Error_8032 a ns1:AvisoSeguridad ;
    rdfs:label "'La carpeta USERS no existe'" ;
    ns1:identificador "8032" ;
    ns1:mitigaRiesgo ns1:Solucion_8032 ;
    ns1:textoExtracto "El CNC no ha encontrado la carpeta de trabajo del usuario (C:\\CNC8070\\Users). DETECCIÓN Durante el arranque del sistema."@es .

ns1:Error_8034 a ns1:AvisoSeguridad ;
    rdfs:label "'Puesta a punto incompleta: No se ha encontrado ninguna copia de seguridad'" ;
    ns1:identificador "8034" ;
    ns1:mitigaRiesgo ns1:Solucion_8034 ;
    ns1:textoExtracto "El CNC no ha encontrado ninguna copia de seguridad de la puesta a punto. DETECCIÓN Durante el arranque del sistema, en modo puesta a punto."@es .

ns1:Error_8035 a ns1:AvisoSeguridad ;
    rdfs:label "'Los siguientes passwords de acceso están aún por definir'" ;
    ns1:identificador "8035" ;
    ns1:mitigaRiesgo ns1:Solucion_8035 ;
    ns1:textoExtracto "Los passwords de acceso indicados en el aviso no están definidos. DETECCIÓN Durante el arranque de un CNC abierto, en modo puesta a punto."@es .

ns1:Error_8036 a ns1:AvisoSeguridad ;
    rdfs:label "'Pase a Modo Usuario o Modo Puesta a Punto para trabajar con el CNC'" ;
    ns1:identificador "8036" ;
    ns1:mitigaRiesgo ns1:Solucion_8036 ;
    ns1:textoExtracto "Solo se permite trabajar con el CNC en los modos usuario y modo puesta a punto. DETECCIÓN Durante el arranque del sistema, en modo setup."@es .

ns1:Modo_PuestaPunto a ns1:ModoOperacion ;
    ns1:textoExtracto "Pase a Modo Usuario o Modo Puesta a Punto para trabajar con el CNC."@es .

ns1:Modo_Setup a ns1:ModoOperacion ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema, en modo setup."@es .

ns1:Modo_Usuario a ns1:ModoOperacion ;
    ns1:textoExtracto "Pase a Modo Usuario o Modo Puesta a Punto para trabajar con el CNC."@es .

ns1:Modo_Utilidades a ns1:ModoOperacion ;
    ns1:textoExtracto "Desde el modo utilidades, usar la opción 'Nuevo directorio' del menú de softkeys."@es .

ns1:Personal_Operador a ns1:Personal ;
    ns1:textoExtracto "Al apagar el CNC, seleccionar la opción 'Cerrar y hacer copia de seguridad'."@es .

ns1:Solucion_8031 a ns1:TareaMantenimiento ;
    ns1:ejecutadoPor ns1:Personal_Tecnico ;
    ns1:requiereMantenimiento ns1:Sistema_CNC ;
    ns1:textoExtracto "Desde el modo utilidades, usar la opción 'Nuevo directorio' del menú de softkeys para crear la carpeta."@es .

ns1:Solucion_8032 a ns1:TareaMantenimiento ;
    ns1:ejecutadoPor ns1:Personal_Tecnico ;
    ns1:requiereMantenimiento ns1:Sistema_CNC ;
    ns1:textoExtracto "Desde el modo utilidades, usar la opción 'Nuevo directorio' del menú de softkeys para crear la carpeta."@es .

ns1:Solucion_8034 a ns1:TareaMantenimiento ;
    ns1:ejecutadoPor ns1:Personal_Operador ;
    ns1:requiereMantenimiento ns1:Sistema_CNC ;
    ns1:textoExtracto "Al apagar el CNC, seleccionar la opción 'Cerrar y hacer copia de seguridad', para que el CNC haga una copia de seguridad de la puesta a punto."@es .

ns1:Solucion_8035 a ns1:TareaMantenimiento ;
    ns1:ejecutadoPor ns1:Personal_Tecnico ;
    ns1:requiereMantenimiento ns1:Sistema_CNC ;
    ns1:textoExtracto "Con el CNC arrancado, acceder al modo utilidades y desde la opción 'Códigos de acceso' del menú de softkeys introducir los passwords indicados."@es .

ns1:Solucion_8036 a ns1:TareaMantenimiento ;
    ns1:ejecutadoPor ns1:Personal_Tecnico ;
    ns1:requiereMantenimiento ns1:Sistema_CNC ;
    ns1:textoExtracto "Utilizar la utilidad DiskMonitor para pasar a modo usuario o modo puesta a punto y volver a arrancar el CNC."@es .

ns1:Personal_Tecnico a ns1:Personal ;
    ns1:textoExtracto "Póngase en contacto con el servicio de asistencia técnica."@es .

ns1:Sistema_CNC a ns1:Sistema ;
    ns1:textoExtracto "CNC no ha encontrado la carpeta en la que se encuentran instaladas las librerías necesarias para compilar el PLC."@es .

