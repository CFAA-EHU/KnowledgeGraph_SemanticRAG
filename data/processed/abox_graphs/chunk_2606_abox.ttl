@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Herramienta_DiskMonitor a ns1:Herramienta ;
    rdfs:label "DiskMonitor" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_8037 ;
    ns1:textoExtracto "utilidad DiskMonitor"@es .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "CNC" ;
    ns1:requiereMantenimiento ns1:DiagnosticoFallo_8037 ;
    ns1:textoExtracto "CNC"@es ;
    ns1:tieneComponente ns1:DiagnosticoFallo_8037 .

ns1:ModoOperacion_ModoPuestaPunto a ns1:ModoOperacion ;
    rdfs:label "Modo puesta a punto" ;
    ns1:textoExtracto "modo puesta a punto"@es .

ns1:ModoOperacion_ModoUsuario a ns1:ModoOperacion ;
    rdfs:label "Modo usuario" ;
    ns1:textoExtracto "modo usuario"@es .

ns1:DiagnosticoFallo_8037 a ns1:DiagnosticoFallo ;
    rdfs:label "Memoria por debajo del mínimo recomendado. Es necesario reiniciar" ;
    ns1:identificador "8037" ;
    ns1:textoExtracto "8037 'Memoria por debajo del mínimo recomendado. Es necesario reiniciar'"@es .

