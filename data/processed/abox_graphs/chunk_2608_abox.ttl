@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Accion_ContactoAsistenciaTecnica_8041 a ns1:TareaMantenimiento ;
    rdfs:label "Contactar con asistencia técnica para el error 8041"@es ;
    ns1:solucionaFallo ns1:Error_8041 ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con el servicio de asistencia técnica."@es .

ns1:Accion_LiberarMemoriaDisco_8041 a ns1:TareaMantenimiento ;
    rdfs:label "Liberar memoria en disco para el error 8041"@es ;
    ns1:solucionaFallo ns1:Error_8041 ;
    ns1:textoExtracto "Hay que liberar memoria en disco para poder arrancar el CNC."@es .

ns1:Accion_ReinicioCNC_8041 a ns1:TareaMantenimiento ;
    rdfs:label "Apagar y encender el CNC para el error 8041"@es ;
    ns1:solucionaFallo ns1:Error_8041 ;
    ns1:textoExtracto "Apagar y encender el CNC. Si el error persiste, póngase en contacto con el servicio de asistencia técnica."@es .

ns1:Error_8041 a ns1:DiagnosticoFallo ;
    rdfs:label "Memoria por debajo del mínimo recomendado para la ejecución"@es ;
    ns1:identificador "8041" ;
    ns1:textoExtracto "8041 'Memoria por debajo del mínimo recomendado para la ejecución' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado menos de 50 MB de memoria libre en disco. SOLUCIÓN Hay que liberar memoria en disco para poder arrancar el CNC."@es .

