@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_CNC_Estandar a ns1:ModoOperacion ;
    rdfs:label "Modo CNC estándar" ;
    ns1:textoExtracto "Pase a modo CNC estándar para editar o ejecutar el programa." .

ns1:ModoOperacion_Conversacional a ns1:ModoOperacion ;
    rdfs:label "Modo conversacional" ;
    ns1:textoExtracto "El programa conversacional tiene mas de 10 MB." .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:activaAlarma ns1:Error_8042,
        ns1:Error_8043,
        ns1:Error_8044,
        ns1:Error_8045 ;
    ns1:textoExtracto "CNC ha detectado menos de 50 MB de memoria libre en disco." .

ns1:Error_8042 a ns1:AvisoSeguridad ;
    rdfs:label "Memoria por debajo del mínimo recomendado" ;
    ns1:identificador "8042" ;
    ns1:textoExtracto "8042 'Memoria por debajo del mínimo recomendado' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado menos de 50 MB de memoria libre en disco. SOLUCIÓN Hay que liberar memoria en disco para poder arrancar el CNC." .

ns1:Error_8043 a ns1:AvisoSeguridad ;
    rdfs:label "Memoria insuficiente para cargar el fichero" ;
    ns1:identificador "8043" ;
    ns1:textoExtracto "8043 'Memoria insuficiente para cargar el fichero' DETECCIÓN Durante la edición. CAUSA No hay memoria suficiente para cargar el fichero. SOLUCIÓN Hay que liberar memoria para cargar el fichero." .

ns1:Error_8044 a ns1:AvisoSeguridad ;
    rdfs:label "Programa demasiado grande para ser editado en modo conversacional" ;
    ns1:identificador "8044" ;
    ns1:textoExtracto "8044 'Programa demasiado grande para ser editado en modo conversacional. Pasar a modo CNC estándar para su edición o ejecución' DETECCIÓN Durante la edición o la ejecución. CAUSA El programa conversacional tiene mas de 10 MB." .

ns1:Error_8045 a ns1:AvisoSeguridad ;
    rdfs:label "Código de validación expirado" ;
    ns1:identificador "8045" ;
    ns1:textoExtracto "8045 'Código de validación expirado. Reinicie el CNC' DETECCIÓN Durante el arranque del CNC o durante la ejecución. CAUSA El CNC ha detectado que su código de validación temporal ha expirado." .

