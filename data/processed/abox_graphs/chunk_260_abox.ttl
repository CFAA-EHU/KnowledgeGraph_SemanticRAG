@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TareaMantenimiento_CalibracionSondaMesa a ns1:TareaMantenimiento ;
    rdfs:label "Calibración de sonda de mesa (Tabletop probe calibration)" ;
    ns1:identificador "Tabletop probe calibration" ;
    ns1:monitoreaParametro ns1:Parametro_SecuenciaAvanceF,
        ns1:Parametro_SecuenciaAvanceH,
        ns1:Parametro_TipoCalibracionI ;
    ns1:textoExtracto "Calibración de sonda de mesa: esquema de palpado radial con posiciones teóricas X..W y secuencias de avance H/F, incluyendo tipo de calibración 'I'." .

ns1:TareaMantenimiento_Probe11 a ns1:TareaMantenimiento ;
    rdfs:label "Centrado de pieza rectangular (PROBE 11)" ;
    ns1:identificador "PROBE 11" ;
    ns1:monitoreaParametro ns1:Parametro_LongitudI,
        ns1:Parametro_LongitudJ,
        ns1:Parametro_MedicionSuperficieL,
        ns1:Parametro_OrdenPalpadoK ;
    ns1:textoExtracto "Centrado de pieza rectangular: se muestran longitudes 'I/J', orden del primer palpado 'K' y medición opcional de superficie 'L'. Varios vectores indican aproximaciones y retiradas (B/D/E)." .

ns1:TareaMantenimiento_Probe12 a ns1:TareaMantenimiento ;
    rdfs:label "Centrado de pieza circular (PROBE 12)" ;
    ns1:identificador "PROBE 12" ;
    ns1:monitoreaParametro ns1:Parametro_DiametroJ,
        ns1:Parametro_MedicionSuperficieL,
        ns1:Parametro_OrdenPalpadoK ;
    ns1:textoExtracto "Centrado de pieza circular con diámetros 'J', orden de palpado 'K' y medición opcional 'L'; trayectorias y retiradas B/D/E." .

ns1:TareaMantenimiento_Probe1_TModel a ns1:TareaMantenimiento ;
    rdfs:label "Calibración de herramienta en torno (PROBE 1 ·T·)" ;
    ns1:identificador "PROBE 1 (T·MODEL)" ;
    ns1:monitoreaParametro ns1:Parametro_DistanciaSeguridadB,
        ns1:Parametro_OrdenPalpadoK ;
    ns1:textoExtracto "Palpado en torno con sonda de mesa; se resaltan lados activos 'K', distancia de seguridad 'B' y velocidades de palpado." .

ns1:TareaMantenimiento_Probe2_TModel a ns1:TareaMantenimiento ;
    rdfs:label "Calibración de sonda de mesa (PROBE 2 ·T·)" ;
    ns1:identificador "PROBE 2 (T·MODEL)" ;
    ns1:textoExtracto "Esquema de calibración con selección de lados de palpado y posiciones X..W; códigos idénticos a #PROBE 1." .

ns1:TareaMantenimiento_Probe3_TModel a ns1:TareaMantenimiento ;
    rdfs:label "Medición de pieza sobre eje de ordenadas (PROBE 3 ·T·)" ;
    ns1:identificador "PROBE 3 (T·MODEL)" ;
    ns1:monitoreaParametro ns1:Parametro_CorreccionDesgasteD,
        ns1:Parametro_CorreccionDesgasteT,
        ns1:Parametro_ToleranciaL ;
    ns1:textoExtracto "Medición sobre cara cilíndrica con vector de palpado en Y y referencia en Z; incluye tolerancia 'L' y corrección de desgaste T/D." .

ns1:TareaMantenimiento_Probe4_TModel a ns1:TareaMantenimiento ;
    rdfs:label "Medición de pieza sobre eje de abscisas (PROBE 4 ·T·)" ;
    ns1:identificador "PROBE 4 (T·MODEL)" ;
    ns1:textoExtracto "Part measuring along the abscissa axis." .

ns1:Parametro_CorreccionDesgasteD a ns1:Parametro ;
    rdfs:label "Corrección de desgaste D" ;
    ns1:identificador "D" ;
    ns1:textoExtracto "corrección de desgaste T/D" .

ns1:Parametro_CorreccionDesgasteT a ns1:Parametro ;
    rdfs:label "Corrección de desgaste T" ;
    ns1:identificador "T" ;
    ns1:textoExtracto "corrección de desgaste T/D" .

ns1:Parametro_DiametroJ a ns1:Parametro ;
    rdfs:label "Diámetro J (PROBE 12)" ;
    ns1:identificador "J" ;
    ns1:textoExtracto "diámetros 'J'" .

ns1:Parametro_DistanciaSeguridadB a ns1:Parametro ;
    rdfs:label "Distancia de seguridad B" ;
    ns1:identificador "B" ;
    ns1:textoExtracto "distancia de seguridad 'B'" .

ns1:Parametro_LongitudI a ns1:Parametro ;
    rdfs:label "Longitud I (PROBE 11)" ;
    ns1:identificador "I" ;
    ns1:textoExtracto "longitudes 'I/J'" .

ns1:Parametro_LongitudJ a ns1:Parametro ;
    rdfs:label "Longitud J (PROBE 11)" ;
    ns1:identificador "J" ;
    ns1:textoExtracto "longitudes 'I/J'" .

ns1:Parametro_SecuenciaAvanceF a ns1:Parametro ;
    rdfs:label "Secuencia de avance F" ;
    ns1:identificador "F" ;
    ns1:textoExtracto "secuencias de avance H/F" .

ns1:Parametro_SecuenciaAvanceH a ns1:Parametro ;
    rdfs:label "Secuencia de avance H" ;
    ns1:identificador "H" ;
    ns1:textoExtracto "secuencias de avance H/F" .

ns1:Parametro_TipoCalibracionI a ns1:Parametro ;
    rdfs:label "Tipo de calibración I" ;
    ns1:identificador "I" ;
    ns1:textoExtracto "tipo de calibración 'I'" .

ns1:Parametro_ToleranciaL a ns1:Parametro ;
    rdfs:label "Tolerancia L (PROBE 3)" ;
    ns1:identificador "L" ;
    ns1:textoExtracto "incluye tolerancia 'L'" .

ns1:Parametro_MedicionSuperficieL a ns1:Parametro ;
    rdfs:label "Medición opcional de superficie L" ;
    ns1:identificador "L" ;
    ns1:textoExtracto "medición opcional de superficie 'L'"@es .

ns1:Parametro_OrdenPalpadoK a ns1:Parametro ;
    rdfs:label "Orden de palpado K" ;
    ns1:identificador "K" ;
    ns1:textoExtracto "orden del primer palpado 'K'"@es .

