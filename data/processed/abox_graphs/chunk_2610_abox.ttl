@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_CodigoValidacionTemporal_8046 a ns1:AvisoSeguridad ;
    rdfs:label "Código de validación temporal detectado"@es ;
    ns1:identificador "8046" ;
    ns1:textoExtracto "8046 'El código de validación temporal ha sido"@es .

ns1:ModoOperacion_CNC_Estandar a ns1:ModoOperacion ;
    rdfs:label "Modo CNC estándar"@es ;
    ns1:habilitadoPor ns1:TareaMantenimiento_ReinicioCNC_8045 ;
    ns1:textoExtracto "Pase a modo CNC estándar para editar o ejecutar el programa."@es .

ns1:AvisoSeguridad_CodigoValidacionExpirado_8045 a ns1:AvisoSeguridad ;
    rdfs:label "Código de validación expirado. Reinicie el CNC"@es ;
    ns1:identificador "8045" ;
    ns1:mitigaRiesgo ns1:TareaMantenimiento_ReinicioCNC_8045 ;
    ns1:textoExtracto "8045 'Código de validación expirado. Reinicie el CNC' [...] CAUSA El CNC ha detectado que su código de validación temporal ha expirado. El CNC no permitirá la marcha hasta que el usuario haya reiniciado el CNC."@es .

ns1:TareaMantenimiento_ReinicioCNC_8045 a ns1:TareaMantenimiento ;
    rdfs:label "Reinicio del CNC (solución para código 8045)"@es ;
    ns1:solucionaFallo ns1:AvisoSeguridad_CodigoValidacionExpirado_8045 ;
    ns1:textoExtracto "SOLUCIÓN Reiniciar el CNC."@es .

