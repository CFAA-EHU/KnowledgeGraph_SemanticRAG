@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_8051 a ns1:Alarma ;
    rdfs:label "Error al restaurar sesión de Usuario" ;
    ns1:identificador "8051" ;
    ns1:textoExtracto "Error restaurando sesión de Usuario. DETECCIÓN Durante el arranque del CNC. CAUSA Uno de los archivos de la sesión de usuario no es accesible o está corrupto." .

ns1:AvisoSeguridad_8046_Solucion a ns1:AvisoSeguridad ;
    rdfs:label "Solución para código 8046" ;
    ns1:solucionaFallo ns1:Alarma_8046 ;
    ns1:textoExtracto "Reinicie el CNC." .

ns1:AvisoSeguridad_8047_Solucion a ns1:AvisoSeguridad ;
    rdfs:label "Solución para código 8047" ;
    ns1:solucionaFallo ns1:Alarma_8047 ;
    ns1:textoExtracto "Apague el CNC y utilice la utilidad DiskMonitor para pasar a modo Usuario." .

ns1:AvisoSeguridad_8048_Solucion a ns1:AvisoSeguridad ;
    rdfs:label "Solución para código 8048" ;
    ns1:solucionaFallo ns1:Alarma_8048 ;
    ns1:textoExtracto "Para finalizar la puesta a punto, siga los siguientes pasos. 1. Apague el CNC y utilice la utilidad DiskMonitor para pasar al modo Setup (puesta a punto). 2. En el modo utilidades, entre en la ventana de códigos de acceso e introduzca el 'Código de acceso general'. 3. Pulse [ALT][F4] para apagar el CNC y seleccione la opción 'Cerrar y hacer copia de seguridad'. 4. Utilice la utilidad DiskMonitor para pasar a modo Usuario." .

ns1:AvisoSeguridad_8050_Solucion a ns1:AvisoSeguridad ;
    rdfs:label "Solución para código 8050" ;
    ns1:solucionaFallo ns1:Alarma_8050 ;
    ns1:textoExtracto "Verificar la configuración CAN, la conexión del sistema y las versiones de boot de los nodos remotos. Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

ns1:ModoOperacion_Setup a ns1:ModoOperacion ;
    rdfs:label "Modo Setup (puesta a punto)" ;
    ns1:textoExtracto "modo Setup (puesta a punto)" .

ns1:ModoOperacion_Usuario a ns1:ModoOperacion ;
    rdfs:label "Modo Usuario" ;
    ns1:textoExtracto "modo Usuario" .

ns1:Sistema_DiskMonitor a ns1:Sistema ;
    rdfs:label "Utilidad DiskMonitor" ;
    ns1:textoExtracto "utilidad DiskMonitor" .

ns1:Alarma_8046 a ns1:Alarma ;
    rdfs:label "Código de validación temporal cancelado" ;
    ns1:identificador "8046" ;
    ns1:textoExtracto "El código de validación temporal ha sido cancelado. Reinicie el CNC. DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado que el usuario ha cancelado el código de validación temporal. El CNC no permitirá la marcha hasta que el usuario haya reiniciado el CNC. SOLUCIÓN Reinicie el CNC." .

ns1:Alarma_8047 a ns1:Alarma ;
    rdfs:label "CNC en modo NO seguro" ;
    ns1:identificador "8047" ;
    ns1:textoExtracto "CNC trabajando en modo NO seguro. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC está trabajando en modo Setup (puesta a punto). SOLUCIÓN Apague el CNC y utilice la utilidad DiskMonitor para pasar a modo Usuario." .

ns1:Alarma_8048 a ns1:Alarma ;
    rdfs:label "Puesta a punto incompleta" ;
    ns1:identificador "8048" ;
    ns1:textoExtracto "Puesta a punto incompleta. DETECCIÓN Durante el arranque del CNC. CAUSA Se cumple una de las siguientes condiciones en modo Usuario: • No están definidos los passwords de protección. • No hay copia de seguridad. SOLUCIÓN Para finalizar la puesta a punto, siga los siguientes pasos. 1. Apague el CNC y utilice la utilidad DiskMonitor para pasar al modo Setup (puesta a punto). 2. En el modo utilidades, entre en la ventana de códigos de acceso e introduzca el 'Código de acceso general'. 3. Pulse [ALT][F4] para apagar el CNC y seleccione la opción 'Cerrar y hacer copia de seguridad'. 4. Utilice la utilidad DiskMonitor para pasar a modo Usuario." .

ns1:Alarma_8050 a ns1:Alarma ;
    rdfs:label "Error de carga de software RIOR" ;
    ns1:identificador "8050" ;
    ns1:textoExtracto "Error cargando software de RIOR. DETECCIÓN Durante el arranque del CNC. CAUSA Error durante el proceso de carga del software de los nodos RIOR. SOLUCIÓN Verificar la configuración CAN, la conexión del sistema y las versiones de boot de los nodos remotos. Si el error persiste, póngase en contacto con el servicio de asistencia técnica." .

