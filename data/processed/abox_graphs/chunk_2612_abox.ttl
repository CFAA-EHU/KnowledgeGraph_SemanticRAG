@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Accion_ContactoAsistenciaTecnica a ns1:TareaMantenimiento ;
    rdfs:label "Contactar con servicio de asistencia técnica"@es ;
    ns1:solucionaFallo ns1:Error_8051_RestauracionSesionUsuario ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con el servicio de asistencia técnica."@es .

ns1:Error_8051_RestauracionSesionUsuario a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8051: Error restaurando sesión de Usuario"@es ;
    ns1:identificador "8051" ;
    ns1:textoExtracto "8051 'Error restaurando sesión de Usuario' DETECCIÓN Durante el arranque del CNC. CAUSA Uno de los archivos de la sesión de usuario no es accesible o está corrupto. Los datos del CNC relativos a las cotas, traslados de orígenes, contador de piezas, cinemáticas, etc pueden haberse perdido."@es .

