@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "CNC"@es ;
    ns1:activaAlarma ns1:Fallo_8055,
        ns1:Fallo_8056 ;
    ns1:textoExtracto "El CNC ha sido bloqueado debido a una violación de los términos de uso"@es .

ns1:TareaMantenimiento_ContactarOEM_8055 a ns1:TareaMantenimiento ;
    rdfs:label "Contactar con el OEM para desbloqueo del CNC"@es ;
    ns1:solucionaFallo ns1:Fallo_8055 ;
    ns1:textoExtracto "Contacte con el OEM" .

ns1:TareaMantenimiento_ContactarOEM_8056 a ns1:TareaMantenimiento ;
    rdfs:label "Contactar con el OEM para inconsistencias en recuperación de herramientas"@es ;
    ns1:solucionaFallo ns1:Fallo_8056 ;
    ns1:textoExtracto "El CNC no ha podido recuperar la información de"@es .

ns1:Fallo_8055 a ns1:DiagnosticoFallo ;
    rdfs:label "Bloqueo del CNC por violación de términos de uso"@es ;
    ns1:identificador "8055" ;
    ns1:textoExtracto "El CNC ha sido bloqueado debido a una violación de los términos de uso. Contacte con el OEM. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC está bloqueado porque ha detectado un cambio de fecha no permitido. SOLUCIÓN Póngase en contacto con el OEM."@es .

ns1:Fallo_8056 a ns1:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en recuperación de posiciones de herramientas en almacén"@es ;
    ns1:identificador "8056" ;
    ns1:textoExtracto "Inconsistencia en la recuperación de las posiciones de las herramientas en el almacén. DETECCIÓN Durante el arranque del CNC. CAUSA El CNC no ha podido recuperar la información de"@es .

