@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FaseArranqueCNC a ns1:ModoOperacion ;
    rdfs:label "Arranque del CNC"@es ;
    ns1:activaAlarma ns1:ErrorRecuperacionFRAM_8128 ;
    ns1:textoExtracto "Durante el arranque del CNC."@es .

ns1:SolucionErrorFRAM_8128 a ns1:TareaMantenimiento ;
    rdfs:label "Verificación de configuración EtherCAT y conexiones para error 8128"@es ;
    ns1:solucionaFallo ns1:ErrorRecuperacionFRAM_8128 ;
    ns1:textoExtracto "Verificar la configuración EtherCAT, conexiones, versión de boot y aplicación de nodos remotos."@es .

ns1:ErrorRecuperacionFRAM_8128 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8128: Fallo en recuperación de datos FRAM"@es ;
    ns1:identificador "8128" ;
    ns1:textoExtracto "No se han podido recuperar los datos de FRAM. [...] Error durante el proceso de recuperación de datos de FRAM. Se arranca con los datos de RAM."@es .

