@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_8128 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8128: Fallo de recuperación de datos FRAM"@es ;
    ns1:identificador "8128" ;
    ns1:mitigaRiesgo ns1:AccionProhibida_ArranqueConDatosRAM ;
    ns1:textoExtracto "No se han podido recuperar los datos de FRAM. DETECCIÓN Durante el arranque del CNC. CAUSA Error durante el proceso de recuperación de datos de FRAM. Se arranca con los datos de RAM. SOLUCIÓN Reiniciar el CNC."@es .

ns1:Manual_ProgramacionCNC a ns1:Manual ;
    rdfs:label "Manual de programación del CNC"@es ;
    ns1:documentadoEn ns1:AvisoSeguridad_8200,
        ns1:AvisoSeguridad_8201 ;
    ns1:textoExtracto "Revisar en el manual de programación los valores admisibles para los parámetros de la sentencia o índices de la variable."@es .

ns1:ModoOperacion_MDI a ns1:ModoOperacion ;
    rdfs:label "Modo MDI (Manual Data Input)"@es ;
    ns1:requiereMantenimiento ns1:DiagnosticoFallo_ValoresEnterosMDI,
        ns1:DiagnosticoFallo_ValoresFlotantesMDI ;
    ns1:textoExtracto "Durante la edición y ejecución en MDI."@es .

ns1:AccionProhibida_ArranqueConDatosRAM a ns1:AccionProhibida ;
    rdfs:label "Arranque del CNC con datos de RAM tras fallo FRAM"@es ;
    ns1:textoExtracto "Se arranca con los datos de RAM [tras fallo de recuperación FRAM]."@es .

ns1:AvisoSeguridad_8200 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8200: Fallo del lexer al reconocer enteros"@es ;
    ns1:identificador "8200" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_ValoresEnterosMDI ;
    ns1:textoExtracto "'Fallo del lexer al reconocer enteros' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA Error al convertir una cadena de caracteres a un valor numérico. Algún valor programado en la sentencia o variable no es correcto. SOLUCIÓN Revisar en el manual de programación los valores admisibles para los parámetros de la sentencia o índices de la variable."@es .

ns1:AvisoSeguridad_8201 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8201: Fallo del lexer al reconocer flotantes"@es ;
    ns1:identificador "8201" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_ValoresFlotantesMDI ;
    ns1:textoExtracto "'Fallo del lexer al reconocer flotantes' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA Error al convertir una cadena de caracteres a un valor numérico. Algún valor programado en la sentencia o variable no es correcto. SOLUCIÓN Revisar en el manual de programación los valores admisibles para los parámetros de la sentencia o índices de la variable."@es .

ns1:DiagnosticoFallo_ValoresEnterosMDI a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Valores enteros incorrectos en programación MDI"@es ;
    ns1:textoExtracto "Error al convertir una cadena de caracteres a un valor numérico. Algún valor programado en la sentencia o variable no es correcto."@es .

ns1:DiagnosticoFallo_ValoresFlotantesMDI a ns1:DiagnosticoFallo ;
    rdfs:label "Diagnóstico: Valores flotantes incorrectos en programación MDI"@es ;
    ns1:textoExtracto "Error al convertir una cadena de caracteres a un valor numérico. Algún valor programado en la sentencia o variable no es correcto."@es .

