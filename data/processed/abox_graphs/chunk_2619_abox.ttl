@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_8206 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 8206: Falta '#'"@es ;
    ns1:detalladoEnEsquema ns1:InterfazProgramacion ;
    ns1:identificador "8206" ;
    ns1:textoExtracto "CAUSA Programada una sentencia sin el carácter de inicio \"#\". SOLUCIÓN Programar \"#\" antes del nombre de la sentencia."@es .

ns1:Fallo_8207 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 8207: Nombre de programa o subrutina demasiado largo"@es ;
    ns1:detalladoEnEsquema ns1:InterfazProgramacion ;
    ns1:identificador "8207" ;
    ns1:textoExtracto "CAUSA Superado el máximo número de caracteres"@es .

ns1:Fallo_ControlSinIniciador a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo: Instrucción de control sin carácter de inicio \"$\""@es ;
    ns1:detalladoEnEsquema ns1:InterfazProgramacion ;
    ns1:textoExtracto "CAUSA Programada una instrucción de control sin el carácter de inicio \"$\". SOLUCIÓN Programar \"$\" antes del nombre de la instrucción de control."@es .

ns1:Parametro_SintaxisInstrucciones a ns1:Parametro ;
    rdfs:label "Sintaxis de instrucciones de control"@es ;
    ns1:textoExtracto "instrucción de control sin el carácter de inicio \"$\", sentencia sin el carácter de inicio \"#\", nombre de programa o subrutina demasiado largo"@es .

ns1:InterfazProgramacion a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de programación/edición"@es ;
    ns1:monitoreaParametro ns1:Parametro_SintaxisInstrucciones ;
    ns1:textoExtracto "DETECCIÓN Durante la edición."@es .

