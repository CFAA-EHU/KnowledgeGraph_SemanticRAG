@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_ComodinesEje a ns1:Parametro ;
    rdfs:label "Comodines válidos para nombres de eje" ;
    ns1:documentadoEn ns1:AvisoSeguridad_8209 ;
    ns1:textoExtracto "Los nombres de eje con comodín válidos son @1 a @5." ;
    ns1:valor "@1 a @5" .

ns1:Parametro_LimiteCaracteresNombre a ns1:Parametro ;
    rdfs:label "Límite de caracteres para nombre de programa/subrutina" ;
    ns1:documentadoEn ns1:AvisoSeguridad_8207 ;
    ns1:textoExtracto "El máximo número de caracteres permitido es 14." ;
    ns1:valor "14" .

ns1:Parametro_LimiteEntero a ns1:Parametro ;
    rdfs:label "Valor máximo para enteros" ;
    ns1:documentadoEn ns1:AvisoSeguridad_8210 ;
    ns1:textoExtracto "El máximo valor admisible para un valor entero es 4294967295." ;
    ns1:valor "4294967295" .

ns1:Parametro_RangoParteEntera a ns1:Parametro ;
    rdfs:label "Rango válido para parte entera" ;
    ns1:documentadoEn ns1:AvisoSeguridad_8211 ;
    ns1:textoExtracto "El rango de valores válidos para la parte entera de un número es ±99999." ;
    ns1:valor "±99999" .

ns1:AvisoSeguridad_8207 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8207: Nombre de programa o subrutina demasiado largo" ;
    ns1:identificador "8207" ;
    ns1:textoExtracto "8207 'Nombre de programa o subrutina demasiado largo' DETECCIÓN Durante la edición. CAUSA Superado el máximo número de caracteres permitido para el nombre de programa o subrutina. SOLUCIÓN El máximo número de caracteres permitido es 14." .

ns1:AvisoSeguridad_8209 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8209: Eje activo inválido" ;
    ns1:identificador "8209" ;
    ns1:textoExtracto "8209 'Eje activo inválido' DETECCIÓN Durante la edición. CAUSA Programado el nombre del eje con un comodín no válido. SOLUCIÓN Los nombres de eje con comodín válidos son @1 a @5." .

ns1:AvisoSeguridad_8210 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8210: Excedidos límites para enteros" ;
    ns1:identificador "8210" ;
    ns1:textoExtracto "8210 'Excedidos límites para enteros' DETECCIÓN Durante la edición. CAUSA Programado un número entero demasiado alto. SOLUCIÓN El máximo valor admisible para un valor entero es 4294967295." .

ns1:AvisoSeguridad_8211 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8211: Excedidos límites para parte entera" ;
    ns1:identificador "8211" ;
    ns1:textoExtracto "8211 'Excedidos límites para parte entera' DETECCIÓN Durante la edición. CAUSA La parte entera del número tiene un valor no válido. SOLUCIÓN El rango de valores válidos para la parte entera de un número es ±99999." .

