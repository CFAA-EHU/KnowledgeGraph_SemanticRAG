@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_EdicionPrograma a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de edición de programa"@es ;
    ns1:activaAlarma ns1:AvisoSeguridad_8211,
        ns1:AvisoSeguridad_8212,
        ns1:AvisoSeguridad_8213,
        ns1:AvisoSeguridad_8214,
        ns1:AvisoSeguridad_8215 ;
    ns1:textoExtracto "Detección de errores durante la edición de instrucciones y valores numéricos."@es .

ns1:AvisoSeguridad_8211 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8211: Parte entera del número no válida"@es ;
    ns1:identificador "8211" ;
    ns1:textoExtracto "CAUSA: La parte entera del número tiene un valor no válido. SOLUCIÓN: El rango de valores válidos para la parte entera de un número es ±99999."@es .

ns1:AvisoSeguridad_8212 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8212: Excedidos límites para parte fraccionaria"@es ;
    ns1:identificador "8212" ;
    ns1:textoExtracto "CAUSA: La parte decimal del número tiene un valor no válido. SOLUCIÓN: El rango de valores válidos para la parte decimal de un número es ±0.99999."@es .

ns1:AvisoSeguridad_8213 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8213: Excedido formato para parte fraccionaria"@es ;
    ns1:identificador "8213" ;
    ns1:textoExtracto "CAUSA: Superado el máximo número de dígitos permitido para la parte decimal de un número. SOLUCIÓN: El máximo número de dígitos permitido para la parte decimal de un número es 5."@es .

ns1:AvisoSeguridad_8214 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8214: Instrucción de control de flujo desconocida"@es ;
    ns1:identificador "8214" ;
    ns1:textoExtracto "CAUSA: La instrucción programada tras el carácter \"$\" no es correcta. SOLUCIÓN: Revisar la sintaxis de la instrucción."@es .

ns1:AvisoSeguridad_8215 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8215: Excedido formato para función"@es ;
    ns1:identificador "8215" ;
    ns1:textoExtracto "CAUSA: Superado el formato permitido para función. SOLUCIÓN: Revisar sintaxis durante edición y ejecución."@es .

