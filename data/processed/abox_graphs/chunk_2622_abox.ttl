@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_8215 a ns1:DiagnosticoFallo ;
    rdfs:label "Excedido formato para función"@es ;
    ns1:identificador "8215" ;
    ns1:solucionaFallo ns1:RevisarSintaxisDeInstruccion ;
    ns1:textoExtracto "8215 'Excedido formato para función' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:Fallo_8217 a ns1:DiagnosticoFallo ;
    rdfs:label "Excedidos límites para flotantes"@es ;
    ns1:identificador "8217" ;
    ns1:solucionaFallo ns1:RevisarSintaxisDeSentenciaEnManual ;
    ns1:textoExtracto "8217 'Excedidos límites para flotantes' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:RevisarSintaxisDeInstruccion a ns1:TareaMantenimiento ;
    rdfs:label "Revisar sintaxis de instrucción"@es ;
    ns1:requiereMantenimiento ns1:ManualProgramacion ;
    ns1:textoExtracto "SOLUCIÓN Revisar la sintaxis de la instrucción."@es .

ns1:RevisarSintaxisDeSentenciaEnManual a ns1:TareaMantenimiento ;
    rdfs:label "Revisar sintaxis de sentencia en manual"@es ;
    ns1:requiereMantenimiento ns1:ManualProgramacion ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación"@es ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia."@es .

