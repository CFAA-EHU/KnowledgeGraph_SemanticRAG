@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8218 a ns1:AvisoSeguridad ;
    rdfs:label "Carácter no válido" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8218" ;
    ns1:textoExtracto "8218 'Carácter no válido' DETECCIÓN Durante la edición. CAUSA Detectado un carácter no válido en el bloque. SOLUCIÓN Revisar la sintaxis del bloque." .

ns1:Error_8219 a ns1:AvisoSeguridad ;
    rdfs:label "Cadena de error vacía" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8219" ;
    ns1:textoExtracto "8219' Cadena de error vacía' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Error_8220 a ns1:AvisoSeguridad ;
    rdfs:label "Cadena de Warning vacía" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8220" ;
    ns1:textoExtracto "8220 'Cadena de Warning vacía' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Error_8221 a ns1:AvisoSeguridad ;
    rdfs:label "Error sintáctico" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8221" ;
    ns1:textoExtracto "8221 'Error sintáctico' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA La sintaxis de la sentencia o variable programada no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia o variable." .

ns1:Error_8222 a ns1:AvisoSeguridad ;
    rdfs:label "Función M inexistente" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8222" ;
    ns1:textoExtracto "8222 'Función M inexistente' DETECCIÓN Durante la edición. CAUSA La función M programada no existe. SOLUCIÓN Revisar en el manual de programación las funciones M existentes." .

ns1:Error_8223 a ns1:AvisoSeguridad ;
    rdfs:label "Exclusividad mutua o funciones M iguales" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8223" ;
    ns1:textoExtracto "8223 'Exclusividad mutua o funciones M iguales' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA Hay una función M programada más de una vez en el mismo bloque o hay dos funciones M incompatibles en el mismo bloque. SOLUCIÓN Una función M sólo debe programarse una vez en el bloque. Revisar el manual de programación para comprobar la exclusividad mutua de las funciones M." .

ns1:Error_8224 a ns1:AvisoSeguridad ;
    rdfs:label "Función M fuera de rango" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8224" ;
    ns1:textoExtracto "8224 'Función M fuera de rango' DETECCIÓN Durante la edición. CAUSA La función M programada no existe. SOLUCIÓN Revisar en el manual de programación las funciones M existentes." .

ns1:Error_8225 a ns1:AvisoSeguridad ;
    rdfs:label "Función G fuera de rango" ;
    ns1:identificador "8225" ;
    ns1:textoExtracto "8225 'Función G fuera de rango' DETECCIÓN Durante la edición y ejecución en MDI." .

ns1:Error_flotantes a ns1:AvisoSeguridad ;
