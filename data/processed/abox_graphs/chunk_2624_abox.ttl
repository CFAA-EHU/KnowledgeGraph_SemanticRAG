@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_8224 a ns1:DiagnosticoFallo ;
    rdfs:label "Función M programada no existe" ;
    ns1:solucionaFallo ns1:UsoDeFuncionMNoExistente ;
    ns1:textoExtracto "CAUSA La función M programada no existe. SOLUCIÓN Revisar en el manual de programación las funciones M existentes." .

ns1:DiagnosticoFallo_8225 a ns1:DiagnosticoFallo ;
    rdfs:label "Función G fuera de rango" ;
    ns1:identificador "8225" ;
    ns1:solucionaFallo ns1:UsoDeFuncionGNoExistente ;
    ns1:textoExtracto "DETECCIÓN Durante la edición y ejecución en MDI. CAUSA La función G programada no existe. SOLUCIÓN Revisar en el manual de programación las funciones G existentes." .

ns1:DiagnosticoFallo_8226 a ns1:DiagnosticoFallo ;
    rdfs:label "Función H fuera de rango" ;
    ns1:identificador "8226" ;
    ns1:solucionaFallo ns1:UsoDeFuncionHNoExistente ;
    ns1:textoExtracto "DETECCIÓN Durante la edición. CAUSA La función H programada no existe. SOLUCIÓN Revisar" .

ns1:Manual_Programacion a ns1:Manual ;
    rdfs:label "Manual de programación" ;
    ns1:textoExtracto "Revisar en el manual de programación las funciones M/G/H existentes." .

ns1:UsoDeFuncionGNoExistente a ns1:AccionProhibida ;
    rdfs:label "Uso de función G no existente" ;
    ns1:textoExtracto "La función G programada no existe." .

ns1:UsoDeFuncionHNoExistente a ns1:AccionProhibida ;
    rdfs:label "Uso de función H no existente" ;
    ns1:textoExtracto "La función H programada no existe." .

ns1:UsoDeFuncionMNoExistente a ns1:AccionProhibida ;
    rdfs:label "Uso de función M no existente" ;
    ns1:textoExtracto "La función M programada no existe." .

