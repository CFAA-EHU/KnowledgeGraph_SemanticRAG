@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_8226 a ns1:Alarma ;
    rdfs:label "Alarma 8226: Función H fuera de rango" ;
    ns1:identificador "8226" ;
    ns1:monitoreaParametro ns1:Parametro_H ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "'Función H fuera de rango' DETECCIÓN Durante la edición. CAUSA La función H programada no existe." .

ns1:Alarma_8227 a ns1:Alarma ;
    rdfs:label "Alarma 8227: Sólo se permite una S negativa con G63" ;
    ns1:identificador "8227" ;
    ns1:monitoreaParametro ns1:Parametro_G63,
        ns1:Parametro_S ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "'Sólo se permite una S negativa con G63' DETECCIÓN Durante la edición. CAUSA Programada una velocidad de cabezal negativa sin haber programado la función G63 en el bloque." .

ns1:Alarma_8228 a ns1:Alarma ;
    rdfs:label "Alarma 8228: Número de herramienta fuera de rango" ;
    ns1:identificador "8228" ;
    ns1:monitoreaParametro ns1:Herramienta ;
    ns1:textoExtracto "'Número de herramienta fuera de rango' DETECCIÓN Durante la edición. CAUSA Programado un número de herramienta negativo." .

ns1:Alarma_8229 a ns1:Alarma ;
    rdfs:label "Alarma 8229: F o E fuera de rango" ;
    ns1:identificador "8229" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "'F o E fuera de rango' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:Alarma_8230 a ns1:Alarma ;
    rdfs:label "Alarma 8230: Velocidad F doblemente programada" ;
    ns1:identificador "8230" ;
    ns1:monitoreaParametro ns1:Parametro_F ;
    ns1:textoExtracto "'Velocidad F doblemente programada' DETECCIÓN Durante la edición. CAUSA La función F está programada más de una vez en el bloque." .

ns1:Alarma_8232 a ns1:Alarma ;
    rdfs:label "Alarma 8232: A doblemente programada" ;
    ns1:identificador "8232" ;
    ns1:textoExtracto "'A doblemente programada' DETECCIÓN Durante la edición. CAUSA Programado el eje A más de una vez en el bloque." .

ns1:Alarma_8233 a ns1:Alarma ;
    rdfs:label "Alarma 8233: B doblemente programada" ;
    ns1:identificador "8233" ;
    ns1:textoExtracto "'B doblemente programada' DETECCIÓN Durante la edición. CAUSA Programado el eje B más de una vez en el bloque." .

ns1:Alarma_8234 a ns1:Alarma ;
    rdfs:label "Alarma 8234: C doblemente programada" ;
    ns1:identificador "8234" ;
    ns1:textoExtracto "'C doblemente programada' DETECCIÓN Durante la edición. CAUSA Programado el eje C más de una vez en el bloque." .

ns1:Alarma_8235 a ns1:Alarma ;
    rdfs:label "Alarma 8235: U doblemente programada" ;
    ns1:identificador "8235" ;
    ns1:textoExtracto "'U doblemente programada' DETECCIÓN Durante la edición." .

ns1:Parametro_F a ns1:Parametro ;
    rdfs:label "Parámetro F (velocidad)" ;
    ns1:textoExtracto "La función F está programada más de una vez en el bloque." .

ns1:Parametro_G63 a ns1:Parametro ;
    rdfs:label "Parámetro G63 (función de programación)" ;
    ns1:textoExtracto "Sólo se permite un valor negativo si se programa en el mismo bloque que la función G63." .

ns1:Parametro_H a ns1:Parametro ;
    rdfs:label "Parámetro H (función)" ;
    ns1:textoExtracto "La función H programada no existe." .

ns1:Parametro_S a ns1:Parametro ;
    rdfs:label "Parámetro S (velocidad de cabezal)" ;
    ns1:textoExtracto "Programada una velocidad de cabezal negativa sin haber programado la función G63 en el bloque." .

ns1:Herramienta a ns1:Herramienta ;
    rdfs:label "Herramienta (número de referencia)" ;
    ns1:textoExtracto "Programado un número de herramienta negativo." .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación" ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación las funciones G existentes." .

