@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_8247 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 8247: 'Sólo R1 puede formar parte de expresiones'" ;
    ns1:identificador "8247" ;
    ns1:solucionaFallo ns1:Parametro_R,
        ns1:Parametro_R1 ;
    ns1:textoExtracto "'Sólo R1 puede formar parte de expresiones' DETECCIÓN Durante la edición. CAUSA La programación del radio es incorrecta. SOLUCIÓN El radio sólo se puede programar mediante \"R\" o \"R1\"." .

ns1:AvisoSeguridad_8250 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 8250: 'Variable de eje sin permiso de escritura'" ;
    ns1:identificador "8250" ;
    ns1:textoExtracto "'Variable de eje sin permiso de escritura' DETECCIÓN Durante la edición. CAUSA La variable no tiene permiso de escritura. SOLUCIÓN La variable es de solo lectura." .

ns1:AvisoSeguridad_8251 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 8251: 'Variable global sin permiso de escritura'" ;
    ns1:identificador "8251" ;
    ns1:textoExtracto "'Variable global sin permiso de escritura' DETECCIÓN Durante la edición. CAUSA La variable no tiene permiso de escritura. SOLUCIÓN La variable es de solo lectura." .

ns1:AvisoSeguridad_8253 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 8253: 'Faltan ejes en G20'" ;
    ns1:identificador "8253" ;
    ns1:solucionaFallo ns1:Funcion_G20 ;
    ns1:textoExtracto "'Faltan ejes en G20' DETECCIÓN Durante la edición. CAUSA No se han programado todos los parámetros obligatorios en la función G20." .

ns1:AvisoSeguridad_K_Duplicada a ns1:AvisoSeguridad ;
    rdfs:label "Aviso: 'K doblemente programada'" ;
    ns1:solucionaFallo ns1:Parametro_K ;
    ns1:textoExtracto "'K doblemente programada' DETECCIÓN Durante la edición. CAUSA El parámetro K está programado más de una vez en el bloque. SOLUCIÓN Programar el parámetro K una sola vez en el bloque." .

ns1:Funcion_G20 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G20" ;
    ns1:textoExtracto "No se han programado todos los parámetros obligatorios en la función G20." .

ns1:Parametro_K a ns1:Parametro ;
    rdfs:label "Parámetro K" ;
    ns1:textoExtracto "El parámetro K está programado más de una vez en el bloque." .

ns1:Parametro_R a ns1:Parametro ;
    rdfs:label "Parámetro R" ;
    ns1:textoExtracto "El radio sólo se puede programar mediante \"R\" o \"R1\"." .

ns1:Parametro_R1 a ns1:Parametro ;
    rdfs:label "Parámetro R1" ;
    ns1:textoExtracto "El radio sólo se puede programar mediante \"R\" o \"R1\"." .

