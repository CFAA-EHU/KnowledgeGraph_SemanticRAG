@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_8254 a ns1:DiagnosticoFallo ;
    rdfs:label "Sobran ejes en G20" ;
    ns1:identificador "8254" ;
    ns1:solucionaFallo ns1:Parametro_G20 ;
    ns1:textoExtracto "8254 'Sobran ejes en G20' DETECCIÓN Durante la edición. CAUSA Algunos de los parámetros programados para la función G20 no están permitidos. SOLUCIÓN Revisar la sintaxis de programación de la función G20." .

ns1:Fallo_8256 a ns1:DiagnosticoFallo ;
    rdfs:label "Instrucción de ciclo de interpolador inexistente" ;
    ns1:identificador "8256" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "8256 'Instrucción de ciclo de interpolador inexistente' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA La instrucción programada no existe. SOLUCIÓN Revisar el manual de programación." .

ns1:Fallo_8257 a ns1:DiagnosticoFallo ;
    rdfs:label "Carácter incorrecto en nombre de programa/subrutina" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8257" ;
    ns1:textoExtracto "8257 'No puede haber nada después del nombre del programa o subrutina' DETECCIÓN Durante la edición. CAUSA En el nombre del programa principal o de la subrutina hay un carácter incorrecto. SOLUCIÓN La definición del nombre del programa principal o subrutina tan solo puede ir acompañada de comentario. Los caracteres prohibidos son: • Programa principal: \\ / : * ? \" < > | y espacio en blanco." .

ns1:Parametro_G20 a ns1:Parametro ;
    rdfs:label "Parámetros obligatorios de la función G20" ;
    ns1:textoExtracto "CAUSA No se han programado todos los parámetros obligatorios en la función G20. SOLUCIÓN Revisar la sintaxis de programación de la función G20." .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación" ;
    ns1:textoExtracto "SOLUCIÓN Revisar el manual de programación." .

