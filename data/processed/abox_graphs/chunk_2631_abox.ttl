@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_CaracteresProgramaPrincipal a ns1:AccionProhibida ;
    rdfs:label "Caracteres prohibidos en programa principal"@es ;
    ns1:textoExtracto "Los caracteres prohibidos son: • Programa principal: \\ / : * ? \" < > | y espacio en blanco."@es .

ns1:AccionProhibida_CaracteresSubrutinaLocal a ns1:AccionProhibida ;
    rdfs:label "Caracteres prohibidos en subrutina local"@es ;
    ns1:textoExtracto "• Subrutina local: / ? \" < > | ) y espacio en blanco."@es .

ns1:Error_8258 a ns1:DiagnosticoFallo ;
    rdfs:label "'Se esperaba expresión tras #TIME'"@es ;
    ns1:identificador "8258" ;
    ns1:textoExtracto "8258 'Se esperaba expresión tras #TIME' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA Sentencia #TIME programada incorrectamente. SOLUCIÓN Esta sentencia #TIME se programa de la forma #TIME [<time>] (los corchetes son opcionales), donde"@es .

