@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8265 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8265: 'Palabra desconocida o incompleta'" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8265" ;
    ns1:solucionaFallo ns1:Funcion_M,
        ns1:Sentencia_TIME,
        ns1:Sentencia_TOOL_AX ;
    ns1:textoExtracto "8265 'Palabra desconocida o incompleta' DETECCIÓN Durante la edición. CAUSA Las posibles causas son las siguientes: • La función, sentencia o expresión programada no es válida. • Programación incorrecta de la función M para un determinado cabezal. • Programación incorrecta de la sentencia #TOOL AX. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia, función o expresión que se quiere programar." .

ns1:Error_8267 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8267: 'Variable de ciclo sin permiso de escritura'" ;
    ns1:identificador "8267" ;
    ns1:textoExtracto "8267 'Variable de ciclo sin permiso de escritura' DETECCIÓN Durante la edición. CAUSA La variable no tiene permiso de escritura. SOLUCIÓN La variable es de solo lectura." .

ns1:Error_8268 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8268: 'Argumento fuera de límites en función'" ;
    ns1:identificador "8268" ;
    ns1:solucionaFallo ns1:FuncionesMatematicas ;
    ns1:textoExtracto "8268 'Argumento fuera de límites en función' DETECCIÓN Durante la edición. CAUSA El argumento programado en la función matemática no es válido. SOLUCIÓN Programar un argumento correcto en la función matemática (LN, LOG, SQRT, EXP, DEXP, SIN, COS, TAN, ASIN, ACOS, ATAN)." .

ns1:Error_8269 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8269: 'Rebasamiento por encima en función'" ;
    ns1:identificador "8269" ;
    ns1:solucionaFallo ns1:FuncionesMatematicas ;
    ns1:textoExtracto "8269 'Rebasamiento por encima en función' DETECCIÓN Durante la edición. CAUSA El argumento programado en la función matemática no es válido. SOLUCIÓN Programar un argumento correcto en la función matemática (LN, LOG, SQRT, EXP, DEXP, SIN, COS, TAN, ASIN, ACOS, ATAN)." .

ns1:Error_8270 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8270: 'Pérdida parcial de función'" ;
    ns1:identificador "8270" ;
    ns1:solucionaFallo ns1:FuncionesMatematicas ;
    ns1:textoExtracto "8270 'Pérdida parcial de función' DETECCIÓN Durante la edición. CAUSA El argumento programado en la función matemática no es válido. SOLUCIÓN Programar un argumento correcto en la función matemática (LN, LOG, SQRT, EXP, DEXP, SIN, COS, TAN, ASIN, ACOS, ATAN)." .

ns1:Error_8271 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8271: 'Argumento no permitido en función'" ;
    ns1:identificador "8271" ;
    ns1:textoExtracto "8271 'Argumento no permitido en función' DETECCIÓN Durante la edición." .

ns1:Funcion_M a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función M para cabezal" ;
    ns1:textoExtracto "Programación incorrecta de la función M para un determinado cabezal." ;
    ns1:valor "M[<cabezal>]" .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación" ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia, función o expresión que se quiere programar." .

ns1:Sentencia_TIME a ns1:Parametro ;
    rdfs:label "Sentencia #TIME" ;
    ns1:textoExtracto "Sentencia #TIME programada incorrectamente. SOLUCIÓN Esta sentencia #TIME se programa de la forma #TIME [<time>] (los corchetes son opcionales), donde el parámetro <time> puede ser un número entero, un parámetro aritmético o una variable." ;
    ns1:valor "#TIME [<time>]" .

ns1:Sentencia_TOOL_AX a ns1:Parametro ;
    rdfs:label "Sentencia #TOOL AX" ;
    ns1:textoExtracto "Programación incorrecta de la sentencia #TOOL AX." ;
    ns1:valor "#TOOL AX" .

ns1:FuncionesMatematicas a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Funciones matemáticas (LN, LOG, SQRT, EXP, DEXP, SIN, COS, TAN, ASIN, ACOS, ATAN)" ;
    ns1:textoExtracto "Programar un argumento correcto en la función matemática (LN, LOG, SQRT, EXP, DEXP, SIN, COS, TAN, ASIN, ACOS, ATAN)." ;
    ns1:valor "LN, LOG, SQRT, EXP, DEXP, SIN, COS, TAN, ASIN, ACOS, ATAN" .

