@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8271 a ns1:DiagnosticoFallo ;
    rdfs:label "Argumento no permitido en función"@es ;
    ns1:identificador "8271" ;
    ns1:solucionaFallo ns1:Solucion_8271 ;
    ns1:textoExtracto "8271 'Argumento no permitido en función' DETECCIÓN Durante la edición. CAUSA El argumento programado en la función matemática no es válido."@es .

ns1:Error_8272 a ns1:DiagnosticoFallo ;
    rdfs:label "Pérdida total en función"@es ;
    ns1:identificador "8272" ;
    ns1:textoExtracto "8272 'Pérdida total en función' DETECCIÓN Durante la"@es .

ns1:Solucion_8271 a ns1:TareaMantenimiento ;
    rdfs:label "Programar argumento correcto en función matemática (LN, LOG, SQRT, EXP, DEXP, SIN, COS, TAN, ASIN, ACOS, ATAN)"@es ;
    ns1:textoExtracto "SOLUCIÓN Programar un argumento correcto en la función matemática (LN, LOG, SQRT, EXP, DEXP, SIN, COS, TAN, ASIN, ACOS, ATAN)."@es .

