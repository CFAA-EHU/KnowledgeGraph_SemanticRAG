@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteMecanico_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:monitoreaParametro ns1:Parametro_VelocidadPosicionamiento ;
    ns1:textoExtracto "Velocidad de posicionamiento del cabezal negativa" .

ns1:DiagnosticoFallo_8279 a ns1:DiagnosticoFallo ;
    rdfs:label "Imagen espejo repetida" ;
    ns1:identificador "8279" ;
    ns1:textoExtracto "8279 'Imagen espejo repetida' DETECCIÓN Durante la edición. CAUSA Las funciones G11, G12 o G13 están programadas más de una vez en el mismo bloque. La función G10 o G14 está programada junto a las funciones G11, G12 o G13 en el mismo bloque. SOLUCIÓN Las funciones G11, G12 y G13 se pueden combinar en un mismo bloque pero cada una de ellas sólo se puede programar una vez. La funciones G10 y G14 no se pueden programar en el mismo bloque que la G11, G12 o G13." .

ns1:DiagnosticoFallo_8280 a ns1:DiagnosticoFallo ;
    rdfs:label "Velocidad de posicionamiento del cabezal negativa" ;
    ns1:identificador "8280" ;
    ns1:textoExtracto "8280 'Velocidad de posicionamiento del cabezal negativa' DETECCIÓN Durante la edición. CAUSA Programada una velocidad" .

ns1:Parametro_VelocidadPosicionamiento a ns1:Parametro ;
    rdfs:label "Velocidad de posicionamiento" ;
    ns1:textoExtracto "Velocidad de posicionamiento del cabezal negativa" .

