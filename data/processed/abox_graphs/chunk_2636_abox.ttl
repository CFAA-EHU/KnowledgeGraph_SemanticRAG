@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_8280 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 8280: Velocidad de posicionamiento del cabezal negativa" ;
    ns1:identificador "8280" ;
    ns1:textoExtracto "8280 'Velocidad de posicionamiento del cabezal negativa' DETECCIÓN Durante la edición. CAUSA Programada una velocidad de posicionamiento negativa en M19. SOLUCIÓN La velocidad de posicionamiento \"Sn. POS\" debe ser positiva." .

ns1:AvisoSeguridad_8281 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 8281: Velocidad de posicionamiento del cabezal doblemente programada" ;
    ns1:identificador "8281" ;
    ns1:textoExtracto "8281 'Velocidad de posicionamiento del cabezal doblemente programada' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA En un mismo bloque hay programado más de una vez la velocidad de posicionamiento del cabezal en M19. SOLUCIÓN Programar una única vez la velocidad de posicionamiento del cabezal \"Sn. POS\"." .

ns1:AvisoSeguridad_8282 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 8282: Parámetro de ciclo fijo repetido" ;
    ns1:identificador "8282" ;
    ns1:textoExtracto "8282 'Parámetro de ciclo fijo repetido' DETECCIÓN Durante la edición. CAUSA Algún parámetro del ciclo fijo está programado más de una vez en el bloque. SOLUCIÓN Cada parámetro del ciclo fijo sólo se puede programar una vez en el bloque." .

ns1:AvisoSeguridad_8283 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 8283: Parámetro no válido en ciclo fijo" ;
    ns1:identificador "8283" ;
    ns1:textoExtracto "8283 'Parámetro no válido en ciclo fijo' DETECCIÓN Durante la edición. CAUSA Programado un parámetro no válido para ese ciclo fijo. SOLUCIÓN Revisar en el manual de programación los parámetros obligatorios y permitidos para cada ciclo fijo." .

ns1:AvisoSeguridad_8284 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 8284: Variable de PLC sin permiso de escritura" ;
    ns1:identificador "8284" ;
    ns1:textoExtracto "8284 'Variable de plc sin permiso de escritura' DETECCIÓN Durante la edición. CAUSA La variable no tiene permiso de escritura. SOLUCIÓN La variable es de solo lectura." .

ns1:AvisoSeguridad_8285 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 8285: G20 - Signo negativo en eje no longitudinal" ;
    ns1:identificador "8285" ;
    ns1:textoExtracto "8285 'G20: sólo se admite signo negativo en el eje longitudinal' DETECCIÓN Durante la edición. CAUSA En la función G20 hay programado un eje con signo negativo y no es el longitudinal. SOLUCIÓN En la función G20 sólo el eje longitudinal puede tener signo negativo." .

ns1:AvisoSeguridad_8287 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 8287: Límites excedidos para parte entera" ;
    ns1:identificador "8287" ;
    ns1:textoExtracto "8287 'Excedidos límites para parte entera' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Funcion_G20 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G20 (restricción de signo en eje longitudinal)" ;
    ns1:textoExtracto "En la función G20 sólo el eje longitudinal puede tener signo negativo." .

ns1:Parametro_CicloFijo a ns1:Parametro ;
    rdfs:label "Parámetro de ciclo fijo" ;
    ns1:documentadoEn ns1:Manual_Programacion ;
    ns1:textoExtracto "Algún parámetro del ciclo fijo está programado más de una vez en el bloque." .

ns1:Parametro_Sn_POS a ns1:Parametro ;
    rdfs:label "Parámetro Sn. POS (velocidad de posicionamiento del cabezal)" ;
    ns1:textoExtracto "La velocidad de posicionamiento \"Sn. POS\" debe ser positiva." .

ns1:Variable_PLC a ns1:Parametro ;
    rdfs:label "Variable de PLC (solo lectura)" ;
    ns1:textoExtracto "La variable no tiene permiso de escritura. La variable es de solo lectura." .

ns1:Manual_Programacion a ns1:Manual ;
    rdfs:label "Manual de programación" ;
    ns1:textoExtracto "Revisar en el manual de programación los parámetros obligatorios y permitidos para cada ciclo fijo." .

