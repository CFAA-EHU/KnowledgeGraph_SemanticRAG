@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_8290 a ns1:Alarma ;
    rdfs:label "Variable del gestor de herramientas sin permiso de escritura"@es ;
    ns1:identificador "8290" ;
    ns1:monitoreaParametro ns1:Parametro_VariableGestorHerramientas ;
    ns1:textoExtracto "8290 'Variable del gestor de herramientas sin permiso de escritura' DETECCIÓN Durante la edición. CAUSA La variable no tiene permiso de escritura. SOLUCIÓN La variable es de solo lectura."@es .

ns1:Alarma_8291 a ns1:Alarma ;
    rdfs:label "Variable del parámetro máquina sin permiso de escritura"@es ;
    ns1:identificador "8291" ;
    ns1:monitoreaParametro ns1:Parametro_VariableMaquina ;
    ns1:textoExtracto "8291 'Variable del parámetro máquina sin permiso de escritura' DETECCIÓN Durante la edición. CAUSA La variable no tiene permiso de escritura. SOLUCIÓN La variable es de solo lectura."@es .

ns1:Alarma_8295 a ns1:Alarma ;
    rdfs:label "Lista de parámetros vacía"@es ;
    ns1:identificador "8295" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "8295 'Lista de parámetros vacía' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:Alarma_8296 a ns1:Alarma ;
    rdfs:label "Parámetro repetido o incompleto"@es ;
    ns1:identificador "8296" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "8296 'Parámetro repetido o incompleto' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:Alarma_8297 a ns1:Alarma ;
    rdfs:label "Parámetro repetido"@es ;
    ns1:identificador "8297" ;
    ns1:textoExtracto "8297 'Parámetro repetido' DETECCIÓN Durante la edición. CAUSA Las posibles causas son las siguientes: • En la sentencia #HSC se ha programado el parámetro CONTERROR más de una vez. • En la sentencia de llamada a subrutina #PCALL, #MCALL o función G con subrutina asociada se ha programado algún parámetro más de una vez. • En la sentencia #PROBE o #POLY se ha programado algún parámetro más de una vez. SOLUCIÓN Programar cada parámetro una única vez en el bloque."@es .

ns1:Alarma_8299 a ns1:Alarma ;
    rdfs:label "Faltan corchetes alrededor de la lista de parámetros"@es ;
    ns1:identificador "8299" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "8299 'Faltan corchetes alrededor de la lista de parámetros' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA La sentencia programada exige que su lista de parámetros se programe entre corchetes. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:Alarma_8300 a ns1:Alarma ;
    rdfs:label "Se precisa al menos un eje para G170, G171 o G157"@es ;
    ns1:identificador "8300" ;
    ns1:textoExtracto "8300 'Se precisa al menos un eje para G170, G171 o G157' DETECCIÓN Durante la edición."@es .

ns1:Parametro_CONTERROR a ns1:Parametro ;
    rdfs:label "CONTERROR" ;
    ns1:textoExtracto "En la sentencia #HSC se ha programado el parámetro CONTERROR más de una vez."@es .

ns1:Parametro_VariableGestorHerramientas a ns1:Parametro ;
    rdfs:label "Variable del gestor de herramientas"@es ;
    ns1:textoExtracto "Variable del gestor de herramientas sin permiso de escritura"@es .

ns1:Parametro_VariableMaquina a ns1:Parametro ;
    rdfs:label "Variable del parámetro máquina"@es ;
    ns1:textoExtracto "Variable del parámetro máquina sin permiso de escritura"@es .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación"@es ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia."@es .

