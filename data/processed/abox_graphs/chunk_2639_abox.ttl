@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8300 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8300: 'Se precisa al menos un eje para G170, G171 o G157'"@es ;
    ns1:identificador "8300" ;
    ns1:solucionaFallo ns1:Fallo_ProgramacionEjes ;
    ns1:textoExtracto "8300 'Se precisa al menos un eje para G170, G171 o G157' DETECCIÓN Durante la edición. CAUSA No se ha programado ningún eje con la función G170, G171 o G157. SOLUCIÓN Programar el eje o ejes que deben verse afectados por la función G170, G171 o G157."@es .

ns1:Error_8302 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8302: 'La coordenada X mínima debe ser menor que la máxima'"@es ;
    ns1:identificador "8302" ;
    ns1:solucionaFallo ns1:Fallo_ParametrosCoordenadas ;
    ns1:textoExtracto "8302 'La coordenada X mínima debe ser menor que la máxima' DETECCIÓN Durante la"@es .

ns1:Error_SintaxisParametros a ns1:AvisoSeguridad ;
    rdfs:label "Error de sintaxis: Parámetros no programados entre corchetes"@es ;
    ns1:solucionaFallo ns1:Fallo_SintaxisParametros ;
    ns1:textoExtracto "CAUSA La sentencia programada exige que su lista de parámetros se programe entre corchetes. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación"@es ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:Fallo_ParametrosCoordenadas a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de parámetros: Coordenada X mínima mayor o igual que la máxima"@es ;
    ns1:textoExtracto "La coordenada X mínima debe ser menor que la máxima"@es .

ns1:Fallo_ProgramacionEjes a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de programación: Ejes no definidos para funciones G170, G171 o G157"@es ;
    ns1:textoExtracto "No se ha programado ningún eje con la función G170, G171 o G157."@es .

ns1:Fallo_SintaxisParametros a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de sintaxis: Lista de parámetros sin corchetes"@es ;
    ns1:textoExtracto "La sentencia programada exige que su lista de parámetros se programe entre corchetes."@es .

