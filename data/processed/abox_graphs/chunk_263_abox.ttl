@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_ModificacionSoftware a ns1:AccionProhibida ;
    rdfs:label "Modificación no autorizada del software CNC8070"@es ;
    ns1:mitigaRiesgo ns1:AvisoSeguridad_SoftwareCNC ;
    ns1:textoExtracto "No se debe reinstalar ni modificar el software del CNC sin consentimiento expreso de Fagor Automation."@es .

ns1:CNC8070_Software a ns1:Sistema ;
    rdfs:label "Software CNC8070"@es ;
    ns1:documentadoEn ns1:Manual_CNC8070_Configuracion ;
    ns1:identificador "CNC8070" ;
    ns1:textoExtracto "Fagor entrega el CNC con el software correctamente instalado en un disco de tipo compact flash. Tanto en un CNC como en un PC (simulador), los archivos necesarios para el funcionamiento del CNC se encuentran en la carpeta C:\\CNC8070 y sus correspondientes subcarpetas."@es ;
    ns1:tieneComponente ns1:CNC8070_DiscoCompactFlash .

ns1:Carpeta_MTB a ns1:InterfazUsuario ;
    rdfs:label "Carpeta MTB (Personalización del CNC)"@es ;
    ns1:compuestoPor ns1:ParametrosMaquina_CNC8070,
        ns1:Programa_PLC ;
    ns1:identificador "MTB" ;
    ns1:textoExtracto "El fabricante dispone de la carpeta ..\\MTB para que pueda guardar las modificaciones que realiza en el CNC, como por ejemplo, el programa PLC, los parámetros máquina, etc."@es .

ns1:Herramienta_FGUIM a ns1:Herramienta ;
    rdfs:label "FGUIM (Programa de personalización del CNC)"@es ;
    ns1:documentadoEn ns1:Manual_CNC8070 ;
    ns1:identificador "FGUIM" ;
    ns1:textoExtracto "El fabricante también puede personalizar el aspecto del CNC mediante el programa de personalización FGUIM."@es .

ns1:ModosAcceso_CNC8070 a ns1:ModoOperacion ;
    rdfs:label "Modos de acceso del CNC8070"@es ;
    ns1:documentadoEn ns1:Manual_CNC8070_ModosTrabajo ;
    ns1:textoExtracto "El disco está preconfigurado con tres modos de acceso, cada uno de los cuales ofrece un nivel de protección diferente."@es .

ns1:AvisoSeguridad_SoftwareCNC a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia de manipulación del software CNC"@es ;
    ns1:textoExtracto "Fagor Automation no se responsabiliza de lesiones a personas, daños físicos o materiales que pudiera sufrir o provocar el CNC y que hayan sido motivados por una manipulación del software."@es .

ns1:CNC8070_DiscoCompactFlash a ns1:ComponenteElectrico ;
    rdfs:label "Disco compact flash del CNC8070"@es ;
    ns1:identificador "compact flash" ;
    ns1:textoExtracto "Fagor entrega el CNC con el software correctamente instalado en un disco de tipo compact flash."@es .

ns1:Manual_CNC8070_Configuracion a ns1:Manual ;
    rdfs:label "Sección 1.7 Configuración del software"@es ;
    ns1:identificador "1.7" ;
    ns1:textoExtracto "Ver '1.7 Configuración del software.' en la página 45."@es .

ns1:Manual_CNC8070_ModosTrabajo a ns1:Manual ;
    rdfs:label "Sección 1.1.1 Modos de trabajo y protección del software en el CNC"@es ;
    ns1:identificador "1.1.1" ;
    ns1:textoExtracto "Ver '1.1.1 Modos de trabajo y protección del software en el CNC.' en la página 32."@es .

ns1:ParametrosMaquina_CNC8070 a ns1:Parametro ;
    rdfs:label "Parámetros máquina del CNC8070"@es ;
    ns1:textoExtracto "los parámetros máquina"@es .

ns1:Programa_PLC a ns1:Sistema ;
    rdfs:label "Programa PLC (CNC8070)"@es ;
    ns1:textoExtracto "el programa PLC"@es .

