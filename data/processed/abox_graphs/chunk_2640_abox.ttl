@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_8302 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 8302: Coordenada X mínima mayor/igual que máxima" ;
    ns1:identificador "8302" ;
    ns1:monitoreaParametro ns1:Parametro_DGWZ_X ;
    ns1:textoExtracto "'La coordenada X mínima debe ser menor que la máxima' DETECCIÓN Durante la edición. CAUSA En la sentencia #DGWZ, la coordenada X mínima es mayor o igual que la máxima." .

ns1:Fallo_8303 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 8303: Coordenada Y mínima mayor/igual que máxima" ;
    ns1:identificador "8303" ;
    ns1:monitoreaParametro ns1:Parametro_DGWZ_Y ;
    ns1:textoExtracto "'La coordenada Y mínima debe ser menor que la máxima' DETECCIÓN Durante la edición. CAUSA En la sentencia #DGWZ, la coordenada Y mínima es mayor o igual que la máxima." .

ns1:Fallo_8304 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 8304: Coordenada Z mínima mayor/igual que máxima" ;
    ns1:identificador "8304" ;
    ns1:monitoreaParametro ns1:Parametro_DGWZ_Z ;
    ns1:textoExtracto "'La coordenada Z mínima debe ser menor que la máxima' DETECCIÓN Durante la edición. CAUSA En la sentencia #DGWZ, la coordenada Z mínima es mayor o igual que la máxima." .

ns1:Fallo_8306 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 8306: Función G201 sin sentencia #AXIS" ;
    ns1:identificador "8306" ;
    ns1:monitoreaParametro ns1:Parametro_AXIS ;
    ns1:textoExtracto "'G201 precisa la programación de la función especial #AXIS' DETECCIÓN Durante la edición. CAUSA No se ha programado la sentencia #AXIS en el mismo bloque que la función G201." .

ns1:Fallo_8307 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 8307: Tercer eje primario programado incorrectamente" ;
    ns1:identificador "8307" ;
    ns1:monitoreaParametro ns1:Parametro_G20_Eje5 ;
    ns1:textoExtracto "'Programación incorrecta del tercer eje primario' DETECCIÓN Durante la edición. CAUSA En la sentencia G20, el parámetro 5 es igual que el 1 o el 2." .

ns1:Fallo_8308 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 8308: Sintaxis incorrecta en G04" ;
    ns1:identificador "8308" ;
    ns1:monitoreaParametro ns1:Parametro_G04_Tiempo ;
    ns1:textoExtracto "'Se esperaba expresión o K expresión tras G04' DETECCIÓN Durante la edición. CAUSA Función G4 mal programada." .

ns1:Fallo_8309 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 8309: Demasiados ejes programados" ;
    ns1:identificador "8309" ;
    ns1:textoExtracto "'Demasiados ejes programados' DETECCIÓN Durante la edición." .

ns1:Parametro_AXIS a ns1:Parametro ;
    rdfs:label "Parámetro #AXIS (ejes afectados)" ;
    ns1:identificador "#AXIS" ;
    ns1:textoExtracto "sentencia #AXIS en el mismo bloque que la función G201" .

ns1:Parametro_DGWZ_X a ns1:Parametro ;
    rdfs:label "Parámetro DGWZ (coordenada X)" ;
    ns1:identificador "#DGWZ_X" ;
    ns1:textoExtracto "sentencia #DGWZ, la coordenada X mínima es mayor o igual que la máxima" .

ns1:Parametro_DGWZ_Y a ns1:Parametro ;
    rdfs:label "Parámetro DGWZ (coordenada Y)" ;
    ns1:identificador "#DGWZ_Y" ;
    ns1:textoExtracto "sentencia #DGWZ, la coordenada Y mínima es mayor o igual que la máxima" .

ns1:Parametro_DGWZ_Z a ns1:Parametro ;
    rdfs:label "Parámetro DGWZ (coordenada Z)" ;
    ns1:identificador "#DGWZ_Z" ;
    ns1:textoExtracto "sentencia #DGWZ, la coordenada Z mínima es mayor o igual que la máxima" .

ns1:Parametro_G04_Tiempo a ns1:Parametro ;
    rdfs:label "Parámetro G04 (tiempo de espera)" ;
    ns1:identificador "G04_time" ;
    ns1:textoExtracto "La función G4 se puede programar como G4 <time> ó G4K<time>, donde <time> es el tiempo de espera" ;
    ns1:valor "time" .

ns1:Parametro_G20_Eje5 a ns1:Parametro ;
    rdfs:label "Parámetro G20 (tercer eje primario)" ;
    ns1:identificador "G20_5" ;
    ns1:textoExtracto "En la sentencia G20, el parámetro 5 es igual que el 1 o el 2" .

