@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_8309 a ns1:DiagnosticoFallo ;
    rdfs:label "Demasiados ejes programados"@es ;
    ns1:identificador "8309" ;
    ns1:solucionaFallo ns1:Parametro_POLY_EjesMaximos ;
    ns1:textoExtracto "8309 'Demasiados ejes programados' DETECCIÓN Durante la edición. CAUSA Demasiados ejes programados en la sentencia #POLY. SOLUCIÓN El número máximo de ejes que se pueden programar es 3."@es .

ns1:Fallo_8310 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta parámetro obligatorio"@es ;
    ns1:identificador "8310" ;
    ns1:solucionaFallo ns1:Parametro_POLY_CS_ACS_PROBE ;
    ns1:textoExtracto "8310 'Falta parámetro obligatorio' DETECCIÓN Durante la edición. CAUSA Falta algún parámetro obligatorio en la sentencia #POLY, #CS, #ACS o #PROBE SOLUCIÓN Revisar en el manual de programación la sintaxis de las"@es .

ns1:Funcion_G4 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G4 (programación de tiempo de espera)"@es ;
    ns1:textoExtracto "CAUSA Función G4 mal programada. SOLUCIÓN La función G4 se puede programar como G4 <time> ó G4K<time>, donde <time> es el tiempo de espera."@es ;
    ns1:tieneFrecuencia ns1:Parametro_G4_Time .

ns1:Parametro_G4_Time a ns1:Parametro ;
    rdfs:label "Tiempo de espera en función G4"@es ;
    ns1:textoExtracto "La función G4 se puede programar como G4 <time> ó G4K<time>, donde <time> es el tiempo de espera."@es .

ns1:Parametro_POLY_CS_ACS_PROBE a ns1:Parametro ;
    rdfs:label "Parámetros obligatorios en sentencias #POLY, #CS, #ACS, #PROBE"@es ;
    ns1:textoExtracto "Falta algún parámetro obligatorio en la sentencia #POLY, #CS, #ACS o #PROBE"@es .

ns1:Parametro_POLY_EjesMaximos a ns1:Parametro ;
    rdfs:label "Número máximo de ejes en sentencia #POLY"@es ;
    ns1:textoExtracto "El número máximo de ejes que se pueden programar es 3."@es ;
    ns1:valor "3" .

