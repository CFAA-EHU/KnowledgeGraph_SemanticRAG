@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8310 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8310: Parámetro obligatorio faltante" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8310" ;
    ns1:solucionaFallo ns1:Parametro_ACS,
        ns1:Parametro_CS,
        ns1:Parametro_POLY,
        ns1:Parametro_PROBE ;
    ns1:textoExtracto "'parámetro obligatorio' DETECCIÓN Durante la edición. CAUSA Falta algún parámetro obligatorio en la sentencia #POLY, #CS, #ACS o #PROBE SOLUCIÓN Revisar en el manual de programación la sintaxis de las sentencias." .

ns1:Error_8311 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8311: Valor de parámetro no válido" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8311" ;
    ns1:solucionaFallo ns1:Parametro_ACS,
        ns1:Parametro_CS,
        ns1:Parametro_HSC,
        ns1:Parametro_POLY ;
    ns1:textoExtracto "'Valor de parámetro no válido' DETECCIÓN Durante la edición. CAUSA Valor no válido en algún argumento de la sentencia #CS, #ACS, #HSC o #POLY. Valor no válido para el índice de un parámetro aritmético. SOLUCIÓN Revisar en el manual de programación la sintaxis de las sentencias. El índice de un parámetro aritmético debe ser siempre positivo o nulo." .

ns1:Error_8312 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8312: #CS/#ACS modo no válido" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8312" ;
    ns1:solucionaFallo ns1:ModoOperacion_CS_ACS ;
    ns1:textoExtracto "'#CS/#ACS: modo no válido' DETECCIÓN Durante la edición. CAUSA Valor no válido para el comando MODE de la sentencia #CS o #ACS. SOLUCIÓN Revisar en el manual de programación la sintaxis de las sentencias." .

ns1:ModoOperacion_CS_ACS a ns1:ModoOperacion ;
    rdfs:label "Modo de operación #CS/#ACS" ;
    ns1:identificador "MODE" ;
    ns1:textoExtracto "Valor no válido para el comando MODE de la sentencia #CS o #ACS" .

ns1:Parametro_HSC a ns1:Parametro ;
    rdfs:label "Parámetro #HSC" ;
    ns1:identificador "#HSC" ;
    ns1:textoExtracto "Valor no válido en algún argumento de la sentencia #HSC" .

ns1:Parametro_PROBE a ns1:Parametro ;
    rdfs:label "Parámetro #PROBE" ;
    ns1:identificador "#PROBE" ;
    ns1:textoExtracto "parámetro obligatorio en la sentencia #PROBE" .

ns1:Parametro_ACS a ns1:Parametro ;
    rdfs:label "Parámetro #ACS" ;
    ns1:identificador "#ACS" ;
    ns1:textoExtracto "parámetro obligatorio en la sentencia #ACS" .

ns1:Parametro_CS a ns1:Parametro ;
    rdfs:label "Parámetro #CS" ;
    ns1:identificador "#CS" ;
    ns1:textoExtracto "parámetro obligatorio en la sentencia #CS" .

ns1:Parametro_POLY a ns1:Parametro ;
    rdfs:label "Parámetro #POLY" ;
    ns1:identificador "#POLY" ;
    ns1:textoExtracto "parámetro obligatorio en la sentencia #POLY" .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación" ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de las sentencias." .

