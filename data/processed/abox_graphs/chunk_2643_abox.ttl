@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8313 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8313: '#CS/#ACS: número de sistema de coordenadas no válida'"@es ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8313" ;
    ns1:solucionaFallo ns1:SistemaCoordenadas ;
    ns1:textoExtracto "8313 '#CS/#ACS: número de sistema de coordenadas no válida' [...] CAUSA Valor no válido para el número de sistema en la sentencia #CS o #ACS. SOLUCIÓN El número de sistema debe tener un valor entre 1 y 5, ambos inclusive."@es .

ns1:Error_8314 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8314: 'Programación incorrecta G30/G73'"@es ;
    ns1:identificador "8314" ;
    ns1:solucionaFallo ns1:Parametro_I,
        ns1:Parametro_J ;
    ns1:textoExtracto "8314 'Programación incorrecta G30/G73' [...] CAUSA En la función G30/G73 se ha programado sólo uno de los parámetros I, J. SOLUCIÓN Programar ambos parámetros I, J o no programar ninguno."@es .

ns1:Error_8315 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8315: 'Número de ciclo de palpador no válido'"@es ;
    ns1:identificador "8315" ;
    ns1:solucionaFallo ns1:CicloPalpador ;
    ns1:textoExtracto "8315 'Número de ciclo de palpador no válido' [...] CAUSA El número de ciclo de palpador no es válido. SOLUCIÓN Consultar en la documentación los ciclos de palpador válidos."@es .

ns1:Error_8316 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8316: 'Parámetro no permitido'"@es ;
    ns1:identificador "8316" ;
    ns1:textoExtracto "8316 'Parámetro no permitido' [...] DETECCIÓN Durante la edición y ejecución en MDI."@es .

ns1:CicloPalpador a ns1:Parametro ;
    rdfs:label "Número de ciclo de palpador"@es ;
    ns1:textoExtracto "Número de ciclo de palpador no válido. [...] Consultar en la documentación los ciclos de palpador válidos."@es .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación"@es ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de las sentencias."@es .

ns1:Parametro_I a ns1:Parametro ;
    rdfs:label "Parámetro I (función G30/G73)"@es ;
    ns1:textoExtracto "En la función G30/G73 se ha programado sólo uno de los parámetros I, J."@es .

ns1:Parametro_J a ns1:Parametro ;
    rdfs:label "Parámetro J (función G30/G73)"@es ;
    ns1:textoExtracto "En la función G30/G73 se ha programado sólo uno de los parámetros I, J."@es .

ns1:SistemaCoordenadas a ns1:Parametro ;
    rdfs:label "Número de sistema de coordenadas (#CS/#ACS)"@es ;
    ns1:textoExtracto "Valor no válido para el número de sistema en la sentencia #CS o #ACS. [...] debe tener un valor entre 1 y 5, ambos inclusive."@es ;
    ns1:valor "1-5" .

