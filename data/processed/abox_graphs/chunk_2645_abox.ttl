@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:HerramientaEdicion a ns1:Herramienta ;
    rdfs:label "Herramienta de edición"@es ;
    ns1:activaAlarma ns1:Error_8318,
        ns1:Error_8319,
        ns1:Error_8320,
        ns1:Error_8321,
        ns1:Error_8322,
        ns1:Error_8323,
        ns1:Error_8324,
        ns1:Error_8325,
        ns1:Error_8326 ;
    ns1:textoExtracto "El corrector de herramienta debe ser positivo."@es .

ns1:Error_8318 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8318: 'Sólo se permite un eje activo 1 por bloque'"@es ;
    ns1:identificador "8318" ;
    ns1:textoExtracto "'Sólo se permite un eje activo 1 por bloque' DETECCIÓN Durante la edición. CAUSA El eje @1 está programado más de una vez en el bloque. SOLUCIÓN Programar el eje @1 una única vez en el bloque."@es .

