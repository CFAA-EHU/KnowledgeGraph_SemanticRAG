ns1:Error_8323 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8323: 'Se espera comparación'"@es ;
    ns1:identificador "8323" ;
    ns1:textoExtracto "'Se espera comparación' DETECCIÓN Durante la edición. CAUSA Se ha programado \"=\" en vez de \"==\". SOLUCIÓN Programar \"==\" en lugar de \"=.\""@es .

ns1:Error_8324 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8324: 'No se espera tabulado'"@es ;
    ns1:identificador "8324" ;
    ns1:textoExtracto "'No se espera tabulado' DETECCIÓN Durante la edición. CAUSA Hay un tabulador incorrecto. SOLUCIÓN Eliminar el tabulador."@es .

