@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8326 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8326: 'No se esperaba espacio'"@es ;
    ns1:identificador "8326" ;
    ns1:textoExtracto "'No se esperaba espacio' DETECCIÓN Durante la edición. CAUSA Hay un espacio en blanco incorrecto. SOLUCIÓN Eliminar el espacio en blanco."@es .

ns1:Error_8327 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8327: 'Falta algún paréntesis'"@es ;
    ns1:identificador "8327" ;
    ns1:textoExtracto "'Falta algún paréntesis' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA El número de paréntesis de apertura no coincide con el número de paréntesis de cierre. SOLUCIÓN Comprobar que cada paréntesis de apertura tiene su correspondiente paréntesis de cierre."@es .

ns1:Sentencia_SET_AX a ns1:Parametro ;
    rdfs:label "#SET AX"@es ;
    ns1:monitoreaParametro ns1:Error_8328 ;
    ns1:textoExtracto "En la sentencia #SET AX se ha programado un valor"@es .

ns1:Error_8328 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8328: '#SET AX: sólo se permite posición cero'"@es ;
    ns1:identificador "8328" ;
    ns1:textoExtracto "'#SET AX: sólo se permite posición cero' DETECCIÓN Durante la edición. CAUSA En la sentencia #SET AX se ha programado un valor"@es .

