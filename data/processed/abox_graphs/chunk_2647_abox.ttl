@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8328 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8328: '#SET AX: sólo se permite posición cero'"@es ;
    ns1:identificador "8328" ;
    ns1:textoExtracto "8328 '#SET AX: sólo se permite posición cero' DETECCIÓN Durante la edición. CAUSA En la sentencia #SET AX se ha programado un valor entero distinto de cero. SOLUCIÓN La sentencia #SET AX sólo permite programar el valor cero para indicar que la posición no está ocupada por ningún eje."@es .

ns1:Error_8329 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8329: 'Se esperaba V'"@es ;
    ns1:identificador "8329" ;
    ns1:textoExtracto "8329 'Se esperaba V' DETECCIÓN Durante la edición. CAUSA Se ha programado un nombre de variable que no comienza con el prefijo \"V.\". SOLUCIÓN Todo nombre de variable tanto en el programa pieza como por MDI debe comenzar con el prefijo \"V.\"."@es .

ns1:Error_8330 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8330: 'Se esperaba nombre o número de eje'"@es ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8330" ;
    ns1:textoExtracto "8330 'Se esperaba nombre o número de eje' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA La sentencia o variable programada exige un nombre o número de eje. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia o variable."@es .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación"@es ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia o variable."@es .

