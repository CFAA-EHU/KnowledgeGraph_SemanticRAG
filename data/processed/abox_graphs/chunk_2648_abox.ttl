@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8331 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8331: 'No se esperaba nombre o número de eje'"@es ;
    ns1:identificador "8331" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "8331 'No se esperaba nombre o número de eje' DETECCIÓN Durante la edición y ejecución en MDI. CAUSA La sentencia o variable programada no acepta un nombre o número de eje."@es .

ns1:Error_8332 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8332: '#WARNING/#ERROR[\"Texto <%d>\"<,valor>]/[nºentero]'"@es ;
    ns1:identificador "8332" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "8332 '#WARNING/#ERROR[\"Texto <%d>\"<,valor>]/[nºentero]' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta."@es .

ns1:Error_8333 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8333: '#MSG[\"Texto <%d>\"<,valor>]'"@es ;
    ns1:identificador "8333" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "8333 '#MSG[\"Texto <%d>\"<,valor>]' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta."@es .

ns1:Error_8334 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8334: '#FREE AX[eje, ...]'"@es ;
    ns1:identificador "8334" ;
    ns1:textoExtracto "8334 '#FREE AX[eje, ...]' DETECCIÓN Durante la edición y ejecución."@es .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación"@es ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia o variable."@es .

