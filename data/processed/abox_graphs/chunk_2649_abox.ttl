@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación"@es ;
    ns1:documentadoEn ns1:Error_8334,
        ns1:Error_8335,
        ns1:Error_8336 ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:Error_8334 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en '#FREE AX[eje, ...]'"@es ;
    ns1:identificador "8334" ;
    ns1:solucionaFallo ns1:UsoIncorrectoDeSintaxisEnFREEAXEje ;
    ns1:textoExtracto "'#FREE AX[eje, ...]' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:Error_8335 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en '#WAIT FOR[expresión]'"@es ;
    ns1:identificador "8335" ;
    ns1:solucionaFallo ns1:UsoIncorrectoDeSintaxisEnWAITFORExpresion ;
    ns1:textoExtracto "'#WAIT FOR[expresión]' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:Error_8336 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en '#TANGFEED RMIN[radio]'"@es ;
    ns1:identificador "8336" ;
    ns1:solucionaFallo ns1:UsoIncorrectoDeSintaxisEnTANGFEEDRMINRadio ;
    ns1:textoExtracto "'#TANGFEED RMIN[radio]' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de"@es .

ns1:UsoIncorrectoDeSintaxisEnFREEAXEje a ns1:AccionProhibida ;
    rdfs:label "Uso incorrecto de sintaxis en '#FREE AX[eje, ...]'"@es ;
    ns1:textoExtracto "La sintaxis de la sentencia no es correcta."@es .

ns1:UsoIncorrectoDeSintaxisEnTANGFEEDRMINRadio a ns1:AccionProhibida ;
    rdfs:label "Uso incorrecto de sintaxis en '#TANGFEED RMIN[radio]'"@es ;
    ns1:textoExtracto "La sintaxis de la sentencia no es correcta."@es .

ns1:UsoIncorrectoDeSintaxisEnWAITFORExpresion a ns1:AccionProhibida ;
    rdfs:label "Uso incorrecto de sintaxis en '#WAIT FOR[expresión]'"@es ;
    ns1:textoExtracto "La sintaxis de la sentencia no es correcta."@es .

