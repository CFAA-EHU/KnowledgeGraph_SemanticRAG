@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaValidacionCNC8070 a ns1:Sistema ;
    rdfs:label "Sistema de validación por código CNC8070"@es ;
    ns1:controla ns1:CarpetaMTB ;
    ns1:identificador "CNC8070" ;
    ns1:monitoreaParametro ns1:CodigoValidacion ;
    ns1:textoExtracto "el sistema moverá la carpeta correspondiente desde ..\\CONFIGURATION a CNC8070 y la renombrará como MTB. [...] el CNC moverá la carpeta correspondiente desde ..\\CONFIGURATION a CNC8070 y la renombrará como MTB."@es .

ns1:CarpetaMTB a ns1:Componente ;
    rdfs:label "Carpeta MTB (configuración activa)"@es ;
    ns1:compuestoPor ns1:CarpetaMTB_M,
        ns1:CarpetaMTB_T ;
    ns1:identificador "MTB" ;
    ns1:textoExtracto "la carpeta correspondiente [...] y la renombrará como MTB. [...] la carpeta MTB a la carpeta ..\\CONFIGURATION y le dará su antiguo nombre (MTB_M, MTB_T, etc)"@es .

ns1:CarpetaMTB_M a ns1:Componente ;
    rdfs:label "Carpeta MTB_M (backup de configuración)"@es ;
    ns1:identificador "MTB_M" ;
    ns1:textoExtracto "le dará su antiguo nombre (MTB_M, MTB_T, etc)"@es .

ns1:CarpetaMTB_T a ns1:Componente ;
    rdfs:label "Carpeta MTB_T (backup de configuración)"@es ;
    ns1:identificador "MTB_T" ;
    ns1:textoExtracto "le dará su antiguo nombre (MTB_M, MTB_T, etc)"@es .

ns1:CodigoValidacion a ns1:Parametro ;
    rdfs:label "Código de validación CNC8070"@es ;
    ns1:textoExtracto "código de validación. [...] Si cambiamos el código de validación, el sistema devolverá la carpeta MTB a la carpeta ..\\CONFIGURATION"@es .

