@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_8336 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en '#TANGFEED RMIN[radio]'"@es ;
    ns1:identificador "8336" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto """
    DETECCIÓN Durante la edición y ejecución.
    CAUSA La sintaxis de la sentencia no es correcta.
    SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia.
    """@es .

