@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_8343 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #INCJOG"@es ;
    ns1:identificador "8343" ;
    ns1:solucionaFallo ns1:UsoIncorrectoDeSintaxisINCJOG ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8343 '#INCJOG[[valorIncremento, valorAvance],..., [...]] nombreEje' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta."@es .

ns1:DiagnosticoFallo_8344 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #SET OFFSET"@es ;
    ns1:identificador "8344" ;
    ns1:solucionaFallo ns1:UsoIncorrectoDeSintaxisSETOFFSET ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8344 '#SET OFFSET[inferior, superior]eje' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta."@es .

ns1:DiagnosticoFallo_8345 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #LINK"@es ;
    ns1:identificador "8345" ;
    ns1:solucionaFallo ns1:UsoIncorrectoDeSintaxisLINK ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8345 '#LINK[maestro, esclavo <,error>]...[...]' DETECCIÓN Durante"@es .

ns1:Manual_Programacion a ns1:Manual ;
    rdfs:label "Manual de programación"@es ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:UsoIncorrectoDeSintaxisINCJOG a ns1:AccionProhibida ;
    rdfs:label "Uso incorrecto de sintaxis #INCJOG"@es ;
    ns1:textoExtracto "La sintaxis de la sentencia '#INCJOG[[valorIncremento, valorAvance],..., [...]] nombreEje' no es correcta."@es .

ns1:UsoIncorrectoDeSintaxisLINK a ns1:AccionProhibida ;
    rdfs:label "Uso incorrecto de sintaxis #LINK"@es ;
    ns1:textoExtracto "La sintaxis de la sentencia '#LINK[maestro, esclavo <,error>]...[...]' no es correcta."@es .

ns1:UsoIncorrectoDeSintaxisSETOFFSET a ns1:AccionProhibida ;
    rdfs:label "Uso incorrecto de sintaxis #SET OFFSET"@es ;
    ns1:textoExtracto "La sintaxis de la sentencia '#SET OFFSET[inferior, superior]eje' no es correcta."@es .

