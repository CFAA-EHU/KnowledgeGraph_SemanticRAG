ns1:ErrorSintaxis_8345 a ns1:DiagnosticoFallo ;
    rdfs:label "'#LINK[maestro, esclavo <,error>]...[...]'" ;
    ns1:identificador "8345" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

