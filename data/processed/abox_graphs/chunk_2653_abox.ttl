@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error8351 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #KIN ID"@es ;
    ns1:identificador "8351" ;
    ns1:textoExtracto "'#KIN ID <[cinemática]>: error de sintaxis' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:Error8352 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #CS/ACS DEF"@es ;
    ns1:identificador "8352" ;
    ns1:textoExtracto "'#CS/ACS DEF <[n]> [MODE m, V1, V2, V3, j1, j2, j3, 0/1]: error de sintaxis' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:Error8353 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #CS/ACS ON/NEW"@es ;
    ns1:identificador "8353" ;
    ns1:textoExtracto "'#CS/ACS ON/NEW <[n]> <[MODE m, V1, V2, V3, j1, j2, j3, 0/1]>: error de sintaxis' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta."@es .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación"@es ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia."@es .

