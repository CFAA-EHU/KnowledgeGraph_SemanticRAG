@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorSintaxis_8353 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #CS/ACS ON/NEW"@es ;
    ns1:identificador "8353" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "'#CS/ACS ON/NEW <[n]> <[MODE m, V1, V2, V3, j1, j2, j3, 0/1]>: error de sintaxis' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

