ns1:ErrorSintaxis_8360 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #DGWZ"@es ;
    ns1:identificador "8360" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
