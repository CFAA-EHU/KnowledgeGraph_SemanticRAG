@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error8360_DGWZ a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8360: Sintaxis incorrecta en '#DGWZ[Eje1min, Eje1max, Eje2min, Eje2max, Eje3min, Eje3max]'" ;
    ns1:identificador "8360" ;
    ns1:textoExtracto "'#DGWZ[Eje1min, Eje1max, Eje2min, Eje2max <, Eje3min, Eje3max>]' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Error8361_CD_ON a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8361: Sintaxis incorrecta en '#CD ON <[horizonte]>'" ;
    ns1:identificador "8361" ;
    ns1:textoExtracto "'#CD ON <[horizonte]>' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Error8362_PATH a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8362: Sintaxis incorrecta en '#PATH[\"path\"]'" ;
    ns1:identificador "8362" ;
    ns1:textoExtracto "'#PATH[\"path\"]' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la" .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación" ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

