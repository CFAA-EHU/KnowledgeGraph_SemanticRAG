@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_8369 a ns1:AvisoSeguridad ;
    rdfs:label "#EXEC[\"path\" <,canal>]" ;
    ns1:documentadoEn ns1:Manual_Programacion ;
    ns1:identificador "8369" ;
    ns1:textoExtracto "8369 #EXEC[\"path\" <,canal>] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:AvisoSeguridad_8370 a ns1:AvisoSeguridad ;
