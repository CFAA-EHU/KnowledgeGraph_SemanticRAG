@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorSintaxis_8371 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en #SIGNAL[marca, ...]" ;
    ns1:identificador "8371" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "8371 #SIGNAL[marca, ...] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

