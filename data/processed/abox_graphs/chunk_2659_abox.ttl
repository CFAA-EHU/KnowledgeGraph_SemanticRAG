@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorSintaxis_8379 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en '#RTCP ON/OFF'"@es ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8379" ;
    ns1:textoExtracto "'#RTCP ON/OFF: error de sintaxis'"@es .

ns1:ErrorSintaxis_8380 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en '#TLC OFF'"@es ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8380" ;
    ns1:textoExtracto "'#TLC OFF: error de sintaxis'"@es .

ns1:ErrorSintaxis_8381 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en '#TOOL ORI'"@es ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8381" ;
    ns1:textoExtracto "'#TOOL ORI: error de sintaxis'"@es .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación"@es ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia."@es .

