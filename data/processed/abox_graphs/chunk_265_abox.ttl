@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoAcceso_Avanzado a ns1:ModoOperacion ;
    rdfs:label "Modo de acceso avanzado (preconfigurado)" ;
    ns1:habilitadoPor ns1:DiscoCompactFlash_CNC ;
    ns1:textoExtracto "El disco está preconfigurado con tres modos de acceso, cada uno de los cuales ofrece un nivel de protección diferente." .

ns1:ModoAcceso_Basico a ns1:ModoOperacion ;
    rdfs:label "Modo de acceso básico (preconfigurado)" ;
    ns1:habilitadoPor ns1:DiscoCompactFlash_CNC ;
    ns1:textoExtracto "El disco está preconfigurado con tres modos de acceso, cada uno de los cuales ofrece un nivel de protección diferente." .

ns1:ModoAcceso_Intermedio a ns1:ModoOperacion ;
    rdfs:label "Modo de acceso intermedio (preconfigurado)" ;
    ns1:habilitadoPor ns1:DiscoCompactFlash_CNC ;
    ns1:textoExtracto "El disco está preconfigurado con tres modos de acceso, cada uno de los cuales ofrece un nivel de protección diferente." .

ns1:SistemaOperativo_CNC a ns1:Sistema ;
    rdfs:label "Sistema operativo del CNC" ;
    ns1:textoExtracto "El equipo muestra el modo de trabajo activo mediante un icono en la barra de tareas del sistema operativo, junto al reloj." ;
    ns1:tieneComponente ns1:InterfazUsuario_CNC .

ns1:InterfazUsuario_CNC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de usuario del CNC" ;
    ns1:ilustradoEn ns1:DiscoCompactFlash_CNC ;
    ns1:textoExtracto "El equipo muestra el modo de trabajo activo mediante un icono en la barra de tareas del sistema operativo, junto al reloj. Cuando el CNC está arrancado, la barra de estado muestra el modo de trabajo activo mediante iconos." .

ns1:DiscoCompactFlash_CNC a ns1:ComponenteElectrico ;
    rdfs:label "Disco compact flash del CNC" ;
    ns1:textoExtracto "Fagor entrega el equipo con un disco del tipo compact flash protegido frente a escritura, excepto aquellas carpetas o archivos que deben estar desprotegidos para el funcionamiento habitual del CNC." .

