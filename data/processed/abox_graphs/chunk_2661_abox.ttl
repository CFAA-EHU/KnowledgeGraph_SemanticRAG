@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_8388 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia '#ESTOP/DSTOP'"@es ;
    ns1:identificador "8388" ;
    ns1:solucionaFallo ns1:Accion_RevisarSintaxis_8388 ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8388 '#ESTOP/DSTOP' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta."@es .

