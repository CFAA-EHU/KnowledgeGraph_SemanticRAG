ns1:Accion_RevisarSintaxis_8388 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar sintaxis de sentencia '#ESTOP/DSTOP' en manual de programación"@es ;
    ns1:requiereConsumible ns1:Manual_Programacion ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia."@es .

