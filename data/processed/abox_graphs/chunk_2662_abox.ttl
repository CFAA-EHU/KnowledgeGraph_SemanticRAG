ns1:ErrorSintaxis_8390 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis '#RET'"@es ;
    ns1:identificador "8390" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

