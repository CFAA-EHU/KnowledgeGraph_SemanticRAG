@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8397 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en '#MASTER nombre_cabezal'"@es ;
    ns1:identificador "8397" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "#MASTER nombre_cabezal' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:Error_8398 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en '#FREE SP/#CALL SP/#SET SP[nombre_cabezal, ...]'"@es ;
    ns1:identificador "8398" ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "#FREE SP/#CALL SP/#SET SP[nombre_cabezal, ...]' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:Error_8399 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en '#RENAME SP[nombre_cabezal_anterior, nombre_cabezal_nuevo][...][...]'"@es ;
    ns1:identificador "8399" ;
    ns1:textoExtracto "#RENAME SP[nombre_cabezal_anterior, nombre_cabezal_nuevo][...][...]' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta."@es .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación"@es ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia."@es .

