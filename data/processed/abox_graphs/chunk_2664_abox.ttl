@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_8399 a ns1:DiagnosticoFallo ;
    rdfs:label "Error sintaxis #RENAME SP" ;
    ns1:documentadoEn ns1:ManualProgramacion_8000_8999 ;
    ns1:identificador "8399" ;
    ns1:textoExtracto "'#RENAME SP[nombre_cabezal_anterior, nombre_cabezal_nuevo][...][...]' DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

