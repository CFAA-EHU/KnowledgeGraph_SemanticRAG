ns1:DiagnosticoFallo_8402 a ns1:DiagnosticoFallo ;
    rdfs:label "Número de almacén de herramientas no válido" ;
    ns1:documentadoEn ns1:ManualProgramacion_8000_8999 ;
    ns1:identificador "8402" ;
    ns1:textoExtracto "'Número de almacén de herramientas no válido' DETECCIÓN Durante la edición. CAUSA El número de almacén definido en la variable no es válido. SOLUCIÓN El número de almacén debe ser un valor entre 1 y 4. Si no se indica el número de almacén se supone el primero." ;
    ns1:valor "1-4" .

ns1:DiagnosticoFallo_8403 a ns1:DiagnosticoFallo ;
    rdfs:label "Error sintaxis #MOVE ABS" ;
