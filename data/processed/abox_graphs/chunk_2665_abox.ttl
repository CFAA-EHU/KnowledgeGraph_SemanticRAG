@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_8405 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #MOVE INF"@es ;
    ns1:identificador "8405" ;
    ns1:solucionaFallo ns1:ManualDeProgramacion ;
    ns1:textoExtracto "#MOVE INF[eje+/- <,avance> <,PRESENT/NEXT/NULL/WAITINPOS>] [...] DETECCIÓN Durante la edición y ejecución en MDI. CAUSA La sintaxis de la sentencia no es correcta."@es .

ns1:Fallo_8406 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #<T>CAM ON"@es ;
    ns1:identificador "8406" ;
    ns1:solucionaFallo ns1:Fallo_8405_solucionaFallo ;
    ns1:textoExtracto "#<T>CAM ON[l, maestro, esclavo, n, m, o, p <,ONCE/CONT>] [...] DETECCIÓN Durante la edición y ejecución en MDI. CAUSA La sintaxis de la sentencia no es correcta."@es .

ns1:Fallo_8407 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #<T>CAM OFF"@es ;
    ns1:identificador "8407" ;
    ns1:solucionaFallo ns1:Fallo_8405_solucionaFallo ;
    ns1:textoExtracto "#<T>CAM OFF[esclavo] [...] DETECCIÓN Durante la edición y ejecución en MDI. CAUSA La sintaxis de la sentencia no es correcta."@es .

ns1:ModoOperacion_MDI a ns1:ModoOperacion ;
    rdfs:label "Modo MDI (Manual Data Input)"@es ;
    ns1:textoExtracto "Durante la edición y ejecución en MDI."@es .

ns1:ManualDeProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación"@es ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia."@es .

