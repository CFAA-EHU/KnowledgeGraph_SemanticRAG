@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_8414 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #UNSYNC"@es ;
    ns1:identificador "8414" ;
    ns1:solucionaFallo ns1:ProgramacionIncorrectaDeSintaxisUNSYNC ;
    ns1:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. '#UNSYNC[cabezal_esclavo <, cabezal_esclavo...]'"@es .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación"@es ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:Parametro_D a ns1:Parametro ;
    rdfs:label "Parámetro D (denominador)"@es ;
    ns1:documentadoEn ns1:DiagnosticoFallo_8415 ;
    ns1:textoExtracto "parámetros D o N"@es .

ns1:Parametro_N a ns1:Parametro ;
    rdfs:label "Parámetro N (numerador)"@es ;
    ns1:documentadoEn ns1:DiagnosticoFallo_8415 ;
    ns1:textoExtracto "parámetros D o N"@es .

ns1:ProgramacionIncorrectaDeSintaxisUNSYNC a ns1:AccionProhibida ;
    rdfs:label "Programación incorrecta de sintaxis #UNSYNC"@es ;
    ns1:textoExtracto "La sintaxis de la sentencia no es correcta."@es .

ns1:ProgramacionParcialDeParametrosDN a ns1:AccionProhibida ;
    rdfs:label "Programación parcial de parámetros D/N"@es ;
    ns1:textoExtracto "falta programar uno de los parámetros D o N."@es .

ns1:DiagnosticoFallo_8415 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta parámetro D o N en sentencias #FOLLOW ON/#SYNC"@es ;
    ns1:identificador "8415" ;
    ns1:solucionaFallo ns1:ProgramacionParcialDeParametrosDN ;
    ns1:textoExtracto "DETECCIÓN Durante la edición. CAUSA En las sentencias #FOLLOW ON y #SYNC falta programar uno de los parámetros D o N. SOLUCIÓN Programar ambos parámetros D y N o ninguno; no se puede"@es .

