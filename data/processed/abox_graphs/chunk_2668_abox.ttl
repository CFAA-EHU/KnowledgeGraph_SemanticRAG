@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_8416 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de programación en parámetros D/N (#FOLLOW ON, #SYNC)" ;
    ns1:identificador "8416" ;
    ns1:solucionaFallo ns1:Parametro_D,
        ns1:Parametro_N ;
    ns1:textoExtracto "'ambos o ninguno' DETECCIÓN Durante la edición. CAUSA En las sentencias #FOLLOW ON y #SYNC falta programar uno de los parámetros D o N. SOLUCIÓN Programar ambos parámetros D y N o ninguno; no se puede programar sólo uno de ellos." .

ns1:Fallo_8417 a ns1:DiagnosticoFallo ;
    rdfs:label "Orden incorrecto de parámetros D/N (#FOLLOW ON, #SYNC)" ;
    ns1:identificador "8417" ;
    ns1:solucionaFallo ns1:Parametro_D,
        ns1:Parametro_N ;
    ns1:textoExtracto "'Programar el numerador antes que el denominador' DETECCIÓN Durante la edición. CAUSA En las sentencias #FOLLOW ON y #SYNC, el parámetro D está programado antes que el parámetro N. SOLUCIÓN Programar el parámetro N antes que el parámetro D." .

ns1:Fallo_8418 a ns1:DiagnosticoFallo ;
    rdfs:label "Sintaxis incorrecta en #ANGAX OFF/SUSP" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8418" ;
    ns1:textoExtracto "'#ANGAX OFF/SUSP <[expresión1, expresión2, expresión3, ...]>' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Fallo_8419 a ns1:DiagnosticoFallo ;
    rdfs:label "Sintaxis incorrecta en #ANGAX ON" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8419" ;
    ns1:textoExtracto "'#ANGAX ON [expresión1, expresión2, expresión3, ...]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Fallo_8420 a ns1:DiagnosticoFallo ;
    rdfs:label "Sintaxis incorrecta en #SERVO ON/OFF" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8420" ;
    ns1:solucionaFallo ns1:Componente_Cabezal ;
    ns1:textoExtracto "'#SERVO ON/OFF [eje/cabezal]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Fallo_8421 a ns1:DiagnosticoFallo ;
    rdfs:label "Sintaxis incorrecta en #MDOFF" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8421" ;
    ns1:textoExtracto "'#MDOFF' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Fallo_8422 a ns1:DiagnosticoFallo ;
    rdfs:label "Sintaxis incorrecta en #CD OFF" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8422" ;
    ns1:textoExtracto "'#CD OFF' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Fallo_8423 a ns1:DiagnosticoFallo ;
    rdfs:label "Sintaxis incorrecta en #OSC" ;
    ns1:documentadoEn ns1:ManualProgramacion ;
    ns1:identificador "8423" ;
    ns1:textoExtracto "'#OSC eje1 eje2 ...' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "eje/cabezal en sentencia #SERVO ON/OFF" .

ns1:Parametro_D a ns1:Parametro ;
    rdfs:label "Parámetro D (numerador)" ;
    ns1:textoExtracto "parámetro D en sentencias #FOLLOW ON y #SYNC" .

ns1:Parametro_N a ns1:Parametro ;
    rdfs:label "Parámetro N (denominador)" ;
    ns1:textoExtracto "parámetro N en sentencias #FOLLOW ON y #SYNC" .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación" ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia" .

