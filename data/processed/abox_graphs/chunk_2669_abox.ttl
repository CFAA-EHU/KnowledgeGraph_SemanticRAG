@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_8423 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia '#OSC eje1 eje2 ...'"@es ;
    ns1:identificador "8423" ;
    ns1:solucionaFallo ns1:Manual_Programacion ;
    ns1:textoExtracto "#OSC eje1 eje2 ...' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:DiagnosticoFallo_8424 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia '#CLEAR<[marca, ...]>'"@es ;
    ns1:identificador "8424" ;
    ns1:solucionaFallo ns1:Manual_Programacion ;
    ns1:textoExtracto "#CLEAR<[marca, ...]>' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:DiagnosticoFallo_8425 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia '#HSC OFF'"@es ;
    ns1:identificador "8425" ;
    ns1:solucionaFallo ns1:Manual_Programacion ;
    ns1:textoExtracto "#HSC OFF' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:Manual_Programacion a ns1:Manual ;
    rdfs:label "Manual de programación"@es ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia."@es .

