@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_ModosTrabajoCNC a ns1:Tabla ;
    rdfs:label "Tabla de modos de trabajo en CNC"@es ;
    ns1:detalladoEnEsquema ns1:InterfazUsuario_CNC ;
    ns1:textoExtracto """
| Icono. | Modo de trabajo. |
| --- | --- |
|  | Modo administrador (Administrator Mode). |
|  | Modo setup (Setup Mode). |
|  | Modo usuario (User Mode)."""@es .

ns1:InterfazUsuario_CNC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de usuario del CNC"@es ;
    ns1:textoExtracto "Modos de trabajo y protección del software en el CNC"@es ;
    ns1:tieneComponente ns1:ModoAdministrador,
        ns1:ModoSetup,
        ns1:ModoUsuario .

ns1:ModoAdministrador a ns1:ModoOperacion ;
    rdfs:label "Modo administrador (Administrator Mode)"@es ;
    ns1:textoExtracto "Modo administrador (Administrator Mode)."@es .

ns1:ModoSetup a ns1:ModoOperacion ;
    rdfs:label "Modo setup (Setup Mode)"@es ;
    ns1:textoExtracto "Modo setup (Setup Mode)."@es .

ns1:ModoUsuario a ns1:ModoOperacion ;
    rdfs:label "Modo usuario (User Mode)"@es ;
    ns1:textoExtracto "Modo usuario (User Mode)."@es .

