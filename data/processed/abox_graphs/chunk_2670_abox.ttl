@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error8425 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8425: Sintaxis incorrecta en '#HSC OFF'"@es ;
    ns1:identificador "8425" ;
    ns1:textoExtracto "8425 '#HSC OFF' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:Error8426 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8426: Sintaxis incorrecta en definición de macros"@es ;
    ns1:identificador "8426" ;
    ns1:textoExtracto "8426 '#DEF \"macro1\" = \"text1\" \"macro2\" = \"text2\" ...' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:Error8427 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8427: Parámetro FIRST/SECOND no permitido en MODE actual"@es ;
    ns1:identificador "8427" ;
    ns1:textoExtracto "8427 'Parámetro FIRST/SECOND no permitido en este MODE' DETECCIÓN Durante la edición. CAUSA En las sentencias #CS y #ACS, los comandos FIRST y SECOND sólo se pueden programar en el MODE 6. SOLUCIÓN Revisar en el manual de programación la sintaxis de las sentencias."@es .

ns1:Error8428 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8428: Sintaxis incorrecta en sentencia (ERROR)"@es ;
    ns1:identificador "8428" ;
    ns1:solucionaFallo ns1:ManualProgramacion8055 ;
    ns1:textoExtracto "8428 '(ERROR <nºentero> <,\"texto\">) DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:Error8429 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8429: Sintaxis incorrecta en sentencia (MSG)"@es ;
    ns1:identificador "8429" ;
    ns1:solucionaFallo ns1:ManualProgramacion8055 ;
    ns1:textoExtracto "8429 '(MSG \"texto\")' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:Error8430 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8430: Sintaxis incorrecta en sentencia (DGWZ)"@es ;
    ns1:identificador "8430" ;
    ns1:solucionaFallo ns1:ManualProgramacion8055 ;
    ns1:textoExtracto "8430 '(DGWZ expresión1, expresión2, expresión3, expresión4 <,expresión5, expresión6>)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:Error8431 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8431: Bloque ESBLK/DSBLK mal programado"@es ;
    ns1:identificador "8431" ;
    ns1:solucionaFallo ns1:ManualProgramacion8055 ;
    ns1:textoExtracto "8431 '(ESBLK/DSBLK)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Las sentencias ESBLK/DSBLK no están solas en el bloque, o falta programar alguna de las dos. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:ManualProgramacion8055 a ns1:Manual ;
    rdfs:label "Manual de programación del sistema 8055"@es ;
    ns1:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta."@es .

