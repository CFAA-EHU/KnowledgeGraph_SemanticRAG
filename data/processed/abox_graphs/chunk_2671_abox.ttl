@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorSintaxis_8055_ESBLK_DSBLK a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencias ESBLK/DSBLK (8055)"@es ;
    ns1:solucionaFallo ns1:ConsultarSintaxisCorrectaDeESBLKDSBLKEnManual8055 ;
    ns1:textoExtracto "Error al programar en lenguaje del 8055. Las sentencias ESBLK/DSBLK no están solas en el bloque, o falta programar alguna de las dos."@es .

ns1:ErrorSintaxis_8055_ESTOP_DSTOP a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencias ESTOP/DSTOP (8055)"@es ;
    ns1:identificador "8432" ;
    ns1:solucionaFallo ns1:ConsultarSintaxisCorrectaDeESTOPDSTOPEnManual8055 ;
    ns1:textoExtracto "Error al programar en lenguaje del 8055. Las sentencias ESTOP/DSTOP no están solas en el bloque, o falta programar alguna de las dos."@es .

ns1:Manual_8055 a ns1:Manual ;
    rdfs:label "Manual de programación 8055"@es ;
    ns1:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:ConsultarSintaxisCorrectaDeESBLKDSBLKEnManual8055 a ns1:TareaMantenimiento ;
    rdfs:label "Consultar sintaxis correcta de ESBLK/DSBLK en manual 8055"@es ;
    ns1:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta. Ambas sentencias deben ir solas en el bloque, y deben estar programadas ambas."@es .

ns1:ConsultarSintaxisCorrectaDeESTOPDSTOPEnManual8055 a ns1:TareaMantenimiento ;
    rdfs:label "Consultar sintaxis correcta de ESTOP/DSTOP en manual 8055"@es ;
    ns1:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta. Ambas sentencias deben ir solas en el bloque, y deben estar programadas ambas."@es .

