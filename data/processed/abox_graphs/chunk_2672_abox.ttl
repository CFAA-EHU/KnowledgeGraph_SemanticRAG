@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8433 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencias EFHOLD/DFHOLD" ;
    ns1:identificador "8433" ;
    ns1:solucionaFallo ns1:Manual_8055 ;
    ns1:textoExtracto "Las sentencias EFHOLD/DFHOLD no están solas en el bloque, o falta programar alguna de las dos. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta. Ambas sentencias deben ir solas en el bloque, y deben estar programadas ambas." .

ns1:Error_8434 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia GOTO N(expresión)" ;
    ns1:identificador "8434" ;
    ns1:solucionaFallo ns1:Manual_8055 ;
    ns1:textoExtracto "La sentencia no está bien programada. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

ns1:Error_8435 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia RPT N(expresión), N(expresión)" ;
    ns1:identificador "8435" ;
    ns1:solucionaFallo ns1:Manual_8055 ;
    ns1:textoExtracto "La sentencia no está bien programada. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

ns1:Error_8436 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia IF condición acción1 <ELSE acción2>" ;
    ns1:identificador "8436" ;
    ns1:solucionaFallo ns1:Manual_8055 ;
    ns1:textoExtracto "La sentencia no está bien programada. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

ns1:Error_8437 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia SUB nºentero" ;
    ns1:identificador "8437" ;
    ns1:solucionaFallo ns1:Manual_8055 ;
    ns1:textoExtracto "La sentencia no está bien programada. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

ns1:Error_8438 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia RET" ;
    ns1:identificador "8438" ;
    ns1:solucionaFallo ns1:Manual_8055 ;
    ns1:textoExtracto "La sentencia no está sola en el bloque o no se ha programado. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta. La sentencia debe ir sola en el bloque." .

ns1:Error_8439 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia CALL expresión" ;
    ns1:identificador "8439" ;
    ns1:solucionaFallo ns1:Manual_8055 ;
    ns1:textoExtracto "Error al programar en lenguaje del 8055." .

ns1:Manual_8055 a ns1:Manual ;
    rdfs:label "Manual del 8055" ;
    ns1:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta." .

