@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorProgramacion_8439 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8439: Sintaxis incorrecta en sentencia CALL"@es ;
    ns1:documentadoEn ns1:Manual_8055 ;
    ns1:identificador "8439" ;
    ns1:solucionaFallo ns1:ProgramarSentenciasCALLSinAislarEnBloque ;
    ns1:textoExtracto "8439 '(CALL expresión)' [...] CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:ErrorProgramacion_8440 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8440: Sintaxis incorrecta en sentencias PCALL/MCALL/PROBE"@es ;
    ns1:documentadoEn ns1:Manual_8055 ;
    ns1:identificador "8440" ;
    ns1:textoExtracto "8440 '(PCALL/MCALL/PROBE expresión <,param>)' [...] CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada."@es .

ns1:ProgramarSentenciasCALLSinAislarEnBloque a ns1:AccionProhibida ;
    rdfs:label "Programar sentencias CALL sin aislar en bloque"@es ;
    ns1:textoExtracto "La sentencia debe ir sola en el bloque."@es .

ns1:Manual_8055 a ns1:Manual ;
    rdfs:label "Manual de programación del lenguaje 8055"@es ;
    ns1:identificador "8055" ;
    ns1:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta."@es .

