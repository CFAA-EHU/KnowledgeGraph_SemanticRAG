@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error8440 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8440: Sintaxis incorrecta en PCALL/MCALL/PROBE"@es ;
    ns1:identificador "8440" ;
    ns1:solucionaFallo ns1:Manual8055 ;
    ns1:textoExtracto "'(PCALL/MCALL/PROBE expresión <,param>)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:Error8441 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8441: Sentencia MDOFF mal programada"@es ;
    ns1:identificador "8441" ;
    ns1:solucionaFallo ns1:Manual8055 ;
    ns1:textoExtracto "'(MDOFF)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está sola en el bloque o no se ha programado. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta. La sentencia debe ir sola en el bloque."@es .

ns1:Error8442 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8442: Sintaxis incorrecta en EXEC P(expresión)"@es ;
    ns1:identificador "8442" ;
    ns1:solucionaFallo ns1:Manual8055 ;
    ns1:textoExtracto "'(EXEC P(expresión) <,directorio>)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:Error8443 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8443: Acción no permitida en sentencia IF"@es ;
    ns1:identificador "8443" ;
    ns1:solucionaFallo ns1:Manual8055 ;
    ns1:textoExtracto "'Acción no permitida en sentencia IF' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Las acciones programadas en la sentencia IF no son válidas; las acciones no pueden ser IF ni SUB. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:Error8444 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8444: Función G mal programada"@es ;
    ns1:identificador "8444" ;
    ns1:solucionaFallo ns1:Manual8055 ;
    ns1:textoExtracto "Función G mal programada. DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:Error8445 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8445: Número de ejes programado incorrecto"@es ;
    ns1:identificador "8445" ;
    ns1:solucionaFallo ns1:Manual8055 ;
    ns1:textoExtracto "'Número de ejes programado incorrecto' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. El número de ejes programado para esa función G no es correcto. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:Error8446 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8446: Parámetros I, J, K no admitidos en bloque G2/G3"@es ;
    ns1:identificador "8446" ;
    ns1:solucionaFallo ns1:Manual8055 ;
    ns1:textoExtracto "'El bloque G2/G3 programado no admite parámetros I, J, K' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. El bloque G2/G3 programado no admite los parámetros I, J, K para definir el centro de la interpolación."@es .

ns1:Manual8055 a ns1:Manual ;
    rdfs:label "Manual de programación del 8055"@es ;
    ns1:identificador "8055" ;
    ns1:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta."@es .

