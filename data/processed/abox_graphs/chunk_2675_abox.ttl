@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorSintaxis_8447 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8447: La función programada exige parámetros I, J, K"@es ;
    ns1:identificador "8447" ;
    ns1:solucionaFallo ns1:SolucionConsultaManual_8055 ;
    ns1:textoExtracto "8447 'La función programada exige parámetros I, J, K' [...] CAUSA Error al programar en lenguaje del 8055. La función G9 exige programar el punto intermedio (parámetros I, J, K)"@es .

ns1:Funcion_G2 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G2 (interpolación circular)"@es ;
    ns1:identificador "G2" ;
    ns1:textoExtracto "El bloque G2/G3 programado no admite los parámetros I, J, K para definir el centro de la interpolación"@es .

ns1:Funcion_G3 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G3 (interpolación circular)"@es ;
    ns1:identificador "G3" ;
    ns1:textoExtracto "El bloque G2/G3 programado no admite los parámetros I, J, K para definir el centro de la interpolación"@es .

ns1:Funcion_G9 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G9 (requiere punto intermedio)"@es ;
    ns1:identificador "G9" ;
    ns1:textoExtracto "La función G9 exige programar el punto intermedio (parámetros I, J, K)"@es .

ns1:Parametro_I a ns1:Parametro ;
    rdfs:label "Parámetro I (coordenada intermedia)"@es ;
    ns1:identificador "I" ;
    ns1:textoExtracto "parámetros I, J, K para definir el centro de la interpolación [...] La función G9 exige programar el punto intermedio (parámetros I, J, K)"@es .

ns1:Parametro_J a ns1:Parametro ;
    rdfs:label "Parámetro J (coordenada intermedia)"@es ;
    ns1:identificador "J" ;
    ns1:textoExtracto "parámetros I, J, K para definir el centro de la interpolación [...] La función G9 exige programar el punto intermedio (parámetros I, J, K)"@es .

ns1:Parametro_K a ns1:Parametro ;
    rdfs:label "Parámetro K (coordenada intermedia)"@es ;
    ns1:identificador "K" ;
    ns1:textoExtracto "parámetros I, J, K para definir el centro de la interpolación [...] La función G9 exige programar el punto intermedio (parámetros I, J, K)"@es .

ns1:Manual_8055 a ns1:Manual ;
    rdfs:label "Manual de programación del control 8055"@es ;
    ns1:identificador "8055" ;
    ns1:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:SolucionConsultaManual_8055 a ns1:TareaMantenimiento ;
    rdfs:label "Consultar sintaxis correcta en manual del 8055"@es ;
    ns1:requiereMantenimiento ns1:Manual_8055 ;
    ns1:textoExtracto "SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

