@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error8448 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación incorrecta de parámetros I,J,K"@es ;
    ns1:identificador "8448" ;
    ns1:solucionaFallo ns1:ParametrosIJK ;
    ns1:textoExtracto "8448 Programación incorrecta de parámetros I,J,K. DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:Error8449 a ns1:DiagnosticoFallo ;
    rdfs:label "Mezcla de coordenadas cartesianas y polares"@es ;
    ns1:identificador "8449" ;
    ns1:textoExtracto "8449 No se permite mezclar coordenadas cartesianas y polares en el mismo bloque. DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:Error8450 a ns1:DiagnosticoFallo ;
    rdfs:label "Función G sin soporte para programación helicoidal"@es ;
    ns1:identificador "8450" ;
    ns1:textoExtracto "8450 La función G programada no admite programación helicoidal. DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:Error8451 a ns1:DiagnosticoFallo ;
    rdfs:label "Función G sin soporte para programación de rosca"@es ;
    ns1:identificador "8451" ;
    ns1:textoExtracto "8451 La función G programada no admite programación de rosca. DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:Error8452 a ns1:DiagnosticoFallo ;
    rdfs:label "Programación incorrecta de rosca (G33/G34)"@es ;
    ns1:identificador "8452" ;
    ns1:solucionaFallo ns1:FuncionG33G34 ;
    ns1:textoExtracto "8452 'Programación incorrecta de la rosca' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Programación incorrecta de la función G33/G34. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:Error8453 a ns1:DiagnosticoFallo ;
    rdfs:label "Término desconocido en programación"@es ;
    ns1:identificador "8453" ;
    ns1:textoExtracto "8453 Palabra desconocida o incompleta tras bloque correcto. DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Se ha programado un termino desconocido. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:ParametroE_G49 a ns1:Parametro ;
    rdfs:label "parámetro E"@es ;
    ns1:monitoreaParametro ns1:Error8454 ;
    ns1:textoExtracto "Valor incorrecto del parámetro E en la función G49"@es .

ns1:ParametroIJK_G9 a ns1:Parametro ;
    rdfs:label "parámetros I,J,K"@es ;
    ns1:monitoreaParametro ns1:Error8448J ;
    ns1:textoExtracto "La función G9 exige programar el punto intermedio (parámetros I, J, K)"@es .

ns1:Error8448J a ns1:DiagnosticoFallo ;
    rdfs:label "Falta punto intermedio en función G9 (parámetros I,J,K)"@es ;
    ns1:documentadoEn ns1:Manual8055 ;
    ns1:solucionaFallo ns1:PuntoIntermedioIJK ;
    ns1:textoExtracto "J, K' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La función G9 exige programar el punto intermedio (parámetros I, J, K) SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:Error8454 a ns1:DiagnosticoFallo ;
    rdfs:label "Valor incorrecto del parámetro E (G49)"@es ;
    ns1:identificador "8454" ;
    ns1:solucionaFallo ns1:ParametroEG49 ;
    ns1:textoExtracto "8454 'Valor de parámetro E incorrecto' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Valor incorrecto del parámetro E en la función G49."@es .

ns1:FuncionG33G34 a ns1:Parametro ;
    rdfs:label "función G33/G34"@es ;
    ns1:textoExtracto "Programación incorrecta de la función G33/G34"@es .

ns1:Manual8055 a ns1:Manual ;
    rdfs:label "Manual del 8055"@es ;
    ns1:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta"@es .

ns1:ParametroEG49 a ns1:Parametro ;
    rdfs:label "parámetro E (G49)"@es ;
    ns1:textoExtracto "Valor incorrecto del parámetro E en la función G49"@es ;
    ns1:valor "incorrecto" .

ns1:ParametrosIJK a ns1:Parametro ;
    rdfs:label "parámetros I,J,K"@es ;
    ns1:textoExtracto "La función G9 exige programar el punto intermedio (parámetros I, J, K)"@es .

ns1:PuntoIntermedioIJK a ns1:Parametro ;
    rdfs:label "punto intermedio (I,J,K)"@es ;
    ns1:textoExtracto "La función G9 exige programar el punto intermedio (parámetros I, J, K)"@es .

