@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Funcion_G a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G"@es ;
    ns1:textoExtracto "función G"@es .

ns1:Funcion_G49 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G49"@es ;
    ns1:textoExtracto "función G49"@es .

ns1:Parametro_E a ns1:Parametro ;
    rdfs:label "Parámetro E"@es ;
    ns1:monitoreaParametro ns1:AvisoSeguridad_8454 ;
    ns1:textoExtracto "parámetro E en la función G49"@es .

ns1:Parametro_S a ns1:Parametro ;
    rdfs:label "Parámetro S"@es ;
    ns1:monitoreaParametro ns1:AvisoSeguridad_8455 ;
    ns1:textoExtracto "parámetro S en la función G"@es .

ns1:AvisoSeguridad_8454 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 8454: 'Valor de parámetro E incorrecto'"@es ;
    ns1:documentadoEn ns1:Manual_8055 ;
    ns1:identificador "8454" ;
    ns1:mitigaRiesgo ns1:ErrorDeSintaxisEnParametroEFuncionG49 ;
    ns1:textoExtracto "'Valor de parámetro E incorrecto' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Valor incorrecto del parámetro E en la función G49."@es .

ns1:AvisoSeguridad_8455 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 8455: 'Valor de parámetro S incorrecto'"@es ;
    ns1:documentadoEn ns1:Manual_8055 ;
    ns1:identificador "8455" ;
    ns1:mitigaRiesgo ns1:ErrorDeSintaxisEnParametroSFuncionG ;
    ns1:textoExtracto "'Valor de parámetro S incorrecto' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Valor incorrecto del parámetro S en la función G."@es .

ns1:ErrorDeSintaxisEnParametroEFuncionG49 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en parámetro E (función G49)"@es ;
    ns1:solucionaFallo ns1:ProgramacionIncorrectaDeParametroE ;
    ns1:textoExtracto "Valor incorrecto del parámetro E en la función G49"@es .

ns1:ErrorDeSintaxisEnParametroSFuncionG a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en parámetro S (función G)"@es ;
    ns1:solucionaFallo ns1:ProgramacionIncorrectaDeParametroS ;
    ns1:textoExtracto "Valor incorrecto del parámetro S en la función G"@es .

ns1:ProgramacionIncorrectaDeParametroE a ns1:AccionProhibida ;
    rdfs:label "Programación incorrecta de parámetro E"@es ;
    ns1:textoExtracto "Error al programar en lenguaje del 8055"@es .

ns1:ProgramacionIncorrectaDeParametroS a ns1:AccionProhibida ;
    rdfs:label "Programación incorrecta de parámetro S"@es ;
    ns1:textoExtracto "Error al programar en lenguaje del 8055"@es .

ns1:Manual_8055 a ns1:Manual ;
    rdfs:label "Manual del 8055"@es ;
    ns1:identificador "8055" ;
    ns1:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta"@es .

