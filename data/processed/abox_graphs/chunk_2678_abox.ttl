@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8055_Parametro_S a ns1:DiagnosticoFallo ;
    rdfs:label "Error de parámetro S en lenguaje 8055"@es ;
    ns1:documentadoEn ns1:Manual_8055 ;
    ns1:solucionaFallo ns1:Parametro_S_Funcion_G ;
    ns1:textoExtracto "Error al programar en lenguaje del 8055. Valor incorrecto del parámetro S en la función G."@es .

ns1:Error_8456 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8456: Valor de parámetro L incorrecto"@es ;
    ns1:documentadoEn ns1:Manual_8055 ;
    ns1:identificador "8456" ;
    ns1:solucionaFallo ns1:Parametro_L_G33_G34 ;
    ns1:textoExtracto "'Valor de parámetro L incorrecto' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Valor incorrecto del parámetro L en la función G33/G34. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:Error_8457 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8457: Orden incorrecto de los ejes"@es ;
    ns1:documentadoEn ns1:Manual_8055 ;
    ns1:identificador "8457" ;
    ns1:textoExtracto "'Orden incorrecto de los ejes' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. El orden de los ejes en el bloque no es correcto. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:Error_8458 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8458: Función o variable inexistente en fresadora"@es ;
    ns1:documentadoEn ns1:Manual_8055 ;
    ns1:identificador "8458" ;
    ns1:textoExtracto "'Función o variable inexistente en fresadora' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La función programada sólo existe en torno y el programa es de una fresa (archivo pim)."@es .

ns1:Parametro_L_G33_G34 a ns1:Parametro ;
    rdfs:label "Parámetro L en funciones G33/G34"@es ;
    ns1:identificador "L" ;
    ns1:textoExtracto "Valor incorrecto del parámetro L en la función G33/G34."@es .

ns1:Parametro_S_Funcion_G a ns1:Parametro ;
    rdfs:label "Parámetro S en función G"@es ;
    ns1:identificador "S" ;
    ns1:textoExtracto "Valor incorrecto del parámetro S en la función G."@es .

ns1:Manual_8055 a ns1:Manual ;
    rdfs:label "Manual de programación del lenguaje 8055"@es ;
    ns1:identificador "8055" ;
    ns1:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta."@es .

