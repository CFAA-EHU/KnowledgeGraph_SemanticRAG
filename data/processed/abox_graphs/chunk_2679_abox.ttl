@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error8461 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8461: Sentencia INIPAR mal programada" ;
    ns1:identificador "8461" ;
    ns1:textoExtracto "8461 '(INIPAR)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está sola en el bloque o no se ha programado." .

ns1:Manual8055 a ns1:Manual ;
    rdfs:label "Manual de programación del control 8055" ;
    ns1:solucionaFallo ns1:Error8460 ;
    ns1:textoExtracto "Consultar en el manual del 8055 los ciclos disponibles." .

ns1:SoftwareFresa a ns1:Sistema ;
    rdfs:label "Software de programación para fresa (archivo pim)" ;
    ns1:solucionaFallo ns1:Error8459 ;
    ns1:textoExtracto "el programa es de una fresa (archivo pim)" .

ns1:SoftwareTorno a ns1:Sistema ;
    rdfs:label "Software de programación para torno (archivo pit)" ;
    ns1:solucionaFallo ns1:Error8459 ;
    ns1:textoExtracto "el programa es de un torno (archivo pit)" .

ns1:Error8460 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8460: Ciclo PROBE inexistente en torno" ;
    ns1:identificador "8460" ;
    ns1:textoExtracto "8460 'Ciclo PROBE inexistente en torno' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. El ciclo PROBE no existe. SOLUCIÓN Consultar en el manual del 8055 los ciclos disponibles." .

ns1:Error8459 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8459: Función o variable inexistente en torno" ;
    ns1:identificador "8459" ;
    ns1:textoExtracto "8459 'Función o variable inexistente en torno' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La función programada sólo existe en fresa y el programa es de un torno (archivo pit). SOLUCIÓN Cambiar el nombre del fichero o utilizar el software correcto." .

