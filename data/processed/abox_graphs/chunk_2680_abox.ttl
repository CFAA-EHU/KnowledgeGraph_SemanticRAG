@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error8462 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8462: Sintaxis incorrecta en sentencia DIGIT/TRACE"@es ;
    ns1:identificador "8462" ;
    ns1:solucionaFallo ns1:ProgramarSentenciasDIGITTRACESinSeguirSintaxisDelManual8055 ;
    ns1:textoExtracto "8462 '(DIGIT/TRACE expresión <,param>)' [...] CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:Error8463 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8463: Sintaxis incorrecta en sentencia OPEN P"@es ;
    ns1:identificador "8463" ;
    ns1:solucionaFallo ns1:ProgramarSentenciasOPENPSinSeguirSintaxisDelManual8055 ;
    ns1:textoExtracto "8463 '(OPEN P(expresión) <,directorio><,A/D><,comentario>)' [...] CAUSA Error al programar en lenguaje del 8055."@es .

ns1:ErrorBloqueSentencia a ns1:DiagnosticoFallo ;
    rdfs:label "Error: Sentencia no aislada en bloque (lenguaje 8055)"@es ;
    ns1:solucionaFallo ns1:AgruparMultiplesSentenciasEnUnMismoBloqueLenguaje8055 ;
    ns1:textoExtracto "CAUSA Error al programar en lenguaje del 8055. La sentencia no está sola en el bloque o no se ha programado. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta. La sentencia debe ir sola en el bloque."@es .

ns1:Manual8055 a ns1:Manual ;
    rdfs:label "Manual de programación del lenguaje 8055"@es ;
    ns1:identificador "8055" ;
    ns1:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:AgruparMultiplesSentenciasEnUnMismoBloqueLenguaje8055 a ns1:AccionProhibida ;
    rdfs:label "Agrupar múltiples sentencias en un mismo bloque (lenguaje 8055)"@es ;
    ns1:textoExtracto "La sentencia no está sola en el bloque [...] La sentencia debe ir sola en el bloque."@es .

ns1:ProgramarSentenciasDIGITTRACESinSeguirSintaxisDelManual8055 a ns1:AccionProhibida ;
    rdfs:label "Programar sentencias DIGIT/TRACE sin seguir sintaxis del manual 8055"@es ;
    ns1:textoExtracto "La sentencia no está bien programada. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:ProgramarSentenciasOPENPSinSeguirSintaxisDelManual8055 a ns1:AccionProhibida ;
    rdfs:label "Programar sentencias OPEN P sin seguir sintaxis del manual 8055"@es ;
    ns1:textoExtracto "Error al programar en lenguaje del 8055. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

