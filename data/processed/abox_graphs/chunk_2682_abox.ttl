@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error8469 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8469: Sintaxis incorrecta en sentencia DW"@es ;
    ns1:identificador "8469" ;
    ns1:solucionaFallo ns1:Manual8055 ;
    ns1:textoExtracto "'(DW expresión1 = expresión2 <expresión3 = expresión4><...>)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:Error8470 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8470: Sintaxis incorrecta en sentencia SK"@es ;
    ns1:identificador "8470" ;
    ns1:solucionaFallo ns1:Manual8055 ;
    ns1:textoExtracto "'(SK expresión1 = \"texto1\" <expresión2 = \"texto2\"><...>)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está bien programada. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:Error8471 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8471: Sentencia WKEY incompleta"@es ;
    ns1:identificador "8471" ;
    ns1:textoExtracto "'(WKEY)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. La sentencia no está sola"@es .

ns1:Manual8055 a ns1:Manual ;
    rdfs:label "Manual de programación del 8055"@es ;
    ns1:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta."@es .

