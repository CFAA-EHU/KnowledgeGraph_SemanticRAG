@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8471 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8471: '(WKEY)'"@es ;
    ns1:identificador "8471" ;
    ns1:solucionaFallo ns1:Manual_8055 ;
    ns1:textoExtracto "Error al programar en lenguaje del 8055. La sentencia no está sola en el bloque o no se ha programado. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta. La sentencia debe ir sola en el bloque."@es .

ns1:Error_8472 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8472: '(WBUF <\"texto\", expresión>)'"@es ;
    ns1:identificador "8472" ;
    ns1:solucionaFallo ns1:Manual_8055 ;
    ns1:textoExtracto "Error al programar en lenguaje del 8055. La sentencia no está bien programada. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:Error_8473 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8473: '(SYSTEM)'"@es ;
    ns1:identificador "8473" ;
    ns1:solucionaFallo ns1:Manual_8055 ;
    ns1:textoExtracto "Error al programar en lenguaje del 8055. La sentencia no está sola en el bloque o no se ha programado. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta. La sentencia debe ir sola en el bloque."@es .

ns1:Error_8474 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8474: 'Ciclo DIGIT inexistente en torno'"@es ;
    ns1:identificador "8474" ;
    ns1:textoExtracto "Error al programar en lenguaje del 8055. La función programada sólo existe en fresadora y el programa es de torno (archivo pit). SOLUCIÓN Cambiar el nombre del fichero o utilizar el software correcto."@es .

ns1:Error_8475 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8475: 'Ciclo TRACE inexistente en torno'"@es ;
    ns1:identificador "8475" ;
    ns1:textoExtracto "Error al programar en lenguaje del 8055. La función programada sólo existe en fresadora y el programa es de torno (archivo pit). SOLUCIÓN Cambiar el nombre del fichero o utilizar el software correcto."@es .

ns1:Error_8476 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8476: 'Función sin traducción'"@es ;
    ns1:identificador "8476" ;
    ns1:solucionaFallo ns1:Manual_8055 ;
    ns1:textoExtracto "La función programada no tiene equivalente en el del 8055. SOLUCIÓN El CNC no puede traducir la función. Consultar en el manual del 8055 las funciones disponibles."@es .

ns1:Error_8477 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8477: 'Minúsculas no permitidas en 8055'"@es ;
    ns1:identificador "8477" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición."@es .

ns1:Manual_8055 a ns1:Manual ;
    rdfs:label "Manual del 8055"@es ;
    ns1:identificador "8055" ;
    ns1:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta"@es .

