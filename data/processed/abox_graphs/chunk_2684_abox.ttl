@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_8055_FuncionNoSoportada a ns1:DiagnosticoFallo ;
    ns1:textoExtracto "CAUSA La función programada no tiene equivalente en el del 8055. SOLUCIÓN El CNC no puede traducir la función. Consultar en el manual del 8055 las funciones disponibles." .

ns1:Fallo_8477 a ns1:DiagnosticoFallo ;
    rdfs:label "Minúsculas no permitidas en 8055" ;
    ns1:identificador "8477" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. El lenguaje del 8055 no permite el uso de minúsculas. SOLUCIÓN Programar las palabras reservadas en mayúsculas." .

ns1:Fallo_8478 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en función G45" ;
    ns1:identificador "8478" ;
    ns1:textoExtracto "G45 <eje1 angulo1 eje2 angulo2 ... DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la" .

