@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:BloqueVacio8481 a ns1:Componente ;
    ns1:identificador "8481" ;
    ns1:textoExtracto "Bloque vacío. DETECCIÓN Durante la edición." .

ns1:ManualProgramacion a ns1:Manual ;
    ns1:textoExtracto "no permite el uso de minúsculas. SOLUCIÓN Programar las palabras reservadas en mayúsculas." .

ns1:Sentencia8478 a ns1:Parametro ;
    ns1:identificador "8478" ;
    ns1:textoExtracto "G45 <eje1 angulo1 eje2 angulo2 ... DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Sentencia8479 a ns1:Parametro ;
    ns1:identificador "8479" ;
    ns1:textoExtracto "'#TANGCTRL ON [<eje1 angulo1, eje2 angulo2, ...><, avance>]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Sentencia8480 a ns1:Parametro ;
    ns1:identificador "8480" ;
    ns1:textoExtracto "'#TANGCTRL OFF/SUSP <[eje1, eje2, ...]' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

