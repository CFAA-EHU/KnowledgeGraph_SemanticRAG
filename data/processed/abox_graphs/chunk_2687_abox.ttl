@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:DGSPDLNombreCabezal a ns1:Alarma ;
    ns1:detalladoEnEsquema ns1:Manual8055 ;
    ns1:textoExtracto "8485 '#DGSPDL nombre_cabezal' DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:OrdenDeDatosIncorrecto a ns1:Alarma ;
    ns1:detalladoEnEsquema ns1:Manual8055 ;
    ns1:textoExtracto "8484 'Orden de datos incorrecto' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. El orden de los datos en el bloque no es correcto. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

ns1:ProgramacionNoValidaFresadora a ns1:Alarma ;
    ns1:detalladoEnEsquema ns1:Manual8055 ;
    ns1:textoExtracto "8486 'Programación no válida en fresadora' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Programación incorrecta de la función G15 en" .

ns1:SintaxisCorrecta8055 a ns1:AvisoSeguridad ;
    ns1:detalladoEnEsquema ns1:Manual8055 ;
    ns1:textoExtracto "SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

