    ns1:detalladoEnEsquema ns1:Manual ;
    ns1:identificador "8489" ;
    ns1:textoExtracto "'$FOR i = inicial, final, incremento'. DETECCIÓN Durante la ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

