@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Contrase_aAdministrador a ns1:Parametro ;
    rdfs:label "Password de protección (Modo administrador)" ;
    ns1:identificador "Administrator mode" ;
    ns1:textoExtracto "El acceso a este modo está protegido mediante la contraseña \"Administrator mode\", definida en el modo utilidades." ;
    ns1:valor "Administrator mode" .

ns1:Contrase_aSetup a ns1:Parametro ;
    rdfs:label "Password de protección (Modo setup)" ;
    ns1:identificador "Parámetros máquina" ;
    ns1:textoExtracto "El acceso a este modo está protegido mediante la contraseña \"Parámetros máquina\", definida en el modo utilidades." ;
    ns1:valor "Parámetros máquina" .

ns1:InterfazAdministrador a ns1:InterfazUsuario ;
    rdfs:label "Pantalla de modo administrador" ;
    ns1:ilustradoEn ns1:ModoAdministrador ;
    ns1:textoExtracto "El equipo muestra en el escritorio la siguiente imagen, con fondo rojo, indicando el modo de trabajo activo y advirtiendo de que se trata de un modo no protegido. ADMINISTRATOR MODE" .

ns1:InterfazSetup a ns1:InterfazUsuario ;
    rdfs:label "Pantalla de modo setup" ;
    ns1:ilustradoEn ns1:ModoSetup ;
    ns1:textoExtracto "El equipo muestra en el escritorio la siguiente imagen, con fondo amarillo, indicando el modo de trabajo activo y advirtiendo de que se trata de un modo no protegido. SETUP MODE" .

ns1:ModoUsuario a ns1:ModoOperacion ;
    rdfs:label "Modo usuario" ;
    ns1:textoExtracto "Modo usuario. Es el modo habitual de trabajo para el" .

ns1:SistemaAbierto a ns1:Sistema ;
    rdfs:label "Sistema abierto" ;
    ns1:habilitadoPor ns1:ModoAdministrador ;
    ns1:textoExtracto "se habilita con el código de validación (opción de software \"Sistema abierto\")" .

ns1:SistemaCerrado a ns1:Sistema ;
    rdfs:label "Sistema cerrado" ;
    ns1:textoExtracto "Si usted no dispone de esta opción de software (es decir, dispone de un \"Sistema cerrado\"), no podrá acceder al modo administrador" .

ns1:ModoSetup a ns1:ModoOperacion ;
    rdfs:label "Modo setup" ;
    ns1:identificador "SETUP MODE" ;
    ns1:textoExtracto "El modo Setup se debe utilizar exclusivamente para la actualización del software del CNC y para la puesta a punto de la máquina; no permite instalar software de terceros. [...] SETUP MODE Nivel de protección. El modo setup dispone de un nivel intermedio de protección, donde está desprotegido todo aquello susceptible de ser modificado durante la puesta en marcha de la máquina; carpetas ..\\MTB, ..\\USERS, ..\\DIAGNOSIS y el registro de Windows." .

ns1:ModoAdministrador a ns1:ModoOperacion ;
    rdfs:label "Modo administrador" ;
    ns1:identificador "ADMINISTRATOR MODE" ;
    ns1:textoExtracto "se habilita con el código de validación (opción de software \"Sistema abierto\"). [...] Este modo se debe utilizar exclusivamente para instalar software ajeno a Fagor, para instalar el CNC (también es posible desde el modo Setup), para actualizar el sistema operativo o para cambiar la configuración del sistema. En este modo no arranca la aplicación CNC. [...] ADMINISTRATOR MODE Nivel de protección. En el modo administrador no existe ningún nivel de protección, todo el disco está desprotegido." .

