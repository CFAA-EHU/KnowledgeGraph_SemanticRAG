@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:ErrorOrdenDato a ns1:DiagnosticoFallo ;
    ns1:solucionaFallo ns1:ManualProgramacion8055 ;
    ns1:textoExtracto "Orden o dato incorrecto. Se ha programado un término desconocido en el bloque o bien el orden de los términos programados no es correcto." .

ns1:ErrorSintaxisSentencia a ns1:DiagnosticoFallo ;
    ns1:solucionaFallo ns1:SentenciaWHILE ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:ErrorSobraParametro a ns1:DiagnosticoFallo ;
    ns1:textoExtracto "'Sobra parámetro'." .

ns1:ErrorValorParametroK a ns1:DiagnosticoFallo ;
    ns1:solucionaFallo ns1:ManualProgramacion8055 ;
    ns1:textoExtracto "'Valor de parámetro K incorrecto'. Valor incorrecto del parámetro K para la función G programada." .

ns1:SentenciaWHILE a ns1:Parametro ;
    ns1:textoExtracto "sintaxis de la sentencia 8495 $WHILE condición" .

ns1:ManualProgramacion8055 a ns1:Manual ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

