@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8498 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8498: Sobra parámetro"@es ;
    ns1:identificador "8498" ;
    ns1:solucionaFallo ns1:ConsultarSintaxisIncorrectaEnManual8055 ;
    ns1:textoExtracto "8498 'Sobra parámetro' [...] CAUSA Error al programar en lenguaje del 8055. Hay un parámetro de más en la función G24/G27."@es .

ns1:Error_8499 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8499: Parámetros incorrectos en función"@es ;
    ns1:identificador "8499" ;
    ns1:solucionaFallo ns1:ConsultarSintaxisIncorrectaEnManual8055 ;
    ns1:textoExtracto "8499 'Parámetros incorrectos en función' [...] CAUSA Error al programar en lenguaje del 8055. Hay parámetros inválidos en función G programada"@es .

ns1:Error_8501 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8501: Función o sentencia aislada en bloque"@es ;
    ns1:identificador "8501" ;
    ns1:solucionaFallo ns1:ConsultarSintaxisIncorrectaEnManual8055 ;
    ns1:textoExtracto "8501 La función o sentencia va sola en el bloque. [...] CAUSA Error al programar en lenguaje del 8055. Se ha programado en el bloque algún término no relacionado con la sentencia o función."@es .

ns1:Error_8502 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8502: Interpolación circular en polares sin radio"@es ;
    ns1:identificador "8502" ;
    ns1:textoExtracto "8502 'La interpolación circular en polares no admite radio' [...] DETECCIÓN Durante la edición."@es .

ns1:Funcion_G_Generica a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G (genérica)"@es ;
    ns1:documentadoEn ns1:Manual_8055 ;
    ns1:textoExtracto "Hay parámetros inválidos en función G programada"@es .

ns1:Parametro_G24_G27 a ns1:Parametro ;
    rdfs:label "Parámetro en funciones G24/G27"@es ;
    ns1:documentadoEn ns1:Manual_8055 ;
    ns1:textoExtracto "Hay un parámetro de más en la función G24/G27."@es .

ns1:Parametro_Radio_Interpolacion a ns1:Parametro ;
    rdfs:label "Parámetro de radio en interpolación circular polar"@es ;
    ns1:documentadoEn ns1:Manual_8055 ;
    ns1:textoExtracto "La interpolación circular en polares no admite radio"@es .

ns1:ConsultarSintaxisIncorrectaEnManual8055 a ns1:AccionProhibida ;
    rdfs:label "Consultar sintaxis incorrecta en manual 8055"@es ;
    ns1:textoExtracto "SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta."@es .

ns1:Manual_8055 a ns1:Manual ;
    rdfs:label "Manual de programación 8055"@es ;
    ns1:identificador "8055" ;
    ns1:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta."@es .

