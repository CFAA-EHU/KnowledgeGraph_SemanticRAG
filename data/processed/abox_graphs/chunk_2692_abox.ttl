@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:CotaFinalDeMovimiento a ns1:Parametro ;
    ns1:documentadoEn ns1:Manual8055 ;
    ns1:identificador "cota final del movimiento" ;
    ns1:textoExtracto "Falta la cota final de movimiento en G8, G9 o G33"@es .

ns1:ErrorDeProgramacion8502 a ns1:Alarma ;
    ns1:detalladoEnEsquema ns1:EsquemaDeEdicion ;
    ns1:identificador "8502" ;
    ns1:textoExtracto "La interpolación circular en polares no admite radio"@es .

ns1:ErrorDeProgramacion8503 a ns1:Alarma ;
    ns1:detalladoEnEsquema ns1:EsquemaDeEdicion ;
    ns1:identificador "8503" ;
    ns1:textoExtracto "Falta programar la cota final del movimiento"@es .

ns1:ParametroQ a ns1:Parametro ;
    ns1:documentadoEn ns1:Manual8055 ;
    ns1:identificador "Q" ;
    ns1:textoExtracto "sólo admite el parámetro Q"@es .

ns1:Maquina8055 a ns1:Maquina ;
    ns1:identificador "8055" ;
    ns1:textoExtracto "programar en lenguaje del 8055"@es .

ns1:EsquemaDeEdicion a ns1:Esquema ;
    ns1:detalladoEnEsquema ns1:Manual8055 ;
    ns1:identificador "Esquema de edición" ;
    ns1:textoExtracto "Durante la edición"@es .

ns1:Manual8055 a ns1:Manual ;
    ns1:documentadoEn ns1:Maquina8055 ;
    ns1:identificador "Manual 8055" ;
    ns1:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta"@es .

