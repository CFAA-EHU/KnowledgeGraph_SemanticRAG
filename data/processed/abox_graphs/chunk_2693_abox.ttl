@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:ErrorProgramacion8503 a ns1:Alarma ;
    ns1:detalladoEnEsquema ns1:Esquema8503 ;
    ns1:mitigaRiesgo ns1:Solucion8503 ;
    ns1:textoExtracto "8503 'Falta programar la cota final del movimiento' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Falta la cota final de movimiento en G8, G9 o G33. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

ns1:ErrorProgramacion8504 a ns1:Alarma ;
    ns1:detalladoEnEsquema ns1:Esquema8504 ;
    ns1:mitigaRiesgo ns1:Solucion8504 ;
    ns1:textoExtracto "8504 'Valor incorrecto del número de bloques (0-50)' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Valor incorrecto del número de bloques en G41/G42. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

ns1:ErrorProgramacion8506 a ns1:Alarma ;
    ns1:detalladoEnEsquema ns1:Esquema8506 ;
    ns1:mitigaRiesgo ns1:Solucion8506 ;
    ns1:textoExtracto "8506 'Programar sólo parámetro E' DETECCIÓN Durante la edición. CAUSA Error al programar en lenguaje del 8055. Si en la función G49 se programa el parámetro E, la función no permite más parámetros. SOLUCIÓN Consultar en el manual del 8055 la sintaxis correcta." .

ns1:Esquema8503 a ns1:Esquema ;
    ns1:identificador "8503" ;
    ns1:textoExtracto "Esquema de la cota final del movimiento" .

ns1:Esquema8504 a ns1:Esquema ;
    ns1:identificador "8504" ;
    ns1:textoExtracto "Esquema del número de bloques" .

ns1:Esquema8506 a ns1:Esquema ;
    ns1:identificador "8506" ;
    ns1:textoExtracto "Esquema de la función G49" .

ns1:Solucion8503 a ns1:AvisoSeguridad ;
    ns1:documentadoEn ns1:Manual8055 ;
    ns1:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta." .

ns1:Solucion8504 a ns1:AvisoSeguridad ;
    ns1:documentadoEn ns1:Manual8055 ;
    ns1:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta." .

ns1:Solucion8506 a ns1:AvisoSeguridad ;
    ns1:documentadoEn ns1:Manual8055 ;
    ns1:textoExtracto "Consultar en el manual del 8055 la sintaxis correcta." .

ns1:Manual8055 a ns1:Manual ;
    ns1:identificador "8055" ;
    ns1:textoExtracto "Manual del 8055" .

