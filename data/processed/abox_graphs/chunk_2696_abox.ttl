@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8519 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8519: Variable externa sin permiso de escritura" ;
    ns1:identificador "8519" ;
    ns1:textoExtracto "Variable externa sin permiso de escritura. DETECCIÓN Durante la edición y ejecución." .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación" ;
    ns1:solucionaFallo ns1:Error_8512,
        ns1:Error_8513,
        ns1:Error_8514,
        ns1:Error_8515,
        ns1:Error_8516,
        ns1:Error_8517,
        ns1:Error_8518 ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Parametro_DINDIST_PrimerValor a ns1:Parametro ;
    rdfs:label "Primer parámetro de #DINDIST (0/1)" ;
    ns1:monitoreaParametro ns1:Error_8515 ;
    ns1:textoExtracto "El primer parámetro #DINDIST debe ser 0 o 1." ;
    ns1:valor "0",
        "1" .

ns1:Error_8512 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8512: Espacio en nombre de subrutina" ;
    ns1:identificador "8512" ;
    ns1:textoExtracto "No se permite espacio en el nombre de subrutina. DETECCIÓN Durante la edición y ejecución. CAUSA El nombre de la subrutina no admite espacios en blanco. SOLUCIÓN Corregir el nombre de la subrutina." .

ns1:Error_8513 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8513: Sintaxis incorrecta en #DINDIST ON" ;
    ns1:identificador "8513" ;
    ns1:textoExtracto "#DINDIST ON[0/1, númeroCanal <,númeroCanal ,númeroCanal>]. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Error_8514 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8514: Sintaxis incorrecta en #DINDIST OFF" ;
    ns1:identificador "8514" ;
    ns1:textoExtracto "#DINDIST OFF. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Error_8516 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8516: Sintaxis incorrecta en #DINDIST_EXEC_CYCLE" ;
    ns1:identificador "8516" ;
    ns1:textoExtracto "#DINDIST_EXEC_CYCLE[númeroCanal]. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Error_8517 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8517: Sintaxis incorrecta en #PATHND" ;
    ns1:identificador "8517" ;
    ns1:textoExtracto "#PATHND ON/OFF. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Error_8518 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8518: Sintaxis incorrecta en #FEEDND" ;
    ns1:identificador "8518" ;
    ns1:textoExtracto "#FEEDND ON/OFF. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Error_8515 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8515: Parámetro inicial incorrecto en #DINDIST" ;
    ns1:identificador "8515" ;
    ns1:textoExtracto "El primer parámetro #DINDIST debe ser 0 o 1. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

