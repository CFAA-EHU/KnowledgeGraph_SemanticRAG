@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Deteccion832 a ns1:DiagnosticoFallo ;
    rdfs:label "Detección Durante la edición y ejecución"@es ;
    ns1:textoExtracto "DETECCIÓN Durante la edición y ejecución" .

ns1:VariableSoloLectura832 a ns1:DiagnosticoFallo ;
    rdfs:label "La variable es de solo lectura o el CNC ha bloqueado momentáneamente la variable mientras realiza alguna operación con ella"@es ;
    ns1:detalladoEnEsquema ns1:VariableSinPermiso832 ;
    ns1:textoExtracto "CAUSA La variable es de solo lectura o el CNC ha bloqueado momentáneamente la variable mientras realiza alguna operación con ella. SOLUCIÓN Si la variable es de solo lectura no se puede escribir. Si el CNC ha bloqueado la variable, esperar a que finalice sus operaciones" .

ns1:EliminarVariable832 a ns1:AccionProhibida ;
    rdfs:label "#DELETE nombreVariableUsuario <, nombreVariableUsuario, ...>."@es ;
    ns1:detalladoEnEsquema ns1:EliminarVariable832 ;
    ns1:textoExtracto "8520 #DELETE nombreVariableUsuario <, nombreVariableUsuario, ...>. DETECCIÓN Durante la edición y ejecución" .

ns1:Manual832 a ns1:Manual ;
    rdfs:label "Manual de programación"@es ;
    ns1:documentadoEn ns1:Solucion832 ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia" .

ns1:SintaxisIncorrecta832 a ns1:Alarma ;
    rdfs:label "Sintaxis de la sentencia no es correcta"@es ;
    ns1:detalladoEnEsquema ns1:SintaxisIncorrecta832 ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta" .

ns1:Solucion832 a ns1:AvisoSeguridad ;
    rdfs:label "Revisar en el manual de programación la sintaxis de la sentencia"@es ;
    ns1:documentadoEn ns1:Manual832 ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia" .

ns1:VariableSinPermiso832 a ns1:DiagnosticoFallo ;
    rdfs:label "Variable externa sin permiso de escritura"@es ;
    ns1:detalladoEnEsquema ns1:VariableSinPermiso832 ;
    ns1:textoExtracto "8519 Variable externa sin permiso de escritura. DETECCIÓN Durante la edición y ejecución" .

