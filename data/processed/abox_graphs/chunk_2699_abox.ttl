@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:SOLUCI_N1 a ns1:AvisoSeguridad ;
    ns1:identificador "8527" ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8527 '#REPOS <INT/INI> nombreEje/nombreCabezal …'"@es .

ns1:SOLUCI_N2 a ns1:AvisoSeguridad ;
    ns1:identificador "8528" ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. Tras #REPOS programar una secuencia de ejes y/o cabezales del canal. 8528 #VOLCOMP ON/OFF"@es .

ns1:SOLUCI_N3 a ns1:AvisoSeguridad ;
    ns1:identificador "8529" ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8529 #RENAME AX OFF"@es .

