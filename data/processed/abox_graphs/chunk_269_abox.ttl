@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoDiagnosis a ns1:ModoOperacion ;
    rdfs:label "Modo diagnosis" ;
    ns1:identificador "Modo_Diagnosis" ;
    ns1:textoExtracto "Algunas utilidades del sistema operativo (administrador de tareas, reloj) estarán disponibles desde el modo diagnosis." .

ns1:ModoSetup a ns1:ModoOperacion ;
    rdfs:label "Modo SETUP" ;
    ns1:identificador "Modo_SETUP" ;
    ns1:textoExtracto "Modo SETUP (puesta a punto). En el encendido, el CNC mostrará un mensaje indicando que se encuentra en un modo no protegido y que la puesta a punto se encuentra sin finalizar." .

ns1:ModoUsuario a ns1:ModoOperacion ;
    rdfs:label "Modo usuario" ;
    ns1:identificador "Modo_Usuario" ;
    ns1:textoExtracto "Modo usuario. Es el modo habitual de trabajo para el usuario, una vez terminada la puesta a punto. Este modo no permite actualizar el CNC ni acceder al sistema operativo." .

ns1:RestriccionTransicionSetupUser a ns1:AccionProhibida ;
    rdfs:label "Restricción de transición SETUP → USER" ;
    ns1:solucionaFallo ns1:AvisoFaltaPasswords ;
    ns1:textoExtracto "Restricciones al trabajo en modo Setup y paso al modo User. Las siguientes restricciones tienen como objetivo que el OEM entregue las máquinas con el CNC en modo de trabajo protegido (Modo User)." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "El CNC considera los archivos guardados en otras carpetas como archivos temporales y serán borrados al apagar el CNC." ;
    ns1:tieneComponente ns1:GestorPasswords,
        ns1:InterfazExploradorArchivos,
        ns1:SistemaProteccion .

ns1:GestorPasswords a ns1:Componente ;
    rdfs:label "Gestor de contraseñas" ;
    ns1:requiereMantenimiento ns1:TareaBackupPasswords ;
    ns1:textoExtracto "Password de protección. El acceso a este modo no está protegido mediante la contraseña." .

ns1:InterfazExploradorArchivos a ns1:InterfazUsuario ;
    rdfs:label "Explorador de archivos (modo utilidades)" ;
    ns1:habilitadoPor ns1:ModoUtilidades ;
    ns1:textoExtracto "La gestión de ficheros de flash, pendrives, ethernet, etc se hará exclusivamente desde el explorador del modo utilidades." .

ns1:ModoUtilidades a ns1:ModoOperacion ;
    rdfs:label "Modo utilidades" ;
    ns1:identificador "Modo_Utilidades" ;
    ns1:textoExtracto "Parámetros máquina, definida en el modo utilidades. Al iniciar el equipo en este modo de trabajo, éste solicita la contraseña de acceso." .

ns1:SistemaProteccion a ns1:ElementoSeguridad ;
    rdfs:label "Sistema de protección del CNC" ;
    ns1:mitigaRiesgo ns1:AvisoFaltaPasswords ;
    ns1:textoExtracto "Nivel de protección. El modo usuario tiene el máximo nivel de protección, donde está desprotegido únicamente las carpetas y archivos susceptibles de ser modificados durante el trabajo normal de la máquina." .

ns1:TareaBackupPasswords a ns1:TareaMantenimiento ;
    rdfs:label "Copia de seguridad de passwords" ;
    ns1:textoExtracto "Si se selecciona sí, y existen passwords, el CNC hace la copia de seguridad y pasa a modo USER (proceso correcto)." .

ns1:AvisoFaltaPasswords a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de falta de passwords" ;
    ns1:textoExtracto "Si se selecciona sí, y no hay passwords, el CNC saca un mensaje de aviso y no cierra la aplicación. En el encendido, el CNC verifica que existen passwords y la copia de seguridad. En caso de que no exista alguno de los dos," .

