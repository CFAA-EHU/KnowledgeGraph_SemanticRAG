@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:ManualProgramacion a ns1:Manual ;
    ns1:textoExtracto "ON/OFF DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." ;
    ns1:tieneComponente ns1:SentenciaHSC,
        ns1:SentenciaPWMOUT,
        ns1:SentenciaRENAME_AX_OFF,
        ns1:SentenciaRENAME_SP_OFF,
        ns1:SentenciaSWTOUT,
        ns1:SentenciaVIRTAX_OFF,
        ns1:SentenciaVIRTAX_ON .

ns1:SentenciaHSC a ns1:Parametro ;
    ns1:identificador "8532" ;
    ns1:textoExtracto "#HSC ON[FAST <, E valor, CORNER valorÁngulo>] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." ;
    ns1:valor "#HSC ON[FAST <, E valor, CORNER valorÁngulo>]" .

ns1:SentenciaPWMOUT a ns1:Parametro ;
    ns1:identificador "8533" ;
    ns1:textoExtracto "#PWMOUT ON<[FREQ/F valor, DUTY/D valor]>/OFF DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." ;
    ns1:valor "#PWMOUT ON<[FREQ/F valor, DUTY/D valor]>/OFF" .

ns1:SentenciaRENAME_AX_OFF a ns1:Parametro ;
    ns1:identificador "8529" ;
    ns1:textoExtracto "#RENAME AX OFF [nombreEje,...] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." ;
    ns1:valor "#RENAME AX OFF [nombreEje,...]" .

ns1:SentenciaRENAME_SP_OFF a ns1:Parametro ;
    ns1:identificador "8530" ;
    ns1:textoExtracto "#RENAME SP OFF [nombreCabezal,...] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." ;
    ns1:valor "#RENAME SP OFF [nombreCabezal,...]" .

ns1:SentenciaSWTOUT a ns1:Parametro ;
    ns1:identificador "8531" ;
    ns1:textoExtracto "#SWTOUT ON[TON = valor,TOF = valor,PON = valor,POF = valor]/OFF DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." ;
    ns1:valor "#SWTOUT ON[TON = valor,TOF = valor,PON = valor,POF = valor]/OFF" .

ns1:SentenciaVIRTAX_OFF a ns1:Parametro ;
    ns1:identificador "8534" ;
    ns1:textoExtracto "#VIRTAX OFF DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." ;
    ns1:valor "#VIRTAX OFF" .

ns1:SentenciaVIRTAX_ON a ns1:Parametro ;
    ns1:identificador "8535" ;
    ns1:textoExtracto "#VIRTAX <ON> <[cotaEje]> DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." ;
    ns1:valor "#VIRTAX <ON> <[cotaEje]>" .

