    ns1:identificador "8537" ;
    ns1:textoExtracto "8537 #DEFROT[ERROR/WARNING/NONE, criterio, Q valorÁngulo] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar" .

