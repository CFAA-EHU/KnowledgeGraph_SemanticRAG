@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:_8535 a ns1:Alarma ;
    ns1:detalladoEnEsquema ns1:_8535_Esquema ;
    ns1:documentadoEn ns1:Manual ;
    ns1:identificador "8535" ;
    ns1:textoExtracto "8535 #VIRTAX <ON> <[cotaEje]> DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

