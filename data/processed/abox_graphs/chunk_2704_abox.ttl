@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:En a ns1:Parametro ;
    ns1:textoExtracto "El rango de valores válidos para un ente geométrico es de 1 a 30" .

ns1:G801 a ns1:ModoOperacion ;
    ns1:textoExtracto "Las funciones G válidas en la definición de un ente geométrico son G801 a G803" .

ns1:G802 a ns1:ModoOperacion ;
    ns1:textoExtracto "Se ha programado incorrectamente el radio del arco en la función G802" .

ns1:G803 a ns1:ModoOperacion ;
    ns1:textoExtracto "Se ha programado incorrectamente el radio del arco en la función G832 o 833" .

ns1:G808 a ns1:ModoOperacion ;
    ns1:textoExtracto "Las funciones G válidas en la definición de un ente geométrico son G808 a G811" .

