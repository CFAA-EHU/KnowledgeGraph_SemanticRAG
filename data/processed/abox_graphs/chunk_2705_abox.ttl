@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:ParametroDError a ns1:Alarma ;
    ns1:detalladoEnEsquema ns1:Esquema1 ;
    ns1:identificador "8553" ;
    ns1:textoExtracto "CAUSA No se permite programar el parámetro D en el bloque. SOLUCIÓN Corregir la programación."@es .

ns1:SintaxisError1 a ns1:Alarma ;
    ns1:detalladoEnEsquema ns1:Esquema1 ;
    ns1:identificador "8551" ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:SintaxisError2 a ns1:Alarma ;
    ns1:detalladoEnEsquema ns1:Esquema1 ;
    ns1:identificador "8552" ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia."@es .

ns1:Esquema1 a ns1:Esquema ;
    ns1:detalladoEnEsquema ns1:Manual ;
    ns1:identificador "8551",
        "8552",
        "8553" ;
    ns1:textoExtracto "CAUSA No se permite programar el parámetro D en el bloque. SOLUCIÓN Corregir la programación."@es .

