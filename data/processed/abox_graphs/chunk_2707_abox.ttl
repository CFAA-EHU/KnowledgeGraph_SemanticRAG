@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:BloqueProgramacion a ns1:Componente ;
    ns1:textoExtracto "programar varias cotas en el bloque" .

ns1:G820 a ns1:Maquina ;
    ns1:textoExtracto "Sólo G820 permite programar varias cotas en el bloque." .

ns1:ManualProgramacion a ns1:Manual ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:SentenciaGProgramada a ns1:Parametro ;
    ns1:textoExtracto "La sentencia o función G programada en el bloque no permite la programación de cotas separadas por comas." .

ns1:SentenciaISOOFF a ns1:Parametro ;
    ns1:identificador "#ISO OFF" ;
    ns1:textoExtracto "DETECCIÓN Durante" .

ns1:SentenciaISOON a ns1:Parametro ;
    ns1:identificador "#ISO <ON><[NAME=\"fileName\"]>" ;
    ns1:textoExtracto "La sintaxis de la sentencia no es correcta." .

