@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DeteccionCicloNoAdmiteNR a ns1:DiagnosticoFallo ;
    ns1:solucionaFallo ns1:EliminarComandoNR ;
    ns1:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA El ciclo no admite la programación del comando NR." .

ns1:DeteccionSintaxisIncorrectaOPEN a ns1:DiagnosticoFallo ;
    ns1:solucionaFallo ns1:CorregirSintaxisSentenciaOPEN ;
    ns1:textoExtracto "8569 #OPEN[\"fichero\" <, A/D> <, KEEPLINE> <, FhandleFichero>] DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta." .

ns1:DeteccionValorIncorrectoNR a ns1:DiagnosticoFallo ;
    ns1:solucionaFallo ns1:ProgramarValorNRMayor2 ;
    ns1:textoExtracto "8568 Valor incorrecto de NR (0-1). DETECCIÓN Durante la edición y ejecución. CAUSA El comando NR no admite los valores 0 y 1." .

ns1:SentenciaRPT a ns1:Parametro ;
    rdfs:label "#RPT" ;
    ns1:textoExtracto "Para repetir el bloque, utilizar la sentencia #RPT." .

ns1:CorregirSintaxisSentenciaOPEN a ns1:AccionProhibida ;
    ns1:textoExtracto "SOLUCIÓN Corregir la sintaxis de la sentencia #OPEN." .

ns1:EliminarComandoNR a ns1:AccionProhibida ;
    ns1:textoExtracto "SOLUCIÓN Eliminar el comando NR del bloque." .

ns1:ProgramarValorNRMayor2 a ns1:AccionProhibida ;
    ns1:textoExtracto "SOLUCIÓN Programar el comando NR con un valor igual o superior a 2." .

