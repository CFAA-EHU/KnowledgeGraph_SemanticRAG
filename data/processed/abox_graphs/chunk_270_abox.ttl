@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_FaltaConfiguracion a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de configuración incompleta"@es ;
    ns1:activaAlarma ns1:ModoOperacion_USER ;
    ns1:textoExtracto "el CNC mostrará un mensaje indicando que la puesta a punto se encuentra sin finalizar. En esta situación el CNC no dispone de garantía Fagor."@es .

ns1:InterfazUsuario_DiskMonitor a ns1:InterfazUsuario ;
    rdfs:label "DiskMonitor"@es ;
    ns1:habilitadoPor ns1:ModoOperacion_SETUP ;
    ns1:textoExtracto "desde el modo SETUP, a través de \"DiskMonitor\" se accede directamente al modo USER."@es .

ns1:ModoOperacion_SETUP a ns1:ModoOperacion ;
    rdfs:label "Modo SETUP"@es ;
    ns1:textoExtracto "desde el modo SETUP, a través de \"DiskMonitor\" se accede directamente al modo USER."@es .

ns1:ModoOperacion_USER a ns1:ModoOperacion ;
    rdfs:label "Modo USER"@es ;
    ns1:textoExtracto "Modo USER (modo de trabajo). En el encendido, el CNC verifica que existen passwords y la copia de seguridad."@es .

