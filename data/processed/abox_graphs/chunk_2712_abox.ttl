@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Sentencia8578 a ns1:AvisoSeguridad ;
    ns1:identificador "8578" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8578 #RTCP ON/OFF<[CLEAR, HEAD=ST/DYN/OFF, TABLE=ST/DYN/OFF, COROT=valor/ROT/FIX]>" .

ns1:Sentencia8579 a ns1:AvisoSeguridad ;
    ns1:identificador "8579" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8579 #LOAD GAPTABLE[fichero]." .

ns1:Sentencia8580 a ns1:AvisoSeguridad ;
    ns1:identificador "8580" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8580 #LOAD PWRTABLE[fichero]." .

