ns1:AvisoProgramacionGiro a ns1:AvisoSeguridad ;
    rdfs:label "8582 Programación no permitida con giro activo. DETECCIÓN Durante la ejecución. CAUSA Se ha programado una sentencia o función G no permitida cuando está activo un giro del sistema de coordenadas. SOLUCIÓN Desactivar el giro de coordenadas." ;
    ns1:identificador "8582" ;
    ns1:textoExtracto "8582 Programación no permitida con giro activo. DETECCIÓN Durante la ejecución. CAUSA Se ha programado una sentencia o función G no permitida cuando está activo un giro del sistema de coordenadas. SOLUCIÓN Desactivar el giro de coordenadas." .

ns1:AvisoProgramacionTransformada a ns1:AvisoSeguridad ;
