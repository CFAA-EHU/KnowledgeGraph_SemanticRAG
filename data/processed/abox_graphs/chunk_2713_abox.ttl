    ns1:identificador "8583" ;
    ns1:textoExtracto "8583 Programación no permitida con transformada activa. DETECCIÓN Durante la ejecución." .

ns1:Sentencia8580 a ns1:AvisoSeguridad ;
    rdfs:label "8580 #LOAD PWRTABLE[fichero]. DETECCIÓN Durante la edición y ejecución. CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." ;
