@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CompensacionRadio a ns1:Parametro ;
    rdfs:label "compensación de radio" ;
    ns1:textoExtracto "compensación de radio (G41/G42)" .

ns1:ProgramacionNoPermitidaCompensacionActiva a ns1:AccionProhibida ;
    rdfs:label "Programación no permitida con compensación activa" ;
    ns1:identificador "8584" ;
    ns1:textoExtracto "Programación no permitida con compensación activa." .

ns1:ProgramacionNoPermitidaSinMovimientoIndependiente a ns1:AccionProhibida ;
    rdfs:label "Programación no permitida sin movimiento independiente activo" ;
    ns1:identificador "8585" ;
    ns1:textoExtracto "Programación no permitida sin movimiento independiente activo." .

ns1:ProgramacionNoPermitidaTransformadaActiva a ns1:AccionProhibida ;
    rdfs:label "Programación no permitida con transformada activa" ;
    ns1:identificador "8583" ;
    ns1:textoExtracto "Programación no permitida con transformada activa." .

ns1:SolucionDesactivarCompensacionRadio a ns1:AccionProhibida ;
    rdfs:label "Desactivar la compensación de radio" ;
    ns1:identificador "8585" ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la compensación de radio." .

ns1:SolucionDesactivarGiroCoordenadas a ns1:AccionProhibida ;
    rdfs:label "Desactivar el giro de coordenadas" ;
    ns1:identificador "8583" ;
    ns1:textoExtracto "SOLUCIÓN Desactivar el giro de coordenadas." .

ns1:SolucionDesactivarTransformacionCoordenadas a ns1:AccionProhibida ;
    rdfs:label "Desactivar la transformación de coordenadas" ;
    ns1:identificador "8584" ;
    ns1:textoExtracto "SOLUCIÓN Desactivar la transformación de coordenadas." .

ns1:TransformacionCoordenadas a ns1:Parametro ;
    rdfs:label "transformación de coordenadas" ;
    ns1:textoExtracto "alguna transformación de coordenadas; #CS/#ACS, #RTCP, #ANGAX, #PARALAX, #VIRTAX" .

