@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:CompensacionRadio a ns1:Parametro ;
    ns1:textoExtracto "Desactivar la compensación de radio." .

ns1:ManualProgramacion a ns1:Manual ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:MovimientoIndependiente a ns1:ModoOperacion ;
    ns1:textoExtracto "activar el movimiento independiente" .

ns1:ProgramacionNoPermitidaSinMovimientoIndependiente a ns1:AccionProhibida ;
    ns1:textoExtracto "Programación no permitida sin movimiento independiente activo." .

ns1:SentenciaCYL a ns1:Parametro ;
    ns1:identificador "#CYL [nombreAbscisa, nombreOrdenada, nombreLong valorRadio <,Q valorOrigenC>] <[númeroCinemática]>" ;
    ns1:textoExtracto "8587 #CYL [nombreAbscisa, nombreOrdenada, nombreLong valorRadio <,Q valorOrigenC>] <[númeroCinemática]>." .

ns1:SentenciaFACE a ns1:Parametro ;
    ns1:identificador "#FACE[nombreAbscisa, nombreOrdenada <,nombreLong, Eje4, Eje5, Q valorOrigenC>] <[númeroCinemática]>" ;
    ns1:textoExtracto "8586 #FACE[nombreAbscisa, nombreOrdenada <,nombreLong, Eje4, Eje5, Q valorOrigenC>] <[númeroCinemática]>." .

ns1:SentenciaGFuncionNoPermitida a ns1:AccionProhibida ;
    ns1:textoExtracto "Se ha programado una sentencia o función G no permitida porque no está activo el movimiento independiente." .

ns1:SintaxisSentenciaIncorrecta8586 a ns1:AccionProhibida ;
    ns1:textoExtracto "La sintaxis de la sentencia no es correcta." .

ns1:SintaxisSentenciaIncorrecta8587 a ns1:AccionProhibida ;
    ns1:textoExtracto "La sintaxis de la sentencia no es correcta." .

