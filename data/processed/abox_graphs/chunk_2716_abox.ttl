@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:ComandoDEF a ns1:ComponenteElectrico ;
    ns1:textoExtracto "Comando DEF o PDEF" .

ns1:ComandoDFD a ns1:ComponenteElectrico ;
    ns1:textoExtracto "DFU, DFD, ERA" .

ns1:ComandoDFU a ns1:ComponenteElectrico ;
    ns1:textoExtracto "DFU, DFD, ERA" .

ns1:ComandoERA a ns1:ComponenteElectrico ;
    ns1:textoExtracto "DFU, DFD, ERA" .

ns1:ComandoPDEF a ns1:ComponenteElectrico ;
    ns1:textoExtracto "Comando DEF o PDEF" .

ns1:ManualProgramacion a ns1:Manual ;
    ns1:detalladoEnEsquema ns1:ErrorFaltaRecursoNumero,
        ns1:ErrorNumeroAntesSimbolo,
        ns1:ErrorRecursoAntesSimbolo,
        ns1:ErrorSimboloRecursoNumero,
        ns1:ErrorSintaxisSentencia ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:SimboloDEF a ns1:ComponenteElectrico ;
    ns1:textoExtracto "símbolo de DEF/PDEF" .

ns1:SimboloPDEF a ns1:ComponenteElectrico ;
    ns1:textoExtracto "símbolo de DEF/PDEF" .

ns1:ErrorFaltaRecursoNumero a ns1:DiagnosticoFallo ;
    ns1:identificador "8701" ;
    ns1:textoExtracto "'Falta recurso o número tras símbolo' DETECCIÓN Durante la edición. CAUSA Falta recurso tras DFU, DFD, ERA o tras el símbolo de DEF/PDEF. SOLUCIÓN Programar \"DEF/PDEF símbolo recurso\" o \"DFU/DFD/ERA recurso\"." .

ns1:ErrorNumeroAntesSimbolo a ns1:DiagnosticoFallo ;
    ns1:identificador "8703" ;
    ns1:textoExtracto "'Número antes de símbolo' DETECCIÓN Durante la edición. CAUSA Comando DEF o PDEF. El número está programado antes que el símbolo. SOLUCIÓN Programar \"DEF/PDEF símbolo número\"." .

ns1:ErrorRecursoAntesSimbolo a ns1:DiagnosticoFallo ;
    ns1:identificador "8702" ;
    ns1:textoExtracto "'Recurso antes de símbolo' DETECCIÓN Durante la edición. CAUSA Comando DEF o PDEF. El recurso está programado antes que el símbolo. SOLUCIÓN Programar \"DEF/PDEF símbolo recurso\"." .

ns1:ErrorSimboloRecursoNumero a ns1:DiagnosticoFallo ;
    ns1:identificador "8704" ;
    ns1:textoExtracto "'Se esperaba recurso o número en lugar de símbolo' DETECCIÓN Durante la edición." .

ns1:ErrorSintaxisSentencia a ns1:DiagnosticoFallo ;
    ns1:textoExtracto "La sintaxis de la sentencia no es correcta." .

