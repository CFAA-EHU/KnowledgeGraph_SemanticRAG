@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComandoDEF a ns1:ComponenteElectrico ;
    rdfs:label "DEF" ;
    ns1:textoExtracto "Comando DEF" .

ns1:ComandoPDEF a ns1:ComponenteElectrico ;
    rdfs:label "PDEF" ;
    ns1:textoExtracto "Comando PDEF" .

ns1:Error8704 a ns1:AvisoSeguridad ;
    ns1:identificador "8704" ;
    ns1:textoExtracto "'Se esperaba recurso o número en lugar de símbolo' DETECCIÓN Durante la edición. CAUSA Comando DEF o PDEF. Hay programados dos símbolos. SOLUCIÓN Programar \"DEF/PDEF símbolo recurso\" o \"DEF/PDEF símbolo número\"." .

ns1:Error8705 a ns1:AvisoSeguridad ;
    ns1:identificador "8705" ;
    ns1:textoExtracto "'No se puede redefinir recursos' DETECCIÓN Durante la edición. CAUSA Comando DEF o PDEF. Hay programados dos recursos. SOLUCIÓN Programar \"DEF/PDEF símbolo recurso\" o \"DEF/PDEF símbolo número\"." .

ns1:Error8706 a ns1:AvisoSeguridad ;
    ns1:identificador "8706" ;
    ns1:textoExtracto "'No se puede redefinir números' DETECCIÓN Durante la edición. CAUSA Comando DEF o PDEF. Hay programados dos números. SOLUCIÓN Programar \"DEF/PDEF símbolo" .

