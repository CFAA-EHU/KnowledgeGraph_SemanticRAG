@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:FaltaConsultaNOT a ns1:Alarma ;
    rdfs:label "Falta la consulta del comando NOT" ;
    ns1:identificador 8716 ;
    ns1:textoExtracto "CAUSA Falta la consulta del comando NOT. SOLUCIÓN Programar \"NOT consulta\" 8716 'Falta paréntesis de cierre' DETECCIÓN Durante la edición." .

ns1:FaltaParentesisCierre a ns1:Alarma ;
    rdfs:label "Falta paréntesis de cierre" ;
    ns1:identificador 8717 ;
    ns1:textoExtracto "CAUSA Hay un paréntesis de apertura pero falta el paréntesis de cierre. SOLUCIÓN Programar \"(consulta)\" 8717 'Falta paréntesis de apertura'" .

ns1:FaltaSegundaConsultaXOR a ns1:Alarma ;
    rdfs:label "Falta la segunda consulta del comando XOR" ;
    ns1:identificador 8715 ;
    ns1:textoExtracto "CAUSA Falta la segunda consulta del comando XOR. SOLUCIÓN Programar \"consulta XOR consulta\" 8715 'Falta operando de la consulta NOT' DETECCIÓN Durante la edición." .

