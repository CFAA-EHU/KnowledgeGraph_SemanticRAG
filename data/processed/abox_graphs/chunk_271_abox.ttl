@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LlaveHardware a ns1:ComponenteElectrico ;
    rdfs:label "Llave hardware" ;
    ns1:habilitadoPor ns1:LicenciaLocal,
        ns1:LicenciaRed ;
    ns1:textoExtracto "La llave hardware suministrada por Fagor deberá estar conectada al puerto USB del PC (si eligió la opción de licencia local) o a un servidor (si eligió la opción de licencia de red)." .

ns1:ModoSimulador a ns1:ModoOperacion ;
    rdfs:label "Modo simulador" ;
    ns1:textoExtracto "su funcionamiento queda restringido a modo simulador y no se podrá conectar a ningún tipo de máquina." .

ns1:SoftwareCNC8070 a ns1:Sistema ;
    rdfs:label "Software CNC 8070" ;
    ns1:identificador "CNC8070" ;
    ns1:textoExtracto "El CNC se puede instalar en un PC, el cual se utilizará como simulador para aprendizaje. El CNC instalado en un PC mantiene todas las prestaciones y funcionalidades; sin embargo, su funcionamiento queda restringido a modo simulador y no se podrá conectar a ningún tipo de máquina. Tanto en un CNC como en un PC (simulador), los archivos necesarios para el funcionamiento del CNC se encuentran en la carpeta C:\\CNC8070 y sus correspondientes subcarpetas." ;
    ns1:tieneComponente ns1:CarpetaMTB .

ns1:SoftwareServidorLlave a ns1:Sistema ;
    rdfs:label "Software de servidor para llave hardware" ;
    ns1:textoExtracto "El servidor no necesita tener instalado el software del CNC, sin embargo sí necesita tener instalado el software que habilite la llave hardware." .

ns1:CarpetaMTB a ns1:InterfazUsuario ;
    rdfs:label "Carpeta MTB" ;
    ns1:identificador "MTB" ;
    ns1:textoExtracto "Personalización del CNC; la carpeta MTB. Tanto en un CNC como en un PC (simulador), el fabricante dispone de la carpeta ..\\MTB para que pueda guardar las modificaciones que realiza en el CNC, como por ejemplo, el programa PLC, los parámetros máquina, etc." .

ns1:LicenciaLocal a ns1:Parametro ;
    rdfs:label "Licencia local (LOCAL)" ;
    ns1:identificador "LOCAL" ;
    ns1:textoExtracto "Elija licencia local si la llave hardware va a estar conectada al PC en el que se está instalando el software del CNC." .

ns1:LicenciaRed a ns1:Parametro ;
    rdfs:label "Licencia de red (NET)" ;
    ns1:identificador "NET" ;
    ns1:textoExtracto "Elija licencia de red si la llave hardware va a estar conectada a un servidor." .

