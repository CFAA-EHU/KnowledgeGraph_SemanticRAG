@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_8724 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta operador y segundo operando del CPS" ;
    ns1:identificador "8724" ;
    ns1:solucionaFallo ns1:ComandoCPS ;
    ns1:textoExtracto "8724 'Falta operador y segundo operando del CPS' DETECCIÓN Durante la edición. CAUSA Falta el operador y el segundo recurso del comando CPS." .

ns1:DiagnosticoFallo_8725 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta primer operando del CPS" ;
    ns1:identificador "8725" ;
    ns1:solucionaFallo ns1:InterfazUsuario_ComandoCPS ;
    ns1:textoExtracto "8725 'Falta primer operando del CPS' DETECCIÓN Durante la edición. CAUSA Falta el primer" .

ns1:ComandoCPS a ns1:InterfazUsuario ;
    rdfs:label "Comando CPS" ;
    ns1:textoExtracto "Programar 'CPS recurso operación recurso'. Los recursos podrán ser un registro, un símbolo o un número. La operación podrá ser uno de los comandos GT, GE, EQ, NE, LE, LT." .

ns1:InterfazUsuario_ComandoCPS a ns1:InterfazUsuario ;
    rdfs:label "Comando CPS" ;
    ns1:textoExtracto "Programar 'CPS recurso operación recurso'. Los recursos podrán ser un registro, un símbolo o un número. La operación podrá ser uno de los comandos GT, GE, EQ, NE, LE, LT." .

