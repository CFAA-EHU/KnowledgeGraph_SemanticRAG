@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Comando_TG a ns1:Parametro ;
    rdfs:label "Comando TG (temporizador)" ;
    ns1:textoExtracto "comando TG... Programar 'TG temporizador preselección'... El valor de preselección podrá ser un registro, un símbolo o un número." .

ns1:FaltaIndiceTemporizadorPreseleccion_TG_8731 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta índice de temporizador y preselección en TG (8731)" ;
    ns1:identificador "8731" ;
    ns1:textoExtracto "'Falta índice de temporizador y preselección en TG' DETECCIÓN Durante la edición. CAUSA Falta el temporizador y el valor de preselección en el comando TG. SOLUCIÓN Programar 'TG temporizador preselección'. El valor de preselección podrá ser un registro, un símbolo o un número." .

ns1:FaltaPreseleccion_TG_8730 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta preselección en TG (8730)" ;
    ns1:identificador "8730" ;
    ns1:textoExtracto "'Falta preselección en TG' DETECCIÓN Durante la edición. CAUSA Falta el valor de preselección en el comando TG. SOLUCIÓN Programar 'TG temporizador preselección'. El valor de preselección podrá ser un registro, un símbolo o un número." .

ns1:OrdenOperandosInvertidos_TG_8732 a ns1:DiagnosticoFallo ;
    rdfs:label "Orden de operandos invertidos en TG (8732)" ;
    ns1:identificador "8732" ;
    ns1:textoExtracto "'Orden de operandos invertidos en TG' DETECCIÓN Durante la edición. CAUSA Programación incorrecta del" .

ns1:Parametro_Preseleccion a ns1:Parametro ;
    rdfs:label "Valor de preselección en comando TG" ;
    ns1:textoExtracto "valor de preselección en el comando TG... El valor de preselección podrá ser un registro, un símbolo o un número." .

ns1:Parametro_Temporizador a ns1:Parametro ;
    rdfs:label "Temporizador en comando TG" ;
    ns1:textoExtracto "Falta el temporizador... en el comando TG... Programar 'TG temporizador preselección'." .

