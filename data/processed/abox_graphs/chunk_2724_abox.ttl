@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error8732 a ns1:DiagnosticoFallo ;
    rdfs:label "Orden de operandos invertidos en TG"@es ;
    ns1:identificador "8732" ;
    ns1:textoExtracto "8732 'Orden de operandos invertidos en TG' DETECCIÓN Durante la edición. CAUSA Programación incorrecta del comando TG. SOLUCIÓN Programar \"TG temporizador preselección\"."@es .

ns1:Error8733 a ns1:DiagnosticoFallo ;
    rdfs:label "Se esperaba instrucción de acción tras NOT"@es ;
    ns1:identificador "8733" ;
    ns1:textoExtracto "8733 'Se esperaba instrucción de acción tras NOT' DETECCIÓN Durante la edición. CAUSA Falta instrucción tras NOT. SOLUCIÓN Programar \"NOT instrucción\"."@es .

ns1:Error8734 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta índice de contador en CUP"@es ;
    ns1:identificador "8734" ;
    ns1:textoExtracto "8734 'Falta índice de contador en CUP' DETECCIÓN Durante la edición. CAUSA Falta el contador en el comando CUP. SOLUCIÓN Programar \"CUP contador\"."@es .

ns1:Error8735 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta índice de contador en CDW"@es ;
    ns1:identificador "8735" ;
    ns1:textoExtracto "8735 'Falta índice de contador en CDW' DETECCIÓN Durante la edición. CAUSA Falta el contador en el comando CDW. SOLUCIÓN Programar \"CDW contador\"."@es .

ns1:Error8736 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta índice de contador en CEN"@es ;
    ns1:identificador "8736" ;
    ns1:textoExtracto "8736 'Falta índice de contador en CEN' DETECCIÓN Durante la edición. CAUSA Falta el contador en el comando CEN. SOLUCIÓN Programar \"CEN contador\"."@es .

ns1:Error8737 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta preselección en CPR"@es ;
    ns1:identificador "8737" ;
    ns1:textoExtracto "8737 'Falta preselección en CPR' DETECCIÓN Durante la edición. CAUSA Falta el valor de preselección en el comando CPR. SOLUCIÓN Programar \"CPR contador preselección\". El valor de preselección podrá ser un registro, un símbolo o un número."@es .

ns1:Error8738 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta índice de contador y preselección en CPR"@es ;
    ns1:identificador "8738" ;
    ns1:textoExtracto "8738 'Falta índice de contador y preselección en CPR' DETECCIÓN Durante la edición. CAUSA Falta el contador y el valor de preselección en el comando CPR. SOLUCIÓN Programar \"CPR contador preselección\". El valor de preselección podrá ser un registro, un símbolo o un número."@es .

ns1:Error8739 a ns1:DiagnosticoFallo ;
    rdfs:label "Orden de operandos invertidos en CPR"@es ;
    ns1:identificador "8739" ;
    ns1:textoExtracto "8739 'Orden de operandos invertidos en CPR' DETECCIÓN Durante la edición. CAUSA Programación incorrecta del comando CPR. SOLUCIÓN Programar \"CPR contador preselección\". El valor de preselección podrá ser un registro, un símbolo o un número."@es .

ns1:ParametroContador a ns1:Parametro ;
    rdfs:label "Índice de contador"@es ;
    ns1:textoExtracto "Falta el contador en el comando"@es .

ns1:ParametroPreseleccion a ns1:Parametro ;
    rdfs:label "Valor de preselección"@es ;
    ns1:textoExtracto "El valor de preselección podrá ser un registro, un símbolo o un número."@es ;
    ns1:valor "registro/símbolo/número"@es .

