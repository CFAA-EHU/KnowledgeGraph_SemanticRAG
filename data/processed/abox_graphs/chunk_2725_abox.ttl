    ns1:identificador "8741" ;
    ns1:textoExtracto "'Falta operando en RES' DETECCIÓN Durante la edición. CAUSA Falta el recurso en el comando RES. SOLUCIÓN Programar \"RES recurso\"."@es .

ns1:DiagnosticoFallo_8742 a ns1:DiagnosticoFallo ;
