@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_8739 a ns1:DiagnosticoFallo ;
    rdfs:label "Orden de operandos invertidos en CPR"@es ;
    ns1:identificador "8739" ;
    ns1:textoExtracto "'Orden de operandos invertidos en CPR' DETECCIÓN Durante la edición. CAUSA Programación incorrecta del comando CPR. SOLUCIÓN Programar \"CPR contador preselección\". El valor de preselección podrá ser un registro, un símbolo o un número."@es .

ns1:DiagnosticoFallo_8740 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta operando en SET"@es ;
    ns1:identificador "8740" ;
    ns1:textoExtracto "'Falta operando en SET' DETECCIÓN Durante la edición. CAUSA Falta el recurso en el comando SET. SOLUCIÓN Programar \"SET recurso\"."@es .

ns1:DiagnosticoFallo_8741 a ns1:DiagnosticoFallo ;
