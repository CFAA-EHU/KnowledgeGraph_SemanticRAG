@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error8741 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8741: Falta operando en RES" ;
    ns1:documentadoEn ns1:ComandoRES ;
    ns1:identificador "8741" ;
    ns1:textoExtracto """
    "SET recurso". 8741 'Falta operando en RES'
    DETECCIÓN Durante la edición.
    CAUSA Falta el recurso en el comando RES.
    SOLUCIÓN Programar "RES recurso".
    """ .

ns1:Error8742 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8742: Falta operando en CPL" ;
    ns1:documentadoEn ns1:ComandoCPL ;
    ns1:identificador "8742" ;
    ns1:textoExtracto """
    8742 'Falta operando en CPL'
    DETECCIÓN Durante la edición.
    CAUSA Falta el recurso en el comando CPL.
    SOLUCIÓN Programar "CPL recurso".
    """ .

ns1:Error8743 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8743: Falta nombre de subrutina tras CAL" ;
    ns1:documentadoEn ns1:ComandoCAL ;
    ns1:identificador "8743" ;
    ns1:textoExtracto """
    8743 Falta nombre de subrutina tras CAL.
    DETECCIÓN Durante la edición del programa PLC.
    CAUSA Falta la subrutina en el comando CAL.
    SOLUCIÓN Programar "CAL subrutina".
    """ .

ns1:Error8744 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8744: Falta etiqueta de salto tras JMP" ;
    ns1:documentadoEn ns1:ComandoJMP ;
    ns1:identificador "8744" ;
    ns1:textoExtracto """
    8744 Falta etiqueta de salto tras JMP.
    DETECCIÓN Durante la edición del programa PLC.
    CAUSA Falta la etiqueta en el comando JMP.
    SOLUCIÓN Programar "JMP etiqueta".
    """ .

ns1:Error8745 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8745: Código MOV no válido" ;
    ns1:documentadoEn ns1:ComandoMOV ;
    ns1:identificador "8745" ;
    ns1:textoExtracto """
    8745 Código MOV no válido.
    DETECCIÓN Durante la edición del programa PLC.
    CAUSA El código de origen o destino en el comando MOV no es válido.
    SOLUCIÓN Los códigos de origen y destino indican el formato de la información (binario o BCD). Los códigos podrán ser 0 (binario) o 1 (BCD).
    """ .

ns1:Error8746 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8746: Fallo del parser al buscar el número de bits a transmitir en el MOV" ;
    ns1:documentadoEn ns1:ComandoMOV ;
    ns1:identificador "8746" ;
    ns1:textoExtracto """
    8746 Fallo del parser al buscar el número de bits a transmitir en el MOV.
    DETECCIÓN Durante la ejecución del programa PLC.
    CAUSA Falta programar el número de bits en el comando MOV.
    SOLUCIÓN El rango de bits a transmitir es 4, 8, 12, 16, 20, 24, 28 y 32.
    """ .

ns1:Error8747 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8747: Solapamiento de origen y destino en el MOV" ;
    ns1:documentadoEn ns1:ComandoMOV ;
    ns1:identificador "8747" ;
    ns1:textoExtracto """
    8747 Hay solapamiento de origen y destino en el MOV.
    DETECCIÓN Durante la edición del programa PLC.
    CAUSA Algunos bits a mover comparten origen y destino.
    SOLUCIÓN Los datos de origen y destino no deben solaparse. Disminuir el número de bits a mover o seleccionar un destino diferente.
    """ .

ns1:Error8748 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8748: Falta origen o destino en el MOV" ;
    ns1:documentadoEn ns1:ComandoMOV ;
    ns1:identificador "8748" ;
    ns1:textoExtracto """
    8748 Falta origen o destino en el MOV.
    DETECCIÓN Durante la edición del programa PLC.
    CAUSA Falta la etiqueta en el comando JMP.
    SOLUCIÓN Programar "JMP etiqueta".
    """ .

ns1:Error8749 a ns1:AvisoSeguridad ;
    rdfs:label "Error 8749: Falta origen y destino en el MOV" ;
    ns1:documentadoEn ns1:ComandoMOV ;
    ns1:identificador "8749" ;
    ns1:textoExtracto """
    8749 Falta origen y destino en el MOV.
    DETECCIÓN Durante la edición del programa PLC.
    """ .

ns1:ComandoCAL a ns1:InterfazUsuario ;
    rdfs:label "Comando CAL" ;
    ns1:textoExtracto "Falta la subrutina en el comando CAL. SOLUCIÓN Programar \"CAL subrutina\"." .

ns1:ComandoCPL a ns1:InterfazUsuario ;
    rdfs:label "Comando CPL" ;
    ns1:textoExtracto "Falta el recurso en el comando CPL. SOLUCIÓN Programar \"CPL recurso\"." .

ns1:ComandoJMP a ns1:InterfazUsuario ;
    rdfs:label "Comando JMP" ;
    ns1:textoExtracto "Falta la etiqueta en el comando JMP. SOLUCIÓN Programar \"JMP etiqueta\"." .

ns1:ComandoRES a ns1:InterfazUsuario ;
    rdfs:label "Comando RES" ;
    ns1:textoExtracto "Falta el recurso en el comando RES. SOLUCIÓN Programar \"RES recurso\"." .

ns1:ComandoMOV a ns1:InterfazUsuario ;
    rdfs:label "Comando MOV" ;
    ns1:textoExtracto """
    El código de origen o destino en el comando MOV no es válido.
    Los códigos de origen y destino indican el formato de la información (binario o BCD). Los códigos podrán ser 0 (binario) o 1 (BCD).
    El rango de bits a transmitir es 4, 8, 12, 16, 20, 24, 28 y 32.
    """ .

