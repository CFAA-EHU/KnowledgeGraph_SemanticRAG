@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazProgramacionPLC a ns1:InterfazUsuario ;
    ns1:activaAlarma ns1:Fallo_8748,
        ns1:Fallo_8749,
        ns1:Fallo_8750 ;
    ns1:textoExtracto "edición del programa PLC"@es .

ns1:Fallo_8748 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta origen o destino en el MOV"@es ;
    ns1:identificador "8748" ;
    ns1:textoExtracto "Falta origen o destino en el MOV. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta la etiqueta en el comando JMP. SOLUCIÓN Programar \"JMP etiqueta\"."@es .

ns1:Fallo_8749 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta origen y destino en el MOV"@es ;
    ns1:identificador "8749" ;
    ns1:textoExtracto "Falta origen y destino en el MOV. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta la etiqueta en el comando JMP. SOLUCIÓN Programar \"JMP etiqueta\"."@es .

ns1:Fallo_8750 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta un argumento en la operación ADS"@es ;
    ns1:identificador "8750" ;
    ns1:textoExtracto "Falta un argumento en la operación ADS. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta un argumento en la operación ADS. SOLUCIÓN Programar \"ADS operando operando resultado\"."@es .

