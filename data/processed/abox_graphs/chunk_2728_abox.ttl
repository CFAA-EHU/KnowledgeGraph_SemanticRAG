ns1:FalloProgramacion_8751 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta un argumento en operación ADS" ;
    ns1:identificador "8751" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA Falta un argumento en la operación ADS. SOLUCIÓN Programar \"ADS operando operando resultado\"." .

