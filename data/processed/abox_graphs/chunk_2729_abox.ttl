@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_DVS_8759 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 8759: Argumento faltante en operación DVS" ;
    ns1:identificador "8759" ;
    ns1:textoExtracto "Falta un argumento en la operación DVS. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta un argumento en la operación DVS. SOLUCIÓN Programar 'DVS operando operando resultado'." .

ns1:Fallo_MLS_8758 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 8758: Argumentos faltantes en operación MLS" ;
    ns1:identificador "8758" ;
    ns1:textoExtracto "Faltan todos los argumentos en la operación MLS. DETECCIÓN Durante la edición del programa PLC. CAUSA Faltan todos los argumentos en la operación MLS. SOLUCIÓN Programar 'MLS operando operando resultado'." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC (programación)" ;
    ns1:textoExtracto "edición del programa PLC" .

