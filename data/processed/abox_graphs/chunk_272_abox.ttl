@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CarpetaCONFIGURATION a ns1:Componente ;
    rdfs:label "Carpeta CONFIGURATION" ;
    ns1:textoExtracto "desde ..\\CONFIGURATION a CNC8070..." ;
    ns1:tieneComponente ns1:SistemaCNC8070 .

ns1:CarpetaMTB a ns1:Componente ;
    rdfs:label "Carpeta MTB" ;
    ns1:textoExtracto "el sistema moverá la carpeta correspondiente desde ..\\CONFIGURATION a CNC8070 y la renombrará como MTB" ;
    ns1:tieneComponente ns1:SistemaCNC8070 .

ns1:CodigoValidacion a ns1:Parametro ;
    rdfs:label "Código de validación" ;
    ns1:monitoreaParametro ns1:SistemaCNC8070 ;
    ns1:textoExtracto "en función del código de validación, el sistema moverá la carpeta..." .

ns1:ParametrosMaquina a ns1:Parametro ;
    rdfs:label "Parámetros máquina" ;
    ns1:monitoreaParametro ns1:SistemaCNC8070 ;
    ns1:textoExtracto "por ejemplo, el programa PLC, los parámetros máquina, etc." .

ns1:ProgramaPLC a ns1:InterfazUsuario ;
    rdfs:label "Programa PLC" ;
    ns1:documentadoEn ns1:SistemaCNC8070 ;
    ns1:textoExtracto "por ejemplo, el programa PLC, los parámetros máquina, etc." .

ns1:SistemaCNC8070 a ns1:Sistema ;
    rdfs:label "Sistema CNC8070" ;
    ns1:identificador "CNC8070" ;
    ns1:textoExtracto "el CNC gestiona las carpetas MTB... el sistema moverá la carpeta correspondiente desde ..\\CONFIGURATION a CNC8070..." .

