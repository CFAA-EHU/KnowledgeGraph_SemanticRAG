@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error8760 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8760: Faltan dos argumentos en operación DVS"@es ;
    ns1:identificador "8760" ;
    ns1:solucionaFallo ns1:OperacionDVS ;
    ns1:textoExtracto "8760 Faltan dos argumentos en la operación DVS. DETECCIÓN Durante la edición del programa PLC. CAUSA Faltan dos argumentos en la operación DVS. SOLUCIÓN Programar \"DVS operando operando resultado\"."@es .

ns1:Error8761 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8761: Faltan todos los argumentos en operación DVS"@es ;
    ns1:identificador "8761" ;
    ns1:solucionaFallo ns1:OperacionDVS ;
    ns1:textoExtracto "8761 Faltan todos los argumentos la en operación DVS. DETECCIÓN Durante la edición del programa PLC. CAUSA Faltan todos los argumentos en la operación DVS. SOLUCIÓN Programar \"DVS operando operando resultado\"."@es .

ns1:Error8762 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8762: Falta un argumento en operación MDS"@es ;
    ns1:identificador "8762" ;
    ns1:solucionaFallo ns1:OperacionMDS ;
    ns1:textoExtracto "8762 Falta un argumento en la operación MDS. DETECCIÓN Durante la edición del programa PLC. CAUSA Faltan un argumento en la operación MDS. SOLUCIÓN Programar \"MDS operando operando resultado\"."@es .

ns1:Error8763 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8763: Faltan dos argumentos en operación MDS"@es ;
    ns1:identificador "8763" ;
    ns1:solucionaFallo ns1:OperacionMDS ;
    ns1:textoExtracto "8763 Faltan dos argumentos en la operación MDS. DETECCIÓN Durante la edición del programa PLC. CAUSA Faltan dos argumentos en la operación MDS. SOLUCIÓN Programar \"MDS operando operando resultado\"."@es .

ns1:Error8764 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8764: Faltan todos los argumentos en operación MDS"@es ;
    ns1:identificador "8764" ;
    ns1:solucionaFallo ns1:OperacionMDS ;
    ns1:textoExtracto "8764 Faltan todos los argumentos en la operación MDS. DETECCIÓN Durante la edición del programa PLC. CAUSA Faltan todos los argumentos en la operación MDS. SOLUCIÓN Programar \"MDS operando operando resultado\"."@es .

ns1:Error8765 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8765: Falta registro en NGU"@es ;
    ns1:identificador "8765" ;
    ns1:solucionaFallo ns1:RegistroNGU ;
    ns1:textoExtracto "8765 Falta registro en NGU. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta registro en NGU. SOLUCIÓN Programar \"NGU registro\"."@es .

ns1:Error8766 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8766: Falta registro en NGS"@es ;
    ns1:identificador "8766" ;
    ns1:solucionaFallo ns1:RegistroNGS ;
    ns1:textoExtracto "8766 Falta registro en NGS. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta registro en NGU. SOLUCIÓN Programar \"NGU registro\"."@es .

ns1:Error8767 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8767: Falta un argumento en instrucción AND"@es ;
    ns1:identificador "8767" ;
    ns1:solucionaFallo ns1:InstruccionAND ;
    ns1:textoExtracto "8767 Falta un argumento en la instrucción de acción AND. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta un argumento en la operación AND. SOLUCIÓN Programar \"AND operando operando resultado\"."@es .

ns1:Error8768 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8768: Faltan dos argumentos en instrucción AND"@es ;
    ns1:identificador "8768" ;
    ns1:textoExtracto "8768 Faltan dos argumentos en la instrucción de acción AND. DETECCIÓN Durante la edición del programa PLC."@es .

ns1:ProgramaPLC a ns1:Sistema ;
    rdfs:label "Programa PLC"@es ;
    ns1:textoExtracto "edición del programa PLC"@es ;
    ns1:tieneComponente ns1:InstruccionAND,
        ns1:OperacionDVS,
        ns1:OperacionMDS,
        ns1:RegistroNGS,
        ns1:RegistroNGU .

ns1:InstruccionAND a ns1:Parametro ;
    rdfs:label "Instrucción AND (operación lógica)"@es ;
    ns1:textoExtracto "instrucción de acción AND"@es ;
    ns1:valor "AND operando operando resultado" .

ns1:RegistroNGS a ns1:Parametro ;
    rdfs:label "Registro NGS"@es ;
    ns1:textoExtracto "registro en NGS"@es .

ns1:RegistroNGU a ns1:Parametro ;
    rdfs:label "Registro NGU"@es ;
    ns1:textoExtracto "registro en NGU"@es ;
    ns1:valor "NGU registro" .

ns1:OperacionDVS a ns1:Parametro ;
    rdfs:label "Operación DVS (división)"@es ;
    ns1:textoExtracto "operación DVS"@es ;
    ns1:valor "DVS operando operando resultado" .

ns1:OperacionMDS a ns1:Parametro ;
    rdfs:label "Operación MDS (multiplicación/división)"@es ;
    ns1:textoExtracto "operación MDS"@es ;
    ns1:valor "MDS operando operando resultado" .

