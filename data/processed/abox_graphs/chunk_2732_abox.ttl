ns1:Fallo_8769 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta de argumentos en instrucción AND" ;
    ns1:identificador "8769" ;
    ns1:textoExtracto "Faltan todos argumentos en la instrucción de acción AND. DETECCIÓN Durante la edición del programa PLC. CAUSA Faltan todos los argumentos en la operación AND. SOLUCIÓN Programar \"AND operando operando resultado\"." .

