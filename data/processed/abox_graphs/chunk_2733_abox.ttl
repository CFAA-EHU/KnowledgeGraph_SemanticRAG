@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TareaMantenimiento_EdicionPLC a ns1:TareaMantenimiento ;
    rdfs:label "Edición de programa PLC (corrección RR1)" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_8777,
        ns1:DiagnosticoFallo_8778 ;
    ns1:textoExtracto "Edición del programa PLC para corregir argumentos en operación RR1." .

ns1:DiagnosticoFallo_8777 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 8777: Argumentos faltantes en operación RR1" ;
    ns1:identificador "8777" ;
    ns1:textoExtracto "Faltan dos argumentos en la operación RR1. DETECCIÓN Durante la edición del programa PLC. SOLUCIÓN Programar 'RR1 origen rotaciones destino'." .

ns1:DiagnosticoFallo_8778 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 8778: Todos los argumentos faltantes en operación RR1" ;
    ns1:identificador "8778" ;
    ns1:textoExtracto "Faltan todos los argumentos en la operación RR1. DETECCIÓN Durante la edición del programa PLC." .

