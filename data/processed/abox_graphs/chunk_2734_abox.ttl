ns1:Fallo_8777 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en operación RR1 (faltan dos argumentos)"@es ;
    ns1:identificador "8777" ;
    ns1:textoExtracto "Detección: Durante la edición del programa PLC. CAUSA: Faltan dos argumentos en la operación RR1. SOLUCIÓN: Programar \"RR1 origen rotaciones destino\"."@es .

