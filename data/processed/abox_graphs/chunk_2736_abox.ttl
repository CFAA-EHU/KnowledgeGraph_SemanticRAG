@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8787 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8787: Faltan todos los argumentos en la operación RL2" ;
    ns1:identificador "8787" ;
    ns1:textoExtracto "8787 Faltan todos argumentos en la operación RL2. DETECCIÓN Durante la edición del programa PLC. CAUSA Faltan todos los argumentos en la operación RL2. SOLUCIÓN Programar 'RL2 origen rotaciones destino'." .

ns1:Error_8788 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8788: Índice final menor que inicial en ERA" ;
    ns1:identificador "8788" ;
    ns1:textoExtracto "8788 Índice final menor que inicial en ERA. DETECCIÓN Durante la edición del programa PLC. CAUSA En la instrucción ERA, el segundo argumento es menor que el primero. SOLUCIÓN Programar 'ERA recurso índice'. El índice debe ser mayor que el recurso." .

ns1:Error_8789 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8789: Índice final fuera de rango en ERA" ;
    ns1:documentadoEn ns1:RangosRecursosPLC ;
    ns1:identificador "8789" ;
    ns1:textoExtracto "8789 Índice final fuera de rango en ERA. DETECCIÓN Durante la edición del programa PLC. CAUSA El segundo indice no es un recurso válido. SOLUCIÓN El rango válido para cada recurso es el siguiente. • Entradas (I1-I1024). • Salidas (O1-O1024). • Entradas locales (LI1-LI16). • Salidas locales (LO1-LO8). • Marcas (M1-M8192). • Mensajes (MSG1-MSG1024). • Errores (ERR1-ERR1024). • Relojes (CLK). • Registros (R1-R1024). • Estado de los temporizadores (T1-T512). • Estado de los contadores (C1-C256)." .

ns1:Error_8790 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8790: Falta índice final en ERA" ;
    ns1:identificador "8790" ;
    ns1:textoExtracto "8790 Falta índice final en ERA. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta el índice en la instrucción ERA. SOLUCIÓN Programar 'ERA recurso índice'." .

ns1:Error_8791 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8791: Falta recurso inicial e índice final en ERA" ;
    ns1:identificador "8791" ;
    ns1:textoExtracto "8791 Falta recurso inicial e índice final en ERA. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta el recurso en la instrucción ERA. SOLUCIÓN Programar 'ERA recurso índice'." .

ns1:Error_8792 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8792: Falta destino en PAR" ;
    ns1:identificador "8792" ;
    ns1:textoExtracto "8792 Falta destino en PAR. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta destino en PAR. SOLUCIÓN Programar 'PAR recurso recurso'." .

ns1:Error_8793 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8793: Falta origen y destino en PAR" ;
    ns1:identificador "8793" ;
    ns1:textoExtracto "8793 Falta origen y destino en PAR. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta origen y destino en PAR." .

ns1:Instruccion_ERA a ns1:Parametro ;
    rdfs:label "Instrucción ERA" ;
    ns1:textoExtracto "Programar 'ERA recurso índice'. El índice debe ser mayor que el recurso." ;
    ns1:valor "ERA recurso índice" .

ns1:Instruccion_PAR a ns1:Parametro ;
    rdfs:label "Instrucción PAR" ;
    ns1:textoExtracto "Programar 'PAR recurso recurso'." ;
    ns1:valor "PAR recurso recurso" .

ns1:Instruccion_RL2 a ns1:Parametro ;
    rdfs:label "Instrucción RL2" ;
    ns1:textoExtracto "Programar 'RL2 origen rotaciones destino'." ;
    ns1:valor "RL2 origen rotaciones destino" .

ns1:RangosRecursosPLC a ns1:Tabla ;
    rdfs:label "Rangos válidos para recursos PLC" ;
    ns1:textoExtracto "El rango válido para cada recurso es el siguiente. • Entradas (I1-I1024). • Salidas (O1-O1024). • Entradas locales (LI1-LI16). • Salidas locales (LO1-LO8). • Marcas (M1-M8192). • Mensajes (MSG1-MSG1024). • Errores (ERR1-ERR1024). • Relojes (CLK). • Registros (R1-R1024). • Estado de los temporizadores (T1-T512). • Estado de los contadores (C1-C256)." .

