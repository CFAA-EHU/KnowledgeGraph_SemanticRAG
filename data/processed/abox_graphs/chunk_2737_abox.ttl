@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8792 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta destino en PAR" ;
    ns1:identificador "8792" ;
    ns1:textoExtracto "Falta destino en PAR. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta destino en PAR. SOLUCIÓN Programar \"PAR recurso recurso\"." .

ns1:Error_8793 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta origen y destino en PAR" ;
    ns1:identificador "8793" ;
    ns1:textoExtracto "Falta origen y destino en PAR. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta origen y destino en PAR. SOLUCIÓN Programar \"PAR recurso recurso\"." .

ns1:Error_8794 a ns1:DiagnosticoFallo ;
    rdfs:label "Cadena de error vacía" ;
    ns1:identificador "8794" ;
    ns1:textoExtracto "Cadena de error vacía. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Hay definido un error sin texto. SOLUCIÓN Definir el texto de error." .

ns1:Error_8795 a ns1:DiagnosticoFallo ;
    rdfs:label "Error sintáctico. No se esperaba %" ;
    ns1:identificador "8795" ;
    ns1:textoExtracto "Error sintáctico. No se esperaba %. DETECCIÓN Durante la edición del programa PLC. CAUSA La instrucción programada no admite el" .

