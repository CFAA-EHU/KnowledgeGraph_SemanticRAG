@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Directiva_PE a ns1:Parametro ;
    rdfs:label "Directiva de período (PE)"@es ;
    ns1:identificador "PE" ;
    ns1:textoExtracto "En la directiva \"PE\" se ha programado un periodo menor o igual que cero."@es ;
    ns1:valor "> 0"^^xsd:string .

ns1:Error_8795 a ns1:DiagnosticoFallo ;
    rdfs:label "Error sintáctico. No se esperaba %"@es ;
    ns1:identificador "8795" ;
    ns1:textoExtracto "8795 Error sintáctico. No se esperaba %. DETECCIÓN Durante la edición del programa PLC. CAUSA La instrucción programada no admite el argumento indicado. SOLUCIÓN Corregir la sintaxis de la línea."@es .

ns1:Error_8796 a ns1:DiagnosticoFallo ;
    rdfs:label "Cadena de warning vacía"@es ;
    ns1:identificador "8796" ;
    ns1:textoExtracto "8796 Cadena de warning vacía. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Hay definido un warning sin texto. SOLUCIÓN Definir el texto de warning."@es .

ns1:Error_8797 a ns1:DiagnosticoFallo ;
    rdfs:label "El segundo argumento debe ser un índice en ERA"@es ;
    ns1:identificador "8797" ;
    ns1:textoExtracto "8797 El segundo argumento debe ser un índice en ERA. DETECCIÓN Durante la edición del programa PLC. CAUSA El segundo argumento debe ser un número. SOLUCIÓN El segundo argumento debe ser un número; no hay que programar el tipo de recurso."@es .

ns1:Error_8798 a ns1:DiagnosticoFallo ;
    rdfs:label "El período debe ser mayor que cero"@es ;
    ns1:identificador "8798" ;
    ns1:textoExtracto "8798 El período debe ser mayor que cero. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA En la directiva \"PE\" se ha programado un periodo menor o igual que cero. SOLUCIÓN Programar en la directiva \"PE\" un valor mayor que cero."@es .

