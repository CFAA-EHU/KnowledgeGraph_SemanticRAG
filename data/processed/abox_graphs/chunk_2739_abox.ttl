@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Comando_CAM a ns1:ComponenteElectrico ;
    rdfs:label "CAM" ;
    ns1:textoExtracto "Se ha programado el comando CAM o FOLLOWOFF sin indicar el eje esclavo." .

ns1:Comando_FOLLOWOFF a ns1:ComponenteElectrico ;
    rdfs:label "FOLLOWOFF" ;
    ns1:textoExtracto "Se ha programado el comando CAM o FOLLOWOFF sin indicar el eje esclavo." .

ns1:Directiva_CAL a ns1:Directiva ;
    ns1:identificador "CAL" ;
    ns1:textoExtracto "En la directiva \"DEF/PDEF/CAL/SUB/EXTERN\" se ha programado un símbolo cuya longitud supera el máximo permitido." .

ns1:Directiva_DEF a ns1:Directiva ;
    ns1:identificador "DEF" ;
    ns1:textoExtracto "En las directivas \"DEF/PDEF\" no se ha programado el símbolo del recurso." .

ns1:Directiva_EXTERN a ns1:Directiva ;
    ns1:identificador "EXTERN" ;
    ns1:textoExtracto "En la directiva \"DEF/PDEF/CAL/SUB/EXTERN\" se ha programado un símbolo cuya longitud supera el máximo permitido." .

ns1:Directiva_PDEF a ns1:Directiva ;
    ns1:identificador "PDEF" ;
    ns1:textoExtracto "En las directivas \"DEF/PDEF\" no se ha programado el símbolo del recurso." .

ns1:Directiva_PE a ns1:Directiva ;
    ns1:identificador "PE" ;
    ns1:textoExtracto "Programar en la directiva \"PE\" un valor mayor que cero." .

ns1:Directiva_SUB a ns1:Directiva ;
    ns1:identificador "SUB" ;
    ns1:textoExtracto "En la directiva \"DEF/PDEF/CAL/SUB/EXTERN\" se ha programado un símbolo cuya longitud supera el máximo permitido." .

ns1:Parametro_longitudMaxima a ns1:Parametro ;
    rdfs:label "longitud máxima de símbolo" ;
    ns1:textoExtracto "La longitud máxima permitida para el símbolo programado en estas directivas es 46 caracteres." ;
    ns1:valor "46" .

