@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC_Fagor a ns1:Sistema ;
    rdfs:label "CNC Fagor" ;
    ns1:textoExtracto "Fagor entrega el CNC con los archivos de ayuda instalados en inglés." ;
    ns1:tieneComponente ns1:ArchivosAyudaCNC_Fagor .

ns1:FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation" ;
    ns1:documentadoEn <http://www.fagorautomation.com/en/downloads/> ;
    ns1:textoExtracto "disponible en la zona de descargas del sitio web corporativo de Fagor Automation." .

ns1:ProgramaSetupHelp_Vxx_xx a ns1:Sistema ;
    rdfs:label "SetupHelp_Vxx.xx.exe" ;
    ns1:controla ns1:ArchivosAyudaCNC_Fagor ;
    ns1:identificador "SetupHelp_Vxx.xx.exe" ;
    ns1:textoExtracto "Se puede cambiar el idioma de la ayuda con el programa SetupHelp_Vxx.xx.exe (donde Vxx_xx es el nombre de la versión), disponible en la zona de descargas del sitio web corporativo de Fagor Automation." .

ns1:ArchivosAyudaCNC_Fagor a ns1:Componente ;
    rdfs:label "Archivos de ayuda del CNC Fagor" ;
    ns1:textoExtracto "Los archivos de ayuda instalados por Fagor se encuentran en la carpeta ..\\Fagor\\Mmc\\Help." .

