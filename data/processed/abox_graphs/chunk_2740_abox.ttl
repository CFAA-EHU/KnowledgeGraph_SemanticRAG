@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_8808 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 8808: Operandos OR iguales" ;
    ns1:identificador "8808" ;
    ns1:textoExtracto "8808 Los operandos de la expresión OR son iguales. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Dos operandos de la expresión \"OR\" iguales." .

ns1:Fallo_8809 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 8809: Operandos AND iguales" ;
    ns1:identificador "8809" ;
    ns1:textoExtracto "8809 Los operandos de la expresión AND son iguales. DETECCIÓN Durante la edición o compilación del programa PLC." .

ns1:ManualInstalacion_PLC a ns1:Manual ;
    ns1:textoExtracto "Revisar en el manual de instalación la sintaxis." .

