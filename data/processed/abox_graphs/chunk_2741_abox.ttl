@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorPLC_8809 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8809: Operandos iguales en expresión AND"@es ;
    ns1:identificador "8809" ;
    ns1:solucionaFallo ns1:ManualInstalacionPLC ;
    ns1:textoExtracto "Los operandos de la expresión AND son iguales. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Dos operandos de la expresión \"AND\" iguales. SOLUCIÓN Revisar en el manual de instalación la sintaxis."@es .

ns1:ErrorPLC_8810 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8810: Operandos iguales en expresión XOR"@es ;
    ns1:identificador "8810" ;
    ns1:solucionaFallo ns1:ManualInstalacionPLC ;
    ns1:textoExtracto "Los operandos de la expresión XOR son iguales. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Dos operandos de la expresión \"XOR\" iguales. SOLUCIÓN Revisar en el manual de instalación la sintaxis."@es .

ns1:ErrorPLC_8811 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8811: Operandos iguales en expresión CPS"@es ;
    ns1:identificador "8811" ;
    ns1:solucionaFallo ns1:ManualInstalacionPLC ;
    ns1:textoExtracto "Los operandos de la expresión CPS son iguales. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Dos operandos de la expresión \"CPS\" iguales. SOLUCIÓN Revisar en el manual de instalación la sintaxis."@es .

ns1:ErrorPLC_8812 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8812: Recursos MOV iguales"@es ;
    ns1:identificador "8812" ;
    ns1:textoExtracto "Los recursos del MOV son iguales. DETECCIÓN Durante la edición del programa PLC. CAUSA Los recursos de origen y destino de la instrucción MOV son iguales. SOLUCIÓN Programar recursos de origen y destino diferentes."@es .

ns1:ErrorPLC_8813 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8813: Registros MOV iguales"@es ;
    ns1:identificador "8813" ;
    ns1:textoExtracto "Los registros del MOV son iguales. DETECCIÓN Durante la edición del programa PLC. CAUSA Los registros de origen y destino de la instrucción MOV son iguales. SOLUCIÓN Programar los registros de origen y destino diferentes."@es .

ns1:ErrorPLC_8814 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8814: Símbolo comienza por dígito"@es ;
    ns1:identificador "8814" ;
    ns1:textoExtracto "Un símbolo no puede comenzar por un dígito. DETECCIÓN Durante la edición del programa PLC. CAUSA El primer carácter del símbolo es un número. SOLUCIÓN Los símbolos deben comenzar por una letra o por el carácter \"/\" seguido de una letra."@es .

ns1:ErrorPLC_8815 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8815: Entrada digital fuera de rango"@es ;
    ns1:identificador "8815" ;
    ns1:textoExtracto "Entrada fuera de rango permitido. DETECCIÓN Durante la edición del programa PLC. CAUSA El número de la entrada digital no es valido. SOLUCIÓN Las entradas digitales deben estar dentro del rango I1 a I1024 y las locales de LI1 a LI16."@es .

ns1:ErrorPLC_8816 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8816: Salida digital fuera de rango"@es ;
    ns1:identificador "8816" ;
    ns1:textoExtracto "Salida fuera de rango permitido. DETECCIÓN Durante la edición del programa PLC. CAUSA El número de la salida digital no es valido."@es .

ns1:ManualInstalacionPLC a ns1:Manual ;
    rdfs:label "Manual de instalación del PLC"@es ;
    ns1:textoExtracto "Revisar en el manual de instalación la sintaxis."@es .

