@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_8816_SalidaFueraRango a ns1:DiagnosticoFallo ;
    rdfs:label "Salida fuera de rango permitido (8816)"@es ;
    ns1:identificador "8816" ;
    ns1:solucionaFallo ns1:RangoSalidasDigitales ;
    ns1:textoExtracto "8816 Salida fuera de rango permitido. [...] SOLUCIÓN Las salidas digitales deben estar dentro del rango O1 a O1024 y las locales de O1 a O8."@es .

ns1:Fallo_8817_LexerEntradas a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer entradas (8817)"@es ;
    ns1:identificador "8817" ;
    ns1:solucionaFallo ns1:RangoEntradasDigitales ;
    ns1:textoExtracto "8817 Fallo del lexer al reconocer entradas."@es .

ns1:RangoEntradasDigitales a ns1:Parametro ;
    rdfs:label "Rango de entradas digitales válidas"@es ;
    ns1:textoExtracto "Las entradas digitales deben estar dentro del rango I1 a I1024 y las locales de LI1 a LI16."@es ;
    ns1:valor "I1-I1024 (globales), LI1-LI16 (locales)" .

ns1:RangoSalidasDigitales a ns1:Parametro ;
    rdfs:label "Rango de salidas digitales válidas"@es ;
    ns1:textoExtracto "Las salidas digitales deben estar dentro del rango O1 a O1024 y las locales de O1 a O8."@es ;
    ns1:valor "O1-O1024 (globales), O1-O8 (locales)" .

