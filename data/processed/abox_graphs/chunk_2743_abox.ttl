@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_8817 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer entradas" ;
    ns1:identificador "8817" ;
    ns1:solucionaFallo ns1:ManualInstalacionPLC ;
    ns1:textoExtracto "DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Error al convertir una cadena de caracteres a entradas. Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:Fallo_8818 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer salidas" ;
    ns1:identificador "8818" ;
    ns1:solucionaFallo ns1:ManualInstalacionPLC ;
    ns1:textoExtracto "DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Error al convertir una cadena de caracteres a salidas. Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:Fallo_8819 a ns1:DiagnosticoFallo ;
    rdfs:label "Bit de registro fuera de rango" ;
    ns1:identificador "8819" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA El bit programado no es válido. SOLUCIÓN Los bits deben estar dentro del rango B0 a B31." .

ns1:Fallo_8820 a ns1:DiagnosticoFallo ;
    rdfs:label "Mensaje fuera de rango" ;
    ns1:identificador "8820" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA El mensaje programado no es válido. SOLUCIÓN Los mensajes deben estar dentro del rango MSG1 a MSG1024." .

ns1:Fallo_8821 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer mensajes" ;
    ns1:identificador "8821" ;
    ns1:solucionaFallo ns1:ManualInstalacionPLC ;
    ns1:textoExtracto "DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Error al convertir una cadena de caracteres a mensajes. Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:Fallo_8822 a ns1:DiagnosticoFallo ;
    rdfs:label "Error fuera de rango" ;
    ns1:identificador "8822" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA El error programado no es válido. SOLUCIÓN Los errores deben estar dentro del rango ERR1 a ERR1024." .

ns1:Fallo_8823 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer errores" ;
    ns1:identificador "8823" ;
    ns1:solucionaFallo ns1:ManualInstalacionPLC ;
    ns1:textoExtracto "DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Error al convertir una cadena de caracteres a errores. Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:Fallo_8824 a ns1:DiagnosticoFallo ;
    rdfs:label "Pantalla fuera de rango" ;
    ns1:identificador "8824" ;
    ns1:textoExtracto "DETECCIÓN Durante la edición del programa PLC. CAUSA La pantalla programada no es válida." .

ns1:Fallo_SalidaDigitalInvalida a ns1:DiagnosticoFallo ;
    rdfs:label "Número de salida digital no válido" ;
    ns1:textoExtracto "CAUSA El número de la salida digital no es válido. SOLUCIÓN Las salidas digitales deben estar dentro del rango O1 a O1024 y las locales de O1 a O8." .

ns1:ManualInstalacionPLC a ns1:Manual ;
    rdfs:label "Manual de instalación del PLC" ;
    ns1:textoExtracto "Revisar en el manual de instalación la sintaxis." .

