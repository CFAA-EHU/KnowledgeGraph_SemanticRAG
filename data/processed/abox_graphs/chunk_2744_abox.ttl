@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error8824 a ns1:DiagnosticoFallo ;
    rdfs:label "Pantalla fuera de rango" ;
    ns1:identificador "8824" ;
    ns1:textoExtracto "8824 Pantalla fuera de rango. DETECCIÓN Durante la edición del programa PLC. CAUSA La pantalla programada no es válida. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:Error8825 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer pantallas" ;
    ns1:identificador "8825" ;
    ns1:textoExtracto "8825 Fallo del lexer al reconocer pantallas. DETECCIÓN" .

ns1:ErrorConversionCadena a ns1:DiagnosticoFallo ;
    rdfs:label "Error al convertir una cadena de caracteres a errores" ;
    ns1:textoExtracto "CAUSA Error al convertir una cadena de caracteres a errores. Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

