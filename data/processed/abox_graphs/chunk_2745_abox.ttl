@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FalloLexerContadores a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer contadores" ;
    ns1:identificador "8829" ;
    ns1:solucionaFallo ns1:ManualInstalacionPLC ;
    ns1:textoExtracto "Fallo del lexer al reconocer contadores. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Error al convertir una cadena de caracteres a contadores. Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:FalloLexerDecimales a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer números decimales" ;
    ns1:identificador "8830" ;
    ns1:solucionaFallo ns1:ManualInstalacionPLC ;
    ns1:textoExtracto "Fallo del lexer al reconocer números decimales. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Error al convertir una cadena de caracteres a números decimales. Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

