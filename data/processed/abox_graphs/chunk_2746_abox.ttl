@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_8831 a ns1:DiagnosticoFallo ;
    rdfs:label "Marca fuera de rango permitido" ;
    ns1:identificador "8831" ;
    ns1:solucionaFallo ns1:RangoMarcasValido,
        ns1:SintaxisProgramacion ;
    ns1:textoExtracto "8831 Marca fuera de rango permitido. DETECCIÓN Durante la edición del programa PLC. CAUSA La marca programada no es válida. SOLUCIÓN Las marcas deben estar dentro del rango M1 a M8192." .

ns1:Fallo_8832 a ns1:DiagnosticoFallo ;
    rdfs:label "Registro fuera de rango permitido" ;
    ns1:identificador "8832" ;
    ns1:textoExtracto "8832 Registro fuera de rango permitido." .

ns1:RangoMarcasValido a ns1:Parametro ;
    rdfs:label "Rango M1 a M8192" ;
    ns1:documentadoEn ns1:ManualInstalacion_PLC ;
    ns1:textoExtracto "Las marcas deben estar dentro del rango M1 a M8192." ;
    ns1:valor "M1-M8192" .

ns1:SintaxisProgramacion a ns1:Parametro ;
    ns1:documentadoEn ns1:ManualInstalacion_PLC ;
    ns1:textoExtracto "Revisar en el manual de instalación la sintaxis." .

ns1:ManualInstalacion_PLC a ns1:Manual ;
    ns1:textoExtracto "Revisar en el manual de instalación la sintaxis." .

