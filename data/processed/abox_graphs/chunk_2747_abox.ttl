@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8832 a ns1:DiagnosticoFallo ;
    rdfs:label "Registro fuera de rango permitido" ;
    ns1:identificador "8832" ;
    ns1:solucionaFallo ns1:ManualInstalacionPLC ;
    ns1:textoExtracto "Registro fuera de rango permitido. DETECCIÓN Durante la edición del programa PLC. CAUSA El registro programado no es válido. SOLUCIÓN Los registros deben estar dentro del rango R1 a R1024." .

ns1:Error_8833 a ns1:DiagnosticoFallo ;
    rdfs:label "Temporizador fuera de rango permitido" ;
    ns1:identificador "8833" ;
    ns1:textoExtracto "Temporizador fuera de rango permitido. DETECCIÓN Durante la edición del programa PLC. CAUSA El temporizador programado no es válido. SOLUCIÓN Los temporizador deben estar dentro del rango T1 a T512." .

ns1:Error_8834 a ns1:DiagnosticoFallo ;
    rdfs:label "Contador fuera de rango permitido" ;
    ns1:identificador "8834" ;
    ns1:textoExtracto "Contador fuera de rango permitido. DETECCIÓN Durante la edición del programa PLC. CAUSA El contador programado no es válido. SOLUCIÓN Los contador deben estar dentro del rango C1 a C256." .

ns1:Error_8835 a ns1:DiagnosticoFallo ;
    rdfs:label "Reloj fuera de rango" ;
    ns1:identificador "8835" ;
    ns1:solucionaFallo ns1:ManualInstalacionPLC ;
    ns1:textoExtracto "Reloj fuera de rango. DETECCIÓN Durante la edición del programa PLC. CAUSA El reloj programado no es válido. SOLUCIÓN Consultar en el manual de instalación los relojes válidos." .

ns1:Error_8836 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer relojes" ;
    ns1:identificador "8836" ;
    ns1:solucionaFallo ns1:ManualInstalacionPLC ;
    ns1:textoExtracto "Fallo del lexer al reconocer relojes. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Error al convertir una cadena de caracteres a relojes. Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:Error_8837 a ns1:DiagnosticoFallo ;
    rdfs:label "Entrada de arranque fuera de rango permitido" ;
    ns1:identificador "8837" ;
    ns1:textoExtracto "Entrada de arranque fuera de rango permitido. DETECCIÓN Durante la edición del programa PLC. CAUSA La entrada de arranque no es válida. SOLUCIÓN Las entradas de arranque deben estar dentro del rango TG1 a TG4." .

ns1:Error_8838 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer entradas de arranque" ;
    ns1:identificador "8838" ;
    ns1:solucionaFallo ns1:ManualInstalacionPLC ;
    ns1:textoExtracto "Fallo del lexer al reconocer entradas de arranque. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Error al convertir una cadena de caracteres a entradas de arranque. Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:Error_8839 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta índice de entrada de arranque" ;
    ns1:identificador "8839" ;
    ns1:textoExtracto "Falta índice de entrada de arranque. Suponemos TG1. DETECCIÓN Durante la edición del programa PLC." .

ns1:ManualInstalacionPLC a ns1:Manual ;
    rdfs:label "Manual de instalación del PLC" ;
    ns1:textoExtracto "Consultar en el manual de instalación los relojes válidos. [...] Revisar en el manual de instalación la sintaxis." .

