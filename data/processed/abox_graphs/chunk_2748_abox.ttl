@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_883 a ns1:DiagnosticoFallo ;
    rdfs:label "Carácter programado incorrecto" ;
    ns1:solucionaFallo ns1:ManualInstalacion ;
    ns1:textoExtracto "Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:Fallo_8839 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta índice de entrada de arranque" ;
    ns1:identificador "8839" ;
    ns1:textoExtracto "Falta índice de entrada de arranque. Suponemos TG1. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta programar el índice de la entrada de arranque. SOLUCIÓN Programar una entrada de arranque dentro del rango TG1 a TG4." .

ns1:Fallo_8840 a ns1:DiagnosticoFallo ;
    rdfs:label "Recurso obsoleto PIC o PAG" ;
    ns1:identificador "8840" ;
    ns1:textoExtracto "Recurso obsoleto PIC o PAG; sustituido por MSG." .

ns1:ManualInstalacion a ns1:Manual ;
    ns1:textoExtracto "Revisar en el manual de instalación la sintaxis." .

