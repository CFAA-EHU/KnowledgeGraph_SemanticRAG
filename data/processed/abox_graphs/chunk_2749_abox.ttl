@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Directiva_CY1 a ns1:Parametro ;
    rdfs:label "Directiva CY1 (comienzo de módulo)"@es ;
    ns1:identificador "CY1" ;
    ns1:textoExtracto "Programar la directiva CY1, PRG, PE al comienzo del módulo"@es .

ns1:Directiva_PE a ns1:Parametro ;
    rdfs:label "Directiva PE (comienzo de módulo)"@es ;
    ns1:identificador "PE" ;
    ns1:textoExtracto "Programar la directiva CY1, PRG, PE al comienzo del módulo"@es .

ns1:Directiva_PRG a ns1:Parametro ;
    rdfs:label "Directiva PRG (comienzo de módulo)"@es ;
    ns1:identificador "PRG" ;
    ns1:textoExtracto "Programar la directiva CY1, PRG, PE al comienzo del módulo"@es .

ns1:Directiva_SUB a ns1:Parametro ;
    rdfs:label "Directiva SUB (comienzo de subrutina)"@es ;
    ns1:identificador "SUB" ;
    ns1:textoExtracto "SUB al comienzo de cada subrutina"@es .

ns1:Fallo_8840 a ns1:DiagnosticoFallo ;
    rdfs:label "Recurso obsoleto PIC o PAG"@es ;
    ns1:identificador "8840" ;
    ns1:textoExtracto "Recurso obsoleto PIC o PAG; sustituido por MSG. DETECCIÓN Durante la edición del programa PLC. CAUSA Ambos recursos ya no son válidos. SOLUCIÓN Es posible que ambos recursos pertenezcan a otra familia de CNCs o hayan cambiado de nombre. No es posible utilizar ambos registros y el PLC los ha sustituido por MSG."@es .

ns1:Fallo_8841 a ns1:DiagnosticoFallo ;
    rdfs:label "Directiva de comienzo de módulo o subrutina faltante"@es ;
    ns1:identificador "8841" ;
    ns1:textoExtracto "Se esperaba directiva de comienzo de módulo o subrutina. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay programado algún módulo o subrutina y falta la directiva de comienzo. SOLUCIÓN Programar la directiva CY1, PRG, PE al comienzo del módulo, o SUB al comienzo de cada subrutina."@es .

ns1:Fallo_8842 a ns1:DiagnosticoFallo ;
    rdfs:label "Consulta faltante en programa PLC"@es ;
    ns1:identificador "8842" ;
    ns1:textoExtracto "Se esperaba consulta en lugar de %. DETECCIÓN Durante la compilación del programa PLC. CAUSA Falta programar una consulta. SOLUCIÓN Programar una consulta."@es .

ns1:Fallo_8843 a ns1:DiagnosticoFallo ;
    rdfs:label "Acción faltante en programa PLC"@es ;
    ns1:identificador "8843" ;
    ns1:textoExtracto "Se esperaba acción en lugar de %. DETECCIÓN Durante la compilación del programa PLC. CAUSA Falta programar una acción. SOLUCIÓN Programar una acción."@es .

ns1:Fallo_8844 a ns1:DiagnosticoFallo ;
    rdfs:label "Consulta previa faltante en instrucción PLC"@es ;
    ns1:identificador "8844" ;
    ns1:textoExtracto "Falta consulta previa. DETECCIÓN Durante la compilación del programa PLC. CAUSA Falta programar una consulta para poder ejecutar la instrucción. SOLUCIÓN Revisar la sintaxis."@es .

ns1:Fallo_8845 a ns1:DiagnosticoFallo ;
    rdfs:label "Marca de sistema redefinida en PLC"@es ;
    ns1:identificador "8845" ;
    ns1:textoExtracto "Marca de sistema redefinida. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay dos señales (marcas) con el mismo nombre. SOLUCIÓN Revisar el nombre de las marcas."@es .

ns1:Fallo_8846 a ns1:DiagnosticoFallo ;
    rdfs:label "Símbolo de usuario redefinido en PLC"@es ;
    ns1:identificador "8846" ;
    ns1:textoExtracto "Símbolo de usuario redefinido. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay dos símbolos con el mismo nombre. SOLUCIÓN Revisar el nombre de los símbolos."@es .

ns1:Fallo_8847 a ns1:DiagnosticoFallo ;
    rdfs:label "Exceso de símbolos de usuario en PLC"@es ;
    ns1:identificador "8847" ;
    ns1:textoExtracto "Demasiados símbolos de usuario. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay definidos más de 100 símbolos PDEF."@es .

ns1:Fallo_ProgramacionArranque a ns1:DiagnosticoFallo ;
    rdfs:label "Falta programar índice de entrada de arranque"@es ;
    ns1:textoExtracto "PLC. CAUSA Falta programar el índice de la entrada de arranque. SOLUCIÓN Programar una entrada de arranque dentro del rango TG1 a TG4."@es .

ns1:Recurso_MSG a ns1:Componente ;
    rdfs:label "Recurso MSG (sustituto de PIC/PAG)"@es ;
    ns1:identificador "MSG" ;
    ns1:textoExtracto "sustituido por MSG"@es .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC"@es ;
    ns1:textoExtracto "PLC"@es ;
    ns1:tieneComponente ns1:Modulo_EntradaArranque .

ns1:Modulo_EntradaArranque a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de arranque (TG1-TG4)"@es ;
    ns1:identificador "TG1-TG4" ;
    ns1:textoExtracto "Programar una entrada de arranque dentro del rango TG1 a TG4"@es .

