@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8847 a ns1:AvisoSeguridad ;
    rdfs:label "Demasiados símbolos de usuario (Error 8847)"@es ;
    ns1:identificador "8847" ;
    ns1:textoExtracto "Demasiados símbolos de usuario. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay definidos más de 100 símbolos PDEF. SOLUCIÓN Programar algunos símbolos PDEF como símbolos DEF. El PLC permite programar 100 símbolos PDEF y un número ilimitado de símbolos DEF."@es .

ns1:Error_8848 a ns1:AvisoSeguridad ;
    rdfs:label "Demasiados errores (Error 8848)"@es ;
    ns1:identificador "8848" ;
    ns1:textoExtracto "Demasiados errores. DETECCIÓN Durante la compilación del programa PLC. CAUSA El PLC ha detectado demasiados errores"@es .

ns1:Error_NombresDuplicados a ns1:AvisoSeguridad ;
    rdfs:label "Símbolos con el mismo nombre"@es ;
    ns1:textoExtracto "CAUSA Hay dos símbolos con el mismo nombre. SOLUCIÓN Revisar el nombre de los símbolos."@es .

