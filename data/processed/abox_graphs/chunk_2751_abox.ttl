@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BloqueProgramacion a ns1:Componente ;
    rdfs:label "Bloque de programación"@es ;
    ns1:textoExtracto "Programar END sola en el bloque."@es .

ns1:Error8848 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8848: Demasiados errores"@es ;
    ns1:identificador "8848" ;
    ns1:textoExtracto "8848 Demasiados errores. DETECCIÓN Durante la compilación del programa PLC. CAUSA El PLC ha detectado demasiados errores y sólo muestra los primeros. SOLUCIÓN Corregir los errores y volver a analizar el programa."@es .

ns1:Error8849 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8849: Se esperaba END o nueva proposición"@es ;
    ns1:identificador "8849" ;
    ns1:textoExtracto "8849 Se esperaba END o nueva proposición. Puede que falte un salto de línea. DETECCIÓN Durante la edición del programa PLC. CAUSA Falta programar END al final de un módulo o subrutina. SOLUCIÓN Programar END al final de cada módulo o subrutina. Programar END sola en el bloque."@es .

ns1:Error8850 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8850: Error fatal"@es ;
    ns1:identificador "8850" ;
    ns1:textoExtracto "8850 Error fatal. No se puede continuar. DETECCIÓN Durante la compilación del programa PLC. CAUSA El PLC ha detectado un error y no puede compilar o ejecutar el programa. SOLUCIÓN Revisar la sintaxis del programa."@es .

ns1:Error8851 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8851: Marca no válida en este contexto"@es ;
    ns1:identificador "8851" ;
    ns1:textoExtracto "8851 Una marca no es válida en este contexto. DETECCIÓN Durante la compilación del programa PLC."@es .

ns1:SistemaProgramacionPLC a ns1:Sistema ;
    rdfs:label "Sistema de programación PLC"@es ;
    ns1:textoExtracto "permite programar 100 símbolos PDEF y un número ilimitado de símbolos DEF."@es ;
    ns1:tieneComponente ns1:ModuloProgramacion .

ns1:SubrutinaProgramacion a ns1:Componente ;
    rdfs:label "Subrutina de programación"@es ;
    ns1:textoExtracto "Programar END al final de cada módulo o subrutina."@es .

ns1:ModuloProgramacion a ns1:Componente ;
    rdfs:label "Módulo de programación PLC"@es ;
    ns1:textoExtracto "Falta programar END al final de un módulo o subrutina."@es .

