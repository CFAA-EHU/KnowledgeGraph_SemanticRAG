@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error8851 a ns1:DiagnosticoFallo ;
    rdfs:label "Marca no válida en contexto" ;
    ns1:identificador "8851" ;
    ns1:solucionaFallo ns1:ManualInstalacionPLC ;
    ns1:textoExtracto "SOLUCIÓN Revisar la sintaxis del programa. 8851 Una marca no es válida en este contexto. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay programada una marca y la instrucción necesita otro tipo de recurso." .

ns1:Error8852 a ns1:DiagnosticoFallo ;
    rdfs:label "Recurso simbolizado no válido" ;
    ns1:identificador "8852" ;
    ns1:solucionaFallo ns1:ManualInstalacionPLC ;
    ns1:textoExtracto "8852 El recurso simbolizado no es válido en este contexto. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay programado un símbolo y la instrucción necesita otro tipo de recurso en el símbolo." .

ns1:Error8853 a ns1:DiagnosticoFallo ;
    rdfs:label "Símbolo no definido" ;
    ns1:identificador "8853" ;
    ns1:textoExtracto "8853 Símbolo no definido. DETECCIÓN Durante la compilación del programa PLC. CAUSA El símbolo programado no existe." .

ns1:Error8854 a ns1:DiagnosticoFallo ;
    rdfs:label "Registro no válido en contexto" ;
    ns1:identificador "8854" ;
    ns1:textoExtracto "8854 Un registro no es válido en este contexto. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay programado un registro y la instrucción necesita otro tipo de recurso." .

ns1:ManualInstalacionPLC a ns1:Manual ;
    rdfs:label "Manual de instalación del PLC" ;
    ns1:textoExtracto "Revisar en el manual de instalación la sintaxis." .

