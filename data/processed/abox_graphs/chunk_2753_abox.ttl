@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ManualInstalacionPLC a ns1:Manual ;
    rdfs:label "Manual de instalación (sintaxis PLC)"@es ;
    ns1:documentadoEn ns1:Fallo_8855,
        ns1:Fallo_8856 ;
    ns1:textoExtracto "Revisar en el manual de instalación la sintaxis."@es .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema de programación PLC"@es ;
    ns1:textoExtracto "Durante la compilación del programa PLC"@es ;
    ns1:tieneComponente ns1:RegistroDeSistemaPLC .

ns1:DuplicacionDeNombresDeRegistrosEnProgramaPLC a ns1:AccionProhibida ;
    rdfs:label "Duplicación de nombres de registros en programa PLC"@es ;
    ns1:textoExtracto "Hay dos señales (registros) con el mismo nombre."@es .

ns1:Fallo_8855 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis: DEF esperado en lugar de %"@es ;
    ns1:identificador "8855" ;
    ns1:solucionaFallo ns1:UsoIncorrectoDeSintaxisEnInstruccionesPLC ;
    ns1:textoExtracto "8855 Se esperaba DEF en lugar de %. DETECCIÓN Durante la edición del programa PLC. CAUSA La sintaxis de la instrucción no es correcta. SOLUCIÓN Revisar en el manual de instalación la sintaxis."@es .

ns1:Fallo_8856 a ns1:DiagnosticoFallo ;
    rdfs:label "Registro de sistema redefinido"@es ;
    ns1:identificador "8856" ;
    ns1:solucionaFallo ns1:DuplicacionDeNombresDeRegistrosEnProgramaPLC ;
    ns1:textoExtracto "8856 Registro de sistema redefinido. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay dos señales (registros) con el mismo nombre."@es .

ns1:RegistroDeSistemaPLC a ns1:ComponenteElectrico ;
    rdfs:label "Registro de sistema PLC"@es ;
    ns1:textoExtracto "registro" .

ns1:UsoIncorrectoDeSintaxisEnInstruccionesPLC a ns1:AccionProhibida ;
    rdfs:label "Uso incorrecto de sintaxis en instrucciones PLC"@es ;
    ns1:textoExtracto "Revisar en el manual de instalación la sintaxis."@es .

