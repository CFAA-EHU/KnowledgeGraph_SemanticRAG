@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_PLC a ns1:Sistema ;
    rdfs:label "Sistema PLC (Programmable Logic Controller)" ;
    ns1:textoExtracto "programa PLC" ;
    ns1:tieneComponente ns1:Modulo_Programa .

ns1:Fallo_8863 a ns1:DiagnosticoFallo ;
    rdfs:label "Etiqueta indefinida" ;
    ns1:identificador "8863" ;
    ns1:textoExtracto "DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay definida un salto a una etiquete pero ésta no existe (=JMP etiqueta). SOLUCIÓN Revisar el nombre de las etiquetas y los saltos a las etiquetas." .

ns1:Fallo_8864 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta salto de línea tras fin de módulo" ;
    ns1:identificador "8864" ;
    ns1:textoExtracto "DETECCIÓN Durante la compilación. CAUSA Hay demasiadas subrutinas definidas en el programa. SOLUCIÓN Utilizar saltos a etiquetas en lugar de subrutinas, o agrupar varias subrutinas en una sola." .

ns1:Modulo_Programa a ns1:Componente ;
    rdfs:label "Módulo de programa" ;
    ns1:requiereMantenimiento ns1:Fallo_8863,
        ns1:Fallo_8864 ;
    ns1:textoExtracto "programa" .

