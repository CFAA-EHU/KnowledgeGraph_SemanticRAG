@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ns1:textoExtracto "Consulte a Fagor Automation por la disponiblidad de esa marca o prestación."@es .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC de Fagor Automation"@es ;
    ns1:textoExtracto "señal de PLC (marca/registro), compilación del programa PLC, familia de CNCs, Fagor Automation"@es ;
    ns1:tieneComponente ns1:Error8864,
        ns1:Error8865,
        ns1:Error8866,
        ns1:Error8867,
        ns1:Error8868,
        ns1:Error8869,
        ns1:Error8870 .

ns1:Error8864 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta salto de línea tras fin de módulo"@es ;
    ns1:identificador "8864" ;
    ns1:textoExtracto "Falta salto de linea tras fin de módulo. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay definida alguna instrucción en la mismo línea que un \"END\". SOLUCIÓN Programar un salto de línea tras la instrucción \"END\"."@es .

ns1:Error8865 a ns1:DiagnosticoFallo ;
    rdfs:label "No hay memoria para símbolos nuevos"@es ;
    ns1:identificador "8865" ;
    ns1:textoExtracto "No hay memoria para símbolos nuevos. DETECCIÓN Durante la compilación del programa PLC. CAUSA Se ha alcanzado el límite de símbolos del sistema. SOLUCIÓN No es posible definir más símbolos."@es .

ns1:Error8866 a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede MOVer marcas de sistema"@es ;
    ns1:identificador "8866" ;
    ns1:textoExtracto "No se puede MOVer marcas de sistema. DETECCIÓN Durante la compilación del programa PLC. CAUSA Se ha intentado mover un recurso a una señal del PLC (marca). SOLUCIÓN Las señales de consulta no se pueden modificar. Modificar las señales modificables mediante instrucciones de acción."@es .

ns1:Error8867 a ns1:DiagnosticoFallo ;
    rdfs:label "Marca obsoleta del sistema"@es ;
    ns1:identificador "8867" ;
    ns1:textoExtracto "Marca obsoleta del sistema. DETECCIÓN Durante la compilación del programa PLC. CAUSA La señal de PLC (marca) ya no es válida. SOLUCIÓN Es posible que la marca pertenezca a otra familia de CNCs o haya cambiado de nombre. No es posible utilizar esta marca."@es .

ns1:Error8868 a ns1:DiagnosticoFallo ;
    rdfs:label "Registro obsoleto del sistema"@es ;
    ns1:identificador "8868" ;
    ns1:textoExtracto "Registro obsoleto del sistema. DETECCIÓN Durante la compilación del programa PLC. CAUSA La señal de PLC (registro) ya no es válida. SOLUCIÓN Es posible que el registro pertenezca a otra familia de CNCs o haya cambiado de nombre. No es posible utilizar este registro."@es .

ns1:Error8869 a ns1:DiagnosticoFallo ;
    rdfs:label "Marca del sistema pendiente de ser implementada"@es ;
    ns1:identificador "8869" ;
    ns1:textoExtracto "Marca del sistema pendiente de ser implementada. DETECCIÓN Durante la compilación del programa PLC. CAUSA La señal de PLC (marca) no es válida. SOLUCIÓN La marca pertenece a una prestación en desarrollo y no ha sido implementada todavía. No es posible utilizar esta marca. Consulte a Fagor Automation por la disponiblidad de esa marca o prestación."@es .

ns1:Error8870 a ns1:DiagnosticoFallo ;
    rdfs:label "Etiqueta definida pero no llamada"@es ;
    ns1:identificador "8870" ;
    ns1:textoExtracto "Etiqueta definida pero no llamada. DETECCIÓN Durante la compilación del programa PLC."@es .

