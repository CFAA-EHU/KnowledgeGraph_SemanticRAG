@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Solucion_8870 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de instrucciones de salto o eliminación de etiqueta (Error 8870)"@es ;
    ns1:solucionaFallo ns1:Error_8870 ;
    ns1:textoExtracto "Revisar las instrucciones de salto o borrar la etiqueta si no se"@es .

ns1:Error_8870 a ns1:AvisoSeguridad ;
    rdfs:label "Etiqueta definida pero no llamada (Error 8870)"@es ;
    ns1:identificador "8870" ;
    ns1:textoExtracto "8870 Etiqueta definida pero no llamada. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay definida una etiqueta en el programa pero no hay ninguna instrucción de salto a ella (=JMP etiqueta)."@es .

