@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8871 a ns1:DiagnosticoFallo ;
    rdfs:label "Error interno: Línea demasiado larga"@es ;
    ns1:identificador "8871" ;
    ns1:textoExtracto "DETECCIÓN Durante la compilación del programa PLC. CAUSA La línea del programa es demasiado larga. SOLUCIÓN Dividir la línea en varias instrucciones."@es .

ns1:Error_8872 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta módulo PRG"@es ;
    ns1:identificador "8872" ;
    ns1:textoExtracto "DETECCIÓN Durante la compilación del programa PLC. CAUSA No se ha programado el módulo PRG. SOLUCIÓN El módulo PRG debe existir en el programa."@es .

ns1:Error_8873 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo del lexer al reconocer módulos periódicos"@es ;
    ns1:identificador "8873" ;
    ns1:solucionaFallo ns1:ManualInstalacionPLC ;
    ns1:textoExtracto "DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA Error al convertir una cadena de caracteres a un módulo periódico. Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis."@es .

ns1:Error_8874 a ns1:DiagnosticoFallo ;
    rdfs:label "Subrutina indefinida"@es ;
    ns1:identificador "8874" ;
    ns1:textoExtracto "Subrutina indefinida."@es .

ns1:Error_EtiquetaSinSalto a ns1:DiagnosticoFallo ;
    rdfs:label "Etiqueta definida sin instrucción de salto"@es ;
    ns1:solucionaFallo ns1:ManualInstalacionPLC ;
    ns1:textoExtracto "CAUSA Hay definida una etiqueta en el programa pero no hay ninguna instrucción de salto a ella (=JMP etiqueta). SOLUCIÓN Revisar las instrucciones de salto o borrar la etiqueta si no se usa."@es .

ns1:ManualInstalacionPLC a ns1:Manual ;
    rdfs:label "Manual de instalación (sintaxis PLC)"@es ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de instalación la sintaxis."@es .

