@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_8874 a ns1:DiagnosticoFallo ;
    rdfs:label "Subrutina indefinida" ;
    ns1:identificador "8874" ;
    ns1:textoExtracto "8874 Subrutina indefinida. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay definida una llamada a una subrutina pero ésta no existe (=CAL subrutina). SOLUCIÓN Revisar el nombre de las subrutinas y las llamadas a subrutinas." .

ns1:Error_8875 a ns1:DiagnosticoFallo ;
    rdfs:label "Registro no definido" ;
    ns1:identificador "8875" ;
    ns1:textoExtracto "8875 Registro no definido. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA No existe el símbolo programado. SOLUCIÓN Programar un símbolo válido, donde 'Símbolo' puede ser una variable del sistema o un símbolo definido con DEF/PDEF." .

ns1:Error_8876 a ns1:DiagnosticoFallo ;
    rdfs:label "Fichero de ejes inaccesible" ;
    ns1:identificador "8876" ;
    ns1:textoExtracto "8876 No se ha podido abrir el fichero de ejes. DETECCIÓN Durante la compilación del programa PLC. CAUSA Error abriendo el fichero 'MTB\\DATA\\axeslog.tab'. SOLUCIÓN Comprobar que el fichero existe y que se puede abrir con un editor habitual. Si está corrupto, póngase en contacto con Fagor Automation." .

ns1:Error_Sintaxis a ns1:DiagnosticoFallo ;
    rdfs:label "Carácter programado incorrecto" ;
    ns1:textoExtracto "Algún carácter programado no es correcto. SOLUCIÓN Revisar en el manual de instalación la sintaxis." .

ns1:ManualInstalacion a ns1:Manual ;
    ns1:textoExtracto "Revisar en el manual de instalación la sintaxis." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Durante la compilación/edición del programa PLC" ;
    ns1:tieneComponente ns1:FicheroEjes .

ns1:FicheroEjes a ns1:Componente ;
    rdfs:label "axeslog.tab" ;
    ns1:identificador "MTB\\DATA\\axeslog.tab" ;
    ns1:textoExtracto "Error abriendo el fichero 'MTB\\DATA\\axeslog.tab'." .

