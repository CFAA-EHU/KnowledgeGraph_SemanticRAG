@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:controla ns1:ErrorIncoherenciaSoftwareBusCAN ;
    ns1:textoExtracto "se visualizará el error correspondiente en el CNC"@es .

ns1:TeclaReset a ns1:InterfazUsuario ;
    rdfs:label "Tecla [RESET]"@es ;
    ns1:activaAlarma ns1:ErrorIncoherenciaSoftwareBusCAN ;
    ns1:textoExtracto "cada vez que se pulse la tecla [RESET]"@es .

ns1:ErrorIncoherenciaSoftwareBusCAN a ns1:AvisoSeguridad ;
    rdfs:label "Error de incoherencia de software en bus CAN"@es ;
    ns1:textoExtracto "no se completa con éxito, y por tanto no se puede garantizar la coherencia de software entre todos los elementos del bus CAN, se visualizará el error correspondiente en el CNC"@es .

