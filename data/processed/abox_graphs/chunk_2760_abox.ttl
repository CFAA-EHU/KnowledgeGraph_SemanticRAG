@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_ContactoFagorAutomation a ns1:AccionProhibida ;
    rdfs:label "Contactar con Fagor Automation si el programa está corrupto"@es ;
    ns1:textoExtracto "Si está corrupto, póngase en contacto con Fagor Automation."@es .

ns1:Alarma_8877 a ns1:Alarma ;
    rdfs:label "Alarma 8877: No hay eje físico equivalente al eje lógico"@es ;
    ns1:identificador "8877" ;
    ns1:textoExtracto "8877 No hay eje físico equivalente al eje lógico. DETECCIÓN Durante la compilación del programa PLC. CAUSA El programa contiene una referencia a un eje que no existe. SOLUCIÓN Revisar la programación."@es .

ns1:Alarma_8878 a ns1:Alarma ;
    rdfs:label "Alarma 8878: Subrutina definida pero no llamada"@es ;
    ns1:identificador "8878" ;
    ns1:textoExtracto "8878 Subrutina definida pero no llamada. DETECCIÓN Durante la compilación del programa PLC. CAUSA Hay definida una subrutina en el programa pero no hay"@es .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ns1:textoExtracto "Fagor Automation"@es .

