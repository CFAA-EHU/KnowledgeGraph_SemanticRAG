@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BloqueCNCEX a ns1:Parametro ;
    rdfs:label "Bloque en instrucción CNCEX" ;
    ns1:textoExtracto "CNCEX(bloque,marca <,canal>)." .

ns1:CanalCNCEX a ns1:Parametro ;
    rdfs:label "Canal en instrucción CNCEX" ;
    ns1:textoExtracto "CNCEX(bloque,marca <,canal>)." .

ns1:Error8882 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8882: Sobra parámetro en sentencia" ;
    ns1:documentadoEn ns1:ManualInstalacionPLC ;
    ns1:identificador "8882" ;
    ns1:solucionaFallo ns1:ParametroSobrante ;
    ns1:textoExtracto "Sobra parámetro en sentencia." .

ns1:Error8883 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8883: CNCRD(variable,registro,marca)" ;
    ns1:documentadoEn ns1:ManualInstalacionPLC ;
    ns1:identificador "8883" ;
    ns1:textoExtracto "CNCRD(variable,registro,marca)." .

ns1:Error8884 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8884: CNCWR(registro,variable,marca)" ;
    ns1:documentadoEn ns1:ManualInstalacionPLC ;
    ns1:identificador "8884" ;
    ns1:textoExtracto "CNCWR(registro,variable,marca)." .

ns1:Error8885 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 8885: CNCEX(bloque,marca <,canal>)" ;
    ns1:documentadoEn ns1:ManualInstalacionPLC ;
    ns1:identificador "8885" ;
    ns1:textoExtracto "CNCEX(bloque,marca <,canal>)." .

ns1:ErrorGenericoSintaxis a ns1:DiagnosticoFallo ;
    rdfs:label "Error genérico: Sintaxis incorrecta en instrucción" ;
    ns1:documentadoEn ns1:ManualInstalacionPLC ;
    ns1:textoExtracto "La sintaxis de la instrucción no es correcta." .

ns1:MarcaCNCEX a ns1:Parametro ;
    rdfs:label "Marca en instrucción CNCEX" ;
    ns1:textoExtracto "CNCEX(bloque,marca <,canal>)." .

ns1:MarcaCNCRD a ns1:Parametro ;
    rdfs:label "Marca en instrucción CNCRD" ;
    ns1:textoExtracto "CNCRD(variable,registro,marca)." .

ns1:MarcaCNCWR a ns1:Parametro ;
    rdfs:label "Marca en instrucción CNCWR" ;
    ns1:textoExtracto "CNCWR(registro,variable,marca)." .

ns1:RegistroCNCRD a ns1:Parametro ;
    rdfs:label "Registro en instrucción CNCRD" ;
    ns1:textoExtracto "CNCRD(variable,registro,marca)." .

ns1:RegistroCNCWR a ns1:Parametro ;
    rdfs:label "Registro en instrucción CNCWR" ;
    ns1:textoExtracto "CNCWR(registro,variable,marca)." .

ns1:VariableCNCRD a ns1:Parametro ;
    rdfs:label "Variable en instrucción CNCRD" ;
    ns1:textoExtracto "CNCRD(variable,registro,marca)." .

ns1:VariableCNCWR a ns1:Parametro ;
    rdfs:label "Variable en instrucción CNCWR" ;
    ns1:textoExtracto "CNCWR(registro,variable,marca)." .

ns1:ParametroSobrante a ns1:Parametro ;
    rdfs:label "Parámetro sobrante en sentencia" ;
    ns1:textoExtracto "Sobra parámetro en sentencia." .

ns1:ManualInstalacionPLC a ns1:Manual ;
    rdfs:label "Manual de instalación del PLC" ;
    ns1:textoExtracto "Revisar en el manual de instalación la sintaxis." .

