@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_8886 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en instrucción MOVE ABS/ADD"@es ;
    ns1:identificador "8886" ;
    ns1:solucionaFallo ns1:AccionProhibida_8886_SintaxisIncorrecta ;
    ns1:textoExtracto "CAUSA La sintaxis de la instrucción no es correcta. SOLUCIÓN Revisar en el manual de instalación la sintaxis. 8886 MOVE ABS/ADD(eje,posición,velocidad,tipoEnlace)"@es .

ns1:DiagnosticoFallo_8887 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en instrucción MOVE INF"@es ;
    ns1:identificador "8887" ;
    ns1:solucionaFallo ns1:AccionProhibida_8887_SintaxisIncorrecta ;
    ns1:textoExtracto "CAUSA La sintaxis de la instrucción no es correcta. SOLUCIÓN Revisar en el manual de instalación la sintaxis. 8887 MOVE INF(eje,sentido,velocidad,tipoEnlace)"@es .

ns1:Parametro_eje a ns1:Parametro ;
    rdfs:label "eje"@es ;
    ns1:textoExtracto "eje"@es .

ns1:Parametro_posicion a ns1:Parametro ;
    rdfs:label "posición"@es ;
    ns1:textoExtracto "posición"@es .

ns1:Parametro_sentido a ns1:Parametro ;
    rdfs:label "sentido"@es ;
    ns1:textoExtracto "sentido"@es .

ns1:Parametro_tipoEnlace a ns1:Parametro ;
    rdfs:label "tipoEnlace"@es ;
    ns1:textoExtracto "tipoEnlace"@es .

ns1:Parametro_velocidad a ns1:Parametro ;
    rdfs:label "velocidad"@es ;
    ns1:textoExtracto "velocidad"@es .

ns1:AccionProhibida_8886_SintaxisIncorrecta a ns1:AccionProhibida ;
    rdfs:label "Uso incorrecto de sintaxis en MOVE ABS/ADD"@es ;
    ns1:documentadoEn ns1:Manual_Instalacion ;
    ns1:textoExtracto "MOVE ABS/ADD(eje,posición,velocidad,tipoEnlace)"@es .

ns1:AccionProhibida_8887_SintaxisIncorrecta a ns1:AccionProhibida ;
    rdfs:label "Uso incorrecto de sintaxis en MOVE INF"@es ;
    ns1:documentadoEn ns1:Manual_Instalacion ;
    ns1:textoExtracto "MOVE INF(eje,sentido,velocidad,tipoEnlace)"@es .

ns1:Manual_Instalacion a ns1:Manual ;
    rdfs:label "Manual de instalación"@es ;
    ns1:textoExtracto "Revisar en el manual de instalación la sintaxis"@es .

