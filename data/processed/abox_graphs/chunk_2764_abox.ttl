@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_8892_Palpador a ns1:Sensor ;
    rdfs:label "Palpador (parámetro TOUCHPROBE)"@es ;
    ns1:textoExtracto "TOUCHPROBE(eje,palpador,ventana,limInf,limSup <,POS/NEG>)"@es .

ns1:Componente_8893_Palpador a ns1:Sensor ;
    rdfs:label "Palpador (parámetro TOUCHPROBE)"@es ;
    ns1:textoExtracto "TOUCHPROBE(eje,palpador <,ventana,limInf,limSup,POS/NEG>)"@es .

ns1:Fallo_8887 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en instrucción MOVE INF"@es ;
    ns1:identificador "8887" ;
    ns1:solucionaFallo ns1:Manual_Instalacion_PLC ;
    ns1:textoExtracto "MOVE INF(eje,sentido,velocidad,tipoEnlace) [...] DETECCIÓN Durante la edición del programa PLC. CAUSA La sintaxis de la instrucción no es correcta. SOLUCIÓN Revisar en el manual de instalación la sintaxis."@es .

ns1:Fallo_8888 a ns1:DiagnosticoFallo ;
