ns1:Fallo_8894 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en instrucción anterior (compilación)"@es ;
    ns1:identificador "8894" ;
    ns1:textoExtracto "'Instrucción anterior incorrecta' [...] DETECCIÓN Al compilar el programa PLC."@es .

ns1:Manual_Instalacion_PLC a ns1:Manual ;
    rdfs:label "Manual de instalación (referencia para sintaxis)"@es ;
    ns1:textoExtracto "SOLUCIÓN Revisar en el manual de instalación la sintaxis."@es .

