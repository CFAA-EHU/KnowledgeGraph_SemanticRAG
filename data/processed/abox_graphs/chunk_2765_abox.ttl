@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_8894 a ns1:DiagnosticoFallo ;
    rdfs:label "Instrucción anterior incorrecta" ;
    ns1:identificador "8894" ;
    ns1:textoExtracto "DETECCIÓN Al compilar el programa PLC. CAUSA El análisis del programa de PLC que realiza el compilador, antes de su conversión a C, ha detectado una instrucción incorrecta. La salida de errores señala la instrucción siguiente a la incorrecta. SOLUCIÓN Corregir, eliminar o comentar la instrucción incorrecta." .

ns1:Fallo_8895 a ns1:DiagnosticoFallo ;
    rdfs:label "Instrucción incorrecta" ;
    ns1:identificador "8895" ;
    ns1:textoExtracto "DETECCIÓN Al compilar el programa PLC. CAUSA El análisis del programa de PLC que realiza" .

ns1:Manual_Instalacion_PLC a ns1:Manual ;
    ns1:textoExtracto "Revisar en el manual de instalación la sintaxis." .

