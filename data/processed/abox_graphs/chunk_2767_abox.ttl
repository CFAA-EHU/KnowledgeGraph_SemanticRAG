@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación" ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Parametro_LEAP a ns1:Parametro ;
    rdfs:label "#LEAP[<,G90/G91> <,POSvalor> <,POSLIMITvalor> <,GAPvalor> <,TIMEvalor> <,OVRvalor>] <nombreEje cotaEje>" ;
    ns1:documentadoEn ns1:ErrorSintaxisSentencia_8900 ;
    ns1:identificador "8900" ;
    ns1:textoExtracto "#LEAP[<,G90/G91> <,POSvalor> <,POSLIMITvalor> <,GAPvalor> <,TIMEvalor> <,OVRvalor>] <nombreEje cotaEje>" .

ns1:Parametro_MSGVAR a ns1:Parametro ;
    rdfs:label "#MSGVAR[indiceVar][\"Texto <%d>\"/nºentero <,valor>]" ;
    ns1:documentadoEn ns1:ErrorSintaxisSentencia_8899 ;
    ns1:identificador "8899" ;
    ns1:textoExtracto "#MSGVAR[indiceVar][\"Texto <%d>\" /nºentero <,valor>]" .

ns1:SentenciaCAM_SELECT a ns1:Parametro ;
    rdfs:label "#CAM SELECT(leva,\"path\\fichero\")" ;
    ns1:documentadoEn ns1:ErrorSenalNoModificable ;
    ns1:identificador "8898" ;
    ns1:textoExtracto "#CAM SELECT(leva,\"path\\fichero\")" .

ns1:ErrorSenalNoModificable a ns1:DiagnosticoFallo ;
    rdfs:label "Error: Señal (marca) no modificable" ;
    ns1:identificador "8898" ;
    ns1:textoExtracto "CAUSA La señal (marca) no es modificable; es una señal de consulta. SOLUCIÓN Utilizar la señal en instrucciones de consulta." .

ns1:ErrorSintaxisSentencia_8899 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #MSGVAR" ;
    ns1:identificador "8899" ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:ErrorSintaxisSentencia_8900 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sintaxis en sentencia #LEAP" ;
    ns1:identificador "8900" ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta." .

