@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FalloSintaxisSentencia_8901 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de sintaxis en sentencia #LEAP"@es ;
    ns1:identificador "8901" ;
    ns1:monitoreaParametro ns1:Parametro_G90_G91,
        ns1:Parametro_GAPvalor,
        ns1:Parametro_INCPOS,
        ns1:Parametro_OVRvalor,
        ns1:Parametro_POSLIMITvalor,
        ns1:Parametro_POSvalor,
        ns1:Parametro_TIMEvalor,
        ns1:Parametro_nombreEje_cotaEje ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8901 #LEAP[<,INCPOS> <,G90/G91> <,POSvalor> <,POSLIMITvalor> <,GAPvalor> <,TIMEvalor> <,OVRvalor>] <nombreEje cotaEje>"@es .

ns1:FalloSintaxisSentencia_8902 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de sintaxis en sentencia #GAPCTRL"@es ;
    ns1:identificador "8902" ;
    ns1:monitoreaParametro ns1:Parametro_F3DPvalor,
        ns1:Parametro_Fvalor,
        ns1:Parametro_GAPvalor,
        ns1:Parametro_INC_8902,
        ns1:Parametro_OFFDISTvalor,
        ns1:Parametro_nombreEje_posicionEje_8902 ;
    ns1:solucionaFallo ns1:ManualProgramacion ;
    ns1:textoExtracto "CAUSA La sintaxis de la sentencia no es correcta. SOLUCIÓN Revisar en el manual de programación la sintaxis de la sentencia. 8902 #GAPCTRL ON/OFF[<INC> <nombreEje posiciónEje> <,GAPvalor> <,Fvalor> <,F3DPvalor> <,OFFDISTvalor>]"@es .

ns1:Parametro_F3DPvalor a ns1:Parametro ;
    rdfs:label "F3DPvalor"@es ;
    ns1:textoExtracto "8902 #GAPCTRL ON/OFF[...,<F3DPvalor>..."@es .

ns1:Parametro_Fvalor a ns1:Parametro ;
    rdfs:label "Fvalor"@es ;
    ns1:textoExtracto "8902 #GAPCTRL ON/OFF[...,<Fvalor>..."@es .

ns1:Parametro_G90_G91 a ns1:Parametro ;
    rdfs:label "G90/G91"@es ;
    ns1:textoExtracto "8901 #LEAP[<,G90/G91>..."@es .

ns1:Parametro_INCPOS a ns1:Parametro ;
    rdfs:label "INCPOS"@es ;
    ns1:textoExtracto "8901 #LEAP[<,INCPOS>..."@es .

ns1:Parametro_INC_8902 a ns1:Parametro ;
    rdfs:label "INC"@es ;
    ns1:textoExtracto "8902 #GAPCTRL ON/OFF[<INC>..."@es .

ns1:Parametro_OFFDISTvalor a ns1:Parametro ;
    rdfs:label "OFFDISTvalor"@es ;
    ns1:textoExtracto "8902 #GAPCTRL ON/OFF[...,<OFFDISTvalor>]"@es .

ns1:Parametro_OVRvalor a ns1:Parametro ;
    rdfs:label "OVRvalor"@es ;
    ns1:textoExtracto "8901 #LEAP[<,OVRvalor>..."@es .

ns1:Parametro_POSLIMITvalor a ns1:Parametro ;
    rdfs:label "POSLIMITvalor"@es ;
    ns1:textoExtracto "8901 #LEAP[<,POSLIMITvalor>..."@es .

ns1:Parametro_POSvalor a ns1:Parametro ;
    rdfs:label "POSvalor"@es ;
    ns1:textoExtracto "8901 #LEAP[<,POSvalor>..."@es .

ns1:Parametro_TIMEvalor a ns1:Parametro ;
    rdfs:label "TIMEvalor"@es ;
    ns1:textoExtracto "8901 #LEAP[<,TIMEvalor>..."@es .

ns1:Parametro_nombreEje_cotaEje a ns1:Parametro ;
    rdfs:label "nombreEje cotaEje"@es ;
    ns1:textoExtracto "8901 #LEAP[...] <nombreEje cotaEje>"@es .

ns1:Parametro_nombreEje_posicionEje_8902 a ns1:Parametro ;
    rdfs:label "nombreEje posiciónEje"@es ;
    ns1:textoExtracto "8902 #GAPCTRL ON/OFF[<nombreEje posiciónEje>..."@es .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación"@es ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia"@es .

ns1:Parametro_GAPvalor a ns1:Parametro ;
    rdfs:label "GAPvalor"@es ;
    ns1:textoExtracto "8901 #LEAP[<,GAPvalor>..."@es .

