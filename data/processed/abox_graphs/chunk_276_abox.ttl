@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC a ns1:Sistema ;
    rdfs:label "CNC"@es ;
    ns1:controla ns1:Cabezal ;
    ns1:monitoreaParametro ns1:OperacionSobreCabezal ;
    ns1:textoExtracto "al ejecutar cualquier operación sobre el cabezal, el CNC realiza una búsqueda de referencia del mismo"@es .

ns1:Software_V1_1x a ns1:Sistema ;
    rdfs:label "Software V1.1x"@es ;
    ns1:cumpleNormativa ns1:CodigoValidacion_V1_1x ;
    ns1:textoExtracto "el código de validación de esa versión"@es .

ns1:TablaDeHerramientasYAlmacenV310 a ns1:Tabla ;
    rdfs:label "Tabla de herramientas y almacén V3.10"@es ;
    ns1:compuestoPor ns1:SoftwareV310 ;
    ns1:textoExtracto "Tabla de herramientas y almacén"@es .

ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "cabezal"@es ;
    ns1:textoExtracto "cabezal"@es .

ns1:CodigoDeValidacionV200 a ns1:Parametro ;
    rdfs:label "código de validación V2.00"@es ;
    ns1:textoExtracto "nuevo código de validación"@es .

ns1:CodigoValidacion_V1_1x a ns1:Parametro ;
    rdfs:label "código de validación V1.1x"@es ;
    ns1:textoExtracto "código de validación de esa versión"@es .

ns1:OperacionSobreCabezal a ns1:AccionProhibida ;
    rdfs:label "operación sobre el cabezal"@es ;
    ns1:textoExtracto "cualquier operación sobre el cabezal"@es .

ns1:SoftkeyCargar a ns1:InterfazUsuario ;
    rdfs:label "softkey 'Cargar'"@es ;
    ns1:textoExtracto "softkeys 'Cargar'"@es .

ns1:SoftkeySalvar a ns1:InterfazUsuario ;
    rdfs:label "softkey 'Salvar'"@es ;
    ns1:textoExtracto "softkeys 'Salvar'"@es .

ns1:SoftwareV200 a ns1:Sistema ;
    rdfs:label "Software V2.00"@es ;
    ns1:cumpleNormativa ns1:CodigoDeValidacionV200 ;
    ns1:habilitadoPor ns1:SoftkeyCargar,
        ns1:SoftkeySalvar ;
    ns1:requiereMantenimiento ns1:TablaDeHerramientasYAlmacenV200 ;
    ns1:textoExtracto "Ambas operaciones se realizan desde la tabla de herramientas y almacén, mediante las softkeys 'Salvar' y 'Cargar'"@es .

ns1:SoftwareV310 a ns1:Sistema ;
    rdfs:label "Software V3.10"@es ;
    ns1:textoExtracto "Versión V3.10"@es .

ns1:TablaDeHerramientasYAlmacenV200 a ns1:Tabla ;
    rdfs:label "Tabla de herramientas y almacén V2.00"@es ;
    ns1:compuestoPor ns1:SoftwareV200 ;
    ns1:textoExtracto "Tabla de herramientas y almacén"@es .

