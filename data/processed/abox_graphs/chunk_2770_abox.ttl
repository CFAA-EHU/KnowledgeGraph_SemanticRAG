@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:ManualInstalacionCNC a ns1:Manual ;
    ns1:detalladoEnEsquema ns1:ComandoCNCWR ;
    ns1:textoExtracto "Revisar en el manual de instalación la sintaxis" .

ns1:ComandoCNCWR a ns1:AccionProhibida,
        ns1:Parametro ;
    ns1:identificador "8905 CNCWR" ;
    ns1:solucionaFallo ns1:SintaxisIncorrectaCNCWR ;
    ns1:textoExtracto "8905 CNCWR(registro, idVar, canal, ejeLog, idxArray1, idxArray2, marca <,registroError>)" ;
    ns1:valor "registro, idVar, canal, ejeLog, idxArray1, idxArray2, marca <,registroError>" .

ns1:SintaxisIncorrectaCNCWR a ns1:DiagnosticoFallo ;
    ns1:textoExtracto "La sintaxis del comando no es correcta" .

