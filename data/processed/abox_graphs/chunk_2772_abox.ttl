@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error9018 a ns1:DiagnosticoFallo ;
    rdfs:label "Demasiados DFUs en una única consulta" ;
    ns1:identificador "9018" ;
    ns1:solucionaFallo ns1:ProgramaPLC ;
    ns1:textoExtracto "9018 Demasiados DFUs en una única consulta. DETECCIÓN Durante la compilación del programa PLC. CAUSA La proposición ejecutable tiene demasiadas instrucciones DFU. SOLUCIÓN Analizar las instrucciones DFU en grupos, guardando el resultado en una marca." .

ns1:Error9019 a ns1:DiagnosticoFallo ;
    rdfs:label "Demasiados DFDs en una única consulta" ;
    ns1:identificador "9019" ;
    ns1:solucionaFallo ns1:ProgramaPLC ;
    ns1:textoExtracto "9019 Demasiados DFDs en una única consulta. DETECCIÓN Durante la compilación del programa PLC. CAUSA La proposición ejecutable tiene demasiadas instrucciones DFU. SOLUCIÓN Analizar las instrucciones DFD en grupos, guardando el resultado en una marca." .

ns1:Error9020 a ns1:DiagnosticoFallo ;
    rdfs:label "Demasiadas acciones" ;
    ns1:identificador "9020" ;
    ns1:solucionaFallo ns1:ProgramaPLC ;
    ns1:textoExtracto "9020 Demasiadas acciones. DETECCIÓN Durante la compilación del programa PLC. CAUSA" .

ns1:ProgramaPLC a ns1:Sistema ;
    rdfs:label "Programa PLC" ;
    ns1:textoExtracto "Durante la compilación del programa PLC" .

