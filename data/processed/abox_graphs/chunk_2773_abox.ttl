@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_9020 a ns1:DiagnosticoFallo ;
    rdfs:label "Demasiadas acciones (9020)" ;
    ns1:identificador "9020" ;
    ns1:solucionaFallo ns1:SistemaPLC ;
    ns1:textoExtracto "Demasiadas acciones. DETECCIÓN Durante la compilación del programa PLC. CAUSA La proposición ejecutable tiene demasiadas acciones. SOLUCIÓN Duplicar la proposición ejecutable y distribuir las acciones." .

ns1:Fallo_9026 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta fin de módulo o subrutina 'END' (9026)" ;
    ns1:identificador "9026" ;
    ns1:solucionaFallo ns1:SistemaPLC ;
    ns1:textoExtracto "Falta fin de módulo o de subrutina 'END'. DETECCIÓN Durante la compilación del programa PLC. CAUSA Falta la proposición directiva END al final de un módulo CY1, PRG o PE. SOLUCIÓN Finalizar todos los módulos con la proposición directiva END." .

ns1:Fallo_9027 a ns1:DiagnosticoFallo ;
    rdfs:label "Instrucción no soportada (9027)" ;
    ns1:identificador "9027" ;
    ns1:solucionaFallo ns1:SistemaPLC ;
    ns1:textoExtracto "Instrucción no soportada. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA La instrucción programada no existe. SOLUCIÓN Revisar la sintaxis." .

ns1:Fallo_9028 a ns1:DiagnosticoFallo ;
    rdfs:label "Debe ser un recurso o un número (9028)" ;
    ns1:identificador "9028" ;
    ns1:solucionaFallo ns1:SistemaPLC ;
    ns1:textoExtracto "Debe ser un recurso o un número. DETECCIÓN Durante la edición o compilación del programa PLC. CAUSA La instrucción programada es incorrecta. SOLUCIÓN Programar un recurso o un número." .

ns1:Modulo_CY1 a ns1:Componente ;
    rdfs:label "Módulo CY1" ;
    ns1:textoExtracto "módulo CY1" .

ns1:Modulo_PE a ns1:Componente ;
    rdfs:label "Módulo PE" ;
    ns1:textoExtracto "módulo PE" .

ns1:Modulo_PRG a ns1:Componente ;
    rdfs:label "Módulo PRG" ;
    ns1:textoExtracto "módulo PRG" .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema de programación PLC" ;
    ns1:textoExtracto "instrucciones DFU. SOLUCIÓN Analizar las instrucciones DFD en grupos, guardando el resultado en una marca." ;
    ns1:tieneComponente ns1:Modulo_CY1,
        ns1:Modulo_PE,
        ns1:Modulo_PRG .

