@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema de programación PLC" ;
    ns1:activaAlarma ns1:Error9000,
        ns1:Error9029,
        ns1:Error9030,
        ns1:Error9031,
        ns1:Error9032,
        ns1:Error9033 ;
    ns1:textoExtracto "DETECCIÓN Durante la compilación del programa PLC" .

ns1:Error9000 a ns1:DiagnosticoFallo ;
    rdfs:label "Instrucción programada incorrecta" ;
    ns1:identificador "9000" ;
    ns1:textoExtracto "CAUSA La instrucción programada es incorrecta. SOLUCIÓN Programar un recurso o un número." .

ns1:Error9029 a ns1:DiagnosticoFallo ;
    rdfs:label "DEF incorrectamente construido" ;
    ns1:identificador "9029" ;
    ns1:textoExtracto "DEF incorrectamente construido. DETECCIÓN Durante la compilación del programa PLC. CAUSA DEF incorrectamente construido. SOLUCIÓN Revisar la programación." .

ns1:Error9030 a ns1:DiagnosticoFallo ;
    rdfs:label "Tipo de recurso desconocido" ;
    ns1:identificador "9030" ;
    ns1:textoExtracto "Tipo de recurso desconocido. DETECCIÓN Durante la compilación del programa PLC. CAUSA Tipo de recurso desconocido. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error9031 a ns1:DiagnosticoFallo ;
    rdfs:label "Fin de fichero en comentario" ;
    ns1:identificador "9031" ;
    ns1:textoExtracto "Fin de fichero en comentario. DETECCIÓN Durante la compilación del programa PLC. CAUSA Fin de fichero en comentario. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error9032 a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede abrir el fichero de símbolos" ;
    ns1:identificador "9032" ;
    ns1:textoExtracto "No se puede abrir el fichero de símbolos. DETECCIÓN Durante la compilación del programa PLC. CAUSA No se puede abrir el fichero de símbolos. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error9033 a ns1:DiagnosticoFallo ;
    rdfs:label "Memoria insuficiente para lista de símbolos" ;
    ns1:identificador "9033" ;
    ns1:textoExtracto "No hay memoria para crear la lista de símbolos. DETECCIÓN Durante la compilación del programa PLC." .

