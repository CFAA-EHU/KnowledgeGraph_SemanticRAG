@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ns1:textoExtracto "Póngase en contacto con Fagor Automation"@es .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC"@es ;
    ns1:activaAlarma ns1:Alarma_9033,
        ns1:Alarma_9034 ;
    ns1:textoExtracto "sistema no dispone de memoria para crear recursos nuevos"@es .

ns1:Alarma_9033 a ns1:Alarma ;
    rdfs:label "Alarma 9033: No hay memoria para crear la lista de símbolos"@es ;
    ns1:identificador "9033" ;
    ns1:textoExtracto "9033 No hay memoria para crear la lista de símbolos. DETECCIÓN Durante la compilación del programa PLC. CAUSA El sistema no dispone de memoria para crear recursos nuevos."@es .

ns1:Alarma_9034 a ns1:Alarma ;
    rdfs:label "Alarma 9034: No se puede abrir el fichero de recursos con símbolo"@es ;
    ns1:identificador "9034" ;
    ns1:textoExtracto "9034 No se puede abrir el fichero de recursos con símbolo. DETECCIÓN Durante la compilación del programa PLC. CAUSA El sistema no dispone de memoria para crear"@es .

