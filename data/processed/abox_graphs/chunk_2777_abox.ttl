@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_9042 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sustitución de carácter en compilación PLC"@es ;
    ns1:identificador "9042" ;
    ns1:textoExtracto "DETECCIÓN Durante la compilación del programa PLC. CAUSA El carácter \"/\" es incorrecto; el PLC lo ha sustituido el carácter \"_\" en el programa compilado. SOLUCIÓN Sustituir el carácter \"/\" por"@es .

ns1:Fallo_MarcaRegistroIncorrecto a ns1:DiagnosticoFallo ;
    rdfs:label "Error de marca o registro incorrecto en PLC"@es ;
    ns1:textoExtracto "CAUSA La marca o registro es incorrecto; el PLC lo ha sustituido en el programa compilado por el recurso sugerido. SOLUCIÓN Sustituir la marca o registro por el recurso sugerido."@es .

