@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorCompilacion_9043 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de compilación: '/' sustituido por '_'" ;
    ns1:documentadoEn ns1:SistemaPLC ;
    ns1:identificador "9043" ;
    ns1:textoExtracto "DETECCIÓN Durante la compilación del programa PLC. CAUSA El carácter \"/\" es incorrecto; el PLC lo ha sustituido el carácter \"_\" en el programa compilado. SOLUCIÓN Sustituir el carácter \"/\" por \"_\" en el programa de PLC." .

ns1:ErrorCompilacion_9044 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de compilación: '+' sustituido por 'POS'" ;
    ns1:documentadoEn ns1:SistemaPLC ;
    ns1:identificador "9044" ;
    ns1:textoExtracto "DETECCIÓN Durante la compilación del programa PLC. CAUSA El carácter \"+\" es incorrecto; el PLC lo ha sustituido por \"POS\" en el programa compilado. SOLUCIÓN Sustituir el carácter \"+\" por \"POS\" en el programa de PLC." .

ns1:ErrorCompilacion_9045 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de compilación: '-' sustituido por 'NEG'" ;
    ns1:documentadoEn ns1:SistemaPLC ;
    ns1:identificador "9045" ;
    ns1:textoExtracto "DETECCIÓN Durante la compilación del programa PLC. CAUSA El carácter \"-\" es incorrecto; el PLC lo ha sustituido por \"NEG\" en el programa compilado. SOLUCIÓN Sustituir el carácter \"-\" por \"NEG\" en el programa de PLC." .

ns1:ErrorCompilacion_9046 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de compilación: '-' sustituido por '_'" ;
    ns1:documentadoEn ns1:SistemaPLC ;
    ns1:identificador "9046" ;
    ns1:textoExtracto "DETECCIÓN Durante la compilación del programa PLC. CAUSA El carácter \"-\" es incorrecto; el PLC lo ha sustituido el carácter \"_\" en el programa compilado. SOLUCIÓN Sustituir el carácter \"-\" por \"_\" en el programa de PLC." .

ns1:ErrorCompilacion_9047 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de compilación: '.' sustituido por '_'" ;
    ns1:documentadoEn ns1:SistemaPLC ;
    ns1:identificador "9047" ;
    ns1:textoExtracto "DETECCIÓN Durante la compilación del programa PLC. CAUSA El carácter \".\" es incorrecto; el PLC lo ha sustituido el carácter \"_\" en el programa compilado. SOLUCIÓN Sustituir el carácter \".\" por \"_\" en el programa de PLC." .

ns1:ErrorCompilacion_9048 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de compilación: Memoria insuficiente para recursos binarios nuevos" ;
    ns1:documentadoEn ns1:SistemaPLC ;
    ns1:identificador "9048" ;
    ns1:solucionaFallo ns1:Empresa_FagorAutomation ;
    ns1:textoExtracto "DETECCIÓN Durante la compilación del programa PLC. CAUSA El sistema no dispone de memoria para crear recursos nuevos. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:ErrorCompilacion_9049 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de compilación: Memoria insuficiente para recursos registros nuevos" ;
    ns1:documentadoEn ns1:SistemaPLC ;
    ns1:identificador "9049" ;
    ns1:textoExtracto "DETECCIÓN Durante la compilación del programa PLC. CAUSA El sistema no dispone de memoria para crear recursos nuevos." .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation" ;
    ns1:textoExtracto "Póngase en contacto con Fagor Automation." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "El sistema no dispone de memoria para crear recursos nuevos." .

