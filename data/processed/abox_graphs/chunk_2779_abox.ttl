@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ns1:textoExtracto "Póngase en contacto con Fagor Automation"@es .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC"@es ;
    ns1:activaAlarma ns1:Fallo_9049,
        ns1:Fallo_9050 ;
    ns1:textoExtracto "Durante la compilación del programa PLC"@es .

ns1:Fallo_9049 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 9049: No hay memoria para recursos registros nuevos"@es ;
    ns1:identificador "9049" ;
    ns1:textoExtracto "9049 No hay memoria para recursos registros nuevos. DETECCIÓN Durante la compilación del programa PLC. CAUSA El sistema no dispone de memoria para crear recursos nuevos."@es .

ns1:Fallo_9050 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 9050: No hay memoria para recursos registros de sistema nuevos"@es ;
    ns1:identificador "9050" ;
    ns1:textoExtracto "9050 No hay memoria para recursos registros de sistema nuevos. DETECCIÓN Durante la compilación del programa"@es .

