@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorGiroHerramienta a ns1:AvisoSeguridad ;
    rdfs:label "Error por giro incorrecto de herramienta" ;
    ns1:textoExtracto "Si el sentido de giro no coincide con el programado se mostrará un error." .

ns1:HabilitacionCabezalV3_15 a ns1:AccionProhibida ;
    rdfs:label "Habilitación del cabezal (versión V3.15)" ;
    ns1:identificador "V3.15" ;
    ns1:mitigaRiesgo ns1:ErrorEjeBloqueado ;
    ns1:textoExtracto "Para evitar errores del tipo 'eje bloqueado', en la maniobra del PLC se debe contemplar la habilitación de la marca SERVOSON con las funciones M19, roscado rígido y cuando se active la marca ENABLES." .

ns1:ParametroGiroHerramienta a ns1:Parametro ;
    rdfs:label "Sentido de giro de herramienta" ;
    ns1:monitoreaParametro ns1:TablaHerramientasCNC ;
    ns1:textoExtracto "El CNC hace caso al icono que define el sentido de giro de la herramienta. Si el sentido de giro no coincide con el programado se mostrará un error." .

ns1:ParametroRadioCYL a ns1:Parametro ;
    rdfs:label "Radio en sentencia #CYL" ;
    ns1:textoExtracto "En la sentencia #CYL es obligatorio programar el radio... definirlo con valor 0 (cero)." ;
    ns1:valor "0" .

ns1:SentenciaCYL a ns1:Parametro ;
    rdfs:label "Sentencia #CYL (programación eje C)" ;
    ns1:textoExtracto "En la sentencia #CYL es obligatorio programar el radio. Para corregir los programas de versiones anteriores, en los que no esté definido el radio, habrá que definirlo con valor 0 (cero)." ;
    ns1:valor "#CYL" .

ns1:SistemaCNC_V3_15 a ns1:Sistema ;
    rdfs:label "Sistema CNC (versión V3.15)" ;
    ns1:identificador "V3.15" ;
    ns1:textoExtracto "Versión V3.15. Modificaciones en la homogeneización de parámetros." ;
    ns1:tieneComponente ns1:FuncionM19,
        ns1:MarcaENABLES,
        ns1:MarcaSERVOSON,
        ns1:ParametroABSOFF .

ns1:ErrorEjeBloqueado a ns1:AvisoSeguridad ;
    rdfs:label "Error 'eje bloqueado'" ;
    ns1:textoExtracto "Para evitar errores del tipo 'eje bloqueado'..." .

ns1:FuncionM19 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función M19 (roscado rígido)" ;
    ns1:textoExtracto "habilitación de la marca SERVOSON con las funciones M19, roscado rígido" ;
    ns1:valor "M19" .

ns1:MarcaENABLES a ns1:Parametro ;
    rdfs:label "Marca ENABLES" ;
    ns1:textoExtracto "cuando se active la marca ENABLES" ;
    ns1:valor "ENABLES" .

ns1:MarcaSERVOSON a ns1:Parametro ;
    rdfs:label "Marca SERVOSON" ;
    ns1:textoExtracto "habilitación de la marca SERVOSON con las funciones M19, roscado rígido y cuando se active la marca ENABLES" ;
    ns1:valor "SERVOSON" .

ns1:ParametroABSOFF a ns1:Parametro ;
    rdfs:label "Parámetro ABSOFF" ;
    ns1:textoExtracto "En versiones anteriores, el CNC enviaba al regulador el valor del parámetro ABSOFF sólo cuando el sistema disponía de I0s codificados." ;
    ns1:valor "ABSOFF" .

ns1:TablaHerramientasCNC a ns1:Tabla ;
    rdfs:label "Tabla de herramientas del CNC" ;
    ns1:documentadoEn ns1:ManualCNC ;
    ns1:textoExtracto "Tabla de herramientas. El CNC hace caso al icono que define el sentido de giro de la herramienta." .

