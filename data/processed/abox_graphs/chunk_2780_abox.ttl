@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation" ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error_9301 a ns1:AvisoSeguridad ;
    rdfs:label "'Los ejes maestro y esclavo deben tener igual REFFEED1 y REFFEED2'" ;
    ns1:identificador "9301" ;
    ns1:textoExtracto "9301 'Los ejes maestro y esclavo deben tener igual REFFEED1 y REFFEED2' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Hay una pareja gantry o tándem cuyos ejes maestro y esclavo tienen diferente velocidad de búsqueda de cero en algún set (parámetros REFFEED1 y REFFEED2). SOLUCIÓN Revisar los parámetros máquina. La velocidad rápida y lenta de búsqueda de referencia máquina (parámetros REFFEED1 y REFFEED2) deberá ser igual en ambos ejes." .

ns1:Error_9302 a ns1:AvisoSeguridad ;
    rdfs:label "'Para asumir el nuevo valor es necesario rearrancar windows'" ;
    ns1:identificador "9302" ;
    ns1:textoExtracto "9302 'Para asumir el nuevo valor es necesario rearrancar windows' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Algún cambio en los parámetros máquina exige rearrancar windows para tener efecto. SOLUCIÓN Rearrancar windows." .

ns1:Parametro_REFFEED1 a ns1:Parametro ;
    rdfs:label "Velocidad de búsqueda de referencia máquina (rápida)" ;
    ns1:identificador "REFFEED1" ;
    ns1:textoExtracto "parámetros REFFEED1 y REFFEED2 [...] velocidad de búsqueda de cero [...] velocidad rápida y lenta de búsqueda de referencia máquina" .

ns1:Parametro_REFFEED2 a ns1:Parametro ;
    rdfs:label "Velocidad de búsqueda de referencia máquina (lenta)" ;
    ns1:identificador "REFFEED2" ;
    ns1:textoExtracto "parámetros REFFEED1 y REFFEED2 [...] velocidad de búsqueda de cero [...] velocidad rápida y lenta de búsqueda de referencia máquina" .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC de Fagor Automation" ;
    ns1:activaAlarma ns1:Error_9050,
        ns1:Error_9051,
        ns1:Error_9052,
        ns1:Error_9053,
        ns1:Error_9054 ;
    ns1:textoExtracto "Durante la compilación del programa PLC. El sistema no dispone de memoria para crear recursos nuevos." .

ns1:Error_9050 a ns1:AvisoSeguridad ;
    rdfs:label "No hay memoria para recursos registros de sistema nuevos" ;
    ns1:identificador "9050" ;
    ns1:textoExtracto "9050 No hay memoria para recursos registros de sistema nuevos. DETECCIÓN Durante la compilación del programa PLC. CAUSA El sistema no dispone de memoria para crear recursos nuevos. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error_9051 a ns1:AvisoSeguridad ;
    rdfs:label "No hay memoria para recursos temporizadores nuevos" ;
    ns1:identificador "9051" ;
    ns1:textoExtracto "9051 No hay memoria para recursos temporizadores nuevos. DETECCIÓN Durante la compilación del programa PLC. CAUSA El sistema no dispone de memoria para crear recursos nuevos. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error_9052 a ns1:AvisoSeguridad ;
    rdfs:label "No hay memoria para recursos contadores nuevos" ;
    ns1:identificador "9052" ;
    ns1:textoExtracto "9052 No hay memoria para recursos contadores nuevos. DETECCIÓN Durante la compilación del programa PLC. CAUSA El sistema no dispone de memoria para crear recursos nuevos. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error_9053 a ns1:AvisoSeguridad ;
    rdfs:label "No hay memoria para símbolos nuevos" ;
    ns1:identificador "9053" ;
    ns1:textoExtracto "9053 No hay memoria para símbolos nuevos. DETECCIÓN Durante la compilación del programa PLC. CAUSA El sistema no dispone de memoria para crear recursos nuevos. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error_9054 a ns1:AvisoSeguridad ;
    rdfs:label "No se puede abrir el puerto COM para MODBUSSVRRS" ;
    ns1:identificador "9054" ;
    ns1:textoExtracto "9054 No se puede abrir el puerto COM para MODBUSSVRRS. DETECCIÓN Durante la compilación del programa PLC. CAUSA Falla la conexión al puerto serie para el servidor de MODBUS. SOLUCIÓN Revisar la conexión y parametrización del puerto serie." .

