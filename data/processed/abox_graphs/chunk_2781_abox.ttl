@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_9303 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 9303: Asociación incorrecta de palpador"@es ;
    ns1:identificador "9303" ;
    ns1:textoExtracto "'El palpador debe asociarse a entrada digital de nodo Fagor' DETECCIÓN"@es .

ns1:Palpador_9303 a ns1:Sensor ;
    rdfs:label "Palpador asociable a nodo Fagor"@es ;
    ns1:controla ns1:NodoFagor_9303 ;
    ns1:textoExtracto "El palpador debe asociarse a entrada digital de nodo Fagor"@es .

ns1:ParametrosMaquina_9302 a ns1:Parametro ;
    rdfs:label "Parámetros máquina que requieren reinicio"@es ;
    ns1:monitoreaParametro ns1:SistemaValidacionParametros ;
    ns1:textoExtracto "Algún cambio en los parámetros máquina exige rearrancar windows para tener efecto."@es .

ns1:Accion_ReinicioWindows_9302 a ns1:TareaMantenimiento ;
    rdfs:label "Reiniciar Windows para aplicar cambios en parámetros máquina"@es ;
    ns1:textoExtracto "SOLUCIÓN Rearrancar windows."@es .

ns1:Fallo_9302 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 9302: Reinicio requerido para parámetros máquina"@es ;
    ns1:identificador "9302" ;
    ns1:solucionaFallo ns1:Accion_ReinicioWindows_9302 ;
    ns1:textoExtracto "'Para asumir el nuevo valor es necesario rearrancar windows' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Algún cambio en los parámetros máquina exige rearrancar windows para tener efecto. SOLUCIÓN Rearrancar windows."@es .

ns1:NodoFagor_9303 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo Fagor con entrada digital para palpador"@es ;
    ns1:textoExtracto "El palpador debe asociarse a entrada digital de nodo Fagor"@es .

ns1:SistemaValidacionParametros a ns1:Sistema ;
    rdfs:label "Sistema de validación de parámetros máquina"@es ;
    ns1:activaAlarma ns1:Fallo_9302 ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina."@es .

