@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EntradaLogica a ns1:ComponenteElectrico ;
    rdfs:label "Entrada lógica (simulación de palpador)"@es ;
    ns1:textoExtracto "las entradas lógicas si sólo se desea simular el palpador."@es .

ns1:Fallo_9303 a ns1:DiagnosticoFallo ;
    rdfs:label "El palpador debe asociarse a entrada digital de nodo Fagor"@es ;
    ns1:identificador "9303" ;
    ns1:monitoreaParametro ns1:Parametro_PRBDI1,
        ns1:Parametro_PRBDI2 ;
    ns1:textoExtracto "9303 'El palpador debe asociarse a entrada digital de nodo Fagor' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El parámetro PRBDI1 o PRBDI2 hace referencia a una entrada digital no válida. Sólo son válidas las entradas digitales que pertenecen a módulos Fagor o las entradas lógicas si sólo se desea simular el palpador. SOLUCIÓN Asignar a los parámetros PRBDI1 y PRBDI2 una entrada digital de un módulo Fagor o una entrada lógica."@es .

ns1:Fallo_9304 a ns1:DiagnosticoFallo ;
    rdfs:label "Ejes gantry: Los dos ejes SERCOS tienen que tener igual OPMODEP"@es ;
    ns1:identificador "9304" ;
    ns1:monitoreaParametro ns1:Parametro_OPMODEP ;
    ns1:textoExtracto "9304 'Ejes gantry: Los dos ejes SERCOS tienen que tener igual OPMODEP' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Hay una pareja gantry o tándem cuyos ejes maestro y esclavo tienen diferente parámetro OPMODEP."@es .

ns1:ModuloFagor a ns1:ComponenteElectrico ;
    rdfs:label "Módulo Fagor (entrada digital válida)"@es ;
    ns1:textoExtracto "Sólo son válidas las entradas digitales que pertenecen a módulos Fagor [...]"@es .

ns1:Palpador a ns1:Sensor ;
    rdfs:label "Palpador"@es ;
    ns1:textoExtracto "El palpador debe asociarse a entrada digital de nodo Fagor"@es .

ns1:SistemaEjesGantry a ns1:Sistema ;
    rdfs:label "Sistema de ejes gantry/tándem"@es ;
    ns1:compuestoPor ns1:EjeEsclavo_SERCOS,
        ns1:EjeMaestro_SERCOS ;
    ns1:textoExtracto "Hay una pareja gantry o tándem cuyos ejes maestro y esclavo tienen diferente parámetro OPMODEP."@es .

ns1:EjeEsclavo_SERCOS a ns1:ComponenteMecanico ;
    rdfs:label "Eje esclavo SERCOS (gantry)"@es ;
    ns1:textoExtracto "Los dos ejes SERCOS tienen que tener igual OPMODEP [...] pareja gantry o tándem cuyos ejes maestro y esclavo [...]"@es .

ns1:EjeMaestro_SERCOS a ns1:ComponenteMecanico ;
    rdfs:label "Eje maestro SERCOS (gantry)"@es ;
    ns1:textoExtracto "Los dos ejes SERCOS tienen que tener igual OPMODEP [...] pareja gantry o tándem cuyos ejes maestro y esclavo [...]"@es .

ns1:Parametro_OPMODEP a ns1:Parametro ;
    rdfs:label "OPMODEP (modo de operación para ejes gantry)"@es ;
    ns1:identificador "OPMODEP" ;
    ns1:textoExtracto "Los dos ejes SERCOS tienen que tener igual OPMODEP [...] Hay una pareja gantry o tándem cuyos ejes maestro y esclavo tienen diferente parámetro OPMODEP."@es .

ns1:Parametro_PRBDI1 a ns1:Parametro ;
    rdfs:label "PRBDI1 (entrada digital para palpador)"@es ;
    ns1:identificador "PRBDI1" ;
    ns1:textoExtracto "El parámetro PRBDI1 [...] hace referencia a una entrada digital no válida."@es .

ns1:Parametro_PRBDI2 a ns1:Parametro ;
    rdfs:label "PRBDI2 (entrada digital para palpador)"@es ;
    ns1:identificador "PRBDI2" ;
    ns1:textoExtracto "El parámetro PRBDI2 [...] hace referencia a una entrada digital no válida."@es .

