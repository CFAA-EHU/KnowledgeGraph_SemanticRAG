@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_9307 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 9307: Tipo de canal CHTYPE no configurado como PLC"@es ;
    ns1:identificador "9307" ;
    ns1:monitoreaParametro ns1:Parametro_CHTYPE ;
    ns1:solucionaFallo ns1:Tarea_RevisarParametrosMaquina ;
    ns1:textoExtracto "'Con opción de software Motion Control el tipo de canal \"CHTYPE\" debe ser de PLC'"@es .

ns1:Fallo_9308 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 9308: Posiciones de compensación fuera de rango"@es ;
    ns1:identificador "9308" ;
    ns1:textoExtracto "'No se permiten posiciones de compensación fuera del rango del módulo'"@es .

ns1:FiltroFrecuenciaEje a ns1:ComponenteElectrico ;
    rdfs:label "Filtro de frecuencia del eje"@es ;
    ns1:textoExtracto "Eliminar un filtro de frecuencia del eje"@es .

ns1:Modo_HSC_FAST a ns1:ModoOperacion ;
    rdfs:label "Modo HSC FAST"@es ;
    ns1:textoExtracto "eliminar el filtro del modo HSC FAST"@es .

ns1:Software_MotionControl a ns1:Sistema ;
    rdfs:label "Software Motion Control"@es ;
    ns1:controla ns1:Parametro_CHTYPE ;
    ns1:textoExtracto "Con opción de software Motion Control"@es .

ns1:Tarea_RevisarParametrosMaquina a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de parámetros máquina (modelo MC)"@es ;
    ns1:textoExtracto "Revisar los parámetros máquina. En el modelo MC, todos los canales deben ser de PLC (parámetro CHTYPE)."@es .

ns1:Parametro_CHTYPE a ns1:Parametro ;
    rdfs:label "Parámetro CHTYPE (tipo de canal)"@es ;
    ns1:textoExtracto "tipo de canal \"CHTYPE\" debe ser de PLC"@es ;
    ns1:valor "PLC" .

