@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_9308 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9308: Posiciones de compensación fuera de rango"@es ;
    ns1:identificador "9308" ;
    ns1:monitoreaParametro ns1:Parametro_CHTYPE ;
    ns1:solucionaFallo ns1:Tabla_CompensacionHusillo ;
    ns1:textoExtracto "'No se permiten posiciones de compensación fuera del rango del módulo' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA La tabla de compensación de husillo o de compensación cruzada del eje tiene definidas posiciones fuera de los límites del módulo. SOLUCIÓN Definir todas las posiciones dentro de los límites de módulo."@es .

ns1:Error_9309 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9309: Herramientas de tierra requeridas sin almacenes"@es ;
    ns1:identificador "9309" ;
    ns1:monitoreaParametro ns1:Parametro_GROUND ;
    ns1:textoExtracto "'Si el número de almacenes es 0, se deben permitir herramienta de tierra' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA La máquina no tiene ningún almacén y no admite herramientas de tierra. SOLUCIÓN Para poder cambiar de herramienta en una máquina sin almacenes, la máquina debe admitir herramientas de tierra (parámetro GROUND)."@es .

ns1:Error_9310 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9310: Override de cabezal en roscado con feedforward bajo"@es ;
    ns1:identificador "9310" ;
    ns1:textoExtracto "'No se permite variar override de cabezal durante roscado si feedforward < 90%' DETECCIÓN Durante la validación de los parámetros máquina o la ejecución de un roscado G33. CAUSA No se permite modificar el override del cabezal durante el roscado si el feedforward es menor del 90%, par evitar dañar la rosca. SOLUCIÓN Aumentar el feedforward del cabezal."@es .

ns1:Error_9311 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9311: Conflicto eje TANDEM y grupo MULTIAXIS"@es ;
    ns1:identificador "9311" ;
    ns1:solucionaFallo ns1:Tabla_EjesTandem ;
    ns1:textoExtracto "'Un eje TANDEM no puede estar en un grupo MULTIAXIS' DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA Uno de los ejes forma parte de una pareja tandem y de un grupo MULTIAXIS. SOLUCIÓN Corregir la tabla de ejes tandem y multieje. Un eje sólo puede estar en una de las dos configuraciones."@es .

ns1:Error_9312 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9312: Conflicto eje GANTRY y grupo MULTIAXIS"@es ;
    ns1:identificador "9312" ;
    ns1:textoExtracto "'Un eje GANTRY no puede estar en un grupo MULTIAXIS' DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA Uno de los ejes forma parte de una pareja gantry y de un grupo MULTIAXIS."@es .

ns1:Maquina_ModeloMC a ns1:Maquina ;
    rdfs:label "Máquina modelo MC"@es ;
    ns1:identificador "MC" ;
    ns1:textoExtracto "En el modelo MC, todos los canales deben ser de PLC (parámetro CHTYPE)."@es .

ns1:Parametro_CHTYPE a ns1:Parametro ;
    rdfs:label "Parámetro CHTYPE (tipo de canal)"@es ;
    ns1:identificador "CHTYPE" ;
    ns1:textoExtracto "todos los canales deben ser de PLC (parámetro CHTYPE)"@es .

ns1:Parametro_GROUND a ns1:Parametro ;
    rdfs:label "Parámetro GROUND (herramientas de tierra)"@es ;
    ns1:identificador "GROUND" ;
    ns1:textoExtracto "la máquina debe admitir herramientas de tierra (parámetro GROUND)"@es .

ns1:Tabla_CompensacionHusillo a ns1:Tabla ;
    rdfs:label "Tabla de compensación de husillo"@es ;
    ns1:textoExtracto "La tabla de compensación de husillo o de compensación cruzada del eje tiene definidas posiciones fuera de los límites del módulo."@es .

ns1:Tabla_EjesTandem a ns1:Tabla ;
    rdfs:label "Tabla de ejes TANDEM"@es ;
    ns1:textoExtracto "Corregir la tabla de ejes tandem y multieje."@es .

