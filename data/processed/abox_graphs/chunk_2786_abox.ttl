@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_9312 a ns1:DiagnosticoFallo ;
    rdfs:label "Un eje GANTRY no puede estar en un grupo MULTIAXIS"@es ;
    ns1:identificador "9312" ;
    ns1:monitoreaParametro ns1:Parametro_ConfiguracionEjes ;
    ns1:textoExtracto "Un eje GANTRY no puede estar en un grupo MULTIAXIS. Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA: Uno de los ejes forma parte de una pareja gantry y de un grupo MULTIAXIS. SOLUCIÓN: Corregir la tabla de ejes gantry y multieje. Un eje sólo puede estar en una de las dos configuraciones."@es .

ns1:Fallo_9313 a ns1:DiagnosticoFallo ;
    rdfs:label "DRIVEID del eje del grupo MULTIAXIS no válido en el sistema"@es ;
    ns1:identificador "9313" ;
    ns1:monitoreaParametro ns1:Parametro_DRIVEID ;
    ns1:textoExtracto "DRIVEID del eje del grupo MULTIAXIS no válido en el sistema. Durante la validación de los parámetros máquina o el arranque del CNC."@es .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC"@es ;
    ns1:textoExtracto "máquina CNC"@es ;
    ns1:tieneComponente ns1:Sistema_ValidacionParametros .

ns1:Tabla_ConfiguracionEjes a ns1:Tabla ;
    rdfs:label "Tabla de configuración de ejes"@es ;
    ns1:documentadoEn ns1:Manual_CNC ;
    ns1:textoExtracto "tabla de ejes gantry y multieje"@es .

ns1:Alarma_9312 a ns1:Alarma ;
    rdfs:label "Alarma 9312: Conflicto configuración eje GANTRY/MULTIAXIS"@es ;
    ns1:identificador "9312" ;
    ns1:textoExtracto "Un eje GANTRY no puede estar en un grupo MULTIAXIS"@es .

ns1:Alarma_9313 a ns1:Alarma ;
    rdfs:label "Alarma 9313: DRIVEID inválido en grupo MULTIAXIS"@es ;
    ns1:identificador "9313" ;
    ns1:textoExtracto "DRIVEID del eje del grupo MULTIAXIS no válido en el sistema"@es .

ns1:Sistema_ValidacionParametros a ns1:Sistema ;
    rdfs:label "Sistema de validación de parámetros máquina"@es ;
    ns1:activaAlarma ns1:Alarma_9312,
        ns1:Alarma_9313 ;
    ns1:controla ns1:Parametro_ConfiguracionEjes,
        ns1:Parametro_DRIVEID ;
    ns1:textoExtracto "validación de los parámetros máquina o el arranque del CNC"@es .

ns1:Parametro_ConfiguracionEjes a ns1:Parametro ;
    rdfs:label "Configuración de ejes GANTRY/MULTIAXIS"@es ;
    ns1:textoExtracto "tabla de ejes gantry y multieje"@es .

ns1:Parametro_DRIVEID a ns1:Parametro ;
    rdfs:label "DRIVEID del eje MULTIAXIS"@es ;
    ns1:textoExtracto "DRIVEID del eje del grupo MULTIAXIS"@es .

