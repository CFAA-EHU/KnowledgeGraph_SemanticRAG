@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_9317 a ns1:DiagnosticoFallo ;
    rdfs:label "Grupo de ejes con diferentes captaciones: todos los ejes SERCOS deben ser velocidad"@es ;
    ns1:identificador "9317" ;
    ns1:monitoreaParametro ns1:Parametro_COUNTERID ;
    ns1:textoExtracto "9317 'Grupo de ejes con dif. captaciones: todos los ejes SERCOS deben ser velocidad' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Hay algún grupo multieje cuyos ejes tienen diferente parámetro COUNTER..."@es .

ns1:SistemaMultieje a ns1:Sistema ;
    rdfs:label "Grupo multieje"@es ;
    ns1:textoExtracto "grupo multieje cuyos ejes tienen diferente parámetro COUNTERID"@es ;
    ns1:tieneComponente ns1:EjeNoSERCOS,
        ns1:EjeSERCOS .

ns1:EjeNoSERCOS a ns1:ComponenteMecanico ;
    rdfs:label "Eje no SERCOS"@es ;
    ns1:textoExtracto "ejes no son Sercos velocidad"@es .

ns1:EjeSERCOS a ns1:ComponenteMecanico ;
    rdfs:label "Eje SERCOS velocidad"@es ;
    ns1:textoExtracto "ejes Sercos velocidad"@es .

ns1:Parametro_COUNTERID a ns1:Parametro ;
    rdfs:label "COUNTERID" ;
    ns1:textoExtracto "parámetro COUNTERID"@es ;
    ns1:valor "COUNTERID" .

