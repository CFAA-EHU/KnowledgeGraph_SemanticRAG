@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_ABSOFF a ns1:Parametro ;
    rdfs:label "ABSOFF" ;
    ns1:monitoreaParametro ns1:SistemaCNC ;
    ns1:textoExtracto "el valor del parámetro ABSOFF"@es .

ns1:SistemaCaptacionAbsoluta a ns1:Sistema ;
    rdfs:label "Sistema de captación absoluta" ;
    ns1:compuestoPor ns1:Regulador,
        ns1:SistemaCNC ;
    ns1:textoExtracto "sistema dispone de captación absoluta"@es .

ns1:VersionSoftware_V3_15 a ns1:Manual ;
    rdfs:label "Versión de software V3.15" ;
    ns1:documentadoEn ns1:SistemaCNC ;
    ns1:identificador "V3.15" ;
    ns1:textoExtracto "A partir de la versión V3.15, al actualizar una versión anterior en máquinas con captación absoluta"@es .

ns1:Parametro_PP177 a ns1:Parametro ;
    rdfs:label "PP177" ;
    ns1:identificador "PP177" ;
    ns1:monitoreaParametro ns1:Regulador ;
    ns1:textoExtracto "el regulador en PP177"@es .

ns1:Parametro_PP178 a ns1:Parametro ;
    rdfs:label "PP178" ;
    ns1:identificador "PP178" ;
    ns1:monitoreaParametro ns1:Regulador ;
    ns1:textoExtracto "(PP177/PP178)"@es .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:controla ns1:Regulador ;
    ns1:textoExtracto "el CNC enviaba al regulador el valor del parámetro ABSOFF"@es .

ns1:Regulador a ns1:ComponenteElectrico ;
    rdfs:label "Regulador" ;
    ns1:textoExtracto "el regulador (PP177/PP178)"@es ;
    ns1:tieneComponente ns1:Parametro_PP177,
        ns1:Parametro_PP178 .

