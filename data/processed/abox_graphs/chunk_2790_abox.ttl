@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_9322 a ns1:DiagnosticoFallo ;
    rdfs:label "No hay Hardware para ejes Mechatrolink"@es ;
    ns1:identificador "9322" ;
    ns1:solucionaFallo ns1:Accion_ContactoFagor ;
    ns1:textoExtracto "9322 'No hay Hardware para ejes Mechatrolink' [...] CAUSA No se dispone del hardware necesario para trabajar con ejes Mechatrolink."@es .

ns1:Fallo_9323 a ns1:DiagnosticoFallo ;
    rdfs:label "Con ejes Mechatrolink no se admiten ejes Tandem"@es ;
    ns1:identificador "9323" ;
    ns1:textoExtracto "9323 'Con ejes Mechatrolink no se admiten ejes Tandem'"@es .

ns1:Fallo_DriveTypeInconsistente a ns1:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en parámetro DRIVETYPE de grupo MULTIAXIS"@es ;
    ns1:monitoreaParametro ns1:Parametro_DRIVETYPE ;
    ns1:solucionaFallo ns1:Tarea_RevisionParametros ;
    ns1:textoExtracto "CAUSA Hay un grupo MULTIAXIS cuyos ejes tienen diferente parámetro DRIVETYPE. SOLUCIÓN Revisar los parámetros máquina. Todos los ejes de un grupo MULTIAXIS deben tener el parámetro DRIVETYPE igual; todos los ejes deben analógicos o todos Sercos."@es .

ns1:Accion_ContactoFagor a ns1:TareaMantenimiento ;
    rdfs:label "Contactar con Fagor Automation"@es ;
    ns1:textoExtracto "Póngase en contacto con Fagor Automation."@es .

ns1:Parametro_DRIVETYPE a ns1:Parametro ;
    rdfs:label "DRIVETYPE" ;
    ns1:textoExtracto "parámetro DRIVETYPE"@es .

ns1:Tarea_RevisionParametros a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de parámetros máquina para grupo MULTIAXIS"@es ;
    ns1:textoExtracto "Revisar los parámetros máquina. Todos los ejes de un grupo MULTIAXIS deben tener el parámetro DRIVETYPE igual; todos los ejes deben analógicos o todos Sercos."@es .

