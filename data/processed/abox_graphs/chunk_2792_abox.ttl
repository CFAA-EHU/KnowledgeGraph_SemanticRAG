@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC (Mechatrolink)"@es ;
    ns1:activaAlarma ns1:Alarma_9327 ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina o el arranque del CNC"@es .

ns1:ModoOperacion_MLink_I a ns1:ModoOperacion ;
    rdfs:label "Modo Mlink-I"@es ;
    ns1:identificador "MLink-I" ;
    ns1:textoExtracto "El modo Mlink-I admite un máximo de 14 elementos"@es .

ns1:ModoOperacion_MLink_II a ns1:ModoOperacion ;
    rdfs:label "Modo Mlink-II"@es ;
    ns1:identificador "MLink-II" ;
    ns1:solucionaFallo ns1:Alarma_9327 ;
    ns1:textoExtracto "el modo Mlink-II 30 elementos"@es .

ns1:Sistema_Mechatrolink a ns1:Sistema ;
    rdfs:label "Sistema Mechatrolink"@es ;
    ns1:activaAlarma ns1:Alarma_9327 ;
    ns1:controla ns1:Parametro_SlotTime ;
    ns1:textoExtracto "La configuración Mechatrolink supera el máximo permitido de ejes y cabezales (servos e inverters)"@es ;
    ns1:tieneComponente ns1:ComponenteElectrico_Inverters,
        ns1:ComponenteElectrico_Servos .

ns1:ComponenteElectrico_Inverters a ns1:ComponenteElectrico ;
    rdfs:label "Inverters (cabezales Mechatrolink)"@es ;
    ns1:textoExtracto "ejes y cabezales (servos e inverters)"@es .

ns1:ComponenteElectrico_Servos a ns1:ComponenteElectrico ;
    rdfs:label "Servos (ejes Mechatrolink)"@es ;
    ns1:textoExtracto "ejes y cabezales (servos e inverters)"@es .

ns1:Parametro_SlotTime a ns1:Parametro ;
    rdfs:label "Slot Time (Mechatrolink)"@es ;
    ns1:textoExtracto "Utilizar una ranura de tiempo (Slot Time) de 90 microsegundos en vez de 60, también reduce el número máximo de reguladores."@es ;
    ns1:valor "90" .

ns1:Alarma_9327 a ns1:Alarma ;
    rdfs:label "Alarma 9327: 'Mechatrolink:Número máximo de ejes y cabezales sobrepasado'"@es ;
    ns1:identificador "9327" ;
    ns1:textoExtracto "'Mechatrolink:Número máximo de ejes y cabezales sobrepasado' DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC."@es .

