@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ReguladorDRV a ns1:ComponenteElectrico ;
    rdfs:label "Regulador (DRV)"@es ;
    ns1:identificador "DRV" ;
    ns1:monitoreaParametro ns1:ParametroDATASIZE,
        ns1:ParametroMLINK ;
    ns1:textoExtracto "acceder a las variables y parámetros del regulador (DRV)"@es .

ns1:SolucionConfiguracionBus_9332 a ns1:TareaMantenimiento ;
    rdfs:label "Configurar bus Mechatrolink II a 32 bytes para acceso a parámetros DRV"@es ;
    ns1:solucionaFallo ns1:FalloComunicacionMechatrolinkII_9332 ;
    ns1:textoExtracto "Para poder acceder a las variables y parámetros del regulador (DRV) hay que configurar el bus como Mechatrolink II a 32 bytes (parámetros MLINK y DATASIZE)"@es .

ns1:FalloComunicacionMechatrolinkII_9332 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 9332: COUNTERTYPE remoto y COUNTERID 0 incompatibles"@es ;
    ns1:identificador "9332" ;
    ns1:textoExtracto "9332 'COUNTERTYPE remoto y COUNTERID 0 incompatibles' DETECCIÓN Durante la validación de los parámetros máquina o el arranque"@es .

ns1:ParametroDATASIZE a ns1:Parametro ;
    rdfs:label "Parámetro DATASIZE (tamaño datos Mechatrolink II)"@es ;
    ns1:textoExtracto "configurar el bus como Mechatrolink II a 32 bytes (parámetros MLINK y DATASIZE)"@es ;
    ns1:valor "32 bytes" .

ns1:ParametroMLINK a ns1:Parametro ;
    rdfs:label "Parámetro MLINK (configuración Mechatrolink II)"@es ;
    ns1:textoExtracto "configurar el bus como Mechatrolink II a 32 bytes (parámetros MLINK y DATASIZE)"@es ;
    ns1:valor "Mechatrolink II a 32 bytes"@es .

