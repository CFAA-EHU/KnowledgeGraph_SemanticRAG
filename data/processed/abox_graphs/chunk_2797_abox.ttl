@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Error_9337 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9337: Sercos posición no funciona con LOOPTIME superior a 8 ms" ;
    ns1:solucionaFallo ns1:Parametro_LOOPTIME,
        ns1:Parametro_OPMODE ;
    ns1:textoExtracto "9337 Sercos posición no funciona con LOOPTIME superior a 8 ms. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA Los reguladores Sercos posición tienen limitado a 8 ms el tiempo de ciclo. SOLUCIÓN Asignar al parámetro máquina LOOPTIME un valor igual o inferior a 8 ms o usar los reguladores en velocidad (OPMODE = Velocidad)." .

ns1:Error_9338 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9338: Memoria insuficiente" ;
    ns1:solucionaFallo ns1:Parametro_NPOINTS ;
    ns1:textoExtracto "9338 Memoria insuficiente. Reducir el valor del parámetro. DETECCIÓN Durante el arranque o validación de los parámetros máquina. CAUSA No se ha podido alocar la memoria para el número de puntos indicados por el parámetro NPOINTS de Fagor > Diagnosis." .

ns1:Error_CompatibilidadParametros a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad entre parámetros HBLS y MODBUSSVRRS" ;
    ns1:solucionaFallo ns1:Parametro_HBLS,
        ns1:Parametro_MODBUSSVRRS ;
    ns1:textoExtracto "máquina relacionados aparecen en el mensaje de error (por ejemplo, los parámetros HBLS y MODBUSSVRRS no son compatibles porque ambos utilizan la línea serie). SOLUCIÓN Anular uno de los dos parámetros mencionados en el mensaje de error." .

ns1:Sistema_Sercos a ns1:Sistema ;
    rdfs:label "Reguladores Sercos posición" ;
    ns1:monitoreaParametro ns1:Parametro_LOOPTIME,
        ns1:Parametro_OPMODE ;
    ns1:textoExtracto "Los reguladores Sercos posición tienen limitado a 8 ms el tiempo de ciclo" .

ns1:Parametro_HBLS a ns1:Parametro ;
    rdfs:label "HBLS" ;
    ns1:textoExtracto "parámetros HBLS y MODBUSSVRRS no son compatibles" .

ns1:Parametro_MODBUSSVRRS a ns1:Parametro ;
    rdfs:label "MODBUSSVRRS" ;
    ns1:textoExtracto "parámetros HBLS y MODBUSSVRRS no son compatibles" .

ns1:Parametro_NPOINTS a ns1:Parametro ;
    rdfs:label "NPOINTS" ;
    ns1:textoExtracto "parámetro NPOINTS de Fagor > Diagnosis" .

ns1:Parametro_LOOPTIME a ns1:Parametro ;
    rdfs:label "LOOPTIME" ;
    ns1:textoExtracto "parámetro máquina LOOPTIME" ;
    ns1:valor 8 .

ns1:Parametro_OPMODE a ns1:Parametro ;
    rdfs:label "OPMODE" ;
    ns1:textoExtracto "usar los reguladores en velocidad (OPMODE = Velocidad)" ;
    ns1:valor "Velocidad" .

