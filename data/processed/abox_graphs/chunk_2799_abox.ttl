@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_934 a ns1:DiagnosticoFallo ;
    rdfs:label "Inconsistencia en parámetros de sets con mismo COUNTERID en módulo RCS-S"@es ;
    ns1:monitoreaParametro ns1:Parametro_ABSOFF,
        ns1:Parametro_COUNTERID,
        ns1:Parametro_EXTMULT,
        ns1:Parametro_FBACKAL,
        ns1:Parametro_FEEDBACKTYPE,
        ns1:Parametro_I0CODDI1,
        ns1:Parametro_I0CODDI2,
        ns1:Parametro_I0TYPE,
        ns1:Parametro_NPULSES,
        ns1:Parametro_REFPULSE,
        ns1:Parametro_SSI,
        ns1:Parametro_SSITYPE ;
    ns1:solucionaFallo ns1:Solucion_934_1 ;
    ns1:textoExtracto "CAUSA: Varios sets que con la misma entrada de captación de un módulo RCS-S (parámetro COUNTERID), no tienen el mismo valor en alguno de los siguientes parámetros: FEEDBACKTYPE, SSITYPE, SSI, I0TYPE, ABSOFF, EXTMULT, REFPULSE, I0CODDI1, I0CODDI2, NPULSES y FBACKAL. SOLUCIÓN: En los sets con igual COUNTERID, definir los parámetros indicados con el mismo valor."@es .

ns1:Fallo_9341 a ns1:DiagnosticoFallo ;
    rdfs:label "Contadora Sercos: set activo de varios ejes no pueden tener igual el parámetro ANAOUTID"@es ;
    ns1:monitoreaParametro ns1:Parametro_ANAOUTID ;
    ns1:textoExtracto "DETECCIÓN: Durante el arranque del CNC o la validación de los parámetros máquina. CAUSA: El set activo en varios ejes está utilizando la misma salida analógica de un módulo RCS-S (parámetro ANAOUTID)."@es .

ns1:Modulo_RCS_S a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S"@es ;
    ns1:textoExtracto "módulo RCS-S"@es ;
    ns1:tieneComponente ns1:Parametro_ABSOFF,
        ns1:Parametro_ANAOUTID,
        ns1:Parametro_COUNTERID,
        ns1:Parametro_EXTMULT,
        ns1:Parametro_FBACKAL,
        ns1:Parametro_FEEDBACKTYPE,
        ns1:Parametro_I0CODDI1,
        ns1:Parametro_I0CODDI2,
        ns1:Parametro_I0TYPE,
        ns1:Parametro_NPULSES,
        ns1:Parametro_REFPULSE,
        ns1:Parametro_SSI,
        ns1:Parametro_SSITYPE .

ns1:Solucion_934_1 a ns1:TareaMantenimiento ;
    rdfs:label "Unificación de parámetros en sets con mismo COUNTERID"@es ;
    ns1:textoExtracto "En los sets con igual COUNTERID, definir los parámetros indicados con el mismo valor."@es .

