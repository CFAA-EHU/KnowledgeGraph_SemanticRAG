@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_Fresadora a ns1:Maquina ;
    rdfs:label "Máquina tipo Fresadora" ;
    ns1:controla ns1:Carpeta_MTB_M ;
    ns1:textoExtracto "MTB_M para fresadora" .

ns1:Maquina_Torno a ns1:Maquina ;
    rdfs:label "Máquina tipo Torno" ;
    ns1:controla ns1:Carpeta_MTB_T ;
    ns1:textoExtracto "MTB_T para el torno" .

ns1:Regulador_PP177 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador PP177" ;
    ns1:identificador "PP177" ;
    ns1:textoExtracto "el valor que tiene el regulador en PP177" .

ns1:Regulador_PP178 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador PP178" ;
    ns1:identificador "PP178" ;
    ns1:textoExtracto "el valor que tiene el regulador en PP178" .

ns1:SistemaCNC8070 a ns1:Sistema ;
    rdfs:label "Sistema CNC8070" ;
    ns1:controla ns1:CodigoValidacion ;
    ns1:identificador "CNC8070" ;
    ns1:textoExtracto "el CNC dispone de una carpeta MTB diferente para cada tipo de software instalado; MTB_T para el torno y MTB_M para fresadora" ;
    ns1:tieneComponente ns1:Carpeta_CONFIGURATION,
        ns1:Carpeta_MTB .

ns1:Software_V3.15 a ns1:Sistema ;
    rdfs:label "Software versión V3.15" ;
    ns1:controla ns1:Parametro_ABSOFF ;
    ns1:identificador "V3.15" ;
    ns1:textoExtracto "A partir de la versión V3.15, al actualizar una versión anterior en máquinas con captación absoluta" .

ns1:Software_V3.20 a ns1:Sistema ;
    rdfs:label "Software versión V3.20" ;
    ns1:identificador "V3.20" ;
    ns1:textoExtracto "Versión V3.20. Cambio en la carpeta MTB" ;
    ns1:tieneComponente ns1:Carpeta_CONFIGURATION .

ns1:Carpeta_MTB a ns1:InterfazUsuario ;
    rdfs:label "Carpeta MTB" ;
    ns1:textoExtracto "no aparece ninguna carpeta MTB en la carpeta CNC8070" .

ns1:CodigoValidacion a ns1:Parametro ;
    rdfs:label "Código de validación" ;
    ns1:textoExtracto "En el arranque del sistema, y en función del código de validación, el sistema moverá la carpeta correspondiente" .

ns1:Parametro_ABSOFF a ns1:Parametro ;
    rdfs:label "Parámetro ABSOFF" ;
    ns1:textoExtracto "hay que poner en el parámetro ABSOFF el valor que tiene el regulador en PP177 ó PP178" ;
    ns1:valor "PP177/178" .

ns1:Carpeta_CONFIGURATION a ns1:InterfazUsuario ;
    rdfs:label "Carpeta CONFIGURATION" ;
    ns1:textoExtracto "el CNC dispone de una carpeta MTB diferente para cada tipo de software instalado en CONFIGURATION" ;
    ns1:tieneComponente ns1:Carpeta_MTB_M,
        ns1:Carpeta_MTB_T .

ns1:Carpeta_MTB_M a ns1:InterfazUsuario ;
    rdfs:label "Carpeta MTB_M (Fresadora)" ;
    ns1:identificador "MTB_M" ;
    ns1:textoExtracto "MTB_M para fresadora" .

ns1:Carpeta_MTB_T a ns1:InterfazUsuario ;
    rdfs:label "Carpeta MTB_T (Torno)" ;
    ns1:identificador "MTB_T" ;
    ns1:textoExtracto "MTB_T para el torno" .

