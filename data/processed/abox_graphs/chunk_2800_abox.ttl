@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_9342 a ns1:AvisoSeguridad ;
    rdfs:label "Offset de cinemática fuera de rango" ;
    ns1:identificador "9342" ;
    ns1:textoExtracto "'Offset de la cinemática fuera del rango permitido por el valor máximo' DETECCIÓN Durante la validación de parámetros máquina o escritura de una variable. CAUSA El offset definido para la cinemática está fuera del rango permitido por el parámetro máquina. SOLUCIÓN Asignar a la variable V.MPK.OFTDATAkin[nb] de la cinemática un valor que esté comprendido entre '-MAX OFFSET' y '+MAX OFFSET' (rango definido por el parámetro máquina de la cinemática correspondiente)." .

ns1:AvisoSeguridad_9343 a ns1:AvisoSeguridad ;
    rdfs:label "Variable DRV duplicada" ;
    ns1:identificador "9343" ;
    ns1:textoExtracto "9343 Variable DRV ya existente. DETECCIÓN Durante la validación de los parámetros máquina o la definición de variables del regulador. CAUSA La variable DRV ya existe en los parámetros máquina OEM. SOLUCIÓN Revisar la definición de la variable." .

ns1:AvisoSeguridad_9344 a ns1:AvisoSeguridad ;
    rdfs:label "Conflicto de mnemónico en variables DRV" ;
    ns1:identificador "9344" ;
    ns1:textoExtracto "9344 Variables DRV de eje y de nodo no pueden tener el mismo MNEMONIC. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Dos variables diferentes no pueden tener el mismo mnemónico. SOLUCIÓN Definir las variables DRV con diferente mnemónico." .

ns1:AvisoSeguridad_9345 a ns1:AvisoSeguridad ;
    rdfs:label "Inconsistencia en mnemónico de variables DRV (MLINK)" ;
    ns1:identificador "9345" ;
    ns1:textoExtracto "9345 MLINK: Variables DRV con igual ID y TYPE no pueden tener diferente MNEMÓNIC. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En los parámetros máquina OEM, hay variables de regulador (DRV) con el mismo identificador (ID) y del mismo tipo de acceso (TYPE), pero diferente mnemónico. SOLUCIÓN Las variables DRV con el mismo identificador deben tener el mismo mnemónico." .

ns1:AvisoSeguridad_9346 a ns1:AvisoSeguridad ;
    rdfs:label "Inconsistencia en modo de variables DRV (MLINK)" ;
    ns1:identificador "9346" ;
    ns1:textoExtracto "9346 MLINK: Variables DRV con igual ID y diferente MNEMÓNIC no pueden tener diferente MODE. DETECCIÓN Durante la validación de los parámetros máquina." .

ns1:Parametro_MAX_OFFSET a ns1:Parametro ;
    rdfs:label "Parámetro MAX OFFSET (rango de offset)" ;
    ns1:identificador "MAX_OFFSET" ;
    ns1:textoExtracto "'-MAX OFFSET' y '+MAX OFFSET' (rango definido por el parámetro máquina de la cinemática correspondiente)" .

ns1:Parametro_V_MPK_OFTDATAkin a ns1:Parametro ;
    rdfs:label "Variable V.MPK.OFTDATAkin[nb]" ;
    ns1:identificador "V.MPK.OFTDATAkin" ;
    ns1:textoExtracto "variable V.MPK.OFTDATAkin[nb] de la cinemática" .

ns1:Sistema_RCS_S a ns1:Sistema ;
    rdfs:label "Módulo RCS-S (salidas analógicas)" ;
    ns1:textoExtracto "módulo RCS-S" ;
    ns1:tieneComponente ns1:Parametro_ANAOUTID .

ns1:Alarma_ANAOUTID a ns1:Alarma ;
    rdfs:label "Alarma ANAOUTID: Detección de conflicto en salida analógica" ;
    ns1:identificador "9341" ;
    ns1:textoExtracto "ANAOUTID' DETECCIÓN Durante el arranque del CNC o la validación de los parámetros máquina. CAUSA El set activo en varios ejes está utilizando la misma salida analógica de un módulo RCS-S (parámetro ANAUOTID). SOLUCIÓN Dos set activos no pueden compartir la misma salida analógica. Activar un set diferente en algún eje o configurar una salida analógica diferente en el set." .

ns1:Parametro_ANAOUTID a ns1:Parametro ;
    rdfs:label "Parámetro ANAOUTID (salida analógica)" ;
    ns1:identificador "ANAOUTID" ;
    ns1:monitoreaParametro ns1:Alarma_ANAOUTID ;
    ns1:textoExtracto "parámetro ANAUOTID" .

