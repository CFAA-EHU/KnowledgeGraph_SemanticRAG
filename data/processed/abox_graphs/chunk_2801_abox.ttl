@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaRegulacionOEM a ns1:Sistema ;
    rdfs:label "Sistema de regulación OEM"@es ;
    ns1:textoExtracto "En los parámetros máquina OEM, hay variables de regulador (DRV) con el mismo identificador (ID)."@es ;
    ns1:tieneComponente ns1:ParametroDRV_Identificador,
        ns1:ParametroDRV_Mnemonico,
        ns1:ParametroDRV_Modo .

ns1:ValidacionParametrosMaquina_9346 a ns1:DiagnosticoFallo ;
    rdfs:label "Validación de parámetros máquina (ID 9346)"@es ;
    ns1:identificador "9346" ;
    ns1:monitoreaParametro ns1:ParametroDRV_Identificador,
        ns1:ParametroDRV_Mnemonico,
        ns1:ParametroDRV_Modo ;
    ns1:textoExtracto "MLINK: Variables DRV con igual ID y diferente MNEMÓNIC no pueden tener diferente MODE. DETECCIÓN Durante la validación de los parámetros máquina."@es .

ns1:ParametroDRV_Identificador a ns1:Parametro ;
    rdfs:label "Parámetro DRV ID"@es ;
    ns1:textoExtracto "Variables DRV con igual ID [...]."@es .

ns1:ParametroDRV_Mnemonico a ns1:Parametro ;
    rdfs:label "Parámetro DRV MNEMÓNIC"@es ;
    ns1:textoExtracto "Variables DRV con [...] diferente MNEMÓNIC."@es .

ns1:ParametroDRV_Modo a ns1:Parametro ;
    rdfs:label "Parámetro DRV MODE"@es ;
    ns1:textoExtracto "Variables DRV [...] no pueden tener diferente MODE."@es .

