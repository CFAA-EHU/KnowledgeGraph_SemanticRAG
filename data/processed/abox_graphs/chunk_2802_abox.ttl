@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_9347 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje repetido en VOLCOMP"@es ;
    ns1:identificador "9347" ;
    ns1:solucionaFallo ns1:Parametro_VCOMPAXIS,
        ns1:Parametro_VMOVAXIS ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA En los parámetros VMOVAXIS o VCOMPAXIS de la compensación volumétrica está definido el mismo eje dos veces. SOLUCIÓN Corregir los parámetros máquina."@es .

ns1:DiagnosticoFallo_9348 a ns1:DiagnosticoFallo ;
    rdfs:label "Ajuste del eje rotativo fuera de rango"@es ;
    ns1:identificador "9348" ;
    ns1:solucionaFallo ns1:Parametro_VK_MAXROTCOMP ;
    ns1:textoExtracto "Ajuste del eje rotativo, (valor medido=%d) fuera del rango permitido por el valor máximo (V.K.MAXROTCOMP=%d) en el eje %s. DETECCIÓN Durante la calibración de cinemáticas. CAUSA El valor medido es mayor que el máximo permitido (V.K.MAXROTCOMP). SOLUCIÓN Cambiar el valor de V.K.MAXROTCOMP en la subrutina KINCAL_BEGIN.NC o el valor compensado quedará limitado a ese valor."@es .

ns1:DiagnosticoFallo_9349 a ns1:DiagnosticoFallo ;
    rdfs:label "Feedback del SET activo del eje no conectado"@es ;
    ns1:identificador "9349" ;
    ns1:solucionaFallo ns1:Sensor_FeedbackEje ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El feedback definido en el set activo del eje no está conectado. SOLUCIÓN Revisar las conexiones."@es .

ns1:DiagnosticoFallo_9350 a ns1:DiagnosticoFallo ;
    rdfs:label "Motor del SET activo del eje no conectado"@es ;
    ns1:identificador "9350" ;
    ns1:solucionaFallo ns1:ComponenteElectrico_MotorEje ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El motor definido en el set activo del eje no está conectado. SOLUCIÓN Revisar las conexiones."@es .

ns1:DiagnosticoFallo_9351 a ns1:DiagnosticoFallo ;
    rdfs:label "DEFAULTSET no coincide con M41SET..M44SET"@es ;
    ns1:identificador "9351" ;
    ns1:solucionaFallo ns1:Parametro_DEFAULTSET ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro DEFAULTSET tiene un valor incorrecto."@es .

ns1:DiagnosticoFallo_ModoAccesoDRV a ns1:DiagnosticoFallo ;
    rdfs:label "Variables DRV con MODE inconsistente"@es ;
    ns1:solucionaFallo ns1:Parametro_DRV_MODE,
        ns1:Parametro_DRV_TYPE ;
    ns1:textoExtracto "DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En los parámetros máquina OEM, hay variables de regulador (DRV) con el mismo identificador (ID), diferente mnemónico y diferente modo de acceso (MODE). SOLUCIÓN Las variables DRV con el mismo identificador deben tener el mismo tipo de acceso (parámetro TYPE) y el mismo modo de acceso (parámetro MODE)."@es .

ns1:ComponenteElectrico_MotorEje a ns1:ComponenteElectrico ;
    rdfs:label "Motor del eje"@es ;
    ns1:textoExtracto "El motor definido en el set activo del eje no está conectado"@es .

ns1:Parametro_DEFAULTSET a ns1:Parametro ;
    rdfs:label "DEFAULTSET" ;
    ns1:identificador "DEFAULTSET" ;
    ns1:textoExtracto "El parámetro DEFAULTSET tiene un valor incorrecto"@es .

ns1:Parametro_DRV_MODE a ns1:Parametro ;
    rdfs:label "DRV MODE" ;
    ns1:identificador "MODE" ;
    ns1:textoExtracto "modo de acceso (MODE)"@es .

ns1:Parametro_DRV_TYPE a ns1:Parametro ;
    rdfs:label "DRV TYPE" ;
    ns1:identificador "TYPE" ;
    ns1:textoExtracto "tipo de acceso (parámetro TYPE)"@es .

ns1:Parametro_VCOMPAXIS a ns1:Parametro ;
    rdfs:label "VCOMPAXIS" ;
    ns1:identificador "VCOMPAXIS" ;
    ns1:textoExtracto "parámetros VMOVAXIS o VCOMPAXIS de la compensación volumétrica"@es .

ns1:Parametro_VK_MAXROTCOMP a ns1:Parametro ;
    rdfs:label "V.K.MAXROTCOMP" ;
    ns1:identificador "V.K.MAXROTCOMP" ;
    ns1:textoExtracto "valor máximo permitido (V.K.MAXROTCOMP)"@es ;
    ns1:valor "límite de compensación rotativa"@es .

ns1:Parametro_VMOVAXIS a ns1:Parametro ;
    rdfs:label "VMOVAXIS" ;
    ns1:identificador "VMOVAXIS" ;
    ns1:textoExtracto "parámetros VMOVAXIS o VCOMPAXIS de la compensación volumétrica"@es .

ns1:Sensor_FeedbackEje a ns1:Sensor ;
    rdfs:label "Feedback del eje"@es ;
    ns1:textoExtracto "El feedback definido en el set activo del eje no está conectado"@es .

