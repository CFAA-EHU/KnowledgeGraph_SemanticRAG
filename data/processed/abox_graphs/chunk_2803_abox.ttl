@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_9351 a ns1:DiagnosticoFallo ;
    ns1:identificador "9351" ;
    ns1:solucionaFallo ns1:Parametro_DEFAULTSET ;
    ns1:textoExtracto "DEFAULTSET debe coincidir con M41SET..M44SET en cabezales. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro DEFAULTSET tiene un valor incorrecto. SOLUCIÓN El valor de DEFAULTSET debe coincidir con uno de los valores definidos en M41SET a M44SET." .

ns1:DiagnosticoFallo_9352 a ns1:DiagnosticoFallo ;
    ns1:identificador "9352" ;
    ns1:solucionaFallo ns1:Parametro_CAXSET ;
    ns1:textoExtracto "CAXSET debe coincidir con M41SET..M44SET en cabezales. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina." .

ns1:Parametro_M41SET a ns1:Parametro ;
    rdfs:label "M41SET" ;
    ns1:textoExtracto "DEFAULTSET debe coincidir con M41SET..M44SET en cabezales. CAXSET debe coincidir con M41SET..M44SET en cabezales." .

ns1:Parametro_M42SET a ns1:Parametro ;
    rdfs:label "M42SET" ;
    ns1:textoExtracto "DEFAULTSET debe coincidir con M41SET..M44SET en cabezales. CAXSET debe coincidir con M41SET..M44SET en cabezales." .

ns1:Parametro_M43SET a ns1:Parametro ;
    rdfs:label "M43SET" ;
    ns1:textoExtracto "DEFAULTSET debe coincidir con M41SET..M44SET en cabezales. CAXSET debe coincidir con M41SET..M44SET en cabezales." .

ns1:Parametro_M44SET a ns1:Parametro ;
    rdfs:label "M44SET" ;
    ns1:textoExtracto "DEFAULTSET debe coincidir con M41SET..M44SET en cabezales. CAXSET debe coincidir con M41SET..M44SET en cabezales." .

ns1:Parametro_CAXSET a ns1:Parametro ;
    rdfs:label "CAXSET" ;
    ns1:monitoreaParametro ns1:Sistema_ValidacionArranque ;
    ns1:textoExtracto "CAXSET debe coincidir con M41SET..M44SET en cabezales." .

ns1:Parametro_DEFAULTSET a ns1:Parametro ;
    rdfs:label "DEFAULTSET" ;
    ns1:monitoreaParametro ns1:Sistema_ValidacionArranque ;
    ns1:textoExtracto "El parámetro DEFAULTSET tiene un valor incorrecto. El valor de DEFAULTSET debe coincidir con uno de los valores definidos en M41SET a M44SET." .

ns1:Sistema_ValidacionArranque a ns1:Sistema ;
    rdfs:label "Sistema de validación de parámetros durante el arranque" ;
    ns1:textoExtracto "Durante el arranque del sistema o validación de los parámetros máquina." ;
    ns1:tieneComponente ns1:Parametro_CAXSET,
        ns1:Parametro_DEFAULTSET,
        ns1:Parametro_M41SET,
        ns1:Parametro_M42SET,
        ns1:Parametro_M43SET,
        ns1:Parametro_M44SET .

