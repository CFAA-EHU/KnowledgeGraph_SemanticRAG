@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ValidacionParametros a ns1:Sistema ;
    rdfs:label "Sistema de validación de parámetros máquina" ;
    ns1:activaAlarma ns1:Alarma_9352,
        ns1:Alarma_9353,
        ns1:Alarma_9355,
        ns1:Alarma_9356,
        ns1:Alarma_9357,
        ns1:Alarma_9358 ;
    ns1:monitoreaParametro ns1:Parametro_CAXSET,
        ns1:Parametro_COMPAXIS,
        ns1:Parametro_COMPTABLEID,
        ns1:Parametro_DEFAULTSET,
        ns1:Parametro_M41SET,
        ns1:Parametro_M42SET,
        ns1:Parametro_M43SET,
        ns1:Parametro_M44SET,
        ns1:Parametro_MOVAXIS,
        ns1:Parametro_OPMODE,
        ns1:Parametro_SYNCSET ;
    ns1:textoExtracto "Durante el arranque del sistema o validación de los parámetros máquina." .

ns1:Alarma_9352 a ns1:Alarma ;
    rdfs:label "Alarma 9352: CAXSET no coincide con M41SET..M44SET" ;
    ns1:identificador "9352" ;
    ns1:textoExtracto "9352 CAXSET debe coincidir con M41SET..M44SET en cabezales. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro DEFAULTSET tiene un valor incorrecto. SOLUCIÓN El valor de DEFAULTSET debe coincidir con uno de los valores definidos en M41SET a M44SET." .

ns1:Alarma_9353 a ns1:Alarma ;
    rdfs:label "Alarma 9353: SYNCSET no coincide con M41SET..M44SET" ;
    ns1:identificador "9353" ;
    ns1:textoExtracto "9353 SYNCSET debe coincidir con M41SET..M44SET en cabezales. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El parámetro DEFAULTSET tiene un valor incorrecto. SOLUCIÓN El valor de DEFAULTSET debe coincidir con uno de los valores definidos en M41SET a M44SET." .

ns1:Alarma_9355 a ns1:Alarma ;
    rdfs:label "Alarma 9355: Ejes maestro/esclavo con OPMODE distinto" ;
    ns1:identificador "9355" ;
    ns1:textoExtracto "9355 Los ejes maestro y esclavo deben tener el mismo OPMODE. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA En un eje gantry, el eje maestro y esclavo no tiene el parámetro OPMODE igual. SOLUCIÓN El parámetro OPMODE debe ser igual en ambos ejes." .

ns1:Alarma_9356 a ns1:Alarma ;
    rdfs:label "Alarma 9356: Compensación de husillo doblemente definida" ;
    ns1:identificador "9356" ;
    ns1:textoExtracto "9356 Compensación de husillo doblemente definida. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Hay asignadas dos compensaciones de husillo iguales (parámetros MOVAXIS y COMPAXIS iguales) a un mismo eje. SOLUCIÓN Asignar al eje una única compensación de husillo." .

ns1:Alarma_9357 a ns1:Alarma ;
    rdfs:label "Alarma 9357: Eje COMPAXIS de compensación no válido" ;
    ns1:identificador "9357" ;
    ns1:textoExtracto "9357 El eje COMPAXIS de la compensación seleccionada no es válido. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El eje tiene asignada una compensación cuyo eje compensado no coincide con el eje. La compensación no tiene ningún efecto en el movimiento del eje. SOLUCIÓN Asignar a COMPTABLEID un valor adecuado." .

ns1:Alarma_9358 a ns1:Alarma ;
    rdfs:label "Alarma 9358: Compensación no definida" ;
    ns1:identificador "9358" ;
    ns1:textoExtracto "9358 Compensación no definida. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El parámetro COMPTABLEID tiene un valor que ya no existe. La compensación no ha sido eliminada." .

ns1:Parametro_CAXSET a ns1:Parametro ;
    rdfs:label "Parámetro CAXSET" ;
    ns1:textoExtracto "CAXSET debe coincidir con M41SET..M44SET en cabezales." .

ns1:Parametro_COMPAXIS a ns1:Parametro ;
    rdfs:label "Parámetro COMPAXIS" ;
    ns1:textoExtracto "parámetros MOVAXIS y COMPAXIS iguales." .

ns1:Parametro_COMPTABLEID a ns1:Parametro ;
    rdfs:label "Parámetro COMPTABLEID" ;
    ns1:textoExtracto "El parámetro COMPTABLEID tiene un valor que ya no existe." .

ns1:Parametro_DEFAULTSET a ns1:Parametro ;
    rdfs:label "Parámetro DEFAULTSET" ;
    ns1:textoExtracto "El parámetro DEFAULTSET tiene un valor incorrecto." .

ns1:Parametro_M41SET a ns1:Parametro ;
    rdfs:label "Parámetro M41SET" ;
    ns1:textoExtracto "valores definidos en M41SET a M44SET." .

ns1:Parametro_M42SET a ns1:Parametro ;
    rdfs:label "Parámetro M42SET" ;
    ns1:textoExtracto "valores definidos en M41SET a M44SET." .

ns1:Parametro_M43SET a ns1:Parametro ;
    rdfs:label "Parámetro M43SET" ;
    ns1:textoExtracto "valores definidos en M41SET a M44SET." .

ns1:Parametro_M44SET a ns1:Parametro ;
    rdfs:label "Parámetro M44SET" ;
    ns1:textoExtracto "valores definidos en M41SET a M44SET." .

ns1:Parametro_MOVAXIS a ns1:Parametro ;
    rdfs:label "Parámetro MOVAXIS" ;
    ns1:textoExtracto "parámetros MOVAXIS y COMPAXIS iguales." .

ns1:Parametro_OPMODE a ns1:Parametro ;
    rdfs:label "Parámetro OPMODE" ;
    ns1:textoExtracto "Los ejes maestro y esclavo deben tener el mismo OPMODE." .

ns1:Parametro_SYNCSET a ns1:Parametro ;
    rdfs:label "Parámetro SYNCSET" ;
    ns1:textoExtracto "SYNCSET debe coincidir con M41SET..M44SET en cabezales." .

