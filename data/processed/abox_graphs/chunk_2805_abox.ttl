@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_COMPTABLEID a ns1:Parametro ;
    rdfs:label "COMPTABLEID" ;
    ns1:monitoreaParametro ns1:Fallo_9358 ;
    ns1:textoExtracto "El parámetro COMPTABLEID tiene un valor que ya no existe." .

ns1:Tabla_ParametrosMaquina a ns1:Tabla ;
    rdfs:label "Tabla de parámetros máquina" ;
    ns1:documentadoEn ns1:Fallo_9360 ;
    ns1:textoExtracto "Se ha intentado validar la tabla de parámetros máquina durante un cambio" .

ns1:Fallo_9358 a ns1:DiagnosticoFallo ;
    rdfs:label "Compensación no definida" ;
    ns1:identificador "9358" ;
    ns1:textoExtracto "Compensación no definida. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA El parámetro COMPTABLEID tiene un valor que ya no existe. La compensación no ha sido eliminada. SOLUCIÓN Asignar a COMPTABLEID un valor que exista." .

ns1:Fallo_9360 a ns1:DiagnosticoFallo ;
    rdfs:label "Validación de parámetros durante cambio de gama" ;
    ns1:identificador "9360" ;
    ns1:textoExtracto "No es posible validar parámetros de un eje con un cambio de gama en proceso. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Se ha intentado validar la tabla de parámetros máquina durante un cambio" .

