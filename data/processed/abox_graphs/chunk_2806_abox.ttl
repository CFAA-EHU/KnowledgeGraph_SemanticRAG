@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_9361 a ns1:DiagnosticoFallo ;
    rdfs:label "Cambio de número de canales/ejes/cabezales requiere rearranque" ;
    ns1:identificador "9361" ;
    ns1:monitoreaParametro ns1:Parametro_CanalesEjesCabezales ;
    ns1:textoExtracto "Para modificar el número de canales, ejes o cabezales es necesario rearrancar el CNC. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Se ha intentado validar la tabla de parámetros máquina tras modificar el número de canales, ejes o cabezales. SOLUCIÓN Para validar el número de canales, ejes o cabezales es necesario rearrancar el CNC." .

ns1:Fallo_9364 a ns1:DiagnosticoFallo ;
    rdfs:label "Conflicto de REFERENCEID compartido en ejes/cabezales" ;
    ns1:identificador "9364" ;
    ns1:monitoreaParametro ns1:Parametro_REFERENCEID ;
    ns1:textoExtracto "Distintos ejes/cabezales no pueden compartir el mismo REFERENCEID al mismo tiempo. DETECCIÓN Durante el arranque o validación de los parámetros máquina. CAUSA Dos ejes o cabezales comparten simultáneamente la misma referencia. SOLUCIÓN Revisar la parametrización de DEFAULTSET y REFERENCEID de los distintos sets de los ejes/cabezales implicados." .

ns1:Fallo_9369 a ns1:DiagnosticoFallo ;
    rdfs:label "DEFAULTSET incompatible con REFERENCEID compartido" ;
    ns1:identificador "9369" ;
    ns1:monitoreaParametro ns1:Parametro_DEFAULTSET ;
    ns1:textoExtracto "DEFAULSET incompatible con ejes/cabezales que comparten el mismo REFERENCEID. DETECCIÓN Durante el arranque o validación de los parámetros máquina. CAUSA Dos ejes o cabezales comparten simultáneamente la misma referencia. SOLUCIÓN Revisar la parametrización de DEFAULTSET y REFERENCEID de los distintos sets de los ejes/cabezales implicados." .

ns1:Fallo_9370 a ns1:DiagnosticoFallo ;
    rdfs:label "CURRBFID no admitido en ejes analógicos" ;
    ns1:identificador "9370" ;
    ns1:monitoreaParametro ns1:Parametro_CURRBFID ;
    ns1:textoExtracto "No se admite CURRBFID en ejes analógicos. DETECCIÓN Durante el arranque o validación de los parámetros máquina. CAUSA Se ha parametrizado CURRFBID para un eje/cabezal analógico. SOLUCIÓN Para eje/cabezal analógico, dejar esta parámetro en blanco." .

ns1:Fallo_9371 a ns1:DiagnosticoFallo ;
    rdfs:label "Motor desconocido (AUTODETECT fallido)" ;
    ns1:identificador "9371" ;
    ns1:monitoreaParametro ns1:Parametro_AUTODETECT ;
    ns1:textoExtracto "Motor desconocido. DETECCIÓN Durante el arranque o validación de los parámetros máquina. CAUSA El CNC no reconoce un motor parametrizado como AUTODETECT; el motor no está disponible en Motors.xml." .

ns1:Fallo_CambioGama a ns1:DiagnosticoFallo ;
    rdfs:label "Validación de parámetros durante cambio de gama" ;
    ns1:monitoreaParametro ns1:Parametro_TablaMaquina ;
    ns1:textoExtracto "eje con un cambio de gama en proceso. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Se ha intentado validar la tabla de parámetros máquina durante un cambio de gama. SOLUCIÓN Esperar a que acabe el cambio de gama para validar los parámetros máquina." .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "CNC" ;
    ns1:tieneComponente ns1:Componente_MotorDesconocido .

ns1:Componente_MotorDesconocido a ns1:ComponenteElectrico ;
    rdfs:label "Motor no reconocido" ;
    ns1:textoExtracto "motor parametrizado como AUTODETECT; el motor no está disponible en Motors.xml" .

ns1:Parametro_AUTODETECT a ns1:Parametro ;
    rdfs:label "AUTODETECT (motores)" ;
    ns1:textoExtracto "AUTODETECT" .

ns1:Parametro_CURRBFID a ns1:Parametro ;
    rdfs:label "CURRBFID" ;
    ns1:textoExtracto "CURRBFID" .

ns1:Parametro_CanalesEjesCabezales a ns1:Parametro ;
    rdfs:label "Número de canales/ejes/cabezales" ;
    ns1:textoExtracto "número de canales, ejes o cabezales" .

ns1:Parametro_DEFAULTSET a ns1:Parametro ;
    rdfs:label "DEFAULTSET" ;
    ns1:textoExtracto "DEFAULTSET" .

ns1:Parametro_REFERENCEID a ns1:Parametro ;
    rdfs:label "REFERENCEID" ;
    ns1:textoExtracto "REFERENCEID" .

ns1:Parametro_TablaMaquina a ns1:Parametro ;
    rdfs:label "Tabla de parámetros máquina" ;
    ns1:textoExtracto "tabla de parámetros máquina" .

