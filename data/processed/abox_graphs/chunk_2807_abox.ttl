@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_9371 a ns1:DiagnosticoFallo ;
    rdfs:label "Motor desconocido"@es ;
    ns1:identificador "9371" ;
    ns1:monitoreaParametro ns1:Parametro_MOT_NAME ;
    ns1:textoExtracto "Motor desconocido. DETECCIÓN Durante el arranque o validación de los parámetros máquina. CAUSA El CNC no reconoce un motor parametrizado como AUTODETECT; el motor no está disponible en Motors.xml. SOLUCIÓN Definir el motor indicando en MOT_NAME su matrícula."@es .

ns1:Fallo_9372 a ns1:DiagnosticoFallo ;
    rdfs:label "Nuevo motor detectado"@es ;
    ns1:identificador "9372" ;
    ns1:textoExtracto "Nuevo motor detectado. DETECCIÓN Durante el arranque o validación de los parámetros máquina."@es .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:controla ns1:ComponenteElectrico_MotorDesconocido ;
    ns1:textoExtracto "El CNC no reconoce un motor parametrizado como AUTODETECT"@es .

ns1:ComponenteElectrico_MotorDesconocido a ns1:ComponenteElectrico ;
    rdfs:label "Motor no reconocido (AUTODETECT)"@es ;
    ns1:monitoreaParametro ns1:Parametro_MOT_NAME ;
    ns1:textoExtracto "el motor no está disponible en Motors.xml"@es .

ns1:Parametro_MOT_NAME a ns1:Parametro ;
    rdfs:label "MOT_NAME (matrícula del motor)"@es ;
    ns1:textoExtracto "Definir el motor indicando en MOT_NAME su matrícula."@es .

