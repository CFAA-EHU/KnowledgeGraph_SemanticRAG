@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_9376 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en parámetros MOVAXIS" ;
    ns1:identificador "9376" ;
    ns1:solucionaFallo ns1:Parametro_MOVAXIS ;
    ns1:textoExtracto "Todos los ejes lineales o todos rotativos y máximo 2 rotativos. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Los MOVAXIS introducidos en la tabla son incorrectos. SOLUCIÓN Revisar los parámetros MOVAXIS." .

ns1:Fallo_9379 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en comando de acceso al captador Stegmann" ;
    ns1:identificador "9379" ;
    ns1:solucionaFallo ns1:Parametro_ComandoStegmann ;
    ns1:textoExtracto "Error en la ejecución del comando de acceso al captador Stegmann. DETECCIÓN Durante la ejecución. CAUSA Error durante el proceso. SOLUCIÓN Revisar los parámetros del comando, el conexionado y el estado y tipo de captador." .

ns1:Fallo_9380 a ns1:DiagnosticoFallo ;
    rdfs:label "Correcciones duplicadas para misma posición" ;
    ns1:identificador "9380" ;
    ns1:solucionaFallo ns1:Tabla_CompensacionCruzada,
        ns1:Tabla_CompensacionHusillo ;
    ns1:textoExtracto "No se permiten correcciones distintas para una misma posición. DETECCIÓN Durante la validación de los parámetros máquina. CAUSA La tabla de compensación de husillo o una tabla de compensación cruzada del eje, tiene definidas distintas correcciones para una misma posición. SOLUCIÓN Revisar las tablas de compensación." .

ns1:Parametro_AXISCH a ns1:Parametro ;
    rdfs:label "AXISCH" ;
    ns1:identificador "AXISCH" ;
    ns1:textoExtracto "utilizar los parámetros LOOPCH, AXISCH, PP55 para cambiar el signo." .

ns1:Parametro_LOOPCH a ns1:Parametro ;
    rdfs:label "LOOPCH" ;
    ns1:identificador "LOOPCH" ;
    ns1:textoExtracto "utilizar los parámetros LOOPCH, AXISCH, PP55 para cambiar el signo." .

ns1:Parametro_M19SPDLEREV a ns1:Parametro ;
    rdfs:label "M19SPDLEREV" ;
    ns1:identificador "M19SPDLEREV" ;
    ns1:textoExtracto "Parametrizar M19SPDLEREV=FALSE y utilizar los parámetros LOOPCH, AXISCH, PP55 para cambiar el signo." ;
    ns1:valor "FALSE" .

ns1:Parametro_PP55 a ns1:Parametro ;
    rdfs:label "PP55" ;
    ns1:identificador "PP55" ;
    ns1:textoExtracto "utilizar los parámetros LOOPCH, AXISCH, PP55 para cambiar el signo." .

ns1:Sensor_Stegmann a ns1:Sensor ;
    rdfs:label "Captador Stegmann" ;
    ns1:textoExtracto "Error en la ejecución del comando de acceso al captador Stegmann." .

ns1:Parametro_ComandoStegmann a ns1:Parametro ;
    rdfs:label "Comando acceso captador Stegmann" ;
    ns1:textoExtracto "Revisar los parámetros del comando, el conexionado y el estado y tipo de captador." .

ns1:Parametro_MOVAXIS a ns1:Parametro ;
    rdfs:label "MOVAXIS" ;
    ns1:identificador "MOVAXIS" ;
    ns1:textoExtracto "Los MOVAXIS introducidos en la tabla son incorrectos." .

ns1:Tabla_CompensacionCruzada a ns1:Tabla ;
    rdfs:label "Tabla de compensación cruzada del eje" ;
    ns1:textoExtracto "una tabla de compensación cruzada del eje, tiene definidas distintas correcciones para una misma posición." .

ns1:Tabla_CompensacionHusillo a ns1:Tabla ;
    rdfs:label "Tabla de compensación de husillo" ;
    ns1:textoExtracto "La tabla de compensación de husillo [...] tiene definidas distintas correcciones para una misma posición." .

