@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SoporteUnicode_CNC a ns1:InterfazUsuario ;
    rdfs:label "Soporte Unicode en editor CNC"@es ;
    ns1:documentadoEn ns1:ManualBroaching ;
    ns1:textoExtracto "El editor del CNC admite caracteres Unicode. Los programas en formato Unicode no son compatibles con versiones anteriores a la versión V4.00."@es .

ns1:ActualizacionSoftware_V4_00 a ns1:TareaMantenimiento ;
    rdfs:label "Actualización del software a versión V4.00"@es ;
    ns1:identificador "V4.00" ;
    ns1:requiereMantenimiento ns1:Parametro_COUNTERTYPE_EjesSercos ;
    ns1:textoExtracto "Al actualizar el software, el CNC respeta la carpeta MTB original. [...] Al instalar la versión V4.00 no se garantiza que el CNC mantenga los orígenes activos ni el estado de las marcas de sincronización."@es .

ns1:ErrorE9332_EjesSercos a ns1:AvisoSeguridad ;
    rdfs:label "Error E9332: Incompatibilidad en parámetros de ejes Sercos"@es ;
    ns1:identificador "E9332" ;
    ns1:textoExtracto "Error E9332 por cada eje Sercos con captación externa. Este error indica que los valores de los parámetros COUNTERTYPE y COUNTERID son incompatibles."@es .

ns1:MaquinaCNC_Broaching a ns1:Maquina ;
    rdfs:label "Máquina CNC (Broaching)"@es ;
    ns1:requiereMantenimiento ns1:ActualizacionSoftware_V4_00 ;
    ns1:textoExtracto "Al actualizar el software, el CNC respeta la carpeta MTB original. En este caso, si al cambiar el código de validación cambia el tipo de máquina, el CNC no moverá la carpeta MTB."@es ;
    ns1:tieneComponente ns1:SistemaEjesSercos .

ns1:Parametro_COUNTERID_EjesSercos a ns1:Parametro ;
    rdfs:label "Parámetro COUNTERID (ejes Sercos)"@es ;
    ns1:textoExtracto "Los valores de los parámetros COUNTERTYPE y COUNTERID son incompatibles (error E9332)."@es .

ns1:SistemaEjesSercos a ns1:Sistema ;
    rdfs:label "Sistema de ejes Sercos con captación externa"@es ;
    ns1:controla ns1:MaquinaCNC_Broaching ;
    ns1:textoExtracto "Durante la actualización desde una versión V3.00 o posterior, el CNC mostrará un error E9332 por cada eje Sercos con captación externa."@es ;
    ns1:tieneComponente ns1:Parametro_COUNTERID_EjesSercos,
        ns1:Parametro_COUNTERTYPE_EjesSercos .

ns1:Parametro_COUNTERTYPE_EjesSercos a ns1:Parametro ;
    rdfs:label "Parámetro COUNTERTYPE (ejes Sercos)"@es ;
    ns1:monitoreaParametro ns1:ErrorE9332_EjesSercos ;
    ns1:textoExtracto "El valor del parámetro COUNTERTYPE debe cambiarse de 'remoto' a 'regulador' en los ejes implicados para corregir el error E9332."@es ;
    ns1:valor "regulador"@es,
        "remoto"@es .

