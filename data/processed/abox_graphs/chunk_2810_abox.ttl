@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_9381 a ns1:DiagnosticoFallo ;
    rdfs:label "Error: Múltiples volantes HBH no admitidos"@es ;
    ns1:identificador "9381" ;
    ns1:solucionaFallo ns1:Accion_ValidacionParametros ;
    ns1:textoExtracto "No se admite más de 1 volante tipo HBH. [...] SOLUCIÓN El CNC sólo permite un volante HBH."@es .

ns1:Fallo_9382 a ns1:DiagnosticoFallo ;
    rdfs:label "Error: Configuración de buses requiere reinicio"@es ;
    ns1:identificador "9382" ;
    ns1:solucionaFallo ns1:Accion_ReinicioCNC ;
    ns1:textoExtracto "configuración de buses, necesita reiniciar CNC. [...] DETECCIÓN Durante el arranque."@es .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "CNC"@es ;
    ns1:textoExtracto "El CNC sólo permite un volante HBH. [...] El CNC necesita reiniciar."@es .

ns1:Tabla_Compensacion a ns1:Tabla ;
    rdfs:label "Tablas de compensación"@es ;
    ns1:documentadoEn ns1:Manual_Tecnico ;
    ns1:textoExtracto "SOLUCIÓN Revisar las tablas de compensación."@es .

ns1:Accion_ReinicioCNC a ns1:TareaMantenimiento ;
    rdfs:label "Reinicio del CNC"@es ;
    ns1:textoExtracto "necesita reiniciar CNC. [...] DETECCIÓN Durante el arranque."@es .

ns1:Accion_ValidacionParametros a ns1:TareaMantenimiento ;
    rdfs:label "Validación de parámetros máquina"@es ;
    ns1:textoExtracto "Durante la validación de los parámetros máquina."@es .

