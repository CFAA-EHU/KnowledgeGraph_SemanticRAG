@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_9505 a ns1:Alarma ;
    rdfs:label "Alarma de pulsos entre I0s"@es ;
    ns1:activaAlarma ns1:Sistema_Regulador ;
    ns1:identificador "9505" ;
    ns1:textoExtracto "9505 Alarma de pulsos entre I0s. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El regulador ha detectado un error en la correlación del pulsos entre dos señales de I0"@es .

ns1:Componente_Encoder a ns1:ComponenteElectrico ;
    rdfs:label "Encoder"@es ;
    ns1:textoExtracto "conexionado del encoder"@es .

ns1:DiagnosticoFallo_Encoder a ns1:DiagnosticoFallo ;
    ns1:solucionaFallo ns1:Sistema_Regulador ;
    ns1:textoExtracto "Revisar el conexionado del encoder"@es .

ns1:Parametro_Vpp_Encoder a ns1:Parametro ;
    rdfs:label "Señales Vpp del encoder"@es ;
    ns1:textoExtracto "señales Vpp del encoder"@es .

ns1:Sistema_Regulador a ns1:Sistema ;
    ns1:monitoreaParametro ns1:Parametro_Vpp_Encoder ;
    ns1:textoExtracto "El regulador ha detectado un error en las señales Vpp del encoder"@es .

