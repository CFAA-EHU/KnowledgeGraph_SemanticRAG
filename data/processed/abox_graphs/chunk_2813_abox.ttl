@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_9505 a ns1:Alarma ;
    rdfs:label "Alarma de pulsos entre I0s" ;
    ns1:activaAlarma ns1:Regulador ;
    ns1:identificador "9505" ;
    ns1:textoExtracto "9505 Alarma de pulsos entre I0s. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El regulador ha detectado un error en la correlación del pulsos entre dos señales de I0 del encoder. SOLUCIÓN Revisar la parametrización y el conexionado del encoder." .

ns1:Alarma_9506 a ns1:Alarma ;
    rdfs:label "Error de comprobación de CRC de PM" ;
    ns1:activaAlarma ns1:Regulador ;
    ns1:identificador "9506" ;
    ns1:textoExtracto "9506 Error de comprobación de CRC de PM. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error interno del regulador. SOLUCIÓN Contacte con Fagor Automation." .

ns1:Alarma_9507 a ns1:Alarma ;
    rdfs:label "Error en la detección de PM" ;
    ns1:activaAlarma ns1:Regulador ;
    ns1:identificador "9507" ;
    ns1:textoExtracto "9507 Error en la detección de PM. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error interno del regulador. SOLUCIÓN Contacte con Fagor Automation." .

ns1:Alarma_9508 a ns1:Alarma ;
    rdfs:label "Watchdog de regulador" ;
    ns1:activaAlarma ns1:Regulador ;
    ns1:identificador "9508" ;
    ns1:textoExtracto "9508 Watchdog de regulador. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador no responde; posible mal funcionamiento, conexionado, etc. SOLUCIÓN Contacte con Fagor Automation." .

ns1:Alarma_9509 a ns1:Alarma ;
    rdfs:label "Fallo 24 Vdc inesperado" ;
    ns1:activaAlarma ns1:Regulador ;
    ns1:identificador "9509" ;
    ns1:textoExtracto "9509 Fallo 24 Vdc inesperado. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador ha detectado una caída en la tensión de control. SOLUCIÓN Revisar el conexionado y la alimentación de control de 24 Vdc." .

ns1:Alarma_9510 a ns1:Alarma ;
    rdfs:label "Lazos de corriente en mismo nodo incompatibles" ;
    ns1:activaAlarma ns1:Regulador ;
    ns1:identificador "9510" ;
    ns1:textoExtracto "9510 Lazos de corriente en mismo nodo incompatibles. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Un regulador doble tiene configurados modos incompatibles de control para cada motor. SOLUCIÓN En un regulador doble, parametrizar el mismo tipo de control en ambos motores." .

ns1:Alarma_9511 a ns1:Alarma ;
    rdfs:label "Error en la actualización de versión DSP" ;
    ns1:activaAlarma ns1:Regulador ;
    ns1:identificador "9511" ;
    ns1:textoExtracto "9511 Error en la actualización de versión DSP. DETECCIÓN Durante el arranque del sistema. CAUSA El CNC no puede actualizar la versión del DSP en algún regulador o RPS. SOLUCIÓN Compruebe el conexionado. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Alarma_9512 a ns1:Alarma ;
    rdfs:label "Error en la actualización de versión FPGA" ;
    ns1:activaAlarma ns1:Regulador ;
    ns1:identificador "9512" ;
    ns1:textoExtracto "9512 Error en la actualización de versión FPGA. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El CNC no puede actualizar la versión de la FPGA en algún regulador o RPS. SOLUCIÓN Compruebe el conexionado." .

ns1:Encoder a ns1:ComponenteElectrico ;
    rdfs:label "Encoder" ;
    ns1:textoExtracto "Revisar la parametrización y el conexionado del encoder." .

ns1:Sistema a ns1:Sistema ;
    rdfs:label "Sistema" ;
    ns1:textoExtracto "Durante el funcionamiento habitual del sistema." ;
    ns1:tieneComponente ns1:Encoder,
        ns1:Regulador .

ns1:Regulador a ns1:ComponenteElectrico ;
    rdfs:label "Regulador" ;
    ns1:textoExtracto "El regulador ha detectado un error en la correlación del pulsos entre dos señales de I0 del encoder." .

