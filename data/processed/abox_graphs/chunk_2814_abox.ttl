@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteCPLD a ns1:ComponenteElectrico ;
    rdfs:label "CPLD"@es ;
    ns1:textoExtracto "versión CPLD"@es .

ns1:ComponenteFPGA a ns1:ComponenteElectrico ;
    rdfs:label "FPGA"@es ;
    ns1:textoExtracto "versión de la FPGA"@es .

ns1:Error9512FPGA a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la actualización de versión FPGA"@es ;
    ns1:identificador "9512" ;
    ns1:solucionaFallo ns1:ContactarConSoporteTecnico,
        ns1:VerificarConexionadoSinAutorizacion ;
    ns1:textoExtracto "9512 Error en la actualización de versión FPGA. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El CNC no puede actualizar la versión de la FPGA en algún regulador o RPS."@es .

ns1:Error9513CPLD a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la actualización de versión CPLD"@es ;
    ns1:identificador "9513" ;
    ns1:textoExtracto "9513 Error en la actualización de versión CPLD. DETECCIÓN Durante el"@es .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:textoExtracto "el CNC no puede actualizar la versión de la FPGA en algún regulador o RPS"@es ;
    ns1:tieneComponente ns1:RPS_0d84cce1ea,
        ns1:ReguladorConFPGA .

ns1:ContactarConSoporteTecnico a ns1:AvisoSeguridad ;
    rdfs:label "Contactar con soporte técnico"@es ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation."@es .

ns1:RPS_0d84cce1ea a ns1:ComponenteElectrico ;
    rdfs:label "RPS"@es ;
    ns1:textoExtracto "RPS"@es .

ns1:ReguladorConFPGA a ns1:ComponenteElectrico ;
    rdfs:label "Regulador con FPGA"@es ;
    ns1:textoExtracto "regulador"@es .

ns1:VerificarConexionadoSinAutorizacion a ns1:AccionProhibida ;
    rdfs:label "Verificar conexionado sin autorización"@es ;
    ns1:textoExtracto "Compruebe el conexionado."@es .

