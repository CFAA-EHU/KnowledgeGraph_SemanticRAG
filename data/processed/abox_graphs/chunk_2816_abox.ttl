@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_9519 a ns1:DiagnosticoFallo ;
    rdfs:label "Recepción de señal de alarma en captación"@es ;
    ns1:identificador "9519" ;
    ns1:textoExtracto "9519 Captación:Recibida señal de alarma. DETECCIÓN"@es .

ns1:Sistema_Principal a ns1:Sistema ;
    rdfs:label "Sistema de arranque y funcionamiento"@es ;
    ns1:textoExtracto "arranque o funcionamiento habitual del sistema"@es ;
    ns1:tieneComponente ns1:Sensor_Captacion .

ns1:Tarea_RevisarConexionado a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de conexionado del captador"@es ;
    ns1:solucionaFallo ns1:Fallo_9518 ;
    ns1:textoExtracto "Revisar el conexionado y el nivel de las señales proporcionadas por el captador"@es .

ns1:Tarea_RevisarSenales a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de señales del captador"@es ;
    ns1:solucionaFallo ns1:Fallo_9518,
        ns1:Fallo_CableAL_Roto ;
    ns1:textoExtracto "Revisar el nivel de las señales proporcionadas por el captador"@es .

ns1:Fallo_CableAL_Roto a ns1:DiagnosticoFallo ;
    rdfs:label "Cable de señal AL y/o /AL roto o desconectado"@es ;
    ns1:textoExtracto "El cable de la señal AL y/o /AL puede estar roto o desconectado."@es .

ns1:Sensor_Captacion a ns1:Sensor ;
    rdfs:label "Captador del sistema"@es ;
    ns1:textoExtracto "señales proporcionadas por el captador"@es .

ns1:Fallo_9518 a ns1:DiagnosticoFallo ;
    rdfs:label "Sobrecorriente o cortocircuito en captación"@es ;
    ns1:identificador "9518" ;
    ns1:textoExtracto "9518 Captación:Sobrecorriente o cortocircuito. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Se ha producido un cortocircuito o se está sobrealimentando el captador."@es .

