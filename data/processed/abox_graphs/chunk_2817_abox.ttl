@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_9520 a ns1:DiagnosticoFallo ;
    rdfs:label "Frecuencia de contaje excesiva"@es ;
    ns1:identificador "9520" ;
    ns1:monitoreaParametro ns1:FrecuenciaDeContajeDelEncoder ;
    ns1:solucionaFallo ns1:ReduccionDeVelocidadDelEje ;
    ns1:textoExtracto "Captación: Frecuencia de contaje excesiva. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA La velocidad del eje excede la capacidad de muestreo del hardware, para ese tipo de señal del encóder."@es .

ns1:Fallo_9521 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de comunicación en captación (CRC incorrecto)"@es ;
    ns1:identificador "9521" ;
    ns1:textoExtracto "Error de comunicación en captación. CRC incorrecto. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema."@es .

ns1:SistemaCaptacion a ns1:Sistema ;
    rdfs:label "Sistema de captación"@es ;
    ns1:detalladoEnEsquema ns1:DocumentacionDelEncoder ;
    ns1:textoExtracto "Durante el arranque o funcionamiento habitual del sistema"@es ;
    ns1:tieneComponente ns1:Encoder .

ns1:DocumentacionDelEncoder a ns1:Esquema ;
    rdfs:label "Documentación del encóder"@es ;
    ns1:textoExtracto "Revise la documentación del encóder para determinar el origen de la alarma"@es .

ns1:Encoder a ns1:Sensor ;
    rdfs:label "Encóder"@es ;
    ns1:activaAlarma ns1:Fallo_9519 ;
    ns1:monitoreaParametro ns1:Parametro_FrecuenciaContaje ;
    ns1:textoExtracto "El encóder ha generado una señal de alarma por un mal funcionamiento del mismo"@es .

ns1:Fallo_9519 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación: Recibida señal de alarma"@es ;
    ns1:activaAlarma ns1:SenalDeAlarmaDelEncoder ;
    ns1:identificador "9519" ;
    ns1:solucionaFallo ns1:RevisionDeDocumentacionDelEncoder ;
    ns1:textoExtracto "Captación: Recibida señal de alarma. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El encóder ha generado una señal de alarma por un mal funcionamiento del mismo."@es .

ns1:FrecuenciaDeContajeDelEncoder a ns1:Parametro ;
    rdfs:label "Frecuencia de contaje del encóder"@es ;
    ns1:textoExtracto "Frecuencia de contaje excesiva"@es ;
    ns1:valor "excesiva"@es .

ns1:Parametro_FrecuenciaContaje a ns1:Parametro ;
    rdfs:label "Frecuencia de contaje"@es ;
    ns1:textoExtracto "Frecuencia de contaje excesiva"@es ;
    ns1:valor "excesiva"@es .

ns1:ReduccionDeVelocidadDelEje a ns1:TareaMantenimiento ;
    rdfs:label "Reducción de velocidad del eje"@es ;
    ns1:textoExtracto "Disminuya la velocidad máxima de movimiento del eje."@es .

ns1:RevisionDeDocumentacionDelEncoder a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de documentación del encóder"@es ;
    ns1:textoExtracto "Revise la documentación del encóder para determinar el origen de la alarma. Puede tratarse también de un falso positivo debido a un mal conexionado."@es .

ns1:SenalDeAlarmaDelEncoder a ns1:Alarma ;
    rdfs:label "Señal de alarma del encóder"@es ;
    ns1:textoExtracto "El encóder ha generado una señal de alarma por un mal funcionamiento del mismo."@es .

