@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error9521 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de comunicación en captación (CRC incorrecto)"@es ;
    ns1:solucionaFallo ns1:Solucion9521_1,
        ns1:Solucion9521_2,
        ns1:Solucion9521_3 ;
    ns1:textoExtracto "9521 Error de comunicación en captación. CRC incorrecto. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Pérdida de la configuración del encóder o de la cabeza de la regla. El CRC de la regla absoluta FAGOR conectada no ha sido identificado por el regulador."@es .

ns1:Error9522 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de comunicación en captación (No se recibió acknowledge)"@es ;
    ns1:solucionaFallo ns1:Solucion9522_1 ;
    ns1:textoExtracto "9522 Error de comunicación en captación. No se recibió acknowledge. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en la lectura de la cota absoluta; no se recibió acknowledge."@es .

ns1:SistemaCaptacion a ns1:Sistema ;
    rdfs:label "Sistema de captación con regla absoluta FAGOR"@es ;
    ns1:textoExtracto "El CRC de la regla absoluta FAGOR conectada no ha sido identificado por el regulador."@es ;
    ns1:tieneComponente ns1:CableCaptacion,
        ns1:CaptadorRegla .

ns1:CableCaptacion a ns1:ComponenteElectrico ;
    rdfs:label "Cable de conexionado del captador"@es ;
    ns1:textoExtracto "Compruebe el cable y el conexionado con el captador."@es .

ns1:CaptadorRegla a ns1:Sensor ;
    rdfs:label "Captador (encóder o cabeza de regla absoluta FAGOR)"@es ;
    ns1:textoExtracto "Pérdida de la configuración del encóder o de la cabeza de la regla. El CRC de la regla absoluta FAGOR conectada no ha sido identificado por el regulador."@es .

ns1:Solucion9521_1 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar cable y conexionado del captador"@es ;
    ns1:textoExtracto "Compruebe el cable y el conexionado con el captador."@es .

ns1:Solucion9521_2 a ns1:TareaMantenimiento ;
    rdfs:label "Verificar parametrización del captador"@es ;
    ns1:textoExtracto "Verifique la correcta parametrización del captador."@es .

ns1:Solucion9521_3 a ns1:TareaMantenimiento ;
    rdfs:label "Reemplazar encóder o cabeza de regla (contactar con Fagor Automation)"@es ;
    ns1:textoExtracto "Si todo es correcto y sigue produciéndose el error, reemplazar el encóder o la cabeza de la regla. Póngase en contacto con Fagor Automation."@es .

ns1:Solucion9522_1 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar cable y conexionado del captador (error acknowledge)"@es ;
    ns1:textoExtracto "Compruebe el cable y el conexionado con el captador."@es .

