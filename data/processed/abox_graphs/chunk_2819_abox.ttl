@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Captador_Sistema a ns1:Sensor ;
    rdfs:label "Captador" ;
    ns1:textoExtracto "Compruebe el cable y el conexionado con el captador. El error puede deberse a un problema en el captador." .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation" ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Modulo_ABSIND a ns1:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND" ;
    ns1:textoExtracto "El regulador ha perdido la sincronización con el módulo ABSIND" .

ns1:Regulador_Sistema a ns1:ComponenteElectrico ;
    rdfs:label "Regulador del sistema" ;
    ns1:monitoreaParametro ns1:Parametro_Cota ;
    ns1:textoExtracto "El regulador ha perdido la sincronización con el módulo ABSIND" .

ns1:TareaMantenimiento_RevisionCableadoCaptador a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de cableado y conexionado del captador" ;
    ns1:solucionaFallo ns1:Error_ABSIND_9523 ;
    ns1:textoExtracto "Compruebe el cable y el conexionado con el captador" .

ns1:Error_ABSIND_9523 a ns1:AvisoSeguridad ;
    rdfs:label "Error de sincronismo ABSIND 9523" ;
    ns1:identificador "9523" ;
    ns1:textoExtracto "9523 ABSIND: Error de sincronismo. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador ha perdido la sincronización con el módulo ABSIND, lo que ha podido producir una lectura de cota incorrecta." .

ns1:Parametro_Cota a ns1:Parametro ;
    rdfs:label "Cota" ;
    ns1:textoExtracto "una lectura de cota incorrecta" .

