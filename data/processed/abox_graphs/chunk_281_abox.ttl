@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EditorCNC_Unicode a ns1:Componente ;
    rdfs:label "Editor del CNC (soporte Unicode)" ;
    ns1:textoExtracto "El editor del CNC admite caracteres Unicode. Los programas en formato Unicode no son compatibles con versiones anteriores a la versión V4.0." .

ns1:ProgramaUnicode a ns1:InterfazUsuario ;
    rdfs:label "Programa en formato Unicode" ;
    ns1:requiereMantenimiento ns1:ConversionANSI ;
    ns1:textoExtracto "programas en formato Unicode no son compatibles con versiones anteriores a la versión V4.0. Un programa en formato Unicode no podrá ser editado ni ejecutado en una versión anterior a la V4.0." .

ns1:VersionSoftware_V4.0 a ns1:Parametro ;
    rdfs:label "Versión mínima compatible (V4.0)" ;
    ns1:identificador "V4.0" ;
    ns1:textoExtracto "versiones anteriores a la versión V4.0" ;
    ns1:valor "4.0" .

ns1:ConversionANSI a ns1:TareaMantenimiento ;
    rdfs:label "Conversión de Unicode a ANSI" ;
    ns1:ejecutadoPor ns1:EditorTerceros ;
    ns1:textoExtracto "Para convertir programas en formato Unicode a formato ANSI puede utilizar un editor de texto de terceros (por ejemplo, el Bloc de notas de Windows)" .

ns1:EditorTerceros a ns1:Herramienta ;
    rdfs:label "Editor de texto de terceros (ej. Bloc de notas)" ;
    ns1:textoExtracto "un editor de texto de terceros (por ejemplo, el Bloc de notas de Windows)" .

