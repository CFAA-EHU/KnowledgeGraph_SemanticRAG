@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ContactoSoporte_Fagor a ns1:TareaMantenimiento ;
    rdfs:label "Contactar con soporte técnico de Fagor Automation" ;
    ns1:ejecutadoPor ns1:Empresa_FagorAutomation ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error_9526_INDUCTOSYN_INC_Alta a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9526: INDUCTOSYN - Señal INC demasiado alta" ;
    ns1:identificador "9526" ;
    ns1:textoExtracto "9526 INDUCTOSYN:Señal INC demasiado alta. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Nivel de la señal incremental del transductor inductosyn/resolver demasiado alto." .

ns1:Regulador_Sistema a ns1:ComponenteElectrico ;
    rdfs:label "Regulador del sistema" ;
    ns1:activaAlarma ns1:Error_9523_Sincronizacion_ABSIND,
        ns1:Error_9524_ABSIND ;
    ns1:controla ns1:Modulo_ABSIND ;
    ns1:textoExtracto "regulador" .

ns1:Solucion_AjusteGananciaFase_ABSIND a ns1:TareaMantenimiento ;
    rdfs:label "Ajustar ganancia y fase del módulo ABSIND con software" ;
    ns1:requiereConsumible ns1:SoftwareAjuste_ABSIND ;
    ns1:solucionaFallo ns1:Error_9525_INDUCTOSYN_INC_Baja ;
    ns1:textoExtracto "Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste." .

ns1:Solucion_ComprobacionConexion_ABSIND a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar conexión y cableado entre regulador y módulo ABSIND" ;
    ns1:solucionaFallo ns1:Error_9523_Sincronizacion_ABSIND,
        ns1:Error_9524_ABSIND ;
    ns1:textoExtracto "Comprobar que la conexión y el cableado son satisfactorios." .

ns1:Solucion_ComprobacionConexion_Inductosyn a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar cable y conexión entre módulo ABSIND y transductor Inductosyn/Resolver" ;
    ns1:solucionaFallo ns1:Error_9525_INDUCTOSYN_INC_Baja ;
    ns1:textoExtracto "Comprobar el cable y la conexión entre el módulo ABSIND y el transductor inductosyn/resolver." .

ns1:Solucion_SustitucionModuloCable_ABSIND a ns1:TareaMantenimiento ;
    rdfs:label "Sustituir módulo ABSIND y/o cable asociado" ;
    ns1:requiereConsumible ns1:Modulo_ABSIND ;
    ns1:solucionaFallo ns1:Error_9525_INDUCTOSYN_INC_Baja ;
    ns1:textoExtracto "pruebe a sustituir el módulo ABSIND y/o el cable asociado a esa captación." .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation" ;
    ns1:textoExtracto "Fagor Automation" .

ns1:SoftwareAjuste_ABSIND a ns1:InterfazUsuario ;
    rdfs:label "Software de ajuste del módulo ABSIND" ;
    ns1:textoExtracto "software de ajuste" .

ns1:Transductor_InductosynResolver a ns1:Sensor ;
    rdfs:label "Transductor Inductosyn/Resolver" ;
    ns1:textoExtracto "transductor inductosyn/resolver" .

ns1:Error_9523_Sincronizacion_ABSIND a ns1:DiagnosticoFallo ;
    rdfs:label "Error de sincronización entre regulador y módulo ABSIND" ;
    ns1:identificador "9523" ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador ha perdido la sincronización con el módulo ABSIND, lo que ha podido producir una lectura de cota incorrecta. Es probable que el error pueda deberse a un mal funcionamiento del módulo ABSIND o a un problema de conexionado entre el módulo ABSIND y el regulador." .

ns1:Error_9524_ABSIND a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9524: ABSIND - Error leyendo información" ;
    ns1:identificador "9524" ;
    ns1:textoExtracto "9524 ABSIND:Error leyendo información. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador no ha podido leer la identificación del módulo ABSIND durante el arranque del sistema. Es probable que el error pueda deberse a un mal funcionamiento del módulo ABSIND o a un problema de conexionado entre el módulo ABSIND y el regulador." .

ns1:Modulo_ABSIND a ns1:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND" ;
    ns1:controla ns1:Transductor_InductosynResolver ;
    ns1:monitoreaParametro ns1:Error_9525_INDUCTOSYN_INC_Baja ;
    ns1:textoExtracto "módulo ABSIND" .

ns1:Error_9525_INDUCTOSYN_INC_Baja a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9525: INDUCTOSYN - Señal INC demasiado baja" ;
    ns1:identificador "9525" ;
    ns1:textoExtracto "9525 INDUCTOSYN:Señal INC demasiado baja. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Nivel de la señal incremental del transductor inductosyn/resolver demasiado bajo." .

