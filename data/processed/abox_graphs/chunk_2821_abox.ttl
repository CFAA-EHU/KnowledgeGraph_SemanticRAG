@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ControlINDUCTOSYN a ns1:Sistema ;
    rdfs:label "Sistema de control INDUCTOSYN"@es ;
    ns1:activaAlarma ns1:Error_9526_INDUCTOSYN ;
    ns1:textoExtracto "arranque o funcionamiento habitual del sistema"@es ;
    ns1:tieneComponente ns1:Modulo_ABSIND .

ns1:Error_9526_INDUCTOSYN a ns1:AvisoSeguridad ;
    rdfs:label "Error 9526: Señal INC demasiado alta (INDUCTOSYN)"@es ;
    ns1:identificador "9526" ;
    ns1:solucionaFallo ns1:Solucion_9526_AjusteGananciaFase,
        ns1:Solucion_9526_ComprobacionTransductor ;
    ns1:textoExtracto "INDUCTOSYN: Señal INC demasiado alta. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Nivel de la señal incremental del transductor inductosyn/resolver demasiado alto."@es .

ns1:Parametro_SenalINC a ns1:Parametro ;
    rdfs:label "Señal incremental INC (INDUCTOSYN)"@es ;
    ns1:textoExtracto "Nivel de la señal incremental del transductor inductosyn/resolver"@es ;
    ns1:valor "demasiado alto"@es .

ns1:Solucion_9526_AjusteGananciaFase a ns1:TareaMantenimiento ;
    rdfs:label "Ajuste de ganancia y fase del módulo ABSIND"@es ;
    ns1:requiereMantenimiento ns1:Modulo_ABSIND ;
    ns1:textoExtracto "Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste."@es .

ns1:Solucion_9526_ComprobacionTransductor a ns1:TareaMantenimiento ;
    rdfs:label "Comprobación del transductor INDUCTOSYN/resolver"@es ;
    ns1:textoExtracto "Comprobar el nivel de señal del transductor inductosyn/resolver."@es .

ns1:Modulo_ABSIND a ns1:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND"@es ;
    ns1:monitoreaParametro ns1:Parametro_SenalINC ;
    ns1:textoExtracto "módulo ABSIND con el software de ajuste"@es .

