@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Accion_ComprobarTierra a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar conexiones de tierra en el armario"@es ;
    ns1:mitigaRiesgo ns1:Error_9529 ;
    ns1:textoExtracto "Comprobar las conexiones de tierra en el armario (ruido eléctrico sobre las señales)"@es .

ns1:Accion_ContactoSoporte a ns1:TareaMantenimiento ;
    rdfs:label "Contactar con Fagor Automation"@es ;
    ns1:ejecutadoPor ns1:Empresa_FagorAutomation ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation"@es .

ns1:Accion_SustitucionModulo a ns1:TareaMantenimiento ;
    rdfs:label "Sustituir módulo ABSIND y/o cable de captación"@es ;
    ns1:requiereMantenimiento ns1:Cable_Captacion_Inductosyn,
        ns1:Modulo_ABSIND ;
    ns1:solucionaFallo ns1:Error_9529 ;
    ns1:textoExtracto "pruebe a sustituir el módulo ABSIND y/o el cable asociado a esa captación"@es .

ns1:Sistema_Inductosyn a ns1:Sistema ;
    rdfs:label "Sistema INDUCTOSYN"@es ;
    ns1:activaAlarma ns1:Error_9529 ;
    ns1:textoExtracto "funcionamiento habitual del sistema"@es ;
    ns1:tieneComponente ns1:Cable_Captacion_Inductosyn,
        ns1:Modulo_ABSIND .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ns1:textoExtracto "Fagor Automation"@es .

ns1:Cable_Captacion_Inductosyn a ns1:ComponenteElectrico ;
    rdfs:label "Cable de captación INDUCTOSYN"@es ;
    ns1:solucionaFallo ns1:Error_9529 ;
    ns1:textoExtracto "el cable asociado a esa captación"@es .

ns1:Modulo_ABSIND a ns1:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND"@es ;
    ns1:solucionaFallo ns1:Error_9529 ;
    ns1:textoExtracto "pruebe a sustituir el módulo ABSIND y/o el cable asociado a esa captación"@es .

ns1:Error_9529 a ns1:AvisoSeguridad ;
    rdfs:label "Error 9529: INDUCTOSYN Checksum EEPROM incorrecto"@es ;
    ns1:identificador "9529" ;
    ns1:textoExtracto "9529 INDUCTOSYN: Checksum EEPROM incorrecto. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema."@es .

