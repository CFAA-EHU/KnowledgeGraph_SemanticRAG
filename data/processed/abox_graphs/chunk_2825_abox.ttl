@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FalloAlimentacionModuloABSIND_9533 a ns1:DiagnosticoFallo ;
    rdfs:label "Nivel de tensión 24 V DC/15 V DC demasiado alto en módulo ABSIND"@es ;
    ns1:identificador "9533" ;
    ns1:solucionaFallo ns1:TareaComprobarAlimentacionModuloABSIND ;
    ns1:textoExtracto "INDUCTOSYN:Nivel de tensión 24 V DC/15 V DC demasiado alto. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Fallo en la alimentación del módulo. SOLUCIÓN Comprobar la alimentación del módulo ABSIND."@es .

ns1:FalloAlimentacionModuloABSIND_9534 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la captación digital Fagor"@es ;
    ns1:identificador "9534" ;
    ns1:textoExtracto "9534 Captación digital Fagor. Error en la"@es .

ns1:SistemaInductosyn a ns1:Sistema ;
    rdfs:label "Sistema INDUCTOSYN"@es ;
    ns1:textoExtracto "INDUCTOSYN:Nivel de tensión 24 V DC/15 V DC demasiado alto"@es ;
    ns1:tieneComponente ns1:ModuloABSIND .

ns1:TareaComprobarAlimentacionModuloABSIND a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar la alimentación del módulo ABSIND"@es ;
    ns1:requiereMantenimiento ns1:ModuloABSIND ;
    ns1:textoExtracto "Comprobar la alimentación del módulo ABSIND"@es .

ns1:ModuloABSIND a ns1:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND"@es ;
    ns1:textoExtracto "módulo ABSIND"@es .

