@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_9534 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la pista absoluta (9534)" ;
    ns1:identificador "9534" ;
    ns1:solucionaFallo ns1:TareaMantenimiento_9534 ;
    ns1:textoExtracto "Captación digital Fagor. Error en la pista absoluta. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Las posibles causas son las siguientes: • El captador no puede calcular la posición absoluta. • Pérdida de contaje. • La señal analógica < 0,20 Vpp." .

ns1:Error_9535 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la CPU (9535)" ;
    ns1:identificador "9535" ;
    ns1:solucionaFallo ns1:TareaMantenimiento_9535 ;
    ns1:textoExtracto "Captación digital Fagor. Error en la CPU. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Encóder o cabeza de la regla dañado." .

ns1:Error_9536 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de los potenciómetros de ajuste (9536)" ;
    ns1:identificador "9536" ;
    ns1:solucionaFallo ns1:TareaMantenimiento_9536 ;
    ns1:textoExtracto "Captación digital Fagor. Error de los potenciómetros de ajuste. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Encóder o cabeza de la regla dañado." .

ns1:Error_9537 a ns1:DiagnosticoFallo ;
    rdfs:label "Error del captador de imagen (CCD) (9537)" ;
    ns1:identificador "9537" ;
    ns1:solucionaFallo ns1:TareaMantenimiento_9537 ;
    ns1:textoExtracto "Captación digital Fagor. Error del captador de imagen (CCD). DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Encóder o cabeza de la regla dañado; el CCD (Charge Coupled Device) o el LED (Light Emitting Diode)." .

ns1:Error_Alimentacion_ABSIND a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en la alimentación del módulo ABSIND" ;
    ns1:solucionaFallo ns1:TareaMantenimiento_Alimentacion_ABSIND ;
    ns1:textoExtracto "Durante el arranque o funcionamiento habitual del sistema. CAUSA Fallo en la alimentación del módulo. SOLUCIÓN Comprobar la alimentación del módulo ABSIND." .

ns1:SistemaCaptacionDigital_Fagor a ns1:Sistema ;
    rdfs:label "Sistema de captación digital Fagor" ;
    ns1:textoExtracto "Captación digital Fagor." ;
    ns1:tieneComponente ns1:CaptadorImagen_CCD,
        ns1:Encoder_Regla,
        ns1:Modulo_ABSIND .

ns1:CaptadorImagen_CCD a ns1:Sensor ;
    rdfs:label "Captador de imagen (CCD)" ;
    ns1:textoExtracto "captador de imagen (CCD)" .

ns1:Encoder_Regla a ns1:ComponenteElectrico ;
    rdfs:label "Encóder o cabeza de la regla" ;
    ns1:textoExtracto "Encóder o la cabeza de la regla." .

ns1:Modulo_ABSIND a ns1:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND" ;
    ns1:textoExtracto "módulo ABSIND" .

ns1:TareaMantenimiento_9534 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Comprobar que el encóder o la regla están trabajando a una velocidad apropiada. Comprobar las tolerancias de montaje. Limpiar el cristal o la cinta de acero de la regla. Si ninguna de las soluciones anteriores resuelve el error, reemplazar el encóder o la cabeza de la regla." .

ns1:TareaMantenimiento_9535 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Reemplazar el encóder o la cabeza de la regla." .

ns1:TareaMantenimiento_9536 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Reemplazar el encóder o la cabeza de la regla." .

ns1:TareaMantenimiento_9537 a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Comprobar las tolerancias de montaje. Limpiar el cristal o la cinta de acero de la regla." .

ns1:TareaMantenimiento_Alimentacion_ABSIND a ns1:TareaMantenimiento ;
    ns1:textoExtracto "Comprobar la alimentación del módulo ABSIND." .

