@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_ContactoFagor_9538 a ns1:AvisoSeguridad ;
    rdfs:label "Contactar con Fagor Automation para reemplazo (9538)"@es ;
    ns1:textoExtracto "Póngase en contacto con Fagor Automation."@es .

ns1:ComponenteElectrico_Encoder_9538 a ns1:ComponenteElectrico ;
    rdfs:label "Encóder o cabeza de regla con CCD/LED (9538)"@es ;
    ns1:identificador "9538" ;
    ns1:textoExtracto "Encóder o cabeza de la regla dañado; el CCD (Charge Coupled Device) o el LED (Light Emitting Diode)."@es .

ns1:FalloEncoder_9538 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en encóder o cabeza de regla (código 9538)"@es ;
    ns1:identificador "9538" ;
    ns1:solucionaFallo ns1:TareaMantenimiento_ComprobarToleranciasMontaje_9538,
        ns1:TareaMantenimiento_LimpiarCristalCintaRegla_9538,
        ns1:TareaMantenimiento_ReemplazarEncoder_9538 ;
    ns1:textoExtracto "CAUSA Encóder o cabeza de la regla dañado; el CCD (Charge Coupled Device) o el LED (Light Emitting Diode). [...] 9538 Captación digital Fagor. Tensión de alimentación fuera de rango."@es .

ns1:TareaMantenimiento_ComprobarToleranciasMontaje_9538 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar tolerancias de montaje (solución 9538)"@es ;
    ns1:textoExtracto "Comprobar las tolerancias de montaje."@es .

ns1:TareaMantenimiento_LimpiarCristalCintaRegla_9538 a ns1:TareaMantenimiento ;
    rdfs:label "Limpiar cristal o cinta de acero de la regla (solución 9538)"@es ;
    ns1:textoExtracto "Limpiar el cristal o la cinta de acero de la regla."@es .

ns1:TareaMantenimiento_ReemplazarEncoder_9538 a ns1:TareaMantenimiento ;
    rdfs:label "Reemplazar encóder o cabeza de regla (solución 9538)"@es ;
    ns1:textoExtracto "Si ninguna de las soluciones anteriores resuelve el error, reemplazar el encóder o la cabeza de la regla."@es .

