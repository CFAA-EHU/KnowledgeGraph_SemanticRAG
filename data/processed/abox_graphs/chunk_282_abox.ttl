@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_Teclados a ns1:InterfazUsuario ;
    rdfs:label "Teclados de máquina" ;
    ns1:habilitadoPor ns1:Parametro_NKEYBD ;
    ns1:textoExtracto "al actualizar una versión anterior en máquinas con varios teclados, hay que configurarlos..." .

ns1:Maquina_MultiTeclado a ns1:Maquina ;
    rdfs:label "Máquina con varios teclados" ;
    ns1:controla ns1:Parametro_NKEYBD ;
    ns1:textoExtracto "Máquina con varios teclados. A partir de la versión V4.02, al actualizar una versión anterior en máquinas con varios teclados..." .

ns1:VersionSoftware_V4.0 a ns1:Sistema ;
    rdfs:label "Versión V4.0" ;
    ns1:identificador "V4.0" ;
    ns1:textoExtracto "a la V4.0. Para convertir programas en formato Unicode a formato ANSI..." .

ns1:VersionSoftware_V4.02 a ns1:Sistema ;
    rdfs:label "Versión V4.02" ;
    ns1:identificador "V4.02" ;
    ns1:textoExtracto "Versión V4.02. Máquina con varios teclados." .

ns1:Parametro_NKEYBD a ns1:Parametro ;
    rdfs:label "Parámetro NKEYBD" ;
    ns1:documentadoEn ns1:VersionSoftware_V4.02 ;
    ns1:identificador "NKEYBD" ;
    ns1:textoExtracto "el CNC define el parámetro NKEYBD con valor 1 (valor por defecto)" ;
    ns1:valor "1" .

