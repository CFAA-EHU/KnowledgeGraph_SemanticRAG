@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TareaRevisionTensionRed a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de tensiones de red y cableado"@es ;
    ns1:solucionaFallo ns1:FalloTensionRed_9550 ;
    ns1:textoExtracto "SOLUCIÓN Revisar tensiones de red y cableado hasta la tarjeta sense."@es .

ns1:TarjetaSense a ns1:ComponenteElectrico ;
    rdfs:label "Tarjeta sense"@es ;
    ns1:textoExtracto "cableado hasta la tarjeta sense"@es .

ns1:FalloTensionRed_9550 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo por tensión de red insuficiente (9550)"@es ;
    ns1:identificador "9550" ;
    ns1:monitoreaParametro ns1:ParametroTensionRed_70porciento,
        ns1:ParametroTensionRed_80porciento ;
    ns1:textoExtracto "Nivel de tensión por debajo del 70%. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Bajada en la tensión de red."@es .

ns1:ParametroTensionRed_70porciento a ns1:Parametro ;
    rdfs:label "Tensión de red (umbral 70%)"@es ;
    ns1:textoExtracto "Nivel de tensión por debajo del 70%"@es ;
    ns1:valor "70%" .

ns1:ParametroTensionRed_80porciento a ns1:Parametro ;
    rdfs:label "Tensión de red (umbral 80%)"@es ;
    ns1:textoExtracto "la tensión de red no ha alcanzado el 80 % del valor esperado"@es ;
    ns1:valor "80%" .

