@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_Regulacion a ns1:Sistema ;
    rdfs:label "Sistema de regulación"@es ;
    ns1:activaAlarma ns1:Fallo_9616_Watchdog_Regulador,
        ns1:Fallo_9617_Fallo_24Vdc ;
    ns1:textoExtracto "funcionamiento habitual del sistema"@es .

ns1:Accion_Contactar_FagorAutomation_9616 a ns1:TareaMantenimiento ;
    rdfs:label "Contactar con Fagor Automation"@es ;
    ns1:textoExtracto "SOLUCIÓN Contacte con Fagor Automation."@es .

ns1:Fallo_9616_Watchdog_Regulador a ns1:DiagnosticoFallo ;
    rdfs:label "Watchdog de regulador"@es ;
    ns1:identificador "9616" ;
    ns1:solucionaFallo ns1:Accion_Contactar_FagorAutomation_9616 ;
    ns1:textoExtracto "Watchdog de regulador. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El regulador no responde; posible mal funcionamiento, conexionado, etc."@es .

ns1:Fallo_9617_Fallo_24Vdc a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 24 Vdc inesperado"@es ;
    ns1:identificador "9617" ;
    ns1:textoExtracto "Fallo 24 Vdc inesperado. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema."@es .

