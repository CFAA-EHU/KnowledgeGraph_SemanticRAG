@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation."@es .

ns1:SistemaCaptacion a ns1:Sistema ;
    rdfs:label "Sistema de captación"@es ;
    ns1:textoExtracto "El lazo ha detectado cable roto en la señal A del contaje del regulador. El regulador no recibe la señal A de la captación."@es ;
    ns1:tieneComponente ns1:ComponenteElectrico_SenalA_Regulador,
        ns1:ComponenteElectrico_SenalB .

ns1:TareaMantenimiento_RevisionCableado a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de cableado y conexiones de captación"@es ;
    ns1:solucionaFallo ns1:Fallo_9623,
        ns1:Fallo_CableRotoSenalA_Regulador ;
    ns1:textoExtracto "SOLUCIÓN Revisar el cable y la conexión de las entradas de captación."@es .

ns1:ComponenteElectrico_SenalA_Regulador a ns1:ComponenteElectrico ;
    rdfs:label "Cable de señal A del contaje del regulador"@es ;
    ns1:monitoreaParametro ns1:Parametro_SenalA ;
    ns1:textoExtracto "cable roto en la señal A del contaje del regulador"@es .

ns1:ComponenteElectrico_SenalB a ns1:ComponenteElectrico ;
    rdfs:label "Cable de señal B del sistema de captación"@es ;
    ns1:monitoreaParametro ns1:Parametro_SenalB ;
    ns1:textoExtracto "Captación: Cable roto señal B"@es .

ns1:Fallo_9623 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación: Cable roto señal B"@es ;
    ns1:identificador "9623" ;
    ns1:textoExtracto "9623 Captación: Cable roto señal B. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA El lazo ha detectado cable roto en la señal A del"@es .

ns1:Fallo_CableRotoSenalA_Regulador a ns1:DiagnosticoFallo ;
    rdfs:label "Cable roto en señal A del contaje del regulador"@es ;
    ns1:textoExtracto "CAUSA El lazo ha detectado cable roto en la señal A del contaje del regulador. El regulador no recibe la señal A de la captación."@es .

ns1:Parametro_SenalA a ns1:Parametro ;
    rdfs:label "Señal A de captación"@es ;
    ns1:textoExtracto "El regulador no recibe la señal A de la captación"@es .

ns1:Parametro_SenalB a ns1:Parametro ;
    rdfs:label "Señal B de captación"@es ;
    ns1:textoExtracto "9623 Captación: Cable roto señal B"@es .

