@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:KEYBD1CH a ns1:Parametro ;
    rdfs:label "KEYBD1CH" ;
    ns1:documentadoEn ns1:TablaParametrosJog ;
    ns1:identificador "KEYBD1CH" ;
    ns1:textoExtracto "KEYBD1CH | Canal activo. | Canal al que está asignado el primer panel de jog."@es ;
    ns1:valor "Canal activo" .

ns1:KEYBD2CH a ns1:Parametro ;
    rdfs:label "KEYBD2CH" ;
    ns1:documentadoEn ns1:TablaParametrosJog ;
    ns1:identificador "KEYBD2CH" ;
    ns1:textoExtracto "KEYBD2CH | Canal activo. | Canal al que está asignado el segundo panel de jog."@es ;
    ns1:valor "Canal activo" .

ns1:NKEYBD a ns1:Parametro ;
    rdfs:label "NKEYBD" ;
    ns1:documentadoEn ns1:TablaParametrosJog ;
    ns1:identificador "NKEYBD" ;
    ns1:textoExtracto "NKEYBD | 2 | Número de paneles de jog."@es ;
    ns1:valor "2" .

ns1:TablaParametrosJog a ns1:Tabla ;
    rdfs:label "Tabla de parámetros para paneles de jog"@es ;
    ns1:documentadoEn ns1:Pagina_38_42 ;
    ns1:textoExtracto """
| Parámetro. | Valor. | Significado. |
| --- | --- | --- |
| NKEYBD | 2 | Número de paneles de jog. |
| KEYBD1CH | Canal activo. | Canal al que está asignado el primer panel de jog. |
| KEYBD2CH | Canal activo. | Canal al que está asignado el segundo panel de jog.
"""@es .

