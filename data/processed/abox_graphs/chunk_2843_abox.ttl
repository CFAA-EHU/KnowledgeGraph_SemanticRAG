@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Cableado_Inductosyn_ABSIND a ns1:ComponenteElectrico ;
    rdfs:label "Cableado entre módulo ABSIND y transductor inductosyn" ;
    ns1:textoExtracto "cable y la conexión entre el módulo ABSIND y el transductor inductosyn/resolver" .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation" ;
    ns1:textoExtracto "Fagor Automation" .

ns1:Error_9632_ABSIND a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de identificación del módulo ABSIND" ;
    ns1:solucionaFallo ns1:ComprobarConexionYCableadoDelModuloABSIND ;
    ns1:textoExtracto "El regulador no ha podido leer la identificación del módulo ABSIND durante el arranque del sistema. Es probable que el error pueda deberse a un mal funcionamiento del módulo ABSIND o a un problema de conexionado entre el módulo ABSIND y el regulador." .

ns1:Error_9634 a ns1:DiagnosticoFallo ;
    rdfs:label "INDUCTOSYN: señal INC demasiado alta" ;
    ns1:identificador "9634" ;
    ns1:solucionaFallo ns1:Error_9633 ;
    ns1:textoExtracto "INDUCTOSYN: señal INC demasiado alta. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Nivel de la señal incremental del transductor inductosyn/resolver demasiado alto." .

ns1:Error_9635 a ns1:DiagnosticoFallo ;
    rdfs:label "INDUCTOSYN: señal GRAY no presente" ;
    ns1:identificador "9635" ;
    ns1:textoExtracto "INDUCTOSYN: señal GRAY no presente. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema." .

ns1:Modulo_ABSIND a ns1:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND" ;
    ns1:textoExtracto "módulo ABSIND" .

ns1:SoftwareAjuste_ABSIND a ns1:InterfazUsuario ;
    rdfs:label "Software de ajuste del módulo ABSIND" ;
    ns1:textoExtracto "software de ajuste" .

ns1:Transductor_Inductosyn a ns1:Sensor ;
    rdfs:label "Transductor inductosyn/resolver" ;
    ns1:textoExtracto "transductor inductosyn/resolver" .

ns1:ComprobarCableadoEntreModuloABSINDYTransductor a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar cableado entre módulo ABSIND y transductor" ;
    ns1:textoExtracto "Comprobar el cable y la conexión entre el módulo ABSIND y el transductor inductosyn/resolver." .

ns1:ComprobarConexionYCableadoDelModuloABSIND a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar conexión y cableado del módulo ABSIND" ;
    ns1:textoExtracto "Comprobar que la conexión y el cableado son satisfactorios." .

ns1:ComprobarGananciaYFaseDelModuloABSIND a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar ganancia y fase del módulo ABSIND" ;
    ns1:textoExtracto "Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste." .

ns1:Error_9633 a ns1:DiagnosticoFallo ;
    rdfs:label "INDUCTOSYN: señal INC demasiado baja" ;
    ns1:identificador "9633" ;
    ns1:solucionaFallo ns1:ComprobarCableadoEntreModuloABSINDYTransductor,
        ns1:ComprobarGananciaYFaseDelModuloABSIND,
        ns1:SustituirModuloABSINDOCableado ;
    ns1:textoExtracto "INDUCTOSYN: señal INC demasiado baja. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Nivel de la señal incremental del transductor inductosyn/resolver demasiado bajo." .

ns1:SustituirModuloABSINDOCableado a ns1:TareaMantenimiento ;
    rdfs:label "Sustituir módulo ABSIND o cableado" ;
    ns1:textoExtracto "Si el error persiste y no se puede eliminar con las acciones anteriores, pruebe a sustituir el módulo ABSIND y/o el cable asociado a esa captación." .

