@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ns1:textoExtracto "Fagor Automation"@es .

ns1:Software_AjusteABSIND a ns1:InterfazUsuario ;
    rdfs:label "software de ajuste del módulo ABSIND"@es ;
    ns1:controla ns1:Parametro_FaseABSIND,
        ns1:Parametro_GananciaABSIND ;
    ns1:textoExtracto "software de ajuste"@es .

ns1:Solucion_ComprobacionAjusteABSIND a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar valores de ganancia y fase con software de ajuste"@es ;
    ns1:ejecutadoPor ns1:Personal_Tecnico ;
    ns1:requiereMantenimiento ns1:Modulo_ABSIND ;
    ns1:textoExtracto "Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste."@es .

ns1:Solucion_ContactoFagorAutomation a ns1:TareaMantenimiento ;
    rdfs:label "Contactar con Fagor Automation"@es ;
    ns1:mitigaRiesgo ns1:Error_9638_INDUCTOSYN ;
    ns1:textoExtracto "póngase en contacto con Fagor Automation"@es .

ns1:Solucion_SustitucionModuloABSIND a ns1:TareaMantenimiento ;
    rdfs:label "Sustituir módulo ABSIND"@es ;
    ns1:requiereMantenimiento ns1:Modulo_ABSIND ;
    ns1:solucionaFallo ns1:Error_9638_INDUCTOSYN ;
    ns1:textoExtracto "sustituir el módulo ABSIND asociado a esa captación"@es .

ns1:Error_9638_INDUCTOSYN a ns1:AvisoSeguridad ;
    rdfs:label "Error 9638 INDUCTOSYN"@es ;
    ns1:identificador "9638" ;
    ns1:mitigaRiesgo ns1:Solucion_ComprobacionAjusteABSIND,
        ns1:Solucion_ContactoFagorAutomation,
        ns1:Solucion_SustitucionModuloABSIND ;
    ns1:textoExtracto "INDUCTOSYN: Error desconocido."@es .

ns1:Modulo_ABSIND a ns1:ComponenteElectrico ;
    rdfs:label "módulo ABSIND"@es ;
    ns1:monitoreaParametro ns1:Parametro_FaseABSIND,
        ns1:Parametro_GananciaABSIND ;
    ns1:textoExtracto "módulo ABSIND asociado a esa captación"@es .

ns1:Parametro_FaseABSIND a ns1:Parametro ;
    rdfs:label "fase del módulo ABSIND"@es ;
    ns1:textoExtracto "valores de [...] fase del módulo ABSIND"@es .

ns1:Parametro_GananciaABSIND a ns1:Parametro ;
    rdfs:label "ganancia del módulo ABSIND"@es ;
    ns1:textoExtracto "valores de la ganancia [...] del módulo ABSIND"@es .

