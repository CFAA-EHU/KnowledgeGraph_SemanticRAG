@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DipswitchS50 a ns1:ComponenteElectrico ;
    rdfs:label "Dipswitch S50" ;
    ns1:textoExtracto "Revise el estado del dipswitch S50 del módulo ABSIND." ;
    ns1:tieneComponente ns1:ModuloABSIND .

ns1:Error9640 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9640: Nivel de tensión 24 Vdc/15 Vdc demasiado bajo (INDUCTOSYN)" ;
    ns1:identificador "9640" ;
    ns1:solucionaFallo ns1:ModuloABSIND ;
    ns1:textoExtracto "9640 INDUCTOSYN: Nivel de tensión 24 Vdc/15 Vdc demasiado bajo. [...] SOLUCIÓN Comprobar la alimentación del módulo ABSIND." .

ns1:Error9641 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9641: Nivel de tensión 24 Vdc/15 Vdc demasiado alto (INDUCTOSYN)" ;
    ns1:identificador "9641" ;
    ns1:solucionaFallo ns1:ModuloABSIND ;
    ns1:textoExtracto "9641 INDUCTOSYN: Nivel de tensión 24 Vdc/15 Vdc demasiado alto. [...] SOLUCIÓN Comprobar la alimentación del módulo ABSIND." .

ns1:Error9642 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 9642: Captación digital Fagor. Error en la pista absoluta" ;
    ns1:identificador "9642" ;
    ns1:textoExtracto "9642 Captación digital Fagor. Error en la pista absoluta." .

ns1:SensorInductosyn a ns1:Sensor ;
    rdfs:label "Captador Inductosyn" ;
    ns1:textoExtracto "tipo de captador (inductosyn/resolver) conectado al módulo ABSIND." .

ns1:SensorResolver a ns1:Sensor ;
    rdfs:label "Captador Resolver" ;
    ns1:textoExtracto "tipo de captador (inductosyn/resolver) conectado al módulo ABSIND." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "El valor seleccionado debe ser coherente con el parámetro máquina SSITYPE del CNC." ;
    ns1:tieneComponente ns1:ModuloABSIND,
        ns1:ParametroSSITYPE .

ns1:ParametroSSITYPE a ns1:Parametro ;
    rdfs:label "SSITYPE" ;
    ns1:identificador "SSITYPE" ;
    ns1:textoExtracto "El valor seleccionado debe ser coherente con el parámetro máquina SSITYPE del CNC." .

ns1:ModuloABSIND a ns1:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND" ;
    ns1:textoExtracto "Revise el estado del dipswitch S50 del módulo ABSIND. [...] Comprobar la alimentación del módulo ABSIND." .

