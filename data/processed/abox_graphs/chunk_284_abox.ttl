@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MANRAPID a ns1:Parametro ;
    rdfs:label "MANRAPID (marca PLC)" ;
    ns1:identificador "MANRAPID" ;
    ns1:textoExtracto "La marca MANRAPID del PLC pasa de ser una marca general a ser una marca por canal. La marca MANRAPID que en versiones anteriores afectaba a todos los ejes del sistema, ahora sólo afectará a los ejes del primer canal." .

ns1:MANRAPIDC1 a ns1:Parametro ;
    rdfs:label "MANRAPIDC1 (marca PLC canal 1)" ;
    ns1:identificador "MANRAPIDC1" ;
    ns1:textoExtracto "Para que la marca afecte a todos los ejes del sistema, hay que modificar el programa de PLC y utilizar las marcas MANRAPIDC1 a MANRAPIDC4, en función de los canales que tenga el sistema." .

ns1:MANRAPIDC4 a ns1:Parametro ;
    rdfs:label "MANRAPIDC4 (marca PLC canal 4)" ;
    ns1:identificador "MANRAPIDC4" ;
    ns1:textoExtracto "Para que la marca afecte a todos los ejes del sistema, hay que modificar el programa de PLC y utilizar las marcas MANRAPIDC1 a MANRAPIDC4, en función de los canales que tenga el sistema." .

ns1:ModoSetup a ns1:ModoOperacion ;
    rdfs:label "Modo setup" ;
    ns1:identificador "modo_setup" ;
    ns1:textoExtracto "Si la instalación se hace en modo setup, el registro sólo tiene carácter temporal hasta que se apague el equipo." .

ns1:OP_PANEL_H_E a ns1:InterfazUsuario ;
    rdfs:label "Módulo OP-PANEL-H/E" ;
    ns1:controla ns1:PANELOFF,
        ns1:QWERTYOFF ;
    ns1:identificador "OP-PANEL-H/E" ;
    ns1:textoExtracto "En versiones anteriores, la marca PANELOFF del PLC deshabilitaba tanto la parte de jog como la parte alfanumérica (módulo OP-PANEL-H/E)." .

ns1:Software_V4.10 a ns1:Sistema ;
    rdfs:label "Software versión V4.10" ;
    ns1:identificador "V4.10" ;
    ns1:requiereMantenimiento ns1:ModoAdministrador ;
    ns1:textoExtracto "Versión V4.10. Actualizar la versión de software. La versión se debe actualizar en modo administrador, no en modo setup como se hace habitualmente, para poder registrar de forma permanente las nuevas librerías." .

ns1:Software_V4.20 a ns1:Sistema ;
    rdfs:label "Software versión V4.20" ;
    ns1:identificador "V4.20" ;
    ns1:requiereMantenimiento ns1:ModoAdministrador ;
    ns1:textoExtracto "Versión V4.20. Actualizar la versión de software. La versión se debe actualizar en modo administrador, no en modo setup como se hace habitualmente, para poder registrar de forma permanente las nuevas librerías." .

ns1:Software_V4.25 a ns1:Sistema ;
    rdfs:label "Software versión V4.25" ;
    ns1:controla ns1:FTIMELIM ;
    ns1:identificador "V4.25" ;
    ns1:textoExtracto "Versión V4.25. Cambio de unidades en el parámetro máquina FTIMELIM, relacionado con el mecanizado en HSC." .

ns1:Software_V5.31.01 a ns1:Sistema ;
    rdfs:label "Software versión V5.31.01" ;
    ns1:identificador "V5.31.01" ;
    ns1:monitoreaParametro ns1:G00COMP ;
    ns1:textoExtracto "Versión V5.31.01. Aplicar o no compensación de radio en G00. En esta versión, los movimientos en G00 no aplican la compensación de radio." .

ns1:Software_V5.40 a ns1:Sistema ;
    rdfs:label "Software versión V5.40" ;
    ns1:identificador "V5.40" ;
    ns1:textoExtracto "Versión V5.40. Nueva opción de software 'CANopen de terceros'." .

ns1:FTIMELIM a ns1:Parametro ;
    rdfs:label "FTIMELIM (parámetro máquina)" ;
    ns1:identificador "FTIMELIM" ;
    ns1:textoExtracto "Cambio de unidades en el parámetro máquina FTIMELIM, relacionado con el mecanizado en HSC. En versiones previas el parámetro FTIMELIM se programaba en milisegundos. A partir de este versión, este parámetro se define en porcentaje." .

ns1:G00COMP a ns1:Parametro ;
    rdfs:label "G00COMP (parámetro compensación radio)" ;
    ns1:identificador "G00COMP" ;
    ns1:textoExtracto "Ésto se corrige en versiones posteriores mediante el parámetro G00COMP." .

ns1:PANELOFF a ns1:Parametro ;
    rdfs:label "PANELOFF (marca PLC)" ;
    ns1:identificador "PANELOFF" ;
    ns1:textoExtracto "En versiones anteriores, la marca PANELOFF del PLC deshabilitaba tanto la parte de jog como la parte alfanumérica (módulo OP-PANEL-H/E). A partir de esta versión, la nueva marca QWERTYOFF deshabilita la parte alfanumérica y la marca PANELOFF sólo deshabilita el panel de jog." .

ns1:QWERTYOFF a ns1:Parametro ;
    rdfs:label "QWERTYOFF (marca PLC)" ;
    ns1:identificador "QWERTYOFF" ;
    ns1:textoExtracto "A partir de esta versión, la nueva marca QWERTYOFF deshabilita la parte alfanumérica y la marca PANELOFF sólo deshabilita el panel de jog." .

ns1:ModoAdministrador a ns1:ModoOperacion ;
    rdfs:label "Modo administrador" ;
    ns1:identificador "modo_administrador" ;
    ns1:textoExtracto "La versión se debe actualizar en modo administrador, no en modo setup como se hace habitualmente, para poder registrar de forma permanente las nuevas librerías." .

