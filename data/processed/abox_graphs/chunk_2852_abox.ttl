@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error9647 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de parámetros en captación digital Fagor" ;
    ns1:identificador "9647" ;
    ns1:solucionaFallo ns1:EncoderCaptacionDigitalFagor ;
    ns1:textoExtracto "Captación digital Fagor. Error de parámetros en captación. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Pérdida de la configuración del encóder o de la cabeza de la regla. SOLUCIÓN Reemplazar el encóder o la cabeza de la regla." .

ns1:Error9648 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en la alimentación de las salidas analógicas" ;
    ns1:identificador "9648" ;
    ns1:solucionaFallo ns1:SalidasAnalogicasCNC ;
    ns1:textoExtracto "Error en la alimentación de las salidas analógicas. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error en la alimentación de las salidas analógicas del CNC. SOLUCIÓN Revisar el conexionado de salida analógica." .

ns1:Error9649 a ns1:DiagnosticoFallo ;
    rdfs:label "Caída del bus de potencia en presencia de par" ;
    ns1:identificador "9649" ;
    ns1:solucionaFallo ns1:BusPotenciaSistema ;
    ns1:textoExtracto "Caída del bus de potencia en presencia de par. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Posible caída en alguna de las líneas trifásicas o fallo en algún regulador. SOLUCIÓN Comprobar que el estado de la líneas, los reguladores y revisar maniobra de potencia." .

ns1:Error9650 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación digital Fagor: Señal analógica por debajo de 0,4 Vpp" ;
    ns1:identificador "9650" ;
    ns1:solucionaFallo ns1:EntradasCaptacionDigitalFagor ;
    ns1:textoExtracto "Captación digital Fagor: Señal analógica por debajo de 0,4 Vpp. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Amplitud de señal de entrada por debajo de 0,4 Vpp aproximadamente. SOLUCIÓN Revisar los cables y la conexión de las entradas de captación." .

ns1:Error9651 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación digital Fagor: Alimentación del encoder fuera de valores deseables" ;
    ns1:identificador "9651" ;
    ns1:solucionaFallo ns1:EncoderCaptacionDigitalFagor ;
    ns1:textoExtracto "Captación digital Fagor: Alimentación del encoder fuera de valores deseables. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error interno en el encoder. SOLUCIÓN Revisar el conexionado e integridad del encoder." .

ns1:Error9652 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación digital Fagor: Velocidad excesiva en el eje" ;
    ns1:identificador "9652" ;
    ns1:solucionaFallo ns1:EncoderCaptacionDigitalFagor ;
    ns1:textoExtracto "Captación digital Fagor: Velocidad excesiva en el eje. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error interno en el encoder. SOLUCIÓN Revisar el conexionado e integridad del encoder." .

ns1:ReguladorPotencia a ns1:ComponenteElectrico ;
    rdfs:label "Regulador de potencia" ;
    ns1:textoExtracto "Posible caída en alguna de las líneas trifásicas o fallo en algún regulador." .

ns1:BusPotenciaSistema a ns1:ComponenteElectrico ;
    rdfs:label "Bus de potencia del sistema" ;
    ns1:textoExtracto "Posible caída en alguna de las líneas trifásicas o fallo en algún regulador. SOLUCIÓN Comprobar que el estado de la líneas, los reguladores y revisar maniobra de potencia." .

ns1:EntradasCaptacionDigitalFagor a ns1:ComponenteElectrico ;
    rdfs:label "Entradas de captación digital Fagor" ;
    ns1:textoExtracto "Amplitud de señal de entrada por debajo de 0,4 Vpp aproximadamente. SOLUCIÓN Revisar los cables y la conexión de las entradas de captación." .

ns1:SalidasAnalogicasCNC a ns1:ComponenteElectrico ;
    rdfs:label "Salidas analógicas del CNC" ;
    ns1:textoExtracto "Error en la alimentación de las salidas analógicas del CNC. SOLUCIÓN Revisar el conexionado de salida analógica." .

ns1:EncoderCaptacionDigitalFagor a ns1:ComponenteElectrico ;
    rdfs:label "Encoder o cabeza de regla de captación digital Fagor" ;
    ns1:textoExtracto "Pérdida de la configuración del encóder o de la cabeza de la regla. SOLUCIÓN Reemplazar el encóder o la cabeza de la regla." .

