@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ns1:textoExtracto "Si el error persiste, póngase en contacto con Fagor Automation"@es .

ns1:Error_9652 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación digital Fagor: Velocidad excesiva en el eje"@es ;
    ns1:identificador "9652" ;
    ns1:solucionaFallo ns1:Encoder_Defectuoso_9652 ;
    ns1:textoExtracto "9652 Captación digital Fagor: Velocidad excesiva en el eje. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error interno en el encoder. SOLUCIÓN Revisar el conexionado e integridad del encoder."@es .

ns1:Error_9653 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación digital Fagor: Temperatura interna fuera de rango"@es ;
    ns1:identificador "9653" ;
    ns1:textoExtracto "9653 Captación digital Fagor: Temperatura interna fuera de rango. DETECCIÓN Durante el funcionamiento habitual del sistema."@es .

ns1:Encoder_Defectuoso_9652 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "Error interno en el encoder"@es .

