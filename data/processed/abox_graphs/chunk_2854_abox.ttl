@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_9653 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación digital Fagor: Temperatura interna fuera de rango" ;
    ns1:identificador "9653" ;
    ns1:solucionaFallo ns1:Encoder ;
    ns1:textoExtracto "9653 Captación digital Fagor: Temperatura interna fuera de rango. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Sobretemperatura en el encoder. SOLUCIÓN Revisar el conexionado e integridad del encoder." .

ns1:Error_9654 a ns1:DiagnosticoFallo ;
    rdfs:label "Captación digital Fagor: Pérdida de sincronización SOL" ;
    ns1:identificador "9654" ;
    ns1:solucionaFallo ns1:Encoder ;
    ns1:textoExtracto "9654 Captación digital Fagor: Pérdida de sincronización SOL. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Error de comunicación del encoder. SOLUCIÓN Revisar el conexionado e integridad del encoder." .

ns1:Error_9655 a ns1:DiagnosticoFallo ;
    rdfs:label "Pulso de I0 no detectado" ;
    ns1:identificador "9655" ;
    ns1:solucionaFallo ns1:Encoder,
        ns1:Regulador ;
    ns1:textoExtracto "9655 Pulso de I0 no detectado. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El regulador no ha recibido la señal de I0. SOLUCIÓN Revisar la parametrización y el conexionado del encoder." .

ns1:Error_9656 a ns1:DiagnosticoFallo ;
    rdfs:label "Falta fase en la tarjeta sense" ;
    ns1:identificador "9656" ;
    ns1:solucionaFallo ns1:TarjetaSense ;
    ns1:textoExtracto "9656 Falta fase en la tarjeta sense. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Una fase de red no llega correctamente a la tarjeta sense. SOLUCIÓN Revisar tensiones de red y cableado hasta la tarjeta sense." .

ns1:Error_9657 a ns1:DiagnosticoFallo ;
    rdfs:label "Nivel de tensión por debajo del 80%" ;
    ns1:identificador "9657" ;
    ns1:solucionaFallo ns1:TarjetaSense ;
    ns1:textoExtracto "9657 Nivel de tensión por debajo del 80%. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Bajada en la tensión de red. Durante un breve periodo, la tensión de red no ha alcanzado el 80 % del valor esperado. SOLUCIÓN Revisar tensiones de red y cableado hasta la tarjeta sense." ;
    ns1:valor "80%" .

ns1:Error_9658 a ns1:DiagnosticoFallo ;
    rdfs:label "Nivel de tensión por debajo del 70%" ;
    ns1:identificador "9658" ;
    ns1:solucionaFallo ns1:TarjetaSense ;
    ns1:textoExtracto "9658 Nivel de tensión por debajo del 70%. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Bajada en la tensión de red. Durante un breve periodo, la tensión de red no ha alcanzado el 70 % del valor esperado. SOLUCIÓN Revisar tensiones de red y cableado hasta la tarjeta sense." ;
    ns1:valor "70%" .

ns1:Error_9659 a ns1:DiagnosticoFallo ;
    rdfs:label "Nivel de tensión por debajo del 40%" ;
    ns1:identificador "9659" ;
    ns1:textoExtracto "9659 Nivel de tensión por debajo del 40%. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Bajada en la tensión de red." ;
    ns1:valor "40%" .

ns1:Regulador a ns1:ComponenteElectrico ;
    rdfs:label "Regulador" ;
    ns1:textoExtracto "El regulador no ha recibido la señal de I0." .

ns1:Encoder a ns1:ComponenteElectrico ;
    rdfs:label "Encoder" ;
    ns1:textoExtracto "Revisar el conexionado e integridad del encoder." .

ns1:TarjetaSense a ns1:ComponenteElectrico ;
    rdfs:label "Tarjeta sense" ;
    ns1:textoExtracto "Falta fase en la tarjeta sense. Revisar tensiones de red y cableado hasta la tarjeta sense." .

