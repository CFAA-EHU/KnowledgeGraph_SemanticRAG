@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_9659 a ns1:DiagnosticoFallo ;
    rdfs:label "Nivel de tensión por debajo del 40%"@es ;
    ns1:identificador "9659" ;
    ns1:solucionaFallo ns1:Solucion_RevisarTensiones_9659 ;
    ns1:textoExtracto "9659 Nivel de tensión por debajo del 40%. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Bajada en la tensión de red. Durante un breve periodo, la tensión de red no ha alcanzado el 40 % del valor esperado."@es .

ns1:Fallo_9660 a ns1:DiagnosticoFallo ;
    rdfs:label "Nivel de tensión cerca del 0%"@es ;
    ns1:identificador "9660" ;
    ns1:textoExtracto "9660 Nivel de tensión cerca del 0%. DETECCIÓN Durante el"@es .

ns1:Parametro_TensionRed a ns1:Parametro ;
    rdfs:label "Tensión de red"@es ;
    ns1:monitoreaParametro ns1:TarjetaSense ;
    ns1:textoExtracto "Bajada en la tensión de red. Durante un breve periodo, la tensión de red no ha alcanzado el 40 % del valor esperado."@es .

ns1:Solucion_RevisarTensiones_9659 a ns1:TareaMantenimiento ;
    rdfs:label "Revisar tensiones de red y cableado hasta la tarjeta sense"@es ;
    ns1:requiereMantenimiento ns1:TarjetaSense ;
    ns1:textoExtracto "SOLUCIÓN Revisar tensiones de red y cableado hasta la tarjeta sense."@es .

ns1:TarjetaSense a ns1:ComponenteElectrico ;
    rdfs:label "Tarjeta sense"@es ;
    ns1:textoExtracto "cableado hasta la tarjeta sense"@es .

