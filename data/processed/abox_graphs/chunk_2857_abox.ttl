@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MotorEje a ns1:ComponenteElectrico ;
    rdfs:label "Motor del eje"@es ;
    ns1:textoExtracto "fallo en el motor"@es .

ns1:Parametro_G00FEED a ns1:Parametro ;
    rdfs:label "Parámetro G00FEED"@es ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "SOLUCIÓN Revisar el parámetro G00FEED."@es .

ns1:Parametro_MAXFLWE a ns1:Parametro ;
    rdfs:label "Parámetro MAXFLWE"@es ;
    ns1:identificador "MAXFLWE" ;
    ns1:monitoreaParametro ns1:Error_9709 ;
    ns1:textoExtracto "El eje ha superado el error de seguimiento permitido (parámetro MAXFLWE)."@es .

ns1:ReguladorEje a ns1:ComponenteElectrico ;
    rdfs:label "Regulador del eje"@es ;
    ns1:textoExtracto "fallo en el regulador"@es .

ns1:SistemaEje a ns1:Sistema ;
    rdfs:label "Sistema de eje"@es ;
    ns1:activaAlarma ns1:Error_9709 ;
    ns1:textoExtracto "El eje ha superado el error de seguimiento permitido"@es .

ns1:Solucion_Revisar_G00FEED a ns1:TareaMantenimiento ;
    rdfs:label "Revisar parámetro G00FEED"@es ;
    ns1:solucionaFallo ns1:Error_9709 ;
    ns1:textoExtracto "SOLUCIÓN Revisar el parámetro G00FEED."@es .

ns1:Error_9709 a ns1:AvisoSeguridad ;
    rdfs:label "Error 9709: Error de seguimiento excesivo"@es ;
    ns1:identificador "9709" ;
    ns1:textoExtracto "9709 Error de seguimiento excesivo. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El eje ha superado el error de seguimiento permitido (parámetro MAXFLWE)."@es .

