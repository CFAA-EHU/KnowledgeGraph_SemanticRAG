@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Eje_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Eje o cabezal" ;
    ns1:activaAlarma ns1:Fallo_9719 ;
    ns1:textoExtracto "cambio de ser en un eje o cabezal." .

ns1:Fallo_I0TYPE a ns1:DiagnosticoFallo ;
    rdfs:label "Incoherencia en I0s latcheados" ;
    ns1:solucionaFallo ns1:I0TYPE_a32b919423 ;
    ns1:textoExtracto "DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Los I0s latcheados no son coherentes. SOLUCIÓN Revisar parámetro I0TYPE (cambiar creciente por decreciente o viceversa)." .

ns1:Modulo_DrcLoop a ns1:ComponenteElectrico ;
    rdfs:label "Módulo DrcLoop" ;
    ns1:activaAlarma ns1:Fallo_9719 ;
    ns1:textoExtracto "Warning en DrcLoop." .

ns1:Parametro_CNCTIME a ns1:Parametro ;
    rdfs:label "CNCTIME" ;
    ns1:identificador "CNCTIME" ;
    ns1:textoExtracto "Revisar parámetros CNCTIME, SYSTEMTIME, POS_LOOPTIME." .

ns1:Parametro_I0TYPE a ns1:Parametro ;
    rdfs:label "I0TYPE" ;
    ns1:identificador "I0TYPE" ;
    ns1:textoExtracto "Revisar parámetro I0TYPE (cambiar creciente por decreciente o viceversa)." .

ns1:Parametro_POS_LOOPTIME a ns1:Parametro ;
    rdfs:label "POS_LOOPTIME" ;
    ns1:identificador "POS_LOOPTIME" ;
    ns1:textoExtracto "Revisar parámetros CNCTIME, SYSTEMTIME, POS_LOOPTIME." .

ns1:Parametro_SYSTEMTIME a ns1:Parametro ;
    rdfs:label "SYSTEMTIME" ;
    ns1:identificador "SYSTEMTIME" ;
    ns1:textoExtracto "Revisar parámetros CNCTIME, SYSTEMTIME, POS_LOOPTIME." .

ns1:Regulador a ns1:ComponenteElectrico ;
    rdfs:label "Regulador" ;
    ns1:activaAlarma ns1:Fallo_9718,
        ns1:Fallo_9720 ;
    ns1:textoExtracto "Los reguladores no se sincronizan entre ellos." .

ns1:CNCTIME_eff29762a8 a ns1:Parametro ;
    rdfs:label "CNCTIME" ;
    ns1:identificador "CNCTIME" ;
    ns1:textoExtracto "Revisar parámetros CNCTIME, SYSTEMTIME, POS_LOOPTIME." .

ns1:Fallo_9718 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en la sincronización entre módulos" ;
    ns1:identificador "9718" ;
    ns1:solucionaFallo ns1:FrecuenciaDeEjecucionDeLazos ;
    ns1:textoExtracto "DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Los reguladores no se sincronizan entre ellos. SOLUCIÓN Reducir la frecuencia de ejecución de los lazos." .

ns1:Fallo_9720 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el regulador" ;
    ns1:identificador "9720" ;
    ns1:textoExtracto "DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El regulador ha generado un error sin determinar." .

ns1:FrecuenciaDeEjecucionDeLazos a ns1:Parametro ;
    rdfs:label "Frecuencia de ejecución de lazos" ;
    ns1:textoExtracto "Reducir la frecuencia de ejecución de los lazos." .

ns1:I0TYPE_a32b919423 a ns1:Parametro ;
    rdfs:label "I0TYPE" ;
    ns1:identificador "I0TYPE" ;
    ns1:textoExtracto "Revisar parámetro I0TYPE (cambiar creciente por decreciente o viceversa)." .

ns1:POSLOOPTIME a ns1:Parametro ;
    rdfs:label "POS_LOOPTIME" ;
    ns1:identificador "POS_LOOPTIME" ;
    ns1:textoExtracto "Revisar parámetros CNCTIME, SYSTEMTIME, POS_LOOPTIME." .

ns1:SYSTEMTIME_0e55982614 a ns1:Parametro ;
    rdfs:label "SYSTEMTIME" ;
    ns1:identificador "SYSTEMTIME" ;
    ns1:textoExtracto "Revisar parámetros CNCTIME, SYSTEMTIME, POS_LOOPTIME." .

ns1:Fallo_9719 a ns1:DiagnosticoFallo ;
    rdfs:label "Warning en DrcLoop" ;
    ns1:identificador "9719" ;
    ns1:solucionaFallo ns1:CNCTIME_eff29762a8,
        ns1:POSLOOPTIME,
        ns1:SYSTEMTIME_0e55982614 ;
    ns1:textoExtracto "DETECCIÓN Durante el arranque del sistema, validación de parámetros o cambio de ser en un eje o cabezal. CAUSA Error en el chequeo de coherencia de parámetros de tiempos de ciclo o error en la inicialización de los parámetros de un eje o cabezal. SOLUCIÓN Revisar parámetros CNCTIME, SYSTEMTIME, POS_LOOPTIME." .

