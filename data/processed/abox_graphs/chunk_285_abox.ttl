@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_G00COMP a ns1:Parametro ;
    rdfs:label "G00COMP" ;
    ns1:identificador "G00COMP" ;
    ns1:textoExtracto "los movimientos en G00 no aplican la compensación de radio. Ésto se corrige en versiones posteriores mediante el parámetro G00COMP" .

ns1:VersionSoftware_V5.40 a ns1:Sistema ;
    rdfs:label "Versión V5.40" ;
    ns1:identificador "V5.40" ;
    ns1:textoExtracto "Nueva opción de software 'CANopen de terceros'. A partir de esta versión, si una máquina estuviera usando algún módulo CANopen no Fagor" ;
    ns1:tieneComponente ns1:ModuloCANopenTerceros .

ns1:ModuloCANopenTerceros a ns1:ComponenteElectrico ;
    rdfs:label "Módulo CANopen de terceros" ;
    ns1:textoExtracto "si una máquina estuviera usando algún módulo CANopen no Fagor" .

