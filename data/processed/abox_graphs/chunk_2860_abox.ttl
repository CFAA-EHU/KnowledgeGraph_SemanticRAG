@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Motor_9721 a ns1:ComponenteElectrico ;
    rdfs:label "Motor" ;
    ns1:activaAlarma ns1:Error9721 ;
    ns1:textoExtracto "Protección I²t del motor. El ciclo de trabajo es demasiado exigente para el motor" .

ns1:ProteccionI2t a ns1:Sensor ;
    rdfs:label "Protección I²t" ;
    ns1:monitoreaParametro ns1:ParametroSobrecarga ;
    ns1:textoExtracto "Protección I²t del motor" .

ns1:Regulador_9720 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador" ;
    ns1:activaAlarma ns1:Error9720 ;
    ns1:textoExtracto "El regulador ha generado un error sin determinar" .

ns1:Error9720 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el regulador" ;
    ns1:identificador "9720" ;
    ns1:textoExtracto "9720 Error en el regulador. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El regulador ha generado un error sin determinar. SOLUCIÓN Resetear los errores. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Error9721 a ns1:DiagnosticoFallo ;
    rdfs:label "Sobrecarga en el motor" ;
    ns1:identificador "9721" ;
    ns1:textoExtracto "9721 Sobrecarga en el motor. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Protección I²t del motor. El ciclo de trabajo es demasiado exigente para el motor. SOLUCIÓN Adecuar el ciclo de trabajo, reducir el par aplicado al" .

ns1:ParametroSobrecarga a ns1:Parametro ;
    rdfs:label "Sobrecarga del motor" ;
    ns1:textoExtracto "El ciclo de trabajo es demasiado exigente para el motor" ;
    ns1:valor "Sobrecarga" .

