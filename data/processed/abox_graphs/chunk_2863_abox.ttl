@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error9724 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el seguimiento de la rampa de emergencia en frenada"@es ;
    ns1:identificador "9724" ;
    ns1:solucionaFallo ns1:EMERGTIMEMAX_53cf22fcf4,
        ns1:EMERGVELMAX_d160e57d1e ;
    ns1:textoExtracto "Error en el seguimiento de la rampa de emergencia en frenada. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA La parada del eje o cabezal no puede seguir la rampa de emergencia (parámetros EMERGVELMAX y EMERGTIMEMAX)."@es .

ns1:Error9725 a ns1:DiagnosticoFallo ;
    rdfs:label "Diferencia excesiva de la posición real"@es ;
    ns1:identificador "9725" ;
    ns1:textoExtracto "Diferencia excesiva de la posición real. DETECCIÓN Durante el"@es .

ns1:SistemaFrenadoEmergencia a ns1:Sistema ;
    rdfs:label "Sistema de frenado de emergencia"@es ;
    ns1:monitoreaParametro ns1:EMERGTIMEMAX_53cf22fcf4,
        ns1:EMERGVELMAX_d160e57d1e ;
    ns1:textoExtracto "rampa de emergencia en frenada"@es .

ns1:EjeOCabezal a ns1:ComponenteMecanico ;
    rdfs:label "eje o cabezal"@es ;
    ns1:textoExtracto "eje o cabezal"@es .

ns1:Maquina a ns1:Maquina ;
    ns1:textoExtracto "Adecuar las exigencias de la frenada de su máquina"@es ;
    ns1:tieneComponente ns1:EjeOCabezal .

ns1:EMERGTIMEMAX_53cf22fcf4 a ns1:Parametro ;
    rdfs:label "EMERGTIMEMAX" ;
    ns1:textoExtracto "parámetro EMERGTIMEMAX"@es .

ns1:EMERGVELMAX_d160e57d1e a ns1:Parametro ;
    rdfs:label "EMERGVELMAX" ;
    ns1:textoExtracto "parámetro EMERGVELMAX"@es .

