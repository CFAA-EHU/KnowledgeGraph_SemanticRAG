@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_9728 a ns1:Alarma ;
    rdfs:label "Alarma 9728: Sobrevelocidad" ;
    ns1:identificador "9728" ;
    ns1:textoExtracto "9728 Sobrevelocidad. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA Límite de velocidad alcanzado. SOLUCIÓN Revisar parametrización y/o ajuste del sistema." .

ns1:Alarma_9729 a ns1:Alarma ;
    rdfs:label "Alarma 9729: OverRun" ;
    ns1:identificador "9729" ;
    ns1:textoExtracto "9729 OverRun. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA El signo de la consigna de par y del feedback de velocidad es erróneo. SOLUCIÓN Revisar los parámetros INVERT y LOOPCH." .

ns1:Componente_Motor a ns1:ComponenteElectrico ;
    rdfs:label "Motor regulado" ;
    ns1:controla ns1:Componente_Regulador ;
    ns1:textoExtracto "reducir el par aplicado al motor" .

ns1:Componente_RPS a ns1:ComponenteElectrico ;
    rdfs:label "RPS (Resolutor de Posición)" ;
    ns1:activaAlarma ns1:Alarma_9730 ;
    ns1:textoExtracto "9730 Error en la RPS. [...] La RPS ha generado un error sin determinar." .

ns1:Componente_Volante a ns1:ComponenteMecanico ;
    rdfs:label "Volante de captación" ;
    ns1:activaAlarma ns1:Alarma_9731 ;
    ns1:textoExtracto "9731 Alarma de captación en volante." .

ns1:DiagnosticoFallo_ProteccionI2t a ns1:DiagnosticoFallo ;
    rdfs:label "Protección I²t del regulador" ;
    ns1:solucionaFallo ns1:Alarma_ProteccionI2t ;
    ns1:textoExtracto "CAUSA Protección I²t del regulador. El ciclo de trabajo es demasiado exigente para el regulador. SOLUCIÓN Adecuar el ciclo de trabajo, reducir el par aplicado al motor o utilizar un regulador de más potencia." .

ns1:Parametro_INVERT a ns1:Parametro ;
    rdfs:label "Parámetro INVERT" ;
    ns1:identificador "INVERT" ;
    ns1:textoExtracto "Revisar los parámetros INVERT y LOOPCH." .

ns1:Parametro_LOOPCH a ns1:Parametro ;
    rdfs:label "Parámetro LOOPCH" ;
    ns1:identificador "LOOPCH" ;
    ns1:textoExtracto "Revisar los parámetros INVERT y LOOPCH." .

ns1:Sistema_Regulacion a ns1:Sistema ;
    rdfs:label "Sistema de regulación de velocidad y par" ;
    ns1:textoExtracto "El ciclo de trabajo es demasiado exigente para el regulador. [...] Revisar parametrización y/o ajuste del sistema. [...] El signo de la consigna de par y del feedback de velocidad es erróneo." ;
    ns1:tieneComponente ns1:Componente_Regulador .

ns1:Alarma_9730 a ns1:Alarma ;
    rdfs:label "Alarma 9730: Error en la RPS" ;
    ns1:identificador "9730" ;
    ns1:textoExtracto "9730 Error en la RPS. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La RPS ha generado un error sin determinar. SOLUCIÓN Resetear los errores. Si el error persiste, póngase en contacto con Fagor Automation." .

ns1:Alarma_9731 a ns1:Alarma ;
    rdfs:label "Alarma 9731: Captación en volante" ;
    ns1:identificador "9731" ;
    ns1:textoExtracto "9731 Alarma de captación en volante. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema." .

ns1:Alarma_ProteccionI2t a ns1:Alarma ;
    rdfs:label "Alarma por protección I²t" ;
    ns1:textoExtracto "Protección I²t del regulador. El ciclo de trabajo es demasiado exigente para el regulador." .

ns1:Componente_Regulador a ns1:ComponenteElectrico ;
    rdfs:label "Regulador de velocidad/par" ;
    ns1:textoExtracto "Protección I²t del regulador. [...] utilizar un regulador de más potencia." .

