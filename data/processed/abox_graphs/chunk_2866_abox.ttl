@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:alarma_9733 a ns1:Alarma ;
    rdfs:label "Fallo en la comunicación double AT Miss"@es ;
    ns1:activaAlarma ns1:fallo_comunicacion_9733 ;
    ns1:identificador "9733" ;
    ns1:textoExtracto "9733 Fallo en la comunicación double AT Miss. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema."@es .

ns1:alarma_9731 a ns1:Alarma ;
    rdfs:label "Alarma de captación en volante"@es ;
    ns1:identificador "9731" ;
    ns1:mitigaRiesgo ns1:aviso_9731 ;
    ns1:textoExtracto "Alarma de captación en volante. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Alarma de captación en el volante de la entrada de captación del regulador."@es .

ns1:aviso_9731 a ns1:AvisoSeguridad ;
    rdfs:label "Revisión de conexionado y alimentación del volante"@es ;
    ns1:solucionaFallo ns1:fallo_captacion_volante ;
    ns1:textoExtracto "SOLUCIÓN Revisar el conexionado y la alimentación del volante."@es .

ns1:fallo_captacion_volante a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en captación del volante (regulador)"@es ;
    ns1:activaAlarma ns1:alarma_9731 ;
    ns1:textoExtracto "CAUSA Alarma de captación en el volante de la entrada de captación del regulador."@es .

ns1:fallo_comunicacion_9733 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de comunicación double AT Miss"@es ;
    ns1:textoExtracto "9733 Fallo en la comunicación double AT Miss. DETECCIÓN Durante el arranque o funcionamiento habitual del sistema. CAUSA Error de"@es .

