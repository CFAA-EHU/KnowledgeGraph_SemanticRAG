@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CableTransmision a ns1:ComponenteElectrico ;
    rdfs:label "Cable de transmisión"@es ;
    ns1:textoExtracto "Revisar el cable de transmisión"@es .

ns1:FalloDataLink a ns1:AvisoSeguridad ;
    rdfs:label "DataLink no presente"@es ;
    ns1:identificador "9738" ;
    ns1:textoExtracto "9738 DataLink no presente."@es .

ns1:RuidoTransmision a ns1:Parametro ;
    rdfs:label "Ruido en transmisión"@es ;
    ns1:monitoreaParametro ns1:SolucionErrorSincronizacion ;
    ns1:textoExtracto "comprobar que no hay presencia de ruido en la transmisión"@es .

ns1:ErrorSincronizacionReguladores a ns1:AvisoSeguridad ;
    rdfs:label "Error de sincronización de reguladores"@es ;
    ns1:identificador "9738" ;
    ns1:textoExtracto "Si en algún momento los reguladores no pueden sincronizarse o pierden la sincronización, se origina este error."@es .

ns1:SolucionErrorSincronizacion a ns1:DiagnosticoFallo ;
    rdfs:label "Revisión de cable de transmisión y ruido"@es ;
    ns1:solucionaFallo ns1:ErrorSincronizacionReguladores ;
    ns1:textoExtracto "Posiblemente el CNC no ha enviado este mensaje o si lo ha hecho no ha sido en el momento exacto. Revisar el cable de transmisión o comprobar que no hay presencia de ruido en la transmisión."@es .

