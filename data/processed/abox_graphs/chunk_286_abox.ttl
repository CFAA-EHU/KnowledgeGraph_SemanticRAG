@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Herramienta_Portaherramientas a ns1:Herramienta ;
    rdfs:label "Portaherramientas" ;
    ns1:textoExtracto "Gráficos HD y orientación del portaherramientas. [...] los gráficos HD de fresadora tienen en cuenta la orientación de la herramienta, definida en la tabla de herramientas." .

ns1:Maquina_ModeloM a ns1:Maquina ;
    rdfs:label "Máquina (modelo M)" ;
    ns1:textoExtracto "En el modelo M, los ciclos fijos asociados a los ejes rotativos necesitan que esté definido el eje longitudinal (parámetro LONGAXIS) y el eje transversal (parámetro FACEAXIS)." ;
    ns1:tieneComponente ns1:Sistema_GraficosHD .

ns1:OpcionSoftware_CANopenTerceros a ns1:Componente ;
    rdfs:label "Opción de software 'CANopen de terceros'" ;
    ns1:textoExtracto "Nueva opción de software 'CANopen de terceros'. A partir de esta versión, si una máquina estuviera usando algún módulo CANopen no Fagor, el CNC no lo reconocerá, y durante la inicialización del bus CAN dara el error correspondiente." .

ns1:OpcionSoftware_Palpador a ns1:Componente ;
    rdfs:label "Opción de software 'Palpador'" ;
    ns1:textoExtracto "Ampliación del alcance de la opción de la software 'Ciclos fijos de palpador'. La opción de software 'Ciclos fijos de palpador' pasa a llamarse 'Palpador'. A partir de esta versión, las funciones G100, G101, G102, G103 y G104 necesitan esta opción de software." .

ns1:Parametro_G00COMP a ns1:Parametro ;
    rdfs:label "Parámetro G00COMP" ;
    ns1:identificador "G00COMP" ;
    ns1:textoExtracto "posteriores mediante el parámetro G00COMP. Versión V5.40." .

ns1:Parametro_FACEAXIS a ns1:Parametro ;
    rdfs:label "Parámetro FACEAXIS" ;
    ns1:identificador "FACEAXIS" ;
    ns1:textoExtracto "el eje transversal (parámetro FACEAXIS)" .

ns1:Parametro_LONGAXIS a ns1:Parametro ;
    rdfs:label "Parámetro LONGAXIS" ;
    ns1:identificador "LONGAXIS" ;
    ns1:textoExtracto "el eje longitudinal (parámetro LONGAXIS)" .

ns1:Sistema_GraficosHD a ns1:Sistema ;
    rdfs:label "Sistema de gráficos HD" ;
    ns1:ilustradoEn ns1:TablaHerramientas ;
    ns1:monitoreaParametro ns1:Parametro_FACEAXIS,
        ns1:Parametro_LONGAXIS ;
    ns1:textoExtracto "Gráficos HD y orientación del portaherramientas. En el modelo M, los ciclos fijos asociados a los ejes rotativos necesitan que esté definido el eje longitudinal (parámetro LONGAXIS) y el eje transversal (parámetro FACEAXIS). Cuando está definido alguno de estos parámetros, los gráficos HD de fresadora tienen en cuenta la orientación de la herramienta, definida en la tabla de herramientas." .

ns1:TablaHerramientas a ns1:Tabla ;
    rdfs:label "Tabla de herramientas" ;
    ns1:textoExtracto "los gráficos HD de fresadora tienen en cuenta la orientación de la herramienta, definida en la tabla de herramientas." .

