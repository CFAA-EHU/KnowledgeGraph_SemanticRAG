@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_Reset a ns1:InterfazUsuario ;
    rdfs:label "Botón RESET"@es ;
    ns1:solucionaFallo ns1:Fallo_20015,
        ns1:Fallo_20016,
        ns1:Fallo_20017,
        ns1:Fallo_20018,
        ns1:Fallo_20019,
        ns1:Fallo_20020 ;
    ns1:textoExtracto "Pulsar [RESET] y analizar las causas del retraso."@es .

ns1:Senal_XFERINH a ns1:Sensor ;
    rdfs:label "Señal XFERINH"@es ;
    ns1:monitoreaParametro ns1:Parametro_Transferencia ;
    ns1:textoExtracto "El PLC debe activar la señal _XFERINH."@es .

ns1:Fallo_20015 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 20015: G33/G34/G95 con cabezal parado"@es ;
    ns1:identificador "20015" ;
    ns1:textoExtracto "20015 G33/G34/G95 con cabezal %x parado. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El cabezal debe ponerse en marcha para ejecutar G33/G34/G95."@es .

ns1:Fallo_20016 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 20016: Esperando finalizar petición de ejes"@es ;
    ns1:identificador "20016" ;
    ns1:textoExtracto "20016 Esperando finalizar petición de ejes. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El eje solicitado debe llegar al canal o ser liberado por otro."@es .

ns1:Fallo_20017 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 20017: Esperando finalizar petición de cabezal"@es ;
    ns1:identificador "20017" ;
    ns1:textoExtracto "20017 Esperando finalizar petición de cabezal. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El cabezal solicitado debe llegar al canal o ser liberado por otro."@es .

ns1:Fallo_20018 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 20018: Esperando finalizar forzar cota (G174)"@es ;
    ns1:identificador "20018" ;
    ns1:textoExtracto "20018 Esperando finalizar forzar cota (G174) del eje %x. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. La función G174 debe finalizar."@es .

ns1:Fallo_20019 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 20019: Esperando señal XFERINH del PLC"@es ;
    ns1:identificador "20019" ;
    ns1:textoExtracto "20019 Esperando señal XFERINH del PLC. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El PLC debe activar la señal _XFERINH."@es .

ns1:Fallo_20020 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 20020: Esperando ejes en posición"@es ;
    ns1:identificador "20020" ;
    ns1:textoExtracto "20020 Esperando ejes en posición. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo."@es .

ns1:Parametro_Transferencia a ns1:Parametro ;
    rdfs:label "Parámetro de transferencia (XFERINH)"@es ;
    ns1:textoExtracto "Esperando señal XFERINH del PLC."@es .

