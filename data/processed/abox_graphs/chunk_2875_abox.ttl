@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_20020 a ns1:DiagnosticoFallo ;
    rdfs:label "Espera de ejes en posición superada" ;
    ns1:identificador "20020" ;
    ns1:solucionaFallo ns1:PulsarRESETSinAnalisisPrevio ;
    ns1:textoExtracto "Esperando ejes en posición. [...] La espera ha superado un tiempo determinado por causa" .

ns1:Fallo_20021 a ns1:DiagnosticoFallo ;
    rdfs:label "Espera de inicialización de captaciones" ;
    ns1:identificador "20021" ;
    ns1:solucionaFallo ns1:PulsarRESETSinAnalisisPrevio ;
    ns1:textoExtracto "Esperando inicialización de captaciones. DETECCIÓN Durante el funcionamiento" .

ns1:InterfazUsuario_Reset a ns1:InterfazUsuario ;
    rdfs:label "Botón [RESET]" ;
    ns1:identificador "RESET" ;
    ns1:textoExtracto "Pulsar [RESET] y analizar las causas del retraso." .

ns1:Senal_XFERINH a ns1:Parametro ;
    rdfs:label "Señal _XFERINH" ;
    ns1:identificador "_XFERINH" ;
    ns1:monitoreaParametro ns1:SensorDeTransferenciaImplicitoEnPLC ;
    ns1:textoExtracto "El PLC debe activar la señal _XFERINH." .

ns1:SensorDeTransferenciaImplicitoEnPLC a ns1:Sensor ;
    rdfs:label "Sensor de transferencia (implícito en PLC)" ;
    ns1:textoExtracto "El PLC debe activar la señal _XFERINH." .

ns1:PulsarRESETSinAnalisisPrevio a ns1:AccionProhibida ;
    rdfs:label "Pulsar [RESET] sin análisis previo" ;
    ns1:textoExtracto "SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso." .

