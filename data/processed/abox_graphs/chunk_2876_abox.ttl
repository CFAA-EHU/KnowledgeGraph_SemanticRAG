@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_20021 a ns1:AvisoSeguridad ;
    rdfs:label "Esperando inicialización de captaciones" ;
    ns1:identificador "20021" ;
    ns1:textoExtracto "20021 Esperando inicialización de captaciones. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. La inicialización de las captaciones debe finalizar." .

ns1:AvisoSeguridad_20024 a ns1:AvisoSeguridad ;
    rdfs:label "Esperando parámetros nuevo Set del eje/cabezal %x" ;
    ns1:identificador "20024" ;
    ns1:textoExtracto "20024 Esperando parámetros nuevo Set del eje/cabezal %x. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. Los parámetros del nuevo set deben llegar." .

ns1:AvisoSeguridad_20025 a ns1:AvisoSeguridad ;
    rdfs:label "Esperando finalizar cambio de gama anterior del eje/cabezal %x" ;
    ns1:identificador "20025" ;
    ns1:textoExtracto "20025 Esperando finalizar cambio de gama anterior del eje/cabezal %x. DETECCIÓN Durante el funcionamiento habitual del sistema. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El cambio de set debe finalizar." .

ns1:AvisoSeguridad_20026 a ns1:AvisoSeguridad ;
    rdfs:label "Esperando bloques de ciclo" ;
    ns1:identificador "20026" ;
    ns1:textoExtracto "20026 Esperando bloques de ciclo. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar." .

ns1:AvisoSeguridad_20027 a ns1:AvisoSeguridad ;
    rdfs:label "Esperando pasar a lazo abierto el cabezal %x" ;
    ns1:identificador "20027" ;
    ns1:textoExtracto "20027 Esperando pasar a lazo abierto el cabezal %x. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo." .

ns1:Componente_Cabezal a ns1:Componente ;
    rdfs:label "Cabezal (eje/cabezal %x)" ;
    ns1:textoExtracto "Esperando parámetros nuevo Set del eje/cabezal %x... Esperando finalizar cambio de gama anterior del eje/cabezal %x... Esperando pasar a lazo abierto el cabezal %x." .

ns1:ModoOperacion_ModoCompatible a ns1:ModoOperacion ;
    rdfs:label "Modo compatible (sin opción #HSC FAST/SURFACE)" ;
    ns1:habilitadoPor ns1:AvisoSeguridad_20022 ;
    ns1:textoExtracto "Ejecutándose en modo compatible." .

ns1:Sistema_DMC a ns1:Sistema ;
    rdfs:label "Sistema DMC (Dynamic Motion Control)" ;
    ns1:activaAlarma ns1:AvisoSeguridad_20023 ;
    ns1:textoExtracto "El DMC avisa que ha empezado el aprendizaje." .

ns1:AvisoSeguridad_20022 a ns1:AvisoSeguridad ;
    rdfs:label "Opción de software #HSC FAST/SURFACE no permitida" ;
    ns1:identificador "20022" ;
    ns1:textoExtracto "20022 Opción de software #HSC FAST/SURFACE no permitida. Ejecutándose en modo compatible. DETECCIÓN Durante la ejecución. CAUSA Programación de #HSC no permitida porque falta la opción de software. SOLUCIÓN Adquirir la opción de software o programar una opción permitida." .

ns1:AvisoSeguridad_20023 a ns1:AvisoSeguridad ;
    rdfs:label "DMC: aprendizaje para ajustar la potencia objetivo" ;
    ns1:identificador "20023" ;
    ns1:textoExtracto "20023 DMC: aprendizaje para ajustar la potencia objetivo. DETECCIÓN Durante la ejecución. CAUSA El DMC avisa que ha empezado el aprendizaje. SOLUCIÓN No requiere ninguna acción." .

