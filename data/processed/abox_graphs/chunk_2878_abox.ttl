@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alerta20028 a ns1:AvisoSeguridad ;
    rdfs:label "Espera en lazo cerrado (cabezal %x)"@es ;
    ns1:identificador "20028" ;
    ns1:mitigaRiesgo ns1:InterfazUsuarioCNC ;
    ns1:textoExtracto "Esperando pasar a lazo cerrado el cabezal %x. DETECCIÓN Durante la ejecución. CAUSA La espera ha superado un tiempo determinado por causa justificada o bloqueo. SOLUCIÓN Pulsar [RESET] y analizar las causas del retraso. El proceso debe finalizar."@es .

ns1:Alerta20029 a ns1:AvisoSeguridad ;
    rdfs:label "Movimiento de eje rotativo bloqueado por RTCP STATIC"@es ;
    ns1:identificador "20029" ;
    ns1:mitigaRiesgo ns1:FuncionRTCP_STATIC ;
    ns1:textoExtracto "Movimiento de eje rotativo no permitido con RTCP STATIC activo. DETECCIÓN Durante la ejecución. CAUSA El CNC ha intentado mover un eje afectado por RTCP STATIC. SOLUCIÓN Desactivar la función de RTCP STATIC."@es .

ns1:Alerta20111 a ns1:AvisoSeguridad ;
    rdfs:label "Versión incompatible de archivo .xca"@es ;
    ns1:identificador "20111" ;
    ns1:textoExtracto "El fichero .xca cargado es una versión anterior y no compatible con la versión actual del CNC. DETECCIÓN Al cargar archivos xca. CAUSA El archivo xca es v1.0 y debe ser v2.0. SOLUCIÓN Convertir el archivo a v2.0."@es .

ns1:InterfazUsuarioCNC a ns1:InterfazUsuario ;
    ns1:habilitadoPor ns1:FuncionRTCP_STATIC ;
    ns1:textoExtracto "Pulsar [RESET]"@es .

ns1:FuncionRTCP_STATIC a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "RTCP STATIC"@es ;
    ns1:textoExtracto "función de RTCP STATIC"@es .

