@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error20112 a ns1:DiagnosticoFallo ;
    rdfs:label "Error al generar fichero xca desde pxca"@es ;
    ns1:identificador "20112" ;
    ns1:solucionaFallo ns1:ArchivoDefgraphErrLog ;
    ns1:textoExtracto "Ha habido errores al generar el fichero xca a partir del fichero pxca. Fichero .xca no generado."@es .

ns1:ErrorVersionXCA a ns1:DiagnosticoFallo ;
    rdfs:label "Incompatibilidad de versión en archivo xca"@es ;
    ns1:textoExtracto "CAUSA El archivo xca es v1.0 y debe ser v2.0. SOLUCIÓN Convertir el archivo a v2.0."@es .

ns1:ArchivoDefgraphErrLog a ns1:InterfazUsuario ;
    rdfs:label "Defgraph-err.log" ;
    ns1:textoExtracto "Revisar el archivo Defgraph-err.log para ver las causas del error."@es .

