@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_FACEAXIS a ns1:Parametro ;
    rdfs:label "FACEAXIS"@es ;
    ns1:identificador "FACEAXIS" ;
    ns1:monitoreaParametro ns1:Herramienta_CNC ;
    ns1:textoExtracto "primer eje definido como FACEAXIS"@es .

ns1:Parametro_LONGAXIS a ns1:Parametro ;
    rdfs:label "LONGAXIS"@es ;
    ns1:identificador "LONGAXIS" ;
    ns1:monitoreaParametro ns1:Herramienta_CNC ;
    ns1:textoExtracto "primer eje definido como LONGAXIS"@es .

ns1:Tabla_26_IconosOrientacionHerramienta a ns1:Tabla ;
    rdfs:label "Tabla de iconos de orientación de herramienta (págs. 38-42)"@es ;
    ns1:ilustradoEn ns1:Pagina_38_42 ;
    ns1:textoExtracto """
| Icono. | Significado. |
| --- | --- |
|  | El CNC orienta la herramienta según el primer eje definido como FACEAXIS. |
|  | El CNC orienta la herramienta según el primer eje definido como LONGAXIS. |
"""@es .

ns1:Herramienta_CNC a ns1:Herramienta ;
    rdfs:label "Herramienta controlada por CNC"@es ;
    ns1:documentadoEn ns1:Tabla_26_IconosOrientacionHerramienta ;
    ns1:textoExtracto "El CNC orienta la herramienta según el primer eje definido como FACEAXIS... El CNC orienta la herramienta según el primer eje definido como LONGAXIS."@es .

