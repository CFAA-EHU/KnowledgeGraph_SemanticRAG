@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error23008 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: error al cargar los datos, puntos de la volumetría"@es ;
    ns1:identificador "23008" ;
    ns1:monitoreaParametro ns1:ParametroCompensacionVolumetrica ;
    ns1:textoExtracto "Error en el fichero de compensación volumétrica: error al cargar los datos, puntos de la volumetría. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Los puntos del archivo de la compensación volumétrica no son correctos. SOLUCIÓN Modificar los puntos del archivo de la compensación volumétrica."@es .

ns1:Error23009 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: los parámetros de \"SQUARENESS\" no tienen puntos contiguos"@es ;
    ns1:identificador "23009" ;
    ns1:monitoreaParametro ns1:ParametroSquareness ;
    ns1:textoExtracto "Error en el fichero de compensación volumétrica: los parámetros de \"SQUARENESS\" no tienen puntos contiguos. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Los puntos del archivo de la compensación volumétrica no son correctos. SOLUCIÓN Modificar los puntos del archivo de la compensación volumétrica."@es .

ns1:Error23010 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: la coordenada está fuera del límite inferior del volumen de compensación"@es ;
    ns1:identificador "23010" ;
    ns1:monitoreaParametro ns1:ParametroCoordenadaVolumen ;
    ns1:textoExtracto "Error en el fichero de compensación volumétrica: la coordenada está fuera del límite inferior del volumen de compensación. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA La coordenada está fuera del límite inferior del volumen de compensación. SOLUCIÓN Modificar las coordenadas para que estén dentro del volumen de compensación."@es .

ns1:Error23011 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: la coordenada está fuera del límite superior del volumen de compensación"@es ;
    ns1:identificador "23011" ;
    ns1:monitoreaParametro ns1:ParametroCoordenadaVolumen ;
    ns1:textoExtracto "Error en el fichero de compensación volumétrica: la coordenada está fuera del límite superior del volumen de compensación. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA La coordenada está fuera del límite superior del volumen de compensación. SOLUCIÓN Modificar las coordenadas para que estén dentro del volumen de compensación."@es .

ns1:Error23012 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: el valor mínimo es mayor que el máximo"@es ;
    ns1:identificador "23012" ;
    ns1:monitoreaParametro ns1:ParametroRangoVolumetrico ;
    ns1:textoExtracto "Error en el fichero de compensación volumétrica: el valor mínimo es mayor que el máximo. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El valor mínimo definido en el archivo de la compensación es mayor que el máximo. SOLUCIÓN Modificar el valor mínimo o máximo del archivo de compensación."@es .

ns1:SistemaValidacionParametros a ns1:Sistema ;
    rdfs:label "Sistema de validación de parámetros máquina"@es ;
    ns1:textoExtracto "Arranque del sistema o validación de los parámetros máquina."@es .

ns1:ParametroCompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Parámetro de compensación volumétrica"@es ;
    ns1:textoExtracto "Variable o elemento del archivo de compensación volumétrica fuera de rango."@es .

ns1:ParametroRangoVolumetrico a ns1:Parametro ;
    rdfs:label "Parámetro de rango volumétrico"@es ;
    ns1:textoExtracto "Valor mínimo y máximo del archivo de compensación volumétrica."@es .

ns1:ParametroSquareness a ns1:Parametro ;
    rdfs:label "Parámetro SQUARENESS"@es ;
    ns1:textoExtracto "Parámetros de \"SQUARENESS\" en el archivo de compensación volumétrica."@es .

ns1:ParametroCoordenadaVolumen a ns1:Parametro ;
    rdfs:label "Parámetro de coordenada del volumen de compensación"@es ;
    ns1:textoExtracto "Coordenada del volumen de compensación."@es .

