@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error23014 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: la coordenada está fuera de los bordes de interpolación" ;
    ns1:identificador "23014" ;
    ns1:textoExtracto "23014 Error en el fichero de compensación volumétrica: la coordenada está fuera de los bordes de interpolación. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA La coordenada está fuera de los bordes de interpolación. SOLUCIÓN Modificar las coordenadas o el archivo de la compensación volumétrica." .

ns1:Error23015 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el análisis del fichero de definición de la compensación volumétrica" ;
    ns1:identificador "23015" ;
    ns1:textoExtracto "23015 Error en el análisis del fichero de definición de la compensación volumétrica. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El archivo de la compensación volumétrica no contiene los datos adecuados. SOLUCIÓN Modificar el archivo de la compensación volumétrica." .

ns1:Error23016 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: no se permite el sistema de coordenadas máquina \"MACHINE\"" ;
    ns1:identificador "23016" ;
    ns1:textoExtracto "23016 Error en el fichero de compensación volumétrica: no se permite el sistema de coordenadas máquina \"MACHINE\". DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA No se permite el sistema de coordenadas \"MACHINE\". SOLUCIÓN Modificar el archivo de la compensación volumétrica para que esté en el sistema de coordenadas KINEMATIC." .

ns1:Error23017 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: el sistema de coordenadas es incorrecto" ;
    ns1:identificador "23017" ;
    ns1:textoExtracto "23017 Error en el fichero de compensación volumétrica: el sistema de coordenadas es incorrecto. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA El sistema de coordenadas definido en el archivo es incorrecto. SOLUCIÓN Modificar el archivo de la compensación volumétrica." .

ns1:Maquina a ns1:Maquina ;
    rdfs:label "Máquina" ;
    ns1:textoExtracto "validación de los parámetros máquina" ;
    ns1:tieneComponente ns1:Sistema_CompensacionVolumetrica .

ns1:Parametro_ValorMaximoCompensacion a ns1:Parametro ;
    rdfs:label "Valor máximo de compensación volumétrica" ;
    ns1:monitoreaParametro ns1:Error23013 ;
    ns1:textoExtracto "El valor mínimo definido en el archivo de la compensación es mayor que el máximo." .

ns1:Parametro_ValorMinimoCompensacion a ns1:Parametro ;
    rdfs:label "Valor mínimo de compensación volumétrica" ;
    ns1:monitoreaParametro ns1:Error23013 ;
    ns1:textoExtracto "El valor mínimo definido en el archivo de la compensación es mayor que el máximo." .

ns1:Sistema_CompensacionVolumetrica a ns1:Sistema ;
    rdfs:label "Sistema de compensación volumétrica" ;
    ns1:textoExtracto "arranque del sistema o validación de los parámetros máquina" ;
    ns1:tieneComponente ns1:Parametro_ValorMaximoCompensacion,
        ns1:Parametro_ValorMinimoCompensacion .

ns1:Error23013 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica: los puntos del fichero están en orden inverso" ;
    ns1:identificador "23013" ;
    ns1:textoExtracto "23013 Error en el fichero de compensación volumétrica: los puntos del fichero están en orden inverso. DETECCIÓN Durante el arranque del sistema o validación de los parámetros máquina. CAUSA Los puntos del archivo están en orden inverso. SOLUCIÓN Modificar los puntos del archivo de la compensación volumétrica." .

