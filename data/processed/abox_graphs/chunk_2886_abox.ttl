@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjeSegundo a ns1:Componente ;
    rdfs:label "segundo eje" ;
    ns1:textoExtracto "la coordenada del segundo eje está fuera del límite inferior del volumen" .

ns1:Error23023Volumetrica a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica" ;
    ns1:solucionaFallo ns1:CompensacionVolumetrica ;
    ns1:textoExtracto "23023 Error en el fichero de compensación volumétrica: la coordenada del segundo eje está fuera del límite inferior del volumen." .

ns1:SistemaArranque a ns1:ModoOperacion ;
    rdfs:label "arranque del sistema" ;
    ns1:textoExtracto "Durante el arranque del sistema o validación de los parámetros máquina." .

ns1:ValidacionParametros a ns1:TareaMantenimiento ;
    rdfs:label "validación de los parámetros máquina" ;
    ns1:textoExtracto "validación de los parámetros máquina" .

ns1:CompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "compensación volumétrica" ;
    ns1:textoExtracto "archivo de la compensación volumétrica" .

