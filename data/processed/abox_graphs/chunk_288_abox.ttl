@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActualizacionSoftware_1_4_1 a ns1:TareaMantenimiento ;
    rdfs:label "Actualización del software desde versiones anteriores"@es ;
    ns1:ejecutadoPor ns1:Personal_TecnicoCNC ;
    ns1:requiereMantenimiento ns1:ArchivosXCA_V2 ;
    ns1:textoExtracto "El CNC dispone de una nueva versión de gráficos HD, que incorporan el nuevo FCAS (control de colisiones) y que utilizan la versión 2 de archivos xca. Por lo tanto, al actualizar la versión del CNC, es necesario instalar/actualizar los archivos xca que definen la configuración de la máquina."@es .

ns1:ArchivosXCA_V2 a ns1:Componente ;
    rdfs:label "Archivos XCA versión 2"@es ;
    ns1:controla ns1:SistemaFCAS ;
    ns1:identificador "versión 2" ;
    ns1:textoExtracto "archivos xca que definen la configuración de la máquina [...] utilizan la versión 2 de archivos xca"@es .

ns1:Personal_TecnicoCNC a ns1:Personal ;
    rdfs:label "Técnico de CNC"@es ;
    ns1:textoExtracto "En una instalación completa (opción 3 del instalador), el setup instala los nuevos archivos xca. En una actualización de la versión (opciones 1 o 2 del instalador), hay que copiar manualmente los nuevos archivos xca."@es .

ns1:SistemaFCAS a ns1:Sistema ;
    rdfs:label "FCAS (control de colisiones)"@es ;
    ns1:identificador "FCAS" ;
    ns1:textoExtracto "nueva versión de gráficos HD, que incorporan el nuevo FCAS (control de colisiones)"@es .

