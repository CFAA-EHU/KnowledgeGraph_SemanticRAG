@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error23034 a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el fichero de compensación volumétrica"@es ;
    ns1:identificador "23034" ;
    ns1:solucionaFallo ns1:SolucionModificacionArchivoCompensacion ;
    ns1:textoExtracto "Error en el fichero de compensación volumétrica: el valor del parámetro del fichero \"AXIS_BEGIN\" es incorrecto."@es .

ns1:ParametroAXIS_BEGIN a ns1:Parametro ;
    rdfs:label "AXIS_BEGIN" ;
    ns1:monitoreaParametro ns1:SistemaMaquina ;
    ns1:textoExtracto "El valor del parámetro del fichero \"AXIS_BEGIN\" es incorrecto."@es .

ns1:SistemaMaquina a ns1:Sistema ;
    rdfs:label "Sistema de compensación volumétrica"@es ;
    ns1:textoExtracto "Durante el arranque del sistema o validación de los parámetros máquina."@es ;
    ns1:tieneComponente ns1:ParametroAXIS_BEGIN .

ns1:SolucionModificacionArchivoCompensacion a ns1:TareaMantenimiento ;
    rdfs:label "Modificar el archivo de la compensación volumétrica"@es ;
    ns1:textoExtracto "Modificar el archivo de la compensación volumétrica."@es .

