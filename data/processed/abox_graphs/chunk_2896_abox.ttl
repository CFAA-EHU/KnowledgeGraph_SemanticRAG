@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_23104 a ns1:AvisoSeguridad ;
    rdfs:label "Error 23104: Conflicto de compensación volumétrica" ;
    ns1:identificador "23104" ;
    ns1:textoExtracto "'No se puede activar la marca VOLCOMP con otra tabla activa sobre ejes comunes'" .

ns1:Error_23151 a ns1:AvisoSeguridad ;
    rdfs:label "Error 23151: Tabla de parámetros inexistente" ;
    ns1:identificador "23151" ;
    ns1:textoExtracto "Número de tabla inexistente. [...] El nombre o número de tabla de parámetros máquina (feedback, motor, tandem, etc) indicado en la variable no existe." .

ns1:Error_23152 a ns1:AvisoSeguridad ;
    rdfs:label "Error 23152: Nombre de tabla demasiado largo" ;
    ns1:identificador "23152" ;
    ns1:textoExtracto "Nombre de tabla demasiado largo." .

ns1:SistemaCompensacionVolumetrica a ns1:Sistema ;
    rdfs:label "Sistema de compensación volumétrica" ;
    ns1:documentadoEn ns1:TablaParametrosMaquina ;
    ns1:textoExtracto "No puede haber activas dos compensaciones volumétricas que tengan algún eje en común." ;
    ns1:tieneComponente ns1:Parametro_VOLCOMP .

ns1:Parametro_VOLCOMP a ns1:Parametro ;
    rdfs:label "Parámetro VOLCOMP (compensación volumétrica)" ;
    ns1:identificador "VOLCOMP" ;
    ns1:textoExtracto "Definir una compensación volumétrica adecuada en los parámetros máquina (parámetros VOLCOMP)." .

ns1:TablaParametrosMaquina a ns1:Tabla ;
    rdfs:label "Tabla de parámetros máquina (feedback, motor, tandem, etc.)" ;
    ns1:textoExtracto "El nombre o número de tabla de parámetros máquina (feedback, motor, tandem, etc) indicado en la variable no existe." .

