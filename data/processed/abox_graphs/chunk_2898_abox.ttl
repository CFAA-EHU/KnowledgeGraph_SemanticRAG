@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error23153 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 23153: Fichero de compensación volumétrica no válido" ;
    ns1:identificador "23153" ;
    ns1:monitoreaParametro ns1:Parametro_VCOMPFILE ;
    ns1:textoExtracto "El fichero de compensación volumétrica no es válido. DETECCIÓN Durante el arranque del CNC o la validación de los parámetros máquina. CAUSA El archivo de la compensación volumétrica (parámetro VCOMPFILE) está vacío o no tiene el formato adecuado. SOLUCIÓN Añadir un fichero válido." .

ns1:Error23154 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 23154: Error en análisis de fichero de compensación volumétrica" ;
    ns1:identificador "23154" ;
    ns1:textoExtracto "Error en el análisis del fichero de definición de la compensación volumétrica. DETECCIÓN Durante el arranque del CNC o la validación de los parámetros máquina. CAUSA Error en el análisis del fichero de definición de la compensación volumétrica. SOLUCIÓN Añadir un fichero válido." .

ns1:ErrorNombreTablaInvalido a ns1:DiagnosticoFallo ;
    rdfs:label "Error: Nombre de tabla de parámetros máquina inválido" ;
    ns1:monitoreaParametro ns1:TablaParametrosMaquina ;
    ns1:textoExtracto "CAUSA El nombre de la tabla de parámetros máquina (feedback, motor, tandem, etc) indicado en la variable no existe, o es demasiado largo. SOLUCIÓN El nombre indicado en la variable debe ser una tabla válida." .

ns1:Parametro_VCOMPFILE a ns1:Parametro ;
    rdfs:label "Parámetro VCOMPFILE (fichero de compensación volumétrica)" ;
    ns1:identificador "VCOMPFILE" ;
    ns1:textoExtracto "parámetro VCOMPFILE" .

ns1:TablaParametrosMaquina a ns1:Tabla ;
    rdfs:label "Tabla de parámetros máquina (feedback, motor, tandem, etc.)" ;
    ns1:textoExtracto "El nombre de la tabla de parámetros máquina (feedback, motor, tandem, etc) indicado en la variable no existe, o es demasiado largo." .

