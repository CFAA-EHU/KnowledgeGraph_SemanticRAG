@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_24001 a ns1:DiagnosticoFallo ;
    rdfs:label "EtherCAT: Datalink no presente" ;
    ns1:identificador "24001" ;
    ns1:solucionaFallo ns1:CableEtherCAT ;
    ns1:textoExtracto "EtherCAT: Datalink no presente. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA El cable EtherCAT está desconectado. SOLUCIÓN Conectar el cable de EtherCAT." .

ns1:Fallo_24002 a ns1:DiagnosticoFallo ;
    rdfs:label "EtherCAT: Paquete perdido" ;
    ns1:identificador "24002" ;
    ns1:solucionaFallo ns1:CableEtherCAT,
        ns1:EsclavoEtherCAT ;
    ns1:textoExtracto "EtherCAT: Paquete perdido. DETECCIÓN Durante el funcionamiento del CNC. CAUSA El cable EtherCAT está desconectado o algún esclavo no funciona correctamente. SOLUCIÓN Revisar el conexionado y el estado de los esclavos." .

ns1:Fallo_24003 a ns1:DiagnosticoFallo ;
    rdfs:label "EtherCAT: CRC Incorrecto" ;
    ns1:identificador "24003" ;
    ns1:solucionaFallo ns1:CableEtherCAT,
        ns1:SistemaEtherCAT ;
    ns1:textoExtracto "EtherCAT: CRC Incorrecto. DETECCIÓN Durante el funcionamiento del CNC. CAUSA El cable EtherCAT está desconectado o hay interferencias en el bus. SOLUCIÓN Revisar el conexionado y el estado de los esclavos." .

ns1:Fallo_24004 a ns1:DiagnosticoFallo ;
    rdfs:label "EtherCAT: Working Counter error" ;
    ns1:identificador "24004" ;
    ns1:solucionaFallo ns1:EsclavoEtherCAT ;
    ns1:textoExtracto "EtherCAT: Working Counter error. DETECCIÓN Durante el funcionamiento del CNC. CAUSA Funcionamiento incorrecto de alguno de los esclavos de EtherCAT. SOLUCIÓN Revisar el conexionado y el estado de los esclavos." .

ns1:Fallo_24010 a ns1:DiagnosticoFallo ;
    rdfs:label "EtherCAT: Fichero ENI de configuración no existe" ;
    ns1:identificador "24010" ;
    ns1:textoExtracto "EtherCAT: Fichero ENI de configuración no existe. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA No existe el fichero ENI de configuración de la red EtherCAT. SOLUCIÓN Copiar en Mtb/Data el fichero ENI de configuración de la red EtherCAT. El archivo se debe llamar fagor_ethercatConfFile.xml." .

ns1:Fallo_24011 a ns1:DiagnosticoFallo ;
    rdfs:label "EtherCAT: Formato de fichero ENI de configuración incorrecto" ;
    ns1:identificador "24011" ;
    ns1:textoExtracto "EtherCAT: Formato de fichero ENI de configuración incorrecto. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA El fichero ENI de configuración de la red EtherCAT tiene un formato ilegible para el CNC. El configurador que ha generado el fichero ENI puede no ser compatible con el CNC. El fichero puede estar incompleto o corrupto. SOLUCIÓN Revisar el fichero." .

ns1:Fallo_24020 a ns1:DiagnosticoFallo ;
    rdfs:label "EtherCAT: Fichero de rutado no existe" ;
    ns1:identificador "24020" ;
    ns1:textoExtracto "EtherCAT: Fichero de rutado no existe. DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA No existe el fichero para acceder a los recursos del bus EtherCAT desde el sistema CNC-PLC Fagor." .

ns1:SistemaEtherCAT a ns1:Sistema ;
    rdfs:label "Sistema EtherCAT" ;
    ns1:textoExtracto "bus EtherCAT" ;
    ns1:tieneComponente ns1:CableEtherCAT,
        ns1:EsclavoEtherCAT .

ns1:EsclavoEtherCAT a ns1:ComponenteElectrico ;
    rdfs:label "Esclavo EtherCAT" ;
    ns1:textoExtracto "esclavo de EtherCAT" .

ns1:CableEtherCAT a ns1:ComponenteElectrico ;
    rdfs:label "Cable EtherCAT" ;
    ns1:textoExtracto "cable EtherCAT" .

