@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActualizacionSoftware_V2 a ns1:Sistema ;
    rdfs:label "Actualización de software a VERSION_2"@es ;
    ns1:compuestoPor ns1:Conexion_SYS_Tool1_C1,
        ns1:Conexion_SYS_Tool1_C2,
        ns1:Conexion_SYS_Tool1_C3,
        ns1:Herramienta_SYS_Tool1_V2,
        ns1:Herramienta_SYS_Tool2_V2,
        ns1:Herramienta_SYS_Tool3_V2,
        ns1:Herramienta_SYS_Tool4_V2 ;
    ns1:identificador "VERSION_2" ;
    ns1:textoExtracto "Incluir: <GeometryObject name=\"VERSION_2\"> </GeometryObject>"@es .

ns1:Conexion_SYS_Tool1_C1 a ns1:ComponenteElectrico ;
    rdfs:label "Conexión SYS-Tool1 a C1 (rotación: 0 1 0 -90)"@es ;
    ns1:textoExtracto "Sustituir: <Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@S1\" rotation=\"0 1 0 -90\"/> Por: <Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@C1\" rotation=\"0 1 0 -90\"/>"@es ;
    ns1:valor "rotation: 0 1 0 -90" .

ns1:Conexion_SYS_Tool1_C2 a ns1:ComponenteElectrico ;
    rdfs:label "Conexión SYS-Tool1 a C2 (rotación: 0 1 0 -90)"@es ;
    ns1:textoExtracto "Sustituir: <Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@S2\" rotation=\"0 1 0 -90\"/> Por: <Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@C2\" rotation=\"0 1 0 -90\"/>"@es ;
    ns1:valor "rotation: 0 1 0 -90" .

ns1:Conexion_SYS_Tool1_C3 a ns1:ComponenteElectrico ;
    rdfs:label "Conexión SYS-Tool1 a C3 (rotación: 0 1 0 -90)"@es ;
    ns1:textoExtracto "Sustituir: <Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@S3\" rotation=\"0 1 0 -90\"/> Por: <Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@C3\" rotation=\"0 1 0 -90\"/>"@es ;
    ns1:valor "rotation: 0 1 0 -90" .

ns1:Herramienta_SYS_Tool1_V2 a ns1:ComponenteMecanico ;
    rdfs:label "ToolVice SYS-Tool1 (Husillo S1)"@es ;
    ns1:identificador "SYS-Tool1" ;
    ns1:textoExtracto "Sustituir: <ReferenceObject name=\"SYS-Tool1\"/> Por: <ToolVice name=\"SYS-Tool1\" spindle=\"S1\"/>"@es .

ns1:Herramienta_SYS_Tool2_V2 a ns1:ComponenteMecanico ;
    rdfs:label "ToolVice SYS-Tool2 (Husillo S2)"@es ;
    ns1:identificador "SYS-Tool2" ;
    ns1:textoExtracto "Sustituir: <ReferenceObject name=\"SYS-Tool2\"/> Por: <ToolVice name=\"SYS-Tool2\" spindle=\"S2\"/>"@es .

ns1:Herramienta_SYS_Tool3_V2 a ns1:ComponenteMecanico ;
    rdfs:label "ToolVice SYS-Tool3 (Husillo S3)"@es ;
    ns1:identificador "SYS-Tool3" ;
    ns1:textoExtracto "Sustituir: <ReferenceObject name=\"SYS-Tool3\"/> Por: <ToolVice name=\"SYS-Tool3\" spindle=\"S3\"/>"@es .

ns1:Herramienta_SYS_Tool4_V2 a ns1:ComponenteMecanico ;
    rdfs:label "ToolVice SYS-Tool4 (Husillo S4)"@es ;
    ns1:identificador "SYS-Tool4" ;
    ns1:textoExtracto "Sustituir: <ReferenceObject name=\"SYS-Tool4\"/> Por: <ToolVice name=\"SYS-Tool4\" spindle=\"S4\"/>"@es .

