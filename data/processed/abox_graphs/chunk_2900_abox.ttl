@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Fallo_24020_EtherCAT_FicheroRutado a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo 24020: Fichero de rutado EtherCAT no existe"@es ;
    ns1:identificador "24020" ;
    ns1:solucionaFallo ns1:Solucion_GenerarFicheroResourceRouterConf ;
    ns1:textoExtracto "EtherCAT: Fichero de rutado no existe. [...] No existe el fichero para acceder a los recursos del bus EtherCAT desde el sistema CNC-PLC Fagor."@es .

ns1:Sistema_CNC_PLC_Fagor a ns1:Sistema ;
    rdfs:label "Sistema CNC-PLC Fagor"@es ;
    ns1:textoExtracto "sistema CNC-PLC Fagor"@es ;
    ns1:tieneComponente ns1:Bus_EtherCAT_Fagor .

ns1:Bus_EtherCAT_Fagor a ns1:ComponenteElectrico ;
    rdfs:label "Bus EtherCAT"@es ;
    ns1:textoExtracto "recursos del bus EtherCAT"@es .

ns1:Fichero_ResourceRouterConf a ns1:Consumible ;
    rdfs:label "resourceRouterConf.xml" ;
    ns1:identificador "resourceRouterConf.xml" ;
    ns1:textoExtracto "El archivo se debe llamar resourceRouterConf.xml."@es .

ns1:Solucion_GenerarFicheroResourceRouterConf a ns1:TareaMantenimiento ;
    rdfs:label "Generar fichero resourceRouterConf.xml con Fagor EtherCAT Mapper"@es ;
    ns1:requiereConsumible ns1:Fichero_ResourceRouterConf ;
    ns1:textoExtracto "Generar un fichero de rutado (mapeo) con la aplicación Fagor EtherCAT Mapper y copiarlo en Mtb/Data. El archivo se debe llamar resourceRouterConf.xml."@es .

