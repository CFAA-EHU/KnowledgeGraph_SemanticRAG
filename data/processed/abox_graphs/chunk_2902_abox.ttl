@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation" ;
    ns1:solucionaFallo ns1:Error_24255,
        ns1:Error_IncompatibilidadSoftware ;
    ns1:textoExtracto "Póngase en contacto con Fagor Automation." .

ns1:Error_24023 a ns1:AvisoSeguridad ;
    rdfs:label "EtherCAT: Nodos EtherCAT no Fagor. Opción de software no permitida" ;
    ns1:identificador "24023" ;
    ns1:textoExtracto "EtherCAT: Nodos EtherCAT no Fagor. Opción de software no permitida. DETECCIÓN Durante el arranque del CNC o tras un reset. CAUSA La inicialización de EtherCAT ha detectado algún nodo no Fagor y no está activa la opción de software para conectar nodos de terceros. SOLUCIÓN Quitar los nodos no Fagor del bus EtherCAT o contratar la opción de software para nodos de terceros." .

ns1:ModoDiagnosis a ns1:ModoOperacion ;
    rdfs:label "Modo diagnosis" ;
    ns1:solucionaFallo ns1:Error_24499 ;
    ns1:textoExtracto "Consultar el modo diagnosis para obtener más información." .

ns1:Error_24255 a ns1:AvisoSeguridad ;
    rdfs:label "EtherCAT: Error desconocido" ;
    ns1:identificador "24255" ;
    ns1:textoExtracto "EtherCAT: Error desconocido. DETECCIÓN Durante el funcionamiento del CNC. CAUSA Error de causa desconocida en el bus EtherCAT. SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:Error_24499 a ns1:AvisoSeguridad ;
    rdfs:label "EtherCAT: Error en nodo" ;
    ns1:identificador "24499" ;
    ns1:textoExtracto "EtherCAT: Error en nodo. Más información en diagnosis. DETECCIÓN Durante el funcionamiento del CNC. CAUSA Error en un nodo. SOLUCIÓN Consultar el modo diagnosis para obtener más información." .

ns1:Error_IncompatibilidadSoftware a ns1:AvisoSeguridad ;
    rdfs:label "Incompatibilidad entre Fagor EtherCAT Mapping y versión del CNC" ;
    ns1:textoExtracto "La versión de la aplicación Fagor EtherCAT Mapping es incompatible con la versión del CNC. • La versión no soporta uno de los recursos mapeados. SOLUCIÓN Póngase en contacto con Fagor Automation." .

