@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_Diagnostico a ns1:InterfazUsuario ;
    rdfs:label "Pantalla de diagnosis" ;
    ns1:monitoreaParametro ns1:DiagnosticoFallo_24501,
        ns1:DiagnosticoFallo_24502,
        ns1:DiagnosticoFallo_24503,
        ns1:DiagnosticoFallo_24504,
        ns1:DiagnosticoFallo_24505,
        ns1:DiagnosticoFallo_24506,
        ns1:DiagnosticoFallo_24507 ;
    ns1:textoExtracto "DETECCIÓN En la pantalla de diagnosis, durante la ejecución." .

ns1:DiagnosticoFallo_24501 a ns1:DiagnosticoFallo ;
    rdfs:label "Tensión de alimentación UM defectuosa" ;
    ns1:identificador "24501" ;
    ns1:textoExtracto "Tensión de alimentación UM defectuosa. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:DiagnosticoFallo_24502 a ns1:DiagnosticoFallo ;
    rdfs:label "Tensión de alimentación UM OK" ;
    ns1:identificador "24502" ;
    ns1:textoExtracto "Tensión de alimentación UM OK. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Condición de fallo corregida. SOLUCIÓN No requiere ninguna acción." .

