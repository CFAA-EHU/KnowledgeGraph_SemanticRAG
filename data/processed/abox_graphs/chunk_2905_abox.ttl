@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazDiagnostico a ns1:InterfazUsuario ;
    rdfs:label "Pantalla de diagnosis"@es ;
    ns1:monitoreaParametro ns1:Error_24508,
        ns1:Error_24509,
        ns1:Error_24510,
        ns1:Error_24511,
        ns1:Error_24512 ;
    ns1:textoExtracto "DETECCIÓN En la pantalla de diagnosis, durante la ejecución."@es .

ns1:SistemaEtherCAT a ns1:Sistema ;
    rdfs:label "Sistema EtherCAT"@es ;
    ns1:activaAlarma ns1:Error_24508,
        ns1:Error_24509,
        ns1:Error_24510,
        ns1:Error_24511,
        ns1:Error_24512 ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_24508 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo genérico de bus local"@es ;
    ns1:identificador "24508" ;
    ns1:textoExtracto "24508 Fallo genérico de bus local. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_24509 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha encontrado ningún módulo"@es ;
    ns1:identificador "24509" ;
    ns1:textoExtracto "24509 No se ha encontrado ningún módulo. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_24510 a ns1:DiagnosticoFallo ;
    rdfs:label "Módulo incorrecto encontrado en la posición %u"@es ;
    ns1:identificador "24510" ;
    ns1:textoExtracto "24510 Módulo incorrecto encontrado en la posición %u. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_24511 a ns1:DiagnosticoFallo ;
    rdfs:label "Más dispositivos de los esperados"@es ;
    ns1:identificador "24511" ;
    ns1:textoExtracto "24511 Más dispositivos de los esperados. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_24512 a ns1:DiagnosticoFallo ;
    rdfs:label "Aplicación en el módulo %u no listo"@es ;
    ns1:identificador "24512" ;
    ns1:textoExtracto "24512 Aplicación en el módulo %u no listo. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

