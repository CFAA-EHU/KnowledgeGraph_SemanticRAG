@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagnosticoFallo_24518 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de bus en dispositivo EtherCAT" ;
    ns1:documentadoEn ns1:InterfazDiagnostico_EtherCAT ;
    ns1:identificador "24518" ;
    ns1:solucionaFallo ns1:ManualEspecifico_NodoEtherCAT ;
    ns1:textoExtracto "24518 Error de bus en el dispositivo %u. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

