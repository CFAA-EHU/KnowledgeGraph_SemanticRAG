ns1:InterfazDiagnostico_EtherCAT a ns1:InterfazUsuario ;
    rdfs:label "Pantalla de diagnosis EtherCAT" ;
    ns1:textoExtracto "En la pantalla de diagnosis, durante la ejecución." .

ns1:ManualEspecifico_NodoEtherCAT a ns1:Manual ;
    rdfs:label "Manual específico del nodo EtherCAT" ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

