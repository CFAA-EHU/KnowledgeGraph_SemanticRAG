@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_ErrorEmergenciaNodo a ns1:AvisoSeguridad ;
    rdfs:label "Error de emergencia en nodo EtherCAT" ;
    ns1:documentadoEn ns1:InterfazUsuario_DiagnosisEtherCAT ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:AvisoSeguridad_ErrorFirmware a ns1:AvisoSeguridad ;
    rdfs:label "Error de firmware en nodo EtherCAT (código 24551)" ;
    ns1:documentadoEn ns1:InterfazUsuario_DiagnosisEtherCAT ;
    ns1:identificador "24551" ;
    ns1:textoExtracto "Se ha producido un error de firmware. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:AvisoSeguridad_FalloBusCorregido a ns1:AvisoSeguridad ;
    rdfs:label "Fallo de bus corregido (código 24550)" ;
    ns1:documentadoEn ns1:InterfazUsuario_DiagnosisEtherCAT ;
    ns1:identificador "24550" ;
    ns1:textoExtracto "El fallo de bus se ha quitado. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Condición de fallo corregida. SOLUCIÓN No requiere ninguna acción." .

ns1:AvisoSeguridad_ModulosCero a ns1:AvisoSeguridad ;
    rdfs:label "Número de módulos cero (código 24553)" ;
    ns1:documentadoEn ns1:InterfazUsuario_DiagnosisEtherCAT ;
    ns1:identificador "24553" ;
    ns1:textoExtracto "El número de módulos es cero. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:AvisoSeguridad_ModulosExcedidos a ns1:AvisoSeguridad ;
    rdfs:label "Número máximo de módulos excedidos (código 24552)" ;
    ns1:documentadoEn ns1:InterfazUsuario_DiagnosisEtherCAT ;
    ns1:identificador "24552" ;
    ns1:textoExtracto "Número máximo de módulos excedidos. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:AvisoSeguridad_PuntosESSuperados a ns1:AvisoSeguridad ;
    rdfs:label "Número máximo de puntos de E/S superados (código 24554)" ;
    ns1:documentadoEn ns1:InterfazUsuario_DiagnosisEtherCAT ;
    ns1:identificador "24554" ;
    ns1:textoExtracto "Número máximo de puntos de E/S superados. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:Manual_EspecificoNodo a ns1:Manual ;
    rdfs:label "Manual específico del nodo EtherCAT" ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:InterfazUsuario_DiagnosisEtherCAT a ns1:InterfazUsuario ;
    rdfs:label "Pantalla de diagnosis EtherCAT" ;
    ns1:textoExtracto "En la pantalla de diagnosis, durante la ejecución." .

