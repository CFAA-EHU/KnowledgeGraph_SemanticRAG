@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Version_V6_01_03 a ns1:Parametro ;
    ns1:identificador "V6.01.03" ;
    ns1:textoExtracto "Versión V6.01.03. Archivos xca y parámetros FACEAXIS y LONGAXIS." .

ns1:Version_V6_20 a ns1:Parametro ;
    ns1:identificador "V6.20" ;
    ns1:textoExtracto "A partir de la versión v6.20, el CNC siempre considera la cota de aproximación en coordenadas absolutas" .

ns1:Version_V6_20_2 a ns1:Parametro ;
    ns1:identificador "V6.20" ;
    ns1:textoExtracto "A partir de la versión v6.20, el CNC siempre considera la cota programada en el comando \"POS\" en coordenadas absolutas" .

ns1:Version_V6_21_12 a ns1:Parametro ;
    ns1:identificador "V6.21.12" ;
    ns1:textoExtracto "Versión V6.21.12. Instalación del software." .

ns1:archivo_xca a ns1:Esquema ;
    ns1:textoExtracto "archivo *.def que acompaña al esquema modelizado de la máquina (archivo xca)" .

ns1:comando_INC a ns1:Parametro ;
    ns1:identificador "INC" ;
    ns1:textoExtracto "añadir el comando \"INC\" a la sentencia #GAPCTRL" .

ns1:comando_POS a ns1:Parametro ;
    ns1:identificador "POS" ;
    ns1:textoExtracto "el CNC siempre considera la cota programada en el comando \"POS\" en coordenadas absolutas" .

ns1:control_FCombo_ocx a ns1:ComponenteElectrico ;
    ns1:identificador "FCombo.ocx" ;
    ns1:textoExtracto "registre correctamente el nuevo control FCombo.ocx" .

ns1:parametro_FACEAXIS a ns1:Parametro ;
    ns1:identificador "FACEAXIS" ;
    ns1:textoExtracto "parámetros FACEAXIS y LONGAXIS" .

ns1:parametro_FIXORI a ns1:Parametro ;
    ns1:textoExtracto "el parámetro FIXORI define si la herramienta está orientada según los ejes definidos en FACEAXIS y LONGAXIS" .

ns1:parametro_LONGAXIS a ns1:Parametro ;
    ns1:identificador "LONGAXIS" ;
    ns1:textoExtracto "parámetros FACEAXIS y LONGAXIS" .

ns1:stdPlug_S1 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "plug=\"stdPlug@S1\"" .

ns1:stdPlug_SYSTool1 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "plug=\"stdPlug@SYS-Tool1\"" .

ns1:stdSocket_C3 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "socket=\"stdSocket@C3\"" .

ns1:stdSocket_C4 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "socket=\"stdSocket@C4\"" .

ns1:stdSocket_S3 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "socket=\"stdSocket@S3\"" .

ns1:stdSocket_S4 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "socket=\"stdSocket@S4\"" .

