@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PantallaDiagnosis a ns1:InterfazUsuario ;
    rdfs:label "Pantalla de diagnosis" ;
    ns1:monitoreaParametro ns1:Error24560,
        ns1:Error24561,
        ns1:Error24562,
        ns1:Error24563,
        ns1:Error24564 ;
    ns1:textoExtracto "DETECCIÓN En la pantalla de diagnosis, durante la ejecución." .

ns1:SolucionConsultaManualNodo a ns1:TareaMantenimiento ;
    rdfs:label "Consultar manual específico del nodo EtherCAT para diagnóstico" ;
    ns1:solucionaFallo ns1:Error24560,
        ns1:Error24561,
        ns1:Error24562,
        ns1:Error24563,
        ns1:Error24564 ;
    ns1:textoExtracto "SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)." .

ns1:Error24560 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 24560: Fallo de hardware/firmware en nodo EtherCAT" ;
    ns1:identificador "24560" ;
    ns1:textoExtracto "24560 Se produjo un error de hardware o firmware. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:Error24561 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 24561: Fallo de hardware/firmware en nodo EtherCAT" ;
    ns1:identificador "24561" ;
    ns1:textoExtracto "24561 Se produjo un error de hardware o firmware. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:Error24562 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 24562: Fallo de hardware/firmware en nodo EtherCAT" ;
    ns1:identificador "24562" ;
    ns1:textoExtracto "24562 Se produjo un error de hardware o firmware. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:Error24563 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 24563: Fallo de activación del bus local por error en nodo EtherCAT" ;
    ns1:identificador "24563" ;
    ns1:textoExtracto "24563 El bus local no se ha podido activar debido a fallos de funcionamiento. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:Error24564 a ns1:DiagnosticoFallo ;
    rdfs:label "Error 24564: Fallo de activación del bus local por error en nodo EtherCAT" ;
    ns1:identificador "24564" ;
    ns1:textoExtracto "24564 El bus local no se ha podido activar debido a fallos de funcionamiento. DETECCIÓN En la pantalla de diagnosis, durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

