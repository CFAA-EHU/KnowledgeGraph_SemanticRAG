@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_24600 a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo de bus corregido"@es ;
    ns1:identificador "24600" ;
    ns1:textoExtracto "El fallo de bus se ha quitado. DETECCIÓN Durante la ejecución. CAUSA Condición de fallo del bus corregida. SOLUCIÓN No requiere ninguna acción."@es .

ns1:Error_24602 a ns1:DiagnosticoFallo ;
    rdfs:label "Tensión de alimentación UM OK"@es ;
    ns1:identificador "24602" ;
    ns1:textoExtracto "Tensión de alimentación UM OK. DETECCIÓN Durante la ejecución. CAUSA Condición de fallo corregida. SOLUCIÓN No requiere ninguna acción."@es .

ns1:NodoEtherCAT a ns1:ComponenteElectrico ;
    rdfs:label "Nodo EtherCAT"@es ;
    ns1:activaAlarma ns1:Error_24595,
        ns1:Error_24596,
        ns1:Error_24597,
        ns1:Error_2459x_Canal,
        ns1:Error_24601 ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:Error_24595 a ns1:DiagnosticoFallo ;
    rdfs:label "Módulo %u: Canal de sobrecarga %u"@es ;
    ns1:identificador "24595" ;
    ns1:solucionaFallo ns1:ManualEspecificoNodo ;
    ns1:textoExtracto "Módulo %u: Canal de sobrecarga %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:Error_24596 a ns1:DiagnosticoFallo ;
    rdfs:label "Módulo %u: Canal Subterráneo %u"@es ;
    ns1:identificador "24596" ;
    ns1:solucionaFallo ns1:ManualEspecificoNodo ;
    ns1:textoExtracto "Módulo %u: Canal Subterráneo %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:Error_24597 a ns1:DiagnosticoFallo ;
    rdfs:label "Configuración incorrecta del módulo Localbus en módulo %u"@es ;
    ns1:identificador "24597" ;
    ns1:solucionaFallo ns1:ManualEspecificoNodo ;
    ns1:textoExtracto "La configuración del módulo Localbus no coincide en el módulo %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:Error_2459x_Canal a ns1:DiagnosticoFallo ;
    rdfs:label "Canal %u: Detección de emergencia en nodo EtherCAT"@es ;
    ns1:solucionaFallo ns1:ManualEspecificoNodo ;
    ns1:textoExtracto "Canal %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:Error_24601 a ns1:DiagnosticoFallo ;
    rdfs:label "Tensión de alimentación UM defectuosa"@es ;
    ns1:identificador "24601" ;
    ns1:solucionaFallo ns1:ManualEspecificoNodo ;
    ns1:textoExtracto "Tensión de alimentación UM defectuosa. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:ManualEspecificoNodo a ns1:Manual ;
    rdfs:label "Manual específico del nodo EtherCAT"@es ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

