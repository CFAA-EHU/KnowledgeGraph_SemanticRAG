@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC_Leapfrog a ns1:Sistema ;
    rdfs:label "CNC Leapfrog" ;
    ns1:identificador "v6.20" ;
    ns1:monitoreaParametro ns1:Parametro_CotaAproximacion,
        ns1:Parametro_CotaFinalSalto ;
    ns1:textoExtracto "Leapfrog. A partir de la versión v6.20, el CNC siempre considera la cota programada en el comando \"POS\" en coordenadas absolutas" .

ns1:Comando_INC a ns1:Parametro ;
    rdfs:label "Comando INC" ;
    ns1:identificador "INC" ;
    ns1:textoExtracto "añadir el comando \"INC\" a la sentencia #GAPCTRL" .

ns1:Comando_INCPOS a ns1:Parametro ;
    rdfs:label "Comando INCPOS" ;
    ns1:identificador "INCPOS" ;
    ns1:textoExtracto "utilizar el comando \"INCPOS\" para programar la cota al final del salto en coordenadas incrementales" .

ns1:Comando_POS a ns1:Parametro ;
    rdfs:label "Comando POS" ;
    ns1:identificador "POS" ;
    ns1:textoExtracto "el CNC siempre considera la cota programada en el comando \"POS\" en coordenadas absolutas" .

ns1:Sentencia_GAPCTRL a ns1:Parametro ;
    rdfs:label "Sentencia #GAPCTRL" ;
    ns1:identificador "#GAPCTRL" ;
    ns1:textoExtracto "añadir el comando \"INC\" a la sentencia #GAPCTRL" .

ns1:Parametro_CotaAproximacion a ns1:Parametro ;
    rdfs:label "Cota de aproximación" ;
    ns1:textoExtracto "Para programar la cota de aproximación en coordenadas incrementales, añadir el comando \"INC\" a la sentencia #GAPCTRL" .

ns1:Parametro_CotaFinalSalto a ns1:Parametro ;
    rdfs:label "Cota al final del salto" ;
    ns1:textoExtracto "Para programar la cota al final del salto en coordenadas incrementales, utilizar el comando \"INCPOS\"" .

