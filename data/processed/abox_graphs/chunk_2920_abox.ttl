@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaEtherCAT a ns1:Sistema ;
    rdfs:label "Sistema EtherCAT"@es ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es ;
    ns1:tieneComponente ns1:NodoEtherCAT .

ns1:Error_24609 a ns1:DiagnosticoFallo ;
    rdfs:label "No se ha encontrado ningún módulo"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24609" ;
    ns1:textoExtracto "24609 No se ha encontrado ningún módulo. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:Error_24610 a ns1:DiagnosticoFallo ;
    rdfs:label "Módulo incorrecto encontrado en la posición %u"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24610" ;
    ns1:textoExtracto "24610 Módulo incorrecto encontrado en la posición %u. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:Error_24611 a ns1:DiagnosticoFallo ;
    rdfs:label "Más dispositivos de los esperados"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24611" ;
    ns1:textoExtracto "24611 Más dispositivos de los esperados. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:Error_24612 a ns1:DiagnosticoFallo ;
    rdfs:label "Aplicación en el módulo %u no listo"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24612" ;
    ns1:textoExtracto "24612 Aplicación en el módulo %u no listo. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:Error_24613 a ns1:DiagnosticoFallo ;
    rdfs:label "Módulo %u dispositivo reset"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24613" ;
    ns1:textoExtracto "24613 Módulo %u dispositivo reset. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:Error_24614 a ns1:DiagnosticoFallo ;
    rdfs:label "Módulo %u timeout de comunicación"@es ;
    ns1:documentadoEn ns1:ManualEspecificoNodo ;
    ns1:identificador "24614" ;
    ns1:textoExtracto "24614 Módulo %u timeout de comunicación. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:NodoEtherCAT a ns1:ComponenteElectrico ;
    rdfs:label "Nodo EtherCAT"@es ;
    ns1:activaAlarma ns1:Error_24609,
        ns1:Error_24610,
        ns1:Error_24611,
        ns1:Error_24612,
        ns1:Error_24613,
        ns1:Error_24614 ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:ManualEspecificoNodo a ns1:Manual ;
    rdfs:label "Manual específico del nodo"@es ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

