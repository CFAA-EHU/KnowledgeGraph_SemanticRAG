@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_24658 a ns1:DiagnosticoFallo ;
    rdfs:label "Software exception" ;
    ns1:documentadoEn ns1:ManualNodoEtherCAT ;
    ns1:identificador "24658" ;
    ns1:textoExtracto "24658 Software exception, fichero: %s, linea: %d. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

ns1:Error_24659 a ns1:DiagnosticoFallo ;
    rdfs:label "Código de emergencia CoE" ;
    ns1:documentadoEn ns1:ManualNodoEtherCAT ;
    ns1:identificador "24659" ;
    ns1:textoExtracto "24659 Código de emergencia CoE: 0x%X, información adicional: 0x%X. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error." .

