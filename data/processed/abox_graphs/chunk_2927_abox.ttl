@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ManualEspecificoNodo a ns1:Manual ;
    rdfs:label "Manual específico del nodo"@es ;
    ns1:textoExtracto "Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error."@es .

ns1:NodoEtherCAT_Generico a ns1:ComponenteElectrico ;
    rdfs:label "Nodo EtherCAT"@es ;
    ns1:activaAlarma ns1:Error_24668 ;
    ns1:textoExtracto "Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error."@es .

ns1:NodoRIOR_E a ns1:ComponenteElectrico ;
    rdfs:label "Nodo RIOR-E"@es ;
    ns1:activaAlarma ns1:Error_24669 ;
    ns1:textoExtracto "Se ha detectado un nodo RIOR-E en BOOT mode."@es .

ns1:Error_24668 a ns1:DiagnosticoFallo ;
    rdfs:label "Identificador de placa analógica incorrecto"@es ;
    ns1:identificador "24668" ;
    ns1:textoExtracto "24668 Identificador de placa analógica incorrecto. DETECCIÓN Durante la ejecución. CAUSA Un nodo EtherCAT ha enviado una emergencia indicando esta condición de error. SOLUCIÓN Se recomienda consultar en el manual específico del nodo, la información de diagnosis o el valor adicional que acompaña al error (código hexadecimal de la emergencia)."@es .

ns1:Error_24669 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de firmware en RIOR-E, BOOT mode"@es ;
    ns1:identificador "24669" ;
    ns1:textoExtracto "24669 Error de firmware en RIOR-E, BOOT mode. DETECCIÓN Durante la ejecución. CAUSA Se ha detectado un nodo RIOR-E en BOOT mode. SOLUCIÓN Volver a cargar el firmware de aplicación."@es .

