ns1:Error_80001 a ns1:DiagnosticoFallo ;
    rdfs:label "Error interno #00: falta el texto del error E%D P0=%D"@es ;
    ns1:identificador "80001" ;
    ns1:solucionaFallo ns1:RevisarLaProgramacion ;
    ns1:textoExtracto "80001 Error interno #00: falta el texto del error E%D P0=%D. DETECCIÓN Durante la ejecución. CAUSA Error en la ejecución de la subrutina. SOLUCIÓN Revisar la programación."@es .

