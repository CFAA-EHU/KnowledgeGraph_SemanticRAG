@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoModoNoSeguro a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de modo no seguro" ;
    ns1:textoExtracto "aparecerá un aviso indicando que se está trabajando en un modo no seguro." .

ns1:AvisoPantallaArranque a ns1:AvisoSeguridad ;
    rdfs:label "Avisos en pantalla durante el arranque" ;
    ns1:textoExtracto "el CNC puede mostrar avisos en pantalla cuya causa debe ser solucionada por el fabricante durante la puesta a punto." .

ns1:TareaMantenimientoPuestaPunto a ns1:TareaMantenimiento ;
    rdfs:label "Puesta a punto del CNC" ;
    ns1:documentadoEn ns1:Pagina32_ModosTrabajo ;
    ns1:ejecutadoPor ns1:Fabricante ;
    ns1:requiereMantenimiento ns1:SistemaNoProtegidoEscritura,
        ns1:SistemaProtegidoEscritura ;
    ns1:textoExtracto "La puesta a punto del CNC se realiza desde el modo setup." .

ns1:DialogoCopiaSeguridad a ns1:InterfazUsuario ;
    rdfs:label "Diálogo de copia de seguridad" ;
    ns1:textoExtracto "el CNC muestra la opción de guardar una copia de seguridad de la configuración de la máquina, el directorio MTB, a un archivo comprimido." .

ns1:DialogoFinalizacionPuestaPunto a ns1:InterfazUsuario ;
    rdfs:label "Diálogo de finalización de puesta a punto" ;
    ns1:textoExtracto "el CNC muestra un segundo diálogo preguntando si se ha finalizado con la puesta a punto. Con la opción 'NO', la próxima vez que se encienda el equipo volverá a arrancar en el modo setup. Con la opción 'SÍ', el CNC hace una copia de seguridad de la carpeta MTB y la próxima vez que se encienda el equipo arrancará en modo usuario." .

ns1:Fabricante a ns1:Personal ;
    rdfs:label "Fabricante" ;
    ns1:textoExtracto "el CNC hace una copia de seguridad de la carpeta MTB y la próxima vez que se encienda el equipo arrancará en modo usuario. El equipo debe ser entregado al usuario preparado para arrancar en modo usuario." .

ns1:ModoSetup a ns1:ModoOperacion ;
    rdfs:label "Modo setup" ;
    ns1:textoExtracto "La puesta a punto del CNC se realiza desde el modo setup. Fagor entrega el equipo preparado para arrancar en este modo." .

ns1:ModoUsuario a ns1:ModoOperacion ;
    rdfs:label "Modo usuario" ;
    ns1:textoExtracto "El equipo debe ser entregado al usuario preparado para arrancar en modo usuario." .

ns1:Pagina32_ModosTrabajo a ns1:Pagina ;
    ns1:identificador "32" ;
    ns1:textoExtracto "Ver '1.1.1 Modos de trabajo y protección del software en el CNC.' en la página 32." .

ns1:SistemaNoProtegidoEscritura a ns1:Sistema ;
    rdfs:label "Sistema sin disco protegido contra escritura" ;
    ns1:ilustradoEn ns1:DialogoCopiaSeguridad ;
    ns1:textoExtracto "Sistema sin disco protegido contra escritura. Las modificaciones de la configuración en un CNC sin disco protegido contra escritura son permanentes." .

ns1:SistemaProtegidoEscritura a ns1:Sistema ;
    rdfs:label "Sistema con disco protegido contra escritura" ;
    ns1:ilustradoEn ns1:DialogoFinalizacionPuestaPunto ;
    ns1:textoExtracto "Sistema con disco protegido contra la escritura." ;
    ns1:tieneComponente ns1:ModoSetup,
        ns1:ModoUsuario .

