@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorG8585_AXISNAME a ns1:AvisoSeguridad ;
    rdfs:label "Error G8585: eje no existente" ;
    ns1:identificador "85862" ;
    ns1:solucionaFallo ns1:Variable_G84585CFG ;
    ns1:textoExtracto "G8585 configuración errónea: AXISNAME=%D no existe. DETECCIÓN Durante la ejecución. CAUSA La subrutina G8585 intenta utilizar un eje que no existe. SOLUCIÓN Revisar la subrutina G8585 y la asignación de datos a la variable V.S.G84585CFG." .

ns1:ErrorG8585_DyR a ns1:AvisoSeguridad ;
    rdfs:label "Error G8585 con programación simultánea D y R" ;
    ns1:identificador "85851" ;
    ns1:textoExtracto "G8585 no permitida con programación simultánea D y R, ni I y J. DETECCIÓN Durante la ejecución. CAUSA Se ha programado el radio y el diámetro exterior, o el radio y el diámetro interior. SOLUCIÓN Revisar la programación. Programar cada dimensión una sola vez, con el radio o el diámetro." .

ns1:ErrorG8585_FACEAXIS a ns1:AvisoSeguridad ;
    rdfs:label "Error G8585: parámetro MPA.FACEAXIS mal configurado" ;
    ns1:identificador "85861" ;
    ns1:solucionaFallo ns1:Parametro_FACEAXIS ;
    ns1:textoExtracto "G8585 configuración errónea: poner parámetro MPA.FACEAXIS.%D=No. DETECCIÓN Durante la ejecución. CAUSA El eje indicado está definido como frontal. SOLUCIÓN Definir el parámetro FACEAXIS del eje con valor \"No\"." .

ns1:ErrorG8585_G92 a ns1:AvisoSeguridad ;
    rdfs:label "Error G8585 con G92 activo" ;
    ns1:identificador "85850" ;
    ns1:solucionaFallo ns1:Parametro_LONGAXIS ;
    ns1:textoExtracto "G8585 no permitida con origen temporal G92 activo. DETECCIÓN Durante la ejecución. CAUSA Se ha programado la función G8585 y hay una preselección de cotas activa (G92). SOLUCIÓN Anular la preselecciona de cotas antes de ejecutar la función G8585." .

ns1:ErrorG8585_I_Mayor_D a ns1:AvisoSeguridad ;
    rdfs:label "Error G8585 con diámetro interno mayor que externo" ;
    ns1:identificador "85852" ;
    ns1:textoExtracto "G8585 con I>D, que es diámetro interno > diámetro externo. DETECCIÓN Durante la ejecución. CAUSA El diámetro interior es mayor que el exterior. SOLUCIÓN Programar el diámetro exterior mayor que el interior." .

ns1:ErrorG8585_LONGAXIS a ns1:AvisoSeguridad ;
    rdfs:label "Error G8585: parámetro MPA.LONGAXIS mal configurado" ;
    ns1:identificador "85860" ;
    ns1:solucionaFallo ns1:Parametro_LONGAXIS ;
    ns1:textoExtracto "G8585 configuración errónea: poner parámetro MPA.LONGAXIS.%D=No. DETECCIÓN Durante la ejecución. CAUSA El eje indicado está definido como longitudinal. SOLUCIÓN Definir el parámetro LONGAXIS del eje con valor \"No\"." .

ns1:ErrorG8585_VariableInvalida a ns1:AvisoSeguridad ;
    rdfs:label "Error G8585: valor incorrecto en V.S.G84585CFG" ;
    ns1:identificador "85863" ;
    ns1:solucionaFallo ns1:Variable_G84585CFG ;
    ns1:textoExtracto "G8585 configuración errónea: valor incorrecto de la variable V.S.G84585CFG=%D. DETECCIÓN Durante la ejecución. CAUSA El valor asignado a la variable no es válido." .

ns1:Parametro_FACEAXIS a ns1:Parametro ;
    rdfs:label "Parámetro MPA.FACEAXIS" ;
    ns1:identificador "MPA.FACEAXIS" ;
    ns1:textoExtracto "parámetro MPA.FACEAXIS.%D=No" ;
    ns1:valor "No" .

ns1:Parametro_LONGAXIS a ns1:Parametro ;
    rdfs:label "Parámetro MPA.LONGAXIS" ;
    ns1:identificador "MPA.LONGAXIS" ;
    ns1:textoExtracto "parámetro MPA.LONGAXIS.%D=No" ;
    ns1:valor "No" .

ns1:Variable_G84585CFG a ns1:Parametro ;
    rdfs:label "Variable V.S.G84585CFG" ;
    ns1:identificador "V.S.G84585CFG" ;
    ns1:textoExtracto "variable V.S.G84585CFG" .

