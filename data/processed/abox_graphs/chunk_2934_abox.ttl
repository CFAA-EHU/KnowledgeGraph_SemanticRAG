@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_85863 a ns1:AvisoSeguridad ;
    rdfs:label "Configuración errónea: valor incorrecto de V.S.G84585CFG"@es ;
    ns1:identificador "85863" ;
    ns1:solucionaFallo ns1:Diagnostico_85863 ;
    ns1:textoExtracto "85863 G8585 configuración errónea: valor incorrecto de la variable V.S.G84585CFG=%D. DETECCIÓN Durante la ejecución. CAUSA El valor asignado a la variable no es válido. SOLUCIÓN Revisar la asignación de datos a la variable en la subrutina G8585."@es .

ns1:Error_85870 a ns1:AvisoSeguridad ;
    rdfs:label "Error interno #90 en G8585 (cinemática)"@es ;
    ns1:identificador "85870" ;
    ns1:solucionaFallo ns1:Diagnostico_85870 ;
    ns1:textoExtracto "85870 Error interno #90 en G8585: KINID=%D, TYPE=%D. DETECCIÓN Durante la ejecución. CAUSA Error en la ejecución de la subrutina G8585, en la cinemática indicada. SOLUCIÓN Revisar la subrutina G8585."@es .

ns1:Diagnostico_85863 a ns1:DiagnosticoFallo ;
    rdfs:label "Revisión de asignación de datos en subrutina G8585"@es ;
    ns1:textoExtracto "Revisar la asignación de datos a la variable en la subrutina G8585."@es .

ns1:Diagnostico_85870 a ns1:DiagnosticoFallo ;
    rdfs:label "Revisión de subrutina G8585 (cinemática)"@es ;
    ns1:textoExtracto "Revisar la subrutina G8585."@es .

