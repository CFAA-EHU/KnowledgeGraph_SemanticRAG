@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Modulo_RCS_S a ns1:Sistema ;
    rdfs:label "Módulo RCS-S" ;
    ns1:textoExtracto "Revisar el conexionado. Revisar el nivel de las señales proporcionadas por el captador."@es ;
    ns1:tieneComponente ns1:Cable_SenalAL_E21A,
        ns1:Cable_SenalAL_E21B,
        ns1:Cable_SenalAL_E21C,
        ns1:Cable_SenalAL_E21D,
        ns1:Cable_SenalB_E21A,
        ns1:Cable_SenalB_E21B,
        ns1:Cable_SenalB_E21C,
        ns1:Cable_SenalB_E21D,
        ns1:Cable_SenalI0_E21A,
        ns1:Cable_SenalI0_E21B,
        ns1:Cable_SenalI0_E21C,
        ns1:Cable_SenalI0_E21D,
        ns1:Captador_E21A,
        ns1:Captador_E21B,
        ns1:Captador_E21C,
        ns1:Captador_E21D .

ns1:Alarma_E137_E21A a ns1:Alarma ;
    rdfs:label "Alarma E137 (Captador E21A)" ;
    ns1:identificador "E137" ;
    ns1:textoExtracto "E137 Recibida señal de alarma en captación E21A. El encoder ha generado una señal de alarma por un mal funcionamiento del mismo."@es .

ns1:Alarma_E237_E21B a ns1:Alarma ;
    rdfs:label "Alarma E237 (Captador E21B)" ;
    ns1:identificador "E237" ;
    ns1:textoExtracto "E237 Recibida señal de alarma en captación E21B."@es .

