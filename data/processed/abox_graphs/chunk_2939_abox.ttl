@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:alarma_E140 a ns1:Alarma ;
    rdfs:label "Alarma E140: Frecuencia de contaje excesiva en E21A" ;
    ns1:identificador "E140" ;
    ns1:mitigaRiesgo ns1:captador_Sercos_E21A ;
    ns1:textoExtracto "Frecuencia de contaje excesiva en captación E21A. La velocidad del movimiento del eje excede la capacidad de muestreo del hardware de la contadora Sercos para ese tipo de señal del encoder." .

ns1:alarma_E141 a ns1:Alarma ;
    rdfs:label "Alarma E141: Distancia incorrecta entre I0 en E21A" ;
    ns1:identificador "E141" ;
    ns1:mitigaRiesgo ns1:captador_Sercos_E21A ;
    ns1:textoExtracto "Distancia incorrecta entre I0 en captación E21A. Error indicativo de no repetitividad de la señal de I0 en cada vuelta del encoder. Pérdida de impulsos y/o medida errónea del captador." .

ns1:alarma_E142 a ns1:Alarma ;
    rdfs:label "Alarma E142: Sobrecorriente en E21A" ;
    ns1:identificador "E142" ;
    ns1:mitigaRiesgo ns1:captador_Sercos_E21A ;
    ns1:textoExtracto "Sobrecorriente o cortocircuito en captación E21A. Se ha producido un cortocircuito o se está sobrealimentando el captador." .

ns1:alarma_E240 a ns1:Alarma ;
    rdfs:label "Alarma E240: Frecuencia de contaje excesiva en E21B" ;
    ns1:identificador "E240" ;
    ns1:mitigaRiesgo ns1:captador_Sercos_E21B ;
    ns1:textoExtracto "Frecuencia de contaje excesiva en captación E21B." .

ns1:alarma_E241 a ns1:Alarma ;
    rdfs:label "Alarma E241: Distancia incorrecta entre I0 en E21B" ;
    ns1:identificador "E241" ;
    ns1:mitigaRiesgo ns1:captador_Sercos_E21B ;
    ns1:textoExtracto "Distancia incorrecta entre I0 en captación E21B." .

ns1:alarma_E242 a ns1:Alarma ;
    rdfs:label "Alarma E242: Sobrecorriente en E21B" ;
    ns1:identificador "E242" ;
    ns1:mitigaRiesgo ns1:captador_Sercos_E21B ;
    ns1:textoExtracto "Sobrecorriente o cortocircuito en captación E21B." .

ns1:alarma_E340 a ns1:Alarma ;
    rdfs:label "Alarma E340: Frecuencia de contaje excesiva en E21C" ;
    ns1:identificador "E340" ;
    ns1:mitigaRiesgo ns1:captador_Sercos_E21C ;
    ns1:textoExtracto "Frecuencia de contaje excesiva en captación E21C." .

ns1:alarma_E341 a ns1:Alarma ;
    rdfs:label "Alarma E341: Distancia incorrecta entre I0 en E21C" ;
    ns1:identificador "E341" ;
    ns1:mitigaRiesgo ns1:captador_Sercos_E21C ;
    ns1:textoExtracto "Distancia incorrecta entre I0 en captación E21C." .

ns1:alarma_E342 a ns1:Alarma ;
    rdfs:label "Alarma E342: Sobrecorriente en E21C" ;
    ns1:identificador "E342" ;
    ns1:mitigaRiesgo ns1:captador_Sercos_E21C ;
    ns1:textoExtracto "Sobrecorriente o cortocircuito en captación E21C." .

ns1:alarma_E438 a ns1:Alarma ;
    rdfs:label "Alarma E438: Amplitud en captación E21D" ;
    ns1:identificador "E438" ;
    ns1:mitigaRiesgo ns1:captador_Sercos_E21D ;
    ns1:textoExtracto "Alarma de amplitud en captación E21D. Excesiva atenuación o saturación de las señales A y/o B. El cableado, el captador o la captación de la contadora Sercos pueden tener algún problema." .

ns1:alarma_E440 a ns1:Alarma ;
    rdfs:label "Alarma E440: Frecuencia de contaje excesiva en E21D" ;
    ns1:identificador "E440" ;
    ns1:mitigaRiesgo ns1:captador_Sercos_E21D ;
    ns1:textoExtracto "Frecuencia de contaje excesiva en captación E21D. La velocidad del movimiento del eje excede la capacidad de muestreo del hardware de la contadora Sercos para ese tipo de señal del encoder." .

ns1:alarma_E441 a ns1:Alarma ;
    rdfs:label "Alarma E441: Distancia incorrecta entre I0 en E21D" ;
    ns1:identificador "E441" ;
    ns1:mitigaRiesgo ns1:captador_Sercos_E21D ;
    ns1:textoExtracto "Distancia incorrecta entre I0 en captación E21D. Error reseteable. Compruebe parámetro REFPULSE del CNC." .

ns1:alarma_E442 a ns1:Alarma ;
    rdfs:label "Alarma E442: Sobrecorriente en E21D" ;
    ns1:identificador "E442" ;
    ns1:mitigaRiesgo ns1:captador_Sercos_E21D ;
    ns1:textoExtracto "Sobrecorriente o cortocircuito en captación E21D." .

ns1:parametro_REFPULSE a ns1:Parametro ;
    rdfs:label "Parámetro REFPULSE del CNC" ;
    ns1:identificador "REFPULSE" ;
    ns1:monitoreaParametro ns1:captador_Sercos_E21A,
        ns1:captador_Sercos_E21B,
        ns1:captador_Sercos_E21C,
        ns1:captador_Sercos_E21D ;
    ns1:textoExtracto "Valor del parámetro REFPULSE del CNC (margen de error de pulsos del encoder)." .

ns1:sistema_captacion_Sercos a ns1:Sistema ;
    rdfs:label "Sistema de captación Sercos (módulo RCS-S)" ;
    ns1:textoExtracto "Contadora Sercos y captadores de encoder para medición de ejes." ;
    ns1:tieneComponente ns1:captador_Sercos_E21A,
        ns1:captador_Sercos_E21B,
        ns1:captador_Sercos_E21C,
        ns1:captador_Sercos_E21D .

ns1:captador_Sercos_E21A a ns1:Sensor ;
    rdfs:label "Captador Sercos E21A" ;
    ns1:identificador "E21A" ;
    ns1:textoExtracto "Captación E21A (encoder Sercos)." .

ns1:captador_Sercos_E21B a ns1:Sensor ;
    rdfs:label "Captador Sercos E21B" ;
    ns1:identificador "E21B" ;
    ns1:textoExtracto "Captación E21B (encoder Sercos)." .

ns1:captador_Sercos_E21C a ns1:Sensor ;
    rdfs:label "Captador Sercos E21C" ;
    ns1:identificador "E21C" ;
    ns1:textoExtracto "Captación E21C (encoder Sercos)." .

ns1:captador_Sercos_E21D a ns1:Sensor ;
    rdfs:label "Captador Sercos E21D" ;
    ns1:identificador "E21D" ;
    ns1:textoExtracto "Captación E21D (encoder Sercos)." .

