@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TareaMantenimiento_GuardarConfiguracionCNC a ns1:TareaMantenimiento ;
    rdfs:label "Guardar copia de seguridad de configuración CNC"@es ;
    ns1:requiereMantenimiento ns1:Maquina_CNC ;
    ns1:textoExtracto "guardar una copia de seguridad de la configuración de la máquina, el directorio MTB, a un archivo comprimido. Si se selecciona el apagado normal y el CNC detecta que se ha modificado la configuración de la máquina, avisa..."@es ;
    ns1:tieneFrecuencia ns1:Frecuencia_ModificacionConfiguracion .

ns1:Frecuencia_ModificacionConfiguracion a ns1:Frecuencia ;
    rdfs:label "Al modificar configuración"@es ;
    ns1:textoExtracto "Si [...] el CNC detecta que se ha modificado la configuración de la máquina"@es .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC"@es ;
    ns1:textoExtracto "configuración de la máquina"@es .

