ns1:Cable_Transductor_ABSIND a ns1:ComponenteElectrico ;
    rdfs:label "Cable de conexión entre módulo ABSIND y transductor inductosyn/resolver" ;
    ns1:textoExtracto "Comprobar el cable y la conexión entre el módulo ABSIND y transductor inductosyn/resolver." .

ns1:Contadora_Sercos a ns1:ComponenteElectrico ;
    rdfs:label "Contadora Sercos" ;
    ns1:textoExtracto "problema de conexionado entre el módulo ABSIND y la contadora Sercos asociado a esa captación" .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation" ;
    ns1:textoExtracto "Si el problema persiste, contacte con Fagor Automation." .

ns1:SoftwareAjuste_ABSIND a ns1:InterfazUsuario ;
    rdfs:label "Software de ajuste del módulo ABSIND" ;
    ns1:textoExtracto "Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste." .

ns1:Transductor_InductosynResolver a ns1:Sensor ;
    rdfs:label "Transductor inductosyn/resolver" ;
    ns1:textoExtracto "cable y la conexión entre el módulo ABSIND y transductor inductosyn/resolver" .

ns1:Modulo_ABSIND a ns1:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND" ;
    ns1:identificador "ABSIND" ;
    ns1:textoExtracto "ha podido leer la información de identificación del módulo ABSIND durante el arranque del sistema. Es probable que el error pueda deberse a un mal funcionamiento del módulo ABSIND o a un problema de conexionado entre el módulo ABSIND y la contadora Sercos asociado a esa captación." .

