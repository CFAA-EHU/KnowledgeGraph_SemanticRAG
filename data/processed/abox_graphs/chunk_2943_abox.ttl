@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_E183 a ns1:Alarma ;
    rdfs:label "E183 INDUCTOSYN: INC signal too-low en captación E21A" ;
    ns1:identificador "E183" ;
    ns1:mitigaRiesgo ns1:Modulo_ABSIND ;
    ns1:textoExtracto "E183 INDUCTOSYN: INC signal too-low en captación E21A. Nivel de la señal incremental del transductor inductosyn/resolver demasiado bajo." .

