@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Alarma_E186 a ns1:Alarma ;
    rdfs:label "E186: Transductor no estable en Power-ON (E21A)" ;
    ns1:activaAlarma ns1:Transductor_Inductosyn_Resolver_E21A ;
    ns1:identificador "E186" ;
    ns1:textoExtracto "E186 INDUCTOSYN: Transductor no estable en Power-ON en captación E21A." .

ns1:Alarma_E187 a ns1:Alarma ;
    rdfs:label "E187: Checksum EEPROM incorrecto (E21A)" ;
    ns1:activaAlarma ns1:Transductor_Inductosyn_Resolver_E21A ;
    ns1:identificador "E187" ;
    ns1:textoExtracto "E187 INDUCTOSYN: Checksum EEPROM incorrecto en captación E21A." .

ns1:Alarma_E286 a ns1:Alarma ;
    rdfs:label "E286: Transductor no estable en Power-ON (E21B)" ;
    ns1:activaAlarma ns1:Transductor_Inductosyn_Resolver_E21B ;
    ns1:identificador "E286" ;
    ns1:textoExtracto "E286 INDUCTOSYN: Transductor no estable en Power-ON en captación E21B." .

ns1:Alarma_E287 a ns1:Alarma ;
    rdfs:label "E287: Checksum EEPROM incorrecto (E21B)" ;
    ns1:activaAlarma ns1:Transductor_Inductosyn_Resolver_E21B ;
    ns1:identificador "E287" ;
    ns1:textoExtracto "E287 INDUCTOSYN: Checksum EEPROM incorrecto en captación E21B." .

ns1:Alarma_E385 a ns1:Alarma ;
    rdfs:label "E385: Señal GRAY ausente (E21B)" ;
    ns1:activaAlarma ns1:Senal_GRAY_E21B ;
    ns1:identificador "E385" ;
    ns1:textoExtracto "E385 INDUCTOSYN: GRAY signal absent en captación E21B." .

ns1:Alarma_E386 a ns1:Alarma ;
    rdfs:label "E386: Transductor no estable en Power-ON (E21C)" ;
    ns1:activaAlarma ns1:Transductor_Inductosyn_Resolver_E21C ;
    ns1:identificador "E386" ;
    ns1:textoExtracto "E386 INDUCTOSYN: Transductor no estable en Power-ON en captación E21C." .

ns1:Alarma_E387 a ns1:Alarma ;
    rdfs:label "E387: Checksum EEPROM incorrecto (E21C)" ;
    ns1:activaAlarma ns1:Transductor_Inductosyn_Resolver_E21C ;
    ns1:identificador "E387" ;
    ns1:textoExtracto "E387 INDUCTOSYN: Checksum EEPROM incorrecto en captación E21C." .

ns1:Alarma_E485 a ns1:Alarma ;
    rdfs:label "E485: Señal GRAY ausente (E21C/E21D)" ;
    ns1:activaAlarma ns1:Senal_GRAY_E21C,
        ns1:Senal_GRAY_E21D ;
    ns1:identificador "E485" ;
    ns1:textoExtracto "E485 INDUCTOSYN: GRAY signal absent en captación E21C. [...] E485 INDUCTOSYN: GRAY signal absent en captación E21D." .

ns1:Alarma_E486 a ns1:Alarma ;
    rdfs:label "E486: Transductor no estable en Power-ON (E21D)" ;
    ns1:activaAlarma ns1:Transductor_Inductosyn_Resolver_E21D ;
    ns1:identificador "E486" ;
    ns1:textoExtracto "E486 INDUCTOSYN: Transductor no estable en Power-ON en captación E21D." .

ns1:Alarma_E487 a ns1:Alarma ;
    rdfs:label "E487: Checksum EEPROM incorrecto (E21D)" ;
    ns1:activaAlarma ns1:Transductor_Inductosyn_Resolver_E21D ;
    ns1:identificador "E487" ;
    ns1:textoExtracto "E487 INDUCTOSYN: Checksum EEPROM incorrecto en captación E21D." .

ns1:Cable_Transductor_ABSIND_E21A a ns1:ComponenteElectrico ;
    rdfs:label "Cable entre módulo ABSIND y transductor (captación E21A)" ;
    ns1:textoExtracto "Comprobar el cable y la conexión entre el módulo ABSIND y transductor inductosyn/resolver." .

ns1:Cable_Transductor_ABSIND_E21B a ns1:ComponenteElectrico ;
    rdfs:label "Cable entre módulo ABSIND y transductor (captación E21B)" ;
    ns1:textoExtracto "Comprobar el cable y la conexión entre el módulo ABSIND y transductor inductosyn/resolver." .

ns1:Cable_Transductor_ABSIND_E21C a ns1:ComponenteElectrico ;
    rdfs:label "Cable entre módulo ABSIND y transductor (captación E21C)" ;
    ns1:textoExtracto "Comprobar el cable y la conexión entre el módulo ABSIND y transductor inductosyn/resolver." .

ns1:Cable_Transductor_ABSIND_E21D a ns1:ComponenteElectrico ;
    rdfs:label "Cable entre módulo ABSIND y transductor (captación E21D)" ;
    ns1:textoExtracto "Comprobar el cable y la conexión entre el módulo ABSIND y transductor inductosyn/resolver." .

ns1:ConexionTierra_Armario a ns1:ComponenteElectrico ;
    rdfs:label "Conexiones de tierra en el armario" ;
    ns1:textoExtracto "Comprobar las conexiones de tierra en el armario (ruido eléctrico sobre las señales)." .

ns1:Modulo_ABSIND a ns1:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND" ;
    ns1:controla ns1:Transductor_Inductosyn_Resolver_E21A,
        ns1:Transductor_Inductosyn_Resolver_E21B,
        ns1:Transductor_Inductosyn_Resolver_E21C,
        ns1:Transductor_Inductosyn_Resolver_E21D ;
    ns1:identificador "ABSIND" ;
    ns1:monitoreaParametro ns1:Senal_GRAY_E21A,
        ns1:Senal_GRAY_E21B,
        ns1:Senal_GRAY_E21C,
        ns1:Senal_GRAY_E21D ;
    ns1:textoExtracto "Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste. [...] Comprobar el cable y la conexión entre el módulo ABSIND y transductor inductosyn/resolver." .

ns1:Parametro_Fase_ABSIND a ns1:Parametro ;
    rdfs:label "Fase del módulo ABSIND" ;
    ns1:monitoreaParametro ns1:SoftwareAjuste_ABSIND ;
    ns1:textoExtracto "Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste." .

ns1:Parametro_Ganancia_ABSIND a ns1:Parametro ;
    rdfs:label "Ganancia del módulo ABSIND" ;
    ns1:monitoreaParametro ns1:SoftwareAjuste_ABSIND ;
    ns1:textoExtracto "Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste." .

ns1:Senal_GRAY_E21A a ns1:Parametro ;
    rdfs:label "Señal GRAY (captación E21A)" ;
    ns1:identificador "GRAY_E21A" ;
    ns1:textoExtracto "Nivel de la señal GRAY del transductor inductosyn/resolver ausente. [...] E186 INDUCTOSYN: Transductor no estable en Power-ON en captación E21A." ;
    ns1:valor "ausente"@es .

ns1:SoftwareAjuste_ABSIND a ns1:InterfazUsuario ;
    rdfs:label "Software de ajuste del módulo ABSIND" ;
    ns1:textoExtracto "Comprobar los valores de la ganancia y de fase del módulo ABSIND con el software de ajuste. [...] Comprobar el ajuste de ganancia y de fase del módulo ABSIND con el software de ajuste." .

ns1:Senal_GRAY_E21B a ns1:Parametro ;
    rdfs:label "Señal GRAY (captación E21B)" ;
    ns1:identificador "GRAY_E21B" ;
    ns1:textoExtracto "E385 INDUCTOSYN: GRAY signal absent en captación E21B." ;
    ns1:valor "absent"@en .

ns1:Senal_GRAY_E21C a ns1:Parametro ;
    rdfs:label "Señal GRAY (captación E21C)" ;
    ns1:identificador "GRAY_E21C" ;
    ns1:textoExtracto "E485 INDUCTOSYN: GRAY signal absent en captación E21C." ;
    ns1:valor "absent"@en .

ns1:Senal_GRAY_E21D a ns1:Parametro ;
    rdfs:label "Señal GRAY (captación E21D)" ;
    ns1:identificador "GRAY_E21D" ;
    ns1:textoExtracto "Nivel de la señal GRAY del transductor inductosyn/resolver ausente. [...] E485 INDUCTOSYN: GRAY signal absent en captación E21D." ;
    ns1:valor "ausente"@es .

ns1:Transductor_Inductosyn_Resolver_E21A a ns1:Sensor ;
    rdfs:label "Transductor inductosyn/resolver (captación E21A)" ;
    ns1:identificador "E21A" ;
    ns1:monitoreaParametro ns1:Senal_GRAY_E21A ;
    ns1:textoExtracto "E186 INDUCTOSYN: Transductor no estable en Power-ON en captación E21A. [...] La posición leída durante la inicialización del módulo ABSIND no es estable." .

ns1:Transductor_Inductosyn_Resolver_E21B a ns1:Sensor ;
    rdfs:label "Transductor inductosyn/resolver (captación E21B)" ;
    ns1:identificador "E21B" ;
    ns1:monitoreaParametro ns1:Senal_GRAY_E21B ;
    ns1:textoExtracto "E286 INDUCTOSYN: Transductor no estable en Power-ON en captación E21B. [...] E21B. E385 INDUCTOSYN: GRAY signal absent en captación E21B." .

ns1:Transductor_Inductosyn_Resolver_E21C a ns1:Sensor ;
    rdfs:label "Transductor inductosyn/resolver (captación E21C)" ;
    ns1:identificador "E21C" ;
    ns1:monitoreaParametro ns1:Senal_GRAY_E21C ;
    ns1:textoExtracto "E386 INDUCTOSYN: Transductor no estable en Power-ON en captación E21C. [...] E21C. E485 INDUCTOSYN: GRAY signal absent en captación E21C." .

ns1:Transductor_Inductosyn_Resolver_E21D a ns1:Sensor ;
    rdfs:label "Transductor inductosyn/resolver (captación E21D)" ;
    ns1:identificador "E21D" ;
    ns1:monitoreaParametro ns1:Senal_GRAY_E21D ;
    ns1:textoExtracto "E486 INDUCTOSYN: Transductor no estable en Power-ON en captación E21D. [...] E21D. E485 INDUCTOSYN: GRAY signal absent en captación E21D." .

