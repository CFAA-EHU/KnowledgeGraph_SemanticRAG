@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Empresa_FagorAutomation a ns1:Empresa ;
    rdfs:label "Fagor Automation"@es ;
    ns1:textoExtracto "contacte con Fagor Automation"@es .

ns1:Modulo_RCS_S_ABSIND a ns1:ComponenteElectrico ;
    rdfs:label "Módulo ABSIND (RCS-S)"@es ;
    ns1:solucionaFallo ns1:Error_E188_Inductosyn_E21A,
        ns1:Error_E288_Inductosyn ;
    ns1:textoExtracto "pruebe a sustituir el módulo ABSIND asociado a esa captación"@es .

ns1:Error_E188_Inductosyn_E21A a ns1:DiagnosticoFallo ;
    rdfs:label "Error E188 INDUCTOSYN: Error desconocido en captación E21A"@es ;
    ns1:identificador "E188" ;
    ns1:textoExtracto "E188 INDUCTOSYN: Error desconocido en captación E21A"@es .

ns1:Error_E288_Inductosyn a ns1:DiagnosticoFallo ;
    rdfs:label "Error E288 INDUCTOSYN"@es ;
    ns1:identificador "E288" ;
    ns1:textoExtracto "E288 INDUCTOSYN:"@es .

