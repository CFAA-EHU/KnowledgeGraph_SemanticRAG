@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CompactFlash_CNC a ns1:ComponenteElectrico ;
    rdfs:label "Compact Flash" ;
    ns1:textoExtracto "puede disponer de compact flash únicamente o de compact flash más disco duro" .

ns1:Contrase_a_AdministratorMode a ns1:Parametro ;
    rdfs:label "Contraseña Administrator mode" ;
    ns1:textoExtracto "contraseña 'Administrator mode', definida en el modo utilidades" .

ns1:Contrase_a_ParametrosMaquina a ns1:Parametro ;
    rdfs:label "Contraseña parámetros máquina" ;
    ns1:textoExtracto "contraseña 'parámetros máquina', definida en el modo utilidades" .

ns1:Directorio_CNC8070_USERS a ns1:InterfazUsuario ;
    rdfs:label "Directorio CNC8070\\USERS" ;
    ns1:textoExtracto "guardarse en un directorio desprotegido, por ejemplo CNC8070\\USERS" .

ns1:DiscoDuro_CNC a ns1:ComponenteElectrico ;
    rdfs:label "Disco duro" ;
    ns1:textoExtracto "compact flash más disco duro" .

ns1:ModoAdministrador_CNC a ns1:ModoOperacion ;
    rdfs:label "Modo administrador" ;
    ns1:textoExtracto "acceso al modo administrador se habilita con el código de validación" .

ns1:PCIndustrial_CNC a ns1:ComponenteElectrico ;
    rdfs:label "PC industrial CNC" ;
    ns1:textoExtracto "El CNC que usted ha adquirido se trata de un PC industrial equipado con sistema operativo Windows XP Embedded o Windows 7, que admite la instalación en él de aplicaciones de terceros." .

ns1:SistemaOperativoWindowsXPEmbeddedOWindows7 a ns1:ComponenteElectrico ;
    rdfs:label "Sistema operativo Windows XP Embedded o Windows 7" ;
    ns1:textoExtracto "sistema operativo Windows XP Embedded o Windows 7" .

