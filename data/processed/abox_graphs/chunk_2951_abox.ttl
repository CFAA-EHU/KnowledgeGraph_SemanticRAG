@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnilloFibraOptica a ns1:ComponenteElectrico ;
    rdfs:label "Anillo de fibra óptica (Módulo RCS-S)" ;
    ns1:compuestoPor ns1:Modulo_RCS_S ;
    ns1:textoExtracto "comunicación a través del anillo de fibra óptica" .

ns1:Parametro_TensionAlimentacion a ns1:Parametro ;
    rdfs:label "Tensión de alimentación (encóder/regla)" ;
    ns1:monitoreaParametro ns1:Modulo_RCS_S ;
    ns1:textoExtracto "La tensión de alimentación debe estar entre 5,3 V y 4,1 V." ;
    ns1:valor "5,3 V - 4,1 V" .

ns1:CableAlimentacionEncoder a ns1:ComponenteElectrico ;
    rdfs:label "Cable de alimentación del encóder/regla" ;
    ns1:compuestoPor ns1:Modulo_RCS_S ;
    ns1:textoExtracto "cable de alimentación del encóder o de la regla" .

ns1:Encoder_Regla a ns1:ComponenteElectrico ;
    rdfs:label "Encóder o cabeza de regla (Fagor)" ;
    ns1:textoExtracto "cable de alimentación del encóder o de la regla" ;
    ns1:tieneComponente ns1:CableAlimentacionEncoder .

ns1:Fallo_E198 a ns1:AvisoSeguridad ;
    rdfs:label "E198 - Error de parámetros (Captación digital Fagor)" ;
    ns1:identificador "E198" ;
    ns1:mitigaRiesgo ns1:TareaMantenimiento_ReemplazarEncoder ;
    ns1:textoExtracto "Captación digital Fagor. Error de parámetros." .

ns1:Fallo_E21A a ns1:AvisoSeguridad ;
    rdfs:label "E21A - Tensión de alimentación fuera de rango (Captación E21A)" ;
    ns1:identificador "E21A" ;
    ns1:mitigaRiesgo ns1:TareaMantenimiento_ComprobarCableadoE21A ;
    ns1:textoExtracto "Captación digital Fagor. Tensión de alimentación fuera de rango. Captación E21A." .

ns1:Fallo_E297 a ns1:AvisoSeguridad ;
    rdfs:label "E297 - Tensión de alimentación fuera de rango (Captación E21B)" ;
    ns1:identificador "E297" ;
    ns1:mitigaRiesgo ns1:TareaMantenimiento_ComprobarCableadoE297 ;
    ns1:textoExtracto "Captación digital Fagor. Tensión de alimentación fuera de rango. Captación E21B." .

ns1:Fallo_E298 a ns1:AvisoSeguridad ;
    rdfs:label "E298 - Error de parámetros (Captación digital Fagor)" ;
    ns1:identificador "E298" ;
    ns1:mitigaRiesgo ns1:TareaMantenimiento_ReemplazarEncoder ;
    ns1:textoExtracto "Captación digital Fagor. Error de parámetros." .

ns1:Fallo_E397 a ns1:AvisoSeguridad ;
    rdfs:label "E397 - Tensión de alimentación fuera de rango (Captación E21C)" ;
    ns1:identificador "E397" ;
    ns1:mitigaRiesgo ns1:TareaMantenimiento_ComprobarCableadoE397 ;
    ns1:textoExtracto "Captación digital Fagor. Tensión de alimentación fuera de rango. Captación E21C." .

ns1:Fallo_E398 a ns1:AvisoSeguridad ;
    rdfs:label "E398 - Error de parámetros (Captación digital Fagor)" ;
    ns1:identificador "E398" ;
    ns1:mitigaRiesgo ns1:TareaMantenimiento_ReemplazarEncoder ;
    ns1:textoExtracto "Captación digital Fagor. Error de parámetros." .

ns1:Fallo_E403 a ns1:AvisoSeguridad ;
    rdfs:label "E403 - Fallo en MST (Anillo de fibra óptica)" ;
    ns1:identificador "E403" ;
    ns1:mitigaRiesgo ns1:TareaMantenimiento_VerificarAnilloFibra ;
    ns1:textoExtracto "Fallo en MST. Problemas en la comunicación a través del anillo de fibra óptica. Verifíquense las conexiones en el anillo y la identificación de cada módulo." .

ns1:Fallo_E404 a ns1:AvisoSeguridad ;
    rdfs:label "E404 - Fallo en MDT (Anillo de fibra óptica)" ;
    ns1:identificador "E404" ;
    ns1:mitigaRiesgo ns1:TareaMantenimiento_VerificarAnilloFibra ;
    ns1:textoExtracto "Fallo en MDT. Problemas en la comunicación a través del anillo de fibra óptica. Verifíquense las conexiones en el anillo y la identificación de cada módulo." .

ns1:Fallo_E405 a ns1:AvisoSeguridad ;
    rdfs:label "E405 - Fase no válida (Anillo de fibra óptica)" ;
    ns1:identificador "E405" ;
    ns1:mitigaRiesgo ns1:TareaMantenimiento_VerificarAnilloFibra ;
    ns1:textoExtracto "Fase no válida (>4). Problemas en la comunicación a través del anillo de fibra óptica. Verifíquense las conexiones en el anillo y la identificación de cada módulo." .

ns1:Fallo_E406 a ns1:AvisoSeguridad ;
    rdfs:label "E406 - Ascenso erróneo de fase (Anillo de fibra óptica)" ;
    ns1:identificador "E406" ;
    ns1:mitigaRiesgo ns1:TareaMantenimiento_VerificarAnilloFibra ;
    ns1:textoExtracto "Ascenso erróneo de fase. Problemas en la comunicación a través del anillo de fibra óptica. Verifíquense las conexiones en el anillo y la identificación de cada módulo." .

ns1:Fallo_E407 a ns1:AvisoSeguridad ;
    rdfs:label "E407 - Descenso erróneo de fase (Anillo de fibra óptica)" ;
    ns1:identificador "E407" ;
    ns1:mitigaRiesgo ns1:TareaMantenimiento_VerificarAnilloFibra ;
    ns1:textoExtracto "Descenso erróneo de fase. Problemas en la comunicación a través del anillo de fibra óptica. Verifíquense las conexiones en el anillo y la identificación de cada módulo." .

ns1:Fallo_E497 a ns1:AvisoSeguridad ;
    rdfs:label "E497 - Tensión de alimentación fuera de rango (Captación E21D)" ;
    ns1:identificador "E497" ;
    ns1:mitigaRiesgo ns1:TareaMantenimiento_ComprobarCableadoE497 ;
    ns1:textoExtracto "Captación digital Fagor. Tensión de alimentación fuera de rango. Captación E21D." .

ns1:Fallo_E498 a ns1:AvisoSeguridad ;
    rdfs:label "E498 - Error de parámetros (Captación digital Fagor)" ;
    ns1:identificador "E498" ;
    ns1:mitigaRiesgo ns1:TareaMantenimiento_ReemplazarEncoder ;
    ns1:textoExtracto "Captación digital Fagor. Error de parámetros." .

ns1:TareaMantenimiento_ComprobarCableadoE21A a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar cableado (E21A)" ;
    ns1:solucionaFallo ns1:Fallo_E21A ;
    ns1:textoExtracto "Comprobar que el cable de alimentación del encóder o de la regla no está deteriorado. Comprobar también que la longitud del cable es adecuada y la conexión del cableado es satisfactoria." .

ns1:TareaMantenimiento_ComprobarCableadoE297 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar cableado (E297)" ;
    ns1:solucionaFallo ns1:Fallo_E297 ;
    ns1:textoExtracto "Comprobar que el cable de alimentación del encóder o de la regla no está deteriorado. Comprobar también que la longitud del cable es adecuada y la conexión del cableado es satisfactoria." .

ns1:TareaMantenimiento_ComprobarCableadoE397 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar cableado (E397)" ;
    ns1:solucionaFallo ns1:Fallo_E397 ;
    ns1:textoExtracto "Comprobar que el cable de alimentación del encóder o de la regla no está deteriorado. Comprobar también que la longitud del cable es adecuada y la conexión del cableado es satisfactoria." .

ns1:TareaMantenimiento_ComprobarCableadoE497 a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar cableado (E497)" ;
    ns1:solucionaFallo ns1:Fallo_E497 ;
    ns1:textoExtracto "Comprobar que el cable de alimentación del encóder o de la regla no está deteriorado. Comprobar también que la longitud del cable es adecuada y la conexión del cableado es satisfactoria." .

ns1:Modulo_RCS_S a ns1:Sistema ;
    rdfs:label "Módulo RCS-S" ;
    ns1:textoExtracto "MÓDULO RCS-S." .

ns1:TareaMantenimiento_ReemplazarEncoder a ns1:TareaMantenimiento ;
    rdfs:label "Reemplazar encóder o cabeza de regla" ;
    ns1:requiereConsumible ns1:Encoder_Regla ;
    ns1:solucionaFallo ns1:Fallo_E198,
        ns1:Fallo_E298,
        ns1:Fallo_E398,
        ns1:Fallo_E498 ;
    ns1:textoExtracto "Pérdida de la configuración del encóder o de la cabeza de la regla. Reemplazar el encóder o la cabeza de la regla." .

ns1:TareaMantenimiento_VerificarAnilloFibra a ns1:TareaMantenimiento ;
    rdfs:label "Verificar conexiones del anillo de fibra óptica" ;
    ns1:solucionaFallo ns1:Fallo_E403,
        ns1:Fallo_E404,
        ns1:Fallo_E405,
        ns1:Fallo_E406,
        ns1:Fallo_E407 ;
    ns1:textoExtracto "Verifíquense las conexiones en el anillo y la identificación de cada módulo." .

