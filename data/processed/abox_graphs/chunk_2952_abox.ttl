@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorE407 a ns1:AvisoSeguridad ;
    rdfs:label "Descenso erróneo de fase (E407)" ;
    ns1:identificador "E407" ;
    ns1:solucionaFallo ns1:AnilloFibraOptica_RCSS ;
    ns1:textoExtracto "E407 Descenso erróneo de fase. Problemas en la comunicación a través del anillo de fibra óptica." .

ns1:ErrorE410 a ns1:AvisoSeguridad ;
    rdfs:label "Ruido resetea Sercon (E410)" ;
    ns1:identificador "E410" ;
    ns1:solucionaFallo ns1:LatiguilloBusInterno_RCSS ;
    ns1:textoExtracto "E410 Ruido resetea Sercon. Por el latiguillo de conexión del bus interno entran ruidos que resetean el SerCon pero no el VeCon2." .

ns1:ErrorE411 a ns1:AvisoSeguridad ;
    rdfs:label "Error de recepción de telegramas (E411)" ;
    ns1:identificador "E411" ;
    ns1:solucionaFallo ns1:AnilloFibraOptica_RCSS ;
    ns1:textoExtracto "E411 Error de recepción de telegramas. Problemas en la comunicación a través del anillo de fibra óptica." .

ns1:ModuloRCSS a ns1:Sistema ;
    rdfs:label "Módulo RCS-S" ;
    ns1:textoExtracto "Problemas en la comunicación a través del **anillo de fibra óptica**. Verifíquense las conexiones en el anillo y la **identificación de cada módulo**." ;
    ns1:tieneComponente ns1:AnilloFibraOptica_RCSS,
        ns1:SerCon_RCSS,
        ns1:VeCon2_RCSS .

ns1:SerCon_RCSS a ns1:ComponenteElectrico ;
    rdfs:label "SerCon (RCS-S)" ;
    ns1:textoExtracto "ruidos que resetean el **SerCon** pero no el VeCon2." .

ns1:VeCon2_RCSS a ns1:ComponenteElectrico ;
    rdfs:label "VeCon2 (RCS-S)" ;
    ns1:textoExtracto "resetean el SerCon pero no el **VeCon2**." .

ns1:LatiguilloBusInterno_RCSS a ns1:ComponenteElectrico ;
    rdfs:label "Latiguillo de conexión del bus interno (RCS-S)" ;
    ns1:textoExtracto "Por el **latiguillo de conexión del bus interno** entran ruidos que resetean el SerCon..." .

ns1:AnilloFibraOptica_RCSS a ns1:ComponenteElectrico ;
    rdfs:label "Anillo de fibra óptica (RCS-S)" ;
    ns1:textoExtracto "Problemas en la comunicación a través del **anillo de fibra óptica**. Verifíquense las conexiones en el anillo..." ;
    ns1:tieneComponente ns1:LatiguilloBusInterno_RCSS .

