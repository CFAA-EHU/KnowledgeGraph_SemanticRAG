@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Almacen_1090_1 a ns1:Herramienta ;
    rdfs:label "almacén"@es ;
    ns1:textoExtracto "cargarla en el almacén"@es .

ns1:Herramienta_1090_1 a ns1:Herramienta ;
    rdfs:label "herramienta"@es ;
    ns1:textoExtracto "Si está en el cabezal o en los brazos cambiadores, cargarla en el almacén."@es .

ns1:TablaHerramientas_1090_1 a ns1:Tabla ;
    rdfs:label "tabla de herramientas"@es ;
    ns1:textoExtracto "al cargar la tabla de herramientas"@es .

