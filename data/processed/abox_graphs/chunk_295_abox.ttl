@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DirectorioCNC8070_USERS a ns1:Sistema ;
    rdfs:label "Directorio CNC8070\\USERS" ;
    ns1:textoExtracto "en un directorio desprotegido, por ejemplo CNC8070\\USERS. En ningún caso debe utilizar un directorio protegido, ya que sólo tendría carácter temporal, desaparecería tras apagar el CNC." .

ns1:ModoDiagnosis_CNC a ns1:ModoOperacion ;
    rdfs:label "Modo diagnosis del CNC" ;
    ns1:monitoreaParametro ns1:RecursosSistema_CNC ;
    ns1:textoExtracto "Esta información la puede consultar dentro del modo diagnosis del CNC." .

ns1:SoftwareTerceros_CNC a ns1:Sistema ;
    rdfs:label "Software de terceros para CNC" ;
    ns1:requiereMantenimiento ns1:VerificacionRecursos_PostInstalacion ;
    ns1:textoExtracto "Antes de instalar el software, compruebe que el CNC cumple con los requisitos que requiere el software" .

ns1:VerificacionRecursos_PostInstalacion a ns1:TareaMantenimiento ;
    rdfs:label "Verificación de recursos tras instalación" ;
    ns1:ejecutadoPor ns1:Personal ;
    ns1:monitoreaParametro ns1:RecursosSistema_CNC ;
    ns1:textoExtracto "Una vez instalado el software, con el CNC arrancado y en funcionamiento, verifique el estado de los recursos del sistema y compruebe que el funcionamiento del CNC, refresco de pantallas, etc es el correcto." .

ns1:RecursosSistema_CNC a ns1:Parametro ;
    rdfs:label "Recursos del sistema (CPU, memoria, disco)" ;
    ns1:textoExtracto "compruebe que el CNC cumple con los requisitos que requiere el software, tanto en CPU como en memoria. [...] Verifique igualmente que el espacio libre en el disco es suficiente para su aplicación." .

