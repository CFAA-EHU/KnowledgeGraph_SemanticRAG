@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjePlanoInvalido a ns1:DiagnosticoFallo ;
    rdfs:label "Eje del plano no válido" ;
    ns1:textoExtracto "CAUSA Algún eje del plano no es válido. Ambos ejes del plano son el mismo o alguno de los ejes del perfil seleccionado no se encuentra definido en el CNC." .

ns1:ErrorEjePlano a ns1:DiagnosticoFallo ;
    rdfs:label "Error en eje del plano" ;
    ns1:solucionaFallo ns1:CorreccionDatosElemento ;
    ns1:textoExtracto "SOLUCIÓN Corregir los datos del elemento. El valor de la arista debe ser menor que las trayectorias entre las que está definido. ' Error en eje del plano'" .

ns1:CorreccionDatosElemento a ns1:TareaMantenimiento ;
    ns1:textoExtracto "SOLUCIÓN Corregir los datos del elemento. El valor de la arista debe ser menor que las trayectorias entre las que está definido." .

