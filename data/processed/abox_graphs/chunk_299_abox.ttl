@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CarpetaMTB_46 a ns1:Sistema ;
    rdfs:label "Carpeta MTB (Machine Tool Builder)"@es ;
    ns1:identificador "1.7.1" ;
    ns1:textoExtracto "Esta carpeta está especialmente dirigida al fabricante de la máquina. Esta carpeta contiene las modificaciones que realiza el fabricante en el CNC, como por ejemplo, el programa PLC, los parámetros máquina, nuevas pantal..."@es ;
    ns1:tieneComponente ns1:AplicacionesExternas_46,
        ns1:PantallasCNC_46,
        ns1:ParametrosMaquina_46,
        ns1:ProgramaPLC_46 .

ns1:AplicacionesExternas_46 a ns1:Sistema ;
    rdfs:label "Aplicaciones externas"@es ;
    ns1:textoExtracto "incorporación de aplicaciones externas"@es .

ns1:PantallasCNC_46 a ns1:InterfazUsuario ;
    rdfs:label "Pantallas CNC"@es ;
    ns1:textoExtracto "nuevas pantallas"@es .

ns1:ParametrosMaquina_46 a ns1:Parametro ;
    rdfs:label "Parámetros máquina"@es ;
    ns1:textoExtracto "los parámetros máquina"@es .

ns1:ProgramaPLC_46 a ns1:Componente ;
    rdfs:label "Programa PLC"@es ;
    ns1:textoExtracto "el programa PLC"@es .

