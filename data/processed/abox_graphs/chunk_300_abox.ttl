@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Archivo_cncError_txt a ns1:InterfazUsuario ;
    rdfs:label "cncError.txt" ;
    ns1:identificador "cncError.txt" ;
    ns1:textoExtracto "archivo cncError.txt que contiene los mensajes y errores del fabricante en los distintos idiomas."@es .

ns1:Herramienta_Fguim a ns1:Herramienta ;
    rdfs:label "Fguim (herramienta de personalización de pantallas)"@es ;
    ns1:textoExtracto "archivos modificados mediante la herramienta de personalización de pantallas (Fguim)."@es .

ns1:MTB_SistemaCarpetas a ns1:Sistema ;
    rdfs:label "Sistema de Carpetas MTB (Machine Tool Builder)"@es ;
    ns1:compuestoPor ns1:MTB_Carpeta_DATA,
        ns1:MTB_Carpeta_DRIVE,
        ns1:MTB_Carpeta_GRAFDATA,
        ns1:MTB_Carpeta_KINEMATIC,
        ns1:MTB_Carpeta_MMC,
        ns1:MTB_Carpeta_PLC ;
    ns1:textoExtracto "Carpeta MTB (Machine Tool Builder)."@es .

ns1:MTB_Carpeta_DATA a ns1:Sistema ;
    rdfs:label "Carpeta DATA (MTB)"@es ;
    ns1:identificador "DATA" ;
    ns1:textoExtracto "Esta carpeta contiene los siguientes archivos o subcarpetas. • Las bases de datos de los parámetros máquina, tablas, etc y las copias de seguridad (en ASCII) de esas tablas. • Los archivos relacionados con los datos de los ciclos del editor (archivos dat). • Los datos que debe mantener el CNC tras el apagado (cotas, orígenes, etc). • En cada idioma de la subcarpeta ..\\LANG está el archivo cncError.txt que contiene los mensajes y errores del fabricante en los distintos idiomas."@es .

ns1:MTB_Carpeta_DRIVE a ns1:Sistema ;
    rdfs:label "Carpeta DRIVE (MTB)"@es ;
    ns1:identificador "DRIVE" ;
    ns1:textoExtracto "Esta carpeta contiene la información referente al modo DDSSETUP."@es .

ns1:MTB_Carpeta_GRAFDATA a ns1:Sistema ;
    rdfs:label "Carpeta GRAFDATA (MTB)"@es ;
    ns1:identificador "GRAFDATA" ;
    ns1:textoExtracto "Esta carpeta contiene la información referente a los gráficos."@es .

ns1:MTB_Carpeta_KINEMATIC a ns1:Sistema ;
    rdfs:label "Carpeta KINEMATIC (MTB)"@es ;
    ns1:identificador "KINEMATIC" ;
    ns1:textoExtracto "Esta carpeta contiene la información referente a las cinemáticas OEM."@es .

ns1:MTB_Carpeta_MMC a ns1:Sistema ;
    rdfs:label "Carpeta MMC (MTB)"@es ;
    ns1:identificador "MMC" ;
    ns1:textoExtracto "Esta carpeta contiene la personalización del CNC realizada por el fabricante. • La subcarpeta ..\\CONFIG contiene los archivos de configuración (archivos ini) y los archivos modificados mediante la herramienta de personalización de pantallas (Fguim). • La subcarpeta ..\\IMAGES contiene las imágenes, iconos, videos, etc que el fabricante utiliza para personalizar el CNC."@es .

ns1:MTB_Carpeta_PLC a ns1:Sistema ;
    rdfs:label "Carpeta PLC (MTB)"@es ;
    ns1:identificador "PLC" ;
    ns1:textoExtracto "Esta carpeta contiene la información referente al PLC. • En cada idioma de la subcarpeta ..\\LANG están los mensajes y errores del PLC en los distintos idiomas."@es .

