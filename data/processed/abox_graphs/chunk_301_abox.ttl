@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CarpetaMTB a ns1:Sistema ;
    rdfs:label "Carpeta MTB (Machine Tool Builder)"@es ;
    ns1:identificador "MTB" ;
    ns1:textoExtracto "Cuando cambia el lenguaje del CNC, éste reemplaza este archivo por el del lenguaje correspondiente."@es ;
    ns1:tieneComponente ns1:CarpetaPLC .

ns1:CarpetaPLC a ns1:Sistema ;
    rdfs:label "Carpeta PLC"@es ;
    ns1:compuestoPor ns1:SubcarpetaLANG_PLC,
        ns1:SubcarpetaPROJECT_PLC,
        ns1:SubcarpetaWATCH_PLC ;
    ns1:textoExtracto "Esta carpeta contiene la información referente al PLC."@es .

ns1:SubcarpetaLANG_PLC a ns1:Sistema ;
    rdfs:label "Subcarpeta LANG (PLC)"@es ;
    ns1:identificador "LANG" ;
    ns1:textoExtracto "En cada idioma de la subcarpeta ..\\LANG están los mensajes y errores del PLC en los distintos idiomas."@es .

ns1:SubcarpetaPROJECT_PLC a ns1:Sistema ;
    rdfs:label "Subcarpeta PROJECT (PLC)"@es ;
    ns1:identificador "PROJECT" ;
    ns1:textoExtracto "La subcarpeta ..\\PROJECT contiene los archivos que forman el proyecto PLC y el fichero objeto."@es .

ns1:SubcarpetaWATCH_PLC a ns1:Sistema ;
    rdfs:label "Subcarpeta WATCH (PLC)"@es ;
    ns1:identificador "WATCH" ;
    ns1:textoExtracto "La subcarpeta ..\\WATCH contiene los datos guardados desde los"@es .

