@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CarpetaMTB a ns1:Sistema ;
    rdfs:label "Carpeta MTB (Machine Tool Builder)" ;
    ns1:compuestoPor ns1:CarpetaRELEASE,
        ns1:CarpetaSUB,
        ns1:CarpetaTUNING,
        ns1:SubcarpetaPROJECT,
        ns1:SubcarpetaWATCH ;
    ns1:textoExtracto "1.7.1 Carpeta MTB (Machine Tool Builder)." .

ns1:CarpetaRELEASE a ns1:Sistema ;
    rdfs:label "Carpeta RELEASE" ;
    ns1:textoExtracto "Esta carpeta contiene los componentes (archivos ocx) utilizados por el fabricante para crear su propia aplicación." .

ns1:CarpetaSUB a ns1:Sistema ;
    rdfs:label "Carpeta SUB" ;
    ns1:compuestoPor ns1:SubrutinaBusquedaCero,
        ns1:SubrutinaCambioHerramienta ;
    ns1:textoExtracto "Esta carpeta contiene los siguientes archivos o subcarpetas. • Las subrutinas del fabricante (cambio de herramienta, búsqueda de cero, etc)." .

ns1:CarpetaTUNING a ns1:Sistema ;
    rdfs:label "Carpeta TUNING" ;
    ns1:textoExtracto "Esta carpeta contiene la información referente a las ayudas a la puesta a punto." .

ns1:SubcarpetaPROJECT a ns1:Sistema ;
    rdfs:label "Subcarpeta PROJECT" ;
    ns1:textoExtracto "La subcarpeta ..\\PROJECT contiene los archivos que forman el proyecto PLC y el fichero objeto." .

ns1:SubcarpetaWATCH a ns1:Sistema ;
    rdfs:label "Subcarpeta WATCH" ;
    ns1:textoExtracto "La subcarpeta ..\\WATCH contiene los datos guardados desde los servicios monitorización y analizador lógico." .

ns1:SubrutinaBusquedaCero a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina de búsqueda de cero" ;
    ns1:textoExtracto "subrutinas del fabricante (cambio de herramienta, búsqueda de cero, etc)." .

ns1:SubrutinaCambioHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina de cambio de herramienta" ;
    ns1:textoExtracto "subrutinas del fabricante (cambio de herramienta, búsqueda de cero, etc)." .

