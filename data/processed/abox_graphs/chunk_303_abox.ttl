@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Carpeta_USERS a ns1:Sistema ;
    rdfs:label "Carpeta USERS" ;
    ns1:compuestoPor ns1:Subcarpeta_HELP,
        ns1:Subcarpeta_POCKET,
        ns1:Subcarpeta_PRG,
        ns1:Subcarpeta_PROFILE,
        ns1:Subcarpeta_REPORTS,
        ns1:Subcarpeta_SUB ;
    ns1:textoExtracto "Esta carpeta está especialmente dirigida al usuario. El propósito de esta carpeta es proporcionar al usuario un espacio en el que pueda guardar ordenadamente los programas pieza, perfiles, etc que vaya generando." .

ns1:Archivo_pcall_txt a ns1:InterfazUsuario ;
    rdfs:label "pcall.txt" ;
    ns1:textoExtracto "el archivo pcall.txt que contiene la lista de subrutinas del usuario." .

ns1:Subcarpeta_HELP a ns1:Sistema ;
    rdfs:label "Subcarpeta HELP" ;
    ns1:textoExtracto "En cada idioma de la subcarpeta ..\\HELP están los archivos de ayuda asociados a las subrutinas globales definidas por el usuario y el archivo pcall.txt que contiene la lista de subrutinas del usuario." ;
    ns1:tieneComponente ns1:Archivo_pcall_txt .

ns1:Subcarpeta_POCKET a ns1:Sistema ;
    rdfs:label "Subcarpeta POCKET" ;
    ns1:textoExtracto "Esta carpeta contiene los perfiles creados mediante el editor de perfiles, asociados a los ciclos del editor." .

ns1:Subcarpeta_PRG a ns1:Sistema ;
    rdfs:label "Subcarpeta PRG" ;
    ns1:compuestoPor ns1:Subcarpeta_PRG_8055_TO_8070 ;
    ns1:textoExtracto "Esta carpeta contiene los programas pieza creados por el usuario, que podrá crear nuevas subcarpetas y guardar así los programas de una forma más ordenada." .

ns1:Subcarpeta_PRG_8055_TO_8070 a ns1:Sistema ;
    rdfs:label "Subcarpeta PRG_8055_TO_8070" ;
    ns1:identificador "PRG_8055_TO_8070" ;
    ns1:textoExtracto "La subcarpeta ..\\PRG_8055_TO_8070 contiene los programas traducidos al lenguaje 8070, que proceden de archivos en formato 8055." .

ns1:Subcarpeta_PROFILE a ns1:Sistema ;
    rdfs:label "Subcarpeta PROFILE" ;
    ns1:textoExtracto "Esta carpeta contiene los perfiles creados mediante el editor de perfiles." .

ns1:Subcarpeta_REPORTS a ns1:Sistema ;
    rdfs:label "Subcarpeta REPORTS" ;
    ns1:textoExtracto "Esta carpeta contiene los archivos (formato bmp) que genera el CNC cuando imprime un gráfico a un archivo y los informes (formato prn) generados desde el modo diagnosis." .

ns1:Subcarpeta_SUB a ns1:Sistema ;
    rdfs:label "Subcarpeta SUB" ;
    ns1:identificador "G500-G599",
        "program_start" ;
    ns1:textoExtracto "Esta carpeta contiene las subrutinas creadas por el usuario, cuya ubicación debe ser fija para el CNC (por ejemplo, las subrutinas genéricas de usuario G500-G599 y la subrutina program_start)." .

