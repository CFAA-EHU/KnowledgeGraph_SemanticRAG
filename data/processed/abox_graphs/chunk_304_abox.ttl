@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaquinaHerramienta a ns1:Maquina ;
    rdfs:label "Máquina-herramienta" ;
    ns1:controla ns1:SistemaCNC ;
    ns1:textoExtracto "Para que la máquina-herramienta pueda ejecutar correctamente las instrucciones programadas, así como interpretar los elementos que tiene interconectados"@es .

ns1:Capitulo_ParametrosMaquina a ns1:Capitulo ;
    rdfs:label "Capítulo de Parámetros Máquina" ;
    ns1:identificador "2.2" ;
    ns1:textoExtracto "Este capítulo recoge el significado de todos los parámetros máquina del CNC."@es .

ns1:ParametrosCNC a ns1:Parametro ;
    rdfs:label "Parámetros máquina del CNC" ;
    ns1:documentadoEn ns1:Capitulo_ParametrosMaquina ;
    ns1:textoExtracto "número de ejes, avances, aceleraciones, captaciones, tipo de almacén, cambiador de herramientas"@es .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:monitoreaParametro ns1:ParametrosCNC ;
    ns1:textoExtracto "el CNC debe conocer los datos específicos de la máquina... Estos datos están determinados por el fabricante de la máquina, que se los indica al CNC a través de los parámetros máquina."@es .

