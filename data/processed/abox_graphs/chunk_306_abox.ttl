@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Almacenes a ns1:Sistema ;
    rdfs:label "almacenes"@es ;
    ns1:textoExtracto "Parámetros de los almacenes. Estos parámetros indican el número de almacenes, tipo, número de posiciones, etc."@es .

ns1:InterfazHMI a ns1:InterfazUsuario ;
    rdfs:label "parámetros HMI"@es ;
    ns1:textoExtracto "Parámetros HMI. Estos parámetros permiten definir el entorno de comunicación entre el operario y el CNC."@es .

ns1:ModoManual a ns1:ModoOperacion ;
    rdfs:label "modo manual"@es ;
    ns1:textoExtracto "Parámetros del modo manual. Estos parámetros permiten personalizar los volantes y las teclas de JOG."@es .

ns1:TablaCinematicas a ns1:Tabla ;
    rdfs:label "tabla de cinemáticas"@es ;
    ns1:textoExtracto "Parámetros de la tabla de cinemáticas. Estos parámetros indican el tipo y características de cada una de las cinemáticas."@es .

ns1:TablaFuncionesM a ns1:Tabla ;
    rdfs:label "tabla de funciones M"@es ;
    ns1:textoExtracto "Parámetros de la tabla de funciones M. Estos parámetros permiten definir nuevas funciones M y personalizar el tipo de sincronización y la rutina asociada a cada una de las funciones M del sistema."@es .

