@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacionFabricante a ns1:ModoOperacion ;
    rdfs:label "Modo parámetros máquina (fabricante)" ;
    ns1:habilitadoPor ns1:ParametrosOEM ;
    ns1:textoExtracto "definir un grupo de parámetros genéricos para que el fabricante los pueda utilizar a modo de parámetros máquina" .

ns1:ParametrosComunicacionCNC a ns1:Parametro ;
    rdfs:label "Parámetros de comunicación CNC" ;
    ns1:textoExtracto "Estos parámetros permiten definir el entorno de comunicación entre el operario y el CNC." .

ns1:ParametrosOEM a ns1:Parametro ;
    rdfs:label "Parámetros OEM" ;
    ns1:monitoreaParametro ns1:ParametrosComunicacionCNC ;
    ns1:textoExtracto "Estos parámetros permiten configurar la lectura/escritura de variables del regulador, editar levas, definir un grupo de parámetros genéricos para que el fabricante los pueda utilizar a modo de parámetros máquina, etc." .

