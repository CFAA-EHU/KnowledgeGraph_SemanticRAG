@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_CNC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz CNC"@es ;
    ns1:textoExtracto "Los parámetros que no aparecen acompañados de este icono pueden asumir el nuevo valor solo con pulsar la softkey 'Validar'."@es ;
    ns1:tieneComponente ns1:ParametroMaquina_GrupoParametros,
        ns1:ParametroMaquina_Homogeneizacion,
        ns1:ParametroMaquina_ListaValoresPredeterminados,
        ns1:ParametroMaquina_ModoValidacion,
        ns1:ParametroMaquina_ReferenciaArchivo,
        ns1:ParametroMaquina_TablaDatos .

ns1:Sistema_Regulador a ns1:Sistema ;
    rdfs:label "Regulador"@es ;
    ns1:monitoreaParametro ns1:ParametroMaquina_Homogeneizacion ;
    ns1:textoExtracto "variables del regulador [...] homogeneización de parámetros entre el CNC y el regulador"@es .

ns1:Tabla_ValoresParametros a ns1:Tabla ;
    rdfs:label "Tabla de valores de parámetros máquina"@es ;
    ns1:documentadoEn ns1:Manual_Tecnico ;
    ns1:textoExtracto "acceder a una tabla de datos"@es .

ns1:ParametroMaquina_GrupoParametros a ns1:Parametro ;
    rdfs:label "Grupo de parámetros"@es ;
    ns1:textoExtracto "acceder a [...] un grupo de parámetros"@es .

ns1:ParametroMaquina_ListaValoresPredeterminados a ns1:Parametro ;
    rdfs:label "Selección de valores predeterminados"@es ;
    ns1:textoExtracto "Los iconos que aparecen junto al valor del parámetro permiten acceder a la lista de valores predeterminados"@es .

ns1:ParametroMaquina_ModoValidacion a ns1:Parametro ;
    rdfs:label "Modo de validación del parámetro"@es ;
    ns1:textoExtracto "Modo de validación del parámetro. Este icono puede aparecer junto al nombre del parámetro e indica que es necesario rearrancar el CNC para que el parámetro asuma el nuevo valor."@es ;
    ns1:valor "Reinicio requerido"@es .

ns1:ParametroMaquina_ReferenciaArchivo a ns1:Parametro ;
    rdfs:label "Referencia a archivo"@es ;
    ns1:textoExtracto "hacer referencia a un archivo"@es .

ns1:ParametroMaquina_TablaDatos a ns1:Parametro ;
    rdfs:label "Tabla de datos asociada"@es ;
    ns1:textoExtracto "acceder a [...] una tabla de datos"@es .

ns1:ParametroMaquina_Homogeneizacion a ns1:Parametro ;
    rdfs:label "Homogeneización de parámetros"@es ;
    ns1:textoExtracto "Homogeneización de parámetros. Este icono puede aparecer junto al nombre del parámetro e indica que éste participa en la homogeneización de parámetros entre el CNC y el regulador."@es ;
    ns1:valor "Sincronización CNC-Regulador"@es .

