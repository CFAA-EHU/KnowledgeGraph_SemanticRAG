@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_48_1 a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de edición de parámetros"@es ;
    ns1:textoExtracto "En los parámetros que no aparecen acompañados de ningún icono, se debe editar un valor"@es ;
    ns1:tieneComponente ns1:Parametro_48_1 .

ns1:Parametro_48_1 a ns1:Parametro ;
    rdfs:label "Parámetro editable sin icono"@es ;
    ns1:textoExtracto "En los parámetros que no aparecen acompañados de ningún icono, se debe editar un valor, que deberá estar dentro de los límites señalados."@es .

