@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CicloCalibracionHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Ciclo de calibración de herramienta"@es ;
    ns1:ejecutadoPor ns1:ModoManualSimulador ;
    ns1:textoExtracto "calibración de herramienta"@es .

ns1:CicloCentradoPieza a ns1:TareaMantenimiento ;
    rdfs:label "Ciclo de centrado de pieza"@es ;
    ns1:ejecutadoPor ns1:ModoManualSimulador ;
    ns1:textoExtracto "ciclos de centrado de pieza"@es .

ns1:ParametrosSimuladorCNC a ns1:Parametro ;
    rdfs:label "Parámetros por defecto en modo simulador"@es ;
    ns1:documentadoEn ns1:Manual_ParametrosMaquina ;
    ns1:textoExtracto "Valor por defecto de los parámetros en un simulador. Cuando el CNC se instala como simulador en un PC, el valor por defecto de algunos parámetros máquina puede ser diferente a los aquí mencionados. Básicamente los cambios se refieren a los avances máximos de ejes, aceleraciones y jerk."@es ;
    ns1:valor "avances_máximos_ejes: modificado; aceleraciones: modificado; jerk: modificado"@es .

ns1:Tabla_IconosParametrosMaquina a ns1:Tabla ;
    rdfs:label "Tabla de iconos de parámetros máquina"@es ;
    ns1:documentadoEn ns1:Manual_ParametrosMaquina ;
    ns1:textoExtracto """
| Icono. | Significado. |
| --- | --- |
|  | El parámetro posee una lista de opciones. |
|  | Accede a una tabla de datos. |
|  | Accede a un grupo de parámetros. |
|  | El parámetro hace referencia a un archivo.
"""@es .

ns1:ParametrosPalpadorSimulador a ns1:Parametro ;
    rdfs:label "Datos del palpador en modo simulador"@es ;
    ns1:documentadoEn ns1:Manual_ParametrosMaquina ;
    ns1:textoExtracto "También se modifican los datos del palpador para poder disponer, en el modo manual, de los ciclos de centrado de pieza y calibración de herramienta."@es ;
    ns1:valor "configuración_específica_simulación"@es .

ns1:ModoManualSimulador a ns1:ModoOperacion ;
    rdfs:label "Modo manual (simulador)"@es ;
    ns1:habilitadoPor ns1:ParametrosPalpadorSimulador ;
    ns1:textoExtracto "modo manual [...] ciclos de centrado de pieza y calibración de herramienta"@es .

