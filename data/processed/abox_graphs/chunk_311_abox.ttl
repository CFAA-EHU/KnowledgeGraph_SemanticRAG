@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC_50 a ns1:ComponenteElectrico ;
    rdfs:label "CNC" ;
    ns1:controla ns1:Regulador_50 ;
    ns1:documentadoEn ns1:TablaHomogeneizacion_50 ;
    ns1:monitoreaParametro ns1:Parametro_NP121_50,
        ns1:Parametro_NP122_50,
        ns1:Parametro_NP131_50,
        ns1:Parametro_NP133_50 ;
    ns1:textoExtracto "el CNC actualiza en los reguladores el valor de los parámetros necesarios para asegurar su equivalencia." .

ns1:Regulador_ACSD_50 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador ACSD" ;
    ns1:textoExtracto "El CNC no homogeneiza los parámetros cuando el regulador es un ACSD." .

ns1:SistemaSercos a ns1:Sistema ;
    rdfs:label "Sistema Sercos" ;
    ns1:textoExtracto "Algunos parámetros del CNC y de los reguladores deben estar definidos de forma equivalente para asegurar el correcto funcionamiento del sistema. Durante la inicialización del anillo Sercos, en el arranque del CNC y en la validación de los parámetros máquina de los ejes y cabezales, el CNC actualiza en los reguladores el valor de los parámetros necesarios para asegurar su equivalencia." ;
    ns1:tieneComponente ns1:CNC_50,
        ns1:Regulador_50,
        ns1:Regulador_ACSD_50 .

ns1:Parametro_NP121_50 a ns1:Parametro ;
    ns1:documentadoEn ns1:TablaHomogeneizacion_50 ;
    ns1:identificador "NP121" ;
    ns1:textoExtracto "la homogeneización actualiza los parámetros NP121, NP122, NP131 y NP133 de cada set del regulador con los valores definidos en el CNC." .

ns1:Parametro_NP122_50 a ns1:Parametro ;
    ns1:documentadoEn ns1:TablaHomogeneizacion_50 ;
    ns1:identificador "NP122" ;
    ns1:textoExtracto "la homogeneización actualiza los parámetros NP121, NP122, NP131 y NP133 de cada set del regulador con los valores definidos en el CNC." .

ns1:Parametro_NP131_50 a ns1:Parametro ;
    ns1:documentadoEn ns1:TablaHomogeneizacion_50 ;
    ns1:identificador "NP131" ;
    ns1:textoExtracto "la homogeneización actualiza los parámetros NP121, NP122, NP131 y NP133 de cada set del regulador con los valores definidos en el CNC." .

ns1:Parametro_NP133_50 a ns1:Parametro ;
    ns1:documentadoEn ns1:TablaHomogeneizacion_50 ;
    ns1:identificador "NP133" ;
    ns1:textoExtracto "la homogeneización actualiza los parámetros NP121, NP122, NP131 y NP133 de cada set del regulador con los valores definidos en el CNC." .

ns1:Regulador_50 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador (genérico)" ;
    ns1:textoExtracto "el CNC actualiza en los reguladores el valor de los parámetros necesarios para asegurar su equivalencia." ;
    ns1:tieneComponente ns1:Parametro_NP121_50,
        ns1:Parametro_NP122_50,
        ns1:Parametro_NP131_50,
        ns1:Parametro_NP133_50 .

ns1:TablaHomogeneizacion_50 a ns1:Tabla ;
    rdfs:label "Tabla de homogeneización de parámetros" ;
    ns1:detalladoEnEsquema ns1:SistemaSercos ;
    ns1:textoExtracto "Entendiendo la tabla de homogeneización." .

