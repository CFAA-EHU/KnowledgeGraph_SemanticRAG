@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Configuracion_Sercos a ns1:Parametro ;
    rdfs:label "Configuración Sercos (posición/velocidad)"@es ;
    ns1:documentadoEn ns1:Tabla_HomogeneizacionParametros_CNC_Regulador ;
    ns1:textoExtracto "Sercos: Indica si la escritura del parámetro en el drive está condicionada por el tipo de configuración Sercos, posición o velocidad."@es .

ns1:Feedback_CaptacionEje a ns1:Parametro ;
    rdfs:label "Feedback de captación del eje (interna/externamente)"@es ;
    ns1:documentadoEn ns1:Tabla_HomogeneizacionParametros_CNC_Regulador ;
    ns1:textoExtracto "Feedback: Indica si la escritura del parámetro en el drive está condicionada por el tipo de captación del eje, interna o externa."@es .

ns1:Parametro_CNC_Lista a ns1:Parametro ;
    rdfs:label "Parámetros máquina del CNC"@es ;
    ns1:documentadoEn ns1:Tabla_HomogeneizacionParametros_CNC_Regulador ;
    ns1:textoExtracto "CNC: Lista de parámetros máquina del CNC."@es .

ns1:Parametro_Drive_Lista a ns1:Parametro ;
    rdfs:label "Parámetros del regulador (DRIVE)"@es ;
    ns1:documentadoEn ns1:Tabla_HomogeneizacionParametros_CNC_Regulador ;
    ns1:textoExtracto "DRIVE: Lista de parámetros del regulador, que equivalen a cada parámetro del CNC."@es .

ns1:Tabla_HomogeneizacionParametros_CNC_Regulador a ns1:Tabla ;
    rdfs:label "Tabla de homogeneización de parámetros entre CNC y regulador"@es ;
    ns1:documentadoEn ns1:Pagina_51 ;
    ns1:identificador "2.1_Homogeneizacion_Parametros" ;
    ns1:textoExtracto "La tabla indica qué parámetros del CNC intervienen en la homogeneización, así como los parámetros del regulador que se ven afectados."@es .

