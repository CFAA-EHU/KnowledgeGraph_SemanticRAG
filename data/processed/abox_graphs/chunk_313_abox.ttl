@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_HomogeneizacionParametrosCNC_Drive a ns1:Tabla ;
    rdfs:label "Tabla de homogeneización de parámetros entre CNC y regulador (DRIVE)"@es ;
    ns1:detalladoEnEsquema ns1:Sistema_CNC_Drive ;
    ns1:textoExtracto """
| CNC       | DRIVE   | Sercos | Feedback | Observaciones                                                                                     |
|-----------|---------|--------|----------|---------------------------------------------------------------------------------------------------|
| AXISTYPE  | PP76    |        |          | PP76=65; Eje lineal. PP76=66; Eje rotativo sin módulo. PP76=194; Eje rotativo con módulo.           |
| PITCH     | NP123   |        |          |                                                                                                   |
| NPULSES2  | PP115   |        | Externa  | B0=0; Si encoder rotativo (NPULSES2<>0). B0=1; Si encoder lineal (NPULSES2==0). NP117; [...]"""@es .

ns1:Parametro_GP10 a ns1:Parametro ;
    rdfs:label "GP10 (FBACKSRC/SINMAGNI)"@es ;
    ns1:identificador "GP10" ;
    ns1:textoExtracto "GP10=0; No hay captación externa. GP10=1; Señal TTL (SINMAGNI==0). GP10=2; Señal Vpp (SINMAGNI<>0)."@es ;
    ns1:valor "0",
        "1",
        "2" .

ns1:Parametro_NP117 a ns1:Parametro ;
    rdfs:label "NP117 (Feedback externo)"@es ;
    ns1:identificador "NP117" ;
    ns1:textoExtracto "NP117; Si encoder rotativo (NPULSES2<>0) o lineal (NPULSES2==0)."@es .

ns1:Parametro_NP118 a ns1:Parametro ;
    rdfs:label "NP118 (Feedback externo)"@es ;
    ns1:identificador "NP118" ;
    ns1:textoExtracto "NP118; Si encoder lineal (NPULSES2==0)."@es .

ns1:Parametro_NP121 a ns1:Parametro ;
    rdfs:label "NP121.x (INPUTREV)"@es ;
    ns1:identificador "NP121.x" ;
    ns1:textoExtracto "INPUTREV (NP121.x). Afecta a todas las gamas."@es .

ns1:Parametro_NP122 a ns1:Parametro ;
    rdfs:label "NP122.x (OUTPUTREV)"@es ;
    ns1:identificador "NP122.x" ;
    ns1:textoExtracto "OUTPUTREV (NP122.x). Afecta a todas las gamas."@es .

ns1:Parametro_NP123 a ns1:Parametro ;
    rdfs:label "NP123 (PITCH)"@es ;
    ns1:identificador "NP123" ;
    ns1:textoExtracto "Parámetro NP123 asociado a PITCH en el DRIVE."@es .

ns1:Parametro_NP131 a ns1:Parametro ;
    rdfs:label "NP131.x (INPUTREV2)"@es ;
    ns1:identificador "NP131.x" ;
    ns1:textoExtracto "INPUTREV2 (NP131.x). Afecta a todas las gamas. Solo si encoder rotativo (NPULSES2<>0)."@es .

ns1:Parametro_NP132 a ns1:Parametro ;
    rdfs:label "NP132.x (OUTPUTREV2)"@es ;
    ns1:identificador "NP132.x" ;
    ns1:textoExtracto "OUTPUTREV2 (NP132.x). Afecta a todas las gamas. Solo si encoder rotativo (NPULSES2<>0)."@es .

ns1:Parametro_NP133 a ns1:Parametro ;
    rdfs:label "NP133 (PITCH2)"@es ;
    ns1:identificador "NP133" ;
    ns1:textoExtracto "NP133; Si encoder rotativo (NPULSES2<>0)."@es .

ns1:Parametro_PP115 a ns1:Parametro ;
    rdfs:label "PP115 (bit 0 para NPULSES2)"@es ;
    ns1:identificador "PP115_B0" ;
    ns1:textoExtracto "Bit 0 de PP115: B0=0 si encoder rotativo (NPULSES2<>0); B0=1 si encoder lineal (NPULSES2==0)."@es ;
    ns1:valor "0",
        "1" .

ns1:Parametro_PP16 a ns1:Parametro ;
    rdfs:label "PP16 (FBMIXTIME)"@es ;
    ns1:identificador "PP16" ;
    ns1:textoExtracto "FBMIXTIME (PP16). Feedback de posición externa."@es .

ns1:Parametro_PP5 a ns1:Parametro ;
    rdfs:label "PP5 (FBACKDIFF)"@es ;
    ns1:identificador "PP5" ;
    ns1:textoExtracto "FBACKDIFF (PP5). Feedback de posición externa."@es .

ns1:Parametro_PP76 a ns1:Parametro ;
    rdfs:label "PP76 (AXISTYPE/AXISMODE)"@es ;
    ns1:identificador "PP76" ;
    ns1:textoExtracto "PP76=65; Eje lineal. PP76=66; Eje rotativo sin módulo. PP76=194; Eje rotativo con módulo."@es ;
    ns1:valor "194",
        "65",
        "66" .

ns1:Sistema_CNC_Drive a ns1:Sistema ;
    rdfs:label "Sistema de interfaz CNC-DRIVE"@es ;
    ns1:textoExtracto "Homogeneización de parámetros entre el CNC y el regulador (DRIVE) para ejes lineales/rotativos y feedback externo."@es ;
    ns1:tieneComponente ns1:Parametro_GP10,
        ns1:Parametro_NP117,
        ns1:Parametro_NP118,
        ns1:Parametro_NP121,
        ns1:Parametro_NP122,
        ns1:Parametro_NP123,
        ns1:Parametro_NP131,
        ns1:Parametro_NP132,
        ns1:Parametro_NP133,
        ns1:Parametro_PP115,
        ns1:Parametro_PP16,
        ns1:Parametro_PP5,
        ns1:Parametro_PP76 .

