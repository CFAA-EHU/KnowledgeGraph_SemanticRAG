@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_ParametrosPosicionExternos a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de posición externos (CNC/regulador)" ;
    ns1:textoExtracto "FBACKDIFF | PP5 | Posición. | Externa. | FBMIXTIME | PP16 | Posición. | Externa. | AXISCH/LOOPCH | PP115 (bit 3) | Posición. | Externa. | B3=0; Signo del contaje AXISCH==LOOPCH. B3=1; Signo del contaje AXISCH<>LOOPCH." ;
    ns1:tieneComponente ns1:Parametro_AXISCH_LOOPCH,
        ns1:Parametro_FBACKDIFF,
        ns1:Parametro_FBMIXTIME .

ns1:Parametro_AXISCH_LOOPCH a ns1:Parametro ;
    rdfs:label "AXISCH/LOOPCH" ;
    ns1:identificador "PP115 (bit 3)" ;
    ns1:textoExtracto "AXISCH/LOOPCH | PP115 (bit 3) | Posición. | Externa. | B3=0; Signo del contaje AXISCH==LOOPCH. B3=1; Signo del contaje AXISCH<>LOOPCH." ;
    ns1:valor "B3=0: AXISCH==LOOPCH ; B3=1: AXISCH<>LOOPCH" .

ns1:Parametro_FBACKDIFF a ns1:Parametro ;
    rdfs:label "FBACKDIFF" ;
    ns1:identificador "PP5" ;
    ns1:textoExtracto "FBACKDIFF | PP5 | Posición. | Externa." ;
    ns1:valor "Posición" .

ns1:Parametro_FBMIXTIME a ns1:Parametro ;
    rdfs:label "FBMIXTIME" ;
    ns1:identificador "PP16" ;
    ns1:textoExtracto "FBMIXTIME | PP16 | Posición. | Externa." ;
    ns1:valor "Posición" .

