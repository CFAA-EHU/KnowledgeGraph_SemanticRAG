@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_ABSOFF a ns1:Parametro ;
    rdfs:label "ABSOFF" ;
    ns1:documentadoEn ns1:Tabla_HomogeneizacionParametrosCNC_Drive ;
    ns1:identificador "PP177/PP178" ;
    ns1:monitoreaParametro ns1:Sistema_Drive ;
    ns1:textoExtracto "ABSOFF; PP177/PP178; Interna/Externa; Sólo si se dispone de I0 codificados o captación absoluta." .

ns1:Parametro_AXISCH a ns1:Parametro ;
    rdfs:label "AXISCH" ;
    ns1:documentadoEn ns1:Tabla_HomogeneizacionParametrosCNC_Drive ;
    ns1:identificador "PP55 (bit 0,2,3)" ;
    ns1:monitoreaParametro ns1:Sistema_Drive ;
    ns1:textoExtracto "AXISCH; PP55 (bit 0,2,3); Posición; B1=0 B2=0 B3=0; No cambia el signo de contaje (AXISCH==NO). B1=1 B2=1 B3=1; Sí cambia el signo de contaje (AXISCH==SI)" .

ns1:Parametro_I0TYPE a ns1:Parametro ;
    rdfs:label "I0TYPE" ;
    ns1:documentadoEn ns1:Tabla_HomogeneizacionParametrosCNC_Drive ;
    ns1:identificador "PP115 (bit 1,5)" ;
    ns1:monitoreaParametro ns1:Sistema_Drive ;
    ns1:textoExtracto "I0TYPE; PP115 (bit 1,5); Feedback: Externa; B1=0 B5=0; Si I0 no codificado. B1=1 B5=0; Si I0 codificado creciente. B1=1 B5=1; Si I0 codificado decreciente." .

ns1:Parametro_REFDIREC_DECINPUT_FBACKSRC a ns1:Parametro ;
    rdfs:label "Búsqueda y captación (REFDIREC, DECINPUT, FBACKSRC)" ;
    ns1:documentadoEn ns1:Tabla_HomogeneizacionParametrosCNC_Drive ;
    ns1:identificador "PP147 (bit 0,1,3,5)" ;
    ns1:monitoreaParametro ns1:Sistema_Drive ;
    ns1:textoExtracto """
REFDIREC (PP147 bit 0): B0=0; Sentido de búsqueda positivo. B0=1; Sentido de búsqueda negativo.
DECINPUT (PP147 bit 5): B5=0; Sí se dispone de micro. B5=1; No se dispone de micro.
FBACKSRC (PP147 bit 3/1): B3=0; Captación interna. B3=1; Captación externa. B1=0; La señal DECEL del CNC siempre es positiva.
""" .

ns1:Parametro_REFFEED1 a ns1:Parametro ;
    rdfs:label "REFFEED1" ;
    ns1:documentadoEn ns1:Tabla_HomogeneizacionParametrosCNC_Drive ;
    ns1:identificador "PP41" ;
    ns1:monitoreaParametro ns1:Sistema_Drive ;
    ns1:textoExtracto "REFFEED1; PP41" .

ns1:Parametro_REFFEED2 a ns1:Parametro ;
    rdfs:label "REFFEED2" ;
    ns1:documentadoEn ns1:Tabla_HomogeneizacionParametrosCNC_Drive ;
    ns1:identificador "PP1" ;
    ns1:monitoreaParametro ns1:Sistema_Drive ;
    ns1:textoExtracto "REFFEED2; PP1" .

ns1:Parametro_REFSHIFT a ns1:Parametro ;
    rdfs:label "REFSHIFT" ;
    ns1:documentadoEn ns1:Tabla_HomogeneizacionParametrosCNC_Drive ;
    ns1:identificador "PP150/PP151" ;
    ns1:monitoreaParametro ns1:Sistema_Drive ;
    ns1:textoExtracto "REFSHIFT; PP150/PP151; Posición: Interna/Externa" .

ns1:Parametro_REFVALUE a ns1:Parametro ;
    rdfs:label "REFVALUE" ;
    ns1:documentadoEn ns1:Tabla_HomogeneizacionParametrosCNC_Drive ;
    ns1:identificador "PP52/PP54" ;
    ns1:monitoreaParametro ns1:Sistema_Drive ;
    ns1:textoExtracto "REFVALUE; PP52/PP54; Posición: Interna/Externa" .

ns1:Sistema_Drive a ns1:Sistema ;
    rdfs:label "Sistema DRIVE" ;
    ns1:textoExtracto "Regulador (DRIVE) para homogeneización de parámetros con el CNC mediante tabla de correspondencias." .

ns1:Tabla_HomogeneizacionParametrosCNC_Drive a ns1:Tabla ;
    rdfs:label "Tabla de homogeneización de parámetros entre CNC y regulador (DRIVE)"@es ;
    ns1:textoExtracto """
| CNC       | DRIVE      | Sercos   | Feedback | Observaciones |
|-----------|------------|----------|----------|---------------|
| AXISCH    | PP55       | Posición |          | B1=0 B2=0 B3=0; No cambia el signo de contaje (AXISCH==NO)...
| I0TYPE    | PP115      |          | Externa  | B1=0 B5=0; Si I0 no codificado...
| REFVALUE  | PP52/PP54  | Posición | Interna/Externa | ...
""" .

