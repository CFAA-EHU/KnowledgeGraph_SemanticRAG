@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:documentadoEn ns1:TablaParametrosCNC ;
    ns1:textoExtracto "En el caso de cabezales, ejes rotativos con módulo..." .

ns1:Componente_EjeRotativo a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo" ;
    ns1:documentadoEn ns1:TablaParametrosCNC ;
    ns1:textoExtracto "ejes rotativos con módulo..." .

ns1:Parametro_ABSOFF a ns1:Parametro ;
    rdfs:label "ABSOFF (PP177/PP178)" ;
    ns1:documentadoEn ns1:TablaParametrosCNC ;
    ns1:identificador "PP177; PP178" ;
    ns1:textoExtracto "ABSOFF | PP177 PP178 |  | Interna. Externa. | Sólo si se dispone de I0 codificados o captación absoluta." .

ns1:Parametro_BACKANOUT a ns1:Parametro ;
    rdfs:label "BACKANOUT" ;
    ns1:documentadoEn ns1:TablaParametrosCNC ;
    ns1:identificador "PP2" ;
    ns1:textoExtracto "BACKANOUT | PP2 | Posición. |  | Sólo si BACKANOUT<>0" ;
    ns1:valor "Posición" .

ns1:Parametro_BACKLASH a ns1:Parametro ;
    rdfs:label "BACKLASH" ;
    ns1:documentadoEn ns1:TablaParametrosCNC ;
    ns1:identificador "PP58" ;
    ns1:textoExtracto "BACKLASH | PP58 | Posición." ;
    ns1:valor "Posición" .

ns1:Parametro_BACKTIME a ns1:Parametro ;
    rdfs:label "BACKTIME" ;
    ns1:documentadoEn ns1:TablaParametrosCNC ;
    ns1:identificador "PP3" ;
    ns1:textoExtracto "BACKTIME | PP3 | Posición. |  | Sólo si BACKANOUT<>0" ;
    ns1:valor "Posición" .

ns1:Parametro_CalculoModuloCota a ns1:Parametro ;
    rdfs:label "Cálculo del módulo de la cota (PP76 bit 7)" ;
    ns1:documentadoEn ns1:TablaParametrosCNC ;
    ns1:identificador "PP76 (bit 7)" ;
    ns1:textoExtracto "Cálculo del módulo de la cota. | PP76 (bit 7) |  |  | B7=0; En los ejes rotativos o cabezales" ;
    ns1:valor "B7=0" .

ns1:Parametro_LimitesSoftware a ns1:Parametro ;
    rdfs:label "Límites de software (PP55 bit 4)" ;
    ns1:documentadoEn ns1:TablaParametrosCNC ;
    ns1:identificador "PP55 (bit 4)" ;
    ns1:textoExtracto "Activar límites de software. | PP55 (bit 4) |  |  | B4=1; Chequear los límites. B4=0; No chequear los límites (En el caso de cabezales, ejes rotativos con módulo y cuando ambos parámetros LIMIT+ y LIMIT- sean 0)." ;
    ns1:valor "B4=1; B4=0" .

ns1:Parametro_MODLIMUP a ns1:Parametro ;
    rdfs:label "MODLIMUP" ;
    ns1:documentadoEn ns1:TablaParametrosCNC ;
    ns1:identificador "PP103" ;
    ns1:textoExtracto "MODLIMUP | PP103 |  |  | Sólo si es cabezal o eje rotativo con módulo." .

ns1:Parametro_PROGAIN a ns1:Parametro ;
    rdfs:label "PROGAIN" ;
    ns1:documentadoEn ns1:TablaParametrosCNC ;
    ns1:identificador "PP104" ;
    ns1:textoExtracto "PROGAIN | PP104" .

ns1:Parametro_REFSHIFT a ns1:Parametro ;
    rdfs:label "REFSHIFT (PP150/PP151)" ;
    ns1:documentadoEn ns1:TablaParametrosCNC ;
    ns1:identificador "PP150; PP151" ;
    ns1:textoExtracto "REFSHIFT | PP150 PP151 | Posición. Posición. | Interna. Externa." ;
    ns1:valor "Posición" .

ns1:Parametro_SZERO a ns1:Parametro ;
    rdfs:label "SZERO" ;
    ns1:documentadoEn ns1:TablaParametrosCNC ;
    ns1:identificador "SP42" ;
    ns1:textoExtracto "SZERO | SP42 |  |  | Sólo si es cabezal. SP42= (SZERO * OUTPUTREV/INPUTREV)" .

ns1:TablaParametrosCNC a ns1:Tabla ;
    rdfs:label "Tabla de homogeneización de parámetros CNC-regulador" ;
    ns1:ilustradoEn ns1:Pagina_51_52 ;
    ns1:textoExtracto "REFSHIFT | PP150 PP151 | Posición. Posición. | Interna. Externa. | [...] Cálculo del módulo de la cota. | PP76 (bit 7) | B7=0; En los ejes rotativos o cabezales" .

