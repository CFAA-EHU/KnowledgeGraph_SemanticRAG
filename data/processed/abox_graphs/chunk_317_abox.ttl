@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "CNC" ;
    ns1:controla ns1:Parametro_PP76_Bit7 ;
    ns1:textoExtracto "el cálculo del módulo de la cota lo realiza el CNC" .

ns1:Tabla_ParametrosHomogeneizacion a ns1:Tabla ;
    rdfs:label "Tabla de homogeneización de parámetros entre CNC y regulador" ;
    ns1:detalladoEnEsquema ns1:Parametro_MAXFLWE,
        ns1:Parametro_PP159,
        ns1:Parametro_PP76_Bit7 ;
    ns1:documentadoEn ns1:Pagina_51_52 ;
    ns1:textoExtracto "| MAXFLWE | PP159 | ... | Cálculo del módulo de la cota. | PP76 (bit 7) | ..." .

ns1:Parametro_MAXFLWE a ns1:Parametro ;
    rdfs:label "MAXFLWE" ;
    ns1:identificador "MAXFLWE" ;
    ns1:monitoreaParametro ns1:Alarma_ErrorSeguimiento ;
    ns1:textoExtracto "Sólo si está activa la monitorización del error de seguimiento." .

ns1:Parametro_PP159 a ns1:Parametro ;
    rdfs:label "PP159" ;
    ns1:identificador "PP159" ;
    ns1:monitoreaParametro ns1:Alarma_ErrorSeguimiento ;
    ns1:textoExtracto "Sólo si está activa la monitorización del error de seguimiento." .

ns1:Alarma_ErrorSeguimiento a ns1:Alarma ;
    rdfs:label "Monitorización del error de seguimiento" ;
    ns1:textoExtracto "Sólo si está activa la monitorización del error de seguimiento." .

ns1:Parametro_PP76_Bit7 a ns1:Parametro ;
    rdfs:label "PP76 (bit 7)" ;
    ns1:identificador "PP76_Bit7" ;
    ns1:textoExtracto "En los ejes rotativos o cabezales trabajando en Sercos velocidad, el cálculo del módulo de la cota lo realiza el CNC." ;
    ns1:valor "B7=0" .

