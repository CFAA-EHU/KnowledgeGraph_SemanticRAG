@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:maquina_gantry a ns1:Maquina ;
    rdfs:label "Máquina gantry" ;
    ns1:textoExtracto "Eje gantry" ;
    ns1:tieneComponente ns1:param_MAXCOUPE,
        ns1:param_MAXFEED .

ns1:modo_HSC a ns1:ModoOperacion ;
    rdfs:label "HSC" ;
    ns1:monitoreaParametro ns1:param_MINCORFEED ;
    ns1:textoExtracto "modo HSC" .

ns1:param_MAXCOUPE a ns1:Parametro ;
    rdfs:label "MAXCOUPE" ;
    ns1:textoExtracto "Eje gantry. Máxima diferencia permitida entre los errores de seguimiento de ambos ejes." ;
    ns1:valor "Máxima diferencia permitida entre errores de seguimiento" .

ns1:param_MAXFEED a ns1:Parametro ;
    rdfs:label "MAXFEED" ;
    ns1:textoExtracto "Máximo avance para el mecanizado. Se recomienda definir este parámetro con un valor distinto de ꞏ0ꞏ." ;
    ns1:valor "Máximo avance para mecanizado" .

ns1:param_MINCORFEED a ns1:Parametro ;
    rdfs:label "MINCORFEED" ;
    ns1:textoExtracto "Velocidad mínima en las esquinas para el modo HSC." ;
    ns1:valor "Velocidad mínima en esquinas (modo HSC)" .

