@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_Jog a ns1:ModoOperacion ;
    rdfs:label "Modo jog"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosPuestaMarcha ;
    ns1:textoExtracto "Modo de trabajo manual. Avance en modo jog continuo."@es .

ns1:Parametro_DSYNCPOSW a ns1:Parametro ;
    rdfs:label "DSYNCPOSW" ;
    ns1:documentadoEn ns1:Tabla_ParametrosPuestaMarcha ;
    ns1:identificador "DSYNCPOSW" ;
    ns1:textoExtracto "Sincronización de ejes y cabezales. Este parámetro se define para el elemento esclavo de la sincronización e indica el margen de posición admisible dentro del cual se considera que la sincronización es correcta."@es .

ns1:Parametro_DSYNCVELW a ns1:Parametro ;
    rdfs:label "DSYNCVELW" ;
    ns1:documentadoEn ns1:Tabla_ParametrosPuestaMarcha ;
    ns1:identificador "DSYNCVELW" ;
    ns1:textoExtracto "Sincronización de ejes y cabezales. Este parámetro se define para el elemento esclavo de la sincronización e indica el margen de velocidad admisible dentro del cual se considera que la sincronización es correcta."@es .

ns1:Parametro_FBACKDIFF a ns1:Parametro ;
    rdfs:label "FBACKDIFF" ;
    ns1:documentadoEn ns1:Tabla_ParametrosPuestaMarcha ;
    ns1:identificador "FBACKDIFF" ;
    ns1:textoExtracto "Máxima diferencia entre captaciones. El CNC tiene en cuenta este parámetro en ejes configurados como Sercos posición y con captación externa o externa+interna. Se recomienda definir este parámetro con un valor distinto de ꞏ0ꞏ."@es .

ns1:Parametro_JOGFEED a ns1:Parametro ;
    rdfs:label "JOGFEED" ;
    ns1:documentadoEn ns1:Tabla_ParametrosPuestaMarcha ;
    ns1:identificador "JOGFEED" ;
    ns1:textoExtracto "Modo de trabajo manual. Avance en modo jog continuo."@es .

ns1:Parametro_LIMIT a ns1:Parametro ;
    rdfs:label "LIMIT+",
        "LIMIT-" ;
    ns1:documentadoEn ns1:Tabla_ParametrosPuestaMarcha ;
    ns1:identificador "LIMIT+",
        "LIMIT-" ;
    ns1:textoExtracto "Límites de recorrido del eje. Se recomienda que ambos parámetros no tengan valor ꞏ0ꞏ."@es .

ns1:Parametro_POSFEED a ns1:Parametro ;
    rdfs:label "POSFEED" ;
    ns1:documentadoEn ns1:Tabla_ParametrosPuestaMarcha ;
    ns1:identificador "POSFEED" ;
    ns1:textoExtracto "Avance de posicionamiento del eje independiente."@es .

ns1:Parametro_PROBEDELAY a ns1:Parametro ;
    rdfs:label "PROBEDELAY" ;
    ns1:documentadoEn ns1:Tabla_ParametrosPuestaMarcha ;
    ns1:identificador "PROBEDELAY" ;
    ns1:textoExtracto "Retardo de la señal de palpador 1 y 2. Este parámetro sólo se define cuando existe un retardo desde el momento de palpación hasta que el CNC recibe la señal (comunicación por infrarrojos, etc)."@es .

ns1:Parametro_PROBEDELAY2 a ns1:Parametro ;
    rdfs:label "PROBEDELAY2" ;
    ns1:documentadoEn ns1:Tabla_ParametrosPuestaMarcha ;
    ns1:identificador "PROBEDELAY2" ;
    ns1:textoExtracto "Retardo de la señal de palpador 1 y 2. Este parámetro sólo se define cuando existe un retardo desde el momento de palpación hasta que el CNC recibe la señal (comunicación por infrarrojos, etc)."@es .

ns1:Parametro_PROBEFEED a ns1:Parametro ;
    rdfs:label "PROBEFEED" ;
    ns1:documentadoEn ns1:Tabla_ParametrosPuestaMarcha ;
    ns1:identificador "PROBEFEED" ;
    ns1:textoExtracto "Avance máximo de palpado."@es .

ns1:Parametro_PROBERANGE a ns1:Parametro ;
    rdfs:label "PROBERANGE" ;
    ns1:documentadoEn ns1:Tabla_ParametrosPuestaMarcha ;
    ns1:identificador "PROBERANGE" ;
    ns1:textoExtracto "Distancia máxima de frenado del palpador. Este parámetro fija la distancia máxima de frenado del palpador tras realizar la palpación, evitando de esta forma la rotura del mismo (cerámicos, etc)."@es .

ns1:Parametro_REPOSFEED a ns1:Parametro ;
    rdfs:label "REPOSFEED" ;
    ns1:documentadoEn ns1:Tabla_ParametrosPuestaMarcha ;
    ns1:identificador "REPOSFEED" ;
    ns1:textoExtracto "Avance de reposicionamiento tras una inspección de herramienta."@es .

ns1:Parametro_TENDENCY a ns1:Parametro ;
    rdfs:label "TENDENCY" ;
    ns1:documentadoEn ns1:Tabla_ParametrosPuestaMarcha ;
    ns1:identificador "TENDENCY" ;
    ns1:textoExtracto "Activación del test de tendencia. Detecta el embalamiento de los ejes debido a realimentación positiva. Se aconseja activarlo durante la puesta a punto de la máquina."@es .

ns1:Tabla_ParametrosPuestaMarcha a ns1:Tabla ;
    rdfs:label "Tabla de parámetros a verificar antes de la puesta en marcha"@es ;
    ns1:documentadoEn ns1:Manual_53_54 ;
    ns1:textoExtracto "LIMIT+ / LIMIT- | Límites de recorrido del eje. Se recomienda que ambos parámetros no tengan valor ꞏ0ꞏ."@es .

