@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo de trabajo manual" ;
    ns1:monitoreaParametro ns1:Parametro_JOGFEED,
        ns1:Parametro_JOGRAPFEED,
        ns1:Parametro_MAXMANACC,
        ns1:Parametro_MAXMANFEED ;
    ns1:textoExtracto "Modo de trabajo manual" .

ns1:Parametro_POSFEED a ns1:Parametro ;
    rdfs:label "POSFEED" ;
    ns1:identificador "POSFEED" ;
    ns1:textoExtracto "Avance de posicionamiento del eje independiente." .

ns1:Parametro_REPOSFEED a ns1:Parametro ;
    rdfs:label "REPOSFEED" ;
    ns1:identificador "REPOSFEED" ;
    ns1:textoExtracto "Avance de reposicionamiento tras una inspección de herramienta." .

ns1:Parametro_JOGFEED a ns1:Parametro ;
    rdfs:label "JOGFEED" ;
    ns1:identificador "JOGFEED" ;
    ns1:textoExtracto "Modo de trabajo manual. Avance en modo jog continuo." .

ns1:Parametro_JOGRAPFEED a ns1:Parametro ;
    rdfs:label "JOGRAPFEED" ;
    ns1:identificador "JOGRAPFEED" ;
    ns1:textoExtracto "Modo de trabajo manual. Avance rápido en modo jog continuo." .

ns1:Parametro_MAXMANACC a ns1:Parametro ;
    rdfs:label "MAXMANACC" ;
    ns1:identificador "MAXMANACC" ;
    ns1:textoExtracto "Modo de trabajo manual. Aceleración máxima en manual." .

ns1:Parametro_MAXMANFEED a ns1:Parametro ;
    rdfs:label "MAXMANFEED" ;
    ns1:identificador "MAXMANFEED" ;
    ns1:textoExtracto "Modo de trabajo manual. Avance máximo en modo jog continuo." .

