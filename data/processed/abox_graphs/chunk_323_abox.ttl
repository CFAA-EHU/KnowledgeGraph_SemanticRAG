@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_FBACKAL a ns1:Parametro ;
    rdfs:label "FBACKAL" ;
    ns1:activaAlarma ns1:Alarma_Captacion ;
    ns1:documentadoEn ns1:Tabla_ParametrosVerificacionPuestaMarcha ;
    ns1:identificador "FBACKAL" ;
    ns1:textoExtracto "Activación de la alarma de captación. La alarma de captación debe estar activada."@es .

ns1:Parametro_FLWEMONITOR a ns1:Parametro ;
    rdfs:label "FLWEMONITOR" ;
    ns1:documentadoEn ns1:Tabla_ParametrosVerificacionPuestaMarcha ;
    ns1:identificador "FLWEMONITOR" ;
    ns1:monitoreaParametro ns1:Parametro_FEDYNFAC,
        ns1:Parametro_MAXFLWE,
        ns1:Parametro_MINFLWE ;
    ns1:textoExtracto "Tipo de monitorización del error de seguimiento. La monitorización debe estar activada."@es .

ns1:Parametro_G00FEED a ns1:Parametro ;
    rdfs:label "G00FEED" ;
    ns1:documentadoEn ns1:Tabla_ParametrosVerificacionPuestaMarcha ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "Avance en G00."@es .

ns1:Parametro_MAXFEED a ns1:Parametro ;
    rdfs:label "MAXFEED" ;
    ns1:documentadoEn ns1:Tabla_ParametrosVerificacionPuestaMarcha ;
    ns1:identificador "MAXFEED" ;
    ns1:textoExtracto "Máximo avance para el mecanizado. Se recomienda definir este parámetro con un valor distinto de ꞏ0ꞏ."@es .

ns1:Alarma_Captacion a ns1:Alarma ;
    rdfs:label "Alarma de captación"@es ;
    ns1:textoExtracto "La alarma de captación debe estar activada."@es .

ns1:Parametro_FEDYNFAC a ns1:Parametro ;
    rdfs:label "FEDYNFAC" ;
    ns1:documentadoEn ns1:Tabla_ParametrosVerificacionPuestaMarcha ;
    ns1:identificador "FEDYNFAC" ;
    ns1:textoExtracto """
Para una monitorización "lineal" del error de seguimiento, este parámetro indica el error porcentual permitido, desviación del error de seguimiento real respecto al teórico.
"""@es .

ns1:Parametro_MAXFLWE a ns1:Parametro ;
    rdfs:label "MAXFLWE" ;
    ns1:documentadoEn ns1:Tabla_ParametrosVerificacionPuestaMarcha ;
    ns1:identificador "MAXFLWE" ;
    ns1:textoExtracto """
Para una monitorización "standard" del error de seguimiento, este parámetro indica el máximo error de seguimiento permitido cuando el eje está en movimiento.
Para una monitorización "lineal" del error de seguimiento, este parámetro indica a partir de qué valor comienza la supervisión dinámica.
"""@es .

ns1:Parametro_MINFLWE a ns1:Parametro ;
    rdfs:label "MINFLWE" ;
    ns1:documentadoEn ns1:Tabla_ParametrosVerificacionPuestaMarcha ;
    ns1:identificador "MINFLWE" ;
    ns1:textoExtracto "Este parámetro indica el máximo error de seguimiento permitido cuando el eje está parado."@es .

ns1:Tabla_ParametrosVerificacionPuestaMarcha a ns1:Tabla ;
    rdfs:label "Tabla de parámetros a verificar antes de la puesta en marcha"@es ;
    ns1:documentadoEn ns1:Pagina_53_54 ;
    ns1:textoExtracto "G00FEED | Avance en G00."@es .

