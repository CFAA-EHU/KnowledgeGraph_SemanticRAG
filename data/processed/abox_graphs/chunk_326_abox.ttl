@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:monitoreaParametro ns1:Parametro_AXISNAME,
        ns1:Parametro_NAXIS ;
    ns1:textoExtracto "El número máximo de ejes depende del número de cabezales; la suma de ejes y cabezales será como máximo 32." ;
    ns1:tieneComponente ns1:Parametro_AXISNAME,
        ns1:Parametro_NAXIS .

ns1:Tabla_AXISNAME a ns1:Tabla ;
    rdfs:label "Tabla AXISNAME" ;
    ns1:documentadoEn ns1:Parametro_AXISNAME ;
    ns1:textoExtracto "| AXISNAME |  | --- | --- | AXISNAME n | Nombre de los ejes. |" .

ns1:Parametro_NAXIS a ns1:Parametro ;
    rdfs:label "NAXIS" ;
    ns1:identificador "MPG.NAXIS" ;
    ns1:textoExtracto "NAXIS Número de ejes que gobierna el CNC. Valores posibles: De 1 a 32. Valor por defecto: 3." ;
    ns1:valor 3 .

ns1:Parametro_AXISNAME a ns1:Parametro ;
    rdfs:label "AXISNAME" ;
    ns1:identificador "MPG.AXISNAMEn" ;
    ns1:textoExtracto "AXISNAME Lista de ejes del sistema. Este parámetro muestra la tabla para definir los nombres de los ejes. El número de ejes del sistema lo establece el parámetro NAXIS." .

