@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaEjesMaquina a ns1:Sistema ;
    rdfs:label "Sistema de ejes lógicos"@es ;
    ns1:documentadoEn ns1:TablaConfiguracionEjes ;
    ns1:textoExtracto "el nombre de los ejes podrá ser cualquiera del rango X, X1…X9,...E, E1…E9. Por ejemplo X, X1, Y3, Z9, W, W7, C... A la hora de definir los ejes, hay que tener en cuenta que el orden en el que se definen establece su número lógico."@es ;
    ns1:tieneComponente ns1:EjeLogico_1,
        ns1:EjeLogico_2,
        ns1:EjeLogico_3 .

ns1:EjeLogico_1 a ns1:Componente ;
    rdfs:label "Eje lógico AXISNAME 1"@es ;
    ns1:identificador "1" ;
    ns1:textoExtracto "AXISNAME 1 | Número lógico ꞏ1ꞏ."@es .

ns1:EjeLogico_2 a ns1:Componente ;
    rdfs:label "Eje lógico AXISNAME 2"@es ;
    ns1:identificador "2" ;
    ns1:textoExtracto "AXISNAME 2 | Número lógico ꞏ2ꞏ."@es .

ns1:EjeLogico_3 a ns1:Componente ;
    rdfs:label "Eje lógico AXISNAME 3"@es ;
    ns1:identificador "3" ;
    ns1:textoExtracto "AXISNAME 3 | Número lógico ꞏ3ꞏ."@es .

ns1:TablaConfiguracionEjes a ns1:Tabla ;
    rdfs:label "Tabla de configuración de ejes (AXISNAME)"@es ;
    ns1:textoExtracto """
| AXISNAME n | Orden lógico. |
| --- | --- |
| AXISNAME 1 | Número lógico ꞏ1ꞏ. |
| AXISNAME 2 | Número lógico ꞏ2ꞏ. |
| AXISNAME 3 | Número lógico ꞏ3ꞏ. """ .

