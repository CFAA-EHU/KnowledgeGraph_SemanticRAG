@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ParametroConfiguracionTandem a ns1:Parametro ;
    rdfs:label "Parámetro de configuración tándem"@es ;
    ns1:documentadoEn ns1:TablaEjesTandem ;
    ns1:monitoreaParametro ns1:SistemaTandem ;
    ns1:textoExtracto "Este parámetro muestra la tabla para definir las parejas tándem del sistema."@es .

ns1:ReguladorTandem a ns1:ComponenteElectrico ;
    rdfs:label "Regulador V6.14+"@es ;
    ns1:controla ns1:MotorTandem1,
        ns1:MotorTandem2 ;
    ns1:identificador "V6.14" ;
    ns1:textoExtracto "La gestión de cabezales y ejes tándem requiere una versión del regulador V6.14 o superior."@es .

ns1:TablaEjesTandem a ns1:Tabla ;
    rdfs:label "Tabla de ejes o cabezales tándem"@es ;
    ns1:detalladoEnEsquema ns1:SistemaTandem ;
    ns1:documentadoEn ns1:ManualBrochado ;
    ns1:textoExtracto "TANDEM Tabla de ejes o cabezales tándem. Este parámetro muestra la tabla para definir las parejas tándem del sistema."@es .

ns1:MotorTandem1 a ns1:ComponenteElectrico ;
    rdfs:label "Motor eléctrico tándem 1"@es ;
    ns1:textoExtracto "dos accionamientos eléctricos (motores) acoplados mecánicamente"@es .

ns1:MotorTandem2 a ns1:ComponenteElectrico ;
    rdfs:label "Motor eléctrico tándem 2"@es ;
    ns1:textoExtracto "dos accionamientos eléctricos (motores) acoplados mecánicamente"@es .

ns1:SistemaTandem a ns1:Sistema ;
    rdfs:label "Sistema de transmisión tándem"@es ;
    ns1:compuestoPor ns1:MotorTandem1,
        ns1:MotorTandem2 ;
    ns1:controla ns1:ReguladorTandem ;
    ns1:textoExtracto "Un eje tándem consiste en dos accionamientos eléctricos (motores) acoplados mecánicamente entre sí formando un único sistema de transmisión (eje o cabezal)."@es .

