@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaTandem_68 a ns1:Sistema ;
    rdfs:label "Sistema tándem de ejes con configuración piñón-cremallera"@es ;
    ns1:compuestoPor ns1:ComponenteMecanico_Pinion1_68,
        ns1:ComponenteMecanico_Pinion2_68,
        ns1:ComponenteMecanico_Rack_68,
        ns1:MotorTandem_Esclavo_68,
        ns1:MotorTandem_Maestro_68 ;
    ns1:detalladoEnEsquema ns1:Tabla_ParametrosTandem_68 ;
    ns1:textoExtracto "Ejemplo de un eje tándem compuesto por dos piñones (pinion) y una cremallera (rack). Esta configuración permite resaltar los siguientes aspectos: Un eje tándem permite disponer del par necesario para mover un accionamiento cuando un sólo motor no es capaz de suministrar el par suficiente para hacerlo. La aplicación de un par de precarga entre el motor principal y el motor esclavo reduce la holgura (backlash)."@es .

ns1:ComponenteMecanico_Pinion1_68 a ns1:ComponenteMecanico ;
    rdfs:label "Piñón 1 (eje maestro)"@es ;
    ns1:textoExtracto "Ejemplo de un eje tándem compuesto por dos piñones (pinion) y una cremallera (rack)."@es .

ns1:ComponenteMecanico_Pinion2_68 a ns1:ComponenteMecanico ;
    rdfs:label "Piñón 2 (eje esclavo)"@es ;
    ns1:textoExtracto "Ejemplo de un eje tándem compuesto por dos piñones (pinion) y una cremallera (rack)."@es .

ns1:ComponenteMecanico_Rack_68 a ns1:ComponenteMecanico ;
    rdfs:label "Cremallera (rack)"@es ;
    ns1:textoExtracto "Ejemplo de un eje tándem compuesto por dos piñones (pinion) y una cremallera (rack)."@es .

ns1:MotorTandem_Esclavo_68 a ns1:ComponenteElectrico ;
    rdfs:label "Motor tándem esclavo"@es ;
    ns1:monitoreaParametro ns1:Parametro_AXISEXCH_68,
        ns1:Parametro_AXISTYPE_68,
        ns1:Parametro_DRIVETYPE_68,
        ns1:Parametro_LIMIT_68,
        ns1:Parametro_REFFEED1_68,
        ns1:Parametro_REFFEED2_68 ;
    ns1:textoExtracto "Cada eje (cabezal) tándem maestro admite un único eje (cabezal) tándem esclavo."@es .

ns1:MotorTandem_Maestro_68 a ns1:ComponenteElectrico ;
    rdfs:label "Motor tándem maestro"@es ;
    ns1:identificador "MASTERAXIS" ;
    ns1:monitoreaParametro ns1:Parametro_AXISEXCH_68,
        ns1:Parametro_AXISTYPE_68,
        ns1:Parametro_DRIVETYPE_68,
        ns1:Parametro_LIMIT_68,
        ns1:Parametro_REFFEED1_68,
        ns1:Parametro_REFFEED2_68 ;
    ns1:textoExtracto "Cada eje (cabezal) tándem maestro admite un único eje (cabezal) tándem esclavo."@es .

ns1:Tabla_ParametrosTandem_68 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de configuración tándem (TANDEM)"@es ;
    ns1:documentadoEn ns1:Manual_Broaching ;
    ns1:textoExtracto "TANDEM n Configuración de cada pareja tándem. Este parámetro muestra la tabla de parámetros para definir las parejas tándem del sistema."@es .

ns1:Parametro_AXISEXCH_68 a ns1:Parametro ;
    rdfs:label "AXISEXCH (permiso de cambio de canal)"@es ;
    ns1:textoExtracto "El permiso de cambio de canal (parámetro AXISEXCH) deberá ser igual en ambos ejes."@es .

ns1:Parametro_AXISTYPE_68 a ns1:Parametro ;
    rdfs:label "AXISTYPE (tipo de eje)"@es ;
    ns1:textoExtracto "Ambos ejes y reguladores deberán ser del mismo tipo (parámetros AXISTYPE y DRIVETYPE iguales para ambos ejes)."@es .

ns1:Parametro_DRIVETYPE_68 a ns1:Parametro ;
    rdfs:label "DRIVETYPE (tipo de accionamiento)"@es ;
    ns1:textoExtracto "Ambos ejes y reguladores deberán ser del mismo tipo (parámetros AXISTYPE y DRIVETYPE iguales para ambos ejes)."@es .

ns1:Parametro_LIMIT_68 a ns1:Parametro ;
    rdfs:label "LIMIT+ (límite de software positivo)"@es,
        "LIMIT- (límite de software negativo)"@es ;
    ns1:textoExtracto "Ambos ejes deberán tener los mismos límites de software (parámetros LIMIT+ y LIMIT- iguales para ambos ejes)."@es .

ns1:Parametro_REFFEED1_68 a ns1:Parametro ;
    rdfs:label "REFFEED1 (velocidad rápida de búsqueda de referencia)"@es ;
    ns1:textoExtracto "La velocidad rápida y lenta de búsqueda de referencia máquina (parámetros REFFEED1 y REFFEED2) deberá ser igual en ambos ejes."@es .

ns1:Parametro_REFFEED2_68 a ns1:Parametro ;
    rdfs:label "REFFEED2 (velocidad lenta de búsqueda de referencia)"@es ;
    ns1:textoExtracto "La velocidad rápida y lenta de búsqueda de referencia máquina (parámetros REFFEED1 y REFFEED2) deberá ser igual en ambos ejes."@es .

