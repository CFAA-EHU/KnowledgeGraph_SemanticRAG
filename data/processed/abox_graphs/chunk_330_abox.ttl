@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaTandem a ns1:Sistema ;
    rdfs:label "Sistema tándem"@es ;
    ns1:detalladoEnEsquema ns1:TablaParametrosTandem ;
    ns1:textoExtracto "configuración de un sistema tándem"@es ;
    ns1:tieneComponente ns1:Parametro_MASTERAXIS,
        ns1:Parametro_SLAVEAXIS,
        ns1:Parametro_TORQDIST .

ns1:Pagina_57_60 a ns1:Pagina ;
    ns1:identificador "57-60" ;
    ns1:textoExtracto "Sección 2.3.3 Configuración de un sistema tándem"@es .

ns1:Parametro_MASTERAXIS a ns1:Parametro ;
    rdfs:label "MASTERAXIS (Eje/cabezal maestro)"@es ;
    ns1:documentadoEn ns1:TablaParametrosTandem ;
    ns1:textoExtracto "MASTERAXIS | Pareja tándem. Eje/cabezal maestro o principal."@es .

ns1:Parametro_SLAVEAXIS a ns1:Parametro ;
    rdfs:label "SLAVEAXIS (Eje/cabezal esclavo)"@es ;
    ns1:documentadoEn ns1:TablaParametrosTandem ;
    ns1:textoExtracto "SLAVEAXIS | Pareja tándem. Eje/cabezal esclavo."@es .

ns1:Parametro_TORQDIST a ns1:Parametro ;
    rdfs:label "TORQDIST (Distribución del par)"@es ;
    ns1:documentadoEn ns1:TablaParametrosTandem ;
    ns1:textoExtracto "TORQDIST | Pareja tándem. Distribución del par."@es .

ns1:TablaParametrosTandem a ns1:Tabla ;
    rdfs:label "Tabla de parámetros para configuración de sistema tándem"@es ;
    ns1:documentadoEn ns1:Pagina_57_60 ;
    ns1:textoExtracto "Este parámetro muestra la tabla de parámetros para definir las parejas tándem del sistema. Cada pareja tándem dispone de los siguientes parámetros máquina para su configuración."@es .

