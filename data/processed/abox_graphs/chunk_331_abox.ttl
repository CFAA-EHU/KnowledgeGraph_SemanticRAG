@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_PRELFITI a ns1:Parametro ;
    rdfs:label "PRELFITI" ;
    ns1:identificador "PRELFITI" ;
    ns1:monitoreaParametro ns1:SistemaTandem ;
    ns1:textoExtracto "Pareja tándem. Tiempo del filtro para aplicar la precarga." .

ns1:Parametro_PRELOAD a ns1:Parametro ;
    rdfs:label "PRELOAD" ;
    ns1:identificador "PRELOAD" ;
    ns1:monitoreaParametro ns1:SistemaTandem ;
    ns1:textoExtracto "Pareja tándem. Precarga entre ambos motores." .

ns1:Parametro_TCOMPLIM a ns1:Parametro ;
    rdfs:label "TCOMPLIM" ;
    ns1:identificador "TCOMPLIM" ;
    ns1:monitoreaParametro ns1:SistemaTandem ;
    ns1:textoExtracto "Pareja tándem. Límite de la compensación." .

ns1:Parametro_TINTIME a ns1:Parametro ;
    rdfs:label "TINTIME" ;
    ns1:identificador "TINTIME" ;
    ns1:monitoreaParametro ns1:SistemaTandem ;
    ns1:textoExtracto "Pareja tándem. Ganancia integral (Ki) para el tándem." .

ns1:Parametro_TORQMODE a ns1:Parametro ;
    rdfs:label "TORQMODE" ;
    ns1:identificador "TORQMODE" ;
    ns1:monitoreaParametro ns1:SistemaTandem ;
    ns1:textoExtracto "Pareja tándem. Modo de control de par." .

ns1:Parametro_TPROGAIN a ns1:Parametro ;
    rdfs:label "TPROGAIN" ;
    ns1:identificador "TPROGAIN" ;
    ns1:monitoreaParametro ns1:SistemaTandem ;
    ns1:textoExtracto "Pareja tándem. Ganancia proporcional (Kp) para el tándem." .

ns1:SistemaTandem a ns1:Sistema ;
    rdfs:label "Sistema Tándem" ;
    ns1:textoExtracto "Configuración de un sistema tándem." ;
    ns1:tieneComponente ns1:Parametro_PRELFITI,
        ns1:Parametro_PRELOAD,
        ns1:Parametro_TCOMPLIM,
        ns1:Parametro_TINTIME,
        ns1:Parametro_TORQMODE,
        ns1:Parametro_TPROGAIN .

