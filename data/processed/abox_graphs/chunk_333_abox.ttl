@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_Tandem a ns1:Sistema ;
    rdfs:label "Sistema tándem de motores"@es ;
    ns1:monitoreaParametro ns1:Parametro_ParTandem_Maestro,
        ns1:Parametro_PreloadTandem ;
    ns1:textoExtracto "Configuración de un sistema tándem [...] par total necesario en el tándem."@es ;
    ns1:tieneComponente ns1:Motor_Esclavo,
        ns1:Motor_Maestro .

ns1:Motor_Esclavo a ns1:ComponenteMecanico ;
    rdfs:label "Motor esclavo (tándem)"@es ;
    ns1:textoExtracto "La diferencia entre el valor de este parámetro y el 100% es el porcentaje que se aplicará al motor esclavo."@es .

ns1:Motor_Maestro a ns1:ComponenteMecanico ;
    rdfs:label "Motor maestro (tándem)"@es ;
    ns1:textoExtracto "El parámetro indica qué porcentaje debe dar el motor maestro."@es .

ns1:Parametro_ParTandem_Maestro a ns1:Parametro ;
    rdfs:label "Parámetro de porcentaje de par (motor maestro)"@es ;
    ns1:textoExtracto "Este parámetro establece el porcentaje de par que realiza cada motor para conseguir el par total necesario en el tándem. El parámetro indica qué porcentaje debe dar el motor maestro."@es ;
    ns1:valor "50%"@es .

ns1:Parametro_PreloadTandem a ns1:Parametro ;
    rdfs:label "PRELOAD (Precarga entre motores tándem)"@es ;
    ns1:identificador "V.MPG.PRELOAD[nb]" ;
    ns1:textoExtracto "Precarga entre ambos motores. Valores posibles: Entre ±100%. Valor por defecto: 0 (se deshabilita la precarga)."@es ;
    ns1:valor "0" .

