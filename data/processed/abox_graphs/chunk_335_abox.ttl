@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ParNominal_Tandem a ns1:Parametro ;
    rdfs:label "Par nominal (T.nom)"@es ;
    ns1:documentadoEn ns1:Tabla_Tandem ;
    ns1:textoExtracto "T.nom Par nominal."@es .

ns1:Parametro_Kp_Tandem a ns1:Parametro ;
    rdfs:label "Ganancia proporcional (Kp) para el tándem"@es ;
    ns1:documentadoEn ns1:Tabla_Tandem ;
    ns1:identificador "V.MPG.TPROGAIN[nb]" ;
    ns1:monitoreaParametro ns1:ErrorPar_Tandem ;
    ns1:textoExtracto "Ganancia proporcional (Kp) para el tándem. Valores posibles: De 0 a 100%. Valor por defecto: 0 (no se aplica ganancia proporcional). Variable asociada: (V.)MPG.TPROGAIN[nb]"@es .

ns1:VelocidadMaxima_Tandem a ns1:Parametro ;
    rdfs:label "Velocidad máxima (S.max)"@es ;
    ns1:documentadoEn ns1:Tabla_Tandem ;
    ns1:textoExtracto "S.max Velocidad máxima."@es ;
    ns1:valor "T.nom"^^rdfs:Literal .

ns1:ErrorPar_Tandem a ns1:Parametro ;
    rdfs:label "Error de par entre motores (T.err)"@es ;
    ns1:documentadoEn ns1:Tabla_Tandem ;
    ns1:textoExtracto "T.err Error de par entre motores. T.err = (–T.mst + T.slv + PRELOAD)"@es .

ns1:Tabla_Tandem a ns1:Tabla ;
    rdfs:label "Tabla TANDEM"@es ;
    ns1:textoExtracto "Parámetro incluido en la tabla TANDEM."@es .

