@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ComponenteElectrico_MotorEsclavo a ns1:ComponenteElectrico ;
    rdfs:label "Motor esclavo (T.slv)" ;
    ns1:textoExtracto "T.slv Par del motor esclavo." ;
    ns1:tieneComponente ns1:SistemaTandem .

ns1:ComponenteElectrico_MotorMaestro a ns1:ComponenteElectrico ;
    rdfs:label "Motor maestro (T.mst)" ;
    ns1:textoExtracto "T.mst Par del motor maestro." ;
    ns1:tieneComponente ns1:SistemaTandem .

ns1:Parametro_Kp a ns1:Parametro ;
    rdfs:label "Ganancia proporcional (Kp)" ;
    ns1:textoExtracto "Kp Ganancia proporcional. Kp = (2000 rpm / 20 Nm) ꞏ 0.1= 10 rpm/Nm." ;
    ns1:valor "10 rpm/Nm"^^xsd:string .

ns1:Parametro_TPROGAIN a ns1:Parametro ;
    rdfs:label "Porcentaje de ganancia proporcional (TPROGAIN)" ;
    ns1:identificador "TPROGAIN" ;
    ns1:textoExtracto "Se define TPROGAIN = 10%." ;
    ns1:valor "10%"^^xsd:string .

ns1:Tabla_TANDEM a ns1:Tabla ;
    rdfs:label "Tabla de parámetros TANDEM" ;
    ns1:textoExtracto "Parámetro incluido en la tabla TANDEM." ;
    ns1:tieneComponente ns1:Parametro_Ki,
        ns1:Parametro_TCOMPLIM .

ns1:Parametro_Ki a ns1:Parametro ;
    rdfs:label "Ganancia integral (Ki)" ;
    ns1:identificador "TINTTIME" ;
    ns1:textoExtracto "Ki Ganancia integral. Valores posibles: De 0 a 65535 milisegundos. Valor por defecto: 0 (no se aplica ganancia integral)." ;
    ns1:valor "0"^^xsd:string .

ns1:Parametro_TCOMPLIM a ns1:Parametro ;
    rdfs:label "Límite de compensación (TCOMPLIM)" ;
    ns1:identificador "TCOMPLIM" ;
    ns1:textoExtracto "TCOMPLIM Pareja tándem. Límite de la compensación. Valores posibles: De 0 a 100%. Valor por defecto: 0 (se deshabilita el eje tándem)." ;
    ns1:valor "0%"^^xsd:string .

ns1:SistemaTandem a ns1:Sistema ;
    rdfs:label "Sistema de eje tándem" ;
    ns1:documentadoEn ns1:Tabla_TANDEM ;
    ns1:monitoreaParametro ns1:Parametro_Ki,
        ns1:Parametro_Kp,
        ns1:Parametro_TCOMPLIM,
        ns1:Parametro_TPROGAIN ;
    ns1:textoExtracto "Ejemplo: Se dispone de un eje tándem con una velocidad máxima de 2000 rpm y un par nominal de 20 Nm." .

