@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ComponenteElectrico_MotorMaestro a ns1:ComponenteElectrico ;
    rdfs:label "Motor maestro (tándem)" ;
    ns1:monitoreaParametro ns1:Parametro_MPG_TCOMPLIM ;
    ns1:textoExtracto "Este parámetro hace referencia al motor maestro. Se define como porcentaje de la velocidad máxima del motor maestro." .

ns1:ModoOperacion_TORQMODE a ns1:ModoOperacion ;
    rdfs:label "Modo de control de par (TORQMODE)" ;
    ns1:textoExtracto "TORQMODE Pareja tándem. Modo de control de par. Valores posibles: Con control de par / Sin control de par." .

ns1:Parametro_MPG_TORQMODE a ns1:Parametro ;
    rdfs:label "MPG.TORQMODE[nb]" ;
    ns1:documentadoEn ns1:Tabla_TANDEM ;
    ns1:identificador "V.MPG.TORQMODE[nb]" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.TORQMODE[nb] Parámetro incluido en la tabla TANDEM. Este parámetro indica si el CNC tiene en cuenta el par para la gestión del tándem. Valores posibles: Con control de par / Sin control de par. Valor por defecto: Con control de par." ;
    ns1:valor "Con control de par"^^xsd:string .

ns1:Parametro_MPG_TCOMPLIM a ns1:Parametro ;
    rdfs:label "MPG.TCOMPLIM[nb]" ;
    ns1:documentadoEn ns1:Tabla_TANDEM ;
    ns1:identificador "V.MPG.TCOMPLIM[nb]" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.TCOMPLIM[nb] Parámetro incluido en la tabla TANDEM. Este parámetro limita la compensación máxima que introduce el tándem. Este límite también se aplica a la integral. Este parámetro hace referencia al motor maestro. Se define como porcentaje de la velocidad máxima del motor maestro. Si se programa con valor \"0\", la salida del control del tándem será cero, lo que implica deshabilitar el tándem." ;
    ns1:valor "0"^^xsd:string .

ns1:Tabla_TANDEM a ns1:Tabla ;
    rdfs:label "Tabla TANDEM" ;
    ns1:textoExtracto "Parámetro incluido en la tabla TANDEM." .

