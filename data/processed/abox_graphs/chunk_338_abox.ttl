@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ParametroDECINPUT a ns1:Parametro ;
    rdfs:label "DECINPUT" ;
    ns1:identificador "DECINPUT" ;
    ns1:textoExtracto "Cuando el eje gantry no disponga de I0 codificado, podrán tener micro de referencia (parámetro DECINPUT) ambos ejes o sólo el eje maestro."@es .

ns1:SistemaEjesGantry a ns1:Sistema ;
    rdfs:label "Sistema de ejes gantry"@es ;
    ns1:detalladoEnEsquema ns1:TablaEjesGantry ;
    ns1:textoExtracto "Se denomina eje gantry a una pareja de ejes que por construcción de la máquina deben desplazarse a la vez y de forma sincronizada."@es ;
    ns1:tieneComponente ns1:EjeGantryEsclavoU,
        ns1:EjeGantryEsclavoW,
        ns1:EjeGantryMaestroX,
        ns1:EjeGantryMaestroZ .

ns1:EjeGantryEsclavoU a ns1:Componente ;
    rdfs:label "Eje gantry esclavo U"@es ;
    ns1:controla ns1:EjeGantryMaestroX ;
    ns1:textoExtracto "eje gantry esclavo (ejemplo: U en X-U). No es programable; es controlado por el CNC."@es .

ns1:EjeGantryEsclavoW a ns1:Componente ;
    rdfs:label "Eje gantry esclavo W"@es ;
    ns1:controla ns1:EjeGantryMaestroZ ;
    ns1:textoExtracto "eje gantry esclavo (ejemplo: W en Z-W). No es programable; es controlado por el CNC."@es .

ns1:TablaEjesGantry a ns1:Tabla ;
    rdfs:label "Tabla de ejes gantry"@es ;
    ns1:documentadoEn ns1:ManualCNC ;
    ns1:textoExtracto "GANTRY Tabla de ejes gantry. Este parámetro muestra la tabla para definir los ejes gantry del sistema."@es .

ns1:EjeGantryMaestroX a ns1:Componente ;
    rdfs:label "Eje gantry maestro X"@es ;
    ns1:monitoreaParametro ns1:ParametroAXISEXCH,
        ns1:ParametroAXISNAME,
        ns1:ParametroAXISTYPE,
        ns1:ParametroDRIVETYPE,
        ns1:ParametroI0TYPE,
        ns1:ParametroLIMIT ;
    ns1:textoExtracto "eje gantry maestro o principal (ejemplo: X en X-U)."@es .

ns1:EjeGantryMaestroZ a ns1:Componente ;
    rdfs:label "Eje gantry maestro Z"@es ;
    ns1:monitoreaParametro ns1:ParametroAXISEXCH,
        ns1:ParametroAXISNAME,
        ns1:ParametroAXISTYPE,
        ns1:ParametroDRIVETYPE,
        ns1:ParametroI0TYPE,
        ns1:ParametroLIMIT ;
    ns1:textoExtracto "eje gantry maestro o principal (ejemplo: Z en Z-W)."@es .

ns1:ParametroAXISEXCH a ns1:Parametro ;
    rdfs:label "AXISEXCH" ;
    ns1:identificador "AXISEXCH" ;
    ns1:textoExtracto "El permiso de cambio de canal (parámetro AXISEXCH) deberá ser igual en ambos ejes."@es .

ns1:ParametroAXISNAME a ns1:Parametro ;
    rdfs:label "AXISNAME" ;
    ns1:identificador "AXISNAME" ;
    ns1:textoExtracto "El eje maestro tiene que estar definido en la tabla de AXISNAME antes que el eje esclavo."@es ;
    ns1:valor "Definición de nombre de eje en tabla"@es .

ns1:ParametroAXISTYPE a ns1:Parametro ;
    rdfs:label "AXISTYPE" ;
    ns1:identificador "AXISTYPE" ;
    ns1:textoExtracto "Ambos ejes deberán ser del mismo tipo (parámetros AXISTYPE y DRIVETYPE iguales para ambos ejes)."@es .

ns1:ParametroDRIVETYPE a ns1:Parametro ;
    rdfs:label "DRIVETYPE" ;
    ns1:identificador "DRIVETYPE" ;
    ns1:textoExtracto "Ambos ejes deberán ser del mismo tipo (parámetros AXISTYPE y DRIVETYPE iguales para ambos ejes)."@es .

ns1:ParametroI0TYPE a ns1:Parametro ;
    rdfs:label "I0TYPE" ;
    ns1:identificador "I0TYPE" ;
    ns1:textoExtracto "El tipo de I0 (parámetro I0TYPE) deberá ser en ambos ejes no codificado o en ambos ejes codificado (creciente o decreciente)."@es .

ns1:ParametroLIMIT a ns1:Parametro ;
    rdfs:label "LIMIT+",
        "LIMIT-" ;
    ns1:identificador "LIMIT+",
        "LIMIT-" ;
    ns1:textoExtracto "Ambos ejes deberán tener los mismos límites de software (parámetros LIMIT+ y LIMIT- iguales para ambos ejes)."@es .

