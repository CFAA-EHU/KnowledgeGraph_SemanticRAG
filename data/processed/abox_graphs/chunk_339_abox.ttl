@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_DECINPUT_78 a ns1:Parametro ;
    rdfs:label "Micro de referencia (DECINPUT)"@es ;
    ns1:identificador "DECINPUT" ;
    ns1:monitoreaParametro ns1:ConfiguracionEjesGantry_78 ;
    ns1:textoExtracto "podrán tener micro de referencia (parámetro DECINPUT) ambos ejes o sólo el eje maestro."@es .

ns1:Parametro_REFFEED1_78 a ns1:Parametro ;
    rdfs:label "Velocidad rápida de búsqueda de referencia (REFFEED1)"@es ;
    ns1:identificador "REFFEED1" ;
    ns1:monitoreaParametro ns1:ConfiguracionEjesGantry_78 ;
    ns1:textoExtracto "La velocidad rápida y lenta de búsqueda de referencia máquina (parámetros REFFEED1 y REFFEED2) deberá ser igual en ambos ejes."@es .

ns1:Parametro_REFFEED2_78 a ns1:Parametro ;
    rdfs:label "Velocidad lenta de búsqueda de referencia (REFFEED2)"@es ;
    ns1:identificador "REFFEED2" ;
    ns1:monitoreaParametro ns1:ConfiguracionEjesGantry_78 ;
    ns1:textoExtracto "La velocidad rápida y lenta de búsqueda de referencia máquina (parámetros REFFEED1 y REFFEED2) deberá ser igual en ambos ejes."@es .

ns1:TablaParametrosGantry_78 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros para ejes gantry"@es ;
    ns1:documentadoEn ns1:ConfiguracionEjesGantry_78 ;
    ns1:textoExtracto "Este parámetro muestra la tabla de parámetros para definir los ejes gantry del sistema."@es .

ns1:ConfiguracionEjesGantry_78 a ns1:Sistema ;
    rdfs:label "Configuración de ejes gantry"@es ;
    ns1:textoExtracto "GANTRY n Configuración de los ejes gantry. Este parámetro muestra la tabla de parámetros para definir los ejes gantry del sistema."@es ;
    ns1:tieneComponente ns1:Parametro_DECINPUT_78,
        ns1:Parametro_REFFEED1_78,
        ns1:Parametro_REFFEED2_78,
        ns1:TablaParametrosGantry_78 .

