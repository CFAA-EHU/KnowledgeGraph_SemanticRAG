@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ParametroMaquina_Gantry_79 a ns1:Parametro ;
    rdfs:label "Parámetro máquina para configuración gantry"@es ;
    ns1:monitoreaParametro ns1:ConfiguracionEjesGantry_79 ;
    ns1:textoExtracto "Cada uno de los ejes gantry dispone de los siguientes parámetros máquina para su configuración"@es .

ns1:TablaParametrosGantry_79 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros para ejes gantry"@es ;
    ns1:documentadoEn ns1:ConfiguracionEjesGantry_79 ;
    ns1:textoExtracto "tabla de parámetros para definir los ejes gantry del sistema"@es .

ns1:ConfiguracionEjesGantry_79 a ns1:Sistema ;
    rdfs:label "Configuración de ejes gantry"@es ;
    ns1:textoExtracto "GANTRY n Configuración de los ejes gantry. Este parámetro muestra la tabla de parámetros para definir los ejes gantry del sistema."@es ;
    ns1:tieneComponente ns1:ParametroMaquina_Gantry_79,
        ns1:TablaParametrosGantry_79 .

