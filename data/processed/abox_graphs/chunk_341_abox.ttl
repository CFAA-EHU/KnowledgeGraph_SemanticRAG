@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:configuracionEjeGantry a ns1:Sistema ;
    rdfs:label "Configuración de un eje gantry"@es ;
    ns1:textoExtracto "MASTERAXIS | Eje maestro o principal. SLAVEAXIS | Eje esclavo. WARNCOUPE | Diferencia entre el error de seguimiento de ambos ejes para mostrar un warning."@es ;
    ns1:tieneComponente ns1:masterAxis,
        ns1:parametroWarnCoupe,
        ns1:slaveAxis .

ns1:parametroWarnCoupe a ns1:Parametro ;
    rdfs:label "WARNCOUPE"@es ;
    ns1:identificador "WARNCOUPE" ;
    ns1:monitoreaParametro ns1:masterAxis,
        ns1:slaveAxis ;
    ns1:textoExtracto "Diferencia entre el error de seguimiento de ambos ejes para mostrar un warning."@es .

ns1:masterAxis a ns1:Componente ;
    rdfs:label "MASTERAXIS"@es ;
    ns1:identificador "MASTERAXIS" ;
    ns1:textoExtracto "Eje maestro o principal."@es .

ns1:slaveAxis a ns1:Componente ;
    rdfs:label "SLAVEAXIS"@es ;
    ns1:identificador "SLAVEAXIS" ;
    ns1:textoExtracto "Eje esclavo."@es .

