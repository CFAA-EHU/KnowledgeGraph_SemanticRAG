@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_ConfiguracionGantry a ns1:Tabla ;
    rdfs:label "Tabla de configuración de parámetros GANTRY" ;
    ns1:textoExtracto "GANTRY | | MAXCOUPE | Diferencia entre el error de seguimiento de ambos ejes para mostrar un warning. | DIFFCOMP | Compensar la diferencia de cota entre ambos ejes tras G74. | MAXDIFF | Máxima diferencia de cota permitid..." ;
    ns1:tieneComponente ns1:Parametro_GANTRY_DIFFCOMP,
        ns1:Parametro_GANTRY_MAXCOUPE,
        ns1:Parametro_GANTRY_MAXDIFF .

ns1:Parametro_GANTRY_DIFFCOMP a ns1:Parametro ;
    rdfs:label "DIFFCOMP" ;
    ns1:textoExtracto "Compensar la diferencia de cota entre ambos ejes tras G74." ;
    ns1:valor "Compensación de diferencia de cota" .

ns1:Parametro_GANTRY_MAXCOUPE a ns1:Parametro ;
    rdfs:label "MAXCOUPE" ;
    ns1:textoExtracto "Diferencia entre el error de seguimiento de ambos ejes para mostrar un warning." ;
    ns1:valor "Diferencia entre el error de seguimiento de ambos ejes" .

ns1:Parametro_GANTRY_MAXDIFF a ns1:Parametro ;
    rdfs:label "MAXDIFF" ;
    ns1:textoExtracto "Máxima diferencia de cota permitida entre ambos ejes para poder compensarla." ;
    ns1:valor "Máxima diferencia de cota permitida" .

