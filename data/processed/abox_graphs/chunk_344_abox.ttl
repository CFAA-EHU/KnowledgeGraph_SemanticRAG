@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_DIFFCOMP a ns1:Parametro ;
    rdfs:label "MPG.DIFFCOMP[nb]" ;
    ns1:controla ns1:Sistema_GANTRY ;
    ns1:documentadoEn ns1:Tabla_GANTRY ;
    ns1:identificador "MPG.DIFFCOMP[nb]" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.DIFFCOMP[nb] [...] Este parámetro habilita la corrección de la diferencia de cota entre el eje gantry." ;
    ns1:valor "Sí / No" .

ns1:Parametro_MAXCOUPLE a ns1:Parametro ;
    rdfs:label "MPG.MAXCOUPE[nb]" ;
    ns1:documentadoEn ns1:Tabla_GANTRY ;
    ns1:identificador "MPG.MAXCOUPE[nb]" ;
    ns1:monitoreaParametro ns1:Sistema_GANTRY ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.MAXCOUPE[nb] [...] Este parámetro indica la máxima diferencia permitida entre los errores de seguimiento de ambos ejes." ;
    ns1:valor "0 a 3937.00787 inch (lineal) / 0.0001 a 99999.9999 grados (angular)" .

ns1:ValorDefecto_DIFFCOMP a ns1:Parametro ;
    rdfs:label "Valor por defecto de MPG.DIFFCOMP[nb]" ;
    ns1:documentadoEn ns1:Tabla_GANTRY ;
    ns1:textoExtracto "Valor por defecto: Sí." ;
    ns1:valor "Sí" .

ns1:ValorDefecto_MAXCOUPLE a ns1:Parametro ;
    rdfs:label "Valor por defecto de MPG.MAXCOUPE[nb]" ;
    ns1:documentadoEn ns1:Tabla_GANTRY ;
    ns1:textoExtracto "Valor por defecto: 1.0000 mm / 0.03937 inch / 1.0000 grado." ;
    ns1:valor "1.0000 mm / 0.03937 inch / 1.0000 grado" .

ns1:Sistema_GANTRY a ns1:Sistema ;
    rdfs:label "Eje gantry" ;
    ns1:textoExtracto "DIFFCOMP Eje gantry. Compensar la diferencia de cota entre ambos ejes tras G74." .

ns1:Tabla_GANTRY a ns1:Tabla ;
    rdfs:label "Tabla GANTRY" ;
    ns1:identificador "GANTRY" ;
    ns1:textoExtracto "Parámetro incluido en la tabla GANTRY." .

