@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_EjeGantry a ns1:Sistema ;
    rdfs:label "Sistema de eje gantry (maestro-esclavo)"@es ;
    ns1:compuestoPor ns1:Parametro_DIFFCOMP,
        ns1:Parametro_MAXDIFF,
        ns1:Parametro_REFFEED2 ;
    ns1:documentadoEn ns1:Tabla_GANTRY ;
    ns1:textoExtracto "En ejes con captación absoluta, si el parámetro DIFFCOMP está a 'Sí', el CNC corregirá la diferencia de cota al habilitar el eje (flanco de subida de la marca SERVOxnON del eje maestro o del esclavo)."@es .

ns1:Parametro_DIFFCOMP a ns1:Parametro ;
    rdfs:label "Parámetro DIFFCOMP (corrección de diferencia de cota en eje gantry)"@es ;
    ns1:documentadoEn ns1:Tabla_GANTRY ;
    ns1:identificador "MPG.DIFFCOMP[nb]" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.DIFFCOMP[nb]. Este parámetro habilita la corrección de la diferencia de cota entre el eje maestro y el esclavo tras la búsqueda de referencia máquina."@es ;
    ns1:valor "Sí" .

ns1:Parametro_MAXDIFF a ns1:Parametro ;
    rdfs:label "Parámetro MAXDIFF (diferencia máxima de cota permitida)"@es ;
    ns1:documentadoEn ns1:Tabla_GANTRY ;
    ns1:identificador "MAXDIFF" ;
    ns1:textoExtracto "MAXDIFF Eje gantry. Máxima diferencia de cota permitida entre ambos ejes para poder compensarla. Valores posibles: De 0 a 99999.9999 mm."@es ;
    ns1:valor "99999.9999" .

ns1:Parametro_REFFEED2 a ns1:Parametro ;
    rdfs:label "Parámetro REFFEED2 (avance para compensación de cota)"@es ;
    ns1:documentadoEn ns1:Tabla_GANTRY ;
    ns1:identificador "REFFEED2" ;
    ns1:textoExtracto "El eje esclavo se moverá hasta alcanzar la cota del eje maestro, al avance especificado en el parámetro REFFEED2."@es .

ns1:Tabla_GANTRY a ns1:Tabla ;
    rdfs:label "Tabla GANTRY (configuración de ejes gantry)"@es ;
    ns1:textoExtracto "Parámetro incluido en la tabla GANTRY."@es .

