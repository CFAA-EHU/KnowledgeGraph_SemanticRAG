@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_MPG_MAXDIFF_nb a ns1:Parametro ;
    rdfs:label "Máxima diferencia de cota permitida entre ejes gantry"@es ;
    ns1:identificador "MPG.MAXDIFF[nb]" ;
    ns1:monitoreaParametro ns1:Sistema_Gantry ;
    ns1:textoExtracto "Máxima diferencia de cota permitida entre ambos ejes para poder compensarla. [...] Variable asociada: (V.)MPG.MAXDIFF[nb]"@es ;
    ns1:valor "0"^^xsd:string .

ns1:Sistema_Gantry a ns1:Sistema ;
    rdfs:label "Sistema de configuración de eje gantry"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_Gantry ;
    ns1:textoExtracto "Para evitar corregir diferencias de cota excesivas entre el eje maestro y el esclavo, este parámetro establece la máxima diferencia de cota permitida entre ambos ejes para poder aplicar la corrección."@es .

ns1:Tabla_Gantry a ns1:Tabla ;
    rdfs:label "Tabla de parámetros GANTRY"@es ;
    ns1:documentadoEn ns1:Manual_CNC ;
    ns1:textoExtracto "Parámetro incluido en la tabla GANTRY."@es .

