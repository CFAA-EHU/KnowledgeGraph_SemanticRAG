@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Pagina_64_65 a ns1:Pagina ;
    ns1:identificador "64-65" ;
    ns1:textoExtracto "2.3.5 Configuración de un grupo multieje"@es .

ns1:ParametroGrupos_86 a ns1:Parametro ;
    rdfs:label "Número de grupos del sistema"@es ;
    ns1:documentadoEn ns1:TablaGruposMultieje_86 ;
    ns1:textoExtracto "el número de grupos del sistema y la composición de cada grupo"@es .

ns1:ReguladorMultieje_86 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador multieje"@es ;
    ns1:textoExtracto "un único regulador"@es .

ns1:SistemaMultieje_86 a ns1:Sistema ;
    rdfs:label "Sistema de grupos multieje"@es ;
    ns1:compuestoPor ns1:ParametroGrupos_86 ;
    ns1:textoExtracto "Un grupo multieje permite controlar varios ejes con un único regulador, controlando uno o varios motores."@es ;
    ns1:tieneComponente ns1:ReguladorMultieje_86 .

ns1:TablaGruposMultieje_86 a ns1:Tabla ;
    rdfs:label "Tabla de grupos multieje"@es ;
    ns1:detalladoEnEsquema ns1:SistemaMultieje_86 ;
    ns1:documentadoEn ns1:Pagina_64_65 ;
    ns1:textoExtracto "Tabla de grupos multieje. Un grupo multieje permite controlar varios ejes con un único regulador, controlando uno o varios motores. Este parámetro muestra la tabla de definición de los grupos multieje, donde hay que definir el número de grupos del sistema y la composición de cada grupo."@es .

