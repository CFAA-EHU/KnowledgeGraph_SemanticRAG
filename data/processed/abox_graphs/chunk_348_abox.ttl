@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_ConfiguracionMultieje a ns1:Tabla ;
    rdfs:label "Tabla de configuración multieje (páginas 64-65)" ;
    ns1:documentadoEn ns1:Sistema_Multieje ;
    ns1:textoExtracto "| MULTIAXIS |  | --- | --- | MULNGROUPS | Número de grupos multieje en el sistema. | GROUP n | Grupos multieje. |" .

ns1:Parametro_GROUP_n a ns1:Parametro ;
    rdfs:label "GROUP n" ;
    ns1:textoExtracto "GROUP n | Grupos multieje." ;
    ns1:valor "Identificador de grupo multieje" .

ns1:Parametro_MULNGROUPS a ns1:Parametro ;
    rdfs:label "MULNGROUPS" ;
    ns1:textoExtracto "MULNGROUPS | Número de grupos multieje en el sistema." ;
    ns1:valor "Número de grupos multieje" .

ns1:Sistema_Multieje a ns1:Sistema ;
    rdfs:label "Sistema multieje" ;
    ns1:textoExtracto "Configuración de un grupo multieje" ;
    ns1:tieneComponente ns1:Parametro_GROUP_n,
        ns1:Parametro_MULNGROUPS .

