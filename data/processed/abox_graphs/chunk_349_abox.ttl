@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CaptacionExterna a ns1:ComponenteElectrico ;
    rdfs:label "Captación externa (directa)" ;
    ns1:textoExtracto "Si la captación externa (captación directa) del eje está conectada a un regulador, el eje podrá operar en modo Sercos posición o Sercos velocidad." .

ns1:EntradaContaje_Local a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de contaje local" ;
    ns1:textoExtracto "Si la captación externa (captación directa) del eje está conectada a una entrada de contaje local o remota, el eje sólo podrá operar en modo Sercos velocidad." .

ns1:EntradaContaje_Remota a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de contaje remota" ;
    ns1:textoExtracto "Si la captación externa (captación directa) del eje está conectada a una entrada de contaje local o remota, el eje sólo podrá operar en modo Sercos velocidad." .

ns1:ModoOperacion_Posicion a ns1:ModoOperacion ;
    rdfs:label "Modo Sercos posición" ;
    ns1:textoExtracto "modo Sercos posición" .

ns1:ModoOperacion_Velocidad a ns1:ModoOperacion ;
    rdfs:label "Modo Sercos velocidad" ;
    ns1:textoExtracto "modo Sercos velocidad" .

ns1:Regulador_Sercos a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos" ;
    ns1:controla ns1:GrupoMultieje_Sercos ;
    ns1:monitoreaParametro ns1:Parametro_DRIVEID,
        ns1:Parametro_OPMODEP ;
    ns1:textoExtracto "Los ejes asociados a un mismo regulador deben cumplir los siguientes requisitos." .

ns1:GrupoMultieje_Sercos a ns1:Sistema ;
    rdfs:label "Grupo multieje Sercos" ;
    ns1:textoExtracto "Requisitos y limitaciones de un grupo multieje. Los ejes asociados a un mismo regulador deben cumplir los siguientes requisitos." .

ns1:Parametro_DRIVEID a ns1:Parametro ;
    rdfs:label "DRIVEID (dirección Sercos)" ;
    ns1:textoExtracto "todos los ejes de un grupo deben tener la misma dirección Sercos (parámetro DRIVEID)" ;
    ns1:valor "DRIVEID" .

ns1:Parametro_OPMODEP a ns1:Parametro ;
    rdfs:label "OPMODEP (modo de operación Sercos)" ;
    ns1:textoExtracto "Todos los ejes de un grupo deben trabajar en el mismo modo de operación Sercos, posición o velocidad (parámetro OPMODEP)" ;
    ns1:valor "OPMODEP" .

