@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC_89 a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:controla ns1:MotorMultieje_89,
        ns1:Parametro_DWELL_89,
        ns1:Parametro_SWITCH_89,
        ns1:Regulador_89 ;
    ns1:textoExtracto "el CNC ejecuta la búsqueda de referencia como si el eje fuera analógico [...] el CNC permite realizar una gestión dinámica del multieje."@es .

ns1:PLC_89 a ns1:Sistema ;
    rdfs:label "PLC de control de ejes"@es ;
    ns1:controla ns1:Parametro_SWITCH_89,
        ns1:Regulador_89 ;
    ns1:textoExtracto "La selección del eje que gobierna el regulador se realiza desde el PLC (marca SWITCH(axis)). El PLC debe aparcar o poner como visualizador los ejes que no gobierna el regulador."@es .

ns1:Parametro_Cota_89 a ns1:Parametro ;
    rdfs:label "Cota de referencia del eje"@es ;
    ns1:textoExtracto "el regulador [...] no actualiza su cota, sólo recibe consigna de velocidad."@es .

ns1:ConfiguracionMultieje_89 a ns1:ModoOperacion ;
    rdfs:label "Configuración de grupo multieje"@es ;
    ns1:textoExtracto "Si la captación externa es local o remota, el CNC ejecuta la búsqueda de referencia como si el eje fuera analógico; el regulador desconoce que hay una búsqueda de referencia en marcha y no actualiza su cota, sólo recibe consigna de velocidad. [...] Para un multieje donde el mismo motor controla varios ejes, el CNC permite realizar una gestión dinámica del multieje."@es ;
    ns1:tieneComponente ns1:CNC_89,
        ns1:MotorMultieje_89,
        ns1:PLC_89,
        ns1:Parametro_DWELL_89,
        ns1:Parametro_SWITCH_89,
        ns1:Regulador_89 .

ns1:MotorMultieje_89 a ns1:ComponenteElectrico ;
    rdfs:label "Motor de grupo multieje"@es ;
    ns1:controla ns1:ConfiguracionMultieje_89 ;
    ns1:textoExtracto "Para un multieje donde el mismo motor controla varios ejes, el CNC permite realizar una gestión dinámica del multieje."@es .

ns1:Parametro_DWELL_89 a ns1:Parametro ;
    rdfs:label "Parámetro DWELL"@es ;
    ns1:identificador "DWELL" ;
    ns1:monitoreaParametro ns1:ConfiguracionMultieje_89 ;
    ns1:textoExtracto "Los ejes utilizan el parámetro DWELL como tiempo de espera antes de dar error por no tener la marca SWITCH activa."@es ;
    ns1:valor ">0" .

ns1:Parametro_SWITCH_89 a ns1:Parametro ;
    rdfs:label "Parámetro SWITCH(axis)"@es ;
    ns1:identificador "SWITCH(axis)" ;
    ns1:textoExtracto "La selección del eje que gobierna el regulador se realiza desde el PLC (marca SWITCH(axis))."@es .

ns1:Regulador_89 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador de eje"@es ;
    ns1:monitoreaParametro ns1:Parametro_Cota_89 ;
    ns1:textoExtracto "el regulador desconoce que hay una búsqueda de referencia en marcha y no actualiza su cota, sólo recibe consigna de velocidad."@es .

