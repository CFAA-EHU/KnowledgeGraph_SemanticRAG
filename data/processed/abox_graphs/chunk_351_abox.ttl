@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ControlEjes a ns1:Sistema ;
    rdfs:label "Sistema de control de ejes multieje"@es ;
    ns1:controla ns1:Marca_DRENA,
        ns1:Marca_ENABLE,
        ns1:Marca_SERVOON,
        ns1:Marca_SPENA,
        ns1:Marca_SWITCH ;
    ns1:textoExtracto "Los ejes utilizan el parámetro DWELL como tiempo de espera antes de dar error por no tener la marca SWITCH activa. El PLC vigila qué marca ENABLE se activa, para engranar ese eje y activar su marca SWITCH, SERVOON, SPENA y DRENA."@es ;
    ns1:tieneComponente ns1:Parametro_DWELL .

ns1:Marca_DRENA a ns1:InterfazUsuario ;
    rdfs:label "Marca DRENA"@es ;
    ns1:textoExtracto "activar su marca [...] DRENA"@es .

ns1:Marca_ENABLE a ns1:InterfazUsuario ;
    rdfs:label "Marca ENABLE"@es ;
    ns1:textoExtracto "El PLC vigila qué marca ENABLE se activa, para engranar ese eje"@es .

ns1:Marca_SERVOON a ns1:InterfazUsuario ;
    rdfs:label "Marca SERVOON"@es ;
    ns1:textoExtracto "activar su marca [...] SERVOON"@es .

ns1:Marca_SPENA a ns1:InterfazUsuario ;
    rdfs:label "Marca SPENA"@es ;
    ns1:textoExtracto "activar su marca [...] SPENA"@es .

ns1:Marca_SWITCH a ns1:InterfazUsuario ;
    rdfs:label "Marca SWITCH"@es ;
    ns1:textoExtracto "parámetro DWELL como tiempo de espera antes de dar error por no tener la marca SWITCH activa"@es .

ns1:Parametro_DWELL a ns1:Parametro ;
    rdfs:label "Parámetro DWELL"@es ;
    ns1:textoExtracto "Los ejes utilizan el parámetro DWELL como tiempo de espera antes de dar error por no tener la marca SWITCH activa."@es ;
    ns1:valor "tiempo de espera"@es .

