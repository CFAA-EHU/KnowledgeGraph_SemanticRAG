@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_GruposMultieje a ns1:Sistema ;
    rdfs:label "Sistema de grupos multieje" ;
    ns1:textoExtracto "El PLC vigila qué marca ENABLE se activa, para engranar ese eje y activar su marca SWITCH, SERVOON, SPENA y DRENA. • El CNC mantiene la vigilancia (error de seguimiento, test de tendencia, etc) de todos los ejes que comparten el regulador, aunque el eje no esté seleccionado." ;
    ns1:tieneComponente ns1:Parametro_GROUP_n,
        ns1:Parametro_MULNGROUP .

ns1:Parametro_GROUP_n a ns1:Parametro ;
    rdfs:label "GROUP_n" ;
    ns1:documentadoEn ns1:Tabla_MULTIAXIS ;
    ns1:textoExtracto "La tabla muestra un parámetro GROUP_n por cada grupo multieje, el cuál contiene los siguientes parámetros máquina para la configuración de los grupos." .

ns1:Parametro_MULNGROUP a ns1:Parametro ;
    rdfs:label "MULNGROUP" ;
    ns1:documentadoEn ns1:Tabla_MULTIAXIS ;
    ns1:identificador "MPG.MULNGROUP" ;
    ns1:textoExtracto "MULNGROUP Número de grupos multieje en el sistema. Valores posibles: De 0 a 16. Valor por defecto: 0. Variable asociada: (V.)MPG.MULNGROUP" ;
    ns1:valor "0" .

ns1:Tabla_MULTIAXIS a ns1:Tabla ;
    rdfs:label "Tabla MULTIAXIS" ;
    ns1:textoExtracto "Parámetro incluido en la tabla MULTIAXIS. Este parámetro establece el número de grupos multieje del sistema. GROUP n Grupos multieje. Este parámetro muestra la tabla de parámetros para definir cada grupo multieje." .

