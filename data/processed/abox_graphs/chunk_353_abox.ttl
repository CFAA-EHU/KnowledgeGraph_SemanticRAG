@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:textoExtracto "Los sets de parámetros del regulador estarán repartidos entre todos los ejes y/o cabezales que forman el grupo multieje, de manera que un grupo podrá estar formado por 8 ejes con 1 set de parámetros cada uno, con un cabezal con 4 sets más 2 ejes con 2 sets cada uno, etc."@es ;
    ns1:tieneComponente ns1:Parametro_KEEPPOS,
        ns1:Parametro_MULNAXIS,
        ns1:Parametro_MULNAXISNAME .

ns1:Variable_V_MPG_MULAXISNAME a ns1:Parametro ;
    rdfs:label "(V.)MPG.MULAXISNAMExn[nb]"@es ;
    ns1:identificador "V_MPG_MULAXISNAME" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.MULAXISNAMExn[nb]"@es .

ns1:Variable_V_MPG_MULNAXIS a ns1:Parametro ;
    rdfs:label "(V.)MPG.MULNAXIS[nb]"@es ;
    ns1:identificador "V_MPG_MULNAXIS" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.MULNAXIS[nb]"@es .

ns1:Parametro_KEEPPOS a ns1:Parametro ;
    rdfs:label "KEEPPOS"@es ;
    ns1:documentadoEn ns1:Tabla_MULTIAXIS ;
    ns1:identificador "KEEPPOS" ;
    ns1:textoExtracto "KEEPPOS n: El eje desactivado mantiene su cota independientemente del eje activo."@es .

ns1:Parametro_MULNAXIS a ns1:Parametro ;
    rdfs:label "MULNAXIS"@es ;
    ns1:documentadoEn ns1:Tabla_MULTIAXIS ;
    ns1:identificador "MULNAXIS" ;
    ns1:textoExtracto "MULNAXIS Número de ejes y/o cabezales que forman el grupo multieje. Valores posibles: De 2 a 8. Valor por defecto: 2."@es ;
    ns1:valor "2" .

ns1:Parametro_MULNAXISNAME a ns1:Parametro ;
    rdfs:label "MULNAXISNAME"@es ;
    ns1:documentadoEn ns1:Tabla_MULTIAXIS ;
    ns1:identificador "MULNAXISNAME" ;
    ns1:textoExtracto "MULNAXISNAME n: Nombre de los ejes y/o cabezales del grupo. Valores posibles: Cualquier eje Sercos del sistema, excepto ejes tándem o gantry."@es .

ns1:Tabla_MULTIAXIS a ns1:Tabla ;
    rdfs:label "Tabla MULTIAXIS"@es ;
    ns1:identificador "MULTIAXIS" ;
    ns1:textoExtracto "Parámetro incluido en la tabla MULTIAXIS // GROUP n."@es .

