@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_GrupoMultieje a ns1:Sistema ;
    rdfs:label "Sistema de grupo multieje" ;
    ns1:monitoreaParametro ns1:Parametro_KEEPPOS_n ;
    ns1:textoExtracto "El primer eje del grupo será el eje maestro, el que por defecto utilizará el regulador; el orden del resto de los ejes no es relevante. En el arranque del sistema, el CNC utilizará los parámetros del eje maestro para realizar la homogeneización de parámetros con el regulador."@es .

ns1:Variable_MPG_KEEPPOSxn a ns1:Parametro ;
    rdfs:label "(V.)MPG.KEEPPOSxn[nb]" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.KEEPPOSxn[nb]."@es .

ns1:Parametro_KEEPPOS_n a ns1:Parametro ;
    rdfs:label "KEEPPOS n" ;
    ns1:documentadoEn ns1:Tabla_MULTIAXIS_GROUP_n ;
    ns1:textoExtracto "KEEPPOS n. El eje desactivado mantiene su cota independientemente del eje activo. Valores posibles: Sí / No. Valor por defecto: No."@es ;
    ns1:valor "No" .

ns1:Tabla_MULTIAXIS_GROUP_n a ns1:Tabla ;
    rdfs:label "Tabla MULTIAXIS // GROUP n" ;
    ns1:textoExtracto "Parámetro incluido en la tabla MULTIAXIS // GROUP n. Para un grupo multieje, este parámetro define si el eje desactivado mantiene o no la cota, cuando se mueve el eje activo."@es .

