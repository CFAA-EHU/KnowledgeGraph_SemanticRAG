@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_SPDLNAME_n a ns1:Parametro ;
    rdfs:label "SPDLNAME n" ;
    ns1:documentadoEn ns1:Tabla_SPDLNAME ;
    ns1:identificador "SPDLNAME_n" ;
    ns1:textoExtracto "SPDLNAME n Nombre de los cabezales. Valores posibles: S, S1ꞏꞏS9. Valor por defecto: Comenzando por SPDLNAME1; S, S1... Variable asociada: (V.)MPG.SPDLNAMEn Parámetro incluido en la tabla SPDLNAME." ;
    ns1:valor "S" .

ns1:Sistema_Cabezales a ns1:Sistema ;
    rdfs:label "Sistema de cabezales" ;
    ns1:textoExtracto "Un canal podrá tener asociado uno, varios o ningún cabezal. [...] La numeración lógica de cabezales continúa a partir del último eje lógico; así, en un sistema con 3 ejes, el primer cabezal de la tabla será el cabezal lógico ꞏ4ꞏ y así sucesivamente." ;
    ns1:tieneComponente ns1:Parametro_NSPDL,
        ns1:Tabla_SPDLNAME .

ns1:Parametro_NSPDL a ns1:Parametro ;
    rdfs:label "NSPDL" ;
    ns1:identificador "NSPDL" ;
    ns1:textoExtracto "NSPDL Número de cabezales que gobierna el CNC. Valores posibles: De 0 a 6. Valor por defecto: 1. Variable asociada: (V.)MPG.NSPDL Este parámetro establece el número de cabezales del sistema, estén servocontrolados o no." ;
    ns1:valor "1" .

ns1:Tabla_SPDLNAME a ns1:Tabla ;
    rdfs:label "Tabla SPDLNAME" ;
    ns1:identificador "SPDLNAME" ;
    ns1:textoExtracto "SPDLNAME Lista de cabezales del sistema. Este parámetro muestra la tabla para definir los nombres de los cabezales. El número de cabezales del sistema lo establece el parámetro NSPDL." .

