@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaEjesCabezales_96 a ns1:Sistema ;
    rdfs:label "Sistema de ejes y cabezales"@es ;
    ns1:compuestoPor ns1:Cabezal1_96,
        ns1:Eje1_96,
        ns1:Eje2_96,
        ns1:Eje3_96 ;
    ns1:documentadoEn ns1:TablaConfiguracionCabezales_96 ;
    ns1:textoExtracto "La numeración lógica de cabezales continúa a partir del último eje lógico; así, en un sistema con 3 ejes, el primer cabezal de la tabla será el cabezal lógico ꞏ4ꞏ y así sucesivamente."@es .

ns1:Cabezal1_96 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal lógico 4"@es ;
    ns1:identificador "SPDLNAME 1" ;
    ns1:textoExtracto "SPDLNAME 1 | Número lógico ꞏ4ꞏ."@es .

ns1:Eje1_96 a ns1:ComponenteMecanico ;
    rdfs:label "Eje lógico 1"@es ;
    ns1:identificador "AXISNAME 1" ;
    ns1:textoExtracto "AXISNAME 1 |  | Número lógico ꞏ1ꞏ."@es .

ns1:Eje2_96 a ns1:ComponenteMecanico ;
    rdfs:label "Eje lógico 2"@es ;
    ns1:identificador "AXISNAME 2" ;
    ns1:textoExtracto "AXISNAME 2 |  | Número lógico ꞏ2ꞏ."@es .

ns1:Eje3_96 a ns1:ComponenteMecanico ;
    rdfs:label "Eje lógico 3"@es ;
    ns1:identificador "AXISNAME 3" ;
    ns1:textoExtracto "AXISNAME 3 |  | Número lógico ꞏ3ꞏ."@es .

ns1:TablaConfiguracionCabezales_96 a ns1:Tabla ;
    rdfs:label "Tabla de configuración lógica de cabezales"@es ;
    ns1:identificador "2.3.6_ConfiguracionCabezales" ;
    ns1:textoExtracto "AXISNAME | SPDLNAME | Orden lógico. | --- | --- | --- | AXISNAME 1 |  | Número lógico ꞏ1ꞏ. | AXISNAME 2 |  | Número lógico ꞏ2ꞏ. | AXISNAME 3 |  | Número lógico ꞏ3ꞏ. |  | SPDLNAME 1 | Número lógico ꞏ4ꞏ."@es .

