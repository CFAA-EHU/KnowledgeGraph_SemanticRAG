@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:monitoreaParametro ns1:Parametro_LOOPTIME ;
    ns1:textoExtracto "El tiempo de muestreo está condicionado en gran medida por la topología del bus, el número total de entradas y salidas y el número de ejes analógicos." .

ns1:Tabla_ValoresOrientativos_LOOPTIME a ns1:Tabla ;
    rdfs:label "Valores orientativos para LOOPTIME" ;
    ns1:documentadoEn ns1:Pagina_68 ;
    ns1:textoExtracto "Usar como valores orientativos, los siguientes:" .

ns1:Parametro_LOOPTIME a ns1:Parametro ;
    rdfs:label "LOOPTIME" ;
    ns1:identificador "MPG.LOOPTIME" ;
    ns1:textoExtracto "LOOPTIME Tiempo de ciclo del CNC. Valores posibles: De 1 a 20 ms. Valor por defecto: 4 ms. Variable asociada: (V.)MPG.LOOPTIME" ;
    ns1:valor 4 .

