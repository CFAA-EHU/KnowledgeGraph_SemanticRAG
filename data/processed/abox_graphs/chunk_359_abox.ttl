@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:TablaTiemposEjesAnalogicos a ns1:Tabla ;
    rdfs:label "Tabla de tiempos de ciclo según número de ejes analógicos"@es ;
    ns1:textoExtracto "| LOOPTIME | Número de ejes analógicos. | --- | --- | 4 ms. | Hasta 8 ejes analógicos. | 5 ms. | Hasta 12 ejes analógicos. | 6 ms. | Hasta 16 ejes analógicos. | 8 ms. | Hasta 20 ejes analógicos. | 10 ms. | Hasta 24 ejes analógicos. |"@es ;
    ns1:tieneComponente ns1:Parametro_10ms_24ejes,
        ns1:Parametro_4ms_8ejes,
        ns1:Parametro_5ms_12ejes,
        ns1:Parametro_6ms_16ejes,
        ns1:Parametro_8ms_20ejes .

ns1:Parametro_10ms_24ejes a ns1:Parametro ;
    rdfs:label "LoopTime 10 ms (hasta 24 ejes analógicos)"@es ;
    ns1:identificador "LOOPTIME_10ms" ;
    ns1:textoExtracto "10 ms. | Hasta 24 ejes analógicos."@es ;
    ns1:valor 10 .

ns1:Parametro_4ms_8ejes a ns1:Parametro ;
    rdfs:label "LoopTime 4 ms (hasta 8 ejes analógicos)"@es ;
    ns1:identificador "LOOPTIME_4ms" ;
    ns1:textoExtracto "4 ms. | Hasta 8 ejes analógicos."@es ;
    ns1:valor 4 .

ns1:Parametro_5ms_12ejes a ns1:Parametro ;
    rdfs:label "LoopTime 5 ms (hasta 12 ejes analógicos)"@es ;
    ns1:identificador "LOOPTIME_5ms" ;
    ns1:textoExtracto "5 ms. | Hasta 12 ejes analógicos."@es ;
    ns1:valor 5 .

ns1:Parametro_6ms_16ejes a ns1:Parametro ;
    rdfs:label "LoopTime 6 ms (hasta 16 ejes analógicos)"@es ;
    ns1:identificador "LOOPTIME_6ms" ;
    ns1:textoExtracto "6 ms. | Hasta 16 ejes analógicos."@es ;
    ns1:valor 6 .

ns1:Parametro_8ms_20ejes a ns1:Parametro ;
    rdfs:label "LoopTime 8 ms (hasta 20 ejes analógicos)"@es ;
    ns1:identificador "LOOPTIME_8ms" ;
    ns1:textoExtracto "8 ms. | Hasta 20 ejes analógicos."@es ;
    ns1:valor 8 .

