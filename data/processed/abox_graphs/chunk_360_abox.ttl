@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ContajesRemotos a ns1:ComponenteElectrico ;
    rdfs:label "Contajes remotos" ;
    ns1:textoExtracto "Número total de contajes remotos habilitados." .

ns1:Herramienta_AnalisisLogicoCAN a ns1:Herramienta ;
    rdfs:label "Herramienta comercial de análisis lógico del bus CAN" ;
    ns1:textoExtracto "Si se desea conseguir una medición exacta del mínimo tiempo de ciclo necesario para una configuración dada, lo más fiable es recurrir a una herramienta comercial de análisis lógico del bus CAN." .

ns1:Parametro_LOOPTIME a ns1:Parametro ;
    rdfs:label "LOOPTIME" ;
    ns1:monitoreaParametro ns1:Sistema_BusCAN ;
    ns1:textoExtracto "Influencia del bus CAN en el parámetro LOOPTIME. Desde el punto de vista del bus CAN, el tiempo mínimo de ciclo para una determinada configuración viene condicionado fundamentalmente por las necesidades del tráfico del sistema; es decir, por el tiempo consumido en la transmisión de mensajes por ciclo." .

ns1:EntradasAnalogicas a ns1:ComponenteElectrico ;
    rdfs:label "Entradas analógicas" ;
    ns1:textoExtracto "Número total de entradas analógicas, salidas analógicas y volantes de teclado." .

ns1:EntradasSalidasDigitales a ns1:ComponenteElectrico ;
    rdfs:label "Entradas y salidas digitales" ;
    ns1:textoExtracto "Número total y frecuencia de cambio de las entradas y salidas digitales." ;
    ns1:tieneFrecuencia ns1:Frecuencia_CambioDigital .

ns1:Frecuencia_CambioDigital a ns1:Frecuencia ;
    rdfs:label "Frecuencia de cambio de entradas/salidas digitales" ;
    ns1:textoExtracto "Número total y frecuencia de cambio de las entradas y salidas digitales." .

ns1:Modulo_PRG_PLC a ns1:ComponenteElectrico ;
    rdfs:label "Módulo PRG del PLC" ;
    ns1:identificador "PRGFREQ" ;
    ns1:textoExtracto "Periodicidad del módulo PRG del PLC (PRGFREQ)." .

ns1:Parametro_VelocidadTransmision a ns1:Parametro ;
    rdfs:label "Velocidad de transmisión de CAN" ;
    ns1:textoExtracto "Velocidad de transmisión de CAN." .

ns1:SalidasAnalogicas a ns1:ComponenteElectrico ;
    rdfs:label "Salidas analógicas" ;
    ns1:textoExtracto "Número total de entradas analógicas, salidas analógicas y volantes de teclado." .

ns1:Sistema_BusCAN a ns1:Sistema ;
    rdfs:label "Bus CAN" ;
    ns1:monitoreaParametro ns1:Parametro_VelocidadTransmision ;
    ns1:textoExtracto "Influencia del bus CAN en el parámetro LOOPTIME. [...] el tiempo mínimo de ciclo para una determinada configuración viene condicionado fundamentalmente por las necesidades del tráfico del sistema; es decir, por el tiempo consumido en la transmisión de mensajes por ciclo." ;
    ns1:tieneComponente ns1:EntradasAnalogicas,
        ns1:EntradasSalidasDigitales,
        ns1:Modulo_PRG_PLC,
        ns1:SalidasAnalogicas,
        ns1:VolantesTeclado .

ns1:VolantesTeclado a ns1:InterfazUsuario ;
    rdfs:label "Volantes de teclado" ;
    ns1:textoExtracto "Número total de entradas analógicas, salidas analógicas y volantes de teclado." .

