@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:HerramientaConfiguracionTiempos a ns1:Herramienta ;
    rdfs:label "Herramienta de configuración de tiempos"@es ;
    ns1:controla ns1:Parametro_LOOPTIME,
        ns1:Parametro_PRGFREQ ;
    ns1:textoExtracto "Con esta herramienta se puede fijar el parámetro LOOPTIME con un valor que cubra con garantías las necesidades de comunicación..."@es .

ns1:AvisoTimeoutCAN a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de timeout en lecturas cíclicas de CAN"@es ;
    ns1:mitigaRiesgo ns1:ErrorSolapamientoCiclo ;
    ns1:textoExtracto "se producirán errores varios de solapamiento de ciclo y timeout en lecturas cíclicas de CAN... mostrando el correspondiente aviso en caso de ser insuficiente."@es .

ns1:BusCAN a ns1:ComponenteElectrico ;
    rdfs:label "Bus CAN"@es ;
    ns1:textoExtracto "sin saturar el ancho de banda del sistema... posibles picos transitorios de tráfico o eventualidades asíncronas."@es .

ns1:ErrorSolapamientoCiclo a ns1:DiagnosticoFallo ;
    rdfs:label "Error de solapamiento de ciclo en CAN"@es ;
    ns1:solucionaFallo ns1:Parametro_LOOPTIME ;
    ns1:textoExtracto "errores varios de solapamiento de ciclo y timeout en lecturas cíclicas de CAN."@es .

ns1:Parametro_PRGFREQ a ns1:Parametro ;
    rdfs:label "PRGFREQ"@es ;
    ns1:identificador "PRGFREQ" ;
    ns1:monitoreaParametro ns1:SistemaComunicacionCAN ;
    ns1:textoExtracto "aumentando el valor del parámetro PRGFREQ..."@es .

ns1:Parametro_LOOPTIME a ns1:Parametro ;
    rdfs:label "LOOPTIME"@es ;
    ns1:identificador "LOOPTIME" ;
    ns1:monitoreaParametro ns1:SistemaComunicacionCAN ;
    ns1:textoExtracto "parámetro LOOPTIME con un valor que cubra con garantías las necesidades de comunicación... Si se programa el parámetro LOOPTIME con un valor insuficiente, el comportamiento del bus será el siguiente..."@es ;
    ns1:valor "60%"^^xsd:string .

ns1:SistemaComunicacionCAN a ns1:Sistema ;
    rdfs:label "Sistema de comunicación CAN (CANfagor/CANopen)"@es ;
    ns1:activaAlarma ns1:AvisoTimeoutCAN ;
    ns1:textoExtracto "el ancho de banda del sistema (se recomienda no sobrepasar el 60% de ocupación del bus)... En el arranque del CNC se realiza adicionalmente una estimación del tiempo necesario, mostrando el correspondiente aviso en caso de ser insuficiente."@es ;
    ns1:tieneComponente ns1:BusCAN .

