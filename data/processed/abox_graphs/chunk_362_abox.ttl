@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PRGFREQ a ns1:Parametro ;
    rdfs:label "PRGFREQ" ;
    ns1:identificador "PRGFREQ" ;
    ns1:monitoreaParametro ns1:ModuloPRG ;
    ns1:textoExtracto "PRGFREQ Periodicidad del módulo PRG del PLC. Valores posibles: De 1 a 100 ciclos. Valor por defecto: 2 ciclos." ;
    ns1:valor "2" .

ns1:Variable_MPG_PRGFREQ a ns1:Parametro ;
    rdfs:label "(V.)MPG.PRGFREQ" ;
    ns1:identificador "MPG.PRGFREQ" ;
    ns1:monitoreaParametro ns1:ModuloPRG ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.PRGFREQ" .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "PLC" .

ns1:ModuloPRG a ns1:ComponenteElectrico ;
    rdfs:label "Módulo PRG del PLC" ;
    ns1:textoExtracto "módulo PRG del PLC" ;
    ns1:tieneComponente ns1:SistemaPLC .

