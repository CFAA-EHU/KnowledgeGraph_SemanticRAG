@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Frecuencia_8ms a ns1:Frecuencia ;
    rdfs:label "Frecuencia de ejecución (8 ms)" ;
    ns1:textoExtracto "con un periodo de muestreo LOOPTIME = 4 ms y una periodicidad PRGFREQ = 2, el programa de PLC se ejecutará cada 4 x 2 = 8 ms" ;
    ns1:tieneFrecuencia ns1:Sistema_PLC ;
    ns1:valor "8 ms" .

ns1:Parametro_PRGFREQ a ns1:Parametro ;
    rdfs:label "PRGFREQ" ;
    ns1:identificador "PRGFREQ" ;
    ns1:monitoreaParametro ns1:Sistema_PLC ;
    ns1:textoExtracto "Periodicidad del módulo PRG del PLC. Valores posibles: De 1 a 100 ciclos. Valor por defecto: 2 ciclos." ;
    ns1:valor "2" .

ns1:Sistema_PLC a ns1:Sistema ;
    rdfs:label "Módulo PRG del PLC" ;
    ns1:textoExtracto "Periodicidad del módulo PRG del PLC. Este parámetro indica con qué frecuencia (cada cuántos ciclos de CNC) se ejecuta un ciclo completo del programa de PLC." ;
    ns1:tieneComponente ns1:Parametro_PRGFREQ .

