@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_SERBRATE a ns1:Parametro ;
    rdfs:label "SERBRATE" ;
    ns1:identificador "V.MPG.SERBRATE" ;
    ns1:textoExtracto "SERBRATE Velocidad de transmisión de Sercos. Valores posibles: 2/4/8/16 Mbps (megabits por segundo). Valor por defecto: 4 Mbps." ;
    ns1:valor "4 Mbps" .

ns1:Tabla_SERPOWSE_Recomendaciones a ns1:Tabla ;
    rdfs:label "Valores recomendados para SERPOWSE" ;
    ns1:documentadoEn ns1:Parametro_SERPOWSE ;
    ns1:textoExtracto "Valores recomendados (placa Sercos I). | SERPOWSE | Longitud del cable. | --- | --- | 2 | Menor de 7 metros. | 4 | Entre 7 y 15 metros. | 6 | Mayor de 15 metros. Valores recomendados (placa Sercos II). | SERPOWSE | Longitud del cable. | Tipo de cable recomendado. | --- | --- | --- | 1 a 4 | Menor de 15 metros." .

ns1:Parametro_SERPOWSE a ns1:Parametro ;
    rdfs:label "SERPOWSE" ;
    ns1:identificador "V.MPG.SERPOWSE" ;
    ns1:textoExtracto "SERPOWSE Potencia óptica de Sercos. Valores posibles: De 1 a 6 (placa Sercos I) / de 1 a 8 (placa Sercos II). Valor por defecto: 4 (placa Sercos I) / 2 (placa Sercos II)." ;
    ns1:valor "4 (placa Sercos I) / 2 (placa Sercos II)" .

