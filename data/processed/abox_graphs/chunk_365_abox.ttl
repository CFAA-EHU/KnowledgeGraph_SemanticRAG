@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteElectrico_Cable_SFO a ns1:ComponenteElectrico ;
    rdfs:label "Cable SFO / SFO-FLEX"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionBusSercos_104 ;
    ns1:identificador "SFO" ;
    ns1:textoExtracto "SFO / SFO-FLEX"@es .

ns1:ComponenteElectrico_Cable_SFO_FLEX a ns1:ComponenteElectrico ;
    rdfs:label "Cable SFO-FLEX"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionBusSercos_104 ;
    ns1:identificador "SFO-FLEX" ;
    ns1:textoExtracto "SFO-FLEX"@es .

ns1:ComponenteElectrico_Cable_SFO_V_FLEX a ns1:ComponenteElectrico ;
    rdfs:label "Cable SFO-V-FLEX"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionBusSercos_104 ;
    ns1:identificador "SFO-V-FLEX" ;
    ns1:textoExtracto "SFO-V-FLEX"@es .

ns1:Parametro_SERPOWSE_1a4 a ns1:Parametro ;
    rdfs:label "SERPOWSE (valores 1-4)"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionBusSercos_104 ;
    ns1:textoExtracto "1 a 4"@es ;
    ns1:valor "1-4" .

ns1:Parametro_SERPOWSE_5a6 a ns1:Parametro ;
    rdfs:label "SERPOWSE (valores 5-6)"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionBusSercos_104 ;
    ns1:textoExtracto "5 a 6"@es ;
    ns1:valor "5-6" .

ns1:Parametro_SERPOWSE_7 a ns1:Parametro ;
    rdfs:label "SERPOWSE (valor 7)"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionBusSercos_104 ;
    ns1:textoExtracto "7"@es ;
    ns1:valor "7" .

ns1:Parametro_SERPOWSE_8 a ns1:Parametro ;
    rdfs:label "SERPOWSE (valor 8)"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionBusSercos_104 ;
    ns1:textoExtracto "8"@es ;
    ns1:valor "8" .

ns1:Tabla_ConfiguracionBusSercos_104 a ns1:Tabla ;
    rdfs:label "Tabla de configuración del bus Sercos (placa Sercos II)"@es ;
    ns1:identificador "SERPOWSE" ;
    ns1:textoExtracto """
Valores recomendados (placa Sercos II).
| SERPOWSE | Longitud del cable. | Tipo de cable recomendado. |
| 1 a 4    | Menor de 15 metros. | SFO / SFO-FLEX             |
| 5 a 6    | Entre 15 y 30 m.    | SFO-FLEX                   |
| 7        | Entre 30 y 40 m.    | SFO-FLEX                   |
| 8        | Mayor de 40 metros. | SFO-V-FLEX                 |
"""@es .

