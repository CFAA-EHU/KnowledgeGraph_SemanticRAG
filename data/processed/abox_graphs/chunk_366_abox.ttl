@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_MlinkI a ns1:ModoOperacion ;
    rdfs:label "Modo Mlink-I" ;
    ns1:textoExtracto "Modo Mechatrolink-I (Mlink-I). Todos los elementos del bus deben operar en el mismo modo." .

ns1:ModoOperacion_MlinkII a ns1:ModoOperacion ;
    rdfs:label "Modo Mlink-II" ;
    ns1:textoExtracto "Modo Mechatrolink-II (Mlink-II). Todos los elementos del bus deben operar con el mismo tamaño del telegrama." .

ns1:Parametro_FBACKSRC a ns1:Parametro ;
    rdfs:label "FBACKSRC (cambio de captación)" ;
    ns1:identificador "FBACKSRC" ;
    ns1:textoExtracto "Tampoco se permite el cambio de captación (parámetro FBACKSRC)." .

ns1:Parametro_FBMIXTIME a ns1:Parametro ;
    rdfs:label "FBMIXTIME (mezcla de captaciones)" ;
    ns1:identificador "FBMIXTIME" ;
    ns1:textoExtracto "No se permite segunda captación, por lo que no es posible la mezcla de captaciones (parámetro FBMIXTIME)." .

ns1:Sistema_BusMechatrolink a ns1:Sistema ;
    rdfs:label "Sistema de bus Mechatrolink" ;
    ns1:textoExtracto "Todos los elementos del bus deben operar en el mismo modo (Mlink-I o Mlink-II), por lo que la selección estará condicionada por el modo disponible en los esclavos conectados en el bus." ;
    ns1:tieneComponente ns1:Parametro_DATASIZE,
        ns1:Parametro_MLINK .

ns1:Parametro_DATASIZE a ns1:Parametro ;
    rdfs:label "DATASIZE (Tamaño del telegrama en Mlink-II)" ;
    ns1:identificador "V.MPG.DATASIZE" ;
    ns1:textoExtracto "DATASIZE Tamaño del telegrama en el modo Mlink-II. Valores posibles: 17 / 32 bytes. Valor por defecto: 32 bytes. Variable asociada: (V.)MPG.DATASIZE Este parámetro define el tamaño del telegrama para el modo Mlink-II." ;
    ns1:valor "32 bytes" .

ns1:Parametro_MLINK a ns1:Parametro ;
    rdfs:label "MLINK (Modo Mechatrolink)" ;
    ns1:identificador "V.MPG.MLINK" ;
    ns1:textoExtracto "MLINK Modo Mechatrolink. Valores posibles: No / Mlink-I / Mlink-II. Valor por defecto: No. Variable asociada: (V.)MPG.MLINK Este parámetro permite configurar el bus Mechatrolink en modo Mlink-I o Mlink-II." ;
    ns1:valor "No" .

