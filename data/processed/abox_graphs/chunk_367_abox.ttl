@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Sistema_BusCAN a ns1:Sistema ;
    rdfs:label "Sistema de bus CAN" ;
    ns1:documentadoEn ns1:Tabla_VelocidadesCANopen ;
    ns1:textoExtracto "Bus CANfagor. Si se utiliza el tipo de bus CANfagor, hay que definir la longitud máxima del bus mediante el parámetro CANLENGTH. Bus CANopen. Si se utiliza el tipo de bus CANopen, la velocidad de trabajo se define en cada uno de los nodos." ;
    ns1:tieneComponente ns1:Parametro_CANLENGTH,
        ns1:Parametro_CANMODE,
        ns1:Parametro_CANOPENFREQ .

ns1:Parametro_CANLENGTH a ns1:Parametro ;
    rdfs:label "CANLENGTH" ;
    ns1:identificador "V.MPG.CANLENGTH" ;
    ns1:textoExtracto "CANLENGTH Longitud del cable del bus CANfagor. Valores posibles: Hasta 20, 30, 40, 50, 60, 70, 80, 90, 100, 110, 120, 130 y más de 130 metros. Valor por defecto: Hasta 20 metros." ;
    ns1:valor "Hasta 20 metros"^^xsd:string .

ns1:Parametro_CANMODE a ns1:Parametro ;
    rdfs:label "CANMODE" ;
    ns1:identificador "V.MPG.CANMODE" ;
    ns1:textoExtracto "CANMODE Tipo de bus CAN. Valores posibles: CANfagor / CANopen. Valor por defecto: CANopen." ;
    ns1:valor "CANopen"^^xsd:string .

ns1:Parametro_CANOPENFREQ a ns1:Parametro ;
    rdfs:label "CANOPENFREQ" ;
    ns1:identificador "V.MPG.CANOPENFREQ" ;
    ns1:textoExtracto "CANOPENFREQ Frecuencia de comunicación del bus CANopen. Valores posibles: Autoscan / 1 Mbps / 800 kbps / 500 kbps / 250 kbps. Valor por defecto: Autoscan." ;
    ns1:valor "Autoscan"^^xsd:string .

ns1:Tabla_VelocidadesCANopen a ns1:Tabla ;
    rdfs:label "Tabla de velocidades CANopen según longitud del bus" ;
    ns1:ilustradoEn ns1:Pagina_71 ;
    ns1:textoExtracto "| Longitud (m) | 20 | 40 | 100 | 500 | --- | Velocidad (kHz) | 1000 | 800 | 500 | 250 |" .

