@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:InterfazUsuario_PanelHBLS a ns1:InterfazUsuario ;
    rdfs:label "Panel portátil HBLS" ;
    ns1:requiereMantenimiento ns1:Parametro_RSTYPE ;
    ns1:textoExtracto "Para el panel portátil HBLS seleccionar RS422." .

ns1:Sistema_ComunicacionSerie a ns1:Sistema ;
    rdfs:label "Sistema de comunicación serie del CNC" ;
    ns1:textoExtracto "Configuración estándar para RS232 y configuración full-duplex para RS422. Para el panel portátil HBLS seleccionar RS422. En la RS485, el CNC controla la recepción y transmisión de datos con la misma señal." ;
    ns1:tieneComponente ns1:Parametro_RSTYPE,
        ns1:Parametro_RetardoRS485 .

ns1:Parametro_RetardoRS485 a ns1:Parametro ;
    rdfs:label "Retardo de recepción/transmisión RS485" ;
    ns1:textoExtracto "Para asegurar una comunicación correcta, es necesario un retardo de 8 ms desde que el CNC deja de transmitir y está preparado para recibir datos." ;
    ns1:valor "8 ms"^^xsd:string .

ns1:Parametro_RSTYPE a ns1:Parametro ;
    rdfs:label "RSTYPE" ;
    ns1:identificador "V.MPG.RSTYPE" ;
    ns1:textoExtracto "RSTYPE Tipo de línea serie. Valores posibles: RS232 / RS485 / RS422. Valor por defecto: RS232." ;
    ns1:valor "RS232"^^xsd:string .

