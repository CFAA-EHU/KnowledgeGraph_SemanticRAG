@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_MODBRATE a ns1:Parametro ;
    rdfs:label "MODBRATE" ;
    ns1:documentadoEn ns1:TablaConfiguracionModBUS ;
    ns1:identificador "(V.)MPG.MODBRATE" ;
    ns1:textoExtracto "Velocidad de comunicación del servidor ModBUS sobre RS485. Valores posibles: 19200 Bd / 38400 Bd / 57600 Bd / 115200 Bd. Valor por defecto: 19200 Bd."@es ;
    ns1:valor "19200 Bd" .

ns1:Parametro_MODBUSSVRRS a ns1:Parametro ;
    rdfs:label "MODBUSSVRRS" ;
    ns1:documentadoEn ns1:TablaConfiguracionModBUS ;
    ns1:identificador "(V.)MPG.MODBUSSVRRS" ;
    ns1:textoExtracto "Activar el servidor ModBUS sobre RS485. Valores posibles: Sí / No. Valor por defecto: No."@es ;
    ns1:valor "No" .

ns1:Parametro_MODBUSSVRTCP a ns1:Parametro ;
    rdfs:label "MODBUSSVRTCP" ;
    ns1:documentadoEn ns1:TablaConfiguracionModBUS ;
    ns1:identificador "(V.)MPG.MODBUSSVRTCP" ;
    ns1:textoExtracto "Activar el servidor ModBUS sobre TCP. Valores posibles: Sí / No. Valor por defecto: No."@es ;
    ns1:valor "No" .

ns1:Parametro_MODSVRID a ns1:Parametro ;
    rdfs:label "MODSVRID" ;
    ns1:documentadoEn ns1:TablaConfiguracionModBUS ;
    ns1:identificador "(V.)MPG.MODSVRID" ;
    ns1:textoExtracto "Identificador del servidor ModBUS sobre RS485. Valores posibles: De 1 a 255. Valor por defecto: 1."@es ;
    ns1:valor "1" .

ns1:TablaConfiguracionModBUS a ns1:Tabla ;
    rdfs:label "Tabla MODBUS"@es ;
    ns1:textoExtracto "Este parámetro muestra la tabla para configurar el servidor ModBUS."@es ;
    ns1:tieneComponente ns1:Parametro_MODBRATE,
        ns1:Parametro_MODBUSSVRRS,
        ns1:Parametro_MODBUSSVRTCP,
        ns1:Parametro_MODSVRID .

