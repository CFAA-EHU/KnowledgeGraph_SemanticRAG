@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_ETHERCATBUS a ns1:Parametro ;
    rdfs:label "ETHERCATBUS" ;
    ns1:identificador "MPG.ETHERCATBUS" ;
    ns1:textoExtracto "ETHERCATBUS Activar el bus EtherCAT. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPG.ETHERCATBUS Activar el bus EtherCAT." ;
    ns1:valor "No" .

