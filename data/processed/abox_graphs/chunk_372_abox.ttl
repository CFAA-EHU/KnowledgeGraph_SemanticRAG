@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC (condiciones por defecto)"@es ;
    ns1:monitoreaParametro ns1:Parametro_UnidadesPresion,
        ns1:Parametro_UnidadesTrabajo ;
    ns1:textoExtracto "Este parámetro indica las unidades de trabajo que asume el CNC por defecto; es decir, en el momento de encendido, después de ejecutarse M02, M30 o después de un reset."@es .

ns1:Parametro_UnidadesPresion a ns1:Parametro ;
    rdfs:label "Unidades de presión (PRESSURE)"@es ;
    ns1:identificador "MPG.PRESSURE" ;
    ns1:textoExtracto "PRESSURE Unidades de presión por defecto. Valores posibles: Bar / Psi. Valor por defecto: Bar. Variable asociada: (V.)MPG.PRESSURE Este parámetro indica las unidades de trabajo que asume el CNC por defecto; es decir, en el momento de encendido, después de ejecutarse M02, M30 o después de un reset."@es ;
    ns1:valor "Bar" .

ns1:Parametro_UnidadesTrabajo a ns1:Parametro ;
    rdfs:label "Unidades de trabajo (INCHES)"@es ;
    ns1:identificador "MPG.INCHES" ;
    ns1:textoExtracto "INCHES Unidades de trabajo (milímetros, inch) por defecto. Valores posibles: Milímetros / inches. Valor por defecto: Milímetros. Variable asociada: (V.)MPG.INCHES Este parámetro indica las unidades de trabajo que asume el CNC por defecto; es decir, en el momento de encendido, después de ejecutarse M02, M30 o después de un reset."@es ;
    ns1:valor "Milímetros" .

