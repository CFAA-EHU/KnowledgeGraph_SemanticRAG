@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ParametrosAritmeticos a ns1:Sistema ;
    rdfs:label "Sistema de parámetros aritméticos locales y globales" ;
    ns1:textoExtracto "Los parámetros MINLOCP y MAXLOCP definen el grupo de parámetros aritméticos locales que se desea utilizar. [...] Los parámetros MAXGLBP y MINGLBP definen el grupo de parámetros aritméticos globales que se desea utilizar. [...] Los parámetros ROPARMAX y ROPARMIN permiten proteger frente a escritura un grupo de parámetros aritméticos globales." ;
    ns1:tieneComponente ns1:Parametro_MAXGLBP,
        ns1:Parametro_MAXLOCP,
        ns1:Parametro_MINGLBP,
        ns1:Parametro_MINLOCP,
        ns1:Parametro_ROPARMAX,
        ns1:Parametro_ROPARMIN .

ns1:Parametro_MAXGLBP a ns1:Parametro ;
    rdfs:label "MAXGLBP" ;
    ns1:identificador "MAXGLBP" ;
    ns1:textoExtracto "MAXGLBP Parámetro aritmético global máximo. Valores posibles: De 100 a 9999. Valor por defecto: 299. Variable asociada: (V.)MPG.MAXGLBP" ;
    ns1:valor "299" .

ns1:Parametro_MAXLOCP a ns1:Parametro ;
    rdfs:label "MAXLOCP" ;
    ns1:identificador "MAXLOCP" ;
    ns1:textoExtracto "MAXLOCP Parámetro aritmético local máximo. Valores posibles: De 0 a 99. Valor por defecto: 25. Variable asociada: (V.)MPG.MAXLOCP" ;
    ns1:valor "25" .

ns1:Parametro_MINGLBP a ns1:Parametro ;
    rdfs:label "MINGLBP" ;
    ns1:identificador "MINGLBP" ;
    ns1:textoExtracto "MINGLBP Parámetro aritmético global mínimo. Valores posibles: De 100 a 9999. Valor por defecto: 100. Variable asociada: (V.)MPG.MINGLBP" ;
    ns1:valor "100" .

ns1:Parametro_MINLOCP a ns1:Parametro ;
    rdfs:label "MINLOCP" ;
    ns1:identificador "MINLOCP" ;
    ns1:textoExtracto "MINLOCP Parámetro aritmético local mínimo. Valores posibles: De 0 a 99. Valor por defecto: 0. Variable asociada: (V.)MPG.MINLOCP" ;
    ns1:valor "0" .

ns1:Parametro_ROPARMAX a ns1:Parametro ;
    rdfs:label "ROPARMAX" ;
    ns1:identificador "ROPARMAX" ;
    ns1:textoExtracto "ROPARMAX Parámetro aritmético global máximo de sólo lectura. Valores posibles: De 100 a 9999. Valor por defecto: 0. Variable asociada: (V.)MPG.ROPARMAX" ;
    ns1:valor "0" .

ns1:Parametro_ROPARMIN a ns1:Parametro ;
    rdfs:label "ROPARMIN" ;
    ns1:identificador "ROPARMIN" ;
    ns1:textoExtracto "ROPARMIN Parámetro aritmético global mínimo de sólo lectura. Valores posibles: De 100 a 9999. Valor por defecto: 0. Variable asociada: (V.)MPG.ROPARMIN" ;
    ns1:valor "0" .

