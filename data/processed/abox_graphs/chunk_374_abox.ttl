@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_MAXCOMP a ns1:Parametro ;
    rdfs:label "MAXCOMP" ;
    ns1:textoExtracto "Parámetro aritmético común entre canales máximo. Valores posibles: De 10000 a 19999. Valor por defecto: 10025. Variable asociada: (V.)MPG.MAXCOMP" ;
    ns1:valor "10025" .

ns1:Parametro_MINCOMP a ns1:Parametro ;
    rdfs:label "MINCOMP" ;
    ns1:textoExtracto "Consultar el parámetro máquina general MINCOMP." .

ns1:Parametro_ROPARMAX a ns1:Parametro ;
    rdfs:label "ROPARMAX" ;
    ns1:textoExtracto "Los parámetros ROPARMAX y ROPARMIN permiten proteger frente a escritura un grupo de parámetros aritméticos globales." .

ns1:Parametro_ROPARMIN a ns1:Parametro ;
    rdfs:label "ROPARMIN" ;
    ns1:textoExtracto "Valor por defecto: 0. Variable asociada: (V.)MPG.ROPARMIN Los parámetros ROPARMAX y ROPARMIN permiten proteger frente a escritura un grupo de parámetros aritméticos globales." ;
    ns1:valor "0" .

