@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Sistema_ParametrosAritmeticosComunes a ns1:Sistema ;
    rdfs:label "Sistema de parámetros aritméticos comunes entre canales" ;
    ns1:textoExtracto "Los parámetros MAXCOMP y MINCOMP definen el grupo de parámetros aritméticos comunes a todos los canales que se desea utilizar. Los parámetros comunes son accesibles desde cualquier canal. El valor de estos parámetros es compartido por todos los canales." ;
    ns1:tieneComponente ns1:Parametro_BKUPCUP,
        ns1:Parametro_MAXCOMP,
        ns1:Parametro_MINCOMP .

ns1:Parametro_BKUPCUP a ns1:Parametro ;
    rdfs:label "BKUPCUP" ;
    ns1:identificador "(V.)MPG.BKUPCUP" ;
    ns1:textoExtracto "Número de parámetros aritméticos comunes no volátiles. Valores posibles: De 0 a 20. Valor por defecto: 0. Variable asociada: (V.)MPG.BKUPCUP" ;
    ns1:valor 0 .

ns1:Parametro_MAXCOMP a ns1:Parametro ;
    rdfs:label "MAXCOMP" ;
    ns1:identificador "(V.)MPG.MAXCOMP" ;
    ns1:textoExtracto "Parámetro aritmético común entre canales máximo. Valores posibles: De 10000 a 19999. Valor por defecto: 10025. Variable asociada: (V.)MPG.MAXCOMP" ;
    ns1:valor 10025 .

ns1:Parametro_MINCOMP a ns1:Parametro ;
    rdfs:label "MINCOMP" ;
    ns1:identificador "(V.)MPG.MINCOMP" ;
    ns1:textoExtracto "Parámetro aritmético común entre canales mínimo. Valores posibles: De 10000 a 19999. Valor por defecto: 10000. Variable asociada: (V.)MPG.MINCOMP" ;
    ns1:valor 10000 .

