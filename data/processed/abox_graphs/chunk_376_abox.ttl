@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaAlmacenamientoCNC a ns1:Sistema ;
    rdfs:label "Sistema de almacenamiento no volátil del CNC"@es ;
    ns1:monitoreaParametro ns1:ParametrosAritmeticosCNC ;
    ns1:textoExtracto "El CNC almacena estos datos cuando se apaga el CNC, ante una caída de tensión, cuando se produce un error de hardware o software, etc."@es .

ns1:ParametrosAritmeticosCNC a ns1:Parametro ;
    rdfs:label "Parámetros aritméticos del CNC"@es ;
    ns1:identificador "1-N" ;
    ns1:textoExtracto "El CNC guarda los primeros parámetros, desde el 1 hasta el definido en este parámetro. Se entiende como datos no volátiles aquellos cuyo valor hay que mantener entre las diferentes sesiones y apagados del CNC."@es .

