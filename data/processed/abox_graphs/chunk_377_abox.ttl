@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_DISCROSS a ns1:Parametro ;
    rdfs:label "DISCROSS" ;
    ns1:identificador "DISCROSS" ;
    ns1:monitoreaParametro ns1:TablaCompensacionCruzada_1,
        ns1:TablaCompensacionCruzada_2 ;
    ns1:textoExtracto "marca DISCROSS. El PLC dispone de una marca para cada tabla; la marca DISCROSS1 es para la tabla 1, DISCROSS2 para la tabla 2" .

ns1:Sistema_CompensacionCruzada a ns1:Sistema ;
    rdfs:label "Sistema de compensación cruzada" ;
    ns1:controla ns1:Parametro_CROSSCOMP ;
    ns1:documentadoEn ns1:Manual_CNC ;
    ns1:textoExtracto "La compensación cruzada se utiliza cuando dependiendo del desplazamiento de un eje, otro eje sufre variaciones de posición." ;
    ns1:tieneComponente ns1:TablaCompensacionCruzada_1,
        ns1:TablaCompensacionCruzada_2 .

ns1:Parametro_CROSSCOMP a ns1:Parametro ;
    rdfs:label "CROSSCOMP" ;
    ns1:documentadoEn ns1:Manual_CNC ;
    ns1:identificador "CROSSCOMP" ;
    ns1:textoExtracto "CROSSCOMP Tablas de compensación cruzada. Este parámetro muestra las tablas de compensación cruzada." .

ns1:Manual_CNC a ns1:Manual ;
    rdfs:label "Manual del CNC" ;
    ns1:textoExtracto "Este parámetro muestra las tablas de compensación cruzada. [...] El CNC calcula la compensación que se debe aplicar a cada eje" .

ns1:TablaCompensacionCruzada_1 a ns1:Tabla ;
    rdfs:label "Tabla de compensación cruzada 1" ;
    ns1:identificador "DISCROSS1" ;
    ns1:textoExtracto "COMPAXIS MOVAXIS POSERROR n POSITION n [...] DISCROSS1 es para la tabla 1" .

ns1:TablaCompensacionCruzada_2 a ns1:Tabla ;
    rdfs:label "Tabla de compensación cruzada 2" ;
    ns1:identificador "DISCROSS2" ;
    ns1:textoExtracto "DISCROSS2 para la tabla 2" .

