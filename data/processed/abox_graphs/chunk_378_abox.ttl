@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FicheroImportacion_117 a ns1:InterfazUsuario ;
    rdfs:label "Fichero de texto para importación de tablas"@es ;
    ns1:textoExtracto "adaptar el formato de un fichero de texto en el que esté guardado el resultado de la medición y posteriormente importarlo."@es .

ns1:ManualOperacion_117 a ns1:Manual ;
    rdfs:label "Manual de operación"@es ;
    ns1:identificador "Manual de operación"@es ;
    ns1:textoExtracto "Para obtener más información sobre cómo importar las tablas de compensación cruzada, consultar en el manual de operación."@es .

ns1:ParametroMaquina_CROSSCOMP_117 a ns1:Parametro ;
    rdfs:label "CROSSCOMP (Configuración de tablas de compensación cruzada)"@es ;
    ns1:identificador "CROSSCOMP" ;
    ns1:monitoreaParametro ns1:TablasCompensacionCruzada_117 ;
    ns1:textoExtracto "CROSSCOMP n Configuración de las tablas de compensación cruzada."@es .

ns1:TablasCompensacionCruzada_117 a ns1:Sistema,
        ns1:Tabla ;
    rdfs:label "Tablas de compensación cruzada"@es ;
    ns1:documentadoEn ns1:ManualOperacion_117 ;
    ns1:textoExtracto "Importar tablas de compensación cruzada. [...] El CNC mostrará las tablas posibles en función del número de ejes definidos."@es ;
    ns1:tieneComponente ns1:ParametroMaquina_CROSSCOMP_117 .

