@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_BIDIR a ns1:Parametro ;
    rdfs:label "BIDIR" ;
    ns1:documentadoEn ns1:TablaCompensacionCruzada_118 ;
    ns1:textoExtracto "Compensación bidireccional."@es .

ns1:Parametro_COMPAXIS a ns1:Parametro ;
    rdfs:label "COMPAXIS" ;
    ns1:documentadoEn ns1:TablaCompensacionCruzada_118 ;
    ns1:textoExtracto "Eje que sufre variaciones (compensado)."@es .

ns1:Parametro_DATA a ns1:Parametro ;
    rdfs:label "DATA" ;
    ns1:documentadoEn ns1:TablaCompensacionCruzada_118 ;
    ns1:textoExtracto "Tabla para definir los valores de compensación."@es .

ns1:Parametro_MOVAXIS a ns1:Parametro ;
    rdfs:label "MOVAXIS" ;
    ns1:documentadoEn ns1:TablaCompensacionCruzada_118 ;
    ns1:textoExtracto "Eje que al moverse genera variaciones (maestro)."@es .

ns1:Parametro_NPCROSS a ns1:Parametro ;
    rdfs:label "NPCROSS" ;
    ns1:documentadoEn ns1:TablaCompensacionCruzada_118 ;
    ns1:textoExtracto "Número de puntos de la tabla."@es .

ns1:Parametro_REFNEED a ns1:Parametro ;
    rdfs:label "REFNEED" ;
    ns1:documentadoEn ns1:TablaCompensacionCruzada_118 ;
    ns1:textoExtracto "Búsqueda de referencia necesaria para compensar."@es .

ns1:Parametro_TYPCROSS a ns1:Parametro ;
    rdfs:label "TYPCROSS" ;
    ns1:documentadoEn ns1:TablaCompensacionCruzada_118 ;
    ns1:textoExtracto "Método de compensación."@es .

ns1:TablaCompensacionCruzada_118 a ns1:Tabla ;
    rdfs:label "Tabla de compensación cruzada (CROSSCOMP)"@es ;
    ns1:identificador "CROSSCOMP" ;
    ns1:textoExtracto "DATA | Tabla para definir los valores de compensación."@es .

