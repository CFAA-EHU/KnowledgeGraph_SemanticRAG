@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaCompensacionCruzada_CROSSCOMP a ns1:Tabla ;
    rdfs:label "Tabla CROSSCOMP"@es ;
    ns1:textoExtracto "Este parámetro establece cuál es el eje maestro en la compensación cruzada. [...] Parámetro incluido en la tabla CROSSCOMP."@es ;
    ns1:tieneComponente ns1:Parametro_BIDIR,
        ns1:Parametro_COMPAXIS,
        ns1:Parametro_MOVAXIS,
        ns1:Parametro_NPCROSS,
        ns1:Parametro_REFNEED,
        ns1:Parametro_TYPCROSS .

ns1:Parametro_BIDIR a ns1:Parametro ;
    rdfs:label "BIDIR"@es ;
    ns1:identificador "MPG.BIDIR[tbl]" ;
    ns1:textoExtracto "BIDIR Compensación bidireccional. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPG.BIDIR[tbl] Parámetro incluido en la tabla CROSSCOMP. Este parámetro indica si la compensación es bidireccional; es decir, si hay distinta compensación en cada sentido."@es ;
    ns1:valor "Sí/No"@es .

ns1:Parametro_COMPAXIS a ns1:Parametro ;
    rdfs:label "COMPAXIS"@es ;
    ns1:identificador "MPG.COMPAXIS[tbl]" ;
    ns1:textoExtracto "COMPAXIS Eje que sufre variaciones (compensado). Valores posibles: Cualquier eje definido en AXISNAME. Variable asociada: (V.)MPG.COMPAXIS[tbl] Parámetro incluido en la tabla CROSSCOMP. Este parámetro establece cuál es el eje compensado en la compensación cruzada."@es ;
    ns1:valor "Cualquier eje definido en AXISNAME"@es .

ns1:Parametro_MOVAXIS a ns1:Parametro ;
    rdfs:label "MOVAXIS"@es ;
    ns1:identificador "MPG.MOVAXIS[tbl]" ;
    ns1:textoExtracto "MOVAXIS Eje que al moverse genera variaciones (maestro). Valores posibles: Cualquier eje definido en AXISNAME. Variable asociada: (V.)MPG.MOVAXIS[tbl] Parámetro incluido en la tabla CROSSCOMP. Este parámetro establece cuál es el eje maestro en la compensación cruzada."@es ;
    ns1:valor "Cualquier eje definido en AXISNAME"@es .

ns1:Parametro_NPCROSS a ns1:Parametro ;
    rdfs:label "NPCROSS"@es ;
    ns1:identificador "MPG.NPCROSS[tbl]" ;
    ns1:textoExtracto "NPCROSS Número de puntos de la tabla. Valores posibles: De 0 a 1000. Valor por defecto: 0 (no hay tabla). Variable asociada: (V.)MPG.NPCROSS[tbl] Parámetro incluido en la tabla CROSSCOMP. Cada tabla de compensación cruzada puede disponer de hasta 1000 puntos."@es ;
    ns1:valor "0-1000" .

ns1:Parametro_REFNEED a ns1:Parametro ;
    rdfs:label "REFNEED"@es ;
    ns1:identificador "MPG.REFNEED[tbl]" ;
    ns1:textoExtracto "REFNEED Búsqueda de referencia necesaria para compensar. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPG.REFNEED[tbl] Parámetro incluido en la tabla CROSSCOMP. Este parámetro indica si es necesario referenciar ambos ejes para empezar a aplicar la compensación."@es ;
    ns1:valor "Sí/No"@es .

ns1:Parametro_TYPCROSS a ns1:Parametro ;
    rdfs:label "TYPCROSS"@es ;
    ns1:identificador "MPG.TYPCROSS[tbl]" ;
    ns1:textoExtracto "TYPCROSS Método de compensación (tipo de cotas). Valores posibles: Real / Teórica. Valor por defecto: Real. Variable asociada: (V.)MPG.TYPCROSS[tbl] Parámetro incluido en la tabla CROSSCOMP. Este parámetro establece si la compensación cruzada se realiza con las cotas teóricas o con las cotas reales."@es ;
    ns1:valor "Real/Teórica"@es .

