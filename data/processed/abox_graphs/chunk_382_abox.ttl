@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_BIDIR a ns1:Parametro ;
    rdfs:label "BIDIR"@es ;
    ns1:identificador "BIDIR" ;
    ns1:textoExtracto "compensación bidireccional (BIDIR = Sí)"@es ;
    ns1:valor "Sí/No"@es .

ns1:Parametro_NEGERROR a ns1:Parametro ;
    rdfs:label "NEGERROR"@es ;
    ns1:documentadoEn ns1:TablaCompensacionCruzada_2.3.16 ;
    ns1:identificador "NEGERROR" ;
    ns1:textoExtracto "parámetro NEGERROR [...] El parámetro NEGERROR sólo se muestra si se ha definido la tabla con compensación bidireccional (BIDIR = Sí)"@es .

ns1:Parametro_POSERROR a ns1:Parametro ;
    rdfs:label "POSERROR"@es ;
    ns1:documentadoEn ns1:TablaCompensacionCruzada_2.3.16 ;
    ns1:identificador "POSERROR" ;
    ns1:textoExtracto "parámetro POSERROR"@es .

ns1:Parametro_POSITION a ns1:Parametro ;
    rdfs:label "POSITION"@es ;
    ns1:documentadoEn ns1:TablaCompensacionCruzada_2.3.16 ;
    ns1:identificador "POSITION" ;
    ns1:textoExtracto "parámetro POSITION"@es .

ns1:Parametro_COMPAXIS a ns1:Parametro ;
    rdfs:label "COMPAXIS"@es ;
    ns1:identificador "COMPAXIS" ;
    ns1:textoExtracto "parámetro COMPAXIS"@es .

ns1:Parametro_MOVAXIS a ns1:Parametro ;
    rdfs:label "MOVAXIS"@es ;
    ns1:identificador "MOVAXIS" ;
    ns1:textoExtracto "parámetro MOVAXIS"@es .

ns1:Parametro_NPCROSS a ns1:Parametro ;
    rdfs:label "NPCROSS"@es ;
    ns1:identificador "NPCROSS" ;
    ns1:textoExtracto "parámetro NPCROSS [...] El número de puntos viene definido por el parámetro NPCROSS"@es ;
    ns1:valor "Número de puntos de compensación"@es .

ns1:TablaCompensacionCruzada_2.3.16 a ns1:Tabla ;
    rdfs:label "Tabla de compensación cruzada"@es ;
    ns1:detalladoEnEsquema ns1:Parametro_COMPAXIS,
        ns1:Parametro_MOVAXIS,
        ns1:Parametro_NPCROSS ;
    ns1:identificador "2.3.16" ;
    ns1:textoExtracto "Este parámetro muestra la lista de puntos y valores de compensación. El CNC sólo permite acceder a esta tabla cuando están definidos los parámetros MOVAXIS, COMPAXIS y NPCROSS."@es .

