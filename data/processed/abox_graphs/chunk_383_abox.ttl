@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_NEGERROR a ns1:Parametro ;
    rdfs:label "NEGERROR" ;
    ns1:documentadoEn ns1:Tabla_CrossCompensation ;
    ns1:textoExtracto "Error a compensar en los desplazamientos en sentido negativo."@es .

ns1:Parametro_POSERROR a ns1:Parametro ;
    rdfs:label "POSERROR" ;
    ns1:documentadoEn ns1:Tabla_CrossCompensation ;
    ns1:textoExtracto "Error a compensar en los desplazamientos en sentido positivo."@es .

ns1:Parametro_POSITION a ns1:Parametro ;
    rdfs:label "POSITION" ;
    ns1:documentadoEn ns1:Tabla_CrossCompensation ;
    ns1:textoExtracto "Posición del eje maestro."@es .

ns1:Tabla_CrossCompensation a ns1:Tabla ;
    rdfs:label "Tabla de compensación cruzada (CROSSCOMP DATA)"@es ;
    ns1:identificador "CROSSCOMP" ;
    ns1:textoExtracto """
| CROSSCOMP DATA |  |
| --- | --- |
| POSITION | Posición del eje maestro. |
| POSERROR | Error a compensar en los desplazamientos en sentido positivo. |
| NEGERROR | Error a compensar en los desplazamientos en sentido negativo.
""" ;
    ns1:tieneComponente ns1:Parametro_NEGERROR,
        ns1:Parametro_POSERROR,
        ns1:Parametro_POSITION .

