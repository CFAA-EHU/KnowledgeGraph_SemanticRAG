@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_NEGERROR a ns1:Parametro ;
    rdfs:label "NEGERROR (Error en sentido negativo)"@es ;
    ns1:documentadoEn ns1:TablaCompensacionCruzada_CROSSCOMP_DATA ;
    ns1:identificador "MPG.NEGERROR[tbl][pt]" ;
    ns1:textoExtracto "NEGERROR: Error a compensar en los desplazamientos en sentido negativo. Valores posibles (1): Entre ±99999.9999 mm. Valor por defecto: 0. Variable asociada: (V.)MPG.NEGERROR[tbl][pt]."@es ;
    ns1:valor "0"^^xsd:string .

ns1:Parametro_POSERROR a ns1:Parametro ;
    rdfs:label "POSERROR (Error en sentido positivo)"@es ;
    ns1:documentadoEn ns1:TablaCompensacionCruzada_CROSSCOMP_DATA ;
    ns1:identificador "MPG.POSERROR[tbl][pt]" ;
    ns1:textoExtracto "POSERROR: Error a compensar en los desplazamientos en sentido positivo. Valores posibles (1): Entre ±99999.9999 mm. Valor por defecto: 0. Variable asociada: (V.)MPG.POSERROR[tbl][pt]."@es ;
    ns1:valor "0"^^xsd:string .

ns1:Parametro_POSITION a ns1:Parametro ;
    rdfs:label "POSITION (Posición del eje maestro)"@es ;
    ns1:documentadoEn ns1:TablaCompensacionCruzada_CROSSCOMP_DATA ;
    ns1:identificador "MPG.POSITION[tbl][pt]" ;
    ns1:textoExtracto "POSITION: Posición del eje maestro. Valores posibles (1): Entre ±99999.9999 mm. Valores posibles (2): Entre ±3937.00787 inch. Valores posibles (3): Entre ±99999.9999 grados. Valor por defecto: 0. Variable asociada: (V.)MPG.POSITION[tbl][pt]."@es ;
    ns1:valor "0"^^xsd:string .

ns1:TablaCompensacionCruzada_CROSSCOMP_DATA a ns1:Tabla ;
    rdfs:label "Tabla CROSSCOMP // DATA"@es ;
    ns1:identificador "CROSSCOMP // DATA" ;
    ns1:textoExtracto "Parámetro incluido en la tabla CROSSCOMP // DATA. Este parámetro define la posición del eje maestro en cada uno de los puntos de compensación."@es .

