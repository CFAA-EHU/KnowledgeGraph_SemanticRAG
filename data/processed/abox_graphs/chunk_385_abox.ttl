@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Maquina_Referencia a ns1:Maquina ;
    rdfs:label "Máquina (punto de referencia)" ;
    ns1:textoExtracto "El punto de referencia máquina debe tener error ≠ 0." .

ns1:Parametro_NEGERROR a ns1:Parametro ;
    rdfs:label "MPG.NEGERROR[tbl][pt]" ;
    ns1:documentadoEn ns1:Tabla_CROSSCOMP_DATA ;
    ns1:identificador "MPG.NEGERROR[tbl][pt]" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.NEGERROR[tbl][pt]. Este parámetro indica el error en el eje compensado cuando el eje maestro se desplaza en sentido negativo." ;
    ns1:valor "0"^^xsd:string .

ns1:Sistema_CompensacionBidireccional a ns1:Sistema ;
    rdfs:label "Sistema de compensación bidireccional" ;
    ns1:detalladoEnEsquema ns1:Tabla_CROSSCOMP_DATA ;
    ns1:textoExtracto "Esta compensación sólo está disponible si se ha definido la tabla con compensación bidireccional." .

ns1:Tabla_CROSSCOMP_DATA a ns1:Tabla ;
    rdfs:label "Tabla CROSSCOMP // DATA" ;
    ns1:identificador "CROSSCOMP // DATA" ;
    ns1:textoExtracto "Parámetro incluido en la tabla CROSSCOMP // DATA. Este parámetro indica el error en el eje compensado cuando el eje maestro se desplaza en sentido negativo." .

