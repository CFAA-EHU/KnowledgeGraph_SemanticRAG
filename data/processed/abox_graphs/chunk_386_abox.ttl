@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCompensacionVolumetrica a ns1:Sistema ;
    rdfs:label "Sistema de compensación volumétrica" ;
    ns1:documentadoEn ns1:TablaCompensacionVolumetrica ;
    ns1:textoExtracto "Las compensaciones volumétricas se configuran en los parámetros máquina y se activan desde el PLC (marcas VOLCOMP1 a VOLCOMP4)." ;
    ns1:tieneComponente ns1:VOLCOMP1,
        ns1:VOLCOMP2,
        ns1:VOLCOMP3,
        ns1:VOLCOMP4 .

ns1:VOLCOMP a ns1:Parametro ;
    rdfs:label "VOLCOMP" ;
    ns1:identificador "VOLCOMP" ;
    ns1:textoExtracto "VOLCOMP Tablas de compensación volumétrica. Este parámetro muestra las tablas de compensación volumétrica." .

ns1:TablaCompensacionVolumetrica a ns1:Tabla ;
    rdfs:label "Tabla de compensación volumétrica" ;
    ns1:textoExtracto "VOLCOMP n Configuración de las tablas de compensación volumétrica. Este parámetro muestra la tabla de parámetros para definir las compensaciones volumétricas del sistema." ;
    ns1:tieneComponente ns1:VCOMPAXIS1,
        ns1:VCOMPAXIS2,
        ns1:VCOMPAXIS3,
        ns1:VCOMPFILE .

ns1:VCOMPAXIS1 a ns1:Parametro ;
    rdfs:label "VCOMPAXIS1" ;
    ns1:identificador "VCOMPAXIS1" ;
    ns1:textoExtracto "VCOMPAXIS1: Nombre del primer eje a compensar." .

ns1:VCOMPAXIS2 a ns1:Parametro ;
    rdfs:label "VCOMPAXIS2" ;
    ns1:identificador "VCOMPAXIS2" ;
    ns1:textoExtracto "VCOMPAXIS2: Nombre del segundo eje a compensar." .

ns1:VCOMPAXIS3 a ns1:Parametro ;
    rdfs:label "VCOMPAXIS3" ;
    ns1:identificador "VCOMPAXIS3" ;
    ns1:textoExtracto "VCOMPAXIS3: Nombre del tercer eje a compensar." .

ns1:VCOMPFILE a ns1:Parametro ;
    rdfs:label "VCOMPFILE" ;
    ns1:identificador "VCOMPFILE" ;
    ns1:textoExtracto "VCOMPFILE: Archivo con los datos de la compensación volumétrica." .

ns1:VOLCOMP1 a ns1:Parametro ;
    rdfs:label "VOLCOMP1" ;
    ns1:identificador "VOLCOMP1" ;
    ns1:textoExtracto "Las compensaciones volumétricas [...] se activan desde el PLC (marcas VOLCOMP1 a VOLCOMP4)." .

ns1:VOLCOMP2 a ns1:Parametro ;
    rdfs:label "VOLCOMP2" ;
    ns1:identificador "VOLCOMP2" ;
    ns1:textoExtracto "Las compensaciones volumétricas [...] se activan desde el PLC (marcas VOLCOMP1 a VOLCOMP4)." .

ns1:VOLCOMP3 a ns1:Parametro ;
    rdfs:label "VOLCOMP3" ;
    ns1:identificador "VOLCOMP3" ;
    ns1:textoExtracto "Las compensaciones volumétricas [...] se activan desde el PLC (marcas VOLCOMP1 a VOLCOMP4)." .

ns1:VOLCOMP4 a ns1:Parametro ;
    rdfs:label "VOLCOMP4" ;
    ns1:identificador "VOLCOMP4" ;
    ns1:textoExtracto "Las compensaciones volumétricas [...] se activan desde el PLC (marcas VOLCOMP1 a VOLCOMP4)." .

