@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_NPOINTSAX1 a ns1:Parametro ;
    rdfs:label "NPOINTSAX1" ;
    ns1:documentadoEn ns1:Tabla_VOLCOMP ;
    ns1:identificador "NPOINTSAX1" ;
    ns1:textoExtracto "NPOINTSAX1 [...] Número de puntos de la compensación volumétrica básica para el eje MOVAXIS. Valores posibles: De 2 a 1000 puntos. Variable asociada: (V.)MPG.NPOINTSAX1[tbl]" ;
    ns1:valor "Rango: 2-1000 puntos ; Variable: (V.)MPG.NPOINTSAX1[tbl]" .

ns1:Parametro_NPOINTSAX2 a ns1:Parametro ;
    rdfs:label "NPOINTSAX2" ;
    ns1:documentadoEn ns1:Tabla_VOLCOMP ;
    ns1:identificador "NPOINTSAX2" ;
    ns1:textoExtracto "NPOINTSAX2 [...] Número de puntos de la compensación volumétrica básica. Variable asociada: (V.)MPG.NPOINTSAX2[tbl]" ;
    ns1:valor "Rango: 2-1000 puntos ; Variable: (V.)MPG.NPOINTSAX2[tbl]" .

ns1:Parametro_NPOINTSAX3 a ns1:Parametro ;
    rdfs:label "NPOINTSAX3" ;
    ns1:documentadoEn ns1:Tabla_VOLCOMP ;
    ns1:identificador "NPOINTSAX3" ;
    ns1:textoExtracto "NPOINTSAX3 [...] Número de puntos de la compensación volumétrica básica. Variable asociada: (V.)MPG.NPOINTSAX3[tbl]" ;
    ns1:valor "Rango: 2-1000 puntos ; Variable: (V.)MPG.NPOINTSAX3[tbl]" .

ns1:Parametro_VCOMPFILE a ns1:Parametro ;
    rdfs:label "VCOMPFILE" ;
    ns1:identificador "VCOMPFILE" ;
    ns1:textoExtracto "El CNC muestra estos parámetros al cargar un archivo con extensión csv en el parámetro VCOMPFILE." ;
    ns1:valor "Formato: archivo CSV" .

ns1:Parametro_VMOVAXIS1 a ns1:Parametro ;
    rdfs:label "VMOVAXIS1" ;
    ns1:documentadoEn ns1:Tabla_VOLCOMP ;
    ns1:identificador "VMOVAXIS1" ;
    ns1:textoExtracto "VMOVAXIS1 [...] Nombre del eje que al moverse genera variaciones. Valores posibles: Cualquier eje definido en AXISNAME. Variable asociada: (V.)MPG.VMOVAXIS1[tbl]" ;
    ns1:valor "Variable: (V.)MPG.VMOVAXIS1[tbl]" .

ns1:Parametro_VMOVAXIS2 a ns1:Parametro ;
    rdfs:label "VMOVAXIS2" ;
    ns1:documentadoEn ns1:Tabla_VOLCOMP ;
    ns1:identificador "VMOVAXIS2" ;
    ns1:textoExtracto "VMOVAXIS2 [...] Nombre del eje que al moverse genera variaciones. Variable asociada: (V.)MPG.VMOVAXIS2[tbl]" ;
    ns1:valor "Variable: (V.)MPG.VMOVAXIS2[tbl]" .

ns1:Parametro_VMOVAXIS3 a ns1:Parametro ;
    rdfs:label "VMOVAXIS3" ;
    ns1:documentadoEn ns1:Tabla_VOLCOMP ;
    ns1:identificador "VMOVAXIS3" ;
    ns1:textoExtracto "VMOVAXIS3 [...] Nombre del eje que al moverse genera variaciones. Variable asociada: (V.)MPG.VMOVAXIS3[tbl]" ;
    ns1:valor "Variable: (V.)MPG.VMOVAXIS3[tbl]" .

ns1:Tabla_VOLCOMP a ns1:Tabla ;
    rdfs:label "Tabla VOLCOMP" ;
    ns1:identificador "VOLCOMP" ;
    ns1:textoExtracto "Parámetro incluido en la tabla VOLCOMP. [...] El CNC muestra estos parámetros al cargar un archivo con extensión csv en el parámetro VCOMPFILE." .

