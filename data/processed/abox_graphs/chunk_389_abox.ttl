@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_CNC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz CNC" ;
    ns1:monitoreaParametro ns1:Parametro_INIPOSAX1,
        ns1:Parametro_INIPOSAX2,
        ns1:Parametro_INIPOSAX3,
        ns1:Parametro_VCOMPFILE ;
    ns1:textoExtracto "El CNC muestra estos parámetros al cargar un archivo con extensión csv en el parámetro VCOMPFILE." .

ns1:Parametro_INIPOSAX1 a ns1:Parametro ;
    rdfs:label "INIPOSAX1" ;
    ns1:identificador "V.MPG.INIPOSAX1[tbl]" ;
    ns1:textoExtracto "INIPOSAX1 [...] Posición inicial de la compensación volumétrica básica para el eje MOVAXIS. Valores posibles: Entre ±99999.9999 mm / Entre ±3937.00787 inch. Valor por defecto: 0." ;
    ns1:valor "0" .

ns1:Parametro_INIPOSAX2 a ns1:Parametro ;
    rdfs:label "INIPOSAX2" ;
    ns1:identificador "V.MPG.INIPOSAX2[tbl]" ;
    ns1:textoExtracto "INIPOSAX2 [...] Posición inicial de la compensación volumétrica básica para el eje MOVAXIS." .

ns1:Parametro_INIPOSAX3 a ns1:Parametro ;
    rdfs:label "INIPOSAX3" ;
    ns1:identificador "V.MPG.INIPOSAX3[tbl]" ;
    ns1:textoExtracto "INIPOSAX3 [...] Posición inicial de la compensación volumétrica básica para el eje MOVAXIS." .

ns1:Parametro_VCOMPFILE a ns1:Parametro ;
    rdfs:label "VCOMPFILE" ;
    ns1:identificador "VCOMPFILE" ;
    ns1:textoExtracto "El CNC muestra estos parámetros al cargar un archivo con extensión csv en el parámetro VCOMPFILE." .

