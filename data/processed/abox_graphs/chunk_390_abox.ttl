@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_VOLCOMP a ns1:Tabla ;
    rdfs:label "Tabla VOLCOMP" ;
    ns1:textoExtracto "Parámetro incluido en la tabla VOLCOMP." ;
    ns1:tieneComponente ns1:Parametro_INCREAX1,
        ns1:Parametro_INCREAX2,
        ns1:Parametro_INCREAX3,
        ns1:Parametro_INIPOSAX1,
        ns1:Parametro_INIPOSAX2,
        ns1:Parametro_INIPOSAX3,
        ns1:Parametro_VCOMPAXIS1,
        ns1:Parametro_VCOMPAXIS2,
        ns1:Parametro_VCOMPAXIS3 .

ns1:Parametro_INCREAX1 a ns1:Parametro ;
    rdfs:label "INCREAX1" ;
    ns1:identificador "MPG.INCREAX1[tbl]" ;
    ns1:textoExtracto "Intervalo entre puntos para el eje MOVAXIS en la compensación volumétrica básica. Valores posibles: Entre ±99999.9999 mm / Entre ±3937.00787 inch. Valor por defecto: 10 mm / 0.3937 inch." ;
    ns1:valor "10" .

ns1:Parametro_INCREAX2 a ns1:Parametro ;
    rdfs:label "INCREAX2" ;
    ns1:identificador "MPG.INCREAX2[tbl]" ;
    ns1:textoExtracto "Intervalo entre puntos para el eje MOVAXIS en la compensación volumétrica básica." ;
    ns1:valor "10" .

ns1:Parametro_INCREAX3 a ns1:Parametro ;
    rdfs:label "INCREAX3" ;
    ns1:identificador "MPG.INCREAX3[tbl]" ;
    ns1:textoExtracto "Intervalo entre puntos para el eje MOVAXIS en la compensación volumétrica básica." ;
    ns1:valor "10" .

ns1:Parametro_INIPOSAX1 a ns1:Parametro ;
    rdfs:label "INIPOSAX1" ;
    ns1:identificador "MPG.INIPOSAX1[tbl]" ;
    ns1:textoExtracto "Posición inicial de la compensación volumétrica básica para el eje MOVAXIS. Valores posibles: Entre ±99999.9999 mm / Entre ±3937.00787 inch. Valor por defecto: 0." ;
    ns1:valor "0" .

ns1:Parametro_INIPOSAX2 a ns1:Parametro ;
    rdfs:label "INIPOSAX2" ;
    ns1:identificador "MPG.INIPOSAX2[tbl]" ;
    ns1:textoExtracto "Posición inicial de la compensación volumétrica básica para el eje MOVAXIS." ;
    ns1:valor "0" .

ns1:Parametro_INIPOSAX3 a ns1:Parametro ;
    rdfs:label "INIPOSAX3" ;
    ns1:identificador "MPG.INIPOSAX3[tbl]" ;
    ns1:textoExtracto "Posición inicial de la compensación volumétrica básica para el eje MOVAXIS." ;
    ns1:valor "0" .

ns1:Parametro_VCOMPAXIS1 a ns1:Parametro ;
    rdfs:label "VCOMPAXIS1" ;
    ns1:identificador "MPG.VCOMPAXIS1[tbl]" ;
    ns1:textoExtracto "Nombre del eje a compensar. Valores posibles: Cualquier eje definido en AXISNAME. Valor por defecto: Ninguno." .

ns1:Parametro_VCOMPAXIS2 a ns1:Parametro ;
    rdfs:label "VCOMPAXIS2" ;
    ns1:identificador "MPG.VCOMPAXIS2[tbl]" ;
    ns1:textoExtracto "Nombre del eje a compensar." .

ns1:Parametro_VCOMPAXIS3 a ns1:Parametro ;
    rdfs:label "VCOMPAXIS3" ;
    ns1:identificador "MPG.VCOMPAXIS3[tbl]" ;
    ns1:textoExtracto "Nombre del eje a compensar." .

