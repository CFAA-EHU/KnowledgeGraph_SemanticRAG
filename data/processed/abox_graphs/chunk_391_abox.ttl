@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_VCOMPAXIS1 a ns1:Parametro ;
    rdfs:label "Variable MPG.VCOMPAXIS1"@es ;
    ns1:documentadoEn ns1:Tabla_VOLCOMP ;
    ns1:identificador "MPG.VCOMPAXIS1" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.VCOMPAXIS1[tbl]"@es .

ns1:Parametro_VCOMPAXIS2 a ns1:Parametro ;
    rdfs:label "Variable MPG.VCOMPAXIS2"@es ;
    ns1:documentadoEn ns1:Tabla_VOLCOMP ;
    ns1:identificador "MPG.VCOMPAXIS2" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.VCOMPAXIS2[tbl]"@es .

ns1:Parametro_VCOMPAXIS3 a ns1:Parametro ;
    rdfs:label "Variable MPG.VCOMPAXIS3"@es ;
    ns1:documentadoEn ns1:Tabla_VOLCOMP ;
    ns1:identificador "MPG.VCOMPAXIS3" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.VCOMPAXIS3[tbl]"@es .

ns1:Tabla_VOLCOMP a ns1:Tabla ;
    rdfs:label "Tabla de compensación volumétrica (VOLCOMP)"@es ;
    ns1:identificador "VOLCOMP" ;
    ns1:textoExtracto "Parámetro incluido en la tabla VOLCOMP. Estos parámetros definen los ejes a compensar mediante la compensación volumétrica."@es .

