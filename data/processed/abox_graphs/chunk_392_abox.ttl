@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_INCHES a ns1:Parametro ;
    rdfs:label "INCHES" ;
    ns1:identificador "INCHES" ;
    ns1:textoExtracto "Las unidades de los datos del archivo (milímetros o pulgadas) deben ser las definidas en el CNC (parámetro INCHES)."@es ;
    ns1:valor "Unidad de medida (milímetros/pulgadas)"@es .

ns1:Parametro_VCOMPFILE a ns1:Parametro ;
    rdfs:label "VCOMPFILE" ;
    ns1:documentadoEn ns1:TablaCompensacionVolumetrica_VOLCOMP ;
    ns1:identificador "VCOMPFILE" ;
    ns1:textoExtracto "VCOMPFILE Archivo con los datos de la compensación volumétrica. Variable asociada: (V.)MPG.VCOMPFILE[tbl]. El archivo con los datos a compensar será un archivo de texto (formato csv). El OEM o la empresa responsable de la calibración deben generar este archivo y definirlo en el parámetro máquina VCOMPFILE."@es ;
    ns1:valor "Archivo CSV con datos de compensación volumétrica"@es .

ns1:TablaCompensacionVolumetrica_VOLCOMP a ns1:Tabla ;
    rdfs:label "Tabla VOLCOMP" ;
    ns1:identificador "VOLCOMP" ;
    ns1:textoExtracto "Las tablas de compensación las genera la aplicación de calibración; no son editables desde el CNC. Parámetro incluido en la tabla VOLCOMP."@es .

