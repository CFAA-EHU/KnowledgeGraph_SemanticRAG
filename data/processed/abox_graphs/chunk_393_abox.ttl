@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:MINAENDW a ns1:Parametro ;
    rdfs:label "MINAENDW" ;
    ns1:controla ns1:Senal_AUXEND,
        ns1:Senal_HSTROBE,
        ns1:Senal_MSTROBE ;
    ns1:identificador "MINAENDW" ;
    ns1:monitoreaParametro ns1:Variable_MPG_MINAENDW ;
    ns1:textoExtracto "MINAENDW Duración mínima de la señal AUXEND. Valores posibles: De 0 a 65535 ms. Valor por defecto: 10 ms." ;
    ns1:valor 10 .

ns1:Parametro_REFTIME a ns1:Parametro ;
    rdfs:label "REFTIME" ;
    ns1:identificador "REFTIME" ;
    ns1:textoExtracto "REFTIME Tiempo estimado para la búsqueda de cero." .

ns1:Senal_AUXEND a ns1:ComponenteElectrico ;
    rdfs:label "AUXEND" ;
    ns1:textoExtracto "señal AUXEND [...] señal de sincronización que el PLC envía al CNC indicando que ha terminado la ejecución de las funciones auxiliares –M–, –S–, –T–" .

ns1:Senal_HSTROBE a ns1:ComponenteElectrico ;
    rdfs:label "HSTROBE" ;
    ns1:textoExtracto "señal HSTROBE [...] para las funciones –H– (que no necesitan sincronización)" .

ns1:Senal_MSTROBE a ns1:ComponenteElectrico ;
    rdfs:label "MSTROBE" ;
    ns1:textoExtracto "señal MSTROBE [...] para las funciones –M– que no necesitan sincronización" .

ns1:Variable_MPG_MINAENDW a ns1:Parametro ;
    rdfs:label "(V.)MPG.MINAENDW" ;
    ns1:identificador "MPG.MINAENDW" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.MINAENDW" .

