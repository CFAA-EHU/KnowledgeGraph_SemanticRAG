@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_General a ns1:Maquina ;
    rdfs:label "Máquina (parámetros generales)" ;
    ns1:textoExtracto "Consultar el parámetro máquina general TTIME" ;
    ns1:tieneComponente ns1:Parametro_DTIME,
        ns1:Parametro_HTIME,
        ns1:Parametro_REFTIME,
        ns1:Parametro_TTIME .

ns1:Parametro_DTIME a ns1:Parametro ;
    rdfs:label "DTIME" ;
    ns1:identificador "MPG.DTIME" ;
    ns1:textoExtracto "DTIME Tiempo estimado para una función D. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0. ms. Variable asociada: (V.)MPG.DTIME" ;
    ns1:valor "0" .

ns1:Parametro_HTIME a ns1:Parametro ;
    rdfs:label "HTIME" ;
    ns1:identificador "MPG.HTIME" ;
    ns1:textoExtracto "HTIME Tiempo estimado para una función H. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0. ms. Variable asociada: (V.)MPG.HTIME" ;
    ns1:valor "0" .

ns1:Parametro_REFTIME a ns1:Parametro ;
    rdfs:label "REFTIME" ;
    ns1:identificador "MPG.REFTIME" ;
    ns1:textoExtracto "REFTIME Tiempo estimado para la búsqueda de cero. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0. ms. Variable asociada: (V.)MPG.REFTIME" ;
    ns1:valor "0" .

ns1:Parametro_TTIME a ns1:Parametro ;
    rdfs:label "TTIME" ;
    ns1:identificador "MPG.TTIME" ;
    ns1:textoExtracto "TTIME Tiempo estimado para una función T. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0. ms." ;
    ns1:valor "0" .

