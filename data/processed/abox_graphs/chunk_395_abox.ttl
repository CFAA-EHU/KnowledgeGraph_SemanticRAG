@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Funcion_D a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función D" ;
    ns1:textoExtracto "Los valores son genéricos, para cualquier función H, D, T o búsqueda de uno o de varios ejes a la vez." .

ns1:Funcion_H a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función H" ;
    ns1:textoExtracto "Los valores son genéricos, para cualquier función H, D, T o búsqueda de uno o de varios ejes a la vez." .

ns1:Funcion_T a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función T" ;
    ns1:monitoreaParametro ns1:Parametro_TTIME ;
    ns1:textoExtracto "Tiempo estimado para una función T" .

ns1:Parametro_BusquedaEjes a ns1:Parametro ;
    rdfs:label "Búsqueda de ejes" ;
    ns1:textoExtracto "búsqueda de uno o de varios ejes a la vez" .

ns1:ModoOperacion_EdicionSimulacion a ns1:ModoOperacion ;
    rdfs:label "Edición - Simulación" ;
    ns1:textoExtracto "En el modo de trabajo edición - simulación hay una opción que permite calcular el tiempo que se necesitará para ejecutar la pieza con las condiciones de mecanizado establecidas en el programa." .

ns1:Parametro_TTIME a ns1:Parametro ;
    rdfs:label "TTIME" ;
    ns1:identificador "MPG.TTIME" ;
    ns1:monitoreaParametro ns1:ModoOperacion_EdicionSimulacion ;
    ns1:textoExtracto "TTIME Tiempo estimado para una función T. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0. ms. Variable asociada: (V.)MPG.TTIME" ;
    ns1:valor "0" .

