@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_MTIME a ns1:Parametro ;
    rdfs:label "Parámetro máquina MTIME"@es ;
    ns1:identificador "MTIME" ;
    ns1:monitoreaParametro ns1:Funcion_M ;
    ns1:textoExtracto "El parámetro máquina de la tabla de funciones –M– MTIME indica el tiempo estimado para la ejecución de una función M."@es .

ns1:Parametro_SPDLTIME a ns1:Parametro ;
    rdfs:label "Parámetro máquina SPDLTIME"@es ;
    ns1:identificador "SPDLTIME" ;
    ns1:monitoreaParametro ns1:Funcion_S ;
    ns1:textoExtracto "El parámetro máquina de cabezales SPDLTIME indica el tiempo estimado para la ejecución de una función S."@es .

ns1:Tabla_Funciones_M a ns1:Tabla ;
    rdfs:label "Tabla de funciones –M–"@es ;
    ns1:documentadoEn ns1:Manual_Broaching ;
    ns1:textoExtracto "El parámetro máquina de la tabla de funciones –M– MTIME indica el tiempo estimado para la ejecución de una función M."@es .

ns1:Funcion_M a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función M"@es ;
    ns1:textoExtracto "El parámetro máquina de la tabla de funciones –M– MTIME indica el tiempo estimado para la ejecución de una función M."@es .

ns1:Funcion_S a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función S"@es ;
    ns1:textoExtracto "El parámetro máquina de cabezales SPDLTIME indica el tiempo estimado para la ejecución de una función S."@es .

