@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_NumeracionEntradasDigitales_CANopen_ADDRESS a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "ADDRESS"@es ;
    ns1:documentadoEn ns1:Tabla_NumeracionEntradasDigitales_CANopen ;
    ns1:textoExtracto "Dirección base del bloque lógico."@es .

ns1:Tabla_NumeracionEntradasDigitales_CANopen_BLOCK a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "BLOCK"@es ;
    ns1:documentadoEn ns1:Tabla_NumeracionEntradasDigitales_CANopen ;
    ns1:textoExtracto "Número de bloque lógico."@es .

ns1:Tabla_NumeracionEntradasDigitales_CANopen_MNEMONIC a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "MNEMONIC"@es ;
    ns1:documentadoEn ns1:Tabla_NumeracionEntradasDigitales_CANopen ;
    ns1:textoExtracto "Mnemónico del bloque lógico."@es .

ns1:Tabla_NumeracionEntradasDigitales_CANopen_NDI a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "NDI"@es ;
    ns1:documentadoEn ns1:Tabla_NumeracionEntradasDigitales_CANopen ;
    ns1:textoExtracto "Número de entradas digitales del módulo."@es .

ns1:Tabla_NumeracionEntradasDigitales_CANopen_NODE a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "NODE"@es ;
    ns1:documentadoEn ns1:Tabla_NumeracionEntradasDigitales_CANopen ;
    ns1:textoExtracto "Número de nodo de la cabecera al que pertenece el bloque lógico de I/Os."@es .

ns1:Tabla_NumeracionEntradasDigitales_CANopen a ns1:Tabla ;
    rdfs:label "Tabla de numeración de entradas digitales (bus CANopen)"@es ;
    ns1:textoExtracto "NDI | Número de entradas digitales del módulo."@es .

