@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_ADDRESS a ns1:Parametro ;
    rdfs:label "ADDRESS" ;
    ns1:documentadoEn ns1:Tabla_144 ;
    ns1:textoExtracto "Dirección base del bloque lógico."@es .

ns1:Parametro_BLOCK a ns1:Parametro ;
    rdfs:label "BLOCK" ;
    ns1:documentadoEn ns1:Tabla_144 ;
    ns1:textoExtracto "Número de bloque lógico."@es .

ns1:Parametro_MNEMONIC a ns1:Parametro ;
    rdfs:label "MNEMONIC" ;
    ns1:documentadoEn ns1:Tabla_144 ;
    ns1:textoExtracto "Mnemónico del bloque lógico."@es .

ns1:Parametro_NDO a ns1:Parametro ;
    rdfs:label "NDO" ;
    ns1:documentadoEn ns1:Tabla_144 ;
    ns1:textoExtracto "Número de salidas digitales del módulo."@es .

ns1:Parametro_NODE a ns1:Parametro ;
    rdfs:label "NODE" ;
    ns1:documentadoEn ns1:Tabla_144 ;
    ns1:textoExtracto "Número de nodo de la cabecera al que pertenece el bloque lógico de I/Os."@es .

ns1:Tabla_144 a ns1:Tabla ;
    rdfs:label "Tabla de numeración de salidas digitales (bus CANopen)"@es ;
    ns1:documentadoEn ns1:Pagina_88,
        ns1:Pagina_89 ;
    ns1:textoExtracto "NDO | Número de salidas digitales del módulo."@es .

