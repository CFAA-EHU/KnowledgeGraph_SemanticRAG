@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:SistemaCANopen_146 a ns1:Sistema ;
    rdfs:label "Sistema de numeración de salidas digitales (bus CANopen)"@es ;
    ns1:textoExtracto "El máximo número de bloques lógicos en el sistema será 64, tanto para entradas como para salidas digitales."@es ;
    ns1:tieneComponente ns1:Parametro_DOMODADDR_146 .

ns1:Parametro_DOMODADDR_146 a ns1:Parametro ;
    rdfs:label "ADDRESS (MPG.DOMODADDR[nb])"@es ;
    ns1:identificador "MPG.DOMODADDR[nb]" ;
    ns1:textoExtracto "ADDRESS Dirección base del bloque lógico. Valores posibles: De 1 a 1017. Valor por defecto: El primer valor válido. Variable asociada: (V.)MPG.DOMODADDR[nb] Este parámetro establece el índice base a partir del cual se numeran las salidas digitales del bloque lógico. Los valores del índice base deben cumplir con la fórmula '8n + 1' (es decir, 1, 9, 17, 25 ...)."@es ;
    ns1:valor 1 .

