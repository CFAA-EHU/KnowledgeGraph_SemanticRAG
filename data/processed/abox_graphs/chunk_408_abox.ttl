@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Modulo_Doble_RIO5 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo doble RIO5 (dos placas)" ;
    ns1:compuestoPor ns1:Placa_RIO5_1,
        ns1:Placa_RIO5_2 ;
    ns1:textoExtracto "En los nodos RIO5, cada módulo doble (módulo con dos placas) cuenta como dos; es decir, dos bloques lógicos. A estos módulos se les debe asignar dos índices base para las entradas y dos índice base para las salidas; uno para cada placa." .

ns1:Sistema_CANopen a ns1:Sistema ;
    rdfs:label "Sistema de numeración de salidas digitales (bus CANopen)" ;
    ns1:textoExtracto "a partir del cual se numeran las salidas digitales del bloque lógico. Los valores del índice base deben cumplir con la fórmula '8n + 1' (es decir, 1, 9, 17, 25 ...)." ;
    ns1:tieneComponente ns1:Parametro_NDO .

ns1:Parametro_NDO a ns1:Parametro ;
    rdfs:label "Número de salidas digitales del bloque lógico (NDO)" ;
    ns1:identificador "NDO" ;
    ns1:textoExtracto "NDO Número de salidas digitales del bloque lógico. Valores posibles: De 8 a 1024. Valor por defecto: 0. Variable asociada: (V.)MPG.DOMODNDO[nb] Número de salidas digitales del bloque lógico; no puede ser cero y debe ser un múltiplo de 8 (8, 16, 24, ...1024)." ;
    ns1:valor "8-1024 (múltiplos de 8)" .

ns1:Placa_RIO5_1 a ns1:ComponenteElectrico ;
    rdfs:label "Placa 1 del módulo doble RIO5" ;
    ns1:textoExtracto "dos bloques lógicos. A estos módulos se les debe asignar dos índices base para las entradas y dos índice base para las salidas; uno para cada placa." .

ns1:Placa_RIO5_2 a ns1:ComponenteElectrico ;
    rdfs:label "Placa 2 del módulo doble RIO5" ;
    ns1:textoExtracto "dos bloques lógicos. A estos módulos se les debe asignar dos índices base para las entradas y dos índice base para las salidas; uno para cada placa." .

