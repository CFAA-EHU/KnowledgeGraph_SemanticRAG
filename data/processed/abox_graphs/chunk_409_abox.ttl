@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_NPT100 a ns1:Parametro ;
    rdfs:label "NPT100" ;
    ns1:identificador "NPT100" ;
    ns1:textoExtracto "NPT100 Número total de entradas PT100 activas. Valores posibles: De 0 a 10. Valor por defecto: 0 (no hay entradas PT100 activas). Variable asociada: (V.)MPG.NPT100" ;
    ns1:valor 0 .

ns1:Parametro_PT100_EntradaAnalogica_n a ns1:Parametro ;
    rdfs:label "PT100[n] - Entrada analógica asociada" ;
    ns1:identificador "PT100[n]" ;
    ns1:textoExtracto "PT100 n Entrada analógica asociada a la entrada PT100. Valores posibles: De 0 a 32. Valor por defecto: 0 (no se desea activar la entrada PT100). Variable asociada: (V.)MPG.PT100[nb]" ;
    ns1:valor 0 .

ns1:Parametro_PT100_EntradasActivas a ns1:Parametro ;
    rdfs:label "Tabla de entradas PT100 activas" ;
    ns1:identificador "PT100" ;
    ns1:textoExtracto "PT100 Tabla de entradas PT100 activas. Este parámetro muestra la lista de entradas PT100 activas en el bus CAN." .

ns1:Sistema_Modulo_RIO5 a ns1:Sistema ;
    rdfs:label "Módulo RIO5" ;
    ns1:identificador "RIO5" ;
    ns1:textoExtracto "Los módulos RIO5 tienen 6 entradas analógicas; las cuatro entradas analógicas (AI1..AI4) más las dos entradas PT100 (AI5..AI6)." ;
    ns1:tieneComponente ns1:Componente_Entrada_AI1_RIO5,
        ns1:Componente_Entrada_AI2_RIO5,
        ns1:Componente_Entrada_AI3_RIO5,
        ns1:Componente_Entrada_AI4_RIO5,
        ns1:Componente_Entrada_PT100_AI5_RIO5,
        ns1:Componente_Entrada_PT100_AI6_RIO5 .

ns1:Sistema_Modulo_RIOR a ns1:Sistema ;
    rdfs:label "Módulo RIOR" ;
    ns1:identificador "RIOR" ;
    ns1:textoExtracto "Los módulos RIOR tienen 4 entradas analógicas; las dos entradas analógicas (AI1..AI2) más las dos entradas PT100 (AI3..AI4)." ;
    ns1:tieneComponente ns1:Componente_Entrada_AI1_RIOR,
        ns1:Componente_Entrada_AI2_RIOR,
        ns1:Componente_Entrada_PT100_AI3_RIOR,
        ns1:Componente_Entrada_PT100_AI4_RIOR .

ns1:SondaTemperatura_PT100 a ns1:Sensor ;
    rdfs:label "Sonda de temperatura PT100" ;
    ns1:textoExtracto "Una entrada PT100 debe estar activa si tiene una de estas sondas de temperatura conectada." .

ns1:Componente_Entrada_AI1_RIO5 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada analógica AI1 (RIO5)" ;
    ns1:identificador "AI1" ;
    ns1:textoExtracto "Entradas analógicas (AI1..AI4)" .

ns1:Componente_Entrada_AI1_RIOR a ns1:ComponenteElectrico ;
    rdfs:label "Entrada analógica AI1 (RIOR)" ;
    ns1:identificador "AI1" ;
    ns1:textoExtracto "las dos entradas analógicas (AI1..AI2)" .

ns1:Componente_Entrada_AI2_RIO5 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada analógica AI2 (RIO5)" ;
    ns1:identificador "AI2" ;
    ns1:textoExtracto "Entradas analógicas (AI1..AI4)" .

ns1:Componente_Entrada_AI2_RIOR a ns1:ComponenteElectrico ;
    rdfs:label "Entrada analógica AI2 (RIOR)" ;
    ns1:identificador "AI2" ;
    ns1:textoExtracto "las dos entradas analógicas (AI1..AI2)" .

ns1:Componente_Entrada_AI3_RIO5 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada analógica AI3 (RIO5)" ;
    ns1:identificador "AI3" ;
    ns1:textoExtracto "Entradas analógicas (AI1..AI4)" .

ns1:Componente_Entrada_AI4_RIO5 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada analógica AI4 (RIO5)" ;
    ns1:identificador "AI4" ;
    ns1:textoExtracto "Entradas analógicas (AI1..AI4)" .

ns1:Componente_Entrada_PT100_AI3_RIOR a ns1:Sensor ;
    rdfs:label "Entrada PT100 AI3 (RIOR)" ;
    ns1:identificador "AI3" ;
    ns1:textoExtracto "las dos entradas PT100 (AI3..AI4)" .

ns1:Componente_Entrada_PT100_AI4_RIOR a ns1:Sensor ;
    rdfs:label "Entrada PT100 AI4 (RIOR)" ;
    ns1:identificador "AI4" ;
    ns1:textoExtracto "las dos entradas PT100 (AI3..AI4)" .

ns1:Componente_Entrada_PT100_AI5_RIO5 a ns1:Sensor ;
    rdfs:label "Entrada PT100 AI5 (RIO5)" ;
    ns1:identificador "AI5" ;
    ns1:textoExtracto "las dos entradas PT100 (AI5..AI6)" .

ns1:Componente_Entrada_PT100_AI6_RIO5 a ns1:Sensor ;
    rdfs:label "Entrada PT100 AI6 (RIO5)" ;
    ns1:identificador "AI6" ;
    ns1:textoExtracto "las dos entradas PT100 (AI5..AI6)" .

