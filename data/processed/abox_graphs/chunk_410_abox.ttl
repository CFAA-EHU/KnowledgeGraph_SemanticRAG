@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Modulo_CNC a ns1:ComponenteElectrico ;
    rdfs:label "Módulo CNC (address = 0)" ;
    ns1:identificador "0" ;
    ns1:textoExtracto "address = 0) CNC • (address = 1) RIO5" .

ns1:Modulo_RIO5 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RIO5 (address = 1)" ;
    ns1:identificador "1" ;
    ns1:textoExtracto "(address = 1) RIO5 - Entradas analógicas. - 1..4 - Entradas PT100. - 5..6" ;
    ns1:tieneComponente ns1:Sensor_PT100_1,
        ns1:Sensor_PT100_2 .

ns1:Modulo_RIOR a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RIOR (address = 2)" ;
    ns1:identificador "2" ;
    ns1:textoExtracto "(address = 2) RIOR - Entradas analógicas. - 7..8 - Entradas PT100. - 9..10" ;
    ns1:tieneComponente ns1:Sensor_PT100_3 .

ns1:Parametro_NPT100 a ns1:Parametro ;
    rdfs:label "Número de entradas PT100 activas" ;
    ns1:textoExtracto "NPT100 = 3" ;
    ns1:valor "3" .

ns1:Sensor_PT100_1 a ns1:Sensor ;
    rdfs:label "Entrada PT100 1 (dirección 5)" ;
    ns1:identificador "5" ;
    ns1:textoExtracto "PT100 1 = 5" .

ns1:Sensor_PT100_2 a ns1:Sensor ;
    rdfs:label "Entrada PT100 2 (dirección 6)" ;
    ns1:identificador "6" ;
    ns1:textoExtracto "PT100 2 = 6" .

ns1:Sensor_PT100_3 a ns1:Sensor ;
    rdfs:label "Entrada PT100 3 (dirección 9)" ;
    ns1:identificador "9" ;
    ns1:textoExtracto "PT100 3 = 9" .

