@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_EntradaAnalogica_RIOR_16bit a ns1:Parametro ;
    rdfs:label "Rango de entrada analógica (16 bits)" ;
    ns1:textoExtracto "Entradas analógicas de 16 bits (15 bits + signo); es decir, unos valores entre ±32767." ;
    ns1:valor "±32767" .

ns1:Parametro_EntradaAnalogica_RIOR_20mA a ns1:Parametro ;
    rdfs:label "Rango de medida ±20 mA" ;
    ns1:monitoreaParametro ns1:ModuloRIOR ;
    ns1:textoExtracto "Rango de medida ±20 miliamperios." ;
    ns1:valor "±20" .

ns1:Parametro_FactorConversion_RIOR a ns1:Parametro ;
    rdfs:label "Factor de conversión (mA a decimiliamperios)" ;
    ns1:textoExtracto "Factor = 200 / 32767 = 0,0061035 (para devolver el valor en decimiliamperios)" ;
    ns1:valor "0.0061035" .

ns1:ModuloRIOR a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RIOR" ;
    ns1:identificador "RIOR" ;
    ns1:textoExtracto "Entradas analógicas del módulo RIOR. • Entradas analógicas de 16 bits (15 bits + signo); es decir, unos valores entre ±32767. • Rango de medida ±20 miliamperios." .

