@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PalpadorMedida a ns1:Sensor ;
    rdfs:label "Palpador de medida (mediciones en pieza)" ;
    ns1:compuestoPor ns1:PalpadorConfiguracion ;
    ns1:textoExtracto "palpador de medida para realizar mediciones en la pieza" .

ns1:Parametro_PROBE a ns1:Parametro ;
    rdfs:label "PROBE (Presencia de palpador)" ;
    ns1:identificador "MPG.PROBE" ;
    ns1:monitoreaParametro ns1:PalpadorConfiguracion ;
    ns1:textoExtracto "PROBE Hay algún palpador presente. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPG.PROBE" ;
    ns1:valor "Sí/No" .

ns1:Parametro_PROBEDATA a ns1:Parametro ;
    rdfs:label "PROBEDATA (Tabla de parámetros del palpador)" ;
    ns1:documentadoEn ns1:TablaParametrosPalpador ;
    ns1:identificador "PROBEDATA" ;
    ns1:textoExtracto "PROBEDATA Parámetros del palpador. Este parámetro muestra la tabla de parámetros necesarios para configurar el palpador." .

ns1:Parametro_PosicionPalpadorSobremesa a ns1:Parametro ;
    rdfs:label "Posición del palpador de sobremesa" ;
    ns1:monitoreaParametro ns1:PalpadorSobremesa ;
    ns1:textoExtracto "es necesario definir la posición del palpador [de sobremesa]." .

ns1:TablaParametrosPalpador a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de configuración del palpador" ;
    ns1:detalladoEnEsquema ns1:PalpadorConfiguracion ;
    ns1:textoExtracto "Este parámetro muestra la tabla de parámetros necesarios para configurar el palpador." .

ns1:PalpadorSobremesa a ns1:Sensor ;
    rdfs:label "Palpador de sobremesa (calibración de herramientas)" ;
    ns1:compuestoPor ns1:PalpadorConfiguracion ;
    ns1:textoExtracto "palpador de sobremesa para calibrar herramientas" ;
    ns1:tieneComponente ns1:Parametro_PosicionPalpadorSobremesa .

ns1:PalpadorConfiguracion a ns1:Sistema ;
    rdfs:label "Configuración de palpador en CNC" ;
    ns1:textoExtracto "PROBE Hay algún palpador presente. [...] El CNC puede tener configurados dos palpadores; habitualmente será un palpador de sobremesa para calibrar herramientas y un palpador de medida para realizar mediciones en la pieza." ;
    ns1:tieneComponente ns1:PalpadorMedida,
        ns1:PalpadorSobremesa,
        ns1:Parametro_PROBE,
        ns1:Parametro_PROBEDATA .

