    rdfs:label "PRBPULSE1" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionPalpador ;
    ns1:identificador "PRBPULSE1" ;
    ns1:textoExtracto "Nivel lógico de activación del palpador 1."@es .

ns1:Parametro_PRBPULSE2 a ns1:Parametro ;
