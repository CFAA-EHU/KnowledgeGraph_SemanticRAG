@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_PRBDI1 a ns1:Parametro ;
    rdfs:label "PRBDI1" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionPalpador ;
    ns1:identificador "PRBDI1" ;
    ns1:textoExtracto "Número de entrada asociada al palpador 1."@es .

ns1:Parametro_PRBDI2 a ns1:Parametro ;
    rdfs:label "PRBDI2" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionPalpador ;
    ns1:identificador "PRBDI2" ;
    ns1:textoExtracto "Número de entrada asociada al palpador 2."@es .

