    ns1:identificador "PROBETYPE2" ;
    ns1:textoExtracto "Tipo de palpador 2."@es .

ns1:Tabla_ConfiguracionPalpador a ns1:Tabla ;
    rdfs:label "Tabla PROBEDATA"@es ;
    ns1:textoExtracto "PROBEDATA"@es .

