@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EntradaLogica_PLC a ns1:ComponenteElectrico ;
    rdfs:label "Entrada lógica del PLC"@es ;
    ns1:textoExtracto "el PLC considera entradas lógicas a aquellas entradas que no existen como físicas"@es .

ns1:ModuloEntradas a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de entradas digitales"@es ;
    ns1:textoExtracto "La entrada digital podrá ser una entrada física del módulo"@es ;
    ns1:tieneComponente ns1:EntradaFisica_1a256 .

ns1:PalpadorLocal a ns1:ComponenteElectrico ;
    rdfs:label "Palpador local"@es ;
    ns1:monitoreaParametro ns1:Parametro_EntradaPalpador ;
    ns1:textoExtracto "para los palpadores locales, indica el número de la entrada local de palpador"@es .

ns1:PalpadorRemoto a ns1:ComponenteElectrico ;
    rdfs:label "Palpador remoto"@es ;
    ns1:monitoreaParametro ns1:Parametro_EntradaPalpador ;
    ns1:textoExtracto "Para los palpadores remotos, este parámetro indica el número de la entrada digital"@es .

ns1:Sensor_Proximidad a ns1:Sensor ;
    rdfs:label "Sensor de proximidad"@es ;
    ns1:textoExtracto "para un sensor de proximidad, no es necesario definir este parámetro."@es .

ns1:EntradaFisica_1a256 a ns1:ComponenteElectrico ;
    rdfs:label "Entradas físicas 1 a 256"@es ;
    ns1:identificador "1-256" ;
    ns1:textoExtracto "si en los módulos remotos están numeradas las entradas 1 a 256"@es .

ns1:Parametro_EntradaPalpador a ns1:Parametro ;
    rdfs:label "Parámetro de entrada del palpador"@es ;
    ns1:identificador "EntradaPalpador" ;
    ns1:textoExtracto "Este parámetro indica el número de la entrada a la que está conectado el palpador."@es .

