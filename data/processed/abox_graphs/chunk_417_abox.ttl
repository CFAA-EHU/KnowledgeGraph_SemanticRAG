@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModuloRemoto_EntradasLogicas a ns1:ComponenteElectrico ;
    rdfs:label "Módulo remoto de entradas lógicas" ;
    ns1:textoExtracto "si en los módulos remotos están numeradas las entradas 1 a 256, el PLC considera entradas lógicas de la 257 a la 1024" ;
    ns1:tieneComponente ns1:Palpador_1,
        ns1:Palpador_2 .

ns1:Palpador_1 a ns1:Sensor ;
    rdfs:label "Palpador 1" ;
    ns1:monitoreaParametro ns1:Parametro_PRBPULSE1 ;
    ns1:textoExtracto "PRBPULSE1 Nivel lógico de activación del palpador 1" .

ns1:Palpador_2 a ns1:Sensor ;
    rdfs:label "Palpador 2" ;
    ns1:monitoreaParametro ns1:Parametro_PRBPULSE2 ;
    ns1:textoExtracto "PRBPULSE2 Nivel lógico de activación del palpador 2" .

ns1:Parametro_PRBPULSE1 a ns1:Parametro ;
    rdfs:label "PRBPULSE1" ;
    ns1:documentadoEn ns1:Tabla_PROBEDATA ;
    ns1:identificador "PRBPULSE1" ;
    ns1:textoExtracto "PRBPULSE1 Nivel lógico de activación del palpador 1. Valores posibles: Positivo / Negativo. Valor por defecto: Positivo. Variable asociada: (V.)MPG.PRBPULSE1" ;
    ns1:valor "Positivo" .

ns1:Parametro_PRBPULSE2 a ns1:Parametro ;
    rdfs:label "PRBPULSE2" ;
    ns1:documentadoEn ns1:Tabla_PROBEDATA ;
    ns1:identificador "PRBPULSE2" ;
    ns1:textoExtracto "PRBPULSE2 Nivel lógico de activación del palpador 2. Valores posibles: Positivo / Negativo. Valor por defecto: Positivo." ;
    ns1:valor "Positivo" .

ns1:Tabla_PROBEDATA a ns1:Tabla ;
    rdfs:label "Tabla PROBEDATA" ;
    ns1:textoExtracto "Parámetro incluido en la tabla PROBEDATA." .

