@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Se_al_INTOL a ns1:Parametro ;
    rdfs:label "Señal INTOL (PLC)" ;
    ns1:textoExtracto "El palpado finalizará cuando se desactive la señal INTOL del PLC." ;
    ns1:valor "Desactivada"^^xsd:string .

ns1:Sensor_Palpador a ns1:Sensor ;
    rdfs:label "Sensor de palpador/proximidad" ;
    ns1:monitoreaParametro ns1:Parametro_PRBPULSE2 ;
    ns1:textoExtracto "Para utilizar el sensor de proximidad como palpador, definir PRBPULSE=negativo para utlizar G100 o PRBPULSE=positivo para G103. El palpado finalizará cuando se desactive la señal INTOL del PLC." .

ns1:Parametro_PRBPULSE2 a ns1:Parametro ;
    rdfs:label "Parámetro PRBPULSE2 (V.MPG.PRBPULSE2)" ;
    ns1:documentadoEn ns1:Tabla_PROBEDATA ;
    ns1:identificador "V.MPG.PRBPULSE2" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.PRBPULSE2. Este parámetro indica si las funciones del palpador actúan a nivel lógico alto (señal de 24V ó 5 V) o a nivel lógico bajo (señal de 0 V) de la señal que proporciona el palpador." ;
    ns1:valor "Positivo"^^xsd:string .

ns1:Tabla_PROBEDATA a ns1:Tabla ;
    rdfs:label "Tabla PROBEDATA" ;
    ns1:textoExtracto "Parámetro incluido en la tabla PROBEDATA." .

