@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Maquina_TerminalRemoto_HBH3_HBH4 a ns1:Maquina ;
    rdfs:label "Terminal remoto HBH3/HBH4" ;
    ns1:requiereMantenimiento ns1:RequisitoDeMemoriaParaHBH3HBH4 ;
    ns1:textoExtracto "necesita un tamaño de memoria de 4096 bytes" .

ns1:Sistema_MemoriaCompartidaPLC a ns1:Sistema ;
    rdfs:label "Memoria compartida del PLC" ;
    ns1:monitoreaParametro ns1:Parametro_PLCDATASIZE ;
    ns1:textoExtracto "área de memoria para intercambiar datos entre un programa PLC escrito en lenguaje C y una aplicación externa" .

ns1:Parametro_PLCDATASIZE a ns1:Parametro ;
    rdfs:label "PLCDATASIZE" ;
    ns1:identificador "V.MPG.PLCDATASIZE" ;
    ns1:textoExtracto "PLCDATASIZE Tamaño de la zona de datos compartida del PLC. Valores posibles: De 0 a 500.000 bytes. Valor por defecto: 0." ;
    ns1:valor 0 .

ns1:RequisitoDeMemoriaParaHBH3HBH4 a ns1:Parametro ;
    rdfs:label "Requisito de memoria para HBH3/HBH4" ;
    ns1:textoExtracto "4096 bytes" ;
    ns1:valor 4096 .

