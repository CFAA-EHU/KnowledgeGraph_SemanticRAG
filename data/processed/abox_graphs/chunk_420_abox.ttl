@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_EXPSCHK a ns1:Parametro ;
    rdfs:label "EXPSCHK" ;
    ns1:identificador "EXPSCHK" ;
    ns1:monitoreaParametro ns1:Sistema_EntradasSalidasLocales ;
    ns1:textoExtracto "EXPSCHK Activar la vigilancia de 24 V en las salidas digitales locales. Valores posibles: ON / OFF. Valor por defecto: ON. Variable asociada: (V.)MPG.EXPSCHK" ;
    ns1:valor "ON/OFF" .

ns1:Parametro_NLOCOUT a ns1:Parametro ;
    rdfs:label "NLOCOUT" ;
    ns1:identificador "NLOCOUT" ;
    ns1:monitoreaParametro ns1:Sistema_EntradasSalidasLocales ;
    ns1:textoExtracto "NLOCOUT Número de salidas digitales locales. Valores posibles: De 0 a 8. Valor por defecto: 0. Variable asociada: (V.)MPG.NLOCOUT" ;
    ns1:valor "0-8" .

ns1:ComponenteElectrico_Conector24V a ns1:ComponenteElectrico ;
    rdfs:label "Conector de alimentación 24V DC para salidas digitales locales" ;
    ns1:textoExtracto "Cuando hay activa alguna salida digital local, hay que alimentar el conector a 24 V DC. Este parámetro habilita la detección de estos 24 V en el conector." .

ns1:Componente_LIO1 a ns1:ComponenteElectrico ;
    rdfs:label "LI/O1" ;
    ns1:identificador "LI/O1" ;
    ns1:textoExtracto "señales digitales locales, identificadas como LI/O1 a LI/O8" .

ns1:Componente_LIO2 a ns1:ComponenteElectrico ;
    rdfs:label "LI/O2" ;
    ns1:identificador "LI/O2" ;
    ns1:textoExtracto "señales digitales locales, identificadas como LI/O1 a LI/O8. Para el PWM y conmutación sincronizada sólo se podrán utilizar las salidas locales asociadas a los pines LI/O1 y LI/O2, ya que están personalizadas para aplicaciones de láser." .

ns1:Componente_LIO3 a ns1:ComponenteElectrico ;
    rdfs:label "LI/O3" ;
    ns1:identificador "LI/O3" ;
    ns1:textoExtracto "señales digitales locales, identificadas como LI/O1 a LI/O8" .

ns1:Componente_LIO4 a ns1:ComponenteElectrico ;
    rdfs:label "LI/O4" ;
    ns1:identificador "LI/O4" ;
    ns1:textoExtracto "señales digitales locales, identificadas como LI/O1 a LI/O8" .

ns1:Componente_LIO5 a ns1:ComponenteElectrico ;
    rdfs:label "LI/O5" ;
    ns1:identificador "LI/O5" ;
    ns1:textoExtracto "señales digitales locales, identificadas como LI/O1 a LI/O8" .

ns1:Componente_LIO6 a ns1:ComponenteElectrico ;
    rdfs:label "LI/O6" ;
    ns1:identificador "LI/O6" ;
    ns1:textoExtracto "señales digitales locales, identificadas como LI/O1 a LI/O8" .

ns1:Componente_LIO7 a ns1:ComponenteElectrico ;
    rdfs:label "LI/O7" ;
    ns1:identificador "LI/O7" ;
    ns1:textoExtracto "señales digitales locales, identificadas como LI/O1 a LI/O8" .

ns1:Componente_LIO8 a ns1:ComponenteElectrico ;
    rdfs:label "LI/O8" ;
    ns1:identificador "LI/O8" ;
    ns1:textoExtracto "señales digitales locales, identificadas como LI/O1 a LI/O8" .

ns1:Sistema_EntradasSalidasLocales a ns1:Sistema ;
    rdfs:label "Sistema de E/S digitales locales LI/O1-LI/O8" ;
    ns1:controla ns1:ComponenteElectrico_Conector24V ;
    ns1:textoExtracto "La unidad central dispone de un conjunto de 8 señales digitales locales, identificadas como LI/O1 a LI/O8, que pueden configurarse tanto de entrada como de salida." ;
    ns1:tieneComponente ns1:Componente_LIO1,
        ns1:Componente_LIO2,
        ns1:Componente_LIO3,
        ns1:Componente_LIO4,
        ns1:Componente_LIO5,
        ns1:Componente_LIO6,
        ns1:Componente_LIO7,
        ns1:Componente_LIO8 .

