@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_NLOCOUT a ns1:Parametro ;
    rdfs:label "NLOCOUT" ;
    ns1:identificador "NLOCOUT" ;
    ns1:textoExtracto "Para la conmutación sincronizada sólo se podrán utilizar las salidas locales asociadas a los pines LI/O1 (salida local 1) y LI/O2 (salida local 2), ya que están personalizadas para aplicaciones de láser. Para ello será necesario parametrizar el parámetro NLOCOUT con valor 8." ;
    ns1:valor "8" .

ns1:Sistema_ConmutacionSincronizada a ns1:Sistema ;
    rdfs:label "Conmutación sincronizada" ;
    ns1:monitoreaParametro ns1:Parametro_SWTDELAY,
        ns1:Parametro_SWTG0FEED,
        ns1:Parametro_SWTOUTPUT ;
    ns1:textoExtracto "Se denomina conmutación sincronizada al proceso de controlar el estado de una salida digital local del CNC en función del tipo de movimiento programado en los ejes. Las transiciones de G0 a G1/G2/G3 activan la salida digital seleccionada. Las transiciones de G1/G2/G3 a G0 desactivan la salida digital seleccionada." ;
    ns1:tieneComponente ns1:ComponenteElectrico_LIO1,
        ns1:ComponenteElectrico_LIO2 .

ns1:ComponenteElectrico_LIO1 a ns1:ComponenteElectrico ;
    rdfs:label "Salida local LI/O1" ;
    ns1:identificador "LI/O1" ;
    ns1:textoExtracto "salidas locales asociadas a los pines LI/O1 (salida local 1)" .

ns1:ComponenteElectrico_LIO2 a ns1:ComponenteElectrico ;
    rdfs:label "Salida local LI/O2" ;
    ns1:identificador "LI/O2" ;
    ns1:textoExtracto "salidas locales asociadas a los pines LI/O2 (salida local 2)" .

ns1:Parametro_SWTDELAY a ns1:Parametro ;
    rdfs:label "SWTDELAY" ;
    ns1:identificador "MPG.SWTDELAY" ;
    ns1:textoExtracto "Retardo del dispositivo asociado a la conmutación sincronizada. Valores posibles: De 0 a 100 ms. Valor por defecto: 0 ms. Variable asociada: (V.)MPG.SWTDELAY" ;
    ns1:valor "0 ms" .

ns1:Parametro_SWTG0FEED a ns1:Parametro ;
    rdfs:label "SWTG0FEED" ;
    ns1:identificador "MPG.SWTG0FEED" ;
    ns1:textoExtracto "Respetar el avance G00 durante la conmutación sincronizada. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)MPG.SWTG0FEED" ;
    ns1:valor "Sí" .

ns1:Parametro_SWTOUTPUT a ns1:Parametro ;
    rdfs:label "SWTOUTPUT" ;
    ns1:identificador "MPG.SWTOUTPUT" ;
    ns1:textoExtracto "Salida digital local asociada a la conmutación sincronizada. Valores posibles: De 0 a NLOCOUT (Número de salidas digitales locales). Valor por defecto: 0. Variable asociada: (V.)MPG.SWTOUTPUT" ;
    ns1:valor "0" .

