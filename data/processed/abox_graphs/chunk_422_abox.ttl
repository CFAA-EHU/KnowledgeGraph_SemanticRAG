@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Comando_SWTOUT a ns1:InterfazUsuario ;
    rdfs:label "#SWTOUT" ;
    ns1:identificador "#SWTOUT" ;
    ns1:textoExtracto "Desde el programa pieza se puede modificar este comportamiento con la sentencia #SWTOUT." .

ns1:Parametro_SWTG0FEED a ns1:Parametro ;
    rdfs:label "SWTG0FEED" ;
    ns1:identificador "SWTG0FEED" ;
    ns1:textoExtracto "SWTG0FEED | Significado. Sí: Los tramos en G0 se ejecutan a avance rápido (parámetro G00FEED). No: El corte se ejecuta a avance constante (con el avance del G1/G2/G3 anterior), sin acelerar en los tramos en G0." ;
    ns1:valor "Sí/No" .

ns1:Tabla_ConmutacionSincronizada a ns1:Tabla ;
    rdfs:label "Conmutación sincronizada (SWTG0FEED)" ;
    ns1:documentadoEn ns1:Pagina_95 ;
    ns1:ilustradoEn ns1:ModoOperacion_AvanceConstante,
        ns1:ModoOperacion_AvanceRapido ;
    ns1:textoExtracto "SWTG0FEED | Significado. Sí: Los tramos en G0 se ejecutan a avance rápido (parámetro G00FEED). No: El corte se ejecuta a avance constante (con el avance del G1/G2/G3 anterior), sin acelerar en los tramos en G0." .

ns1:ModoOperacion_AvanceConstante a ns1:ModoOperacion ;
    rdfs:label "Avance constante (G1/G2/G3)" ;
    ns1:textoExtracto "El corte se ejecuta a avance constante (con el avance del G1/G2/G3 anterior), sin acelerar en los tramos en G0." .

ns1:ModoOperacion_AvanceRapido a ns1:ModoOperacion ;
    rdfs:label "Avance rápido (G0)" ;
    ns1:monitoreaParametro ns1:Parametro_G00FEED ;
    ns1:textoExtracto "Los tramos en G0 se ejecutan a avance rápido (parámetro G00FEED)." .

ns1:Pagina_95 a ns1:Pagina ;
    rdfs:label "Página 95" ;
    ns1:identificador "95" ;
    ns1:textoExtracto "Sección 2.3.28 Conmutación sincronizada." .

ns1:Parametro_G00FEED a ns1:Parametro ;
    rdfs:label "G00FEED" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "Los tramos en G0 se ejecutan a avance rápido (parámetro G00FEED)." .

