@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ControlPotenciaCNC a ns1:Sistema ;
    rdfs:label "Sistema de control de potencia del CNC" ;
    ns1:monitoreaParametro ns1:Variable_A_FEED_xn,
        ns1:Variable_A_TFEED_xn ;
    ns1:textoExtracto "El CNC permite controlar la potencia, del láser o del duty del PWM, en función del avance." ;
    ns1:tieneComponente ns1:Parametro_PWRCTRLACT,
        ns1:Parametro_PWRCTRLCANCEL .

ns1:Parametro_PWRCTRLACT a ns1:Parametro ;
    rdfs:label "PWRCTRLACT" ;
    ns1:identificador "(V.)MPG.PWRCTRLACT" ;
    ns1:monitoreaParametro ns1:Variable_A_FEED_xn,
        ns1:Variable_A_TFEED_xn ;
    ns1:textoExtracto "PWRCTRLACT Gestionar la potencia en función del avance real. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPG.PWRCTRLACT El CNC permite controlar la potencia, del láser o del duty del PWM, en función del avance. Este parámetro define qué avance debe usar el CNC para gestionar la potencia." ;
    ns1:valor "Sí, No" .

ns1:Parametro_PWRCTRLCANCEL a ns1:Parametro ;
    rdfs:label "PWRCTRLCANCEL" ;
    ns1:identificador "(V.)MPG.PWRCTRLCANCEL" ;
    ns1:textoExtracto "PWRCTRLCANCEL Cancelar el control de potencia con reset/M2/M30. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPG.PWRCTRLCANCEL Este parámetro indica si el CNC cancela el control de potencia tras ejecutar M02, M30 o después de un reset." ;
    ns1:valor "Sí, No" .

ns1:Variable_A_FEED_xn a ns1:Parametro ;
    rdfs:label "A.FEED.xn" ;
    ns1:identificador "(V.)A.FEED.xn" ;
    ns1:textoExtracto "avance real (variable (V.)A.FEED.xn)" .

ns1:Variable_A_TFEED_xn a ns1:Parametro ;
    rdfs:label "A.TFEED.xn" ;
    ns1:identificador "(V.)A.TFEED.xn" ;
    ns1:textoExtracto "avance teórico (variable (V.)A.TFEED.xn)" .

