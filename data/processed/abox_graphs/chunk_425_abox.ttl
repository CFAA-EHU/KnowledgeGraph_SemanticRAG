@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_GAPANAINID a ns1:Parametro ;
    rdfs:label "Número de entrada analógica conectada al sensor"@es ;
    ns1:documentadoEn ns1:Tabla_GAPCONTROL ;
    ns1:identificador "GAPANAINID" ;
    ns1:textoExtracto "GAPANAINID | Número de entrada analógica conectada al sensor."@es .

ns1:Parametro_GAPANAINTYPE a ns1:Parametro ;
    rdfs:label "Tipo de entrada analógica conectada al sensor"@es ;
    ns1:documentadoEn ns1:Tabla_GAPCONTROL ;
    ns1:identificador "GAPANAINTYPE" ;
    ns1:textoExtracto "GAPANAINTYPE | Tipo de entrada analógica conectada al sensor."@es .

ns1:Parametro_GAPAPPROACHDYN a ns1:Parametro ;
    rdfs:label "Respuesta dinámica en aproximación"@es ;
    ns1:documentadoEn ns1:Tabla_GAPCONTROL ;
    ns1:identificador "GAPAPPROACHDYN" ;
    ns1:textoExtracto "GAPAPPROACHDYN | Respuesta dinámica durante la parte final del movimiento de aproximación a la chapa."@es .

ns1:Parametro_GAPDISTLIMIT a ns1:Parametro ;
    rdfs:label "Distancia límite del sensor"@es ;
    ns1:documentadoEn ns1:Tabla_GAPCONTROL ;
    ns1:identificador "GAPDISTLIMIT" ;
    ns1:monitoreaParametro ns1:Sensor_GAP ;
    ns1:textoExtracto "GAPDISTLIMIT | Distancia que corresponde a la señal analógica límite del sensor."@es .

ns1:Parametro_GAPERRORCANCEL a ns1:Parametro ;
    rdfs:label "Anulación de error de gap"@es ;
    ns1:documentadoEn ns1:Tabla_GAPCONTROL ;
    ns1:identificador "GAPERRORCANCEL" ;
    ns1:textoExtracto "GAPERRORCANCEL | Anular el error de gap fuera del rango definido por GAPMIN/GAPMAX."@es .

ns1:Parametro_GAPGAIN a ns1:Parametro ;
    rdfs:label "Ganancia proporcional en GAPCTRL"@es ;
    ns1:documentadoEn ns1:Tabla_GAPCONTROL ;
    ns1:identificador "GAPGAIN" ;
    ns1:textoExtracto "GAPGAIN | Ganancia proporcional a aplicar en GAPCTRL."@es .

ns1:Parametro_GAPMIN a ns1:Parametro ;
    rdfs:label "Límite mínimo del sensor"@es ;
    ns1:documentadoEn ns1:Tabla_GAPCONTROL ;
    ns1:identificador "GAPMIN" ;
    ns1:monitoreaParametro ns1:Sensor_GAP ;
    ns1:textoExtracto "GAPMIN | Límite mínimo del sensor."@es .

ns1:Parametro_GAPSENSORCH a ns1:Parametro ;
    rdfs:label "Cambio de signo de la señal del sensor"@es ;
    ns1:documentadoEn ns1:Tabla_GAPCONTROL ;
    ns1:identificador "GAPSENSORCH" ;
    ns1:monitoreaParametro ns1:Sensor_GAP ;
    ns1:textoExtracto "GAPSENSORCH | Cambiar el signo de la señal del sensor."@es .

ns1:Parametro_GAPSENSORFILTER a ns1:Parametro ;
    rdfs:label "Configuración del filtro del sensor"@es ;
    ns1:documentadoEn ns1:Tabla_GAPCONTROL ;
    ns1:identificador "GAPSENSORFILTER" ;
    ns1:monitoreaParametro ns1:Sensor_GAP ;
    ns1:textoExtracto "GAPSENSORFILTER | Tabla para configurar el filtro del sensor."@es .

ns1:Parametro_GAPSENSOROFFSET a ns1:Parametro ;
    rdfs:label "Offset del sensor"@es ;
    ns1:documentadoEn ns1:Tabla_GAPCONTROL ;
    ns1:identificador "GAPSENSOROFFSET" ;
    ns1:monitoreaParametro ns1:Sensor_GAP ;
    ns1:textoExtracto "GAPSENSOROFFSET | Offset a aplicar al sensor."@es .

ns1:Parametro_GAPVOLTLIMIT a ns1:Parametro ;
    rdfs:label "Voltaje límite del sensor"@es ;
    ns1:documentadoEn ns1:Tabla_GAPCONTROL ;
    ns1:identificador "GAPVOLTLIMIT" ;
    ns1:monitoreaParametro ns1:Sensor_GAP ;
    ns1:textoExtracto "GAPVOLTLIMIT | Voltaje que corresponde al recorrido límite del sensor."@es .

ns1:Sensor_GAP a ns1:Sensor ;
    rdfs:label "Sensor de control del gap"@es ;
    ns1:textoExtracto "parámetro muestra la tabla para definir el control del gap [...] entrada analógica conectada al sensor [...] señal del sensor [...] recorrido límite del sensor."@es .

ns1:Tabla_GAPCONTROL a ns1:Tabla ;
    rdfs:label "Tabla de parámetros del control del gap"@es ;
    ns1:identificador "GAPCONTROL" ;
    ns1:textoExtracto "GAPCONTROL Tabla de parámetros del control del gap. Este parámetro muestra la tabla para definir el control del gap."@es .

