@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_GAPCOLLISIONMODE a ns1:Parametro ;
    rdfs:label "GAPCOLLISIONMODE" ;
    ns1:identificador "GAPCOLLISIONMODE" ;
    ns1:textoExtracto "Comportamiento del CNC ante una colisión del sensor." .

ns1:Parametro_GAPERRORCANCEL a ns1:Parametro ;
    rdfs:label "GAPERRORCANCEL" ;
    ns1:identificador "GAPERRORCANCEL" ;
    ns1:textoExtracto "Anular el error de gap fuera del rango definido por GAPMIN/GAPMAX." .

ns1:Parametro_GAPTOLCANCEL a ns1:Parametro ;
    rdfs:label "GAPTOLCANCEL" ;
    ns1:identificador "GAPTOLCANCEL" ;
    ns1:textoExtracto "Anular el error de gap fuera del rango definido por GAPTOL." .

ns1:Parametro_GAPTONEG a ns1:Parametro ;
    rdfs:label "GAPTONEG" ;
    ns1:identificador "GAPTONEG" ;
    ns1:textoExtracto "Bloque de movimiento en #GAPCTRL hacia cota descendente." .

ns1:Sensor_GAP a ns1:Sensor ;
    rdfs:label "Sensor de gap" ;
    ns1:monitoreaParametro ns1:Parametro_GAPANAINTYPE,
        ns1:Parametro_GAPMAX,
        ns1:Parametro_GAPMIN,
        ns1:Parametro_GAPTOL ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.GAPANAINTIME. Este parámetro indica dónde está ubicada la salida analógica conectada al sensor." .

ns1:Parametro_GAPANAINTYPE a ns1:Parametro ;
    rdfs:label "GAPANAINTYPE" ;
    ns1:identificador "GAPANAINTYPE" ;
    ns1:textoExtracto "Tipo de entrada analógica conectada al sensor. Valores posibles: Remoto CAN / Regulador / Captación / EtherCAT. Valor por defecto: Regulador." ;
    ns1:valor "Regulador" .

ns1:Parametro_GAPMAX a ns1:Parametro ;
    rdfs:label "GAPMAX" ;
    ns1:identificador "GAPMAX" ;
    ns1:textoExtracto "Límite máximo del sensor." ;
    ns1:valor "límite_máximo" .

ns1:Parametro_GAPMIN a ns1:Parametro ;
    rdfs:label "GAPMIN" ;
    ns1:identificador "GAPMIN" ;
    ns1:textoExtracto "Límite mínimo del sensor." ;
    ns1:valor "límite_mínimo" .

ns1:Parametro_GAPTOL a ns1:Parametro ;
    rdfs:label "GAPTOL" ;
    ns1:identificador "GAPTOL" ;
    ns1:textoExtracto "Margen de tolerancia del error." ;
    ns1:valor "margen_tolerancia" .

