@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BusEtherCAT a ns1:ComponenteElectrico ;
    rdfs:label "Bus EtherCAT"@es ;
    ns1:documentadoEn ns1:Tabla_166_EntradasGap ;
    ns1:textoExtracto "El sensor del gap está conectado a una entrada analógica del bus EtherCAT. Las entradas analógicas están disponibles en los módulos RIOW-E."@es ;
    ns1:tieneComponente ns1:ModuloRIOW_E .

ns1:ModuloRemotoCAN a ns1:ComponenteElectrico ;
    rdfs:label "Módulo remoto CAN"@es ;
    ns1:documentadoEn ns1:Tabla_166_EntradasGap ;
    ns1:textoExtracto "Entrada analógica en los módulos remotos CAN."@es .

ns1:ReguladorGap a ns1:ComponenteElectrico ;
    rdfs:label "Regulador del gap"@es ;
    ns1:monitoreaParametro ns1:ParametroGap ;
    ns1:textoExtracto "Entrada analógica en un regulador. [...] El sensor del gap está conectado a la entrada X3 del regulador."@es ;
    ns1:tieneComponente ns1:EntradaX3 .

ns1:SensorGap a ns1:Sensor ;
    rdfs:label "Sensor del gap"@es ;
    ns1:documentadoEn ns1:Tabla_166_EntradasGap ;
    ns1:textoExtracto "El sensor del gap está conectado a la entrada X3 del regulador. [...] El sensor del gap está conectado a una entrada analógica del bus EtherCAT."@es .

ns1:EntradaX3 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada X3 del regulador"@es ;
    ns1:documentadoEn ns1:Tabla_166_EntradasGap ;
    ns1:textoExtracto "El sensor del gap está conectado a la entrada X3 del regulador."@es .

ns1:ModuloRIOW_E a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RIOW-E"@es ;
    ns1:textoExtracto "Las entradas analógicas están disponibles en los módulos RIOW-E."@es .

ns1:ParametroGap a ns1:Parametro ;
    rdfs:label "Gap programado (GAPINPOSW)"@es ;
    ns1:textoExtracto "El CNC controla el eje del sensor hasta que alcanza el gap programado (teniendo en cuenta GAPINPOSW)."@es ;
    ns1:valor "GAPINPOSW" .

ns1:Tabla_166_EntradasGap a ns1:Tabla ;
    rdfs:label "Tabla de valores de entrada para control del gap"@es ;
    ns1:textoExtracto """
| Valor. | Significado. |
| --- | --- |
| Remoto CAN. | Entrada analógica en los módulos remotos CAN. |
| Regulador. | Entrada analógica en un regulador. |
| Captación. | Entrada de captación en un regulador. [...] |
| EtherCAT | El sensor del gap está conectado a una entrada analógica del bus EtherCAT. [...]"""@es .

