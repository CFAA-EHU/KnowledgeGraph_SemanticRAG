@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ModuloSalidasAnalogicas a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de salidas analógicas" ;
    ns1:textoExtracto "Los módulos de salidas analógicas se numeran según el orden lógico de los grupos remotos. Si hay más de un módulo de salidas analógicas dentro de cada grupo, el orden es de izquierda a derecha." ;
    ns1:tieneComponente ns1:SalidaAnalogica_1,
        ns1:SalidaAnalogica_2 .

ns1:Parametro_ConsignaAnalogica a ns1:Parametro ;
    rdfs:label "Parámetro de consigna analógica" ;
    ns1:monitoreaParametro ns1:ReguladorSercos,
        ns1:SalidaAnalogica_1,
        ns1:SalidaAnalogica_2 ;
    ns1:textoExtracto "este parámetro indica el número de la salida analógica que se utiliza para la consigna. [...] El parámetro se define mediante un número de tres dígitos; el primer dígito indica el número de la salida analógica a utilizar (1 ó 2) y los dos dígitos siguientes indican la dirección lógica del regulador (de 1 a 32)." ;
    ns1:valor "XXX"^^xsd:string .

ns1:ReguladorSercos a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos" ;
    ns1:identificador "1-32" ;
    ns1:textoExtracto "Gestión de la consigna analógica desde los reguladores Sercos. [...] La dirección lógica la establece el conmutador rotativo 'address'." .

ns1:SalidaAnalogica_1 a ns1:ComponenteElectrico ;
    rdfs:label "Salida analógica 1" ;
    ns1:identificador "1" ;
    ns1:textoExtracto "el primer dígito indica el número de la salida analógica a utilizar (1 ó 2)" .

ns1:SalidaAnalogica_2 a ns1:ComponenteElectrico ;
    rdfs:label "Salida analógica 2" ;
    ns1:identificador "2" ;
    ns1:textoExtracto "el primer dígito indica el número de la salida analógica a utilizar (1 ó 2)" .

