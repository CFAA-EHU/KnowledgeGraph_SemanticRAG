@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Manual_Regulador a ns1:Manual ;
    rdfs:label "Manual del regulador (versión ≥9.10)"@es ;
    ns1:documentadoEn ns1:Regulador_7 ;
    ns1:identificador "v9.10" ;
    ns1:textoExtracto "Consultar en el manual de i regulador el conexionado del sensor del gap. Esta prestación requiere una versión de regulador v9.10 o posterior"@es .

ns1:Nodo_Regulador a ns1:ComponenteElectrico ;
    rdfs:label "Nodo del regulador (dirección lógica)"@es ;
    ns1:monitoreaParametro ns1:Parametro_107 ;
    ns1:textoExtracto "este parámetro indica el número de nodo del regulador"@es .

ns1:Registro_PLC_EtherCAT a ns1:Parametro ;
    rdfs:label "Registro del PLC para entrada analógica (EtherCAT)"@es ;
    ns1:monitoreaParametro ns1:Parametro_107 ;
    ns1:textoExtracto "este parámetro indica el registro del PLC que mapea la entrada"@es .

ns1:EntradaAnalogica_1 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada analógica '1' del regulador"@es ;
    ns1:identificador "1" ;
    ns1:textoExtracto "se utiliza la entrada analógica ꞏ1ꞏ del regulador cuya dirección lógica es ꞏ7ꞏ"@es .

ns1:Regulador_7 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador con dirección lógica '7'"@es ;
    ns1:identificador "7" ;
    ns1:monitoreaParametro ns1:Parametro_107 ;
    ns1:textoExtracto "dirección lógica [...] ꞏ7ꞏ [...] entrada analógica ꞏ1ꞏ del regulador"@es ;
    ns1:tieneComponente ns1:EntradaAnalogica_1 .

ns1:Sensor_Gap a ns1:Sensor ;
    rdfs:label "Sensor del gap"@es ;
    ns1:monitoreaParametro ns1:Parametro_107 ;
    ns1:textoExtracto "Consultar en el manual de i regulador el conexionado del sensor del gap"@es .

ns1:Parametro_107 a ns1:Parametro ;
    rdfs:label "Parámetro de dirección lógica '107'"@es ;
    ns1:identificador "107" ;
    ns1:monitoreaParametro ns1:Sensor_Gap ;
    ns1:textoExtracto "el parámetro se define con el valor ꞏ107ꞏ, indica que se utiliza la entrada analógica ꞏ1ꞏ del regulador cuya dirección lógica es ꞏ7ꞏ"@es ;
    ns1:valor "107" .

