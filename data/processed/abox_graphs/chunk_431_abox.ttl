@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_GAPDISTLIMIT a ns1:Parametro ;
    rdfs:label "GAPDISTLIMIT" ;
    ns1:identificador "GAPDISTLIMIT" ;
    ns1:monitoreaParametro ns1:Sensor_GAP ;
    ns1:textoExtracto "GAPDISTLIMIT Distancia que corresponde a la señal analógica límite del sensor. Valores posibles: De 0 a 99999.9999 mm / De 0 a 3937.00787 inch. Valor por defecto: 10.0000 mm / 0.39370 inch." ;
    ns1:valor "10.0000 mm / 0.39370 inch"^^xsd:string .

ns1:Parametro_GAPVOLTLIMIT a ns1:Parametro ;
    rdfs:label "GAPVOLTLIMIT" ;
    ns1:identificador "GAPVOLTLIMIT" ;
    ns1:monitoreaParametro ns1:Sensor_GAP ;
    ns1:textoExtracto "GAPVOLTLIMIT Voltaje que corresponde al recorrido límite del sensor. Valores posibles: De 0 a 10000 mV. Valor por defecto: 10000 mV." ;
    ns1:valor "10000 mV"^^xsd:string .

ns1:Variable_MPG_GAPDISTLIMIT a ns1:Parametro ;
    rdfs:label "(V.)MPG.GAPDISTLIMIT" ;
    ns1:identificador "(V.)MPG.GAPDISTLIMIT" ;
    ns1:monitoreaParametro ns1:Sensor_GAP ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.GAPDISTLIMIT Distancia que corresponde a señal analógica límite del sensor (parámetro GAPVOLTLIMIT)." .

ns1:Variable_MPG_GAPVOLTLIMIT a ns1:Parametro ;
    rdfs:label "(V.)MPG.GAPVOLTLIMIT" ;
    ns1:identificador "(V.)MPG.GAPVOLTLIMIT" ;
    ns1:monitoreaParametro ns1:Sensor_GAP ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.GAPVOLTLIMIT Voltaje (en milivoltios) que corresponde al recorrido límite del sensor (parámetro GAPDISTLIMIT)." .

ns1:Sensor_GAP a ns1:Sensor ;
    rdfs:label "Sensor de gap" ;
    ns1:textoExtracto "Entrada analógica de los módulos remotos EtherCAT. En este caso, este parámetro indica el registro del PLC que mapea la entrada analógica conectada al sensor." .

