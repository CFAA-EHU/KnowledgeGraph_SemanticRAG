@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_GAPGAIN a ns1:Parametro ;
    rdfs:label "GAPGAIN" ;
    ns1:identificador "(V.)MPG.GAPGAIN" ;
    ns1:monitoreaParametro ns1:Sensor_GAP ;
    ns1:textoExtracto "Ganancia proporcional a aplicar en GAPCTRL. Valores posibles: De 0.0000 a 100.0000. Valor por defecto: 0.2." ;
    ns1:valor "0.2"^^xsd:float .

ns1:Parametro_GAPSENSORCH a ns1:Parametro ;
    rdfs:label "GAPSENSORCH" ;
    ns1:identificador "(V.)MPG.GAPSENSORCH" ;
    ns1:monitoreaParametro ns1:Sensor_GAP ;
    ns1:textoExtracto "Cambiar el signo de la señal del sensor. Valores posibles: Sí / No. Valor por defecto: No." ;
    ns1:valor "No"^^xsd:string .

ns1:Parametro_GAPSENSOROFFSET a ns1:Parametro ;
    rdfs:label "GAPSENSOROFFSET" ;
    ns1:identificador "(V.)MPG.GAPSENSOROFFSET" ;
    ns1:monitoreaParametro ns1:Sensor_GAP ;
    ns1:textoExtracto "Offset a aplicar al sensor. Valores posibles: Entre ±10000 mV. Valor por defecto: 0 mV." ;
    ns1:valor "0"^^xsd:string .

ns1:Sensor_GAP a ns1:Sensor ;
    rdfs:label "Sensor de GAP" ;
    ns1:textoExtracto "Offset a aplicar al sensor desde el CNC... Ganancia proporcional aplicada a la señal del sensor, en posición." .

