@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_GAPGAIN_Reducido a ns1:Parametro ;
    rdfs:label "GAPGAIN reducido durante aproximación"@es ;
    ns1:controla ns1:Parametro_MPG_GAPGAIN ;
    ns1:textoExtracto "Este parámetro reduce, en el porcentaje definido, el valor de GAPGAIN del eje del sensor durante la aproximación a la chapa."@es .

ns1:Parametro_GAPSENSORFILTER a ns1:Parametro ;
    rdfs:label "Filtro del sensor GAP"@es ;
    ns1:identificador "GAPSENSORFILTER" ;
    ns1:textoExtracto "Para utilizar valores mayores de 0.2 (cercanos a 1) se recomienda utilizar el parámetro GAPSENSORFILTER."@es .

ns1:Parametro_MPG_GAPAPPROACHDYN a ns1:Parametro ;
    rdfs:label "Respuesta dinámica de aproximación (MPG.GAPAPPROACHDYN)"@es ;
    ns1:identificador "MPG.GAPAPPROACHDYN" ;
    ns1:monitoreaParametro ns1:Sensor_GAP ;
    ns1:textoExtracto "GAPAPPROACHDYN Respuesta dinámica durante la parte final del movimiento de aproximación a la chapa. Valores posibles: De 10 a 120 %. Valor por defecto: 80 %."@es ;
    ns1:valor 80 .

ns1:Parametro_MPG_GAPGAIN a ns1:Parametro ;
    rdfs:label "Ganancia proporcional (MPG.GAPGAIN)"@es ;
    ns1:identificador "MPG.GAPGAIN" ;
    ns1:monitoreaParametro ns1:Sensor_GAP ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.GAPGAIN Ganancia proporcional aplicada a la señal del sensor, en posición."@es ;
    ns1:valor 0.2 .

ns1:Sensor_GAP a ns1:Sensor ;
    rdfs:label "Sensor de posición GAP"@es ;
    ns1:textoExtracto "señal del sensor, en posición"@es .

