@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:GapSensorFilter a ns1:Parametro ;
    rdfs:label "GAPSENSORFILTER" ;
    ns1:detalladoEnEsquema ns1:TablaConfiguracionFiltroSensor ;
    ns1:identificador "GAPSENSORFILTER" ;
    ns1:textoExtracto "GAPSENSORFILTER Tabla para configurar el filtro del sensor." .

ns1:TablaConfiguracionFiltroSensor a ns1:Tabla ;
    rdfs:label "Tabla para configurar el filtro del sensor" ;
    ns1:textoExtracto "Este parámetro muestra la tabla para configurar el filtro del sensor." .

