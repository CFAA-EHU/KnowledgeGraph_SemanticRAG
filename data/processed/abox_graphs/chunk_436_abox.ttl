@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sensor_Gap a ns1:Sensor ;
    rdfs:label "Sensor de Gap" ;
    ns1:monitoreaParametro ns1:Parametro_FrecuenciaCorteGapSensor,
        ns1:Parametro_OrdenFiltroGapSensor,
        ns1:Parametro_TipoFiltroGapSensor ;
    ns1:textoExtracto "GAP SENSOR POSITION FEEDBACK LOOP GAP P-GAIN V.G.GAP CUTOF FILTER" .

ns1:Parametro_FrecuenciaCorteGapSensor a ns1:Parametro ;
    rdfs:label "Frecuencia de corte (GAP SENSOR)" ;
    ns1:documentadoEn ns1:Tabla_GAPSENSORFILTER ;
    ns1:identificador "MPG.FREQUENCY" ;
    ns1:textoExtracto "FREQUENCY | Frecuencia de corte. Valores posibles: De 0 a 500.0000 Hz. Valor por defecto: 30.0000 Hz." ;
    ns1:valor "30.0000" .

ns1:Parametro_OrdenFiltroGapSensor a ns1:Parametro ;
    rdfs:label "Orden del filtro (GAP SENSOR)" ;
    ns1:documentadoEn ns1:Tabla_GAPSENSORFILTER ;
    ns1:identificador "MPG.ORDER" ;
    ns1:textoExtracto "ORDER | Orden del filtro. Valores posibles: De 0 a 50. Valor por defecto: 0 (no se aplica filtro). Variable asociada: (V.)MPG.ORDER" ;
    ns1:valor "0" .

ns1:Parametro_TipoFiltroGapSensor a ns1:Parametro ;
    rdfs:label "Tipo de filtro (GAP SENSOR)" ;
    ns1:documentadoEn ns1:Tabla_GAPSENSORFILTER ;
    ns1:identificador "MPG.TYPE" ;
    ns1:textoExtracto "TYPE | Tipo de filtro. Valores posibles: Paso bajo. Valor por defecto: Paso bajo. Variable asociada: (V.)MPG.TYPE" ;
    ns1:valor "Paso bajo" .

ns1:Tabla_GAPSENSORFILTER a ns1:Tabla ;
    rdfs:label "Tabla GAPSENSORFILTER" ;
    ns1:identificador "GAPSENSORFILTER" ;
    ns1:textoExtracto "GAPSENSORFILTER | ORDER | Orden del filtro. | TYPE | Tipo de filtro. | FREQUENCY | Frecuencia de corte." .

