@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_FrecuenciaCorte a ns1:Parametro ;
    rdfs:label "Frequency (Frecuencia de corte)" ;
    ns1:documentadoEn ns1:Tabla_GAPSENSORFILTER ;
    ns1:identificador "MPG.FREQUENCY" ;
    ns1:textoExtracto "FREQUENCY Frecuencia de corte. Valores posibles: De 0 a 500.0000 Hz. Valor por defecto: 30.0000 Hz. Variable asociada: (V.)MPG.FREQUENCY" ;
    ns1:valor "30.0000" .

ns1:Parametro_GAPERRORCANCEL a ns1:Parametro ;
    rdfs:label "GAPERRORCANCEL" ;
    ns1:identificador "MPG.GAPERRORCANCEL" ;
    ns1:textoExtracto "GAPERRORCANCEL Anular el error de gap fuera del rango definido por GAPMIN/GAPMAX. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPG.GAPERRORCANCEL" ;
    ns1:valor "No" .

ns1:Parametro_GAPMAX a ns1:Parametro ;
    rdfs:label "GAPMAX" ;
    ns1:textoExtracto "rango definido por GAPMIN/GAPMAX" .

ns1:Parametro_GAPMIN a ns1:Parametro ;
    rdfs:label "GAPMIN" ;
    ns1:textoExtracto "rango definido por GAPMIN/GAPMAX" .

ns1:Parametro_INPOSGAP a ns1:Parametro ;
    rdfs:label "INPOSGAP" ;
    ns1:textoExtracto "el CNC sigue vigilando la marca INPOSGAP" .

ns1:Tabla_GAPSENSORFILTER a ns1:Tabla ;
    rdfs:label "Tabla GAPSENSORFILTER" ;
    ns1:textoExtracto "Parámetro incluido en la tabla GAPSENSORFILTER. Frecuencia de corte del filtro." .

