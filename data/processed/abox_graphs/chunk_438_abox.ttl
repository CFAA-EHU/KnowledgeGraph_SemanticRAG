@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_GAPTOLCANCEL a ns1:Parametro ;
    rdfs:label "GAPTOLCANCEL" ;
    ns1:identificador "MPG.GAPTOLCANCEL" ;
    ns1:textoExtracto "GAPTOLCANCEL Anular el error de gap fuera del rango definido por GAPTOL. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPG.GAPTOLCANCEL El parámetro GAPTOLCANCEL establece el comportamiento del CNC cuando el gap supera el margen definido en el parámetro GAPTOL." ;
    ns1:valor "No" .

ns1:Sensor_Gap a ns1:Sensor ;
    ns1:monitoreaParametro ns1:Parametro_GAPMAX,
        ns1:Parametro_GAPMIN ;
    ns1:textoExtracto "Si el gap sobrepasa el rango definido en los parámetros GAPMIN y GAPMAX, el PLC desactiva la marca INPOSGAP." .

ns1:Tabla_ComportamientoGap a ns1:Tabla ;
    ns1:documentadoEn ns1:Pagina_98_103 ;
    ns1:textoExtracto "| Valor. | Significado. | --- | --- | Sí. | El CNC anula el error de gap fuera del rango y no detiene el movimiento de los ejes. | No | El CNC da error de gap fuera del rango y detiene el movimiento de los ejes, respetando la rampa de frenado y controlando el gap durante la rampa." .

ns1:Parametro_GAPMAX a ns1:Parametro ;
    rdfs:label "GAPMAX" ;
    ns1:identificador "MPG.GAPMAX" ;
    ns1:textoExtracto "GAPMAX Límite máximo del sensor. Valores posibles: De 0 a 99999.9999 mm / De 0 a 3937.00787 inch. Valor por defecto: 5.0000 mm / 0.19685 inch. Variable asociada: (V.)MPG.GAPMAX Máximo valor permitido para el gap." ;
    ns1:valor 5.0000 .

ns1:Parametro_GAPMIN a ns1:Parametro ;
    rdfs:label "GAPMIN" ;
    ns1:identificador "MPG.GAPMIN" ;
    ns1:textoExtracto "GAPMIN Límite mínimo del sensor. Valores posibles: De 0 a 99999.9999 mm / De 0 a 3937.00787 inch. Valor por defecto: 0. Variable asociada: (V.)MPG.GAPMIN Mínimo valor permitido para el gap." ;
    ns1:valor 0.0 .

