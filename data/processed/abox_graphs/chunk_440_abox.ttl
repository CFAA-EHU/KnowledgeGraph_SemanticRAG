@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_Gap_EjeZ_No a ns1:Parametro ;
    rdfs:label "Configuración invertida del eje Z (gap)"@es ;
    ns1:documentadoEn ns1:Tabla_2.3.31_ControlGap ;
    ns1:textoExtracto "El sentido positivo del eje Z es hacia abajo y el negativo hacia arriba (eje Z invertido). El eje se mueve en sentido positivo (hacia abajo) para alcanzar el gap."@es ;
    ns1:valor "No" .

ns1:Parametro_Gap_EjeZ_Si a ns1:Parametro ;
    rdfs:label "Configuración estándar del eje Z (gap)"@es ;
    ns1:documentadoEn ns1:Tabla_2.3.31_ControlGap ;
    ns1:textoExtracto "El sentido positivo del eje Z es hacia arriba y el negativo hacia abajo (condiciones normales). El eje se mueve en sentido negativo (hacia abajo) para alcanzar el gap."@es ;
    ns1:valor "Sí" .

ns1:Tabla_2.3.31_ControlGap a ns1:Tabla ;
    rdfs:label "Tabla de valores para control del gap (eje Z)"@es ;
    ns1:textoExtracto "No | El sentido positivo del eje Z es hacia abajo y el negativo hacia arriba (eje Z invertido). El eje se mueve en sentido positivo (hacia abajo) para alcanzar el gap."@es .

