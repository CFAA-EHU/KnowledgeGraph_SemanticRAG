@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_GAP a ns1:ComponenteMecanico ;
    rdfs:label "Gap"@es ;
    ns1:controla ns1:Parametro_GAPTONEG ;
    ns1:documentadoEn ns1:Tabla_ControlGap_180 ;
    ns1:textoExtracto "GAP"@es .

ns1:Componente_WORKPIECE a ns1:ComponenteMecanico ;
    rdfs:label "Pieza de trabajo (WORKPIECE)"@es ;
    ns1:documentadoEn ns1:Tabla_ControlGap_180 ;
    ns1:textoExtracto "WORKPIECE" .

ns1:Componente_Z a ns1:ComponenteElectrico ;
    rdfs:label "Señal Z+"@es,
        "Señal Z-"@es ;
    ns1:documentadoEn ns1:Tabla_ControlGap_180 ;
    ns1:textoExtracto "Z-"@es .

ns1:Sensor_LASER a ns1:Sensor ;
    rdfs:label "Sensor LASER"@es ;
    ns1:documentadoEn ns1:Tabla_ControlGap_180 ;
    ns1:monitoreaParametro ns1:Parametro_GAPTONEG ;
    ns1:textoExtracto "LASER"@es .

ns1:Parametro_GAPTONEG a ns1:Parametro ;
    rdfs:label "GAPTONEG" ;
    ns1:documentadoEn ns1:Tabla_ControlGap_180 ;
    ns1:textoExtracto "GAPTONEG = Sí / GAPTONEG = No"@es ;
    ns1:valor "No",
        "Sí" .

ns1:Tabla_ControlGap_180 a ns1:Tabla ;
    rdfs:label "Tabla de estados del control del gap"@es ;
    ns1:identificador "2.3.31" ;
    ns1:ilustradoEn ns1:Pagina_98_103 ;
    ns1:textoExtracto """
| Z+
Z-
LASER
GAP
WORKPIECE
GAPTONEG = Sí | Z-
Z+
LASER
GAP
WORKPIECE
GAPTONEG = No |
""" .

