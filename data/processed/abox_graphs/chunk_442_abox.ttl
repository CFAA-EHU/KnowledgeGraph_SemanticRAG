@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:leapfrog_LeapDynOvr a ns1:Parametro ;
    rdfs:label "LEAPDYNOVR" ;
    ns1:identificador "LEAPDYNOVR" ;
    ns1:monitoreaParametro ns1:maquina_Leapfrog ;
    ns1:textoExtracto "LEAPDYNOVR Respuesta dinámica del salto durante el leapfrog. Valores posibles: De 10 a 100000 %. Valor por defecto: 100 %. Variable asociada: (V.)MPG.LEAPDYNOVR Este parámetro permite reducir la respuesta dinámica del eje Z (eje longitudinal) durante el leapfrog, para conseguir un salto más suave tanto en la subida como en la bajada."@es ;
    ns1:valor "100" .

ns1:parametro_AccJerk a ns1:Parametro ;
    rdfs:label "ACCJERK" ;
    ns1:identificador "ACCJERK" ;
    ns1:monitoreaParametro ns1:maquina_Leapfrog ;
    ns1:textoExtracto "| ACCJERK | Jerk de aceleración y deceleración. Los parámetros ACCJERK y DECJERK definen la pendiente de la aceleración y deceleración. Ambos parámetros permiten limitar los cambios de aceleración, de forma que la máquina vaya más suave en los incrementos o decrementos de velocidades pequeñas y con valores de FFGAIN cercanos al 100%."@es .

ns1:parametro_Accel a ns1:Parametro ;
    rdfs:label "ACCEL" ;
    ns1:identificador "ACCEL" ;
    ns1:monitoreaParametro ns1:maquina_Leapfrog ;
    ns1:textoExtracto "| ACCEL | Aceleración y deceleración. Los parámetros ACCEL y DECEL fijan los valores de la aceleración cuando ésta es trapezoidal o seno cuadrado (parámetro SLOPETYPE)."@es .

ns1:parametro_DecJerk a ns1:Parametro ;
    rdfs:label "DECJERK" ;
    ns1:identificador "DECJERK" ;
    ns1:monitoreaParametro ns1:maquina_Leapfrog ;
    ns1:textoExtracto "| DECJERK | Jerk de aceleración y deceleración. Los parámetros ACCJERK y DECJERK definen la pendiente de la aceleración y deceleración. Ambos parámetros permiten limitar los cambios de aceleración, de forma que la máquina vaya más suave en los incrementos o decrementos de velocidades pequeñas y con valores de FFGAIN cercanos al 100%."@es .

ns1:parametro_Decel a ns1:Parametro ;
    rdfs:label "DECEL" ;
    ns1:identificador "DECEL" ;
    ns1:monitoreaParametro ns1:maquina_Leapfrog ;
    ns1:textoExtracto "| DECEL | Aceleración y deceleración. Los parámetros ACCEL y DECEL fijan los valores de la aceleración cuando ésta es trapezoidal o seno cuadrado (parámetro SLOPETYPE)."@es .

ns1:parametro_SlopeType a ns1:Parametro ;
    rdfs:label "SLOPETYPE" ;
    ns1:identificador "SLOPETYPE" ;
    ns1:monitoreaParametro ns1:maquina_Leapfrog ;
    ns1:textoExtracto "| Parámetro. | Significado. | --- | --- | SLOPETYPE | Tipo de aceleración por defecto; lineal, trapezoidal y seno cuadrado (square sine)."@es .

ns1:maquina_Leapfrog a ns1:Maquina ;
    ns1:textoExtracto "El leapfrog necesita valores altos de ACEL y DECEL (del orden de 15000 mm/s² o mayor) y de ACCJERK y DECJERK (del orden de 20 veces ACEL y DECEL)."@es .

