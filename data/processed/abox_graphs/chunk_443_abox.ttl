@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Maquina_Leapfrog a ns1:Maquina ;
    rdfs:label "Máquina Leapfrog" ;
    ns1:textoExtracto "respuesta de la máquina [...] aproximación a la chapa" ;
    ns1:tieneComponente ns1:Parametro_ACEL,
        ns1:Parametro_DECEL,
        ns1:Parametro_LACC1,
        ns1:Parametro_LACC2 .

ns1:Parametro_ACEL a ns1:Parametro ;
    rdfs:label "ACEL" ;
    ns1:textoExtracto "parámetro de aceleración (referencia para LACC1)" .

ns1:Parametro_DECEL a ns1:Parametro ;
    rdfs:label "DECEL" ;
    ns1:textoExtracto "parámetro de deceleración (referencia para LACC2)" .

ns1:Parametro_LACC1 a ns1:Parametro ;
    rdfs:label "LACC1" ;
    ns1:textoExtracto "aceleración lineal LACC1" ;
    ns1:valor "un tercio de ACEL"^^xsd:string .

ns1:Parametro_LACC2 a ns1:Parametro ;
    rdfs:label "LACC2" ;
    ns1:textoExtracto "aceleración lineal LACC2" ;
    ns1:valor "un tercio de DECEL"^^xsd:string .

