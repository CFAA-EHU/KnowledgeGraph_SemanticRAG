@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_LACC1 a ns1:Parametro ;
    rdfs:label "LACC1"@es ;
    ns1:documentadoEn ns1:Tabla_Leapfrog_ParametrosAceleracion ;
    ns1:identificador "LACC1" ;
    ns1:textoExtracto "Aceleración del primer tramo. Ejemplo: LACC1 = 6000 mm/s²."@es ;
    ns1:valor "6000 mm/s²" .

ns1:Parametro_LACC2 a ns1:Parametro ;
    rdfs:label "LACC2"@es ;
    ns1:documentadoEn ns1:Tabla_Leapfrog_ParametrosAceleracion ;
    ns1:identificador "LACC2" ;
    ns1:textoExtracto "Aceleración del segundo tramo. Ejemplo: LACC2 = 6000 mm/s²."@es ;
    ns1:valor "6000 mm/s²" .

ns1:Tabla_Leapfrog_ParametrosAceleracion a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de aceleración (Leapfrog)"@es ;
    ns1:textoExtracto """
| Parámetro. | Significado. |
| --- | --- |
| LACC1
LACC2 | Aceleración del primer y segundo tramo. Los parámetros LACC1 y LACC2 fijan los valores de la aceleración cuando ésta
es lineal (parámetro SLOPETYPE)."""@es ;
    ns1:tieneComponente ns1:Parametro_LACC1,
        ns1:Parametro_LACC2 .

