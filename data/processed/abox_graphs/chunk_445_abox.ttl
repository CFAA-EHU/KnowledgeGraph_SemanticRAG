@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CompensacionDispersion a ns1:Sistema ;
    rdfs:label "Sistema de compensación de dispersión láser" ;
    ns1:detalladoEnEsquema ns1:Tabla_CompensacionDispersionLaser ;
    ns1:textoExtracto "El objetivo de la compensación es mantener constante el recorrido total del láser, para evitar así variaciones de dispersión en el punto de corte en la chapa. Para la compensación se utiliza un eje esclavo que sigue a los ejes principales." ;
    ns1:tieneComponente ns1:Comando_FOLLOW,
        ns1:Parametro_LASERFOLLOW,
        ns1:Sentencia_FOLLOW .

ns1:Comando_FOLLOW a ns1:InterfazUsuario ;
    rdfs:label "Comando FOLLOW" ;
    ns1:identificador "FOLLOW" ;
    ns1:textoExtracto "La compensación de la dispersión se activa desde el programa mediante la sentencia #FOLLOW o desde el PLC mediante el comando FOLLOW." .

ns1:Sentencia_FOLLOW a ns1:InterfazUsuario ;
    rdfs:label "Sentencia #FOLLOW" ;
    ns1:identificador "#FOLLOW" ;
    ns1:textoExtracto "La compensación de la dispersión se activa desde el programa mediante la sentencia #FOLLOW" .

ns1:Tabla_CompensacionDispersionLaser a ns1:Tabla ;
    rdfs:label "Tabla de compensación de dispersión láser" ;
    ns1:documentadoEn ns1:Parametro_LASERFOLLOW ;
    ns1:textoExtracto "Este parámetro muestra la tabla para definir la compensación." .

ns1:Parametro_LASERFOLLOW a ns1:Parametro ;
    rdfs:label "LASERFOLLOW" ;
    ns1:identificador "LASERFOLLOW" ;
    ns1:textoExtracto "LASERFOLLOW Compensar la dispersión por el recorrido del láser de CO2. Este parámetro muestra la tabla para definir la compensación." .

