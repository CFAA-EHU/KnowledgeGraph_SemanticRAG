@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_ParametrosLaserFollow a ns1:Tabla ;
    rdfs:label "Tabla de parámetros LASERFOLLOW" ;
    ns1:textoExtracto "LASERFOLLOW | LASERFOLLOWAXIS | Eje esclavo al que se aplica el FOLLOW. | LASERFOLLOWOFFSET | Offset de los ejes del triedro con respecto al eje esclavo. | LASERFOLLOW1 | Indica como afecta el primer eje del triedro al eje esclavo. | LASERFOLLOW2 | Indica como afecta el segundo eje del triedro al eje esclavo. | LASERFOLLOW3 | Indica como afecta el tercer eje del triedro al eje esclavo." ;
    ns1:tieneComponente ns1:Parametro_LASERFOLLOW,
        ns1:Parametro_LASERFOLLOW1,
        ns1:Parametro_LASERFOLLOW2,
        ns1:Parametro_LASERFOLLOW3,
        ns1:Parametro_LASERFOLLOWAXIS,
        ns1:Parametro_LASERFOLLOWOFFSET .

ns1:Parametro_LASERFOLLOW a ns1:Parametro ;
    rdfs:label "LASERFOLLOW" ;
    ns1:identificador "LASERFOLLOW" ;
    ns1:textoExtracto "LASERFOLLOW" .

ns1:Parametro_LASERFOLLOW1 a ns1:Parametro ;
    rdfs:label "LASERFOLLOW1" ;
    ns1:identificador "LASERFOLLOW1" ;
    ns1:textoExtracto "LASERFOLLOW1 | Indica como afecta el primer eje del triedro al eje esclavo." .

ns1:Parametro_LASERFOLLOW2 a ns1:Parametro ;
    rdfs:label "LASERFOLLOW2" ;
    ns1:identificador "LASERFOLLOW2" ;
    ns1:textoExtracto "LASERFOLLOW2 | Indica como afecta el segundo eje del triedro al eje esclavo." .

ns1:Parametro_LASERFOLLOW3 a ns1:Parametro ;
    rdfs:label "LASERFOLLOW3" ;
    ns1:identificador "LASERFOLLOW3" ;
    ns1:textoExtracto "LASERFOLLOW3 | Indica como afecta el tercer eje del triedro al eje esclavo." .

ns1:Parametro_LASERFOLLOWAXIS a ns1:Parametro ;
    rdfs:label "LASERFOLLOWAXIS" ;
    ns1:identificador "LASERFOLLOWAXIS" ;
    ns1:textoExtracto "LASERFOLLOWAXIS | Eje esclavo al que se aplica el FOLLOW." .

ns1:Parametro_LASERFOLLOWOFFSET a ns1:Parametro ;
    rdfs:label "LASERFOLLOWOFFSET" ;
    ns1:identificador "LASERFOLLOWOFFSET" ;
    ns1:textoExtracto "LASERFOLLOWOFFSET | Offset de los ejes del triedro con respecto al eje esclavo." .

