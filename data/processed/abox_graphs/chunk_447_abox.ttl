@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Param_LASERFOLLOW1 a ns1:Parametro ;
    rdfs:label "LASERFOLLOW1"@es ;
    ns1:documentadoEn ns1:Tabla_LASERFOLLOW ;
    ns1:identificador "LASERFOLLOW1" ;
    ns1:textoExtracto "Efecto del primer eje del triedro sobre el eje esclavo. Valores posibles: No afecta / Positivo / Negativo. Valor por defecto: No afecta. Variable asociada: (V.)MPG.LASERFOLLOW1"@es ;
    ns1:valor "No afecta, Positivo, Negativo"@es .

ns1:Param_LASERFOLLOW2 a ns1:Parametro ;
    rdfs:label "LASERFOLLOW2"@es ;
    ns1:documentadoEn ns1:Tabla_LASERFOLLOW ;
    ns1:identificador "LASERFOLLOW2" ;
    ns1:textoExtracto "Efecto del segundo eje del triedro sobre el eje esclavo."@es .

ns1:Param_LASERFOLLOWAXIS a ns1:Parametro ;
    rdfs:label "LASERFOLLOWAXIS"@es ;
    ns1:documentadoEn ns1:Tabla_LASERFOLLOW ;
    ns1:identificador "LASERFOLLOWAXIS" ;
    ns1:textoExtracto "Eje esclavo al que se aplica el FOLLOW. Valores posibles: X, X1ꞏꞏX9, ꞏꞏ , C, C1ꞏꞏC9. Valor por defecto: 0 (no hay compensación). Variable asociada: (V.)MPG.LASERFOLLOW"@es ;
    ns1:valor "X, X1...X9, C, C1...C9"@es .

ns1:Param_LASERFOLLOWOFFSET a ns1:Parametro ;
    rdfs:label "LASERFOLLOWOFFSET"@es ;
    ns1:documentadoEn ns1:Tabla_LASERFOLLOW ;
    ns1:identificador "LASERFOLLOWOFFSET" ;
    ns1:textoExtracto "Offset del origen del triedro respecto del eje esclavo. Valores posibles: Entre ±99999.9999 mm / Entre ±3937.00787 inch. Valor por defecto: 0. Variable asociada: (V.)MPG.LASERFOLLOWOFFSET"@es ;
    ns1:valor "±99999.9999 mm / ±3937.00787 inch"@es .

ns1:Tabla_LASERFOLLOW a ns1:Tabla ;
    rdfs:label "Tabla LASERFOLLOW"@es ;
    ns1:textoExtracto "Parámetro incluido en la tabla LASERFOLLOW."@es ;
    ns1:tieneComponente ns1:Param_LASERFOLLOW1,
        ns1:Param_LASERFOLLOW2,
        ns1:Param_LASERFOLLOWAXIS,
        ns1:Param_LASERFOLLOWOFFSET .

