@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CompensacionLaser a ns1:Sistema ;
    rdfs:label "Sistema de compensación láser" ;
    ns1:documentadoEn ns1:Tabla_LASERFOLLOW ;
    ns1:textoExtracto "canal que gestiona compensación" ;
    ns1:tieneComponente ns1:Parametro_LASERFOLLOW3,
        ns1:Parametro_LASERFOLLOWAXIS,
        ns1:Variable_V.A.FLWMASTER.xn .

ns1:Parametro_LASERFOLLOW3 a ns1:Parametro ;
    rdfs:label "LASERFOLLOW3" ;
    ns1:documentadoEn ns1:Tabla_LASERFOLLOW ;
    ns1:identificador "LASERFOLLOW3" ;
    ns1:textoExtracto "LASERFOLLOW3 Efecto del tercer eje del triedro sobre el eje esclavo. Valores posibles: No afecta / Positivo / Negativo. Valor por defecto: No afecta. Variable asociada: (V.)MPG.LASERFOLLOW3" ;
    ns1:valor "No afecta" .

ns1:Parametro_LASERFOLLOWAXIS a ns1:Parametro ;
    rdfs:label "LASERFOLLOWAXIS" ;
    ns1:identificador "LASERFOLLOWAXIS" ;
    ns1:textoExtracto "parámetro LASERFOLLOWAXIS" .

ns1:Variable_V.A.FLWMASTER.xn a ns1:Parametro ;
    rdfs:label "Variable V.A.FLWMASTER.xn" ;
    ns1:identificador "V.A.FLWMASTER.xn" ;
    ns1:textoExtracto "variable V.A.FLWMASTER.xn del eje esclavo (parámetro LASERFOLLOWAXIS)" .

ns1:Tabla_LASERFOLLOW a ns1:Tabla ;
    rdfs:label "Tabla LASERFOLLOW" ;
    ns1:textoExtracto "Parámetro incluido en la tabla LASERFOLLOW." .

