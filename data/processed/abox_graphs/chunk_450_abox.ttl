@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_ATPOSX a ns1:Parametro ;
    rdfs:label "V.A.TPOS.X" ;
    ns1:identificador "V.A.TPOS.X" ;
    ns1:textoExtracto "V.A.TPOS.X" .

ns1:Parametro_ATPOSY a ns1:Parametro ;
    rdfs:label "V.A.TPOS.Y" ;
    ns1:identificador "V.A.TPOS.Y" ;
    ns1:textoExtracto "V.A.TPOS.Y" .

ns1:Parametro_ATPOSZ a ns1:Parametro ;
    rdfs:label "V.A.TPOS.Z" ;
    ns1:identificador "V.A.TPOS.Z" ;
    ns1:textoExtracto "V.A.TPOS.Z" .

ns1:Parametro_LASERFOLLOW1 a ns1:Parametro ;
    rdfs:label "V.MPG.LASERFOLLOW1" ;
    ns1:identificador "V.MPG.LASERFOLLOW1" ;
    ns1:textoExtracto "V.MPG.LASERFOLLOW1 * V.A.TPOS.X" .

ns1:Parametro_LASERFOLLOW2 a ns1:Parametro ;
    rdfs:label "V.MPG.LASERFOLLOW2" ;
    ns1:identificador "V.MPG.LASERFOLLOW2" ;
    ns1:textoExtracto "V.MPG.LASERFOLLOW2 * V.A.TPOS.Y" .

ns1:Parametro_LASERFOLLOW3 a ns1:Parametro ;
    rdfs:label "V.MPG.LASERFOLLOW3" ;
    ns1:identificador "V.MPG.LASERFOLLOW3" ;
    ns1:textoExtracto "V.MPG.LASERFOLLOW3 * V.A.TPOS.Z" .

ns1:Parametro_LASERFOLLOWOFFSET a ns1:Parametro ;
    rdfs:label "V.MPG.LASERFOLLOWOFFSET" ;
    ns1:identificador "V.MPG.LASERFOLLOWOFFSET" ;
    ns1:textoExtracto "V.MPG.LASERFOLLOWOFFSET" .

ns1:Parametro_VAFLWMASTERxn a ns1:Parametro ;
    rdfs:label "V.A.FLWMASTER.xn" ;
    ns1:identificador "V.A.FLWMASTER.xn" ;
    ns1:textoExtracto "V.A.FLWMASTER.xn = V.MPG.LASERFOLLOWOFFSET + V.MPG.LASERFOLLOW1 * V.A.TPOS.X + V.MPG.LASERFOLLOW2 * V.A.TPOS.Y + V.MPG.LASERFOLLOW3 * V.A.TPOS.Z" .

