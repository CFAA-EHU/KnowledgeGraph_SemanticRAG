@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:monitoreaParametro ns1:Parametro_SYNCCANCEL ;
    ns1:textoExtracto "Este parámetro indica si el CNC cancela la sincronización de cabezales tras ejecutar M02, M30 o después de un error o reset." .

ns1:Parametro_SYNCCANCEL a ns1:Parametro ;
    rdfs:label "SYNCCANCEL" ;
    ns1:identificador "MPG.SYNCCANCEL" ;
    ns1:textoExtracto "SYNCCANCEL Cancelar la sincronización de cabezales. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)MPG.SYNCCANCEL" ;
    ns1:valor "Sí" .

