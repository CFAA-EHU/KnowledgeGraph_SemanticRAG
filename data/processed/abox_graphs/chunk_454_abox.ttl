@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_KEYBDnCH a ns1:Parametro ;
    rdfs:label "KEYBDnCH" ;
    ns1:detalladoEnEsquema ns1:Tabla_AsignacionPanelesJog ;
    ns1:identificador "V.MPG.KEYBDCH[jog]" ;
    ns1:textoExtracto "KEYBDnCH Canal al que está asignado el panel de jog. Valores posibles: Canal activo / CH1 / CH2 / CH3 / CH4. Valor por defecto: Canal activo." ;
    ns1:valor "Canal activo" .

ns1:Parametro_NKEYBD a ns1:Parametro ;
    rdfs:label "NKEYBD" ;
    ns1:identificador "V.MPG.NKEYBD" ;
    ns1:textoExtracto "NKEYBD Número de paneles de jog. Valores posibles: De 1 a 8. Valor por defecto: 1." ;
    ns1:valor "1" .

ns1:Parametro_KEYBDCH a ns1:Parametro ;
    rdfs:label "KEYBDCH" ;
    ns1:identificador "V.MPG.KEYBDCH" ;
    ns1:textoExtracto "KEYBDCH Lista de paneles de jog del sistema. Este parámetro muestra la tabla para asignar los paneles de jog a los canales." .

ns1:Tabla_AsignacionPanelesJog a ns1:Tabla ;
    rdfs:label "Tabla KEYBDCH" ;
    ns1:documentadoEn ns1:Parametro_KEYBDCH ;
    ns1:textoExtracto "KEYBDCH | KEYBDnCH (Canal al que está asignado el panel de jog)." .

