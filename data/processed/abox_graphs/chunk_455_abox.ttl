@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_PLCTYPE a ns1:Parametro ;
    rdfs:label "PLCTYPE" ;
    ns1:documentadoEn ns1:Tabla_ComportamientoPLC ;
    ns1:identificador "MPG.PLCTYPE" ;
    ns1:textoExtracto "PLCTYPE Tipo de PLC. Valores posibles: IEC / IEC+Fagor / Fagor. Valor por defecto: IEC. Variable asociada: (V.)MPG.PLCTYPE" ;
    ns1:valor "IEC"^^xsd:string .

ns1:Tabla_ComportamientoPLC a ns1:Tabla ;
    rdfs:label "Comportamiento de arranque/parada del PLC según PLCTYPE" ;
    ns1:textoExtracto "La siguiente tabla muestra a quién afecta el arranque (RUN) y la parada (STOP) del PLC en función de este parámetro, así como el estado de la marca PLCREADY." .

