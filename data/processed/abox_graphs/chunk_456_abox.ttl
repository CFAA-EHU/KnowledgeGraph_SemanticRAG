@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_EjesYCabezales a ns1:ComponenteMecanico ;
    rdfs:label "Ejes y cabezales" ;
    ns1:controla ns1:Parametro_RENAMECANCEL ;
    ns1:textoExtracto "renombrar los ejes y cabezales" .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "Este parámetro indica si el CNC mantiene o cancela el nombre de los ejes y cabezales tras un reset o al comienzo de un nuevo programa pieza en el mismo canal." ;
    ns1:tieneComponente ns1:Parametro_RENAMECANCEL,
        ns1:Sentencia_RENAME .

ns1:ModoOperacion_MDI_MDA a ns1:ModoOperacion ;
    rdfs:label "MDI/MDA" ;
    ns1:habilitadoPor ns1:Sentencia_RENAME ;
    ns1:textoExtracto "modo MDI/MDA" .

ns1:Sentencia_RENAME a ns1:Parametro ;
    rdfs:label "#RENAME" ;
    ns1:monitoreaParametro ns1:Parametro_RENAMECANCEL ;
    ns1:textoExtracto "La sentencia #RENAME permite renombrar los ejes y cabezales desde el programa pieza o el modo MDI/MDA." .

ns1:Parametro_RENAMECANCEL a ns1:Parametro ;
    rdfs:label "RENAMECANCEL" ;
    ns1:identificador "MPG.RENAMECANCEL" ;
    ns1:textoExtracto "RENAMECANCEL Cancelar el cambio de nombre de los ejes y los cabezales. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)MPG.RENAMECANCEL" ;
    ns1:valor "Sí" .

