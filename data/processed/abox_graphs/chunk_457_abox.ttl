@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_FINEORG a ns1:Parametro ;
    rdfs:label "FINEORG" ;
    ns1:detalladoEnEsquema ns1:Tabla_TrasladosOrigen ;
    ns1:habilitadoPor ns1:Funcion_G159 ;
    ns1:identificador "MPG.FINEORG" ;
    ns1:textoExtracto "FINEORG Definición fina de los traslados de origen. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPG.FINEORG" ;
    ns1:valor "No"^^xsd:string .

ns1:Funcion_G159 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G159" ;
    ns1:textoExtracto "Al ejecutar la función G159, el CNC asume como nuevo traslado de origen la suma de ambas partes." .

ns1:Tabla_TrasladosOrigen a ns1:Tabla ;
    rdfs:label "Tabla de traslados de origen" ;
    ns1:textoExtracto "Este parámetro habilita en la tabla de traslados de orígenes la posibilidad de definir cada traslado con un valor grueso (o absoluto) y otro fino (o incremental)." .

