@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Sistema_BusSercos a ns1:Sistema ;
    rdfs:label "Bus Sercos" ;
    ns1:textoExtracto "anillo Sercos puede haber hasta 32 nodos, los módulos RCS-S siempre ocupan posiciones entre la 1 y la 15." ;
    ns1:tieneComponente ns1:Modulo_RCS_S .

ns1:Manual_ModuloRCS_S a ns1:Manual ;
    rdfs:label "Manual del módulo RCS-S" ;
    ns1:textoExtracto "Sección 2.3.41 Módulo remoto RCS-S (Contadora Sercos)." .

ns1:Modulo_RCS_S a ns1:ComponenteElectrico ;
    rdfs:label "Módulo remoto RCS-S" ;
    ns1:detalladoEnEsquema ns1:Tabla_SERCOUNTID ;
    ns1:identificador "RCS-S" ;
    ns1:monitoreaParametro ns1:Parametro_NSERCOUNT,
        ns1:Parametro_SERCOUNTID ;
    ns1:textoExtracto "Módulo remoto RCS-S (Contadora Sercos). Número de módulos RCS-S en el bus." .

ns1:Parametro_NSERCOUNT a ns1:Parametro ;
    rdfs:label "NSERCOUNT" ;
    ns1:identificador "NSERCOUNT" ;
    ns1:textoExtracto "NSERCOUNT Número de nodos contadoras Sercos en el bus. Valores posibles: De 0 a 8. Valor por defecto: 0." ;
    ns1:valor 0 .

ns1:Parametro_SERCOUNTID a ns1:Parametro ;
    rdfs:label "SERCOUNTID" ;
    ns1:identificador "SERCOUNTID" ;
    ns1:textoExtracto "SERCOUNTID n Tabla de identificadores de la ruleta asociadas a las contadoras Sercos. Valores posibles: De 1 a 15. Estos parámetros permiten asignar una numeración lógica a los módulos RCS-S del bus a partir de su dirección física, fijada por su conmutador rotativo (número de nodo)." .

ns1:Tabla_SERCOUNTID a ns1:Tabla ;
    rdfs:label "Tabla de identificadores SERCOUNTID" ;
    ns1:documentadoEn ns1:Manual_ModuloRCS_S ;
    ns1:textoExtracto "SERCOUNTID n Tabla de identificadores de la ruleta asociadas a las contadoras Sercos." .

