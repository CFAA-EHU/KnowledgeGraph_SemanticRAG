@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaParametros_Canal_n a ns1:Tabla ;
    rdfs:label "Tabla de parámetros del canal n"@es ;
    ns1:monitoreaParametro ns1:ParametrosMaquina_Canal_n ;
    ns1:textoExtracto "CHANNEL n Tabla de parámetros del canal. Este parámetro muestra la tabla de parámetros máquina del canal."@es .

ns1:ParametrosMaquina_Canal_n a ns1:Parametro ;
    rdfs:label "Parámetros máquina del canal n"@es ;
    ns1:textoExtracto "parámetros máquina del canal"@es .

