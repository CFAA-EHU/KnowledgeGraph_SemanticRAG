@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_PanelMando a ns1:InterfazUsuario ;
    rdfs:label "Panel de mando" ;
    ns1:textoExtracto "Un canal oculto no se puede resetear desde el panel de mando; para resetearlo habrá que agruparlo con otro canal o bien resetearlo desde el PLC mediante la marca RESETIN." .

ns1:ModoOperacion_Automatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático" ;
    ns1:textoExtracto "modos manual o automático. El cambio entre los modos manual y automático de un canal afectará a todos los canales del grupo que se encuentren en uno de estos modos" .

ns1:ModoOperacion_EDISIMU a ns1:ModoOperacion ;
    rdfs:label "Modo EDISIMU" ;
    ns1:textoExtracto "Los modos automático y EDISIMU sí están disponibles, pero no se permite ejecutar ni simular programas" .

ns1:ModoOperacion_MDI_MDA a ns1:ModoOperacion ;
    rdfs:label "Modo MDI/MDA" ;
    ns1:textoExtracto "Los canales gobernados desde el PLC no disponen de modo manual ni modo MDI/MDA" .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo manual" ;
    ns1:textoExtracto "modos manual o automático. El cambio entre los modos manual y automático de un canal afectará a todos los canales del grupo que se encuentren en uno de estos modos" .

ns1:Parametro_CHTYPE a ns1:Parametro ;
    rdfs:label "CHTYPE" ;
    ns1:identificador "V.[ch].MPG.CHTYPE" ;
    ns1:textoExtracto "Tipo de canal. Valores posibles: CNC / PLC / CNC+PLC. Valor por defecto: CNC. Variable asociada: (V.)[ch].MPG.CHTYPE" ;
    ns1:valor "CNC" .

ns1:Parametro_HIDDENCH a ns1:Parametro ;
    rdfs:label "HIDDENCH" ;
    ns1:identificador "V.[ch].MPG.HIDDENCH" ;
    ns1:textoExtracto "Canal oculto. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPG.HIDDENCH" ;
    ns1:valor "No" .

ns1:Sistema_GrupoCanales a ns1:Sistema ;
    rdfs:label "Sistema de agrupación de canales" ;
    ns1:compuestoPor ns1:Parametro_GROUPID ;
    ns1:textoExtracto "Dos o más canales se pueden configurar para formar un grupo. Los canales de un mismo grupo se comportan de la siguiente manera: [...] Un reset en cualquiera de los canales del grupo afecta a todos ellos. [...] Si se produce un error en cualquiera de los canales del grupo, se detiene la ejecución en todos ellos." .

ns1:Parametro_GROUPID a ns1:Parametro ;
    rdfs:label "GROUPID" ;
    ns1:identificador "V.[ch].MPG.GROUPID" ;
    ns1:textoExtracto "Grupo al que pertenece el canal. Valores posibles: De 0 a 2. Valor por defecto: 0 (no pertenece a ningún grupo). Variable asociada: (V.)[ch].MPG.GROUPID" ;
    ns1:valor "0" .

