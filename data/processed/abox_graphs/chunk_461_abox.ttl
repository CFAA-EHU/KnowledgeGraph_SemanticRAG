@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_AXISNAME a ns1:Parametro ;
    rdfs:label "AXISNAME" ;
    ns1:documentadoEn ns1:Sistema_EjesMaquina ;
    ns1:identificador "AXISNAME" ;
    ns1:textoExtracto "Puede pertenecer al canal cualquier eje definido en el parámetro AXISNAME" .

ns1:Parametro_CHNAXIS a ns1:Parametro ;
    rdfs:label "CHNAXIS" ;
    ns1:documentadoEn ns1:Sistema_EjesMaquina ;
    ns1:identificador "CHNAXIS" ;
    ns1:textoExtracto "CHNAXIS Número de ejes del canal. Valores posibles: De 0 a 28. Valor por defecto: 3. Variable asociada: (V.)[ch].MPG.CHNAXIS Este parámetro establece el número de ejes del canal, estén servocontrolados o no." ;
    ns1:valor "3" .

ns1:Parametro_NAXIS a ns1:Parametro ;
    rdfs:label "NAXIS" ;
    ns1:documentadoEn ns1:Sistema_EjesMaquina ;
    ns1:identificador "NAXIS" ;
    ns1:textoExtracto "el número de ejes del sistema, definido en el parámetro NAXIS" .

ns1:Parametro_CHAXISNAMEn a ns1:Parametro ;
    rdfs:label "CHAXISNAMEn" ;
    ns1:documentadoEn ns1:Tabla_CHAXISNAME ;
    ns1:identificador "CHAXISNAMEn" ;
    ns1:textoExtracto "CHAXISNAME n Nombre de los ejes. Valores posibles: Cualquier eje definido en AXISNAME. Valor por defecto: Comenzando por CHAXISNAME1; X, Y, Z... Variable asociada: (V.)[ch].MPG.CHAXISNAMEn" .

ns1:Tabla_CHAXISNAME a ns1:Tabla ;
    rdfs:label "Tabla CHAXISNAME" ;
    ns1:documentadoEn ns1:Sistema_EjesMaquina ;
    ns1:identificador "CHAXISNAME" ;
    ns1:textoExtracto "CHAXISNAME Lista de ejes del canal. Este parámetro muestra la tabla para definir los nombres de los ejes. [...] | CHAXISNAME |  | --- | --- | CHAXISNAME n | Nombre de los ejes." ;
    ns1:tieneComponente ns1:Parametro_CHAXISNAMEn .

ns1:Sistema_EjesMaquina a ns1:Sistema ;
    rdfs:label "Sistema de ejes de la máquina" ;
    ns1:textoExtracto "Un canal podrá tener asociado inicialmente uno, varios o ninguno de los ejes definidos en el sistema. [...] La suma de los ejes asignados a los canales tampoco podrá superar el número de ejes del sistema." ;
    ns1:tieneComponente ns1:Parametro_AXISNAME,
        ns1:Parametro_CHAXISNAMEn,
        ns1:Parametro_CHNAXIS,
        ns1:Parametro_NAXIS,
        ns1:Tabla_CHAXISNAME .

