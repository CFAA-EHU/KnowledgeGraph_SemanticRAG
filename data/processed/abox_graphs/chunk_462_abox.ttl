@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Funcion_G17 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G17 (plano XY)" ;
    ns1:identificador "G17" ;
    ns1:textoExtracto "los que seleccionamos con las funciones G17, G18 y G19" .

ns1:Funcion_G18 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G18 (plano XZ)" ;
    ns1:identificador "G18" ;
    ns1:textoExtracto "los que seleccionamos con las funciones G17, G18 y G19" .

ns1:Funcion_G19 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G19 (plano YZ)" ;
    ns1:identificador "G19" ;
    ns1:textoExtracto "los que seleccionamos con las funciones G17, G18 y G19" .

ns1:Funcion_G20 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G20 (plano de trabajo personalizado)" ;
    ns1:identificador "G20" ;
    ns1:textoExtracto "Con la función G20 podemos formar cualquier plano de trabajo con los ejes del canal." .

ns1:Parametro_CHAXISNAME_1 a ns1:Parametro ;
    rdfs:label "Parámetro CHAXISNAME 1" ;
    ns1:documentadoEn ns1:TablaConfiguracionEjesCanal ;
    ns1:textoExtracto "CHAXISNAME 1 | Índice ꞏ1ꞏ." ;
    ns1:valor "1" .

ns1:Parametro_CHAXISNAME_2 a ns1:Parametro ;
    rdfs:label "Parámetro CHAXISNAME 2" ;
    ns1:documentadoEn ns1:TablaConfiguracionEjesCanal ;
    ns1:textoExtracto "CHAXISNAME 2 | Índice ꞏ2ꞏ." ;
    ns1:valor "2" .

ns1:Parametro_CHAXISNAME_3 a ns1:Parametro ;
    rdfs:label "Parámetro CHAXISNAME 3" ;
    ns1:documentadoEn ns1:TablaConfiguracionEjesCanal ;
    ns1:textoExtracto "CHAXISNAME 3 | Índice ꞏ3ꞏ." ;
    ns1:valor "3" .

ns1:TablaConfiguracionEjesCanal a ns1:Tabla ;
    rdfs:label "Tabla de configuración de ejes del canal" ;
    ns1:identificador "Tabla 2.4.2" ;
    ns1:textoExtracto "CHAXISNAME n | Índice en el canal. [...] CHAXISNAME 3 | Índice ꞏ3ꞏ." .

