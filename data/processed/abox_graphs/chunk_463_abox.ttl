@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Funcion_G17 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G17" ;
    ns1:documentadoEn ns1:Tabla_PlanosTrabajo ;
    ns1:identificador "G17" ;
    ns1:textoExtracto "G17 | CHAXISNAME 1 | CHAXISNAME 2 | CHAXISNAME 3" .

ns1:Funcion_G18 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G18" ;
    ns1:documentadoEn ns1:Tabla_PlanosTrabajo ;
    ns1:identificador "G18" ;
    ns1:textoExtracto "G18 | CHAXISNAME 3 | CHAXISNAME 1 | CHAXISNAME 2" .

ns1:Funcion_G19 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G19" ;
    ns1:documentadoEn ns1:Tabla_PlanosTrabajo ;
    ns1:identificador "G19" ;
    ns1:textoExtracto "G19 | CHAXISNAME 2 | CHAXISNAME 3 | CHAXISNAME 1" .

ns1:Funcion_G20 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G20" ;
    ns1:identificador "G20" ;
    ns1:textoExtracto "Con la función G20 podemos formar cualquier plano de trabajo con los ejes del canal." .

ns1:SistemaEjesTorno a ns1:Sistema ;
    rdfs:label "Sistema de ejes del modelo torno" ;
    ns1:documentadoEn ns1:Tabla_PlanosTrabajo ;
    ns1:textoExtracto "En el modelo torno, este parámetro indica la configuración de ejes de la máquina, triedro o plano." ;
    ns1:tieneComponente ns1:Parametro_GEOCONFIG,
        ns1:Parametro_IPLANE .

ns1:Parametro_GEOCONFIG a ns1:Parametro ;
    rdfs:label "GEOCONFIG" ;
    ns1:identificador "GEOCONFIG" ;
    ns1:textoExtracto "GEOCONFIG Configuración geométrica de los ejes del canal. Valores posibles: Plano / Triedro. Valor por defecto: Triedro. Variable asociada: (V.)[ch].MPG.GEOCONFIG" ;
    ns1:valor "Triedro"^^xsd:string .

ns1:Parametro_IPLANE a ns1:Parametro ;
    rdfs:label "IPLANE" ;
    ns1:identificador "IPLANE" ;
    ns1:textoExtracto "El plano habitual de trabajo será G18 (si se ha configurado así en el parámetro IPLANE)." .

ns1:Tabla_PlanosTrabajo a ns1:Tabla ;
    rdfs:label "Tabla de planos de trabajo (G17, G18, G19)" ;
    ns1:textoExtracto "| Plano. | Eje de abscisas. | Eje de ordenadas. | Eje longitudinal. | --- | --- | --- | --- | G17 | CHAXISNAME 1 | CHAXISNAME 2 | CHAXISNAME 3 | G18 | CHAXISNAME 3 | CHAXISNAME 1 | CHAXISNAME 2 | G19 | CHAXISNAME 2 | CHAXISNAME 3 | CHAXISNAME 1" .

