@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:ConfiguracionEjesPlano a ns1:Esquema ;
    ns1:textoExtracto "Configuración de ejes tipo \"plano\". Esta configuración dispone de dos ejes formando el habitual plano de trabajo en torno. Puede haber más ejes, pero no pueden formar parte del triedro; deberán ser ejes auxiliares, rotativos, etc." .

ns1:ParametroIPLANE a ns1:Parametro ;
    ns1:identificador "IPLANE" ;
    ns1:textoExtracto "el parámetro máquina IPLANE no se aplica" .

ns1:PlanoG17 a ns1:Tabla ;
    ns1:textoExtracto "Plano. | Eje de abscisas. | Eje de ordenadas. | Eje longitudinal. | G17 | CHAXISNAME 1 | CHAXISNAME 2 | CHAXISNAME 3 |" ;
    ns1:tieneComponente ns1:EjeAbscisasG17,
        ns1:EjeLongitudinalG17,
        ns1:EjeOrdenadasG17 .

ns1:PlanoG18 a ns1:Tabla ;
    ns1:textoExtracto "Plano. | Eje de abscisas. | Eje de ordenadas. | Eje longitudinal. | G18 | CHAXISNAME 3 | CHAXISNAME 1 | CHAXISNAME 2 |" ;
    ns1:tieneComponente ns1:EjeAbscisasG18,
        ns1:EjeLongitudinalG18,
        ns1:EjeOrdenadasG18 .

ns1:PlanoG19 a ns1:Tabla ;
    ns1:textoExtracto "Plano. | Eje de abscisas. | Eje de ordenadas. | Eje longitudinal. | G19 | CHAXISNAME 2 | CHAXISNAME 3 | CHAXISNAME 1 |" ;
    ns1:tieneComponente ns1:EjeAbscisasG19,
        ns1:EjeLongitudinalG19,
        ns1:EjeOrdenadasG19 .

ns1:PlanoTrabajoG18 a ns1:ModoOperacion ;
    ns1:identificador "G18" ;
    ns1:textoExtracto "el plano de trabajo siempre es G18 y estará formado por los dos primeros ejes definidos en el canal" .

ns1:EjeAbscisasG17 a ns1:Parametro ;
    ns1:textoExtracto "Eje de abscisas. | G17 | CHAXISNAME 1" .

ns1:EjeAbscisasG18 a ns1:Parametro ;
    ns1:textoExtracto "Eje de abscisas. | G18 | CHAXISNAME 3" .

ns1:EjeAbscisasG19 a ns1:Parametro ;
    ns1:textoExtracto "Eje de abscisas. | G19 | CHAXISNAME 2" .

ns1:EjeLongitudinalG17 a ns1:Parametro ;
    ns1:textoExtracto "Eje longitudinal. | G17 | CHAXISNAME 3" .

ns1:EjeLongitudinalG18 a ns1:Parametro ;
    ns1:textoExtracto "Eje longitudinal. | G18 | CHAXISNAME 2" .

ns1:EjeLongitudinalG19 a ns1:Parametro ;
    ns1:textoExtracto "Eje longitudinal. | G19 | CHAXISNAME 1" .

ns1:EjeOrdenadasG17 a ns1:Parametro ;
    ns1:textoExtracto "Eje de ordenadas. | G17 | CHAXISNAME 2" .

ns1:EjeOrdenadasG18 a ns1:Parametro ;
    ns1:textoExtracto "Eje de ordenadas. | G18 | CHAXISNAME 1" .

ns1:EjeOrdenadasG19 a ns1:Parametro ;
    ns1:textoExtracto "Eje de ordenadas. | G19 | CHAXISNAME 3" .

