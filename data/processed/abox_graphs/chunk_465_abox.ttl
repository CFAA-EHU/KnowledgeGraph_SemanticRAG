@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FuncionG17 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G17" ;
    ns1:identificador "G17" ;
    ns1:textoExtracto "G17: No cambia de plano y muestra un warning avisando de ello." .

ns1:FuncionG18 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G18" ;
    ns1:habilitadoPor ns1:ConfiguracionEjesPlano ;
    ns1:identificador "G18" ;
    ns1:ilustradoEn ns1:TablaFuncionesG ;
    ns1:textoExtracto "G18: No produce ningún efecto (salvo que esté activa la función G20)." .

ns1:FuncionG19 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G19" ;
    ns1:identificador "G19" ;
    ns1:textoExtracto "G19: No cambia de plano y muestra un warning avisando de ello." .

ns1:FuncionG20 a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G20" ;
    ns1:habilitadoPor ns1:ConfiguracionEjesPlano ;
    ns1:identificador "G20" ;
    ns1:ilustradoEn ns1:TablaFuncionesG ;
    ns1:solucionaFallo ns1:HerramientaFresadora ;
    ns1:textoExtracto "G20: Se permite si no altera el plano principal; es decir, sólo se puede usar para cambiar el eje longitudinal." .

ns1:HerramientaTorno a ns1:Herramienta ;
    rdfs:label "Herramienta de torno" ;
    ns1:requiereMantenimiento ns1:ConfiguracionEjesPlano ;
    ns1:textoExtracto "Con herramientas de torno la compensación de longitud se aplica en todos los ejes en los que se haya definido offset en la herramienta." .

ns1:Sentencia_TOOL_AX a ns1:Parametro ;
    rdfs:label "Sentencia #TOOL AX" ;
    ns1:identificador "#TOOL AX" ;
    ns1:textoExtracto "Cuando en un torno se vayan a emplear herramientas de fresadora, se puede cambiar el eje de compensación longitudinal con la sentencia #TOOL AX o la función G20." .

ns1:HerramientaFresadora a ns1:Herramienta ;
    rdfs:label "Herramienta de fresadora" ;
    ns1:requiereMantenimiento ns1:ConfiguracionEjesPlano ;
    ns1:textoExtracto "Este eje longitudinal es en el que se aplica la compensación de longitud cuando se emplean herramientas de fresadora." .

ns1:TablaFuncionesG a ns1:Tabla ;
    rdfs:label "Tabla de funciones G para planos de trabajo" ;
    ns1:documentadoEn ns1:ConfiguracionEjesPlano ;
    ns1:textoExtracto "| Función. | Significado. | --- | --- | G17 | No cambia de plano y muestra un warning avisando de ello. | G18 | No produce ningún efecto (salvo que esté activa la función G20). | G19 | No cambia de plano y muestra un warning avisando de ello. | G20 | Se permite si no altera el plano principal; es decir, sólo se puede usar para cambiar el eje longitudinal." .

ns1:ConfiguracionEjesPlano a ns1:ModoOperacion ;
    rdfs:label "Configuración de ejes tipo 'plano'" ;
    ns1:textoExtracto "Configuración de ejes tipo 'plano'. Programación de arcos. [...] El eje longitudinal. En esta configuración se considera como eje longitudinal el segundo eje del canal." .

