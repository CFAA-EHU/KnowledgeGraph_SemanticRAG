@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionEjesPlano a ns1:ModoOperacion ;
    rdfs:label "Configuración de ejes tipo \"plano\"" ;
    ns1:textoExtracto "Configuración de ejes tipo \"plano\"" .

ns1:Funcion_G20 a ns1:Parametro ;
    rdfs:label "G20" ;
    ns1:textoExtracto "función G20" .

ns1:IntercambioEjes a ns1:AccionProhibida ;
    rdfs:label "Intercambio de ejes" ;
    ns1:textoExtracto "Se permite el intercambio de ejes, pero se debe tener en cuenta que el comportamiento anterior se mantiene; es decir, todo el tratamiento explicado anteriormente se mantiene para los ejes primero y segundo del canal que resulten del intercambio." .

ns1:Sentencia_TOOL_AX a ns1:Parametro ;
    rdfs:label "TOOL AX" ;
    ns1:textoExtracto "sentencia #TOOL AX" .

