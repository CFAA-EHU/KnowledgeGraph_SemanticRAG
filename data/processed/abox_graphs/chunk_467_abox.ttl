@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_CHNSPDL a ns1:Parametro ;
    rdfs:label "CHNSPDL" ;
    ns1:identificador "CHNSPDL" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "CHNSPDL Número de cabezales del canal. Valores posibles: De 0 a 4. Valor por defecto: 1. Variable asociada: (V.)[ch].MPG.CHNSPDL Este parámetro establece el número de cabezales del canal, estén servocontrolados o no." ;
    ns1:valor 1 .

ns1:Parametro_CHSPDLNAME a ns1:Parametro ;
    rdfs:label "CHSPDLNAME" ;
    ns1:detalladoEnEsquema ns1:Tabla_CHSPDLNAME ;
    ns1:identificador "CHSPDLNAME" ;
    ns1:textoExtracto "CHSPDLNAME Lista de cabezales del canal. Este parámetro muestra la tabla para definir los nombres de los cabezales. El número de cabezales del canal lo establece el parámetro CHNSPDL." .

ns1:Parametro_NSPDL a ns1:Parametro ;
    rdfs:label "NSPDL" ;
    ns1:identificador "NSPDL" ;
    ns1:textoExtracto "número de cabezales del sistema, definido en el parámetro NSPDL" .

ns1:Parametro_SPDLNAME a ns1:Parametro ;
    rdfs:label "SPDLNAME" ;
    ns1:identificador "SPDLNAME" ;
    ns1:textoExtracto "Cualquier cabezal definido en SPDLNAME" .

ns1:Componente_CabezalMaster a ns1:Componente ;
    rdfs:label "Cabezal Master" ;
    ns1:textoExtracto "el canal asume como cabezal master el primer cabezal definido en los parámetros máquina del canal (master original)" .

ns1:Manual_ConfiguracionCabezales a ns1:Manual ;
    rdfs:label "Sección 2.4.3 Configuración de los cabezales del canal" ;
    ns1:identificador "2.4.3" ;
    ns1:textoExtracto "Configuración de los cabezales del canal. Este parámetro establece el número de cabezales del canal, estén servocontrolados o no." .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "arranque del CNC y tras un reset, el canal asume como cabezal master el primer cabezal definido en los parámetros máquina del canal" ;
    ns1:tieneComponente ns1:Componente_CabezalMaster .

ns1:Tabla_CHSPDLNAME a ns1:Tabla ;
    rdfs:label "Tabla CHSPDLNAME" ;
    ns1:documentadoEn ns1:Manual_ConfiguracionCabezales ;
    ns1:identificador "CHSPDLNAME" ;
    ns1:textoExtracto "| CHSPDLNAME |  | --- | --- | CHSPDLNAME n | Nombre de los cabezales. | CHSPDLNAME n Nombre de los cabezales. Valores posibles: Cualquier cabezal definido en SPDLNAME." .

