@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionCabezalesCanal a ns1:Sistema ;
    rdfs:label "Configuración de cabezales del canal"@es ;
    ns1:textoExtracto "A la hora de definir los cabezales, hay que tener en cuenta que el orden en el que se definen establece su índice en el canal. El primer cabezal de la tabla tendrá índice ꞏ1ꞏ y así sucesivamente. Al igual que el nombre d..."@es ;
    ns1:tieneComponente ns1:Cabezal_1 .

ns1:Cabezal_1 a ns1:Componente ;
    rdfs:label "Cabezal (índice 1)"@es ;
    ns1:identificador "1" ;
    ns1:textoExtracto "El primer cabezal de la tabla tendrá índice ꞏ1ꞏ"@es .

