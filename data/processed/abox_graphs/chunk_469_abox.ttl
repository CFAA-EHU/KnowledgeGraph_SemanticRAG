@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_ConfiguracionCabezalesCanal a ns1:Tabla ;
    rdfs:label "Tabla de configuración de cabezales del canal"@es ;
    ns1:documentadoEn ns1:Pagina_116 ;
    ns1:identificador "CHSPDLNAME" ;
    ns1:textoExtracto """
| CHSPDLNAME | Índice en el canal. |
| --- | --- |
| CHSPDLNAME 1 | Índice ꞏ1ꞏ. |
| CHSPDLNAME 2 | Índice ꞏ2ꞏ. |
| CHSPDLNAME 3 | Índice ꞏ3ꞏ. """@es .

ns1:Pagina_116 a ns1:Pagina ;
    ns1:identificador "116" ;
    ns1:textoExtracto "2.4.3 Configuración de los cabezales del canal"@es .

