@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_ALIGNC a ns1:Parametro ;
    rdfs:label "ALIGNC" ;
    ns1:identificador "ALIGNC" ;
    ns1:textoExtracto "ALIGNC Alineamiento del eje C para mecanizado diametral. Valores posibles: Sí / No. Valor por defecto: Sí." ;
    ns1:valor "Sí" .

ns1:Parametro_CAXNAME a ns1:Parametro ;
    rdfs:label "CAXNAME" ;
    ns1:identificador "CAXNAME" ;
    ns1:textoExtracto "CAXNAME Nombre por defecto del eje C. Valores posibles: Cualquier nombre de eje válido; X, X1ꞏꞏX9, ꞏꞏ , C, C1ꞏꞏC9. Valor por defecto: C." ;
    ns1:valor "C" .

ns1:Sentencia_CAX a ns1:InterfazUsuario ;
    rdfs:label "#CAX" ;
    ns1:identificador "#CAX" ;
    ns1:textoExtracto "desde el programa se usará la sentencia #CAX para indicar cuál está activo. Sólo puede haber activo un eje C en cada canal." .

ns1:Variable_V_ch_MPG_ALIGNC a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPG.ALIGNC" ;
    ns1:identificador "(V.)[ch].MPG.ALIGNC" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.ALIGNC" .

ns1:Variable_V_ch_MPG_CAXNAME a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPG.CAXNAME" ;
    ns1:identificador "(V.)[ch].MPG.CAXNAME" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.CAXNAME" .

