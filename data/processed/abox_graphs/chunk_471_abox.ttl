@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Herramienta_MecanizadoEjeC a ns1:Herramienta ;
    rdfs:label "Herramienta de mecanizado para eje C" ;
    ns1:textoExtracto "Continuar el mecanizado retrocediendo la herramienta." .

ns1:TareaMantenimiento_MecanizadoEjeC a ns1:TareaMantenimiento ;
    rdfs:label "Mecanizado del eje C" ;
    ns1:requiereMantenimiento ns1:Parametro_ALIGNC ;
    ns1:textoExtracto "(1)Mecanizado hasta el centro. (2)Girar 180° el eje C. (3)Continuar el mecanizado retrocediendo la herramienta." .

ns1:Parametro_ALIGNC a ns1:Parametro ;
    rdfs:label "ALIGNC" ;
    ns1:textoExtracto "ALIGNC | Significado. Sí. (1)Mecanizado hasta el centro. (2)Girar 180° el eje C. (3)Continuar el mecanizado retrocediendo la herramienta." ;
    ns1:valor "Sí" .

