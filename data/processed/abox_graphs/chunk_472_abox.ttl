@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_LOOPTIME a ns1:Parametro ;
    rdfs:label "LOOPTIME" ;
    ns1:identificador "LOOPTIME" ;
    ns1:textoExtracto "El número de bloques a preparar depende del tipo de mecanizado [...] Este parámetro fija el número máximo de bloques que debe procesar el CNC en cada ciclo (parámetro LOOPTIME)." .

ns1:Parametro_PREPFREQ a ns1:Parametro ;
    rdfs:label "PREPFREQ" ;
    ns1:identificador "PREPFREQ" ;
    ns1:textoExtracto "PREPFREQ Número máximo de bloques a preparar por ciclo. Valores posibles: De 1 a 8. Valor por defecto: 1." ;
    ns1:valor 1 .

ns1:Variable_V_MPG_PREPFREQ a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPG.PREPFREQ" ;
    ns1:identificador "(V.)[ch].MPG.PREPFREQ" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.PREPFREQ" .

