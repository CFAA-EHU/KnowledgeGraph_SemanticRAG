@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Senal_ADVINPOS a ns1:ComponenteElectrico ;
    rdfs:label "Señal ADVINPOS"@es ;
    ns1:controla ns1:Parametro_ADVINPOS ;
    ns1:monitoreaParametro ns1:Parametro_DuracionMovimiento ;
    ns1:textoExtracto "señal de anticipación ADVINPOS"@es .

ns1:Parametro_ADVINPOS a ns1:Parametro ;
    rdfs:label "ADVINPOS"@es ;
    ns1:identificador "ADVINPOS" ;
    ns1:textoExtracto "señal de anticipación ADVINPOS"@es ;
    ns1:valor "0"@es .

ns1:Parametro_DuracionMovimiento a ns1:Parametro ;
    rdfs:label "Duración del movimiento"@es ;
    ns1:textoExtracto "duración total del movimiento"@es ;
    ns1:valor "inferior al valor especificado en el parámetro"@es .

