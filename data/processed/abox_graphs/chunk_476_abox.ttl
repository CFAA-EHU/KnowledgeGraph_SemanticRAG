@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_HSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC (High Speed Cutting)" ;
    ns1:textoExtracto "Configuración del modo HSC (canal)" ;
    ns1:tieneComponente ns1:Parametro_CORNER,
        ns1:Parametro_FASTFACTOR,
        ns1:Parametro_FASTFILTFREQ,
        ns1:Parametro_FEEDAVRG,
        ns1:Parametro_FREQRES,
        ns1:Parametro_FSMOOTHFREQ,
        ns1:Parametro_FTIMELIM,
        ns1:Parametro_HSCDEFAULTMODE,
        ns1:Parametro_HSCFILTFREQ,
        ns1:Parametro_HSCROUND,
        ns1:Parametro_MINCORFEED,
        ns1:Parametro_ORISMOOTH,
        ns1:Parametro_SMOOTHFREQ,
        ns1:Parametro_SOFTFREQ,
        ns1:Parametro_SURFFILTFREQ .

ns1:Parametro_CORNER a ns1:Parametro ;
    rdfs:label "CORNER" ;
    ns1:identificador "CORNER" ;
    ns1:textoExtracto "Ángulo máximo de la esquina para mecanizarla en arista viva." ;
    ns1:valor "Ángulo máximo para arista viva" .

ns1:Parametro_FASTFACTOR a ns1:Parametro ;
    rdfs:label "FASTFACTOR" ;
    ns1:identificador "FASTFACTOR" ;
    ns1:textoExtracto "Porcentaje de avance por defecto (modo FAST)." ;
    ns1:valor "Porcentaje de avance (FAST)" .

ns1:Parametro_FASTFILTFREQ a ns1:Parametro ;
    rdfs:label "FASTFILTFREQ" ;
    ns1:identificador "FASTFILTFREQ" ;
    ns1:textoExtracto "Frecuencia del filtro (modo FAST)." ;
    ns1:valor "Frecuencia del filtro (FAST)" .

ns1:Parametro_FEEDAVRG a ns1:Parametro ;
    rdfs:label "FEEDAVRG" ;
    ns1:identificador "FEEDAVRG" ;
    ns1:textoExtracto "Calcular el promedio del avance." ;
    ns1:valor "Promedio del avance" .

ns1:Parametro_FREQRES a ns1:Parametro ;
    rdfs:label "FREQRES" ;
    ns1:identificador "FREQRES" ;
    ns1:textoExtracto "Primera frecuencia de resonancia de la máquina." ;
    ns1:valor "Frecuencia de resonancia" .

ns1:Parametro_FSMOOTHFREQ a ns1:Parametro ;
    rdfs:label "FSMOOTHFREQ" ;
    ns1:identificador "FSMOOTHFREQ" ;
    ns1:textoExtracto "Frecuencia de suavizado en la interpolación (modo FAST)." ;
    ns1:valor "Frecuencia de suavizado (FAST)" .

ns1:Parametro_FTIMELIM a ns1:Parametro ;
    rdfs:label "FTIMELIM" ;
    ns1:identificador "FTIMELIM" ;
    ns1:textoExtracto "Diferencia de tiempo admisible en la interpolación del avance (modo FAST)." ;
    ns1:valor "Diferencia de tiempo admisible (FAST)" .

ns1:Parametro_HSCDEFAULTMODE a ns1:Parametro ;
    rdfs:label "HSCDEFAULTMODE" ;
    ns1:identificador "HSCDEFAULTMODE" ;
    ns1:textoExtracto "Modo por defecto al programar #HSC ON." ;
    ns1:valor "Modo por defecto" .

ns1:Parametro_HSCFILTFREQ a ns1:Parametro ;
    rdfs:label "HSCFILTFREQ" ;
    ns1:identificador "HSCFILTFREQ" ;
    ns1:textoExtracto "Frecuencia del filtro (modo CONTERROR)." ;
    ns1:valor "Frecuencia del filtro (CONTERROR)" .

ns1:Parametro_HSCROUND a ns1:Parametro ;
    rdfs:label "HSCROUND" ;
    ns1:identificador "HSCROUND" ;
    ns1:textoExtracto "Valor por defecto del error máximo de la trayectoria en HSC." ;
    ns1:valor "Error máximo de trayectoria" .

ns1:Parametro_MINCORFEED a ns1:Parametro ;
    rdfs:label "MINCORFEED" ;
    ns1:identificador "MINCORFEED" ;
    ns1:textoExtracto "Velocidad mínima en las esquinas." ;
    ns1:valor "Velocidad mínima en esquinas" .

ns1:Parametro_ORISMOOTH a ns1:Parametro ;
    rdfs:label "ORISMOOTH" ;
    ns1:identificador "ORISMOOTH" ;
    ns1:textoExtracto "Suavizado de la orientación de los ejes rotativos trabajando con RTCP." ;
    ns1:valor "Suavizado de orientación (RTCP)" .

ns1:Parametro_SMOOTHFREQ a ns1:Parametro ;
    rdfs:label "SMOOTHFREQ" ;
    ns1:identificador "SMOOTHFREQ" ;
    ns1:textoExtracto "Frecuencia de suavizado en la interpolación." ;
    ns1:valor "Frecuencia de suavizado (modo estándar)" .

ns1:Parametro_SOFTFREQ a ns1:Parametro ;
    rdfs:label "SOFTFREQ" ;
    ns1:identificador "SOFTFREQ" ;
    ns1:textoExtracto "Frecuencia del filtro de trayectoria para perfiles de aceleración lineal." ;
    ns1:valor "Frecuencia del filtro (trayectoria lineal)" .

ns1:Parametro_SURFFILTFREQ a ns1:Parametro ;
    rdfs:label "SURFFILTFREQ" ;
    ns1:identificador "SURFFILTFREQ" ;
    ns1:textoExtracto "Frecuencia del filtro de ejes (modo SURFACE)." ;
    ns1:valor "Frecuencia del filtro (SURFACE)" .

