@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_HSCDEFAULTMODE a ns1:ModoOperacion ;
    rdfs:label "HSCDEFAULTMODE" ;
    ns1:identificador "HSCDEFAULTMODE" ;
    ns1:monitoreaParametro ns1:Parametro_HSCDEFAULTMODE ;
    ns1:textoExtracto "HSCDEFAULTMODE Modo por defecto al programar #HSC ON. Valores posibles: SURFACE / CONTERROR / FAST. Valor por defecto: SURFACE." .

ns1:Parametro_CORNER a ns1:Parametro ;
    rdfs:label "CORNER" ;
    ns1:identificador "(V.)[ch].MPG.CORNER" ;
    ns1:textoExtracto "CORNER Ángulo máximo de la esquina para mecanizarla en arista viva. Valores posibles: De 0 a 180.0000º. Valor por defecto: 0. Variable asociada: (V.)[ch].MPG.CORNER Este parámetro indica el ángulo máximo entre dos trayectorias, por debajo del cual se mecaniza en arista viva." ;
    ns1:valor "0" .

ns1:Parametro_FEEDAVRG a ns1:Parametro ;
    rdfs:label "FEEDAVRG" ;
    ns1:identificador "(V.)[ch].MPG.FEEDAVRG" ;
    ns1:textoExtracto "FEEDAVRG Calcular el promedio del avance. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)[ch].MPG.FEEDAVRG Este parámetro habilita el ajuste del avance en función de la velocidad de lectura de bloques y del tamaño de los mismos." ;
    ns1:valor "Sí" .

ns1:Parametro_MINCORFEED a ns1:Parametro ;
    rdfs:label "MINCORFEED" ;
    ns1:identificador "(V.)[ch].MPG.MINCORFEED" ;
    ns1:textoExtracto "MINCORFEED Velocidad mínima en las esquinas. Valores posibles: De 0 a 200000.0000 mm/min / de 0 a 7874.01575 inch/min. Valor por defecto: 0. Variable asociada: (V.)[ch].MPG.MINCORFEED No se recomienda modificar este valor, porque se puede sobrepasar la dinámica de los ejes." ;
    ns1:valor "0" .

ns1:Parametro_PREPFREQ a ns1:Parametro ;
    rdfs:label "PREPFREQ" ;
    ns1:identificador "PREPFREQ" ;
    ns1:textoExtracto "La velocidad de lectura de bloques depende del parámetro máquina PREPFREQ." .

ns1:Parametro_SMOOTHFREQ a ns1:Parametro ;
    rdfs:label "SMOOTHFREQ" ;
    ns1:identificador "(V.)[ch].MPG.SMOOTHFREQ" ;
    ns1:textoExtracto "SMOOTHFREQ Frecuencia de suavizado en la interpolación. Valores posibles: De 0 a 500.0000. Valor por defecto: 0 (no está activa). Variable asociada: (V.)[ch].MPG.SMOOTHFREQ Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias." ;
    ns1:valor "0" .

ns1:Parametro_HSCDEFAULTMODE a ns1:Parametro ;
    rdfs:label "HSCDEFAULTMODE" ;
    ns1:identificador "(V.)[ch].MPG.HSCDEFAULTMODE" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.HSCDEFAULTMODE" ;
    ns1:valor "SURFACE" .

