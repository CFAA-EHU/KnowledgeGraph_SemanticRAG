@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro1 a ns1:Parametro ;
    rdfs:label "Frecuencia de suavizado en la interpolación de trayectorias" ;
    ns1:identificador "MPG.SMOOTHFREQ" ;
    ns1:mitigaRiesgo ns1:ModoHSC ;
    ns1:textoExtracto "Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias. Este parámetro evita acelerar y decelerar a lo largo de una trayectoria, por encima de una determinada frecuencia al generar una velocidad promediada." .

ns1:Parametro2 a ns1:Parametro ;
    rdfs:label "Frecuencia del filtro en el modo CONTERROR" ;
    ns1:identificador "HSCFILTFREQ" ;
    ns1:mitigaRiesgo ns1:ModoHSC ;
    ns1:textoExtracto "Este parámetro fija la frecuencia del filtro en el modo CONTERROR. Este parámetro es válido cuando el perfil de aceleración es trapezoidal o seno cuadrado, que es el perfil de aceleración por defecto para el modo HSC CONTERROR." .

ns1:ModoHSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC CONTERROR" ;
    ns1:textoExtracto "El modo HSC CONTERROR utiliza un perfil de aceleración trapezoidal o seno cuadrado por defecto." .

