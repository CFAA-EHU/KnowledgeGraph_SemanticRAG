@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_FASTFACTOR a ns1:Parametro ;
    rdfs:label "FASTFACTOR" ;
    ns1:identificador "FASTFACTOR" ;
    ns1:monitoreaParametro ns1:ModoOperacion_FAST ;
    ns1:textoExtracto "FASTFACTOR Porcentaje de avance por defecto (modo FAST). Valores posibles: De 0 a 100. Valor por defecto: 100."@es ;
    ns1:valor 100 .

ns1:Parametro_FTIMELIM a ns1:Parametro ;
    rdfs:label "FTIMELIM" ;
    ns1:identificador "FTIMELIM" ;
    ns1:monitoreaParametro ns1:ModoOperacion_FAST,
        ns1:ModoOperacion_SURFACE ;
    ns1:textoExtracto "FTIMELIM Diferencia de tiempo admisible en la interpolación del avance (modo FAST y SURFACE). Valores posibles: De 0 a 100000.0000 %. Valor por defecto: 200 %."@es ;
    ns1:valor "200.0"^^xsd:float .

ns1:Parametro_HSCFILTFREQ a ns1:Parametro ;
    rdfs:label "HSCFILTFREQ" ;
    ns1:identificador "HSCFILTFREQ" ;
    ns1:monitoreaParametro ns1:ModoOperacion_CONTERROR ;
    ns1:textoExtracto "HSCFILTFREQ Frecuencia del filtro (modo CONTERROR). Valores posibles: De 0 a 500.0000. Valor por defecto: 40."@es ;
    ns1:valor "40.0"^^xsd:float .

ns1:ModoOperacion_CONTERROR a ns1:ModoOperacion ;
    rdfs:label "Modo CONTERROR" ;
    ns1:textoExtracto "modo HSC CONTERROR"@es .

ns1:ModoOperacion_SURFACE a ns1:ModoOperacion ;
    rdfs:label "Modo SURFACE" ;
    ns1:textoExtracto "modo SURFACE"@es .

ns1:ModoOperacion_FAST a ns1:ModoOperacion ;
    rdfs:label "Modo FAST" ;
    ns1:textoExtracto "Este parámetro afecta al avance en las esquinas e indica el porcentaje de aceleración que se desea alcanzar, sobre el máximo que es capaz de conseguir el CNC, en el modo FAST."@es .

