@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:InterpolacionAvance a ns1:Parametro ;
    rdfs:label "Interpolación del avance" ;
    ns1:textoExtracto "Si se programa con valor 0, el CNC no realiza la interpolación del avance y por tanto la ejecución es más rápida." ;
    ns1:valor "0"^^xsd:string .

ns1:ModoHSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC (canal)" ;
    ns1:monitoreaParametro ns1:FTIMELIM ;
    ns1:textoExtracto "Configuración del modo HSC (canal)." .

ns1:FTIMELIM a ns1:Parametro ;
    rdfs:label "FTIMELIM" ;
    ns1:identificador "FTIMELIM" ;
    ns1:textoExtracto "El parámetro FTIMELIM permite limitar el tiempo que emplea el CNC para la interpolación del avance en cada tramo." .

