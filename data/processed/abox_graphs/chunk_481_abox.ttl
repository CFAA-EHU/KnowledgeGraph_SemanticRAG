@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_FASTFILTFREQ a ns1:Parametro ;
    rdfs:label "Frecuencia del filtro (FASTFILTFREQ)" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC_FAST ;
    ns1:textoExtracto "FASTFILTFREQ Frecuencia del filtro (modo FAST). Valores posibles: De 0 a 500.0000. Valor por defecto: 17. [...] activa un filtro 'paso bajo' automático para todos los ejes del canal durante la ejecución en modo HSC FAST." ;
    ns1:valor "17.0"^^xsd:float .

ns1:Parametro_FSMOOTHFREQ a ns1:Parametro ;
    rdfs:label "Frecuencia de suavizado en interpolación (FSMOOTHFREQ)" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC_FAST,
        ns1:ModoOperacion_HSC_SURFACE ;
    ns1:textoExtracto "FSMOOTHFREQ Frecuencia de suavizado en la interpolación (modo FAST y SURFACE). Valores posibles: De 0 a 500.0000. Valor por defecto: 20. [...] fija la frecuencia de suavizado en la interpolación de trayectorias para los modos HSC FAST y SURFACE." ;
    ns1:valor "20.0"^^xsd:float .

ns1:Parametro_FTIMELIM a ns1:Parametro ;
    rdfs:label "Tiempo máximo de ejecución (FTIMELIM)" ;
    ns1:textoExtracto "parámetro [...] aumenta el tiempo máximo permitido de ejecución total; por ejemplo, un valor de 200% o 300% permitirá hasta el doble o triple de tiempo de ejecución en el tramo interpolado." ;
    ns1:valor "200%–300%"^^xsd:string .

ns1:Parametro_SURFFILTFREQ a ns1:Parametro ;
    rdfs:label "Frecuencia del filtro de ejes (SURFFILTFREQ)" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC_SURFACE ;
    ns1:textoExtracto "SURFFILTFREQ Frecuencia del filtro de ejes (modo SURFACE). Valores posibles: De 0 a 500.0000 Hz. Valor por defecto: 25 Hz." ;
    ns1:valor "25.0"^^xsd:float .

ns1:ModoOperacion_HSC_FAST a ns1:ModoOperacion ;
    rdfs:label "Modo HSC FAST" ;
    ns1:textoExtracto "modo HSC FAST" .

ns1:ModoOperacion_HSC_SURFACE a ns1:ModoOperacion ;
    rdfs:label "Modo HSC SURFACE" ;
    ns1:textoExtracto "modo HSC SURFACE" .

