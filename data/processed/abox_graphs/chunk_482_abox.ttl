@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_FREQRES a ns1:Parametro ;
    rdfs:label "FREQRES" ;
    ns1:identificador "(V.)[ch].MPG.FREQRES" ;
    ns1:monitoreaParametro ns1:Maquina_Generica ;
    ns1:textoExtracto "Primera frecuencia de resonancia de la máquina. Valores posibles: De 0 a 500.0000. Valor por defecto: 0." ;
    ns1:valor "0" .

ns1:Parametro_SURFFILTFREQ a ns1:Parametro ;
    rdfs:label "SURFFILTFREQ" ;
    ns1:identificador "(V.)[ch].MPG.SURFFILTFREQ" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC_SURFACE ;
    ns1:textoExtracto "Frecuencia del filtro de ejes (modo SURFACE). Valores posibles: De 0 a 500.0000 Hz. Valor por defecto: 25 Hz." ;
    ns1:valor "25" .

ns1:Maquina_Generica a ns1:Maquina ;
    rdfs:label "Máquina" ;
    ns1:textoExtracto "Frecuencia de resonancia de la máquina." .

ns1:ModoOperacion_HSC_SURFACE a ns1:ModoOperacion ;
    rdfs:label "Modo HSC SURFACE" ;
    ns1:textoExtracto "modo HSC SURFACE, el cuál permite suavizar la respuesta de los ejes generando una trayectoria más suave." .

