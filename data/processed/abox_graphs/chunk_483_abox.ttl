@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Herramienta_FineTune a ns1:Herramienta ;
    rdfs:label "FineTune" ;
    ns1:textoExtracto "Este parámetro se debe ajustar con ayuda de la aplicación FineTune."@es .

ns1:Parametro_FREQRES a ns1:Parametro ;
    rdfs:label "FREQRES" ;
    ns1:identificador "FREQRES" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC ;
    ns1:textoExtracto "FREQRES Primera frecuencia de resonancia de la máquina. Valores posibles: De 0 a 500.0000. Valor por defecto: 0. Variable asociada: (V.)[ch].MPG.FREQRES Frecuencia de resonancia que el CNC debe eliminar en la generación de la consigna."@es ;
    ns1:valor "0" .

ns1:Parametro_HSCROUND a ns1:Parametro ;
    rdfs:label "HSCROUND" ;
    ns1:identificador "HSCROUND" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC ;
    ns1:textoExtracto "HSCROUND Valor por defecto del error máximo de la trayectoria en HSC. Valores posibles: De 0.0001 a 99999.9999 mm / de 0 a 3937.00787 inch. Valor por defecto: 0.06 mm / 0.00236 inch. Variable asociada: (V.)[ch].MPG.HSCROUND Error máximo de la trayectoria en HSC."@es ;
    ns1:valor "0.06 mm / 0.00236 inch" .

ns1:Parametro_ORISMOOTH a ns1:Parametro ;
    rdfs:label "ORISMOOTH" ;
    ns1:identificador "ORISMOOTH" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC ;
    ns1:textoExtracto "ORISMOOTH Suavizado de la orientación de los ejes rotativos trabajando con RTCP. Valores posibles: De 0 a 200 ms. Valor por defecto: 60 ms. Variable asociada: (V.)[ch].MPG.ORISMOOTH Este parámetro suaviza la orientación de los ejes rotativos, sin error en la punta de la herramienta, al trabajar con RTCP en modo HSC SURFACE."@es ;
    ns1:valor "60 ms" .

ns1:Parametro_SOFTFREQ a ns1:Parametro ;
    rdfs:label "SOFTFREQ" ;
    ns1:identificador "SOFTFREQ" ;
    ns1:monitoreaParametro ns1:ModoOperacion_HSC ;
    ns1:textoExtracto "SOFTFREQ Frecuencia del filtro de trayectoria para perfiles de aceleración lineal. Valores posibles: De 0 a 500.0000 Hz. Valor por defecto: 25 Hz. Variable asociada: (V.)[ch].MPG.SOFTFREQ Este parámetro permite suavizar el perfil de velocidad en modo HSC SURFACE, lo que permite mejorar el tiempo y la calidad superficial del mecanizado."@es ;
    ns1:valor "25 Hz" .

ns1:ModoOperacion_HSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC" ;
    ns1:textoExtracto "modo HSC CONTERROR... Este parámetro permite suavizar el perfil de velocidad en modo HSC SURFACE"@es .

