@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_EjeVirtualHerramienta a ns1:Sistema ;
    rdfs:label "Eje virtual de la herramienta" ;
    ns1:habilitadoPor ns1:ModoOperacion_Automatico,
        ns1:ModoOperacion_InspeccionHerramienta,
        ns1:ModoOperacion_Manual,
        ns1:ModoOperacion_ReposicionEjes ;
    ns1:monitoreaParametro ns1:Parametro_VIRTAXCANCEL,
        ns1:Parametro_VIRTAXISNAME ;
    ns1:textoExtracto "El eje virtual de la herramienta debe ser un eje lineal, pertenecer al canal y no puede ser parte del triedro principal cuando se encuentra activo. Al ser un eje del canal, es posible moverlo como cualquier otro eje en los distintos modos de trabajo; automático, manual, inspección de herramienta, reposición de ejes, etc." .

ns1:ModoOperacion_Automatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático" ;
    ns1:textoExtracto "modos de trabajo; automático, manual, inspección de herramienta, reposición de ejes, etc." .

ns1:ModoOperacion_InspeccionHerramienta a ns1:ModoOperacion ;
    rdfs:label "Inspección de herramienta" ;
    ns1:textoExtracto "modos de trabajo; automático, manual, inspección de herramienta, reposición de ejes, etc." .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo manual" ;
    ns1:textoExtracto "modos de trabajo; automático, manual, inspección de herramienta, reposición de ejes, etc." .

ns1:ModoOperacion_ReposicionEjes a ns1:ModoOperacion ;
    rdfs:label "Reposición de ejes" ;
    ns1:textoExtracto "modos de trabajo; automático, manual, inspección de herramienta, reposición de ejes, etc." .

ns1:Parametro_VIRTAXCANCEL a ns1:Parametro ;
    rdfs:label "VIRTAXCANCEL" ;
    ns1:identificador "(V.)[ch].MPG.VIRTAXCANCEL" ;
    ns1:textoExtracto "VIRTAXCANCEL Cancelación automática del eje virtual de la herramienta tras M30 y Reset. Valores posibles: Sí / No. Valor por defecto: No. Este parámetro indica si el CNC anula o no el eje virtual de la herramienta tras ejecutar M02/M30 y tras un reset." ;
    ns1:valor "No" .

ns1:Parametro_VIRTAXISNAME a ns1:Parametro ;
    rdfs:label "VIRTAXISNAME" ;
    ns1:identificador "(V.)[ch].MPG.VIRTAXISNAME" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.VIRTAXISNAME Nombre con el que se identifica el eje virtual de la herramienta. El eje virtual de la herramienta debe ser un eje lineal, pertenecer al canal y no puede ser parte del triedro principal cuando se encuentra activo." ;
    ns1:valor "ninguno" .

