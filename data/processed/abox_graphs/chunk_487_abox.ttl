@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC (control numérico)"@es ;
    ns1:controla ns1:InterfazUsuario_SentenciaKIN ;
    ns1:textoExtracto "El CNC puede tener definidas hasta 6 cinemáticas distintas. [...] Este parámetro indica si en el arranque, el CNC cancela el plano inclinado (#CS/#ACS) que se encontraba activo cuando se apagó."@es ;
    ns1:tieneComponente ns1:Parametro_CSCANCEL,
        ns1:Parametro_CinematicaDefecto,
        ns1:Parametro_LINKCANCEL .

ns1:InterfazUsuario_SentenciaKIN a ns1:InterfazUsuario ;
    rdfs:label "Sentencia #KIN ID (selección de cinemática)"@es ;
    ns1:identificador "#KIN_ID" ;
    ns1:textoExtracto "Para seleccionar otra cinemática desde el programa pieza utilizar la sentencia #KIN ID."@es .

ns1:Parametro_CSCANCEL a ns1:Parametro ;
    rdfs:label "CSCANCEL (Cancelar plano inclinado en arranque)"@es ;
    ns1:identificador "CSCANCEL" ;
    ns1:textoExtracto "CSCANCEL Cancelar el plano inclinado en el arranque. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)[ch].MPG.CSCANCEL Este parámetro indica si en el arranque, el CNC cancela el plano inclinado (#CS/#ACS) que se encontraba activo cuando se apagó."@es ;
    ns1:valor "Sí" .

ns1:Parametro_CinematicaDefecto a ns1:Parametro ;
    rdfs:label "Cinemática por defecto (valor 'Ninguna')"@es ;
    ns1:identificador "Cinemática_Defecto" ;
    ns1:textoExtracto "Si se define con valor \"Ninguna\", el CNC no activa ninguna cinemática por defecto. El CNC puede tener definidas hasta 6 cinemáticas distintas."@es ;
    ns1:valor "Ninguna" .

ns1:Parametro_LINKCANCEL a ns1:Parametro ;
    rdfs:label "LINKCANCEL (Cancelar acoplamiento de ejes por defecto)"@es ;
    ns1:identificador "LINKCANCEL" ;
    ns1:textoExtracto "LINKCANCEL Cancelar el acoplamiento de ejes por defecto. Valores posibles: Sí / No. Valor por defecto: Sí."@es ;
    ns1:valor "Sí" .

