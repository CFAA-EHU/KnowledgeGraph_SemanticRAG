@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_LINKCANCEL a ns1:Parametro ;
    rdfs:label "LINKCANCEL" ;
    ns1:identificador "(V.)[ch].MPG.LINKCANCEL" ;
    ns1:textoExtracto "LINKCANCEL Cancelar el acoplamiento de ejes por defecto. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)[ch].MPG.LINKCANCEL Este parámetro indica si se anulan o no los acoplamientos de ejes activos (#LINK) cuando finaliza el programa pieza, tras una emergencia y tras un reset." ;
    ns1:valor "Sí" .

ns1:Parametro_MIRRORCANCEL a ns1:Parametro ;
    rdfs:label "MIRRORCANCEL" ;
    ns1:identificador "(V.)[ch].MPG.MIRRORCANCEL" ;
    ns1:textoExtracto "MIRRORCANCEL Cancelar la imagen espejo (G11/G12/G13/G14) tras M30 y reset. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)[ch].MPG.MIRRORCANCEL Este parámetro indica si se anula o no la imagen espejo cuando finaliza el programa pieza y tras un reset." ;
    ns1:valor "Sí" .

ns1:Parametro_SLOPETYPE a ns1:Parametro ;
    rdfs:label "SLOPETYPE" ;
    ns1:identificador "(V.)[ch].MPG.SLOPETYPE" ;
    ns1:textoExtracto "SLOPETYPE Tipo de aceleración por defecto. Valores posibles: Lineal / Trapezoidal / Seno cuadrado (Square" .

