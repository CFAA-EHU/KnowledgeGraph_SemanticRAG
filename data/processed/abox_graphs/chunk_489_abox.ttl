@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_SLOPETYPE a ns1:Parametro ;
    rdfs:label "Tipo de aceleración por defecto (SLOPETYPE)"@es ;
    ns1:identificador "SLOPETYPE" ;
    ns1:monitoreaParametro ns1:ModoOperacion_Automatico,
        ns1:ModoOperacion_Manual ;
    ns1:textoExtracto "Tipo de aceleración por defecto. Valores posibles: Lineal / Trapezoidal / Seno cuadrado (Square sine). Valor por defecto: Seno cuadrado. Variable asociada: (V.)[ch].MPG.SLOPETYPE"@es ;
    ns1:valor "Seno cuadrado"@es .

ns1:Variable_V_MPG_SLOPETYPE a ns1:Parametro ;
    rdfs:label "Variable (V.)[ch].MPG.SLOPETYPE" ;
    ns1:identificador "(V.)[ch].MPG.SLOPETYPE" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.SLOPETYPE"@es ;
    ns1:valor "Seno cuadrado"@es .

ns1:ModoOperacion_Automatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático (movimientos programados)"@es ;
    ns1:textoExtracto "tipo de aceleración que se aplica por defecto en los movimientos automáticos"@es .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo manual (CNC)"@es ;
    ns1:textoExtracto "Cuando se trabaja en modo manual el CNC aplica siempre la aceleración lineal."@es .

