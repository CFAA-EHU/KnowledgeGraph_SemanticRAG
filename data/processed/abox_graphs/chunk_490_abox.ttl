@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_Autom_tico a ns1:ModoOperacion ;
    rdfs:label "Modo automático"@es ;
    ns1:habilitadoPor ns1:Sistema_ControlEjes ;
    ns1:textoExtracto "para el modo automático, utilizar la sentencia #SLOPE."@es .

ns1:Parametro_AceleracionLineal a ns1:Parametro ;
    rdfs:label "Aceleración lineal"@es ;
    ns1:monitoreaParametro ns1:Sistema_ControlEjes ;
    ns1:textoExtracto "La peor respuesta se consigue con la aceleración lineal."@es .

ns1:Parametro_AceleracionSenoCuadrado a ns1:Parametro ;
    rdfs:label "Aceleración seno cuadrado"@es ;
    ns1:monitoreaParametro ns1:Sistema_ControlEjes ;
    ns1:textoExtracto "La aceleración seno cuadrado es una mejora a la aceleración trapezoidal, que suaviza el jerk para que los desplazamientos sean más suaves y sufra menos la mecánica del eje."@es .

ns1:Parametro_AceleracionTrapezoidal a ns1:Parametro ;
    rdfs:label "Aceleración trapezoidal"@es ;
    ns1:monitoreaParametro ns1:Sistema_ControlEjes ;
    ns1:textoExtracto "La aceleración trapezoidal permite programar rampas con objeto de suavizar los cambios de aceleración y deceleración."@es .

ns1:TareaMantenimiento_SeleccionAceleracion a ns1:TareaMantenimiento ;
    rdfs:label "Selección de tipo de aceleración"@es ;
    ns1:ejecutadoPor ns1:Personal_Operador ;
    ns1:requiereMantenimiento ns1:Sistema_ControlEjes ;
    ns1:textoExtracto "Para seleccionar una aceleración distinta desde el programa pieza, para el modo automático, utilizar la sentencia #SLOPE."@es .

ns1:ComponenteMecanico_Eje a ns1:ComponenteMecanico ;
    rdfs:label "Mecánica del eje"@es ;
    ns1:textoExtracto "los desplazamientos sean más suaves y sufra menos la mecánica del eje."@es .

ns1:Sistema_ControlEjes a ns1:Sistema ;
    rdfs:label "Sistema de control de ejes"@es ;
    ns1:textoExtracto "En función del tipo de aceleración seleccionado, en los parámetros máquina de los ejes se mostrarán los necesarios para configurar la aceleración."@es ;
    ns1:tieneComponente ns1:ComponenteMecanico_Eje .

