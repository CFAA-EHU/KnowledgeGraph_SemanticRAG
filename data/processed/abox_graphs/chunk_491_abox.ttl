@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Perfil_LinealTrapezoidal a ns1:ModoOperacion ;
    rdfs:label "Perfil lineal trapezoidal"@es ;
    ns1:documentadoEn ns1:Figura_2.4.8_GraficasMovimiento ;
    ns1:textoExtracto "LINEAR TRAPEZOIDAL"@es .

ns1:Perfil_SenoCuadrado a ns1:ModoOperacion ;
    rdfs:label "Perfil seno cuadrado"@es ;
    ns1:documentadoEn ns1:Figura_2.4.8_GraficasMovimiento ;
    ns1:textoExtracto "los más lentos con la seno cuadrado"@es .

ns1:Parametro_Aceleracion a ns1:Parametro ;
    rdfs:label "Aceleración (a)"@es ;
    ns1:monitoreaParametro ns1:Sistema_ControlMovimiento ;
    ns1:textoExtracto "gráficas de [...] aceleración (a)"@es .

ns1:Parametro_Jerk a ns1:Parametro ;
    rdfs:label "Jerk (j)"@es ;
    ns1:monitoreaParametro ns1:Sistema_ControlMovimiento ;
    ns1:textoExtracto "gráficas de [...] jerk (j)"@es .

ns1:Parametro_Velocidad a ns1:Parametro ;
    rdfs:label "Velocidad (v)"@es ;
    ns1:monitoreaParametro ns1:Sistema_ControlMovimiento ;
    ns1:textoExtracto "gráficas de velocidad (v)"@es .

ns1:Figura_2.4.8_GraficasMovimiento a ns1:Figura ;
    rdfs:label "Gráficas de velocidad, aceleración y jerk por perfil de movimiento"@es ;
    ns1:ilustradoEn ns1:Pagina_124_130 ;
    ns1:textoExtracto "La siguiente figura muestra, para cada uno de los casos, las gráficas de velocidad (v), aceleración (a) y jerk (j)."@es .

ns1:Sistema_ControlMovimiento a ns1:Sistema ;
    rdfs:label "Sistema de control de movimiento por perfiles"@es ;
    ns1:ilustradoEn ns1:Figura_2.4.8_GraficasMovimiento ;
    ns1:textoExtracto "Los desplazamientos más rápidos se consiguen con la aceleración lineal y los más lentos con la seno cuadrado."@es ;
    ns1:tieneComponente ns1:Parametro_Aceleracion,
        ns1:Parametro_Jerk,
        ns1:Parametro_Velocidad .

