@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Aceleracion_Lineal a ns1:Parametro ;
    rdfs:label "Aceleración lineal"@es ;
    ns1:documentadoEn ns1:Tabla_248_CondicionesDefectoCanal ;
    ns1:identificador "SLOPETYPE=Lineal" ;
    ns1:monitoreaParametro ns1:Parametro_LACC1,
        ns1:Parametro_LACC2,
        ns1:Parametro_LFEED ;
    ns1:textoExtracto "Tipo de aceleración: Lineal."@es .

