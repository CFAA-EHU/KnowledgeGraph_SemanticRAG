@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_HSC_CONTERROR a ns1:ModoOperacion ;
    rdfs:label "Modo HSC CONTERROR" ;
    ns1:monitoreaParametro ns1:Parametro_SLOPETYPE ;
    ns1:textoExtracto "Modo HSC CONTERROR cuando SLOPETYPE=Seno cuadrado." .

ns1:Parametro_CHAXISNAME a ns1:Parametro ;
    rdfs:label "CHAXISNAME" ;
    ns1:textoExtracto "Los ejes que forman el plano de trabajo dependen del parámetro máquina CHAXISNAME." .

ns1:Parametro_IPLANE a ns1:Parametro ;
    rdfs:label "IPLANE (Plano principal)" ;
    ns1:identificador "V.[ch].MPG.IPLANE" ;
    ns1:textoExtracto "IPLANE Plano principal (G17/G18) por defecto. Valores posibles: G17 / G18. Valor por defecto: G17. Variable asociada: (V.)[ch].MPG.IPLANE" ;
    ns1:valor "G17" .

ns1:Parametro_SLOPETYPE a ns1:Parametro ;
    rdfs:label "SLOPETYPE" ;
    ns1:textoExtracto "Modo HSC CONTERROR cuando SLOPETYPE=Seno cuadrado." ;
    ns1:valor "Seno cuadrado" .

