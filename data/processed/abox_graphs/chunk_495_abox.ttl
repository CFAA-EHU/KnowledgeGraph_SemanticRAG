ns1:ConfiguracionEjes_Plano a ns1:Parametro ;
    rdfs:label "Configuración de ejes tipo 'plano'"@es ;
    ns1:documentadoEn ns1:Tabla_PlanosTrabajo_234 ;
    ns1:textoExtracto "Modelo T (torno). Configuración de ejes tipo 'plano'"@es .

