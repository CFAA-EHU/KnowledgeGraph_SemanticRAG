ns1:Tabla_PlanosTrabajo_234 a ns1:Tabla ;
    rdfs:label "Tabla de planos de trabajo por modelo (G17, G18, G19, G20)"@es ;
    ns1:documentadoEn ns1:Manual_Seccion2.4.8 ;
    ns1:textoExtracto """
| Plano. | Eje de abscisas. | Eje de ordenadas. | Eje longitudinal. |
| --- | --- | --- | --- |
| G17 | CHAXISNAME 1 | CHAXISNAME 2 | CHAXISNAME 3 |
| G18 | CHAXISNAME 3 | CHAXISNAME 1 | CHAXISNAME 2
"""@es .

