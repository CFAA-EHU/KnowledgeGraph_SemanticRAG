@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IMOVEMENT a ns1:Parametro ;
    rdfs:label "IMOVEMENT" ;
    ns1:identificador "IMOVEMENT" ;
    ns1:textoExtracto "IMOVEMENT Tipo de movimiento (G0/G1) por defecto. Valores posibles: G0 / G1. Valor por defecto: G01." ;
    ns1:tieneComponente ns1:ModeloT ;
    ns1:valor "G01" .

ns1:ISYSTEM a ns1:Parametro ;
    rdfs:label "ISYSTEM" ;
    ns1:identificador "ISYSTEM" ;
    ns1:textoExtracto "ISYSTEM Tipo de coordenadas (G90/G91) por defecto. Valores posibles: G90 / G91. Valor por defecto: G90. Variable asociada: (V.)[ch].MPG.ISYSTEM Este parámetro indica el tipo de coordenadas que asume el CNC por defecto. Las coordenadas de un punto se pueden definir en cotas absolutas (G90) respecto el origen o en cotas incrementales (G91) desde respecto la posición actual. Para cambiar el tipo de coordenadas desde el programa pieza utilizar las funciones G90 ó G91." ;
    ns1:tieneComponente ns1:ModeloT ;
    ns1:valor "G90" .

ns1:ModeloT a ns1:Maquina ;
    rdfs:label "Modelo T (torno)" ;
    ns1:identificador "Modelo T" ;
    ns1:textoExtracto "Modelo T (torno). Configuración de ejes tipo \"plano\". El plano de trabajo siempre es G18; el parámetro máquina IPLANE no se aplica y no se permite cambiar de plano desde el programa pieza, sólo el eje longitudinal (G20)." .

