@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:InterfazUsuario_CNC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz CNC (arranque/reset)" ;
    ns1:monitoreaParametro ns1:Parametro_IMOVE ;
    ns1:textoExtracto "Este parámetro indica el tipo de movimiento, G0 o G1, que asume el CNC por defecto (en el arranque, tras un reset o M30)." .

ns1:Manual_ProgramacionPieza a ns1:Manual ;
    rdfs:label "Manual de programación de pieza" ;
    ns1:documentadoEn ns1:Parametro_IMOVE ;
    ns1:textoExtracto "Para cambiarlo desde el programa pieza utilizar las funciones G0 ó G1." .

ns1:Parametro_IMOVE a ns1:Parametro ;
    rdfs:label "IMOVE (Tipo de movimiento por defecto)" ;
    ns1:identificador "IMOVE" ;
    ns1:textoExtracto "IMOVE Tipo de movimiento (G0/G1) por defecto. Valores posibles: G0 / G1. Valor por defecto: G01. Variable asociada: (V.)[ch].MPG.IMOVE" ;
    ns1:valor "G01"^^xsd:string .

