@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_MDI_MDA a ns1:ModoOperacion ;
    rdfs:label "MDI/MDA" ;
    ns1:textoExtracto "Al acceder al modo MDI/MDA y programar un movimiento sin G, el CNC lo ejecuta en G0/G1" .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Manual" ;
    ns1:textoExtracto "Al programar un movimiento desde el modo manual, el eje se mueve en G0/G1" .

ns1:Tabla_IMMOVE_FuncionesG a ns1:Tabla ;
    rdfs:label "Tabla IMOVE - Funciones G (G0, G1)" ;
    ns1:detalladoEnEsquema ns1:Funcion_G0,
        ns1:Funcion_G1 ;
    ns1:documentadoEn ns1:Sistema_CNC_Arranque ;
    ns1:textoExtracto "| IMOVE | Significado. | --- | --- | G0. | • El CNC asume la función G0... | G1. | • El CNC asume la función G1..." .

ns1:Parametro_G00FEED a ns1:Parametro ;
    rdfs:label "G00FEED" ;
    ns1:textoExtracto "avance rápido definido en el parámetro G00FEED" ;
    ns1:valor "avance_rapido" .

ns1:Parametro_G0MODAL a ns1:Parametro ;
    rdfs:label "G0MODAL" ;
    ns1:identificador "G0MODAL" ;
    ns1:textoExtracto "Parámetro G0MODAL; mantener la función G0 modal o no. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)[ch].MPG.G0MODAL." ;
    ns1:valor "Sí" .

ns1:Sistema_CNC_Arranque a ns1:Sistema ;
    rdfs:label "CNC (Comportamiento en arranque/reset)" ;
    ns1:controla ns1:Parametro_G0MODAL ;
    ns1:textoExtracto "Aunque la función G0 esté definida como no-modal, con IMOVE=G0 el CNC asume la función G0 en el arranque, tras un reset o M30. A partir de la programación de G1, G2 o G3, el CNC recupera G1 como función modal hasta el siguiente reset o M30." ;
    ns1:tieneComponente ns1:Funcion_G0,
        ns1:Funcion_G1 .

ns1:Funcion_G0 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G0" ;
    ns1:identificador "G0" ;
    ns1:monitoreaParametro ns1:Parametro_G00FEED ;
    ns1:textoExtracto "El CNC asume la función G0. Los desplazamientos en G0 se realizan al avance rápido definido en el parámetro G00FEED. El CNC visualiza G0 en la historia de funciones G." .

ns1:Funcion_G1 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "G1" ;
    ns1:identificador "G1" ;
    ns1:textoExtracto "El CNC asume la función G1. Los desplazamientos en G1 se realizan al avance activo en el CNC. El CNC no visualiza G1 en la historia de funciones G." .

