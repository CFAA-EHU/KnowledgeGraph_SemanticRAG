@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_IMOVE a ns1:Parametro ;
    rdfs:label "IMOVE" ;
    ns1:identificador "IMOVE" ;
    ns1:textoExtracto "Parámetro IMOVE; tipo de movimiento (G0/G1) en el arranque, tras un reset o M30. El valor IMOVE=G0 tiene prioridad sobre G0MODAL=No." ;
    ns1:valor "G0/G1" .

ns1:Tabla_2.4.8_CondicionesPorDefecto a ns1:Tabla ;
    rdfs:label "Tabla 2.4.8: Condiciones por defecto (canal)" ;
    ns1:detalladoEnEsquema ns1:ModoOperacion_G00,
        ns1:ModoOperacion_G01 ;
    ns1:documentadoEn ns1:Pagina_124 ;
    ns1:textoExtracto "| G0MODAL | Significado. | --- | --- | Sí. | La función G00 es modal... No. | La función G00 no es modal..." .

ns1:ModoOperacion_G00 a ns1:ModoOperacion ;
    rdfs:label "G00 (Avance rápido)" ;
    ns1:controla ns1:Parametro_G0MODAL ;
    ns1:textoExtracto "La función G00 es modal. Una vez programada permanece activa hasta que se programe G01, G02, G03, G33 o G63." .

ns1:ModoOperacion_G01 a ns1:ModoOperacion ;
    rdfs:label "G01 (Interpolación lineal)" ;
    ns1:textoExtracto "G1 se mantiene modal. En el ámbito de influencia de un ciclo fijo se mantendrá activa la última G programada; G0 mantiene la condición de modal." .

ns1:Parametro_G0MODAL a ns1:Parametro ;
    rdfs:label "G0MODAL" ;
    ns1:textoExtracto "La función G00 es modal. Una vez programada permanece activa hasta que se programe G01, G02, G03, G33 o G63." ;
    ns1:valor "Sí/No" .

