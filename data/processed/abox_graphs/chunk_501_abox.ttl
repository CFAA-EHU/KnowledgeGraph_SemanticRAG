@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_240_ParametrosCNC a ns1:Tabla ;
    rdfs:label "Tabla 2.4.8: Condiciones por defecto (canal)" ;
    ns1:textoExtracto "| G2G3MODAL | Significado. | --- | --- | Sí. | Las funciones G02 y G03 son modales; una vez programadas permanecen activas hasta que se programe G00, G01, G33 o G63. | No. | Las funciones G02 y G03 no son modales; hay que programarlas en cada bloque de interpolación circular." ;
    ns1:tieneComponente ns1:Parametro_G2G3MODAL,
        ns1:Parametro_IFEED,
        ns1:Variable_V_MPG_IFEED .

ns1:Parametro_G2G3MODAL a ns1:Parametro ;
    rdfs:label "G2G3MODAL" ;
    ns1:identificador "G2G3MODAL" ;
    ns1:textoExtracto "Las funciones G02 y G03 son modales; una vez programadas permanecen activas hasta que se programe G00, G01, G33 o G63." ;
    ns1:valor "Sí/No" .

ns1:Parametro_IFEED a ns1:Parametro ;
    rdfs:label "IFEED" ;
    ns1:identificador "IFEED" ;
    ns1:textoExtracto "Tipo de avance (G94/G95) por defecto. Valores posibles: G94 / G95. Valor por defecto: G94." ;
    ns1:valor "G94" .

ns1:Variable_V_MPG_IFEED a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPG.IFEED" ;
    ns1:identificador "(V.)[ch].MPG.IFEED" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.IFEED" .

