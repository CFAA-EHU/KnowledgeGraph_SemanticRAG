@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_MDI a ns1:ModoOperacion ;
    rdfs:label "Modo de operación MDI/MDA"@es ;
    ns1:textoExtracto "no afecta al movimiento [...] en modo MDI/MDA."@es .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo de operación manual (jog)"@es ;
    ns1:habilitadoPor ns1:Parametro_FPRMAN ;
    ns1:textoExtracto "modo manual; no afecta al movimiento con volantes o en modo MDI/MDA."@es .

ns1:Sistema_ControlAvance a ns1:Sistema ;
    rdfs:label "Sistema de control de avance por programa pieza"@es ;
    ns1:controla ns1:Parametro_G94,
        ns1:Parametro_G95 ;
    ns1:textoExtracto "Para cambiar el tipo de avance desde el programa pieza utilizar las funciones G94 ó G95."@es .

ns1:Variable_MPG_FPRMAN a ns1:Parametro ;
    rdfs:label "Variable de sistema (V.)[ch].MPG.FPRMAN"@es ;
    ns1:identificador "(V.)[ch].MPG.FPRMAN" ;
    ns1:monitoreaParametro ns1:Parametro_FPRMAN ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.FPRMAN"@es .

ns1:Parametro_G94 a ns1:Parametro ;
    rdfs:label "Configuración de avance G94 (mm/min)"@es ;
    ns1:identificador "G94" ;
    ns1:textoExtracto "La configuración típica para el modelo fresadora será G94."@es ;
    ns1:valor "mm/min" .

ns1:Parametro_FPRMAN a ns1:Parametro ;
    rdfs:label "Permiso de G95 en modo manual (FPRMAN)"@es ;
    ns1:identificador "FPRMAN" ;
    ns1:monitoreaParametro ns1:Parametro_G95 ;
    ns1:textoExtracto "FPRMAN Función G95 permitida en modo manual. Valores posibles: Sí / No. Valor por defecto: Sí."@es ;
    ns1:valor "Sí" .

ns1:Parametro_G95 a ns1:Parametro ;
    rdfs:label "Configuración de avance G95 (mm/rev, grados/rev o inch/rev)"@es ;
    ns1:identificador "G95" ;
    ns1:textoExtracto "Con G95 el avance se asume en mm/rev, grados/rev o inch/rev. La configuración típica para el modelo torno será G95."@es ;
    ns1:valor "mm/rev, grados/rev, inch/rev" .

