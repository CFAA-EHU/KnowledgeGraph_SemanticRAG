@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_G136 a ns1:Parametro ;
    rdfs:label "Compensación de radio con trayectorias circulares (G136)"@es ;
    ns1:textoExtracto "Con la compensación de radio activa, las trayectorias compensadas se pueden enlazar entre sí mediante trayectorias circulares (G136)."@es ;
    ns1:valor "G136" .

ns1:Parametro_G137 a ns1:Parametro ;
    rdfs:label "Compensación de radio con trayectorias lineales (G137)"@es ;
    ns1:textoExtracto "Con la compensación de radio activa, las trayectorias compensadas se pueden enlazar entre sí mediante [...] trayectorias lineales (G137)."@es ;
    ns1:valor "G137" .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:controla ns1:ModoOperacion_Automatico,
        ns1:ModoOperacion_MDI,
        ns1:ModoOperacion_Manual ;
    ns1:textoExtracto "El CNC aplica la función G95 a los ejes principales del canal; [...] Este parámetro indica el modo de compensación que asume el CNC en el momento de encendido."@es ;
    ns1:tieneComponente ns1:Parametro_G94,
        ns1:Parametro_G95,
        ns1:Parametro_IRCOMP,
        ns1:Parametro_VG_FMAN,
        ns1:Parametro_VG_PRGFPR,
        ns1:Variable_V_SReal .

ns1:ModoOperacion_Automatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático"@es ;
    ns1:textoExtracto "Al pasar del modo automático al modo manual con G95 activa [...] para modo automático."@es .

ns1:ModoOperacion_MDI a ns1:ModoOperacion ;
    rdfs:label "Modo MDI"@es ;
    ns1:textoExtracto "Lo mismo ocurre si se activa G95 desde en MDI sobre el modo manual. [...] El eje se moverá a 10mm/rev*SReal[rpm] en MDI."@es .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo manual (jog)"@es ;
    ns1:textoExtracto "movimientos en jog desde el modo manual. [...] Al pasar del modo automático al modo manual con G95 activa, la historia sigue mostrando G95 pero los movimientos en jog serán en G94."@es .

ns1:Parametro_G94 a ns1:Parametro ;
    rdfs:label "Función G94 (avance por minuto)"@es ;
    ns1:textoExtracto "los movimientos en jog serán en G94 (avance por minuto)."@es ;
    ns1:valor "G94" .

ns1:Parametro_G95 a ns1:Parametro ;
    rdfs:label "Función G95 (avance por vuelta)"@es ;
    ns1:textoExtracto "Se permite la función G95 (avance por vuelta) para los movimientos en jog desde el modo manual. [...] No se permite la función G95 (avance por vuelta) para los movimientos en jog desde el modo manual."@es ;
    ns1:valor "G95" .

ns1:Parametro_IRCOMP a ns1:Parametro ;
    rdfs:label "Modo de compensación de radio (G136/G137)"@es ;
    ns1:identificador "IRCOMP" ;
    ns1:textoExtracto "IRCOMP Modo de compensación de radio (G136/G137) por defecto. Valores posibles: G136 / G137. [...] Este parámetro indica el modo de compensación que asume el CNC en el momento de encendido."@es ;
    ns1:valor "G136",
        "G137" .

ns1:Parametro_VG_FMAN a ns1:Parametro ;
    rdfs:label "Avance manual (G.FMAN)"@es ;
    ns1:identificador "G.FMAN" ;
    ns1:textoExtracto "La F programado en modo manual, con G95 en la historia, será (V.)G.FMAN (avance por minuto) para movimientos en jog."@es .

ns1:Parametro_VG_PRGFPR a ns1:Parametro ;
    rdfs:label "Avance programado (G.PRGFPR)"@es ;
    ns1:identificador "G.PRGFPR" ;
    ns1:textoExtracto "La F programado en modo manual, con G95 en la historia, será [...] (V.)G.PRGFPR (avance por vuelta) para modo automático."@es .

ns1:Variable_V_SReal a ns1:Parametro ;
    rdfs:label "Velocidad real del eje (SReal)"@es ;
    ns1:identificador "SReal" ;
    ns1:textoExtracto "El eje se moverá a 10mm/rev*SReal[rpm] en MDI o al mover un eje a una cota [X][START]."@es .

