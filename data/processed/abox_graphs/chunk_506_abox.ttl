@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_PlanoCancelacion a ns1:Parametro ;
    rdfs:label "Parámetro PLANECANCEL"@es ;
    ns1:identificador "V.[ch].MPG.PLANECANCEL" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.PLANECANCEL. Este parámetro define cuál es el plano activo tras ejecutar M02, M30 o reset."@es ;
    ns1:valor "Sí" .

ns1:ValorDefecto_PlanoCancelacion_Si a ns1:Parametro ;
    rdfs:label "Valor por defecto: Sí (PLANECANCEL)"@es ;
    ns1:textoExtracto "Valor por defecto: Sí."@es ;
    ns1:valor "Sí" .

