@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_PLANECANCEL a ns1:Parametro ;
    rdfs:label "PLANECANCEL" ;
    ns1:controla ns1:Parametro_IPLANE ;
    ns1:identificador "PLANECANCEL" ;
    ns1:textoExtracto "En el momento del encendido, después de ejecutar M02 ó M30, y después de un reset, el CNC asume el plano definido en el parámetro IPLANE." .

ns1:Tabla_ComportamientoPLANECANCEL a ns1:Tabla ;
    rdfs:label "Condiciones por defecto (canal) - PLANECANCEL" ;
    ns1:documentadoEn ns1:Pagina_124_130 ;
    ns1:textoExtracto "PLANECANCEL. | Significado. | --- | --- | Sí | En el momento del encendido, después de ejecutar M02 ó M30, y después de un reset, el CNC asume el plano definido en el parámetro IPLANE. | No | En el momento del encendido..." .

ns1:Parametro_IPLANE a ns1:Parametro ;
    rdfs:label "IPLANE" ;
    ns1:textoExtracto "plano definido en el parámetro IPLANE" ;
    ns1:valor "G17/G18/G19"@es .

