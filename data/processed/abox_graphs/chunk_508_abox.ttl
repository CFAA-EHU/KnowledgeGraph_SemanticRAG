@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_ICORNER a ns1:Parametro ;
    rdfs:label "ICORNER (Tipo de arista por defecto)"@es ;
    ns1:identificador "ICORNER" ;
    ns1:monitoreaParametro ns1:ModoOperacion_AristaMatada,
        ns1:ModoOperacion_AristaSemimatada,
        ns1:ModoOperacion_AristaViva ;
    ns1:textoExtracto "ICORNER Tipo de arista (G5/G7/G50) por defecto. Valores posibles: G50 / G5 / G7. Valor por defecto: G50. Variable asociada: (V.)[ch].MPG.ICORNER"@es ;
    ns1:valor "G50" .

ns1:Parametro_INPOSW a ns1:Parametro ;
    rdfs:label "INPOSW (Banda de muerte en arista viva)"@es ;
    ns1:identificador "INPOSW" ;
    ns1:textoExtracto "Cuando se trabaja en arista viva, el CNC comienza la ejecución del siguiente desplazamiento cuando el eje entra en la banda de muerte, definida en el parámetro INPOSW."@es .

ns1:Parametro_MAXROUND a ns1:Parametro ;
    rdfs:label "MAXROUND (Máximo error de redondeo en G5)"@es ;
    ns1:identificador "MAXROUND" ;
    ns1:textoExtracto "MAXROUND Máximo error de redondeo en G5."@es .

ns1:Parametro_ROUNDFEED a ns1:Parametro ;
    rdfs:label "ROUNDFEED (Avance en redondeo por porcentaje)"@es ;
    ns1:identificador "ROUNDFEED" ;
    ns1:textoExtracto "El avance (#ROUNDPAR [2]) define el porcentaje del avance activo que se va a emplear en el mecanizado."@es .

ns1:Sentencia_ROUNDPAR a ns1:Parametro ;
    rdfs:label "#ROUNDPAR (Sentencia para cambiar tipo de redondeo)"@es ;
    ns1:habilitadoPor ns1:Parametro_ROUNDTYPE ;
    ns1:identificador "#ROUNDPAR" ;
    ns1:textoExtracto "Para cambiar el tipo de redondeo desde el programa utilizar la sentencia #ROUNDPAR."@es .

ns1:ModoOperacion_AristaMatada a ns1:ModoOperacion ;
    rdfs:label "Modo de arista matada (G5)"@es ;
    ns1:identificador "G5" ;
    ns1:textoExtracto "arista matada (G5)"@es .

ns1:ModoOperacion_AristaSemimatada a ns1:ModoOperacion ;
    rdfs:label "Modo de arista semimatada (G50)"@es ;
    ns1:identificador "G50" ;
    ns1:textoExtracto "arista semimatada (G50)"@es .

ns1:ModoOperacion_AristaViva a ns1:ModoOperacion ;
    rdfs:label "Modo de arista viva (G7)"@es ;
    ns1:identificador "G7" ;
    ns1:textoExtracto "arista viva (G7)"@es .

ns1:ModoOperacion_RedondeoErrorCordal a ns1:ModoOperacion ;
    rdfs:label "Redondeo por error cordal"@es ;
    ns1:textoExtracto "Error cordal (#ROUNDPAR [1]) define la desviación máxima permitida entre el punto programado y el perfil resultante."@es .

ns1:ModoOperacion_RedondeoPorcentajeAvance a ns1:ModoOperacion ;
    rdfs:label "Redondeo por porcentaje de avance"@es ;
    ns1:textoExtracto "El avance (#ROUNDPAR [2]) define el porcentaje del avance activo que se va a emplear en el mecanizado."@es .

ns1:Parametro_ROUNDTYPE a ns1:Parametro ;
    rdfs:label "ROUNDTYPE (Tipo de redondeo en G5)"@es ;
    ns1:identificador "ROUNDTYPE" ;
    ns1:monitoreaParametro ns1:ModoOperacion_RedondeoErrorCordal,
        ns1:ModoOperacion_RedondeoPorcentajeAvance ;
    ns1:textoExtracto "ROUNDTYPE Tipo de redondeo en G5 por defecto. Valores posibles: Error cordal / %Avance. Valor por defecto: Error cordal. Variable asociada: (V.)[ch].MPG.ROUNDTYPE"@es ;
    ns1:valor "Error cordal" .

