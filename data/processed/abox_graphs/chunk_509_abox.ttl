@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_Avance a ns1:Parametro ;
    rdfs:label "Avance (#ROUNDPAR [2])" ;
    ns1:identificador "ROUNDPAR[2]" ;
    ns1:textoExtracto "El avance (#ROUNDPAR [2]) define el porcentaje del avance activo que se va a emplear en el mecanizado." .

ns1:Variable_V_MPG_MAXROUND a ns1:Parametro ;
    rdfs:label "Variable (V.)[ch].MPG.MAXROUND" ;
    ns1:identificador "(V.)[ch].MPG.MAXROUND" ;
    ns1:monitoreaParametro ns1:Parametro_MAXROUND ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.MAXROUND" .

ns1:Parametro_MAXROUND a ns1:Parametro ;
    rdfs:label "MAXROUND" ;
    ns1:identificador "MAXROUND" ;
    ns1:textoExtracto "MAXROUND Máximo error de redondeo en G5. Valores posibles: De 0.02 a 99999.9999 mm o grados / de 0.00079 a 3937.00787 inch. Valor por defecto: 0.1000 mm o grados / 0.00394 inch." ;
    ns1:valor "0.1000" .

