@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_CONTERROR a ns1:ModoOperacion ;
    rdfs:label "Modo CONTERROR"@es ;
    ns1:textoExtracto "modo CONTERROR"@es .

ns1:ModoOperacion_FAST a ns1:ModoOperacion ;
    rdfs:label "Modo FAST"@es ;
    ns1:textoExtracto "modo FAST"@es .

ns1:ModoOperacion_HSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC"@es ;
    ns1:textoExtracto "modo HSC cuando no se programa CONTERROR (modo CONTERROR) ni E (modo FAST)."@es .

ns1:Parametro_MPG_MAXROUND a ns1:Parametro ;
    rdfs:label "Parámetro MPG.MAXROUND"@es ;
    ns1:identificador "MPG.MAXROUND" ;
    ns1:monitoreaParametro ns1:Parametro_ROUNDTYPE_ErrorCordal ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.MAXROUND. Este parámetro define la desviación máxima permitida entre el punto programado y el perfil resultante del matado de arista. El CNC lo tiene en cuenta con ROUNDTYPE = Error cordal. Este parámetro también define el error de contorno máximo permitido para el modo HSC cuando no se programa CONTERROR (modo CONTERROR) ni E (modo FAST)."@es ;
    ns1:valor "0.00394 inch"@es .

ns1:Parametro_MPG_ROUNDFEED a ns1:Parametro ;
    rdfs:label "Parámetro MPG.ROUNDFEED"@es ;
    ns1:identificador "MPG.ROUNDFEED" ;
    ns1:monitoreaParametro ns1:Parametro_ROUNDTYPE_PorcentajeAvance ;
    ns1:textoExtracto "ROUNDFEED. Porcentaje de avance en G5. Valores posibles: De 0 a 100. Valor por defecto: 100. Variable asociada: (V.)[ch].MPG.ROUNDFEED. Este parámetro define el porcentaje del avance activo que se va a emplear en el mecanizado. El CNC lo tiene en cuenta con ROUNDTYPE = %Avance."@es ;
    ns1:valor "100" .

ns1:Parametro_ROUNDTYPE_ErrorCordal a ns1:Parametro ;
    rdfs:label "ROUNDTYPE = Error cordal"@es ;
    ns1:identificador "ROUNDTYPE_ErrorCordal" ;
    ns1:textoExtracto "El CNC lo tiene en cuenta con ROUNDTYPE = Error cordal."@es .

ns1:Parametro_ROUNDTYPE_PorcentajeAvance a ns1:Parametro ;
    rdfs:label "ROUNDTYPE = %Avance"@es ;
    ns1:identificador "ROUNDTYPE_PorcentajeAvance" ;
    ns1:textoExtracto "El CNC lo tiene en cuenta con ROUNDTYPE = %Avance."@es .

