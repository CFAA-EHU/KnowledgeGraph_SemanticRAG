@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_CIRINERR a ns1:Parametro ;
    rdfs:label "CIRINERR" ;
    ns1:identificador "CIRINERR" ;
    ns1:monitoreaParametro ns1:Variable_CIRINERR ;
    ns1:textoExtracto "CIRINERR Error absoluto máximo permitido en el radio. Valores posibles: De 0 a 99999.9999 mm o grados / de 0 a 3937.00787 inch. Valor por defecto: 0.0100 mm o grados / 0.00039 inch." ;
    ns1:valor "0.0100 mm / 0.00039 inch"^^xsd:string .

ns1:Parametro_CIRINFACT a ns1:Parametro ;
    rdfs:label "CIRINFACT" ;
    ns1:identificador "CIRINFACT" ;
    ns1:monitoreaParametro ns1:Variable_CIRINFACT ;
    ns1:textoExtracto "CIRINFACT Error relativo máximo permitido en el radio. Valores posibles: De 0 a 100.0 %. Valor por defecto: 0.1 %." ;
    ns1:valor "0.1 %"^^xsd:string .

ns1:Variable_CIRINERR a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPG.CIRINERR" ;
    ns1:identificador "(V.)[ch].MPG.CIRINERR" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.CIRINERR" .

ns1:Variable_CIRINFACT a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPG.CIRINFACT" ;
    ns1:identificador "(V.)[ch].MPG.CIRINFACT" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.CIRINFACT" .

