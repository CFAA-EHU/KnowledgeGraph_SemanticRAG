@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_G264 a ns1:ModoOperacion ;
    rdfs:label "Función G264" ;
    ns1:controla ns1:InterfazUsuario_CNC_CorreccionArco ;
    ns1:textoExtracto "Esta funcionalidad se controla desde el programa mediante las funciones G264 y G265." .

ns1:ModoOperacion_G265 a ns1:ModoOperacion ;
    rdfs:label "Función G265" ;
    ns1:controla ns1:InterfazUsuario_CNC_CorreccionArco ;
    ns1:textoExtracto "Esta funcionalidad se controla desde el programa mediante las funciones G264 y G265." .

ns1:Parametro_CIRINERR a ns1:Parametro ;
    rdfs:label "CIRINERR" ;
    ns1:textoExtracto "El parámetro CIRINERR indica el error absoluto máximo permitido." ;
    ns1:valor "error_absoluto_máximo" .

ns1:Parametro_CIRINFACT a ns1:Parametro ;
    rdfs:label "CIRINFACT" ;
    ns1:textoExtracto "El parámetro CIRINFACT indica el error relativo máximo permitido (% del radio)." ;
    ns1:valor "error_relativo_máximo" .

ns1:InterfazUsuario_CNC_CorreccionArco a ns1:InterfazUsuario ;
    rdfs:label "Interfaz CNC para corrección del centro del arco" ;
    ns1:monitoreaParametro ns1:Parametro_CIRINERR,
        ns1:Parametro_CIRINFACT ;
    ns1:textoExtracto "El CNC mostrará el error correspondiente cuando la diferencia entre ambos radios sea mayor que CIRINERR y mayor que —CIRINFACT x Radio—." .

