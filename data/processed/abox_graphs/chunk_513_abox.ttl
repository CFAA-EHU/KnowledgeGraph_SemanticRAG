@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_FEEDND a ns1:Parametro ;
    rdfs:label "FEEDND Avance programado en todos los ejes"@es ;
    ns1:textoExtracto "FEEDND Aplicar el avance programado a todos los ejes del canal. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPG.FEEDND Este parámetro indica si el avance programado se aplica a todos los ejes del canal o sólo a los ejes principales."@es ;
    ns1:valor "No" .

ns1:Parametro_MAXOVR a ns1:Parametro ;
    rdfs:label "MAXOVR Override (%) máximo permitido"@es ;
    ns1:monitoreaParametro ns1:InterfazUsuario_OverrideAvance ;
    ns1:textoExtracto "MAXOVR Override (%) máximo permitido. Valores posibles: De 0 a 255. Valor por defecto: 200. Variable asociada: (V.)[ch].MPG.MAXOVR Este parámetro indica el máximo porcentaje que se permite aplicar al avance programado de los ejes (feedrate override)."@es ;
    ns1:valor "200" .

ns1:Parametro_RAPIDOVR a ns1:Parametro ;
    rdfs:label "RAPIDOVR Override en G00"@es ;
    ns1:monitoreaParametro ns1:InterfazUsuario_OverrideAvance ;
    ns1:textoExtracto "RAPIDOVR Override actúa en G00 (entre 0 y 100%). Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)[ch].MPG.RAPIDOVR Este parámetro indica si se permite modificar el porcentaje de avance (entre el 0% y el 100%) cuando se trabaja en G0."@es ;
    ns1:valor "Sí" .

ns1:InterfazUsuario_OverrideAvance a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de control de feedrate override"@es ;
    ns1:textoExtracto "El porcentaje que se aplica al avance programado puede ser fijado por programa, por PLC o por el conmutador del panel, siendo el más prioritario el fijado por programa y el menos prioritario el seleccionado por el conmutador."@es .

