@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_AvanceCompuesto a ns1:ModoOperacion ;
    rdfs:label "Modo de avance compuesto (FEEDND=Sí)"@es ;
    ns1:controla ns1:Parametro_FEEDND ;
    ns1:textoExtracto "El avance programado será la resultante de componer los movimientos sobre todos los ejes del canal."@es .

ns1:ModoOperacion_AvanceLimitadoEjesPrincipales a ns1:ModoOperacion ;
    rdfs:label "Modo de avance limitado a ejes principales (FEEDND=No)"@es ;
    ns1:controla ns1:Parametro_FEEDND ;
    ns1:textoExtracto "Si alguno de los ejes principales tiene desplazamiento programado, el avance programado será la resultante de componer el movimiento sólo sobre estos ejes. El resto de los ejes se desplazan al avance que les corresponda para terminar el movimiento todos a la vez."@es .

ns1:Parametro_MAXFEED a ns1:Parametro ;
    rdfs:label "Límite de avance máximo (MAXFEED)"@es ;
    ns1:identificador "MAXFEED" ;
    ns1:textoExtracto "Sólo se limita el avance programado si algún eje pudiera sobrepasar su MAXFEED."@es .

ns1:Tabla_ComportamientoAvance a ns1:Tabla ;
    rdfs:label "Tabla de comportamiento del avance según FEEDND"@es ;
    ns1:detalladoEnEsquema ns1:Parametro_FEEDND ;
    ns1:textoExtracto "| FEEDND | Significado. | --- | --- | Sí. | El avance programado será la resultante de componer los movimientos sobre todos los ejes del canal. | No. | Si alguno de los ejes principales tiene desplazamiento programado, el avance programado será la resultante de componer el movimiento sólo sobre estos ejes. El resto de los ejes se desplazan al avance que les corresponda para terminar el movimiento todos a la vez. [...]"@es .

ns1:Parametro_FEEDND a ns1:Parametro ;
    rdfs:label "FEEDND" ;
    ns1:identificador "FEEDND" ;
    ns1:textoExtracto "FEEDND | Significado."@es ;
    ns1:valor "Sí/No" .

