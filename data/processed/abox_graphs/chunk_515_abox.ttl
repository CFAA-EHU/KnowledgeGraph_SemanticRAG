@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_MAXDYNOVR a ns1:Parametro ;
    rdfs:label "MAXDYNOVR" ;
    ns1:identificador "MAXDYNOVR" ;
    ns1:monitoreaParametro ns1:InterfazUsuario_BarraDeslizanteModoAutomatico ;
    ns1:textoExtracto "MAXDYNOVR Máximo override dinámico para todos los ejes del canal. Valores posibles: De 100 a 500 %. Valor por defecto: 200 %." ;
    ns1:valor "200" .

ns1:Parametro_MINDYNOVR a ns1:Parametro ;
    rdfs:label "MINDYNOVR" ;
    ns1:identificador "MINDYNOVR" ;
    ns1:monitoreaParametro ns1:InterfazUsuario_BarraDeslizanteModoAutomatico ;
    ns1:textoExtracto "MINDYNOVR Mínimo override dinámico para todos los ejes del canal. Valores posibles: De 10 a 100 %. Valor por defecto: 30 %." ;
    ns1:valor "30" .

ns1:ModoOperacion_Automatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático" ;
    ns1:textoExtracto "La pantalla del modo automático ofrece una barra deslizante que permite variar la dinámica definida por programa para un mecanizado." .

ns1:InterfazUsuario_BarraDeslizanteModoAutomatico a ns1:InterfazUsuario ;
    rdfs:label "Barra deslizante de override dinámico (modo automático)" ;
    ns1:ilustradoEn ns1:ModoOperacion_Automatico ;
    ns1:textoExtracto "La pantalla del modo automático ofrece una barra deslizante que permite variar la dinámica definida por programa para un mecanizado." .

