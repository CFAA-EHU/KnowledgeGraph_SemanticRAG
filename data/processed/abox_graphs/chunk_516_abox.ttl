@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DMCPEAKSIZE a ns1:Parametro ;
    rdfs:label "DMCPEAKSIZE" ;
    ns1:identificador "DMCPEAKSIZE" ;
    ns1:monitoreaParametro ns1:PotenciaDMC ;
    ns1:textoExtracto "DMCPEAKSIZE Exceso porcentual de potencia para monitorizar los picos de potencia en el DMC. Valores posibles: De 0 a 100 %. Valor por defecto: 20 %. Variable asociada: (V.)[ch].MPG.DMCPEAKSIZE" ;
    ns1:valor "20" .

ns1:MAXDMCOVR a ns1:Parametro ;
    rdfs:label "MAXDMCOVR" ;
    ns1:identificador "MAXDMCOVR" ;
    ns1:monitoreaParametro ns1:AvanceDMC ;
    ns1:textoExtracto "MAXDMCOVR Máximo override DMC de todos los ejes del canal. Valores posibles: De 100 a 255 %. Valor por defecto: 120 %. Variable asociada: (V.)[ch].MPG.MAXDMCOVR" ;
    ns1:valor "120" .

ns1:MINDMCOVR a ns1:Parametro ;
    rdfs:label "MINDMCOVR" ;
    ns1:identificador "MINDMCOVR" ;
    ns1:monitoreaParametro ns1:AvanceDMC ;
    ns1:textoExtracto "MINDMCOVR Mínimo override DMC de todos los ejes del canal. Valores posibles: De 10 a 100 %. Valor por defecto: 80 %. Variable asociada: (V.)[ch].MPG.MINDMCOVR" ;
    ns1:valor "80" .

ns1:PanelMando a ns1:InterfazUsuario ;
    rdfs:label "Panel de mando" ;
    ns1:controla ns1:AvanceDMC ;
    ns1:textoExtracto "El porcentaje de avance que aplica el DMC se suma al seleccionado desde el conmutador del panel de mando." .

ns1:PotenciaDMC a ns1:Parametro ;
    rdfs:label "Potencia nominal DMC" ;
    ns1:monitoreaParametro ns1:MaquinaBrochadora ;
    ns1:textoExtracto "Exceso porcentual de potencia, sobre la potencia nominal, para monitorizar los picos de potencia en el DMC." .

ns1:MaquinaBrochadora a ns1:Maquina ;
    rdfs:label "Máquina con control DMC" ;
    ns1:textoExtracto "El CNC siempre respeta el límite máximo definido en el parámetro máquina MAXOVR. Si el usuario selecciona desde el conmutador del panel de mando, un override por debajo de MINDMCOVR, el CNC inhibe el DMC (no lo desactiva); cuando el override vuelva a superar MINDMCOVR, el DMC volverá a funcionar con normalidad." ;
    ns1:tieneComponente ns1:PanelMando .

ns1:AvanceDMC a ns1:Parametro ;
    rdfs:label "Override de avance DMC" ;
    ns1:controla ns1:MaquinaBrochadora ;
    ns1:textoExtracto "El porcentaje de avance (feed override) mínimo y máximo que puede aplicar el DMC (control dinámico del mecanizado) en el canal. Ambos porcentajes se pueden modificar desde la sentencia #DMCON." .

