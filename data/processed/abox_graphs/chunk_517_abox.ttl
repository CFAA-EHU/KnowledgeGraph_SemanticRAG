@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal"@es ;
    ns1:textoExtracto "detiene los ejes manteniendo el giro de cabezal"@es .

ns1:Parametro_DMCPEAKSIZE a ns1:Parametro ;
    rdfs:label "Exceso porcentual de potencia DMC"@es ;
    ns1:identificador "V.[ch].MPG.DMCPEAKSIZE" ;
    ns1:monitoreaParametro ns1:Sistema_DMC ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.DMCPEAKSIZE. Exceso porcentual de potencia, sobre la potencia nominal, para monitorizar los picos de potencia en el DMC."@es ;
    ns1:valor 20 .

ns1:Alarma_DMCPWRPEAK a ns1:Alarma ;
    rdfs:label "Marca DMCPWRPEAK"@es ;
    ns1:identificador "DMCPWRPEAK" ;
    ns1:textoExtracto "activa la marca DMCPWRPEAK. Este parámetro permite detectar un pico de potencia, que puede ser"@es .

ns1:Sistema_DMC a ns1:Sistema ;
    rdfs:label "Sistema DMC"@es ;
    ns1:controla ns1:Alarma_DMCPWRPEAK ;
    ns1:textoExtracto "monitorizar los picos de potencia en el DMC"@es .

