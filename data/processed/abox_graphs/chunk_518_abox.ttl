@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_WarningConsumoExcesivo a ns1:AvisoSeguridad ;
    rdfs:label "Warning de consumo excesivo en DMC" ;
    ns1:mitigaRiesgo ns1:Parametro_DMCPWRHOLD ;
    ns1:textoExtracto "el CNC muestra un warning y activa la marca DMCPWRHOLD" .

ns1:AvisoSeguridad_WarningPotencia a ns1:AvisoSeguridad ;
    rdfs:label "Warning de potencia en DMC" ;
    ns1:mitigaRiesgo ns1:Parametro_DMCPWRPEAK ;
    ns1:textoExtracto "el CNC muestra un warning, detiene los ejes manteniendo el giro de cabezal y activa la marca DMCPWRPEAK" .

ns1:Herramienta_DMC a ns1:Herramienta ;
    rdfs:label "Herramienta de corte (DMC)" ;
    ns1:textoExtracto "puede ser debido a la rotura de la herramienta, profundización de pasada demasiado grande, etc." .

ns1:Sistema_DMC a ns1:Sistema ;
    rdfs:label "Sistema DMC" ;
    ns1:monitoreaParametro ns1:Parametro_DMCPWRFACTOR,
        ns1:Parametro_DMCPWRHOLD,
        ns1:Parametro_DMCPWRPEAK ;
    ns1:textoExtracto "Configuración del DMC" ;
    ns1:tieneComponente ns1:Parametro_DMCPWRFACTOR,
        ns1:Parametro_DMCPWRHOLD,
        ns1:Parametro_DMCPWRPEAK .

ns1:Parametro_DMCPWRFACTOR a ns1:Parametro ;
    rdfs:label "Factor multiplicador DMCPWRFACTOR" ;
    ns1:identificador "DMCPWRFACTOR" ;
    ns1:textoExtracto "DMCPWRFACTOR Factor multiplicador de la potencia objetivo, para monitorizar el exceso de potencia consumida en el DMC. Valores posibles: De 0.0 a 100.0. Valor por defecto: 2.0." ;
    ns1:valor "2.0" .

ns1:Parametro_DMCPWRHOLD a ns1:Parametro ;
    rdfs:label "Marca DMCPWRHOLD" ;
    ns1:identificador "DMCPWRHOLD" ;
    ns1:textoExtracto "activa la marca DMCPWRHOLD. Este parámetro permite detectar un consumo excesivo de potencia que puede ser debido a un desgaste de herramienta." .

ns1:Parametro_DMCPWRPEAK a ns1:Parametro ;
    rdfs:label "Marca DMCPWRPEAK" ;
    ns1:identificador "DMCPWRPEAK" ;
    ns1:textoExtracto "activa la marca DMCPWRPEAK. Este parámetro permite detectar un pico de potencia, que puede ser debido a la rotura de la herramienta, profundización de pasada demasiado grande, etc." .

