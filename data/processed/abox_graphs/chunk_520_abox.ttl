@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FuncionCambioHerramienta a ns1:Tabla,
        ns1:TareaMantenimiento ;
    rdfs:label "Función de cambio de herramienta (G-code asociado)"@es ;
    ns1:ejecutadoPor ns1:SubrutinasFabricante ;
    ns1:textoExtracto "subrutinas asociadas a algunas funciones del CNC como el cambio de herramienta, G74, G180 a G189, G380 a G399"@es .

ns1:ModoSETUP_CNC a ns1:ModoOperacion ;
    rdfs:label "Modo SETUP (puesta a punto, CNC)"@es ;
    ns1:habilitadoPor ns1:SubrutinasFabricante ;
    ns1:textoExtracto "Con el CNC en modo SETUP (puesta a punto), las rutinas OEM cuya extensión sea .fst se cargarán en la memoria RAM la primera vez que se ejecutan dentro del programa."@es .

ns1:ModoUSER_CNC a ns1:ModoOperacion ;
    rdfs:label "Modo USER (CNC)"@es ;
    ns1:habilitadoPor ns1:SubrutinasFabricante ;
    ns1:textoExtracto "Con el CNC en modo USER, las rutinas OEM cuya extensión sea .fst, se cargan en la memoria RAM en el arranque de la aplicación CNC."@es .

ns1:FrecuenciaEjecucionOptimizada a ns1:Frecuencia ;
    rdfs:label "Frecuencia de ejecución optimizada (memoria RAM)"@es ;
    ns1:textoExtracto "Si durante la ejecución se utilizan repetidamente las mismas subrutinas, es más eficiente cargar estas subrutinas en la memoria RAM del CNC, ya que así el acceso a las mismas es más rápido, y por lo tanto se optimiza el tiempo de ejecución."@es ;
    ns1:valor "optimizada"@es .

ns1:TablaSubrutinasFabricante a ns1:Tabla ;
    rdfs:label "Tabla de subrutinas del fabricante"@es ;
    ns1:documentadoEn ns1:ManualCNC ;
    ns1:textoExtracto "SUBTABLE Tabla de subrutinas del fabricante. Las subrutinas de fabricante son aquellas guardadas la carpeta ..\\MTB\\Sub."@es .

ns1:SubrutinasFabricante a ns1:Sistema ;
    rdfs:label "Subrutinas de fabricante (OEM)"@es ;
    ns1:detalladoEnEsquema ns1:TablaSubrutinasFabricante ;
    ns1:textoExtracto "Las subrutinas de fabricante son aquellas guardadas la carpeta ..\\MTB\\Sub. Estas subrutinas están asociadas a algunas funciones del CNC como el cambio de herramienta, G74, G180 a G189, G380 a G399, etc."@es ;
    ns1:tieneFrecuencia ns1:FrecuenciaEjecucionOptimizada .

