@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FuncionG74 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G74" ;
    ns1:identificador "G74" ;
    ns1:requiereMantenimiento ns1:REFPSUB_G74 ;
    ns1:textoExtracto "La función G74 (búsqueda de referencia máquina) se puede programar de 2 formas. Indicando los ejes y el orden en que se efectúa la búsqueda o programando sólo G74 (sin ejes)." .

ns1:TOOLSUB a ns1:TareaMantenimiento ;
    rdfs:label "TOOLSUB" ;
    ns1:ejecutadoPor ns1:MaquinaBrochadora ;
    ns1:monitoreaParametro ns1:ParametroTOOLSUB ;
    ns1:textoExtracto "Subrutina asociada a la función T. Valores posibles: Cualquier texto de hasta 64 caracteres. Variable asociada: (V.)[ch].MPG.TOOLSUB. Esta subrutina se ejecuta automáticamente cada vez que se ejecuta una función T (selección de herramienta)." .

ns1:ParametroREFPSUB a ns1:Parametro ;
    rdfs:label "Variable (V.)[ch].MPG.REFPSUB" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.REFPSUB" ;
    ns1:valor "Texto (hasta 64 caracteres)" .

ns1:ParametroTOOLSUB a ns1:Parametro ;
    rdfs:label "Variable (V.)[ch].MPG.TOOLSUB" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.TOOLSUB" ;
    ns1:valor "Texto (hasta 64 caracteres)" .

ns1:REFPSUB_G74 a ns1:TareaMantenimiento ;
    rdfs:label "REFPSUB (G74)" ;
    ns1:ejecutadoPor ns1:MaquinaBrochadora ;
    ns1:monitoreaParametro ns1:ParametroREFPSUB ;
    ns1:textoExtracto "Subrutina asociada a la función G74. Valores posibles: Cualquier texto de hasta 64 caracteres. Variable asociada: (V.)[ch].MPG.REFPSUB. La función G74 (búsqueda de referencia máquina) se puede programar de 2 formas." .

ns1:MaquinaBrochadora a ns1:Maquina ;
    rdfs:label "Máquina brochadora" ;
    ns1:textoExtracto "Esta subrutina se ejecuta automáticamente cada vez que se ejecuta una función T (selección de herramienta)." .

