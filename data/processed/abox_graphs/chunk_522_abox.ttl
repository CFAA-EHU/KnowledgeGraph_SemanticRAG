@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacionManual a ns1:ModoOperacion ;
    rdfs:label "Modo manual"@es ;
    ns1:habilitadoPor ns1:SubrutinaBusquedaEjes ;
    ns1:textoExtracto "búsqueda de referencia máquina en modo manual sin selección de eje"@es .

ns1:ParametroINT1SUB a ns1:Parametro ;
    rdfs:label "INT1SUB"@es ;
    ns1:identificador "INT1SUB" ;
    ns1:textoExtracto "Subrutinas de interrupción. Valores posibles: Cualquier texto de hasta 64 caracteres. Variable asociada: (V.)[ch].MPG.INT1SUB"@es ;
    ns1:valor "Texto (hasta 64 caracteres)"@es .

ns1:ParametroINT4SUB a ns1:Parametro ;
    rdfs:label "INT4SUB"@es ;
    ns1:identificador "INT4SUB" ;
    ns1:textoExtracto "Subrutinas de interrupción. Valores posibles: Cualquier texto de hasta 64 caracteres. Variable asociada: (V.)[ch].MPG.INT4SUB"@es ;
    ns1:valor "Texto (hasta 64 caracteres)"@es .

ns1:SubrutinaBusquedaEjes a ns1:Sistema ;
    rdfs:label "Subrutina de búsqueda de ejes"@es ;
    ns1:textoExtracto "Dentro de esta subrutina deben programarse los ejes y el orden en que se efectúa la búsqueda. También se efectúa una llamada a esta subrutina cuando se realiza una búsqueda de referencia máquina en modo manual sin selección de eje."@es ;
    ns1:tieneComponente ns1:ParametroINT1SUB,
        ns1:ParametroINT4SUB .

