@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_Operacion_Piercing a ns1:Parametro ;
    rdfs:label "Marca de operación de piercing"@es ;
    ns1:textoExtracto "el OEM debe desactivar esta marca (asignarle valor 0) para indicar al CNC que ha finalizado la operación de piercing"@es .

ns1:Subrutina_CUTTINGON a ns1:Componente ;
    rdfs:label "Subrutina asociada al comando #CUTTING ON"@es ;
    ns1:textoExtracto "Subrutina asociada al comando #CUTTING ON. Valores posibles: Cualquier texto de hasta 64 caracteres."@es ;
    ns1:valor "Cualquier texto de hasta 64 caracteres"@es .

ns1:Variable_MPG_CUTTINGON a ns1:Parametro ;
    rdfs:label "Variable asociada a CUTTINGON"@es ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.CUTTINGON Este parámetro indica el nombre de la subrutina asociada a la sentencia #CUTTINGON."@es ;
    ns1:valor "(V.)[ch].MPG.CUTTINGON"@es .

