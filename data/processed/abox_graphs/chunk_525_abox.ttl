@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_OEMSUB_G18x a ns1:Parametro ;
    rdfs:label "Parámetro OEMSUB (G180-G189)" ;
    ns1:identificador "(V.)[ch].MPG.OEMSUB" ;
    ns1:textoExtracto "Subrutinas asociadas a las funciones G180 a G189. Valores posibles: Cualquier texto de hasta 64 caracteres." .

ns1:Sentencia_CUTTINGOFF a ns1:InterfazUsuario ;
    rdfs:label "Sentencia #CUTTINGOFF" ;
    ns1:ejecutadoPor ns1:Subrutina_Cuttingoff ;
    ns1:habilitadoPor ns1:Parametro_CUTTINGOFF ;
    ns1:textoExtracto "Cada vez que el CNC ejecuta esta sentencia, efectúa una llamada a la subrutina asociada (por defecto, Cuttingoff.fst)." .

ns1:Sentencia_CUTTINGON a ns1:InterfazUsuario ;
    rdfs:label "Sentencia #CUTTINGON" ;
    ns1:ejecutadoPor ns1:Subrutina_Cuttingon ;
    ns1:habilitadoPor ns1:Parametro_CUTTINGON ;
    ns1:textoExtracto "Cada vez que el CNC ejecuta esta sentencia, efectúa una llamada a la subrutina asociada (por defecto, Cuttingon.fst)." .

ns1:Sentencia_FINALSUB a ns1:InterfazUsuario ;
    rdfs:label "Sentencia #FINALSUB" ;
    ns1:habilitadoPor ns1:Parametro_FINALSUB ;
    ns1:textoExtracto "Cada vez que el CNC ejecuta esta sentencia, efectúa una llamada a la subrutina asociada." .

ns1:Parametro_CUTTINGOFF a ns1:Parametro ;
    rdfs:label "Parámetro CUTTINGOFF" ;
    ns1:identificador "(V.)[ch].MPG.CUTTINGOFF" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.CUTTINGOFF. Este parámetro indica el nombre de la subrutina asociada a la sentencia #CUTTINGOFF." ;
    ns1:valor "Cuttingoff.fst"^^xsd:string .

ns1:Parametro_CUTTINGON a ns1:Parametro ;
    rdfs:label "Parámetro CUTTINGON" ;
    ns1:identificador "(V.)[ch].MPG.CUTTINGON" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.CUTTINGON. Este parámetro indica el nombre de la subrutina asociada a la sentencia #CUTTINGON." ;
    ns1:valor "Cuttingon.fst"^^xsd:string .

ns1:Parametro_FINALSUB a ns1:Parametro ;
    rdfs:label "Parámetro FINALSUB" ;
    ns1:identificador "(V.)[ch].MPG.FINALSUB" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.FINALSUB. Este parámetro indica el nombre de la subrutina asociada a la sentencia #FINALSUB." .

ns1:Subrutina_Cuttingoff a ns1:ModoOperacion ;
    rdfs:label "Subrutina Cuttingoff.fst" ;
    ns1:controla ns1:Variable_CUTTING ;
    ns1:identificador "Cuttingoff.fst" ;
    ns1:textoExtracto "Subrutina asociada al comando #CUTTINGOFF. Por defecto, Cuttingoff.fst. Es responsabilidad del OEM garantizar que la subrutina tiene en cuenta todos los aspectos de seguridad relativos al manejo del láser." .

ns1:Subrutina_Cuttingon a ns1:ModoOperacion ;
    rdfs:label "Subrutina Cuttingon.fst" ;
    ns1:controla ns1:Variable_CUTTING ;
    ns1:identificador "Cuttingon.fst" ;
    ns1:textoExtracto "Subrutina asociada a la sentencia #CUTTINGON. Por defecto, Cuttingon.fst. Es responsabilidad del OEM garantizar que la subrutina tiene en cuenta todos los aspectos de seguridad relativos al manejo del láser." .

ns1:Variable_CUTTING a ns1:Parametro ;
    rdfs:label "Marca CUTTING" ;
    ns1:textoExtracto "El OEM debe activar la marca CUTTING (asignarle valor 1) para indicar al PLC que empieza la operación de cutting. [...] Al final de la subrutina Cuttingoff.fst, el OEM debe desactivar la marca CUTTING (asignarle valor 0)." ;
    ns1:valor 0,
        1 .

