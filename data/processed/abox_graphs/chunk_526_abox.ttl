@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_V_OEMSUB1 a ns1:Parametro ;
    rdfs:label "Variable OEMSUB1 (G18x)"@es ;
    ns1:identificador "(V.)[ch].MPG.OEMSUB1" ;
    ns1:monitoreaParametro ns1:Subrutina_OEMSUB_G18x ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.OEMSUB1ꞏꞏ10"@es ;
    ns1:valor "texto (hasta 64 caracteres)"@es .

ns1:Parametro_V_OEMSUB10 a ns1:Parametro ;
    rdfs:label "Variable OEMSUB10 (G18x)"@es ;
    ns1:identificador "(V.)[ch].MPG.OEMSUB10" ;
    ns1:monitoreaParametro ns1:Subrutina_OEMSUB_G18x ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.OEMSUB1ꞏꞏ10"@es ;
    ns1:valor "texto (hasta 64 caracteres)"@es .

ns1:TareaMantenimiento_LlamadaSubrutina_G18x a ns1:TareaMantenimiento ;
    rdfs:label "Llamada a subrutina G180-G189"@es ;
    ns1:ejecutadoPor ns1:Subrutina_OEMSUB_G18x ;
    ns1:textoExtracto "Cada vez que el CNC ejecuta esta sentencia, efectúa una llamada a la subrutina asociada [...] Cada vez que se ejecuta una de estas funciones se efectúa una llamada a la subrutina"@es .

ns1:Subrutina_OEMSUB_G18x a ns1:InterfazUsuario ;
    rdfs:label "Subrutinas OEMSUB (G18x)"@es ;
    ns1:identificador "G180-G189" ;
    ns1:textoExtracto "OEMSUB (G18x) Subrutinas asociadas a las funciones G180 a G189. Valores posibles: Cualquier texto de hasta 64 caracteres. Variable asociada: (V.)[ch].MPG.OEMSUB1ꞏꞏ10"@es .

