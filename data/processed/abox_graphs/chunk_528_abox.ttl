@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC_8055MC_TC a ns1:Maquina ;
    rdfs:label "Máquina CNC 8055 MC/TC"@es ;
    ns1:textoExtracto "Para poder ejecutar programas del 8055 MC/TC, en el CNC deben existir dos subrutinas llamadas 9998 y 9999"@es ;
    ns1:tieneComponente ns1:Subrutina_9998,
        ns1:Subrutina_9999 .

ns1:ProgramaPieza_8055MC_TC a ns1:ModoOperacion ;
    rdfs:label "Programa de pieza (lenguaje 8055 MC/TC)"@es ;
    ns1:habilitadoPor ns1:Subrutina_9998,
        ns1:Subrutina_9999 ;
    ns1:textoExtracto "Cada programa en lenguaje del 8055 MC/TC incorpora al principio y al final una llamada a la rutina correspondiente."@es .

ns1:Subrutina_9998 a ns1:ModoOperacion ;
    rdfs:label "Subrutina 9998 (inicio de programa)"@es ;
    ns1:identificador "9998" ;
    ns1:textoExtracto "9998 Rutina que ejecutará el CNC al principio de cada programa."@es .

ns1:Subrutina_9999 a ns1:ModoOperacion ;
    rdfs:label "Subrutina 9999 (fin de programa)"@es ;
    ns1:identificador "9999" ;
    ns1:textoExtracto "9999 Rutina que ejecutará el CNC al final de cada programa."@es .

