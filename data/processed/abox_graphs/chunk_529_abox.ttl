@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BloqueFinSubrutina a ns1:Componente ;
    rdfs:label "Bloque de fin de subrutina"@es ;
    ns1:textoExtracto "excepto el bloque de fin de subrutina"@es .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:activaAlarma ns1:ErrorEjecucionCNC ;
    ns1:controla ns1:SubrutinaFinProgramaPieza,
        ns1:SubrutinaInicioProgramaPieza ;
    ns1:textoExtracto "el CNC mostrará un error"@es .

ns1:ErrorEjecucionCNC a ns1:AvisoSeguridad ;
    rdfs:label "Error por subrutina no definida en CNC"@es ;
    ns1:mitigaRiesgo ns1:SubrutinaFinProgramaPieza,
        ns1:SubrutinaInicioProgramaPieza ;
    ns1:textoExtracto "el CNC mostrará un error cada vez que se intente ejecutar un programa pieza"@es .

ns1:SubrutinaFinProgramaPieza a ns1:Componente ;
    rdfs:label "Subrutina de fin de programa pieza"@es ;
    ns1:textoExtracto "al final del programa pieza"@es .

ns1:SubrutinaInicioProgramaPieza a ns1:Componente ;
    rdfs:label "Subrutina de inicio de programa pieza"@es ;
    ns1:textoExtracto "rutinas [...] al principio [...] del programa pieza"@es .

