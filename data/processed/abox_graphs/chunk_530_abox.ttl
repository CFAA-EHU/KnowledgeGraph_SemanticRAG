@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:palpador_sobremesa a ns1:ComponenteMecanico ;
    rdfs:label "Palpador de sobremesa"@es ;
    ns1:monitoreaParametro ns1:parametro_PROBEDATA ;
    ns1:textoExtracto "posición del palpador de sobremesa en los tres primeros ejes del canal"@es .

ns1:parametro_CHAXISNAME a ns1:Parametro ;
    rdfs:label "CHAXISNAME (Ejes del canal)"@es ;
    ns1:documentadoEn ns1:chunk269 ;
    ns1:identificador "CHAXISNAME" ;
    ns1:textoExtracto "según el parámetro CHAXISNAME"@es .

ns1:parametro_PROBEDATA a ns1:Parametro ;
    rdfs:label "PROBEDATA (Parámetros del palpador relativos al canal)"@es ;
    ns1:documentadoEn ns1:chunk269 ;
    ns1:identificador "PROBEDATA" ;
    ns1:textoExtracto "PROBEDATA Parámetros del palpador relativos al canal."@es .

ns1:chunk269 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros PROBEDATA"@es ;
    ns1:identificador "PROBEDATA" ;
    ns1:textoExtracto "Este parámetro muestra la tabla para definir la posición del palpador de sobremesa en los tres primeros ejes del canal, según el parámetro CHAXISNAME."@es .

