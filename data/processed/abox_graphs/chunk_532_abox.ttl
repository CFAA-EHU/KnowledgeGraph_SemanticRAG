@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Tabla_ParametrosPalpador a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de posición del palpador" ;
    ns1:textoExtracto "PRB2MIN | Cota mínima del palpador (segundo eje del canal). PRB3MAX | Cota máxima del palpador (tercer eje del canal). PRB3MIN | Cota mínima del palpador (tercer eje del canal). PRB1MAX | Cota máxima del palpador (primer eje del canal). PRB1MIN | Cota mínima del palpador (primer eje del canal). PRB2MAX | Cota máxima del palpador (segundo eje del canal)." ;
    ns1:tieneComponente ns1:Parametro_PRB1MAX,
        ns1:Parametro_PRB1MIN,
        ns1:Parametro_PRB2MAX,
        ns1:Parametro_PRB2MIN,
        ns1:Parametro_PRB3MAX,
        ns1:Parametro_PRB3MIN .

ns1:Parametro_PRB1MAX a ns1:Parametro ;
    rdfs:label "PRB1MAX" ;
    ns1:identificador "PRB1MAX" ;
    ns1:textoExtracto "Cota máxima del palpador (primer eje del canal). Valores posibles: Entre ±99999.9999 mm / entre ±3937.00787 inch. Valor por defecto: 0. Variable asociada: (V.)[ch].MPG.PRB1MAX" ;
    ns1:valor "0"^^xsd:string .

ns1:Parametro_PRB1MIN a ns1:Parametro ;
    rdfs:label "PRB1MIN" ;
    ns1:identificador "PRB1MIN" ;
    ns1:textoExtracto "Cota mínima del palpador (primer eje del canal). Valores posibles: Entre ±99999.9999 mm / entre ±3937.00787 inch. Valor por defecto: 0. Variable asociada: (V.)[ch].MPG.PRB1MIN" ;
    ns1:valor "0"^^xsd:string .

ns1:Parametro_PRB2MAX a ns1:Parametro ;
    rdfs:label "PRB2MAX" ;
    ns1:identificador "PRB2MAX" ;
    ns1:textoExtracto "Cota máxima del palpador (segundo eje del canal). Valores posibles: Entre ±99999.9999 mm / entre ±3937.00787 inch. Valor por defecto: 0. Variable asociada: (V.)[ch].MPG.PRB2MAX" ;
    ns1:valor "0"^^xsd:string .

ns1:Parametro_PRB2MIN a ns1:Parametro ;
    rdfs:label "PRB2MIN" ;
    ns1:identificador "PRB2MIN" ;
    ns1:textoExtracto "Cota mínima del palpador (segundo eje del canal)." ;
    ns1:valor "0"^^xsd:string .

ns1:Parametro_PRB3MAX a ns1:Parametro ;
    rdfs:label "PRB3MAX" ;
    ns1:identificador "PRB3MAX" ;
    ns1:textoExtracto "Cota máxima del palpador (tercer eje del canal). Valores posibles: Entre ±99999.9999 mm / entre ±3937.00787 inch. Valor por defecto: 0. Variable asociada: (V.)[ch].MPG.PRB3MAX" ;
    ns1:valor "0"^^xsd:string .

ns1:Parametro_PRB3MIN a ns1:Parametro ;
    rdfs:label "PRB3MIN" ;
    ns1:identificador "PRB3MIN" ;
    ns1:textoExtracto "Cota mínima del palpador (tercer eje del canal). Valores posibles: Entre ±99999.9999 mm / entre ±3937.00787 inch." ;
    ns1:valor "0"^^xsd:string .

