@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_PalpadorSobremesa a ns1:Componente ;
    rdfs:label "Palpador de sobremesa" ;
    ns1:textoExtracto "palpador de sobremesa que se utiliza para la calibración de herramientas"@es ;
    ns1:tieneComponente ns1:Maquina_CNC .

ns1:Parametro_PRB3MAX a ns1:Parametro ;
    rdfs:label "PRB3MAX" ;
    ns1:identificador "(V.)[ch].MPG.PRB3MAX" ;
    ns1:monitoreaParametro ns1:Maquina_CNC ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.PRB3MAX Consultar el parámetro máquina general PRB3MIN. PRB3MIN Cota mínima del palpador (tercer eje del canal)." ;
    ns1:valor "Entre ±99999.9999 mm / entre ±3937.00787 inch"@es .

ns1:Parametro_PRB3MIN a ns1:Parametro ;
    rdfs:label "PRB3MIN" ;
    ns1:identificador "(V.)[ch].MPG.PRB3MIN" ;
    ns1:monitoreaParametro ns1:Maquina_CNC ;
    ns1:textoExtracto "PRB3MIN Cota mínima del palpador (tercer eje del canal). Valores posibles: Entre ±99999.9999 mm / entre ±3937.00787 inch. Valor por defecto: 0."@es ;
    ns1:valor "Entre ±99999.9999 mm / entre ±3937.00787 inch"@es .

ns1:Maquina_CNC a ns1:Maquina ;
    ns1:textoExtracto "Estos parámetros definen la posición que ocupa el palpador de sobremesa que se utiliza para la calibración de herramientas. Se definirán en cotas absolutas y estarán referidas al cero máquina. Si se trata de un CNC modelo TORNO, las cotas deben expresarse en radios."@es .

