    ns1:textoExtracto "PRB3MIN" .

ns1:Esquema_PosicionPalpadorSobremesa a ns1:Esquema ;
    rdfs:label "Esquema de posición del palpador de sobremesa"@es ;
    ns1:identificador "2.4.15" ;
    ns1:textoExtracto "PRB2MIN X PRB3MIN X" .

