@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_PRB1MAX a ns1:Parametro ;
    rdfs:label "PRB1MAX" ;
    ns1:detalladoEnEsquema ns1:Esquema_PosicionPalpadorSobremesa ;
    ns1:textoExtracto "PRB1MAX" .

ns1:Parametro_PRB1MIN a ns1:Parametro ;
    rdfs:label "PRB1MIN" ;
    ns1:detalladoEnEsquema ns1:Esquema_PosicionPalpadorSobremesa ;
    ns1:textoExtracto "PRB1MIN" .

ns1:Parametro_PRB2MAX a ns1:Parametro ;
    rdfs:label "PRB2MAX" ;
    ns1:detalladoEnEsquema ns1:Esquema_PosicionPalpadorSobremesa ;
    ns1:textoExtracto "PRB2MAX" .

ns1:Parametro_PRB2MIN a ns1:Parametro ;
    rdfs:label "PRB2MIN" ;
    ns1:detalladoEnEsquema ns1:Esquema_PosicionPalpadorSobremesa ;
    ns1:textoExtracto "PRB2MIN" .

ns1:Parametro_PRB3MAX a ns1:Parametro ;
    rdfs:label "PRB3MAX" ;
    ns1:detalladoEnEsquema ns1:Esquema_PosicionPalpadorSobremesa ;
    ns1:textoExtracto "PRB3MAX" .

ns1:Parametro_PRB3MIN a ns1:Parametro ;
