@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Campo_MPLC a ns1:Parametro ;
    rdfs:label "MPLC" ;
    ns1:documentadoEn ns1:Tabla_FuncionesM ;
    ns1:identificador "MPLC" ;
    ns1:textoExtracto "La tabla de funciones M dispone del campo MPLC para definir si el CNC envía o no la función al PLC." .

ns1:Parametro_FUNPLC a ns1:Parametro ;
    rdfs:label "FUNPLC" ;
    ns1:identificador "FUNPLC" ;
    ns1:monitoreaParametro ns1:Variable_V_MPG_FUNPLC ;
    ns1:textoExtracto "FUNPLC Enviar las funciones M, H, S al PLC en la búsqueda de bloque. Valores posibles: Sí / No. Valor por defecto: No." ;
    ns1:valor "No" .

ns1:Tabla_FuncionesM a ns1:Tabla ;
    rdfs:label "Tabla de funciones M" ;
    ns1:textoExtracto "La tabla de funciones M dispone del campo MPLC para definir si el CNC envía o no la función al PLC." .

ns1:Variable_V_MPG_FUNPLC a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPG.FUNPLC" ;
    ns1:identificador "(V.)[ch].MPG.FUNPLC" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.FUNPLC" .

