@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FuncionMHSF a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función MHSF"@es ;
    ns1:monitoreaParametro ns1:BusquedaBloque_Mecanizado ;
    ns1:textoExtracto "el CNC muestra la softkey 'MHSF' para poder ejecutar cualquier función de este tipo, modificando así las condiciones de mecanizado"@es .

ns1:HistoriaFunciones_Mecanizado a ns1:InterfazUsuario ;
    rdfs:label "Historia de funciones (mecanizado)"@es ;
    ns1:habilitadoPor ns1:BusquedaBloque_Mecanizado ;
    ns1:textoExtracto "el CNC muestra en pantalla la historia de dichas funciones para que el usuario las pueda habilitar en el orden deseado"@es .

ns1:Softkey_MHSF a ns1:InterfazUsuario ;
    rdfs:label "Softkey MHSF"@es ;
    ns1:identificador "MHSF" ;
    ns1:ilustradoEn ns1:BusquedaBloque_Mecanizado ;
    ns1:textoExtracto "el CNC muestra la softkey 'MHSF' para poder ejecutar cualquier función de este tipo"@es .

ns1:BusquedaBloque_Mecanizado a ns1:ModoOperacion ;
    rdfs:label "Búsqueda de bloque (mecanizado)"@es ;
    ns1:textoExtracto "las funciones se envían al PLC durante la búsqueda de bloque, a medida que se van leyendo. Una vez finalizada la búsqueda de bloque, y tras reposicionar los ejes, el CNC muestra la softkey 'MHSF' para poder ejecutar cualquier función de este tipo, modificando así las condiciones de mecanizado."@es .

