@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Maquina_CNC a ns1:Maquina ;
    ns1:monitoreaParametro ns1:VariablePLC_G00FEED ;
    ns1:textoExtracto "el CNC limita el avance al valor definido en MAXFEED sin mostrar ningún error ni warning. [...] el CNC asume el cambio inmediatamente y éste permanece activo hasta que la variable tome valor ꞏ0ꞏ." ;
    ns1:tieneComponente ns1:Parametro_DEFAULTFEED,
        ns1:Parametro_G00FEED,
        ns1:Parametro_MAXFEED .

ns1:Parametro_DEFAULTFEED a ns1:Parametro ;
    rdfs:label "DEFAULTFEED" ;
    ns1:identificador "(V.)[ch].MPG.DEFAULTFEED" ;
    ns1:textoExtracto "DEFAULTFEED Asumir MAXFEED para los desplazamientos en G1/G2/G3 sin avance activo. Valores posibles: Sí / No. Valor por defecto: No. Este parámetro determina si los ejes se desplazan al avance definido en MAXFEED cuando se programa un movimiento en G01/G02/G03 sin programar el avance." ;
    ns1:valor "No"^^xsd:string .

ns1:VariablePLC_G00FEED a ns1:Parametro ;
    rdfs:label "Variable PLC G00FEED" ;
    ns1:controla ns1:Parametro_G00FEED,
        ns1:Parametro_MAXFEED ;
    ns1:identificador "(V.)[ch].PLC.G00FEED" ;
    ns1:textoExtracto "El PLC dispone de la variable (V.)[ch].PLC.G00FEED que permite limitar el avance en el canal para cualquier tipo de movimiento (G00, G01, etc). Esta variable limita el avance de la trayectoria y afecta a todos los ejes, tanto si se mueven interpolados como eje a eje." .

ns1:Parametro_G00FEED a ns1:Parametro ;
    rdfs:label "G00FEED" ;
    ns1:textoExtracto "Este parámetro no se podrá definir con un valor superior al del parámetro G00FEED. [...] el CNC asume como avance máximo para todos los desplazamientos el definido en el parámetro máquina G00FEED." .

ns1:Parametro_MAXFEED a ns1:Parametro ;
    rdfs:label "MAXFEED" ;
    ns1:identificador "(V.)[ch].MPG.MAXFEED" ;
    ns1:textoExtracto "MAXFEED Máximo avance de mecanizado sobre la trayectoria. Valores posibles: De 0 a 500000.0000 mm/min / de 0 a 19685.03937 inch/min. Valor por defecto: 0. Este parámetro establece el avance máximo de mecanizado (movimientos en G01/G02/G03) sobre la trayectoria; si se define con valor ꞏ0ꞏ, no se limita el avance." ;
    ns1:valor "0"^^xsd:string,
        "19685.03937 inch/min"^^xsd:string,
        "500000.0000 mm/min"^^xsd:string .

