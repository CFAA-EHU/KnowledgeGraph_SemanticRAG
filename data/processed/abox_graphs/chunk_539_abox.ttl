@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_DEFAULTFEED a ns1:Parametro ;
    rdfs:label "Parámetro MPG.DEFAULTFEED" ;
    ns1:identificador "V.[ch].MPG.DEFAULTFEED" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.DEFAULTFEED. Este parámetro determina si los ejes se desplazan al avance definido en MAXFEED cuando se programa un movimiento en G01/G02/G03 sin programar el avance." ;
    ns1:valor "No"^^xsd:string .

ns1:Parametro_MAXFEED a ns1:Parametro ;
    rdfs:label "Parámetro MAXFEED" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro [DEFAULTFEED] cuando se ha definido MAXFEED con un valor distinto de '0'." .

