@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_RAPIDEN a ns1:Parametro ;
    rdfs:label "RAPIDEN" ;
    ns1:identificador "V.[ch].MPG.RAPIDEN" ;
    ns1:monitoreaParametro ns1:ModoOperacion_AvanceRapido ;
    ns1:textoExtracto "RAPIDEN Permitir habilitar el avance rápido para el modo automático. Valores posibles: Deshabilitado / EXRAPID o tecla rápido / EXRAPID y tecla rápido. Valor por defecto: Deshabilitado." ;
    ns1:valor "Deshabilitado"^^xsd:string .

ns1:InterfazUsuario_TeclaRapido a ns1:InterfazUsuario ;
    rdfs:label "Tecla rápido" ;
    ns1:textoExtracto "pulsar la tecla 'rápido'" .

ns1:Marca_EXRAPID a ns1:Parametro ;
    rdfs:label "Marca EXRAPID" ;
    ns1:identificador "EXRAPID" ;
    ns1:textoExtracto "activar la marca EXRAPID de PLC" .

ns1:ModoOperacion_AvanceRapido a ns1:ModoOperacion ;
    rdfs:label "Avance rápido en modo automático" ;
    ns1:habilitadoPor ns1:InterfazUsuario_TeclaRapido,
        ns1:Marca_EXRAPID ;
    ns1:textoExtracto "Este parámetro indica si se permite habilitar el avance rápido durante la ejecución de un programa, para los desplazamientos programados." .

