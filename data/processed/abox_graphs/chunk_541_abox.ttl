@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_deshabilitacionAvanceRapido a ns1:AccionProhibida ;
    rdfs:label "Avance rápido no disponible"@es ;
    ns1:mitigaRiesgo ns1:ModoOperacion_avanceRapidoAutomatico ;
    ns1:textoExtracto "El avance rápido no está disponible para el modo automático."@es .

ns1:Parametro_EXRAPID a ns1:Parametro ;
    rdfs:label "Marca EXRAPID"@es ;
    ns1:habilitadoPor ns1:InterfazUsuario_panelJog ;
    ns1:identificador "EXRAPID" ;
    ns1:textoExtracto "marca EXRAPID de PLC"@es .

ns1:InterfazUsuario_panelJog a ns1:InterfazUsuario ;
    rdfs:label "Panel de jog"@es ;
    ns1:textoExtracto "tecla \"rápido\" del panel de jog"@es .

ns1:ModoOperacion_avanceRapidoAutomatico a ns1:ModoOperacion ;
    rdfs:label "Avance rápido para modo automático"@es ;
    ns1:identificador "RAPIDEN" ;
    ns1:textoExtracto "2.4.19 Avance rápido para el modo automático."@es .

