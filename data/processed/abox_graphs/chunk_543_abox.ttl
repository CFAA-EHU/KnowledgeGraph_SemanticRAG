@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_AvanceRapido a ns1:Parametro ;
    rdfs:label "Parámetro de avance rápido"@es ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "Si el parámetro se define con valor ꞏ0ꞏ, no se limita el avance. Este parámetro no afecta a los desplazamientos programados en G00 ni a los roscados."@es .

ns1:Parametro_LimiteAvanceRapido a ns1:Parametro ;
    rdfs:label "Parámetro de límite de avance rápido"@es ;
    ns1:identificador "FRAPIDEN" ;
    ns1:textoExtracto "El avance rápido no podrá superar al definido en los parámetros de eje G00FEED y FRAPIDEN"@es .

ns1:Variable_PLC_AvanceMaximo a ns1:Parametro ;
    rdfs:label "Variable PLC de avance máximo"@es ;
    ns1:textoExtracto "ni tampoco al avance máximo fijado por PLC (variable"@es .

