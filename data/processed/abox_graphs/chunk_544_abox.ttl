@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_AvanceRapidoAutomatico a ns1:ModoOperacion ;
    rdfs:label "Avance rápido para modo automático" ;
    ns1:monitoreaParametro ns1:Parametro_FRAPIDEN,
        ns1:Parametro_G00FEED,
        ns1:Parametro_MAXFEED,
        ns1:VariablePLC_F,
        ns1:VariablePLC_G00FEED ;
    ns1:textoExtracto "Los roscados se ejecutan al avance programado. El avance rápido no podrá superar al definido en los parámetros de eje G00FEED y FRAPIDEN, ni tampoco al avance máximo fijado por PLC (variable (V.)PLC.G00FEED). El avance rápido podrá superar al definido en el parámetro MAXFEED del canal y al avance activo definido por PLC (variable (V.)PLC.F)." .

ns1:Parametro_FRAPIDEN a ns1:Parametro ;
    rdfs:label "FRAPIDEN" ;
    ns1:identificador "FRAPIDEN" ;
    ns1:textoExtracto "avance rápido no podrá superar al definido en los parámetros de eje G00FEED y FRAPIDEN" .

ns1:Parametro_G00FEED a ns1:Parametro ;
    rdfs:label "G00FEED" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "avance programado... parámetro de eje G00FEED" .

ns1:Parametro_MAXFEED a ns1:Parametro ;
    rdfs:label "MAXFEED" ;
    ns1:identificador "MAXFEED" ;
    ns1:textoExtracto "avance rápido podrá superar al definido en el parámetro MAXFEED del canal" .

ns1:VariablePLC_F a ns1:Parametro ;
    rdfs:label "Variable PLC F" ;
    ns1:identificador "V.PLC.F" ;
    ns1:textoExtracto "avance activo definido por PLC (variable (V.)PLC.F)" .

ns1:VariablePLC_G00FEED a ns1:Parametro ;
    rdfs:label "Variable PLC G00FEED" ;
    ns1:identificador "V.PLC.G00FEED" ;
    ns1:textoExtracto "avance máximo fijado por PLC (variable (V.)PLC.G00FEED)" .

