@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "El CNC siempre respeta la dinámica de los ejes implicados en la trayectoria, es decir, respeta la aceleración y el jerk definido en cada eje." ;
    ns1:tieneComponente ns1:Parametro_MAXACCEL,
        ns1:Parametro_MAXJERK .

ns1:Variable_MAXACCEL_Temporal a ns1:Parametro ;
    rdfs:label "Variable temporal MAXACCEL" ;
    ns1:identificador "(V.)[ch].G.MAXACCEL" ;
    ns1:textoExtracto "La variable (V.)[ch].G.MAXACCEL permite modificar temporalmente, en un momento dado y en tiempo real, el valor definido por el parámetro máquina. El CNC asume el cambio inmediatamente y permanece activo hasta ejecutar M30 o reset." .

ns1:Variable_MAXJERK_Temporal a ns1:Parametro ;
    rdfs:label "Variable temporal MAXJERK" ;
    ns1:identificador "(V.)[ch].G.MAXJERK" ;
    ns1:textoExtracto "La variable (V.)[ch].G.MAXJERK permite modificar temporalmente, en un momento dado y en tiempo real, el valor definido por el parámetro máquina." .

ns1:Parametro_MAXACCEL a ns1:Parametro ;
    rdfs:label "MAXACCEL" ;
    ns1:identificador "(V.)[ch].MPG.MAXACCEL" ;
    ns1:textoExtracto "Máxima aceleración sobre la trayectoria de mecanizado. Valores posibles: De 0.0010 a 600000000.0000 mm/min / de 0.00004 a 23622047.24409 inch/min. Este parámetro permite suavizar el avance sobre la trayectoria, limitando la aceleración máxima sobre ella." ;
    ns1:valor "0.0010 a 600000000.0000 mm/min / 0.00004 a 23622047.24409 inch/min" .

ns1:Parametro_MAXJERK a ns1:Parametro ;
    rdfs:label "MAXJERK" ;
    ns1:identificador "(V.)[ch].MPG.MAXJERK" ;
    ns1:textoExtracto "Máximo jerk sobre la trayectoria de mecanizado. Valores posibles: De 0.0010 a 6E11 mm/min / de 0.00004 a 2.362E10 inch/min. Este parámetro permite suavizar el avance sobre la trayectoria, limitando el jerk máximo sobre ella." ;
    ns1:valor "0.0010 a 6E11 mm/min / 0.00004 a 2.362E10 inch/min" .

