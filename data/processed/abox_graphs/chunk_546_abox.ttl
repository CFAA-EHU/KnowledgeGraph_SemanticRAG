@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "CNC (Control Numérico Computarizado)"@es ;
    ns1:textoExtracto "El CNC asume el cambio inmediatamente y permanece activo hasta ejecutar M30 o reset"@es .

ns1:ModoOperacion_Temporal a ns1:ModoOperacion ;
    rdfs:label "Modo de operación temporal para jerk máximo"@es ;
    ns1:habilitadoPor ns1:Variable_G_MAXJERK ;
    ns1:textoExtracto "modificar temporalmente [...] hasta ejecutar M30 o reset, en cuyo caso el CNC recupera el valor fijado por el parámetro máquina"@es .

ns1:ParametroMaquina_MAXJERK a ns1:Parametro ;
    rdfs:label "Parámetro máquina para jerk máximo"@es ;
    ns1:identificador "MAXJERK" ;
    ns1:textoExtracto "el valor definido por el parámetro máquina"@es .

ns1:Variable_G_MAXJERK a ns1:Parametro ;
    rdfs:label "Variable (V.)[ch].G.MAXJERK"@es ;
    ns1:identificador "(V.)[ch].G.MAXJERK" ;
    ns1:monitoreaParametro ns1:ParametroMaquina_MAXJERK ;
    ns1:textoExtracto "La variable (V.)[ch].G.MAXJERK permite modificar temporalmente, en un momento dado y en tiempo real, el valor definido por el parámetro máquina"@es .

