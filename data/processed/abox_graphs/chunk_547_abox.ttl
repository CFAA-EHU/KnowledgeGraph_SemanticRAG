@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "CNC"@es ;
    ns1:monitoreaParametro ns1:ParametroMaquina_JerckMaximo,
        ns1:VariableOverride_Jerck ;
    ns1:textoExtracto "el CNC recupera el valor fijado por el parámetro máquina"@es .

ns1:ParametroMaquina_JerckMaximo a ns1:Parametro ;
    rdfs:label "Parámetro máquina de jerk máximo"@es ;
    ns1:textoExtracto "valor fijado por el parámetro máquina"@es ;
    ns1:valor "límite de jerk sobre la trayectoria"@es .

ns1:VariableOverride_Jerck a ns1:Parametro ;
    rdfs:label "Variable de override de jerk"@es ;
    ns1:textoExtracto "Si la variable toma valor ꞏ0ꞏ, el CNC no aplica ningún límite al jerk sobre la trayectoria, ni siquiera el fijado por parámetro máquina"@es ;
    ns1:valor "0" .

