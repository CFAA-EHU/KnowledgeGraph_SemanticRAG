@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_MAXFREQ a ns1:Parametro ;
    rdfs:label "MAXFREQ" ;
    ns1:documentadoEn ns1:Manual_Seccion2.4.21 ;
    ns1:identificador "(V.)[ch].MPG.MAXFREQ" ;
    ns1:textoExtracto "MAXFREQ Máxima frecuencia generada sobre la trayectoria de mecanizado. Valores posibles: De 0 a 500 Hz. Valor por defecto: 0." ;
    ns1:valor "0-500 Hz" .

ns1:Manual_Seccion2.4.21 a ns1:Manual ;
    rdfs:label "Sección 2.4.21 - Máxima frecuencia sobre la trayectoria" ;
    ns1:textoExtracto "Máxima frecuencia generada sobre la trayectoria de mecanizado. Este parámetro permite parametrizar el filtro de suavizado para el mecanizado en G5." .

