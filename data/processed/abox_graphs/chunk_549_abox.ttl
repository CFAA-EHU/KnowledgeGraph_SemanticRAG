@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ModoOperacion_G5 a ns1:ModoOperacion ;
    rdfs:label "G5" ;
    ns1:identificador "G5" ;
    ns1:textoExtracto "CNC aplica este filtro en HSC, G50, G5 y G7." .

ns1:ModoOperacion_G50 a ns1:ModoOperacion ;
    rdfs:label "G50" ;
    ns1:identificador "G50" ;
    ns1:textoExtracto "CNC aplica este filtro en HSC, G50, G5 y G7." .

ns1:ModoOperacion_G7 a ns1:ModoOperacion ;
    rdfs:label "G7" ;
    ns1:identificador "G7" ;
    ns1:textoExtracto "CNC aplica este filtro en HSC, G50, G5 y G7." .

ns1:ModoOperacion_HSC a ns1:ModoOperacion ;
    rdfs:label "HSC" ;
    ns1:identificador "HSC" ;
    ns1:textoExtracto "CNC aplica este filtro en HSC, G50, G5 y G7." .

ns1:Parametro_CURVFREQRES a ns1:Parametro ;
    rdfs:label "CURVFREQRES" ;
    ns1:identificador "CURVFREQRES" ;
    ns1:monitoreaParametro ns1:Maquina_CNC ;
    ns1:textoExtracto "CURVFREQRES Primera frecuencia de resonancia de la máquina en los arcos. Valores posibles: De 0 a 500.0000 Hz. Valor por defecto: 0." ;
    ns1:valor "0.0"^^xsd:float .

ns1:Maquina_CNC a ns1:Maquina ;
    ns1:textoExtracto "CNC aplica este filtro en HSC, G50, G5 y G7." .

