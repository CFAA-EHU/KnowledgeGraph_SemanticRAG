@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_Retrace a ns1:ModoOperacion ;
    rdfs:label "Función retrace" ;
    ns1:controla ns1:ComponenteElectrico_Cabezal ;
    ns1:identificador "retrace" ;
    ns1:textoExtracto "Una vez permitida la función retrace, esta se podrá activar desde el PLC mediante la marca RETRACE. Para poder ejecutar la función retrace, el CNC guarda la información de los últimos bloques ejecutados." .

ns1:Parametro_NRETBLK a ns1:Parametro ;
    rdfs:label "Parámetro NRETBLK" ;
    ns1:identificador "NRETBLK" ;
    ns1:textoExtracto "Máximo número de bloques permitidos para la función retrace. Valores posibles: De 0 a 300. Valor por defecto: 75. Variable asociada: (V.)[ch].MPG.NRETBLK Este parámetro establece el máximo número de bloques que se pueden retroceder con la función retrace." ;
    ns1:valor "75" .

ns1:Parametro_RETMFUNC a ns1:Parametro ;
    rdfs:label "Parámetro RETMFUNC" ;
    ns1:identificador "RETMFUNC" ;
    ns1:textoExtracto "Tratamiento de las funciones M con la función retrace. Valores posibles: Ignorar / Cancelar. Valor por defecto: Ignorar. Variable asociada: (V.)[ch].MPG.RETMFUNC Este parámetro establece el comportamiento de la función retrace cuando se ejecutan funciones M." ;
    ns1:valor "Ignorar" .

ns1:Parametro_RETRACAC a ns1:Parametro ;
    rdfs:label "Parámetro RETRACAC" ;
    ns1:identificador "RETRACAC" ;
    ns1:textoExtracto "Permitir habilitar la función retrace. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPG.RETRACAC Este parámetro indica si se permite utilizar la función retrace en el CNC." ;
    ns1:valor "No" .

ns1:ComponenteElectrico_Cabezal a ns1:ComponenteElectrico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "Las funciones M03 y M04 se ignoran siempre; el CNC no arranca el cabezal ni cambia el sentido de giro. La función M05 sólo cancela la función retrace si implica detener el cabezal." .

