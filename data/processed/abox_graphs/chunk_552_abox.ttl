@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DistanciaRetiroHerramienta a ns1:Parametro ;
    rdfs:label "Distancia de retiro de herramienta" ;
    ns1:monitoreaParametro ns1:CiclosFijosRoscado_T ;
    ns1:textoExtracto "La distancia que se retira la herramienta depende de la programación del ciclo." .

ns1:G233 a ns1:ModoOperacion ;
    rdfs:label "G233" ;
    ns1:identificador "G233" ;
    ns1:textoExtracto "Si G233 no está activa, los ejes se detienen al final de la pasada." .

ns1:CiclosFijosRoscado_T a ns1:ModoOperacion ;
    rdfs:label "Ciclos fijos de roscado (modelo -T-)" ;
    ns1:identificador "CiclosFijosRoscado_T" ;
    ns1:requiereMantenimiento ns1:HerramientaCNC_Roscado ;
    ns1:textoExtracto "En los ciclos fijos de roscado (modelo -T-), tanto ISO como conversacional, el CNC retira los ejes de la pieza." .

ns1:HerramientaCNC_Roscado a ns1:Herramienta ;
    rdfs:label "Herramienta de roscado" ;
    ns1:textoExtracto "el CNC retira los ejes de la pieza. La distancia que se retira la herramienta depende de la programación del ciclo." .

