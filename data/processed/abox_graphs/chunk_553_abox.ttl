@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_AXISEXCH a ns1:Parametro ;
    rdfs:label "AXISEXCH" ;
    ns1:identificador "AXISEXCH" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "el comportamiento de este parámetro también depende del parámetro AXISEXCH, el cual define si el cambio de canal de un cabezal es temporal o permanente" ;
    ns1:valor "Temporal, Permanente" .

ns1:Parametro_MASTERSPDL a ns1:Parametro ;
    rdfs:label "MASTERSPDL" ;
    ns1:identificador "MASTERSPDL" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "MASTERSPDL Cabezal master mantenido. Valores posibles: Temporal / Mantenido. Valor por defecto: Temporal. Variable asociada: (V.)[ch].MPG.MASTERSPDL" ;
    ns1:valor "Temporal, Mantenido" .

ns1:Tabla_MASTERSPDL_Significado a ns1:Tabla ;
    rdfs:label "Significado de valores MASTERSPDL" ;
    ns1:documentadoEn ns1:Manual_CNC ;
    ns1:textoExtracto "| MASTERSPDL | Significado. | --- | --- | Temporal. | El canal recupera su cabezal master original si está libre; sino, selecciona como master el primer cabezal disponible de la configuración original. | Mantenido. | El canal mantiene el cabezal master activo." .

ns1:Componente_MasterHead_Original a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal master original" ;
    ns1:textoExtracto "el canal recupera su cabezal master original si está libre; sino, selecciona como master el primer cabezal disponible de la configuración original" .

ns1:Componente_MasterHead_Temporal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal master temporal" ;
    ns1:textoExtracto "El canal mantiene el cabezal master activo. [...] Si el cabezal master actual del canal es un cabezal cedido por otro canal y su permiso de cambio de canal es temporal (AXISEXCH=Temporal), el cabezal vuelve a su canal original" .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "tras reiniciar el CNC. [...] en el arranque del CNC y tras un reset, el canal asume como cabezal master el primer cabezal definido en los parámetros máquina del canal" ;
    ns1:tieneComponente ns1:Componente_MasterHead_Original,
        ns1:Componente_MasterHead_Temporal .

