@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_CNC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz CNC" ;
    ns1:monitoreaParametro ns1:Parametro_PotenciaCabezal,
        ns1:Parametro_VelocidadCabezal ;
    ns1:textoExtracto "El CNC muestra únicamente los parámetros correspondientes al tipo de eje y regulador seleccionados" .

ns1:Sistema_RegulacionEje a ns1:Sistema ;
    rdfs:label "Sistema de regulación de eje" ;
    ns1:controla ns1:Parametro_PotenciaCabezal,
        ns1:Parametro_VelocidadCabezal ;
    ns1:textoExtracto "tipo de eje y regulador seleccionados" .

ns1:Parametro_PotenciaCabezal a ns1:Parametro ;
    rdfs:label "Parámetro de potencia del cabezal" ;
    ns1:textoExtracto "definen la potencia (definida en watios)" ;
    ns1:valor "watios" .

ns1:Parametro_VelocidadCabezal a ns1:Parametro ;
    rdfs:label "Parámetro de velocidad del cabezal" ;
    ns1:textoExtracto "los parámetros relacionados con la velocidad del cabezal (definida en rpm)" ;
    ns1:valor "rpm" .

