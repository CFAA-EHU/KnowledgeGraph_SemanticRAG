@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:controla ns1:Parametro_AXISEXCH ;
    ns1:textoExtracto "Parámetro válido para [...] cabezales. Inicialmente, cada canal tiene asignados unos [...] cabezales." .

ns1:Componente_Eje a ns1:ComponenteMecanico ;
    rdfs:label "Eje" ;
    ns1:controla ns1:Parametro_AXISEXCH ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos [...]. Inicialmente, cada canal tiene asignados unos ejes [...]." .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:controla ns1:Parametro_AXISEXCH ;
    ns1:textoExtracto "El CNC puede cambiar ejes y cabezales de canal o simplemente modificar la configuración de un canal alterando la posición de sus ejes y cabezales o eliminando alguno de ellos." .

ns1:Variable_MPA_AXISEXCH a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.AXISEXCH.xn" ;
    ns1:identificador "(V.)[ch].MPA.AXISEXCH.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.AXISEXCH.xn" .

ns1:Parametro_AXISEXCH a ns1:Parametro ;
    rdfs:label "AXISEXCH" ;
    ns1:identificador "AXISEXCH" ;
    ns1:monitoreaParametro ns1:Variable_MPA_AXISEXCH ;
    ns1:textoExtracto "AXISEXCH Permiso de cambio de canal. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: No / Temporal / Mantenido. Valor por defecto: No." ;
    ns1:valor "No / Temporal / Mantenido"^^xsd:string .

