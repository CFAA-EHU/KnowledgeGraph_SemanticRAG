@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ModoOperacion_Simulacion a ns1:ModoOperacion ;
    rdfs:label "Modo de operación: Simulación" ;
    ns1:monitoreaParametro ns1:Parametro_AXISTYPE,
        ns1:Parametro_DRIVETYPE ;
    ns1:textoExtracto "La opción Simulado se debe usar cuando no hay eje físico o durante la puesta a punto. Con la opción Simulado, el CNC simula todos los movimientos, asume como cota real la cota teórica y no proporciona consignas al exterior. Los ejes simulados no se activan mediante el código de validación." .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "El CNC no permite disponer de reguladores Sercos y Mechatrolink en un mismo sistema, pero sí permite combinar estos reguladores con reguladores analógicos." ;
    ns1:tieneComponente ns1:Parametro_AXISTYPE,
        ns1:Parametro_DRIVETYPE,
        ns1:Parametro_POSUNITS .

ns1:Parametro_POSUNITS a ns1:Parametro ;
    rdfs:label "POSUNITS (Unidades del sistema de captación)" ;
    ns1:identificador "POSUNITS" ;
    ns1:textoExtracto "POSUNITS Unidades del sistema de captación." .

ns1:Parametro_AXISTYPE a ns1:Parametro ;
    rdfs:label "AXISTYPE (Tipo de eje)" ;
    ns1:identificador "AXISTYPE" ;
    ns1:textoExtracto "AXISTYPE Tipo de eje. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Lineal / Rotativo / Cabezal. Valor por defecto: Lineal." ;
    ns1:valor "Lineal"^^xsd:string .

ns1:Parametro_DRIVETYPE a ns1:Parametro ;
    rdfs:label "DRIVETYPE (Tipo de regulador)" ;
    ns1:identificador "DRIVETYPE" ;
    ns1:textoExtracto "DRIVETYPE Tipo de regulador. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos, Mlink (Mechatrolink) y simulado. Valores posibles: Analógico / Sercos / Mlink / Simulado. Valor por defecto: Simulado." ;
    ns1:valor "Simulado"^^xsd:string .

