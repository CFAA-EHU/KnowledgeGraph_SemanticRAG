@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_Regulador_299 a ns1:Sistema ;
    rdfs:label "Sistema de regulador (eje)"@es ;
    ns1:documentadoEn ns1:Pagina_148 ;
    ns1:monitoreaParametro ns1:Parametro_PosUnits_Grados,
        ns1:Parametro_PosUnits_Milimetros,
        ns1:Parametro_PosUnits_Pulsos ;
    ns1:textoExtracto "Tipo de eje y regulador"@es .

ns1:Parametro_PosUnits_Grados a ns1:Parametro ;
    rdfs:label "Unidad de medición en grados (POSUNITS)"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_UnidadesRegulador_299 ;
    ns1:textoExtracto "La comunicación con el regulador se realiza en grados"@es ;
    ns1:valor "grados"@es .

ns1:Parametro_PosUnits_Milimetros a ns1:Parametro ;
    rdfs:label "Unidad de medición en milímetros (POSUNITS)"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_UnidadesRegulador_299 ;
    ns1:textoExtracto "La comunicación con el regulador se realiza en milímetros"@es ;
    ns1:valor "milímetros"@es .

ns1:Parametro_PosUnits_Pulsos a ns1:Parametro ;
    rdfs:label "Unidad de comunicación en pulsos (POSUNITS)"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_UnidadesRegulador_299 ;
    ns1:textoExtracto "La comunicación con el regulador se realiza en pulsos"@es ;
    ns1:valor "pulsos"@es .

ns1:Pagina_148 a ns1:Pagina ;
    rdfs:label "Página 148 (Sección 2.5.2: Tipo de eje y regulador)"@es ;
    ns1:identificador "148" ;
    ns1:textoExtracto "2.5.2 Tipo de eje y regulador"@es .

ns1:Tabla_UnidadesRegulador_299 a ns1:Tabla ;
    rdfs:label "Tabla de unidades de comunicación del regulador"@es ;
    ns1:documentadoEn ns1:Pagina_148 ;
    ns1:textoExtracto "POSUNITS | Significado. --- | --- Medición. | La comunicación con el regulador se realiza en milímetros o grados. Pulsos. | La comunicación con el regulador se realiza en pulsos."@es .

