@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_ComunicacionSercos a ns1:Tabla ;
    rdfs:label "Tabla de comunicación con regulador Sercos" ;
    ns1:documentadoEn ns1:Parametro_SERCOSDATA ;
    ns1:textoExtracto "Este parámetro muestra la tabla para definir la comunicación con el regulador Sercos." .

ns1:Parametro_SERCOSDATA a ns1:Parametro ;
    rdfs:label "SERCOSDATA" ;
    ns1:identificador "SERCOSDATA" ;
    ns1:textoExtracto "SERCOSDATA Datos del regulador Sercos. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos." .

