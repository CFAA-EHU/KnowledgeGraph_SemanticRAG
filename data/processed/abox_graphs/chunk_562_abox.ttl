@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_SercosData a ns1:Tabla ;
    rdfs:label "Tabla de parámetros SercosData"@es ;
    ns1:detalladoEnEsquema ns1:Sistema_Sercos ;
    ns1:textoExtracto "DRIVEID | Dirección del regulador Sercos. OPMODEP | Modo de operación principal del regulador Sercos. FBACKSRC | Tipo de captación. FBACKDIFF | Máxima diferencia entre captaciones. ULTRAIPO | Parámetro actualmente sin función. FBACKTIME | Constante de tiempo para la captación mixta."@es .

ns1:Parametro_DRIVEID a ns1:Parametro ;
    rdfs:label "DRIVEID"@es ;
    ns1:identificador "DRIVEID" ;
    ns1:textoExtracto "Dirección del regulador Sercos."@es .

ns1:Parametro_FBACKDIFF a ns1:Parametro ;
    rdfs:label "FBACKDIFF"@es ;
    ns1:identificador "FBACKDIFF" ;
    ns1:textoExtracto "Máxima diferencia entre captaciones."@es .

ns1:Parametro_FBACKSRC a ns1:Parametro ;
    rdfs:label "FBACKSRC"@es ;
    ns1:identificador "FBACKSRC" ;
    ns1:textoExtracto "Tipo de captación."@es .

ns1:Parametro_FBACKTIME a ns1:Parametro ;
    rdfs:label "FBACKTIME"@es ;
    ns1:identificador "FBACKTIME" ;
    ns1:textoExtracto "Constante de tiempo para la captación mixta."@es .

ns1:Parametro_OPMODEP a ns1:Parametro ;
    rdfs:label "OPMODEP"@es ;
    ns1:identificador "OPMODEP" ;
    ns1:textoExtracto "Modo de operación principal del regulador Sercos."@es .

ns1:Parametro_ULTRAIPO a ns1:Parametro ;
    rdfs:label "ULTRAIPO"@es ;
    ns1:identificador "ULTRAIPO" ;
    ns1:textoExtracto "Parámetro actualmente sin función."@es .

ns1:Sistema_Sercos a ns1:Sistema ;
    rdfs:label "Sistema de regulador Sercos"@es ;
    ns1:textoExtracto "Configurar un regulador Sercos"@es ;
    ns1:tieneComponente ns1:Parametro_DRIVEID,
        ns1:Parametro_FBACKDIFF,
        ns1:Parametro_FBACKSRC,
        ns1:Parametro_FBACKTIME,
        ns1:Parametro_OPMODEP,
        ns1:Parametro_ULTRAIPO .

