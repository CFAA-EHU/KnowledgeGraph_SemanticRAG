@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Manual_ReguladorSercos a ns1:Manual ;
    rdfs:label "Manual del regulador Sercos" ;
    ns1:textoExtracto "Consultar el manual del regulador para obtener más información."@es .

ns1:Parametro_DRIVEID a ns1:Parametro ;
    rdfs:label "DRIVEID" ;
    ns1:documentadoEn ns1:Tabla_SERCOSDATA ;
    ns1:identificador "DRIVEID" ;
    ns1:monitoreaParametro ns1:ReguladorSercos_Generico ;
    ns1:textoExtracto "DRIVEID Dirección del regulador Sercos. [...] Valor por defecto: 1."@es ;
    ns1:valor "1" .

ns1:Parametro_OPMODEP a ns1:Parametro ;
    rdfs:label "OPMODEP" ;
    ns1:documentadoEn ns1:Tabla_SERCOSDATA ;
    ns1:identificador "OPMODEP" ;
    ns1:monitoreaParametro ns1:ReguladorSercos_Generico ;
    ns1:textoExtracto "OPMODEP Modo de operación principal del regulador Sercos. [...] Valor por defecto: Posición."@es ;
    ns1:valor "Posición" .

ns1:ReguladorSercos_Generico a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos (genérico)" ;
    ns1:textoExtracto "Parámetro válido para regulador Sercos."@es ;
    ns1:tieneComponente ns1:Parametro_DRIVEID,
        ns1:Parametro_OPMODEP .

ns1:Tabla_SERCOSDATA a ns1:Tabla ;
    rdfs:label "Tabla SERCOSDATA" ;
    ns1:documentadoEn ns1:Manual_ReguladorSercos ;
    ns1:identificador "SERCOSDATA" ;
    ns1:textoExtracto "Parámetro incluido en la tabla SERCOSDATA."@es .

