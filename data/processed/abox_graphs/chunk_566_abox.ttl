@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacionSercosPosicion a ns1:ModoOperacion ;
    rdfs:label "Modo Sercos posición"@es ;
    ns1:controla ns1:ReguladorSercosPosicion ;
    ns1:textoExtracto "Modo de operación del regulador en Sercos posición."@es .

ns1:ModoOperacionSercosVelocidad a ns1:ModoOperacion ;
    rdfs:label "Modo Sercos velocidad"@es ;
    ns1:textoExtracto "(igual que en el modo Sercos velocidad)"@es .

ns1:ProcesoBusquedaCero a ns1:TareaMantenimiento ;
    rdfs:label "Búsqueda de cero"@es ;
    ns1:ejecutadoPor ns1:ReguladorSercosPosicion ;
    ns1:textoExtracto "el proceso de búsqueda de cero. [...] La búsqueda de cero la controla el regulador."@es .

ns1:SenalSANALOG a ns1:Parametro ;
    rdfs:label "Señal SANALOG (desde PLC)"@es ;
    ns1:textoExtracto "Cuando sea necesario utilizar la señal SANALOG desde PLC, su valor también vendrá expresado en diezmilésimas de milímetro o milésimas de grado."@es ;
    ns1:valor "0.0001 mm o 0.001°"@es .

ns1:FrecuenciaLazoPosicion a ns1:Frecuencia ;
    rdfs:label "Frecuencia de lazo de posición"@es ;
    ns1:textoExtracto "cierra el lazo de posición cada 256 microsegundos"@es ;
    ns1:valor "256 µs"@es .

ns1:ParametroCompensacionHolgura a ns1:Parametro ;
    rdfs:label "Compensación de holgura"@es ;
    ns1:textoExtracto "El error de seguimiento y la compensación de holgura se calculan en el CNC."@es .

ns1:ParametroConsignaPosicion a ns1:Parametro ;
    rdfs:label "Consigna de posición (cotas absolutas)"@es ;
    ns1:textoExtracto "La consigna se envía al regulador en cotas absolutas, en diezmilésimas de milímetro (ejes lineales) o milésimas de grado (ejes rotativos)."@es ;
    ns1:valor "0.0001 mm o 0.001°"@es .

ns1:ParametroErrorSeguimiento a ns1:Parametro ;
    rdfs:label "Error de seguimiento"@es ;
    ns1:textoExtracto "El error de seguimiento [...] se calculan en el CNC."@es .

ns1:ParametroFeedbackPosicion a ns1:Parametro ;
    rdfs:label "Feedback de posición (cota absoluta)"@es ;
    ns1:textoExtracto "El feedback del regulador al CNC llega como cota absoluta, en diezmilésimas de milímetro o milésimas de grado."@es ;
    ns1:valor "0.0001 mm o 0.001°"@es .

ns1:ReguladorSercosPosicion a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos en modo posición"@es ;
    ns1:monitoreaParametro ns1:ParametroCompensacionHolgura,
        ns1:ParametroConsignaPosicion,
        ns1:ParametroErrorSeguimiento,
        ns1:ParametroFeedbackPosicion ;
    ns1:textoExtracto "Modo de operación del regulador en Sercos posición. [...] El regulador suaviza la consigna mediante una interpolación cúbica y cierra el lazo de posición cada 256 microsegundos."@es ;
    ns1:tieneFrecuencia ns1:FrecuenciaLazoPosicion .

