@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Cabezal_306 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal"@es ;
    ns1:controla ns1:Motor_306 ;
    ns1:textoExtracto "Antes de comenzar la búsqueda de cero, el cabezal se detiene si previamente se encontraba girando."@es .

ns1:ReguladorSercos_306 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos"@es ;
    ns1:controla ns1:Motor_306 ;
    ns1:monitoreaParametro ns1:Parametro_FBACKSRC_306 ;
    ns1:textoExtracto "La búsqueda de cero la controla el regulador. [...] El feed forward y AC-Forward lo aplica el regulador. [...] Parámetro válido para regulador Sercos."@es .

ns1:Parametro_FBACKSRC_306 a ns1:Parametro ;
    rdfs:label "FBACKSRC (Tipo de captación)"@es ;
    ns1:documentadoEn ns1:Tabla_SERCOSDATA_306 ;
    ns1:identificador "FBACKSRC" ;
    ns1:textoExtracto "FBACKSRC Tipo de captación. Parámetro válido para ejes lineales, rotativos y cabezales. [...] Valores posibles: Interna / Externa / Interna + Externa. Valor por defecto: Interna. Variable asociada: (V.)[ch].MPA.FBACKSRC.xn"@es ;
    ns1:valor "Interna" .

ns1:Tabla_SERCOSDATA_306 a ns1:Tabla ;
    rdfs:label "Tabla SERCOSDATA"@es ;
    ns1:identificador "SERCOSDATA" ;
    ns1:textoExtracto "Parámetro incluido en la tabla SERCOSDATA."@es .

ns1:Motor_306 a ns1:ComponenteElectrico ;
    rdfs:label "Motor (captación interna)"@es ;
    ns1:textoExtracto "si se utiliza captación interna, el valor de la posición se toma de la captación motor"@es .

