@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "CNC" ;
    ns1:controla ns1:ModoOperacion_CaptacionExterna,
        ns1:ModoOperacion_CaptacionInternaExterna ;
    ns1:textoExtracto "el CNC permite habilitar la mezcla" .

ns1:ModoOperacion_CaptacionExterna a ns1:ModoOperacion ;
    rdfs:label "Captación externa" ;
    ns1:monitoreaParametro ns1:Parametro_FBACKDIFF ;
    ns1:textoExtracto "Cuando el tipo de captación es externa" .

ns1:ModoOperacion_CaptacionInternaExterna a ns1:ModoOperacion ;
    rdfs:label "Captación interna+externa" ;
    ns1:monitoreaParametro ns1:Parametro_FBACKDIFF,
        ns1:Parametro_FBACKSEL ;
    ns1:textoExtracto "Cuando el tipo de captación es interna+externa" .

ns1:Parametro_FBACKSEL a ns1:Parametro ;
    rdfs:label "FBACKSEL(axis)" ;
    ns1:identificador "FBACKSEL" ;
    ns1:textoExtracto "desde el PLC se puede conmutar entre ambas captaciones con la marca FBACKSEL(axis)" .

ns1:Parametro_FBACKDIFF a ns1:Parametro ;
    rdfs:label "FBACKDIFF" ;
    ns1:identificador "FBACKDIFF" ;
    ns1:textoExtracto "se recomienda definir el parámetro FBACKDIFF" .

