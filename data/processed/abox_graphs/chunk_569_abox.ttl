@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_FBACKDIFF a ns1:Parametro ;
    rdfs:label "FBACKDIFF" ;
    ns1:monitoreaParametro ns1:SistemaCaptacion ;
    ns1:textoExtracto "definir el parámetro FBACKDIFF. Cuando el tipo de captación es externa o interna+externa"@es .

ns1:Parametro_FBMIXTIME a ns1:Parametro ;
    rdfs:label "FBMIXTIME" ;
    ns1:monitoreaParametro ns1:SistemaCaptacion ;
    ns1:textoExtracto "el CNC permite habilitar la mezcla de captaciones; parámetro FBMIXTIME"@es .

ns1:ComponenteCaptacionExterna a ns1:Componente ;
    rdfs:label "Componente de captación externa"@es ;
    ns1:textoExtracto "captación externa"@es .

ns1:ComponenteCaptacionInterna a ns1:Componente ;
    rdfs:label "Componente de captación interna"@es ;
    ns1:textoExtracto "captación interna"@es .

ns1:SistemaCaptacion a ns1:Sistema ;
    rdfs:label "Sistema de captación (externa/interna)"@es ;
    ns1:textoExtracto "captación externa o interna+externa"@es ;
    ns1:tieneComponente ns1:ComponenteCaptacionExterna,
        ns1:ComponenteCaptacionInterna .

