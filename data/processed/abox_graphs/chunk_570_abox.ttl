@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_CambioViaPLC a ns1:ModoOperacion ;
    rdfs:label "Cambio de captación vía PLC"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionReguladorSercos_2.5.3 ;
    ns1:habilitadoPor ns1:Parametro_FBACKSEL ;
    ns1:textoExtracto "El tipo de captación se puede cambiar desde el PLC mediante la marca FBACKSEL(axis)."@es .

ns1:ModoOperacion_CaptacionExterna a ns1:ModoOperacion ;
    rdfs:label "Captación externa"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionReguladorSercos_2.5.3 ;
    ns1:habilitadoPor ns1:Parametro_FBACKSRC ;
    ns1:textoExtracto "Captación externa."@es .

ns1:ModoOperacion_CaptacionInterna a ns1:ModoOperacion ;
    rdfs:label "Captación interna"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionReguladorSercos_2.5.3 ;
    ns1:habilitadoPor ns1:Parametro_FBACKSRC ;
    ns1:textoExtracto "Captación interna."@es .

ns1:ModoOperacion_MezclaCaptaciones a ns1:ModoOperacion ;
    rdfs:label "Mezcla de captaciones"@es ;
    ns1:controla ns1:Parametro_FBMIXTIME ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionReguladorSercos_2.5.3 ;
    ns1:habilitadoPor ns1:Parametro_FBACKSRC ;
    ns1:textoExtracto "Está activa la mezcla de captaciones."@es .

ns1:Parametro_FBACKSEL a ns1:Parametro ;
    rdfs:label "FBACKSEL(axis)"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionReguladorSercos_2.5.3 ;
    ns1:identificador "FBACKSEL" ;
    ns1:textoExtracto "la marca FBACKSEL(axis). Captación interna o externa."@es .

ns1:Parametro_FBMIXTIME a ns1:Parametro ;
    rdfs:label "FBMIXTIME"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionReguladorSercos_2.5.3 ;
    ns1:identificador "FBMIXTIME" ;
    ns1:textoExtracto "FBMIXTIME [...] Valor mayor que ꞏ0ꞏ."@es .

ns1:Parametro_FBACKSRC a ns1:Parametro ;
    rdfs:label "FBACKSRC"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionReguladorSercos_2.5.3 ;
    ns1:identificador "FBACKSRC" ;
    ns1:textoExtracto "FBACKSRC [...] Tipo de captación."@es .

ns1:Tabla_ConfiguracionReguladorSercos_2.5.3 a ns1:Tabla ;
    rdfs:label "Tabla de configuración de regulador Sercos (FBACKSRC/FBMIXTIME)"@es ;
    ns1:textoExtracto """
| FBACKSRC      | FBMIXTIME         | Tipo de captación.         |
|---------------|-------------------|----------------------------|
| Interna       | (Sin función)     | Captación interna.         |
| Externa       | 0                 | Captación externa.         |
| Externa       | Valor mayor que 0 | Mezcla de captaciones.     |
| Interna+Externa | 0               | Cambio vía PLC (FBACKSEL). |
| Interna+Externa | Valor mayor que 0 | Cambio vía PLC (mezcla).   |
"""^^rdfs:Literal .

