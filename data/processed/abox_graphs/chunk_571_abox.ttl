@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_FBACKDIFF a ns1:Parametro ;
    rdfs:label "FBACKDIFF (Máxima diferencia entre captaciones)"@es ;
    ns1:documentadoEn ns1:Tabla_SERCOSDATA ;
    ns1:monitoreaParametro ns1:SistemaCaptacionDoble ;
    ns1:textoExtracto "FBACKDIFF Máxima diferencia entre captaciones. Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador Sercos posición. Valores posibles: Entre ±99999.9999 mm o grados / entre ±3937.00787 inch. Valor por defecto: 0 (no hay vigilancia). Variable asociada: (V.)[ch].MPA.FBACKDIFF.xn Parámetro incluido en la tabla SERCOSDATA."@es ;
    ns1:valor "0" .

ns1:Parametro_FBMIXTIME a ns1:Parametro ;
    rdfs:label "FBMIXTIME (Constante de tiempo para captación mixta)"@es ;
    ns1:documentadoEn ns1:Tabla_SERCOSDATA ;
    ns1:monitoreaParametro ns1:SistemaCaptacionDoble ;
    ns1:textoExtracto "FBMIXTIME Constante de tiempo para la captación mixta. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos. Valores posibles: De 0 a 3200.0 ms. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.FBMIXTIME.xn Parámetro incluido en la tabla SERCOSDATA."@es ;
    ns1:valor "0" .

ns1:Parametro_ULTRAIPO a ns1:Parametro ;
    rdfs:label "ULTRAIPO (Sin función)"@es ;
    ns1:documentadoEn ns1:Tabla_SERCOSDATA ;
    ns1:textoExtracto "ULTRAIPO (Sin función) Parámetro actualmente sin función."@es .

ns1:ReguladorSercos a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos"@es ;
    ns1:textoExtracto "el CNC utiliza la captación interna (captación motor) en el encendido, cuando se resetea el regulador y cuando se inicializa el anillo Sercos."@es ;
    ns1:tieneComponente ns1:ComponenteCaptacionInterna .

ns1:ComponenteCaptacionExterna a ns1:Sensor ;
    rdfs:label "Captación externa"@es ;
    ns1:textoExtracto "Los ejes tándem no admiten el tipo de captación interna+externa. En un eje tándem, ambos ejes pueden tener el mismo tipo de captación, externa o interna, pero lo habitual es que el eje maestro vaya con captación externa y el eje esclavo con captación interna."@es .

ns1:ComponenteCaptacionInterna a ns1:Sensor ;
    rdfs:label "Captación interna (captación motor)"@es ;
    ns1:textoExtracto "el CNC utiliza la captación interna (captación motor) en el encendido, cuando se resetea el regulador y cuando se inicializa el anillo Sercos."@es .

ns1:SistemaCaptacionDoble a ns1:Sistema ;
    rdfs:label "Sistema de doble captación (interna+externa)"@es ;
    ns1:textoExtracto "Cuando el sistema dispone de doble captación, este parámetro permite vigilar la diferencia entre ambas captaciones. Si la diferencia supera el valor definido, se muestra el error correspondiente."@es ;
    ns1:tieneComponente ns1:ComponenteCaptacionExterna,
        ns1:ComponenteCaptacionInterna .

ns1:Tabla_SERCOSDATA a ns1:Tabla ;
    rdfs:label "Tabla SERCOSDATA"@es ;
    ns1:textoExtracto "Parámetro incluido en la tabla SERCOSDATA."@es .

