@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_CaptacionExterna a ns1:ModoOperacion ;
    rdfs:label "Modo de captación externa"@es ;
    ns1:habilitadoPor ns1:Parametro_ConstanteTiempoCaptacion ;
    ns1:textoExtracto "cuando la captación es externa"@es .

ns1:ModoOperacion_CaptacionMixta a ns1:ModoOperacion ;
    rdfs:label "Modo de captación externa+interna"@es ;
    ns1:habilitadoPor ns1:Parametro_ConstanteTiempoCaptacion ;
    ns1:textoExtracto "cuando la captación es externa+interna"@es .

ns1:Componente_Encoder a ns1:Sensor ;
    rdfs:label "Encóder de posición"@es ;
    ns1:textoExtracto "lazo de posición del encóder"@es .

ns1:Componente_Regla a ns1:Sensor ;
    rdfs:label "Regla de posición"@es ;
    ns1:textoExtracto "lazo de posición [...] de la regla"@es .

ns1:Sistema_CaptacionPosicion a ns1:Sistema ;
    rdfs:label "Sistema de captación de posición (encóder + regla)"@es ;
    ns1:textoExtracto "lazo de posición del encóder y de la regla"@es ;
    ns1:tieneComponente ns1:Componente_Encoder,
        ns1:Componente_Regla .

ns1:Parametro_ConstanteTiempoCaptacion a ns1:Parametro ;
    rdfs:label "Constante de tiempo para mezcla de captaciones"@es ;
    ns1:monitoreaParametro ns1:Sistema_CaptacionPosicion ;
    ns1:textoExtracto "Este parámetro permite definir la constante de tiempo a utilizar en la mezcla de captaciones; es decir, determina el retraso entre las cotas que se introducen al lazo de posición del encóder y de la regla."@es ;
    ns1:valor "0"@es .

