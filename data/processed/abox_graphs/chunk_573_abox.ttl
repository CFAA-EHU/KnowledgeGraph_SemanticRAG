@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ReguladorSercos_V6.13 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos (versión mínima V6.13)"@es ;
    ns1:identificador "V6.13" ;
    ns1:monitoreaParametro ns1:Parametro_MezclaCaptaciones ;
    ns1:textoExtracto "Este parámetro requiere una versión de regulador V6.13 o superior."@es .

ns1:SistemaCaptacionHibrida a ns1:Sistema ;
    rdfs:label "Sistema de captación híbrida (interna + externa)"@es ;
    ns1:controla ns1:Maquina_AltaHolgura ;
    ns1:textoExtracto "Mezclando ambas captaciones se consigue el efecto deseado de precisión y suavidad."@es ;
    ns1:tieneComponente ns1:Parametro_MezclaCaptaciones .

ns1:Maquina_AltaHolgura a ns1:Maquina ;
    rdfs:label "Máquina con mucha holgura"@es ;
    ns1:textoExtracto "En máquinas con mucha holgura, en las que se utiliza captación externa para conseguir mayor precisión, es posible que se produzca cierta inestabilidad. Este tipo de máquinas, con captación interna va suave pero es posible que pierda precisión; con la captación externa en cambio, se aumenta la precisión pero la máquina puede ir más brusca."@es .

ns1:Parametro_MezclaCaptaciones a ns1:Parametro ;
    rdfs:label "Parámetro de mezcla de captaciones"@es ;
    ns1:textoExtracto "el parámetro se define con valor distinto de ꞏ0ꞏ, se habilita la mezcla de captaciones; si se define con valor ꞏ0ꞏ, sólo se utilizará la captación externa. Un cambio en este parámetro supondrá que la validación de parámetros fuerce la inicialización del anillo Sercos."@es ;
    ns1:valor "0 (solo externa) / ≠0 (mezcla)"@es .

