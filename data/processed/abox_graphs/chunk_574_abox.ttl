@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ParametroConsigna a ns1:Parametro ;
    rdfs:label "Consigna de regulación"@es ;
    ns1:monitoreaParametro ns1:SistemaCaptacionReguladorSercos ;
    ns1:textoExtracto "El CNC utiliza la mezcla de captaciones para el cálculo de la consigna"@es .

ns1:CaptacionExterna a ns1:Componente ;
    rdfs:label "Captación externa"@es ;
    ns1:textoExtracto "para el calculo de las compensaciones, test de circularidad, etc el CNC utiliza la captación externa (captación directa)."@es .

ns1:CaptacionInterna a ns1:Componente ;
    rdfs:label "Captación interna"@es ;
    ns1:textoExtracto "Mezclando ambas captaciones se consigue el efecto deseado de precisión y suavidad."@es .

ns1:SistemaCaptacionReguladorSercos a ns1:Sistema ;
    rdfs:label "Sistema de captación del regulador Sercos"@es ;
    ns1:compuestoPor ns1:CaptacionExterna,
        ns1:CaptacionInterna ;
    ns1:textoExtracto "Mezclando ambas captaciones se consigue el efecto deseado de precisión y suavidad."@es .

