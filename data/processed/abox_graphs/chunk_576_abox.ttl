@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_DRIVEID a ns1:Parametro ;
    rdfs:label "DRIVEID" ;
    ns1:documentadoEn ns1:Tabla_MLINKDATA ;
    ns1:textoExtracto "Dirección del regulador."@es .

ns1:Parametro_OPMODEP a ns1:Parametro ;
    rdfs:label "OPMODEP" ;
    ns1:documentadoEn ns1:Tabla_MLINKDATA ;
    ns1:textoExtracto "Modo de operación principal del regulador."@es ;
    ns1:tieneFrecuencia ns1:ModoOperacion_Principal .

ns1:Parametro_OPTION a ns1:Parametro ;
    rdfs:label "OPTION" ;
    ns1:documentadoEn ns1:Tabla_MLINKDATA ;
    ns1:textoExtracto "Activar las opciones del regulador."@es .

ns1:ModoOperacion_Principal a ns1:ModoOperacion ;
    ns1:textoExtracto "Modo de operación principal del regulador."@es .

ns1:Pagina_152 a ns1:Pagina ;
    ns1:identificador "152" ;
    ns1:textoExtracto "2.5.4 Configurar un regulador Mechatrolink"@es .

ns1:Tabla_MLINKDATA a ns1:Tabla ;
    rdfs:label "Tabla MLINKDATA"@es ;
    ns1:documentadoEn ns1:Pagina_152 ;
    ns1:textoExtracto """
    | MLINKDATA |
    | --- | --- |
    | DRIVEID | Dirección del regulador. |
    | OPMODEP | Modo de operación principal del regulador. |
    | OPTION | Activar las opciones del regulador.
    """@es .

