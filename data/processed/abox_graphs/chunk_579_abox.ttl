@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_Mechatrolink a ns1:Sistema ;
    rdfs:label "Regulador Mechatrolink"@es ;
    ns1:monitoreaParametro ns1:Parametro_MLINKDATA_OPTION ;
    ns1:textoExtracto "Parámetro válido para regulador Mechatrolink. [...] Este parámetro permite configurar diferentes opciones del regulador Mechatrolink, como activar filtros de aceleración o deceleración, activar la primera o segunda captación, elegir un control P o PI para el lazo de"@es ;
    ns1:tieneComponente ns1:Parametro_MLINKDATA_OPTION .

ns1:Tabla_MLINKDATA a ns1:Tabla ;
    rdfs:label "Tabla MLINKDATA (configuración Mechatrolink)"@es ;
    ns1:textoExtracto "Parámetro incluido en la tabla MLINKDATA."@es .

ns1:Parametro_MLINKDATA_OPTION a ns1:Parametro ;
    rdfs:label "Parámetro OPTION del regulador Mechatrolink"@es ;
    ns1:documentadoEn ns1:Tabla_MLINKDATA ;
    ns1:identificador "MPA.OPTION" ;
    ns1:textoExtracto "Parámetro válido para regulador Mechatrolink. Valores posibles: De $00000000 a $0000FFFF. Valor por defecto: $00000000. Variable asociada: (V.)[ch].MPA.OPTION.xn"@es ;
    ns1:valor "$00000000" .

