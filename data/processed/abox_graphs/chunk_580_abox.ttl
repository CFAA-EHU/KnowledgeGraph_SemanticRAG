@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ReguladorMechatrolink_319 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Mechatrolink" ;
    ns1:documentadoEn ns1:ManualReguladorMechatrolink_319 ;
    ns1:identificador "16 bits" ;
    ns1:textoExtracto "permite configurar diferentes opciones del regulador Mechatrolink, como activar filtros de aceleración o deceleración, activar la primera o segunda captación, elegir un control P o PI para el lazo de velocidad" .

ns1:ManualReguladorMechatrolink_319 a ns1:Manual ;
    rdfs:label "Manual del regulador Mechatrolink" ;
    ns1:textoExtracto "Consulte el manual de regulador para conocer el significado de cada bit" .

