@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_FGUIM a ns1:InterfazUsuario ;
    rdfs:label "FGUIM (Configuración de visualización)"@es ;
    ns1:textoExtracto "La visualización en pantalla de los decimales de un eje Hirth se configurará desde el FGUIM."@es .

ns1:Parametro_HPITCH a ns1:Parametro ;
    rdfs:label "HPITCH (Paso del eje Hirth)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosEjeHirth ;
    ns1:identificador "(V.)[ch].MPA.HPITCH.xn" ;
    ns1:monitoreaParametro ns1:Parametro_HIRTH ;
    ns1:textoExtracto "Paso del eje Hirth. Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0 a 99999.9999 mm. Valores posibles (2): De 0 a 3937.00787 inch. Valores posibles (3): De 0 a 99999.9999 grados. Valor por defecto: 1 mm / 0.03937 inch / 1 grado. Variable asociada: (V.)[ch].MPA.HPITCH.xn"@es ;
    ns1:valor "1 mm / 0.03937 inch / 1 grado" .

ns1:Parametro_HIRTH a ns1:Parametro ;
    rdfs:label "HIRTH (Eje con dentado Hirth)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosEjeHirth ;
    ns1:identificador "(V.)[ch].MPA.HIRTH.xn" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPA.HIRTH.xn Se denomina eje Hirth al que debe posicionarse siempre en posiciones múltiplos de un valor dado."@es ;
    ns1:valor "No" .

ns1:Tabla_ParametrosEjeHirth a ns1:Tabla ;
    rdfs:label "Tabla de parámetros del eje Hirth"@es ;
    ns1:textoExtracto "Las posiciones del conmutador para los movimientos en jog se pueden personalizar en la tabla de parámetros del eje, para que se correspondan con los pasos deseados."@es .

