@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_CAXIS a ns1:Parametro ;
    rdfs:label "CAXIS" ;
    ns1:identificador "CAXIS" ;
    ns1:textoExtracto "El eje rotativo debe tener su parámetro máquina CAXIS = Sí" ;
    ns1:valor "Sí / No" .

ns1:Parametro_FACEAXIS a ns1:Parametro ;
    rdfs:label "FACEAXIS" ;
    ns1:identificador "FACEAXIS" ;
    ns1:textoExtracto "FACEAXIS Eje transversal. Parámetro válido para ejes lineales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPA.FACEAXIS.xn" ;
    ns1:valor "Sí / No" .

ns1:Parametro_LONGAXIS a ns1:Parametro ;
    rdfs:label "LONGAXIS" ;
    ns1:identificador "LONGAXIS" ;
    ns1:textoExtracto "LONGAXIS Eje longitudinal. Parámetro válido para ejes lineales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPA.LONGAXIS.xn" ;
    ns1:valor "Sí / No" .

ns1:Tabla_PersonalizacionFresadoraConRotativos a ns1:Tabla ;
    rdfs:label "Personalización habitual en fresadora con ejes rotativos" ;
    ns1:documentadoEn ns1:Manual_ConfiguracionEjes ;
    ns1:textoExtracto "Personalización habitual en fresadora con ejes rotativos: En este tipo de máquina, para utilizar los ciclos asociados a los eje rotativos, es necesario indicar cuál es el eje longitudinal y el transversal. El eje rotativo debe tener su parámetro máquina CAXIS = Sí; el eje lineal asociado al eje rotativo debe tener su parámetro máquina LONGAXIS=Sí; el eje transversal debe tener su parámetro máquina FACEAXIS=Sí." .

ns1:Tabla_PersonalizacionFresadoraSinRotativos a ns1:Tabla ;
    rdfs:label "Personalización habitual en fresadora sin ejes rotativos" ;
    ns1:documentadoEn ns1:Manual_ConfiguracionEjes ;
    ns1:textoExtracto "Personalización habitual en fresadora sin ejes rotativos: En este tipo de máquina no es necesario indicar cuál es el eje longitudinal ni el transversal. | Todos los ejes. | FACEAXIS = No | LONGAXIS = No" .

ns1:Tabla_PersonalizacionTorno a ns1:Tabla ;
    rdfs:label "Personalización habitual en torno" ;
    ns1:documentadoEn ns1:Manual_ConfiguracionEjes ;
    ns1:textoExtracto "Personalización habitual en torno: En tornos hay indicar cuál es el eje longitudinal y el transversal. | Eje X. | FACEAXIS = Sí | LONGAXIS = No | Eje Z. | FACEAXIS = No | LONGAXIS = Sí | Resto de los ejes. | FACEAXIS = No | LONGAXIS = No" .

ns1:Manual_ConfiguracionEjes a ns1:Manual ;
    rdfs:label "Sección 2.5.6 Configuración de ejes en máquinas tipo torno" ;
    ns1:identificador "2.5.6" ;
    ns1:textoExtracto "FACEAXIS Eje transversal. [...] Personalización habitual en fresadora con ejes rotativos: [...]" .

