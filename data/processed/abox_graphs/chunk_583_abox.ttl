@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_ConfiguracionEjesTorno a ns1:Tabla ;
    rdfs:label "Personalización habitual en torno (eje rotativo A)" ;
    ns1:documentadoEn ns1:EjeLineal_X,
        ns1:EjeRotativo_A,
        ns1:EjeTransversal_Z ;
    ns1:textoExtracto "Personalización habitual en torno (si el eje rotativo es el A): | Eje A. | - - - | - - - | CAXIS=Sí | Eje X (eje lineal asociado al rotativo). | FACEAXIS = No | LONGAXIS = Sí | CAXIS=No | Eje Z. | FACEAXIS = Sí | LONGAXIS = No | CAXIS=No" .

ns1:EjeLineal_X a ns1:ComponenteMecanico ;
    rdfs:label "Eje X (lineal asociado al rotativo)" ;
    ns1:monitoreaParametro ns1:Parametro_LONGAXIS ;
    ns1:textoExtracto "Eje X (eje lineal asociado al rotativo). [...] LONGAXIS = Sí" .

ns1:EjeRotativo_A a ns1:ComponenteMecanico ;
    rdfs:label "Eje A (rotativo)" ;
    ns1:monitoreaParametro ns1:Parametro_CAXIS ;
    ns1:textoExtracto "Eje A. [...] CAXIS=Sí" .

ns1:EjeTransversal_Z a ns1:ComponenteMecanico ;
    rdfs:label "Eje Z (transversal)" ;
    ns1:monitoreaParametro ns1:Parametro_FACEAXIS ;
    ns1:textoExtracto "Eje Z. [...] FACEAXIS = Sí" .

ns1:Parametro_CAXIS a ns1:Parametro ;
    rdfs:label "CAXIS" ;
    ns1:textoExtracto "parámetro máquina CAXIS = Sí" ;
    ns1:valor "Sí" .

ns1:Parametro_FACEAXIS a ns1:Parametro ;
    rdfs:label "FACEAXIS" ;
    ns1:textoExtracto "parámetro máquina FACEAXIS=Sí" ;
    ns1:valor "Sí" .

ns1:Parametro_LONGAXIS a ns1:Parametro ;
    rdfs:label "LONGAXIS" ;
    ns1:textoExtracto "parámetro máquina LONGAXIS=Sí" ;
    ns1:valor "Sí" .

