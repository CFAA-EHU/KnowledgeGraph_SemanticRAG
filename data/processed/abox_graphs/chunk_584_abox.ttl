@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:EjeB a ns1:ModoOperacion ;
    ns1:textoExtracto "Eje B. - - - CAXIS=Sí" .

ns1:EjeC a ns1:ModoOperacion ;
    ns1:textoExtracto "Eje C. - - - CAXIS=Sí" .

ns1:EjeXY a ns1:ModoOperacion ;
    ns1:textoExtracto "Eje X o Y (sólo uno de los dos) FACEAXIS = Sí | LONGAXIS = No | CAXIS=No" .

ns1:EjeY a ns1:ModoOperacion ;
    ns1:textoExtracto "Eje Y (eje lineal asociado al rotativo). FACEAXIS = No | LONGAXIS = Sí | CAXIS=No" .

ns1:EjeZ a ns1:ModoOperacion ;
    ns1:textoExtracto "Eje Z. FACEAXIS = Sí | LONGAXIS = No | CAXIS=No" .

ns1:EjeZ_lineal_C a ns1:ModoOperacion ;
    ns1:textoExtracto "Eje Z (eje lineal asociado al rotativo). FACEAXIS = No | LONGAXIS = Sí | CAXIS=No" .

ns1:EsquemaModelizado a ns1:Esquema ;
    ns1:textoExtracto "archivo xca y parámetros FACEAXIS y LONGAXIS. En archivo *.def que acompaña al esquema modelizado de la máquina (archivo xca) define si los gráficos trabajan con cotas de la base o de la punta de la herramienta." .

ns1:ParametroCAXIS a ns1:Parametro ;
    ns1:textoExtracto "CAXIS" .

ns1:ParametroFACEAXIS a ns1:Parametro ;
    ns1:textoExtracto "FACEAXIS" .

ns1:ParametroFIXORI a ns1:Parametro ;
    ns1:textoExtracto "FIXORI" .

ns1:ParametroLONGAXIS a ns1:Parametro ;
    ns1:textoExtracto "LONGAXIS" .

ns1:Herramienta a ns1:Herramienta ;
    ns1:textoExtracto "para cada herramienta, el parámetro FIXORI define si la herramienta está orientada según los ejes definidos en FACEAXIS y LONGAXIS." .

