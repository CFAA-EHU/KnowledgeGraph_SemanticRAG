@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Herramienta_Generica a ns1:Herramienta ;
    ns1:monitoreaParametro ns1:Parametro_FACEAXIS,
        ns1:Parametro_FIXORI,
        ns1:Parametro_LONGAXIS ;
    ns1:textoExtracto "para cada herramienta, el parámetro FIXORI define si la herramienta está orientada según los ejes definidos en FACEAXIS y LONGAXIS" .

ns1:InterfazUsuario_GraficosHD a ns1:InterfazUsuario ;
    rdfs:label "Gráficos HD" ;
    ns1:monitoreaParametro ns1:Parametro_FACEAXIS,
        ns1:Parametro_LONGAXIS ;
    ns1:textoExtracto "Si los gráficos HD trabajan con las cotas de la punta de la herramienta, hacen caso a los parámetros FACEAXIS y LONGAXIS" .

ns1:Parametro_FIXORI a ns1:Parametro ;
    rdfs:label "FIXORI" ;
    ns1:textoExtracto "el parámetro FIXORI define si la herramienta está orientada según los ejes definidos en FACEAXIS y LONGAXIS" .

ns1:Parametro_FACEAXIS a ns1:Parametro ;
    rdfs:label "FACEAXIS" ;
    ns1:textoExtracto "los gráficos HD trabajan con las cotas de la punta de la herramienta, hacen caso a los parámetros FACEAXIS y LONGAXIS" .

ns1:Parametro_LONGAXIS a ns1:Parametro ;
    rdfs:label "LONGAXIS" ;
    ns1:textoExtracto "los gráficos HD trabajan con las cotas de la punta de la herramienta, hacen caso a los parámetros FACEAXIS y LONGAXIS" .

