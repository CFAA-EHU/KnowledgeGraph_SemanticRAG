@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaSincronizacionEjes a ns1:Sistema ;
    rdfs:label "Sistema de sincronización de ejes y cabezales" ;
    ns1:textoExtracto "SYNCSET Set de parámetros para la sincronización. [...] Cuando los cabezales se sincronizan en velocidad, el cabezal esclavo gira a la misma velocidad que el cabezal maestro (teniendo en cuenta el ratio)."@es ;
    ns1:tieneComponente ns1:Parametro_DSYNCVELW,
        ns1:Parametro_SYNCSET,
        ns1:Variable_V_MPA_DSYNCVELW_xn,
        ns1:Variable_V_MPA_SYNCSET_xn .

ns1:Parametro_DSYNCVELW a ns1:Parametro ;
    rdfs:label "DSYNCVELW" ;
    ns1:identificador "DSYNCVELW" ;
    ns1:textoExtracto "DSYNCVELW Ventana de sincronización en velocidad. Parámetro válido para ejes lineales, rotativos y cabezales. [...] Valor por defecto: 100 mm/min / 3.937 inch/min / 3600 grados/min / 10 rpm."@es ;
    ns1:valor "100 mm/min" .

ns1:Parametro_SYNCSET a ns1:Parametro ;
    rdfs:label "SYNCSET" ;
    ns1:identificador "SYNCSET" ;
    ns1:textoExtracto "SYNCSET Set de parámetros para la sincronización. Parámetro válido para ejes rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 4. Valor por defecto: 1."@es ;
    ns1:valor "1" .

ns1:Variable_V_MPA_DSYNCVELW_xn a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.DSYNCVELW.xn" ;
    ns1:identificador "V_MPA_DSYNCVELW_xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.DSYNCVELW.xn Este parámetro se define para el elemento esclavo de la sincronización e indica el margen de velocidad admisible dentro del cual se considera que la sincronización es correcta."@es .

ns1:Variable_V_MPA_SYNCSET_xn a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.SYNCSET.xn" ;
    ns1:identificador "V_MPA_SYNCSET_xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.SYNCSET.xn Set de parámetros que asume el eje o cabezal cuando está sincronizado."@es .

