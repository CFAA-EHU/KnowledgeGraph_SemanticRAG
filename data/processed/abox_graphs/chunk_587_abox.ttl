@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SenalSYNSPEED_326 a ns1:Sensor ;
    rdfs:label "Señal SYNSPEED"@es ;
    ns1:monitoreaParametro ns1:ParametroUmbralSYNSPEED_326 ;
    ns1:textoExtracto "la señal SYNSPEED se pone a nivel lógico bajo"@es .

ns1:ParametroUmbralSYNSPEED_326 a ns1:Parametro ;
    rdfs:label "Parámetro de umbral SYNSPEED"@es ;
    ns1:monitoreaParametro ns1:SincronizacionEjesCabezales_326 ;
    ns1:textoExtracto "Si se supera el valor definido en este parámetro, la señal SYNSPEED se pone a nivel lógico bajo"@es .

ns1:SincronizacionEjesCabezales_326 a ns1:ModoOperacion ;
    rdfs:label "Sincronización de ejes y cabezales"@es ;
    ns1:textoExtracto "Cuando los cabezales se sincronizan en velocidad, el cabezal esclavo gira a la misma velocidad que el cabezal maestro (teniendo en cuenta el ratio). [...] En la sincronización de ejes, el eje esclavo se mueve al mismo avance que el eje maestro (teniendo en cuenta el ratio)."@es .

