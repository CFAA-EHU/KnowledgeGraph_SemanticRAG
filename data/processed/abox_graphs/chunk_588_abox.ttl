@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaSincronizacionEjes a ns1:Sistema ;
    rdfs:label "Sistema de sincronización de ejes y cabezales"@es ;
    ns1:controla ns1:Marca_INSYNC,
        ns1:Marca_SYNCHRONP,
        ns1:Marca_SYNCPOSI ;
    ns1:textoExtracto "esclavo se mueve al mismo avance que el eje maestro (teniendo en cuenta el ratio). [...] En la sincronización de ejes, el eje esclavo sigue al maestro manteniendo el desfase programado (teniendo en cuenta el ratio)."@es ;
    ns1:tieneComponente ns1:Parametro_DSYNCPOSW .

ns1:Marca_INSYNC a ns1:InterfazUsuario ;
    rdfs:label "Marca INSYNC (PLC)"@es ;
    ns1:identificador "INSYNC" ;
    ns1:textoExtracto "Si la diferencia entre la velocidad de sincronización calculada para el eje esclavo y su velocidad real supera el valor definido en este parámetro, se desactiva la marca INSYNC del PLC."@es .

ns1:Marca_SYNCHRONP a ns1:InterfazUsuario ;
    rdfs:label "Marca SYNCHRONP (PLC)"@es ;
    ns1:identificador "SYNCHRONP" ;
    ns1:textoExtracto "se activará la marca SYNCHRONP del PLC para indicar que el cabezal se ha sincronizado en posición como esclavo."@es .

ns1:Marca_SYNCPOSI a ns1:InterfazUsuario ;
    rdfs:label "Marca SYNCPOSI (PLC)"@es ;
    ns1:identificador "SYNCPOSI" ;
    ns1:textoExtracto "Si se supera el valor definido en este parámetro, se desactiva la marca SYNCPOSI del PLC; no se detiene el movimiento ni se muestra ningún error."@es .

ns1:Parametro_DSYNCPOSW a ns1:Parametro ;
    rdfs:label "Ventana de sincronización en posición (DSYNCPOSW)"@es ;
    ns1:identificador "DSYNCPOSW" ;
    ns1:monitoreaParametro ns1:Variable_MPA_DSYNCPOSW_xn ;
    ns1:textoExtracto "DSYNCPOSW Ventana de sincronización en posición. Parámetro válido para ejes lineales, rotativos y cabezales. [...] Este parámetro se define para el elemento esclavo de la sincronización e indica el margen de posición admisible dentro del cual se considera que la sincronización es correcta."@es ;
    ns1:valor "0.0100 mm/min / 0.00039 inch/min / 0.0100 grados/min" .

ns1:Variable_MPA_DSYNCPOSW_xn a ns1:Parametro ;
    rdfs:label "Variable asociada a DSYNCPOSW (V.)[ch].MPA.DSYNCPOSW.xn"@es ;
    ns1:identificador "MPA.DSYNCPOSW.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.DSYNCPOSW.xn"@es .

