@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_Linearlike a ns1:ModoOperacion ;
    rdfs:label "Linearlike" ;
    ns1:textoExtracto "Valores posibles: Linearlike / Módulo." .

ns1:ModoOperacion_Modulo a ns1:ModoOperacion ;
    rdfs:label "Módulo" ;
    ns1:textoExtracto "Valores posibles: Linearlike / Módulo." .

ns1:Parametro_AXISMODE a ns1:Parametro ;
    rdfs:label "AXISMODE" ;
    ns1:monitoreaParametro ns1:Parametro_MODLOWLIM,
        ns1:Parametro_MODUPLIM,
        ns1:Parametro_SHORTESTWAY,
        ns1:Parametro_UNIDIR ;
    ns1:textoExtracto "AXISMODE Modo de trabajo del eje rotativo. Parámetro válido para ejes rotativos. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "Módulo" .

ns1:Parametro_MODLOWLIM a ns1:Parametro ;
    rdfs:label "MODLOWLIM" ;
    ns1:textoExtracto "Para ejes analógicos y simulados, el límite inferior MODLOWLIM debe ser menor que el límite superior MODUPLIM, como por ejemplo 0º a 360º, 0º a 400º ó -230 a 95; no se permite, por ejemplo -100º a -230º ó 360º a 0º." .

ns1:Parametro_MODUPLIM a ns1:Parametro ;
    rdfs:label "MODUPLIM" ;
    ns1:textoExtracto "Los límites de módulo (límites de recorrido del eje rotativo) vienen fijados por los parámetros de gama MODUPLIM y MODLOWLIM." .

ns1:Parametro_SHORTESTWAY a ns1:Parametro ;
    rdfs:label "SHORTESTWAY" ;
    ns1:textoExtracto "Hay que definir los parámetros SHORTESTWAY y UNIDIR." ;
    ns1:valor "No" .

ns1:Parametro_UNIDIR a ns1:Parametro ;
    rdfs:label "UNIDIR" ;
    ns1:textoExtracto "UNIDIR = No" ;
    ns1:valor "No" .

