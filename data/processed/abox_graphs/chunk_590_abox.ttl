@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_EjeRotativo_Linearlike a ns1:ModoOperacion ;
    rdfs:label "Modo de operación de eje rotativo (Linearlike)" ;
    ns1:monitoreaParametro ns1:Parametro_AXISMODE_Linearlike,
        ns1:Parametro_LIMIT ;
    ns1:textoExtracto "Comportamiento cuando AXISMODE = Linearlike. Actúa parecido a un eje lineal. Se pueden programar desplazamientos en G0/G1 y G90/G91. El contaje es libre y en grados (no le afecta mm/inch)."@es .

ns1:Parametro_MODLOWLIM a ns1:Parametro ;
    rdfs:label "MODLOWLIM" ;
    ns1:identificador "MODLOWLIM" ;
    ns1:textoExtracto "Los parámetros SHORTESTWAY, UNIDIR y los de gama MODUPLIM y MODLOWLIM no tienen significado."@es .

ns1:Parametro_MODUPLIM a ns1:Parametro ;
    rdfs:label "MODUPLIM" ;
    ns1:identificador "MODUPLIM" ;
    ns1:textoExtracto "Los parámetros SHORTESTWAY, UNIDIR y los de gama MODUPLIM y MODLOWLIM no tienen significado."@es .

ns1:Parametro_SHORTESTWAY a ns1:Parametro ;
    rdfs:label "SHORTESTWAY" ;
    ns1:identificador "SHORTESTWAY" ;
    ns1:textoExtracto "Los parámetros SHORTESTWAY, UNIDIR y los de gama MODUPLIM y MODLOWLIM no tienen significado."@es .

ns1:Parametro_UNIDIR a ns1:Parametro ;
    rdfs:label "UNIDIR" ;
    ns1:identificador "UNIDIR" ;
    ns1:textoExtracto "Los parámetros SHORTESTWAY, UNIDIR y los de gama MODUPLIM y MODLOWLIM no tienen significado. UNIDIR Sentido de giro único."@es ;
    ns1:valor "Sentido de giro único" .

ns1:Parametro_AXISMODE_Linearlike a ns1:Parametro ;
    rdfs:label "AXISMODE = Linearlike" ;
    ns1:identificador "AXISMODE=Linearlike" ;
    ns1:textoExtracto "Comportamiento cuando AXISMODE = Linearlike. Actúa parecido a un eje lineal."@es ;
    ns1:valor "Linearlike" .

ns1:Parametro_LIMIT a ns1:Parametro ;
    rdfs:label "LIMIT+",
        "LIMIT-" ;
    ns1:identificador "LIMIT+",
        "LIMIT-" ;
    ns1:textoExtracto "Los parámetros LIMIT+ y LIMIT- no tienen significado. [...] Hay límites de recorrido fijados por LIMIT+ y LIMIT-."@es .

