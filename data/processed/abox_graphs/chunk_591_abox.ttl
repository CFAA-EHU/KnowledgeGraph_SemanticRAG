@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_MODLOWLIM a ns1:Parametro ;
    rdfs:label "MODLOWLIM" ;
    ns1:textoExtracto "Los parámetros SHORTESTWAY, UNIDIR y los de gama MODUPLIM y MODLOWLIM no tienen significado." .

ns1:Parametro_MODUPLIM a ns1:Parametro ;
    rdfs:label "MODUPLIM" ;
    ns1:textoExtracto "Los parámetros SHORTESTWAY, UNIDIR y los de gama MODUPLIM y MODLOWLIM no tienen significado." .

ns1:Parametro_SHORTESTWAY a ns1:Parametro ;
    rdfs:label "SHORTESTWAY (Posicionamiento por camino más corto)" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "SHORTESTWAY Posicionamiento por el camino más corto. Parámetro válido para ejes rotativos. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPA.SHORTESTWAY.xn" ;
    ns1:valor "No" .

ns1:Parametro_UNIDIR a ns1:Parametro ;
    rdfs:label "UNIDIR (Sentido de giro único)" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "UNIDIR Sentido de giro único. Parámetro válido para ejes rotativos. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: No (ambos sentidos) / Positivo / Negativo. Valor por defecto: No (ambos sentidos). Variable asociada: (V.)[ch].MPA.UNIDIR.xn" ;
    ns1:valor "No (ambos sentidos)" .

ns1:Variable_V_MPA_SHORTESTWAY_xn a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.SHORTESTWAY.xn" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.SHORTESTWAY.xn" .

ns1:Variable_V_MPA_UNIDIR_xn a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.UNIDIR.xn" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.UNIDIR.xn" .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "CNC (Control Numérico Computarizado)" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro cuando AXISMODE = Módulo y SHORTESTWAY = No." .

