@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_SHORTESTWAY a ns1:Parametro ;
    rdfs:label "SHORTESTWAY" ;
    ns1:identificador "SHORTESTWAY" ;
    ns1:textoExtracto "Este parámetro indica si los desplazamientos en G90 de los ejes rotativos se realizan por el camino más corto. [...] SHORTESTWAY = Sí" ;
    ns1:valor "Sí" .

