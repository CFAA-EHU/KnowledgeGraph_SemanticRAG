@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_AXISMODE_Modulo a ns1:ModoOperacion ;
    rdfs:label "AXISMODE = Módulo" ;
    ns1:identificador "AXISMODE_Modulo" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro cuando AXISMODE = Módulo." .

ns1:Parametro_MODCOMP a ns1:Parametro ;
    rdfs:label "MODCOMP (Compensación de módulo)" ;
    ns1:identificador "MODCOMP" ;
    ns1:textoExtracto "MODCOMP Compensación de módulo. Parámetro válido para ejes rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No (sin compensación)." ;
    ns1:valor "Sí / No"@es .

ns1:Parametro_MODERR a ns1:Parametro ;
    rdfs:label "MODERR" ;
    ns1:identificador "MODERR" ;
    ns1:textoExtracto "Los parámetros de gama MODNROT y MODERR fijan la compensación que se debe aplicar para obtener un contaje exacto." .

ns1:Parametro_MODNROT a ns1:Parametro ;
    rdfs:label "MODNROT" ;
    ns1:identificador "MODNROT" ;
    ns1:textoExtracto "Los parámetros de gama MODNROT y MODERR fijan la compensación que se debe aplicar para obtener un contaje exacto." .

ns1:Variable_V_MPA_MODCOMP_xn a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.MODCOMP.xn" ;
    ns1:identificador "V_MPA_MODCOMP_xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.MODCOMP.xn" .

