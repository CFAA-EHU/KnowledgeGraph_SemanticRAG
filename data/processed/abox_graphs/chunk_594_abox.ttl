@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Variable_MPA_DMCSPDL_sn a ns1:Parametro ;
    rdfs:label "Variable asociada (V.)[ch].MPA.DMCSPDL.sn" ;
    ns1:identificador "(V.)[ch].MPA.DMCSPDL.sn" ;
    ns1:monitoreaParametro ns1:DMCSPDL ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.DMCSPDL.sn" .

ns1:DMCSPDL a ns1:Parametro ;
    rdfs:label "DMCSPDL" ;
    ns1:identificador "DMCSPDL" ;
    ns1:textoExtracto "DMCSPDL Cabezal con control de potencia habilitable. Valores posibles: Sí / No. Valor por defecto: No." ;
    ns1:valor "No" .

