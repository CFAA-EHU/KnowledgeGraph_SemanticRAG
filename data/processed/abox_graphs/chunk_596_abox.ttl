@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:param_AUTOGEAR a ns1:Parametro ;
    rdfs:label "AUTOGEAR" ;
    ns1:identificador "(V.)[ch].MPA.AUTOGEAR.xn" ;
    ns1:textoExtracto "AUTOGEAR Cambio de gama automático. Parámetro válido para cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No." ;
    ns1:valor "No" .

ns1:param_LOSPDLIM a ns1:Parametro ;
    rdfs:label "LOSPDLIM" ;
    ns1:identificador "(V.)[ch].MPA.LOSPDLIM.xn" ;
    ns1:textoExtracto "LOSPDLIM Porcentaje inferior de rpm OK. Parámetro válido para cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 255. Valor por defecto: 50." ;
    ns1:valor "50" .

ns1:param_UPSPDLIM a ns1:Parametro ;
    rdfs:label "UPSPDLIM" ;
    ns1:identificador "(V.)[ch].MPA.UPSPDLIM.xn" ;
    ns1:textoExtracto "UPSPDLIM Porcentaje superior de rpm OK. Parámetro válido para cabezales. Parámetro válido para regulador analógico, Sercos y simulado." .

