@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal"@es ;
    ns1:controla ns1:Parametro_SPDLSTOP ;
    ns1:textoExtracto "Las funciones M2, M30, un error o un reset paran el cabezal."@es .

ns1:ModoOperacion_EDISIMU a ns1:ModoOperacion ;
    rdfs:label "Modo EDISIMU"@es ;
    ns1:monitoreaParametro ns1:Parametro_SPDLTIME ;
    ns1:textoExtracto "En el modo de trabajo EDISIMU hay una opción que permite calcular el tiempo que se necesitará para ejecutar la pieza con las condiciones de mecanizado establecidas en el programa."@es .

ns1:Parametro_SPDLSTOP a ns1:Parametro ;
    rdfs:label "Parada de cabezal (SPDLSTOP)"@es ;
    ns1:textoExtracto "Las funciones M2, M30, un error o un reset paran el cabezal. Parámetro válido para"@es .

ns1:Parametro_SPDLTIME a ns1:Parametro ;
    rdfs:label "Tiempo estimado para función S (SPDLTIME)"@es ;
    ns1:identificador "(V.)[ch].MPA.SPDLTIME.xn" ;
    ns1:textoExtracto "De 0 a 1000000 ms. Valor por defecto: 0 ms. Variable asociada: (V.)[ch].MPA.SPDLTIME.xn [...] indica el tiempo estimado para el proceso de la función S."@es ;
    ns1:valor 0 .

