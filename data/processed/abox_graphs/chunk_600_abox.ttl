@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ControlCabezal a ns1:Sistema ;
    rdfs:label "Sistema de control de cabezal (M19/M3/M4)"@es ;
    ns1:monitoreaParametro ns1:Parametro_SPDLEREV_M19,
        ns1:Parametro_STEPOVR ;
    ns1:textoExtracto "La marca SPDLEREV siempre afecta a los cabezales en lazo abierto (M3/M4), independientemente de lo definido en este parámetro."@es ;
    ns1:tieneComponente ns1:Parametro_SPDLEREV_M19,
        ns1:Parametro_STEPOVR .

ns1:Parametro_SPDLEREV_M19 a ns1:Parametro ;
    rdfs:label "Parámetro SPDLEREV para M19"@es ;
    ns1:identificador "M19SPDLEREV" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.M19SPDLEREV.xn. Este parámetro define si la marca SPDLEREV del PLC (invertir el sentido de giro) también afecta a los cabezales en M19."@es ;
    ns1:valor "No" .

ns1:Parametro_STEPOVR a ns1:Parametro ;
    rdfs:label "Parámetro STEPOVR (Paso del override del cabezal)"@es ;
    ns1:identificador "STEPOVR" ;
    ns1:textoExtracto "STEPOVR Paso del override del cabezal. Parámetro válido para cabezales. Valores posibles: De 0 a 255. Valor por defecto: 5. Variable asociada: (V.)[ch].MPA.STEPOVR.xn"@es ;
    ns1:valor "5" .

