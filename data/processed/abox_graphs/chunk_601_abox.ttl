@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_MAXOVR a ns1:Parametro ;
    rdfs:label "Override máximo permitido (MAXOVR)" ;
    ns1:identificador "(V.)[ch].MPA.MAXOVR.xn" ;
    ns1:monitoreaParametro ns1:InterfazUsuario_PanelMando ;
    ns1:textoExtracto "Este parámetro establece el porcentaje máximo permitido a aplicar a la velocidad de giro del cabezal, cuando ésta se modifica desde el panel de mando (teclas o conmutador speed override)." ;
    ns1:valor "150" .

ns1:Parametro_MINOVR a ns1:Parametro ;
    rdfs:label "Override mínimo permitido (MINOVR)" ;
    ns1:identificador "(V.)[ch].MPA.MINOVR.xn" ;
    ns1:monitoreaParametro ns1:InterfazUsuario_PanelMando ;
    ns1:textoExtracto "Este parámetro establece el porcentaje mínimo permitido a aplicar a la velocidad de giro del cabezal, cuando ésta se modifica desde el panel de mando (teclas o conmutador speed override)." ;
    ns1:valor "50" .

ns1:Parametro_STEPOVR a ns1:Parametro ;
    rdfs:label "Paso incremental de speed override (STEPOVR)" ;
    ns1:identificador "(V.)[ch].MPA.STEPOVR.xn" ;
    ns1:monitoreaParametro ns1:InterfazUsuario_PanelMando ;
    ns1:textoExtracto "Este parámetro define el paso incremental para modificar la velocidad de giro programada, mediante las teclas de speed override del panel de mando." ;
    ns1:valor "5" .

ns1:Maquina_Cabezal a ns1:Maquina ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "Parámetro válido para cabezales. Este parámetro define el paso incremental para modificar la velocidad de giro programada del cabezal." .

ns1:InterfazUsuario_PanelMando a ns1:InterfazUsuario ;
    rdfs:label "Panel de mando (speed override)" ;
    ns1:controla ns1:Maquina_Cabezal ;
    ns1:textoExtracto "panel de mando. Parámetro sin función cuando el panel de mando dispone del conmutador speed override." .

