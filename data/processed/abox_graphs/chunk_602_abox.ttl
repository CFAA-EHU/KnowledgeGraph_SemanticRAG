@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_FFGAIN a ns1:Parametro ;
    rdfs:label "FFGAIN" ;
    ns1:identificador "FFGAIN" ;
    ns1:textoExtracto "El feed forward se define con el parámetro FFGAIN y se puede modificar desde el PLC mediante variables." ;
    ns1:valor "90-100%" .

ns1:Parametro_FFWTYPE a ns1:Parametro ;
    rdfs:label "FFWTYPE" ;
    ns1:identificador "FFWTYPE" ;
    ns1:textoExtracto "El CNC no permite modificar el override del cabezal durante un roscado si detecta que en alguna gama de los ejes implicados no está activo el feed forward (parámetro FFWTYPE)." .

ns1:Parametro_MAXOVR a ns1:Parametro ;
    rdfs:label "MAXOVR" ;
    ns1:identificador "MAXOVR" ;
    ns1:textoExtracto "Nunca se podrán superar los límites definidos mediante los parámetros máquina MINOVR y MAXOVR." .

ns1:Parametro_MINOVR a ns1:Parametro ;
    rdfs:label "MINOVR" ;
    ns1:identificador "MINOVR" ;
    ns1:textoExtracto "Nunca se podrán superar los límites definidos mediante los parámetros máquina MINOVR y MAXOVR." .

ns1:Parametro_THREADOVR a ns1:Parametro ;
    rdfs:label "THREADOVR" ;
    ns1:identificador "THREADOVR" ;
    ns1:monitoreaParametro ns1:Maquina_CNC ;
    ns1:textoExtracto "THREADOVR Variación máxima permitida para el override durante el roscado. Parámetro válido para cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 100%. Valor por defecto: 0 (no se permite variar el override)." ;
    ns1:valor "0-100%" .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de roscado" ;
    ns1:requiereMantenimiento ns1:TareaMantenimiento_AjusteOverride ;
    ns1:textoExtracto "Parámetro válido para cabezales. [...] El parámetro establece la máxima variación de override permitida para el cabezal, tanto para aumentarlo como para disminuirlo." .

ns1:Frecuencia_DuranteOperacion a ns1:Frecuencia ;
    rdfs:label "Durante operación de roscado" ;
    ns1:textoExtracto "modificar el override del cabezal durante el roscado electrónico (G33) y en los ciclos fijos de roscado del modelo ꞏTꞏ (G86, G87)." .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "El CNC no permite modificar el override del cabezal durante un roscado si detecta que en alguna gama de los ejes implicados no está activo el feed forward." ;
    ns1:tieneComponente ns1:Componente_Cabezal .

ns1:TareaMantenimiento_AjusteOverride a ns1:TareaMantenimiento ;
    rdfs:label "Ajuste de override en roscado" ;
    ns1:textoExtracto "Si se define este parámetro con un valor distinto de ꞏ0ꞏ se habilita la posibilidad de modificar el override del cabezal durante el roscado electrónico (G33) y en los ciclos fijos de roscado del modelo ꞏTꞏ (G86, G87 y sus equivalentes del editor de ciclos)." ;
    ns1:tieneFrecuencia ns1:Frecuencia_DuranteOperacion .

