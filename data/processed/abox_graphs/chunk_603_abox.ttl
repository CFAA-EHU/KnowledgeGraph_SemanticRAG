@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacionRoscadoG33 a ns1:ModoOperacion ;
    rdfs:label "Roscado electrónico G33"@es ;
    ns1:requiereMantenimiento ns1:CambioOverrideCabezalRoscado ;
    ns1:textoExtracto "Roscado electrónico G33"@es .

ns1:ParametroEntradaRosca a ns1:Parametro ;
    rdfs:label "Entrada de rosca"@es ;
    ns1:textoExtracto "el CNC respeta [...] la entrada de la rosca"@es .

ns1:ParametroOverrideCabezal a ns1:Parametro ;
    rdfs:label "Override del cabezal"@es ;
    ns1:monitoreaParametro ns1:CambioOverrideCabezalRoscado ;
    ns1:textoExtracto "el override activo al comenzar la pasada"@es .

ns1:ParametroPasoRosca a ns1:Parametro ;
    rdfs:label "Paso de rosca"@es ;
    ns1:textoExtracto "el CNC respeta el paso [...] de la rosca"@es .

ns1:CambioOverrideCabezalRoscado a ns1:TareaMantenimiento ;
    rdfs:label "Cambio del override del cabezal durante el roscado"@es ;
    ns1:identificador "2.5.13" ;
    ns1:textoExtracto "Los ciclos de roscado permiten modificar la velocidad del cabezal durante las pasadas de roscado, excepto en las que se realizan a la profundidad final de la rosca (una o dos pasadas finales), las cuales se realizan al override activo al comenzar la pasada."@es .

