@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_RoscadoElectronicoG33 a ns1:ModoOperacion ;
    rdfs:label "Roscado electrónico G33" ;
    ns1:requiereMantenimiento ns1:TareaMantenimiento_CambioOverrideCabezal ;
    ns1:textoExtracto "Roscado electrónico G33. Consideraciones relativas al cambio de override. [...] Si hay programados dos o más G33 para la misma rosca, todos los roscados deben comenzar a la misma velocidad." .

ns1:Parametro_OVRFILTER a ns1:Parametro ;
    rdfs:label "OVRFILTER" ;
    ns1:textoExtracto "OVRFILTER Tiempo para hacer efectivo el cambio de override. Parámetro válido para cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 1000000 ms." ;
    ns1:valor "0-1000000 ms" .

ns1:TareaMantenimiento_CambioOverrideCabezal a ns1:TareaMantenimiento ;
    rdfs:label "Cambio del override del cabezal durante el roscado" ;
    ns1:monitoreaParametro ns1:Parametro_OVRFILTER ;
    ns1:textoExtracto "Cambio del override del cabezal durante el roscado. [...] El CNC permite variar la velocidad del cabezal durante la pasada de roscado." .

