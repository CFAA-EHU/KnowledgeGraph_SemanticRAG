@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "CNC Control System" ;
    ns1:monitoreaParametro ns1:Parametro_OVRFILTER,
        ns1:Parametro_THREADOVR ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro con THREADOVR distinto de 0 (cero)." .

ns1:Parametro_OVRFILTER a ns1:Parametro ;
    rdfs:label "Override Filter Parameter" ;
    ns1:identificador "V.[ch].MPA.OVRFILTER.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.OVRFILTER.xn. Este parámetro actúa como filtro para hacer efectivo el cambio de override." ;
    ns1:valor 0 .

ns1:Parametro_THREADOVR a ns1:Parametro ;
    rdfs:label "Thread Override Parameter" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro con THREADOVR distinto de 0 (cero)." ;
    ns1:valor 0 .

