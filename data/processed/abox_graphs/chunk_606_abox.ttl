@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC (control numérico)" ;
    ns1:textoExtracto "En los ejes rotativos, el CNC sólo se tiene en cuenta este parámetro cuando AXISMODE = Linearlike. En los ejes lineales y rotativos, estos parámetros definen los límites de recorrido del eje." ;
    ns1:tieneComponente ns1:Parametro_LIMIT,
        ns1:Parametro_SWLIMITTOL .

ns1:Variable_V_MPA_NEGLIMIT_xn a ns1:Parametro ;
    rdfs:label "Variable asociada a LIMIT- ((V.)[ch].MPA.NEGLIMIT.xn)" ;
    ns1:identificador "(V.)[ch].MPA.NEGLIMIT.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.NEGLIMIT.xn" .

ns1:Variable_V_MPA_POSLIMIT_xn a ns1:Parametro ;
    rdfs:label "Variable asociada a LIMIT+ ((V.)[ch].MPA.POSLIMIT.xn)" ;
    ns1:identificador "(V.)[ch].MPA.POSLIMIT.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.POSLIMIT.xn" .

ns1:Parametro_LIMIT a ns1:Parametro ;
    rdfs:label "LIMIT+ (Límite de software positivo)",
        "LIMIT- (Límite de software negativo)" ;
    ns1:identificador "LIMIT+",
        "LIMIT-" ;
    ns1:textoExtracto "LIMIT+ Límite de software positivo. Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): Entre ±99999.9999 mm. Valores posibles (2): Entre ±3937.00787 inch. Valores posibles (3): Entre ±99999.9999 grados. Valor por defecto: 99999.9999 mm / 3937.00787 inch / 99999.9999 grados." ;
    ns1:valor "-99999.9999 mm / -3937.00787 inch / -99999.9999 grados",
        "99999.9999 mm / 3937.00787 inch / 99999.9999 grados" .

ns1:Parametro_SWLIMITTOL a ns1:Parametro ;
    rdfs:label "SWLIMITTOL (Tolerancia de los límites de software)" ;
    ns1:identificador "SWLIMITTOL" ;
    ns1:textoExtracto "SWLIMITTOL Tolerancia de los límites de software. Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): Entre ±99999.9999 mm. Valores posibles (2): Entre ±3937.00787 inch. Valores posibles (3): Entre ±99999.9999 grados. Valor por defecto: 0.1000 mm / 0.00394 inch / 0.1000 grados." ;
    ns1:valor "0.1000 mm / 0.00394 inch / 0.1000 grados" .

