@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Variable_ZONELIMITTOL a ns1:Parametro ;
    rdfs:label "Variable asociada a ZONELIMITTOL" ;
    ns1:identificador "(V.)[ch].MPA.ZONELIMITTOL.xn" ;
    ns1:monitoreaParametro ns1:ZONELIMITTOL ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.ZONELIMITTOL.xn. Distancia de seguridad que aplica el CNC al eje respecto el límite de la zona de trabajo." .

ns1:ZONELIMITTOL a ns1:Parametro ;
    rdfs:label "ZONELIMITTOL" ;
    ns1:identificador "ZONELIMITTOL" ;
    ns1:textoExtracto "ZONELIMITTOL Distancia de seguridad de los límites de las zonas de trabajo. Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "0.1000 mm / 0.00394 inch"^^xsd:string .

