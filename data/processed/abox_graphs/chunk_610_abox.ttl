@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_ZONELIMITTOL a ns1:Parametro ;
    rdfs:label "Distancia de seguridad de los límites de las zonas de trabajo"@es ;
    ns1:identificador "(V.)[ch].A.ZONELIMITTOL.xn" ;
    ns1:textoExtracto "La distancia de seguridad se puede modificar con la siguiente variable, que en el arranque tomará el valor de este parámetro. ( V.)[ch].A.ZONELIMITTOL.xn Distancia de seguridad de los límites de las zonas de trabajo."@es ;
    ns1:valor "Distancia de seguridad configurada"@es .

