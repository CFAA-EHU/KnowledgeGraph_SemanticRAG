@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ModoOperacion_EjeMuerto a ns1:ModoOperacion ;
    rdfs:label "Eje muerto (freno activo)"@es ;
    ns1:textoExtracto "cuando está quieto (freno activo) se dice que el eje está 'muerto'"@es .

ns1:ModoOperacion_EjeVivo a ns1:ModoOperacion ;
    rdfs:label "Eje vivo (desplazamiento)"@es ;
    ns1:textoExtracto "Cuando está gobernado por el CNC (desplazamientos) se dice que el eje está 'vivo'"@es .

ns1:Parametro_DWELL a ns1:Parametro ;
    rdfs:label "DWELL (Temporización para ejes muertos)"@es ;
    ns1:identificador "DWELL" ;
    ns1:monitoreaParametro ns1:Variable_V_MPA_DWELL_xn ;
    ns1:textoExtracto "DWELL Temporización para ejes muertos. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0 (no hay temporización). Variable asociada: (V.)[ch].MPA.DWELL.xn"@es ;
    ns1:valor 0 .

ns1:Variable_V_MPA_DWELL_xn a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.DWELL.xn" ;
    ns1:identificador "(V.)[ch].MPA.DWELL.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.DWELL.xn"@es .

