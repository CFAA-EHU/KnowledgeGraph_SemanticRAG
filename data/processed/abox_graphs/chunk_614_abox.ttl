@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_TemporizacionEjes a ns1:Sistema ;
    rdfs:label "Sistema de temporización para ejes muertos" ;
    ns1:compuestoPor ns1:Eje_Muerto,
        ns1:Eje_Tandem_Esclavo,
        ns1:Eje_Tandem_Maestro,
        ns1:Parametro_DWELL,
        ns1:Regulador_Servo,
        ns1:Senal_DEAD_axis,
        ns1:Senal_ENABLE,
        ns1:Senal_SERVOON ;
    ns1:documentadoEn ns1:Pagina_168 ;
    ns1:textoExtracto "ENABLE Velocity Command DWELL" .

ns1:Eje_Tandem_Esclavo a ns1:ComponenteMecanico ;
    rdfs:label "Eje tándem esclavo" ;
    ns1:textoExtracto "tanto el eje maestro como esclavo deben estar habilitados antes de poder moverse" .

ns1:Eje_Tandem_Maestro a ns1:ComponenteMecanico ;
    rdfs:label "Eje tándem maestro" ;
    ns1:monitoreaParametro ns1:Parametro_DWELL ;
    ns1:textoExtracto "En un eje tándem, tanto el eje maestro como esclavo deben estar habilitados antes de poder moverse" .

ns1:Regulador_Servo a ns1:ComponenteElectrico ;
    rdfs:label "Regulador servo" ;
    ns1:controla ns1:Senal_SERVOON ;
    ns1:textoExtracto "el regulador está listo" .

ns1:Senal_DEAD_axis a ns1:ComponenteElectrico ;
    rdfs:label "Señal DEAD(axis)" ;
    ns1:controla ns1:Eje_Muerto ;
    ns1:textoExtracto "será necesario habilitar el eje desde PLC como eje 'muerto' (señal DEAD(axis))" .

ns1:Senal_ENABLE a ns1:ComponenteElectrico ;
    rdfs:label "Señal ENABLE" ;
    ns1:textoExtracto "La señal ENABLE indica al PLC que permita el movimiento del eje" .

ns1:Eje_Muerto a ns1:ComponenteMecanico ;
    rdfs:label "Eje muerto" ;
    ns1:monitoreaParametro ns1:Parametro_DWELL ;
    ns1:textoExtracto "Si un eje va a trabajar como eje 'muerto' en un programa con empalme de trayectorias G5, G50 o HSC" .

ns1:Senal_SERVOON a ns1:ComponenteElectrico ;
    rdfs:label "Señal SERVOON" ;
    ns1:textoExtracto "la señal SERVOON que el regulador está listo" .

ns1:Parametro_DWELL a ns1:Parametro ;
    rdfs:label "Parámetro DWELL" ;
    ns1:textoExtracto "el CNC esperará el tiempo definido en el parámetro DWELL antes de comenzar el movimiento" .

