@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Funcion_G151 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G151 (Cambio a programación en radios/diámetros)"@es ;
    ns1:habilitadoPor ns1:SistemaCNC ;
    ns1:textoExtracto "Para cambiar el tipo de cotas desde el programa utilizar las funciones G151 ó G152."@es .

ns1:Funcion_G152 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función G152 (Cambio a programación en radios/diámetros)"@es ;
    ns1:habilitadoPor ns1:SistemaCNC ;
    ns1:textoExtracto "Para cambiar el tipo de cotas desde el programa utilizar las funciones G151 ó G152."@es .

ns1:Parametro_DIAMPROG a ns1:Parametro ;
    rdfs:label "DIAMPROG (Programación en diámetros)"@es ;
    ns1:monitoreaParametro ns1:SistemaCNC ;
    ns1:textoExtracto "DIAMPROG Programación en diámetros. Parámetro válido para ejes lineales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No."@es ;
    ns1:valor "No" .

ns1:Variable_MPA_DIAMPROG a ns1:Parametro ;
    rdfs:label "Variable asociada (V.)[ch].MPA.DIAMPROG.xn"@es ;
    ns1:monitoreaParametro ns1:SistemaCNC ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.DIAMPROG.xn"@es .

ns1:MaquinaTorno a ns1:Maquina ;
    rdfs:label "Máquina tipo torno"@es ;
    ns1:textoExtracto "En máquinas tipo torno, las cotas del eje transversal se pueden programar en radios o diámetros."@es .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:controla ns1:MaquinaTorno ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro cuando FACEAXIS = Sí. Los desplazamientos respecto al cero máquina (#MCS) siempre se realizan según este parámetro."@es .

