@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ComponenteMotor a ns1:ComponenteElectrico ;
    rdfs:label "Motor (eje Sercos)" ;
    ns1:monitoreaParametro ns1:Parametro_REFDIREC ;
    ns1:textoExtracto "el parámetro REFDIREC indica el sentido de giro del motor" .

ns1:ReguladorAnalogico a ns1:ComponenteElectrico ;
    rdfs:label "Regulador analógico" ;
    ns1:monitoreaParametro ns1:Parametro_REFDIREC ;
    ns1:textoExtracto "Parámetro válido para regulador analógico" .

ns1:SistemaCabezales a ns1:Sistema ;
    rdfs:label "Sistema de cabezales" ;
    ns1:textoExtracto "Parámetro válido para [...] cabezales" ;
    ns1:tieneComponente ns1:Parametro_REFDIREC .

ns1:SistemaEjesLineales a ns1:Sistema ;
    rdfs:label "Sistema de ejes lineales" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales" ;
    ns1:tieneComponente ns1:Parametro_REFDIREC .

ns1:SistemaEjesRotativos a ns1:Sistema ;
    rdfs:label "Sistema de ejes rotativos" ;
    ns1:textoExtracto "Parámetro válido para [...] cabezales" ;
    ns1:tieneComponente ns1:Parametro_REFDIREC .

ns1:SistemaSercos a ns1:Sistema ;
    rdfs:label "Sistema Sercos" ;
    ns1:textoExtracto "Parámetro válido para [...] Sercos" ;
    ns1:tieneComponente ns1:Parametro_REFDIREC .

ns1:SistemaSimulado a ns1:Sistema ;
    rdfs:label "Sistema simulado" ;
    ns1:textoExtracto "Parámetro válido para [...] simulado" ;
    ns1:tieneComponente ns1:Parametro_REFDIREC .

ns1:Variable_MPA_REFDIREC_xn a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.REFDIREC.xn" ;
    ns1:identificador "MPA.REFDIREC.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.REFDIREC.xn" .

ns1:Parametro_REFDIREC a ns1:Parametro ;
    rdfs:label "REFDIREC" ;
    ns1:identificador "REFDIREC" ;
    ns1:textoExtracto "REFDIREC Sentido de búsqueda de cero. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Negativo / Positivo. Valor por defecto: Positivo." ;
    ns1:valor "Positivo"^^xsd:string .

