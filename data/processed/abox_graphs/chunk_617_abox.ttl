@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteElectrico_Cabezal a ns1:ComponenteElectrico ;
    rdfs:label "Cabezal" ;
    ns1:controla ns1:Sistema_CNC ;
    ns1:textoExtracto "Si el cabezal está girando, el CNC respeta el sentido de giro del mismo para empezar la búsqueda de cero. Si el cabezal dispone de micro de I0 y está girando, el CNC detiene el giro e inicia la búsqueda de referencia en el sentido indicado por REFDIREC." .

ns1:Parametro_RefMode a ns1:Parametro ;
    rdfs:label "REFMODE" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "REFMODE Modo de búsqueda de cero. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos posición. Valores posibles: Regulador / CNC. Valor por defecto: CNC." ;
    ns1:valor "CNC" .

ns1:Variable_MPA_REFMODE a ns1:Parametro ;
    rdfs:label "Variable MPA.REFMODE.xn" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.REFMODE.xn" .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "el CNC respeta el sentido de giro del mismo para empezar la búsqueda de cero [...] el CNC detiene el giro e inicia la búsqueda de referencia en el sentido indicado por REFDIREC." .

