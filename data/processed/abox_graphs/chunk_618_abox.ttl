@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_CNC_BusquedaReferencia a ns1:ModoOperacion ;
    rdfs:label "Búsqueda de referencia (modo CNC)"@es ;
    ns1:documentadoEn ns1:Tabla_357_BusquedaReferencia ;
    ns1:identificador "Sercos velocidad" ;
    ns1:textoExtracto "El CNC realiza la búsqueda de referencia del eje como si éste fuera Sercos velocidad. El CNC ejecuta la homogeneización de parámetros como si el eje fuera Sercos velocidad."@es .

ns1:ModoOperacion_Regulador_BusquedaReferencia a ns1:ModoOperacion ;
    rdfs:label "Búsqueda de referencia (modo regulador)"@es ;
    ns1:documentadoEn ns1:Tabla_357_BusquedaReferencia ;
    ns1:identificador "Sercos posición" ;
    ns1:textoExtracto "El regulador realiza la búsqueda de referencia del eje como si éste fuera Sercos posición."@es .

ns1:Parametro_Homogeneizacion_CNC a ns1:Parametro ;
    rdfs:label "Homogeneización de parámetros (CNC)"@es ;
    ns1:documentadoEn ns1:Tabla_357_BusquedaReferencia ;
    ns1:textoExtracto "El CNC ejecuta la homogeneización de parámetros como si el eje fuera Sercos velocidad."@es .

ns1:Tabla_357_BusquedaReferencia a ns1:Tabla ;
    rdfs:label "Tabla de búsqueda de referencia (eje)"@es ;
    ns1:documentadoEn ns1:Pagina_170_171 ;
    ns1:textoExtracto "Regulador. | El regulador realiza la búsqueda de referencia del eje como si éste fuera Sercos posición."@es .

