@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteElectrico_MicroI0 a ns1:ComponenteElectrico ;
    rdfs:label "Micro de referencia (I0)" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_BusquedaReferencia ;
    ns1:textoExtracto "el eje busca el micro, invierte el sentido de búsqueda, y cuando deja de pulsar el micro empieza a buscar el I0" .

ns1:ComponenteElectrico_MicroSeguridad a ns1:ComponenteElectrico ;
    rdfs:label "Micro de seguridad (I0)" ;
    ns1:mitigaRiesgo ns1:ModoOperacion_BusquedaReferencia ;
    ns1:textoExtracto "Cuando hay micro de I0, el CNC no realiza la búsqueda de I0 sobre la marcha [...] el eje dispone de un micro de seguridad para que el eje no se salga de los límites de recorrido al hacer la búsqueda" .

ns1:ComponenteMecanico_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:monitoreaParametro ns1:Parametro_DECINPUT,
        ns1:Parametro_REFDIREC ;
    ns1:textoExtracto "El eje/cabezal dispone de micro para la búsqueda de referencia [...] En los cabezales con micro de I0, el cabezal pasa dos veces sobre el micro" .

ns1:ComponenteMecanico_EjeLineal a ns1:ComponenteMecanico ;
    rdfs:label "Eje lineal" ;
    ns1:monitoreaParametro ns1:Parametro_DECINPUT,
        ns1:Parametro_REFDIREC ;
    ns1:textoExtracto "Si el eje lineal dispone de I0 codificados [...] Si el eje lineal no dispone de I0 codificados" .

ns1:ComponenteMecanico_EjeRotativo a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo" ;
    ns1:monitoreaParametro ns1:Parametro_DECINPUT,
        ns1:Parametro_REFDIREC ;
    ns1:textoExtracto "Si el eje rotativo dispone de I0 codificados [...] El eje rotativo puede girar sin fin" .

ns1:Sistema_ReguladorAnalogico a ns1:Sistema ;
    rdfs:label "Regulador analógico" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico y Sercos" .

ns1:Sistema_ReguladorSercos a ns1:Sistema ;
    rdfs:label "Regulador Sercos" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico y Sercos" .

ns1:Variable_V_MPA_DECINPUT_xn a ns1:Parametro ;
    rdfs:label "Variable asociada (V.)[ch].MPA.DECINPUT.xn" ;
    ns1:documentadoEn ns1:ModoOperacion_BusquedaReferencia ;
    ns1:identificador "(V.)[ch].MPA.DECINPUT.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.DECINPUT.xn" .

ns1:Parametro_DECINPUT a ns1:Parametro ;
    rdfs:label "DECINPUT" ;
    ns1:documentadoEn ns1:ModoOperacion_BusquedaReferencia ;
    ns1:identificador "DECINPUT" ;
    ns1:textoExtracto "DECINPUT El eje/cabezal dispone de micro para la búsqueda de referencia. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)[ch].MPA.DECINPUT.xn" ;
    ns1:valor "Sí" .

ns1:Parametro_REFDIREC a ns1:Parametro ;
    rdfs:label "REFDIREC" ;
    ns1:documentadoEn ns1:ModoOperacion_BusquedaReferencia ;
    ns1:identificador "REFDIREC" ;
    ns1:textoExtracto "la búsqueda la realiza siempre en el sentido definido por el parámetro REFDIREC" .

ns1:ModoOperacion_BusquedaReferencia a ns1:ModoOperacion ;
    rdfs:label "Búsqueda de referencia" ;
    ns1:textoExtracto "El eje/cabezal dispone de micro para la búsqueda de referencia [...] El eje realiza la búsqueda de referencia mediante las marcas codificadas" .

