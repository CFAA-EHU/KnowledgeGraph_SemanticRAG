@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_CabezalConMicroIO a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal con micro de I/O" ;
    ns1:monitoreaParametro ns1:Parametro_DECINPUT,
        ns1:Parametro_REFFEED1 ;
    ns1:textoExtracto "En los cabezales con micro de I0, el cabezal pasa dos veces sobre el micro" .

ns1:Parametro_DECINPUT a ns1:Parametro ;
    rdfs:label "Parámetro DECINPUT" ;
    ns1:textoExtracto "el parámetro DECINPUT debe tener valor" ;
    ns1:valor "•" .

ns1:Parametro_REFFEED1 a ns1:Parametro ;
    rdfs:label "Parámetro REFFEED1" ;
    ns1:textoExtracto "La primera vuelta se da a la velocidad definida en REFFEED1" ;
    ns1:valor "velocidad_de_referencia_primera_vuelta" .

