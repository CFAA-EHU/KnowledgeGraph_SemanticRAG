@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "Parámetro válido para cabezales" .

ns1:Parametro_NPULSES a ns1:Parametro ;
    rdfs:label "NPULSES" ;
    ns1:textoExtracto "parámetros NPULSES y NPULSES2 se han definido con valor distinto de 0" ;
    ns1:valor "pulsos para referencia (debe ser ≠ 0)" .

ns1:Parametro_NPULSES2 a ns1:Parametro ;
    rdfs:label "NPULSES2" ;
    ns1:textoExtracto "parámetros NPULSES y NPULSES2 se han definido con valor distinto de 0" ;
    ns1:valor "pulsos secundarios para referencia (debe ser ≠ 0)" .

ns1:Parametro_REFFEED1 a ns1:Parametro ;
    rdfs:label "REFFEED1" ;
    ns1:textoExtracto "velocidad definida en REFFEED1" ;
    ns1:valor "velocidad de primera vuelta" .

ns1:Parametro_REFFEED2 a ns1:Parametro ;
    rdfs:label "REFFEED2" ;
    ns1:textoExtracto "velocidad definida en REFFEED2" ;
    ns1:valor "velocidad de búsqueda sobre micro" .

ns1:Parametro_REFINI a ns1:Parametro ;
    rdfs:label "REFINI" ;
    ns1:documentadoEn ns1:Paginas170171 ;
    ns1:identificador "REFINI" ;
    ns1:monitoreaParametro ns1:Variable_V_MPA_REFINI_xn ;
    ns1:textoExtracto "Búsqueda de cero en el primer movimiento. Parámetro válido para cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: Sí." ;
    ns1:valor "Sí/No" .

ns1:Sistema_ReguladorAnalogico a ns1:Sistema ;
    rdfs:label "Regulador analógico" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado" .

ns1:Sistema_Sercos a ns1:Sistema ;
    rdfs:label "Sercos" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado" .

ns1:Sistema_Simulado a ns1:Sistema ;
    rdfs:label "Sistema simulado" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado" .

ns1:Paginas170171 a ns1:Pagina ;
    rdfs:label "Páginas 170-171" ;
    ns1:textoExtracto "Sección 2.5.20 Búsqueda de referencia" .

ns1:Variable_V_MPA_REFINI_xn a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.REFINI.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.REFINI.xn" ;
    ns1:valor "variable de control de búsqueda de referencia" .

