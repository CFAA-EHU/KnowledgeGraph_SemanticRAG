@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ConfiguracionMovimientoPalpador a ns1:Sistema ;
    rdfs:label "Configuración del movimiento con palpador" ;
    ns1:textoExtracto "2.5.21 Configuración del movimiento con palpador. PROBEAXIS [...] PROBERANGE [...] PROBEFEED [...]" ;
    ns1:tieneComponente ns1:Parametro_PROBEAXIS,
        ns1:Parametro_PROBEFEED,
        ns1:Parametro_PROBERANGE .

ns1:Parametro_PROBEAXIS a ns1:Parametro ;
    rdfs:label "PROBEAXIS" ;
    ns1:identificador "PROBEAXIS" ;
    ns1:textoExtracto "PROBEAXIS [...] Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPA.PROBEAXIS.xn Este parámetro indica si el eje es participante en movimiento con palpador (G100)." ;
    ns1:valor "Sí/No" .

ns1:Parametro_PROBEFEED a ns1:Parametro ;
    rdfs:label "PROBEFEED" ;
    ns1:identificador "PROBEFEED" ;
    ns1:textoExtracto "PROBEFEED [...] Avance máximo de palpado. [...] Valores posibles (1): De 0 a 36000000.0000 mm/min. [...] Valor por defecto: 0. [...] El valor de este parámetro debe ser inferior que el avance necesario para frenar en el espacio definido en PROBERANGE con los valores de aceleración y de jerk del eje." ;
    ns1:valor "0 mm/min (defecto)" .

ns1:Parametro_PROBERANGE a ns1:Parametro ;
    rdfs:label "PROBERANGE" ;
    ns1:identificador "PROBERANGE" ;
    ns1:textoExtracto "PROBERANGE [...] Distancia máxima de frenado. [...] Valores posibles (1): De 0 a 99999.9999 mm. [...] Valor por defecto: 1.0000 mm / 0.03937 inch / 1.0000 grado. [...] Este parámetro fija la máxima distancia de frenado del palpador tras realizar la palpación, evitando de esta forma la rotura del mismo (cerámicos, etc)." ;
    ns1:valor "1.0000 mm (defecto)" .

