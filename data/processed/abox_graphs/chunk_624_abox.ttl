@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PRBDI1 a ns1:Parametro ;
    rdfs:label "PRBDI1" ;
    ns1:identificador "PRBDI1" ;
    ns1:textoExtracto "El parámetro PROBEDELAY corresponde al palpador definido en PRBDI1" .

ns1:PRBDI2 a ns1:Parametro ;
    rdfs:label "PRBDI2" ;
    ns1:identificador "PRBDI2" ;
    ns1:textoExtracto "PROBEDELAY2 al palpador definido en PRBDI2." .

ns1:PROBEDELAY a ns1:Parametro ;
    rdfs:label "PROBEDELAY" ;
    ns1:identificador "PROBEDELAY" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Entre ±100000.0000 ms. Valor por defecto: 0 (no hay retardo). Variable asociada: (V.)[ch].MPA.PROBEDELAY.xn Consultar el parámetro máquina de ejes PROBEDELAY2. PROBEDELAY2 Retardo de la señal de palpador 2." ;
    ns1:valor "Entre ±100000.0000 ms" .

ns1:PROBEDELAY2 a ns1:Parametro ;
    rdfs:label "PROBEDELAY2" ;
    ns1:identificador "PROBEDELAY2" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Entre ±100000.0000 ms. Valor por defecto: 0 (no hay retardo). Variable asociada: (V.)[ch].MPA.PROBEDELAY2.xn El parámetro PROBEDELAY corresponde al palpador definido en PRBDI1 y PROBEDELAY2 al palpador definido en PRBDI2." ;
    ns1:valor "Entre ±100000.0000 ms" .

ns1:Palpador1_900c4c264a a ns1:Sensor ;
    rdfs:label "Palpador 1" ;
    ns1:identificador "PRBDI1" ;
    ns1:textoExtracto "El parámetro PROBEDELAY corresponde al palpador definido en PRBDI1" .

ns1:Palpador2_2d9fa4e702 a ns1:Sensor ;
    rdfs:label "Palpador 2" ;
    ns1:identificador "PRBDI2" ;
    ns1:textoExtracto "PROBEDELAY2 al palpador definido en PRBDI2." .

