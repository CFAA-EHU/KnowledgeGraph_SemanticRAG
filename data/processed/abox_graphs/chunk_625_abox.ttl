@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CicloCalibracion_PROBE2 a ns1:TareaMantenimiento ;
    rdfs:label "Ciclo de calibración de palpador #PROBE 2"@es ;
    ns1:identificador "PROBE 2" ;
    ns1:monitoreaParametro ns1:Parametro_P299 ;
    ns1:solucionaFallo ns1:Parametro_PROBEDELAY ;
    ns1:textoExtracto "el ciclo de calibración de palpador #PROBE 2. Tras su ejecución, el ciclo devuelve en el parámetro aritmético P299 el valor óptimo"@es .

ns1:SistemaControlCNC a ns1:Sistema ;
    rdfs:label "Sistema de control CNC (recepción de señal de palpación)"@es ;
    ns1:controla ns1:SensorPalpador ;
    ns1:textoExtracto "el CNC recibe la señal (comunicación por infrarrojos, etc)"@es .

ns1:Parametro_P299 a ns1:Parametro ;
    rdfs:label "Parámetro aritmético P299"@es ;
    ns1:identificador "P299" ;
    ns1:textoExtracto "el ciclo devuelve en el parámetro aritmético P299 el valor óptimo"@es .

ns1:SensorPalpador a ns1:Sensor ;
    rdfs:label "Sonda de proximidad para control del gap (palpador láser)"@es ;
    ns1:monitoreaParametro ns1:Parametro_PROBEDELAY ;
    ns1:textoExtracto "En el modelo láser, si la sonda de proximidad para el control del gap tiene un retardo"@es .

ns1:Parametro_PROBEDELAY a ns1:Parametro ;
    rdfs:label "Parámetro PROBEDELAY"@es ;
    ns1:identificador "PROBEDELAY" ;
    ns1:textoExtracto "el parámetro PROBEDELAY de los ejes y el cabezal"@es .

