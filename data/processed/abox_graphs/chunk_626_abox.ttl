@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ModoOperacion_JogContinuo a ns1:ModoOperacion ;
    rdfs:label "Modo jog continuo" ;
    ns1:textoExtracto "avance definido para el modo jog continuo (parámetro JOGFEED)." .

ns1:Parametro_G00FEED a ns1:Parametro ;
    rdfs:label "G00FEED" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "El valor del parámetro REPOSFEED deberá ser siempre menor que G00FEED, MAXMANFEED y JOGRAPFEED." .

ns1:Parametro_JOGFEED a ns1:Parametro ;
    rdfs:label "JOGFEED" ;
    ns1:identificador "JOGFEED" ;
    ns1:textoExtracto "avance definido para el modo jog continuo (parámetro JOGFEED)." .

ns1:Parametro_JOGRAPFEED a ns1:Parametro ;
    rdfs:label "JOGRAPFEED" ;
    ns1:identificador "JOGRAPFEED" ;
    ns1:textoExtracto "El valor del parámetro REPOSFEED deberá ser siempre menor que G00FEED, MAXMANFEED y JOGRAPFEED." .

ns1:Parametro_MAXMANFEED a ns1:Parametro ;
    rdfs:label "MAXMANFEED" ;
    ns1:identificador "MAXMANFEED" ;
    ns1:textoExtracto "El valor del parámetro REPOSFEED deberá ser siempre menor que G00FEED, MAXMANFEED y JOGRAPFEED." .

ns1:Parametro_REPOSFEED a ns1:Parametro ;
    rdfs:label "REPOSFEED" ;
    ns1:identificador "REPOSFEED" ;
    ns1:textoExtracto "REPOSFEED Avance máximo de reposicionamiento. Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "0"^^xsd:string .

ns1:Variable_V_MPA_REPOSFEED_xn a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.REPOSFEED.xn" ;
    ns1:identificador "(V.)[ch].MPA.REPOSFEED.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.REPOSFEED.xn" .

