@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Marca_PLC_FLIMITAC a ns1:Actuador ;
    rdfs:label "FLIMITAC" ;
    ns1:controla ns1:Parametro_FLIMIT ;
    ns1:identificador "FLIMITAC" ;
    ns1:textoExtracto "El valor definido se activa desde el PLC (marcas FLIMITAC o FLIMITACCHC1)" .

ns1:Marca_PLC_FLIMITACCHC1 a ns1:Actuador ;
    rdfs:label "FLIMITACCHC1" ;
    ns1:controla ns1:Parametro_FLIMIT ;
    ns1:identificador "FLIMITACCHC1" ;
    ns1:textoExtracto "El valor definido se activa desde el PLC (marcas FLIMITAC o FLIMITACCHC1)" .

ns1:Parametro_SLIMIT a ns1:Parametro ;
    rdfs:label "SLIMIT" ;
    ns1:identificador "SLIMIT" ;
    ns1:monitoreaParametro ns1:Maquina_CNC ;
    ns1:textoExtracto "SLIMIT Límite máximo de seguridad para la velocidad del cabezal. Parámetro válido para cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "0 a 200000.0000 rpm" .

ns1:Variable_V_MPA_FLIMIT_xn a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.FLIMIT.xn" ;
    ns1:identificador "(V.)[ch].MPA.FLIMIT.xn" ;
    ns1:monitoreaParametro ns1:Maquina_CNC ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.FLIMIT.xn" .

ns1:Variable_V_PLC_G00FEED a ns1:Parametro ;
    rdfs:label "(V.)PLC.G00FEED" ;
    ns1:identificador "(V.)PLC.G00FEED" ;
    ns1:monitoreaParametro ns1:Maquina_CNC ;
    ns1:textoExtracto "Cuando hay un avance máximo fijado por PLC (variable (V.)PLC.G00FEED), el CNC aplica el avance más restrictivo." .

ns1:Parametro_FLIMIT a ns1:Parametro ;
    rdfs:label "FLIMIT" ;
    ns1:identificador "FLIMIT" ;
    ns1:monitoreaParametro ns1:Maquina_CNC ;
    ns1:textoExtracto "FLIMIT Límite máximo de seguridad para el avance del eje. Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "0 a 500000.0000 mm/min / 0 a 19685.03937 inch/min / 0 a 72000000.0000 grados/min" .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "El CNC aplica el límite máximo de seguridad para el avance del eje en el bloque en ejecución." .

