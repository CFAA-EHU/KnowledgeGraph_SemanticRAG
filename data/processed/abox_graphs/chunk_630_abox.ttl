@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_G192 a ns1:Parametro ;
    rdfs:label "Velocidad máxima de giro para mecanizado (función G192)"@es ;
    ns1:identificador "G192" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "También es posible fijar una velocidad máxima de giro para el mecanizado, por programa (función G192) o por PLC (variable (V.)PLC.SL.sn)."@es .

ns1:Parametro_PLCCNTL a ns1:Parametro ;
    rdfs:label "Control de cabezal por PLC (marca PLCCNTL)"@es ;
    ns1:controla ns1:Componente_CabezalMecanizado ;
    ns1:identificador "PLCCNTL" ;
    ns1:textoExtracto "El límite de seguridad también se aplica a los cabezales controlados por PLC (marca PLCCNTL), excepto cuando el cabezal es digital controlado en posición."@es .

ns1:Parametro_SLIMITAC a ns1:Parametro ;
    rdfs:label "Límite de seguridad para avance/velocidad (marca SLIMITAC)"@es ;
    ns1:identificador "SLIMITAC" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "desde el PLC (marcas SLIMITAC o SLIMITACSPDL) y el CNC lo aplica en el bloque en ejecución. Al desactivar los límites, el CNC recupera la velocidad programada. Si el parámetro se define con valor ꞏ0ꞏ, no se limita la velocidad."@es .

ns1:Parametro_SLIMITACSPDL a ns1:Parametro ;
    rdfs:label "Límite de seguridad para velocidad (marca SLIMITACSPDL)"@es ;
    ns1:identificador "SLIMITACSPDL" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "desde el PLC (marcas SLIMITAC o SLIMITACSPDL) y el CNC lo aplica en el bloque en ejecución."@es .

ns1:Parametro_VPLC_SL_sn a ns1:Parametro ;
    rdfs:label "Velocidad máxima de mecanizado por PLC (variable V.PLC.SL.sn)"@es ;
    ns1:identificador "V.PLC.SL.sn" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "También es posible fijar una velocidad máxima de giro para el mecanizado, por programa (función G192) o por PLC (variable (V.)PLC.SL.sn)."@es .

ns1:Componente_CabezalMecanizado a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de mecanizado"@es ;
    ns1:textoExtracto "El límite de seguridad también se aplica a los cabezales controlados por PLC (marca PLCCNTL), excepto cuando el cabezal es digital controlado en posición."@es .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:controla ns1:Componente_CabezalMecanizado ;
    ns1:textoExtracto "el CNC lo aplica en el bloque en ejecución. [...] el CNC aplica el límite de velocidad más restrictivo; el fijado para el mecanizado o el de seguridad."@es .

