@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_LimiteSeguridadVelocidad a ns1:Parametro ;
    rdfs:label "Límite de seguridad para la velocidad"@es ;
    ns1:documentadoEn ns1:Tabla_LimitesVelocidadSeguridad ;
    ns1:textoExtracto "Límite de seguridad para la velocidad"@es ;
    ns1:valor "0, 50, 150" .

ns1:Parametro_LimiteVelocidadActivo a ns1:Parametro ;
    rdfs:label "Límite de velocidad activo"@es ;
    ns1:documentadoEn ns1:Tabla_LimitesVelocidadSeguridad ;
    ns1:textoExtracto "Límite de velocidad activo"@es ;
    ns1:valor "50, 100" .

ns1:Parametro_LimiteVelocidadMecanizado a ns1:Parametro ;
    rdfs:label "Límite para la velocidad de mecanizado"@es ;
    ns1:documentadoEn ns1:Tabla_LimitesVelocidadSeguridad ;
    ns1:textoExtracto "Límite para la velocidad de mecanizado"@es ;
    ns1:valor "0, 100" .

ns1:Pagina_175 a ns1:Pagina ;
    ns1:identificador "175" ;
    ns1:textoExtracto "Sección 2.5.24 Configurar el límite máximo de seguridad para el avance y la velocidad"@es .

ns1:Tabla_LimitesVelocidadSeguridad a ns1:Tabla ;
    rdfs:label "Tabla de límites de seguridad para velocidad y avance"@es ;
    ns1:documentadoEn ns1:Pagina_175 ;
    ns1:textoExtracto """
| Límite de seguridad para la velocidad. | Límite para la velocidad de mecanizado. | Límite de velocidad activo. |
| --- | --- | --- |
| 0 | 100 | 100 |
| 50 | 0 | 50 |
| 50 | 100 | 50 |
| 150 | 100 | 100
"""@es .

