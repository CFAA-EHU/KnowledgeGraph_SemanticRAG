@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal"@es ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. En los cabezales, estos parámetros sólo se aplicarán cuando el cabezal se interpole con ejes durante el roscado rígido o cuando el cabezal trabaje como eje C."@es ;
    ns1:tieneComponente ns1:ModoOperacion_Manual .

ns1:Parametro_DesplazamientoManual a ns1:Parametro ;
    rdfs:label "Parámetro de desplazamiento en modo manual"@es ;
    ns1:documentadoEn ns1:TablaParametrosModoManual ;
    ns1:monitoreaParametro ns1:ModoOperacion_Manual ;
    ns1:textoExtracto "Este parámetro muestra la tabla de parámetros para definir los desplazamientos en modo manual."@es .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo de trabajo manual"@es ;
    ns1:detalladoEnEsquema ns1:TablaParametrosModoManual ;
    ns1:textoExtracto "Modo de trabajo manual. Este parámetro muestra la tabla de parámetros para definir los desplazamientos en modo manual."@es .

ns1:TablaParametrosModoManual a ns1:Tabla ;
    rdfs:label "Tabla de parámetros del modo manual"@es ;
    ns1:documentadoEn ns1:Manual_Seccion2_5_25 ;
    ns1:textoExtracto "Tabla de parámetros del modo manual. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado."@es .

