@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo de trabajo manual" ;
    ns1:textoExtracto "2.5.25 Modo de trabajo manual"@es ;
    ns1:tieneComponente ns1:Parametro_INCJOGDIST,
        ns1:Parametro_INCJOGFEED,
        ns1:Parametro_IPOACCP,
        ns1:Parametro_IPOFEEDP,
        ns1:Parametro_JOGFEED,
        ns1:Parametro_JOGRAPFEED,
        ns1:Parametro_MANACCP,
        ns1:Parametro_MANFEEDP,
        ns1:Parametro_MANNEGSW,
        ns1:Parametro_MANPOSSW,
        ns1:Parametro_MAXMANACC,
        ns1:Parametro_MAXMANFEED,
        ns1:Parametro_MPGFILTER,
        ns1:Parametro_MPGRESOL .

ns1:Parametro_INCJOGDIST a ns1:Parametro ;
    rdfs:label "INCJOGDIST" ;
    ns1:identificador "INCJOGDIST" ;
    ns1:textoExtracto "Distancia a recorrer en jog incremental."@es .

ns1:Parametro_INCJOGFEED a ns1:Parametro ;
    rdfs:label "INCJOGFEED" ;
    ns1:identificador "INCJOGFEED" ;
    ns1:textoExtracto "Avance en jog incremental."@es .

ns1:Parametro_IPOACCP a ns1:Parametro ;
    rdfs:label "IPOACCP" ;
    ns1:identificador "IPOACCP" ;
    ns1:textoExtracto "Máximo porcentaje de aceleración de ejecución en G201."@es .

ns1:Parametro_IPOFEEDP a ns1:Parametro ;
    rdfs:label "IPOFEEDP" ;
    ns1:identificador "IPOFEEDP" ;
    ns1:textoExtracto "Máximo porcentaje de avance de ejecución en G201."@es .

ns1:Parametro_JOGFEED a ns1:Parametro ;
    rdfs:label "JOGFEED" ;
    ns1:identificador "JOGFEED" ;
    ns1:textoExtracto "Avance en modo jog continuo."@es .

ns1:Parametro_JOGRAPFEED a ns1:Parametro ;
    rdfs:label "JOGRAPFEED" ;
    ns1:identificador "JOGRAPFEED" ;
    ns1:textoExtracto "Avance rápido en modo jog continuo."@es .

ns1:Parametro_MANACCP a ns1:Parametro ;
    rdfs:label "MANACCP" ;
    ns1:identificador "MANACCP" ;
    ns1:textoExtracto "Máximo porcentaje de aceleración manual en G201."@es .

ns1:Parametro_MANFEEDP a ns1:Parametro ;
    rdfs:label "MANFEEDP" ;
    ns1:identificador "MANFEEDP" ;
    ns1:textoExtracto "Máximo porcentaje de avance manual en G201."@es .

ns1:Parametro_MANNEGSW a ns1:Parametro ;
    rdfs:label "MANNEGSW" ;
    ns1:identificador "MANNEGSW" ;
    ns1:textoExtracto "Máximo recorrido negativo con G201."@es .

ns1:Parametro_MANPOSSW a ns1:Parametro ;
    rdfs:label "MANPOSSW" ;
    ns1:identificador "MANPOSSW" ;
    ns1:textoExtracto "Máximo recorrido positivo con G201."@es .

ns1:Parametro_MAXMANACC a ns1:Parametro ;
    rdfs:label "MAXMANACC" ;
    ns1:identificador "MAXMANACC" ;
    ns1:textoExtracto "Aceleración máxima en modo jog continuo."@es .

ns1:Parametro_MAXMANFEED a ns1:Parametro ;
    rdfs:label "MAXMANFEED" ;
    ns1:identificador "MAXMANFEED" ;
    ns1:textoExtracto "Avance máximo en modo jog continuo."@es .

ns1:Parametro_MPGFILTER a ns1:Parametro ;
    rdfs:label "MPGFILTER" ;
    ns1:identificador "MPGFILTER" ;
    ns1:textoExtracto "Tiempo de filtro para el volante."@es .

ns1:Parametro_MPGRESOL a ns1:Parametro ;
    rdfs:label "MPGRESOL" ;
    ns1:identificador "MPGRESOL" ;
    ns1:textoExtracto "Resolución del volante."@es .

