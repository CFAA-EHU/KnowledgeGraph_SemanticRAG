@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_JOGFEED a ns1:Parametro ;
    rdfs:label "JOGFEED" ;
    ns1:documentadoEn ns1:Tabla_Manual ;
    ns1:identificador "JOGFEED" ;
    ns1:monitoreaParametro ns1:ModoOperacion_Manual_JogContinuo ;
    ns1:textoExtracto "JOGFEED Avance en jog continuo. [...] Valor por defecto: 1000.0000 mm/min / 39.37008 inch/min / 1000.0000 grados/min." ;
    ns1:valor "1000.0000" .

ns1:Parametro_JOGRAPFEED a ns1:Parametro ;
    rdfs:label "JOGRAPFEED" ;
    ns1:documentadoEn ns1:Tabla_Manual ;
    ns1:identificador "JOGRAPFEED" ;
    ns1:monitoreaParametro ns1:ModoOperacion_Manual_JogContinuo ;
    ns1:textoExtracto "JOGRAPFEED Avance rápido en jog continuo. [...] Valor por defecto: 10000.0000 mm/min / 393.70079 inch/min / 10000.0000 grados/min." ;
    ns1:valor "10000.0000" .

ns1:Parametro_MAXMANFEED a ns1:Parametro ;
    rdfs:label "MAXMANFEED" ;
    ns1:documentadoEn ns1:Tabla_Manual ;
    ns1:identificador "MAXMANFEED" ;
    ns1:monitoreaParametro ns1:ModoOperacion_Manual_JogContinuo ;
    ns1:textoExtracto "MAXMANFEED Avance máximo en jog continuo. [...] Valores posibles (1): De 0 a 200000.0000 mm/min." .

ns1:Tabla_Manual a ns1:Tabla ;
    rdfs:label "Tabla MANUAL" ;
    ns1:documentadoEn ns1:ModoOperacion_Manual_JogContinuo ;
    ns1:textoExtracto "Parámetro incluido en la tabla MANUAL." .

ns1:ModoOperacion_Manual_JogContinuo a ns1:ModoOperacion ;
    rdfs:label "Modo de trabajo manual. Jog continuo" ;
    ns1:textoExtracto "MODO DE TRABAJO MANUAL. JOG CONTINUO. JOGFEED Avance en jog continuo. [...] Este parámetro define el avance para los desplazamientos en jog continuo en modo manual." ;
    ns1:tieneComponente ns1:Parametro_JOGFEED,
        ns1:Parametro_JOGRAPFEED,
        ns1:Parametro_MAXMANFEED .

