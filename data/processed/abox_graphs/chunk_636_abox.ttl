@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_INCJOGDIST a ns1:Parametro ;
    rdfs:label "INCJOGDIST (Tabla de desplazamientos en jog incremental)"@es ;
    ns1:documentadoEn ns1:Tabla_MANUAL ;
    ns1:monitoreaParametro ns1:ModoOperacion_Manual ;
    ns1:textoExtracto "Tabla de desplazamientos en jog incremental. Este parámetro muestra la tabla para definir los desplazamientos del eje en cada posición del conmutador de jog. La tabla consta de cinco parámetros, uno para cada posición del conmutador del panel de mando: INCJOGDIST1 (Posición ꞏ1ꞏ), INCJOGDIST2 (Posición ꞏ10ꞏ), INCJOGDIST3 (Posición ꞏ100ꞏ), INCJOGDIST4 (Posición ꞏ1000ꞏ), INCJOGDIST5 (Posición ꞏ10000ꞏ)."@es .

ns1:Parametro_INCJOGDIST1 a ns1:Parametro ;
    rdfs:label "INCJOGDIST1 (Posición ꞏ1ꞏ del conmutador)"@es ;
    ns1:documentadoEn ns1:Tabla_MANUAL ;
    ns1:textoExtracto "INCJOGDIST1 Posición ꞏ1ꞏ del conmutador. Valores posibles (1): De 0.0001 a 99999.9999 mm."@es ;
    ns1:valor 0.0001 .

ns1:Parametro_INCJOGDIST2 a ns1:Parametro ;
    rdfs:label "INCJOGDIST2 (Posición ꞏ10ꞏ del conmutador)"@es ;
    ns1:documentadoEn ns1:Tabla_MANUAL ;
    ns1:textoExtracto "INCJOGDIST2 Posición ꞏ10ꞏ del conmutador. Valores posibles (1): De 0.0001 a 99999.9999 mm."@es ;
    ns1:valor 0.0001 .

ns1:Parametro_INCJOGDIST3 a ns1:Parametro ;
    rdfs:label "INCJOGDIST3 (Posición ꞏ100ꞏ del conmutador)"@es ;
    ns1:documentadoEn ns1:Tabla_MANUAL ;
    ns1:textoExtracto "INCJOGDIST3 Posición ꞏ100ꞏ del conmutador. Valores posibles (1): De 0.0001 a 99999.9999 mm."@es ;
    ns1:valor 0.0001 .

ns1:Parametro_INCJOGDIST4 a ns1:Parametro ;
    rdfs:label "INCJOGDIST4 (Posición ꞏ1000ꞏ del conmutador)"@es ;
    ns1:documentadoEn ns1:Tabla_MANUAL ;
    ns1:textoExtracto "INCJOGDIST4 Posición ꞏ1000ꞏ del conmutador. Valores posibles (1): De 0.0001 a 99999.9999 mm."@es ;
    ns1:valor 0.0001 .

ns1:Parametro_INCJOGDIST5 a ns1:Parametro ;
    rdfs:label "INCJOGDIST5 (Posición ꞏ10000ꞏ del conmutador)"@es ;
    ns1:documentadoEn ns1:Tabla_MANUAL ;
    ns1:textoExtracto "INCJOGDIST5 Posición ꞏ10000ꞏ del conmutador. Valores posibles (1): De 0.0001 a 99999.9999 mm."@es ;
    ns1:valor 0.0001 .

ns1:Parametro_MAXMANACC a ns1:Parametro ;
    rdfs:label "MAXMANACC (Aceleración máxima en jog continuo)"@es ;
    ns1:documentadoEn ns1:Tabla_MANUAL ;
    ns1:monitoreaParametro ns1:ModoOperacion_Manual ;
    ns1:textoExtracto "Este parámetro define la aceleración máxima para los desplazamientos en jog continuo en modo manual. Valores posibles (1): De 0.0010 a 600000000.0000 mm/s². Valor por defecto: 10000.0000 mm/s². Variable asociada: (V.)[ch].MPA.MAXMANACC.xn"@es ;
    ns1:valor 10000.0000 .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo de trabajo manual"@es ;
    ns1:textoExtracto "MODO DE TRABAJO MANUAL. JOG INCREMENTAL."@es .

ns1:Tabla_MANUAL a ns1:Tabla ;
    rdfs:label "Tabla MANUAL"@es ;
    ns1:detalladoEnEsquema ns1:ModoOperacion_Manual ;
    ns1:textoExtracto "Parámetro incluido en la tabla MANUAL. Este parámetro define la aceleración máxima para los desplazamientos en jog continuo en modo manual."@es .

