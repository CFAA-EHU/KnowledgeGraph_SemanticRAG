@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_TeclaJog a ns1:InterfazUsuario ;
    rdfs:label "Tecla de jog" ;
    ns1:controla ns1:Parametro_INCJOGDIST ;
    ns1:textoExtracto "En cada parámetro hay que definir la distancia que se desplaza el eje cada vez que se pulsa la tecla de jog." .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo de trabajo manual" ;
    ns1:monitoreaParametro ns1:Parametro_INCJOGDIST ;
    ns1:textoExtracto "Modo de trabajo manual. Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:Parametro_INCJOGDIST a ns1:Parametro ;
    rdfs:label "Distancia incremental de jog (INCJOGDIST)" ;
    ns1:identificador "MPA.INCJOGDIST" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.INCJOGDIST[pos].xn. En cada parámetro hay que definir la distancia que se desplaza el eje cada vez que se pulsa la tecla de jog." ;
    ns1:valor "Rango 1: 0.0001 a 99999.9999 mm / Rango 2: 0.0000 a 3937.00787 inch / Rango 3: 0.0001 a 99999.9999 grados" .

