@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo de trabajo manual"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_ParametrosDesplazamientoManual ;
    ns1:textoExtracto "Modo de trabajo manual"@es .

ns1:Parametro_INCJOGDIST1 a ns1:Parametro ;
    rdfs:label "INCJOGDIST1" ;
    ns1:documentadoEn ns1:Tabla_ParametrosDesplazamientoManual ;
    ns1:identificador "INCJOGDIST1" ;
    ns1:textoExtracto "INCJOGDIST1 | 0.0010 mm o grados / 0.00003937 inch."@es ;
    ns1:valor "0.0010 mm o grados / 0.00003937 inch" .

ns1:Parametro_INCJOGDIST2 a ns1:Parametro ;
    rdfs:label "INCJOGDIST2" ;
    ns1:documentadoEn ns1:Tabla_ParametrosDesplazamientoManual ;
    ns1:identificador "INCJOGDIST2" ;
    ns1:textoExtracto "INCJOGDIST2 | 0.0100 mm o grados / 0.00039370 inch."@es ;
    ns1:valor "0.0100 mm o grados / 0.00039370 inch" .

ns1:Parametro_INCJOGDIST3 a ns1:Parametro ;
    rdfs:label "INCJOGDIST3" ;
    ns1:documentadoEn ns1:Tabla_ParametrosDesplazamientoManual ;
    ns1:identificador "INCJOGDIST3" ;
    ns1:textoExtracto "INCJOGDIST3 | 0.1000 mm o grados / 0.00393700 inch."@es ;
    ns1:valor "0.1000 mm o grados / 0.00393700 inch" .

ns1:Parametro_INCJOGDIST4 a ns1:Parametro ;
    rdfs:label "INCJOGDIST4" ;
    ns1:documentadoEn ns1:Tabla_ParametrosDesplazamientoManual ;
    ns1:identificador "INCJOGDIST4" ;
    ns1:textoExtracto "INCJOGDIST4 | 1.0000 mm o grados / 0.03937007 inch."@es ;
    ns1:valor "1.0000 mm o grados / 0.03937007 inch" .

ns1:Parametro_INCJOGDIST5 a ns1:Parametro ;
    rdfs:label "INCJOGDIST5" ;
    ns1:documentadoEn ns1:Tabla_ParametrosDesplazamientoManual ;
    ns1:identificador "INCJOGDIST5" ;
    ns1:textoExtracto "INCJOGDIST5 | 10.000 mm o grados / 0.39370078 inch."@es ;
    ns1:valor "10.000 mm o grados / 0.39370078 inch" .

ns1:Tabla_ParametrosDesplazamientoManual a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de desplazamiento en modo manual"@es ;
