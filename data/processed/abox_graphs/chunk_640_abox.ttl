@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteElectrico_ConmutadorJog a ns1:ComponenteElectrico ;
    rdfs:label "Conmutador de jog (3 posiciones)"@es ;
    ns1:compuestoPor ns1:Parametro_MPGRESOL1,
        ns1:Parametro_MPGRESOL2,
        ns1:Parametro_MPGRESOL3 ;
    ns1:textoExtracto "conmutador de jog [...] Posición ꞏ1ꞏ [...] Posición ꞏ10ꞏ [...] Posición ꞏ100ꞏ"@es .

ns1:InterfazUsuario_PanelMando a ns1:InterfazUsuario ;
    rdfs:label "Panel de mando (conmutador de jog)"@es ;
    ns1:textoExtracto "conmutador del panel de mando"@es ;
    ns1:tieneComponente ns1:ComponenteElectrico_ConmutadorJog .

ns1:Parametro_MPGRESOL1 a ns1:Parametro ;
    rdfs:label "MPGRESOL1 (Resolución en posición '1')"@es ;
    ns1:documentadoEn ns1:Tabla_ResolucionVolante_Jog ;
    ns1:identificador "MPGRESOL1" ;
    ns1:textoExtracto "MPGRESOL1 Posición ꞏ1ꞏ del conmutador."@es ;
    ns1:valor "±99999.9999 mm / ±3937.00787 inch / ±99999.9999 grados"@es .

ns1:Parametro_MPGRESOL2 a ns1:Parametro ;
    rdfs:label "MPGRESOL2 (Resolución en posición '10')"@es ;
    ns1:documentadoEn ns1:Tabla_ResolucionVolante_Jog ;
    ns1:identificador "MPGRESOL2" ;
    ns1:textoExtracto "MPGRESOL2 Posición ꞏ10ꞏ del conmutador."@es ;
    ns1:valor "±99999.9999 mm / ±3937.00787 inch / ±99999.9999 grados"@es .

ns1:Parametro_MPGRESOL3 a ns1:Parametro ;
    rdfs:label "MPGRESOL3 (Resolución en posición '100')"@es ;
    ns1:documentadoEn ns1:Tabla_ResolucionVolante_Jog ;
    ns1:identificador "MPGRESOL3" ;
    ns1:textoExtracto "MPGRESOL3 Posición ꞏ100ꞏ del conmutador."@es ;
    ns1:valor "±99999.9999 mm / ±3937.00787 inch / ±99999.9999 grados"@es .

ns1:Tabla_ResolucionVolante_Jog a ns1:Tabla ;
    rdfs:label "Tabla de resolución del volante en modo manual"@es ;
    ns1:detalladoEnEsquema ns1:InterfazUsuario_PanelMando ;
    ns1:textoExtracto "Este parámetro muestra la tabla para definir la resolución del volante en cada posición del conmutador de jog. La tabla consta de tres parámetros, uno para cada posición del conmutador del panel de mando."@es .

