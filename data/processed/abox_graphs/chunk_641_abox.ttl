@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo de trabajo manual"@es ;
    ns1:monitoreaParametro ns1:Parametro_ResolucionMPG_Manual ;
    ns1:textoExtracto "Modo de trabajo manual (Sección 2.5.25)."@es .

ns1:Parametro_ResolucionMPG_Manual a ns1:Parametro ;
    rdfs:label "Resolución de desplazamiento por impulso (MPG)"@es ;
    ns1:identificador "MPA.MPGRESOL[pos].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.MPGRESOL[pos].xn. En cada parámetro hay que definir la distancia que se desplaza el eje por cada impulso del volante. Si la resolución es negativa, se invierte el sentido de desplazamiento (movimiento contrario al indicado por las señales A y B del volante)."@es ;
    ns1:valor "±99999.9999 mm / ±3937.00787 inch / ±99999.9999 grados" .

