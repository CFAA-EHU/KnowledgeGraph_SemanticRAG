@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_MPGRESOL1 a ns1:Parametro ;
    ns1:documentadoEn ns1:Tabla_ResolucionMPG ;
    ns1:identificador "MPGRESOL1" ;
    ns1:textoExtracto "MPGRESOL1 | 0.0010 mm o grados / 0.00003937 inch"@es ;
    ns1:valor "0.0010 mm o grados / 0.00003937 inch" .

ns1:Parametro_MPGRESOL2 a ns1:Parametro ;
    ns1:documentadoEn ns1:Tabla_ResolucionMPG ;
    ns1:identificador "MPGRESOL2" ;
    ns1:textoExtracto "MPGRESOL2 | 0.0100 mm o grados / 0.00039370 inch"@es ;
    ns1:valor "0.0100 mm o grados / 0.00039370 inch" .

ns1:Parametro_MPGRESOL3 a ns1:Parametro ;
    ns1:documentadoEn ns1:Tabla_ResolucionMPG ;
    ns1:identificador "MPGRESOL3" ;
    ns1:textoExtracto "MPGRESOL3 | 0.1000 mm o grados / 0.00393700 inch"@es ;
    ns1:valor "0.1000 mm o grados / 0.00393700 inch" .

ns1:Tabla_ResolucionMPG a ns1:Tabla ;
    rdfs:label "Tabla de resolución de parámetros MPG"@es ;
    ns1:textoExtracto """Parámetro | Resolución
MPGRESOL1 | 0.0010 mm o grados / 0.00003937 inch
MPGRESOL2 | 0.0100 mm o grados / 0.00039370 inch
MPGRESOL3 | 0.1000 mm o grados / 0.00393700 inch"""@es ;
    ns1:tieneComponente ns1:Parametro_MPGRESOL1,
        ns1:Parametro_MPGRESOL2,
        ns1:Parametro_MPGRESOL3 .

