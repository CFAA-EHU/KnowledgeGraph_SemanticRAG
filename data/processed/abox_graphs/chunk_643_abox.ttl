@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteElectrico_VolanteGraduado a ns1:ComponenteElectrico ;
    rdfs:label "Volante con disco graduado" ;
    ns1:monitoreaParametro ns1:Parametro_MPGRESOL1 ;
    ns1:textoExtracto "El volante dispone de un disco graduado de 100 posiciones y se desea una resolución de 0.001 mm para la posición ꞏ1ꞏ del conmutador." .

ns1:Sistema_ReguladorAnalogico a ns1:Sistema ;
    rdfs:label "Regulador analógico" ;
    ns1:controla ns1:Parametro_MPGFILTER ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:Sistema_Sercos a ns1:Sistema ;
    rdfs:label "Sistema Sercos" ;
    ns1:controla ns1:Parametro_MPGFILTER ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:Sistema_Simulado a ns1:Sistema ;
    rdfs:label "Sistema simulado" ;
    ns1:controla ns1:Parametro_MPGFILTER ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:Parametro_MPGRESOL1 a ns1:Parametro ;
    rdfs:label "MPGRESOL1" ;
    ns1:identificador "MPGRESOL1" ;
    ns1:textoExtracto "Un volante de 100 impulsos/vuelta proporciona 1 impulso por marca. MPGRESOL1 = 0.0010 mm. • Un volante de 200 impulsos/vuelta proporciona 2 impulsos por marca. MPGRESOL1 = 0.0005 mm. • Un volante de 25 impulsos/vuelta proporciona 1 impulso por cada 4 marcas. MPGRESOL1 = 0.0040 mm." ;
    ns1:valor "0.0005 mm",
        "0.0010 mm",
        "0.0040 mm" .

ns1:Parametro_MPGFILTER a ns1:Parametro ;
    rdfs:label "MPGFILTER" ;
    ns1:identificador "MPGFILTER" ;
    ns1:textoExtracto "MPGFILTER Tiempo de filtro para el volante. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 1 a 1000. Valor por defecto: 10." ;
    ns1:valor "10" .

