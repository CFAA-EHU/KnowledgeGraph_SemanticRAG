@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_MANNEGSW a ns1:Parametro ;
    rdfs:label "Máximo recorrido negativo con G201 (MANNEGSW)" ;
    ns1:documentadoEn ns1:Tabla_MANUAL ;
    ns1:identificador "MPA.MANNEGSW.xn" ;
    ns1:monitoreaParametro ns1:Maquina_Ejes ;
    ns1:textoExtracto "Valor por defecto: -99999.9999 mm / -3937.00787 inch / -99999.9999 grados. Variable asociada: (V.)[ch].MPA.MANNEGSW.xn. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "-99999.9999" .

ns1:Parametro_MANPOSSW a ns1:Parametro ;
    rdfs:label "Parámetro máquina de posición manual (MANPOSSW)" ;
    ns1:documentadoEn ns1:Tabla_MANUAL ;
    ns1:identificador "MPA.MANPOSSW.xn" ;
    ns1:monitoreaParametro ns1:Maquina_Ejes ;
    ns1:textoExtracto "Valor por defecto: 99999.9999 mm / 3937.00787 inch / 99999.9999 grados. Variable asociada: (V.)[ch].MPA.MANPOSSW.xn" ;
    ns1:valor "99999.9999" .

ns1:Maquina_Ejes a ns1:Maquina ;
    rdfs:label "Máquina de ejes (lineales, rotativos y cabezales)" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:Tabla_MANUAL a ns1:Tabla ;
    rdfs:label "Tabla MANUAL" ;
    ns1:textoExtracto "Parámetro incluido en la tabla MANUAL." .

