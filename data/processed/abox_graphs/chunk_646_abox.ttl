@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_MANNEGSW a ns1:Parametro ;
    rdfs:label "Variable asociada: (V.)[ch].MPA.MANNEGSW.xn" ;
    ns1:monitoreaParametro ns1:ModoOperacion_ManualSuperpuesto ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.MANNEGSW.xn Parámetro incluido en la tabla MANUAL." .

ns1:Tabla_MANUAL a ns1:Tabla ;
    rdfs:label "Tabla MANUAL" ;
    ns1:documentadoEn ns1:Manual ;
    ns1:textoExtracto "Parámetro incluido en la tabla MANUAL" .

ns1:ModoOperacion_ManualSuperpuesto a ns1:ModoOperacion ;
    rdfs:label "Modo manual superpuesto al modo automático" ;
    ns1:identificador "G201" ;
    ns1:textoExtracto "modo manual superpuesto al modo automático" .

