@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_IPOFEEDP a ns1:Parametro ;
    rdfs:label "IPOFEEDP" ;
    ns1:documentadoEn ns1:Tabla_MANUAL ;
    ns1:identificador "(V.)[ch].MPA.IPOFEEDP.xn" ;
    ns1:monitoreaParametro ns1:ModoOperacion_G201 ;
    ns1:textoExtracto "Máximo porcentaje de avance de ejecución en G201. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 100. Valor por defecto: 80. Cuando se activa la función G201, el avance asume instantáneamente el valor fijado por IPOFEEDP." ;
    ns1:valor "80" .

ns1:Parametro_MANACCP a ns1:Parametro ;
    rdfs:label "MANACCP" ;
    ns1:documentadoEn ns1:Tabla_MANUAL ;
    ns1:identificador "(V.)[ch].MPA.MANACCP.xn" ;
    ns1:monitoreaParametro ns1:ModoOperacion_G201 ;
    ns1:textoExtracto "Máximo porcentaje aceleración manual en G201. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 100. Valor por defecto: 20." ;
    ns1:valor "20" .

ns1:Parametro_MANFEEDP a ns1:Parametro ;
    rdfs:label "MANFEEDP" ;
    ns1:documentadoEn ns1:Tabla_MANUAL ;
    ns1:identificador "(V.)[ch].MPA.MANFEEDP.xn" ;
    ns1:monitoreaParametro ns1:ModoOperacion_G201 ;
    ns1:textoExtracto "Máximo porcentaje de avance manual en G201. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 100. Valor por defecto: 20." ;
    ns1:valor "20" .

ns1:Parametro_MANNEGSW a ns1:Parametro ;
    rdfs:label "MANNEGSW" ;
    ns1:documentadoEn ns1:Tabla_MANUAL ;
    ns1:identificador "(V.)[ch].MPA.MANNEGSW.xn" ;
    ns1:textoExtracto "Parámetro incluido en la tabla MANUAL. Cuando se trabaja con la función G201, modo manual superpuesto al modo automático, estos parámetros indican cuánto se puede mover en modo manual el eje en ambos sentidos." ;
    ns1:valor "Variable asociada: (V.)[ch].MPA.MANNEGSW.xn" .

ns1:ModoOperacion_G201 a ns1:ModoOperacion ;
    rdfs:label "Modo manual superpuesto al modo automático (G201)" ;
    ns1:textoExtracto "modo manual superpuesto al modo automático, estos parámetros indican cuánto se puede mover en modo manual el eje en ambos sentidos." .

ns1:Tabla_MANUAL a ns1:Tabla ;
    rdfs:label "Tabla MANUAL" ;
    ns1:documentadoEn ns1:ModoOperacion_G201 ;
    ns1:textoExtracto "Parámetro incluido en la tabla MANUAL." .

