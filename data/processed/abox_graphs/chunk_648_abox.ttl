@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_IPOACCP a ns1:Parametro ;
    rdfs:label "Parámetro IPOACCP (máximo porcentaje aceleración en G201)" ;
    ns1:documentadoEn ns1:Tabla_MANUAL ;
    ns1:identificador "IPOACCP" ;
    ns1:textoExtracto "IPOACCP Máximo porcentaje aceleración de ejecución en G201. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 100. Valor por defecto: 80. Variable asociada: (V.)[ch].MPA.IPOACCP.xn" ;
    ns1:valor "80" .

ns1:Parametro_MPA_MANACCP a ns1:Parametro ;
    rdfs:label "Parámetro MPA.MANACCP (porcentaje aceleración manual)" ;
    ns1:documentadoEn ns1:Tabla_MANUAL ;
    ns1:identificador "MPA.MANACCP" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 100. Valor por defecto: 20. Variable asociada: (V.)[ch].MPA.MANACCP.xn" ;
    ns1:valor "20" .

ns1:Tabla_MANUAL a ns1:Tabla ;
    rdfs:label "Tabla MANUAL (parámetros de modo trabajo manual)" ;
    ns1:textoExtracto "Parámetro incluido en la tabla MANUAL" .

