@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_Broaching a ns1:Maquina ;
    rdfs:label "Máquina de brochado"@es ;
    ns1:textoExtracto "Se recomienda que la suma de ambos parámetros no sea superior a 100 para evitar que, en determinadas condiciones, se superen los límites dinámicos de la máquina."@es .

ns1:Parametro_IPOACCP a ns1:Parametro ;
    rdfs:label "Parámetro IPOACCP (Aceleración en modo manual)"@es ;
    ns1:documentadoEn ns1:Tabla_MANUAL ;
    ns1:identificador "IPOACCP" ;
    ns1:monitoreaParametro ns1:ModoOperacion_G201 ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 100. Valor por defecto: 80. Variable asociada: (V.)[ch].MPA.IPOACCP.xn [...] Cuando se trabaja con la función G201, modo manual superpuesto al modo automático, ambos parámetros indican la máxima aceleración a utilizar de cada modo."@es ;
    ns1:valor "80" .

ns1:ModoOperacion_G201 a ns1:ModoOperacion ;
    rdfs:label "Modo G201 (Manual superpuesto a automático)"@es ;
    ns1:identificador "G201" ;
    ns1:textoExtracto "Cuando se trabaja con la función G201, modo manual superpuesto al modo automático, ambos parámetros indican la máxima aceleración a utilizar de cada modo."@es .

ns1:Tabla_MANUAL a ns1:Tabla ;
    rdfs:label "Tabla MANUAL (Parámetros de modo manual)"@es ;
    ns1:documentadoEn ns1:Manual_Broaching ;
    ns1:textoExtracto "Parámetro incluido en la tabla MANUAL."@es .

