@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_Automatico a ns1:ModoOperacion ;
    rdfs:label "Modo de ejecución automática" ;
    ns1:controla ns1:Parametro_IPOFEEDP ;
    ns1:textoExtracto "modos automático y manual" .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo de trabajo manual" ;
    ns1:controla ns1:Parametro_MANFEEDP ;
    ns1:textoExtracto "Modo de trabajo manual" .

ns1:Tabla_ValoresAvance a ns1:Tabla ;
    rdfs:label "Tabla de valores de avance para el eje Y" ;
    ns1:documentadoEn ns1:Sistema_EjeY ;
    ns1:textoExtracto "Considerando los siguientes valores para el eje Y: G00FEED: 1000 mm/min. JOGFEED: 100 mm/min. MAXMANFEED: 120 mm/min. IPOFEEDP: 50%. MANFEEDP: 50%" .

ns1:Parametro_G00FEED a ns1:Parametro ;
    rdfs:label "G00FEED" ;
    ns1:textoExtracto "G00FEED: 1000 mm/min" ;
    ns1:valor "1000 mm/min" .

ns1:Parametro_JOGFEED a ns1:Parametro ;
    rdfs:label "JOGFEED" ;
    ns1:textoExtracto "JOGFEED: 100 mm/min" ;
    ns1:valor "100 mm/min" .

ns1:Parametro_MAXMANFEED a ns1:Parametro ;
    rdfs:label "MAXMANFEED" ;
    ns1:textoExtracto "MAXMANFEED: 120 mm/min" ;
    ns1:valor "120 mm/min" .

ns1:Sistema_EjeY a ns1:Sistema ;
    rdfs:label "Eje Y" ;
    ns1:controla ns1:Parametro_IPOFEEDP,
        ns1:Parametro_MANFEEDP ;
    ns1:monitoreaParametro ns1:Parametro_G00FEED,
        ns1:Parametro_JOGFEED,
        ns1:Parametro_MAXMANFEED ;
    ns1:textoExtracto "eje Y" .

ns1:Parametro_IPOFEEDP a ns1:Parametro ;
    rdfs:label "IPOFEEDP" ;
    ns1:textoExtracto "IPOFEEDP: 50%" ;
    ns1:valor "50%" .

ns1:Parametro_MANFEEDP a ns1:Parametro ;
    rdfs:label "MANFEEDP" ;
    ns1:textoExtracto "MANFEEDP: 50%" ;
    ns1:valor "50%" .

