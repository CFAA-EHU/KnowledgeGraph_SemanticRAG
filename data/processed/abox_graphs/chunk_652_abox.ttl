@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CompensacionHusillo a ns1:Sistema ;
    rdfs:label "Sistema de compensación de husillo" ;
    ns1:detalladoEnEsquema ns1:Tabla_LSCRWDATA_DATA ;
    ns1:textoExtracto "Compensación de husillo" ;
    ns1:tieneComponente ns1:Parametro_LSCRWDATA_BIDIR,
        ns1:Parametro_LSCRWDATA_NPOINTS,
        ns1:Parametro_LSCRWDATA_REFNEED,
        ns1:Parametro_LSCRWDATA_TYPLSCRW .

ns1:Parametro_LSCRWDATA_BIDIR a ns1:Parametro ;
    rdfs:label "BIDIR" ;
    ns1:textoExtracto "BIDIR | Compensación bidireccional." ;
    ns1:valor "Compensación bidireccional" .

ns1:Parametro_LSCRWDATA_NPOINTS a ns1:Parametro ;
    rdfs:label "NPOINTS" ;
    ns1:textoExtracto "NPOINTS | Número de puntos de la tabla." ;
    ns1:valor "Número de puntos de la tabla" .

ns1:Parametro_LSCRWDATA_REFNEED a ns1:Parametro ;
    rdfs:label "REFNEED" ;
    ns1:textoExtracto "REFNEED | Búsqueda de referencia necesaria para compensar." ;
    ns1:valor "Búsqueda de referencia necesaria para compensar" .

ns1:Parametro_LSCRWDATA_TYPLSCRW a ns1:Parametro ;
    rdfs:label "TYPLSCRW" ;
    ns1:textoExtracto "TYPLSCRW | Método de compensación." ;
    ns1:valor "Método de compensación" .

ns1:Tabla_LSCRWDATA_DATA a ns1:Tabla ;
    rdfs:label "Tabla de compensación de husillo (DATA)" ;
    ns1:identificador "DATA" ;
    ns1:textoExtracto "DATA | Tabla para definir los valores de compensación." .

