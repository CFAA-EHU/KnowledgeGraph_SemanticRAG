@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_BIDIR a ns1:Parametro ;
    rdfs:label "BIDIR (Compensación bidireccional)"@es ;
    ns1:documentadoEn ns1:Tabla_LSCRWCOMP ;
    ns1:identificador "BIDIR" ;
    ns1:textoExtracto "BIDIR Compensación bidireccional. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPA.BIDIR.xn"@es ;
    ns1:valor "No" .

ns1:Parametro_NPOINTS a ns1:Parametro ;
    rdfs:label "NPOINTS (Número de puntos de la tabla)"@es ;
    ns1:documentadoEn ns1:Tabla_LSCRWCOMP ;
    ns1:identificador "NPOINTS" ;
    ns1:textoExtracto "NPOINTS Número de puntos de la tabla. Parámetro válido para ejes lineales, rotativos y cabezales. Valores posibles: De 0 a 1000. Valor por defecto: 0 (no hay tabla). Variable asociada: (V.)[ch].MPA.NPOINTS.xn"@es ;
    ns1:valor "0" .

ns1:Parametro_REFNEED a ns1:Parametro ;
    rdfs:label "REFNEED (Búsqueda de cero necesaria)"@es ;
    ns1:documentadoEn ns1:Tabla_LSCRWCOMP ;
    ns1:identificador "REFNEED" ;
    ns1:textoExtracto "REFNEED Búsqueda de cero necesaria. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPA.REFNEED.xn"@es ;
    ns1:valor "No" .

ns1:Parametro_TYPLSCRW a ns1:Parametro ;
    rdfs:label "TYPLSCRW (Método de compensación)"@es ;
    ns1:documentadoEn ns1:Tabla_LSCRWCOMP ;
    ns1:identificador "TYPLSCRW" ;
    ns1:textoExtracto "TYPLSCRW Método de compensación (tipo de cotas). Valores posibles: Real / Teórica. Valor por defecto: Real. Variable asociada: (V.)[ch].MPA.TYPLSCRW.xn"@es ;
    ns1:valor "Real" .

ns1:Tabla_LSCRWCOMP a ns1:Tabla ;
    rdfs:label "Tabla de compensación de husillo (LSCRWCOMP)"@es ;
    ns1:identificador "LSCRWCOMP" ;
    ns1:textoExtracto "La tabla de compensación de husillo puede disponer de hasta 1000 puntos. Parámetro incluido en la tabla LSCRWCOMP."@es .

