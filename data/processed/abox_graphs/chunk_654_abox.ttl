@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_CompensacionReferenciaHusillo a ns1:Parametro ;
    rdfs:label "Parámetro de referencia para compensación de husillo"@es ;
    ns1:documentadoEn ns1:Tabla_LSCRWCOMP ;
    ns1:identificador "MPA.REFNEED.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.REFNEED.xn. Este parámetro indica si es necesario referenciar el eje para empezar a aplicar la compensación."@es ;
    ns1:valor "No" .

ns1:Sistema_RegulacionAnalogica a ns1:Sistema ;
    rdfs:label "Sistema de regulación analógica"@es ;
    ns1:controla ns1:Parametro_CompensacionHusilloPorPunto ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado."@es .

ns1:Sistema_RegulacionSercos a ns1:Sistema ;
    rdfs:label "Sistema de regulación Sercos"@es ;
    ns1:controla ns1:Parametro_CompensacionHusilloPorPunto ;
    ns1:textoExtracto "Parámetro válido para regulador [...] Sercos [...]."@es .

ns1:Sistema_RegulacionSimulada a ns1:Sistema ;
    rdfs:label "Sistema de regulación simulada"@es ;
    ns1:controla ns1:Parametro_CompensacionHusilloPorPunto ;
    ns1:textoExtracto "Parámetro válido para regulador [...] simulado."@es .

ns1:Tabla_LSCRWCOMP a ns1:Tabla ;
    rdfs:label "Tabla de compensación de husillo (LSCRWCOMP)"@es ;
    ns1:textoExtracto "Parámetro incluido en la tabla LSCRWCOMP. [...] El CNC sólo permite acceder a esta tabla cuando está definido"@es .

ns1:Parametro_CompensacionHusilloPorPunto a ns1:Parametro ;
    rdfs:label "Compensación de husillo en cada punto"@es ;
    ns1:documentadoEn ns1:Tabla_LSCRWCOMP ;
    ns1:textoExtracto "DATA Compensación de husillo en cada punto. [...] Este parámetro muestra la lista de puntos y valores de compensación."@es ;
    ns1:valor "Valores dependientes de puntos (ejes lineales/rotativos/cabezales)"@es .

