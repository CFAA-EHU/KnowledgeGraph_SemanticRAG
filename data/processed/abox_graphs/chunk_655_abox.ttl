@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_BIDIR a ns1:Parametro ;
    rdfs:label "BIDIR" ;
    ns1:textoExtracto "El parámetro NEGERROR sólo se muestra si se ha definido la tabla con compensación bidireccional (BIDIR = Sí)." .

ns1:Tabla_CompensacionHusillo a ns1:Tabla ;
    rdfs:label "Tabla de compensación de husillo" ;
    ns1:detalladoEnEsquema ns1:Tabla_DATA ;
    ns1:textoExtracto "Este parámetro muestra la lista de puntos y valores de compensación." ;
    ns1:tieneComponente ns1:Parametro_NPOINTS .

ns1:Parametro_NEGERROR a ns1:Parametro ;
    rdfs:label "NEGERROR" ;
    ns1:textoExtracto "Para cada uno de los puntos se deben definir los parámetros POSITION, POSERROR y NEGERROR. El parámetro NEGERROR sólo se muestra si se ha definido la tabla con compensación bidireccional (BIDIR = Sí)." .

ns1:Parametro_NPOINTS a ns1:Parametro ;
    rdfs:label "NPOINTS" ;
    ns1:textoExtracto "El número de puntos viene definido por el parámetro NPOINTS. El CNC sólo permite acceder a esta tabla cuando está definido el parámetro NPOINTS." .

ns1:Parametro_POSERROR a ns1:Parametro ;
    rdfs:label "POSERROR" ;
    ns1:textoExtracto "Para cada uno de los puntos se deben definir los parámetros POSITION, POSERROR y NEGERROR." .

ns1:Parametro_POSITION a ns1:Parametro ;
    rdfs:label "POSITION" ;
    ns1:textoExtracto "Para cada uno de los puntos se deben definir los parámetros POSITION, POSERROR y NEGERROR." .

ns1:Tabla_DATA a ns1:Tabla ;
    rdfs:label "Tabla DATA" ;
    ns1:textoExtracto "En la tabla DATA se debe definir el error que se desea compensar en determinadas posiciones del eje." ;
    ns1:tieneComponente ns1:Parametro_NEGERROR,
        ns1:Parametro_POSERROR,
        ns1:Parametro_POSITION .

