@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCompensacionHusillo a ns1:Sistema ;
    rdfs:label "Sistema de compensación de husillo" ;
    ns1:textoExtracto "Al definir los diferentes puntos de la tabla, se deben cumplir los siguientes requisitos: Los puntos de la tabla deben estar ordenados por su posición en el eje, debiendo comenzar la tabla por el punto más negativo o menos positivo que se vaya a compensar." ;
    ns1:tieneComponente ns1:Tabla_LSCRWCOMP .

ns1:Parametro_POSITION a ns1:Parametro ;
    rdfs:label "POSITION" ;
    ns1:documentadoEn ns1:Tabla_LSCRWCOMP ;
    ns1:identificador "V.[ch].MPA.POSITION[pt].xn" ;
    ns1:textoExtracto "Posición de cada punto. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "0" .

ns1:Tabla_LSCRWCOMP a ns1:Tabla ;
    rdfs:label "LSCRWCOMP // DATA" ;
    ns1:monitoreaParametro ns1:Parametro_POSITION ;
    ns1:textoExtracto "Cada parámetro de la tabla representa un punto del perfil a compensar. La posición que ocupa el punto en el perfil vendrá referida al cero máquina." .

