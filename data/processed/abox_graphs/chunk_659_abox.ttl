@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_POSERROR_2526 a ns1:Parametro ;
    rdfs:label "Error de posición del husillo (POSERROR)"@es ;
    ns1:documentadoEn ns1:Tabla_LSCRWCOMP ;
    ns1:identificador "MPA.POSERROR[pt].xn" ;
    ns1:monitoreaParametro ns1:Sistema_CompensacionHusillo_2526 ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.POSERROR[pt].xn. Valor por defecto: 0."@es ;
    ns1:valor 0.0 .

ns1:Sistema_CompensacionHusillo_2526 a ns1:Sistema ;
    rdfs:label "Sistema de compensación de husillo"@es ;
    ns1:textoExtracto "Este parámetro indica el error cuando el eje"@es .

ns1:Tabla_LSCRWCOMP a ns1:Tabla ;
    rdfs:label "Tabla LSCRWCOMP // DATA"@es ;
    ns1:identificador "LSCRWCOMP" ;
    ns1:textoExtracto "Parámetro incluido en la tabla LSCRWCOMP // DATA."@es .

