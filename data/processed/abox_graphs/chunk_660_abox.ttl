@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ReguladorAnalogico a ns1:Sistema ;
    rdfs:label "Sistema de regulador analógico"@es ;
    ns1:monitoreaParametro ns1:Parametro_NEGERROR,
        ns1:Parametro_POSERROR ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado."@es .

ns1:Parametro_NEGERROR a ns1:Parametro ;
    rdfs:label "Error de posición en sentido negativo (NEGERROR)"@es ;
    ns1:documentadoEn ns1:Tabla_LSCRWCOMP ;
    ns1:identificador "MPA.NEGERROR" ;
    ns1:textoExtracto "Error en sentido negativo. Parámetro válido para ejes lineales, rotativos y cabezales. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.NEGERROR[pt].xn"@es ;
    ns1:valor "0" .

ns1:Parametro_POSERROR a ns1:Parametro ;
    rdfs:label "Error de posición en sentido positivo (POSERROR)"@es ;
    ns1:documentadoEn ns1:Tabla_LSCRWCOMP ;
    ns1:identificador "MPA.POSERROR" ;
    ns1:textoExtracto "Este parámetro indica el error cuando el eje se desplaza en sentido positivo. Si no se ha definido la tabla con compensación bidireccional, este error también se aplicará a los desplazamientos en sentido negativo. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.POSERROR[pt].xn"@es ;
    ns1:valor "0" .

ns1:Tabla_LSCRWCOMP a ns1:Tabla ;
    rdfs:label "Tabla de compensación de husillo (LSCRWCOMP // DATA)"@es ;
    ns1:identificador "LSCRWCOMP" ;
    ns1:textoExtracto "Parámetro incluido en la tabla LSCRWCOMP // DATA. Este parámetro indica el error cuando el eje se desplaza en sentido positivo [...] Parámetro incluido en la tabla LSCRWCOMP // DATA."@es .

