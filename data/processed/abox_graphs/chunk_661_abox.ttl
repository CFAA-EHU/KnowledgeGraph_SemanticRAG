@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_NEGERROR a ns1:Parametro ;
    rdfs:label "Variable MPA.NEGERROR[pt].xn"@es ;
    ns1:documentadoEn ns1:Tabla_LSCRWCOMP ;
    ns1:identificador "MPA.NEGERROR[pt].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.NEGERROR[pt].xn Parámetro incluido en la tabla LSCRWCOMP // DATA. Este parámetro indica el error cuando el eje se desplaza en sentido negativo."@es .

ns1:Tabla_LSCRWCOMP a ns1:Tabla ;
    rdfs:label "Tabla LSCRWCOMP"@es ;
    ns1:identificador "LSCRWCOMP" ;
    ns1:textoExtracto "tabla LSCRWCOMP // DATA"@es .

