@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaquinaCNC a ns1:Maquina ;
    rdfs:label "CNC (Control Numérico Computarizado)" ;
    ns1:textoExtracto "El CNC dispone de diferentes filtros." ;
    ns1:tieneComponente ns1:Cabezal,
        ns1:EjeLineal,
        ns1:EjeRotativo .

ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:requiereMantenimiento ns1:ConfiguracionFiltro_n ;
    ns1:textoExtracto "Parámetro válido para [...] cabezales. [...] Los filtros definidos para el cabezal sólo se aplicarán cuando éste trabaje como eje C o esté realizando un roscado rígido." ;
    ns1:tieneComponente ns1:FiltroAntirresonante,
        ns1:FiltroPasoBajo .

ns1:EjeLineal a ns1:ComponenteMecanico ;
    rdfs:label "Eje lineal" ;
    ns1:requiereMantenimiento ns1:ConfiguracionFiltro_n ;
    ns1:textoExtracto "Parámetro válido para ejes lineales" ;
    ns1:tieneComponente ns1:FiltroAntirresonante,
        ns1:FiltroPasoBajo .

ns1:EjeRotativo a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo" ;
    ns1:requiereMantenimiento ns1:ConfiguracionFiltro_n ;
    ns1:textoExtracto "Parámetro válido para ejes [...] rotativos" ;
    ns1:tieneComponente ns1:FiltroAntirresonante,
        ns1:FiltroPasoBajo .

ns1:ConfiguracionFiltro_n a ns1:Parametro ;
    rdfs:label "Configuración FILTER n" ;
    ns1:documentadoEn ns1:TablaFiltrosFrecuencia ;
    ns1:textoExtracto "FILTER n Configuración del filtro. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:FiltroAntirresonante a ns1:Parametro ;
    rdfs:label "Filtro antirresonante (banda eliminada)" ;
    ns1:documentadoEn ns1:TablaFiltrosFrecuencia ;
    ns1:textoExtracto "El filtro \"antirresonante\" (banda eliminada), que limita una zona de la banda pasante" ;
    ns1:valor "banda eliminada" .

ns1:FiltroPasoBajo a ns1:Parametro ;
    rdfs:label "Filtro paso bajo" ;
    ns1:documentadoEn ns1:TablaFiltrosFrecuencia ;
    ns1:textoExtracto "los filtros \"paso bajo\", que limitan la banda pasante a partir de una determinada frecuencia" ;
    ns1:valor "paso bajo" .

ns1:TablaFiltrosFrecuencia a ns1:Tabla ;
    rdfs:label "Tabla de filtros FILTER" ;
    ns1:documentadoEn ns1:Manual_Seccion_2.5.27 ;
    ns1:textoExtracto "FILTER Tabla de filtros. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Este parámetro muestra las tablas para configurar los filtros de frecuencia." .

