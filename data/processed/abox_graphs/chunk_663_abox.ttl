@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_AnchuraBandaNormalizada a ns1:Parametro ;
    rdfs:label "NORBWIDTH"@es ;
    ns1:documentadoEn ns1:Tabla_FiltrosResonancia ;
    ns1:textoExtracto "Anchura de banda normalizada."@es .

ns1:Parametro_FrecuenciaCorte a ns1:Parametro ;
    rdfs:label "FREQUENCY"@es ;
    ns1:documentadoEn ns1:Tabla_FiltrosResonancia ;
    ns1:textoExtracto "Frecuencia de corte o central."@es .

ns1:Parametro_OrdenFiltro a ns1:Parametro ;
    rdfs:label "ORDER"@es ;
    ns1:documentadoEn ns1:Tabla_FiltrosResonancia ;
    ns1:textoExtracto "Orden del filtro."@es .

ns1:Parametro_PorcentajeSenal a ns1:Parametro ;
    rdfs:label "SHARE"@es ;
    ns1:documentadoEn ns1:Tabla_FiltrosResonancia ;
    ns1:textoExtracto "Porcentaje de señal que pasa a través del filtro."@es .

ns1:Parametro_TipoFiltro a ns1:Parametro ;
    rdfs:label "TYPE"@es ;
    ns1:documentadoEn ns1:Tabla_FiltrosResonancia ;
    ns1:textoExtracto "Tipo de filtro."@es .

ns1:Tabla_FiltrosResonancia a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de filtros para eliminar frecuencias de resonancia"@es ;
    ns1:documentadoEn ns1:Pagina_184_186 ;
    ns1:textoExtracto "TYPE | Tipo de filtro."@es .

