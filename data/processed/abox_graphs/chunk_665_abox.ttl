@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ParametroAvance_404 a ns1:Parametro ;
    rdfs:label "Avance de trayectoria"@es ;
    ns1:textoExtracto "si no se ejecuta al mismo avance"@es .

ns1:ParametroDesfase_404 a ns1:Parametro ;
    rdfs:label "Desfase no constante"@es ;
    ns1:monitoreaParametro ns1:FiltroPasoBajo_404 ;
    ns1:textoExtracto "introduce un desfase no constante, dependiente de las frecuencias"@es .

ns1:ParametroFrecuencia_404 a ns1:Parametro ;
    rdfs:label "Frecuencia de resonancia"@es ;
    ns1:monitoreaParametro ns1:FiltroPasoBajo_404 ;
    ns1:textoExtracto "frecuencia"@es .

ns1:ParametroRetardo_404 a ns1:Parametro ;
    rdfs:label "Retardo introducido por filtro"@es ;
    ns1:monitoreaParametro ns1:FiltroPasoBajo_404 ;
    ns1:textoExtracto "introduce menos retardo"@es .

ns1:FiltroPasoBajo_404 a ns1:ComponenteElectrico ;
    rdfs:label "Filtro paso bajo para suavizar movimientos CNC"@es ;
    ns1:textoExtracto "El filtro \"paso bajo\", para un misma frecuencia, necesita menos orden y como consecuencia, introduce menos retardo. Este tipo de filtro introduce un desfase no constante, dependiente de las frecuencias."@es .

