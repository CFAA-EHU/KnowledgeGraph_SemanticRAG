@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FiltroAntirresonante a ns1:ComponenteElectrico ;
    rdfs:label "Filtro antirresonante (banda eliminada)" ;
    ns1:textoExtracto "Filtro \"antirresonante\" (banda eliminada). Si la máquina tiene una frecuencia de resonancia en una zona intermedia de su banda pasante, será conveniente eliminar esa frecuencia con un filtro \"antirresonante\"." .

ns1:FiltroDesfaseNoConstante a ns1:ComponenteElectrico ;
    rdfs:label "Filtro con desfase no constante" ;
    ns1:textoExtracto "tipo de filtro introduce un desfase no constante, dependiente de las frecuencias. Este desfase puede provocar que la trayectoria se modifique si no se ejecuta al mismo avance, como por ejemplo, al cambiar el porcentaje de avance o al ir y volver por la misma trayectoria." .

ns1:FiltroPasoBajoFAGOR a ns1:ComponenteElectrico ;
    rdfs:label "Filtro paso bajo FAGOR" ;
    ns1:textoExtracto "El filtro \"paso bajo FAGOR\" introduce un desfase constante, independiente de la frecuencia. Este tipo de filtro necesita mayor orden para tener el mismo nivel de filtrado." .

