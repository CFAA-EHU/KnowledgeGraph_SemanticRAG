@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:_407_FiltroResonancia a ns1:Parametro ;
    rdfs:label "Parámetro FILTER SHARE"@es ;
    ns1:documentadoEn ns1:_407_TablaFILTER ;
    ns1:identificador "V.[ch].MPA.SHARE[nb].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.SHARE[nb].xn Parámetro incluido en la tabla FILTER. Este parámetro indica el porcentaje de señal que pasa a través del filtro. Este valor debe ser equivalente al sobrepasamiento porcentual de la resonancia, ya que debe contrarrestar a la misma."@es ;
    ns1:valor "SHARE=100(Ar-Ao)/Ar" .

ns1:_407_FormulaCalculo a ns1:Parametro ;
    rdfs:label "Fórmula de cálculo SHARE"@es ;
    ns1:textoExtracto "Ejemplo de cálculo ante una determinada respuesta de la máquina: SHARE=100(Ar-Ao)/Ar"@es ;
    ns1:valor "SHARE=100(Ar-Ao)/Ar" .

ns1:_407_TablaFILTER a ns1:Tabla ;
    rdfs:label "Tabla FILTER"@es ;
    ns1:textoExtracto "Parámetro incluido en la tabla FILTER."@es .

