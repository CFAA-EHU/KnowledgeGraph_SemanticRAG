@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Funcion_G112 a ns1:AccionProhibida,
        ns1:Tabla ;
    rdfs:label "G112" ;
    ns1:controla ns1:Parametro_DEFAULTSET ;
    ns1:textoExtracto "Para seleccionar un set de parámetros en el eje desde el programa pieza, usar la función G112." .

ns1:Parametro_NPARSETS a ns1:Parametro ;
    rdfs:label "NPARSETS" ;
    ns1:identificador "(V.)[ch].MPA.NPARSETS.xn" ;
    ns1:monitoreaParametro ns1:Componente_Cabezal ;
    ns1:textoExtracto "NPARSETS Número de sets de parámetros disponibles. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 1 a 4. Valor por defecto: 1." ;
    ns1:valor "1" .

ns1:Parametro_SYNCSET a ns1:Parametro ;
    rdfs:label "SYNCSET" ;
    ns1:textoExtracto "El CNC arranca sin gama, y nada mas arrancar se sincronizan cabezales que no tienen definido el parámetro SYNCSET." .

ns1:Sistema_ReguladorAnalogico a ns1:Sistema ;
    rdfs:label "Regulador analógico" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:Sistema_Sercos a ns1:Sistema ;
    rdfs:label "Sercos" ;
    ns1:textoExtracto "Si cae el anillo Sercos y el regulador pone la gama por defecto." .

ns1:Parametro_DEFAULTSET a ns1:Parametro ;
    rdfs:label "DEFAULTSET" ;
    ns1:identificador "(V.)[ch].MPA.DEFAULTSET.xn" ;
    ns1:monitoreaParametro ns1:Componente_Cabezal ;
    ns1:textoExtracto "DEFAULTSET Set de parámetros por defecto en el encendido. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 4. Valor por defecto: 1." ;
    ns1:valor "1" .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "Comportamiento en un cabezal. El parámetro DEFAULTSET sólo se utiliza en el caso de mover el cabezal por primera vez sin gama y sin S programada." .

