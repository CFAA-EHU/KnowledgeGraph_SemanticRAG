@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_DEFAULTSET a ns1:Parametro ;
    rdfs:label "DEFAULTSET" ;
    ns1:textoExtracto "el encendido y el reset no utilizan el parámetro DEFAULTSET" .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:controla ns1:GamaDefecto,
        ns1:GamaOperativa ;
    ns1:textoExtracto "El CNC arranca sin gama" ;
    ns1:tieneComponente ns1:Cabezal,
        ns1:PLC_ControlGama,
        ns1:ReguladorGamaDefecto .

ns1:PLC_ControlGama a ns1:Actuador ;
    rdfs:label "PLC (control de gama)" ;
    ns1:controla ns1:GamaOperativa ;
    ns1:textoExtracto "el CNC pone la gama que indica el PLC" .

ns1:Parametro_S a ns1:Parametro ;
    rdfs:label "S (velocidad)" ;
    ns1:textoExtracto "la que corresponde a la S" .

ns1:Parametro_SYNCSET a ns1:Parametro ;
    rdfs:label "SYNCSET" ;
    ns1:monitoreaParametro ns1:SistemaSincronizacionCabezales ;
    ns1:textoExtracto "cabezales que no tienen definido el parámetro SYNCSET" .

ns1:ReguladorGamaDefecto a ns1:ComponenteElectrico ;
    rdfs:label "Regulador de gama por defecto" ;
    ns1:controla ns1:GamaDefecto ;
    ns1:textoExtracto "el regulador pone la gama por defecto" .

ns1:SistemaSincronizacionCabezales a ns1:Sistema ;
    rdfs:label "Sistema de sincronización de cabezales" ;
    ns1:controla ns1:Cabezal ;
    ns1:monitoreaParametro ns1:Parametro_SYNCSET ;
    ns1:textoExtracto "se sincronizan cabezales que no tienen definido el parámetro SYNCSET" .

ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:controla ns1:Parametro_S ;
    ns1:textoExtracto "se sincronizan cabezales que no tienen definido el parámetro SYNCSET" .

ns1:GamaDefecto a ns1:ModoOperacion ;
    rdfs:label "Gama por defecto" ;
    ns1:textoExtracto "el regulador pone la gama por defecto" .

ns1:GamaOperativa a ns1:ModoOperacion ;
    rdfs:label "Gama operativa" ;
    ns1:textoExtracto "el CNC pone la gama que indica el PLC" .

