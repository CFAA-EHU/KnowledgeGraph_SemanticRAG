@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_411_potencia_laser a ns1:Parametro ;
    rdfs:label "potencia"@es ;
    ns1:identificador "W" ;
    ns1:monitoreaParametro ns1:Sistema_411_eje_laser ;
    ns1:textoExtracto "definen la potencia (definida en watios)"@es ;
    ns1:valor "watios"@es .

ns1:Parametro_411_velocidad_cabezal a ns1:Parametro ;
    rdfs:label "velocidad del cabezal"@es ;
    ns1:identificador "rpm" ;
    ns1:monitoreaParametro ns1:Sistema_411_eje_laser ;
    ns1:textoExtracto "los parámetros relacionados con la velocidad del cabezal (definida en rpm)"@es .

ns1:Tabla_411_sets_parametros_eje a ns1:Tabla ;
    rdfs:label "sets de parámetros de dinámica del eje"@es ;
    ns1:detalladoEnEsquema ns1:Sistema_411_eje_laser ;
    ns1:documentadoEn ns1:Pagina_188 ;
    ns1:textoExtracto "Se pueden definir hasta 4 sets de parámetros distintos para indicar la dinámica del eje en cada una de ellas (avances, ganancias, aceleraciones, etc)"@es .

ns1:ComponenteMecanico_411_cabezal a ns1:ComponenteMecanico ;
    rdfs:label "cabezal"@es ;
    ns1:textoExtracto "velocidad del cabezal (definida en rpm)"@es .

ns1:Pagina_188 a ns1:Pagina ;
    ns1:identificador "188" ;
    ns1:textoExtracto "Sección 2.6: Parámetros máquina de los ejes. Gamas de trabajo."@es .

ns1:Sistema_411_eje_laser a ns1:Sistema ;
    rdfs:label "eje láser"@es ;
    ns1:textoExtracto "En el modelo láser, los parámetros relacionados con la velocidad del cabezal [...] definen la potencia"@es ;
    ns1:tieneComponente ns1:ComponenteMecanico_411_cabezal .

