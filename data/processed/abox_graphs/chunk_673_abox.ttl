@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CaptacionEjeLineal_Husillo a ns1:Sistema ;
    rdfs:label "Sistema de captación para eje lineal con husillo y encoder"@es ;
    ns1:monitoreaParametro ns1:Parametro_PITCH ;
    ns1:textoExtracto "En un eje lineal con encoder y husillo, el parámetro define el paso de husillo."@es ;
    ns1:tieneComponente ns1:Parametro_PITCH .

ns1:Sistema_CaptacionEjeLineal_Regla a ns1:Sistema ;
    rdfs:label "Sistema de captación para eje lineal con transductor lineal (regla)"@es ;
    ns1:monitoreaParametro ns1:Parametro_PITCH ;
    ns1:textoExtracto "En un eje lineal con transductor lineal (regla), el parámetro define el paso de la regla."@es ;
    ns1:tieneComponente ns1:Parametro_PITCH .

ns1:Sistema_CaptacionEjeRotativo a ns1:Sistema ;
    rdfs:label "Sistema de captación para eje rotativo"@es ;
    ns1:monitoreaParametro ns1:Parametro_PITCH ;
    ns1:textoExtracto "En un eje rotativo, el parámetro define el número de grados por vuelta de encoder."@es ;
    ns1:tieneComponente ns1:Parametro_PITCH .

ns1:Parametro_PITCH a ns1:Parametro ;
    rdfs:label "PITCH (Paso de husillo)"@es ;
    ns1:identificador "MPA.PITCH[set].xn" ;
    ns1:textoExtracto "PITCH Paso de husillo. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0 a 99999.9999 mm. Valores posibles (2): De 0 a 3937.00787 inch. Valores posibles (3): De 0 a 99999.9999 grados. Valor por defecto: 5 mm / 0.19685 inch / 360º. Variable asociada: (V.)[ch].MPA.PITCH[set].xn"@es ;
    ns1:valor "5 mm / 0.19685 inch / 360º" .

