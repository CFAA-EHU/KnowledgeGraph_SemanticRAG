@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Eje_Husillo5mm a ns1:ComponenteMecanico ;
    rdfs:label "Eje con husillo de 5 mm" ;
    ns1:detalladoEnEsquema ns1:Tabla_ResolucionCaptacion_413 ;
    ns1:identificador "5 mm" ;
    ns1:monitoreaParametro ns1:Parametro_Pitch5mm ;
    ns1:textoExtracto "Eje con husillo de 5 mm." .

ns1:Eje_ReglaFagor20um a ns1:ComponenteMecanico ;
    rdfs:label "Eje con regla Fagor de paso 20 µm" ;
    ns1:detalladoEnEsquema ns1:Tabla_ResolucionCaptacion_413 ;
    ns1:identificador "20 µm" ;
    ns1:monitoreaParametro ns1:Parametro_Pitch20um ;
    ns1:textoExtracto "Eje con regla Fagor de paso 20 µm." .

ns1:Eje_RotativoReduccion1_10 a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo con reducción 1/10" ;
    ns1:detalladoEnEsquema ns1:Tabla_ResolucionCaptacion_413 ;
    ns1:identificador "1/10" ;
    ns1:monitoreaParametro ns1:Parametro_Pitch36grados ;
    ns1:textoExtracto "Eje rotativo con reducción 1/10." .

ns1:Parametro_Pitch20um a ns1:Parametro ;
    rdfs:label "PITCH (0.020 mm)" ;
    ns1:textoExtracto "0.020 mm." ;
    ns1:valor "0.020 mm" .

ns1:Parametro_Pitch36grados a ns1:Parametro ;
    rdfs:label "PITCH (36°)" ;
    ns1:textoExtracto "36°." ;
    ns1:valor "36°" .

ns1:Parametro_Pitch5mm a ns1:Parametro ;
    rdfs:label "PITCH (5 mm)" ;
    ns1:textoExtracto "5 mm." ;
    ns1:valor "5 mm" .

ns1:Tabla_ResolucionCaptacion_413 a ns1:Tabla ;
    rdfs:label "Tabla de resolución de captación por tipo de eje" ;
    ns1:textoExtracto """
| Tipo de eje. | PITCH |
| --- | --- |
| Eje con husillo de 5 mm. | 5 mm. |
| Eje con regla Fagor de paso 20 µm. | 0.020 mm. |
| Eje rotativo con reducción 1/10. | 36º. |
""" .

