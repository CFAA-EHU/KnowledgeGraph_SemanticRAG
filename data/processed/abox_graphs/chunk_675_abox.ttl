@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ComponenteElectrico_Encoder a ns1:ComponenteElectrico ;
    rdfs:label "Encoder" ;
    ns1:monitoreaParametro ns1:Parametro_NPULSES ;
    ns1:textoExtracto "NPULSES Número de impulsos del encoder. [...] Si se emplea un reductor en el eje se deberá tener en cuenta todo el conjunto al definir el número de impulsos por vuelta." .

ns1:ComponenteMecanico_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:monitoreaParametro ns1:Parametro_INPUTREV,
        ns1:Parametro_REFINI ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.INPUTREV[set].xn [...] búsqueda de referencia del cabezal con su primer movimiento." .

ns1:ComponenteMecanico_Reductor a ns1:ComponenteMecanico ;
    rdfs:label "Reductor" ;
    ns1:textoExtracto "Si se emplea un reductor en el eje se deberá tener en cuenta todo el conjunto al definir el número de impulsos por vuelta." .

ns1:Parametro_NPULSES2 a ns1:Parametro ;
    rdfs:label "NPULSES2" ;
    ns1:identificador "NPULSES2" ;
    ns1:textoExtracto "Si se definen los parámetros NPULSES y NPULSES2 con valor distinto de ꞏ0ꞏ, el parámetro REFINI establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento." .

ns1:Parametro_PITCH a ns1:Parametro ;
    rdfs:label "PITCH" ;
    ns1:identificador "PITCH" ;
    ns1:textoExtracto "La posible reducción existente entre el motor y el encoder también se puede introducir directamente a través del parámetro PITCH; en ese caso, los parámetros INPUTREV y OUTPUTREV se definirán con valor ꞏ1ꞏ." .

ns1:Parametro_PITCH2 a ns1:Parametro ;
    rdfs:label "PITCH2" ;
    ns1:identificador "PITCH2" ;
    ns1:textoExtracto "PITCH2 Paso de husillo (captación externa)." .

ns1:Sistema_ReguladorAnalogico a ns1:Sistema ;
    rdfs:label "Regulador analógico" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:tieneComponente ns1:Parametro_INPUTREV,
        ns1:Parametro_NPULSES,
        ns1:Parametro_OUTPUTREV .

ns1:Sistema_Sercos a ns1:Sistema ;
    rdfs:label "Sercos" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:tieneComponente ns1:Parametro_INPUTREV,
        ns1:Parametro_NPULSES,
        ns1:Parametro_OUTPUTREV .

ns1:Sistema_Simulado a ns1:Sistema ;
    rdfs:label "Simulado" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:tieneComponente ns1:Parametro_INPUTREV,
        ns1:Parametro_NPULSES,
        ns1:Parametro_OUTPUTREV .

ns1:Parametro_REFINI a ns1:Parametro ;
    rdfs:label "REFINI" ;
    ns1:identificador "REFINI" ;
    ns1:textoExtracto "Si se definen los parámetros NPULSES y NPULSES2 con valor distinto de ꞏ0ꞏ, el parámetro REFINI establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento." .

ns1:Parametro_OUTPUTREV a ns1:Parametro ;
    rdfs:label "OUTPUTREV" ;
    ns1:identificador "OUTPUTREV" ;
    ns1:textoExtracto "OUTPUTREV Vueltas eje máquina. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 1 a 32767. Valor por defecto: 1." ;
    ns1:valor 1 .

ns1:Parametro_INPUTREV a ns1:Parametro ;
    rdfs:label "INPUTREV" ;
    ns1:identificador "INPUTREV" ;
    ns1:textoExtracto "INPUTREV Vueltas eje motor. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 1 a 32767. Valor por defecto: 1." ;
    ns1:valor 1 .

ns1:Parametro_NPULSES a ns1:Parametro ;
    rdfs:label "NPULSES" ;
    ns1:identificador "NPULSES" ;
    ns1:textoExtracto "NPULSES Número de impulsos del encoder. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos velocidad y simulado. Valores posibles: De 0 a 1000000. Valor por defecto: 1250." ;
    ns1:valor 1250 .

