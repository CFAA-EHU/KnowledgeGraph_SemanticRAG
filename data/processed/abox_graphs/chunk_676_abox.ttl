@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_NPULSES a ns1:Parametro ;
    rdfs:label "NPULSES" ;
    ns1:textoExtracto "Si se definen los parámetros NPULSES y NPULSES2 con valor distinto de ꞏ0ꞏ..." ;
    ns1:valor "distinto de 0" .

ns1:Parametro_NPULSES2 a ns1:Parametro ;
    rdfs:label "NPULSES2" ;
    ns1:textoExtracto "Si se definen los parámetros NPULSES y NPULSES2 con valor distinto de ꞏ0ꞏ..." ;
    ns1:valor "distinto de 0" .

ns1:Parametro_REFINI a ns1:Parametro ;
    rdfs:label "REFINI" ;
    ns1:textoExtracto "el parámetro REFINI establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento" .

ns1:Sistema_ReguladorSercos a ns1:Sistema ;
    rdfs:label "Regulador Sercos" ;
    ns1:controla ns1:Componente_Cabezal ;
    ns1:textoExtracto "Parámetro válido para regulador Sercos" .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:monitoreaParametro ns1:Parametro_PITCH2 ;
    ns1:textoExtracto "búsqueda de referencia del cabezal con su primer movimiento" .

ns1:Parametro_PITCH2 a ns1:Parametro ;
    rdfs:label "PITCH2" ;
    ns1:textoExtracto "PITCH2 Paso de husillo (captación externa). Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos" ;
    ns1:valor "5 mm / 0.19685 inch" .

