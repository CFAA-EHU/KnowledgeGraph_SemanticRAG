@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:RangoGrados_PITCH2 a ns1:Parametro ;
    rdfs:label "Rango de valores en grados (PITCH2)" ;
    ns1:textoExtracto "Valores posibles (3): De 0 a 99999.9999 grados." ;
    ns1:valor "0-99999.9999 grados"^^xsd:string .

ns1:RangoMilimetros_PITCH2 a ns1:Parametro ;
    rdfs:label "Rango de valores en milímetros (PITCH2)" ;
    ns1:textoExtracto "Valores posibles (1): De 0 a 99999.9999 mm." ;
    ns1:valor "0-99999.9999 mm"^^xsd:string .

ns1:RangoPulgadas_PITCH2 a ns1:Parametro ;
    rdfs:label "Rango de valores en pulgadas (PITCH2)" ;
    ns1:textoExtracto "Valores posibles (2): De 0 a 3937.00787 inch." ;
    ns1:valor "0-3937.00787 inch"^^xsd:string .

ns1:ValorDefecto_PITCH2 a ns1:Parametro ;
    rdfs:label "Valor por defecto de PITCH2" ;
    ns1:solucionaFallo ns1:Parametro_PITCH2 ;
    ns1:textoExtracto "Valor por defecto: 5 mm / 0.19685 inch / 360º." ;
    ns1:valor "5 mm"^^xsd:string .

ns1:Parametro_PITCH2 a ns1:Parametro ;
    rdfs:label "Parámetro PITCH2 (regulador Sercos)" ;
    ns1:identificador "MPA.PITCH2[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.PITCH2[set].xn. El significado de este parámetro depende del tipo captación. • En un eje lineal con encoder y husillo, el parámetro define el paso de husillo. • En un eje lineal con transductor lineal (regla), el parámetro define el paso de la regla. • En un eje rotativo, el parámetro define el número de grados por vuelta de encoder." ;
    ns1:valor "5 mm / 0.19685 inch / 360º"^^xsd:string .

