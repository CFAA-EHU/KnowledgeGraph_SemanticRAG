@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ComponenteMecanico_EjeRotativoReduccion1_10 a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo con reducción 1/10"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_ResolucionCaptacion_417 ;
    ns1:identificador "36° (1/10)" ;
    ns1:textoExtracto "Eje rotativo con reducción 1/10."@es ;
    ns1:valor "36.0"^^xsd:float .

ns1:ComponenteMecanico_Husillo5mm a ns1:ComponenteMecanico ;
    rdfs:label "Eje con husillo de 5 mm"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_ResolucionCaptacion_417 ;
    ns1:identificador "5 mm" ;
    ns1:textoExtracto "Eje con husillo de 5 mm."@es ;
    ns1:valor "5.0"^^xsd:float .

ns1:ComponenteMecanico_ReglaFagor20um a ns1:ComponenteMecanico ;
    rdfs:label "Eje con regla Fagor de paso 20 µm"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_ResolucionCaptacion_417 ;
    ns1:identificador "20 µm" ;
    ns1:textoExtracto "Eje con regla Fagor de paso 20 µm."@es ;
    ns1:valor "0.02"^^xsd:float .

ns1:Tabla_ResolucionCaptacion_417 a ns1:Tabla ;
    rdfs:label "Tabla de resolución de captación por tipo de eje"@es ;
    ns1:documentadoEn ns1:Pagina_188,
        ns1:Pagina_189,
        ns1:Pagina_190,
        ns1:Pagina_191 ;
    ns1:textoExtracto """
| Tipo de eje. | PITCH |
| --- | --- |
| Eje con husillo de 5 mm. | 5 mm. |
| Eje con regla Fagor de paso 20 µm. | 0.020 mm. |
| Eje rotativo con reducción 1/10. | 36º. |
"""@es .

