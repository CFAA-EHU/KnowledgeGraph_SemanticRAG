@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:RelacionTransmisionCaptacion2 a ns1:Sistema ;
    rdfs:label "Relación de transmisión para la segunda captación" ;
    ns1:textoExtracto "Los parámetros INPUTREV2 y OUTPUTREV2 establecen la relación de transmisión para la segunda captación." ;
    ns1:tieneComponente ns1:Parametro_INPUTREV2,
        ns1:Parametro_OUTPUTREV2 .

ns1:Parametro_NPULSES2 a ns1:Parametro ;
    rdfs:label "NPULSES2" ;
    ns1:identificador "NPULSES2" ;
    ns1:textoExtracto "Número de impulsos del encoder (captación externa). Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos." .

ns1:Parametro_INPUTREV2 a ns1:Parametro ;
    rdfs:label "INPUTREV2" ;
    ns1:identificador "INPUTREV2" ;
    ns1:monitoreaParametro ns1:Sistema_ReguladorSercos ;
    ns1:textoExtracto "Vueltas eje motor (captación externa). Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos. Valores posibles: De 1 a 32767. Valor por defecto: 1. Variable asociada: (V.)[ch].MPA.INPUTREV2[set].xn" ;
    ns1:valor 1 .

ns1:Parametro_OUTPUTREV2 a ns1:Parametro ;
    rdfs:label "OUTPUTREV2" ;
    ns1:identificador "OUTPUTREV2" ;
    ns1:monitoreaParametro ns1:Sistema_ReguladorSercos ;
    ns1:textoExtracto "Vueltas eje máquina (captación externa). Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos. Valores posibles: De 1 a 32767. Valor por defecto: 1. Variable asociada: (V.)[ch].MPA.OUTPUTREV2[set].xn" ;
    ns1:valor 1 .

ns1:Sistema_ReguladorSercos a ns1:Sistema ;
    rdfs:label "Regulador Sercos" ;
    ns1:textoExtracto "Parámetro válido para regulador Sercos." ;
    ns1:tieneComponente ns1:Parametro_INPUTREV2,
        ns1:Parametro_NPULSES2,
        ns1:Parametro_OUTPUTREV2 .

