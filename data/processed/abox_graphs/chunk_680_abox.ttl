@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_NPULSES a ns1:Parametro ;
    rdfs:label "NPULSES" ;
    ns1:documentadoEn ns1:Manual_Seccion2_6_1 ;
    ns1:monitoreaParametro ns1:Componente_Encoder ;
    ns1:textoExtracto "Si se definen los parámetros NPULSES y NPULSES2 con valor distinto de ꞏ0ꞏ, el parámetro REFINI establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento." .

ns1:Parametro_NPULSES2 a ns1:Parametro ;
    rdfs:label "NPULSES2" ;
    ns1:documentadoEn ns1:Manual_Seccion2_6_1 ;
    ns1:identificador "V.[ch].MPA.NPULSES2[set].xn" ;
    ns1:monitoreaParametro ns1:Componente_Encoder,
        ns1:Componente_TransductorLineal ;
    ns1:textoExtracto "Este parámetro define el número de impulsos por vuelta del encoder para la segunda captación. [...] definir NPULSES2" ;
    ns1:valor "1250" .

ns1:Parametro_REFINI a ns1:Parametro ;
    rdfs:label "REFINI" ;
    ns1:controla ns1:Componente_Cabezal ;
    ns1:documentadoEn ns1:Manual_Seccion2_6_1 ;
    ns1:textoExtracto "el parámetro REFINI establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento." .

ns1:Parametro_SINMAGNI a ns1:Parametro ;
    rdfs:label "SINMAGNI" ;
    ns1:documentadoEn ns1:Manual_Seccion2_6_1 ;
    ns1:monitoreaParametro ns1:Componente_Cabezal ;
    ns1:textoExtracto "SINMAGNI Factor de multiplicación para la señal de captación senoidal." .

ns1:Sistema_ReguladorAnalogico a ns1:Sistema ;
    rdfs:label "Regulador analógico" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico y simulado" .

ns1:Sistema_ReguladorSercos a ns1:Sistema ;
    rdfs:label "Regulador Sercos" ;
    ns1:textoExtracto "Parámetro válido para regulador Sercos" .

ns1:Componente_Reductor a ns1:ComponenteMecanico ;
    rdfs:label "Reductor" ;
    ns1:textoExtracto "Si se emplea un reductor en el eje se deberá tener en cuenta todo el conjunto al definir el número de impulsos por vuelta" .

ns1:Componente_TransductorLineal a ns1:ComponenteElectrico ;
    rdfs:label "Transductor lineal (regla)" ;
    ns1:textoExtracto "Con transductor lineal (regla), definir NPULSES2" .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "búsqueda de referencia del cabezal con su primer movimiento" .

ns1:Componente_Encoder a ns1:ComponenteElectrico ;
    rdfs:label "Encoder" ;
    ns1:textoExtracto "número de impulsos por vuelta del encoder para la segunda captación" ;
    ns1:tieneComponente ns1:Componente_Reductor .

ns1:Manual_Seccion2_6_1 a ns1:Manual ;
    rdfs:label "Sección 2.6.1: Resolución de la captación" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos. Valores posibles: De 0 a 1000000. Valor por defecto: 1250. Variable asociada: (V.)[ch].MPA.NPULSES2[set].xn" .

