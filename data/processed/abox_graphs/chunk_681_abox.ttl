@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_NPULSES a ns1:Parametro ;
    rdfs:label "Parámetro NPULSES" ;
    ns1:identificador "NPULSES" ;
    ns1:ilustradoEn ns1:Tabla_ResolucionContaje ;
    ns1:textoExtracto "Los parámetros SINMAGNI, PITCH y NPULSES definen la resolución de contaje del eje" .

ns1:Parametro_PITCH a ns1:Parametro ;
    rdfs:label "Parámetro PITCH" ;
    ns1:identificador "PITCH" ;
    ns1:ilustradoEn ns1:Tabla_ResolucionContaje ;
    ns1:textoExtracto "Los parámetros SINMAGNI, PITCH y NPULSES definen la resolución de contaje del eje" .

ns1:Parametro_SINMAGNI a ns1:Parametro ;
    rdfs:label "Parámetro SINMAGNI" ;
    ns1:identificador "SINMAGNI" ;
    ns1:ilustradoEn ns1:Tabla_ResolucionContaje ;
    ns1:monitoreaParametro ns1:SenalCaptacionEje ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.SINMAGNI[set].xn. Este parámetro indica el factor de multiplicación que se aplica a la señal de captación senoidal del eje." ;
    ns1:valor 0 .

ns1:SenalCaptacionEje a ns1:Sensor ;
    rdfs:label "Señal de captación del eje" ;
    ns1:textoExtracto "Este parámetro indica el factor de multiplicación que se aplica a la **señal de captación** senoidal del eje. Para señales de captación cuadradas definir SINMAGNI = 0 y el CNC aplicará siempre el factor x4." .

ns1:Tabla_ResolucionContaje a ns1:Tabla ;
    rdfs:label "Resolución de contaje del eje" ;
    ns1:detalladoEnEsquema ns1:Tabla_ResolucionContaje ;
    ns1:documentadoEn ns1:Manual_Broaching ;
    ns1:textoExtracto "Los parámetros SINMAGNI, PITCH y NPULSES definen la resolución de contaje del eje, tal y como se muestra en la siguiente tabla." .

