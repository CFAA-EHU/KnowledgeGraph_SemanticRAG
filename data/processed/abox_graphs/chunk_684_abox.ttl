@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteElectrico_ConectorAlarma a ns1:ComponenteElectrico ;
    rdfs:label "Conector de alarma de captación" ;
    ns1:textoExtracto "pin de alarma del conector" .

ns1:Parametro_HWFBACKAL a ns1:Parametro ;
    rdfs:label "Parámetro HWFBACKAL" ;
    ns1:activaAlarma ns1:Alarma_CaptacionHardware ;
    ns1:identificador "V.[ch].MPA.HWFBACKAL[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.HWFBACKAL[set].xn. Este parámetro habilita la alarma de captación por hardware, a través del pin de alarma del conector." .

ns1:Alarma_CaptacionHardware a ns1:Alarma ;
    rdfs:label "Alarma de captación por hardware" ;
    ns1:textoExtracto "Este parámetro habilita la alarma de captación por hardware, a través del pin de alarma del conector." .

