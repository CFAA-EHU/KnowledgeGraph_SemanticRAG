@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_SercosVelocidadCaptacion a ns1:Parametro ;
    rdfs:label "Sercos velocidad con captación interna+externa con contajes locales"@es ;
    ns1:habilitadoPor ns1:Alarma_CaptacionHardware ;
    ns1:identificador "Sercos velocidad con captación" ;
    ns1:textoExtracto "Sercos velocidad con captación interna+externa con contajes locales. Este parámetro habilita la alarma de captación por hardware..."@es .

ns1:Alarma_CaptacionHardware a ns1:Alarma ;
    rdfs:label "Alarma de captación por hardware"@es ;
    ns1:activaAlarma ns1:ComponenteElectrico_ConectorPinesAlarma ;
    ns1:textoExtracto "Esta alarma pretende discernir la desconexión o ruptura de alguno de los cables de la captación para señales tanto TTL diferenciales como senoidales."@es .

ns1:ComponenteElectrico_ConectorPinesAlarma a ns1:ComponenteElectrico ;
    rdfs:label "Conector (pin de alarma)"@es ;
    ns1:textoExtracto "pin de alarma del conector"@es .

