@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:errorSeguimiento a ns1:AvisoSeguridad ;
    rdfs:label "Error de seguimiento" ;
    ns1:mitigaRiesgo ns1:parametro_LOOPCH ;
    ns1:textoExtracto "Si el eje se embala se visualiza error de seguimiento" .

ns1:maquina_eje a ns1:Maquina ;
    rdfs:label "Eje (lineal/rotativo/cabezal)" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales" ;
    ns1:tieneComponente ns1:parametro_AXISCH,
        ns1:parametro_INPOSW,
        ns1:parametro_LOOPCH .

ns1:parametro_AXISCH a ns1:Parametro ;
    rdfs:label "AXISCH" ;
    ns1:identificador "AXISCH" ;
    ns1:monitoreaParametro ns1:variable_MPA_AXISCH ;
    ns1:textoExtracto "AXISCH Cambio de signo del contaje. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No." ;
    ns1:valor "No" .

ns1:parametro_INPOSW a ns1:Parametro ;
    rdfs:label "INPOSW" ;
    ns1:identificador "INPOSW" ;
    ns1:textoExtracto "INPOSW Banda de muerte." .

ns1:variable_MPA_AXISCH a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.AXISCH[set].xn" ;
    ns1:identificador "(V.)[ch].MPA.AXISCH[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.AXISCH[set].xn" .

ns1:variable_MPA_LOOPCH a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.LOOPCH[set].xn" ;
    ns1:identificador "(V.)[ch].MPA.LOOPCH[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.LOOPCH[set].xn" .

ns1:parametro_LOOPCH a ns1:Parametro ;
    rdfs:label "LOOPCH" ;
    ns1:identificador "LOOPCH" ;
    ns1:monitoreaParametro ns1:variable_MPA_LOOPCH ;
    ns1:textoExtracto "LOOPCH Cambio de signo de la consigna. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No." ;
    ns1:valor "No" .

