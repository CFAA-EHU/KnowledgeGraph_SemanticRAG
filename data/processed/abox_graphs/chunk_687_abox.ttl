@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:controla ns1:Parametro_INPOSW ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:Componente_EjeLineal a ns1:ComponenteMecanico ;
    rdfs:label "Eje lineal" ;
    ns1:controla ns1:Parametro_INPOSW ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:Componente_EjeRotativo a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo" ;
    ns1:controla ns1:Parametro_INPOSW ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:Sistema_ReguladorAnalogico a ns1:Sistema ;
    rdfs:label "Regulador analógico" ;
    ns1:monitoreaParametro ns1:Parametro_INPOSW ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:Sistema_Sercos a ns1:Sistema ;
    rdfs:label "Sistema Sercos" ;
    ns1:monitoreaParametro ns1:Parametro_INPOSW ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:Sistema_Simulado a ns1:Sistema ;
    rdfs:label "Sistema simulado" ;
    ns1:monitoreaParametro ns1:Parametro_INPOSW ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:Variable_V_MPA_INPOSW a ns1:Parametro ;
    rdfs:label "Variable asociada (V.)[ch].MPA.INPOSW[set].xn" ;
    ns1:identificador "V_MPA_INPOSW" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.INPOSW[set].xn" .

ns1:Parametro_INPOSW a ns1:Parametro ;
    rdfs:label "INPOSW (Banda de muerte)" ;
    ns1:identificador "INPOSW" ;
    ns1:textoExtracto "INPOSW Banda de muerte. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0.0001 a 99999.9999 mm. Valores posibles (2): De 0.0000 a 3937.00787 inch. Valores posibles (3): De 0.0001 a 99999.9999 grados. Valor por defecto: 0.0100 mm / 0.00039 inch / 0.0100 grados." ;
    ns1:valor "0.0100 mm / 0.00039 inch / 0.0100 grados" .

