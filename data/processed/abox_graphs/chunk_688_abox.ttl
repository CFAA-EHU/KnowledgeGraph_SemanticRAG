@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ComponenteElectrico_Motor a ns1:ComponenteElectrico ;
    rdfs:label "Motor" ;
    ns1:controla ns1:ComponenteMecanico_Carro ;
    ns1:textoExtracto "al invertir el sentido de giro hay un retardo desde que comienza a moverse el motor hasta que se mueve el carro." .

ns1:ComponenteMecanico_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:monitoreaParametro ns1:Parametro_BACKLASH ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:ComponenteMecanico_Eje a ns1:ComponenteMecanico ;
    rdfs:label "Eje" ;
    ns1:monitoreaParametro ns1:Parametro_BACKLASH ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales." ;
    ns1:tieneComponente ns1:ComponenteElectrico_Encoder .

ns1:ComponenteMecanico_Husillo a ns1:ComponenteMecanico ;
    rdfs:label "Husillo" ;
    ns1:textoExtracto "máquinas viejas en las que el juego entre husillo y soporte es defectuoso (gastado)." .

ns1:ComponenteMecanico_Soporte a ns1:ComponenteMecanico ;
    rdfs:label "Soporte de husillo" ;
    ns1:textoExtracto "máquinas viejas en las que el juego entre husillo y soporte es defectuoso (gastado)." .

ns1:ComponenteMecanico_TransductorLineal a ns1:ComponenteMecanico ;
    rdfs:label "Transductor lineal (regla)" ;
    ns1:textoExtracto "Con transductor lineal (regla), definir BACKLASH = 0." .

ns1:Herramienta_RelojComparador a ns1:Herramienta ;
    rdfs:label "Reloj comparador" ;
    ns1:textoExtracto "Para medir la holgura utilizar un reloj comparador." .

ns1:ModoOperacion_Incremental a ns1:ModoOperacion ;
    rdfs:label "Modo incremental" ;
    ns1:textoExtracto "Desplazar el eje en sentido contrario en modo incremental hasta detectar que el eje se mueve." .

ns1:ComponenteElectrico_Encoder a ns1:ComponenteElectrico ;
    rdfs:label "Encoder" ;
    ns1:textoExtracto "Normalmente ocurre en ejes con encoder y en máquinas viejas en las que el juego entre husillo y soporte es defectuoso (gastado)." .

ns1:ComponenteMecanico_Carro a ns1:ComponenteMecanico ;
    rdfs:label "Carro" ;
    ns1:textoExtracto "al invertir el sentido de giro hay un retardo desde que comienza a moverse el motor hasta que se mueve el carro." .

ns1:Parametro_BACKLASH a ns1:Parametro ;
    rdfs:label "BACKLASH (Compensación de holgura)" ;
    ns1:identificador "MPA.BACKLASH[set].xn" ;
    ns1:textoExtracto "BACKLASH Holgura a compensar. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): Entre ±3.2768 mm. Valores posibles (2): Entre ±0.12901 inch. Valores posibles (3): Entre ±3.2768 grados. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.BACKLASH[set].xn" ;
    ns1:valor "0.0"^^xsd:float .

