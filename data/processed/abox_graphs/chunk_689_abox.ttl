@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_BAKANOUT a ns1:Parametro ;
    rdfs:label "BAKANOUT (Impulso adicional de consigna)" ;
    ns1:identificador "BAKANOUT" ;
    ns1:textoExtracto "BAKANOUT Impulso adicional de consigna. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos. Valores posibles: Con regulador analógico, entre ±32767 / con regulador Sercos, entre ±1000 rpm. Valor por defecto: 0 (no se aplica)." ;
    ns1:valor 0 .

ns1:Parametro_BAKTIME a ns1:Parametro ;
    rdfs:label "BAKTIME" ;
    ns1:identificador "BAKTIME" ;
    ns1:textoExtracto "La duración de esta consigna adicional depende de los parámetros BAKTIME y PEAKDISP." .

ns1:Parametro_PEAKDISP a ns1:Parametro ;
    rdfs:label "PEAKDISP" ;
    ns1:identificador "PEAKDISP" ;
    ns1:textoExtracto "La duración de esta consigna adicional depende de los parámetros BAKTIME y PEAKDISP." .

ns1:Variable_V_MPA_BAKANOUT a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.BAKANOUT[set].xn" ;
    ns1:identificador "(V.)[ch].MPA.BAKANOUT[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.BAKANOUT[set].xn" .

