@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ReguladorAnalogico a ns1:Sistema ;
    rdfs:label "Regulador analógico"@es ;
    ns1:monitoreaParametro ns1:Parametro_ConsignaAdicional ;
    ns1:textoExtracto "Con regulador analógico, la consigna adicional se expresará en unidades del conversor D/A"@es .

ns1:Parametro_ConsignaAdicional a ns1:Parametro ;
    rdfs:label "Consigna adicional (regulador analógico)"@es ;
    ns1:textoExtracto "la consigna adicional se expresará en unidades del conversor D/A, admitiendo cualquier número entero entre ±32767. Al valor -32767 le corresponderá una consigna de -10 V; al valor 32767, una consigna de 10 V."@es ;
    ns1:valor "-32767/-10V ... 32767/10V" .

