@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CompensacionHolgura a ns1:Sistema ;
    rdfs:label "Sistema de compensación de holgura con impulso adicional de consigna" ;
    ns1:textoExtracto "En los ejes analógicos, cuando LOOPCH=Sí hay que definir BAKANOUT con valor negativo para que el CNC aplique el pico de inversión en sentido correcto. Cuando se define un impulso adicional de consigna también hay que definir los parámetros BAKTIME, ACTBAKAN y PEAKDISP." ;
    ns1:tieneComponente ns1:Parametro_ACTBAKAN,
        ns1:Parametro_BAKANOUT,
        ns1:Parametro_BAKTIME,
        ns1:Parametro_PEAKDISP .

ns1:Parametro_ACTBAKAN a ns1:Parametro ;
    rdfs:label "ACTBAKAN" ;
    ns1:textoExtracto "ACTBAKAN: Aplicación del impulso adicional de consigna. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos. Valores posibles: Siempre / G2-G3. Valor por defecto: Siempre." ;
    ns1:valor "Siempre, G2-G3" .

ns1:Parametro_BAKANOUT a ns1:Parametro ;
    rdfs:label "BAKANOUT" ;
    ns1:textoExtracto "cuando LOOPCH=Sí hay que definir BAKANOUT con valor negativo para que el CNC aplique el pico de inversión en sentido correcto. Cuando se define un impulso adicional de consigna también hay que definir los parámetros BAKTIME, ACTBAKAN y PEAKDISP." ;
    ns1:valor "- (negativo)" .

ns1:Parametro_BAKTIME a ns1:Parametro ;
    rdfs:label "BAKTIME" ;
    ns1:textoExtracto "BAKTIME: Duración del impulso adicional de consigna. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos. Valores posibles: De 0 a 100 ms. Valor por defecto: 0." ;
    ns1:valor "0-100 ms" .

ns1:Parametro_PEAKDISP a ns1:Parametro ;
    rdfs:label "PEAKDISP" ;
    ns1:textoExtracto "PEAKDISP: Distancia de corte del pico de holgura. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos. Valores posibles: De 0 a 99999.9999 mm / 0 a 3937.00787 inch / 0 a 99999.9999 grados." ;
    ns1:valor "0-99999.9999 mm, 0-3937.00787 inch, 0-99999.9999°" .

