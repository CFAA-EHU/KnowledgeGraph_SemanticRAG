@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_BAKANOUT a ns1:Parametro ;
    rdfs:label "Parámetro BAKANOUT (condición para PEAKDISP)"@es ;
    ns1:identificador "BAKANOUT" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro cuando trabaja con impulso adicional de consigna; parámetro BAKANOUT distinto de cero"@es .

ns1:Parametro_PEAKDISP a ns1:Parametro ;
    rdfs:label "Parámetro PEAKDISP (compensación de holgura con impulso adicional)"@es ;
    ns1:identificador "V.[ch].MPA.PEAKDISP[set].xn" ;
    ns1:monitoreaParametro ns1:Variable_V_MPA_PEAKDISP ;
    ns1:textoExtracto "Parámetro válido para regulador analógico y Sercos. [...] El parámetro PEAKDISP define la distancia real recorrida por el eje, después de la inversión de movimiento teórica"@es ;
    ns1:valor "0.0050 mm / 0.00020 inch / 0.0050 grados"^^xsd:string .

ns1:Variable_V_MPA_PEAKDISP a ns1:Parametro ;
    rdfs:label "Variable asociada V.[ch].MPA.PEAKDISP[set].xn"@es ;
    ns1:identificador "V.[ch].MPA.PEAKDISP[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.PEAKDISP[set].xn"@es .

