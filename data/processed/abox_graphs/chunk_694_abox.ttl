@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_BAKANOUT a ns1:Parametro ;
    rdfs:label "BAKANOUT" ;
    ns1:textoExtracto "parámetro BAKANOUT distinto de cero"@es ;
    ns1:valor "distinto de cero" .

ns1:Parametro_PEAKDISP a ns1:Parametro ;
    rdfs:label "PEAKDISP" ;
    ns1:textoExtracto "El parámetro PEAKDISP define la distancia real recorrida por el eje, después de la inversión de movimiento teórica, a la que el CNC corta el pico de inversión en dicho eje (impulso adicional de consigna). [ rev/min]"@es ;
    ns1:valor "distancia real recorrida por el eje tras inversión de movimiento [rev/min]" .

