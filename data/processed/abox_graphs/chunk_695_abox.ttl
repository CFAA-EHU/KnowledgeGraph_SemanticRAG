@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:OrdenFinBAKANOUT_434 a ns1:AccionProhibida ;
    rdfs:label "Orden para fin de holgura (BAKANOUT)"@es ;
    ns1:mitigaRiesgo ns1:CompensacionHolgura_434 ;
    ns1:textoExtracto "Orden para fin BAKANOUT de holgura"@es .

ns1:ParametroAmplitudPosicion_434 a ns1:Parametro ;
    rdfs:label "Amplitud del parámetro de posición"@es ;
    ns1:monitoreaParametro ns1:CompensacionHolgura_434 ;
    ns1:textoExtracto "Amplitud del parámetro de posición."@es .

ns1:CompensacionHolgura_434 a ns1:ModoOperacion ;
    rdfs:label "Compensación de holgura con impulso adicional de consigna"@es ;
    ns1:identificador "2.6.4" ;
    ns1:textoExtracto "Orden para iniciar la compensación de holgura. [...] Amplitud del parámetro de posición."@es .

