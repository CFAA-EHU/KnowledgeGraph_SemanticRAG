@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_REVEHYST a ns1:Parametro ;
    rdfs:label "REVEHYST" ;
    ns1:identificador "REVEHYST" ;
    ns1:monitoreaParametro ns1:Sistema_CompensacionHolgura ;
    ns1:textoExtracto "valor REVEHYST distinto de 0 [...] Si REVEHYST= 0.0005 mm, el CNC no activará la compensación"@es ;
    ns1:valor "0.0005" .

ns1:Componente_EjeVisualizador a ns1:ComponenteMecanico ;
    rdfs:label "Eje definido como visualizador" ;
    ns1:controla ns1:Parametro_BACKlash ;
    ns1:textoExtracto "ejes definidos como visualizador"@es .

ns1:Parametro_BACKlash a ns1:Parametro ;
    rdfs:label "BACKLASH" ;
    ns1:monitoreaParametro ns1:Sistema_CompensacionHolgura ;
    ns1:textoExtracto "valor del parámetro BACKLASH"@es .

ns1:Sistema_CompensacionHolgura a ns1:Sistema ;
    rdfs:label "Sistema de compensación de holgura con impulso adicional" ;
    ns1:textoExtracto "compensación de holgura con impulso adicional de consigna [...] Inversión de la consigna de posición. 2 Límite definido en REVEHYST. Inicio de la compensación de holgura. 3 Cancelación de la compensación de holgura"@es ;
    ns1:tieneComponente ns1:Componente_EjeVisualizador .

