@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CompensacionHolgura a ns1:ModoOperacion ;
    rdfs:label "Compensación de holgura" ;
    ns1:monitoreaParametro ns1:Parametro_REVEHYST ;
    ns1:textoExtracto "compensación de holgura. 3 Cancelación de la compensación de holgura. [...] el CNC lanzará la compensación. Tras aplicar una compensación, el CNC tomará la siguiente orden de invertir como nueva referencia para evaluar la variación de la posición y establecer cuándo se alcanza nuevamente el valor dado en el parámetro REVEHYST y volver a compensar." .

ns1:Parametro_REVEHYST a ns1:Parametro ;
    rdfs:label "REVEHYST" ;
    ns1:identificador "REVEHYST" ;
    ns1:textoExtracto "Si REVEHYST= 0.0005 mm, el CNC no activará la compensación en las inversiones posteriores a la primera mientras la posición del eje no varíe al menos el valor definido en este parámetro" ;
    ns1:valor "0.0005 mm" .

