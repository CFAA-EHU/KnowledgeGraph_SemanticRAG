@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_PanelMando a ns1:InterfazUsuario ;
    rdfs:label "Panel de mando"@es ;
    ns1:controla ns1:Parametro_MAXFEED ;
    ns1:textoExtracto "Si se intenta sobrepasar el avance máximo desde el programa pieza, desde el PLC o desde el panel de mando, el CNC limita el avance al valor definido en MAXFEED."@es .

ns1:ModoOperacion_G00 a ns1:ModoOperacion ;
    rdfs:label "Modo G00 (avance rápido)"@es ;
    ns1:habilitadoPor ns1:Parametro_G00FEED ;
    ns1:identificador "G00" ;
    ns1:textoExtracto "Si no se limita el avance de mecanizado, el CNC asume como avance máximo para todos los desplazamientos el definido en el parámetro máquina G00FEED."@es .

ns1:ModoOperacion_G01 a ns1:ModoOperacion ;
    rdfs:label "Modo G01 (interpolación lineal)"@es ;
    ns1:habilitadoPor ns1:Parametro_MAXFEED ;
    ns1:identificador "G01" ;
    ns1:textoExtracto "Este parámetro establece el avance máximo de mecanizado (movimientos en G01/G02/G03) del eje."@es .

ns1:ModoOperacion_G02 a ns1:ModoOperacion ;
    rdfs:label "Modo G02 (interpolación circular CW)"@es ;
    ns1:habilitadoPor ns1:Parametro_MAXFEED ;
    ns1:identificador "G02" ;
    ns1:textoExtracto "Este parámetro establece el avance máximo de mecanizado (movimientos en G01/G02/G03) del eje."@es .

ns1:ModoOperacion_G03 a ns1:ModoOperacion ;
    rdfs:label "Modo G03 (interpolación circular CCW)"@es ;
    ns1:habilitadoPor ns1:Parametro_MAXFEED ;
    ns1:identificador "G03" ;
    ns1:textoExtracto "Este parámetro establece el avance máximo de mecanizado (movimientos en G01/G02/G03) del eje."@es .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:monitoreaParametro ns1:Parametro_G00FEED,
        ns1:Parametro_MAXFEED ;
    ns1:textoExtracto "El CNC limita el avance al valor definido en MAXFEED sin mostrar ningún error ni warning. Si no se limita el avance de mecanizado, el CNC asume como avance máximo para todos los desplazamientos el definido en el parámetro máquina G00FEED."@es .

ns1:Parametro_G00FEED a ns1:Parametro ;
    rdfs:label "Parámetro G00FEED"@es ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "Parámetro máquina G00FEED. Si se intenta sobrepasar el avance máximo desde el programa pieza, desde el PLC o desde el panel de mando, el CNC limita el avance al valor definido en MAXFEED sin mostrar ningún error ni warning. Si no se limita el avance de mecanizado, el CNC asume como avance máximo para todos los desplazamientos el definido en el parámetro máquina G00FEED."@es ;
    ns1:valor "Definido por máquina (límite superior para MAXFEED)"@es .

ns1:Parametro_MAXFEED a ns1:Parametro ;
    rdfs:label "Parámetro MAXFEED"@es ;
    ns1:identificador "MPA.MAXFEED[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.MAXFEED[set].xn. Este parámetro establece el avance máximo de mecanizado (movimientos en G01/G02/G03) del eje; si se define con valor ꞏ0ꞏ, no se limita el avance."@es ;
    ns1:valor "Definido por usuario (≤ G00FEED)"@es .

