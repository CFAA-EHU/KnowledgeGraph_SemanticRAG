@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal"@es ;
    ns1:monitoreaParametro ns1:Parametro_G00FEED,
        ns1:Parametro_MAXFREQ,
        ns1:Parametro_MAXVOLT ;
    ns1:textoExtracto "Parámetro válido para cabezales. [...] Consigna que debe proporcionar el CNC para que el cabezal alcance la potencia del generador definida en G00FEED."@es .

ns1:Componente_Motor a ns1:ComponenteElectrico ;
    rdfs:label "Motor"@es ;
    ns1:monitoreaParametro ns1:Parametro_G00FEED,
        ns1:Parametro_MAXRPM ;
    ns1:textoExtracto "Revoluciones máximas del motor. Parámetro válido para ejes lineales, rotativos y cabezales."@es .

ns1:Sistema_InverterMechatrolink a ns1:Sistema ;
    rdfs:label "Inverter Mechatrolink"@es ;
    ns1:controla ns1:Parametro_MAXFREQ ;
    ns1:textoExtracto "Parámetro válido para Inverter Mechatrolink."@es .

ns1:Sistema_ReguladorAnalogico a ns1:Sistema ;
    rdfs:label "Regulador analógico"@es ;
    ns1:controla ns1:Parametro_MAXVOLT ;
    ns1:textoExtracto "Parámetro válido para regulador analógico y Sercos velocidad."@es .

ns1:Parametro_MAXRPM a ns1:Parametro ;
    rdfs:label "MAXRPM"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosAvanceG00 ;
    ns1:identificador "MAXRPM" ;
    ns1:textoExtracto "Revoluciones máximas del motor. Parámetro válido para ejes lineales, rotativos y cabezales."@es .

ns1:Parametro_G00FEED a ns1:Parametro ;
    rdfs:label "G00FEED"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosAvanceG00 ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "(V.)PLC.G00FEED | G00FEED (eje) | MAXFEED (eje)"@es .

ns1:Parametro_MAXFREQ a ns1:Parametro ;
    rdfs:label "MAXFREQ"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosAvanceG00 ;
    ns1:identificador "MAXFREQ" ;
    ns1:textoExtracto "Frecuencia necesaria para alcanzar G00FEED. Parámetro válido para cabezales. Parámetro válido para Inverter Mechatrolink. Valores posibles: De 0.0010 a 10000.0000 Hz. Valor por defecto: 50 Hz."@es ;
    ns1:valor "50" .

ns1:Parametro_MAXVOLT a ns1:Parametro ;
    rdfs:label "MAXVOLT"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosAvanceG00 ;
    ns1:identificador "MAXVOLT" ;
    ns1:textoExtracto "Consigna para alcanzar G00FEED. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos velocidad. Valores posibles: De 0 a 10000.0000 mV. Valor por defecto: 9500 mV (9.5 V)."@es ;
    ns1:valor "9500" .

ns1:Tabla_ParametrosAvanceG00 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de avance rápido G00 y velocidad máxima"@es ;
    ns1:textoExtracto """
| Variable. | Parámetros máquina. |  | Avance. |  |
| --- | --- | --- | --- | --- |
| (V.)PLC.G00FEED | G00FEED (eje) | MAXFEED (eje) | G00 | G01, G02, ꞏꞏꞏ |
| 0 | 10000 | 0 | 10000 | 10000 |
| 0 | 10000 | 6000 | 10000 | 6000 |
| 4000 | 10000 | 6000 | 4000 | 4000 |
| 7000 | 10000 | 6000 | 7000 | 4000 |
| 12000 | 10000 | 6000 | 10000 | 6000 """@es .

