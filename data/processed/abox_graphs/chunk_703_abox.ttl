@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:componente_Motor a ns1:ComponenteMecanico ;
    rdfs:label "Motor" ;
    ns1:monitoreaParametro ns1:parametro_MAXRPM ;
    ns1:textoExtracto "Revoluciones máximas del motor" .

ns1:parametro_MAXRPM a ns1:Parametro ;
    rdfs:label "MAXRPM" ;
    ns1:identificador "V.[ch].MPA.MAXRPM[set].xn" ;
    ns1:textoExtracto "MAXRPM Revoluciones máximas del motor. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para Mechatrolink velocidad e Inverter. Valores posibles: De 0 a 100000 rpm. Valor por defecto: 3000 rpm." ;
    ns1:valor "3000" .

