@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ModoOperacion_G00 a ns1:ModoOperacion ;
    rdfs:label "G00 (Avance rápido)"@es ;
    ns1:documentadoEn ns1:Tabla_444_ParametrosAvanceRapido ;
    ns1:monitoreaParametro ns1:Parametro_G00FEED ;
    ns1:textoExtracto "G00 | 10000"@es .

ns1:ModoOperacion_G01_G02 a ns1:ModoOperacion ;
    rdfs:label "G01, G02, etc. (Interpolación)"@es ;
    ns1:documentadoEn ns1:Tabla_444_ParametrosAvanceRapido ;
    ns1:textoExtracto "G01, G02, ꞏꞏꞏ | 6000"@es .

ns1:Parametro_FRAPIDEN a ns1:Parametro ;
    rdfs:label "FRAPIDEN (eje)"@es ;
    ns1:documentadoEn ns1:Tabla_444_ParametrosAvanceRapido ;
    ns1:textoExtracto "FRAPIDEN (eje)"@es ;
    ns1:valor 6000 .

ns1:Parametro_MAXFEED a ns1:Parametro ;
    rdfs:label "MAXFEED"@es ;
    ns1:documentadoEn ns1:Tabla_444_ParametrosAvanceRapido ;
    ns1:textoExtracto "El avance rápido podrá superar al definido en el parámetro MAXFEED del canal"@es ;
    ns1:valor 10000 .

ns1:Parametro_VPLC_F a ns1:Parametro ;
    rdfs:label "(V.)PLC.F"@es ;
    ns1:documentadoEn ns1:Tabla_444_ParametrosAvanceRapido ;
    ns1:textoExtracto "avance activo definido por PLC (variable (V.)PLC.F)"@es .

ns1:Parametro_G00FEED a ns1:Parametro ;
    rdfs:label "G00FEED (eje)"@es ;
    ns1:documentadoEn ns1:Tabla_444_ParametrosAvanceRapido ;
    ns1:identificador "(V.)PLC.G00FEED" ;
    ns1:textoExtracto "(V.)PLC.G00FEED | G00FEED (eje)"@es .

ns1:Tabla_444_ParametrosAvanceRapido a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de avance rápido (modo automático)"@es ;
    ns1:documentadoEn ns1:Pagina_198 ;
    ns1:textoExtracto "Variable. | Parámetros máquina. |  | Avance rápido. |  | (V.)PLC.G00FEED | G00FEED (eje) | FRAPIDEN (eje) | G00 | G01, G02, ꞏꞏꞏ"@es .

