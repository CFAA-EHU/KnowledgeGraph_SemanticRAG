@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:controla ns1:Parametro_FFGAIN,
        ns1:Parametro_FFWTYPE,
        ns1:Parametro_PROGAIN ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:Componente_EjeLineal a ns1:ComponenteMecanico ;
    rdfs:label "Eje lineal" ;
    ns1:controla ns1:Parametro_FFGAIN,
        ns1:Parametro_FFWTYPE,
        ns1:Parametro_PROGAIN ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:Componente_EjeRotativo a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo" ;
    ns1:controla ns1:Parametro_FFGAIN,
        ns1:Parametro_FFWTYPE,
        ns1:Parametro_PROGAIN ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:Sistema_ReguladorAnalogico a ns1:Sistema ;
    rdfs:label "Regulador analógico" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:tieneComponente ns1:Parametro_FFGAIN,
        ns1:Parametro_FFWTYPE,
        ns1:Parametro_PROGAIN .

ns1:Sistema_ReguladorSercos a ns1:Sistema ;
    rdfs:label "Regulador Sercos" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:tieneComponente ns1:Parametro_FFGAIN,
        ns1:Parametro_FFWTYPE,
        ns1:Parametro_PROGAIN .

ns1:Sistema_ReguladorSimulado a ns1:Sistema ;
    rdfs:label "Regulador simulado" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:tieneComponente ns1:Parametro_FFGAIN,
        ns1:Parametro_FFWTYPE,
        ns1:Parametro_PROGAIN .

ns1:Variable_V_MPA_FFGAIN a ns1:Parametro ;
    rdfs:label "Variable asociada a FFGAIN" ;
    ns1:identificador "(V.)[ch].MPA.FFGAIN[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.FFGAIN[set].xn" .

ns1:Variable_V_MPA_FFWTYPE a ns1:Parametro ;
    rdfs:label "Variable asociada a FFWTYPE" ;
    ns1:identificador "(V.)[ch].MPA.FFWTYPE[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.FFWTYPE[set].xn" .

ns1:Variable_V_MPA_PROGAIN a ns1:Parametro ;
    rdfs:label "Variable asociada a PROGAIN" ;
    ns1:identificador "(V.)[ch].MPA.PROGAIN[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.PROGAIN[set].xn" .

ns1:Parametro_FFGAIN a ns1:Parametro ;
    rdfs:label "Porcentaje de feed forward en automático (FFGAIN)" ;
    ns1:identificador "FFGAIN" ;
    ns1:monitoreaParametro ns1:Variable_V_MPA_FFGAIN ;
    ns1:textoExtracto "FFGAIN Porcentaje de feed forward en automático. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 120 %. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.FFGAIN[set].xn" ;
    ns1:valor 0 .

ns1:Parametro_FFWTYPE a ns1:Parametro ;
    rdfs:label "Tipo de pre-control (FFWTYPE)" ;
    ns1:identificador "FFWTYPE" ;
    ns1:monitoreaParametro ns1:Variable_V_MPA_FFWTYPE ;
    ns1:textoExtracto "FFWTYPE Tipo de pre-control. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: OFF / Feed Forward / AC-Forward / Feed Forward + AC-Forward. Valor por defecto: OFF. Variable asociada: (V.)[ch].MPA.FFWTYPE[set].xn" ;
    ns1:valor "OFF" .

ns1:Parametro_PROGAIN a ns1:Parametro ;
    rdfs:label "Ganancia proporcional (PROGAIN)" ;
    ns1:identificador "PROGAIN" ;
    ns1:monitoreaParametro ns1:Variable_V_MPA_PROGAIN ;
    ns1:textoExtracto "PROGAIN Ganancia proporcional. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0.0 a 100.0 (1000/min). Valor por defecto: 1. Variable asociada: (V.)[ch].MPA.PROGAIN[set].xn Este parámetro fija el error de seguimiento (diferencia entre la cota teórica instantánea y la posición real del eje) que se desea obtener para un determinado avance." ;
    ns1:valor "1.0"^^xsd:float .

