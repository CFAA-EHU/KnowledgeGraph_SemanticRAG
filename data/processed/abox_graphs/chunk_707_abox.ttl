@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_Automatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático" ;
    ns1:textoExtracto "Un eje que vaya a trabajar como eje independiente debería tener definido el mismo feed forward en los modos automáticos y manual" .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo manual" ;
    ns1:textoExtracto "Un eje que vaya a trabajar como eje independiente debería tener definido el mismo feed forward en los modos automáticos y manual" .

ns1:Parametro_FFGAIN a ns1:Parametro ;
    rdfs:label "MPA.FFGAIN" ;
    ns1:identificador "V.[ch].MPA.FFGAIN[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.FFGAIN[set].xn. El CNC sólo tiene en cuenta este parámetro cuando trabaja con feed forward; parámetro FFWTYPE si regulador analógico o simulado y parámetro OPMODEP si regulador Sercos." ;
    ns1:valor "0" .

ns1:Parametro_FFWTYPE a ns1:Parametro ;
    rdfs:label "FFWTYPE" ;
    ns1:textoExtracto "parámetro FFWTYPE si regulador analógico o simulado" .

ns1:Parametro_OPMODEP a ns1:Parametro ;
    rdfs:label "OPMODEP" ;
    ns1:textoExtracto "parámetro OPMODEP si regulador Sercos" .

