@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_Automatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático" ;
    ns1:textoExtracto "Un eje que vaya a trabajar como eje independiente debería tener definido el mismo feed forward en los modos automáticos y manual" .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo manual" ;
    ns1:textoExtracto "Un eje que vaya a trabajar como eje independiente debería tener definido el mismo feed forward en los modos automáticos y manual" .

ns1:Parametro_AvanceProgramado a ns1:Parametro ;
    rdfs:label "Avance programado (programmed feedrate)" ;
    ns1:textoExtracto "el resto de la consigna será proporcional al error de seguimiento ''. Programmed FFGAIN Feedrate" ;
    ns1:valor "programmed feedrate" .

ns1:Parametro_ErrorSeguimiento a ns1:Parametro ;
    rdfs:label "Error de seguimiento (ε)" ;
    ns1:textoExtracto "minimizando el error de seguimiento ''. El ajuste óptimo se consigue cuando se minimiza el error de seguimiento al máximo sin invertir su signo" ;
    ns1:valor "ε" .

ns1:Parametro_FFGAIN a ns1:Parametro ;
    rdfs:label "FFGAIN" ;
    ns1:textoExtracto "los parámetros FFGAIN y MANFFGAIN deberían ser iguales. Este parámetro permite mejorar el lazo de posición minimizando el error de seguimiento ''." ;
    ns1:valor "FFGAIN" .

ns1:Parametro_FeedForward a ns1:Parametro ;
    rdfs:label "Feed forward" ;
    ns1:textoExtracto "Un eje que vaya a trabajar como eje independiente debería tener definido el mismo feed forward en los modos automáticos y manual; es decir, los parámetros FFGAIN y MANFFGAIN deberían ser iguales." ;
    ns1:valor "FeedForward" .

ns1:Parametro_MANFFGAIN a ns1:Parametro ;
    rdfs:label "MANFFGAIN" ;
    ns1:textoExtracto "los parámetros FFGAIN y MANFFGAIN deberían ser iguales." ;
    ns1:valor "MANFFGAIN" .

ns1:Parametro_PROGAIN a ns1:Parametro ;
    rdfs:label "PROGAIN" ;
    ns1:textoExtracto "Programmed FFGAIN Feedrate  Analog Nominal PROGAIN output Position Actual position" ;
    ns1:valor "PROGAIN" .

