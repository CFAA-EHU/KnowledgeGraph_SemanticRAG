@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ModoOperacion_Automatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático" ;
    ns1:requiereMantenimiento ns1:Parametro_FFGAIN ;
    ns1:textoExtracto "A veces, el feed forward seleccionado para el modo automático puede ser demasiado elevado para el modo manual, donde no interesa llevar un control tan estricto del error de seguimiento." .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo manual" ;
    ns1:requiereMantenimiento ns1:Parametro_MANFFGAIN ;
    ns1:textoExtracto "A veces, el feed forward seleccionado para el modo automático puede ser demasiado elevado para el modo manual, donde no interesa llevar un control tan estricto del error de seguimiento." .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro cuando trabaja con feed forward; parámetro FFWTYPE si regulador analógico o simulado y parámetro OPMODEP si regulador Sercos." ;
    ns1:tieneComponente ns1:Parametro_ACFWFACTOR,
        ns1:Parametro_FFGAIN,
        ns1:Parametro_FFWTYPE,
        ns1:Parametro_MANFFGAIN,
        ns1:Parametro_OPMODEP .

ns1:Parametro_ACFWFACTOR a ns1:Parametro ;
    rdfs:label "ACFWFACTOR" ;
    ns1:identificador "ACFWFACTOR" ;
    ns1:textoExtracto "ACFWFACTOR Constante de tiempo de aceleración. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos velocidad y simulado. Valores posibles: De 0.001 a 1000000.0000 ms. Valor por defecto: 1000.0000 ms." ;
    ns1:valor "1000.0"^^xsd:float .

ns1:Parametro_FFWTYPE a ns1:Parametro ;
    rdfs:label "FFWTYPE" ;
    ns1:identificador "FFWTYPE" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro [MANFFGAIN] cuando trabaja con feed forward; parámetro FFWTYPE si regulador analógico o simulado y parámetro OPMODEP si regulador Sercos." .

ns1:Parametro_OPMODEP a ns1:Parametro ;
    rdfs:label "OPMODEP" ;
    ns1:identificador "OPMODEP" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro [MANFFGAIN] cuando trabaja con feed forward; parámetro FFWTYPE si regulador analógico o simulado y parámetro OPMODEP si regulador Sercos." .

ns1:Parametro_FFGAIN a ns1:Parametro ;
    rdfs:label "FFGAIN" ;
    ns1:identificador "FFGAIN" ;
    ns1:textoExtracto "Un eje que vaya a trabajar como eje independiente debería tener definido el mismo feed forward en los modos automáticos y manual; es decir, los parámetros FFGAIN y MANFFGAIN deberían ser iguales." .

ns1:Parametro_MANFFGAIN a ns1:Parametro ;
    rdfs:label "MANFFGAIN" ;
    ns1:identificador "MANFFGAIN" ;
    ns1:textoExtracto "MANFFGAIN Porcentaje de feed forward en manual. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y simulado. Valores posibles: De 0 a 120 %. Valor por defecto: 0." ;
    ns1:valor 0 .

