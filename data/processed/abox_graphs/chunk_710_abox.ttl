@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_ControlMaquina a ns1:Sistema ;
    rdfs:label "Sistema de control de la máquina"@es ;
    ns1:monitoreaParametro ns1:Parametro_SercosPosicion ;
    ns1:textoExtracto "el tiempo de respuesta del sistema es un valor (normalmente desconocido) que depende de las inercias de la máquina y del ajuste del regulador"@es .

ns1:Tarea_AjusteGanancias a ns1:TareaMantenimiento ;
    rdfs:label "Ajuste de ganancias del regulador"@es ;
    ns1:requiereMantenimiento ns1:Regulador_Inercia ;
    ns1:textoExtracto "probar con varios valores. El ajuste óptimo se consigue cuando se minimiza el error de seguimiento al máximo pero sin invertir los picos."@es .

ns1:Regulador_Inercia a ns1:ComponenteElectrico ;
    rdfs:label "Regulador de inercia"@es ;
    ns1:controla ns1:Parametro_SercosPosicion ;
    ns1:textoExtracto "depende de las inercias de la máquina y del ajuste del regulador"@es .

ns1:Parametro_SercosPosicion a ns1:Parametro ;
    rdfs:label "Parámetro Sercos posición"@es ;
    ns1:textoExtracto "Sin función en Sercos posición. Se aconseja asignar a este parámetro un valor del orden del tiempo de respuesta del sistema."@es ;
    ns1:valor "tiempo de respuesta del sistema (ajustable)"@es .

