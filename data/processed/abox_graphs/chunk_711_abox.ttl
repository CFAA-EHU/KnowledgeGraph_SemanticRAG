@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_Ganancia10um a ns1:Parametro ;
    rdfs:label "Ganancia AC-forward (10 µm por cuadro)"@es ;
    ns1:monitoreaParametro ns1:Sistema_AjusteGanancias ;
    ns1:textoExtracto "Respuesta del sistema sin ganancia AC-forward (10 µm por cuadro)."@es ;
    ns1:valor "10 µm" .

ns1:Parametro_Ganancia1um a ns1:Parametro ;
    rdfs:label "Ganancia AC-forward (1 µm por cuadro)"@es ;
    ns1:monitoreaParametro ns1:Sistema_AjusteGanancias ;
    ns1:textoExtracto "Respuesta del sistema con ganancia AC-forward (1 µm por cuadro)."@es ;
    ns1:valor "1 µm" .

ns1:Sistema_AjusteGanancias a ns1:Sistema ;
    rdfs:label "Sistema de ajuste de ganancias AC-forward"@es ;
    ns1:identificador "AC-forward" ;
    ns1:textoExtracto "Ajuste apropiado. Respuesta del sistema sin ganancia AC-forward (10 µm por cuadro). Picos invertidos; ajuste inapropiado. Respuesta del sistema con ganancia AC-forward (1 µm por cuadro)."@es .

