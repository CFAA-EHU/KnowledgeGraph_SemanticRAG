@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_Automatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático (AC-Forward)" ;
    ns1:habilitadoPor ns1:Parametro_ACFGAIN ;
    ns1:textoExtracto "Un eje que vaya a trabajar como eje independiente debería tener definido el mismo AC forward en los modos automáticos y manual; es decir, los parámetros ACFGAIN y MANACFGAIN deberían ser iguales." .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo manual (AC-Forward)" ;
    ns1:habilitadoPor ns1:Parametro_MANACFGAIN ;
    ns1:textoExtracto "Un eje que vaya a trabajar como eje independiente debería tener definido el mismo AC forward en los modos automáticos y manual; es decir, los parámetros ACFGAIN y MANACFGAIN deberían ser iguales." .

ns1:Parametro_ACFWFACTOR a ns1:Parametro ;
    rdfs:label "ACFWFACTOR" ;
    ns1:textoExtracto "La compensación de los retardos se realiza con el parámetro ACFWFACTOR, que tendrá un valor más alto que si se aplicaría el parámetro TRANSDELAY (aproximadamente la suma de TRANSDELAY y ACFWFACTOR en un ajuste analógico o Sercos velocidad)." ;
    ns1:valor "> TRANSDELAY" .

ns1:Sistema_ControlGap a ns1:Sistema ;
    rdfs:label "Sistema de control de gap (láser)" ;
    ns1:controla ns1:Parametro_TRANSDELAY ;
    ns1:textoExtracto "En máquinas láser con control de gap, el parámetro TRANSDELAY del eje asociado al sensor debe valor 0 (cero), para que la respuesta de la máquina sea igual con y sin control de gap." ;
    ns1:tieneComponente ns1:Sensor_EjeGap .

ns1:Parametro_ACFGAIN a ns1:Parametro ;
    rdfs:label "ACFGAIN" ;
    ns1:identificador "(V.)[ch].MPA.ACFGAIN[set].xn" ;
    ns1:solucionaFallo ns1:ErrorSeguimiento_Aceleracion ;
    ns1:textoExtracto "ACFGAIN Porcentaje de AC-Forward en automático. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 120 %. Valor por defecto: 0." ;
    ns1:valor "0-120%",
        "0"^^ns1:default .

ns1:Parametro_MANACFGAIN a ns1:Parametro ;
    rdfs:label "MANACFGAIN" ;
    ns1:identificador "(V.)[ch].MPA.MANACFGAIN[set].xn" ;
    ns1:solucionaFallo ns1:ErrorSeguimiento_Aceleracion ;
    ns1:textoExtracto "MANACFGAIN Porcentaje de AC-Forward en manual. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y simulado. Valores posibles: De 0 a 120 %. Valor por defecto: 0." ;
    ns1:valor "0-120%",
        "0"^^ns1:default .

ns1:ErrorSeguimiento_Aceleracion a ns1:DiagnosticoFallo ;
    rdfs:label "Error de seguimiento en aceleraciones" ;
    ns1:textoExtracto "los picos de error de seguimiento en aceleraciones y paradas van a ser mayores que en un ajuste con este parámetro." .

ns1:Parametro_TRANSDELAY a ns1:Parametro ;
    rdfs:label "TRANSDELAY" ;
    ns1:monitoreaParametro ns1:Sensor_EjeGap ;
    ns1:textoExtracto "el parámetro TRANSDELAY del eje asociado al sensor debe valor 0 (cero), para que la respuesta de la máquina sea igual con y sin control de gap." ;
    ns1:valor "0" .

ns1:Sensor_EjeGap a ns1:Sensor ;
    rdfs:label "Sensor de control de gap" ;
    ns1:monitoreaParametro ns1:Parametro_TRANSDELAY ;
    ns1:textoExtracto "el parámetro TRANSDELAY del eje asociado al sensor debe valor 0 (cero), para que la respuesta de la máquina sea igual con y sin control de gap." .

