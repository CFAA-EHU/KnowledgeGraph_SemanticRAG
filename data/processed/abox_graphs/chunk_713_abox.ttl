@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaControlAceleracion a ns1:Sistema ;
    rdfs:label "Sistema de control de aceleración" ;
    ns1:controla ns1:Parametro_ACFWGAIN,
        ns1:Parametro_FFGAIN,
        ns1:Parametro_PROGAIN ;
    ns1:textoExtracto "mejoran la respuesta del sistema en los cambios de aceleración" .

ns1:Parametro_ACFWGAIN a ns1:Parametro ;
    rdfs:label "ACFWGAIN (Programmed AC-forward Gain)" ;
    ns1:monitoreaParametro ns1:ErrorSeguimiento_e ;
    ns1:textoExtracto "Programmed ACFWGAIN Acceleration" .

ns1:Parametro_FFGAIN a ns1:Parametro ;
    rdfs:label "FFGAIN (Feedrate Gain)" ;
    ns1:monitoreaParametro ns1:ErrorSeguimiento_e ;
    ns1:textoExtracto "Programmed FFGAIN Feedrate" .

ns1:Parametro_PROGAIN a ns1:Parametro ;
    rdfs:label "PROGAIN (Proportional Gain)" ;
    ns1:monitoreaParametro ns1:ErrorSeguimiento_e ;
    ns1:textoExtracto "PROGAIN" .

ns1:ErrorSeguimiento_e a ns1:Parametro ;
    rdfs:label "Error de seguimiento (ε)" ;
    ns1:textoExtracto "minimizando el error de seguimiento \"\" en los arranques, frenadas y cambios de sentido" ;
    ns1:valor "ε" .

