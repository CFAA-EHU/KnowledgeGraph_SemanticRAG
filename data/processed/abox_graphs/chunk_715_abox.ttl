@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_G0ACDCJERK a ns1:Parametro ;
    rdfs:label "G0ACDCJERK" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "los movimientos en G0 dependen del parámetro G0ACDCJERK" .

ns1:Parametro_LACC1 a ns1:Parametro ;
    rdfs:label "LACC1" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "El CNC aplica los parámetros LACC1 y LACC2 a los movimientos en G1, G2 y G3" .

ns1:Parametro_LACC1G0 a ns1:Parametro ;
    rdfs:label "LACC1G0" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros LACC1G0, LACC2G0 y LFEEDG0" .

ns1:Parametro_LACC2 a ns1:Parametro ;
    rdfs:label "LACC2" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "El CNC aplica los parámetros LACC1 y LACC2 a los movimientos en G1, G2 y G3" .

ns1:Parametro_LACC2G0 a ns1:Parametro ;
    rdfs:label "LACC2G0" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros LACC1G0, LACC2G0 y LFEEDG0" .

ns1:Parametro_LFEED a ns1:Parametro ;
    rdfs:label "LFEED" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros LACC1, LACC2 y LFEED" .

ns1:Parametro_LFEEDG0 a ns1:Parametro ;
    rdfs:label "LFEEDG0" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros LACC1G0, LACC2G0 y LFEEDG0" .

ns1:Tabla_ConfiguracionG0ACDCJERK a ns1:Tabla ;
    rdfs:label "Configuración de G0ACDCJERK" ;
    ns1:documentadoEn ns1:Pagina_203_204 ;
    ns1:textoExtracto "G0ACDCJERK | Significado. | --- | --- | Sí. | Los movimientos en G0 utilizan los parámetros LACC1G0, LACC2G0 y LFEEDG0. | No. | Los movimientos en G0 utilizan los parámetros LACC1, LACC2 y LFEED." .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "El CNC aplica los parámetros LACC1 y LACC2 a los movimientos en G1, G2 y G3" .

