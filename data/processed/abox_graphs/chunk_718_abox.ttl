@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC" ;
    ns1:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1, G2 y G3." ;
    ns1:tieneComponente ns1:Parametro_ACCEL,
        ns1:Parametro_ACCELG0,
        ns1:Parametro_DECEL,
        ns1:Parametro_DECELG0,
        ns1:Parametro_G0ACDCJERK,
        ns1:Parametro_SLOPETYPE .

ns1:Tabla_G0ACDCJERK a ns1:Tabla ;
    rdfs:label "Tabla de configuración de G0ACDCJERK" ;
    ns1:documentadoEn ns1:Pagina_205_206_207 ;
    ns1:textoExtracto "| G0ACDCJERK | Significado. | --- | --- | Sí. | Los movimientos en G0 utilizan los parámetros ACCELG0 y DECELG0. | No. | Los movimientos en G0 utilizan los parámetros ACCEL y DECEL." .

ns1:Pagina_205_206_207 a ns1:Pagina ;
    rdfs:label "Páginas 205-207: Aceleración trapezoidal y seno cuadrado" ;
    ns1:identificador "205-207" ;
    ns1:textoExtracto "Sección 2.6.9 Aceleración trapezoidal y seno cuadrado." .

ns1:Parametro_ACCEL a ns1:Parametro ;
    rdfs:label "ACCEL (Aceleración)" ;
    ns1:identificador "ACCEL" ;
    ns1:textoExtracto "ACCEL Aceleración. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0.0010 a 600000000.0000 mm/s². Valor por defecto: 3000.0000 mm/s² / 118.12023 inch/s² / 3000.0000 grados/s²." ;
    ns1:valor "3000.0000" .

ns1:Parametro_ACCELG0 a ns1:Parametro ;
    rdfs:label "ACCELG0" ;
    ns1:identificador "ACCELG0" ;
    ns1:textoExtracto "Sí. Los movimientos en G0 utilizan los parámetros ACCELG0 y DECELG0." .

ns1:Parametro_DECEL a ns1:Parametro ;
    rdfs:label "DECEL (Deceleración)" ;
    ns1:identificador "DECEL" ;
    ns1:textoExtracto "DECEL Deceleración. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0.0010 a 600000000.0000 mm/s². Valor por defecto: 3000.0000 mm/s² / 118.12023 inch/s² / 3000.0000 grados/s²." ;
    ns1:valor "3000.0000" .

ns1:Parametro_DECELG0 a ns1:Parametro ;
    rdfs:label "DECELG0" ;
    ns1:identificador "DECELG0" ;
    ns1:textoExtracto "Sí. Los movimientos en G0 utilizan los parámetros ACCELG0 y DECELG0." .

ns1:Parametro_G0ACDCJERK a ns1:Parametro ;
    rdfs:label "G0ACDCJERK" ;
    ns1:identificador "G0ACDCJERK" ;
    ns1:textoExtracto "Los movimientos en G0 dependen del parámetro G0ACDCJERK." .

ns1:Parametro_SLOPETYPE a ns1:Parametro ;
    rdfs:label "SLOPETYPE" ;
    ns1:identificador "SLOPETYPE" ;
    ns1:textoExtracto "Los parámetros ACCEL y DECEL fijan los valores de la aceleración cuando ésta es trapezoidal o seno cuadrado (parámetro SLOPETYPE)." .

