    ns1:identificador "DECELG0" ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCELG0 y DECELG0." .

ns1:Tabla_ParametrosAceleracionG0 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de aceleración en G0"@es ;
    ns1:documentadoEn ns1:Pagina_205_206_207 ;
    ns1:textoExtracto "G0ACDCJERK | Significado... Los movimientos en G0 utilizan los parámetros ACCELG0 y DECELG0... Los movimientos en G0 utilizan los parámetros ACCEL y DECEL."@es ;
    ns1:tieneComponente ns1:Parametro_G0ACDCJERK .

ns1:Pagina_205_206_207 a ns1:Pagina ;
    rdfs:label "Páginas 205-207 (Sección 2.6.9)"@es ;
