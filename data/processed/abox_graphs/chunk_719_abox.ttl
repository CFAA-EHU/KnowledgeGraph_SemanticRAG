ns1:Parametro_ACCEL a ns1:Parametro ;
    rdfs:label "ACCEL" ;
    ns1:identificador "ACCEL" ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCEL y DECEL." .

