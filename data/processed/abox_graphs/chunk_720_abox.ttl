@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:controla ns1:Parametro_ACCEL,
        ns1:Parametro_ACCJERK,
        ns1:Parametro_DECEL,
        ns1:Parametro_DECJERK ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:Componente_EjeLineal a ns1:ComponenteMecanico ;
    rdfs:label "Eje lineal" ;
    ns1:controla ns1:Parametro_ACCEL,
        ns1:Parametro_ACCJERK,
        ns1:Parametro_DECEL,
        ns1:Parametro_DECJERK ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:Componente_EjeRotativo a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo" ;
    ns1:controla ns1:Parametro_ACCEL,
        ns1:Parametro_ACCJERK,
        ns1:Parametro_DECEL,
        ns1:Parametro_DECJERK ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:Sistema_ReguladorAnalogico a ns1:Sistema ;
    rdfs:label "Regulador analógico" ;
    ns1:monitoreaParametro ns1:Parametro_ACCJERK,
        ns1:Parametro_DECJERK ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:Sistema_Sercos a ns1:Sistema ;
    rdfs:label "Sercos" ;
    ns1:monitoreaParametro ns1:Parametro_ACCJERK,
        ns1:Parametro_DECJERK ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:Sistema_Simulado a ns1:Sistema ;
    rdfs:label "Sistema simulado" ;
    ns1:monitoreaParametro ns1:Parametro_ACCJERK,
        ns1:Parametro_DECJERK ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:Parametro_ACCEL a ns1:Parametro ;
    rdfs:label "ACCEL" ;
    ns1:textoExtracto "La aceleración pasa a ser constante y su valor es ACCEL." .

ns1:Parametro_DECEL a ns1:Parametro ;
    rdfs:label "DECEL" ;
    ns1:textoExtracto "La deceleración pasa a ser constante y su valor es DECEL." .

ns1:Parametro_ACCJERK a ns1:Parametro ;
    rdfs:label "ACCJERK" ;
    ns1:identificador "MPA.ACCJERK[set].xn" ;
    ns1:textoExtracto "ACCJERK Jerk de aceleración. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0.0010 a 6E+011 mm/s³. Valores posibles (2): De 0.00004 a 2.362E+010 inch/s³. Valores posibles (3): De 0.0010 a 6E+011 mm/s³. Valor por defecto: 45000.000 mm/s³ / 1771.65354 inch/s³ / 45000.000 grados/s³." ;
    ns1:valor "45000.000" .

ns1:Parametro_DECJERK a ns1:Parametro ;
    rdfs:label "DECJERK" ;
    ns1:identificador "MPA.DECJERK" ;
    ns1:textoExtracto "DECJERK Jerk de deceleración. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." .

