@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC" ;
    ns1:controla ns1:ModoOperacion_G0,
        ns1:ModoOperacion_G1,
        ns1:ModoOperacion_G2,
        ns1:ModoOperacion_G3 ;
    ns1:monitoreaParametro ns1:Parametro_ACCEL,
        ns1:Parametro_DECEL,
        ns1:Parametro_FFGain,
        ns1:Parametro_G0ACDCJERK ;
    ns1:textoExtracto "la máquina vaya más suave en los incrementos o decrementos de velocidades pequeñas" .

ns1:ModoOperacion_G33 a ns1:ModoOperacion ;
    rdfs:label "G33 (Roscado)" ;
    ns1:textoExtracto "movimientos con roscado (G33)" .

ns1:ModoOperacion_HSC_FAST a ns1:ModoOperacion ;
    rdfs:label "HSC FAST" ;
    ns1:textoExtracto "movimientos con HSC FAST" .

ns1:ModoOperacion_G0 a ns1:ModoOperacion ;
    rdfs:label "G0 (Posicionamiento rápido)" ;
    ns1:textoExtracto "movimientos en G0" .

ns1:ModoOperacion_G1 a ns1:ModoOperacion ;
    rdfs:label "G1 (Interpolación lineal)" ;
    ns1:textoExtracto "movimientos en G1" .

ns1:ModoOperacion_G2 a ns1:ModoOperacion ;
    rdfs:label "G2 (Interpolación circular horaria)" ;
    ns1:textoExtracto "movimientos en G2" .

ns1:ModoOperacion_G3 a ns1:ModoOperacion ;
    rdfs:label "G3 (Interpolación circular antihoraria)" ;
    ns1:textoExtracto "movimientos en G3" .

ns1:Parametro_ACCEL a ns1:Parametro ;
    rdfs:label "ACCEL" ;
    ns1:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1, G2 y G3" .

ns1:Parametro_DECEL a ns1:Parametro ;
    rdfs:label "DECEL" ;
    ns1:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1, G2 y G3" .

ns1:Parametro_FFGain a ns1:Parametro ;
    rdfs:label "FFGAIN" ;
    ns1:textoExtracto "valores de FFGAIN cercanos al 100%" ;
    ns1:valor "100%" .

ns1:Parametro_G0ACDCJERK a ns1:Parametro ;
    rdfs:label "G0ACDCJERK" ;
    ns1:textoExtracto "los movimientos en G0 dependen del parámetro G0ACDCJERK" .

