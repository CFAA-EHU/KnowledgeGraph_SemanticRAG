@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_ParametrosAceleracion a ns1:Tabla ;
    rdfs:label "Parámetros de aceleración trapezoidal y seno cuadrado" ;
    ns1:detalladoEnEsquema ns1:Pagina_205_206_207 ;
    ns1:documentadoEn ns1:Pagina_205_206_207 ;
    ns1:textoExtracto "| G0ACDCJERK | Significado. | --- | --- | Sí. | Los movimientos en G0 utilizan los parámetros ACCJERKG0 y DECJERKG0. | No. | Los movimientos en G0 utilizan los parámetros ACCJERK y DECJERK." ;
    ns1:tieneComponente ns1:Parametro_ACCEL,
        ns1:Parametro_ACCJERK,
        ns1:Parametro_ACCJERKG0,
        ns1:Parametro_DECJERK,
        ns1:Parametro_DECJERKG0,
        ns1:Parametro_G00FEED,
        ns1:Parametro_G0ACDCJERK .

ns1:Parametro_ACCEL a ns1:Parametro ;
    rdfs:label "ACCEL" ;
    ns1:identificador "ACCEL" ;
    ns1:textoExtracto "ACCEL = 2 x ACCJERK = 2 x 60 x 0,5" ;
    ns1:valor "2 x ACCJERK" .

ns1:Parametro_ACCJERK a ns1:Parametro ;
    rdfs:label "ACCJERK" ;
    ns1:identificador "ACCJERK" ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCJERK y DECJERK." .

ns1:Parametro_ACCJERKG0 a ns1:Parametro ;
    rdfs:label "ACCJERKG0" ;
    ns1:identificador "ACCJERKG0" ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCJERKG0 y DECJERKG0." .

ns1:Parametro_DECJERK a ns1:Parametro ;
    rdfs:label "DECJERK" ;
    ns1:identificador "DECJERK" ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCJERK y DECJERK." .

ns1:Parametro_DECJERKG0 a ns1:Parametro ;
    rdfs:label "DECJERKG0" ;
    ns1:identificador "DECJERKG0" ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCJERKG0 y DECJERKG0." .

ns1:Parametro_G00FEED a ns1:Parametro ;
    rdfs:label "G00FEED" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "El eje se puede parametrizar con aceleración máxima y jerk mínimo para alcanzar G00FEED." .

ns1:Parametro_G0ACDCJERK a ns1:Parametro ;
    rdfs:label "G0ACDCJERK" ;
    ns1:identificador "G0ACDCJERK" ;
    ns1:textoExtracto "G0ACDCJERK | Significado. Los movimientos en G0 utilizan los parámetros ACCJERKG0 y DECJERKG0 (si Sí) o ACCJERK y DECJERK (si No)." .

ns1:Pagina_205_206_207 a ns1:Pagina ;
    rdfs:label "Páginas 205-207: Aceleración trapezoidal y seno cuadrado" ;
    ns1:identificador "205-207" ;
    ns1:textoExtracto "Ejemplo. Aceleración trapezoidal. [...] Ejemplo. Aceleración seno cuadrado. [...]" .

