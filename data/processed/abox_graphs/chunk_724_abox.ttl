@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_463_ParametrosAceleracion a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de aceleración trapezoidal y seno cuadrado" ;
    ns1:textoExtracto "G00FEED ACCEL ACCJERK t t t t/3 t t/3 t t/3 t 3 G00FEED ACCEL ACCEL = x ACCJERK = 3 x 2 60 x 0,5 0,5" ;
    ns1:tieneComponente ns1:Parametro_ACCEL,
        ns1:Parametro_ACCJERK,
        ns1:Parametro_G00FEED .

ns1:Parametro_ACCEL a ns1:Parametro ;
    rdfs:label "ACCEL" ;
    ns1:identificador "ACCEL" ;
    ns1:textoExtracto "ACCEL = x" ;
    ns1:valor "x" .

ns1:Parametro_ACCJERK a ns1:Parametro ;
    rdfs:label "ACCJERK" ;
    ns1:identificador "ACCJERK" ;
    ns1:textoExtracto "ACCJERK = 3 x" ;
    ns1:valor "3 x" .

ns1:Parametro_G00FEED a ns1:Parametro ;
    rdfs:label "G00FEED" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "G00FEED ACCEL ACCJERK" .

