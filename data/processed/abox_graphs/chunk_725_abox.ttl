@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Tabla_ParametrosG0 a ns1:Tabla ;
    rdfs:label "Parámetros de aceleración para movimientos en G0" ;
    ns1:textoExtracto "| Parámetros a utilizar en los movimientos en G0. | G0ACDCJERK |  | --- | --- | --- | No | Sí | Aceleración lineal (movimientos en G0). • Aceleración del primer tramo. • Aceleración del segundo tramo. • Velocidad de cambio de aceleración. | LACC1 LACC2 LFEED | LACC1G0 LACC2G0 LFEEDG0 | Aceleración trapezoidal y seno cuadrado (movimientos en G0). • Aceleración. • Deceleración. • Jerk de aceleración. • Jerk de deceleración. | ACCEL DECEL ACCJERK DECJERK | ACCELG0 DECELG0 ACCJERKG0 DECJERKG0 |" ;
    ns1:tieneComponente ns1:Parametro_ACCELG0,
        ns1:Parametro_ACCJERKG0,
        ns1:Parametro_DECELG0,
        ns1:Parametro_DECJERKG0,
        ns1:Parametro_G0ACDCJERK,
        ns1:Parametro_LACC1G0,
        ns1:Parametro_LACC2G0,
        ns1:Parametro_LFEEDG0 .

ns1:Parametro_ACCELG0 a ns1:Parametro ;
    rdfs:label "ACCELG0 (Aceleración trapezoidal en G0)" ;
    ns1:identificador "ACCELG0" ;
    ns1:textoExtracto "Aceleración trapezoidal y seno cuadrado (movimientos en G0). • Aceleración." .

ns1:Parametro_ACCJERKG0 a ns1:Parametro ;
    rdfs:label "ACCJERKG0 (Jerk de aceleración en G0)" ;
    ns1:identificador "ACCJERKG0" ;
    ns1:textoExtracto "Aceleración trapezoidal y seno cuadrado (movimientos en G0). • Jerk de aceleración." .

ns1:Parametro_DECELG0 a ns1:Parametro ;
    rdfs:label "DECELG0 (Deceleración trapezoidal en G0)" ;
    ns1:identificador "DECELG0" ;
    ns1:textoExtracto "Aceleración trapezoidal y seno cuadrado (movimientos en G0). • Deceleración." .

ns1:Parametro_DECJERKG0 a ns1:Parametro ;
    rdfs:label "DECJERKG0 (Jerk de deceleración en G0)" ;
    ns1:identificador "DECJERKG0" ;
    ns1:textoExtracto "Aceleración trapezoidal y seno cuadrado (movimientos en G0). • Jerk de deceleración." .

ns1:Parametro_G0ACDCJERK a ns1:Parametro ;
    rdfs:label "G0ACDCJERK" ;
    ns1:identificador "G0ACDCJERK" ;
    ns1:textoExtracto "G0ACDCJERK Ampliación de parámetros si G0. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPA.G0ACDCJERK[set].xn" ;
    ns1:valor "No"^^xsd:string .

ns1:Parametro_LACC1G0 a ns1:Parametro ;
    rdfs:label "LACC1G0 (Aceleración del primer tramo en G0)" ;
    ns1:identificador "LACC1G0" ;
    ns1:textoExtracto "Aceleración lineal (movimientos en G0). • Aceleración del primer tramo." .

ns1:Parametro_LACC2G0 a ns1:Parametro ;
    rdfs:label "LACC2G0 (Aceleración del segundo tramo en G0)" ;
    ns1:identificador "LACC2G0" ;
    ns1:textoExtracto "Aceleración lineal (movimientos en G0). • Aceleración del segundo tramo." .

ns1:Parametro_LFEEDG0 a ns1:Parametro ;
    rdfs:label "LFEEDG0 (Velocidad de cambio de aceleración en G0)" ;
    ns1:identificador "LFEEDG0" ;
    ns1:textoExtracto "Aceleración lineal (movimientos en G0). • Velocidad de cambio de aceleración." .

