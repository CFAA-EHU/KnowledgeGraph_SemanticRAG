@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_AvanceG0 a ns1:Parametro ;
    rdfs:label "Parámetro de avance para cambio de aceleración en G0"@es ;
    ns1:identificador "LACC1G0",
        "LACC2G0" ;
    ns1:monitoreaParametro ns1:Parametro_LACC1G0,
        ns1:Parametro_LACC2G0 ;
    ns1:textoExtracto "definido en este parámetro se cambia la aceleración de LACC1G0 a LACC2G0. Durante la fase de deceleración, cuando se alcanza el avance definido en este parámetro se cambia la aceleración de LACC2G0 a LACC1G0."@es .

ns1:Parametro_LACC1G0 a ns1:Parametro ;
    rdfs:label "LACC1G0"@es ;
    ns1:identificador "LACC1G0" ;
    ns1:textoExtracto "aceleración de LACC1G0"@es ;
    ns1:valor "aceleración inicial en movimientos G0"@es .

ns1:Parametro_LACC2G0 a ns1:Parametro ;
    rdfs:label "LACC2G0"@es ;
    ns1:identificador "LACC2G0" ;
    ns1:textoExtracto "aceleración de LACC2G0"@es ;
    ns1:valor "aceleración intermedia en movimientos G0"@es .

