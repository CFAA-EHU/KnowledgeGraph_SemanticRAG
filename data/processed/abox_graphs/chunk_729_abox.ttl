@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Param_ACCELG0 a ns1:Parametro ;
    rdfs:label "ACCELG0" ;
    ns1:identificador "ACCELG0" ;
    ns1:monitoreaParametro ns1:Maquina_CNC ;
    ns1:textoExtracto "ACCELG0 Aceleración (movimientos en G0). Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "4000.0000 mm/s² / 157.48031 inch/s² / 4000.0000 grados/s²"^^xsd:string .

ns1:Param_DECELG0 a ns1:Parametro ;
    rdfs:label "DECELG0" ;
    ns1:identificador "DECELG0" ;
    ns1:monitoreaParametro ns1:Maquina_CNC ;
    ns1:textoExtracto "DECELG0 Deceleración (movimientos en G0). Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "4000.0000 mm/s² / 157.48031 inch/s² / 4000.0000 grados/s²"^^xsd:string .

ns1:Param_G0ACDCJERK a ns1:Parametro ;
    rdfs:label "G0ACDCJERK" ;
    ns1:identificador "G0ACDCJERK" ;
    ns1:monitoreaParametro ns1:Maquina_CNC ;
    ns1:textoExtracto "los movimientos en G0 dependen del parámetro G0ACDCJERK." .

ns1:Param_SLOPETYPE a ns1:Parametro ;
    rdfs:label "SLOPETYPE" ;
    ns1:identificador "SLOPETYPE" ;
    ns1:textoExtracto "Los parámetros ACCEL y DECEL fijan los valores de la aceleración cuando ésta es trapezoidal o seno cuadrado (parámetro SLOPETYPE)." .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1, G2 y G3; los movimientos en G0 dependen del parámetro G0ACDCJERK." ;
    ns1:tieneComponente ns1:Param_ACCELG0,
        ns1:Param_DECELG0,
        ns1:Param_G0ACDCJERK,
        ns1:Param_SLOPETYPE .

