@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_ACCEL a ns1:Parametro ;
    rdfs:label "ACCEL" ;
    ns1:documentadoEn ns1:Tabla_ParametrosG0_469 ;
    ns1:identificador "ACCEL" ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCEL y DECEL."@es .

ns1:Parametro_ACCELG0 a ns1:Parametro ;
    rdfs:label "ACCELG0" ;
    ns1:documentadoEn ns1:Tabla_ParametrosG0_469 ;
    ns1:identificador "ACCELG0" ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCELG0 y DECELG0."@es .

ns1:Parametro_ACCJERKG0 a ns1:Parametro ;
    rdfs:label "ACCJERKG0" ;
    ns1:documentadoEn ns1:Tabla_ParametrosG0_469 ;
    ns1:identificador "ACCJERKG0" ;
    ns1:monitoreaParametro ns1:Maquina_Controlada ;
    ns1:textoExtracto "ACCJERKG0 Jerk de aceleración (movimientos en G0)... Valor por defecto: 55000.000 mm/s³ / 2165.35433 inch/s³ / 55000.000 grados/s³."@es ;
    ns1:valor "55000.000" .

ns1:Parametro_DECEL a ns1:Parametro ;
    rdfs:label "DECEL" ;
    ns1:documentadoEn ns1:Tabla_ParametrosG0_469 ;
    ns1:identificador "DECEL" ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCEL y DECEL."@es .

ns1:Parametro_DECELG0 a ns1:Parametro ;
    rdfs:label "DECELG0" ;
    ns1:documentadoEn ns1:Tabla_ParametrosG0_469 ;
    ns1:identificador "DECELG0" ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCELG0 y DECELG0."@es .

ns1:Parametro_DECJERKG0 a ns1:Parametro ;
    rdfs:label "DECJERKG0" ;
    ns1:documentadoEn ns1:Tabla_ParametrosG0_469 ;
    ns1:identificador "DECJERKG0" ;
    ns1:monitoreaParametro ns1:Maquina_Controlada ;
    ns1:textoExtracto "DECJERKG0 Jerk de deceleración (movimientos en G0)... Valor por defecto: 55000.000 mm/s³ / 2165.35433 inch/s³ / 55000.000 grados/s³."@es ;
    ns1:valor "55000.000" .

ns1:Maquina_Controlada a ns1:Maquina ;
    rdfs:label "Máquina con control de movimientos G0"@es ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado."@es .

ns1:Tabla_ParametrosG0_469 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de jerk en movimientos G0"@es ;
    ns1:documentadoEn ns1:Pagina_210_211 ;
    ns1:textoExtracto "G0ACDCJERK | Significado... Los parámetros ACCJERKG0 y DECJERKG0 definen la pendiente de la aceleración y deceleración."@es .

