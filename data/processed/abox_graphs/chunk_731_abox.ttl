@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_ACCEL a ns1:Parametro ;
    rdfs:label "Parámetro ACCEL" ;
    ns1:monitoreaParametro ns1:Maquina_CNC ;
    ns1:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1, G2 y G3" .

ns1:Parametro_DECEL a ns1:Parametro ;
    rdfs:label "Parámetro DECEL" ;
    ns1:monitoreaParametro ns1:Maquina_CNC ;
    ns1:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1, G2 y G3" .

ns1:Parametro_G0ACDCJERK a ns1:Parametro ;
    rdfs:label "Parámetro G0ACDCJERK" ;
    ns1:monitoreaParametro ns1:Maquina_CNC ;
    ns1:textoExtracto "los movimientos en G0 dependen del parámetro G0ACDCJERK" .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Máquina CNC" ;
    ns1:textoExtracto "la máquina vaya más suave en los incrementos o decrementos de velocidades pequeñas y con valores de FFGAIN cercanos al 100%" .

