@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_G0 a ns1:ModoOperacion ;
    rdfs:label "Movimiento rápido (G0)"@es ;
    ns1:identificador "G0" ;
    ns1:monitoreaParametro ns1:Parametro_ACCJERK,
        ns1:Parametro_ACCJERKG0,
        ns1:Parametro_DECJERK,
        ns1:Parametro_DECJERKG0 ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCJERKG0 y DECJERKG0. [...] Los movimientos en G0 utilizan los parámetros ACCJERK y DECJERK."@es .

ns1:Parametro_ACCJERK a ns1:Parametro ;
    rdfs:label "ACCJERK" ;
    ns1:documentadoEn ns1:Tabla_G0ACDCJERK ;
    ns1:identificador "ACCJERK" ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCJERK y DECJERK."@es .

ns1:Parametro_ACCJERKG0 a ns1:Parametro ;
    rdfs:label "ACCJERKG0" ;
    ns1:documentadoEn ns1:Tabla_G0ACDCJERK ;
    ns1:identificador "ACCJERKG0" ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCJERKG0 y DECJERKG0."@es .

ns1:Parametro_DECJERK a ns1:Parametro ;
    rdfs:label "DECJERK" ;
    ns1:documentadoEn ns1:Tabla_G0ACDCJERK ;
    ns1:identificador "DECJERK" ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCJERK y DECJERK."@es .

ns1:Parametro_DECJERKG0 a ns1:Parametro ;
    rdfs:label "DECJERKG0" ;
    ns1:documentadoEn ns1:Tabla_G0ACDCJERK ;
    ns1:identificador "DECJERKG0" ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCJERKG0 y DECJERKG0."@es .

ns1:Tabla_G0ACDCJERK a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de aceleración/desaceleración en G0"@es ;
    ns1:documentadoEn ns1:Pagina_210_211 ;
    ns1:textoExtracto "G0ACDCJERK | Significado. [...] Los movimientos en G0 utilizan los parámetros ACCJERKG0 y DECJERKG0. [...] Los movimientos en G0 utilizan los parámetros ACCJERK y DECJERK."@es .

