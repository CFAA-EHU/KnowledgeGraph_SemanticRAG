@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_ConfiguracionHSC a ns1:Parametro ;
    rdfs:label "Parámetro de configuración HSC" ;
    ns1:documentadoEn ns1:Tabla_ParametrosHSC ;
    ns1:textoExtracto "Este parámetro muestra la tabla para definir el modo HSC de trabajo" .

ns1:ModoOperacion_HSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC" ;
    ns1:identificador "HSC" ;
    ns1:textoExtracto "modo HSC de trabajo" .

ns1:Tabla_ParametrosHSC a ns1:Tabla ;
    rdfs:label "Tabla de parámetros del modo HSC" ;
    ns1:documentadoEn ns1:ModoOperacion_HSC ;
    ns1:textoExtracto "HSC Tabla de parámetros del modo HSC. Este parámetro muestra la tabla para definir el modo HSC de trabajo." .

