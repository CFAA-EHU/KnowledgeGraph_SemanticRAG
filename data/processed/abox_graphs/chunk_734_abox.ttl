@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_HSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC" ;
    ns1:textoExtracto "Configuración del modo HSC" ;
    ns1:tieneComponente ns1:Parametro_CONTERROR,
        ns1:Parametro_CORNERACC,
        ns1:Parametro_CORNERJERK,
        ns1:Parametro_CURVACC,
        ns1:Parametro_CURVJERK,
        ns1:Parametro_FASTACC,
        ns1:Parametro_MAXERROR .

ns1:Parametro_CONTERROR a ns1:Parametro ;
    rdfs:label "CONTERROR" ;
    ns1:identificador "CONTERROR" ;
    ns1:textoExtracto "Tolerancia por eje." ;
    ns1:valor "Tolerancia por eje" .

ns1:Parametro_CORNERACC a ns1:Parametro ;
    rdfs:label "CORNERACC" ;
    ns1:identificador "CORNERACC" ;
    ns1:textoExtracto "Aceleración máxima permitida en las esquinas." ;
    ns1:valor "Aceleración máxima (esquinas)" .

ns1:Parametro_CORNERJERK a ns1:Parametro ;
    rdfs:label "CORNERJERK" ;
    ns1:identificador "CORNERJERK" ;
    ns1:textoExtracto "Jerk máximo permitido en las esquinas." ;
    ns1:valor "Jerk máximo (esquinas)" .

ns1:Parametro_CURVACC a ns1:Parametro ;
    rdfs:label "CURVACC" ;
    ns1:identificador "CURVACC" ;
    ns1:textoExtracto "Aceleración máxima permitida en curvatura." ;
    ns1:valor "Aceleración máxima (curvatura)" .

ns1:Parametro_CURVJERK a ns1:Parametro ;
    rdfs:label "CURVJERK" ;
    ns1:identificador "CURVJERK" ;
    ns1:textoExtracto "Jerk máximo permitido en curvatura." ;
    ns1:valor "Jerk máximo (curvatura)" .

ns1:Parametro_FASTACC a ns1:Parametro ;
    rdfs:label "FASTACC" ;
    ns1:identificador "FASTACC" ;
    ns1:textoExtracto "Aceleración máxima permitida (modo FAST)." ;
    ns1:valor "Aceleración máxima (modo FAST)" .

ns1:Parametro_MAXERROR a ns1:Parametro ;
    rdfs:label "MAXERROR" ;
    ns1:identificador "MAXERROR" ;
    ns1:textoExtracto "Error de posición." ;
    ns1:valor "Error de posición" .

