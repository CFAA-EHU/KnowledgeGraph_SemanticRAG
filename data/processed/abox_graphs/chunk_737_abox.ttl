@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ModoOperacion_HSC a ns1:ModoOperacion ;
    rdfs:label "Modo de alta velocidad (HSC)" ;
    ns1:monitoreaParametro ns1:Parametro_CURVJERK,
        ns1:Parametro_FASTACC,
        ns1:Parametro_MAXERROR ;
    ns1:textoExtracto "Configuración del modo HSC" .

ns1:Parametro_CURVJERK a ns1:Parametro ;
    rdfs:label "Jerk máximo en curvatura (CURVJERK)" ;
    ns1:identificador "MPA.CURVJERK" ;
    ns1:textoExtracto "permitido en curvatura. [...] Variable asociada: (V.)[ch].MPA.CURVJERK[set].xn Si este parámetro se define con valor ꞏ0ꞏ, se respeta el jerk máximo del eje." ;
    ns1:valor "0"^^xsd:string .

ns1:Parametro_FASTACC a ns1:Parametro ;
    rdfs:label "Aceleración máxima en modo FAST (FASTACC)" ;
    ns1:identificador "MPA.FASTACC" ;
    ns1:textoExtracto "FASTACC Aceleración máxima permitida (modo FAST). [...] Variable asociada: (V.)[ch].MPA.FASTACC[set].xn Si este parámetro se define con valor ꞏ0ꞏ, se respeta la aceleración máxima del eje." ;
    ns1:valor "0"^^xsd:string .

ns1:Parametro_MAXERROR a ns1:Parametro ;
    rdfs:label "Error máximo de posición (MAXERROR)" ;
    ns1:identificador "MPA.MAXERROR" ;
    ns1:textoExtracto "MAXERROR Error de posición. [...] Máximo error de posición del eje en HSC cuando trabaja fuera del plano/triedo." ;
    ns1:valor "0.1000 mm / 0.00394 inch / 0.1000 grados"^^xsd:string .

