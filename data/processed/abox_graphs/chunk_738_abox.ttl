@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_HSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC (High Speed Cutting)"@es ;
    ns1:textoExtracto "Configuración del modo HSC: parámetros para mecanizado en 5 ejes y control de error de posición."@es ;
    ns1:tieneComponente ns1:Parametro_CONTERROR_HSC,
        ns1:Parametro_MAXERROR_HSC .

ns1:Parametro_CONTERROR_HSC a ns1:Parametro ;
    rdfs:label "Tolerancia por eje para suavizado de trayectoria n-dimensional (CONTERROR)"@es ;
    ns1:identificador "MPA.CONTERROR[set].xn" ;
    ns1:textoExtracto "Tolerancia por eje para el suavizado de la trayectoria n-dimensional generada. Parámetro válido para ejes lineales, rotativos y cabezales. Valor por defecto: 0.1000 mm/º. Variable asociada: (V.)[ch].MPA.CONTERROR[set].xn"@es ;
    ns1:valor "0.1000" .

ns1:Parametro_MAXERROR_HSC a ns1:Parametro ;
    rdfs:label "Máximo error de posición del eje en HSC"@es ;
    ns1:identificador "MPA.MAXERROR[set].xn" ;
    ns1:textoExtracto "Máximo error de posición del eje en HSC cuando trabaja fuera del plano/triedo. Valor por defecto: 0.1000 mm / 0.00394 inch / 0.1000 grados. Variable asociada: (V.)[ch].MPA.MAXERROR[set].xn"@es ;
    ns1:valor "0.1000" .

