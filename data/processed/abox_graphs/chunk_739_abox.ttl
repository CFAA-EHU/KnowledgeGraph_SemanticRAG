@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_I0TYPE a ns1:Parametro ;
    rdfs:label "I0TYPE (Tipo de I0)" ;
    ns1:monitoreaParametro ns1:Variable_MPA_I0TYPE ;
    ns1:textoExtracto "I0TYPE Tipo de I0. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: No codificado / Codificado creciente / Codificado decreciente. Valor por defecto: No codificado." ;
    ns1:valor "No codificado" .

ns1:Variable_MPA_I0TYPE a ns1:Parametro ;
    rdfs:label "Variable MPA.I0TYPE[set].xn" ;
    ns1:identificador "MPA.I0TYPE[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.I0TYPE[set].xn" .

