@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Encoder a ns1:Sensor ;
    rdfs:label "Encoder"@es ;
    ns1:textoExtracto "El encóder puede tener una o varias marcas de I0 [...] El encóder referencia la posición con esta marca de I0" ;
    ns1:tieneComponente ns1:MarcaI0 .

ns1:MicroInterruptorReferencia a ns1:ComponenteElectrico ;
    rdfs:label "Microinterruptor de referencia (home-switch)"@es ;
    ns1:textoExtracto "por ejemplo, con un micro (home-switch)" .

ns1:ModoReferencia_CodificadoCreciente a ns1:ModoOperacion ;
    rdfs:label "Modo de referencia codificado creciente"@es ;
    ns1:documentadoEn ns1:Tabla_ModosReferenciaEncoder ;
    ns1:textoExtracto "El encóder dispone de varias marcas de I0, separadas entre sí diferentes distancias, siguiendo una fórmula matemática. El encóder referencia la posición tras sobrepasar dos marcas de I0 contiguas, es decir, tras recorrer unos pocos milímetros." .

ns1:ModoReferencia_CodificadoDecreciente a ns1:ModoOperacion ;
    rdfs:label "Modo de referencia codificado decreciente"@es ;
    ns1:documentadoEn ns1:Tabla_ModosReferenciaEncoder ;
    ns1:textoExtracto "La codificación de I0 será decreciente si la distancia entre las marcas de I0 disminuye según el sentido de movimiento, durante la búsqueda de referencia." .

ns1:ModoReferencia_Normal a ns1:ModoOperacion ;
    rdfs:label "Modo de referencia normal"@es ;
    ns1:documentadoEn ns1:Tabla_ModosReferenciaEncoder ;
    ns1:textoExtracto "El encóder puede tener una o varias marcas de I0, pero sólo hay una marca seleccionada (por ejemplo, con un micro (home-switch)). El encóder referencia la posición con esta marca de I0. En función de la posición inicial, pueden ser necesarios largos recorridos hasta referenciar la posición." .

ns1:MarcaI0 a ns1:ComponenteElectrico ;
    rdfs:label "Marca de referencia I0"@es ;
    ns1:textoExtracto "marcas de I0" .

ns1:Tabla_ModosReferenciaEncoder a ns1:Tabla ;
    rdfs:label "Tabla de modos de referencia de encoder"@es ;
    ns1:textoExtracto "Normal. | El encóder puede tener una o varias marcas de I0, pero sólo hay una marca seleccionada (por ejemplo, con un micro (home-switch)). El encóder referencia la posición con esta marca de I0. En función de la posició..." .

