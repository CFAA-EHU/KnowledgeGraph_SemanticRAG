@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_REFSHIFT a ns1:Parametro ;
    rdfs:label "REFSHIFT" ;
    ns1:identificador "REFSHIFT" ;
    ns1:textoExtracto "REFSHIFT Offset del punto de referencia. Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): Entre ±99999.9999 mm." .

ns1:Parametro_REFVALUE a ns1:Parametro ;
    rdfs:label "REFVALUE" ;
    ns1:identificador "REFVALUE" ;
    ns1:monitoreaParametro ns1:Variable_MPA_REFVALUE ;
    ns1:textoExtracto "REFVALUE Posición del punto de referencia. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): Entre ±99999.9999 mm. Valores posibles (2): Entre ±3937.00787 inch. Valores posibles (3): Entre ±99999.9999 grados. Valor por defecto: 0." ;
    ns1:valor "0" .

ns1:SistemaCaptacion a ns1:Sistema ;
    rdfs:label "Sistema de captación" ;
    ns1:textoExtracto "El sistema de captación no dispone de I0 codificado. [...] El sistema de captación dispone de I0 codificado y el eje utiliza la compensación de error husillo." ;
    ns1:tieneComponente ns1:Maquina .

ns1:ReguladorAnalogico a ns1:ComponenteElectrico ;
    rdfs:label "Regulador analógico" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:ReguladorSercos a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:ReguladorSimulado a ns1:ComponenteElectrico ;
    rdfs:label "Regulador simulado" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:Variable_MPA_REFVALUE a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.REFVALUE[set].xn" ;
    ns1:identificador "(V.)[ch].MPA.REFVALUE[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.REFVALUE[set].xn" .

ns1:Maquina a ns1:Maquina ;
    rdfs:label "Máquina" ;
    ns1:textoExtracto "El punto de referencia máquina hay que definirlo en los siguientes casos: [...] Definir la cota del punto de referencia respecto al cero máquina." ;
    ns1:tieneComponente ns1:ReguladorAnalogico,
        ns1:ReguladorSercos,
        ns1:ReguladorSimulado .

