@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Maquina_482 a ns1:Maquina ;
    rdfs:label "Máquina" ;
    ns1:controla ns1:Parametro_REFSHIFT ;
    ns1:textoExtracto "el nuevo punto de referencia máquina no coincide con el anterior. Como el punto de referencia máquina debe seguir siendo el mismo" ;
    ns1:tieneComponente ns1:SistemaCaptacion .

ns1:Parametro_REFVALUE a ns1:Parametro ;
    rdfs:label "REFVALUE" ;
    ns1:textoExtracto "en ese punto actualiza su cota al valor de REFVALUE." .

ns1:ReguladorAnalogico a ns1:ComponenteElectrico ;
    rdfs:label "Regulador analógico" ;
    ns1:monitoreaParametro ns1:Parametro_REFSHIFT ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:SistemaCaptacion a ns1:Sistema ;
    rdfs:label "Sistema de captación" ;
    ns1:monitoreaParametro ns1:Parametro_REFSHIFT ;
    ns1:textoExtracto "A veces, para reajustar la máquina, es necesario soltar el sistema de captación por lo que el nuevo punto de referencia máquina no coincide con el anterior." .

ns1:Parametro_REFSHIFT a ns1:Parametro ;
    rdfs:label "REFSHIFT" ;
    ns1:identificador "(V.)[ch].MPA.REFSHIFT[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.REFSHIFT[set].xn [...] en el parámetro REFSHIFT se debe indicar la diferencia existente entre ambos puntos, el anterior y el actual." ;
    ns1:valor "0"^^xsd:string .

