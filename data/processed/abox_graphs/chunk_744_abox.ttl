@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_REFFEED1 a ns1:Parametro ;
    rdfs:label "REFFEED1" ;
    ns1:identificador "REFFEED1" ;
    ns1:textoExtracto "REFFEED1 Velocidad rápida de búsqueda de referencia. Parámetro válido para ejes lineales, rotativos y cabezales." ;
    ns1:valor "Velocidad rápida de búsqueda de referencia" .

ns1:Parametro_REFSHIFT a ns1:Parametro ;
    rdfs:label "REFSHIFT" ;
    ns1:monitoreaParametro ns1:Sistema_ReguladorEje ;
    ns1:textoExtracto "el CNC envía el valor del parámetro REFSHIFT al regulador para que éste lo tenga en cuenta; de esta manera, la cota del CNC y la del regulador es la misma." .

ns1:TareaMantenimiento_BusquedaReferencia a ns1:TareaMantenimiento ;
    rdfs:label "Búsqueda de referencia en ejes Sercos" ;
    ns1:requiereMantenimiento ns1:Componente_EjeSercos ;
    ns1:textoExtracto "Cuando los ejes son Sercos posición, en la homogeneización de parámetros el CNC envía el valor del parámetro REFSHIFT al regulador para que éste lo tenga en cuenta; de esta manera, la cota del CNC y la del regulador es la misma. REFFEED1 Velocidad rápida de búsqueda de referencia." .

ns1:Sistema_ReguladorEje a ns1:Sistema ;
    rdfs:label "Regulador de eje Sercos" ;
    ns1:controla ns1:Componente_EjeSercos ;
    ns1:textoExtracto "el CNC envía el valor del parámetro REFSHIFT al regulador para que éste lo tenga en cuenta; de esta manera, la cota del CNC y la del regulador es la misma." .

ns1:Componente_EjeSercos a ns1:ComponenteMecanico ;
    rdfs:label "Eje Sercos (posición)" ;
    ns1:textoExtracto "Cuando los ejes son Sercos posición, en la homogeneización de parámetros el CNC envía el valor del parámetro REFSHIFT al regulador..." .

