@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MicroReferenciaMaquina a ns1:ComponenteElectrico ;
    rdfs:label "Micro de referencia máquina"@es ;
    ns1:controla ns1:SistemaCaptacion ;
    ns1:textoExtracto "hasta que se pulsa el micro de referencia máquina, invierte el sentido a REFFEED2 y, tras despulsar el micro"@es .

ns1:Parametro_REFFEED1 a ns1:Parametro ;
    rdfs:label "Parámetro REFFEED1 (avance inicial de búsqueda de referencia)"@es ;
    ns1:monitoreaParametro ns1:SistemaCaptacion ;
    ns1:textoExtracto "la búsqueda de referencia se ejecuta al avance indicado en REFFEED1 hasta que se pulsa el micro de referencia máquina"@es ;
    ns1:valor "100.0000" .

ns1:Parametro_REFFEED2 a ns1:Parametro ;
    rdfs:label "Parámetro REFFEED2 (avance post-referencia)"@es ;
    ns1:identificador "V.[ch].MPA.REFFEED2[set].xn" ;
    ns1:monitoreaParametro ns1:SistemaCaptacion ;
    ns1:textoExtracto "invierte el sentido a REFFEED2 y, tras despulsar el micro, continúa al avance indicado en REFFEED2"@es ;
    ns1:valor "100.0000" .

ns1:Parametro_REFPULSE a ns1:Parametro ;
    rdfs:label "Parámetro REFPULSE (tipo de impulso I0)"@es ;
    ns1:monitoreaParametro ns1:SistemaCaptacion ;
    ns1:textoExtracto "REFPULSE Tipo de impulso del I0. Parámetro válido para ejes lineales, rotativos y cabezales. Valores posibles: Positivo / Negativo."@es ;
    ns1:valor "Positivo" .

ns1:SistemaCaptacion a ns1:Sistema ;
    rdfs:label "Sistema de captación de referencia"@es ;
    ns1:textoExtracto "Cuando el sistema de captación no dispone de I0 codificado [...] hasta que se recibe el impulso de I0 del sistema de captación."@es .

