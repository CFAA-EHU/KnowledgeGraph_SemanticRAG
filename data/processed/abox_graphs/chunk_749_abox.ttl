@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_POSINREF a ns1:Parametro ;
    rdfs:label "POSINREF" ;
    ns1:monitoreaParametro ns1:Variable_MPA_POSINREF ;
    ns1:textoExtracto "POSINREF Búsqueda de referencia con movimiento del eje al punto de referencia. Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No." ;
    ns1:valor "No" .

ns1:Parametro_REFVALUE a ns1:Parametro ;
    rdfs:label "REFVALUE" ;
    ns1:textoExtracto "punto de referencia máquina (parámetro REFVALUE)" .

ns1:Sensor_CaptacionMotor a ns1:Sensor ;
    rdfs:label "Captación motor absoluta" ;
    ns1:mitigaRiesgo ns1:AvisoSeguridad_DesplazamientoInnecesario ;
    ns1:textoExtracto "captación interna (captación motor) absoluta. En ejes con captación motor absoluta, el CNC conoce en todo momento la posición relativa del eje por vuelta del motor." .

ns1:AvisoSeguridad_DesplazamientoInnecesario a ns1:AvisoSeguridad ;
    rdfs:label "Desplazamiento innecesario en búsqueda de referencia" ;
    ns1:textoExtracto "En ejes con captación motor absoluta, [...] no es necesario que se desplace hasta el punto de referencia." .

ns1:Variable_MPA_POSINREF a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.POSINREF[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.POSINREF[set].xn" .

