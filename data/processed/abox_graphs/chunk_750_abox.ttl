@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_ABSFEEDBACK a ns1:Parametro ;
    rdfs:label "ABSFEEDBACK" ;
    ns1:textoExtracto "Captación absoluta (parámetro ABSFEEDBACK=Total/Una vuelta)." ;
    ns1:valor "Total/Una vuelta" .

ns1:Parametro_MAXDIFREF a ns1:Parametro ;
    rdfs:label "MAXDIFREF" ;
    ns1:monitoreaParametro ns1:Variable_V_MPA_MAXDIFREF ;
    ns1:textoExtracto "MAXDIFREF Máxima diferencia de posición permitida para considerar que no es necesario volver a referenciar. Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "0.0200 mm / 0.00079 inch / 0.0200 grados" .

ns1:Parametro_REFPOIN a ns1:Parametro ;
    rdfs:label "REFPOIN" ;
    ns1:textoExtracto "Máxima diferencia de posición, entre la cota guardada por el CNC y la leída por el encóder, para volver a referenciar el eje (marca REFPOIN)." .

ns1:Variable_V_MPA_MAXDIFREF a ns1:Parametro ;
    rdfs:label "V.[ch].MPA.MAXDIFREF[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.MAXDIFREF[set].xn" ;
    ns1:valor "ABSFEEDBACK=Total/Una vuelta" .

