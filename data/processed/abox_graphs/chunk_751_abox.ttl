@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_3753 a ns1:AvisoSeguridad ;
    rdfs:label "Error 3753"@es ;
    ns1:identificador "3753" ;
    ns1:textoExtracto "mostrará el error 3753. Con este error, el usuario decide la validez de la cota."@es .

ns1:Maquina a ns1:Maquina ;
    rdfs:label "Máquina"@es ;
    ns1:textoExtracto "la posición de la máquina"@es ;
    ns1:tieneComponente ns1:SistemaCNC .

ns1:Marca_REFPOIN a ns1:Parametro ;
    rdfs:label "Marca REFPOIN"@es ;
    ns1:identificador "REFPOIN" ;
    ns1:textoExtracto "pone la marca de PLC REFPOIN = 1"@es ;
    ns1:valor "1" .

ns1:Parametro_MAXDIFREF a ns1:Parametro ;
    rdfs:label "Parámetro MAXDIFREF"@es ;
    ns1:identificador "MAXDIFREF" ;
    ns1:textoExtracto "Si la diferencia es menor que MAXDIFREF [...] Si la diferencia es mayor que MAXDIFREF"@es .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:activaAlarma ns1:Error_3753 ;
    ns1:controla ns1:Marca_REFPOIN ;
    ns1:monitoreaParametro ns1:Parametro_MAXDIFREF ;
    ns1:textoExtracto "el CNC arranca con la nueva posición calculada por el encóder [...] el CNC arrancará con la posición guardada por el CNC en el apagado"@es .

