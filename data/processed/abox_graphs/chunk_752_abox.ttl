@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "CNC" ;
    ns1:activaAlarma ns1:AvisoSeguridad_Error3753 ;
    ns1:monitoreaParametro ns1:Parametro_ABSFEEDBACK,
        ns1:Parametro_ABSOFF,
        ns1:Parametro_I0TYPE,
        ns1:Parametro_MAXDIFREF ;
    ns1:textoExtracto "el CNC arrancará con la posición guardada por el CNC en el apagado [...] El CNC pone la marca de PLC REFPOIN(axis)=0. [...] El CNC sólo tiene en cuenta este parámetro con I0TYPE=Codificado." ;
    ns1:tieneComponente ns1:Componente_ModuloRCS_S,
        ns1:Componente_Regulador .

ns1:AvisoSeguridad_Error3753 a ns1:AvisoSeguridad ;
    rdfs:label "Error 3753 (Diferencia de cota)" ;
    ns1:textoExtracto "Si MAXDIFREF, el CNC arrancará con la posición guardada por el CNC en el apagado y mostrará el error 3753. Con este error, el usuario decide la validez de la cota. • Si la posición de la máquina coincide con el campo 'Valor actual' del error, la cota es válida. [...] • Si la posición de la máquina coincide con el campo 'Valor esperado', la cota no es válida." .

ns1:Componente_ModuloRCS_S a ns1:Componente ;
    rdfs:label "Módulo RCS-S" ;
    ns1:textoExtracto "cuando la captación absoluta está en un módulo RCS-S." .

ns1:Componente_Regulador a ns1:Componente ;
    rdfs:label "Regulador (analógico/Sercos/simulado)" ;
    ns1:textoExtracto "Máxima diferencia de posición, entre la cota guardada por el CNC y el regulador, para volver a referenciar el eje. [...] Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:Parametro_ABSFEEDBACK a ns1:Parametro ;
    rdfs:label "ABSFEEDBACK" ;
    ns1:textoExtracto "Captación incremental (parámetro ABSFEEDBACK=No). [...] El CNC sólo tiene en cuenta este parámetro con I0TYPE=Codificado, con ABSFEEDBACK=Sí o cuando la captación absoluta está en un módulo RCS-S." ;
    ns1:valor "Sí/No" .

ns1:Parametro_ABSOFF a ns1:Parametro ;
    rdfs:label "ABSOFF" ;
    ns1:identificador "MPA.ABSOFF[set].xn" ;
    ns1:textoExtracto "Offset respecto al I0 codificado. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): Entre ±99999.9999 mm. Valores posibles (2): Entre ±3937.00787 inch. Valores posibles (3): Entre ±99999.9999 grados. Valor por defecto: 0." ;
    ns1:valor "0" .

ns1:Parametro_I0TYPE a ns1:Parametro ;
    rdfs:label "I0TYPE" ;
    ns1:textoExtracto "Las reglas con I0 codificado permiten conocer la posición de la máquina tras un recorrido mínimo de 20 o 100 mm." ;
    ns1:valor "Codificado/No codificado" .

ns1:Parametro_MAXDIFREF a ns1:Parametro ;
    rdfs:label "MAXDIFREF" ;
    ns1:textoExtracto "Máxima diferencia de posición, entre la cota guardada por el CNC y el regulador, para volver a referenciar el eje (marca REFPOIN). Si tras un error o una caída del anillo Sercos, la diferencia es mayor que MAXDIFREF, el CNC pone la marca de PLC REFPOIN(axis)=0." ;
    ns1:valor "Variable según configuración (mm/inch/grados)" .

