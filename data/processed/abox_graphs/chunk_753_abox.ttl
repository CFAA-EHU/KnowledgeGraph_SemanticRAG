@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_CeroMaquina_492 a ns1:Parametro ;
    rdfs:label "Parámetro de cero máquina (OM)"@es ;
    ns1:monitoreaParametro ns1:Maquina_Brochadora_492 ;
    ns1:textoExtracto "Para que el CNC muestre la posición respecto al cero máquina (OM) es necesario personalizar este parámetro con la posición"@es .

ns1:Maquina_Brochadora_492 a ns1:Maquina ;
    rdfs:label "Máquina brochadora (CNC)"@es ;
    ns1:textoExtracto "Tras leer dos I0 codificados seguidos (separados 20 ó 100 mm) se conoce la posición de la máquina respecto al cero del cristal (OG)"@es .

