@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "CNC (Control Numérico Computarizado)"@es ;
    ns1:monitoreaParametro ns1:Parametro_EXTMULT ;
    ns1:textoExtracto "El CNC muestre la posición respecto al cero máquina (OM) [...] El CNC sólo tiene en cuenta este parámetro con I0TYPE = Codificado."@es .

ns1:Sistema_Regulador a ns1:Sistema ;
    rdfs:label "Regulador analógico/simulado"@es ;
    ns1:controla ns1:Parametro_EXTMULT ;
    ns1:textoExtracto "Parámetro válido para regulador analógico y simulado."@es .

ns1:Variable_V_MPA_EXTMULT a ns1:Parametro ;
    rdfs:label "Variable asociada V.[ch].MPA.EXTMULT[set].xn"@es ;
    ns1:identificador "V.[ch].MPA.EXTMULT[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.EXTMULT[set].xn"@es .

ns1:Parametro_EXTMULT a ns1:Parametro ;
    rdfs:label "Factor externo para I0 codificados (EXTMULT)"@es ;
    ns1:identificador "EXTMULT" ;
    ns1:textoExtracto "EXTMULT Factor externo para I0 codificados. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y simulado. Valores posibles: De 0 a 65535. Valor por defecto: 0."@es ;
    ns1:valor "0" .

