@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_MPA_EXTMULT a ns1:Parametro ;
    rdfs:label "Variable MPA.EXTMULT"@es ;
    ns1:identificador "V.[ch].MPA.EXTMULT[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.EXTMULT[set].xn El CNC sólo tiene en cuenta este parámetro con I0TYPE = Codificado. Este parámetro indica la relación existente entre el período mecánico o periodo de la serigrafía del cri..."@es .

