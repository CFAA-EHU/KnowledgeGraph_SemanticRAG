@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Regulador_Analogico a ns1:Sistema ;
    rdfs:label "Regulador analógico"@es ;
    ns1:controla ns1:Parametro_I0CODDI1,
        ns1:Parametro_I0CODDI2 ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado."@es .

ns1:Sistema_Sercos a ns1:Sistema ;
    rdfs:label "Sercos"@es ;
    ns1:controla ns1:Parametro_I0CODDI1,
        ns1:Parametro_I0CODDI2 ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado."@es .

ns1:Sistema_Simulado a ns1:Sistema ;
    rdfs:label "Sistema simulado"@es ;
    ns1:controla ns1:Parametro_I0CODDI1,
        ns1:Parametro_I0CODDI2 ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado."@es .

ns1:Tabla_ParametrosEncoderRotativo_Fagor a ns1:Tabla ;
    rdfs:label "Valores EXTMULT para encóder rotativos Fagor"@es ;
    ns1:documentadoEn ns1:Manual_Brochado ;
    ns1:textoExtracto "Valores que se deben asignar para los encóder Fagor con señal I0 codificada. [...] HO SO 90.000 impulsos. 5 | HO SO 180.000 impulsos. 10 | HOP SOP 18.000 impulsos. 1"@es .

ns1:Variable_I0CODDI1 a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.I0CODDI1[set].xn"@es ;
    ns1:identificador "I0CODDI1[set]" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.I0CODDI1[set].xn"@es .

ns1:Variable_I0CODDI2 a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.I0CODDI2[set].xn"@es ;
    ns1:identificador "I0CODDI2[set]" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.I0CODDI2[set].xn"@es .

ns1:EncoderLineal_Fagor_FOX a ns1:Sensor ;
    rdfs:label "Transductor lineal Fagor FOX"@es ;
    ns1:identificador "FOX" ;
    ns1:monitoreaParametro ns1:Parametro_EXTMULT_FOX ;
    ns1:textoExtracto "El transductor lineal Fagor \"FOX\" dispone de un periodo de gramaje del cristal de 100 µm y de un periodo de señal de contaje de 4 µm."@es .

ns1:Parametro_EXTMULT_FOX a ns1:Parametro ;
    rdfs:label "EXTMULT (Fagor FOX)"@es ;
    ns1:monitoreaParametro ns1:EncoderLineal_Fagor_FOX ;
    ns1:textoExtracto "EXTMULT = 100 / 4 = 25"@es ;
    ns1:valor "25" .

ns1:Parametro_I0CODDI1 a ns1:Parametro ;
    rdfs:label "I0CODDI1"@es ;
    ns1:identificador "I0CODDI1" ;
    ns1:textoExtracto "Paso entre 2 I0 codificados fijos. Parámetro válido para ejes lineales, rotativos y cabezales. [...] Valor por defecto: 1000."@es ;
    ns1:valor "1000" .

ns1:Parametro_I0CODDI2 a ns1:Parametro ;
    rdfs:label "I0CODDI2"@es ;
    ns1:identificador "I0CODDI2" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro con I0TYPE = Codificado."@es ;
    ns1:valor "1001" .

