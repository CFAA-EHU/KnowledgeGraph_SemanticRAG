@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_EXTMULT a ns1:Parametro ;
    rdfs:label "Parámetro EXTMULT" ;
    ns1:textoExtracto "Número de ondas entre I0 fijos = 20000/(20 x EXTMULT) = 1000" .

ns1:Parametro_I0CODDI1_180k a ns1:Parametro ;
    rdfs:label "I0CODDI1 para encóder HO/SO 180.000 impulsos" ;
    ns1:documentadoEn ns1:Tabla_ValoresEncoderFagor ;
    ns1:textoExtracto "HO | SO | 180.000 impulsos. | 1000" ;
    ns1:valor "1000" .

ns1:Parametro_I0CODDI1_18k_HOP_SOP a ns1:Parametro ;
    rdfs:label "I0CODDI1 para encóder HOP/SOP 18.000 impulsos" ;
    ns1:documentadoEn ns1:Tabla_ValoresEncoderFagor ;
    ns1:textoExtracto "HOP | SOP | 18.000 impulsos. | 1000" ;
    ns1:valor "1000" .

ns1:Parametro_I0CODDI1_90k a ns1:Parametro ;
    rdfs:label "I0CODDI1 para encóder HO/SO 90.000 impulsos" ;
    ns1:documentadoEn ns1:Tabla_ValoresEncoderFagor ;
    ns1:textoExtracto "HO | SO | 90.000 impulsos. | 1000" ;
    ns1:valor "1000" .

ns1:Parametro_I0CODDI2 a ns1:Parametro ;
    rdfs:label "Parámetro I0CODDI2" ;
    ns1:identificador "V.[ch].MPA.I0CODDI2[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.I0CODDI2[set].xn. Valor por defecto: 1001." ;
    ns1:valor "1001" .

ns1:Parametro_I0CODDI2_180k a ns1:Parametro ;
    rdfs:label "I0CODDI2 para encóder HO/SO 180.000 impulsos" ;
    ns1:documentadoEn ns1:Tabla_ValoresEncoderFagor ;
    ns1:textoExtracto "HO | SO | 180.000 impulsos. | 1001" ;
    ns1:valor "1001" .

ns1:Parametro_I0CODDI2_18k_HOP_SOP a ns1:Parametro ;
    rdfs:label "I0CODDI2 para encóder HOP/SOP 18.000 impulsos" ;
    ns1:documentadoEn ns1:Tabla_ValoresEncoderFagor ;
    ns1:textoExtracto "HOP | SOP | 18.000 impulsos. | 1001" ;
    ns1:valor "1001" .

ns1:Parametro_I0CODDI2_90k a ns1:Parametro ;
    rdfs:label "I0CODDI2 para encóder HO/SO 90.000 impulsos" ;
    ns1:documentadoEn ns1:Tabla_ValoresEncoderFagor ;
    ns1:textoExtracto "HO | SO | 90.000 impulsos. | 1001" ;
    ns1:valor "1001" .

ns1:Parametro_I0TYPE a ns1:Parametro ;
    rdfs:label "Parámetro I0TYPE" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro con I0TYPE = Codificado." ;
    ns1:valor "Codificado" .

ns1:Tabla_ValoresEncoderFagor a ns1:Tabla ;
    rdfs:label "Tabla de valores para encóder Fagor con señal I0 codificada" ;
    ns1:textoExtracto "Valores que se deben asignar para los encóder Fagor con señal I0 codificada." .

