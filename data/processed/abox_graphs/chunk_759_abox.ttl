@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_FLWEMONITOR a ns1:Parametro ;
    rdfs:label "Parámetro de seguimiento MPA.MINFLWE"@es ;
    ns1:identificador "MPA.MINFLWE" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.MINFLWE[set].xn. El CNC sólo tiene en cuenta este parámetro con FLWEMONITOR"@es ;
    ns1:valor "1.0000 mm / 0.03937 inch / 1.0000 grados"@es .

ns1:Parametro_FLWEMONITOR_RangoGRADOS a ns1:Parametro ;
    rdfs:label "Rango de valor (grados) para MPA.MINFLWE"@es ;
    ns1:textoExtracto "Valores posibles (3): De 0.001 a 99999.9999 grados."@es ;
    ns1:valor "0.001-99999.9999 grados" .

ns1:Parametro_FLWEMONITOR_RangoINCH a ns1:Parametro ;
    rdfs:label "Rango de valor (inch) para MPA.MINFLWE"@es ;
    ns1:textoExtracto "Valores posibles (2): De 0.001 a 3937.00787 inch."@es ;
    ns1:valor "0.001-3937.00787 inch" .

ns1:Parametro_FLWEMONITOR_RangoMM a ns1:Parametro ;
    rdfs:label "Rango de valor (mm) para MPA.MINFLWE"@es ;
    ns1:textoExtracto "Valores posibles (1): De 0.001 a 99999.9999 mm."@es ;
    ns1:valor "0.001-99999.9999 mm" .

