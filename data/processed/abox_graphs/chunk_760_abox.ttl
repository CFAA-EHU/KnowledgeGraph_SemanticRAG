@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_FLWEMONITOR a ns1:Parametro ;
    rdfs:label "FLWEMONITOR" ;
    ns1:identificador "FLWEMONITOR" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro con FLWEMONITOR distinto de OFF."@es .

ns1:Sistema_ReguladorAnalogico a ns1:Sistema ;
    rdfs:label "Regulador analógico" ;
    ns1:monitoreaParametro ns1:Parametro_FEDYNFAC,
        ns1:Parametro_MAXFLWE,
        ns1:Parametro_MINFLWE ;
    ns1:textoExtracto "Parámetro válido para regulador analógico y Sercos."@es .

ns1:Sistema_ReguladorSercos a ns1:Sistema ;
    rdfs:label "Regulador Sercos" ;
    ns1:monitoreaParametro ns1:Parametro_FEDYNFAC,
        ns1:Parametro_MAXFLWE,
        ns1:Parametro_MINFLWE ;
    ns1:textoExtracto "Parámetro válido para regulador analógico y Sercos."@es .

ns1:Parametro_FEDYNFAC a ns1:Parametro ;
    rdfs:label "FEDYNFAC" ;
    ns1:identificador "FEDYNFAC" ;
    ns1:textoExtracto "Porcentaje de desviación permitido para el error de seguimiento. [...] Variable asociada: (V.)[ch].MPA.FEDYNFAC[set].xn"@es ;
    ns1:valor "50" .

ns1:Parametro_MAXFLWE a ns1:Parametro ;
    rdfs:label "MAXFLWE" ;
    ns1:identificador "MAXFLWE" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.MAXFLWE[set].xn [...] Con FLWEMONITOR = Standard, MAXFLWE indica el máximo error de seguimiento permitido cuando el eje está en movimiento."@es ;
    ns1:valor "30.0000" .

ns1:Parametro_MINFLWE a ns1:Parametro ;
    rdfs:label "MINFLWE" ;
    ns1:identificador "MINFLWE" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.MINFLWE[set].xn [...] Este parámetro indica el máximo error de seguimiento permitido cuando el eje está parado."@es ;
    ns1:valor "1.0000" .

