@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_FEDYNFAC a ns1:Parametro ;
    rdfs:label "Parámetro FEDYNFAC (Factor de error dinámico de seguimiento)"@es ;
    ns1:documentadoEn ns1:Pagina_219_221 ;
    ns1:habilitadoPor ns1:ModoOperacion_FLWEMONITOR ;
    ns1:identificador "MPA.FEDYNFAC" ;
    ns1:ilustradoEn ns1:Figura_BandaErrorSeguimiento ;
    ns1:monitoreaParametro ns1:Parametro_MAXFLWE ;
    ns1:textoExtracto "Parámetro válido para regulador analógico y Sercos. Valores posibles: De 0 a 100 %. Valor por defecto: 50. Variable asociada: (V.)[ch].MPA.FEDYNFAC[set].xn [...] Este parámetro indica el error porcentual permitido; es decir, la desviación del error de seguimiento real respecto al teórico."@es ;
    ns1:valor 50 .

ns1:Figura_BandaErrorSeguimiento a ns1:Figura ;
    rdfs:label "Banda de error de seguimiento (zona sombreada)"@es ;
    ns1:ilustradoEn ns1:Pagina_219_221 ;
    ns1:textoExtracto "El CNC calcula [...] la banda permitida (zona sombreada en la figura) [...]"@es .

ns1:ModoOperacion_FLWEMONITOR a ns1:ModoOperacion ;
    rdfs:label "Modo FLWEMONITOR (Monitorización de error de seguimiento)"@es ;
    ns1:identificador "FLWEMONITOR" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro con FLWEMONITOR distinto de OFF."@es .

ns1:Parametro_MAXFLWE a ns1:Parametro ;
    rdfs:label "Parámetro MAXFLWE (Umbral de error de seguimiento)"@es ;
    ns1:identificador "MAXFLWE" ;
    ns1:textoExtracto "El parámetro MAXFLWE indica a partir de qué valor del error de [...]"@es .

ns1:Pagina_219_221 a ns1:Pagina ;
    rdfs:label "Sección 2.6.15: Error de seguimiento (págs. 219-221)"@es ;
    ns1:identificador "2.6.15" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico y Sercos. Valores posibles: De 0 a 100 %. Valor por defecto: 50. Variable asociada: (V.)[ch].MPA.FEDYNFAC[set].xn [...]"@es .

