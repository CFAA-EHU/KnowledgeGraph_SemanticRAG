@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_FLWEMONITOR a ns1:Parametro ;
    rdfs:label "FLWEMONITOR" ;
    ns1:identificador "FLWEMONITOR" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro con FLWEMONITOR=Lineal." ;
    ns1:valor "Lineal" .

ns1:Parametro_MAXFLWE a ns1:Parametro ;
    rdfs:label "MAXFLWE" ;
    ns1:textoExtracto "El parámetro MAXFLWE indica a partir de qué valor del error de seguimiento comienza la supervisión dinámica." ;
    ns1:valor "valor_umbral_error_seguimiento" .

ns1:Sistema_ReguladorAnalogico a ns1:Sistema ;
    rdfs:label "Regulador analógico" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico y Sercos." ;
    ns1:tieneComponente ns1:Parametro_ESTDELAY,
        ns1:Parametro_INPOMAX .

ns1:Sistema_ReguladorSimulado a ns1:Sistema ;
    rdfs:label "Regulador simulado" ;
    ns1:textoExtracto "Parámetro válido para regulador [...] simulado." ;
    ns1:tieneComponente ns1:Parametro_INPOMAX .

ns1:Sistema_Sercos a ns1:Sistema ;
    rdfs:label "Sercos" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico y Sercos." ;
    ns1:tieneComponente ns1:Parametro_ESTDELAY,
        ns1:Parametro_INPOMAX .

ns1:Variable_FLWE a ns1:Parametro ;
    rdfs:label "FLWE" ;
    ns1:identificador "(V.)A.FLWE.xn" ;
    ns1:textoExtracto "consultar con ayuda del osciloscopio las variables (V.)A.FLWE.xn y (V.)A.FLWEST.xn" .

ns1:Variable_FLWEST a ns1:Parametro ;
    rdfs:label "FLWEST" ;
    ns1:identificador "(V.)A.FLWEST.xn" ;
    ns1:textoExtracto "consultar con ayuda del osciloscopio las variables (V.)A.FLWE.xn y (V.)A.FLWEST.xn" .

ns1:Variable_INPOMAX a ns1:Parametro ;
    rdfs:label "INPOMAX (variable)" ;
    ns1:identificador "(V.)[ch].MPA.INPOMAX[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.INPOMAX[set].xn" .

ns1:Parametro_ESTDELAY a ns1:Parametro ;
    rdfs:label "ESTDELAY" ;
    ns1:identificador "ESTDELAY" ;
    ns1:monitoreaParametro ns1:Variable_FLWE,
        ns1:Variable_FLWEST ;
    ns1:textoExtracto "ESTDELAY Retardo del error de seguimiento. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.ESTDELAY[set].xn" ;
    ns1:valor "0-1000000_ms" .

ns1:Parametro_INPOMAX a ns1:Parametro ;
    rdfs:label "INPOMAX" ;
    ns1:identificador "INPOMAX" ;
    ns1:monitoreaParametro ns1:Variable_INPOMAX ;
    ns1:textoExtracto "INPOMAX Tiempo para entrar en banda de muerte. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.INPOMAX[set].xn" ;
    ns1:valor "0-1000000_ms" .

