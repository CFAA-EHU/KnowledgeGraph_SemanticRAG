@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_AXISMODE a ns1:Parametro ;
    rdfs:label "Modo de eje (AXISMODE)" ;
    ns1:identificador "AXISMODE" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta estos parámetros con AXISMODE = Módulo." .

ns1:Parametro_MODCOMP a ns1:Parametro ;
    rdfs:label "Compensación de módulo (MODCOMP)" ;
    ns1:identificador "MODCOMP" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta estos parámetros con AXISMODE = Módulo y MODCOMP = Sí." .

ns1:Parametro_MODERR a ns1:Parametro ;
    rdfs:label "Error de módulo: Número de incrementos (MODERR)" ;
    ns1:detalladoEnEsquema ns1:Sistema_ReguladorAnalogico,
        ns1:Sistema_Sercos,
        ns1:Sistema_Simulado ;
    ns1:documentadoEn ns1:Manual_CNC ;
    ns1:identificador "MODERR" ;
    ns1:monitoreaParametro ns1:Componente_Cabezal,
        ns1:Componente_EjeRotativo ;
    ns1:textoExtracto "MODERR Error de módulo. Número de incrementos. [...] Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.MODERR[set].xn" ;
    ns1:valor "0" .

ns1:Parametro_MODLOWLIM a ns1:Parametro ;
    rdfs:label "Límite inferior del módulo (MODLOWLIM)" ;
    ns1:detalladoEnEsquema ns1:Sistema_ReguladorAnalogico,
        ns1:Sistema_Sercos,
        ns1:Sistema_Simulado ;
    ns1:documentadoEn ns1:Manual_CNC ;
    ns1:identificador "MODLOWLIM" ;
    ns1:monitoreaParametro ns1:Componente_Cabezal,
        ns1:Componente_EjeRotativo ;
    ns1:textoExtracto "MODLOWLIM Límite inferior del módulo. Parámetro válido para ejes rotativos y cabezales. [...] Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.MODLOWLIM[set].xn" ;
    ns1:valor "0" .

ns1:Parametro_MODNROT a ns1:Parametro ;
    rdfs:label "Error de módulo: Número de vueltas (MODNROT)" ;
    ns1:detalladoEnEsquema ns1:Sistema_ReguladorAnalogico,
        ns1:Sistema_Sercos,
        ns1:Sistema_Simulado ;
    ns1:documentadoEn ns1:Manual_CNC ;
    ns1:identificador "MODNROT" ;
    ns1:monitoreaParametro ns1:Componente_Cabezal,
        ns1:Componente_EjeRotativo ;
    ns1:textoExtracto "MODNROT Error de módulo. Número de vueltas. [...] Valor por defecto: 1. Variable asociada: (V.)[ch].MPA.MODNROT[set].xn" ;
    ns1:valor "1" .

ns1:Parametro_MODUPLIM a ns1:Parametro ;
    rdfs:label "Límite superior del módulo (MODUPLIM)" ;
    ns1:detalladoEnEsquema ns1:Sistema_ReguladorAnalogico,
        ns1:Sistema_Sercos,
        ns1:Sistema_Simulado ;
    ns1:documentadoEn ns1:Manual_CNC ;
    ns1:identificador "MODUPLIM" ;
    ns1:monitoreaParametro ns1:Componente_Cabezal,
        ns1:Componente_EjeRotativo ;
    ns1:textoExtracto "MODUPLIM Límite superior del módulo. Parámetro válido para ejes rotativos y cabezales. [...] Valor por defecto: 360. Variable asociada: (V.)[ch].MPA.MODUPLIM[set].xn" ;
    ns1:valor "360" .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "Parámetro válido para ejes rotativos y cabezales." .

ns1:Componente_EjeRotativo a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo" ;
    ns1:textoExtracto "Parámetro válido para ejes rotativos y cabezales." .

ns1:Sistema_ReguladorAnalogico a ns1:Sistema ;
    rdfs:label "Regulador analógico" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:Sistema_Sercos a ns1:Sistema ;
    rdfs:label "Sistema Sercos" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:Sistema_Simulado a ns1:Sistema ;
    rdfs:label "Sistema simulado" ;
    ns1:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." .

