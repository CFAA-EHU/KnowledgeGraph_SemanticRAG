@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_MODERR a ns1:Parametro ;
    rdfs:label "Parámetro MODERR"@es ;
    ns1:monitoreaParametro ns1:Sistema_EjesRotativos ;
    ns1:textoExtracto "El parámetro MODERR indica el error que hay que compensar cuando el eje ha girado las vueltas indicadas en el parámetro MODNROT."@es .

ns1:Parametro_MODNROT a ns1:Parametro ;
    rdfs:label "Parámetro MODNROT"@es ;
    ns1:monitoreaParametro ns1:Sistema_EjesRotativos ;
    ns1:textoExtracto "el parámetro MODNROT [indica] las vueltas [del eje] para aplicar compensación."@es .

ns1:Sistema_EjesRotativos a ns1:Sistema ;
    rdfs:label "Sistema de ejes rotativos y cabezal"@es ;
    ns1:textoExtracto "Configuración del módulo (ejes rotativos y cabezal)."@es ;
    ns1:tieneComponente ns1:Componente_Encoder .

