@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Variable_VelocidadCabezal_POLARITY a ns1:Parametro ;
    rdfs:label "(V.)[ch].A.POLARITY.sn / (V.)[ch].SP.POLARITY.sn" ;
    ns1:monitoreaParametro ns1:Parametro_POLARM3,
        ns1:Parametro_POLARM4 ;
    ns1:textoExtracto "Esta variable permite invertir el significado de los parámetros POLARM3 y POLARM4. La variable no modifica los valores de los parámetros máquina." .

ns1:Parametro_POLARM3 a ns1:Parametro ;
    rdfs:label "POLARM3" ;
    ns1:textoExtracto "Los parámetros POLARM3 y POLARM4 indican el signo de la consigna para las funciones M3 y M4 respectivamente. Ambos parámetros se deben definir con valor \"Positivo\"." ;
    ns1:valor "Positivo" .

ns1:Parametro_POLARM4 a ns1:Parametro ;
    rdfs:label "POLARM4" ;
    ns1:textoExtracto "Los parámetros POLARM3 y POLARM4 indican el signo de la consigna para las funciones M3 y M4 respectivamente. Ambos parámetros se deben definir con valor \"Positivo\"." ;
    ns1:valor "Positivo" .

