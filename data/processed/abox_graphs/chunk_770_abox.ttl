@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_MINANOUT a ns1:Tabla ;
    rdfs:label "Tabla de correspondencia MINANOUT" ;
    ns1:documentadoEn ns1:Parametro_MINANOUT ;
    ns1:textoExtracto "| MINANOUT | Consigna. | --- | --- | 1 ꞏꞏꞏ 3277 ꞏꞏꞏ 32767 | 0,3 mV. ꞏꞏꞏ 1 V. ꞏꞏꞏ 10 V. |" .

ns1:Tabla_SERVOOFF a ns1:Tabla ;
    rdfs:label "Tabla de correspondencia SERVOOFF" ;
    ns1:documentadoEn ns1:Parametro_SERVOOFF ;
    ns1:textoExtracto "| SERVOOFF | Consigna. | --- | --- | -32767 ꞏꞏꞏ -3277 ꞏꞏꞏ 1 ꞏꞏꞏ 3277 ꞏꞏꞏ 32767 | -10 V. ꞏꞏꞏ -1 V. ꞏꞏꞏ 0,3 mV. ꞏꞏꞏ 1 V. ꞏꞏꞏ 10 V. |" .

ns1:Parametro_MINANOUT a ns1:Parametro ;
    rdfs:label "MINANOUT" ;
    ns1:identificador "MINANOUT" ;
    ns1:textoExtracto "MINANOUT Consigna mínima. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico. Valores posibles: De 0 a 32767. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.MINANOUT[set].xn La consigna se expresa en unidades del conversor D/A, admitiendo cualquier número entero entre 0 y 32767, correspondiendo para el valor 32767 la consigna de 10 V." ;
    ns1:valor "0 a 32767" .

ns1:Parametro_SERVOOFF a ns1:Parametro ;
    rdfs:label "SERVOOFF" ;
    ns1:identificador "SERVOOFF" ;
    ns1:textoExtracto "SERVOOFF Compensación del offset. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico. Valores posibles: Entre ±32767. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.SERVOOFF[set].xn Consigna que se aplica como offset al regulador. La consigna se expresa en unidades del conversor D/A, admitiendo cualquier número entero entre ±32767, correspondiendo para el valor ±32767 la consigna de ±10 V." ;
    ns1:valor "-32767 a 32767" .

