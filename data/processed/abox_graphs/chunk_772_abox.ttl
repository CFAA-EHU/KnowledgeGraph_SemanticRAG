@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ReguladorSercos_226_228 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos" ;
    ns1:controla ns1:ParametroSalidaAnalogica_226_228 ;
    ns1:textoExtracto "Gestión de la consigna analógica desde los reguladores Sercos." .

ns1:ModuloSalidasAnalogicas_226_228 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de salidas analógicas" ;
    ns1:identificador "1-4 (primer módulo), 5-8 (segundo módulo)" ;
    ns1:textoExtracto "Los módulos de salidas analógicas se numeran según el orden lógico de los grupos remotos (conmutador rotativo de la fuente de alimentación)." .

ns1:ParametroSalidaAnalogica_226_228 a ns1:Parametro ;
    rdfs:label "Número de salida analógica" ;
    ns1:monitoreaParametro ns1:ModuloSalidasAnalogicas_226_228 ;
    ns1:textoExtracto "este parámetro indica cuál es el número de la salida analógica y el regulador a utilizar." .

