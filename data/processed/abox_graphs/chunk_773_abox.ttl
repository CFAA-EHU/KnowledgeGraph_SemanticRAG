@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_RCS_S a ns1:Sistema ;
    rdfs:label "Sistema de módulos RCS-S" ;
    ns1:textoExtracto "Gestión de la consigna analógica desde el módulo RCS-S. [...] Las salidas analógicas del primer módulo serán 1 a 4, las del segundo 5 a 8 y así sucesivamente." ;
    ns1:tieneComponente ns1:Variable_V_G_ANAO_107 .

ns1:Sistema_ReguladoresSercos a ns1:Sistema ;
    rdfs:label "Sistema de reguladores Sercos" ;
    ns1:textoExtracto "consigna analógica desde los reguladores Sercos. [...] La dirección lógica la establece el conmutador rotativo 'address'." ;
    ns1:tieneComponente ns1:Parametro_107,
        ns1:Parametro_COUNTERTYPE,
        ns1:Parametro_OP1,
        ns1:Parametro_OP2 .

ns1:Variable_V_MPA_COUNTERTYPE a ns1:Parametro ;
    rdfs:label "Variable V.[ch].MPA.COUNTERTYPE[set].xn" ;
    ns1:identificador "V.[ch].MPA.COUNTERTYPE[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.COUNTERTYPE[set].xn" .

ns1:Parametro_107 a ns1:Parametro ;
    rdfs:label "Parámetro de salida analógica 107" ;
    ns1:identificador "107" ;
    ns1:textoExtracto "si el parámetro se define con el valor ꞏ107ꞏ, indica que se utiliza la entrada analógica ꞏ1ꞏ del regulador cuya dirección lógica es ꞏ7ꞏ" ;
    ns1:valor "107" .

ns1:Parametro_COUNTERTYPE a ns1:Parametro ;
    rdfs:label "Parámetro COUNTERTYPE" ;
    ns1:identificador "COUNTERTYPE" ;
    ns1:textoExtracto "COUNTERTYPE Tipo de entrada de captación del eje. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos velocidad. Valores posibles: Remoto CAN / Regulador / Contadora Sercos / Local. Valor por defecto: Remoto." ;
    ns1:valor "Remoto" .

ns1:Parametro_OP1 a ns1:Parametro ;
    rdfs:label "Parámetro OP1 del regulador" ;
    ns1:identificador "OP1" ;
    ns1:textoExtracto "Los parámetros OP1 y OP2 del regulador se deben definir con valor 0" ;
    ns1:valor "0" .

ns1:Parametro_OP2 a ns1:Parametro ;
    rdfs:label "Parámetro OP2 del regulador" ;
    ns1:identificador "OP2" ;
    ns1:textoExtracto "Los parámetros OP1 y OP2 del regulador se deben definir con valor 0" ;
    ns1:valor "0" .

ns1:Variable_V_G_ANAO_107 a ns1:Parametro ;
    rdfs:label "Variable V.G.ANAO[107]" ;
    ns1:identificador "V.G.ANAO[107]" ;
    ns1:textoExtracto "para consultar la tensión en esa salida hay que escribir la variable de la forma V.G.ANAO[107]" .

