@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModuloRemoto a ns1:ComponenteElectrico ;
    rdfs:label "Módulo remoto"@es ;
    ns1:textoExtracto "en los módulos remotos"@es .

ns1:Modulo_RCS_S a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S (contadora Sercos)"@es ;
    ns1:textoExtracto "en un módulo RCS-S (contadora Sercos)"@es .

ns1:Parametro_EntradaCaptacionEje a ns1:Parametro ;
    rdfs:label "Parámetro de entrada de captación del eje"@es ;
    ns1:monitoreaParametro ns1:Sensor_CaptacionEje ;
    ns1:textoExtracto "Este parámetro indica dónde está ubicada la entrada de captación del eje; en los módulos remotos, en la captación libre de un regulador Sercos, en un módulo RCS-S (contadora Sercos) o en las entradas de captación locales de la unidad central."@es .

ns1:ReguladorSercos a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos"@es ;
    ns1:textoExtracto "captación libre de un regulador Sercos"@es ;
    ns1:tieneComponente ns1:Parametro_PP5 .

ns1:UnidadCentral a ns1:Sistema ;
    rdfs:label "Unidad central"@es ;
    ns1:textoExtracto "entradas de captación locales de la unidad central"@es .

ns1:Parametro_PP5 a ns1:Parametro ;
    rdfs:label "Parámetro PP5"@es ;
    ns1:identificador "PP5" ;
    ns1:monitoreaParametro ns1:Sensor_CaptacionEje ;
    ns1:textoExtracto "parametrizar el parámetro PP5=-0,0001"@es ;
    ns1:valor "-0,0001" .

ns1:Sensor_CaptacionEje a ns1:Sensor ;
    rdfs:label "Sensor de captación del eje"@es ;
    ns1:textoExtracto "entrada de captación del eje"@es .

