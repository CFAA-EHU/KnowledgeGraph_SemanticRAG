@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ContadoraSercos_RCS_S a ns1:ComponenteElectrico ;
    rdfs:label "Contadora Sercos (RCS-S)" ;
    ns1:textoExtracto "módulo RCS-S (contadora Sercos)" .

ns1:EntradaCaptacionInterna a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de captación interna (motor)" ;
    ns1:textoExtracto "captación interna (motor) y la captación externa (directa) de un eje estén en reguladores diferentes" .

ns1:ModuloRemoto a ns1:ComponenteElectrico ;
    rdfs:label "Módulo remoto" ;
    ns1:textoExtracto "módulos remotos, de 1 a 40" .

ns1:Parametro_COUNTERID a ns1:Parametro ;
    rdfs:label "COUNTERID" ;
    ns1:textoExtracto "Número de la entrada de captación del eje. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos velocidad. Valores posibles: Módulos remotos, de 1 a 40 / Regulador Sercos, de 1 a 32 / Contadora Sercos, de 1 a 32 / Entradas locales, de 1 a 2. Valor por defecto: 0." ;
    ns1:valor 0 .

ns1:Parametro_PP5 a ns1:Parametro ;
    rdfs:label "PP5" ;
    ns1:monitoreaParametro ns1:EntradaCaptacionExterna ;
    ns1:textoExtracto "parametrizar el parámetro PP5=-0,0001. Significado para un eje Sercos velocidad. Este parámetro indica dónde está ubicada la entrada para la captación externa (directa) del eje" ;
    ns1:valor "-0,0001" .

ns1:ReguladorSercos a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos" ;
    ns1:textoExtracto "regulador Sercos, en este regulador parametrizar el parámetro PP5=-0,0001. [...] captación libre de un regulador Sercos" ;
    ns1:tieneComponente ns1:EntradaCaptacionExterna .

ns1:UnidadCentral a ns1:Sistema ;
    rdfs:label "Unidad central" ;
    ns1:textoExtracto "entradas de captación locales de la unidad central" ;
    ns1:tieneComponente ns1:EntradaCaptacionExterna .

ns1:EntradaCaptacionExterna a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de captación externa (directa)" ;
    ns1:textoExtracto "entrada para la captación externa (directa) del eje; en los módulos remotos, en la captación libre de un regulador Sercos, en un módulo RCS-S (contadora Sercos) o en las entradas de captación locales de la unidad central" .

