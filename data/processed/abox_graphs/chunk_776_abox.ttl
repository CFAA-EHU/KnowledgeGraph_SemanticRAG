@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCaptacionRemota a ns1:Sistema ;
    rdfs:label "Sistema de captación remota CANfagor"@es ;
    ns1:controla ns1:Parametro_EntradaCaptacionEje ;
    ns1:textoExtracto "Entrada de captación en los módulos remotos CANfagor"@es ;
    ns1:tieneComponente ns1:ModuloContadoras_CANfagor .

ns1:ModuloContadoras_CANfagor a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de contadoras CANfagor"@es ;
    ns1:monitoreaParametro ns1:Parametro_EntradaCaptacionEje ;
    ns1:textoExtracto "Para la entrada de captación se utiliza un módulo de contadoras"@es .

ns1:Parametro_EntradaCaptacionEje a ns1:Parametro ;
    rdfs:label "Parámetro de entrada de captación asociada al eje"@es ;
    ns1:textoExtracto "este parámetro indicará cuál es la entrada de captación a utilizar (si la captación es local o remota) o el número de regulador o contadora"@es .

