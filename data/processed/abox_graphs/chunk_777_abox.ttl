@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModuloContadoras_CANfagor a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de contadoras (CANfagor)"@es ;
    ns1:textoExtracto "Para la entrada de captación se utiliza un módulo de contadoras en los módulos remotos. [...] Las contadoras del primer módulo serán 1 a 4, las del segundo 5 a 8 y así sucesivamente."@es ;
    ns1:tieneComponente ns1:EntradaCaptacion_1_4_CANfagor,
        ns1:EntradaCaptacion_5_8_CANfagor .

ns1:Modulo_RCS_S a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S"@es ;
    ns1:textoExtracto "Entrada de captación en un módulo RCS-S. [...] Los módulos RCS-S se numeran según su orden lógico (parámetro SERCOUNTID)."@es ;
    ns1:tieneComponente ns1:EntradaCaptacion_1_4_RCSS,
        ns1:EntradaCaptacion_5_8_RCSS .

ns1:Parametro_DireccionLogica_Sercos a ns1:Parametro ;
    rdfs:label "Dirección lógica del regulador (Sercos)"@es ;
    ns1:monitoreaParametro ns1:Regulador_Sercos ;
    ns1:textoExtracto "El parámetro indica la dirección lógica del regulador (de 1 a 32)."@es ;
    ns1:valor "1-32" .

ns1:Parametro_EntradaCaptacion_CANfagor a ns1:Parametro ;
    rdfs:label "Número de entrada de captación (CANfagor)"@es ;
    ns1:monitoreaParametro ns1:EntradaCaptacion_1_4_CANfagor,
        ns1:EntradaCaptacion_5_8_CANfagor ;
    ns1:textoExtracto "Este parámetro indica el número de la entrada de captación que se utiliza."@es .

ns1:Parametro_EntradaCaptacion_Laser a ns1:Parametro ;
    rdfs:label "Entrada de captación (Modelo láser)"@es ;
    ns1:monitoreaParametro ns1:Cabezal_Laser ;
    ns1:textoExtracto "la entrada de captación del cabezal será 0"@es ;
    ns1:valor "0" .

ns1:Parametro_EntradaCaptacion_RCSS a ns1:Parametro ;
    rdfs:label "Número de entrada de captación (RCS-S)"@es ;
    ns1:monitoreaParametro ns1:EntradaCaptacion_1_4_RCSS,
        ns1:EntradaCaptacion_5_8_RCSS ;
    ns1:textoExtracto "Este parámetro indica el número de la entrada de captación que se utiliza."@es .

ns1:Cabezal_Laser a ns1:Componente ;
    rdfs:label "Cabezal láser"@es ;
    ns1:textoExtracto "Modelo láser. En el modelo láser, la entrada de captación del cabezal será 0 ya que no hay captación real."@es .

ns1:EntradaCaptacion_Secundaria_Sercos a ns1:ComponenteElectrico ;
    rdfs:label "Segunda entrada de captación (Regulador Sercos)"@es ;
    ns1:identificador "2" ;
    ns1:textoExtracto "siempre se utilizará la segunda entrada de captación del regulador"@es .

ns1:Regulador_Sercos a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos"@es ;
    ns1:textoExtracto "Entrada de captación en los reguladores Sercos. En este caso siempre se utilizará la segunda entrada de captación del regulador."@es ;
    ns1:tieneComponente ns1:EntradaCaptacion_Secundaria_Sercos .

ns1:EntradaCaptacion_1_4_CANfagor a ns1:ComponenteElectrico ;
    rdfs:label "Entradas de captación 1-4 (Módulo CANfagor)"@es ;
    ns1:identificador "1-4" ;
    ns1:textoExtracto "Las contadoras del primer módulo serán 1 a 4"@es .

ns1:EntradaCaptacion_1_4_RCSS a ns1:ComponenteElectrico ;
    rdfs:label "Entradas de captación 1-4 (Módulo RCS-S)"@es ;
    ns1:identificador "1-4" ;
    ns1:textoExtracto "Las entradas de captación del primer módulo serán 1 a 4"@es .

ns1:EntradaCaptacion_5_8_CANfagor a ns1:ComponenteElectrico ;
    rdfs:label "Entradas de captación 5-8 (Módulo CANfagor)"@es ;
    ns1:identificador "5-8" ;
    ns1:textoExtracto "las del segundo 5 a 8"@es .

ns1:EntradaCaptacion_5_8_RCSS a ns1:ComponenteElectrico ;
    rdfs:label "Entradas de captación 5-8 (Módulo RCS-S)"@es ;
    ns1:identificador "5-8" ;
    ns1:textoExtracto "las del segundo 5 a 8"@es .

