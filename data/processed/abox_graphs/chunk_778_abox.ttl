@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_HomogeneizacionActiva a ns1:ModoOperacion ;
    rdfs:label "Homogeneización activa" ;
    ns1:controla ns1:Parametro_DRIVESET ;
    ns1:textoExtracto "Con la homogeneización activa, el CNC envía los parámetros del set ꞏ1ꞏ del eje maestro al set ꞏ0ꞏ y a la gama ꞏ1ꞏ (la primera) del regulador." .

ns1:Sistema_ReguladorSercos a ns1:Sistema ;
    rdfs:label "Regulador Sercos" ;
    ns1:textoExtracto "Parámetro válido para regulador Sercos." ;
    ns1:tieneComponente ns1:Parametro_ACFGAIN,
        ns1:Parametro_DRIVESET,
        ns1:Parametro_FFGAIN,
        ns1:Parametro_Kv .

ns1:Parametro_ACFGAIN a ns1:Parametro ;
    rdfs:label "ACFGAIN" ;
    ns1:identificador "ACFGAIN" ;
    ns1:textoExtracto "AC forward (parámetro ACFGAIN)" .

ns1:Parametro_FFGAIN a ns1:Parametro ;
    rdfs:label "FFGAIN" ;
    ns1:identificador "FFGAIN" ;
    ns1:textoExtracto "feed forward (parámetro FFGAIN)" .

ns1:Parametro_Kv a ns1:Parametro ;
    rdfs:label "Kv" ;
    ns1:identificador "Kv" ;
    ns1:textoExtracto "los cambios de Kv" .

ns1:Variable_MPA_DriveSet a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.DRIVESET[set].xn" ;
    ns1:identificador "(V.)[ch].MPA.DRIVESET[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.DRIVESET[set].xn" .

ns1:Parametro_DRIVESET a ns1:Parametro ;
    rdfs:label "DRIVESET" ;
    ns1:identificador "DRIVESET" ;
    ns1:monitoreaParametro ns1:Variable_MPA_DriveSet ;
    ns1:textoExtracto "DRIVESET Set del regulador a utilizar. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos. Valores posibles: De 0 a 8. Valor por defecto: 0." ;
    ns1:valor "0-8" .

