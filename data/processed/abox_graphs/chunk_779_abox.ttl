@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_FEEDBACKTYPE a ns1:Parametro ;
    rdfs:label "FEEDBACKTYPE" ;
    ns1:identificador "MPA.FEEDBACKTYPE[set].xn" ;
    ns1:monitoreaParametro ns1:Modulo_RCS_S ;
    ns1:textoExtracto "FEEDBACKTYPE Tipo de captación del módulo RCS-S. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos velocidad. Valores posibles (1): Entradas locales; TTL / TTL diferencial / Vpp / SSI. Valores posibles (2): Contadora Sercos; TTL / TTL diferencial / Vpp / SSI / FeeDat / EnDat. Valor por defecto: TTL diferencial." ;
    ns1:valor "TTL diferencial"^^xsd:string .

ns1:Variable_V_MPA_FEEDBACKTYPE a ns1:Parametro ;
    rdfs:label "Variable asociada a FEEDBACKTYPE" ;
    ns1:identificador "V.[ch].MPA.FEEDBACKTYPE[set].xn" ;
    ns1:monitoreaParametro ns1:Modulo_RCS_S ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.FEEDBACKTYPE[set].xn" .

ns1:Modulo_RCS_S a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S" ;
    ns1:textoExtracto "módulo RCS-S. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos velocidad." .

