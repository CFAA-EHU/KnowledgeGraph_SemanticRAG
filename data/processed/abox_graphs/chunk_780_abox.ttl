@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_FeedbackType a ns1:Parametro ;
    rdfs:label "FEEDBACKTYPE" ;
    ns1:textoExtracto "parámetro FEEDBACKTYPE" ;
    ns1:valor "EnDat",
        "FeeDat" .

ns1:Parametro_EncoderInfo a ns1:Parametro ;
    rdfs:label "ENCODERINFO" ;
    ns1:monitoreaParametro ns1:Tabla_ParametrosEncoder ;
    ns1:textoExtracto "ENCODERINFO Información del encóder. Cuando el tipo de captación es FeeDat o EnDat (parámetro FEEDBACKTYPE), este parámetro muestra una tabla de parámetros con la información del encóder." .

ns1:Tabla_ParametrosEncoder a ns1:Tabla ;
    ns1:documentadoEn ns1:Parametro_EncoderInfo ;
    ns1:textoExtracto "tabla de parámetros con la información del encóder" .

