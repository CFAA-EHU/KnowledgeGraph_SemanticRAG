@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_DATALENGTH a ns1:Parametro ;
    rdfs:label "DATALENGTH" ;
    ns1:documentadoEn ns1:Tabla_ParametrosEncoder_520 ;
    ns1:identificador "DATALENGTH" ;
    ns1:textoExtracto "Número de bits que constituyen el dato en la transmisión." .

ns1:Parametro_NAME a ns1:Parametro ;
    rdfs:label "NAME" ;
    ns1:documentadoEn ns1:Tabla_ParametrosEncoder_520 ;
    ns1:identificador "NAME" ;
    ns1:textoExtracto "Nomenclatura del encóder." .

ns1:Parametro_RESOLUTION a ns1:Parametro ;
    rdfs:label "RESOLUTION" ;
    ns1:documentadoEn ns1:Tabla_ParametrosEncoder_520 ;
    ns1:identificador "RESOLUTION" ;
    ns1:textoExtracto "Resolución del encóder." .

ns1:Parametro_SERIALNUMBER a ns1:Parametro ;
    rdfs:label "SERIALNUMBER" ;
    ns1:documentadoEn ns1:Tabla_ParametrosEncoder_520 ;
    ns1:identificador "SERIALNUMBER" ;
    ns1:textoExtracto "Número de serie del encóder." .

ns1:Parametro_TYPE a ns1:Parametro ;
    rdfs:label "TYPE" ;
    ns1:documentadoEn ns1:Tabla_ParametrosEncoder_520 ;
    ns1:identificador "TYPE" ;
    ns1:textoExtracto "Tipo de encóder." .

ns1:Tabla_ParametrosEncoder_520 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros del encóder (pág. 230-231)" ;
    ns1:textoExtracto """
| Parámetro. | Significado. |
| --- | --- |
| NAME | Nomenclatura del encóder. |
| TYPE | Tipo de encóder. |
| RESOLUTION | Resolución del encóder. |
| SERIALNUMBER | Número de serie del encóder. |
| DATALENGTH | Número de bits que constituyen el dato en la transmisión.
""" .

