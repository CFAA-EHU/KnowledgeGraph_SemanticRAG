@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaParametrosEncoder_521 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros del encóder (pág. 230-231)"@es ;
    ns1:textoExtracto "El CNC obtiene esta información del propio encóder, por lo que estos parámetros no se pueden modificar. [...] NAME Nomenclatura del encóder. [...] TYPE Tipo de encóder. [...] RESOLUTION Resolución del encóder. [...] SERIALNUMBER Número de serie del encóder."@es ;
    ns1:tieneComponente ns1:ParametroEncoder_Nombre_521,
        ns1:ParametroEncoder_NumeroSerie_521,
        ns1:ParametroEncoder_Resolucion_521,
        ns1:ParametroEncoder_Tipo_521 .

ns1:ParametroEncoder_Nombre_521 a ns1:Parametro ;
    rdfs:label "NAME (Nomenclatura del encóder)"@es ;
    ns1:identificador "(V.)[ch].MPA.DE_NAME[set].xn" ;
    ns1:textoExtracto "NAME Nomenclatura del encóder. [...] • Si es un encóder Fagor, nombre del encóder. • Si es un encóder EnDat, texto \"EnDat\"."@es ;
    ns1:valor "(V.)[ch].A.CDE_NAME[set].xn"@es .

ns1:ParametroEncoder_NumeroSerie_521 a ns1:Parametro ;
    rdfs:label "SERIALNUMBER (Número de serie del encóder)"@es ;
    ns1:identificador "(V.)[ch].MPA.DE_SERIALNUMBER[set].xn" ;
    ns1:textoExtracto "SERIALNUMBER Número de serie del encóder."@es .

ns1:ParametroEncoder_Resolucion_521 a ns1:Parametro ;
    rdfs:label "RESOLUTION (Resolución del encóder)"@es ;
    ns1:identificador "(V.)[ch].MPA.DE_RESOLUTION[set].xn" ;
    ns1:textoExtracto "RESOLUTION Resolución del encóder. [...] • Si el encóder es lineal, resolución en nanómetros. • Si el encóder es angular, número de impulsos por vuelta."@es ;
    ns1:valor "(V.)[ch].A.CDE_RESOLUTION[set].xn"@es .

ns1:ParametroEncoder_Tipo_521 a ns1:Parametro ;
    rdfs:label "TYPE (Tipo de encóder)"@es ;
    ns1:identificador "(V.)[ch].MPA.DE_TYPE[set].xn" ;
    ns1:textoExtracto "TYPE Tipo de encóder. [...] Tipo de encóder (absoluto rotativo multivuelta, absoluto rotativo, absoluto lineal, etc)."@es ;
    ns1:valor "(V.)[ch].A.CDE_TYPE[set].xn"@es .

