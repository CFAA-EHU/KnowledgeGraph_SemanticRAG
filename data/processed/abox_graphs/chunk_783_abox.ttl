@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Param_DataLength a ns1:Parametro ;
    rdfs:label "Longitud de datos de transmisión (DATALENGTH)"@es ;
    ns1:documentadoEn ns1:Encoder_Parametros ;
    ns1:identificador "DATALENGTH" ;
    ns1:textoExtracto "DATALENGTH • Número de bits que constituyen el dato en la transmisión."@es ;
    ns1:valor "(V.)[ch].MPA.DE_DATALENGTH[set].xn"^^xsd:string .

ns1:Param_ResolucionAngular a ns1:Parametro ;
    rdfs:label "Resolución del encóder angular (impulsos/vuelta)"@es ;
    ns1:documentadoEn ns1:Encoder_Parametros ;
    ns1:textoExtracto "Si el encóder es angular, número de impulsos por vuelta."@es .

ns1:Param_ResolucionLinear a ns1:Parametro ;
    rdfs:label "Resolución del encóder lineal (nanómetros)"@es ;
    ns1:documentadoEn ns1:Encoder_Parametros ;
    ns1:textoExtracto "Si el encóder es lineal, resolución en nanómetros."@es .

ns1:Param_SerialNumber a ns1:Parametro ;
    rdfs:label "Número de serie del encóder (SERIALNUMBER)"@es ;
    ns1:documentadoEn ns1:Encoder_Parametros ;
    ns1:identificador "SERIALNUMBER" ;
    ns1:textoExtracto "SERIALNUMBER • Número de serie del encóder. [...] Parámetro no modificable; el CNC lee este parámetro del encóder."@es ;
    ns1:valor "(V.)[ch].MPA.DE_SERIALNUMBER[set].xn"^^xsd:string .

ns1:Encoder_Parametros a ns1:Tabla ;
    rdfs:label "Tabla de parámetros del encóder"@es ;
    ns1:textoExtracto "Variable asociada (valor guardado en la tabla): (V.)[ch].MPA.DE_SERIALNUMBER[set].xn [...] (V.)[ch].MPA.DE_DATALENGTH[set].xn"@es .

