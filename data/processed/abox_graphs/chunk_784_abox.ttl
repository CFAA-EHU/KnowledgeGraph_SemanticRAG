@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_DATALENGTH a ns1:Parametro ;
    rdfs:label "DATALENGTH" ;
    ns1:identificador "DATALENGTH" ;
    ns1:monitoreaParametro ns1:Encoder_ParametroTransmision ;
    ns1:textoExtracto "DATALENGTH Número de bits que constituyen el dato en la transmisión." ;
    ns1:valor "Número de bits que constituyen el dato en la transmisión" .

ns1:Tabla_ParametrosEncoder a ns1:Tabla ;
    rdfs:label "Tabla de parámetros del encóder" ;
    ns1:documentadoEn ns1:Manual_Tecnico ;
    ns1:textoExtracto "Variable asociada (valor guardado en la tabla): (V.)[ch].MPA.DE_DATALENGTH[set].xn" .

ns1:Variable_CDE_DATALENGTH a ns1:Parametro ;
    rdfs:label "(V.)[ch].A.CDE_DATALENGTH[set].xn" ;
    ns1:identificador "(V.)[ch].A.CDE_DATALENGTH[set].xn" ;
    ns1:monitoreaParametro ns1:Encoder_ParametroTransmision ;
    ns1:textoExtracto "Variable asociada (valor leído del encóder): (V.)[ch].A.CDE_DATALENGTH[set].xn" .

ns1:Variable_DE_DATALENGTH a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.DE_DATALENGTH[set].xn" ;
    ns1:identificador "(V.)[ch].MPA.DE_DATALENGTH[set].xn" ;
    ns1:monitoreaParametro ns1:Encoder_ParametroTransmision ;
    ns1:textoExtracto "Variable asociada (valor guardado en la tabla): (V.)[ch].MPA.DE_DATALENGTH[set].xn" .

ns1:Encoder_ParametroTransmision a ns1:ComponenteElectrico ;
    rdfs:label "Parámetro de transmisión del encóder" ;
    ns1:textoExtracto "parámetro del encóder. DATALENGTH Número de bits que constituyen el dato en la transmisión." .

