@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_LongitudCable a ns1:Parametro ;
    rdfs:label "Longitud del cable"@es ;
    ns1:monitoreaParametro ns1:Frecuencia_2MHz,
        ns1:Frecuencia_4MHz ;
    ns1:textoExtracto "La frecuencia depende de la longitud del cable; cuanto más corto sea el cable, mayor puede ser la frecuencia."@es .

ns1:Frecuencia_2MHz a ns1:Frecuencia ;
    rdfs:label "Frecuencia por defecto (2 MHz)"@es ;
    ns1:textoExtracto "Se recomienda utilizar la frecuencia por defecto (2 MHz), válida hasta 100 m de cable."@es ;
    ns1:valor "2 MHz"^^rdfs:Literal .

ns1:Frecuencia_4MHz a ns1:Frecuencia ;
    rdfs:label "Frecuencia de 4 MHz"@es ;
    ns1:textoExtracto "Para seleccionar la velocidad de 4 MHz, el encoder debe poder trabajar a esa velocidad y la longitud del cable debe ser inferior a los 50m."@es ;
    ns1:valor "4 MHz"^^rdfs:Literal .

