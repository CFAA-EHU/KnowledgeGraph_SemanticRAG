    rdfs:label "Encoder Fagor HA-27-D200" ;
    ns1:identificador "Fagor HA-27-D200" ;
    ns1:monitoreaParametro ns1:Parametro_SSITYPE ;
    ns1:textoExtracto "Fagor HA-27-D200 | Encoder Fagor." .

