    ns1:monitoreaParametro ns1:Parametro_SSITYPE ;
    ns1:textoExtracto "Fagor SA-23-D90 | Encoder Fagor." .

ns1:Sensor_ABSIND_InductosynLIN a ns1:Sensor ;
    rdfs:label "Captador lineal absoluto (ABSIND inductosyn LIN)" ;
    ns1:identificador "ABSIND (inductosyn LIN)" ;
    ns1:monitoreaParametro ns1:Parametro_SSITYPE ;
    ns1:textoExtracto "ABSIND (inductosyn LIN) | Captador lineal absoluto en el pitch. Hace falta referenciar la regla." .

ns1:Sensor_ABSIND_InductosynLIN_ABS a ns1:Sensor ;
    rdfs:label "Captador lineal absoluto (ABSIND inductosyn LIN+ABS)" ;
    ns1:identificador "ABSIND (inductosyn LIN+ABS)" ;
    ns1:monitoreaParametro ns1:Parametro_SSITYPE ;
    ns1:textoExtracto "ABSIND (inductosyn LIN+ABS) | Captador lineal absoluto." .

ns1:Sensor_ABSIND_InductosynROT a ns1:Sensor ;
    rdfs:label "Captador rotativo absoluto (ABSIND inductosyn ROT)" ;
    ns1:identificador "ABSIND (inductosyn ROT)" ;
    ns1:monitoreaParametro ns1:Parametro_SSITYPE ;
    ns1:textoExtracto "ABSIND (inductosyn ROT) | Captador rotativo absoluto en el pitch. Hace falta referenciar la regla." .

ns1:Sensor_ABSIND_InductosynROT_ABS a ns1:Sensor ;
    rdfs:label "Captador rotativo absoluto (ABSIND inductosyn ROT+ABS)" ;
    ns1:identificador "ABSIND (inductosyn ROT+ABS)" ;
    ns1:monitoreaParametro ns1:Parametro_SSITYPE ;
    ns1:textoExtracto "ABSIND (inductosyn ROT+ABS) | Captador rotativo absoluto en una vuelta del encoder." .

ns1:Sensor_ABSIND_Resolver a ns1:Sensor ;
    rdfs:label "Captador rotativo absoluto (ABSIND resolver)" ;
    ns1:identificador "ABSIND (resolver)" ;
    ns1:monitoreaParametro ns1:Parametro_SSITYPE ;
    ns1:textoExtracto "ABSIND (resolver) | Captador rotativo absoluto en una vuelta." .

ns1:Tabla_ParametrosSSI a ns1:Tabla ;
    rdfs:label "Tabla de parámetros SSI" ;
    ns1:detalladoEnEsquema ns1:Parametro_SSITYPE ;
    ns1:textoExtracto "SSI Tabla de parámetros SSI (Synchronous Serial Interface). Este parámetro muestra la tabla de parámetros para configurar el formato de transmisión SSI. En función del tipo de regla seleccionado (parámetro SSITYPE), algunos de estos valores estarán prefijados y no se podrán modificar." .

ns1:Parametro_SSITYPE a ns1:Parametro ;
    rdfs:label "SSITYPE" ;
    ns1:identificador "V.[ch].MPA.SSITYPE[set].xn" ;
    ns1:textoExtracto "SSITYPE Tipo de captación SSI conectada a la captación correspondiente. Valores posibles: SSITYPE Fagor / Usuario G / Usuario. Valor por defecto: Usuario. Variable asociada: (V.)[ch].MPA.SSITYPE[set].xn Cuando FEEDBACKTYPE=SSI, este parámetro permite definir el formato de la transmisión SSI." ;
    ns1:valor "Usuario"^^xsd:string .

