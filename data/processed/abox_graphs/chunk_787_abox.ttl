@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Encoder_Fagor_HA_23_D90 a ns1:ComponenteElectrico ;
    rdfs:label "Encoder Fagor HA-23-D90" ;
    ns1:identificador "Fagor HA-23-D90" ;
    ns1:monitoreaParametro ns1:Parametro_SSITYPE ;
    ns1:textoExtracto "Fagor HA-23-D90 | Encoder Fagor." .

