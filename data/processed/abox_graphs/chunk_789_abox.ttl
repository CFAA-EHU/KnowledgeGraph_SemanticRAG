@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCaptacionSSI a ns1:Sistema ;
    rdfs:label "Sistema de captación SSI" ;
    ns1:monitoreaParametro ns1:Parametro_SSIALARMBITS,
        ns1:Parametro_SSICRCBITS,
        ns1:Parametro_SSIDATALENGTH,
        ns1:Parametro_SSISTARTBITS ;
    ns1:textoExtracto "Los siguientes parámetros definen el orden y el formato en el que el sistema de captación envía los datos." ;
    ns1:tieneComponente ns1:Parametro_SSIALARMBITS,
        ns1:Parametro_SSICRCBITS,
        ns1:Parametro_SSIDATALENGTH,
        ns1:Parametro_SSIDATAMODE,
        ns1:Parametro_SSIOPERATION,
        ns1:Parametro_SSIPACKFORMAT,
        ns1:Parametro_SSISTARTBITS .

ns1:Parametro_SSIDATAMODE a ns1:Parametro ;
    rdfs:label "SSIDATAMODE" ;
    ns1:identificador "SSIDATAMODE" ;
    ns1:textoExtracto "Orden en el que se transmite el bit más significativo. • SSIDATAMODE = 0; el primer bit es el LSB (Least Significant Bit). • SSIDATAMODE = 1; el primer bit es el MSB (Most Significant Bit)." .

ns1:Parametro_SSIOPERATION a ns1:Parametro ;
    rdfs:label "SSIOPERATION" ;
    ns1:identificador "SSIOPERATION" ;
    ns1:textoExtracto "Tipo de operación sobre los datos antes de leerlos." .

ns1:Parametro_SSIPACKFORMAT a ns1:Parametro ;
    rdfs:label "SSIPACKFORMAT" ;
    ns1:identificador "SSIPACKFORMAT" ;
    ns1:textoExtracto "Orden en el que los datos son enviados por el encoder. Si primero nos va llegar la cota, el CRC o la alarma y que orden hay entre ellos. Si hay bits de start programados, se considera que siempre van a recibirse los primeros." .

ns1:Parametro_SSIALARMBITS a ns1:Parametro ;
    rdfs:label "SSIALARMBITS" ;
    ns1:identificador "SSIALARMBITS" ;
    ns1:textoExtracto "Número de bits, si los hubiese, para el chequeo de una transmisión correcta. El captador puede mandar uno o varios bits indicando una condición de alarma si algo ha ido mal, o bien uno o varios bits de reconocimiento (acknowledge) si la transmisión ha sido efectuada correctamente." .

ns1:Parametro_SSICRCBITS a ns1:Parametro ;
    rdfs:label "SSICRCBITS" ;
    ns1:identificador "SSICRCBITS" ;
    ns1:textoExtracto "Número de bits, si los hubiese, que constituyen algún tipo de chequeo de transmisión válida (CRC, checksum, paridad)." .

ns1:Parametro_SSIDATALENGTH a ns1:Parametro ;
    rdfs:label "SSIDATALENGTH" ;
    ns1:identificador "SSIDATALENGTH" ;
    ns1:textoExtracto "Número de bits de la transmisión SSI que constituyen la cota." .

ns1:Parametro_SSISTARTBITS a ns1:Parametro ;
    rdfs:label "SSISTARTBITS" ;
    ns1:identificador "SSISTARTBITS" ;
    ns1:textoExtracto "Número de bits, si los hubiese, que es necesario esperar para empezar a recibir la información de cota." .

