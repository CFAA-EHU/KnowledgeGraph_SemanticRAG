@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_ParametrosSSI a ns1:Tabla ;
    rdfs:label "Tabla de parámetros SSI (Tipo de captación SSI)" ;
    ns1:documentadoEn ns1:Param_SSIALARMLEVEL,
        ns1:Param_SSICRCTYPE,
        ns1:Param_SSIDATALENGTH,
        ns1:Param_SSIOPERATION,
        ns1:Param_SSIPACKFORMAT ;
    ns1:textoExtracto "Tabla de parámetros SSI con columnas 'Parámetro' y 'Significado' describiendo SSIALARMLEVEL, SSICRCTYPE, SSIDATALENGTH, SSIPACKFORMAT y SSIOPERATION." .

ns1:Param_SSIALARMLEVEL a ns1:Parametro ;
    rdfs:label "SSIALARMLEVEL" ;
    ns1:identificador "SSIALARMLEVEL" ;
    ns1:textoExtracto "Valores que pueden provocar que el encoder transmita uno o más bits indicando algún tipo de error." ;
    ns1:valor "Variable asociada: (V.)[ch].MPA.SSIALARMLEVEL[set].xn" .

ns1:Param_SSICRCTYPE a ns1:Parametro ;
    rdfs:label "SSICRCTYPE" ;
    ns1:identificador "SSICRCTYPE" ;
    ns1:textoExtracto "Tipo de cálculo a realizar cuando el encoder transmita información adicional a la cota para realizar algún tipo de comprobación de coherencia en los datos." .

ns1:Param_SSIDATALENGTH a ns1:Parametro ;
    rdfs:label "SSIDATALENGTH" ;
    ns1:identificador "SSIDATALENGTH" ;
    ns1:textoExtracto "Número de bits de la transmisión SSI que constituyen la cota. Valores posibles: De 0 a 255. Valor por defecto: 0." ;
    ns1:valor "Variable asociada: (V.)[ch].MPA.SSIDATALENGTH[set].xn" .

ns1:Param_SSIOPERATION a ns1:Parametro ;
    rdfs:label "SSIOPERATION" ;
    ns1:identificador "SSIOPERATION" ;
    ns1:textoExtracto "Tipo de operación sobre los datos antes de leerlos. Valores posibles: De 0 a 1." .

ns1:Param_SSIPACKFORMAT a ns1:Parametro ;
    rdfs:label "SSIPACKFORMAT" ;
    ns1:identificador "SSIPACKFORMAT" ;
    ns1:textoExtracto "Formato de paquete SSI. Valores posibles: Data / Data-CRC / CRC-Data / Data-Alarm / Alarm-Data / Data-CRC-Alarm / Alarm-Data-CRC / Data-Alarm-CRC / Alarm-CRC-Data / CRC-Data-Alarm / CRC-Alarm-Data. Valor por defecto: Data." ;
    ns1:valor "Variable asociada: (V.)[ch].MPA.SSIPACKFORMAT[set].xn" .

