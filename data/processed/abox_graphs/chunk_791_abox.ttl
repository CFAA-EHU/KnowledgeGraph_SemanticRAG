@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_SSIOPERATION a ns1:Parametro ;
    rdfs:label "SSIOPERATION" ;
    ns1:identificador "SSIOPERATION" ;
    ns1:textoExtracto "Este parámetro indica si es necesario realizar algún tipo de operación sobre los datos antes de ser interpretados, ya que pueden estar codificados en un formato específico." ;
    ns1:valor "0" .

