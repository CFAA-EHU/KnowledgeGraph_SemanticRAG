@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_FormatoDatosSSI a ns1:Parametro ;
    rdfs:label "Formato de datos SSI"@es ;
    ns1:documentadoEn ns1:Tabla_FormatoDatosSSI ;
    ns1:textoExtracto "Los datos llegan en formato binario o Gray Code según valor 0 o 1."@es ;
    ns1:valor 0 .

ns1:Parametro_SSICRCBITS a ns1:Parametro ;
    rdfs:label "SSICRCBITS"@es ;
    ns1:textoExtracto "Este parámetro sólo tiene sentido en el caso de que SSICRCBITS sea distinto de 0."@es .

ns1:Parametro_SSICRCTYPE a ns1:Parametro ;
    rdfs:label "SSICRCTYPE (Tipo de CRC)"@es ;
    ns1:textoExtracto "SSICRCTYPE Tipo de CRC. Valores posibles: No calcular CRC / Checksum Fagor / Checksum INDUCTOSYN. Valor por defecto: No calcular CRC. Variable asociada: (V.)[ch].MPA.SSICRCTYPE[set].xn Cuando el encoder transmite información adicional a la cota, este parámetro define el tipo de cálculo a realizar para comprobar la coherencia en los datos."@es ;
    ns1:valor "No calcular CRC"@es .

ns1:Tabla_FormatoDatosSSI a ns1:Tabla ;
    rdfs:label "Tabla de formatos de datos SSI"@es ;
    ns1:textoExtracto """| Valor. | Significado. |
| --- | --- |
| 0 | Los datos llegan en formato binario. |
| 1 | Los datos llegan en formato Gray Code. |"""@es .

