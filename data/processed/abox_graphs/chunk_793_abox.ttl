@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_ChecksumFagor a ns1:Parametro ;
    rdfs:label "Checksum Fagor"@es ;
    ns1:documentadoEn ns1:Tabla_532_ParametrosCRC ;
    ns1:textoExtracto "Algoritmo de comprobación de datos empleado en las captaciones de Fagor Automation."@es ;
    ns1:valor "Checksum Fagor"@es .

ns1:Parametro_ChecksumINDUCTOSYN a ns1:Parametro ;
    rdfs:label "Checksum INDUCTOSYN"@es ;
    ns1:documentadoEn ns1:Tabla_532_ParametrosCRC ;
    ns1:textoExtracto "Algoritmo de comprobación de datos empleado en el conexionado con un módulo INDUCTOSYN."@es ;
    ns1:valor "Checksum INDUCTOSYN"@es .

ns1:Parametro_NoCalcularCRC a ns1:Parametro ;
    rdfs:label "No calcular CRC"@es ;
    ns1:documentadoEn ns1:Tabla_532_ParametrosCRC ;
    ns1:textoExtracto "Aunque el CNC recibe los bits de CRC, no se hace ningún procesamiento de los mismos y por lo tanto no se reportan errores si la transmisión es errónea. No es una opción recomendable y sólo debe usarse en casos de puesta a punto."@es ;
    ns1:valor "No calcular CRC"@es .

ns1:Tabla_532_ParametrosCRC a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de CRC para módulos SSI"@es ;
    ns1:textoExtracto "Valor. | Significado."@es .

