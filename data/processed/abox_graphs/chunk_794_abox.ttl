@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Tabla_ConfiguracionEjemploCRC a ns1:Tabla ;
    rdfs:label "Ejemplo de configuración CRC en reglas absolutas Fagor" ;
    ns1:documentadoEn ns1:Sistema_TransmisionSSI ;
    ns1:textoExtracto "las reglas absolutas Fagor pueden configurarse para transmitir 5 bits de CRC junto con el valor de la cota. Si una regla está configurada en este modo deberá programarse SSIDATALENGTH=27 y SSICRCBITS=5." .

ns1:Parametro_SSICRCBITS a ns1:Parametro ;
    rdfs:label "SSICRCBITS" ;
    ns1:textoExtracto "SSICRCBITS Número de bits que componen el CRC de la transmisión SSI que constituyen el chequeo de transmisión válida. Valores posibles: De 0 a 31. Valor por defecto: 0." ;
    ns1:valor 0 .

ns1:Parametro_SSIDATALENGTH a ns1:Parametro ;
    rdfs:label "SSIDATALENGTH" ;
    ns1:textoExtracto "SSIDATALENGTH=27" ;
    ns1:valor 27 .

ns1:Parametro_SSISTARTBITS a ns1:Parametro ;
    rdfs:label "SSISTARTBITS" ;
    ns1:textoExtracto "SSISTARTBITS Número de bits de start. Valores posibles: De 0 a 3. Valor por defecto: 0." ;
    ns1:valor 0 .

ns1:Sistema_TransmisionSSI a ns1:Sistema ;
    rdfs:label "Sistema de transmisión SSI (INDUCTOSYN)" ;
    ns1:textoExtracto "Checksum INDUCTOSYN. | Algoritmo de comprobación de datos empleado en el conexionado con un módulo INDUCTOSYN." ;
    ns1:tieneComponente ns1:Parametro_SSICRCBITS,
        ns1:Parametro_SSIDATALENGTH,
        ns1:Parametro_SSISTARTBITS .

