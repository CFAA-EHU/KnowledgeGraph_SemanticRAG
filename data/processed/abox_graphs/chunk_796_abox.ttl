@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:SSIALARMBITS a ns1:Parametro ;
    rdfs:label "SSIALARMBITS" ;
    ns1:identificador "SSIALARMBITS" ;
    ns1:textoExtracto "Este parámetro sólo tiene sentido en el caso de que SSIALARMBITS sea distinto de 0." .

ns1:SSIALARMLEVEL a ns1:Parametro ;
    rdfs:label "SSIALARMLEVEL" ;
    ns1:identificador "SSIALARMLEVEL" ;
    ns1:textoExtracto "Nivel de los bits de alarma para dar error. Valores posibles: De 0 a 3. Valor por defecto: 0." ;
    ns1:valor 0 .

ns1:Variable_SSIALARMLEVEL a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.SSIALARMLEVEL[set].xn" ;
    ns1:identificador "(V.)[ch].MPA.SSIALARMLEVEL[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.SSIALARMLEVEL[set].xn. Valor que tienen que tener los bits de alarma/acknowledge para que se produzca una condición de error." .

