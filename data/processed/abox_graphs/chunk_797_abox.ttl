@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_CLOCKFREQ a ns1:Parametro ;
    rdfs:label "CLOCKFREQ" ;
    ns1:identificador "CLOCKFREQ" ;
    ns1:textoExtracto "CLOCKFREQ = 400 kHz" ;
    ns1:valor 400 .

ns1:Parametro_SSIALARMBITS a ns1:Parametro ;
    rdfs:label "SSIALARMBITS" ;
    ns1:textoExtracto "SSIALARMBITS = 1" ;
    ns1:valor 2 .

ns1:Parametro_SSIALARMLEVEL a ns1:Parametro ;
    rdfs:label "SSIALARMLEVEL" ;
    ns1:textoExtracto "SSIALARMLEVEL = 1" ;
    ns1:valor 2 .

ns1:Parametro_SSIDATAMODE a ns1:Parametro ;
    rdfs:label "SSIDATAMODE" ;
    ns1:identificador "SSIDATAMODE" ;
    ns1:textoExtracto "SSIDATAMODE Modo de transmisión. Valores posibles: De 0 a 1. Valor por defecto: 0." .

ns1:Parametro_SSIRESOL a ns1:Parametro ;
    rdfs:label "SSIRESOL" ;
    ns1:identificador "SSIRESOL" ;
    ns1:textoExtracto "SSIRESOL Resolución del contaje digital. Valores posibles: De 1 a 999999999. Valor por defecto: 10000." ;
    ns1:valor 10000 .

ns1:Parametro_STARTDELAY a ns1:Parametro ;
    rdfs:label "STARTDELAY" ;
    ns1:identificador "STARTDELAY" ;
    ns1:textoExtracto "STARTDELAY Número de clocks a esperar entre el primer flanco de bajada y el primer flanco de subida. Valores posibles: De 0 a 255. Valor por defecto: 0." ;
    ns1:valor 0 .

ns1:Tabla_ParametrosSSI a ns1:Tabla ;
    rdfs:label "Tabla de parámetros SSI" ;
    ns1:documentadoEn ns1:Pagina_232_236 ;
    ns1:textoExtracto "SSIDATAMODE Modo de transmisión. Valores posibles: De 0 a 1. Variable asociada: (V.)[ch].MPA.SSIDATAMODE[set].xn STARTDELAY Número de clocks a esperar... SSIRESOL Resolución del contaje digital..." .

ns1:Pagina_232_236 a ns1:Pagina ;
    rdfs:label "Páginas 232-236" ;
    ns1:identificador "2.6.25" ;
    ns1:textoExtracto "Tipo de captación SSI. Ejemplo: En el caso de que un encoder indique una condición de error con 2 bits..." .

