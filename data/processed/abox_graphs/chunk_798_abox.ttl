@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_Encoder8192Pulsos a ns1:Sensor ;
    rdfs:label "Encoder (8192 pulsos/vuelta)"@es ;
    ns1:documentadoEn ns1:Manual_Seccion2.6.25 ;
    ns1:identificador "8192ppv" ;
    ns1:monitoreaParametro ns1:Parametro_SSIRESOL_Encoder8192Pulsos ;
    ns1:textoExtracto "encoder de 8192 pulsos por vuelta"@es .

ns1:Componente_Husillo10mm a ns1:ComponenteMecanico ;
    rdfs:label "Husillo (paso 10mm)"@es ;
    ns1:documentadoEn ns1:Manual_Seccion2.6.25 ;
    ns1:identificador "10mm_paso" ;
    ns1:textoExtracto "husillo de paso 10 mm"@es ;
    ns1:tieneComponente ns1:Parametro_PITCH_Husillo10mm .

ns1:Componente_InductosynABSIND a ns1:Sensor ;
    rdfs:label "Inductosyn (ROT+ABS, 10000 unidades)"@es ;
    ns1:documentadoEn ns1:Manual_Seccion2.6.25 ;
    ns1:identificador "ABSIND_10000" ;
    ns1:monitoreaParametro ns1:Parametro_PITCH_Inductosyn2Grados,
        ns1:Parametro_PITCH_Inductosyn4Grados,
        ns1:Parametro_SSIRESOL_InductosynABS ;
    ns1:textoExtracto "SSITYPE = ABSIND (inductosyn ROT+ABS), para un giro de 2 ó 4 grados... el incremento del contaje es de 10000 unidades"@es .

ns1:Componente_ReglaAbsolutaFagor20Micras a ns1:Sensor ;
    rdfs:label "Regla absoluta Fagor (20µ)"@es ;
    ns1:documentadoEn ns1:Manual_Seccion2.6.25 ;
    ns1:identificador "Fagor_20µ" ;
    ns1:monitoreaParametro ns1:Parametro_PITCH_ReglaFagor20Micras,
        ns1:Parametro_SSIRESOL_ReglaFagor20Micras ;
    ns1:textoExtracto "Regla absoluta Fagor de 20 micras de paso de regla y una resolución digital de 1 dµ."@es .

ns1:Tabla_EjemplosSSI a ns1:Tabla ;
    rdfs:label "Ejemplos de resolución SSI (Sección 2.6.25)"@es ;
    ns1:documentadoEn ns1:Pagina_232_236 ;
    ns1:ilustradoEn ns1:Manual_Seccion2.6.25 ;
    ns1:textoExtracto "Ejemplo: Regla absoluta Fagor... Ejemplo: encoder de 8192 pulsos... Ejemplo: SSITYPE = ABSIND (inductosyn ROT+ABS)..."@es .

ns1:Parametro_PITCH_Husillo10mm a ns1:Parametro ;
    rdfs:label "Paso de husillo (10mm)"@es ;
    ns1:documentadoEn ns1:Manual_Seccion2.6.25 ;
    ns1:identificador "10mm" ;
    ns1:textoExtracto "husillo de paso 10 mm. PITCH = 10 mm"@es ;
    ns1:valor "10" .

ns1:Parametro_PITCH_Inductosyn2Grados a ns1:Parametro ;
    rdfs:label "Paso angular (Inductosyn 2°)"@es ;
    ns1:documentadoEn ns1:Manual_Seccion2.6.25 ;
    ns1:identificador "2°" ;
    ns1:textoExtracto "PITCH = 2º"@es ;
    ns1:valor "2" .

ns1:Parametro_PITCH_Inductosyn4Grados a ns1:Parametro ;
    rdfs:label "Paso angular (Inductosyn 4°)"@es ;
    ns1:documentadoEn ns1:Manual_Seccion2.6.25 ;
    ns1:identificador "4°" ;
    ns1:textoExtracto "PITCH = 2º ó 4º"@es ;
    ns1:valor "4" .

ns1:Parametro_PITCH_ReglaFagor20Micras a ns1:Parametro ;
    rdfs:label "Paso de regla (Regla Fagor 20µ)"@es ;
    ns1:documentadoEn ns1:Manual_Seccion2.6.25 ;
    ns1:identificador "20µ" ;
    ns1:textoExtracto "Regla absoluta Fagor de 20 micras de paso de regla"@es ;
    ns1:valor "20" .

ns1:Parametro_SSIRESOL_Encoder8192Pulsos a ns1:Parametro ;
    rdfs:label "SSIRESOL (Encoder 8192 pulsos)"@es ;
    ns1:documentadoEn ns1:Manual_Seccion2.6.25 ;
    ns1:textoExtracto "SSIRESOL = 8192"@es ;
    ns1:valor "8192" .

ns1:Parametro_SSIRESOL_InductosynABS a ns1:Parametro ;
    rdfs:label "SSIRESOL (Inductosyn ROT+ABS)"@es ;
    ns1:documentadoEn ns1:Manual_Seccion2.6.25 ;
    ns1:textoExtracto "SSITYPE = ABSIND (inductosyn ROT+ABS)... SSIRESOL = 10000"@es ;
    ns1:valor "10000" .

ns1:Parametro_SSIRESOL_ReglaFagor20Micras a ns1:Parametro ;
    rdfs:label "SSIRESOL (Regla absoluta Fagor 20µ)"@es ;
    ns1:documentadoEn ns1:Manual_Seccion2.6.25 ;
    ns1:textoExtracto "Regla absoluta Fagor de 20 micras de paso de regla y una resolución digital de 1 dµ. SSIRESOL = 20 µ / 0,1 µ = 200."@es ;
    ns1:valor "200" .

