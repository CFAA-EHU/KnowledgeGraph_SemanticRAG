@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_AXDELAY a ns1:Parametro ;
    rdfs:label "AXDELAY" ;
    ns1:identificador "AXDELAY" ;
    ns1:monitoreaParametro ns1:Variable_MPA_AXDELAY ;
    ns1:textoExtracto "AXDELAY Estimación del retardo en el regulador. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "Estándar / De 0 a 127 ciclos" .

ns1:Tabla_ValoresAXDELAY a ns1:Tabla ;
    rdfs:label "Tabla de valores del parámetro AXDELAY" ;
    ns1:documentadoEn ns1:Manual_2.6.26 ;
    ns1:textoExtracto "| Valor. | Significado. | --- | --- | Estándar. | Para regulación Fagor, donde no es necesaria ninguna compensación de retardo." .

ns1:Manual_2.6.26 a ns1:Pagina ;
    rdfs:label "Sección 2.6.26 - Estimación del retardo en el regulador" ;
    ns1:identificador "2.6.26" ;
    ns1:textoExtracto "AXDELAY Estimación del retardo en el regulador. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:Variable_MPA_AXDELAY a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.AXDELAY[set].xn" ;
    ns1:identificador "MPA.AXDELAY" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.AXDELAY[set].xn" .

