@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteMecanico_Palpador a ns1:ComponenteMecanico ;
    rdfs:label "Palpador"@es ;
    ns1:textoExtracto "cálculo de la distancia de frenado del palpador"@es .

ns1:SistemaCNC_Fagor a ns1:Sistema ;
    rdfs:label "Sistema CNC Fagor"@es ;
    ns1:monitoreaParametro ns1:ParametroADVINPOS,
        ns1:ParametroRetardo_Regulador ;
    ns1:textoExtracto "El CNC compensa automáticamente las diferencias de retardo... El CNC también tiene en cuenta este retardo en el cálculo del tiempo de anticipación (marca ADVINPOS), en el repaso de roscas y en el cálculo de la distancia de frenado del palpador."@es ;
    ns1:tieneComponente ns1:ReguladorFagor_CompensacionVariable,
        ns1:ReguladorFagor_Estandar,
        ns1:ReguladorFagor_SinCompensacion .

ns1:ParametroADVINPOS a ns1:Parametro ;
    rdfs:label "ADVINPOS"@es ;
    ns1:textoExtracto "tiempo de anticipación (marca ADVINPOS)"@es .

ns1:ParametroRetardo_Regulador a ns1:Parametro ;
    rdfs:label "Retardo en regulador (Fagor)"@es ;
    ns1:textoExtracto "compensación de retardo... diferencias de retardo entre los reguladores de los ejes del canal... Ciclos de retardo en el regulador."@es ;
    ns1:valor "0-127" .

ns1:ReguladorFagor_CompensacionVariable a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Fagor (compensación 1-127)"@es ;
    ns1:identificador "1-127" ;
    ns1:textoExtracto "Ciclos de retardo en el regulador. El CNC compensa automáticamente las diferencias de retardo entre los reguladores de los ejes del canal."@es .

ns1:ReguladorFagor_Estandar a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Fagor (modo estándar)"@es ;
    ns1:identificador "Estándar" ;
    ns1:textoExtracto "Para regulación Fagor, donde no es necesaria ninguna compensación de retardo. El CNC compensa automáticamente las diferencias de retardo entre los reguladores de los ejes del canal."@es .

ns1:ReguladorFagor_SinCompensacion a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Fagor (compensación=0)"@es ;
    ns1:identificador "0" ;
    ns1:textoExtracto "El CNC no aplica compensación de retardo en el regulador."@es .

