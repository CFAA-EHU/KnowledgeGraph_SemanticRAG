@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_EjesLineales a ns1:Sistema ;
    rdfs:label "Ejes lineales" ;
    ns1:textoExtracto "Parámetro valido para ejes lineales y rotativos."@es ;
    ns1:tieneComponente ns1:Parametro_TRANSDELAY .

ns1:Sistema_EjesRotativos a ns1:Sistema ;
    rdfs:label "Ejes rotativos" ;
    ns1:textoExtracto "Parámetro valido para ejes lineales y rotativos."@es ;
    ns1:tieneComponente ns1:Parametro_TRANSDELAY .

ns1:Sistema_ModeloLaser a ns1:Sistema ;
    rdfs:label "Modelo láser" ;
    ns1:textoExtracto "Particularidades en el modelo láser."@es ;
    ns1:tieneComponente ns1:Parametro_TRANSDELAY .

ns1:Sistema_ReguladorAnalogico a ns1:Sistema ;
    rdfs:label "Regulador analógico" ;
    ns1:textoExtracto "Parámetro valido para regulador analógico, Sercos velocidad y simulado."@es ;
    ns1:tieneComponente ns1:Parametro_TRANSDELAY .

ns1:Sistema_SercosVelocidad a ns1:Sistema ;
    rdfs:label "Sercos velocidad" ;
    ns1:textoExtracto "Parámetro valido para regulador analógico, Sercos velocidad y simulado."@es ;
    ns1:tieneComponente ns1:Parametro_TRANSDELAY .

ns1:Variable_V_MPA_TRANSDELAY a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.TRANSDELAY[set].xn" ;
    ns1:identificador "(V.)[ch].MPA.TRANSDELAY[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.TRANSDELAY[set].xn"@es .

ns1:Parametro_TRANSDELAY a ns1:Parametro ;
    rdfs:label "TRANSDELAY" ;
    ns1:identificador "TRANSDELAY" ;
    ns1:monitoreaParametro ns1:Variable_V_MPA_TRANSDELAY ;
    ns1:textoExtracto "TRANSDELAY Corrección del retardo introducido por el bus y el regulador. Parámetro valido para ejes lineales y rotativos. Parámetro valido para regulador analógico, Sercos velocidad y simulado. Valores posibles: De 0 a 4*LOOPTIME µs. Valor por defecto: 0."@es ;
    ns1:valor "0" .

