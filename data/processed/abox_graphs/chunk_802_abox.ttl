@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaquinaLaser_541 a ns1:Maquina ;
    rdfs:label "Máquina láser con control de gap"@es ;
    ns1:textoExtracto "En máquinas láser con control de gap, el parámetro TRANSDELAY del eje asociado al sensor debe valor 0 (cero), para que la respuesta de la máquina sea igual con y sin control de gap."@es ;
    ns1:tieneComponente ns1:Parametro_ACFWFACTOR_541,
        ns1:Parametro_TRANSDELAY_541,
        ns1:SensorGap_541 .

ns1:Parametro_ACFWFACTOR_541 a ns1:Parametro ;
    rdfs:label "ACFWFACTOR"@es ;
    ns1:identificador "ACFWFACTOR" ;
    ns1:textoExtracto "La compensación de los retardos se realiza con el parámetro ACFWFACTOR, que tendrá un valor más alto que si se aplicara el parámetro TRANSDELAY"@es .

ns1:SensorGap_541 a ns1:Sensor ;
    rdfs:label "Sensor de gap"@es ;
    ns1:monitoreaParametro ns1:Parametro_TRANSDELAY_541 ;
    ns1:textoExtracto "el parámetro TRANSDELAY del eje asociado al sensor"@es .

ns1:Parametro_TRANSDELAY_541 a ns1:Parametro ;
    rdfs:label "TRANSDELAY"@es ;
    ns1:identificador "TRANSDELAY" ;
    ns1:textoExtracto "el parámetro TRANSDELAY del eje asociado al sensor debe valor 0 (cero), para que la respuesta de la máquina sea igual con y sin control de gap"@es ;
    ns1:valor "0" .

