@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Componente_HBH3_HBH4 a ns1:ComponenteElectrico ;
    rdfs:label "Terminal remoto HBH3/HBH4" ;
    ns1:controla ns1:ModoOperacion_Manual ;
    ns1:identificador "HBH3/HBH4" ;
    ns1:textoExtracto "El terminal remoto HBH3/HBH4 cuenta como un volante." .

ns1:Componente_HBLS a ns1:ComponenteElectrico ;
    rdfs:label "Mando portátil HBLS" ;
    ns1:identificador "HBLS" ;
    ns1:textoExtracto "El mando portátil HBLS no cuenta como volante a la hora de definir este parámetro." .

ns1:Parametro_MPGRESOL a ns1:Parametro ;
    rdfs:label "MPGRESOL" ;
    ns1:identificador "MPGRESOL" ;
    ns1:textoExtracto "Para fijar la resolución de cada volante, cuánto avanza en cada una de las posiciones del conmutador, se debe personalizar el parámetro MPGRESOL." .

ns1:Parametro_NMPG a ns1:Parametro ;
    rdfs:label "NMPG" ;
    ns1:identificador "NMPG" ;
    ns1:monitoreaParametro ns1:InterfazUsuario_MANPG ;
    ns1:textoExtracto "NMPG Número de volantes conectados al CNC. Valores posibles: De 0 a 12. Valor por defecto: 0 (no hay volantes). Variable asociada: (V.)MPMAN.NMPG" ;
    ns1:valor 0 .

ns1:Manual_ModoManual a ns1:Manual ;
    ns1:textoExtracto "2.7 Parámetros máquina del modo manual. - 2.7.1 Configuración de los volantes." .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo manual" ;
    ns1:detalladoEnEsquema ns1:InterfazUsuario_MANPG ;
    ns1:textoExtracto "El CNC permite gobernar el desplazamiento de los ejes mediante volantes electrónicos." .

ns1:InterfazUsuario_MANPG a ns1:InterfazUsuario ;
    rdfs:label "Tabla de volantes (MANPG)" ;
    ns1:documentadoEn ns1:Manual_ModoManual ;
    ns1:identificador "MANPG" ;
    ns1:textoExtracto "MANPG Tabla de volantes." .

