@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ParametroConfiguracionVolantes a ns1:Parametro ;
    rdfs:label "Configuración del volante (MANPG n)"@es ;
    ns1:detalladoEnEsquema ns1:TablaVolantesManual ;
    ns1:identificador "MANPG n" ;
    ns1:textoExtracto "MANPG n Configuración del volante. Este parámetro muestra la tabla para configurar los volantes."@es .

ns1:ParametroListaVolantes a ns1:Parametro ;
    rdfs:label "Lista de volantes disponibles"@es ;
    ns1:documentadoEn ns1:TablaVolantesManual ;
    ns1:textoExtracto "lista de volantes disponibles"@es .

ns1:TablaVolantesManual a ns1:Tabla ;
    rdfs:label "Tabla de volantes (MANPG)"@es ;
    ns1:identificador "MANPG" ;
    ns1:textoExtracto "MANPG Tabla de volantes. Este parámetro muestra la lista de volantes disponibles."@es .

