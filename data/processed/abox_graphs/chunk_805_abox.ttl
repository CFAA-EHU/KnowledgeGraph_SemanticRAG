@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo manual" ;
    ns1:textoExtracto "2.7 Parámetros máquina del modo manual."@es ;
    ns1:tieneComponente ns1:Parametro_COUNTERID,
        ns1:Parametro_COUNTERTYPE,
        ns1:Parametro_HWFBTYPE,
        ns1:Parametro_MPGAXIS .

ns1:Parametro_COUNTERID a ns1:Parametro ;
    rdfs:label "COUNTERID" ;
    ns1:documentadoEn ns1:Tabla_MANPG ;
    ns1:identificador "COUNTERID" ;
    ns1:monitoreaParametro ns1:Variable_MPMAN.COUNTERID ;
    ns1:textoExtracto "COUNTERID Entrada de captación asociada al volante. Valores posibles: De 1 a 40 si captación remotas CAN / de -1 a -9 si captación en el teclado / de 1 a 2 si captación local / de 1 a 32 si captación en módulo RCS-S / 1 si la captación variable. Valor por defecto: 0."@es ;
    ns1:valor "0" .

ns1:Parametro_COUNTERTYPE a ns1:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ns1:documentadoEn ns1:Tabla_MANPG ;
    ns1:identificador "COUNTERTYPE" ;
    ns1:monitoreaParametro ns1:Variable_MPMAN.COUNTERTYPE ;
    ns1:textoExtracto "COUNTERTYPE Tipo de entrada de captación del volante. Valores posibles: Remoto / Teclado / Local / Contadora Sercos / Variable. Valor por defecto: Remoto."@es ;
    ns1:valor "Remoto" .

ns1:Parametro_HWFBTYPE a ns1:Parametro ;
    rdfs:label "HWFBTYPE" ;
    ns1:documentadoEn ns1:Tabla_MANPG ;
    ns1:identificador "HWFBTYPE" ;
    ns1:textoExtracto "HWFBTYPE Tipo de captación asociada a la entrada del volante."@es .

ns1:Parametro_MPGAXIS a ns1:Parametro ;
    rdfs:label "MPGAXIS" ;
    ns1:documentadoEn ns1:Tabla_MANPG ;
    ns1:identificador "MPGAXIS" ;
    ns1:textoExtracto "MPGAXIS Nombre del eje asociado al volante."@es .

ns1:Variable_MPMAN.COUNTERID a ns1:Parametro ;
    rdfs:label "(V.)MPMAN.COUNTERID[hw]" ;
    ns1:identificador "MPMAN.COUNTERID" ;
    ns1:textoExtracto "Variable asociada: (V.)MPMAN.COUNTERID[hw]"@es .

ns1:Variable_MPMAN.COUNTERTYPE a ns1:Parametro ;
    rdfs:label "(V.)MPMAN.COUNTERTYPE[hw]" ;
    ns1:identificador "MPMAN.COUNTERTYPE" ;
    ns1:textoExtracto "Variable asociada: (V.)MPMAN.COUNTERTYPE[hw]"@es .

ns1:Tabla_MANPG a ns1:Tabla ;
    rdfs:label "Tabla MANPG" ;
    ns1:identificador "MANPG" ;
    ns1:textoExtracto "Parámetro incluido en la tabla MANPG."@es .

