@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_PrimerTecladoBus a ns1:InterfazUsuario ;
    rdfs:label "Primer teclado en el bus (volantes -1, -2, -3)"@es ;
    ns1:identificador "-1,-2,-3" ;
    ns1:ilustradoEn ns1:Tabla_OrdenVolantesManual ;
    ns1:textoExtracto "Primer teclado en el bus. | -1 -2 -3"@es .

ns1:InterfazUsuario_SegundoTecladoBus a ns1:InterfazUsuario ;
    rdfs:label "Segundo teclado en el bus (volantes -4, -5, -6)"@es ;
    ns1:identificador "-4,-5,-6" ;
    ns1:ilustradoEn ns1:Tabla_OrdenVolantesManual ;
    ns1:textoExtracto "Segundo teclado en el bus. | -4 -5 -6"@es .

ns1:InterfazUsuario_TercerTecladoBus a ns1:InterfazUsuario ;
    rdfs:label "Tercer teclado en el bus (volantes -7, -8, -9)"@es ;
    ns1:identificador "-7,-8,-9" ;
    ns1:ilustradoEn ns1:Tabla_OrdenVolantesManual ;
    ns1:textoExtracto "Tercer teclado en el bus. | -7 -8 -9"@es .

ns1:Tabla_OrdenVolantesManual a ns1:Tabla ;
    rdfs:label "Tabla de orden de volantes en modo manual"@es ;
    ns1:documentadoEn ns1:Pagina_238_239 ;
    ns1:textoExtracto "Orden del teclado. | Numeración de los volantes. --- | --- Primer teclado en el bus. | -1 -2 -3 Segundo teclado en el bus. | -4 -5 -6 Tercer teclado en el bus. | -7 -8 -9"@es .

