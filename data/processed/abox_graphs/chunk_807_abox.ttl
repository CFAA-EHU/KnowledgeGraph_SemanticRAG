@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Interfaz_HBH3_HBH4 a ns1:InterfazUsuario ;
    rdfs:label "Terminal remoto HBH3/HBH4" ;
    ns1:identificador "HBH3/HBH4" ;
    ns1:textoExtracto "El terminal remoto HBH3/HBH4 siempre tendrá valor ꞏ1ꞏ. Volantes conectados a través de una entrada 'Variable'." ;
    ns1:tieneComponente ns1:Parametro_VariableEntrada .

ns1:Parametro_HWFBTYPE a ns1:Parametro ;
    rdfs:label "HWFBTYPE" ;
    ns1:documentadoEn ns1:Tabla_MANPG ;
    ns1:identificador "HWFBTYPE" ;
    ns1:textoExtracto "HWFBTYPE Tipo de captación asociada a la entrada del volante. Valores posibles: TTL / TTLDIFF. Valor por defecto: TTLDIFF. Variable asociada: (V.)MPMAN.HWFBTYPE[hw] Parámetro incluido en la tabla MANPG." ;
    ns1:valor "TTLDIFF" .

ns1:Parametro_MPGAXIS a ns1:Parametro ;
    rdfs:label "MPGAXIS" ;
    ns1:documentadoEn ns1:Tabla_MANPG ;
    ns1:identificador "MPGAXIS" ;
    ns1:textoExtracto "MPGAXIS Nombre del eje asociado al volante. Valores posibles: Cualquier eje definido en AXISNAME. Variable asociada: (V.)MPMAN.MPGAXIS[hw] Parámetro incluido en la tabla MANPG. Este parámetro establece si el volante está asociado a un eje en concreto (volante individual) o si puede desplazar cualquier eje de la máquina (volante general)." .

ns1:Parametro_SERCOUNTID a ns1:Parametro ;
    rdfs:label "SERCOUNTID" ;
    ns1:documentadoEn ns1:Sistema_RCS_S ;
    ns1:identificador "SERCOUNTID" ;
    ns1:textoExtracto "parámetro SERCOUNTID" .

ns1:Sistema_CAN a ns1:Sistema ;
    rdfs:label "Sistema de grupos remotos CAN" ;
    ns1:textoExtracto "Volantes conectados a través de los grupos remotos CAN. Los volantes se numeran de 1 a 40. Los volantes se numeran según el orden lógico de los grupos remotos (conmutador rotativo del elemento Power Supply)." ;
    ns1:tieneComponente ns1:Componente_PowerSupply .

ns1:Sistema_EntradasLocales a ns1:Sistema ;
    rdfs:label "Sistema de entradas de captación locales" ;
    ns1:textoExtracto "Volantes conectados a través de las entradas de captación locales. No es necesario definir este parámetro." .

ns1:Componente_PowerSupply a ns1:ComponenteElectrico ;
    rdfs:label "Power Supply (elemento de conmutación rotativa)" ;
    ns1:textoExtracto "conmutador rotativo del elemento Power Supply" .

ns1:Parametro_VariableEntrada a ns1:Parametro ;
    rdfs:label "Parámetro de entrada Variable (HBH3/HBH4)" ;
    ns1:textoExtracto "El terminal remoto HBH3/HBH4 siempre tendrá valor ꞏ1ꞏ." ;
    ns1:valor "1" .

ns1:Sistema_RCS_S a ns1:Sistema ;
    rdfs:label "Sistema RCS-S (contadora Sercos)" ;
    ns1:identificador "RCS-S" ;
    ns1:textoExtracto "Volantes conectados a través de los módulos RCS-S (contadora Sercos). Los volantes se numeran de 1 a 32. Los volantes se numeran según el orden lógico de los módulos RCS-S (parámetro SERCOUNTID). Las entradas de captación del primer módulo serán 1 a 4, las del segundo 5 a 8 y así sucesivamente." .

ns1:Tabla_MANPG a ns1:Tabla ;
    rdfs:label "Tabla MANPG" ;
    ns1:textoExtracto "Parámetro incluido en la tabla MANPG. Tipo de captación asociada a la entrada del volante, cuando éste se encuentra conectado a las entradas locales o a un módulo RCS-S (contadora Sercos). MPGAXIS Nombre del eje asociado al volante. Parámetro incluido en la tabla MANPG." .

