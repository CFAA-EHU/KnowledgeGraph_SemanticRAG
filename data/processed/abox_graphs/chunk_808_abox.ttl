@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_547_TecladoJog a ns1:InterfazUsuario ;
    rdfs:label "Teclado de jog"@es ;
    ns1:textoExtracto "seleccionar desde el teclado de jog el eje a desplazar"@es .

ns1:ModoOperacion_547_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo manual (configuración volantes)"@es ;
    ns1:textoExtracto "2.7 Parámetros máquina del modo manual. - 2.7.1 Configuración de los volantes"@es .

ns1:Parametro_547_1 a ns1:Parametro ;
    rdfs:label "Nombre del eje (volante individual)"@es ;
    ns1:textoExtracto "definir el nombre del eje al que está asociado"@es ;
    ns1:valor "valor_alfanumérico"@es .

ns1:Parametro_547_2 a ns1:Parametro ;
    rdfs:label "Asignación de volante general"@es ;
    ns1:textoExtracto "no asignar ningún valor al parámetro, dejarlo en blanco"@es ;
    ns1:valor "vacío"@es .

ns1:Parametro_547_3 a ns1:Parametro ;
    rdfs:label "Configuración terminal remoto HBH3/HBH4"@es ;
    ns1:textoExtracto "dejar este parámetro sin definir"@es ;
    ns1:valor "no_definido"@es .

