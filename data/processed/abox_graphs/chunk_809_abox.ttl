@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_TecladoJog a ns1:InterfazUsuario ;
    rdfs:label "Teclado de jog"@es ;
    ns1:habilitadoPor ns1:ModoOperacion_ManualVolantes ;
    ns1:textoExtracto "seleccionar desde el teclado de jog el eje a desplazar"@es .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "CNC"@es ;
    ns1:controla ns1:ModoOperacion_ManualVolantes ;
    ns1:textoExtracto "el CNC sumará o restará los impulsos de ambos volantes"@es ;
    ns1:tieneComponente ns1:Componente_VolanteGeneral,
        ns1:Componente_VolanteIndividual .

ns1:Componente_VolanteGeneral a ns1:ComponenteMecanico ;
    rdfs:label "Volante general"@es ;
    ns1:textoExtracto "este eje se podrá mover con el volante general"@es .

ns1:Componente_VolanteIndividual a ns1:ComponenteMecanico ;
    rdfs:label "Volante individual"@es ;
    ns1:textoExtracto "con su volante individual"@es .

ns1:ModoOperacion_ManualVolantes a ns1:ModoOperacion ;
    rdfs:label "Modo manual con volantes"@es ;
    ns1:textoExtracto "2.7 Parámetros máquina del modo manual. - 2.7.1 Configuración de los volantes."@es .

