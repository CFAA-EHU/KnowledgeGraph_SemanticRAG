@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_TecladoJog a ns1:InterfazUsuario ;
    rdfs:label "Teclado Jog" ;
    ns1:documentadoEn ns1:Tabla_JOGKEYBD2DEF,
        ns1:Tabla_JOGKEYBD8DEF,
        ns1:Tabla_JOGKEYDEF ;
    ns1:textoExtracto "El parámetro JOGKEYDEF corresponde al primer panel de jog, JOGKEYBD2DEF al segundo y así sucesivamente. [...] Cada uno de estos parámetros define la función de una de las teclas de jog." ;
    ns1:tieneComponente ns1:Parametro_JOGKEYBD2DEF_n,
        ns1:Parametro_JOGKEYBD8DEF_n,
        ns1:Parametro_JOGKEYDEF_n .

ns1:Variable_MPMAN_JOGKEYBDkbDEF a ns1:Parametro ;
    rdfs:label "Variable MPMAN.JOGKEYBDkbDEF[jk]" ;
    ns1:identificador "MPMAN.JOGKEYBDkbDEF[jk]" ;
    ns1:monitoreaParametro ns1:Parametro_JOGKEYBD2DEF_n ;
    ns1:textoExtracto "Variable asociada: (V.)MPMAN.JOGKEYBDkbDEF[jk]" .

ns1:Variable_MPMAN_JOGKEYDEF a ns1:Parametro ;
    rdfs:label "Variable MPMAN.JOGKEYDEF[jk]" ;
    ns1:identificador "MPMAN.JOGKEYDEF[jk]" ;
    ns1:monitoreaParametro ns1:Parametro_JOGKEYDEF_n ;
    ns1:textoExtracto "Variable asociada: (V.)MPMAN.JOGKEYDEF[jk]" .

ns1:Parametro_JOGKEYBD8DEF_n a ns1:Parametro ;
    rdfs:label "Parámetro JOGKEYBD8DEF[n]" ;
    ns1:documentadoEn ns1:Tabla_JOGKEYBD8DEF ;
    ns1:identificador "JOGKEYBD8DEF[n]" ;
    ns1:textoExtracto "JOGKEYBD8DEF n" ;
    ns1:valor "1- a 10+, 1 a 10, R, +, -" .

ns1:Parametro_JOGKEYBD2DEF_n a ns1:Parametro ;
    rdfs:label "Parámetro JOGKEYBD2DEF[n]" ;
    ns1:documentadoEn ns1:Tabla_JOGKEYBD2DEF ;
    ns1:identificador "JOGKEYBD2DEF[n]" ;
    ns1:textoExtracto "JOGKEYBD2DEF n" ;
    ns1:valor "1- a 10+, 1 a 10, R, +, -" .

ns1:Parametro_JOGKEYDEF_n a ns1:Parametro ;
    rdfs:label "Parámetro JOGKEYDEF[n]" ;
    ns1:documentadoEn ns1:Tabla_JOGKEYDEF ;
    ns1:identificador "JOGKEYDEF[n]" ;
    ns1:textoExtracto "JOGKEYDEF n [...] define la función de una de las teclas de jog." ;
    ns1:valor "1- a 10+, 1 a 10, R, +, -" .

ns1:Tabla_JOGKEYBD2DEF a ns1:Tabla ;
    rdfs:label "Tabla JOGKEYBD2DEF" ;
    ns1:identificador "JOGKEYBD2DEF" ;
    ns1:textoExtracto "JOGKEYBD2DEF al segundo [panel de jog]." .

ns1:Tabla_JOGKEYBD8DEF a ns1:Tabla ;
    rdfs:label "Tabla JOGKEYBD8DEF" ;
    ns1:identificador "JOGKEYBD8DEF" ;
    ns1:textoExtracto "JOGKEYBD8DEF n" .

ns1:Tabla_JOGKEYDEF a ns1:Tabla ;
    rdfs:label "Tabla JOGKEYDEF" ;
    ns1:identificador "JOGKEYDEF" ;
    ns1:textoExtracto "Tablas para configurar las teclas de jog. [...] Hay disponible una tabla para cada teclado de jog." .

