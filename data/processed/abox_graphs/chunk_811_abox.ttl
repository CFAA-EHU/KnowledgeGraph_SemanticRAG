@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_TecladoJog a ns1:InterfazUsuario ;
    rdfs:label "Teclado de jog" ;
    ns1:textoExtracto "Este parámetro se aplica cuando en el teclado de jog se dispone de teclas distintas para seleccionar el eje y el sentido de desplazamiento." ;
    ns1:tieneComponente ns1:Tecla_Eje1,
        ns1:Tecla_Eje10,
        ns1:Tecla_Eje10Negativo,
        ns1:Tecla_Eje10Positivo,
        ns1:Tecla_Eje1Negativo,
        ns1:Tecla_Eje1Positivo,
        ns1:Tecla_Eje2,
        ns1:Tecla_Eje2Negativo,
        ns1:Tecla_Eje2Positivo,
        ns1:Tecla_Eje3,
        ns1:Tecla_Eje3Negativo,
        ns1:Tecla_Eje3Positivo,
        ns1:Tecla_Eje4,
        ns1:Tecla_Eje4Negativo,
        ns1:Tecla_Eje4Positivo,
        ns1:Tecla_Eje5,
        ns1:Tecla_Eje5Negativo,
        ns1:Tecla_Eje5Positivo,
        ns1:Tecla_Eje6,
        ns1:Tecla_Eje6Negativo,
        ns1:Tecla_Eje6Positivo,
        ns1:Tecla_Eje7,
        ns1:Tecla_Eje7Negativo,
        ns1:Tecla_Eje7Positivo,
        ns1:Tecla_Eje8,
        ns1:Tecla_Eje8Negativo,
        ns1:Tecla_Eje8Positivo,
        ns1:Tecla_Eje9,
        ns1:Tecla_Eje9Negativo,
        ns1:Tecla_Eje9Positivo,
        ns1:Tecla_Rapido,
        ns1:Tecla_SentidoNegativo,
        ns1:Tecla_SentidoPositivo .

ns1:Parametro_JOGTYPE a ns1:Parametro ;
    rdfs:label "JOGTYPE" ;
    ns1:textoExtracto "JOGTYPE Comportamiento de las teclas de jog. Valores posibles: Eje pulsado / Eje mantenido. Valor por defecto: Eje pulsado." ;
    ns1:valor "Eje pulsado" .

ns1:Tecla_Eje1 a ns1:ComponenteElectrico ;
    rdfs:label "Tecla 1" ;
    ns1:monitoreaParametro ns1:Parametro_AXISNAME ;
    ns1:textoExtracto "1 .. 10 Teclas para definir el eje a desplazar." .

ns1:Tecla_Eje1Negativo a ns1:ComponenteElectrico ;
    rdfs:label "Tecla 1-" ;
    ns1:monitoreaParametro ns1:Parametro_AXISNAME ;
    ns1:textoExtracto "1-, 2-, 3-, .. 10- Teclas para definir el eje y el sentido de desplazamiento." .

ns1:Tecla_Eje1Positivo a ns1:ComponenteElectrico ;
    rdfs:label "Tecla 1+" ;
    ns1:monitoreaParametro ns1:Parametro_AXISNAME ;
    ns1:textoExtracto "1+, 2+, 3+, .. 10+ Teclas para definir el eje y el sentido de desplazamiento." .

ns1:Tecla_Rapido a ns1:ComponenteElectrico ;
    rdfs:label "Tecla R" ;
    ns1:textoExtracto "R Tecla de rápido." .

ns1:Tecla_SentidoNegativo a ns1:ComponenteElectrico ;
    rdfs:label "Tecla -" ;
    ns1:textoExtracto "+ - Teclas para definir el sentido de desplazamiento." .

ns1:Tecla_SentidoPositivo a ns1:ComponenteElectrico ;
    rdfs:label "Tecla +" ;
    ns1:textoExtracto "+ - Teclas para definir el sentido de desplazamiento." .

ns1:Parametro_AXISNAME a ns1:Parametro ;
    rdfs:label "AXISNAME" ;
    ns1:textoExtracto "El número corresponde al eje lógico, según el parámetro AXISNAME." .

