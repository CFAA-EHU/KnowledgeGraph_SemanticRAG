@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_TecladoJog_1 a ns1:InterfazUsuario ;
    rdfs:label "Primer teclado de jog" ;
    ns1:ilustradoEn ns1:Tabla_USERKEYDEF ;
    ns1:textoExtracto "USERKEYDEF corresponde al primer panel de jog." ;
    ns1:tieneComponente ns1:Parametro_USERKEYDEF .

ns1:InterfazUsuario_TecladoJog_2 a ns1:InterfazUsuario ;
    rdfs:label "Segundo teclado de jog" ;
    ns1:ilustradoEn ns1:Tabla_USERKEYBD2DEF ;
    ns1:textoExtracto "USERKEYBD2DEF al segundo [panel de jog]." ;
    ns1:tieneComponente ns1:Parametro_USERKEYBD2DEF .

ns1:Parametro_JOGKEYDEF a ns1:Parametro ;
    rdfs:label "JOGKEYDEF" ;
    ns1:identificador "JOGKEYDEF" ;
    ns1:textoExtracto "El significado de este parámetro es similar al parámetro máquina JOGKEYDEF." .

ns1:Parametro_USERKEYBD8DEF a ns1:Parametro ;
    rdfs:label "USERKEYBD8DEF" ;
    ns1:documentadoEn ns1:Tabla_USERKEYBD8DEF ;
    ns1:identificador "USERKEYBD8DEF" ;
    ns1:monitoreaParametro ns1:Variable_V_MPMAN_USERKEYBD8DEF ;
    ns1:textoExtracto "USERKEYBD8DEF n [...] Cada uno de estos parámetros define la función de una de las teclas de usuario." .

ns1:Parametro_USERKEYBD2DEF a ns1:Parametro ;
    rdfs:label "USERKEYBD2DEF" ;
    ns1:documentadoEn ns1:Tabla_USERKEYBD2DEF ;
    ns1:identificador "USERKEYBD2DEF" ;
    ns1:monitoreaParametro ns1:Variable_V_MPMAN_USERKEYBD2DEF ;
    ns1:textoExtracto "USERKEYBD2DEF al segundo [panel de jog]." .

ns1:Parametro_USERKEYDEF a ns1:Parametro ;
    rdfs:label "USERKEYDEF" ;
    ns1:documentadoEn ns1:Tabla_USERKEYDEF ;
    ns1:identificador "USERKEYDEF" ;
    ns1:monitoreaParametro ns1:Variable_V_MPMAN_USERKEYDEF ;
    ns1:textoExtracto "El parámetro USERKEYDEF corresponde al primer panel de jog." .

ns1:Variable_V_MPMAN_USERKEYBD2DEF a ns1:Parametro ;
    rdfs:label "(V.)MPMAN.USERKEYBD2DEF[uk]" ;
    ns1:documentadoEn ns1:Tabla_USERKEYBD2DEF ;
    ns1:identificador "(V.)MPMAN.USERKEYBD2DEF" ;
    ns1:textoExtracto "Variable asociada: (V.)MPMAN.USERKEYBDkbDEF[uk]." .

ns1:Variable_V_MPMAN_USERKEYBD8DEF a ns1:Parametro ;
    rdfs:label "(V.)MPMAN.USERKEYBD8DEF[uk]" ;
    ns1:documentadoEn ns1:Tabla_USERKEYBD8DEF ;
    ns1:identificador "(V.)MPMAN.USERKEYBD8DEF" ;
    ns1:textoExtracto "Variable asociada: (V.)MPMAN.USERKEYBDkbDEF[uk]." .

ns1:Variable_V_MPMAN_USERKEYDEF a ns1:Parametro ;
    rdfs:label "(V.)MPMAN.USERKEYDEF[uk]" ;
    ns1:documentadoEn ns1:Tabla_USERKEYDEF ;
    ns1:identificador "(V.)MPMAN.USERKEYDEF" ;
    ns1:textoExtracto "Variable asociada: (V.)MPMAN.USERKEYDEF[uk]." .

ns1:Tabla_USERKEYBD8DEF a ns1:Tabla ;
    rdfs:label "Tabla USERKEYBD8DEF" ;
    ns1:documentadoEn ns1:Pagina_242 ;
    ns1:textoExtracto "USERKEYBD8DEF n [...] Hay disponible una tabla para cada teclado de jog." .

ns1:Pagina_242 a ns1:Pagina ;
    rdfs:label "Página 242 (Sección 2.7.3)" ;
    ns1:identificador "242" ;
    ns1:textoExtracto "Configurar las teclas de usuario como teclas de jog." .

ns1:Tabla_USERKEYBD2DEF a ns1:Tabla ;
    rdfs:label "Tabla USERKEYBD2DEF" ;
    ns1:documentadoEn ns1:Pagina_242 ;
    ns1:textoExtracto "USERKEYBD2DEF n [...] Hay disponible una tabla para cada teclado de jog." .

ns1:Tabla_USERKEYDEF a ns1:Tabla ;
    rdfs:label "Tabla USERKEYDEF" ;
    ns1:documentadoEn ns1:Pagina_242 ;
    ns1:textoExtracto "USERKEYDEF n [...] Parámetro incluido en la tabla USERKEYDEF. Hay disponible una tabla para cada teclado de jog." .

