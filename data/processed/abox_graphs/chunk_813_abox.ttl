@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_TeclasJog a ns1:InterfazUsuario ;
    rdfs:label "Teclas de usuario configurables como teclas de jog" ;
    ns1:documentadoEn ns1:Tabla_ValoresTeclasJog ;
    ns1:monitoreaParametro ns1:Parametro_AXISNAME,
        ns1:Parametro_JOGKEYDEF,
        ns1:Parametro_JOGTYPE ;
    ns1:textoExtracto "El significado de este parámetro es similar al parámetro máquina JOGKEYDEF. Para definir el comportamiento de cada una de las teclas, se les asignará uno de los siguientes valores" .

ns1:Parametro_AXISNAME a ns1:Parametro ;
    rdfs:label "AXISNAME" ;
    ns1:identificador "AXISNAME" ;
    ns1:textoExtracto "número corresponde al eje lógico, según el parámetro AXISNAME" .

ns1:Parametro_JOGKEYDEF a ns1:Parametro ;
    rdfs:label "JOGKEYDEF" ;
    ns1:identificador "JOGKEYDEF" ;
    ns1:textoExtracto "El significado de este parámetro es similar al parámetro máquina JOGKEYDEF." .

ns1:Parametro_JOGTYPE a ns1:Parametro ;
    rdfs:label "JOGTYPE" ;
    ns1:identificador "JOGTYPE" ;
    ns1:textoExtracto "respetando también lo definido en el parámetro máquina JOGTYPE" .

ns1:Tabla_ValoresTeclasJog a ns1:Tabla ;
    ns1:textoExtracto """
| Valor. | Significado. |
| --- | --- |
| 1-, 2-, 3-, .. 10- | Teclas para definir el eje y el sentido de desplazamiento. El parámetro se define con un valor comprendido entre 1- y 10+ (con signo). El signo indica el sentido de positivo (+) o negativo (-) de movimiento y el número corresponde al eje lógico, según el parámetro AXISNAME. |
| 1 .. 10 | Teclas para definir el eje a desplazar. El parámetro se define con un valor comprendido entre 1 y 10 (sin signo), que corresponde al eje lógico, según el parámetro AXISNAME. |
| + - | Teclas para definir el sentido de desplazamiento. El parámetro se define con uno de los valores "+" y "-", para indicar el sentido de desplazamiento. |
| R | Tecla de rápido. El parámetro se define con el valor "R". """ .

