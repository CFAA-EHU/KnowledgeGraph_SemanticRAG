@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_NMPG a ns1:Parametro ;
    rdfs:label "NMPG (Cómputo total de volantes del sistema)"@es ;
    ns1:textoExtracto "El mando portátil HBLS no afecta al cómputo total de volantes del sistema (parámetro NMPG)."@es .

ns1:Parametro_RSTYPE a ns1:Parametro ;
    rdfs:label "RSTYPE (Tipo de línea serie)"@es ;
    ns1:textoExtracto "Para poder utilizar el panel portátil HBLS, la línea serie debe estar configurada como RS422 (parámetro RSTYPE)."@es .

ns1:Sistema_CNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:textoExtracto "CNC"@es ;
    ns1:tieneComponente ns1:InterfazUsuario_MandoPortatilHBLS .

ns1:InterfazUsuario_MandoPortatilHBLS a ns1:InterfazUsuario ;
    rdfs:label "Mando portátil HBLS"@es ;
    ns1:monitoreaParametro ns1:Parametro_HBLS ;
    ns1:textoExtracto "panel portátil HBLS conectado al CNC a través de la línea serie"@es .

ns1:Parametro_HBLS a ns1:Parametro ;
    rdfs:label "HBLS (Activar mando portátil HBLS)"@es ;
    ns1:identificador "V.MPMAN.HBLS" ;
    ns1:textoExtracto "HBLS Activar mando portátil HBLS. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPMAN.HBLS"@es ;
    ns1:valor "No" .

