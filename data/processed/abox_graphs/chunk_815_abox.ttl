@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_HBHIP a ns1:Parametro ;
    rdfs:label "HBHIP" ;
    ns1:identificador "HBHIP" ;
    ns1:monitoreaParametro ns1:TerminalRemoto_HBH3_HBH4 ;
    ns1:textoExtracto "HBHIP Dirección IP del volante HBH. Valores posibles: De 0 a 15 caracteres. Valor por defecto: 0." ;
    ns1:valor "0" .

ns1:Variable_V_MPMAN_HBHIP a ns1:Parametro ;
    rdfs:label "(V.)MPMAN.HBHIP" ;
    ns1:identificador "(V.)MPMAN.HBHIP" ;
    ns1:monitoreaParametro ns1:TerminalRemoto_HBH3_HBH4 ;
    ns1:textoExtracto "Variable asociada: (V.)MPMAN.HBHIP Dirección IP del volante HBH." .

ns1:Manual_TerminalRemoto_HBH3_HBH4 a ns1:Manual ;
    ns1:textoExtracto "Para obtener mas información sobre el terminal remoto HBH3/HBH4, consultar su manual." .

ns1:TerminalRemoto_HBH3_HBH4 a ns1:InterfazUsuario ;
    rdfs:label "Terminal remoto HBH3/HBH4" ;
    ns1:documentadoEn ns1:Manual_TerminalRemoto_HBH3_HBH4 ;
    ns1:identificador "HBH3/HBH4" ;
    ns1:textoExtracto "Para obtener mas información sobre el terminal remoto HBH3/HBH4, consultar su manual." .

