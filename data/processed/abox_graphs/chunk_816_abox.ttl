@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ContadorX1 a ns1:ComponenteElectrico ;
    rdfs:label "Contador (X1)" ;
    ns1:textoExtracto "Entrada captación: Contador (X1)" .

ns1:ParametroCOUNTERID_X a ns1:Parametro ;
    rdfs:label "COUNTERID" ;
    ns1:identificador "COUNTERID" ;
    ns1:textoExtracto "Parámetro máquina: COUNTERID. Valor: -1. Significado: Conector MPG1." ;
    ns1:valor "-1" .

ns1:ParametroCOUNTERID_Y a ns1:Parametro ;
    rdfs:label "COUNTERID" ;
    ns1:identificador "COUNTERID" ;
    ns1:textoExtracto "Parámetro máquina: COUNTERID. Valor: -2. Significado: Conector MPG2." ;
    ns1:valor "-2" .

ns1:ParametroCOUNTERTYPE_X a ns1:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ns1:identificador "COUNTERTYPE" ;
    ns1:textoExtracto "Parámetro máquina: COUNTERTYPE. Valor: Teclado. Significado: Volante conectado al teclado." ;
    ns1:valor "Teclado" .

ns1:ParametroCOUNTERTYPE_Y a ns1:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ns1:identificador "COUNTERTYPE" ;
    ns1:textoExtracto "Parámetro máquina: COUNTERTYPE. Valor: Teclado. Significado: Volante conectado al teclado." ;
    ns1:valor "Teclado" .

ns1:ParametroMPGAXIS_X a ns1:Parametro ;
    rdfs:label "MPGAXIS" ;
    ns1:identificador "MPGAXIS" ;
    ns1:textoExtracto "Parámetro máquina: MPGAXIS. Valor: X. Significado: Eje asociado." ;
    ns1:valor "X" .

ns1:ParametroMPGRESOL100_X a ns1:Parametro ;
    rdfs:label "MPGRESOL 100" ;
    ns1:identificador "MPGRESOL 100" ;
    ns1:textoExtracto "Parámetro máquina: MPGRESOL 100. Valor: 0.1. Significado: Resolución 0.1" ;
    ns1:valor "0.1" .

ns1:ParametroMPGRESOL10_X a ns1:Parametro ;
    rdfs:label "MPGRESOL 10" ;
    ns1:identificador "MPGRESOL 10" ;
    ns1:textoExtracto "Parámetro máquina: MPGRESOL 10. Valor: 0.01. Significado: Resolución 0.01" ;
    ns1:valor "0.01" .

ns1:ParametroMPGRESOL1_X a ns1:Parametro ;
    rdfs:label "MPGRESOL 1" ;
    ns1:identificador "MPGRESOL 1" ;
    ns1:textoExtracto "Parámetro máquina: MPGRESOL 1. Valor: 0.001. Significado: Resolución 0.001" ;
    ns1:valor "0.001" .

ns1:ParametroNMPG a ns1:Parametro ;
    rdfs:label "NMPG" ;
    ns1:identificador "NMPG" ;
    ns1:textoExtracto "Parámetro máquina: NMPG. Valor: 3. Significado: Sistema con 3 volantes." ;
    ns1:valor "3" .

ns1:SistemaVolantes a ns1:Sistema ;
    rdfs:label "Sistema de volantes" ;
    ns1:textoExtracto "Personalización de los volantes. En una máquina con ejes X, Y, Z, A se desea disponer de un volante individual para el eje X, un volante individual para el eje Y e un volante general para los ejes Z, A." ;
    ns1:tieneComponente ns1:VolanteGeneralZA,
        ns1:VolanteIndividualX,
        ns1:VolanteIndividualY .

ns1:TecladoMPG1 a ns1:ComponenteElectrico ;
    rdfs:label "Teclado (MPG1)" ;
    ns1:textoExtracto "Entrada captación: Teclado (MPG1)" .

ns1:TecladoMPG2 a ns1:ComponenteElectrico ;
    rdfs:label "Teclado (MPG2)" ;
    ns1:textoExtracto "Entrada captación: Teclado (MPG2)" .

ns1:VolanteGeneralZA a ns1:ComponenteMecanico ;
    rdfs:label "Volante general para los ejes Z, A" ;
    ns1:textoExtracto "Volante general para el resto de ejes (Z, A). Entrada captación: Contador (X1). Disco graduado de 100 posiciones. Impulsos/vuelta: 100 Resoluciones (Z): 0.001, 0.01, 0.1 Resoluciones (A): 0.01, 0.1, 1" .

ns1:VolanteIndividualX a ns1:ComponenteMecanico ;
    rdfs:label "Volante individual del eje X" ;
    ns1:textoExtracto "Volante individual para el eje X. Entrada captación: Teclado (MPG1). Disco graduado de 100 posiciones. Impulsos/vuelta: 100 Resoluciones (X): 0.001, 0.01, 0.1" .

ns1:VolanteIndividualY a ns1:ComponenteMecanico ;
    rdfs:label "Volante individual del eje Y" ;
    ns1:textoExtracto "Volante individual para el eje Y. Entrada captación: Teclado (MPG2). Disco graduado de 100 posiciones. Impulsos/vuelta: 200 Resoluciones (Y): 0.001, 0.01, 0.1" .

