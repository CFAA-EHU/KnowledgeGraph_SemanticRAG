@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteElectrico_MPG2 a ns1:ComponenteElectrico ;
    rdfs:label "Conector MPG2"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosVolanteJog ;
    ns1:textoExtracto "Conector MPG2"@es .

ns1:Parametro_COUNTERID a ns1:Parametro ;
    rdfs:label "COUNTERID" ;
    ns1:documentadoEn ns1:Tabla_ParametrosVolanteJog ;
    ns1:identificador "COUNTERID" ;
    ns1:textoExtracto "COUNTERID | -2 | Conector MPG2."@es ;
    ns1:valor "-2" .

ns1:Parametro_COUNTERTYPE a ns1:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ns1:documentadoEn ns1:Tabla_ParametrosVolanteJog ;
    ns1:identificador "COUNTERTYPE" ;
    ns1:textoExtracto "COUNTERTYPE | Teclado. | Volante conectado al teclado."@es ;
    ns1:valor "Teclado" .

ns1:Parametro_MPGAXIS a ns1:Parametro ;
    rdfs:label "MPGAXIS" ;
    ns1:documentadoEn ns1:Tabla_ParametrosVolanteJog ;
    ns1:identificador "MPGAXIS" ;
    ns1:textoExtracto "MPGAXIS | Y | Eje asociado."@es ;
    ns1:valor "Y" .

ns1:Parametro_MPGRESOL_1 a ns1:Parametro ;
    rdfs:label "MPGRESOL 1" ;
    ns1:documentadoEn ns1:Tabla_ParametrosVolanteJog ;
    ns1:identificador "MPGRESOL 1" ;
    ns1:textoExtracto "MPGRESOL 1 | 0.0005 | Resolución 0.001"@es ;
    ns1:valor "0.0005" .

ns1:Parametro_MPGRESOL_10 a ns1:Parametro ;
    rdfs:label "MPGRESOL 10" ;
    ns1:documentadoEn ns1:Tabla_ParametrosVolanteJog ;
    ns1:identificador "MPGRESOL 10" ;
    ns1:textoExtracto "MPGRESOL 10 | 0.005 | Resolución 0.01"@es ;
    ns1:valor "0.005" .

ns1:Parametro_MPGRESOL_100 a ns1:Parametro ;
    rdfs:label "MPGRESOL 100" ;
    ns1:documentadoEn ns1:Tabla_ParametrosVolanteJog ;
    ns1:identificador "MPGRESOL 100" ;
    ns1:textoExtracto "MPGRESOL 100 | 0.05 | Resolución 0.1"@es ;
    ns1:valor "0.05" .

ns1:Tabla_ParametrosVolanteJog a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de máquina para personalización de volantes y teclas de jog"@es ;
    ns1:textoExtracto """
| Parámetro máquina. | Valor. | Significado. |
| --- | --- | --- |
| COUNTERTYPE | Teclado. | Volante conectado al teclado. |
| COUNTERID | -2 | Conector MPG2. |
| MPGAXIS | Y | Eje asociado. |
| MPGRESOL 1 | 0.0005 | Resolución 0.001 |
| MPGRESOL 10 | 0.005 | Resolución 0.01 |
| MPGRESOL 100 | 0.05 | Resolución 0.1 """ .

