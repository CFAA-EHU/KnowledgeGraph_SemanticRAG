@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Interfaz_JOG_PANEL a ns1:InterfazUsuario ;
    rdfs:label "Teclado JOG-PANEL"@es ;
    ns1:textoExtracto "Ejemplo 1: Teclado JOG-PANEL. Ejemplo 2: Teclado JOG-PANEL. Ejemplo 3: Teclado JOG-PANEL."@es .

ns1:Interfaz_LCD_10K a ns1:InterfazUsuario ;
    rdfs:label "Teclado LCD-10K"@es ;
    ns1:textoExtracto "Ejemplo 4: Teclado LCD-10K. Ejemplo 5: Teclado LCD-10K. Ejemplo 6: Teclado LCD-10K."@es .

ns1:Parametro_A_MPGRESOL_1 a ns1:Parametro ;
    rdfs:label "A-MPGRESOL (resolución 0.01)" ;
    ns1:documentadoEn ns1:TablaParametrosVolantesJog ;
    ns1:identificador "A-MPGRESOL_1" ;
    ns1:textoExtracto "A - MPGRESOL 1 | 0.01 | Eje A. Resolución 0.01"@es ;
    ns1:valor "0.01" .

ns1:Parametro_A_MPGRESOL_10 a ns1:Parametro ;
    rdfs:label "A-MPGRESOL (resolución 0.1)" ;
    ns1:documentadoEn ns1:TablaParametrosVolantesJog ;
    ns1:identificador "A-MPGRESOL_10" ;
    ns1:textoExtracto "A - MPGRESOL 10 | 0.1 | Eje A. Resolución 0.1"@es ;
    ns1:valor "0.1" .

ns1:Parametro_A_MPGRESOL_100 a ns1:Parametro ;
    rdfs:label "A-MPGRESOL (resolución 1)" ;
    ns1:documentadoEn ns1:TablaParametrosVolantesJog ;
    ns1:identificador "A-MPGRESOL_100" ;
    ns1:textoExtracto "A - MPGRESOL 100 | 1 | Eje A. Resolución 1"@es ;
    ns1:valor "1" .

ns1:Parametro_COUNTERID a ns1:Parametro ;
    rdfs:label "COUNTERID" ;
    ns1:documentadoEn ns1:TablaParametrosVolantesJog ;
    ns1:identificador "COUNTERID" ;
    ns1:textoExtracto "COUNTERID | 1 | Entrada de contaje X1."@es ;
    ns1:valor "1" .

ns1:Parametro_COUNTERTYPE a ns1:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ns1:documentadoEn ns1:TablaParametrosVolantesJog ;
    ns1:identificador "COUNTERTYPE" ;
    ns1:textoExtracto "COUNTERTYPE | Remoto. | Volante conectado a los módulos remotos."@es ;
    ns1:valor "Remoto" .

ns1:Parametro_MPGAXIS a ns1:Parametro ;
    rdfs:label "MPGAXIS" ;
    ns1:documentadoEn ns1:TablaParametrosVolantesJog ;
    ns1:identificador "MPGAXIS" ;
    ns1:textoExtracto "MPGAXIS |  | Volante asociado al resto de los ejes."@es .

ns1:Parametro_Z_MPGRESOL_1 a ns1:Parametro ;
    rdfs:label "Z-MPGRESOL (resolución 0.001)" ;
    ns1:documentadoEn ns1:TablaParametrosVolantesJog ;
    ns1:identificador "Z-MPGRESOL_1" ;
    ns1:textoExtracto "Z - MPGRESOL 1 | 0.001 | Eje Z. Resolución 0.001"@es ;
    ns1:valor "0.001" .

ns1:Parametro_Z_MPGRESOL_10 a ns1:Parametro ;
    rdfs:label "Z-MPGRESOL (resolución 0.01)" ;
    ns1:documentadoEn ns1:TablaParametrosVolantesJog ;
    ns1:identificador "Z-MPGRESOL_10" ;
    ns1:textoExtracto "Z - MPGRESOL 10 | 0.01 | Eje Z. Resolución 0.01"@es ;
    ns1:valor "0.01" .

ns1:Parametro_Z_MPGRESOL_100 a ns1:Parametro ;
    rdfs:label "Z-MPGRESOL (resolución 0.1)" ;
    ns1:documentadoEn ns1:TablaParametrosVolantesJog ;
    ns1:identificador "Z-MPGRESOL_100" ;
    ns1:textoExtracto "Z - MPGRESOL 100 | 0.1 | Eje Z. Resolución 0.1"@es ;
    ns1:valor "0.1" .

ns1:TablaParametrosVolantesJog a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de máquina para personalización de volantes y teclas de jog"@es ;
    ns1:textoExtracto """
| Parámetro máquina. | Valor. | Significado. |
| --- | --- | --- |
| COUNTERTYPE | Remoto. | Volante conectado a los módulos remotos. |
| COUNTERID | 1 | Entrada de contaje X1. |
| MPGAXIS |  | Volante asociado al resto de los ejes. |
| Z - MPGRESOL 1 | 0.001 | Eje Z. Resolución 0.001 |
| Z - MPGRESOL 10 | 0.01 | Eje Z. Resolución 0.01 |
| Z - MPGRESOL 100 | 0.1 | Eje Z. Resolución 0.1 |
| A - MPGRESOL 1 | 0.01 | Eje A. Resolución 0.01 |
| A - MPGRESOL 10 | 0.1 | Eje A. Resolución 0.1 |
| A - MPGRESOL 100 | 1 | Eje A. Resolución 1 """@es .

