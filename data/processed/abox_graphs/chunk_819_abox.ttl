@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Pagina_248_249 a ns1:Pagina ;
    rdfs:label "Páginas 248-249"@es ;
    ns1:textoExtracto "2.8 Parámetros máquina de la tabla de funciones M. - 2.8.1 Tabla de funciones M."@es .

ns1:Parametro_MTABLESIZE a ns1:Parametro ;
    rdfs:label "MTABLESIZE" ;
    ns1:documentadoEn ns1:TablaFuncionesM_558 ;
    ns1:identificador "MTABLESIZE" ;
    ns1:textoExtracto "MTABLESIZE Número de elementos de la tabla. Valores posibles: de 0 a 200. Valor por defecto: 50. Variable asociada: (V.)MPM.MTABLESIZE Este parámetro indica el número de funciones M a definir en la tabla."@es ;
    ns1:valor "50" .

ns1:TablaFuncionesM_558 a ns1:Tabla ;
    rdfs:label "Tabla de funciones M"@es ;
    ns1:documentadoEn ns1:Pagina_248_249 ;
    ns1:textoExtracto "DATA Tabla de funciones M. Muestra la tabla de personalización de funciones M. Para cada función M hay que definir los siguientes campos."@es ;
    ns1:tieneComponente ns1:Parametro_MTABLESIZE .

