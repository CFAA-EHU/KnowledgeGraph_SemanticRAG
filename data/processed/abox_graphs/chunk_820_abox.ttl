@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_COMMENT a ns1:Parametro ;
    rdfs:label "Descripción (COMMENT)" ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:textoExtracto "COMMENT Descripción de la función M." .

ns1:Parametro_MNUM a ns1:Parametro ;
    rdfs:label "Número de la función M (MNUM)" ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:textoExtracto "MNUM Número de la función M. Valores posibles: de 0 a 65535. Variable asociada: (V.)MPM.MNUM[pos] Parámetro incluido en la tabla DATA. Este parámetro indica el número de la función M." ;
    ns1:valor "0-65535" .

ns1:Parametro_MPLC a ns1:Parametro ;
    rdfs:label "Enviar al PLC (MPLC)" ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:textoExtracto "MPLC Enviar la función M al PLC en la búsqueda de bloque." .

ns1:Parametro_MPROGNAME a ns1:Parametro ;
    rdfs:label "Nombre de subrutina (MPROGNAME)" ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:textoExtracto "MPROGNAME Nombre de subrutina asociada a la función M." .

ns1:Parametro_MTIME a ns1:Parametro ;
    rdfs:label "Tiempo estimado (MTIME)" ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:textoExtracto "MTIME Tiempo estimado para la función M." .

ns1:Parametro_SYNCHTYPE a ns1:Parametro ;
    rdfs:label "Tipo de sincronización (SYNCHTYPE)" ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:textoExtracto "SYNCHTYPE Tipo de sincronización. Valores posibles: Sin sincronización / Antes-Antes / Antes-Después / Después-Después. Valor por defecto: Antes-Antes. Variable asociada: (V.)MPM.SYNCHTYPE[pos] Parámetro incluido en la tabla DATA." ;
    ns1:valor "Sin sincronización, Antes-Antes, Antes-Después, Después-Después" .

ns1:TablaFuncionesM a ns1:Tabla ;
    rdfs:label "Tabla de funciones M" ;
    ns1:textoExtracto "2.8.1 Tabla de funciones M. | DATA | | --- | --- | MNUM | Número de la función M. | SYNCHTYPE | Tipo de sincronización. | MPROGNAME | Nombre de subrutina asociada a la función M. | MTIME | Tiempo estimado para la función M. | MPLC | Enviar la función M al PLC en la búsqueda de bloque. | COMMENT | Descripción de la función M." ;
    ns1:tieneComponente ns1:Parametro_COMMENT,
        ns1:Parametro_MNUM,
        ns1:Parametro_MPLC,
        ns1:Parametro_MPROGNAME,
        ns1:Parametro_MTIME,
        ns1:Parametro_SYNCHTYPE .

