@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_SincronizacionM a ns1:Sistema ;
    rdfs:label "Sistema de sincronización de funciones M"@es ;
    ns1:monitoreaParametro ns1:Parametro_SYNCHTYPE ;
    ns1:textoExtracto "Como las funciones M pueden programarse junto al desplazamiento de los ejes en un mismo bloque, hay que indicar cuándo se envía la función al PLC y cuándo se comprueba que ya ha sido ejecutada (sincronización)."@es .

ns1:Tabla_DATA a ns1:Tabla ;
    rdfs:label "Tabla DATA"@es ;
    ns1:textoExtracto "Parámetro incluido en la tabla DATA"@es ;
    ns1:tieneComponente ns1:Parametro_SYNCHTYPE .

ns1:Parametro_SYNCHTYPE a ns1:Parametro ;
    rdfs:label "Parámetro SYNCHTYPE"@es ;
    ns1:identificador "MPM.SYNCHTYPE[pos]" ;
    ns1:textoExtracto "Valor por defecto: Antes-Antes. Variable asociada: (V.)MPM.SYNCHTYPE[pos] Parámetro incluido en la tabla DATA."@es ;
    ns1:valor "Antes-Antes" .

