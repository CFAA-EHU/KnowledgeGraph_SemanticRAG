@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_AntesAntes a ns1:Parametro ;
    rdfs:label "Antes - Antes (sincronización función M)" ;
    ns1:ilustradoEn ns1:TablaFuncionesM_561 ;
    ns1:textoExtracto "Antes - Antes. La función M se envía al PLC y se sincroniza antes del movimiento." ;
    ns1:valor "Antes - Antes" .

ns1:Parametro_AntesDespues a ns1:Parametro ;
    rdfs:label "Antes - Después (sincronización función M)" ;
    ns1:ilustradoEn ns1:TablaFuncionesM_561 ;
    ns1:textoExtracto "Antes - Después. La función M se envía al PLC antes del movimiento y se sincroniza después." ;
    ns1:valor "Antes - Después" .

ns1:Parametro_DespuesDespues a ns1:Parametro ;
    rdfs:label "Después - Después (sincronización función M)" ;
    ns1:ilustradoEn ns1:TablaFuncionesM_561 ;
    ns1:textoExtracto "Después - Después. La función M se envía al PLC y se sincroniza después del movimiento." ;
    ns1:valor "Después - Después" .

ns1:Parametro_SinSincronizacion a ns1:Parametro ;
    rdfs:label "Sin sincronización (función M)" ;
    ns1:ilustradoEn ns1:TablaFuncionesM_561 ;
    ns1:textoExtracto "Sin sincronización. Función M sin sincronización." ;
    ns1:valor "Sin sincronización" .

ns1:TablaFuncionesM_561 a ns1:Tabla ;
    rdfs:label "Tabla de funciones M (sincronización)" ;
    ns1:documentadoEn ns1:Pagina_248,
        ns1:Pagina_249 ;
    ns1:textoExtracto "2.8.1 Tabla de funciones M. | Tipo de sincronización. | Significado. | Sin sincronización. | Función M sin sincronización. | Antes - Antes. | La función M se envía al PLC y se sincroniza antes del movimiento. | Antes - Después. | La función M se envía al PLC antes del movimiento y se sincroniza después. | Después - Después. | La función M se envía al PLC y se sincroniza después del movimiento." .

