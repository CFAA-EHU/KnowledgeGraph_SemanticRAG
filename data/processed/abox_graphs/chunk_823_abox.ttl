@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:CarpetaSubrutinasMTB a ns1:InterfazUsuario ;
    rdfs:label "Carpeta ..\\MTB\\Sub" ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:identificador "..\\MTB\\Sub" ;
    ns1:textoExtracto "Las subrutinas asociadas a las funciones M deben estar en la carpeta ..\\MTB\\Sub." .

ns1:FuncionM_M03 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función M03" ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:identificador "M03" ;
    ns1:textoExtracto "Las funciones M03 y M04 para el arranque del cabezal, es conveniente ejecutarla y sincronizarla antes del movimiento." .

ns1:FuncionM_M04 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función M04" ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:identificador "M04" ;
    ns1:textoExtracto "Las funciones M03 y M04 para el arranque del cabezal, es conveniente ejecutarla y sincronizarla antes del movimiento." .

ns1:FuncionM_M05 a ns1:ModoOperacion,
        ns1:Tabla ;
    rdfs:label "Función M05" ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:identificador "M05" ;
    ns1:textoExtracto "La función M05 para parar el cabezal, es conveniente ejecutarla y sincronizarla tras el movimiento." .

ns1:Parametro_MPROGNAME a ns1:Parametro ;
    rdfs:label "MPROGNAME" ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:identificador "MPROGNAME" ;
    ns1:textoExtracto "MPROGNAME Nombre de subrutina asociada a la función M. Valores posibles: Cualquier texto de hasta 64 caracteres. Valor por defecto: Sin subrutina." ;
    ns1:valor "Sin subrutina"^^xsd:string .

ns1:Variable_V_MPM_MPROGNAME a ns1:Parametro ;
    rdfs:label "(V.)MPM.MPROGNAME[pos]" ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:identificador "V_MPM_MPROGNAME" ;
    ns1:textoExtracto "Variable asociada: (V.)MPM.MPROGNAME[pos]" .

ns1:TablaFuncionesM a ns1:Tabla ;
    rdfs:label "Tabla de funciones M" ;
    ns1:documentadoEn ns1:Pagina_248_249 ;
    ns1:textoExtracto "2.8.1 Tabla de funciones M. [...] Las funciones M se pueden enviar y/o sincronizar antes o después del movimiento." .

