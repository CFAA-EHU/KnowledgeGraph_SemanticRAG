ns1:Pagina_248_249 a ns1:Pagina ;
    ns1:identificador "248-249" ;
    ns1:textoExtracto "2.8 Parámetros máquina de la tabla de funciones M. - 2.8.1 Tabla de funciones M."@es .

ns1:Parametro_MTIME_563 a ns1:Parametro ;
    rdfs:label "MTIME"@es ;
    ns1:monitoreaParametro ns1:TablaFuncionesM_563 ;
    ns1:textoExtracto "MTIME Tiempo estimado para la función M. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0 ms."@es ;
