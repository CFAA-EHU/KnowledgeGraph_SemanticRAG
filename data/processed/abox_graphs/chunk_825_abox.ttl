@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_EDISIMU a ns1:ModoOperacion ;
    rdfs:label "Modo EDISIMU" ;
    ns1:requiereMantenimiento ns1:Parametro_MTIME ;
    ns1:textoExtracto "En el modo de trabajo EDISIMU hay una opción que permite calcular el tiempo que se necesitará para ejecutar la pieza con las condiciones de mecanizado establecidas en el programa." .

ns1:Parametro_MPLC a ns1:Parametro ;
    rdfs:label "Envío de función M al PLC" ;
    ns1:identificador "MPLC" ;
    ns1:textoExtracto "MPLC Enviar la función M al PLC en la búsqueda de bloque. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)MPM.MPLC[pos] Parámetro incluido en la tabla" ;
    ns1:valor "Sí" .

ns1:Tabla_DATA a ns1:Tabla ;
    rdfs:label "Tabla de parámetros DATA" ;
    ns1:documentadoEn ns1:Manual_Maquina ;
    ns1:textoExtracto "Parámetro incluido en la tabla DATA" .

ns1:Parametro_MTIME a ns1:Parametro ;
    rdfs:label "Tiempo de ejecución estimado" ;
    ns1:identificador "MTIME" ;
    ns1:textoExtracto "Valor por defecto: 0 ms. Variable asociada: (V.)MPM.MTIME[pos] Parámetro incluido en la tabla DATA. En el modo de trabajo EDISIMU hay una opción que permite calcular el tiempo que se necesitará para ejecutar la pieza con las condiciones de mecanizado establecidas en el programa." ;
    ns1:valor "0 ms" .

