@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Archivo_MComments_txt a ns1:InterfazUsuario ;
    rdfs:label "MComments.txt" ;
    ns1:documentadoEn ns1:Tabla_FuncionesM ;
    ns1:textoExtracto "Los comentarios se guardan en el archivo MComments.txt y se puede tener un archivo por cada idioma. Estos archivos se guardan en la carpeta ..\\MTB\\Data\\Lang." .

ns1:Parametro_COMMENT a ns1:Parametro ;
    rdfs:label "COMMENT" ;
    ns1:documentadoEn ns1:Tabla_FuncionesM ;
    ns1:textoExtracto "COMMENT Descripción de la función M. Este campo ofrece la posibilidad de asociar una pequeña descripción a la función M. Este campo es informativo; no es utilizado por el CNC." .

ns1:Parametro_MPLC a ns1:Parametro ;
    rdfs:label "MPLC" ;
    ns1:documentadoEn ns1:Tabla_FuncionesM ;
    ns1:textoExtracto "MPLC Enviar la función M al PLC en la búsqueda de bloque. Valores posibles: Sí / No. Valor por defecto: Sí." ;
    ns1:valor "Sí" .

ns1:Variable_V_MPM_COMMENT a ns1:Parametro ;
    rdfs:label "(V.)MPM.COMMENT[pos]" ;
    ns1:documentadoEn ns1:Tabla_FuncionesM ;
    ns1:textoExtracto "Variable asociada: (V.)MPM.COMMENT[pos] Parámetro incluido en la tabla DATA." .

ns1:Variable_V_MPM_MPLC a ns1:Parametro ;
    rdfs:label "(V.)MPM.MPLC[pos]" ;
    ns1:documentadoEn ns1:Tabla_FuncionesM ;
    ns1:textoExtracto "Variable asociada: (V.)MPM.MPLC[pos] Parámetro incluido en la tabla DATA." .

ns1:Tabla_FuncionesM a ns1:Tabla ;
    rdfs:label "Tabla de funciones M" ;
    ns1:documentadoEn ns1:Manual ;
    ns1:textoExtracto "2.8.1 Tabla de funciones M" .

