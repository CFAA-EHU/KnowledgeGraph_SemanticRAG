@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CinematicasCNC a ns1:Sistema ;
    rdfs:label "Sistema de cinemáticas del CNC" ;
    ns1:documentadoEn ns1:Tabla_OrdenEjesCinematica ;
    ns1:ilustradoEn ns1:Sentencia_KIN_ID ;
    ns1:textoExtracto "Se pueden personalizar hasta 6 cinemáticas distintas para una misma máquina. El CNC ofrece una serie de cinemáticas predefinidas y que se pueden configurar fácilmente desde los parámetros máquina. Además de estas cinemáticas, el OEM puede integrar 6 cinemáticas adicionales." ;
    ns1:tieneComponente ns1:Parametro_KINID .

ns1:Parametro_KINID a ns1:Parametro ;
    rdfs:label "Parámetro máquina KINID" ;
    ns1:identificador "KINID" ;
    ns1:textoExtracto "El parámetro máquina de canal KINID indica el número de cinemática (no tipo) que asume el CNC en ese canal tras el encendido." .

ns1:Sentencia_KIN_ID a ns1:InterfazUsuario ;
    rdfs:label "Sentencia #KIN ID" ;
    ns1:identificador "#KIN ID" ;
    ns1:textoExtracto "Para seleccionar una cinemática desde el programa pieza, utilizar la sentencia #KIN ID." .

ns1:Tabla_OrdenEjesCinematica a ns1:Tabla ;
    rdfs:label "Orden de ejes en cinemática" ;
    ns1:textoExtracto "Orden del eje: Eje 1º (abscisas), Eje 2º (ordenadas), Eje 3º (longitudinal), Eje 4º, Eje 5º, Eje 6º, Eje 7º, Eje 8º. Los 3 primeros ejes deben ser lineales sobre los que se aplica la compensación de cabezal." .

