@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Eje8 a ns1:ComponenteMecanico ;
    rdfs:label "Eje 8º" ;
    ns1:textoExtracto "Eje 8º | Octavo eje de la cinemática." .

ns1:Ejes9ySiguientes a ns1:ComponenteMecanico ;
    rdfs:label "Ejes 9º y siguientes" ;
    ns1:textoExtracto "Eje 9º y siguientes. | Resto de los ejes." .

ns1:Parametro_CompensacionCabezal a ns1:Parametro ;
    rdfs:label "Compensación de cabezal" ;
    ns1:monitoreaParametro ns1:EjesLinealesCompensacion ;
    ns1:textoExtracto "Los 3 primeros ejes deben ser lineales sobre los que se aplica la compensación de cabezal." .

ns1:EjesLinealesCompensacion a ns1:ComponenteMecanico ;
    rdfs:label "Ejes lineales (1º-3º)" ;
    ns1:textoExtracto "Los 3 primeros ejes deben ser lineales sobre los que se aplica la compensación de cabezal." .

