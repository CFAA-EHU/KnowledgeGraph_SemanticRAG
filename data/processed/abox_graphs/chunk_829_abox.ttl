@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_HEADREF a ns1:Parametro ;
    rdfs:label "Posición de referencia HEAD/TOOL (HEADREF)" ;
    ns1:documentadoEn ns1:Tabla_Cinematicas ;
    ns1:identificador "HEADREF" ;
    ns1:textoExtracto "HEADREF | Posición de referencia máquina HEAD/TOOL." .

ns1:Parametro_TDATA_n a ns1:Parametro ;
    rdfs:label "Parámetro numérico TDATA n" ;
    ns1:documentadoEn ns1:Tabla_Cinematicas ;
    ns1:identificador "TDATA n" ;
    ns1:textoExtracto "TDATA n | Parámetro numérico en formato decimal." .

ns1:Parametro_TYPE a ns1:Parametro ;
    rdfs:label "Tipo de cinemática (TYPE)" ;
    ns1:documentadoEn ns1:Tabla_Cinematicas ;
    ns1:identificador "TYPE" ;
    ns1:textoExtracto "TYPE | Tipo de cinemática." .

ns1:Sistema_Cinematicas a ns1:Sistema ;
    rdfs:label "Sistema de cinemáticas configurables" ;
    ns1:compuestoPor ns1:Parametro_KINID,
        ns1:Parametro_NKIN,
        ns1:Sentencia_KIN_ID ;
    ns1:detalladoEnEsquema ns1:Tabla_Cinematicas ;
    ns1:textoExtracto "Se pueden personalizar hasta 6 cinemáticas distintas para una misma máquina, debiendo indicarse en cada una de ellas el tipo de cinemática a aplicar." .

ns1:Parametro_KINID a ns1:Parametro ;
    rdfs:label "Número de cinemática de canal (KINID)" ;
    ns1:identificador "KINID" ;
    ns1:textoExtracto "El parámetro máquina de canal KINID indica el número de cinemática (no tipo) que asume el CNC en ese canal tras el encendido." .

ns1:Parametro_NKIN a ns1:Parametro ;
    rdfs:label "Número de cinemáticas definidas (NKIN)" ;
    ns1:identificador "NKIN" ;
    ns1:monitoreaParametro ns1:Variable_MPK_NKIN ;
    ns1:textoExtracto "NKIN Número de cinemáticas definidas. Valores posibles: De 0 a 6. Valor por defecto: 0." ;
    ns1:valor "0..6" .

ns1:Sentencia_KIN_ID a ns1:Parametro ;
    rdfs:label "Sentencia #KIN ID" ;
    ns1:identificador "#KIN ID" ;
    ns1:textoExtracto "Para seleccionar una cinemática desde el programa pieza, utilizar la sentencia #KIN ID. KINEMATIC n" .

ns1:Variable_MPK_NKIN a ns1:Parametro ;
    rdfs:label "Variable MPK.NKIN" ;
    ns1:identificador "MPK.NKIN" ;
    ns1:textoExtracto "Variable asociada: (V.)MPK.NKIN" .

ns1:Tabla_Cinematicas a ns1:Tabla ;
    rdfs:label "Tabla de cinemáticas" ;
    ns1:documentadoEn ns1:Manual_Configuracion ;
    ns1:textoExtracto "Tabla de cinemáticas. Muestra la tabla para definir las cinemáticas del sistema." .

