@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_ParametrosCinematicasOEM a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de configuración de cinemáticas OEM" ;
    ns1:textoExtracto "Las cinemáticas OEM disponen de los siguientes parámetros máquina para su configuración." ;
    ns1:tieneComponente ns1:Parametro_AUXCTE_SIZE,
        ns1:Parametro_HEADREF,
        ns1:Parametro_KINDATA_SIZE,
        ns1:Parametro_NKINAX,
        ns1:Parametro_PARAM_D_SIZE,
        ns1:Parametro_PARAM_I_SIZE,
        ns1:Parametro_TDATA,
        ns1:Parametro_TDATA_I,
        ns1:Parametro_TYPE .

ns1:Parametro_AUXCTE_SIZE a ns1:Parametro ;
    rdfs:label "AUXCTE_SIZE" ;
    ns1:identificador "AUXCTE_SIZE" ;
    ns1:textoExtracto "Tamaño del área de variables auxiliares." .

ns1:Parametro_HEADREF a ns1:Parametro ;
    rdfs:label "HEADREF" ;
    ns1:identificador "HEADREF" ;
    ns1:textoExtracto "Posición de referencia máquina HEAD/TOOL." .

ns1:Parametro_KINDATA_SIZE a ns1:Parametro ;
    rdfs:label "KINDATA_SIZE" ;
    ns1:identificador "KINDATA_SIZE" ;
    ns1:textoExtracto "Tamaño del área de datos de propósito general." .

ns1:Parametro_NKINAX a ns1:Parametro ;
    rdfs:label "NKINAX" ;
    ns1:identificador "NKINAX" ;
    ns1:textoExtracto "Número de ejes de la cinemática." .

ns1:Parametro_PARAM_D_SIZE a ns1:Parametro ;
    rdfs:label "PARAM_D_SIZE" ;
    ns1:identificador "PARAM_D_SIZE" ;
    ns1:textoExtracto "Número de parámetros numéricos en formato decimal." .

ns1:Parametro_PARAM_I_SIZE a ns1:Parametro ;
    rdfs:label "PARAM_I_SIZE" ;
    ns1:identificador "PARAM_I_SIZE" ;
    ns1:textoExtracto "Número de parámetros en formato entero de la cinemática." .

ns1:Parametro_TDATA a ns1:Parametro ;
    rdfs:label "TDATA" ;
    ns1:identificador "TDATA" ;
    ns1:textoExtracto "Parámetro numérico en formato decimal." .

ns1:Parametro_TDATA_I a ns1:Parametro ;
    rdfs:label "TDATA_I" ;
    ns1:identificador "TDATA_I" ;
    ns1:textoExtracto "Parámetro numérico en formato entero." .

ns1:Parametro_TYPE a ns1:Parametro ;
    rdfs:label "TYPE" ;
    ns1:identificador "TYPE" ;
    ns1:textoExtracto "Tipo de cinemática." .

