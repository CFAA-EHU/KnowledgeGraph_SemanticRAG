@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinicionVectorial_Cabezal a ns1:Parametro ;
    rdfs:label "TYPE = 50" ;
    ns1:identificador "50" ;
    ns1:textoExtracto "Definición vectorial de cinemáticas de cabezal." .

ns1:DefinicionVectorial_CabezalMesa a ns1:Parametro ;
    rdfs:label "TYPE = 52" ;
    ns1:identificador "52" ;
    ns1:textoExtracto "Definición vectorial de cinemáticas de cabezal–mesa." .

ns1:DefinicionVectorial_Mesa a ns1:Parametro ;
    rdfs:label "TYPE = 51" ;
    ns1:identificador "51" ;
    ns1:textoExtracto "Definición vectorial de cinemáticas de mesa." .

ns1:TablaConfiguracionCinematica a ns1:Tabla ;
    rdfs:label "Tabla de configuración de cinemáticas (páginas 251-255)" ;
    ns1:ilustradoEn ns1:ConfiguracionCinematicaEjeC_Cilindrica,
        ns1:ConfiguracionCinematicaEjeC_Frontal_ALIGNC_NO,
        ns1:ConfiguracionCinematicaEjeC_Frontal_ALIGNC_YES ;
    ns1:textoExtracto "TYPE=41/42 | Y-C | TYPE=43 | Z-C" .

ns1:ConfiguracionCinematicaEjeC_Cilindrica a ns1:ModoOperacion ;
    rdfs:label "TYPE = 43" ;
    ns1:identificador "43" ;
    ns1:textoExtracto "Eje C. Mecanizado en la superficie cilíndrica." .

ns1:ConfiguracionCinematicaEjeC_Frontal_ALIGNC_NO a ns1:ModoOperacion ;
    rdfs:label "TYPE = 42" ;
    ns1:identificador "42" ;
    ns1:textoExtracto "Eje C. Mecanizado en la superficie frontal cuando ALIGNC = NO." .

ns1:ConfiguracionCinematicaEjeC_Frontal_ALIGNC_YES a ns1:ModoOperacion ;
    rdfs:label "TYPE = 41" ;
    ns1:identificador "41" ;
    ns1:textoExtracto "Eje C. Mecanizado en la superficie frontal cuando ALIGNC = YES." .

