@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_Cinematica a ns1:Sistema ;
    rdfs:label "Sistema de cinemática de máquina" ;
    ns1:documentadoEn ns1:Tabla_ParametrosCinematicos ;
    ns1:textoExtracto "Configuración de las cinemáticas. HEADREF Posición de referencia máquina HEAD/TOOL." ;
    ns1:tieneComponente ns1:Parametro_HEADREF,
        ns1:Parametro_TDATA1,
        ns1:Parametro_TDATA13,
        ns1:Parametro_TDATA14,
        ns1:Parametro_TDATA15,
        ns1:Parametro_TDATA2,
        ns1:Parametro_TDATA3 .

ns1:Tabla_ParametrosCinematicos a ns1:Tabla ;
    rdfs:label "Tabla de parámetros cinemáticos" ;
    ns1:detalladoEnEsquema ns1:Parametro_HEADREF,
        ns1:Parametro_TDATA1,
        ns1:Parametro_TDATA13,
        ns1:Parametro_TDATA14,
        ns1:Parametro_TDATA15,
        ns1:Parametro_TDATA2,
        ns1:Parametro_TDATA3 ;
    ns1:textoExtracto "TDATA n Parámetro numérico en formato decimal. Valores posibles: Entre ±999999999.0000" .

ns1:Parametro_HEADREF a ns1:Parametro ;
    rdfs:label "HEADREF" ;
    ns1:identificador "MPK.HEADREF" ;
    ns1:textoExtracto "HEADREF Posición de referencia máquina HEAD/TOOL. Valores posibles: Tool base / Head base / Auto tool base. Valor por defecto: Tool base. Variable asociada: (V.)MPK.HEADREF" ;
    ns1:valor "Tool base" .

ns1:Parametro_TDATA1 a ns1:Parametro ;
    rdfs:label "TDATA1" ;
    ns1:textoExtracto "TDATA1 a TDATA3 (cinemáticas vectoriales)" ;
    ns1:valor "0" .

ns1:Parametro_TDATA13 a ns1:Parametro ;
    rdfs:label "TDATA13" ;
    ns1:textoExtracto "TDATA13 a TDATA15 (cinemáticas no vectoriales)" ;
    ns1:valor "0" .

ns1:Parametro_TDATA14 a ns1:Parametro ;
    rdfs:label "TDATA14" ;
    ns1:textoExtracto "TDATA13 a TDATA15 (cinemáticas no vectoriales)" ;
    ns1:valor "0" .

ns1:Parametro_TDATA15 a ns1:Parametro ;
    rdfs:label "TDATA15" ;
    ns1:textoExtracto "TDATA13 a TDATA15 (cinemáticas no vectoriales)" ;
    ns1:valor "0" .

ns1:Parametro_TDATA2 a ns1:Parametro ;
    rdfs:label "TDATA2" ;
    ns1:textoExtracto "TDATA1 a TDATA3 (cinemáticas vectoriales)" ;
    ns1:valor "0" .

ns1:Parametro_TDATA3 a ns1:Parametro ;
    rdfs:label "TDATA3" ;
    ns1:textoExtracto "TDATA1 a TDATA3 (cinemáticas vectoriales)" ;
    ns1:valor "0" .

