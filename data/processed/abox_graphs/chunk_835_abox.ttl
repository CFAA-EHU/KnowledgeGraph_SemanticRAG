@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_TDATA a ns1:Parametro ;
    rdfs:label "TDATA"@es ;
    ns1:documentadoEn ns1:TablaParametrosCinematicos ;
    ns1:monitoreaParametro ns1:Variable_MPK_MAXOFTDATAkin,
        ns1:Variable_MPK_TDATAkin ;
    ns1:textoExtracto "TDATA n Parámetro numérico en formato decimal. Valores posibles: Entre ±999999999.0000 Valor por defecto: 0."@es ;
    ns1:valor "0" .

ns1:TablaParametrosCinematicos a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de cinemáticas"@es ;
    ns1:textoExtracto "No se modifica el valor de estos parámetros en la tabla de parámetros."@es ;
    ns1:tieneComponente ns1:Parametro_TDATA .

ns1:Variable_MPK_MAXOFTDATAkin a ns1:Parametro ;
    rdfs:label "(V.)MPK.MAXOFTDATAkin[nb]"@es ;
    ns1:textoExtracto "Variable asociada: (V.)MPK.MAXOFTDATAkin[nb]"@es .

ns1:Variable_MPK_TDATAkin a ns1:Parametro ;
    rdfs:label "(V.)MPK.TDATAkin[nb]"@es ;
    ns1:textoExtracto "Variable asociada: (V.)MPK.TDATAkin[nb]"@es .

