@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Sistema_Cinematica a ns1:Sistema ;
    rdfs:label "Sistema de cinemática (#KIN ID)" ;
    ns1:monitoreaParametro ns1:Parametro_MAXOFFSET_TDATA_I,
        ns1:Parametro_TDATA_I ;
    ns1:textoExtracto "El nuevo valor se hará efectivo al activar la cinemática (#KIN ID) o el RTCP." .

ns1:Variable_MPK_MAXOFTDATA_Ikin a ns1:Parametro ;
    rdfs:label "Variable asociada MPK.MAXOFTDATA_Ikin[nb]" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionCinematica_575 ;
    ns1:textoExtracto "Variable asociada: (V.)MPK.MAXOFTDATA_Ikin[nb]" .

ns1:Variable_MPK_TDATA_Ikin a ns1:Parametro ;
    rdfs:label "Variable asociada MPK.TDATA_Ikin[nb]" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionCinematica_575 ;
    ns1:textoExtracto "Variable asociada: (V.)MPK.TDATA_Ikin[nb]" .

ns1:Parametro_MAXOFFSET_TDATA_I a ns1:Parametro ;
    rdfs:label "Máximo offset para TDATA_I (MAXOFTDATA_Ikin)" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionCinematica_575 ;
    ns1:textoExtracto "Variable asociada: (V.)MPK.MAXOFTDATA_Ikin[nb]. Parámetro numérico en formato entero." .

ns1:Parametro_TDATA_I a ns1:Parametro ;
    rdfs:label "Parámetro TDATA_I" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionCinematica_575 ;
    ns1:textoExtracto "TDATA_I n Parámetro numérico en formato entero. Valores posibles: Entre ±2147483647. Valor por defecto: 0." ;
    ns1:valor 0 .

ns1:Tabla_ConfiguracionCinematica_575 a ns1:Tabla ;
    rdfs:label "Tabla de configuración de parámetros cinemáticos (pág. 251-255)" ;
    ns1:textoExtracto """
| DATA |  |
| --- | --- |
| VALUE | A definir por el OEM. Valor del parámetro. |
| MAX OFFSET | A definir por el OEM. Máximo offset que puede definir el usuario. |
| OFFSET | A definir por el usuario. Offset del parámetro.""" .

