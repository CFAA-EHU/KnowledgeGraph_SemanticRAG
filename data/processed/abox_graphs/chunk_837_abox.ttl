@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_ParametrosCinematicos_576 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros cinemáticos (DATA)"@es ;
    ns1:textoExtracto """
| DATA |  |
| --- | --- |
| VALUE | A definir por el OEM. Valor del parámetro. |
| MAX OFFSET | A definir por el OEM. Máximo offset que puede definir el usuario. |
| OFFSET | A definir por el usuario. Offset del parámetro."""@es ;
    ns1:tieneComponente ns1:Parametro_MAX_OFFSET_576,
        ns1:Parametro_OFFSET_576,
        ns1:Parametro_VALUE_576 .

ns1:Parametro_MAX_OFFSET_576 a ns1:Parametro ;
    rdfs:label "MAX OFFSET (límite de ajuste)"@es ;
    ns1:textoExtracto "A definir por el OEM. Máximo offset que puede definir el usuario. Esta columna siempre será un valor positivo, y el offset definido por el usuario será un valor comprendido entre \"- MAX OFFSET\" y \"+ MAX OFFSET\"."@es ;
    ns1:valor "OEM-defined (positivo)" .

ns1:Parametro_OFFSET_576 a ns1:Parametro ;
    rdfs:label "OFFSET (ajuste de usuario)"@es ;
    ns1:textoExtracto "A definir por el usuario. Offset del parámetro. Los valores de offset definidos por el usuario se sumarán a su parámetro TDATA correspondiente."@es ;
    ns1:valor "user-defined (rango: ±MAX_OFFSET)" .

ns1:Parametro_VALUE_576 a ns1:Parametro ;
    rdfs:label "VALUE (parámetro base)"@es ;
    ns1:textoExtracto "A definir por el OEM. Valor del parámetro."@es ;
    ns1:valor "OEM-defined" .

