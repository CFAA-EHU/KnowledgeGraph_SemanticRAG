@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:cabezal_angular a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal angular" ;
    ns1:textoExtracto "Cabezal angular. [...] el eje rotativo principal (4) debe girar sobre uno de los ejes principales (X, Y, Z) y el eje secundario o arrastrado (5) formará un determinado ángulo." ;
    ns1:tieneComponente ns1:eje_rotativo_principal,
        ns1:eje_rotativo_secundario .

ns1:cabezal_esferico a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal esférico" ;
    ns1:textoExtracto "Cabezal esférico." ;
    ns1:tieneComponente ns1:eje_A,
        ns1:eje_B,
        ns1:eje_C .

ns1:cabezal_ortogonal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal ortogonal" ;
    ns1:textoExtracto "Cabezal ortogonal." ;
    ns1:tieneComponente ns1:eje_A,
        ns1:eje_B,
        ns1:eje_C .

ns1:parametro_TDATA1 a ns1:Parametro ;
    rdfs:label "TDATA1" ;
    ns1:identificador "TDATA1" ;
    ns1:monitoreaParametro ns1:eje_rotativo_secundario ;
    ns1:textoExtracto "Indica la distancia entre la nariz del mandrino y el eje rotativo secundario, según el eje Z." .

ns1:parametro_TDATA2 a ns1:Parametro ;
    rdfs:label "TDATA2" ;
    ns1:identificador "TDATA2" ;
    ns1:monitoreaParametro ns1:eje_rotativo_principal,
        ns1:eje_rotativo_secundario ;
    ns1:textoExtracto "Indica la distancia entre el eje rotativo secundario y el principal según el eje X." .

ns1:parametro_TDATA3 a ns1:Parametro ;
    rdfs:label "TDATA3" ;
    ns1:identificador "TDATA3" ;
    ns1:monitoreaParametro ns1:eje_rotativo_principal,
        ns1:eje_rotativo_secundario ;
    ns1:textoExtracto "Indica la distancia entre el eje rotativo secundario y el principal según el eje Y." .

ns1:parametro_TDATA4 a ns1:Parametro ;
    rdfs:label "TDATA4" ;
    ns1:identificador "TDATA4" ;
    ns1:monitoreaParametro ns1:eje_rotativo_principal,
        ns1:eje_rotativo_secundario ;
    ns1:textoExtracto "Indica la distancia entre el eje rotativo secundario y el principal según el eje Z." .

ns1:parametro_TDATA5 a ns1:Parametro ;
    rdfs:label "TDATA5" ;
    ns1:identificador "TDATA5" ;
    ns1:monitoreaParametro ns1:herramienta ;
    ns1:textoExtracto "Indica la distancia entre el eje de la herramienta y el eje rotativo secundario según el eje X." .

ns1:parametro_TDATA6 a ns1:Parametro ;
    rdfs:label "TDATA6" ;
    ns1:identificador "TDATA6" ;
    ns1:monitoreaParametro ns1:herramienta ;
    ns1:textoExtracto "Indica la distancia entre el eje de la herramienta y el eje rotativo secundario según el eje Y." .

ns1:parametro_TDATA7 a ns1:Parametro ;
    rdfs:label "TDATA7" ;
    ns1:identificador "TDATA7" ;
    ns1:monitoreaParametro ns1:eje_rotativo_principal,
        ns1:eje_rotativo_secundario ;
    ns1:textoExtracto "Indica el ángulo entre los ejes rotativos principal y secundario, en los cabezales rotativos." .

ns1:eje_A a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo A" ;
    ns1:textoExtracto "eje rotativo asociado al eje principal X (A)." .

ns1:eje_B a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo B" ;
    ns1:textoExtracto "eje rotativo asociado al eje principal Y (B)." .

ns1:eje_C a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo C" ;
    ns1:textoExtracto "eje rotativo asociado al eje principal Z (C)." .

ns1:herramienta a ns1:Herramienta ;
    rdfs:label "Herramienta" ;
    ns1:textoExtracto "eje de la herramienta." .

ns1:eje_rotativo_principal a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo principal (4)" ;
    ns1:identificador "4" ;
    ns1:textoExtracto "el eje rotativo principal (4) debe girar sobre uno de los ejes principales (X, Y, Z)." .

ns1:eje_rotativo_secundario a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo secundario (5)" ;
    ns1:identificador "5" ;
    ns1:textoExtracto "el eje secundario o arrastrado (5) formará un determinado ángulo." .

