@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TipoCinematica_1 a ns1:ModoOperacion ;
    rdfs:label "Tipo 1 de cinemática del cabezal"@es ;
    ns1:documentadoEn ns1:Tabla_CinematicasCabezal_Tipos1_8 ;
    ns1:identificador "TYPE=1" ;
    ns1:textoExtracto "TYPE=1 TDATA 13(+) TDATA 14(+) TDATA 15(+) B TDATA 4(+) A TDATA 2(+) TDATA 1(+) Z Z Z Y X X Y TDATA 6(+)" .

ns1:TipoCinematica_2 a ns1:ModoOperacion ;
    rdfs:label "Tipo 2 de cinemática del cabezal"@es ;
    ns1:documentadoEn ns1:Tabla_CinematicasCabezal_Tipos1_8 ;
    ns1:identificador "TYPE=2" ;
    ns1:textoExtracto "TYPE=2 TDATA 13(+) DATA 14(+) TDATA 3(+) TDATA 2(+) TDATA 15(+) C A TDATA 1(+) Z Z Z Y X X Y TDATA 6(+)" .

ns1:TipoCinematica_3 a ns1:ModoOperacion ;
    rdfs:label "Tipo 3 de cinemática del cabezal"@es ;
    ns1:documentadoEn ns1:Tabla_CinematicasCabezal_Tipos1_8 ;
    ns1:identificador "TYPE=3" ;
    ns1:textoExtracto "TYPE=3 TDATA 13(+) TDATA 14(+) TDATA 3(+) A TDATA 15(+) TDATA 4(+) B TDATA 5(-) TDATA 1(+) Z Z Z Y X X Y" .

ns1:TipoCinematica_4 a ns1:ModoOperacion ;
    rdfs:label "Tipo 4 de cinemática del cabezal"@es ;
    ns1:documentadoEn ns1:Tabla_CinematicasCabezal_Tipos1_8 ;
    ns1:identificador "TYPE=4" ;
    ns1:textoExtracto "TYPE=4 TDATA 13(+) TDATA 14(+) TDATA 2(+) TDATA 5(+) TDATA 15(+) C TDATA 3(-) TDATA 1(+) B Z Z Z Y X X Y" .

ns1:TipoCinematica_5 a ns1:ModoOperacion ;
    rdfs:label "Tipo 5 de cinemática del cabezal"@es ;
    ns1:documentadoEn ns1:Tabla_CinematicasCabezal_Tipos1_8 ;
    ns1:identificador "TYPE=5" ;
    ns1:textoExtracto "TYPE=5 TDATA 13(+) TDATA 14(+) TDATA 3(+) 5(+) TDATA 15(+) TDATA 7(+) A A DAT T C TDATA 1(+) Z Z Z Y X X Y TDATA 6(+)" .

ns1:Tabla_CinematicasCabezal_Tipos1_8 a ns1:Tabla ;
    rdfs:label "Tabla de cinemáticas del cabezal (tipos 1 a 8)"@es ;
    ns1:textoExtracto """
| TYPE=1 TDATA 13(+) TDATA 14(+)
TDATA 15(+)
B
TDATA 4(+)
A
TDATA 2(+) TDATA 1(+)
Z Z Z
Y X
X Y TDATA 6(+)
---
TYPE=5 TDATA 13(+) TDATA 14(+)
TDATA 3(+)
5(+) TDATA 15(+)
TDATA 7(+)
A
A DAT
T
C TDATA 1(+)
Z Z Z
Y X X Y TDATA 6(+)
""" .

