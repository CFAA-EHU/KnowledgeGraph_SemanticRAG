@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_0 a ns1:ModoOperacion ;
    rdfs:label "Modo 0: Ambos ejes servocontrolados" ;
    ns1:documentadoEn ns1:Tabla_TDATA12 ;
    ns1:identificador "0" ;
    ns1:textoExtracto "0 | Los dos ejes son servocontrolados." .

ns1:ModoOperacion_1 a ns1:ModoOperacion ;
    rdfs:label "Modo 1: Eje principal manual, secundario servocontrolado" ;
    ns1:documentadoEn ns1:Tabla_TDATA12 ;
    ns1:identificador "1" ;
    ns1:textoExtracto "1 | Eje principal manual y eje secundario servocontrolado." .

ns1:ModoOperacion_2 a ns1:ModoOperacion ;
    rdfs:label "Modo 2: Eje principal servocontrolado, secundario manual" ;
    ns1:documentadoEn ns1:Tabla_TDATA12 ;
    ns1:identificador "2" ;
    ns1:textoExtracto "2 | Eje principal servocontrolado y eje secundario manual." .

ns1:ModoOperacion_3 a ns1:ModoOperacion ;
    rdfs:label "Modo 3: Ambos ejes manuales" ;
    ns1:documentadoEn ns1:Tabla_TDATA12 ;
    ns1:identificador "3" ;
    ns1:textoExtracto "3 | Los dos ejes son manuales." .

ns1:Parametro_TDATA12 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA12 (Modo de control de cinemática)" ;
    ns1:documentadoEn ns1:Tabla_TDATA12 ;
    ns1:identificador "TDATA12" ;
    ns1:textoExtracto "TDATA12 | Significado." .

ns1:Parametro_TDATA13 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA13 (Posición X del cabezal)" ;
    ns1:documentadoEn ns1:Tabla_TDATA13_15 ;
    ns1:identificador "TDATA13" ;
    ns1:textoExtracto "TDATA13 Distancia entre el eje rotativo principal y el punto de referencia, según el eje X." .

ns1:Parametro_TDATA14 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA14 (Posición Y del cabezal)" ;
    ns1:documentadoEn ns1:Tabla_TDATA13_15 ;
    ns1:identificador "TDATA14" ;
    ns1:textoExtracto "TDATA14 Distancia entre el eje rotativo principal y el punto de referencia, según el eje Y." .

ns1:Parametro_TDATA15 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA15 (Posición Z del cabezal)" ;
    ns1:documentadoEn ns1:Tabla_TDATA13_15 ;
    ns1:identificador "TDATA15" ;
    ns1:textoExtracto "TDATA15 Distancia entre el eje rotativo principal y el punto de referencia, según el eje Z." .

ns1:Tabla_TDATA13_15 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de posición del cabezal (TDATA13-TDATA15)" ;
    ns1:textoExtracto "TDATA13··TDATA15 Posición del cabezal respecto al punto de referencia. TDATA13 Distancia entre el eje rotativo principal y el punto de referencia, según el eje X. TDATA14 Distancia entre el eje rotativo principal y el punto de referencia, según el eje Y. TDATA15 Distancia entre el eje rotativo principal y el punto de referencia, según el eje Z." .

ns1:Tabla_TDATA12 a ns1:Tabla ;
    rdfs:label "Tabla de modos de control de cinemática del cabezal (TDATA12)" ;
    ns1:textoExtracto "TDATA12 | Significado... 0 | Los dos ejes son servocontrolados. 1 | Eje principal manual y eje secundario servocontrolado. 2 | Eje principal servocontrolado y eje secundario manual. 3 | Los dos ejes son manuales." .

