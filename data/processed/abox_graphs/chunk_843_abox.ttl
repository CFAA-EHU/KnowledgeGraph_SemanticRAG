@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CinematicaMesa a ns1:Sistema ;
    rdfs:label "Sistema de cinemática de mesa giratoria (tipos 9-12)"@es ;
    ns1:monitoreaParametro ns1:Parametro_TDATA2,
        ns1:Parametro_TDATA3,
        ns1:Parametro_TDATA4,
        ns1:Parametro_TDATA5,
        ns1:Parametro_TDATA7 ;
    ns1:textoExtracto "Se pueden controlar los siguientes tipos de mesas giratorias. [...] TDATA2··TDATA5 Dimensiones de la mesa."@es ;
    ns1:tieneComponente ns1:Parametro_TDATA2,
        ns1:Parametro_TDATA3,
        ns1:Parametro_TDATA4,
        ns1:Parametro_TDATA5,
        ns1:Parametro_TDATA7 .

ns1:Parametro_TDATA2 a ns1:Parametro ;
    rdfs:label "TDATA2 - Distancia eje secundario (X)"@es ;
    ns1:identificador "TDATA2" ;
    ns1:textoExtracto "TDATA2 Distancia del eje rotativo secundario al punto de referencia máquina o a la intersección con el eje primario, según el eje X."@es ;
    ns1:valor "variable" .

ns1:Parametro_TDATA3 a ns1:Parametro ;
    rdfs:label "TDATA3 - Distancia eje secundario (Y)"@es ;
    ns1:identificador "TDATA3" ;
    ns1:textoExtracto "TDATA3 Distancia del eje rotativo secundario al punto de referencia máquina o a la intersección con el eje primario, según el eje Y."@es ;
    ns1:valor "variable" .

ns1:Parametro_TDATA4 a ns1:Parametro ;
    rdfs:label "TDATA4 - Distancia eje secundario (Z)"@es ;
    ns1:identificador "TDATA4" ;
    ns1:textoExtracto "TDATA4 Distancia del eje rotativo secundario al punto de referencia máquina o a la intersección con el eje primario, según el eje Z."@es ;
    ns1:valor "variable" .

ns1:Parametro_TDATA5 a ns1:Parametro ;
    rdfs:label "TDATA5 - Distancia entre ejes rotativos"@es ;
    ns1:identificador "TDATA5" ;
    ns1:textoExtracto "TDATA5 Indica la distancia entre el eje rotativo secundario y el principal."@es ;
    ns1:valor "variable" .

ns1:Parametro_TDATA7 a ns1:Parametro ;
    rdfs:label "TDATA7 - Origen RTCP"@es ;
    ns1:identificador "TDATA7" ;
    ns1:textoExtracto "TDATA7 Origen para aplicar el RTCP. Valores posibles: 0 (cero máquina) / 1 (cero pieza). Valor por defecto: 0."@es ;
    ns1:valor "0" .

