@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Cinematica_Tipos9a12 a ns1:ModoOperacion ;
    rdfs:label "Cinemática de mesa (tipos 9 a 12)"@es ;
    ns1:monitoreaParametro ns1:Parametro_TDATA7 ;
    ns1:textoExtracto "Definición de las cinemáticas de la mesa (tipos 9 a 12)."@es .

ns1:Parametro_TDATA7 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA7 (RTCP: cero máquina/cero pieza)"@es ;
    ns1:identificador "TDATA7" ;
    ns1:textoExtracto "Valores posibles: 0 (cero máquina) / 1 (cero pieza). Valor por defecto: 0. Este parámetro indica si el CNC aplica el RTCP respecto el cero máquina o el cero pieza. En este tipo de cinemática se recomienda definir este parámetro con valor ꞏ1ꞏ."@es ;
    ns1:valor "0",
        "1" .

