@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Herramienta_Cinematica a ns1:Herramienta ;
    rdfs:label "Herramienta de referencia para cinemáticas" ;
    ns1:textoExtracto "Se denomina posición de reposo cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal). En las cinemáticas con ejes rotativos en la mesa, el sentido de giro se determina desde el punto de vista de la herramienta." .

ns1:Maquina_Tipo9 a ns1:Maquina ;
    rdfs:label "Máquina con cinemática tipo 9" ;
    ns1:cumpleNormativa ns1:Directiva_DIN66217 ;
    ns1:identificador "TYPE=9" ;
    ns1:textoExtracto "TYPE=9 TDATA 10 = 0 TDATA 11 = 0" .

ns1:Parametro_TDATA10 a ns1:Parametro ;
    rdfs:label "Sentido de giro del eje rotativo principal" ;
    ns1:identificador "TDATA10" ;
    ns1:textoExtracto "TDATA10 Sentido de giro del eje rotativo principal. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." ;
    ns1:valor "0" .

ns1:Parametro_TDATA10_Tipo9 a ns1:Parametro ;
    rdfs:label "Sentido de giro del eje rotativo principal (TYPE=9)" ;
    ns1:identificador "TDATA10_TYPE9" ;
    ns1:textoExtracto "TDATA 10 = 0" ;
    ns1:valor "0" .

ns1:Parametro_TDATA11 a ns1:Parametro ;
    rdfs:label "Sentido de giro del eje rotativo secundario" ;
    ns1:identificador "TDATA11" ;
    ns1:textoExtracto "TDATA11 Sentido de giro del eje rotativo secundario. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 1." ;
    ns1:valor "1" .

ns1:Parametro_TDATA11_Tipo9 a ns1:Parametro ;
    rdfs:label "Sentido de giro del eje rotativo secundario (TYPE=9)" ;
    ns1:identificador "TDATA11_TYPE9" ;
    ns1:textoExtracto "TDATA 11 = 0" ;
    ns1:valor "0" .

ns1:Parametro_TDATA8 a ns1:Parametro ;
    rdfs:label "Posición de reposo del eje rotativo principal" ;
    ns1:identificador "TDATA8" ;
    ns1:textoExtracto "TDATA8 Posición de reposo del eje rotativo principal. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0." ;
    ns1:valor "0" .

ns1:Parametro_TDATA9 a ns1:Parametro ;
    rdfs:label "Posición de reposo del eje rotativo secundario" ;
    ns1:identificador "TDATA9" ;
    ns1:textoExtracto "TDATA9 Posición de reposo del eje rotativo secundario. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0. Se denomina posición de reposo cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal)." ;
    ns1:valor "0" .

ns1:Directiva_DIN66217 a ns1:Directiva ;
    rdfs:label "Norma DIN 66217" ;
    ns1:identificador "DIN 66217" ;
    ns1:textoExtracto "La dirección de los ejes X Y Z, según la norma DIN 66217, se puede recordar fácilmente utilizando la regla de la mano derecha. En los ejes rotativos, el sentido de giro viene determinado al doblar los dedos alrededor del eje lineal asociado con el dedo pulgar señalando la dirección positiva del eje lineal." .

