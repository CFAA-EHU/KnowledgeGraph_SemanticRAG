@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ModoOperacion_RTCP a ns1:ModoOperacion ;
    rdfs:label "Modo RTCP" ;
    ns1:textoExtracto "Con el modo RTCP activo, este parámetro establece si el sistema de coordenadas pieza está fijo sobre la pieza y gira con ella..." .

ns1:Parametro_TDATA10_TYPE9_12 a ns1:Parametro ;
    rdfs:label "TDATA 10 (Tipos 9-12)" ;
    ns1:textoExtracto "TDATA 10 = 0 [...] TDATA 10 = 1" ;
    ns1:valor "0,1"^^xsd:string .

ns1:Parametro_TDATA11_TYPE9_12 a ns1:Parametro ;
    rdfs:label "TDATA 11 (Tipos 9-12)" ;
    ns1:textoExtracto "TDATA 11 = 0 [...] TDATA 11 = 1" ;
    ns1:valor "0,1"^^xsd:string .

ns1:Tabla_SignificadoTDATA12 a ns1:Tabla ;
    rdfs:label "Significado de valores TDATA12" ;
    ns1:documentadoEn ns1:Parametro_TDATA12_EjesRotativos ;
    ns1:textoExtracto "| TDATA12 | Significado. | --- | --- | 0 | Los dos ejes son servocontrolados. | 1 | Eje principal manual y eje secundario servocontrolado. | 2 | Eje principal servocontrolado y eje secundario manual. | 3 | Los dos ejes son manuales." .

ns1:Tabla_SignificadoTDATA16 a ns1:Tabla ;
    rdfs:label "Significado de valores TDATA16" ;
    ns1:documentadoEn ns1:Parametro_TDATA16_SistemaCoordenadas ;
    ns1:textoExtracto "| TDATA16 | Significado. | --- | --- | 0 | Al variar la orientación de la pieza, no se modifica la posición que ocupa la punta de la herramienta sobre la pieza." .

ns1:Parametro_TDATA12_EjesRotativos a ns1:Parametro ;
    rdfs:label "TDATA12 (Ejes rotativos)" ;
    ns1:identificador "TDATA12" ;
    ns1:textoExtracto "TDATA12 Ejes rotativos manuales o servocontrolados. Valores posibles: 0 a 3. Valor por defecto: 0. Este parámetro indica si los ejes rotativos son manuales o servocontrolados." ;
    ns1:valor "0,1,2,3"^^xsd:string .

ns1:Parametro_TDATA16_SistemaCoordenadas a ns1:Parametro ;
    rdfs:label "TDATA16 (Girar sistema de coordenadas)" ;
    ns1:identificador "TDATA16" ;
    ns1:textoExtracto "TDATA16 Girar el sistema de coordenadas pieza al girar la mesa. Valores posibles: 0 / 1. Valor por defecto: 0. Con el modo RTCP activo, este parámetro establece si el sistema de coordenadas pieza está fijo sobre la pieza y gira con ella o si por el contrario se mantiene paralelo al sistema de coordenadas máquina." ;
    ns1:valor "0,1"^^xsd:string .

