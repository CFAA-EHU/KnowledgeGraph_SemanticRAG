@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Herramienta_Cinematica a ns1:Herramienta ;
    rdfs:label "Herramienta en sistema cinemático" ;
    ns1:textoExtracto "punta de la herramienta sobre la pieza" .

ns1:Parametro_TDATA16_0 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA16 = 0" ;
    ns1:documentadoEn ns1:Tabla_TDATA16 ;
    ns1:identificador "0" ;
    ns1:textoExtracto "Al variar la orientación de la pieza, no se modifica la posición que ocupa la punta de la herramienta sobre la pieza. El sistema de coordenadas está fijo sobre la pieza y gira con ella." ;
    ns1:valor "0" .

ns1:Parametro_TDATA16_1 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA16 = 1" ;
    ns1:documentadoEn ns1:Tabla_TDATA16 ;
    ns1:identificador "1" ;
    ns1:textoExtracto "Al variar la orientación de la pieza, no se modifica la posición que ocupa el punto definido como cero pieza. El sistema de coordenadas se mantiene paralelo al sistema de coordenadas máquina." ;
    ns1:valor "1" .

ns1:SistemaCoordenadasMaquina a ns1:Sistema ;
    rdfs:label "Sistema de coordenadas máquina" ;
    ns1:textoExtracto "El sistema de coordenadas se mantiene paralelo al sistema de coordenadas máquina." .

ns1:SistemaCoordenadasPieza a ns1:Sistema ;
    rdfs:label "Sistema de coordenadas fijo a la pieza" ;
    ns1:textoExtracto "El sistema de coordenadas está fijo sobre la pieza y gira con ella." .

ns1:Tabla_TDATA16 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros TDATA16 para cinemáticas de mesa (tipos 9-12)" ;
    ns1:textoExtracto """
| TDATA16 | Significado. |
| --- | --- |
| 0 | Al variar la orientación de la pieza, no se modifica la posición que ocupa la punta de la herramienta sobre la pieza. El sistema de coordenadas está fijo sobre la pieza y gira con ella. |
| 1 | Al variar la orientación de la pieza, no se modifica la posición que ocupa el punto definido como cero pieza. El sistema de coordenadas se mantiene paralelo al sistema de coordenadas máquina. |
""" .

