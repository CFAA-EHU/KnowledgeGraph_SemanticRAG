@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:cinematica_cabezal_mesa_tipos13_16 a ns1:Sistema ;
    rdfs:label "Cinemática cabezal-mesa (tipos 13 a 16)"@es ;
    ns1:textoExtracto "En este tipo de cinemáticas un eje de giro se encuentra en el cabezal y el otro en la mesa. El del cabezal se encarga de orientar la herramienta y el de la mesa de trabajo orienta la pieza."@es ;
    ns1:tieneComponente ns1:cabezal_tipos13_16,
        ns1:mesa_trabajo_tipos13_16,
        ns1:param_TDATA1,
        ns1:param_TDATA2,
        ns1:param_TDATA3,
        ns1:param_TDATA4,
        ns1:param_TDATA5,
        ns1:param_TDATA6,
        ns1:param_TDATA7 .

ns1:cabezal_tipos13_16 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal (tipos 13 a 16)"@es ;
    ns1:textoExtracto "El del cabezal se encarga de orientar la herramienta [...] El cuarto eje corresponde al eje rotativo del cabezal."@es .

ns1:mesa_trabajo_tipos13_16 a ns1:ComponenteMecanico ;
    rdfs:label "Mesa de trabajo (tipos 13 a 16)"@es ;
    ns1:textoExtracto "El de la mesa de trabajo orienta la pieza [...] El quinto eje corresponde al eje rotativo de la mesa."@es .

ns1:param_TDATA1 a ns1:Parametro ;
    rdfs:label "TDATA1"@es ;
    ns1:identificador "TDATA1" ;
    ns1:textoExtracto "TDATA1 Indica la distancia entre la nariz del mandrino y el eje rotativo del cabezal, según el eje Z."@es ;
    ns1:valor "Distancia (eje Z): nariz mandrino ↔ eje rotativo cabezal"@es .

ns1:param_TDATA2 a ns1:Parametro ;
    rdfs:label "TDATA2"@es ;
    ns1:identificador "TDATA2" ;
    ns1:textoExtracto "TDATA2 Indica la distancia entre el eje de la herramienta y el eje rotativo del cabezal, según el eje X."@es ;
    ns1:valor "Distancia (eje X): eje herramienta ↔ eje rotativo cabezal"@es .

ns1:param_TDATA3 a ns1:Parametro ;
    rdfs:label "TDATA3"@es ;
    ns1:identificador "TDATA3" ;
    ns1:textoExtracto "TDATA3 Indica la distancia entre el eje de la herramienta y el eje rotativo del cabezal, según el eje Y."@es ;
    ns1:valor "Distancia (eje Y): eje herramienta ↔ eje rotativo cabezal"@es .

ns1:param_TDATA4 a ns1:Parametro ;
    rdfs:label "TDATA4"@es ;
    ns1:identificador "TDATA4" ;
    ns1:textoExtracto "TDATA4 Distancia del eje rotativo de la mesa al punto de referencia máquina, según el eje X."@es ;
    ns1:valor "Distancia (eje X): eje rotativo mesa ↔ referencia máquina"@es .

ns1:param_TDATA5 a ns1:Parametro ;
    rdfs:label "TDATA5"@es ;
    ns1:identificador "TDATA5" ;
    ns1:textoExtracto "TDATA5 Distancia del eje rotativo de la mesa al punto de referencia máquina, según el eje Y."@es ;
    ns1:valor "Distancia (eje Y): eje rotativo mesa ↔ referencia máquina"@es .

ns1:param_TDATA6 a ns1:Parametro ;
    rdfs:label "TDATA6"@es ;
    ns1:identificador "TDATA6" ;
    ns1:textoExtracto "TDATA6 Distancia del eje rotativo de la mesa al punto de referencia máquina, según el eje Z."@es ;
    ns1:valor "Distancia (eje Z): eje rotativo mesa ↔ referencia máquina"@es .

ns1:param_TDATA7 a ns1:Parametro ;
    rdfs:label "TDATA7"@es ;
    ns1:identificador "TDATA7" ;
    ns1:textoExtracto "TDATA7 Origen para aplicar el RTCP. Valores posibles: 0 (cero máquina) / 1 (cero pieza). Valor por defecto: 0."@es ;
    ns1:valor "0 (cero máquina) o 1 (cero pieza)"@es .

