@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_RTCP a ns1:Parametro ;
    rdfs:label "Parámetro RTCP (TDATA7)" ;
    ns1:identificador "TDATA7" ;
    ns1:monitoreaParametro ns1:Maquina_CNC ;
    ns1:textoExtracto "Este parámetro indica si el CNC aplica el RTCP respecto el cero máquina o el cero pieza. TDATA7=0 TDATA7=1" ;
    ns1:valor 0 .

ns1:Maquina_CNC a ns1:Maquina ;
    ns1:textoExtracto "CNC (control numérico que aplica RTCP según parámetro TDATA7)" .

