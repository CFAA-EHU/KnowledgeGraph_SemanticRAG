@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:TDATA10 a ns1:Parametro ;
    rdfs:label "TDATA10" ;
    ns1:cumpleNormativa ns1:NormaDIN66217 ;
    ns1:identificador "TDATA10" ;
    ns1:textoExtracto "Sentido de giro del eje rotativo principal. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." ;
    ns1:valor 0 .

ns1:TDATA10_ConfiguracionMesa a ns1:Parametro ;
    rdfs:label "TDATA10 (configuración mesa)" ;
    ns1:cumpleNormativa ns1:NormaDIN66217 ;
    ns1:identificador "TDATA10=1" ;
    ns1:textoExtracto "En las cinemáticas con ejes rotativos en la mesa, el sentido de giro se determina desde el punto de vista de la herramienta, por lo que se parametrizará TDATA10=1" ;
    ns1:valor 1 .

ns1:TDATA11 a ns1:Parametro ;
    rdfs:label "TDATA11" ;
    ns1:cumpleNormativa ns1:NormaDIN66217 ;
    ns1:identificador "TDATA11" ;
    ns1:textoExtracto "Sentido de giro del eje rotativo secundario. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." ;
    ns1:valor 0 .

ns1:TDATA11_ConfiguracionMesa a ns1:Parametro ;
    rdfs:label "TDATA11 (configuración mesa)" ;
    ns1:cumpleNormativa ns1:NormaDIN66217 ;
    ns1:identificador "TDATA11=1" ;
    ns1:textoExtracto "En las cinemáticas con ejes rotativos en la mesa, el sentido de giro se determina desde el punto de vista de la herramienta, por lo que se parametrizará TDATA11=1" ;
    ns1:valor 1 .

ns1:TDATA8 a ns1:Parametro ;
    rdfs:label "TDATA8" ;
    ns1:identificador "TDATA8" ;
    ns1:textoExtracto "Posición de reposo del eje rotativo principal. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0." ;
    ns1:valor "0.0"^^xsd:float .

ns1:TDATA9 a ns1:Parametro ;
    rdfs:label "TDATA9" ;
    ns1:identificador "TDATA9" ;
    ns1:textoExtracto "Posición de reposo del eje rotativo secundario. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0. Se denomina posición de reposo cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal)." ;
    ns1:valor "0.0"^^xsd:float .

ns1:NormaDIN66217 a ns1:Directiva ;
    rdfs:label "DIN 66217" ;
    ns1:identificador "DIN 66217" ;
    ns1:textoExtracto "La dirección de los ejes X Y Z, según la norma DIN 66217, se puede recordar fácilmente utilizando la regla de la mano derecha. En los ejes rotativos, el sentido de giro viene determinado al doblar los dedos alrededor del eje lineal asociado con el dedo pulgar señalando la dirección positiva del eje lineal." .

