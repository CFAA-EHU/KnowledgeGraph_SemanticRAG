@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Cinematica_Tipo13 a ns1:ModoOperacion ;
    rdfs:label "Cinemática Tipo 13" ;
    ns1:identificador "TYPE=13" ;
    ns1:monitoreaParametro ns1:Parametro_TDATA1,
        ns1:Parametro_TDATA10,
        ns1:Parametro_TDATA11,
        ns1:Parametro_TDATA13,
        ns1:Parametro_TDATA14,
        ns1:Parametro_TDATA15,
        ns1:Parametro_TDATA3,
        ns1:Parametro_TDATA4,
        ns1:Parametro_TDATA5,
        ns1:Parametro_TDATA6 ;
    ns1:textoExtracto "TYPE=13" .

ns1:Cinematica_Tipo14 a ns1:ModoOperacion ;
    rdfs:label "Cinemática Tipo 14" ;
    ns1:identificador "TYPE=14" ;
    ns1:monitoreaParametro ns1:Parametro_TDATA1,
        ns1:Parametro_TDATA11,
        ns1:Parametro_TDATA13,
        ns1:Parametro_TDATA14,
        ns1:Parametro_TDATA15,
        ns1:Parametro_TDATA3,
        ns1:Parametro_TDATA4,
        ns1:Parametro_TDATA5 ;
    ns1:textoExtracto "TYPE=14" .

ns1:Parametro_TDATA10 a ns1:Parametro ;
    rdfs:label "TDATA10" ;
    ns1:textoExtracto "se parametrizará TDATA10=1" ;
    ns1:valor "1" .

ns1:Parametro_TDATA6 a ns1:Parametro ;
    rdfs:label "TDATA6" ;
    ns1:textoExtracto "TDATA 6(+)" ;
    ns1:valor "+" .

ns1:Parametro_TDATA1 a ns1:Parametro ;
    rdfs:label "TDATA1" ;
    ns1:textoExtracto "TDATA 1(+)" ;
    ns1:valor "+" .

ns1:Parametro_TDATA11 a ns1:Parametro ;
    rdfs:label "TDATA11" ;
    ns1:textoExtracto "se parametrizará TDATA10=1 TDATA11 = 1" ;
    ns1:valor "1" .

ns1:Parametro_TDATA13 a ns1:Parametro ;
    rdfs:label "TDATA13" ;
    ns1:textoExtracto "TDATA 13(+)" ;
    ns1:valor "+" .

ns1:Parametro_TDATA14 a ns1:Parametro ;
    rdfs:label "TDATA14" ;
    ns1:textoExtracto "TDATA 14(+)" ;
    ns1:valor "+" .

ns1:Parametro_TDATA15 a ns1:Parametro ;
    rdfs:label "TDATA15" ;
    ns1:textoExtracto "TDATA 15(+)" ;
    ns1:valor "+" .

ns1:Parametro_TDATA3 a ns1:Parametro ;
    rdfs:label "TDATA3" ;
    ns1:textoExtracto "TDATA 3(+)" ;
    ns1:valor "+" .

ns1:Parametro_TDATA4 a ns1:Parametro ;
    rdfs:label "TDATA4" ;
    ns1:textoExtracto "TDATA 4(+)" ;
    ns1:valor "+" .

ns1:Parametro_TDATA5 a ns1:Parametro ;
    rdfs:label "TDATA5" ;
    ns1:textoExtracto "TDATA 5(+)" ;
    ns1:valor "+" .

