@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Tabla_CinematicasCabezal_Tipos13a16 a ns1:Tabla ;
    rdfs:label "Definición de cinemáticas del cabezal (tipos 13 a 16)" ;
    ns1:detalladoEnEsquema ns1:Parametro_TDATA12,
        ns1:Parametro_TDATA13,
        ns1:Parametro_TDATA14,
        ns1:Parametro_TDATA15 ;
    ns1:textoExtracto "| TYPE=15 ... TDATA11 = 1 ... | --- | TYPE=16 ... TDATA11 = 1 ... |" .

ns1:Parametro_TDATA12 a ns1:Parametro ;
    rdfs:label "TDATA12" ;
    ns1:textoExtracto "TDATA12 Ejes rotativos manuales o servocontrolados. Valores posibles: 0 a 3. Valor por defecto: 0. Este parámetro indica si los ejes rotativos son manuales o servocontrolados." ;
    ns1:valor 0 .

ns1:Parametro_TDATA13 a ns1:Parametro ;
    rdfs:label "TDATA13" ;
    ns1:textoExtracto "TDATA13 Distancia que define la colocación del cabezal, desde el eje rotativo, según el eje X." .

ns1:Parametro_TDATA14 a ns1:Parametro ;
    rdfs:label "TDATA14" ;
    ns1:textoExtracto "TDATA14 Distancia que define la colocación del cabezal, desde el eje rotativo, según el eje Y." .

ns1:Parametro_TDATA15 a ns1:Parametro ;
    rdfs:label "TDATA15" ;
    ns1:textoExtracto "TDATA15 Distancia que define la colocación del cabezal, desde el eje rotativo, según el eje Z." .

