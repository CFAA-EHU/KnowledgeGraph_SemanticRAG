@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteMecanico_EjeRotativoPrincipal a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo principal del cabezal"@es ;
    ns1:textoExtracto "Se llama eje rotativo principal, al eje rotativo del cabezal que en su giro arrastra a los otros dos ejes de giro."@es .

ns1:Sistema_CinematicaCabezal a ns1:Sistema ;
    rdfs:label "Sistema de cinemática del cabezal (tipos 17-24)"@es ;
    ns1:textoExtracto "Se pueden definir con valor positivo o negativo. El signo (+) en las figuras indica el sentido que se asume como positivo, los números 1º, 2º, 3º indican los centros de giro. Se llama eje rotativo principal, al eje rotativo del cabezal que en su giro arrastra a los otros dos ejes de giro."@es ;
    ns1:tieneComponente ns1:Parametro_TDATA1,
        ns1:Parametro_TDATA10,
        ns1:Parametro_TDATA11,
        ns1:Parametro_TDATA12,
        ns1:Parametro_TDATA2,
        ns1:Parametro_TDATA3,
        ns1:Parametro_TDATA4,
        ns1:Parametro_TDATA5,
        ns1:Parametro_TDATA6,
        ns1:Parametro_TDATA7,
        ns1:Parametro_TDATA8,
        ns1:Parametro_TDATA9 .

ns1:Parametro_TDATA1 a ns1:Parametro ;
    rdfs:label "TDATA1 (distancia nariz-mandrino a centro de giro terciario, eje Z)"@es ;
    ns1:identificador "TDATA1" ;
    ns1:textoExtracto "TDATA1 Indica la distancia entre la nariz del mandrino y el centro de giro terciario, eje rotativo terciario, según el eje Z."@es ;
    ns1:valor "distancia (eje Z)"@es .

ns1:Parametro_TDATA10 a ns1:Parametro ;
    rdfs:label "TDATA10 (distancia 3º a 2º centro de giro, eje Z)"@es ;
    ns1:identificador "TDATA10" ;
    ns1:textoExtracto "TDATA10 Indica la distancia desde el 3º centro de giro hasta el 2º centro de giro, según el eje Z."@es ;
    ns1:valor "distancia (eje Z)"@es .

ns1:Parametro_TDATA11 a ns1:Parametro ;
    rdfs:label "TDATA11 (distancia eje herramienta a 3º centro de giro, eje X)"@es ;
    ns1:identificador "TDATA11" ;
    ns1:textoExtracto "TDATA11 Indica la distancia desde el eje de la herramienta hasta el 3º centro de giro, según el eje X."@es ;
    ns1:valor "distancia (eje X)"@es .

ns1:Parametro_TDATA12 a ns1:Parametro ;
    rdfs:label "TDATA12 (distancia eje herramienta a 3º centro de giro, eje Y)"@es ;
    ns1:identificador "TDATA12" ;
    ns1:textoExtracto "TDATA12 Indica la distancia desde el eje de la herramienta hasta el 3º centro de giro, según el eje Y."@es ;
    ns1:valor "distancia (eje Y)"@es .

ns1:Parametro_TDATA2 a ns1:Parametro ;
    rdfs:label "TDATA2 (distancia 1º centro de giro a referencia máquina, eje X)"@es ;
    ns1:identificador "TDATA2" ;
    ns1:textoExtracto "TDATA2 Indica la distancia del cabezal desde el 1º centro de giro hasta el punto de referencia máquina, según el eje X."@es ;
    ns1:valor "distancia (eje X)"@es .

ns1:Parametro_TDATA3 a ns1:Parametro ;
    rdfs:label "TDATA3 (distancia 1º centro de giro a referencia máquina, eje Y)"@es ;
    ns1:identificador "TDATA3" ;
    ns1:textoExtracto "TDATA3 Indica la distancia del cabezal desde el 1º centro de giro hasta el punto de referencia máquina, según el eje Y."@es ;
    ns1:valor "distancia (eje Y)"@es .

ns1:Parametro_TDATA4 a ns1:Parametro ;
    rdfs:label "TDATA4 (distancia 1º centro de giro a referencia máquina, eje Z)"@es ;
    ns1:identificador "TDATA4" ;
    ns1:textoExtracto "TDATA4 Indica la distancia del cabezal desde el 1º centro de giro hasta el punto de referencia máquina, según el eje Z."@es ;
    ns1:valor "distancia (eje Z)"@es .

ns1:Parametro_TDATA5 a ns1:Parametro ;
    rdfs:label "TDATA5 (distancia 2º a 1º centro de giro, eje X)"@es ;
    ns1:identificador "TDATA5" ;
    ns1:textoExtracto "TDATA5 Indica la distancia desde el 2º centro de giro hasta el 1º centro de giro, según el eje X."@es ;
    ns1:valor "distancia (eje X)"@es .

ns1:Parametro_TDATA6 a ns1:Parametro ;
    rdfs:label "TDATA6 (distancia 2º a 1º centro de giro, eje Y)"@es ;
    ns1:identificador "TDATA6" ;
    ns1:textoExtracto "TDATA6 Indica la distancia desde el 2º centro de giro hasta el 1º centro de giro, según el eje Y."@es ;
    ns1:valor "distancia (eje Y)"@es .

ns1:Parametro_TDATA7 a ns1:Parametro ;
    rdfs:label "TDATA7 (distancia 2º a 1º centro de giro, eje Z)"@es ;
    ns1:identificador "TDATA7" ;
    ns1:textoExtracto "TDATA7 Indica la distancia desde el 2º centro de giro hasta el 1º centro de giro, según el eje Z."@es ;
    ns1:valor "distancia (eje Z)"@es .

ns1:Parametro_TDATA8 a ns1:Parametro ;
    rdfs:label "TDATA8 (distancia 3º a 2º centro de giro, eje X)"@es ;
    ns1:identificador "TDATA8" ;
    ns1:textoExtracto "TDATA8 Indica la distancia desde el 3º centro de giro hasta el 2º centro de giro, según el eje X."@es ;
    ns1:valor "distancia (eje X)"@es .

ns1:Parametro_TDATA9 a ns1:Parametro ;
    rdfs:label "TDATA9 (distancia 3º a 2º centro de giro, eje Y)"@es ;
    ns1:identificador "TDATA9" ;
    ns1:textoExtracto "TDATA9 Indica la distancia desde el 3º centro de giro hasta el 2º centro de giro, según el eje Y."@es ;
    ns1:valor "distancia (eje Y)"@es .

