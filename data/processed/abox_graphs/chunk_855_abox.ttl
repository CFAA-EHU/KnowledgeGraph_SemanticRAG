@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Cabezal_Tipos17_24 a ns1:Sistema ;
    rdfs:label "Cabezal (tipos 17 a 24)"@es ;
    ns1:identificador "Tipos 17-24" ;
    ns1:textoExtracto "Definición de las cinemáticas del cabezal (tipos 17 a 24)."@es ;
    ns1:tieneComponente ns1:EjeRotativoSecundario_Cabezal_Tipos17_24,
        ns1:EjeRotativoTerciario_Cabezal_Tipos17_24 .

ns1:EjeRotativoSecundario_Cabezal_Tipos17_24 a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo secundario (cabezal tipos 17-24)"@es ;
    ns1:identificador "Tipos 17-24" ;
    ns1:textoExtracto "Se llama eje rotativo secundario, al eje rotativo del cabezal que en su giro arrastra a un eje de giro."@es .

ns1:EjeRotativoTerciario_Cabezal_Tipos17_24 a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo terciario (cabezal tipos 17-24)"@es ;
    ns1:identificador "Tipos 17-24" ;
    ns1:textoExtracto "Se llama eje rotativo terciario, al eje rotativo del cabezal que en su giro..."@es .

