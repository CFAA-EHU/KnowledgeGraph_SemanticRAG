@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjeRotativoSecundario_Cabezal_Tipos17_24 a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo secundario del cabezal (tipos 17-24)"@es ;
    ns1:textoExtracto "Se llama eje rotativo secundario, al eje rotativo del cabezal que en su giro arrastra a un eje de giro."@es .

ns1:EjeRotativoTerciario_Cabezal_Tipos17_24 a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo terciario del cabezal (tipos 17-24)"@es ;
    ns1:controla ns1:Herramienta_Cabezal_Tipos17_24 ;
    ns1:textoExtracto "Se llama eje rotativo terciario, al eje rotativo del cabezal que en su giro no arrastra a ningún otro eje de giro, solo a la herramienta."@es .

ns1:Herramienta_Cabezal_Tipos17_24 a ns1:Herramienta ;
    rdfs:label "Herramienta acoplada al cabezal (tipos 17-24)"@es ;
    ns1:textoExtracto "solo a la herramienta"@es .

