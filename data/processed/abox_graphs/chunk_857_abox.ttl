ns1:EsquemaCinematicasCabezalTipos17a24 a ns1:Esquema ;
    rdfs:label "Esquema de cinemáticas del cabezal (tipos 17 a 24)"@es ;
    ns1:identificador "2.9.5" ;
    ns1:textoExtracto """
TYPE=17 TDATA 2(+) TDATA 3(+)
A 1º TDATA 4(+) 1º
TDATA 7(+) TDATA 12(+)
2º 2º
3º TDATA 10(+) 3º
TDATA 8(+)
B TDATA 1(+)
A
Z Z Z TDATA 6(+)
Y X X Y

[...]

TYPE=24 TDATA 2(+) TDATA 3(+) TDATA 6(+)
TDATA 4(+)
TDATA 5(+)
C 2º 1º 1º 2º
B
3º 3º TDATA 10(+)
TDATA 8(+) TDATA 1(+)
Z A Z Z
Y X
X Y TDATA 12(+)
""" .

