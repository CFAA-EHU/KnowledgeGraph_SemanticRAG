@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_TDATA12_0 a ns1:Parametro ;
    rdfs:label "Modo cinemático: Todos los ejes servocontrolados"@es ;
    ns1:documentadoEn ns1:Tabla_TDATA12_CinematicasCabezal ;
    ns1:textoExtracto "Los tres ejes son servocontrolados."@es ;
    ns1:valor "0" .

ns1:Parametro_TDATA12_7 a ns1:Parametro ;
    rdfs:label "Modo cinemático: Todos los ejes manuales"@es ;
    ns1:documentadoEn ns1:Tabla_TDATA12_CinematicasCabezal ;
    ns1:textoExtracto "Todos los ejes son manuales."@es ;
    ns1:valor "7" .

ns1:Tabla_TDATA12_CinematicasCabezal a ns1:Tabla ;
    rdfs:label "Tabla TDATA12: Definición de cinemáticas del cabezal (tipos 17-24)"@es ;
    ns1:identificador "TDATA12" ;
    ns1:textoExtracto "TDATA12 | Significado."@es .

