@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Funcion_FACE a ns1:InterfazUsuario,
        ns1:Tabla ;
    rdfs:label "Función #FACE" ;
    ns1:ilustradoEn ns1:Tabla_CinematicasTipo41_42 ;
    ns1:textoExtracto "Estas cinemáticas se seleccionan mediante la función #FACE desde el programa pieza." .

ns1:Herramienta_Mecanizado a ns1:Herramienta ;
    rdfs:label "Herramienta de mecanizado" ;
    ns1:monitoreaParametro ns1:Parametro_TDATA6 ;
    ns1:textoExtracto "El desalineamiento de la herramienta da lugar a una zona circular, de radio TDATA6, que no es accesible al mecanizado." .

ns1:Parametro_TDATA10 a ns1:Parametro ;
    rdfs:label "Sentido de giro del eje giratorio (TDATA10)" ;
    ns1:textoExtracto "TDATA10 Sentido de giro del eje giratorio." .

ns1:Parametro_TDATA2 a ns1:Parametro ;
    rdfs:label "Posición del eje rotativo (TDATA2)" ;
    ns1:textoExtracto "TDATA2 Posición del eje rotativo. Valores posibles: Entre ±999999999.0000 Valor por defecto: 0. Indica la distancia del eje rotativo al eje lineal sobre el que se desarrolla." ;
    ns1:valor "0" .

ns1:Parametro_TDATA4 a ns1:Parametro ;
    rdfs:label "Offset angular del eje rotativo (TDATA4)" ;
    ns1:textoExtracto "TDATA4 Offset angular del eje rotativo. Valores posibles: Entre ±999999999.0000º Valor por defecto: 0." ;
    ns1:valor "0" .

ns1:Parametro_TDATA5 a ns1:Parametro ;
    rdfs:label "Posición del eje de giro (TDATA5)" ;
    ns1:textoExtracto "TDATA5 Posición del eje de giro. Valores posibles: 0 (el eje de giro se encuentra en el cero pieza) / 1 (la posición del eje de giro viene indicada por DATA2). Valor por defecto: 0." ;
    ns1:valor "0" .

ns1:Parametro_TDATA6 a ns1:Parametro ;
    rdfs:label "Desalineamiento de la herramienta sobre el eje C (TDATA6)" ;
    ns1:textoExtracto "TDATA6 Desalineamiento de la herramienta sobre el eje C. Valores posibles: Entre ±999999999.0000 Valor por defecto: 0. Este parámetro permite corregir el desalineamiento de la herramienta. Una herramienta está desalineada si cuando se sitúa en cota cero y no coincide con el eje de giro del eje." ;
    ns1:valor "0" .

ns1:Tabla_CinematicasTipo41_42 a ns1:Tabla ;
    rdfs:label "Tabla de cinemáticas tipo 41/42" ;
    ns1:documentadoEn ns1:Manual_CNC ;
    ns1:textoExtracto "Estas cinemáticas se seleccionan mediante la función #FACE desde el programa pieza. Si al ejecutar esta función no se selecciona la cinemática, el CNC cogerá de la primera cinemática del tipo 41 o 42 definida en la tabla." .

