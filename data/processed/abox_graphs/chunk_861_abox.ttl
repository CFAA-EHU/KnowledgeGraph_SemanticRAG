@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Herramienta_Mecanizado a ns1:Herramienta ;
    rdfs:label "Herramienta de mecanizado"@es ;
    ns1:textoExtracto "El desalineamiento de la herramienta da lugar a una zona circular [...] que no es accesible al mecanizado."@es .

ns1:Maquina_EjeC a ns1:Maquina ;
    rdfs:label "Eje giratorio –C– (tipos 41-42)"@es ;
    ns1:requiereMantenimiento ns1:AlineacionDeHerramientaParaEvitarZonaInaccesibleRadioTDATA6 ;
    ns1:textoExtracto "Definición de las cinemáticas del eje –C– (tipos 41 a 42)."@es ;
    ns1:tieneComponente ns1:Parametro_TDATA10,
        ns1:Parametro_TDATA6 .

ns1:AlineacionDeHerramientaParaEvitarZonaInaccesibleRadioTDATA6 a ns1:TareaMantenimiento ;
    rdfs:label "Alineación de herramienta para evitar zona inaccesible (radio TDATA6)"@es ;
    ns1:textoExtracto "El desalineamiento de la herramienta da lugar a una zona circular, de radio TDATA6, que no es accesible al mecanizado."@es .

ns1:Parametro_TDATA10 a ns1:Parametro ;
    rdfs:label "Sentido de giro del eje giratorio (TDATA10)"@es ;
    ns1:identificador "TDATA10" ;
    ns1:textoExtracto "TDATA10 Sentido de giro del eje giratorio. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0."@es ;
    ns1:valor "0 (según DIN 66217)"@es .

ns1:Parametro_TDATA6 a ns1:Parametro ;
    rdfs:label "Radio de zona inaccesible (TDATA6)"@es ;
    ns1:identificador "TDATA6" ;
    ns1:textoExtracto "El desalineamiento de la herramienta da lugar a una zona circular, de radio TDATA6, que no es accesible al mecanizado."@es ;
    ns1:valor "radio de zona inaccesible"@es .

