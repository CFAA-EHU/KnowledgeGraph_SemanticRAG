@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_CabezalTorno a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de torno (ejemplo de eje rotativo)"@es ;
    ns1:textoExtracto "por ejemplo el cabezal de un torno"@es .

ns1:Funcion_CYL a ns1:InterfazUsuario,
        ns1:Tabla ;
    rdfs:label "Función #CYL"@es ;
    ns1:identificador "#CYL" ;
    ns1:textoExtracto "Estas cinemáticas se seleccionan mediante la función #CYL desde el programa pieza."@es .

ns1:Sistema_CinematicaTipo43 a ns1:Sistema ;
    rdfs:label "Cinemática tipo 43 (eje –C–)"@es ;
    ns1:controla ns1:Parametro_TDATA2_PosicionEjeRotativo ;
    ns1:detalladoEnEsquema ns1:Tabla_TDATA2 ;
    ns1:identificador "Tipo 43" ;
    ns1:textoExtracto "Definición de las cinemáticas del eje –C– (tipo 43). En este tipo de cinemáticas se define la situación física del eje rotativo respecto de los ejes lineales."@es .

ns1:Parametro_TDATA2_PosicionEjeRotativo a ns1:Parametro ;
    rdfs:label "Posición del eje rotativo (TDATA2)"@es ;
    ns1:documentadoEn ns1:Tabla_TDATA2 ;
    ns1:textoExtracto "TDATA2 Posición del eje rotativo. Valores posibles: Entre ±999999999.0000 Valor por defecto: 0."@es ;
    ns1:valor "0" .

ns1:Tabla_TDATA2 a ns1:Tabla ;
    rdfs:label "Tabla TDATA2: Posición del eje rotativo (tipo 43)"@es ;
    ns1:identificador "TDATA2" ;
    ns1:textoExtracto "TDATA2 Posición del eje rotativo. Valores posibles: Entre ±999999999.0000 Valor por defecto: 0. Indica la posición del eje rotativo según el eje de la herramienta."@es .

