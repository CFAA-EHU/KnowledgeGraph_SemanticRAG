@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CinematicaEjeC a ns1:Sistema ;
    rdfs:label "Cinemática del eje C (tipo 43)"@es ;
    ns1:identificador "TYPE=43" ;
    ns1:textoExtracto "TYPE=43 Z Z X Y Z C [...] Definición de las cinemáticas del eje –C– (tipo 43)."@es ;
    ns1:tieneComponente ns1:Parametro_TDATA10,
        ns1:Parametro_TDATA4 .

ns1:Parametro_TDATA10 a ns1:Parametro ;
    rdfs:label "Sentido de giro del eje giratorio (TDATA10)"@es ;
    ns1:identificador "TDATA10" ;
    ns1:textoExtracto "TDATA10 Sentido de giro del eje giratorio. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0."@es ;
    ns1:valor "0" .

ns1:Parametro_TDATA4 a ns1:Parametro ;
    rdfs:label "Offset angular para el eje rotativo (TDATA4)"@es ;
    ns1:identificador "TDATA4" ;
    ns1:textoExtracto "TDATA4 Offset angular para el eje rotativo. Valores posibles: Entre ±999999999.0000º. Valor por defecto: 0."@es ;
    ns1:valor "0" .

