@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CinematicaCabezalTipo50 a ns1:Sistema ;
    rdfs:label "Cinemática de cabezal tipo 50" ;
    ns1:textoExtracto "Esta cinemática permite controlar cualquier tipo de cabezal que tenga como máximo dos ejes rotativos. [...] Definición vectorial de la cinemáticas." ;
    ns1:tieneComponente ns1:EjeRotativo1,
        ns1:EjeRotativo2,
        ns1:Portaherramientas .

ns1:EjeRotativo1 a ns1:ComponenteMecanico ;
    rdfs:label "Primer eje rotativo" ;
    ns1:textoExtracto "V1: Vector dirección del primer eje rotativo. T1: Vector traslación del primer eje rotativo." ;
    ns1:tieneComponente ns1:VectorDireccion1,
        ns1:VectorTraslacion1 .

ns1:EjeRotativo2 a ns1:ComponenteMecanico ;
    rdfs:label "Segundo eje rotativo" ;
    ns1:textoExtracto "V2: Vector dirección del segundo eje rotativo. T2: Vector traslación del segundo eje rotativo." ;
    ns1:tieneComponente ns1:VectorDireccion2,
        ns1:VectorTraslacion2 .

ns1:Portaherramientas a ns1:ComponenteMecanico ;
    rdfs:label "Portaherramientas" ;
    ns1:textoExtracto "T3: Vector traslación del portaherramientas. V3: Vector dirección del portaherramientas." ;
    ns1:tieneComponente ns1:VectorDireccion3,
        ns1:VectorTraslacion3 .

ns1:VectorDireccion1 a ns1:Parametro ;
    rdfs:label "Vector dirección del primer eje rotativo (V1)" ;
    ns1:textoExtracto "V1: Vector dirección del primer eje rotativo." ;
    ns1:valor "V1" .

ns1:VectorDireccion2 a ns1:Parametro ;
    rdfs:label "Vector dirección del segundo eje rotativo (V2)" ;
    ns1:textoExtracto "V2: Vector dirección del segundo eje rotativo." ;
    ns1:valor "V2" .

ns1:VectorDireccion3 a ns1:Parametro ;
    rdfs:label "Vector dirección del portaherramientas (V3)" ;
    ns1:textoExtracto "V3: Vector dirección del portaherramientas." ;
    ns1:valor "V3" .

ns1:VectorTraslacion1 a ns1:Parametro ;
    rdfs:label "Vector traslación del primer eje rotativo (T1)" ;
    ns1:textoExtracto "T1: Vector traslación del primer eje rotativo." ;
    ns1:valor "T1" .

ns1:VectorTraslacion2 a ns1:Parametro ;
    rdfs:label "Vector traslación del segundo eje rotativo (T2)" ;
    ns1:textoExtracto "T2: Vector traslación del segundo eje rotativo." ;
    ns1:valor "T2" .

ns1:VectorTraslacion3 a ns1:Parametro ;
    rdfs:label "Vector traslación del portaherramientas (T3)" ;
    ns1:textoExtracto "T3: Vector traslación del portaherramientas." ;
    ns1:valor "T3" .

