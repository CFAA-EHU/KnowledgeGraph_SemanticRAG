@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCinematicoCabezalTipo50 a ns1:Sistema ;
    rdfs:label "Sistema de cinemática vectorial de cabezal (tipo 50)" ;
    ns1:textoExtracto "Definición vectorial de cinemáticas de cabezal (tipo 50). T2: Vector traslación del segundo eje rotativo. T3: Vector traslación del portaherramientas. V1: Vector dirección del primer eje rotativo. V2: Vector dirección del segundo eje rotativo. V3: Vector dirección del portaherramientas." ;
    ns1:tieneComponente ns1:EjeRotativo1,
        ns1:EjeRotativo2,
        ns1:PortaHerramientas .

ns1:EjeRotativo1 a ns1:ComponenteMecanico ;
    rdfs:label "Primer eje rotativo (V1)" ;
    ns1:textoExtracto "V1: Vector dirección del primer eje rotativo." ;
    ns1:tieneComponente ns1:VectorDireccionV1,
        ns1:VectorTraslacionT1 .

ns1:EjeRotativo2 a ns1:ComponenteMecanico ;
    rdfs:label "Segundo eje rotativo (V2)" ;
    ns1:textoExtracto "V2: Vector dirección del segundo eje rotativo. T2: Vector traslación del segundo eje rotativo." ;
    ns1:tieneComponente ns1:VectorDireccionV2,
        ns1:VectorTraslacionT2 .

ns1:PortaHerramientas a ns1:ComponenteMecanico ;
    rdfs:label "Porta-herramientas (V3)" ;
    ns1:textoExtracto "T3: Vector traslación del portaherramientas. V3: Vector dirección del portaherramientas." ;
    ns1:tieneComponente ns1:VectorDireccionV3,
        ns1:VectorTraslacionT3 .

ns1:VectorDireccionV1 a ns1:Parametro ;
    rdfs:label "Vector dirección V1 (TDATA4, TDATA5, TDATA6)" ;
    ns1:textoExtracto "V1 (TDATA4, TDATA5, TDATA6)" ;
    ns1:valor "TDATA4,TDATA5,TDATA6" .

ns1:VectorDireccionV2 a ns1:Parametro ;
    rdfs:label "Vector dirección V2 (TDATA14, TDATA15, TDATA16)" ;
    ns1:textoExtracto "V2 (TDATA14, TDATA15, TDATA16)" ;
    ns1:valor "TDATA14,TDATA15,TDATA16" .

ns1:VectorDireccionV3 a ns1:Parametro ;
    rdfs:label "Vector dirección V3 (TDATA24, TDATA25, TDATA26)" ;
    ns1:textoExtracto "V3 (TDATA24, TDATA25, TDATA26)" ;
    ns1:valor "TDATA24,TDATA25,TDATA26" .

ns1:VectorTraslacionT1 a ns1:Parametro ;
    rdfs:label "Vector traslación T1 (TDATA1, TDATA2, TDATA3)" ;
    ns1:textoExtracto "T1 (TDATA1, TDATA2, TDATA3)" ;
    ns1:valor "TDATA1,TDATA2,TDATA3" .

ns1:VectorTraslacionT2 a ns1:Parametro ;
    rdfs:label "Vector traslación T2 (TDATA11, TDATA12, TDATA13)" ;
    ns1:textoExtracto "T2 (TDATA11, TDATA12, TDATA13)" ;
    ns1:valor "TDATA11,TDATA12,TDATA13" .

ns1:VectorTraslacionT3 a ns1:Parametro ;
    rdfs:label "Vector traslación T3 (TDATA21, TDATA22, TDATA23)" ;
    ns1:textoExtracto "T3 (TDATA21, TDATA22, TDATA23)" ;
    ns1:valor "TDATA21,TDATA22,TDATA23" .

