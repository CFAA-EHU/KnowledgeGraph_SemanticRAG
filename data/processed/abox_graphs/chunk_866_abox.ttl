@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Sistema_CinematicaCabezalTipo50 a ns1:Sistema ;
    rdfs:label "Sistema de cinemática del cabezal (tipo 50)" ;
    ns1:cumpleNormativa ns1:Directiva_DIN66217 ;
    ns1:monitoreaParametro ns1:Parametro_TDATA1,
        ns1:Parametro_TDATA2,
        ns1:Parametro_TDATA3,
        ns1:Parametro_TDATA4,
        ns1:Parametro_TDATA5,
        ns1:Parametro_TDATA6,
        ns1:Parametro_TDATA7,
        ns1:Parametro_TDATA8,
        ns1:Parametro_TDATA9 ;
    ns1:textoExtracto "Definición vectorial de cinemáticas de cabezal (tipo 50)." ;
    ns1:tieneComponente ns1:Parametro_TDATA1,
        ns1:Parametro_TDATA2,
        ns1:Parametro_TDATA3,
        ns1:Parametro_TDATA4,
        ns1:Parametro_TDATA5,
        ns1:Parametro_TDATA6,
        ns1:Parametro_TDATA7,
        ns1:Parametro_TDATA8,
        ns1:Parametro_TDATA9 .

ns1:Directiva_DIN66217 a ns1:Directiva ;
    rdfs:label "DIN 66217 (Norma de dirección de ejes y sentido de giro)" ;
    ns1:identificador "DIN 66217" ;
    ns1:textoExtracto "La dirección de los ejes X Y Z, según la norma DIN 66217, se puede recordar fácilmente utilizando la regla de la mano derecha." .

ns1:Parametro_TDATA1 a ns1:Parametro ;
    rdfs:label "TDATA1 (Componente X del vector traslación del eje rotativo principal)" ;
    ns1:identificador "TDATA1" ;
    ns1:textoExtracto "TDATA1 Distancia del eje rotativo principal al punto de referencia máquina (eje X)." ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA2 a ns1:Parametro ;
    rdfs:label "TDATA2 (Componente Y del vector traslación del eje rotativo principal)" ;
    ns1:identificador "TDATA2" ;
    ns1:textoExtracto "TDATA2 Distancia del eje rotativo principal al punto de referencia máquina (eje Y)." ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA3 a ns1:Parametro ;
    rdfs:label "TDATA3 (Componente Z del vector traslación del eje rotativo principal)" ;
    ns1:identificador "TDATA3" ;
    ns1:textoExtracto "TDATA3 Distancia del eje rotativo principal al punto de referencia máquina (eje Z)." ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA4 a ns1:Parametro ;
    rdfs:label "TDATA4 (Componente X del vector dirección del eje rotativo principal)" ;
    ns1:identificador "TDATA4" ;
    ns1:textoExtracto "TDATA4 Componente del vector dirección del eje rotativo principal (eje X)." .

ns1:Parametro_TDATA5 a ns1:Parametro ;
    rdfs:label "TDATA5 (Componente Y del vector dirección del eje rotativo principal)" ;
    ns1:identificador "TDATA5" ;
    ns1:textoExtracto "TDATA5 Componente del vector dirección del eje rotativo principal (eje Y)." .

ns1:Parametro_TDATA6 a ns1:Parametro ;
    rdfs:label "TDATA6 (Componente Z del vector dirección del eje rotativo principal)" ;
    ns1:identificador "TDATA6" ;
    ns1:textoExtracto "TDATA6 Componente del vector dirección del eje rotativo principal (eje Z)." .

ns1:Parametro_TDATA7 a ns1:Parametro ;
    rdfs:label "TDATA7 (Posición de reposo del eje rotativo principal)" ;
    ns1:identificador "TDATA7" ;
    ns1:textoExtracto "TDATA7 Posición de reposo del eje rotativo principal. [...] cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal)." ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA8 a ns1:Parametro ;
    rdfs:label "TDATA8 (Sentido de giro del eje rotativo principal)" ;
    ns1:identificador "TDATA8" ;
    ns1:textoExtracto "TDATA8 Sentido de giro del eje rotativo principal. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217)." ;
    ns1:valor 0 .

ns1:Parametro_TDATA9 a ns1:Parametro ;
    rdfs:label "TDATA9 (Modo de control del eje rotativo principal)" ;
    ns1:identificador "TDATA9" ;
    ns1:textoExtracto "TDATA9 Eje rotativo principal manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual)." ;
    ns1:valor 0 .

