ns1:Parametro_TDATA9 a ns1:Parametro ;
    rdfs:label "TDATA9" ;
    ns1:identificador "TDATA9" ;
    ns1:textoExtracto "TDATA9 Eje rotativo principal manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0. Este parámetro indica si el eje rotativo es manual o servocontrolado." ;
