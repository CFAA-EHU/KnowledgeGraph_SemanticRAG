@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Sistema_CinematicaCabezal a ns1:Sistema ;
    rdfs:label "Cinemática de cabezal (tipo 50)" ;
    ns1:monitoreaParametro ns1:Parametro_TDATA21,
        ns1:Parametro_TDATA22,
        ns1:Parametro_TDATA23,
        ns1:Parametro_TDATA24 ;
    ns1:textoExtracto "Definición vectorial de cinemáticas de cabezal (tipo 50)." ;
    ns1:tieneComponente ns1:Herramienta_Portaherramientas .

ns1:Herramienta_Portaherramientas a ns1:Herramienta ;
    rdfs:label "Portaherramientas" ;
    ns1:textoExtracto "Este vector traslación indica la distancia desde la base del portaherramientas al punto de referencia del eje rotativo secundario." .

ns1:Parametro_TDATA21 a ns1:Parametro ;
    rdfs:label "TDATA21" ;
    ns1:identificador "TDATA21" ;
    ns1:textoExtracto "TDATA21 Distancia de la base de la herramienta al eje rotativo secundario (eje X)." ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA22 a ns1:Parametro ;
    rdfs:label "TDATA22" ;
    ns1:identificador "TDATA22" ;
    ns1:textoExtracto "TDATA22 Distancia de la base de la herramienta al eje rotativo secundario (eje Y)." ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA23 a ns1:Parametro ;
    rdfs:label "TDATA23" ;
    ns1:identificador "TDATA23" ;
    ns1:textoExtracto "TDATA23 Distancia de la base de la herramienta al eje rotativo secundario (eje Z)." ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA24 a ns1:Parametro ;
    rdfs:label "TDATA24" ;
    ns1:identificador "TDATA24" ;
    ns1:textoExtracto "TDATA24 Componente del vector dirección del portaherramientas." ;
    ns1:valor 0.0 .

