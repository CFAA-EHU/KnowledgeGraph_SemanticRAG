@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_TDATA23 a ns1:Parametro ;
    rdfs:label "TDATA23" ;
    ns1:identificador "TDATA23" ;
    ns1:monitoreaParametro ns1:Herramienta_Portaherramientas ;
    ns1:textoExtracto "Distancia de la base de la herramienta al eje rotativo secundario (eje Z)." .

ns1:Parametro_TDATA24 a ns1:Parametro ;
    rdfs:label "TDATA24" ;
    ns1:identificador "TDATA24" ;
    ns1:monitoreaParametro ns1:Herramienta_Portaherramientas ;
    ns1:textoExtracto "Componente del vector dirección del portaherramientas (eje X)." .

ns1:Parametro_TDATA25 a ns1:Parametro ;
    rdfs:label "TDATA25" ;
    ns1:identificador "TDATA25" ;
    ns1:monitoreaParametro ns1:Herramienta_Portaherramientas ;
    ns1:textoExtracto "Componente del vector dirección del portaherramientas (eje Y)." .

ns1:Parametro_TDATA26 a ns1:Parametro ;
    rdfs:label "TDATA26" ;
    ns1:identificador "TDATA26" ;
    ns1:monitoreaParametro ns1:Herramienta_Portaherramientas ;
    ns1:textoExtracto "Componente del vector dirección del portaherramientas (eje Z)." .

ns1:Herramienta_Portaherramientas a ns1:Herramienta ;
