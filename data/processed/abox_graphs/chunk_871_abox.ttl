@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CinematicaTipo51 a ns1:Sistema ;
    rdfs:label "Cinemática de mesa tipo 51"@es ;
    ns1:compuestoPor ns1:EjeRotativo1,
        ns1:EjeRotativo2 ;
    ns1:identificador "Tipo 51" ;
    ns1:textoExtracto "Esta cinemática permite controlar cualquier tipo de mesa que tenga como máximo dos ejes rotativos. Definición vectorial de la cinemáticas. Este tipo de cinemáticas permite definir los ejes rotativos que la componen mediante vectores."@es .

ns1:EjeRotativo1 a ns1:ComponenteMecanico ;
    rdfs:label "Primer eje rotativo (Tipo 51)"@es ;
    ns1:monitoreaParametro ns1:ParametroVectorT1,
        ns1:ParametroVectorV1 ;
    ns1:textoExtracto "Cada uno de los ejes rotativos de la cinemática se define mediante un vector traslación (posición del eje) y un vector dirección (dirección del eje). V1 T1: Vector traslación del primer eje rotativo. V1: Vector dirección del primer eje rotativo."@es .

ns1:EjeRotativo2 a ns1:ComponenteMecanico ;
    rdfs:label "Segundo eje rotativo (Tipo 51)"@es ;
    ns1:monitoreaParametro ns1:ParametroVectorT2,
        ns1:ParametroVectorV2 ;
    ns1:textoExtracto "T2: Vector traslación del segundo eje rotativo. V2: Vector dirección del segundo eje rotativo."@es .

ns1:ParametroVectorT1 a ns1:Parametro ;
    rdfs:label "Vector traslación T1 (TDATA1, TDATA2, TDATA3)"@es ;
    ns1:textoExtracto "T1 (TDATA1, TDATA2, TDATA3)"@es ;
    ns1:valor "(TDATA1, TDATA2, TDATA3)" .

ns1:ParametroVectorT2 a ns1:Parametro ;
    rdfs:label "Vector traslación T2 (TDATA11, TDATA12, TDATA13)"@es ;
    ns1:textoExtracto "T2 (TDATA11, TDATA12, TDATA13)"@es ;
    ns1:valor "(TDATA11, TDATA12, TDATA13)" .

ns1:ParametroVectorV1 a ns1:Parametro ;
    rdfs:label "Vector dirección V1 (TDATA4, TDATA5, TDATA6)"@es ;
    ns1:textoExtracto "V1 (TDATA4, TDATA5, TDATA6)"@es ;
    ns1:valor "(TDATA4, TDATA5, TDATA6)" .

ns1:ParametroVectorV2 a ns1:Parametro ;
    rdfs:label "Vector dirección V2 (TDATA14, TDATA15, TDATA16)"@es ;
    ns1:textoExtracto "V2 (TDATA14, TDATA15, TDATA16)"@es ;
    ns1:valor "(TDATA14, TDATA15, TDATA16)" .

