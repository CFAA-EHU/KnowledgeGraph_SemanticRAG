@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Sistema_CinematicaMesaTipo51 a ns1:Sistema ;
    rdfs:label "Cinemática de mesa (tipo 51)" ;
    ns1:textoExtracto "Definición vectorial de cinemáticas de mesa (tipo 51)." ;
    ns1:tieneComponente ns1:Parametro_TDATA1,
        ns1:Parametro_TDATA2,
        ns1:Parametro_TDATA3,
        ns1:Parametro_TDATA7,
        ns1:Parametro_TDATA8,
        ns1:Parametro_TDATA9 .

ns1:Parametro_TDATA1 a ns1:Parametro ;
    rdfs:label "TDATA1 (Distancia eje X)" ;
    ns1:identificador "TDATA1" ;
    ns1:textoExtracto "TDATA1 Distancia del eje rotativo principal al punto de referencia máquina (eje X)." ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA2 a ns1:Parametro ;
    rdfs:label "TDATA2 (Distancia eje Y)" ;
    ns1:identificador "TDATA2" ;
    ns1:textoExtracto "TDATA2 Distancia del eje rotativo principal al punto de referencia máquina (eje Y)." ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA3 a ns1:Parametro ;
    rdfs:label "TDATA3 (Distancia eje Z)" ;
    ns1:identificador "TDATA3" ;
    ns1:textoExtracto "TDATA3 Distancia del eje rotativo principal al punto de referencia máquina (eje Z)." ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA7 a ns1:Parametro ;
    rdfs:label "TDATA7 (Posición de reposo)" ;
    ns1:identificador "TDATA7" ;
    ns1:textoExtracto "TDATA7 Posición de reposo del eje rotativo principal. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0." ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA8 a ns1:Parametro ;
    rdfs:label "TDATA8 (Sentido de giro)" ;
    ns1:identificador "TDATA8" ;
    ns1:textoExtracto "TDATA8 Sentido de giro del eje rotativo principal. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." ;
    ns1:valor 0 .

ns1:Parametro_TDATA9 a ns1:Parametro ;
    rdfs:label "TDATA9 (Modo de control)" ;
    ns1:identificador "TDATA9" ;
    ns1:textoExtracto "TDATA9 Eje rotativo principal manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0." ;
    ns1:valor 0 .

