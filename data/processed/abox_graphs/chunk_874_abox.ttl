@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC_51 a ns1:Maquina ;
    rdfs:label "Máquina CNC (tipo 51)"@es ;
    ns1:monitoreaParametro ns1:Parametro_RTCP_TDATA10 ;
    ns1:textoExtracto "cinemáticas de mesa (tipo 51)"@es .

ns1:Parametro_RTCP_TDATA10 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA10 (RTCP)"@es ;
    ns1:identificador "TDATA10" ;
    ns1:textoExtracto "Origen para aplicar el RTCP. Valores posibles: 0 (cero máquina) / 1 (cero pieza). Valor por defecto: 0. Este parámetro indica si el CNC aplica el RTCP respecto el cero máquina o el cero pieza."@es ;
    ns1:valor "0" .

