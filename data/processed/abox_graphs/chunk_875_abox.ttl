@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Sistema_CinematicaMesaTipo51 a ns1:Sistema ;
    rdfs:label "Sistema de cinemática de mesa (tipo 51)" ;
    ns1:textoExtracto "Definición vectorial de cinemáticas de mesa (tipo 51)." ;
    ns1:tieneComponente ns1:Parametro_TDATA11,
        ns1:Parametro_TDATA12,
        ns1:Parametro_TDATA13,
        ns1:Parametro_TDATA14,
        ns1:Parametro_TDATA15,
        ns1:Parametro_TDATA16,
        ns1:Parametro_TDATA17,
        ns1:Parametro_TDATA18,
        ns1:Parametro_TDATA19,
        ns1:Parametro_TDATA20 .

ns1:Parametro_TDATA11 a ns1:Parametro ;
    rdfs:label "TDATA11: Distancia del eje rotativo secundario al principal (eje X)" ;
    ns1:identificador "TDATA11" ;
    ns1:textoExtracto "TDATA11 Distancia del eje rotativo secundario al principal (eje X). Valores posibles: De 0 a 99999.9999 mm / de 0 a 3937.00787 inch. Valor por defecto: 0." ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA12 a ns1:Parametro ;
    rdfs:label "TDATA12: Distancia del eje rotativo secundario al principal (eje Y)" ;
    ns1:identificador "TDATA12" ;
    ns1:textoExtracto "TDATA12 Distancia del eje rotativo secundario al principal (eje Y)." ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA13 a ns1:Parametro ;
    rdfs:label "TDATA13: Distancia del eje rotativo secundario al principal (eje Z)" ;
    ns1:identificador "TDATA13" ;
    ns1:textoExtracto "TDATA13 Distancia del eje rotativo secundario al principal (eje Z)." ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA14 a ns1:Parametro ;
    rdfs:label "TDATA14: Componente X del vector dirección del eje rotativo secundario" ;
    ns1:identificador "TDATA14" ;
    ns1:textoExtracto "TDATA14 Componente del vector dirección del eje rotativo secundario (eje X)." .

ns1:Parametro_TDATA15 a ns1:Parametro ;
    rdfs:label "TDATA15: Componente Y del vector dirección del eje rotativo secundario" ;
    ns1:identificador "TDATA15" ;
    ns1:textoExtracto "TDATA15 Componente del vector dirección del eje rotativo secundario (eje Y)." .

ns1:Parametro_TDATA16 a ns1:Parametro ;
    rdfs:label "TDATA16: Componente Z del vector dirección del eje rotativo secundario" ;
    ns1:identificador "TDATA16" ;
    ns1:textoExtracto "TDATA16 Componente del vector dirección del eje rotativo secundario (eje Z)." .

ns1:Parametro_TDATA17 a ns1:Parametro ;
    rdfs:label "TDATA17: Posición de reposo del eje rotativo secundario" ;
    ns1:identificador "TDATA17" ;
    ns1:textoExtracto "TDATA17 Posición de reposo del eje rotativo secundario. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0. Se denomina posición de reposo a la posición en la que se han definido los vectores dirección de los ejes rotativos de la cinemática." ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA18 a ns1:Parametro ;
    rdfs:label "TDATA18: Sentido de giro del eje rotativo secundario" ;
    ns1:identificador "TDATA18" ;
    ns1:textoExtracto "TDATA18 Sentido de giro del eje rotativo secundario. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." ;
    ns1:valor 0 .

ns1:Parametro_TDATA19 a ns1:Parametro ;
    rdfs:label "TDATA19: Modo de control del eje rotativo secundario" ;
    ns1:identificador "TDATA19" ;
    ns1:textoExtracto "TDATA19 Eje rotativo secundario manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0. Este parámetro indica si el eje rotativo es manual o servocontrolado." ;
    ns1:valor 0 .

ns1:Parametro_TDATA20 a ns1:Parametro ;
    rdfs:label "TDATA20: Origen para aplicar el RTCP" ;
    ns1:identificador "TDATA20" ;
    ns1:textoExtracto "TDATA20 Origen para aplicar el RTCP." .

