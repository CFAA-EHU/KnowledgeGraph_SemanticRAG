@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_Tipo51 a ns1:Maquina ;
    rdfs:label "Máquina tipo 51 (cinemática de mesa)" ;
    ns1:textoExtracto "Definición vectorial de cinemáticas de mesa (tipo 51)" ;
    ns1:tieneComponente ns1:Sistema_CoordenadasMaquina,
        ns1:Sistema_CoordenadasPieza .

ns1:ModoOperacion_RTCP a ns1:ModoOperacion ;
    rdfs:label "RTCP" ;
    ns1:textoExtracto "modo RTCP activo" .

ns1:Parametro_TDATA19 a ns1:Parametro ;
    rdfs:label "TDATA19" ;
    ns1:identificador "TDATA19" ;
    ns1:textoExtracto "TDATA19 Eje rotativo secundario manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0. Este parámetro indica si el eje rotativo es manual o servocontrolado." ;
    ns1:valor "0" .

ns1:Parametro_TDATA20 a ns1:Parametro ;
    rdfs:label "TDATA20" ;
    ns1:identificador "TDATA20" ;
    ns1:textoExtracto "TDATA20 Origen para aplicar el RTCP. Valores posibles: 0 (cero máquina) / 1 (cero pieza). Valor por defecto: 0. Consultar el parámetro TDATA10." ;
    ns1:valor "0" .

ns1:Parametro_TDATA31 a ns1:Parametro ;
    rdfs:label "TDATA31" ;
    ns1:identificador "TDATA31" ;
    ns1:textoExtracto "TDATA31 Girar el sistema de coordenadas pieza al girar la mesa. Valores posibles: 0 (sí) / 1 (no). Valor por defecto: 0. Con el modo RTCP activo, este parámetro establece si el sistema de coordenadas pieza está fijo sobre la pieza y gira con ella o si por el contrario se mantiene paralelo al sistema de coordenadas" ;
    ns1:valor "0" .

ns1:Sistema_CoordenadasMaquina a ns1:Sistema ;
    rdfs:label "Sistema de coordenadas máquina" ;
    ns1:textoExtracto "cero máquina" .

ns1:Sistema_CoordenadasPieza a ns1:Sistema ;
    rdfs:label "Sistema de coordenadas pieza" ;
    ns1:controla ns1:Parametro_TDATA31 ;
    ns1:textoExtracto "sistema de coordenadas pieza" .

