@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Herramienta_MesaTipo51 a ns1:Herramienta ;
    rdfs:label "Herramienta de mesa (tipo 51)"@es ;
    ns1:documentadoEn ns1:Tabla_TDATA31_DefinicionVectorial ;
    ns1:textoExtracto "punta de la herramienta sobre la pieza"@es .

ns1:Maquina_Tipo51 a ns1:Maquina ;
    rdfs:label "Máquina con cinemática de mesa (tipo 51)"@es ;
    ns1:documentadoEn ns1:Tabla_TDATA31_DefinicionVectorial ;
    ns1:identificador "Tipo 51" ;
    ns1:textoExtracto "Definición vectorial de cinemáticas de mesa (tipo 51)"@es ;
    ns1:tieneComponente ns1:SistemaCoordenadasMaquina .

ns1:Parametro_TDATA31 a ns1:Parametro ;
    rdfs:label "TDATA31" ;
    ns1:identificador "TDATA31" ;
    ns1:textoExtracto "TDATA31 | Significado." ;
    ns1:valor "0, 1"@es .

ns1:Parametro_TDATA31_Valor0 a ns1:Parametro ;
    rdfs:label "TDATA31 = 0" ;
    ns1:detalladoEnEsquema ns1:Tabla_TDATA31_DefinicionVectorial ;
    ns1:identificador "TDATA31=0" ;
    ns1:textoExtracto "Al variar la orientación de la pieza, no se modifica la posición que ocupa la punta de la herramienta sobre la pieza. El sistema de coordenadas está fijo sobre la pieza y gira con ella."@es ;
    ns1:valor "0" .

ns1:Parametro_TDATA31_Valor1 a ns1:Parametro ;
    rdfs:label "TDATA31 = 1" ;
    ns1:detalladoEnEsquema ns1:Tabla_TDATA31_DefinicionVectorial ;
    ns1:identificador "TDATA31=1" ;
    ns1:textoExtracto "Al variar la orientación de la pieza, no se modifica la posición que ocupa el punto definido como cero pieza. El sistema de coordenadas se mantiene paralelo al sistema de coordenadas máquina."@es ;
    ns1:valor "1" .

ns1:SistemaCoordenadasPieza a ns1:Sistema ;
    rdfs:label "Sistema de coordenadas de pieza"@es ;
    ns1:documentadoEn ns1:Tabla_TDATA31_DefinicionVectorial ;
    ns1:textoExtracto "El sistema de coordenadas está fijo sobre la pieza y gira con ella."@es .

ns1:SistemaCoordenadasMaquina a ns1:Sistema ;
    rdfs:label "Sistema de coordenadas máquina"@es ;
    ns1:documentadoEn ns1:Tabla_TDATA31_DefinicionVectorial ;
    ns1:textoExtracto "El sistema de coordenadas se mantiene paralelo al sistema de coordenadas máquina."@es .

ns1:Tabla_TDATA31_DefinicionVectorial a ns1:Tabla ;
    rdfs:label "Definición vectorial de cinemáticas de mesa (tipo 51)"@es ;
    ns1:documentadoEn ns1:Manual_Broaching ;
    ns1:textoExtracto "| TDATA31 | Significado. | --- | --- | 0 | Al variar la orientación de la pieza, no se modifica la posición que ocupa la punta de la herramienta sobre la pieza. El sistema de coordenadas está fijo sobre la pieza y gira con ella. | 1 | Al variar la orientación de la pieza, no se modifica la posición que ocupa el punto definido como cero pieza. El sistema de coordenadas se mantiene paralelo al sistema de coordenadas máquina." .

