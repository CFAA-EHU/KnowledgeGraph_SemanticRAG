@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ParametroVectorialTipo52 a ns1:Parametro ;
    rdfs:label "Definición vectorial de cinemática tipo 52"@es ;
    ns1:documentadoEn ns1:CinematicaTipo52 ;
    ns1:textoExtracto "Este tipo de cinemáticas permite definir los ejes rotativos que la componen mediante vectores. Cada uno de los ejes rotativos de la cinemática se define mediante un vector traslación (posición del eje) y un vector dirección (dirección del eje)."@es .

ns1:CabezalTipo52 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal (cinemática tipo 52)"@es ;
    ns1:textoExtracto "Cabezal: T1: Vector traslación del primer eje rotativo. T2: Vector traslación del segundo eje rotativo. T3: Vector traslación del portaherramientas."@es ;
    ns1:tieneComponente ns1:EjeRotativo1,
        ns1:EjeRotativo2,
        ns1:PortaherramientasTipo52 .

ns1:CinematicaTipo52 a ns1:Sistema ;
    rdfs:label "Cinemática cabezal-mesa (tipo 52)"@es ;
    ns1:compuestoPor ns1:CabezalTipo52,
        ns1:MesaTipo52 ;
    ns1:textoExtracto "Esta cinemática permite controlar cualquier tipo de cinemática compuesta por un cabezal y una mesa, que tenga como máximo dos ejes rotativos en el cabezal y otros dos en la mesa."@es ;
    ns1:tieneComponente ns1:EjeRotativo1,
        ns1:EjeRotativo2,
        ns1:EjeRotativo3,
        ns1:EjeRotativo4,
        ns1:PortaherramientasTipo52 .

ns1:MesaTipo52 a ns1:ComponenteMecanico ;
    rdfs:label "Mesa (cinemática tipo 52)"@es ;
    ns1:textoExtracto "Mesa: T4: Vector traslación del tercer eje rotativo. T5: Vector traslación del cuarto eje rotativo."@es ;
    ns1:tieneComponente ns1:EjeRotativo3,
        ns1:EjeRotativo4 .

ns1:EjeRotativo1 a ns1:ComponenteMecanico ;
    rdfs:label "Primer eje rotativo (cinemática tipo 52)"@es ;
    ns1:identificador "Eje1_Tipo52" ;
    ns1:textoExtracto "T1: Vector traslación del primer eje rotativo. V1: Vector dirección del primer eje rotativo."@es .

ns1:EjeRotativo2 a ns1:ComponenteMecanico ;
    rdfs:label "Segundo eje rotativo (cinemática tipo 52)"@es ;
    ns1:identificador "Eje2_Tipo52" ;
    ns1:textoExtracto "T2: Vector traslación del segundo eje rotativo. V2: Vector dirección del segundo eje rotativo."@es .

ns1:EjeRotativo3 a ns1:ComponenteMecanico ;
    rdfs:label "Tercer eje rotativo (cinemática tipo 52)"@es ;
    ns1:identificador "Eje3_Tipo52" ;
    ns1:textoExtracto "T4: Vector traslación del tercer eje rotativo. V4: Vector dirección del tercer eje rotativo."@es .

ns1:EjeRotativo4 a ns1:ComponenteMecanico ;
    rdfs:label "Cuarto eje rotativo (cinemática tipo 52)"@es ;
    ns1:identificador "Eje4_Tipo52" ;
    ns1:textoExtracto "T5: Vector traslación del cuarto eje rotativo. V5: Vector dirección del cuarto eje rotativo."@es .

ns1:PortaherramientasTipo52 a ns1:ComponenteMecanico ;
    rdfs:label "Portaherramientas (cinemática tipo 52)"@es ;
    ns1:identificador "Portaherramientas_Tipo52" ;
    ns1:textoExtracto "T3: Vector traslación del portaherramientas. V3: Vector dirección del portaherramientas."@es .

