@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CinematicaTipo52 a ns1:Sistema ;
    rdfs:label "Cinemática cabezal–mesa (tipo 52)"@es ;
    ns1:identificador "Tipo_52" ;
    ns1:textoExtracto "Definición vectorial de cinemáticas de cabezal–mesa (tipo 52)."@es ;
    ns1:tieneComponente ns1:Parametro_T1,
        ns1:Parametro_T2,
        ns1:Parametro_T3,
        ns1:Parametro_T5,
        ns1:Parametro_V1,
        ns1:Parametro_V2,
        ns1:Parametro_V3,
        ns1:Parametro_V5,
        ns1:Parametro_VG_POSROTn .

ns1:Parametro_T1 a ns1:Parametro ;
    rdfs:label "Vector traslación del primer eje (T1)"@es ;
    ns1:identificador "T1" ;
    ns1:textoExtracto "T1 (TDATA1, TDATA2, TDATA3)"@es ;
    ns1:valor "TDATA1, TDATA2, TDATA3" .

ns1:Parametro_T2 a ns1:Parametro ;
    rdfs:label "Vector traslación del segundo eje (T2)"@es ;
    ns1:identificador "T2" ;
    ns1:textoExtracto "T2 (TDATA11, TDATA12, TDATA13)"@es ;
    ns1:valor "TDATA11, TDATA12, TDATA13" .

ns1:Parametro_T3 a ns1:Parametro ;
    rdfs:label "Vector traslación del tercer eje (T3)"@es ;
    ns1:identificador "T3" ;
    ns1:textoExtracto "T3 (TDATA21, TDATA22, TDATA23)"@es ;
    ns1:valor "TDATA21, TDATA22, TDATA23" .

ns1:Parametro_T5 a ns1:Parametro ;
    rdfs:label "Definición de ejes no físicos en cinemática (T5)"@es ;
    ns1:identificador "T5" ;
    ns1:textoExtracto "T5 Definición de los ejes que no están presentes en la cinemática."@es .

ns1:Parametro_V1 a ns1:Parametro ;
    rdfs:label "Vector dirección del primer eje (V1)"@es ;
    ns1:identificador "V1" ;
    ns1:textoExtracto "V1 (TDATA4, TDATA5, TDATA6)"@es ;
    ns1:valor "TDATA4, TDATA5, TDATA6" .

ns1:Parametro_V2 a ns1:Parametro ;
    rdfs:label "Vector dirección del segundo eje (V2)"@es ;
    ns1:identificador "V2" ;
    ns1:textoExtracto "V2 (TDATA14, TDATA15, TDATA16)"@es ;
    ns1:valor "TDATA14, TDATA15, TDATA16" .

ns1:Parametro_V3 a ns1:Parametro ;
    rdfs:label "Vector dirección del tercer eje (V3)"@es ;
    ns1:identificador "V3" ;
    ns1:textoExtracto "V3 (TDATA24, TDATA25, TDATA26)"@es ;
    ns1:valor "TDATA24, TDATA25, TDATA26" .

ns1:Parametro_V5 a ns1:Parametro ;
    rdfs:label "Vector dirección del cuarto eje rotativo (V5)"@es ;
    ns1:identificador "V5" ;
    ns1:textoExtracto "V5: Vector dirección del cuarto eje rotativo."@es .

ns1:Parametro_VG_POSROTn a ns1:Parametro ;
    rdfs:label "Variable de posición rotativa (VG.POSROTn)"@es ;
    ns1:identificador "VG.POSROTn" ;
    ns1:textoExtracto "La variable del componente correspondiente: V.G.POSROTn = 0"@es ;
    ns1:valor "0" .

