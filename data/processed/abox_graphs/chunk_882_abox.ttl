@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ComponenteMecanico_CabezalTipo52 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal tipo 52 (cinemática cabezal–mesa)"@es ;
    ns1:cumpleNormativa ns1:Directiva_DIN66217 ;
    ns1:textoExtracto "Definición vectorial de cinemáticas de cabezal–mesa (tipo 52)."@es ;
    ns1:tieneComponente ns1:Parametro_TDATA33_VectorTraslacionEjeRotativo,
        ns1:Parametro_TDATA46_VectorDireccionEjeRotativo,
        ns1:Parametro_TDATA7_PosicionReposo,
        ns1:Parametro_TDATA8_SentidoGiro .

ns1:Parametro_TDATA1_ComponenteX_Traslacion a ns1:Parametro ;
    rdfs:label "TDATA1: Distancia eje rotativo principal al punto referencia máquina (eje X)"@es ;
    ns1:identificador "TDATA1" ;
    ns1:textoExtracto "TDATA1 Distancia del eje rotativo principal al punto de referencia máquina (eje X)."@es ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA2_ComponenteY_Traslacion a ns1:Parametro ;
    rdfs:label "TDATA2: Distancia eje rotativo principal al punto referencia máquina (eje Y)"@es ;
    ns1:identificador "TDATA2" ;
    ns1:textoExtracto "TDATA2 Distancia del eje rotativo principal al punto de referencia máquina (eje Y)."@es ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA3_ComponenteZ_Traslacion a ns1:Parametro ;
    rdfs:label "TDATA3: Distancia eje rotativo principal al punto referencia máquina (eje Z)"@es ;
    ns1:identificador "TDATA3" ;
    ns1:textoExtracto "TDATA3 Distancia del eje rotativo principal al punto de referencia máquina (eje Z)."@es ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA4_ComponenteX_Direccion a ns1:Parametro ;
    rdfs:label "TDATA4: Componente X del vector dirección del eje rotativo principal"@es ;
    ns1:identificador "TDATA4" ;
    ns1:textoExtracto "TDATA4 Componente del vector dirección del eje rotativo principal (eje X)."@es ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA5_ComponenteY_Direccion a ns1:Parametro ;
    rdfs:label "TDATA5: Componente Y del vector dirección del eje rotativo principal"@es ;
    ns1:identificador "TDATA5" ;
    ns1:textoExtracto "TDATA5 Componente del vector dirección del eje rotativo principal (eje Y)."@es ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA6_ComponenteZ_Direccion a ns1:Parametro ;
    rdfs:label "TDATA6: Componente Z del vector dirección del eje rotativo principal"@es ;
    ns1:identificador "TDATA6" ;
    ns1:textoExtracto "TDATA6 Componente del vector dirección del eje rotativo principal (eje Z)."@es ;
    ns1:valor 1.0 .

ns1:Directiva_DIN66217 a ns1:Directiva ;
    rdfs:label "Norma DIN 66217 (dirección de ejes X Y Z)"@es ;
    ns1:identificador "DIN 66217" ;
    ns1:textoExtracto "La dirección de los ejes X Y Z, según la norma DIN 66217, se puede recordar fácilmente utilizando la regla de la mano derecha."@es .

ns1:Parametro_TDATA33_VectorTraslacionEjeRotativo a ns1:Parametro ;
    rdfs:label "Vector traslación del eje rotativo principal del cabezal (TDATA33)"@es ;
    ns1:identificador "TDATA33" ;
    ns1:textoExtracto "Vector traslación del eje rotativo principal del cabezal. Valores posibles: De 0 a 99999.9999 mm / de 0 a 3937.00787 inch. Valor por defecto: 0. Este vector traslación indica la distancia desde el punto de referencia del eje rotativo principal al punto de referencia máquina."@es ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA46_VectorDireccionEjeRotativo a ns1:Parametro ;
    rdfs:label "Vector dirección del eje rotativo principal del cabezal (TDATA4-TDATA6)"@es ;
    ns1:identificador "TDATA4-6" ;
    ns1:textoExtracto "TDATA 4··TDATA6 Vector dirección del eje rotativo principal del cabezal."@es .

ns1:Parametro_TDATA7_PosicionReposo a ns1:Parametro ;
    rdfs:label "TDATA7: Posición de reposo del eje rotativo principal"@es ;
    ns1:identificador "TDATA7" ;
    ns1:textoExtracto "TDATA7 Posición de reposo del eje rotativo principal del cabezal. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0. Se denomina posición de reposo cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal)."@es ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA8_SentidoGiro a ns1:Parametro ;
    rdfs:label "TDATA8: Sentido de giro del eje rotativo principal"@es ;
    ns1:identificador "TDATA8" ;
    ns1:textoExtracto "TDATA8 Sentido de giro del eje rotativo principal del cabezal. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0."@es ;
    ns1:valor 0 .

