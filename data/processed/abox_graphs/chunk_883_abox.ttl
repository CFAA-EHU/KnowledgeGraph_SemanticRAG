@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Directiva_DIN66217 a ns1:Directiva ;
    rdfs:label "Norma DIN 66217"@es ;
    ns1:identificador "DIN 66217" ;
    ns1:textoExtracto "según la norma DIN 66217"@es .

ns1:Parametro_DireccionEjesXYZ a ns1:Parametro ;
    rdfs:label "Parámetro de dirección de ejes X-Y-Z según DIN 66217"@es ;
    ns1:identificador "DIN_66217_EJES_XYZ" ;
    ns1:textoExtracto "Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0. La dirección de los ejes X Y Z, según la norma DIN 66217, se puede recordar fácilmente utilizando la regla de la mano derecha."@es ;
    ns1:valor "0" .

ns1:Parametro_TDATA9 a ns1:Parametro ;
    rdfs:label "TDATA9 - Eje rotativo principal del cabezal"@es ;
    ns1:identificador "TDATA9" ;
    ns1:textoExtracto "TDATA9 Eje rotativo principal del cabezal manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0."@es ;
    ns1:valor "0" .

