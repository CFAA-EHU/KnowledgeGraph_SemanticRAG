@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Sistema_CinematicaCabezalTipo52 a ns1:Sistema ;
    rdfs:label "Cinemática cabezal–mesa (tipo 52)" ;
    ns1:textoExtracto "Definición vectorial de cinemáticas de cabezal–mesa (tipo 52)." ;
    ns1:tieneComponente ns1:Parametro_TDATA11,
        ns1:Parametro_TDATA12,
        ns1:Parametro_TDATA13,
        ns1:Parametro_TDATA14,
        ns1:Parametro_TDATA15,
        ns1:Parametro_TDATA16,
        ns1:Parametro_TDATA17,
        ns1:Parametro_TDATA18,
        ns1:Parametro_TDATA9 .

ns1:Parametro_TDATA11 a ns1:Parametro ;
    rdfs:label "TDATA11 - Distancia eje rotativo secundario (eje X)" ;
    ns1:identificador "TDATA11" ;
    ns1:textoExtracto "TDATA11 Distancia del eje rotativo secundario al principal (eje X)." ;
    ns1:valor "0.0"^^xsd:float .

ns1:Parametro_TDATA12 a ns1:Parametro ;
    rdfs:label "TDATA12 - Distancia eje rotativo secundario (eje Y)" ;
    ns1:identificador "TDATA12" ;
    ns1:textoExtracto "TDATA12 Distancia del eje rotativo secundario al principal (eje Y)." ;
    ns1:valor "0.0"^^xsd:float .

ns1:Parametro_TDATA13 a ns1:Parametro ;
    rdfs:label "TDATA13 - Distancia eje rotativo secundario (eje Z)" ;
    ns1:identificador "TDATA13" ;
    ns1:textoExtracto "TDATA13 Distancia del eje rotativo secundario al principal (eje Z)." ;
    ns1:valor "0.0"^^xsd:float .

ns1:Parametro_TDATA14 a ns1:Parametro ;
    rdfs:label "TDATA14 - Vector dirección eje rotativo secundario (eje X)" ;
    ns1:identificador "TDATA14" ;
    ns1:textoExtracto "TDATA14 Componente del vector dirección del eje rotativo secundario (eje X)." ;
    ns1:valor "0.0"^^xsd:float .

ns1:Parametro_TDATA15 a ns1:Parametro ;
    rdfs:label "TDATA15 - Vector dirección eje rotativo secundario (eje Y)" ;
    ns1:identificador "TDATA15" ;
    ns1:textoExtracto "TDATA15 Componente del vector dirección del eje rotativo secundario (eje Y)." ;
    ns1:valor "0.0"^^xsd:float .

ns1:Parametro_TDATA16 a ns1:Parametro ;
    rdfs:label "TDATA16 - Vector dirección eje rotativo secundario (eje Z)" ;
    ns1:identificador "TDATA16" ;
    ns1:textoExtracto "TDATA16 Componente del vector dirección del eje rotativo secundario (eje Z)." ;
    ns1:valor "1.0"^^xsd:float .

ns1:Parametro_TDATA17 a ns1:Parametro ;
    rdfs:label "TDATA17 - Posición de reposo eje rotativo secundario" ;
    ns1:identificador "TDATA17" ;
    ns1:textoExtracto "TDATA17 Posición de reposo del eje rotativo secundario del cabezal. Se denomina posición de reposo cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal)." ;
    ns1:valor "0.0"^^xsd:float .

ns1:Parametro_TDATA18 a ns1:Parametro ;
    rdfs:label "TDATA18 - Sentido de giro eje rotativo secundario" ;
    ns1:identificador "TDATA18" ;
    ns1:textoExtracto "TDATA18 Sentido de giro del eje rotativo secundario del cabezal." .

ns1:Parametro_TDATA9 a ns1:Parametro ;
    rdfs:label "TDATA9 - Eje rotativo principal del cabezal (manual/servocontrolado)" ;
    ns1:identificador "TDATA9" ;
    ns1:textoExtracto "TDATA9 Eje rotativo principal del cabezal manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0. Este parámetro indica si el eje rotativo es manual o servocontrolado." ;
    ns1:valor 0 .

