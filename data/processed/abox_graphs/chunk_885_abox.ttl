@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_TDATA17 a ns1:Parametro ;
    rdfs:label "TDATA17 (Posición de reposo del cabezal)"@es ;
    ns1:monitoreaParametro ns1:Sistema_CinematicaCabezal ;
    ns1:textoExtracto "Se denomina posición de reposo cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal). Si el eje no existe en la cinemática, se definirá como TDATA17=0."@es ;
    ns1:valor "0" .

ns1:Parametro_TDATA18 a ns1:Parametro ;
    rdfs:label "TDATA18 (Sentido de giro del eje rotativo secundario)"@es ;
    ns1:monitoreaParametro ns1:Sistema_CinematicaCabezal ;
    ns1:textoExtracto "TDATA18 Sentido de giro del eje rotativo secundario del cabezal. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0."@es ;
    ns1:valor "0" .

ns1:Parametro_TDATA19 a ns1:Parametro ;
    rdfs:label "TDATA19 (Tipo de control del eje rotativo secundario)"@es ;
    ns1:monitoreaParametro ns1:Sistema_CinematicaCabezal ;
    ns1:textoExtracto "TDATA19 Eje rotativo secundario del cabezal manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0."@es ;
    ns1:valor "0" .

ns1:ComponenteMecanico_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal (eje rotativo secundario)"@es ;
    ns1:textoExtracto "eje rotativo secundario del cabezal"@es .

ns1:Sistema_CinematicaCabezal a ns1:Sistema ;
    rdfs:label "Sistema de cinemática cabezal–mesa (tipo 52)"@es ;
    ns1:textoExtracto "Definición vectorial de cinemáticas de cabezal–mesa (tipo 52)."@es ;
    ns1:tieneComponente ns1:ComponenteMecanico_Cabezal .

