@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_TDATA8 a ns1:Parametro ;
    rdfs:label "TDATA8" ;
    ns1:identificador "TDATA8" ;
    ns1:textoExtracto "el parámetro TDATA8." .

ns1:Sistema_CinematicaCabezalMesa a ns1:Sistema ;
    rdfs:label "Cinemática cabezal–mesa (tipo 52)" ;
    ns1:textoExtracto "Definición vectorial de cinemáticas de cabezal–mesa (tipo 52)." ;
    ns1:tieneComponente ns1:Componente_EjeRotativoPrincipal,
        ns1:Componente_EjeRotativoSecundario,
        ns1:Componente_Portaherramientas .

ns1:Componente_EjeRotativoPrincipal a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo principal de la mesa" ;
    ns1:textoExtracto "Vector traslación del eje rotativo principal de la mesa. [...] Este vector traslación indica la distancia desde el punto de referencia del eje rotativo principal al punto de referencia máquina." ;
    ns1:tieneComponente ns1:Parametro_TDATA31,
        ns1:Parametro_TDATA32,
        ns1:Parametro_TDATA33 .

ns1:Componente_EjeRotativoSecundario a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo secundario del cabezal" ;
    ns1:textoExtracto "TDATA19 Eje rotativo secundario del cabezal manual o servocontrolado." ;
    ns1:tieneComponente ns1:Parametro_TDATA19 .

ns1:Componente_Portaherramientas a ns1:ComponenteMecanico ;
    rdfs:label "Portaherramientas" ;
    ns1:textoExtracto "Vector traslación del portaherramientas. [...] Este vector traslación indica la distancia desde la base del portaherramientas al punto de referencia del eje rotativo secundario." ;
    ns1:tieneComponente ns1:Parametro_TDATA21,
        ns1:Parametro_TDATA22,
        ns1:Parametro_TDATA23,
        ns1:Parametro_TDATA24,
        ns1:Parametro_TDATA25,
        ns1:Parametro_TDATA26 .

ns1:Parametro_TDATA19 a ns1:Parametro ;
    rdfs:label "Eje rotativo secundario del cabezal (manual/servocontrolado)" ;
    ns1:identificador "TDATA19" ;
    ns1:textoExtracto "TDATA19 Eje rotativo secundario del cabezal manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0. Este parámetro indica si el eje rotativo es manual o servocontrolado. Si el eje no existe en la cinemática, se definirá como TDATA19=1." ;
    ns1:valor "0 (servocontrolado) / 1 (manual)"^^xsd:string .

ns1:Parametro_TDATA21 a ns1:Parametro ;
    rdfs:label "Vector traslación X del portaherramientas" ;
    ns1:identificador "TDATA21" ;
    ns1:textoExtracto "TDATA21 Distancia de la base de la herramienta al eje rotativo secundario (eje X)." ;
    ns1:valor "0 a 99999.9999 mm / 0 a 3937.00787 inch"^^xsd:string .

ns1:Parametro_TDATA22 a ns1:Parametro ;
    rdfs:label "Vector traslación Y del portaherramientas" ;
    ns1:identificador "TDATA22" ;
    ns1:textoExtracto "TDATA22 Distancia de la base de la herramienta al eje rotativo secundario (eje Y)." ;
    ns1:valor "0 a 99999.9999 mm / 0 a 3937.00787 inch"^^xsd:string .

ns1:Parametro_TDATA23 a ns1:Parametro ;
    rdfs:label "Vector traslación Z del portaherramientas" ;
    ns1:identificador "TDATA23" ;
    ns1:textoExtracto "TDATA23 Distancia de la base de la herramienta al eje rotativo secundario (eje Z)." ;
    ns1:valor "0 a 99999.9999 mm / 0 a 3937.00787 inch"^^xsd:string .

ns1:Parametro_TDATA24 a ns1:Parametro ;
    rdfs:label "Vector dirección X del portaherramientas" ;
    ns1:identificador "TDATA24" ;
    ns1:textoExtracto "TDATA24 Componente del vector dirección del portaherramientas (eje X)." .

ns1:Parametro_TDATA25 a ns1:Parametro ;
    rdfs:label "Vector dirección Y del portaherramientas" ;
    ns1:identificador "TDATA25" ;
    ns1:textoExtracto "TDATA25 Componente del vector dirección del portaherramientas (eje Y)." .

ns1:Parametro_TDATA26 a ns1:Parametro ;
    rdfs:label "Vector dirección Z del portaherramientas" ;
    ns1:identificador "TDATA26" ;
    ns1:textoExtracto "TDATA26 Componente del vector dirección del portaherramientas (eje Z)." .

ns1:Parametro_TDATA31 a ns1:Parametro ;
    rdfs:label "Vector traslación X del eje rotativo principal de la mesa" ;
    ns1:identificador "TDATA31" ;
    ns1:textoExtracto "TDATA31 Distancia del eje rotativo principal al punto de referencia máquina (eje X)." ;
    ns1:valor "0 a 99999.9999 mm / 0 a 3937.00787 inch"^^xsd:string .

ns1:Parametro_TDATA32 a ns1:Parametro ;
    rdfs:label "Vector traslación Y del eje rotativo principal de la mesa" ;
    ns1:identificador "TDATA32" ;
    ns1:textoExtracto "TDATA32 Distancia del eje rotativo principal al punto de referencia máquina (eje Y)." ;
    ns1:valor "0 a 99999.9999 mm / 0 a 3937.00787 inch"^^xsd:string .

ns1:Parametro_TDATA33 a ns1:Parametro ;
    rdfs:label "Vector traslación Z del eje rotativo principal de la mesa" ;
    ns1:identificador "TDATA33" ;
    ns1:textoExtracto "TDATA33 Distancia del eje rotativo principal al punto de referencia máquina (eje Z)." ;
    ns1:valor "0 a 99999.9999 mm / 0 a 3937.00787 inch"^^xsd:string .

