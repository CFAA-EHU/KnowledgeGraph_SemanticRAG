@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Sistema_CinematicaTipo52 a ns1:Sistema ;
    rdfs:label "Sistema de cinemática tipo 52 (cabezal–mesa)" ;
    ns1:textoExtracto "Definición vectorial de cinemáticas de cabezal–mesa (tipo 52)." ;
    ns1:tieneComponente ns1:Parametro_TDATA31,
        ns1:Parametro_TDATA32,
        ns1:Parametro_TDATA33,
        ns1:Parametro_TDATA34,
        ns1:Parametro_TDATA35,
        ns1:Parametro_TDATA36 .

ns1:Parametro_TDATA31 a ns1:Parametro ;
    rdfs:label "TDATA31" ;
    ns1:identificador "TDATA31" ;
    ns1:textoExtracto "Distancia del eje rotativo principal al punto de referencia máquina (eje X)." ;
    ns1:valor "0.0"^^xsd:float .

ns1:Parametro_TDATA32 a ns1:Parametro ;
    rdfs:label "TDATA32" ;
    ns1:identificador "TDATA32" ;
    ns1:textoExtracto "Distancia del eje rotativo principal al punto de referencia máquina (eje Y)." ;
    ns1:valor "0.0"^^xsd:float .

ns1:Parametro_TDATA33 a ns1:Parametro ;
    rdfs:label "TDATA33" ;
    ns1:identificador "TDATA33" ;
    ns1:textoExtracto "Distancia del eje rotativo principal al punto de referencia máquina (eje Z)." ;
    ns1:valor "0.0"^^xsd:float .

ns1:Parametro_TDATA34 a ns1:Parametro ;
    rdfs:label "TDATA34" ;
    ns1:identificador "TDATA34" ;
    ns1:textoExtracto "Componente del vector dirección del eje rotativo principal (eje X)." .

ns1:Parametro_TDATA35 a ns1:Parametro ;
    rdfs:label "TDATA35" ;
    ns1:identificador "TDATA35" ;
    ns1:textoExtracto "Componente del vector dirección del eje rotativo principal (eje Y)." .

ns1:Parametro_TDATA36 a ns1:Parametro ;
    rdfs:label "TDATA36" ;
    ns1:identificador "TDATA36" ;
    ns1:textoExtracto "Componente del vector dirección del eje rotativo principal (eje Z)." .

