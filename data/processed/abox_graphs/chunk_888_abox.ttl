@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Sistema_CinematicaMesaTipo52 a ns1:Sistema ;
    rdfs:label "Cinemática de cabezal–mesa (tipo 52)" ;
    ns1:textoExtracto "Definición vectorial de cinemáticas de cabezal–mesa (tipo 52)." ;
    ns1:tieneComponente ns1:Parametro_TDATA34,
        ns1:Parametro_TDATA35,
        ns1:Parametro_TDATA36,
        ns1:Parametro_TDATA37,
        ns1:Parametro_TDATA38,
        ns1:Parametro_TDATA39,
        ns1:Parametro_TDATA40 .

ns1:Parametro_TDATA34 a ns1:Parametro ;
    rdfs:label "TDATA34" ;
    ns1:identificador "TDATA34" ;
    ns1:textoExtracto "TDATA34 Componente del vector dirección del eje rotativo principal (eje X)." ;
    ns1:valor "0.0"^^xsd:float .

ns1:Parametro_TDATA35 a ns1:Parametro ;
    rdfs:label "TDATA35" ;
    ns1:identificador "TDATA35" ;
    ns1:textoExtracto "TDATA35 Componente del vector dirección del eje rotativo principal (eje Y)." ;
    ns1:valor "0.0"^^xsd:float .

ns1:Parametro_TDATA36 a ns1:Parametro ;
    rdfs:label "TDATA36" ;
    ns1:identificador "TDATA36" ;
    ns1:textoExtracto "TDATA36 Componente del vector dirección del eje rotativo principal (eje Z). Si el eje no existe en la cinemática, se definirá como TDATA34=0, TDATA35=0, TDATA36=1." ;
    ns1:valor "1.0"^^xsd:float .

ns1:Parametro_TDATA37 a ns1:Parametro ;
    rdfs:label "TDATA37" ;
    ns1:identificador "TDATA37" ;
    ns1:textoExtracto "TDATA37 Posición de reposo del eje rotativo principal de la mesa. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0." ;
    ns1:valor "0.0"^^xsd:float .

ns1:Parametro_TDATA38 a ns1:Parametro ;
    rdfs:label "TDATA38" ;
    ns1:identificador "TDATA38" ;
    ns1:textoExtracto "TDATA38 Sentido de giro del eje rotativo principal de la mesa. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." ;
    ns1:valor 0 .

ns1:Parametro_TDATA39 a ns1:Parametro ;
    rdfs:label "TDATA39" ;
    ns1:identificador "TDATA39" ;
    ns1:textoExtracto "TDATA39 Eje rotativo principal de la mesa manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0." ;
    ns1:valor 0 .

ns1:Parametro_TDATA40 a ns1:Parametro ;
    rdfs:label "TDATA40" ;
    ns1:identificador "TDATA40" ;
    ns1:textoExtracto "TDATA40 Origen para aplicar el RTCP. Valores posibles: 0 (cero máquina) / 1 (cero pieza). Valor por defecto: 0." ;
    ns1:valor 0 .

