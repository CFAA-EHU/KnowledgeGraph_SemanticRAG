@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Sistema_CinematicaTipo52 a ns1:Sistema ;
    rdfs:label "Sistema de cinemática tipo 52 (cabezal–mesa)" ;
    ns1:textoExtracto "Definición vectorial de cinemáticas de cabezal–mesa (tipo 52)." ;
    ns1:tieneComponente ns1:Parametro_TDATA41,
        ns1:Parametro_TDATA42,
        ns1:Parametro_TDATA43,
        ns1:Parametro_TDATA44,
        ns1:Parametro_TDATA45,
        ns1:Parametro_TDATA46,
        ns1:Parametro_TDATA47,
        ns1:Parametro_TDATA48 .

ns1:Parametro_TDATA41 a ns1:Parametro ;
    rdfs:label "TDATA41: Distancia eje rotativo secundario (X)" ;
    ns1:identificador "TDATA41" ;
    ns1:textoExtracto "TDATA41 Distancia del eje rotativo secundario al principal (eje X)." ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA42 a ns1:Parametro ;
    rdfs:label "TDATA42: Distancia eje rotativo secundario (Y)" ;
    ns1:identificador "TDATA42" ;
    ns1:textoExtracto "TDATA42 Distancia del eje rotativo secundario al principal (eje Y)." ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA43 a ns1:Parametro ;
    rdfs:label "TDATA43: Distancia eje rotativo secundario (Z)" ;
    ns1:identificador "TDATA43" ;
    ns1:textoExtracto "TDATA43 Distancia del eje rotativo secundario al principal (eje Z)." ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA44 a ns1:Parametro ;
    rdfs:label "TDATA44: Componente vector dirección (X)" ;
    ns1:identificador "TDATA44" ;
    ns1:textoExtracto "TDATA44 Componente del vector dirección del eje rotativo secundario (eje X)." ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA45 a ns1:Parametro ;
    rdfs:label "TDATA45: Componente vector dirección (Y)" ;
    ns1:identificador "TDATA45" ;
    ns1:textoExtracto "TDATA45 Componente del vector dirección del eje rotativo secundario (eje Y)." ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA46 a ns1:Parametro ;
    rdfs:label "TDATA46: Componente vector dirección (Z)" ;
    ns1:identificador "TDATA46" ;
    ns1:textoExtracto "TDATA46 Componente del vector dirección del eje rotativo secundario (eje Z)." ;
    ns1:valor 1.0 .

ns1:Parametro_TDATA47 a ns1:Parametro ;
    rdfs:label "TDATA47: Posición de reposo eje rotativo secundario" ;
    ns1:identificador "TDATA47" ;
    ns1:textoExtracto "TDATA47 Posición de reposo del eje rotativo secundario de la mesa. Valores posibles: Entre ±99999.9999º." ;
    ns1:valor 0.0 .

ns1:Parametro_TDATA48 a ns1:Parametro ;
    rdfs:label "TDATA48: Sentido de giro eje rotativo secundario" ;
    ns1:identificador "TDATA48" ;
    ns1:textoExtracto "TDATA48 Sentido de giro del eje rotativo secundario de la mesa. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217)." ;
    ns1:valor 0 .

