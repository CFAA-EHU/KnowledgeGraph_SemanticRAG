@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_TDATA38 a ns1:Parametro ;
    rdfs:label "Parámetro relacionado con TDATA48 (consulta obligatoria)"@es ;
    ns1:identificador "TDATA38" ;
    ns1:textoExtracto "Consultar el parámetro TDATA38."@es .

ns1:Parametro_TDATA48 a ns1:Parametro ;
    rdfs:label "Sentido de giro del eje rotativo secundario de la mesa"@es ;
    ns1:identificador "TDATA48" ;
    ns1:textoExtracto "TDATA48 Sentido de giro del eje rotativo secundario de la mesa. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0."@es ;
    ns1:valor "0" .

ns1:Parametro_TDATA49 a ns1:Parametro ;
    rdfs:label "Eje rotativo secundario de la mesa (manual/servocontrolado)"@es ;
    ns1:identificador "TDATA49" ;
    ns1:textoExtracto "TDATA49 Eje rotativo secundario de la mesa manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0. Este parámetro indica si el eje rotativo es manual o servocontrolado. Si el eje no existe en la cinemática, se definirá como TDATA49=1."@es ;
    ns1:valor "0" .

ns1:Parametro_TDATA50 a ns1:Parametro ;
    rdfs:label "Origen para aplicar el RTCP"@es ;
    ns1:identificador "TDATA50" ;
    ns1:textoExtracto "TDATA50 Origen para aplicar el RTCP. Valores posibles: 0 (cero máquina) / 1 (cero pieza)."@es .

