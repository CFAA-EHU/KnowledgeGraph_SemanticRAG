@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_RTCP a ns1:ModoOperacion ;
    rdfs:label "Modo RTCP (Rotational Tool Center Point)"@es ;
    ns1:identificador "RTCP" ;
    ns1:textoExtracto "Con el modo RTCP activo, este parámetro establece si el sistema de coordenadas pieza está fijo sobre la pieza y gira con ella o si por el contrario se mantiene paralelo al sistema de coordenadas máquina."@es .

ns1:Parametro_TDATA49 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA49 (Definición de eje inexistente en cinemática)"@es ;
    ns1:identificador "TDATA49" ;
    ns1:textoExtracto "Si el eje no existe en la cinemática, se definirá como TDATA49=1."@es ;
    ns1:valor "1" .

ns1:Sistema_CoordenadasMaquina a ns1:Sistema ;
    rdfs:label "Sistema de coordenadas máquina"@es ;
    ns1:textoExtracto "sistema de coordenadas máquina"@es .

ns1:Parametro_TDATA50 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA50 (Origen para RTCP)"@es ;
    ns1:identificador "TDATA50" ;
    ns1:textoExtracto "TDATA50 Origen para aplicar el RTCP. Valores posibles: 0 (cero máquina) / 1 (cero pieza). Valor por defecto: 0. Consultar el parámetro TDATA40."@es ;
    ns1:valor "0" .

ns1:Parametro_TDATA51 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA51 (Giro de sistema de coordenadas pieza)"@es ;
    ns1:controla ns1:Sistema_CoordenadasPieza ;
    ns1:identificador "TDATA51" ;
    ns1:textoExtracto "TDATA51 Girar el sistema de coordenadas pieza al girar la mesa. Valores posibles: 0 (sí) / 1 (no). Valor por defecto: 0. Con el modo RTCP activo, este parámetro establece si el sistema de coordenadas pieza está fijo sobre la pieza y gira con ella o si por el contrario se mantiene paralelo al sistema de coordenadas máquina."@es ;
    ns1:valor "0" .

ns1:Sistema_CoordenadasPieza a ns1:Sistema ;
    rdfs:label "Sistema de coordenadas pieza"@es ;
    ns1:monitoreaParametro ns1:Parametro_TDATA50,
        ns1:Parametro_TDATA51 ;
    ns1:textoExtracto "sistema de coordenadas pieza"@es .

