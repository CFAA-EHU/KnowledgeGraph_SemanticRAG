@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CinematicaCabezalMesa a ns1:Sistema ;
    rdfs:label "Sistema de cinemática cabezal–mesa (tipo 52)" ;
    ns1:compuestoPor ns1:Parametro_TDATA51,
        ns1:Parametro_TDATA52 ;
    ns1:detalladoEnEsquema ns1:Tabla_DefinicionTDATA51,
        ns1:Tabla_DefinicionTDATA52 ;
    ns1:textoExtracto "Definición vectorial de cinemáticas de cabezal–mesa (tipo 52). [...] Z' X' Z' X' #RTCP ON B-30 B TDATA51 = 0 TDATA51 = 1 TDATA52" .

ns1:Parametro_TDATA51 a ns1:Parametro ;
    rdfs:label "TDATA51" ;
    ns1:identificador "TDATA51" ;
    ns1:textoExtracto "Al variar la orientación de la pieza, no se modifica la posición que ocupa la punta de la herramienta sobre la pieza. El sistema de coordenadas está fijo sobre la pieza y gira con ella. [...] Al variar la orientación de la pieza, no se modifica la posición que ocupa el punto definido como cero pieza. El sistema de coordenadas se mantiene paralelo al sistema de coordenadas máquina." ;
    ns1:valor "0, 1" .

ns1:Parametro_TDATA52 a ns1:Parametro ;
    rdfs:label "TDATA52" ;
    ns1:identificador "TDATA52" ;
    ns1:textoExtracto "Aplicar RTCP completo. Valores posibles: 0 (sí) / 1 (no). Valor por defecto: 0. Este parámetro establece si el CNC aplica el RTCP a toda la cinemática o sólo a la parte del cabezal." ;
    ns1:valor "0, 1" .

ns1:Tabla_DefinicionTDATA51 a ns1:Tabla ;
    rdfs:label "Tabla de definición de TDATA51" ;
    ns1:documentadoEn ns1:Pagina_285 ;
    ns1:textoExtracto "| TDATA51 | Significado. | --- | --- | 0 | Al variar la orientación de la pieza, no se modifica la posición que ocupa la punta de la herramienta sobre la pieza. [...] | 1 | Al variar la orientación de la pieza, no se modifica la posición que ocupa el punto definido como cero pieza. [...]" .

ns1:Tabla_DefinicionTDATA52 a ns1:Tabla ;
    rdfs:label "Tabla de definición de TDATA52" ;
    ns1:documentadoEn ns1:Pagina_285 ;
    ns1:textoExtracto "| TDATA52 | Significado. | --- | --- | 0 | RTCP completo, mesa + cabezal." .

