@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TDATA52_0 a ns1:Tabla ;
    rdfs:label "TDATA52" ;
    ns1:identificador "TDATA52" ;
    ns1:textoExtracto "Significado. | TDATA52 | Significado. | --- | --- | 0 | RTCP completo, mesa + cabezal. | 1 | RTCP sólo teniendo en cuenta la parte del cabezal. | " .

ns1:TDATA52_0_0 a ns1:Pagina ;
    rdfs:label "Página 0" ;
    ns1:detalladoEnEsquema ns1:TDATA52 ;
    ns1:identificador "0" ;
    ns1:textoExtracto "RTCP completo, mesa + cabezal." ;
    ns1:tieneComponente ns1:Cabezal,
        ns1:Mesa .

ns1:TDATA52_0_1 a ns1:Pagina ;
    rdfs:label "Página 1" ;
    ns1:detalladoEnEsquema ns1:TDATA52 ;
    ns1:identificador "1" ;
    ns1:textoExtracto "RTCP sólo teniendo en cuenta la parte del cabezal." ;
    ns1:tieneComponente ns1:Cabezal .

