@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_CinematicasOEM a ns1:Sistema ;
    rdfs:label "Sistema de cinemáticas OEM (tipos 100 a 105)" ;
    ns1:textoExtracto "En las cinemáticas OEM hay que indicar el número de parámetros, variables auxiliares y datos de propósito general que se utilizan." ;
    ns1:tieneComponente ns1:Parametro_AUXCTE_SIZE,
        ns1:Parametro_KINDATA_SIZE,
        ns1:Parametro_NKINAX,
        ns1:Parametro_PARAM_D_SIZE,
        ns1:Parametro_PARAM_I_SIZE,
        ns1:Parametro_TDATA1_100,
        ns1:Parametro_TDATA_I1_100 .

ns1:Parametro_AUXCTE_SIZE a ns1:Parametro ;
    rdfs:label "AUXCTE_SIZE" ;
    ns1:identificador "AUXCTE_SIZE" ;
    ns1:textoExtracto "AUXCTE_SIZE Tamaño del área de variables auxiliares. Valores posibles: De 0 a 1000 bytes. Valor por defecto: 0. Variable asociada: (V.)MPK.AUXCTE_SIZE[kin]" ;
    ns1:valor "0" .

ns1:Parametro_KINDATA_SIZE a ns1:Parametro ;
    rdfs:label "KINDATA_SIZE" ;
    ns1:identificador "KINDATA_SIZE" ;
    ns1:textoExtracto "KINDATA_SIZE Tamaño del área de datos de propósito general. Valores posibles: De 0 a 100000 bytes. Valor por defecto: 0. Variable asociada: (V.)MPK.KINDATA_SIZE[kin]" ;
    ns1:valor "0" .

ns1:Parametro_NKINAX a ns1:Parametro ;
    rdfs:label "NKINAX" ;
    ns1:identificador "NKINAX" ;
    ns1:textoExtracto "NKINAX Número de ejes de la cinemática. Valores posibles: De 0 a 8. Valor por defecto: 0. Variable asociada: (V.)MPK.NKINAX[kin]" ;
    ns1:valor "0" .

ns1:Parametro_PARAM_D_SIZE a ns1:Parametro ;
    rdfs:label "PARAM_D_SIZE" ;
    ns1:identificador "PARAM_D_SIZE" ;
    ns1:textoExtracto "PARAM_D_SIZE Número de parámetros en formato decimal. Valores posibles: De 0 a 100. Valor por defecto: 0. Variable asociada: (V.)MPK.PARAM_D_SIZE[kin]" ;
    ns1:valor "0" .

ns1:Parametro_PARAM_I_SIZE a ns1:Parametro ;
    rdfs:label "PARAM_I_SIZE" ;
    ns1:identificador "PARAM_I_SIZE" ;
    ns1:textoExtracto "PARAM_I_SIZE Número de parámetros en formato entero. Valores posibles: De 0 a 100. Valor por defecto: 0. Variable asociada: (V.)MPK.PARAM_I_SIZE[kin]" ;
    ns1:valor "0" .

ns1:Parametro_TDATA1_100 a ns1:Parametro ;
    rdfs:label "TDATA1··100" ;
    ns1:identificador "TDATA1··100" ;
    ns1:textoExtracto "TDATA1··100 Parámetros para configurar la cinemática (formato decimal). Para las cinemáticas predefinidas de Fagor se ofrecen 100 parámetros. Para las cinemáticas propias del fabricante, la cantidad de parámetros es configurable." .

ns1:Parametro_TDATA_I1_100 a ns1:Parametro ;
    rdfs:label "TDATA_I1··100" ;
    ns1:identificador "TDATA_I1··100" ;
    ns1:textoExtracto "TDATA_I1··100 Parámetros para configurar la cinemática (formato entero). Para las cinemáticas predefinidas de Fagor se ofrecen 100 parámetros. Para las cinemáticas propias del fabricante, la cantidad de parámetros es configurable." .

