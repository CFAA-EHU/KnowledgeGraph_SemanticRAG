@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_TDATA1_Tipo50 a ns1:Parametro ;
    rdfs:label "TDATA1 (cinemática tipo 50)" ;
    ns1:documentadoEn ns1:TablaCinematicaTipo50_Tipo5,
        ns1:TablaCinematicaTipo50_Tipo6 ;
    ns1:identificador "TDATA1" ;
    ns1:textoExtracto "TDATA1 | TDATA2 (tipo 5) / TDATA13 (tipo 6)" .

ns1:Parametro_TDATA2_Tipo50 a ns1:Parametro ;
    rdfs:label "TDATA2 (cinemática tipo 50)" ;
    ns1:documentadoEn ns1:TablaCinematicaTipo50_Tipo5,
        ns1:TablaCinematicaTipo50_Tipo6 ;
    ns1:identificador "TDATA2" ;
    ns1:textoExtracto "TDATA2 | TDATA14 (tipo 5) / TDATA3 (tipo 6)" .

ns1:Parametro_TDATA3_Tipo50 a ns1:Parametro ;
    rdfs:label "TDATA3 (cinemática tipo 50)" ;
    ns1:documentadoEn ns1:TablaCinematicaTipo50_Tipo5,
        ns1:TablaCinematicaTipo50_Tipo6 ;
    ns1:identificador "TDATA3" ;
    ns1:textoExtracto "TDATA3 | TDATA15 (tipo 5) / TDATA15 (tipo 6)" .

ns1:Parametro_TDATA9_Tipo50 a ns1:Parametro ;
    rdfs:label "TDATA9 (cinemática tipo 50)" ;
    ns1:documentadoEn ns1:TablaCinematicaTipo50_Tipo5,
        ns1:TablaCinematicaTipo50_Tipo6 ;
    ns1:identificador "TDATA9" ;
    ns1:textoExtracto "TDATA9 | 0, si TDATA12=0 o TDATA12=2; 1, si TDATA12=1 o TDATA12=3" ;
    ns1:valor "0, si TDATA12=0 o TDATA12=2; 1, si TDATA12=1 o TDATA12=3"@es .

ns1:Parametro_TYPE_Tipo50 a ns1:Parametro ;
    rdfs:label "TYPE (cinemática tipo 50)" ;
    ns1:documentadoEn ns1:TablaCinematicaTipo50_Tipo5,
        ns1:TablaCinematicaTipo50_Tipo6 ;
    ns1:identificador "TYPE" ;
    ns1:textoExtracto "TYPE | 50" ;
    ns1:valor "50" .

ns1:TablaCinematicaTipo50_Tipo5 a ns1:Tabla ;
    rdfs:label "Tabla de equivalencia: cinemática tipo 50 vs. tipo 5" ;
    ns1:textoExtracto """
| Parámetro de la cinemática vectorial (tipo 50). | Valor/parámetro equivalente en la cinemática tipo 5. |
| --- | --- |
| TYPE | 50 |
| TDATA1 | TDATA2 |
| TDATA2 | TDATA14 |
| TDATA3 | TDATA15 |
| TDATA4 | 1 |
| TDATA5 | 0 |
| TDATA6 | 0 |
| TDATA7 | TDATA8 |
| TDATA8 | TDATA10 |
| TDATA9 | 0, si TDATA12=0 o TDATA12=2; 1, si TDATA12=1 o TDATA12=3. |
| TDATA11 | TDATA5*COS(TDATA7) |
| TDATA12 | TDATA3 |
| TDATA13 | TDATA5*SIN(TDATA7) |
| TDATA14 | COS(TDATA7) |
| TDATA15 | 0 |
| TDATA16 | SIN(TDATA7) |
| TDATA17 | TDATA9 |
| TDATA18 | TDATA11 |
| TDATA19 | 0, si TDATA12=0 o TDATA12=1; 1, si TDATA12=2 o TDATA12=3. |
| TDATA21 | 0 |
| TDATA22 | TDATA6 |
| TDATA23 | TDATA1 |
| TDATA24 | 0 |
| TDATA25 | 0 |
| TDATA26 | 1 """ .

ns1:TablaCinematicaTipo50_Tipo6 a ns1:Tabla ;
    rdfs:label "Tabla de equivalencia: cinemática tipo 50 vs. tipo 6" ;
    ns1:textoExtracto """
| Parámetro de la cinemática vectorial (tipo 50). | Valor/parámetro equivalente en la cinemática tipo 6. |
| --- | --- |
| TYPE | 50 |
| TDATA1 | TDATA13 |
| TDATA2 | TDATA3 |
| TDATA3 | TDATA15 |
| TDATA4 | 0 |
| TDATA5 | 1 |
| TDATA6 | 0 |
| TDATA7 | TDATA8 |
| TDATA8 | TDATA10 |
| TDATA9 | 0, si TDATA12=0 o TDATA12=2; 1, si TDATA12=1 o TDATA12=3.""" .

