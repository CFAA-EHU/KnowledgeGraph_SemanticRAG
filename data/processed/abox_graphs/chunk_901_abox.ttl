@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_TDATA12_Tipo50 a ns1:Parametro ;
    rdfs:label "TDATA12 (cinemática tipo 50)"@es ;
    ns1:documentadoEn ns1:Tabla_RedefinicionCinematicaTipo50_a_Tipo7,
        ns1:Tabla_RedefinicionCinematicaTipo50_a_Tipo8 ;
    ns1:identificador "TDATA12" ;
    ns1:textoExtracto "TDATA12 | TDATA3 (en tipo 7); TDATA9 depende de TDATA12"@es .

ns1:Parametro_TDATA13_Tipo7 a ns1:Parametro ;
    rdfs:label "TDATA13 (cinemática tipo 7)"@es ;
    ns1:documentadoEn ns1:Tabla_RedefinicionCinematicaTipo50_a_Tipo7 ;
    ns1:identificador "TDATA13" ;
    ns1:textoExtracto "TDATA1 | TDATA13"@es .

ns1:Parametro_TDATA13_Tipo8 a ns1:Parametro ;
    rdfs:label "TDATA13 (cinemática tipo 8)"@es ;
    ns1:documentadoEn ns1:Tabla_RedefinicionCinematicaTipo50_a_Tipo8 ;
    ns1:identificador "TDATA13" ;
    ns1:textoExtracto "TDATA1 | TDATA13"@es .

ns1:Parametro_TDATA1_Tipo50 a ns1:Parametro ;
    rdfs:label "TDATA1 (cinemática tipo 50)"@es ;
    ns1:documentadoEn ns1:Tabla_RedefinicionCinematicaTipo50_a_Tipo7,
        ns1:Tabla_RedefinicionCinematicaTipo50_a_Tipo8 ;
    ns1:identificador "TDATA1" ;
    ns1:textoExtracto "TDATA1 | TDATA13"@es .

ns1:Parametro_TDATA9_Tipo50 a ns1:Parametro ;
    rdfs:label "TDATA9 (cinemática tipo 50)"@es ;
    ns1:documentadoEn ns1:Tabla_RedefinicionCinematicaTipo50_a_Tipo7,
        ns1:Tabla_RedefinicionCinematicaTipo50_a_Tipo8 ;
    ns1:identificador "TDATA9" ;
    ns1:textoExtracto "TDATA9 | 0, si TDATA12=0 o TDATA12=2; 1, si TDATA12=1 o TDATA12=3."@es .

ns1:Parametro_TYPE_Tipo50 a ns1:Parametro ;
    rdfs:label "TYPE (cinemática tipo 50)"@es ;
    ns1:documentadoEn ns1:Tabla_RedefinicionCinematicaTipo50_a_Tipo7,
        ns1:Tabla_RedefinicionCinematicaTipo50_a_Tipo8 ;
    ns1:identificador "TYPE" ;
    ns1:textoExtracto "TYPE | 50"@es ;
    ns1:valor "50" .

ns1:Tabla_RedefinicionCinematicaTipo50_a_Tipo7 a ns1:Tabla ;
    rdfs:label "Tabla de equivalencia: cinemática tipo 50 (vectorial) ↔ tipo 7"@es ;
    ns1:textoExtracto """
| Parámetro de la cinemática vectorial (tipo 50). | Valor/parámetro equivalente en la cinemática tipo 7. |
| TYPE | 50 |
| TDATA1 | TDATA13 |
| TDATA2 | TDATA14 |
| TDATA3 | TDATA4 |
| TDATA4 | 0 |
| TDATA5 | 0 |
| TDATA6 | 1 |
| TDATA7 | TDATA8 |
| TDATA8 | TDATA10 |
| TDATA9 | 0, si TDATA12=0 o TDATA12=2; 1, si TDATA12=1 o TDATA12=3. |
| TDATA11 | TDATA5*SIN(TDATA7) |
| TDATA12 | TDATA3 |
| TDATA13 | TDATA5*COS(TDATA7) |
| TDATA14 | SIN(TDATA7) |
| TDATA15 | 0 |
| TDATA16 | COS(TDATA7) |
| TDATA17 | TDATA9 |
| TDATA18 | TDATA11 |
| TDATA19 | 0, si TDATA12=0 o TDATA12=1; 1, si TDATA12=2 o TDATA12=3. |
| TDATA21 | 0 |
| TDATA22 | TDATA6 |
| TDATA23 | TDATA1 |
| TDATA24 | 0 |
| TDATA25 | 0 |
| TDATA26 | 1 |
"""@es .

ns1:Tabla_RedefinicionCinematicaTipo50_a_Tipo8 a ns1:Tabla ;
    rdfs:label "Tabla de equivalencia: cinemática tipo 50 (vectorial) ↔ tipo 8"@es ;
    ns1:textoExtracto """
| Parámetro de la cinemática vectorial (tipo 50). | Valor/parámetro equivalente en la cinemática tipo 8. |
| TYPE | 50 |
| TDATA1 | TDATA13 |
| TDATA2 | TDATA14 |
| TDATA3 | TDATA4 |
| TDATA4 | 0 |
| TDATA5 | 0 |
| TDATA6 | 1 |
| TDATA7 | TDATA8 |
| TDATA8 | TDATA10 |
| TDATA9 | 0, si TDATA12=0 o TDATA12=2; 1, si TDATA12=1 o TDATA12=3.
"""@es .

