@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_TDATA15_51 a ns1:Parametro ;
    rdfs:label "TDATA15 (cinemática tipo 51)" ;
    ns1:documentadoEn ns1:Tabla_CinematicaTipo51_Tipo9 ;
    ns1:identificador "TDATA15" ;
    ns1:textoExtracto "TDATA15 | 1" ;
    ns1:valor "1" .

ns1:Parametro_TDATA16_51 a ns1:Parametro ;
    rdfs:label "TDATA16 (cinemática tipo 51)" ;
    ns1:documentadoEn ns1:Tabla_CinematicaTipo51_Tipo10 ;
    ns1:identificador "TDATA16" ;
