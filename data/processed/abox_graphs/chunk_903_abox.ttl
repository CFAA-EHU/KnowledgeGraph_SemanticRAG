ns1:Parametro_TYPE_51 a ns1:Parametro ;
    rdfs:label "TYPE (cinemática tipo 51)" ;
    ns1:documentadoEn ns1:Tabla_CinematicaTipo51_Tipo10,
        ns1:Tabla_CinematicaTipo51_Tipo9 ;
    ns1:identificador "TYPE" ;
    ns1:textoExtracto "TYPE | 51" ;
    ns1:valor "51" .

ns1:Tabla_CinematicaTipo51_Tipo10 a ns1:Tabla ;
    rdfs:label "Tabla de equivalencia: cinemática tipo 51 desde tipo 10" ;
    ns1:textoExtracto """
| Parámetro de la cinemática vectorial (tipo 51). | Valor/parámetro equivalente en la cinemática tipo 10. |
| --- | --- |
| TYPE | 51 |
| TDATA1 | 0 |
| TDATA2 | -(TDATA5+TDATA3) |
| TDATA3 | -TDATA4 |
| TDATA4 | 1 |
| TDATA5 | 0 |
| TDATA6 | 0 |
| TDATA7 | TDATA8 |
| TDATA8 | TDATA10 |
| TDATA9 | 0 |
| TDATA10 | TDATA7 |
| TDATA11 | -TDATA2 |
| TDATA12 | TDATA5 |
| TDATA13 | 0 |
| TDATA14 | 0 |
| TDATA15 | 0 |
| TDATA16 | 1 |
| TDATA17 | TDATA9 |
| TDATA18 | TDATA11 |
| TDATA19 | 0 |
| TDATA20 | TDATA7 |
| TDATA31 | TDATA16 |
""" .

ns1:Tabla_CinematicaTipo51_Tipo9 a ns1:Tabla ;
    rdfs:label "Tabla de equivalencia: cinemática tipo 51 desde tipo 9" ;
    ns1:textoExtracto """
| Parámetro de la cinemática vectorial (tipo 51). | Valor/parámetro equivalente en la cinemática tipo 9. |
| --- | --- |
