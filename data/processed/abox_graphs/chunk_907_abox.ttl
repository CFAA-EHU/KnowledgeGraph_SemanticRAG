ns1:Tabla_CinematicaTipo52_a_Tipo14_Parte2 a ns1:Tabla ;
    rdfs:label "Tabla de equivalencia (continuación) entre parámetros de cinemática vectorial (tipo 52) y cinemática tipo 14"@es ;
