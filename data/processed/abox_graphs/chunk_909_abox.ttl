@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Param_TDATA31_Tipo52 a ns1:Parametro ;
    rdfs:label "TDATA31 (cinemática tipo 52)"@es ;
    ns1:documentadoEn ns1:Tabla_CinematicaVectorial_Tipo52_a_Tipo15 ;
    ns1:identificador "TDATA31" ;
    ns1:textoExtracto "| TDATA31 | 0 |"@es ;
    ns1:valor "0" .

