ns1:Tabla_CinematicaVectorial_Tipo52_a_Tipo16 a ns1:Tabla ;
    rdfs:label "Tabla de equivalencia: cinemática vectorial (tipo 52) ↔ tipo 16"@es ;
    ns1:documentadoEn ns1:Pagina_308 ;
    ns1:textoExtracto "Adaptar una cinemática tipo 16 a una cinemática tipo 52."@es .

ns1:Tabla_CinematicaVectorial_Tipo52_a_Tipo15 a ns1:Tabla ;
    rdfs:label "Tabla de equivalencia: cinemática vectorial (tipo 52) ↔ tipo 15"@es ;
    ns1:documentadoEn ns1:Pagina_293 ;
    ns1:textoExtracto """
| Parámetro de la cinemática vectorial (tipo 52). | Valor/parámetro equivalente en la cinemática tipo 15. |
| TDATA31 | 0 |
| TDATA32 | -TDATA5 |
| TDATA33 | -TDATA6 |
| TDATA34 | 1 |
| TDATA35 | 0 |
| TDATA36 | 0 |
| TDATA37 | TDATA9 |
| TDATA38 | TDATA11 |
"""@es .

