@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_TDATA1_52 a ns1:Parametro ;
    rdfs:label "TDATA1 (cinemática tipo 52)"@es ;
    ns1:documentadoEn ns1:Tabla_RedefinicionCinematicaTipo16a52 ;
    ns1:textoExtracto "| TDATA1 | TDATA13 |"@es ;
    ns1:valor "TDATA13" .

ns1:Parametro_TDATA2_52 a ns1:Parametro ;
    rdfs:label "TDATA2 (cinemática tipo 52)"@es ;
    ns1:documentadoEn ns1:Tabla_RedefinicionCinematicaTipo16a52 ;
    ns1:textoExtracto "| TDATA2 | TDATA14 |"@es ;
    ns1:valor "TDATA14" .

ns1:Parametro_TDATA31_52 a ns1:Parametro ;
    rdfs:label "TDATA31 (cinemática tipo 52)"@es ;
    ns1:documentadoEn ns1:Tabla_RedefinicionCinematicaTipo16a52 ;
    ns1:textoExtracto "| TDATA31 | -TDATA4 |"@es ;
    ns1:valor "-TDATA4" .

ns1:Parametro_TDATA32_52 a ns1:Parametro ;
    rdfs:label "TDATA32 (cinemática tipo 52)"@es ;
    ns1:documentadoEn ns1:Tabla_RedefinicionCinematicaTipo16a52 ;
    ns1:textoExtracto "| TDATA32 | -TDATA5 |"@es ;
    ns1:valor "-TDATA5" .

ns1:Parametro_TDATA3_52 a ns1:Parametro ;
    rdfs:label "TDATA3 (cinemática tipo 52)"@es ;
    ns1:documentadoEn ns1:Tabla_RedefinicionCinematicaTipo16a52 ;
    ns1:textoExtracto "| TDATA3 | TDATA15 |"@es ;
    ns1:valor "TDATA15" .

ns1:Parametro_TDATA40_52 a ns1:Parametro ;
    rdfs:label "TDATA40 (cinemática tipo 52)"@es ;
    ns1:documentadoEn ns1:Tabla_RedefinicionCinematicaTipo16a52 ;
    ns1:textoExtracto "| TDATA40 | A elegir. |"@es ;
    ns1:valor "A elegir"@es .

ns1:Parametro_TDATA4_52 a ns1:Parametro ;
    rdfs:label "TDATA4 (cinemática tipo 52)"@es ;
    ns1:documentadoEn ns1:Tabla_RedefinicionCinematicaTipo16a52 ;
    ns1:textoExtracto "| TDATA4 | 0 |"@es ;
    ns1:valor "0" .

ns1:Parametro_TDATA50_52 a ns1:Parametro ;
    rdfs:label "TDATA50 (cinemática tipo 52)"@es ;
    ns1:documentadoEn ns1:Tabla_RedefinicionCinematicaTipo16a52 ;
    ns1:textoExtracto "| TDATA50 | A elegir. |"@es ;
    ns1:valor "A elegir"@es .

ns1:Parametro_TYPE_52 a ns1:Parametro ;
    rdfs:label "TYPE"@es ;
    ns1:documentadoEn ns1:Tabla_RedefinicionCinematicaTipo16a52 ;
    ns1:identificador "52" ;
    ns1:textoExtracto "| TYPE | 52 |"@es ;
    ns1:valor "52" .

ns1:Tabla_RedefinicionCinematicaTipo16a52 a ns1:Tabla ;
    rdfs:label "Tabla de redefinición de cinemática tipo 16 a tipo 52"@es ;
    ns1:detalladoEnEsquema ns1:Parametro_TYPE_52 ;
    ns1:textoExtracto """
| TDATA51 | A elegir. |
| TDATA52 | A elegir. |
 Adaptar una cinemática tipo 16 a una cinemática tipo 52. | Parámetro de la
cinemática vectorial (tipo 52). | Valor/parámetro equivalente en la cinemática tipo 16.
"""@es .

