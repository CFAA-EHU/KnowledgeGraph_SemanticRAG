@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_TDATA51 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA51"@es ;
    ns1:documentadoEn ns1:Tabla_RedefinicionCinematicas_TDATA ;
    ns1:identificador "TDATA51" ;
    ns1:textoExtracto "TDATA51 | A elegir."@es .

ns1:Parametro_TDATA52 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA52"@es ;
    ns1:documentadoEn ns1:Tabla_RedefinicionCinematicas_TDATA ;
    ns1:identificador "TDATA52" ;
    ns1:textoExtracto "TDATA52 | A elegir."@es .

ns1:Tabla_RedefinicionCinematicas_TDATA a ns1:Tabla ;
    rdfs:label "Tabla de parámetros TDATA51-TDATA52 para redefinición de cinemáticas"@es ;
    ns1:identificador "TDATA51-TDATA52" ;
    ns1:textoExtracto """
| TDATA51 | A elegir. |
| TDATA52 | A elegir. |
"""@es .

