@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Canal_651_1 a ns1:Sistema ;
    ns1:textoExtracto "La transformación angular se puede definir con cualquier pareja de ejes del sistema, pero para activar la transformación ambos ejes deben pertenecer al mismo canal." .

ns1:EjeAngular_651_1 a ns1:Componente ;
    ns1:textoExtracto "X Eje cartesiano. X' Eje angular. Z Eje ortogonal." .

ns1:EjeCartesiano_651_1 a ns1:Componente ;
    ns1:textoExtracto "X Eje cartesiano. X' Eje angular. Z Eje ortogonal." .

ns1:EjeGantry_651_1 a ns1:Componente ;
    ns1:textoExtracto "Ambos ejes pueden ser ejes maestros en una pareja de ejes acoplados o ejes gantry." .

ns1:EjeInclinado_651_1 a ns1:Componente ;
    ns1:textoExtracto "La transformación angular de eje inclinado permite programar desplazamientos en coordenadas cartesianas y ejecutarlos en un plano no cartesiano; es decir, en un plano donde los ejes no están a 90º entre ellos." .

ns1:EjeLineal_651_1 a ns1:Componente ;
    ns1:textoExtracto "Ambos ejes deben ser lineales." .

ns1:EjeMaestro_651_2 a ns1:Componente ;
    ns1:textoExtracto "Ambos ejes pueden ser ejes maestros en una pareja de ejes acoplados o ejes gantry." .

ns1:EjeOrtogonal_651_1 a ns1:Componente ;
    ns1:textoExtracto "X Eje cartesiano. X' Eje angular. Z Eje ortogonal." .

ns1:Maquina_651_1 a ns1:Maquina ;
    ns1:textoExtracto "Se pueden personalizar hasta 14 transformaciones angulares distintas en una misma máquina." .

ns1:ProgramaPieza_651_1 a ns1:Componente ;
    ns1:textoExtracto "la activación de las transformaciones angulares se realiza desde el programa pieza mediante la sentencia #ANGAX ON." .

ns1:SentenciaANGAXON_651_1 a ns1:Componente ;
    ns1:textoExtracto "la activación de las transformaciones angulares se realiza desde el programa pieza mediante la sentencia #ANGAX ON." .

ns1:TransformacionAngular_651_1 a ns1:Sistema ;
    ns1:textoExtracto "La transformación angular de eje inclinado permite programar desplazamientos en coordenadas cartesianas y ejecutarlos en un plano no cartesiano; es decir, en un plano donde los ejes no están a 90º entre ellos." .

