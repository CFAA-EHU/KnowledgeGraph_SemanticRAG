@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_NANG a ns1:Parametro ;
    rdfs:label "Número de transformaciones angulares definidas (NANG)"@es ;
    ns1:identificador "NANG" ;
    ns1:monitoreaParametro ns1:Variable_MPK_NANG ;
    ns1:textoExtracto "NANG Número de transformaciones angulares definidas. Valores posibles: De 0 a 14. Valor por defecto: 0. Variable asociada: (V.)MPK.NANG"@es ;
    ns1:valor 0 .

ns1:Sentencia_ANGAX_ON a ns1:Parametro ;
    rdfs:label "Sentencia #ANGAX ON"@es ;
    ns1:identificador "#ANGAX ON" ;
    ns1:textoExtracto "La activación de las transformaciones angulares se realiza desde el programa pieza mediante la sentencia #ANGAX ON."@es .

ns1:Tabla_ANGTR a ns1:Tabla ;
    rdfs:label "Tabla de transformaciones angulares (ANGTR)"@es ;
    ns1:documentadoEn ns1:Manual_CNC ;
    ns1:identificador "ANGTR" ;
    ns1:textoExtracto "ANGTR Tabla de transformaciones angulares. Muestra las tablas de configuración de las transformaciones angulares."@es .

ns1:Manual_CNC a ns1:Manual ;
    ns1:textoExtracto "Sección 2.9.14: Configuración de las transformaciones angulares (parámetros)."@es .

ns1:Variable_MPK_NANG a ns1:Parametro ;
    rdfs:label "Variable MPK.NANG"@es ;
    ns1:identificador "MPK.NANG" ;
    ns1:textoExtracto "Variable asociada: (V.)MPK.NANG"@es .

