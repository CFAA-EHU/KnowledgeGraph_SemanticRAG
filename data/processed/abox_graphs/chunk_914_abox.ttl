@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_TransformacionAngular a ns1:Sistema ;
    rdfs:label "Sistema de transformación angular" ;
    ns1:textoExtracto "Sistema de coordenadas del eje inclinado definido por parámetros como ANGAXNA, ORTAXNA, ANGANTR y OFFANGAX." ;
    ns1:tieneComponente ns1:Parametro_ANGANTR,
        ns1:Parametro_ANGAXNA,
        ns1:Parametro_OFFANGAX,
        ns1:Parametro_ORTAXNA .

ns1:Parametro_ANGANTR a ns1:Parametro ;
    rdfs:label "ANGANTR" ;
    ns1:identificador "ANGANTR" ;
    ns1:textoExtracto "Ángulo entre el eje cartesiano y el eje inclinado. Valores posibles: Entre ±360.0000º. Valor por defecto: 30 grados." ;
    ns1:valor "60º" .

ns1:Parametro_ANGAXNA a ns1:Parametro ;
    rdfs:label "ANGAXNA" ;
    ns1:identificador "ANGAXNA" ;
    ns1:textoExtracto "Nombre del eje angular (eje inclinado). Variable asociada: (V.)MPK.ANGAXNA[ang]" ;
    ns1:valor "X" .

ns1:Parametro_OFFANGAX a ns1:Parametro ;
    rdfs:label "OFFANGAX" ;
    ns1:identificador "OFFANGAX" ;
    ns1:textoExtracto "Offset del origen de la transformación angular. Valores posibles: Entre ±99999.9999 mm / entre ±3937.00787 inch. Valor por defecto: 0." ;
    ns1:valor "0" .

ns1:Parametro_ORTAXNA a ns1:Parametro ;
    rdfs:label "ORTAXNA" ;
    ns1:identificador "ORTAXNA" ;
    ns1:textoExtracto "Nombre del eje ortogonal. Variable asociada: (V.)MPK.ORTAXNA[ang]" ;
    ns1:valor "Z" .

