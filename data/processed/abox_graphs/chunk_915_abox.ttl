@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:CinematicaEjesParalelos a ns1:Sistema ;
    rdfs:label "Cinemática de ejes paralelos"@es ;
    ns1:documentadoEn ns1:Tabla_PARALLEL_n ;
    ns1:textoExtracto "Esta cinemática permite trabajar con ejes que comparten dirección física y que actúan sobre la herramienta. El CNC no asume ninguna cinemática tras el encendido; la activación de la cinemática se realiza desde el programa pieza mediante la sentencia #PARALAX."@es ;
    ns1:tieneComponente ns1:Parametro_ADDAX,
        ns1:Parametro_ADDORG,
        ns1:Parametro_NPARAL,
        ns1:Parametro_PARALAX,
        ns1:Parametro_PARALINI .

ns1:Parametro_ADDAX a ns1:Parametro ;
    rdfs:label "ADDAX"@es ;
    ns1:identificador "ADDAX" ;
    ns1:textoExtracto "ADDAX Eje aditivo paralelo. Valores posibles: Cualquier eje definido en el parámetro AXISNAME. Valor por defecto: -. Variable asociada: (V.)MPK.ADDAX[nb]"@es .

ns1:Parametro_ADDORG a ns1:Parametro ;
    rdfs:label "ADDORG"@es ;
    ns1:identificador "ADDORG" ;
    ns1:textoExtracto "ADDORG Distancia entre los cero máquina de ambos ejes. Valores posibles: ±214748.3647 mm. Valor por defecto: 0. Variable asociada: (V.)MPK.ADDORG[nb]"@es ;
    ns1:valor 0.0 .

ns1:Parametro_NPARAL a ns1:Parametro ;
    rdfs:label "NPARAL"@es ;
    ns1:identificador "NPARAL" ;
    ns1:textoExtracto "NPARAL Número de cinemáticas de ejes paralelos. Valores posibles: De 0 a 6. Valor por defecto: 0. Variable asociada: (V.)MPK.NPARAL"@es ;
    ns1:valor 0 .

ns1:Parametro_PARALAX a ns1:Parametro ;
    rdfs:label "PARALAX"@es ;
    ns1:identificador "PARALAX" ;
    ns1:textoExtracto "PARALAX Eje principal de la transformación. Valores posibles: Cualquier eje definido en el parámetro AXISNAME. Valor por defecto: -. Variable asociada: (V.)MPK.PARALAX[nb]"@es .

ns1:Parametro_PARALINI a ns1:Parametro ;
    rdfs:label "PARALINI"@es ;
    ns1:identificador "PARALINI" ;
    ns1:textoExtracto "PARALINI Estado de la cinemática paralela en el arranque."@es .

ns1:Tabla_PARALLEL_n a ns1:Tabla ;
    rdfs:label "Tabla PARALLEL n"@es ;
    ns1:detalladoEnEsquema ns1:CinematicaEjesParalelos ;
    ns1:identificador "PARALLEL n" ;
    ns1:textoExtracto "PARALLEL n Tabla de cinemáticas de ejes paralelos. Muestra las tablas de configuración de las cinemáticas de ejes paralelos."@es .

