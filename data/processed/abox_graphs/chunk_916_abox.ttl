@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_MPK.ADDORG_nb a ns1:Parametro ;
    rdfs:label "MPK.ADDORG[nb]" ;
    ns1:documentadoEn ns1:Tabla_PARALLEL_n ;
    ns1:identificador "MPK.ADDORG[nb]" ;
    ns1:textoExtracto "Distancia entre los cero máquina de ambos ejes, del eje principal al eje aditivo. Valores posibles: ±214748.3647 mm / Valor por defecto: 0" ;
    ns1:valor "0" .

ns1:Parametro_MPK.PARALINI_nb a ns1:Parametro ;
    rdfs:label "MPK.PARALINI[nb]" ;
    ns1:documentadoEn ns1:Tabla_PARALLEL_n ;
    ns1:identificador "MPK.PARALINI[nb]" ;
    ns1:textoExtracto "Estado de la cinemática paralela en el arranque. Valores posibles: PARALAXOFF / PARALAX VIS. Valor por defecto: PARALAXOFF" ;
    ns1:valor "PARALAXOFF" .

ns1:Tabla_PARALLEL_n a ns1:Tabla ;
    rdfs:label "Tabla PARALLEL n" ;
    ns1:textoExtracto "Parámetro incluido en la tabla PARALLEL n." .

