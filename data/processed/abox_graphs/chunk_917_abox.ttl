@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Herramienta_CNC a ns1:Herramienta ;
    rdfs:label "Herramienta CNC" ;
    ns1:textoExtracto "el eje maestro siempre muestra la distancia de la herramienta a la pieza." .

ns1:ModoOperacion_ParalaxOff a ns1:ModoOperacion ;
    rdfs:label "PARALAX OFF" ;
    ns1:textoExtracto "PARALAX OFF | Cinemática desactivada." .

ns1:ModoOperacion_ParalaxVis a ns1:ModoOperacion ;
    rdfs:label "PARALAX VIS" ;
    ns1:controla ns1:Parametro_CotaEjeMaestro ;
    ns1:textoExtracto "PARALAX VIS. | Cinemática activa en modo visualización. El CNC actualiza la cota del eje maestro con el desplazamiento realizado por eje aditivo, de manera que el eje maestro siempre muestra la distancia de la herramienta a la pieza." .

ns1:Pieza_Trabajo a ns1:PiezaRecambio ;
    rdfs:label "Pieza de trabajo" ;
    ns1:textoExtracto "el eje maestro siempre muestra la distancia de la herramienta a la pieza." .

ns1:Parametro_CotaEjeMaestro a ns1:Parametro ;
    rdfs:label "Cota del eje maestro" ;
    ns1:textoExtracto "El CNC actualiza la cota del eje maestro con el desplazamiento realizado por eje aditivo, de manera que el eje maestro siempre muestra la distancia de la herramienta a la pieza." .

