@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_GROUND a ns1:Parametro ;
    rdfs:label "GROUND" ;
    ns1:identificador "GROUND" ;
    ns1:textoExtracto "GROUND Se permiten herramientas de tierra (carga manual). Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)TM.MZGROUND[mz] Se denominan herramientas de tierra a las que no están situadas en el almacén." ;
    ns1:valor "No"^^xsd:string .

ns1:Parametro_NTOOLMZ a ns1:Parametro ;
    rdfs:label "NTOOLMZ" ;
    ns1:identificador "NTOOLMZ" ;
    ns1:textoExtracto "NTOOLMZ Número de almacenes. Valores posibles: De 0 a 4. Valor por defecto: 1. Variable asociada: (V.)TM.NTOOLMZ Número de almacenes del sistema." ;
    ns1:valor 1 .

ns1:Parametro_STORAGE a ns1:Parametro ;
    rdfs:label "STORAGE" ;
    ns1:documentadoEn ns1:Tabla_MAGAZINE_n ;
    ns1:identificador "STORAGE" ;
    ns1:textoExtracto "STORAGE Parámetros relacionados con el almacenamiento." .

ns1:Tabla_MAGAZINE_n a ns1:Tabla ;
    rdfs:label "Tabla del almacén MAGAZINE n" ;
    ns1:textoExtracto "MAGAZINE n Tabla del almacén. Este parámetro muestra las tablas para definir los datos del almacén. Cada tabla dispone de los siguientes parámetros máquina para su configuración." .

