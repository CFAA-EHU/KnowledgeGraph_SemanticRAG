@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Magazine_n a ns1:Sistema ;
    rdfs:label "MAGAZINE n" ;
    ns1:textoExtracto "MAGAZINE n" .

ns1:Management a ns1:Sistema ;
    rdfs:label "MANAGEMENT" ;
    ns1:textoExtracto "MANAGEMENT Parámetros relacionados con la gestión del almacén." .

ns1:Storage a ns1:Sistema ;
    rdfs:label "STORAGE" ;
    ns1:textoExtracto "STORAGE Parámetros relacionados con el almacenamiento." .

