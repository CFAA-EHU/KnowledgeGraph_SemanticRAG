@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_MAGAZINE_STORAGE a ns1:Tabla ;
    rdfs:label "Tabla MAGAZINE // STORAGE" ;
    ns1:textoExtracto "Cada tabla dispone de los siguientes parámetros máquina para su configuración. [...] Parámetro incluido en la tabla MAGAZINE // STORAGE." ;
    ns1:tieneComponente ns1:Parametro_RANDOM,
        ns1:Parametro_SIZE .

ns1:Parametro_RANDOM a ns1:Parametro ;
    rdfs:label "RANDOM (Almacén random)" ;
    ns1:identificador "TM.MZRANDOM[mz]" ;
    ns1:textoExtracto "RANDOM Almacén random. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)TM.MZRANDOM[mz] [...] Este parámetro indica si las herramientas debe ocupar siempre la misma posición (no-random) o si pueden ocupar cualquier posición (random)." ;
    ns1:valor "No" .

ns1:Parametro_SIZE a ns1:Parametro ;
    rdfs:label "SIZE (Tamaño del almacén)" ;
    ns1:identificador "TM.MZSIZE[mz]" ;
    ns1:textoExtracto "SIZE Tamaño del almacén (número de posiciones). Valores posibles: De 0 a 1000. Valor por defecto: 20. Variable asociada: (V.)TM.MZSIZE[mz] [...] Este parámetro indica la capacidad del almacén, sin contar la herramientas de tierra." ;
    ns1:valor "20" .

