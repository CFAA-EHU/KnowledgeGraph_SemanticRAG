@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ParametrosRelacionadosConLaGestionDelAlmacen a ns1:Parametro ;
    rdfs:label "Parámetros relacionados con la gestión del almacén"@es ;
    ns1:compuestoPor ns1:AccionAlEjecutarUnaM06SinTSeleccionada_9305485ce1,
        ns1:CambiadorHerramientasCiclico,
        ns1:OptimizacionGestion,
        ns1:TipoAlmacen,
        ns1:VariableTM_MZTYPE ;
    ns1:detalladoEnEsquema ns1:TablaGestionAlmacen ;
    ns1:textoExtracto "MANAGEMENT Parámetros relacionados con la gestión del almacén. Este parámetro muestra los datos para configurar la gestión del almacén."@es .

ns1:TablaMAGAZINE a ns1:Tabla ;
    rdfs:label "Tabla MAGAZINE"@es ;
    ns1:textoExtracto "Parámetro incluido en la tabla MAGAZINE // MANAGEMENT."@es .

ns1:TipoAlmacenAsincrono a ns1:Parametro ;
    rdfs:label "Tipo de almacén Asíncrono"@es ;
    ns1:textoExtracto "Valores posibles: Asíncrono / Síncrono / Torreta / Síncrono + 2 Brazos / Síncrono + 1 Brazo."@es ;
    ns1:valor "Asíncrono"@es .

ns1:TipoAlmacenSincrono1Brazo a ns1:Parametro ;
    rdfs:label "Tipo de almacén Síncrono + 1 Brazo"@es ;
    ns1:textoExtracto "Valores posibles: Asíncrono / Síncrono / Torreta / Síncrono + 2 Brazos / Síncrono + 1 Brazo."@es ;
    ns1:valor "Síncrono + 1 Brazo"@es .

ns1:TipoAlmacenSincrono2Brazos a ns1:Parametro ;
    rdfs:label "Tipo de almacén Síncrono + 2 Brazos"@es ;
    ns1:textoExtracto "Valores posibles: Asíncrono / Síncrono / Torreta / Síncrono + 2 Brazos / Síncrono + 1 Brazo."@es ;
    ns1:valor "Síncrono + 2 Brazos"@es .

ns1:TipoAlmacenTorreta a ns1:Parametro ;
    rdfs:label "Tipo de almacén Torreta"@es ;
    ns1:textoExtracto "Valores posibles: Asíncrono / Síncrono / Torreta / Síncrono + 2 Brazos / Síncrono + 1 Brazo."@es ;
    ns1:valor "Torreta"@es .

ns1:AccionAlEjecutarUnaM06SinTSeleccionada_9305485ce1 a ns1:Parametro ;
    rdfs:label "Acción al ejecutar una M06 sin T seleccionada"@es ;
    ns1:textoExtracto "M6ALONE Acción al ejecutar una M06 sin T seleccionada."@es .

ns1:CambiadorHerramientasCiclico a ns1:Parametro ;
    rdfs:label "Cambiador de herramientas cíclico"@es ;
    ns1:textoExtracto "CYCLIC Cambiador de herramientas cíclico."@es .

ns1:OptimizacionGestion a ns1:Parametro ;
    rdfs:label "Optimización de la gestión"@es ;
    ns1:textoExtracto "OPTIMIZE Optimización de la gestión."@es .

ns1:TablaGestionAlmacen a ns1:Tabla ;
    ns1:textoExtracto "Cada tabla dispone de los siguientes parámetros máquina para su configuración."@es .

ns1:TipoAlmacen a ns1:Parametro ;
    rdfs:label "Tipo de almacén"@es ;
    ns1:textoExtracto "TYPE Tipo de almacén."@es ;
    ns1:valor ns1:TipoAlmacenSincrono .

ns1:TipoAlmacenSincrono a ns1:Parametro ;
    rdfs:label "Tipo de almacén Síncrono"@es ;
    ns1:textoExtracto "Valores posibles: Asíncrono / Síncrono / Torreta / Síncrono + 2 Brazos / Síncrono + 1 Brazo."@es ;
    ns1:valor "Síncrono"@es .

ns1:VariableTM_MZTYPE a ns1:Parametro ;
    rdfs:label "(V.)TM.MZTYPE[mz]"@es ;
    ns1:textoExtracto "Variable asociada: (V.)TM.MZTYPE[mz] Parámetro incluido en la tabla MAGAZINE // MANAGEMENT."@es .

