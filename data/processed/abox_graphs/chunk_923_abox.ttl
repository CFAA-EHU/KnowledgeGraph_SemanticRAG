@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlmacenSincronoConBrazoCambiador1Pinza_35b00f5c9a a ns1:Sistema ;
    rdfs:label "almacén síncrono con brazo cambiador (1 pinza)" ;
    ns1:compuestoPor ns1:BrazoCambiador1Pinza ;
    ns1:textoExtracto "Los almacenes síncronos con brazo cambiador (1 o 2 pinzas), tienen el almacén próximo al cabezal." .

ns1:AlmacenSincronoConBrazoCambiador2Pinzas_6ec4c937c3 a ns1:Sistema ;
    rdfs:label "almacén síncrono con brazo cambiador (2 pinzas)" ;
    ns1:compuestoPor ns1:BrazoCambiador2Pinzas ;
    ns1:textoExtracto "Los almacenes síncronos con brazo cambiador (1 o 2 pinzas), tienen el almacén próximo al cabezal." .

ns1:Herramienta a ns1:PiezaRecambio ;
    rdfs:label "herramienta" ;
    ns1:textoExtracto "El CNC finaliza el movimiento de los ejes. El brazo cambiador coge en cada pinza una herramienta (almacén y cabezal) y efectúa el cambio." .

ns1:Pinza a ns1:ComponenteMecanico ;
    rdfs:label "pinza" ;
    ns1:textoExtracto "El CNC finaliza el movimiento de los ejes. El brazo cambiador coge en cada pinza una herramienta (almacén y cabezal) y efectúa el cambio." .

ns1:ProcesoCambioHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "proceso de cambio de herramienta" ;
    ns1:compuestoPor ns1:PasoCogerHerramienta,
        ns1:PasoContinuarEjecucion,
        ns1:PasoDejarHerramienta,
        ns1:PasoFinalizarMovimiento,
        ns1:PasoSeleccionHerramienta ;
    ns1:textoExtracto "El cambio de herramienta se realiza de la siguiente manera (ejemplo con 2 pinzas). (1)Durante el mecanizado, el almacén selecciona la nueva herramienta. (2)El CNC finaliza el movimiento de los ejes. (3)El brazo cambiador coge en cada pinza una herramienta (almacén y cabezal) y efectúa el cambio. (4)El brazo cambiador vuelve al almacén para dejar la herramienta. (5)El CNC continúa con la ejecución del programa." .

ns1:BrazoCambiador1Pinza a ns1:ComponenteMecanico ;
    rdfs:label "brazo cambiador (1 pinza)" ;
    ns1:textoExtracto "Los almacenes síncronos con brazo cambiador (1 o 2 pinzas), tienen el almacén próximo al cabezal." .

ns1:BrazoCambiador2Pinzas a ns1:ComponenteMecanico ;
    rdfs:label "brazo cambiador (2 pinzas)" ;
    ns1:textoExtracto "Los almacenes síncronos con brazo cambiador (1 o 2 pinzas), tienen el almacén próximo al cabezal." .

ns1:PasoCogerHerramienta a ns1:AccionProhibida ;
    rdfs:label "paso 3: coger herramienta con el brazo cambiador" ;
    ns1:textoExtracto "(3)El brazo cambiador coge en cada pinza una herramienta (almacén y cabezal) y efectúa el cambio." .

ns1:PasoContinuarEjecucion a ns1:AccionProhibida ;
    rdfs:label "paso 5: continuación de la ejecución del programa" ;
    ns1:textoExtracto "(5)El CNC continúa con la ejecución del programa." .

ns1:PasoDejarHerramienta a ns1:AccionProhibida ;
    rdfs:label "paso 4: dejar herramienta en el almacén" ;
    ns1:textoExtracto "(4)El brazo cambiador vuelve al almacén para dejar la herramienta." .

ns1:PasoFinalizarMovimiento a ns1:AccionProhibida ;
    rdfs:label "paso 2: finalización del movimiento de los ejes" ;
    ns1:textoExtracto "(2)El CNC finaliza el movimiento de los ejes." .

ns1:PasoSeleccionHerramienta a ns1:AccionProhibida ;
    rdfs:label "paso 1: selección de herramienta durante el mecanizado" ;
    ns1:textoExtracto "(1)Durante el mecanizado, el almacén selecciona la nueva herramienta." .

