@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Funcion_M06 a ns1:AccionProhibida,
        ns1:Tabla ;
    rdfs:label "Función M06 (cambio de herramienta)" ;
    ns1:textoExtracto "necesita una orden de cambio de herramienta (función M06) después de buscar una herramienta y antes de buscar la siguiente." .

ns1:ModoOperacion_MDI a ns1:ModoOperacion ;
    rdfs:label "Modo MDI" ;
    ns1:textoExtracto "en modo MDI se ejecutan todos los bloques, no se tiene en cuenta este parámetro." .

ns1:Parametro_CYCLIC a ns1:Parametro ;
    rdfs:label "Cambiador de herramientas cíclico" ;
    ns1:documentadoEn ns1:Tabla_MAGAZINE_MANAGEMENT ;
    ns1:identificador "TM.MZCYCLIC[mz]" ;
    ns1:textoExtracto "CYCLIC Cambiador de herramientas cíclico. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)TM.MZCYCLIC[mz] Parámetro incluido en la tabla MAGAZINE // MANAGEMENT." ;
    ns1:valor "Sí" .

ns1:Parametro_OPTIMIZE a ns1:Parametro ;
    rdfs:label "Optimización de la gestión" ;
    ns1:documentadoEn ns1:Tabla_MAGAZINE_MANAGEMENT ;
    ns1:identificador "TM.MZOPTIMIZED[mz]" ;
    ns1:textoExtracto "OPTIMIZE Optimización de la gestión. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)TM.MZOPTIMIZED[mz] Parámetro incluido en la tabla MAGAZINE // MANAGEMENT." ;
    ns1:valor "Sí" .

ns1:Tabla_MAGAZINE_MANAGEMENT a ns1:Tabla ;
    rdfs:label "MAGAZINE // MANAGEMENT" ;
    ns1:textoExtracto "Parámetro incluido en la tabla MAGAZINE // MANAGEMENT." .

