@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:AccionAlEjecutarUnaM06SinHerramientaSeleccionada_a8f03f8e01 a ns1:AccionProhibida ;
    ns1:textoExtracto "Acción al ejecutar una M06 sin herramienta seleccionada." ;
    ns1:valor "Mostrar un error" .

ns1:SistemaAlmacen a ns1:Sistema ;
    ns1:textoExtracto "En almacén rándom, buscar huecos del mismo tamaño." ;
    ns1:tieneComponente ns1:VTMRESPECTSIZES .

ns1:TablaGestionAlmacen a ns1:Tabla ;
    ns1:textoExtracto "Parámetro incluido en la tabla MAGAZINE // MANAGEMENT." ;
    ns1:tieneComponente ns1:M6ALONE_251184b4f5,
        ns1:VTMRESPECTSIZES .

ns1:M6ALONE_251184b4f5 a ns1:Parametro ;
    ns1:identificador "M6ALONE" ;
    ns1:textoExtracto "Acción al ejecutar una M06 sin herramienta seleccionada. Valores posibles: Nada / Mostrar un aviso / Mostrar un error. Valor por defecto: Mostrar un error." ;
    ns1:valor "Mostrar un error" .

ns1:VTMRESPECTSIZES a ns1:Parametro ;
    ns1:identificador "(V.)TM.RESPECTSIZES" ;
    ns1:textoExtracto "En almacén rándom, buscar huecos del mismo tamaño. Valores posibles: Sí / No. Valor por defecto: No." ;
    ns1:valor "No" .

