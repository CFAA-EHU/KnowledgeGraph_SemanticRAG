@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:AvisoSeguridad_M06_SinSeleccionHerramienta a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de cambio de herramienta sin selección previa (M06)" ;
    ns1:mitigaRiesgo ns1:Parametro_MZM6ALONE ;
    ns1:textoExtracto "Este parámetro indica qué ocurre cuando se ejecuta una M06 sin selección previa de herramienta. Valores posibles: Nada / Mostrar un aviso / Mostrar un error." .

ns1:TareaMantenimiento_CambioHerramienta_M06 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta (función M06)" ;
    ns1:requiereMantenimiento ns1:Parametro_MZM6ALONE ;
    ns1:textoExtracto "La función M06 implica cambio de herramienta." .

ns1:Tabla_MAGAZINE_MANAGEMENT a ns1:Tabla ;
    rdfs:label "MAGAZINE // MANAGEMENT" ;
    ns1:identificador "MAGAZINE // MANAGEMENT" ;
    ns1:textoExtracto "Parámetro incluido en la tabla MAGAZINE // MANAGEMENT." .

ns1:Parametro_MZM6ALONE a ns1:Parametro ;
    rdfs:label "TM.MZM6ALONE[mz]" ;
    ns1:documentadoEn ns1:Tabla_MAGAZINE_MANAGEMENT ;
    ns1:identificador "TM.MZM6ALONE[mz]" ;
    ns1:textoExtracto "Variable asociada: (V.)TM.MZM6ALONE[mz]" ;
    ns1:valor "Mostrar un error"^^xsd:string .

