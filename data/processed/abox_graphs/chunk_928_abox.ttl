@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_VentanaPrincipal a ns1:InterfazUsuario ;
    rdfs:label "Ventana principal (HMI)"@es ;
    ns1:monitoreaParametro ns1:Parametro_HEIGHT,
        ns1:Parametro_POSX,
        ns1:Parametro_POSY,
        ns1:Parametro_RESOLUTION,
        ns1:Parametro_WIDTH ;
    ns1:textoExtracto "WINDOW Dimensiones y resolución de la ventana principal. Este parámetro muestra los datos para configurar la ventana principal."@es .

ns1:Parametro_HEIGHT a ns1:Parametro ;
    rdfs:label "HEIGHT"@es ;
    ns1:documentadoEn ns1:Tabla_WINDOW ;
    ns1:identificador "HEIGHT" ;
    ns1:textoExtracto "HEIGHT Altura de la ventana. Parámetro incluido en la tabla WINDOW."@es .

ns1:Parametro_POSX a ns1:Parametro ;
    rdfs:label "POSX"@es ;
    ns1:documentadoEn ns1:Tabla_WINDOW ;
    ns1:identificador "POSX" ;
    ns1:textoExtracto "POSX Coordenada X de la esquina superior izquierda. Valor por defecto: 0. Parámetro incluido en la tabla WINDOW."@es ;
    ns1:valor "0" .

ns1:Parametro_POSY a ns1:Parametro ;
    rdfs:label "POSY"@es ;
    ns1:documentadoEn ns1:Tabla_WINDOW ;
    ns1:identificador "POSY" ;
    ns1:textoExtracto "POSY Coordenada Y de la esquina superior izquierda. Valor por defecto: 0. Parámetro incluido en la tabla WINDOW."@es ;
    ns1:valor "0" .

ns1:Parametro_RESOLUTION a ns1:Parametro ;
    rdfs:label "RESOLUTION"@es ;
    ns1:documentadoEn ns1:Tabla_WINDOW ;
    ns1:identificador "RESOLUTION" ;
    ns1:textoExtracto "RESOLUTION Resolución de la pantalla. Valores posibles: CUSTOM / 10\" / 15\" / 19\" / 21\" LANDSCAPE / 21\" PORTRAIT. Valor por defecto: 10\". Parámetro incluido en la tabla WINDOW."@es ;
    ns1:valor "10\"" .

ns1:Parametro_WIDTH a ns1:Parametro ;
    rdfs:label "WIDTH"@es ;
    ns1:documentadoEn ns1:Tabla_WINDOW ;
    ns1:identificador "WIDTH" ;
    ns1:textoExtracto "WIDTH Anchura de la ventana. Parámetro incluido en la tabla WINDOW."@es .

ns1:Tabla_WINDOW a ns1:Tabla ;
    rdfs:label "Tabla WINDOW"@es ;
    ns1:detalladoEnEsquema ns1:InterfazUsuario_VentanaPrincipal ;
    ns1:textoExtracto "La tabla dispone de los siguientes parámetros máquina. | WINDOW |  | --- | --- | POSX | Coordenada X de la esquina superior izquierda. | POSY | Coordenada Y de la esquina superior izquierda. | RESOLUTION | Resolución de la ventana. | WIDTH | Anchura de la ventana. | HEIGHT | Altura de la ventana."@es .

