@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:InterfazUsuario_VentanaPrincipal a ns1:InterfazUsuario ;
    rdfs:label "Ventana principal del HMI"@es ;
    ns1:monitoreaParametro ns1:Parametro_Height,
        ns1:Parametro_Resolucion,
        ns1:Parametro_Width ;
    ns1:textoExtracto "Tamaño del interface (píxeles). Los parámetros WIDTH y HEIGHT definen el tamaño de la ventana."@es .

ns1:Parametro_Height a ns1:Parametro ;
    rdfs:label "HEIGHT"@es ;
    ns1:documentadoEn ns1:Tabla_ResolucionVentana ;
    ns1:identificador "HEIGHT" ;
    ns1:textoExtracto "HEIGHT. Altura de la ventana. Valores posibles: De 480 a 1050 píxeles. Valor por defecto: 600 píxeles."@es ;
    ns1:valor 600 .

ns1:Parametro_Resolucion a ns1:Parametro ;
    rdfs:label "RESOLUTION"@es ;
    ns1:documentadoEn ns1:Tabla_ResolucionVentana ;
    ns1:identificador "RESOLUTION" ;
    ns1:textoExtracto "RESOLUTION. (valor). Parámetro que define el tamaño del interface según la tabla. Estos parámetros sólo se pueden modificar cuando el parámetro RESOLUTION tiene el valor \"CUSTOM\"."@es ;
    ns1:valor "19\"=1280×1024; 21\" LANDSCAPE=1300×1080; 21\" PORTRAIT=1080×1400" .

ns1:Parametro_Width a ns1:Parametro ;
    rdfs:label "WIDTH"@es ;
    ns1:documentadoEn ns1:Tabla_ResolucionVentana ;
    ns1:identificador "WIDTH" ;
    ns1:textoExtracto "WIDTH. Anchura de la ventana. Valores posibles: De 800 a 1680 píxeles. Valor por defecto: 800 píxeles."@es ;
    ns1:valor 800 .

ns1:Tabla_ResolucionVentana a ns1:Tabla ;
    rdfs:label "Tabla de resolución y dimensiones de la ventana principal"@es ;
    ns1:detalladoEnEsquema ns1:InterfazUsuario_VentanaPrincipal ;
    ns1:textoExtracto """
| RESOLUTION. (valor) | Tamaño del interface (píxeles). |
| --- | --- |
| 19" | 1280 × 1024. |
| 21" LANDSCAPE | 1300 × 1080. El interface no ocupa toda la pantalla para permitir un teclado virtual. |
| 21" PORTRAIT | 1080 × 1400. El interface no ocupa toda la pantalla para permitir un teclado virtual."""@es .

