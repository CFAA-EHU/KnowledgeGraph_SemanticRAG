@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_Softkeys a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de softkeys" ;
    ns1:documentadoEn ns1:Tabla_SOFTKEYMETRICS_Valores ;
    ns1:textoExtracto "menú horizontal... menú vertical... softkeys verticales y la altura de las horizontales... interface ocupa toda la pantalla" ;
    ns1:tieneComponente ns1:Parametro_HMENUNSOFTKEY,
        ns1:Parametro_SOFTKEYMETRICS,
        ns1:Parametro_VMENUNSOFTKEY .

ns1:Parametro_HMENUNSOFTKEY a ns1:Parametro ;
    rdfs:label "HMENUNSOFTKEY" ;
    ns1:identificador "HMENUNSOFTKEY" ;
    ns1:textoExtracto "HMENUNSOFTKEY Número de softkeys del menú horizontal. Valores posibles: De 7 a 12. Valor por defecto: 7." ;
    ns1:valor "7" .

ns1:Parametro_SOFTKEYMETRICS a ns1:Parametro ;
    rdfs:label "SOFTKEYMETRICS" ;
    ns1:identificador "SOFTKEYMETRICS" ;
    ns1:textoExtracto "SOFTKEYMETRICS Dimensiones de las softkeys. Valores posibles: Estándar / Avanzado. Valor por defecto: Estándar. Este parámetro permite optimizar la anchura de las softkeys verticales y la altura de las horizontales, para que el espacio que ocupen sea mas proporcionado." ;
    ns1:valor "Estándar" .

ns1:Parametro_VMENUNSOFTKEY a ns1:Parametro ;
    rdfs:label "VMENUNSOFTKEY" ;
    ns1:identificador "VMENUNSOFTKEY" ;
    ns1:textoExtracto "VMENUNSOFTKEY Número de softkeys del menú vertical. Valores posibles: De 5 a 12. Valor por defecto: 5." ;
    ns1:valor "5" .

ns1:Tabla_SOFTKEYMETRICS_Valores a ns1:Tabla ;
    rdfs:label "Tabla de valores SOFTKEYMETRICS" ;
    ns1:textoExtracto "| Valor. | Significado. | --- | --- | Estándar. | El interface mantiene un valor proporcional entre el alto y el ancho las softkeys. | Avanzado. | El interface optimiza el espacio ocupado por las softkeys. Opción recomendada para monitores panorámicos donde el interface ocupa toda la pantalla." .

