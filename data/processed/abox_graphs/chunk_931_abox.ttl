@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_HMITYPE a ns1:Parametro ;
    rdfs:label "HMITYPE" ;
    ns1:controla ns1:InterfazUsuario_CNC_Avanzado,
        ns1:InterfazUsuario_CNC_Clasico,
        ns1:InterfazUsuario_CNC_Estandar ;
    ns1:textoExtracto "HMITYPE Tipo de interface del CNC. Valores posibles: Estándar / Clásico / Avanzado. Valor por defecto: Estándar. Este parámetro establece la forma de operar con el CNC, a través del interface." ;
    ns1:valor "Estándar" .

ns1:Parametro_SFTYPE a ns1:Parametro ;
    rdfs:label "SFTYPE" ;
    ns1:textoExtracto "SFTYPE Tipo de árbol de softkeys. Valores posibles: Estándar / Desplegables. Valor por defecto: Estándar. Dependiendo del valor seleccionado, el árbol de softkeys aparece de la siguiente forma." ;
    ns1:valor "Estándar" .

ns1:InterfazUsuario_CNC_Avanzado a ns1:InterfazUsuario ;
    rdfs:label "Interfaz CNC Avanzado" ;
    ns1:textoExtracto "Forma de operar basada en la tecla [Main-Menu], que muestra un menú principal desde el que se accede, mediante softkeys, a los diferentes modos de trabajo, (automático, manual, editor, etc). También es posible utilizar las hotkeys de acceso directo. Esta la forma de operar estándar del 8058, 8060 y 8065." .

ns1:InterfazUsuario_CNC_Clasico a ns1:InterfazUsuario ;
    rdfs:label "Interfaz CNC Clásico" ;
    ns1:textoExtracto "Forma de operar basada en hotkeys, para seleccionar el modo de trabajo (automático, manual, editor, etc). Esta la forma de operar estándar del 8070." .

ns1:InterfazUsuario_CNC_Estandar a ns1:InterfazUsuario ;
    rdfs:label "Interfaz CNC Estándar" ;
    ns1:textoExtracto "Forma de operar por defecto en el CNC, que podrá ser la forma clásica o avanzada, dependiendo del modelo de CNC." .

