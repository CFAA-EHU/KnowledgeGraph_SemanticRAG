@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ModoOperacion_Desplegables a ns1:ModoOperacion ;
    rdfs:label "Modo de operación con menús desplegables" ;
    ns1:habilitadoPor ns1:InterfazUsuario_CNC ;
    ns1:textoExtracto "Árbol de softkeys basado en menús desplegables, de manera que únicamente hay un nivel de softkeys. No hay submenús de softkeys, simplificando así la operativa." .

ns1:ModoOperacion_Estandar a ns1:ModoOperacion ;
    rdfs:label "Modo de operación estándar" ;
    ns1:habilitadoPor ns1:InterfazUsuario_CNC ;
    ns1:textoExtracto "Árbol de softkeys basado en menús y submenús; es decir, hay distintos niveles de softkeys dentro de un mismo modo de trabajo." .

ns1:Parametro_FFORMAT a ns1:Parametro ;
    rdfs:label "FFORMAT" ;
    ns1:textoExtracto "FFORMAT Formato de visualización de la F programada. Valor por defecto: 5.2. Este parámetro establece el formato numérico (enteros y decimales) para visualizar el avance." ;
    ns1:valor "5.2"^^xsd:string .

ns1:Parametro_LANGUAGE a ns1:Parametro ;
    rdfs:label "LANGUAGE" ;
    ns1:textoExtracto "LANGUAGE Idioma de trabajo. Valor por defecto: English. Seleccionar un idioma entre los disponibles." ;
    ns1:valor "English"^^xsd:string .

ns1:Parametro_MMINCHSOFTKEY a ns1:Parametro ;
    rdfs:label "MMINCHSOFTKEY" ;
    ns1:textoExtracto "MMINCHSOFTKEY Mostrar la softkey para cambiar el formato de visualización entre milímetros y pulgadas. Valores posibles: Sí / No. Valor por defecto: No." ;
    ns1:valor "No"^^xsd:string .

ns1:Parametro_SFORMAT a ns1:Parametro ;
    rdfs:label "SFORMAT" ;
    ns1:textoExtracto "SFORMAT Formato de visualización de la S programada. Valor por defecto: 5.1. Este parámetro establece el formato numérico (enteros y decimales) para visualizar la velocidad." ;
    ns1:valor "5.1"^^xsd:string .

ns1:Parametro_VMENU a ns1:Parametro ;
    rdfs:label "VMENU" ;
    ns1:textoExtracto "VMENU Posición del menú vertical de softkeys. Valores posibles: Izquierda / Derecha. Valor por defecto: Derecha." ;
    ns1:valor "Derecha"^^xsd:string .

ns1:InterfazUsuario_CNC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de usuario CNC" ;
    ns1:monitoreaParametro ns1:Parametro_FFORMAT,
        ns1:Parametro_LANGUAGE,
        ns1:Parametro_MMINCHSOFTKEY,
        ns1:Parametro_SFORMAT,
        ns1:Parametro_VMENU ;
    ns1:textoExtracto "Árbol de softkeys basado en menús y submenús; es decir, hay distintos niveles de softkeys dentro de un mismo modo de trabajo." .

