@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Aplicacion_LantekExpertInside a ns1:Herramienta ;
    rdfs:label "Lantek Expert Inside" ;
    ns1:ilustradoEn ns1:Tabla_USERKEY ;
    ns1:textoExtracto "En un modelo láser, se recomienda utilizar la esta tecla para abrir la aplicación \"Lantek Expert Inside\" para el nesting; C:\\Lantek\\Expert\\Expert.exe." .

ns1:Herramienta_FGUIM a ns1:Herramienta ;
    rdfs:label "FGUIM" ;
    ns1:ilustradoEn ns1:Tabla_USERKEY ;
    ns1:textoExtracto "Ejecutar una aplicación externa, por ejemplo el FGUIM." .

ns1:InterfazUsuario_TeclaCUSTOM a ns1:InterfazUsuario ;
    rdfs:label "Tecla [CUSTOM]" ;
    ns1:detalladoEnEsquema ns1:Tabla_USERKEY ;
    ns1:textoExtracto "USERKEY Personalización de la tecla de usuario. Esta tabla muestra los parámetros para configurar la tecla de usuario." .

ns1:Parametro_APPLICATION a ns1:Parametro ;
    rdfs:label "APPLICATION" ;
    ns1:documentadoEn ns1:Tabla_USERKEY ;
    ns1:textoExtracto "APPLICATION Ejecutar una aplicación del PC. Parámetro incluido en la tabla USERKEY. Cuando se define el parámetro USERKEY=Application, este parámetro permite seleccionar la aplicación. Hay que indicar el path completo de la aplicación; por ejemplo ..\\Fagor\\Release\\Fguim.exe." .

ns1:Parametro_COMPONENT a ns1:Parametro ;
    rdfs:label "COMPONENT" ;
    ns1:documentadoEn ns1:Tabla_USERKEY ;
    ns1:textoExtracto "COMPONENT Acceder a uno de los componentes del CNC. Valores posibles: Diagnosis / PLC / Parámetros máquina / DDSSETUP / TUNING" .

ns1:Parametro_FUNCTION a ns1:Parametro ;
    rdfs:label "FUNCTION" ;
    ns1:documentadoEn ns1:Tabla_USERKEY ;
    ns1:textoExtracto "FUNCTION Función de la tecla de usuario. Valores posibles: Windows / Componente / Aplicación / CNC OFF / Nada. Valor por defecto: Nada." ;
    ns1:valor "Nada" .

ns1:Tabla_USERKEY a ns1:Tabla ;
    rdfs:label "Tabla USERKEY" ;
    ns1:textoExtracto "USERKEY Personalización de la tecla de usuario. Esta tabla muestra los parámetros para configurar la tecla de usuario." ;
    ns1:tieneComponente ns1:Parametro_APPLICATION,
        ns1:Parametro_COMPONENT,
        ns1:Parametro_FUNCTION .

