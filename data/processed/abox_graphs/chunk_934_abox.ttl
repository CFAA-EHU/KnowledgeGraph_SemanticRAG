@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_TeclaNEXT a ns1:InterfazUsuario ;
    rdfs:label "Tecla NEXT"@es ;
    ns1:controla ns1:Parametro_FUNCTION,
        ns1:Parametro_SYSHMENU,
        ns1:Parametro_SYSMENUMODE,
        ns1:Parametro_SYSVMENU ;
    ns1:ilustradoEn ns1:Tabla_CHANGEKEY ;
    ns1:textoExtracto "CHANGEKEY Personalización de la tecla de cambio."@es .

ns1:Pagina_323_324 a ns1:Pagina ;
    rdfs:label "Páginas 323-324"@es ;
    ns1:identificador "2.11.5" ;
    ns1:textoExtracto "Configuración del teclado (tecla [NEXT])."@es .

ns1:Parametro_FUNCTION a ns1:Parametro ;
    rdfs:label "FUNCTION"@es ;
    ns1:documentadoEn ns1:Tabla_CHANGEKEY ;
    ns1:textoExtracto "Función de la tecla de cambio. Valores posibles: Sg Página / Sg Canal / Menú. Valor por defecto: Sg Página."@es ;
    ns1:valor "Sg Página" .

ns1:Parametro_SYSHMENU a ns1:Parametro ;
    rdfs:label "SYSHMENU"@es ;
    ns1:documentadoEn ns1:Tabla_CHANGEKEY ;
    ns1:textoExtracto "Menú de sistema horizontal. Valores posibles: Deshabilitado / Páginas / Canales / Componentes. Valor por defecto: Deshabilitado."@es ;
    ns1:valor "Deshabilitado" .

ns1:Parametro_SYSMENUMODE a ns1:Parametro ;
    rdfs:label "SYSMENUMODE"@es ;
    ns1:documentadoEn ns1:Tabla_CHANGEKEY ;
    ns1:textoExtracto "Comportamiento del menú de sistema. Valores posibles: Volátil / Fijo. Valor por defecto: Volátil."@es ;
    ns1:valor "Volátil" .

ns1:Parametro_SYSVMENU a ns1:Parametro ;
    rdfs:label "SYSVMENU"@es ;
    ns1:documentadoEn ns1:Tabla_CHANGEKEY ;
    ns1:textoExtracto "Menú de sistema vertical. Valores posibles: Deshabilitado / Páginas / Canales / Componentes. Valor por defecto: Deshabilitado."@es ;
    ns1:valor "Deshabilitado" .

ns1:Tabla_CHANGEKEY a ns1:Tabla ;
    rdfs:label "Tabla CHANGEKEY"@es ;
    ns1:documentadoEn ns1:Pagina_323_324 ;
    ns1:textoExtracto "Esta tabla muestra los parámetros para configurar la tecla de cambio. La tabla dispone de los siguientes parámetros máquina."@es .

