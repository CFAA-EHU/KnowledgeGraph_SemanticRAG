@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:InterfazUsuario_MenuSoftkeys a ns1:InterfazUsuario ;
    rdfs:label "Menú de softkeys" ;
    ns1:textoExtracto "Este parámetro establece las opciones que se mostrarán en cada menú de softkeys."@es .

ns1:Parametro_SYSHMENU a ns1:Parametro ;
    rdfs:label "SYSHMENU" ;
    ns1:documentadoEn ns1:Tabla_CHANGEKEY ;
    ns1:identificador "SYSHMENU" ;
    ns1:textoExtracto "Consultar el parámetro SYSHMENU. SYSVMENU Menú de sistema vertical."@es ;
    ns1:valor "Deshabilitado"^^xsd:string .

ns1:Parametro_SYSVMENU a ns1:Parametro ;
    rdfs:label "SYSVMENU" ;
    ns1:documentadoEn ns1:Tabla_CHANGEKEY ;
    ns1:identificador "SYSVMENU" ;
    ns1:textoExtracto "SYSVMENU Menú de sistema vertical. Valores posibles: Deshabilitado / Páginas / Canales / Componentes. Valor por defecto: Deshabilitado."@es ;
    ns1:valor "Deshabilitado"^^xsd:string .

ns1:Tabla_CHANGEKEY a ns1:Tabla ;
    rdfs:label "Tabla CHANGEKEY" ;
    ns1:identificador "CHANGEKEY" ;
    ns1:textoExtracto "Parámetro incluido en la tabla CHANGEKEY."@es .

