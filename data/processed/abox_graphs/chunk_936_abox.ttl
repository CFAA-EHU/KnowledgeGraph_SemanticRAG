@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Menu323324 a ns1:InterfazUsuario ;
    ns1:identificador "Menu 323-324" ;
    ns1:textoExtracto "El menú muestra las distintas páginas o pantallas del modo de trabajo activo." ;
    ns1:tieneComponente ns1:Canales,
        ns1:Componentes,
        ns1:Paginas .

ns1:Canales a ns1:ModoOperacion ;
    ns1:identificador "Canales" ;
    ns1:textoExtracto "El menú muestra la lista de canales disponibles." .

ns1:Componentes a ns1:Sistema ;
    ns1:identificador "Componentes" ;
    ns1:textoExtracto "El menú muestra los componentes o modos de trabajo del CNC." .

ns1:Paginas a ns1:ModoOperacion ;
    ns1:identificador "Paginas" ;
    ns1:textoExtracto "El menú muestra las distintas páginas o pantallas del modo de trabajo activo." .

