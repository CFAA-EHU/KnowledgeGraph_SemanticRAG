@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_FUNCTION a ns1:Parametro ;
    rdfs:label "FUNCTION" ;
    ns1:documentadoEn ns1:Tabla_ESCAPEKEY ;
    ns1:monitoreaParametro ns1:InterfazUsuario_Teclado ;
    ns1:textoExtracto "Función asociada a la tecla de escape. Valores posibles: Menú previo / Componente previo / Menú-Componente previo. Valor por defecto: Menú previo." ;
    ns1:valor "Menú previo" .

ns1:Parametro_NPREVIOUS a ns1:Parametro ;
    rdfs:label "NPREVIOUS" ;
    ns1:documentadoEn ns1:Tabla_ESCAPEKEY ;
    ns1:monitoreaParametro ns1:InterfazUsuario_Teclado ;
    ns1:textoExtracto "Número máximo de componentes previos memorizados. Valores posibles: De 1 a 5. Valor por defecto: 1." ;
    ns1:valor "1" .

ns1:InterfazUsuario_Teclado a ns1:InterfazUsuario ;
    rdfs:label "Tecla [ESC]" ;
    ns1:detalladoEnEsquema ns1:Tabla_ESCAPEKEY ;
    ns1:textoExtracto "Personalización de la tecla de escape. Este parámetro define el comportamiento de la tecla [ESC]." .

ns1:Tabla_ESCAPEKEY a ns1:Tabla ;
    rdfs:label "Tabla ESCAPEKEY" ;
    ns1:ilustradoEn ns1:InterfazUsuario_Teclado ;
    ns1:textoExtracto "Esta tabla muestra los parámetros para configurar la tecla de escape. La tabla dispone de los siguientes parámetros máquina." .

