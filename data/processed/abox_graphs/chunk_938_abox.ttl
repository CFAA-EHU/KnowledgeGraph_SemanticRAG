@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:parametro_NPREVIOUS a ns1:Parametro ;
    rdfs:label "NPREVIOUS" ;
    ns1:documentadoEn ns1:tabla_ESCAPEKEY ;
    ns1:identificador "NPREVIOUS" ;
    ns1:textoExtracto "NPREVIOUS Número máximo de componentes previos memorizados. Valores posibles: De 1 a 5. Valor por defecto: 1." ;
    ns1:valor "1" .

ns1:tecla_ESC a ns1:InterfazUsuario ;
    rdfs:label "Tecla [ESC]" ;
    ns1:textoExtracto "En cada componente, la tecla [ESC] primero sube de menú hasta alcanzar el menú principal del componente." .

ns1:tabla_ESCAPEKEY a ns1:Tabla ;
    rdfs:label "Tabla ESCAPEKEY" ;
    ns1:identificador "ESCAPEKEY" ;
    ns1:textoExtracto "Parámetro incluido en la tabla ESCAPEKEY." .

