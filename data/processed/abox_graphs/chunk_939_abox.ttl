@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoTelediagnosis a ns1:ModoOperacion ;
    rdfs:label "Telediagnosis" ;
    ns1:textoExtracto "Puede ser necesaria su utilización cuando se trabaja con telediagnosis (control remoto de CNC)." .

ns1:TecladoJogSimulado a ns1:InterfazUsuario ;
    rdfs:label "Teclado de JOG simulado" ;
    ns1:habilitadoPor ns1:SIMJOGPANEL ;
    ns1:monitoreaParametro ns1:SIMJOGPANEL ;
    ns1:textoExtracto "Se denomina Teclado de JOG simulado a una ventana que se superpone a la pantalla del CNC y que permite simular las teclas de JOG y las teclas de acceso a los modos de trabajo." .

ns1:SIMJOGPANEL a ns1:Parametro ;
    rdfs:label "SIMJOGPANEL" ;
    ns1:identificador "SIMJOGPANEL" ;
    ns1:textoExtracto "SIMJOGPANEL Teclado de JOG simulado. Valores posibles: Sí / No. Valor por defecto: No. Este parámetro indica si el teclado simulado está disponible." ;
    ns1:valor "No" .

