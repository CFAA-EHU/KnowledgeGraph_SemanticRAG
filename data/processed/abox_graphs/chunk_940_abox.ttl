@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_WINEXIT a ns1:Parametro ;
    rdfs:label "WINEXIT" ;
    ns1:identificador "WINEXIT" ;
    ns1:textoExtracto "WINEXIT Salida de Windows al cerrar el CNC. Valores posibles: Sí / No. Valor por defecto: No (no se cierra Windows)." ;
    ns1:valor "No" .

