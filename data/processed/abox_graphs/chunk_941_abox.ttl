@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_Channel1 a ns1:Parametro ;
    rdfs:label "Channel1" ;
    ns1:identificador "Channel1" ;
    ns1:monitoreaParametro ns1:InterfazUsuario_FGUIM ;
    ns1:textoExtracto "propiedades Channel1 y Channel2 de la ventana gráfica" .

ns1:Parametro_Channel2 a ns1:Parametro ;
    rdfs:label "Channel2" ;
    ns1:identificador "Channel2" ;
    ns1:monitoreaParametro ns1:InterfazUsuario_FGUIM ;
    ns1:textoExtracto "propiedades Channel1 y Channel2 de la ventana gráfica" .

ns1:Parametro_GRAPHTYPECH_n a ns1:Parametro ;
    rdfs:label "GRAPHTYPECH n" ;
    ns1:documentadoEn ns1:Tabla_GRAPHTYPE ;
    ns1:identificador "GRAPHTYPECH n" ;
    ns1:monitoreaParametro ns1:InterfazUsuario_FGUIM ;
    ns1:textoExtracto "GRAPHTYPECH n | Tipo de gráfico en cada canal. Valores posibles: Torno horizontal o vertical; X+ Z+ / X- Z+ / X+ Z- / X- Z-." ;
    ns1:valor "Horizontal X+ Z+"^^rdfs:Literal .

ns1:Tabla_GRAPHTYPE a ns1:Tabla ;
    rdfs:label "Tabla GRAPHTYPE" ;
    ns1:detalladoEnEsquema ns1:InterfazUsuario_FGUIM ;
    ns1:textoExtracto "GRAPHTYPE | Lista de gráficos en cada canal. En el modelo torno, este parámetro muestra la tabla para definir la configuración de los gráficos en cada canal." .

ns1:InterfazUsuario_FGUIM a ns1:InterfazUsuario ;
    rdfs:label "Aplicación FGUIM" ;
    ns1:textoExtracto "Para ello, utilizando la aplicación FGUIM, se deben modificar las propiedades Channel1 y Channel2 de la ventana gráfica para poder ver en un gráfico la ejecución de ambos canales." .

