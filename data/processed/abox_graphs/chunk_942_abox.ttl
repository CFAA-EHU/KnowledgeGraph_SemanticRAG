@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_PLC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz PLC" ;
    ns1:controla ns1:Parametro_DRIVEVAR ;
    ns1:textoExtracto "El parámetro DRIVEVAR permite definir la lista de variables DRV, aquellas que permiten acceder a las variables y/o parámetros de los reguladores digitales desde el programa pieza, modo MDI/MDA, PLC o interfaz." .

ns1:ModoOperacion_MDI_MDA a ns1:ModoOperacion ;
    rdfs:label "Modo MDI/MDA" ;
    ns1:habilitadoPor ns1:Parametro_DRIVEVAR ;
    ns1:textoExtracto "El parámetro DRIVEVAR permite definir la lista de variables DRV, aquellas que permiten acceder a las variables y/o parámetros de los reguladores digitales desde el [...] modo MDI/MDA, PLC o interfaz." .

ns1:Sistema_Reguladores a ns1:Sistema ;
    rdfs:label "Sistema de reguladores digitales" ;
    ns1:textoExtracto "El parámetro DRIVEVAR permite definir la lista de variables DRV, aquellas que permiten acceder a las variables y/o parámetros de los reguladores digitales desde el programa pieza, modo MDI/MDA, PLC o interfaz." ;
    ns1:tieneComponente ns1:Parametro_DRIVEVAR,
        ns1:Variable_DRV_Mechatrolink,
        ns1:Variable_DRV_Sercos .

ns1:Tabla_DRVVAR a ns1:Tabla ;
    rdfs:label "Tabla DRIVEVAR" ;
    ns1:detalladoEnEsquema ns1:Sistema_Reguladores ;
    ns1:textoExtracto "DRIVEVAR Tabla de variables de los reguladores. El parámetro DRIVEVAR permite definir la lista de variables DRV, aquellas que permiten acceder a las variables y/o parámetros de los reguladores digitales desde el programa pieza, modo MDI/MDA, PLC o interfaz." .

ns1:Variable_DRV_Mechatrolink a ns1:Parametro ;
    rdfs:label "Variables DRV (Mechatrolink)" ;
    ns1:documentadoEn ns1:Tabla_DRVVAR ;
    ns1:identificador "DRV_Mechatrolink" ;
    ns1:textoExtracto "Las variables DRV pueden acceder a las variables y/o parámetros de los servos. El acceso a las variables del regulador será siempre de solo lectura, mientras que el acceso a los parámetros podrá ser de lectura o escritura." .

ns1:Variable_DRV_Sercos a ns1:Parametro ;
    rdfs:label "Variables DRV (Sercos)" ;
    ns1:documentadoEn ns1:Tabla_DRVVAR ;
    ns1:identificador "DRV_Sercos" ;
    ns1:textoExtracto "Las variables DRV pueden acceder a las variables del regulador. El acceso a las variables podrá ser solo lectura o de lectura y escritura." .

ns1:Parametro_DRIVEVAR a ns1:Parametro ;
    rdfs:label "Parámetro DRIVEVAR" ;
    ns1:identificador "DRIVEVAR" ;
    ns1:monitoreaParametro ns1:Variable_DRV_Mechatrolink,
        ns1:Variable_DRV_Sercos ;
    ns1:textoExtracto "El parámetro DRIVEVAR permite definir la lista de variables DRV, aquellas que permiten acceder a las variables y/o parámetros de los reguladores digitales desde el programa pieza, modo MDI/MDA, PLC o interfaz." .

