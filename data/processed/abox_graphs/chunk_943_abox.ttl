@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Sistema_Mechatrolink a ns1:Sistema ;
    rdfs:label "Sistema Mechatrolink" ;
    ns1:documentadoEn ns1:Pagina_328_329 ;
    ns1:textoExtracto "Características y limitaciones de los dispositivos Mechatrolink." ;
    ns1:tieneComponente ns1:ModoOperacion_MLink_II .

ns1:ModoOperacion_MLink_II a ns1:ModoOperacion ;
    rdfs:label "Modo MLink-II" ;
    ns1:documentadoEn ns1:Pagina_328_329 ;
    ns1:textoExtracto "El acceso a variables y/o parámetros de los dispositivos sólo está disponible para el modo Mlink-II a 32 bytes." .

ns1:Parametro_DATA a ns1:Parametro ;
    rdfs:label "DATA" ;
    ns1:documentadoEn ns1:Tabla_DRIVEVAR ;
    ns1:identificador "DRV.DATA" ;
    ns1:textoExtracto "DATA Variables de los reguladores. Este parámetro muestra la tabla para definir la lista de variables DRV." .

ns1:Parametro_SIZE a ns1:Parametro ;
    rdfs:label "SIZE" ;
    ns1:documentadoEn ns1:Tabla_DRIVEVAR ;
    ns1:identificador "DRV.SIZE" ;
    ns1:textoExtracto "SIZE Número de variables a consultar en el regulador. Valores posibles: De 0 a 99. Valor por defecto: 0. Variable asociada: (V.)DRV.SIZE" ;
    ns1:valor 0 .

ns1:Tabla_DRIVEVAR a ns1:Tabla ;
    rdfs:label "Tabla DRIVEVAR" ;
    ns1:documentadoEn ns1:Pagina_328_329 ;
    ns1:textoExtracto "| DRIVEVAR |  | --- | --- | SIZE | Número de elementos de la tabla de variables del regulador | DATA | Variables de los reguladores." ;
    ns1:tieneComponente ns1:Parametro_DATA,
        ns1:Parametro_SIZE .

ns1:Pagina_328_329 a ns1:Pagina ;
    rdfs:label "Páginas 328-329" ;
    ns1:ilustradoEn ns1:Manual_Tecnico ;
    ns1:textoExtracto "2.12 Parámetros máquina OEM. - 2.12.1 Lectura de variables del regulador (Sercos o Mechatrolink)." .

