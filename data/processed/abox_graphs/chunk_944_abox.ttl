@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_AXIS a ns1:Parametro ;
    rdfs:label "AXIS"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosRegulador_SercosMechatrolink ;
    ns1:identificador "AXIS" ;
    ns1:textoExtracto "Nombre del eje o cabezal al que accede la variable; si se define como \"*\", todos los ejes y cabezales."@es .

ns1:Parametro_ID_Mechatrolink a ns1:Parametro ;
    rdfs:label "ID (Mechatrolink)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosRegulador_SercosMechatrolink ;
    ns1:identificador "ID_Mechatrolink" ;
    ns1:textoExtracto "Identificador del parámetro (0000-FFFF) o de la variable (0-F) a consultar en el dispositivo."@es .

ns1:Parametro_ID_Sercos a ns1:Parametro ;
    rdfs:label "ID (Sercos)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosRegulador_SercosMechatrolink ;
    ns1:identificador "ID_Sercos" ;
    ns1:textoExtracto "Identificador ID Sercos de la variable a consultar en el regulador."@es .

ns1:Parametro_MNEMONIC a ns1:Parametro ;
    rdfs:label "MNEMONIC"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosRegulador_SercosMechatrolink ;
    ns1:identificador "MNEMONIC" ;
    ns1:textoExtracto "Mnemónico asignado a la variable DRV. El acceso a la variable desde el CNC será de la forma: (V.)DRV.{mnemónico}.{eje} / (V.)DRV.{mnemónico}.{cabezal}"@es .

ns1:Parametro_MODE a ns1:Parametro ;
    rdfs:label "MODE"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosRegulador_SercosMechatrolink ;
    ns1:identificador "MODE" ;
    ns1:textoExtracto "Modo de acceso. El acceso a las variables podrá ser solo lectura o de lectura y escritura."@es .

ns1:Parametro_TYPE_Mechatrolink a ns1:Parametro ;
    rdfs:label "TYPE (Mechatrolink)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosRegulador_SercosMechatrolink ;
    ns1:identificador "TYPE_Mechatrolink" ;
    ns1:textoExtracto "Tipo de consulta; variable o parámetro."@es .

ns1:Parametro_TYPE_Sercos a ns1:Parametro ;
    rdfs:label "TYPE (Sercos)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosRegulador_SercosMechatrolink ;
    ns1:identificador "TYPE_Sercos" ;
    ns1:textoExtracto "Tipo de acceso, síncrono o asíncrono. Las variables de acceso síncrono se gestionan a través del canal cíclico. [...] Se recomienda definir las variables con acceso síncrono."@es .

ns1:Sistema_ReguladorMechatrolink a ns1:Sistema ;
    rdfs:label "Regulador Mechatrolink"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_ParametrosRegulador_SercosMechatrolink ;
    ns1:textoExtracto "Para dispositivos Mechatrolink, en cada variable DRV hay que definir los campos MNEMONIC, AXIS, ID, TYPE y MODE."@es .

ns1:Sistema_ReguladorSercos a ns1:Sistema ;
    rdfs:label "Regulador Sercos"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_ParametrosRegulador_SercosMechatrolink ;
    ns1:textoExtracto "Variables de acceso síncrono gestionadas a través del canal cíclico. [...] No todas las variables se pueden definir con acceso síncrono; sólo aquellas que pueden utilizar el canal cíclico de Sercos."@es .

ns1:Tabla_ParametrosRegulador_SercosMechatrolink a ns1:Tabla ;
    rdfs:label "Tabla de parámetros de variables del regulador (Sercos/Mechatrolink)"@es ;
    ns1:textoExtracto """
| Campo    | Significado                                                                                     |
|----------|-------------------------------------------------------------------------------------------------|
| MNEMONIC | Mnemónico asignado a la variable DRV. El acceso desde el CNC será: (V.)DRV.{mnemónico}.{eje/cabezal} |
| AXIS     | Nombre del eje o cabezal al que accede la variable; "*" para todos los ejes/cabezales.         |
| ID       | Identificador ID Sercos (o 0000-FFFF/0-F para Mechatrolink) de la variable/parámetro.          |
| TYPE     | Tipo de acceso (síncrono/asíncrono) o consulta (variable/parámetro).                           |
| MODE     | Modo de acceso (lectura o lectura/escritura).                                                   |
"""@es .

