@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Tabla_684_ParametrosRegulador a ns1:Tabla ;
    rdfs:label "Tabla de parámetros del regulador (Sercos/Mechatrolink)"@es ;
    ns1:detalladoEnEsquema ns1:Parametro_684_Identificador,
        ns1:Parametro_684_ModoAcceso,
        ns1:Parametro_684_TipoConsulta ;
    ns1:documentadoEn ns1:Pagina_328_329 ;
    ns1:textoExtracto "ID | Identificador del parámetro (0000-FFFF) o de la variable (0-F) a consultar en el dispositivo. TYPE | Tipo de consulta; variable o parámetro. MODE | Modo de acceso."@es .

ns1:Parametro_684_Identificador a ns1:Parametro ;
    rdfs:label "Identificador del parámetro (0000-FFFF) o de la variable (0-F)"@es ;
    ns1:identificador "0000-FFFF (parámetro), 0-F (variable)" ;
    ns1:textoExtracto "ID | Identificador del parámetro (0000-FFFF) o de la variable (0-F) a consultar en el dispositivo."@es .

ns1:Parametro_684_ModoAcceso a ns1:Parametro ;
    rdfs:label "Modo de acceso (lectura/escritura o solo lectura)"@es ;
    ns1:textoExtracto "MODE | Modo de acceso. El acceso a las variables del regulador será siempre de solo lectura, mientras que el acceso a los parámetros podrá ser de lectura o escritura."@es ;
    ns1:valor "solo_lectura (variable) , lectura_escritura (parámetro)" .

ns1:Parametro_684_TipoConsulta a ns1:Parametro ;
    rdfs:label "Tipo de consulta (variable o parámetro)"@es ;
    ns1:textoExtracto "TYPE | Tipo de consulta; variable o parámetro."@es ;
    ns1:valor "variable , parámetro" .

