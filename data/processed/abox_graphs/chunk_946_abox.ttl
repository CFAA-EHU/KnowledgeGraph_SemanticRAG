@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_Sincrono a ns1:ModoOperacion ;
    ns1:habilitadoPor ns1:Variable_FFGAIN ;
    ns1:textoExtracto "Para modificar el FFGAIN en modo síncrono... Esta variable debe ser síncrona." .

ns1:Sistema_Regulador a ns1:Sistema ;
    ns1:identificador "V9.10" ;
    ns1:textoExtracto "la versión del regulador debe ser V9.10 o superior. La variable deberá actuar sobre el parámetro PP216 (VelocityFeedForwardPercentage) del regulador." ;
    ns1:tieneComponente ns1:Parametro_PP216,
        ns1:Variable_FFGAIN .

ns1:Parametro_PP216 a ns1:Parametro ;
    rdfs:label "VelocityFeedForwardPercentage" ;
    ns1:documentadoEn ns1:Tabla_DRIVEVAR ;
    ns1:identificador "PP216" ;
    ns1:textoExtracto "La variable deberá actuar sobre el parámetro PP216 (VelocityFeedForwardPercentage) del regulador. Las unidades de la variable serán las del regulador (en centésimas). IDN Sercos 00296 para el porcentaje de feed-forward (PP216)." ;
    ns1:valor "centésimas" .

ns1:Tabla_DRIVEVAR a ns1:Tabla ;
    ns1:identificador "DRIVEVAR" ;
    ns1:textoExtracto "En la tabla DRIVEVAR, definir la variable de la siguiente manera. | Campo | Significado | --- | --- | MNEMONIC | Mnemónico asignado a la variable DRV. | AXIS | Número de nodo del regulador. | ID | IDN Sercos de la variable a consultar en el regulador. IDN Sercos 00296 para el porcentaje de feed-forward (PP216). | TYPE | Esta variable debe ser síncrona. | MODE | El acceso a la variable debe ser de escritura." .

ns1:Variable_FFGAIN a ns1:Parametro ;
    ns1:documentadoEn ns1:Tabla_DRIVEVAR ;
    ns1:identificador "FFGAIN" ;
    ns1:monitoreaParametro ns1:Parametro_PP216 ;
    ns1:textoExtracto "Para modificar el FFGAIN en modo síncrono... La variable deberá actuar sobre el parámetro PP216 (VelocityFeedForwardPercentage) del regulador." .

