@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoAccesoEscritura a ns1:ModoOperacion ;
    rdfs:label "Modo de acceso de escritura"@es ;
    ns1:textoExtracto "El acceso a la variable debe ser de escritura."@es .

ns1:ModoSincrono a ns1:ModoOperacion ;
    rdfs:label "Modo síncrono"@es ;
    ns1:textoExtracto "Modificar el FFGAIN en el regulador (PP216) en modo síncrono."@es .

ns1:ReguladorEjeX a ns1:Componente ;
    rdfs:label "Regulador del eje X"@es ;
    ns1:textoExtracto "Se desea modificar el FFGAIN del eje X (nodo 2)."@es .

ns1:ReguladorPP216 a ns1:Componente ;
    rdfs:label "Regulador PP216"@es ;
    ns1:identificador "PP216" ;
    ns1:textoExtracto "Modificar el FFGAIN en el regulador (PP216) en modo síncrono."@es .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC"@es ;
    ns1:textoExtracto "El acceso desde el CNC será V.DRV.FFGAIN.2"@es .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC"@es ;
    ns1:textoExtracto "El acceso desde el PLC será DRV.FFGAIN.2"@es .

ns1:VariableFFGAIN_X a ns1:Parametro ;
    rdfs:label "FFGAIN del eje X"@es ;
    ns1:identificador "V.DRV.FFGAIN.2" ;
    ns1:textoExtracto "Se desea modificar el FFGAIN del eje X (nodo 2). El acceso desde el CNC será V.DRV.FFGAIN.2 El acceso desde el PLC será DRV.FFGAIN.2 V.DRV.FFGAIN.2=9000 (Aplicar un feed-forward en el segundo regulador del 90 %)."@es .

