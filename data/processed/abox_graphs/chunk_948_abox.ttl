@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Pagina_331_332 a ns1:Pagina ;
    ns1:identificador "331-332" ;
    ns1:textoExtracto "Los valores de la tabla pueden ser modificados en cualquier momento... Los valores de la tabla de simulación sólo pueden ser leídos o modificados a través de su variable." .

ns1:Parametro_DATA_MTBPAR a ns1:Parametro ;
    rdfs:label "DATA (Lista de parámetros del fabricante)" ;
    ns1:identificador "MTB.DATA" ;
    ns1:monitoreaParametro ns1:TablaParametrosFabricante_MTBPAR ;
    ns1:textoExtracto "DATA Lista de parámetros del fabricante. Este parámetro muestra la tabla de parámetros del fabricante. Para cada parámetro hay que definir los siguientes campos." .

ns1:Parametro_SIZE_MTBPAR a ns1:Parametro ;
    rdfs:label "SIZE (Número de parámetros del fabricante)" ;
    ns1:identificador "MTB.SIZE" ;
    ns1:monitoreaParametro ns1:TablaParametrosFabricante_MTBPAR ;
    ns1:textoExtracto "SIZE Número de parámetros del fabricante. Valores posibles: De 0 a 1000. Valor por defecto: 0. Variable asociada: (V.)MTB.SIZE Este parámetro establece el número de parámetros de fabricante que se van a utilizar." ;
    ns1:valor 0 .

ns1:TablaParametrosFabricante_MTBPAR a ns1:Tabla ;
    rdfs:label "MTBPAR" ;
    ns1:documentadoEn ns1:Pagina_331_332 ;
    ns1:identificador "MTBPAR" ;
    ns1:textoExtracto "MTBPAR Tabla de parámetros del fabricante. Esta tabla ofrece 1000 parámetros genéricos para que el fabricante los pueda utilizar a modo de parámetros máquina." ;
    ns1:tieneComponente ns1:Parametro_DATA_MTBPAR,
        ns1:Parametro_SIZE_MTBPAR .

