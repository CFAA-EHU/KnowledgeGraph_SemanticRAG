@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ParametroFabricante_COMMENT a ns1:Parametro ;
    rdfs:label "Parámetro COMMENT (descripción OEM)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosFabricante_688 ;
    ns1:textoExtracto "COMMENT Descripción del parámetro OEM."@es .

ns1:ParametroFabricante_INCHES a ns1:Parametro ;
    rdfs:label "Parámetro INCHES (afectación por unidades)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosFabricante_688 ;
    ns1:textoExtracto "INCHES El parámetro se ve afectado por el cambio de unidades."@es .

ns1:ParametroFabricante_MODE a ns1:Parametro ;
    rdfs:label "Parámetro MODE (modo de acceso)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosFabricante_688 ;
    ns1:textoExtracto "MODE Modo de acceso al parámetro desde su variable."@es .

ns1:VariableAcceso_MTB_P a ns1:InterfazUsuario ;
    rdfs:label "Variable MTB.P[i] (lectura/escritura de parámetro [i])"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosFabricante_688 ;
    ns1:monitoreaParametro ns1:ParametroFabricante_VALUE ;
    ns1:textoExtracto "(V.)MTB.P[i] Valor del parámetro de fabricante [i]."@es .

ns1:VariableAcceso_MTB_PF a ns1:InterfazUsuario ;
    rdfs:label "Variable MTB.PF[i] (valor escalado ×10000 del parámetro [i])"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosFabricante_688 ;
    ns1:monitoreaParametro ns1:ParametroFabricante_VALUE ;
    ns1:textoExtracto "(V.)MTB.PF[i] Valor del parámetro de fabricante [i]. Valor por 10000."@es .

ns1:ParametroFabricante_VALUE a ns1:Parametro ;
    rdfs:label "Parámetro VALUE (valor numérico)"@es ;
    ns1:documentadoEn ns1:Tabla_ParametrosFabricante_688 ;
    ns1:textoExtracto "VALUE Valor del parámetro. Valores posibles: Entre ±99999.9999. Valor por defecto: 0."@es ;
    ns1:valor "±99999.9999" .

ns1:Tabla_ParametrosFabricante_688 a ns1:Tabla ;
    rdfs:label "Tabla de parámetros genéricos del fabricante (pág. 331-332)"@es ;
    ns1:documentadoEn ns1:Manual_Broaching ;
    ns1:textoExtracto """
    | DATA |  |
    | --- | --- |
    | VALUE | Valor del parámetro. |
    | MODE | Modo de acceso al parámetro desde su variable. |
    | INCHES | El parámetro se ve afectado por el cambio de unidades. |
    | COMMENT | Descripción del parámetro OEM.
    VALUE Valor del parámetro. Valores posibles: Entre ±99999.9999. Valor por defecto: 0."""@es .

