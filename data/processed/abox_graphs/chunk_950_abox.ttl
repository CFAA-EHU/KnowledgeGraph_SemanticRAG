@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoSetup a ns1:ModoOperacion ;
    rdfs:label "Modo Setup"@es ;
    ns1:textoExtracto """
Modo Setup. Las variables pueden modificar los parámetros de solo lectura, desde un programa pieza. Las variables pueden escribir los parámetros con permiso de escritura y de solo lectura. Los nuevos valores se mantienen tras reiniciar o apagar el CNC."""@es .

ns1:ModoUser a ns1:ModoOperacion ;
    rdfs:label "Modo User"@es ;
    ns1:textoExtracto """
Modo User. Las variables sólo pueden escribir los parámetros con permiso de escritura. Los nuevos valores se mantienen tras reiniciar o apagar el CNC."""@es .

ns1:ParametroCOMMENT a ns1:Parametro ;
    rdfs:label "Parámetro COMMENT (Descripción OEM)"@es ;
    ns1:identificador "COMMENT" ;
    ns1:textoExtracto """
COMMENT Descripción del parámetro OEM. Este campo ofrece la posibilidad de asociar una pequeña descripción al parámetro. Este campo es informativo; no es utilizado por el CNC."""@es .

ns1:ParametroINCHES a ns1:Parametro ;
    rdfs:label "Parámetro INCHES (Cambio de unidades)"@es ;
    ns1:identificador "INCHES" ;
    ns1:textoExtracto """
INCHES El parámetro se ve afectado por el cambio de unidades. Valores posibles: Sí / No. Valor por defecto: Sí."""@es ;
    ns1:valor "Sí" .

ns1:ParametroMODE a ns1:Parametro ;
    rdfs:label "Parámetro MODE (Modo de acceso)"@es ;
    ns1:identificador "MODE" ;
    ns1:textoExtracto """
MODE Modo de acceso al parámetro desde su variable. Valores posibles: Lectura / Escritura. Valor por defecto: Lectura."""@es ;
    ns1:valor "Lectura" .

ns1:TablaParametrosMTB a ns1:Tabla ;
    rdfs:label "Tabla de parámetros genéricos V.MTB.P[i]"@es ;
    ns1:textoExtracto """
| Mnemónico. | Valor. | V.MTB.P[i] | V.MTB.PF[i] |
| --- | --- | --- | --- |
| P0 | 7 | V.MTB.P[0] = 7 | V.MTB.PF[0] = 70000 |
| P8 | 12,5 | V.MTB.P[8] = 12,5 | V.MTB.PF[8] = 125000"""@es ;
    ns1:tieneComponente ns1:ParametroP0,
        ns1:ParametroP8 .

ns1:ParametroP0 a ns1:Parametro ;
    rdfs:label "Parámetro V.MTB.P[0]"@es ;
    ns1:identificador "P0" ;
    ns1:textoExtracto "V.MTB.P[0] = 7"@es ;
    ns1:valor "7" .

ns1:ParametroP8 a ns1:Parametro ;
    rdfs:label "Parámetro V.MTB.P[8]"@es ;
    ns1:identificador "P8" ;
    ns1:textoExtracto "V.MTB.P[8] = 12,5"@es ;
    ns1:valor "12.5" .

