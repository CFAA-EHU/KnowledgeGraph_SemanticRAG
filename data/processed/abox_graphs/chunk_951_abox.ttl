@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Archivo_MTBComments a ns1:InterfazUsuario ;
    rdfs:label "Archivo MTBComments.txt"@es ;
    ns1:documentadoEn ns1:Parametro_OEM ;
    ns1:identificador "MTBComments.txt" ;
    ns1:textoExtracto "Los comentarios se guardan en el archivo MTBComments.txt y se puede tener un archivo por cada idioma. Estos archivos se guardan en la carpeta ..\\MTB\\Data\\Lang."@es .

ns1:Parametro_OEM a ns1:Parametro ;
    rdfs:label "Parámetro OEM"@es ;
    ns1:identificador "OEM" ;
    ns1:textoExtracto "Descripción del parámetro OEM. Este campo ofrece la posibilidad de asociar una pequeña descripción al parámetro. Este campo es informativo; no es utilizado por el CNC."@es .

