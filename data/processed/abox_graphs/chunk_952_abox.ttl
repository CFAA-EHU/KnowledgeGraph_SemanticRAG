@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ParametroDATA a ns1:Parametro ;
    rdfs:label "DATA" ;
    ns1:documentadoEn ns1:TablaCAMTABLE ;
    ns1:identificador "DATA" ;
    ns1:textoExtracto "Lista de levas electrónicas. Este parámetro muestra la lista de levas disponibles." .

ns1:ParametroSIZE a ns1:Parametro ;
    rdfs:label "SIZE" ;
    ns1:documentadoEn ns1:TablaCAMTABLE ;
    ns1:identificador "SIZE" ;
    ns1:monitoreaParametro ns1:SistemaLevas ;
    ns1:textoExtracto "Número de levas electrónicas. Valores posibles: De 0 a 16. Valor por defecto: 0. Parámetro incluido en la tabla CAMTABLE." ;
    ns1:valor 0 .

ns1:SistemaLevas a ns1:Sistema ;
    rdfs:label "Sistema de levas electrónicas" ;
    ns1:textoExtracto "Este parámetro establece el número de levas electrónicas del sistema." ;
    ns1:tieneComponente ns1:EditorLevas .

ns1:EditorLevas a ns1:InterfazUsuario ;
    rdfs:label "Editor de levas" ;
    ns1:textoExtracto "El editor de levas es un elemento gráfico de ayuda para el diseño de levas." .

ns1:TablaCAMTABLE a ns1:Tabla ;
    rdfs:label "CAMTABLE" ;
    ns1:detalladoEnEsquema ns1:EditorLevas ;
    ns1:textoExtracto "Tabla de levas electrónicas. Esta tabla muestra los parámetros para definir las levas electrónicas." .

