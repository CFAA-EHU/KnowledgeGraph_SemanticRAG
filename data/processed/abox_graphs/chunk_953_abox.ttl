@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ManualEditorLevas_692 a ns1:Manual ;
    rdfs:label "Manual específico del editor de levas"@es ;
    ns1:documentadoEn ns1:EditorLevasElectronicas_692 ;
    ns1:textoExtracto "Esta funcionalidad dispone de un manual específico."@es .

ns1:ParametroAceleracion_692 a ns1:Parametro ;
    rdfs:label "aceleración"@es ;
    ns1:monitoreaParametro ns1:EditorLevasElectronicas_692 ;
    ns1:textoExtracto "edición de valores de [...] aceleración"@es .

ns1:ParametroJerk_692 a ns1:Parametro ;
    rdfs:label "jerk"@es ;
    ns1:monitoreaParametro ns1:EditorLevasElectronicas_692 ;
    ns1:textoExtracto "edición de valores de [...] jerk"@es .

ns1:ParametroVelocidad_692 a ns1:Parametro ;
    rdfs:label "velocidad"@es ;
    ns1:monitoreaParametro ns1:EditorLevasElectronicas_692 ;
    ns1:textoExtracto "edición de valores de velocidad"@es .

ns1:ListaLevasElectronicas_692 a ns1:Parametro ;
    rdfs:label "Lista de levas electrónicas"@es ;
    ns1:identificador "DATA" ;
    ns1:textoExtracto "DATA Lista de levas electrónicas. Este parámetro muestra la lista de levas disponibles."@es .

ns1:EditorLevasElectronicas_692 a ns1:InterfazUsuario ;
    rdfs:label "Editor de levas electrónicas"@es ;
    ns1:identificador "CAM n" ;
    ns1:monitoreaParametro ns1:ListaLevasElectronicas_692 ;
    ns1:textoExtracto "CAM n Editor de levas electrónicas. Editor de levas que ofrece una cómoda asistencia para analizar el comportamiento de la leva proyectada a través de las facilidades gráficas de edición de valores de velocidad, aceleración y jerk."@es .

