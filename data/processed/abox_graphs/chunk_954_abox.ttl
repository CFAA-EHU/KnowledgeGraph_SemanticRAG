@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_CNC_001 a ns1:AvisoSeguridad ;
    rdfs:label "Código de error por falta de fichero ejecutable PLC"@es ;
    ns1:textoExtracto "si no existe [el programa ejecutable], el CNC mostrará el código de error correspondiente"@es .

ns1:IntercambioDatos_CNC_PLC a ns1:InterfazUsuario ;
    rdfs:label "Intercambio automático de información CNC-PLC"@es ;
    ns1:textoExtracto "Existe un intercambio de información entre el CNC y el PLC que se realiza de modo automático. Desde el PLC se puede: Consultar y/o modificar las variables de intercambio CNC-PLC. Desde el CNC se puede: Transferir las funciones auxiliares M, H y S"@es .

ns1:PLC_ProgramaEjecutable a ns1:Sistema ;
    rdfs:label "Programa ejecutable del PLC"@es ;
    ns1:controla ns1:ModuloRemoto_EntradasSalidas ;
    ns1:monitoreaParametro ns1:ParametroMaquinaGeneral_001 ;
    ns1:textoExtracto "El programa de PLC tiene estructura modular y puede combinar ficheros en lenguaje de mnemónicos, lenguaje de contactos o lenguaje C. Para que el programa pueda ser ejecutado, hay que generar el fichero objeto (fichero ejecutable). Tras el encendido, el CNC ejecuta el programa ejecutable del PLC almacenado en memoria"@es .

ns1:ModuloRemoto_EntradasSalidas a ns1:ComponenteElectrico ;
    rdfs:label "Módulos remotos de entradas/salidas físicas"@es ;
    ns1:textoExtracto "Controlar las entradas y salidas físicas (módulos remotos)"@es .

ns1:ParametroMaquinaGeneral_001 a ns1:Parametro ;
    rdfs:label "Parámetro máquina general (p.m.g.)"@es ;
    ns1:identificador "p.m.g." ;
    ns1:textoExtracto "Parámetro máquina general (p.m.g.)"@es .

