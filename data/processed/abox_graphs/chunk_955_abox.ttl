@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramaPLC_694 a ns1:Sistema ;
    rdfs:label "Programa PLC combinado (mnemónicos, contactos, C)"@es ;
    ns1:compuestoPor ns1:FicheroContactos_694,
        ns1:FicheroLenguajeC_694,
        ns1:FicheroMnemotecnicos_694 ;
    ns1:identificador "\\MTB\\PLC\\PROJECT" ;
    ns1:textoExtracto "El programa de PLC puede combinar varios ficheros en lenguaje de mnemónicos (extensión \"plc\"), varios ficheros en lenguaje C (extensión \"c\") y un fichero en lenguaje de contactos (extensión \"ld\"). Todos los ficheros que componen el programa PLC deben estar en el directorio \\MTB\\PLC\\PROJECT."@es ;
    ns1:tieneComponente ns1:SubrutinaSUMA_694 .

ns1:FicheroContactos_694 a ns1:Componente ;
    rdfs:label "Fichero en lenguaje de contactos (extensión .ld)"@es ;
    ns1:identificador "*.ld" ;
    ns1:textoExtracto "un fichero en lenguaje de contactos (extensión \"ld\")"@es .

ns1:FicheroLenguajeC_694 a ns1:Componente ;
    rdfs:label "Fichero en lenguaje C (extensión .c)"@es ;
    ns1:identificador "*.c" ;
    ns1:textoExtracto "ficheros en lenguaje C (extensión \"c\")... para tareas auxiliares (por ejemplo, compensación de temperatura)"@es .

ns1:FicheroMnemotecnicos_694 a ns1:Componente ;
    rdfs:label "Fichero en lenguaje mnemotécnico (extensión .plc)"@es ;
    ns1:identificador "*.plc" ;
    ns1:textoExtracto "ficheros en lenguaje de mnemónicos (extensión \"plc\")... Se aconseja utilizar los ficheros en lenguaje de mnemónicos o de contactos como programa principal del PLC"@es .

ns1:SubrutinaSUMA_694 a ns1:Componente ;
    rdfs:label "Subrutina SUMA (mnemotécnico/C)"@es ;
    ns1:identificador "SUMA" ;
    ns1:textoExtracto "Las subrutinas del programa en lenguaje de mnemónicos... hay que definirlas fuera de los módulos... El nombre de la subrutina debe estar redactado en mayúsculas en ambos ficheros. | SUB SUMA ()= ADS R201 R202 R203 | void SUMA (void) { R203=R201+R202; }"@es .

