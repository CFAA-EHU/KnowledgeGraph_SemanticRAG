@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:EstructuraModular_PLC a ns1:Sistema ;
    rdfs:label "Estructura modular del programa de PLC"@es ;
    ns1:compuestoPor ns1:ModuloEjecucionPeriodica_PLC,
        ns1:ModuloPrimerCiclo_PLC,
        ns1:ModuloPrincipal_PLC ;
    ns1:textoExtracto "El programa PLC puede estar formado por los siguientes módulos. Cada módulo debe empezar con la proposición directiva que lo define (CY1, PRG, PE) y finalizar con la proposición directiva END."@es .

ns1:ParametroLOOPTIME a ns1:Parametro ;
    rdfs:label "Tiempo de lazo (LOOPTIME)"@es ;
    ns1:identificador "LOOPTIME" ;
    ns1:textoExtracto "periodo de muestreo de 4 ms (LOOPTIME=4)"@es ;
    ns1:valor 4 .

ns1:ModuloEjecucionPeriodica_PLC a ns1:Sistema ;
    rdfs:label "Módulo de ejecución periódica (PE)"@es ;
    ns1:identificador "PE" ;
    ns1:textoExtracto "Módulo de ejecución periódica. [...] El módulo periódico comienza con la proposición directiva PE y termina con la proposición directiva END. El PLC ejecuta el módulo periódico de forma periódica, con la frecuencia fijada en la directiva PE."@es .

ns1:ModuloPrimerCiclo_PLC a ns1:Sistema ;
    rdfs:label "Módulo del primer ciclo (CY1)"@es ;
    ns1:identificador "CY1" ;
    ns1:textoExtracto "Módulo del primer ciclo (CY1). [...] El PLC ejecuta el módulo de primer ciclo una única vez, cuando arranca el programa de PLC. Este módulo permite inicializar los diferentes recursos y variables antes de proceder a la ejecución del programa."@es .

ns1:ModuloPrincipal_PLC a ns1:Sistema ;
    rdfs:label "Módulo principal (PRG)"@es ;
    ns1:identificador "PRG" ;
    ns1:monitoreaParametro ns1:ParametroPRGFREQ ;
    ns1:textoExtracto "Módulo principal. [...] El módulo principal comienza con la proposición directiva PRG y termina con la proposición directiva END. El PLC ejecuta el módulo principal de forma cíclica, con la frecuencia fijada por el parámetro PRGFREQ."@es .

ns1:ParametroPRGFREQ a ns1:Parametro ;
    rdfs:label "Frecuencia de ejecución del módulo principal (PRGFREQ)"@es ;
    ns1:identificador "PRGFREQ" ;
    ns1:textoExtracto "El parámetro PRGFREQ indica con qué frecuencia (cada cuántos ciclos de CNC) el PLC ejecuta un ciclo completo del módulo principal."@es ;
    ns1:valor 2 .

