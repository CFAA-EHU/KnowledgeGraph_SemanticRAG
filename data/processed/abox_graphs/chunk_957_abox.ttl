@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModuloPeriodico_PE30000 a ns1:Sistema ;
    rdfs:label "Módulo periódico PE 30000" ;
    ns1:identificador "PE 30000" ;
    ns1:textoExtracto "Una tarea que es suficiente evaluarla cada 30 segundos se definirá en un módulo periódico que se ejecute cada 30 segundos (PE 30000)" ;
    ns1:tieneFrecuencia ns1:Frecuencia_30segundos .

ns1:Frecuencia_30segundos a ns1:Frecuencia ;
    rdfs:label "Frecuencia de 30 segundos" ;
    ns1:textoExtracto "módulo periódico que se ejecute cada 30 segundos" ;
    ns1:valor "30 segundos" .

