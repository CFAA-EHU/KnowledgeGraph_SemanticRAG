@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PLC_Recursos_ComunicacionCNC a ns1:InterfazUsuario ;
    rdfs:label "Registros y marcas de comunicación CNC-PLC" ;
    ns1:textoExtracto "Registros y marcas de comunicación CNC-PLC." .

ns1:PLC_Recursos_Contadores a ns1:Parametro ;
    rdfs:label "Contadores del PLC" ;
    ns1:identificador "C1-C256" ;
    ns1:textoExtracto "Contadores (C1-C256). Los recursos C [...] mantiene su valor entre arranque y arranque del CNC." .

ns1:PLC_Recursos_EntradasSalidas a ns1:Sistema ;
    rdfs:label "Recursos de E/S del PLC" ;
    ns1:textoExtracto "El PLC dispone de los siguientes recursos. • Entradas (I1-I1024) y salidas (O1-O1024). • Entradas locales (LI1-LI16) y salidas locales (LO1-LO8)." ;
    ns1:tieneComponente ns1:EntradasLocales_LI1_LI16,
        ns1:Entradas_I1_I1024,
        ns1:SalidasLocales_LO1_LO8,
        ns1:Salidas_O1_O1024 .

ns1:PLC_Recursos_Errores a ns1:AvisoSeguridad ;
    rdfs:label "Errores del PLC" ;
    ns1:identificador "ERR1-ERR1024" ;
    ns1:textoExtracto "Errores (ERR1-ERR1024). Los recursos ERR [...] se inicializan a (=0) en el arranque del PLC." .

ns1:PLC_Recursos_Marcas a ns1:Sistema ;
    rdfs:label "Marcas del PLC" ;
    ns1:identificador "M1-M8192" ;
    ns1:textoExtracto "Marcas (M1-M8192). Los recursos M [...] mantiene su valor entre arranque y arranque del CNC." .

ns1:PLC_Recursos_Mensajes a ns1:InterfazUsuario ;
    rdfs:label "Mensajes del PLC" ;
    ns1:identificador "MSG1-MSG1024" ;
    ns1:textoExtracto "Mensajes (MSG1-MSG1024). Los recursos MSG [...] se inicializan a (=0) en el arranque del PLC." .

ns1:PLC_Recursos_Registros a ns1:Parametro ;
    rdfs:label "Registros del PLC" ;
    ns1:identificador "R1-R1024" ;
    ns1:textoExtracto "Registros (R1-R1024). Los recursos R [...] mantiene su valor entre arranque y arranque del CNC." .

ns1:PLC_Recursos_Temporizadores a ns1:Parametro ;
    rdfs:label "Temporizadores del PLC" ;
    ns1:identificador "T1-T512" ;
    ns1:textoExtracto "Temporizadores (T1-T512). Los recursos T [...] se inicializan a (=0) en el arranque del PLC." .

ns1:EntradasLocales_LI1_LI16 a ns1:ComponenteElectrico ;
    rdfs:label "Entradas locales LI1-LI16" ;
    ns1:identificador "LI1-LI16" ;
    ns1:textoExtracto "Entradas locales (LI1-LI16) [...] Las unidades centrales ICU y MCU disponen de 8 entradas digitales [...] Se denominan entradas locales porque se encuentran en la unidad central." .

ns1:Entradas_I1_I1024 a ns1:ComponenteElectrico ;
    rdfs:label "Entradas I1-I1024" ;
    ns1:identificador "I1-I1024" ;
    ns1:textoExtracto "Entradas (I1-I1024) [...] Las entradas son elementos que proporcionan información al PLC de las señales que se reciben del exterior." .

ns1:SalidasLocales_LO1_LO8 a ns1:ComponenteElectrico ;
    rdfs:label "Salidas locales LO1-LO8" ;
    ns1:identificador "LO1-LO8" ;
    ns1:textoExtracto "Salidas locales (LO1-LO8) [...] un conjunto de 8 señales digitales locales que pueden configurarse tanto de entrada como de salida." .

ns1:Salidas_O1_O1024 a ns1:ComponenteElectrico ;
    rdfs:label "Salidas O1-O1024" ;
    ns1:identificador "O1-O1024" ;
    ns1:textoExtracto "Salidas (O1-O1024) [...] Las salidas son elementos que permiten al PLC activar o desactivar los distintos dispositivos o accionamientos del armario eléctrico." .

