@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_EntradasSalidasLocales a ns1:Sistema ;
    rdfs:label "Sistema de entradas y salidas locales del PLC" ;
    ns1:textoExtracto "Se denominan entradas y salidas locales porque se encuentran en la unidad central y no en los módulos remotos." ;
    ns1:tieneComponente ns1:EntradaLocal_LI1,
        ns1:EntradaLocal_LI10,
        ns1:EntradaLocal_LI11,
        ns1:EntradaLocal_LI12,
        ns1:EntradaLocal_LI13,
        ns1:EntradaLocal_LI14,
        ns1:EntradaLocal_LI15,
        ns1:EntradaLocal_LI16,
        ns1:EntradaLocal_LI2,
        ns1:EntradaLocal_LI3,
        ns1:EntradaLocal_LI4,
        ns1:EntradaLocal_LI5,
        ns1:EntradaLocal_LI6,
        ns1:EntradaLocal_LI7,
        ns1:EntradaLocal_LI8,
        ns1:EntradaLocal_LI9,
        ns1:SalidaLocal_LO1,
        ns1:SalidaLocal_LO2,
        ns1:SalidaLocal_LO3,
        ns1:SalidaLocal_LO4,
        ns1:SalidaLocal_LO5,
        ns1:SalidaLocal_LO6,
        ns1:SalidaLocal_LO7,
        ns1:SalidaLocal_LO8 .

ns1:EntradaLocal_LI1 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada local LI1" ;
    ns1:identificador "LI1" ;
    ns1:textoExtracto "Las entradas locales se representan mediante la letra LI seguida del número de entrada, desde LI1 hasta LI16." .

