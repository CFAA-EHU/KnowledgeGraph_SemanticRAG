@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Se_al_ALARM a ns1:AvisoSeguridad ;
    rdfs:label "Señal _ALARM" ;
    ns1:textoExtracto "Los errores no activan la alarma del CNC, señal (_ALARM)." .

ns1:Reloj_CLK1 a ns1:Parametro ;
    rdfs:label "Reloj CLK1" ;
    ns1:identificador "CLK1" ;
    ns1:monitoreaParametro ns1:SistemaRelojesPLC ;
    ns1:textoExtracto "Se representan mediante CLK seguido del número de reloj que se desea referenciar. Todos ellos se inicializan a (=0) en el arranque del PLC." ;
    ns1:valor 0 .

ns1:Reloj_CLK2 a ns1:Parametro ;
    rdfs:label "Reloj CLK2" ;
    ns1:identificador "CLK2" ;
    ns1:monitoreaParametro ns1:SistemaRelojesPLC ;
    ns1:textoExtracto "Se representan mediante CLK seguido del número de reloj que se desea referenciar. Todos ellos se inicializan a (=0) en el arranque del PLC." ;
    ns1:valor 0 .

ns1:SistemaRelojesPLC a ns1:Sistema ;
    rdfs:label "Relojes internos del PLC (CLK)" ;
    ns1:textoExtracto "Relojes (CLK). Son relojes internos de diferentes periodos de tiempo que pueden ser utilizados en el programa de PLC." ;
    ns1:tieneComponente ns1:Reloj_CLK1,
        ns1:Reloj_CLK2 .

