@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:MarcaReloj_CLK_2 a ns1:ComponenteElectrico ;
    rdfs:label "Instancia genérica de marca de reloj CLK"@es ;
    ns1:compuestoPor ns1:PLC_Programa_702 ;
    ns1:identificador "CLK[número]" ;
    ns1:textoExtracto "Se representan mediante CLK seguido del número de reloj que se desea referenciar."@es .

ns1:Parametro_TiempoMedioPeriodo_1 a ns1:Parametro ;
    rdfs:label "Tiempo de medio período (0/1)"@es ;
    ns1:monitoreaParametro ns1:MarcaReloj_CLK_1 ;
    ns1:textoExtracto "medio periodo o cada cuanto tiempo cambia de estado (0/1)"@es ;
    ns1:valor "0"^^xsd:string .

ns1:MarcaReloj_CLK_1 a ns1:ComponenteElectrico ;
    rdfs:label "Marca de reloj CLK (medio período variable)"@es ;
    ns1:compuestoPor ns1:PLC_Programa_702 ;
    ns1:identificador "CLK" ;
    ns1:monitoreaParametro ns1:Parametro_TiempoMedioPeriodo_1 ;
    ns1:textoExtracto "marcas de reloj disponibles. Junto a ellas se indica su medio periodo o cada cuanto tiempo cambia de estado (0/1)."@es .

ns1:PLC_Programa_702 a ns1:Sistema ;
    rdfs:label "Programa de PLC (sección 3.4)"@es ;
    ns1:identificador "CLK" ;
    ns1:textoExtracto "en el programa de PLC. Se representan mediante CLK seguido del número de reloj que se desea referenciar. Todos ellos se inicializan a (=0) en el arranque del PLC."@es ;
    ns1:tieneComponente ns1:MarcaReloj_CLK_1,
        ns1:MarcaReloj_CLK_2 .

