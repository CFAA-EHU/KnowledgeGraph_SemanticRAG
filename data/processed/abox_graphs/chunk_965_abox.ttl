    rdfs:label "CLK12800"@es ;
    ns1:documentadoEn ns1:Tabla_RegistrosPLC ;
    ns1:identificador "CLK12800" ;
    ns1:textoExtracto "CLK12800 | 12.8 s"@es ;
    ns1:valor "12.8 s"^^xsd:string .

ns1:Parametro_CLK128000 a ns1:Parametro ;
    rdfs:label "CLK128000"@es ;
    ns1:documentadoEn ns1:Tabla_RegistrosPLC ;
    ns1:identificador "CLK128000" ;
    ns1:textoExtracto "CLK128000 | 128 s"@es ;
    ns1:valor "128 s"^^xsd:string .

ns1:Parametro_CLK32 a ns1:Parametro ;
    rdfs:label "CLK32"@es ;
    ns1:documentadoEn ns1:Tabla_RegistrosPLC ;
    ns1:identificador "CLK32" ;
    ns1:textoExtracto "CLK32 | 32 ms"@es ;
    ns1:valor "32 ms"^^xsd:string .

ns1:Parametro_CLK3200 a ns1:Parametro ;
    rdfs:label "CLK3200"@es ;
    ns1:documentadoEn ns1:Tabla_RegistrosPLC ;
    ns1:identificador "CLK3200" ;
    ns1:textoExtracto "CLK3200 | 3.2 s"@es ;
    ns1:valor "3.2 s"^^xsd:string .

ns1:Parametro_CLK32000 a ns1:Parametro ;
    rdfs:label "CLK32000"@es ;
    ns1:documentadoEn ns1:Tabla_RegistrosPLC ;
    ns1:identificador "CLK32000" ;
    ns1:textoExtracto "CLK32000 | 32 s"@es ;
    ns1:valor "32 s"^^xsd:string .

ns1:Parametro_CLK64 a ns1:Parametro ;
    rdfs:label "CLK64"@es ;
    ns1:documentadoEn ns1:Tabla_RegistrosPLC ;
    ns1:identificador "CLK64" ;
    ns1:textoExtracto "CLK64 | 64 ms"@es ;
    ns1:valor "64 ms"^^xsd:string .

ns1:Parametro_CLK6400 a ns1:Parametro ;
    rdfs:label "CLK6400"@es ;
    ns1:documentadoEn ns1:Tabla_RegistrosPLC ;
    ns1:identificador "CLK6400" ;
    ns1:textoExtracto "CLK6400 | 6.4 s"@es ;
    ns1:valor "6.4 s"^^xsd:string .

ns1:Parametro_CLK64000 a ns1:Parametro ;
    rdfs:label "CLK64000"@es ;
    ns1:documentadoEn ns1:Tabla_RegistrosPLC ;
    ns1:identificador "CLK64000" ;
    ns1:textoExtracto "CLK64000 | 64 s"@es ;
    ns1:valor "64 s"^^xsd:string .

ns1:Tabla_RegistrosPLC a ns1:Tabla ;
    rdfs:label "Tabla de recursos temporales del PLC (registros, temporizadores, contadores)"@es ;
    ns1:textoExtracto """
| CLK32 | 32 ms | CLK3200 | 3.2 s | CLK32000 | 32 s |
| CLK64 | 64 ms | CLK6400 | 6.4 s | CLK64000 | 64 s |
| CLK128 | 128 ms | CLK12800 | 12.8 s | CLK128000 | 128 s |
Registros (R1-R1024). Son elementos que permiten almacenar en 32 bits una variable numérica. [...]
Temporizadores (T1-T512). Son elementos capaces de mantener su salida al mismo nivel lógico durante un determinado tiempo [...]
Contadores (C1-C256). Son elementos capaces de contar o descontar una cantidad determinada de sucesos.""" .

