@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Componente_ContadoresPLC a ns1:Componente ;
    rdfs:label "Contadores del PLC (C1-C256)"@es ;
    ns1:documentadoEn ns1:Tabla_RegistrosPLC ;
    ns1:identificador "C1-C256" ;
    ns1:textoExtracto "Contadores (C1-C256). Son elementos capaces de contar o descontar una cantidad determinada de sucesos."@es .

ns1:Componente_RegistrosPLC a ns1:Componente ;
    rdfs:label "Registros del PLC (R1-R1024)"@es ;
    ns1:documentadoEn ns1:Tabla_RegistrosPLC ;
    ns1:identificador "R1-R1024" ;
    ns1:textoExtracto "Registros (R1-R1024). Son elementos que permiten almacenar en 32 bits una variable numérica. El valor almacenado en cada registro será considerado como un número entero con signo, entre ± 2.147.483.647. Puede ser tratado como número decimal o hexadecimal (precedido por el carácter \"$\"). Por ejemplo: 156 (Decimal) $9C (Hexadecimal)."@es .

ns1:Componente_TemporizadoresPLC a ns1:Componente ;
    rdfs:label "Temporizadores del PLC (T1-T512)"@es ;
    ns1:documentadoEn ns1:Tabla_RegistrosPLC ;
    ns1:identificador "T1-T512" ;
    ns1:textoExtracto "Temporizadores (T1-T512). Son elementos capaces de mantener su salida al mismo nivel lógico durante un determinado tiempo (constante de tiempo), pasado el cual, su salida cambia de estado. Todos los temporizadores se inicializan a (=0) en el arranque del PLC."@es .

ns1:Parametro_CLK128 a ns1:Parametro ;
    rdfs:label "CLK128"@es ;
    ns1:documentadoEn ns1:Tabla_RegistrosPLC ;
    ns1:identificador "CLK128" ;
    ns1:textoExtracto "CLK128 | 128 ms"@es ;
    ns1:valor "128 ms"^^xsd:string .

