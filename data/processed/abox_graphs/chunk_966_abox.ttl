@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Se_al_CNCREADY a ns1:Sensor ;
    rdfs:label "CNCREADY" ;
    ns1:identificador "CNCREADY" ;
    ns1:textoExtracto "Señales de consulta: CNCREADY, START, FHOUT, ..." .

ns1:Se_al_EMERGEN a ns1:Actuador ;
    rdfs:label "_EMERGEN" ;
    ns1:identificador "_EMERGEN" ;
    ns1:textoExtracto "Señales modificables: _EMERGEN, _STOP, _FEEDHOL, ..." .

ns1:Se_al_FEEDHOL a ns1:Actuador ;
    rdfs:label "_FEEDHOL" ;
    ns1:identificador "_FEEDHOL" ;
    ns1:textoExtracto "Señales modificables: _EMERGEN, _STOP, _FEEDHOL, ..." .

ns1:Se_al_FHOUT a ns1:Sensor ;
    rdfs:label "FHOUT" ;
    ns1:identificador "FHOUT" ;
    ns1:textoExtracto "Señales de consulta: CNCREADY, START, FHOUT, ..." .

ns1:Se_al_START a ns1:Sensor ;
    rdfs:label "START" ;
    ns1:identificador "START" ;
    ns1:textoExtracto "Señales de consulta: CNCREADY, START, FHOUT, ..." .

ns1:Se_al_STOP a ns1:Actuador ;
    rdfs:label "_STOP" ;
    ns1:identificador "_STOP" ;
    ns1:textoExtracto "Señales modificables: _EMERGEN, _STOP, _FEEDHOL, ..." .

