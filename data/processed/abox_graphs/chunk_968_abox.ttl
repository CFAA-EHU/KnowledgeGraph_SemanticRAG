@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Temporizador_Generico a ns1:ComponenteElectrico ;
    rdfs:label "Temporizador (genérico)"@es ;
    ns1:textoExtracto "Todos los temporizadores disponen de la salida de estado T y de las entradas TEN, TRS, TG1, TG2, TG3 y TG4. También es posible consultar en cualquier momento el tiempo t que lleva transcurrido desde que se activó el temporizador."@es ;
    ns1:tieneComponente ns1:Entrada_TEN,
        ns1:Entrada_TG1,
        ns1:Entrada_TG2,
        ns1:Entrada_TG3,
        ns1:Entrada_TG4,
        ns1:Entrada_TRS,
        ns1:Parametro_Tiempo_Transcurrido,
        ns1:Salida_Estado_T .

ns1:Entrada_TEN a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de enable (TEN)"@es ;
    ns1:identificador "TEN" ;
    ns1:monitoreaParametro ns1:Parametro_Enable_Temporizador ;
    ns1:textoExtracto "(TEN) Entrada de enable. Permite detener y reanudar la temporización. Se referencia mediante las letras TEN seguidas del número de temporizador, por ejemplo TEN 1, TEN 25, TEN 102, etc."@es .

ns1:Entrada_TEN_T10 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada TEN del temporizador T10"@es ;
    ns1:controla ns1:Temporizador_T10 ;
    ns1:identificador "TEN 10" ;
    ns1:textoExtracto "I2 = TEN 10"@es .

ns1:Entrada_TG1 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de tiempo TG1"@es ;
    ns1:identificador "TG1" ;
    ns1:textoExtracto "entradas [...] TG1"@es .

ns1:Entrada_TG2 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de tiempo TG2"@es ;
    ns1:identificador "TG2" ;
    ns1:textoExtracto "entradas [...] TG2"@es .

ns1:Entrada_TG3 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de tiempo TG3"@es ;
    ns1:identificador "TG3" ;
    ns1:textoExtracto "entradas [...] TG3"@es .

ns1:Entrada_TG4 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de tiempo TG4"@es ;
    ns1:identificador "TG4" ;
    ns1:textoExtracto "entradas [...] TG4"@es .

ns1:Entrada_TRS a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de reset (TRS)"@es ;
    ns1:identificador "TRS" ;
    ns1:textoExtracto "(TRS) Entrada de reset. Permite inicializar el temporizador, asignando el valor 0 a su estado T y cancelando su cuenta. Se referencia mediante las letras TRS seguidas del número de temporizador, por ejemplo TRS 1, TRS 25, TRS 102, etc."@es .

ns1:Parametro_Enable_Temporizador a ns1:Parametro ;
    rdfs:label "Estado de enable del temporizador"@es ;
    ns1:textoExtracto "si se pone la entrada TEN a (=0) el PLC detiene la temporización, siendo necesario poner la entrada TEN a (=1) para que dicha temporización continúe"@es ;
    ns1:valor 0,
        1 .

ns1:Parametro_Tiempo_Transcurrido a ns1:Parametro ;
    rdfs:label "Tiempo transcurrido (t)"@es ;
    ns1:identificador "t" ;
    ns1:textoExtracto "es posible consultar en cualquier momento el tiempo t que lleva transcurrido desde que se activó el temporizador"@es .

ns1:Salida_Estado_T a ns1:ComponenteElectrico ;
    rdfs:label "Salida de estado T"@es ;
    ns1:identificador "T" ;
    ns1:textoExtracto "Todos los temporizadores disponen de la salida de estado T"@es .

ns1:Temporizador_T10 a ns1:ComponenteElectrico ;
    rdfs:label "Temporizador T10"@es ;
    ns1:identificador "T10" ;
    ns1:textoExtracto "I2 = TEN 10. La entrada I2 controla la entrada de enable del temporizador T10"@es ;
    ns1:tieneComponente ns1:Entrada_TEN_T10 .

