@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Entrada_I3 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada I3 (Reset T10)" ;
    ns1:controla ns1:Temporizador_T10 ;
    ns1:identificador "I3" ;
    ns1:textoExtracto "Por defecto y cada vez que se activa un temporizador el PLC pone esta entrada a (=0). I3 = TRS 10. La entrada I3 controla la entrada de reset del temporizador T10." .

ns1:Entrada_TG1 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada TG1 (Modo monoestable)" ;
    ns1:controla ns1:Temporizador_T10 ;
    ns1:identificador "TG1" ;
    ns1:textoExtracto "TG1 activa el modo monoestable." .

ns1:Entrada_TG2 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada TG2 (Modo retardo a la conexión)" ;
    ns1:controla ns1:Temporizador_T10 ;
    ns1:identificador "TG2" ;
    ns1:textoExtracto "TG2 activa el modo retardo a la conexión." .

ns1:Entrada_TG3 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada TG3 (Modo retardo a la desconexión)" ;
    ns1:controla ns1:Temporizador_T10 ;
    ns1:identificador "TG3" ;
    ns1:textoExtracto "TG3 activa el modo retardo a la desconexión." .

ns1:Entrada_TG4 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada TG4 (Modo limitador de señal)" ;
    ns1:controla ns1:Temporizador_T10 ;
    ns1:identificador "TG4" ;
    ns1:textoExtracto "TG4 activa el modo limitador de señal." .

ns1:Parametro_ConstanteTiempo a ns1:Parametro ;
    rdfs:label "Constante de tiempo (temporizador)" ;
    ns1:textoExtracto "Se referencian mediante las letras TG1, TG2, TG3, TG4 seguidas del número de temporizador que se desea referenciar y del valor con que se desea comenzar su cuenta (constante de tiempo). Por ejemplo TG1 1 100, TG2 25 224, TG3 102 0, etc. Definir la constante de tiempo." ;
    ns1:valor "Ejemplo: 100, 224, 0" .

ns1:Temporizador_T10 a ns1:ComponenteElectrico ;
    rdfs:label "Temporizador T10" ;
    ns1:identificador "T10" ;
    ns1:textoExtracto "I3 = TRS 10. La entrada I3 controla la entrada de reset del temporizador T10." .

