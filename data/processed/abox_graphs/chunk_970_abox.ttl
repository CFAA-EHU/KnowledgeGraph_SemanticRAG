@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Rango_Constante_Tiempo a ns1:Parametro ;
    rdfs:label "Rango válido para constantes de tiempo" ;
    ns1:textoExtracto "Su valor debe estar comprendido entre 0 y 4294967295 ms, lo que equivale a 1193 horas (casi 50 días)" ;
    ns1:valor "0-4294967295" .

ns1:Temporizador_TG1 a ns1:ComponenteElectrico ;
    rdfs:label "Temporizador TG1" ;
    ns1:identificador "TG1" ;
    ns1:monitoreaParametro ns1:Parametro_Tiempo_TG1 ;
    ns1:textoExtracto "TG1 1 100" .

ns1:Temporizador_TG2 a ns1:ComponenteElectrico ;
    rdfs:label "Temporizador TG2" ;
    ns1:identificador "TG2" ;
    ns1:monitoreaParametro ns1:Parametro_Tiempo_TG2 ;
    ns1:textoExtracto "TG2 25 224" .

ns1:Temporizador_TG3 a ns1:ComponenteElectrico ;
    rdfs:label "Temporizador TG3" ;
    ns1:identificador "TG3" ;
    ns1:monitoreaParametro ns1:Parametro_Tiempo_TG3 ;
    ns1:textoExtracto "TG3 102 0" .

ns1:Parametro_Tiempo_TG1 a ns1:Parametro ;
    rdfs:label "Constante de tiempo TG1" ;
    ns1:textoExtracto "La constante de tiempo se define con un valor numérico o con el valor interno de un registro R. Su valor debe estar comprendido entre 0 y 4294967295 ms" ;
    ns1:valor 100 .

ns1:Parametro_Tiempo_TG2 a ns1:Parametro ;
    rdfs:label "Constante de tiempo TG2" ;
    ns1:textoExtracto "La constante de tiempo se define con un valor numérico o con el valor interno de un registro R. Su valor debe estar comprendido entre 0 y 4294967295 ms" ;
    ns1:valor 224 .

ns1:Parametro_Tiempo_TG3 a ns1:Parametro ;
    rdfs:label "Constante de tiempo TG3" ;
    ns1:textoExtracto "La constante de tiempo se define con un valor numérico o con el valor interno de un registro R. Su valor debe estar comprendido entre 0 y 4294967295 ms" ;
    ns1:valor 0 .

