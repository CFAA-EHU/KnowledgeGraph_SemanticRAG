@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoRetardoConexion_TG2 a ns1:ModoOperacion ;
    rdfs:label "Modo retardo a la conexión (entrada TG2)"@es ;
    ns1:monitoreaParametro ns1:Parametro_TiempoTranscurrido ;
    ns1:textoExtracto "Este modo de funcionamiento permite realizar un retardo entre la activación de la entrada de arranque TG2 y la activación de la salida de estado T del temporizador. La duración del retardo la fija la constante de tiempo."@es ;
    ns1:tieneComponente ns1:Entrada_TG2,
        ns1:Parametro_ConstanteTiempo,
        ns1:Parametro_TEN,
        ns1:Parametro_TRS,
        ns1:Salida_T .

ns1:Entrada_TG2 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada TG2"@es ;
    ns1:textoExtracto "flanco de subida en la entrada TG2"@es .

ns1:Parametro_ConstanteTiempo a ns1:Parametro ;
    rdfs:label "Constante de tiempo"@es ;
    ns1:textoExtracto "La duración del retardo la fija la constante de tiempo."@es .

ns1:Parametro_TEN a ns1:Parametro ;
    rdfs:label "Parámetro TEN"@es ;
    ns1:identificador "TEN" ;
    ns1:textoExtracto "Con TEN=1 y TRS=0, el temporizador se activa [...] Si una vez activado el temporizador se selecciona TEN=0, el PLC detiene la temporización, siendo necesario asignar TEN=1 para que dicha temporización continúe."@es ;
    ns1:valor "0"@es,
        "1"@es .

ns1:Parametro_TRS a ns1:Parametro ;
    rdfs:label "Parámetro TRS"@es ;
    ns1:identificador "TRS" ;
    ns1:textoExtracto "Con TEN=1 y TRS=0 [...] Si se produce un flanco de subida en la entrada TRS, durante la temporización o después de ella, el PLC inicializa el temporizador"@es ;
    ns1:valor "0"@es .

ns1:Parametro_TiempoTranscurrido a ns1:Parametro ;
    rdfs:label "Tiempo transcurrido (t)"@es ;
    ns1:identificador "t" ;
    ns1:textoExtracto "el tiempo transcurrido (t) se mantiene hasta que se produce un nuevo flanco de subida en la entrada TG2"@es .

ns1:Salida_T a ns1:ComponenteElectrico ;
    rdfs:label "Salida de estado T"@es ;
    ns1:textoExtracto "salida de estado T del temporizador"@es .

