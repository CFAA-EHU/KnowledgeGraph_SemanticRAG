@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:ModoRetardoDesconexion_TG3 a ns1:ModoOperacion ;
    rdfs:label "Modo retardo a la desconexión (entrada TG3)"@es ;
    ns1:controla ns1:Temporizador_T ;
    ns1:textoExtracto "Este modo de funcionamiento permite realizar un retardo entre la desactivación de la entrada de arranque TG3 y la desactivación de la salida T del temporizador. La duración del retardo, está determinada por la constante de tiempo."@es ;
    ns1:tieneComponente ns1:Entrada_TG3,
        ns1:Parametro_ConstanteTiempo,
        ns1:Parametro_TEN,
        ns1:Parametro_TRS,
        ns1:Salida_T .

ns1:Entrada_TG3 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada TG3"@es ;
    ns1:monitoreaParametro ns1:Parametro_EstadoT ;
    ns1:textoExtracto "flanco de subida en la entrada TG3"@es .

ns1:Parametro_TEN a ns1:Parametro ;
    rdfs:label "Parámetro TEN"@es ;
    ns1:controla ns1:Temporizador_T ;
    ns1:identificador "TEN" ;
    ns1:textoExtracto "Con TEN=1 y TRS=0, el temporizador se activa"@es ;
    ns1:valor 0,
        1 .

ns1:Parametro_TRS a ns1:Parametro ;
    rdfs:label "Parámetro TRS"@es ;
    ns1:controla ns1:Temporizador_T ;
    ns1:identificador "TRS" ;
    ns1:textoExtracto "Con TEN=1 y TRS=0, el temporizador se activa"@es ;
    ns1:valor 0 .

ns1:Salida_T a ns1:ComponenteElectrico ;
    rdfs:label "Salida T"@es ;
    ns1:monitoreaParametro ns1:Parametro_EstadoT ;
    ns1:textoExtracto "salida de estado del temporizador toma el valor T=1"@es .

ns1:Parametro_ConstanteTiempo a ns1:Parametro ;
    rdfs:label "Constante de tiempo"@es ;
    ns1:textoExtracto "tiempo especificado mediante la constante de tiempo"@es .

ns1:Parametro_EstadoT a ns1:Parametro ;
    rdfs:label "Estado T (T=1/T=0)"@es ;
    ns1:textoExtracto "desactivándose la salida de estado del temporizador (T=0)"@es ;
    ns1:valor 0,
        1 .

ns1:Temporizador_T a ns1:ComponenteElectrico ;
    rdfs:label "Temporizador T"@es ;
    ns1:controla ns1:Parametro_ConstanteTiempo ;
    ns1:textoExtracto "el temporizador esperará un flanco de bajada de la entrada TG3 para comenzar la temporización t"@es ;
    ns1:tieneComponente ns1:Parametro_EstadoT .

