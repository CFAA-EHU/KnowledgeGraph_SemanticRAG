@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_TemporizadorLimitadorTG4 a ns1:ModoOperacion ;
    rdfs:label "Modo limitador de la señal (entrada TG4)"@es ;
    ns1:controla ns1:ComponenteElectrico_EntradaTG4,
        ns1:ComponenteElectrico_SalidaEstadoTemporizador ;
    ns1:textoExtracto "En este modo de funcionamiento el estado del temporizador se mantiene a nivel lógico alto (T=1) desde que se activa la entrada TG4 hasta que transcurra el tiempo indicado mediante la constante de tiempo, o hasta que se produzca un flanco de bajada en la entrada TG4."@es ;
    ns1:tieneComponente ns1:Parametro_ConstanteTiempo,
        ns1:Parametro_EstadoTemporizadorT,
        ns1:Parametro_TEN,
        ns1:Parametro_TRS,
        ns1:Parametro_TiempoTranscurrido_t .

ns1:ComponenteElectrico_EntradaTG4 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada TG4"@es ;
    ns1:textoExtracto "desde que se activa la entrada TG4 hasta que transcurra el tiempo indicado [...] Si antes de haber transcurrido el tiempo especificado se produce un flanco de bajada de la entrada de arranque TG4, el PLC da por finalizada la temporización. [...] Para volver a activar el temporizador, deberá producirse un nuevo flanco de subida en la entrada TG4."@es .

ns1:ComponenteElectrico_SalidaEstadoTemporizador a ns1:ComponenteElectrico ;
    rdfs:label "Salida de estado del temporizador"@es ;
    ns1:textoExtracto "la salida de estado del temporizador (T) cambia de estado (T=1) y comienza la temporización t. [...] desactivándose la salida de estado del temporizador (T=0)."@es .

ns1:Parametro_ConstanteTiempo a ns1:Parametro ;
    rdfs:label "Constante de tiempo"@es ;
    ns1:textoExtracto "el estado del temporizador se mantiene a nivel lógico alto (T=1) desde que se activa la entrada TG4 hasta que transcurra el tiempo indicado mediante la constante de tiempo"@es .

ns1:Parametro_EstadoTemporizadorT a ns1:Parametro ;
    rdfs:label "Estado del temporizador (T)"@es ;
    ns1:textoExtracto "la salida de estado del temporizador (T) cambia de estado (T=1) y comienza la temporización t a partir del valor 0. [...] desactivándose la salida de estado del temporizador (T=0)."@es ;
    ns1:valor "0",
        "1" .

ns1:Parametro_TEN a ns1:Parametro ;
    rdfs:label "Parámetro TEN"@es ;
    ns1:textoExtracto "Con TEN=1 y TRS=0, el temporizador se activa al producirse un flanco de subida en la entrada TG4. [...] Si una vez activado el temporizador se selecciona TEN=0, el PLC detiene la temporización, siendo necesario asignar TEN=1 para que dicha temporización continúe."@es ;
    ns1:valor "0",
        "1" .

ns1:Parametro_TRS a ns1:Parametro ;
    rdfs:label "Parámetro TRS"@es ;
    ns1:textoExtracto "Funcionamiento de la entrada TRS en este modo. Si se produce un flanco de subida en la entrada TRS, durante la temporización o después de ella, el PLC inicializa el temporizador, asignando el valor 0 a su estado T y cancelando su cuenta (la inicializa a 0)."@es ;
    ns1:valor "0",
        "1" .

ns1:Parametro_TiempoTranscurrido_t a ns1:Parametro ;
    rdfs:label "Tiempo transcurrido (t)"@es ;
    ns1:textoExtracto "comienza la temporización t a partir del valor 0. [...] El tiempo transcurrido (t) se mantiene hasta que se produzca un nuevo flanco de subida en la entrada TG4."@es .

