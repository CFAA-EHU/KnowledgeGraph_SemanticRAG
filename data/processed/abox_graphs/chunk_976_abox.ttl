@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Entrada_CEN a ns1:ComponenteElectrico ;
    rdfs:label "Entrada CEN (enable)" ;
    ns1:controla ns1:Entrada_CDW,
        ns1:Entrada_CUP ;
    ns1:identificador "CEN" ;
    ns1:textoExtracto "(CEN) Entrada de enable. Permite detener la cuenta interna del contador. [...] Para poder modificar la cuenta interna (CUP y CDW) la entrada CEN debe estar a (=1). Con CEN a (=0) se detiene la cuenta del contador y no se hace caso a las entradas CUP y CDW."^^rdfs:Literal ;
    ns1:tieneComponente ns1:Contador_Generico .

ns1:Entrada_CPR a ns1:ComponenteElectrico ;
    rdfs:label "Entrada CPR (preselección)" ;
    ns1:identificador "CPR" ;
    ns1:textoExtracto "(CPR) Entrada de preselección. Permite preseleccionar el contador con el valor deseado. Se referencia mediante las letras CPR seguidas del número de contador y del valor que se desea asignar a su cuenta. El contador se preselecciona con el valor indicado cuando se produce un flanco de subida en la entrada CPR."^^rdfs:Literal ;
    ns1:tieneComponente ns1:Contador_Generico .

ns1:Salida_Estado_C a ns1:ComponenteElectrico ;
    rdfs:label "Salida estado C" ;
    ns1:identificador "C" ;
    ns1:textoExtracto "Todos los contadores disponen de la salida estado C [...]"^^rdfs:Literal ;
    ns1:tieneComponente ns1:Contador_Generico .

ns1:Variable_Cuenta_Interna a ns1:Parametro ;
    rdfs:label "Cuenta interna del contador" ;
    ns1:monitoreaParametro ns1:Contador_Generico ;
    ns1:textoExtracto "La cuenta de un contador se almacena en una variable de 32 bits, por lo que su valor puede estar comprendido entre ±2147483647."^^rdfs:Literal ;
    ns1:valor "±2147483647" .

ns1:Entrada_CDW a ns1:ComponenteElectrico ;
    rdfs:label "Entrada CDW (descontaje)" ;
    ns1:identificador "CDW" ;
    ns1:textoExtracto "(CDW) Entrada de descontaje. Cada vez que se produce un flanco de subida en esta entrada la cuenta interna del contador se decrementa en una unidad. Se referencia mediante las letras CDW seguidas del número de contador que se desea referenciar, por ejemplo CDW 1, CDW 25, CDW 102, etc."^^rdfs:Literal ;
    ns1:tieneComponente ns1:Contador_Generico .

ns1:Entrada_CUP a ns1:ComponenteElectrico ;
    rdfs:label "Entrada CUP (contaje)" ;
    ns1:identificador "CUP" ;
    ns1:textoExtracto "(CUP) Entrada de contaje. Cada vez que se produce un flanco de subida en esta entrada la cuenta interna del contador se incrementa en una unidad. Se referencia mediante las letras CUP seguidas del número de contador que se desea referenciar, por ejemplo CUP 1, CUP 25, CUP 102, etc."^^rdfs:Literal ;
    ns1:tieneComponente ns1:Contador_Generico .

ns1:Contador_Generico a ns1:ComponenteElectrico ;
    rdfs:label "Contador genérico" ;
    ns1:textoExtracto "Todos los contadores disponen de la salida estado C y de las entradas CUP, CDW, CEN y CPR. También es posible consultar en cualquier momento el valor de su cuenta interna. La cuenta de un contador se almacena en una variable de 32 bits, por lo que su valor puede estar comprendido entre ±2147483647."^^rdfs:Literal .

