@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EntradaCPR_Contador a ns1:ComponenteElectrico ;
    rdfs:label "Entrada CPR (preselección de contador)"@es ;
    ns1:identificador "CPR" ;
    ns1:monitoreaParametro ns1:Parametro_ValorPreseleccion ;
    ns1:textoExtracto "(CPR) Entrada de preselección. Permite preseleccionar el contador con el valor deseado. Se referencia mediante las letras CPR seguidas del número de contador y del valor que se desea asignar a su cuenta."@es .

ns1:Parametro_ValorPreseleccion a ns1:Parametro ;
    rdfs:label "Valor de preselección del contador"@es ;
    ns1:textoExtracto "El valor de la cuenta puede indicarse con un valor numérico o con el valor interno de un registro R. Su valor debe estar comprendido entre 0 y ± 2.147.483.647."@es ;
    ns1:valor "0 a ±2147483647" .

