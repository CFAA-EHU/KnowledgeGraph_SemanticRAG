@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Contador_C20 a ns1:ComponenteElectrico ;
    rdfs:label "Contador C20" ;
    ns1:identificador "C20" ;
    ns1:textoExtracto "Preselecciona el contador C20 con el valor 100." .

ns1:Contador_C22 a ns1:ComponenteElectrico ;
    rdfs:label "Contador C22" ;
    ns1:identificador "C22" ;
    ns1:textoExtracto "Preselecciona el contador C22 con el valor del registro R200." .

ns1:Instruccion_C123_M100 a ns1:InterfazUsuario ;
    rdfs:label "Asignación de estado lógico C123 a M100" ;
    ns1:controla ns1:Marca_M100 ;
    ns1:monitoreaParametro ns1:Contador_C123 ;
    ns1:textoExtracto "C123 = M100 Asigna a M100 el estado (0/1) de C123" .

ns1:Instruccion_CPS_C123_GT_1000 a ns1:InterfazUsuario ;
    rdfs:label "Comparación C123 > 1000" ;
    ns1:controla ns1:Marca_M100 ;
    ns1:monitoreaParametro ns1:Contador_C123 ;
    ns1:textoExtracto "CPS C123 GT 1000 = M100 Compara si la cuenta de C123 es mayor que 1000, en cuyo caso activa la marca M100." .

ns1:Instruccion_MOV_C123_R200 a ns1:InterfazUsuario ;
    rdfs:label "Transferencia de cuenta C123 a R200" ;
    ns1:controla ns1:Registro_R200 ;
    ns1:monitoreaParametro ns1:Contador_C123 ;
    ns1:textoExtracto "I2 = MOV C123 R200 Transfiere la cuenta de C123 al registro R200." .

ns1:VariableContador_32bits a ns1:Parametro ;
    rdfs:label "Variable de 32 bits para cuenta de contador" ;
    ns1:textoExtracto "El PLC dispone de una variable de 32 bits para almacenar la cuenta de cada contador." ;
    ns1:valor "32 bits" .

ns1:Registro_R200 a ns1:Parametro ;
    rdfs:label "Registro R200" ;
    ns1:identificador "R200" ;
    ns1:textoExtracto "Preselecciona el contador C22 con el valor del registro R200." .

ns1:Marca_M100 a ns1:Parametro ;
    rdfs:label "Marca M100" ;
    ns1:identificador "M100" ;
    ns1:textoExtracto "C123 = M100 Asigna a M100 el estado (0/1) de C123" .

ns1:Contador_C123 a ns1:ComponenteElectrico ;
    rdfs:label "Contador C123" ;
    ns1:identificador "C123" ;
    ns1:textoExtracto "Su representación C123 coincide con la salida de estado pero se utilizan en instrucciones de tipo distinto." .

