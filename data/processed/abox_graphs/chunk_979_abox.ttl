@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Comentario_PLC a ns1:Parametro ;
    rdfs:label "Comentario en programa PLC (inicia con ;)"@es ;
    ns1:textoExtracto "Todos los comentarios deben comenzar con el carácter punto y coma \";\". Las líneas que comienzan con el carácter \";\" son consideradas como comentario y no se ejecutan."@es ;
    ns1:valor ";" .

ns1:ModuloEjecucionPeriodica_PLC a ns1:Sistema ;
    rdfs:label "Módulo de ejecución periódica (PE)"@es ;
    ns1:compuestoPor ns1:ProposicionDirectiva_PLC,
        ns1:ProposicionEjecutable_PLC ;
    ns1:identificador "PE" ;
    ns1:textoExtracto "Módulo de ejecución periódica (PE)."@es .

ns1:ModuloPrimerCiclo_PLC a ns1:Sistema ;
    rdfs:label "Módulo del primer ciclo (CY1)"@es ;
    ns1:compuestoPor ns1:ProposicionDirectiva_PLC,
        ns1:ProposicionEjecutable_PLC ;
    ns1:identificador "CY1" ;
    ns1:textoExtracto "Módulo del primer ciclo (CY1)."@es .

ns1:ModuloPrincipal_PLC a ns1:Sistema ;
    rdfs:label "Módulo principal (PRG)"@es ;
    ns1:compuestoPor ns1:ProposicionDirectiva_PLC,
        ns1:ProposicionEjecutable_PLC ;
    ns1:identificador "PRG" ;
    ns1:textoExtracto "Módulo principal (PRG)."@es .

ns1:ExpresionLogica_PLC a ns1:Parametro ;
    rdfs:label "Expresión lógica booleana (ej. I32 AND I36 AND M111)"@es ;
    ns1:compuestoPor ns1:InstruccionConsulta_PLC,
        ns1:OperadorLogico_AND ;
    ns1:textoExtracto "Expresiones lógicas o booleanas (I28 AND I30). Las expresiones lógicas están formadas por: Instrucciones de consulta (I28, O25). Operadores (AND)."@es ;
    ns1:valor "I32 AND I36 AND M111" .

ns1:InstruccionAccion_PLC a ns1:Parametro ;
    rdfs:label "Instrucción de acción (ej. =O25)"@es ;
    ns1:textoExtracto "Instrucciones de acción (=O25)."@es ;
    ns1:valor "=O25" .

ns1:InstruccionConsulta_PLC a ns1:Parametro ;
    rdfs:label "Instrucción de consulta (ej. I28, O25)"@es ;
    ns1:textoExtracto "Instrucciones de consulta (I28, O25)."@es ;
    ns1:valor "I28, O25" .

ns1:OperadorLogico_AND a ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Operador lógico AND"@es ;
    ns1:textoExtracto "Operadores (AND)."@es ;
    ns1:valor "AND" .

ns1:ProposicionDirectiva_PLC a ns1:Parametro ;
    rdfs:label "Proposición directiva (ej. REA, IMA)"@es ;
    ns1:textoExtracto "Las proposiciones directivas proporcionan información al PLC sobre el tipo de módulo (PRG, CY1,...) y sobre la forma en que debe ejecutarse el mismo (REA, IMA,...)."@es ;
    ns1:valor "REA, IMA" .

ns1:ProposicionEjecutable_PLC a ns1:Parametro ;
    rdfs:label "Proposición ejecutable (ej. I28 AND I30)"@es ;
    ns1:compuestoPor ns1:ExpresionLogica_PLC,
        ns1:InstruccionAccion_PLC ;
    ns1:textoExtracto "Las proposiciones ejecutables permiten consultar y/o alterar el estado de los recursos del PLC y están compuestas por: Expresiones lógicas o booleanas (I28 AND I30). Instrucciones de acción (=O25)."@es ;
    ns1:valor "I28 AND I30 = O25" .

