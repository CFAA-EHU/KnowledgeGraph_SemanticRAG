@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Instruccion_I100_M102 a ns1:ComponenteElectrico ;
    rdfs:label "Instrucción I100 = M102" ;
    ns1:documentadoEn ns1:EjemploProgramacionPLC_719 ;
    ns1:textoExtracto "I100 = M102 ; Proposición ejecutable" .

ns1:Instruccion_M300 a ns1:ComponenteElectrico ;
    rdfs:label "Instrucción = M300" ;
    ns1:documentadoEn ns1:EjemploProgramacionPLC_719 ;
    ns1:textoExtracto "I32 \\ AND I36 = M300 ; Instrucción de acción" .

ns1:Instruccion_O25 a ns1:ComponenteElectrico ;
    rdfs:label "Instrucción = O25" ;
    ns1:documentadoEn ns1:EjemploProgramacionPLC_719 ;
    ns1:textoExtracto "I28 AND I30 = O25 ; Instrucción de acción" .

ns1:EjemploProgramacionPLC_719 a ns1:Sistema ;
    rdfs:label "Ejemplo de programación PLC" ;
    ns1:identificador "EjemploProgramacionPLC_Pag357-358" ;
    ns1:textoExtracto """PRG ; Proposición directiva
; Ejemplo ; Comentario
I100 = M102 ; Proposición ejecutable
I28 AND I30 ; Expresión lógica
= O25 ; Instrucción de acción
I32 \\ ; Instrucción de consulta (1ª parte de expresión)
AND I36 ; Instrucción de consulta (2ª parte de expresión)
= M300 ; Instrucción de acción
END ; Proposición directiva""" .

