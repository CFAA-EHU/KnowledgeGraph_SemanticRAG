@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CY1 a ns1:ModoOperacion ;
    rdfs:label "CY1" ;
    ns1:identificador "CY1" ;
    ns1:textoExtracto "CY1 Módulo de primer ciclo." .

ns1:DEF a ns1:ModoOperacion ;
    rdfs:label "DEF" ;
    ns1:identificador "DEF" ;
    ns1:textoExtracto "DEF, PDEF Definición de símbolo." .

ns1:END a ns1:ModoOperacion ;
    rdfs:label "END" ;
    ns1:identificador "END" ;
    ns1:textoExtracto "END Final del módulo o subrutina. Hay que definirlo para cada módulo o subrutina." .

ns1:EXTERN a ns1:ModoOperacion ;
    rdfs:label "EXTERN" ;
    ns1:identificador "EXTERN" ;
    ns1:textoExtracto "EXTERN Definición de subrutina externa." .

ns1:IMA a ns1:ModoOperacion ;
    rdfs:label "IMA" ;
    ns1:identificador "IMA" ;
    ns1:textoExtracto "REA, IMA Valores reales o imagen." .

ns1:L a ns1:ModoOperacion ;
    rdfs:label "L" ;
    ns1:identificador "L" ;
    ns1:textoExtracto "L Etiqueta." .

ns1:NOMONIT a ns1:ModoOperacion ;
    rdfs:label "NOMONIT" ;
    ns1:identificador "NOMONIT" ;
    ns1:textoExtracto "NOMONIT No monitorización." .

ns1:PDEF a ns1:ModoOperacion ;
    rdfs:label "PDEF" ;
    ns1:identificador "PDEF" ;
    ns1:textoExtracto "DEF, PDEF Definición de símbolo." .

ns1:PE_t a ns1:ModoOperacion ;
    rdfs:label "PE t" ;
    ns1:identificador "PE t" ;
    ns1:textoExtracto "PE t Módulo periódico. Se ejecuta cada t milisegundos." .

ns1:PRG a ns1:ModoOperacion ;
    rdfs:label "PRG" ;
    ns1:identificador "PRG" ;
    ns1:textoExtracto "PRG Módulo principal." .

ns1:REA a ns1:ModoOperacion ;
    rdfs:label "REA" ;
    ns1:identificador "REA" ;
    ns1:textoExtracto "REA, IMA Valores reales o imagen." .

ns1:SUB a ns1:ModoOperacion ;
    rdfs:label "SUB" ;
    ns1:identificador "SUB" ;
    ns1:textoExtracto "SUB Definición de subrutina." .

