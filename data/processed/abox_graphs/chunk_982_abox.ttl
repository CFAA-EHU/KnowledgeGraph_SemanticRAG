@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Ejemplo_CombinacionValores a ns1:Tabla ;
    rdfs:label "Ejemplo de combinación REA/IMA" ;
    ns1:ilustradoEn ns1:Modulo_CY1,
        ns1:Modulo_PRG ;
    ns1:textoExtracto "IMA I3 AND REA M4 = 02" .

ns1:Instruccion_Accion a ns1:Parametro ;
    rdfs:label "Instrucción de acción (=O32)" ;
    ns1:identificador "=O32" ;
    ns1:monitoreaParametro ns1:Parametro_ValoresReales ;
    ns1:textoExtracto "Las instrucciones de acción (=O32) siempre actualizan los valores reales de los recursos del PLC" .

ns1:Parametro_ValoresImagen a ns1:Parametro ;
    rdfs:label "IMA (Valores imagen)" ;
    ns1:identificador "IMA" ;
    ns1:textoExtracto "REA, IMA Valores reales o imagen. [...] valor imagen el que disponía cuando se finalizó el ciclo anterior" .

ns1:Modulo_CY1 a ns1:Sistema ;
    rdfs:label "Módulo CY1" ;
    ns1:identificador "CY1" ;
    ns1:textoExtracto "CY1 ; Comienzo del módulo CY1 [...] END ; Final del módulo CY1" .

ns1:Modulo_PRG a ns1:Sistema ;
    rdfs:label "Módulo PRG" ;
    ns1:identificador "PRG" ;
    ns1:textoExtracto "PRG ; Comienzo del módulo PRG [...] END ; Final del módulo PRG" .

ns1:Parametro_ValoresReales a ns1:Parametro ;
    rdfs:label "REA (Valores reales)" ;
    ns1:identificador "REA" ;
    ns1:textoExtracto "REA, IMA Valores reales o imagen. Indican si las consultas [...] Valor real es el que dispone el recurso en ese momento" .

