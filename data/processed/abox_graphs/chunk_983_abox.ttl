@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Directiva_EXTERN_722 a ns1:Directiva ;
    rdfs:label "Directiva EXTERN (Subrutina externa)"@es ;
    ns1:documentadoEn ns1:SistemaProgramacionPLC_722 ;
    ns1:identificador "EXTERN" ;
    ns1:textoExtracto "EXTERN Definición de subrutina externa. Las subrutinas definidas en el fichero de lenguaje C que utiliza el programa deben estar definidas como externas al principio del programa, antes que la directiva DEF y los módulos CY1, PRE y PEt."@es .

ns1:Directiva_L_722 a ns1:Directiva ;
    rdfs:label "Directiva L (Etiqueta)"@es ;
    ns1:identificador "L" ;
    ns1:textoExtracto "L Etiqueta. Sirve para identificar una línea de programa. Se puede definir de 2 formas: • Con L seguido de hasta 7 cifras (L1 - L9999999). • Con L_ seguido de hasta 8 caracteres (L_GEAR). Si está definida dentro de un módulo (CY1, PRG o PE), identifica una línea de programa y permite realizar referencias o saltos de programa."@es .

ns1:Directiva_SUB_722 a ns1:Directiva ;
    rdfs:label "Directiva SUB (Subrutina)"@es ;
    ns1:documentadoEn ns1:SistemaProgramacionPLC_722 ;
    ns1:identificador "SUB" ;
    ns1:textoExtracto "SUB Definición de subrutina. Indica el comienzo de una subrutina. Se denomina subrutina a una parte de programa que puede ser llamada desde cualquier proposición ejecutable. Se define con SUB seguido de un espacio y hasta 24 caracteres. Una subrutina debe finalizar siempre con la directiva END."@es .

ns1:Parametro_M1_722 a ns1:Parametro ;
    rdfs:label "Parámetro M1"@es ;
    ns1:monitoreaParametro ns1:ModoOperacion_IMA_722,
        ns1:ModoOperacion_REA_722 ;
    ns1:textoExtracto "()=M1 fija el valor real de M1=1 pero su valor imagen es ꞏ0ꞏ. Sólo tras finalizar este ciclo su valor imagen será ꞏ1ꞏ."@es ;
    ns1:valor "1 (real), 0 (imagen inicial)"@es .

ns1:Parametro_M2_722 a ns1:Parametro ;
    rdfs:label "Parámetro M2"@es ;
    ns1:textoExtracto "M1 M2 Con valores reales (REA) la salida O5 toma el valor 1..."@es .

ns1:Parametro_O5_722 a ns1:Parametro ;
    rdfs:label "Salida O5"@es ;
    ns1:textoExtracto "la salida O5 toma el valor 1 al finalizar el primer scan o ciclo, mientras que necesita 4 ciclos con valores imagen (IMA)."@es ;
    ns1:valor "1 (tras 1 ciclo en REA, 4 ciclos en IMA)"@es .

ns1:ModoOperacion_IMA_722 a ns1:ModoOperacion ;
    rdfs:label "Modo valores imagen (IMA)"@es ;
    ns1:textoExtracto "trabajar con valores imagen (IMA) permite analizar un mismo recurso a lo largo del programa con el mismo valor, independientemente del valor real que en ese momento disponga."@es .

ns1:ModoOperacion_REA_722 a ns1:ModoOperacion ;
    rdfs:label "Modo valores reales (REA)"@es ;
    ns1:textoExtracto "El sistema es más rápido trabajando con valores reales (REA)..."@es .

ns1:SistemaProgramacionPLC_722 a ns1:Sistema ;
    rdfs:label "Sistema de programación PLC (valores REA/IMA)"@es ;
    ns1:textoExtracto "M1 M2 Con valores reales (REA) la salida O5 toma el valor 1 al finalizar el primer scan o ciclo, mientras que necesita 4 ciclos con valores imagen (IMA). En el primer ciclo, ()=M1 fija el valor real de M1=1 pero su valor imagen es ꞏ0ꞏ. Sólo tras finalizar este ciclo su valor imagen será ꞏ1ꞏ. El sistema es más rápido trabajando con valores reales (REA) mientras que trabajar con valores imagen (IMA) permite analizar un mismo recurso a lo largo del programa con el mismo valor, independientemente del valor real que en ese momento disponga."@es ;
    ns1:tieneComponente ns1:ModoOperacion_IMA_722,
        ns1:ModoOperacion_REA_722,
        ns1:Parametro_M1_722,
        ns1:Parametro_M2_722,
        ns1:Parametro_O5_722 .

