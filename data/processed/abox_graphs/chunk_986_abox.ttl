@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Directiva_NOMONIT a ns1:Directiva ;
    rdfs:label "Directiva NOMONIT para deshabilitar monitorización" ;
    ns1:identificador "NOMONIT" ;
    ns1:textoExtracto "NOMONIT No monitorización. Cuando se programa esta directiva no se genera la información necesaria para la monitorización del programa de PLC." .

ns1:Simbolo_CONSTANT_FFFF3 a ns1:Parametro ;
    rdfs:label "Símbolo PDEF CONSTANT $FFFF3" ;
    ns1:identificador "CONSTANT_FFFF3" ;
    ns1:textoExtracto "PDEF CONSTANT $FFFF3" ;
    ns1:valor "$FFFF3" .

ns1:Simbolo_COOL_I12 a ns1:Parametro ;
    rdfs:label "Símbolo PDEF COOL I12" ;
    ns1:identificador "COOL_I12" ;
    ns1:textoExtracto "PDEF COOL I12" ;
    ns1:valor "I12" .

ns1:Simbolo_DATA_D1 a ns1:Parametro ;
    rdfs:label "Símbolo DEF DATA_D1" ;
    ns1:identificador "DATA_D1" ;
    ns1:textoExtracto "DEF DATA_D1 372893" ;
    ns1:valor "372893" .

ns1:Simbolo_DATA_D3 a ns1:Parametro ;
    rdfs:label "Símbolo DEF DATA_D3" ;
    ns1:identificador "DATA_D3" ;
    ns1:textoExtracto "DEF DATA_D3 -437289" ;
    ns1:valor "-437289" .

ns1:Simbolo_FAN_I23 a ns1:Parametro ;
    rdfs:label "Símbolo DEF /FAN I23" ;
    ns1:identificador "FAN_I23" ;
    ns1:textoExtracto "DEF /FAN I23" ;
    ns1:valor "I23" .

ns1:SistemaPLC_MTB a ns1:Sistema ;
    rdfs:label "Sistema PLC (MTB)" ;
    ns1:textoExtracto "El archivo se guarda en la carpeta ..\\MTB\\PLC\\Project" ;
    ns1:tieneComponente ns1:Archivo_plc_pdef_h .

ns1:Variable_PLC_symbol a ns1:Parametro ;
    rdfs:label "Variable PLC.symbol para acceso externo a símbolos PDEF" ;
    ns1:identificador "PLC.symbol" ;
    ns1:monitoreaParametro ns1:Directiva_PDEF ;
    ns1:textoExtracto "PLC.symbol Acceso desde una aplicación externa." .

ns1:Variable_V_PLC_symbol a ns1:Parametro ;
    rdfs:label "Variable V.PLC.symbol para acceso a símbolos PDEF" ;
    ns1:identificador "V.PLC.symbol" ;
    ns1:monitoreaParametro ns1:Directiva_PDEF ;
    ns1:textoExtracto "V.PLC.symbol Acceso desde programa pieza o MDI." .

ns1:Archivo_plc_pdef_h a ns1:InterfazUsuario ;
    rdfs:label "Archivo de cabecera plc_pdef.h" ;
    ns1:documentadoEn ns1:Directiva_PDEF ;
    ns1:identificador "plc_pdef.h" ;
    ns1:textoExtracto "genera el archivo plc_pdef.h con los #define de todos los símbolos definidos en el programa PLC. El archivo se guarda en la carpeta ..\\MTB\\PLC\\Project" .

ns1:Directiva_PDEF a ns1:Directiva ;
    rdfs:label "Directiva PDEF para definición de símbolos en PLC" ;
    ns1:identificador "PDEF" ;
    ns1:textoExtracto "genera el archivo plc_pdef.h con los #define de todos los símbolos definidos en el programa PLC. [...] PDEF COOL I12 PDEF CONSTANT $FFFF3 DEF DATA_D1 372893 DEF DATA_D3 -437289 DEF /FAN I23" .

