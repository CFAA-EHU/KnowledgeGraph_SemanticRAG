@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Modulo_CY1 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo CY1" ;
    ns1:identificador "CY1" ;
    ns1:textoExtracto "CY1 [...] END" .

ns1:Modulo_PE100 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo PE 100" ;
    ns1:identificador "PE 100" ;
    ns1:textoExtracto "PE 100 [...] END" .

ns1:Modulo_PRG a ns1:ComponenteElectrico ;
    rdfs:label "Módulo PRG" ;
    ns1:identificador "PRG" ;
    ns1:textoExtracto "PRG [...] END" .

ns1:Parametro_02 a ns1:Parametro ;
    rdfs:label "Valor 02" ;
    ns1:textoExtracto "= 02" ;
    ns1:valor "02" .

ns1:Parametro_COOL_I12 a ns1:Parametro ;
    rdfs:label "Parámetro COOL I12" ;
    ns1:identificador "I12" ;
    ns1:textoExtracto "DEF COOL I12" ;
    ns1:valor "COOL" .

ns1:Parametro_FAN_I23 a ns1:Parametro ;
