    ns1:identificador "M4" ;
    ns1:textoExtracto "REA M4" .

ns1:Subrutina_A22 a ns1:ComponenteElectrico ;
    rdfs:label "Subrutina A22" ;
    ns1:identificador "A22" ;
    ns1:textoExtracto "SUB A22 [...] END" .

ns1:Subrutina_EXTERN_TEMPERATURE a ns1:ComponenteElectrico ;
