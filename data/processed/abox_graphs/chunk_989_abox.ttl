    rdfs:label "Parámetro I3" ;
    ns1:identificador "I3" ;
    ns1:textoExtracto "IMA I3" .

ns1:Parametro_L_GEAR a ns1:Parametro ;
    rdfs:label "Parámetro L_GEAR" ;
    ns1:identificador "L_GEAR" ;
    ns1:textoExtracto "L_GEAR" .

ns1:Parametro_M4 a ns1:Parametro ;
