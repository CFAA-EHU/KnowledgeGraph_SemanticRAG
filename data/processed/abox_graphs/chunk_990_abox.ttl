ns1:InstruccionesConsultaPLC_CNC_4_2 a ns1:InterfazUsuario ;
    rdfs:label "Instrucciones de consulta PLC-CNC"@es ;
    ns1:textoExtracto "Permiten evaluar el estado de los recursos del PLC y de las marcas y registros de comunicación CNC-PLC. Se disponen de las siguientes instrucciones de consulta. • Instrucciones de consulta simples. • Instrucciones de con..."@es ;
    ns1:tieneComponente ns1:InstruccionComparacion_4_2_3,
        ns1:InstruccionConsultaSimple_4_2_1,
        ns1:InstruccionDeteccionFlancos_4_2_2 .

ns1:InstruccionComparacion_4_2_3 a ns1:Componente ;
    rdfs:label "Instrucción de comparación"@es ;
    ns1:textoExtracto "Instrucciones de consulta de comparación"@es .

ns1:InstruccionConsultaSimple_4_2_1 a ns1:Componente ;
    rdfs:label "Instrucción de consulta simple"@es ;
    ns1:textoExtracto "Instrucciones de consulta simples"@es .

ns1:InstruccionDeteccionFlancos_4_2_2 a ns1:Componente ;
