@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsultaDeteccionFlancos a ns1:Sistema ;
    rdfs:label "Consulta de detección de flancos" ;
    ns1:textoExtracto "Analizan si se ha producido un cambio de estado en el recurso desde la última vez que se realizó esta misma consulta. Esta consulta puede efectuarse sobre valores reales o imagen." ;
    ns1:tieneComponente ns1:EjemploUso_DFD_M45,
        ns1:EjemploUso_DFD_O32,
        ns1:EjemploUso_DFU_AUXEND,
        ns1:EjemploUso_DFU_B3R120,
        ns1:EjemploUso_DFU_I23,
        ns1:FormatoProgramacion_DFU_DFD,
        ns1:Instruccion_DFD,
        ns1:Instruccion_DFU .

ns1:EjemploUso_DFD_M45 a ns1:Parametro ;
    rdfs:label "Ejemplo de uso: DFD M45" ;
    ns1:textoExtracto "DFD M45" ;
    ns1:valor "M45" .

ns1:EjemploUso_DFD_O32 a ns1:Parametro ;
    rdfs:label "Ejemplo de uso: DFD O32" ;
    ns1:textoExtracto "DFD O32" ;
    ns1:valor "O32" .

ns1:EjemploUso_DFU_AUXEND a ns1:Parametro ;
    rdfs:label "Ejemplo de uso: DFU AUXEND" ;
    ns1:textoExtracto "DFU AUXEND" ;
    ns1:valor "AUXEND" .

ns1:EjemploUso_DFU_B3R120 a ns1:Parametro ;
    rdfs:label "Ejemplo de uso: DFU B3R120" ;
    ns1:textoExtracto "DFU B3R120" ;
    ns1:valor "B3R120" .

ns1:EjemploUso_DFU_I23 a ns1:Parametro ;
    rdfs:label "Ejemplo de uso: DFU I23" ;
    ns1:textoExtracto "DFU I23" ;
    ns1:valor "I23" .

ns1:FormatoProgramacion_DFU_DFD a ns1:Parametro ;
    rdfs:label "Formato de programación para DFU/DFD" ;
    ns1:textoExtracto "El formato de programación para DFU y DFD es: DFU I1ꞏꞏ1024 DFD O1ꞏꞏ1024 M1ꞏꞏ8192 MSG1ꞏꞏ1024 ERR1ꞏꞏ1024 B0ꞏꞏ31 R1ꞏꞏ1024 CLK Marcas de comunicación CNC-PLC" ;
    ns1:valor "DFU I1..1024 / DFD O1..1024 / M1..8192 / MSG1..1024 / ERR1..1024 / B0..31 / R1..1024 / CLK" .

ns1:Instruccion_DFD a ns1:InterfazUsuario ;
    rdfs:label "DFD (Detectar flanco de bajada)" ;
    ns1:identificador "DFD" ;
    ns1:textoExtracto "DFD Detectar flanco de bajada. Detecta si se ha producido un flanco de bajada, cambio de estado de 1 a 0, en el recurso especificado. Devuelve un \"1\" si se ha producido." .

ns1:Instruccion_DFU a ns1:InterfazUsuario ;
    rdfs:label "DFU (Detectar flanco de subida)" ;
    ns1:identificador "DFU" ;
    ns1:textoExtracto "DFU Detectar flanco de subida. Detecta si se ha producido un flanco de subida, cambio de estado de 0 a 1, en el recurso especificado. Devuelve un \"1\" si se ha producido." .

