@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Ejemplo_Comparacion_C12_R14 a ns1:TareaMantenimiento ;
    rdfs:label "Ejemplo: CPS C12 GT R14 = M100" ;
    ns1:documentadoEn ns1:Instruccion_CPS ;
    ns1:textoExtracto "CPS C12 GT R14 = M100. Si la cuenta interna del contador C12 es MAYOR que el valor del registro R14, el PLC asignará a la marca M100 el valor 1, y el valor 0 en caso contrario." ;
    ns1:tieneComponente ns1:Marca_M100,
        ns1:Operando_Contador,
        ns1:Operando_Registro .

ns1:Ejemplo_Comparacion_T2 a ns1:TareaMantenimiento ;
    rdfs:label "Ejemplo: CPS T2 EQ 100 = TG1 5 2000" ;
    ns1:documentadoEn ns1:Instruccion_CPS ;
    ns1:textoExtracto "CPS T2 EQ 100 = TG1 5 2000. Cuando el tiempo que lleve transcurrido el temporizador T2 sea IGUAL al valor 100, se activará el temporizador T5 funcionando como monoestable y con una constante de tiempo de 2 s." ;
    ns1:tieneComponente ns1:Operando_Temporizador .

ns1:Registro_CNC_PLC a ns1:ComponenteElectrico ;
    rdfs:label "Registro de comunicación CNC-PLC" ;
    ns1:identificador "R_CNC-PLC" ;
    ns1:textoExtracto "Se pueden utilizar como operandos los registros de comunicación CNC-PLC" .

ns1:Marca_M100 a ns1:ComponenteElectrico ;
    rdfs:label "Marca M100" ;
    ns1:identificador "M100" ;
    ns1:textoExtracto "Si la cuenta interna del contador C12 es MAYOR que el valor del registro R14, el PLC asignará a la marca M100 el valor 1" .

ns1:Operando_Contador a ns1:ComponenteElectrico ;
    rdfs:label "Contador (C1~C256)" ;
    ns1:identificador "C1~C256" ;
    ns1:textoExtracto "Se pueden utilizar como operandos los contadores (cuenta interna) [...] C1ꞏꞏ256" .

ns1:Operando_Registro a ns1:ComponenteElectrico ;
    rdfs:label "Registro (R1~R1024)" ;
    ns1:identificador "R1~R1024" ;
    ns1:textoExtracto "Se pueden utilizar como operandos los registros [...] R1ꞏꞏ1024" .

ns1:Operando_Temporizador a ns1:ComponenteElectrico ;
    rdfs:label "Temporizador (T1~T512)" ;
    ns1:identificador "T1~T512" ;
    ns1:textoExtracto "Se pueden utilizar como operandos los temporizadores (cuenta interna) [...] T1ꞏꞏ512" .

ns1:Instruccion_CPS a ns1:InterfazUsuario ;
    rdfs:label "Instrucción CPS (Comparación entre operandos)" ;
    ns1:identificador "CPS" ;
    ns1:textoExtracto "La instrucción CPS permite realizar comparaciones entre dos operandos, comprobando si el primer operando es mayor (GT), mayor o igual (GE), igual (EQ), distinto (NE), menor o igual (LE) o menor (LT) que el segundo. [...] El formato de programación es: T1ꞏꞏ512 GT CPS T1ꞏꞏ512 C1ꞏꞏ256 GE C1ꞏꞏ256 R1ꞏꞏ1024 EQ R1ꞏꞏ1024 R CNC-PLC NE R CNC-PLC LT" .

