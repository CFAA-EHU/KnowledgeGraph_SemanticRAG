@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Contador_734_1 a ns1:ComponenteElectrico ;
    rdfs:label "Contador C1"@es ;
    ns1:identificador "C1" ;
    ns1:textoExtracto "Un flanco de subida en la entrada I2 preseleccionará el contador C1 con el valor 100."@es ;
    ns1:valor "100" .

ns1:EntradaFisica_734_1 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada física I2"@es ;
    ns1:identificador "I2" ;
    ns1:textoExtracto "La salida O3 mostrará el estado de la entrada I2. [...] Un flanco de bajada en la entrada I2 activará la entrada de arranque TG1."@es .

ns1:MarcaComunicacion_734_1 a ns1:ComponenteElectrico ;
    rdfs:label "Marca M100"@es ;
    ns1:identificador "M100" ;
    ns1:textoExtracto "La marca M100 mostrará el estado negado de la entrada I2."@es .

ns1:Salida_734_1 a ns1:ComponenteElectrico ;
    rdfs:label "Salida O3"@es ;
    ns1:identificador "O3" ;
    ns1:textoExtracto "La salida O3 mostrará el estado de la entrada I2."@es .

ns1:SistemaPLC_734 a ns1:Sistema ;
    rdfs:label "Sistema PLC con recursos modificables"@es ;
    ns1:identificador "I1/1024" ;
    ns1:textoExtracto "Las instrucciones de acción permiten alterar el estado de los recursos del PLC y de las marcas de comunicación CNC-PLC. [...] Cuando se vea el campo 'I1/1024' se debe entender que sólo se puede modificar el estado de las entradas no utilizadas."@es ;
    ns1:tieneComponente ns1:InstruccionAccion_734_1,
        ns1:InstruccionAccion_734_2,
        ns1:InstruccionAccion_734_3,
        ns1:InstruccionAccion_734_4 .

ns1:Temporizador_734_1 a ns1:ComponenteElectrico ;
    rdfs:label "Temporizador T2 (entrada TG1)"@es ;
    ns1:identificador "T2" ;
    ns1:textoExtracto "Un flanco de bajada en la entrada I2 activará la entrada de arranque TG1 del temporizador T2."@es .

ns1:InstruccionAccion_734_1 a ns1:ComponenteElectrico ;
    rdfs:label "Instrucción de acción binaria (I2 = O3)"@es ;
    ns1:identificador "I2 = O3" ;
    ns1:textoExtracto "La salida O3 mostrará el estado de la entrada I2."@es .

ns1:InstruccionAccion_734_2 a ns1:ComponenteElectrico ;
    rdfs:label "Instrucción de acción binaria con NOT (M100 = NOT I2)"@es ;
    ns1:identificador "NOT M100" ;
    ns1:textoExtracto "La marca M100 mostrará el estado negado de la entrada I2."@es .

ns1:InstruccionAccion_734_3 a ns1:ComponenteElectrico ;
    rdfs:label "Instrucción de acción de flanco (TG1 activada por I2)"@es ;
    ns1:identificador "NOT TG1" ;
    ns1:textoExtracto "Un flanco de bajada en la entrada I2 activará la entrada de arranque TG1 del temporizador T2."@es .

ns1:InstruccionAccion_734_4 a ns1:ComponenteElectrico ;
    rdfs:label "Instrucción de acción de preselección (CPR 1 100)"@es ;
    ns1:identificador "CPR 1 100" ;
    ns1:textoExtracto "Un flanco de subida en la entrada I2 preseleccionará el contador C1 con el valor 100."@es ;
    ns1:valor "100" .

