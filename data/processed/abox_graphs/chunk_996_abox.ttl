@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Entrada_I3 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada I3" ;
    ns1:textoExtracto "Asigna a la entrada de arranque TG1 del temporizador T4 el estado de la entrada I3, por lo que un flanco de subida en I3 activará la entrada de arranque TG1 del temporizador T4." .

ns1:Marca_M111 a ns1:ComponenteElectrico ;
    rdfs:label "Marca M111" ;
    ns1:textoExtracto "Asigna a la marca M111 el valor obtenido en la evaluación de la Expresión lógica (I2 OR I3) AND (I4 OR (NOT I5 AND I6))." .

ns1:Entrada_TG1_T4 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de arranque TG1 (Temporizador T4)" ;
    ns1:controla ns1:Temporizador_T4 ;
    ns1:textoExtracto "Asigna a la entrada de arranque TG1 del temporizador T4 el estado de la entrada I3, por lo que un flanco de subida en I3 activará la entrada de arranque TG1 del temporizador T4." .

ns1:Temporizador_T4 a ns1:ComponenteElectrico ;
    rdfs:label "Temporizador T4" ;
    ns1:textoExtracto "Asigna a la entrada de arranque TG1 del temporizador T4 el estado de la entrada I3, por lo que un flanco de subida en I3 activará la entrada de arranque TG1 del temporizador T4." ;
    ns1:tieneComponente ns1:Entrada_TG1_T4 .

