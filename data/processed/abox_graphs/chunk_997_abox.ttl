@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Entrada_I12 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada I12" ;
    ns1:identificador "I12" ;
    ns1:textoExtracto "I12 OR NOT I22 = RES M55" .

ns1:Entrada_I22 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada I22" ;
    ns1:identificador "I22" ;
    ns1:textoExtracto "I12 OR NOT I22 = RES M55" .

ns1:Entrada_I8 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada I8" ;
    ns1:identificador "I8" ;
    ns1:textoExtracto "DFU I8 OR DFD M22 = CPL B12R35" .

ns1:Instruccion_CPL a ns1:AccionProhibida ;
    rdfs:label "Instrucción CPL" ;
    ns1:controla ns1:Bit_B12R35 ;
    ns1:identificador "CPL" ;
    ns1:textoExtracto "= CPL M 1/8192 [...] Si expresión \"1\" complementa el recurso. Si el resultado obtenido en la evaluación de la expresión lógica es un \"1\" complementa el estado del recurso especificado." .

ns1:Instruccion_RES a ns1:AccionProhibida ;
    rdfs:label "Instrucción RES" ;
    ns1:controla ns1:Marca_M55,
        ns1:Marca_M65 ;
    ns1:identificador "RES" ;
    ns1:textoExtracto "= RES O 1/1024 [...] Si expresión \"1\" asigna \"0\" al recurso. Si el resultado obtenido en la evaluación de la expresión lógica es un \"1\", asigna un \"0\" al recurso especificado." .

ns1:Instruccion_SET a ns1:AccionProhibida ;
    rdfs:label "Instrucción SET" ;
    ns1:controla ns1:Bit_B0R100,
        ns1:Recurso_Marca_CNC_PLC ;
    ns1:identificador "SET" ;
    ns1:textoExtracto "= SET I 1/1024 [...] Si expresión \"1\" asigna \"1\" al recurso. Si el resultado obtenido en la evaluación de la expresión lógica es un \"1\", asigna un \"1\" al recurso especificado." .

ns1:Marca_M22 a ns1:ComponenteElectrico ;
    rdfs:label "Marca M22" ;
    ns1:identificador "M22" ;
    ns1:textoExtracto "DFU I8 OR DFD M22 = CPL B12R35" .

ns1:Registro_R100 a ns1:ComponenteElectrico ;
    rdfs:label "Registro R100" ;
    ns1:identificador "R100" ;
    ns1:textoExtracto "se activará (se pondrá a \"1\") el bit 0 del registro R100" .

ns1:Registro_R35 a ns1:ComponenteElectrico ;
    rdfs:label "Registro R35" ;
    ns1:identificador "R35" ;
    ns1:textoExtracto "el PLC complementará el estado del bit 12 del registro R35" .

ns1:Temporizador_T2 a ns1:ComponenteElectrico ;
    rdfs:label "Temporizador T2" ;
    ns1:identificador "T2" ;
    ns1:monitoreaParametro ns1:Bit_B0R100 ;
    ns1:textoExtracto "CPS T2 EQ 100 = SET B0R100 [...] Cuando la cuenta (tiempo) del temporizador T2 sea igual a 100" .

ns1:Bit_B12R35 a ns1:ComponenteElectrico ;
    rdfs:label "Bit 12 del Registro R35" ;
    ns1:identificador "B12R35" ;
    ns1:textoExtracto "el PLC complementará el estado del bit 12 del registro R35" .

ns1:Marca_M55 a ns1:ComponenteElectrico ;
    rdfs:label "Marca M55" ;
    ns1:identificador "M55" ;
    ns1:textoExtracto "I12 OR NOT I22 = RES M55" .

ns1:Marca_M65 a ns1:ComponenteElectrico ;
    rdfs:label "Marca M65" ;
    ns1:identificador "M65" ;
    ns1:textoExtracto "= NOT RES M65" .

ns1:Recurso_Marca_CNC_PLC a ns1:ComponenteElectrico ;
    rdfs:label "Marca CNC-PLC" ;
    ns1:identificador "CNC-PLC" ;
    ns1:textoExtracto "Marca CNC-PLC = SET" .

ns1:Bit_B0R100 a ns1:ComponenteElectrico ;
    rdfs:label "Bit 0 del Registro R100" ;
    ns1:identificador "B0R100" ;
    ns1:textoExtracto "se activará (se pondrá a \"1\") el bit 0 del registro R100" .

