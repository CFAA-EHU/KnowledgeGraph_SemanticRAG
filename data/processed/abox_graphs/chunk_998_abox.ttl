@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Entrada_I12 a ns1:Parametro ;
    rdfs:label "Entrada I12" ;
    ns1:identificador "I12" ;
    ns1:textoExtracto "(I12 AND I23) OR M54 = O6" .

ns1:Entrada_I2 a ns1:Parametro ;
    rdfs:label "Entrada I2" ;
    ns1:identificador "I2" ;
    ns1:textoExtracto "I2 = CAL L5 = O2 Con I2=1 se ejecuta la subrutina L5 y una vez finalizada ésta el PLC asigna a la salida O2 el valor de la entrada I2 (1)." ;
    ns1:valor "1" .

ns1:Entrada_I23 a ns1:Parametro ;
    rdfs:label "Entrada I23" ;
    ns1:identificador "I23" ;
    ns1:textoExtracto "(I12 AND I23) OR M54 = O6" .

ns1:Entrada_I8 a ns1:Parametro ;
    rdfs:label "Entrada I8" ;
    ns1:identificador "I8" ;
    ns1:textoExtracto "I8 = JMP L12 Si I8=1 el programa continúa en L12 y no se ejecutan los bloques intermedios." ;
    ns1:valor "1" .

ns1:Etiqueta_L12 a ns1:Parametro ;
    rdfs:label "Etiqueta L12" ;
    ns1:identificador "L12" ;
    ns1:textoExtracto "I8 = JMP L12 Si I8=1 el programa continúa en L12 y no se ejecutan los bloques intermedios." .

ns1:Etiqueta_L123 a ns1:Parametro ;
    rdfs:label "Etiqueta L123" ;
    ns1:identificador "L123" ;
    ns1:textoExtracto "JMP L123 Si la etiqueta se definió como L123." .

ns1:Etiqueta_L234 a ns1:Parametro ;
    rdfs:label "Etiqueta L234" ;
    ns1:identificador "L234" ;
    ns1:textoExtracto "CAL L234 Si se definió como L234." .

ns1:Etiqueta_L5 a ns1:Parametro ;
    rdfs:label "Etiqueta L5" ;
    ns1:identificador "L5" ;
    ns1:textoExtracto "I2 = CAL L5 = O2 Con I2=1 se ejecuta la subrutina L5 y una vez finalizada ésta el PLC asigna a la salida O2 el valor de la entrada I2 (1)." .

ns1:Etiqueta_L_ASA2 a ns1:Parametro ;
    rdfs:label "Etiqueta L_ASA2" ;
    ns1:identificador "L_ASA2" ;
    ns1:textoExtracto "JMP L_ASA2 Si la etiqueta se definió como L_ASA2." .

ns1:Instruccion_CAL a ns1:AccionProhibida ;
    rdfs:label "Llamada a subrutina (CAL)" ;
    ns1:identificador "CAL" ;
    ns1:textoExtracto "CAL Llamada a subrutina. Si el resultado obtenido en la evaluación de la expresión lógica es un \"1\" esta acción ejecuta la subrutina indicada. Si el resultado obtenido en la evaluación de la expresión lógica es un \"0\" esta acción será ignorada por el PLC, continuando el programa sin ejecutar dicha subrutina." .

ns1:Instruccion_JMP a ns1:AccionProhibida ;
    rdfs:label "Salto incondicional (JMP)" ;
    ns1:identificador "JMP" ;
    ns1:textoExtracto "JMP Salto incondicional. Si el resultado obtenido en la evaluación de la expresión lógica es un \"1\", provoca un salto a la etiqueta especificada. Si el resultado es \"0\" continúa en la siguiente línea de programa." .

ns1:Instruccion_RET a ns1:AccionProhibida ;
    rdfs:label "Retorno de subrutina (RET)" ;
    ns1:identificador "RET" ;
    ns1:textoExtracto "RET Retorno o final de subrutina." .

ns1:Parametro_T2 a ns1:Parametro ;
    rdfs:label "Temporizador T2" ;
    ns1:identificador "T2" ;
    ns1:textoExtracto "CPS T2 EQ 2000 = O12" ;
    ns1:valor "2000" .

ns1:Salida_O12 a ns1:Parametro ;
    rdfs:label "Salida O12" ;
    ns1:identificador "O12" ;
    ns1:textoExtracto "CPS T2 EQ 2000 = O12" .

ns1:Salida_O2 a ns1:Parametro ;
    rdfs:label "Salida O2" ;
    ns1:identificador "O2" ;
    ns1:textoExtracto "I2 = CAL L5 = O2 Con I2=1 se ejecuta la subrutina L5 y una vez finalizada ésta el PLC asigna a la salida O2 el valor de la entrada I2 (1)." ;
    ns1:valor "1" .

ns1:Salida_O6 a ns1:Parametro ;
    rdfs:label "Salida O6" ;
    ns1:identificador "O6" ;
    ns1:textoExtracto "(I12 AND I23) OR M54 = O6" .

ns1:Salida_O8 a ns1:Parametro ;
    rdfs:label "Salida O8" ;
    ns1:identificador "O8" ;
    ns1:textoExtracto "NOT M14 AND NOT B7R120 = O8" .

ns1:Subrutina_L_GEAR a ns1:ModoOperacion ;
    rdfs:label "Subrutina L_GEAR" ;
    ns1:identificador "L_GEAR" ;
    ns1:textoExtracto "CAL L_GEAR Si se definió como L_GEAR." .

ns1:Subrutina_OILING a ns1:ModoOperacion ;
    rdfs:label "Subrutina OILING" ;
    ns1:identificador "OILING" ;
    ns1:textoExtracto "CAL OILING Si se definió como SUB OILING." .

