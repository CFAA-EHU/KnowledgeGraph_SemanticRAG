@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Subrutina_RupturaSecuencia_738 a ns1:Sistema ;
    rdfs:label "Subrutina de ruptura de secuencia"@es ;
    ns1:identificador "4.4.3" ;
    ns1:textoExtracto "Con I2=0 no se ejecuta la subrutina y el PLC asigna a la salida O2 el valor de la entrada I2 (0). [...] Si durante la ejecución de una subrutina el PLC detecta un RET validado dará por finalizada la subrutina."@es ;
    ns1:tieneComponente ns1:Directiva_RET_738,
        ns1:Entrada_I2_738,
        ns1:Salida_O2_738 .

ns1:Directiva_RET_738 a ns1:Directiva ;
    rdfs:label "Directiva RET"@es ;
    ns1:identificador "RET" ;
    ns1:textoExtracto "RET Retorno o final de subrutina. Si el resultado obtenido en la evaluación de la expresión lógica es un '1' esta acción será tratada por el PLC como la proposición directiva END. Si el resultado es '0', será ignorada por el PLC."@es .

ns1:Entrada_I2_738 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada I2"@es ;
    ns1:textoExtracto "el PLC asigna a la salida O2 el valor de la entrada I2 (0)"@es ;
    ns1:valor "0" .

ns1:Salida_O2_738 a ns1:ComponenteElectrico ;
    rdfs:label "Salida O2"@es ;
    ns1:textoExtracto "el PLC asigna a la salida O2 el valor de la entrada I2 (0)"@es .

