    rdfs:label "Fixture coordinate system"@en ;
    ns1:textoExtracto "#ACS"@en .

ns1:Instruccion_ANGAX_OFF a ns1:Parametro ;
    rdfs:label "Turn angular transformation off"@en ;
    ns1:textoExtracto "#ANGAX OFF"@en .

ns1:Instruccion_ANGAX_ON a ns1:Parametro ;
    rdfs:label "Turn angular transformation on"@en ;
    ns1:textoExtracto "#ANGAX ON"@en .

ns1:Instruccion_ANGAX_SUSP a ns1:Parametro ;
    rdfs:label "Freeze angular transformation"@en ;
    ns1:textoExtracto "#ANGAX SUSP"@en .

ns1:Instruccion_ASPLINE_ENDTANG a ns1:Parametro ;
    rdfs:label "Akima splines. Type of final tangent"@en ;
    ns1:textoExtracto "#ASPLINE ENDTANG"@en .

ns1:Instruccion_ASPLINE_MODE a ns1:Parametro ;
    rdfs:label "Akima splines. Selection of tangent type"@en ;
    ns1:textoExtracto "#ASPLINE MODE"@en .

ns1:Instruccion_ASPLINE_STARTTANG a ns1:Parametro ;
    rdfs:label "Akima splines. Type of starting tangent"@en ;
    ns1:textoExtracto "#ASPLINE STARTTANG"@en .

ns1:Instruccion_AXIS a ns1:Parametro ;
    rdfs:label "Axis upon which the additive manual intervention is applied"@en ;
    ns1:textoExtracto "#AXIS"@en .

ns1:Instruccion_CALL a ns1:Parametro ;
    rdfs:label "Call to a global or local subroutine"@en ;
    ns1:textoExtracto "#CALL"@en .

ns1:Instruccion_CALL_AX a ns1:Parametro ;
    rdfs:label "Add a new axis to the configuration of the channel"@en ;
    ns1:textoExtracto "#CALL AX"@en .

ns1:Instruccion_CALL_SP a ns1:Parametro ;
    rdfs:label "Add a spindle to the configuration of the channel"@en ;
    ns1:textoExtracto "#CALL SP"@en .

ns1:Instruccion_CAM_OFF a ns1:Parametro ;
    rdfs:label "Cancel the electronic cam"@en ;
    ns1:textoExtracto "#CAM OFF"@en .

ns1:Instruccion_CAM_ON a ns1:Parametro ;
    rdfs:label "Activate the electronic cam (real coordinates)"@en ;
    ns1:textoExtracto "#CAM ON"@en .

ns1:Instruccion_CAX a ns1:Parametro ;
    rdfs:label "\"C\" axis. Activating the spindle as ·C· axis"@en ;
    ns1:textoExtracto "#CAX"@en .

ns1:Instruccion_CD_OFF a ns1:Parametro ;
    rdfs:label "Cancel collision detection"@en ;
    ns1:textoExtracto "#CD OFF"@en .

ns1:Instruccion_CD_ON a ns1:Parametro ;
    rdfs:label "Activating collision detection"@en ;
    ns1:textoExtracto "#CD ON"@en .

ns1:Instruccion_CLEAR a ns1:Parametro ;
    rdfs:label "Channels. It clears the synchronism marks of the channel"@en ;
    ns1:textoExtracto "#CLEAR"@en .

ns1:Instruccion_COMMENT_BEGIN a ns1:Parametro ;
    rdfs:label "Beginning of comment"@en ;
    ns1:textoExtracto "#COMMENT BEGIN"@en .

ns1:Instruccion_COMMENT_END a ns1:Parametro ;
    rdfs:label "End of comment"@en ;
    ns1:textoExtracto "#COMMENT END"@en .

ns1:Instruccion_CONTJOG a ns1:Parametro ;
    rdfs:label "Manual intervention. Feedrate in continuous jog"@en ;
    ns1:textoExtracto "#CONTJOG"@en .

ns1:Instruccion_DO a ns1:Parametro ;
    rdfs:label "Conditional block repetition"@en ;
    ns1:textoExtracto "$DO $ENDDO"@en .

ns1:Instruccion_ELSEIF a ns1:Parametro ;
    rdfs:label "Conditional execution"@en ;
    ns1:textoExtracto "$ELSEIF $ELSE"@en .

ns1:Instruccion_FOR a ns1:Parametro ;
    rdfs:label "Block repetition"@en ;
    ns1:textoExtracto "$FOR $ENDFOR"@en .

ns1:Instruccion_GOTO a ns1:Parametro ;
    rdfs:label "Block skip"@en ;
    ns1:textoExtracto "$GOTO" .

ns1:Instruccion_IF a ns1:Parametro ;
    rdfs:label "Conditional execution"@en ;
    ns1:textoExtracto "$IF $ENDIF"@en .

ns1:Instruccion_L a ns1:Parametro ;
    rdfs:label "Call to a global subroutine"@en ;
    ns1:textoExtracto "L"@en .

ns1:Instruccion_LL a ns1:Parametro ;
    rdfs:label "Call to a local subroutine"@en ;
    ns1:textoExtracto "LL"@en .

ns1:Instruccion_SWITCH a ns1:Parametro ;
    rdfs:label "Conditional execution"@en ;
