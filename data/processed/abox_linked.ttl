ns1:ModoOperacionAssumeOrigins a ns1:ModoOperacion ;
    rdfs:label "Assume the active origins for execution" ;
    ns1:textoExtracto "Assume the active origins for execution. When starting the simulation or pressing the simulation reset, the CNC applies to the simulation the origins set in the execution environment (for example, the part zero set in jog mode)." .

ns1:ModoOperacionBlockSkip a ns1:ModoOperacion ;
    rdfs:label "Block skip" ;
    ns1:textoExtracto "Option to simulate the external \"block skip\" switch. Being this option active, the CNC does not simulate the blocks containing the block-skip character \"/\"." .

