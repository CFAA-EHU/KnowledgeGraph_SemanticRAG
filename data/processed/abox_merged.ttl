ns1:tieneFabricante a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "tiene fabricante",
        "tieneFabricante",
        "tieneFabricante"@es ;
    rdfs:comment "Propiedad que indica el fabricante de un componente.",
        "Propiedad que indica el fabricante del panel de operador de emergencia.",
        "Propiedad que relaciona un componente con su fabricante",
        "Propiedad que relaciona un componente con su fabricante.",
        "Relación que indica el fabricante de un componente.",
        "Relación que indica el fabricante de un componente."@es ;
    rdfs:domain [ a owl:Restriction ;
            owl:onProperty ns1:tieneFabricante ;
            owl:someValuesFrom ns1:SiemensAG ],
        [ a owl:Restriction ;
            owl:onProperty ns1:tieneFabricante ;
            owl:someValuesFrom ns1:Weidmuller ],
        ns1:BloqueProteccionDiferencial,
        ns1:Cabecera,
        ns1:CaudalimetroMecatronico,
