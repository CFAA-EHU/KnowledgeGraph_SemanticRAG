ns1:PanelInfografico a owl:Class ;
    rdfs:label "Panel infográfico",
        "PanelInfografico" ;
    rdfs:comment "Panel infográfico de advertencias con pictogramas STOP y triángulos de peligro; bloques rojos con texto blanco destacan consignación, prohibición de aire a presión y uso de mástil anticaídas",
        "Paneles infográficos con pictograma 'STOP' y avisos de seguridad." .

<https://vocab.cfaa.eus/broaching/base#Maquina> a owl:Class ;
    rdfs:label "Máquina" ;
    rdfs:comment "Clase base para máquinas EKIN, S. Coop." .

<https://vocab.cfaa.eus/broaching/electric/EntradaDigital> a owl:Class ;
    rdfs:label "Entrada digital" ;
    rdfs:comment "Punto de entrada en un sistema eléctrico para señales digitales." .

ns1:CarroPortaPiezas a owl:Class ;
    rdfs:label "Carro Porta-Piezas",
        "Carro porta-piezas",
        "CarroPortaPiezas",
        "Carro porta-piezas"@es ;
    rdfs:comment "Carro porta-piezas mencionado en el texto.",
        "Carro porta-piezas que se mueve durante el proceso de brochado.",
        "Carro que porta las piezas de la máquina",
        "Componente que realiza el desplazamiento durante el proceso de mecanizado.",
        "Vista 3D a color de la columna y el carro con globos numerados y recuadros en rojo; identifica cremalleras, servomotores, guías, frenos, fuelles y sensores" .

ns1:PlataformaLaterales a owl:Class ;
    rdfs:label "PlataformaLaterales" ;
    rdfs:comment "Componente mecánico descrito en la figura 4-13.",
        "Plataformas laterales mencionadas en el texto." .

ns1:SistemaEngrase a owl:Class ;
    rdfs:label "SistemaEngrase" ;
    rdfs:comment "Componente mecánico descrito en la figura 4-16." .

ns1:CarroPortaPieza a owl:Class ;
    rdfs:label "Carro porta-pieza",
        "Carro porta-piezas",
        "CarroPortaPieza",
        "Carro porta-pieza"@es ;
    rdfs:comment "Carro porta-piezas de la columna.",
        "Componente mecánico que porta piezas en la máquina de brochado.",
        "Explosivo funcional del carro y las guías traseras de contrapesos. Se destacan patines y bloqueos hidráulicos; etiquetas laterales listan frenos MAYR por posiciones izquierda/derecha.",
        "Para su apertura se tiene que dar cualquiera de estas posibilidades: Ciclo de cambio de cremallera con carro porta-pieza en posición inferior." ;
    rdfs:subClassOf ns1:ComponenteMaquina .

ns1:Columna a owl:Class ;
    rdfs:label "Columna",
        "Columna"@es ;
    rdfs:comment "Columna en la pantalla de arranque de motores.",
        "Componente montado sobre el zócalo.",
        "Corte 3D de la columna mostrando guías lineales, regla lineal, cremallera, piñón, servomotores y carro porta-piezas. Flechas y rótulos marcan la direccionalidad vertical del movimiento y la relación entre accionamientos y guiado.",
        "Estructura a la que está fijado el carro porta-brochas.",
        "Vista 3D a color de la columna y el carro con globos numerados y recuadros en rojo; identifica cremalleras, servomotores, guías, frenos, fuelles y sensores",
        "Estructura vertical de soporte de la máquina"@es .

ns1:PanelOperador a owl:Class ;
    rdfs:label "Panel Operador",
        "PanelOperador",
        "Panel Operador"@es,
        "Panel operador"@es ;
    rdfs:comment "Clase que representa un panel operador",
        "Panel de operación y control de la máquina" .

ns1:ArmarioNeumatico a owl:Class ;
    rdfs:label "ArmarioNeumatico" ;
    rdfs:comment "Componente mecánico descrito en la figura 4-15." .

ns1:FormacionPersonal a owl:Class ;
    rdfs:label "Formación del personal"@es .

ns1:PlatoDivisor a owl:Class ;
    rdfs:label "Plato divisor",
        "Plato divisor"@es ;
    rdfs:comment "Componente de la máquina que se cambia de base",
        "Componente mecánico utilizado para dividir ángulos en la máquina.",
        "Perspectiva del conjunto del plato sobre bancada con resaltado del plato (1) y servomotor (2). Paleta de colores separa elementos y facilita la correspondencia con referencias comerciales",
        "Perspectiva del plato con dentado Hirth, servomotor y torreta de micros (SQ46/SQ47). Colores cálidos resaltan el anillo dentado; flechas sugieren el giro tras el desbloqueo hidráulico.",
        "Clase que representa el plato divisor de la máquina."@es,
        "Componente de la máquina alumbrado por las lámparas verticales"@es .

ns1:SistemaHidraulico a owl:Class ;
    rdfs:label "SistemaHidraulico" ;
    rdfs:comment "Componente mecánico descrito en la figura 4-17." .

ns1:Sistema a owl:Class ;
    rdfs:label "Sistema" .

ns1:Maquina a owl:Class ;
    rdfs:label "Maquina",
        "MÁQUINA",
        "Máquina",
        "Máquina"@es ;
    rdfs:comment "Clase que representa una máquina en general.",
        "Equipo que requiere instalación en un recinto cerrado y protegido.",
        "Maquina que debe ser levantada inicialmente unos pocos centímetros del suelo para verificar su equilibrio.",
        "Máquina de brochado.",
        "Máquina diseñada y fabricada según los últimos avances de la técnica y las normas técnicas de seguridad vigentes",
        "Equipo o dispositivo mecánico"@es .

ns1:Componente a owl:Class ;
    rdfs:label "Componente" ;
    rdfs:comment "Clase base para componentes",
        "Clase base para componentes del sistema de refrigeración.",
        "Clase base para todos los componentes del sistema.",
        "Clase base para todos los componentes mecánicos o eléctricos." .

