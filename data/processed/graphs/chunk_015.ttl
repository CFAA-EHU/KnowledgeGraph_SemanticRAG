@prefix base: <http://example.org/base#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:Maquina a owl:Class ;
    rdfs:label "Máquina" .

base:ElementoDeSeguridad a owl:Class ;
    rdfs:label "Elemento de seguridad" .

base:MedidaDeProteccion a owl:Class ;
    rdfs:label "Medida de protección" .

base:Personal a owl:Class ;
    rdfs:label "Personal" .

base:PiezaDeRecambio a owl:Class ;
    rdfs:label "Pieza de recambio" .

base:ZonaDeTrabajo a owl:Class ;
    rdfs:label "Zona de trabajo" .

base:ManualDeInstrucciones a owl:Class ;
    rdfs:label "Manual de instrucciones" .

base:Cartel a owl:Class ;
    rdfs:label "Cartel" .

base:PlacaDeAdvertencia a owl:Class ;
    rdfs:label "Placa de advertencia" .

base:tieneElementoDeSeguridad a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:ElementoDeSeguridad .

base:verificarEstado a owl:ObjectProperty ;
    rdfs:domain base:ElementoDeSeguridad ;
    rdfs:range base:Maquina .

base:requiereInstruccion a owl:ObjectProperty ;
    rdfs:domain base:Personal ;
    rdfs:range base:Maquina .

base:debeRespetar a owl:ObjectProperty ;
    rdfs:domain base:Personal ;
    rdfs:range base:MedidaDeProteccion .

base:debeUtilizar a owl:ObjectProperty ;
    rdfs:domain base:Personal ;
    rdfs:range base:PrendaDeProteccion .

base:debeMantener a owl:ObjectProperty ;
    rdfs:domain base:ZonaDeTrabajo ;
    rdfs:range base:Maquina .

base:debeEstarLibreDe a owl:ObjectProperty ;
    rdfs:domain base:ZonaDeTrabajo ;
    rdfs:range base:Objeto .

base:debeObservar a owl:ObjectProperty ;
    rdfs:domain base:Personal ;
    rdfs:range base:Cartel .

base:debeRespetarManual a owl:ObjectProperty ;
    rdfs:domain base:Personal ;
    rdfs:range base:ManualDeInstrucciones .

base:debeMantenerOriginal a owl:ObjectProperty ;
    rdfs:domain base:PiezaDeRecambio ;
    rdfs:range base:PiezaDeRecambio .

base:debeDetenerse a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:Maquina .

base:debeComunicar a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:PersonaCompetente .

base:debeAprobar a owl:ObjectProperty ;
    rdfs:domain base:Modificacion ;
    rdfs:range base:EKIN .

base:afectaA a owl:ObjectProperty ;
    rdfs:domain base:Modificacion ;
    rdfs:range base:Maquina .

base:tienePlacaDeAdvertencia a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:PlacaDeAdvertencia .

base:noDebeRetirar a owl:ObjectProperty ;
    rdfs:domain base:Personal ;
    rdfs:range base:PlacaDeAdvertencia .

base:PrendaDeProteccion a owl:Class ;
    rdfs:label "Prenda de protección" .

base:Objeto a owl:Class ;
    rdfs:label "Objeto" .

base:PersonaCompetente a owl:Class ;
    rdfs:label "Persona competente" .

base:Modificacion a owl:Class ;
    rdfs:label "Modificación" .

base:EKIN a owl:Class ;
    rdfs:label "EKIN" .