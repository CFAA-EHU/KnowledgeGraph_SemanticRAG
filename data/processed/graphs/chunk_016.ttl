@prefix base: <http://example.org/base#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:Maquina a owl:Class ;
    rdfs:label "Máquina" .

base:PlacaDeAdvertencia a owl:Class ;
    rdfs:label "Placa de Advertencia" .

base:Instruccion a owl:Class ;
    rdfs:label "Instrucción" .

base:EnclavamientoDeSeguridad a owl:Class ;
    rdfs:label "Enclavamiento de Seguridad" .

base:Carro a owl:Class ;
    rdfs:label "Carro" .

base:Pieza a owl:Class ;
    rdfs:label "Pieza" .

base:Broche a owl:Class ;
    rdfs:label "Broche" .

base:tienePlacaDeAdvertencia a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:PlacaDeAdvertencia .

base:tieneInstruccion a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:Instruccion .

base:tieneEnclavamientoDeSeguridad a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:EnclavamientoDeSeguridad .

base:tieneCarro a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:Carro .

base:Carro a owl:Class ;
    rdfs:label "Carro" .

base:tienePieza a owl:ObjectProperty ;
    rdfs:domain base:Carro ;
    rdfs:range base:Pieza .

base:tieneBroche a owl:ObjectProperty ;
    rdfs:domain base:Pieza ;
    rdfs:range base:Broche .

base:estaBrochado a owl:ObjectProperty ;
    rdfs:domain base:Pieza ;
    rdfs:range base:Broche ;
    rdfs:comment "Incompleto: Requiere resolución externa" .