@prefix base: <http://example.org/base#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:EnclavamientoDeSeguridad a owl:Class ;
    rdfs:label "EnclavamientoDeSeguridad" .

base:CarroDeLaMaquina a owl:Class ;
    rdfs:label "CarroDeLaMaquina" .

base:PiezaABrochar a owl:Class ;
    rdfs:label "PiezaABrochar" .

base:UtilDeAmarre a owl:Class ;
    rdfs:label "UtilDeAmarre" .

base:Fluido a owl:Class ;
    rdfs:label "Fluido" ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

base:DefensaDeLaMaquina a owl:Class ;
    rdfs:label "DefensaDeLaMaquina" .

base:ElementoEnMovimiento a owl:Class ;
    rdfs:label "ElementoEnMovimiento" ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

base:Pieza a owl:Class ;
    rdfs:label "Pieza" .

base:MedioDeElevacion a owl:Class ;
    rdfs:label "MedioDeElevacion" .

base:LegislacionVigente a owl:Class ;
    rdfs:label "LegislacionVigente" ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

base:Maquina a owl:Class ;
    rdfs:label "Maquina" .

base:tieneEnclavamientoDeSeguridad a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:EnclavamientoDeSeguridad .

base:tieneCarro a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:CarroDeLaMaquina .

base:tienePiezaABrochar a owl:ObjectProperty ;
    rdfs:domain base:CarroDeLaMaquina ;
    rdfs:range base:PiezaABrochar .

base:tieneUtilDeAmarre a owl:ObjectProperty ;
    rdfs:domain base:CarroDeLaMaquina ;
    rdfs:range base:UtilDeAmarre .

base:tieneFluido a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:Fluido .

base:tieneDefensa a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:DefensaDeLaMaquina .

base:tieneElementoEnMovimiento a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:ElementoEnMovimiento .

base:tienePieza a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:Pieza .

base:requiereMedioDeElevacion a owl:ObjectProperty ;
    rdfs:domain base:Pieza ;
    rdfs:range base:MedioDeElevacion .

base:cumpleLegislacion a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:LegislacionVigente .

base:debeEstarCorrectamenteColocada a owl:ObjectProperty ;
    rdfs:domain base:PiezaABrochar ;
    rdfs:range base:UtilDeAmarre .

base:debeEstarEnPosicionCorrecta a owl:ObjectProperty ;
    rdfs:domain base:DefensaDeLaMaquina ;
    rdfs:range base:Maquina .

base:debeSeguirLegislacion a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:LegislacionVigente .

base:tieneEfectoPerjudicial a owl:ObjectProperty ;
    rdfs:domain base:Fluido ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

base:debeSolicitarMedidasDeSeguridad a owl:ObjectProperty ;
    rdfs:domain base:Fluido ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "Incompleto: Requiere resolución externa" .