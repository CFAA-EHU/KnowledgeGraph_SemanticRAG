@prefix base: <http://example.org/base#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:ElementoDeSeguridad a owl:Class ;
    rdfs:label "ElementoDeSeguridad" .

base:Máquina a owl:Class ;
    rdfs:label "Máquina" .

base:InterruptorGeneralDelArmarioEléctrico a owl:Class ;
    rdfs:label "InterruptorGeneralDelArmarioEléctrico" ;
    rdfs:subClassOf base:ElementoDeSeguridad .

base:PulsadorDeParadaDeEmergencia a owl:Class ;
    rdfs:label "PulsadorDeParadaDeEmergencia" ;
    rdfs:subClassOf base:ElementoDeSeguridad .

base:PanelDesmontable a owl:Class ;
    rdfs:label "PanelDesmontable" ;
    rdfs:subClassOf base:ElementoDeSeguridad .

base:Puerta a owl:Class ;
    rdfs:label "Puerta" ;
    rdfs:subClassOf base:ElementoDeSeguridad .

base:PanelFijo a owl:Class ;
    rdfs:label "PanelFijo" ;
    rdfs:subClassOf base:ElementoDeSeguridad .

base:verificarEstado a owl:ObjectProperty ;
    rdfs:domain base:Máquina ;
    rdfs:range base:ElementoDeSeguridad ;
    rdfs:label "verificarEstado" .

base:requerirSustitución a owl:ObjectProperty ;
    rdfs:domain base:ElementoDeSeguridad ;
    rdfs:range base:ElementoDeSeguridad ;
    rdfs:label "requerirSustitución" .

base:afectar a owl:ObjectProperty ;
    rdfs:domain base:TareaDeMantenimiento ;
    rdfs:range base:ElementoDeSeguridad ;
    rdfs:label "afectar" .

base:comprobarFuncionamiento a owl:ObjectProperty ;
    rdfs:domain base:PersonalDeMantenimiento ;
    rdfs:range base:ElementoDeSeguridad ;
    rdfs:label "comprobarFuncionamiento" .

base:TareaDeMantenimiento a owl:Class ;
    rdfs:label "TareaDeMantenimiento" .

base:PersonalDeMantenimiento a owl:Class ;
    rdfs:label "PersonalDeMantenimiento" .