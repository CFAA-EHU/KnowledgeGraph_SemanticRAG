@prefix base: <http://example.org/base#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:Puerta a owl:Class ;
    rdfs:label "Puerta"@es .

base:InterruptorDeSeguridad a owl:Class ;
    rdfs:label "Interruptor de Seguridad"@es .

base:Sistema a owl:Class ;
    rdfs:label "Sistema"@es .

base:Servomotor a owl:Class ;
    rdfs:label "Servomotor"@es .

base:Máquina a owl:Class ;
    rdfs:label "Máquina"@es .

base:tieneInterruptorDeSeguridad a owl:ObjectProperty ;
    rdfs:domain base:Puerta ;
    rdfs:range base:InterruptorDeSeguridad .

base:controla a owl:ObjectProperty ;
    rdfs:domain base:InterruptorDeSeguridad ;
    rdfs:range base:Puerta .

base:desconecta a owl:ObjectProperty ;
    rdfs:domain base:InterruptorDeSeguridad ;
    rdfs:range base:Sistema ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

base:desconectaServomotor a owl:ObjectProperty ;
    rdfs:domain base:InterruptorDeSeguridad ;
    rdfs:range base:Servomotor .

base:provocaParada a owl:ObjectProperty ;
    rdfs:domain base:InterruptorDeSeguridad ;
    rdfs:range base:Máquina .