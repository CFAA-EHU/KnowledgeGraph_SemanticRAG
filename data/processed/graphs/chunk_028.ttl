@prefix base: <http://example.org/base#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:ArmarioElectrico a owl:Class .
base:InterruptorGeneral a owl:Class ;
    rdfs:subClassOf base:ArmarioElectrico .
base:Maquina a owl:Class .
base:Servomotor a owl:Class ;
    rdfs:subClassOf base:Maquina .
base:Sistema a owl:Class ;
    rdfs:subClassOf base:Maquina .

base:tieneInterruptorGeneral a owl:ObjectProperty ;
    rdfs:domain base:ArmarioElectrico ;
    rdfs:range base:InterruptorGeneral .
base:realizaConexion a owl:ObjectProperty ;
    rdfs:domain base:InterruptorGeneral ;
    rdfs:range base:Maquina .
base:realizaDesconexion a owl:ObjectProperty ;
    rdfs:domain base:InterruptorGeneral ;
    rdfs:range base:Maquina .
base:requiereConsignacion a owl:ObjectProperty ;
    rdfs:domain base:Maquina ;
    rdfs:range base:InterruptorGeneral .
base:evitaAccionInvoluntaria a owl:ObjectProperty ;
    rdfs:domain base:InterruptorGeneral ;
    rdfs:range base:Maquina ;
    rdfs:comment "Incompleto: Requiere resolución externa" .
base:tieneCandado a owl:ObjectProperty ;
    rdfs:domain base:InterruptorGeneral ;
    rdfs:range base:Maquina ;
    rdfs:comment "Incompleto: Requiere resolución externa" .