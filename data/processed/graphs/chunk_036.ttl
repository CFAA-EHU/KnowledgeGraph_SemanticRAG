@prefix base: <http://example.org/base#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

base:Color rdf:type owl:Class ;
    rdfs:label "Color"@es .

base:Columna rdf:type owl:Class ;
    rdfs:label "Columna"@es .

base:Carro rdf:type owl:Class ;
    rdfs:label "Carro"@es .

base:Carenado rdf:type owl:Class ;
    rdfs:label "Carenado"@es .

base:ArmarioElectrico rdf:type owl:Class ;
    rdfs:label "ArmarioEléctrico"@es .

base:Pupitre rdf:type owl:Class ;
    rdfs:label "Pupitre"@es .

base:tieneColor rdf:type owl:DatatypeProperty ;
    rdfs:domain [ rdf:type owl:Class ;
                  rdfs:subClassOf base:Columna, base:Carro, base:Carenado, base:ArmarioElectrico, base:Pupitre ] ;
    rdfs:range xsd:string ;
    rdfs:label "tieneColor"@es .

base:BlancoRAL7035 rdf:type owl:NamedIndividual ;
    rdf:type base:Color ;
    rdfs:label "Blanco RAL 7035"@es .