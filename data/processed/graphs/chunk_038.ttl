@prefix : <http://example.org/ontology#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix base: <http://example.org/base#> .
@prefix elec: <http://example.org/electric#> .

:PupitreDeMandoPrincipal a owl:Class ;
    rdfs:label "Pupitre de mando principal"@es ;
    rdfs:comment "Pupitre de mando principal con brazo articulado"@es .

:PantallaTactil a owl:Class ;
    rdfs:label "Pantalla táctil"@es ;
    rdfs:comment "Pantalla táctil de pupitre principal"@es .

elec:tienePantallaTactil a owl:ObjectProperty ;
    rdfs:domain :PupitreDeMandoPrincipal ;
    rdfs:range :PantallaTactil ;
    rdfs:label "tiene pantalla táctil"@es .

elec:modelo a owl:DatatypeProperty ;
    rdfs:domain :PantallaTactil ;
    rdfs:range xsd:string ;
    rdfs:label "modelo"@es .

elec:fabricante a owl:DatatypeProperty ;
    rdfs:domain :PantallaTactil ;
    rdfs:range xsd:string ;
    rdfs:label "fabricante"@es .

elec:tamañoPantalla a owl:DatatypeProperty ;
    rdfs:domain :PantallaTactil ;
    rdfs:range xsd:string ;
    rdfs:label "tamaño de pantalla"@es .

elec:memoria a owl:DatatypeProperty ;
    rdfs:domain :PantallaTactil ;
    rdfs:range xsd:string ;
    rdfs:label "memoria"@es .