@prefix base: <http://example.org/equipoHidraulico#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:TomaDePresion a owl:Class ;
    rdfs:label "TomaDePresion" ;
    rdfs:comment "Clase que representa una toma de presión en el equipo hidráulico." .

base:TomaDePresion18G a owl:Class ;
    rdfs:label "TomaDePresion18G" ;
    rdfs:subClassOf base:TomaDePresion ;
    rdfs:comment "Subclase específica de toma de presión con tamaño 1/8 G." .

base:TomaDePresion18G rdfs:isDefinedBy <http://example.org/equipoHidraulico#TomaDePresion18G> .