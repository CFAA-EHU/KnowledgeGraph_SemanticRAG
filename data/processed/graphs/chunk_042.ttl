@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix base: <http://example.org/base#> .
@prefix modo: <http://example.org/modo#> .

base:ModoManual a owl:Class ;
    rdfs:label "ModoManual" .

base:ModoAutomaticoCargaDescargaManual a owl:Class ;
    rdfs:label "ModoAutomaticoCargaDescargaManual" .

modo:tieneModo a owl:ObjectProperty ;
    rdfs:domain base:ModoManual ;
    rdfs:range base:ModoAutomaticoCargaDescargaManual .

modo:tieneModo a owl:ObjectProperty ;
    rdfs:domain base:ModoAutomaticoCargaDescargaManual ;
    rdfs:range base:ModoManual .