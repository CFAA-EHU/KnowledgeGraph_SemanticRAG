@prefix base: <http://example.org/base#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:CarroPortaPiezas a owl:Class ;
    rdfs:label "CarroPortaPiezas" .

base:Patin a owl:Class ;
    rdfs:label "Patín" .

base:BloqueoHidraulico a owl:Class ;
    rdfs:label "BloqueoHidraulico" .

base:Contrapeso a owl:Class ;
    rdfs:label "Contrapeso" .

base:Guia a owl:Class ;
    rdfs:label "Guía" .

base:Columna a owl:Class ;
    rdfs:label "Columna" .

base:tienePatines a owl:ObjectProperty ;
    rdfs:domain base:CarroPortaPiezas ;
    rdfs:range base:Patin .

base:tieneBloqueosHidraulicos a owl:ObjectProperty ;
    rdfs:domain base:CarroPortaPiezas ;
    rdfs:range base:BloqueoHidraulico .

base:tieneContrapesos a owl:ObjectProperty ;
    rdfs:domain base:CarroPortaPiezas ;
    rdfs:range base:Contrapeso .

base:tieneGuia a owl:ObjectProperty ;
    rdfs:domain base:Columna ;
    rdfs:range base:Guia .

base:tienePatines a owl:ObjectProperty ;
    rdfs:domain base:Contrapeso ;
    rdfs:range base:Patin .

base:tieneBloqueoHidraulico a owl:ObjectProperty ;
    rdfs:domain base:Contrapeso ;
    rdfs:range base:BloqueoHidraulico .

base:seDesplazanPor a owl:ObjectProperty ;
    rdfs:domain base:Contrapeso ;
    rdfs:range base:Guia ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

base:estaUbicadoEn a owl:ObjectProperty ;
    rdfs:domain base:Guia ;
    rdfs:range base:Columna ;
    rdfs:comment "Incompleto: Requiere resolución externa" .