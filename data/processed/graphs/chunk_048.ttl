@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix base: <http://example.org/machine#> .
@prefix mecanica: <http://example.org/mechanics#> .
@prefix elec: <http://example.org/electronics#> .

base:PlatoDivisor a owl:Class ;
    rdfs:label "Plato Divisor"@es .

base:CarroPortaPiezas a owl:Class ;
    rdfs:label "Carro Porta-Piezas"@es .

base:DentadoHirth a owl:Class ;
    rdfs:label "Dentado Hirth"@es .

base:DiscoIconel a owl:Class ;
    rdfs:label "Disco Iconel"@es .

base:CilindroHidraulico a owl:Class ;
    rdfs:label "Cilindro Hidráulico"@es .

base:EngranajeSuperior a owl:Class ;
    rdfs:label "Engranaje Superior"@es .

base:EngranajeInferior a owl:Class ;
    rdfs:label "Engranaje Inferior"@es .

base:Servomotor a owl:Class ;
    rdfs:label "Servomotor"@es .

base:TorretaMicros a owl:Class ;
    rdfs:label "Torreta de Micros"@es .

base:Leva a owl:Class ;
    rdfs:label "Leva"@es .

base:BasePlana a owl:Class ;
    rdfs:label "Base Plana"@es .

base:BaseInclinada a owl:Class ;
    rdfs:label "Base Inclinada"@es .

mecanica:estaColocadoSobre a owl:ObjectProperty ;
    rdfs:label "está colocado sobre"@es .

mecanica:disponeDe a owl:ObjectProperty ;
    rdfs:label "dispone de"@es .

mecanica:permite a owl:ObjectProperty ;
    rdfs:label "permite"@es .

mecanica:interviene a owl:ObjectProperty ;
    rdfs:label "interviene"@es .

mecanica:amarraCon a owl:ObjectProperty ;
    rdfs:label "amarra con"@es .

mecanica:permiteQue a owl:ObjectProperty ;
    rdfs:label "permite que"@es .

mecanica:libera a owl:ObjectProperty ;
    rdfs:label "libera"@es .

mecanica:desbloquea a owl:ObjectProperty ;
    rdfs:label "desbloquea"@es .

mecanica:gira a owl:ObjectProperty ;
    rdfs:label "gira"@es .

mecanica:disponeDeTorretaMicros a owl:ObjectProperty ;
    rdfs:label "dispone de torreta de micros"@es .

mecanica:seActivanPor a owl:ObjectProperty ;
    rdfs:label "se activan por medio de"@es .

mecanica:disponeDeBase a owl:ObjectProperty ;
    rdfs:label "dispone de base"@es .

elec:daSeñal a owl:ObjectProperty ;
    rdfs:label "da señal"@es .

base:PlatoDivisor mecanica:estaColocadoSobre base:CarroPortaPiezas .
base:PlatoDivisor mecanica:disponeDe base:DentadoHirth .
base:DentadoHirth mecanica:permite base:PlatoDivisor .
base:PlatoDivisor mecanica:amarraCon base:DiscoIconel .
base:CilindroHidraulico mecanica:interviene base:PlatoDivisor .
base:CilindroHidraulico mecanica:permiteQue base:EngranajeSuperior .
base:EngranajeSuperior mecanica:libera base:EngranajeInferior .
base:EngranajeInferior mecanica:desbloquea base:DentadoHirth .
base:Servomotor mecanica:gira base:PlatoDivisor .
base:Servomotor mecanica:disponeDeTorretaMicros base:TorretaMicros .
base:TorretaMicros mecanica:seActivanPor base:Leva .
base:TorretaMicros elec:daSeñal "SQ46" .
base:TorretaMicros elec:daSeñal "SQ47" .
base:PlatoDivisor mecanica:disponeDeBase base:BasePlana .
base:PlatoDivisor mecanica:disponeDeBase base:BaseInclinada .