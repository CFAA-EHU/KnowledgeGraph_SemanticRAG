@prefix : <http://example.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix base: <http://example.org/base#> .
@prefix sistema: <http://example.org/sistema#> .

base:NavegadorDeCarpetas a owl:Class ;
    rdfs:label "NavegadorDeCarpetas" .

base:Programa a owl:Class ;
    rdfs:label "Programa" .

base:Carpeta a owl:Class ;
    rdfs:label "Carpeta" .

sistema:Acceder a owl:ObjectProperty ;
    rdfs:label "acceder" ;
    rdfs:domain base:NavegadorDeCarpetas ;
    rdfs:range base:Carpeta .

sistema:Seleccionar a owl:ObjectProperty ;
    rdfs:label "seleccionar" ;
    rdfs:domain base:NavegadorDeCarpetas ;
    rdfs:range base:Programa .

sistema:Pulsar a owl:ObjectProperty ;
    rdfs:label "pulsar" ;
    rdfs:domain base:NavegadorDeCarpetas ;
    rdfs:range base:Utilidad .

base:Utilidad a owl:Class ;
    rdfs:label "Utilidad" .

base:Eliminar a owl:ObjectProperty ;
    rdfs:label "eliminar" ;
    rdfs:domain base:NavegadorDeCarpetas ;
    rdfs:range base:Programa .