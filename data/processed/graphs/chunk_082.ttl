@prefix base: <http://example.org/base#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:Programa a owl:Class .
base:Instrucción a owl:Class .
base:CicloDeBrochado a owl:Class .
base:Parámetro a owl:Class .

base:tieneInstrucción a owl:ObjectProperty ;
    rdfs:domain base:Programa ;
    rdfs:range base:Instrucción .

base:almacenaParámetro a owl:ObjectProperty ;
    rdfs:domain base:Instrucción ;
    rdfs:range base:Parámetro .

base:cargarParámetro a owl:ObjectProperty ;
    rdfs:domain base:Instrucción ;
    rdfs:range base:CicloDeBrochado ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

base:tieneImagen a owl:ObjectProperty ;
    rdfs:domain base:CicloDeBrochado ;
    rdfs:range base:CicloDeBrochado .