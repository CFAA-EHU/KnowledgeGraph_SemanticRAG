@prefix base: <http://example.org/brochadora-electromecanica-de-exteriores#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:BrochadoraElectromecanicaDeExteriores a owl:Class ;
    rdfs:label "Brochadora Electromecánica de Exteriores" .

base:MantenimientoEInspeccion a owl:Class ;
    rdfs:label "Mantenimiento e Inspección" .

base:Capitulo7 a owl:Class ;
    rdfs:label "Capítulo 7" .

base:A218Rashem7x3000x500 a owl:Class ;
    rdfs:label "A218/Rashem 7x3000x500" .

base:BrochadoraElectromecanicaDeExteriores rdfs:subClassOf base:A218Rashem7x3000x500 .

base:MantenimientoEInspeccion rdfs:subClassOf base:Capitulo7 .