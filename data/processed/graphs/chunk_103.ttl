@prefix base: <http://example.org/base#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

base:FinalDeCarrera a owl:Class ;
    rdfs:label "Final de Carrera"@es .

base:DetectorProximidad a owl:Class ;
    rdfs:label "Detector de Proximidad"@es .

base:ComprobacionFuncionamiento a owl:Class ;
    rdfs:label "Comprobación de Funcionamiento"@es .

base:Reemplazo a owl:Class ;
    rdfs:label "Reemplazo"@es .

base:comprobarFuncionamientoDe a owl:ObjectProperty ;
    rdfs:domain base:ComprobacionFuncionamiento ;
    rdfs:range rdf:Resource .

base:requerirReemplazo a owl:ObjectProperty ;
    rdfs:domain base:ComprobacionFuncionamiento ;
    rdfs:range base:Reemplazo .