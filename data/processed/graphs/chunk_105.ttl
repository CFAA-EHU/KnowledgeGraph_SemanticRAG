@prefix base: <http://example.org/base#> .
@prefix mecanica: <http://example.org/mecanica#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:CentralDeEngraseAutomatico a owl:Class ;
    rdfs:label "Central de engrase automático"@es .

base:CartuchoDeGrasa a owl:Class ;
    rdfs:label "Cartucho de grasa"@es .

mecanica:tieneCartuchoDeGrasa a owl:ObjectProperty ;
    rdfs:domain base:CentralDeEngraseAutomatico ;
    rdfs:range base:CartuchoDeGrasa .

base:LUE400051 a owl:Class ;
    rdfs:label "LUE+400-05-1"@es ;
    rdfs:subClassOf base:CartuchoDeGrasa .