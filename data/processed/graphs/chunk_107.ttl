@prefix base: <http://example.org/base#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:DepositoDeRefrigeracion a owl:Class ;
    rdfs:label "DepositoDeRefrigeracion" .

base:AceiteDeCorte a owl:Class ;
    rdfs:label "AceiteDeCorte" .

base:CUTMAXS50291 a owl:Class ;
    rdfs:label "CUT-MAX S 5029-1" ;
    rdfs:subClassOf base:AceiteDeCorte .

base:DepositoDeRefrigeracion a owl:Class ;
    rdfs:label "DepositoDeRefrigeracion" .

base:llenar a owl:ObjectProperty ;
    rdfs:domain base:DepositoDeRefrigeracion ;
    rdfs:range base:CUTMAXS50291 ;
    rdfs:label "llenar" .