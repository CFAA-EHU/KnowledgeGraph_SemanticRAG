@prefix base: <http://example.org/base#> .
@prefix mecanica: <http://example.org/mecanica#> .
@prefix elec: <http://example.org/elec#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:BrochadoraElectromecanicaDeExteriores a owl:Class ;
    rdfs:label "Brochadora Electromecánica de Exteriores"@es .

mecanica:ElementoMecanico a owl:Class ;
    rdfs:label "Elemento Mecánico"@es .

mecanica:ElementoComercial a owl:Class ;
    rdfs:label "Elemento Comercial"@es .

mecanica:ParteDeDesgaste a owl:Class ;
    rdfs:label "Parte de Desgaste"@es .

mecanica:Columna a owl:Class ;
    rdfs:label "Columna"@es .

mecanica:CarroPortabrocas a owl:Class ;
    rdfs:label "Carro Portabrocas"@es .

mecanica:tieneElementoMecanico a owl:ObjectProperty ;
    rdfs:label "tiene elemento mecánico"@es ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range mecanica:ElementoMecanico .

mecanica:tieneElementoComercial a owl:ObjectProperty ;
    rdfs:label "tiene elemento comercial"@es ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range mecanica:ElementoComercial .

mecanica:tieneParteDeDesgaste a owl:ObjectProperty ;
    rdfs:label "tiene parte de desgaste"@es ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range mecanica:ParteDeDesgaste .

mecanica:tieneColumna a owl:ObjectProperty ;
    rdfs:label "tiene columna"@es ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range mecanica:Columna .

mecanica:tieneCarroPortabrocas a owl:ObjectProperty ;
    rdfs:label "tiene carro portabrocas"@es ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range mecanica:CarroPortabrocas .

mecanica:ElementoMecanico a owl:Class ;
    rdfs:label "Elemento Mecánico"@es .

mecanica:ElementoComercial a owl:Class ;
    rdfs:label "Elemento Comercial"@es .

mecanica:ParteDeDesgaste a owl:Class ;
    rdfs:label "Parte de Desgaste"@es .

mecanica:Columna a owl:Class ;
    rdfs:label "Columna"@es .

mecanica:CarroPortabrocas a owl:Class ;
    rdfs:label "Carro Portabrocas"@es .