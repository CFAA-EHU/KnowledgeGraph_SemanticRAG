@prefix base: <http://example.org/base#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:Cremallera a owl:Class ;
    rdfs:label "Cremallera" .

base:ReductorConPinon a owl:Class ;
    rdfs:label "Reductor con piñón" .

base:Servomotor a owl:Class ;
    rdfs:label "Servomotor" .

base:PinonDeFieltro a owl:Class ;
    rdfs:label "Piñón de fieltro" .

base:ReglaLinealAbsoluta a owl:Class ;
    rdfs:label "Regla lineal absoluta" .

base:SistemaDeGuiadoCarroPortaPiezaDerecha a owl:Class ;
    rdfs:label "Sistema de guiado carro porta-pieza derecha" .

base:SistemaDeGuiadoCarroPortaPiezaIzquierda a owl:Class ;
    rdfs:label "Sistema de guiado carro porta-pieza izquierda" .

base:FrenoCarroPortaPieza a owl:Class ;
    rdfs:label "Freno carro porta-pieza" .

base:SistemaGuiadoContrapesos a owl:Class ;
    rdfs:label "Sistema guiado contrapesos" .

base:Freno a owl:Class ;
    rdfs:label "Freno" .

base:Fuelles a owl:Class ;
    rdfs:label "Fuelles" .

base:PinonContrapeso a owl:Class ;
    rdfs:label "Piñón contrapeso" .

base:Cadena a owl:Class ;
    rdfs:label "Cadena" .

base:Rodamiento a owl:Class ;
    rdfs:label "Rodamiento" .

base:DetectorDeProximidad a owl:Class ;
    rdfs:label "Detector de proximidad" .

base:BrochadoraElectromecanicaDeExteriores a owl:Class ;
    rdfs:label "Brochadora electromecánica de exteriores" ;
    rdfs:isDefinedBy <http://example.org/base#> .

base:tieneCremallera a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range base:Cremallera .

base:tieneReductorConPinon a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range base:ReductorConPinon .

base:tieneServomotor a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range base:Servomotor .

base:tienePinonDeFieltro a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range base:PinonDeFieltro .

base:tieneReglaLinealAbsoluta a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range base:ReglaLinealAbsoluta .

base:tieneSistemaDeGuiadoCarroPortaPiezaDerecha a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range base:SistemaDeGuiadoCarroPortaPiezaDerecha .

base:tieneSistemaDeGuiadoCarroPortaPiezaIzquierda a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range base:SistemaDeGuiadoCarroPortaPiezaIzquierda .

base:tieneFrenoCarroPortaPieza a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range base:FrenoCarroPortaPieza .

base:tieneSistemaGuiadoContrapesos a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range base:SistemaGuiadoContrapesos .

base:tieneFreno a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range base:Freno .

base:tieneFuelles a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range base:Fuelles .

base:tienePinonContrapeso a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range base:PinonContrapeso .

base:tieneCadena a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range base:Cadena .

base:tieneRodamiento a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range base:Rodamiento .

base:tieneDetectorDeProximidad a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range base:DetectorDeProximidad .