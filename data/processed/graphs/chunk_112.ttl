@prefix base: <http://example.org/base#> .
@prefix mecanica: <http://example.org/mecanica#> .
@prefix elec: <http://example.org/elec#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:PlatoDivisor a owl:Class ;
    rdfs:label "Plato divisor"@es .

base:Servomotor a owl:Class ;
    rdfs:label "Servomotor"@es .

base:CilindroNeumatico a owl:Class ;
    rdfs:label "Cilindro neumático"@es .

base:Cepillo a owl:Class ;
    rdfs:label "Cepillo"@es .

base:BrochadoraElectromecanicaDeExteriores a owl:Class ;
    rdfs:label "Brochadora electromecánica de exteriores"@es .

base:SistemaLimpiezaBrocha a owl:Class ;
    rdfs:label "Sistema de limpieza brocha"@es .

base:Carenado a owl:Class ;
    rdfs:label "Carenado"@es .

mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range owl:Class .

mecanica:tieneElementoComercial a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range owl:Class .

mecanica:tieneElementoDesgaste a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range owl:Class .

mecanica:tieneSistemaLimpiezaBrocha a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range base:SistemaLimpiezaBrocha .

mecanica:tieneCarenado a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range base:Carenado .

mecanica:tienePlatoDivisor a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range base:PlatoDivisor .

mecanica:tieneServomotor a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range base:Servomotor .

mecanica:tieneCilindroNeumatico a owl:ObjectProperty ;
    rdfs:domain base:SistemaLimpiezaBrocha ;
    rdfs:range base:CilindroNeumatico .

mecanica:tieneCepillo a owl:ObjectProperty ;
    rdfs:domain base:SistemaLimpiezaBrocha ;
    rdfs:range base:Cepillo .

mecanica:tieneReferencia a owl:DatatypeProperty ;
    rdfs:domain owl:Class ;
    rdfs:range rdfs:Literal .

mecanica:tieneProveedor a owl:DatatypeProperty ;
    rdfs:domain owl:Class ;
    rdfs:range rdfs:Literal .

mecanica:tieneCantidad a owl:DatatypeProperty ;
    rdfs:domain owl:Class ;
    rdfs:range rdfs:Literal .