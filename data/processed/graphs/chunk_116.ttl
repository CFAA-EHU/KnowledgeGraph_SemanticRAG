@prefix : <http://example.org/hidraulico#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:DepositoHidraulico a owl:Class ;
    rdfs:label "DepositoHidraulico" .

:FluidoHidraulico a owl:Class ;
    rdfs:label "FluidoHidraulico" .

:DepositoHidraulicoCapacidad a owl:DatatypeProperty ;
    rdfs:domain :DepositoHidraulico ;
    rdfs:range xsd:decimal ;
    rdfs:label "capacidad" .

:DepositoHidraulicoFluido a owl:ObjectProperty ;
    rdfs:domain :DepositoHidraulico ;
    rdfs:range :FluidoHidraulico ;
    rdfs:label "fluido" .

:AceiteISO3498HM46 a :FluidoHidraulico ;
    rdfs:label "Aceite ISO 3498 - HM46" .