@prefix base: <http://example.org/base#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:CentralDeEngraseAutomatica a owl:Class ;
    rdfs:label "Central de engrase automática"@es .

base:CartuchoDeGrasa a owl:Class ;
    rdfs:label "Cartucho de grasa"@es .

base:CentralDeEngraseAutomatica base:utilizaCartuchoDeGrasa base:CartuchoDeGrasa .

base:utilizaCartuchoDeGrasa a owl:ObjectProperty ;
    rdfs:label "utiliza cartucho de grasa"@es ;
    rdfs:domain base:CentralDeEngraseAutomatica ;
    rdfs:range base:CartuchoDeGrasa .

base:LUE400051 a owl:NamedIndividual , base:CartuchoDeGrasa ;
    rdfs:label "LUE+400-05-1"@es .