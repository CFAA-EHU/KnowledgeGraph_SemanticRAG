@prefix base: <http://example.org/base#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix mecanica: <http://example.org/mecanica#> .
@prefix elec: <http://example.org/elec#> .

base:BrochadoraElectromecanicaDeExteriores a owl:Class ;
    rdfs:label "Brochadora Electromecánica de Exteriores"@es .

mecanica:tieneModelo a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range rdfs:Literal .

mecanica:tieneDimensiones a owl:DatatypeProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range rdfs:Literal .

elec:tieneSistemaElectrico a owl:ObjectProperty ;
    rdfs:domain base:BrochadoraElectromecanicaDeExteriores ;
    rdfs:range base:SistemaElectrico ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

base:SistemaElectrico a owl:Class ;
    rdfs:label "Sistema Electrico"@es .