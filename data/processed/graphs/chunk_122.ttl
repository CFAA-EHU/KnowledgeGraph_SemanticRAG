@prefix base: <http://example.org/base#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix admin: <https://admin-shell.io/dictionary/> .

base:LlaveDeBola a owl:Class ;
    rdfs:label "Llave de bola"@es .

base:TaponVSTI38EDCF a owl:Class ;
    rdfs:label "Tapon VSTI3/8EDCF"@es .

base:DepositoAluminio a owl:Class ;
    rdfs:label "Deposito Aluminio"@es .

base:PieParaDeposito a owl:Class ;
    rdfs:label "Pie para deposito"@es .

base:Tapa2854 a owl:Class ;
    rdfs:label "Tapa2854"@es .

base:IndicadorDeNivelConTermometro a owl:Class ;
    rdfs:label "Indicador de nivel con termometro"@es .

base:TaponDeAireacionYLlenado a owl:Class ;
    rdfs:label "Tapon de aireacion y llenado"@es .

admin:Sensor a owl:Class ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Sensor> ;
    rdfs:label "Sensor"@es .

base:AdaptadorNivelesRegulables a owl:Class ;
    rdfs:label "Adaptador niveles regulables"@es .

base:BombaDePistones a owl:Class ;
    rdfs:label "Bomba de pistones"@es .

base:BombaCaudalVariable a owl:Class ;
    rdfs:label "Bomba caudal variable"@es .

base:AdaptadorBocas a owl:Class ;
    rdfs:label "Adaptador bocas"@es .

base:Fuelle a owl:Class ;
    rdfs:label "Fuelle"@es .

base:Soporte a owl:Class ;
    rdfs:label "Soporte"@es .

base:Semiacoplamiento a owl:Class ;
    rdfs:label "Semiacoplamiento"@es .

base:CoronaSpidex a owl:Class ;
    rdfs:label "Corona Spidex"@es .

base:BancadaMotor a owl:Class ;
    rdfs:label "Bancada motor"@es .

base:TacoSoporte a owl:Class ;
    rdfs:label "Taco soporte"@es .

base:DinaflexCilindrico a owl:Class ;
    rdfs:label "Dinaflex cilindrico"@es .

base:Manguera a owl:Class ;
    rdfs:label "Manguera"@es .

base:Terminal a owl:Class ;
    rdfs:label "Terminal"@es .

base:Antirretorno a owl:Class ;
    rdfs:label "Antirretorno"@es .

base:Racor a owl:Class ;
    rdfs:label "Racor"@es .

base:Motor a owl:Class ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Motor> ;
    rdfs:label "Motor"@es .

base:tieneFabricante a owl:ObjectProperty ;
    rdfs:label "tiene fabricante"@es ;
    rdfs:domain base:Componente ;
    rdfs:range base:Fabricante .

base:tieneReferencia a owl:ObjectProperty ;
    rdfs:label "tiene referencia"@es ;
    rdfs:domain base:Componente ;
    rdfs:range xsd:string .

base:tieneCantidad a owl:DatatypeProperty ;
    rdfs:label "tiene cantidad"@es ;
    rdfs:domain base:Componente ;
    rdfs:range xsd:integer .

base:Componente a owl:Class ;
    rdfs:label "Componente"@es .

base:Fabricante a owl:Class ;
    rdfs:label "Fabricante"@es .