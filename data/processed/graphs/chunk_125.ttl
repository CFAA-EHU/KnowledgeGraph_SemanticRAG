@prefix base: <http://example.org/manual/elec#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:SeccionadorPrincipal a owl:Class ;
    rdfs:label "SeccionadorPrincipal" .

base:AlimentacionGeneral a owl:Class ;
    rdfs:label "AlimentacionGeneral" .

base:Alimentacion24VDC a owl:Class ;
    rdfs:label "Alimentacion24VDC" .

base:ClimatizadorArmario a owl:Class ;
    rdfs:label "ClimatizadorArmario" .

base:MotorCACurrent a owl:Class ;
    rdfs:label "MotorCACurrent" .

base:MonitorPanelPC a owl:Class ;
    rdfs:label "MonitorPanelPC" .

base:CNC8070 a owl:Class ;
    rdfs:label "CNC8070" .

base:FuenteAlimentacionReguladores a owl:Class ;
    rdfs:label "FuenteAlimentacionReguladores" .

base:ServomotorIZQUIERDAAXD2 a owl:Class ;
    rdfs:label "ServomotorIZQUIERDAAXD2" .

base:ServomotorDERECHAAXD2 a owl:Class ;
    rdfs:label "ServomotorDERECHAAXD2" .

base:ServomotorMESAAXD1 a owl:Class ;
    rdfs:label "ServomotorMESAAXD1" .

base:PuertasSeguridad a owl:Class ;
    rdfs:label "PuertasSeguridad" .

base:PILZSeguridad a owl:Class ;
    rdfs:label "PILZSeguridad" .

base:PILZSalidasSeguras a owl:Class ;
    rdfs:label "PILZSalidasSeguras" .

base:IOMaquinaVista a owl:Class ;
    rdfs:label "IOMaquinaVista" .

base:PowerModule a owl:Class ;
    rdfs:label "PowerModule" .

base:BorneEntradaDigital a owl:Class ;
    rdfs:label "BorneEntradaDigital" .

base:tienePagina a owl:ObjectProperty ;
    rdfs:label "tienePagina" ;
    rdfs:domain base:Manual ;
    rdfs:range base:Pagina .

base:Manual a owl:Class ;
    rdfs:label "Manual" .

base:Pagina a owl:Class ;
    rdfs:label "Pagina" .

base:tieneDescripcion a owl:DatatypeProperty ;
    rdfs:label "tieneDescripcion" ;
    rdfs:domain base:Pagina ;
    rdfs:range rdfs:Literal .