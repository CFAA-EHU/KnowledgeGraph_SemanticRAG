@prefix base: <http://example.org/base#> .
@prefix mecanica: <http://example.org/mecanica#> .
@prefix elec: <http://example.org/elec#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

base:MotorLimpiezaBastidor a owl:Class ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Motor> .

base:MotorEngrase a owl:Class ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Motor> .

base:LimitadorSobretension a owl:Class .

base:Varistor a owl:Class .

base:Contactor a owl:Class .

base:Contacto a owl:Class .

base:AcopladorPorRelé a owl:Class .

base:Climatizador a owl:Class .

base:Plc a owl:Class .

mecanica:tienePotencia a owl:DatatypeProperty ;
    rdfs:domain base:MotorLimpiezaBastidor ;
    rdfs:range xsd:decimal .

mecanica:tieneVoltaje a owl:DatatypeProperty ;
    rdfs:domain base:MotorLimpiezaBastidor ;
    rdfs:range xsd:decimal .

mecanica:tieneTipoContacto a owl:DatatypeProperty ;
    rdfs:domain base:MotorLimpiezaBastidor ;
    rdfs:range xsd:string .

mecanica:tieneVoltajeControl a owl:DatatypeProperty ;
    rdfs:domain base:MotorLimpiezaBastidor ;
    rdfs:range xsd:decimal .

mecanica:tieneTipoContacto a owl:DatatypeProperty ;
    rdfs:domain base:MotorEngrase ;
    rdfs:range xsd:string .

mecanica:tieneVoltajeControl a owl:DatatypeProperty ;
    rdfs:domain base:MotorEngrase ;
    rdfs:range xsd:decimal .

mecanica:tienePotencia a owl:DatatypeProperty ;
    rdfs:domain base:MotorEngrase ;
    rdfs:range xsd:decimal .

mecanica:tieneVoltaje a owl:DatatypeProperty ;
    rdfs:domain base:MotorEngrase ;
    rdfs:range xsd:decimal .

elec:tieneTipo a owl:DatatypeProperty ;
    rdfs:domain base:LimitadorSobretension ;
    rdfs:range xsd:string .

elec:tieneTipo a owl:DatatypeProperty ;
    rdfs:domain base:Varistor ;
    rdfs:range xsd:string .

elec:tieneTipo a owl:DatatypeProperty ;
    rdfs:domain base:Contacto ;
    rdfs:range xsd:string .

elec:tieneTipo a owl:DatatypeProperty ;
    rdfs:domain base:AcopladorPorRelé ;
    rdfs:range xsd:string .

elec:tieneTipo a owl:DatatypeProperty ;
    rdfs:domain base:Climatizador ;
    rdfs:range xsd:string .

elec:tieneTipo a owl:DatatypeProperty ;
    rdfs:domain base:Plc ;
    rdfs:range xsd:string .

mecanica:estaConectadoA a owl:ObjectProperty ;
    rdfs:domain base:MotorLimpiezaBastidor ;
    rdfs:range base:LimitadorSobretension ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

mecanica:estaConectadoA a owl:ObjectProperty ;
    rdfs:domain base:MotorLimpiezaBastidor ;
    rdfs:range base:Varistor ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

mecanica:estaConectadoA a owl:ObjectProperty ;
    rdfs:domain base:MotorEngrase ;
    rdfs:range base:LimitadorSobretension ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

mecanica:estaConectadoA a owl:ObjectProperty ;
    rdfs:domain base:MotorEngrase ;
    rdfs:range base:Varistor ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

elec:controla a owl:ObjectProperty ;
    rdfs:domain base:Contacto ;
    rdfs:range base:MotorLimpiezaBastidor ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

elec:controla a owl:ObjectProperty ;
    rdfs:domain base:Contacto ;
    rdfs:range base:MotorEngrase ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

elec:controla a owl:ObjectProperty ;
    rdfs:domain base:AcopladorPorRelé ;
    rdfs:range base:MotorLimpiezaBastidor ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

elec:controla a owl:ObjectProperty ;
    rdfs:domain base:AcopladorPorRelé ;
    rdfs:range base:MotorEngrase ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

elec:controla a owl:ObjectProperty ;
    rdfs:domain base:Plc ;
    rdfs:range base:MotorLimpiezaBastidor ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

elec:controla a owl:ObjectProperty ;
    rdfs:domain base:Plc ;
    rdfs:range base:MotorEngrase ;
    rdfs:comment "Incompleto: Requiere resolución externa" .