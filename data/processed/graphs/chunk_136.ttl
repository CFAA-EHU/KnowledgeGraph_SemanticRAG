@prefix base: <http://example.org/base#> .
@prefix elec: <http://example.org/elec#> .
@prefix mecanica: <http://example.org/mecanica#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

base:InterruptorAutomatico a owl:Class ;
    rdfs:label "Interruptor Automático"@es .

base:BloqueContactoAuxiliar a owl:Class ;
    rdfs:label "Bloque de Contacto Auxiliar"@es .

base:Guardamotor a owl:Class ;
    rdfs:label "Guardamotor"@es .

base:GuardamotorRefrigeranteBrocha a base:Guardamotor ;
    rdfs:label "Guardamotor Refrigerante Brocha"@es .

base:GuardamotorLimpiezaBastidor a base:Guardamotor ;
    rdfs:label "Guardamotor Limpieza Bastidor"@es .

base:GuardamotorExtractorViruta a base:Guardamotor ;
    rdfs:label "Guardamotor Extractor de Viruta"@es .

base:GuardamotorCintaEntrada a base:Guardamotor ;
    rdfs:label "Guardamotor Cinta de Entrada"@es .

elec:InterruptorAutomaticoBornesTornillo a base:InterruptorAutomatico ;
    rdfs:label "Interruptor Automático Bornes Tornillo"@es .

elec:BloqueContactoAuxiliarTransversal a base:BloqueContactoAuxiliar ;
    rdfs:label "Bloque de Contacto Auxiliar Transversal"@es .

mecanica:estaAsociadoA a owl:ObjectProperty ;
    rdfs:label "está asociado a"@es ;
    rdfs:domain base:InterruptorAutomatico ;
    rdfs:range base:Guardamotor .

mecanica:tieneAmperaje a owl:DatatypeProperty ;
    rdfs:label "tiene amperaje"@es ;
    rdfs:domain base:InterruptorAutomatico ;
    rdfs:range xsd:decimal .

mecanica:tieneBornesTornillo a owl:DatatypeProperty ;
    rdfs:label "tiene bornes de tornillo"@es ;
    rdfs:domain base:InterruptorAutomatico ;
    rdfs:range xsd:boolean .

mecanica:tieneNumeroNombres a owl:DatatypeProperty ;
    rdfs:label "tiene número de nombres"@es ;
    rdfs:domain base:BloqueContactoAuxiliar ;
    rdfs:range xsd:integer .

mecanica:tieneBornesTornilloBloque a owl:DatatypeProperty ;
    rdfs:label "tiene bornes de tornillo"@es ;
    rdfs:domain base:BloqueContactoAuxiliar ;
    rdfs:range xsd:boolean .