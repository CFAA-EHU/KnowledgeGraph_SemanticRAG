@prefix base: <http://example.org/base#> .
@prefix mecanica: <http://example.org/mecanica#> .
@prefix elec: <http://example.org/elec#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:EmergenciaPanelOperador a owl:Class ;
    rdfs:label "EmergenciaPanelOperador" .

base:PanelOperador a owl:Class ;
    rdfs:label "PanelOperador" .

base:Componente a owl:Class ;
    rdfs:label "Componente" .

base:BotonEmergencia a owl:Class ;
    rdfs:label "BotonEmergencia" ;
    rdfs:subClassOf base:Componente .

base:ContactModule a owl:Class ;
    rdfs:label "ContactModule" ;
    rdfs:subClassOf base:Componente .

base:Soporte a owl:Class ;
    rdfs:label "Soporte" ;
    rdfs:subClassOf base:Componente .

mecanica:estaConectadoA a owl:ObjectProperty ;
    rdfs:domain base:Componente ;
    rdfs:range base:Componente .

elec:tieneColor a owl:DatatypeProperty ;
    rdfs:domain base:Componente ;
    rdfs:range rdfs:Literal .

elec:tieneModelo a owl:DatatypeProperty ;
    rdfs:domain base:Componente ;
    rdfs:range rdfs:Literal .

elec:tieneFabricante a owl:DatatypeProperty ;
    rdfs:domain base:Componente ;
    rdfs:range rdfs:Literal .

elec:tieneCodigo a owl:DatatypeProperty ;
    rdfs:domain base:Componente ;
    rdfs:range rdfs:Literal .