@prefix base: <http://example.org/base#> .
@prefix mecanica: <http://example.org/mecanica#> .
@prefix elec: <http://example.org/elec#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:EmergenciaPanelOperador a owl:Class ;
    rdfs:label "Emergencia Panel Operador" .

base:EmergenciaArmario a owl:Class ;
    rdfs:label "Emergencia Armario" .

base:Soporte a owl:Class ;
    rdfs:label "Soporte" .

base:ContactModule1NC a owl:Class ;
    rdfs:label "Contact Module 1NC" .

base:PulsadorSetaParoEmergencia a owl:Class ;
    rdfs:label "Pulsador Seta Paro Emergencia" .

base:NotHaltUnterlegschild a owl:Class ;
    rdfs:label "Not-Halt-Unterlegschild" .

mecanica:estaConectadoA a owl:ObjectProperty ;
    rdfs:domain base:EmergenciaPanelOperador ;
    rdfs:range base:Soporte .

mecanica:estaConectadoA a owl:ObjectProperty ;
    rdfs:domain base:EmergenciaArmario ;
    rdfs:range base:Soporte .

elec:tieneContactModule1NC a owl:ObjectProperty ;
    rdfs:domain base:EmergenciaPanelOperador ;
    rdfs:range base:ContactModule1NC .

elec:tieneContactModule1NC a owl:ObjectProperty ;
    rdfs:domain base:EmergenciaArmario ;
    rdfs:range base:ContactModule1NC .

elec:tienePulsadorSetaParoEmergencia a owl:ObjectProperty ;
    rdfs:domain base:EmergenciaArmario ;
    rdfs:range base:PulsadorSetaParoEmergencia .

elec:tieneNotHaltUnterlegschild a owl:ObjectProperty ;
    rdfs:domain base:EmergenciaArmario ;
    rdfs:range base:NotHaltUnterlegschild .

base:Soporte a owl:Class ;
    rdfs:label "Soporte" .

base:ContactModule1NC a owl:Class ;
    rdfs:label "Contact Module 1NC" .

base:PulsadorSetaParoEmergencia a owl:Class ;
    rdfs:label "Pulsador Seta Paro Emergencia" .

base:NotHaltUnterlegschild a owl:Class ;
    rdfs:label "Not-Halt-Unterlegschild" .