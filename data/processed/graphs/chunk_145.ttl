@prefix base: <http://example.org/base#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix mecanica: <http://example.org/mecanica#> .
@prefix elec: <http://example.org/elec#> .
@prefix sensor: <https://admin-shell.io/dictionary/Sensor> .
@prefix motor: <https://admin-shell.io/dictionary/Motor> .

base:AcopladorDelBus a owl:Class ;
    rdfs:label "Acoplador del bus Inline"@es ;
    rdfs:comment "Acoplador de bus, EtherCAT®, Hembra RJ45"@es .

base:IndustrialWiFiRouter a owl:Class ;
    rdfs:label "Industrial WiFi Router"@es ;
    rdfs:comment "SiteManager 1149 With its integrated WiFi"@es .

base:LlaveDeBola a owl:Class ;
    rdfs:label "Llave de bola"@es .

base:TaponVSTI38EDCF a owl:Class ;
    rdfs:label "Tapon VSTI3/8EDCF"@es .

base:DepositoAluminio a owl:Class ;
    rdfs:label "Deposito Aluminio"@es ;
    rdfs:comment "C=123LTS:NG130"@es .

base:PieParaDeposito a owl:Class ;
    rdfs:label "Pie para deposito"@es ;
    rdfs:comment "NG30/44/70:BZUB0027=BZUB0151"@es .

base:Tapa2854 a owl:Class ;
    rdfs:label "Tapa2854"@es .

base:IndicadorDeNivelConTermometro a owl:Class ;
    rdfs:label "Indicador de nivel con termometro"@es ;
    rdfs:comment "LS-127-1T-M12"@es .

base:TaponDeAireacionYLlenado a owl:Class ;
    rdfs:label "Tapon de aireacion y llenado"@es ;
    rdfs:comment "TM-478-G100=CFA23SWCPE"@es .

base:SensorDeNivelTON a owl:Class ;
    rdfs:subClassOf sensor:Sensor ;
    rdfs:label "Sensor de nivel TON"@es ;
    rdfs:comment "Salida digital, DC PNP, contactos dorados"@es .

base:AdaptadorNivelesRegulables a owl:Class ;
    rdfs:label "Adaptador niveles regulables"@es .

base:BombaDePistones a owl:Class ;
    rdfs:label "Bomba de pistones"@es .

base:BombaCaudalVariable a owl:Class ;
    rdfs:label "Bomba caudal variable"@es ;
    rdfs:comment "PV7-1X/40-45"@es .

base:AdaptadorBocasPVQ10SS a owl:Class ;
    rdfs:label "Adaptador bocas PVQ10SS"@es ;
    rdfs:comment "1/2 G"@es .

base:FuelleMFB a owl:Class ;
    rdfs:label "Fuelle MFB"@es ;
    rdfs:comment "Ø27XØ47X134"@es .

base:SoporteRV250124105 a owl:Class ;
    rdfs:label "Soporte RV250/124/105"@es .

base:SemiacoplamientoSpidexAlu a owl:Class ;
    rdfs:label "Semiacoplamiento Spidex Alu"@es ;
    rdfs:comment "A24.A"@es .

base:CoronaSpidexZK24ShoreA a owl:Class ;
    rdfs:label "Corona Spidex ZK 24 Shore A"@es ;
    rdfs:comment "SP240406"@es .

base:BancadaMotor a owl:Class ;
    rdfs:label "Bancada motor"@es ;
    rdfs:comment "3 Y 4CV S/PLANO 4-3367"@es .

base:TacoSoporteM10 a owl:Class ;
    rdfs:label "Taco soporte M10"@es ;
    rdfs:comment "40X26; S/PLANO"@es .

base:DinaflexCilindrico a owl:Class ;
    rdfs:label "Dinaflex cilindrico"@es ;
    rdfs:comment "REF.104/40; MACHO"@es .

elec:AcopladorDelBus a owl:Class ;
    rdfs:subClassOf base:AcopladorDelBus .

elec:IndustrialWiFiRouter a owl:Class ;
    rdfs:subClassOf base:IndustrialWiFiRouter .

mecanica:LlaveDeBola a owl:Class ;
    rdfs:subClassOf base:LlaveDeBola .

mecanica:TaponVSTI38EDCF a owl:Class ;
    rdfs:subClassOf base:TaponVSTI38EDCF .

mecanica:DepositoAluminio a owl:Class ;
    rdfs:subClassOf base:DepositoAluminio .

mecanica:PieParaDeposito a owl:Class ;
    rdfs:subClassOf base:PieParaDeposito .

mecanica:Tapa2854 a owl:Class ;
    rdfs:subClassOf base:Tapa2854 .

mecanica:IndicadorDeNivelConTermometro a owl:Class ;
    rdfs:subClassOf base:IndicadorDeNivelConTermometro .

mecanica:TaponDeAireacionYLlenado a owl:Class ;
    rdfs:subClassOf base:TaponDeAireacionYLlenado .

mecanica:SensorDeNivelTON a owl:Class ;
    rdfs:subClassOf base:SensorDeNivelTON .

mecanica:AdaptadorNivelesRegulables a owl:Class ;
    rdfs:subClassOf base:AdaptadorNivelesRegulables .

mecanica:BombaDePistones a owl:Class ;
    rdfs:subClassOf base:BombaDePistones .

mecanica:BombaCaudalVariable a owl:Class ;
    rdfs:subClassOf base:BombaCaudalVariable .

mecanica:AdaptadorBocasPVQ10SS a owl:Class ;
    rdfs:subClassOf base:AdaptadorBocasPVQ10SS .

mecanica:FuelleMFB a owl:Class ;
    rdfs:subClassOf base:FuelleMFB .

mecanica:SoporteRV250124105 a owl:Class ;
    rdfs:subClassOf base:SoporteRV250124105 .

mecanica:SemiacoplamientoSpidexAlu a owl:Class ;
    rdfs:subClassOf base:SemiacoplamientoSpidexAlu .

mecanica:CoronaSpidexZK24ShoreA a owl:Class ;
    rdfs:subClassOf base:CoronaSpidexZK24ShoreA .

mecanica:BancadaMotor a owl:Class ;
    rdfs:subClassOf base:BancadaMotor .

mecanica:TacoSoporteM10 a owl:Class ;
    rdfs:subClassOf base:TacoSoporteM10 .

mecanica:DinaflexCilindrico a owl:Class ;
    rdfs:subClassOf base:DinaflexCilindrico .

mecanica:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain mecanica:Componente ;
    rdfs:range base:Fabricante .

mecanica:tieneDesignacion a owl:DatatypeProperty ;
    rdfs:domain mecanica:Componente ;
    rdfs:range rdfs:Literal .

elec:tieneFabricante a owl:ObjectProperty ;
    rdfs:domain elec:Componente ;
    rdfs:range base:Fabricante .

elec:tieneDesignacion a owl:DatatypeProperty ;
    rdfs:domain elec:Componente ;
    rdfs:range rdfs:Literal .