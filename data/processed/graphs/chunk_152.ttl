@prefix base: <http://example.org/base#> .
@prefix elec: <http://example.org/elec#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

base:ProteccionDiferencial a owl:Class ;
    rdfs:label "Protección Diferencial"@es .

base:InterruptorAutomatico a owl:Class ;
    rdfs:label "Interruptor Automático"@es .

base:InterruptorProteccionSelectiva a owl:Class ;
    rdfs:label "Interruptor de Protección Selectiva"@es .

base:BlocProteccionDiferencial a owl:Class ;
    rdfs:label "Bloque de Protección Diferencial"@es .

elec:tieneVoltaje a owl:DatatypeProperty ;
    rdfs:label "tiene voltaje"@es ;
    rdfs:domain base:InterruptorProteccionSelectiva ;
    rdfs:range xsd:string .

elec:tieneIntensidad a owl:DatatypeProperty ;
    rdfs:label "tiene intensidad"@es ;
    rdfs:domain base:InterruptorProteccionSelectiva ;
    rdfs:range xsd:string .

elec:tienePolo a owl:DatatypeProperty ;
    rdfs:label "tiene polo"@es ;
    rdfs:domain base:InterruptorProteccionSelectiva ;
    rdfs:range xsd:string .

elec:tieneTipo a owl:DatatypeProperty ;
    rdfs:label "tiene tipo"@es ;
    rdfs:domain base:InterruptorProteccionSelectiva ;
    rdfs:range xsd:string .

elec:tieneProteccion a owl:DatatypeProperty ;
    rdfs:label "tiene protección"@es ;
    rdfs:domain base:InterruptorAutomatico ;
    rdfs:range xsd:string .

elec:tieneClase a owl:DatatypeProperty ;
    rdfs:label "tiene clase"@es ;
    rdfs:domain base:InterruptorAutomatico ;
    rdfs:range xsd:string .

elec:tieneDisposicion a owl:DatatypeProperty ;
    rdfs:label "tiene disposición"@es ;
    rdfs:domain base:InterruptorAutomatico ;
    rdfs:range xsd:string .

elec:estaConectadoA a owl:ObjectProperty ;
    rdfs:label "está conectado a"@es ;
    rdfs:domain base:BlocProteccionDiferencial ;
    rdfs:range base:InterruptorProteccionSelectiva .

elec:protege a owl:ObjectProperty ;
    rdfs:label "protege"@es ;
    rdfs:domain base:InterruptorAutomatico ;
    rdfs:range base:Motor .