@prefix base: <http://example.org/base#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

base:SelectorOIBlanco a owl:Class ;
    rdfs:label "Selector, O-I, Blanco"@es ;
    rdfs:comment "Selector iluminable, 22 mm, redondo, metal, brillante, blanco, largo"@es .

base:PulsadorSetaParoEmergencia a owl:Class ;
    rdfs:label "Pulsador Seta Paro Emergencia"@es ;
    rdfs:comment "Pulsador de seta de PARADA DE EMERGENCIA, 22 mm, redondo, metal"@es .

base:PlacaFondoRedonda a owl:Class ;
    rdfs:label "Placa de Fondo Redonda"@es ;
    rdfs:comment "Placa de fondo redonda, para pulsador de seta de PARADA DE EMERGENCIA"@es .

base:ModuloDeContactos1NC a owl:Class ;
    rdfs:label "Módulo de Contactos 1NC"@es ;
    rdfs:comment "Módulo de contactos con 1 contacto, 1NC, bornes de resorte"@es .

base:PulsadorNegro a owl:Class ;
    rdfs:label "Pulsador Negro"@es ;
    rdfs:comment "Pulsador, 22 mm, redondo, metal, brillante, negro, botón"@es .

base:PulsadorIluminadoVerde a owl:Class ;
    rdfs:label "Pulsador Iluminado Verde"@es ;
    rdfs:comment "Pulsador iluminado, 22 mm, redondo, metal, brillante, verde"@es .

base:PulsadorIluminadoBlanco a owl:Class ;
    rdfs:label "Pulsador Iluminado Blanco"@es ;
    rdfs:comment "Pulsador iluminado, 22 mm, redondo, metal, brillante, blanco"@es .

base:ModuloDeContactos1NO a owl:Class ;
    rdfs:label "Módulo de Contactos 1NO"@es ;
    rdfs:comment "Módulo de contactos con 1 contacto, 1NO, bornes de resorte"@es .

base:ModuloDeLED a owl:Class ;
    rdfs:label "Módulo de LED"@es ;
    rdfs:comment "Módulo de LED con LED integrado"@es .

base:tieneColor a owl:DatatypeProperty ;
    rdfs:domain base:SelectorOIBlanco ;
    rdfs:range xsd:string .

base:tieneColor a owl:DatatypeProperty ;
    rdfs:domain base:PulsadorSetaParoEmergencia ;
    rdfs:range xsd:string .

base:tieneColor a owl:DatatypeProperty ;
    rdfs:domain base:PulsadorNegro ;
    rdfs:range xsd:string .

base:tieneColor a owl:DatatypeProperty ;
    rdfs:domain base:PulsadorIluminadoVerde ;
    rdfs:range xsd:string .

base:tieneColor a owl:DatatypeProperty ;
    rdfs:domain base:PulsadorIluminadoBlanco ;
    rdfs:range xsd:string .

base:tieneMaterial a owl:DatatypeProperty ;
    rdfs:domain base:SelectorOIBlanco ;
    rdfs:range xsd:string .

base:tieneMaterial a owl:DatatypeProperty ;
    rdfs:domain base:PulsadorSetaParoEmergencia ;
    rdfs:range xsd:string .

base:tieneMaterial a owl:DatatypeProperty ;
    rdfs:domain base:PulsadorNegro ;
    rdfs:range xsd:string .

base:tieneMaterial a owl:DatatypeProperty ;
    rdfs:domain base:PulsadorIluminadoVerde ;
    rdfs:range xsd:string .

base:tieneMaterial a owl:DatatypeProperty ;
    rdfs:domain base:PulsadorIluminadoBlanco ;
    rdfs:range xsd:string .

base:tieneTamanio a owl:DatatypeProperty ;
    rdfs:domain base:SelectorOIBlanco ;
    rdfs:range xsd:string .

base:tieneTamanio a owl:DatatypeProperty ;
    rdfs:domain base:PulsadorSetaParoEmergencia ;
    rdfs:range xsd:string .

base:tieneTamanio a owl:DatatypeProperty ;
    rdfs:domain base:PulsadorNegro ;
    rdfs:range xsd:string .

base:tieneTamanio a owl:DatatypeProperty ;
    rdfs:domain base:PulsadorIluminadoVerde ;
    rdfs:range xsd:string .

base:tieneTamanio a owl:DatatypeProperty ;
    rdfs:domain base:PulsadorIluminadoBlanco ;
    rdfs:range xsd:string .

base:tieneForma a owl:DatatypeProperty ;
    rdfs:domain base:SelectorOIBlanco ;
    rdfs:range xsd:string .

base:tieneForma a owl:DatatypeProperty ;
    rdfs:domain base:PulsadorSetaParoEmergencia ;
    rdfs:range xsd:string .

base:tieneForma a owl:DatatypeProperty ;
    rdfs:domain base:PulsadorNegro ;
    rdfs:range xsd:string .

base:tieneForma a owl:DatatypeProperty ;
    rdfs:domain base:PulsadorIluminadoVerde ;
    rdfs:range xsd:string .

base:tieneForma a owl:DatatypeProperty ;
    rdfs:domain base:PulsadorIluminadoBlanco ;
    rdfs:range xsd:string .

base:tieneTipoDeBornes a owl:DatatypeProperty ;
    rdfs:domain base:ModuloDeContactos1NC ;
    rdfs:range xsd:string .

base:tieneTipoDeBornes a owl:DatatypeProperty ;
    rdfs:domain base:ModuloDeContactos1NO ;
    rdfs:range xsd:string .

base:tieneTipoDeContacto a owl:DatatypeProperty ;
    rdfs:domain base:ModuloDeContactos1NC ;
    rdfs:range xsd:string .

base:tieneTipoDeContacto a owl:DatatypeProperty ;
    rdfs:domain base:ModuloDeContactos1NO ;
    rdfs:range xsd:string .

base:tieneTipoDeIluminacion a owl:DatatypeProperty ;
    rdfs:domain base:ModuloDeLED ;
    rdfs:range xsd:string .

base:estaAsociadoCon a owl:ObjectProperty ;
    rdfs:domain base:PulsadorSetaParoEmergencia ;
    rdfs:range base:PlacaFondoRedonda ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

base:estaAsociadoCon a owl:ObjectProperty ;
    rdfs:domain base:PlacaFondoRedonda ;
    rdfs:range base:PulsadorSetaParoEmergencia ;
    rdfs:comment "Incompleto: Requiere resolución externa" .