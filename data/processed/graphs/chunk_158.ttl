@prefix base: <http://example.org/base#> .
@prefix mecanica: <http://example.org/mecanica#> .
@prefix elec: <http://example.org/elec#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix admin: <https://admin-shell.io/dictionary/> .

base:TransformadorPrimario a owl:Class ;
    rdfs:label "Transformador Primario" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/TransformadorPrimario> .

base:PNOZmultiBaseUnit a owl:Class ;
    rdfs:label "PNOZmulti 2 base unit 24V DC" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/PNOZmultiBaseUnit> .

base:PNOZmultiInputModule a owl:Class ;
    rdfs:label "PNOZmulti 2 Input module 24V DC via base unit" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/PNOZmultiInputModule> .

base:ChipCard a owl:Class ;
    rdfs:label "ChipCard para PNOZ-mm01p" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/ChipCard> .

base:BornasDeResorte a owl:Class ;
    rdfs:label "Bornas de resorte PNOZ 4pines" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/BornasDeResorte> .

base:UnidadIluminada a owl:Class ;
    rdfs:label "Unidad iluminada" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/UnidadIluminada> .

base:LightColumnBase a owl:Class ;
    rdfs:label "Light column base + cover" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/LightColumnBase> .

base:BaseDeFijacion a owl:Class ;
    rdfs:label "BASE DE FIJACIÓN 80MM CON TUBO DE" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/BaseDeFijacion> .

base:CajaDeMando a owl:Class ;
    rdfs:label "Caja de mando con asas 600X600X210" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/CajaDeMando> .

base:ArticulacionMural a owl:Class ;
    rdfs:label "Articulacion mural CP120" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/ArticulacionMural> .

base:AnglePiece a owl:Class ;
    rdfs:label "Angle piece 90°, CP 120" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/AnglePiece> .

admin:Coupling a owl:Class ;
    rdfs:label "Coupling" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Coupling> .

base:SupportSection a owl:Class ;
    rdfs:label "Support section CP 120, solid, L: 1000 mm" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/SupportSection> .

base:DispositivoEntradaSalida a owl:Class ;
    rdfs:label "Dispositivo E/S descentralizado Axioline E, Equipo de entrada digital, EtherCAT®, Tecnología de conexión" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/DispositivoEntradaSalida> .

mecanica:estaConectadoA a owl:ObjectProperty ;
    rdfs:domain base:Componente ;
    rdfs:range base:Componente ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

elec:tieneVoltaje a owl:DatatypeProperty ;
    rdfs:domain base:Componente ;
    rdfs:range xsd:string ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

base:Componente a owl:Class ;
    rdfs:label "Componente" ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Componente> .