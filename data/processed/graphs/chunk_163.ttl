    rdfs:range base:TorretaDeMicros .

elec:tieneFuncion a owl:ObjectProperty ;
    rdfs:label "tieneFuncion" ;
    rdfs:domain base:AlumbradoInteriorDeMaquina ;
    rdfs:range rdfs:Literal .

mecanica:tieneDireccionalidad a owl:ObjectProperty ;
    rdfs:label "tieneDireccionalidad" ;
    rdfs:domain base:Columna ;
    rdfs:range rdfs:Literal .

mecanica:tieneRelacion a owl:ObjectProperty ;
