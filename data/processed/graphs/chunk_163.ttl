@prefix base: <http://example.org/base#> .
@prefix mecanica: <http://example.org/mecanica#> .
@prefix elec: <http://example.org/elec#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:AlumbradoInteriorDeMaquina a owl:Class ;
    rdfs:label "AlumbradoInteriorDeMaquina" .

base:LuminariaVertical a owl:Class ;
    rdfs:label "LuminariaVertical" .

base:LuminariaHorizontal a owl:Class ;
    rdfs:label "LuminariaHorizontal" .

base:PlatoDivisor a owl:Class ;
    rdfs:label "PlatoDivisor" .

base:Herramienta a owl:Class ;
    rdfs:label "Herramienta" .

base:ProteccionIP67 a owl:Class ;
    rdfs:label "ProteccionIP67" .

base:Zocalo a owl:Class ;
    rdfs:label "Zocalo" .

base:CubetaSuperior a owl:Class ;
    rdfs:label "CubetaSuperior" .

base:ApoyoAntivibratorio a owl:Class ;
    rdfs:label "ApoyoAntivibratorio" .

base:BaseEstructural a owl:Class ;
    rdfs:label "BaseEstructural" .

base:Refrigerante a owl:Class ;
    rdfs:label "Refrigerante" .

base:Viruta a owl:Class ;
    rdfs:label "Viruta" .

base:Columna a owl:Class ;
    rdfs:label "Columna" .

base:GuiaLineal a owl:Class ;
    rdfs:label "GuiaLineal" .

base:ReglaLineal a owl:Class ;
    rdfs:label "ReglaLineal" .

base:Cremallera a owl:Class ;
    rdfs:label "Cremallera" .

base:Pinon a owl:Class ;
    rdfs:label "Pinon" .

base:Servomotor a owl:Class ;
    rdfs:label "Servomotor" .

base:CarroPortaPiezas a owl:Class ;
    rdfs:label "CarroPortaPiezas" .

base:Patin a owl:Class ;
    rdfs:label "Patin" .

base:BloqueoHidraulico a owl:Class ;
    rdfs:label "BloqueoHidraulico" .

base:FrenoMayr a owl:Class ;
    rdfs:label "FrenoMayr" .

base:Contrapeso a owl:Class ;
    rdfs:label "Contrapeso" .

base:DentadoHirth a owl:Class ;
    rdfs:label "DentadoHirth" .

base:TorretaDeMicros a owl:Class ;
    rdfs:label "TorretaDeMicros" .

mecanica:estaConectadoA a owl:ObjectProperty ;
    rdfs:label "estaConectadoA" ;
    rdfs:domain base:LuminariaVertical ;
    rdfs:range base:PlatoDivisor .

mecanica:estaConectadoA a owl:ObjectProperty ;
    rdfs:label "estaConectadoA" ;
    rdfs:domain base:LuminariaHorizontal ;
    rdfs:range base:Herramienta .

mecanica:tieneProteccion a owl:ObjectProperty ;
    rdfs:label "tieneProteccion" ;
    rdfs:domain base:AlumbradoInteriorDeMaquina ;
    rdfs:range base:ProteccionIP67 .

mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:label "tieneComponente" ;
    rdfs:domain base:Zocalo ;
    rdfs:range base:CubetaSuperior .

mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:label "tieneComponente" ;
    rdfs:domain base:Zocalo ;
    rdfs:range base:ApoyoAntivibratorio .

mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:label "tieneComponente" ;
    rdfs:domain base:Zocalo ;
    rdfs:range base:BaseEstructural .

mecanica:contiene a owl:ObjectProperty ;
    rdfs:label "contiene" ;
    rdfs:domain base:BaseEstructural ;
    rdfs:range base:Refrigerante .

mecanica:contiene a owl:ObjectProperty ;
    rdfs:label "contiene" ;
    rdfs:domain base:BaseEstructural ;
    rdfs:range base:Viruta .

mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:label "tieneComponente" ;
    rdfs:domain base:Columna ;
    rdfs:range base:GuiaLineal .

mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:label "tieneComponente" ;
    rdfs:domain base:Columna ;
    rdfs:range base:ReglaLineal .

mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:label "tieneComponente" ;
    rdfs:domain base:Columna ;
    rdfs:range base:Cremallera .

mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:label "tieneComponente" ;
    rdfs:domain base:Columna ;
    rdfs:range base:Pinon .

mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:label "tieneComponente" ;
    rdfs:domain base:Columna ;
    rdfs:range base:Servomotor .

mecanica:tieneComponente a owl:ObjectProperty ;
