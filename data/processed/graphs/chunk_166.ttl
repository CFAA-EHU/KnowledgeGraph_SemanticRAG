@prefix base: <http://example.org/base#> .
@prefix mecanica: <http://example.org/mecanica#> .
@prefix elec: <http://example.org/elec#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix admin: <https://admin-shell.io/dictionary/> .

base:PlataformaLaterales a owl:Class ;
    rdfs:label "PlataformaLaterales" .

base:PortaCremalleras a owl:Class ;
    rdfs:label "PortaCremalleras" .

base:SeccionFrontal a owl:Class ;
    rdfs:label "SeccionFrontal" ;
    rdfs:subClassOf base:PlataformaLaterales .

base:Cancamo a owl:Class ;
    rdfs:label "Cancamo" .

base:Grúa a owl:Class ;
    rdfs:label "Grúa" .

mecanica:estaConectadoA a owl:ObjectProperty ;
    rdfs:domain base:PortaCremalleras ;
    rdfs:range base:Cancamo .

mecanica:requiere a owl:ObjectProperty ;
    rdfs:domain base:PortaCremalleras ;
    rdfs:range base:Grúa .

base:SistemaLimpiezaBrochas a owl:Class ;
    rdfs:label "SistemaLimpiezaBrochas" .

base:Carro a owl:Class ;
    rdfs:label "Carro" .

base:ModuloCilindroCepillos a owl:Class ;
    rdfs:label "ModuloCilindroCepillos" .

base:Estado a owl:Class ;
    rdfs:label "Estado" .

base:Avanzado a owl:Class ;
    rdfs:label "Avanzado" ;
    rdfs:subClassOf base:Estado .

base:Retrocedido a owl:Class ;
    rdfs:label "Retrocedido" ;
    rdfs:subClassOf base:Estado .

base:ArmarioNeumatico a owl:Class ;
    rdfs:label "ArmarioNeumatico" .

base:SistemaNeumatico a owl:Class ;
    rdfs:label "SistemaNeumatico" ;
    rdfs:subClassOf base:ArmarioNeumatico .

base:Entrada a owl:Class ;
    rdfs:label "Entrada" .

base:AvanceCepillo a owl:Class ;
    rdfs:label "AvanceCepillo" .

base:RetrocesoCepillo a owl:Class ;
    rdfs:label "RetrocesoCepillo" .

base:Refrigerante a owl:Class ;
    rdfs:label "Refrigerante" .

base:Presion a owl:Class ;
    rdfs:label "Presion" .

base:SistemaEngrase a owl:Class ;
    rdfs:label "SistemaEngrase" .

base:EngraseAutomatico a owl:Class ;
    rdfs:label "EngraseAutomatico" ;
    rdfs:subClassOf base:SistemaEngrase .

base:EngraseManual a owl:Class ;
    rdfs:label "EngraseManual" ;
    rdfs:subClassOf base:SistemaEngrase .

base:Deposito a owl:Class ;
    rdfs:label "Deposito" .

base:Linea a owl:Class ;
    rdfs:label "Linea" .

base:PinonEspuma a owl:Class ;
    rdfs:label "PinonEspuma" .

base:SistemaHidraulico a owl:Class ;
    rdfs:label "SistemaHidraulico" .

admin:Motor a owl:Class ;
    rdfs:label "Motor" ;
    rdfs:isDefinedBy admin:Motor .

base:Nivel a owl:Class ;
    rdfs:label "Nivel" .

base:Mesa a owl:Class ;
    rdfs:label "Mesa" .

base:Freno a owl:Class ;
    rdfs:label "Freno" .

base:PuntoMedida a owl:Class ;
    rdfs:label "PuntoMedida" ;
    rdfs:comment "Incompleto: Requiere resolución externa" .

mecanica:tieneCodificacion a owl:ObjectProperty ;
    rdfs:domain base:SeccionFrontal ;
    rdfs:range rdf:HTML .

mecanica:tieneDescripcion a owl:ObjectProperty ;
    rdfs:domain base:SeccionFrontal ;
    rdfs:range rdf:HTML .

mecanica:tieneEstado a owl:ObjectProperty ;
    rdfs:domain base:ModuloCilindroCepillos ;
    rdfs:range base:Estado .

mecanica:tieneEtiqueta a owl:ObjectProperty ;
    rdfs:domain base:ArmarioNeumatico ;
    rdfs:range rdf:HTML .

mecanica:tieneFuncion a owl:ObjectProperty ;
    rdfs:domain base:ArmarioNeumatico ;
    rdfs:range rdf:HTML .

mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:domain base:SistemaEngrase ;
    rdfs:range base:Deposito .

mecanica:tieneLinea a owl:ObjectProperty ;
    rdfs:domain base:SistemaEngrase ;
    rdfs:range base:Linea .

mecanica:tienePinon a owl:ObjectProperty ;
    rdfs:domain base:SistemaEngrase ;
    rdfs:range base:PinonEspuma .

mecanica:tieneMotor a owl:ObjectProperty ;
    rdfs:domain base:SistemaHidraulico ;
    rdfs:range admin:Motor .

mecanica:tieneNivel a owl:ObjectProperty ;
    rdfs:domain base:SistemaHidraulico ;
    rdfs:range base:Nivel .

mecanica:tieneMesa a owl:ObjectProperty ;
    rdfs:domain base:SistemaHidraulico ;
    rdfs:range base:Mesa .

mecanica:tieneFreno a owl:ObjectProperty ;
    rdfs:domain base:SistemaHidraulico ;
    rdfs:range base:Freno .

mecanica:tienePuntoMedida a owl:ObjectProperty ;
    rdfs:domain base:SistemaHidraulico ;
    rdfs:range base:PuntoMedida .