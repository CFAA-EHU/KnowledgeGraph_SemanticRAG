@prefix base: <http://example.org/base#> .
@prefix mecanica: <http://example.org/mecanica#> .
@prefix elec: <http://example.org/elec#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:VolteoMaquina a owl:Class ;
    rdfs:label "VolteoMáquina"@es .

base:Plano a owl:Class ;
    rdfs:label "Plano"@es .

base:Vista a owl:Class ;
    rdfs:label "Vista"@es .

base:Rejilla a owl:Class ;
    rdfs:label "Rejilla"@es .

base:CartelaTecnica a owl:Class ;
    rdfs:label "CartelaTécnica"@es .

base:InterruptorGeneral a owl:Class ;
    rdfs:label "InterruptorGeneral"@es .

base:Seccionador a owl:Class ;
    rdfs:label "Seccionador"@es .

base:LuzPiloto a owl:Class ;
    rdfs:label "LuzPiloto"@es .

base:MarcajeMando a owl:Class ;
    rdfs:label "MarcajeMando"@es .

base:PanelOperador a owl:Class ;
    rdfs:label "PanelOperador"@es .

base:Boton a owl:Class ;
    rdfs:label "Botón"@es .

base:Teclado a owl:Class ;
    rdfs:label "Teclado"@es .

base:ControlJog a owl:Class ;
    rdfs:label "ControlJog"@es .

mecanica:tieneSecuencia a owl:ObjectProperty ;
    rdfs:label "tieneSecuencia"@es ;
    rdfs:domain base:VolteoMaquina ;
    rdfs:range base:Vista .

mecanica:tieneVistas a owl:ObjectProperty ;
    rdfs:label "tieneVistas"@es ;
    rdfs:domain base:Plano ;
    rdfs:range base:Vista .

mecanica:tieneRejilla a owl:ObjectProperty ;
    rdfs:label "tieneRejilla"@es ;
    rdfs:domain base:Plano ;
    rdfs:range base:Rejilla .

mecanica:tieneCartelasTecnicas a owl:ObjectProperty ;
    rdfs:label "tieneCartelasTecnicas"@es ;
    rdfs:domain base:Plano ;
    rdfs:range base:CartelaTecnica .

elec:tieneInterruptorGeneral a owl:ObjectProperty ;
    rdfs:label "tieneInterruptorGeneral"@es ;
    rdfs:domain base:ArmarioElectrico ;
    rdfs:range base:InterruptorGeneral .

elec:tieneSeccionador a owl:ObjectProperty ;
    rdfs:label "tieneSeccionador"@es ;
    rdfs:domain base:ArmarioElectrico ;
    rdfs:range base:Seccionador .

elec:tieneLuzPiloto a owl:ObjectProperty ;
    rdfs:label "tieneLuzPiloto"@es ;
    rdfs:domain base:Seccionador ;
    rdfs:range base:LuzPiloto .

elec:tieneMarcajeMando a owl:ObjectProperty ;
    rdfs:label "tieneMarcajeMando"@es ;
    rdfs:domain base:Seccionador ;
    rdfs:range base:MarcajeMando .

elec:tienePanelOperador a owl:ObjectProperty ;
    rdfs:label "tienePanelOperador"@es ;
    rdfs:domain base:ArmarioElectrico ;
    rdfs:range base:PanelOperador .

elec:tieneBotones a owl:ObjectProperty ;
    rdfs:label "tieneBotones"@es ;
    rdfs:domain base:PanelOperador ;
    rdfs:range base:Botón .

elec:tieneTeclado a owl:ObjectProperty ;
    rdfs:label "tieneTeclado"@es ;
    rdfs:domain base:PanelOperador ;
    rdfs:range base:Teclado .

elec:tieneControlJog a owl:ObjectProperty ;
    rdfs:label "tieneControlJog"@es ;
    rdfs:domain base:PanelOperador ;
    rdfs:range base:ControlJog .

base:ArmarioElectrico a owl:Class ;
    rdfs:label "ArmarioEléctrico"@es .