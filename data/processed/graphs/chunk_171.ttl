@prefix base: <http://example.org/base#> .
@prefix mecanica: <http://example.org/mecanica#> .
@prefix elec: <http://example.org/elec#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:PlatoDivisor a owl:Class ;
    rdfs:label "Plato Divisor"@es .

base:Servomotor a owl:Class ;
    rdfs:label "Servomotor"@es .

base:SistemaLimpiezaBrocha a owl:Class ;
    rdfs:label "Sistema de Limpieza de Brocha"@es .

base:ModuloLongitudinal a owl:Class ;
    rdfs:label "Módulo Longitudinal"@es .

base:CilindroNeumatico a owl:Class ;
    rdfs:label "Cilindro Neumático"@es .

base:Cepillo a owl:Class ;
    rdfs:label "Cepillo"@es .

base:PeineCerdas a owl:Class ;
    rdfs:label "Peine de Cerdas"@es .

base:Carenado a owl:Class ;
    rdfs:label "Carenado"@es .

elec:Lampara a owl:Class ;
    rdfs:label "Lámpara"@es .

elec:InterruptorEUCHNER a owl:Class ;
    rdfs:label "Interruptor EUCHNER"@es .

base:CarroPortaPiezas a owl:Class ;
    rdfs:label "Carro Porta-piezas"@es .

base:GuiaLineal a owl:Class ;
    rdfs:label "Guía Lineal"@es .

base:Bastidor a owl:Class ;
    rdfs:label "Bastidor"@es .

base:Apoyo a owl:Class ;
    rdfs:label "Apoyo"@es .

base:Columna a owl:Class ;
    rdfs:label "Columna"@es .

base:Patin a owl:Class ;
    rdfs:label "Patín"@es .

base:CableadoSensor a owl:Class ;
    rdfs:label "Cableado de Sensores"@es .

mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:label "tiene componente"@es ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range base:Servomotor .

mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:label "tiene componente"@es ;
    rdfs:domain base:SistemaLimpiezaBrocha ;
    rdfs:range base:ModuloLongitudinal .

mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:label "tiene componente"@es ;
    rdfs:domain base:ModuloLongitudinal ;
    rdfs:range base:CilindroNeumatico .

mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:label "tiene componente"@es ;
    rdfs:domain base:ModuloLongitudinal ;
    rdfs:range base:Cepillo .

mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:label "tiene componente"@es ;
    rdfs:domain base:ModuloLongitudinal ;
    rdfs:range base:PeineCerdas .

mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:label "tiene componente"@es ;
    rdfs:domain base:Carenado ;
    rdfs:range elec:Lampara .

mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:label "tiene componente"@es ;
    rdfs:domain base:Carenado ;
    rdfs:range elec:InterruptorEUCHNER .

mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:label "tiene componente"@es ;
    rdfs:domain base:CarroPortaPiezas ;
    rdfs:range base:GuiaLineal .

mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:label "tiene componente"@es ;
    rdfs:domain base:CarroPortaPiezas ;
    rdfs:range base:Bastidor .

mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:label "tiene componente"@es ;
    rdfs:domain base:CarroPortaPiezas ;
    rdfs:range base:Apoyo .

mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:label "tiene componente"@es ;
    rdfs:domain base:CarroPortaPiezas ;
    rdfs:range base:Columna .

mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:label "tiene componente"@es ;
    rdfs:domain base:CarroPortaPiezas ;
    rdfs:range base:Patin .

mecanica:tieneComponente a owl:ObjectProperty ;
    rdfs:label "tiene componente"@es ;
    rdfs:domain base:CarroPortaPiezas ;
    rdfs:range base:CableadoSensor .