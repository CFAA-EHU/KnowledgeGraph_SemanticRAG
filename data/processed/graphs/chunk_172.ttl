@prefix base: <http://example.org/base#> .
@prefix mecanica: <http://example.org/mecanica#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:CarroPortaPiezas rdf:type owl:Class ;
    rdfs:label "Carro Porta-piezas" ;
    rdfs:isDefinedBy <http://example.org/base#CarroPortaPiezas> .

base:SubconjuntoII rdf:type owl:Class ;
    rdfs:label "Subconjunto II" ;
    rdfs:isDefinedBy <http://example.org/base#SubconjuntoII> .

base:Guia rdf:type owl:Class ;
    rdfs:label "Guía" ;
    rdfs:isDefinedBy <http://example.org/base#Guia> .

base:Patin rdf:type owl:Class ;
    rdfs:label "Patín" ;
    rdfs:isDefinedBy <http://example.org/base#Patin> .

base:CableadoSensor rdf:type owl:Class ;
    rdfs:label "Cableado de sensores" ;
    rdfs:isDefinedBy <http://example.org/base#CableadoSensor> .

base:Zocalo rdf:type owl:Class ;
    rdfs:label "Zócalo" ;
    rdfs:isDefinedBy <http://example.org/base#Zocalo> .

base:Soporte rdf:type owl:Class ;
    rdfs:label "Soporte" ;
    rdfs:isDefinedBy <http://example.org/base#Soporte> .

base:AlojamientoMecanizado rdf:type owl:Class ;
    rdfs:label "Alojamiento mecanizado" ;
    rdfs:isDefinedBy <http://example.org/base#AlojamientoMecanizado> .

base:ComponenteMorado rdf:type owl:Class ;
    rdfs:label "Componente morado" ;
    rdfs:isDefinedBy <http://example.org/base#ComponenteMorado> .

base:Roscas rdf:type owl:Class ;
    rdfs:label "Roscas" ;
    rdfs:isDefinedBy <http://example.org/base#Roscas> .

base:Asiento rdf:type owl:Class ;
    rdfs:label "Asiento" ;
    rdfs:isDefinedBy <http://example.org/base#Asiento> .

base:TaladradoReferencia rdf:type owl:Class ;
    rdfs:label "Taladrado de referencia" ;
    rdfs:isDefinedBy <http://example.org/base#TaladradoReferencia> .

base:PerfilGuia rdf:type owl:Class ;
    rdfs:label "Perfil guía" ;
    rdfs:isDefinedBy <http://example.org/base#PerfilGuia> .

base:Deslizadera rdf:type owl:Class ;
    rdfs:label "Deslizadera" ;
    rdfs:isDefinedBy <http://example.org/base#Deslizadera> .

base:PatronTaladros rdf:type owl:Class ;
    rdfs:label "Patrón de taladros" ;
    rdfs:isDefinedBy <http://example.org/base#PatronTaladros> .

base:NotaPrecision rdf:type owl:Class ;
    rdfs:label "Nota de precisión" ;
    rdfs:isDefinedBy <http://example.org/base#NotaPrecision> .

base:CotaCritica rdf:type owl:Class ;
    rdfs:label "Cota crítica" ;
    rdfs:isDefinedBy <http://example.org/base#CotaCritica> .

base:SeccionAnclaje rdf:type owl:Class ;
    rdfs:label "Sección de anclaje" ;
    rdfs:isDefinedBy <http://example.org/base#SeccionAnclaje> .

base:ToleranciaRectitud rdf:type owl:Class ;
    rdfs:label "Tolerancia de rectitud" ;
    rdfs:isDefinedBy <http://example.org/base#ToleranciaRectitud> .

base:ToleranciaPlanitud rdf:type owl:Class ;
    rdfs:label "Tolerancia de planitud" ;
    rdfs:isDefinedBy <http://example.org/base#ToleranciaPlanitud> .

base:CotaReferencia rdf:type owl:Class ;
    rdfs:label "Cota de referencia" ;
    rdfs:isDefinedBy <http://example.org/base#CotaReferencia> .

base:PinonContrapeso rdf:type owl:Class ;
    rdfs:label "Piñón contrapeso" ;
    rdfs:isDefinedBy <http://example.org/base#PinonContrapeso> .

base:SoportePinon rdf:type owl:Class ;
    rdfs:label "Soporte de piñón" ;
    rdfs:isDefinedBy <http://example.org/base#SoportePinon> .

base:CotaReferenciaSoportePinon rdf:type owl:Class ;
    rdfs:label "Cota de referencia del soporte de piñón" ;
    rdfs:isDefinedBy <http://example.org/base#CotaReferenciaSoportePinon> .

mecanica:tieneComponente rdf:type owl:ObjectProperty ;
    rdfs:domain base:CarroPortaPiezas ;
    rdfs:range base:ComponenteMorado ;
    rdfs:label "tiene componente" .

mecanica:tieneZocalo rdf:type owl:ObjectProperty ;
    rdfs:domain base:CarroPortaPiezas ;
    rdfs:range base:Zocalo ;
    rdfs:label "tiene zócalo" .

mecanica:tieneSoporte rdf:type owl:ObjectProperty ;
    rdfs:domain base:Zocalo ;
    rdfs:range base:Soporte ;
    rdfs:label "tiene soporte" .

mecanica:tieneAlojamientoMecanizado rdf:type owl:ObjectProperty ;
    rdfs:domain base:Zocalo ;
    rdfs:range base:AlojamientoMecanizado ;
    rdfs:label "tiene alojamiento mecanizado" .

mecanica:tieneRoscas rdf:type owl:ObjectProperty ;
    rdfs:domain base:Zocalo ;
    rdfs:range base:Roscas ;
    rdfs:label "tiene roscas" .

mecanica:tieneAsiento rdf:type owl:ObjectProperty ;
    rdfs:domain base:Zocalo ;
    rdfs:range base:Asiento ;
    rdfs:label "tiene asiento" .

mecanica:tieneTaladradoReferencia rdf:type owl:ObjectProperty ;
    rdfs:domain base:Zocalo ;
    rdfs:range base:TaladradoReferencia ;
    rdfs:label "tiene taladrado de referencia" .

mecanica:tienePerfilGuia rdf:type owl:ObjectProperty ;
    rdfs:domain base:CarroPortaPiezas ;
    rdfs:range base:PerfilGuia ;
    rdfs:label "tiene perfil guía" .

mecanica:tieneDeslizadera rdf:type owl:ObjectProperty ;
    rdfs:domain base:PerfilGuia ;
    rdfs:range base:Deslizadera ;
    rdfs:label "tiene deslizadera" .

mecanica:tienePatronTaladros rdf:type owl:ObjectProperty ;
    rdfs:domain base:PerfilGuia ;
    rdfs:range base:PatronTaladros ;
    rdfs:label "tiene patrón de taladros" .

mecanica:tieneNotaPrecision rdf:type owl:ObjectProperty ;
    rdfs:domain base:PerfilGuia ;
    rdfs:range base:NotaPrecision ;
    rdfs:label "tiene nota de precisión" .

mecanica:tieneCotaCritica rdf:type owl:ObjectProperty ;
    rdfs:domain base:PerfilGuia ;
    rdfs:range base:CotaCritica ;
    rdfs:label "tiene cota crítica" .

mecanica:tienePatin rdf:type owl:ObjectProperty ;
    rdfs:domain base:CarroPortaPiezas ;
    rdfs:range base:Patin ;
    rdfs:label "tiene patín" .

mecanica:tieneSeccionAnclaje rdf:type owl:ObjectProperty ;
    rdfs:domain base:Patin ;
    rdfs:range base:SeccionAnclaje ;
    rdfs:label "tiene sección de anclaje" .

mecanica:tieneToleranciaRectitud rdf:type owl:ObjectProperty ;
    rdfs:domain base:Patin ;
    rdfs:range base:ToleranciaRectitud ;
    rdfs:label "tiene tolerancia de rectitud" .

mecanica:tieneToleranciaPlanitud rdf:type owl:ObjectProperty ;
    rdfs:domain base:Patin ;
    rdfs:range base:ToleranciaPlanitud ;
    rdfs:label "tiene tolerancia de planitud" .

mecanica:tieneCotaReferencia rdf:type owl:ObjectProperty ;
    rdfs:domain base:Patin ;
    rdfs:range base:CotaReferencia ;
    rdfs:label "tiene cota de referencia" .

mecanica:tienePinonContrapeso rdf:type owl:ObjectProperty ;
    rdfs:domain base:CarroPortaPiezas ;
    rdfs:range base:PinonContrapeso ;
    rdfs:label "tiene piñón contrapeso" .

mecanica:tieneSoportePinon rdf:type owl:ObjectProperty ;
    rdfs:domain base:PinonContrapeso ;
    rdfs:range base:SoportePinon ;
    rdfs:label "tiene soporte de piñón" .

mecanica:tieneCotaReferenciaSoportePinon rdf:type owl:ObjectProperty ;
    rdfs:domain base:SoportePinon ;
    rdfs:range base:CotaReferenciaSoportePinon ;
    rdfs:label "tiene cota de referencia del soporte de piñón" .