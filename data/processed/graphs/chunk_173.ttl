@prefix base: <http://example.org/base#> .
@prefix mecanica: <http://example.org/mecanica#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:SoportePiñónDCH a owl:Class .
base:SoportePiñónIZQ a owl:Class .
base:PiñónMacizoDoble a owl:Class .
base:FuelleCarroPortaPiezas a owl:Class .

mecanica:tieneIsométrico a owl:ObjectProperty ;
    rdfs:domain base:SoportePiñónDCH ;
    rdfs:range base:Isométrico .
mecanica:tieneVistasOrtogonales a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
        owl:unionOf ( base:SoportePiñónDCH base:SoportePiñónIZQ ) ] ;
    rdfs:range base:VistasOrtogonales .
mecanica:tieneSección a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
        owl:unionOf ( base:SoportePiñónDCH base:SoportePiñónIZQ ) ] ;
    rdfs:range base:Sección .
mecanica:tieneEjeEstriado a owl:ObjectProperty ;
    rdfs:domain base:SoportePiñónDCH ;
    rdfs:range base:EjeEstriado .
mecanica:tieneChaveteros a owl:ObjectProperty ;
    rdfs:domain base:SoportePiñónDCH ;
    rdfs:range base:Chaveteros .
mecanica:tieneAlojamientoRodamientos a owl:ObjectProperty ;
    rdfs:domain base:SoportePiñónDCH ;
    rdfs:range base:AlojamientoRodamientos .
mecanica:tieneRadios a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
        owl:unionOf ( base:SoportePiñónDCH base:SoportePiñónIZQ ) ] ;
    rdfs:range base:Radios .
mecanica:tieneChaflanes a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
        owl:unionOf ( base:SoportePiñónDCH base:SoportePiñónIZQ ) ] ;
    rdfs:range base:Chaflanes .
mecanica:tieneReferenciasCadenaRodillos a owl:ObjectProperty ;
    rdfs:domain base:SoportePiñónDCH ;
    rdfs:range base:ReferenciasCadenaRodillos .
mecanica:tieneGlobosPiezasClave a owl:ObjectProperty ;
    rdfs:domain base:SoportePiñónDCH ;
    rdfs:range base:GlobosPiezasClave .
mecanica:tieneCotasAlojamiento a owl:ObjectProperty ;
    rdfs:domain base:SoportePiñónIZQ ;
    rdfs:range base:CotasAlojamiento .
mecanica:tieneRoscas a owl:ObjectProperty ;
    rdfs:domain base:SoportePiñónIZQ ;
    rdfs:range base:Roscas .
mecanica:tienePosiciónRacor a owl:ObjectProperty ;
    rdfs:domain base:SoportePiñónIZQ ;
    rdfs:range base:PosiciónRacor .
mecanica:tieneGeometríaDiferenciada a owl:ObjectProperty ;
    rdfs:domain base:SoportePiñónIZQ ;
    rdfs:range base:GeometríaDiferenciada .
mecanica:tieneDentadoCadena a owl:ObjectProperty ;
    rdfs:domain base:PiñónMacizoDoble ;
    rdfs:range base:DentadoCadena .
mecanica:tieneAjusteCubo a owl:ObjectProperty ;
    rdfs:domain base:PiñónMacizoDoble ;
    rdfs:range base:AjusteCubo .
mecanica:tieneTaladrosRoscados a owl:ObjectProperty ;
    rdfs:domain base:PiñónMacizoDoble ;
    rdfs:range base:TaladrosRoscados .
mecanica:tieneRadioTransición a owl:ObjectProperty ;
    rdfs:domain base:PiñónMacizoDoble ;
    rdfs:range base:RadioTransición .
mecanica:tieneDetalleFlancoDiente a owl:ObjectProperty ;
    rdfs:domain base:PiñónMacizoDoble ;
    rdfs:range base:DetalleFlancoDiente .
mecanica:tieneSeccionesPlegadas a owl:ObjectProperty ;
    rdfs:domain base:FuelleCarroPortaPiezas ;
    rdfs:range base:SeccionesPlegadas .
mecanica:tieneRadiosPliegue a owl:ObjectProperty ;
    rdfs:domain base:FuelleCarroPortaPiezas ;
    rdfs:range base:RadiosPliegue .
mecanica:tienePasos a owl:ObjectProperty ;
    rdfs:domain base:FuelleCarroPortaPiezas ;
    rdfs:range base:Pasos .
mecanica:tieneÁngulos a owl:ObjectProperty ;
    rdfs:domain base:FuelleCarroPortaPiezas ;
    rdfs:range base:Ángulos .
mecanica:tieneFunciónBarrera a owl:ObjectProperty ;
    rdfs:domain base:FuelleCarroPortaPiezas ;
    rdfs:range base:FunciónBarrera .

base:Isométrico a owl:Class .
base:VistasOrtogonales a owl:Class .
base:Sección a owl:Class .
base:EjeEstriado a owl:Class .
base:Chaveteros a owl:Class .
base:AlojamientoRodamientos a owl:Class .
base:Radios a owl:Class .
base:Chaflanes a owl:Class .
base:ReferenciasCadenaRodillos a owl:Class .
base:GlobosPiezasClave a owl:Class .
base:CotasAlojamiento a owl:Class .
base:Roscas a owl:Class .
base:PosiciónRacor a owl:Class .
base:GeometríaDiferenciada a owl:Class .
base:DentadoCadena a owl:Class .
base:AjusteCubo a owl:Class .
base:TaladrosRoscados a owl:Class .
base:RadioTransición a owl:Class .
base:DetalleFlancoDiente a owl:Class .
base:SeccionesPlegadas a owl:Class .
base:RadiosPliegue a owl:Class .
base:Pasos a owl:Class .
base:Ángulos a owl:Class .
base:FunciónBarrera a owl:Class .