@prefix base: <http://example.org/base#> .
@prefix mecanica: <http://example.org/mecanica#> .
@prefix elec: <http://example.org/elec#> .
@prefix fluidos: <http://example.org/fluidos#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

base:ConjuntoContrapeso a owl:Class .
base:PlatoDivisor a owl:Class .
base:ConjuntoCepillos a owl:Class .

mecanica:tieneGuia a owl:ObjectProperty ;
    rdfs:domain base:ConjuntoContrapeso ;
    rdfs:range base:Guia .

mecanica:tieneFijacion a owl:ObjectProperty ;
    rdfs:domain base:ConjuntoContrapeso ;
    rdfs:range base:Fijacion .

mecanica:tieneDeslizador a owl:ObjectProperty ;
    rdfs:domain base:ConjuntoContrapeso ;
    rdfs:range base:Deslizador .

mecanica:tieneCoronaDentada a owl:ObjectProperty ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range base:CoronaDentada .

mecanica:tieneAlojamientoCentral a owl:ObjectProperty ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range base:AlojamientoCentral .

mecanica:tienePatronCircular a owl:ObjectProperty ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range base:PatronCircular .

mecanica:tieneInclinacion a owl:ObjectProperty ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range xsd:decimal .

mecanica:tieneDentadoPerimetral a owl:ObjectProperty ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range base:DentadoPerimetral .

mecanica:tienePatronAgujeros a owl:ObjectProperty ;
    rdfs:domain base:PlatoDivisor ;
    rdfs:range base:PatronAgujeros .

mecanica:tieneCuerpo a owl:ObjectProperty ;
    rdfs:domain base:ConjuntoCepillos ;
    rdfs:range base:Cuerpo .

mecanica:tieneCilindroNeumatico a owl:ObjectProperty ;
    rdfs:domain base:ConjuntoCepillos ;
    rdfs:range base:CilindroNeumatico .

mecanica:tieneCartuchoCepillos a owl:ObjectProperty ;
    rdfs:domain base:ConjuntoCepillos ;
    rdfs:range base:CartuchoCepillos .

mecanica:tieneGuia a owl:ObjectProperty ;
    rdfs:domain base:ConjuntoCepillos ;
    rdfs:range base:Guia .

mecanica:tieneTornilleria a owl:ObjectProperty ;
    rdfs:domain base:ConjuntoCepillos ;
    rdfs:range base:Tornilleria .

mecanica:tienePasoAire a owl:ObjectProperty ;
    rdfs:domain base:ConjuntoCepillos ;
    rdfs:range base:PasoAire .

mecanica:tieneCota a owl:ObjectProperty ;
    rdfs:domain base:ConjuntoCepillos ;
    rdfs:range xsd:decimal .

fluidos:tieneDeposito a owl:ObjectProperty ;
    rdfs:domain fluidos:GrupoHidraulico ;
    rdfs:range base:Deposito .

fluidos:tieneSensorNivel a owl:ObjectProperty ;
    rdfs:domain fluidos:GrupoHidraulico ;
    rdfs:range <https://admin-shell.io/dictionary/Sensor> .

fluidos:tieneMotor a owl:ObjectProperty ;
    rdfs:domain fluidos:GrupoHidraulico ;
    rdfs:range <https://admin-shell.io/dictionary/Motor> .

fluidos:tieneBomba a owl:ObjectProperty ;
    rdfs:domain fluidos:GrupoHidraulico ;
    rdfs:range base:Bomba .

fluidos:tieneRetornoTanque a owl:ObjectProperty ;
    rdfs:domain fluidos:GrupoHidraulico ;
    rdfs:range base:RetornoTanque .

base:Guia a owl:Class .
base:Fijacion a owl:Class .
base:Deslizador a owl:Class .
base:CoronaDentada a owl:Class .
base:AlojamientoCentral a owl:Class .
base:PatronCircular a owl:Class .
base:DentadoPerimetral a owl:Class .
base:PatronAgujeros a owl:Class .
base:Cuerpo a owl:Class .
base:CilindroNeumatico a owl:Class .
base:CartuchoCepillos a owl:Class .
base:Tornilleria a owl:Class .
base:PasoAire a owl:Class .
base:Deposito a owl:Class .
base:Bomba a owl:Class .
base:RetornoTanque a owl:Class .

fluidos:GrupoHidraulico a owl:Class .