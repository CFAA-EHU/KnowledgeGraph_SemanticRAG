@prefix base: <http://example.org/base#> .
@prefix elec: <http://example.org/elec#> .
@prefix mecanica: <http://example.org/mecanica#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:AlimentacionGeneral a owl:Class ;
    rdfs:label "Alimentación General"@es .

base:EsquemaDeServicios a owl:Class ;
    rdfs:label "Esquema de Servicios"@es .

base:Transformador a owl:Class ;
    rdfs:label "Transformador"@es .

base:Luminaria a owl:Class ;
    rdfs:label "Luminaria"@es .

base:Magnetotermico a owl:Class ;
    rdfs:label "Magnetotérmico"@es .

base:Rel a owl:Class ;
    rdfs:label "Relé"@es .

base:Cableado a owl:Class ;
    rdfs:label "Cableado"@es .

base:Alimentacion24VDC a owl:Class ;
    rdfs:label "Alimentación 24VDC"@es .

base:SITOP a owl:Class ;
    rdfs:label "SITOP"@es .

base:Modulo a owl:Class ;
    rdfs:label "Módulo"@es .

base:PLC a owl:Class ;
    rdfs:label "PLC"@es .

base:Safety a owl:Class ;
    rdfs:label "Safety"@es .

base:Panel a owl:Class ;
    rdfs:label "Panel"@es .

base:CNC a owl:Class ;
    rdfs:label "CNC"@es .

base:IOExterno a owl:Class ;
    rdfs:label "I/O Externo"@es .

base:Borne a owl:Class ;
    rdfs:label "Borne"@es .

base:Piloto a owl:Class ;
    rdfs:label "Piloto"@es .

base:Linea a owl:Class ;
    rdfs:label "Línea"@es .

base:Climatizador a owl:Class ;
    rdfs:label "Climatizador"@es .

base:ModuloClimatizador a owl:Class ;
    rdfs:label "Módulo Climatizador"@es .

base:Control a owl:Class ;
    rdfs:label "Control"@es .

base:MotorCA a owl:Class ;
    rdfs:label "Motor de C.A"@es .

base:Contacto a owl:Class ;
    rdfs:label "Contacto"@es .

elec:tieneAlimentacion a owl:ObjectProperty ;
    rdfs:label "tiene alimentación"@es ;
    rdfs:domain base:AlimentacionGeneral ;
    rdfs:range base:EsquemaDeServicios .

elec:tieneTransformador a owl:ObjectProperty ;
    rdfs:label "tiene transformador"@es ;
    rdfs:domain base:EsquemaDeServicios ;
    rdfs:range base:Transformador .

elec:tieneLuminaria a owl:ObjectProperty ;
    rdfs:label "tiene luminaria"@es ;
    rdfs:domain base:EsquemaDeServicios ;
    rdfs:range base:Luminaria .

elec:tieneMagnetotermico a owl:ObjectProperty ;
    rdfs:label "tiene magnetotérmico"@es ;
    rdfs:domain base:EsquemaDeServicios ;
    rdfs:range base:Magnetotermico .

elec:tieneRel a owl:ObjectProperty ;
    rdfs:label "tiene relé"@es ;
    rdfs:domain base:EsquemaDeServicios ;
    rdfs:range base:Rel .

elec:tieneCableado a owl:ObjectProperty ;
    rdfs:label "tiene cableado"@es ;
    rdfs:domain base:EsquemaDeServicios ;
    rdfs:range base:Cableado .

elec:tieneSITOP a owl:ObjectProperty ;
    rdfs:label "tiene SITOP"@es ;
    rdfs:domain base:Alimentacion24VDC ;
    rdfs:range base:SITOP .

elec:tieneModulo a owl:ObjectProperty ;
    rdfs:label "tiene módulo"@es ;
    rdfs:domain base:Alimentacion24VDC ;
    rdfs:range base:Modulo .

elec:tienePLC a owl:ObjectProperty ;
    rdfs:label "tiene PLC"@es ;
    rdfs:domain base:Alimentacion24VDC ;
    rdfs:range base:PLC .

elec:tieneSafety a owl:ObjectProperty ;
    rdfs:label "tiene Safety"@es ;
    rdfs:domain base:Alimentacion24VDC ;
    rdfs:range base:Safety .

elec:tienePanel a owl:ObjectProperty ;
    rdfs:label "tiene panel"@es ;
    rdfs:domain base:Alimentacion24VDC ;
    rdfs:range base:Panel .

elec:tieneCNC a owl:ObjectProperty ;
    rdfs:label "tiene CNC"@es ;
    rdfs:domain base:Alimentacion24VDC ;
    rdfs:range base:CNC .

elec:tieneIOExterno a owl:ObjectProperty ;
    rdfs:label "tiene I/O Externo"@es ;
    rdfs:domain base:Alimentacion24VDC ;
    rdfs:range base:IOExterno .

elec:tieneBorne a owl:ObjectProperty ;
