elec:tienePiloto a owl:ObjectProperty ;
    rdfs:label "tiene piloto"@es ;
    rdfs:domain base:Alimentacion24VDC ;
    rdfs:range base:Piloto .

elec:tieneLinea a owl:ObjectProperty ;
    rdfs:label "tiene línea"@es ;
    rdfs:domain base:Alimentacion24VDC ;
    rdfs:range base:Linea .

elec:tieneClimatizador a owl:ObjectProperty ;
    rdfs:label "tiene climatizador"@es ;
    rdfs:domain base:Climatizador ;
    rdfs:range base:ModuloClimatizador .

elec:tieneControl a owl:ObjectProperty ;
    rdfs:label "tiene control"@es ;
    rdfs:domain base:Climatizador ;
    rdfs:range base:Control .

elec:tieneMotorCA a owl:ObjectProperty ;
    rdfs:label "tiene motor de C.A"@es ;
    rdfs:domain base:MotorCA ;
    rdfs:range base:MotorCA .

elec:tieneContacto a owl:ObjectProperty ;
