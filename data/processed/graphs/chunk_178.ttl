@prefix base: <http://example.org/base#> .
@prefix elec: <http://example.org/elec#> .
@prefix mecanica: <http://example.org/mecanica#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

### Clases ###
base:MonitorPanelPC a owl:Class ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/MonitorPanelPC> .

base:PanelPC a owl:Class ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/PanelPC> .

base:CNC8070 a owl:Class ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/CNC8070> .

base:Drive a owl:Class ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/Drive> .

base:ServomotorIZQUIERDAAXD2 a owl:Class ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/ServomotorIZQUIERDAAXD2> .

base:FuenteDeAlimentacionReguladores a owl:Class ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/FuenteDeAlimentacionReguladores> .

base:EjeTracionIZQ a owl:Class ;
    rdfs:isDefinedBy <https://admin-shell.io/dictionary/EjeTracionIZQ> .

### Propiedades de Objeto ###
elec:tieneBarras a owl:ObjectProperty ;
    rdfs:domain base:FuenteDeAlimentacionReguladores ;
    rdfs:range base:Barras .

elec:tieneConexiones a owl:ObjectProperty ;
    rdfs:domain base:MonitorPanelPC ;
    rdfs:range base:Conexiones .

elec:tieneAlimentacion a owl:ObjectProperty ;
    rdfs:domain base:MonitorPanelPC ;
    rdfs:range base:Alimentacion .

elec:tieneEnlaces a owl:ObjectProperty ;
    rdfs:domain base:MonitorPanelPC ;
    rdfs:range base:Enlaces .

elec:tieneBuses a owl:ObjectProperty ;
    rdfs:domain base:CNC8070 ;
    rdfs:range base:Buses .

elec:tieneRelé a owl:ObjectProperty ;
    rdfs:domain base:CNC8070 ;
    rdfs:range base:Relé .

elec:tienePuertos a owl:ObjectProperty ;
    rdfs:domain base:CNC8070 ;
    rdfs:range base:Puertos .

elec:tieneSeñales a owl:ObjectProperty ;
    rdfs:domain base:CNC8070 ;
    rdfs:range base:Señales .

elec:tieneEntradas a owl:ObjectProperty ;
    rdfs:domain base:FuenteDeAlimentacionReguladores ;
    rdfs:range base:Entradas .

elec:tieneSalidas a owl:ObjectProperty ;
    rdfs:domain base:FuenteDeAlimentacionReguladores ;
    rdfs:range base:Salidas .

elec:tieneBloquesDePotencia a owl:ObjectProperty ;
    rdfs:domain base:FuenteDeAlimentacionReguladores ;
    rdfs:range base:BloquesDePotencia .

elec:tieneBornes a owl:ObjectProperty ;
    rdfs:domain base:BloquesDePotencia ;
    rdfs:range base:Bornes .

elec:tieneRelésAsociados a owl:ObjectProperty ;
    rdfs:domain base:BloquesDePotencia ;
    rdfs:range base:RelésAsociados .

elec:tieneEntradasDrive a owl:ObjectProperty ;
    rdfs:domain base:ServomotorIZQUIERDAAXD2 ;
    rdfs:range base:EntradasDrive .

elec:tieneBusesServomotor a owl:ObjectProperty ;
    rdfs:domain base:ServomotorIZQUIERDAAXD2 ;
    rdfs:range base:BusesServomotor .

elec:tieneSeñalesServomotor a owl:ObjectProperty ;
    rdfs:domain base:ServomotorIZQUIERDAAXD2 ;
    rdfs:range base:SeñalesServomotor .

elec:tieneRelésServomotor a owl:ObjectProperty ;
    rdfs:domain base:ServomotorIZQUIERDAAXD2 ;
    rdfs:range base:RelésServomotor .

elec:tieneEnlacesServomotor a owl:ObjectProperty ;
    rdfs:domain base:ServomotorIZQUIERDAAXD2 ;
    rdfs:range base:EnlacesServomotor .

### Propiedades de Datos ###
elec:tieneLongitudes a owl:DatatypeProperty ;
    rdfs:domain elec:Cableados ;
    rdfs:range xsd:string .

elec:tieneAlimentacionMonitor a owl:DatatypeProperty ;
    rdfs:domain base:MonitorPanelPC ;
    rdfs:range xsd:string .

elec:tieneEnlacesUSB a owl:DatatypeProperty ;
    rdfs:domain base:MonitorPanelPC ;
    rdfs:range xsd:string .

elec:tieneEnlacesVGA a owl:DatatypeProperty ;
    rdfs:domain base:MonitorPanelPC ;
