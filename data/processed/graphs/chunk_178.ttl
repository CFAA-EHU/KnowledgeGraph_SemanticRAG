    rdfs:range xsd:string .

elec:tieneEntradasDriveServomotor a owl:DatatypeProperty ;
    rdfs:domain base:ServomotorIZQUIERDAAXD2 ;
    rdfs:range xsd:string .

elec:tieneSeñalesServomotor a owl:DatatypeProperty ;
    rdfs:domain base:ServomotorIZQUIERDAAXD2 ;
