@prefix base: <http://example.org/base#> .
@prefix mecanica: <http://example.org/mecanica#> .
@prefix elec: <http://example.org/elec#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:Conector a owl:Class ;
    rdfs:label "Conector" .

base:Actuador a owl:Class ;
    rdfs:label "Actuador" .

base:Bloque a owl:Class ;
    rdfs:label "Bloque" .

base:Bobina a owl:Class ;
    rdfs:label "Bobina" .

base:Relé a owl:Class ;
    rdfs:label "Relé" .

base:Sensor a owl:Class ;
    rdfs:label "Sensor" .

base:Entrada a owl:Class ;
    rdfs:label "Entrada" .

base:Salida a owl:Class ;
    rdfs:label "Salida" .

base:Módulo a owl:Class ;
    rdfs:label "Módulo" .

mecanica:estaEtiquetadoComo a owl:ObjectProperty ;
    rdfs:domain base:Conector ;
    rdfs:range rdf:Literal .

mecanica:representa a owl:ObjectProperty ;
    rdfs:domain base:Bloque ;
    rdfs:range base:Actuador .

mecanica:tieneTrazado a owl:ObjectProperty ;
    rdfs:domain base:Bobina ;
    rdfs:range rdf:Literal .

mecanica:tieneRetorno a owl:ObjectProperty ;
    rdfs:domain base:Bobina ;
    rdfs:range rdf:Literal .

mecanica:identifica a owl:ObjectProperty ;
    rdfs:domain base:Módulo ;
    rdfs:range base:Conector .

mecanica:muestraCorrespondenciaCon a owl:ObjectProperty ;
    rdfs:domain base:Módulo ;
    rdfs:range base:Actuador .

mecanica:tieneJerarquía a owl:ObjectProperty ;
    rdfs:domain base:Módulo ;
    rdfs:range rdf:Literal .

elec:tieneEntrada a owl:ObjectProperty ;
    rdfs:domain base:Módulo ;
    rdfs:range base:Entrada .

elec:tieneSalida a owl:ObjectProperty ;
    rdfs:domain base:Módulo ;
    rdfs:range base:Salida .

elec:tieneRelé a owl:ObjectProperty ;
    rdfs:domain base:Módulo ;
    rdfs:range base:Relé .

elec:enlazaComunicaciones a owl:ObjectProperty ;
    rdfs:domain base:Módulo ;
    rdfs:range rdf:Literal .

elec:tieneSensor a owl:ObjectProperty ;
    rdfs:domain base:Módulo ;
    rdfs:range base:Sensor .

elec:tieneAlimentación a owl:ObjectProperty ;
    rdfs:domain base:Módulo ;
    rdfs:range rdf:Literal .

elec:tienePin a owl:ObjectProperty ;
    rdfs:domain base:Conector ;
    rdfs:range rdf:Literal .

elec:tieneMasa a owl:ObjectProperty ;
    rdfs:domain base:Conector ;
    rdfs:range rdf:Literal .

elec:tieneFE a owl:ObjectProperty ;
    rdfs:domain base:Conector ;
    rdfs:range rdf:Literal .