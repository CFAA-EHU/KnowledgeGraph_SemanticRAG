@prefix base: <http://example.org/base#> .
@prefix mecanica: <http://example.org/mecanica#> .
@prefix elec: <http://example.org/elec#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

base:PlanoDeBornes a owl:Class ;
    rdfs:label "Plano de bornes" .

base:DiagramaMatricial a owl:Class ;
    rdfs:label "Diagrama matricial" .

base:Borne a owl:Class ;
    rdfs:label "Borne" .

base:Motor a owl:Class ;
    rdfs:label "Motor" .

base:Climatizador a owl:Class ;
    rdfs:label "Climatizador" .

base:Sistema a owl:Class ;
    rdfs:label "Sistema" .

base:Señal a owl:Class ;
    rdfs:label "Señal" .

base:Servomotor a owl:Class ;
    rdfs:label "Servomotor" .

base:Alimentacion a owl:Class ;
    rdfs:label "Alimentación" .

base:FuncionMaquina a owl:Class ;
    rdfs:label "Función de máquina" .

base:PaginaFuncional a owl:Class ;
    rdfs:label "Página funcional" .

base:GrupoFuncional a owl:Class ;
    rdfs:label "Grupo funcional" .

mecanica:tienePrecondicion a owl:ObjectProperty ;
    rdfs:domain base:PlanoDeBornes ;
    rdfs:range rdf:Literal .

mecanica:tieneEtapa a owl:ObjectProperty ;
    rdfs:domain base:PlanoDeBornes ;
    rdfs:range rdf:Literal .

mecanica:tieneFilas a owl:ObjectProperty ;
    rdfs:domain base:DiagramaMatricial ;
    rdfs:range rdf:Literal .

mecanica:tieneBornes a owl:ObjectProperty ;
    rdfs:domain base:DiagramaMatricial ;
    rdfs:range base:Borne .

mecanica:tieneFuncion a owl:ObjectProperty ;
    rdfs:domain base:Borne ;
    rdfs:range rdf:Literal .

mecanica:tieneReferenciaHoja a owl:ObjectProperty ;
    rdfs:domain base:Borne ;
    rdfs:range rdf:Literal .

mecanica:tieneAsignacion a owl:ObjectProperty ;
    rdfs:domain base:Borne ;
    rdfs:range rdf:Literal .

mecanica:tieneSistema a owl:ObjectProperty ;
    rdfs:domain base:Borne ;
    rdfs:range base:Sistema .

mecanica:tieneSeñal a owl:ObjectProperty ;
    rdfs:domain base:Borne ;
    rdfs:range base:Señal .

mecanica:tieneMotor a owl:ObjectProperty ;
    rdfs:domain base:Borne ;
    rdfs:range base:Motor .

mecanica:tieneClimatizador a owl:ObjectProperty ;
    rdfs:domain base:Borne ;
    rdfs:range base:Climatizador .

mecanica:tieneServomotor a owl:ObjectProperty ;
    rdfs:domain base:Borne ;
    rdfs:range base:Servomotor .

mecanica:tieneAlimentacion a owl:ObjectProperty ;
    rdfs:domain base:Borne ;
    rdfs:range base:Alimentacion .

mecanica:tieneFuncionMaquina a owl:ObjectProperty ;
    rdfs:domain base:Borne ;
    rdfs:range base:FuncionMaquina .

mecanica:tienePaginaFuncional a owl:ObjectProperty ;
    rdfs:domain base:Borne ;
    rdfs:range base:PaginaFuncional .

mecanica:tieneGrupoFuncional a owl:ObjectProperty ;
    rdfs:domain base:Borne ;
    rdfs:range base:GrupoFuncional .

mecanica:tieneNumeracion a owl:ObjectProperty ;
    rdfs:domain base:Borne ;
    rdfs:range rdf:Literal .