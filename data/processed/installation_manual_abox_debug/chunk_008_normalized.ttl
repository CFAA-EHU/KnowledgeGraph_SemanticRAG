@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:SistemaCNC a ex:Sistema ;
    rdfs:label "CNC 8070" ;
    ex:textoExtracto "Parámetros máquina", definida en el modo utilidades. Al iniciar el equipo en este modo de trabajo, éste solicita la contraseña de acceso." .  ex:ModoUtilidades a ex:ModoOperacion ;     rdfs:label \"Modo Utilidades" ;     ex:textoExtracto "Parámetros máquina", definida en el modo utilidades. Al iniciar el equipo en este modo de trabajo, éste solicita la contraseña de acceso." .

ex:ModoUsuario a ex:ModoOperacion ;
    rdfs:label \"Modo Usuario" ;
    ex:textoExtracto "Es el modo habitual de trabajo para el usuario, una vez terminada la puesta a punto. Este modo no permite actualizar el CNC ni acceder al sistema operativo." .

ex:ModoSetup a ex:ModoOperacion ;
    rdfs:label "Modo SETUP" ;
    ex:textoExtracto "En el encendido, el CNC mostrará un mensaje indicando que se encuentra en un modo no protegido y que la puesta a punto se encuentra sin finalizar." .

ex:SistemaCNC ex:tieneComponente ex:ModoUtilidades .
ex:SistemaCNC ex:tieneComponente ex:ModoUsuario .
ex:SistemaCNC ex:tieneComponente ex:ModoSetup .