@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:SistemaAlmacen ex:rdfs label "Sistema Almacén" ;
    ex:textoExtracto "A continuación se muestra una descripción detallada de las operaciones válidas para este almacén." .

ex:SignalTAKEPOS a ex:Parametro ;
    rdfs:label "Señal TAKEPOS" ;
    ex:textoExtracto "Las señales TAKEPOS, LEAVEPOS y NEXTPOS pueden tomar los siguientes valores." .

ex:SignalLEAVEPOS a ex:Parametro ;
    rdfs:label "Señal LEAVEPOS" ;
    ex:textoExtracto "Las señales TAKEPOS, LEAVEPOS y NEXTPOS pueden tomar los siguientes valores." .

ex:SignalNEXTPOS a ex:Parametro ;
    rdfs:label "Señal NEXTPOS" ;
    ex:textoExtracto "Las señales TAKEPOS, LEAVEPOS y NEXTPOS pueden tomar los siguientes valores." .

ex:SistemaAlmacen ex:tieneComponente ex:SignalTAKEPOS .
ex:SistemaAlmacen ex:tieneComponente ex:SignalLEAVEPOS .
ex:SistemaAlmacen ex:tieneComponente ex:SignalNEXTPOS .