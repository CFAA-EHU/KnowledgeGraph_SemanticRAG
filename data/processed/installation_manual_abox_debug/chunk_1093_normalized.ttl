@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Motor_A1 ex:ComponenteElectrico ;
    ex:textoExtracto "Motor" ;
    ex:identificador "A1" ;
    rdfs:label "Motor A1" .

ex:Motor_A2 ex:ComponenteElectrico ;
    ex:textoExtracto "motor" ;
    ex:identificador "A2" ;
    rdfs:label "Motor A2" .

ex:Eje_A1 ex:ComponenteMecanico ;
    ex:textoExtracto "Eje A1" ;
    ex:identificador "A1" ;
    rdfs:label "Eje A1" .

ex:Eje_A2 ex:ComponenteMecanico ;
    ex:textoExtracto "Eje A2" ;
    ex:identificador "A2" ;
    rdfs:label "Eje A2" .

ex:Sistema_Multieje ex:Sistema ;
    ex:textoExtracto "Sistema con dos ejes y sólo un motor. El sistema tiene las siguientes características. • Un único regulador controla dos ejes con el mismo motor. • Cada eje utiliza un tipo de captación diferente." ;
    ex:tieneComponente ex:Motor_A1, ex:Motor_A2, ex:Eje_A1, ex:Eje_A2 ;
    rdfs:label "Sistema multieje" .