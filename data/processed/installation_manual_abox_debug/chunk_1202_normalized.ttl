@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TOOLSUB_CHN a ex:Parametro ;
    rdfs:label "TOOLSUB CHN" ;
    ex:textoExtracto "Asignar la subrutina al comando. | Parámetro. |  | Significado. | TOOLSUB CHN |  | Subrutina asociada a la función T." ;
    ex:valor "Subrutina asociada a la función T." .

ex:ParametroGeneralCanal a ex:Parametro ;
    rdfs:label "[CHN] Parámetro máquina; general del canal" ;
    ex:textoExtracto "[CHN].......Parámetro máquina; general del canal. Nombre y ubicación de la subrutina. Esta subrutina debe estar definida en el parámetro general TOOLSUB y estará guardada en la carpeta ..\Mtb\Sub. Si hay varios canales, puede haber una subrutina diferente para cada canal." .

ex:CarpetaSubrutinas a ex:Esquema ;
    rdfs:label "..\Mtb\Sub" ;
    ex:textoExtracto "Esta subrutina debe estar definida en el parámetro general TOOLSUB y estará guardada en la carpeta ..\Mtb\Sub." .