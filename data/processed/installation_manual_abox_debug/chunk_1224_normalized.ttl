@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla1224_657 a ex:Tabla ;
    ex:textoExtracto "Las siguientes variables son accesibles desde; (PRG) el programa pieza y desde el modo MDI/MDA, PLC e (INT) una aplicación externa. La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W). | Variable. | PRG | PLC | INT |
| --- | --- | --- | --- |
| (V.)[ch].MPG.CUTTINGON
Subrutina asociada al comando #CUTTING ON. Unidades: Texto. | - | - | R |
| (V.)[ch].MPG.CUTTINGON
Subrutina asociada al comando #CUTTINGOFF. Unidades: Texto. | - | - | R |
 Sintaxis. ꞏchꞏ Número de canal. | [2].MPG.CUTTINGON | Canal ꞏ2ꞏ. |
| --- | ---" .

ex:Variable_MPG_CUTTINGON a ex:Parametro ;
    ex:textoExtracto "(V.)[ch].MPG.CUTTINGON
Subrutina asociada al comando #CUTTING ON. Unidades: Texto." ;
    ex:valor "Texto" ;
    ex:identificador "[ch].MPG.CUTTINGON" .

ex:Variable_MPG_CUTTINGOFF a ex:Parametro ;
    ex:textoExtracto "(V.)[ch].MPG.CUTTINGON
Subrutina asociada al comando #CUTTINGOFF. Unidades: Texto." ;
    ex:valor "Texto" ;
    ex:identificador "[ch].MPG.CUTTINGOFF" .

ex:Canal_2 a ex:Parametro ;
    ex:textoExtracto "Sintaxis. ꞏchꞏ Número de canal. | [2].MPG.CUTTINGON | Canal ꞏ2ꞏ. |" ;
    ex:identificador "[2]" .