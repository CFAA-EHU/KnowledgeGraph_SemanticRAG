@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Subrutina_pcall_txt a ex:Archivo ;
    rdfs:label "pcall.txt" ;
    ex:textoExtracto "la lista pcall.txt mostrará los nombres de subrutinas contenidos en ambos" .

ex:Version_V1_60_8060 a ex:Parametro ;
    rdfs:label "V1.60 (8060)" ;
    ex:textoExtracto "A partir de las versiones V1.60 (8060) y V5.60 (8065)" .

ex:Version_V5_60_8065 a ex:Parametro ;
    rdfs:label "V5.60 (8065)" ;
    ex:textoExtracto "A partir de las versiones V1.60 (8060) y V5.60 (8065)" .

ex:CNC a ex:Maquina ;
    ex:textoExtracto "el CNC ya no busca los archivos de ayuda" .

ex:Carpeta_Session_Help a ex:Componente ;
    rdfs:label "\\Users\\Session\\Help\\{idioma}" ;
    ex:textoExtracto ".. \\Users\\Session\\Help\\{idioma}" .

ex:Carpeta_Mtb_Sub_Help a ex:Componente ;
    rdfs:label "\\Mtb\\Sub\\Help\\{idioma}" ;
    ex:textoExtracto "..\\Mtb\\Sub\\Help\\{idioma}" .

ex:Carpeta_Users_Help a ex:Componente ;
    rdfs:label "\\Users\\Help\\{idioma}" ;
    ex:textoExtracto ".. \\Users\\Help\\{idioma}" .