@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Maquina608
  a ex:Maquina ;
  rdfs:label "Maquina" ;
  ex:identificador "608" ;
  ex:documentadoEn ex:Manual608 .

ex:Manual608
  a ex:Manual ;
  rdfs:label "Manual" ;
  ex:identificador "608" ;
  ex:documentadoEn ex:Tabla608 .

ex:Tabla608 a ex:Tabla ;
     a ex:Tabla ;
  rdfs:label "Tabla" ;
  ex:identificador "608" ;
  ex:detalladoEnEsquema ex:Esquema608 .

ex:Esquema608
  a ex:Esquema ;
  rdfs:label "Esquema" ;
  ex:identificador "608" ;
  ex:tieneComponente ex:ComponenteElectrico608 .

ex:ComponenteElectrico608
  a ex:ComponenteElectrico ;
  rdfs:label "Componente eléctrico" ;
  ex:identificador "608" ;
  ex:tieneComponente ex:Sensor608 .

ex:Sensor608
  a ex:Sensor ;
  rdfs:label "Sensor" ;
  ex:identificador "608" ;
  ex:monitoreaParametro ex:Parametro608 .

ex:Parametro608
  a ex:Parametro ;
  rdfs:label "Parámetro" ;
  ex:identificador "608" ;
  ex:valor "6" .