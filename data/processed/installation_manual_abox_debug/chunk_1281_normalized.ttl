@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:LantekExpertInside a ex:Software ;
    ex:textoExtracto """Fagor Automation y Lantek han colaborado en la integración del software Lantek Expert Inside para los modelos CNC 8060 y 8070.""" ;
    ex:identificador "Lantek Expert Inside" .

ex:CNC_8060 a ex:Maquina ;
    ex:identificador "CNC 8060" ;
    ex:textoExtracto """Fagor Automation y Lantek han colaborado en la integración del software Lantek Expert Inside para los modelos CNC 8060 y 8070.""" .

ex:CNC_8070 a ex:Maquina ;
    ex:identificador "CNC 8070" ;
    ex:textoExtracto """Fagor Automation y Lantek han colaborado en la integración del software Lantek Expert Inside para los modelos CNC 8060 y 8070.""" .

ex:PanelPC a ex:ComponenteElectrico ;
    ex:textoExtracto """El software puede ir instalado bien en el CNC o bien en un PanelPC.""" .

ex:InterfazLantekExpertInside a ex:InterfazUsuario ;
    rdfs:label "interfaz"@es ;
    ex:textoExtracto """La sencilla interfaz, adecuada para pantallas táctiles, facilita la revisión del corte en tiempo real y las modificaciones a pie de máquina.""" .

ex:PostprocesadorFagor a ex:ComponenteElectrico ;
    rdfs:label "postprocesador Fagor integrado"@es ;
    ex:textoExtracto """El postprocesador Fagor integrado creará el programa pieza para el CNC.""" .