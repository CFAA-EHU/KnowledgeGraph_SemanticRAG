@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Diagrama de compensación cruzada (pág. 77)
ex:Esquema_CompensacionCruzada_2_3_16
    a ex:Esquema ;
    rdfs:label "Esquema de compensación cruzada MOVAXIS-COMPAXIS"@es ;
    ex:textoExtracto "Diagrama conceptual de 'compensación cruzada' donde un eje maestro (MOVAXIS) provoca variaciones en un eje compensado (COMPAXIS). [...] La disposición incluye flechas de dirección del movimiento, áreas sombreadas para el componente afectado y rótulos tipográficos que explicitan la relación causa–efecto y la necesidad de definir puntos de compensación a lo largo del recorrido."@es ;
    ex:ilustradoEn ex:Pagina_77 ;
    ex:detalladoEnEsquema ex:Sensor_MOVAXIS, ex:Sensor_COMPAXIS .

ex:Sensor_MOVAXIS
    a ex:Sensor ;
    rdfs:label "Sensor de eje maestro (MOVAXIS)"@es ;
    ex:textoExtracto "eje maestro (MOVAXIS) [...] desplazándose; se señalan posiciones discretas 'POSITION n' y el error asociado 'POSERROR n'."@es ;
    ex:monitoreaParametro ex:Parametro_POSERROR .

ex:Sensor_COMPAXIS
    a ex:Sensor ;
    rdfs:label "Sensor de eje compensado (COMPAXIS)"@es ;
    ex:textoExtracto "eje compensado (COMPAXIS) [...] relación causa–efecto y la necesidad de definir puntos de compensación."@es .

ex:Parametro_POSERROR
    a ex:Parametro ;
    rdfs:label "Error de posición (POSERROR)"@es ;
    ex:textoExtracto "error asociado 'POSERROR n'."@es ;
    ex:valor "POSERROR n" .

---

### Palpador de sobremesa (torno) (pág. 92)
ex:Esquema_PalpadorSobremesa_Torno
    a ex:Esquema ;
    rdfs:label "Configuración de palpador de sobremesa para torno"@es ;
    ex:textoExtracto "Ilustración de un palpador de sobremesa para calibración de herramientas en torno: se observa el útil de torneado aproximándose al palpador fijo instalado en la bancada. [...] enfatizando la detección por contacto y la orientación del conjunto en un entorno de medición estático."@es ;
    ex:ilustradoEn ex:Pagina_92 ;
    ex:detalladoEnEsquema ex:Sensor_PalpadorSobremesa, ex:ComponenteMecanico_SoportePalpador .

ex:Sensor_PalpadorSobremesa
    a ex:Sensor ;
    rdfs:label "Palpador de sobremesa (torno)"@es ;
    ex:textoExtracto "palpador de sobremesa para calibración de herramientas en torno: [...] el punto de contacto, [...] resaltando la detección por contacto."@es .

ex:ComponenteMecanico_SoportePalpador
    a ex:ComponenteMecanico ;
    rdfs:label "Soporte de palpador para torno"@es ;
    ex:textoExtracto "el soporte del palpador [...] instalado en la bancada."@es .

---

### Palpador de medida (máquina) (pág. 92)
ex:Esquema_PalpadorMedida_Maquina
    a ex:Esquema ;
    rdfs:label "Configuración de palpador de medida para inspección en máquina"@es ;
    ex:textoExtracto "Ilustración de un palpador de medida montado en máquina para inspección de pieza: se representa un palpador tipo esférico acercándose a la superficie de una pieza cilíndrica, [...] resaltando la funcionalidad metrológica en ciclo (toma de puntos en la pieza), la dirección de aproximación y el rol del disparo del palpador como evento de medición."@es ;
    ex:ilustradoEn ex:Pagina_92 ;
    ex:detalladoEnEsquema ex:Sensor_PalpadorEsferico .

ex:Sensor_PalpadorEsferico
    a ex:Sensor ;
    rdfs:label "Palpador esférico de medida"@es ;
    ex:textoExtracto "palpador tipo esférico [...] punto de contacto marcado. [...] el disparo del palpador como evento de medición."@es .

---

### Sensor de gap (pág. 100)
ex:Esquema_SensorGap
    a ex:Esquema ;
    rdfs:label "Gráfico del sensor de gap"@es ;
    ex:textoExtracto "Gráfico del sensor de gap con ejes mV (horizontal) y mm/inch (vertical)."@es ;
    ex:ilustradoEn ex:Pagina_100 ;
    ex:detalladoEnEsquema ex:Sensor_Gap .

ex:Sensor_Gap
    a ex:Sensor ;
    rdfs:label "Sensor de gap"@es ;
    ex:textoExtracto "sensor de gap con ejes mV (horizontal) y mm/inch (vertical)."@es ;
    ex:monitoreaParametro ex:Parametro_DistanciaGap, ex:Parametro_VoltajeSalida .

ex:Parametro_DistanciaGap
    a ex:Parametro ;
    rdfs:label "Distancia de gap"@es ;
    ex:textoExtracto "mm/inch (vertical)."@es ;
    ex:valor "mm/inch" .

ex:Parametro_VoltajeSalida
    a ex:Parametro ;
    rdfs:label "Voltaje de salida del sensor"@es ;
    ex:textoExtracto "mV (horizontal)."@es ;
    ex:valor "mV" .

