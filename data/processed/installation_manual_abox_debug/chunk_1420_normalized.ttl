@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:KEYLED2 a ex:Sensor ;
    rdfs:label "KEYLED2" ;
    ex:textoExtracto "Se ilustra qué grupos de teclas disponen de iluminación controlable mediante KEYLED2/KEYLEDHBLS." .

ex:KEYLEDHBLS a ex:Sensor ;
    rdfs:label "KEYLEDHBLS" ;
    ex:textoExtracto "Se ilustra qué grupos de teclas disponen de iluminación controlable mediante KEYLED2/KEYLEDHBLS." .

ex:OP-PANEL-H/E a ex:InterfazUsuario ;
    rdfs:label "OP-PANEL-H/E" ;
    ex:textoExtracto "Esquema de asignación de bits a teclas del OP-PANEL-H/E (tabla gráfica sobre el teclado)." .

ex:OP-PANEL a ex:InterfazUsuario ;
    rdfs:label "OP-PANEL" ;
    ex:textoExtracto "Conjunto de tres fotografías (OP-PANEL, OP-PANEL-329 y QC-C65□-10K) usadas como referencia visual para 'Registros KEYDIS…'." .

ex:OP-PANEL-329 a ex:InterfazUsuario ;
    rdfs:label "OP-PANEL-329" ;
    ex:textoExtracto "Conjunto de tres fotografías (OP-PANEL, OP-PANEL-329 y QC-C65□-10K) usadas como referencia visual para 'Registros KEYDIS…'." .

ex:QC-C65□-10K a ex:InterfazUsuario ;
    rdfs:label "QC-C65□-10K" ;
    ex:textoExtracto "Conjunto de tres fotografías (OP-PANEL, OP-PANEL-329 y QC-C65□-10K) usadas como referencia visual para 'Registros KEYDIS…'." .

ex:KEYDIS2 a ex:Parametro ;
    rdfs:label "KEYDIS2" ;
    ex:textoExtracto "Rejilla ilustrativa de teclas de jog (1–15) y bloque de funciones (START, STOP, ZERO, RESET, husillo y override) para el mapeo KEYDIS2." .

ex:EsquemaTeclasJog a ex:Esquema ;
    rdfs:label "Esquema de teclas de jog" ;
    ex:textoExtracto "Rejilla ilustrativa de teclas de jog (1–15) y bloque de funciones (START, STOP, ZERO, RESET, husillo y override) para el mapeo KEYDIS2." .

ex:AlmacenTorretaTorno a ex:Sistema ;
    rdfs:label "Almacén tipo torreta para torno" ;
    ex:textoExtracto "Ilustración de un almacén tipo torreta para torno: se observa una torreta indexable con varios portaherramientas montados radialmente, cada uno con su plaquita o fresa, y la posición de trabajo orientada hacia el punto de mecanizado." .