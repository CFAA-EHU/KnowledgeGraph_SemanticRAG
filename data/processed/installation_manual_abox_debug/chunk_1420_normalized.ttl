@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Esquema_AsignacionBitsTeclasOP-PANEL-H/E
    a ex:Esquema ;
    rdfs:label "Esquema de asignación de bits a teclas del OP-PANEL-H/E" ;
    ex:textoExtracto "Esquema de asignación de bits a teclas del OP-PANEL-H/E (tabla gráfica sobre el teclado). Identifica para cada tecla el bit asociado (0–15 y 16–31) para control de leds y posibles inhibiciones, con énfasis en funciones de husillo, ejecución e interbloqueos." ;
    ex:ilustradoEn ex:InterfazUsuario_OP-PANEL-H/E .

ex:InterfazUsuario_OP-PANEL-H/E
    a ex:InterfazUsuario ;
    rdfs:label "OP-PANEL-H/E" ;
    ex:textoExtracto "Esquema de asignación de bits a teclas del OP-PANEL-H/E (tabla gráfica sobre el teclado)." ;
    ex:tieneComponente ex:Tecla_Start , ex:Tecla_Stop , ex:Tecla_Zero , ex:Tecla_Reset , ex:Tecla_Husillo , ex:Tecla_Override ;
    ex:tieneComponente ex:Tecla_Jog_1_a_15 .

ex:Tecla_Start
    a ex:ComponenteElectrico ;
    rdfs:label "Tecla START" ;
    ex:textoExtracto "bloque de funciones (START, STOP, ZERO, RESET, husillo y override) para el mapeo KEYDIS2." ;
    ex:detalladoEnEsquema ex:Esquema_AsignacionBitsTeclasOP-PANEL-H/E .

ex:Tecla_Stop
    a ex:ComponenteElectrico ;
    rdfs:label "Tecla STOP" ;
    ex:textoExtracto "bloque de funciones (START, STOP, ZERO, RESET, husillo y override) para el mapeo KEYDIS2." ;
    ex:detalladoEnEsquema ex:Esquema_AsignacionBitsTeclasOP-PANEL-H/E .

ex:Tecla_Zero
    a ex:ComponenteElectrico ;
    rdfs:label "Tecla ZERO" ;
    ex:textoExtracto "bloque de funciones (START, STOP, ZERO, RESET, husillo y override) para el mapeo KEYDIS2." ;
    ex:detalladoEnEsquema ex:Esquema_AsignacionBitsTeclasOP-PANEL-H/E .

ex:Tecla_Reset
    a ex:ComponenteElectrico ;
    rdfs:label "Tecla RESET" ;
    ex:textoExtracto "bloque de funciones (START, STOP, ZERO, RESET, husillo y override) para el mapeo KEYDIS2." ;
    ex:detalladoEnEsquema ex:Esquema_AsignacionBitsTeclasOP-PANEL-H/E .

ex:Tecla_Husillo
    a ex:ComponenteElectrico ;
    rdfs:label "Tecla husillo" ;
    ex:textoExtracto "bloque de funciones (START, STOP, ZERO, RESET, husillo y override) para el mapeo KEYDIS2." ;
    ex:detalladoEnEsquema ex:Esquema_AsignacionBitsTeclasOP-PANEL-H/E .

ex:Tecla_Override
    a ex:ComponenteElectrico ;
    rdfs:label "Tecla override" ;
    ex:textoExtracto "bloque de funciones (START, STOP, ZERO, RESET, husillo y override) para el mapeo KEYDIS2." ;
    ex:detalladoEnEsquema ex:Esquema_AsignacionBitsTeclasOP-PANEL-H/E .

ex:Tecla_Jog_1_a_15
    a ex:ComponenteElectrico ;
    rdfs:label "Teclas de jog (1–15)" ;
    ex:textoExtracto "Rejilla ilustrativa de teclas de jog (1–15) y bloque de funciones [...] para el mapeo KEYDIS2." ;
    ex:detalladoEnEsquema ex:Esquema_AsignacionBitsTeclasOP-PANEL-H/E .

ex:Sistema_IluminacionTeclas
    a ex:Sistema ;
    rdfs:label "Sistema KEYLED2/KEYLEDHBLS" ;
    ex:textoExtracto "Se ilustra qué grupos de teclas disponen de iluminación controlable mediante KEYLED2/KEYLEDHBLS." ;
    ex:controla ex:Tecla_Start , ex:Tecla_Stop , ex:Tecla_Zero , ex:Tecla_Reset , ex:Tecla_Husillo , ex:Tecla_Override , ex:Tecla_Jog_1_a_15 .

ex:Figura_AlmacenTorretaTorno
    a ex:Figura ;
    rdfs:label "Ilustración de almacén tipo torreta para torno" ;
    ex:textoExtracto "Ilustración de un almacén tipo torreta para torno: se observa una torreta indexable con varios portaherramientas montados radialmente, cada uno con su plaquita o fresa, y la posición de trabajo orientada hacia el punto de mecanizado. La vista enfatiza la disposición circular de estaciones y el giro de la torreta para presentar la herramienta activa." ;
    ex:ilustradoEn ex:Sistema_AlmacenHerramientasTorreta .

ex:Sistema_AlmacenHerramientasTorreta
    a ex:Sistema ;
    rdfs:label "Sistema de almacén de herramientas tipo torreta" ;
    ex:textoExtracto "torreta indexable con varios portaherramientas montados radialmente, cada uno con su plaquita o fresa, y la posición de trabajo orientada hacia el punto de mecanizado." ;
    ex:compuestoPor ex:PortaHerramientas_1 , ex:PortaHerramientas_2 , ex:PortaHerramientas_N ;
    ex:ilustradoEn ex:Figura_AlmacenTorretaTorno .

ex:PortaHerramientas_1
    a ex:ComponenteMecanico ;
    rdfs:label "Portaherramientas 1 (torreta)" ;
    ex:textoExtracto "portaherramientas montados radialmente, cada uno con su plaquita o fresa." .

ex:PortaHerramientas_2
    a ex:ComponenteMecanico ;
    rdfs:label "Portaherramientas 2 (torreta)" ;
    ex:textoExtracto "portaherramientas montados radialmente, cada uno con su plaquita o fresa." .

ex:PortaHerramientas_N
    a ex:ComponenteMecanico ;
    rdfs:label "Portaherramientas N (torreta)" ;
    ex:textoExtracto "portaherramientas montados radialmente, cada uno con su plaquita o fresa." .