@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Figura_AlmacenAsincronoCadena
    a ex:Figura ;
    rdfs:label "Ilustración de almacén asíncrono tipo cadena con brazo cambiador"@es ;
    ex:textoExtracto "Ilustración de almacén asíncrono tipo cadena con brazo cambiador desplazado del cabezal. Se observa la cinta portaherramientas serpenteante y el brazo operando en paralelo al mecanizado. El elemento visual comunica la independencia de movimientos y la posibilidad de activar la marca de continuación (TCHANGEOK) tras el intercambio en el husillo."@es ;
    ex:ilustradoEn ex:Pagina_541 .

ex:Figura_ComparativaTecladosCNC
    a ex:Figura ;
    rdfs:label "Galería comparativa de cuatro teclados CNC según distribución"@es ;
    ex:textoExtracto "Galería comparativa de cuatro teclados CNC según distribución: tres variantes rotuladas 'Español (España)' y una 'Inglés (Estados Unidos)'. Las vistas muestran la disposición física de teclas, presencia de teclas de función específicas del CNC y agrupación por bloques (alfanumérico, cursores, funciones), útil para asociar los 'scan codes' a su posición y entender las diferencias por idioma/distribución."@es ;
    ex:ilustradoEn ex:Pagina_541 ;
    ex:documentadoEn ex:Seccion_8_1 .

ex:InterfazUsuario_ConfiguracionTecladoWindows
    a ex:InterfazUsuario ;
    rdfs:label "Panel de control de Windows para configuración de teclado"@es ;
    ex:textoExtracto "Pareja de capturas del Panel de control de Windows (iconos 'Clock, Language, and Region' y enlace 'Change keyboard or other input methods'), usadas para ilustrar el acceso a la configuración de idioma y distribución de teclado del sistema operativo previo a la simulación desde PLC."@es ;
    ex:ilustradoEn ex:Pagina_542 ;
    ex:documentadoEn ex:Seccion_8_1 .

ex:InterfazUsuario_VentanaTecladosIdiomas
    a ex:InterfazUsuario ;
    rdfs:label "Ventana 'Teclados e idiomas' con botón 'Cambiar teclados…'"@es ;
    ex:textoExtracto "Captura de la ventana 'Teclados e idiomas' con el botón 'Cambiar teclados…'."@es ;
    ex:ilustradoEn ex:Pagina_542 ;
    ex:documentadoEn ex:Seccion_8_1 .

ex:Pagina_541
    a ex:Pagina ;
    ex:identificador "541" ;
    ex:documentadoEn ex:Seccion_8 .

ex:Pagina_542
    a ex:Pagina ;
    ex:identificador "542" ;
    ex:documentadoEn ex:Seccion_8 .

ex:Seccion_8
    a ex:Capitulo ;
    ex:identificador "8" ;
    rdfs:label "Simular un teclado desde el PLC. Códigos de teclas"@es .

ex:Seccion_8_1
    a ex:Capitulo ;
    ex:identificador "8.1" ;
    rdfs:label "Seleccionar el idioma y la distribución de teclado"@es ;
    ex:documentadoEn ex:Seccion_8 .