@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Maquina1557
  a ex:Maquina ;
  rdfs:label "Máquina" ;
  ex:detalladoEnEsquema ex:Esquema1557 ;
  ex:tieneComponente ex:EjeX1557, ex:EjeXp1557, ex:EjeZ1557 ;
  ex:tieneComponente ex:Bancada1557, ex:Carro1557, ex:Pieza1557 ;
  ex:tieneComponente ex:Cabezal1557, ex:Fresa1557 ;
  ex:tieneComponente ex:Almacen1557 .

ex:EjeX1557
  a ex:Eje ;
  rdfs:label "Eje X" ;
  ex:activaAlarma ex:AlarmaX1557 ;
  ex:tieneFrecuencia "60º" .

ex:EjeXp1557
  a ex:Eje ;
  rdfs:label "Eje X'" ;
  ex:activaAlarma ex:AlarmaXp1557 ;
  ex:tieneFrecuencia "60º" .

ex:EjeZ1557
  a ex:Eje ;
  rdfs:label "Eje Z" ;
  ex:activaAlarma ex:AlarmaZ1557 .

ex:Bancada1557
  a ex:ComponenteMecanico ;
  rdfs:label "Bancada" .

ex:Carro1557
  a ex:ComponenteMecanico ;
  rdfs:label "Carro" .

ex:Pieza1557
  a ex:PiezaRecambio ;
  rdfs:label "Pieza" .

ex:Cabezal1557
  a ex:ComponenteMecanico ;
  rdfs:label "Cabezal" ;
  ex:tieneComponente ex:Fresa1557 .

ex:Fresa1557
  a ex:Herramienta ;
  rdfs:label "Fresa" .

ex:Almacen1557
  a ex:Almacen ;
  rdfs:label "Almacén" ;
  ex:tieneComponente ex:CarruselGantry1557, ex:BrazoDoblePinza1557 .

ex:CarruselGantry1557
  a ex:ComponenteMecanico ;
  rdfs:label "Carrusel-gantry" .

ex:BrazoDoblePinza1557
  a ex:ComponenteMecanico ;
  rdfs:label "Brazo de doble pinza" .

ex:Esquema1557
  a ex:Esquema ;
  rdfs:label "Esquema" ;
  ex:ilustradoEn ex:IlustracionCinematica1557 .

ex:IlustracionCinematica1557
  a ex:Figura ;
  rdfs:label "Ilustración de cinemática de ejes paralelos" ;
  ex:documentadoEn ex:Maquina1557 .

ex:AlarmaX1557
  a ex:Alarma ;
  rdfs:label "Alarma X" .

ex:AlarmaXp1557
  a ex:Alarma ;
  rdfs:label "Alarma X'" .

ex:AlarmaZ1557
  a ex:Alarma ;
  rdfs:label "Alarma Z" .