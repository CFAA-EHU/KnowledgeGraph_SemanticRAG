@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:EsquemaTransferenciaBits a ex:Esquema ;
    rdfs:label "Esquema de transferencia de bits en =MOV con conversión Bin↔BCD" ;
    ex:textoExtracto "Esquema de transferencia de bits en =MOV con conversión Bin↔BCD: se representan bloques INPUT/OUTPUT con bits indexados (S1…S8/…S16) y su mapeo hacia salidas, indicando anchuras (4, 8, …, 32 bits) y códigos de origen/destino." .

ex:DiagramaRotacionRegistrosTipo1 a ex:Figura ;
    rdfs:label "Diagrama de rotación de registros tipo 1 (RL1/RR1)" ;
    ex:textoExtracto "Diagrama de rotación de registros tipo 1 (RL1/RR1): flechas muestran el desplazamiento de bits y la entrada/salida de '0' por el extremo opuesto, indicando la pérdida del bit expulsado." .

ex:DiagramaRotacionRegistrosTipo2 a ex:Figura ;
    rdfs:label "Diagrama de rotación de registros tipo 2 (RL2/RR2)" ;
    ex:textoExtracto "Diagrama de rotación de registros tipo 2 (RL2/RR2): rotación circular donde el bit desplazado reingresa por el extremo contrario, preservando el conjunto de 32 bits." .

ex:GraficoFvsPos a ex:Figura ;
    rdfs:label "Gráfico F vs Pos" ;
    ex:textoExtracto "Gráfico 'F vs Pos' que ejemplifica tres bloques consecutivos MOVE ABS con distintos parámetros de enlace (PRESENT, NEXT, NULL): el eje horizontal es la posición (marcas en 50 mm, 100 mm, 150 mm) y el vertical el avance F (niveles 125, 250, 500)."