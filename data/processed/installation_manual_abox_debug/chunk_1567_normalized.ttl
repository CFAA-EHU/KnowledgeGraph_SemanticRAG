@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:ComponenteHerramientaCabezal a ex:ComponenteHerramienta ;
    rdfs:label "cabezal" ;
    ex:textoExtracto "Ilustración de un almacén síncrono sin brazo cambiador: carrusel de herramientas dispuesto bajo una boquilla de husillo/cabezal;" .

ex:ComponenteHerramientaCarrusel a ex:ComponenteHerramienta ;
    rdfs:label "carrusel de herramientas" ;
    ex:textoExtracto "Ilustración de un almacén síncrono sin brazo cambiador: carrusel de herramientas dispuesto bajo una boquilla de husillo/cabezal;" .

ex:SistemaAlmacenHerramientasSincronoSinBrazo a ex:Sistema ;
    rdfs:label "almacén síncrono sin brazo cambiador" ;
    ex:textoExtracto "Ilustración de un almacén síncrono sin brazo cambiador: carrusel de herramientas dispuesto bajo una boquilla de husillo/cabezal;" ;
    ex:tieneComponente ex:ComponenteHerramientaCarrusel, ex:ComponenteHerramientaCabezal .

ex:SistemaAlmacenHerramientasSincronoConBrazo a ex:Sistema ;
    rdfs:label "almacén síncrono con brazo cambiador" ;
    ex:textoExtracto "Ilustración de un almacén síncrono con brazo cambiador (1–2 pinzas): se aprecia un disco portaherramientas cercano al cabezal y un brazo basculante con pinzas que transfieren la herramienta entre carrusel y husillo." ;
    ex:tieneComponente ex:ComponenteHerramientaCarrusel, ex:ComponenteHerramientaCabezal .

ex:SistemaAlmacenHerramientasAsincronoConBrazo a ex:Sistema ;
    rdfs:label "almacén asíncrono con brazo cambiador" ;
    ex:textoExtracto "Ilustración de un almacén asíncrono con brazo cambiador: cadena tipo 'crawler' o almacén lineal alejado del cabezal y un brazo de doble pinza desplazándose de forma independiente." .