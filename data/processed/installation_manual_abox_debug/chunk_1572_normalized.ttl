@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:AlmacenAsincrono a ex:Sistema ;
rdfs:label "Almacén asíncrono tipo cadena con brazo cambiador"@es ;
ex:detalladoEnEsquema ex:EsquemaAlmacenAsincrono .

ex:BrazoCambiador a ex:Actuador ;
rdfs:label "Brazo cambiador"@es ;
ex:tieneComponente ex:CintaPortaherramientas .

ex:CintaPortaherramientas a ex:ComponenteElectrico ;
rdfs:label "Cinta portaherramientas serpenteante"@es .

ex:Cabezal a ex:ComponenteMecanico ;
rdfs:label "Cabezal"@es .

ex:Husillo a ex:ComponenteMecanico ;
rdfs:label "Husillo"@es .

ex:MarcaContinuacion a ex:Alarma ;
rdfs:label "Marca de continuación (TCHANGEOK)"@es ;
ex:activadoPor ex:BrazoCambiador .

ex:EsquemaAlmacenAsincrono a ex:Esquema ;
rdfs:label "Ilustración de almacén asíncrono tipo cadena con brazo cambiador desplazado del cabezal"@es ;
ex:ilustradoEn ex:ImagenAlmacenAsincrono .

ex:ImagenAlmacenAsincrono a ex:Figura ;
rdfs:label "Ilustración de almacén asíncrono tipo cadena con brazo cambiador desplazado del cabezal"@es .