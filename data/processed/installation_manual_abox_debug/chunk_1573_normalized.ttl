@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Teclado rdfs:label "Teclado" ;
ex:identificador "Teclado" ;
ex:textoExtracto "Simular un teclado desde el PLC. Códigos de teclas. ( 8.1 Seleccionar el idioma y la distribución de teclado)" .

ex:Idioma rdfs:label "Idioma" ;
ex:identificador "Idioma" ;
ex:textoExtracto "Idioma de entrada" .

ex:DistribucionTeclado rdfs:label "Distribución del teclado" ;
ex:identificador "Distribución del teclado" ;
ex:textoExtracto "Distribución del teclado" .

ex:PLC rdfs:label "PLC" ;
ex:identificador "PLC" ;
ex:textoExtracto "Simular un teclado desde el PLC" .

ex:SistemaOperativo rdfs:label "Sistema operativo" ;
ex:identificador "Sistema operativo" ;
ex:textoExtracto "Barra de idioma de Windows" .

ex:ServicioInstalado rdfs:label "Servicio instalado" ;
ex:identificador "Servicio instalado" ;
ex:textoExtracto "Servicios instalados" .

ex:AsistenteAlta rdfs:label "Asistente de alta" ;
ex:identificador "Asistente de alta" ;
ex:textoExtracto "Agregar un idioma de entrada y su distribución de teclado" .

ex:Documentacion rdfs:label "Documentación" ;
ex:identificador "Documentación" ;
ex:textoExtracto "Captura de la web corporativa de Fagor Automation (página de descargas) donde localizar el manual \"Variables del CNC\"" .

ex:Teclado ex:controla ex:Idioma .
ex:Teclado ex:controla ex:DistribucionTeclado .
ex:PLC ex:alimenta ex:Teclado .
ex:SistemaOperativo ex:tieneComponente ex:Teclado .
ex:SistemaOperativo ex:tieneComponente ex:Idioma .
ex:SistemaOperativo ex:tieneComponente ex:DistribucionTeclado .
ex:ServicioInstalado ex:documentadoEn ex:Documentacion .
ex:AsistenteAlta ex:habilitadoPor ex:ServicioInstalado .