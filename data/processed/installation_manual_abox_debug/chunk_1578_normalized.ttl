@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Sistema1 a ex:Sistema ;
ex:tieneComponente ex:Eje1, ex:Eje2 ;
ex:tieneComponente ex:Motor1 ;
ex:tieneComponente ex:BloqueRegulador ;
ex:tieneComponente ex:BusCAN ;
ex:tieneComponente ex:Contador1, ex:Contador2 ;
ex:documentadoEn ex:Manual1 .

ex:Eje1 a ex:Eje ;
ex:tieneComponente ex:ModuloRemoto1 ;
ex:tieneComponente ex:CaptacionDirecta1 .

ex:Eje2 a ex:Eje ;
ex:tieneComponente ex:ModuloRemoto2 ;
ex:tieneComponente ex:CaptacionDirecta2 .

ex:Motor1 a ex:Motor ;
ex:alimenta ex:Eje1, ex:Eje2 .

ex:BloqueRegulador a ex:Bloque ;
ex:controla ex:Motor1 .

ex:BusCAN a ex:Bus ;
ex:conecta ex:BloqueRegulador .

ex:Contador1 a ex:Contador ;
ex:monitoreaParametro ex:Eje1 .

ex:Contador2 a ex:Contador ;
ex:monitoreaParametro ex:Eje2 .

ex:ModuloRemoto1 a ex:ModuloRemoto ;
ex:activadoPor ex:Eje1 .

ex:ModuloRemoto2 a ex:ModuloRemoto ;
ex:activadoPor ex:Eje2 .

ex:CaptacionDirecta1 a ex:Captacion ;
ex:realizadaPor ex:Eje1 .

ex:CaptacionDirecta2 a ex:Captacion ;
ex:realizadaPor ex:Eje2 .

ex:Manual1 a ex:Manual ;
ex:documenta ex:Sistema1 .