@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:DiagramaLazoControl
  a ex:Esquema ;
  rdfs:label "Diagrama de bloques del lazo de control del CNC"@es ;
  ex:detalladoEnEsquema "Se encadena SLOPE, INTERPOLATOR, TRANSFOR y FILTER, seguido de la entrada al lazo de posición. Incluye sumadores/compensadores (COMP, DELTA), consignas (POSCMD, FTEO), señales de retroalimentación (POSNC), y rutas para salidas analógicas y buses (Sercos Vel./Pos.). Las etiquetas de variables (p. ej., V.G.PATHFEED, V.A.LOOPTPOS.xn) explicitan puntos de observación en el flujo, y las ramas por eje (axis 1–3) muestran el tratamiento paralelo."@es ;
  ex:ilustradoEn "Páginas: 640 | Sección: 14. Subrutinas — 14.3 Subrutina asociada al reset | Título: — " .

ex:Slope
  a ex:ComponenteElectrico ;
  rdfs:label "SLOPE"@es ;
  ex:tieneComponente ex:DiagramaLazoControl .

ex:Interpolator
  a ex:ComponenteElectrico ;
  rdfs:label "INTERPOLATOR"@es ;
  ex:tieneComponente ex:DiagramaLazoControl .

ex:Transformer
  a ex:ComponenteElectrico ;
  rdfs:label "TRANSFOR"@es ;
  ex:tieneComponente ex:DiagramaLazoControl .

ex:Filter
  a ex:ComponenteElectrico ;
  rdfs:label "FILTER"@es ;
  ex:tieneComponente ex:DiagramaLazoControl .

ex:Compensador
  a ex:ComponenteElectrico ;
  rdfs:label "COMP, DELTA"@es ;
  ex:tieneComponente ex:DiagramaLazoControl .

ex:Consigna
  a ex:ComponenteElectrico ;
  rdfs:label "POSCMD, FTEO"@es ;
  ex:tieneComponente ex:DiagramaLazoControl .

ex:Se_alRetroalimentacion
  a ex:ComponenteElectrico ;
  rdfs:label "POSNC"@es ;
  ex:tieneComponente ex:DiagramaLazoControl .

ex:SalidaAnalogica
  a ex:ComponenteElectrico ;
  rdfs:label "Sercos Vel./Pos."@es ;
  ex:tieneComponente ex:DiagramaLazoControl .

ex:DiagramaProcesoReset
  a ex:Esquema ;
  rdfs:label "Diagrama temporal del proceso de reset"@es ;
  ex:detalladoEnEsquema "Dos trazas digitales (RESETIN y RESETOUT) y la ventana MINAENDW marcada sobre RESETOUT. La línea de tiempo (t) indica cuatro hitos numerados: activación de RESETIN, tiempo para asumir condiciones iniciales, activación de RESETOUT y final de reset, tras lo cual se ejecuta la subrutina PROGRAM_RESET. Flechas horizontales y niveles alto/bajo clarifican la secuencia y persistencia de señales."@es ;
  ex:ilustradoEn "Páginas: 665 | Sección: 15.1 Gestión de varios teclados | Título: — " .

ex:ResetIn
  a ex:ComponenteElectrico ;
  rdfs:label "RESETIN"@es ;
  ex:tieneComponente ex:DiagramaProcesoReset .

ex:ResetOut
  a ex:ComponenteElectrico ;
  rdfs:label "RESETOUT"@es ;
  ex:tieneComponente ex:DiagramaProcesoReset .

ex:ProgramReset
  a ex:Subrutina ;
  rdfs:label "PROGRAM_RESET"@es ;
  ex:ejecutadoPor ex:DiagramaProcesoReset .

ex:BusCan
  a ex:Sistema ;
  rdfs:label "Bus CAN"@es ;
  ex:detalladoEnEsquema "Numeración y orden de los paneles de mando y grupos de E/S remotas. Se muestran iconos del CNC (Address=0), módulos de E/S remotas (Address=1,3,4) y dos 'Jog-Panel' (Address=2 y 5), dispuestos en un esquema lineal del bus."@es ;
  ex:ilustradoEn "Páginas: 665 | Sección: 15.1 Gestión de varios teclados | Título: — " .

ex:Cnc
  a ex:Actuador ;
  rdfs:label "CNC"@es ;
  ex:tieneComponente ex:BusCan ;
  ex:address "0" .

ex:ModuloESRemota
  a ex:Actuador ;
  rdfs:label "Módulo de E/S remota"@es ;
  ex:tieneComponente ex:BusCan ;
  ex:address "1,3,4" .

ex:JogPanel
  a ex:Actuador ;
  rdfs:label "Jog-Panel"@es ;
  ex:tieneComponente ex:BusCan ;
  ex:address "2,5" .