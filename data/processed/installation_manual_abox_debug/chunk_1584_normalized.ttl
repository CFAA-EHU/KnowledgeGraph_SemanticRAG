@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Sistema1 a ex:Sistema ;
ex:identificador "Sercos" ;
ex:textoExtracto "Esquema de interconexión del sistema Sercos con dos contadoras RCS-S (nodos 3 y 5) y tres reguladores AXD (nodos 1, 2 y 4)." .

ex:Nodo3 a ex:Nodo ;
ex:identificador "3" ;
ex:parteDe ex:Sistema1 ;
ex:tieneComponente ex:ContadoraRCS_S1 .

ex:ContadoraRCS_S1 a ex:ContadoraRCS_S ;
ex:identificador "RCS-S" ;
ex:parteDe ex:Nodo3 .

ex:Nodo5 a ex:Nodo ;
ex:identificador "5" ;
ex:parteDe ex:Sistema1 ;
ex:tieneComponente ex:ContadoraRCS_S2 .

ex:ContadoraRCS_S2 a ex:ContadoraRCS_S ;
ex:identificador "RCS-S" ;
ex:parteDe ex:Nodo5 .

ex:Nodo1 a ex:Nodo ;
ex:identificador "1" ;
ex:parteDe ex:Sistema1 ;
ex:tieneComponente ex:ReguladorAXD1 .

ex:ReguladorAXD1 a ex:ReguladorAXD ;
ex:identificador "AXD" ;
ex:parteDe ex:Nodo1 .

ex:Nodo2 a ex:Nodo ;
ex:identificador "2" ;
ex:parteDe ex:Sistema1 ;
ex:tieneComponente ex:ReguladorAXD2 .

ex:ReguladorAXD2 a ex:ReguladorAXD ;
ex:identificador "AXD" ;
ex:parteDe ex:Nodo2 .

ex:Nodo4 a ex:Nodo ;
ex:identificador "4" ;
ex:parteDe ex:Sistema1 ;
ex:tieneComponente ex:ReguladorAXD3 .

ex:ReguladorAXD3 a ex:ReguladorAXD ;
ex:identificador "AXD" ;
ex:parteDe ex:Nodo4 .

ex:EjeAnalogicoX a ex:EjeAnalogico ;
ex:identificador "X" ;
ex:parteDe ex:Sistema1 .

ex:EjeAnalogicoY a ex:EjeAnalogico ;
ex:identificador "Y" ;
ex:parteDe ex:Sistema1 .

ex:EjeAnalogicoZ a ex:EjeAnalogico ;
ex:identificador "Z" ;
ex:parteDe ex:Sistema1 .

ex:EjeSercosU a ex:EjeSercos ;
ex:identificador "U" ;
ex:parteDe ex:Sistema1 .

ex:EjeSercosV a ex:EjeSercos ;
ex:identificador "V" ;
ex:parteDe ex:Sistema1 .

ex:Volante a ex:Volante ;
ex:parteDe ex:Sistema1 .

ex:CabezalS a ex:Cabezal ;
ex:identificador "S" ;
ex:parteDe ex:Sistema1 .

ex:SalidaAnalogicaANAOUT a ex:SalidaAnalogica ;
ex:identificador "ANAOUT" ;
ex:parteDe ex:Sistema1 .

ex:EntradaCaptacionE21A a ex:EntradaCaptacion ;
ex:identificador "E21A" ;
ex:parteDe ex:Sistema1 .

ex:EntradaCaptacionE21B a ex:EntradaCaptacion ;
ex:identificador "E21B" ;
ex:parteDe ex:Sistema1 .

ex:EntradaCaptacionE21C a ex:EntradaCaptacion ;
ex:identificador "E21C" ;
ex:parteDe ex:Sistema1 .