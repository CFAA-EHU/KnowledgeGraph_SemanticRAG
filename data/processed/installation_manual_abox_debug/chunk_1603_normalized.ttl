@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:DiagnosticoFallo1
  a ex:DiagnosticoFallo ;
  rdfs:label "ERROR 24499 – EtherCAT: Error in slave. More information in diagnostic"@es ;
  ex:identificador "ERROR 24499" ;
  ex:detalladoEnEsquema ex:EsquemaDiagnostico .

ex:EsquemaDiagnostico
  a ex:Esquema ;
  ex:detalladoEnEsquema ex:PantallaDiagnostico .

ex:PantallaDiagnostico
  a ex:Pantalla ;
  ex:ilustradoEn ex:HMI .

ex:HMI
  a ex:HMI ;
  ex:tieneComponente ex:BotonNavegacion .

ex:BotonNavegacion
  a ex:Boton ;
  ex:habilitadoPor ex:AlarmaError .

ex:AlarmaError
  a ex:Alarma ;
  ex:activaAlarma ex:DiagnosticoFallo1 .

ex:NodoEnError
  a ex:Nodo ;
  ex:tieneComponente ex:ModuloAfectado .

ex:ModuloAfectado
  a ex:Modulo ;
  ex:tieneComponente ex:PanelDerecho .

ex:PanelDerecho
  a ex:Panel ;
  ex:tieneComponente ex:InfoValue .

ex:InfoValue
  a ex:InfoValue ;
  ex:tieneComponente ex:IconoJerarquico .

ex:IconoJerarquico
  a ex:Icono ;
  ex:tieneComponente ex:JerarquiaModulos .

ex:JerarquiaModulos
  a ex:Jerarquia ;
  ex:tieneComponente ex:ArbolConfiguracion .

ex:ArbolConfiguracion
  a ex:Arbol ;
  ex:tieneComponente ex:TablaSignificados .

ex:TablaSignificados a ex:Tabla ;
     a ex:Tabla ;
  ex:tieneComponente ex:PanelOpciones .

ex:PanelOpciones
  a ex:Panel ;
  ex:tieneComponente ex:BotonesAplicados .

ex:BotonesAplicados
  a ex:Botones ;
  ex:tieneComponente ex:CajaRutaProyecto .

ex:CajaRutaProyecto
  a ex:Caja ;
  ex:tieneComponente ex:RutaProyecto .

ex:RutaProyecto
  a ex:Ruta ;
  ex:tieneComponente ex:PlantillaHardware .

ex:PlantillaHardware
  a ex:Plantilla ;
  ex:tieneComponente ex:DialogoConfiguracion .

ex:DialogoConfiguracion
  a ex:Dialogo ;
  ex:tieneComponente ex:CampoNombre .

ex:CampoNombre
  a ex:Campo ;
  ex:tieneComponente ex:CampoParametros .

ex:CampoParametros
  a ex:Campo ;
  ex:tieneComponente ex:AccesoSettings .