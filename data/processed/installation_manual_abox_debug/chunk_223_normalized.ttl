@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaSubrutinasFabricante a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de subrutinas del fabricante"@es ;
    ex:textoExtracto "SUBTABLE Tabla de subrutinas del fabricante. Las subrutinas de fabricante son aquellas guardadas la carpeta ..\\MTB\\Sub."@es ;
    ex:documentadoEn ex:ManualCNC .

ex:SubrutinaTOOLSUB
    a ex:Componente ;
    rdfs:label "TOOLSUB" ;
    ex:identificador "TOOLSUB" ;
    ex:textoExtracto "TOOLSUB Subrutina asociada a la función T. Valores posibles: Cualquier texto de hasta 64 caracteres. Variable asociada: (V.)[ch].MPG.TOOLSUB Esta subrutina se ejecuta automáticamente cada vez que se ejecuta una función T (selección de herramienta)."@es ;
    ex:documentadoEn ex:TablaSubrutinasFabricante .

ex:SubrutinaREFPSUB
    a ex:Componente ;
    rdfs:label "REFPSUB (G74)" ;
    ex:identificador "REFPSUB" ;
    ex:textoExtracto "REFPSUB (G74) Subrutina asociada a la función G74. Valores posibles: Cualquier texto de hasta 64 caracteres. Variable asociada: (V.)[ch].MPG.REFPSUB La función G74 (búsqueda de referencia máquina) se puede programar de 2 formas."@es ;
    ex:documentadoEn ex:TablaSubrutinasFabricante .

ex:SubrutinaINT1SUB
    a ex:Componente ;
    rdfs:label "INT1SUB" ;
    ex:identificador "INT1SUB" ;
    ex:textoExtracto "INT1SUB··INT4SUB Subrutinas de interrupción."@es ;
    ex:documentadoEn ex:TablaSubrutinasFabricante .

ex:SubrutinaINT2SUB
    a ex:Componente ;
    rdfs:label "INT2SUB" ;
    ex:identificador "INT2SUB" ;
    ex:textoExtracto "INT1SUB··INT4SUB Subrutinas de interrupción."@es ;
    ex:documentadoEn ex:TablaSubrutinasFabricante .

ex:SubrutinaINT3SUB
    a ex:Componente ;
    rdfs:label "INT3SUB" ;
    ex:identificador "INT3SUB" ;
    ex:textoExtracto "INT1SUB··INT4SUB Subrutinas de interrupción."@es ;
    ex:documentadoEn ex:TablaSubrutinasFabricante .

ex:SubrutinaINT4SUB
    a ex:Componente ;
    rdfs:label "INT4SUB" ;
    ex:identificador "INT4SUB" ;
    ex:textoExtracto "INT1SUB··INT4SUB Subrutinas de interrupción."@es ;
    ex:documentadoEn ex:TablaSubrutinasFabricante .

ex:ManualCNC
    a ex:Manual .