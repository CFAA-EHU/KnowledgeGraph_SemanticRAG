@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TablaSubrutinasFabricante a ex:Tabla ;
    rdfs:label "Tabla de subrutinas del fabricante"@es ;
    ex:textoExtracto "SUBTABLE Tabla de subrutinas del fabricante. Las subrutinas de fabricante son aquellas guardadas la carpeta ..\MTB\Sub. Estas subrutinas están asociadas a algunas funciones del CNC como el cambio de herramienta, G74, G180 a G189, G380 a G399, etc."@es .

ex:SubrutinaTOOLSUB a ex:TareaMantenimiento ;
    rdfs:label "TOOLSUB"@es ;
    ex:textoExtracto "TOOLSUB Subrutina asociada a la función T. Valores posibles: Cualquier texto de hasta 64 caracteres. Variable asociada: (V.)[ch].MPG.TOOLSUB Esta subrutina se ejecuta automáticamente cada vez que se ejecuta una función T (selección de herramienta)."@es .

ex:SubrutinaREFPSUB a ex:TareaMantenimiento ;
    rdfs:label "REFPSUB (G74)"@es ;
    ex:textoExtracto "REFPSUB (G74) Subrutina asociada a la función G74. Valores posibles: Cualquier texto de hasta 64 caracteres. Variable asociada: (V.)[ch].MPG.REFPSUB La función G74 (búsqueda de referencia máquina) se puede programar de 2 formas. Indicando los ejes y el orden en que se efectúa la búsqueda o programando sólo G74 (sin ejes). Al ejecutarse un bloque que contiene sólo la función G74 (sin ejes) se efectúa una llamada a la rutina indicada en éste parámetro. Dentro de esta subrutina deben programarse los ejes y el orden en que se efectúa la búsqueda. También se efectúa una llamada a esta subrutina cuando se realiza una búsqueda de referencia máquina en modo manual sin selección de eje."@es .

ex:SubrutinaINT1SUB a ex:TareaMantenimiento ;
    rdfs:label "INT1SUB"@es ;
    ex:textoExtracto "INT1SUB··INT4SUB Subrutinas de interrupción."@es .

ex:SubrutinaINT2SUB a ex:TareaMantenimiento ;
    rdfs:label "INT2SUB"@es ;
    ex:textoExtracto "INT1SUB··INT4SUB Subrutinas de interrupción."@es .

ex:SubrutinaINT3SUB a ex:TareaMantenimiento ;
    rdfs:label "INT3SUB"@es ;
    ex:textoExtracto "INT1SUB··INT4SUB Subrutinas de interrupción."@es .

ex:SubrutinaINT4SUB a ex:TareaMantenimiento ;
    rdfs:label "INT4SUB"@es ;
    ex:textoExtracto "INT1SUB··INT4SUB Subrutinas de interrupción."@es .

ex:TablaSubrutinasFabricante a ex:Tabla ;
    ex:compuestoPor ex:SubrutinaTOOLSUB, ex:SubrutinaREFPSUB, ex:SubrutinaINT1SUB, ex:SubrutinaINT2SUB, ex:SubrutinaINT3SUB, ex:SubrutinaINT4SUB .