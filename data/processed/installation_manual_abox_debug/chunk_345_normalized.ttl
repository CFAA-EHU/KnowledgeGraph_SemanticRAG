@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:LSCRWCOMP a ex:Parametro ;
    ex:textoExtracto "LSCRWCOMP
DATA
POSITION | Posición del eje.
POSERROR | Error a compensar en los desplazamientos en sentido positivo.
NEGERROR | Error a compensar en los desplazamientos en sentido negativo." .

ex:POSITION a ex:Parametro ;
    ex:textoExtracto "POSITION | Posición del eje." .

ex:POSERROR a ex:Parametro ;
    ex:textoExtracto "POSERROR | Error a compensar en los desplazamientos en sentido positivo." .

ex:NEGERROR a ex:Parametro ;
    ex:textoExtracto "NEGERROR | Error a compensar en los desplazamientos en sentido negativo." .