@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ParametroACCEL a rdfs:Class ;
    rdfs:label "Parámetro ACCEL"@es ;
    ex:textoExtracto "Ambos parámetros permiten limitar los cambios de aceleración"@es ;
    ex:valor "ACCEL"@es .

ex:ParametroDECEL a rdfs:Class ;
    rdfs:label "Parámetro DECEL"@es ;
    ex:textoExtracto "Ambos parámetros permiten limitar los cambios de aceleración"@es ;
    ex:valor "DECEL"@es .

ex:ParametroG0ACDCJERK a rdfs:Class ;
    rdfs:label "Parámetro G0ACDCJERK"@es ;
    ex:textoExtracto "los movimientos en G0 dependen del parámetro G0ACDCJERK"@es ;
    ex:valor "G0ACDCJERK"@es .

ex:ParametroFFGAIN a rdfs:Class ;
    rdfs:label "Parámetro FFGAIN"@es ;
    ex:textoExtracto "con valores de FFGAIN cercanos al 100%"@es ;
    ex:valor "FFGAIN"@es .

ex:MovimientoG0 a ex:ModoOperacion ;
    rdfs:label "Movimiento G0"@es ;
    ex:textoExtracto "los movimientos en G0 dependen del parámetro G0ACDCJERK"@es .

ex:MovimientoG1 a ex:ModoOperacion ;
    rdfs:label "Movimiento G1"@es ;
    ex:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1"@es .

ex:MovimientoG2 a ex:ModoOperacion ;
    rdfs:label "Movimiento G2"@es ;
    ex:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G2"@es .

ex:MovimientoG3 a ex:ModoOperacion ;
    rdfs:label "Movimiento G3"@es ;
    ex:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G3"@es .

ex:MovimientoG33 a ex:ModoOperacion ;
    rdfs:label "Movimiento G33"@es ;
    ex:textoExtracto "El CNC no tiene en cuenta estos parámetros en los movimientos con roscado (G33)"@es .

ex:MovimientoHSCFAST a ex:ModoOperacion ;
    rdfs:label "Movimiento HSC FAST"@es ;
    ex:textoExtracto "El CNC no tiene en cuenta estos parámetros en ... HSC FAST"@es .