ex:SistemaCNC a ex:Sistema ;
    rdfs:label "CNC 8070" ;
    ex:textoExtracto "HSC Tabla de parámetros del modo HSC. Este parámetro muestra la tabla para definir el modo HSC de trabajo." .

ex:ParametroModoHSC a ex:Parametro ;
    rdfs:label "Modo HSC" ;
    ex:textoExtracto "Este parámetro muestra la tabla para definir el modo HSC de trabajo." ;
    ex:documentadoEn ex:SistemaCNC .