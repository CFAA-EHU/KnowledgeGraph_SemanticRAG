@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:SistemaCNC a ex:Sistema ;
    rdfs:label "CNC 8070" ;
    ex:textoExtracto "el CNC arranca con la nueva posición calculada por el encóder y pone la marca de PLC REFPOIN = 1." .

ex:ParametroMAXDIFREF a ex:Parametro ;
    rdfs:label "Máxima diferencia de referencia" ;
    ex:textoExtracto "Si la diferencia es menor que MAXDIFREF, el CNC arranca con la nueva posición calculada por el encóder y pone la marca de PLC REFPOIN = 1." .

ex:AceiteHidraulicoISO46 a ex:Consumible ;
    rdfs:label "Aceite Hidráulico ISO 46" ;
    ex:textoExtracto "" ; # No hay información relevante para este consumible en el fragmento.

ex:FalloError3753 a ex:DiagnosticoFallo ;
    rdfs:label "Error de referencia 3753" ;
    ex:textoExtracto "Si la diferencia es mayor que MAXDIFREF, el CNC arrancará con la posición guardada por el CNC en el apagado y mostrará el error 3753." .

ex:TareaRevisionPosicion a ex:TareaMantenimiento ;
    rdfs:label "Revisión de Posición" ;
    ex:textoExtracto "Con este error, el usuario decide la validez de la cota." ;
    ex:solucionaFallo ex:FalloError3753 .