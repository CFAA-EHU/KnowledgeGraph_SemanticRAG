@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModuloCY1 a ex:Sistema ;
    ex:textoExtracto "CY1 ; Comienzo del módulo CY1 ... END ; Final del módulo CY1" .

ex:ModuloPRG a ex:Sistema ;
    ex:textoExtracto "PRG ; Comienzo del módulo PRG ... END ; Final del módulo PRG" .

ex:RecursoREA a ex:Parametro ;
    ex:textoExtracto "REA, IMA Valores reales o imagen. Indican si las consultas definidas a continuación se realizan teniendo en cuenta los valores reales (REA) o imagen (IMA) de los recursos I, O, M." ;
    rdfs:label "REA" .

ex:RecursoIMA a ex:Parametro ;
    ex:textoExtracto "REA, IMA Valores reales o imagen. Indican si las consultas definidas a continuación se realizan teniendo en cuenta los valores reales (REA) o imagen (IMA) de los recursos I, O, M." ;
    rdfs:label "IMA" .

ex:RecursoI a ex:Parametro ;
    ex:textoExtracto "valores reales (REA) o imagen (IMA) de los recursos I, O, M" ;
    rdfs:label "I" .

ex:RecursoO a ex:Parametro ;
    ex:textoExtracto "valores reales (REA) o imagen (IMA) de los recursos I, O, M" ;
    rdfs:label "O" .

ex:RecursoM a ex:Parametro ;
    ex:textoExtracto "valores reales (REA) o imagen (IMA) de los recursos I, O, M" ;
    rdfs:label "M" .

ex:ExpresionIMAI3ANDREA M4 a ex:AccionProhibida ;
    ex:textoExtracto "IMA I3 AND REA M4 = 02" .

ex:InstruccionAccionO32 a ex:TareaMantenimiento ;
    ex:textoExtracto "Las instrucciones de acción (=O32) siempre actualizan los valores reales de los recursos del PLC." .