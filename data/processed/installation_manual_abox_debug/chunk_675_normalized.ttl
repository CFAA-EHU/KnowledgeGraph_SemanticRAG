@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broading/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:configuracionTecladoNEXT
    a ex:InterfazUsuario ;
    rdfs:label "Configuración de la tecla NEXT"@es ;
    ex:textoExtracto "Configuración del teclado (tecla [NEXT])."@es ;
    ex:tieneComponente ex:menuPaginas, ex:menuCanales, ex:menuComponentes .

ex:menuPaginas
    a ex:InterfazUsuario ;
    rdfs:label "Menú Páginas"@es ;
    ex:textoExtracto "El menú muestra las distintas páginas o pantallas del modo de trabajo activo."@es ;
    ex:monitoreaParametro ex:parametroPaginas .

ex:menuCanales
    a ex:InterfazUsuario ;
    rdfs:label "Menú Canales"@es ;
    ex:textoExtracto "El menú muestra la lista de canales disponibles."@es ;
    ex:monitoreaParametro ex:parametroCanales .

ex:menuComponentes
    a ex:InterfazUsuario ;
    rdfs:label "Menú Componentes"@es ;
    ex:textoExtracto "El menú muestra los componentes o modos de trabajo del CNC."@es ;
    ex:monitoreaParametro ex:parametroComponentes .

ex:parametroPaginas
    a ex:Parametro ;
    rdfs:label "Páginas (modo de trabajo)"@es ;
    ex:valor "Páginas"@es ;
    ex:textoExtracto "El menú muestra las distintas páginas o pantallas del modo de trabajo activo."@es .

ex:parametroCanales
    a ex:Parametro ;
    rdfs:label "Canales"@es ;
    ex:valor "Canales"@es ;
    ex:textoExtracto "El menú muestra la lista de canales disponibles."@es .

ex:parametroComponentes
    a ex:Parametro ;
    rdfs:label "Componentes/Modos de trabajo"@es ;
    ex:valor "Componentes"@es ;
    ex:textoExtracto "El menú muestra los componentes o modos de trabajo del CNC."@es .

ex:modoDeshabilitado
    a ex:ModoOperacion ;
    rdfs:label "Modo deshabilitado"@es ;
    ex:textoExtracto "El menú estará deshabilitado."@es .