@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModuloPeriodicoPE30000 a ex:Modulo ;
    rdfs:label "módulo periódico PE 30000"@es ;
    ex:textoExtracto "Una tarea que es suficiente evaluarla cada 30 segundos se definirá en un módulo periódico que se ejecute cada 30 segundos (PE 30000)."@es ;
    ex:identificador "PE 30000" .

ex:ModuloPeriodico a ex:Modulo ;
    rdfs:label "módulo periódico"@es ;
    ex:textoExtracto "Este módulo se puede utilizar para tareas que no necesitan ser evaluadas en cada ciclo del PLC."@es .