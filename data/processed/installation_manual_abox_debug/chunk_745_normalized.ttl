@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:ParametroCam a ex:Parametro ;
    rdfs:label "Número de leva" ;
    ex:textoExtracto "cam | Número de leva." .

ex:ParametroMaster a ex:Parametro ;
    rdfs:label "Nombre del eje maestro" ;
    ex:textoExtracto "master | Nombre del eje maestro." .

ex:ParametroTIME a ex:Parametro ;
    rdfs:label "Leva de tiempo" ;
    ex:textoExtracto "TIME | Leva de tiempo. Si en lugar de programar un nombre de eje se programa \"TIME\", la leva se interpreta como una leva en tiempo." .

ex:ParametroSlave a ex:Parametro ;
    rdfs:label "Nombre del eje esclavo" ;
    ex:textoExtracto "slave | Nombre del eje esclavo." .

ex:ParametroMasterOff a ex:Parametro ;
    rdfs:label "Offset para el eje maestro" ;
    ex:textoExtracto "master_off | Offset para el eje maestro." .

ex:ParametroSlaveOff a ex:Parametro ;
    rdfs:label "Offset para el eje esclavo" ;
    ex:textoExtracto "slave_off | Offset para el eje esclavo." .

ex:ParametroRangeMaster a ex:Parametro ;
    rdfs:label "Escala o rango de activación del eje maestro" ;
    ex:textoExtracto "range_master | Escala o rango de activación del eje maestro." .

ex:ParametroRangeSlave a ex:Parametro ;
    rdfs:label "Escala o rango de activación del eje esclavo" ;
    ex:textoExtracto "range_slave | Escala o rango de activación del eje esclavo." .

ex:ParametroType a ex:Parametro ;
    rdfs:label "Define el tipo de leva; periódica o no periódica" ;
    ex:textoExtracto "type | Define el tipo de leva; periódica o no periódica. Se programa mediante los parámetros \"ONCE\" (leva no periódica) o \"CONT\" (leva periódica)."