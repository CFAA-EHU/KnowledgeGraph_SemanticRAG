@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ParametroA_ZONELIMITTOL_a ex:Parametro ;
    rdfs:label "Distancia de seguridad de los límites de las zonas de trabajo" ;
    ex:identificador "A.ZONELIMITTOL.xn" ;
    ex:textoExtracto "[ch].A.ZONELIMITTOL.xn | Distancia de seguridad de los límites de las zonas de trabajo." .

ex:ParametroG_ZONEST_k ex:Parametro ;
    rdfs:label "Estado de la zona de trabajo [k]" ;
    ex:identificador "G.ZONEST[k]" ;
    ex:textoExtracto "[ch].G.ZONEST[k] | Estado de la zona de trabajo [k]." .

ex:ParametroA_ZONELOWLIM_k_a ex:Parametro ;
    rdfs:label "Límite inferior de la zona [k]" ;
    ex:identificador "A.ZONELOWLIM[k].xn" ;
    ex:textoExtracto "[ch].A.ZONELOWLIM[k].xn | Límite inferior de la zona [k]." .

ex:ParametroA_ZONEUPLIM_k_a ex:Parametro ;
    rdfs:label "Límite superior de la zona [k]" ;
    ex:identificador "A.ZONEUPLIM[k].xn" ;
    ex:textoExtracto "[ch].A.ZONEUPLIM[k].xn | Límite superior de la zona [k]." .

ex:ParametroG_ZONECIRAX1_k ex:Parametro ;
    rdfs:label "Eje lógico correspondiente a la primera cota del centro de la zona [k]" ;
    ex:identificador "G.ZONECIRAX1[k]" ;
    ex:textoExtracto "[ch].G.ZONECIRAX1[k] | Eje lógico correspondiente a la primera cota del centro de la zona [k]." .