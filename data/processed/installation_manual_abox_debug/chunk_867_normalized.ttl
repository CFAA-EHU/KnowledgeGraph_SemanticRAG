@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:SistemaCNC a ex:Sistema ;
    rdfs:label "CNC 8070" ;
    ex:textoExtracto "El CNC activa esta marca cuando el usuario valida los parámetros de piercing de la tabla activa." .

ex:PLC a ex:Sistema ;
    rdfs:label "PLC" ;
    ex:textoExtracto "El PLC gestiona los efectos de estas variables sobre los dispositivos de la máquina (salidas analógicas, digitales, etc)." .

ex:ParametroPIRVARACT a ex:Parametro ;
    ex:identificador "PIRVARACT" ;
    rdfs:label "Marca activada por el CNC cuando se validan parámetros de piercing" ;
    ex:textoExtracto "El CNC activa esta marca cuando el usuario valida los parámetros de piercing de la tabla activa." .

ex:ParametroINPOSGAP a ex:Parametro ;
    ex:identificador "INPOSGAP" ;
    rdfs:label "Marca que indica si el gap está dentro del rango definido por GAPMIN y GAPMAX" ;
    ex:textoExtracto "El CNC activa esta marca si el gap está dentro del rango definido por los parámetros GAPMIN-GAPMAX." .

ex:ParametroGAPERRORCANCEL a ex:Parametro ;
    ex:identificador "GAPERRORCANCEL" ;
    rdfs:label "Parámetro que establece el comportamiento del CNC cuando el gap sobrepasa el rango GAPMIN - GAPMAX" ;
    ex:textoExtracto "El parámetro GAPERRORCANCEL establece el comportamiento del CNC cuando el gap sobrepasa el rango GAPMIN - GAPMAX." .

ex:ParametroGAPMIN a ex:Parametro ;
    ex:identificador "GAPMIN" ;
    rdfs:label "Parámetro que define el límite inferior del rango de gap" ;
    ex:textoExtracto "El CNC activa esta marca si el gap está dentro del rango definido por los parámetros GAPMIN-GAPMAX." .

ex:ParametroGAPMAX a ex:Parametro ;
    ex:identificador "GAPMAX" ;
    rdfs:label "Parámetro que define el límite superior del rango de gap" ;
    ex:textoExtracto "El CNC activa esta marca si el gap está dentro del rango definido por los parámetros GAPMIN-GAPMAX." .

ex:SistemaCNC ex:activaAlarma ex:ParametroPIRVARACT .
ex:SistemaCNC ex:activaAlarma ex:ParametroINPOSGAP .
ex:SistemaCNC ex:desactivaAlarma ex:ParametroINPOSGAP .
ex:PLC ex:gestiona ex:ParametroPIRVARACT .
ex:PLC ex:gestiona ex:ParametroINPOSGAP .