@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:HerramientaCabezal a a ex:Herramienta ;
    rdfs:label "herramienta del cabezal"@es ;
    ex:textoExtracto "Coger la herramienta del cabezal con la pinza ꞏ2ꞏ"@es .

ex:Pinza2 a ex:ComponenteMecanico ;
    rdfs:label "pinza ꞏ2ꞏ"@es ;
    ex:textoExtracto "pinza ꞏ2ꞏ"@es .

ex:MarcaSPDLTOCH2 a ex:Parametro ;
    rdfs:label "marca SPDLTOCH2"@es ;
    ex:identificador "SPDLTOCH2" ;
    ex:textoExtracto "activar la marca SPDLTOCH2"@es .

ex:HerramientaTierra a ex:ComponenteElectrico ;
    rdfs:label "herramienta de tierra"@es ;
    ex:textoExtracto "Poner la herramienta de tierra en el cabezal"@es .

ex:MarcaGRTOSPDL a ex:Parametro ;
    rdfs:label "marca GRTOSPDL"@es ;
    ex:identificador "GRTOSPDL" ;
    ex:textoExtracto "activar la marca GRTOSPDL"@es .

ex:BrazoCambiador a ex:ComponenteMecanico ;
    rdfs:label "brazo cambiador"@es ;
    ex:textoExtracto "Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza ꞏ2ꞏ"@es .

ex:MarcaTCHANGEOK a ex:Parametro ;
    rdfs:label "marca TCHANGEOK"@es ;
    ex:identificador "TCHANGEOK" ;
    ex:textoExtracto "activar TCHANGEOK"@es .

ex:Almacen a ex:Sistema ;
    rdfs:label "almacén"@es ;
    ex:textoExtracto "dejar la herramienta de la pinza ꞏ2ꞏ en el almacén"@es .

ex:MarcaCH2TOMZ a ex:Parametro ;
    rdfs:label "marca CH2TOMZ"@es ;
    ex:identificador "CH2TOMZ" ;
    ex:textoExtracto "activar la marca CH2TOMZ"@es .

ex:TMOPERATION a ex:Parametro ;
    rdfs:label "TMOPERATION"@es ;
    ex:identificador "TMOPERATION" ;
    ex:valor "7" ;
    ex:textoExtracto "TMOPERATION = 7"@es .

ex:TAKEPOS a ex:Parametro ;
    rdfs:label "TAKEPOS"@es ;
    ex:identificador "TAKEPOS" ;
    ex:valor "-1" ;
    ex:textoExtracto "TAKEPOS=-1"@es .

ex:LEAVEPOS a ex:Parametro ;
    rdfs:label "LEAVEPOS"@es ;
    ex:identificador "LEAVEPOS" ;
    ex:valor "-4" ;
    ex:textoExtracto "LEAVEPOS=-4"@es .

ex:HerramientaBrazo a ex:Herramienta ;
    rdfs:label "herramienta del brazo"@es ;
    ex:textoExtracto "Dejar la herramienta del cabezal en tierra y coger una herramienta del brazo"@es .

ex:BrazoCambiador a ex:ComponenteMecanico ;
    rdfs:label "brazo cambiador"@es ;
    ex:textoExtracto "Herramienta en el brazo cambiador"@es .

ex:HerramientaTierra a ex:ComponenteElectrico ;
    rdfs:label "herramienta de tierra"@es ;
    ex:textoExtracto "LEAVEPOS=-4 Herramienta de tierra"@es .