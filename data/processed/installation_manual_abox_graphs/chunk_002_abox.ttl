@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DocumentoTecnicoConfiguracionSoftware a ns1:DocumentoTecnico ;
    rdfs:label "1.7 Configuración del software" ;
    ns1:documentadoEn ns1:CNC8070_6f21d461ef ;
    ns1:textoExtracto "Ver \"1.7 Configuración del software.\" en la página 45."@es .

ns1:CNC8070_6f21d461ef a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:mitigaRiesgo ns1:ModificacionDelSoftwareSinConsentimiento,
        ns1:ReinstalacionOModificacionDelSoftwareSinConsentimiento ;
    ns1:textoExtracto "Fagor entrega el CNC con el software correctamente instalado en un disco de tipo compact flash." .

ns1:ModificacionDelSoftwareSinConsentimiento a ns1:AccionProhibida ;
    rdfs:label "Modificación del software sin consentimiento" ;
    ns1:textoExtracto "Fagor Automation no se responsabiliza de lesiones a personas, daños físicos o materiales que pudiera sufrir o provocar el CNC y que hayan sido motivados por una manipulación del software." .

ns1:ReinstalacionOModificacionDelSoftwareSinConsentimiento a ns1:AccionProhibida ;
    rdfs:label "Reinstalación o modificación del software sin consentimiento" ;
    ns1:textoExtracto "No se debe reinstalar ni modificar el software del CNC sin consentimiento expreso de Fagor Automation." .

