@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SistemaCNC8070 a ex:Maquina ;
    ex:textoExtracto "el sistema moverá la carpeta correspondiente desde ..\\CONFIGURATION a CNC8070 y la renombrará como MTB" ;
    ex:tieneComponente ex:CarpetaMTB .

ex:CarpetaMTB a ex:Componente ;
    ex:textoExtracto "la renombrará como MTB" ;
    ex:identificador "MTB" ;
    ex:textoExtracto "el sistema no hará ningún cambio en el arranque ni al modificar el código de validación" .

ex:CarpetaCONFIGURATION a ex:Componente ;
    ex:textoExtracto "desde ..\\CONFIGURATION a CNC8070" ;
    ex:identificador "CONFIGURATION" .

ex:CarpetaMTB_M a ex:Componente ;
    ex:textoExtracto "le dará su antiguo nombre (MTB_M, MTB_T, etc)" ;
    ex:identificador "MTB_M" .

ex:CarpetaMTB_T a ex:Componente ;
    ex:textoExtracto "le dará su antiguo nombre (MTB_M, MTB_T, etc)" ;
    ex:identificador "MTB_T" .