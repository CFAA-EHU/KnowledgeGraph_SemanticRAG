@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_5b27bf375e a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Fagor entrega el equipo con un disco del tipo compact flash protegido frente a escritura, excepto aquellas carpetas o archivos que deben estar desprotegidos para el funcionamiento habitual del CNC." ;
    ns1:tieneComponente ns1:BarraEstado,
        ns1:DiscoCompactFlash,
        ns1:ModoTrabajoActivo .

ns1:BarraEstado a ns1:ComponenteElectrico ;
    rdfs:label "Barra de estado" ;
    ns1:textoExtracto "Cuando el CNC está arrancado, la barra de estado muestra el modo de trabajo activo mediante iconos." .

ns1:DiscoCompactFlash a ns1:ComponenteElectrico ;
    rdfs:label "Disco Compact Flash" ;
    ns1:textoExtracto "Fagor entrega el equipo con un disco del tipo compact flash protegido frente a escritura, excepto aquellas carpetas o archivos que deben estar desprotegidos para el funcionamiento habitual del CNC." .

ns1:ModoTrabajoActivo a ns1:ModoOperacion ;
    rdfs:label "Modo de trabajo activo" ;
    ns1:textoExtracto "El equipo muestra el modo de trabajo activo mediante un icono en la barra de tareas del sistema operativo, junto al reloj." .

