@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:DiscoCompactFlash_4 a ex:ComponenteElectrico ;
    rdfs:label "disco del tipo compact flash" ;
    ex:textoExtracto "Fagor entrega el equipo con un disco del tipo compact flash protegido frente a escritura" ;
    ex:compuestoPor ex:ProteccionEscritura_4 .

ex:ProteccionEscritura_4 a ex:ElementoSeguridad ;
    ex:textoExtracto "protegido frente a escritura" .

ex:ModoAcceso_4_1 a ex:ModoOperacion ;
    rdfs:label "modo de acceso 1" ;
    ex:textoExtracto "El disco está preconfigurado con tres modos de acceso, cada uno de los cuales ofrece un nivel de protección diferente" .

ex:ModoAcceso_4_2 a ex:ModoOperacion ;
    rdfs:label "modo de acceso 2" ;
    ex:textoExtracto "El disco está preconfigurado con tres modos de acceso, cada uno de los cuales ofrece un nivel de protección diferente" .

ex:ModoAcceso_4_3 a ex:ModoOperacion ;
    rdfs:label "modo de acceso 3" ;
    ex:textoExtracto "El disco está preconfigurado con tres modos de acceso, cada uno de los cuales ofrece un nivel de protección diferente" .

ex:IconoModoTrabajo_4 a ex:InterfazUsuario ;
    rdfs:label "icono en la barra de tareas" ;
    ex:textoExtracto "El equipo muestra el modo de trabajo activo mediante un icono en la barra de tareas del sistema operativo, junto al reloj" ;
    ex:ilustradoEn ex:DiscoCompactFlash_4 .

ex:BarraEstado_4 a ex:InterfazUsuario ;
    rdfs:label "barra de estado" ;
    ex:textoExtracto "Cuando el CNC está arrancado, la barra de estado muestra el modo de trabajo activo mediante iconos" ;
    ex:ilustradoEn ex:DiscoCompactFlash_4 .