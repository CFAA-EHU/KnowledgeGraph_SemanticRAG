@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiscoCompactFlash_CNC
    a ex:ComponenteElectrico ;
    rdfs:label "Disco compact flash del CNC" ;
    ex:textoExtracto "Fagor entrega el equipo con un disco del tipo compact flash protegido frente a escritura, excepto aquellas carpetas o archivos que deben estar desprotegidos para el funcionamiento habitual del CNC." .

ex:ModoAcceso_Basico
    a ex:ModoOperacion ;
    rdfs:label "Modo de acceso básico (preconfigurado)" ;
    ex:textoExtracto "El disco está preconfigurado con tres modos de acceso, cada uno de los cuales ofrece un nivel de protección diferente." .

ex:ModoAcceso_Intermedio
    a ex:ModoOperacion ;
    rdfs:label "Modo de acceso intermedio (preconfigurado)" ;
    ex:textoExtracto "El disco está preconfigurado con tres modos de acceso, cada uno de los cuales ofrece un nivel de protección diferente." .

ex:ModoAcceso_Avanzado
    a ex:ModoOperacion ;
    rdfs:label "Modo de acceso avanzado (preconfigurado)" ;
    ex:textoExtracto "El disco está preconfigurado con tres modos de acceso, cada uno de los cuales ofrece un nivel de protección diferente." .

ex:InterfazUsuario_CNC
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de usuario del CNC" ;
    ex:textoExtracto "El equipo muestra el modo de trabajo activo mediante un icono en la barra de tareas del sistema operativo, junto al reloj. Cuando el CNC está arrancado, la barra de estado muestra el modo de trabajo activo mediante iconos." ;
    ex:ilustradoEn ex:DiscoCompactFlash_CNC .

ex:BarraEstado_CNC
    a ex:InterfazUsuario ;
    rdfs:label "Barra de estado del CNC" ;
    ex:textoExtracto "la barra de estado muestra el modo de trabajo activo mediante iconos" ;
    ex:compuestoPor ex:InterfazUsuario_CNC .