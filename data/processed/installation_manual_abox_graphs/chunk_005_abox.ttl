@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoTrabajoAdministrador a ns1:ModoOperacion ;
    rdfs:label "Modo administrador" ;
    ns1:textoExtracto "Modo administrador (Administrator Mode)" .

ns1:ModoTrabajoSetup a ns1:ModoOperacion ;
    rdfs:label "Modo setup" ;
    ns1:textoExtracto "Modo setup (Setup Mode)" .

ns1:ModoTrabajoUsuario a ns1:ModoOperacion ;
    rdfs:label "Modo usuario" ;
    ns1:textoExtracto "Modo usuario (User Mode)" .

