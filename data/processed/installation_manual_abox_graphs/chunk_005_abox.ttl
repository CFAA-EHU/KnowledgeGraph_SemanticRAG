@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ModoAdministrador a ex:ModoOperacion ;
    ex:identificador "Administrator Mode" ;
    ex:textoExtracto "Modo administrador (Administrator Mode)" .

ex:ModoSetup a ex:ModoOperacion ;
    ex:identificador "Setup Mode" ;
    ex:textoExtracto "Modo setup (Setup Mode)" .

ex:ModoUsuario a ex:ModoOperacion ;
    ex:identificador "User Mode" ;
    ex:textoExtracto "Modo usuario (User Mode)" .