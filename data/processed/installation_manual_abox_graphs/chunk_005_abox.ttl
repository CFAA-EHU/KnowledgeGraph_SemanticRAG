@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ModosOperacionCNC a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de modos de operación del CNC"@es ;
    ex:textoExtracto """
| Icono. | Modo de trabajo. |
| --- | --- |
|  | Modo administrador (Administrator Mode). |
|  | Modo setup (Setup Mode). |
|  | Modo usuario (User Mode)."""@es ;
    ex:ilustradoEn ex:InterfazUsuario_CNC .

ex:InterfazUsuario_CNC
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de usuario del CNC"@es ;
    ex:textoExtracto "Modos de trabajo y protección del software en el CNC"@es .

ex:ModoOperacion_Administrador
    a ex:ModoOperacion ;
    rdfs:label "Modo administrador (Administrator Mode)"@es ;
    ex:textoExtracto "Modo administrador (Administrator Mode)."@es ;
    ex:documentadoEn ex:Tabla_ModosOperacionCNC .

ex:ModoOperacion_Setup
    a ex:ModoOperacion ;
    rdfs:label "Modo setup (Setup Mode)"@es ;
    ex:textoExtracto "Modo setup (Setup Mode)."@es ;
    ex:documentadoEn ex:Tabla_ModosOperacionCNC .

ex:ModoOperacion_Usuario
    a ex:ModoOperacion ;
    rdfs:label "Modo usuario (User Mode)"@es ;
    ex:textoExtracto "Modo usuario (User Mode)."@es ;
    ex:documentadoEn ex:Tabla_ModosOperacionCNC .