@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_f226fe5ced a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "En una actualización de software desde una versión en la que el equipo tiene un disco sin protección contra la escritura, no existirán estos modos de trabajo." ;
    ns1:tieneComponente ns1:HotkeyALT_D,
        ns1:ModoAdministrador,
        ns1:ModoTrabajo,
        ns1:VentanaDiskMonitor .

ns1:SistemaAbierto a ns1:Directiva ;
    rdfs:label "Sistema abierto" ;
    ns1:textoExtracto "Si usted no dispone de esta opción de software (es decir, dispone de un \"Sistema cerrado\"), no podrá acceder al modo." .

ns1:SistemaCerrado a ns1:Directiva ;
    rdfs:label "Sistema cerrado" ;
    ns1:textoExtracto "Si usted no dispone de esta opción de software (es decir, dispone de un \"Sistema cerrado\"), no podrá acceder al modo." .

ns1:HotkeyALT_D a ns1:ComponenteElectrico ;
    rdfs:label "[ALT][D]" ;
    ns1:textoExtracto "Con la aplicación CNC apagada, el cambio del modo de trabajo se realiza con la hotkey [ALT][D]." .

ns1:ModoAdministrador a ns1:ModoOperacion ;
    rdfs:label "modo administrador" ;
    ns1:textoExtracto "El acceso al modo administrador se habilita con el código de validación (opción de software \"Sistema abierto\")." .

ns1:ModoTrabajo a ns1:ModoOperacion ;
    rdfs:label "Modo de Trabajo" ;
    ns1:textoExtracto "Cambio del modo de trabajo (ventana diskMonitor)." .

ns1:VentanaDiskMonitor a ns1:InterfazUsuario ;
    rdfs:label "ventana DiskMonitor" ;
    ns1:textoExtracto "el equipo muestra la ventana DiskMonitor para cambiar de un modo de trabajo a otro." .

