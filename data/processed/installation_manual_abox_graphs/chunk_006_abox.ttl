@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoTrabajo_DiskMonitor
    a                     ex:ModoOperacion ;
    rdfs:label            "Modo de trabajo (ventana DiskMonitor)"@es ;
    ex:textoExtracto      "Cambio del modo de trabajo (ventana diskMonitor). [...] el equipo muestra la ventana DiskMonitor para cambiar de un modo de trabajo a otro. Este proceso implica reiniciar el equipo, y si el fabricante lo ha definido así, también será necesario introducir la contraseña correspondiente."@es .

ex:ModoTrabajo_Administrador
    a                     ex:ModoOperacion ;
    rdfs:label            "Modo administrador"@es ;
    ex:textoExtracto      "Modo administrador. El acceso al modo administrador se habilita con el código de validación (opción de software 'Sistema abierto')."@es ;
    ex:habilitadoPor      ex:OpcionSoftware_SistemaAbierto .

ex:OpcionSoftware_SistemaAbierto
    a                     ex:Parametro ;
    rdfs:label            "Sistema abierto (opción de software)"@es ;
    ex:textoExtracto      "opción de software 'Sistema abierto'"@es ;
    ex:identificador       "Sistema abierto" .

ex:OpcionSoftware_SistemaCerrado
    a                     ex:Parametro ;
    rdfs:label            "Sistema cerrado (opción de software)"@es ;
    ex:textoExtracto      "dispone de un 'Sistema cerrado'"@es ;
    ex:identificador       "Sistema cerrado" .

ex:Interfaz_DiskMonitor
    a                     ex:InterfazUsuario ;
    rdfs:label            "Ventana DiskMonitor"@es ;
    ex:textoExtracto      "el equipo muestra la ventana DiskMonitor para cambiar de un modo de trabajo a otro. [...] En la ventana anterior, al seleccionar el botón -i- de la parte superior derecha, el equipo muestra la lista de carpetas y archivos desprotegidos en ese momento."@es .

ex:Hotkey_ALT_D
    a                     ex:InterfazUsuario ;
    rdfs:label            "Combinación de teclas [ALT][D]"@es ;
    ex:textoExtracto      "el cambio del modo de trabajo se realiza con la hotkey [ALT][D] [...] Con el CNC arrancado en cualquier modo de trabajo, la hotkey [ALT][D] muestra la ventana DiskMonitor"@es .

ex:Hotkey_CTRL_ALT_TAB_SHIFT
    a                     ex:InterfazUsuario ;
    rdfs:label            "Secuencia de teclas [CTRL]+[ALT]+[TAB]+[SHIFT]"@es ;
    ex:textoExtracto      "la secuencia de teclas [CTRL]+[ALT]+[TAB]+[SHIFT] permite proteger o desproteger cualquier carpeta o archivo del sistema"@es .

ex:Proceso_ReinicioPorCambioModo
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Reinicio del equipo por cambio de modo de trabajo"@es ;
    ex:textoExtracto      "Este proceso implica reiniciar el equipo"@es .

ex:Proceso_ProteccionCarpetas
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Protección/desprotección de carpetas y archivos"@es ;
    ex:textoExtracto      "permiten proteger o desproteger cualquier carpeta o archivo del sistema que no sea clave para el correcto funcionamiento del control"@es ;
    ex:ejecutadoPor       ex:ModoTrabajo_Administrador ;
    ex:requiereMantenimiento ex:Interfaz_DiskMonitor .