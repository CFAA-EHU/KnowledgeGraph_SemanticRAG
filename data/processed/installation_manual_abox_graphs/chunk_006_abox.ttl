@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoAdministrador a ex:ModoOperacion ;
    rdfs:label "Modo administrador"@es ;
    ex:textoExtracto "El acceso al modo administrador se habilita con el código de validación (opción de software \"Sistema abierto\")."@es .

ex:SistemaCerrado a ex:ModoOperacion ;
    rdfs:label "Sistema cerrado"@es ;
    ex:textoExtracto "Si usted no dispone de esta opción de software (es decir, dispone de un \"Sistema cerrado\"), no podrá acceder al modo administrador."@es .

ex:VentanaDiskMonitor a ex:InterfazUsuario ;
    rdfs:label "Ventana DiskMonitor"@es ;
    ex:textoExtracto "el equipo muestra la ventana DiskMonitor para cambiar de un modo de trabajo a otro"@es .

ex:Hotkey_ALTD a ex:InterfazUsuario ;
    rdfs:label "[ALT][D]"@es ;
    ex:textoExtracto "el cambio del modo de trabajo se realiza con la hotkey [ALT][D]"@es .

ex:Hotkey_CTRLALTTABSHIFT a ex:InterfazUsuario ;
    rdfs:label "[CTRL]+[ALT]+[TAB]+[SHIFT]"@es ;
    ex:textoExtracto "la secuencia de teclas [CTRL]+[ALT]+[TAB]+[SHIFT] permite proteger o desproteger cualquier carpeta o archivo"@es .

ex:ModoUtilidades a ex:ModoOperacion ;
    rdfs:label "Modo utilidades"@es ;
    ex:textoExtracto "Desde el modo utilidades, desde el menú de softkeys se podrá seleccionar el modo de trabajo deseado."@es .

ex:ContrasenaFabricante a ex:Parametro ;
    rdfs:label "Contraseña correspondiente"@es ;
    ex:textoExtracto "si el fabricante lo ha definido así, también será necesario introducir la contraseña correspondiente"@es .