@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoOperacion_Administrador
    a ex:ModoOperacion ;
    rdfs:label "Modo Administrador" ;
    ex:textoExtracto "se habilita con el código de validación (opción de software \"Sistema abierto\"). [...] Este modo se debe utilizar exclusivamente para instalar software ajeno a Fagor, para instalar el CNC (también es posible desde el modo Setup), para actualizar el sistema operativo o para cambiar la configuración del sistema. En este modo no arranca la aplicación CNC. [...] ADMINISTRATOR MODE Nivel de protección. En el modo administrador no existe ningún nivel de protección, todo el disco está desprotegido." ;
    ex:identificador "Administrator Mode" ;
    ex:habilitadoPor ex:OpcionSoftware_SistemaAbierto .

ex:ModoOperacion_Setup
    a ex:ModoOperacion ;
    rdfs:label "Modo Setup" ;
    ex:textoExtracto "El modo Setup se debe utilizar exclusivamente para la actualización del software del CNC y para la puesta a punto de la máquina; no permite instalar software de terceros. [...] SETUP MODE Nivel de protección. El modo setup dispone de un nivel intermedio de protección, donde está desprotegido todo aquello susceptible de ser modificado durante la puesta en marcha de la máquina; carpetas ..\\MTB, ..\\USERS, ..\\DIAGNOSIS y el registro de Windows." ;
    ex:identificador "Setup Mode" .

ex:ModoOperacion_Usuario
    a ex:ModoOperacion ;
    rdfs:label "Modo Usuario" ;
    ex:textoExtracto "Modo usuario. Es el modo habitual de trabajo para el" .

ex:OpcionSoftware_SistemaAbierto
    a ex:Sistema ;
    rdfs:label "Sistema abierto (opción de software)" ;
    ex:textoExtracto "se habilita con el código de validación (opción de software \"Sistema abierto\")." ;
    ex:identificador "Sistema abierto" .

ex:InterfazUsuario_ModoAdministrador
    a ex:InterfazUsuario ;
    rdfs:label "Pantalla de Modo Administrador" ;
    ex:textoExtracto "El equipo muestra en el escritorio la siguiente imagen, con fondo rojo, indicando el modo de trabajo activo y advirtiendo de que se trata de un modo no protegido. ADMINISTRATOR MODE" ;
    ex:ilustradoEn ex:ModoOperacion_Administrador .

ex:InterfazUsuario_ModoSetup
    a ex:InterfazUsuario ;
    rdfs:label "Pantalla de Modo Setup" ;
    ex:textoExtracto "El equipo muestra en el escritorio la siguiente imagen, con fondo amarillo, indicando el modo de trabajo activo y advirtiendo de que se trata de un modo no protegido. SETUP MODE" ;
    ex:ilustradoEn ex:ModoOperacion_Setup .

ex:AvisoSeguridad_ModoAdministrador
    a ex:AvisoSeguridad ;
    rdfs:label "Advertencia de Modo No Protegido (Administrador)" ;
    ex:textoExtracto "indicando el modo de trabajo activo y advirtiendo de que se trata de un modo no protegido." ;
    ex:mitigaRiesgo ex:ModoOperacion_Administrador .

ex:AvisoSeguridad_ModoSetup
    a ex:AvisoSeguridad ;
    rdfs:label "Advertencia de Modo No Protegido (Setup)" ;
    ex:textoExtracto "indicando el modo de trabajo activo y advirtiendo de que se trata de un modo no protegido." ;
    ex:mitigaRiesgo ex:ModoOperacion_Setup .

ex:Contrasena_AdministratorMode
    a ex:Parametro ;
    rdfs:label "Contraseña \"Administrator mode\"" ;
    ex:textoExtracto "El acceso a este modo está protegido mediante la contraseña \"Administrator mode\", definida en el modo utilidades." ;
    ex:identificador "Administrator mode" ;
    ex:monitoreaParametro ex:ModoOperacion_Administrador .

ex:Contrasena_ParametrosMaquina
    a ex:Parametro ;
    rdfs:label "Contraseña \"Parámetros máquina\"" ;
    ex:textoExtracto "El acceso a este modo está protegido mediante la contraseña \"Parámetros máquina\", definida en el modo utilidades." ;
    ex:identificador "Parámetros máquina" ;
    ex:monitoreaParametro ex:ModoOperacion_Setup .