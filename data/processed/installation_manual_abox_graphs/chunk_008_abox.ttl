@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_1f96db738c a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Parámetros máquina, definida en el modo utilidades." ;
    ns1:tieneComponente ns1:ModoSetup,
        ns1:ModoUsuario,
        ns1:ModoUtilidades .

ns1:CarpetaUSERS a ns1:ElementoSeguridad ;
    rdfs:label "..\\USERS" ;
    ns1:textoExtracto "Los programas pieza deben guardarse en la carpeta ..\\USERS;" .

ns1:ModoSetup a ns1:ModoOperacion ;
    rdfs:label "Modo Setup (puesta a punto)" ;
    ns1:textoExtracto "En el encendido, el CNC mostrará un mensaje indicando que se encuentra en un modo no protegido y que la puesta a punto se encuentra sin finalizar." .

ns1:ModoUsuario a ns1:ModoOperacion ;
    rdfs:label "Modo Usuario" ;
    ns1:textoExtracto "Es el modo habitual de trabajo para el usuario, una vez terminada la puesta a punto." ;
    ns1:tieneComponente ns1:CarpetaUSERS .

ns1:ModoUtilidades a ns1:ModoOperacion ;
    rdfs:label "Modo Utilidades" ;
    ns1:textoExtracto "Al iniciar el equipo en este modo de trabajo, éste solicita la contraseña de acceso." .

