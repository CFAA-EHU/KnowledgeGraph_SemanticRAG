@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_43c2496f1c a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de puesta a punto sin finalizar" ;
    ns1:mitigaRiesgo ns1:AccionProhibidaSinGarantia ;
    ns1:textoExtracto "En caso de que no exista alguno de los dos, el CNC mostrará un mensaje indicando que la puesta a punto se encuentra sin finalizar." .

ns1:CNC8070_9c9f5d309c a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:ModoTrabajoUSER ;
    ns1:textoExtracto "El CNC verifica que existen passwords y la copia de seguridad." .

ns1:AccionProhibidaSinGarantia a ns1:AccionProhibida ;
    rdfs:label "Acción prohibida sin garantía" ;
    ns1:textoExtracto "En esta situación el CNC no dispone de garantía Fagor." .

ns1:ModoTrabajoUSER a ns1:ModoOperacion ;
    rdfs:label "Modo USER" ;
    ns1:textoExtracto "Modo USER (modo de trabajo). En el encendido, el CNC verifica que existen passwords y la copia de seguridad." .

