@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoOperacion_USER
    a               ex:ModoOperacion ;
    rdfs:label      "Modo USER (modo de trabajo)"@es ;
    ex:textoExtracto
        "Modo USER (modo de trabajo). En el encendido, el CNC verifica que existen passwords y la copia de seguridad. En caso de que no exista alguno de los dos, el CNC mostrará un mensaje indicando que la puesta a punto se encuentra sin finalizar."@es .

ex:AvisoSeguridad_FaltaConfiguracion
    a               ex:AvisoSeguridad ;
    rdfs:label      "Aviso de configuración incompleta"@es ;
    ex:textoExtracto
        "el CNC mostrará un mensaje indicando que la puesta a punto se encuentra sin finalizar. En esta situación el CNC no dispone de garantía Fagor."@es .

ex:InterfazUsuario_DiskMonitor
    a               ex:InterfazUsuario ;
    rdfs:label      "DiskMonitor"@es ;
    ex:textoExtracto
        "desde el modo SETUP, a través de \"DiskMonitor\" se accede directamente al modo USER."@es .

ex:ModoOperacion_SETUP
    a               ex:ModoOperacion ;
    rdfs:label      "Modo SETUP"@es ;
    ex:textoExtracto
        "desde el modo SETUP, a través de \"DiskMonitor\" se accede directamente al modo USER."@es .

ex:ModoOperacion_USER
    ex:habilitadoPor    ex:InterfazUsuario_DiskMonitor .

ex:AvisoSeguridad_FaltaConfiguracion
    ex:mitigaRiesgo     ex:ModoOperacion_USER .