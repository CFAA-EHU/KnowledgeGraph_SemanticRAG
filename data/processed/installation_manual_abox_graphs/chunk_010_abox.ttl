@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PC_Simulador_CNC_10 a ex:Maquina ;
    rdfs:label "PC (simulador)" ;
    ex:textoExtracto "El CNC se puede instalar en un PC, el cual se utilizará como simulador para aprendizaje." .

ex:CNC_Simulador_10 a ex:Maquina ;
    rdfs:label "CNC (simulador)" ;
    ex:textoExtracto "El CNC se puede instalar en un PC, el cual se utilizará como simulador para aprendizaje." .

ex:Carpeta_CNC8070_10 a ex:Componente ;
    rdfs:label "C:\\CNC8070" ;
    ex:textoExtracto "los archivos necesarios para el funcionamiento del CNC se encuentran en la carpeta C:\\CNC8070 y sus correspondientes subcarpetas." .

ex:Licencia_Local_10 a ex:ModoOperacion ;
    rdfs:label "licencia local (LOCAL)" ;
    ex:identificador "LOCAL" ;
    ex:textoExtracto "Elija licencia local si la llave hardware va a estar conectada al PC en el que se está instalando el software del CNC." .

ex:Licencia_Red_10 a ex:ModoOperacion ;
    rdfs:label "licencia de red (NET)" ;
    ex:identificador "NET" ;
    ex:textoExtracto "Elija licencia de red si la llave hardware va a estar conectada a un servidor." .

ex:Llave_Hardware_10 a ex:ComponenteElectrico ;
    rdfs:label "llave hardware" ;
    ex:textoExtracto "La llave hardware suministrada por Fagor deberá estar conectada al puerto USB del PC (si eligió la opción de licencia local) o a un servidor (si eligió la opción de licencia de red)." .

ex:Carpeta_MTB_10 a ex:Componente ;
    rdfs:label "MTB" ;
    ex:textoExtracto "el fabricante dispone de la carpeta ..\\MTB para que pueda guardar las modificaciones que realiza en el CNC, como por ejemplo, el programa PLC, los parámetros máquina, etc." .

ex:Puerto_USB_10 a ex:ComponenteElectrico ;
    rdfs:label "puerto USB" ;
    ex:textoExtracto "La llave hardware suministrada por Fagor deberá estar conectada al puerto USB del PC (si eligió la opción de licencia local)." .

ex:Servidor_Licencia_10 a ex:Maquina ;
    rdfs:label "servidor" ;
    ex:textoExtracto "Elija licencia de red si la llave hardware va a estar conectada a un servidor." .

ex:Configuracion_Software_10 a ex:Manual ;
    rdfs:label "Configuración del software" ;
    ex:textoExtracto "Ver \"1.7 Configuración del software.\" en la página 45." .