@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_b65877d723 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:CarpetaMTB ;
    ns1:monitoreaParametro ns1:CodigoDeValidacion ;
    ns1:textoExtracto "El CNC gestiona las carpetas MTB de la siguiente manera." .

ns1:CarpetaMTB a ns1:ComponenteElectrico ;
    rdfs:label "carpeta MTB" ;
    ns1:textoExtracto "El sistema moverá la carpeta correspondiente desde ..\\CONFIGURATION a CNC8070 y la renombrará como MTB." .

ns1:CodigoDeValidacion a ns1:Parametro ;
    rdfs:label "código de validación" ;
    ns1:textoExtracto "en función del código de validación, el sistema moverá la carpeta correspondiente desde ..\\CONFIGURATION a CNC8070 y la renombrará como MTB." .

