@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MTB a ex:Componente ;
    rdfs:label "MTB" ;
    ex:textoExtracto "el sistema moverá la carpeta correspondiente desde ..\\CONFIGURATION a CNC8070 y la renombrará como MTB"@es ;
    ex:textoExtracto "el sistema devolverá la carpeta MTB a la carpeta ..\\CONFIGURATION y le dará su antiguo nombre (MTB_M, MTB_T, etc)"@es ;
    ex:textoExtracto "el sistema no hará ningún cambio en el arranque ni al modificar el código de validación"@es .

ex:CNC8070 a ex:Sistema ;
    rdfs:label "CNC8070" ;
    ex:textoExtracto "el sistema moverá la carpeta correspondiente desde ..\\CONFIGURATION a CNC8070"@es ;
    ex:textoExtracto "el sistema devolverá la carpeta MTB a la carpeta ..\\CONFIGURATION y le dará su antiguo nombre (MTB_M, MTB_T, etc)"@es .

ex:CONFIGURATION a ex:Componente ;
    rdfs:label "CONFIGURATION" ;
    ex:textoExtracto "el sistema moverá la carpeta correspondiente desde ..\\CONFIGURATION a CNC8070"@es ;
    ex:textoExtracto "el sistema devolverá la carpeta MTB a la carpeta ..\\CONFIGURATION"@es .