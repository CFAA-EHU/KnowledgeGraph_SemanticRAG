@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SetupHelp_Vxx_xx_exe
    a ex:InterfazUsuario ;
    rdfs:label "SetupHelp_Vxx.xx.exe" ;
    ex:textoExtracto "Se puede cambiar el idioma de la ayuda con el programa SetupHelp_Vxx.xx.exe (donde Vxx_xx es el nombre de la versión), disponible en la zona de descargas del sitio web corporativo de Fagor Automation." ;
    ex:identificador "SetupHelp_Vxx.xx.exe" .

ex:ArchivosAyudaCNC
    a ex:Componente ;
    rdfs:label "Archivos de ayuda del CNC" ;
    ex:textoExtracto "Fagor entrega el CNC con los archivos de ayuda instalados en inglés." ;
    ex:documentadoEn ex:SetupHelp_Vxx_xx_exe .

ex:CarpetaFagorMmcHelp
    a ex:Componente ;
    rdfs:label "Carpeta ..\\Fagor\\Mmc\\Help" ;
    ex:textoExtracto "Los archivos de ayuda instalados por Fagor se encuentran en la carpeta ..\\Fagor\\Mmc\\Help." .

ex:CarpetaUsersHelp
    a ex:Componente ;
    rdfs:label "Carpeta ..\\Users\\Help" ;
    ex:textoExtracto "El programa SetupHelp_Vxx.xx.exe instala la ayuda en la carpeta ..\\Users\\Help." ;
    ex:controla ex:ArchivosAyudaCNC .