@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SetupHelp_Vxx_xx ex:textoExtracto "Se puede cambiar el idioma de la ayuda con el programa SetupHelp_Vxx.xx.exe (donde Vxx_xx es el nombre de la versión), disponible en la zona de descargas del sitio web corporativo de Fagor Automation." ;
    a ex:Herramienta ;
    ex:identificador "SetupHelp_Vxx.xx.exe" .

ex:FagorAutomation ex:textoExtracto "Fagor Automation" ;
    a ex:Empresa .

ex:CNC_Help_Language_Changer ex:textoExtracto "Archivo: CNC Help Language Changer" ;
    a ex:Herramienta ;
    ex:identificador "CNC Help Language Changer" .

ex:CNC ex:textoExtracto "Fagor entrega el CNC con los archivos de ayuda instalados en inglés. ... Cuando el CNC debe mostrar la ayuda, primero la busca en ..\\Users\\Help, y si no la encuentra, en ..\\Fagor\\Mmc\\Help." ;
    a ex:Maquina .

ex:Carpeta_Fagor_Mmc_Help ex:textoExtracto "Los archivos de ayuda instalados por Fagor se encuentran en la carpeta ..\\Fagor\\Mmc\\Help." ;
    a ex:Sistema ;
    ex:identificador "..\\Fagor\\Mmc\\Help" .

ex:Carpeta_Users_Help ex:textoExtracto "El programa SetupHelp_Vxx.xx.exe instala la ayuda en la carpeta ..\\Users\\Help." ;
    a ex:Sistema ;
    ex:identificador "..\\Users\\Help" .