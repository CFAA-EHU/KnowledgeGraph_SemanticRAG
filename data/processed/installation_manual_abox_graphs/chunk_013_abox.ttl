@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ActualizacionSoftware_1_4
    a ex:TareaMantenimiento ;
    rdfs:label "Actualización de software del CNC"@es ;
    ex:textoExtracto "Las actualizaciones se deben realizar con el software suministrado por Fagor Automation. [...] Para actualizar el software, cerrar todos los programas que estén en marcha, incluido el CNC. [...] Introduzca el pendrive de Fagor en el puerto USB y ejecute el programa setup8070_Vxx_xx_xx.exe"@es ;
    ex:requiereMantenimiento ex:CNC_FagorAutomation ;
    ex:ejecutadoPor ex:PersonalTecnico .

ex:CNC_FagorAutomation
    a ex:Maquina ;
    rdfs:label "CNC (Fagor Automation)"@es ;
    ex:textoExtracto "Actualización del software. Para actualizar el software, cerrar todos los programas que estén en marcha, incluido el CNC. [...] Al comenzar el proceso, el CNC ofrece la posibilidad de realizar la instalación partiendo de cero"@es ;
    ex:tieneComponente ex:BusCAN_CNC ;
    ex:tieneComponente ex:NodosRemotos_BusCAN ;
    ex:tieneComponente ex:InterfazUSB_CNC .

ex:BusCAN_CNC
    a ex:Sistema ;
    rdfs:label "Bus CAN del CNC"@es ;
    ex:textoExtracto "Actualización de los nodos remotos del bus CAN. En cada arranque del CNC se verifica la compatibilidad de las versiones de los nodos remotos detectados en el bus CAN"@es ;
    ex:compuestoPor ex:NodosRemotos_BusCAN .

ex:NodosRemotos_BusCAN
    a ex:ComponenteElectrico ;
    rdfs:label "Nodos remotos del bus CAN"@es ;
    ex:textoExtracto "se procederá automáticamente a actualizar todos estos dispositivos en caso de ser necesario. [...] Si la carga no se completa con éxito, y por tanto no se puede garantizar la coherencia de software entre todos los elementos del bus CAN"@es .

ex:InterfazUSB_CNC
    a ex:InterfazUsuario ;
    rdfs:label "Puerto USB del CNC"@es ;
    ex:textoExtracto "Introduzca el pendrive de Fagor en el puerto USB y ejecute el programa setup8070_Vxx_xx_xx.exe"@es .

ex:SoftwareSetup_8070
    a ex:Componente ;
    rdfs:label "Software de actualización setup8070_Vxx_xx_xx.exe"@es ;
    ex:identificador "setup8070_Vxx_xx_xx.exe" ;
    ex:textoExtracto "ejecute el programa setup8070_Vxx_xx_xx.exe (donde Vxx_xx_xx es el nombre de la versión)"@es .

ex:CopiaSeguridadConfiguracion
    a ex:TareaMantenimiento ;
    rdfs:label "Copia de seguridad de configuración del CNC"@es ;
    ex:textoExtracto "Se recomienda tener siempre una copia de seguridad de toda la configuración (ficheros ASCII), a saber las tablas de parámetros máquina, de herramientas, de herramientas activas y del almacén, así como el programa PLC"@es ;
    ex:documentadoEn ex:ManualCNC .

ex:ParametrosMaquina
    a ex:Parametro ;
    rdfs:label "Parámetros máquina del CNC"@es ;
    ex:textoExtracto "se mantiene la configuración de los parámetros máquina [...] las tablas de parámetros máquina"@es .

ex:ProgramaPLC_CNC
    a ex:Componente ;
    rdfs:label "Programa PLC del CNC"@es ;
    ex:textoExtracto "se mantiene la configuración de los [...] programa PLC [...] copia de seguridad de [...] el programa PLC"@es .

ex:PersonalTecnico
    a ex:Personal ;
    rdfs:label "Personal técnico"@es ;
    ex:textoExtracto "Antes de actualizar el software, consulte la lista de posibles incompatibilidades"@es .

ex:ManualCNC
    a ex:Manual ;
    rdfs:label "Manual del CNC (Sección 1.4.1)"@es ;
    ex:identificador "1.4.1" ;
    ex:textoExtracto "Ver '1.4.1 Actualización del software desde versiones anteriores.' en la página 38"@es .