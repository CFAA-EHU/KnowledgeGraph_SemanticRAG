@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceiteHidraulicoISO46 a ns1:Consumible ;
    rdfs:label "copias de seguridad de la configuración (ficheros ASCII)" ;
    ns1:textoExtracto "Se recomienda tener siempre una copia de seguridad de toda la configuración (ficheros ASCII), a saber las tablas de parámetros máquina, de herramientas, de herramientas activas y del almacén, así como el programa PLC." .

ns1:ActualizarLaVersionDeSoftware a ns1:TareaMantenimiento ;
    rdfs:label "Actualizar la versión de software" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "Las actualizaciones se deben realizar con el software suministrado por Fagor Automation." .

ns1:CNC8070_8b1a52752c a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Para actualizar el software, cerrar todos los programas que estén en marcha, incluido el CNC." .

ns1:ConfiguracionDeLosParametrosMaquina a ns1:Parametro ;
    rdfs:label "Configuración de los parámetros máquina" ;
    ns1:textoExtracto "se mantiene la configuración de los parámetros máquina, programa PLC, tablas de herramientas y datos del almacén." .

ns1:ProgramaPLC a ns1:Parametro ;
    rdfs:label "programa PLC" ;
    ns1:textoExtracto "programa PLC" .

ns1:TablaHerramientas a ns1:Tabla ;
    rdfs:label "Tablas de herramientas" ;
    ns1:textoExtracto "tablas de herramientas" .

ns1:PersonalTecnicoAutorizado a ns1:Personal ;
    rdfs:label "Personal Técnico Autorizado" ;
    ns1:textoExtracto "Se recomienda tener siempre una copia de seguridad de toda la configuración (ficheros ASCII)" .

