@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ErrorIncoherenciaSoftwareBusCAN
    a               ex:AvisoSeguridad ;
    rdfs:label      "Error de incoherencia de software en bus CAN"@es ;
    ex:textoExtracto
        "no se completa con éxito, y por tanto no se puede garantizar la coherencia de software entre todos los elementos del bus CAN, se visualizará el error correspondiente en el CNC cada vez que se pulse la tecla [RESET]."@es .

ex:InterfazUsuarioCNC
    a               ex:InterfazUsuario ;
    rdfs:label      "Interfaz CNC"@es ;
    ex:textoExtracto
        "se visualizará el error correspondiente en el CNC cada vez que se pulse la tecla [RESET]"@es ;
    ex:activaAlarma  ex:ErrorIncoherenciaSoftwareBusCAN .

ex:TeclaReset
    a               ex:ComponenteElectrico ;
    rdfs:label      "Tecla [RESET]"@es ;
    ex:textoExtracto
        "cada vez que se pulse la tecla [RESET]"@es .