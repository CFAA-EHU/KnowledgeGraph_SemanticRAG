@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TablaHerramientasAlmacenV2_00 a ex:Tabla ;
    rdfs:label "Tabla de herramientas y almacén" ;
    ex:textoExtracto "Tabla de herramientas y almacén" ;
    ex:identificador "V2.00" .

ex:SoftkeySalvar a ex:InterfazUsuario ;
    rdfs:label "Softkey 'Salvar'" ;
    ex:textoExtracto "mediante las softkeys 'Salvar' y 'Cargar'" .

ex:SoftkeyCargar a ex:InterfazUsuario ;
    rdfs:label "Softkey 'Cargar'" ;
    ex:textoExtracto "mediante las softkeys 'Salvar' y 'Cargar'" .

ex:CodigoValidacionV1_1x a ex:Parametro ;
    rdfs:label "Código de validación V1.1x" ;
    ex:textoExtracto "Tras actualizar el software desde una versión V1.1x o anterior deja de ser válido el código de validación de esa versión" .

ex:MarcaSERVOSON a ex:Parametro ;
    rdfs:label "marca SERVOSON" ;
    ex:textoExtracto "en la maniobra del PLC se debe contemplar la habilitación de la marca SERVOSON con las funciones M19, roscado rígido y cuando se active la marca ENABLES" .

ex:MarcaENABLES a ex:Parametro ;
    rdfs:label "marca ENABLES" ;
    ex:textoExtracto "en la maniobra del PLC se debe contemplar la habilitación de la marca SERVOSON con las funciones M19, roscado rígido y cuando se active la marca ENABLES" .

ex:IconoSentidoGiroHerramienta a ex:InterfazUsuario ;
    rdfs:label "icono que define el sentido de giro de la herramienta" ;
    ex:textoExtracto "El CNC hace caso al icono que define el sentido de giro de la herramienta" .

ex:ParametroABSOFF a ex:Parametro ;
    rdfs:label "parámetro ABSOFF" ;
    ex:textoExtracto "el CNC enviaba al regulador el valor del parámetro ABSOFF" ;
    ex:valor "PP177/PP178" .

ex:ReguladorI0sCodificados a ex:ComponenteElectrico ;
    rdfs:label "sistema con I0s codificados" ;
    ex:textoExtracto "cuando el sistema disponía de I0s codificados" .

ex:ReguladorCaptacionAbsoluta a ex:ComponenteElectrico ;
    rdfs:label "sistema con captación absoluta" ;
    ex:textoExtracto "cuando el sistema dispone de captación absoluta" .