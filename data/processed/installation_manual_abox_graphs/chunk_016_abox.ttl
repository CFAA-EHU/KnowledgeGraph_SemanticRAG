@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_d1e66e6005 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:CabezalPrincipal ;
    ns1:parametroMonitoradoPor ns1:Parametro_ca5c0fb658 ;
    ns1:textoExtracto "Habilitación del cabezal. Tras el encendido, al ejecutar cualquier operación sobre el cabezal, el CNC realiza una búsqueda de referencia del mismo." .

ns1:CabezalPrincipal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal Principal" ;
    ns1:textoExtracto "Habilitación del cabezal. Tras el encendido, al ejecutar cualquier operación sobre el cabezal, el CNC realiza una búsqueda de referencia del mismo." .

ns1:Parametro_ca5c0fb658 a ns1:Parametro ;
    rdfs:label "Parámetro ABSOFF" ;
    ns1:identificador "ABSOFF" ;
    ns1:textoExtracto "En versiones anteriores, el CNC enviaba al regulador el valor del parámetro ABSOFF sólo cuando el sistema disponía de I0s codificados." .

