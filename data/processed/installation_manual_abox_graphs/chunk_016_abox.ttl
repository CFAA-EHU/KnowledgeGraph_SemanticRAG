@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_ABSOFF a ex:Parametro ;
    rdfs:label "ABSOFF" ;
    ex:textoExtracto "el valor del parámetro ABSOFF" ;
    ex:textoExtracto "poner en el parámetro ABSOFF el valor que tiene el regulador en PP177 ó" .

ex:Parametro_PP177 a ex:Parametro ;
    rdfs:label "PP177" ;
    ex:textoExtracto "el regulador (PP177/PP178)" ;
    ex:textoExtracto "el valor que tiene el regulador en PP177 ó" .

ex:Parametro_PP178 a ex:Parametro ;
    rdfs:label "PP178" ;
    ex:textoExtracto "el regulador (PP177/PP178)" .

ex:CNC a ex:Componente ;
    rdfs:label "CNC" ;
    ex:textoExtracto "el CNC enviaba al regulador" ;
    ex:textoExtracto "el CNC también envía" .

ex:Regulador a ex:Componente ;
    rdfs:label "regulador" ;
    ex:textoExtracto "al regulador" ;
    ex:textoExtracto "el regulador (PP177/PP178)" ;
    ex:textoExtracto "el valor que tiene el regulador en PP177 ó" .

ex:Sistema_CaptacionAbsoluta a ex:Sistema ;
    rdfs:label "sistema con captación absoluta" ;
    ex:textoExtracto "el sistema disponía de I0s codificados" ;
    ex:textoExtracto "el sistema dispone de captación absoluta" ;
    ex:textoExtracto "en máquinas con captación absoluta" .

ex:Version_V3_15 a ex:ModoOperacion ;
    rdfs:label "V3.15" ;
    ex:textoExtracto "A partir de la versión V3.15" .