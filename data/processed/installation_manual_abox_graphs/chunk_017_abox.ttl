@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_d898f9e6cd a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:ValorDelParametroABSOFF,
        ns1:ValorDelParametroPP177,
        ns1:ValorDelParametroPP178 ;
    ns1:textoExtracto "A partir de esta versión, el CNC también envía el valor del parámetro ABSOFF al regulador (PP177/PP178) cuando el sistema dispone de captación absoluta." .

ns1:Regulador a ns1:ComponenteElectrico ;
    rdfs:label "Regulador" ;
    ns1:textoExtracto "En versiones anteriores, el CNC enviaba al regulador el valor del parámetro ABSOFF sólo cuando el sistema disponía de I0s codificados." .

ns1:ValorDelParametroABSOFF a ns1:Parametro ;
    rdfs:label "Valor del parámetro ABSOFF" ;
    ns1:textoExtracto "En versiones anteriores, el CNC enviaba al regulador el valor del parámetro ABSOFF sólo cuando el sistema disponía de I0s codificados." .

ns1:ValorDelParametroPP177 a ns1:Parametro ;
    rdfs:label "Valor del parámetro PP177" ;
    ns1:textoExtracto "A partir de esta versión, el CNC también envía el valor del parámetro ABSOFF al regulador (PP177/PP178) cuando el sistema dispone de captación absoluta." .

ns1:ValorDelParametroPP178 a ns1:Parametro ;
    rdfs:label "Valor del parámetro PP178" ;
    ns1:textoExtracto "A partir de esta versión, el CNC también envía el valor del parámetro ABSOFF al regulador (PP177/PP178) cuando el sistema dispone de captación absoluta." .

