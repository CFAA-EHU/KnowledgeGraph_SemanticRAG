ns1:CNC8070_2a22369fb7 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "En la nueva carpeta CONFIGURATION, el CNC dispone de una carpeta MTB diferente para cada tipo de software instalado; MTB_T para el torno y MTB_M para fresadora." ;
    ns1:tieneComponente ns1:Parametro_18b4e21bce,
        ns1:Parametro_ca5c0fb658,
        ns1:Parametro_d8f139c9a2 .

ns1:Parametro_18b4e21bce a ns1:Parametro ;
    rdfs:label "Parámetro PP178" ;
    ns1:identificador "PP178" ;
    ns1:textoExtracto "A partir de la versión V3.15, al actualizar una versión anterior en máquinas con captación absoluta, hay que poner en el parámetro ABSOFF el valor que tiene el regulador en PP177 ó PP178." .

ns1:Parametro_ca5c0fb658 a ns1:Parametro ;
    rdfs:label "Parámetro ABSOFF" ;
    ns1:identificador "ABSOFF" ;
    ns1:textoExtracto "A partir de la versión V3.15, al actualizar una versión anterior en máquinas con captación absoluta, hay que poner en el parámetro ABSOFF el valor que tiene el regulador en PP177 ó PP178." .

ns1:Parametro_d8f139c9a2 a ns1:Parametro ;
