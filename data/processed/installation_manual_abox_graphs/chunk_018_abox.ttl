@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ProgramaFormatoUnicode a ex:Parametro ;
    rdfs:label "Programa en formato Unicode" ;
    ex:textoExtracto "Los programas en formato Unicode no son compatibles con versiones anteriores a la versión V4.0. Un programa en formato Unicode no podrá ser editado ni ejecutado en una versión anterior a la V4.0." .

ex:VersionSoftwareV4_0 a ex:ModoOperacion ;
    rdfs:label "Versión V4.0" ;
    ex:identificador "V4.0" ;
    ex:textoExtracto "versión V4.0" .

ex:EditorCNC a ex:InterfazUsuario ;
    rdfs:label "Editor del CNC" ;
    ex:textoExtracto "El editor del CNC admite caracteres Unicode." .

ex:FormatoANSI a ex:Parametro ;
    rdfs:label "Formato ANSI" ;
    ex:textoExtracto "convertir programas en formato Unicode a formato ANSI" .

ex:BlocDeNotasWindows a ex:Herramienta ;
    rdfs:label "Bloc de notas de Windows" ;
    ex:textoExtracto "puede utilizar un editor de texto de terceros (por ejemplo, el Bloc de notas de Windows)" .

ex:EditorTextoTerceros a ex:Herramienta ;
    rdfs:label "Editor de texto de terceros" ;
    ex:textoExtracto "utilizar un editor de texto de terceros" .