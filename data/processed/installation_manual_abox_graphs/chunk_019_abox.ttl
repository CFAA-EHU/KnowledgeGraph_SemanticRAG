@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_734f13790c a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Ejes Sercos. Durante la actualización desde una versión V3.00 o posterior, el CNC mostrará un error E9332 por cada eje Sercos con captación externa." .

ns1:CambiarCodigoDeValidacion a ns1:AccionProhibida ;
    rdfs:label "Cambiar código de validación" ;
    ns1:textoExtracto "En este caso, si al cambiar el código de validación cambia el tipo de máquina, el CNC no moverá la carpeta MTB." .

ns1:ErrorE9332 a ns1:AvisoSeguridad ;
    rdfs:label "Error E9332" ;
    ns1:textoExtracto "Durante la actualización desde una versión V3.00 o posterior, el CNC mostrará un error E9332 por cada eje Sercos con captación externa." .

ns1:IdentificadorDeContador a ns1:Parametro ;
    rdfs:label "Identificador de contador" ;
    ns1:identificador "COUNTERID" ;
    ns1:textoExtracto "Este error indica que los valores de los parámetros COUNTERTYPE y COUNTERID son incompatibles." .

ns1:TipoDeContador a ns1:Parametro ;
    rdfs:label "Tipo de contador" ;
    ns1:identificador "COUNTERTYPE" ;
    ns1:textoExtracto "Para corregir el error, cambiar el valor del parámetro COUNTERTYPE de 'remoto' a 'regulador' en los ejes implicados." .

