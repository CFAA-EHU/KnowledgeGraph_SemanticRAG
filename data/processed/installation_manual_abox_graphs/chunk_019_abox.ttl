@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:V4_0 ex:textoExtracto """a la V4.0.""" .
ex:V4_02 ex:textoExtracto """Versión V4.02.""" .
ex:ParametroNKEYBD ex:textoExtracto """el parámetro NKEYBD""" .
ex:ValorPorDefectoNKEYBD ex:textoExtracto """valor por defecto""" .
ex:ValorNKEYBD1 ex:textoExtracto """valor 1""" .
ex:PrimerTeclado ex:textoExtracto """el primer teclado (el de numeración más baja según el conmutador Address)""" .

ex:V4_0 a ex:ModoOperacion ;
    ex:identificador "V4.0" .

ex:V4_02 a ex:ModoOperacion ;
    ex:identificador "V4.02" .

ex:ParametroNKEYBD a ex:Parametro ;
    ex:textoExtracto """el parámetro NKEYBD""" .

ex:ValorPorDefectoNKEYBD a ex:Parametro ;
    ex:textoExtracto """valor por defecto""" ;
    ex:valor "1" .

ex:ValorNKEYBD1 a ex:Parametro ;
    ex:textoExtracto """valor 1""" ;
    ex:valor "1" .

ex:PrimerTeclado a ex:Componente ;
    ex:textoExtracto """el primer teclado (el de numeración más baja según el conmutador Address)""" .