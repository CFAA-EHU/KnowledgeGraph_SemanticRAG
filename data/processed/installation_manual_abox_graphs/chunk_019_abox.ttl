@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:VersionSoftware_V4.0
    a ex:Sistema ;
    rdfs:label "Versión V4.0"@es ;
    ex:textoExtracto "a la V4.0. Para convertir programas en formato Unicode a formato ANSI puede utilizar un editor de texto de terceros (por ejemplo, el Bloc de notas de Windows), pero al realizar esta operación, los caracteres especiales sin equivalente en formato ANSI se perderán."@es ;
    ex:identificador "V4.0" .

ex:VersionSoftware_V4.02
    a ex:Sistema ;
    rdfs:label "Versión V4.02"@es ;
    ex:textoExtracto "Versión V4.02. Máquina con varios teclados. A partir de la versión V4.02, al actualizar una versión anterior en máquinas con varios teclados, hay que configurarlos de la siguiente manera."@es ;
    ex:identificador "V4.02" .

ex:Parametro_NKEYBD
    a ex:Parametro ;
    rdfs:label "Parámetro NKEYBD"@es ;
    ex:textoExtracto "el CNC define el parámetro NKEYBD con valor 1 (valor por defecto) y sólo habilita el primer teclado"@es ;
    ex:identificador "NKEYBD" ;
    ex:valor "1" .

ex:InterfazUsuario_TecladosMultiples
    a ex:InterfazUsuario ;
    rdfs:label "Configuración de teclados múltiples"@es ;
    ex:textoExtracto "al actualizar una versión anterior en máquinas con varios teclados, hay que configurarlos de la siguiente manera. Si no se configuran los teclados, el CNC define el parámetro NKEYBD con valor 1 (valor por defecto) y sólo habilita el primer teclado (el de numeración más baja según el conmutador Address)."@es ;
    ex:controla ex:Parametro_NKEYBD .