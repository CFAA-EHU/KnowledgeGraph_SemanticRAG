@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ParametrosJog a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de paneles de jog"@es ;
    ex:textoExtracto "Parámetro | Valor | Significado\nNKEYBD | 2 | Número de paneles de jog\nKEYBD1CH | Canal activo | Canal al que está asignado el primer panel de jog\nKEYBD2CH | Canal activo | Canal al que está asignado el segundo panel de jog"@es ;
    ex:tieneComponente ex:Parametro_NKEYBD, ex:Parametro_KEYBD1CH, ex:Parametro_KEYBD2CH .

ex:Parametro_NKEYBD
    a ex:Parametro ;
    rdfs:label "NKEYBD"@es ;
    ex:identificador "NKEYBD" ;
    ex:valor "2" ;
    ex:textoExtracto "NKEYBD | 2 | Número de paneles de jog"@es ;
    ex:documentadoEn ex:Tabla_ParametrosJog .

ex:Parametro_KEYBD1CH
    a ex:Parametro ;
    rdfs:label "KEYBD1CH"@es ;
    ex:identificador "KEYBD1CH" ;
    ex:valor "Canal activo"@es ;
    ex:textoExtracto "KEYBD1CH | Canal activo | Canal al que está asignado el primer panel de jog"@es ;
    ex:documentadoEn ex:Tabla_ParametrosJog .

ex:Parametro_KEYBD2CH
    a ex:Parametro ;
    rdfs:label "KEYBD2CH"@es ;
    ex:identificador "KEYBD2CH" ;
    ex:valor "Canal activo"@es ;
    ex:textoExtracto "KEYBD2CH | Canal activo | Canal al que está asignado el segundo panel de jog"@es ;
    ex:documentadoEn ex:Tabla_ParametrosJog .