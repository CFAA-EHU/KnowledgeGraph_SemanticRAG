@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Parametro_NKEYBD a ex:Parametro ;
    ex:identificador "NKEYBD" ;
    ex:valor "2" ;
    ex:textoExtracto "NKEYBD | 2 | Número de paneles de jog." .

ex:Parametro_KEYBD1CH a ex:Parametro ;
    ex:identificador "KEYBD1CH" ;
    ex:textoExtracto "KEYBD1CH | Canal activo. | Canal al que está asignado el primer panel de jog." .

ex:Parametro_KEYBD2CH a ex:Parametro ;
    ex:identificador "KEYBD2CH" ;
    ex:textoExtracto "KEYBD2CH | Canal activo. | Canal al que está asignado el segundo panel de jog." .