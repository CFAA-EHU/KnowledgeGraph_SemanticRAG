@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_21f00c83d7 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Si no se configuran los teclados, el CNC define el parámetro NKEYBD con valor 1 (valor por defecto) y sólo habilita el primer teclado." .

ns1:NumeroDeTecladosConfigurados a ns1:Parametro ;
    rdfs:label "Número de teclados configurados" ;
    ns1:identificador "NKEYBD" ;
    ns1:textoExtracto "Si no se configuran los teclados, el CNC define el parámetro NKEYBD con valor 1 (valor por defecto)" ;
    ns1:valor "1" .

