@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_G00COMP a ex:Parametro ;
    rdfs:label "G00COMP" ;
    ex:textoExtracto "mediante el parámetro G00COMP" .

ex:Version_V5_40 a ex:ModoOperacion ;
    rdfs:label "V5.40" ;
    ex:textoExtracto "Versión V5.40" .

ex:OpcionSoftware_CANopenTerceros a ex:ModoOperacion ;
    rdfs:label "CANopen de terceros" ;
    ex:textoExtracto "Nueva opción de software \"CANopen de terceros\"" .