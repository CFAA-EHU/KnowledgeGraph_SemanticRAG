    ex:textoExtracto "Nueva opción de software \"CANopen de terceros\"." .

ex:OpcionSoftware_Palpador
    a ex:ModoOperacion ;
    rdfs:label "Palpador" ;
    ex:textoExtracto "La opción de software \"Ciclos fijos de palpador\" pasa a llamarse \"Palpador\"." ;
