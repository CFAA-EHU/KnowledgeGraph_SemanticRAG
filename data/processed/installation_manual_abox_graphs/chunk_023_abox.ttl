ex:Parametro_G00COMP
    a ex:Parametro ;
    rdfs:label "G00COMP" ;
    ex:textoExtracto "posteriores mediante el parámetro G00COMP. Versión V5.40." .

ex:Parametro_LONGAXIS
    a ex:Parametro ;
    rdfs:label "LONGAXIS" ;
    ex:textoExtracto "el eje longitudinal (parámetro LONGAXIS)" .

ex:Parametro_FACEAXIS
