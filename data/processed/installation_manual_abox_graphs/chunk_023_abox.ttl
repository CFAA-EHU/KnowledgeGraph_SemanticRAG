@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_e076f6d593 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:ManualActualizacionSoftware ;
    ns1:textoExtracto "Versión V4.25. Cambio de unidades en el parámetro máquina FTIMELIM, relacionado con el mecanizado en HSC." .

ns1:CompensacionDeRadioEnG00 a ns1:Parametro ;
    rdfs:label "Compensación de radio en G00" ;
    ns1:identificador "G00COMP" ;
    ns1:textoExtracto "Ésto se corrige en versiones posteriores mediante el parámetro G00COMP." .

ns1:LimiteDeTiempoParaMecanizadoEnHSC a ns1:Parametro ;
    rdfs:label "Límite de tiempo para mecanizado en HSC" ;
    ns1:identificador "FTIMELIM" ;
    ns1:textoExtracto "En versiones previas el parámetro FTIMELIM se programaba en milisegundos. A partir de este versión, este parámetro se define en porcentaje." .

ns1:ManualActualizacionSoftware a ns1:DocumentoTecnico ;
    rdfs:label "Manual de actualización del software" ;
    ns1:textoExtracto "La versión se debe actualizar en modo administrador, no en modo setup como se hace habitualmente, para poder registrar de forma permanente las nuevas librerías." .

