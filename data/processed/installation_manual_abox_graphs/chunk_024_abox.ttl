@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_IconosOrientacionHerramienta a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de iconos de orientación de herramienta (páginas 38-42)"@es ;
    ex:textoExtracto """
| Icono. | Significado. |
| --- | --- |
|  | El CNC orienta la herramienta según el primer eje definido como FACEAXIS. |
|  | El CNC orienta la herramienta según el primer eje definido como LONGAXIS. |
"""@es ;
    ex:ilustradoEn ex:Manual_Brochado .

ex:InterfazUsuario_OrientacionFACEAXIS
    a ex:InterfazUsuario ;
    rdfs:label "Indicador de orientación FACEAXIS"@es ;
    ex:textoExtracto "El CNC orienta la herramienta según el primer eje definido como FACEAXIS."@es ;
    ex:documentadoEn ex:Tabla_IconosOrientacionHerramienta .

ex:InterfazUsuario_OrientacionLONGAXIS
    a ex:InterfazUsuario ;
    rdfs:label "Indicador de orientación LONGAXIS"@es ;
    ex:textoExtracto "El CNC orienta la herramienta según el primer eje definido como LONGAXIS."@es ;
    ex:documentadoEn ex:Tabla_IconosOrientacionHerramienta .