@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoOperacion_FACEAXIS a ex:ModoOperacion ;
    rdfs:label "FACEAXIS" ;
    ex:textoExtracto "El CNC orienta la herramienta según el primer eje definido como FACEAXIS." .

ex:ModoOperacion_LONGAXIS a ex:ModoOperacion ;
    rdfs:label "LONGAXIS" ;
    ex:textoExtracto "El CNC orienta la herramienta según el primer eje definido como LONGAXIS." .