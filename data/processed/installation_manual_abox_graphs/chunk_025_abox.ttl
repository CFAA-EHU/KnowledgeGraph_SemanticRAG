@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ArchivoXCA_25_1 a ex:ComponenteElectrico ;
    rdfs:label "archivos xca" ;
    ex:textoExtracto "Archivos xca. El CNC dispone de una nueva versión de gráficos HD, que incorporan el nuevo FCAS (control de colisiones) y que utilizan la versión 2 de archivos xca." .

ex:ArchivoXCA_25_2 a ex:ComponenteElectrico ;
    rdfs:label "archivos xca por defecto" ;
    ex:textoExtracto "Si son los archivos xca por defecto, sólo hay que copiar los nuevos a su ubicación dentro ..\\Fagor\\Grafdata\\Machines." .

ex:ArchivoXCA_25_3 a ex:ComponenteElectrico ;
    rdfs:label "archivos xca personalizados" ;
    ex:textoExtracto "Si son archivos xca personalizados y adaptados a la máquina, hay que realizar las siguientes modificaciones." .

ex:SistemaCNC_25 a ex:Maquina ;
    rdfs:label "CNC" ;
    ex:textoExtracto "El CNC dispone de una nueva versión de gráficos HD, que incorporan el nuevo FCAS (control de colisiones) y que utilizan la versión 2 de archivos xca." .

ex:FCAS_25 a ex:Sistema ;
    rdfs:label "FCAS" ;
    ex:textoExtracto "El CNC dispone de una nueva versión de gráficos HD, que incorporan el nuevo FCAS (control de colisiones)." .