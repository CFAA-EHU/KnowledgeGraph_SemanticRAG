@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_c522e48efb a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:OpcionSoftwareCANopenTerceros,
        ns1:OpcionSoftwarePalpador ;
    ns1:monitoreaParametro ns1:CompensacionDeDesplazamientoRapido,
        ns1:EjeLongitudinal_af6cf7d0c2,
        ns1:EjeTransversal ;
    ns1:textoExtracto "A partir de esta versión, si una máquina estuviera usando algún módulo CANopen no Fagor, el CNC no lo reconocerá, y durante la inicialización del bus CAN dará el error correspondiente." .

ns1:CompensacionDeDesplazamientoRapido a ns1:Parametro ;
    rdfs:label "Compensación de desplazamiento rápido" ;
    ns1:identificador "G00COMP" ;
    ns1:textoExtracto "posteriores mediante el parámetro G00COMP." .

ns1:EjeLongitudinal_af6cf7d0c2 a ns1:Parametro ;
    rdfs:label "Eje longitudinal" ;
    ns1:identificador "LONGAXIS" ;
    ns1:textoExtracto "los ciclos fijos asociados a los ejes rotativos necesitan que esté definido el eje longitudinal (parámetro LONGAXIS)" .

ns1:EjeTransversal a ns1:Parametro ;
    rdfs:label "Eje transversal" ;
    ns1:identificador "FACEAXIS" ;
    ns1:textoExtracto "y el eje transversal (parámetro FACEAXIS)." .

ns1:OpcionSoftwareCANopenTerceros a ns1:Directiva ;
    rdfs:label "CANopen de terceros" ;
    ns1:textoExtracto "Nueva opción de software \"CANopen de terceros\"." .

ns1:OpcionSoftwarePalpador a ns1:Directiva ;
    rdfs:label "Palpador" ;
    ns1:textoExtracto "La opción de software \"Ciclos fijos de palpador\" pasa a llamarse \"Palpador\"." .

