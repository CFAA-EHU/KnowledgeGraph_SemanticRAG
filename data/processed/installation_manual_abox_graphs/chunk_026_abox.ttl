@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SYS_Tool1 a ex:ComponenteElectrico ;
    ex:textoExtracto "Sustituir: <ReferenceObject name=\"SYS-Tool1\"/> Por: <ToolVice name=\"SYS-Tool1\" spindle=\"S1\"/>" .

ex:SYS_Tool2 a ex:ComponenteElectrico ;
    ex:textoExtracto "Sustituir: <ReferenceObject name=\"SYS-Tool2\"/> Por: <ToolVice name=\"SYS-Tool2\" spindle=\"S2\"/>" .

ex:SYS_Tool3 a ex:ComponenteElectrico ;
    ex:textoExtracto "Sustituir: <ReferenceObject name=\"SYS-Tool3\"/> Por: <ToolVice name=\"SYS-Tool3\" spindle=\"S3\"/>" .

ex:SYS_Tool4 a ex:ComponenteElectrico ;
    ex:textoExtracto "Sustituir: <ReferenceObject name=\"SYS-Tool4\"/> Por: <ToolVice name=\"SYS-Tool4\" spindle=\"S4\"/>" .

ex:VERSION_2 a ex:Componente ;
    ex:textoExtracto "Entre: <ComponentSet> y: <GeometryObject name=\"NO_MACHINE\"> Incluir: <GeometryObject name=\"VERSION_2\"> </GeometryObject>" .

ex:SYS_Tool1_Connection_C1 a ex:ComponenteElectrico ;
    ex:textoExtracto "Sustituir: <Connection plug=\"stdPlug@S1\" socket=\"stdSocket@C1\"/> ... Por: <Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@C1\" rotation=\"0 1 0 -90\"/>" .

ex:SYS_Tool1_Connection_C2 a ex:ComponenteElectrico ;
    ex:textoExtracto "Sustituir: <Connection plug=\"stdPlug@S1\" socket=\"stdSocket@C2\"/> ... Por: <Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@C2\" rotation=\"0 1 0 -90\"/>" .

ex:SYS_Tool1_Connection_C3 a ex:ComponenteElectrico ;
    ex:textoExtracto "Sustituir: <Connection plug=\"stdPlug@S1\" socket=\"stdSocket@C3\"/> ... Por: <Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@C3\" rotation=\"0 1 0 -90\"/>" .