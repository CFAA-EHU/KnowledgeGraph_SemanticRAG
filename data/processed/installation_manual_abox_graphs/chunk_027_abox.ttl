@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_FACEAXIS
    a ex:Parametro ;
    rdfs:label "FACEAXIS" ;
    ex:textoExtracto "el parámetro FACEAXIS define si la herramienta está orientada según los ejes definidos en FACEAXIS y LONGAXIS." ;
    ex:monitoreaParametro ex:Sistema_GraficosHD .

ex:Parametro_LONGAXIS
    a ex:Parametro ;
    rdfs:label "LONGAXIS" ;
    ex:textoExtracto "el parámetro FIXORI define si la herramienta está orientada según los ejes definidos en FACEAXIS y LONGAXIS." ;
    ex:monitoreaParametro ex:Sistema_GraficosHD .

ex:Parametro_FIXORI
    a ex:Parametro ;
    rdfs:label "FIXORI" ;
    ex:textoExtracto "el parámetro FIXORI define si la herramienta está orientada según los ejes definidos en FACEAXIS y LONGAXIS." ;
    ex:monitoreaParametro ex:Sistema_GraficosHD .

ex:Parametro_GAPCTRL
    a ex:Parametro ;
    rdfs:label "#GAPCTRL" ;
    ex:textoExtracto "Para programar la cota de aproximación en coordenadas incrementales, añadir el comando \"INC\" a la sentencia #GAPCTRL." ;
    ex:valor "INC" ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Sistema_GraficosHD
    a ex:Sistema ;
    rdfs:label "Sistema de gráficos HD" ;
    ex:textoExtracto "A partir de esta versión, los gráficos actúan de la siguiente manera. • Si los gráficos HD trabajan con las cotas de la punta de la herramienta, hacen caso a los parámetros FACEAXIS y LONGAXIS. • Si los gráficos HD trabajan con las cotas de la base de la herramienta, no hacen caso a los parámetros FACEAXIS y LONGAXIS." .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "A partir de la versión v6.20, el CNC siempre considera la cota de aproximación en coordenadas absolutas, independientemente de la función G90/G91 activa." ;
    ex:controla ex:Parametro_GAPCTRL .

ex:ComponenteElectrico_ControlFCombo
    a ex:ComponenteElectrico ;
    rdfs:label "FCombo.ocx" ;
    ex:identificador "FCombo.ocx" ;
    ex:textoExtracto "Hay que instalar la esta versión en modo administrador, para que el proceso registre correctamente el nuevo control FCombo.ocx." ;
    ex:tieneComponente ex:Sistema_CNC .

ex:Esquema_ModelizadoMaquina
    a ex:Esquema ;
    rdfs:label "Esquema modelizado de la máquina" ;
    ex:identificador "*.xca" ;
    ex:textoExtracto "En archivo *.def que acompaña al esquema modelizado de la máquina (archivo xca) define si los gráficos trabajan con cotas de la base o de la punta de la herramienta." ;
    ex:detalladoEnEsquema ex:Sistema_GraficosHD .

ex:Manual_VersionSoftware
    a ex:Manual ;
    rdfs:label "Manual de actualización de software" ;
    ex:textoExtracto "Versión V6.01.03. [...] Versión V6.21.12. Instalación del software." ;
    ex:documentadoEn ex:Sistema_CNC ;
    ex:documentadoEn ex:Sistema_GraficosHD .