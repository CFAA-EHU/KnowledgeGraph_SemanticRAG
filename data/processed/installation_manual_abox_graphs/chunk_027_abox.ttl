@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArchivoXCA a ns1:ComponenteElectrico ;
    rdfs:label "Archivos XCA" ;
    ns1:esComponenteDe ns1:CNC8070_bb60dabd60 ;
    ns1:textoExtracto "al actualizar la versión del CNC, es necesario instalar/actualizar los archivos xca que definen la configuración de la máquina." .

ns1:TareaMantenimiento_5186de1c8e a ns1:TareaMantenimiento ;
    rdfs:label "Tarea de Actualización de Archivos XCA" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "En una actualización de la versión (opciones 1 o 2 del instalador), hay que copiar manualmente los nuevos archivos xca." .

ns1:CNC8070_bb60dabd60 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC dispone de una nueva versión de gráficos HD, que incorporan el nuevo FCAS (control de colisiones) y que utilizan la versión 2 de archivos xca." .

ns1:PersonalTecnicoAutorizado a ns1:Personal ;
    rdfs:label "Personal Técnico Autorizado" ;
    ns1:textoExtracto "hay que copiar manualmente los nuevos archivos xca." .

