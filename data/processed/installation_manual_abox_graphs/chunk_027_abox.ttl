@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:stdPlug_S3 a ex:ComponenteElectrico ;
    ex:textoExtracto "plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@S3\"" .

ex:stdSocket_S3 a ex:ComponenteElectrico ;
    ex:textoExtracto "socket=\"stdSocket@S3\"" .

ex:stdPlug_S4 a ex:ComponenteElectrico ;
    ex:textoExtracto "plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@S4\"" .

ex:stdSocket_S4 a ex:ComponenteElectrico ;
    ex:textoExtracto "socket=\"stdSocket@S4\"" .

ex:stdPlug_C3 a ex:ComponenteElectrico ;
    ex:textoExtracto "socket=\"stdSocket@C3\"" .

ex:stdPlug_C4 a ex:ComponenteElectrico ;
    ex:textoExtracto "plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@C4\"" .

ex:stdSocket_C4 a ex:ComponenteElectrico ;
    ex:textoExtracto "socket=\"stdSocket@C4\"" .

ex:Parametro_FACEAXIS a ex:Parametro ;
    ex:textoExtracto "parámetros FACEAXIS y LONGAXIS" .

ex:Parametro_LONGAXIS a ex:Parametro ;
    ex:textoExtracto "parámetros FACEAXIS y LONGAXIS" .

ex:Parametro_FIXORI a ex:Parametro ;
    ex:textoExtracto "el parámetro FIXORI define si la herramienta está orientada según los ejes definidos en FACEAXIS y LONGAXIS" .

ex:Parametro_GAPCTRL a ex:Parametro ;
    ex:textoExtracto "añadir el comando \"INC\" a la sentencia #GAPCTRL" .

ex:Control_FCombo_ocx a ex:ComponenteElectrico ;
    ex:textoExtracto "registre correctamente el nuevo control FCombo.ocx" .

ex:Esquema_modelizado a ex:Esquema ;
    ex:textoExtracto "archivo *.def que acompaña al esquema modelizado de la máquina (archivo xca)" .