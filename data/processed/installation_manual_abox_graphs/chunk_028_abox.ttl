@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArchivoXCA a ns1:ComponenteElectrico ;
    rdfs:label "Archivo XCA" ;
    ns1:textoExtracto "Si son los archivos xca por defecto, sólo hay que copiar los nuevos a su ubicación dentro de ..\\Fagor\\Grafdata\\Machines." .

ns1:CNC8070_4ce9829127 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:TablaActualizacionSoftware ;
    ns1:textoExtracto "Si son archivos xca personalizados y adaptados a la máquina, hay que realizar las siguientes modificaciones." .

ns1:TablaActualizacionSoftware a ns1:Tabla ;
    rdfs:label "Tabla de Actualización del Software" ;
    ns1:textoExtracto "Sustituir: <ReferenceObject name=\"SYS-Tool1\"/> Por: <ToolVice name=\"SYS-Tool1\" spindle=\"S1\"/>" .

