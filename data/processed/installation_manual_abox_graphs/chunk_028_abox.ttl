@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Comando_INC
    a ex:Parametro ;
    rdfs:label "Comando INC" ;
    ex:textoExtracto "añadir el comando \"INC\" a la sentencia #GAPCTRL" ;
    ex:identificador "INC" .

ex:Comando_INCPOS
    a ex:Parametro ;
    rdfs:label "Comando INCPOS" ;
    ex:textoExtracto "utilizar el comando \"INCPOS\"" ;
    ex:identificador "INCPOS" .

ex:Comando_POS
    a ex:Parametro ;
    rdfs:label "Comando POS" ;
    ex:textoExtracto "el CNC siempre considera la cota programada en el comando \"POS\" en coordenadas absolutas" ;
    ex:identificador "POS" .

ex:Sentencia_GAPCTRL
    a ex:Parametro ;
    rdfs:label "Sentencia #GAPCTRL" ;
    ex:textoExtracto "sentencia #GAPCTRL" ;
    ex:identificador "#GAPCTRL" .

ex:CNC_Leapfrog
    a ex:Sistema ;
    rdfs:label "CNC Leapfrog" ;
    ex:textoExtracto "Leapfrog. A partir de la versión v6.20" ;
    ex:identificador "v6.20" .

ex:Version_v6.20
    a ex:Parametro ;
    rdfs:label "Versión v6.20" ;
    ex:textoExtracto "A partir de la versión v6.20" ;
    ex:identificador "v6.20" ;
    ex:documentadoEn ex:CNC_Leapfrog .