@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Comando_INC a ex:Parametro ;
    rdfs:label "INC" ;
    ex:textoExtracto "añadir el comando \"INC\" a la sentencia #GAPCTRL" ;
    ex:valor "INC" .

ex:Sentencia_GAPCTRL a ex:ComponenteElectrico ;
    rdfs:label "#GAPCTRL" ;
    ex:textoExtracto "sentencia #GAPCTRL" .

ex:Comando_POS a ex:Parametro ;
    rdfs:label "POS" ;
    ex:textoExtracto "comando \"POS\" en coordenadas absolutas" ;
    ex:valor "POS" .

ex:Comando_INCPOS a ex:Parametro ;
    rdfs:label "INCPOS" ;
    ex:textoExtracto "comando \"INCPOS\"" ;
    ex:valor "INCPOS" .

ex:Version_v6_20 a ex:Parametro ;
    rdfs:label "v6.20" ;
    ex:textoExtracto "A partir de la versión v6.20" ;
    ex:valor "v6.20" .

ex:Comando_G90 a ex:Parametro ;
    rdfs:label "G90" ;
    ex:textoExtracto "comando G90/G91" ;
    ex:valor "G90" .

ex:Comando_G91 a ex:Parametro ;
    rdfs:label "G91" ;
    ex:textoExtracto "comando G90/G91" ;
    ex:valor "G91" .

ex:Sistema_CNC a ex:Maquina ;
    rdfs:label "CNC" ;
    ex:textoExtracto "el CNC siempre considera la cota programada" .