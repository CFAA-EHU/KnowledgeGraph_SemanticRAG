@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_f4594b1b48 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "A partir de la versión v6.20, el CNC siempre considera la cota programada en el comando \"POS\" en coordenadas absolutas, independientemente del comando G90/G91." ;
    ns1:tieneComponente ns1:DefineLaCotaDeAproximacionEnCoordenadasIncrementales,
        ns1:DefineSiLaHerramientaEstaOrientadaSegunLosEjesDefinidosEnFACEAXISYLONGAXIS,
        ns1:DefineSiLosGraficosTrabajanConCotasDeLaBaseODeLaPuntaDeLaHerramienta .

ns1:DefineLaCotaDeAproximacionEnCoordenadasIncrementales a ns1:Parametro ;
    rdfs:label "Define la cota de aproximación en coordenadas incrementales" ;
    ns1:textoExtracto "Para programar la cota de aproximación en coordenadas incrementales, añadir el comando \"INC\" a la sentencia #GAPCTRL." .

ns1:DefineSiLaHerramientaEstaOrientadaSegunLosEjesDefinidosEnFACEAXISYLONGAXIS a ns1:Parametro ;
    rdfs:label "Define si la herramienta está orientada según los ejes definidos en FACEAXIS y LONGAXIS" ;
    ns1:textoExtracto "el parámetro FIXORI define si la herramienta está orientada según los ejes definidos en FACEAXIS y LONGAXIS." .

ns1:DefineSiLosGraficosTrabajanConCotasDeLaBaseODeLaPuntaDeLaHerramienta a ns1:Parametro ;
    rdfs:label "Define si los gráficos trabajan con cotas de la base o de la punta de la herramienta" ;
    ns1:textoExtracto "En archivo *.def que acompaña al esquema modelizado de la máquina (archivo xca) define si los gráficos trabajan con cotas de la base o de la punta de la herramienta." .

