@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_8a55c5b0fb a ns1:Parametro ;
    rdfs:label "Comando para programar la cota al final del salto en coordenadas incrementales" ;
    ns1:identificador "INCPOS" ;
    ns1:textoExtracto "Para programar la cota al final del salto en coordenadas incrementales, utilizar el comando \"INCPOS\"." .

ns1:Parametro_df297c19cc a ns1:Parametro ;
    rdfs:label "Comando para programar la cota en coordenadas absolutas" ;
    ns1:identificador "POS" ;
    ns1:textoExtracto "el CNC siempre considera la cota programada en el comando \"POS\" en coordenadas absolutas." .

ns1:SentenciaParaControlDeGap a ns1:Parametro ;
    rdfs:label "Sentencia para control de gap" ;
    ns1:identificador "GAPCTRL" ;
    ns1:textoExtracto "añadir el comando \"INC\" a la sentencia #GAPCTRL." .

