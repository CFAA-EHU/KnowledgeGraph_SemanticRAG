@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:PCIndustrial_31_44 a ex:Maquina ;
    ex:textoExtracto "El CNC que usted ha adquirido se trata de un PC industrial equipado con sistema operativo Windows XP Embedded o Windows 7" .

ex:SistemaOperativoWindowsXPEmbedded_31_44 a ex:Componente ;
    ex:textoExtracto "sistema operativo Windows XP Embedded" .

ex:SistemaOperativoWindows7_31_44 a ex:Componente ;
    ex:textoExtracto "sistema operativo Windows 7" .

ex:ModoAdministrador_31_44 a ex:ModoOperacion ;
    ex:textoExtracto "acceso al modo administrador" .

ex:CodigoValidacion_31_44 a ex:Parametro ;
    ex:textoExtracto "el acceso al modo administrador se habilita con el código de validación" .

ex:ContraseñaParametrosMaquina_31_44 a ex:Parametro ;
    ex:textoExtracto "la contraseña 'parámetros máquina', definida en el modo utilidades" .

ex:ContraseñaAdministratorMode_31_44 a ex:Parametro ;
    ex:textoExtracto "la contraseña 'Administrator mode', definida en el modo utilidades" .

ex:DirectorioCNC8070USERS_31_44 a ex:Componente ;
    ex:textoExtracto "guardarse en un directorio desprotegido, por ejemplo CNC8070\\USERS" .

ex:CompactFlash_31_44 a ex:Componente ;
    ex:textoExtracto "puede disponer de compact flash únicamente o de compact flash más disco duro" .

ex:DiscoDuro_31_44 a ex:Componente ;
    ex:textoExtracto "puede disponer de compact flash más disco duro" .

ex:SistemaSinDiscoProtegido_31_44 a ex:Sistema ;
    ex:textoExtracto "En un sistema sin disco protegido, el acceso al modo administrador está protegido mediante la contraseña 'parámetros máquina'" .

ex:SistemaConDiscoProtegido_31_44 a ex:Sistema ;
    ex:textoExtracto "En un sistema con disco protegido, el acceso al modo administrador está protegido mediante la contraseña 'Administrator mode'" .