@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoDiagnostico_CNC8070
    a               ex:ModoOperacion ;
    rdfs:label      "Modo diagnosis del CNC"@es ;
    ex:textoExtracto
                    "Esta información la puede consultar dentro del **modo diagnosis** del CNC."@es ;
    ex:monitoreaParametro
                    ex:Parametro_RecursosSistema_CNC8070 .

ex:Parametro_RecursosSistema_CNC8070
    a               ex:Parametro ;
    rdfs:label      "Recursos del sistema (CPU, memoria, disco)"@es ;
    ex:textoExtracto
                    "compruebe que el CNC cumple con los requisitos que requiere el software, tanto en **CPU como en memoria** [...] verifique el **espacio libre en el disco**"@es .

ex:InterfazUsuario_CNC8070
    a               ex:InterfazUsuario ;
    rdfs:label      "Interfaz de usuario del CNC8070"@es ;
    ex:textoExtracto
                    "verifique [...] que el **refresco de pantallas** [...] es el correcto."@es ;
    ex:monitoreaParametro
                    ex:Parametro_RecursosSistema_CNC8070 .

ex:Sistema_CNC8070
    a               ex:Sistema ;
    rdfs:label      "Sistema CNC8070"@es ;
    ex:identificador "CNC8070" ;
    ex:textoExtracto
                    "el **CNC** (dependiendo de la configuración de la máquina) puede consumir entre un 50% y un 60% de sus recursos disponibles."@es ;
    ex:tieneComponente
                    ex:InterfazUsuario_CNC8070 ;
    ex:controla     ex:ModoDiagnostico_CNC8070 .