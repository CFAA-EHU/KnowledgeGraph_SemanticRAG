@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_057e5042d4 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:mitigaRiesgo ns1:AvisoSeguridad_36bca6ac32 ;
    ns1:textoExtracto "Si se selecciona el apagado normal y el CNC detecta que se ha modificado la configuración de la máquina, avisará de esta circunstancia y preguntará si se desea guardar una copia de seguridad de la configuración de la máquina." .

ns1:GuardarCopiaDeSeguridadDeLaConfiguracionDeLaMaquina a ns1:TareaMantenimiento ;
    rdfs:label "Guardar copia de seguridad de la configuración de la máquina" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "guardar una copia de seguridad de la configuración de la máquina, el directorio MTB, a un archivo comprimido." .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    rdfs:label "Máquina Brochadora Electromecánica Exterior A218" ;
    ns1:textoExtracto "guardar una copia de seguridad de la configuración de la máquina, el directorio MTB, a un archivo comprimido." .

ns1:AvisoSeguridad_36bca6ac32 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de modificación de configuración" ;
    ns1:textoExtracto "avisará de esta circunstancia y preguntará si se desea guardar una copia de seguridad de la configuración de la máquina." .

