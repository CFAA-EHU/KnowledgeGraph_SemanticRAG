@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SistemaDiagnosisCNC a ex:ModoOperacion ;
    ex:textoExtracto "Esta información la puede consultar dentro del modo diagnosis del CNC." .

ex:RecursoSistemaCNC a ex:Parametro ;
    ex:textoExtracto "Recuerde que el equipo, el sistema operativo y el CNC (dependiendo de la configuración de la máquina) pueden consumir entre un 50% y un 60% de sus recursos disponibles." ;
    ex:valor "50%-60%" .

ex:DirectorioUsuariosCNC a ex:Sistema ;
    ex:identificador "CNC8070\\USERS" ;
    ex:textoExtracto "por ejemplo CNC8070\\USERS" .

ex:RecursoCPU a ex:Parametro ;
    ex:textoExtracto "compruebe que el CNC cumple con los requisitos que requiere el software, tanto en CPU como en memoria" .

ex:RecursoMemoria a ex:Parametro ;
    ex:textoExtracto "compruebe que el CNC cumple con los requisitos que requiere el software, tanto en CPU como en memoria" .

ex:RecursoDisco a ex:Parametro ;
    ex:textoExtracto "Verifique igualmente que el espacio libre en el disco es suficiente para su aplicación." .

ex:RecursoPantalla a ex:Parametro ;
    ex:textoExtracto "verifique el estado de los recursos del sistema y compruebe que el funcionamiento del CNC, refresco de pantallas, etc es el correcto." .