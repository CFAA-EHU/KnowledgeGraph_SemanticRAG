@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_64288c542a a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Requisitos del sistema. Antes de instalar el software, compruebe que el CNC cumple con los requisitos que requiere el software, tanto en CPU como en memoria." .

ns1:VerificarEstadoDeRecursosDelSistema a ns1:TareaMantenimiento ;
    rdfs:label "Verificar estado de recursos del sistema" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "Una vez instalado el software, con el CNC arrancado y en funcionamiento, verifique el estado de los recursos del sistema y compruebe que el funcionamiento del CNC, refresco de pantallas, etc es el correcto." .

ns1:PersonalTecnicoAutorizado a ns1:Personal ;
    rdfs:label "Personal Técnico Autorizado" ;
    ns1:textoExtracto "Una vez instalado el software, con el CNC arrancado y en funcionamiento, verifique el estado de los recursos del sistema y compruebe que el funcionamiento del CNC, refresco de pantallas, etc es el correcto." .

