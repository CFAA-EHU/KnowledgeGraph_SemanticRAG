@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:USERS a ex:InterfazUsuario ;
    rdfs:label "USERS" ;
    ex:textoExtracto "Carpeta para el usuario. Esta carpeta está especialmente dirigida al usuario. El propósito de esta carpeta es proporcionar al usuario un espacio en el que pueda guardar ordenadamente los programas pieza, perfiles, etc que vaya generando." ;
    ex:textoExtracto "El CNC borra el contenido de la carpeta TMP cada vez que arranca. No utilice esta carpeta para guardar archivos que desee conservar." .

ex:TMP a ex:InterfazUsuario ;
    rdfs:label "TMP" ;
    ex:textoExtracto "El CNC borra el contenido de la carpeta TMP cada vez que arranca. No utilice esta carpeta para guardar archivos que desee conservar." .