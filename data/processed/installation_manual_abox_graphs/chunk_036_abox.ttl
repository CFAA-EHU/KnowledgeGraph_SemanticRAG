@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_75ac3871e7 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Esta carpeta contiene el software correspondiente a la versión del CNC instalada." .

ns1:CarpetaBACKUPSDIR a ns1:Componente ;
    rdfs:label "BACKUPSDIR" ;
    ns1:textoExtracto "Backup de las instalaciones previas. Cada vez que el usuario instala una versión nueva completa, el instalador guarda en esta carpeta una copia de la instalación anterior." .

ns1:CarpetaCONFIGURATION a ns1:Componente ;
    rdfs:label "CONFIGURATION" ;
    ns1:textoExtracto "Esta carpeta contiene las diferentes carpetas MTB del sistema; MTB_T para el torno y MTB_M para fresadora. En el arranque del sistema, y en función del código de validación, el sistema moverá la carpeta correspondiente de CONFIGURATION a MTB." .

ns1:CarpetaDIAGNOSIS a ns1:Componente ;
    rdfs:label "DIAGNOSIS" ;
    ns1:textoExtracto "Esta carpeta contiene la información relevante para un correcto diagnóstico de los errores, incluido el archivo reportfagor.zip." .

ns1:CarpetaDRIVERS a ns1:Componente ;
    rdfs:label "DRIVERS" ;
    ns1:textoExtracto "Esta carpeta contiene algunos drivers necesarios para el correcto funcionamiento del CNC." .

ns1:CarpetaFAGOR a ns1:Componente ;
    rdfs:label "FAGOR" ;
    ns1:textoExtracto "Esta carpeta contiene el software correspondiente a la versión del CNC instalada. Las actualizaciones de software se realizan en este directorio, no afectando al contenido de los directorios MTB y USERS." .

ns1:CarpetaMTB a ns1:Componente ;
    rdfs:label "MTB" ;
    ns1:textoExtracto "Esta carpeta está especialmente dirigida al fabricante de la máquina. Esta carpeta contiene las modificaciones que realiza el fabricante en el CNC, como por ejemplo, el programa PLC, los parámetros máquina, nuevas pantallas, incorporación de aplicaciones externas, etc." .

ns1:CarpetaTMP a ns1:Componente ;
    rdfs:label "TMP" ;
    ns1:textoExtracto "El CNC utiliza esta carpeta para guardar los archivos temporales que genera durante su funcionamiento. El CNC borra el contenido de esta carpeta cada vez que arranca." .

ns1:CarpetaUSERS a ns1:Componente ;
    rdfs:label "USERS" ;
    ns1:textoExtracto "Esta carpeta está especialmente dirigida al usuario. El propósito de esta carpeta es proporcionar al usuario un espacio en el que pueda guardar archivos y programas personalizados." .

