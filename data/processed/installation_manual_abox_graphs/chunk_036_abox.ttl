@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:CarpetaMTB_46
    a               ex:Sistema ;
    rdfs:label      "Carpeta MTB (Machine Tool Builder)"@es ;
    ex:textoExtracto
        "Esta carpeta está especialmente dirigida al fabricante de la máquina. Esta carpeta contiene las modificaciones que realiza el fabricante en el CNC, como por ejemplo, el programa PLC, los parámetros máquina, nuevas pantallas, incorporación de aplicaciones externas, etc."@es ;
    ex:identificador "1.7.1" .

ex:ProgramaPLC_46
    a               ex:ComponenteElectrico ;
    rdfs:label      "Programa PLC"@es ;
    ex:textoExtracto "el programa PLC"@es ;
    ex:documentadoEn ex:CarpetaMTB_46 .

ex:ParametrosMaquina_46
    a               ex:Parametro ;
    rdfs:label      "Parámetros máquina"@es ;
    ex:textoExtracto "los parámetros máquina"@es ;
    ex:documentadoEn ex:CarpetaMTB_46 .

ex:PantallasHMI_46
    a               ex:InterfazUsuario ;
    rdfs:label      "Nuevas pantallas"@es ;
    ex:textoExtracto "nuevas pantallas"@es ;
    ex:documentadoEn ex:CarpetaMTB_46 .

ex:AplicacionesExternas_46
    a               ex:Sistema ;
    rdfs:label      "Aplicaciones externas"@es ;
    ex:textoExtracto "incorporación de aplicaciones externas"@es ;
    ex:documentadoEn ex:CarpetaMTB_46 .