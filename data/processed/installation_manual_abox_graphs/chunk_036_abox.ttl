@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ManualMTB a ex:Manual ;
    ex:textoExtracto "Esta carpeta está especialmente dirigida al fabricante de la máquina. Esta carpeta contiene las modificaciones que realiza el fabricante en el CNC, como por ejemplo, el programa PLC, los parámetros máquina, nuevas pantallas, incorporación de aplicaciones externas, etc." ;
    rdfs:label "Manual MTB (Machine Tool Builder)" .

ex:CarpetaMTB a ex:Manual ;
    ex:textoExtracto "Esta carpeta está especialmente dirigida al fabricante de la máquina. Esta carpeta contiene las modificaciones que realiza el fabricante en el CNC, como por ejemplo, el programa PLC, los parámetros máquina, nuevas pantallas, incorporación de aplicaciones externas, etc." ;
    rdfs:label "Carpeta MTB (Machine Tool Builder)" ;
    ex:compuestoPor ex:ProgramaPLC, ex:ParametrosMaquina, ex:PantallasAdicionales, ex:AplicacionesExternas .

ex:ProgramaPLC a ex:ComponenteElectrico ;
    ex:textoExtracto "el programa PLC" ;
    rdfs:label "Programa PLC" .

ex:ParametrosMaquina a ex:Parametro ;
    ex:textoExtracto "los parámetros máquina" ;
    rdfs:label "Parámetros máquina" .

ex:PantallasAdicionales a ex:InterfazUsuario ;
    ex:textoExtracto "nuevas pantallas" ;
    rdfs:label "Pantallas adicionales" .

ex:AplicacionesExternas a ex:Componente ;
    ex:textoExtracto "incorporación de aplicaciones externas" ;
    rdfs:label "Aplicaciones externas" .