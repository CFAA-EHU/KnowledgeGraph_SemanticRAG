@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_ebd4e4dcf3 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC borra el contenido de la carpeta TMP cada vez que arranca." ;
    ns1:tieneComponente ns1:CarpetaUsuario .

ns1:CarpetaUsuario a ns1:Componente ;
    rdfs:label "Carpeta para el usuario" ;
    ns1:textoExtracto "Esta carpeta está especialmente dirigida al usuario. El propósito de esta carpeta es proporcionar al usuario un espacio en el que pueda guardar ordenadamente los programas pieza, perfiles, etc que vaya generando." .

