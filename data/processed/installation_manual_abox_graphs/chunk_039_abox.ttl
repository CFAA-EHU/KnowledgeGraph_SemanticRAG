@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:CarpetaMTB
    a ex:Sistema ;
    rdfs:label "Carpeta MTB (Machine Tool Builder)" ;
    ex:textoExtracto "1.7.1 Carpeta MTB (Machine Tool Builder)." ;
    ex:compuestoPor ex:SubcarpetaPROJECT, ex:SubcarpetaWATCH, ex:SubcarpetaRELEASE, ex:SubcarpetaSUB, ex:SubcarpetaTUNING .

ex:SubcarpetaPROJECT
    a ex:Sistema ;
    rdfs:label "Subcarpeta PROJECT" ;
    ex:textoExtracto "La subcarpeta ..\\PROJECT contiene los archivos que forman el proyecto PLC y el fichero objeto." .

ex:SubcarpetaWATCH
    a ex:Sistema ;
    rdfs:label "Subcarpeta WATCH" ;
    ex:textoExtracto "La subcarpeta ..\\WATCH contiene los datos guardados desde los servicios monitorización y analizador lógico." .

ex:SubcarpetaRELEASE
    a ex:Sistema ;
    rdfs:label "Subcarpeta RELEASE" ;
    ex:textoExtracto "Esta carpeta contiene los componentes (archivos ocx) utilizados por el fabricante para crear su propia aplicación." .

ex:SubcarpetaSUB
    a ex:Sistema ;
    rdfs:label "Subcarpeta SUB" ;
    ex:textoExtracto "Esta carpeta contiene los siguientes archivos o subcarpetas: Las subrutinas del fabricante (cambio de herramienta, búsqueda de cero, etc)." ;
    ex:compuestoPor ex:SubrutinasFabricante, ex:SubcarpetaHELP .

ex:SubrutinasFabricante
    a ex:InterfazUsuario ;
    rdfs:label "Subrutinas del fabricante" ;
    ex:textoExtracto "Las subrutinas del fabricante (cambio de herramienta, búsqueda de cero, etc)." .

ex:SubcarpetaHELP
    a ex:Sistema ;
    rdfs:label "Subcarpeta HELP" ;
    ex:textoExtracto "En cada idioma de la subcarpeta ..\\HELP están los archivos de ayuda asociados a las subrutinas del fabricante y el archivo pcall.txt que contiene la lista de subrutinas del fabricante." .

ex:SubcarpetaTUNING
    a ex:Sistema ;
    rdfs:label "Subcarpeta TUNING" ;
    ex:textoExtracto "Esta carpeta contiene la información referente a las ayudas a la puesta a punto." .