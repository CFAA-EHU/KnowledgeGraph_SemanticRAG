@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Carpeta_USERS
    a ex:InterfazUsuario ;
    rdfs:label "Carpeta USERS"@es ;
    ex:textoExtracto "Esta carpeta está especialmente dirigida al usuario. El propósito de esta carpeta es proporcionar al usuario un espacio en el que pueda guardar ordenadamente los programas pieza, perfiles, etc que vaya generando."@es ;
    ex:tieneComponente ex:Carpeta_HELP, ex:Carpeta_POCKET, ex:Carpeta_PRG, ex:Carpeta_PROFILE, ex:Carpeta_REPORTS, ex:Carpeta_SUB .

ex:Carpeta_HELP
    a ex:InterfazUsuario ;
    rdfs:label "Carpeta HELP"@es ;
    ex:textoExtracto "En cada idioma de la subcarpeta ..\\HELP están los archivos de ayuda asociados a las subrutinas globales definidas por el usuario y el archivo pcall.txt que contiene la lista de subrutinas del usuario."@es .

ex:Carpeta_POCKET
    a ex:InterfazUsuario ;
    rdfs:label "Carpeta POCKET"@es ;
    ex:textoExtracto "Esta carpeta contiene los perfiles creados mediante el editor de perfiles, asociados a los ciclos del editor."@es .

ex:Carpeta_PRG
    a ex:InterfazUsuario ;
    rdfs:label "Carpeta PRG"@es ;
    ex:textoExtracto "Esta carpeta contiene los programas pieza creados por el usuario, que podrá crear nuevas subcarpetas y guardar así los programas de una forma más ordenada. La subcarpeta ..\\PRG_8055_TO_8070 contiene los programas traducidos al lenguaje 8070, que proceden de archivos en formato 8055."@es ;
    ex:tieneComponente ex:Subcarpeta_PRG_8055_TO_8070 .

ex:Subcarpeta_PRG_8055_TO_8070
    a ex:InterfazUsuario ;
    rdfs:label "Subcarpeta PRG_8055_TO_8070"@es ;
    ex:textoExtracto "La subcarpeta ..\\PRG_8055_TO_8070 contiene los programas traducidos al lenguaje 8070, que proceden de archivos en formato 8055. El CNC guarda el programa traducido con el mismo nombre pero con la extensión m55 (programa de fresadora) ó t55 (programa de torno)."@es ;
    ex:identificador "m55", "t55" .

ex:Carpeta_PROFILE
    a ex:InterfazUsuario ;
    rdfs:label "Carpeta PROFILE"@es ;
    ex:textoExtracto "Esta carpeta contiene los perfiles creados mediante el editor de perfiles."@es .

ex:Carpeta_REPORTS
    a ex:InterfazUsuario ;
    rdfs:label "Carpeta REPORTS"@es ;
    ex:textoExtracto "Esta carpeta contiene los archivos (formato bmp) que genera el CNC cuando imprime un gráfico a un archivo y los informes (formato prn) generados desde el modo diagnosis."@es ;
    ex:identificador "bmp", "prn" .

ex:Carpeta_SUB
    a ex:InterfazUsuario ;
    rdfs:label "Carpeta SUB"@es ;
    ex:textoExtracto "Esta carpeta contiene las subrutinas creadas por el usuario, cuya ubicación debe ser fija para el CNC (por ejemplo, las subrutinas genéricas de usuario G500-G599 y la subrutina program_start)."@es ;
    ex:identificador "G500-G599", "program_start" .