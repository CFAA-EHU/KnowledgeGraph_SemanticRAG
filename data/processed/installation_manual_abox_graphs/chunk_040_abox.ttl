@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_8e83cffb28 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Cuando cambia el lenguaje del CNC, éste reemplaza este archivo por el del lenguaje correspondiente." .

ns1:CarpetaPLC a ns1:Componente ;
    rdfs:label "Carpeta PLC" ;
    ns1:textoExtracto "Esta carpeta contiene la información referente al PLC." .

ns1:SubcarpetaLANG a ns1:Componente ;
    rdfs:label "Subcarpeta LANG" ;
    ns1:textoExtracto "En cada idioma de la subcarpeta ..\\LANG están los mensajes y errores del PLC en los distintos idiomas." .

ns1:SubcarpetaPROJECT a ns1:Componente ;
    rdfs:label "Subcarpeta PROJECT" ;
    ns1:textoExtracto "La subcarpeta ..\\PROJECT contiene los archivos que forman el proyecto PLC y el fichero objeto." .

ns1:SubcarpetaWATCH a ns1:Componente ;
    rdfs:label "Subcarpeta WATCH" ;
    ns1:textoExtracto "La subcarpeta ..\\WATCH contiene los datos guardados desde los" .

