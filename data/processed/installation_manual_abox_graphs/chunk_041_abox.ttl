@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Capitulo41 a ex:Capitulo ;
    rdfs:label "Capítulo"@es ;
    ex:textoExtracto "Este capítulo recoge el significado de todos los parámetros máquina del CNC."@es .

ex:ParametroMaquinaCNC a ex:Parametro ;
    rdfs:label "Parámetro máquina del CNC"@es ;
    ex:textoExtracto "parámetros máquina del CNC"@es .

ex:ModeloCNC a ex:Maquina ;
    rdfs:label "CNC"@es ;
    ex:textoExtracto "modelo de CNC"@es .

ex:ParametroEje a ex:Parametro ;
    rdfs:label "Parámetro de eje"@es ;
    ex:textoExtracto "número de ejes"@es .

ex:ParametroAvance a ex:Parametro ;
    rdfs:label "Parámetro de avance"@es ;
    ex:textoExtracto "avances"@es .

ex:ParametroAceleracion a ex:Parametro ;
    rdfs:label "Parámetro de aceleración"@es ;
    ex:textoExtracto "aceleraciones"@es .

ex:ParametroCaptacion a ex:Parametro ;
    rdfs:label "Parámetro de captación"@es ;
    ex:textoExtracto "captaciones"@es .

ex:ParametroAlmacen a ex:Parametro ;
    rdfs:label "Parámetro de almacén"@es ;
    ex:textoExtracto "tipo de almacén"@es .

ex:ParametroCambiadorHerramienta a ex:Parametro ;
    rdfs:label "Parámetro de cambiador de herramientas"@es ;
    ex:textoExtracto "cambiador de herramientas"@es .

ex:FabricanteMaquina a ex:Empresa ;
    rdfs:label "Fabricante de la máquina"@es ;
    ex:textoExtracto "fabricante de la máquina"@es .

ex:ParametroMaquinaGrupo a ex:Parametro ;
    rdfs:label "Grupo de parámetros máquina"@es ;
    ex:textoExtracto "Los parámetros máquina del CNC están agrupados de la siguiente manera."@es .