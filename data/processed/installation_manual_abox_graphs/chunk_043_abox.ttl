@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_5a5a3b62ec a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:monitoreaParametro ns1:NumeroDeEjes_70cd6d1efd,
        ns1:Parametro_6b2c7338a5,
        ns1:TipoDeAlmacen_29529db65e ;
    ns1:textoExtracto "El CNC muestra los parámetros apropiados en función del modelo y las opciones de software activas." .

ns1:EsquemaParametrosMaquina a ns1:Esquema ;
    rdfs:label "Parámetros Máquina" ;
    ns1:textoExtracto "Este capítulo recoge el significado de todos los parámetros máquina del CNC. Algunos parámetros dependen del modelo de CNC y otros son comunes a ambos." .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    rdfs:label "Máquina-herramienta" ;
    ns1:textoExtracto "Para que la máquina-herramienta pueda ejecutar correctamente las instrucciones programadas, así como interpretar los elementos que tiene interconectados, el CNC debe conocer los datos específicos de la máquina." ;
    ns1:tieneComponente ns1:CambiadorHerramientas .

ns1:CambiadorHerramientas a ns1:ComponenteMecanico ;
    rdfs:label "Cambiador de herramientas" ;
    ns1:textoExtracto "Algunos de estos datos pueden ser el número de ejes, avances, aceleraciones, captaciones, tipo de almacén, cambiador de herramientas, etc." .

ns1:NumeroDeEjes_70cd6d1efd a ns1:Parametro ;
    rdfs:label "Número de ejes" ;
    ns1:textoExtracto "Algunos de estos datos pueden ser el número de ejes, avances, aceleraciones, captaciones, tipo de almacén, cambiador de herramientas, etc." .

ns1:Parametro_6b2c7338a5 a ns1:Parametro ;
    rdfs:label "Aceleración",
        "Avance",
        "Captación" ;
    ns1:textoExtracto "Algunos de estos datos pueden ser el número de ejes, avances, aceleraciones, captaciones, tipo de almacén, cambiador de herramientas, etc." .

ns1:TipoDeAlmacen_29529db65e a ns1:Parametro ;
    rdfs:label "Tipo de almacén" ;
    ns1:textoExtracto "Algunos de estos datos pueden ser el número de ejes, avances, aceleraciones, captaciones, tipo de almacén, cambiador de herramientas, etc." .

