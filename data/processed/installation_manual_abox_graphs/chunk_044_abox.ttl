@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ParametroListaOpciones a ex:Parametro ;
    rdfs:label "Icono: parámetro con lista de opciones" ;
    ex:textoExtracto "El parámetro posee una lista de opciones." .

ex:ParametroTablaDatos a ex:Parametro ;
    rdfs:label "Icono: parámetro que accede a una tabla de datos" ;
    ex:textoExtracto "Accede a una tabla de datos." .

ex:ParametroGrupoParametros a ex:Parametro ;
    rdfs:label "Icono: parámetro que accede a un grupo de parámetros" ;
    ex:textoExtracto "Accede a un grupo de parámetros." .

ex:ParametroArchivo a ex:Parametro ;
    rdfs:label "Icono: parámetro que hace referencia a un archivo" ;
    ex:textoExtracto "El parámetro hace referencia a un archivo." .

ex:SimuladorCNC a ex:Sistema ;
    rdfs:label "Simulador CNC en PC" ;
    ex:textoExtracto "Cuando el CNC se instala como simulador en un PC, el valor por defecto de algunos parámetros máquina puede ser diferente a los aquí mencionados." .

ex:ParametroAvanceMaximoEjes a ex:Parametro ;
    rdfs:label "Parámetro: avance máximo de ejes" ;
    ex:textoExtracto "Básicamente los cambios se refieren a los avances máximos de ejes, aceleraciones y jerk." .

ex:ParametroAceleracion a ex:Parametro ;
    rdfs:label "Parámetro: aceleraciones" ;
    ex:textoExtracto "Básicamente los cambios se refieren a los avances máximos de ejes, aceleraciones y jerk." .

ex:ParametroJerk a ex:Parametro ;
    rdfs:label "Parámetro: jerk" ;
    ex:textoExtracto "Básicamente los cambios se refieren a los avances máximos de ejes, aceleraciones y jerk." .

ex:ParametroDatosPalpador a ex:Parametro ;
    rdfs:label "Parámetro: datos del palpador" ;
    ex:textoExtracto "También se modifican los datos del palpador para poder disponer, en el modo manual, de los ciclos de centrado de pieza y calibración de herramienta." .

ex:ModoManual a ex:ModoOperacion ;
    rdfs:label "Modo manual" ;
    ex:textoExtracto "para poder disponer, en el modo manual, de los ciclos de centrado de pieza y calibración de herramienta." .

ex:TablaParametrosMaquina a ex:Tabla ;
    rdfs:label "Tabla de parámetros máquina" ;
    ex:textoExtracto "Valor por defecto de los parámetros en un simulador." .