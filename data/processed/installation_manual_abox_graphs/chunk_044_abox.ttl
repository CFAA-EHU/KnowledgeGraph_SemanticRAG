@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ParametrosDeEjesYCabezales a ns1:Parametro ;
    rdfs:label "Parámetros de ejes y cabezales" ;
    ns1:textoExtracto "Estos parámetros indican las propiedades de los ejes y cabezales, límites de recorrido, condiciones de desplazamiento, volantes asociados, trabajo con palpador, compensaciones, etc." .

ns1:ParametrosDelModoManual a ns1:Parametro ;
    rdfs:label "Parámetros del modo manual" ;
    ns1:textoExtracto "Parámetros del modo manual." .

ns1:ParametrosGenerales a ns1:Parametro ;
    rdfs:label "Parámetros generales" ;
    ns1:textoExtracto "Estos parámetros definen el nombre de los ejes y cabezales, condiciones tras el encendido, rutinas asociadas a determinadas funciones, etc." .

