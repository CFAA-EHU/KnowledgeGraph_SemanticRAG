@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SistemaHomogeneizacionParametrosCNCRegulador a ex:Sistema ;
    rdfs:label "Sistema de homogeneización de parámetros entre CNC y regulador"@es ;
    ex:textoExtracto "Sercos. Algunos parámetros del CNC y de los reguladores deben estar definidos de forma equivalente para asegurar el correcto funcionamiento del sistema."@es .

ex:ParametroNP121 a ex:Parametro ;
    rdfs:label "NP121"@es ;
    ex:identificador "NP121" ;
    ex:textoExtracto "NP121"@es .

ex:ParametroNP122 a ex:Parametro ;
    rdfs:label "NP122"@es ;
    ex:identificador "NP122" ;
    ex:textoExtracto "NP122"@es .

ex:ParametroNP131 a ex:Parametro ;
    rdfs:label "NP131"@es ;
    ex:identificador "NP131" ;
    ex:textoExtracto "NP131"@es .

ex:ParametroNP133 a ex:Parametro ;
    rdfs:label "NP133"@es ;
    ex:identificador "NP133" ;
    ex:textoExtracto "NP133"@es .

ex:TablaHomogeneizacionParametros a ex:Tabla ;
    rdfs:label "Tabla de homogeneización de parámetros"@es ;
    ex:textoExtracto "Entendiendo la tabla de homogeneización. La tabla indica qué parámetros del CNC intervienen en la homogeneización, así como los parámetros del regulador que se ven afectados."@es ;
    ex:compuestoPor ex:ParametroNP121, ex:ParametroNP122, ex:ParametroNP131, ex:ParametroNP133 .

ex:ReguladorACSD a ex:ComponenteElectrico ;
    rdfs:label "Regulador ACSD"@es ;
    ex:textoExtracto "El CNC no homogeneiza los parámetros cuando el regulador es un ACSD."@es .

ex:DriveSercos a ex:ComponenteElectrico ;
    rdfs:label "Drive Sercos"@es ;
    ex:textoExtracto "Sercos. Algunos parámetros del CNC y de los reguladores deben estar definidos de forma equivalente para asegurar el correcto funcionamiento del sistema."@es .