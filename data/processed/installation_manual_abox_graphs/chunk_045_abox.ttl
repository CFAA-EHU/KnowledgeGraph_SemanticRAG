@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ParametrosDeLaTablaDeCinematicas a ns1:Parametro ;
    rdfs:label "Parámetros de la tabla de cinemáticas" ;
    ns1:textoExtracto "Estos parámetros indican el tipo y características de cada una de las cinemáticas." .

ns1:ParametrosDeLaTablaDeFuncionesM a ns1:Parametro ;
    rdfs:label "Parámetros de la tabla de funciones M" ;
    ns1:textoExtracto "Estos parámetros permiten definir nuevas funciones M y personalizar el tipo de sincronización y la rutina asociada a cada una de las funciones M del sistema." .

ns1:ParametrosDeLosAlmacenes a ns1:Parametro ;
    rdfs:label "Parámetros de los almacenes" ;
    ns1:textoExtracto "Estos parámetros indican el número de almacenes, tipo, número de posiciones, etc." .

ns1:ParametrosHMI a ns1:Parametro ;
    rdfs:label "Parámetros HMI" ;
    ns1:textoExtracto "Estos parámetros permiten definir el entorno de comunicación entre el operario y el CNC." .

