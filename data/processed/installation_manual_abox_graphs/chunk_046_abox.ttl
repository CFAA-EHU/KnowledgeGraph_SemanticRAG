@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PP76 a ex:Parametro ;
    rdfs:label "PP76" ;
    ex:identificador "PP76" ;
    ex:valor "65; Eje lineal. 66; Eje rotativo sin módulo. 194; Eje rotativo con módulo." ;
    ex:textoExtracto "PP76=65; Eje lineal. PP76=66; Eje rotativo sin módulo. PP76=194; Eje rotativo con módulo." .

ex:NP123 a ex:Parametro ;
    rdfs:label "PITCH" ;
    ex:identificador "NP123" ;
    ex:textoExtracto "PITCH" .

ex:NP121 a ex:Parametro ;
    rdfs:label "INPUTREV" ;
    ex:identificador "NP121.x" ;
    ex:textoExtracto "INPUTREV" .

ex:NP122 a ex:Parametro ;
    rdfs:label "OUTPUTREV" ;
    ex:identificador "NP122.x" ;
    ex:textoExtracto "OUTPUTREV" .

ex:NP115 a ex:Parametro ;
    rdfs:label "NPULSES2" ;
    ex:identificador "PP115 (bit 0)" ;
    ex:valor "B0=0; Si encoder rotativo (NPULSES2<>0). B0=1; Si encoder lineal (NPULSES2==0)." ;
    ex:textoExtracto "NPULSES2" .

ex:NP117 a ex:Parametro ;
    rdfs:label "NP117" ;
    ex:identificador "NP117" ;
    ex:textoExtracto "NP117" .

ex:NP133 a ex:Parametro ;
    rdfs:label "PITCH2" ;
    ex:identificador "NP133" ;
    ex:textoExtracto "PITCH2" .

ex:NP118 a ex:Parametro ;
    rdfs:label "PITCH2" ;
    ex:identificador "NP118" ;
    ex:textoExtracto "PITCH2" .

ex:NP131 a ex:Parametro ;
    rdfs:label "INPUTREV2" ;
    ex:identificador "NP131.x" ;
    ex:textoExtracto "INPUTREV2" .

ex:NP132 a ex:Parametro ;
    rdfs:label "OUTPUTREV2" ;
    ex:identificador "NP132.x" ;
    ex:textoExtracto "OUTPUTREV2" .

ex:GP10 a ex:Parametro ;
    rdfs:label "FBACKSRC SINMAGNI" ;
    ex:identificador "GP10" ;
    ex:valor "GP10=0; No hay captación externa. GP10=1; Señal TTL (SINMAGNI==0). GP10=2; Señal Vpp (SINMAGNI<>0)." ;
    ex:textoExtracto "GP10" .

ex:PP5 a ex:Parametro ;
    rdfs:label "FBACKDIFF" ;
    ex:identificador "PP5" ;
    ex:textoExtracto "FBACKDIFF" .

ex:PP16 a ex:Parametro ;
    rdfs:label "FBMIXTIME" ;
    ex:identificador "PP16" ;
    ex:textoExtracto "FBMIXTIME" .

ex:PP115 a ex:Parametro ;
    rdfs:label "AXISCH LOOPCH" ;
    ex:identificador "PP115 (bit 3)" ;
    ex:textoExtracto "AXISCH LOOPCH" .

ex:SistemaHomogeneizacionParametros a ex:Sistema ;
    rdfs:label "Sistema de homogeneización de parámetros entre CNC y regulador" ;
    ex:compuestoPor ex:PP76, ex:NP123, ex:NP121, ex:NP122, ex:NP115, ex:NP117, ex:NP133, ex:NP118, ex:NP131, ex:NP132, ex:GP10, ex:PP5, ex:PP16, ex:PP115 ;
    ex:textoExtracto "Sección 2.1 Homogeneización de parámetros entre el CNC y el regulador" .