@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_HomogeneizacionParametrosCNC_Drive a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de homogeneización de parámetros entre CNC y regulador (DRIVE)"@es ;
    ex:textoExtracto """
| CNC       | DRIVE   | Sercos | Feedback | Observaciones                                                                 |
|-----------|---------|--------|----------|-------------------------------------------------------------------------------|
| AXISTYPE  | PP76    |        |          | PP76=65; Eje lineal. PP76=66; Eje rotativo sin módulo. PP76=194; Eje rotativo con módulo. |
| PITCH     | NP123   |        |          |                                                                               |
| NPULSES2  | PP115 (bit 0), NP117 |    | Externa. | B0=0; Si encoder rotativo (NPULSES2<>0). B0=1; Si encoder lineal (NPULSES2==0).""" .

ex:Parametro_PP76
    a ex:Parametro ;
    rdfs:label "PP76 (AXISTYPE/AXISMODE)"@es ;
    ex:identificador "PP76" ;
    ex:textoExtracto "PP76=65; Eje lineal. PP76=66; Eje rotativo sin módulo. PP76=194; Eje rotativo con módulo." ;
    ex:documentadoEn ex:Tabla_HomogeneizacionParametrosCNC_Drive .

ex:Parametro_NP123
    a ex:Parametro ;
    rdfs:label "NP123 (PITCH)"@es ;
    ex:identificador "NP123" ;
    ex:textoExtracto "PITCH" ;
    ex:documentadoEn ex:Tabla_HomogeneizacionParametrosCNC_Drive .

ex:Parametro_PP115_Bit0
    a ex:Parametro ;
    rdfs:label "PP115 (bit 0)"@es ;
    ex:identificador "PP115_B0" ;
    ex:textoExtracto "B0=0; Si encoder rotativo (NPULSES2<>0). B0=1; Si encoder lineal (NPULSES2==0)." ;
    ex:documentadoEn ex:Tabla_HomogeneizacionParametrosCNC_Drive .

ex:Parametro_NP117
    a ex:Parametro ;
    rdfs:label "NP117 (Encoder rotativo/lineal)"@es ;
    ex:identificador "NP117" ;
    ex:textoExtracto "Si encoder rotativo (NPULSES2<>0). Si encoder lineal (NPULSES2==0)." ;
    ex:documentadoEn ex:Tabla_HomogeneizacionParametrosCNC_Drive .