@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_61eeb6f853 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "rearrancar el CNC para que el parámetro asuma el nuevo valor." .

ns1:IconoHomogeneizacion a ns1:ElementoSeguridad ;
    rdfs:label "icono de homogeneización" ;
    ns1:textoExtracto "Este icono puede aparecer junto al nombre del parámetro e indica que éste participa en la homogeneización de parámetros entre el CNC y el regulador." .

ns1:IconoValidacion a ns1:ElementoSeguridad ;
    rdfs:label "icono de validación" ;
    ns1:textoExtracto "Este icono puede aparecer junto al nombre del parámetro e indica que es necesario rearrancar el CNC para que el parámetro asuma el nuevo valor." .

ns1:Parametro_c4e6ffd1dc a ns1:Parametro ;
    rdfs:label "parámetro genérico" ;
    ns1:documentadoEn ns1:ArchivoReferencia,
        ns1:TablaDatos ;
    ns1:textoExtracto "definir un grupo de parámetros genéricos para que el fabricante los pueda utilizar a modo de parámetros máquina, etc." .

ns1:ArchivoReferencia a ns1:DocumentoTecnico ;
    rdfs:label "archivo" ;
    ns1:textoExtracto "Los iconos que aparecen junto al valor del parámetro permiten acceder a la lista de valores predeterminados, a una tabla de datos, a un grupo de parámetros o hacer referencia a un archivo." .

ns1:TablaDatos a ns1:Tabla ;
    rdfs:label "tabla de datos" ;
    ns1:textoExtracto "Los iconos que aparecen junto al valor del parámetro permiten acceder a la lista de valores predeterminados, a una tabla de datos, a un grupo de parámetros o hacer referencia a un archivo." .

