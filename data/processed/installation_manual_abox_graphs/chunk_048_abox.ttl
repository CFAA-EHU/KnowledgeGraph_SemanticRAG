@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SistemaHomogeneizacionParametrosCNCRegulador a ex:Sistema ;
    ex:textoExtracto """| CNC | DRIVE | Sercos | Feedback | Observaciones |
| --- | --- | --- | --- | --- |
| AXISCH | PP55 (bit 0,2,3) | Posición. |  | B1=0 B2=0 B3=0; No cambia el signo de contaje (AXISCH==NO)
B1=1 B2=1 B3=1; Sí cambia el signo de contaje (AXISCH==SI) |
| I0TYPE | PP115 (bit 1,5) |  | Externa. | B1=0 B5=0; Si I0 no codificado. B1=1 B5=0; Si I0 codificado creciente. B1=1 B5=1; Si I0 codificado decreciente. |
| I0CODDI1 I0CODDI2 | NP166 NP165 |  |  | Sólo si se dispone de I0 codificados. |
| REFDIREC DECINPUT FBACKSRC | PP147 (bit 0) PP147 (bit 5) PP147 (bit 3) PP147 (bit 1) |  |  | B0=0; Sentido de búsqueda positivo. B0=1; Sentido de búsqueda negativo. B5=0; Sí se dispone de micro. B5=1; No se dispone de micro. B3=0; Captación interna. B3=1; Captación externa. B1=0; La señal DECEL del CNC siempre es positiva. |
| REFFEED1 | PP41 |  |  |  |
| REFFEED2 | PP1 |  |  |  |
| REFVALUE | PP52 PP54 | Posición. Posición. | Interna. Externa. |  |
| REFSHIFT | PP150 PP151 | Posición. Posición. | Interna. Externa. |  |
| ABSOFF | PP177 PP178 |  | Interna. Externa. | Sólo si se dispone de I0 codificados o captación absoluta.""" .

ex:PP55 a ex:Parametro ;
    ex:identificador "PP55" ;
    ex:textoExtracto "PP55 (bit 0,2,3)" .

ex:PP115 a ex:Parametro ;
    ex:identificador "PP115" ;
    ex:textoExtracto "PP115 (bit 1,5)" .

ex:NP166 a ex:Parametro ;
    ex:identificador "NP166" ;
    ex:textoExtracto "NP166" .

ex:NP165 a ex:Parametro ;
    ex:identificador "NP165" ;
    ex:textoExtracto "NP165" .

ex:PP147 a ex:Parametro ;
    ex:identificador "PP147" ;
    ex:textoExtracto "PP147 (bit 0, bit 5, bit 3, bit 1)" .

ex:PP41 a ex:Parametro ;
    ex:identificador "PP41" ;
    ex:textoExtracto "PP41" .

ex:PP1 a ex:Parametro ;
    ex:identificador "PP1" ;
    ex:textoExtracto "PP1" .

ex:PP52 a ex:Parametro ;
    ex:identificador "PP52" ;
    ex:textoExtracto "PP52" .

ex:PP54 a ex:Parametro ;
    ex:identificador "PP54" ;
    ex:textoExtracto "PP54" .

ex:PP150 a ex:Parametro ;
    ex:identificador "PP150" ;
    ex:textoExtracto "PP150" .

ex:PP151 a ex:Parametro ;
    ex:identificador "PP151" ;
    ex:textoExtracto "PP151" .

ex:PP177 a ex:Parametro ;
    ex:identificador "PP177" ;
    ex:textoExtracto "PP177" .

ex:PP178 a ex:Parametro ;
    ex:identificador "PP178" ;
    ex:textoExtracto "PP178" .

ex:SistemaHomogeneizacionParametrosCNCRegulador ex:compuestoPor ex:PP55, ex:PP115, ex:NP166, ex:NP165, ex:PP147, ex:PP41, ex:PP1, ex:PP52, ex:PP54, ex:PP150, ex:PP151, ex:PP177, ex:PP178 .