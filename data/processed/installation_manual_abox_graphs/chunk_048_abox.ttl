@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_a8dc5eb71b a ns1:Parametro ;
    rdfs:label "Parámetro sin icono" ;
    ns1:textoExtracto "En los parámetros que no aparecen acompañados de ningún icono, se debe editar un valor, que deberá estar dentro de los límites señalados." .

