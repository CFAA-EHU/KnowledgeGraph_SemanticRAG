ex:Parametro_LimitesSoftware_PP55_bit4
    a                       ex:Parametro ;
    rdfs:label              "Límites de software (PP55, bit 4)" ;
    ex:identificador         "PP55 (bit 4)" ;
    ex:textoExtracto         "Activar límites de software. | PP55 (bit 4) |  |  | B4=1; Chequear los límites. B4=0; No chequear los límites (En el caso de cabezales, ejes rotativos con módulo y cuando ambos parámetros LIMIT+ y LIMIT- sean 0)." ;
    ex:documentadoEn         ex:Tabla_ParametrosCNC_51_52 .

