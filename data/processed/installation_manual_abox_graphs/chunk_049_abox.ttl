ex:Tabla_ParametrosCNC_51_52 a ex:Tabla ;
     a                       ex:Tabla ;
    rdfs:label              "Tabla de parámetros de homogeneización CNC-regulador (pág. 51-52)" ;
    ex:textoExtracto        "REFSHIFT | PP150 PP151 | Posición. Posición. | Interna. Externa. [...] Cálculo del módulo de la cota. | PP76 (bit 7) | B7=0; En los ejes rotativos o cabezales"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#XMLLiteral> .

