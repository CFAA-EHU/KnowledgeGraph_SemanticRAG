@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:MAXFLWE a ex:Parametro ;
    ex:identificador "MAXFLWE" ;
    ex:textoExtracto "MAXFLWE" .

ex:PP159 a ex:Parametro ;
    ex:identificador "PP159" ;
    ex:textoExtracto "PP159" .

ex:PP76_bit_7 a ex:Parametro ;
    ex:identificador "PP76 (bit 7)" ;
    ex:textoExtracto "PP76 (bit 7)" .

ex:SistemaCNC a ex:Sistema ;
    ex:textoExtracto "el CNC" .

ex:SistemaRegulador a ex:Sistema ;
    ex:textoExtracto "el regulador" .

ex:Tabla50 a ex:Tabla ;
    ex:textoExtracto "| MAXFLWE | PP159 |  |  | Sólo si está activa la monitorización del error de seguimiento. |\n| Cálculo del módulo de la cota. | PP76 (bit 7) |  |  | B7=0; En los ejes rotativos o cabezales trabajando en Sercos velocidad, el cálculo del módulo de la cota lo realiza el CNC. |" ;
    ex:tieneComponente ex:MAXFLWE, ex:PP159, ex:PP76_bit_7, ex:SistemaCNC, ex:SistemaRegulador .