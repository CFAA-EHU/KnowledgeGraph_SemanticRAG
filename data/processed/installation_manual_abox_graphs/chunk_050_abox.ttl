@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_0c0a5d74c7 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:ReguladorACSD ;
    ns1:monitoreaParametro ns1:NumeroDeParametroNP121,
        ns1:NumeroDeParametroNP122,
        ns1:NumeroDeParametroNP131,
        ns1:NumeroDeParametroNP133 ;
    ns1:textoExtracto "El CNC no homogeneiza los parámetros cuando el regulador es un ACSD." .

ns1:NumeroDeParametroNP121 a ns1:Parametro ;
    rdfs:label "Número de parámetro NP121" ;
    ns1:identificador "NP121" ;
    ns1:textoExtracto "La homogeneización actualiza los parámetros NP121, NP122, NP131 y NP133 de cada set del regulador con los valores definidos en el CNC." .

ns1:NumeroDeParametroNP122 a ns1:Parametro ;
    rdfs:label "Número de parámetro NP122" ;
    ns1:identificador "NP122" ;
    ns1:textoExtracto "La homogeneización actualiza los parámetros NP121, NP122, NP131 y NP133 de cada set del regulador con los valores definidos en el CNC." .

ns1:NumeroDeParametroNP131 a ns1:Parametro ;
    rdfs:label "Número de parámetro NP131" ;
    ns1:identificador "NP131" ;
    ns1:textoExtracto "La homogeneización actualiza los parámetros NP121, NP122, NP131 y NP133 de cada set del regulador con los valores definidos en el CNC." .

ns1:NumeroDeParametroNP133 a ns1:Parametro ;
    rdfs:label "Número de parámetro NP133" ;
    ns1:identificador "NP133" ;
    ns1:textoExtracto "La homogeneización actualiza los parámetros NP121, NP122, NP131 y NP133 de cada set del regulador con los valores definidos en el CNC." .

ns1:ReguladorACSD a ns1:ComponenteElectrico ;
    rdfs:label "Regulador ACSD" ;
    ns1:textoExtracto "La homogeneización y las gamas de velocidad. El número de sets de parámetros para definir las gamas de velocidad puede ser diferente en el CNC y en el regulador." .

