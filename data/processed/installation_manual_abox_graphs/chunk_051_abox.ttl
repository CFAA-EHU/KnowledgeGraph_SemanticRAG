@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_WARNCOUPE a ex:Parametro ;
    rdfs:label "WARNCOUPE" ;
    ex:textoExtracto "Eje gantry. Máxima diferencia permitida entre los errores de seguimiento de ambos ejes antes de mostrar un warning." ;
    ex:valor "Máxima diferencia permitida entre los errores de seguimiento de ambos ejes antes de mostrar un warning" .

ex:Parametro_MAXCOUPE a ex:Parametro ;
    rdfs:label "MAXCOUPE" ;
    ex:textoExtracto "Eje gantry. Máxima diferencia permitida entre los errores de seguimiento de ambos ejes." ;
    ex:valor "Máxima diferencia permitida entre los errores de seguimiento de ambos ejes" .

ex:Parametro_MINCORFEED a ex:Parametro ;
    rdfs:label "MINCORFEED" ;
    ex:textoExtracto "Velocidad mínima en las esquinas para el modo HSC." ;
    ex:valor "Velocidad mínima en las esquinas para el modo HSC" .

ex:Parametro_MAXFEED a ex:Parametro ;
    rdfs:label "MAXFEED" ;
    ex:textoExtracto "Máximo avance para el mecanizado. Se recomienda definir este parámetro con un valor distinto de ꞏ0ꞏ." ;
    ex:valor "Máximo avance para el mecanizado" .