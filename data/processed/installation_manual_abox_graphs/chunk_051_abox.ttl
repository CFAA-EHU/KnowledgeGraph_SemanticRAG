@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FeedbackCaptacion a ns1:Parametro ;
    rdfs:label "Tipo de captación del eje" ;
    ns1:textoExtracto "Indica si la escritura del parámetro en el drive está condicionada por el tipo de captación del eje, interna o externa." .

ns1:Parametro_4e4eb2f05d a ns1:Parametro ;
    rdfs:label "Parámetro máquina del CNC" ;
    ns1:textoExtracto "Lista de parámetros máquina del CNC." .

ns1:Parametro_f471419cd9 a ns1:Parametro ;
    rdfs:label "Parámetro del regulador equivalente al CNC" ;
    ns1:textoExtracto "Lista de parámetros del regulador, que equivalen a cada parámetro del CNC." .

ns1:SercosConfiguracion a ns1:Parametro ;
    rdfs:label "Tipo de configuración Sercos" ;
    ns1:textoExtracto "Indica si la escritura del parámetro en el drive está condicionada por el tipo de configuración Sercos, posición o velocidad." .

ns1:TablaHomogeneizacionParametros a ns1:Tabla ;
    rdfs:label "Tabla de homogeneización de parámetros entre el CNC y el regulador" ;
    ns1:ilustradoEn ns1:Pagina51_52 ;
    ns1:textoExtracto "La tabla indica qué parámetros del CNC intervienen en la homogeneización, así como los parámetros del regulador que se ven afectados." .

