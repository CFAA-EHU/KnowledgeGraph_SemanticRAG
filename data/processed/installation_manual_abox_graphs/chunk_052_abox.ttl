@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ParametrosPuestaMarcha a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros a verificar antes de la puesta en marcha"@es ;
    ex:textoExtracto "Parámetro | Significado... [fragmento de tabla con 11 parámetros técnicos]"@es ;
    ex:documentadoEn ex:Pagina_53_54 ;
    ex:ilustradoEn ex:Seccion_2_2 .

ex:Parametro_FBACKDIFF
    a ex:Parametro ;
    rdfs:label "FBACKDIFF (Máxima diferencia entre captaciones)"@es ;
    ex:textoExtracto "FBACKDIFF | Máxima diferencia entre captaciones. El CNC tiene en cuenta este parámetro en ejes configurados como Sercos posición y con captación externa o externa+interna. Se recomienda definir este parámetro con un valor distinto de ꞏ0ꞏ."@es ;
    ex:monitoreaParametro ex:Sistema_CNC ;
    ex:documentadoEn ex:Tabla_ParametrosPuestaMarcha .

ex:Parametro_DSYNCVELW
    a ex:Parametro ;
    rdfs:label "DSYNCVELW (Margen de velocidad en sincronización)"@es ;
    ex:textoExtracto "DSYNCVELW | Sincronización de ejes y cabezales. Este parámetro se define para el elemento esclavo de la sincronización e indica el margen de velocidad admisible dentro del cual se considera que la sincronización es correcta."@es ;
    ex:monitoreaParametro ex:Sistema_CNC ;
    ex:documentadoEn ex:Tabla_ParametrosPuestaMarcha .

ex:Parametro_DSYNCPOSW
    a ex:Parametro ;
    rdfs:label "DSYNCPOSW (Margen de posición en sincronización)"@es ;
    ex:textoExtracto "DSYNCPOSW | Sincronización de ejes y cabezales. Este parámetro se define para el elemento esclavo de la sincronización e indica el margen de posición admisible dentro del cual se considera que la sincronización es correcta."@es ;
    ex:monitoreaParametro ex:Sistema_CNC ;
    ex:documentadoEn ex:Tabla_ParametrosPuestaMarcha .

ex:Parametro_LIMIT
    a ex:Parametro ;
    rdfs:label "LIMIT+ (Límite positivo de recorrido del eje)"@es ;
    ex:textoExtracto "LIMIT+ | Límites de recorrido del eje. Se recomienda que ambos parámetros no tengan valor ꞏ0ꞏ."@es ;
    ex:monitoreaParametro ex:Sistema_CNC ;
    ex:documentadoEn ex:Tabla_ParametrosPuestaMarcha .

ex:Parametro_LIMIT
    a ex:Parametro ;
    rdfs:label "LIMIT- (Límite negativo de recorrido del eje)"@es ;
    ex:textoExtracto "LIMIT- | Límites de recorrido del eje. Se recomienda que ambos parámetros no tengan valor ꞏ0ꞏ."@es ;
    ex:monitoreaParametro ex:Sistema_CNC ;
    ex:documentadoEn ex:Tabla_ParametrosPuestaMarcha .

ex:Parametro_TENDENCY
    a ex:Parametro ;
    rdfs:label "TENDENCY (Test de tendencia para detección de embalamiento)"@es ;
    ex:textoExtracto "TENDENCY | Activación del test de tendencia. Detecta el embalamiento de los ejes debido a realimentación positiva. Se aconseja activarlo durante la puesta a punto de la máquina."@es ;
    ex:monitoreaParametro ex:Sistema_CNC ;
    ex:documentadoEn ex:Tabla_ParametrosPuestaMarcha .

ex:Parametro_PROBERANGE
    a ex:Parametro ;
    rdfs:label "PROBERANGE (Distancia máxima de frenado del palpador)"@es ;
    ex:textoExtracto "PROBERANGE | Distancia máxima de frenado del palpador. Este parámetro fija la distancia máxima de frenado del palpador tras realizar la palpación, evitando de esta forma la rotura del mismo (cerámicos, etc)."@es ;
    ex:monitoreaParametro ex:Sistema_CNC ;
    ex:documentadoEn ex:Tabla_ParametrosPuestaMarcha .

ex:Parametro_PROBEFEED
    a ex:Parametro ;
    rdfs:label "PROBEFEED (Avance máximo de palpado)"@es ;
    ex:textoExtracto "PROBEFEED | Avance máximo de palpado."@es ;
    ex:monitoreaParametro ex:Sistema_CNC ;
    ex:documentadoEn ex:Tabla_ParametrosPuestaMarcha .

ex:Parametro_PROBEDELAY
    a ex:Parametro ;
    rdfs:label "PROBEDELAY (Retardo de señal del palpador 1)"@es ;
    ex:textoExtracto "PROBEDELAY | Retardo de la señal de palpador 1 y 2. Este parámetro sólo se define cuando existe un retardo desde el momento de palpación hasta que el CNC recibe la señal (comunicación por infrarrojos, etc)."@es ;
    ex:monitoreaParametro ex:Sistema_CNC ;
    ex:documentadoEn ex:Tabla_ParametrosPuestaMarcha .

ex:Parametro_PROBEDELAY2
    a ex:Parametro ;
    rdfs:label "PROBEDELAY2 (Retardo de señal del palpador 2)"@es ;
    ex:textoExtracto "PROBEDELAY2 | Retardo de la señal de palpador 1 y 2. Este parámetro sólo se define cuando existe un retardo desde el momento de palpación hasta que el CNC recibe la señal (comunicación por infrarrojos, etc)."@es ;
    ex:monitoreaParametro ex:Sistema_CNC ;
    ex:documentadoEn ex:Tabla_ParametrosPuestaMarcha .

ex:Parametro_REPOSFEED
    a ex:Parametro ;
    rdfs:label "REPOSFEED (Avance de reposicionamiento post-inspección)"@es ;
    ex:textoExtracto "REPOSFEED | Avance de reposicionamiento tras una inspección de herramienta."@es ;
    ex:monitoreaParametro ex:Sistema_CNC ;
    ex:documentadoEn ex:Tabla_ParametrosPuestaMarcha .

ex:Parametro_POSFEED
    a ex:Parametro ;
    rdfs:label "POSFEED (Avance de posicionamiento del eje)"@es ;
    ex:textoExtracto "POSFEED | Avance de posicionamiento del eje independiente."@es ;
    ex:monitoreaParametro ex:Sistema_CNC ;
    ex:documentadoEn ex:Tabla_ParametrosPuestaMarcha .

ex:Parametro_JOGFEED
    a ex:Parametro ;
    rdfs:label "JOGFEED (Avance en modo jog continuo)"@es ;
    ex:textoExtracto "JOGFEED | Modo de trabajo manual. Avance en modo jog continuo."@es ;
    ex:monitoreaParametro ex:Sistema_CNC ;
    ex:documentadoEn ex:Tabla_ParametrosPuestaMarcha .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC (Control Numérico Computarizado)"@es ;
    ex:textoExtracto "El CNC tiene en cuenta este parámetro en ejes configurados como Sercos posición..."@es .