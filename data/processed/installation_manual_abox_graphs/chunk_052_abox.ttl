ns1:ConfiguracionDelEje a ns1:Parametro ;
    rdfs:label "Configuración del eje" ;
    ns1:identificador "PP115 (bit 3)" ;
    ns1:textoExtracto "" .

ns1:DiferencialDeRetroalimentacion a ns1:Parametro ;
    rdfs:label "Diferencial de retroalimentación" ;
    ns1:identificador "PP5" ;
    ns1:textoExtracto "" .

ns1:FuenteDeRetroalimentacion_7333e7569f a ns1:Parametro ;
    rdfs:label "Fuente de retroalimentación" ;
    ns1:identificador "GP10" ;
    ns1:textoExtracto "GP10=0; No hay captación externa. GP10=1; Señal TTL (SINMAGNI==0). GP10=2; Señal Vpp (SINMAGNI<>0)." .

ns1:Parametro_b3d28cf673 a ns1:Parametro ;
    rdfs:label "Pitch" ;
    ns1:identificador "NP123" ;
    ns1:textoExtracto "" .

ns1:Pitch2 a ns1:Parametro ;
    rdfs:label "Número de pulsos por revolución",
        "Pitch 2" ;
    ns1:identificador "NP117",
        "NP118",
        "NP133",
        "PP115 (bit 0)" ;
    ns1:textoExtracto "B0=0; Si encoder rotativo (NPULSES2<>0). B0=1; Si encoder lineal (NPULSES2==0). NP117; Si encoder rotativo (NPULSES2<>0).",
        "NP133; Si encoder rotativo (NPULSES2<>0). NP117; Si encoder lineal (NPULSES2==0). NP118; Si encoder lineal (NPULSES2==0)." .

ns1:ReversionDeEntrada a ns1:Parametro ;
    rdfs:label "Reversión de entrada" ;
    ns1:identificador "NP121.x" ;
    ns1:textoExtracto "Afecta a todas las gamas." .

ns1:ReversionDeEntrada2 a ns1:Parametro ;
    rdfs:label "Reversión de entrada 2" ;
    ns1:identificador "NP131.x" ;
    ns1:textoExtracto "Afecta a todas las gamas. Sólo si encoder rotativo (NPULSES2<>0)." .

ns1:ReversionDeSalida a ns1:Parametro ;
    rdfs:label "Reversión de salida" ;
    ns1:identificador "NP122.x" ;
    ns1:textoExtracto "Afecta a todas las gamas." .

ns1:ReversionDeSalida2 a ns1:Parametro ;
    rdfs:label "Reversión de salida 2" ;
    ns1:identificador "NP132.x" ;
    ns1:textoExtracto "Afecta a todas las gamas. Sólo si encoder rotativo (NPULSES2<>0)." .

ns1:TiempoDeMezclaDeRetroalimentacion a ns1:Parametro ;
    rdfs:label "Tiempo de mezcla de retroalimentación" ;
    ns1:identificador "PP16" ;
    ns1:textoExtracto "" .

ns1:TipoDeEje a ns1:Parametro ;
    rdfs:label "Tipo de eje" ;
    ns1:identificador "AXISTYPE" ;
    ns1:textoExtracto "PP76=65; Eje lineal. PP76=66; Eje rotativo sin módulo. PP76=194; Eje rotativo con módulo." .

