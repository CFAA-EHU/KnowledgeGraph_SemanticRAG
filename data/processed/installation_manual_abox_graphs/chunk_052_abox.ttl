@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_FBACKDIFF a ex:Parametro ;
    rdfs:label "FBACKDIFF" ;
    ex:textoExtracto "Máxima diferencia entre captaciones. El CNC tiene en cuenta este parámetro en ejes configurados como Sercos posición y con captación externa o externa+interna. Se recomienda definir este parámetro con un valor distinto de ꞏ0ꞏ." ;
    ex:identificador "FBACKDIFF" .

ex:Parametro_DSYNCVELW a ex:Parametro ;
    rdfs:label "DSYNCVELW" ;
    ex:textoExtracto "Sincronización de ejes y cabezales. Este parámetro se define para el elemento esclavo de la sincronización e indica el margen de velocidad admisible dentro del cual se considera que la sincronización es correcta." ;
    ex:identificador "DSYNCVELW" .

ex:Parametro_DSYNCPOSW a ex:Parametro ;
    rdfs:label "DSYNCPOSW" ;
    ex:textoExtracto "Sincronización de ejes y cabezales. Este parámetro se define para el elemento esclavo de la sincronización e indica el margen de posición admisible dentro del cual se considera que la sincronización es correcta." ;
    ex:identificador "DSYNCPOSW" .

ex:Parametro_LIMIT_ a ex:Parametro ;
    rdfs:label "LIMIT+" ;
    ex:textoExtracto "Límites de recorrido del eje. Se recomienda que ambos parámetros no tengan valor ꞏ0ꞏ." ;
    ex:identificador "LIMIT+" .

ex:Parametro_LIMIT__ a ex:Parametro ;
    rdfs:label "LIMIT-" ;
    ex:textoExtracto "Límites de recorrido del eje. Se recomienda que ambos parámetros no tengan valor ꞏ0ꞏ." ;
    ex:identificador "LIMIT-" .

ex:Parametro_TENDENCY a ex:Parametro ;
    rdfs:label "TENDENCY" ;
    ex:textoExtracto "Activación del test de tendencia. Detecta el embalamiento de los ejes debido a realimentación positiva. Se aconseja activarlo durante la puesta a punto de la máquina." ;
    ex:identificador "TENDENCY" .

ex:Parametro_PROBERANGE a ex:Parametro ;
    rdfs:label "PROBERANGE" ;
    ex:textoExtracto "Distancia máxima de frenado del palpador. Este parámetro fija la distancia máxima de frenado del palpador tras realizar la palpación, evitando de esta forma la rotura del mismo (cerámicos, etc)." ;
    ex:identificador "PROBERANGE" .

ex:Parametro_PROBEFEED a ex:Parametro ;
    rdfs:label "PROBEFEED" ;
    ex:textoExtracto "Avance máximo de palpado." ;
    ex:identificador "PROBEFEED" .

ex:Parametro_PROBEDELAY a ex:Parametro ;
    rdfs:label "PROBEDELAY" ;
    ex:textoExtracto "Retardo de la señal de palpador 1. Este parámetro sólo se define cuando existe un retardo desde el momento de palpación hasta que el CNC recibe la señal (comunicación por infrarrojos, etc)." ;
    ex:identificador "PROBEDELAY" .

ex:Parametro_PROBEDELAY2 a ex:Parametro ;
    rdfs:label "PROBEDELAY2" ;
    ex:textoExtracto "Retardo de la señal de palpador 2. Este parámetro sólo se define cuando existe un retardo desde el momento de palpación hasta que el CNC recibe la señal (comunicación por infrarrojos, etc)." ;
    ex:identificador "PROBEDELAY2" .

ex:Parametro_REPOSFEED a ex:Parametro ;
    rdfs:label "REPOSFEED" ;
    ex:textoExtracto "Avance de reposicionamiento tras una inspección de herramienta." ;
    ex:identificador "REPOSFEED" .

ex:Parametro_POSFEED a ex:Parametro ;
    rdfs:label "POSFEED" ;
    ex:textoExtracto "Avance de posicionamiento del eje independiente." ;
    ex:identificador "POSFEED" .

ex:Parametro_JOGFEED a ex:Parametro ;
    rdfs:label "JOGFEED" ;
    ex:textoExtracto "Modo de trabajo manual. Avance en modo jog continuo." ;
    ex:identificador "JOGFEED" .