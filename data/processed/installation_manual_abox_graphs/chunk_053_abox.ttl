@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:REPOSFEED a ex:Parametro ;
    ex:textoExtracto "REPOSFEED | Avance de reposicionamiento tras una inspección de herramienta." ;
    rdfs:label "REPOSFEED" .

ex:POSFEED a ex:Parametro ;
    ex:textoExtracto "POSFEED | Avance de posicionamiento del eje independiente." ;
    rdfs:label "POSFEED" .

ex:JOGFEED a ex:Parametro ;
    ex:textoExtracto "JOGFEED | Modo de trabajo manual. Avance en modo jog continuo." ;
    rdfs:label "JOGFEED" .

ex:JOGRAPFEED a ex:Parametro ;
    ex:textoExtracto "JOGRAPFEED | Modo de trabajo manual. Avance rápido en modo jog continuo." ;
    rdfs:label "JOGRAPFEED" .

ex:MAXMANFEED a ex:Parametro ;
    ex:textoExtracto "MAXMANFEED | Modo de trabajo manual. Avance máximo en modo jog continuo." ;
    rdfs:label "MAXMANFEED" .

ex:MAXMANACC a ex:Parametro ;
    ex:textoExtracto "MAXMANACC | Modo de trabajo manual. Aceleración máxima en manual." ;
    rdfs:label "MAXMANACC" .