@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_REPOSFEED a ex:Parametro ;
    rdfs:label "REPOSFEED" ;
    ex:textoExtracto "Avance de reposicionamiento tras una inspección de herramienta." ;
    ex:identificador "REPOSFEED" .

ex:Parametro_POSFEED a ex:Parametro ;
    rdfs:label "POSFEED" ;
    ex:textoExtracto "Avance de posicionamiento del eje independiente." ;
    ex:identificador "POSFEED" .

ex:Parametro_JOGFEED a ex:Parametro ;
    rdfs:label "JOGFEED" ;
    ex:textoExtracto "Modo de trabajo manual. Avance en modo jog continuo." ;
    ex:identificador "JOGFEED" .

ex:Parametro_JOGRAPFEED a ex:Parametro ;
    rdfs:label "JOGRAPFEED" ;
    ex:textoExtracto "Modo de trabajo manual. Avance rápido en modo jog continuo." ;
    ex:identificador "JOGRAPFEED" .

ex:Parametro_MAXMANFEED a ex:Parametro ;
    rdfs:label "MAXMANFEED" ;
    ex:textoExtracto "Modo de trabajo manual. Avance máximo en modo jog continuo." ;
    ex:identificador "MAXMANFEED" .

ex:Parametro_MAXMANACC a ex:Parametro ;
    rdfs:label "MAXMANACC" ;
    ex:textoExtracto "Modo de trabajo manual. Aceleración máxima en manual." ;
    ex:identificador "MAXMANACC" .

ex:ModoOperacion_Manual a ex:ModoOperacion ;
    rdfs:label "Modo de trabajo manual" ;
    ex:textoExtracto "Modo de trabajo manual (referenciado en parámetros JOGFEED, JOGRAPFEED, MAXMANFEED, MAXMANACC)." .

ex:ModoOperacion_Manual ex:monitoreaParametro ex:Parametro_JOGFEED .
ex:ModoOperacion_Manual ex:monitoreaParametro ex:Parametro_JOGRAPFEED .
ex:ModoOperacion_Manual ex:monitoreaParametro ex:Parametro_MAXMANFEED .
ex:ModoOperacion_Manual ex:monitoreaParametro ex:Parametro_MAXMANACC .