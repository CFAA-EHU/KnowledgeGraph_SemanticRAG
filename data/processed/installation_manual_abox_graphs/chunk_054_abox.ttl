    rdfs:label "Código de entrada I0" ;
    ns1:identificador "NP165" ;
    ns1:textoExtracto "Sólo si se dispone de I0 codificados." .

ns1:DesplazamientoDeReferencia a ns1:Parametro ;
    rdfs:label "Desplazamiento de referencia" ;
    ns1:identificador "PP150 PP151" ;
    ns1:textoExtracto "Posición. Posición." .

ns1:EntradaDeDeceleracion a ns1:Parametro ;
    rdfs:label "Entrada de deceleración" ;
    ns1:identificador "PP147 (bit 5)" ;
    ns1:textoExtracto "B5=0; Sí se dispone de micro. B5=1; No se dispone de micro." .

ns1:FuenteDeRetroalimentacion_211d26ec72 a ns1:Parametro ;
    rdfs:label "Fuente de retroalimentación" ;
    ns1:identificador "PP41" ;
