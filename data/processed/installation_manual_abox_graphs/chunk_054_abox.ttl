ns1:OffsetAbsoluto a ns1:Parametro ;
    rdfs:label "Offset absoluto" ;
    ns1:identificador "PP177 PP178" ;
    ns1:textoExtracto "Sólo si se dispone de I0 codificados o captación absoluta." .

ns1:Parametro_7ece5517d5 a ns1:Parametro ;
    rdfs:label "Parámetro de configuración del eje" ;
    ns1:identificador "PP55" ;
    ns1:textoExtracto "B1=0 B2=0 B3=0; No cambia el signo de contaje (AXISCH==NO) B1=1 B2=1 B3=1; Sí cambia el signo de contaje (AXISCH==SI)" .

ns1:SentidoDeBusquedaDelEje a ns1:Parametro ;
    rdfs:label "Sentido de búsqueda del eje" ;
    ns1:identificador "PP147 (bit 0)" ;
    ns1:textoExtracto "B0=0; Sentido de búsqueda positivo. B0=1; Sentido de búsqueda negativo." .

ns1:TipoDeEntradaI0 a ns1:Parametro ;
    rdfs:label "Tipo de entrada I0" ;
    ns1:identificador "PP115" ;
    ns1:textoExtracto "B1=0 B5=0; Si I0 no codificado. B1=1 B5=0; Si I0 codificado creciente. B1=1 B5=1; Si I0 codificado decreciente." .

ns1:ValorDeReferencia a ns1:Parametro ;
    rdfs:label "Valor de referencia" ;
    ns1:identificador "PP52 PP54" ;
    ns1:textoExtracto "Posición. Posición." .

