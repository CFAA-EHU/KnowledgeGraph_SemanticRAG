@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MAXMANFEED
    a ex:Parametro ;
    rdfs:label "MAXMANFEED" ;
    ex:textoExtracto "Modo de trabajo manual. Avance máximo en modo jog continuo." ;
    ex:identificador "MAXMANFEED" .

ex:Parametro_MAXMANACC
    a ex:Parametro ;
    rdfs:label "MAXMANACC" ;
    ex:textoExtracto "Modo de trabajo manual. Aceleración máxima en manual." ;
    ex:identificador "MAXMANACC" .

ex:Parametro_INCJOGFEED
    a ex:Parametro ;
    rdfs:label "INCJOGFEED" ;
    ex:textoExtracto "Modo de trabajo manual. Avance en modo jog incremental." ;
    ex:identificador "INCJOGFEED" .

ex:ModoOperacion_Manual
    a ex:ModoOperacion ;
    rdfs:label "Modo de trabajo manual" ;
    ex:textoExtracto "Modo de trabajo manual" ;
    ex:monitoreaParametro ex:Parametro_MAXMANFEED ;
    ex:monitoreaParametro ex:Parametro_MAXMANACC ;
    ex:monitoreaParametro ex:Parametro_INCJOGFEED .