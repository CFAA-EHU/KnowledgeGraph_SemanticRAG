@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:FBACKAL a ex:Alarma ;
    ex:textoExtracto "Activación de la alarma de captación. La alarma de captación debe estar activada." ;
    rdfs:label "FBACKAL" .

ex:G00FEED a ex:Parametro ;
    ex:textoExtracto "Avance en G00." ;
    rdfs:label "G00FEED" .

ex:MAXFEED a ex:Parametro ;
    ex:textoExtracto "Máximo avance para el mecanizado. Se recomienda definir este parámetro con un valor distinto de ꞏ0ꞏ." ;
    rdfs:label "MAXFEED" .

ex:FLWEMONITOR a ex:Parametro ;
    ex:textoExtracto "Tipo de monitorización del error de seguimiento. La monitorización debe estar activada." ;
    rdfs:label "FLWEMONITOR" .

ex:MINFLWE a ex:Parametro ;
    ex:textoExtracto "Este parámetro indica el máximo error de seguimiento permitido cuando el eje está parado." ;
    rdfs:label "MINFLWE" .

ex:MAXFLWE a ex:Parametro ;
    ex:textoExtracto "Para una monitorización \"standard\" del error de seguimiento, este parámetro indica el máximo error de seguimiento permitido cuando el eje está en movimiento. Para una monitorización \"lineal\" del error de seguimiento, este parámetro indica a partir de qué valor comienza la supervisión dinámica." ;
    rdfs:label "MAXFLWE" .

ex:FEDYNFAC a ex:Parametro ;
    ex:textoExtracto "Para una monitorización \"lineal\" del error de seguimiento, este parámetro indica el error porcentual permitido, desviación del error de seguimiento real respecto al teórico." ;
    rdfs:label "FEDYNFAC" .