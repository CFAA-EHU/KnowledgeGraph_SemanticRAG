@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CalculoDelModuloDeLaCota a ns1:Parametro ;
    rdfs:label "Cálculo del módulo de la cota" ;
    ns1:identificador "PP76 (bit 7)" ;
    ns1:textoExtracto "B7=0; En los ejes rotativos o cabezales trabajando en Sercos velocidad, el cálculo del módulo de la cota lo realiza el CNC." .

ns1:CotaMaximaDeVelocidad a ns1:Parametro ;
    rdfs:label "Cota máxima de velocidad" ;
    ns1:identificador "MAXFLWE" ;
    ns1:textoExtracto "Sólo si está activa la monitorización del error de seguimiento." .

