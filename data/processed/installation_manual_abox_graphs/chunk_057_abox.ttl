@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_NAXIS
    a ex:Parametro ;
    rdfs:label "NAXIS" ;
    ex:textoExtracto "NAXIS Número de ejes que gobierna el CNC. Valores posibles: De 1 a 32. Valor por defecto: 3." ;
    ex:valor "3"^^xsd:integer ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Parametro_NSPDL
    a ex:Parametro ;
    rdfs:label "NSPDL" ;
    ex:textoExtracto "la suma de ejes y cabezales será como máximo 32. Por ejemplo, un sistema con 6 cabezales podrá tener 26 ejes (NSPDL=6 NAXIS=26)." ;
    ex:valor "0"^^xsd:integer ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Tabla_AXISNAME a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla AXISNAME" ;
    ex:textoExtracto "AXISNAME Lista de ejes del sistema. Este parámetro muestra la tabla para definir los nombres de los ejes." ;
    ex:documentadoEn ex:Manual_CNC .

ex:Parametro_AXISNAME1
    a ex:Parametro ;
    rdfs:label "AXISNAME1" ;
    ex:textoExtracto "AXISNAME n Nombre de los ejes. Valores posibles: X, X1..X9, Y, Y1..Y9, .. E, E1..E9. Valor por defecto: Comenzando por AXISNAME1; X, Y, Z..." ;
    ex:valor "X" ;
    ex:detalladoEnEsquema ex:Tabla_AXISNAME ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Parametro_AXISNAME2
    a ex:Parametro ;
    rdfs:label "AXISNAME2" ;
    ex:textoExtracto "AXISNAME n Nombre de los ejes. Valores posibles: X, X1..X9, Y, Y1..Y9, .. E, E1..E9. Valor por defecto: Comenzando por AXISNAME1; X, Y, Z..." ;
    ex:valor "Y" ;
    ex:detalladoEnEsquema ex:Tabla_AXISNAME ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Parametro_AXISNAME3
    a ex:Parametro ;
    rdfs:label "AXISNAME3" ;
    ex:textoExtracto "AXISNAME n Nombre de los ejes. Valores posibles: X, X1..X9, Y, Y1..Y9, .. E, E1..E9. Valor por defecto: Comenzando por AXISNAME1; X, Y, Z..." ;
    ex:valor "Z" ;
    ex:detalladoEnEsquema ex:Tabla_AXISNAME ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "NAXIS Número de ejes que gobierna el CNC. [...] Un sistema sin cabezales podrá tener 32 ejes (NSPDL=0 NAXIS=32) y un sistema con 6 cabezales podrá tener 26 ejes (NSPDL=6 NAXIS=26)." ;
    ex:compuestoPor ex:Parametro_NAXIS, ex:Parametro_NSPDL .

ex:Manual_CNC
    a ex:Manual ;
    rdfs:label "Manual del sistema CNC" ;
    ex:textoExtracto "AXISNAME Lista de ejes del sistema. Este parámetro muestra la tabla para definir los nombres de los ejes." .