@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EjeLogico1 a ex:ComponenteMecanico ;
    rdfs:label "Eje lógico 1" ;
    ex:identificador "AXISNAME 1" ;
    ex:textoExtracto "El primer eje de la tabla será el eje lógico ꞏ1ꞏ y así sucesivamente." .

ex:EjeLogico2 a ex:ComponenteMecanico ;
    rdfs:label "Eje lógico 2" ;
    ex:identificador "AXISNAME 2" ;
    ex:textoExtracto "Número lógico ꞏ2ꞏ." .

ex:EjeLogico3 a ex:ComponenteMecanico ;
    rdfs:label "Eje lógico 3" ;
    ex:identificador "AXISNAME 3" ;
    ex:textoExtracto "Número lógico ꞏ3ꞏ." .