@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivacionDelTestDeTendencia a ns1:Parametro ;
    rdfs:label "Activación del test de tendencia" ;
    ns1:identificador "TENDENCY" ;
    ns1:textoExtracto "TENDENCY | Activación del test de tendencia. Detecta el embalamiento de los ejes debido a realimentación positiva." .

ns1:AvanceDePosicionamientoDelEjeIndependiente a ns1:Parametro ;
    rdfs:label "Avance de posicionamiento del eje independiente" ;
    ns1:identificador "POSFEED" ;
    ns1:textoExtracto "POSFEED | Avance de posicionamiento del eje independiente." .

ns1:AvanceDeReposicionamientoTrasUnaInspeccionDeHerramienta a ns1:Parametro ;
    rdfs:label "Avance de reposicionamiento tras una inspección de herramienta" ;
    ns1:identificador "REPOSFEED" ;
    ns1:textoExtracto "REPOSFEED | Avance de reposicionamiento tras una inspección de herramienta." .

ns1:AvanceEnModoJogContinuo a ns1:Parametro ;
    rdfs:label "Avance en modo jog continuo" ;
    ns1:identificador "JOGFEED" ;
    ns1:textoExtracto "JOGFEED | Modo de trabajo manual. Avance en modo jog continuo." .

ns1:AvanceMaximoDePalpado_a280e3df2f a ns1:Parametro ;
    rdfs:label "Avance máximo de palpado" ;
    ns1:identificador "PROBEFEED" ;
    ns1:textoExtracto "PROBEFEED | Avance máximo de palpado." .

ns1:DistanciaMaximaDeFrenadoDelPalpador a ns1:Parametro ;
    rdfs:label "Distancia máxima de frenado del palpador" ;
    ns1:identificador "PROBERANGE" ;
    ns1:textoExtracto "PROBERANGE | Distancia máxima de frenado del palpador. Este parámetro fija la distancia máxima de frenado del palpador tras realizar la palpación, evitando de esta forma la rotura del mismo (cerámicos, etc)." .

ns1:LimiteInferiorDeRecorridoDelEje a ns1:Parametro ;
    rdfs:label "Límite inferior de recorrido del eje" ;
    ns1:identificador "LIMIT-" ;
    ns1:textoExtracto "LIMIT- | Límites de recorrido del eje. Se recomienda que ambos parámetros no tengan valor '0'." .

ns1:LimiteSuperiorDeRecorridoDelEje a ns1:Parametro ;
    rdfs:label "Límite superior de recorrido del eje" ;
    ns1:identificador "LIMIT+" ;
    ns1:textoExtracto "LIMIT+ | Límites de recorrido del eje. Se recomienda que ambos parámetros no tengan valor '0'." .

ns1:MaximaDiferenciaEntreCaptaciones a ns1:Parametro ;
    rdfs:label "Máxima diferencia entre captaciones" ;
    ns1:identificador "FBACKDIFF" ;
    ns1:textoExtracto "FBACKDIFF | Máxima diferencia entre captaciones. El CNC tiene en cuenta este parámetro en ejes configurados como Sercos posición y con captación externa o externa+interna." .

ns1:RetardoDeLaSenalDePalpador1 a ns1:Parametro ;
    rdfs:label "Retardo de la señal de palpador 1" ;
    ns1:identificador "PROBEDELAY" ;
    ns1:textoExtracto "PROBEDELAY | Retardo de la señal de palpador 1 y 2. Este parámetro sólo se define cuando existe un retardo desde el momento de palpación hasta que el CNC recibe la señal (comunicación por infrarrojos, etc)." .

ns1:SincronizacionDeEjesYCabezalesMargenDePosicion a ns1:Parametro ;
    rdfs:label "Sincronización de ejes y cabezales (margen de posición)" ;
    ns1:identificador "DSYNCPOSW" ;
    ns1:textoExtracto "DSYNCPOSW | Sincronización de ejes y cabezales. Este parámetro se define para el elemento esclavo de la sincronización e indica el margen de posición admisible dentro del cual se considera que la sincronización es correcta." .

ns1:SincronizacionDeEjesYCabezalesMargenDeVelocidad a ns1:Parametro ;
    rdfs:label "Sincronización de ejes y cabezales (margen de velocidad)" ;
    ns1:identificador "DSYNCVELW" ;
    ns1:textoExtracto "DSYNCVELW | Sincronización de ejes y cabezales. Este parámetro se define para el elemento esclavo de la sincronización e indica el margen de velocidad admisible dentro del cual se considera que la sincronización es correcta." .

