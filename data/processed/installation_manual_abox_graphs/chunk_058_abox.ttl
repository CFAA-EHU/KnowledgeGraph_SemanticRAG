@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaConfiguracionEjes a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuración de ejes lógicos"@es ;
    ex:textoExtracto "AXISNAME n | Orden lógico. | --- | --- | AXISNAME 1 | Número lógico ꞏ1ꞏ. | AXISNAME 2 | Número lógico ꞏ2ꞏ. | AXISNAME 3 | Número lógico ꞏ3ꞏ."@es ;
    ex:identificador "Tabla 2.3.2 (pág. 56)" .

ex:Parametro_AXISNAME_1
    a ex:Parametro ;
    rdfs:label "AXISNAME 1" ;
    ex:textoExtracto "AXISNAME 1 | Número lógico ꞏ1ꞏ."@es ;
    ex:valor "1" ;
    ex:documentadoEn ex:TablaConfiguracionEjes .

ex:Parametro_AXISNAME_2
    a ex:Parametro ;
    rdfs:label "AXISNAME 2" ;
    ex:textoExtracto "AXISNAME 2 | Número lógico ꞏ2ꞏ."@es ;
    ex:valor "2" ;
    ex:documentadoEn ex:TablaConfiguracionEjes .

ex:Parametro_AXISNAME_n
    a ex:Parametro ;
    rdfs:label "AXISNAME n" ;
    ex:textoExtracto "AXISNAME n | Orden lógico."@es ;
    ex:documentadoEn ex:TablaConfiguracionEjes .