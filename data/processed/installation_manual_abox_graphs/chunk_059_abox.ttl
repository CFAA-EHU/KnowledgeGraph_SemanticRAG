@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaEjesTandem a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de ejes o cabezales tándem"@es ;
    ex:textoExtracto "TANDEM Tabla de ejes o cabezales tándem. Este parámetro muestra la tabla para definir las parejas tándem del sistema."@es ;
    ex:identificador "TANDEM" .

ex:SistemaTandem
    a ex:Sistema ;
    rdfs:label "Sistema tándem"@es ;
    ex:textoExtracto "Un eje tándem consiste en dos accionamientos eléctricos (motores) acoplados mecánicamente entre sí formando un único sistema de transmisión (eje o cabezal)."@es ;
    ex:documentadoEn ex:TablaEjesTandem .

ex:AccionamientoElectrico1
    a ex:ComponenteElectrico ;
    rdfs:label "Accionamiento eléctrico (motor) en sistema tándem"@es ;
    ex:textoExtracto "dos accionamientos eléctricos (motores) acoplados mecánicamente entre sí"@es .

ex:AccionamientoElectrico2
    a ex:ComponenteElectrico ;
    rdfs:label "Accionamiento eléctrico (motor) en sistema tándem"@es ;
    ex:textoExtracto "dos accionamientos eléctricos (motores) acoplados mecánicamente entre sí"@es .

ex:SistemaTandem
    ex:tieneComponente ex:AccionamientoElectrico1 , ex:AccionamientoElectrico2 ;
    ex:compuestoPor ex:AccionamientoElectrico1 , ex:AccionamientoElectrico2 .

ex:ReguladorV6_14
    a ex:ComponenteElectrico ;
    rdfs:label "Regulador V6.14"@es ;
    ex:textoExtracto "La gestión de cabezales y ejes tándem requiere una versión del regulador V6.14 o superior."@es ;
    ex:identificador "V6.14" .