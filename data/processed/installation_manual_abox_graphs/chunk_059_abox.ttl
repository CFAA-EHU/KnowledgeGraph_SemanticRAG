@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceDePosicionamientoDelEjeIndependiente a ns1:Parametro ;
    rdfs:label "Avance de posicionamiento del eje independiente" ;
    ns1:identificador "POSFEED" ;
    ns1:textoExtracto "POSFEED | Avance de posicionamiento del eje independiente." .

ns1:AvanceDeReposicionamientoTrasUnaInspeccionDeHerramienta a ns1:Parametro ;
    rdfs:label "Avance de reposicionamiento tras una inspección de herramienta" ;
    ns1:identificador "REPOSFEED" ;
    ns1:textoExtracto "REPOSFEED | Avance de reposicionamiento tras una inspección de herramienta." .

ns1:ModoDeTrabajoManualAceleracionMaximaEnManual a ns1:Parametro ;
    rdfs:label "Modo de trabajo manual. Aceleración máxima en manual" ;
    ns1:identificador "MAXMANACC" ;
    ns1:textoExtracto "MAXMANACC | Modo de trabajo manual. Aceleración máxima en manual." .

ns1:ModoDeTrabajoManualAvanceEnModoJogContinuo a ns1:Parametro ;
    rdfs:label "Modo de trabajo manual. Avance en modo jog continuo" ;
    ns1:identificador "JOGFEED" ;
    ns1:textoExtracto "JOGFEED | Modo de trabajo manual. Avance en modo jog continuo." .

ns1:ModoDeTrabajoManualAvanceMaximoEnModoJogContinuo a ns1:Parametro ;
    rdfs:label "Modo de trabajo manual. Avance máximo en modo jog continuo" ;
    ns1:identificador "MAXMANFEED" ;
    ns1:textoExtracto "MAXMANFEED | Modo de trabajo manual. Avance máximo en modo jog continuo." .

ns1:ModoDeTrabajoManualAvanceRapidoEnModoJogContinuo a ns1:Parametro ;
    rdfs:label "Modo de trabajo manual. Avance rápido en modo jog continuo" ;
    ns1:identificador "JOGRAPFEED" ;
    ns1:textoExtracto "JOGRAPFEED | Modo de trabajo manual. Avance rápido en modo jog continuo." .

