@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceleracionMaximaEnManual a ns1:Parametro ;
    rdfs:label "Aceleración máxima en manual" ;
    ns1:identificador "MAXMANACC" ;
    ns1:textoExtracto "Modo de trabajo manual. Aceleración máxima en manual." .

ns1:AvanceEnModoJogIncremental a ns1:Parametro ;
    rdfs:label "Avance en modo jog incremental" ;
    ns1:identificador "INCJOGFEED" ;
    ns1:textoExtracto "Modo de trabajo manual. Avance en modo jog incremental." .

ns1:AvanceMaximoEnModoJogContinuo a ns1:Parametro ;
    rdfs:label "Avance máximo en modo jog continuo" ;
    ns1:identificador "MAXMANFEED" ;
    ns1:textoExtracto "Modo de trabajo manual. Avance máximo en modo jog continuo." .

