@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:EjeTandem_60_1 a ex:ComponenteMecanico ;
    ex:textoExtracto "Eje tándem compuesto por dos piñones (pinion) y una cremallera (rack)" .

ex:MotorPrincipal_60_1 a ex:ComponenteElectrico ;
    ex:textoExtracto "motor principal" .

ex:MotorEsclavo_60_1 a ex:ComponenteElectrico ;
    ex:textoExtracto "motor esclavo" .

ex:SistemaTandem_60_1 a ex:Sistema ;
    ex:textoExtracto "sistema tándem" ;
    ex:compuestoPor ex:EjeTandem_60_1 ;
    ex:tieneComponente ex:MotorPrincipal_60_1, ex:MotorEsclavo_60_1 ;
    ex:detalladoEnEsquema ex:EsquemaTandem_60_1 .

ex:EsquemaTandem_60_1 a ex:Esquema ;
    ex:textoExtracto "Ejemplo de un eje tándem compuesto por dos piñones (pinion) y una cremallera (rack)" .