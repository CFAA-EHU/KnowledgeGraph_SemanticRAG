@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivacionDeLaAlarmaDeCaptacion a ns1:Parametro ;
    rdfs:label "Activación de la alarma de captación" ;
    ns1:identificador "FBACKAL" ;
    ns1:textoExtracto "FBACKAL | Activación de la alarma de captación. La alarma de captación debe estar activada." .

ns1:AvanceEnG00 a ns1:Parametro ;
    rdfs:label "Avance en G00" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "G00FEED | Avance en G00." .

ns1:ErrorPorcentualPermitidoParaLaMonitorizacionLineal a ns1:Parametro ;
    rdfs:label "Error porcentual permitido para la monitorización lineal" ;
    ns1:identificador "FEDYNFAC" ;
    ns1:textoExtracto "FEDYNFAC | Para una monitorización \"lineal\" del error de seguimiento, este parámetro indica el error porcentual permitido, desviación del error de seguimiento real respecto al teórico." .

ns1:MaximoAvanceParaElMecanizado a ns1:Parametro ;
    rdfs:label "Máximo avance para el mecanizado" ;
    ns1:identificador "MAXFEED" ;
    ns1:textoExtracto "MAXFEED | Máximo avance para el mecanizado. Se recomienda definir este parámetro con un valor distinto de ꞏ0ꞏ." .

ns1:MaximoErrorDeSeguimientoPermitidoCuandoElEjeEstaEnMovimiento a ns1:Parametro ;
    rdfs:label "Máximo error de seguimiento permitido cuando el eje está en movimiento" ;
    ns1:identificador "MAXFLWE" ;
    ns1:textoExtracto "MAXFLWE | Para una monitorización \"standard\" del error de seguimiento, este parámetro indica el máximo error de seguimiento permitido cuando el eje está en movimiento." .

ns1:MaximoErrorDeSeguimientoPermitidoCuandoElEjeEstaParado a ns1:Parametro ;
    rdfs:label "Máximo error de seguimiento permitido cuando el eje está parado" ;
    ns1:identificador "MINFLWE" ;
    ns1:textoExtracto "MINFLWE | Este parámetro indica el máximo error de seguimiento permitido cuando el eje está parado." .

ns1:TipoDeMonitorizacionDelErrorDeSeguimiento_60c7e14d93 a ns1:Parametro ;
    rdfs:label "Tipo de monitorización del error de seguimiento" ;
    ns1:identificador "FLWEMONITOR" ;
    ns1:textoExtracto "FLWEMONITOR | Tipo de monitorización del error de seguimiento. La monitorización debe estar activada." .

