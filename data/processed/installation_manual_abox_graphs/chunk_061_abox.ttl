@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Tabla61 a ex:Tabla ;
    ex:textoExtracto "Este parámetro muestra la tabla de parámetros para definir las parejas tándem del sistema. Cada pareja tándem dispone de los siguientes parámetros máquina para su configuración. | TANDEM |  | MASTERAXIS | Pareja tándem. Eje/cabezal maestro o principal. | SLAVEAXIS | Pareja tándem. Eje/cabezal esclavo. | TORQDIST | Pareja tándem. Distribución del par."@es .

ex:MASTERAXIS a ex:Parametro ;
    ex:textoExtracto "Pareja tándem. Eje/cabezal maestro o principal."@es ;
    rdfs:label "MASTERAXIS"@es .

ex:SLAVEAXIS a ex:Parametro ;
    ex:textoExtracto "Pareja tándem. Eje/cabezal esclavo."@es ;
    rdfs:label "SLAVEAXIS"@es .

ex:TORQDIST a ex:Parametro ;
    ex:textoExtracto "Pareja tándem. Distribución del par."@es ;
    rdfs:label "TORQDIST"@es .

ex:Tabla61 a ex:Tabla ;
    ex:tieneComponente ex:MASTERAXIS, ex:SLAVEAXIS, ex:TORQDIST .