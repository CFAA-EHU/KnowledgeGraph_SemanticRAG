@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:configuracionTandem_62
    a ex:Sistema ;
    rdfs:label "Configuración de sistema tándem"@es ;
    ex:textoExtracto "PRELOAD | Pareja tándem. Precarga entre ambos motores. [...] TORQMODE | Pareja tándem. Modo de control de par."@es ;
    ex:tieneComponente
        ex:param_PRELOAD_62,
        ex:param_PRELFITI_62,
        ex:param_TPROGAIN_62,
        ex:param_TINTIME_62,
        ex:param_TCOMPLIM_62,
        ex:param_TORQMODE_62 .

ex:param_PRELOAD_62
    a ex:Parametro ;
    rdfs:label "PRELOAD" ;
    ex:identificador "PRELOAD" ;
    ex:textoExtracto "Pareja tándem. Precarga entre ambos motores."@es .

ex:param_PRELFITI_62
    a ex:Parametro ;
    rdfs:label "PRELFITI" ;
    ex:identificador "PRELFITI" ;
    ex:textoExtracto "Pareja tándem. Tiempo del filtro para aplicar la precarga."@es .

ex:param_TPROGAIN_62
    a ex:Parametro ;
    rdfs:label "TPROGAIN" ;
    ex:identificador "TPROGAIN" ;
    ex:textoExtracto "Pareja tándem. Ganancia proporcional (Kp) para el tándem."@es .

ex:param_TINTIME_62
    a ex:Parametro ;
    rdfs:label "TINTIME" ;
    ex:identificador "TINTIME" ;
    ex:textoExtracto "Pareja tándem. Ganancia integral (Ki) para el tándem."@es .

ex:param_TCOMPLIM_62
    a ex:Parametro ;
    rdfs:label "TCOMPLIM" ;
    ex:identificador "TCOMPLIM" ;
    ex:textoExtracto "Pareja tándem. Límite de la compensación."@es .

ex:param_TORQMODE_62
    a ex:Parametro ;
    rdfs:label "TORQMODE" ;
    ex:identificador "TORQMODE" ;
    ex:textoExtracto "Pareja tándem. Modo de control de par."@es .