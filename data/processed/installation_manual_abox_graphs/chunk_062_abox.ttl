@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TANDEM a ex:Sistema ;
    ex:textoExtracto "TANDEM" ;
    ex:tieneComponente ex:PRELOAD, ex:PRELFITI, ex:TPROGAIN, ex:TINTIME, ex:TCOMPLIM, ex:TORQMODE .

ex:PRELOAD a ex:Parametro ;
    ex:textoExtracto "PRELOAD. Pareja tándem. Precarga entre ambos motores." ;
    ex:valor "Pareja tándem. Precarga entre ambos motores." .

ex:PRELFITI a ex:Parametro ;
    ex:textoExtracto "PRELFITI. Pareja tándem. Tiempo del filtro para aplicar la precarga." ;
    ex:valor "Pareja tándem. Tiempo del filtro para aplicar la precarga." .

ex:TPROGAIN a ex:Parametro ;
    ex:textoExtracto "TPROGAIN. Pareja tándem. Ganancia proporcional (Kp) para el tándem." ;
    ex:valor "Pareja tándem. Ganancia proporcional (Kp) para el tándem." .

ex:TINTIME a ex:Parametro ;
    ex:textoExtracto "TINTIME. Pareja tándem. Ganancia integral (Ki) para el tándem." ;
    ex:valor "Pareja tándem. Ganancia integral (Ki) para el tándem." .

ex:TCOMPLIM a ex:Parametro ;
    ex:textoExtracto "TCOMPLIM. Pareja tándem. Límite de la compensación." ;
    ex:valor "Pareja tándem. Límite de la compensación." .

ex:TORQMODE a ex:ModoOperacion ;
    ex:textoExtracto "TORQMODE. Pareja tándem. Modo de control de par." ;
    ex:valor "Pareja tándem. Modo de control de par." .