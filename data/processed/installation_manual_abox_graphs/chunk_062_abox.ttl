@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_f8fb67d890 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC puede disponer de un único canal de ejecución (sistema monocanal) o de varios (sistema multicanal)." .

ns1:NumeroDeCanalesDelCNC a ns1:Parametro ;
    rdfs:label "Número de canales del CNC" ;
    ns1:identificador "MPG.NCHANNEL" ;
    ns1:textoExtracto "NCHANNEL Número de canales del CNC. Valores posibles: De 1 a 4. Valor por defecto: 1." .

