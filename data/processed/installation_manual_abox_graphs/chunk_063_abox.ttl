@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_febf81e945 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Los ejes y cabezales de un canal. Un canal puede disponer de un grupo de ejes y cabezales que actúen de forma independiente o en paralelo al resto de canales." ;
    ns1:tieneComponente ns1:CabezalCanal,
        ns1:EjeCanal .

ns1:ConfiguracionDeCanales a ns1:Parametro ;
    rdfs:label "Configuración de canales" ;
    ns1:textoExtracto "Un canal puede disponer de un grupo de ejes y cabezales que actúen de forma independiente o en paralelo al resto de canales." .

ns1:CabezalCanal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal del Canal" ;
    ns1:textoExtracto "Para poder mover un eje o cabezal, éste debe estar asignado a un canal." .

ns1:EjeCanal a ns1:ComponenteMecanico ;
    rdfs:label "Eje del Canal" ;
    ns1:textoExtracto "Para poder mover un eje o cabezal, éste debe estar asignado a un canal." .

