@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_ParTandem_Maestro
    a ex:Parametro ;
    rdfs:label "Parámetro de porcentaje de par para motor maestro en sistema tándem" ;
    ex:textoExtracto "Este parámetro establece el porcentaje de par que realiza cada motor para conseguir el par total necesario en el tándem. El parámetro indica qué porcentaje debe dar el motor maestro." ;
    ex:valor "50%"^^xsd:string .

ex:Parametro_PreloadTandem
    a ex:Parametro ;
    rdfs:label "Precarga entre motores en sistema tándem (PRELOAD)" ;
    ex:identificador "MPG.PRELOAD[nb]" ;
    ex:textoExtracto "PRELOAD Pareja tándem. Precarga entre ambos motores. Valores posibles: Entre ±100%. Valor por defecto: 0 (se deshabilita la precarga)." ;
    ex:valor "0"^^xsd:string .

ex:SistemaTandem
    a ex:Sistema ;
    rdfs:label "Sistema de configuración tándem de motores" ;
    ex:textoExtracto "Configuración de un sistema tándem... Este parámetro establece el porcentaje de par que realiza cada motor para conseguir el par total necesario en el tándem." ;
    ex:tieneComponente ex:Motor_Maestro, ex:Motor_Esclavo ;
    ex:monitoreaParametro ex:Parametro_ParTandem_Maestro, ex:Parametro_PreloadTandem .

ex:Motor_Maestro
    a ex:ComponenteMecanico ;
    rdfs:label "Motor maestro en sistema tándem" ;
    ex:textoExtracto "El parámetro indica qué porcentaje debe dar el motor maestro." .

ex:Motor_Esclavo
    a ex:ComponenteMecanico ;
    rdfs:label "Motor esclavo en sistema tándem" ;
    ex:textoExtracto "La diferencia entre el valor de este parámetro y el 100% es el porcentaje que se aplicará al motor esclavo." .