@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MotorMaestro a ex:ComponenteMecanico ;
    rdfs:label "motor maestro" ;
    ex:textoExtracto "El parámetro indica qué porcentaje debe dar el motor maestro."@es .

ex:MotorEsclavo a ex:ComponenteMecanico ;
    rdfs:label "motor esclavo" ;
    ex:textoExtracto "la diferencia entre el valor de este parámetro y el 100% es el porcentaje que se aplicará al motor esclavo."@es .

ex:ParametroParTandem a ex:Parametro ;
    rdfs:label "par tándem" ;
    ex:textoExtracto "Este parámetro establece el porcentaje de par que realiza cada motor para conseguir el par total necesario en el tándem."@es .

ex:ParametroPRELOAD a ex:Parametro ;
    rdfs:label "PRELOAD" ;
    ex:identificador "MPG.PRELOAD[nb]" ;
    ex:textoExtracto "Pareja tándem. Precarga entre ambos motores. Valores posibles: Entre ±100%. Valor por defecto: 0 (se deshabilita la precarga)."@es .