@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ListaDeEjesDelSistema a ns1:Parametro ;
    rdfs:label "Lista de ejes del sistema" ;
    ns1:documentadoEn ns1:TablaEjes ;
    ns1:identificador "MPG.AXISNAMEn" ;
    ns1:textoExtracto "AXISNAME Lista de ejes del sistema. Este parámetro muestra la tabla para definir los nombres de los ejes." .

ns1:NumeroDeEjesQueGobiernaElCNC a ns1:Parametro ;
    rdfs:label "Número de ejes que gobierna el CNC" ;
    ns1:documentadoEn ns1:TablaEjes ;
    ns1:identificador "MPG.NAXIS" ;
    ns1:textoExtracto "NAXIS Número de ejes que gobierna el CNC. Valores posibles: De 1 a 32. Valor por defecto: 3." .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:TablaEjes a ns1:Tabla ;
    rdfs:label "Tabla AXISNAME" ;
    ns1:ilustradoEn ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "| AXISNAME n | Nombre de los ejes. |" .

