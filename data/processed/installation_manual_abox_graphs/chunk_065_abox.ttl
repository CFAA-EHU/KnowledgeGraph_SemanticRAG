@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MPG.PRELOAD a ex:Parametro ;
    rdfs:label "MPG.PRELOAD" ;
    ex:identificador "(V.)MPG.PRELOAD[nb]" ;
    ex:textoExtracto "Parámetro incluido en la tabla TANDEM. La precarga es el par previo que se aplica , en sentidos opuestos, a ambos motores del tándem para establecer una tracción entre ellos con el fin de eliminar la holgura cuando el tándem se encuentra en reposo. El parámetro indica qué porcentaje del par nominal del motor maestro se aplicará como precarga." ;
    ex:valor "Entre ±100%. Valor por defecto: 0 (se deshabilita la precarga)" .

ex:MPG.PRELFITI a ex:Parametro ;
    rdfs:label "MPG.PRELFITI" ;
    ex:identificador "(V.)MPG.PRELFITI[nb]" ;
    ex:textoExtracto "Parámetro incluido en la tabla TANDEM. Filtro de primer orden que establece el tiempo que tarda el CNC en aplicar la precarga de forma progresiva. El filtro elimina los escalones de par en la entrada del compensador tándem cuando se parametriza un valor de precarga, evitando así un escalón en la consigna de velocidad del motor maestro y del motor esclavo del tándem." ;
    ex:valor "De 0 a 65535 milisegundos (con valor 0, se deshabilita el filtro). Valor por defecto: 0 ms" .

ex:MPG.TPROGAIN a ex:Parametro ;
    rdfs:label "MPG.TPROGAIN" ;
    ex:identificador "(V.)MPG.TPROGAIN[nb]" ;
    ex:textoExtracto "Parámetro incluido en la tabla TANDEM." ;
    ex:valor "De 0 a 100%. Valor por defecto: 0 (no se aplica ganancia proporcional)" .

ex:TablaTANDEM a ex:Tabla ;
    ex:textoExtracto "Parámetro incluido en la tabla TANDEM." ;
    ex:tieneComponente ex:MPG.PRELOAD, ex:MPG.PRELFITI, ex:MPG.TPROGAIN .

ex:MotorMaestro a ex:ComponenteMecanico ;
    rdfs:label "motor maestro" ;
    ex:textoExtracto "ambos motores del tándem ... par nominal del motor maestro" .

ex:MotorEsclavo a ex:ComponenteMecanico ;
    rdfs:label "motor esclavo" ;
    ex:textoExtracto "motor esclavo del tándem" .

ex:SistemaTandem a ex:Sistema ;
    ex:textoExtracto "Pareja tándem. Precarga entre ambos motores ... forman el tándem" ;
    ex:tieneComponente ex:MotorMaestro, ex:MotorEsclavo, ex:MPG.PRELOAD, ex:MPG.PRELFITI, ex:MPG.TPROGAIN .