@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaReguladorV614 a ns1:Sistema ;
    rdfs:label "Sistema Regulador V6.14" ;
    ns1:textoExtracto "La gestión de cabezales y ejes tándem requiere una versión del regulador V6.14 o superior." .

ns1:SistemaTandem a ns1:Sistema ;
    rdfs:label "Sistema Tándem" ;
    ns1:textoExtracto "Un eje tándem consiste en dos accionamientos eléctricos (motores) acoplados mecánicamente entre sí formando un único sistema de transmisión (eje o cabezal)." .

ns1:TablaDeEjesOCabezalesTandem a ns1:Parametro ;
    rdfs:label "Tabla de ejes o cabezales tándem" ;
    ns1:textoExtracto "Este parámetro muestra la tabla para definir las parejas tándem del sistema." .

