@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MotorMaestro a ex:ComponenteMecanico ;
    ex:textoExtracto "T.mst Par del motor maestro." ;
    rdfs:label "Motor maestro" .

ex:MotorEsclavo a ex:ComponenteMecanico ;
    ex:textoExtracto "T.slv Par del motor esclavo." ;
    rdfs:label "Motor esclavo" .

ex:TablaTandem a ex:Tabla ;
    ex:textoExtracto "Parámetro incluido en la tabla TANDEM" ;
    rdfs:label "Tabla TANDEM" .

ex:ParametroTINTTIME a ex:Parametro ;
    ex:identificador "TINTTIME" ;
    ex:textoExtracto "TINTTIME Pareja tándem. Ganancia integral (Ki) para el tándem. Valores posibles: De 0 a 65535 milisegundos. Valor por defecto: 0 (no se aplica ganancia integral). Variable asociada: (V.)MPG.TINTTIME[nb] Parámetro incluido en la tabla TANDEM." ;
    rdfs:label "Parámetro TINTTIME" .

ex:ParametroTCOMPLIM a ex:Parametro ;
    ex:identificador "TCOMPLIM" ;
    ex:textoExtracto "TCOMPLIM Pareja tándem. Límite de la compensación. Valores posibles: De 0 a 100%. Valor por defecto: 0 (se deshabilita el eje tándem). Variable asociada: (V.)MPG.TCOMPLIM[nb] Parámetro incluido en la tabla TANDEM." ;
    rdfs:label "Parámetro TCOMPLIM" .

ex:ParametroKp a ex:Parametro ;
    ex:identificador "Kp" ;
    ex:textoExtracto "Kp Ganancia proporcional." ;
    rdfs:label "Parámetro Kp" .

ex:ParametroKi a ex:Parametro ;
    ex:identificador "Ki" ;
    ex:textoExtracto "Ki Ganancia integral." ;
    rdfs:label "Parámetro Ki" .

ex:ParametroTnom a ex:Parametro ;
    ex:identificador "T.nom" ;
    ex:textoExtracto "T.nom Par nominal." ;
    rdfs:label "Parámetro T.nom" .

ex:ParametroTerr a ex:Parametro ;
    ex:identificador "T.err" ;
    ex:textoExtracto "T.err Error de par entre motores. T.err = (–T.mst+T.slv+PRELOAD)" ;
    rdfs:label "Parámetro T.err" .

ex:ParametroPRELOAD a ex:Parametro ;
    ex:identificador "PRELOAD" ;
    ex:textoExtracto "T.err = (–T.mst+T.slv+PRELOAD)" ;
    rdfs:label "Parámetro PRELOAD" .

ex:TablaTandem a ex:Tabla ;
    ex:tieneComponente ex:ParametroTINTTIME, ex:ParametroTCOMPLIM .