@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaTandemConfiguracion a ns1:Sistema ;
    rdfs:label "Sistema Tándem" ;
    ns1:textoExtracto "Esta configuración permite resaltar los siguientes aspectos:" ;
    ns1:tieneComponente ns1:EjeEsclavo,
        ns1:EjeMaestro .

ns1:EjeEsclavo a ns1:ComponenteMecanico ;
    rdfs:label "Eje Esclavo" ;
    ns1:textoExtracto "Cada eje (cabezal) tándem maestro admite un único eje (cabezal) tándem esclavo." ;
    ns1:tieneComponente ns1:LimiteInferiorDeSoftware,
        ns1:LimiteSuperiorDeSoftware,
        ns1:ModoDeEje,
        ns1:PermisoDeCambioDeCanal,
        ns1:RutaMasCorta,
        ns1:TipoDeControlador,
        ns1:TipoDeEje_4a526239b6,
        ns1:VelocidadLentaDeBusquedaDeReferencia,
        ns1:VelocidadRapidaDeBusquedaDeReferencia .

ns1:EjeMaestro a ns1:ComponenteMecanico ;
    rdfs:label "Eje Maestro" ;
    ns1:textoExtracto "Cada eje (cabezal) tándem maestro admite un único eje (cabezal) tándem esclavo." ;
    ns1:tieneComponente ns1:LimiteInferiorDeSoftware,
        ns1:LimiteSuperiorDeSoftware,
        ns1:ModoDeEje,
        ns1:PermisoDeCambioDeCanal,
        ns1:RutaMasCorta,
        ns1:TipoDeControlador,
        ns1:TipoDeEje_4a526239b6,
        ns1:VelocidadLentaDeBusquedaDeReferencia,
        ns1:VelocidadRapidaDeBusquedaDeReferencia .

ns1:LimiteInferiorDeSoftware a ns1:Parametro ;
    rdfs:label "Límite inferior de software" ;
    ns1:textoExtracto "Ambos ejes deberán tener los mismos límites de software (parámetros LIMIT+ y LIMIT- iguales para ambos ejes)." .

ns1:LimiteSuperiorDeSoftware a ns1:Parametro ;
    rdfs:label "Límite superior de software" ;
    ns1:textoExtracto "Ambos ejes deberán tener los mismos límites de software (parámetros LIMIT+ y LIMIT- iguales para ambos ejes)." .

ns1:ModoDeEje a ns1:Parametro ;
    rdfs:label "Modo de eje" ;
    ns1:textoExtracto "Cuando los ejes sean rotativos, ambos ejes deberán ser del mismo tipo (parámetros AXISMODE y SHORTESTWAY iguales para ambos ejes)." .

ns1:PermisoDeCambioDeCanal a ns1:Parametro ;
    rdfs:label "Permiso de cambio de canal" ;
    ns1:textoExtracto "El permiso de cambio de canal (parámetro AXISEXCH) deberá ser igual en ambos ejes." .

ns1:RutaMasCorta a ns1:Parametro ;
    rdfs:label "Ruta más corta" ;
    ns1:textoExtracto "Cuando los ejes sean rotativos, ambos ejes deberán ser del mismo tipo (parámetros AXISMODE y SHORTESTWAY iguales para ambos ejes)." .

ns1:TipoDeControlador a ns1:Parametro ;
    rdfs:label "Tipo de controlador" ;
    ns1:textoExtracto "Ambos ejes y reguladores deberán ser del mismo tipo (parámetros AXISTYPE y DRIVETYPE iguales para ambos ejes)." .

ns1:TipoDeEje_4a526239b6 a ns1:Parametro ;
    rdfs:label "Tipo de eje" ;
    ns1:textoExtracto "Ambos ejes y reguladores deberán ser del mismo tipo (parámetros AXISTYPE y DRIVETYPE iguales para ambos ejes)." .

ns1:VelocidadLentaDeBusquedaDeReferencia a ns1:Parametro ;
    rdfs:label "Velocidad lenta de búsqueda de referencia" ;
    ns1:textoExtracto "La velocidad rápida y lenta de búsqueda de referencia máquina (parámetros REFFEED1 y REFFEED2) deberá ser igual en ambos ejes." .

ns1:VelocidadRapidaDeBusquedaDeReferencia a ns1:Parametro ;
    rdfs:label "Velocidad rápida de búsqueda de referencia" ;
    ns1:textoExtracto "La velocidad rápida y lenta de búsqueda de referencia máquina (parámetros REFFEED1 y REFFEED2) deberá ser igual en ambos ejes." .

