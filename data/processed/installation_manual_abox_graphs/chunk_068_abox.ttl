@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaTandem a ns1:Sistema ;
    rdfs:label "Sistema Tándem" ;
    ns1:textoExtracto "Este parámetro muestra la tabla de parámetros para definir las parejas tándem del sistema." ;
    ns1:tieneComponente ns1:ParejaTandemDistribucionDelPar,
        ns1:ParejaTandemEjeCabezalEsclavo,
        ns1:ParejaTandemEjeCabezalMaestroOPrincipal .

ns1:ParejaTandemDistribucionDelPar a ns1:Parametro ;
    rdfs:label "Pareja tándem. Distribución del par." ;
    ns1:identificador "TORQDIST" ;
    ns1:textoExtracto "TORQDIST | Pareja tándem. Distribución del par." .

ns1:ParejaTandemEjeCabezalEsclavo a ns1:Parametro ;
    rdfs:label "Pareja tándem. Eje/cabezal esclavo." ;
    ns1:identificador "SLAVEAXIS" ;
    ns1:textoExtracto "SLAVEAXIS | Pareja tándem. Eje/cabezal esclavo." .

ns1:ParejaTandemEjeCabezalMaestroOPrincipal a ns1:Parametro ;
    rdfs:label "Pareja tándem. Eje/cabezal maestro o principal." ;
    ns1:identificador "MASTERAXIS" ;
    ns1:textoExtracto "MASTERAXIS | Pareja tándem. Eje/cabezal maestro o principal." .

