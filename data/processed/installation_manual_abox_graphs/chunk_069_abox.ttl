@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TablaGantryEjes a ex:Tabla ;
    rdfs:label "Tabla de ejes gantry"@es ;
    ex:textoExtracto "Tabla de ejes gantry. Este parámetro muestra la tabla para definir los ejes gantry del sistema."@es ;
    ex:tieneComponente ex:EjeGantryMaestro, ex:EjeGantryEsclavo .

ex:EjeGantryMaestro a ex:ComponenteMecanico ;
    rdfs:label "eje gantry maestro"@es ;
    ex:textoExtracto "eje gantry maestro"@es .

ex:EjeGantryEsclavo a ex:ComponenteMecanico ;
    rdfs:label "eje gantry esclavo"@es ;
    ex:textoExtracto "eje gantry esclavo"@es .

ex:SistemaCNC a ex:Sistema ;
    rdfs:label "CNC"@es ;
    ex:textoExtracto "En el CNC"@es ;
    ex:controla ex:EjeGantryMaestro .

ex:FresadoraPuente a ex:Maquina ;
    rdfs:label "fresadora puente"@es ;
    ex:textoExtracto "Ejemplo de una fresadora puente con dos ejes gantry, X-U Z-W."@es ;
    ex:tieneComponente ex:EjeGantryMaestro_2, ex:EjeGantryEsclavo_2 .

ex:EjeGantryMaestro_2 a ex:ComponenteMecanico ;
    rdfs:label "eje gantry maestro X"@es ;
    ex:textoExtracto "X"@es .

ex:EjeGantryEsclavo_2 a ex:ComponenteMecanico ;
    rdfs:label "eje gantry esclavo U"@es ;
    ex:textoExtracto "U"@es .

ex:EjeGantryMaestro_3 a ex:ComponenteMecanico ;
    rdfs:label "eje gantry maestro Z"@es ;
    ex:textoExtracto "Z"@es .

ex:EjeGantryEsclavo_3 a ex:ComponenteMecanico ;
    rdfs:label "eje gantry esclavo W"@es ;
    ex:textoExtracto "W"@es .