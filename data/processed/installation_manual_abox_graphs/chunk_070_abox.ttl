@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_345b633aaf a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC cierra el lazo de posición únicamente con la posición del eje maestro del tándem." .

ns1:DistribucionDelParEnLaParejaTandem a ns1:Parametro ;
    rdfs:label "Distribución del par en la pareja tándem" ;
    ns1:identificador "MPG.TORQDIST" ;
    ns1:textoExtracto "Este parámetro establece el porcentaje de par que realiza cada motor para conseguir el par total necesario en el tándem." .

ns1:EjeCabezalEsclavoDeLaParejaTandem a ns1:Parametro ;
    rdfs:label "Eje/cabezal esclavo de la pareja tándem" ;
    ns1:identificador "MPG.TSLAVEAXIS" ;
    ns1:textoExtracto "Este parámetro establece cuál es el eje o cabezal esclavo de la pareja tándem." .

ns1:EjeCabezalMaestroOPrincipalDeLaParejaTandem a ns1:Parametro ;
    rdfs:label "Eje/cabezal maestro o principal de la pareja tándem" ;
    ns1:identificador "MPG.TMASTERAXIS" ;
    ns1:textoExtracto "Este parámetro establece cuál es el eje o cabezal maestro de la pareja tándem." .

