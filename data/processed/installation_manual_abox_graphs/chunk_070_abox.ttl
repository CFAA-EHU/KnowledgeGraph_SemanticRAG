@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_DECINPUT a ex:Parametro ;
    rdfs:label "DECINPUT" ;
    ex:textoExtracto "parámetro DECINPUT" ;
    ex:valor "DECINPUT" .

ex:Parametro_REFFEED1 a ex:Parametro ;
    rdfs:label "REFFEED1" ;
    ex:textoExtracto "parámetros REFFEED1" ;
    ex:valor "REFFEED1" .

ex:Parametro_REFFEED2 a ex:Parametro ;
    rdfs:label "REFFEED2" ;
    ex:textoExtracto "parámetros REFFEED2" ;
    ex:valor "REFFEED2" .

ex:Parametro_GANTRY_n a ex:Parametro ;
    rdfs:label "GANTRY n" ;
    ex:textoExtracto "parámetro GANTRY n" ;
    ex:valor "GANTRY n" .

ex:Tabla_ConfiguracionEjesGantry a ex:Tabla ;
    ex:textoExtracto "tabla de parámetros para definir los ejes gantry del sistema" ;
    ex:detalladoEnEsquema ex:Parametro_GANTRY_n .