@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ParametroGantryConfiguracion a ex:Parametro ;
    rdfs:label "Configuración de los ejes gantry" ;
    ex:textoExtracto "Este parámetro muestra la tabla de parámetros para definir los ejes gantry del sistema." ;
    ex:valor "tabla de parámetros para definir los ejes gantry" .

ex:TablaParametrosGantry a ex:Tabla ;
    ex:textoExtracto "Este parámetro muestra la tabla de parámetros para definir los ejes gantry del sistema." ;
    ex:detalladoEnEsquema ex:ParametroGantryConfiguracion .

ex:EjeGantry a ex:Maquina ;
    ex:textoExtracto "Cada uno de los ejes gantry dispone de los siguientes parámetros máquina para su configuración." ;
    ex:compuestoPor ex:ParametroGantryConfiguracion .