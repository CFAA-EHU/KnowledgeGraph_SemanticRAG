@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ConfiguracionEjeGantry
    a ex:Sistema ;
    rdfs:label "Configuración de un eje gantry"@es ;
    ex:textoExtracto "MASTERAXIS | Eje maestro o principal. SLAVEAXIS | Eje esclavo. WARNCOUPE | Diferencia entre el error de seguimiento de ambos ejes para mostrar un warning."@es ;
    ex:tieneComponente ex:Parametro_MASTERAXIS, ex:Parametro_SLAVEAXIS, ex:Parametro_WARNCOUPE .

ex:Parametro_MASTERAXIS
    a ex:Parametro ;
    rdfs:label "MASTERAXIS" ;
    ex:identificador "MASTERAXIS" ;
    ex:textoExtracto "Eje maestro o principal."@es .

ex:Parametro_SLAVEAXIS
    a ex:Parametro ;
    rdfs:label "SLAVEAXIS" ;
    ex:identificador "SLAVEAXIS" ;
    ex:textoExtracto "Eje esclavo."@es .

ex:Parametro_WARNCOUPE
    a ex:Parametro ;
    rdfs:label "WARNCOUPE" ;
    ex:identificador "WARNCOUPE" ;
    ex:textoExtracto "Diferencia entre el error de seguimiento de ambos ejes para mostrar un warning."@es .