@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaTandem a ns1:Sistema ;
    rdfs:label "Sistema Tándem" ;
    ns1:textoExtracto "Configuración de un sistema tándem." ;
    ns1:tieneComponente ns1:GananciaProporcionalKpParaElTandem_a08a2aeffb,
        ns1:PrecargaEntreAmbosMotores_8d11f14e32,
        ns1:TiempoDelFiltroParaAplicarLaPrecarga_b6173c89dd .

ns1:GananciaProporcionalKpParaElTandem_a08a2aeffb a ns1:Parametro ;
    rdfs:label "Ganancia proporcional (Kp) para el tándem" ;
    ns1:identificador "MPG.TPROGAIN[nb]" ;
    ns1:textoExtracto "Valores posibles: De 0 a 100%. Valor por defecto: 0 (no se aplica ganancia proporcional)." .

ns1:PrecargaEntreAmbosMotores_8d11f14e32 a ns1:Parametro ;
    rdfs:label "Precarga entre ambos motores" ;
    ns1:identificador "MPG.PRELOAD[nb]" ;
    ns1:textoExtracto "Valores posibles: Entre ±100%. Valor por defecto: 0 (se deshabilita la precarga)." .

ns1:TiempoDelFiltroParaAplicarLaPrecarga_b6173c89dd a ns1:Parametro ;
    rdfs:label "Tiempo del filtro para aplicar la precarga" ;
    ns1:identificador "MPG.PRELFITI[nb]" ;
    ns1:textoExtracto "Valores posibles: De 0 a 65535 milisegundos (con valor 0, se deshabilita el filtro). Valor por defecto: 0 ms." .

