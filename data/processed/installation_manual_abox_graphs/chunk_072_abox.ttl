@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:GANTRY a ex:Sistema ;
    ex:textoExtracto "GANTRY" ;
    ex:tieneComponente ex:MASTERAXIS, ex:SLAVEAXIS, ex:WARNCOUPE .

ex:MASTERAXIS a ex:ComponenteMecanico ;
    rdfs:label "Eje maestro o principal" ;
    ex:textoExtracto "MASTERAXIS | Eje maestro o principal." .

ex:SLAVEAXIS a ex:ComponenteMecanico ;
    rdfs:label "Eje esclavo" ;
    ex:textoExtracto "SLAVEAXIS | Eje esclavo." .

ex:WARNCOUPE a ex:AvisoSeguridad ;
    rdfs:label "Diferencia entre el error de seguimiento de ambos ejes para mostrar un warning" ;
    ex:textoExtracto "WARNCOUPE | Diferencia entre el error de seguimiento de ambos ejes para mostrar un warning." .