@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaTandem a ns1:Sistema ;
    rdfs:label "Sistema tándem" ;
    ns1:textoExtracto "Configuración de un sistema tándem. Ganancia proporcional (Kp) para el tándem. Valores posibles: De 0 a 100%. Valor por defecto: 0 (no se aplica ganancia proporcional). Variable asociada: (V.)MPG.TPROGAIN[nb] Parámetro incluido en la tabla TANDEM." ;
    ns1:tieneComponente ns1:GananciaProporcionalParaElTandem .

ns1:GananciaProporcionalParaElTandem a ns1:Parametro ;
    rdfs:label "Ganancia proporcional para el tándem" ;
    ns1:identificador "MPG.TPROGAIN[nb]" ;
    ns1:textoExtracto "Ganancia proporcional (Kp) para el tándem. Valores posibles: De 0 a 100%. Valor por defecto: 0 (no se aplica ganancia proporcional). Variable asociada: (V.)MPG.TPROGAIN[nb] Parámetro incluido en la tabla TANDEM." .

