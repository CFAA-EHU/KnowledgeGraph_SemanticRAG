@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MPG_MAXCOUPE
    a ex:Parametro ;
    rdfs:label "MPG.MAXCOUPE[nb]" ;
    ex:identificador "MPG.MAXCOUPE[nb]" ;
    ex:valor "De 0 a 3937.00787 inch / De 0.0001 a 99999.9999 grados" ;
    ex:valor "1.0000 mm / 0.03937 inch / 1.0000 grado"^^ex:valorPorDefecto ;
    ex:textoExtracto "Valores posibles (2): De 0 a 3937.00787 inch. Valores posibles (3): De 0.0001 a 99999.9999 grados. Valor por defecto: 1.0000 mm / 0.03937 inch / 1.0000 grado. Variable asociada: (V.)MPG.MAXCOUPE[nb] Parámetro incluido en la tabla GANTRY." ;
    ex:documentadoEn ex:Tabla_GANTRY .

ex:Parametro_MPG_DIFFCOMP
    a ex:Parametro ;
    rdfs:label "MPG.DIFFCOMP[nb]" ;
    ex:identificador "MPG.DIFFCOMP[nb]" ;
    ex:valor "Sí / No" ;
    ex:valor "Sí"^^ex:valorPorDefecto ;
    ex:textoExtracto "DIFFCOMP Eje gantry. Compensar la diferencia de cota entre ambos ejes tras G74. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)MPG.DIFFCOMP[nb] Parámetro incluido en la tabla GANTRY." ;
    ex:documentadoEn ex:Tabla_GANTRY .

ex:Tabla_GANTRY a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla GANTRY" ;
    ex:textoExtracto "Parámetro incluido en la tabla GANTRY." .