@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CompensacionMaximaDelTandem a ns1:Parametro ;
    rdfs:label "Compensación máxima del tándem" ;
    ns1:identificador "MPG.TCOMPLIM[nb]" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.TCOMPLIM[nb] Parámetro incluido en la tabla TANDEM. Este parámetro limita la compensación máxima que introduce el tándem." .

ns1:ModoDeControlDePar_cb77019b15 a ns1:Parametro ;
    rdfs:label "Modo de control de par" ;
    ns1:identificador "MPG.TORQMODE[nb]" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.TORQMODE[nb] Parámetro incluido en la tabla TANDEM. Este parámetro indica si el CNC tiene en cuenta el par para la gestión del tándem." .

