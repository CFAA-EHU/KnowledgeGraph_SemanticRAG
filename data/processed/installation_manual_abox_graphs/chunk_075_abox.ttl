@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ParametroMPG_MAXCOUPE a ex:Parametro ;
    rdfs:label "MPG.MAXCOUPE" ;
    ex:identificador "(V.)MPG.MAXCOUPE[nb]" ;
    ex:textoExtracto "Parámetro incluido en la tabla GANTRY. Este parámetro indica la máxima diferencia permitida entre los errores de seguimiento de ambos ejes. Si la diferencia supera este valor, el CNC mostrará un error." ;
    ex:valor "De 0 a 3937.00787 inch" .

ex:ParametroDIFFCOMP a ex:Parametro ;
    rdfs:label "DIFFCOMP" ;
    ex:identificador "(V.)MPG.DIFFCOMP[nb]" ;
    ex:textoExtracto "Parámetro incluido en la tabla GANTRY. Este parámetro habilita la corrección de la diferencia de cota entre el eje" ;
    ex:valor "Sí / No" .