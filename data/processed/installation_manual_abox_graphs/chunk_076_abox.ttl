@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjesHirth a ns1:Parametro ;
    rdfs:label "Ejes hirth" ;
    ns1:identificador "HIRTH" ;
    ns1:textoExtracto "Los ejes hirth (parámetro HIRTH = YES) no podrán ser ejes gantry." .

ns1:LimiteInferiorDeSoftware_e707e2f419 a ns1:Parametro ;
    rdfs:label "Límite inferior de software" ;
    ns1:identificador "LIMIT-" ;
    ns1:textoExtracto "Ambos ejes deberán tener los mismos límites de software (parámetros LIMIT+ y LIMIT- iguales para ambos ejes)." .

ns1:LimiteSuperiorDeSoftware_02cbbaf917 a ns1:Parametro ;
    rdfs:label "Límite superior de software" ;
    ns1:identificador "LIMIT+" ;
    ns1:textoExtracto "Ambos ejes deberán tener los mismos límites de software (parámetros LIMIT+ y LIMIT- iguales para ambos ejes)." .

ns1:MicroDeReferencia_b388e4eaf9 a ns1:Parametro ;
    rdfs:label "Micro de referencia" ;
    ns1:identificador "DECINPUT" ;
    ns1:textoExtracto "Cuando el eje gantry no disponga de I0 codificado, podrán tener micro de referencia (parámetro DECINPUT) ambos ejes o sólo el eje maestro." .

ns1:ModoDelEje a ns1:Parametro ;
    rdfs:label "Modo del eje" ;
    ns1:identificador "AXISMODE" ;
    ns1:textoExtracto "Cuando los ejes sean rotativos, ambos ejes deberán ser del mismo tipo (parámetros AXISMODE y SHORTESTWAY iguales para ambos ejes)." .

ns1:PermisoDeCambioDeCanal_2f2435ba9c a ns1:Parametro ;
    rdfs:label "Permiso de cambio de canal" ;
    ns1:identificador "AXISEXCH" ;
    ns1:textoExtracto "El permiso de cambio de canal (parámetro AXISEXCH) deberá ser igual en ambos ejes." .

ns1:RutaMasCorta_58451b2f82 a ns1:Parametro ;
    rdfs:label "Ruta más corta" ;
    ns1:identificador "SHORTESTWAY" ;
    ns1:textoExtracto "Cuando los ejes sean rotativos, ambos ejes deberán ser del mismo tipo (parámetros AXISMODE y SHORTESTWAY iguales para ambos ejes)." .

ns1:SentidoDeGiroUnico a ns1:Parametro ;
    rdfs:label "Sentido de giro único" ;
    ns1:identificador "UNIDIR" ;
    ns1:textoExtracto "Los ejes rotativos con sentido de giro único (parámetro UNIDIR = YES) no podrán ser ejes gantry." .

ns1:TablaDeAXISNAME a ns1:Parametro ;
    rdfs:label "Tabla de AXISNAME" ;
    ns1:identificador "AXISNAME" ;
    ns1:textoExtracto "El eje maestro tiene que estar definido en la tabla de AXISNAME antes que el eje esclavo." .

ns1:TablaEjesGantry a ns1:Tabla ;
    rdfs:label "Tabla de ejes gantry" ;
    ns1:documentadoEn ns1:CNC8070_a3ada72520 ;
    ns1:textoExtracto "GANTRY Tabla de ejes gantry. Este parámetro muestra la tabla para definir los ejes gantry del sistema." .

ns1:TipoDeEje a ns1:Parametro ;
    rdfs:label "Tipo de eje" ;
    ns1:identificador "AXISTYPE" ;
    ns1:textoExtracto "Ambos ejes y reguladores deberán ser del mismo tipo (parámetros AXISTYPE y DRIVETYPE iguales para ambos ejes)." .

ns1:TipoDeI0 a ns1:Parametro ;
    rdfs:label "Tipo de I0" ;
    ns1:identificador "I0TYPE" ;
    ns1:textoExtracto "El tipo de I0 (parámetro I0TYPE) deberá ser en ambos ejes no codificado o en ambos ejes codificado (creciente o decreciente)." .

ns1:TipoDeRegulador a ns1:Parametro ;
    rdfs:label "Tipo de regulador" ;
    ns1:identificador "DRIVETYPE" ;
    ns1:textoExtracto "Ambos ejes y reguladores deberán ser del mismo tipo (parámetros AXISTYPE y DRIVETYPE iguales para ambos ejes)." .

ns1:CNC8070_a3ada72520 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "En el CNC sólo hay que programar los desplazamientos de uno de los ejes (eje gantry maestro o principal)." .

