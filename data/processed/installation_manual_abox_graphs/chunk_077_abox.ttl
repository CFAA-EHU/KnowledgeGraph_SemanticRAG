ex:Tabla_GruposMultieje_77 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de grupos multieje"@es ;
    ex:textoExtracto "Tabla de grupos multieje. Un grupo multieje permite controlar varios ejes con un único regulador, controlando uno o varios motores. Este parámetro muestra la tabla de definición de los grupos multieje, donde hay que definir el número de grupos del sistema y la composición de cada grupo."@es ;
    ex:documentadoEn ex:Pagina_64_65 .

ex:Pagina_64_65
    a ex:Pagina ;
    ex:identificador "64-65" ;
    ex:textoExtracto "2.3.5 Configuración de un grupo multieje"@es .