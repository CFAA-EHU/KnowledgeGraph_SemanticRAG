@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MicroDeReferencia a ns1:Parametro ;
    rdfs:label "Micro de referencia" ;
    ns1:textoExtracto "Cuando el eje gantry no disponga de I0 codificado, podrán tener micro de referencia (parámetro DECINPUT) ambos ejes o sólo el eje maestro." .

ns1:SistemaGantry a ns1:Sistema ;
    rdfs:label "Sistema Gantry" ;
    ns1:textoExtracto "GANTRY n Configuración de los ejes gantry. Este parámetro muestra la tabla de parámetros para definir los ejes gantry del sistema." .

ns1:VelocidadLentaDeBusquedaDeReferenciaMaquina_ea7caad81a a ns1:Parametro ;
    rdfs:label "Velocidad lenta de búsqueda de referencia máquina" ;
    ns1:textoExtracto "La velocidad rápida y lenta de búsqueda de referencia máquina (parámetros REFFEED1 y REFFEED2) deberá ser igual en ambos ejes." .

ns1:VelocidadRapidaDeBusquedaDeReferenciaMaquina_9390369197 a ns1:Parametro ;
    rdfs:label "Velocidad rápida de búsqueda de referencia máquina" ;
    ns1:textoExtracto "La velocidad rápida y lenta de búsqueda de referencia máquina (parámetros REFFEED1 y REFFEED2) deberá ser igual en ambos ejes." .

