@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MULNGROUPS
    a ex:Parametro ;
    rdfs:label "MULNGROUPS" ;
    ex:textoExtracto "MULNGROUPS | Número de grupos multieje en el sistema." ;
    ex:valor "Número de grupos multieje en el sistema" .

ex:Parametro_GROUP_n
    a ex:Parametro ;
    rdfs:label "GROUP n" ;
    ex:textoExtracto "GROUP n | Grupos multieje." ;
    ex:valor "Grupos multieje" .

ex:InterfazUsuario_ConfiguracionMultieje
    a ex:InterfazUsuario ;
    rdfs:label "Configuración de un grupo multieje" ;
    ex:textoExtracto "Configuración de un grupo multieje" ;
    ex:tieneComponente ex:Parametro_MULNGROUPS ;
    ex:tieneComponente ex:Parametro_GROUP_n .