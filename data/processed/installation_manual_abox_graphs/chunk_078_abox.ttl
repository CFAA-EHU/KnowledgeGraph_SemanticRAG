@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MULNGROUPS a ex:Parametro ;
    ex:textoExtracto "MULNGROUPS | Número de grupos multieje en el sistema." ;
    rdfs:label "Número de grupos multieje en el sistema" .

ex:GROUP_n a ex:Parametro ;
    ex:textoExtracto "GROUP n | Grupos multieje." ;
    rdfs:label "Grupos multieje" .

ex:Tabla_78 a ex:Tabla ;
    ex:textoExtracto "| MULTIAXIS |  |\n| --- | --- |\n| MULNGROUPS | Número de grupos multieje en el sistema. |\n| GROUP n | Grupos multieje. |" ;
    ex:compuestoPor ex:MULNGROUPS, ex:GROUP_n .