@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:GrupoMultieje_Sercos
    a                     ex:Sistema ;
    rdfs:label            "Grupo multieje Sercos" ;
    ex:textoExtracto      "Requisitos y limitaciones de un grupo multieje. Los ejes asociados a un mismo regulador deben cumplir los siguientes requisitos..." .

ex:Parametro_DRIVEID
    a                     ex:Parametro ;
    rdfs:label            "DRIVEID (dirección Sercos)" ;
    ex:textoExtracto      "todos los ejes de un grupo deben tener la misma dirección Sercos (parámetro DRIVEID)" ;
    ex:documentadoEn       ex:GrupoMultieje_Sercos .

ex:Parametro_OPMODEP
    a                     ex:Parametro ;
    rdfs:label            "OPMODEP (modo de operación Sercos)" ;
    ex:textoExtracto      "Todos los ejes de un grupo deben trabajar en el mismo modo de operación Sercos, posición o velocidad (parámetro OPMODEP)" ;
    ex:documentadoEn       ex:GrupoMultieje_Sercos .

ex:Parametro_DWELL
    a                     ex:Parametro ;
    rdfs:label            "DWELL (tiempo de espera)" ;
    ex:textoExtracto      "definir el parámetro DWELL>0. Los ejes utilizan el parámetro DWELL como tiempo de espera antes de dar error por no tener la marca SWITCH activa" ;
    ex:documentadoEn       ex:GrupoMultieje_Sercos .

ex:ModoOperacion_Posicion
    a                     ex:ModoOperacion ;
    rdfs:label            "Modo Sercos posición" ;
    ex:textoExtracto      "modo Sercos posición" ;
    ex:documentadoEn       ex:GrupoMultieje_Sercos .

ex:ModoOperacion_Velocidad
    a                     ex:ModoOperacion ;
    rdfs:label            "Modo Sercos velocidad" ;
    ex:textoExtracto      "modo Sercos velocidad" ;
    ex:documentadoEn       ex:GrupoMultieje_Sercos .

ex:Motor_Multieje
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Motor de grupo multieje" ;
    ex:textoExtracto      "Para un multieje donde el mismo motor controla varios ejes..." ;
    ex:tieneComponente     ex:GrupoMultieje_Sercos .