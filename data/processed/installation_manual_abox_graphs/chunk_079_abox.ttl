@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiferenciaEntreElErrorDeSeguimientoDeAmbosEjesParaMostrarUnWarning a ns1:Parametro ;
    rdfs:label "Diferencia entre el error de seguimiento de ambos ejes para mostrar un warning" ;
    ns1:documentadoEn ns1:SistemaGantry ;
    ns1:identificador "WARNCOUPE" ;
    ns1:textoExtracto "WARNCOUPE | Diferencia entre el error de seguimiento de ambos ejes para mostrar un warning." .

ns1:EjeEsclavo a ns1:Parametro ;
    rdfs:label "Eje esclavo" ;
    ns1:documentadoEn ns1:SistemaGantry ;
    ns1:identificador "SLAVEAXIS" ;
    ns1:textoExtracto "SLAVEAXIS | Eje esclavo." .

ns1:EjeMaestroOPrincipal a ns1:Parametro ;
    rdfs:label "Eje maestro o principal" ;
    ns1:documentadoEn ns1:SistemaGantry ;
    ns1:identificador "MASTERAXIS" ;
    ns1:textoExtracto "MASTERAXIS | Eje maestro o principal." .

ns1:SistemaGantry a ns1:Sistema ;
    rdfs:label "Sistema Gantry" ;
    ns1:textoExtracto "GANTRY" .

