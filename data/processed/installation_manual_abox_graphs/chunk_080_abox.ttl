@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:EjeGrupoMultieje_80_1 a ex:ComponenteMecanico ;
    ex:textoExtracto "Los ejes del grupo" ;
    ex:tieneComponente ex:ParametroDWELL_80_1, ex:MarcaSWITCH_80_1, ex:MarcaENABLE_80_1, ex:MarcaSERVOON_80_1, ex:MarcaSPENA_80_1, ex:MarcaDRENA_80_1 .

ex:ParametroDWELL_80_1 a ex:Parametro ;
    ex:identificador "DWELL" ;
    ex:textoExtracto "definir el parámetro DWELL>0. Los ejes utilizan el parámetro DWELL como tiempo de espera antes de dar error por no tener la marca SWITCH activa" ;
    ex:valor ">0" .

ex:MarcaSWITCH_80_1 a ex:Sensor ;
    ex:identificador "SWITCH" ;
    ex:textoExtracto "marca SWITCH" .

ex:MarcaENABLE_80_1 a ex:Sensor ;
    ex:identificador "ENABLE" ;
    ex:textoExtracto "marca ENABLE" .

ex:MarcaSERVOON_80_1 a ex:Sensor ;
    ex:identificador "SERVOON" ;
    ex:textoExtracto "marca SERVOON" .

ex:MarcaSPENA_80_1 a ex:Sensor ;
    ex:identificador "SPENA" ;
    ex:textoExtracto "marca SPENA" .

ex:MarcaDRENA_80_1 a ex:Sensor ;
    ex:identificador "DRENA" ;
    ex:textoExtracto "marca DRENA" .

ex:PLC_80_1 a ex:ComponenteElectrico ;
    ex:textoExtracto "El PLC vigila qué marca ENABLE se activa, para engranar ese eje y activar su marca SWITCH, SERVOON, SPENA y DRENA" ;
    ex:controla ex:EjeGrupoMultieje_80_1 .