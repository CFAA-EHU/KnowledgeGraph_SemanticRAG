ns1:DiferenciaEntreElErrorDeSeguimientoDeAmbosEjesParaMostrarUnWarning_59a56c7b7f a ns1:Parametro ;
    rdfs:label "Diferencia entre el error de seguimiento de ambos ejes para mostrar un warning" ;
    ns1:identificador "MPG.WARNCOUPE" ;
    ns1:textoExtracto "WARNCOUPE Eje gantry. Diferencia entre el error de seguimiento de ambos ejes para mostrar un warning." .

ns1:EjeEsclavoDelEjeGantry a ns1:Parametro ;
    rdfs:label "Eje esclavo del eje gantry" ;
    ns1:identificador "MPG.SLAVEAXIS" ;
    ns1:textoExtracto "SLAVEAXIS Eje gantry. Eje esclavo. Valores posibles: Cualquier eje definido en AXISNAME." .

ns1:EjeMaestroOPrincipalDelEjeGantry a ns1:Parametro ;
    rdfs:label "Eje maestro o principal del eje gantry" ;
    ns1:identificador "MPG.MASTERAXIS" ;
    ns1:textoExtracto "MASTERAXIS Eje gantry. Eje maestro o principal. Valores posibles: Cualquier eje definido en AXISNAME." .

ns1:MaximaDiferenciaPermitidaEntreElErrorDeSeguimientoDeAmbosEjes a ns1:Parametro ;
    rdfs:label "Máxima diferencia permitida entre el error de seguimiento de ambos ejes" ;
    ns1:identificador "MPG.MAXCOUPE" ;
    ns1:textoExtracto "MAXCOUPE Eje gantry. Máxima diferencia permitida entre el error de seguimiento de ambos ejes." .

