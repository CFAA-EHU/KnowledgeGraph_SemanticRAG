@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MULNGROUP a ex:Parametro ;
    rdfs:label "MULNGROUP" ;
    ex:identificador "MULNGROUP" ;
    ex:valor "De 0 a 16" ;
    ex:textoExtracto "MULNGROUP Número de grupos multieje en el sistema. Valores posibles: De 0 a 16. Valor por defecto: 0." ;
    ex:textoExtracto "Parámetro incluido en la tabla MULTIAXIS. Este parámetro establece el número de grupos multieje del sistema." .

ex:GROUP_n a ex:Parametro ;
    rdfs:label "GROUP_n" ;
    ex:identificador "GROUP_n" ;
    ex:textoExtracto "GROUP n Grupos multieje. Este parámetro muestra la tabla de parámetros para definir cada grupo multieje." ;
    ex:textoExtracto "La tabla muestra un parámetro GROUP_n por cada grupo multieje, el cuál contiene los siguientes parámetros máquina para la configuración de los grupos." .

ex:Tabla_MULTIAXIS a ex:Tabla ;
    ex:textoExtracto "Parámetro incluido en la tabla MULTIAXIS." ;
    ex:tieneComponente ex:MULNGROUP, ex:GROUP_n .

ex:PLC a ex:ComponenteElectrico ;
    ex:textoExtracto "El PLC vigila qué marca ENABLE se activa, para engranar ese eje y activar su marca SWITCH, SERVOON, SPENA y DRENA." ;
    ex:textoExtracto "El CNC mantiene la vigilancia (error de seguimiento, test de tendencia, etc) de todos los ejes que comparten el regulador, aunque el eje no esté seleccionado." .

ex:Marca_SWITCH a ex:Parametro ;
    rdfs:label "SWITCH" ;
    ex:identificador "SWITCH" ;
    ex:textoExtracto "como tiempo de espera antes de dar error por no tener la marca SWITCH activa." .

ex:Marca_ENABLE a ex:Parametro ;
    rdfs:label "ENABLE" ;
    ex:identificador "ENABLE" ;
    ex:textoExtracto "El PLC vigila qué marca ENABLE se activa, para engranar ese eje y activar su marca SWITCH, SERVOON, SPENA y DRENA." .

ex:Marca_SERVOON a ex:Parametro ;
    rdfs:label "SERVOON" ;
    ex:identificador "SERVOON" ;
    ex:textoExtracto "El PLC vigila qué marca ENABLE se activa, para engranar ese eje y activar su marca SWITCH, SERVOON, SPENA y DRENA." .

ex:Marca_SPENA a ex:Parametro ;
    rdfs:label "SPENA" ;
    ex:identificador "SPENA" ;
    ex:textoExtracto "El PLC vigila qué marca ENABLE se activa, para engranar ese eje y activar su marca SWITCH, SERVOON, SPENA y DRENA." .

ex:Marca_DRENA a ex:Parametro ;
    rdfs:label "DRENA" ;
    ex:identificador "DRENA" ;
    ex:textoExtracto "El PLC vigila qué marca ENABLE se activa, para engranar ese eje y activar su marca SWITCH, SERVOON, SPENA y DRENA." .