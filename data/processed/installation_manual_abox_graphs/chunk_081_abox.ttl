@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MULNGROUP
    a ex:Parametro ;
    rdfs:label "MULNGROUP" ;
    ex:textoExtracto "MULNGROUP Número de grupos multieje en el sistema. Valores posibles: De 0 a 16. Valor por defecto: 0." ;
    ex:valor "0-16"^^xsd:string ;
    ex:documentadoEn ex:Tabla_MULTIAXIS .

ex:Tabla_MULTIAXIS a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla MULTIAXIS" ;
    ex:textoExtracto "Parámetro incluido en la tabla MULTIAXIS. Este parámetro establece el número de grupos multieje del sistema." ;
    ex:tieneComponente ex:Parametro_GROUP_n .

ex:Parametro_GROUP_n
    a ex:Parametro ;
    rdfs:label "GROUP_n" ;
    ex:textoExtracto "GROUP n Grupos multieje. Este parámetro muestra la tabla de parámetros para definir cada grupo multieje." ;
    ex:documentadoEn ex:Tabla_MULTIAXIS .

ex:Sistema_GruposMultieje
    a ex:Sistema ;
    rdfs:label "Sistema de grupos multieje" ;
    ex:textoExtracto "El PLC vigila qué marca ENABLE se activa, para engranar ese eje y activar su marca SWITCH, SERVOON, SPENA y DRENA. • El CNC mantiene la vigilancia (error de seguimiento, test de tendencia, etc) de todos los ejes que comparten el regulador, aunque el eje no esté seleccionado." ;
    ex:tieneComponente ex:Parametro_MULNGROUP ;
    ex:tieneComponente ex:Parametro_GROUP_n .