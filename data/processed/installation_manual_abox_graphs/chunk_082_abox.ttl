@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:HabilitaLaCorreccionDeLaDiferenciaDeCotaEntreElEje a ns1:Parametro ;
    rdfs:label "Habilita la corrección de la diferencia de cota entre el eje" ;
    ns1:identificador "MPG.DIFFCOMP" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.DIFFCOMP[nb] Parámetro incluido en la tabla GANTRY. Este parámetro habilita la corrección de la diferencia de cota entre el eje." .

ns1:MaximaDiferenciaPermitidaEntreLosErroresDeSeguimientoDeAmbosEjes a ns1:Parametro ;
    rdfs:label "Máxima diferencia permitida entre los errores de seguimiento de ambos ejes" ;
    ns1:identificador "MPG.MAXCOUPE" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.MAXCOUPE[nb] Parámetro incluido en la tabla GANTRY. Este parámetro indica la máxima diferencia permitida entre los errores de seguimiento de ambos ejes." .

