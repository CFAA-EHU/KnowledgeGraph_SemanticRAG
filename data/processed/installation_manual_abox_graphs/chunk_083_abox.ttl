@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaGANTRY a ns1:Tabla ;
    rdfs:label "Tabla GANTRY" ;
    ns1:ilustra ns1:SistemaCNC ;
    ns1:textoExtracto "Parámetro incluido en la tabla GANTRY." ;
    ns1:tieneComponente ns1:CorreccionDeLaDiferenciaDeCotaEntreElEjeMaestroYElEsclavo,
        ns1:MaximaDiferenciaDeCotaPermitidaEntreAmbosEjes .

ns1:CorreccionDeLaDiferenciaDeCotaEntreElEjeMaestroYElEsclavo a ns1:Parametro ;
    rdfs:label "Corrección de la diferencia de cota entre el eje maestro y el esclavo" ;
    ns1:identificador "MPG.DIFFCOMP[nb]" ;
    ns1:textoExtracto "Este parámetro habilita la corrección de la diferencia de cota entre el eje maestro y el esclavo tras la búsqueda de referencia máquina." .

ns1:MaximaDiferenciaDeCotaPermitidaEntreAmbosEjes a ns1:Parametro ;
    rdfs:label "Máxima diferencia de cota permitida entre ambos ejes" ;
    ns1:identificador "MAXDIFF" ;
    ns1:textoExtracto "Valores posibles (1): De 0 a 99999.9999 mm." .

