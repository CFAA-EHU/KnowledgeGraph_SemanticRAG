@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoOperacion_reactivacionEjeMantieneCota a ex:ModoOperacion ;
    rdfs:label "reactivación de eje mantiene cota" ;
    ex:textoExtracto "Cuando el eje se reactiva, mantiene la cota que tiene en ese momento." .

ex:ModoOperacion_reactivacionEjeHeredaCota a ex:ModoOperacion ;
    rdfs:label "reactivación de eje hereda cota" ;
    ex:textoExtracto "Cuando el eje se reactiva, no mantiene su cota; hereda la cota del último eje activo." .