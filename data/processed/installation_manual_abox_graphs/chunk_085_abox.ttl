@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_840a232e09 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "MULTIAXIS Tabla de grupos multieje. Un grupo multieje permite controlar varios ejes con un único regulador, controlando uno o varios motores." .

ns1:TablaDeGruposMultieje a ns1:Parametro ;
    rdfs:label "Tabla de grupos multieje" ;
    ns1:identificador "MULTIAXIS" ;
    ns1:textoExtracto "Este parámetro muestra la tabla de definición de los grupos multieje, donde hay que definir el número de grupos del sistema y la composición de cada grupo." .

