@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_NSPDL
    a ex:Parametro ;
    rdfs:label "NSPDL" ;
    ex:textoExtracto "NSPDL Número de cabezales que gobierna el CNC. Valores posibles: De 0 a 6. Valor por defecto: 1." ;
    ex:valor "1" ;
    ex:identificador "MPG.NSPDL" .

ex:Tabla_SPDLNAME a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla SPDLNAME" ;
    ex:textoExtracto "SPDLNAME Lista de cabezales del sistema. Este parámetro muestra la tabla para definir los nombres de los cabezales." .

ex:Parametro_SPDLNAME_n
    a ex:Parametro ;
    rdfs:label "SPDLNAME n" ;
    ex:textoExtracto "SPDLNAME n Nombre de los cabezales. Valores posibles: S, S1…S9. Valor por defecto: Comenzando por SPDLNAME1; S, S1..." ;
    ex:valor "S" ;
    ex:identificador "MPG.SPDLNAMEn" ;
    ex:documentadoEn ex:Tabla_SPDLNAME .

ex:Sistema_CabezalesCNC
    a ex:Sistema ;
    rdfs:label "Sistema de cabezales CNC" ;
    ex:textoExtracto "Un canal podrá tener asociado uno, varios o ningún cabezal. SPDLNAME Lista de cabezales del sistema." ;
    ex:tieneComponente ex:Parametro_NSPDL ;
    ex:tieneComponente ex:Tabla_SPDLNAME .