@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_NSPDL a ex:Parametro ;
    rdfs:label "NSPDL" ;
    ex:identificador "(V.)MPG.NSPDL" ;
    ex:textoExtracto "NSPDL Número de cabezales que gobierna el CNC. Valores posibles: De 0 a 6. Valor por defecto: 1. Variable asociada: (V.)MPG.NSPDL Este parámetro establece el número de cabezales del sistema, estén servocontrolados o no." ;
    ex:valor "De 0 a 6" .

ex:Parametro_SPDLNAME a ex:Parametro ;
    rdfs:label "SPDLNAME" ;
    ex:identificador "(V.)MPG.SPDLNAMEn" ;
    ex:textoExtracto "SPDLNAME Lista de cabezales del sistema. Este parámetro muestra la tabla para definir los nombres de los cabezales. El número de cabezales del sistema lo establece el parámetro NSPDL. | SPDLNAME |  | SPDLNAME n | Nombre de los cabezales. SPDLNAME n Nombre de los cabezales. Valores posibles: S, S1ꞏꞏS9. Valor por defecto: Comenzando por SPDLNAME1; S, S1... Variable asociada: (V.)MPG.SPDLNAMEn Parámetro incluido en la tabla SPDLNAME. El nombre del cabezal estará definido por 1 ó 2 caracteres. El primer carácter debe ser la letra –S–. El segundo carácter es opcional y será un sufijo numérico entre 1 y 9. De esta forma el nombre de los cabezales podrá ser cualquiera del rango S, S1…S9. A la hora de definir los cabezales, hay que tener en cuenta que el orden en el que se definen establece su número lógico." ;
    ex:valor "S, S1…S9" .

ex:Tabla_SPDLNAME a ex:Tabla ;
    ex:textoExtracto "| SPDLNAME |  | SPDLNAME n | Nombre de los cabezales. | AXISNAME | SPDLNAME | Orden lógico." ;
    ex:compuestoPor ex:Parametro_SPDLNAME .