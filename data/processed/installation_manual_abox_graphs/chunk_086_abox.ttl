@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaConfiguracionCabezales_86 a ex:Tabla ;
     a               ex:Tabla ;
    ex:identificador "2.3.6 Configuración de los cabezales" ;
    ex:textoExtracto "La numeración lógica de cabezales continúa a partir del último eje lógico; así, en un sistema con 3 ejes, el primer cabezal de la tabla será el cabezal lógico ꞏ4ꞏ y así sucesivamente. | AXISNAME | SPDLNAME | Orden lógico. | --- | --- | --- | AXISNAME 1 |  | Número lógico ꞏ1ꞏ. | AXISNAME 2 |  | Número lógico ꞏ2ꞏ. | AXISNAME 3 |  | Número lógico ꞏ3ꞏ. |  | SPDLNAME 1 | Número lógico ꞏ4ꞏ." .

ex:SistemaEjesCabezales_86
    a               ex:Sistema ;
    ex:textoExtracto "sistema con 3 ejes" ;
    ex:compuestoPor  ex:EjeLogico_1_86 , ex:EjeLogico_2_86 , ex:EjeLogico_3_86 , ex:CabezalLogico_4_86 ;
    ex:detalladoEnEsquema ex:TablaConfiguracionCabezales_86 .

ex:EjeLogico_1_86
    a               ex:Componente ;
    rdfs:label      "Eje lógico 1" ;
    ex:identificador "1" ;
    ex:textoExtracto "AXISNAME 1 | Número lógico ꞏ1ꞏ." ;
    ex:documentadoEn ex:TablaConfiguracionCabezales_86 .

ex:EjeLogico_2_86
    a               ex:Componente ;
    rdfs:label      "Eje lógico 2" ;
    ex:identificador "2" ;
    ex:textoExtracto "AXISNAME 2 | Número lógico ꞏ2ꞏ." ;
    ex:documentadoEn ex:TablaConfiguracionCabezales_86 .

ex:EjeLogico_3_86
    a               ex:Componente ;
    rdfs:label      "Eje lógico 3" ;
    ex:identificador "3" ;
    ex:textoExtracto "AXISNAME 3 | Número lógico ꞏ3ꞏ." ;
    ex:documentadoEn ex:TablaConfiguracionCabezales_86 .

ex:CabezalLogico_4_86
    a               ex:Componente ;
    rdfs:label      "Cabezal lógico 4" ;
    ex:identificador "4" ;
    ex:textoExtracto "SPDLNAME 1 | Número lógico ꞏ4ꞏ." ;
    ex:documentadoEn ex:TablaConfiguracionCabezales_86 .