@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_LOOPTIME
    a ex:Parametro ;
    rdfs:label "LOOPTIME" ;
    ex:identificador "MPG.LOOPTIME" ;
    ex:textoExtracto "LOOPTIME Tiempo de ciclo del CNC. Valores posibles: De 1 a 20 ms. Valor por defecto: 4 ms. Variable asociada: (V.)MPG.LOOPTIME Este parámetro fija el periodo de muestreo que utiliza el CNC." ;
    ex:valor "4"^^<http://www.w3.org/2001/XMLSchema#integer> .