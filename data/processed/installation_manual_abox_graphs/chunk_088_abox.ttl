@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_TiemposEjesAnalogicos a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de tiempos de ciclo según número de ejes analógicos"@es ;
    ex:textoExtracto """
| LOOPTIME | Número de ejes analógicos. |
| --- | --- |
| 4 ms. | Hasta 8 ejes analógicos. |
| 5 ms. | Hasta 12 ejes analógicos. |
| 6 ms. | Hasta 16 ejes analógicos. |
| 8 ms. | Hasta 20 ejes analógicos. |
| 10 ms. | Hasta 24 ejes analógicos. |
"""@es .

ex:Parametro_LOOPTIME_4ms
    a ex:Parametro ;
    rdfs:label "LOOPTIME 4 ms"@es ;
    ex:valor "4 ms" ;
    ex:textoExtracto "4 ms. Hasta 8 ejes analógicos."@es ;
    ex:documentadoEn ex:Tabla_TiemposEjesAnalogicos .

ex:Parametro_LOOPTIME_5ms
    a ex:Parametro ;
    rdfs:label "LOOPTIME 5 ms"@es ;
    ex:valor "5 ms" ;
    ex:textoExtracto "5 ms. Hasta 12 ejes analógicos."@es ;
    ex:documentadoEn ex:Tabla_TiemposEjesAnalogicos .

ex:Parametro_LOOPTIME_6ms
    a ex:Parametro ;
    rdfs:label "LOOPTIME 6 ms"@es ;
    ex:valor "6 ms" ;
    ex:textoExtracto "6 ms. Hasta 16 ejes analógicos."@es ;
    ex:documentadoEn ex:Tabla_TiemposEjesAnalogicos .

ex:Parametro_LOOPTIME_8ms
    a ex:Parametro ;
    rdfs:label "LOOPTIME 8 ms"@es ;
    ex:valor "8 ms" ;
    ex:textoExtracto "8 ms. Hasta 20 ejes analógicos."@es ;
    ex:documentadoEn ex:Tabla_TiemposEjesAnalogicos .

ex:Parametro_LOOPTIME_10ms
    a ex:Parametro ;
    rdfs:label "LOOPTIME 10 ms"@es ;
    ex:valor "10 ms" ;
    ex:textoExtracto "10 ms. Hasta 24 ejes analógicos."@es ;
    ex:documentadoEn ex:Tabla_TiemposEjesAnalogicos .