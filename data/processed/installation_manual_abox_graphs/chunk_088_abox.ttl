@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_8dbfb2dcaa a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:ComponenteElectrico_fb9dad688a ;
    ns1:textoExtracto "el CNC ejecuta la búsqueda de referencia como si el eje fuera analógico" .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:controla ns1:ComponenteElectrico_fb9dad688a ;
    ns1:textoExtracto "La selección del eje que gobierna el regulador se realiza desde el PLC (marca SWITCH(axis)). El PLC debe aparcar o poner como visualizador los ejes que no gobierna el regulador." .

ns1:TiempoDeEsperaAntesDeDarErrorPorNoTenerLaMarcaSWITCHActiva a ns1:Parametro ;
    rdfs:label "Tiempo de espera antes de dar error por no tener la marca SWITCH activa" ;
    ns1:identificador "DWELL" ;
    ns1:textoExtracto "definir el parámetro DWELL>0. Los ejes utilizan el parámetro DWELL como tiempo de espera antes de dar error por no tener la marca SWITCH activa." .

ns1:ComponenteElectrico_fb9dad688a a ns1:ComponenteElectrico ;
    rdfs:label "Regulador" ;
    ns1:textoExtracto "el regulador desconoce que hay una búsqueda de referencia en marcha y no actualiza su cota, sólo recibe consigna de velocidad." .

