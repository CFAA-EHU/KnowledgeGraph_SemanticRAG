@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla88 a ex:Tabla ;
    ex:textoExtracto """| LOOPTIME | Número de ejes analógicos. |
| --- | --- |
| 4 ms. | Hasta 8 ejes analógicos. |
| 5 ms. | Hasta 12 ejes analógicos. |
| 6 ms. | Hasta 16 ejes analógicos. |
| 8 ms. | Hasta 20 ejes analógicos. |
| 10 ms. | Hasta 24 ejes analógicos. |""" .

ex:ParametroLOOPTIME a ex:Parametro ;
    ex:identificador "LOOPTIME" ;
    ex:textoExtracto "LOOPTIME" .

ex:Frecuencia4ms a ex:Frecuencia ;
    ex:valor "4 ms." ;
    ex:textoExtracto "4 ms." ;
    ex:detalladoEnEsquema ex:Tabla88 .

ex:Frecuencia5ms a ex:Frecuencia ;
    ex:valor "5 ms." ;
    ex:textoExtracto "5 ms." ;
    ex:detalladoEnEsquema ex:Tabla88 .

ex:Frecuencia6ms a ex:Frecuencia ;
    ex:valor "6 ms." ;
    ex:textoExtracto "6 ms." ;
    ex:detalladoEnEsquema ex:Tabla88 .

ex:Frecuencia8ms a ex:Frecuencia ;
    ex:valor "8 ms." ;
    ex:textoExtracto "8 ms." ;
    ex:detalladoEnEsquema ex:Tabla88 .

ex:Frecuencia10ms a ex:Frecuencia ;
    ex:valor "10 ms." ;
    ex:textoExtracto "10 ms." ;
    ex:detalladoEnEsquema ex:Tabla88 .

ex:ParametroEjesAnalogicos a ex:Parametro ;
    ex:identificador "Número de ejes analógicos" ;
    ex:textoExtracto "Número de ejes analógicos." .

ex:ValorHasta8Ejes a ex:Parametro ;
    ex:valor "Hasta 8 ejes analógicos." ;
    ex:textoExtracto "Hasta 8 ejes analógicos." ;
    ex:detalladoEnEsquema ex:Tabla88 .

ex:ValorHasta12Ejes a ex:Parametro ;
    ex:valor "Hasta 12 ejes analógicos." ;
    ex:textoExtracto "Hasta 12 ejes analógicos." ;
    ex:detalladoEnEsquema ex:Tabla88 .

ex:ValorHasta16Ejes a ex:Parametro ;
    ex:valor "Hasta 16 ejes analógicos." ;
    ex:textoExtracto "Hasta 16 ejes analógicos." ;
    ex:detalladoEnEsquema ex:Tabla88 .

ex:ValorHasta20Ejes a ex:Parametro ;
    ex:valor "Hasta 20 ejes analógicos." ;
    ex:textoExtracto "Hasta 20 ejes analógicos." ;
    ex:detalladoEnEsquema ex:Tabla88 .

ex:ValorHasta24Ejes a ex:Parametro ;
