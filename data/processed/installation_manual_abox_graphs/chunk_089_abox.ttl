@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:LOOPTIME a ex:Parametro ;
    ex:textoExtracto "Influencia del bus CAN en el parámetro LOOPTIME. Desde el punto de vista del bus CAN, el tiempo mínimo de ciclo para una determinada configuración viene condicionado fundamentalmente por las necesidades del tráfico del sistema; es decir, por el tiempo consumido en la transmisión de mensajes por ciclo." ;
    ex:valor "Parámetro LOOPTIME" .

ex:PRGFREQ a ex:Parametro ;
    ex:textoExtracto "PRGFREQ Periodicidad del módulo PRG del PLC. Valores posibles: De 1 a 100 ciclos. Valor por defecto: 2 ciclos. Variable asociada: (V.)MPG.PRGFREQ" ;
    ex:identificador "PRGFREQ" ;
    ex:valor "Periodicidad del módulo PRG del PLC (1 a 100 ciclos, por defecto 2 ciclos)" .

ex:MPG.PRGFREQ a ex:Parametro ;
    ex:textoExtracto "PRGFREQ Periodicidad del módulo PRG del PLC. ... Variable asociada: (V.)MPG.PRGFREQ" ;
    ex:identificador "(V.)MPG.PRGFREQ" .

ex:BusCAN a ex:Sistema ;
    ex:textoExtracto "Influencia del bus CAN en el parámetro LOOPTIME. ... Velocidad de transmisión de CAN." ;
    ex:identificador "CAN" .

ex:PLC a ex:Componente ;
    ex:textoExtracto "Periodicidad del módulo PRG del PLC" ;
    ex:identificador "PLC" .

ex:HerramientaAnalisisLogicoCAN a ex:Herramienta ;
    ex:textoExtracto "lo más fiable es recurrir a una herramienta comercial de análisis lógico del bus CAN" .

ex:CNCFagor a ex:Maquina ;
    ex:textoExtracto "CANfagor En el caso de que el tiempo de ciclo del CNC no sea suficiente para gestionar la configuración deseada, se producirán errores varios de solapamiento de ciclo y timeout en lecturas cíclicas de CAN." ;
    ex:identificador "CANfagor" .

ex:CNCOpen a ex:AvisoSeguridad ;
    ex:textoExtracto "CANopen En el arranque del CNC se realiza adicionalmente una estimación del tiempo necesario, mostrando el correspondiente aviso en caso de ser insuficiente." ;
    ex:identificador "CANopen" .