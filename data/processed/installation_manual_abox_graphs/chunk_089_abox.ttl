@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_0cb5ff7389 a ns1:Parametro ;
    rdfs:label "marca DRENA" ;
    ns1:identificador "DRENA" ;
    ns1:textoExtracto "El PLC vigila qué marca ENABLE se activa, para engranar ese eje y activar su marca SWITCH, SERVOON, SPENA y DRENA." .

ns1:Parametro_143c8827e7 a ns1:Parametro ;
    rdfs:label "marca SPENA" ;
    ns1:identificador "SPENA" ;
    ns1:textoExtracto "El PLC vigila qué marca ENABLE se activa, para engranar ese eje y activar su marca SWITCH, SERVOON, SPENA y DRENA." .

ns1:Parametro_7cbccb0cfe a ns1:Parametro ;
    rdfs:label "marca SERVOON" ;
    ns1:identificador "SERVOON" ;
    ns1:textoExtracto "El PLC vigila qué marca ENABLE se activa, para engranar ese eje y activar su marca SWITCH, SERVOON, SPENA y DRENA." .

ns1:Parametro_7e6449caa5 a ns1:Parametro ;
    rdfs:label "marca SWITCH" ;
    ns1:identificador "SWITCH" ;
    ns1:textoExtracto "Los ejes utilizan el parámetro DWELL como tiempo de espera antes de dar error por no tener la marca SWITCH activa." .

ns1:Parametro_ccfabce9b6 a ns1:Parametro ;
    rdfs:label "marca ENABLE se activa para engranar ese eje" ;
    ns1:identificador "ENABLE" ;
    ns1:textoExtracto "El PLC vigila qué marca ENABLE se activa, para engranar ese eje y activar su marca SWITCH, SERVOON, SPENA y DRENA." .

ns1:TiempoDeEsperaAntesDeDarErrorPorNoTenerLaMarcaSWITCHActiva a ns1:Parametro ;
    rdfs:label "tiempo de espera antes de dar error por no tener la marca SWITCH activa" ;
    ns1:identificador "DWELL" ;
    ns1:textoExtracto "Los ejes utilizan el parámetro DWELL como tiempo de espera antes de dar error por no tener la marca SWITCH activa." .

