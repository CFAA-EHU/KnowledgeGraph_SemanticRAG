@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PRGFREQ a ex:Parametro ;
    rdfs:label "PRGFREQ" ;
    ex:identificador "PRGFREQ" ;
    ex:textoExtracto "PRGFREQ Periodicidad del módulo PRG del PLC. Valores posibles: De 1 a 100 ciclos. Valor por defecto: 2 ciclos." ;
    ex:valor "2 ciclos" ;
    ex:valor "De 1 a 100 ciclos" .

ex:MPG.PRGFREQ a ex:Parametro ;
    rdfs:label "MPG.PRGFREQ" ;
    ex:identificador "MPG.PRGFREQ" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.PRGFREQ" .

ex:LOOPTIME a ex:Parametro ;
    rdfs:label "LOOPTIME" ;
    ex:textoExtracto "con un periodo de muestreo LOOPTIME = 4 ms" ;
    ex:valor "4 ms" .

ex:PLC a ex:Sistema ;
    rdfs:label "PLC" ;
    ex:textoExtracto "módulo PRG del PLC" .

ex:CicloCNC a ex:Parametro ;
    rdfs:label "Ciclo de CNC" ;
    ex:textoExtracto "cada cuántos ciclos de CNC" .