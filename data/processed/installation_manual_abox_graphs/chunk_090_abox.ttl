@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_PRGFREQ
    a ex:Parametro ;
    rdfs:label "PRGFREQ" ;
    ex:identificador "PRGFREQ" ;
    ex:textoExtracto "PRGFREQ Periodicidad del módulo PRG del PLC. Valores posibles: De 1 a 100 ciclos. Valor por defecto: 2 ciclos." ;
    ex:valor "2" ;
    ex:monitoreaParametro ex:Sistema_PLC .

ex:Frecuencia_PRGFREQ
    a ex:Frecuencia ;
    rdfs:label "Frecuencia de ejecución PRG" ;
    ex:textoExtracto "Este parámetro indica con qué frecuencia (cada cuántos ciclos de CNC) se ejecuta un ciclo completo del programa de PLC." ;
    ex:valor "1-100 ciclos" .

ex:Sistema_PLC
    a ex:Sistema ;
    rdfs:label "Módulo PRG del PLC" ;
    ex:textoExtracto "módulo PRG del PLC" ;
    ex:tieneComponente ex:Parametro_PRGFREQ ;
    ex:tieneFrecuencia ex:Frecuencia_PRGFREQ .

ex:Parametro_LOOPTIME
    a ex:Parametro ;
    rdfs:label "LOOPTIME" ;
    ex:identificador "LOOPTIME" ;
    ex:textoExtracto "periodo de muestreo LOOPTIME = 4 ms" ;
    ex:valor "4 ms" ;
    ex:monitoreaParametro ex:Sistema_PLC .