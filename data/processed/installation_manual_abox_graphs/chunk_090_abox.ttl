@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_765eb0a28a a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:TablaParametrosMultieje ;
    ns1:textoExtracto "El CNC mantiene la vigilancia (error de seguimiento, test de tendencia, etc) de todos los ejes que comparten el regulador, aunque el eje no esté seleccionado." .

ns1:NumeroDeGruposMultiejeEnElSistema a ns1:Parametro ;
    rdfs:label "Número de grupos multieje en el sistema" ;
    ns1:identificador "MPG.MULNGROUP" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.MULNGROUP Parámetro incluido en la tabla MULTIAXIS. Este parámetro establece el número de grupos multieje del sistema." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "El PLC vigila qué marca ENABLE se activa, para engranar ese eje y activar su marca SWITCH, SERVOON, SPENA y DRENA." .

ns1:TablaParametrosMultieje a ns1:Tabla ;
    rdfs:label "Tabla de parámetros multieje" ;
    ns1:textoExtracto "La tabla muestra un parámetro GROUP_n por cada grupo multieje, el cuál contiene los siguientes parámetros máquina para la configuración de los grupos." .

