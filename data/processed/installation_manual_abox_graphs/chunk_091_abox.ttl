@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_11a7db896f a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "En el arranque del sistema, el CNC utilizará los parámetros del eje maestro para realizar la homogeneización de parámetros con el regulador." .

ns1:NombreDeLosEjesYOCabezalesDelGrupo a ns1:Parametro ;
    rdfs:label "Nombre de los ejes y/o cabezales del grupo" ;
    ns1:identificador "MPG.MULAXISNAMExn" ;
    ns1:textoExtracto "MULAXISNAME n Nombre de los ejes y/o cabezales del grupo. Valores posibles: Cualquier eje Sercos del sistema, excepto ejes tándem o gantry." .

ns1:NumeroDeEjesYOCabezalesQueFormanElGrupoMultieje a ns1:Parametro ;
    rdfs:label "Número de ejes y/o cabezales que forman el grupo multieje" ;
    ns1:identificador "MPG.MULNAXIS" ;
    ns1:textoExtracto "MULNAXIS Número de ejes y/o cabezales que forman el grupo multieje. Valores posibles: De 2 a 8. Valor por defecto: 2." .

