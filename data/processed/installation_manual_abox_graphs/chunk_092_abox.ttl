@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla92 a ex:Tabla ;
    ex:textoExtracto "Valores recomendados (placa Sercos II). | SERPOWSE | Longitud del cable. | Tipo de cable recomendado. | 1 a 4 | Menor de 15 metros. | SFO / SFO-FLEX | 5 a 6 | Entre 15 y 30 metros. | SFO-FLEX | 7 | Entre 30 y 40 metros. | SFO-FLEX | 8 | Mayor de 40 metros. | SFO-V-FLEX |"@es .

ex:ParametroLongitudCable1a4 a ex:Parametro ;
    ex:textoExtracto "1 a 4 | Menor de 15 metros. | SFO / SFO-FLEX"@es ,
        "Menor de 15 metros."@es ;
    ex:valor "Menor de 15 metros"@es ;
    ex:identificador "1 a 4"@es .

ex:ParametroLongitudCable5a6 a ex:Parametro ;
    ex:textoExtracto "5 a 6 | Entre 15 y 30 metros. | SFO-FLEX"@es ,
        "Entre 15 y 30 metros."@es ;
    ex:valor "Entre 15 y 30 metros"@es ;
    ex:identificador "5 a 6"@es .

ex:ParametroLongitudCable7 a ex:Parametro ;
    ex:textoExtracto "7 | Entre 30 y 40 metros. | SFO-FLEX"@es ,
        "Entre 30 y 40 metros."@es ;
    ex:valor "Entre 30 y 40 metros"@es ;
    ex:identificador "7"@es .

ex:ParametroLongitudCable8 a ex:Parametro ;
    ex:textoExtracto "8 | Mayor de 40 metros. | SFO-V-FLEX"@es ,
        "Mayor de 40 metros."@es ;
    ex:valor "Mayor de 40 metros"@es ;
    ex:identificador "8"@es .

ex:ParametroTipoCableSFO a ex:Parametro ;
    ex:textoExtracto "SFO / SFO-FLEX"@es ;
    ex:valor "SFO / SFO-FLEX"@es .

ex:ParametroTipoCableSFOflex a ex:Parametro ;
    ex:textoExtracto "SFO-FLEX"@es ;
    ex:valor "SFO-FLEX"@es .

ex:ParametroTipoCableSFOVflex a ex:Parametro ;
    ex:textoExtracto "SFO-V-FLEX"@es ;
    ex:valor "SFO-V-FLEX"@es .

ex:Tabla92 a ex:Tabla ;
    ex:tieneComponente ex:ParametroLongitudCable1a4 ,
        ex:ParametroLongitudCable5a6 ,
        ex:ParametroLongitudCable7 ,
        ex:ParametroLongitudCable8 ,
        ex:ParametroTipoCableSFO ,
        ex:ParametroTipoCableSFOflex ,
        ex:ParametroTipoCableSFOVflex .