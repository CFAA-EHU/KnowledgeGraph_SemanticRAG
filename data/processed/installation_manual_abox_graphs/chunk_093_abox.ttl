@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionDeCotaEnGrupoMultieje a ns1:Parametro ;
    rdfs:label "Configuración de cota en grupo multieje" ;
    ns1:identificador "MULTIAXISGROUPCOTA" ;
    ns1:textoExtracto "Cuando el eje se reactiva, mantiene la cota que tiene en ese momento." .

ns1:ConfiguracionDeCotaHeredadaEnGrupoMultieje a ns1:Parametro ;
    rdfs:label "Configuración de cota heredada en grupo multieje" ;
    ns1:identificador "MULTIAXISGROUPCOTA_Neg" ;
    ns1:textoExtracto "Cuando el eje se reactiva, no mantiene su cota; hereda la cota del último eje activo." .

