@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:CANMODE a ex:Parametro ;
    rdfs:label "CANMODE" ;
    ex:identificador "(V.)MPG.CANMODE" ;
    ex:textoExtracto "CANMODE Tipo de bus CAN. Valores posibles: CANfagor / CANopen. Valor por defecto: CANopen." ;
    ex:valor "CANopen" .

ex:CANfagor a ex:ModoOperacion ;
    rdfs:label "CANfagor" ;
    ex:textoExtracto "Si se utiliza el tipo de bus CANfagor, hay que definir la longitud máxima del bus mediante el parámetro CANLENGTH." .

ex:CANopen a ex:ModoOperacion ;
    rdfs:label "CANopen" ;
    ex:textoExtracto "Si se utiliza el tipo de bus CANopen, la velocidad de trabajo se define en cada uno de los nodos. Todos los nodos deben trabajar a la misma velocidad. Las velocidades de trabajo en el bus dependen de la longitud total del bus." .

ex:CANLENGTH a ex:Parametro ;
    rdfs:label "CANLENGTH" ;
    ex:identificador "(V.)MPG.CANLENGTH" ;
    ex:textoExtracto "CANLENGTH Longitud del cable del bus CANfagor. Valores posibles: Hasta 20, 30, 40, 50, 60, 70, 80, 90, 100, 110, 120, 130 y más de 130 metros. Valor por defecto: Hasta 20 metros." ;
    ex:valor "Hasta 20 metros" .

ex:CANOPENFREQ a ex:Frecuencia ;
    rdfs:label "CANOPENFREQ" ;
    ex:identificador "(V.)MPG.CANOPENFREQ" ;
    ex:textoExtracto "CANOPENFREQ Frecuencia de comunicación del bus CANopen. Valores posibles: Autoscan / 1 Mbps / 800 kbps / 500 kbps / 250 kbps. Valor por defecto: Autoscan." ;
    ex:valor "Autoscan" .

ex:TablaVelocidadCAN a ex:Tabla ;
    ex:textoExtracto "Longitud (m) | 20 | 40 | 100 | 500 | Velocidad (kHz) | 1000 | 800 | 500 | 250" ;
    ex:tieneComponente ex:Velocidad20m, ex:Velocidad40m, ex:Velocidad100m, ex:Velocidad500m .

ex:Velocidad20m a ex:Frecuencia ;
    ex:textoExtracto "Longitud (m) 20 | Velocidad (kHz) 1000" ;
    ex:valor "1000 kHz" .

ex:Velocidad40m a ex:Frecuencia ;
    ex:textoExtracto "Longitud (m) 40 | Velocidad (kHz) 800" ;
    ex:valor "800 kHz" .

ex:Velocidad100m a ex:Frecuencia ;
    ex:textoExtracto "Longitud (m) 100 | Velocidad (kHz) 500" ;
    ex:valor "500 kHz" .

ex:Velocidad500m a ex:Frecuencia ;
    ex:textoExtracto "Longitud (m) 500 | Velocidad (kHz) 250" ;
    ex:valor "250 kHz" .