@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_CANMODE
    a ex:Parametro ;
    rdfs:label "CANMODE" ;
    ex:textoExtracto "CANMODE Tipo de bus CAN. Valores posibles: CANfagor / CANopen. Valor por defecto: CANopen." ;
    ex:identificador "V.MPG.CANMODE" ;
    ex:valor "CANopen" .

ex:Parametro_CANLENGTH
    a ex:Parametro ;
    rdfs:label "CANLENGTH" ;
    ex:textoExtracto "CANLENGTH Longitud del cable del bus CANfagor. Valores posibles: Hasta 20, 30, 40, 50, 60, 70, 80, 90, 100, 110, 120, 130 y más de 130 metros. Valor por defecto: Hasta 20 metros." ;
    ex:identificador "V.MPG.CANLENGTH" ;
    ex:valor "Hasta 20 metros" .

ex:Parametro_CANOPENFREQ
    a ex:Parametro ;
    rdfs:label "CANOPENFREQ" ;
    ex:textoExtracto "CANOPENFREQ Frecuencia de comunicación del bus CANopen. Valores posibles: Autoscan / 1 Mbps / 800 kbps / 500 kbps / 250 kbps. Valor por defecto: Autoscan." ;
    ex:identificador "V.MPG.CANOPENFREQ" ;
    ex:valor "Autoscan" .

ex:Tabla_VelocidadesCANopen a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de velocidades del bus CANopen según longitud" ;
    ex:textoExtracto "| Longitud (m) | 20 | 40 | 100 | 500 | --- | --- | --- | --- | Velocidad (kHz) | 1000 | 800 | 500 | 250 |" ;
    ex:ilustradoEn ex:Pagina_71 .

ex:Sistema_BusCAN
    a ex:Sistema ;
    rdfs:label "Sistema de bus CAN" ;
    ex:textoExtracto "Configuración del bus CAN. Bus CANfagor. Si se utiliza el tipo de bus CANfagor, hay que definir la longitud máxima del bus mediante el parámetro CANLENGTH. Bus CANopen. Si se utiliza el tipo de bus CANopen, la velocidad de trabajo se define en cada uno de los nodos." ;
    ex:tieneComponente ex:Parametro_CANMODE ;
    ex:tieneComponente ex:Parametro_CANLENGTH ;
    ex:tieneComponente ex:Parametro_CANOPENFREQ ;
    ex:detalladoEnEsquema ex:Tabla_VelocidadesCANopen .