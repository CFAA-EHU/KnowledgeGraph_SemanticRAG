@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_7dba309a69 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:TablaSPDLNAME ;
    ns1:textoExtracto "Este parámetro establece el número de cabezales del sistema, estén servocontrolados o no." ;
    ns1:tieneComponente ns1:NombreDeLosCabezales,
        ns1:NumeroDeCabezalesQueGobiernaElCNC .

ns1:NombreDeLosCabezales a ns1:Parametro ;
    rdfs:label "Nombre de los cabezales" ;
    ns1:identificador "MPG.SPDLNAMEn" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.SPDLNAMEn Parámetro incluido en la tabla SPDLNAME. El nombre del cabezal estará definido por 1 ó 2 caracteres." .

ns1:NumeroDeCabezalesQueGobiernaElCNC a ns1:Parametro ;
    rdfs:label "Número de cabezales que gobierna el CNC" ;
    ns1:identificador "MPG.NSPDL" ;
    ns1:textoExtracto "NSPDL Número de cabezales que gobierna el CNC. Valores posibles: De 0 a 6. Valor por defecto: 1." .

ns1:TablaSPDLNAME a ns1:Tabla ;
    rdfs:label "Tabla SPDLNAME" ;
    ns1:textoExtracto "El parámetro muestra la tabla para definir los nombres de los cabezales. El número de cabezales del sistema lo establece el parámetro NSPDL." .

