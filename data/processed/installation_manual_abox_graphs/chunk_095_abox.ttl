@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:FrecuenciaAutoscan a ex:Frecuencia ;
    rdfs:label "Autoscan" ;
    ex:textoExtracto "Autoscan" ;
    ex:valor "Autoscan" .

ex:Frecuencia1000kHz a ex:Frecuencia ;
    rdfs:label "1000 kHz" ;
    ex:textoExtracto "1000 kHz" ;
    ex:valor "1000 kHz" .

ex:Frecuencia800kHz a ex:Frecuencia ;
    rdfs:label "800 kHz" ;
    ex:textoExtracto "800 kHz" ;
    ex:valor "800 kHz" .

ex:Frecuencia500kHz a ex:Frecuencia ;
    rdfs:label "500 kHz" ;
    ex:textoExtracto "500 kHz" ;
    ex:valor "500 kHz" .

ex:Frecuencia250kHz a ex:Frecuencia ;
    rdfs:label "250 kHz" ;
    ex:textoExtracto "250 kHz" ;
    ex:valor "250 kHz" .

ex:TablaConfiguracionBusCAN a ex:Tabla ;
    rdfs:label "Tabla de configuración del bus CAN" ;
    ex:textoExtracto "Velocidad | Longitud del bus CAN.\nAutoscan | El CNC ajusta la frecuencia del bus en cada arranque, en función de la velocidad del resto de los módulos. Dependiendo de la configuración del bus, esta opción puede hacer que el arranque del CNC sea más lento que si hay una frecuencia definida.\n1000 kHz | Hasta 20 metros.\n800 kHz | Entre 20 y 40 metros.\n500 kHz | Entre 40 y 100 metros.\n250 kHz | Entre 100 y 500 metros." ;
    ex:tieneComponente ex:FrecuenciaAutoscan, ex:Frecuencia1000kHz, ex:Frecuencia800kHz, ex:Frecuencia500kHz, ex:Frecuencia250kHz .

ex:SistemaCNC a ex:Maquina ;
    rdfs:label "CNC" ;
    ex:textoExtracto "El CNC ajusta la frecuencia del bus en cada arranque, en función de la velocidad del resto de los módulos." .

ex:ModuloRIO5 a ex:ComponenteElectrico ;
    rdfs:label "módulos remotos de la serie RIO5" ;
    ex:textoExtracto "en los módulos remotos de la serie RIO5 no está disponible esta velocidad" .

ex:ModuloRIOR a ex:ComponenteElectrico ;
    rdfs:label "módulos remotos de la serie RIOR" ;
    ex:textoExtracto "la velocidad de 250 kHz sólo está disponible para la comunicación con los teclados y los módulos remotos de la serie RIOW y RIOR" .

ex:ModuloRIOW a ex:ComponenteElectrico ;
    rdfs:label "módulos remotos de la serie RIOW" ;
    ex:textoExtracto "la velocidad de 250 kHz sólo está disponible para la comunicación con los teclados y los módulos remotos de la serie RIOW y RIOR" .

ex:TecladoCNC a ex:ComponenteElectrico ;
    rdfs:label "teclados" ;
    ex:textoExtracto "la velocidad de 250 kHz sólo está disponible para la comunicación con los teclados y los módulos remotos de la serie RIOW y RIOR" .

ex:ModeloLaser a ex:Maquina ;
    rdfs:label "modelo láser" ;
    ex:textoExtracto "Particularidades en el modelo láser. Para el modelo láser con módulos RIOR, se recomienda utilizar una frecuencia de comunicación de 1 MHz." .