@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ConfiguracionBusCAN_71 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuración del bus CAN (pág. 71)"@es ;
    ex:textoExtracto """
| Velocidad | Longitud del bus CAN. |
| --- | --- |
| Autoscan | El CNC ajusta la frecuencia del bus en cada arranque, en función de la velocidad del resto de los módulos. [...]"""@es ;
    ex:documentadoEn ex:Pagina_71 .

ex:Pagina_71
    a ex:Pagina ;
    ex:identificador "71" ;
    ex:textoExtracto "2.3.10 Configuración del bus CAN"@es .

ex:Frecuencia_Autoscan
    a ex:Frecuencia ;
    rdfs:label "Autoscan" ;
    ex:textoExtracto "El CNC ajusta la frecuencia del bus en cada arranque, en función de la velocidad del resto de los módulos. Dependiendo de la configuración del bus, esta opción puede hacer que el arranque del CNC sea más lento que si hay una frecuencia definida."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionBusCAN_71 .

ex:Frecuencia_1000kHz
    a ex:Frecuencia ;
    rdfs:label "1000 kHz" ;
    ex:valor "1000" ;
    ex:textoExtracto "Hasta 20 metros."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionBusCAN_71 .

ex:Frecuencia_800kHz
    a ex:Frecuencia ;
    rdfs:label "800 kHz" ;
    ex:valor "800" ;
    ex:textoExtracto "Entre 20 y 40 metros."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionBusCAN_71 .

ex:Frecuencia_500kHz
    a ex:Frecuencia ;
    rdfs:label "500 kHz" ;
    ex:valor "500" ;
    ex:textoExtracto "Entre 40 y 100 metros."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionBusCAN_71 .

ex:Frecuencia_250kHz
    a ex:Frecuencia ;
    rdfs:label "250 kHz" ;
    ex:valor "250" ;
    ex:textoExtracto "Entre 100 y 500 metros. [...] sólo está disponible para la comunicación con los teclados y los módulos remotos de la serie RIOW y RIOR; en los módulos remotos de la serie RIO5 no está disponible esta velocidad."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionBusCAN_71 .

ex:Frecuencia_1MHz_RecomendadaLaser
    a ex:Frecuencia ;
    rdfs:label "1 MHz (recomendada para modelo láser)" ;
    ex:valor "1000" ;
    ex:textoExtracto "Para el modelo láser con módulos RIOR, se recomienda utilizar una frecuencia de comunicación de 1 MHz."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionBusCAN_71 .