@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCabezalesConfiguracion a ns1:Sistema ;
    rdfs:label "Sistema de cabezales" ;
    ns1:textoExtracto "La numeración lógica de cabezales continúa a partir del último eje lógico; así, en un sistema con 3 ejes, el primer cabezal de la tabla será el cabezal lógico ꞏ4ꞏ y así sucesivamente." ;
    ns1:tieneComponente ns1:NombreDeVelocidadDelCabezal1,
        ns1:NombreDelEje1_24c4fecb1e,
        ns1:NombreDelEje2,
        ns1:NombreDelEje3 .

ns1:NombreDeVelocidadDelCabezal1 a ns1:Parametro ;
    rdfs:label "Nombre de velocidad del cabezal 1" ;
    ns1:identificador "SPDLNAME 1" ;
    ns1:textoExtracto "|  | SPDLNAME 1 | Número lógico ꞏ4ꞏ.|" .

ns1:NombreDelEje1_24c4fecb1e a ns1:Parametro ;
    rdfs:label "Nombre del eje 1" ;
    ns1:identificador "AXISNAME 1" ;
    ns1:textoExtracto "| AXISNAME 1 |  | Número lógico ꞏ1ꞏ.|" .

ns1:NombreDelEje2 a ns1:Parametro ;
    rdfs:label "Nombre del eje 2" ;
    ns1:identificador "AXISNAME 2" ;
    ns1:textoExtracto "| AXISNAME 2 |  | Número lógico ꞏ2ꞏ.|" .

ns1:NombreDelEje3 a ns1:Parametro ;
    rdfs:label "Nombre del eje 3" ;
    ns1:identificador "AXISNAME 3" ;
    ns1:textoExtracto "| AXISNAME 3 |  | Número lógico ꞏ3ꞏ.|" .

