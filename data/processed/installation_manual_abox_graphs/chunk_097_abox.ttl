@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaConfiguracionModBUS a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla MODBUS"@es ;
    ex:textoExtracto "Este parámetro muestra la tabla para configurar el servidor ModBUS."@es ;
    ex:tieneComponente ex:Parametro_MODBUSSVRTCP ;
    ex:tieneComponente ex:Parametro_MODBUSSVRRS ;
    ex:tieneComponente ex:Parametro_MODSVRID ;
    ex:tieneComponente ex:Parametro_MODBRATE .

ex:Parametro_MODBUSSVRTCP
    a ex:Parametro ;
    rdfs:label "MODBUSSVRTCP"@es ;
    ex:identificador "(V.)MPG.MODBUSSVRTCP" ;
    ex:textoExtracto "Activar el servidor ModBUS sobre TCP. Valores posibles: Sí / No. Valor por defecto: No."@es ;
    ex:valor "No" ;
    ex:documentadoEn ex:TablaConfiguracionModBUS .

ex:Parametro_MODBUSSVRRS
    a ex:Parametro ;
    rdfs:label "MODBUSSVRRS"@es ;
    ex:identificador "(V.)MPG.MODBUSSVRRS" ;
    ex:textoExtracto "Activar el servidor ModBUS sobre RS485. Valores posibles: Sí / No. Valor por defecto: No."@es ;
    ex:valor "No" ;
    ex:documentadoEn ex:TablaConfiguracionModBUS .

ex:Parametro_MODSVRID
    a ex:Parametro ;
    rdfs:label "MODSVRID"@es ;
    ex:identificador "(V.)MPG.MODSVRID" ;
    ex:textoExtracto "Identificador del servidor ModBUS sobre RS485. Valores posibles: De 1 a 255. Valor por defecto: 1."@es ;
    ex:valor "1" ;
    ex:documentadoEn ex:TablaConfiguracionModBUS .

ex:Parametro_MODBRATE
    a ex:Parametro ;
    rdfs:label "MODBRATE"@es ;
    ex:identificador "(V.)MPG.MODBRATE" ;
    ex:textoExtracto "Velocidad de comunicación del servidor ModBUS sobre RS485. Valores posibles: 19200 Bd / 38400 Bd / 57600 Bd / 115200 Bd. Valor por defecto: 19200 Bd."@es ;
    ex:valor "19200 Bd" ;
    ex:documentadoEn ex:TablaConfiguracionModBUS .