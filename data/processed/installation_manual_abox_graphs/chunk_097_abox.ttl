@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TablaModBUS a ex:Esquema ;
    ex:textoExtracto "MODBUS Configurar el servidor ModBUS. Este parámetro muestra la tabla para configurar el servidor ModBUS." ;
    ex:tieneComponente ex:MODBUSSVRTCP, ex:MODBUSSVRRS, ex:MODSVRID, ex:MODBRATE .

ex:MODBUSSVRTCP a ex:Parametro ;
    ex:textoExtracto "MODBUSSVRTCP Activar el servidor ModBUS sobre TCP. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPG.MODBUSSVRTCP Parámetro incluido en la tabla MODBUS. Activar el servidor ModBUS sobre TCP." ;
    ex:valor "Sí / No" ;
    ex:identificador "(V.)MPG.MODBUSSVRTCP" .

ex:MODBUSSVRRS a ex:Parametro ;
    ex:textoExtracto "MODBUSSVRRS Activar el servidor ModBUS sobre RS485. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPG.MODBUSSVRRS Parámetro incluido en la tabla MODBUS. Activar el servidor ModBUS sobre RS485." ;
    ex:valor "Sí / No" ;
    ex:identificador "(V.)MPG.MODBUSSVRRS" .

ex:MODSVRID a ex:Parametro ;
    ex:textoExtracto "MODSVRID Identificador del servidor ModBUS sobre RS485. Valores posibles: De 1 a 255. Valor por defecto: 1. Variable asociada: (V.)MPG.MODSVRID Parámetro incluido en la tabla MODBUS. Identificador del servidor ModBUS sobre RS485." ;
    ex:valor "De 1 a 255" ;
    ex:identificador "(V.)MPG.MODSVRID" .

ex:MODBRATE a ex:Parametro ;
    ex:textoExtracto "MODBRATE Velocidad de comunicación del servidor ModBUS sobre RS485. Valores posibles: 19200 Bd / 38400 Bd / 57600 Bd / 115200 Bd. Valor por defecto: 19200 Bd. Variable asociada: (V.)MPG.MODBRATE Parámetro incluido en la tabla MODBUS. Velocidad de comunicación del servidor ModBUS sobre RS485." ;
    ex:valor "19200 Bd / 38400 Bd / 57600 Bd / 115200 Bd" ;
    ex:identificador "(V.)MPG.MODBRATE" .