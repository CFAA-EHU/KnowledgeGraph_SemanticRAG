@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ETHERCATBUS a ex:Parametro ;
    ex:textoExtracto "ETHERCATBUS Activar el bus EtherCAT. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPG.ETHERCATBUS Activar el bus EtherCAT." ;
