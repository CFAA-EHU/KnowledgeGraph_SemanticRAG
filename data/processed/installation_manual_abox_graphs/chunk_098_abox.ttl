@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FrecuenciaPRGFREQ a ns1:Frecuencia ;
    rdfs:label "Frecuencia de cambio del módulo PRG del PLC" ;
    ns1:identificador "PRGFREQ" ;
    ns1:textoExtracto "Periodicidad del módulo PRG del PLC (PRGFREQ)." .

ns1:Herramienta_f42a9383b6 a ns1:Herramienta ;
    rdfs:label "Herramienta comercial de análisis lógico del bus CAN" ;
    ns1:textoExtracto "lo más fiable es recurrir a una herramienta comercial de análisis lógico del bus CAN." .

ns1:SistemaCAN a ns1:Sistema ;
    rdfs:label "Sistema CAN" ;
    ns1:monitoreaParametro ns1:TiempoDeCicloMinimoParaUnaConfiguracionDada ;
    ns1:textoExtracto "Desde el punto de vista del bus CAN, el tiempo mínimo de ciclo para una determinada configuración viene condicionado fundamentalmente por las necesidades del tráfico del sistema;" .

ns1:SistemaPLCPRG a ns1:Sistema ;
    rdfs:label "Módulo PRG del PLC" ;
    ns1:textoExtracto "Periodicidad del módulo PRG del PLC (PRGFREQ)." .

ns1:TiempoDeCicloMinimoParaUnaConfiguracionDada a ns1:Parametro ;
    rdfs:label "Tiempo de ciclo mínimo para una configuración dada" ;
    ns1:identificador "LOOPTIME" ;
    ns1:textoExtracto "Influencia del bus CAN en el parámetro LOOPTIME." .

