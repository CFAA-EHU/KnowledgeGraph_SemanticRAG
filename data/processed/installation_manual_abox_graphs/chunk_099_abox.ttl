@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_5819f150e3 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "En ambos casos, sería necesario incrementar el valor del parámetro LOOPTIME o reducir el tiempo de comunicación del sistema (aumentando la velocidad de CAN, aumentando el valor del parámetro PRGFREQ o quitando elementos físicos)." .

ns1:FrecuenciaDelPrograma a ns1:Parametro ;
    rdfs:label "Frecuencia del programa" ;
    ns1:identificador "PRGFREQ" ;
    ns1:textoExtracto "En ambos casos, sería necesario incrementar el valor del parámetro LOOPTIME o reducir el tiempo de comunicación del sistema (aumentando la velocidad de CAN, aumentando el valor del parámetro PRGFREQ o quitando elementos físicos)." .

ns1:TiempoDeCicloDelCNC a ns1:Parametro ;
    rdfs:label "Tiempo de ciclo del CNC" ;
    ns1:identificador "LOOPTIME" ;
    ns1:textoExtracto "Con esta herramienta se puede fijar el parámetro LOOPTIME con un valor que cubra con garantías las necesidades de comunicación, pero sin saturar el ancho de banda del sistema." .

