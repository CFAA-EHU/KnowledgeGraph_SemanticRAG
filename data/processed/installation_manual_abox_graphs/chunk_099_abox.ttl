@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MPG_INCHES a ex:Parametro ;
    rdfs:label "MPG.INCHES" ;
    ex:identificador "(V.)MPG.INCHES" ;
    ex:textoExtracto "Este parámetro indica las unidades de trabajo que asume el CNC por defecto; es decir, en el momento de encendido, después de ejecutarse M02, M30 o después de un reset. También son las unidades para los desplazamientos respecto al cero máquina (#MCS). Para cambiar las unidades desde el programa pieza, utilizar las funciones G70 ó G71." ;
    ex:valor "Milímetros" .

ex:MPG_PRESSURE a ex:Parametro ;
    rdfs:label "MPG.PRESSURE" ;
    ex:identificador "(V.)MPG.PRESSURE" ;
    ex:textoExtracto "Este parámetro indica las unidades de trabajo que asume el CNC por defecto; es decir, en el momento de encendido, después de ejecutarse M02, M30 o después de un reset." ;
    ex:valor "Bar" .