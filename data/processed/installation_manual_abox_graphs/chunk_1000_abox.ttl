@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SUB_ARM_BACK a ex:AccionProhibida ;
    ex:textoExtracto "LL SUB_ARM_BACK ; Retirar el brazo cambiador." .

ex:SUB_CH2_TO_MZ a ex:AccionProhibida ;
    ex:textoExtracto "LL SUB_CH2_TO_MZ ; Comenzar el envío del brazo cambiador al almacén para dejar la herramienta." .

ex:TCHANGEOK a ex:Parametro ;
    ex:identificador "V.PLC.M[1100]=1" ;
    ex:textoExtracto "V.PLC.M[1100]=1 ; Orden al PLC para que active la marca TCHANGEOK, indicando al gestor que puede continuar la ejecución." .

ex:SUB_MZ_TO_CH1 a ex:AccionProhibida ;
    ex:textoExtracto "LL SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1." .

ex:SUB_SPD_AUTCHG a ex:AccionProhibida ;
    ex:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático." .

ex:SUB_ARM_TO_CHG a ex:AccionProhibida ;
    ex:textoExtracto "LL SUB_ARM_TO_CHG ; Llevar el brazo cambiador al punto de cambio." .

ex:SUB_CH1_TO_SPD a ex:AccionProhibida ;
    ex:textoExtracto "LL SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal." .

ex:SUB_SPD_GMCHG a ex:AccionProhibida ;
    ex:textoExtracto "LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual." .