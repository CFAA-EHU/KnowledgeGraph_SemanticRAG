@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioDeHerramienta_2566e97249 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta" ;
    ns1:ejecuta ns1:Componente_2ab7e63384 ;
    ns1:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático. LL SUB_MZ_TO_SPD ; Poner la herramienta del almacén en el cabezal." .

ns1:Componente_2ab7e63384 a ns1:Componente ;
    rdfs:label "Almacén",
        "Cabezal",
        "Herramienta" ;
    ns1:textoExtracto "LL SUB_SPD_TO_MZ ; Dejar la herramienta del cabezal en el almacén. $BREAK $CASE 10 ; Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal." .

