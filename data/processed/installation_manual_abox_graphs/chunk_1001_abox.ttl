@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CodigoDeOperacionDelPLCParaOptimizacionDelCambio a ns1:Parametro ;
    rdfs:label "Código de operación del PLC para optimización del cambio" ;
    ns1:identificador "TMOPERATION" ;
    ns1:textoExtracto "el gestor envía al PLC el código TMOPERATION=11." .

ns1:Parametro_7959033478 a ns1:Parametro ;
    rdfs:label "Marca que indica herramienta llevada de tierra al cabezal" ;
    ns1:identificador "GRTOSPDL" ;
    ns1:textoExtracto "La herramienta se ha llevado de tierra al cabezal." .

ns1:Parametro_94a80a9622 a ns1:Parametro ;
    rdfs:label "Marca que indica finalización de operación" ;
    ns1:identificador "MZROT" ;
    ns1:textoExtracto "Activar la marca MZROT para indicar al gestor que se ha finalizado la operación." .

ns1:Parametro_aed1a67bbe a ns1:Parametro ;
    rdfs:label "Marca que indica herramienta llevada del cabezal a tierra" ;
    ns1:identificador "SPDLTOGR" ;
    ns1:textoExtracto "La herramienta se ha llevado del cabezal a tierra." .

ns1:Parametro_db77df6f5e a ns1:Parametro ;
    rdfs:label "Marca que indica herramienta llevada del almacén al cabezal" ;
    ns1:identificador "MZTOSPDL" ;
    ns1:textoExtracto "La herramienta se ha llevado del almacén al cabezal." .

