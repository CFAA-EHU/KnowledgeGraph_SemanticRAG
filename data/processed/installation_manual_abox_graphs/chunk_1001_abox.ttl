@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:LL_SUB_CH1_TO_SPD a ex:AccionProhibida ;
    ex:textoExtracto "punto de cambio. LL SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal." .

ex:LL_SUB_ARM_BACK a ex:AccionProhibida ;
    ex:textoExtracto "LL SUB_ARM_BACK ; Retirar el brazo cambiador." .

ex:LL_SUB_SPD_GMCHG a ex:AccionProhibida ;
    ex:textoExtracto "LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual." .

ex:LL_SUB_SPD_TO_GR a ex:AccionProhibida ;
    ex:textoExtracto "LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal." .

ex:V_PLC_TMOPERATION a ex:Parametro ;
    ex:textoExtracto "V.PLC.TMOPERATION = 0" .

ex:V_TM_MZWAIT a ex:Parametro ;
    ex:textoExtracto "V.TM.MZWAIT == 1" .

ex:ESTOP a ex:AccionProhibida ;
    ex:textoExtracto "# ESTOP ; Habilitar la tecla STOP." .