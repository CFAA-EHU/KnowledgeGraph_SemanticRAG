@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IndicaLaPosicionDeAlmacenEnLaQueHayQueDejarLaHerramienta a ns1:Parametro ;
    rdfs:label "Indica la posición de almacén en la que hay que dejar la herramienta" ;
    ns1:identificador "LEAVEPOS" ;
    ns1:textoExtracto "Este registro indica la posición de almacén en la que hay que dejar la herramienta." .

ns1:IndicaLaPosicionDeAlmacenQueOcupaLaHerramientaQueHayQueCoger a ns1:Parametro ;
    rdfs:label "Indica la posición de almacén que ocupa la herramienta que hay que coger" ;
    ns1:identificador "TAKEPOS" ;
    ns1:textoExtracto "Este registro indica la posición de almacén que ocupa la herramienta que hay que coger." .

ns1:IndicaQueElAlmacenYaHaGirado a ns1:Parametro ;
    rdfs:label "Indica que el almacén ya ha girado" ;
    ns1:identificador "M1111" ;
    ns1:textoExtracto "DFU M1111 = SET MZROT DFD MZROT = RES M1111 Ya ha girado el almacén." .

ns1:IndicaQueLaHerramientaSeHaLlevadoDelCabezalAlAlmacen a ns1:Parametro ;
    rdfs:label "Indica que la herramienta se ha llevado del cabezal al almacén" ;
    ns1:identificador "M1110" ;
    ns1:textoExtracto "DFU M1110 = SET SPDLTOGR DFD SPDLTOGR = RES M1110 La herramienta se ha llevado del cabezal al almacén." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "La rutina M06 utiliza las siguientes funciones auxiliares M para indicar al PLC qué movimientos debe realizar." .

