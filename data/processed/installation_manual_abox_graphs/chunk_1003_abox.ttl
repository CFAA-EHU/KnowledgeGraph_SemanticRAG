@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:M06 a ex:TareaMantenimiento ;
    ex:textoExtracto "La rutina M06 utiliza las siguientes funciones auxiliares M para indicar al PLC qué movimientos debe realizar." ;
    ex:compuestoPor ex:M101, ex:M102, ex:M104, ex:M106, ex:M121, ex:M122, ex:M123 .

ex:M101 a ex:TareaMantenimiento ;
    ex:textoExtracto "M101 Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1." .

ex:M102 a ex:TareaMantenimiento ;
    ex:textoExtracto "M102 Llevar la herramienta de la pinza 1 al cabezal." .

ex:M104 a ex:TareaMantenimiento ;
    ex:textoExtracto "M104 Coger la herramienta del cabezal con la pinza 2." .

ex:M106 a ex:TareaMantenimiento ;
    ex:textoExtracto "M106 Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza 2." .

ex:M121 a ex:TareaMantenimiento ;
    ex:textoExtracto "M121 Llevar el brazo cambiador al punto de cambio." .

ex:M122 a ex:TareaMantenimiento ;
    ex:textoExtracto "M122 Llevar el brazo cambiador al almacén." .

ex:M123 a ex:TareaMantenimiento ;
    ex:textoExtracto "M123 Retirar el brazo cambiador." .