ns1:LamparaDeLaTeclaUSER12IluminadaCuandoHayEmergencia a ns1:AvisoSeguridad ;
    rdfs:label "Lámpara de la tecla USER12 iluminada cuando hay emergencia" ;
    ns1:textoExtracto "Lámpara de la tecla USER12 iluminada cuando hay" .

ns1:PosicionDeAlmacenQueOcupaLaHerramienta a ns1:Parametro ;
    rdfs:label "Posición de almacén que ocupa la herramienta" ;
    ns1:identificador "TAKEPOS" ;
    ns1:textoExtracto "Este registro indica la posición de almacén que ocupa la herramienta que hay que coger." .

ns1:SenalDeEmergenciaDelGestorDeHerramientas a ns1:AvisoSeguridad ;
    rdfs:label "Señal de emergencia del gestor de herramientas" ;
    ns1:solucionaFallo ns1:ActivacionDeLaEmergenciaMedianteTeclaUSER12 ;
    ns1:textoExtracto "Tratamiento de la señal de emergencia del gestor de herramientas." .

ns1:SenalDeEmergenciaDelGestorDeHerramientas_e671f9e281 a ns1:Parametro ;
    rdfs:label "Señal de emergencia del gestor de herramientas" ;
    ns1:identificador "TMINEM" ;
    ns1:textoExtracto "Si se pulsa la tecla USER12 se activa la emergencia." .

ns1:ActivacionDeLaEmergenciaMedianteTeclaUSER12 a ns1:TareaMantenimiento ;
    rdfs:label "Activación de la emergencia mediante tecla USER12" ;
    ns1:textoExtracto "Si se pulsa la tecla USER12 se activa la emergencia." .

