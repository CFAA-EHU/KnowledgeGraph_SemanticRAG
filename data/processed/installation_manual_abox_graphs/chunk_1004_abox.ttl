@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:M121 a ex:TareaMantenimiento ;
    rdfs:label "M121" ;
    ex:textoExtracto "Llevar el brazo cambiador al punto de cambio." .

ex:M122 a ex:TareaMantenimiento ;
    rdfs:label "M122" ;
    ex:textoExtracto "Llevar el brazo cambiador al almacén." .

ex:M123 a ex:TareaMantenimiento ;
    rdfs:label "M123" ;
    ex:textoExtracto "Retirar el brazo cambiador." .

ex:CH2TOMZ a ex:Sensor ;
    rdfs:label "CH2TOMZ" ;
    ex:textoExtracto "Activar la marca CH2TOMZ cuando se haya dejado la herramienta, para que el gestor sepa que la herramienta se ha llevado de la pinza 2 al almacén." .

ex:LEAVEPOS a ex:Parametro ;
    rdfs:label "LEAVEPOS" ;
    ex:textoExtracto "Este registro indica la posición de almacén en la que hay que dejar la herramienta." .

ex:TAKEPOS a ex:Parametro ;
    rdfs:label "TAKEPOS" ;
    ex:textoExtracto "Este registro indica la posición de almacén que ocupa la herramienta que hay que coger." .

ex:USER12 a ex:Sensor ;
    rdfs:label "USER12" ;
    ex:textoExtracto "Si se pulsa la tecla USER12 se activa la emergencia." .

ex:USER13 a ex:Sensor ;
    rdfs:label "USER13" ;
    ex:textoExtracto "Si se pulsa la tecla USER13 se quita la emergencia." .

ex:B11KEYBD1 a ex:Sensor ;
    rdfs:label "B11KEYBD1" ;
    ex:textoExtracto "Señal de emergencia del gestor de herramientas." .

ex:B11KEYLED1 a ex:Sensor ;
    rdfs:label "B11KEYLED1" ;
    ex:textoExtracto "Lámpara de la tecla USER12 iluminada cuando hay emergencia." .

ex:B12KEYBD1 a ex:Sensor ;
    rdfs:label "B12KEYBD1" ;
    ex:textoExtracto "Señal de emergencia del gestor de herramientas." .

ex:TMINEM a ex:Parametro ;
    rdfs:label "TMINEM" ;
    ex:textoExtracto "Señal de emergencia del gestor." .

ex:DFU a ex:Parametro ;
    rdfs:label "DFU" ;
    ex:textoExtracto "Tratamiento de la señal de emergencia del gestor de herramientas." .

ex:SETTMEM a ex:Parametro ;
    rdfs:label "SETTMEM" ;
    ex:textoExtracto "Tratamiento de la señal de emergencia del gestor de herramientas." .

ex:RESTMEM a ex:Parametro ;
    rdfs:label "RESTMEM" ;
    ex:textoExtracto "Tratamiento de la señal de emergencia del gestor de herramientas." .