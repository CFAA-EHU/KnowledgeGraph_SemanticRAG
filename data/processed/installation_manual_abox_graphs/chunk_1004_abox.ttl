@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:M121 a ex:TareaMantenimiento ;
    rdfs:label "Llevar el brazo cambiador al punto de cambio"@es ;
    ex:textoExtracto "M121 Llevar el brazo cambiador al punto de cambio."@es ;
    ex:identificador "M121" .

ex:M122 a ex:TareaMantenimiento ;
    rdfs:label "Llevar el brazo cambiador al almacén"@es ;
    ex:textoExtracto "M122 Llevar el brazo cambiador al almacén."@es ;
    ex:identificador "M122" .

ex:M123 a ex:TareaMantenimiento ;
    rdfs:label "Retirar el brazo cambiador"@es ;
    ex:textoExtracto "M123 Retirar el brazo cambiador."@es ;
    ex:identificador "M123" .

ex:M106 a ex:TareaMantenimiento ;
    rdfs:label "Gestión de herramienta en pinza 2"@es ;
    ex:textoExtracto "Tratamiento de la función M106: • Dar por finalizada cuando el brazo abandona la zona de posible colisión y se puede mecanizar. • Activar la marca CH2TOMZ cuando se haya dejado la herramienta, para que el gestor sepa que la herramienta se ha llevado de la pinza 2 al almacén."@es ;
    ex:identificador "M106" .

ex:Pinza2 a ex:ComponenteMecanico ;
    rdfs:label "Herramienta de la pinza 2"@es ;
    ex:textoExtracto "herramienta de la pinza 2"@es .

ex:BrazoCambiador a ex:ComponenteMecanico ;
    rdfs:label "Brazo cambiador de herramientas"@es ;
    ex:textoExtracto "brazo cambiador"@es .

ex:AlmacenHerramientas a ex:ComponenteMecanico ;
    rdfs:label "Almacén de herramientas"@es ;
    ex:textoExtracto "almacén"@es .

ex:LEAVEPOS a ex:Parametro ;
    rdfs:label "Registro LEAVEPOS"@es ;
    ex:textoExtracto "LEAVEPOS Este registro indica la posición de almacén en la que hay que dejar la herramienta."@es .

ex:TAKEPOS a ex:Parametro ;
    rdfs:label "Registro TAKEPOS"@es ;
    ex:textoExtracto "TAKEPOS Este registro indica la posición de almacén que ocupa la herramienta que hay que coger."@es .

ex:EmergenciaGestor a ex:AvisoSeguridad ;
    rdfs:label "Señal de emergencia del gestor de herramientas"@es ;
    ex:textoExtracto "Señal de emergencia del gestor. Tratamiento de la señal de emergencia del gestor de herramientas."@es .

ex:Tecla_USER12 a ex:InterfazUsuario ;
    rdfs:label "Tecla USER12 (activación emergencia)"@es ;
    ex:textoExtracto "Si se pulsa la tecla USER12 se activa la emergencia."@es ;
    ex:identificador "USER12" .

ex:Tecla_USER13 a ex:InterfazUsuario ;
    rdfs:label "Tecla USER13 (desactivación emergencia)"@es ;
    ex:textoExtracto "Si se pulsa la tecla USER13 se quita la emergencia."@es ;
    ex:identificador "USER13" .

ex:Lampara_USER12 a ex:Alarma ;
    rdfs:label "Lámpara USER12 (indica emergencia)"@es ;
    ex:textoExtracto "Lámpara de la tecla USER12 iluminada cuando hay emergencia."@es .

ex:M106 ex:ejecutadoPor ex:BrazoCambiador .
ex:M106 ex:requiereMantenimiento ex:Pinza2 .
ex:M121 ex:ejecutadoPor ex:BrazoCambiador .
ex:M122 ex:ejecutadoPor ex:BrazoCambiador ;
      ex:requiereMantenimiento ex:AlmacenHerramientas .
ex:M123 ex:ejecutadoPor ex:BrazoCambiador .
ex:EmergenciaGestor ex:activaAlarma ex:Lampara_USER12 .
ex:Tecla_USER12 ex:activaAlarma ex:EmergenciaGestor .
ex:Tecla_USER13 ex:solucionaFallo ex:EmergenciaGestor .