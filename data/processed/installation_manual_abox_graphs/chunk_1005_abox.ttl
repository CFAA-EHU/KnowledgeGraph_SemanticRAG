@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjecucionDeLaFuncionM06 a ns1:TareaMantenimiento ;
    rdfs:label "Ejecución de la función M06" ;
    ns1:ejecutadoPor ns1:CNC8070_5ef3b83dee ;
    ns1:textoExtracto "Dentro de dicha rutina hay que volver a programar la función M06 para que el CNC indique al gestor que debe comenzar el cambio de herramienta." .

ns1:EjecucionDeLaFuncionT a ns1:TareaMantenimiento ;
    rdfs:label "Ejecución de la función T" ;
    ns1:ejecutadoPor ns1:CNC8070_5ef3b83dee ;
    ns1:textoExtracto "1 Cuando el CNC ejecuta la función T, se lo indica al gestor." .

ns1:GestionDelCambioDeHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Gestión del cambio de herramienta" ;
    ns1:ejecutadoPor ns1:CNC8070_5ef3b83dee ;
    ns1:textoExtracto "Se aconseja incluir la gestión del cambio de herramienta en la rutina asociada a M06 y dejar como labor del PLC el control de los dispositivos externos." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "El gestor envía una orden al PLC para que seleccione la próxima herramienta en el almacén (si se puede)." .

ns1:CNC8070_5ef3b83dee a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controladoPor ns1:SistemaPLC ;
    ns1:textoExtracto "El gestor envía una orden al PLC para efectuar el cambio." .

