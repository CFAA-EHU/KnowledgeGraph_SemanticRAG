@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:PLC_InterfazTeclado
    a                     ex:InterfazUsuario ;
    rdfs:label            "Interfaz de teclado del PLC"@es ;
    ex:textoExtracto      "La distribución del teclado controla los caracteres que aparecen en la pantalla cuando se pulsan las teclas. Para que los caracteres de la pantalla coincidan con las teclas, en el sistema operativo hay que seleccionar la distribución de teclado adecuada. Los código de tecla (scan codes) también dependen de la distribución de teclado seleccionada."@es ;
    ex:tieneComponente    ex:Teclado_EspanolEspana, ex:Teclado_InglesEEUU ;
    ex:ilustradoEn        ex:Tabla_DistribucionesTeclado .

ex:Teclado_EspanolEspana
    a                     ex:Componente ;
    rdfs:label            "Teclado (Español - España)"@es ;
    ex:identificador      "Español (España)" ;
    ex:textoExtracto      "Español (España)."@es .

ex:Teclado_InglesEEUU
    a                     ex:Componente ;
    rdfs:label            "Teclado (Inglés - Estados Unidos)"@es ;
    ex:identificador      "Inglés (Estados Unidos)" ;
    ex:textoExtracto      "Inglés (Estados Unidos)."@es .

ex:Tabla_DistribucionesTeclado a ex:Tabla ;
     a                     ex:Tabla ;
    rdfs:label            "Tabla de distribuciones de teclado disponibles"@es ;
    ex:textoExtracto      "| Teclados. |  |  | --- | --- | --- | Español (España). | Español (España). | Español (España). |  |  |  | Inglés (Estados Unidos). |  |  |"@es ;
    ex:documentadoEn      ex:Pagina_541_542 .