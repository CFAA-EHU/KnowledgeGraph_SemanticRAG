@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RegistroLEAVEPOS a ns1:Parametro ;
    rdfs:label "Registro LEAVEPOS" ;
    ns1:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor." .

ns1:RegistroTAKEPOS a ns1:Parametro ;
    rdfs:label "Registro TAKEPOS" ;
    ns1:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor." .

ns1:ValorTAKEPOSAlmacen a ns1:Parametro ;
    rdfs:label "Posición en el almacén" ;
    ns1:documentadoEn ns1:TablaValoresTakePosLeavePos ;
    ns1:identificador "#" ;
    ns1:textoExtracto "# | Posición en el almacén." .

ns1:ValorTAKEPOSCero a ns1:Parametro ;
    rdfs:label "No hay que hacer nada" ;
    ns1:documentadoEn ns1:TablaValoresTakePosLeavePos ;
    ns1:identificador "0" ;
    ns1:textoExtracto "0 | No hay que hacer nada." .

ns1:ValorTAKEPOSTierra a ns1:Parametro ;
    rdfs:label "Herramienta de tierra" ;
    ns1:documentadoEn ns1:TablaValoresTakePosLeavePos ;
    ns1:identificador "-4" ;
    ns1:textoExtracto "-4 | Herramienta de tierra." .

ns1:TablaValoresTakePosLeavePos a ns1:Tabla ;
    rdfs:label "Tabla de valores TAKEPOS y LEAVEPOS" ;
    ns1:textoExtracto "A continuación se muestra una tabla resumen de los valores TAKEPOS y LEAVEPOS que utiliza el gestor en cada una de las operaciones, así como las marcas que debe activar el PLC al finalizar cada operación." .

