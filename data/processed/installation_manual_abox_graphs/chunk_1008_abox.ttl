@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazUsuario_CNC_ModosTrabajo
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de usuario - Modos de trabajo CNC" ;
    ex:textoExtracto "Ventana de tareas, Menú principal, Modo automático, Modo manual, Modo MDI/MDA, Modo EDISIMU, Tablas de usuario, Tabla de herramientas y del almacén, Modo utilidades, Modo de usuario, Calculadora, Help, Barra para modificar la dinámica de la máquina" ;
    ex:tieneComponente
        ex:ModoOperacion_Auto,
        ex:ModoOperacion_Manual,
        ex:ModoOperacion_MDI,
        ex:ModoOperacion_EDISIMU,
        ex:ModoOperacion_Usuario,
        ex:ModoOperacion_Utilidades .

ex:InterfazUsuario_CNC_Operaciones
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de usuario - Operaciones CNC" ;
    ex:textoExtracto "Menú anterior horizontal, Cambio de ventana, Cambio de pantalla, Tecla bi-color, Recuperar un valor, Modo bloque a bloque, Mostrar/Ocultar panel de mando virtual, Mostrar/Ocultar los mensajes del PLC, Mostrar/Ocultar los mensajes del CNC, Minimizar/Maximizar el CNC, Apagar el CNC, Ventana de sincronización de canales" ;
    ex:tieneComponente
        ex:ModoOperacion_SingleBlock .

ex:ModoOperacion_Auto
    a ex:ModoOperacion ;
    rdfs:label "Modo automático (AUTO)" ;
    ex:identificador "AUTO" ;
    ex:textoExtracto "Modo automático. | AUTO | [CTRL]+[F6]" .

ex:ModoOperacion_Manual
    a ex:ModoOperacion ;
    rdfs:label "Modo manual (MANUAL)" ;
    ex:identificador "MANUAL" ;
    ex:textoExtracto "Modo manual. | MANUAL | [CTRL]+[F7]" .

ex:ModoOperacion_MDI
    a ex:ModoOperacion ;
    rdfs:label "Modo MDI/MDA" ;
    ex:identificador "MDI" ;
    ex:textoExtracto "Modo MDI/MDA. | MDI | [CTRL]+[F8]" .

ex:ModoOperacion_EDISIMU
    a ex:ModoOperacion ;
    rdfs:label "Modo EDISIMU (EDIT)" ;
    ex:identificador "EDIT" ;
    ex:textoExtracto "Modo EDISIMU. | EDIT | [CTRL]+[F9]" .

ex:ModoOperacion_Usuario
    a ex:ModoOperacion ;
    rdfs:label "Modo de usuario" ;
    ex:textoExtracto "Modo de usuario. | [SHIFT]+[F1]" .

ex:ModoOperacion_Utilidades
    a ex:ModoOperacion ;
    rdfs:label "Modo utilidades (UTILITIES)" ;
    ex:identificador "UTILITIES" ;
    ex:textoExtracto "Modo utilidades. | UTILITIES | [CTRL]+[F12]" .

ex:ModoOperacion_SingleBlock
    a ex:ModoOperacion ;
    rdfs:label "Modo bloque a bloque (SINGLE)" ;
    ex:identificador "SINGLE" ;
    ex:textoExtracto "Modo bloque a bloque. | SINGLE | [CTRL]+[B]" .