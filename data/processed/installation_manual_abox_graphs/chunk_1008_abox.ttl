@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:InterfazUsuario_1008_1 a ex:InterfazUsuario ;
    ex:textoExtracto "Modo de trabajo. | Tecla. | Hotkey. | Ventana de tareas. |  | [CTRL]+[A] | Menú principal. | MAIN MENU | [CTRL]+[SHIFT]+[F1] | Modo automático. | AUTO | [CTRL]+[F6] | Modo manual. | MANUAL | [CTRL]+[F7] | Modo MDI/MDA. | MDI | [CTRL]+[F8] | Modo EDISIMU. | EDIT | [CTRL]+[F9] | Tablas de usuario. | TABLES | [CTRL]+[F10] | Tabla de herramientas y del almacén. | TOOLS | [CTRL]+[F11] | Modo utilidades. | UTILITIES | [CTRL]+[F12] | Modo de usuario. |  | [SHIFT]+[F1] | Calculadora. | CALC | [CTRL]+[K] | Help. | HELP ? | [CTRL]+[F4] | Barra para modificar la dinámica de la máquina. |  | [CTRL]+[H] |" ;
    ex:tieneComponente ex:Tecla_CTRL_A_1008, ex:Tecla_CTRL_SHIFT_F1_1008, ex:Tecla_CTRL_F6_1008, ex:Tecla_CTRL_F7_1008, ex:Tecla_CTRL_F8_1008, ex:Tecla_CTRL_F9_1008, ex:Tecla_CTRL_F10_1008, ex:Tecla_CTRL_F11_1008, ex:Tecla_CTRL_F12_1008, ex:Tecla_SHIFT_F1_1008, ex:Tecla_CTRL_K_1008, ex:Tecla_CTRL_F4_1008, ex:Tecla_CTRL_H_1008 .

ex:InterfazUsuario_1008_2 a ex:InterfazUsuario ;
    ex:textoExtracto "Operaciones en el CNC. |  | Hotkey. | Menú anterior horizontal. | BACK | [CTRL]+[F1] | Cambio de ventana. | FOCUS | [CTRL]+[F2] | Cambio de pantalla. | NEXT | [CTRL]+[F3] | Tecla bi-color. |  | [ALT]+[B] | Recuperar un valor. | RECALL | [CTRL]+[F5] | Modo bloque a bloque. | SINGLE | [CTRL]+[B] | Mostrar/Ocultar panel de mando virtual. |  | [CTRL]+[J] | Mostrar/Ocultar los mensajes del PLC. |  | [CTRL]+[M] | Mostrar/Ocultar los mensajes del CNC. |  | [CTRL]+[O] | Minimizar/Maximizar el CNC. |  | [CTRL]+[W] | Apagar el CNC. |  | [ALT]+[F4] | Ventana de sincronización de canales." ;
    ex:tieneComponente ex:Tecla_CTRL_F1_1008, ex:Tecla_CTRL_F2_1008, ex:Tecla_CTRL_F3_1008, ex:Tecla_ALT_B_1008, ex:Tecla_CTRL_F5_1008, ex:Tecla_CTRL_B_1008, ex:Tecla_CTRL_J_1008, ex:Tecla_CTRL_M_1008, ex:Tecla_CTRL_O_1008, ex:Tecla_CTRL_W_1008, ex:Tecla_ALT_F4_1008 .

ex:Tecla_CTRL_A_1008 a ex:InterfazUsuario ;
    rdfs:label "[CTRL]+[A]" ;
    ex:textoExtracto "[CTRL]+[A]" .

