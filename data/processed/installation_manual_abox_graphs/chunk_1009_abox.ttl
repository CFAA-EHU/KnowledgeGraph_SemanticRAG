@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:InterfazUsuario_1009_1 a ex:InterfazUsuario ;
    ex:textoExtracto "Minimizar/Maximizar el CNC. | [CTRL]+[O]" ;
    ex:identificador "[CTRL]+[O]" .

ex:InterfazUsuario_1009_2 a ex:InterfazUsuario ;
    ex:textoExtracto "Apagar el CNC. | [CTRL]+[W]" ;
    ex:identificador "[CTRL]+[W]" .

ex:InterfazUsuario_1009_3 a ex:InterfazUsuario ;
    ex:textoExtracto "Ventana de sincronización de canales. | [ALT]+[F4]" ;
    ex:identificador "[ALT]+[F4]" .

ex:InterfazUsuario_1009_4 a ex:InterfazUsuario ;
    ex:textoExtracto "Mostrar / ocultar la ventana de errores y warnings. | [ALT]+[S]" ;
    ex:identificador "[ALT]+[S]" .

ex:InterfazUsuario_1009_5 a ex:InterfazUsuario ;
    ex:textoExtracto "Mostrar / ocultar la ventana de errores y warnings. | [ALT]+[W]" ;
    ex:identificador "[ALT]+[W]" .