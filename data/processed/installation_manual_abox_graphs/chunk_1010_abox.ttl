@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Variable_GKEY
    a                     ex:Parametro ;
    rdfs:label            "Variable G.KEY"@es ;
    ex:identificador      "G.KEY" ;
    ex:textoExtracto      "La variable (V.)G.KEY guarda el código de la última tecla aceptada por el CNC (código de tecla pulsada)."@es ;
    ex:monitoreaParametro ex:InterfazUsuario_CNC .

ex:InterfazUsuario_CNC
    a                     ex:InterfazUsuario ;
    rdfs:label            "Interfaz de usuario del CNC"@es ;
    ex:textoExtracto      "última tecla aceptada por el CNC"@es .

ex:Comando_CNCRD
    a                     ex:Parametro ;
    rdfs:label            "Comando CNCRD"@es ;
    ex:identificador      "CNCRD" ;
    ex:textoExtracto      "El comando CNCRD guarda el código de la tecla en el registro R100. [...] { condición} = CNCRD(G.KEY,R100,M100)"@es ;
    ex:monitoreaParametro ex:Variable_GKEY .

ex:Registro_R100
    a                     ex:Parametro ;
    rdfs:label            "Registro R100"@es ;
    ex:identificador      "R100" ;
    ex:textoExtracto      "El comando CNCRD guarda el código de la tecla en el registro R100."@es .

ex:Marca_M100
    a                     ex:Parametro ;
    rdfs:label            "Marca M100"@es ;
    ex:identificador      "M100" ;
    ex:textoExtracto      "El PLC activa la marca M100 cuando comienza la operación y la mantiene así hasta que finaliza la misma."@es .