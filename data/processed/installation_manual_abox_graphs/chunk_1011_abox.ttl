@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:G_KEY ex:textoExtracto "Para simular el teclado desde el PLC, escribir en la variable (V.)G.KEY el código de la tecla." ;
    a ex:Parametro ;
    ex:identificador "G.KEY" .

ex:PLC ex:textoExtracto "El PLC activa la marca M101 cuando comienza la operación y la mantiene así hasta que finaliza la misma." ;
    a ex:Sistema .

ex:M101 ex:textoExtracto "El PLC activa la marca M101 cuando comienza la operación y la mantiene así hasta que finaliza la misma." ;
    a ex:Parametro ;
    ex:identificador "M101" .

ex:R101 ex:textoExtracto "El comando CNCWR escribe en la variable el valor del registro registro R101." ;
    a ex:Parametro ;
    ex:identificador "R101" .

ex:CNCWR ex:textoExtracto "Para escribir la variable desde el PLC utilizar el comando CNCWR." ;
    a ex:AccionProhibida .

ex:ComandoSimulacionTeclado ex:textoExtracto "Para simular el teclado desde el PLC, escribir en la variable (V.)G.KEY el código de la tecla." ;
    a ex:TareaMantenimiento .

ex:RetardoSeguridad ex:textoExtracto "se recomienda utilizar un retardo de al menos 200 ms entre el envío de ambos códigos (por seguridad)" ;
    a ex:Frecuencia ;
    ex:valor "200 ms" .

ex:Tecla_SHIFT ex:textoExtracto "añadir el código correspondiente a la tecla [SHIFT]" ;
    a ex:ComponenteElectrico .

ex:ComandoCNCWR ex:textoExtracto "{ condición} = CNCWR(R101,G.KEY,M101)" ;
    a ex:AccionProhibida .