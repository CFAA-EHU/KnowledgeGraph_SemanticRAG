@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:B0KEYBD1 a ex:ComponenteElectrico ;
    ex:textoExtracto "La primera tecla de usuario (B0KEYBD1) envía el carácter \"a\". DFU B0KEYBD1 = CNCWR(R200,G.KEY,M200) = TG1 200 200" .

ex:B1KEYBD1 a ex:ComponenteElectrico ;
    ex:textoExtracto "La segunda tecla de usuario (B1KEYBD1) envía el carácter \"A\". DFU B1KEYBD1 = CNCWR(R202,G.KEY,M202) = CNCWR(R200,G.KEY,M203) = TG1 202 200" .

ex:PLC_SimulacionTeclado a ex:Sistema ;
    ex:textoExtracto "Simular el teclado desde el PLC." ;
    ex:compuestoPor ex:B0KEYBD1, ex:B1KEYBD1 ;
    ex:tieneComponente ex:B0KEYBD1, ex:B1KEYBD1 .