@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_8.4_SimulacionTecladoPLC
    a ex:Tabla ;
    rdfs:label "Tabla de simulación de teclado desde PLC"@es ;
    ex:textoExtracto """
| Inicializar los registros. () = MOV $1E R200 ; Pulsar la tecla [A]
() = MOV $9E R201 ; Soltar la tecla [A]
() = MOV $2A R202 ; Pulsar la tecla [SHIFT]
() = MOV $AA R203 ; Soltar la tecla [SHIFT] |
""" ;
    ex:documentadoEn ex:Pagina_545 .

ex:Sistema_SimulacionTecladoPLC
    a ex:Sistema ;
    rdfs:label "Sistema de simulación de teclado desde PLC"@es ;
    ex:textoExtracto """
La primera tecla de usuario (B0KEYBD1) envía el carácter \"a\".
La segunda tecla de usuario (B1KEYBD1) envía el carácter \"A\".
Combinación de teclas. Para simular desde el PLC una combinación de teclas (por ejemplo [CTRL]+[F1]).
""" ;
    ex:detalladoEnEsquema ex:Tabla_8.4_SimulacionTecladoPLC ;
    ex:tieneComponente ex:TeclaUsuario_B0KEYBD1 ;
    ex:tieneComponente ex:TeclaUsuario_B1KEYBD1 .

ex:TeclaUsuario_B0KEYBD1
    a ex:InterfazUsuario ;
    rdfs:label "Tecla de usuario B0KEYBD1 (envía 'a')"@es ;
    ex:identificador "B0KEYBD1" ;
    ex:textoExtracto "La primera tecla de usuario (B0KEYBD1) envía el carácter \"a\"."@es .

ex:TeclaUsuario_B1KEYBD1
    a ex:InterfazUsuario ;
    rdfs:label "Tecla de usuario B1KEYBD1 (envía 'A')"@es ;
    ex:identificador "B1KEYBD1" ;
    ex:textoExtracto "La segunda tecla de usuario (B1KEYBD1) envía el carácter \"A\"."@es .

ex:Parametro_RetardoSimulacion
    a ex:Parametro ;
    rdfs:label "Retardo entre envío de códigos de teclas"@es ;
    ex:valor "200" ;
    ex:textoExtracto "Se recomienda utilizar un retardo de al menos 200 ms entre el envío de dos códigos (por seguridad)."@es .