@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_75edd34dd6 a ns1:Componente ;
    rdfs:label "Almacén de herramientas" ;
    ns1:textoExtracto "Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal." .

ns1:Componente_9522bc956c a ns1:Componente ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "poner la herramienta del almacén en el cabezal" .

ns1:OperacionDeCambioDeHerramientaDeTierraAlAlmacen a ns1:TareaMantenimiento ;
    rdfs:label "Operación de cambio de herramienta de tierra al almacén" ;
    ns1:solucionaFallo ns1:FalloPresenciaHerramientaEnAlmacen ;
    ns1:textoExtracto "TMOPERATION = 9 Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal." .

ns1:OperacionDeCambioDeHerramientaDelAlmacenATierra a ns1:TareaMantenimiento ;
    rdfs:label "Operación de cambio de herramienta del almacén a tierra" ;
    ns1:solucionaFallo ns1:FalloPresenciaHerramientaEnTierra ;
    ns1:textoExtracto "TMOPERATION = 10 Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal." .

ns1:OperacionDeOrientacionDelAlmacen a ns1:TareaMantenimiento ;
    rdfs:label "Operación de orientación del almacén" ;
    ns1:solucionaFallo ns1:FalloOrientacionAlmacen ;
    ns1:textoExtracto "TMOPERATION = 11 Orientar el almacén. Esta operación es una optimización del cambio de herramienta que permite orientar el almacén durante el mecanizado." .

ns1:Parametro_7959033478 a ns1:Parametro ;
    rdfs:label "Marca para poner la herramienta de tierra en el cabezal" ;
    ns1:identificador "GRTOSPDL" ;
    ns1:textoExtracto "activar la marca GRTOSPDL" .

ns1:Parametro_876c0c3b98 a ns1:Parametro ;
    rdfs:label "Marca para dejar la herramienta del cabezal en el almacén" ;
    ns1:identificador "SPDLTOMZ" ;
    ns1:textoExtracto "activar la marca SPDLTOMZ" .

ns1:Parametro_94a80a9622 a ns1:Parametro ;
    rdfs:label "Marca para indicar finalización de orientación del almacén" ;
    ns1:identificador "MZROT" ;
    ns1:textoExtracto "Activar la marca MZROT para indicar que ha finalizado la operación, se haya orientado el almacén o no." .

ns1:Parametro_aed1a67bbe a ns1:Parametro ;
    rdfs:label "Marca para dejar la herramienta en tierra" ;
    ns1:identificador "SPDLTOGR" ;
    ns1:textoExtracto "activar la marca SPDLTOGR" .

ns1:Parametro_db77df6f5e a ns1:Parametro ;
    rdfs:label "Marca para poner la herramienta del almacén en el cabezal" ;
    ns1:identificador "MZTOSPDL" ;
    ns1:textoExtracto "activar la marca MZTOSPDL" .

