@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Tecla_CTRL a ex:ComponenteElectrico ;
    rdfs:label "tecla [CTRL]" ;
    ex:textoExtracto "tecla [CTRL]" .

ex:Tecla_F1 a ex:ComponenteElectrico ;
    rdfs:label "tecla [F1]" ;
    ex:textoExtracto "tecla [F1]" .

ex:Registro_R204 a ex:ComponenteElectrico ;
    rdfs:label "R204" ;
    ex:textoExtracto "MOV $1D R204 ; Pulsar la tecla [CTRL]" .

ex:Registro_R205 a ex:ComponenteElectrico ;
    rdfs:label "R205" ;
    ex:textoExtracto "MOV $9D R205 ; Soltar la tecla [CTRL]" .

ex:Registro_R206 a ex:ComponenteElectrico ;
    rdfs:label "R206" ;
    ex:textoExtracto "MOV $3B R206 ; Pulsar la tecla [F1]" .

ex:Registro_R207 a ex:ComponenteElectrico ;
    rdfs:label "R207" ;
    ex:textoExtracto "MOV $BB R207 ; Soltar la tecla [F1]" .

ex:B0KEYBD1 a ex:ComponenteElectrico ;
    rdfs:label "B0KEYBD1" ;
    ex:textoExtracto "La primera tecla de usuario (B0KEYBD1) envía la combinación [CTRL]+[F1]" .

ex:M204 a ex:ComponenteElectrico ;
    rdfs:label "M204" ;
    ex:textoExtracto "DFU B0KEYBD1 = CNCWR(R204,G.KEY,M204)" .

ex:M206 a ex:ComponenteElectrico ;
    rdfs:label "M206" ;
    ex:textoExtracto "DFU B0KEYBD1 = CNCWR(R206,G.KEY,M206)" .

ex:M207 a ex:ComponenteElectrico ;
    rdfs:label "M207" ;
    ex:textoExtracto "DFD M302 = CNCWR(R207,G.KEY,M207)" .

ex:M205 a ex:ComponenteElectrico ;
    rdfs:label "M205" ;
    ex:textoExtracto "DFD M302 = CNCWR(R205,G.KEY,M205)" .

ex:M302 a ex:ComponenteElectrico ;
    rdfs:label "M302" ;
    ex:textoExtracto "T202 = M302" .

ex:M303 a ex:ComponenteElectrico ;
    rdfs:label "M303" ;
    ex:textoExtracto "T203 =M303" .

ex:T202 a ex:ComponenteElectrico ;
    rdfs:label "T202" ;
    ex:textoExtracto "T202 = M302" .

ex:T203 a ex:ComponenteElectrico ;
    rdfs:label "T203" ;
    ex:textoExtracto "T203 =M303" .