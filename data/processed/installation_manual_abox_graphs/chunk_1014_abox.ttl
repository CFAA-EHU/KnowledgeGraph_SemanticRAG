@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioDeHerramientaOptimizado a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta optimizado" ;
    ns1:solucionaFallo ns1:DiagnosticoFalloCambioHerramientaNoOptimizado ;
    ns1:textoExtracto "Es una operación optimizada, válida sólo cuando el almacén es random y la herramienta es especial." .

ns1:DejarLaHerramientaDelCabezalEnElAlmacenYCogerUnaHerramientaDelMismoAlmacen_555c71033f a ns1:Parametro ;
    rdfs:label "Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén" ;
    ns1:identificador "TMOPERATION=12" ;
    ns1:textoExtracto "TMOPERATION = 12 Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén (como TMOPERATION=5)." .

ns1:OrientarDosAlmacenes_80aafb2a11 a ns1:Parametro ;
    rdfs:label "Orientar dos almacenes" ;
    ns1:identificador "TMOPERATION=13" ;
    ns1:textoExtracto "TMOPERATION = 13 Orientar dos almacenes." .

ns1:Parametro_94a80a9622 a ns1:Parametro ;
    rdfs:label "Marca para indicar finalización de operación" ;
    ns1:identificador "MZROT" ;
    ns1:textoExtracto "Activar la marca MZROT para indicar que ha finalizado la operación, se haya orientado el almacén o no." .

ns1:PosicionDelAlmacenParaCogerLaHerramienta a ns1:Parametro ;
    rdfs:label "Posición del almacén para coger la herramienta" ;
    ns1:identificador "TAKEPOS=#" ;
    ns1:textoExtracto "TAKEPOS=# Posición del almacén para coger la herramienta." .

ns1:PosicionDelAlmacenParaDejarLaHerramienta a ns1:Parametro ;
    rdfs:label "Posición del almacén para dejar la herramienta" ;
    ns1:identificador "LEAVEPOS=#" ;
    ns1:textoExtracto "LEAVEPOS=# Posición del almacén para dejar la herramienta." .

