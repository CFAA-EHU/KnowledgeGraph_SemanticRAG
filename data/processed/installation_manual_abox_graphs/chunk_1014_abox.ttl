@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TeclaBloquearMayusculas a ex:ComponenteElectrico ;
    ex:identificador "$3A" ;
    ex:textoExtracto "Bloquear mayúsculas. | $3A | $BA" .

ex:TeclaMayusculas a ex:ComponenteElectrico ;
    ex:identificador "$2A / $36" ;
    ex:textoExtracto "Mayúsculas (SHIFT). | $2A/ $36 | $AA / $B6" .

ex:TeclaControl a ex:ComponenteElectrico ;
    ex:identificador "$1D" ;
    ex:textoExtracto "Control (CTRL). | $1D | $9D" .

ex:TeclaAlternativo a ex:ComponenteElectrico ;
    ex:identificador "$38" ;
    ex:textoExtracto "Alternativo (ALT). | $38 | $B8" .

ex:TeclaAlternativoGrafico a ex:ComponenteElectrico ;
    ex:identificador "$E0$38" ;
    ex:textoExtracto "Alternativo gráfico (ALT GR). | $E0$38 | $E0$B8" .

ex:TeclaBarraEspaciadora a ex:ComponenteElectrico ;
    ex:identificador "$39" ;
    ex:textoExtracto "Barra espaciadora. | $39 | $B9" .

ex:TeclaRetroceso a ex:ComponenteElectrico ;
    ex:identificador "$0E" ;
    ex:textoExtracto "Retroceso (backspace). | $0E | $8E" .

ex:TeclaImprimirPantalla a ex:ComponenteElectrico ;
    ex:identificador "$E0$37" ;
    ex:textoExtracto "Imprimir pantalla. | $E0$37 | $E0$B7" .

ex:TeclaAvanzarPagina a ex:ComponenteElectrico ;
    ex:identificador "$E0$51" ;
    ex:textoExtracto "Avanzar página. | $E0$51 | $E0$D1" .

ex:TeclaRetrocederPagina a ex:ComponenteElectrico ;
    ex:identificador "$E0$49" ;
    ex:textoExtracto "Retroceder página. | $E0$49 | $E0$C9" .

ex:TeclaInicio a ex:ComponenteElectrico ;
    ex:identificador "$E0$47" ;
    ex:textoExtracto "Inicio. | $E0$47 | $E0$C7" .

ex:TeclaFin a ex:ComponenteElectrico ;
    ex:identificador "$E0$4F" ;
    ex:textoExtracto "Fin. | $E0$4F | $E0$CF" .

ex:TeclaFlechaArriba a ex:ComponenteElectrico ;
    ex:identificador "$E0$48" ;
    ex:textoExtracto "Flecha arriba. | $E0$48 | $E0$C8" .

ex:TeclaFlechaAbajo a ex:ComponenteElectrico ;
    ex:identificador "$E0$50" ;
    ex:textoExtracto "Flecha abajo. | $E0$50 | $E0$D0" .

ex:TeclaFlechaDerecha a ex:ComponenteElectrico ;
    ex:identificador "$E0$4D" ;
    ex:textoExtracto "Flecha derecha. | $E0$4D | $E0$CD" .

ex:TeclaFlechaIzquierda a ex:ComponenteElectrico ;
    ex:identificador "$E0$4B" ;
    ex:textoExtracto "Flecha izquierda. | $E0$4B | $E0$CB" .