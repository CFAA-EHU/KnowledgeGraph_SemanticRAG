@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_CodigosTecla_Espanol a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de códigos de tecla para distribución 'Español (España)'"@es ;
    ex:textoExtracto "En las teclas con varios caracteres, para enviar el primer carácter (minúscula), utilizar los códigos indicados; para el segundo carácter (mayúsculas), añadir el código correspondiente a la tecla [SHIFT], de la siguiente manera; para el tercer carácter, utilizar el código correspondiente a la tecla [ALT GR]."@es ;
    ex:identificador "8.5.1 Scan codes. Distribución de teclado 'Español (España)'" .

ex:Tecla_BloquearMayusculas
    a ex:Componente ;
    rdfs:label "Tecla Bloquear Mayúsculas"@es ;
    ex:textoExtracto "Bloquear mayúsculas."@es ;
    ex:identificador "$3A (pulsar) / $BA (soltar)" ;
    ex:documentadoEn ex:Tabla_CodigosTecla_Espanol .

ex:Tecla_Shift
    a ex:Componente ;
    rdfs:label "Tecla Mayúsculas (SHIFT)"@es ;
    ex:textoExtracto "Mayúsculas (SHIFT)."@es ;
    ex:identificador "$2A / $36 (pulsar) / $AA / $B6 (soltar)" ;
    ex:documentadoEn ex:Tabla_CodigosTecla_Espanol .

