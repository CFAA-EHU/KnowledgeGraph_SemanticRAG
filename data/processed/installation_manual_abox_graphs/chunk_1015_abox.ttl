@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarMarcaMZROT a ns1:AccionProhibida ;
    rdfs:label "Activar marca MZROT" ;
    ns1:textoExtracto "Activar la marca MZROT en ambos almacenes para indicar que ha finalizado la operación, se hayan orientado los almacenes o no." .

ns1:ActivarMarcaMZTOSPDL a ns1:AccionProhibida ;
    rdfs:label "Activar marca MZTOSPDL" ;
    ns1:textoExtracto "2 Poner la herramienta del almacén en el cabezal y activar la marca MZTOSPDL." .

ns1:ActivarMarcaSPDLTOMZ a ns1:AccionProhibida ;
    rdfs:label "Activar marca SPDLTOMZ" ;
    ns1:textoExtracto "1 Dejar la herramienta del cabezal en el almacén y activar la marca SPDLTOMZ." .

ns1:CambioDeHerramienta_0cf48555b6 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta" ;
    ns1:textoExtracto "Esta operación es una optimización del cambio de herramienta que permite orientar dos almacenes durante el mecanizado." .

ns1:DejarLaHerramientaDelCabezalEnElAlmacenYCogerUnaHerramientaDeOtroAlmacen_84005c662b a ns1:AccionProhibida ;
    rdfs:label "Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén" ;
    ns1:textoExtracto "TMOPERATION = 14 Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén." .

ns1:IdentificadorDeAlmacen a ns1:Parametro ;
    rdfs:label "Identificador de almacén" ;
    ns1:textoExtracto "MZID En la parte baja de este registro se indica el almacén en el que hay que dejar la herramienta y en la parte alta el almacén del que hay que coger la herramienta." .

ns1:OrientarDosAlmacenes_f35e036c0b a ns1:AccionProhibida ;
    rdfs:label "Orientar dos almacenes" ;
    ns1:textoExtracto "TMOPERATION = 13 Orientar dos almacenes. Esta operación es una optimización del cambio de herramienta que permite orientar dos almacenes durante el mecanizado." .

ns1:PosicionParaCogerLaHerramienta a ns1:Parametro ;
    rdfs:label "Posición para coger la herramienta" ;
    ns1:textoExtracto "TAKEPOS=# Posición del almacén para coger la herramienta." .

ns1:PosicionParaDejarLaHerramienta a ns1:Parametro ;
    rdfs:label "Posición para dejar la herramienta" ;
    ns1:textoExtracto "LEAVEPOS=# Posición del almacén para dejar la herramienta." .

ns1:SistemaAlmacenamientoHerramientas a ns1:Sistema ;
    rdfs:label "Sistema de almacenamiento de herramientas" ;
    ns1:textoExtracto "para coger la herramienta. LEAVEPOS=# Posición del almacén para dejar la herramienta." .

