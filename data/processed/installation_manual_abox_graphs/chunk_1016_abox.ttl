@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:B0KEYBD1 a ex:ComponenteElectrico ;
    rdfs:label "B0KEYBD1" ;
    ex:textoExtracto "La primera tecla de usuario (B0KEYBD1) realiza las siguientes operaciones." ;
    ex:compuestoPor ex:ModoManual, ex:ModoMDI, ex:BusquedaReferenciaEjeX, ex:SalidaModoMDI ;
    ex:tieneFrecuencia ex:Retardo200ms .

ex:ModoManual a ex:ModoOperacion ;
    ex:textoExtracto "El CNC accede al modo manual." .

ex:ModoMDI a ex:ModoOperacion ;
    ex:textoExtracto "El CNC accede al modo MDI." .

ex:BusquedaReferenciaEjeX a ex:TareaMantenimiento ;
    ex:textoExtracto "El CNC realiza una búsqueda de referencia máquina del eje X." .

ex:SalidaModoMDI a ex:ModoOperacion ;
    ex:textoExtracto "Tras finalizar la búsqueda de referencia máquina, el CNC sale del modo MDI." .

ex:Retardo200ms a ex:Frecuencia ;
    ex:valor "200ms" ;
    ex:textoExtracto "En el ejemplo se utiliza un retardo de 200ms entre el envío de ambos códigos (por seguridad)." .