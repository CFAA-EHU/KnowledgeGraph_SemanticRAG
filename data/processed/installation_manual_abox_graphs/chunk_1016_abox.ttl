@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TeclaUsuario_B0KEYBD1
    a ex:InterfazUsuario ;
    rdfs:label "Tecla de usuario B0KEYBD1" ;
    ex:textoExtracto "La primera tecla de usuario (B0KEYBD1) realiza las siguientes operaciones..." ;
    ex:identificador "B0KEYBD1" ;
    ex:controla ex:ModoManual_CNC, ex:ModoMDI_CNC, ex:BusquedaReferencia_EjeX .

ex:ModoManual_CNC
    a ex:ModoOperacion ;
    rdfs:label "Modo manual (CNC)" ;
    ex:textoExtracto "El CNC accede al modo manual." .

ex:ModoMDI_CNC
    a ex:ModoOperacion ;
    rdfs:label "Modo MDI (CNC)" ;
    ex:textoExtracto "El CNC accede al modo MDI." .

ex:BusquedaReferencia_EjeX
    a ex:TareaMantenimiento ;
    rdfs:label "Búsqueda de referencia máquina del eje X" ;
    ex:textoExtracto "El CNC realiza una búsqueda de referencia máquina del eje X." .

ex:RetardoSeguridad_200ms
    a ex:Parametro ;
    rdfs:label "Retardo de seguridad (200 ms)" ;
    ex:valor "200" ;
    ex:textoExtracto "En el ejemplo se utiliza un retardo de 200ms entre el envío de ambos códigos (por seguridad)." .