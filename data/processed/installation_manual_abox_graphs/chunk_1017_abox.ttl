@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SistemaSimulacionTecladoPLC
    a ex:Sistema ;
    rdfs:label "Sistema de simulación del teclado desde PLC"@es ;
    ex:textoExtracto """
; Inicializar los registros. START OR DFU M313 = CYSTART
()
; El CNC accede al modo manual. [CTRL]+[F7]
; El CNC accede al modo MDI. [CTRL]+[F8]
; Búsqueda de referencia máquina."""@es ;
    ex:tieneComponente ex:RegistroR200, ex:RegistroR201, ex:RegistroR202, ex:RegistroR203,
                      ex:RegistroR204, ex:RegistroR205, ex:RegistroR206, ex:RegistroR207,
                      ex:RegistroR208, ex:RegistroR209, ex:RegistroR210, ex:RegistroR211,
                      ex:RegistroR212, ex:RegistroR213, ex:RegistroR214, ex:RegistroR215,
                      ex:RegistroR216, ex:RegistroR217 ;
    ex:controla ex:ModoManualCNC, ex:ModoMDICNC .

ex:RegistroR200 a ex:Componente ; rdfs:label "Registro R200"@es ; ex:textoExtracto "MOV $1D R200"@es ; ex:valor "$1D" .
ex:RegistroR201 a ex:Componente ; rdfs:label "Registro R201"@es ; ex:textoExtracto "MOV $9D R201"@es ; ex:valor "$9D" .
ex:RegistroR202 a ex:Componente ; rdfs:label "Registro R202"@es ; ex:textoExtracto "MOV $41 R202"@es ; ex:valor "$41" .
ex:RegistroR203 a ex:Componente ; rdfs:label "Registro R203"@es ; ex:textoExtracto "MOV $C1 R203"@es ; ex:valor "$C1" .
ex:RegistroR204 a ex:Componente ; rdfs:label "Registro R204"@es ; ex:textoExtracto "MOV $42 R204"@es ; ex:valor "$42" .
ex:RegistroR205 a ex:Componente ; rdfs:label "Registro R205"@es ; ex:textoExtracto "MOV $C2 R205"@es ; ex:valor "$C2" .
ex:RegistroR206 a ex:Componente ; rdfs:label "Registro R206"@es ; ex:textoExtracto "MOV $22 R206"@es ; ex:valor "$22" .
ex:RegistroR207 a ex:Componente ; rdfs:label "Registro R207"@es ; ex:textoExtracto "MOV $A2 R207"@es ; ex:valor "$A2" .
ex:RegistroR208 a ex:Componente ; rdfs:label "Registro R208"@es ; ex:textoExtracto "MOV $08 R208"@es ; ex:valor "$08" .
ex:RegistroR209 a ex:Componente ; rdfs:label "Registro R209"@es ; ex:textoExtracto "MOV $88 R209"@es ; ex:valor "$88" .
ex:RegistroR210 a ex:Componente ; rdfs:label "Registro R210"@es ; ex:textoExtracto "MOV $05 R210"@es ; ex:valor "$05" .
ex:RegistroR211 a ex:Componente ; rdfs:label "Registro R211"@es ; ex:textoExtracto "MOV $85 R211"@es ; ex:valor "$85" .
ex:RegistroR212 a ex:Componente ; rdfs:label "Registro R212"@es ; ex:textoExtracto "MOV $2D R212"@es ; ex:valor "$2D" .
ex:RegistroR213 a ex:Componente ; rdfs:label "Registro R213"@es ; ex:textoExtracto "MOV $AD R213"@es ; ex:valor "$AD" .
ex:RegistroR214 a ex:Componente ; rdfs:label "Registro R214"@es ; ex:textoExtracto "MOV $02 R214"@es ; ex:valor "$02" .
ex:RegistroR215 a ex:Componente ; rdfs:label "Registro R215"@es ; ex:textoExtracto "MOV $82 R215"@es ; ex:valor "$82" .
ex:RegistroR216 a ex:Componente ; rdfs:label "Registro R216"@es ; ex:textoExtracto "MOV $01 R216"@es ; ex:valor "$01" .
ex:RegistroR217 a ex:Componente ; rdfs:label "Registro R217"@es ; ex:textoExtracto "MOV $81 R217"@es ; ex:valor "$81" .

ex:ModoManualCNC
    a ex:ModoOperacion ;
    rdfs:label "Modo Manual CNC"@es ;
    ex:textoExtracto "; El CNC accede al modo manual. [CTRL]+[F7]"@es .

ex:ModoMDICNC
    a ex:ModoOperacion ;
    rdfs:label "Modo MDI CNC"@es ;
    ex:textoExtracto "; El CNC accede al modo MDI. [CTRL]+[F8]"@es .