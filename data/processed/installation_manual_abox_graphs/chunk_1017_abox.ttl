    ex:textoExtracto "MOV $02 R214 = MOV $82 R215 ; [1]" .

ex:ComponenteElectrico1017_10 a ex:ComponenteElectrico ;
    ex:textoExtracto "MOV $01 R216 = MOV $81 R217 ; [ESC]" .

ex:InterfazUsuario1017_1 a ex:InterfazUsuario ;
    ex:textoExtracto "[ CTRL]+[F7]" .

ex:InterfazUsuario1017_2 a ex:InterfazUsuario ;
    ex:textoExtracto "[ CTRL]+[F8]" .

ex:Sistema1017 a ex:Sistema ;
    ex:textoExtracto "El CNC accede al modo manual. [ CTRL]+[F7]" ;
    ex:compuestoPor ex:InterfazUsuario1017_1 .

ex:Sistema1017 ex:compuestoPor ex:ComponenteElectrico1017_2 .

