ex:ParametroR220
    a ex:Parametro ;
    rdfs:label "Parámetro R220 (Estado CNC - READY=1)" ;
    ex:textoExtracto "CPS R220 EQ 1) = CNCWR(R216,G.KEY,M216) ; Estado del CNC (\"1\"=READY)" ;
    ex:identificador "R220" ;
    ex:valor "1" .