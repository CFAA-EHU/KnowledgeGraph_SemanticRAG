ex:ComponenteM313
    a ex:ComponenteElectrico ;
    rdfs:label "Componente M313 (START - CYSTART=1)" ;
    ex:textoExtracto "DFD M313 = SET M500 ; [START] (CYSTART=1)" ;
    ex:identificador "M313" .

ex:ComponenteM314
    a ex:ComponenteElectrico ;
    rdfs:label "Componente M314 (T214 - Reset)" ;
    ex:textoExtracto "DFD M314 = CNCWR(R217,G.KEY,M217)= RES M500=RES M501" ;
    ex:identificador "M314" ;
    ex:monitoreaParametro ex:ParametroR217 .

