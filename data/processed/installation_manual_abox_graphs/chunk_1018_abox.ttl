@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_4e38dbf794 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "$IF [V.S.EXECUTION == 1] ; CNC en ejecución" .

ns1:CambioDeHerramienta_ad185fecc3 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta" ;
    ns1:textoExtracto "M6 ; Orden al gestor para comenzar el cambio de herramienta." .

ns1:EstadoAutomaticoDelCNC a ns1:Parametro ;
    rdfs:label "Estado automático del CNC" ;
    ns1:identificador "V.G.CNCAUTSTATUS" ;
    ns1:textoExtracto "$IF [[V.G.CNCAUTSTATUS & 4096] | [V.G.CNCAUTSTATUS & 8192]]" .

ns1:EstadoCompletoDelSistema a ns1:Parametro ;
    rdfs:label "Estado completo del sistema" ;
    ns1:identificador "V.G.FULLSTATUS" ;
    ns1:textoExtracto "$IF [[[V.G.FULLSTATUS & 255]<9] | [[V.G.FULLSTATUS & 255]>13]]" .

ns1:EstadoDeEjecucion a ns1:Parametro ;
    rdfs:label "Estado de ejecución" ;
    ns1:identificador "V.S.EXECUTION" ;
    ns1:textoExtracto "$SWITCH V.S.EXECUTION; Analiza el tipo de operación." .

