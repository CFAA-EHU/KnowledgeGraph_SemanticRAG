@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SistemaSimulacionTecladoPLC
    a ex:Sistema ;
    rdfs:label "Sistema de simulación del teclado desde PLC" ;
    ex:textoExtracto "Ejemplo. Simular el teclado desde el PLC." ;
    ex:identificador "G74" ;
    ex:compuestoPor ex:ComponenteM303, ex:ComponenteM304, ex:ComponenteM305, ex:ComponenteM306, ex:ComponenteM307, ex:ComponenteM308, ex:ComponenteM309, ex:ComponenteM310, ex:ComponenteM311, ex:ComponenteM312, ex:ComponenteM313, ex:ComponenteM314 ;
    ex:controla ex:InterfazTecladoCNC .

ex:InterfazTecladoCNC
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de teclado CNC (G.KEY)" ;
    ex:textoExtracto "CNCWR(R206,G.KEY,M206), CNCWR(R207,G.KEY,M207), ..." .

ex:ComponenteM303
    a ex:ComponenteElectrico ;
    rdfs:label "Componente M303 (T204)" ;
    ex:textoExtracto "DFD M303 = CNCWR(R206,G.KEY,M206) = TG1 204 200" ;
    ex:identificador "M303" ;
    ex:monitoreaParametro ex:ParametroR206 .

ex:ComponenteM304
    a ex:ComponenteElectrico ;
    rdfs:label "Componente M304 (T205)" ;
    ex:textoExtracto "DFD M304 = CNCWR(R207,G.KEY,M207) = TG1 205 200" ;
    ex:identificador "M304" ;
    ex:monitoreaParametro ex:ParametroR207 .

