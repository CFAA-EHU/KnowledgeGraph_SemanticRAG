@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:man_8070_var_pdf a ex:Manual ;
    rdfs:label "man_8070_var.pdf" ;
    ex:identificador "man_8070_var.pdf" ;
    ex:textoExtracto "Toda la información sobre las variables del CNC está en el manual \"Variables del CNC\", disponible en el sitio web corporativo de Fagor Automation. El nombre del documento electrónico es man_8070_var.pdf." ;
    ex:documentadoEn ex:Manual_Variables_CNC .

ex:Manual_Variables_CNC a ex:Manual ;
    rdfs:label "Variables del CNC" ;
    ex:textoExtracto "Toda la información sobre las variables del CNC está en el manual \"Variables del CNC\", disponible en el sitio web corporativo de Fagor Automation." .