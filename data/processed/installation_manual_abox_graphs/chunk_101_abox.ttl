@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ROPARMIN a ex:Parametro ;
    rdfs:label "ROPARMIN" ;
    ex:identificador "(V.)MPG.ROPARMIN" ;
    ex:textoExtracto "Valores posibles: De 100 a 9999. Valor por defecto: 0. Variable asociada: (V.)MPG.ROPARMIN Los parámetros ROPARMAX y ROPARMIN permiten proteger frente a escritura un grupo de parámetros aritméticos globales. Si ambos parámetros se definen con valor 0, no hay parámetros protegidos." ;
    ex:valor "0" .

ex:ROPARMAX a ex:Parametro ;
    rdfs:label "ROPARMAX" ;
    ex:identificador "(V.)MPG.ROPARMAX" ;
    ex:textoExtracto "Valores posibles: De 100 a 9999. Valor por defecto: 0. Variable asociada: (V.)MPG.ROPARMIN Los parámetros ROPARMAX y ROPARMIN permiten proteger frente a escritura un grupo de parámetros aritméticos globales. Si ambos parámetros se definen con valor 0, no hay parámetros protegidos." ;
    ex:valor "0" .

ex:MAXCOMP a ex:Parametro ;
    rdfs:label "MAXCOMP" ;
    ex:identificador "(V.)MPG.MAXCOMP" ;
    ex:textoExtracto "MAXCOMP Parámetro aritmético común entre canales máximo. Valores posibles: De 10000 a 19999. Valor por defecto: 10025. Variable asociada: (V.)MPG.MAXCOMP Consultar el parámetro máquina general MINCOMP." ;
    ex:valor "10025" .

ex:MINCOMP a ex:Parametro ;
    rdfs:label "MINCOMP" ;
    ex:textoExtracto "MINCOMP Parámetro" ;
    ex:valor "" .