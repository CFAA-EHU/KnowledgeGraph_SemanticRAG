@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PeriodicidadDelModuloPRGDelPLC_6b2161111a a ns1:Parametro ;
    rdfs:label "Periodicidad del módulo PRG del PLC" ;
    ns1:identificador "PRGFREQ" ;
    ns1:textoExtracto "PRGFREQ Periodicidad del módulo PRG del PLC. Valores posibles: De 1 a 100 ciclos. Valor por defecto: 2 ciclos." .

ns1:VariableAsociadaAlParametroPRGFREQ a ns1:Parametro ;
    rdfs:label "Variable asociada al parámetro PRGFREQ" ;
    ns1:identificador "MPG.PRGFREQ" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.PRGFREQ Este parámetro indica con qué frecuencia (cada cuántos ciclos de CNC) se ejecuta un ciclo completo del programa de PLC." .

