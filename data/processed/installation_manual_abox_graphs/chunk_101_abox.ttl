@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_ROPARMIN
    a ex:Parametro ;
    rdfs:label "ROPARMIN" ;
    ex:textoExtracto "Los parámetros ROPARMAX y ROPARMIN permiten proteger frente a escritura un grupo de parámetros aritméticos globales. Si ambos parámetros se definen con valor 0, no hay parámetros protegidos. Valor por defecto: 0." ;
    ex:valor "0" ;
    ex:identificador "V.MPG.ROPARMIN" .

ex:Parametro_ROPARMAX
    a ex:Parametro ;
    rdfs:label "ROPARMAX" ;
    ex:textoExtracto "Los parámetros ROPARMAX y ROPARMIN permiten proteger frente a escritura un grupo de parámetros aritméticos globales." ;
    ex:valor "0" ;
    ex:identificador "V.MPG.ROPARMAX" .

ex:Parametro_MAXCOMP
    a ex:Parametro ;
    rdfs:label "MAXCOMP" ;
    ex:textoExtracto "Parámetro aritmético común entre canales máximo. Valores posibles: De 10000 a 19999. Valor por defecto: 10025." ;
    ex:valor "10025" ;
    ex:identificador "V.MPG.MAXCOMP" .

ex:Parametro_MINCOMP
    a ex:Parametro ;
    rdfs:label "MINCOMP" ;
    ex:textoExtracto "Consultar el parámetro máquina general MINCOMP." .