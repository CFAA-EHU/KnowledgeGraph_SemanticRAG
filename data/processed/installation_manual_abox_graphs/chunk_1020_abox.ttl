@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalHerramienta a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de herramienta" ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio manual." .

ns1:CambioDeHerramientaAutomatico_2bddb72182 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta automático" ;
    ns1:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático." .

ns1:CambioDeHerramientaManual_05b3760b6b a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta manual" ;
    ns1:textoExtracto "LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual." .

ns1:Componente_217e1470a1 a ns1:Componente ;
    rdfs:label "Almacén de herramientas" ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en tierra, y coger otra del almacén." .

ns1:Herramienta_414d337620 a ns1:Herramienta ;
    rdfs:label "Herramienta de tierra" ;
    ns1:textoExtracto "Colocar la herramienta de tierra en el cabezal." .

ns1:PuntoCambioManual a ns1:ElementoSeguridad ;
    rdfs:label "Punto de cambio manual" ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio manual." .

