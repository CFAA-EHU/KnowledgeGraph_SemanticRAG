ex:EjeRotativoA rdfs:label "Eje rotativo A" ;
    a ex:ComponenteMecanico ;
    ex:textoExtracto "Nombre. | Tipo de eje según la norma DIN 66217. | | An Bn Cn | Ejes rotativos, sobre los ejes X-Y-Z respectivamente."@es .

