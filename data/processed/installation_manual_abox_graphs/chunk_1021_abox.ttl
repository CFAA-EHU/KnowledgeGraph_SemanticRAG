@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalHerramienta a ns1:Componente ;
    rdfs:label "Cabezal de herramienta" ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio manual. Quitar la herramienta del cabezal. Colocar la herramienta de tierra en el cabezal." .

ns1:CambioDeHerramientaAutomatico_f30cbfea56 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta automático" ;
    ns1:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático. LL SUB_SPD_TO_MZ ; Dejar la herramienta del cabezal en el almacén." .

ns1:CambioDeHerramientaManual_556e5682a2 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta manual" ;
    ns1:textoExtracto "LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual. LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal. LL SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal." .

ns1:Componente_11d9cb1ab7 a ns1:Componente ;
    rdfs:label "Almacén de herramientas" ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en el almacén." .

ns1:PuntoDeCambioManual a ns1:Componente ;
    rdfs:label "Punto de cambio manual" ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio manual." .

