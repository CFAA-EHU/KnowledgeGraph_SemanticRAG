@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_NAXIS
    a ex:Parametro ;
    rdfs:label "NAXIS" ;
    ex:textoExtracto "Número de ejes del sistema." ;
    ex:identificador "NAXIS" .

ex:Parametro_AXISNAME
    a ex:Parametro ;
    rdfs:label "AXISNAME" ;
    ex:textoExtracto "Lista de ejes del sistema. El orden en el que se definen los ejes en AXISNAME determina su número lógico." ;
    ex:identificador "AXISNAME" .

ex:Parametro_NSPDL
    a ex:Parametro ;
    rdfs:label "NSPDL" ;
    ex:textoExtracto "Número de cabezales del sistema." ;
    ex:identificador "NSPDL" .

ex:Parametro_SPDLNAME
    a ex:Parametro ;
    rdfs:label "SPDLNAME" ;
    ex:textoExtracto "Lista de cabezales del sistema. El orden en el que se definen los cabezales en SPDLNAME determina su número lógico." ;
    ex:identificador "SPDLNAME" .

ex:Tabla_ParametrosEjesCabezales a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de ejes y cabezales" ;
    ex:textoExtracto "Parámetro | Significado | NAXIS | Número de ejes del sistema | AXISNAME | Lista de ejes del sistema | NSPDL | Número de cabezales del sistema | SPDLNAME | Lista de cabezales del sistema" ;
    ex:documentadoEn ex:Pagina_556 .

ex:Tabla_OrdenLogicoEjesCabezales a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de orden lógico de ejes y cabezales" ;
    ex:textoExtracto "AXISNAME | SPDLNAME | Orden lógico | AXISNAME 1 |  | Número lógico ꞏ1ꞏ | AXISNAME 2 |  | Número lógico ꞏ2ꞏ | AXISNAME 3 |  | Número lógico ꞏ3ꞏ |  | SPDLNAME 1 | Número lógico ꞏ4ꞏ |  | SPDLNAME 2 | Número lógico ꞏ5ꞏ" ;
    ex:documentadoEn ex:Pagina_556 ;
    ex:ilustradoEn ex:Pagina_556 .

ex:Pagina_556
    a ex:Pagina ;
    rdfs:label "Página 556 - Configuración de ejes y cabezales" ;
    ex:identificador "556" ;
    ex:textoExtracto "La configuración de ejes y cabezales del sistema se define mediante los parámetros máquina NAXIS, AXISNAME, NSPDL y SPDLNAME." .