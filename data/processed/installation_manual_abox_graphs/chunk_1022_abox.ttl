@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_NAXIS a ex:Parametro ;
    rdfs:label "NAXIS" ;
    ex:identificador "NAXIS" ;
    ex:textoExtracto "Número de ejes del sistema."@es .

ex:Parametro_AXISNAME a ex:Parametro ;
    rdfs:label "AXISNAME" ;
    ex:identificador "AXISNAME" ;
    ex:textoExtracto "Lista de ejes del sistema."@es .

ex:Parametro_NSPDL a ex:Parametro ;
    rdfs:label "NSPDL" ;
    ex:identificador "NSPDL" ;
    ex:textoExtracto "Número de cabezales del sistema."@es .

ex:Parametro_SPDLNAME a ex:Parametro ;
    rdfs:label "SPDLNAME" ;
    ex:identificador "SPDLNAME" ;
    ex:textoExtracto "Lista de cabezales del sistema."@es .

ex:Tabla_ConfiguracionEjesCabezales a ex:Tabla ;
    ex:textoExtracto "Parámetro. | Significado. | NAXIS | Número de ejes del sistema. | AXISNAME | Lista de ejes del sistema. | NSPDL | Número de cabezales del sistema. | SPDLNAME | Lista de cabezales del sistema."@es .

ex:Parametro_AXISNAME_1 a ex:Parametro ;
    rdfs:label "AXISNAME 1" ;
    ex:identificador "AXISNAME 1" ;
    ex:textoExtracto "AXISNAME 1"@es .

ex:Parametro_AXISNAME_2 a ex:Parametro ;
    rdfs:label "AXISNAME 2" ;
    ex:identificador "AXISNAME 2" ;
    ex:textoExtracto "AXISNAME 2"@es .

ex:Parametro_AXISNAME_3 a ex:Parametro ;
    rdfs:label "AXISNAME 3" ;
    ex:identificador "AXISNAME 3" ;
    ex:textoExtracto "AXISNAME 3"@es .

ex:Parametro_SPDLNAME_1 a ex:Parametro ;
    rdfs:label "SPDLNAME 1" ;
    ex:identificador "SPDLNAME 1" ;
    ex:textoExtracto "SPDLNAME 1"@es .

ex:Parametro_SPDLNAME_2 a ex:Parametro ;
    rdfs:label "SPDLNAME 2" ;
    ex:identificador "SPDLNAME 2" ;
    ex:textoExtracto "SPDLNAME 2"@es .

ex:Sistema_ConfiguracionEjesCabezales a ex:Sistema ;
    ex:textoExtracto "La configuración de ejes y cabezales del sistema se define mediante los parámetros máquina NAXIS, AXISNAME, NSPDL y SPDLNAME."@es ;
    ex:compuestoPor ex:Parametro_NAXIS, ex:Parametro_AXISNAME, ex:Parametro_NSPDL, ex:Parametro_SPDLNAME, ex:Parametro_AXISNAME_1, ex:Parametro_AXISNAME_2, ex:Parametro_AXISNAME_3, ex:Parametro_SPDLNAME_1, ex:Parametro_SPDLNAME_2 ;
    ex:detalladoEnEsquema ex:Tabla_ConfiguracionEjesCabezales .