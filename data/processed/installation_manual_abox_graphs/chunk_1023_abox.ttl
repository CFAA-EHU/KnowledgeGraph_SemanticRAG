@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CodigoDeOperacionDelPLC a ns1:Parametro ;
    rdfs:label "Código de operación del PLC" ;
    ns1:identificador "TMOPERATION" ;
    ns1:textoExtracto "el gestor envía al PLC el código TMOPERATION=11." .

ns1:FuncionM06 a ns1:Sistema ;
    rdfs:label "Función M06" ;
    ns1:textoExtracto "Cada vez que la rutina M06 finaliza una acción se lo indica al PLC para que active la marca correspondiente del gestor." .

ns1:FuncionT a ns1:Sistema ;
    rdfs:label "Función T" ;
    ns1:textoExtracto "Cuando se ejecuta la función –T– Cuando se ejecuta la función T el gestor envía al PLC el código TMOPERATION=11." .

ns1:Parametro_7959033478 a ns1:Parametro ;
    rdfs:label "Marca para indicar herramienta en cabezal" ;
    ns1:identificador "GRTOSPDL" ;
    ns1:textoExtracto "DFU M1108 = SET GRTOSPDL DFD GRTOSPDL = RES M1108 La herramienta se ha llevado de tierra al cabezal." .

ns1:Parametro_94a80a9622 a ns1:Parametro ;
    rdfs:label "Marca para indicar finalización de operación" ;
    ns1:identificador "MZROT" ;
    ns1:textoExtracto "activa la marca MZROT para indicar que ha finalizado la operación." .

ns1:Parametro_aed1a67bbe a ns1:Parametro ;
    rdfs:label "Marca para indicar herramienta en tierra" ;
    ns1:identificador "SPDLTOGR" ;
    ns1:textoExtracto "DFU M1107 = SET SPDLTOGR DFD SPDLTOGR = RES M1107 La herramienta se ha llevado del cabezal a tierra." .

