@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ParametroSPDLNAME a ex:Parametro ;
    ex:textoExtracto "Al igual que el nombre, el índice permite identificar el cabezal en las variables. El índice de un cabezal en el sistema viene establecido por el orden en el que está definido en el parámetro máquina SPDLNAME. El primer cabezal de la tabla SPDLNAME tendrá índice ꞏ1ꞏ y así sucesivamente." ;
    ex:valor "SPDLNAME" .

ex:ParametroAXISNAME a ex:Parametro ;
    ex:textoExtracto "AXISNAME" ;
    ex:valor "AXISNAME" .

ex:TablaConfiguracionEjesCabezales a ex:Tabla ;
    ex:textoExtracto "| AXISNAME | Orden lógico. | Índice en el sistema. |\n| --- | --- | --- |\n| AXISNAME 1 | Número lógico ꞏ1ꞏ. |  |\n| AXISNAME 2 | Número lógico ꞏ2ꞏ. |  |\n| AXISNAME 3 | Número lógico ꞏ3ꞏ. |  |\n| SPDLNAME 1 | Número lógico ꞏ4ꞏ. | Cabezal con índice ꞏ1ꞏ. |\n| SPDLNAME 2 | Número lógico ꞏ5ꞏ. | Cabezal con índice ꞏ2ꞏ. |" ;
    ex:tieneComponente ex:CabezalIndice1, ex:CabezalIndice2, ex:CabezalIndice3 .

ex:CabezalIndice1 a ex:Componente ;
    ex:textoExtracto "Cabezal con índice ꞏ1ꞏ." ;
    ex:identificador "SPDLNAME 1" ;
    ex:valor "1" .

ex:CabezalIndice2 a ex:Componente ;
    ex:textoExtracto "Cabezal con índice ꞏ2ꞏ." ;
    ex:identificador "SPDLNAME 2" ;
    ex:valor "2" .

ex:CabezalIndice3 a ex:Componente ;
    ex:textoExtracto "Número lógico ꞏ3ꞏ." ;
    ex:identificador "AXISNAME 3" ;
    ex:valor "3" .