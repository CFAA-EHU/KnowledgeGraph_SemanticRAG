@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_CHNAXIS rdfs:label "CHNAXIS" ;
    a ex:Parametro ;
    ex:textoExtracto "Número de ejes del canal." ;
    ex:valor "Número de ejes del canal" .

ex:Parametro_CHAXISNAME rdfs:label "CHAXISNAME" ;
    a ex:Parametro ;
    ex:textoExtracto "Lista de ejes del canal." ;
    ex:valor "Lista de ejes del canal" .

ex:Parametro_CHNSPDL rdfs:label "CHNSPDL" ;
    a ex:Parametro ;
    ex:textoExtracto "Número de cabezales del canal." ;
    ex:valor "Número de cabezales del canal" .

ex:Parametro_CHSPDLNAME rdfs:label "CHSPDLNAME" ;
    a ex:Parametro ;
    ex:textoExtracto "Lista de cabezales del canal." ;
    ex:valor "Lista de cabezales del canal" .

ex:Parametro_NAXIS rdfs:label "NAXIS" ;
    a ex:Parametro ;
    ex:textoExtracto "Número de ejes del sistema." ;
    ex:valor "Número de ejes del sistema" .

ex:Tabla_ConfiguracionCanales a ex:Tabla ;
    rdfs:label "Tabla de configuración de canales" ;
    a ex:Tabla ;
    ex:textoExtracto "Parámetro. | Significado. | CHNAXIS | Número de ejes del canal. | CHAXISNAME | Lista de ejes del canal. | CHNSPDL | Número de cabezales del canal. | CHSPDLNAME | Lista de cabezales del canal." .