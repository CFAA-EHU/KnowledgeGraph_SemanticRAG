@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramacionBasicaDelPLC a ns1:TareaMantenimiento ;
    rdfs:label "Programación básica del PLC" ;
    ns1:documentadoEn ns1:EsquemaProgramacionPLC ;
    ns1:textoExtracto "La rutina M06 utiliza las siguientes funciones auxiliares M para indicar al PLC qué movimientos debe realizar. Su programación depende del tipo de máquina." .

ns1:EsquemaProgramacionPLC a ns1:Esquema ;
    rdfs:label "Esquema de programación básica del PLC" ;
    ns1:detalladoEnEsquema ns1:SETGRTOSPDL,
        ns1:SETMZROT,
        ns1:SETMZTOSPDL,
        ns1:SETSPDLTOMZ,
        ns1:SeleccionarEnElAlmacenLaPosicionQueIndicaLEAVEPOSYDejarLaHerramientaDelCabezal_24dcc7f9dc,
        ns1:SeleccionarEnElAlmacenLaPosicionQueIndicaTAKEPOSYPonerLaHerramientaEnElCabezal_df9bd0f605 ;
    ns1:textoExtracto "La rutina M06 utiliza las siguientes funciones auxiliares M para indicar al PLC qué movimientos debe realizar. Su programación depende del tipo de máquina." .

ns1:SETGRTOSPDL a ns1:Parametro ;
    rdfs:label "SET GRTOSPDL" ;
    ns1:identificador "M1108" ;
    ns1:textoExtracto "DFU M1108 = SET GRTOSPDL DFD GRTOSPDL = RES M1108 La herramienta se ha llevado de tierra al cabezal." .

ns1:SETMZROT a ns1:Parametro ;
    rdfs:label "SET MZROT" ;
    ns1:identificador "M1111" ;
    ns1:textoExtracto "DFU M1111 = SET MZROT DFD MZROT = RES M1111 Ya ha girado el almacén." .

ns1:SETMZTOSPDL a ns1:Parametro ;
    rdfs:label "SET MZTOSPDL" ;
    ns1:identificador "M1109" ;
    ns1:textoExtracto "DFU M1109 = SET MZTOSPDL DFD MZTOSPDL = RES M1109 La herramienta se ha llevado del almacén al cabezal." .

ns1:SETSPDLTOMZ a ns1:Parametro ;
    rdfs:label "SET SPDLTOMZ" ;
    ns1:identificador "M1110" ;
    ns1:textoExtracto "DFU M1110 = SET SPDLTOMZ DFD SPDLTOMZ = RES M1110 La herramienta se ha llevado del cabezal al almacén." .

ns1:SeleccionarEnElAlmacenLaPosicionQueIndicaLEAVEPOSYDejarLaHerramientaDelCabezal_24dcc7f9dc a ns1:Parametro ;
    rdfs:label "Seleccionar en el almacén la posición que indica LEAVEPOS y dejar la herramienta del cabezal" ;
    ns1:identificador "M110" ;
    ns1:textoExtracto "M110 Seleccionar en el almacén la posición que indica LEAVEPOS y dejar la herramienta del cabezal." .

ns1:SeleccionarEnElAlmacenLaPosicionQueIndicaTAKEPOSYPonerLaHerramientaEnElCabezal_df9bd0f605 a ns1:Parametro ;
    rdfs:label "Seleccionar en el almacén la posición que indica TAKEPOS y poner la herramienta en el cabezal" ;
    ns1:identificador "M109" ;
    ns1:textoExtracto "M109 Seleccionar en el almacén la posición que indica TAKEPOS y poner la herramienta en el cabezal." .

