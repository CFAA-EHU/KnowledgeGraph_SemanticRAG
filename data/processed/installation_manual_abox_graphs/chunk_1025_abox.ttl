@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SenalEmergenciaGestor a ns1:AvisoSeguridad ;
    rdfs:label "Señal de emergencia del gestor" ;
    ns1:textoExtracto "Tratamiento de la señal de emergencia del gestor de herramientas." .

ns1:SistemaPLCProgramacionBasica a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Su programación depende del tipo de máquina." ;
    ns1:tieneComponente ns1:RegistroLeavePos,
        ns1:RegistroTakePos .

ns1:RegistroLeavePos a ns1:ComponenteElectrico ;
    rdfs:label "Registro LEAVEPOS" ;
    ns1:textoExtracto "Este registro indica la posición de almacén en la que hay que dejar la herramienta." .

ns1:RegistroTakePos a ns1:ComponenteElectrico ;
    rdfs:label "Registro TAKEPOS" ;
    ns1:textoExtracto "Este registro indica la posición de almacén que ocupa la herramienta que hay que coger." .

