@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaConfiguracionCanales a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuración de ejes y cabezales (CHAXISNAME/CHSPDLNAME)"@es ;
    ex:textoExtracto "El primer cabezal de la tabla CHSPDLNAME tendrá índice ꞏ1ꞏ y así sucesivamente. | CHAXISNAME | CHSPDLNAME | Índice en el canal. | --- | --- | --- | CHAXISNAME 1 |  | Eje con índice ꞏ1ꞏ. | CHAXISNAME 2 |  | Eje con índice ꞏ2ꞏ. | CHAXISNAME 3 |  | Eje con índice ꞏ3ꞏ. |  | CHSPDLNAME 1 | Cabezal con índice ꞏ1ꞏ. |  | CHSPDLNAME 2 | Cabezal con índice ꞏ2ꞏ."@es ;
    ex:identificador "Tabla_10.1.2_ConfiguracionEjesCabezales" .

ex:TablaConfiguracionCanales_Eje1 a ex:Tabla ;
     a ex:ComponenteMecanico ;
    rdfs:label "Eje CHAXISNAME 1"@es ;
    ex:textoExtracto "Eje con índice ꞏ1ꞏ."@es ;
    ex:identificador "CHAXISNAME_1" ;
    ex:documentadoEn ex:TablaConfiguracionCanales .

ex:TablaConfiguracionCanales_Eje2 a ex:Tabla ;
     a ex:ComponenteMecanico ;
    rdfs:label "Eje CHAXISNAME 2"@es ;
    ex:textoExtracto "Eje con índice ꞏ2ꞏ."@es ;
    ex:identificador "CHAXISNAME_2" ;
    ex:documentadoEn ex:TablaConfiguracionCanales .

ex:TablaConfiguracionCanales_Eje3 a ex:Tabla ;
     a ex:ComponenteMecanico ;
    rdfs:label "Eje CHAXISNAME 3"@es ;
    ex:textoExtracto "Eje con índice ꞏ3ꞏ."@es ;
    ex:identificador "CHAXISNAME_3" ;
    ex:documentadoEn ex:TablaConfiguracionCanales .

ex:TablaConfiguracionCanales_Cabezal1 a ex:Tabla ;
     a ex:ComponenteMecanico ;
    rdfs:label "Cabezal CHSPDLNAME 1"@es ;
    ex:textoExtracto "El primer cabezal de la tabla CHSPDLNAME tendrá índice ꞏ1ꞏ y así sucesivamente. [...] Cabezal con índice ꞏ1ꞏ."@es ;
    ex:identificador "CHSPDLNAME_1" ;
    ex:documentadoEn ex:TablaConfiguracionCanales .

ex:TablaConfiguracionCanales_Cabezal2 a ex:Tabla ;
     a ex:ComponenteMecanico ;
    rdfs:label "Cabezal CHSPDLNAME 2"@es ;
    ex:textoExtracto "Cabezal con índice ꞏ2ꞏ."@es ;
    ex:identificador "CHSPDLNAME_2" ;
    ex:documentadoEn ex:TablaConfiguracionCanales .