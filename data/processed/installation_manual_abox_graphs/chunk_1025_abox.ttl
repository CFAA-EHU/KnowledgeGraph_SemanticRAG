@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla1025_557 a ex:Tabla ;
    ex:textoExtracto """El primer cabezal de la tabla CHSPDLNAME tendrá índice ꞏ1ꞏ y así sucesivamente. | CHAXISNAME | CHSPDLNAME | Índice en el canal. |
| --- | --- | --- |
| CHAXISNAME 1 |  | Eje con índice ꞏ1ꞏ. |
| CHAXISNAME 2 |  | Eje con índice ꞏ2ꞏ. |
| CHAXISNAME 3 |  | Eje con índice ꞏ3ꞏ. |
|  | CHSPDLNAME 1 | Cabezal con índice ꞏ1ꞏ. |
|  | CHSPDLNAME 2 | Cabezal con índice ꞏ2ꞏ.""" .

ex:Eje1 a ex:ComponenteMecanico ;
    ex:identificador "CHAXISNAME 1" ;
    ex:textoExtracto "Eje con índice ꞏ1ꞏ." .

ex:Eje2 a ex:ComponenteMecanico ;
    ex:identificador "CHAXISNAME 2" ;
    ex:textoExtracto "Eje con índice ꞏ2ꞏ." .

ex:Eje3 a ex:ComponenteMecanico ;
    ex:identificador "CHAXISNAME 3" ;
    ex:textoExtracto "Eje con índice ꞏ3ꞏ." .

ex:Cabezal1 a ex:ComponenteMecanico ;
    ex:identificador "CHSPDLNAME 1" ;
    ex:textoExtracto "Cabezal con índice ꞏ1ꞏ." .

ex:Cabezal2 a ex:ComponenteMecanico ;
    ex:identificador "CHSPDLNAME 2" ;
    ex:textoExtracto "Cabezal con índice ꞏ2ꞏ." .

ex:Tabla1025_557 a ex:Tabla ;
    ex:tieneComponente ex:Eje1, ex:Eje2, ex:Eje3, ex:Cabezal1, ex:Cabezal2 .