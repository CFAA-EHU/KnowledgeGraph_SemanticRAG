@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivacionDeEmergenciaPorTeclaUSER12 a ns1:AccionProhibida ;
    rdfs:label "Activación de emergencia por tecla USER12" ;
    ns1:activaAlarma ns1:LampadaDeTeclaUSER12 ;
    ns1:textoExtracto "Si se pulsa la tecla USER12 se activa la emergencia." .

ns1:DesactivacionDeEmergenciaPorTeclaUSER13 a ns1:AccionProhibida ;
    rdfs:label "Desactivación de emergencia por tecla USER13" ;
    ns1:textoExtracto "Si se pulsa la tecla USER13 se quita la emergencia." .

ns1:Sensor_1ccda88d1a a ns1:Sensor ;
    rdfs:label "Sensor de señal de emergencia" ;
    ns1:textoExtracto "Tratamiento de la señal de emergencia del gestor de herramientas." .

ns1:LampadaDeTeclaUSER12 a ns1:AvisoSeguridad ;
    rdfs:label "Lámpada de tecla USER12" ;
    ns1:textoExtracto "Lámpara de la tecla USER12 iluminada cuando hay emergencia." .

