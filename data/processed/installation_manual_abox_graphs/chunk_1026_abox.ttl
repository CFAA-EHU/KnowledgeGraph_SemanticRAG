@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ConfiguracionesMaquinas_1026 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuraciones de máquinas (Sección 10.2)"@es ;
    ex:textoExtracto "A continuación se ofrecen diferentes configuraciones de máquinas. En cada una de ellas se indica cuál es el número lógico e índice en el canal de cada eje y cabezal. [...] | Lista de ejemplos. | Página. | Fresadora con 1 canal, 3 ejes y 1 cabezal. | 559 | [...] Torno con 3 canales, 6 ejes y 2 cabezales. Canal 1: 2 ejes y 1 cabezal. Configuración de ejes tipo plano."@es ;
    ex:documentadoEn ex:Pagina_558 ;
    ex:ilustradoEn ex:Esquema_PlanosTrabajo_G17_G18_G19 .

ex:Pagina_558
    a ex:Pagina ;
    ex:identificador "558" ;
    ex:textoExtracto "Sección 10.2 Ejemplos de configuración"@es .

ex:Esquema_PlanosTrabajo_G17_G18_G19
    a ex:Esquema ;
    rdfs:label "Esquema de planos de trabajo asociados a funciones G17, G18 y G19"@es ;
    ex:textoExtracto "En cada ejemplo también se muestra el plano de trabajo asociado a las funciones G17, G18 y G19."@es .

ex:Parametro_GEOCONFIG
    a ex:Parametro ;
    rdfs:label "GEOCONFIG" ;
    ex:identificador "GEOCONFIG" ;
    ex:textoExtracto "En los ejemplos de torno está indicado el valor del parámetro máquina GEOCONFIG, ya que en función de este parámetro cambia el comportamiento de las funciones asociadas a los planos de trabajo."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionesMaquinas_1026 .