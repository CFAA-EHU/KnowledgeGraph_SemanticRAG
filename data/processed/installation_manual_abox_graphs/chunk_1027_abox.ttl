@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TornoCon3Canales a ex:Maquina ;
    ex:textoExtracto "Torno con 3 canales, 6 ejes y 2 cabezales. Canal 1: 2 ejes y 1 cabezal. Configuración de ejes tipo plano. Canal 2: 2 ejes y 1 cabezal. Configuración de ejes tipo plano. Canal 3: 2 ejes y ningún cabezal." ;
    ex:tieneComponente ex:Canal1, ex:Canal2, ex:Canal3 .

ex:Canal1 a ex:Sistema ;
    ex:textoExtracto "Canal 1: 2 ejes y 1 cabezal. Configuración de ejes tipo plano." ;
    ex:compuestoPor ex:Eje1Canal1, ex:Eje2Canal1, ex:Cabezal1Canal1 .

ex:Canal2 a ex:Sistema ;
    ex:textoExtracto "Canal 2: 2 ejes y 1 cabezal. Configuración de ejes tipo plano." ;
    ex:compuestoPor ex:Eje1Canal2, ex:Eje2Canal2, ex:Cabezal1Canal2 .

ex:Canal3 a ex:Sistema ;
    ex:textoExtracto "Canal 3: 2 ejes y ningún cabezal." ;
    ex:compuestoPor ex:Eje1Canal3, ex:Eje2Canal3 .

ex:Eje1Canal1 a ex:ComponenteMecanico ;
    ex:textoExtracto "2 ejes" .

ex:Eje2Canal1 a ex:ComponenteMecanico ;
    ex:textoExtracto "2 ejes" .

ex:Cabezal1Canal1 a ex:ComponenteMecanico ;
    ex:textoExtracto "1 cabezal" .

ex:Eje1Canal2 a ex:ComponenteMecanico ;
    ex:textoExtracto "2 ejes" .

ex:Eje2Canal2 a ex:ComponenteMecanico ;
    ex:textoExtracto "2 ejes" .

ex:Cabezal1Canal2 a ex:ComponenteMecanico ;
    ex:textoExtracto "1 cabezal" .

ex:Eje1Canal3 a ex:ComponenteMecanico ;
    ex:textoExtracto "2 ejes" .

ex:Eje2Canal3 a ex:ComponenteMecanico ;
    ex:textoExtracto "2 ejes" .