@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RegistroLEAVEPOS a ns1:Parametro ;
    rdfs:label "Registro LEAVEPOS" ;
    ns1:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor." .

ns1:RegistroTAKEPOS a ns1:Parametro ;
    rdfs:label "Registro TAKEPOS" ;
    ns1:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor." .

ns1:SistemaGestorHerramientas a ns1:Sistema ;
    rdfs:label "Sistema Gestor de Herramientas" ;
    ns1:textoExtracto "Operaciones válidas del gestor de herramientas para este almacén." ;
    ns1:tieneComponente ns1:CogerUnaHerramientaDelAlmacenYPonerlaEnElCabezal_a17c0cbec2,
        ns1:DejarLaHerramientaDelCabezalEnElAlmacen_a998acc2f8,
        ns1:DejarLaHerramientaDelCabezalEnTierra_6f4542da77,
        ns1:PonerEnElCabezalUnaHerramientaDeTierra_911ae91ce3 .

ns1:CogerUnaHerramientaDelAlmacenYPonerlaEnElCabezal_a17c0cbec2 a ns1:TareaMantenimiento ;
    rdfs:label "Coger una herramienta del almacén y ponerla en el cabezal" ;
    ns1:textoExtracto "1 | Coger una herramienta del almacén y ponerla en el cabezal." .

ns1:DejarLaHerramientaDelCabezalEnElAlmacen_a998acc2f8 a ns1:TareaMantenimiento ;
    rdfs:label "Dejar la herramienta del cabezal en el almacén" ;
    ns1:textoExtracto "2 | Dejar la herramienta del cabezal en el almacén." .

ns1:DejarLaHerramientaDelCabezalEnTierra_6f4542da77 a ns1:TareaMantenimiento ;
    rdfs:label "Dejar la herramienta del cabezal en tierra" ;
    ns1:textoExtracto "4 | Dejar la herramienta del cabezal en tierra." .

ns1:PonerEnElCabezalUnaHerramientaDeTierra_911ae91ce3 a ns1:TareaMantenimiento ;
    rdfs:label "Poner en el cabezal una herramienta de tierra" ;
    ns1:textoExtracto "3 | Poner en el cabezal una herramienta de tierra." .

