@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteHidraulico_40d310c4db a ns1:ComponenteHidraulico ;
    rdfs:label "Herramienta de tierra" ;
    ns1:textoExtracto "-4 | Herramienta de tierra." .

ns1:TablaResumenOperacionesValidas a ns1:Tabla ;
    rdfs:label "Tabla resumen de operaciones válidas y marcas que activa el PLC" ;
    ns1:textoExtracto "A continuación se muestra una tabla resumen de los valores TAKEPOS y LEAVEPOS que utiliza el gestor en cada una de las operaciones, así como las marcas que debe activar el PLC al finalizar cada operación." .

