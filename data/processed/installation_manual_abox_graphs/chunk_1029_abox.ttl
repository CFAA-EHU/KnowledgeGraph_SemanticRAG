@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:CabezalIndice1 a ex:ComponenteMecanico ;
    rdfs:label "Cabezal con índice 1" ;
    ex:identificador "CHSPDLNAME 1" ;
    ex:textoExtracto "Cabezal con índice ꞏ1ꞏ. Número lógico ꞏ4ꞏ. Selección de planos en el canal ꞏ1ꞏ." .

ex:PlanoX_Y a ex:Parametro ;
    rdfs:label "Plano X-Y" ;
    ex:textoExtracto "Plano X-Y. Eje perpendicular Z." .

ex:PlanoZ_X a ex:Parametro ;
    rdfs:label "Plano Z-X" ;
    ex:textoExtracto "Plano Z-X. Eje perpendicular Y." .

ex:PlanoY_Z a ex:Parametro ;
    rdfs:label "Plano Y-Z" ;
    ex:textoExtracto "Plano Y-Z. Eje perpendicular X." .

ex:PlanoLongitudinal a ex:Parametro ;
    rdfs:label "Plano longitudinal" ;
    ex:textoExtracto "Cualquier plano y/o eje longitudinal." .