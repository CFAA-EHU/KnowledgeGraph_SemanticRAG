@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Fresadora_1Canal_3Ejes_1Cabezal
    a ex:Maquina ;
    rdfs:label "Fresadora con 1 canal, 3 ejes y 1 cabezal"@es ;
    ex:textoExtracto "Sección 10.2.1 Fresadora con 1 canal, 3 ejes y 1 cabezal."@es ;
    ex:tieneComponente ex:Cabezal_Indice1 .

ex:Cabezal_Indice1
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal con índice 1"@es ;
    ex:identificador "1" ;
    ex:textoExtracto "Cabezal con índice ꞏ1ꞏ. Número lógico ꞏ4ꞏ. Selección de planos en el canal ꞏ1ꞏ."@es .

ex:Tabla_SeleccionPlanos_Cabezal1 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de selección de planos para cabezal índice 1"@es ;
    ex:textoExtracto
    """
| Función. | Plano seleccionado. |
| --- | --- |
| G17 | Plano X-Y. Eje perpendicular Z. |
| G18 | Plano Z-X. Eje perpendicular Y. |
| G19 | Plano Y-Z. Eje perpendicular X. |
| G20 | Cualquier plano y/o eje longitudinal.
    """@es ;
    ex:documentadoEn ex:Fresadora_1Canal_3Ejes_1Cabezal .

ex:Parametro_G17
    a ex:Parametro ;
    rdfs:label "G17" ;
    ex:identificador "G17" ;
    ex:valor "Plano X-Y. Eje perpendicular Z."@es ;
    ex:textoExtracto "G17 | Plano X-Y. Eje perpendicular Z."@es ;
    ex:documentadoEn ex:Tabla_SeleccionPlanos_Cabezal1 .

ex:Parametro_G18
    a ex:Parametro ;
    rdfs:label "G18" ;
    ex:identificador "G18" ;
    ex:valor "Plano Z-X. Eje perpendicular Y."@es ;
    ex:textoExtracto "G18 | Plano Z-X. Eje perpendicular Y."@es ;
    ex:documentadoEn ex:Tabla_SeleccionPlanos_Cabezal1 .

ex:Parametro_G19
    a ex:Parametro ;
    rdfs:label "G19" ;
    ex:identificador "G19" ;
    ex:valor "Plano Y-Z. Eje perpendicular X."@es ;
    ex:textoExtracto "G19 | Plano Y-Z. Eje perpendicular X."@es ;
    ex:documentadoEn ex:Tabla_SeleccionPlanos_Cabezal1 .

ex:Parametro_G20
    a ex:Parametro ;
    rdfs:label "G20" ;
    ex:identificador "G20" ;
    ex:valor "Cualquier plano y/o eje longitudinal"@es ;
    ex:textoExtracto "G20 | Cualquier plano y/o eje longitudinal."@es ;
    ex:documentadoEn ex:Tabla_SeleccionPlanos_Cabezal1 .