@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaSercos a ns1:Sistema ;
    rdfs:label "Sistema Sercos" ;
    ns1:textoExtracto "SERBRATE Velocidad de transmisión de Sercos. Valores posibles: 2/4/8/16 Mbps (megabits por segundo). Valor por defecto: 4 Mbps." ;
    ns1:tieneComponente ns1:PotenciaOpticaDeSercos,
        ns1:VelocidadDeTransmisionDeSercos .

ns1:PotenciaOpticaDeSercos a ns1:Parametro ;
    rdfs:label "Potencia óptica de Sercos" ;
    ns1:identificador "MPG.SERPOWSE" ;
    ns1:textoExtracto "SERPOWSE Potencia óptica de Sercos. Valores posibles: De 1 a 6 (placa Sercos I) / de 1 a 8 (placa Sercos II). Valor por defecto: 4 (placa Sercos I) / 2 (placa Sercos II)." .

ns1:VelocidadDeTransmisionDeSercos a ns1:Parametro ;
    rdfs:label "Velocidad de transmisión de Sercos" ;
    ns1:identificador "MPG.SERBRATE" ;
    ns1:textoExtracto "SERBRATE Velocidad de transmisión de Sercos. Valores posibles: 2/4/8/16 Mbps (megabits por segundo). Valor por defecto: 4 Mbps." .

