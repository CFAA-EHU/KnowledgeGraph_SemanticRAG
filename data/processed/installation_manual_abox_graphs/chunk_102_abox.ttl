@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MAXCOMP
    a ex:Parametro ;
    rdfs:label "MAXCOMP" ;
    ex:identificador "V.MPG.MAXCOMP" ;
    ex:valor "10025"^^xsd:integer ;
    ex:textoExtracto "común entre canales máximo. Valores posibles: De 10000 a 19999. Valor por defecto: 10025. Variable asociada: (V.)MPG.MAXCOMP" .

ex:Parametro_MINCOMP
    a ex:Parametro ;
    rdfs:label "MINCOMP" ;
    ex:identificador "V.MPG.MINCOMP" ;
    ex:valor "10000"^^xsd:integer ;
    ex:textoExtracto "Parámetro aritmético común entre canales mínimo. Valores posibles: De 10000 a 19999. Valor por defecto: 10000. Variable asociada: (V.)MPG.MINCOMP" .

ex:Parametro_BKUPCUP
    a ex:Parametro ;
    rdfs:label "BKUPCUP" ;
    ex:identificador "V.MPG.BKUPCUP" ;
    ex:valor "0"^^xsd:integer ;
    ex:textoExtracto "Número de parámetros aritméticos comunes no volátiles. Valores posibles: De 0 a 20. Valor por defecto: 0. Variable asociada: (V.)MPG.BKUPCUP" .

ex:Sistema_ParametrosAritmeticosComunes
    a ex:Sistema ;
    rdfs:label "Sistema de parámetros aritméticos comunes entre canales" ;
    ex:textoExtracto "Los parámetros MAXCOMP y MINCOMP definen el grupo de parámetros aritméticos comunes a todos los canales que se desea utilizar. Los parámetros comunes son accesibles desde cualquier canal. El valor de estos parámetros es compartido por todos los canales." ;
    ex:tieneComponente ex:Parametro_MAXCOMP, ex:Parametro_MINCOMP, ex:Parametro_BKUPCUP .