@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_MAXCOMP a ex:Parametro ;
    rdfs:label "MAXCOMP" ;
    ex:identificador "MAXCOMP" ;
    ex:textoExtracto "Parámetro aritmético común entre canales máximo. Valores posibles: De 10000 a 19999. Valor por defecto: 10025. Variable asociada: (V.)MPG.MAXCOMP" ;
    ex:valor "10025" ;
    ex:tieneComponente ex:Parametro_MPG .

ex:Parametro_MINCOMP a ex:Parametro ;
    rdfs:label "MINCOMP" ;
    ex:identificador "MINCOMP" ;
    ex:textoExtracto "MINCOMP Parámetro aritmético común entre canales mínimo. Valores posibles: De 10000 a 19999. Valor por defecto: 10000. Variable asociada: (V.)MPG.MINCOMP" ;
    ex:valor "10000" ;
    ex:tieneComponente ex:Parametro_MPG .

ex:Parametro_BKUPCUP a ex:Parametro ;
    rdfs:label "BKUPCUP" ;
    ex:identificador "BKUPCUP" ;
    ex:textoExtracto "BKUPCUP Número de parámetros aritméticos comunes no volátiles. Valores posibles: De 0 a 20. Valor por defecto: 0. Variable asociada: (V.)MPG.BKUPCUP Este parámetro indica el número parámetros aritméticos comunes que se almacenan en la RAM con batería." ;
    ex:valor "0" ;
    ex:tieneComponente ex:Parametro_MPG .

ex:Parametro_MPG a ex:Parametro ;
    rdfs:label "MPG" ;
    ex:identificador "MPG" ;
    ex:textoExtracto "Los parámetros MAXCOMP y MINCOMP definen el grupo de parámetros aritméticos comunes a todos los canales que se desea utilizar. Los parámetros comunes son accesibles desde cualquier canal. El valor de estos parámetros es compartido por todos los canales." ;
    ex:tieneComponente ex:Parametro_MAXCOMP, ex:Parametro_MINCOMP, ex:Parametro_BKUPCUP .