@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Maquina_1030_560 a ex:Maquina ;
    ex:textoExtracto "Supongamos una máquina de un canal con tres ejes y cabezal y dos ejes sin asignar inicialmente. Los ejes y cabezales están distribuidos de la siguiente manera. Canal ꞏ1ꞏ. 3 ejes (X Y Z) 1 cabezal (S). Sin asignar. 2 ejes (A B) Configuración general de los canales, ejes y cabezales. Configuración de los ejes y cabezales del sistema." ;
    ex:tieneComponente ex:Eje_X_1030_560, ex:Eje_Y_1030_560, ex:Eje_Z_1030_560, ex:Eje_A_1030_560, ex:Eje_B_1030_560, ex:Cabezal_S1_1030_560 .

ex:Eje_X_1030_560 a ex:ComponenteMecanico ;
    ex:identificador "AXISNAME 1" ;
    ex:textoExtracto "AXISNAME 1 | X | Número lógico ꞏ1ꞏ." .

ex:Eje_Y_1030_560 a ex:ComponenteMecanico ;
    ex:identificador "AXISNAME 2" ;
    ex:textoExtracto "AXISNAME 2 | Y | Número lógico ꞏ2ꞏ." .

ex:Eje_Z_1030_560 a ex:ComponenteMecanico ;
    ex:identificador "AXISNAME 3" ;
    ex:textoExtracto "AXISNAME 3 | Z | Número lógico ꞏ3ꞏ." .

ex:Eje_A_1030_560 a ex:ComponenteMecanico ;
    ex:identificador "AXISNAME 4" ;
    ex:textoExtracto "AXISNAME 4 | A | Número lógico ꞏ4ꞏ." .

ex:Eje_B_1030_560 a ex:ComponenteMecanico ;
    ex:identificador "AXISNAME 5" ;
    ex:textoExtracto "AXISNAME 5 | B | Número lógico ꞏ5ꞏ." .

ex:Cabezal_S1_1030_560 a ex:ComponenteMecanico ;
    ex:identificador "SPDLNAME 1" ;
    ex:textoExtracto "SPDLNAME 1 | S1 | Número lógico ꞏ6ꞏ. | Cabezal con índice ꞏ1ꞏ." .