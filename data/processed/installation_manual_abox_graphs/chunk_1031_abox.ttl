@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Fresadora_1Canal_5Ejes_1Cabezal a ex:Maquina ;
    ex:textoExtracto "Fresadora con 1 canal, 5 ejes (2 libres) y 1 cabezal." ;
    ex:tieneComponente ex:Cabezal_Indice_1 .

ex:Cabezal_Indice_1 a ex:ComponenteMecanico ;
    ex:textoExtracto "Cabezal con índice ꞏ1ꞏ. Número lógico ꞏ10ꞏ." ;
    ex:identificador "CHSPDLNAME 1" .

ex:Seleccion_Planos_Canal_1 a ex:InterfazUsuario ;
    ex:textoExtracto "Selección de planos en el canal ꞏ1ꞏ." ;
    ex:compuestoPor ex:Funcion_G17, ex:Funcion_G18, ex:Funcion_G19, ex:Funcion_G20 .

ex:Funcion_G17 a ex:ModoOperacion ;
    ex:textoExtracto "G17. Plano X-Y. Eje perpendicular Z." ;
    ex:identificador "G17" .

ex:Funcion_G18 a ex:ModoOperacion ;
    ex:textoExtracto "G18. Plano Z-X. Eje perpendicular Y." ;
    ex:identificador "G18" .

ex:Funcion_G19 a ex:ModoOperacion ;
    ex:textoExtracto "G19. Plano Y-Z. Eje perpendicular X." ;
    ex:identificador "G19" .

ex:Funcion_G20 a ex:ModoOperacion ;
    ex:textoExtracto "G20. Cualquier plano y/o eje longitudinal." ;
    ex:identificador "G20" .