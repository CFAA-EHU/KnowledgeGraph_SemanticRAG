@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_SeleccionPlanos_1031 a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de selección de planos en canal 1 (G17-G20)"@es ;
    ex:textoExtracto """
| Función. | Plano seleccionado. |
| --- | --- |
| G17 | Plano X-Y. Eje perpendicular Z. |
| G18 | Plano Z-X. Eje perpendicular Y. |
| G19 | Plano Y-Z. Eje perpendicular X. |
| G20 | Cualquier plano y/o eje longitudinal.
""" ;
    ex:documentadoEn ex:Pagina_560 ;
    ex:identificador "10.2.2" .

ex:Pagina_560
    a               ex:Pagina ;
    ex:identificador "560" ;
    ex:textoExtracto "Sección 10.2.2: Fresadora con 1 canal, 5 ejes (2 libres) y 1 cabezal."@es .

ex:Parametro_G17
    a               ex:Parametro ;
    rdfs:label      "G17" ;
    ex:identificador "G17" ;
    ex:textoExtracto "Plano X-Y. Eje perpendicular Z."@es ;
    ex:documentadoEn ex:Tabla_SeleccionPlanos_1031 .

ex:Parametro_G18
    a               ex:Parametro ;
    rdfs:label      "G18" ;
    ex:identificador "G18" ;
    ex:textoExtracto "Plano Z-X. Eje perpendicular Y."@es ;
    ex:documentadoEn ex:Tabla_SeleccionPlanos_1031 .

ex:Parametro_G19
    a               ex:Parametro ;
    rdfs:label      "G19" ;
    ex:identificador "G19" ;
    ex:textoExtracto "Plano Y-Z. Eje perpendicular X."@es ;
    ex:documentadoEn ex:Tabla_SeleccionPlanos_1031 .

ex:Parametro_G20
    a               ex:Parametro ;
    rdfs:label      "G20" ;
    ex:identificador "G20" ;
    ex:textoExtracto "Cualquier plano y/o eje longitudinal."@es ;
    ex:documentadoEn ex:Tabla_SeleccionPlanos_1031 .

ex:Cabezal_Indice1
    a               ex:ComponenteMecanico ;
    rdfs:label      "Cabezal con índice 1"@es ;
    ex:identificador "1" ;
    ex:textoExtracto "Cabezal con índice ꞏ1ꞏ. Número lógico ꞏ10ꞏ. Selección de planos en el canal ꞏ1ꞏ."@es ;
    ex:documentadoEn ex:Pagina_560 .