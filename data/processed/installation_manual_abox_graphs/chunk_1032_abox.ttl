@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Fresadora_1032 a ex:Maquina ;
    ex:textoExtracto "Supongamos una máquina con tres canales dónde los dos primeros canales disponen de ejes y cabezales para mecanizar y el tercer canal es un sistema de carga y descarga controlado por dos ejes. Los ejes y cabezales están distribuidos de la siguiente manera. Canal ꞏ1ꞏ. 3 ejes (X Y Z) 1 cabezal (S1). Canal ꞏ2ꞏ. 4 ejes (X1 Y1 Z1 W) 1 cabezal (S2). Canal ꞏ3ꞏ. 2 ejes (U U1) 0 cabezales." ;
    ex:compuestoPor ex:Canal_1_1032, ex:Canal_2_1032, ex:Canal_3_1032 .

ex:Canal_1_1032 a ex:Sistema ;
    ex:textoExtracto "Canal ꞏ1ꞏ. 3 ejes (X Y Z) 1 cabezal (S1)" ;
    ex:compuestoPor ex:Eje_X_1032, ex:Eje_Y_1032, ex:Eje_Z_1032, ex:Cabezal_S1_1032 .

ex:Eje_X_1032 a ex:ComponenteMecanico ;
    ex:textoExtracto "3 ejes (X Y Z)" .

ex:Eje_Y_1032 a ex:ComponenteMecanico ;
    ex:textoExtracto "3 ejes (X Y Z)" .

ex:Eje_Z_1032 a ex:ComponenteMecanico ;
    ex:textoExtracto "3 ejes (X Y Z)" .

ex:Cabezal_S1_1032 a ex:ComponenteMecanico ;
    ex:textoExtracto "1 cabezal (S1)" .

ex:Canal_2_1032 a ex:Sistema ;
    ex:textoExtracto "Canal ꞏ2ꞏ. 4 ejes (X1 Y1 Z1 W) 1 cabezal (S2)" ;
    ex:compuestoPor ex:Eje_X1_1032, ex:Eje_Y1_1032, ex:Eje_Z1_1032, ex:Eje_W_1032, ex:Cabezal_S2_1032 .

ex:Eje_X1_1032 a ex:ComponenteMecanico ;
    ex:textoExtracto "4 ejes (X1 Y1 Z1 W)" .

ex:Eje_Y1_1032 a ex:ComponenteMecanico ;
    ex:textoExtracto "4 ejes (X1 Y1 Z1 W)" .

ex:Eje_Z1_1032 a ex:ComponenteMecanico ;
    ex:textoExtracto "4 ejes (X1 Y1 Z1 W)" .

ex:Eje_W_1032 a ex:ComponenteMecanico ;
    ex:textoExtracto "4 ejes (X1 Y1 Z1 W)" .

ex:Cabezal_S2_1032 a ex:ComponenteMecanico ;
    ex:textoExtracto "1 cabezal (S2)" .

ex:Canal_3_1032 a ex:Sistema ;
    ex:textoExtracto "Canal ꞏ3ꞏ. 2 ejes (U U1) 0 cabezales" ;
    ex:compuestoPor ex:Eje_U_1032, ex:Eje_U1_1032 .

ex:Eje_U_1032 a ex:ComponenteMecanico ;
    ex:textoExtracto "2 ejes (U U1)" .

ex:Eje_U1_1032 a ex:ComponenteMecanico ;
    ex:textoExtracto "2 ejes (U U1)" .