@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PosicionEnElAlmacenYHerramientaDeTierra a ns1:Parametro ;
    rdfs:label "Herramienta de tierra.",
        "No hay que hacer nada.",
        "Posición en el almacén y herramienta de tierra",
        "Posición en el almacén." ;
    ns1:identificador "almacen_herramienta" ;
    ns1:textoExtracto "# Posición en el almacén. -4 Herramienta de tierra." ;
    ns1:valor "#",
        "-4",
        "0" .

