ex:SistemaFresadora_3Canales_9Ejes_2Cabezales
    a ex:Sistema ;
    rdfs:label "Sistema de fresadora con 3 canales, 9 ejes y 2 cabezales"@es ;
    ex:textoExtracto "Canal ꞏ3ꞏ. 2 ejes (U U1) 0 cabezales. Configuración general de los canales, ejes y cabezales. Configuración de los ejes y cabezales del sistema."@es ;
    ex:tieneComponente ex:Eje_X, ex:Eje_Y, ex:Eje_Z, ex:Eje_X1, ex:Eje_Y1, ex:Eje_Z1, ex:Eje_W, ex:Eje_U, ex:Eje_U1 ;
    ex:tieneComponente ex:Cabezal_S1, ex:Cabezal_S2 .

ex:Eje_X
    a ex:ComponenteMecanico ;
    rdfs:label "Eje X"@es ;
    ex:identificador "AXISNAME 1" ;
    ex:textoExtracto "AXISNAME 1 | X | Número lógico ꞏ1ꞏ."@es ;
    ex:valor "X" ;
    ex:documentadoEn ex:SistemaFresadora_3Canales_9Ejes_2Cabezales .

