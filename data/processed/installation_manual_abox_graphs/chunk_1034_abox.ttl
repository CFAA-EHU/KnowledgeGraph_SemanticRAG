ex:Cabezal1_Canal2
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal 1 (Canal 2, índice 1, lógica 10)"@es ;
    ex:identificador "CHSPDLNAME 1" ;
    ex:valor "S1"^^xsd:string ;
    ex:textoExtracto "Cabezal con índice ꞏ1ꞏ. Número lógico ꞏ10ꞏ."@es ;
