@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CogerLaHerramientaDelAlmacenConLaPinza a ns1:AccionProhibida ;
    rdfs:label "Coger la herramienta del almacén con la pinza" ;
    ns1:textoExtracto "3 Coger la herramienta del almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1." .

ns1:CogerLaHerramientaDelCabezalConLaPinza a ns1:AccionProhibida ;
    rdfs:label "Coger la herramienta del cabezal con la pinza" ;
    ns1:textoExtracto "1 Coger la herramienta del cabezal con la pinza ꞏ1ꞏ y activar la marca SPDLTOCH1." .

ns1:CogerUnaHerramientaDeTierra a ns1:AccionProhibida ;
    rdfs:label "Coger una herramienta de tierra" ;
    ns1:textoExtracto "TMOPERATION = 6 Dejar la herramienta del cabezal en el almacén y coger una herramienta de tierra." .

ns1:DejarLaHerramienta a ns1:AccionProhibida ;
    rdfs:label "Dejar la herramienta" ;
    ns1:textoExtracto "2 Dejar la herramienta" .

ns1:DejarLaHerramientaDeLaPinzaEnElAlmacen a ns1:AccionProhibida ;
    rdfs:label "Dejar la herramienta de la pinza en el almacén" ;
    ns1:textoExtracto "2 Dejar la herramienta de la pinza ꞏ1ꞏ en el almacén y activar la marca CH1TOMZ." .

ns1:DejarLaHerramientaDelCabezalEnElAlmacen_5b39a00c5a a ns1:AccionProhibida ;
    rdfs:label "Dejar la herramienta del cabezal en el almacén" ;
    ns1:textoExtracto "TMOPERATION = 6 Dejar la herramienta del cabezal en el almacén y coger una herramienta de tierra." .

ns1:DejarLaHerramientaEnLaPosicionDelAlmacen a ns1:AccionProhibida ;
    rdfs:label "Dejar la herramienta en la posición del almacén" ;
    ns1:textoExtracto "LEAVEPOS=# Posición del almacén para dejar la herramienta." .

ns1:PonerLaHerramientaDeLaPinzaEnElCabezal a ns1:AccionProhibida ;
    rdfs:label "Poner la herramienta de la pinza en el cabezal" ;
    ns1:textoExtracto "4 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL." .

