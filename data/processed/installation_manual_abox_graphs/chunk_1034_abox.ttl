@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Eje1 rdfs:label "X" ;
    a ex:ComponenteMecanico ;
    ex:identificador "1" ;
    ex:textoExtracto "Eje con índice ꞏ1ꞏ." .

ex:Eje2 rdfs:label "Y" ;
    a ex:ComponenteMecanico ;
    ex:identificador "2" ;
    ex:textoExtracto "Eje con índice ꞏ2ꞏ." .

ex:Eje3 rdfs:label "Z" ;
    a ex:ComponenteMecanico ;
    ex:identificador "3" ;
    ex:textoExtracto "Eje con índice ꞏ3ꞏ." .

ex:Cabezal1 rdfs:label "S1" ;
    a ex:ComponenteMecanico ;
    ex:identificador "1" ;
    ex:textoExtracto "Cabezal con índice ꞏ1ꞏ." .

ex:SistemaFresadoraCanal2 rdfs:label "Fresadora con 3 canales, 9 ejes y 2 cabezales (canal 2)" ;
    a ex:Sistema ;
    ex:textoExtracto "Configuración de los ejes y cabezales del canal ꞏ2ꞏ." ;
    ex:tieneComponente ex:Eje1, ex:Eje2, ex:Eje3, ex:Cabezal1 .