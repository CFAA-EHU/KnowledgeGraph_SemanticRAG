PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaConfiguracionEjesCanal2 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuración de ejes y cabezales (Canal 2)"@es ;
    ex:textoExtracto """
| Índice en el canal. | Orden lógico. |
| --- | --- | --- | --- |
| CHAXISNAME 1 | X | Eje con índice ꞏ1ꞏ. | Número lógico ꞏ1ꞏ.
| CHAXISNAME 2 | Y | Eje con índice ꞏ2ꞏ. | Número lógico ꞏ2ꞏ.
| CHAXISNAME 3 | Z | Eje con índice ꞏ3ꞏ. | Número lógico ꞏ3ꞏ.

| CHSPDLNAME | Valor. | Índice en el canal. | Orden lógico. |
| --- | --- | --- | --- |
| CHSPDLNAME 1 | S1 | Cabezal con índice ꞏ1ꞏ. | Número lógico ꞏ10ꞏ.
"""@es ;
    ex:documentadoEn ex:Pagina_561_562 .

ex:EjeX_Canal2
    a ex:ComponenteMecanico ;
    rdfs:label "Eje X (Canal 2, índice 1)"@es ;
    ex:identificador "CHAXISNAME 1" ;
    ex:valor "1"^^xsd:string ;
    ex:textoExtracto "Eje con índice ꞏ1ꞏ. Número lógico ꞏ1ꞏ."@es ;
    ex:documentadoEn ex:TablaConfiguracionEjesCanal2 .

ex:EjeY_Canal2
    a ex:ComponenteMecanico ;
    rdfs:label "Eje Y (Canal 2, índice 2)"@es ;
    ex:identificador "CHAXISNAME 2" ;
    ex:valor "2"^^xsd:string ;
    ex:textoExtracto "Eje con índice ꞏ2ꞏ. Número lógico ꞏ2ꞏ."@es ;
    ex:documentadoEn ex:TablaConfiguracionEjesCanal2 .

ex:EjeZ_Canal2
    a ex:ComponenteMecanico ;
    rdfs:label "Eje Z (Canal 2, índice 3)"@es ;
    ex:identificador "CHAXISNAME 3" ;
    ex:valor "3"^^xsd:string ;
    ex:textoExtracto "Eje con índice ꞏ3ꞏ. Número lógico ꞏ3ꞏ."@es ;
