@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Fresadora_3Canales_9Ejes_2Cabezales a ex:Maquina ;
    ex:textoExtracto "Fresadora con 3 canales, 9 ejes y 2 cabezales." ;
    ex:compuestoPor ex:Eje_X1, ex:Eje_Y1, ex:Eje_Z1, ex:Eje_W, ex:Eje_U1, ex:Eje_U, ex:Cabezal_S2, ex:Plano_XY_Z, ex:Plano_X1Y1_Z1 .

ex:Eje_X1 a ex:ComponenteMecanico ;
    ex:identificador "X1" ;
    ex:textoExtracto "Eje con índice ꞏ1ꞏ. Número lógico ꞏ4ꞏ." .

ex:Eje_Y1 a ex:ComponenteMecanico ;
    ex:identificador "Y1" ;
    ex:textoExtracto "Eje con índice ꞏ2ꞏ. Número lógico ꞏ5ꞏ." .

ex:Eje_Z1 a ex:ComponenteMecanico ;
    ex:identificador "Z1" ;
    ex:textoExtracto "Eje con índice ꞏ3ꞏ. Número lógico ꞏ6ꞏ." .

ex:Eje_W a ex:ComponenteMecanico ;
    ex:identificador "W" ;
    ex:textoExtracto "Eje con índice ꞏ4ꞏ. Número lógico ꞏ7ꞏ." .

ex:Eje_U1 a ex:ComponenteMecanico ;
    ex:identificador "U1" ;
    ex:textoExtracto "Eje con índice ꞏ1ꞏ. Número lógico ꞏ9ꞏ." .

ex:Eje_U a ex:ComponenteMecanico ;
    ex:identificador "U" ;
    ex:textoExtracto "Eje con índice ꞏ2ꞏ. Número lógico ꞏ8ꞏ." .

ex:Cabezal_S2 a ex:ComponenteMecanico ;
    ex:identificador "S2" ;
    ex:textoExtracto "Cabezal con índice ꞏ1ꞏ. Número lógico ꞏ11ꞏ." .

ex:Plano_XY_Z a ex:Sistema ;
    ex:textoExtracto "Plano X-Y. Eje perpendicular Z." .

ex:Plano_X1Y1_Z1 a ex:Sistema ;
    ex:textoExtracto "Plano X1-Y1. Eje perpendicular Z1." .