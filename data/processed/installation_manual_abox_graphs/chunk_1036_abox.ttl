@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

ns1:CogerHerramientaDelAlmacen a ns1:AccionProhibida ;
    rdfs:label "Coger herramienta del almacén" ;
    ns1:textoExtracto "1 Coger la herramienta del almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1." .

ns1:DejarHerramientaEnAlmacen a ns1:AccionProhibida ;
    rdfs:label "Dejar herramienta en almacén" ;
    ns1:textoExtracto "Dejar la herramienta de la pinza ꞏ1ꞏ en el almacén y activar la marca CH1TOMZ." .

ns1:Herramienta_6e230a99de a ns1:Herramienta ;
    rdfs:label "Herramienta de tierra" ;
    ns1:textoExtracto "Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

ns1:OperacionDeAlmacen a ns1:AccionProhibida ;
    rdfs:label "Operación de almacén" ;
    ns1:textoExtracto "La secuencia de esta operación es la siguiente. 1 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

ns1:Parametro_7959033478 a ns1:Parametro ;
    rdfs:label "Marca GRTOSPDL" ;
    ns1:identificador "GRTOSPDL" ;
    ns1:textoExtracto "activar la marca GRTOSPDL." .

ns1:Parametro_92b7e6b9ba a ns1:Parametro ;
    rdfs:label "Marca MZTOCH1" ;
    ns1:identificador "MZTOCH1" ;
    ns1:textoExtracto "activar la marca MZTOCH1." .

ns1:Parametro_a3ed774051 a ns1:Parametro ;
    rdfs:label "Marca SPDLTOCH1" ;
    ns1:identificador "SPDLTOCH1" ;
    ns1:textoExtracto "activar la marca SPDLTOCH1." .

ns1:Parametro_fa5bf031fb a ns1:Parametro ;
    rdfs:label "Marca CH1TOMZ" ;
    ns1:identificador "CH1TOMZ" ;
    ns1:textoExtracto "activar la marca CH1TOMZ." .

ns1:Sistema_49b3ea280a a ns1:Sistema ;
    rdfs:label "Almacén de herramientas" ;
    ns1:textoExtracto "Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal." .

