@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaConfiguracionEjes1023 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuración de ejes y cabezales (Sección 10.2.3)"@es ;
    ex:textoExtracto """
| CHAXISNAME | Valor | Índice en el canal. | Orden lógico. |
| --- | --- | --- | --- |
| CHAXISNAME 1 | X | Eje con índice ꞏ1ꞏ. | Número lógico ꞏ1ꞏ. |
| CHAXISNAME 2 | Z | Eje con índice ꞏ2ꞏ. | Número lógico ꞏ2ꞏ.

| CHSPDLNAME | Valor | Índice en el canal. | Orden lógico. |
| --- | --- | --- | --- |
| CHSPDLNAME 1 | S | Cabezal con índice ꞏ1ꞏ. | Número lógico ꞏ3ꞏ.
"""@es ;
    ex:documentadoEn ex:Pagina_561_562 .

ex:EjeX_Canal1_1023
    a ex:ComponenteMecanico ;
    rdfs:label "Eje X (Índice 1, Canal 1)"@es ;
    ex:identificador "X" ;
    ex:valor "1"^^xsd:string ;
    ex:textoExtracto "Eje con índice ꞏ1ꞏ. Número lógico ꞏ1ꞏ. Valor: X"@es ;
    ex:documentadoEn ex:TablaConfiguracionEjes1023 .

ex:EjeZ_Canal1_1023
    a ex:ComponenteMecanico ;
    rdfs:label "Eje Z (Índice 2, Canal 1)"@es ;
    ex:identificador "Z" ;
    ex:valor "2"^^xsd:string ;
    ex:textoExtracto "Eje con índice ꞏ2ꞏ. Número lógico ꞏ2ꞏ. Valor: Z"@es ;
    ex:documentadoEn ex:TablaConfiguracionEjes1023 .

ex:CabezalS_Canal1_1023
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal S (Índice 1, Canal 1)"@es ;
    ex:identificador "S" ;
    ex:valor "3"^^xsd:string ;
    ex:textoExtracto "Cabezal con índice ꞏ1ꞏ. Número lógico ꞏ3ꞏ. Valor: S"@es ;
    ex:documentadoEn ex:TablaConfiguracionEjes1023 .

ex:SistemaPlanoTrabajo_G18_1023
    a ex:Sistema ;
    rdfs:label "Sistema de plano de trabajo G18 (Canal 1, Ejes X-Z)"@es ;
    ex:textoExtracto """
Selección de planos en el canal ꞏ1ꞏ. Con esta configuración, el plano de trabajo siempre es G18 y estará formado por los dos primeros ejes definidos en el canal: X (primer eje) y Z (segundo eje). El plano de trabajo será ZX (eje Z como abscisas y eje X como ordenadas). Las funciones G17 y G19 no son válidas.
"""@es ;
    ex:compuestoPor ex:EjeX_Canal1_1023 ;
    ex:compuestoPor ex:EjeZ_Canal1_1023 ;
    ex:documentadoEn ex:Pagina_561_562 .