@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Fresadora_3Canales_9Ejes_2Cabezales a ex:Maquina ;
    ex:textoExtracto "Fresadora con 3 canales, 9 ejes y 2 cabezales." ;
    ex:compuestoPor ex:Eje_X_1, ex:Eje_Z_2, ex:Cabezal_S_1 .

ex:Eje_X_1 a ex:ComponenteMecanico ;
    ex:identificador "CHAXISNAME 1" ;
    ex:textoExtracto "Eje con índice ꞏ1ꞏ." ;
    ex:valor "X" .

ex:Eje_Z_2 a ex:ComponenteMecanico ;
    ex:identificador "CHAXISNAME 2" ;
    ex:textoExtracto "Eje con índice ꞏ2ꞏ." ;
    ex:valor "Z" .

ex:Cabezal_S_1 a ex:ComponenteMecanico ;
    ex:identificador "CHSPDLNAME 1" ;
    ex:textoExtracto "Cabezal con índice ꞏ1ꞏ." ;
    ex:valor "S" .