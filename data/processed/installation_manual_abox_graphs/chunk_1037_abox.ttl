@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CogerLaHerramientaDelAlmacen a ns1:AccionProhibida ;
    rdfs:label "Coger la herramienta del almacén" ;
    ns1:textoExtracto "1 Coger la herramienta del almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1." .

ns1:CogerLaHerramientaDelCabezal a ns1:AccionProhibida ;
    rdfs:label "Coger la herramienta del cabezal" ;
    ns1:textoExtracto "1 Coger la herramienta del cabezal con la pinza ꞏ1ꞏ y activar la marca SPDLTOCH1." .

ns1:DejarLaHerramientaDelCabezalEnElAlmacenYCogerUnaHerramientaDeOtroAlmacen_84005c662b a ns1:AccionProhibida ;
    rdfs:label "Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén" ;
    ns1:textoExtracto "TMOPERATION = 14 Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén." .

ns1:DejarLaHerramientaEnElAlmacen a ns1:AccionProhibida ;
    rdfs:label "Dejar la herramienta en el almacén" ;
    ns1:textoExtracto "2 Dejar la herramienta de la pinza ꞏ1ꞏ en el almacén y activar la marca CH1TOMZ." .

ns1:DejarLaHerramientaEnElCabezal a ns1:AccionProhibida ;
    rdfs:label "Dejar la herramienta en el cabezal" ;
    ns1:textoExtracto "2 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL." .

ns1:IdentificadorDeAlmacen_8732dee42a a ns1:Parametro ;
    rdfs:label "Identificador de almacén" ;
    ns1:identificador "MZID" ;
    ns1:textoExtracto "En la parte baja de este registro se indica el almacén en el que hay que dejar la herramienta y en la parte alta el almacén del que hay que coger la herramienta." .

ns1:IndicadorDeCambioDeHerramientaATierra a ns1:Parametro ;
    rdfs:label "Indicador de cambio de herramienta a tierra" ;
    ns1:identificador "SPDLTOGR" ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en tierra y activar la marca SPDLTOGR." .

ns1:IndicadorDeCambioDeHerramientaDelCabezal a ns1:Parametro ;
    rdfs:label "Indicador de cambio de herramienta del cabezal" ;
    ns1:identificador "CH1TOSPDL" ;
    ns1:textoExtracto "Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL." .

ns1:IndicadorDeFinalizacionDeOperacion a ns1:Parametro ;
    rdfs:label "Indicador de finalización de operación" ;
    ns1:identificador "MZROT" ;
    ns1:textoExtracto "Activar la marca MZROT para indicar que ha finalizado la operación, se haya orientado el almacén o no." .

ns1:OrientarDosAlmacenes_f35e036c0b a ns1:AccionProhibida ;
    rdfs:label "Orientar dos almacenes" ;
    ns1:textoExtracto "TMOPERATION = 13 Orientar dos almacenes. Esta operación es una optimización del cambio de herramienta que permite orientar dos almacenes durante el mecanizado." .

ns1:OrientarElAlmacen_bce766479d a ns1:AccionProhibida ;
    rdfs:label "Orientar el almacén" ;
    ns1:textoExtracto "TMOPERATION = 11 Orientar el almacén. Esta operación es una optimización del cambio de herramienta que permite orientar el almacén durante el mecanizado." .

