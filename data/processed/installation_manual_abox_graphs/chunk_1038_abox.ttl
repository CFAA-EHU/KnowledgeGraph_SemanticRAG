@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CogerLaHerramientaDelCabezalConLaPinza a ns1:AccionProhibida ;
    rdfs:label "Coger la herramienta del cabezal con la pinza" ;
    ns1:textoExtracto "1 Coger la herramienta del cabezal con la pinza ꞏ1ꞏ y activar la marca SPDLTOCH1." .

ns1:CogerLaHerramientaDelOtroAlmacenConLaPinza a ns1:AccionProhibida ;
    rdfs:label "Coger la herramienta del otro almacén con la pinza" ;
    ns1:textoExtracto "3 Coger la herramienta del otro almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1." .

ns1:DejarLaHerramientaDeLaPinzaEnElAlmacen a ns1:AccionProhibida ;
    rdfs:label "Dejar la herramienta de la pinza en el almacén" ;
    ns1:textoExtracto "2 Dejar la herramienta de la pinza ꞏ1ꞏ en el almacén y activar la marca CH1TOMZ." .

ns1:Parametro_1823548c27 a ns1:Parametro ;
    rdfs:label "Marca para indicar que se ha puesto la herramienta en el cabezal" ;
    ns1:identificador "CH1TOSPDL" ;
    ns1:textoExtracto "4 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL." .

ns1:Parametro_92b7e6b9ba a ns1:Parametro ;
    rdfs:label "Marca para indicar que se ha cogido la herramienta del otro almacén" ;
    ns1:identificador "MZTOCH1" ;
    ns1:textoExtracto "3 Coger la herramienta del otro almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1." .

ns1:Parametro_a3ed774051 a ns1:Parametro ;
    rdfs:label "Marca para indicar que se ha cogido la herramienta del cabezal" ;
    ns1:identificador "SPDLTOCH1" ;
    ns1:textoExtracto "1 Coger la herramienta del cabezal con la pinza ꞏ1ꞏ y activar la marca SPDLTOCH1." .

ns1:Parametro_fa5bf031fb a ns1:Parametro ;
    rdfs:label "Marca para indicar que se ha dejado la herramienta en el almacén" ;
    ns1:identificador "CH1TOMZ" ;
    ns1:textoExtracto "2 Dejar la herramienta de la pinza ꞏ1ꞏ en el almacén y activar la marca CH1TOMZ." .

ns1:PonerLaHerramientaDeLaPinzaEnElCabezal a ns1:AccionProhibida ;
    rdfs:label "Poner la herramienta de la pinza en el cabezal" ;
    ns1:textoExtracto "4 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL." .

