@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ConfiguracionTorno_1024_Canal1
    a               ex:Sistema ;
    ex:identificador "Canal 1 (G18)" ;
    ex:textoExtracto "Configuración general de los canales, ejes y cabezales. | Sistema | Canal ꞏ1ꞏ | NCHANNEL = 1 | GEOCONFIG = Plano | NAXIS = 3 | CHNAXIS = 3 | NSPDL = 1 | CHNSPDL = 1 | IPLANE = G18" ;
    rdfs:label      "Configuración de torno con 1 canal, 3 ejes (X, Z, Y) y 1 cabezal (S) en plano G18" .

ex:Eje_X_Canal1
    a               ex:ComponenteMecanico ;
    ex:identificador "AXISNAME 1" ;
    ex:textoExtracto "AXISNAME 1 | X | Número lógico ꞏ1ꞏ. | Eje con índice ꞏ1ꞏ." ;
    rdfs:label      "Eje X (Canal 1, índice 1)" .

ex:Eje_Z_Canal1
    a               ex:ComponenteMecanico ;
    ex:identificador "AXISNAME 2" ;
    ex:textoExtracto "AXISNAME 2 | Z | Número lógico ꞏ2ꞏ. | Eje con índice ꞏ2ꞏ." ;
    rdfs:label      "Eje Z (Canal 1, índice 2)" .

ex:Eje_Y_Canal1
    a               ex:ComponenteMecanico ;
    ex:identificador "AXISNAME 3" ;
    ex:textoExtracto "AXISNAME 3 | Y | Número lógico ꞏ3ꞏ. | Eje con índice ꞏ3ꞏ." ;
    rdfs:label      "Eje Y (Canal 1, índice 3)" .

ex:Cabezal_S_Canal1
    a               ex:ComponenteMecanico ;
    ex:identificador "SPDLNAME 1" ;
    ex:textoExtracto "SPDLNAME 1 | S | Número lógico ꞏ4ꞏ. | Cabezal con índice ꞏ1ꞏ." ;
    rdfs:label      "Cabezal S (Canal 1, índice 1)" .

ex:ConfiguracionTorno_1024_Canal1
    ex:tieneComponente ex:Eje_X_Canal1 ;
    ex:tieneComponente ex:Eje_Z_Canal1 ;
    ex:tieneComponente ex:Eje_Y_Canal1 ;
    ex:tieneComponente ex:Cabezal_S_Canal1 .