@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Torno_1Canal_3Ejes_1Cabezal a ex:Maquina ;
    ex:textoExtracto "Los ejes y cabezales están distribuidos de la siguiente manera. Canal ꞏ1ꞏ. 3 ejes (X Z Y) 1 cabezal (S). Configuración general de los canales, ejes y cabezales." ;
    ex:identificador "NCHANNEL = 1" ;
    ex:identificador "GEOCONFIG = Plano" ;
    ex:identificador "NAXIS = 3" ;
    ex:identificador "NSPDL = 1" ;
    ex:identificador "CHNAXIS = 3" ;
    ex:identificador "CHNSPDL = 1" ;
    ex:identificador "IPLANE = G18" ;
    ex:tieneComponente ex:Eje_X, ex:Eje_Z, ex:Eje_Y, ex:Cabezal_S .

ex:Eje_X a ex:ComponenteMecanico ;
    ex:textoExtracto "AXISNAME 1 | X | Número lógico ꞏ1ꞏ." ;
    ex:identificador "Número lógico ꞏ1ꞏ" ;
    ex:identificador "Índice en el sistema: " .

ex:Eje_Z a ex:ComponenteMecanico ;
    ex:textoExtracto "AXISNAME 2 | Z | Número lógico ꞏ2ꞏ." ;
    ex:identificador "Número lógico ꞏ2ꞏ" ;
    ex:identificador "Índice en el sistema: " .

ex:Eje_Y a ex:ComponenteMecanico ;
    ex:textoExtracto "AXISNAME 3 | Y | Número lógico ꞏ3ꞏ." ;
    ex:identificador "Número lógico ꞏ3ꞏ" ;
    ex:identificador "Índice en el sistema: " .

ex:Cabezal_S a ex:ComponenteMecanico ;
    ex:textoExtracto "SPDLNAME 1 | S | Número lógico ꞏ4ꞏ. | Cabezal con índice ꞏ1ꞏ." ;
    ex:identificador "Número lógico ꞏ4ꞏ" ;
    ex:identificador "Índice en el sistema: 1" .