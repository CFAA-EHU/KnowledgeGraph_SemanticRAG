@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ConfiguracionEjes_Plano_Torno1Canal3Ejes1Cabezal
    a               ex:ModoOperacion ;
    rdfs:label      "Configuración de ejes tipo plano (G18 ZX) para torno con 1 canal, 3 ejes y 1 cabezal"@es ;
    ex:textoExtracto "Con una configuración de ejes tipo plano, siempre está activo el plano G18; en este caso el plano ZX. Las funciones G17 y G19 no son válidas."@es ;
    ex:identificador "G18" .

ex:Parametro_G18_PlanoZX
    a               ex:Parametro ;
    rdfs:label      "G18 (Plano ZX)"@es ;
    ex:textoExtracto "G18: Plano ZX. Eje Z para la compensación longitudinal."@es ;
    ex:identificador "G18" ;
    ex:monitoreaParametro ex:ConfiguracionEjes_Plano_Torno1Canal3Ejes1Cabezal .

ex:Parametro_G20_CompensacionLongitudinal
    a               ex:Parametro ;
    rdfs:label      "G20 (Selección de eje Y para compensación longitudinal)"@es ;
    ex:textoExtracto "La función G20 permite seleccionar el resto de ejes (eje Y) como eje para la compensación longitudinal."@es ;
    ex:identificador "G20" ;
    ex:monitoreaParametro ex:ConfiguracionEjes_Plano_Torno1Canal3Ejes1Cabezal .

ex:Cabezal_Indice1_Torno
    a               ex:ComponenteMecanico ;
    rdfs:label      "Cabezal con índice 1"@es ;
    ex:textoExtracto "CHSPDLNAME 1: Cabezal con índice ꞏ1ꞏ. Número lógico ꞏ4ꞏ."@es ;
    ex:identificador "CHSPDLNAME_1" ;
    ex:tieneComponente ex:ConfiguracionEjes_Plano_Torno1Canal3Ejes1Cabezal .