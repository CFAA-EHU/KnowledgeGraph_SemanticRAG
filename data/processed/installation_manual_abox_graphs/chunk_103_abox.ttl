@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TablaCompensacionCruzada1 a ex:Parametro ;
    rdfs:label "CROSSCOMP" ;
    ex:textoExtracto "CROSSCOMP Tablas de compensación cruzada. Este parámetro muestra las tablas de compensación cruzada." ;
    ex:valor "n" ;
    ex:textoExtracto "CROSSCOMP n Configuración de las tablas de compensación cruzada." .

ex:TablaCompensacionCruzada2 a ex:Parametro ;
    rdfs:label "COMPAXIS" ;
    ex:textoExtracto "COMPAXIS MOVAXIS POSERROR n POSITION n" .

ex:TablaCompensacionCruzada3 a ex:Parametro ;
    rdfs:label "MOVAXIS" ;
    ex:textoExtracto "COMPAXIS MOVAXIS POSERROR n POSITION n" .

ex:TablaCompensacionCruzada4 a ex:Parametro ;
    rdfs:label "POSERROR" ;
    ex:textoExtracto "COMPAXIS MOVAXIS POSERROR n POSITION n" .

ex:TablaCompensacionCruzada5 a ex:Parametro ;
    rdfs:label "POSITION" ;
    ex:textoExtracto "COMPAXIS MOVAXIS POSERROR n POSITION n" .

ex:SistemaCNC a ex:Sistema ;
    ex:textoExtracto "El CNC calcula la compensación que se debe aplicar a cada eje, teniendo en cuenta el orden en que están definidas las tablas. Aunque por defecto el CNC siempre activa las tablas de compensación cruzada que tiene definidas, estas tablas se pueden deshabilitar desde el PLC mediante la marca DISCROSS." ;
    ex:tieneComponente ex:TablaCompensacionCruzada1, ex:TablaCompensacionCruzada2, ex:TablaCompensacionCruzada3, ex:TablaCompensacionCruzada4, ex:TablaCompensacionCruzada5 .

ex:SistemaPLC a ex:Sistema ;
    ex:textoExtracto "El PLC dispone de una marca para cada tabla; la marca DISCROSS1 es para la tabla 1, DISCROSS2 para la tabla 2 y así sucesivamente." ;
    ex:tieneComponente ex:TablaCompensacionCruzada1, ex:TablaCompensacionCruzada2, ex:TablaCompensacionCruzada3, ex:TablaCompensacionCruzada4, ex:TablaCompensacionCruzada5 .