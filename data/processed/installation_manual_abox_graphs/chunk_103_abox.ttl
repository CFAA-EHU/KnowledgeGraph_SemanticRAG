@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaConfiguracionBusSercos a ns1:Tabla ;
    rdfs:label "Valores recomendados (placa Sercos II)" ;
    ns1:ilustra ns1:CableTipoSFO,
        ns1:CableTipoSFOVflex,
        ns1:CableTipoSFOflex ;
    ns1:textoExtracto "Valores recomendados (placa Sercos II). | SERPOWSE | Longitud del cable. | Tipo de cable recomendado." .

ns1:CableTipoSFO a ns1:ComponenteElectrico ;
    rdfs:label "Cable tipo SFO" ;
    ns1:textoExtracto "Menor de 15 metros. | SFO / SFO-FLEX" .

ns1:CableTipoSFOVflex a ns1:ComponenteElectrico ;
    rdfs:label "Cable tipo SFO-V-FLEX" ;
    ns1:textoExtracto "Mayor de 40 metros. | SFO-V-FLEX" .

ns1:CableTipoSFOflex a ns1:ComponenteElectrico ;
    rdfs:label "Cable tipo SFO-FLEX" ;
    ns1:textoExtracto "Entre 15 y 30 metros. | SFO-FLEX" .

