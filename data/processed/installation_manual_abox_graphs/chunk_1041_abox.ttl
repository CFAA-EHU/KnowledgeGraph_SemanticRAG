@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Torno_ConfiguracionTriedro_1041
    a                       ex:Maquina ;
    rdfs:label              "Torno con 1 canal, 3 ejes y 1 cabezal (configuración triedro)"@es ;
    ex:textoExtracto        "Torno con 1 canal, 3 ejes y 1 cabezal. Configuración de ejes tipo triedro."@es ;
    ex:identificador        "Configuración tipo triedro (G18 por defecto)"@es ;
    ex:tieneComponente      ex:Cabezal_Indice1_1041 ;
    ex:controla             ex:Parametro_IPLANE_1041 .

ex:Cabezal_Indice1_1041
    a                       ex:ComponenteMecanico ;
    rdfs:label              "Cabezal con índice 1"@es ;
    ex:textoExtracto        "Cabezal con índice ꞏ1ꞏ. Número lógico ꞏ4ꞏ. Selección de planos en el canal ꞏ1ꞏ."@es ;
    ex:identificador        "1 (índice cabezal), 4 (número lógico)"@es .

ex:Parametro_IPLANE_1041
    a                       ex:Parametro ;
    rdfs:label              "Parámetro IPLANE (plano habitual de trabajo)"@es ;
    ex:textoExtracto        "el plano habitual de trabajo será G18 (si se ha configurado así en el parámetro IPLANE)"@es ;
    ex:identificador        "IPLANE"@es ;
    ex:valor                 "G18"@es .

ex:Tabla_PlanosTrabajo_1041 a ex:Tabla ;
     a                       ex:Tabla ;
    rdfs:label              "Tabla de selección de planos de trabajo (G17-G20)"@es ;
    ex:textoExtracto        "G17: Plano X-Y. Eje perpendicular Z. G18: Plano Z-X. Eje perpendicular Y. G19: Plano Y-Z. Eje perpendicular X. G20: Cualquier plano y/o eje longitudinal."@es ;
    ex:documentadoEn        ex:Pagina_564_1041 .

ex:Pagina_564_1041
    a                       ex:Pagina ;
    rdfs:label              "Página 564 (Sección 10.2.5)"@es ;
    ex:identificador        "564"@es ;
    ex:textoExtracto        "10.2.5 Torno con 1 canal, 3 ejes y 1 cabezal. Configuración de ejes tipo triedro."@es .