@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioDeHerramienta_ecc5906d9a a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta" ;
    ns1:ejecuta ns1:CabezalTecnico,
        ns1:Componente_42f5d2d2da,
        ns1:Pinza1_b7f3855462,
        ns1:PuntoCambioAutomatico ;
    ns1:textoExtracto "LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal." .

ns1:CabezalTecnico a ns1:Componente ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal." .

ns1:Componente_42f5d2d2da a ns1:Componente ;
    rdfs:label "Almacén de herramientas" ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en el almacén, y coger otra del almacén." .

ns1:Pinza1_b7f3855462 a ns1:Componente ;
    rdfs:label "Pinza 1" ;
    ns1:textoExtracto "Coger la herramienta del cabezal con la pinza 1." .

ns1:PuntoCambioAutomatico a ns1:Componente ;
    rdfs:label "Punto de cambio automático" ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio automático." .

