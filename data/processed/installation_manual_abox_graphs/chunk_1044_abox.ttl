@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Sistema_TornoDobleCanal_ConfiguracionEjes
    a ex:Sistema ;
    rdfs:label "Sistema de torno con 2 canales, 4 ejes y 2 cabezales"@es ;
    ex:textoExtracto "plano. Los ejes y cabezales están distribuidos de la siguiente manera. Canal ꞏ1ꞏ. 2 ejes (X Z) 1 cabezal (S). Canal ꞏ2ꞏ. 2 ejes (X1 Z1) 1 cabezal (S1). Configuración general de los canales, ejes y cabezales."@es ;
    ex:identificador "NCHANNEL=2; NAXIS=4; NSPDL=2" ;
    ex:tieneComponente ex:Canal_1, ex:Canal_2, ex:Eje_X, ex:Eje_Z, ex:Eje_X1, ex:Eje_Z1 ;
    ex:compuestoPor ex:Cabezal_S, ex:Cabezal_S1 .

ex:Canal_1
    a ex:Componente ;
    rdfs:label "Canal 1 (X, Z, S)"@es ;
    ex:textoExtracto "Canal ꞏ1ꞏ. 2 ejes (X Z) 1 cabezal (S)."@es ;
    ex:identificador "CHNAXIS=2; CHNSPDL=1; IPLANE=G18" ;
    ex:tieneComponente ex:Eje_X, ex:Eje_Z ;
    ex:compuestoPor ex:Cabezal_S .

ex:Canal_2
    a ex:Componente ;
    rdfs:label "Canal 2 (X1, Z1, S1)"@es ;
    ex:textoExtracto "Canal ꞏ2ꞏ. 2 ejes (X1 Z1) 1 cabezal (S1)."@es ;
    ex:identificador "CHNAXIS=2; CHNSPDL=1; IPLANE=G18" ;
    ex:tieneComponente ex:Eje_X1, ex:Eje_Z1 ;
    ex:compuestoPor ex:Cabezal_S1 .

ex:Eje_X
    a ex:ComponenteMecanico ;
    rdfs:label "Eje X (Canal 1)"@es ;
    ex:textoExtracto "AXISNAME 1: X | Número lógico ꞏ1ꞏ."@es ;
    ex:identificador "AXISNAME=X; Índice lógico=1" .

ex:Eje_Z
    a ex:ComponenteMecanico ;
    rdfs:label "Eje Z (Canal 1)"@es ;
    ex:textoExtracto "AXISNAME 2: Z | Número lógico ꞏ2ꞏ."@es ;
    ex:identificador "AXISNAME=Z; Índice lógico=2" .

ex:Eje_X1
    a ex:ComponenteMecanico ;
    rdfs:label "Eje X1 (Canal 2)"@es ;
    ex:textoExtracto "AXISNAME 3: X1 | Número lógico ꞏ3ꞏ."@es ;
    ex:identificador "AXISNAME=X1; Índice lógico=3" .

ex:Eje_Z1
    a ex:ComponenteMecanico ;
    rdfs:label "Eje Z1 (Canal 2)"@es ;
    ex:textoExtracto "AXISNAME 4: Z1 | Número lógico ꞏ4ꞏ."@es ;
    ex:identificador "AXISNAME=Z1; Índice lógico=4" .

ex:Cabezal_S
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal S (Canal 1)"@es ;
    ex:textoExtracto "SPDLNAME 1: S | Número lógico ꞏ5ꞏ. Cabezal con índice ꞏ1ꞏ."@es ;
    ex:identificador "SPDLNAME=S; Índice lógico=5; Índice en canal=1" .

ex:Cabezal_S1
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal S1 (Canal 2)"@es ;
    ex:textoExtracto "SPDLNAME 2: S1 | Número lógico ꞏ6ꞏ. Cabezal con índice ꞏ2ꞏ."@es ;
    ex:identificador "SPDLNAME=S1; Índice lógico=6; Índice en canal=2" .

ex:Tabla_ConfiguracionCanales a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuración de canales, ejes y cabezales"@es ;
    ex:textoExtracto "Configuración general de los canales, ejes y cabezales. | Sistema | Canal ꞏ1ꞏ | Canal ꞏ2ꞏ | ... | AXISNAME | Valor | Orden lógico. | Índice en el sistema."@es ;
    ex:documentadoEn ex:Sistema_TornoDobleCanal_ConfiguracionEjes .