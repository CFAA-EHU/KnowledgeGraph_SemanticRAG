@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SistemaTornoCanal1 ex:textoExtracto "Sistema | Canal ꞏ1ꞏ | Canal ꞏ2ꞏ | NCHANNEL = 2 | GEOCONFIG = Plano | GEOCONFIG = Plano | NAXIS = 4 | CHNAXIS = 2 | CHNAXIS = 2 | NSPDL = 2 | CHNSPDL = 1 | CHNSPDL = 1 | IPLANE = G18 | IPLANE = G18 ." ;
    a ex:Sistema ;
    ex:identificador "NCHANNEL = 2" ;
    ex:tieneComponente ex:EjeX, ex:EjeZ, ex:CabezalS .

ex:SistemaTornoCanal2 ex:textoExtracto "Sistema | Canal ꞏ1ꞏ | Canal ꞏ2ꞏ | NCHANNEL = 2 | GEOCONFIG = Plano | GEOCONFIG = Plano | NAXIS = 4 | CHNAXIS = 2 | CHNAXIS = 2 | NSPDL = 2 | CHNSPDL = 1 | CHNSPDL = 1 | IPLANE = G18 | IPLANE = G18 ." ;
    a ex:Sistema ;
    ex:identificador "NCHANNEL = 2" ;
    ex:tieneComponente ex:EjeX1, ex:EjeZ1, ex:CabezalS1 .

ex:EjeX ex:textoExtracto "AXISNAME 1 | X | Número lógico ꞏ1ꞏ." ;
    a ex:ComponenteMecanico ;
    ex:identificador "AXISNAME 1" ;
    ex:valor "X" .

ex:EjeZ ex:textoExtracto "AXISNAME 2 | Z | Número lógico ꞏ2ꞏ." ;
    a ex:ComponenteMecanico ;
    ex:identificador "AXISNAME 2" ;
    ex:valor "Z" .

ex:EjeX1 ex:textoExtracto "AXISNAME 3 | X1 | Número lógico ꞏ3ꞏ." ;
    a ex:ComponenteMecanico ;
    ex:identificador "AXISNAME 3" ;
    ex:valor "X1" .

ex:EjeZ1 ex:textoExtracto "AXISNAME 4 | Z1 | Número lógico ꞏ4ꞏ." ;
    a ex:ComponenteMecanico ;
    ex:identificador "AXISNAME 4" ;
    ex:valor "Z1" .

ex:CabezalS ex:textoExtracto "SPDLNAME 1 | S | Número lógico ꞏ5ꞏ. | Cabezal con índice ꞏ1ꞏ." ;
    a ex:ComponenteMecanico ;
    ex:identificador "SPDLNAME 1" ;
    ex:valor "S" .

ex:CabezalS1 ex:textoExtracto "SPDLNAME 2 | S1 | Número lógico ꞏ6ꞏ. | Cabezal con índice ꞏ2ꞏ." ;
    a ex:ComponenteMecanico ;
    ex:identificador "SPDLNAME 2" ;
    ex:valor "S1" .