@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnalisisDelTipoDeOperacion a ns1:AccionProhibida ;
    rdfs:label "Análisis del tipo de operación" ;
    ns1:textoExtracto "$ENDSWITCH ; Fin análisis del tipo de operación." .

ns1:CambioManualDeHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Cambio manual de herramienta" ;
    ns1:textoExtracto "cambio manual. LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal." .

ns1:HabilitarLaTeclaSTOP a ns1:AccionProhibida ;
    rdfs:label "Habilitar la tecla STOP" ;
    ns1:textoExtracto "# ESTOP ; Habilitar la tecla STOP." .

ns1:SistemaGestorAlmacen a ns1:Sistema ;
    rdfs:label "Sistema Gestor Almacén" ;
    ns1:textoExtracto "$WHILE V.TM.MZWAIT == 1 $ENDWHILE ; Espera al gestor del almacén." .

