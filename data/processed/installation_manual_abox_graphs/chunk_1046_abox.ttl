@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Torno_2Canales_4Ejes_2Cabezales a ex:Maquina ;
    ex:textoExtracto "Torno con 2 canales, 4 ejes y 2 cabezales. Configuración de ejes tipo"@es ;
    ex:tieneComponente ex:Eje_X, ex:Eje_Z, ex:PlanoTrabajo_G18, ex:Canal_1, ex:Canal_2, ex:Cabezal_1 .

ex:Eje_X a ex:ComponenteMecanico ;
    ex:textoExtracto "eje X (primer eje del canal)"@es ;
    ex:identificador "X" ;
    ex:valor "primer eje del canal"@es .

ex:Eje_Z a ex:ComponenteMecanico ;
    ex:textoExtracto "eje Z (segundo eje del canal)"@es ;
    ex:identificador "Z" ;
    ex:valor "segundo eje del canal"@es .

ex:PlanoTrabajo_G18 a ex:Parametro ;
    ex:textoExtracto "el plano de trabajo siempre es G18 y estará formado por los dos primeros ejes definidos en el canal"@es ;
    ex:identificador "G18" ;
    ex:valor "plano de trabajo ZX (eje Z como abscisas y eje X como ordenadas)"@es .

ex:Canal_1 a ex:Sistema ;
    ex:textoExtracto "Selección de planos en el canal ꞏ1ꞏ"@es ;
    ex:identificador "1" .

ex:Canal_2 a ex:Sistema ;
    ex:textoExtracto "Selección de planos en el canal ꞏ2ꞏ"@es ;
    ex:identificador "2" .

ex:Cabezal_1 a ex:ComponenteMecanico ;
    ex:textoExtracto "Cabezal con índice ꞏ1ꞏ"@es ;
    ex:identificador "1" ;
    ex:valor "Número lógico ꞏ6ꞏ"@es .