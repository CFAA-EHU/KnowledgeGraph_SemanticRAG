@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CodigoDeOperacionDelGestorParaElPLC a ns1:Parametro ;
    rdfs:label "Código de operación del gestor para el PLC" ;
    ns1:identificador "TMOPERATION" ;
    ns1:textoExtracto "el gestor envía al PLC el código TMOPERATION=11." .

ns1:Parametro_1823548c27 a ns1:Parametro ;
    rdfs:label "Marca para movimiento de herramienta desde pinza 1 al cabezal" ;
    ns1:identificador "CH1TOSPDL" ;
    ns1:textoExtracto "DFU M1102 = SET CH1TOSPDL DFD CH1TOSPDL = RES M1102 La herramienta se ha llevado de la pinza 1 al cabezal." .

ns1:Parametro_7959033478 a ns1:Parametro ;
    rdfs:label "Marca para movimiento de herramienta desde tierra al cabezal" ;
    ns1:identificador "GRTOSPDL" ;
    ns1:textoExtracto "DFU M1108 = SET GRTOSPDL DFD GRTOSPDL = RES M1108 La herramienta se ha llevado de tierra al cabezal." .

ns1:Parametro_92b7e6b9ba a ns1:Parametro ;
    rdfs:label "Marca correspondiente del gestor para herramienta en pinza 1" ;
    ns1:identificador "MZTOCH1" ;
    ns1:textoExtracto "DFU M1101 = SET MZTOCH1 DFD MZTOCH1 = RES M1101 La herramienta se ha llevado del almacén a la pinza 1." .

ns1:Parametro_94a80a9622 a ns1:Parametro ;
    rdfs:label "Marca que indica finalización de operación" ;
    ns1:identificador "MZROT" ;
    ns1:textoExtracto "activar la marca MZROT para indicar al gestor que se ha finalizado la operación." .

ns1:Parametro_a3ed774051 a ns1:Parametro ;
    rdfs:label "Marca para movimiento de herramienta desde el cabezal a la pinza 1" ;
    ns1:identificador "SPDLTOCH1" ;
    ns1:textoExtracto "DFU M1103 = SET SPDLTOCH1 DFD SPDLTOCH1 = RES M1103 La herramienta se ha llevado del cabezal a la pinza 1." .

ns1:Parametro_aed1a67bbe a ns1:Parametro ;
    rdfs:label "Marca para movimiento de herramienta desde el cabezal a tierra" ;
    ns1:identificador "SPDLTOGR" ;
    ns1:textoExtracto "DFU M1107 = SET SPDLTOGR DFD SPDLTOGR = RES M1107 La herramienta se ha llevado del cabezal a tierra." .

ns1:Parametro_fa5bf031fb a ns1:Parametro ;
    rdfs:label "Marca para movimiento de herramienta desde la pinza 1 al almacén" ;
    ns1:identificador "CH1TOMZ" ;
    ns1:textoExtracto "DFU M1105 = SET CH1TOMZ DFD CH1TOMZ = RES M1105 La herramienta se ha llevado de la pinza 1 al almacén." .

