@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Torno_3Canales_6Ejes_2Cabezales a ex:Maquina ;
    ex:textoExtracto "plano. Los ejes y cabezales están distribuidos de la siguiente manera. Canal ꞏ1ꞏ. 2 ejes (X Z) 1 cabezal (S). Canal ꞏ2ꞏ. 2 ejes (X1 Z1) 1 cabezal (S1). Canal ꞏ3ꞏ. 2 ejes (U V) Configuración general de los canales, ejes y cabezales. | Sistema | Canal ꞏ1ꞏ | Canal ꞏ2ꞏ | Canal ꞏ3ꞏ | | --- | --- | --- | --- | | NCHANNEL = 3 | GEOCONFIG = Plano | GEOCONFIG = Plano | | NAXIS = 6 | CHNAXIS = 2 | CHNAXIS = 2 | CHNAXIS = 2 | | NSPDL = 2 | CHNSPDL = 1 | CHNSPDL = 1 | CHNSPDL = 0 | |  | IPLANE = G18 | IPLANE = G18 | | Configuración de los ejes y cabezales del sistema. | AXISNAME | Valor | Orden lógico. | Índice en el sistema." ;
    ex:tieneComponente ex:Canal_1, ex:Canal_2, ex:Canal_3 .

ex:Canal_1 a ex:Sistema ;
    ex:textoExtracto "Canal ꞏ1ꞏ. 2 ejes (X Z) 1 cabezal (S). | Sistema | Canal ꞏ1ꞏ | ... | CHNAXIS = 2 | CHNSPDL = 1 | IPLANE = G18" ;
    ex:identificador "Canal 1" ;
    ex:compuestoPor ex:Eje_X, ex:Eje_Z, ex:Cabezal_S ;
    ex:valor "GEOCONFIG = Plano, CHNAXIS = 2, CHNSPDL = 1, IPLANE = G18" .

ex:Canal_2 a ex:Sistema ;
    ex:textoExtracto "Canal ꞏ2ꞏ. 2 ejes (X1 Z1) 1 cabezal (S1). | Sistema | ... | Canal ꞏ2ꞏ | ... | CHNAXIS = 2 | CHNSPDL = 1 | IPLANE = G18" ;
    ex:identificador "Canal 2" ;
    ex:compuestoPor ex:Eje_X1, ex:Eje_Z1, ex:Cabezal_S1 ;
    ex:valor "GEOCONFIG = Plano, CHNAXIS = 2, CHNSPDL = 1, IPLANE = G18" .

ex:Canal_3 a ex:Sistema ;
    ex:textoExtracto "Canal ꞏ3ꞏ. 2 ejes (U V) | Sistema | ... | Canal ꞏ3ꞏ | ... | CHNAXIS = 2 | CHNSPDL = 0" ;
    ex:identificador "Canal 3" ;
    ex:compuestoPor ex:Eje_U, ex:Eje_V ;
    ex:valor "CHNAXIS = 2, CHNSPDL = 0" .

ex:Eje_X a ex:ComponenteMecanico ;
    ex:textoExtracto "2 ejes (X Z)" ;
    ex:identificador "X" .

ex:Eje_Z a ex:ComponenteMecanico ;
    ex:textoExtracto "2 ejes (X Z)" ;
    ex:identificador "Z" .

ex:Eje_X1 a ex:ComponenteMecanico ;
    ex:textoExtracto "2 ejes (X1 Z1)" ;
    ex:identificador "X1" .

ex:Eje_Z1 a ex:ComponenteMecanico ;
    ex:textoExtracto "2 ejes (X1 Z1)" ;
    ex:identificador "Z1" .

ex:Eje_U a ex:ComponenteMecanico ;
    ex:textoExtracto "2 ejes (U V)" ;
    ex:identificador "U" .

ex:Eje_V a ex:ComponenteMecanico ;
    ex:textoExtracto "2 ejes (U V)" ;
    ex:identificador "V" .

ex:Cabezal_S a ex:ComponenteMecanico ;
    ex:textoExtracto "1 cabezal (S)" ;
    ex:identificador "S" .

ex:Cabezal_S1 a ex:ComponenteMecanico ;
    ex:textoExtracto "1 cabezal (S1)" ;
    ex:identificador "S1" .