@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Torno_3Canales_6Ejes_2Cabezales a ex:Maquina ;
    ex:textoExtracto "Torno con 3 canales, 6 ejes y 2 cabezales. Configuración de ejes tipo"@es ;
    ex:tieneComponente ex:Eje_X, ex:Eje_Z, ex:Eje_X1, ex:Eje_Z1, ex:Eje_U, ex:Eje_V, ex:Cabezal_S, ex:Cabezal_S1 .

ex:Eje_X a ex:ComponenteMecanico ;
    ex:identificador "AXISNAME 1" ;
    ex:textoExtracto "AXISNAME 1 | X | Número lógico ꞏ1ꞏ."@es .

ex:Eje_Z a ex:ComponenteMecanico ;
    ex:identificador "AXISNAME 2" ;
    ex:textoExtracto "AXISNAME 2 | Z | Número lógico ꞏ2ꞏ."@es .

ex:Eje_X1 a ex:ComponenteMecanico ;
    ex:identificador "AXISNAME 3" ;
    ex:textoExtracto "AXISNAME 3 | X1 | Número lógico ꞏ3ꞏ."@es .

ex:Eje_Z1 a ex:ComponenteMecanico ;
    ex:identificador "AXISNAME 4" ;
    ex:textoExtracto "AXISNAME 4 | Z1 | Número lógico ꞏ4ꞏ."@es .

ex:Eje_U a ex:ComponenteMecanico ;
    ex:identificador "AXISNAME 5" ;
    ex:textoExtracto "AXISNAME 5 | U | Número lógico ꞏ5ꞏ."@es .

ex:Eje_V a ex:ComponenteMecanico ;
    ex:identificador "AXISNAME 6" ;
    ex:textoExtracto "AXISNAME 6 | V | Número lógico ꞏ6ꞏ."@es .

ex:Cabezal_S a ex:ComponenteMecanico ;
    ex:identificador "SPDLNAME 1" ;
    ex:textoExtracto "SPDLNAME 1 | S | Número lógico ꞏ7ꞏ. Cabezal con índice ꞏ1ꞏ."@es .

ex:Cabezal_S1 a ex:ComponenteMecanico ;
    ex:identificador "SPDLNAME 2" ;
    ex:textoExtracto "SPDLNAME 2 | S1 | Número lógico ꞏ8ꞏ. Cabezal con índice ꞏ2ꞏ."@es .