@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Torno_3Canales_6Ejes_2Cabezales a ex:Maquina ;
    ex:textoExtracto "Torno con 3 canales, 6 ejes y 2 cabezales. Configuración de ejes tipo" ;
    ex:tieneComponente ex:Eje_X1, ex:Eje_Z1, ex:Cabezal_S1 .

ex:Eje_X1 a ex:ComponenteMecanico ;
    ex:identificador "X1" ;
    ex:textoExtracto "Eje con índice ꞏ1ꞏ. Número lógico ꞏ3ꞏ." .

ex:Eje_Z1 a ex:ComponenteMecanico ;
    ex:identificador "Z1" ;
    ex:textoExtracto "Eje con índice ꞏ2ꞏ. Número lógico ꞏ4ꞏ." .

ex:Cabezal_S1 a ex:ComponenteMecanico ;
    ex:identificador "S1" ;
    ex:textoExtracto "Cabezal con índice ꞏ1ꞏ. Número lógico ꞏ8ꞏ." .