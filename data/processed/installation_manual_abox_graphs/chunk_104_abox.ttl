@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_da684d1dc3 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC no realiza ningún proceso de homogeneización de parámetros con los reguladores Mechatrolink." .

ns1:ModoMechatrolink a ns1:Parametro ;
    rdfs:label "Modo Mechatrolink" ;
    ns1:identificador "MPG.MLINK" ;
    ns1:textoExtracto "Este parámetro permite configurar el bus Mechatrolink en modo Mlink-I o Mlink-II." .

ns1:TamanoDelTelegramaEnElModoMlinkII a ns1:Parametro ;
    rdfs:label "Tamaño del telegrama en el modo Mlink-II" ;
    ns1:identificador "MPG.DATASIZE" ;
    ns1:textoExtracto "Este parámetro define el tamaño del telegrama para el modo Mlink-II." .

