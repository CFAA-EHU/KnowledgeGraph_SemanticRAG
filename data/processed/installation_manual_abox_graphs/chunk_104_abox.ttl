@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TablaCompensacionCruzada_104 a ex:Tabla ;
    ex:textoExtracto "CROSSCOMP |  |" ;
    ex:tieneComponente ex:MOVAXIS_104, ex:COMPAXIS_104, ex:NPCROSS_104, ex:TYPCROSS_104, ex:BIDIR_104, ex:REFNEED_104, ex:DATA_104 .

ex:MOVAXIS_104 a ex:Parametro ;
    ex:textoExtracto "MOVAXIS | Eje que al moverse genera variaciones (maestro)." .

ex:COMPAXIS_104 a ex:Parametro ;
    ex:textoExtracto "COMPAXIS | Eje que sufre variaciones (compensado)." .

ex:NPCROSS_104 a ex:Parametro ;
    ex:textoExtracto "NPCROSS | Número de puntos de la tabla." .

ex:TYPCROSS_104 a ex:Parametro ;
    ex:textoExtracto "TYPCROSS | Método de compensación." .

ex:BIDIR_104 a ex:Parametro ;
    ex:textoExtracto "BIDIR | Compensación bidireccional." .

ex:REFNEED_104 a ex:Parametro ;
    ex:textoExtracto "REFNEED | Búsqueda de referencia necesaria para compensar." .

ex:DATA_104 a ex:Tabla ;
    ex:textoExtracto "DATA | Tabla para definir los valores de compensación." .