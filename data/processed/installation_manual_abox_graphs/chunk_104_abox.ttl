@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaCompensacionCruzada_104 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de compensación cruzada (CROSSCOMP)"@es ;
    ex:textoExtracto """
| CROSSCOMP |  |
| --- | --- |
| MOVAXIS | Eje que al moverse genera variaciones (maestro). |
| COMPAXIS | Eje que sufre variaciones (compensado). |
| NPCROSS | Número de puntos de la tabla. |
| TYPCROSS | Método de compensación. |
| BIDIR | Compensación bidireccional. |
| REFNEED | Búsqueda de referencia necesaria para compensar. |
| DATA | Tabla para definir los valores de compensación.
"""@es ;
    ex:tieneComponente ex:Parametro_MOVAXIS_104, ex:Parametro_COMPAXIS_104, ex:Parametro_NPCROSS_104,
                      ex:Parametro_TYPCROSS_104, ex:Parametro_BIDIR_104, ex:Parametro_REFNEED_104,
                      ex:Parametro_DATA_104 .

ex:Parametro_MOVAXIS_104
    a ex:Parametro ;
    rdfs:label "MOVAXIS"@es ;
    ex:identificador "MOVAXIS" ;
    ex:textoExtracto "Eje que al moverse genera variaciones (maestro)."@es .

ex:Parametro_COMPAXIS_104
    a ex:Parametro ;
    rdfs:label "COMPAXIS"@es ;
    ex:identificador "COMPAXIS" ;
    ex:textoExtracto "Eje que sufre variaciones (compensado)."@es .

ex:Parametro_NPCROSS_104
    a ex:Parametro ;
    rdfs:label "NPCROSS"@es ;
    ex:identificador "NPCROSS" ;
    ex:textoExtracto "Número de puntos de la tabla."@es .

ex:Parametro_TYPCROSS_104
    a ex:Parametro ;
    rdfs:label "TYPCROSS"@es ;
    ex:identificador "TYPCROSS" ;
    ex:textoExtracto "Método de compensación."@es .

ex:Parametro_BIDIR_104
    a ex:Parametro ;
    rdfs:label "BIDIR"@es ;
    ex:identificador "BIDIR" ;
    ex:textoExtracto "Compensación bidireccional."@es .

ex:Parametro_REFNEED_104
    a ex:Parametro ;
    rdfs:label "REFNEED"@es ;
    ex:identificador "REFNEED" ;
    ex:textoExtracto "Búsqueda de referencia necesaria para compensar."@es .

ex:Parametro_DATA_104
    a ex:Parametro ;
    rdfs:label "DATA"@es ;
    ex:identificador "DATA" ;
    ex:textoExtracto "Tabla para definir los valores de compensación."@es .