@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Torno_3Canales_6Ejes_2Cabezales a ex:Maquina ;
    ex:textoExtracto "Torno con 3 canales, 6 ejes y 2 cabezales. Configuración de ejes tipo" ;
    ex:tieneComponente ex:Eje_U, ex:Eje_V .

ex:Eje_U a ex:ComponenteMecanico ;
    ex:identificador "CHAXISNAME 1" ;
    ex:textoExtracto "Eje con índice ꞏ1ꞏ. Número lógico ꞏ5ꞏ." ;
    ex:valor "U" .

ex:Eje_V a ex:ComponenteMecanico ;
    ex:identificador "CHAXISNAME 2" ;
    ex:textoExtracto "Eje con índice ꞏ2ꞏ. Número lógico ꞏ6ꞏ." ;
    ex:valor "V" .