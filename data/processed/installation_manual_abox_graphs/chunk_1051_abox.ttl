@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EjeRotativoLinearlike a ex:ModoOperacion ;
    rdfs:label "Eje rotativo linearlike" ;
    ex:textoExtracto "El eje se comporta como un eje lineal, pero las unidades de programación son grados. El CNC visualiza las cotas entre los límites de recorrido." .

ex:ParametroLIMITmas a ex:Parametro ;
    rdfs:label "LIMIT+" ;
    ex:textoExtracto "Los parámetros máquina LIMIT+ y LIMIT- establecen los límites de recorrido del eje; no hay límites de módulo." .

ex:ParametroLIMITmenos a ex:Parametro ;
    rdfs:label "LIMIT-" ;
    ex:textoExtracto "Los parámetros máquina LIMIT+ y LIMIT- establecen los límites de recorrido del eje; no hay límites de módulo." .

ex:ParametroAXISTYPE a ex:Parametro ;
    rdfs:label "AXISTYPE" ;
    ex:textoExtracto "Parámetro. | Valor. | AXISTYPE | Rotativo." .

ex:ParametroAXISMODE a ex:Parametro ;
    rdfs:label "AXISMODE" ;
    ex:textoExtracto "Parámetro. | Valor. | AXISMODE | Linearlike." .

ex:ParametroUNIDIR a ex:Parametro ;
    rdfs:label "UNIDIR" ;
    ex:textoExtracto "Parámetro. | Valor. | UNIDIR | Sin función." .

ex:ParametroSHORTESTWAY a ex:Parametro ;
    rdfs:label "SHORTESTWAY" ;
    ex:textoExtracto "Parámetro. | Valor. | SHORTESTWAY | Sin función." .

ex:ParametroMODUPLIM a ex:Parametro ;
    rdfs:label "MODUPLIM" ;
    ex:textoExtracto "Parámetro. | Valor. | MODUPLIM | Sin función." .

ex:ParametroMODLOWLIM a ex:Parametro ;
    rdfs:label "MODLOWLIM" ;
    ex:textoExtracto "Parámetro. | Valor. | MODLOWLIM | Sin función." .

ex:ConfiguracionParametrosMaquina a ex:Tabla ;
    ex:textoExtracto "Configuración de los parámetros máquina. Los parámetros máquina LIMIT+ y LIMIT- establecen los límites de recorrido del eje; no hay límites de módulo. | Parámetro. | Valor. | AXISTYPE | Rotativo. | AXISMODE | Linearlike. | UNIDIR | Sin función. | SHORTESTWAY | Sin función. | LIMIT+ | Límites de recorrido. | LIMIT- | Límites de recorrido. | MODUPLIM | Sin función. | MODLOWLIM | Sin función." ;
    ex:tieneComponente ex:ParametroLIMITmas, ex:ParametroLIMITmenos, ex:ParametroAXISTYPE, ex:ParametroAXISMODE, ex:ParametroUNIDIR, ex:ParametroSHORTESTWAY, ex:ParametroMODUPLIM, ex:ParametroMODLOWLIM .