@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MovimientoIncrementalNormal
    a ex:Parametro ;
    rdfs:label "Movimiento incremental normal"@es ;
    ex:textoExtracto "Movimiento incremental normal. El signo de la cota indica el sentido del desplazamiento; el valor absoluto de la cota indica el incremento de posición."@es ;
    ex:valor "signo: sentido; valor absoluto: incremento de posición"@es .

ex:ModoOperacion_EjeRotativoUnVuelta
    a ex:ModoOperacion ;
    rdfs:label "Modo de operación: eje rotativo (1 vuelta máxima)"@es ;
    ex:textoExtracto "Aunque el desplazamiento programado sea superior al módulo, el eje nunca da más de una vuelta."@es .

ex:ModoOperacion_EjeRotativoMultiVuelta
    a ex:ModoOperacion ;
    rdfs:label "Modo de operación: eje rotativo (múltiples vueltas)"@es ;
    ex:textoExtracto "Si el desplazamiento programado es superior al módulo, el eje da más de una vuelta."@es .