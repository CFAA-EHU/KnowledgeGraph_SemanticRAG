@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MovimientoIncrementalNormal a ex:Parametro ;
    rdfs:label "Movimiento incremental normal"@es ;
    ex:textoExtracto "El signo de la cota indica el sentido del desplazamiento; el valor absoluto de la cota indica el incremento de posición."@es .

ex:DesplazamientoProgramado a ex:Parametro ;
    rdfs:label "Desplazamiento programado"@es ;
    ex:textoExtracto "Aunque el desplazamiento programado sea superior al módulo, el eje nunca da más de una vuelta."@es .

ex:ModuloEje a ex:Parametro ;
    rdfs:label "Módulo"@es ;
    ex:textoExtracto "Si el desplazamiento programado es superior al módulo, el eje da más de una vuelta."@es .