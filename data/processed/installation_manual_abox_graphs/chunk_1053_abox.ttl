@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ParametroAXISTYPE a ex:Parametro ;
    ex:identificador "AXISTYPE" ;
    ex:valor "Rotativo" ;
    ex:textoExtracto "AXISTYPE | Rotativo." .

ex:ParametroAXISMODE a ex:Parametro ;
    ex:identificador "AXISMODE" ;
    ex:valor "Módulo" ;
    ex:textoExtracto "AXISMODE | Módulo." .

ex:ParametroUNIDIR a ex:Parametro ;
    ex:identificador "UNIDIR" ;
    ex:valor "Positivo / Negativo" ;
    ex:textoExtracto "UNIDIR | Positivo / Negativo." .

ex:ParametroSHORTESTWAY a ex:Parametro ;
    ex:identificador "SHORTESTWAY" ;
    ex:valor "No" ;
    ex:textoExtracto "SHORTESTWAY | No." .

ex:ParametroLIMIT a ex:Parametro ;
    ex:identificador "LIMIT+" ;
    ex:valor "Sin función. No hay límites de recorrido." ;
    ex:textoExtracto "LIMIT+ | Sin función. No hay límites de recorrido." .

ex:ParametroLIMIT a ex:Parametro ;
    ex:identificador "LIMIT-" ;
    ex:valor "Sin función. No hay límites de recorrido." ;
    ex:textoExtracto "LIMIT- | Sin función. No hay límites de recorrido." .

ex:ParametroMODUPLIM a ex:Parametro ;
    ex:identificador "MODUPLIM" ;
    ex:valor "Límites del módulo. Límites para visualizar las cotas." ;
    ex:textoExtracto "MODUPLIM | Límites del módulo. Límites para visualizar las cotas." .

ex:ParametroMODLOWLIM a ex:Parametro ;
    ex:identificador "MODLOWLIM" ;
    ex:valor "Límites del módulo. Límites para visualizar las cotas." ;
    ex:textoExtracto "MODLOWLIM | Límites del módulo. Límites para visualizar las cotas." .

ex:ParametroUNIDIRRotativo a ex:Parametro ;
    ex:identificador "UNIDIR" ;
    ex:valor "No" ;
    ex:textoExtracto "UNIDIR | No." .

ex:ParametroSHORTESTWAYRotativo a ex:Parametro ;
    ex:identificador "SHORTESTWAY" ;
    ex:valor "No" ;
    ex:textoExtracto "SHORTESTWAY | No." .

ex:ModoOperacionRotativo a ex:ModoOperacion ;
    ex:identificador "Rotativo" ;
    ex:textoExtracto "Eje rotativo unidireccional. Este tipo de eje rotativo sólo se desplaza en un sentido, el que tiene predeterminado." .

ex:ModoOperacionModulo a ex:ModoOperacion ;
    ex:identificador "Módulo" ;
    ex:textoExtracto "Parámetros máquina MODUPLIM y MODLOWLIM establecen los límites del módulo del eje; no hay límites de recorrido." .