@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EjeRotativoPosicionamiento_1054 a ex:Maquina ;
    rdfs:label "Eje rotativo de posicionamiento" ;
    ex:textoExtracto "Eje rotativo de posicionamiento. Este tipo de eje rotativo se puede desplazar en ambos sentidos, pero en los movimientos absolutos se desplaza por el camino más corto. El CNC visualiza las cotas entre los límites del módulo." ;
    ex:identificador "UNIDIR" ;
    ex:identificador "SHORTESTWAY" ;
    ex:identificador "LIMIT+" ;
    ex:identificador "LIMIT-" ;
    ex:identificador "MODUPLIM" ;
    ex:identificador "MODLOWLIM" .