@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_UNIDIR
    a ex:Parametro ;
    rdfs:label "UNIDIR" ;
    ex:textoExtracto "UNIDIR | Positivo / Negativo." ;
    ex:valor "Positivo/Negativo" .

ex:Parametro_SHORTESTWAY
    a ex:Parametro ;
    rdfs:label "SHORTESTWAY" ;
    ex:textoExtracto "SHORTESTWAY | No." ;
    ex:valor "No" .

ex:Parametro_MODUPLIM
    a ex:Parametro ;
    rdfs:label "MODUPLIM" ;
    ex:textoExtracto "MODUPLIM | Límites del módulo. Límites para visualizar las cotas." ;
    ex:valor "Límite superior del módulo" .

ex:Parametro_MODLOWLIM
    a ex:Parametro ;
    rdfs:label "MODLOWLIM" ;
    ex:textoExtracto "MODLOWLIM | Límites del módulo. Límites para visualizar las cotas." ;
    ex:valor "Límite inferior del módulo" .

ex:ModoOperacion_EjeRotativoPosicionamiento
    a ex:ModoOperacion ;
    rdfs:label "Eje rotativo de posicionamiento" ;
    ex:textoExtracto "Eje rotativo de posicionamiento. Este tipo de eje rotativo se puede desplazar en ambos sentidos, pero en los movimientos absolutos se desplaza por el camino más corto. El CNC visualiza las cotas entre los límites del módulo." ;
    ex:tieneComponente ex:Parametro_UNIDIR ;
    ex:tieneComponente ex:Parametro_SHORTESTWAY ;
    ex:tieneComponente ex:Parametro_MODUPLIM ;
    ex:tieneComponente ex:Parametro_MODLOWLIM .