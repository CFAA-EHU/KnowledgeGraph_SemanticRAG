@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EjeTandemMaestro1056 a ex:Maquina ;
    rdfs:label "eje tándem maestro" ;
    ex:textoExtracto "Un eje tándem consiste en dos motores acoplados mecánicamente entre sí formando un único sistema de transmisión (eje o cabezal). En el CNC sólo se visualiza y se programa un eje (eje tándem maestro)." .

ex:EjeTandemEsclavo1056 a ex:Maquina ;
    rdfs:label "eje tándem esclavo" ;
    ex:textoExtracto "El otro eje (eje tándem esclavo) no se visualiza y no es programable; es controlado por el CNC." .

ex:MotorPrincipal1056 a ex:ComponenteMecanico ;
    rdfs:label "motor principal" ;
    ex:textoExtracto "Un eje tándem consiste en dos motores acoplados mecánicamente entre sí formando un único sistema de transmisión (eje o cabezal)." .

ex:MotorEsclavo1056 a ex:ComponenteMecanico ;
    rdfs:label "motor esclavo" ;
    ex:textoExtracto "Un eje tándem consiste en dos motores acoplados mecánicamente entre sí formando un único sistema de transmisión (eje o cabezal)." .

ex:SistemaTransmisionTandem1056 a ex:Sistema ;
    rdfs:label "sistema de transmisión tándem" ;
    ex:compuestoPor ex:EjeTandemMaestro1056, ex:EjeTandemEsclavo1056 ;
    ex:textoExtracto "Un eje tándem consiste en dos motores acoplados mecánicamente entre sí formando un único sistema de transmisión (eje o cabezal)." .

ex:Piñon1056 a ex:ComponenteMecanico ;
    rdfs:label "piñón" ;
    ex:textoExtracto "Ejemplo de un eje tándem compuesto por dos piñones y una cremallera." .

ex:Cremallera1056 a ex:ComponenteMecanico ;
    rdfs:label "cremallera" ;
    ex:textoExtracto "Ejemplo de un eje tándem compuesto por dos piñones y una cremallera." .

ex:SistemaPiñonCremallera1056 a ex:Sistema ;
    rdfs:label "sistema piñón-cremallera" ;
    ex:compuestoPor ex:Piñon1056, ex:Cremallera1056 ;
    ex:textoExtracto "Ejemplo de un eje tándem compuesto por dos piñones y una cremallera." .

ex:EjeGantry1056 a ex:Maquina ;
    rdfs:label "eje gantry" ;
    ex:textoExtracto "Una de las muchas aplicaciones de las que dispone el control de eje tándem se asocia a máquinas gantry. En el siguiente ejemplo se puede ver un eje gantry con dos ejes tándem." .

ex:ParPrecarga1056 a ex:Parametro ;
    rdfs:label "par de precarga" ;
    ex:textoExtracto "La aplicación de un par de precarga entre el motor principal y el motor esclavo reduce la holgura (backlash) piñón - cremallera." .