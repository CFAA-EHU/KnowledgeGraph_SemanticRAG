@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:OperacionDelAlmacen a ns1:TareaMantenimiento ;
    rdfs:label "Operación del almacén" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_b751aa7107 ;
    ns1:textoExtracto "2 Coger la herramienta del almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1. 3 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ. 4 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL." .

ns1:Parametro_1823548c27 a ns1:Parametro ;
    rdfs:label "Marca CH1TOSPDL" ;
    ns1:identificador "CH1TOSPDL" ;
    ns1:textoExtracto "4 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL." .

ns1:Parametro_63e02acfc4 a ns1:Parametro ;
    rdfs:label "Marca CH2TOMZ" ;
    ns1:identificador "CH2TOMZ" ;
    ns1:textoExtracto "3 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ." .

ns1:Parametro_92b7e6b9ba a ns1:Parametro ;
    rdfs:label "Marca MZTOCH1" ;
    ns1:identificador "MZTOCH1" ;
    ns1:textoExtracto "2 Coger la herramienta del almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1." .

ns1:DiagnosticoFallo_b751aa7107 a ns1:DiagnosticoFallo ;
    rdfs:label "Herramienta incorrecta" ;
    ns1:textoExtracto "La secuencia de esta operación es la siguiente. El gestor también admite la secuencia 1-3-2." .

