@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_AXISEXCH a ex:Parametro ;
    rdfs:label "AXISEXCH" ;
    ex:textoExtracto "El permiso de cambio de canal (parámetro AXISEXCH)" .

ex:Parametro_LIMIT a ex:Parametro ;
    rdfs:label "LIMIT" ;
    ex:textoExtracto "límites de software (parámetros LIMIT+ y LIMIT-)" .

ex:Parametro_AXISMODE a ex:Parametro ;
    rdfs:label "AXISMODE" ;
    ex:textoExtracto "parámetros AXISMODE" .

ex:Parametro_SHORTESTWAY a ex:Parametro ;
    rdfs:label "SHORTESTWAY" ;
    ex:textoExtracto "parámetros SHORTESTWAY" .