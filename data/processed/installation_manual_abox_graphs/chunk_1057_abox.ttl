@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_AXISEXCH
    a ex:Parametro ;
    rdfs:label "Parámetro AXISEXCH (permiso de cambio de canal)"@es ;
    ex:textoExtracto "El permiso de cambio de canal (parámetro AXISEXCH) deberá ser igual en ambos ejes."@es ;
    ex:identificador "AXISEXCH" .

ex:Parametro_LIMIT
    a ex:Parametro ;
    rdfs:label "Parámetro LIMIT+ (límite de software positivo)"@es ;
    ex:textoExtracto "Ambos ejes deberán tener los mismos límites de software (parámetros LIMIT+ y LIMIT- iguales para ambos ejes)."@es ;
    ex:identificador "LIMIT+" .

ex:Parametro_LIMIT
    a ex:Parametro ;
    rdfs:label "Parámetro LIMIT- (límite de software negativo)"@es ;
    ex:textoExtracto "Ambos ejes deberán tener los mismos límites de software (parámetros LIMIT+ y LIMIT- iguales para ambos ejes)."@es ;
    ex:identificador "LIMIT-" .

ex:Parametro_AXISMODE
    a ex:Parametro ;
    rdfs:label "Parámetro AXISMODE (modo de eje)"@es ;
    ex:textoExtracto "Cuando los ejes sean rotativos, ambos ejes deberán ser del mismo tipo (parámetros AXISMODE y SHORTESTWAY iguales para ambos ejes)."@es ;
    ex:identificador "AXISMODE" .

ex:Parametro_SHORTESTWAY
    a ex:Parametro ;
    rdfs:label "Parámetro SHORTESTWAY (trayectoria más corta)"@es ;
    ex:textoExtracto "Cuando los ejes sean rotativos, ambos ejes deberán ser del mismo tipo (parámetros AXISMODE y SHORTESTWAY iguales para ambos ejes)."@es ;
    ex:identificador "SHORTESTWAY" .

ex:Pagina_572_ConfiguracionTandem
    a ex:Pagina ;
    rdfs:label "Página 572: Configuración de ejes tándem"@es ;
    ex:textoExtracto "El permiso de cambio de canal (parámetro AXISEXCH) deberá ser igual en ambos ejes. • Ambos ejes deberán tener los mismos límites de software (parámetros LIMIT+ y LIMIT- iguales para ambos ejes). • Cuando los ejes sean rotativos, ambos ejes deberán ser del mismo tipo (parámetros AXISMODE y SHORTESTWAY iguales para ambos ejes)."@es ;
    ex:identificador "572" .

ex:Parametro_AXISEXCH ex:documentadoEn ex:Pagina_572_ConfiguracionTandem .
ex:Parametro_LIMIT ex:documentadoEn ex:Pagina_572_ConfiguracionTandem .
ex:Parametro_LIMIT ex:documentadoEn ex:Pagina_572_ConfiguracionTandem .
ex:Parametro_AXISMODE ex:documentadoEn ex:Pagina_572_ConfiguracionTandem .
ex:Parametro_SHORTESTWAY ex:documentadoEn ex:Pagina_572_ConfiguracionTandem .