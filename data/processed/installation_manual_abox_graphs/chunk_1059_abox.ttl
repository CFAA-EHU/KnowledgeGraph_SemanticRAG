@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalHerramientas a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de herramientas" ;
    ns1:textoExtracto "Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

ns1:ComponenteMecanico_e0702d2bb9 a ns1:ComponenteMecanico ;
    rdfs:label "Almacén de herramientas" ;
    ns1:textoExtracto "Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal." .

ns1:Herramienta_6e230a99de a ns1:Herramienta ;
    rdfs:label "Herramienta de tierra" ;
    ns1:textoExtracto "Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

ns1:OperacionCogerHerramienta a ns1:AccionProhibida ;
    rdfs:label "Operación Coger Herramienta" ;
    ns1:solucionaFallo ns1:DiagnosticoFalloHerramienta ;
    ns1:textoExtracto "1 Coger la herramienta del almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1." .

ns1:OperacionDeAlmacen a ns1:AccionProhibida ;
    rdfs:label "Operación de almacén" ;
    ns1:solucionaFallo ns1:DiagnosticoFalloHerramienta ;
    ns1:textoExtracto "La secuencia de esta operación es la siguiente. 1 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

ns1:Parametro_63e02acfc4 a ns1:Parametro ;
    rdfs:label "Marca CH2TOMZ" ;
    ns1:identificador "CH2TOMZ" ;
    ns1:textoExtracto "Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ." .

ns1:Parametro_7959033478 a ns1:Parametro ;
    rdfs:label "Marca GRTOSPDL" ;
    ns1:identificador "GRTOSPDL" ;
    ns1:textoExtracto "Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

ns1:Parametro_92b7e6b9ba a ns1:Parametro ;
    rdfs:label "Marca MZTOCH1" ;
    ns1:identificador "MZTOCH1" ;
    ns1:textoExtracto "Coger la herramienta del almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1." .

ns1:Parametro_d80576b55d a ns1:Parametro ;
    rdfs:label "Marca SPDLTOCH2" ;
    ns1:identificador "SPDLTOCH2" ;
    ns1:textoExtracto "Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2." .

