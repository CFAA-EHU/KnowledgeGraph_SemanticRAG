@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ParametrosMaquina_ConfiguracionTandem
    a               ex:Parametro ;
    rdfs:label      "Parámetros máquina para configuración de parejas tándem"@es ;
    ex:textoExtracto "Las parejas tándem del sistema se configuran desde los parámetros máquina. Cada pareja tándem dispone de los siguientes parámetros máquina generales para su configuración."@es .

ex:SistemaTandem
    a               ex:Sistema ;
    rdfs:label      "Sistema de parejas tándem"@es ;
    ex:textoExtracto "Las parejas tándem del sistema..."@es ;
    ex:tieneComponente ex:ParametrosMaquina_ConfiguracionTandem .