@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FrecuenciaDeComunicacionDelBusCANopen a ns1:Parametro ;
    rdfs:label "Frecuencia de comunicación del bus CANopen" ;
    ns1:identificador "MPG.CANOPENFREQ" ;
    ns1:textoExtracto "CANOPENFREQ Frecuencia de comunicación del bus CANopen. Valores posibles: Autoscan / 1 Mbps / 800 kbps / 500 kbps / 250 kbps. Valor por defecto: Autoscan." .

ns1:LongitudDelCableDelBusCANfagor a ns1:Parametro ;
    rdfs:label "Longitud del cable del bus CANfagor" ;
    ns1:identificador "MPG.CANLENGTH" ;
    ns1:textoExtracto "CANLENGTH Longitud del cable del bus CANfagor. Valores posibles: Hasta 20, 30, 40, 50, 60, 70, 80, 90, 100, 110, 120, 130 y más de 130 metros. Valor por defecto: Hasta 20 metros." .

ns1:TipoDeBusCAN a ns1:Parametro ;
    rdfs:label "Tipo de bus CAN" ;
    ns1:identificador "MPG.CANMODE" ;
    ns1:textoExtracto "CANMODE Tipo de bus CAN. Valores posibles: CANfagor / CANopen. Valor por defecto: CANopen." .

