@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_2f325e1b12 a ns1:AccionProhibida ;
    rdfs:label "Herramienta de tierra" ;
    ns1:solucionaFallo ns1:FalloPresionHidraulicaBaja ;
    ns1:textoExtracto "LEAVEPOS=-4 Herramienta de tierra. La secuencia de esta operación es la siguiente." .

ns1:DejarLaHerramientaDelCabezalEnElAlmacenYCogerUnaHerramientaDeOtroAlmacen_84005c662b a ns1:AccionProhibida ;
    rdfs:label "Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén" ;
    ns1:textoExtracto "TMOPERATION = 14 Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén." .

ns1:DejarLaHerramientaDelCabezalEnElAlmacenYCogerUnaHerramientaDelMismoAlmacen_6f9e517776 a ns1:AccionProhibida ;
    rdfs:label "Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén" ;
    ns1:textoExtracto "TMOPERATION = 12 Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén (como TMOPERATION=5)." .

ns1:OrientarDosAlmacenes_f35e036c0b a ns1:AccionProhibida ;
    rdfs:label "Orientar dos almacenes" ;
    ns1:textoExtracto "TMOPERATION = 13 Orientar dos almacenes. Esta operación es una optimización del cambio de herramienta que permite orientar dos almacenes durante el mecanizado." .

ns1:OrientarElAlmacen_bce766479d a ns1:AccionProhibida ;
    rdfs:label "Orientar el almacén" ;
    ns1:textoExtracto "TMOPERATION = 11 Orientar el almacén. Esta operación es una optimización del cambio de herramienta que permite orientar el almacén durante el mecanizado." .

ns1:Parametro_1823548c27 a ns1:Parametro ;
    rdfs:label "Marca CH1TOSPDL" ;
    ns1:identificador "CH1TOSPDL" ;
    ns1:textoExtracto "activar la marca CH1TOSPDL." .

ns1:Parametro_92b7e6b9ba a ns1:Parametro ;
    rdfs:label "Marca MZTOCH1" ;
    ns1:identificador "MZTOCH1" ;
    ns1:textoExtracto "activar la marca MZTOCH1." .

ns1:Parametro_94a80a9622 a ns1:Parametro ;
    rdfs:label "Marca MZROT" ;
    ns1:identificador "MZROT" ;
    ns1:textoExtracto "Activar la marca MZROT para indicar que ha finalizado la operación, se haya orientado el almacén o no." .

ns1:Parametro_aed1a67bbe a ns1:Parametro ;
    rdfs:label "Marca SPDLTOGR" ;
    ns1:identificador "SPDLTOGR" ;
    ns1:textoExtracto "activar la marca SPDLTOGR." .

