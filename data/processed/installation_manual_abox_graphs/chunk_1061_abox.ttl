@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SistemaTandem1061 a ex:Sistema ;
    ex:textoExtracto "Un sistema tándem podrá estar formado por una pareja de ejes lineales, de ejes rotativos o de cabezales." ;
    ex:compuestoPor ex:EjeMaestroTandem1061, ex:EjeEsclavoTandem1061 .

ex:EjeMaestroTandem1061 a ex:ComponenteMecanico ;
    ex:textoExtracto "El motor maestro del tándem, además de generar par, es el responsable del posicionamiento." ;
    ex:identificador "MASTERAXIS" ;
    ex:documentadoEn ex:TablaTANDEM1061 .

ex:EjeEsclavoTandem1061 a ex:ComponenteMecanico ;
    ex:textoExtracto "El motor esclavo únicamente suministra par." ;
    ex:identificador "SLAVEAXIS" ;
    ex:documentadoEn ex:TablaTANDEM1061 .

ex:TablaTANDEM1061 a ex:Tabla ;
    ex:textoExtracto "Los parámetros máquina MASTERAXIS y SLAVEAXIS, dentro de la tabla TANDEM." .

ex:MotorMaestro1061 a ex:ComponenteElectrico ;
    ex:textoExtracto "El motor maestro del tándem, además de generar par, es el responsable del posicionamiento." .

ex:MotorEsclavo1061 a ex:ComponenteElectrico ;
    ex:textoExtracto "El motor esclavo únicamente suministra par." .

ex:ParametroAXISNAME1061 a ex:Parametro ;
    ex:textoExtracto "Los ejes deberán estar previamente definidos en el parámetro AXISNAME" .

ex:ParametroSPDLNAME1061 a ex:Parametro ;
    ex:textoExtracto "los cabezales en el parámetro SPDLNAME" .

ex:ModoSercosVelocidad1061 a ex:ModoOperacion ;
    ex:textoExtracto "Los ejes o cabezales del tándem deben ser Sercos velocidad" .

ex:PLCTandem1061 a ex:ComponenteElectrico ;
    ex:textoExtracto "El PLC deba habilitar y deshabilitar las señales SPENA(axis) y DRENA(axis) de los cabezales maestro y esclavo simultáneamente." .