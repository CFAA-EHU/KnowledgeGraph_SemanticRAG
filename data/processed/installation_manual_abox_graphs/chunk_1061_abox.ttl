@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DejarLaHerramientaDelCabezalEnElAlmacenYCogerUnaHerramientaDeOtroAlmacen_5bc58783a0 a ns1:TareaMantenimiento ;
    rdfs:label "Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén" ;
    ns1:documentadoEn ns1:RegistroMZID ;
    ns1:textoExtracto "TMOPERATION = 14 Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén." ;
    ns1:tieneComponente ns1:PosicionDelAlmacenParaCogerLaHerramienta_565a898463,
        ns1:PosicionDelAlmacenParaDejarLaHerramienta_cdb33c0f18 .

ns1:PosicionDelAlmacenParaCogerLaHerramienta_565a898463 a ns1:Parametro ;
    rdfs:label "Posición del almacén para coger la herramienta" ;
    ns1:textoExtracto "TAKEPOS=# Posición del almacén para coger la herramienta." .

ns1:PosicionDelAlmacenParaDejarLaHerramienta_cdb33c0f18 a ns1:Parametro ;
    rdfs:label "Posición del almacén para dejar la herramienta" ;
    ns1:textoExtracto "LEAVEPOS=# Posición del almacén para dejar la herramienta." .

ns1:RegistroMZID a ns1:Tabla ;
    rdfs:label "MZID" ;
    ns1:textoExtracto "MZID En la parte baja de este registro se indica el almacén en el que hay que dejar la herramienta y en la parte alta el almacén del que hay que coger la herramienta." .

