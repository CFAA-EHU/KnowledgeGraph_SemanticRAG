@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PLC_tandem_1062 a ex:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ex:textoExtracto "El PLC deba habilitar y deshabilitar las señales SPENA(axis) y DRENA(axis) de los cabezales maestro y esclavo simultáneamente." .

ex:senal_SPENA_1062 a ex:ComponenteElectrico ;
    rdfs:label "SPENA(axis)" ;
    ex:textoExtracto "señales SPENA(axis) y DRENA(axis) de los cabezales maestro y esclavo" .

ex:senal_DRENA_1062 a ex:ComponenteElectrico ;
    rdfs:label "DRENA(axis)" ;
    ex:textoExtracto "señales SPENA(axis) y DRENA(axis) de los cabezales maestro y esclavo" .

ex:cabezal_maestro_1062 a ex:ComponenteMecanico ;
    rdfs:label "cabezal maestro" ;
    ex:textoExtracto "cabezales maestro y esclavo" .

ex:cabezal_esclavo_1062 a ex:ComponenteMecanico ;
    rdfs:label "cabezal esclavo" ;
    ex:textoExtracto "cabezales maestro y esclavo" .

ex:senal_PLCCNTL_1062 a ex:ComponenteElectrico ;
    rdfs:label "PLCCNTL" ;
    ex:textoExtracto "activar las marcas PLCCNTL, SPDLEREV y SANALOG del cabezal maestro" .

ex:senal_SPDLEREV_1062 a ex:ComponenteElectrico ;
    rdfs:label "SPDLEREV" ;
    ex:textoExtracto "activar las marcas PLCCNTL, SPDLEREV y SANALOG del cabezal maestro" .

ex:senal_SANALOG_1062 a ex:ComponenteElectrico ;
    rdfs:label "SANALOG" ;
    ex:textoExtracto "activar las marcas PLCCNTL, SPDLEREV y SANALOG del cabezal maestro" .

ex:distribucion_par_tandem_1062 a ex:Parametro ;
    rdfs:label "distribución del par en el tándem" ;
    ex:textoExtracto "La distribución del par establece el porcentaje de par que realiza cada motor para conseguir el par total necesario en el tándem." .

ex:motor_tandem_1062 a ex:ComponenteElectrico ;
    rdfs:label "motor" ;
    ex:textoExtracto "cada motor para conseguir el par total necesario en el tándem" .