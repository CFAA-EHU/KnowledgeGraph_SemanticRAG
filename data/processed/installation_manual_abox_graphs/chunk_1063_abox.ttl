@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "La comunicación entre el PLC y la rutina M06 se realiza mediante una serie de marcas y registros genéricos." ;
    ns1:tieneComponente ns1:CogerLaHerramientaDelCabezalConLaPinza2,
        ns1:LaHerramientaSeHaLlevadoDeLaPinza1AlCabezal,
        ns1:LaHerramientaSeHaLlevadoDeLaPinza2AlAlmacen,
        ns1:LaHerramientaSeHaLlevadoDeTierraAlCabezal,
        ns1:LaHerramientaSeHaLlevadoDelAlmacenALaPinza1,
        ns1:LaHerramientaSeHaLlevadoDelCabezalALaPinza2_cbb088b3ae,
        ns1:LaHerramientaSeHaLlevadoDelCabezalATierra_29ff4998ea,
        ns1:LlevarLaHerramientaDeLaPinza1AlCabezal,
        ns1:SeleccionarEnElAlmacenLaPosicionQueIndicaLEAVEPOSYDejarLaHerramientaDeLaPinza2,
        ns1:SeleccionarEnElAlmacenLaPosicionQueIndicaTAKEPOSYCogerLaHerramientaConLaPinza1 .

ns1:CogerLaHerramientaDelCabezalConLaPinza2 a ns1:Parametro ;
    rdfs:label "Coger la herramienta del cabezal con la pinza 2" ;
    ns1:identificador "M104" ;
    ns1:textoExtracto "M104 Coger la herramienta del cabezal con la pinza 2." .

ns1:LaHerramientaSeHaLlevadoDeLaPinza1AlCabezal a ns1:Parametro ;
    rdfs:label "La herramienta se ha llevado de la pinza 1 al cabezal" ;
    ns1:identificador "M1102" ;
    ns1:textoExtracto "M1102 La herramienta se ha llevado de la pinza 1 al cabezal." .

ns1:LaHerramientaSeHaLlevadoDeLaPinza2AlAlmacen a ns1:Parametro ;
    rdfs:label "La herramienta se ha llevado de la pinza 2 al almacén" ;
    ns1:identificador "M1106" ;
    ns1:textoExtracto "M1106 La herramienta se ha llevado de la pinza 2 al almacén." .

ns1:LaHerramientaSeHaLlevadoDeTierraAlCabezal a ns1:Parametro ;
    rdfs:label "La herramienta se ha llevado de tierra al cabezal" ;
    ns1:identificador "M1108" ;
    ns1:textoExtracto "M1108 La herramienta se ha llevado de tierra al cabezal." .

ns1:LaHerramientaSeHaLlevadoDelAlmacenALaPinza1 a ns1:Parametro ;
    rdfs:label "La herramienta se ha llevado del almacén a la pinza 1" ;
    ns1:identificador "M1101" ;
    ns1:textoExtracto "M1101 La herramienta se ha llevado del almacén a la pinza 1." .

ns1:LaHerramientaSeHaLlevadoDelCabezalALaPinza2_cbb088b3ae a ns1:Parametro ;
    rdfs:label "La herramienta se ha llevado del cabezal a la pinza 2" ;
    ns1:identificador "M1104" ;
    ns1:textoExtracto "M1104 La herramienta se ha llevado del cabezal a la pinza 2." .

ns1:LaHerramientaSeHaLlevadoDelCabezalATierra_29ff4998ea a ns1:Parametro ;
    rdfs:label "La herramienta se ha llevado del cabezal a tierra" ;
    ns1:identificador "M1107" ;
    ns1:textoExtracto "M1107 La herramienta se ha llevado del cabezal a tierra." .

ns1:LlevarLaHerramientaDeLaPinza1AlCabezal a ns1:Parametro ;
    rdfs:label "Llevar la herramienta de la pinza 1 al cabezal" ;
    ns1:identificador "M102" ;
    ns1:textoExtracto "M102 Llevar la herramienta de la pinza 1 al cabezal." .

ns1:SeleccionarEnElAlmacenLaPosicionQueIndicaLEAVEPOSYDejarLaHerramientaDeLaPinza2 a ns1:Parametro ;
    rdfs:label "Seleccionar en el almacén la posición que indica LEAVEPOS y dejar la herramienta de la pinza 2" ;
    ns1:identificador "M106" ;
    ns1:textoExtracto "M106 Seleccionar en el almacén la posición que indica LEAVEPOS y dejar la herramienta de la pinza 2." .

ns1:SeleccionarEnElAlmacenLaPosicionQueIndicaTAKEPOSYCogerLaHerramientaConLaPinza1 a ns1:Parametro ;
    rdfs:label "Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1" ;
    ns1:identificador "M101" ;
    ns1:textoExtracto "M101 Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1." .

