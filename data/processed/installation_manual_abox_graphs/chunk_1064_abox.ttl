@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_TPROGAIN a ex:Parametro ;
    rdfs:label "TPROGAIN" ;
    ex:textoExtracto "Ganancia proporcional (Kp) para el tándem. El controlador proporcional genera una salida proporcional al error en par entre los dos motores. La ganancia proporcional se puede definir con el parámetro TPROGAIN." ;
    ex:valor "Ganancia proporcional (Kp) para el tándem" .

ex:Parametro_Ki a ex:Parametro ;
    rdfs:label "Ki" ;
    ex:textoExtracto "Ganancia integral (Ki) para el tándem." ;
    ex:valor "Ganancia integral (Ki) para el tándem" .