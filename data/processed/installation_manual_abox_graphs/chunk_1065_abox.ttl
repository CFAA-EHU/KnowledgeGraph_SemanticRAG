@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TPROGAIN a ex:Parametro ;
    rdfs:label "TPROGAIN" ;
    ex:textoExtracto "La ganancia proporcional se puede definir con el parámetro TPROGAIN." ;
    ex:valor "proporcional" .

ex:TINTTIME a ex:Parametro ;
    rdfs:label "TINTTIME" ;
    ex:textoExtracto "La ganancia integral se puede definir con el parámetro TINTTIME." ;
    ex:valor "integral" .