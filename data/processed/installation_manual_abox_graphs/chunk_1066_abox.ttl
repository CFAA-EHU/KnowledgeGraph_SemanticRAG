@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalHerramientas a ns1:Componente ;
    rdfs:label "Cabezal de herramientas" ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio automático." .

ns1:CambioDeHerramientaAutomatico_89fc9c8e64 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta automático" ;
    ns1:textoExtracto "Coger una herramienta del almacén y ponerla en el cabezal." .

ns1:CambioDeHerramientaManual_89bf2de7bb a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta manual" ;
    ns1:textoExtracto "Colocar la herramienta de tierra en el cabezal." .

ns1:Componente_213e1fe730 a ns1:Componente ;
    rdfs:label "Almacén de herramientas" ;
    ns1:textoExtracto "Coger la herramienta del almacén con la pinza 1." .

ns1:DejarHerramientaEnAlmacenAutomatico a ns1:TareaMantenimiento ;
    rdfs:label "Dejar herramienta en almacén automático" ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en el almacén." .

ns1:DejarHerramientaEnTierra a ns1:TareaMantenimiento ;
    rdfs:label "Dejar herramienta en tierra" ;
    ns1:textoExtracto "Quitar la herramienta del cabezal." .

