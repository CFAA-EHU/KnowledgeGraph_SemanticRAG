@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Esquema_Precarga_Reposo
    a               ex:Esquema ;
    rdfs:label      "Precarga en reposo" ;
    ex:textoExtracto "Precarga en reposo." .

ex:Esquema_Precarga_Aceleracion
    a               ex:Esquema ;
    rdfs:label      "Precarga con aceleración" ;
    ex:textoExtracto "Precarga con aceleración." .

ex:Esquema_Precarga_VelocidadConstante_1
    a               ex:Esquema ;
    rdfs:label      "Precarga a velocidad constante (par de fricción > precarga)" ;
    ex:textoExtracto "Precarga a velocidad constante. Par de fricción > Precarga." .

ex:Esquema_Precarga_VelocidadConstante_2
    a               ex:Esquema ;
    rdfs:label      "Precarga a velocidad constante (par de fricción < precarga)" ;
    ex:textoExtracto "Precarga a velocidad constante. Par de fricción < Precarga." .

ex:Esquema_Precarga_Deceleracion
    a               ex:Esquema ;
    rdfs:label      "Precarga con deceleración" ;
    ex:textoExtracto "Precarga con deceleración." .

ex:Figura_EfectoPrecarga
    a               ex:Figura ;
    rdfs:label      "Efecto de la precarga en diferentes situaciones" ;
    ex:textoExtracto "Los siguientes diagramas muestran el efecto de la precarga en diferentes situaciones." ;
    ex:ilustradoEn  ex:Esquema_Precarga_Reposo ,
                    ex:Esquema_Precarga_Aceleracion ,
                    ex:Esquema_Precarga_VelocidadConstante_1 ,
                    ex:Esquema_Precarga_VelocidadConstante_2 ,
                    ex:Esquema_Precarga_Deceleracion .