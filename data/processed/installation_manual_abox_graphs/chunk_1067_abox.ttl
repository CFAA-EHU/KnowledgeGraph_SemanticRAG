@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:DiagramaBloquesControlTandem a ex:Esquema ;
    rdfs:label "Diagrama de bloques del sistema de control del tándem"@es ;
    ex:textoExtracto "El diagrama de bloques del sistema de control del tándem muestra el eje tándem maestro con su eje tándem esclavo."@es ;
    ex:compuestoPor ex:EjeTandemMaestro, ex:EjeTandemEsclavo, ex:Regulador, ex:ControlNumerico .

ex:EjeTandemMaestro a ex:ComponenteMecanico ;
    rdfs:label "Eje tándem maestro"@es ;
    ex:textoExtracto "El diagrama de bloques del sistema de control del tándem muestra el eje tándem maestro con su eje tándem esclavo."@es .

ex:EjeTandemEsclavo a ex:ComponenteMecanico ;
    rdfs:label "Eje tándem esclavo"@es ;
    ex:textoExtracto "El diagrama de bloques del sistema de control del tándem muestra el eje tándem maestro con su eje tándem esclavo."@es .

ex:Regulador a ex:ComponenteElectrico ;
    rdfs:label "Regulador"@es ;
    ex:textoExtracto "En el diagrama de bloques aparece una zona correspondiente al regulador y otra al control numérico, que engloba el lazo de posición y el control del tándem."@es .

ex:ControlNumerico a ex:ComponenteElectrico ;
    rdfs:label "Control numérico"@es ;
    ex:textoExtracto "En el diagrama de bloques aparece una zona correspondiente al regulador y otra al control numérico, que engloba el lazo de posición y el control del tándem."@es .

ex:MotorMaestroTandem a ex:ComponenteElectrico ;
    rdfs:label "Motor maestro del tándem"@es ;
    ex:textoExtracto "Par del motor maestro del tándem. Es el porcentaje de par nominal que refleja la variable sercos TV2 del regulador que gobierna el eje maestro del tándem."@es .

ex:MotorEsclavoTandem a ex:ComponenteElectrico ;
    rdfs:label "Motor esclavo del tándem"@es ;
    ex:textoExtracto "Par del motor esclavo del tándem. Es el porcentaje de par nominal que refleja la variable sercos TV2 del regulador que gobierna el eje esclavo del tándem."@es .

ex:LazoPosicion a ex:Sistema ;
    rdfs:label "Lazo de posición"@es ;
    ex:textoExtracto "El lazo de posición se cierra únicamente con la posición del eje maestro del tándem."@es .

ex:LazoVelocidad a ex:Sistema ;
    rdfs:label "Lazo de velocidad"@es ;
    ex:textoExtracto "La consigna de velocidad del eje tándem maestro se envía también al eje esclavo del tándem cerrando el lazo de velocidad."@es .

ex:ControlTandem a ex:Sistema ;
    rdfs:label "Control del eje tándem"@es ;
    ex:textoExtracto "El control de tándem modifica la consigna de velocidad del eje maestro y del eje esclavo en función de la distribución de par y la precarga seleccionada."@es .

ex:DistribucionPar a ex:Parametro ;
    rdfs:label "Distribución de par"@es ;
    ex:textoExtracto "Distribución de par. Ganancia de normalización de los pares generados por los motores cuyo fin es establecer un reparto de pares que no siga una relación 1:1."@es .

ex:Precarga a ex:Parametro ;
    rdfs:label "Precarga"@es ;
    ex:textoExtracto "Precarga. Par previo aplicado a ambos ejes del tándem en sentidos opuestos."@es .