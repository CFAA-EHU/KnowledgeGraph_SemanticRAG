@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalHerramientas a ns1:Componente ;
    rdfs:label "Cabezal de herramientas" ;
    ns1:requiereMantenimiento ns1:CambioDeHerramientaAutomatico_2bddb72182,
        ns1:CambioDeHerramientaManual_05b3760b6b ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio automático." .

ns1:Componente_2469f375a8 a ns1:Componente ;
    rdfs:label "Almacén de herramientas" ;
    ns1:textoExtracto "Coger la herramienta del almacén con la pinza 1." .

ns1:CambioDeHerramientaAutomatico_2bddb72182 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta automático" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático." .

ns1:CambioDeHerramientaManual_05b3760b6b a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta manual" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual." .

