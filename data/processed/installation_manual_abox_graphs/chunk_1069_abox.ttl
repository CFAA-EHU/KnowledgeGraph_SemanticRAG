@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MotorMaestro a ex:ComponenteMecanico ;
    rdfs:label "motor maestro" ;
    ex:textoExtracto "motores maestro" .

ex:MotorEsclavo a ex:ComponenteMecanico ;
    rdfs:label "motor esclavo" ;
    ex:textoExtracto "motores esclavo" .

ex:EjeTandem a ex:ComponenteMecanico ;
    rdfs:label "eje tándem" ;
    ex:compuestoPor ex:MotorMaestro, ex:MotorEsclavo ;
    ex:textoExtracto "eje tándem" .

ex:FiltroPrecarga a ex:Componente ;
    rdfs:label "filtro de precarga" ;
    ex:textoExtracto "Filtro de precarga. Filtro de primer orden cuyo fin es evitar la entrada de escalones de par al configurar la precarga." .

ex:PI_Tandem a ex:Componente ;
    rdfs:label "PI del tándem" ;
    ex:textoExtracto "PI del tándem. PI cuya función es conseguir que cada motor realice el par que le corresponde." .

ex:SistemaSercos a ex:Sistema ;
    rdfs:label "Sercos" ;
    ex:textoExtracto "vía Sercos" .