@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla_CROSSCOMP a ex:Tabla ;
    ex:textoExtracto "Este parámetro muestra la lista de puntos y valores de compensación. El CNC sólo permite acceder a esta tabla cuando están definidos los parámetros MOVAXIS, COMPAXIS y NPCROSS." ;
    ex:valor "Tabla para definir los valores de compensación" .

ex:Parametro_MOVAXIS a ex:Parametro ;
    ex:textoExtracto "parámetros MOVAXIS, COMPAXIS y NPCROSS" .

ex:Parametro_COMPAXIS a ex:Parametro ;
    ex:textoExtracto "parámetros MOVAXIS, COMPAXIS y NPCROSS" .

ex:Parametro_NPCROSS a ex:Parametro ;
    ex:textoExtracto "parámetros MOVAXIS, COMPAXIS y NPCROSS" .

ex:Parametro_MPG_REFNEED a ex:Parametro ;
    ex:textoExtracto "Variable asociada: (V.)MPG.REFNEED[tbl] Parámetro incluido en la tabla CROSSCOMP. Este parámetro indica si es necesario referenciar ambos ejes para empezar a aplicar la compensación." ;
    ex:identificador "MPG.REFNEED[tbl]" .