@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_590a0090ae a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" ;
    ns1:tieneFrecuencia ns1:Frecuencia1000kHz,
        ns1:Frecuencia250kHz,
        ns1:Frecuencia500kHz,
        ns1:Frecuencia800kHz,
        ns1:FrecuenciaAutoscan .

ns1:Frecuencia1000kHz a ns1:Frecuencia ;
    rdfs:label "1000 kHz" ;
    ns1:textoExtracto "Hasta 20 metros." .

ns1:Frecuencia250kHz a ns1:Frecuencia ;
    rdfs:label "250 kHz" ;
    ns1:textoExtracto "Entre 100 y 500 metros. La velocidad de 250 kHz sólo está disponible para la comunicación con los teclados y los módulos remotos de la serie RIOW y RIOR; en los módulos remotos de la serie RIO5 no está disponible esta velocidad." .

ns1:Frecuencia500kHz a ns1:Frecuencia ;
    rdfs:label "500 kHz" ;
    ns1:textoExtracto "Entre 40 y 100 metros." .

ns1:Frecuencia800kHz a ns1:Frecuencia ;
    rdfs:label "800 kHz" ;
    ns1:textoExtracto "Entre 20 y 40 metros." .

ns1:FrecuenciaAutoscan a ns1:Frecuencia ;
    rdfs:label "Autoscan" ;
    ns1:textoExtracto "El CNC ajusta la frecuencia del bus en cada arranque, en función de la velocidad del resto de los módulos." .

