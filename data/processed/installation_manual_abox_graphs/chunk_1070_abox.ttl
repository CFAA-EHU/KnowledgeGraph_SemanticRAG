@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioManualDeHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Cambio manual de herramienta" ;
    ns1:textoExtracto "cambio manual. LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal." .

ns1:EsperaAlGestorDelAlmacen_07d4481cb4 a ns1:AccionProhibida ;
    rdfs:label "Espera al gestor del almacén" ;
    ns1:textoExtracto "$WHILE V.TM.MZWAIT == 1 $ENDWHILE ; Espera al gestor del almacén." .

ns1:FinAnalisisDelTipoDeOperacion a ns1:AccionProhibida ;
    rdfs:label "Fin análisis del tipo de operación" ;
    ns1:textoExtracto "$BREAK $ENDSWITCH ; Fin análisis del tipo de operación." .

ns1:FinDeTratamientoDeBloqueUnico_3df643f2f8 a ns1:AccionProhibida ;
    rdfs:label "Fin de tratamiento de bloque único" ;
    ns1:textoExtracto "$ENDIF #DSBLK ; Fin de tratamiento de bloque único." .

ns1:HabilitarLaTeclaSTOP a ns1:AccionProhibida ;
    rdfs:label "Habilitar la tecla STOP" ;
    ns1:textoExtracto "# ESTOP ; Habilitar la tecla STOP." .

