@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_V_A_TPIIN_xn a ex:Parametro ;
    rdfs:label "(V.)[ch].A.TPIIN.xn" ;
    ex:textoExtracto "Entrada del PI del eje maestro del tándem (en rpm)" ;
    ex:valor "R" .

ex:Parametro_V_A_TPIOUT_xn a ex:Parametro ;
    rdfs:label "(V.)[ch].A.TPIOUT.xn" ;
    ex:textoExtracto "Salida del PI del eje maestro del tándem (en rpm)" ;
    ex:valor "R" .

ex:Parametro_V_A_TFILTOUT_xn a ex:Parametro ;
    rdfs:label "(V.)[ch].A.TFILTOUT.xn" ;
    ex:textoExtracto "Salida del filtro de precarga" ;
    ex:valor "R" .

ex:Parametro_V_A_PRELOAD_xn a ex:Parametro ;
    rdfs:label "(V.)[ch].A.PRELOAD.xn" ;
    ex:textoExtracto "Precarga" ;
    ex:valor "R/W" .

ex:Parametro_V_A_FTEO_xn a ex:Parametro ;
    rdfs:label "(V.)[ch].A.FTEO.xn" ;
    ex:textoExtracto "Consigna de velocidad para Sercos" ;
    ex:valor "R" .

ex:Parametro_V_A_TORQUE_xn a ex:Parametro ;
    rdfs:label "(V.)[ch].A.TORQUE.xn" ;
    ex:textoExtracto "Par de corriente en Sercos" ;
    ex:valor "R" .

ex:Parametro_V_A_TORQUE a ex:Parametro ;
    rdfs:label "(V.)A.TORQUE" ;
    ex:textoExtracto "La lectura desde el PLC de esta variable vendrá expresada en décimas (x10)." .