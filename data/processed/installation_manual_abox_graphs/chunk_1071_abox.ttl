@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_2b4127f1db a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "La rutina M06 utiliza las siguientes funciones auxiliares M para indicar al PLC qué movimientos debe realizar." .

ns1:CodigoDeOperacionDelGestorParaElPLC a ns1:Parametro ;
    rdfs:label "Código de operación del gestor para el PLC" ;
    ns1:identificador "TMOPERATION" ;
    ns1:textoExtracto "el gestor envía al PLC el código TMOPERATION=11." .

ns1:Parametro_1823548c27 a ns1:Parametro ;
    rdfs:label "Marca que indica herramienta de pinza 1 al cabezal" ;
    ns1:identificador "CH1TOSPDL" ;
    ns1:textoExtracto "DFU M1102 = SET CH1TOSPDL" .

ns1:Parametro_63e02acfc4 a ns1:Parametro ;
    rdfs:label "Marca que indica herramienta de pinza 2 al almacén" ;
    ns1:identificador "CH2TOMZ" ;
    ns1:textoExtracto "DFU M1106 = SET CH2TOMZ" .

ns1:Parametro_7959033478 a ns1:Parametro ;
    rdfs:label "Marca que indica herramienta de tierra al cabezal" ;
    ns1:identificador "GRTOSPDL" ;
    ns1:textoExtracto "DFU M1108 = SET GRTOSPDL" .

ns1:Parametro_92b7e6b9ba a ns1:Parametro ;
    rdfs:label "Marca que indica herramienta en pinza 1" ;
    ns1:identificador "MZTOCH1" ;
    ns1:textoExtracto "DFU M1101 = SET MZTOCH1" .

ns1:Parametro_94a80a9622 a ns1:Parametro ;
    rdfs:label "Marca que indica finalización de operación" ;
    ns1:identificador "MZROT" ;
    ns1:textoExtracto "activa la marca MZROT para indicar que ha finalizado la operación." .

ns1:Parametro_aed1a67bbe a ns1:Parametro ;
    rdfs:label "Marca que indica herramienta de cabezal a tierra" ;
    ns1:identificador "SPDLTOGR" ;
    ns1:textoExtracto "DFU M1107 = SET SPDLTOGR" .

ns1:Parametro_d80576b55d a ns1:Parametro ;
    rdfs:label "Marca que indica herramienta de cabezal a pinza 2" ;
    ns1:identificador "SPDLTOCH2" ;
    ns1:textoExtracto "DFU M1104 = SET SPDLTOCH2" .

