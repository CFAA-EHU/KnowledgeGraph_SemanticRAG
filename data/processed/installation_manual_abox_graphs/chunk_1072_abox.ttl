@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:MaquinaTandem_1072 a ex:Maquina ;
    ex:textoExtracto "En este proceso debe tenerse en cuenta el tipo de máquina de la que se dispone. En general, una máquina tándem posee frecuencia de resonancia baja" .

ex:EjeMaestro_1072 a ex:ComponenteMecanico ;
    ex:textoExtracto "asegurar un perfecto funcionamiento tanto del eje maestro como del eje esclavo de modo independiente" .

ex:EjeEsclavo_1072 a ex:ComponenteMecanico ;
    ex:textoExtracto "asegurar un perfecto funcionamiento tanto del eje maestro como del eje esclavo de modo independiente" .

ex:MotorEjeMaestro_1072 a ex:ComponenteElectrico ;
    ex:textoExtracto "el segundo motor está siendo arrastrado por el primero" .

ex:MotorEjeEsclavo_1072 a ex:ComponenteElectrico ;
    ex:textoExtracto "el segundo motor está siendo arrastrado por el primero" .

ex:Regulador_1072 a ex:ComponenteElectrico ;
    ex:textoExtracto "cambiar el signo de sus valores monitorizados mediante los parámetros SP43 y TP85 del regulador" ;
    ex:identificador "SP43, TP85" .

ex:ParametroSP43_1072 a ex:Parametro ;
    ex:textoExtracto "cambiar el signo de sus valores monitorizados mediante los parámetros SP43" ;
    ex:identificador "SP43" .

ex:ParametroTP85_1072 a ex:Parametro ;
    ex:textoExtracto "cambiar el signo de sus valores monitorizados mediante los parámetros ... TP85 del regulador" ;
    ex:identificador "TP85" .