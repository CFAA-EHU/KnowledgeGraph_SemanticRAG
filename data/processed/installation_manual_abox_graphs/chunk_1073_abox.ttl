@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Motor1 a ex:ComponenteMecanico ;
    rdfs:label "motor"@es ;
    ex:textoExtracto "motores"@es .

ex:Motor2 a ex:ComponenteMecanico ;
    rdfs:label "motor"@es ;
    ex:textoExtracto "motores"@es .

ex:SistemaTandem a ex:Sistema ;
    rdfs:label "tándem"@es ;
    ex:textoExtracto "tándem"@es ;
    ex:compuestoPor ex:Motor1, ex:Motor2 ;
    ex:tieneComponente ex:Motor1, ex:Motor2 .

ex:MaquinaPrincipal a ex:Maquina ;
    rdfs:label "máquina"@es ;
    ex:textoExtracto "la máquina"@es ;
    ex:compuestoPor ex:SistemaTandem .

ex:ParametroTORQDIST a ex:Parametro ;
    rdfs:label "TORQDIST"@es ;
    ex:textoExtracto "parámetro \"TORQDIST\""@es .

ex:ParametroPRELOAD a ex:Parametro ;
    rdfs:label "PRELOAD"@es ;
    ex:textoExtracto "parámetros \"TORQDIST\" y \"PRELOAD\""@es .

ex:VariableSercosTV2 a ex:Parametro ;
    rdfs:label "Sercos TV2"@es ;
    ex:textoExtracto "variable Sercos TV2"@es ;
    ex:monitoreaParametro ex:Motor1, ex:Motor2 .

ex:MetodoAjusteLazoVelocidad a ex:TareaMantenimiento ;
    rdfs:label "método utilizado normalmente"@es ;
    ex:textoExtracto "método utilizado normalmente"@es ;
    ex:ejecutadoPor ex:MaquinaPrincipal .