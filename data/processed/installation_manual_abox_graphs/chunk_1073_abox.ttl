@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LamparaTMINEM a ns1:ComponenteElectrico ;
    rdfs:label "Lámpara de la tecla USER12" ;
    ns1:documentadoEn ns1:SistemaPLC ;
    ns1:textoExtracto "Lámpara de la tecla USER12 iluminada cuando hay emergencia." .

ns1:PosicionDeAlmacenParaCogerLaHerramienta a ns1:Parametro ;
    rdfs:label "Posición de almacén para coger la herramienta" ;
    ns1:documentadoEn ns1:SistemaPLC ;
    ns1:identificador "TAKEPOS" ;
    ns1:textoExtracto "Este registro indica la posición de almacén que ocupa la herramienta que hay que coger." .

ns1:PosicionDeAlmacenParaDejarLaHerramienta a ns1:Parametro ;
    rdfs:label "Posición de almacén para dejar la herramienta" ;
    ns1:documentadoEn ns1:SistemaPLC ;
    ns1:identificador "LEAVEPOS" ;
    ns1:textoExtracto "Este registro indica la posición de almacén en la que hay que dejar la herramienta." .

ns1:SenalDeEmergenciaDelGestorDeHerramientas_e671f9e281 a ns1:Parametro ;
    rdfs:label "Señal de emergencia del gestor de herramientas" ;
    ns1:documentadoEn ns1:SistemaPLC ;
    ns1:identificador "TMINEM" ;
    ns1:textoExtracto "Tratamiento de la señal de emergencia del gestor de herramientas." .

ns1:TeclaUSER12 a ns1:ComponenteElectrico ;
    rdfs:label "Tecla USER12" ;
    ns1:documentadoEn ns1:SistemaPLC ;
    ns1:textoExtracto "Si se pulsa la tecla USER12 se activa la emergencia." .

ns1:TeclaUSER13 a ns1:ComponenteElectrico ;
    rdfs:label "Tecla USER13" ;
    ns1:documentadoEn ns1:SistemaPLC ;
    ns1:textoExtracto "Si se pulsa la tecla USER13 se quita la emergencia." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Programación básica del PLC." .

