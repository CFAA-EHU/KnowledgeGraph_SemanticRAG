@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_ANAOUTID a ex:Parametro ;
    rdfs:label "ANAOUTID" ;
    ex:textoExtracto "Parámetro. | Significado. | ANAOUTID | Número de la salida analógica asociada al eje." ;
    ex:valor "1 - 16" ;
    ex:textoExtracto "En este caso, este parámetro indica el número de la salida analógica que se utiliza para la consigna." .

ex:Parametro_COUNTERTYPE a ex:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ex:textoExtracto "Parámetro. | Significado. | COUNTERTYPE | Tipo de entrada de captación del eje." .

ex:Parametro_COUNTERID a ex:Parametro ;
    rdfs:label "COUNTERID" ;
    ex:textoExtracto "Parámetro. | Significado. | COUNTERID | Número de la entrada de captación del eje." .

ex:Parametro_ANAOUTID_ConfiguracionSalidaAnalogica a ex:Parametro ;
    rdfs:label "ANAOUTID" ;
    ex:textoExtracto "Configurar la salida analógica del eje. La consigna para un eje analógico se puede tomar desde una salida analógica de los módulos remotos o de un regulador Sercos. La selección se realiza mediante el parámetro ANAOUTID." .

ex:Sistema_GestionConsignaAnalogica a ex:Sistema ;
    rdfs:label "Gestión de la consigna analógica" ;
    ex:textoExtracto "Gestión de la consigna analógica desde los módulos remotos CANfagor." ;
    ex:compuestoPor ex:Parametro_ANAOUTID .

ex:Sistema_GestionConsignaAnalogica_Sercos a ex:Sistema ;
    rdfs:label "Gestión de la consigna analógica desde reguladores Sercos" ;
    ex:textoExtracto "Gestión de la consigna analógica desde los reguladores Sercos." ;
    ex:compuestoPor ex:Parametro_ANAOUTID_ConfiguracionSalidaAnalogica .