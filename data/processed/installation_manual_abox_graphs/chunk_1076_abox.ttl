ex:UnidadCentral a ex:ComponenteElectrico ;
    rdfs:label "unidad central" ;
    ex:textoExtracto "La unidad central dispone de dos entradas de captación." ;
    ex:detalladoEnEsquema ex:Tabla_1076_3 .

ex:Tabla_1076_1 a ex:Tabla ;
    ex:textoExtracto "Parámetro. | Valor. | --- | --- | COUNTERTYPE | Remoto. | COUNTERID | Número de la entrada de captación." .

