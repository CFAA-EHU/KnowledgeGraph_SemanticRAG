@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_COUNTERTYPE
    a ex:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ex:textoExtracto "COUNTERTYPE | Remoto."@es ;
    ex:valor "Remoto", "Regulador", "Local" .

ex:Parametro_COUNTERID
    a ex:Parametro ;
    rdfs:label "COUNTERID" ;
    ex:textoExtracto "COUNTERID | Número de la entrada de captación."@es ;
    ex:valor "1-4 (primer módulo)", "5-8 (segundo módulo)", "1-32 (dirección lógica)", "1-2 (unidad central)" .

ex:Tabla_ConfiguracionEntradasCaptacion a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Configuración de entradas de captación" ;
    ex:textoExtracto "Para la entrada de captación se utiliza un módulo de contadoras en los módulos remotos. [...] La unidad central dispone de dos entradas de captación."@es ;
    ex:documentadoEn ex:Pagina_581_582 .

ex:Pagina_581_582
    a ex:Pagina ;
    ex:identificador "581-582" ;
    ex:textoExtracto "11.3 Ejes analógicos. - 11.3.1 Configurar el número de salida analógica y de la entrada de captación."@es .