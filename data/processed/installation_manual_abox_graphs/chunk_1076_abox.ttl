@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_COUNTERTYPE_Remoto a ex:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ex:valor "Remoto" ;
    ex:textoExtracto "COUNTERTYPE | Remoto." ;
    ex:detalladoEnEsquema ex:Tabla_1076_1 .

ex:Parametro_COUNTERID_Remoto a ex:Parametro ;
    rdfs:label "COUNTERID" ;
    ex:valor "Número de la entrada de captación" ;
    ex:textoExtracto "COUNTERID | Número de la entrada de captación." ;
    ex:detalladoEnEsquema ex:Tabla_1076_1 .

ex:ModuloContadoras_Remoto a ex:ComponenteElectrico ;
    rdfs:label "módulo de contadoras" ;
    ex:textoExtracto "Para la entrada de captación se utiliza un módulo de contadoras en los módulos remotos." ;
    ex:detalladoEnEsquema ex:Tabla_1076_1 .

ex:Parametro_COUNTERTYPE_Regulador a ex:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ex:valor "Regulador" ;
    ex:textoExtracto "COUNTERTYPE | Regulador." ;
    ex:detalladoEnEsquema ex:Tabla_1076_2 .

ex:Parametro_COUNTERID_Regulador a ex:Parametro ;
    rdfs:label "COUNTERID" ;
    ex:valor "Número de la entrada de captación" ;
    ex:textoExtracto "COUNTERID | Número de la entrada de captación." ;
    ex:detalladoEnEsquema ex:Tabla_1076_2 .

ex:Regulador_Sercos a ex:ComponenteElectrico ;
    rdfs:label "reguladores Sercos" ;
    ex:textoExtracto "En este caso siempre se utilizará la segunda entrada de captación del regulador." ;
    ex:detalladoEnEsquema ex:Tabla_1076_2 .

ex:Parametro_COUNTERTYPE_Local a ex:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ex:valor "Local" ;
    ex:textoExtracto "COUNTERTYPE | Local." ;
    ex:detalladoEnEsquema ex:Tabla_1076_3 .

ex:Parametro_COUNTERID_Local a ex:Parametro ;
    rdfs:label "COUNTERID" ;
    ex:valor "Número de la entrada de captación" ;
    ex:textoExtracto "COUNTERID | Número de la entrada de captación." ;
