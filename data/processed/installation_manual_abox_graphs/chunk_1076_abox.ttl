@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CogerUnaHerramientaDelAlmacen a ns1:AccionProhibida ;
    rdfs:label "Coger una herramienta del almacén" ;
    ns1:textoExtracto "Coger una herramienta del almacén y ponerla en el brazo (pinza ꞏ1ꞏ)." .

ns1:DejarLaHerramientaDelBrazo a ns1:AccionProhibida ;
    rdfs:label "Dejar la herramienta del brazo" ;
    ns1:textoExtracto "Dejar la herramienta del brazo (pinza ꞏ2ꞏ) en el almacén." .

ns1:RegistroLEAVEPOS_bf2ec2760d a ns1:Parametro ;
    rdfs:label "Registro LEAVEPOS" ;
    ns1:identificador "LEAVEPOS" ;
    ns1:textoExtracto "Las señales TAKEPOS y LEAVEPOS pueden tomar los siguientes valores." .

ns1:RegistroTAKEPOS_6b8e93e912 a ns1:Parametro ;
    rdfs:label "Registro TAKEPOS" ;
    ns1:identificador "TAKEPOS" ;
    ns1:textoExtracto "Las señales TAKEPOS y LEAVEPOS pueden tomar los siguientes valores." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor." .

