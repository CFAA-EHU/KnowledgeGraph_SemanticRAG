@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaValoresOperacionesPLC a ns1:Tabla ;
    rdfs:label "Tabla de valores TAKEPOS y LEAVEPOS" ;
    ns1:ilustra ns1:MarcaTCHANGEOK,
        ns1:ValorLEAVEPOS,
        ns1:ValorTAKEPOS ;
    ns1:textoExtracto "A continuación se muestra una tabla resumen de los valores TAKEPOS y LEAVEPOS que utiliza el gestor en cada una de las operaciones, así como las marcas que debe activar el PLC al finalizar cada operación." .

ns1:MarcaTCHANGEOK a ns1:Parametro ;
    rdfs:label "Marca TCHANGEOK" ;
    ns1:textoExtracto "La marca TCHANGEOK es opcional y sólo se debe utilizar cuando es posible. Una vez efectuado el cambio y la herramienta está en el brazo, activar la marca TCHANGEOK para continuar la ejecución del programa mientras se deja la herramienta en el almacén." .

ns1:ValorLEAVEPOS a ns1:Parametro ;
    rdfs:label "Valor LEAVEPOS" ;
    ns1:textoExtracto "A continuación se muestra una tabla resumen de los valores TAKEPOS y LEAVEPOS que utiliza el gestor en cada una de las operaciones, así como las marcas que debe activar el PLC al finalizar cada operación." .

ns1:ValorTAKEPOS a ns1:Parametro ;
    rdfs:label "Valor TAKEPOS" ;
    ns1:textoExtracto "A continuación se muestra una tabla resumen de los valores TAKEPOS y LEAVEPOS que utiliza el gestor en cada una de las operaciones, así como las marcas que debe activar el PLC al finalizar cada operación." .

