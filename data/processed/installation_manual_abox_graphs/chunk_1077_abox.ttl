@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Motor1 a ex:ComponenteMecanico ;
    rdfs:label "motor"@es ;
    ex:textoExtracto "ambos motores están controlados por el mismo regulador"@es .

ex:Motor2 a ex:ComponenteMecanico ;
    rdfs:label "motor"@es ;
    ex:textoExtracto "ambos motores están controlados por el mismo regulador"@es .

ex:Regulador a ex:ComponenteElectrico ;
    rdfs:label "regulador"@es ;
    ex:textoExtracto "ambos motores están controlados por el mismo regulador"@es ;
    ex:controla ex:Motor1, ex:Motor2 .

ex:Eje1 a ex:ComponenteMecanico ;
    rdfs:label "eje"@es ;
    ex:textoExtracto "Hay máquinas donde existen 2 ejes que nunca están de forma simultánea en la misma configuración"@es .

ex:Eje2 a ex:ComponenteMecanico ;
    rdfs:label "eje"@es ;
    ex:textoExtracto "Hay máquinas donde existen 2 ejes que nunca están de forma simultáneamente en la misma configuración"@es .

ex:Parametro_COUNTERTYPE a ex:Parametro ;
    rdfs:label "COUNTERTYPE"@es ;
    ex:textoExtracto "Para utilizar la misma entrada de captación, los parámetros COUNTERTYPE y COUNTERID de ambos ejes debe ser iguales."@es .

ex:Parametro_COUNTERID a ex:Parametro ;
    rdfs:label "COUNTERID"@es ;
    ex:textoExtracto "Para utilizar la misma entrada de captación, los parámetros COUNTERTYPE y COUNTERID de ambos ejes debe ser iguales."@es .

ex:Parametro_ANAOUTID a ex:Parametro ;
    rdfs:label "ANAOUTID"@es ;
    ex:textoExtracto "Para utilizar la misma salida analógica, el parámetro ANAOUTID de ambos ejes también debe ser igual."@es .

ex:Parametro_ABSFEEDBACK a ex:Parametro ;
    rdfs:label "ABSFEEDBACK"@es ;
    ex:textoExtracto "ABSFEEDBACK | Tipo de captación."@es .

ex:Parametro_SINMAGNI a ex:Parametro ;
    rdfs:label "SINMAGNI"@es ;
    ex:textoExtracto "SINMAGNI | Factor multiplicador de la señal sinusoidal."@es .

ex:Parametro_I0TYPE a ex:Parametro ;
    rdfs:label "I0TYPE"@es ;
    ex:textoExtracto "I0TYPE | Tipo de I0."@es .

ex:Parametro_REFPULSE a ex:Parametro ;
    rdfs:label "REFPULSE"@es ;
    ex:textoExtracto "REFPULSE | Flanco de la señal de I0."@es .

ex:Parametro_ABSOFF a ex:Parametro ;
    rdfs:label "ABSOFF"@es ;
    ex:textoExtracto "ABSOFF | Offset del captador respecto a I0."@es .

ex:Parametro_EXTMULT a ex:Parametro ;
    rdfs:label "EXTMULT"@es ;
    ex:textoExtracto "EXTMULT | Factor multiplicador externo."@es .

ex:Parametro_I0CODDI1 a ex:Parametro ;
    rdfs:label "I0CODDI1"@es ;
    ex:textoExtracto "I0CODDI1 | Paso entre señales de I0 fijas."@es .

ex:Parametro_I0CODDI2 a ex:Parametro ;
    rdfs:label "I0CODDI2"@es ;
    ex:textoExtracto "I0CODDI2 | Paso entre señales de I0 variables."@es .

ex:SistemaControlEjes a ex:Sistema ;
    rdfs:label "sistema de control de ejes"@es ;
    ex:textoExtracto "Hay máquinas donde existen 2 ejes que nunca están de forma simultánea en la misma configuración"@es ;
    ex:compuestoPor ex:Eje1, ex:Eje2, ex:Motor1, ex:Motor2, ex:Regulador ;
    ex:tieneComponente ex:Parametro_COUNTERTYPE, ex:Parametro_COUNTERID, ex:Parametro_ANAOUTID, ex:Parametro_ABSFEEDBACK, ex:Parametro_SINMAGNI, ex:Parametro_I0TYPE, ex:Parametro_REFPULSE, ex:Parametro_ABSOFF, ex:Parametro_EXTMULT, ex:Parametro_I0CODDI1, ex:Parametro_I0CODDI2 .