@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Motor1 a ex:ComponenteMecanico ;
    rdfs:label "motor" ;
    ex:textoExtracto "motor" .

ex:GrupoMultieje1 a ex:Sistema ;
    rdfs:label "Grupo multieje compuesto por dos ejes controlados por un único motor" ;
    ex:textoExtracto "Grupo multieje compuesto por dos ejes controlados por un único motor" ;
    ex:compuestoPor ex:Motor1 .

ex:Regulador1 a ex:Actuador ;
    rdfs:label "regulador" ;
    ex:textoExtracto "regulador" .

ex:Eje1 a ex:ComponenteMecanico ;
    rdfs:label "eje" ;
    ex:textoExtracto "eje" .

ex:Eje2 a ex:ComponenteMecanico ;
    rdfs:label "eje" ;
    ex:textoExtracto "eje" .

ex:GrupoMultieje1 ex:compuestoPor ex:Eje1, ex:Eje2 .

ex:ModoOperacionSercosPosicion a ex:ModoOperacion ;
    rdfs:label "modo Sercos posición" ;
    ex:textoExtracto "modo Sercos posición" .

ex:ModoOperacionSercosVelocidad a ex:ModoOperacion ;
    rdfs:label "modo Sercos velocidad" ;
    ex:textoExtracto "modo Sercos velocidad" .

ex:ParametroDRIVEID a ex:Parametro ;
    rdfs:label "parámetro DRIVEID" ;
    ex:textoExtracto "parámetro DRIVEID" .

ex:ParametroOPMODEP a ex:Parametro ;
    rdfs:label "parámetro OPMODEP" ;
    ex:textoExtracto "parámetro OPMODEP" .