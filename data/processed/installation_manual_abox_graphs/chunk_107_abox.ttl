@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceiteHidraulicoISO46 a ns1:Consumible ;
    rdfs:label "Retardo de 8 ms" ;
    ns1:requiereConsumible ns1:ConfiguracionDeRetardoEnRS485 ;
    ns1:textoExtracto "Para asegurar una comunicación correcta, es necesario un retardo de 8 ms desde que el CNC deja de transmitir y está preparado para recibir datos." .

ns1:CNC8070_62b1ba4301 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "En la RS485, el CNC controla la recepción y transmisión de datos con la misma señal, de manera que durante la transmisión está deshabilitada la recepción." .

ns1:TipoDeLineaSerie a ns1:Parametro ;
    rdfs:label "Tipo de línea serie" ;
    ns1:identificador "MPG.RSTYPE" ;
    ns1:textoExtracto "RSTYPE Tipo de línea serie. Valores posibles: RS232 / RS485 / RS485. Valor por defecto: RS232." .

ns1:ConfiguracionDeRetardoEnRS485 a ns1:TareaMantenimiento ;
    rdfs:label "Configuración de retardo en RS485" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "Para asegurar una comunicación correcta, es necesario un retardo de 8 ms desde que el CNC deja de transmitir y está preparado para recibir datos." .

ns1:PersonalTecnicoAutorizado a ns1:Personal ;
    rdfs:label "Personal Técnico Autorizado" ;
    ns1:textoExtracto "Si no es posible parametrizar este retardo en el esclavo, se recomienda utilizar un adaptador externo RS232/RS485." .

