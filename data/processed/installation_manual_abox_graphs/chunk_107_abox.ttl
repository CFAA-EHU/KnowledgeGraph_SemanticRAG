@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TablaCompensacionCruzada_107 a ex:Tabla ;
    rdfs:label "Tabla de compensación cruzada"@es ;
    ex:textoExtracto "Este parámetro muestra la lista de puntos y valores de compensación."@es ;
    ex:textoExtracto "El CNC sólo permite acceder a esta tabla cuando están definidos los parámetros MOVAXIS, COMPAXIS y NPCROSS."@es ;
    ex:textoExtracto "En la tabla DATA se debe definir el error que se desea compensar en determinadas posiciones del eje que se mueve."@es ;
    ex:textoExtracto "El número de puntos viene definido por el parámetro NPCROSS."@es ;
    ex:textoExtracto "Para cada uno de los puntos se deben definir los parámetros POSITION, POSERROR y NEGERROR."@es ;
    ex:textoExtracto "El parámetro NEGERROR sólo se muestra si se ha definido la tabla con compensación bidireccional (BIDIR = Sí)."@es .

ex:ParametroMOVAXIS_107 a ex:Parametro ;
    rdfs:label "MOVAXIS"@es ;
    ex:textoExtracto "parámetros MOVAXIS"@es .

ex:ParametroCOMPAXIS_107 a ex:Parametro ;
    rdfs:label "COMPAXIS"@es ;
    ex:textoExtracto "parámetros COMPAXIS"@es .

ex:ParametroNPCROSS_107 a ex:Parametro ;
    rdfs:label "NPCROSS"@es ;
    ex:textoExtracto "parámetros NPCROSS"@es .

ex:ParametroDATA_107 a ex:Parametro ;
    rdfs:label "DATA"@es ;
    ex:textoExtracto "En la tabla DATA"@es .

ex:ParametroPOSITION_107 a ex:Parametro ;
    rdfs:label "POSITION"@es ;
    ex:textoExtracto "parámetros POSITION"@es .

ex:ParametroPOSERROR_107 a ex:Parametro ;
    rdfs:label "POSERROR"@es ;
    ex:textoExtracto "parámetros POSERROR"@es .

ex:ParametroNEGERROR_107 a ex:Parametro ;
    rdfs:label "NEGERROR"@es ;
    ex:textoExtracto "parámetros NEGERROR"@es .

ex:ParametroBIDIR_107 a ex:Parametro ;
    rdfs:label "BIDIR"@es ;
    ex:textoExtracto "compensación bidireccional (BIDIR = Sí)"@es .