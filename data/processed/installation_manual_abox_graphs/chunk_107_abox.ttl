@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaCompensacionCruzada_107 a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de compensación cruzada"@es ;
    ex:textoExtracto "Este parámetro muestra la lista de puntos y valores de compensación. [...] El número de puntos viene definido por el parámetro NPCROSS."@es ;
    ex:documentadoEn ex:Pagina_77_78_79 ;
    ex:tieneComponente ex:Parametro_NPCROSS_107 ,
                      ex:Parametro_MOVAXIS_107 ,
                      ex:Parametro_COMPAXIS_107 ,
                      ex:Parametro_POSITION_107 ,
                      ex:Parametro_POSERROR_107 ,
                      ex:Parametro_NEGERROR_107 ,
                      ex:Parametro_BIDIR_107 .

ex:Parametro_NPCROSS_107
    a               ex:Parametro ;
    rdfs:label      "NPCROSS"@es ;
    ex:textoExtracto "El número de puntos viene definido por el parámetro NPCROSS."@es ;
    ex:valor         "Número de puntos de compensación"@es .

ex:Parametro_MOVAXIS_107
    a               ex:Parametro ;
    rdfs:label      "MOVAXIS"@es ;
    ex:textoExtracto "El CNC sólo permite acceder a esta tabla cuando están definidos los parámetros MOVAXIS, COMPAXIS y NPCROSS."@es .

ex:Parametro_COMPAXIS_107
    a               ex:Parametro ;
    rdfs:label      "COMPAXIS"@es ;
    ex:textoExtracto "El CNC sólo permite acceder a esta tabla cuando están definidos los parámetros MOVAXIS, COMPAXIS y NPCROSS."@es .

ex:Parametro_POSITION_107
    a               ex:Parametro ;
    rdfs:label      "POSITION"@es ;
    ex:textoExtracto "Para cada uno de los puntos se deben definir los parámetros POSITION, POSERROR y NEGERROR."@es .

ex:Parametro_POSERROR_107
    a               ex:Parametro ;
    rdfs:label      "POSERROR"@es ;
    ex:textoExtracto "Para cada uno de los puntos se deben definir los parámetros POSITION, POSERROR y NEGERROR."@es .

ex:Parametro_NEGERROR_107
    a               ex:Parametro ;
    rdfs:label      "NEGERROR"@es ;
    ex:textoExtracto "El parámetro NEGERROR sólo se muestra si se ha definido la tabla con compensación bidireccional (BIDIR = Sí)."@es .

ex:Parametro_BIDIR_107
    a               ex:Parametro ;
    rdfs:label      "BIDIR"@es ;
    ex:textoExtracto "El parámetro NEGERROR sólo se muestra si se ha definido la tabla con compensación bidireccional (BIDIR = Sí)."@es ;
    ex:valor         "Sí/No"@es .

ex:Pagina_77_78_79
    a               ex:Pagina ;
    ex:identificador "77-79" ;
    ex:textoExtracto "Sección 2.3.16 Tablas de compensación cruzada"@es .