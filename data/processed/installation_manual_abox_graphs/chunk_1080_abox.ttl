@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaOperacionesPLC a ns1:Tabla ;
    rdfs:label "Tabla de Operaciones Válidas del PLC" ;
    ns1:ilustradoEn ns1:Pagina527,
        ns1:Pagina528,
        ns1:Pagina529 ;
    ns1:textoExtracto "Tabla con los códigos TMOPERATION, TAKEPOS, LEAVEPOS y sus respectivas marcas que activa el PLC." ;
    ns1:tieneComponente ns1:OperacionValidaDelPLC,
        ns1:Parametro_7959033478,
        ns1:Parametro_92b7e6b9ba,
        ns1:Parametro_d80576b55d,
        ns1:PosicionDeSalidaDelPLC,
        ns1:PosicionDeTomaDelPLC .

ns1:OperacionValidaDelPLC a ns1:Parametro ;
    rdfs:label "Operación válida del PLC" ;
    ns1:identificador "TMOPERATION" ;
    ns1:textoExtracto "Código TMOPERATION en la tabla de operaciones válidas y marcas que activa el PLC." .

ns1:Parametro_7959033478 a ns1:Parametro ;
    rdfs:label "Marca GRTOSPDL del PLC" ;
    ns1:identificador "GRTOSPDL" ;
    ns1:textoExtracto "Código GRTOSPDL en la tabla de operaciones válidas y marcas que activa el PLC." .

ns1:Parametro_92b7e6b9ba a ns1:Parametro ;
    rdfs:label "Marca MZTOCH1 del PLC" ;
    ns1:identificador "MZTOCH1" ;
    ns1:textoExtracto "Código MZTOCH1 en la tabla de operaciones válidas y marcas que activa el PLC." .

ns1:Parametro_d80576b55d a ns1:Parametro ;
    rdfs:label "Marca SPDLTOCH2 del PLC" ;
    ns1:identificador "SPDLTOCH2" ;
    ns1:textoExtracto "Código SPDLTOCH2 en la tabla de operaciones válidas y marcas que activa el PLC." .

ns1:PosicionDeSalidaDelPLC a ns1:Parametro ;
    rdfs:label "Posición de salida del PLC" ;
    ns1:identificador "LEAVEPOS" ;
    ns1:textoExtracto "Código LEAVEPOS en la tabla de operaciones válidas y marcas que activa el PLC." .

ns1:PosicionDeTomaDelPLC a ns1:Parametro ;
    rdfs:label "Posición de toma del PLC" ;
    ns1:identificador "TAKEPOS" ;
    ns1:textoExtracto "Código TAKEPOS en la tabla de operaciones válidas y marcas que activa el PLC." .

