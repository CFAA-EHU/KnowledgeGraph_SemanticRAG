@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoOperacion_SercosVelocidad a ex:ModoOperacion ;
    rdfs:label "modo Sercos velocidad"@es ;
    ex:textoExtracto "el eje sólo podrá operar en modo Sercos velocidad"@es .

ex:SistemaCaptacionExterna a ex:Sensor ;
    rdfs:label "captación externa"@es ;
    ex:textoExtracto "Si la captación externa (captación directa) del eje está conectada a una entrada de contaje local o remota"@es .

ex:EntradaConteoLocal a ex:ComponenteElectrico ;
    rdfs:label "entrada de contaje local"@es ;
    ex:textoExtracto "conectada a una entrada de contaje local o remota"@es .

ex:EntradaConteoRemota a ex:ComponenteElectrico ;
    rdfs:label "entrada de contaje remota"@es ;
    ex:textoExtracto "conectada a una entrada de contaje local o remota"@es .

ex:CNC a ex:Sistema ;
    rdfs:label "CNC"@es ;
    ex:textoExtracto "el CNC ejecuta la búsqueda de referencia"@es .

ex:EjeAnalogico a ex:ComponenteMecanico ;
    rdfs:label "eje analógico"@es ;
    ex:textoExtracto "como si el eje fuera analógico"@es .

ex:ReguladorEje a ex:ComponenteElectrico ;
    rdfs:label "regulador del eje"@es ;
    ex:textoExtracto "el regulador desconoce que hay una búsqueda de referencia en marcha"@es .

ex:BusquedaReferencia a ex:TareaMantenimiento ;
    rdfs:label "búsqueda de referencia"@es ;
    ex:textoExtracto "el CNC ejecuta la búsqueda de referencia como si el eje fuera analógico; el regulador desconoce que hay una búsqueda de referencia en marcha"@es .