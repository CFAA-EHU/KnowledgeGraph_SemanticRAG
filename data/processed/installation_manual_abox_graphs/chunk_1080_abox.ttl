@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoOperacion_SercosVelocidad
    a               ex:ModoOperacion ;
    rdfs:label      "Modo Sercos velocidad"@es ;
    ex:textoExtracto
        "el eje sólo podrá operar en modo Sercos velocidad"@es .

ex:Sistema_CaptacionExterna
    a               ex:Sistema ;
    rdfs:label      "Captación externa (directa) del eje"@es ;
    ex:textoExtracto
        "Si la captación externa (captación directa) del eje está conectada a una entrada de contaje local o remota"@es .

ex:Componente_EntradaContaje
    a               ex:ComponenteElectrico ;
    rdfs:label      "Entrada de contaje (local/remota)"@es ;
    ex:textoExtracto
        "entrada de contaje local o remota"@es .

ex:Sistema_CNC
    a               ex:Sistema ;
    rdfs:label      "CNC"@es ;
    ex:textoExtracto
        "el CNC ejecuta la búsqueda de referencia"@es ;
    ex:controla    ex:ModoOperacion_SercosVelocidad .

ex:TareaMantenimiento_BusquedaReferencia
    a               ex:TareaMantenimiento ;
    rdfs:label      "Búsqueda de referencia del eje"@es ;
    ex:textoExtracto
        "el CNC ejecuta la búsqueda de referencia como si el eje fuera analógico"@es ;
    ex:ejecutadoPor ex:Sistema_CNC .