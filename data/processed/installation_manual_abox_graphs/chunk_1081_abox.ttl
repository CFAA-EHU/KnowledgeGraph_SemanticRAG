@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:GestionMultieje_11_4
    a ex:ModoOperacion ;
    rdfs:label "Gestión multieje (CNC)" ;
    ex:textoExtracto "Si la captación externa es local o remota, el CNC ejecuta la búsqueda de referencia como si el eje fuera analógico; [...] Para un multieje donde el mismo motor controla varios ejes, el CNC permite realizar una gestión dinámica del multieje." .

ex:MotorMultieje_11_4
    a ex:ComponenteElectrico ;
    rdfs:label "Motor compartido en configuración multieje" ;
    ex:textoExtracto "Para un multieje donde el mismo motor controla varios ejes, el CNC permite realizar una gestión dinámica del multieje." ;
    ex:controla ex:EjeMaestro_11_4 ;
    ex:controla ex:EjeSecundario_11_4 .

ex:EjeMaestro_11_4
    a ex:ComponenteMecanico ;
    rdfs:label "Eje maestro (primer eje definido en MULAXISNAME_1)" ;
    ex:textoExtracto "Tras el encendido, el regulador controla el eje maestro del grupo, el primer eje definido en el grupo (parámetro MULAXISNAME_1)." ;
    ex:monitoreaParametro ex:Parametro_DEFAULTSET_11_4 ;
    ex:monitoreaParametro ex:Parametro_DWELL_11_4 .

ex:EjeSecundario_11_4
    a ex:ComponenteMecanico ;
    rdfs:label "Eje secundario (configurado como 'eje muerto' en multieje)" ;
    ex:textoExtracto "Para hacer la gestión dinámica de un multieje, hay que configurar los ejes del grupo como ejes muertos y definir el parámetro DWELL>0." ;
    ex:monitoreaParametro ex:Parametro_DWELL_11_4 .

ex:Parametro_DEFAULTSET_11_4
    a ex:Parametro ;
    rdfs:label "DEFAULTSET (set por defecto del eje)" ;
    ex:textoExtracto "El CNC asume el set por defecto del eje (parámetro DEFAULTSET)." ;
    ex:identificador "DEFAULTSET" .

ex:Parametro_DWELL_11_4
    a ex:Parametro ;
    rdfs:label "DWELL (tiempo de espera antes de error)" ;
    ex:textoExtracto "Los ejes utilizan el parámetro DWELL como tiempo de espera antes de dar error por no tener la marca SWITCH activa." ;
    ex:identificador "DWELL" ;
    ex:valor ">0" .

ex:ReguladorMultieje_11_4
    a ex:Actuador ;
    rdfs:label "Regulador de grupo multieje" ;
    ex:textoExtracto "El regulador desconoce que hay una búsqueda de referencia en marcha y no actualiza su cota, sólo recibe consigna de velocidad. [...] El regulador controla el eje maestro del grupo." ;
    ex:controla ex:EjeMaestro_11_4 ;
    ex:compuestoPor ex:MotorMultieje_11_4 .

ex:PLC_11_4
    a ex:InterfazUsuario ;
    rdfs:label "PLC (control lógico programable para gestión de ejes)" ;
    ex:textoExtracto "La selección del eje que gobierna el regulador se realiza desde el PLC (marca SWITCH(axis)). [...] El PLC debe aparcar o poner como visualizador los ejes que no gobierna el regulador." ;
    ex:controla ex:ReguladorMultieje_11_4 ;
    ex:habilitadoPor ex:Marca_SWITCH_11_4 ;
    ex:habilitadoPor ex:Marca_ENABLE_11_4 .

ex:Marca_SWITCH_11_4
    a ex:Parametro ;
    rdfs:label "SWITCH (señal de selección de eje)" ;
    ex:textoExtracto "La selección del eje que gobierna el regulador se realiza desde el PLC (marca SWITCH(axis)). [...] El PLC vigila qué marca ENABLE se activa, para engranar ese eje y activar su marca SWITCH, SERVOON, SPENA y DRENA." ;
    ex:identificador "SWITCH" .

ex:Marca_ENABLE_11_4
    a ex:Parametro ;
    rdfs:label "ENABLE (señal de activación de eje)" ;
    ex:textoExtracto "El PLC vigila qué marca ENABLE se activa, para engranar ese eje y activar su marca SWITCH, SERVOON, SPENA y DRENA." ;
    ex:identificador "ENABLE" .