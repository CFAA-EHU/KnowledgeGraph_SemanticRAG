@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Motor_1081_1 a ex:ComponenteMecanico ;
    ex:textoExtracto "el mismo motor controla varios ejes" .

ex:Parametro_DWELL_1081_1 a ex:Parametro ;
    ex:identificador "DWELL" ;
    ex:textoExtracto "definir el parámetro DWELL>0" .

ex:Parametro_DEFAULTSET_1081_1 a ex:Parametro ;
    ex:identificador "DEFAULTSET" ;
    ex:textoExtracto "el CNC asume el set por defecto del eje (parámetro DEFAULTSET)" .

ex:Parametro_MULAXISNAME_1_1081_1 a ex:Parametro ;
    ex:identificador "MULAXISNAME_1" ;
    ex:textoExtracto "el primer eje definido en el grupo (parámetro MULAXISNAME_1)" .

ex:Sistema_CNC_1081_1 a ex:Sistema ;
    ex:textoExtracto "el CNC ejecuta la búsqueda de referencia" , "el CNC permite realizar una gestión dinámica del multieje" , "El CNC mantiene la vigilancia (error de seguimiento, test de tendencia, etc)" .

ex:Sistema_PLC_1081_1 a ex:Sistema ;
    ex:textoExtracto "El PLC debe aparcar o poner como visualizador los ejes que no gobierna el regulador" , "El PLC vigila qué marca ENABLE se activa" , "la maniobra del PLC debe definir el set y la gama que asume el regulador" .

ex:Sistema_Regulador_1081_1 a ex:Sistema ;
    ex:textoExtracto "el regulador desconoce que hay una búsqueda de referencia en marcha" , "el regulador controla el eje maestro del grupo" .