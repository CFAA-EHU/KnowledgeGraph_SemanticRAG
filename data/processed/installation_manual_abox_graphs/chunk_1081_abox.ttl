@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaAlmacenamientoOperaciones a ns1:Sistema ;
    rdfs:label "Sistema de Almacenamiento Operaciones" ;
    ns1:textoExtracto "A continuación se muestra una descripción detallada de las operaciones válidas para este almacén." ;
    ns1:tieneComponente ns1:IdentificadorDeZona,
        ns1:PosicionDeSalida,
        ns1:PosicionDeToma,
        ns1:SiguientePosicion .

ns1:IdentificadorDeZona a ns1:Parametro ;
    rdfs:label "Identificador de zona" ;
    ns1:identificador "MZID" ;
    ns1:textoExtracto "Para cada operación se indica cuales de las señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas." .

ns1:PosicionDeSalida a ns1:Parametro ;
    rdfs:label "Posición de salida" ;
    ns1:identificador "LEAVEPOS" ;
    ns1:textoExtracto "Las señales TAKEPOS, LEAVEPOS y NEXTPOS pueden tomar los siguientes valores." .

ns1:PosicionDeToma a ns1:Parametro ;
    rdfs:label "Posición de toma" ;
    ns1:identificador "TAKEPOS" ;
    ns1:textoExtracto "Las señales TAKEPOS, LEAVEPOS y NEXTPOS pueden tomar los siguientes valores." .

ns1:SiguientePosicion a ns1:Parametro ;
    rdfs:label "Siguiente posición" ;
    ns1:identificador "NEXTPOS" ;
    ns1:textoExtracto "Las señales TAKEPOS, LEAVEPOS y NEXTPOS pueden tomar los siguientes valores." .

