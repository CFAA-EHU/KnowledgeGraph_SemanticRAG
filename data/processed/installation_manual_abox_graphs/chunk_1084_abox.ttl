@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_3870df7ced a ns1:AccionProhibida ;
    rdfs:label "Accion de poner la herramienta del brazo en el cabezal" ;
    ns1:textoExtracto "3 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y" .

ns1:AccionProhibida_58447f02a1 a ns1:AccionProhibida ;
    rdfs:label "Accion de coger la herramienta del cabezal con la pinza 2" ;
    ns1:textoExtracto "1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2." .

ns1:AccionProhibida_cb41399c83 a ns1:AccionProhibida ;
    rdfs:label "Accion de dejar la herramienta en el almacén" ;
    ns1:textoExtracto "2 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ." .

ns1:Componente_15d4a71b65 a ns1:Componente ;
    rdfs:label "Herramienta del brazo" ;
    ns1:textoExtracto "TAKEPOS=-1 Herramienta en el brazo cambiador." .

ns1:Componente_d57bb7c16f a ns1:Componente ;
    rdfs:label "Herramienta del cabezal" ;
    ns1:textoExtracto "1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2." .

ns1:OperacionDeCogerLaHerramientaDelAlmacenConLaPinza1 a ns1:AccionProhibida ;
    rdfs:label "Operación de coger la herramienta del almacén con la pinza 1" ;
    ns1:textoExtracto "el gestor envía el código TMOPERATION=11 para coger la herramienta del almacén con la pinza 1." .

ns1:PosicionAlmacen a ns1:Parametro ;
    rdfs:label "Posición del almacén para dejar la herramienta" ;
    ns1:identificador "LEAVEPOS" ;
    ns1:textoExtracto "LEAVEPOS=# Posición del almacén para dejar la herramienta." .

ns1:SistemaAlmacenHerramientas a ns1:Sistema ;
    rdfs:label "Sistema de almacenamiento de herramientas" ;
    ns1:textoExtracto "Las herramientas del cabezal y del brazo son del mismo almacén." .

