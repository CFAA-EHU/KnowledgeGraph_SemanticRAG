@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_MULTIAXIS a ex:Parametro ;
    rdfs:label "MULTIAXIS" ;
    ex:textoExtracto "Parámetro. | Significado. | MULTIAXIS | Tabla de grupos multieje." ;
    ex:valor "Tabla de grupos multieje" .

ex:Parametro_MULNGROUP a ex:Parametro ;
    rdfs:label "MULNGROUP" ;
    ex:textoExtracto "Parámetro. | Significado. | MULNGROUP | Número de grupos multieje en el sistema." ;
    ex:valor "Número de grupos multieje en el sistema" .

ex:Parametro_GROUP_n a ex:Parametro ;
    rdfs:label "GROUP n" ;
    ex:textoExtracto "Parámetro. | Significado. | GROUP n | Grupos multieje." ;
    ex:valor "Grupos multieje" .

ex:Parametro_MULNAXIS a ex:Parametro ;
    rdfs:label "MULNAXIS" ;
    ex:textoExtracto "Parámetro. | Significado. | MULNAXIS | Número de ejes y/o cabezales que forman el grupo multieje." ;
    ex:valor "Número de ejes y/o cabezales que forman el grupo multieje" .

ex:Parametro_MULAXISNAME_n a ex:Parametro ;
    rdfs:label "MULAXISNAME n" ;
    ex:textoExtracto "Parámetro. | Significado. | MULAXISNAME n | Nombre de los ejes y/o cabezales del grupo." ;
    ex:valor "Nombre de los ejes y/o cabezales del grupo" .

ex:Tabla_MULTIAXIS a ex:Tabla ;
    ex:textoExtracto "El parámetro MULTIAXIS muestra la tabla de definición de los grupos multieje, donde hay que definir el número de grupos del sistema y la composición de cada grupo." ;
    ex:detalladoEnEsquema ex:Parametro_MULTIAXIS .

ex:Sistema_GruposMultieje a ex:Sistema ;
    ex:textoExtracto "Los grupos multieje se configuran desde los parámetros máquina. Cada grupo multieje dispone de los siguientes parámetros máquina generales para su configuración." ;
    ex:compuestoPor ex:Parametro_MULNGROUP, ex:Parametro_GROUP_n, ex:Parametro_MULNAXIS, ex:Parametro_MULAXISNAME_n .