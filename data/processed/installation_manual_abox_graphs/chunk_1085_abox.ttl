@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_1df0d763bb a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "En esta operación, el gestor admite dos secuencias." .

ns1:Parametro_1823548c27 a ns1:Parametro ;
    rdfs:label "Marca para poner la herramienta de la pinza 1 en el cabezal" ;
    ns1:identificador "CH1TOSPDL" ;
    ns1:textoExtracto "3 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL." .

ns1:Parametro_63e02acfc4 a ns1:Parametro ;
    rdfs:label "Marca para dejar la herramienta de la pinza 2 en el almacén" ;
    ns1:identificador "CH2TOMZ" ;
    ns1:textoExtracto "2 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ." .

ns1:Parametro_7959033478 a ns1:Parametro ;
    rdfs:label "Marca para poner la herramienta de tierra en el cabezal" ;
    ns1:identificador "GRTOSPDL" ;
    ns1:textoExtracto "3 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

ns1:Parametro_d80576b55d a ns1:Parametro ;
    rdfs:label "Marca para mover la herramienta del cabezal a la pinza 2" ;
    ns1:identificador "SPDLTOCH2" ;
    ns1:textoExtracto "1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2." .

ns1:PrimeraSecuenciaDeOperacionesDelAlmacen a ns1:AccionProhibida ;
    rdfs:label "Primera secuencia de operaciones del almacén" ;
    ns1:activaAlarma ns1:SegundaSecuenciaDeOperacionesDelAlmacen ;
    ns1:solucionaFallo ns1:SegundaSecuenciaDeOperacionesDelAlmacen ;
    ns1:textoExtracto "Primera secuencia: 1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 2 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ. 3 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

ns1:SegundaSecuenciaDeOperacionesDelAlmacen a ns1:AccionProhibida ;
    rdfs:label "Segunda secuencia de operaciones del almacén" ;
    ns1:textoExtracto "Segunda secuencia: 1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 2 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

