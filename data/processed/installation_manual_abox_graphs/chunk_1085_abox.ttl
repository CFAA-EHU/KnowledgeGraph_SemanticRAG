@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla_1085_1 a ex:Tabla ;
    ex:textoExtracto "La tabla muestra un parámetro MUMLAXISNAME_n por cada eje o cabezal que forma parte del grupo multieje."@es .

ex:Parametro_MUMLAXISNAME_n a ex:Parametro ;
    ex:textoExtracto "un parámetro MUMLAXISNAME_n por cada eje o cabezal que forma parte del grupo multieje"@es .

ex:EjeMaestro_1085 a ex:ComponenteMecanico ;
    ex:textoExtracto "el primer eje del grupo será el eje maestro, el que por defecto utilizará el regulador"@es .

ex:EjeSercos_1085 a ex:ComponenteMecanico ;
    ex:textoExtracto "Puede formar parte de un grupo cualquier eje Sercos del sistema"@es .

ex:Regulador_1085 a ex:ComponenteElectrico ;
    ex:textoExtracto "el regulador"@es ;
    ex:textoExtracto "Configurar el set del regulador a utilizar."@es .

ex:SistemaCNC_1085 a ex:Maquina ;
    ex:textoExtracto "el CNC"@es ;
    ex:textoExtracto "En el arranque del sistema, el CNC utilizará los parámetros del eje maestro para realizar la homogeneización de parámetros con el regulador."@es .

ex:Tabla_1085_1 a ex:Tabla ;
    ex:tieneComponente ex:Parametro_MUMLAXISNAME_n .
ex:EjeSercos_1085 ex:compuestoPor ex:Parametro_MUMLAXISNAME_n .
ex:SistemaCNC_1085 ex:tieneComponente ex:EjeMaestro_1085 .
ex:SistemaCNC_1085 ex:tieneComponente ex:EjeSercos_1085 .
ex:EjeMaestro_1085 ex:controla ex:Regulador_1085 .
ex:SistemaCNC_1085 ex:controla ex:Regulador_1085 .