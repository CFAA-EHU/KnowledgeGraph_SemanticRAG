@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioDeHerramientaEnElAlmacen a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta en el almacén" ;
    ns1:solucionaFallo ns1:DiagnosticoFalloHerramientaIncorrecta ;
    ns1:textoExtracto "Segunda secuencia: 1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 2 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

ns1:Parametro_384c3b5bc7 a ns1:Parametro ;
    rdfs:label "Marca para indicar que se ha abandonado la zona de posible colisión" ;
    ns1:identificador "TCHANGEOK" ;
    ns1:textoExtracto "4 Al abandonar el brazo la zona de posible colisión activar TCHANGEOK, si se desea, para que continúe la ejecución del programa." .

ns1:Parametro_63e02acfc4 a ns1:Parametro ;
    rdfs:label "Marca para indicar que se ha dejado la herramienta en el almacén" ;
    ns1:identificador "CH2TOMZ" ;
    ns1:textoExtracto "5 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ." .

ns1:Parametro_7959033478 a ns1:Parametro ;
    rdfs:label "Marca para indicar que se ha puesto la herramienta de tierra en el cabezal" ;
    ns1:identificador "GRTOSPDL" ;
    ns1:textoExtracto "2 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

ns1:Parametro_d80576b55d a ns1:Parametro ;
    rdfs:label "Marca para indicar que se ha cogido la herramienta del cabezal" ;
    ns1:identificador "SPDLTOCH2" ;
    ns1:textoExtracto "1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2." .

ns1:PinzaParaCambiarHerramientas a ns1:ComponenteElectrico ;
    rdfs:label "Pinza para cambiar herramientas" ;
    ns1:textoExtracto "1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2." .

ns1:SistemaAlmacenHerramientas a ns1:Sistema ;
    rdfs:label "Sistema de almacenamiento de herramientas" ;
    ns1:textoExtracto "3 Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza ꞏ2ꞏ." .

