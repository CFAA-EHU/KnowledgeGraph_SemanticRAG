@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_DRIVESET a ex:Parametro ;
    rdfs:label "DRIVESET" ;
    ex:identificador "DRIVESET" ;
    ex:textoExtracto "Parámetro. | Significado. | DRIVESET | Set del regulador a utilizar." ;
    ex:valor "Set del regulador a utilizar" .

ex:Parametro_FFGAIN a ex:Parametro ;
    rdfs:label "FFGAIN" ;
    ex:identificador "FFGAIN" ;
    ex:textoExtracto "feed forward (parámetro FFGAIN)" .

ex:Parametro_ACFGAIN a ex:Parametro ;
    rdfs:label "ACFGAIN" ;
    ex:identificador "ACFGAIN" ;
    ex:textoExtracto "AC forward (parámetro ACFGAIN)" .

ex:Parametro_Homogeneizacion a ex:Parametro ;
    rdfs:label "Homogeneización" ;
    ex:textoExtracto "Con la homogeneización activa, el CNC envía los parámetros del set ꞏ1ꞏ del eje maestro al set ꞏ0ꞏ y a la gama ꞏ1ꞏ (la primera) del regulador." .

ex:Parametro_CNC a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "el CNC envía los cambios de Kv, feed forward (parámetro FFGAIN) y AC forward (parámetro ACFGAIN) al set indicado en este parámetro." .

ex:Parametro_Regulador a ex:ComponenteElectrico ;
    rdfs:label "Regulador" ;
    ex:textoExtracto "el parámetro DRIVESET indica la gama a activar en el regulador tras un cambio de set o gama en el CNC" .