@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioDeHerramientaDelAlmacen a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta del almacén" ;
    ns1:textoExtracto "La secuencia de esta operación es la siguiente. Previamente, durante el mecanizado (al ejecutar la T), el gestor envía el código TMOPERATION=11 para coger la herramienta del almacén con la pinza 1." .

ns1:CodigoDeOperacionParaCogerHerramientaDeTierra a ns1:Parametro ;
    rdfs:label "Código de operación para coger herramienta de tierra" ;
    ns1:identificador "TMOPERATION=8" ;
    ns1:textoExtracto "TMOPERATION = 8 Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra." .

ns1:CodigoDeOperacionParaCogerHerramientaDelAlmacen a ns1:Parametro ;
    rdfs:label "Código de operación para coger herramienta del almacén" ;
    ns1:identificador "TMOPERATION=11" ;
    ns1:textoExtracto "el gestor envía el código TMOPERATION=11 para coger la herramienta del almacén con la pinza 1." .

ns1:CodigoDeOperacionParaCogerHerramientaDelAlmacen_a1eeaf0b1b a ns1:Parametro ;
    rdfs:label "Código de operación para coger herramienta del almacén" ;
    ns1:identificador "TMOPERATION=9" ;
    ns1:textoExtracto "TMOPERATION = 9 Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal." .

ns1:CogerHerramientaDeTierra a ns1:TareaMantenimiento ;
    rdfs:label "Coger herramienta de tierra" ;
    ns1:textoExtracto "TMOPERATION = 8 Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra." .

ns1:CogerHerramientaDelAlmacenYLlevarlaATierraPasandoPorElCabezal a ns1:TareaMantenimiento ;
    rdfs:label "Coger herramienta del almacén y llevarla a tierra pasando por el cabezal" ;
    ns1:textoExtracto "TMOPERATION = 9 Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal." .

ns1:DejarHerramientaEnElAlmacen a ns1:TareaMantenimiento ;
    rdfs:label "Dejar herramienta en el almacén" ;
    ns1:textoExtracto "5 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ." .

ns1:DejarHerramientaEnTierra_dbe116b771 a ns1:TareaMantenimiento ;
    rdfs:label "Dejar herramienta en tierra" ;
    ns1:textoExtracto "1 Dejar la herramienta del cabezal en tierra y activar la marca SPDLTOGR." .

ns1:Parametro_1823548c27 a ns1:Parametro ;
    rdfs:label "Marca para poner herramienta en el cabezal" ;
    ns1:identificador "CH1TOSPDL" ;
    ns1:textoExtracto "activar la marca CH1TOSPDL." .

ns1:Parametro_63e02acfc4 a ns1:Parametro ;
    rdfs:label "Marca para dejar herramienta en el almacén" ;
    ns1:identificador "CH2TOMZ" ;
    ns1:textoExtracto "activar la marca CH2TOMZ." .

ns1:Parametro_7959033478 a ns1:Parametro ;
    rdfs:label "Marca para poner herramienta de tierra en el cabezal" ;
    ns1:identificador "GRTOSPDL" ;
    ns1:textoExtracto "activar la marca GRTOSPDL." .

ns1:Parametro_aed1a67bbe a ns1:Parametro ;
    rdfs:label "Marca para dejar herramienta en tierra" ;
    ns1:identificador "SPDLTOGR" ;
    ns1:textoExtracto "activar la marca SPDLTOGR." .

ns1:PonerHerramientaDeTierraEnElCabezal a ns1:TareaMantenimiento ;
    rdfs:label "Poner herramienta de tierra en el cabezal" ;
    ns1:textoExtracto "2 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

ns1:PonerHerramientaEnElCabezal a ns1:TareaMantenimiento ;
    rdfs:label "Poner herramienta en el cabezal" ;
    ns1:textoExtracto "2 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL." .

