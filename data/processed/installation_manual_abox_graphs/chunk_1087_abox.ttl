@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:COUNTERTYPE a ex:Parametro ;
    ex:textoExtracto "Parámetro. Significado. COUNTERTYPE Tipo de entrada de captación del eje; regulador, local o remota." ;
    rdfs:label "COUNTERTYPE" .

ex:COUNTERID a ex:Parametro ;
    ex:textoExtracto "Parámetro. Significado. COUNTERID Número de la entrada de captación del eje." ;
    rdfs:label "COUNTERID" .

ex:Regulador a ex:ComponenteElectrico ;
    ex:textoExtracto "Tipo de entrada de captación del eje. La captación interna (motor) de ambos ejes esta ubicada en el regulador." ;
    rdfs:label "Regulador" .

ex:ModuloRemoto a ex:ComponenteElectrico ;
    ex:textoExtracto "en los módulos remotos (4 entradas por módulo, TTL diferencial y senoidal 1 Vpp)" ;
    rdfs:label "Módulo remoto" .

ex:UnidadCentral a ex:ComponenteElectrico ;
    ex:textoExtracto "en las entradas de captación locales de la unidad central" ;
    rdfs:label "Unidad central" .

ex:Motor a ex:ComponenteMecanico ;
    ex:textoExtracto "La captación interna (motor) de ambos ejes esta ubicada en el regulador." ;
    rdfs:label "Motor" .

ex:SistemaMultieje a ex:Sistema ;
    ex:textoExtracto "Configuración de un grupo multieje" ;
    rdfs:label "Sistema multieje" .