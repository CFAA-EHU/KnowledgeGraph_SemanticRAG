@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Motor1 a ex:ComponenteMecanico ;
    ex:textoExtracto "Motor" ;
    rdfs:label "Motor" .

ex:ParametroFeedback1 a ex:Parametro ;
    ex:textoExtracto "Feedback" ;
    rdfs:label "Feedback" .

ex:ParametroDirect1 a ex:Parametro ;
    ex:textoExtracto "Direct" ;
    rdfs:label "Direct" .

ex:ParametroCounterDigital1 a ex:Parametro ;
    ex:textoExtracto "COUNTER DIGITAL INPUT" ;
    rdfs:label "COUNTER DIGITAL INPUT" .

ex:ParametroCountType1 a ex:Parametro ;
    ex:textoExtracto "COUNTERTYPE = Local" ;
    rdfs:label "COUNTERTYPE = Local" .

ex:SistemaConfiguracionMultieje1 a ex:Sistema ;
    ex:textoExtracto "Configuración de un grupo multieje" ;
    ex:tieneComponente ex:Motor1, ex:ParametroFeedback1, ex:ParametroDirect1, ex:ParametroCounterDigital1, ex:ParametroCountType1 ;
    rdfs:label "Configuración de un grupo multieje" .