@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:OperacionDeCogerUnaHerramientaDelAlmacenYDejarlaEnTierra a ns1:AccionProhibida ;
    rdfs:label "Operación de coger una herramienta del almacén y dejarla en tierra" ;
    ns1:activaAlarma ns1:OperacionDeDejarLaHerramientaDelCabezalEnTierra,
        ns1:OperacionDePonerLaHerramientaDeLaPinzaEnElCabezal ;
    ns1:textoExtracto "TMOPERATION = 10 Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal." .

ns1:OperacionDeCogerUnaHerramientaDelAlmacenYDejarlaEnTierra_2637c0c430 a ns1:Parametro ;
    rdfs:label "Operación de coger una herramienta del almacén y dejarla en tierra" ;
    ns1:textoExtracto "TMOPERATION = 10 Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal." .

ns1:OperacionDeCogerUnaHerramientaDelAlmacenYPonerlaEnElBrazo a ns1:AccionProhibida ;
    rdfs:label "Operación de coger una herramienta del almacén y ponerla en el brazo" ;
    ns1:textoExtracto "TMOPERATION = 11 Coger una herramienta del almacén y ponerla en el brazo." .

ns1:OperacionDeCogerUnaHerramientaDelAlmacenYPonerlaEnElBrazo_be3bbf010c a ns1:Parametro ;
    rdfs:label "Operación de coger una herramienta del almacén y ponerla en el brazo" ;
    ns1:textoExtracto "TMOPERATION = 11 Coger una herramienta del almacén y ponerla en el brazo." .

ns1:OperacionDeDejarLaHerramientaDelCabezalEnTierra a ns1:AccionProhibida ;
    rdfs:label "Operación de dejar la herramienta del cabezal en tierra" ;
    ns1:textoExtracto "2 Dejar la herramienta del cabezal en tierra y activar la marca SPDLTOGR." .

ns1:OperacionDePonerLaHerramientaDeLaPinzaEnElCabezal a ns1:AccionProhibida ;
    rdfs:label "Operación de poner la herramienta de la pinza en el cabezal" ;
    ns1:textoExtracto "1 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL." .

