@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CogerUnaHerramientaDelAlmacenYPonerlaEnElBrazo_149b70c370 a ns1:TareaMantenimiento ;
    rdfs:label "Coger una herramienta del almacén y ponerla en el brazo" ;
    ns1:activaAlarma ns1:Parametro_92b7e6b9ba ;
    ns1:textoExtracto "TMOPERATION = 11 Coger una herramienta del almacén y ponerla en el brazo. Esta operación es una optimización del cambio de herramienta que permite colocar una herramienta en la pinza ꞏ1ꞏ del brazo cambiador durante el mecanizado." .

ns1:DejarLaHerramientaDelCabezalEnElAlmacenYCogerUnaHerramientaDelBrazo_6188ce8c79 a ns1:TareaMantenimiento ;
    rdfs:label "Dejar la herramienta del cabezal en el almacén y coger una herramienta del brazo" ;
    ns1:textoExtracto "TMOPERATION = 14 Dejar la herramienta del cabezal en el almacén y coger una herramienta del brazo. Las herramientas del cabezal y del brazo son de almacenes diferentes." .

ns1:DejarLaHerramientaDelCabezalEnElAlmacenYCogerUnaHerramientaDelMismoAlmacen_ab312c8d05 a ns1:TareaMantenimiento ;
    rdfs:label "Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén" ;
    ns1:activaAlarma ns1:Parametro_fa5bf031fb ;
    ns1:textoExtracto "TMOPERATION = 12 Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén (como TMOPERATION=5)." .

ns1:IdentificadorDeAlmacen_8732dee42a a ns1:Parametro ;
    rdfs:label "Identificador de almacén" ;
    ns1:identificador "MZID" ;
    ns1:textoExtracto "MZID En la parte baja de este registro se indica el almacén en el que hay que dejar la herramienta y en la parte alta el almacén del que hay que coger la herramienta." .

ns1:Parametro_92b7e6b9ba a ns1:Parametro ;
    rdfs:label "Marca para coger herramienta" ;
    ns1:identificador "MZTOCH1" ;
    ns1:textoExtracto "activar la marca MZTOCH1." .

ns1:Parametro_fa5bf031fb a ns1:Parametro ;
    rdfs:label "Marca para dejar herramienta" ;
    ns1:identificador "CH1TOMZ" ;
    ns1:textoExtracto "activar la marca CH1TOMZ." .

