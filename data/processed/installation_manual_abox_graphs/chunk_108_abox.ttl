@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_CrossCompData a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla CROSSCOMP DATA"@es ;
    ex:textoExtracto """
| CROSSCOMP DATA |  |
| --- | --- |
| POSITION | Posición del eje maestro. |
| POSERROR | Error a compensar en los desplazamientos en sentido positivo. |
| NEGERROR | Error a compensar en los desplazamientos en sentido negativo.
"""@es ;
    ex:identificador "CROSSCOMP DATA" ;
    ex:tieneComponente ex:Parametro_POSITION, ex:Parametro_POSERROR, ex:Parametro_NEGERROR .

ex:Parametro_POSITION
    a ex:Parametro ;
    rdfs:label "POSITION" ;
    ex:textoExtracto "Posición del eje maestro."@es ;
    ex:identificador "POSITION" .

ex:Parametro_POSERROR
    a ex:Parametro ;
    rdfs:label "POSERROR" ;
    ex:textoExtracto "Error a compensar en los desplazamientos en sentido positivo."@es ;
    ex:identificador "POSERROR" .

ex:Parametro_NEGERROR
    a ex:Parametro ;
    rdfs:label "NEGERROR" ;
    ex:textoExtracto "Error a compensar en los desplazamientos en sentido negativo."@es ;
    ex:identificador "NEGERROR" .