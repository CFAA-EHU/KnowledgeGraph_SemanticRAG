@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla_108 a ex:Tabla ;
    ex:textoExtracto """| CROSSCOMP
DATA |  |
| --- | --- |
| POSITION | Posición del eje maestro. |
| POSERROR | Error a compensar en los desplazamientos en sentido
positivo. |
| NEGERROR | Error a compensar en los desplazamientos en sentido
negativo. |""" ;
    ex:tieneComponente ex:POSITION, ex:POSERROR, ex:NEGERROR .

ex:POSITION a ex:Parametro ;
    ex:textoExtracto "POSITION | Posición del eje maestro." .

ex:POSERROR a ex:Parametro ;
    ex:textoExtracto "NEGERROR | Error a compensar en los desplazamientos en sentido positivo." .

ex:NEGERROR a ex:Parametro ;
    ex:textoExtracto "NEGERROR | Error a compensar en los desplazamientos en sentido negativo." .