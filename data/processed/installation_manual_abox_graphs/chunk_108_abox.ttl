@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarElServidorModBUSSobreRS485 a ns1:Parametro ;
    rdfs:label "Activar el servidor ModBUS sobre RS485" ;
    ns1:identificador "MPG.MODBUSSVRRS" ;
    ns1:textoExtracto "MODBUSSVRRS Activar el servidor ModBUS sobre RS485. Valores posibles: Sí / No. Valor por defecto: No." .

ns1:ActivarElServidorModBUSSobreTCP a ns1:Parametro ;
    rdfs:label "Activar el servidor ModBUS sobre TCP" ;
    ns1:identificador "MPG.MODBUSSVRTCP" ;
    ns1:textoExtracto "MODBUSSVRTCP Activar el servidor ModBUS sobre TCP. Valores posibles: Sí / No. Valor por defecto: No." .

ns1:IdentificadorDelServidorModBUSSobreRS485 a ns1:Parametro ;
    rdfs:label "Identificador del servidor ModBUS sobre RS485" ;
    ns1:identificador "MPG.MODSVRID" ;
    ns1:textoExtracto "MODSVRID Identificador del servidor ModBUS sobre RS485. Valores posibles: De 1 a 255. Valor por defecto: 1." .

ns1:VelocidadDeComunicacionDelServidorModBUSSobreRS485 a ns1:Parametro ;
    rdfs:label "Velocidad de comunicación del servidor ModBUS sobre RS485" ;
    ns1:identificador "MPG.MODBRATE" ;
    ns1:textoExtracto "MODBRATE Velocidad de comunicación del servidor ModBUS sobre RS485. Valores posibles: 19200 Bd / 38400 Bd / 57600 Bd / 115200 Bd. Valor por defecto: 19200 Bd." .

