@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:PLC_GrupoMultieje
    a                     ex:Sistema ;
    rdfs:label            "PLC para gestión de grupos multieje" ;
    ex:textoExtracto      "Los grupos multieje se gestionan desde el PLC, para lo cual dispone de la siguiente marca." ;
    ex:tieneComponente    ex:Se_al_SWITCH_axis ;
    ex:controla           ex:Regulador_Ejes ;
    ex:monitoreaParametro ex:Parametro_GV21 ;
    ex:monitoreaParametro ex:Parametro_GV25 .

ex:Se_al_SWITCH_axis
    a                     ex:ComponenteElectrico ;
    rdfs:label            "SWITCH(axis)" ;
    ex:identificador       "SWITCH(axis)" ;
    ex:textoExtracto      "El PLC activa esta marca para indicar al CNC cuál es el eje o cabezal que debe gobernar." .

ex:Regulador_Ejes
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Regulador de ejes/cabezales" ;
    ex:textoExtracto      "El proceso de cambio de un eje o cabezal debe contemplar [...] escribir los parámetros en el regulador [...] cambiar el set y/o la gama en el regulador." ;
    ex:monitoreaParametro ex:Parametro_GV21 ;
    ex:monitoreaParametro ex:Parametro_GV25 .

ex:Parametro_GV21
    a               ex:Parametro ;
    rdfs:label      "GV21" ;
    ex:identificador "GV21" ;
    ex:textoExtracto "parámetros GV21 [...] del regulador" .

ex:Parametro_GV25
    a               ex:Parametro ;
    rdfs:label      "GV25" ;
    ex:identificador "GV25" ;
    ex:textoExtracto "parámetros GV25 [...] del regulador" .

ex:Se_al_SERPLCAC
    a               ex:ComponenteElectrico ;
    rdfs:label      "SERPLCAC" ;
    ex:identificador "SERPLCAC" ;
    ex:textoExtracto "Verificar que el cambio de set y/o gama ha terminado (marca SERPLCAC)" .

ex:Proceso_CambioEje
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Proceso de cambio de eje/cabezal" ;
    ex:textoExtracto      "El proceso de cambio de un eje o cabezal debe contemplar las siguientes aspectos (suponiendo que el eje X está activo y eje X1 aparcado): 1 Aparcar el eje X. 2 Verificar que el eje X está aparcado. 3 Conmutar al eje X1 (SWITCHX1=1). 4 En caso necesario, escribir los parámetros en el regulador. 5 Cambiar el set y/o la gama en el regulador. 6 Verificar que el cambio de set y/o gama ha terminado. 7 Habilitar el eje X1." ;
    ex:requiereMantenimiento ex:Regulador_Ejes .