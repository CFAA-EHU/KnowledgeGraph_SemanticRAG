@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_d04948d0a8 a ns1:AccionProhibida ;
    rdfs:label "LEAVEPOS" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_0d07128969 ;
    ns1:textoExtracto "LEAVEPOS=# Posición del almacén para dejar la herramienta." .

ns1:CogerLaHerramientaDelCabezalConLaPinza2_65235e0e32 a ns1:TareaMantenimiento ;
    rdfs:label "Coger la herramienta del cabezal con la pinza 2" ;
    ns1:textoExtracto "1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca" .

ns1:RegistroMZID a ns1:ComponenteElectrico ;
    rdfs:label "MZID" ;
    ns1:textoExtracto "En la parte baja de este registro se indica el almacén en el que hay que dejar la herramienta y en la parte alta el almacén del que hay que coger la herramienta." .

ns1:DiagnosticoFallo_0d07128969 a ns1:DiagnosticoFallo ;
    rdfs:label "Herramienta incorrecta en el cabezal" ;
    ns1:textoExtracto "En esta operación, el gestor admite dos secuencias. Previamente, durante el mecanizado (al ejecutar la T), el gestor envía el código TMOPERATION=11 para coger la herramienta del almacén con la pinza 1." .

