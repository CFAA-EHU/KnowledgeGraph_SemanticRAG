@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SWITCHX1 a ex:Sensor ;
    rdfs:label "SWITCHX1" ;
    ex:textoExtracto "SWITCH(axis)" .

ex:SERPLCAC a ex:Sensor ;
    rdfs:label "SERPLCAC" ;
    ex:textoExtracto "marca SERPLCAC" .

ex:GV21 a ex:Parametro ;
    rdfs:label "GV21" ;
    ex:textoExtracto "parámetros GV21" .

ex:GV25 a ex:Parametro ;
    rdfs:label "GV25" ;
    ex:textoExtracto "parámetros GV25" .

ex:PLC a ex:Sistema ;
    rdfs:label "PLC" ;
    ex:textoExtracto "Los grupos multieje se gestionan desde el PLC" .

ex:Regulador a ex:Componente ;
    rdfs:label "regulador" ;
    ex:textoExtracto "el regulador tras el encendido", "el regulador para cada cambio de eje o cabezal", "el regulador" .

ex:EjeX a ex:Componente ;
    rdfs:label "eje X" ;
    ex:textoExtracto "el eje X está activo", "Aparcar el eje X", "el eje X está aparcado", "Habilitar el eje X1" .

ex:EjeX1 a ex:Componente ;
    rdfs:label "eje X1" ;
    ex:textoExtracto "eje X1 aparcado", "Conmutar al eje X1 (SWITCHX1=1)", "Habilitar el eje X1" .

ex:PLC ex:controla ex:Regulador ;
    ex:textoExtracto "La maniobra de PLC debe definir el set y la gama que asume el regulador tras el encendido, conmutar entre los diferentes ejes o cabezales del grupo y definir el set y la gama que asume el regulador para cada cambio de eje o cabezal" .

ex:PLC ex:monitoreaParametro ex:SWITCHX1 ;
    ex:textoExtracto "El PLC activa esta marca para indicar al CNC cuál es el eje o cabezal que debe gobernar" .

ex:Regulador ex:monitoreaParametro ex:SERPLCAC ;
    ex:textoExtracto "Verificar que la escritura de parámetros en el regulador ha finalizado y en caso necesario, validar los parámetros del regulador. Verificar que el cambio de set y/o gama ha terminado (marca SERPLCAC) y que el set y/o gama del regulador es correcta (parámetros GV21 y GV25 del regulador)" .

ex:Regulador ex:monitoreaParametro ex:GV21 ;
    ex:textoExtracto "que el set y/o gama del regulador es correcta (parámetros GV21 y GV25 del regulador)" .

ex:Regulador ex:monitoreaParametro ex:GV25 ;
    ex:textoExtracto "que el set y/o gama del regulador es correcta (parámetros GV21 y GV25 del regulador)" .