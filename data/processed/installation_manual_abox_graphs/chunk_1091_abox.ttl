@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ParametroSet a ex:Parametro ;
    rdfs:label "set" ;
    ex:textoExtracto "Entendemos por set a un conjunto de parámetros susceptibles de ser activados"@es .

ex:ParametroGama a ex:Parametro ;
    rdfs:label "gama" ;
    ex:textoExtracto "por gama a los parámetros específicos de la reducción"@es .

ex:ParametroDRIVESET a ex:Parametro ;
    rdfs:label "DRIVESET" ;
    ex:identificador "DRIVESET" ;
    ex:textoExtracto "activan la gama definida en el parámetro DRIVESET del set programado"@es .

ex:ParametroCAXSET a ex:Parametro ;
    rdfs:label "CAXSET" ;
    ex:identificador "CAXSET" ;
    ex:textoExtracto "activa el set definido en el parámetro CAXSET"@es .

ex:FuncionG112 a ex:Parametro ;
    rdfs:label "G112" ;
    ex:identificador "G112" ;
    ex:textoExtracto "G112 (solo ejes)"@es .

ex:FuncionM41M44 a ex:Parametro ;
    rdfs:label "M41-M44" ;
    ex:identificador "M41-M44" ;
    ex:textoExtracto "M41-M44 (solo cabezales)"@es .

ex:FuncionV_A_SETGE_xn a ex:Parametro ;
    rdfs:label "(V.)A.SETGE.xn" ;
    ex:identificador "(V.)A.SETGE.xn" ;
    ex:textoExtracto "(V.)A.SETGE.xn"@es .

ex:FuncionCAX_ON a ex:Parametro ;
    rdfs:label "#CAX ON" ;
    ex:identificador "#CAX ON" ;
    ex:textoExtracto "#CAX ON"@es .

ex:FuncionCAX_OFF a ex:Parametro ;
    rdfs:label "#CAX OFF" ;
    ex:identificador "#CAX OFF" ;
    ex:textoExtracto "#CAX OFF"@es .

ex:SistemaCNC a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "El CNC activa el set programado"@es .

ex:SistemaRegulador a ex:Sistema ;
    rdfs:label "Regulador" ;
    ex:textoExtracto "El regulador activa la gama definida en el parámetro DRIVESET del set programado"@es .

ex:GrupoMultieje a ex:Sistema ;
    rdfs:label "grupo multieje" ;
    ex:textoExtracto "Ejes y cabezales incluidos en un grupo multieje"@es .

ex:EjeC a ex:ComponenteMecanico ;
    rdfs:label "eje C" ;
    ex:textoExtracto "Cabezal y eje C"@es .