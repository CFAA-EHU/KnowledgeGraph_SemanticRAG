@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CodigoDeOperacionDelGestor a ns1:Parametro ;
    rdfs:label "Código de operación del gestor" ;
    ns1:identificador "TMOPERATION" ;
    ns1:textoExtracto "el mecanizado (al ejecutar la T), el gestor envía el código TMOPERATION=11 para coger la herramienta del almacén con la pinza 1." .

ns1:CogerLaHerramientaDelAlmacenConLaPinza1_8a4873a644 a ns1:AccionProhibida ;
    rdfs:label "Coger la herramienta del almacén con la pinza 1" ;
    ns1:textoExtracto "el mecanizado (al ejecutar la T), el gestor envía el código TMOPERATION=11 para coger la herramienta del almacén con la pinza 1." .

ns1:CogerLaHerramientaDelAlmacenConLaPinza2 a ns1:AccionProhibida ;
    rdfs:label "Coger la herramienta del almacén con la pinza 2" ;
    ns1:textoExtracto "Coger una herramienta del almacén y ponerla en el brazo (pinza ꞏ1ꞏ)." .

ns1:DejarLaHerramientaDeLaPinza2EnElAlmacen a ns1:AccionProhibida ;
    rdfs:label "Dejar la herramienta de la pinza 2 en el almacén" ;
    ns1:textoExtracto "Dejar la herramienta del brazo (pinza ꞏ2ꞏ) en el almacén." .

ns1:Parametro_1823548c27 a ns1:Parametro ;
    rdfs:label "Marca de activación CH1TOSPDL" ;
    ns1:identificador "CH1TOSPDL" ;
    ns1:textoExtracto "Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL." .

ns1:Parametro_63e02acfc4 a ns1:Parametro ;
    rdfs:label "Marca de activación CH2TOMZ" ;
    ns1:identificador "CH2TOMZ" ;
    ns1:textoExtracto "activar la marca CH2TOMZ." .

ns1:Parametro_92b7e6b9ba a ns1:Parametro ;
    rdfs:label "Marca de activación MZTOCH1" ;
    ns1:identificador "MZTOCH1" ;
    ns1:textoExtracto "activar la marca MZTOCH1." .

ns1:Parametro_d80576b55d a ns1:Parametro ;
    rdfs:label "Marca de activación SPDLTOCH2" ;
    ns1:identificador "SPDLTOCH2" ;
    ns1:textoExtracto "activar la marca SPDLTOCH2." .

ns1:PonerLaHerramientaDeLaPinza1EnElCabezal a ns1:AccionProhibida ;
    rdfs:label "Poner la herramienta de la pinza 1 en el cabezal" ;
    ns1:textoExtracto "Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL." .

