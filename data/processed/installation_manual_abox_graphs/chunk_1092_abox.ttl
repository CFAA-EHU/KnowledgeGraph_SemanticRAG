@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SistemaMultieje_1092_1 a ex:Sistema ;
    ex:textoExtracto "Ejemplo 1. Sistema con dos ejes, cada uno con su motor. El sistema tiene las siguientes características. • Un único regulador controla dos ejes, cada uno con su motor. • Cada eje utiliza un tipo de captación diferente." ;
    ex:tieneComponente ex:Eje_A1_1092, ex:Eje_A2_1092, ex:Regulador_1092 .

ex:Eje_A1_1092 a ex:ComponenteMecanico ;
    ex:textoExtracto "Eje A1 La captación externa (directa) está conectada al propio regulador." ;
    ex:tieneComponente ex:Motor_A1_1092 .

ex:Motor_A1_1092 a ex:ComponenteElectrico ;
    ex:textoExtracto "Eje A1 ... cada uno con su motor." .

ex:Eje_A2_1092 a ex:ComponenteMecanico ;
    ex:textoExtracto "Eje A2 La captación externa (directa) está conectada a los módulos remotos." ;
    ex:tieneComponente ex:Motor_A2_1092 .

ex:Motor_A2_1092 a ex:ComponenteElectrico ;
    ex:textoExtracto "Eje A2 ... cada uno con su motor." .

ex:Regulador_1092 a ex:ComponenteElectrico ;
    ex:textoExtracto "Un único regulador controla dos ejes, cada uno con su motor." ;
    ex:controla ex:Eje_A1_1092, ex:Eje_A2_1092 .