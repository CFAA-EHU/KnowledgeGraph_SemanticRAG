@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LlevarElBrazoCambiadorAlAlmacen a ns1:TareaMantenimiento ;
    rdfs:label "Llevar el brazo cambiador al almacén" ;
    ns1:textoExtracto "M122 | Llevar el brazo cambiador al almacén." .

ns1:LlevarElBrazoCambiadorAlPuntoDeCambio a ns1:TareaMantenimiento ;
    rdfs:label "Llevar el brazo cambiador al punto de cambio" ;
    ns1:textoExtracto "M121 | Llevar el brazo cambiador al punto de cambio." .

ns1:RetirarElBrazoCambiador a ns1:TareaMantenimiento ;
    rdfs:label "Retirar el brazo cambiador" ;
    ns1:textoExtracto "M123 | Retirar el brazo cambiador." .

