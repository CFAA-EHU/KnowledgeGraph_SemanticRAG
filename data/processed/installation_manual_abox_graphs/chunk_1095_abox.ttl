@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalCambioManual a ns1:ComponenteMecanico ;
    rdfs:label "Punto de cambio manual" ;
    ns1:controladoPor ns1:BrazoCambiador ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio manual." .

ns1:CambioDeHerramienta_9881bb0dd4 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta" ;
    ns1:solucionaFallo ns1:DiagnosticoFallo_a14eaa0e85 ;
    ns1:textoExtracto "Colocar la herramienta de tierra en el cabezal. Mensaje al operario para que ponga la herramienta." .

ns1:EstadoDeLaHerramienta_16bca60b08 a ns1:Parametro ;
    rdfs:label "Estado de la herramienta" ;
    ns1:identificador "V.PLC.M[1107]" ;
    ns1:textoExtracto "WAIT FOR [V.PLC.M[1107]==0]" .

ns1:Parametro_7a1fb22386 a ns1:Parametro ;
    rdfs:label "Marca GRTOSPDL al gestor" ;
    ns1:identificador "V.PLC.M[1108]" ;
    ns1:textoExtracto "V.PLC.M[1108]=1" .

ns1:BrazoCambiador a ns1:ComponenteMecanico ;
    rdfs:label "Brazo cambiador" ;
    ns1:textoExtracto "Llevar el brazo cambiador al punto de cambio." .

ns1:DiagnosticoFallo_a14eaa0e85 a ns1:DiagnosticoFallo ;
    rdfs:label "Herramienta incorrecta" ;
    ns1:textoExtracto "Colocar la herramienta de tierra en el cabezal. Mensaje al operario para que ponga la herramienta." .

