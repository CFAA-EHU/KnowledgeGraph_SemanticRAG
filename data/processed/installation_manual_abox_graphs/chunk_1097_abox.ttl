@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioDeHerramienta_79e03ae99e a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en el almacén. LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático." ;
    ns1:tieneComponente ns1:BrazoCambiador,
        ns1:CabezalHerramienta,
        ns1:ComponenteMecanico_2c93a93856,
        ns1:PuntoCambioAutomatico .

ns1:Herramienta_414d337620 a ns1:Herramienta ;
    rdfs:label "Herramienta de tierra" ;
    ns1:textoExtracto "Colocar la herramienta de tierra en el cabezal." .

ns1:BrazoCambiador a ns1:ComponenteMecanico ;
    rdfs:label "Brazo cambiador" ;
    ns1:textoExtracto "Llevar el brazo cambiador al punto de cambio." .

ns1:CabezalHerramienta a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de herramienta" ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en el almacén." .

ns1:ComponenteMecanico_2c93a93856 a ns1:ComponenteMecanico ;
    rdfs:label "Almacén de herramientas" ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en el almacén." .

ns1:PersonalTecnicoAutorizado a ns1:Personal ;
    rdfs:label "Personal Técnico Autorizado" ;
    ns1:textoExtracto "Orden al PLC para que active la marca TCHANGEOK, indicando al gestor que puede continuar la ejecución." .

ns1:PuntoCambioAutomatico a ns1:ElementoSeguridad ;
    rdfs:label "Punto de cambio automático" ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio automático." .

