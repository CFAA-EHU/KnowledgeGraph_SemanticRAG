@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Parametro_I0TYPE a ex:Parametro ;
    ex:identificador "I0TYPE" ;
    ex:textoExtracto "No codificado." ;
    ex:valor "No codificado" .

ex:Parametro_DECINPUT a ex:Parametro ;
    ex:identificador "DECINPUT" ;
    ex:textoExtracto "El eje dispone de micro para la búsqueda de referencia." ;
    ex:valor "El eje dispone de micro para la búsqueda de referencia" .

ex:Parametro_REFDIREC a ex:Parametro ;
    ex:identificador "REFDIREC" ;
    ex:textoExtracto "Sentido del movimiento para la búsqueda de referencia." ;
    ex:valor "Sentido del movimiento para la búsqueda de referencia" .

ex:Parametro_REFFEED1 a ex:Parametro ;
    ex:identificador "REFFEED1" ;
    ex:textoExtracto "Velocidad rápida de búsqueda de referencia." ;
    ex:valor "Velocidad rápida de búsqueda de referencia" .

ex:Parametro_REFFEED2 a ex:Parametro ;
    ex:identificador "REFFEED2" ;
    ex:textoExtracto "Velocidad lenta de búsqueda de referencia." ;
    ex:valor "Velocidad lenta de búsqueda de referencia" .

ex:MicroReferenciaMaquina a ex:Sensor ;
    ex:textoExtracto "el fabricante debe colocar, en cada eje, un micro de referencia en la posición que ocupa el punto de referencia máquina" .

ex:PuntoReferenciaMaquina a ex:Componente ;
    ex:textoExtracto "punto de referencia máquina" .

ex:SistemaCaptacionNoCodificado a ex:Sistema ;
    ex:textoExtracto "sistema de captación que no dispone de I0s codificados" .

ex:SistemaCaptacionCodificado a ex:Sistema ;
    ex:textoExtracto "sistema de captación con I0s codificados" .

ex:Eje a ex:ComponenteMecanico ;
    ex:textoExtracto "el eje se desplaza en el sentido indicado por el parámetro REFDIREC y al avance indicado en el parámetro REFFEED1 hasta que pulsa el micro de referencia máquina" .

ex:CNC a ex:Sistema ;
    ex:textoExtracto "hasta que el CNC recibe un impulso de I0 del sistema de captación" .