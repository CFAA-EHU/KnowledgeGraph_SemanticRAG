@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_REFVALUE
    a ex:Parametro ;
    rdfs:label "REFVALUE" ;
    ex:identificador "REFVALUE" ;
    ex:textoExtracto "REFVALUE | Posición del punto de referencia." ;
    ex:valor "Posición del punto de referencia" .

ex:Parametro_REFSHIFT
    a ex:Parametro ;
    rdfs:label "REFSHIFT" ;
    ex:identificador "REFSHIFT" ;
    ex:textoExtracto "REFSHIFT | Offset del punto de referencia." ;
    ex:textoExtracto "en el parámetro REFSHIFT se debe indicar la diferencia existente entre ambos puntos, el anterior y el actual. De esta manera, cuando el eje encuentra el I0, se desplaza el valor indicado en REFSHIFT y en ese punto actualiza su cota al valor de REFVALUE." ;
    ex:valor "Offset del punto de referencia" .

ex:Parametro_REFFEED1
    a ex:Parametro ;
    rdfs:label "REFFEED1" ;
    ex:identificador "REFFEED1" ;
    ex:textoExtracto "REFFEED1 | Velocidad rápida de búsqueda de referencia." ;
    ex:valor "Velocidad rápida de búsqueda de referencia" .

ex:Tabla_ParametrosBusquedaReferencia a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de búsqueda de referencia (ejes y cabezales)" ;
    ex:textoExtracto "Parámetro. | Valor. --- | --- REFVALUE | Posición del punto de referencia. REFSHIFT | Offset del punto de referencia. [...] REFFEED1 | Velocidad rápida de búsqueda de referencia." ;
    ex:documentadoEn ex:Pagina_595_597 .

ex:SistemaBusquedaReferencia
    a ex:Sistema ;
    rdfs:label "Sistema de búsqueda de referencia (ejes y cabezales)" ;
    ex:textoExtracto "A veces, para reajustar la máquina, es necesario soltar el sistema de captación por lo que el nuevo punto de referencia máquina no coincide con el anterior. [...] La búsqueda de referencia la realiza el servo y el micro de referencia debe estar cableado al servo." ;
    ex:tieneComponente ex:Parametro_REFVALUE ;
    ex:tieneComponente ex:Parametro_REFSHIFT ;
    ex:tieneComponente ex:Parametro_REFFEED1 ;
    ex:detalladoEnEsquema ex:Tabla_ParametrosBusquedaReferencia .

ex:ComponenteElectrico_MicroReferencia
    a ex:ComponenteElectrico ;
    rdfs:label "Micro de referencia" ;
    ex:textoExtracto "el micro de referencia debe estar cableado al servo." ;
    ex:textoExtracto "1 [...] Cuando el eje pulsa el micro, cambia al avance de aproximación 1 [...] 3 Cuando el eje suelta el micro y recibe la señal del I0, cambia al avance de aproximación 2" .