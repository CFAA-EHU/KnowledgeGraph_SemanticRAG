@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_REFVALUE a ex:Parametro ;
    rdfs:label "REFVALUE" ;
    ex:textoExtracto "Parámetro. | Valor. | REFVALUE | Posición del punto de referencia." ;
    ex:valor "Posición del punto de referencia" .

ex:Parametro_REFSHIFT a ex:Parametro ;
    rdfs:label "REFSHIFT" ;
    ex:textoExtracto "Parámetro. | Valor. | REFSHIFT | Offset del punto de referencia." ;
    ex:valor "Offset del punto de referencia" .

ex:Parametro_REFFEED1 a ex:Parametro ;
    rdfs:label "REFFEED1" ;
    ex:textoExtracto "Parámetro. | Valor. | REFFEED1 | Velocidad rápida de búsqueda de referencia." ;
    ex:valor "Velocidad rápida de búsqueda de referencia" .

ex:Sistema_Captacion a ex:Sistema ;
    rdfs:label "sistema de captación" ;
    ex:textoExtracto "soltar el sistema de captación" .

ex:Eje a ex:ComponenteMecanico ;
    rdfs:label "eje" ;
    ex:textoExtracto "el eje se desplaza en la dirección de búsqueda", "el eje pulsa el micro", "el eje suelta el micro", "el eje" .

ex:Micro a ex:Sensor ;
    rdfs:label "micro" ;
    ex:textoExtracto "el eje pulsa el micro", "el eje suelta el micro" .

ex:Servo a ex:ComponenteElectrico ;
    rdfs:label "servo" ;
    ex:textoExtracto "la búsqueda de referencia la realiza el servo", "el servo", "el servo da por finalizada la búsqueda de referencia" .

ex:Micro_Referencia a ex:Sensor ;
    rdfs:label "micro de referencia" ;
    ex:textoExtracto "el micro de referencia debe estar cableado al servo" .

ex:Regulador a ex:ComponenteElectrico ;
    rdfs:label "regulador" ;
    ex:textoExtracto "el CNC envía el valor del parámetro REFSHIFT al regulador", "la cota del CNC y la del regulador es la misma" .

ex:CNC a ex:ComponenteElectrico ;
    rdfs:label "CNC" ;
    ex:textoExtracto "el CNC envía el valor del parámetro REFSHIFT al regulador", "la cota del CNC" .

ex:Esquema_BusquedaReferencia a ex:Esquema ;
    rdfs:label "Esquema de búsqueda de referencia" ;
    ex:textoExtracto "Particularidades de la búsqueda de referencia para ejes Mechatrolink.", "Particularidades de la búsqueda de referencia para los cabezales, sistema tándem y ejes analógicos.", "Particularidades de la búsqueda de referencia para los cabezales." ;
    ex:compuestoPor ex:Parametro_REFVALUE, ex:Parametro_REFSHIFT, ex:Parametro_REFFEED1, ex:Sistema_Captacion, ex:Eje, ex:Micro, ex:Servo, ex:Micro_Referencia, ex:Regulador, ex:CNC .