@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioDeHerramienta_97ba1d8a3c a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta" ;
    ns1:documentadoEn ns1:ManualDeProgramacion ;
    ns1:textoExtracto "LL SUB_SPD_TO_CH2 ; Coger la herramienta del cabezal con la pinza 2. LL SUB_ARM_BACK ; Retirar el brazo cambiador. LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual. LL SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal." .

ns1:OrdenParaActivarMarcaTCHANGEOK a ns1:Parametro ;
    rdfs:label "Orden para activar marca TCHANGEOK" ;
    ns1:identificador "M[1100]" ;
    ns1:textoExtracto "V.PLC.M[1100]=1 ; Orden al PLC para que active la marca TCHANGEOK, indicando al gestor que puede continuar la ejecución." .

