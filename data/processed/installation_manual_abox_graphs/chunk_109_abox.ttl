@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_CROSSCOMP_DATA a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla CROSSCOMP // DATA" ;
    ex:textoExtracto "Parámetro incluido en la tabla CROSSCOMP // DATA. Este parámetro define la posición del eje maestro en cada uno de los puntos de compensación." ;
    ex:identificador "CROSSCOMP // DATA" .

ex:Parametro_POSITION
    a ex:Parametro ;
    rdfs:label "POSITION" ;
    ex:textoExtracto "POSITION: Posición del eje maestro. Valores posibles (1): Entre ±99999.9999 mm. Valores posibles (2): Entre ±3937.00787 inch. Valores posibles (3): Entre ±99999.9999 grados. Valor por defecto: 0. Variable asociada: (V.)MPG.POSITION[tbl][pt]." ;
    ex:valor "0" ;
    ex:documentadoEn ex:Tabla_CROSSCOMP_DATA .

ex:Parametro_POSERROR
    a ex:Parametro ;
    rdfs:label "POSERROR" ;
    ex:textoExtracto "POSERROR: Error a compensar en los desplazamientos en sentido positivo. Valores posibles (1): Entre ±99999.9999 mm. Valores posibles (2): Entre ±3937.00787 inch. Valores posibles (3): Entre ±99999.9999 grados. Valor por defecto: 0. Variable asociada: (V.)MPG.POSERROR[tbl][pt]." ;
    ex:valor "0" ;
    ex:documentadoEn ex:Tabla_CROSSCOMP_DATA .

ex:Parametro_NEGERROR
    a ex:Parametro ;
    rdfs:label "NEGERROR" ;
    ex:textoExtracto "NEGERROR: Error a compensar en los desplazamientos en sentido negativo. Valores posibles (1): Entre ±99999.9999 mm. Valores posibles (2): Entre ±3937.00787 inch. Valores posibles (3): Entre ±99999.9999 grados. Valor por defecto: 0. Variable asociada: (V.)MPG.NEGERROR[tbl][pt]." ;
    ex:valor "0" ;
    ex:documentadoEn ex:Tabla_CROSSCOMP_DATA .