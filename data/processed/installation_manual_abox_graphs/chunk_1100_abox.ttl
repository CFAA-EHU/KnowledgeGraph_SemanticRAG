@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ParametrosBusquedaReferencia1151 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros para búsqueda de referencia (ejes y cabezales)"@es ;
    ex:textoExtracto """
| Parámetro. | Valor. |
| --- | --- |
| REFINI | Búsqueda de cero en el primer movimiento. |
| NPULSES | Número de impulsos del encoder. |
| NPULSES2 | Número de impulsos del encoder (captación externa). |
"""@es ;
    ex:tieneComponente ex:Parametro_REFINI ,
                      ex:Parametro_NPULSES ,
                      ex:Parametro_NPULSES2 .

ex:Parametro_REFINI
    a ex:Parametro ;
    ex:identificador "REFINI" ;
    ex:valor "Búsqueda de cero en el primer movimiento"@es ;
    ex:textoExtracto "REFINI | Búsqueda de cero en el primer movimiento."@es ;
    ex:documentadoEn ex:Tabla_ParametrosBusquedaReferencia1151 .

ex:Parametro_NPULSES
    a ex:Parametro ;
    ex:identificador "NPULSES" ;
    ex:valor "Número de impulsos del encoder"@es ;
    ex:textoExtracto "NPULSES | Número de impulsos del encoder."@es ;
    ex:documentadoEn ex:Tabla_ParametrosBusquedaReferencia1151 .

ex:Parametro_NPULSES2
    a ex:Parametro ;
    ex:identificador "NPULSES2" ;
    ex:valor "Número de impulsos del encoder (captación externa)"@es ;
    ex:textoExtracto "NPULSES2 | Número de impulsos del encoder (captación externa)."@es ;
    ex:documentadoEn ex:Tabla_ParametrosBusquedaReferencia1151 .