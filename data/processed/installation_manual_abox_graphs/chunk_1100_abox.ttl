@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalHerramientas a ns1:Componente ;
    rdfs:label "Cabezal de herramientas" ;
    ns1:requiereConsumible ns1:Componente_12261df927,
        ns1:Componente_d61e1a1207 ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio manual." ;
    ns1:tieneComponente ns1:BrazoCambiador .

ns1:CambioDeHerramientaManual_5210792c71 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta manual" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio manual. Quitar la herramienta del cabezal." .

ns1:Parametro_51414495f4 a ns1:Parametro ;
    rdfs:label "Marca TCHANGEOK" ;
    ns1:identificador "V.PLC.M[1100]" ;
    ns1:textoExtracto "Orden al PLC para que active la marca TCHANGEOK, indicando al gestor que puede continuar la ejecución." .

ns1:PuntoCambioManual a ns1:ElementoSeguridad ;
    rdfs:label "Punto de cambio manual" ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio manual." .

ns1:BrazoCambiador a ns1:Componente ;
    rdfs:label "Brazo cambiador" ;
    ns1:textoExtracto "Llevar el brazo cambiador al punto de cambio." .

ns1:Componente_12261df927 a ns1:Componente ;
    rdfs:label "Herramienta de tierra" ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en tierra y coger otra de tierra." .

ns1:Componente_d61e1a1207 a ns1:Componente ;
    rdfs:label "Herramienta del almacén" ;
    ns1:textoExtracto "Coger otra del almacén." .

