@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BrazoCambiador a ns1:ComponenteMecanico ;
    rdfs:label "Brazo cambiador" ;
    ns1:textoExtracto "LL SUB_ARM_BACK ; Retirar el brazo cambiador." .

ns1:CabezalCambioAutomatico a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de cambio automático" ;
    ns1:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático." .

ns1:CambioDeHerramienta_4872f862bb a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta" ;
    ns1:textoExtracto "LL SUB_ARM_BACK ; Retirar el brazo cambiador. LL SUB_CH2_TO_MZ ; Comenzar el envío del brazo cambiador al almacén para dejar la herramienta." .

ns1:ComponenteElectrico_6d671dd457 a ns1:ComponenteElectrico ;
    rdfs:label "Herramienta en almacén" ;
    ns1:textoExtracto "LL SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1." .

ns1:OrdenDeActivacionTCHANGEOK a ns1:Parametro ;
    rdfs:label "Orden de activación TCHANGEOK" ;
    ns1:identificador "V.PLC.M[1100]" ;
    ns1:textoExtracto "V.PLC.M[1100]=1 ; Orden al PLC para que active la marca TCHANGEOK, indicando al gestor que puede continuar la ejecución." .

