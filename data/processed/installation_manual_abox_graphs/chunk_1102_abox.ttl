@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:EjeProgramado1 a ex:Maquina ;
    ex:textoExtracto "Si alguno de los ejes del grupo programado no dispone de micro"@es .

ex:EjeProgramado2 a ex:Maquina ;
    ex:textoExtracto "Si ninguno de los ejes del grupo programado dispone de micro"@es .

ex:MicroEje a ex:Sensor ;
    ex:textoExtracto "micro"@es .

ex:OrdenAvanceREFFEED2 a ex:ModoOperacion ;
    ex:textoExtracto "orden que le toque"@es, "buscar cero a REFFEED2"@es .

ex:NumeroLogicoEje a ex:Parametro ;
    ex:textoExtracto "eje de menor número lógico"@es .