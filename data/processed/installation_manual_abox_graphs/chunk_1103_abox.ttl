@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioDeHerramienta_c9a39009ec a ns1:AccionProhibida ;
    rdfs:label "Cambio de herramienta" ;
    ns1:textoExtracto "Enviar el brazo cambiador al almacén. Si LEAVEPOS indica una posición del almacén dejar la herramienta que está en la pinza 1 en dicha posición y activar la marca CH1TOMZ." .

ns1:CodigoDeOperacionDelGestor a ns1:Parametro ;
    rdfs:label "Código de operación del gestor" ;
    ns1:identificador "TMOPERATION" ;
    ns1:textoExtracto "el gestor envía al PLC el código TMOPERATION=11 para coger la próxima herramienta en el brazo y acercarla al cabezal durante el mecanizado." .

ns1:CogerHerramientaConPinza1 a ns1:AccionProhibida ;
    rdfs:label "Coger herramienta con pinza 1" ;
    ns1:textoExtracto "Coger con la pinza 1 la herramienta que ocupa la posición de almacén que indica TAKEPOS." .

ns1:Parametro_384c3b5bc7 a ns1:Parametro ;
    rdfs:label "Marca de cambio de herramienta completado" ;
    ns1:identificador "TCHANGEOK" ;
    ns1:textoExtracto "DFU M1100 = SET TCHANGEOK DFD TCHANGEOK = RES M1100" .

ns1:Parametro_92b7e6b9ba a ns1:Parametro ;
    rdfs:label "Marca de herramienta cogida por pinza 1" ;
    ns1:identificador "MZTOCH1" ;
    ns1:textoExtracto "activar la marca MZTOCH1 para indicar al gestor que se ha cogido la herramienta." .

ns1:Parametro_fa5bf031fb a ns1:Parametro ;
    rdfs:label "Marca de cambio de herramienta" ;
    ns1:identificador "CH1TOMZ" ;
    ns1:textoExtracto "activar la marca CH1TOMZ." .

ns1:RutinaM06 a ns1:AccionProhibida ;
    rdfs:label "Rutina M06" ;
    ns1:textoExtracto "Cada vez que la rutina M06 finaliza una acción se lo indica al PLC para que active la marca correspondiente del gestor." .

ns1:SeleccionarPosicionEnAlmacenYCogerHerramientaConPinza1 a ns1:AccionProhibida ;
    rdfs:label "Seleccionar posición en almacén y coger herramienta con pinza 1" ;
    ns1:textoExtracto "M101 Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Cuando se ejecuta la función T el gestor envía al PLC el código TMOPERATION=11 para coger la próxima herramienta en el brazo y acercarla al cabezal durante el mecanizado." .

