@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EjeGantryMaestro a ex:Maquina ;
    rdfs:label "eje maestro"@es ;
    ex:textoExtracto "eje maestro"@es .

ex:EjeGantryEsclavo a ex:Maquina ;
    rdfs:label "eje esclavo"@es ;
    ex:textoExtracto "eje esclavo"@es .

ex:ParametroI0TYPE a ex:Parametro ;
    rdfs:label "I0TYPE"@es ;
    ex:textoExtracto "parámetro I0TYPE"@es .

ex:ParametroDECINPUT a ex:Parametro ;
    rdfs:label "DECINPUT"@es ;
    ex:textoExtracto "parámetro DECINPUT"@es .

ex:SistemaCaptacionReferencia a ex:Sistema ;
    rdfs:label "sistema de captación que no dispone de I0s codificados"@es ;
    ex:textoExtracto "sistema de captación que no dispone de I0s codificados"@es .