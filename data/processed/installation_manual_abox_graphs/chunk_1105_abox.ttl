@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:I0TYPE a ex:Parametro ;
    ex:identificador "I0TYPE" ;
    ex:textoExtracto "Tipo de I0. No codificado en ambos ejes. A definir en los ejes maestro y esclavo." .

ex:DECINPUT a ex:Parametro ;
    ex:identificador "DECINPUT" ;
    ex:textoExtracto "El eje dispone de micro para la búsqueda de referencia. A definir en los ejes maestro y esclavo." .

ex:REFDIREC a ex:Parametro ;
    ex:identificador "REFDIREC" ;
    ex:textoExtracto "Sentido del movimiento para la búsqueda de referencia. A definir en el eje maestro." .

ex:REFFEED1 a ex:Parametro ;
    ex:identificador "REFFEED1" ;
    ex:textoExtracto "Velocidad rápida de búsqueda de referencia. A definir en el eje maestro." .

ex:REFFEED2 a ex:Parametro ;
    ex:identificador "REFFEED2" ;
    ex:textoExtracto "Velocidad lenta de búsqueda de referencia. A definir en el eje maestro." .

ex:REFVALUE a ex:Parametro ;
    ex:identificador "REFVALUE" ;
    ex:textoExtracto "Posición del punto de referencia. A definir en los ejes maestro y esclavo." .

ex:REFSHIFT a ex:Parametro ;
    ex:identificador "REFSHIFT" ;
    ex:textoExtracto "Offset del punto de referencia. A definir en los ejes maestro y esclavo." .