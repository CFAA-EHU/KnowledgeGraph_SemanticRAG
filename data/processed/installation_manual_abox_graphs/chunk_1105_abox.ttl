@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ProgramacionBasicaDelPLC_effa55b327 a ns1:TareaMantenimiento ;
    rdfs:label "Programación básica del PLC" ;
    ns1:textoExtracto "herramienta de la pinza 2. M121 Llevar el brazo cambiador al punto de cambio. M122 Llevar el brazo cambiador al almacén. M123 Retirar el brazo cambiador." .

ns1:RegistroQueIndicaLaPosicionDeAlmacenEnLaQueHayQueDejarLaHerramienta a ns1:Parametro ;
    rdfs:label "Registro que indica la posición de almacén en la que hay que dejar la herramienta" ;
    ns1:identificador "LEAVEPOS" ;
    ns1:textoExtracto "Este registro indica la posición de almacén en la que hay que dejar la herramienta." .

ns1:RegistroQueIndicaLaPosicionDeAlmacenQueOcupaLaHerramientaQueHayQueCoger a ns1:Parametro ;
    rdfs:label "Registro que indica la posición de almacén que ocupa la herramienta que hay que coger" ;
    ns1:identificador "TAKEPOS" ;
    ns1:textoExtracto "Este registro indica la posición de almacén que ocupa la herramienta que hay que coger." .

ns1:SenalEmergenciaGestor a ns1:AvisoSeguridad ;
    rdfs:label "Señal de emergencia del gestor" ;
    ns1:textoExtracto "Tratamiento de la señal de emergencia del gestor de herramientas." .

ns1:TratamientoDeLaFuncionM106 a ns1:Parametro ;
    rdfs:label "Tratamiento de la función M106" ;
    ns1:identificador "M106" ;
    ns1:textoExtracto "Dar por finalizada cuando el brazo abandona la zona de posible colisión y se puede mecanizar." .

