@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:EjeMaestro a ex:Maquina ;
    ex:textoExtracto "el parámetro REFDIREC del eje maestro" , "el avance indicado en el parámetro REFFEED1 del eje maestro" , "el avance REFFEED2 del eje maestro" , "el parámetro REFSHIFT del eje maestro" , "el eje maestro pulse su micro" .

ex:EjeEsclavo a ex:Maquina ;
    ex:textoExtracto "el segundo eje pulse su micro" , "el eje esclavo termine el movimiento correspondiente al parámetro REFSHIFT" , "el parámetro REFSHIFT del eje esclavo" , "el eje esclavo inicializa la cota tras haber encontrado el I0" .

ex:Parametro_REFDIREC a ex:Parametro ;
    ex:identificador "REFDIREC" ;
    ex:textoExtracto "el parámetro REFDIREC del eje maestro" .

ex:Parametro_REFFEED1 a ex:Parametro ;
    ex:identificador "REFFEED1" ;
    ex:textoExtracto "el avance indicado en el parámetro REFFEED1 del eje maestro" .

ex:Parametro_REFFEED2 a ex:Parametro ;
    ex:identificador "REFFEED2" ;
    ex:textoExtracto "el avance REFFEED2 del eje maestro" .

ex:Parametro_REFVALUE a ex:Parametro ;
    ex:identificador "REFVALUE" ;
    ex:textoExtracto "el valor definido en el parámetro REFVALUE" .

ex:Parametro_REFSHIFT a ex:Parametro ;
    ex:identificador "REFSHIFT" ;
    ex:textoExtracto "el parámetro REFSHIFT del eje maestro" , "el parámetro REFSHIFT del eje esclavo" .

ex:Micro a ex:Sensor ;
    ex:textoExtracto "pulse su micro" .

ex:I0 a ex:Sensor ;
    ex:textoExtracto "encuentra el I0" .

ex:SistemaCaptacion a ex:Sistema ;
    ex:textoExtracto "Búsqueda de referencia con un sistema de captación que no dispone de I0s codificados" .