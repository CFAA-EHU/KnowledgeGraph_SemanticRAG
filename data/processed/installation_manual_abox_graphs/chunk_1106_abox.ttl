@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Señal de emergencia del gestor. Tratamiento de la señal de emergencia del gestor de herramientas." ;
    ns1:tieneComponente ns1:EstadoDeEmergenciaDelSistema,
        ns1:LamparaDeLaTeclaUSER12_a24e01f31c,
        ns1:SenalDeTeclaUSER12ParaActivarEmergencia,
        ns1:SenalDeTeclaUSER13ParaDesactivarEmergencia .

ns1:EstadoDeEmergenciaDelSistema a ns1:Parametro ;
    rdfs:label "Estado de emergencia del sistema" ;
    ns1:identificador "TMINEM" ;
    ns1:textoExtracto "DFU TMINEM = RES SETTMEM Si se pulsa la tecla USER12 se activa la emergencia. TMINEM AND DFU B12KEYBD1 = SET RESTMEM Si se pulsa la tecla USER13 se quita la emergencia." .

ns1:LamparaDeLaTeclaUSER12_a24e01f31c a ns1:ComponenteElectrico ;
    rdfs:label "Lámpara de la tecla USER12" ;
    ns1:textoExtracto "TMINEM = B11KEYLED1 Lámpara de la tecla USER12 iluminada cuando hay emergencia." .

ns1:SenalDeTeclaUSER12ParaActivarEmergencia a ns1:Parametro ;
    rdfs:label "Señal de tecla USER12 para activar emergencia" ;
    ns1:identificador "B11KEYBD1" ;
    ns1:textoExtracto "DFU B11KEYBD1 AND NOT TMINEM = SET SETTMEM DFU TMINEM = RES SETTMEM Si se pulsa la tecla USER12 se activa la emergencia." .

ns1:SenalDeTeclaUSER13ParaDesactivarEmergencia a ns1:Parametro ;
    rdfs:label "Señal de tecla USER13 para desactivar emergencia" ;
    ns1:identificador "B12KEYBD1" ;
    ns1:textoExtracto "TMINEM AND DFU B12KEYBD1 = SET RESTMEM Si se pulsa la tecla USER13 se quita la emergencia." .

