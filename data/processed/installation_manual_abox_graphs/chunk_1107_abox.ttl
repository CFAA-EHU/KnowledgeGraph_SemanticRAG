@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:EjeMaestro a ex:ComponenteMecanico ;
    ex:textoExtracto "el parámetro REFDIREC del eje maestro" ;
    ex:identificador "eje maestro" .

ex:EjeEsclavo a ex:ComponenteMecanico ;
    ex:textoExtracto "el eje esclavo" ;
    ex:identificador "eje esclavo" .

ex:Parametro_REFDIREC a ex:Parametro ;
    ex:textoExtracto "parámetro REFDIREC" ;
    ex:identificador "REFDIREC" .

ex:Parametro_REFFEED1 a ex:Parametro ;
    ex:textoExtracto "parámetro REFFEED1" ;
    ex:identificador "REFFEED1" .

ex:Parametro_REFFEED2 a ex:Parametro ;
    ex:textoExtracto "parámetro REFFEED2" ;
    ex:identificador "REFFEED2" .

ex:Parametro_REFVALUE a ex:Parametro ;
    ex:textoExtracto "parámetro REFVALUE" ;
    ex:identificador "REFVALUE" .

ex:Parametro_REFSHIFT a ex:Parametro ;
    ex:textoExtracto "parámetro REFSHIFT" ;
    ex:identificador "REFSHIFT" .

ex:MicroEjeMaestro a ex:Sensor ;
    ex:textoExtracto "pulse su micro" ;
    ex:identificador "micro del eje maestro" .

ex:MicroEjeEsclavo a ex:Sensor ;
    ex:textoExtracto "el eje esclavo encuentre el I0" ;
    ex:identificador "I0" .

ex:CNC a ex:Maquina ;
    ex:textoExtracto "El CNC comenzará el desplazamiento" .

ex:SistemaEjesGantry a ex:Sistema ;
    ex:textoExtracto "ambos ejes" ;
    ex:compuestoPor ex:EjeMaestro, ex:EjeEsclavo ;
    ex:controla ex:CNC .