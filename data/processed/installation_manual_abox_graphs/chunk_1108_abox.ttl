@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionDeTeclado a ns1:TareaMantenimiento ;
    rdfs:label "Configuración de Teclado" ;
    ns1:ejecutadoPor ns1:PersonalTecnico ;
    ns1:textoExtracto "1 Hacer click en el Menú de inicio > Panel de control > Configuración regional y de idioma." .

ns1:DistribucionTecladoEEUU a ns1:Componente ;
    rdfs:label "Distribución del Teclado Inglés (Estados Unidos)" ;
    ns1:textoExtracto "Inglés (Estados Unidos)." .

ns1:DistribucionTecladoEspana a ns1:Componente ;
    rdfs:label "Distribución del Teclado Español (España)" ;
    ns1:textoExtracto "Español (España)." .

ns1:SistemaOperativoWindows a ns1:Sistema ;
    rdfs:label "Sistema Operativo Windows" ;
    ns1:textoExtracto "Para poder cambiar la distribución del teclado, hay que añadir a Windows el idioma de entrada y la distribución de teclado deseada." .

ns1:PersonalTecnico a ns1:Personal ;
    rdfs:label "Técnico" ;
    ns1:textoExtracto "1 Hacer click en el Menú de inicio > Panel de control > Configuración regional y de idioma." .

