@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EjeMaestro a ex:Maquina ;
    rdfs:label "eje maestro" ;
    ex:textoExtracto "el CNC lee el incremento en la cota real del eje esclavo y la envía al eje maestro como incremento de la cota teórica, haciendo así que el eje maestro siga al esclavo" .

ex:EjeEsclavo a ex:Maquina ;
    rdfs:label "eje esclavo" ;
    ex:textoExtracto "el CNC envía al regulador la orden de referenciar el eje esclavo"@es, "el CNC lee el incremento en la cota real del eje esclavo"@es .