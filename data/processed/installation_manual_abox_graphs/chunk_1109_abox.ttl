@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_89a0576a29 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Los códigos de tecla (scan codes) permiten conocer cuál ha sido la última tecla aceptada por el CNC y también permiten simular el teclado desde el PLC." ;
    ns1:tieneComponente ns1:CodigoDeTecla,
        ns1:CodigoDeTeclaPulsado,
        ns1:CodigoDeTeclaSoltado .

ns1:SimulacionDeTeclado a ns1:TareaMantenimiento ;
    rdfs:label "Simulación de Teclado" ;
    ns1:textoExtracto "Los códigos de tecla (scan codes) permiten conocer cuál ha sido la última tecla aceptada por el CNC y también permiten simular el teclado desde el PLC." .

ns1:TeclaReset a ns1:AccionProhibida ;
    rdfs:label "Tecla [RESET]" ;
    ns1:textoExtracto "Las teclas [START], [STOP] y [RESET] se pueden accionar desde el PLC mediante las marcas CYSTART, _STOP y RESETIN respectivamente." .

ns1:TeclaStart a ns1:AccionProhibida ;
    rdfs:label "Tecla [START]" ;
    ns1:textoExtracto "Las teclas [START], [STOP] y [RESET] se pueden accionar desde el PLC mediante las marcas CYSTART, _STOP y RESETIN respectivamente." .

ns1:TeclaStop a ns1:AccionProhibida ;
    rdfs:label "Tecla [STOP]" ;
    ns1:textoExtracto "Las teclas [START], [STOP] y [RESET] se pueden accionar desde el PLC mediante las marcas CYSTART, _STOP y RESETIN respectivamente." .

ns1:CodigoDeTecla a ns1:Parametro ;
    rdfs:label "Código de Tecla" ;
    ns1:textoExtracto "A cada tecla le corresponden dos códigos; uno para la acción de pulsar tecla y otro para la acción de soltar tecla." .

ns1:CodigoDeTeclaPulsado a ns1:Parametro ;
    rdfs:label "Código de Tecla Pulsado" ;
    ns1:textoExtracto "A cada tecla le corresponden dos códigos; uno para la acción de pulsar tecla y otro para la acción de soltar tecla." .

ns1:CodigoDeTeclaSoltado a ns1:Parametro ;
    rdfs:label "Código de Tecla Soltado" ;
    ns1:textoExtracto "A cada tecla le corresponden dos códigos; uno para la acción de pulsar tecla y otro para la acción de soltar tecla." .

