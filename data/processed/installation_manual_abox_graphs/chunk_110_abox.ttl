@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ParametroMPG_NEGERROR a ex:Parametro ;
    rdfs:label "MPG.NEGERROR[tbl][pt]" ;
    ex:identificador "MPG.NEGERROR[tbl][pt]" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.NEGERROR[tbl][pt] Parámetro incluido en la tabla CROSSCOMP // DATA. Este parámetro indica el error en el eje compensado cuando el eje maestro se desplaza en sentido negativo." ;
    ex:valor "0" .

ex:TablaCROSSCOMP_DATA a ex:Tabla ;
    ex:identificador "CROSSCOMP // DATA" ;
    ex:textoExtracto "Parámetro incluido en la tabla CROSSCOMP // DATA." ;
    ex:compuestoPor ex:ParametroMPG_NEGERROR .