@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EjeMaestro a ex:Maquina ;
    rdfs:label "eje maestro" ;
    ex:textoExtracto "el eje maestro" .

ex:EjeEsclavo a ex:Maquina ;
    rdfs:label "eje esclavo" ;
    ex:textoExtracto "el eje esclavo" .

ex:CNC a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "el CNC" .

ex:Parametro_REFFEED1 a ex:Parametro ;
    rdfs:label "REFFEED1" ;
    ex:identificador "REFFEED1" ;
    ex:textoExtracto "parámetro REFFEED1" .

ex:Parametro_REFFEED2 a ex:Parametro ;
    rdfs:label "REFFEED2" ;
    ex:identificador "REFFEED2" ;
    ex:textoExtracto "parámetro REFFEED2" .

ex:Parametro_DIFFCOMP a ex:Parametro ;
    rdfs:label "DIFFCOMP" ;
    ex:identificador "DIFFCOMP" ;
    ex:textoExtracto "parámetro DIFFCOMP" .

ex:Parametro_SERVOxnON a ex:Parametro ;
    rdfs:label "SERVOxnON" ;
    ex:identificador "SERVOxnON" ;
    ex:textoExtracto "marca SERVOxnON" .

ex:Parametro_SERVOaxisON a ex:Parametro ;
    rdfs:label "SERVOaxisON" ;
    ex:identificador "SERVO(axis)ON" ;
    ex:textoExtracto "SERVO(axis)ON" .

ex:Parametro_DIFFCOMPaxis a ex:Parametro ;
    rdfs:label "DIFFCOMP(axis)" ;
    ex:identificador "DIFFCOMP(axis)" ;
    ex:textoExtracto "marca DIFFCOMP(axis)" .

ex:CNC ex:controla ex:EjeMaestro ;
    ex:controla ex:EjeEsclavo ;
    ex:textoExtracto "el CNC envía al eje maestro como incremento de la cota teórica, haciendo así que el eje maestro siga al esclavo" ;
    ex:textoExtracto "el CNC envía al regulador la orden de referenciar el eje maestro" ;
    ex:textoExtracto "el CNC vigila que el incremento de la cota real se corresponda como máximo al avance de búsqueda de referencia (parámetro REFFEED1)" ;
    ex:textoExtracto "el CNC tiene en cuenta la diferencia de cotas para corregirla, si está permitido por el parámetro DIFFCOMP" .

ex:Parametro_REFFEED1 ex:valor "avance de búsqueda de referencia" ;
    ex:textoExtracto "parámetro REFFEED1" .

ex:Parametro_REFFEED2 ex:valor "avance especificado en el parámetro REFFEED2" ;
    ex:textoExtracto "parámetro REFFEED2" .

ex:Parametro_DIFFCOMP ex:valor "habilita la corrección de la diferencia de cota entre el eje maestro y el esclavo tras la búsqueda de referencia máquina" ;
    ex:textoExtracto "parámetro DIFFCOMP" .

ex:Parametro_SERVOxnON ex:valor "flanco de subida de la marca SERVOxnON" ;
    ex:textoExtracto "marca SERVOxnON" .

ex:Parametro_SERVOaxisON ex:valor "flanco de subida de SERVO(axis)ON" ;
    ex:textoExtracto "SERVO(axis)ON" .

ex:Parametro_DIFFCOMPaxis ex:valor "corrige la diferencia de cota entre el eje maestro y esclavo" ;
    ex:textoExtracto "marca DIFFCOMP(axis)" .