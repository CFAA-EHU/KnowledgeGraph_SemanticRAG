@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:DIFFCOMP_axis a ex:ComponenteElectrico ;
    rdfs:label "DIFFCOMP(axis)" ;
    ex:textoExtracto "La marca DIFFCOMP(axis) corrige la diferencia de cota entre el eje maestro y esclavo, de la siguiente manera." .

ex:SERVO_axis_ON a ex:ModoOperacion ;
    rdfs:label "SERVO(axis)ON" ;
    ex:textoExtracto "Con el flanco de subida de SERVO(axis)ON si DIFFCOMP(axis) está activa." .

ex:REFPOIN_axis a ex:Sensor ;
    rdfs:label "REFPOIN(axis)" ;
    ex:textoExtracto "La marca REFPOIN(axis) de ambos ejes se activa cuando termina la corrección de la cota." .