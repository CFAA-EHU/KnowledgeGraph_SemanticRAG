@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ApagarElCNC a ns1:TareaMantenimiento ;
    rdfs:label "Apagar el CNC" ;
    ns1:textoExtracto "[CTRL]+[W] - Apagar el CNC." .

ns1:MinimizarMaximizarElCNC a ns1:TareaMantenimiento ;
    rdfs:label "Minimizar/Maximizar el CNC" ;
    ns1:textoExtracto "[CTRL]+[O] - Minimizar/Maximizar el CNC." .

ns1:MostrarOcultarLaVentanaDeErroresYWarnings a ns1:TareaMantenimiento ;
    rdfs:label "Mostrar / ocultar la ventana de errores y warnings" ;
    ns1:textoExtracto "[ALT]+[W] - Mostrar / ocultar la ventana de errores y warnings." .

ns1:VentanaDeSincronizacionDeCanales a ns1:TareaMantenimiento ;
    rdfs:label "Ventana de sincronización de canales" ;
    ns1:textoExtracto "[ALT]+[S] - Ventana de sincronización de canales." .

