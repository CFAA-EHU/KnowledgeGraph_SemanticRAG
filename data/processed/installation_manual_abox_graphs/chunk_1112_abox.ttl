@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CodigoDeLaUltimaTeclaAceptadaPorElCNC a ns1:Parametro ;
    rdfs:label "Código de la última tecla aceptada por el CNC" ;
    ns1:documentadoEn ns1:ComandoCNCRD,
        ns1:InterfazUsuarioCNC,
        ns1:SistemaPLC ;
    ns1:identificador "G.KEY" ;
    ns1:textoExtracto "La variable (V.)G.KEY guarda el código de la última tecla aceptada por el CNC (código de tecla pulsada)." .

ns1:Parametro_913dcd525c a ns1:Parametro ;
    rdfs:label "Marca que indica inicio y fin de operación del PLC" ;
    ns1:identificador "M100" ;
    ns1:textoExtracto "El PLC activa la marca M100 cuando comienza la operación y la mantiene así hasta que finaliza la misma." .

ns1:RegistroQueAlmacenaElCodigoDeLaTecla a ns1:Parametro ;
    rdfs:label "Registro que almacena el código de la tecla" ;
    ns1:identificador "R100" ;
    ns1:textoExtracto "El comando CNCRD guarda el código de la tecla en el registro R100." .

ns1:ComandoCNCRD a ns1:AccionProhibida ;
    rdfs:label "Comando CNCRD" ;
    ns1:textoExtracto "El comando CNCRD guarda el código de la tecla en el registro R100." .

ns1:InterfazUsuarioCNC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de usuario del CNC" ;
    ns1:textoExtracto "Esta variable es de lectura desde el programa e interfaz." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Esta variable es de lectura y escritura desde el PLC." .

