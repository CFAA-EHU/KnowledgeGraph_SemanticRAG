@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:LimiteSoftwareSL ex:textoExtracto "SL Límites de software, aplicados por el CNC." ;
    a ex:Parametro ;
    ex:identificador "SL" .

ex:LimiteFisicoFL ex:textoExtracto "FL Límites físicos." ;
    a ex:Parametro ;
    ex:identificador "FL" .

ex:CeroMaquina ex:textoExtracto "Cero máquina." ;
    a ex:Parametro .

ex:PuntoReferenciaPortaherramientas ex:textoExtracto "Punto de referencia del portaherramientas." ;
    a ex:Parametro .

ex:CNC ex:textoExtracto "El CNC permite definir límites de software en los ejes lineales y ejes rotativos linearlike." ;
    a ex:Maquina .

ex:EjeX ex:textoExtracto "X" ;
    a ex:ComponenteMecanico .

ex:EjeZ ex:textoExtracto "Z" ;
    a ex:ComponenteMecanico .

ex:EjeSL ex:textoExtracto "SL" ;
    a ex:ComponenteMecanico .

ex:EjeT ex:textoExtracto "T" ;
    a ex:ComponenteMecanico .

ex:EjeO ex:textoExtracto "O" ;
    a ex:ComponenteMecanico .

ex:EjeM ex:textoExtracto "M" ;
    a ex:ComponenteMecanico .

ex:EjeY ex:textoExtracto "Y" ;
    a ex:ComponenteMecanico .

ex:EjeFL ex:textoExtracto "FL" ;
    a ex:ComponenteMecanico .

ex:EjeLinealLike ex:textoExtracto "linearlike" ;
    a ex:ModoOperacion .

ex:LimiteSoftwareSuperior1 ex:textoExtracto "el límite superior e inferior más restrictivo" ;
    a ex:Parametro .

ex:LimiteSoftwareInferior1 ex:textoExtracto "el límite superior e inferior más restrictivo" ;
    a ex:Parametro .

ex:LimiteSoftwareSuperior2 ex:textoExtracto "el límite superior e inferior más restrictivo" ;
    a ex:Parametro .

ex:LimiteSoftwareInferior2 ex:textoExtracto "el límite superior e inferior más restrictivo" ;
    a ex:Parametro .

ex:VariableLimiteSoftware ex:textoExtracto "El CNC dispone de la siguiente variable para indicar que alguno de los ejes alcanzado los límites de software." ;
    a ex:Parametro .

ex:ModoManual ex:textoExtracto "acceder al modo manual y mover el eje o cabezal que ha sobrepasado el límite." ;
    a ex:ModoOperacion .

ex:AccionDetenerEjecucion ex:textoExtracto "el CNC detiene la ejecución y muestra el error correspondiente." ;
    a ex:AccionProhibida .

ex:AccionMostrarError ex:textoExtracto "el CNC detiene la ejecución y muestra el error correspondiente." ;
    a ex:AccionProhibida .