@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:LIMITPOS ex:textoExtracto "LIMITPOS(axis) El eje ha alcanzado el límite superior de software." ;
    a ex:Parametro ;
    ex:identificador "LIMITPOS(axis)" .

ex:LIMITNEG ex:textoExtracto "LIMITNEG(axis) El eje ha alcanzado el límite inferior de software." ;
    a ex:Parametro ;
    ex:identificador "LIMITNEG(axis)" .

ex:G_SOFTLIMIT ex:textoExtracto "(V.)[ch].G.SOFTLIMIT Límites de software alcanzados. El PLC activa una de estas marcas para indicar al CNC que el eje o cabezal correspondiente ha alcanzado el límite de software en sentido positivo o negativo." ;
    a ex:Parametro ;
    ex:identificador "(V.)[ch].G.SOFTLIMIT" .