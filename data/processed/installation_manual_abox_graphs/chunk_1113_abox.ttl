@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_541caf6886 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documenta ns1:SimulacionDelTecladoDesdeElPLC ;
    ns1:textoExtracto "Para escribir la variable desde el PLC utilizar el comando CNCWR." .

ns1:CodigoDeLaTeclaParaSimularElTecladoDesdeElPLC a ns1:Parametro ;
    rdfs:label "Código de la tecla para simular el teclado desde el PLC" ;
    ns1:identificador "G.KEY" ;
    ns1:textoExtracto "Para simular el teclado desde el PLC, escribir en la variable (V.)G.KEY el código de la tecla." .

ns1:Parametro_e9d21d580b a ns1:Parametro ;
    rdfs:label "Marca M101 para activación de operación" ;
    ns1:identificador "M101" ;
    ns1:textoExtracto "El PLC activa la marca M101 cuando comienza la operación y la mantiene así hasta que finaliza la misma." .

ns1:RegistroR101ParaEscrituraDeVariables a ns1:Parametro ;
    rdfs:label "Registro R101 para escritura de variables" ;
    ns1:identificador "R101" ;
    ns1:textoExtracto "El comando CNCWR escribe en la variable el valor del registro R101." .

ns1:SimulacionDelTecladoDesdeElPLC a ns1:TareaMantenimiento ;
    rdfs:label "Simulación del teclado desde el PLC" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:solucionaFallo ns1:FalloPresionHidraulicaBaja ;
    ns1:textoExtracto "Para simular el teclado desde el PLC, escribir en la variable (V.)G.KEY el código de la tecla." .

