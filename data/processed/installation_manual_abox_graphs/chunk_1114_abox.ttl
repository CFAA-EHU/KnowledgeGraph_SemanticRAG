@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_fcd722317a a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "DFU B0KEYBD1 = CNCWR(R200,G.KEY,M200) = TG1 200 200" .

ns1:PrimeraTeclaDeUsuario a ns1:Parametro ;
    rdfs:label "Primera tecla de usuario" ;
    ns1:identificador "B0KEYBD1" ;
    ns1:textoExtracto "La primera tecla de usuario (B0KEYBD1) envía el carácter \"a\"." .

ns1:PulsarLaTeclaA a ns1:Parametro ;
    rdfs:label "Pulsar la tecla [A]" ;
    ns1:identificador "R200" ;
    ns1:textoExtracto "() = MOV $1E R200 ; Pulsar la tecla [A]" .

ns1:PulsarLaTeclaSHIFT a ns1:Parametro ;
    rdfs:label "Pulsar la tecla [SHIFT]" ;
    ns1:identificador "R202" ;
    ns1:textoExtracto "() = MOV $2A R202 ; Pulsar la tecla [SHIFT]" .

ns1:SegundaTeclaDeUsuario a ns1:Parametro ;
    rdfs:label "Segunda tecla de usuario" ;
    ns1:identificador "B1KEYBD1" ;
    ns1:textoExtracto "La segunda tecla de usuario (B1KEYBD1) envía el carácter \"A\"." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Para simular desde el PLC una combinación de teclas (por ejemplo [CTRL]+[F1])" .

ns1:SoltarLaTeclaA a ns1:Parametro ;
    rdfs:label "Soltar la tecla [A]" ;
    ns1:identificador "R201" ;
    ns1:textoExtracto "() = MOV $9E R201 ; Soltar la tecla [A]" .

ns1:SoltarLaTeclaSHIFT a ns1:Parametro ;
    rdfs:label "Soltar la tecla [SHIFT]" ;
    ns1:identificador "R203" ;
    ns1:textoExtracto "() = MOV $AA R203 ; Soltar la tecla [SHIFT]" .

