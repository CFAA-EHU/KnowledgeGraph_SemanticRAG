@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:G198 a ex:Parametro ;
    ex:identificador "G198" ;
    ex:textoExtracto "G198 | (V.)[ch].A.NEGLIMIT.xn | Límites inferiores de software." .

ex:G199 a ex:Parametro ;
    ex:identificador "G199" ;
    ex:textoExtracto "G199 | (V.)[ch].A.POSLIMIT.xn | Límites superiores de software." .

ex:LimiteSoftwareInferior a ex:Parametro ;
    ex:identificador "(V.)[ch].A.NEGLIMIT.xn" ;
    ex:textoExtracto "(V.)[ch].A.NEGLIMIT.xn | Límites inferiores de software." .

ex:LimiteSoftwareSuperior a ex:Parametro ;
    ex:identificador "(V.)[ch].A.POSLIMIT.xn" ;
    ex:textoExtracto "(V.)[ch].A.POSLIMIT.xn | Límites superiores de software." .

ex:ModoTrabajoAbsoluto a ex:ModoOperacion ;
    ex:identificador "G90" ;
    ex:textoExtracto "G90" .

ex:ModoTrabajoIncremental a ex:ModoOperacion ;
    ex:identificador "G91" ;
    ex:textoExtracto "G91" .

ex:SegundoLimiteSoftware a ex:Parametro ;
    ex:identificador "segundos límites de software" ;
    ex:textoExtracto "Segundos límites de software. Estos límites de software se definen mediante las siguientes variables, con permiso de escritura desde el programa pieza, MDI, PLC o interfaz. Estas variables se inicializan en el encendido, asumiendo el máximo valor posible." .