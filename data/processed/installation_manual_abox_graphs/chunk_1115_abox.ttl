@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PrimeraTeclaDeUsuario a ns1:Parametro ;
    rdfs:label "Primera tecla de usuario" ;
    ns1:identificador "B0KEYBD1" ;
    ns1:textoExtracto "La primera tecla de usuario (B0KEYBD1) envía la combinación [CTRL]+[F1]." .

ns1:RegistroParaPulsarTeclaCTRL a ns1:Parametro ;
    rdfs:label "Registro para pulsar tecla [CTRL]" ;
    ns1:identificador "R204" ;
    ns1:textoExtracto "() = MOV $1D R204 ; Pulsar la tecla [CTRL]" .

ns1:RegistroParaPulsarTeclaF1 a ns1:Parametro ;
    rdfs:label "Registro para pulsar tecla [F1]" ;
    ns1:identificador "R206" ;
    ns1:textoExtracto "() = MOV $3B R206 ; Pulsar la tecla [F1]" .

ns1:RegistroParaSoltarTeclaCTRL a ns1:Parametro ;
    rdfs:label "Registro para soltar tecla [CTRL]" ;
    ns1:identificador "R205" ;
    ns1:textoExtracto "() = MOV $9D R205 ; Soltar la tecla [CTRL]" .

ns1:RegistroParaSoltarTeclaF1 a ns1:Parametro ;
    rdfs:label "Registro para soltar tecla [F1]" ;
    ns1:identificador "R207" ;
    ns1:textoExtracto "() = MOV $BB R207 ; Soltar la tecla [F1]" .

