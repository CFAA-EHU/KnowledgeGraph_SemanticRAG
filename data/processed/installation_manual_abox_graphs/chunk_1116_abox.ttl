@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Variable_V_ch_A_RTNEGLIMIT_xn a ex:Parametro ;
    rdfs:label "(V.)[ch].A.RTNEGLIMIT.xn" ;
    ex:identificador "(V.)[ch].A.RTNEGLIMIT.xn" ;
    ex:textoExtracto "Variable: (V.)[ch].A.RTNEGLIMIT.xn. Significado: Límites inferiores de software (segundos límites)." ;
    ex:valor "Límites inferiores de software (segundos límites)" .

ex:Variable_V_ch_A_RTPOSLIMIT_xn a ex:Parametro ;
    rdfs:label "(V.)[ch].A.RTPOSLIMIT.xn" ;
    ex:identificador "(V.)[ch].A.RTPOSLIMIT.xn" ;
    ex:textoExtracto "Variable: (V.)[ch].A.RTPOSLIMIT.xn. Significado: Límites superiores de software (segundos límites)." ;
    ex:valor "Límites superiores de software (segundos límites)" .

ex:Variable_LimitesSoftware a ex:Parametro ;
    rdfs:label "Límites de software" ;
    ex:textoExtracto "Si ambos límites de un eje (inferior y superior) se definen con valor ꞏ0ꞏ, se anulan dichos límites y el CNC aplicará al eje los primeros límites de software." ;
    ex:valor "Límites de software" .