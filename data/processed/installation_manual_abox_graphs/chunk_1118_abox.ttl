@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_39a5f50557 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controladoPor ns1:TeclaUsuarioB0KEYBD1 ;
    ns1:textoExtracto "El CNC accede al modo manual. El CNC accede al modo MDI. El CNC realiza una búsqueda de referencia máquina del eje X." .

ns1:ModoMDI a ns1:ModoOperacion ;
    rdfs:label "Modo MDI" ;
    ns1:textoExtracto "El CNC accede al modo MDI. Tras finalizar la búsqueda de referencia máquina, el CNC sale del modo MDI." .

ns1:ModoManual a ns1:ModoOperacion ;
    rdfs:label "Modo Manual" ;
    ns1:textoExtracto "El CNC accede al modo manual." .

ns1:SimularElTecladoDesdeElPLC a ns1:TareaMantenimiento ;
    rdfs:label "Simular el teclado desde el PLC" ;
    ns1:ejecuta ns1:AccederAlModoMDI,
        ns1:AccederAlModoManual,
        ns1:BusquedaReferenciaMaquinaEjeX,
        ns1:SalirDelModoMDI ;
    ns1:textoExtracto "La primera tecla de usuario (B0KEYBD1) realiza las siguientes operaciones. 1 El CNC accede al modo manual. 2 El CNC accede al modo MDI. 3 El CNC realiza una búsqueda de referencia máquina del eje X. 4 Tras finalizar la búsqueda de referencia máquina, el CNC sale del modo MDI." .

ns1:AccederAlModoMDI a ns1:AccionProhibida ;
    rdfs:label "Acceder al modo MDI" ;
    ns1:textoExtracto "El CNC accede al modo MDI." .

ns1:AccederAlModoManual a ns1:AccionProhibida ;
    rdfs:label "Acceder al modo manual" ;
    ns1:textoExtracto "El CNC accede al modo manual." .

ns1:BusquedaReferenciaMaquinaEjeX a ns1:AccionProhibida ;
    rdfs:label "Búsqueda de Referencia Máquina Eje X" ;
    ns1:textoExtracto "El CNC realiza una búsqueda de referencia máquina del eje X." .

ns1:SalirDelModoMDI a ns1:AccionProhibida ;
    rdfs:label "Salir del modo MDI" ;
    ns1:textoExtracto "Tras finalizar la búsqueda de referencia máquina, el CNC sale del modo MDI." .

ns1:TeclaUsuarioB0KEYBD1 a ns1:Componente ;
    rdfs:label "Tecla Usuario B0KEYBD1" ;
    ns1:textoExtracto "La primera tecla de usuario (B0KEYBD1) realiza las siguientes operaciones." .

