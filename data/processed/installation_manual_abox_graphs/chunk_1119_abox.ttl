@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_1fa428cb9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC accede al modo manual. [ CTRL]+[F7]" ;
    ns1:tieneComponente ns1:RegistroDeControlParaTeclaCTRL,
        ns1:RegistroDeControlParaTeclaF7,
        ns1:RegistroDeControlParaTeclaF8 .

ns1:RegistroDeControlParaTeclaCTRL a ns1:Parametro ;
    rdfs:label "Registro de control para tecla [CTRL]" ;
    ns1:identificador "R200" ;
    ns1:textoExtracto "() = MOV $1D R200 = MOV $9D R201 ; [CTRL]" .

ns1:RegistroDeControlParaTeclaF7 a ns1:Parametro ;
    rdfs:label "Registro de control para tecla [F7]" ;
    ns1:identificador "R202" ;
    ns1:textoExtracto "() = MOV $41 R202 = MOV $C1 R203 ; [F7]" .

ns1:RegistroDeControlParaTeclaF8 a ns1:Parametro ;
    rdfs:label "Registro de control para tecla [F8]" ;
    ns1:identificador "R204" ;
    ns1:textoExtracto "() = MOV $42 R204 = MOV $C2 R205 ; [F8]" .

