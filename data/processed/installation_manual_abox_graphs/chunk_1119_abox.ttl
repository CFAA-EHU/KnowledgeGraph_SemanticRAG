@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:CompensacionVolumetricaGrande a ex:ModoOperacion ;
    rdfs:label "Compensación volumétrica grande" ;
    ex:textoExtracto "La opción \"Compensación volumétrica grande\" también permite utilizar los otros dos tipos de compensación, media y básica." ;
    ex:tieneComponente ex:CompensacionVolumetricaMedia, ex:CompensacionVolumetricaBasica .

ex:CompensacionVolumetricaMedia a ex:ModoOperacion ;
    rdfs:label "Compensación volumétrica media" ;
    ex:textoExtracto "La opción \"Compensación volumétrica grande\" también permite utilizar los otros dos tipos de compensación, media y básica." ;
    ex:tieneComponente ex:CompensacionVolumetricaBasica .

ex:CompensacionVolumetricaBasica a ex:ModoOperacion ;
    rdfs:label "Compensación volumétrica básica" ;
    ex:textoExtracto "La opción \"Compensación volumétrica grande\" también permite utilizar los otros dos tipos de compensación, media y básica." .