@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:volcomp_111
    a               ex:Parametro ;
    rdfs:label      "VOLCOMP (Tablas de compensación volumétrica)"@es ;
    ex:textoExtracto "VOLCOMP Tablas de compensación volumétrica. Este parámetro muestra las tablas de compensación volumétrica. Las compensaciones volumétricas se configuran en los parámetros máquina y se activan desde el PLC (marcas VOLCOMP1 a VOLCOMP4)."@es ;
    ex:identificador "VOLCOMP" ;
    ex:monitoreaParametro ex:tabla_volcomp_config_111 .

ex:tabla_volcomp_config_111
    a               ex:Tabla ;
    rdfs:label      "Configuración de tablas de compensación volumétrica"@es ;
    ex:textoExtracto "VOLCOMP n Configuración de las tablas de compensación volumétrica. Este parámetro muestra la tabla de parámetros para definir las compensaciones volumétricas del sistema."@es ;
    ex:detalladoEnEsquema ex:parametros_volcomp_111 ;
    ex:tieneComponente ex:param_vcompaxis1_111 ,
                        ex:param_vcompaxis2_111 ,
                        ex:param_vcompaxis3_111 ,
                        ex:param_vcompfile_111 .

ex:parametros_volcomp_111
    a               ex:Sistema ;
    rdfs:label      "Parámetros de compensación volumétrica (VCOMPAXIS1-VCOMPAXIS3, VCOMPFILE)"@es ;
    ex:textoExtracto "Cada una de las tablas dispone de los siguientes parámetros máquina para su configuración. Compensación volumétrica media y grande."@es .

ex:param_vcompaxis1_111
    a               ex:Parametro ;
    rdfs:label      "VCOMPAXIS1" ;
    ex:textoExtracto "Nombre del primer eje a compensar."@es ;
    ex:identificador "VCOMPAXIS1" ;
    ex:documentadoEn ex:tabla_volcomp_config_111 .

ex:param_vcompaxis2_111
    a               ex:Parametro ;
    rdfs:label      "VCOMPAXIS2" ;
    ex:textoExtracto "Nombre del segundo eje a compensar."@es ;
    ex:identificador "VCOMPAXIS2" ;
    ex:documentadoEn ex:tabla_volcomp_config_111 .

ex:param_vcompaxis3_111
    a               ex:Parametro ;
    rdfs:label      "VCOMPAXIS3" ;
    ex:textoExtracto "Nombre del tercer eje a compensar."@es ;
    ex:identificador "VCOMPAXIS3" ;
    ex:documentadoEn ex:tabla_volcomp_config_111 .

ex:param_vcompfile_111
    a               ex:Parametro ;
    rdfs:label      "VCOMPFILE" ;
    ex:textoExtracto "Archivo con los datos de la compensación volumétrica."@es ;
    ex:identificador "VCOMPFILE" ;
    ex:documentadoEn ex:tabla_volcomp_config_111 .