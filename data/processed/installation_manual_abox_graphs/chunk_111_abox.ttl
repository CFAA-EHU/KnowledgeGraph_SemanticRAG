@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:VOLCOMP a ex:Parametro ;
    rdfs:label "VOLCOMP" ;
    ex:textoExtracto "VOLCOMP Tablas de compensación volumétrica. Este parámetro muestra las tablas de compensación volumétrica." ;
    ex:valor "Tablas de compensación volumétrica" .

ex:VOLCOMP1 a ex:ModoOperacion ;
    rdfs:label "VOLCOMP1" ;
    ex:textoExtracto "se activan desde el PLC (marcas VOLCOMP1 a VOLCOMP4)" .

ex:VOLCOMP2 a ex:ModoOperacion ;
    rdfs:label "VOLCOMP2" ;
    ex:textoExtracto "se activan desde el PLC (marcas VOLCOMP1 a VOLCOMP4)" .

ex:VOLCOMP3 a ex:ModoOperacion ;
    rdfs:label "VOLCOMP3" ;
    ex:textoExtracto "se activan desde el PLC (marcas VOLCOMP1 a VOLCOMP4)" .

ex:VOLCOMP4 a ex:ModoOperacion ;
    rdfs:label "VOLCOMP4" ;
    ex:textoExtracto "se activan desde el PLC (marcas VOLCOMP1 a VOLCOMP4)" .

ex:VCOMPAXIS1 a ex:Parametro ;
    rdfs:label "VCOMPAXIS1" ;
    ex:textoExtracto "Nombre del primer eje a compensar" .

ex:VCOMPAXIS2 a ex:Parametro ;
    rdfs:label "VCOMPAXIS2" ;
    ex:textoExtracto "Nombre del segundo eje a compensar" .

ex:VCOMPAXIS3 a ex:Parametro ;
    rdfs:label "VCOMPAXIS3" ;
    ex:textoExtracto "Nombre del tercer eje a compensar" .

ex:VCOMPFILE a ex:Parametro ;
    rdfs:label "VCOMPFILE" ;
    ex:textoExtracto "Archivo con los datos de la compensación volumétrica" .