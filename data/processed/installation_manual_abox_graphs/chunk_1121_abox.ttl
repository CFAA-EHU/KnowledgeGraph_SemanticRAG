@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:CompensacionVolumetricaBasica a ex:ModoOperacion ;
    rdfs:label "compensación volumétrica básica"@es ;
    ex:textoExtracto "En la compensación volumétrica básica hay que definir ambos ejes, el que se mueve y el que se compensa."@es .

ex:EjeMovimiento a ex:Componente ;
    rdfs:label "eje que se mueve"@es ;
    ex:textoExtracto "el que se mueve"@es ;
    ex:compuestoPor ex:CompensacionVolumetricaBasica .

ex:EjeCompensacion a ex:Componente ;
    rdfs:label "eje que se compensa"@es ;
    ex:textoExtracto "el que se compensa"@es ;
    ex:compuestoPor ex:CompensacionVolumetricaBasica .