@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_VCOMPFILE a ex:Parametro ;
    rdfs:label "VCOMPFILE" ;
    ex:textoExtracto "El CNC muestra estos parámetros al cargar un archivo con extensión csv en el parámetro VCOMPFILE." .

ex:CNC a ex:Maquina ;
    ex:textoExtracto "El CNC muestra estos parámetros al cargar un archivo con extensión csv en el parámetro VCOMPFILE." .