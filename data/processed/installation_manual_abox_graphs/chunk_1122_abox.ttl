@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_VCOMPFILE
    a               ex:Parametro ;
    rdfs:label      "VCOMPFILE" ;
    ex:textoExtracto "El CNC muestra estos parámetros al cargar un archivo con extensión csv en el parámetro VCOMPFILE." ;
    ex:identificador "VCOMPFILE" .

ex:InterfazUsuario_CNC_Parametros
    a               ex:InterfazUsuario ;
    rdfs:label      "Interfaz de usuario del CNC (parámetros)" ;
    ex:textoExtracto "El CNC muestra estos parámetros al cargar un archivo con extensión csv en el parámetro VCOMPFILE." ;
    ex:monitoreaParametro ex:Parametro_VCOMPFILE .