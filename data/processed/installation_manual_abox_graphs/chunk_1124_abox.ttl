@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EjeGantry a ex:Maquina ;
    rdfs:label "eje gantry"@es ;
    ex:textoExtracto "el eje es gantry"@es .

ex:ParametroMaquina_VCOMPFILE a ex:Parametro ;
    rdfs:label "VCOMPFILE"@es ;
    ex:identificador "VCOMPFILE MPG"@es ;
    ex:textoExtracto "El archivo con los datos a compensar será un archivo de texto (formato csv). El OEM o la empresa responsable de la calibración deben generar este archivo y definirlo en el parámetro máquina VCOMPFILE."@es .

ex:ParametroMaquina_INCHES a ex:Parametro ;
    rdfs:label "INCHES"@es ;
    ex:textoExtracto "Las unidades de los datos del archivo (milímetros o pulgadas) deben ser las definidas en el CNC (parámetro INCHES)."@es .

ex:CompensacionEje a ex:Parametro ;
    rdfs:label "compensación de eje"@es ;
    ex:textoExtracto "Un eje puede estar incluido en varias compensaciones, pero compensaciones que comparten ejes no pueden estar activas al mismo tiempo."@es .