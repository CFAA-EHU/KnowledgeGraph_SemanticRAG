@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_VCOMPFILE
    a ex:Parametro ;
    rdfs:label "VCOMPFILE" ;
    ex:textoExtracto "El archivo con los datos a compensar será un archivo de texto (formato csv). El OEM o la empresa responsable de la calibración deben generar este archivo y definirlo en el parámetro máquina VCOMPFILE." ;
    ex:identificador "VCOMPFILE" ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Parametro_INCHES
    a ex:Parametro ;
    rdfs:label "INCHES" ;
    ex:textoExtracto "Las unidades de los datos del archivo (milímetros o pulgadas) deben ser las definidas en el CNC (parámetro INCHES)." ;
    ex:identificador "INCHES" ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "el CNC aplica la compensación también al eje esclavo. [...] Las unidades de los datos del archivo [...] deben ser las definidas en el CNC (parámetro INCHES)." .