@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:VOLCOMP1 a ex:Parametro ;
    rdfs:label "VOLCOMP1" ;
    ex:textoExtracto "Si el PLC activa una de estas marcas (cambio de 0 a 1), el CNC activa la compensación volumétrica correspondiente (parámetro VOLCOMP). Si el PLC desactiva una de estas marcas (cambio de 1 a 0), el CNC desactiva la compensación volumétrica correspondiente. La marca VOLCOMP1 corresponde a la primera compensación volumétrica (parámetro VOLCOMP1);" ;
    ex:valor "PLC_M" .

ex:VOLCOMP2 a ex:Parametro ;
    rdfs:label "VOLCOMP2" ;
    ex:textoExtracto "VOLCOMP2 (R/W). Señal modificable." ;
    ex:valor "PLC_M" .

ex:VOLCOMP3 a ex:Parametro ;
    rdfs:label "VOLCOMP3" ;
    ex:textoExtracto "VOLCOMP3" ;
    ex:valor "PLC_M" .

ex:VOLCOMP4 a ex:Parametro ;
    rdfs:label "VOLCOMP4" ;
    ex:textoExtracto "VOLCOMP4" ;
    ex:valor "PLC_M" .

ex:CompensacionVolumetrica a ex:Parametro ;
    rdfs:label "Compensación volumétrica" ;
    ex:textoExtracto "el CNC activa la compensación volumétrica correspondiente (parámetro VOLCOMP). La compensación volumétrica permanece activa tras un reset, error o fin de programa (M30)." .

ex:PLC_M a ex:ModoOperacion ;
    rdfs:label "PLC_M" ;
    ex:textoExtracto "Marca de PLC. ( R/W).......Señal modificable." .