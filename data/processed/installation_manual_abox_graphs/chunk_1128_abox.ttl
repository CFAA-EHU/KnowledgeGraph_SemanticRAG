    rdfs:label "Torno con 1 canal, 3 ejes y 1 cabezal (Configuración de ejes tipo plano)" ;
    ns1:textoExtracto "Torno con 1 canal, 3 ejes y 1 cabezal. Configuración de ejes tipo plano." .

ns1:MaquinaTorno1Canal3Ejes1CabezalTriedro a ns1:Maquina ;
    rdfs:label "Torno con 1 canal, 3 ejes y 1 cabezal (Configuración de ejes tipo triedro)" ;
    ns1:textoExtracto "Torno con 1 canal, 3 ejes y 1 cabezal. Configuración de ejes tipo triedro." .

ns1:MaquinaTorno1Canal3Ejes1Libre1CabezalPlano a ns1:Maquina ;
    rdfs:label "Torno con 1 canal, 3 ejes (1 libre) y 1 cabezal (Configuración de ejes tipo plano)" ;
    ns1:textoExtracto "Torno con 1 canal, 3 ejes (1 libre) y 1 cabezal. Configuración de ejes tipo plano." .

