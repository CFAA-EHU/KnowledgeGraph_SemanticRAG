    rdfs:label "Fresadora con 1 canal, 5 ejes (2 libres) y 1 cabezal" ;
    ns1:textoExtracto "Fresadora con 1 canal, 5 ejes (2 libres) y 1 cabezal." .

ns1:MaquinaFresadora3Canal9Ejes2Cabezales a ns1:Maquina ;
    rdfs:label "Fresadora con 3 canales, 9 ejes y 2 cabezales" ;
    ns1:textoExtracto "Fresadora con 3 canales, 9 ejes y 2 cabezales. Canal 1: 3 ejes y 1 cabezal. Canal 2: 4 ejes y 1 cabezal. Canal 3: 2 ejes y ningún cabezal." .

ns1:MaquinaTorno1Canal2Ejes1Cabezal a ns1:Maquina ;
    rdfs:label "Torno con 1 canal, 2 ejes y 1 cabezal" ;
    ns1:textoExtracto "Torno con 1 canal, 2 ejes y 1 cabezal. Configuración de ejes tipo plano." .

