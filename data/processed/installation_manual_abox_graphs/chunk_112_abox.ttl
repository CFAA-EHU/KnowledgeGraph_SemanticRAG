@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TablaCompensacionVolumetrica a ex:Tabla ;
    ex:textoExtracto "Tabla de compensación volumétrica básica con parámetros por eje (VMOVAXIS1, VMOVAXIS2, VMOVAXIS3, NPOINTSAX1, NPOINTSAX2, NPOINTSAX3, INIPOSAX1, INIPOSAX2, INIPOSAX3, INCREAX1, INCREAX2, INCREAX3, VCOMPAXIS1, VCOMPAXIS2, VCOMPAXIS3, VCOMPFILE)." ;
    ex:compuestoPor ex:ParametroVMOVAXIS1, ex:ParametroVMOVAXIS2, ex:ParametroVMOVAXIS3, ex:ParametroNPOINTSAX1, ex:ParametroNPOINTSAX2, ex:ParametroNPOINTSAX3, ex:ParametroINIPOSAX1, ex:ParametroINIPOSAX2, ex:ParametroINIPOSAX3, ex:ParametroINCREAX1, ex:ParametroINCREAX2, ex:ParametroINCREAX3, ex:ParametroVCOMPAXIS1, ex:ParametroVCOMPAXIS2, ex:ParametroVCOMPAXIS3, ex:ParametroVCOMPFILE .

ex:ParametroVMOVAXIS1 a ex:Parametro ;
    ex:identificador "VMOVAXIS1" ;
    ex:textoExtracto "VMOVAXIS1: En la compensación volumétrica básica, nombre del eje que al moverse genera variaciones." .

ex:ParametroVMOVAXIS2 a ex:Parametro ;
    ex:identificador "VMOVAXIS2" ;
    ex:textoExtracto "VMOVAXIS2: En la compensación volumétrica básica, nombre del eje que al moverse genera variaciones." .

ex:ParametroVMOVAXIS3 a ex:Parametro ;
    ex:identificador "VMOVAXIS3" ;
    ex:textoExtracto "VMOVAXIS3: En la compensación volumétrica básica, nombre del eje que al moverse genera variaciones." .

ex:ParametroNPOINTSAX1 a ex:Parametro ;
    ex:identificador "NPOINTSAX1" ;
    ex:textoExtracto "NPOINTSAX1: Número de puntos de la compensación volumétrica básica en cada eje." .

ex:ParametroNPOINTSAX2 a ex:Parametro ;
    ex:identificador "NPOINTSAX2" ;
    ex:textoExtracto "NPOINTSAX2: Número de puntos de la compensación volumétrica básica en cada eje." .

ex:ParametroNPOINTSAX3 a ex:Parametro ;
    ex:identificador "NPOINTSAX3" ;
    ex:textoExtracto "NPOINTSAX3: Número de puntos de la compensación volumétrica básica en cada eje." .

ex:ParametroINIPOSAX1 a ex:Parametro ;
    ex:identificador "INIPOSAX1" ;
    ex:textoExtracto "INIPOSAX1: Posición inicial de la compensación volumétrica básica en cada eje MOVAXIS." .

ex:ParametroINIPOSAX2 a ex:Parametro ;
    ex:identificador "INIPOSAX2" ;
    ex:textoExtracto "INIPOSAX2: Posición inicial de la compensación volumétrica básica en cada eje MOVAXIS." .

ex:ParametroINIPOSAX3 a ex:Parametro ;
    ex:identificador "INIPOSAX3" ;
    ex:textoExtracto "INIPOSAX3: Posición inicial de la compensación volumétrica básica en cada eje MOVAXIS." .

ex:ParametroINCREAX1 a ex:Parametro ;
    ex:identificador "INCREAX1" ;
    ex:textoExtracto "INCREAX1: Intervalo entre puntos para el eje MOVAXIS en la compensación volumétrica básica." .

ex:ParametroINCREAX2 a ex:Parametro ;
    ex:identificador "INCREAX2" ;
    ex:textoExtracto "INCREAX2: Intervalo entre puntos para el eje MOVAXIS en la compensación volumétrica básica." .

ex:ParametroINCREAX3 a ex:Parametro ;
    ex:identificador "INCREAX3" ;
    ex:textoExtracto "INCREAX3: Intervalo entre puntos para el eje MOVAXIS en la compensación volumétrica básica." .

ex:ParametroVCOMPAXIS1 a ex:Parametro ;
    ex:identificador "VCOMPAXIS1" ;
    ex:textoExtracto "VCOMPAXIS1: Nombre del primer, segundo y tercer eje a compensar." .

ex:ParametroVCOMPAXIS2 a ex:Parametro ;
    ex:identificador "VCOMPAXIS2" ;
    ex:textoExtracto "VCOMPAXIS2: Nombre del primer, segundo y tercer eje a compensar." .

ex:ParametroVCOMPAXIS3 a ex:Parametro ;
    ex:identificador "VCOMPAXIS3" ;
    ex:textoExtracto "VCOMPAXIS3: Nombre del primer, segundo y tercer eje a compensar." .

ex:ParametroVCOMPFILE a ex:Parametro ;
    ex:identificador "VCOMPFILE" ;
    ex:textoExtracto "VCOMPFILE: Archivo con los datos de la compensación volumétrica." .