@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_INIPOSAX1 a ex:Parametro ;
    ex:textoExtracto "Este punto corresponde al punto inicial del volumen a compensar (parámetros INIPOSAX1, INIPOSAX2, INIPOSAX3)." ;
    rdfs:label "INIPOSAX1" .

ex:Parametro_INIPOSAX2 a ex:Parametro ;
    ex:textoExtracto "Este punto corresponde al punto inicial del volumen a compensar (parámetros INIPOSAX1, INIPOSAX2, INIPOSAX3)." ;
    rdfs:label "INIPOSAX2" .

ex:Parametro_INIPOSAX3 a ex:Parametro ;
    ex:textoExtracto "Este punto corresponde al punto inicial del volumen a compensar (parámetros INIPOSAX1, INIPOSAX2, INIPOSAX3)." ;
    rdfs:label "INIPOSAX3" .

ex:Parametro_NPOINTSAX1 a ex:Parametro ;
    ex:textoExtracto "hasta completar todos los puntos del X (parámetro NPOINTSAX1)" ;
    rdfs:label "NPOINTSAX1" .

ex:Parametro_INCREAX1 a ex:Parametro ;
    ex:textoExtracto "La distancia entre puntos del eje X está definida en el parámetro INCREAX1." ;
    rdfs:label "INCREAX1" .

ex:Parametro_NPOINTSAX2 a ex:Parametro ;
    ex:textoExtracto "desde el punto Y(P2) hasta el último punto del eje Y (parámetro NPOINTSAX2)" ;
    rdfs:label "NPOINTSAX2" .

ex:Parametro_INCREAX2 a ex:Parametro ;
    ex:textoExtracto "La distancia entre puntos del eje Y está definida en el parámetro INCREAX2." ;
    rdfs:label "INCREAX2" .

ex:Parametro_NPOINTSAX3 a ex:Parametro ;
    ex:textoExtracto "hasta el último punto del eje Z (parámetro NPOINTSAX3)" ;
    rdfs:label "NPOINTSAX3" .

ex:Esquema_DefinicionPuntosVolumen a ex:Esquema ;
    ex:textoExtracto "Suponiendo un triedro en los siguientes ejes. VMOVAXIS1=X VMOVAXIS2=Y VMOVAXIS3=Z. 1 La primera fila corresponde al punto \"X(P1), Y(P1), Z(P1)\". Este punto corresponde al punto inicial del volumen a compensar (parámetros INIPOSAX1, INIPOSAX2, INIPOSAX3). 1 X(P1) Y(P1) Z(P1) Z X Y XYZ(P1) X (INIPOSAX1) Y (INIPOSAX2) Z (INIPOSAX3) 2 La segunda fila corresponde al punto \"X(P2), Y(P1), Z(P1)\", la tercera al punto \"X(P3), Y(P1), Z(P1)\", y así sucesivamente hasta completar todos los puntos del X (parámetro NPOINTSAX1). La distancia entre puntos del eje X está definida en el parámetro INCREAX1. 2 X(P2) Y(P1) Z(P1) Z X(Pn) Y(P1) Z(P1) X Y X(Pn) NPOINTAX1 X(P4) X(P3) X(P2) XYZ(P1) 3 Repetir la misma operación para definir todos los puntos del eje X, desde el punto Y(P2) hasta el último punto del eje Y (parámetro NPOINTSAX2). La distancia entre puntos del eje Y está definida en el parámetro INCREAX2. 3 X(P1) Y(P2) Z(P1) X(P2) Y(P2) Z(P1) Z X(Pn) Y(P2) Z(P1) X(P1) Y(Pn) Z(P1) X Y X(P2) Y(Pn) Z(P1) X(Pn) ··· NPOINTAX1 Y(Pn) X(Pn) Y(Pn) Z(P1) X(P3) Y(P2) X(P2) XYZ(P1) 4 Una vez definidos todos los puntos del plano (cota Z(P1)), repetir la misma operación desde el punto \"X(P1), Y(P1), Z(P2)\" hasta el último punto del eje Z (parámetro NPOINTSAX3)." ;
    ex:tieneComponente ex:Parametro_INIPOSAX1, ex:Parametro_INIPOSAX2, ex:Parametro_INIPOSAX3, ex:Parametro_NPOINTSAX1, ex:Parametro_INCREAX1, ex:Parametro_NPOINTSAX2, ex:Parametro_INCREAX2, ex:Parametro_NPOINTSAX3 .