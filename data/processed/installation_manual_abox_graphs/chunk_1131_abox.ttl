@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_INIPOSAX1
    a ex:Parametro ;
    rdfs:label "INIPOSAX1" ;
    ex:textoExtracto "punto inicial del volumen a compensar (parámetros INIPOSAX1, INIPOSAX2, INIPOSAX3). 1 X(P1) Y(P1) Z(P1) Z X Y XYZ(P1) X (INIPOSAX1)" ;
    ex:valor "X(P1)" .

ex:Parametro_INIPOSAX2
    a ex:Parametro ;
    rdfs:label "INIPOSAX2" ;
    ex:textoExtracto "punto inicial del volumen a compensar (parámetros INIPOSAX1, INIPOSAX2, INIPOSAX3). 1 X(P1) Y(P1) Z(P1) Z X Y XYZ(P1) Y (INIPOSAX2)" ;
    ex:valor "Y(P1)" .

ex:Parametro_INIPOSAX3
    a ex:Parametro ;
    rdfs:label "INIPOSAX3" ;
    ex:textoExtracto "punto inicial del volumen a compensar (parámetros INIPOSAX1, INIPOSAX2, INIPOSAX3). 1 X(P1) Y(P1) Z(P1) Z X Y XYZ(P1) Z (INIPOSAX3)" ;
    ex:valor "Z(P1)" .

ex:Parametro_NPOINTSAX1
    a ex:Parametro ;
    rdfs:label "NPOINTSAX1" ;
    ex:textoExtracto "La segunda fila corresponde al punto 'X(P2), Y(P1), Z(P1)', la tercera al punto 'X(P3), Y(P1), Z(P1)', y así sucesivamente hasta completar todos los puntos del X (parámetro NPOINTSAX1)." .

ex:Parametro_INCREAX1
    a ex:Parametro ;
    rdfs:label "INCREAX1" ;
    ex:textoExtracto "La distancia entre puntos del eje X está definida en el parámetro INCREAX1." .

ex:Parametro_NPOINTSAX2
    a ex:Parametro ;
    rdfs:label "NPOINTSAX2" ;
    ex:textoExtracto "Repetir la misma operación para definir todos los puntos del eje X, desde el punto Y(P2) hasta el último punto del eje Y (parámetro NPOINTSAX2)." .

ex:Parametro_INCREAX2
    a ex:Parametro ;
    rdfs:label "INCREAX2" ;
    ex:textoExtracto "La distancia entre puntos del eje Y está definida en el parámetro INCREAX2." .

ex:Parametro_NPOINTSAX3
    a ex:Parametro ;
    rdfs:label "NPOINTSAX3" ;
    ex:textoExtracto "repetir la misma operación desde el punto 'X(P1), Y(P1), Z(P2)' hasta el último punto del eje Z (parámetro NPOINTSAX3)." .

ex:Sistema_TriedroEjes
    a ex:Sistema ;
    rdfs:label "Sistema de ejes (X-Y-Z)" ;
    ex:textoExtracto "Suponiendo un triedro en los siguientes ejes. VMOVAXIS1=X VMOVAXIS2=Y VMOVAXIS3=Z." ;
    ex:monitoreaParametro ex:Parametro_INIPOSAX1 ;
    ex:monitoreaParametro ex:Parametro_INIPOSAX2 ;
    ex:monitoreaParametro ex:Parametro_INIPOSAX3 ;
    ex:monitoreaParametro ex:Parametro_NPOINTSAX1 ;
    ex:monitoreaParametro ex:Parametro_INCREAX1 ;
    ex:monitoreaParametro ex:Parametro_NPOINTSAX2 ;
    ex:monitoreaParametro ex:Parametro_INCREAX2 ;
    ex:monitoreaParametro ex:Parametro_NPOINTSAX3 .