@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalS a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal S" ;
    ns1:textoExtracto "SPDLNAME 1 | S1 | Número lógico ꞏ6ꞏ. Cabezal con índice ꞏ1ꞏ." ;
    ns1:tieneComponente ns1:SistemaFresadoraCanal1 .

ns1:EjeA a ns1:ComponenteMecanico ;
    rdfs:label "Eje A" ;
    ns1:textoExtracto "AXISNAME 4 | A | Número lógico ꞏ4ꞏ." ;
    ns1:tieneComponente ns1:SistemaFresadoraCanal1 .

ns1:EjeB a ns1:ComponenteMecanico ;
    rdfs:label "Eje B" ;
    ns1:textoExtracto "AXISNAME 5 | B | Número lógico ꞏ5ꞏ." ;
    ns1:tieneComponente ns1:SistemaFresadoraCanal1 .

ns1:EjeX a ns1:ComponenteMecanico ;
    rdfs:label "Eje X" ;
    ns1:textoExtracto "AXISNAME 1 | X | Número lógico ꞏ1ꞏ." ;
    ns1:tieneComponente ns1:SistemaFresadoraCanal1 .

ns1:EjeY a ns1:ComponenteMecanico ;
    rdfs:label "Eje Y" ;
    ns1:textoExtracto "AXISNAME 2 | Y | Número lógico ꞏ2ꞏ." ;
    ns1:tieneComponente ns1:SistemaFresadoraCanal1 .

ns1:EjeZ a ns1:ComponenteMecanico ;
    rdfs:label "Eje Z" ;
    ns1:textoExtracto "AXISNAME 3 | Z | Número lógico ꞏ3ꞏ." ;
    ns1:tieneComponente ns1:SistemaFresadoraCanal1 .

ns1:SistemaFresadoraCanal1 a ns1:Sistema ;
    rdfs:label "Sistema Fresadora con 1 canal, 5 ejes (2 libres) y 1 cabezal" ;
    ns1:textoExtracto "Supongamos una máquina de un canal con tres ejes y cabezal y dos ejes sin asignar inicialmente." .

