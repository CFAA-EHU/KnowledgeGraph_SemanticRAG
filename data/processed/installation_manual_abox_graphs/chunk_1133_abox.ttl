ex:Tabla1133_1 a ex:Tabla ;
    ex:tieneComponente ex:ParametroMPG_VMOVAXIS1, ex:ParametroMPG_VMOVAXIS2, ex:ParametroMPG_VMOVAXIS3, ex:ParametroMPG_NPOINTSAX1, ex:ParametroMPG_NPOINTSAX2, ex:ParametroMPG_NPOINTSAX3, ex:ParametroMPG_INIPOSAX1, ex:ParametroMPG_INIPOSAX2, ex:ParametroMPG_INIPOSAX3, ex:ParametroMPG_INCREAX1, ex:ParametroMPG_INCREAX2, ex:ParametroMPG_INCREAX3, ex:ParametroMPG_VCOMPAXIS1, ex:ParametroMPG_VCOMPAXIS2, ex:ParametroMPG_VCOMPAXIS3, ex:ParametroMPG_VCOMPFILE .