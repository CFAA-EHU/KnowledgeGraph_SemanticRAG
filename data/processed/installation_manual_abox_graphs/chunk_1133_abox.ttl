ex:Tabla_12_1_5_Variables_MPG a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de variables MPG accesibles desde PRG, PLC e INT"@es ;
    ex:textoExtracto "Las siguientes variables son accesibles desde; (PRG) el programa pieza y desde el modo MDI/MDA, PLC e (INT) una aplicación externa. La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W)."@es ;
    ex:documentadoEn ex:Pagina_611_612 .

ex:Parametro_MPG_VMOVAXIS1
    a ex:Parametro ;
    rdfs:label "MPG.VMOVAXIS1" ;
    ex:identificador "MPG.VMOVAXIS1[tbl]" ;
    ex:textoExtracto "Nombre del eje que al moverse genera variaciones."@es ;
    ex:documentadoEn ex:Tabla_12_1_5_Variables_MPG .

