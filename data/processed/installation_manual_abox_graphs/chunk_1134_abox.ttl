@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaFresadoraTresCanalEjesCabezales a ns1:Sistema ;
    rdfs:label "Sistema Fresadora con 3 canales, 9 ejes y 2 cabezales" ;
    ns1:textoExtracto "Supongamos una máquina con tres canales dónde los dos primeros canales disponen de ejes y cabezales para mecanizar y el tercer canal es un sistema de carga y descarga controlado por dos ejes." .

ns1:Sistema_3901a59f03 a ns1:Sistema ;
    rdfs:label "Canal 1" ;
    ns1:textoExtracto "Canal ꞏ1ꞏ. 3 ejes (X Y Z) 1 cabezal (S1)." ;
    ns1:tieneComponente ns1:CabezalS1,
        ns1:EjeX,
        ns1:EjeY,
        ns1:EjeZ .

ns1:Sistema_3eb5761148 a ns1:Sistema ;
    rdfs:label "Canal 3" ;
    ns1:textoExtracto "Canal ꞏ3ꞏ. 2 ejes (U U1) 0 cabezales." ;
    ns1:tieneComponente ns1:EjeU,
        ns1:EjeU1 .

ns1:Sistema_baf85b7070 a ns1:Sistema ;
    rdfs:label "Canal 2" ;
    ns1:textoExtracto "Canal ꞏ2ꞏ. 4 ejes (X1 Y1 Z1 W) 1 cabezal (S2)." ;
    ns1:tieneComponente ns1:CabezalS2,
        ns1:EjeW,
        ns1:EjeX1,
        ns1:EjeY1,
        ns1:EjeZ1 .

ns1:CabezalS1 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal S1" ;
    ns1:textoExtracto "Canal ꞏ1ꞏ. 3 ejes (X Y Z) 1 cabezal (S1)." .

ns1:CabezalS2 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal S2" ;
    ns1:textoExtracto "Canal ꞏ2ꞏ. 4 ejes (X1 Y1 Z1 W) 1 cabezal (S2)." .

ns1:EjeU a ns1:ComponenteMecanico ;
    rdfs:label "Eje U" ;
    ns1:textoExtracto "Canal ꞏ3ꞏ. 2 ejes (U U1) 0 cabezales." .

ns1:EjeU1 a ns1:ComponenteMecanico ;
    rdfs:label "Eje U1" ;
    ns1:textoExtracto "Canal ꞏ3ꞏ. 2 ejes (U U1) 0 cabezales." .

ns1:EjeW a ns1:ComponenteMecanico ;
    rdfs:label "Eje W" ;
    ns1:textoExtracto "Canal ꞏ2ꞏ. 4 ejes (X1 Y1 Z1 W) 1 cabezal (S2)." .

ns1:EjeX a ns1:ComponenteMecanico ;
    rdfs:label "Eje X" ;
    ns1:textoExtracto "Canal ꞏ1ꞏ. 3 ejes (X Y Z) 1 cabezal (S1)." .

ns1:EjeX1 a ns1:ComponenteMecanico ;
    rdfs:label "Eje X1" ;
    ns1:textoExtracto "Canal ꞏ2ꞏ. 4 ejes (X1 Y1 Z1 W) 1 cabezal (S2)." .

ns1:EjeY a ns1:ComponenteMecanico ;
    rdfs:label "Eje Y" ;
    ns1:textoExtracto "Canal ꞏ1ꞏ. 3 ejes (X Y Z) 1 cabezal (S1)." .

ns1:EjeY1 a ns1:ComponenteMecanico ;
    rdfs:label "Eje Y1" ;
    ns1:textoExtracto "Canal ꞏ2ꞏ. 4 ejes (X1 Y1 Z1 W) 1 cabezal (S2)." .

ns1:EjeZ a ns1:ComponenteMecanico ;
    rdfs:label "Eje Z" ;
    ns1:textoExtracto "Canal ꞏ1ꞏ. 3 ejes (X Y Z) 1 cabezal (S1)." .

ns1:EjeZ1 a ns1:ComponenteMecanico ;
    rdfs:label "Eje Z1" ;
    ns1:textoExtracto "Canal ꞏ2ꞏ. 4 ejes (X1 Y1 Z1 W) 1 cabezal (S2)." .

