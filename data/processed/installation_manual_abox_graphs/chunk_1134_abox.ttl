@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:V_MPG_VCOMPFILE a ex:Parametro ;
    rdfs:label "V.MPG.VCOMPFILE[tbl]" ;
    ex:textoExtracto "Archivo con los datos de la compensación volumétrica. Unidades: -." ;
    ex:valor "tbl" .

ex:V_MPG_VMOVAXIS2 a ex:Parametro ;
    rdfs:label "V.MPG.VMOVAXIS2[1]" ;
    ex:textoExtracto "Nombre del segundo eje de la primera tabla de compensación volumétrica." .

ex:V_MPG_NPOINTAX2 a ex:Parametro ;
    rdfs:label "V.MPG.NPOINTAX2[2]" ;
    ex:textoExtracto "Número de puntos del segundo eje de la segunda tabla de compensación volumétrica." .