@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:VOLCOMP1 a ex:Parametro ;
    rdfs:label "V.PLC.VOLCOMP1" ;
    ex:identificador "(V.)PLC.VOLCOMP1" ;
    ex:textoExtracto "Estas variables refleja el valor de las marcas VOLCOMP1 a VOLCOMP4 del PLC. Si el PLC activa una de estas marcas (cambio de 0 a 1), el CNC activa la compensación volumétrica correspondiente (parámetro VOLCOMP)." .

ex:VOLCOMP2 a ex:Parametro ;
    rdfs:label "V.PLC.VOLCOMP2" ;
    ex:identificador "(V.)PLC.VOLCOMP2" ;
    ex:textoExtracto "Estas variables refleja el valor de las marcas VOLCOMP1 a VOLCOMP4 del PLC. Si el PLC activa una de estas marcas (cambio de 0 a 1), el CNC activa la compensación volumétrica correspondiente (parámetro VOLCOMP)." .

ex:VOLCOMP3 a ex:Parametro ;
    rdfs:label "V.PLC.VOLCOMP3" ;
    ex:identificador "(V.)PLC.VOLCOMP3" ;
    ex:textoExtracto "Estas variables refleja el valor de las marcas VOLCOMP1 a VOLCOMP4 del PLC. Si el PLC activa una de estas marcas (cambio de 0 a 1), el CNC activa la compensación volumétrica correspondiente (parámetro VOLCOMP)." .

ex:VOLCOMP4 a ex:Parametro ;
    rdfs:label "V.PLC.VOLCOMP4" ;
    ex:identificador "(V.)PLC.VOLCOMP4" ;
    ex:textoExtracto "Estas variables refleja el valor de las marcas VOLCOMP1 a VOLCOMP4 del PLC. Si el PLC activa una de estas marcas (cambio de 0 a 1), el CNC activa la compensación volumétrica correspondiente (parámetro VOLCOMP)." .

ex:VOLCOMP a ex:Parametro ;
    rdfs:label "Compensación volumétrica" ;
    ex:identificador "VOLCOMP" ;
    ex:textoExtracto "el CNC activa la compensación volumétrica correspondiente (parámetro VOLCOMP)" .

ex:V_A_VOLCOMP_Z a ex:Parametro ;
    rdfs:label "V.A.VOLCOMP.Z" ;
    ex:identificador "V.A.VOLCOMP.Z" ;
    ex:valor "Eje Z" ;
    ex:textoExtracto "Valor que está añadiendo la compensación volumétrica al eje. Si la compensación volumétrica no está activa, la variable devuelve valor 0 (cero). Unidades: Milímetros, pulgadas o grados." .

ex:V_A_VOLCOMP_3 a ex:Parametro ;
    rdfs:label "V.A.VOLCOMP.3" ;
    ex:identificador "V.A.VOLCOMP.3" ;
    ex:valor "Eje con número lógico 3" ;
    ex:textoExtracto "Valor que está añadiendo la compensación volumétrica al eje. Si la compensación volumétrica no está activa, la variable devuelve valor 0 (cero). Unidades: Milímetros, pulgadas o grados." .

ex:V_2_A_VOLCOMP_3 a ex:Parametro ;
    rdfs:label "V.[2].A.VOLCOMP.3" ;
    ex:identificador "V.[2].A.VOLCOMP.3" ;
    ex:valor "Eje con índice 3 en el canal 2" ;
    ex:textoExtracto "Valor que está añadiendo la compensación volumétrica al eje. Si la compensación volumétrica no está activa, la variable devuelve valor 0 (cero). Unidades: Milímetros, pulgadas o grados." .