@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ParametrosCompensacionVolumetrica_1136 a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de parámetros de compensación volumétrica (MPG)"@es ;
    ex:textoExtracto """
    | Parámetro. |  | Significado. |
    | --- | --- | --- |
    | VOLCOMP MPG |  | Este parámetro muestra las tablas de compensación volumétrica. |
    | VCOMPAXIS1 MPG, VCOMPAXIS2, VCOMPAXIS3 |  | Estos parámetros definen los ejes a compensar mediante la compensación volumétrica. [...] |
    | VCOMPFILE MPG |  | Las tablas de compensación las genera la aplicación de calibración; no son editables desde el CNC. [...]"""@es ;
    ex:documentadoEn ex:Pagina_613 .

ex:Parametro_VOLCOMP_MPG
    a               ex:Parametro ;
    rdfs:label      "VOLCOMP (MPG)"@es ;
    ex:identificador "VOLCOMP MPG" ;
    ex:textoExtracto "Este parámetro muestra las tablas de compensación volumétrica."@es ;
    ex:documentadoEn ex:Tabla_ParametrosCompensacionVolumetrica_1136 .

ex:Parametro_VCOMPAXIS1_MPG
    a               ex:Parametro ;
    rdfs:label      "VCOMPAXIS1 (MPG)"@es ;
    ex:identificador "VCOMPAXIS1 MPG" ;
    ex:textoExtracto "Estos parámetros definen los ejes a compensar mediante la compensación volumétrica. Los ejes podrán ser lineales o rotativos, y hay que definir al menos uno eje."@es ;
    ex:documentadoEn ex:Tabla_ParametrosCompensacionVolumetrica_1136 .

ex:Parametro_VCOMPAXIS2_MPG
    a               ex:Parametro ;
    rdfs:label      "VCOMPAXIS2 (MPG)"@es ;
    ex:identificador "VCOMPAXIS2" ;
    ex:textoExtracto "Estos parámetros definen los ejes a compensar mediante la compensación volumétrica."@es ;
    ex:documentadoEn ex:Tabla_ParametrosCompensacionVolumetrica_1136 .

ex:Parametro_VCOMPAXIS3_MPG
    a               ex:Parametro ;
    rdfs:label      "VCOMPAXIS3 (MPG)"@es ;
    ex:identificador "VCOMPAXIS3" ;
    ex:textoExtracto "Estos parámetros definen los ejes a compensar mediante la compensación volumétrica."@es ;
    ex:documentadoEn ex:Tabla_ParametrosCompensacionVolumetrica_1136 .

ex:Parametro_VCOMPFILE_MPG
    a               ex:Parametro ;
    rdfs:label      "VCOMPFILE (MPG)"@es ;
    ex:identificador "VCOMPFILE MPG" ;
    ex:textoExtracto "Las tablas de compensación las genera la aplicación de calibración; no son editables desde el CNC. Las unidades de los datos del archivo (milímetros o pulgadas) deben ser las definidas en el CNC (parámetro INCHES)."@es ;
    ex:documentadoEn ex:Tabla_ParametrosCompensacionVolumetrica_1136 .

ex:Pagina_613
    a               ex:Pagina ;
    ex:identificador "613" ;
    ex:textoExtracto "12.2 Compensación volumétrica media o grande. - 12.2.1 Puesta a punto. Parámetros máquina; generales."@es .