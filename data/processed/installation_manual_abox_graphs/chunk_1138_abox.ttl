@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalS a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal S" ;
    ns1:compuestoPor ns1:SistemaFresadoraTresCanalDosEjesUnCabezal ;
    ns1:textoExtracto "SPDLNAME 1 | S | Número lógico ꞏ3ꞏ. Cabezal con índice ꞏ1ꞏ." .

ns1:ConfiguracionGeometrica_26249d6b0a a ns1:Parametro ;
    rdfs:label "Configuración geométrica" ;
    ns1:textoExtracto "GEOCONFIG = Plano" ;
    ns1:valor "Plano" .

ns1:EjeX a ns1:ComponenteMecanico ;
    rdfs:label "Eje X" ;
    ns1:compuestoPor ns1:SistemaFresadoraTresCanalDosEjesUnCabezal ;
    ns1:textoExtracto "AXISNAME 1 | X | Número lógico ꞏ1ꞏ." .

ns1:EjeZ a ns1:ComponenteMecanico ;
    rdfs:label "Eje Z" ;
    ns1:compuestoPor ns1:SistemaFresadoraTresCanalDosEjesUnCabezal ;
    ns1:textoExtracto "AXISNAME 2 | Z | Número lógico ꞏ2ꞏ." .

ns1:NumeroDeCabezales_a1652dc76c a ns1:Parametro ;
    rdfs:label "Número de cabezales" ;
    ns1:textoExtracto "NSPDL = 1" ;
    ns1:valor "1" .

ns1:NumeroDeCanales_56bac2f73e a ns1:Parametro ;
    rdfs:label "Número de canales" ;
    ns1:textoExtracto "NCHANNEL = 1" ;
    ns1:valor "1" .

ns1:NumeroDeEjes_05ac6ddf40 a ns1:Parametro ;
    rdfs:label "Número de ejes" ;
    ns1:textoExtracto "NAXIS = 2" ;
    ns1:valor "2" .

ns1:PlanoDeConfiguracion a ns1:Parametro ;
    rdfs:label "Plano de configuración" ;
    ns1:textoExtracto "IPLANE = G18" ;
    ns1:valor "G18" .

ns1:Sistema_af5bbda309 a ns1:Sistema ;
    rdfs:label "Canal 1" ;
    ns1:textoExtracto "Configuración de los canales, ejes y cabezales. | Sistema | Canal ꞏ1ꞏ" .

ns1:SistemaFresadoraTresCanalDosEjesUnCabezal a ns1:Sistema ;
    rdfs:label "Sistema Fresadora con 3 canales, 9 ejes y 2 cabezales" ;
    ns1:textoExtracto "TORNO CON 1 CANAL, 2 EJES Y 1 CABEZAL. CONFIGURACIÓN DE EJES TIPO PLANO." .

