@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaFresadora a ns1:Sistema ;
    rdfs:label "Sistema Fresadora" ;
    ns1:textoExtracto "Selección de planos en el canal ꞏ1ꞏ. Con esta configuración, el plano de trabajo siempre es G18 y estará formado por los dos primeros ejes definidos en el canal." ;
    ns1:tieneComponente ns1:CabezalConIndice1_e57c994dea,
        ns1:EjeConIndice1_1a5eae98f3,
        ns1:EjeConIndice2_7b69909a24 .

ns1:CabezalConIndice1_e57c994dea a ns1:Parametro ;
    rdfs:label "Cabezal con índice 1" ;
    ns1:identificador "CHSPDLNAME1" ;
    ns1:textoExtracto "CHSPDLNAME 1 | S | Cabezal con índice ꞏ1ꞏ. | Número lógico ꞏ3ꞏ." .

ns1:EjeConIndice1_1a5eae98f3 a ns1:Parametro ;
    rdfs:label "Eje con índice 1" ;
    ns1:identificador "CHAXISNAME1" ;
    ns1:textoExtracto "CHAXISNAME 1 | X | Eje con índice ꞏ1ꞏ. | Número lógico ꞏ1ꞏ." .

ns1:EjeConIndice2_7b69909a24 a ns1:Parametro ;
    rdfs:label "Eje con índice 2" ;
    ns1:identificador "CHAXISNAME2" ;
    ns1:textoExtracto "CHAXISNAME 2 | Z | Eje con índice ꞏ2ꞏ. | Número lógico ꞏ2ꞏ." .

