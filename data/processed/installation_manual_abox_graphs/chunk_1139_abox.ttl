@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PLC a ex:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ex:textoExtracto "Si el PLC activa una de estas marcas (cambio de 0 a 1)" .

ex:CNC a ex:ComponenteElectrico ;
    rdfs:label "CNC" ;
    ex:textoExtracto "el CNC activa la compensación volumétrica correspondiente" .

ex:Parametro_VOLCOMP a ex:Parametro ;
    ex:identificador "VOLCOMP" ;
    ex:textoExtracto "parámetro VOLCOMP" .

ex:Variable_V.PLC.VOLCOMP1 a ex:Parametro ;
    ex:identificador "V.PLC.VOLCOMP1" ;
    ex:textoExtracto "V.PLC.VOLCOMP1 | Compensación volumétrica ꞏ1ꞏ." ;
    rdfs:label "Compensación volumétrica 1" .

ex:CompensacionVolumetrica a ex:Parametro ;
    rdfs:label "Compensación volumétrica" ;
    ex:textoExtracto "Compensación volumétrica." .

ex:SistemaControl a ex:Sistema ;
    ex:textoExtracto "Si el PLC activa una de estas marcas (cambio de 0 a 1), el CNC activa la compensación volumétrica correspondiente" ;
    ex:tieneComponente ex:PLC, ex:CNC, ex:Parametro_VOLCOMP, ex:Variable_V.PLC.VOLCOMP1, ex:CompensacionVolumetrica .