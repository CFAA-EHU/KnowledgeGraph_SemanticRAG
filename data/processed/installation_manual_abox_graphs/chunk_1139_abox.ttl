@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_VOLCOMP
    a               ex:Parametro ;
    rdfs:label      "Compensación volumétrica (VOLCOMP)"@es ;
    ex:identificador "VOLCOMP" ;
    ex:textoExtracto "el CNC activa la compensación volumétrica correspondiente (parámetro VOLCOMP). [...] | V.PLC.VOLCOMP1 | Compensación volumétrica ꞏ1ꞏ."@es ;
    ex:valor        "R/W" .

ex:Variable_V.PLC.VOLCOMP1
    a               ex:Parametro ;
    rdfs:label      "V.PLC.VOLCOMP1" ;
    ex:identificador "V.PLC.VOLCOMP1" ;
    ex:textoExtracto "Sintaxis de la variable. | V.PLC.VOLCOMP1 | Compensación volumétrica ꞏ1ꞏ."@es ;
    ex:monitoreaParametro ex:Parametro_VOLCOMP .