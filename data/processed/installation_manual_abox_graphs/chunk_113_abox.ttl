ns1:NumeroDeParametrosAritmeticosComunesNoVolatiles_ec4c63ba58 a ns1:Parametro ;
    rdfs:label "Número de parámetros aritméticos comunes no volátiles" ;
    ns1:identificador "MPG.BKUPCUP" ;
    ns1:textoExtracto "Valores posibles: De 0 a 20. Valor por defecto: 0. Variable asociada: (V.)MPG.BKUPCUP Este parámetro indica el número de parámetros aritméticos comunes que se almacenan en la RAM con batería." ;
    ns1:valor "0"^^xsd:string .

ns1:VariableAsociadaAlGrupoDeParametrosAritmeticosComunesMaximo a ns1:Parametro ;
    rdfs:label "Variable asociada al grupo de parámetros aritméticos comunes máximo" ;
    ns1:identificador "MPG.MAXCOMP" ;
    ns1:textoExtracto "Valores posibles: De 10000 a 19999. Valor por defecto: 10025. Variable asociada: (V.)MPG.MAXCOMP" ;
    ns1:valor "10025"^^xsd:string .

ns1:VariableAsociadaAlGrupoDeParametrosAritmeticosComunesMinimo a ns1:Parametro ;
    rdfs:label "Variable asociada al grupo de parámetros aritméticos comunes mínimo" ;
    ns1:identificador "MPG.MINCOMP" ;
    ns1:textoExtracto "Valores posibles: De 10000 a 19999. Valor por defecto: 10000. Variable asociada: (V.)MPG.MINCOMP" ;
    ns1:valor "10000"^^xsd:string .

