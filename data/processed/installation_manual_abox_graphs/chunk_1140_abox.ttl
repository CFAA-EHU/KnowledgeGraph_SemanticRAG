@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:V_PLC_VOLCOMP1 a ex:Parametro ;
    ex:identificador "V.PLC.VOLCOMP1" ;
    ex:textoExtracto "Compensación volumétrica ꞏ1ꞏ." ;
    rdfs:label "Compensación volumétrica" .

ex:Variable_VOLCOMP_xn a ex:Parametro ;
    ex:identificador "(V.)[ch].A.VOLCOMP.xn" ;
    ex:textoExtracto "Valor que está añadiendo la compensación volumétrica al eje. Si la compensación volumétrica no está activa, la variable devuelve valor 0 (cero). Unidades: Milímetros, pulgadas o grados." ;
    rdfs:label "Valor de compensación volumétrica al eje" .

ex:Variable_PIVOT_xn a ex:Parametro ;
    ex:identificador "(V.)[ch].A.PIVOT.xn" ;
    ex:textoExtracto "Distancia entre el centro de pivotamiento y la punta de la herramienta, en el sistema de coordenadas máquina. Esta variable devuelve la suma de los offsets del cabezal (parámetros TDATA) y de la herramienta." ;
    rdfs:label "Distancia entre centro de pivotamiento y punta de herramienta" .

ex:Variable_VOLCOMP_Z a ex:Parametro ;
    ex:identificador "V.A.VOLCOMP.Z" ;
    ex:textoExtracto "Eje Z." ;
    rdfs:label "Variable de compensación volumétrica para eje Z" .

ex:Variable_VOLCOMP_3 a ex:Parametro ;
    ex:identificador "V.A.VOLCOMP.3" ;
    ex:textoExtracto "Eje con número lógico ꞏ3ꞏ." ;
    rdfs:label "Variable de compensación volumétrica para eje lógico 3" .

ex:Variable_VOLCOMP_Canal2_Eje3 a ex:Parametro ;
    ex:identificador "V.[2].A.VOLCOMP.3" ;
    ex:textoExtracto "Eje con índice ꞏ3ꞏ en el canal ꞏ2ꞏ." ;
    rdfs:label "Variable de compensación volumétrica para eje 3 en canal 2" .