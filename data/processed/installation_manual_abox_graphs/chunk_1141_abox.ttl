@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error_0046
    a ex:AvisoSeguridad ;
    rdfs:label "Error 0046: 'Eje inexistente'" ;
    ex:textoExtracto "0046 'Eje inexistente' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Las posibles causas son las siguientes: • El usuario ha asignado a un parámetro máquina el nombre de un eje que no existe. • En la compensación volumétrica básica, no se ha definido uno de los ejes VMOVAXIS o VCOMPAXIS. SOLUCIÓN Corregir los parámetros máquina. Los nombres de eje válidos son los definidos en el parámetro AXISNAME." ;
    ex:identificador "0046" .

ex:Error_1445
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1445: 'Valor de parámetro no válido'" ;
    ex:textoExtracto "1445 'Valor de parámetro no válido' DETECCIÓN Durante la ejecución. CAUSA En una sentencia o en un ciclo fijo, un parámetro tiene un valor no válido. SOLUCIÓN Revisar la programación." ;
    ex:identificador "1445" .

ex:Error_1447
    a ex:AvisoSeguridad ;
    rdfs:label "Error 1447: 'Opción de software no permitida'" ;
    ex:textoExtracto "1447 'Opción de software no permitida' DETECCIÓN Durante la ejecución. CAUSA El CNC no dispone de la opción de software necesaria para ejecutar la orden programada. SOLUCIÓN En el modo diagnosis se pueden consultar las opciones de software disponibles en el CNC." ;
    ex:identificador "1447" .

ex:Error_9347
    a ex:AvisoSeguridad ;
    rdfs:label "Error 9347: 'Eje repetido en VOLCOMP'" ;
    ex:textoExtracto "9347 'Eje repetido en VOLCOMP' DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA En los parámetros VMOVAXIS o VCOMPAXIS de la compensación volumétrica está definido el mismo eje dos veces. SOLUCIÓN Corregir los parámetros máquina." ;
    ex:identificador "9347" .

ex:Error_23101
    a ex:AvisoSeguridad ;
    rdfs:label "Error 23101: 'Error en el análisis del fichero de definición de la compensación volumétrica'" ;
    ex:textoExtracto "23101 'Error en el análisis del fichero de definición de la compensación volumétrica' DETECCIÓN Durante la validación de los parámetros máquina o el arranque del CNC. CAUSA El fichero de definición de la compensación volumétrica no contiene los datos adecuados. Compensación volumétrica básica: • El fichero no es del tipo csv. • El formato del fichero definido en VCOMPFILE no es correcto. • El fichero definido en VCOMPFILE no tiene definidos todos los puntos. El número de puntos viene definido por la expresión: NPOINTSAX1 × NPOINTSAX2 × NPOINTSAX3 Compensación volumétrica media y grande: • El formato del fichero definido en VCOMPFILE no es correcto." ;
    ex:identificador "23101" .

ex:Parametro_AXISNAME
    a ex:Parametro ;
    rdfs:label "Parámetro AXISNAME" ;
    ex:textoExtracto "Los nombres de eje válidos son los definidos en el parámetro AXISNAME." ;
    ex:identificador "AXISNAME" .

ex:Parametro_VMOVAXIS
    a ex:Parametro ;
    rdfs:label "Parámetro VMOVAXIS" ;
    ex:textoExtracto "En la compensación volumétrica básica, no se ha definido uno de los ejes VMOVAXIS o VCOMPAXIS." ;
    ex:identificador "VMOVAXIS" .

ex:Parametro_VCOMPAXIS
    a ex:Parametro ;
    rdfs:label "Parámetro VCOMPAXIS" ;
    ex:textoExtracto "En la compensación volumétrica básica, no se ha definido uno de los ejes VMOVAXIS o VCOMPAXIS." ;
    ex:identificador "VCOMPAXIS" .

ex:Parametro_VCOMPFILE
    a ex:Parametro ;
    rdfs:label "Parámetro VCOMPFILE" ;
    ex:textoExtracto "El fichero de definición de la compensación volumétrica no contiene los datos adecuados. [...] El formato del fichero definido en VCOMPFILE no es correcto." ;
    ex:identificador "VCOMPFILE" .

ex:Parametro_NPOINTSAX1
    a ex:Parametro ;
    rdfs:label "Parámetro NPOINTSAX1" ;
    ex:textoExtracto "El número de puntos viene definido por la expresión: NPOINTSAX1 × NPOINTSAX2 × NPOINTSAX3" ;
    ex:identificador "NPOINTSAX1" .

ex:Parametro_NPOINTSAX2
    a ex:Parametro ;
    rdfs:label "Parámetro NPOINTSAX2" ;
    ex:textoExtracto "El número de puntos viene definido por la expresión: NPOINTSAX1 × NPOINTSAX2 × NPOINTSAX3" ;
    ex:identificador "NPOINTSAX2" .

ex:Parametro_NPOINTSAX3
    a ex:Parametro ;
    rdfs:label "Parámetro NPOINTSAX3" ;
    ex:textoExtracto "El número de puntos viene definido por la expresión: NPOINTSAX1 × NPOINTSAX2 × NPOINTSAX3" ;
    ex:identificador "NPOINTSAX3" .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "El CNC no dispone de la opción de software necesaria para ejecutar la orden programada." .

ex:Error_0046 ex:monitoreaParametro ex:Parametro_AXISNAME .
ex:Error_0046 ex:monitoreaParametro ex:Parametro_VMOVAXIS .
ex:Error_0046 ex:monitoreaParametro ex:Parametro_VCOMPAXIS .
ex:Error_9347 ex:monitoreaParametro ex:Parametro_VMOVAXIS .
ex:Error_9347 ex:monitoreaParametro ex:Parametro_VCOMPAXIS .
ex:Error_23101 ex:monitoreaParametro ex:Parametro_VCOMPFILE .
ex:Error_23101 ex:monitoreaParametro ex:Parametro_NPOINTSAX1 .
ex:Error_23101 ex:monitoreaParametro ex:Parametro_NPOINTSAX2 .
ex:Error_23101 ex:monitoreaParametro ex:Parametro_NPOINTSAX3 .