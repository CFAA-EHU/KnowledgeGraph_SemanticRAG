@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionGeometricaDelSistema a ns1:Parametro ;
    rdfs:label "Configuración geométrica del sistema" ;
    ns1:identificador "GEOCONFIG" ;
    ns1:textoExtracto "GEOCONFIG = Plano" .

ns1:NumeroDeCabezalesEnElCanal a ns1:Parametro ;
    rdfs:label "Número de cabezales en el canal" ;
    ns1:identificador "CHNSPDL" ;
    ns1:textoExtracto "CHNSPDL = 1" .

ns1:NumeroDeCabezales_446b871644 a ns1:Parametro ;
    rdfs:label "Número de cabezales" ;
    ns1:identificador "NSPDL" ;
    ns1:textoExtracto "NSPDL = 1" .

ns1:NumeroDeCanal_8129fe91bb a ns1:Parametro ;
    rdfs:label "Número de canal" ;
    ns1:identificador "NCHANNEL" ;
    ns1:textoExtracto "NCHANNEL = 1" .

ns1:NumeroDeEjesEnElCanal a ns1:Parametro ;
    rdfs:label "Número de ejes en el canal" ;
    ns1:identificador "CHNAXIS" ;
    ns1:textoExtracto "CHNAXIS = 3" .

ns1:NumeroDeEjes_8913f423ec a ns1:Parametro ;
    rdfs:label "Número de ejes" ;
    ns1:identificador "NAXIS" ;
    ns1:textoExtracto "NAXIS = 3" .

ns1:PlanoDeConfiguracion_7355681f24 a ns1:Parametro ;
    rdfs:label "Plano de configuración" ;
    ns1:identificador "IPLANE" ;
    ns1:textoExtracto "IPLANE = G18" .

ns1:SistemaTornoConCanalEjesCabezales a ns1:Sistema ;
    rdfs:label "Sistema Torno con 1 canal, 3 ejes y 1 cabezal" ;
    ns1:textoExtracto "Los ejes y cabezales están distribuidos de la siguiente manera. Canal ꞏ1ꞏ. 3 ejes (X Z Y) 1 cabezal (S)." ;
    ns1:tieneComponente ns1:CabezalS,
        ns1:EjeX,
        ns1:EjeY,
        ns1:EjeZ .

ns1:CabezalS a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal S" ;
    ns1:textoExtracto "SPDLNAME 1 | S | Número lógico ꞏ4ꞏ. Cabezal con índice ꞏ1ꞏ." .

ns1:EjeX a ns1:ComponenteMecanico ;
    rdfs:label "Eje X" ;
    ns1:textoExtracto "AXISNAME 1 | X | Número lógico ꞏ1ꞏ." .

ns1:EjeY a ns1:ComponenteMecanico ;
    rdfs:label "Eje Y" ;
    ns1:textoExtracto "AXISNAME 3 | Y | Número lógico ꞏ3ꞏ." .

ns1:EjeZ a ns1:ComponenteMecanico ;
    rdfs:label "Eje Z" ;
    ns1:textoExtracto "AXISNAME 2 | Z | Número lógico ꞏ2ꞏ." .

