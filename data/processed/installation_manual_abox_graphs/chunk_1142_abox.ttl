@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:FicheroVCOMPFILE a ex:ComponenteElectrico ;
    rdfs:label "VCOMPFILE" ;
    ex:textoExtracto "El fichero definido en VCOMPFILE no tiene definidos todos los puntos." ;
    ex:textoExtracto "El formato del fichero definido en VCOMPFILE no es correcto." ;
    ex:textoExtracto "En la compensación volumétrica básica, el fichero debe ser del tipo csv y tener todos los puntos definidos." .

ex:ErrorSistemaCompensacionVolumetrica a ex:AvisoSeguridad ;
    ex:identificador "23102" ;
    ex:textoExtracto "'Error del sistema de compensación volumétrica;" .

ex:CompensacionVolumetricaBasica a ex:ModoOperacion ;
    ex:textoExtracto "En la compensación volumétrica básica, el fichero debe ser del tipo csv y tener todos los puntos definidos." .

ex:CompensacionVolumetricaMediaGrande a ex:ModoOperacion ;
    ex:textoExtracto "Compensación volumétrica media y grande:" .