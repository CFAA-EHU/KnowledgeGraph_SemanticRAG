@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoHSCPorDefecto a ex:ModoOperacion ;
    rdfs:label "Modo HSC por defecto" ;
    ex:textoExtracto "Modo HSC por defecto." ;
    ex:identificador "#HSC" .

ex:ParametroHSCDEFAULTMODE a ex:Parametro ;
    rdfs:label "HSCDEFAULTMODE" ;
    ex:textoExtracto "El modo de mecanizado por defecto está definido en el parámetro HSCDEFAULTMODE" .

ex:ModoSurface a ex:ModoOperacion ;
    rdfs:label "modo SURFACE" ;
    ex:textoExtracto "optimizando el acabado superficial (modo SURFACE)" .

ex:ModoContError a ex:ModoOperacion ;
    rdfs:label "modo CONTERROR" ;
    ex:textoExtracto "optimizando el error de contorno (modo CONTERROR)" .

ex:ModoFast a ex:ModoOperacion ;
    rdfs:label "modo FAST" ;
    ex:textoExtracto "o la velocidad de mecanizado (modo FAST)" .

ex:SistemaCADCAM a ex:Sistema ;
    rdfs:label "sistemas de CAD/CAM" ;
    ex:textoExtracto "En la actualidad muchas piezas son diseñadas mediante sistemas de CAD/CAM." .

ex:ProgramaCNC a ex:Sistema ;
    rdfs:label "programa de CNC" ;
    ex:textoExtracto "Este tipo de información es posteriormente postprocesada para generar un programa de CNC" .

ex:MaquinaCNC a ex:Maquina ;
    rdfs:label "CNC" ;
    ex:textoExtracto "la capacidad del CNC para analizar una gran cantidad de puntos por delante" .

ex:EjeCNC a ex:ComponenteMecanico ;
    rdfs:label "eje" ;
    ex:textoExtracto "de cada eje y de la trayectoria" .

ex:ParametroJerk a ex:Parametro ;
    rdfs:label "jerk" ;
    ex:textoExtracto "restricciones de aceleración máxima, jerk, etc de cada eje" .

ex:ParametroAceleracionMaxima a ex:Parametro ;
    rdfs:label "aceleración máxima" ;
    ex:textoExtracto "restricciones de aceleración máxima, jerk, etc de cada eje" .

ex:EmpresaFagor a ex:Empresa ;
    rdfs:label "Fagor" ;
    ex:textoExtracto "Fagor ofrece el modo SURFACE como modo por defecto" .