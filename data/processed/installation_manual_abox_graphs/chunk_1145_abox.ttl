@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoOperacion_HSC a ex:ModoOperacion ;
    rdfs:label "HSC" ;
    ex:textoExtracto "Mecanizado HSC optimizando el error cordal (modo CONTERROR)" .

ex:Parametro_SLOPETYPE a ex:Parametro ;
    ex:identificador "SLOPETYPE" ;
    ex:textoExtracto "Este modo utiliza el tipo de aceleración definido en el parámetro SLOPETYPE." .

ex:Parametro_CORNERJERK a ex:Parametro ;
    ex:identificador "CORNERJERK" ;
    ex:textoExtracto "se puede ampliar el jerk en las aristas (parámetro CORNERJERK)" .

ex:Parametro_SMOOTHFREQ a ex:Parametro ;
    ex:identificador "SMOOTHFREQ" ;
    ex:textoExtracto "aplicar la frecuencia de suavizado en la interpolación de la trayectoria (parámetro SMOOTHFREQ)" .

ex:Parametro_FILTER a ex:Parametro ;
    ex:identificador "FILTER" ;
    ex:textoExtracto "Los efectos de los filtros definidos mediante el parámetro FILTER se suman a los efectos de los filtros activos en HSC" .

ex:Parametro_HSCFILTFREQ a ex:Parametro ;
    ex:identificador "HSCFILTFREQ" ;
    ex:textoExtracto "parámetro HSCFILTFREQ para el modo CONTERROR" .

ex:Sistema_CNC a ex:Sistema ;
    ex:textoExtracto "el CNC modifica la geometría mediante algoritmos inteligentes de eliminación de puntos innecesarios y generación de splines o transiciones polinómicas entre los bloques" .