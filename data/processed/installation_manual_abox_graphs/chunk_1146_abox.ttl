@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:FILTER a ex:Parametro ;
    rdfs:label "FILTER" ;
    ex:textoExtracto "Los efectos de los filtros definidos mediante el parámetro FILTER se suman a los efectos de los filtros activos en HSC" .

ex:HSCFILTFREQ a ex:Parametro ;
    rdfs:label "HSCFILTFREQ" ;
    ex:textoExtracto "parámetro HSCFILTFREQ para el modo CONTERROR" .

ex:CONTERROR a ex:ModoOperacion ;
    rdfs:label "CONTERROR" ;
    ex:textoExtracto "parámetro HSCFILTFREQ para el modo CONTERROR" .

ex:FAST a ex:ModoOperacion ;
    rdfs:label "FAST" ;
    ex:textoExtracto "Mecanizado HSC optimizando el avance (modo FAST)" .

ex:HSC a ex:ModoOperacion ;
    rdfs:label "HSC" ;
    ex:textoExtracto "efectos de los filtros activos en HSC" .