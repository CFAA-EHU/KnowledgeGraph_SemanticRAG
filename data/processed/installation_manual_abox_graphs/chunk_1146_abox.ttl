@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaTorno a ns1:Sistema ;
    rdfs:label "Sistema Torno con 1 canal, 3 ejes (1 libre) y 1 cabezal" ;
    ns1:textoExtracto "Torno con 1 canal, 3 ejes (1 libre) y 1 cabezal. Configuración de ejes tipo." ;
    ns1:tieneComponente ns1:CabezalConIndiceLogico4,
        ns1:PlanoZXParaCompensacionLongitudinal .

ns1:CabezalConIndiceLogico4 a ns1:Parametro ;
    rdfs:label "Cabezal con índice lógico 4" ;
    ns1:identificador "CHSPDLNAME 1" ;
    ns1:textoExtracto "CHSPDLNAME 1 | S | Cabezal con índice ꞏ1ꞏ. Número lógico ꞏ4ꞏ." .

ns1:PlanoZXParaCompensacionLongitudinal a ns1:Parametro ;
    rdfs:label "Plano ZX para compensación longitudinal" ;
    ns1:identificador "G18" ;
    ns1:textoExtracto "G18 | Plano ZX. Eje Z para la compensación longitudinal." .

