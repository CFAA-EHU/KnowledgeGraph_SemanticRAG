@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoOperacion_FAST a ex:ModoOperacion ;
    rdfs:label "FAST" ;
    ex:textoExtracto "el parámetro FILTER se suman a los efectos de los filtros activos en HSC; parámetro HSCFILTFREQ para el modo CONTERROR. Mecanizado HSC optimizando el avance (modo FAST). Es el modo recomendado de trabajo en las siguientes circunstancias." ;
    ex:tieneFrecuencia ex:Parametro_FASTFILTFREQ .

ex:Parametro_FASTFILTFREQ a ex:Parametro ;
    rdfs:label "FASTFILTFREQ" ;
    ex:textoExtracto "La frecuencia de este filtro para todos los ejes se parametriza en el parámetro FASTFILTFREQ." ;
    ex:valor "frecuencia de filtro para todos los ejes" .

ex:Parametro_LACC1 a ex:Parametro ;
    rdfs:label "LACC1" ;
    ex:textoExtracto "Este modo utiliza aceleración lineal, independientemente de lo definido en el parámetro SLOPETYPE. Para obtener resultados óptimos es imprescindible un buen ajuste de los parámetros LACC1 y LACC2." .

ex:Parametro_LACC2 a ex:Parametro ;
    rdfs:label "LACC2" ;
    ex:textoExtracto "Para obtener resultados óptimos es imprescindible un buen ajuste de los parámetros LACC1 y LACC2." .

ex:Parametro_FASTFACTOR a ex:Parametro ;
    rdfs:label "FASTFACTOR" ;
    ex:textoExtracto "Desde el programa se puede indicar el porcentaje de avance a aplicar, sobre el máximo que es capaz de alcanzar el CNC en función de como se hayan parametrizado los parámetros LACC1 y LACC2. Su programación es opcional; si no se define, se asume el porcentaje definido en el parámetro FASTFACTOR." .

ex:Parametro_SLOPETYPE a ex:Parametro ;
    rdfs:label "SLOPETYPE" ;
    ex:textoExtracto "Este modo utiliza aceleración lineal, independientemente de lo definido en el parámetro SLOPETYPE." .

ex:Parametro_HSCFILTFREQ a ex:Parametro ;
    rdfs:label "HSCFILTFREQ" ;
    ex:textoExtracto "parámetro HSCFILTFREQ para el modo CONTERROR." .

ex:ModoOperacion_CONTERROR a ex:ModoOperacion ;
    rdfs:label "CONTERROR" ;
    ex:textoExtracto "parámetro HSCFILTFREQ para el modo CONTERROR." .