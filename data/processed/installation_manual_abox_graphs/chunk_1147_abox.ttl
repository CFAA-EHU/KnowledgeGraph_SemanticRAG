@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalS a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal S" ;
    ns1:identificador "SPDLNAME 1" ;
    ns1:textoExtracto "SPDLNAME 1 | S" .

ns1:CabezalS1 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal S1" ;
    ns1:identificador "SPDLNAME 2" ;
    ns1:textoExtracto "SPDLNAME 2 | S1" .

ns1:ConfiguracionGeometricaDelCanal1 a ns1:Parametro ;
    rdfs:label "Configuración geométrica del canal 1",
        "Configuración geométrica del canal 2" ;
    ns1:identificador "GEOCONFIG" ;
    ns1:textoExtracto "GEOCONFIG = Plano" ;
    ns1:valor "Plano" .

ns1:EjeX a ns1:ComponenteMecanico ;
    rdfs:label "Eje X" ;
    ns1:identificador "AXISNAME 1" ;
    ns1:textoExtracto "AXISNAME 1 | X" .

ns1:EjeX1 a ns1:ComponenteMecanico ;
    rdfs:label "Eje X1" ;
    ns1:identificador "AXISNAME 3" ;
    ns1:textoExtracto "AXISNAME 3 | X1" .

ns1:EjeZ a ns1:ComponenteMecanico ;
    rdfs:label "Eje Z" ;
    ns1:identificador "AXISNAME 2" ;
    ns1:textoExtracto "AXISNAME 2 | Z" .

ns1:EjeZ1 a ns1:ComponenteMecanico ;
    rdfs:label "Eje Z1" ;
    ns1:identificador "AXISNAME 4" ;
    ns1:textoExtracto "AXISNAME 4 | Z1" .

ns1:NumeroDeCabezalesDelCanal1 a ns1:Parametro ;
    rdfs:label "Número de cabezales del canal 1",
        "Número de cabezales del canal 2" ;
    ns1:identificador "CHNSPDL" ;
    ns1:textoExtracto "CHNSPDL = 1" ;
    ns1:valor "1" .

ns1:NumeroDeCabezales_446b871644 a ns1:Parametro ;
    rdfs:label "Número de cabezales" ;
    ns1:identificador "NSPDL" ;
    ns1:textoExtracto "NSPDL = 2" ;
    ns1:valor "2" .

ns1:NumeroDeCanales_ab4c63a44d a ns1:Parametro ;
    rdfs:label "Número de canales" ;
    ns1:identificador "NCHANNEL" ;
    ns1:textoExtracto "NCHANNEL = 2" ;
    ns1:valor "2" .

ns1:NumeroDeEjesDelCanal1 a ns1:Parametro ;
    rdfs:label "Número de ejes del canal 1",
        "Número de ejes del canal 2" ;
    ns1:identificador "CHNAXIS" ;
    ns1:textoExtracto "CHNAXIS = 2" ;
    ns1:valor "2" .

ns1:NumeroDeEjes_8913f423ec a ns1:Parametro ;
    rdfs:label "Número de ejes" ;
    ns1:identificador "NAXIS" ;
    ns1:textoExtracto "NAXIS = 4" ;
    ns1:valor "4" .

ns1:PlanoDeTrabajoDelCanal1 a ns1:Parametro ;
    rdfs:label "Plano de trabajo del canal 1",
        "Plano de trabajo del canal 2" ;
    ns1:identificador "IPLANE" ;
    ns1:textoExtracto "IPLANE = G18" ;
    ns1:valor "G18" .

ns1:SistemaTornoConCanal a ns1:Sistema ;
    rdfs:label "Sistema Torno con 2 canales, 4 ejes y 2 cabezales" ;
    ns1:textoExtracto "plano. Los ejes y cabezales están distribuidos de la siguiente manera." .

