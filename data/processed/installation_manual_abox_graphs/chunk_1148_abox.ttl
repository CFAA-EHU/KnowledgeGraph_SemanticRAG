@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaConfiguracionEjes a ns1:Esquema ;
    rdfs:label "Configuración de ejes y cabezales" ;
    ns1:textoExtracto "Configuración de los ejes y cabezales del canal ꞏ2ꞏ." ;
    ns1:tieneComponente ns1:CabezalConIndice1_05815fed25,
        ns1:EjeConIndice1,
        ns1:EjeConIndice2 .

ns1:CabezalConIndice1_05815fed25 a ns1:Parametro ;
    rdfs:label "Cabezal con índice 1" ;
    ns1:identificador "CHSPDLNAME 1" ;
    ns1:textoExtracto "CHSPDLNAME 1 | S | Cabezal con índice ꞏ1ꞏ. | Número lógico ꞏ5ꞏ." .

ns1:EjeConIndice1 a ns1:Parametro ;
    rdfs:label "Eje con índice 1",
        "Eje con índice 1 en canal 2" ;
    ns1:identificador "CHAXISNAME 1" ;
    ns1:textoExtracto "CHAXISNAME 1 | X | Eje con índice ꞏ1ꞏ. | Número lógico ꞏ1ꞏ.",
        "CHAXISNAME 1 | X1 | Eje con índice ꞏ1ꞏ. | Número lógico ꞏ3ꞏ." .

ns1:EjeConIndice2 a ns1:Parametro ;
    rdfs:label "Eje con índice 2",
        "Eje con índice 2 en canal 2" ;
    ns1:identificador "CHAXISNAME 2" ;
    ns1:textoExtracto "CHAXISNAME 2 | Z | Eje con índice ꞏ2ꞏ. | Número lógico ꞏ2ꞏ.",
        "CHAXISNAME 2 | Z1 | Eje con índice ꞏ2ꞏ. | Número lógico ꞏ4ꞏ." .

