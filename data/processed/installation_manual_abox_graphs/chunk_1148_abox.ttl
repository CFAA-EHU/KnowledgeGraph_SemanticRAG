@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_FASTFILTFREQ
    a ex:Parametro ;
    rdfs:label "FASTFILTFREQ" ;
    ex:textoExtracto "La frecuencia de este filtro para todos los ejes se parametriza en el parámetro FASTFILTFREQ." ;
    ex:identificador "FASTFILTFREQ" ;
    ex:monitoreaParametro ex:FiltroEjes_HSC .

ex:FiltroEjes_HSC
    a ex:ComponenteElectrico ;
    rdfs:label "Filtro de suavizado para ejes (modo HSC)" ;
    ex:textoExtracto "filtro para todos los ejes, que se introduce automáticamente, para suavizar el movimiento de la máquina" ;
    ex:controla ex:PerfilVelocidad_HSC .

ex:PerfilVelocidad_HSC
    a ex:Parametro ;
    rdfs:label "Perfil de velocidad (modo HSC)" ;
    ex:textoExtracto "perfiles de velocidad y aceleración más suaves pero de menor precisión en las esquinas" .

ex:ModoOperacion_HSC
    a ex:ModoOperacion ;
    rdfs:label "Modo HSC (High Speed Cutting)" ;
    ex:textoExtracto "modo HSC" ;
    ex:tieneComponente ex:FiltroEjes_HSC .