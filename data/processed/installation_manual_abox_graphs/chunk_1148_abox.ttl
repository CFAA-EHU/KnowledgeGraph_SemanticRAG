@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_FASTFILTFREQ a ex:Parametro ;
    rdfs:label "FASTFILTFREQ" ;
    ex:textoExtracto "La frecuencia de este filtro para todos los ejes se parametriza en el parámetro FASTFILTFREQ." ;
    ex:valor "frecuencia de filtro para todos los ejes" .

ex:Filtro_Eje a ex:Componente ;
    ex:textoExtracto "un filtro para todos los ejes, que se introduce automáticamente, para suavizar el movimiento de la máquina" .

ex:ModoOperacion_HSC a ex:ModoOperacion ;
    ex:textoExtracto "modo HSC" .