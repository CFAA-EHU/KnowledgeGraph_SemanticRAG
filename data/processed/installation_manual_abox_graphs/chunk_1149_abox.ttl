@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IndiceDelCabezalEnElCanal1 a ns1:Parametro ;
    rdfs:label "Índice del cabezal en el canal 1" ;
    ns1:documentadoEn ns1:SistemaTorno ;
    ns1:identificador "CHSPDLNAME 1" ;
    ns1:textoExtracto "CHSPDLNAME 1 | S1 | Cabezal con índice ꞏ1ꞏ. | Número lógico ꞏ6ꞏ." .

ns1:EjeX a ns1:ComponenteMecanico ;
    rdfs:label "Eje X" ;
    ns1:textoExtracto "Si se han definido los ejes X (primer eje del canal) y Z (segundo eje del canal)" .

ns1:EjeZ a ns1:ComponenteMecanico ;
    rdfs:label "Eje Z" ;
    ns1:textoExtracto "Si se han definido los ejes X (primer eje del canal) y Z (segundo eje del canal)" .

ns1:SistemaTorno a ns1:Sistema ;
    rdfs:label "Sistema Torno con 2 canales, 4 ejes y 2 cabezales" ;
    ns1:textoExtracto "Torno con 2 canales, 4 ejes y 2 cabezales. Configuración de ejes tipo" ;
    ns1:tieneComponente ns1:EjeX,
        ns1:EjeZ .

