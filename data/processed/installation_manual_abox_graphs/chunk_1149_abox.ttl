@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:FiltroFrecuencia1149 a ex:Frecuencia ;
    ex:textoExtracto "filtro de frecuencia más baja" ;
    ex:valor "más baja" .

ex:ParametroFILTER1149 a ex:Parametro ;
    ex:identificador "FILTER" ;
    ex:textoExtracto "parámetro FILTER" .

ex:ParametroFASTFILTFREQ1149 a ex:Parametro ;
    ex:identificador "FASTFILTFREQ" ;
    ex:textoExtracto "parámetro FASTFILTFREQ" .

ex:ModoHSC1149 a ex:ModoOperacion ;
    ex:identificador "HSC" ;
    ex:textoExtracto "modo HSC" .

ex:ModoFAST1149 a ex:ModoOperacion ;
    ex:identificador "FAST" ;
    ex:textoExtracto "modo FAST" .