ns1:CNC8070_b1a6f8b106 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC almacena estos datos cuando se apaga el CNC, ante una caída de tensión, cuando se produce un error de hardware o software, etc." .

ns1:NumeroDeParametrosGuardados a ns1:Parametro ;
    rdfs:label "Número de parámetros guardados" ;
    ns1:textoExtracto "El CNC guarda los primeros parámetros, desde el 1 hasta el definido en este parámetro." .

