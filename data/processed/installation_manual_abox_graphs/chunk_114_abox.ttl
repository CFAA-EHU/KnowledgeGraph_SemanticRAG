@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_INIPOSAX1 a ex:Parametro ;
    rdfs:label "INIPOSAX1" ;
    ex:textoExtracto "INIPOSAX1 Posición inicial de la compensación volumétrica básica para el eje MOVAXIS." ;
    ex:valor "Entre ±99999.9999 mm / Entre ±3937.00787 inch" ;
    ex:identificador "VCOMPFILE" .

ex:Parametro_INIPOSAX2 a ex:Parametro ;
    rdfs:label "INIPOSAX2" ;
    ex:textoExtracto "INIPOSAX2 Posición inicial de la compensación volumétrica básica para el eje MOVAXIS." ;
    ex:valor "Entre ±99999.9999 mm / Entre ±3937.00787 inch" ;
    ex:identificador "VCOMPFILE" .

ex:Parametro_INIPOSAX3 a ex:Parametro ;
    rdfs:label "INIPOSAX3" ;
    ex:textoExtracto "INIPOSAX3 Posición inicial de la compensación volumétrica básica para el eje MOVAXIS." ;
    ex:valor "Entre ±99999.9999 mm / Entre ±3937.00787 inch" ;
    ex:identificador "VCOMPFILE" .

ex:Tabla_Compensacion_Volumetrica a ex:Tabla ;
    ex:textoExtracto "Estos parámetros sólo están disponibles para la compensación volumétrica básica; sin función en la compensación volumétrica media y grande. El CNC muestra estos parámetros al cargar un archivo con extensión csv en el parámetro VCOMPFILE." ;
    ex:compuestoPor ex:Parametro_INIPOSAX1, ex:Parametro_INIPOSAX2, ex:Parametro_INIPOSAX3 .