@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_INIPOSAX1
    a ex:Parametro ;
    rdfs:label "INIPOSAX1" ;
    ex:textoExtracto "INIPOSAX1 [...] Posición inicial de la compensación volumétrica básica para el eje MOVAXIS. Valores posibles: Entre ±99999.9999 mm / Entre ±3937.00787 inch. Valor por defecto: 0." ;
    ex:valor "0" ;
    ex:identificador "MPG.INIPOSAX1[tbl]" .

ex:Parametro_INIPOSAX2
    a ex:Parametro ;
    rdfs:label "INIPOSAX2" ;
    ex:textoExtracto "INIPOSAX2" ;
    ex:identificador "MPG.INIPOSAX2[tbl]" .

ex:Parametro_INIPOSAX3
    a ex:Parametro ;
    rdfs:label "INIPOSAX3" ;
    ex:textoExtracto "INIPOSAX3" ;
    ex:identificador "MPG.INIPOSAX3[tbl]" .

ex:Parametro_VCOMPFILE
    a ex:Parametro ;
    rdfs:label "VCOMPFILE" ;
    ex:textoExtracto "El CNC muestra estos parámetros al cargar un archivo con extensión csv en el parámetro VCOMPFILE." ;
    ex:identificador "VCOMPFILE" .

ex:Sistema_CompensacionVolumetricaBasica
    a ex:Sistema ;
    rdfs:label "Compensación volumétrica básica" ;
    ex:textoExtracto "Estos parámetros sólo están disponibles para la compensación volumétrica básica; sin función en la compensación volumétrica media y grande." ;
    ex:tieneComponente ex:Parametro_INIPOSAX1 ;
    ex:tieneComponente ex:Parametro_INIPOSAX2 ;
    ex:tieneComponente ex:Parametro_INIPOSAX3 ;
    ex:tieneComponente ex:Parametro_VCOMPFILE .