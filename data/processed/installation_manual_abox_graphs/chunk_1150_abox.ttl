@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ParametrosHSC_1150 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros HSC (páginas 621-622)"@es ;
    ex:textoExtracto """
| Parámetro. |  | Significado. |
| --- | --- | --- |
| HSCDEFAULMODE MPG |  | Modo por defecto al programar #HSC ON. |
| FEEDAVRG MPG |  | Este parámetro habilita el ajuste del avance en función de la velocidad de lectura de bloques y del tamaño de los mismos... |
| SMOOTHFREQ MPG |  | Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias... |
| CORNER MPG |  | Este parámetro indica el ángulo máximo entre dos trayectorias... |
| HSCFILTFREQ MPG |  | Este parámetro activa un filtro automático FIR para todos los ejes del canal durante la ejecución en modo CONTERROR..."""@es ;
    ex:documentadoEn ex:Pagina_621_622 .

ex:Pagina_621_622
    a ex:Pagina ;
    ex:identificador "621-622" ;
    ex:textoExtracto "13.2 Configuración del modo HSC. - 13.2.1 Puesta a punto. Parámetros máquina; generales."@es .

ex:Parametro_HSCDEFAULMODE
    a ex:Parametro ;
    rdfs:label "HSCDEFAULMODE" ;
    ex:identificador "HSCDEFAULMODE MPG" ;
    ex:textoExtracto "Modo por defecto al programar #HSC ON."@es ;
    ex:documentadoEn ex:Tabla_ParametrosHSC_1150 .

ex:Parametro_FEEDAVRG
    a ex:Parametro ;
    rdfs:label "FEEDAVRG" ;
    ex:identificador "FEEDAVRG MPG" ;
    ex:textoExtracto "Este parámetro habilita el ajuste del avance en función de la velocidad de lectura de bloques y del tamaño de los mismos. Este ajuste evita tener que frenar por un suministro inadecuado de bloques pequeños; aunque como consecuencia de ello la velocidad alcanzada sea menor, el tiempo total de mecanizado mejorará."@es ;
    ex:documentadoEn ex:Tabla_ParametrosHSC_1150 .

ex:Parametro_SMOOTHFREQ
    a ex:Parametro ;
    rdfs:label "SMOOTHFREQ" ;
    ex:identificador "SMOOTHFREQ MPG" ;
    ex:textoExtracto "Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias. Este parámetro evita acelerar y decelerar a lo largo de una trayectoria, por encima de una determinada frecuencia al generar una velocidad promediada."@es ;
    ex:documentadoEn ex:Tabla_ParametrosHSC_1150 .

ex:Parametro_CORNER
    a ex:Parametro ;
    rdfs:label "CORNER" ;
    ex:identificador "CORNER MPG" ;
    ex:textoExtracto "Este parámetro indica el ángulo máximo entre dos trayectorias, por debajo del cual se mecaniza en arista viva."@es ;
    ex:documentadoEn ex:Tabla_ParametrosHSC_1150 .

ex:Parametro_HSCFILTFREQ
    a ex:Parametro ;
    rdfs:label "HSCFILTFREQ" ;
    ex:identificador "HSCFILTFREQ MPG" ;
    ex:textoExtracto "Este parámetro activa un filtro automático FIR para todos los ejes del canal durante la ejecución en modo CONTERROR. Este filtro permite suavizar la respuesta de los ejes generando una trayectoria más suave, y en caso necesario, reducir el avance para que el error de trayectoria se ajuste al programado."@es ;
    ex:documentadoEn ex:Tabla_ParametrosHSC_1150 .

ex:ModoOperacion_HSC
    a ex:ModoOperacion ;
    rdfs:label "Modo HSC"@es ;
    ex:textoExtracto "Configuración del modo HSC (High-Speed Cutting)."@es ;
    ex:documentadoEn ex:Pagina_621_622 .

ex:ModoOperacion_CONTERROR
    a ex:ModoOperacion ;
    rdfs:label "CONTERROR" ;
    ex:textoExtracto "Modo de control de error de trayectoria."@es ;
    ex:documentadoEn ex:Tabla_ParametrosHSC_1150 .