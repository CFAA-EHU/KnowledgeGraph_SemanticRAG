@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalS a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal S" ;
    ns1:esComponenteDe ns1:SistemaTornoCanal1 ;
    ns1:textoExtracto "1 cabezal (S)" .

ns1:CabezalS1 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal S1" ;
    ns1:esComponenteDe ns1:SistemaTornoCanal2 ;
    ns1:textoExtracto "1 cabezal (S1)" .

ns1:EjeU a ns1:ComponenteMecanico ;
    rdfs:label "Eje U" ;
    ns1:esComponenteDe ns1:SistemaTornoCanal3 ;
    ns1:textoExtracto "2 ejes (U V)" .

ns1:EjeV a ns1:ComponenteMecanico ;
    rdfs:label "Eje V" ;
    ns1:esComponenteDe ns1:SistemaTornoCanal3 ;
    ns1:textoExtracto "2 ejes (U V)" .

ns1:EjeX a ns1:ComponenteMecanico ;
    rdfs:label "Eje X" ;
    ns1:esComponenteDe ns1:SistemaTornoCanal1 ;
    ns1:textoExtracto "2 ejes (X Z)" .

ns1:EjeX1 a ns1:ComponenteMecanico ;
    rdfs:label "Eje X1" ;
    ns1:esComponenteDe ns1:SistemaTornoCanal2 ;
    ns1:textoExtracto "2 ejes (X1 Z1)" .

ns1:EjeZ a ns1:ComponenteMecanico ;
    rdfs:label "Eje Z" ;
    ns1:esComponenteDe ns1:SistemaTornoCanal1 ;
    ns1:textoExtracto "2 ejes (X Z)" .

ns1:EjeZ1 a ns1:ComponenteMecanico ;
    rdfs:label "Eje Z1" ;
    ns1:esComponenteDe ns1:SistemaTornoCanal2 ;
    ns1:textoExtracto "2 ejes (X1 Z1)" .

ns1:SistemaTornoCanal3 a ns1:Sistema ;
    rdfs:label "Sistema Torno Canal 3" ;
    ns1:textoExtracto "Canal ꞏ3ꞏ. 2 ejes (U V)" .

ns1:SistemaTornoCanal1 a ns1:Sistema ;
    rdfs:label "Sistema Torno Canal 1" ;
    ns1:textoExtracto "Canal ꞏ1ꞏ. 2 ejes (X Z) 1 cabezal (S)." .

ns1:SistemaTornoCanal2 a ns1:Sistema ;
    rdfs:label "Sistema Torno Canal 2" ;
    ns1:textoExtracto "Canal ꞏ2ꞏ. 2 ejes (X1 Z1) 1 cabezal (S1)." .

