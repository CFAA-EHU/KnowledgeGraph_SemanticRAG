@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:FiltroSuavizadoRespuestaEjes a ex:Parametro ;
    rdfs:label "Filtro suavizado respuesta de los ejes"@es ;
    ex:textoExtracto "Este filtro permite suavizar la respuesta de los ejes generando una trayectoria más suave"@es .

ex:FASTFACTOR_MPG a ex:Parametro ;
    rdfs:label "FASTFACTOR MPG"@es ;
    ex:identificador "FASTFACTOR MPG" ;
    ex:textoExtracto "FASTFACTOR MPG | Este parámetro afecta al avance en las esquinas e indica el"@es .