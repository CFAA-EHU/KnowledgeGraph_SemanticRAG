@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaTorno a ns1:Sistema ;
    rdfs:label "Sistema Torno" ;
    ns1:textoExtracto "Selección de planos en el canal 1 y 2. Con esta configuración, el plano de trabajo siempre es G18 y estará formado por los dos primeros ejes definidos en el canal." ;
    ns1:tieneComponente ns1:EjeConIndice1,
        ns1:EjeConIndice2 .

ns1:EjeConIndice1 a ns1:Parametro ;
    rdfs:label "Eje con índice 1" ;
    ns1:identificador "CHAXISNAME 1" ;
    ns1:textoExtracto "CHAXISNAME 1 | U | Eje con índice ꞏ1ꞏ. | Número lógico ꞏ5ꞏ." .

ns1:EjeConIndice2 a ns1:Parametro ;
    rdfs:label "Eje con índice 2" ;
    ns1:identificador "CHAXISNAME 2" ;
    ns1:textoExtracto "CHAXISNAME 2 | V | Eje con índice ꞏ2ꞏ. | Número lógico ꞏ6ꞏ." .

