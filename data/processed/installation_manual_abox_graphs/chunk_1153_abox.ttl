@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:FASTFILTFREQ_MPG a ex:Parametro ;
    rdfs:label "FASTFILTFREQ MPG" ;
    ex:identificador "FASTFILTFREQ MPG" ;
    ex:textoExtracto "Este parámetro activa un filtro \"paso bajo\" automático para todos los ejes del canal durante la ejecución en modo HSC FAST, el cuál permite suavizar la respuesta de los ejes generando una trayectoria más suave. Este filtro tiene el inconveniente de redondear ligeramente las aristas. Este parámetro introduce un desfase constante, independiente de las frecuencias." ;
    ex:valor "parámetro máquina; general" .

ex:FREQRES_MPG a ex:Parametro ;
    rdfs:label "FREQRES MPG" ;
    ex:identificador "FREQRES MPG" ;
    ex:textoExtracto "Frecuencia de resonancia que el CNC debe eliminar en la generación de la consigna. Este parámetro sólo es válido cuando el perfil de aceleración es trapezoidal o seno cuadrado (parámetro SLOPETYPE), que es el perfil de aceleración por defecto para el modo HSC CONTERROR." ;
    ex:valor "parámetro máquina; general" .

ex:SOFTFREQ_MPG a ex:Parametro ;
    rdfs:label "SOFTFREQ MPG" ;
    ex:identificador "SOFTFREQ MPG" ;
    ex:textoExtracto "Frecuencia del filtro de trayectoria para perfiles de aceleración lineal. Este parámetro permite suavizar el perfil de velocidad en modo HSC FAST, lo que permite mejorar el tiempo y la calidad superficial del mecanizado. Este parámetro se debe ajustar con ayuda de la aplicación FineTune." ;
    ex:valor "parámetro máquina; general" .

ex:HSCROUND_MPG a ex:Parametro ;
    rdfs:label "HSCROUND MPG" ;
    ex:identificador "HSCROUND MPG" ;
    ex:textoExtracto "Valor por defecto del error máximo de la trayectoria en HSC." ;
    ex:valor "parámetro máquina; general" .

ex:SURFFILFREQ_MPG a ex:Parametro ;
    rdfs:label "SURFFILFREQ MPG" ;
    ex:identificador "SURFFILFREQ MPG" ;
    ex:textoExtracto "Este parámetro activa un filtro automático para todos los ejes del canal durante la ejecución en modo HSC SURFACE, el cuál permite suavizar la respuesta de los ejes generando una trayectoria más suave." ;
    ex:valor "parámetro máquina; general" .