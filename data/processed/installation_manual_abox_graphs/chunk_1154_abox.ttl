@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_CORNERACC_MPA a ex:Parametro ;
    rdfs:label "CORNERACC MPA" ;
    ex:identificador "CORNERACC MPA" ;
    ex:textoExtracto "Este parámetro define la aceleración máxima que se va a permitir al eje en la transición de bloques. Si este parámetro se define con valor ꞏ0ꞏ, se respeta la aceleración máxima del eje." ;
    ex:valor "0" .

ex:Parametro_CURVACC_MPA a ex:Parametro ;
    rdfs:label "CURVACC MPA" ;
    ex:identificador "CURVACC MPA" ;
    ex:textoExtracto "Aceleración máxima permitida en curvatura. Si este parámetro se define con valor ꞏ0ꞏ, se respeta la aceleración máxima del eje." ;
    ex:valor "0" .

ex:Parametro_CORNERJERK_MPA a ex:Parametro ;
    rdfs:label "CORNERJERK MPA" ;
    ex:identificador "CORNERJERK MPA" ;
    ex:textoExtracto "Jerk máximo permitido en las esquinas. Si este parámetro se define con valor ꞏ0ꞏ, se respeta el jerk máximo del eje." ;
    ex:valor "0" .

ex:Parametro_CURVJERK_MPA a ex:Parametro ;
    rdfs:label "CURVJERK MPA" ;
    ex:identificador "CURVJERK MPA" ;
    ex:textoExtracto "Jerk máximo permitido en curvatura. Si este parámetro se define con valor ꞏ0ꞏ, se respeta el jerk máximo del eje." ;
    ex:valor "0" .

ex:Parametro_FASTACC_MPA a ex:Parametro ;
    rdfs:label "FASTACC MPA" ;
    ex:identificador "FASTACC MPA" ;
    ex:textoExtracto "Aceleración máxima permitida (modo FAST). Si este parámetro se define con valor ꞏ0ꞏ, se respeta la aceleración máxima del eje." ;
    ex:valor "0" .

ex:Parametro_MAXERROR_MPA a ex:Parametro ;
    rdfs:label "MAXERROR MPA" ;
    ex:identificador "MAXERROR MPA" ;
    ex:textoExtracto "Error de posición. Máximo error de posición del eje en HSC cuando trabaja fuera del plano/triedo." .