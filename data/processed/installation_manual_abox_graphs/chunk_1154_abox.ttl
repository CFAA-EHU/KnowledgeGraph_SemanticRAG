@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_92cf6ea2d3 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:TablaConfiguracionEjesRotativos ;
    ns1:textoExtracto "El CNC admite diferentes formas de configurar un eje rotativo, en función de como va a realizar los desplazamientos." ;
    ns1:tieneComponente ns1:EjeRotativoLinearlike,
        ns1:EjeRotativoNormal .

ns1:LimiteInferior a ns1:Parametro ;
    rdfs:label "Límite Inferior" ;
    ns1:identificador "LIMIT-" ;
    ns1:textoExtracto "Los parámetros máquina LIMIT+ y LIMIT- establecen los límites de recorrido del eje; no hay límites de módulo." .

ns1:LimiteSuperior a ns1:Parametro ;
    rdfs:label "Límite Superior" ;
    ns1:identificador "LIMIT+" ;
    ns1:textoExtracto "Los parámetros máquina LIMIT+ y LIMIT- establecen los límites de recorrido del eje; no hay límites de módulo." .

ns1:ModoDeEje_bf5415576b a ns1:Parametro ;
    rdfs:label "Modo de Eje" ;
    ns1:identificador "AXISMODE" ;
    ns1:textoExtracto "Los parámetros máquina LIMIT+ y LIMIT- establecen los límites de recorrido del eje; no hay límites de módulo." .

ns1:TipoDeEje a ns1:Parametro ;
    rdfs:label "Tipo de Eje" ;
    ns1:identificador "AXISTYPE" ;
    ns1:textoExtracto "Los parámetros máquina LIMIT+ y LIMIT- establecen los límites de recorrido del eje; no hay límites de módulo." .

ns1:EjeRotativoLinearlike a ns1:ComponenteMecanico ;
    rdfs:label "Eje Rotativo Linearlike" ;
    ns1:textoExtracto "El eje se comporta como un eje lineal, pero las unidades de programación son grados. El CNC visualiza las cotas entre los límites de recorrido." .

ns1:EjeRotativoNormal a ns1:ComponenteMecanico ;
    rdfs:label "Eje Rotativo Normal" ;
    ns1:textoExtracto "Este tipo de eje rotativo puede girar en ambos sentidos. El CNC visualiza las cotas entre los límites del módulo." .

ns1:TablaConfiguracionEjesRotativos a ns1:Tabla ;
    rdfs:label "Tabla de Configuración de Ejes Rotativos" ;
    ns1:textoExtracto """| Parámetro. | Valor. |
| --- | --- |
| AXISTYPE | Rotativo. |
| AXISMODE | Linearlike. |
| UNIDIR | Sin función. |
| SHORTESTWAY | Sin función. |
| LIMIT+
LIMIT- | Límites de recorrido. |
| MODUPLIM
MODLOWLIM | Sin función. |""" .

