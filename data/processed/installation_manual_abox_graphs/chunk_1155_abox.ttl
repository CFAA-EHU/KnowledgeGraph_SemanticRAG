@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazUsuario_1155
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de acceso a variables (PRG/MDI/MDA/PLC/INT)"@es ;
    ex:textoExtracto "Las siguientes variables son accesibles desde; (PRG) el programa pieza y desde el modo MDI/MDA, PLC e (INT) una aplicación externa. La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W)."@es ;
    ex:identificador "13.3 Variables" .

ex:Parametro_1155_AccesoSincronoPLC
    a ex:Parametro ;
    rdfs:label "Acceso síncrono a variables desde PLC"@es ;
    ex:textoExtracto "El acceso a las variables desde el PLC, tanto para la lectura como para la escritura, será síncrono."@es ;
    ex:monitoreaParametro ex:InterfazUsuario_1155 .

ex:Parametro_1155_ValorPreparacionBloques
    a ex:Parametro ;
    rdfs:label "Valor de preparación de bloques (programa pieza)"@es ;
    ex:textoExtracto "El acceso a las variables desde el programa pieza devuelve el valor de la preparación de bloques, excepto cuando se indique lo contrario."@es ;
    ex:monitoreaParametro ex:InterfazUsuario_1155 .