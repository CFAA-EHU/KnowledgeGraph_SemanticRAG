@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjeRotativo a ns1:Sistema ;
    rdfs:label "Eje Rotativo" ;
    ns1:textoExtracto "Aunque el desplazamiento programado sea superior al módulo, el eje nunca da más de una vuelta." .

ns1:IncrementoDePosicion a ns1:Parametro ;
    rdfs:label "incremento de posición" ;
    ns1:textoExtracto "el valor absoluto de la cota indica el incremento de posición." .

ns1:MovimientoIncrementalNormal a ns1:AccionProhibida ;
    rdfs:label "Movimiento incremental normal" ;
    ns1:textoExtracto "El signo de la cota indica el sentido del desplazamiento; el valor absoluto de la cota indica el incremento de posición." .

