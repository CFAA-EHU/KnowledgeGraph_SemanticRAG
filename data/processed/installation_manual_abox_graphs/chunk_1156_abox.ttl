@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DireccionUnica a ns1:Parametro ;
    rdfs:label "Dirección única" ;
    ns1:identificador "UNIDIR" ;
    ns1:textoExtracto "UNIDIR | No. / Positivo / Negativo." ;
    ns1:valor "No"@es,
        "Positivo / Negativo"@es .

ns1:LimiteInferior a ns1:Parametro ;
    rdfs:label "Límite inferior" ;
    ns1:identificador "LIMIT-" ;
    ns1:textoExtracto "LIMIT- | Sin función. No hay límites de recorrido." ;
    ns1:valor "Sin función"@es .

ns1:LimiteInferiorDelModulo_89c14f30f9 a ns1:Parametro ;
    rdfs:label "Límite inferior del módulo" ;
    ns1:identificador "MODLOWLIM" ;
    ns1:textoExtracto "MODLOWLIM | Límites del módulo. Límites para visualizar las cotas." .

ns1:LimiteSuperior a ns1:Parametro ;
    rdfs:label "Límite superior" ;
    ns1:identificador "LIMIT+" ;
    ns1:textoExtracto "LIMIT+ | Sin función. No hay límites de recorrido." ;
    ns1:valor "Sin función"@es .

ns1:LimiteSuperiorDelModulo_b06aef9c56 a ns1:Parametro ;
    rdfs:label "Límite superior del módulo" ;
    ns1:identificador "MODUPLIM" ;
    ns1:textoExtracto "MODUPLIM | Límites del módulo. Límites para visualizar las cotas." .

ns1:ModoDelEje a ns1:Parametro ;
    rdfs:label "Modo del eje" ;
    ns1:identificador "AXISMODE" ;
    ns1:textoExtracto "AXISMODE | Módulo." ;
    ns1:valor "Módulo"@es .

ns1:RutaMasCorta_58451b2f82 a ns1:Parametro ;
    rdfs:label "Ruta más corta" ;
    ns1:identificador "SHORTESTWAY" ;
    ns1:textoExtracto "SHORTESTWAY | No." ;
    ns1:valor "No"@es .

ns1:TipoDeEje a ns1:Parametro ;
    rdfs:label "Tipo de eje" ;
    ns1:identificador "AXISTYPE" ;
    ns1:textoExtracto "AXISTYPE | Rotativo." ;
    ns1:valor "Rotativo"@es .

