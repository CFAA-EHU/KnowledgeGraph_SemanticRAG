@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CaminoMasCorto a ns1:Parametro ;
    rdfs:label "Camino más corto" ;
    ns1:identificador "SHORTESTWAY" ;
    ns1:textoExtracto "Configuración de los parámetros máquina. SHORTESTWAY Sí." .

ns1:DireccionUnica a ns1:Parametro ;
    rdfs:label "Dirección única" ;
    ns1:identificador "UNIDIR" ;
    ns1:textoExtracto "Configuración de los parámetros máquina. UNIDIR No." .

ns1:LimiteInferiorDelModuloDelEje a ns1:Parametro ;
    rdfs:label "Límite inferior del módulo del eje" ;
    ns1:textoExtracto "Los parámetros máquina MODUPLIM y MODLOWLIM establecen los límites del módulo del eje;" .

ns1:LimiteSuperiorDelModuloDelEje a ns1:Parametro ;
    rdfs:label "Límite superior del módulo del eje" ;
    ns1:textoExtracto "Los parámetros máquina MODUPLIM y MODLOWLIM establecen los límites del módulo del eje;" .

ns1:ModoDelEje a ns1:Parametro ;
    rdfs:label "Modo del eje" ;
    ns1:identificador "AXISMODE" ;
    ns1:textoExtracto "Configuración de los parámetros máquina. AXISMODE Módulo." .

ns1:TipoDeEje a ns1:Parametro ;
    rdfs:label "Tipo de eje" ;
    ns1:identificador "AXISTYPE" ;
    ns1:textoExtracto "Configuración de los parámetros máquina. AXISTYPE Rotativo." .

