@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_13_3_4_VariablesLimitacionAvance a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla 13.3.4: Variables asociadas a la limitación en el avance"@es ;
    ex:textoExtracto """
| Variables. | PRG | PLC | INT |
| --- | --- | --- | --- |
| (V.)[ch].G.PERFRATE
Porcentaje de bloques que gestiona el CNC en la preparación de
bloques, respecto el óptimo alcanzable, para alcanzar el avance
máximo en cada tramo. [...]"""@es ;
    ex:documentadoEn ex:Pagina_625_626 .

ex:Parametro_PERFRATE
    a ex:Parametro ;
    rdfs:label "(V.)[ch].G.PERFRATE" ;
    ex:identificador "PERFRATE" ;
    ex:valor "100"^^xsd:float ; # Valor óptimo esperado
    ex:textoExtracto "Porcentaje de bloques que gestiona el CNC en la preparación de bloques, respecto el óptimo alcanzable, para alcanzar el avance máximo en cada tramo. Esta variable debe devolver un valor próximo a 100; si el porcentaje de bloques es inferior al 100 %, puede que el HSC esté perdiendo espacio para aumentar el avance, respetando el espacio disponible para frenar."@es ;
    ex:documentadoEn ex:Tabla_13_3_4_VariablesLimitacionAvance .

ex:Parametro_DROPRATE
    a ex:Parametro ;
    rdfs:label "(V.)[ch].G.DROPRATE" ;
    ex:identificador "DROPRATE" ;
    ex:valor "100"^^xsd:float ; # Valor óptimo esperado
    ex:textoExtracto "Porcentaje de reducción del avance máximo alcanzable. [...] Esta variable debe devolver un valor próximo a 100; si el valor es inferior al 100 %, es posible que el CNC pueda aumentar el avance si tuviera más bloques."@es ;
    ex:documentadoEn ex:Tabla_13_3_4_VariablesLimitacionAvance .

ex:Parametro_LIMERROR
    a ex:Parametro ;
    rdfs:label "(V.)[ch].G.LIMERROR" ;
    ex:identificador "LIMERROR" ;
    ex:textoExtracto "Valor del error que desactiva las splines (modo CONTERROR). Esta variable permite valorar si el programa está generado con más error del que pedimos al modo HSC."@es ;
    ex:documentadoEn ex:Tabla_13_3_4_VariablesLimitacionAvance .

ex:Parametro_PREPFREQ
    a ex:Parametro ;
    rdfs:label "PREPFREQ" ;
    ex:identificador "PREPFREQ" ;
    ex:textoExtracto "Parámetro que puede aumentarse para mejorar el suministro de bloques, siempre que el sistema vaya holgado de tiempo (aproximadamente el 50% del tiempo de ciclo)."@es ;
    ex:documentadoEn ex:Tabla_13_3_4_VariablesLimitacionAvance .

ex:Parametro_NCTIMERATE
    a ex:Parametro ;
    rdfs:label "V.G.NCTIMERATE" ;
    ex:identificador "NCTIMERATE" ;
    ex:textoExtracto "Porcentaje de tiempo de ciclo que utiliza el CNC. Esta información permite evaluar si el sistema está holgado para aumentar PREPFREQ."@es ;
    ex:documentadoEn ex:Tabla_13_3_4_VariablesLimitacionAvance .

# Relaciones funcionales entre parámetros (según lógica descrita en el texto)
ex:Parametro_PERFRATE
    ex:monitoreaParametro ex:Parametro_DROPRATE .

ex:Parametro_DROPRATE
    ex:monitoreaParametro ex:Parametro_PERFRATE .

ex:Parametro_PREPFREQ
    ex:solucionaFallo ex:Parametro_PERFRATE ,
                      ex:Parametro_DROPRATE .

ex:Parametro_NCTIMERATE
    ex:monitoreaParametro ex:Parametro_PREPFREQ .