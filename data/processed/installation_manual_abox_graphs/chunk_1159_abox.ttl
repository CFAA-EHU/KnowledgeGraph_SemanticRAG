@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfigurarUnEjeComoEjeRotativo a ns1:Parametro ;
    rdfs:label "Configurar un eje como eje rotativo" ;
    ns1:identificador "AXISMODE" ;
    ns1:textoExtracto "AXISMODE | Módulo." .

ns1:LimitesDelModuloParaVisualizarLasCotas a ns1:Parametro ;
    rdfs:label "Límites del módulo para visualizar las cotas" ;
    ns1:identificador "MODLOWLIM" ;
    ns1:textoExtracto "MODLOWLIM | Límites del módulo. Límites para visualizar las cotas." .

ns1:LimitesDelModuloParaVisualizarLasCotas_55ce157dcb a ns1:Parametro ;
    rdfs:label "Límites del módulo para visualizar las cotas" ;
    ns1:identificador "MODUPLIM" ;
    ns1:textoExtracto "MODUPLIM | Límites del módulo. Límites para visualizar las cotas." .

ns1:NoEspecificaDireccionUnica a ns1:Parametro ;
    rdfs:label "No especifica dirección única" ;
    ns1:identificador "UNIDIR" ;
    ns1:textoExtracto "UNIDIR | No." .

ns1:SinFuncionNoHayLimitesDeRecorrido a ns1:Parametro ;
    rdfs:label "Sin función. No hay límites de recorrido" ;
    ns1:identificador "LIMIT+",
        "LIMIT-" ;
    ns1:textoExtracto "LIMIT- | Sin función. No hay límites de recorrido." .

ns1:UsarElCaminoMasCorto a ns1:Parametro ;
    rdfs:label "Usar el camino más corto" ;
    ns1:identificador "SHORTESTWAY" ;
    ns1:textoExtracto "SHORTESTWAY | Sí." .

