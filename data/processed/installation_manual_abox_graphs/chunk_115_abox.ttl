@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_f050ed3529 a ns1:Parametro ;
    rdfs:label "Marca para deshabilitar tabla 2 de compensación cruzada" ;
    ns1:habilitadoPor ns1:SistemaPLC ;
    ns1:identificador "DISCROSS2" ;
    ns1:textoExtracto "La marca DISCROSS2 es para la tabla 2." .

ns1:Parametro_fdb4869759 a ns1:Parametro ;
    rdfs:label "Marca para deshabilitar tabla 1 de compensación cruzada" ;
    ns1:habilitadoPor ns1:SistemaPLC ;
    ns1:identificador "DISCROSS1" ;
    ns1:textoExtracto "La marca DISCROSS1 es para la tabla 1." .

ns1:TablasDeCompensacionCruzada a ns1:Parametro ;
    rdfs:label "Tablas de compensación cruzada" ;
    ns1:documentadoEn ns1:TablaCompensacionCruzada ;
    ns1:identificador "CROSSCOMP" ;
    ns1:textoExtracto "Este parámetro muestra las tablas de compensación cruzada." .

ns1:TablaCompensacionCruzada a ns1:Tabla ;
    rdfs:label "Tablas de compensación cruzada" ;
    ns1:textoExtracto "Definir las tablas en el orden en que se ha realizado la medición." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "El PLC dispone de una marca para cada tabla." .

