@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla_VOLCOMP a ex:Tabla ;
    ex:textoExtracto "Parámetro incluido en la tabla VOLCOMP." ;
    ex:tieneComponente ex:Parametro_MPG.INIPOSAX1_tbl, ex:Parametro_MPG.INIPOSAX2_tbl, ex:Parametro_MPG.INIPOSAX3_tbl, ex:Parametro_MPG.INCREAX1_tbl, ex:Parametro_MPG.INCREAX2_tbl, ex:Parametro_MPG.INCREAX3_tbl, ex:Parametro_MPG.VCOMPAXIS1_tbl, ex:Parametro_MPG.VCOMPAXIS2_tbl, ex:Parametro_MPG.VCOMPAXIS3_tbl .

ex:Parametro_MPG.INIPOSAX1_tbl a ex:Parametro ;
    ex:identificador "(V.)MPG.INIPOSAX1[tbl]" ;
    ex:textoExtracto "Posición inicial de la compensación volumétrica básica para el MOVAXIS. Estos parámetros sólo están disponibles para la compensación volumétrica básica; sin función en la compensación volumétrica media y grande. El CNC muestra estos parámetros al cargar un archivo con extensión csv en el parámetro VCOMPFILE." ;
    ex:valor "Entre ±99999.9999 mm / Entre ±3937.00787 inch. Valor por defecto: 0" .

ex:Parametro_MPG.INIPOSAX2_tbl a ex:Parametro ;
    ex:identificador "(V.)MPG.INIPOSAX2[tbl]" ;
    ex:textoExtracto "Posición inicial de la compensación volumétrica básica para el MOVAXIS. Estos parámetros sólo están disponibles para la compensación volumétrica básica; sin función en la compensación volumétrica media y grande. El CNC muestra estos parámetros al cargar un archivo con extensión csv en el parámetro VCOMPFILE." ;
    ex:valor "Entre ±99999.9999 mm / Entre ±3937.00787 inch. Valor por defecto: 0" .

ex:Parametro_MPG.INIPOSAX3_tbl a ex:Parametro ;
    ex:identificador "(V.)MPG.INIPOSAX3[tbl]" ;
    ex:textoExtracto "Posición inicial de la compensación volumétrica básica para el MOVAXIS. Estos parámetros sólo están disponibles para la compensación volumétrica básica; sin función en la compensación volumétrica media y grande. El CNC muestra estos parámetros al cargar un archivo con extensión csv en el parámetro VCOMPFILE." ;
    ex:valor "Entre ±99999.9999 mm / Entre ±3937.00787 inch. Valor por defecto: 0" .

ex:Parametro_MPG.INCREAX1_tbl a ex:Parametro ;
    ex:identificador "(V.)MPG.INCREAX1[tbl]" ;
    ex:textoExtracto "Intervalo entre puntos para el eje MOVAXIS en la compensación volumétrica básica. Estos parámetros sólo están disponibles para la compensación volumétrica básica; sin función en la compensación volumétrica media y grande. El CNC muestra estos parámetros al cargar un archivo con extensión csv en el parámetro VCOMPFILE." ;
    ex:valor "Entre ±99999.9999 mm / Entre ±3937.00787 inch. Valor por defecto: 10 mm / 0.3937 inch" .

ex:Parametro_MPG.INCREAX2_tbl a ex:Parametro ;
    ex:identificador "(V.)MPG.INCREAX2[tbl]" ;
    ex:textoExtracto "Intervalo entre puntos para el eje MOVAXIS en la compensación volumétrica básica. Estos parámetros sólo están disponibles para la compensación volumétrica básica; sin función en la compensación volumétrica media y grande. El CNC muestra estos parámetros al cargar un archivo con extensión csv en el parámetro VCOMPFILE." ;
    ex:valor "Entre ±99999.9999 mm / Entre ±3937.00787 inch. Valor por defecto: 10 mm / 0.3937 inch" .

ex:Parametro_MPG.INCREAX3_tbl a ex:Parametro ;
    ex:identificador "(V.)MPG.INCREAX3[tbl]" ;
    ex:textoExtracto "Intervalo entre puntos para el eje MOVAXIS en la compensación volumétrica básica. Estos parámetros sólo están disponibles para la compensación volumétrica básica; sin función en la compensación volumétrica media y grande. El CNC muestra estos parámetros al cargar un archivo con extensión csv en el parámetro VCOMPFILE." ;
    ex:valor "Entre ±99999.9999 mm / Entre ±3937.00787 inch. Valor por defecto: 10 mm / 0.3937 inch" .

ex:Parametro_MPG.VCOMPAXIS1_tbl a ex:Parametro ;
    ex:identificador "(V.)MPG.VCOMPAXIS1[tbl]" ;
    ex:textoExtracto "Nombre del eje a compensar. Estos parámetros sólo están disponibles para la compensación volumétrica básica; sin función en la compensación volumétrica media y grande. El CNC muestra estos parámetros al cargar un archivo con extensión csv en el parámetro VCOMPFILE." ;
    ex:valor "Cualquier eje definido en AXISNAME. Valor por defecto: Ninguno" .

