@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LimiteInferiorDeSoftware_e707e2f419 a ns1:Parametro ;
    rdfs:label "Límite inferior de software" ;
    ns1:identificador "LIMIT-" ;
    ns1:textoExtracto "Ambos ejes deberán tener los mismos límites de software (parámetros LIMIT+ y LIMIT- iguales para ambos ejes)." .

ns1:LimiteSuperiorDeSoftware_02cbbaf917 a ns1:Parametro ;
    rdfs:label "Límite superior de software" ;
    ns1:identificador "LIMIT+" ;
    ns1:textoExtracto "Ambos ejes deberán tener los mismos límites de software (parámetros LIMIT+ y LIMIT- iguales para ambos ejes)." .

ns1:PermisoDeCambioDeCanal_2f2435ba9c a ns1:Parametro ;
    rdfs:label "Permiso de cambio de canal" ;
    ns1:identificador "AXISEXCH" ;
    ns1:textoExtracto "El permiso de cambio de canal (parámetro AXISEXCH) deberá ser igual en ambos ejes." .

ns1:TipoDeEje_8bbab99ff2 a ns1:Parametro ;
    rdfs:label "Tipo de eje" ;
    ns1:identificador "AXISMODE" ;
    ns1:textoExtracto "Cuando los ejes sean rotativos, ambos ejes deberán ser del mismo tipo (parámetros AXISMODE y SHORTESTWAY iguales para ambos ejes)." .

ns1:TipoDeMovimientoMasCorto a ns1:Parametro ;
    rdfs:label "Tipo de movimiento más corto" ;
    ns1:identificador "SHORTESTWAY" ;
    ns1:textoExtracto "Cuando los ejes sean rotativos, ambos ejes deberán ser del mismo tipo (parámetros AXISMODE y SHORTESTWAY iguales para ambos ejes)." .

