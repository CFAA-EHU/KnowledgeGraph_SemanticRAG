@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Variable_PARLIMC_13_3_4
    a ex:Parametro ;
    rdfs:label "Variable (V.)[ch].G.PARLIMC" ;
    ex:identificador "V.[ch].G.PARLIMC" ;
    ex:textoExtracto """
    Causa que limita el avance en la esquina, en el bloque en ejecución. La variable devuelve uno de los siguientes valores.
    [1] El avance máximo del eje.
    [4] La aceleración en la esquina (parámetro CORNERACC).
    [5] El jerk en la esquina (parámetro CORNERJERK).
    [8] El error cordal en la esquina (modo CONTERROR).
    [9] Geometría de la esquina (modo FAST).
    """ ;
    ex:monitoreaParametro ex:SistemaControlCNC_13_3_4 .

ex:SistemaControlCNC_13_3_4
    a ex:Sistema ;
    rdfs:label "Sistema de control CNC (Sección 13.3.4)" ;
    ex:textoExtracto "El CNC evalúa la variable durante la ejecución (detiene la preparación de bloques)." .

ex:Tabla_VariablesLimitacionAvance_13_3_4 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de variables asociadas a la limitación en el avance (Pág. 625-626)" ;
    ex:textoExtracto """
    | Variables. | PRG | PLC | INT |
    | --- | --- | --- | --- |
    | (V.)[ch].G.PARLIMC
    Causa que limita el avance en la esquina, en el bloque en ejecución. La variable devuelve uno de los siguientes valores. [1] El avance máximo del eje. [4] La aceleración en la esquina (parámetro CORNERACC). [5] El jerk en la esquina (parámetro CORNERJERK). [8] El error cordal en la esquina (modo CONTERROR). [9] Geometría de la esquina (modo FAST). Unidades: -.
    """ ;
    ex:documentadoEn ex:Pagina_625_626 ;
    ex:detalladoEnEsquema ex:Variable_PARLIMC_13_3_4 .

ex:Pagina_625_626
    a ex:Pagina ;
    rdfs:label "Páginas 625-626 (Sección 13.3.4)" ;
    ex:textoExtracto "Variables asociadas a la limitación en el avance." ;
    ex:ilustradoEn ex:Capitulo_13 .