@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "Las parejas tándem del sistema se configuran desde los parámetros máquina." ;
    ns1:tieneComponente ns1:Parametro_d59cb80fa3 .

ns1:Parametro_d59cb80fa3 a ns1:Parametro ;
    rdfs:label "Parámetro de configuración para pareja tándem 1",
        "Parámetro de configuración para pareja tándem 2" ;
    ns1:textoExtracto "Cada pareja tándem dispone de los siguientes parámetros máquina generales para su configuración." .

