@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_345b633aaf a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC cierra el lazo de posición únicamente con la posición del eje maestro del tándem." .

ns1:ComponenteElectrico_94cd4772e7 a ns1:ComponenteElectrico ;
    rdfs:label "Motor Maestro del Tándem" ;
    ns1:textoExtracto "El motor maestro del tándem, además de generar par, es el responsable del posicionamiento." .

ns1:ComponenteElectrico_b67ef10490 a ns1:ComponenteElectrico ;
    rdfs:label "Motor Esclavo del Tándem" ;
    ns1:textoExtracto "El motor esclavo únicamente suministra par." .

ns1:EjeEsclavoDelTandem a ns1:Parametro ;
    rdfs:label "Eje Esclavo del Tándem" ;
    ns1:identificador "SLAVEAXIS" ;
    ns1:textoExtracto "Los ejes deberán estar previamente definidos en el parámetro MASTERAXIS y SLAVEAXIS, dentro de la tabla TANDEM." .

ns1:EjeMaestroDelTandem a ns1:Parametro ;
    rdfs:label "Eje Maestro del Tándem" ;
    ns1:identificador "MASTERAXIS" ;
    ns1:textoExtracto "Los ejes deberán estar previamente definidos en el parámetro MASTERAXIS y SLAVEAXIS, dentro de la tabla TANDEM." .

ns1:NombreDelCabezal_64c7ab3ced a ns1:Parametro ;
    rdfs:label "Nombre del Cabezal" ;
    ns1:identificador "SPDLNAME" ;
    ns1:textoExtracto "Los ejes deberán estar previamente definidos en el parámetro AXISNAME y los cabezales en el parámetro SPDLNAME." .

ns1:NombreDelEje_6114635aa5 a ns1:Parametro ;
    rdfs:label "Nombre del Eje" ;
    ns1:identificador "AXISNAME" ;
    ns1:textoExtracto "Los ejes deberán estar previamente definidos en el parámetro AXISNAME y los cabezales en el parámetro SPDLNAME." .

ns1:SistemaTandem a ns1:Sistema ;
    rdfs:label "Sistema Tándem" ;
    ns1:textoExtracto "Un sistema tándem podrá estar formado por una pareja de ejes lineales, de ejes rotativos o de cabezales." .

