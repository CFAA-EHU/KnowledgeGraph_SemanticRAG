@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ControlAnalogico a ns1:Parametro ;
    rdfs:label "Control Analógico" ;
    ns1:identificador "SANALOG" ;
    ns1:textoExtracto "Para controlar el cabezal tándem desde el PLC, por ejemplo en un cambio de gama, sólo es necesario activar las marcas PLCCNTL, SPDLEREV y SANALOG del cabezal maestro." .

ns1:ControlDelPLC a ns1:Parametro ;
    rdfs:label "Control del PLC" ;
    ns1:identificador "PLCCNTL" ;
    ns1:textoExtracto "Para controlar el cabezal tándem desde el PLC, por ejemplo en un cambio de gama, sólo es necesario activar las marcas PLCCNTL, SPDLEREV y SANALOG del cabezal maestro." .

ns1:ReversoDeVelocidad a ns1:Parametro ;
    rdfs:label "Reverso de velocidad" ;
    ns1:identificador "SPDLEREV" ;
    ns1:textoExtracto "Para controlar el cabezal tándem desde el PLC, por ejemplo en un cambio de gama, sólo es necesario activar las marcas PLCCNTL, SPDLEREV y SANALOG del cabezal maestro." .

ns1:SenalDeDeshabilitacion a ns1:Parametro ;
    rdfs:label "Señal de deshabilitación" ;
    ns1:identificador "DRENA(axis)" ;
    ns1:textoExtracto "El PLC deba habilitar y deshabilitar las señales SPENA(axis) y DRENA(axis) de los cabezales maestro y esclavo simultáneamente." .

ns1:SenalDeHabilitacion a ns1:Parametro ;
    rdfs:label "Señal de habilitación" ;
    ns1:identificador "SPENA(axis)" ;
    ns1:textoExtracto "El PLC deba habilitar y deshabilitar las señales SPENA(axis) y DRENA(axis) de los cabezales maestro y esclavo simultáneamente." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:controla ns1:CabezalEsclavo,
        ns1:CabezalMaestro ;
    ns1:textoExtracto "El PLC deba habilitar y deshabilitar las señales SPENA(axis) y DRENA(axis) de los cabezales maestro y esclavo simultáneamente." .

ns1:CabezalEsclavo a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal Esclavo" ;
    ns1:textoExtracto "El PLC deba habilitar y deshabilitar las señales SPENA(axis) y DRENA(axis) de los cabezales maestro y esclavo simultáneamente." .

ns1:CabezalMaestro a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal Maestro" ;
    ns1:textoExtracto "Para controlar el cabezal tándem desde el PLC, por ejemplo en un cambio de gama, sólo es necesario activar las marcas PLCCNTL, SPDLEREV y SANALOG del cabezal maestro." .

