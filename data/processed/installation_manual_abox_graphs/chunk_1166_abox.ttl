@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_VariablesVelocidadLazo a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de variables asociadas a velocidad en el lazo de posición"@es ;
    ex:textoExtracto """
| Variables. | PRG | PLC | INT |
| --- | --- | --- | --- |
| (V.)[ch].A.TFEED.xn
(V.)[ch].A.TFEED.sn
(V.)[ch].SP.TFEED.sn
Valor instantáneo teórico de la velocidad a la entrada del lazo de
posición. Unidades: -.
| (V.)[ch].A.FEED.xn
(V.)[ch].A.FEED.sn
(V.)[ch].SP.FEED.sn
Valor instantáneo real de la velocidad a la entrada del lazo de posición. Unidades: -.
(*) El CNC evalúa la variable durante la ejecución (detiene la preparación de bloques).
Sintaxis: ꞏchꞏ Número de canal. ꞏxnꞏ Nombre, número lógico o índice del eje. ꞏsnꞏ Nombre, número lógico o índice del cabezal.
"""@es .

ex:Param_VelocidadTeoricaEntradaLazo
    a ex:Parametro ;
    rdfs:label "Valor instantáneo teórico de velocidad (TFEED)"@es ;
    ex:identificador "(V.)[ch].A.TFEED.xn / (V.)[ch].A.TFEED.sn / (V.)[ch].SP.TFEED.sn" ;
    ex:textoExtracto "Valor instantáneo teórico de la velocidad a la entrada del lazo de posición."@es ;
    ex:documentadoEn ex:Tabla_VariablesVelocidadLazo .

ex:Param_VelocidadRealEntradaLazo
    a ex:Parametro ;
    rdfs:label "Valor instantáneo real de velocidad (FEED)"@es ;
    ex:identificador "(V.)[ch].A.FEED.xn / (V.)[ch].A.FEED.sn / (V.)[ch].SP.FEED.sn" ;
    ex:textoExtracto "Valor instantáneo real de la velocidad a la entrada del lazo de posición."@es ;
    ex:documentadoEn ex:Tabla_VariablesVelocidadLazo .

ex:SintaxisVariablesCNC_Velocidad
    a ex:InterfazUsuario ;
    rdfs:label "Sintaxis de variables CNC para velocidad en lazo de posición"@es ;
    ex:textoExtracto """
ꞏchꞏ Número de canal.
ꞏxnꞏ Nombre, número lógico o índice del eje (ej. 'Z', '4').
ꞏsnꞏ Nombre, número lógico o índice del cabezal (ej. 'S', '2').
Ejemplos:
- V.A.TFEED.Z → Eje Z.
- V.SP.TFEED.S → Cabezal S.
- V.[2].A.TFEED.1 → Eje índice '1' en canal '2'.
"""@es ;
    ex:documentadoEn ex:Tabla_VariablesVelocidadLazo .