@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Tabla1167_629 a ex:Tabla ;
    ex:textoExtracto """| Variables. | PRG | PLC | INT |
| --- | --- | --- | --- |
| (V.)[ch].A.POSCMD.xn
(V.)[ch].A.POSCMD.sn
(V.)[ch].SP.POSCMD.sn
Consigna de posición para Sercos. Unidades: -. | R(*) | R | R |
| (V.)[ch].A.POSNC.xn
(V.)[ch].A.POSNC.sn
(V.)[ch].SP.POSNC.sn
Feedback de posición. Unidades: -. | R(*) | R | R |
| (V.)[ch].A.FTEO.xn
(V.)[ch].A.FTEO.sn
(V.)[ch].SP.FTEO.sn
Consigna de velocidad para Sercos (en rpm). Unidades: rpm. | R(*) | R | R |
 (*) El CNC evalúa la variable durante la ejecución (detiene la preparación de bloques). Sintaxis de la variable. ꞏchꞏ Número de canal. ꞏxnꞏ Nombre, número lógico o índice del eje. ꞏsnꞏ Nombre, número lógico o índice del cabezal. | V.A.POSCMD.Z | Eje Z. |
| --- | --- |
| V.A.POSCMD.S | Cabezal S. |
| V.SP.POSCMD.S | Cabezal S. |
| V.SP.POSCMD | Cabezal master. |
| V.A.POSCMD.4 | Eje o cabezal con número lógico ꞏ4ꞏ. |
| V.[2].A.POSCMD.1 | Eje con índice ꞏ1ꞏ en el canal ꞏ2ꞏ. |
| V.SP.POSCMD.2 | Cabezal con índice ꞏ2ꞏ en el sistema. |
| V.[2].SP.POSCMD.1 | Cabezal con índice ꞏ1ꞏ en el canal ꞏ2ꞏ. |""" .

ex:VariableConsignaPosicionSercos a ex:Parametro ;
    rdfs:label "Consigna de posición para Sercos" ;
    ex:identificador "(V.)[ch].A.POSCMD.xn" ;
    ex:identificador "(V.)[ch].A.POSCMD.sn" ;
    ex:identificador "(V.)[ch].SP.POSCMD.sn" ;
    ex:valor "Unidades: -." ;
    ex:textoExtracto """(V.)[ch].A.POSCMD.xn
(V.)[ch].A.POSCMD.sn
(V.)[ch].SP.POSCMD.sn
Consigna de posición para Sercos. Unidades: -.""" ;
    ex:tieneFrecuencia ex:FrecuenciaRPR .

ex:VariableFeedbackPosicion a ex:Parametro ;
    rdfs:label "Feedback de posición" ;
    ex:identificador "(V.)[ch].A.POSNC.xn" ;
    ex:identificador "(V.)[ch].A.POSNC.sn" ;
    ex:identificador "(V.)[ch].SP.POSNC.sn" ;
    ex:valor "Unidades: -." ;
    ex:textoExtracto """(V.)[ch].A.POSNC.xn
(V.)[ch].A.POSNC.sn
(V.)[ch].SP.POSNC.sn
Feedback de posición. Unidades: -.""" ;
    ex:tieneFrecuencia ex:FrecuenciaRPR .

ex:VariableConsignaVelocidadSercos a ex:Parametro ;
    rdfs:label "Consigna de velocidad para Sercos" ;
    ex:identificador "(V.)[ch].A.FTEO.xn" ;
    ex:identificador "(V.)[ch].A.FTEO.sn" ;
    ex:identificador "(V.)[ch].SP.FTEO.sn" ;
    ex:valor "Unidades: rpm." ;
    ex:textoExtracto """(V.)[ch].A.FTEO.xn
(V.)[ch].A.FTEO.sn
(V.)[ch].SP.FTEO.sn
Consigna de velocidad para Sercos (en rpm). Unidades: rpm.""" ;
    ex:tieneFrecuencia ex:FrecuenciaRPR .

ex:FrecuenciaRPR a ex:Frecuencia ;
    ex:textoExtracto "R(*) | R | R" .

ex:SintaxisVariableCNC a ex:Parametro ;
    rdfs:label "Sintaxis de la variable" ;
    ex:textoExtracto """(*) El CNC evalúa la variable durante la ejecución (detiene la preparación de bloques). ꞏchꞏ Número de canal. ꞏxnꞏ Nombre, número lógico o índice del eje. ꞏsnꞏ Nombre, número lógico o índice del cabezal.""" .

ex:EjeZ a ex:Parametro ;
    rdfs:label "Eje Z" ;
    ex:identificador "V.A.POSCMD.Z" ;
    ex:textoExtracto "V.A.POSCMD.Z | Eje Z." .

ex:CabezalS a ex:Parametro ;
    rdfs:label "Cabezal S" ;
    ex:identificador "V.A.POSCMD.S" ;
    ex:identificador "V.SP.POSCMD.S" ;
    ex:textoExtracto """V.A.POSCMD.S | Cabezal S.
V.SP.POSCMD.S | Cabezal S.""" .

