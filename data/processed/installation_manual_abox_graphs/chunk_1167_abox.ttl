    rdfs:label "Cabezal con índice 1 en el canal 2" ;
    ex:identificador "V.[2].SP.POSCMD.1" ;
    ex:textoExtracto "V.[2].SP.POSCMD.1 | Cabezal con índice ꞏ1ꞏ en el canal ꞏ2ꞏ." .