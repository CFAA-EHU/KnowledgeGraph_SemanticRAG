@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_VariablesConsignaFeedback a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de variables asociadas a consigna y feedback de posición/velocidad (Sercos)"@es ;
    ex:textoExtracto """
| Variables. | PRG | PLC | INT |
| --- | --- | --- | --- |
| (V.)[ch].A.POSCMD.xn
(V.)[ch].A.POSCMD.sn
(V.)[ch].SP.POSCMD.sn
Consigna de posición para Sercos. Unidades: -.
| (V.)[ch].A.POSNC.xn
(V.)[ch].A.POSNC.sn
(V.)[ch].SP.POSNC.sn
Feedback de posición. Unidades: -.
| (V.)[ch].A.FTEO.xn
(V.)[ch].A.FTEO.sn
(V.)[ch].SP.FTEO.sn
Consigna de velocidad para Sercos (en rpm). Unidades: rpm.
(*) El CNC evalúa la variable durante la ejecución (detiene la preparación de bloques).
""" .

ex:Parametro_V_A_POSCMD_Z
    a ex:Parametro ;
    rdfs:label "V.A.POSCMD.Z" ;
    ex:identificador "V.A.POSCMD.Z" ;
    ex:textoExtracto "V.A.POSCMD.Z | Eje Z."@es ;
    ex:documentadoEn ex:Tabla_VariablesConsignaFeedback .

ex:Parametro_V_A_POSCMD_S
    a ex:Parametro ;
    rdfs:label "V.A.POSCMD.S" ;
    ex:identificador "V.A.POSCMD.S" ;
    ex:textoExtracto "V.A.POSCMD.S | Cabezal S."@es ;
    ex:documentadoEn ex:Tabla_VariablesConsignaFeedback .

ex:Parametro_V_SP_POSCMD_S
    a ex:Parametro ;
    rdfs:label "V.SP.POSCMD.S" ;
    ex:identificador "V.SP.POSCMD.S" ;
    ex:textoExtracto "V.SP.POSCMD.S | Cabezal S."@es ;
    ex:documentadoEn ex:Tabla_VariablesConsignaFeedback .

ex:Parametro_V_SP_POSCMD
    a ex:Parametro ;
    rdfs:label "V.SP.POSCMD" ;
    ex:identificador "V.SP.POSCMD" ;
    ex:textoExtracto "V.SP.POSCMD | Cabezal master."@es ;
    ex:documentadoEn ex:Tabla_VariablesConsignaFeedback .

ex:Parametro_V_A_POSCMD_4
    a ex:Parametro ;
    rdfs:label "V.A.POSCMD.4" ;
    ex:identificador "V.A.POSCMD.4" ;
    ex:textoExtracto "V.A.POSCMD.4 | Eje o cabezal con número lógico '4'."@es ;
    ex:documentadoEn ex:Tabla_VariablesConsignaFeedback .

ex:Parametro_V_2_A_POSCMD_1
    a ex:Parametro ;
    rdfs:label "V.[2].A.POSCMD.1" ;
    ex:identificador "V.[2].A.POSCMD.1" ;
    ex:textoExtracto "V.[2].A.POSCMD.1 | Eje con índice '1' en el canal '2'."@es ;
    ex:documentadoEn ex:Tabla_VariablesConsignaFeedback .

ex:Parametro_V_SP_POSCMD_2
    a ex:Parametro ;
    rdfs:label "V.SP.POSCMD.2" ;
    ex:identificador "V.SP.POSCMD.2" ;
    ex:textoExtracto "V.SP.POSCMD.2 | Cabezal con índice '2' en el sistema."@es ;
    ex:documentadoEn ex:Tabla_VariablesConsignaFeedback .

ex:Parametro_V_2_SP_POSCMD_1
    a ex:Parametro ;
    rdfs:label "V.[2].SP.POSCMD.1" ;
    ex:identificador "V.[2].SP.POSCMD.1" ;
    ex:textoExtracto "V.[2].SP.POSCMD.1 | Cabezal con índice '1' en el canal '2'."@es ;
    ex:documentadoEn ex:Tabla_VariablesConsignaFeedback .

ex:Parametro_V_A_POSNC_xn
    a ex:Parametro ;
    rdfs:label "(V.)[ch].A.POSNC.xn" ;
    ex:identificador "(V.)[ch].A.POSNC.xn" ;
    ex:textoExtracto "(V.)[ch].A.POSNC.xn | Feedback de posición para eje xn (Sercos)."@es ;
    ex:documentadoEn ex:Tabla_VariablesConsignaFeedback ;
    ex:valor "Unidades: - (feedback de posición)."@es .

ex:Parametro_V_A_FTEO_xn
    a ex:Parametro ;
    rdfs:label "(V.)[ch].A.FTEO.xn" ;
    ex:identificador "(V.)[ch].A.FTEO.xn" ;
    ex:textoExtracto "(V.)[ch].A.FTEO.xn | Consigna de velocidad para eje xn (Sercos, rpm)."@es ;
    ex:documentadoEn ex:Tabla_VariablesConsignaFeedback ;
    ex:valor "rpm" .