@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DistribucionDelParEnElTandem a ns1:Parametro ;
    rdfs:label "Distribución del par en el tándem" ;
    ns1:identificador "TORQDIST" ;
    ns1:textoExtracto "La distribución del par en el tándem se define con el parámetro TORQDIST, el cual indica qué porcentaje debe dar el motor maestro." .

ns1:GananciaProporcionalParaElTandem_c9f3b278e9 a ns1:Parametro ;
    rdfs:label "Ganancia proporcional para el tándem" ;
    ns1:identificador "TPROGAIN" ;
    ns1:textoExtracto "La ganancia proporcional se puede definir con el parámetro TPROGAIN." .

ns1:PrecargaDePar a ns1:Parametro ;
    rdfs:label "Precarga de par" ;
    ns1:identificador "PRELOAD" ;
    ns1:textoExtracto "La precarga se define con el parámetro PRELOAD, el cual indica qué porcentaje del par nominal del motor maestro se aplicará como precarga." .

ns1:TiempoParaAplicarLaPrecarga a ns1:Parametro ;
    rdfs:label "Tiempo para aplicar la precarga" ;
    ns1:identificador "PRELFITI" ;
    ns1:textoExtracto "Para aplicar la precarga de una forma gradual y evitar así escalones de par en la entrada del compensador tándem se puede definir el parámetro PRELFITI." .

