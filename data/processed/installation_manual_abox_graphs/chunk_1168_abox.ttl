@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoOperacion_HSC a ex:ModoOperacion ;
    rdfs:label "HSC" ;
    ex:textoExtracto "Para el ajuste del modo HSC" .

ex:Parametro_G00FEED a ex:Parametro ;
    ex:identificador "G00FEED" ;
    ex:textoExtracto "los parámetros G00FEED, ACCEL, LACC1, LACC2 y ACCJERK testeados y ajustados" .

ex:Parametro_ACCEL a ex:Parametro ;
    ex:identificador "ACCEL" ;
    ex:textoExtracto "los parámetros G00FEED, ACCEL, LACC1, LACC2 y ACCJERK testeados y ajustados" .

ex:Parametro_LACC1 a ex:Parametro ;
    ex:identificador "LACC1" ;
    ex:textoExtracto "los parámetros G00FEED, ACCEL, LACC1, LACC2 y ACCJERK testeados y ajustados" .

ex:Parametro_LACC2 a ex:Parametro ;
    ex:identificador "LACC2" ;
    ex:textoExtracto "los parámetros G00FEED, ACCEL, LACC1, LACC2 y ACCJERK testeados y ajustados" .

ex:Parametro_ACCJERK a ex:Parametro ;
    ex:identificador "ACCJERK" ;
    ex:textoExtracto "los parámetros G00FEED, ACCEL, LACC1, LACC2 y ACCJERK testeados y ajustados" .

ex:Herramienta_Osciloscopio a ex:Herramienta ;
    rdfs:label "osciloscopio" ;
    ex:textoExtracto "El osciloscopio servirá como herramienta análisis para ver la evolución del HSC durante el mecanizado" .

ex:Sistema_CNC a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "El CNC dispone de un conjunto de variables, que analizadas durante la ejecución del mecanizado, permiten discernir aspectos mejorables del HSC" ;
    ex:tieneComponente ex:Parametro_G00FEED, ex:Parametro_ACCEL, ex:Parametro_LACC1, ex:Parametro_LACC2, ex:Parametro_ACCJERK .