@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:V_G_PERFRATE a ex:Parametro ;
    rdfs:label "V.G.PERFRATE" ;
    ex:textoExtracto "Porcentaje de bloques que gestiona el CNC en la preparación de bloques, respecto el óptimo alcanzable." ;
    ex:identificador "V.G.PERFRATE" .

ex:V_G_DROPRATE a ex:Parametro ;
    rdfs:label "V.G.DROPRATE" ;
    ex:textoExtracto "Porcentaje de reducción del avance máximo alcanzable." ;
    ex:identificador "V.G.DROPRATE" .

ex:V_G_NCTIMERATE a ex:Parametro ;
    rdfs:label "V.G.NCTIMERATE" ;
    ex:textoExtracto "Porcentaje del tiempo de ciclo que utiliza la parte de tiempo real de CNC." ;
    ex:identificador "V.G.NCTIMERATE" .

ex:V_G_LOOPTIMERATE a ex:Parametro ;
    rdfs:label "V.G.LOOPTIMERATE" ;
    ex:textoExtracto "Porcentaje del tiempo de ciclo que utiliza el lazo de posición." ;
    ex:identificador "V.G.LOOPTIMERATE" .

ex:V_G_CHTIMERATE a ex:Parametro ;
    rdfs:label "V.G.CHTIMERATE" ;
    ex:textoExtracto "Porcentaje del tiempo de ciclo que utiliza el canal." ;
    ex:identificador "V.G.CHTIMERATE" .

ex:V_G_PREPTIMERATE a ex:Parametro ;
    rdfs:label "V.G.PREPTIMERATE" ;
    ex:textoExtracto "Porcentaje del tiempo de ciclo que utiliza el canal para la preparación de bloques." ;
    ex:identificador "V.G.PREPTIMERATE" .

ex:V_G_IPOTIMERATE a ex:Parametro ;
    rdfs:label "V.G.IPOTIMERATE" ;
    ex:textoExtracto "Porcentaje del tiempo de ciclo que utiliza el interpolador del canal." ;
    ex:identificador "V.G.IPOTIMERATE" .