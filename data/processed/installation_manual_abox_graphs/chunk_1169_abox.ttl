@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ParametrosHSC a ex:Tabla ;
    rdfs:label "Tabla de parámetros de rendimiento en modo HSC"@es ;
    ex:textoExtracto """
| Variable. | Significado. |
| --- | --- |
| V.G.PERFRATE | Porcentaje de bloques que gestiona el CNC en la preparación de
bloques, respecto el óptimo alcanzable. |
| V.G.DROPRATE | Porcentaje de reducción del avance máximo alcanzable. |
| V.G.NCTIMERATE | Porcentaje del tiempo de ciclo que utiliza la parte de tiempo real de
CNC. |
| V.G.LOOPTIMERATE | Porcentaje del tiempo de ciclo que utiliza el lazo de posición. |
| V.G.CHTIMERATE | Porcentaje del tiempo de ciclo que utiliza el canal. |
| V.G.PREPTIMERATE | Porcentaje del tiempo de ciclo que utiliza el canal para la
preparación de bloques. |
| V.G.IPOTIMERATE | Porcentaje del tiempo de ciclo que utiliza el interpolador del canal. |
"""@es .

ex:Parametro_VG_PERFRATE a ex:Parametro ;
    rdfs:label "V.G.PERFRATE" ;
    ex:identificador "V.G.PERFRATE" ;
    ex:textoExtracto "Porcentaje de bloques que gestiona el CNC en la preparación de bloques, respecto el óptimo alcanzable."@es ;
    ex:documentadoEn ex:Tabla_ParametrosHSC .

ex:Parametro_VG_DROPRATE a ex:Parametro ;
    rdfs:label "V.G.DROPRATE" ;
    ex:identificador "V.G.DROPRATE" ;
    ex:textoExtracto "Porcentaje de reducción del avance máximo alcanzable."@es ;
    ex:documentadoEn ex:Tabla_ParametrosHSC .

ex:Parametro_VG_NCTIMERATE a ex:Parametro ;
    rdfs:label "V.G.NCTIMERATE" ;
    ex:identificador "V.G.NCTIMERATE" ;
    ex:textoExtracto "Porcentaje del tiempo de ciclo que utiliza la parte de tiempo real de CNC."@es ;
    ex:documentadoEn ex:Tabla_ParametrosHSC .

ex:Parametro_VG_LOOPTIMERATE a ex:Parametro ;
    rdfs:label "V.G.LOOPTIMERATE" ;
    ex:identificador "V.G.LOOPTIMERATE" ;
    ex:textoExtracto "Porcentaje del tiempo de ciclo que utiliza el lazo de posición."@es ;
    ex:documentadoEn ex:Tabla_ParametrosHSC .

ex:Parametro_VG_CHTIMERATE a ex:Parametro ;
    rdfs:label "V.G.CHTIMERATE" ;
    ex:identificador "V.G.CHTIMERATE" ;
    ex:textoExtracto "Porcentaje del tiempo de ciclo que utiliza el canal."@es ;
    ex:documentadoEn ex:Tabla_ParametrosHSC .

ex:Parametro_VG_PREPTIMERATE a ex:Parametro ;
    rdfs:label "V.G.PREPTIMERATE" ;
    ex:identificador "V.G.PREPTIMERATE" ;
    ex:textoExtracto "Porcentaje del tiempo de ciclo que utiliza el canal para la preparación de bloques."@es ;
    ex:documentadoEn ex:Tabla_ParametrosHSC .

ex:Parametro_VG_IPOTIMERATE a ex:Parametro ;
    rdfs:label "V.G.IPOTIMERATE" ;
    ex:identificador "V.G.IPOTIMERATE" ;
    ex:textoExtracto "Porcentaje del tiempo de ciclo que utiliza el interpolador del canal."@es ;
    ex:documentadoEn ex:Tabla_ParametrosHSC .