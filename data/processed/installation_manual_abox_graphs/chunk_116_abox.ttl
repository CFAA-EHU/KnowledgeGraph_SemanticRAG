@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_a0df8fd86c a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC mostrará las tablas posibles en función del número de ejes definidos." .

ns1:ConfiguracionDeLasTablasDeCompensacionCruzada a ns1:Parametro ;
    rdfs:label "Configuración de las tablas de compensación cruzada" ;
    ns1:identificador "CROSSCOMP" ;
    ns1:textoExtracto "CROSSCOMP n Configuración de las tablas de compensación cruzada." .

ns1:ImportarTablasDeCompensacionCruzada a ns1:TareaMantenimiento ;
    rdfs:label "Importar tablas de compensación cruzada" ;
    ns1:documentadoEn ns1:ManualOperacion ;
    ns1:textoExtracto "Para ahorrar tiempo y eliminar errores de transcripción, en lugar de introducir los datos manualmente, se puede adaptar el formato de un fichero de texto en el que esté guardado el resultado de la medición y posteriormente importarlo." .

ns1:ManualOperacion a ns1:Manual ;
    rdfs:label "manual de operación" ;
    ns1:textoExtracto "Para obtener mas información sobre cómo importar las tablas de compensación cruzada, consultar en el manual de operación." .

