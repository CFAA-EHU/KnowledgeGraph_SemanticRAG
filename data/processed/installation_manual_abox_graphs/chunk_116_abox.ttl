@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:VOLCOMP a ex:Tabla ;
    rdfs:label "VOLCOMP" ;
    ex:textoExtracto "Parámetro incluido en la tabla VOLCOMP." ;
    ex:compuestoPor ex:MPG.VCOMPAXIS1, ex:MPG.VCOMPAXIS2, ex:MPG.VCOMPAXIS3 .

ex:MPG.VCOMPAXIS1 a ex:Parametro ;
    rdfs:label "MPG.VCOMPAXIS1[tbl]" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.VCOMPAXIS1[tbl]" .

ex:MPG.VCOMPAXIS2 a ex:Parametro ;
    rdfs:label "MPG.VCOMPAXIS2[tbl]" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.VCOMPAXIS2[tbl]" .

ex:MPG.VCOMPAXIS3 a ex:Parametro ;
    rdfs:label "MPG.VCOMPAXIS3[tbl]" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.VCOMPAXIS3[tbl]" .