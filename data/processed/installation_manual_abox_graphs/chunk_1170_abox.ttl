@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:V_G_PREPTIMERATE a ex:Parametro ;
    ex:identificador "V.G.PREPTIMERATE" ;
    ex:textoExtracto "Porcentaje del tiempo de ciclo que utiliza el canal para la preparación de bloques." ;
    ex:valor "Porcentaje del tiempo de ciclo que utiliza el canal para la preparación de bloques." .

ex:V_G_IPOTIMERATE a ex:Parametro ;
    ex:identificador "V.G.IPOTIMERATE" ;
    ex:textoExtracto "Porcentaje del tiempo de ciclo que utiliza el interpolador del canal." ;
    ex:valor "Porcentaje del tiempo de ciclo que utiliza el interpolador del canal." .

ex:V_G_PERFRATE a ex:Parametro ;
    ex:identificador "V.G.PERFRATE" ;
    ex:textoExtracto "Un valor menor que 100 indica que el CNC puede tratar más bloques." .

ex:V_G_DROPRATE a ex:Parametro ;
    ex:identificador "V.G.DROPRATE" ;
    ex:textoExtracto "Un valor menor que 100 indica que el CNC podría aumentar el avance si tuviera más bloques." .

ex:PREPFREQ a ex:Parametro ;
    ex:textoExtracto "aumentar el parámetro PREPFREQ para que aumente el suministro de bloques, siempre que el sistema vaya holgado de tiempo; es decir, que el porcentaje de tiempo de ciclo que utiliza el CNC no esté demasiado cerca del tiempo de ciclo total (aproximadamente el 50%)." .

ex:V_G_NCTIMERATE a ex:Parametro ;
    ex:identificador "V.G.NCTIMERATE" ;
    ex:textoExtracto "Con un valor menor que 50, se puede aumentar el parámetro PREPFREQ." .

ex:FEEDAVRG a ex:Parametro ;
    ex:textoExtracto "definir el parámetro FEEDAVRG con valor ꞏNoꞏ, para evitar que el CNC limite el avance en función del suministro de bloques." .

ex:ModoOperacion_HSC a ex:ModoOperacion ;
    ex:identificador "HSC" ;
    ex:textoExtracto "Para asegurar un suministro de bloques adecuado al HSC" .

ex:Sistema_CNC a ex:Sistema ;
    ex:textoExtracto "el CNC puede tratar más bloques", "el CNC podría aumentar el avance si tuviera más bloques", "el CNC dispone de las siguientes variables", "el CNC limite el avance en función del suministro de bloques" .