@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_PREPTIMERATE
    a ex:Parametro ;
    rdfs:label "V.G.PREPTIMERATE" ;
    ex:identificador "V.G.PREPTIMERATE" ;
    ex:textoExtracto "| V.G.PREPTIMERATE | Porcentaje del tiempo de ciclo que utiliza el canal para la preparación de bloques." ;
    ex:valor "Porcentaje del tiempo de ciclo para preparación de bloques" .

ex:Parametro_IPOTIMERATE
    a ex:Parametro ;
    rdfs:label "V.G.IPOTIMERATE" ;
    ex:identificador "V.G.IPOTIMERATE" ;
    ex:textoExtracto "| V.G.IPOTIMERATE | Porcentaje del tiempo de ciclo que utiliza el interpolador del canal." ;
    ex:valor "Porcentaje del tiempo de ciclo para interpolación" .

ex:Parametro_PERFRATE
    a ex:Parametro ;
    rdfs:label "V.G.PERFRATE" ;
    ex:identificador "V.G.PERFRATE" ;
    ex:textoExtracto "V.G.PERFRATE Un valor menor que 100 indica que el CNC puede tratar más bloques." ;
    ex:valor "Indicador de capacidad de procesamiento de bloques" .

ex:Parametro_DROPRATE
    a ex:Parametro ;
    rdfs:label "V.G.DROPRATE" ;
    ex:identificador "V.G.DROPRATE" ;
    ex:textoExtracto "V.G.DROPRATE Un valor menor que 100 indica que el CNC podría aumentar el avance si tuviera más bloques." ;
    ex:valor "Indicador de capacidad de aumento de avance" .

ex:Parametro_NCTIMERATE
    a ex:Parametro ;
    rdfs:label "V.G.NCTIMERATE" ;
    ex:identificador "V.G.NCTIMERATE" ;
    ex:textoExtracto "V.G.NCTIMERATE Con un valor menor que 50, se puede aumentar el parámetro PREPFREQ." ;
    ex:valor "Porcentaje de tiempo de ciclo utilizado por el CNC" .

ex:Parametro_PREPFREQ
    a ex:Parametro ;
    rdfs:label "PREPFREQ" ;
    ex:identificador "PREPFREQ" ;
    ex:textoExtracto "se puede aumentar el parámetro PREPFREQ para que aumente el suministro de bloques" ;
    ex:valor "Frecuencia de preparación de bloques" .

ex:Parametro_FEEDAVRG
    a ex:Parametro ;
    rdfs:label "FEEDAVRG" ;
    ex:identificador "FEEDAVRG" ;
    ex:textoExtracto "definir el parámetro FEEDAVRG con valor ꞏNoꞏ" ;
    ex:valor "Promedio de avance (configurable: Sí/No)" .

ex:ModoOperacion_HSC
    a ex:ModoOperacion ;
    rdfs:label "Modo HSC" ;
    ex:identificador "HSC" ;
    ex:textoExtracto "Para asegurar un suministro de bloques adecuado al HSC" ;
    ex:monitoreaParametro ex:Parametro_PREPTIMERATE ;
    ex:monitoreaParametro ex:Parametro_IPOTIMERATE ;
    ex:monitoreaParametro ex:Parametro_PERFRATE ;
    ex:monitoreaParametro ex:Parametro_DROPRATE ;
    ex:monitoreaParametro ex:Parametro_NCTIMERATE .