@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:V_G_PARLIMF a ex:Parametro ;
    rdfs:label "V.G.PARLIMF" ;
    ex:textoExtracto "Causa que limita el avance en el bloque en ejecución." ;
    ex:valor "Causa que limita el avance en el bloque en ejecución." .

ex:V_G_AXLIMF a ex:Parametro ;
    rdfs:label "V.G.AXLIMF" ;
    ex:textoExtracto "Número lógico del eje que limita el avance, en el bloque en ejecución." ;
    ex:valor "Número lógico del eje que limita el avance, en el bloque en ejecución." .

ex:V_G_PARLIMC a ex:Parametro ;
    rdfs:label "V.G.PARLIMC" ;
    ex:textoExtracto "Causa que limita el avance en la esquina, en el bloque actual." ;
    ex:valor "Causa que limita el avance en la esquina, en el bloque actual." .

ex:V_G_AXLIMC a ex:Parametro ;
    rdfs:label "V.G.AXLIMC" ;
    ex:textoExtracto "Número lógico del eje que limita el avance en la esquina, en el bloque en ejecución." ;
    ex:valor "Número lógico del eje que limita el avance en la esquina, en el bloque en ejecución." .

ex:V_G_LIMERROR a ex:Parametro ;
    rdfs:label "V.G.LIMERROR" ;
    ex:textoExtracto "Valor del error que desactiva las splines (modo CONTERROR)." ;
    ex:valor "Valor del error que desactiva las splines (modo CONTERROR)." .

ex:V_G_PATHFEED a ex:Parametro ;
    rdfs:label "V.G.PATHFEED" ;
    ex:textoExtracto "Avance teórico sobre la trayectoria." ;
    ex:valor "Avance teórico sobre la trayectoria." .

ex:V_G_FREAL a ex:Parametro ;
    rdfs:label "V.G.FREAL" ;
    ex:textoExtracto "Avance real sobre la trayectoria." ;
    ex:valor "Avance real sobre la trayectoria." .