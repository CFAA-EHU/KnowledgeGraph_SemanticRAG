@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaControlTandem a ns1:Sistema ;
    rdfs:label "Sistema de control del tándem" ;
    ns1:textoExtracto "El diagrama de bloques del sistema de control del tándem muestra el eje tándem maestro con su eje tándem esclavo." ;
    ns1:tieneComponente ns1:ControlTandem,
        ns1:EjeTandemEsclavo,
        ns1:EjeTandemMaestro,
        ns1:LazoPosicion,
        ns1:LazoVelocidad,
        ns1:SistemaControlNumerico .

ns1:ControlTandem a ns1:Sistema ;
    rdfs:label "Control de Tándem" ;
    ns1:textoExtracto "El control de tándem modifica la consigna de velocidad del eje maestro y del eje esclavo en función de la distribución de par y la precarga seleccionada." .

ns1:EjeTandemEsclavo a ns1:ComponenteMecanico ;
    rdfs:label "Eje Tándem Esclavo" ;
    ns1:textoExtracto "El diagrama de bloques del sistema de control del tándem muestra el eje tándem maestro con su eje tándem esclavo." .

ns1:EjeTandemMaestro a ns1:ComponenteMecanico ;
    rdfs:label "Eje Tándem Maestro" ;
    ns1:textoExtracto "El diagrama de bloques del sistema de control del tándem muestra el eje tándem maestro con su eje tándem esclavo." .

ns1:LazoPosicion a ns1:Sistema ;
    rdfs:label "Lazo de Posición" ;
    ns1:textoExtracto "El lazo de posición se cierra únicamente con la posición del eje maestro del tándem." .

ns1:LazoVelocidad a ns1:Sistema ;
    rdfs:label "Lazo de Velocidad" ;
    ns1:textoExtracto "La consigna de velocidad del eje tándem maestro se envía también al eje esclavo del tándem cerrando el lazo de velocidad." .

ns1:SistemaControlNumerico a ns1:Sistema ;
    rdfs:label "Sistema Control Numérico" ;
    ns1:textoExtracto "En el diagrama de bloques aparece una zona correspondiente al regulador y otra al control numérico, que engloba el lazo de posición y el control del tándem." .

