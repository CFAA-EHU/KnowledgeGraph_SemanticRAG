@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Parametro_CURVACC a ex:Parametro ;
    ex:identificador "CURVACC" ;
    ex:textoExtracto "La aceleración debida a la curvatura (parámetro CURVACC)" .

ex:Parametro_CURVJERK a ex:Parametro ;
    ex:identificador "CURVJERK" ;
    ex:textoExtracto "El jerk debido a la curvatura (parámetro CURVJERK)" .

ex:Parametro_CORNERACC a ex:Parametro ;
    ex:identificador "CORNERACC" ;
    ex:textoExtracto "La aceleración en la esquina (parámetro CORNERACC)" .

ex:Parametro_CORNERJERK a ex:Parametro ;
    ex:identificador "CORNERJERK" ;
    ex:textoExtracto "El jerk en la esquina (parámetro CORNERJERK)" .

ex:Variable_V_G_LIMERROR a ex:Parametro ;
    ex:identificador "V.G.LIMERROR" ;
    ex:textoExtracto "El error que comete el spline se puede consultar con la variable V.G.LIMERROR" .

ex:Variable_V_G_AXLMIC a ex:Parametro ;
    ex:identificador "V.G.AXLIMC" ;
    ex:textoExtracto "Consultar la variable V.G.AXLIMC para conocer cuál es el eje que está limitando el avance" .

ex:Variable_V_G_PARLIMC a ex:Parametro ;
    ex:identificador "V.G.PARLIMC" ;
    ex:textoExtracto "Consultar la variable V.G.PARLIMC para conocer la causa por la que este eje está limitando el avance" .

ex:Modo_CONTERROR a ex:ModoOperacion ;
    ex:identificador "CONTERROR" ;
    ex:textoExtracto "El error cordal en la esquina (modo CONTERROR)" .

ex:Modo_FAST a ex:ModoOperacion ;
    ex:identificador "FAST" ;
    ex:textoExtracto "Geometría de la esquina (modo FAST)" .