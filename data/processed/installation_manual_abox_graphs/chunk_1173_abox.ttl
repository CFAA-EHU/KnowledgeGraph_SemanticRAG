@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ValoresErrorHSC a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de valores de error en modo HSC"@es ;
    ex:textoExtracto "| Valor. | Significado. | --- | --- | -1 | El perfil generado no supera el error programado. El error programado no limita el avance máximo del eje. | Valor | Valor del error que desactiva las splines."@es ;
    ex:ilustradoEn ex:Pagina_630 .

ex:Parametro_ErrorSplines
    a ex:Parametro ;
    rdfs:label "Valor del error que desactiva las splines"@es ;
    ex:textoExtracto "Valor del error que desactiva las splines"@es ;
    ex:valor "-1" ;
    ex:documentadoEn ex:Tabla_ValoresErrorHSC .

ex:Variable_VGBLKN
    a ex:Parametro ;
    rdfs:label "V.G.BLKN (Última etiqueta ejecutada)"@es ;
    ex:textoExtracto "V.G.BLKN | Última etiqueta ejecutada (número)."@es ;
    ex:documentadoEn ex:Tabla_ValoresErrorHSC .

ex:Variable_VGLINEN
    a ex:Parametro ;
    rdfs:label "V.G.LINEN (Número de bloques ejecutados)"@es ;
    ex:textoExtracto "V.G.LINEN | Número de bloques de programa ejecutados o preparados."@es ;
    ex:documentadoEn ex:Tabla_ValoresErrorHSC .

ex:Variable_VGPATHFEED_1
    a ex:Parametro ;
    rdfs:label "V.G.PATHFEED (Avance teórico sobre la trayectoria, primera mención)"@es ;
    ex:textoExtracto "V.G.PATHFEED | Avance teórico sobre la trayectoria."@es ;
    ex:documentadoEn ex:Tabla_ValoresErrorHSC .

ex:Variable_VGPARLIMF
    a ex:Parametro ;
    rdfs:label "V.G.PARLIMF (Causa que limita el avance en el bloque)"@es ;
    ex:textoExtracto "V.G.PARLIMF | Causa que limita el avance en el bloque en ejecución."@es ;
    ex:documentadoEn ex:Tabla_ValoresErrorHSC .

ex:Variable_VGAXLIMF
    a ex:Parametro ;
    rdfs:label "V.G.AXLIMF (Eje que limita el avance en el bloque)"@es ;
    ex:textoExtracto "V.G.AXLIMF | Número lógico del eje que limita el avance, en el bloque en ejecución."@es ;
    ex:documentadoEn ex:Tabla_ValoresErrorHSC .

ex:Variable_VGPARLIMC
    a ex:Parametro ;
    rdfs:label "V.G.PARLIMC (Causa que limita el avance en la esquina)"@es ;
    ex:textoExtracto "V.G.PARLIMC | Causa que limita el avance en la esquina, en el bloque actual."@es ;
    ex:documentadoEn ex:Tabla_ValoresErrorHSC .

ex:Variable_VGAXLIMC
    a ex:Parametro ;
    rdfs:label "V.G.AXLIMC (Eje que limita el avance en la esquina)"@es ;
    ex:textoExtracto "V.G.AXLIMC | Número lógico del eje que limita el avance en la esquina, en el bloque en ejecución."@es ;
    ex:documentadoEn ex:Tabla_ValoresErrorHSC .

ex:Variable_VGLIMERROR
    a ex:Parametro ;
    rdfs:label "V.G.LIMERROR (Valor del error que desactiva splines en modo CONTERROR)"@es ;
    ex:textoExtracto "V.G.LIMERROR | Valor del error que desactiva las splines (modo CONTERROR)."@es ;
    ex:documentadoEn ex:Tabla_ValoresErrorHSC .

ex:Variable_VGPATHFEED_2
    a ex:Parametro ;
    rdfs:label "V.G.PATHFEED (Avance teórico sobre la trayectoria, segunda mención)"@es ;
    ex:textoExtracto "V.G.PATHFEED | Avance teórico sobre la trayectoria."@es ;
    ex:documentadoEn ex:Tabla_ValoresErrorHSC .

ex:Variable_VGFREAL
    a ex:Parametro ;
    rdfs:label "V.G.FREAL (Avance real sobre la trayectoria)"@es ;
    ex:textoExtracto "V.G.FREAL | Avance real sobre la trayectoria."@es ;
    ex:documentadoEn ex:Tabla_ValoresErrorHSC .

ex:ModoOperacion_HSC
    a ex:ModoOperacion ;
    rdfs:label "Modo HSC (High Speed Cutting)"@es ;
    ex:textoExtracto "proceso de análisis y ajuste del modo HSC"@es ;
    ex:monitoreaParametro ex:Parametro_ErrorSplines ;
    ex:monitoreaParametro ex:Variable_VGBLKN ;
    ex:monitoreaParametro ex:Variable_VGLINEN ;
    ex:monitoreaParametro ex:Variable_VGPATHFEED_1 ;
    ex:monitoreaParametro ex:Variable_VGPARLIMF ;
    ex:monitoreaParametro ex:Variable_VGAXLIMF ;
    ex:monitoreaParametro ex:Variable_VGPARLIMC ;
    ex:monitoreaParametro ex:Variable_VGAXLIMC ;
    ex:monitoreaParametro ex:Variable_VGLIMERROR ;
    ex:monitoreaParametro ex:Variable_VGPATHFEED_2 ;
    ex:monitoreaParametro ex:Variable_VGFREAL .