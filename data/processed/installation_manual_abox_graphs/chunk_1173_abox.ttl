@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaTandem a ns1:Sistema ;
    rdfs:label "Eje tándem" ;
    ns1:textoExtracto "una tracción entre ellos con el fin de eliminar la holgura piñón-cremallera cuando se encuentra en reposo." ;
    ns1:tieneComponente ns1:ComponenteElectrico_fadc0c2275,
        ns1:ControlPI,
        ns1:FiltroPrecarga .

ns1:ComponenteElectrico_fadc0c2275 a ns1:ComponenteElectrico ;
    rdfs:label "Motor esclavo del eje tándem",
        "Motor maestro del eje tándem" ;
    ns1:textoExtracto "los pares suministrados por los motores maestro y esclavo." .

ns1:ControlPI a ns1:ComponenteElectrico ;
    rdfs:label "Control PI del tándem" ;
    ns1:textoExtracto "PI cuya función es conseguir que cada motor realice el par que le corresponde." .

ns1:FiltroPrecarga a ns1:ComponenteElectrico ;
    rdfs:label "Filtro de precarga" ;
    ns1:textoExtracto "Filtro de primer orden cuyo fin es evitar la entrada de escalones de par al configurar la precarga." .

