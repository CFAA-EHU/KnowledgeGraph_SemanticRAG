@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:VGFREAL a ex:Sensor ;
    rdfs:label "V.G.FREAL" ;
    ex:textoExtracto "V.G.FREAL | Avance real sobre la trayectoria." .

ex:AnalisisTrayectoria a ex:TareaMantenimiento ;
    ex:textoExtracto "Analizar las diferentes variables de los ejes en la zona conflictiva, para determinar si hay un error en la trayectoria teórica, en el lazo de control o en la captación." .

ex:ZonaConflictiva a ex:Parametro ;
    ex:textoExtracto "las diferentes variables de los ejes en la zona conflictiva" .

ex:TrayectoriaTeorica a ex:Parametro ;
    ex:textoExtracto "error en la trayectoria teórica" .

ex:LazoControl a ex:Parametro ;
    ex:textoExtracto "error en el lazo de control" .

ex:Captacion a ex:Parametro ;
    ex:textoExtracto "error en la captación" .