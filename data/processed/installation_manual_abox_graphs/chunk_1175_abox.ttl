    ex:identificador "V.A.FILTEROUT.xn" ;
    ex:textoExtracto "Cota teórica del interpolador después del filtro." ;
    rdfs:label "Cota teórica del interpolador después del filtro." .

ex:Parametro_V_A_LOOPTPOS_xn a ex:Parametro ;
    ex:identificador "V.A.LOOPTPOS.xn" ;
    ex:textoExtracto "Cota teórica a la entrada del lazo de posición." ;
    rdfs:label "Cota teórica a la entrada del lazo de posición." .

ex:Parametro_V_A_LOOPPOS_xn a ex:Parametro ;
    ex:identificador "V.A.LOOPPOS.xn" ;
    ex:textoExtracto "Cota real a la entrada del lazo de posición." ;
