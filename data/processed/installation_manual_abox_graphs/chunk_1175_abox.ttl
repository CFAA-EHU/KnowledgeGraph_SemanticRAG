ex:Tabla1175 a ex:Tabla ;
    ex:tieneComponente ex:Parametro_V_A_IPOPOS_xn, ex:Parametro_V_A_ADDMANOF_xn, ex:Parametro_V_A_INDPOS_xn, ex:Parametro_V_A_FILTERIN_xn, ex:Parametro_V_A_FILTEROUT_xn, ex:Parametro_V_A_LOOPTPOS_xn, ex:Parametro_V_A_LOOPPOS_xn, ex:Parametro_V_A_TFEED_xn, ex:Parametro_V_A_FEED_xn, ex:Parametro_V_A_POSCMD_xn, ex:Parametro_V_A_FTEO_xn, ex:Parametro_V_A_POSNC_xn .