@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TandemNbDistribucionDelPar a ns1:Parametro ;
    rdfs:label "Tándem [nb]. Distribución del par" ;
    ns1:identificador "MPG.TORQDIST[nb]" ;
    ns1:textoExtracto "(V.)MPG.TORQDIST[nb] Tándem [nb]. Distribución del par | R | R | R |" .

