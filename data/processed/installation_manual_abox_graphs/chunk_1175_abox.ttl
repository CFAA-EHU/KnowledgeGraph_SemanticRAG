    ex:identificador "V.A.INDPOS.xn" ;
    ex:textoExtracto "Cota teórica del interpolador independiente." ;
    rdfs:label "Cota teórica del interpolador independiente." .

ex:Parametro_V_A_FILTERIN_xn a ex:Parametro ;
    ex:identificador "V.A.FILTERIN.xn" ;
    ex:textoExtracto "Cota teórica del interpolador antes del filtro." ;
    rdfs:label "Cota teórica del interpolador antes del filtro." .

