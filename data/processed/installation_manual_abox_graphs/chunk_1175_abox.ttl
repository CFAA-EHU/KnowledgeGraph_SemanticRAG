ex:Parametro_V_A_TFEED_xn a ex:Parametro ;
    ex:identificador "V.A.TFEED.xn" ;
    ex:textoExtracto "Valor instantáneo teórico de la velocidad a la entrada del lazo de posición." ;
    rdfs:label "Valor instantáneo teórico de la velocidad a la entrada del lazo de posición." .

