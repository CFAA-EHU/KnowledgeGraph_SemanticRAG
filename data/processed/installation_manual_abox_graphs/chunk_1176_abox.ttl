@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:MPG_IMOVEMACH a ex:ComponenteElectrico ;
    ex:textoExtracto "YES INDEPENDENT (V.)A.INDPOS.xn INTERPOLATOR (V.)A.ITPOS.xn NO V.A.MANOF.1 V.A.ADDMANOF.1 (V.)G.PATHFEED (V.)A.FILTERIN.xn (V.)A.FILTEROUT.xn Velocity command axis 1 (V.)A.IPOPOS.1 SLOPE INTERPOLATOR TRANSFOR FILTER Movement block axis 2 axis 3 (V.)A.ACTACF.xn (V.)A.ACTFFW.xn (V.)MPA.LOOPCHG.xn (V.)G.ANAO[n] +/- Analog V.A.PLCOF.xn (V.)A.LOOPTPOS.xn (V.)A.TFEED.xn (V.)A.FLWE.xn (V.)A.FILTEROUT.xn + + + (V.)MPG.PROGAIN (V.)MP + A / . - LOOPCHG.xn (V.)A.FTEO.xn Sercos Vel. - (V.)A.TPOS.xn + (V.)A.POSCMD.xn - -COMP -DELTA Sercos Pos. DRIVE V.A.PLCOF.xn (V.)MPA.AXISCHG.xn (V.)A.POSNC.xn +/- Analog V.A.LOOPPOS.xn (V.)MPA.AXISCHG.xn (V.)A.POS.xn- + V.A.FEED.xn (V.)A.POSNC.xn COMP +/- DELTA Sercos Vel. (V.)A.POSNC.xn DELTA Sercos Pos." .

ex:FILTER a ex:ComponenteElectrico ;
    ex:textoExtracto "SLOPE INTERPOLATOR TRANFOR FILTER" .

ex:DRIVE a ex:ComponenteElectrico ;
    ex:textoExtracto "DRIVE" .

ex:INTERPOLATOR a ex:Componente ;
    ex:textoExtracto "INDEPENDENT (V.)A.INDPOS.xn INTERPOLATOR (V.)A.ITPOS.xn NO" .

ex:COMPENSACION_COTA a ex:Componente ;
    ex:textoExtracto "COMP Compensación de cota debida a la compensación de husillo o a la compensación cruzada." .