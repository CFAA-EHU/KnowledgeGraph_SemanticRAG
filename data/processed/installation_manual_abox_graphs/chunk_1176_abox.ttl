@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Esquema_LazosVariables_633
    a                       ex:Esquema ;
    rdfs:label              "Esquema de lazos y variables de control (pág. 633)"@es ;
    ex:textoExtracto         "| (V.)MPG.IMOVEMACH YES INDEPENDENT (V.)A.INDPOS.xn INTERPOLATOR (V.)A.ITPOS.xn NO V.A.MANOF.1 V.A.ADDMANOF.1 (V.)G.PATHFEED (V.)A.FILTERIN.xn (V.)A.FILTEROUT.xn Velocity command axis 1 (V.)A.IPOPOS.1 SLOPE INTERPOLATOR TRANSFOR FILTER Movement block axis 2 axis 3 (V.)A.ACTACF.xn (V.)A.ACTFFW.xn (V.)MPA.LOOPCHG.xn (V.)G.ANAO[n] +/- Analog V.A.PLCOF.xn (V.)A.LOOPTPOS.xn (V.)A.TFEED.xn (V.)A.FLWE.xn (V.)A.FILTEROUT.xn + + + (V.)MPG.PROGAIN (V.)MPA.LOOPCHG.xn (V.)A.FTEO.xn Sercos Vel. - (V.)A.TPOS.xn + (V.)A.POSCMD.xn - -COMP -DELTA Sercos Pos. DRIVE V.A.PLCOF.xn (V.)MPA.AXISCHG.xn (V.)A.POSNC.xn +/- Analog V.A.LOOPPOS.xn (V.)MPA.AXISCHG.xn (V.)A.POS.xn- + V.A.FEED.xn (V.)A.POSNC.xn COMP +/- DELTA Sercos Vel. (V.)A.POSNC.xn DELTA Sercos Pos." ;
    ex:identificador         "13.5" .

ex:ComponenteElectrico_FiltroEntrada
    a                       ex:ComponenteElectrico ;
    rdfs:label              "Filtro de entrada (A.FILTERIN.xn)"@es ;
    ex:textoExtracto         "(V.)A.FILTERIN.xn" ;
    ex:detalladoEnEsquema    ex:Esquema_LazosVariables_633 .

ex:ComponenteElectrico_FiltroSalida
    a                       ex:ComponenteElectrico ;
    rdfs:label              "Filtro de salida (A.FILTEROUT.xn)"@es ;
    ex:textoExtracto         "(V.)A.FILTEROUT.xn" ;
    ex:detalladoEnEsquema    ex:Esquema_LazosVariables_633 .

ex:Sistema_ControlMovimiento
    a                       ex:Sistema ;
    rdfs:label              "Sistema de control de movimiento (interpolador y lazos)"@es ;
    ex:textoExtracto         "INDEPENDENT (V.)A.INDPOS.xn INTERPOLATOR (V.)A.ITPOS.xn [...] COMP Compensación de cota debida a la compensación de husillo o a la compensación cruzada." ;
    ex:compuestoPor          ex:ComponenteElectrico_FiltroEntrada ;
    ex:compuestoPor          ex:ComponenteElectrico_FiltroSalida ;
    ex:detalladoEnEsquema    ex:Esquema_LazosVariables_633 .

ex:Parametro_VelocidadEje1
    a                       ex:Parametro ;
    rdfs:label              "Velocidad comando eje 1 (A.IPOPOS.1)"@es ;
    ex:textoExtracto         "(V.)A.IPOPOS.1 Velocity command axis 1" ;
    ex:monitoreaParametro    ex:Sistema_ControlMovimiento ;
    ex:documentadoEn         ex:Esquema_LazosVariables_633 .

ex:Parametro_CompensacionCota
    a                       ex:Parametro ;
    rdfs:label              "Compensación de cota (COMP)"@es ;
    ex:textoExtracto         "COMP Compensación de cota debida a la compensación de husillo o a la compensación cruzada." ;
    ex:monitoreaParametro    ex:Sistema_ControlMovimiento ;
    ex:documentadoEn         ex:Esquema_LazosVariables_633 .