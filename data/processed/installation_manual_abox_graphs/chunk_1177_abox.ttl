@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AjusteDelTandem_061d73321f a ns1:TareaMantenimiento ;
    rdfs:label "Ajuste del tándem",
        "Personal Técnico Autorizado" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "Se realizará un reajuste posterior con los dos motores juntos." .

ns1:CNC8070_00710b981a a ns1:Sistema ;
    rdfs:label "CNC 8070",
        "Máquina tándem" ;
    ns1:controla ns1:MaquinaBrochadoraElectromecanicaExteriorA218 ;
    ns1:textoExtracto "En general, una máquina tándem posee frecuencia de resonancia baja; por lo tanto, el CNC debe generar consignas de posición sin componentes frecuenciales superiores a la frecuencia de resonancia." .

ns1:Componente_0ee21c1e82 a ns1:Componente ;
    rdfs:label "Motor principal" ;
    ns1:textoExtracto "No realizar desplazamientos bruscos ya que el segundo motor está siendo arrastrado por el primero. En esta situación cualquier aceleración o deceleración que se produzca le obliga a pasar de un lado al otro de la holgura sufriendo golpes." .

ns1:ParametroSP43 a ns1:Parametro ;
    rdfs:label "Parámetro SP43" ;
    ns1:textoExtracto "Adviértase que una inversión en el sentido de giro de un motor invierte el sentido del par y por tanto será necesario cambiar el signo de sus valores monitorizados mediante los parámetros SP43 y TP85 del regulador." .

ns1:ParametroTP85 a ns1:Parametro ;
    rdfs:label "Parámetro TP85" ;
    ns1:textoExtracto "Adviértase que una inversión en el sentido de giro de un motor invierte el sentido del par y por tanto será necesario cambiar el signo de sus valores monitorizados mediante los parámetros SP43 y TP85 del regulador." .

