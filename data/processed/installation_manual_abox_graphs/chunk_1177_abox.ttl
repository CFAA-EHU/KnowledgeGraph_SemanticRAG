@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_ITPOS_xn
    a               ex:Parametro ;
    rdfs:label      "ITPOS.xn" ;
    ex:textoExtracto "COMP Compensación de cota debida a la compensación de husillo o a la compensación cruzada."@es ;
    ex:valor        "COMP (Compensación de cota)"@es .

ex:Parametro_DELTA
    a               ex:Parametro ;
    rdfs:label      "DELTA" ;
    ex:textoExtracto "DELTA Decalaje en el encendido para mantener la cota del apagado."@es ;
    ex:valor        "Decalaje en el encendido"@es .

ex:Tabla_ParametrosSercosPos a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de parámetros Sercos Pos (Sección 13.5)" ;
    ex:textoExtracto "Sercos Pos. | DELTA | ... | INDEPENDENT INTERPOLATOR | (V.)A.ITPOS.xn"@es ;
    ex:tieneComponente ex:Parametro_ITPOS_xn ;
    ex:tieneComponente ex:Parametro_DELTA .