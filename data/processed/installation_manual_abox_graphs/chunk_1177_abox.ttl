@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:COMP_CompensaciónCota ex:textoExtracto "COMP Compensación de cota debida a la compensación de husillo o a la compensación cruzada." ;
    a ex:Parametro ;
    ex:identificador "COMP" ;
    rdfs:label "Compensación de cota" .

ex:DELTA_DecalajeEncendido ex:textoExtracto "DELTA Decalaje en el encendido para mantener la cota del apagado." ;
    a ex:Parametro ;
    ex:identificador "DELTA" ;
    rdfs:label "Decalaje en el encendido" .

ex:INDEPENDENT_Interpolator ex:textoExtracto "INDEPENDENT INTERPOLATOR" ;
    a ex:ModoOperacion ;
    rdfs:label "Interpolador independiente" .