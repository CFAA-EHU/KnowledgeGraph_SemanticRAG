@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AjusteDelTandem a ns1:TareaMantenimiento ;
    rdfs:label "Ajuste del Tándem" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "Proceso de ajuste del tándem." .

ns1:DistribucionDePar_599604b44b a ns1:Parametro ;
    rdfs:label "Distribución de par" ;
    ns1:identificador "TORQDIST" ;
    ns1:monitoreaParametro ns1:SistemaTandem ;
    ns1:textoExtracto "Según el parámetro \"TORQDIST\" (p.e para una distribución del 50%, la mitad del par)." .

ns1:Parametro_57bb7ed26d a ns1:Parametro ;
    rdfs:label "Precarga" ;
    ns1:identificador "PRELOAD" ;
    ns1:monitoreaParametro ns1:SistemaTandem ;
    ns1:textoExtracto "Según los parámetros \"TORQDIST\" y \"PRELOAD\"." .

ns1:ComponenteElectrico_fe2686a09d a ns1:ComponenteElectrico ;
    rdfs:label "Motor Principal 1",
        "Motor Principal 2" ;
    ns1:textoExtracto "Cada motor hace el par que les corresponde, según el parámetro \"TORQDIST\"." .

ns1:SistemaTandem a ns1:Sistema ;
    rdfs:label "Sistema Tándem" ;
    ns1:textoExtracto "Habilitar el tándem con ambos motores. En primer lugar, deshabilitar el PI del tándem, suministrar potencia y comprobar que el sistema está en reposo." ;
    ns1:tieneComponente ns1:ComponenteElectrico_fe2686a09d .

