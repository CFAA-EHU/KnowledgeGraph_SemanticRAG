@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SubrutinaCambioHerramienta a ex:TareaMantenimiento ;
    rdfs:label "subrutina asociada al cambio de herramienta"@es ;
    ex:textoExtracto "subrutina asociada al cambio de herramienta"@es .

ex:SubrutinaBusquedaReferencia a ex:TareaMantenimiento ;
    rdfs:label "subrutina asociada a la búsqueda de referencia"@es ;
    ex:textoExtracto "subrutina asociada a la búsqueda de referencia"@es .

ex:CNC a ex:Maquina ;
    rdfs:label "CNC"@es ;
    ex:textoExtracto "El CNC dispone de una serie de subrutinas que, en función de la configuración de la máquina, deben estar definidas"@es ;
    ex:compuestoPor ex:SubrutinaCambioHerramienta, ex:SubrutinaBusquedaReferencia .