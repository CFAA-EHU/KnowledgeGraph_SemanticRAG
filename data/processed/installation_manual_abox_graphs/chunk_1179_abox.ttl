        ns1:NumeroDeLaSalidaAnalogicaAsociadaAlEje_49b10c2374,
        ns1:TipoDeEntradaDeCaptacionDelEje_218ba37db9 .

ns1:NumeroDeLaEntradaDeCaptacionDelEje_f6ca2329df a ns1:Parametro ;
    rdfs:label "Número de la entrada de captación del eje" ;
    ns1:identificador "COUNTERID" ;
    ns1:textoExtracto "COUNTERID | Número de la entrada de captación del eje." .

ns1:NumeroDeLaSalidaAnalogicaAsociadaAlEje_49b10c2374 a ns1:Parametro ;
    rdfs:label "Número de la salida analógica asociada al eje" ;
    ns1:identificador "ANAOUTID" ;
