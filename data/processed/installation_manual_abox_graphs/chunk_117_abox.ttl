@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:VCOMPFILE a ex:Parametro ;
    rdfs:label "VCOMPFILE" ;
    ex:identificador "VCOMPFILE" ;
    ex:textoExtracto "VCOMPFILE Archivo con los datos de la compensación volumétrica."@es .

ex:MPG_VCOMPFILE_tbl a ex:Parametro ;
    rdfs:label "(V.)MPG.VCOMPFILE[tbl]" ;
    ex:identificador "(V.)MPG.VCOMPFILE[tbl]" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.VCOMPFILE[tbl] Parámetro incluido en la tabla VOLCOMP."@es .

ex:VOLCOMP a ex:Tabla ;
    ex:textoExtracto "Parámetro incluido en la tabla VOLCOMP."@es .

ex:INCHES a ex:Parametro ;
    rdfs:label "INCHES" ;
    ex:identificador "INCHES" ;
    ex:textoExtracto "Las unidades de los datos del archivo (milímetros o pulgadas) deben ser las definidas en el CNC (parámetro INCHES)."@es .

ex:CompensacionVolumetricaMediaGrande a ex:Parametro ;
    rdfs:label "Compensación volumétrica media y grande" ;
    ex:textoExtracto "Compensación volumétrica media y grande."@es .

ex:CompensacionVolumetricaBasica a ex:Parametro ;
    rdfs:label "Compensación volumétrica básica" ;
    ex:textoExtracto "Compensación volumétrica básica."@es .

ex:FormatoCSV a ex:Parametro ;
    rdfs:label "formato csv" ;
    ex:textoExtracto "El archivo con los datos a compensar será un archivo de texto (formato csv)."@es .