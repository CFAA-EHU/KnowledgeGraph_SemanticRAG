@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaCompensacionCruzada a ns1:Tabla ;
    rdfs:label "Tablas de compensación cruzada"@es ;
    ns1:ilustra ns1:BusquedaDeReferenciaNecesariaParaCompensar,
        ns1:CompensacionBidireccional,
        ns1:EjeQueAlMoverseGeneraVariacionesMaestro,
        ns1:EjeQueSufreVariacionesCompensado,
        ns1:MetodoDeCompensacion,
        ns1:NumeroDePuntosDeLaTabla ;
    ns1:textoExtracto "Sección 2.3.16 Tablas de compensación cruzada." .

ns1:BusquedaDeReferenciaNecesariaParaCompensar a ns1:Parametro ;
    rdfs:label "Búsqueda de referencia necesaria para compensar"@es ;
    ns1:identificador "REFNEED" ;
    ns1:textoExtracto "REFNEED | Búsqueda de referencia necesaria para compensar." .

ns1:CompensacionBidireccional a ns1:Parametro ;
    rdfs:label "Compensación bidireccional"@es ;
    ns1:identificador "BIDIR" ;
    ns1:textoExtracto "BIDIR | Compensación bidireccional." .

ns1:EjeQueAlMoverseGeneraVariacionesMaestro a ns1:Parametro ;
    rdfs:label "Eje que al moverse genera variaciones (maestro)"@es ;
    ns1:identificador "MOVAXIS" ;
    ns1:textoExtracto "MOVAXIS | Eje que al moverse genera variaciones (maestro)." .

ns1:EjeQueSufreVariacionesCompensado a ns1:Parametro ;
    rdfs:label "Eje que sufre variaciones (compensado)"@es ;
    ns1:identificador "COMPAXIS" ;
    ns1:textoExtracto "COMPAXIS | Eje que sufre variaciones (compensado)." .

ns1:MetodoDeCompensacion a ns1:Parametro ;
    rdfs:label "Método de compensación"@es ;
    ns1:identificador "TYPCROSS" ;
    ns1:textoExtracto "TYPCROSS | Método de compensación." .

ns1:NumeroDePuntosDeLaTabla a ns1:Parametro ;
    rdfs:label "Número de puntos de la tabla"@es ;
    ns1:identificador "NPCROSS" ;
    ns1:textoExtracto "NPCROSS | Número de puntos de la tabla." .

