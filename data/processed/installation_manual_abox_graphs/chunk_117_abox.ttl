@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaVOLCOMP a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla VOLCOMP"@es ;
    ex:textoExtracto "Parámetro incluido en la tabla VOLCOMP. Compensación volumétrica media y grande."@es ;
    ex:identificador "VOLCOMP" .

ex:Parametro_VCOMPFILE
    a ex:Parametro ;
    rdfs:label "VCOMPFILE"@es ;
    ex:textoExtracto "VCOMPFILE: Archivo con los datos de la compensación volumétrica. Variable asociada: (V.)MPG.VCOMPFILE[tbl]."@es ;
    ex:identificador "VCOMPFILE" ;
    ex:documentadoEn ex:TablaVOLCOMP .

ex:Parametro_INCHES
    a ex:Parametro ;
    rdfs:label "INCHES"@es ;
    ex:textoExtracto "Las unidades de los datos del archivo (milímetros o pulgadas) deben ser las definidas en el CNC (parámetro INCHES)."@es ;
    ex:identificador "INCHES" .

ex:ArchivoCompensacionVolumetrica
    a ex:Componente ;
    rdfs:label "Archivo de compensación volumétrica (CSV)"@es ;
    ex:textoExtracto "El archivo con los datos a compensar será un archivo de texto (formato csv)."@es ;
    ex:monitoreaParametro ex:Parametro_VCOMPFILE ;
    ex:monitoreaParametro ex:Parametro_INCHES .