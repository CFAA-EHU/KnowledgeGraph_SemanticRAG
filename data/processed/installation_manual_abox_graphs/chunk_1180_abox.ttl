@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IndicarLaEntradaDeCaptacionAUtilizarONumeroDeRegulador a ns1:Parametro ;
    rdfs:label "Indicar la entrada de captación a utilizar o número de regulador" ;
    ns1:identificador "COUNTERID" ;
    ns1:textoExtracto "en el parámetro COUNTERID hay que indicar cuál es la entrada de captación a utilizar (si la captación es local o remota) o el número de regulador." .

ns1:NumeroDeSalidaAnalogicaYReguladorAUtilizar a ns1:Parametro ;
    rdfs:label "Número de salida analógica y regulador a utilizar" ;
    ns1:identificador "ANAOUTID" ;
    ns1:textoExtracto "En este caso, este parámetro indica cuál es el número de la salida analógica y el regulador a utilizar." ;
    ns1:valor """101 - 132
201 - 232""" .

ns1:Parametro_abd242a7d2 a ns1:Parametro ;
    rdfs:label "Parámetro del regulador Sercos" ;
    ns1:identificador "PP5" ;
    ns1:textoExtracto "se debe parametrizar el parámetro del regulador PP5=-0,0001." .

ns1:ReguladorSercos_bf55dfac2d a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos" ;
    ns1:textoExtracto "Cuando se utiliza la entrada de captación de un regulador Sercos, no se permite realizar la búsqueda de referencia." .

ns1:SeleccionDeEntradaDeCaptacionParaUnEjeAnalogico a ns1:Parametro ;
    rdfs:label "Selección de entrada de captación para un eje analógico" ;
    ns1:identificador "COUNTERTYPE" ;
    ns1:textoExtracto "La selección se realiza mediante el parámetro COUNTERTYPE." .

