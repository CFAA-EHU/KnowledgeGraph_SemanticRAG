@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MPROGNAME a ex:Parametro ;
    rdfs:label "Parámetro MPROGNAME de la tabla de funciones M" ;
    ex:textoExtracto "Nombre: Parámetro MPROGNAME de la tabla de funciones M. Canales: Subrutina común a todos los canales. Path: ..\\Mtb\\Sub." ;
    ex:identificador "MPROGNAME" .

ex:REFPSUB a ex:Parametro ;
    rdfs:label "Parámetro general REFPSUB" ;
    ex:textoExtracto "Nombre: Parámetro general REFPSUB. Canales: Subrutina por canal. Path: ..\\Mtb\\Sub" ;
    ex:identificador "REFPSUB" .

ex:OEMSUB a ex:Parametro ;
    rdfs:label "Parámetro general OEMSUB(G180) a OEMSUB(G189)" ;
    ex:textoExtracto "Nombre: Parámetro general OEMSUB(G180) a OEMSUB(G189). Canales: Subrutina por canal Path: ..\\Mtb\\Sub." ;
    ex:identificador "OEMSUB" .

ex:TablaFuncionesM a ex:Tabla ;
    rdfs:label "Tabla de funciones M" ;
    ex:textoExtracto "Parámetro MPROGNAME de la tabla de funciones M" ;
    ex:compuestoPor ex:MPROGNAME .

ex:SubrutinaG74 a ex:TareaMantenimiento ;
    rdfs:label "Subrutina asociada a la función G74" ;
    ex:textoExtracto "Subrutina asociada a la función G74." ;
    ex:ejecutadoPor ex:MPROGNAME .

ex:SubrutinaG180G189 a ex:TareaMantenimiento ;
    rdfs:label "Subrutinas OEM asociadas a las funciones G180 a G189" ;
    ex:textoExtracto "Subrutinas OEM asociadas a las funciones G180 a G189." ;
    ex:ejecutadoPor ex:OEMSUB .