@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeLaEntradaDeCaptacionDelRegulador a ns1:Parametro ;
    rdfs:label "Número de la entrada de captación del regulador",
        "Número de la entrada de captación local",
        "Número de la entrada de captación remota" ;
    ns1:identificador "COUNTERID" ;
    ns1:textoExtracto "COUNTERID | Número de la entrada de captación." .

ns1:TipoDeContadorLocal a ns1:Parametro ;
    rdfs:label "Tipo de contador local",
        "Tipo de contador regulador",
        "Tipo de contador remoto" ;
    ns1:identificador "COUNTERTYPE" ;
    ns1:textoExtracto "COUNTERTYPE | Local.",
        "COUNTERTYPE | Regulador.",
        "COUNTERTYPE | Remoto." .

