@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_1a35bacf03 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "En estos casos, ambos motores están controlados por el mismo regulador y para el CNC sólo hay una entrada de captación y una salida analógica." .

ns1:IdentificadorDeSalidaAnalogica a ns1:Parametro ;
    rdfs:label "Identificador de salida analógica" ;
    ns1:identificador "ANAOUTID" ;
    ns1:textoExtracto "Para utilizar la misma salida analógica, el parámetro ANAOUTID de ambos ejes también debe ser igual." .

ns1:IdentificadorDelContador a ns1:Parametro ;
    rdfs:label "Identificador del contador" ;
    ns1:identificador "COUNTERID" ;
    ns1:textoExtracto "Para utilizar la misma entrada de captación, los parámetros COUNTERTYPE y COUNTERID de ambos ejes debe ser iguales." .

ns1:TipoDeCaptacion_846ab96f70 a ns1:Parametro ;
    rdfs:label "Tipo de captación" ;
    ns1:identificador "ABSFEEDBACK" ;
    ns1:textoExtracto "| ABSFEEDBACK | Tipo de captación.|" .

ns1:TipoDeContador a ns1:Parametro ;
    rdfs:label "Tipo de contador" ;
    ns1:identificador "COUNTERTYPE" ;
    ns1:textoExtracto "Para utilizar la misma entrada de captación, los parámetros COUNTERTYPE y COUNTERID de ambos ejes debe ser iguales." .

