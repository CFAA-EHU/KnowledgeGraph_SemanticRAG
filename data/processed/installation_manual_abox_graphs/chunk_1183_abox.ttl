@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoOperacion_Setup
    a               ex:ModoOperacion ;
    rdfs:label      "Modo SETUP (puesta a punto)"@es ;
    ex:textoExtracto
        "Con el CNC en modo SETUP (puesta a punto), las rutinas OEM [...] se cargan en la memoria RAM durante la preparación de bloques."@es .

ex:Sistema_CNC
    a               ex:Sistema ;
    rdfs:label      "CNC"@es ;
    ex:textoExtracto
        "el CNC comprueba si está cargada en memoria RAM, y si no lo está y hay espacio, la carga. [...] el CNC las borra de la memoria RAM."@es ;
    ex:tieneComponente
        ex:ComponenteElectrico_MemoriaRAM ;
    ex:habilitadoPor
        ex:ModoOperacion_Setup .

ex:ComponenteElectrico_MemoriaRAM
    a               ex:ComponenteElectrico ;
    rdfs:label      "Memoria RAM"@es ;
    ex:textoExtracto
        "las rutinas OEM [...] se cargan en la memoria RAM durante la preparación de bloques. [...] el CNC las borra de la memoria RAM."@es .