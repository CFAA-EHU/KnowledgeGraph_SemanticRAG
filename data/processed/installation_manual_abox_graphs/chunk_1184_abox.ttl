@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaMultieje a ns1:Sistema ;
    rdfs:label "Sistema Multieje" ;
    ns1:textoExtracto "Grupo multieje compuesto por dos ejes, cada uno controlado por un motor." ;
    ns1:tieneComponente ns1:ComponenteElectrico_43e4ad0873,
        ns1:ReguladorMultieje .

ns1:ComponenteElectrico_43e4ad0873 a ns1:ComponenteElectrico ;
    rdfs:label "Motor A1",
        "Motor A2" ;
    ns1:textoExtracto "Axis A1 Axis A2 Grupo multieje compuesto por dos ejes, cada uno controlado por un motor." .

ns1:ReguladorMultieje a ns1:ComponenteElectrico ;
    rdfs:label "Regulador multieje" ;
    ns1:textoExtracto "Un grupo multieje consiste en varios ejes o cabezales Sercos controlados por un único regulador, aunque no de forma simultánea." .

