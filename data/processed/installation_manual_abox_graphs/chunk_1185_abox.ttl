@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ModoAutomatico a ex:ModoOperacion ;
    ex:textoExtracto "desde el modo automático" .

ex:TeclaSTART a ex:InterfazUsuario ;
    ex:textoExtracto "pulsar la tecla [START]" .

ex:CNC a ex:Sistema ;
    ex:textoExtracto "el CNC" .

ex:SubrutinaStart a ex:TareaMantenimiento ;
    ex:textoExtracto "subrutina asociada al start" ;
    ex:textoExtracto "el CNC la ejecuta inmediatamente después de pulsar la tecla [START]" ;
    ex:textoExtracto "el CNC muestra en la barra general de estado el nombre de la subrutina" ;
    ex:textoExtracto "ejecuta la subrutina como un bloque único" .

ex:BarraEstadoGeneral a ex:InterfazUsuario ;
    ex:textoExtracto "el CNC muestra en la barra general de estado el nombre de la subrutina" .