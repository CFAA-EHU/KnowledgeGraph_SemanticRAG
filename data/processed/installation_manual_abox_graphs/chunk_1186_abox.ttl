@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_8dbfb2dcaa a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:EjeOperativo ;
    ns1:textoExtracto "el CNC ejecuta la búsqueda de referencia como si el eje fuera analógico" .

ns1:ModoSercosVelocidad a ns1:ModoOperacion ;
    rdfs:label "modo Sercos velocidad" ;
    ns1:textoExtracto "el eje sólo podrá operar en modo Sercos velocidad" .

ns1:BusquedaReferencia a ns1:AccionProhibida ;
    rdfs:label "Búsqueda de Referencia" ;
    ns1:textoExtracto "el CNC ejecuta la búsqueda de referencia como si el eje fuera analógico; el regulador desconoce que hay una búsqueda de referencia en marcha y no" .

ns1:EjeOperativo a ns1:ComponenteMecanico ;
    rdfs:label "Eje Operativo" ;
    ns1:textoExtracto "Si la captación externa (captación directa) del eje está conectada a una entrada de contaje local o remota, el eje sólo podrá operar en modo Sercos velocidad." ;
    ns1:tieneComponente ns1:BusquedaReferencia .

