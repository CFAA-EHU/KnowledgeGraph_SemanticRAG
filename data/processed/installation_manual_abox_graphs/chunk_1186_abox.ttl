@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PROGRAM_START a ex:TareaMantenimiento ;
    rdfs:label "PROGRAM_START" ;
    ex:textoExtracto "Nombre y ubicación de la subrutina. El nombre de la subrutina debe ser PROGRAM_START (sin extensión) y estará guardada en la carpeta ..\Users\Sub." .

ex:PROGRAM_START_C1 a ex:TareaMantenimiento ;
    rdfs:label "PROGRAM_START_C1" ;
    ex:textoExtracto "Nombre. | Canal. | PROGRAM_START_C1 | Canal 1." .

ex:PROGRAM_START_C2 a ex:TareaMantenimiento ;
    rdfs:label "PROGRAM_START_C2" ;
    ex:textoExtracto "Nombre. | Canal. | PROGRAM_START_C2 | Canal 2." .

ex:PROGRAM_START_C3 a ex:TareaMantenimiento ;
    rdfs:label "PROGRAM_START_C3" ;
    ex:textoExtracto "Nombre. | Canal. | PROGRAM_START_C3 | Canal 3." .

ex:PROGRAM_START_C4 a ex:TareaMantenimiento ;
    rdfs:label "PROGRAM_START_C4" ;
    ex:textoExtracto "Nombre. | Canal. | PROGRAM_START_C4 | Canal 4." .

ex:Tabla_14_2_1 a ex:Tabla ;
    ex:textoExtracto "Nombre. | Canal. | --- | --- | PROGRAM_START PROGRAM_START_C1 | Canal 1. El CNC admite los dos nombres para la subrutina asociada al primer canal; si existen ambas subrutinas, el CNC ejecuta PROGRAM_START. | PROGRAM_START_C2 | Canal 2. | PROGRAM_START_C3 | Canal 3. | PROGRAM_START_C4 | Canal 4." ;
    ex:tieneComponente ex:PROGRAM_START, ex:PROGRAM_START_C1, ex:PROGRAM_START_C2, ex:PROGRAM_START_C3, ex:PROGRAM_START_C4 .