@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_8dbfb2dcaa a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC ejecuta la búsqueda de referencia como si el eje fuera analógico." .

ns1:PrimerEjeDefinidoEnElGrupo a ns1:Parametro ;
    rdfs:label "Primer eje definido en el grupo" ;
    ns1:identificador "MULAXISNAME_1" ;
    ns1:textoExtracto "El regulador controla el eje maestro del grupo, el primer eje definido en el grupo (parámetro MULAXISNAME_1)." .

ns1:SetPorDefectoDelEje a ns1:Parametro ;
    rdfs:label "Set por defecto del eje" ;
    ns1:identificador "DEFAULTSET" ;
    ns1:textoExtracto "El CNC asume el set por defecto del eje (parámetro DEFAULTSET)." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "La selección del eje que gobierna el regulador se realiza desde el PLC (marca SWITCH(axis))." .

ns1:TiempoDeEsperaAntesDeDarErrorPorNoTenerLaMarcaSWITCHActiva a ns1:Parametro ;
    rdfs:label "Tiempo de espera antes de dar error por no tener la marca SWITCH activa" ;
    ns1:identificador "DWELL" ;
    ns1:textoExtracto "Los ejes utilizan el parámetro DWELL como tiempo de espera antes de dar error por no tener la marca SWITCH activa." .

