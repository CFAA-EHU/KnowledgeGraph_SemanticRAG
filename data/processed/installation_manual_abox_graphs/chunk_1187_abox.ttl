@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SubrutinaReset_14_3
    a                     ex:ModoOperacion ;
    rdfs:label            "Subrutina asociada al reset"@es ;
    ex:textoExtracto      "En cada canal, el reset puede tener una subrutina asociada, que se ejecuta al pulsar la tecla [RESET] del panel de mando o cuando el PLC activa la marca RESETIN. Esta subrutina permite, por ejemplo, poner unas condiciones iniciales diferentes de las que fija el reset o condicionadas a la configuración de la máquina, activar operaciones/modos que deshabilita el reset, etc."@es ;
    ex:identificador      "14.3" .

ex:InterfazUsuario_PanelMando
    a                     ex:InterfazUsuario ;
    rdfs:label            "Panel de mando"@es ;
    ex:textoExtracto      "tecla [RESET] del panel de mando"@es .

ex:TeclaReset
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Tecla RESET"@es ;
    ex:textoExtracto      "tecla [RESET] del panel de mando"@es ;
    ex:tieneComponente     ex:InterfazUsuario_PanelMando .

ex:MarcaResetIN
    a                     ex:Parametro ;
    rdfs:label            "RESETIN"@es ;
    ex:textoExtracto      "cuando el PLC activa la marca RESETIN"@es ;
    ex:identificador      "RESETIN" .

ex:ModoEjecucionSimulada
    a                     ex:ModoOperacion ;
    rdfs:label            "Modo ejecución simulada (Funciones G)"@es ;
    ex:textoExtracto      "El CNC ejecuta la subrutina con la opción 'Funciones G' del modo ejecución simulada"@es .

ex:FuncionG41 a ex:Tabla ;
     a                     ex:Parametro ;
    rdfs:label            "Compensación de radio (G41)"@es ;
    ex:textoExtracto      "La ejecución tiene en cuenta la compensación de radio (funciones G41, G42)"@es ;
    ex:identificador      "G41" .

ex:FuncionG42 a ex:Tabla ;
     a                     ex:Parametro ;
    rdfs:label            "Compensación de radio (G42)"@es ;
    ex:textoExtracto      "La ejecución tiene en cuenta la compensación de radio (funciones G41, G42)"@es ;
    ex:identificador      "G42" .

ex:FuncionG4 a ex:Tabla ;
     a                     ex:Parametro ;
    rdfs:label            "Temporización (G4)"@es ;
    ex:textoExtracto      "La ejecución tiene en cuenta las temporizaciones programadas mediante G4"@es ;
    ex:identificador      "G4" .

ex:FuncionM00 a ex:Tabla ;
     a                     ex:Parametro ;
    rdfs:label            "Parada de programa (M00)"@es ;
    ex:textoExtracto      "La ejecución tiene en cuenta las paradas de programa programadas mediante M00 y M01"@es ;
    ex:identificador      "M00" .

ex:FuncionM01 a ex:Tabla ;
     a                     ex:Parametro ;
    rdfs:label            "Parada opcional de programa (M01)"@es ;
    ex:textoExtracto      "La ejecución tiene en cuenta las paradas de programa programadas mediante M00 y M01"@es ;
    ex:identificador      "M01" .

ex:BarraEstadoGeneral
    a                     ex:InterfazUsuario ;
    rdfs:label            "Barra general de estado"@es ;
    ex:textoExtracto      "El CNC muestra en la barra general de estado el nombre de la subrutina"@es .

ex:SubrutinaReset_14_3
    ex:ilustradoEn        ex:BarraEstadoGeneral ;
    ex:habilitadoPor      ex:TeclaReset ;
    ex:habilitadoPor      ex:MarcaResetIN ;
    ex:tieneFrecuencia    ex:ModoEjecucionSimulada .