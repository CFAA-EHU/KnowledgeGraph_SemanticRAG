@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SubrutinaReset ex:textoExtracto "En cada canal, el reset puede tener una subrutina asociada, que se ejecuta al pulsar la tecla [RESET] del panel de mando o cuando el PLC activa la marca RESETIN." ;
    a ex:TareaMantenimiento ;
    ex:ejecutadoPor ex:PanelDeMando ;
    ex:ejecutadoPor ex:PLC .

ex:PanelDeMando ex:textoExtracto "tecla [RESET] del panel de mando" ;
    a ex:InterfazUsuario .

ex:PLC ex:textoExtracto "el PLC activa la marca RESETIN" ;
    a ex:ComponenteElectrico .

ex:ModoEjecucionSimulada ex:textoExtracto "el CNC ejecuta la subrutina con la opción \"Funciones G\" del modo ejecución simulada" ;
    a ex:ModoOperacion .

ex:FuncionG41 a ex:Tabla ;
    ex:textoExtracto "compensación de radio (funciones G41, G42)" ;
    a ex:Parametro .

ex:FuncionG42 a ex:Tabla ;
    ex:textoExtracto "compensación de radio (funciones G41, G42)" ;
    a ex:Parametro .

ex:FuncionM00 a ex:Tabla ;
    ex:textoExtracto "paradas de programa programadas mediante M00 y M01" ;
    a ex:Parametro .

ex:FuncionM01 a ex:Tabla ;
    ex:textoExtracto "paradas de programa programadas mediante M00 y M01" ;
    a ex:Parametro .

ex:FuncionG4 a ex:Tabla ;
    ex:textoExtracto "temporizaciones programadas mediante G4" ;
    a ex:Parametro .

ex:BarraGeneralEstado ex:textoExtracto "el CNC muestra en la barra general de estado el nombre de la subrutina" ;
    a ex:InterfazUsuario .