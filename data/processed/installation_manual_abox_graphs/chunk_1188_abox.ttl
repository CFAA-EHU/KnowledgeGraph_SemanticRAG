@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PROGRAM_RESET a ex:TareaMantenimiento ;
    rdfs:label "PROGRAM_RESET" ;
    ex:textoExtracto "El nombre de la subrutina debe ser PROGRAM_RESET (sin extensión) y estará guardada en la carpeta ..\Users\Sub." ;
    ex:identificador "PROGRAM_RESET" .

ex:PROGRAM_RESET_C1 a ex:TareaMantenimiento ;
    rdfs:label "PROGRAM_RESET_C1" ;
    ex:textoExtracto "puede haber una subrutina diferente para cada canal, cuyo nombre deberá ser PROGRAM_RESET_Cn donde n es el número de canal (entre 1 y 4)." ;
    ex:identificador "PROGRAM_RESET_C1" .

ex:PROGRAM_RESET_C2 a ex:TareaMantenimiento ;
    rdfs:label "PROGRAM_RESET_C2" ;
    ex:textoExtracto "| PROGRAM_RESET_C2 | Canal 2. |" ;
    ex:identificador "PROGRAM_RESET_C2" .

ex:PROGRAM_RESET_C3 a ex:TareaMantenimiento ;
    rdfs:label "PROGRAM_RESET_C3" ;
    ex:textoExtracto "| PROGRAM_RESET_C3 | Canal 3. |" ;
    ex:identificador "PROGRAM_RESET_C3" .

ex:PROGRAM_RESET_C4 a ex:TareaMantenimiento ;
    rdfs:label "PROGRAM_RESET_C4" ;
    ex:textoExtracto "| PROGRAM_RESET_C4 | Canal 4. |" ;
    ex:identificador "PROGRAM_RESET_C4" .

ex:RESETIN a ex:Parametro ;
    rdfs:label "RESETIN" ;
    ex:textoExtracto "El PLC activa la marca RESETIN (RESETIN=1)." ;
    ex:identificador "RESETIN" .

ex:RESETOUT a ex:Parametro ;
    rdfs:label "RESETOUT" ;
    ex:textoExtracto "El canal activa la marca RESETOUT (RESETOUT=1) para indicar que ha finalizado el reset." ;
    ex:identificador "RESETOUT" .

ex:MINAENDW a ex:Parametro ;
    rdfs:label "MINAENDW" ;
    ex:textoExtracto "Esta marca permanece activa el tiempo fijado en el parámetro general MINAENDW." ;
    ex:identificador "MINAENDW" .

ex:PanelDeMando a ex:InterfazUsuario ;
    rdfs:label "panel de mando" ;
    ex:textoExtracto "El usuario pulsa la tecla [RESET] del panel de mando" .

ex:CNC a ex:Maquina ;
    rdfs:label "CNC" ;
    ex:textoExtracto "El CNC admite los dos nombres para la subrutina asociada al primer canal" .