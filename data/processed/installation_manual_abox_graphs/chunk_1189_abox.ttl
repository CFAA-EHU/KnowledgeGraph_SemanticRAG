@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_78f98c2256 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:ParametrizarSetsDelRegulador ;
    ns1:textoExtracto "El CNC asume el set por defecto (parámetro DEFAULTSET)." .

ns1:SetPorDefecto a ns1:Parametro ;
    rdfs:label "Set por defecto" ;
    ns1:identificador "DEFAULTSET" ;
    ns1:textoExtracto "El CNC asume el set por defecto (parámetro DEFAULTSET)." .

ns1:SistemaReguladorSercos a ns1:Sistema ;
    rdfs:label "Regulador Sercos" ;
    ns1:textoExtracto "Homogeneización de parámetros entre el CNC y el regulador Sercos." .

ns1:ParametrizarSetsDelRegulador a ns1:TareaMantenimiento ;
    rdfs:label "Parametrizar sets del regulador" ;
    ns1:textoExtracto "el resto de sets del regulador hay que parametrizarlos desde el DDSSetup o en el propio regulador." .

