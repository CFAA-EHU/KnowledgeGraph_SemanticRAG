@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Subrutina_9998 a ex:TareaMantenimiento ;
    rdfs:label "9998" ;
    ex:textoExtracto "Rutina que ejecutará el CNC al principio de cada programa del 8055-MC y 8055-TC." ;
    ex:identificador "9998" .

ex:Subrutina_9999 a ex:TareaMantenimiento ;
    rdfs:label "9999" ;
    ex:textoExtracto "Rutina que ejecutará el CNC al final de cada programa del 8055-MC y 8055-TC." ;
    ex:identificador "9999" .

ex:Programa_8055MC_TC a ex:Sistema ;
    rdfs:label "Programa 8055-MC/TC" ;
    ex:textoExtracto "programas del 8055 MC/TC" .

ex:Lenguaje_8070 a ex:Sistema ;
    rdfs:label "Lenguaje 8070" ;
    ex:textoExtracto "lenguaje del 8070" .

ex:CNC a ex:Maquina ;
    rdfs:label "CNC" ;
    ex:textoExtracto "en el CNC deben existir dos subrutinas llamadas 9998 y 9999" .