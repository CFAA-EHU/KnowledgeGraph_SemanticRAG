@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BusquedaDeReferenciaNecesariaParaCompensar_9a5cdb741b a ns1:Parametro ;
    rdfs:label "Búsqueda de referencia necesaria para compensar"@es ;
    ns1:identificador "MPG.REFNEED" ;
    ns1:textoExtracto "REFNEED Búsqueda de referencia necesaria para compensar. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPG.REFNEED[tbl] Parámetro incluido en la tabla CROSSCOMP." .

ns1:CompensacionBidireccional_3e25956854 a ns1:Parametro ;
    rdfs:label "Compensación bidireccional"@es ;
    ns1:identificador "MPG.BIDIR" ;
    ns1:textoExtracto "BIDIR Compensación bidireccional. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPG.BIDIR[tbl] Parámetro incluido en la tabla CROSSCOMP." .

ns1:EjeQueAlMoverseGeneraVariacionesMaestro_a9ed7aa812 a ns1:Parametro ;
    rdfs:label "Eje que al moverse genera variaciones (maestro)"@es ;
    ns1:identificador "MPG.MOVAXIS" ;
    ns1:textoExtracto "MOVAXIS Eje que al moverse genera variaciones (maestro). Valores posibles: Cualquier eje definido en AXISNAME. Variable asociada: (V.)MPG.MOVAXIS[tbl] Parámetro incluido en la tabla CROSSCOMP." .

ns1:EjeQueSufreVariacionesCompensado_a023bb406b a ns1:Parametro ;
    rdfs:label "Eje que sufre variaciones (compensado)"@es ;
    ns1:identificador "MPG.COMPAXIS" ;
    ns1:textoExtracto "COMPAXIS Eje que sufre variaciones (compensado). Valores posibles: Cualquier eje definido en AXISNAME. Variable asociada: (V.)MPG.COMPAXIS[tbl] Parámetro incluido en la tabla CROSSCOMP." .

ns1:MetodoDeCompensacionTipoDeCotas a ns1:Parametro ;
    rdfs:label "Método de compensación (tipo de cotas)"@es ;
    ns1:identificador "MPG.TYPCROSS" ;
    ns1:textoExtracto "TYPCROSS Método de compensación (tipo de cotas). Valores posibles: Real / Teórica. Valor por defecto: Real. Variable asociada: (V.)MPG.TYPCROSS[tbl] Parámetro incluido en la tabla CROSSCOMP." .

ns1:NumeroDePuntosDeLaTabla_1bf89b7c42 a ns1:Parametro ;
    rdfs:label "Número de puntos de la tabla"@es ;
    ns1:identificador "MPG.NPCROSS" ;
    ns1:textoExtracto "NPCROSS Número de puntos de la tabla. Valores posibles: De 0 a 1000. Valor por defecto: 0 (no hay tabla). Variable asociada: (V.)MPG.NPCROSS[tbl] Parámetro incluido en la tabla CROSSCOMP." .

