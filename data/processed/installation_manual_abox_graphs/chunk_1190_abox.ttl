@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:GruposMultieje a ns1:Parametro ;
    rdfs:label "Grupos multieje" ;
    ns1:identificador "GROUP n" ;
    ns1:textoExtracto "La tabla muestra un parámetro GROUP_n por cada grupo multieje." .

ns1:NombreDeLosEjesYOCabezalesDelGrupo_8163cfdead a ns1:Parametro ;
    rdfs:label "Nombre de los ejes y/o cabezales del grupo" ;
    ns1:identificador "MULAXISNAME n" ;
    ns1:textoExtracto "La tabla muestra un parámetro MUMLAXISNAME_n por cada eje o cabezal que forma parte del grupo multieje." .

ns1:NumeroDeEjesYOCabezalesQueFormanElGrupoMultieje_b87bae47ec a ns1:Parametro ;
    rdfs:label "Número de ejes y/o cabezales que forman el grupo multieje" ;
    ns1:identificador "MULNAXIS" ;
    ns1:textoExtracto "El parámetro MULNAXIS establece el número de ejes y/o cabezales que forman el grupo multieje." .

ns1:NumeroDeGruposMultiejeEnElSistema_c2c7a220e7 a ns1:Parametro ;
    rdfs:label "Número de grupos multieje en el sistema" ;
    ns1:identificador "MULNGROUP" ;
    ns1:textoExtracto "El parámetro MULNGROUP establece el número de grupos multieje del sistema." .

ns1:TablaDeGruposMultieje a ns1:Parametro ;
    rdfs:label "Tabla de grupos multieje" ;
    ns1:identificador "MULTIAXIS" ;
    ns1:textoExtracto "El parámetro MULTIAXIS muestra la tabla de definición de los grupos multieje." .

