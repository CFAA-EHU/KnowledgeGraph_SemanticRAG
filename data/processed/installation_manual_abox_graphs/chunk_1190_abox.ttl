@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SUBPATH_CHN a ex:Parametro ;
    rdfs:label "SUBPATH CHN" ;
    ex:textoExtracto "Nombre y ubicación de la subrutina. | Parámetro. |  | Significado. |"@es, "Este parámetro indica el directorio por defecto para las subrutinas de usuario y las subrutinas necesarias para poder ejecutar programas del 8055-MC y 8055-TC."@es, "[CHN].......Parámetro máquina; general del canal. El nombre de las subrutinas es 9998 y 9999. Ambas subrutinas deben estar guardadas en el path indicado por el parámetro general SUBPATH. Todos los canales utilizan las mismas subrutinas."@es ;
    ex:identificador "CHN" ;
    ex:valor "9998, 9999" .

ex:Parametro_8055_MC a ex:Parametro ;
    rdfs:label "8055-MC" ;
    ex:textoExtracto "Este parámetro indica el directorio por defecto para las subrutinas de usuario y las subrutinas necesarias para poder ejecutar programas del 8055-MC y 8055-TC."@es .

ex:Parametro_8055_TC a ex:Parametro ;
    rdfs:label "8055-TC" ;
    ex:textoExtracto "Este parámetro indica el directorio por defecto para las subrutinas de usuario y las subrutinas necesarias para poder ejecutar programas del 8055-MC y 8055-TC."@es .