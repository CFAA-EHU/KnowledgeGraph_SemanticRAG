@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SUBPATH_CHN
    a ex:Parametro ;
    rdfs:label "SUBPATH CHN" ;
    ex:identificador "SUBPATH CHN" ;
    ex:textoExtracto "Este parámetro indica el directorio por defecto para las subrutinas de usuario y las subrutinas necesarias para poder ejecutar programas del 8055-MC y 8055-TC." ;
    ex:valor "Directorio por defecto para subrutinas (8055-MC/8055-TC)" .

ex:Subrutina_9998
    a ex:Componente ;
    rdfs:label "Subrutina 9998" ;
    ex:identificador "9998" ;
    ex:textoExtracto "El nombre de las subrutinas es 9998 y 9999. Ambas subrutinas deben estar guardadas en el path indicado por el parámetro general SUBPATH." .

ex:Subrutina_9999
    a ex:Componente ;
    rdfs:label "Subrutina 9999" ;
    ex:identificador "9999" ;
    ex:textoExtracto "El nombre de las subrutinas es 9998 y 9999. Ambas subrutinas deben estar guardadas en el path indicado por el parámetro general SUBPATH." .

ex:Parametro_CHN
    a ex:Parametro ;
    rdfs:label "Parámetro máquina CHN" ;
    ex:identificador "CHN" ;
    ex:textoExtracto "[CHN].......Parámetro máquina; general del canal." .

ex:Tabla_ConfiguracionSubrutinas_14_4_1 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla 14.4.1: Configuración de subrutinas (pág. 641)" ;
    ex:textoExtracto "Nombre y ubicación de la subrutina. | Parámetro. |  | Significado." ;
    ex:documentadoEn ex:Pagina_641 .