@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:KinCal_Begin_nc a ex:TareaMantenimiento ;
    ex:textoExtracto "El ciclo de calibración de cinemática tiene asociadas dos subrutinas (KinCal_Begin.nc y KinCal_End.nc) que el CNC ejecuta antes y después del ciclo." ;
    rdfs:label "KinCal_Begin.nc" .

ex:KinCal_End_nc a ex:TareaMantenimiento ;
    ex:textoExtracto "El ciclo de calibración de cinemática tiene asociadas dos subrutinas (KinCal_Begin.nc y KinCal_End.nc) que el CNC ejecuta antes y después del ciclo." ;
    rdfs:label "KinCal_End.nc" .