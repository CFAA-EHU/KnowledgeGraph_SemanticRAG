@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_11a7db896f a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "En el arranque del sistema, el CNC utilizará los parámetros del eje maestro para realizar la homogeneización de parámetros con el regulador." .

ns1:EjeMaestro a ns1:ComponenteMecanico ;
    rdfs:label "Eje Maestro" ;
    ns1:textoExtracto "El primer eje del grupo será el eje maestro, el que por defecto utilizará el regulador." .

ns1:MUMLAXISNAMEN_db65e00eea a ns1:Parametro ;
    rdfs:label "MUMLAXISNAME_n" ;
    ns1:textoExtracto "La tabla muestra un parámetro MUMLAXISNAME_n por cada eje o cabezal que forma parte del grupo multieje." .

ns1:Regulador a ns1:ComponenteElectrico ;
    rdfs:label "Regulador" ;
    ns1:textoExtracto "Configurar el set del regulador a utilizar." .

