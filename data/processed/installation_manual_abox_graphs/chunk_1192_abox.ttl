@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:KinCal_Begin_nc
    a ex:Componente ;
    rdfs:label "KinCal_Begin.nc" ;
    ex:textoExtracto "El nombre de las subrutinas es KinCal_Begin.nc [...] Ambas subrutinas deben estar guardadas en la carpeta ..\\Mtb\\Sub." ;
    ex:identificador "KinCal_Begin.nc" .

ex:KinCal_End_nc
    a ex:Componente ;
    rdfs:label "KinCal_End.nc" ;
    ex:textoExtracto "El nombre de las subrutinas es [...] KinCal_End.nc. Ambas subrutinas deben estar guardadas en la carpeta ..\\Mtb\\Sub." ;
    ex:identificador "KinCal_End.nc" .

ex:SistemaSubrutinasKinCal
    a ex:Sistema ;
    rdfs:label "Sistema de subrutinas KinCal" ;
    ex:textoExtracto "Ambas subrutinas deben estar guardadas en la carpeta ..\\Mtb\\Sub. Todos los canales utilizan las mismas subrutinas." ;
    ex:compuestoPor ex:KinCal_Begin_nc ;
    ex:compuestoPor ex:KinCal_End_nc .