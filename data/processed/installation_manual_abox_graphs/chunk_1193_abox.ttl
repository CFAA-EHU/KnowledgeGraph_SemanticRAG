@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Subrutina_Sub_Probe_Tool_Begin_fst
    a ex:Componente ;
    rdfs:label "Sub_Probe_Tool_Begin.fst" ;
    ex:identificador "Sub_Probe_Tool_Begin.fst" ;
    ex:textoExtracto "subrutina asociada al inicio del ciclo de calibración de herramienta" ;
    ex:textoExtracto "Fagor suministra la subrutina Sub_Probe_Tool_Begin.fst asociada a la entrada de palpador 1" ;
    ex:textoExtracto "Al iniciar la ejecución, el ciclo primero ejecuta la subrutina Sub_Probe_Tool_Begin.fst" .

ex:Subrutina_Sub_Probe_Piece_Begin_fst
    a ex:Componente ;
    rdfs:label "Sub_Probe_Piece_Begin.fst" ;
    ex:identificador "Sub_Probe_Piece_Begin.fst" ;
    ex:textoExtracto "subrutina asociada a la entrada de palpador 2" .

ex:Subrutina_Sub_Probe_Tool_End_fst
    a ex:Componente ;
    rdfs:label "Sub_Probe_Tool_End.fst" ;
    ex:identificador "Sub_Probe_Tool_End.fst" ;
    ex:textoExtracto "Subrutina asociada al final del ciclo de calibración de herramienta" ;
    ex:textoExtracto "Al finalizar la ejecución, el ciclo primero ejecuta [...] la subrutina Sub_Probe_Tool_End.fst" .

ex:FuncionesM_Antes_Calibracion a ex:Tabla ;
     a ex:Componente ;
    rdfs:label "Funciones M-antes del ciclo de calibración" ;
    ex:textoExtracto "cuatro funciones M para ejecutarlas antes del ciclo" ;
    ex:textoExtracto "ejecuta las funciones M-antes con sus correspondientes subrutinas asociadas" .

ex:FuncionesM_Despues_Calibracion a ex:Tabla ;
     a ex:Componente ;
    rdfs:label "Funciones M-después del ciclo de calibración" ;
    ex:textoExtracto "cuatro funciones M para ejecutarlas después" ;
    ex:textoExtracto "ejecuta las funciones M-después con sus correspondientes subrutinas asociadas" .

ex:Marca_PROBE1ENA
    a ex:Sensor ;
    rdfs:label "PROBE1ENA" ;
    ex:identificador "PROBE1ENA" ;
    ex:textoExtracto "indican que el palpador está habilitado" ;
    ex:textoExtracto "Gestión de las marcas PROBE1ENA/PROBE2ENA en la subrutina" .

ex:Marca_PROBE2ENA
    a ex:Sensor ;
    rdfs:label "PROBE2ENA" ;
    ex:identificador "PROBE2ENA" ;
    ex:textoExtracto "indican que el palpador está habilitado" ;
    ex:textoExtracto "Gestión de las marcas PROBE1ENA/PROBE2ENA en la subrutina" .

ex:Marca_PROBE1MONIT
    a ex:Sensor ;
    rdfs:label "PROBE1MONIT" ;
    ex:identificador "PROBE1MONIT" ;
    ex:textoExtracto "asociadas al modo seguro del palpador" ;
    ex:textoExtracto "Gestión de las marcas PROBE1MONIT/PROBE2MONIT en la subrutina" .

ex:Marca_PROBE2MONIT
    a ex:Sensor ;
    rdfs:label "PROBE2MONIT" ;
    ex:identificador "PROBE2MONIT" ;
    ex:textoExtracto "asociadas al modo seguro del palpador" ;
    ex:textoExtracto "Gestión de las marcas PROBE1MONIT/PROBE2MONIT en la subrutina" .

ex:Tabla_SubrutinasCicloCalibracion a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Subrutinas asociadas al ciclo de calibración de herramienta" ;
    ex:textoExtracto "| Nombre. | Significado. | --- | --- | Sub_Probe_Tool_Begin.fst | Subrutina asociada al inicio del ciclo de calibración de herramienta. | Sub_Probe_Tool_End.fst | Subrutina asociada al final del ciclo de calibración de herramienta. |" ;
    ex:documentadoEn ex:Subrutina_Sub_Probe_Tool_Begin_fst ;
    ex:documentadoEn ex:Subrutina_Sub_Probe_Tool_End_fst .