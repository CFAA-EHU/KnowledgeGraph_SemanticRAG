@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Sub_Probe_Tool_Begin_fst a ex:TareaMantenimiento ;
    ex:textoExtracto "Subrutina Sub_Probe_Tool_Begin.fst asociada a la entrada de palpador 1" ;
    rdfs:label "Sub_Probe_Tool_Begin.fst" .

ex:Sub_Probe_Piece_Begin_fst a ex:TareaMantenimiento ;
    ex:textoExtracto "Subrutina Sub_Probe_Piece_Begin.fst asociada a la entrada de palpador 2" ;
    rdfs:label "Sub_Probe_Piece_Begin.fst" .

ex:Sub_Probe_Tool_End_fst a ex:TareaMantenimiento ;
    ex:textoExtracto "Subrutina Sub_Probe_Tool_End.fst asociada al final del ciclo de calibración de herramienta" ;
    rdfs:label "Sub_Probe_Tool_End.fst" .

ex:CicloCalibracionHerramienta a ex:Sistema ;
    ex:textoExtracto "El ciclo de calibración de herramienta, tanto ISO como del editor, tiene asociadas dos subrutinas que el CNC ejecuta antes y después del ciclo" ;
    ex:compuestoPor ex:Sub_Probe_Tool_Begin_fst, ex:Sub_Probe_Tool_End_fst ;
    rdfs:label "Ciclo de calibración de herramienta" .