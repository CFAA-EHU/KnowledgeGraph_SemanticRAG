@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_971d1875b4 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Cuando el eje utiliza la segunda entrada de captación de otro regulador, el CNC no permite realizar su búsqueda de referencia, por lo que el eje debe disponer de captación absoluta." .

ns1:ComponenteElectrico_6023500184 a ns1:ComponenteElectrico ;
    rdfs:label "Motor" ;
    ns1:textoExtracto "La captación interna (motor) de ambos ejes esta ubicada en el regulador." .

ns1:ComponenteElectrico_c87acc2115 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador" ;
    ns1:textoExtracto "el parámetro COUNTERTYPE indica dónde está ubicada la entrada para la captación externa (directa) del eje; en los módulos remotos, en la captación libre de un regulador Sercos o en las entradas de captación locales de la unidad central." .

ns1:NumeroDeLaEntradaDeCaptacionDelEje_f6ca2329df a ns1:Parametro ;
    rdfs:label "Número de la entrada de captación del eje" ;
    ns1:identificador "COUNTERID" ;
    ns1:textoExtracto "COUNTERID | Número de la entrada de captación del eje." .

ns1:TipoDeEntradaDeCaptacionDelEjeReguladorLocalORemota a ns1:Parametro ;
    rdfs:label "Tipo de entrada de captación del eje; regulador, local o remota" ;
    ns1:identificador "COUNTERTYPE" ;
    ns1:textoExtracto "COUNTERTYPE | Tipo de entrada de captación del eje; regulador, local o remota." .

