@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Subrutina_Probe_Tool_Begin
    a ex:InterfazUsuario ;
    rdfs:label "Sub_Probe_Tool_Begin.fst" ;
    ex:identificador "Sub_Probe_Tool_Begin.fst" ;
    ex:textoExtracto "El nombre de las subrutinas es Sub_Probe_Tool_Begin.fst [...] Al ser una subrutina OEM con extensión fst, el CNC carga esta subrutina en la memoria RAM del CNC." ;
    ex:documentadoEn ex:Pagina_637_EjecucionSubrutinasRAM .

ex:Subrutina_Probe_Tool_End
    a ex:InterfazUsuario ;
    rdfs:label "Sub_Probe_Tool_End.fst" ;
    ex:identificador "Sub_Probe_Tool_End.fst" ;
    ex:textoExtracto "El nombre de las subrutinas es [...] Sub_Probe_Tool_End.fst. Ambas subrutinas deben estar guardadas en la carpeta ..\\Mtb\\Sub." ;
    ex:documentadoEn ex:Pagina_637_EjecucionSubrutinasRAM .

ex:Pagina_637_EjecucionSubrutinasRAM
    a ex:Pagina ;
    rdfs:label "14.1 Ejecutar subrutinas desde la memoria RAM" ;
    ex:identificador "Página 637" ;
    ex:textoExtracto "Ver en la '14.1 Ejecutar subrutinas desde la memoria RAM (extensión *.fst).' página 637." .