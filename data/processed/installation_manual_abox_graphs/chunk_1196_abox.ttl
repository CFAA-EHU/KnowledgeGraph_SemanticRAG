@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_0e41936c32 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Los grupos multieje se gestionan desde el PLC, para lo cual dispone de la siguiente marca." .

ns1:ComponenteElectrico_3ef837e010 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador" ;
    ns1:textoExtracto "4 En caso necesario, escribir los parámetros en el regulador." .

ns1:ConmutarAlEjeX1 a ns1:Parametro ;
    rdfs:label "Conmutar al eje X1" ;
    ns1:identificador "SWITCHX1" ;
    ns1:textoExtracto "3 Conmutar al eje X1 (SWITCHX1=1)." .

ns1:Parametro_3d77749cd9 a ns1:Parametro ;
    rdfs:label "Parámetro del regulador para verificar el set o gama correcta" ;
    ns1:identificador "GV21" ;
    ns1:textoExtracto "6 Verificar que el cambio de set y/o gama ha terminado (marca SERPLCAC) y que el set y/o gama del regulador es correcta (parámetros GV21 y GV25 del regulador)." .

ns1:Parametro_7b18238566 a ns1:Parametro ;
    rdfs:label "Parámetro del regulador para verificar el set o gama correcta" ;
    ns1:identificador "GV25" ;
    ns1:textoExtracto "6 Verificar que el cambio de set y/o gama ha terminado (marca SERPLCAC) y que el set y/o gama del regulador es correcta (parámetros GV21 y GV25 del regulador)." .

ns1:VerificarQueElCambioDeSetYOGamaHaTerminado a ns1:Parametro ;
    rdfs:label "Verificar que el cambio de set y/o gama ha terminado" ;
    ns1:identificador "SERPLCAC" ;
    ns1:textoExtracto "6 Verificar que el cambio de set y/o gama ha terminado (marca SERPLCAC)" .

