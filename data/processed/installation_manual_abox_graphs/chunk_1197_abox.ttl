@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_81ba0ecd44 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:ParametroCAXSET,
        ns1:Parametro_e0c748760d ;
    ns1:textoExtracto "El CNC activa el set definido en el parámetro CAXSET." .

ns1:CambioDeSetYGama a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de Set y Gama" ;
    ns1:textoExtracto "Un cambio de set activa todos los parámetros del mismo, incluidos los de la gama, mientras que un cambio de gama sólo activa los parámetros específicos de la reducción." .

ns1:CambioDeSetYGamaEnMultieje a ns1:AccionProhibida ;
    rdfs:label "Cambio de Set y Gama en Multieje" ;
    ns1:textoExtracto "Si el eje o cabezal no forma parte de un grupo multieje, las funciones G112 y M41 a M44 actúan igual en el CNC pero en el regulador activan la gama programada, no la definida en el parámetro DRIVESET." .

ns1:ReguladorHidraulico a ns1:Sistema ;
    rdfs:label "Regulador Hidraulico" ;
    ns1:controla ns1:ParametroCAXSET,
        ns1:Parametro_e0c748760d ;
    ns1:textoExtracto "El regulador activa la gama definida en el parámetro CAXSET." .

ns1:ParametroCAXSET a ns1:Parametro ;
    rdfs:label "Parámetro CAXSET" ;
    ns1:textoExtracto "El CNC activa el set definido en el parámetro CAXSET." .

ns1:Parametro_e0c748760d a ns1:Parametro ;
    rdfs:label "Parámetro que define la gama en el set programado" ;
    ns1:textoExtracto "El regulador activa la gama definida en el parámetro DRIVESET del set programado." .

