@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaConDosEjes a ns1:Sistema ;
    rdfs:label "Sistema con dos ejes" ;
    ns1:textoExtracto "Sistema con dos ejes, cada uno con su motor." .

ns1:CaptacionExternaA1 a ns1:ComponenteElectrico ;
    rdfs:label "Captación externa para Eje A1" ;
    ns1:controladoPor ns1:ReguladorControlaEjes ;
    ns1:textoExtracto "La captación externa (directa) está conectada al propio regulador." .

ns1:CaptacionExternaA2 a ns1:ComponenteElectrico ;
    rdfs:label "Captación externa para Eje A2" ;
    ns1:controladoPor ns1:ModulosRemotos ;
    ns1:textoExtracto "La captación externa (directa) está conectada a los módulos remotos." .

ns1:EjeA1 a ns1:Sistema ;
    rdfs:label "Eje A1" ;
    ns1:compuestoPor ns1:CaptacionExternaA1 ;
    ns1:textoExtracto "Eje A1 La captación externa (directa) está conectada al propio regulador." .

ns1:EjeA2 a ns1:Sistema ;
    rdfs:label "Eje A2" ;
    ns1:compuestoPor ns1:CaptacionExternaA2 ;
    ns1:textoExtracto "Eje A2 La captación externa (directa) está conectada a los módulos remotos." .

ns1:ModulosRemotos a ns1:Sistema ;
    rdfs:label "Módulos Remotos" ;
    ns1:textoExtracto "La captación externa (directa) está conectada a los módulos remotos." .

ns1:ReguladorControlaEjes a ns1:ComponenteElectrico ;
    rdfs:label "Regulador que controla dos ejes" ;
    ns1:controla ns1:EjeA1,
        ns1:EjeA2 ;
    ns1:textoExtracto "Un único regulador controla dos ejes, cada uno con su motor." .

