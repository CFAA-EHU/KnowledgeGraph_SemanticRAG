@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PROBE1MONIT a ex:Parametro ;
    rdfs:label "PROBE1MONIT" ;
    ex:textoExtracto "Gestión de las marcas PROBE1MONIT/PROBE2MONIT en la subrutina." .

ex:PROBE2MONIT a ex:Parametro ;
    rdfs:label "PROBE2MONIT" ;
    ex:textoExtracto "Gestión de las marcas PROBE1MONIT/PROBE2MONIT en la subrutina." .

ex:Sub_Probe_Piece_Begin_fst a ex:TareaMantenimiento ;
    rdfs:label "Sub_Probe_Piece_Begin.fst" ;
    ex:textoExtracto "Se recomienda que OEM gestione ambas marca desde la subrutina Sub_Probe_Piece_Begin.fst para avisar, si están desactivadas, que el palpador está en modo no seguro." .

ex:AvisoSeguridad_ModoNoSeguro a ex:AvisoSeguridad ;
    rdfs:label "Aviso de modo no seguro del palpador" ;
    ex:textoExtracto "para avisar, si están desactivadas, que el palpador está en modo no seguro." .