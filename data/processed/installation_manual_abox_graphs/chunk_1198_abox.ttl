@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Marca_PROBE1MONIT
    a ex:Parametro ;
    rdfs:label "PROBE1MONIT" ;
    ex:textoExtracto "Gestión de las marcas PROBE1MONIT/PROBE2MONIT en la subrutina. Estas marcas están asociadas al modo seguro del palpador." ;
    ex:monitoreaParametro ex:ModoSeguroPalpador .

ex:Marca_PROBE2MONIT
    a ex:Parametro ;
    rdfs:label "PROBE2MONIT" ;
    ex:textoExtracto "Gestión de las marcas PROBE1MONIT/PROBE2MONIT en la subrutina. Estas marcas están asociadas al modo seguro del palpador." ;
    ex:monitoreaParametro ex:ModoSeguroPalpador .

ex:ModoSeguroPalpador
    a ex:ModoOperacion ;
    rdfs:label "Modo seguro del palpador" ;
    ex:textoExtracto "Estas marcas están asociadas al modo seguro del palpador." .

ex:Subrutina_Sub_Probe_Piece_Begin
    a ex:Sistema ;
    rdfs:label "Sub_Probe_Piece_Begin.fst" ;
    ex:textoExtracto "Se recomienda que OEM gestione ambas marca desde la subrutina Sub_Probe_Piece_Begin.fst para avisar, si están desactivadas, que el palpador está en modo no seguro." ;
    ex:controla ex:Marca_PROBE1MONIT, ex:Marca_PROBE2MONIT ;
    ex:mitigaRiesgo ex:AvisoModoNoSeguro .

ex:AvisoModoNoSeguro
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso de palpador en modo no seguro" ;
    ex:textoExtracto "para avisar, si están desactivadas, que el palpador está en modo no seguro." .