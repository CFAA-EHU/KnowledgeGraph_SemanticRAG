@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaConDosEjesUnMotor a ns1:Sistema ;
    rdfs:label "Sistema con dos ejes y sólo un motor" ;
    ns1:textoExtracto "El sistema tiene las siguientes características. • Un único regulador controla dos ejes con el mismo motor. • Cada eje utiliza un tipo de captación diferente." ;
    ns1:tieneComponente ns1:EjeA1,
        ns1:EjeA2,
        ns1:ReguladorUnico .

ns1:EjeA1 a ns1:ComponenteMecanico ;
    rdfs:label "Eje A1" ;
    ns1:controladoPor ns1:ReguladorUnico ;
    ns1:textoExtracto "Eje A1 La captación externa (directa) está conectada a los módulos remotos." .

ns1:EjeA2 a ns1:ComponenteMecanico ;
    rdfs:label "Eje A2" ;
    ns1:controladoPor ns1:ReguladorUnico ;
    ns1:textoExtracto "Eje A2 La captación externa (directa) está conectada a los módulos remotos." .

ns1:ReguladorUnico a ns1:ComponenteElectrico ;
    rdfs:label "Regulador único" ;
    ns1:controla ns1:EjeA1,
        ns1:EjeA2 ;
    ns1:textoExtracto "Un único regulador controla dos ejes con el mismo motor." .

