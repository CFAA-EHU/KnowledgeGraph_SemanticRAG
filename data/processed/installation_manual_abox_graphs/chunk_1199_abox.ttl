@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Subrutina_Sub_Probe_Piece_Begin
    a               ex:InterfazUsuario ;
    rdfs:label      "Subrutina Sub_Probe_Piece_Begin" ;
    ex:identificador "Sub_Probe_Piece_Begin.fst" ;
    ex:textoExtracto "El nombre de las subrutinas es Sub_Probe_Piece_Begin.fst [...] Al ser una subrutina OEM con extensión fst, el CNC carga esta subrutina en la memoria RAM del CNC." .

ex:Subrutina_Sub_Probe_Piece_End
    a               ex:InterfazUsuario ;
    rdfs:label      "Subrutina Sub_Probe_Piece_End" ;
    ex:identificador "Sub_Probe_Piece_End.fst" ;
    ex:textoExtracto "El nombre de las subrutinas es [...] Sub_Probe_Piece_End.fst. Ambas subrutinas deben estar guardadas en la carpeta ..\\Mtb\\Sub." .

ex:Carpeta_Mtb_Sub
    a               ex:Sistema ;
    rdfs:label      "Carpeta de subrutinas ..\\Mtb\\Sub" ;
    ex:textoExtracto "Ambas subrutinas deben estar guardadas en la carpeta ..\\Mtb\\Sub." ;
    ex:tieneComponente ex:Subrutina_Sub_Probe_Piece_Begin ;
    ex:tieneComponente ex:Subrutina_Sub_Probe_Piece_End .