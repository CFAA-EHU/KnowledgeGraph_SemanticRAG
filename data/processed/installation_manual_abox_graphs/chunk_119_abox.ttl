@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IndicaSiEsNecesarioReferenciarAmbosEjesParaEmpezarAAplicarLaCompensacion a ns1:Parametro ;
    rdfs:label "Indica si es necesario referenciar ambos ejes para empezar a aplicar la compensación" ;
    ns1:documentadoEn ns1:TablaCompensacionCruzada ;
    ns1:identificador "MPG.REFNEED" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.REFNEED[tbl] Parámetro incluido en la tabla CROSSCOMP." .

ns1:TablaCompensacionCruzada a ns1:Tabla ;
    rdfs:label "Tabla para definir los valores de compensación" ;
    ns1:textoExtracto "DATA Tabla para definir los valores de compensación. Este parámetro muestra la lista de puntos y valores de compensación." .

