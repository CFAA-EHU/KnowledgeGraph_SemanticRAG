@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MPG.TTIME a ex:Parametro ;
    rdfs:label "MPG.TTIME" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.TTIME" ;
    ex:valor "0. ms" .

ex:ParametroMaquinaCabezales a ex:Parametro ;
    rdfs:label "parámetro máquina de cabezales" ;
    ex:textoExtracto "El parámetro máquina de cabezales" .

ex:ModoEdicionSimulacion a ex:ModoOperacion ;
    rdfs:label "modo de trabajo edición - simulación" ;
    ex:textoExtracto "En el modo de trabajo edición - simulación hay una opción que permite calcular el tiempo que se necesitará para ejecutar la pieza con las condiciones de mecanizado establecidas en el programa." .

ex:FuncionHDT a ex:Parametro ;
    rdfs:label "funciones H, D, T" ;
    ex:textoExtracto "Los valores son genéricos, para cualquier función H, D, T o búsqueda de uno o de varios ejes a la vez." .