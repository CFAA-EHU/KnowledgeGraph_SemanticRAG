@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Sub_Probe_Piece_Begin ex:textoExtracto """Ejemplo de subrutina Sub_Probe_Piece_Begin.fst suministrada por Fagor (a adaptar por el OEM). # ESBLK ; Activate PROBE 2 Hardware by PLC output. ; Check PROBE is READY with PLC Input from Probe Hardware. # MSG["WAIT FOR ENABLING PROBE2"] #WAIT FOR[V.PLC.PROBE2ENA==1] ; Select PROBE 2 input for using in Probing. # SELECT PROBE[2] #FLUSH $IF [V.G.PRBST2==1] #WARNING["PROBE2 SIGNAL TOUCHING"] M0 $ENDIF ; Check probe in safe mode feature is actived. $IF [V.PLC.PROBE2MONIT==0] #MSG["PROBE NOT IN SAFE MODE"] $ENDIF #RETDSBLK #COMMENT BEGIN PLC signals to add in the logic: PROBE2ENA; PROBE 2 is enabled confirmation signal to CNC. If not used in PLC, it is actived by default. PROBE2MONIT; It activates PROBE2 in SAFE mode. If probe is actived in no G100/3 motion, CNC will stop motion and shows an error. If not used in PLC, it is actived by default. # COMMENT END""" ;
    a ex:TareaMantenimiento ;
    rdfs:label "Sub_Probe_Piece_Begin.fst" .

ex:Sub_Probe_Piece_End ex:textoExtracto """Ejemplo de subrutina Sub_Probe_Piece_End.fst suministrada por Fagor (a adaptar por el OEM). # ESBLK ;Deactivate PROBE2 Hardware by PLC output #RETDSBLK""" ;
    a ex:TareaMantenimiento ;
    rdfs:label "Sub_Probe_Piece_End.fst" .

ex:PROBE2ENA ex:textoExtracto """PROBE2ENA; PROBE 2 is enabled confirmation signal to CNC. If not used in PLC, it is actived by default.""" ;
    a ex:Parametro ;
    rdfs:label "PROBE2ENA" .

ex:PROBE2MONIT ex:textoExtracto """PROBE2MONIT; It activates PROBE2 in SAFE mode. If probe is actived in no G100/3 motion, CNC will stop motion and shows an error. If not used in PLC, it is actived by default.""" ;
    a ex:Parametro ;
    rdfs:label "PROBE2MONIT" .

ex:PROBE2 ex:textoExtracto """PROBE 2 Hardware"" ; ""Check PROBE is READY with PLC Input from Probe Hardware"" ; ""Select PROBE 2 input for using in Probing"" ; ""PROBE2 SIGNAL TOUCHING"" ; ""PROBE NOT IN SAFE MODE"" ; ""Deactivate PROBE2 Hardware by PLC output""" ;
    a ex:Sensor ;
    rdfs:label "PROBE2" .