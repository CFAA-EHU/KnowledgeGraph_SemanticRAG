@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_cc4ed78672 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Configuración del grupo multieje. | MULTIAXIS | GROUP_1 |" ;
    ns1:tieneComponente ns1:EjeA1,
        ns1:EjeA2 .

ns1:ConfiguracionDelGrupoMultieje a ns1:Parametro ;
    rdfs:label "Configuración del grupo multieje" ;
    ns1:identificador "MULNGROUP" ;
    ns1:textoExtracto "MULNGROUP = 1" .

ns1:EjeA1ConfiguradoEnElGrupoMultieje a ns1:Parametro ;
    rdfs:label "Eje A1 configurado en el grupo multieje" ;
    ns1:identificador "MULAXI1" ;
    ns1:textoExtracto "2 = A1 = A2 Configuración de los ejes." .

ns1:EjeA2ConfiguradoEnElGrupoMultieje a ns1:Parametro ;
    rdfs:label "Eje A2 configurado en el grupo multieje" ;
    ns1:identificador "MULAXI2" ;
    ns1:textoExtracto "2 = A1 = A2 Configuración de los ejes." .

ns1:EjeA1 a ns1:ComponenteElectrico ;
    rdfs:label "Eje A1" ;
    ns1:textoExtracto "Eje A1 | 1 | Velocidad | Externa Remoto | 1" .

ns1:EjeA2 a ns1:ComponenteElectrico ;
    rdfs:label "Eje A2" ;
    ns1:textoExtracto "Eje A2 | 1 | Velocidad | Externa Remoto | 2" .

