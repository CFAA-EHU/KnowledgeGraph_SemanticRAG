@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_0e9296f651 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:BusquedaReferenciaAutomatica,
        ns1:BusquedaReferenciaManual,
        ns1:BusquedaReferenciaProgramaMDI,
        ns1:CeroMaquina,
        ns1:PuntoReferenciaMaquina ;
    ns1:textoExtracto "La búsqueda de referencia es la operación mediante la cual se realiza la sincronización del sistema." .

ns1:BusquedaReferenciaAutomatica a ns1:AccionProhibida ;
    rdfs:label "Búsqueda de referencia automática" ;
    ns1:documentadoEn ns1:SubrutinaDeBusquedaDeReferenciaAsociadaALaFuncionG74 ;
    ns1:textoExtracto "Búsqueda de referencia automática, desde el modo manual. Este tipo sólo disponible cuando esta definida la subrutina de búsqueda de referencia asociada a la función G74 (parámetro REFPSUB)." .

ns1:BusquedaReferenciaManual a ns1:AccionProhibida ;
    rdfs:label "Búsqueda de referencia manual" ;
    ns1:textoExtracto "Búsqueda de referencia manual, desde el modo manual. Los ejes se referencian de uno en uno." .

ns1:BusquedaReferenciaProgramaMDI a ns1:AccionProhibida ;
    rdfs:label "Búsqueda de referencia por programa o MDI" ;
    ns1:textoExtracto "Búsqueda de referencia por programa o MDI, mediante la función G74." .

ns1:CeroMaquina a ns1:AccionProhibida ;
    rdfs:label "Cero máquina" ;
    ns1:documentadoEn ns1:PosicionDelPuntoDeReferenciaParaCadaEje ;
    ns1:textoExtracto "El cero máquina es el origen del sistema de referencia de la máquina, fijado por el fabricante de la máquina." .

ns1:PuntoReferenciaMaquina a ns1:AccionProhibida ;
    rdfs:label "Punto de referencia máquina" ;
    ns1:documentadoEn ns1:PosicionDelPuntoDeReferenciaParaCadaEje ;
    ns1:textoExtracto "El punto de referencia máquina es un punto de la máquina fijado por el fabricante y referenciado respecto al cero máquina." .

ns1:SubrutinaDeBusquedaDeReferenciaAsociadaALaFuncionG74 a ns1:Parametro ;
    rdfs:label "Subrutina de búsqueda de referencia asociada a la función G74" ;
    ns1:identificador "REFPSUB" ;
    ns1:textoExtracto "Este tipo sólo disponible cuando esta definida la subrutina de búsqueda de referencia asociada a la función G74 (parámetro REFPSUB)." .

ns1:PosicionDelPuntoDeReferenciaParaCadaEje a ns1:Parametro ;
    rdfs:label "Posición del punto de referencia para cada eje" ;
    ns1:identificador "REFVALUE" ;
    ns1:textoExtracto "La posición del punto de referencia, para cada eje, se parametriza en el parámetro REFVALUE." .

