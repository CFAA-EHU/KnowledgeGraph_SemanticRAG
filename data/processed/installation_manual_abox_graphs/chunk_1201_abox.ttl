@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SubrutinaCambioHerramienta_1201 a ex:TareaMantenimiento ;
    rdfs:label "Subrutina asociada al cambio de herramienta (función T)" ;
    ex:textoExtracto "La subrutina asociada a la herramienta se ejecuta automáticamente cada vez que se ejecuta una función T (selección de herramienta)." ;
    ex:ejecutadoPor ex:CNC_1201 .

ex:CNC_1201 a ex:Maquina ;
    rdfs:label "CNC" ;
    ex:textoExtracto "Cuando el CNC selecciona una herramienta, la rutina asociada a T ejecuta la función M06 (cambio de herramienta)." .

ex:FuncionT_1201 a ex:ModoOperacion ;
    rdfs:label "función T" ;
    ex:textoExtracto "La subrutina asociada a la herramienta se ejecuta automáticamente cada vez que se ejecuta una función T (selección de herramienta)." .

ex:FuncionM06_1201 a ex:ModoOperacion ;
    rdfs:label "función M06" ;
    ex:textoExtracto "Si dentro de esta subrutina se incluye la función M06, el proceso de carga de la herramienta se realizará cuando se ejecuta el código 'T'." .