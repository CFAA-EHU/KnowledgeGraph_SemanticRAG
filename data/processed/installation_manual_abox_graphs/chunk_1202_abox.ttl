@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CoordenadaXDelCeroMaquina a ns1:Parametro ;
    rdfs:label "Coordenada X del cero máquina" ;
    ns1:identificador "XMW" ;
    ns1:textoExtracto "Coordenadas del cero máquina XMW, YMW, ZMW" .

ns1:CoordenadaXDelCeroPieza a ns1:Parametro ;
    rdfs:label "Coordenada X del cero pieza" ;
    ns1:identificador "XMH" ;
    ns1:textoExtracto "Coordenadas del cero pieza XMH, YMH, ZMH" .

ns1:CoordenadaYDelCeroMaquina a ns1:Parametro ;
    rdfs:label "Coordenada Y del cero máquina" ;
    ns1:identificador "YMW" ;
    ns1:textoExtracto "Coordenadas del cero máquina XMW, YMW, ZMW" .

ns1:CoordenadaYDelCeroPieza a ns1:Parametro ;
    rdfs:label "Coordenada Y del cero pieza" ;
    ns1:identificador "YMH" ;
    ns1:textoExtracto "Coordenadas del cero pieza XMH, YMH, ZMH" .

ns1:CoordenadaZDelCeroMaquina a ns1:Parametro ;
    rdfs:label "Coordenada Z del cero máquina" ;
    ns1:identificador "ZMW" ;
    ns1:textoExtracto "Coordenadas del cero máquina XMW, YMW, ZMW" .

ns1:CoordenadaZDelCeroPieza a ns1:Parametro ;
    rdfs:label "Coordenada Z del cero pieza" ;
    ns1:identificador "ZMH" ;
    ns1:textoExtracto "Coordenadas del cero pieza XMH, YMH, ZMH" .

