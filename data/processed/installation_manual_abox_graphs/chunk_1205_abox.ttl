@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_e955f6d2a2 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "hasta que el CNC recibe un impulso de I0 del sistema de captación." .

ns1:MicroDeReferenciaMaquina a ns1:Componente ;
    rdfs:label "Micro de referencia máquina" ;
    ns1:textoExtracto "Si antes de recibir la señal del I0 el eje pulsa el micro de referencia máquina, este invierte el sentido y continúa con el proceso, alejándose del micro, hasta que el CNC recibe un impulso de I0 del sistema de captación." .

ns1:RedefinirPuntoDeReferenciaMaquina a ns1:TareaMantenimiento ;
    rdfs:label "Redefinir punto de referencia máquina" ;
    ns1:textoExtracto "Redefinir el punto de referencia máquina tras soltar el sistema de captación." .

ns1:SistemaCaptacion a ns1:Sistema ;
    rdfs:label "Sistema de captación" ;
    ns1:textoExtracto "Si antes de recibir la señal del I0 el eje pulsa el micro de referencia máquina, este invierte el sentido y continúa con el proceso, alejándose del micro, hasta que el CNC recibe un impulso de I0 del sistema de captación." .

