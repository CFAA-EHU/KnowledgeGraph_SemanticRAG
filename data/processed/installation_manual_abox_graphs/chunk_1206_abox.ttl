@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:OffsetDelPuntoDeReferencia_c4d36c80a6 a ns1:Parametro ;
    rdfs:label "Offset del punto de referencia" ;
    ns1:textoExtracto "En el parámetro REFSHIFT se debe indicar la diferencia existente entre ambos puntos, el anterior y el actual. De esta manera, cuando el eje encuentra el I0, se desplaza el valor indicado en REFSHIFT y en ese punto actualiza su cota al valor de REFVALUE." .

ns1:PosicionDelPuntoDeReferencia_0e80f1f6e4 a ns1:Parametro ;
    rdfs:label "Posición del punto de referencia" ;
    ns1:textoExtracto "En el parámetro REFSHIFT se debe indicar la diferencia existente entre ambos puntos, el anterior y el actual. De esta manera, cuando el eje encuentra el I0, se desplaza el valor indicado en REFSHIFT y en ese punto actualiza su cota al valor de REFVALUE." .

ns1:VelocidadRapidaDeBusquedaDeReferencia_1ce8273eec a ns1:Parametro ;
    rdfs:label "Velocidad rápida de búsqueda de referencia" ;
    ns1:textoExtracto "La búsqueda de referencia la realiza el servo y el micro de referencia debe estar cableado al servo. El procedimiento de referencia sigue la siguiente secuencia." .

