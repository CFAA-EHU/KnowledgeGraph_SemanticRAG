@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SubrutinaAsociadaM a ex:ModoOperacion ;
    rdfs:label "Subrutina asociada a función M" ;
    ex:textoExtracto "Las funciones auxiliares \"M\" pueden tener una subrutina asociada, que el CNC ejecutará en lugar de la función." .

ex:CNC a ex:Maquina ;
    rdfs:label "CNC" ;
    ex:textoExtracto "el CNC ejecutará en lugar de la función" .

ex:FuncionM a ex:ModoOperacion ;
    rdfs:label "Función M" ;
    ex:textoExtracto "funciones auxiliares \"M\""@es, "función \"M\""@es .