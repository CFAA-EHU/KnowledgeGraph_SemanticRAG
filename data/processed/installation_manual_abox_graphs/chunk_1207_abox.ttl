@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FuncionAuxiliar_M a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "Función auxiliar M"@es ;
    ex:textoExtracto "Las funciones auxiliares \"M\" pueden tener una subrutina asociada, que el CNC ejecutará en lugar de la función."@es ;
    ex:identificador "M" .

ex:SubrutinaAsociada_M
    a ex:TareaMantenimiento ;
    rdfs:label "Subrutina asociada a función M"@es ;
    ex:textoExtracto "Las funciones auxiliares \"M\" pueden tener una subrutina asociada, que el CNC ejecutará en lugar de la función."@es ;
    ex:ejecutadoPor ex:FuncionAuxiliar_M .