@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_d51ff8b30d a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC realizará una nueva búsqueda de referencia del cabezal en las siguientes circunstancias." ;
    ns1:tieneComponente ns1:CabezalReferenciado,
        ns1:EjeEsclavo,
        ns1:EjeMaestro .

ns1:DefinidoConValorDistintoDe0ParaTenerEnCuentaElParametroREFINI a ns1:Parametro ;
    rdfs:label "Definido con valor distinto de 0 para tener en cuenta el parámetro REFINI" ;
    ns1:identificador "NPULSES" ;
    ns1:textoExtracto "Este parámetro sólo se tiene en cuenta cuando los parámetros NPULSES y NPULSES2 se han definido con valor distinto de 0." .

ns1:DefinidoConValorDistintoDe0ParaTenerEnCuentaElParametroREFINI_922111d7b5 a ns1:Parametro ;
    rdfs:label "Definido con valor distinto de 0 para tener en cuenta el parámetro REFINI" ;
    ns1:identificador "NPULSES2" ;
    ns1:textoExtracto "Este parámetro sólo se tiene en cuenta cuando los parámetros NPULSES y NPULSES2 se han definido con valor distinto de 0." .

ns1:EjeAnalogico a ns1:ComponenteMecanico ;
    rdfs:label "Eje analógico" ;
    ns1:textoExtracto "Si se programa una búsqueda de cero de varios ejes analógicos en paralelo, es decir, con el mismo índice (por ejemplo \"G74 X1 Y1 Z1\")." .

ns1:EstableceSiElCNCHaceUnaBusquedaDeReferenciaDelCabezalConSuPrimerMovimiento a ns1:Parametro ;
    rdfs:label "Establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento" ;
    ns1:identificador "REFINI" ;
    ns1:textoExtracto "El parámetro REFINI establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento." .

ns1:CabezalReferenciado a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal referenciado" ;
    ns1:textoExtracto "Si el cabezal está referenciado, las paradas orientadas del cabezal en M19 no fuerzan una nueva búsqueda de referencia." .

ns1:EjeEsclavo a ns1:ComponenteMecanico ;
    rdfs:label "Eje esclavo" ;
    ns1:textoExtracto "En un sistema tándem, sólo se referencia el eje maestro; la búsqueda de cero es transparente para el esclavo que simplemente acompaña al maestro." .

ns1:EjeMaestro a ns1:ComponenteMecanico ;
    rdfs:label "Eje maestro" ;
    ns1:textoExtracto "En un sistema tándem, sólo se referencia el eje maestro; la búsqueda de cero es transparente para el esclavo que simplemente acompaña al maestro." .

