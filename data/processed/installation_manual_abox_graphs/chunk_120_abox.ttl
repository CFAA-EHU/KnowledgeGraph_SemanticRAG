@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_MT ex:textoExtracto "El parámetro máquina de la tabla de funciones –M– MTIME indica el tiempo estimado para la ejecución de una función M." ;
    rdfs:label "MTIME" ;
    a ex:Parametro ;
    ex:valor "tiempo estimado para la ejecución de una función M" .

ex:Parametro_SPDLTIME ex:textoExtracto "El parámetro máquina de cabezales SPDLTIME indica el tiempo estimado para la ejecución de una función S." ;
    rdfs:label "SPDLTIME" ;
    a ex:Parametro ;
    ex:valor "tiempo estimado para la ejecución de una función S" .