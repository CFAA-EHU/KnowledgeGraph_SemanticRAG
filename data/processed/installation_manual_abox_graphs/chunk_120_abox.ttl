@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjeDeCompensacion a ns1:Parametro ;
    rdfs:label "Eje de compensación" ;
    ns1:textoExtracto "Este parámetro muestra la lista de puntos y valores de compensación. El CNC sólo permite acceder a esta tabla cuando están definidos los parámetros MOVAXIS, COMPAXIS y NPCROSS." .

ns1:EjeQueSeMueve a ns1:Parametro ;
    rdfs:label "Eje que se mueve" ;
    ns1:textoExtracto "Este parámetro muestra la lista de puntos y valores de compensación. El CNC sólo permite acceder a esta tabla cuando están definidos los parámetros MOVAXIS, COMPAXIS y NPCROSS." .

ns1:ErrorNegativoEnLaPosicion a ns1:Parametro ;
    rdfs:label "Error negativo en la posición" ;
    ns1:textoExtracto "El parámetro NEGERROR sólo se muestra si se ha definido la tabla con compensación bidireccional (BIDIR = Sí)." .

ns1:ErrorPositivoEnLaPosicion a ns1:Parametro ;
    rdfs:label "Error positivo en la posición" ;
    ns1:textoExtracto "Para cada uno de los puntos se deben definir los parámetros POSITION, POSERROR y NEGERROR." .

ns1:NumeroDePuntos a ns1:Parametro ;
    rdfs:label "Número de puntos" ;
    ns1:textoExtracto "El número de puntos viene definido por el parámetro NPCROSS." .

ns1:PosicionDelEjeQueSeMueve a ns1:Parametro ;
    rdfs:label "Posición del eje que se mueve" ;
    ns1:textoExtracto "Para cada uno de los puntos se deben definir los parámetros POSITION, POSERROR y NEGERROR." .

