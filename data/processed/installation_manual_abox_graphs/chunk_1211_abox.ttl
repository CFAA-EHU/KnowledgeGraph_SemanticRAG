@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MicroDeReferencia_b388e4eaf9 a ns1:Parametro ;
    rdfs:label "Micro de referencia" ;
    ns1:identificador "DECINPUT" ;
    ns1:textoExtracto "podrán tener micro de referencia (parámetro DECINPUT) ambos ejes o sólo el eje maestro." .

ns1:SistemaCaptacionReferencia a ns1:Sistema ;
    rdfs:label "Sistema de captación que no dispone de I0s codificados" ;
    ns1:textoExtracto "Búsqueda de referencia con un sistema de captación que no dispone de I0s codificados. Los ejes maestro y esclavo tienen micro." ;
    ns1:tieneComponente ns1:EjeGantryEsclavo,
        ns1:EjeGantryMaestro .

ns1:TipoDeI0 a ns1:Parametro ;
    rdfs:label "Tipo de I0" ;
    ns1:identificador "I0TYPE" ;
    ns1:textoExtracto "El tipo de I0 (parámetro I0TYPE) deberá ser en ambos ejes el mismo." .

ns1:EjeGantryEsclavo a ns1:ComponenteMecanico ;
    rdfs:label "Eje Gantry Esclavo" ;
    ns1:textoExtracto "Los ejes maestro y esclavo tienen micro." .

ns1:EjeGantryMaestro a ns1:ComponenteMecanico ;
    rdfs:label "Eje Gantry Maestro" ;
    ns1:textoExtracto "Los ejes maestro y esclavo tienen micro." .

