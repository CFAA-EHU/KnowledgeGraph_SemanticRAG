PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SubrutinasInterrupcion_1213
    a                  ex:Sistema ;
    rdfs:label         "Subrutinas de interrupción"@es ;
    ex:textoExtracto   "Las subrutinas de interrupción las define el fabricante de la máquina y se ejecutan desde el PLC. Cuando el PLC ordena la ejecución de una de estas subrutinas, el canal interrumpe la ejecución del programa y ejecuta la subrutina de interrupción correspondiente."@es ;
    ex:controla        ex:PLC_1213 .

ex:PLC_1213
    a                  ex:ComponenteElectrico ;
    rdfs:label         "PLC"@es ;
    ex:textoExtracto   "el PLC. Cuando el PLC ordena la ejecución de una de estas subrutinas"@es .