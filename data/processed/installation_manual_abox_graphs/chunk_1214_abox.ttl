@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_INT1SUB_CHN
    a               ex:Parametro ;
    rdfs:label      "INT1SUB CHN" ;
    ex:identificador "INT1SUB" ;
    ex:textoExtracto "INT1SUB CHN [...] Subrutinas de interrupción. [CHN].......Parámetro máquina; general del canal. Nombre y ubicación de la subrutina." ;
    ex:valor         "Nombre y ubicación de la subrutina de interrupción para el canal" .

ex:Parametro_INIT1SUB
    a               ex:Parametro ;
    rdfs:label      "INIT1SUB" ;
    ex:identificador "INIT1SUB" ;
    ex:textoExtracto "Estas subrutinas deben estar definidas en los parámetros generales INIT1SUB a INIT4SUB" ;
    ex:valor         "Definición de subrutina de inicialización 1" .

ex:Parametro_INIT4SUB
    a               ex:Parametro ;
    rdfs:label      "INIT4SUB" ;
    ex:identificador "INIT4SUB" ;
    ex:textoExtracto "Estas subrutinas deben estar definidas en los parámetros generales INIT1SUB a INIT4SUB" ;
    ex:valor         "Definición de subrutina de inicialización 4" .

ex:Tabla_14_13_1_Subrutinas a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla 14.13.1 - Parámetros de subrutinas de interrupción" ;
    ex:textoExtracto "Asignar las subrutinas a las funciones. | Parámetro. | Significado. | INT1SUB CHN [...] Subrutinas de interrupción. [CHN].......Parámetro máquina; general del canal." ;
    ex:documentadoEn ex:Pagina_652 .

ex:Pagina_652
    a               ex:Pagina ;
    rdfs:label      "Página 652 - Sección 14.13.1 Configurar las subrutinas" ;
    ex:identificador "652" ;
    ex:textoExtracto "Asignar las subrutinas a las funciones. [...] Estas subrutinas deben estar definidas en los parámetros generales INIT1SUB a INIT4SUB y estarán guardadas en la carpeta ..\\Mtb\\Sub." .