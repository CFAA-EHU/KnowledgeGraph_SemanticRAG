@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceDeReferencia1DelEjeMaestro a ns1:Parametro ;
    rdfs:label "Avance de referencia 1 del eje maestro" ;
    ns1:identificador "REFFEED1" ;
    ns1:textoExtracto "Este desplazamiento se realiza al avance indicado en el parámetro REFFEED1 del eje maestro." .

ns1:AvanceDeReferencia2DelEjeMaestro a ns1:Parametro ;
    rdfs:label "Avance de referencia 2 del eje maestro" ;
    ns1:identificador "REFFEED2" ;
    ns1:textoExtracto "ambos ejes se desplazan al avance REFFEED2 del eje maestro hasta que el eje esclavo encuentre el I0." .

ns1:DesplazamientoDeReferencia_0a6815684c a ns1:Parametro ;
    rdfs:label "Desplazamiento de referencia" ;
    ns1:identificador "REFSHIF" ;
    ns1:textoExtracto "teniendo en cuenta también el parámetro REFSHIFT." .

ns1:DireccionDeReferenciaDelEjeMaestro a ns1:Parametro ;
    rdfs:label "Dirección de referencia del eje maestro" ;
    ns1:identificador "REFDIREC" ;
    ns1:textoExtracto "El CNC comenzará el desplazamiento de ambos ejes en el sentido indicado por el parámetro REFDIREC del eje maestro." .

ns1:ValorDeReferenciaInicial a ns1:Parametro ;
    rdfs:label "Valor de referencia inicial" ;
    ns1:identificador "REFVALUE" ;
    ns1:textoExtracto "el eje esclavo inicializa su cota con el valor definido en el parámetro REFVALUE." .

