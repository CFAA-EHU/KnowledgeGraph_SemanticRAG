@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceDeReferencia a ns1:Parametro ;
    rdfs:label "Avance de referencia" ;
    ns1:identificador "REFFEED2" ;
    ns1:textoExtracto "avance indicado en el parámetro REFFEED2 del eje maestro" .

ns1:DesplazamientoDeReferencia_ae6acabd2f a ns1:Parametro ;
    rdfs:label "Desplazamiento de referencia" ;
    ns1:identificador "REFSHIFT" ;
    ns1:textoExtracto "teniendo en cuenta también el parámetro REFSHIFT" .

ns1:DireccionDeReferencia a ns1:Parametro ;
    rdfs:label "Dirección de referencia" ;
    ns1:identificador "REFDIREC" ;
    ns1:textoExtracto "indicado por el parámetro REFDIREC del eje maestro" .

ns1:ReguladorReferencia a ns1:ComponenteElectrico ;
    rdfs:label "Regulador para referenciar el eje esclavo" ;
    ns1:textoExtracto "El CNC envía al regulador la orden de referenciar el eje esclavo." .

ns1:SistemaCaptacionReferencia a ns1:Sistema ;
    rdfs:label "Sistema de captación que dispone de I0s codificados o donde ningún eje dispone de micro" ;
    ns1:textoExtracto "Búsqueda de referencia con un sistema de captación que dispone de I0s codificados o donde ningún eje dispone de micro." .

ns1:ValorDeReferencia_8ad75138b6 a ns1:Parametro ;
    rdfs:label "Valor de referencia" ;
    ns1:identificador "REFVALUE" ;
    ns1:textoExtracto "el valor definido en el parámetro REFVALUE" .

