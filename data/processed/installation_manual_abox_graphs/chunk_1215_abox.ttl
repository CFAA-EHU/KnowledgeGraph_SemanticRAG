@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla_1215_652 a ex:Tabla ;
    ex:textoExtracto "Las siguientes variables son accesibles desde; (PRG) el programa pieza y desde el modo MDI/MDA, PLC e (INT) una aplicación externa. La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W). | Variable. | PRG | PLC | INT | | --- | --- | --- | --- | | (V.)[ch].MPG.INT1SUB (V.)[ch].MPG.INT2SUB (V.)[ch].MPG.INT3SUB (V.)[ch].MPG.INT4SUB Subrutinas de interrupción. Unidades: Texto. | - | - | R | Sintaxis. ꞏchꞏ Número de canal. | [2].MPG.INT1SUB | Canal ꞏ2ꞏ. |" ;
    ex:tieneComponente ex:Variable_MPG_INT1SUB, ex:Variable_MPG_INT2SUB, ex:Variable_MPG_INT3SUB, ex:Variable_MPG_INT4SUB .

ex:Variable_MPG_INT1SUB a ex:Parametro ;
    ex:identificador "[ch].MPG.INT1SUB" ;
    ex:textoExtracto "(V.)[ch].MPG.INT1SUB" .

ex:Variable_MPG_INT2SUB a ex:Parametro ;
    ex:identificador "[ch].MPG.INT2SUB" ;
    ex:textoExtracto "(V.)[ch].MPG.INT2SUB" .

ex:Variable_MPG_INT3SUB a ex:Parametro ;
    ex:identificador "[ch].MPG.INT3SUB" ;
    ex:textoExtracto "(V.)[ch].MPG.INT3SUB" .

ex:Variable_MPG_INT4SUB a ex:Parametro ;
    ex:identificador "[ch].MPG.INT4SUB" ;
    ex:textoExtracto "(V.)[ch].MPG.INT3SUB" .