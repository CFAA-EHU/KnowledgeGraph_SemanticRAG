@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_df56588584 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC envía al regulador la orden de referenciar el eje esclavo." .

ns1:CotaRealEjeEsclavo a ns1:Parametro ;
    rdfs:label "Cota real del eje esclavo" ;
    ns1:textoExtracto "el CNC lee el incremento en la cota real del eje esclavo y la envía al eje maestro como incremento de la cota teórica." .

ns1:CotaTeoricaEjeMaestro a ns1:Parametro ;
    rdfs:label "Cota teórica del eje maestro" ;
    ns1:textoExtracto "haciendo así que el eje maestro siga al esclavo con tan solo el retraso entre la cota teórica y la real." .

ns1:ReguladorEjeEsclavo a ns1:ComponenteElectrico ;
    rdfs:label "Regulador del eje esclavo" ;
    ns1:textoExtracto "El CNC envía al regulador la orden de referenciar el eje esclavo." .

