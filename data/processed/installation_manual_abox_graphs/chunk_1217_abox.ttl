@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_INITIALSUB_CHN rdfs:label "INITIALSUB CHN" ;
    a ex:Parametro ;
    ex:textoExtracto "Parámetro. |  | Significado. | | --- | --- | --- | | INITIALSUB CHN |  | Subrutina asociada al comando #INITIALSUB." ;
    ex:valor "INITIALSUB CHN" .

ex:Subrutina_Initialsub_fst rdfs:label "Initialsub.fst" ;
    a ex:Componente ;
    ex:textoExtracto "Esta subrutina debe estar definida en el parámetro general INITIALSUB (por defecto Initialsub.fst) y estará guardada en la carpeta ..\\Mtb\\Sub." .

ex:Carpeta_Mtb_Sub rdfs:label "..\\Mtb\\Sub" ;
    a ex:Sistema ;
    ex:textoExtracto "el CNC copia las subrutinas a la carpeta ..\\Mtb\\Sub si no existen" .

ex:Comando_INISUB rdfs:label "#INITIALSUB" ;
    a ex:Parametro ;
    ex:textoExtracto "Subrutina asociada al comando #INITIALSUB." .

ex:Sistema_CNC rdfs:label "CNC" ;
    a ex:Maquina ;
    ex:textoExtracto "el CNC actúa de la siguiente manera", "el CNC siempre actualiza las subrutinas", "el CNC carga esta subrutina en la memoria RAM del CNC" .

ex:Parametro_INISUB rdfs:label "INITIALSUB" ;
    a ex:Parametro ;
    ex:textoExtracto "definida en el parámetro general INITIALSUB (por defecto Initialsub.fst)" .

ex:Subrutina_OEM_fst rdfs:label "subrutina OEM con extensión fst" ;
    a ex:Componente ;
    ex:textoExtracto "Al ser una subrutina OEM con extensión fst, el CNC carga esta subrutina en la memoria RAM del CNC." .