@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_9556735fce a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:EjeEsclavo,
        ns1:EjeMaestro ;
    ns1:monitoreaParametro ns1:AvanceDeBusquedaDeReferencia,
        ns1:CorreccionDeDiferenciaDeCota ;
    ns1:textoExtracto "el CNC envía al regulador la orden de referenciar el eje maestro" .

ns1:AvanceDeBusquedaDeReferencia a ns1:Parametro ;
    rdfs:label "avance de búsqueda de referencia" ;
    ns1:identificador "REFFEED1" ;
    ns1:textoExtracto "el CNC vigila que el incremento de la cota real se corresponda como máximo al avance de búsqueda de referencia (parámetro REFFEED1)" .

ns1:CorreccionDeDiferenciaDeCota a ns1:Parametro ;
    rdfs:label "corrección de diferencia de cota" ;
    ns1:identificador "DIFFCOMP" ;
    ns1:textoExtracto "El parámetro DIFFCOMP habilita la corrección de la diferencia de cota entre el eje maestro y el esclavo tras la búsqueda de referencia máquina." .

ns1:EjeEsclavo a ns1:ComponenteMecanico ;
    rdfs:label "Eje Esclavo" ;
    ns1:textoExtracto "el eje esclavo se moverá hasta alcanzar la cota del eje maestro" .

ns1:EjeMaestro a ns1:ComponenteMecanico ;
    rdfs:label "Eje Maestro" ;
    ns1:textoExtracto "la envía al eje maestro como incremento de la cota teórica" .

