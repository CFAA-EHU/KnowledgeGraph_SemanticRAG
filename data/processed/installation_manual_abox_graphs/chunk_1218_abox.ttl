@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDelServo a ns1:Parametro ;
    rdfs:label "Estado del servo" ;
    ns1:identificador "SERVO(axis)ON" ;
    ns1:textoExtracto "Con el flanco de subida de SERVO(axis)ON si DIFFCOMP(axis) está activa." .

ns1:Parametro_02061a6ef4 a ns1:Parametro ;
    rdfs:label "Marca de referencia del eje" ;
    ns1:identificador "REFPOIN(axis)" ;
    ns1:textoExtracto "La marca REFPOIN(axis) de ambos ejes se activa cuando termina la corrección de la cota." .

ns1:Parametro_951477d4ee a ns1:Parametro ;
    rdfs:label "Marca que corrige la diferencia de cota entre el eje maestro y esclavo" ;
    ns1:identificador "DIFFCOMP(axis)" ;
    ns1:textoExtracto "La marca DIFFCOMP(axis) corrige la diferencia de cota entre el eje maestro y esclavo, de la siguiente manera." .

