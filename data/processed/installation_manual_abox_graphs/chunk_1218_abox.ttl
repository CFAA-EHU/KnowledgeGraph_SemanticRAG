@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_14_14_2_Variables a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de variables accesibles desde PRG, MDI/MDA, PLC e INT"@es ;
    ex:textoExtracto "Las siguientes variables son accesibles desde; (PRG) el programa pieza y desde el modo MDI/MDA, PLC e (INT) una aplicación externa. La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W)."@es ;
    ex:identificador "14.14.2" .

ex:Variable_MPG_INITIALSUB
    a               ex:Parametro ;
    rdfs:label      "MPG.INITIALSUB" ;
    ex:textoExtracto "Subrutina asociada al comando #INITIALSUB. Unidades: Texto."@es ;
    ex:valor         "Texto" ;
    ex:documentadoEn ex:Tabla_14_14_2_Variables ;
    ex:identificador "[ch].MPG.INITIALSUB" .

ex:Canal_2
    a               ex:InterfazUsuario ;
    rdfs:label      "Canal 2"@es ;
    ex:textoExtracto "ꞏchꞏ Número de canal. | [2].MPG.INITIALSUB | Canal ꞏ2ꞏ."@es ;
    ex:identificador "2" .