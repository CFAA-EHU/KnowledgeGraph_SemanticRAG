@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla1218_1 a ex:Tabla ;
    ex:textoExtracto "Las siguientes variables son accesibles desde; (PRG) el programa pieza y desde el modo MDI/MDA, PLC e (INT) una aplicación externa. La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W). | Variable. | PRG | PLC | INT | | --- | --- | --- | --- | | (V.)[ch].MPG.INITIALSUB Subrutina asociada al comando #INITIALSUB. Unidades: Texto. | - | - | R | Sintaxis. ꞏchꞏ Número de canal. | [2].MPG.INITIALSUB | Canal ꞏ2ꞏ."@es .

ex:Variable_MPG_INITIALSUB a ex:Parametro ;
    ex:textoExtracto "(V.)[ch].MPG.INITIALSUB Subrutina asociada al comando #INITIALSUB. Unidades: Texto."@es ;
    ex:valor "Texto"@es ;
    ex:identificador "[ch].MPG.INITIALSUB" ;
    ex:identificador "[2].MPG.INITIALSUB" .

ex:Tabla1218_1 a ex:Tabla ;
    ex:tieneComponente ex:Variable_MPG_INITIALSUB .