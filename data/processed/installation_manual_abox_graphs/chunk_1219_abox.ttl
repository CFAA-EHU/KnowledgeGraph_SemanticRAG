@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_88111a6eb0 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documenta ns1:AjusteManualDeEjes ;
    ns1:solucionaFallo ns1:AvisoSeguridad_3003784ca3 ;
    ns1:textoExtracto "El CNC permite definir límites de software en los ejes lineales y ejes rotativos." .

ns1:LimiteSuperiorDeSoftware1 a ns1:Parametro ;
    rdfs:label "Límite superior de software 1" ;
    ns1:identificador "SL1" ;
    ns1:textoExtracto "De los cuatro límites de software que pueden existir en cada eje, el CNC aplicará el límite superior e inferior más restrictivo." .

ns1:LimiteSuperiorDeSoftware2 a ns1:Parametro ;
    rdfs:label "Límite superior de software 2" ;
    ns1:identificador "SL2" ;
    ns1:textoExtracto "De los cuatro límites de software que pueden existir en cada eje, el CNC aplicará el límite superior e inferior más restrictivo." .

ns1:AjusteManualDeEjes a ns1:TareaMantenimiento ;
    rdfs:label "Ajuste manual de ejes" ;
    ns1:textoExtracto "Para llevar el eje a la zona permitida, acceder al modo manual y mover el eje o cabezal que ha sobrepasado el límite." .

ns1:AvisoSeguridad_3003784ca3 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de límites de software" ;
    ns1:textoExtracto "Si se programa una posición en la que el punto de referencia del portaherramientas sale de los límites de software, el CNC detiene la ejecución y muestra el error correspondiente." .

