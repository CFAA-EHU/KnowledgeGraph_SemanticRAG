@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ElEjeHaAlcanzadoElLimiteInferiorDeSoftware a ns1:Parametro ;
    rdfs:label "El eje ha alcanzado el límite inferior de software" ;
    ns1:identificador "LIMITNEG" ;
    ns1:textoExtracto "LIMITNEG(axis) El eje ha alcanzado el límite inferior de software." .

ns1:ElEjeHaAlcanzadoElLimiteSuperiorDeSoftware a ns1:Parametro ;
    rdfs:label "El eje ha alcanzado el límite superior de software" ;
    ns1:identificador "LIMITPOS" ;
    ns1:textoExtracto "LIMITPOS(axis) El eje ha alcanzado el límite superior de software." .

ns1:LimitesDeSoftwareAlcanzados a ns1:Parametro ;
    rdfs:label "Límites de software alcanzados" ;
    ns1:identificador "G.SOFTLIMIT" ;
    ns1:textoExtracto "(V.)[ch].G.SOFTLIMIT Límites de software alcanzados." .

