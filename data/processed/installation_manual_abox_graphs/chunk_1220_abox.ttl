@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_PIERCING_CHN rdfs:label "PIERCING CHN" ;
    a ex:Parametro ;
    ex:textoExtracto "Parámetro máquina; general del canal. Nombre y ubicación de la subrutina. Esta subrutina debe estar definida en el parámetro general PIERCING (por defecto Piercing.fst) y estará guardada en la carpeta ..\\Mtb\\Sub." ;
    ex:valor "PIERCING CHN" .

ex:Subrutina_Piercing_fst rdfs:label "Piercing.fst" ;
    a ex:Componente ;
    ex:textoExtracto "Subrutina asociada al comando #PIERCING. [...] el CNC carga esta subrutina en la memoria RAM del CNC. [...] subrutina OEM con extensión fst." ;
    ex:identificador "Piercing.fst" .

ex:Sistema_CNC rdfs:label "CNC" ;
    a ex:Maquina ;
    ex:textoExtracto "el CNC actúa de la siguiente manera. [...] el CNC siempre actualiza las subrutinas. [...] el CNC carga esta subrutina en la memoria RAM del CNC." .

ex:Esquema_ConfigurarSubrutinas rdfs:label "Configurar subrutinas" ;
    a ex:Esquema ;
    ex:textoExtracto "Si se actualiza la versión, el CNC actúa de la siguiente manera. [...] Asignar la subrutina al comando. | Parámetro. |  | Significado. | [...] PIERCING CHN |  | Subrutina asociada al comando #PIERCING." ;
    ex:compuestoPor ex:Parametro_PIERCING_CHN, ex:Subrutina_Piercing_fst ;
    ex:detalladoEnEsquema ex:Sistema_CNC .