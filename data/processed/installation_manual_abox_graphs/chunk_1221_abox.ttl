@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla_1221_655 a ex:Tabla ;
    ex:textoExtracto "Las siguientes variables son accesibles desde; (PRG) el programa pieza y desde el modo MDI/MDA, PLC e (INT) una aplicación externa. La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W). | Variable. | PRG | PLC | INT | | --- | --- | --- | --- | | (V.)[ch].MPG.PIERCING Subrutina asociada al comando #PIERCING. Unidades: Texto. | - | - | R | Sintaxis. ꞏchꞏ Número de canal. | [2].MPG.PIERCING | Canal ꞏ2ꞏ. |" .

ex:Variable_MPG_PIERCING a ex:Parametro ;
    ex:identificador "[ch].MPG.PIERCING" ;
    ex:textoExtracto "(V.)[ch].MPG.PIERCING Subrutina asociada al comando #PIERCING. Unidades: Texto." ;
    ex:valor "Texto" ;
    ex:tieneFrecuencia ex:Frecuencia_Acceso_INT_lectura .

ex:Frecuencia_Acceso_INT_lectura a ex:Frecuencia ;
    ex:textoExtracto "Acceso de lectura (R) desde (INT) una aplicación externa." ;
    ex:valor "R" .