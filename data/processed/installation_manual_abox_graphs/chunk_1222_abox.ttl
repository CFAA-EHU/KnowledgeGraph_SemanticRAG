@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SubrutinaCuttingON a ex:TareaMantenimiento ;
    rdfs:label "subrutina asociada a #CUTTING ON" ;
    ex:textoExtracto "El comando #CUTTINGON ejecuta la subrutina que tiene asociada después de actualizar las variables del cutting ((V.)TTCUT.name)." .

ex:SubrutinaCuttingOFF a ex:TareaMantenimiento ;
    rdfs:label "subrutina asociada a #CUTTING OFF" ;
    ex:textoExtracto "El comando #CUTTING OFF sólo ejecuta la subrutina que tiene asociada." .

ex:MarcaCUTTING a ex:Parametro ;
    rdfs:label "marca CUTTING" ;
    ex:textoExtracto "El OEM debe activar la marca CUTTING (asignarle valor 1) para indicar al PLC que empieza la operación de cutting. Al final de la subrutina asociada a #CUTTING OFF (o cuando el OEM lo considere necesario), el OEM debe desactivar esta marca (asignarle valor 0) para indicar al CNC que ha finalizado la operación de piercing." .

ex:VariableTTCUT_name a ex:Parametro ;
    rdfs:label "variable (V.)TTCUT.name" ;
    ex:textoExtracto "El comando #CUTTINGON ejecuta la subrutina que tiene asociada después de actualizar las variables del cutting ((V.)TTCUT.name)." .

ex:VariableV_PLC_CUTTING a ex:Parametro ;
    rdfs:label "variable V.PLC.CUTTING" ;
    ex:textoExtracto "Esta marca refleja el estado de la variable V.PLC.CUTTING." .