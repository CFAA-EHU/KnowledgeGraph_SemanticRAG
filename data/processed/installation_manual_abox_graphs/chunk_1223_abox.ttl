@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_65f336f2f1 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:ManualDeProgramacion ;
    ns1:textoExtracto "Modificar los límites de software mediante las funciones G198/G199." .

ns1:InterfazParaDefinirLimitesDeSoftware a ns1:InterfazUsuario ;
    rdfs:label "Interfaz para definir límites de software" ;
    ns1:textoExtracto "Segundos límites de software. Estos límites de software se definen mediante las siguientes variables, con permiso de escritura desde el programa pieza, MDI, PLC o interfaz." .

ns1:ModoDeCoordenadasAbsolutas a ns1:Parametro ;
    rdfs:label "Modo de coordenadas absolutas" ;
    ns1:identificador "G90" ;
    ns1:textoExtracto "Dependiendo del modo de trabajo activo G90 ó G91, la posición de los nuevos límites estará definida en coordenadas absolutas (G90) en el sistema de referencia de la máquina." .

ns1:ModoDeCoordenadasIncrementales a ns1:Parametro ;
    rdfs:label "Modo de coordenadas incrementales" ;
    ns1:identificador "G91" ;
    ns1:textoExtracto "Dependiendo del modo de trabajo activo G90 ó G91, la posición de los nuevos límites estará definida en coordenadas absolutas (G90) en el sistema de referencia de la máquina." .

ns1:Parametro_cade1166a9 a ns1:Parametro ;
    rdfs:label "Función para definir nuevos límites superiores de software" ;
    ns1:identificador "G199" ;
    ns1:textoExtracto "G199 X1000 Y1000 (Nuevos límites superiores X=1000 Y=1000)" .

ns1:Parametro_d2d16381ca a ns1:Parametro ;
    rdfs:label "Función para definir nuevos límites inferiores de software" ;
    ns1:identificador "G198" ;
    ns1:textoExtracto "G198 X-1000 Y-1000 (Nuevos límites inferiores X=-1000 Y=-1000)" .

