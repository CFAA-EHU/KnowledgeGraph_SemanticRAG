@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Subrutina_CUTTINGON_CHN a ex:Parametro ;
    rdfs:label "CUTTINGON CHN" ;
    ex:textoExtracto "Subrutina asociada al comando #CUTTING ON." ;
    ex:valor "Cuttingon.fst" ;
    ex:identificador "CUTTINGON CHN" .

ex:Subrutina_CUTTINGOFF_CHN a ex:Parametro ;
    rdfs:label "CUTTINGOFF CHN" ;
    ex:textoExtracto "Subrutina asociada al comando #CUTTING OFF." ;
    ex:valor "Cuttingoff.fst" ;
    ex:identificador "CUTTINGOFF CHN" .

ex:CNC a ex:Maquina ;
    ex:textoExtracto "el CNC actúa de la siguiente manera" .

ex:Carpeta_Mtb_Sub a ex:Componente ;
    ex:textoExtracto "el CNC sólo copia las subrutinas a la carpeta ..\\Mtb\\Sub si no existen" .

ex:Parametro_Canal a ex:Parametro ;
    ex:textoExtracto "[CHN].......Parámetro máquina; general del canal. Nombre y ubicación de la subrutina." ;
    ex:identificador "CHN" .

ex:Subrutina_OEM_fst a ex:Parametro ;
    ex:textoExtracto "Al ser una subrutina OEM con extensión fst, el CNC carga esta subrutina en la memoria RAM del CNC." .

ex:Esquema_Configurar_Subrutinas a ex:Esquema ;
    ex:textoExtracto "Si se actualiza la versión, el CNC actúa de la siguiente manera. • En las dos primeras opciones de instalación, el CNC sólo copia las subrutinas a la carpeta ..\\Mtb\\Sub si no existen. • En la tercera opción instalación \"rename previous version and install it completely\", el CNC siempre actualiza las subrutinas. Asignar la subrutina al comando." ;
    ex:compuestoPor ex:Subrutina_CUTTINGON_CHN, ex:Subrutina_CUTTINGOFF_CHN, ex:Carpeta_Mtb_Sub, ex:Parametro_Canal, ex:Subrutina_OEM_fst ;
    ex:documentadoEn ex:Manual_Pagina_656 .

ex:Manual_Pagina_656 a ex:Manual ;
    ex:identificador "1223" ;
    ex:textoExtracto "Paginas: [656] Seccion: 14.16.1 Configurar las subrutinas." .