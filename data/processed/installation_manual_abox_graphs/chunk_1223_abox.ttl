@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_CUTTINGON_CHN
    a               ex:Parametro ;
    rdfs:label      "CUTTINGON CHN" ;
    ex:textoExtracto "Subrutina asociada al comando #CUTTING ON. [...] [CHN].......Parámetro máquina; general del canal. Nombre y ubicación de la subrutina." ;
    ex:identificador "CUTTINGON" .

ex:Parametro_CUTTINGOFF_CHN
    a               ex:Parametro ;
    rdfs:label      "CUTTINGOFF CHN" ;
    ex:textoExtracto "Subrutina asociada al comando #CUTTING OFF. [...] [CHN].......Parámetro máquina; general del canal. Nombre y ubicación de la subrutina." ;
    ex:identificador "CUTTINGOFF" .

ex:Subrutina_Cuttingon_fst
    a               ex:Componente ;
    rdfs:label      "Cuttingon.fst" ;
    ex:textoExtracto "subrutina OEM con extensión fst [...] por defecto Cuttingon.fst. Ambas subrutinas deben estar guardadas en la carpeta ..\\Mtb\\Sub." ;
    ex:identificador "Cuttingon.fst" .

ex:Subrutina_Cuttingoff_fst
    a               ex:Componente ;
    rdfs:label      "Cuttingoff.fst" ;
    ex:textoExtracto "subrutina OEM con extensión fst [...] por defecto Cuttingoff.fst. Ambas subrutinas deben estar guardadas en la carpeta ..\\Mtb\\Sub." ;
    ex:identificador "Cuttingoff.fst" .

ex:InterfazUsuario_CNC
    a               ex:InterfazUsuario ;
    ex:textoExtracto "el CNC actúa de la siguiente manera [...] el CNC carga esta subrutina en la memoria RAM del CNC." ;
    ex:controla    ex:Subrutina_Cuttingon_fst ;
    ex:controla    ex:Subrutina_Cuttingoff_fst .

ex:Parametro_CUTTINGON_CHN
    ex:monitoreaParametro ex:Subrutina_Cuttingon_fst .

ex:Parametro_CUTTINGOFF_CHN
    ex:monitoreaParametro ex:Subrutina_Cuttingoff_fst .

ex:Pagina_637
    a               ex:Pagina ;
    ex:identificador "637" ;
    ex:textoExtracto "Ver en la '14.1 Ejecutar subrutinas desde la memoria RAM (extensión *.fst).' página 637." .

ex:Subrutina_Cuttingon_fst
    ex:documentadoEn ex:Pagina_637 .

ex:Subrutina_Cuttingoff_fst
    ex:documentadoEn ex:Pagina_637 .