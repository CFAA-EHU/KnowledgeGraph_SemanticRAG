@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Subrutina_FINALSUB a ex:TareaMantenimiento ;
    rdfs:label "Subrutina asociada al comando #FINALSUB" ;
    ex:textoExtracto "Subrutina orientada al modelo láser. Las subrutinas suministradas por Fagor ofrecen una gestión básica del láser, por lo que deben ser configuradas de forma apropiada por el OEM. Es su responsabilidad del OEM garantizar que la subrutina cumple todos los aspectos de seguridad relativos al manejo del láser. El comando #FINALSUB tiene una subrutina asociada, que el CNC ejecuta junto al comando. Este comando esta orientado a máquina láser, donde esta subrutina debe realizar las operaciones finales del láser." ;
    ex:identificador "#FINALSUB" .

ex:Maquina_Laser a ex:Maquina ;
    rdfs:label "máquina láser" ;
    ex:textoExtracto "Este comando esta orientado a máquina láser, donde esta subrutina debe realizar las operaciones finales del láser." .

ex:Empresa_Fagor a ex:Empresa ;
    rdfs:label "Fagor" ;
    ex:textoExtracto "Las subrutinas suministradas por Fagor ofrecen una gestión básica del láser" .

ex:Sistema_CNC a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "que el CNC ejecuta junto al comando" .