@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LimitesInferioresDeSoftwareSegundosLimites a ns1:Parametro ;
    rdfs:label "Límites inferiores de software (segundos límites)"@es ;
    ns1:identificador "A.RTNEGLIMIT.xn" ;
    ns1:textoExtracto "\"(V.)[ch].A.RTNEGLIMIT.xn | Límites inferiores de software (segundos límites).\""@es .

ns1:LimitesSuperioresDeSoftwareSegundosLimites a ns1:Parametro ;
    rdfs:label "Límites superiores de software (segundos límites)"@es ;
    ns1:identificador "A.RTPOSLIMIT.xn" ;
    ns1:textoExtracto "\"(V.)[ch].A.RTPOSLIMIT.xn | Límites superiores de software (segundos límites).\""@es .

