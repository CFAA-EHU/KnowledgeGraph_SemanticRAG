@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_FINALSUB_CHN rdfs:label "FINALSUB CHN" ;
    a ex:Parametro ;
    ex:textoExtracto "Parámetro máquina; general del canal. Nombre y ubicación de la subrutina. Esta subrutina debe estar definida en el parámetro general FINALSUB (por defecto Finalsub.fst) y estará guardada en la carpeta ..\\Mtb\\Sub." ;
    ex:valor "FINALSUB CHN" .

ex:Subrutina_Finalsub_fst rdfs:label "Finalsub.fst" ;
    a ex:Componente ;
    ex:textoExtracto "Subrutina asociada al comando #FINALSUB. ... Al ser una subrutina OEM con extensión fst, el CNC carga esta subrutina en la memoria RAM del CNC." ;
    ex:identificador "Finalsub.fst" .

ex:Sistema_CNC rdfs:label "CNC" ;
    a ex:Maquina ;
    ex:textoExtracto "el CNC actúa de la siguiente manera. ... el CNC siempre actualiza las subrutinas. ... el CNC carga esta subrutina en la memoria RAM del CNC." .

ex:Comando_FINALSUB rdfs:label "#FINALSUB" ;
    a ex:Parametro ;
    ex:textoExtracto "Subrutina asociada al comando #FINALSUB." ;
    ex:valor "#FINALSUB" .

ex:Esquema_ConfiguracionSubrutinas rdfs:label "Configurar las subrutinas" ;
    a ex:Esquema ;
    ex:textoExtracto "Si se actualiza la versión, el CNC actúa de la siguiente manera. • En las dos primeras opciones de instalación, el CNC sólo copia las subrutinas a la carpeta ..\\Mtb\\Sub si no existen. • En la tercera opción instalación \"rename previous version and install it completely\", el CNC siempre actualiza las subrutinas. Asignar la subrutina al comando. | Parámetro. |  | Significado. | | --- | --- | --- | | FINALSUB CHN |  | Subrutina asociada al comando #FINALSUB." ;
    ex:compuestoPor ex:Parametro_FINALSUB_CHN, ex:Comando_FINALSUB, ex:Subrutina_Finalsub_fst ;
    ex:detalladoEnEsquema ex:Sistema_CNC .