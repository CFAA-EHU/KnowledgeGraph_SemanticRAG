    rdfs:label "Compensación Volumétrica 2" ;
    ns1:textoExtracto "Las compensaciones volumétricas se configuran en los parámetros máquina y se activan desde el PLC (marcas VOLCOMP1 a VOLCOMP4)." .

ns1:CompensacionVolumetrica3_ecc3193a01 a ns1:Parametro ;
    rdfs:label "Compensación Volumétrica 3" ;
    ns1:textoExtracto "Las compensaciones volumétricas se configuran en los parámetros máquina y se activan desde el PLC (marcas VOLCOMP1 a VOLCOMP4)." .

ns1:CompensacionVolumetrica4_2177e746e7 a ns1:Parametro ;
    rdfs:label "Compensación Volumétrica 4" ;
