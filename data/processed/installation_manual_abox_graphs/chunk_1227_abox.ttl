@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Variable_MPG_FINALSUB a ex:Parametro ;
    rdfs:label "Variable (V.)[ch].MPG.FINALSUB" ;
    ex:identificador "(V.)[ch].MPG.FINALSUB" ;
    ex:textoExtracto "Variable. (V.)[ch].MPG.FINALSUB Subrutina asociada al comando #FINALSUB. Unidades: Texto." ;
    ex:valor "Texto" .

ex:Tabla_Variables_14_17_2 a ex:Tabla ;
    ex:textoExtracto "Las siguientes variables son accesibles desde; (PRG) el programa pieza y desde el modo MDI/MDA, PLC e (INT) una aplicación externa. La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W). | Variable. | PRG | PLC | INT | | --- | --- | --- | --- | | (V.)[ch].MPG.FINALSUB Subrutina asociada al comando #FINALSUB. Unidades: Texto. | - | - | R | Sintaxis. ꞏchꞏ Número de canal. | [2].MPG.FINALSUB | Canal ꞏ2ꞏ. |" ;
    ex:tieneComponente ex:Variable_MPG_FINALSUB .