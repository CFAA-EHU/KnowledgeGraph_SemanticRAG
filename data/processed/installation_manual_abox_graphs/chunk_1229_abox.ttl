@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Subrutina_G500
    a ex:Componente ;
    rdfs:label "Subrutina G500" ;
    ex:textoExtracto "G500 tendrá asociada la subrutina G500." ;
    ex:identificador "G500" .

ex:Subrutina_G501
    a ex:Componente ;
    rdfs:label "Subrutina G501" ;
    ex:textoExtracto "G501 tendrá asociada la subrutina G501." ;
    ex:identificador "G501" .

ex:Subrutina_G599
    a ex:Componente ;
    rdfs:label "Subrutina G599" ;
    ex:textoExtracto "G599 tendrá asociada la subrutina G599." ;
    ex:identificador "G599" .

ex:Carpeta_UsersSub
    a ex:InterfazUsuario ;
    rdfs:label "Carpeta ..\\Users\\Sub" ;
    ex:textoExtracto "La subrutina [...] estarán guardadas en la carpeta ..\\Users\\Sub." .

ex:Carpeta_MtbSub
    a ex:InterfazUsuario ;
    rdfs:label "Carpeta ..\\Mtb\\Sub" ;
    ex:textoExtracto "el CNC sólo copia las subrutinas a la carpeta ..\\Mtb\\Sub si no existen." .

ex:SistemaActualizacionSubrutinas
    a ex:Sistema ;
    rdfs:label "Sistema de actualización de subrutinas del CNC" ;
    ex:textoExtracto "Si se actualiza la versión, el CNC actúa de la siguiente manera. [...] En la tercera opción instalación 'rename previous version and install it completely', el CNC siempre actualiza las subrutinas." ;
    ex:tieneComponente ex:Subrutina_G500, ex:Subrutina_G501, ex:Subrutina_G599 ;
    ex:documentadoEn ex:Carpeta_UsersSub, ex:Carpeta_MtbSub .