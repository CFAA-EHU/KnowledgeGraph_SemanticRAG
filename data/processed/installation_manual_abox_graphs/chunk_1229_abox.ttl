@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCompensacionVolumetricaBasica a ns1:Sistema ;
    rdfs:label "Sistema de Compensación Volumétrica Básica" ;
    ns1:documentadoEn ns1:FicheroDatosCompensacion ;
    ns1:textoExtracto "El volumen a compensar está definido por hasta 25 puntos en cada eje. Esta compensación corrige los errores de traslación." .

ns1:SistemaCompensacionVolumetricaMediaGrande a ns1:Sistema ;
    rdfs:label "Sistema de Compensación Volumétrica Media y Grande" ;
    ns1:documentadoEn ns1:FicheroDatosCompensacion ;
    ns1:textoExtracto "Esta compensación corrige los 21 componentes del error geométrico (traslación, rotación y cuadratura)." .

ns1:TareaMantenimiento_4a46790d69 a ns1:TareaMantenimiento ;
    rdfs:label "Tarea de Calibración de Compensación Volumétrica Básica" ;
    ns1:textoExtracto "La compensación básica es la más rápida de calibrar, pero puede ser menos precisa que las otras." .

ns1:TareaMantenimiento_7e1f158bf5 a ns1:TareaMantenimiento ;
    rdfs:label "Tarea de Calibración de Compensación Volumétrica Media y Grande" ;
    ns1:textoExtracto "La compensación media y grande son más precisas que la básica, pero son más lentas de calibrar." .

ns1:FicheroDatosCompensacion a ns1:DocumentoTecnico ;
    rdfs:label "Fichero de Datos de Compensación" ;
    ns1:textoExtracto "El OEM debe definir en los parámetros máquina todos los datos de la compensación y seleccionar el fichero que contiene los datos de la compensación." .

