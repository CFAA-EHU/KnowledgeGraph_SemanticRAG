@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorACompensarEnDesplazamientosNegativos a ns1:Parametro ;
    rdfs:label "Error a compensar en desplazamientos negativos" ;
    ns1:identificador "MPG.NEGERROR[tbl][pt]" ;
    ns1:textoExtracto "Este parámetro indica el error a compensar en los desplazamientos en sentido negativo." .

ns1:ErrorACompensarEnDesplazamientosPositivos a ns1:Parametro ;
    rdfs:label "Error a compensar en desplazamientos positivos" ;
    ns1:identificador "MPG.POSERROR[tbl][pt]" ;
    ns1:textoExtracto "Este parámetro indica el error en el eje compensado cuando el eje maestro se desplaza en sentido positivo." .

ns1:PosicionDelEjeMaestro_14612ed19a a ns1:Parametro ;
    rdfs:label "Posición del eje maestro" ;
    ns1:identificador "MPG.POSITION[tbl][pt]" ;
    ns1:textoExtracto "Este parámetro define la posición del eje maestro en cada uno de los puntos de compensación." .

