@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinirAmbosEjesEnCompensacionVolumetricaBasica a ns1:AccionProhibida ;
    rdfs:label "Definir ambos ejes en compensación volumétrica básica" ;
    ns1:textoExtracto "En la compensación volumétrica básica hay que definir ambos ejes, el que se mueve y el que se compensa." .

ns1:DefinirCompensacion2DDeCaidaDeCarnero a ns1:AccionProhibida ;
    rdfs:label "Definir compensación 2D de caída de carnero" ;
    ns1:textoExtracto "por ejemplo, una compensación cruzada habitual o una compensación 2D de caída de carnero." .

ns1:DefinirCompensacionCruzadaHabitual a ns1:AccionProhibida ;
    rdfs:label "Definir compensación cruzada habitual" ;
    ns1:textoExtracto "por ejemplo, una compensación cruzada habitual o una compensación 2D de caída de carnero." .

