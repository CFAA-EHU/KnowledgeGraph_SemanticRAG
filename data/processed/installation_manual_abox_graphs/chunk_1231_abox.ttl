@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SistemaCNC_1231
    a                   ex:Sistema ;
    rdfs:label          "Sistema CNC (gestión de subrutinas)" ;
    ex:textoExtracto    "Si se actualiza la versión, el CNC actúa de la siguiente manera. [...] el CNC siempre actualiza las subrutinas."@es ;
    ex:tieneComponente  ex:InterfazSubrutinas_G8000-8999 ;
    ex:identificador    "..\\Mtb\\Sub ; ..\\Users\\Sub" .

ex:InterfazSubrutinas_G8000-8999
    a                   ex:InterfazUsuario ;
    rdfs:label          "Interfaz de subrutinas G8000-G8999" ;
    ex:textoExtracto    "La subrutina asociadas a las funciones G8000 a G8999 tendrán el mismo nombre que la función (sin extensión) y estarán guardadas en la carpeta ..\\Users\\Sub. G8000 tendrá asociada la subrutina G8000 [...] G8999 tendrá asociada la subrutina G8999."@es ;
    ex:identificador    "G8000-G8999" .