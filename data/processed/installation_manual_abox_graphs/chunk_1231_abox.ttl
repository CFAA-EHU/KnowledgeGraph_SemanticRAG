@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArchivoCSVDeParametros a ns1:Parametro ;
    rdfs:label "Archivo CSV de parámetros" ;
    ns1:identificador "VCOMPFILE" ;
    ns1:textoExtracto "El CNC muestra estos parámetros al cargar un archivo con extensión csv en el parámetro VCOMPFILE." .

