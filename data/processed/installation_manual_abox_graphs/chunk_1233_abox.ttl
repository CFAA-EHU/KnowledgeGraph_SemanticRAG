@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArchivoConLosDatosACompensar a ns1:Parametro ;
    rdfs:label "Archivo con los datos a compensar" ;
    ns1:identificador "VCOMPFILE" ;
    ns1:textoExtracto "El archivo con los datos a compensar será un archivo de texto (formato csv). El OEM o la empresa responsable de la calibración deben generar este archivo y definirlo en el parámetro máquina VCOMPFILE." .

ns1:UnidadesDelCNC a ns1:Parametro ;
    rdfs:label "Unidades del CNC" ;
    ns1:identificador "INCHES" ;
    ns1:textoExtracto "Las unidades de los datos del archivo (milímetros o pulgadas) deben ser las definidas en el CNC (parámetro INCHES)." .

