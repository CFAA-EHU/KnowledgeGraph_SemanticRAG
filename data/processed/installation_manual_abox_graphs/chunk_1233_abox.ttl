@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:G180_Subrutina
    a ex:InterfazUsuario ;
    rdfs:label "Subrutina G180" ;
    ex:textoExtracto "G180 P0= P1= P2= P3= P4= P5= [...] P1 = Movimiento en X, P2 = Movimiento en Y, P3 = Movimiento en Z, P4 = Avance F, P5 = Velocidad S" ;
    ex:identificador "G180" ;
    ex:tieneComponente ex:G180_ParametroX, ex:G180_ParametroY, ex:G180_ParametroZ, ex:G180_ParametroAvance, ex:G180_ParametroVelocidad .

ex:G180_ParametroX
    a ex:Parametro ;
    rdfs:label "Parámetro P1 (Movimiento en X)" ;
    ex:textoExtracto "P1 = Movimiento en X" ;
    ex:identificador "P1" ;
    ex:valor "X" .

ex:G180_ParametroY
    a ex:Parametro ;
    rdfs:label "Parámetro P2 (Movimiento en Y)" ;
    ex:textoExtracto "P2 = Movimiento en Y" ;
    ex:identificador "P2" ;
    ex:valor "Y" .

ex:G180_ParametroZ
    a ex:Parametro ;
    rdfs:label "Parámetro P3 (Movimiento en Z)" ;
    ex:textoExtracto "P3 = Movimiento en Z" ;
    ex:identificador "P3" ;
    ex:valor "Z" .

ex:G180_ParametroAvance
    a ex:Parametro ;
    rdfs:label "Parámetro P4 (Avance F)" ;
    ex:textoExtracto "P4 = Avance F" ;
    ex:identificador "P4" ;
    ex:valor "F" .

ex:G180_ParametroVelocidad
    a ex:Parametro ;
    rdfs:label "Parámetro P5 (Velocidad S)" ;
    ex:textoExtracto "P5 = Velocidad S" ;
    ex:identificador "P5" ;
    ex:valor "S" .

ex:Manual_Subrutinas
    a ex:Manual ;
    rdfs:label "Manual de ficheros de ayuda para subrutinas" ;
    ex:textoExtracto "Ejemplo de un fichero de ayuda de una subrutina. [...] Nombre y ubicación de los ficheros. Nombre de los archivos de ayuda. El nombre de los ficheros debe seguir la siguiente norma: [...]" ;
    ex:documentadoEn ex:G180_Subrutina .

ex:Tabla_NombresArchivosAyuda a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Normativa de nombres para archivos de ayuda" ;
    ex:textoExtracto "| Subrutina. | Nombre de los archivos de ayuda. | [...] | G180-G189 [...] | El nombre de los ficheros será la función a la que está asociada. Por ejemplo G180.txt y G180.bmp." ;
    ex:documentadoEn ex:Manual_Subrutinas .