@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazUsuario_EditorCNC8070
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de editor CNC8070"@es ;
    ex:textoExtracto "El editor permite tener en un archivo de texto (txt) una lista subrutinas que se mostrará durante la edición del programa pieza, cada vez que se edite una sentencia #PCALL ó #MCALL. El editor muestra la lista de subrutinas durante la edición, tras el espacio en blanco o tabulador posterior las sentencias #PCALL o #MCALL."@es ;
    ex:identificador "CNC8070_Editor" .

ex:ArchivoListaSubrutinas_pcall.txt
    a ex:InterfazUsuario ;
    rdfs:label "Archivo pcall.txt (lista de subrutinas)"@es ;
    ex:textoExtracto "El nombre del fichero deberá ser .pcall.txt [...] El fichero se deberá editar de tal manera que cada línea sea el nombre de una posible subrutina a llamar."@es ;
    ex:identificador "pcall.txt" ;
    ex:documentadoEn ex:InterfazUsuario_EditorCNC8070 .

ex:RutaAlmacenamiento_UsersSubHelp
    a ex:InterfazUsuario ;
    rdfs:label "Ruta de almacenamiento de subrutinas (..\\Users\\Sub\\Help)"@es ;
    ex:textoExtracto "el usuario deberá guardar su archivo pcall.txt ..\\Users\\Sub\\Help."@es ;
    ex:identificador "..\\Users\\Sub\\Help" ;
    ex:documentadoEn ex:InterfazUsuario_EditorCNC8070 .

ex:RutaAlmacenamiento_MtbSubHelp
    a ex:InterfazUsuario ;
    rdfs:label "Ruta de almacenamiento de subrutinas (..\\Mtb\\Sub\\Help)"@es ;
    ex:textoExtracto "El fabricante de la máquina guardará el archivo en la carpeta ..\\Mtb\\Sub\\Help."@es ;
    ex:identificador "..\\Mtb\\Sub\\Help" ;
    ex:documentadoEn ex:InterfazUsuario_EditorCNC8070 .

ex:EjemploSubrutina_FAGOR.NC
    a ex:Componente ;
    rdfs:label "Subrutina FAGOR.NC"@es ;
    ex:textoExtracto "Ejemplo de un fichero con una lista de subrutinas: C:\\CNC8070\\USERS\\SUB\\FAGOR.NC"@es ;
    ex:identificador "FAGOR.NC" ;
    ex:ilustradoEn ex:ArchivoListaSubrutinas_pcall.txt .

ex:EjemploSubrutina_SUBROUTINE.NC
    a ex:Componente ;
    rdfs:label "Subrutina SUBROUTINE.NC"@es ;
    ex:textoExtracto "Ejemplo de un fichero con una lista de subrutinas: SUBROUTINE.NC"@es ;
    ex:identificador "SUBROUTINE.NC" ;
    ex:ilustradoEn ex:ArchivoListaSubrutinas_pcall.txt .

ex:EjemploSubrutina_EXAMPLE.NC
    a ex:Componente ;
    rdfs:label "Subrutina EXAMPLE.NC"@es ;
    ex:textoExtracto "Ejemplo de un fichero con una lista de subrutinas: EXAMPLE.NC"@es ;
    ex:identificador "EXAMPLE.NC" ;
    ex:ilustradoEn ex:ArchivoListaSubrutinas_pcall.txt .

ex:EjemploSubrutina_POSITIONING.NC
    a ex:Componente ;
    rdfs:label "Subrutina POSITIONING.NC"@es ;
    ex:textoExtracto "Ejemplo de un fichero con una lista de subrutinas: POSITIONING.NC"@es ;
    ex:identificador "POSITIONING.NC" ;
    ex:ilustradoEn ex:ArchivoListaSubrutinas_pcall.txt .