@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArchivoConLosDatosParaLaCompensacionVolumetricaBasica a ns1:Parametro ;
    rdfs:label "Archivo con los datos para la compensación volumétrica básica" ;
    ns1:identificador "VCOMPFILE" ;
    ns1:textoExtracto "El OEM o la empresa responsable de la calibración deben generar este archivo y definirlo en el parámetro máquina VCOMPFILE." .

ns1:CNC8070_4bdb2ce273 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Las unidades de los datos del archivo (milímetros o pulgadas) deben ser las definidas en el CNC (parámetro INCHES)." .

ns1:EjeXParaCompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Eje X para compensación volumétrica" ;
    ns1:identificador "VCOMPAXIS1" ;
    ns1:textoExtracto "Las columnas corresponden a los ejes definidos en los parámetros VCOMPAXIS1 (primera columna), VCOMPAXIS2 (segunda columna) y VCOMPAXIS3 (tercera columna)." .

ns1:EjeYParaCompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Eje Y para compensación volumétrica" ;
    ns1:identificador "VCOMPAXIS2" ;
    ns1:textoExtracto "Las columnas corresponden a los ejes definidos en los parámetros VCOMPAXIS1 (primera columna), VCOMPAXIS2 (segunda columna) y VCOMPAXIS3 (tercera columna)." .

ns1:EjeZParaCompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Eje Z para compensación volumétrica" ;
    ns1:identificador "VCOMPAXIS3" ;
    ns1:textoExtracto "Las columnas corresponden a los ejes definidos en los parámetros VCOMPAXIS1 (primera columna), VCOMPAXIS2 (segunda columna) y VCOMPAXIS3 (tercera columna)." .

ns1:NumeroDePuntosEnElEjeX a ns1:Parametro ;
    rdfs:label "Número de puntos en el eje X" ;
    ns1:identificador "NPOINTSAX1" ;
    ns1:textoExtracto "VMOVAXIS1=X NPOINTSAX1=3 INCREAX1=30 VCOMPAXIS1=X" .

ns1:NumeroDePuntosEnElEjeY a ns1:Parametro ;
    rdfs:label "Número de puntos en el eje Y" ;
    ns1:identificador "NPOINTSAX2" ;
    ns1:textoExtracto "VMOVAXIS2=Y NPOINTSAX2=2 INCREAX2=30 VCOMPAXIS2=Y" .

ns1:NumeroDePuntosEnElEjeZ a ns1:Parametro ;
    rdfs:label "Número de puntos en el eje Z" ;
    ns1:identificador "NPOINTSAX3" ;
    ns1:textoExtracto "VMOVAXIS3=Z NPOINTSAX3=2 INCREAX3=36 VCOMPAXIS3=Z" .

ns1:UnidadesDelCNCMilimetrosOPulgadas a ns1:Parametro ;
    rdfs:label "Unidades del CNC (milímetros o pulgadas)" ;
    ns1:identificador "INCHES" ;
    ns1:textoExtracto "Las unidades de los datos del archivo (milímetros o pulgadas) deben ser las definidas en el CNC (parámetro INCHES)." .

