@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PanelJog1 a ex:Componente ;
    rdfs:label "panel de jog"@es ;
    ex:textoExtracto "Un panel de jog podrá estar asociado a un canal en concreto (por ejemplo, en un torno TT)"@es .

ex:PanelJog2 a ex:Componente ;
    rdfs:label "panel de jog"@es ;
    ex:textoExtracto "una máquina con dos puestos de trabajo donde ambos paneles de jog funcionan de igual forma"@es .

ex:CNC a ex:Maquina ;
    rdfs:label "CNC"@es ;
    ex:textoExtracto "Como el CNC puede tener conectados varios paneles de jog, desde el CNC se permite configurar el comportamiento de cada uno de ellos respecto a los canales."@es .

ex:CanalConcreto a ex:ModoOperacion ;
    rdfs:label "canal en concreto"@es ;
    ex:textoExtracto "Un panel de jog podrá estar asociado a un canal en concreto"@es .

ex:CanalActivo a ex:ModoOperacion ;
    rdfs:label "canal activo"@es ;
    ex:textoExtracto "siempre al canal activo"@es .

ex:TornoTT a ex:Maquina ;
    rdfs:label "torno TT"@es ;
    ex:textoExtracto "por ejemplo, en un torno TT"@es .

ex:MaquinaDosPuestos a ex:Maquina ;
    rdfs:label "máquina con dos puestos de trabajo"@es ;
    ex:textoExtracto "una máquina con dos puestos de trabajo donde ambos paneles de jog funcionan de igual forma"@es .