@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PosicionInicialDelEjeX a ns1:Parametro ;
    rdfs:label "Posición inicial del eje X" ;
    ns1:identificador "INIPOSAX1" ;
    ns1:textoExtracto "\"X (INIPOSAX1)\"" .

ns1:PosicionInicialDelEjeY a ns1:Parametro ;
    rdfs:label "Posición inicial del eje Y" ;
    ns1:identificador "INIPOSAX2" ;
    ns1:textoExtracto "\"Y (INIPOSAX2)\"" .

ns1:PosicionInicialDelEjeZ a ns1:Parametro ;
    rdfs:label "Posición inicial del eje Z" ;
    ns1:identificador "INIPOSAX3" ;
    ns1:textoExtracto "\"Z (INIPOSAX3)\"" .

