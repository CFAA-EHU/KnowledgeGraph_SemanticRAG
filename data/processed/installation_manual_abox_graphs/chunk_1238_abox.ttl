@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PanelMandoJog_0 a ex:ComponenteElectrico ;
    rdfs:label "CNC Remote I/Os Jog-Panel (Address = 0)" ;
    ex:textoExtracto "CNC Remote I/Os Jog-Panel (Address = 0)" .

ex:PanelMandoJog_1 a ex:ComponenteElectrico ;
    rdfs:label "CNC Remote I/Os Jog-Panel (Address = 1)" ;
    ex:textoExtracto "CNC Remote I/Os Jog-Panel (Address = 1)" .

ex:PanelMandoJog_2 a ex:ComponenteElectrico ;
    rdfs:label "CNC Remote I/Os Jog-Panel (Address = 2)" ;
    ex:textoExtracto "CNC Remote I/Os Jog-Panel (Address = 2)" .

ex:BusCAN a ex:ComponenteElectrico ;
    rdfs:label "bus CAN (conmutador Address)" ;
    ex:textoExtracto "El CNC numera los paneles de mando según el orden que ocupan dentro del bus CAN (conmutador Address)." .