@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorEnElEjeCompensadoCuandoElEjeMaestroSeDesplazaEnSentidoNegativo a ns1:Parametro ;
    rdfs:label "Error en el eje compensado cuando el eje maestro se desplaza en sentido negativo" ;
    ns1:documentadoEn ns1:TablaCompensacionCruzada ;
    ns1:identificador "MPG.NEGERROR" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.NEGERROR[tbl][pt] Parámetro incluido en la tabla CROSSCOMP // DATA. Este parámetro indica el error en el eje compensado cuando el eje maestro se desplaza en sentido negativo." .

ns1:TablaCompensacionCruzada a ns1:Tabla ;
    rdfs:label "Tabla CROSSCOMP // DATA" ;
    ns1:textoExtracto "Parámetro incluido en la tabla CROSSCOMP // DATA. Esta compensación sólo está disponible si se ha definido la tabla con compensación bidireccional." .

