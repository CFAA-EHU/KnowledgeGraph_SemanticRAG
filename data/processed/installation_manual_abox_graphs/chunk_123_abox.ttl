@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_NDIMOD
    a ex:Parametro ;
    rdfs:label "NDIMOD" ;
    ex:identificador "MPG.NDIMOD" ;
    ex:textoExtracto "NDIMOD Número de bloques lógicos de entradas digitales. Valores posibles: De 0 a 42. Valor por defecto: 0 (no se desea personalizar la numeración). Variable asociada: (V.)MPG.NDIMOD Este parámetro indica la cantidad de bloques lógicos en los que se dividen los módulos de entradas digitales conectados en el bus CANopen." ;
    ex:valor "0"^^xsd:integer .

ex:Parametro_DIMODADDR
    a ex:Parametro ;
    rdfs:label "DIMODADDR" ;
    ex:textoExtracto "DIMODADDR Direcciones base de los bloques lógicos de entradas digitales. Este parámetro muestra la tabla para personalizar los bloques lógicos de entradas digitales." .

ex:Sistema_BusCANopen
    a ex:Sistema ;
    rdfs:label "Bus CANopen" ;
    ex:textoExtracto "módulos de entradas digitales conectados en el bus CANopen" ;
    ex:tieneComponente ex:Componente_ModulosEntradasDigitales .

ex:Componente_ModulosEntradasDigitales
    a ex:ComponenteElectrico ;
    rdfs:label "Módulos de entradas digitales" ;
    ex:textoExtracto "módulos de entradas digitales conectados en el bus CANopen" ;
    ex:monitoreaParametro ex:Parametro_NDIMOD ;
    ex:monitoreaParametro ex:Parametro_DIMODADDR .

ex:Nodo_RIO5
    a ex:ComponenteElectrico ;
    rdfs:label "Nodo RIO5" ;
    ex:textoExtracto "En los nodos RIO5 y RIOR, cada módulo es un bloque lógico, no se permite agrupar varios módulos en un bloque ni dividir un módulo en bloques." .

ex:Nodo_RIOR
    a ex:ComponenteElectrico ;
    rdfs:label "Nodo RIOR" ;
    ex:textoExtracto "En los nodos RIO5 y RIOR, cada módulo es un bloque lógico, no se permite agrupar varios módulos en un bloque ni dividir un módulo en bloques." .

ex:Nodo_RIOW
    a ex:ComponenteElectrico ;
    rdfs:label "Nodo RIOW" ;
    ex:textoExtracto "En los nodos RIOW y de terceros, se permite virtualizar los bloques lógicos que se desee, tanto en número como en dimensión." .