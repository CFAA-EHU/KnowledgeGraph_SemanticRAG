@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:NDIMOD a ex:Parametro ;
    rdfs:label "NDIMOD" ;
    ex:identificador "NDIMOD" ;
    ex:textoExtracto "NDIMOD Número de bloques lógicos de entradas digitales. Valores posibles: De 0 a 42. Valor por defecto: 0 (no se desea personalizar la numeración). Variable asociada: (V.)MPG.NDIMOD Este parámetro indica la cantidad de bloques lógicos en los que se dividen los módulos de entradas digitales conectados en el bus CANopen." ;
    ex:valor "0 a 42" .

ex:DIMODADDR a ex:Parametro ;
    rdfs:label "DIMODADDR" ;
    ex:identificador "DIMODADDR" ;
    ex:textoExtracto "DIMODADDR Direcciones base de los bloques lógicos de entradas digitales. Este parámetro muestra la tabla para personalizar los bloques lógicos de entradas digitales." .

ex:ParametroCNC a ex:Parametro ;
    rdfs:label "Parámetro CNC" ;
    ex:textoExtracto "Este parámetro indica la cantidad de bloques lógicos en los que se dividen los módulos de entradas digitales conectados en el bus CANopen." .

ex:BusCANopen a ex:Sistema ;
    rdfs:label "Bus CANopen" ;
    ex:textoExtracto "módulos de entradas digitales conectados en el bus CANopen" .

ex:ModuloEntradaDigital a ex:ComponenteElectrico ;
    rdfs:label "Módulo de entradas digitales" ;
    ex:textoExtracto "módulos de entradas digitales conectados en el bus CANopen" .

ex:BloqueLogico a ex:Componente ;
    rdfs:label "Bloque lógico" ;
    ex:textoExtracto "bloques lógicos en los que se dividen los módulos de entradas digitales" .

ex:ModuloRIO5 a ex:ComponenteElectrico ;
    rdfs:label "Módulo RIO5" ;
    ex:textoExtracto "En los nodos RIO5 y RIOR, cada módulo es un bloque lógico" .

ex:ModuloRIOR a ex:ComponenteElectrico ;
    rdfs:label "Módulo RIOR" ;
    ex:textoExtracto "En los nodos RIO5 y RIOR, cada módulo es un bloque lógico" .

ex:ModuloDobleRIO5 a ex:ComponenteElectrico ;
    rdfs:label "Módulo doble RIO5" ;
    ex:textoExtracto "En los nodos RIO5, cada módulo doble (módulo con dos placas) cuenta como dos; es decir, dos bloques lógicos" .

ex:ModuloRIOW a ex:ComponenteElectrico ;
    rdfs:label "Módulo RIOW" ;
    ex:textoExtracto "En los nodos RIOW y de terceros, se permite virtualizar los bloques lógicos que se desee" .

ex:ModuloTerceros a ex:ComponenteElectrico ;
    rdfs:label "Módulo de terceros" ;
    ex:textoExtracto "En los nodos RIOW y de terceros, se permite virtualizar los bloques lógicos que se desee" .

ex:EntradaDigital a ex:ComponenteElectrico ;
    rdfs:label "Entrada digital" ;
    ex:textoExtracto "personalizar la numeración de las entradas digitales de cada bloque lógico" .

ex:CNC a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "el CNC permite personalizar la numeración de las entradas digitales" .