@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazUsuario_JogPanel
    a ex:InterfazUsuario ;
    rdfs:label "Jog-Panel" ;
    ex:textoExtracto "Jog-Panel" ;
    ex:identificador "Jog-Panel" .

ex:Sistema_RemoteIO_Address5
    a ex:Sistema ;
    rdfs:label "Remote I/Os (Address = 5)" ;
    ex:textoExtracto "Remote I/Os (Address = 5)" ;
    ex:identificador "Address=5" .

ex:Sistema_RemoteIO_Address4
    a ex:Sistema ;
    rdfs:label "Remote I/Os (Address = 4)" ;
    ex:textoExtracto "Remote I/Os (Address = 4)" ;
    ex:identificador "Address=4" .

ex:Sistema_RemoteIO_Address3
    a ex:Sistema ;
    rdfs:label "Remote I/Os (Address = 3)" ;
    ex:textoExtracto "Remote I/Os (Address = 3)" ;
    ex:identificador "Address=3" .

ex:InterfazUsuario_JogPanel
    ex:compuestoPor ex:Sistema_RemoteIO_Address5 ;
    ex:compuestoPor ex:Sistema_RemoteIO_Address4 ;
    ex:compuestoPor ex:Sistema_RemoteIO_Address3 .