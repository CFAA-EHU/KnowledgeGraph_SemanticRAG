@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjeXDelMovimiento a ns1:Parametro ;
    rdfs:label "Eje X del movimiento" ;
    ns1:identificador "VMOVAXIS1" ;
    ns1:textoExtracto "VMOVAXIS1=X" .

ns1:EjeYDelMovimiento a ns1:Parametro ;
    rdfs:label "Eje Y del movimiento" ;
    ns1:identificador "VMOVAXIS2" ;
    ns1:textoExtracto "VMOVAXIS2=Y" .

ns1:EjeZDelMovimiento a ns1:Parametro ;
    rdfs:label "Eje Z del movimiento" ;
    ns1:identificador "VMOVAXIS3" ;
    ns1:textoExtracto "VMOVAXIS3=Z" .

ns1:IncrementoEntrePuntosDelEjeX a ns1:Parametro ;
    rdfs:label "Incremento entre puntos del eje X" ;
    ns1:identificador "INCREAX1" ;
    ns1:textoExtracto "parámetro INCREAX1" .

ns1:IncrementoEntrePuntosDelEjeY a ns1:Parametro ;
    rdfs:label "Incremento entre puntos del eje Y" ;
    ns1:identificador "INCREAX2" ;
    ns1:textoExtracto "parámetro INCREAX2" .

ns1:NumeroDePuntosEnElEjeX a ns1:Parametro ;
    rdfs:label "Número de puntos en el eje X" ;
    ns1:identificador "NPOINTSAX1" ;
    ns1:textoExtracto "parámetro NPOINTSAX1" .

ns1:NumeroDePuntosEnElEjeY a ns1:Parametro ;
    rdfs:label "Número de puntos en el eje Y" ;
    ns1:identificador "NPOINTSAX2" ;
    ns1:textoExtracto "parámetro NPOINTSAX2" .

ns1:PosicionInicialEnElEjeX a ns1:Parametro ;
    rdfs:label "Posición inicial en el eje X" ;
    ns1:identificador "INIPOSAX1" ;
    ns1:textoExtracto "parámetros INIPOSAX1, INIPOSAX2, INIPOSAX3" .

ns1:PosicionInicialEnElEjeY a ns1:Parametro ;
    rdfs:label "Posición inicial en el eje Y" ;
    ns1:identificador "INIPOSAX2" ;
    ns1:textoExtracto "parámetros INIPOSAX1, INIPOSAX2, INIPOSAX3" .

ns1:PosicionInicialEnElEjeZ a ns1:Parametro ;
    rdfs:label "Posición inicial en el eje Z" ;
    ns1:identificador "INIPOSAX3" ;
    ns1:textoExtracto "parámetros INIPOSAX1, INIPOSAX2, INIPOSAX3" .

