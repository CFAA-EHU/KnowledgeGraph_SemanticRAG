@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SistemaPanelesJog
    a ex:Sistema ;
    rdfs:label "Sistema de paneles Jog"@es ;
    ex:textoExtracto "Primer panel de mando del sistema. [...] Tercer panel de mando del sistema."@es ;
    ex:tieneComponente ex:CNC_PanelMando1, ex:JogPanel1, ex:JogPanel2, ex:JogPanel3 ;
    ex:tieneComponente ex:IOsRemotas1, ex:IOsRemotas2, ex:IOsRemotas3 ;
    ex:compuestoPor ex:Parametro_NKEYBD, ex:Parametro_KEYBD1CH, ex:Parametro_KEYBD2CH, ex:Parametro_KEYBD3CH, ex:Parametro_KEYBD4CH, ex:Parametro_KEYBD5CH, ex:Parametro_KEYBD6CH, ex:Parametro_KEYBD7CH, ex:Parametro_KEYBD8CH ;
    ex:compuestoPor ex:Parametro_JOGKEYDEF, ex:Parametro_JOGKEYBD2DEF, ex:Parametro_JOGKEYBD3DEF, ex:Parametro_JOGKEYBD4DEF, ex:Parametro_JOGKEYBD5DEF, ex:Parametro_JOGKEYBD6DEF, ex:Parametro_JOGKEYBD7DEF, ex:Parametro_JOGKEYBD8DEF .

ex:CNC_PanelMando1
    a ex:InterfazUsuario ;
    rdfs:label "CNC (Primer panel de mando del sistema)"@es ;
    ex:textoExtracto "CNC | Primer panel de mando del sistema."@es ;
    ex:identificador "CNC" .

ex:JogPanel1
    a ex:InterfazUsuario ;
    rdfs:label "Jog-Panel (Segundo panel de mando del sistema)"@es ;
    ex:textoExtracto "Jog-Panel | Segundo panel de mando del sistema."@es ;
    ex:identificador "JogPanel1" .

ex:JogPanel2
    a ex:InterfazUsuario ;
    rdfs:label "Jog-Panel (Tercer panel de mando del sistema)"@es ;
    ex:textoExtracto "Jog-Panel | Tercer panel de mando del sistema."@es ;
    ex:identificador "JogPanel2" .

ex:JogPanel3
    a ex:InterfazUsuario ;
    rdfs:label "Jog-Panel (Panel adicional del sistema)"@es ;
    ex:textoExtracto "I/Os remotas. [...] Jog-Panel | Tercer panel de mando del sistema."@es ;
    ex:identificador "JogPanel3" .

ex:IOsRemotas1
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo de I/Os remotas 1"@es ;
    ex:textoExtracto "I/Os remotas."@es ;
    ex:identificador "IOsRemotas1" .

ex:IOsRemotas2
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo de I/Os remotas 2"@es ;
    ex:textoExtracto "I/Os remotas."@es ;
    ex:identificador "IOsRemotas2" .

ex:IOsRemotas3
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo de I/Os remotas 3"@es ;
    ex:textoExtracto "I/Os remotas."@es ;
    ex:identificador "IOsRemotas3" .

ex:Parametro_NKEYBD
    a ex:Parametro ;
    rdfs:label "NKEYBD (Número de paneles de jog)"@es ;
    ex:textoExtracto "El parámetro NKEYBD establece el número de paneles de jog del sistema."@es ;
    ex:identificador "NKEYBD" ;
    ex:valor "Número de paneles de jog"@es .

ex:Parametro_KEYBD1CH
    a ex:Parametro ;
    rdfs:label "KEYBD1CH (Asignación del primer panel de jog)"@es ;
    ex:textoExtracto "KEYBD1CH .. KEYBD8CH | Lista de paneles de jog del sistema. [...] KEYBD1CH corresponde al primer panel de jog"@es ;
    ex:identificador "KEYBD1CH" ;
    ex:valor "Asignación del primer panel de jog a canal"@es .

ex:Parametro_KEYBD2CH
    a ex:Parametro ;
    rdfs:label "KEYBD2CH (Asignación del segundo panel de jog)"@es ;
    ex:textoExtracto "KEYBD2CH al segundo"@es ;
    ex:identificador "KEYBD2CH" ;
    ex:valor "Asignación del segundo panel de jog a canal"@es .

ex:Parametro_KEYBD3CH
    a ex:Parametro ;
    rdfs:label "KEYBD3CH (Asignación del tercer panel de jog)"@es ;
    ex:textoExtracto "KEYBD3CH"@es ;
    ex:identificador "KEYBD3CH" ;
    ex:valor "Asignación del tercer panel de jog a canal"@es .

ex:Parametro_KEYBD4CH
    a ex:Parametro ;
    rdfs:label "KEYBD4CH (Asignación del cuarto panel de jog)"@es ;
    ex:textoExtracto "KEYBD4CH"@es ;
    ex:identificador "KEYBD4CH" ;
    ex:valor "Asignación del cuarto panel de jog a canal"@es .

ex:Parametro_KEYBD5CH
    a ex:Parametro ;
    rdfs:label "KEYBD5CH (Asignación del quinto panel de jog)"@es ;
    ex:textoExtracto "KEYBD5CH"@es ;
    ex:identificador "KEYBD5CH" ;
    ex:valor "Asignación del quinto panel de jog a canal"@es .

ex:Parametro_KEYBD6CH
    a ex:Parametro ;
    rdfs:label "KEYBD6CH (Asignación del sexto panel de jog)"@es ;
    ex:textoExtracto "KEYBD6CH"@es ;
    ex:identificador "KEYBD6CH" ;
    ex:valor "Asignación del sexto panel de jog a canal"@es .

ex:Parametro_KEYBD7CH
    a ex:Parametro ;
    rdfs:label "KEYBD7CH (Asignación del séptimo panel de jog)"@es ;
    ex:textoExtracto "KEYBD7CH"@es ;
    ex:identificador "KEYBD7CH" ;
    ex:valor "Asignación del séptimo panel de jog a canal"@es .

ex:Parametro_KEYBD8CH
    a ex:Parametro ;
    rdfs:label "KEYBD8CH (Asignación del octavo panel de jog)"@es ;
    ex:textoExtracto "KEYBD8CH"@es ;
    ex:identificador "KEYBD8CH" ;
    ex:valor "Asignación del octavo panel de jog a canal"@es .

ex:Parametro_JOGKEYDEF
    a ex:Parametro ;
    rdfs:label "JOGKEYDEF (Configuración de teclas del primer panel de jog)"@es ;
    ex:textoExtracto "JOGKEYDEF [...] corresponde al primer panel de jog"@es ;
    ex:identificador "JOGKEYDEF" ;
    ex:valor "Tabla de configuración de teclas para el primer panel de jog"@es .

ex:Parametro_JOGKEYBD2DEF
    a ex:Parametro ;
    rdfs:label "JOGKEYBD2DEF (Configuración de teclas del segundo panel de jog)"@es ;
    ex:textoExtracto "JOGKEYBD2DEF al segundo"@es ;
    ex:identificador "JOGKEYBD2DEF" ;
    ex:valor "Tabla de configuración de teclas para el segundo panel de jog"@es .

ex:Parametro_JOGKEYBD3DEF
    a ex:Parametro ;
    rdfs:label "JOGKEYBD3DEF (Configuración de teclas del tercer panel de jog)"@es ;
    ex:textoExtracto "JOGKEYBD3DEF"@es ;
    ex:identificador "JOGKEYBD3DEF" ;
    ex:valor "Tabla de configuración de teclas para el tercer panel de jog"@es .

ex:Parametro_JOGKEYBD4DEF
    a ex:Parametro ;
    rdfs:label "JOGKEYBD4DEF (Configuración de teclas del cuarto panel de jog)"@es ;
    ex:textoExtracto "JOGKEYBD4DEF"@es ;
    ex:identificador "JOGKEYBD4DEF" ;
    ex:valor "Tabla de configuración de teclas para el cuarto panel de jog"@es .

ex:Parametro_JOGKEYBD5DEF
    a ex:Parametro ;
    rdfs:label "JOGKEYBD5DEF (Configuración de teclas del quinto panel de jog)"@es ;
    ex:textoExtracto "JOGKEYBD5DEF"@es ;
    ex:identificador "JOGKEYBD5DEF" ;
    ex:valor "Tabla de configuración de teclas para el quinto panel de jog"@es .

ex:Parametro_JOGKEYBD6DEF
    a ex:Parametro ;
    rdfs:label "JOGKEYBD6DEF (Configuración de teclas del sexto panel de jog)"@es ;
    ex:textoExtracto "JOGKEYBD6DEF"@es ;
    ex:identificador "JOGKEYBD6DEF" ;
    ex:valor "Tabla de configuración de teclas para el sexto panel de jog"@es .

ex:Parametro_JOGKEYBD7DEF
    a ex:Parametro ;
    rdfs:label "JOGKEYBD7DEF (Configuración de teclas del séptimo panel de jog)"@es ;
    ex:textoExtracto "JOGKEYBD7DEF"@es ;
    ex:identificador "JOGKEYBD7DEF" ;
    ex:valor "Tabla de configuración de teclas para el séptimo panel de jog"@es .

ex:Parametro_JOGKEYBD8DEF
    a ex:Parametro ;
    rdfs:label "JOGKEYBD8DEF (Configuración de teclas del octavo panel de jog)"@es ;
    ex:textoExtracto "JOGKEYBD8DEF"@es ;
    ex:identificador "JOGKEYBD8DEF" ;
    ex:valor "Tabla de configuración de teclas para el octavo panel de jog"@es .