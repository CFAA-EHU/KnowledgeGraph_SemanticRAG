@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SistemaConfiguracionPrestacion_1241 a ex:Sistema ;
    ex:textoExtracto "Primer panel de mando del sistema." ;
    rdfs:label "CNC" .

ex:SistemaConfiguracionPrestacion_1241_2 a ex:Sistema ;
    ex:textoExtracto "Segundo panel de mando del sistema." ;
    rdfs:label "Jog-Panel" .

ex:SistemaConfiguracionPrestacion_1241_3 a ex:Sistema ;
    ex:textoExtracto "Tercer panel de mando del sistema." ;
    rdfs:label "Jog-Panel" .

ex:ParametroMaquina_NKEYBD a ex:Parametro ;
    ex:identificador "NKEYBD" ;
    ex:textoExtracto "El parámetro NKEYBD establece el número de paneles de jog del sistema." ;
    ex:valor "Número de paneles de jog" .

ex:ParametroMaquina_KEYBD1CH a ex:Parametro ;
    ex:identificador "KEYBD1CH" ;
    ex:textoExtracto "El parámetro KEYBDCH muestra la tabla para asignar los paneles de jog a los canales, donde el parámetro KEYBD1CH corresponde al primer panel de jog." ;
    ex:valor "Lista de paneles de jog del sistema" .

ex:ParametroMaquina_KEYBD2CH a ex:Parametro ;
    ex:identificador "KEYBD2CH" ;
    ex:textoExtracto "El parámetro KEYBD2CH corresponde al segundo panel de jog." ;
    ex:valor "Lista de paneles de jog del sistema" .

ex:ParametroMaquina_JOGKEYDEF a ex:Parametro ;
    ex:identificador "JOGKEYDEF" ;
    ex:textoExtracto "El parámetro JOGKEYDEF corresponde al primer panel de jog." ;
    ex:valor "Tablas para configurar las teclas de jog" .

ex:ParametroMaquina_JOGKEYBD2DEF a ex:Parametro ;
    ex:identificador "JOGKEYBD2DEF" ;
    ex:textoExtracto "El parámetro JOGKEYBD2DEF corresponde al segundo panel de jog." ;
    ex:valor "Tablas para configurar las teclas de jog" .