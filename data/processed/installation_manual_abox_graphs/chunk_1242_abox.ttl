@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TecladoJOG_1242 a ex:InterfazUsuario ;
    ex:textoExtracto "El teclado de JOG puede estar compuesto por los siguientes tipos de teclas." ;
    ex:tieneComponente ex:TeclaJOG_Xmas_1242, ex:TeclaJOG_X_1242, ex:TeclaJOG_mas_1242, ex:TeclaJOG_rapido_1242 .

ex:TeclaJOG_Xmas_1242 a ex:ComponenteElectrico ;
    rdfs:label "Tecla para definir el eje y el sentido de desplazamiento (X+)" ;
    ex:textoExtracto "Teclas para definir el eje y el sentido de desplazamiento. X+ El parámetro se define con un valor comprendido entre -1 y +16 (con signo)." ;
    ex:valor "valor entre -1 y +16 (con signo)" .

ex:TeclaJOG_X_1242 a ex:ComponenteElectrico ;
    rdfs:label "Tecla para definir el eje a desplazar (X)" ;
    ex:textoExtracto "Teclas para definir el eje a desplazar. X El parámetro se define con un valor comprendido entre 1 y 16 (sin signo)." ;
    ex:valor "valor entre 1 y 16 (sin signo)" .

ex:TeclaJOG_mas_1242 a ex:ComponenteElectrico ;
    rdfs:label "Tecla para definir el sentido de desplazamiento (+/-)" ;
    ex:textoExtracto "Teclas para definir el sentido de desplazamiento. + El parámetro se define con uno de los valores '+' y '-', para indicar el sentido de desplazamiento." ;
    ex:valor "valor '+' o '-'" .

ex:TeclaJOG_rapido_1242 a ex:ComponenteElectrico ;
    rdfs:label "Tecla de rápido" ;
    ex:textoExtracto "Tecla de rápido. El parámetro se define con el valor 'R'." ;
    ex:valor "valor 'R'" .

ex:TablaConfiguracionTeclasJOG_1242 a ex:Tabla ;
    ex:textoExtracto "Tablas para configurar las teclas de usuario como teclas de jog. USERKEYDEF USERKEYBD2DEF ... USERKEYBD8DEF Estos parámetros permiten configurar las teclas de usuario de cada panel como teclas de jog." ;
    ex:compuestoPor ex:Parametro_USERKEYDEF_1242, ex:Parametro_USERKEYBD2DEF_1242, ex:Parametro_USERKEYBD8DEF_1242 .

ex:Parametro_USERKEYDEF_1242 a ex:Parametro ;
    rdfs:label "USERKEYDEF" ;
    ex:identificador "USERKEYDEF" ;
    ex:textoExtracto "El parámetro USERKEYDEF corresponde al primer panel de jog, USERKEYBD2DEF al segundo y así sucesivamente." .

ex:Parametro_USERKEYBD2DEF_1242 a ex:Parametro ;
    rdfs:label "USERKEYBD2DEF" ;
    ex:identificador "USERKEYBD2DEF" ;
    ex:textoExtracto "El parámetro USERKEYDEF corresponde al primer panel de jog, USERKEYBD2DEF al segundo y así sucesivamente." .

ex:Parametro_USERKEYBD8DEF_1242 a ex:Parametro ;
    rdfs:label "USERKEYBD8DEF" ;
    ex:identificador "USERKEYBD8DEF" ;
    ex:textoExtracto "El parámetro USERKEYDEF corresponde al primer panel de jog, USERKEYBD2DEF al segundo y así sucesivamente." .