@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ValorDePunto1 a ns1:Parametro ;
    rdfs:label "Valor de Punto 1" ;
    ns1:textoExtracto "4 X(P1) Y(P1) Z(P2)" .

ns1:ValorDePunto2 a ns1:Parametro ;
    rdfs:label "Valor de Punto 2" ;
    ns1:textoExtracto "Z(P2) X(Pn) Y(P1) Z(P2)" .

ns1:ValorDePunto3 a ns1:Parametro ;
    rdfs:label "Valor de Punto 3" ;
    ns1:textoExtracto "X(P3) Y(P2) X(P2)" .

ns1:ValorDePunto4 a ns1:Parametro ;
    rdfs:label "Valor de Punto 4" ;
    ns1:textoExtracto "NPOINTAX1 Y(Pn) X(P4)" .

ns1:ValorDePuntoN a ns1:Parametro ;
    rdfs:label "Valor de Punto n" ;
    ns1:textoExtracto "X(Pn) Y(P1) Z(P2)" .

