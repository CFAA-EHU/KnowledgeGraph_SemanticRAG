@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModuloHardware_JOG_PANEL
    a                     ex:InterfazUsuario ;
    rdfs:label            "JOG-PANEL" ;
    ex:textoExtracto       "Módulo hardware. | Teclas de usuario. | JOG-PANEL 1 2 15 16" ;
    ex:identificador       "JOG-PANEL" ;
    ex:tieneComponente    ex:TeclaUsuario_1, ex:TeclaUsuario_2, ex:TeclaUsuario_15, ex:TeclaUsuario_16 .

ex:TeclaUsuario_1
    a                     ex:InterfazUsuario ;
    rdfs:label            "Tecla de usuario 1 (JOG-PANEL)" ;
    ex:textoExtracto       "Se definen con un valor comprendido entre 1 y 16 (con signo) para las teclas que definen el eje y el sentido" ;
    ex:identificador       "1" .

ex:TeclaUsuario_2
    a                     ex:InterfazUsuario ;
    rdfs:label            "Tecla de usuario 2 (JOG-PANEL)" ;
    ex:textoExtracto       "Se definen con un valor comprendido entre 1 y 16 (con signo) para las teclas que definen el eje y el sentido" ;
    ex:identificador       "2" .

ex:TeclaUsuario_15
    a                     ex:InterfazUsuario ;
    rdfs:label            "Tecla de usuario 15 (JOG-PANEL)" ;
    ex:textoExtracto       "Se definen con un valor comprendido entre 1 y 16 (con signo) para las teclas que definen el eje y el sentido" ;
    ex:identificador       "15" .

ex:TeclaUsuario_16
    a                     ex:InterfazUsuario ;
    rdfs:label            "Tecla de usuario 16 (JOG-PANEL)" ;
    ex:textoExtracto       "Se definen con un valor comprendido entre 1 y 16 (con signo) para las teclas que definen el eje y el sentido" ;
    ex:identificador       "16" .

ex:Parametro_JOGKEYBDkbDEF
    a                     ex:Parametro ;
    rdfs:label            "JOGKEYBDkbDEF" ;
    ex:textoExtracto       "El significado de este parámetro es similar al parámetro máquina JOGKEYBDkbDEF" ;
    ex:identificador       "JOGKEYBDkbDEF" .

ex:Parametro_JOGTYPE
    a                     ex:Parametro ;
    rdfs:label            "JOGTYPE" ;
    ex:textoExtracto       "Las teclas de usuario así definidas se comportan de la misma manera que las teclas de jog, bien se hayan definido con signo o sin signo, y respetando también lo definido en el parámetro máquina JOGTYPE" ;
    ex:identificador       "JOGTYPE" .

ex:Parametro_AXISNAME
    a                     ex:Parametro ;
    rdfs:label            "AXISNAME" ;
    ex:textoExtracto       "El número corresponde al eje lógico, según el parámetro AXISNAME" ;
    ex:identificador       "AXISNAME" .

ex:RegistroPLC_KEYBD1
    a                     ex:InterfazUsuario ;
    rdfs:label            "KEYBD1" ;
    ex:textoExtracto       "KEYBD1 / KEYBD2 | Estos registros son una copia del mapa de teclas pulsadas del último teclado utilizado" ;
    ex:identificador       "KEYBD1" .

ex:RegistroPLC_KEYBD2
    a                     ex:InterfazUsuario ;
    rdfs:label            "KEYBD2" ;
    ex:textoExtracto       "KEYBD1 / KEYBD2 | Estos registros son una copia del mapa de teclas pulsadas del último teclado utilizado" ;
    ex:identificador       "KEYBD2" .

ex:RegistroPLC_KEYBD1_1
    a                     ex:InterfazUsuario ;
    rdfs:label            "KEYBD1_1" ;
    ex:textoExtracto       "KEYBD1_1 / KEYBD2_1 | Estos registros indican (bit=1) qué tecla se ha pulsado en cada panel de mando" ;
    ex:identificador       "KEYBD1_1" .

ex:RegistroPLC_KEYBD2_1
    a                     ex:InterfazUsuario ;
    rdfs:label            "KEYBD2_1" ;
    ex:textoExtracto       "KEYBD1_1 / KEYBD2_1 | Estos registros indican (bit=1) qué tecla se ha pulsada en cada panel de mando" ;
    ex:identificador       "KEYBD2_1" .