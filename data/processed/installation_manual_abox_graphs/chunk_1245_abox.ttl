@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:KEYBD1 a ex:Sensor ;
    rdfs:label "KEYBD1" ;
    ex:textoExtracto "Los registros KEYBD1 y KEYBD2 son una copia del mapa de teclas pulsadas del último teclado utilizado."@es ;
    ex:identificador "KEYBD1" .

ex:KEYBD2 a ex:Sensor ;
    rdfs:label "KEYBD2" ;
    ex:textoExtracto "Los registros KEYBD1 y KEYBD2 son una copia del mapa de teclas pulsadas del último teclado utilizado."@es ;
    ex:identificador "KEYBD2" .

ex:KEYBD1_1 a ex:Sensor ;
    rdfs:label "KEYBD1_1" ;
    ex:textoExtracto "Si sólo hay un teclado, estos registros coinciden con KEYBD1_1 y KEYBD2_1."@es ;
    ex:identificador "KEYBD1_1" .

ex:KEYBD2_1 a ex:Sensor ;
    rdfs:label "KEYBD2_1" ;
    ex:textoExtracto "Si sólo hay un teclado, estos registros coinciden con KEYBD1_1 y KEYBD2_1."@es ;
    ex:identificador "KEYBD2_1" .

ex:KEYBD1_2 a ex:Sensor ;
    rdfs:label "KEYBD1_2" ;
    ex:textoExtracto "Los registros KEYBD1_n y KEYBD2_n indican (bit=1) qué tecla se ha pulsado en cada panel de mando. Los registros KEYBD1_1 y KEYBD2_1 corresponden al primer panel de jog, KEYBD1_2 y KEYBD2_2 al segundo y así sucesivamente."@es ;
    ex:identificador "KEYBD1_2" .

ex:KEYBD2_2 a ex:Sensor ;
    rdfs:label "KEYBD2_2" ;
    ex:textoExtracto "Los registros KEYBD1_n y KEYBD2_n indican (bit=1) qué tecla se ha pulsado en cada panel de mando. Los registros KEYBD1_1 y KEYBD2_1 corresponden al primer panel de jog, KEYBD1_2 y KEYBD2_2 al segundo y así sucesivamente."@es ;
    ex:identificador "KEYBD2_2" .