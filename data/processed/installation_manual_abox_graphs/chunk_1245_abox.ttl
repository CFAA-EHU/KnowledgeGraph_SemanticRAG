@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Registro_KEYBD1 a ex:Componente ;
    rdfs:label "Registro KEYBD1" ;
    ex:textoExtracto "Los registros KEYBD1 y KEYBD2 son una copia del mapa de teclas pulsadas del último teclado utilizado. Estos registros indican qué tecla se ha pulsado (bit=1)." .

ex:Registro_KEYBD2 a ex:Componente ;
    rdfs:label "Registro KEYBD2" ;
    ex:textoExtracto "Los registros KEYBD1 y KEYBD2 son una copia del mapa de teclas pulsadas del último teclado utilizado. Estos registros indican qué tecla se ha pulsado (bit=1)." .

ex:Registro_KEYBD1_1 a ex:Componente ;
    rdfs:label "Registro KEYBD1_1" ;
    ex:identificador "KEYBD1_1" ;
    ex:textoExtracto "Los registros KEYBD1_1 y KEYBD2_1 corresponden al primer panel de jog." .

ex:Registro_KEYBD2_1 a ex:Componente ;
    rdfs:label "Registro KEYBD2_1" ;
    ex:identificador "KEYBD2_1" ;
    ex:textoExtracto "Los registros KEYBD1_1 y KEYBD2_1 corresponden al primer panel de jog." .

ex:Registro_KEYBD1_2 a ex:Componente ;
    rdfs:label "Registro KEYBD1_2" ;
    ex:identificador "KEYBD1_2" ;
    ex:textoExtracto "KEYBD1_2 y KEYBD2_2 al segundo [panel de jog]." .

ex:Registro_KEYBD2_2 a ex:Componente ;
    rdfs:label "Registro KEYBD2_2" ;
    ex:identificador "KEYBD2_2" ;
    ex:textoExtracto "KEYBD1_2 y KEYBD2_2 al segundo [panel de jog]." .

ex:PanelJog_1 a ex:InterfazUsuario ;
    rdfs:label "Primer panel de jog" ;
    ex:textoExtracto "Los registros KEYBD1_1 y KEYBD2_1 corresponden al primer panel de jog." ;
    ex:tieneComponente ex:Registro_KEYBD1_1, ex:Registro_KEYBD2_1 .

ex:PanelJog_2 a ex:InterfazUsuario ;
    rdfs:label "Segundo panel de jog" ;
    ex:textoExtracto "KEYBD1_2 y KEYBD2_2 al segundo [panel de jog]." ;
    ex:tieneComponente ex:Registro_KEYBD1_2, ex:Registro_KEYBD2_2 .