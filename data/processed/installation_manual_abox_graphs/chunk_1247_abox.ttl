@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:KEYLED1 a ex:Sensor ;
    rdfs:label "KEYLED1" ;
    ex:textoExtracto "Los registros KEYLED1 y KEYLED2 controlan los led (lámparas) de las teclas de todos los paneles de mando simultáneamente." ;
    ex:valor "controla leds de teclas de paneles de mando" .

ex:KEYLED2 a ex:Sensor ;
    rdfs:label "KEYLED2" ;
    ex:textoExtracto "Los registros KEYLED1 y KEYLED2 controlan los led (lámparas) de las teclas de todos los paneles de mando simultáneamente." ;
    ex:valor "controla leds de teclas de paneles de mando" .

ex:KEYLED1_n a ex:Sensor ;
    rdfs:label "KEYLED1_n" ;
    ex:textoExtracto "Los registros KEYLED1_n y KEYLED2_n controlan los led (lámparas) de las teclas de cada panel de mando." ;
    ex:valor "controla leds de teclas de panel de mando" .

ex:KEYLED2_n a ex:Sensor ;
    rdfs:label "KEYLED2_n" ;
    ex:textoExtracto "Los registros KEYLED1_n y KEYLED2_n controlan los led (lámparas) de las teclas de cada panel de mando." ;
    ex:valor "controla leds de teclas de panel de mando" .

ex:KEYLED1_1 a ex:Sensor ;
    rdfs:label "KEYLED1_1" ;
    ex:textoExtracto "Los registros KEYLED1_1 y KEYLED2_1 corresponden al primer panel de jog." ;
    ex:valor "corresponde a primer panel de jog" .

ex:KEYLED2_1 a ex:Sensor ;
    rdfs:label "KEYLED2_1" ;
    ex:textoExtracto "Los registros KEYLED1_1 y KEYLED2_1 corresponden al primer panel de jog." ;
    ex:valor "corresponde a primer panel de jog" .

ex:KEYLED1_2 a ex:Sensor ;
    rdfs:label "KEYLED1_2" ;
    ex:textoExtracto "Los registros KEYLED1_2 y KEYLED2_2 al segundo y así sucesivamente." ;
    ex:valor "corresponde a segundo panel de jog" .

ex:KEYLED2_2 a ex:Sensor ;
    rdfs:label "KEYLED2_2" ;
    ex:textoExtracto "Los registros KEYLED1_2 y KEYLED2_2 al segundo y así sucesivamente." ;
    ex:valor "corresponde a segundo panel de jog" .