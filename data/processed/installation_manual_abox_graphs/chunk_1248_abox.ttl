    ex:valor "FF" ;
    ex:textoExtracto "Panel de jog asignado al canal activo." .

ex:PANELOFF a ex:Parametro ;
    rdfs:label "PANELOFF" ;
    ex:textoExtracto "Si el PLC pone una de estas marcas a (=1) se deshabilita el panel de jog correspondiente." ;
    ex:valor "1" ;
    ex:textoExtracto "Se deshabilita el panel de jog." .

ex:PANELOFF1 a ex:Parametro ;
    rdfs:label "PANELOFF1" ;
    ex:textoExtracto "Si el PLC activa una de estas marcas, se deshabilita el panel de jog correspondiente." ;
    ex:valor "1" ;
    ex:textoExtracto "Se deshabilita el panel de jog integrado en el bus CAN; el resto de elementos del bus no se ven afectados." .

