@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:KEYBD1CH a ex:Parametro ;
    rdfs:label "KEYBD1CH" ;
    ex:textoExtracto "Estos registros permiten modificar el comportamiento por defecto de los teclados respecto a los canales, definido en los parámetros máquina." ;
    ex:valor "0" ;
    ex:textoExtracto "Configuración definida en los parámetros máquina." .

ex:KEYBD2CH a ex:Parametro ;
    rdfs:label "KEYBD2CH" ;
    ex:textoExtracto "Estos registros permiten modificar el comportamiento por defecto de los teclados respecto a los canales, definido en los parámetros máquina." ;
    ex:valor "1" ;
    ex:textoExtracto "Panel de jog asignado al canal 1." .

