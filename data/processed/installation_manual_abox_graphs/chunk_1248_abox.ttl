@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArchivoDeCompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Archivo de compensación volumétrica" ;
    ns1:identificador "VCOMPFILE MPG" ;
    ns1:textoExtracto "Las tablas de compensación las genera la aplicación de calibración; no son editables desde el CNC." .

ns1:CompensacionVolumetrica_f3b40e4563 a ns1:Parametro ;
    rdfs:label "Compensación volumétrica" ;
    ns1:identificador "VOLCOMP MPG" ;
    ns1:textoExtracto "Este parámetro muestra las tablas de compensación volumétrica." .

ns1:Eje1ParaCompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Eje 1 para compensación volumétrica" ;
    ns1:identificador "VCOMPAXIS1 MPG" ;
    ns1:textoExtracto "Estos parámetros definen los ejes a compensar mediante la compensación volumétrica." .

ns1:Eje2ParaCompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Eje 2 para compensación volumétrica" ;
    ns1:identificador "VCOMPAXIS2 MPG" ;
    ns1:textoExtracto "Estos parámetros definen los ejes a compensar mediante la compensación volumétrica." .

ns1:Eje3ParaCompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Eje 3 para compensación volumétrica" ;
    ns1:identificador "VCOMPAXIS3 MPG" ;
    ns1:textoExtracto "Estos parámetros definen los ejes a compensar mediante la compensación volumétrica." .

