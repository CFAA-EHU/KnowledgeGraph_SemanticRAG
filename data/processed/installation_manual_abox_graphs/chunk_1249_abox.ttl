@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PanelJog1 a ex:ComponenteElectrico ;
    rdfs:label "Panel de jog" ;
    ex:identificador "PANELOFF1" ;
    ex:textoExtracto "La marca PANELOFF1 deshabilita el primero del bus" ;
    ex:textoExtracto "Panel de jog | PANELOFF1" .

ex:PanelJog2 a ex:ComponenteElectrico ;
    rdfs:label "Panel de jog" ;
    ex:identificador "PANELOFF2" ;
    ex:textoExtracto "La marca PANELOFF2 deshabilita el segundo del bus" ;
    ex:textoExtracto "Panel de jog | PANELOFF2" .

ex:TablaConfiguracionPrestacion a ex:Tabla ;
    ex:textoExtracto "Address | Elemento | Marca de PLC | --- | --- | --- | 0 | CNC |  | 1 | Grupo remoto (I/Os) |  | 2 | Panel de jog | PANELOFF1 | 3 | Grupo remoto (I/Os) |  | 4 | Grupo remoto (I/Os) |  | 5 | Panel de jog | PANELOFF2" ;
    ex:tieneComponente ex:PanelJog1, ex:PanelJog2 .