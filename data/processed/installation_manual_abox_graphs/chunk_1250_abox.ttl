@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_37cdc5f8a0 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC aplica la compensación volumétrica después de aplicar la compensación de husillo y la compensación cruzada." .

ns1:CompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "compensación volumétrica" ;
    ns1:textoExtracto "La compensación volumétrica permanece activa tras un reset, error o fin de programa (M30)." .

