@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArchivoConLosDatosDeLaCompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Archivo con los datos de la compensación volumétrica" ;
    ns1:identificador "MPG.VCOMPFILE" ;
    ns1:textoExtracto "\"(V.)MPG.VCOMPFILE[tbl] Archivo con los datos de la compensación volumétrica. Unidades: -.\"" .

ns1:NombreDelSegundoEjeDeLaPrimeraTablaDeCompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Nombre del segundo eje de la primera tabla de compensación volumétrica" ;
    ns1:identificador "MPG.VMOVAXIS2" ;
    ns1:textoExtracto "\"V.MPG.VMOVAXIS2[1] Nombre del segundo eje de la primera tabla de compensación volumétrica.\"" .

ns1:NumeroDePuntosDelSegundoEjeDeLaSegundaTablaDeCompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Número de puntos del segundo eje de la segunda tabla de compensación volumétrica" ;
    ns1:identificador "MPG.NPOINTAX2" ;
    ns1:textoExtracto "\"V.MPG.NPOINTAX2[2] Número de puntos del segundo eje de la segunda tabla de compensación volumétrica.\"" .

ns1:ValorDeLasMarcasVOLCOMP1 a ns1:Parametro ;
    rdfs:label "Valor de las marcas VOLCOMP1" ;
    ns1:identificador "PLC.VOLCOMP1" ;
    ns1:textoExtracto "\"(V.)PLC.VOLCOMP1 Estas variables reflejan el valor de las marcas VOLCOMP1 a VOLCOMP4 del PLC.\"" .

ns1:ValorDeLasMarcasVOLCOMP2 a ns1:Parametro ;
    rdfs:label "Valor de las marcas VOLCOMP2" ;
    ns1:identificador "PLC.VOLCOMP2" ;
    ns1:textoExtracto "\"(V.)PLC.VOLCOMP2 Estas variables reflejan el valor de las marcas VOLCOMP1 a VOLCOMP4 del PLC.\"" .

ns1:ValorDeLasMarcasVOLCOMP3 a ns1:Parametro ;
    rdfs:label "Valor de las marcas VOLCOMP3" ;
    ns1:identificador "PLC.VOLCOMP3" ;
    ns1:textoExtracto "\"(V.)PLC.VOLCOMP3 Estas variables reflejan el valor de las marcas VOLCOMP1 a VOLCOMP4 del PLC.\"" .

ns1:ValorDeLasMarcasVOLCOMP4 a ns1:Parametro ;
    rdfs:label "Valor de las marcas VOLCOMP4" ;
    ns1:identificador "PLC.VOLCOMP4" ;
    ns1:textoExtracto "\"(V.)PLC.VOLCOMP4 Estas variables reflejan el valor de las marcas VOLCOMP1 a VOLCOMP4 del PLC.\"" .

