@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Pulsador_I71 a ex:Sensor ;
    rdfs:label "Pulsador para activar y desactivar el volante de avance"@es ;
    ex:identificador "I71" ;
    ex:textoExtracto "La máquina dispone de un pulsador para activar y desactivar el volante de avance (entrada I71)"@es .

ex:Volante_Avance a ex:ComponenteMecanico ;
    rdfs:label "Volante de avance"@es ;
    ex:textoExtracto "el control del avance se efectúa con el segundo volante"@es .

ex:Marca_M1000 a ex:ComponenteElectrico ;
    rdfs:label "Marca auxiliar M1000"@es ;
    ex:identificador "M1000" ;
    ex:textoExtracto "M1000 _____ Volante de avance activo."@es .

ex:Registro_R100 a ex:ComponenteElectrico ;
    rdfs:label "Registro R100"@es ;
    ex:identificador "R100" ;
    ex:textoExtracto "R100 _____ Impulsos totales del volante."@es .

ex:Registro_R101 a ex:ComponenteElectrico ;
    rdfs:label "Registro R101"@es ;
    ex:identificador "R101" ;
    ex:textoExtracto "R101 _____ Impulsos del volante hasta la lectura anterior."@es .

ex:Registro_R102 a ex:ComponenteElectrico ;
    rdfs:label "Registro R102"@es ;
    ex:identificador "R102" ;
    ex:textoExtracto "R102 _____ Impulsos del volante desde la lectura anterior."@es .

ex:Registro_R103 a ex:ComponenteElectrico ;
    rdfs:label "Registro R103"@es ;
    ex:identificador "R103" ;
    ex:textoExtracto "R103 _____ Porcentaje de avance calculado."@es .

ex:Reloj_CLK100 a ex:Sensor ;
    rdfs:label "Reloj CLK100"@es ;
    ex:identificador "CLK100" ;
    ex:textoExtracto "Si está activo el volante avance y se produce un flanco de subida en el reloj CLK100"@es .

ex:Conmutador_FeedOverride a ex:ComponenteElectrico ;
    rdfs:label "Conmutador feed override"@es ;
    ex:textoExtracto "desinhibir todas las posiciones del conmutador feed override y continuar con la ejecución del programa"@es .