@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:PulsadorVolanteAvance_I71
    a               ex:ComponenteElectrico ;
    rdfs:label      "Pulsador para activar/desactivar volante de avance (I71)" ;
    ex:identificador "I71" ;
    ex:textoExtracto "I71 _____ Pulsador para activar y desactivar el volante de avance." ;
    ex:controla     ex:VolanteAvance .

ex:VolanteAvance
    a               ex:ComponenteMecanico ;
    rdfs:label      "Volante de avance" ;
    ex:textoExtracto "el control del avance se efectúa con el segundo volante." ;
    ex:monitoreaParametro ex:ParametroImpulsosTotales_R100 ;
    ex:monitoreaParametro ex:ParametroPorcentajeAvance_R103 .

ex:ParametroImpulsosTotales_R100
    a               ex:Parametro ;
    rdfs:label      "Impulsos totales del volante (R100)" ;
    ex:identificador "R100" ;
    ex:textoExtracto "R100 _____ Impulsos totales del volante." ;
    ex:valor         "Valor acumulado de impulsos del volante" .

ex:ParametroImpulsosAnteriores_R101
    a               ex:Parametro ;
    rdfs:label      "Impulsos del volante hasta la lectura anterior (R101)" ;
    ex:identificador "R101" ;
    ex:textoExtracto "R101 _____ Impulsos del volante hasta la lectura anterior." .

ex:ParametroImpulsosDesdeLectura_R102
    a               ex:Parametro ;
    rdfs:label      "Impulsos del volante desde la lectura anterior (R102)" ;
    ex:identificador "R102" ;
    ex:textoExtracto "R102 _____ Impulsos del volante desde la lectura anterior." .

ex:ParametroPorcentajeAvance_R103
    a               ex:Parametro ;
    rdfs:label      "Porcentaje de avance calculado (R103)" ;
    ex:identificador "R103" ;
    ex:textoExtracto "R103 _____ Porcentaje de avance calculado." .

ex:MarcaVolanteActivo_M1000
    a               ex:Actuador ;
    rdfs:label      "Marca: Volante de avance activo (M1000)" ;
    ex:identificador "M1000" ;
    ex:textoExtracto "M1000 _____ Volante de avance activo." ;
    ex:controla     ex:AvisoVolanteActivo .

ex:AvisoVolanteActivo
    a               ex:AvisoSeguridad ;
    rdfs:label      "Mensaje de volante de avance activo" ;
    ex:textoExtracto "Si está activo el volante de avance, mostrar un mensaje." .

ex:SistemaControlAvance_PLC
    a               ex:Sistema ;
    rdfs:label      "Sistema de control de avance (PLC)" ;
    ex:textoExtracto "Ejemplo de maniobra del PLC. La máquina dispone de un pulsador para activar y desactivar el volante de avance..." ;
    ex:tieneComponente ex:PulsadorVolanteAvance_I71 ;
    ex:tieneComponente ex:VolanteAvance ;
    ex:tieneComponente ex:MarcaVolanteActivo_M1000 ;
    ex:monitoreaParametro ex:ParametroImpulsosTotales_R100 ;
    ex:monitoreaParametro ex:ParametroImpulsosAnteriores_R101 ;
    ex:monitoreaParametro ex:ParametroImpulsosDesdeLectura_R102 ;
    ex:monitoreaParametro ex:ParametroPorcentajeAvance_R103 .