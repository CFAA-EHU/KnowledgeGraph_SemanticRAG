@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:R103 a ex:Parametro ;
    ex:identificador "R103" ;
    ex:textoExtracto "Ajustar el valor del registro R103; ignorar el sentido de giro del volante (signo) y limitar el valor al 120%." .

ex:Parametro_120 a ex:Parametro ;
    ex:identificador "120" ;
    ex:textoExtracto "CPS R103 GT 120 = MOV 120 R103" .

ex:Parametro_0 a ex:Parametro ;
    ex:identificador "0" ;
    ex:textoExtracto "CPS R103 LT 0 = SBS 0 R103 R103" .

ex:CLK100 a ex:Frecuencia ;
    ex:identificador "CLK100" ;
    ex:textoExtracto "DFU CLK100 = CNCWR (R103,PLC.FRO, M1001)" .

ex:M1001 a ex:Parametro ;
    ex:identificador "M1001" ;
    ex:textoExtracto "DFU CLK100 = CNCWR (R103,PLC.FRO, M1001)" .

ex:L101 a ex:Parametro ;
    ex:identificador "L101" ;
    ex:textoExtracto "L101 END" .