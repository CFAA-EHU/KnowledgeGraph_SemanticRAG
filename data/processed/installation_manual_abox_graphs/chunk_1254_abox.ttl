@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SoftkeyHelper_txt a ex:Esquema ;
    ex:textoExtracto "Los textos de ayuda están definidos en el archivo SoftkeyHelper.txt, y puede haber un archivo por cada idioma, los cuales se guardan en la carpeta \"..\\MTB \\data \\Lang\". El archivo está en formato texto, por lo que se pueden ver y editar (y por lo tanto traducir a otros idiomas) en cualquier editor de texto." ;
    ex:compuestoPor ex:AUTOMATIC_MODE, ex:HMI .

ex:AUTOMATIC_MODE a ex:ModoOperacion ;
    ex:textoExtracto "El archivo está dividido en secciones, una por cada modo de operación, en cada una de las cuales está la lista de softkeys y el texto de ayuda que tiene asociado. Por ejemplo, para el modo automático. [ AUTOMATIC MODE] AUTO1=Seleccionar programa AUTO2=Prg en simulación AUTO3=Inspección AUTO4=Abandonar inspección AUTO5=Reposicionar AUTO6=Reposicionar inicio bloque AUTO7=Modo ejecución AUTO8=Cancelar bloque AUTO9=Gráficos" ;
    ex:tieneComponente ex:AUTO1, ex:AUTO2, ex:AUTO3, ex:AUTO4, ex:AUTO5, ex:AUTO6, ex:AUTO7, ex:AUTO8, ex:AUTO9 .

ex:AUTO1 a ex:TareaMantenimiento ;
    ex:textoExtracto "AUTO1=Seleccionar programa" .

ex:AUTO2 a ex:TareaMantenimiento ;
    ex:textoExtracto "AUTO2=Prg en simulación" .

ex:AUTO3 a ex:TareaMantenimiento ;
    ex:textoExtracto "AUTO3=Inspección" .

ex:AUTO4 a ex:TareaMantenimiento ;
    ex:textoExtracto "AUTO4=Abandonar inspección" .

ex:AUTO5 a ex:TareaMantenimiento ;
    ex:textoExtracto "AUTO5=Reposicionar" .

ex:AUTO6 a ex:TareaMantenimiento ;
    ex:textoExtracto "AUTO6=Reposicionar inicio bloque" .

ex:AUTO7 a ex:TareaMantenimiento ;
    ex:textoExtracto "AUTO7=Modo ejecución" .

ex:AUTO8 a ex:TareaMantenimiento ;
    ex:textoExtracto "AUTO8=Cancelar bloque" .

ex:AUTO9 a ex:TareaMantenimiento ;
    ex:textoExtracto "AUTO9=Gráficos" .

ex:HMI a ex:ModoOperacion ;
    ex:textoExtracto "Texto de ayuda del icono de estado del CNC. En el archivo SoftkeyHelper.txt también es posible asignar un texto de ayuda a los iconos que muestran el estado del CNC, en la parte superior de la pantalla. Estos textos de ayuda se definen en la sección [HMI]. [ HMI] HMI_NOREADY= HMI_READY= HMI_INEXECUTION= HMI_INTERRUPTED= HMI_INERROR=" ;
    ex:tieneComponente ex:HMI_NOREADY, ex:HMI_READY, ex:HMI_INEXECUTION, ex:HMI_INTERRUPTED, ex:HMI_INERROR .

ex:HMI_NOREADY a ex:TareaMantenimiento ;
    ex:textoExtracto "HMI_NOREADY=" .

ex:HMI_READY a ex:TareaMantenimiento ;
    ex:textoExtracto "HMI_READY=" .

ex:HMI_INEXECUTION a ex:TareaMantenimiento ;
    ex:textoExtracto "HMI_INEXECUTION=" .

ex:HMI_INTERRUPTED a ex:TareaMantenimiento ;
    ex:textoExtracto "HMI_INTERRUPTED=" .

ex:HMI_INERROR a ex:TareaMantenimiento ;
    ex:textoExtracto "HMI_INERROR=" .