@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorreccionDeParametrosMaquina a ns1:TareaMantenimiento ;
    rdfs:label "Corrección de parámetros máquina" ;
    ns1:solucionaFallo ns1:EjeInexistente_e290dc00b3 ;
    ns1:textoExtracto "SOLUCIÓN Corregir los parámetros máquina. Los nombres de eje válidos son los definidos en el parámetro AXISNAME." .

ns1:OpcionDeSoftwareNoPermitida a ns1:DiagnosticoFallo ;
    rdfs:label "Opción de software no permitida" ;
    ns1:textoExtracto "'Opción de software no permitida' DETECCIÓN Durante la ejecución. CAUSA El CNC no dispone de la opción de software necesaria para ejecutar la orden programada. SOLUCIÓN En el modo diagnosis se pueden consultar las opciones de software disponibles en el CNC." .

ns1:RevisionDeProgramacion_2f5a95c092 a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de programación" ;
    ns1:solucionaFallo ns1:ValorDeParametroNoValido ;
    ns1:textoExtracto "SOLUCIÓN Revisar la programación." .

ns1:EjeInexistente_e290dc00b3 a ns1:DiagnosticoFallo ;
    rdfs:label "Eje inexistente" ;
    ns1:textoExtracto "'Eje inexistente' DETECCIÓN Durante la validación de los parámetros máquina. CAUSA Las posibles causas son las siguientes: • El usuario ha asignado a un parámetro máquina el nombre de un eje que no existe. • En la compensación volumétrica básica, no se ha definido uno de los ejes VMOVAXIS o VCOMPAXIS. SOLUCIÓN Corregir los parámetros máquina. Los nombres de eje válidos son los definidos en el parámetro AXISNAME." .

ns1:ValorDeParametroNoValido a ns1:DiagnosticoFallo ;
    rdfs:label "Valor de parámetro no válido" ;
    ns1:textoExtracto "'Valor de parámetro no válido' DETECCIÓN Durante la ejecución. CAUSA En una sentencia o en un ciclo fijo, un parámetro tiene un valor no válido. SOLUCIÓN Revisar la programación." .

