@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ContadoraSercos1 a ex:ComponenteElectrico ;
    rdfs:label "contadora Sercos"@es ;
    ex:textoExtracto "La contadora Sercos es, al igual que los reguladores, un tipo de nodo del anillo Sercos."@es .

ex:ReguladorSercos1 a ex:ComponenteElectrico ;
    rdfs:label "regulador"@es ;
    ex:textoExtracto "La contadora Sercos es, al igual que los reguladores, un tipo de nodo del anillo Sercos."@es .

ex:AnilloSercos1 a ex:Sistema ;
    rdfs:label "anillo Sercos"@es ;
    ex:textoExtracto "La contadora Sercos es, al igual que los reguladores, un tipo de nodo del anillo Sercos."@es ;
    ex:compuestoPor ex:ContadoraSercos1, ex:ReguladorSercos1 .

ex:ParametroNSERCOUNT a ex:Parametro ;
    rdfs:label "NSERCOUNT"@es ;
    ex:identificador "NSERCOUNT"@es ;
    ex:textoExtracto "Parámetro. | Significado. | NSERCOUNT | Número de nodos contadoras Sercos en el bus."@es .

ex:ParametroSERCOUNTID a ex:Parametro ;
    rdfs:label "SERCOUNTID"@es ;
    ex:identificador "SERCOUNTID"@es ;
    ex:textoExtracto "Parámetro. | Significado. | SERCOUNTID | Tabla de identificadores de la ruleta asociadas a las contadoras Sercos."@es .

ex:TablaSERCOUNTID a ex:Tabla ;
    rdfs:label "tabla SERCOUNTID"@es ;
    ex:identificador "SERCOUNTID"@es ;
    ex:textoExtracto "La tabla SERCOUNTID de los parámetros máquina generales, nos permite enlazar la numeración lógica de las contadoras Sercos (1..8) con la numeración física determinada por la ruleta de cada nodo (introducir en cada posición de la tabla el Sercos ID asociado a dicha posición lógica de contadora)."@es ;
    ex:documentadoEn ex:ParametroSERCOUNTID .

ex:RuletaContadoraSercos1 a ex:ComponenteElectrico ;
    rdfs:label "ruleta de contadora Sercos"@es ;
    ex:textoExtracto "Cada contadora deberá identificarse físicamente por una numeración (Sercos ID), a través de la ruleta que incorpora en su frontal."@es .

ex:ContadoraSercos2 a ex:ComponenteElectrico ;
    rdfs:label "contadora Sercos"@es ;
    ex:identificador "Sercos ID"@es ;
    ex:textoExtracto "Cada contadora deberá identificarse físicamente por una numeración (Sercos ID), a través de la ruleta que incorpora en su frontal."@es ;
    ex:tieneComponente ex:RuletaContadoraSercos1 .

ex:AnilloSercos2 a ex:Sistema ;
    rdfs:label "anillo Sercos"@es ;
    ex:textoExtracto "Dicho identificador deberá ser único en el anillo, siguiendo un criterio de numeración correlativo de 1 a n y sin huecos (siendo n el número total de nodos Sercos, considerando tanto reguladores como contadoras)."@es ;
    ex:compuestoPor ex:ContadoraSercos2, ex:ReguladorSercos1 .