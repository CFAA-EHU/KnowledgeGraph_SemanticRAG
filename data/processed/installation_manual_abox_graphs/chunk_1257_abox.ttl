@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_ANAOUTTYPE a ex:Parametro ;
    rdfs:label "ANAOUTTYPE" ;
    ex:textoExtracto "Parámetro. | ANAOUTTYPE | Tipo de salida analógica asociada al eje." ;
    ex:valor "Tipo de salida analógica asociada al eje." .

ex:Parametro_ANAOUTID a ex:Parametro ;
    rdfs:label "ANAOUTID" ;
    ex:textoExtracto "Parámetro. | ANAOUTID | Número de la salida analógica asociada al eje." ;
    ex:valor "Número de la salida analógica asociada al eje." .

ex:Parametro_ANAOUTTYPE_valor_modulo_RCS_S a ex:Parametro ;
    rdfs:label "ANAOUTTYPE" ;
    ex:textoExtracto "Parámetro. | ANAOUTTYPE | Módulo RCS-S (contadora Sercos)" ;
    ex:valor "Módulo RCS-S (contadora Sercos)" .

ex:Parametro_ANAOUTID_valor_1_4 a ex:Parametro ;
    rdfs:label "ANAOUTID" ;
    ex:textoExtracto "Parámetro. | ANAOUTID | 1 - 4." ;
    ex:valor "1 - 4" .

ex:Sistema_configuracion_salidas_analogicas a ex:Sistema ;
    rdfs:label "Configuración de salidas analógicas" ;
    ex:textoExtracto "La salida analógica se configura desde los parámetros máquina. Cada eje dispone de los siguientes parámetros máquina para su configuración." .

ex:Parametro_ANAOUTTYPE ex:tieneComponente ex:Parametro_ANAOUTTYPE_valor_modulo_RCS_S .
ex:Parametro_ANAOUTID ex:tieneComponente ex:Parametro_ANAOUTID_valor_1_4 .
ex:Sistema_configuracion_salidas_analogicas ex:compuestoPor ex:Parametro_ANAOUTTYPE, ex:Parametro_ANAOUTID .