@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_ANAOUTTYPE
    a ex:Parametro ;
    rdfs:label "ANAOUTTYPE" ;
    ex:textoExtracto "Tipo de salida analógica asociada al eje." ;
    ex:monitoreaParametro ex:SalidaAnalogica_Eje .

ex:Parametro_ANAOUTID
    a ex:Parametro ;
    rdfs:label "ANAOUTID" ;
    ex:textoExtracto "Número de la salida analógica asociada al eje." ;
    ex:monitoreaParametro ex:SalidaAnalogica_Eje ;
    ex:valor "1 - 4" .

ex:SalidaAnalogica_Eje
    a ex:ComponenteElectrico ;
    ex:textoExtracto "La salida analógica se configura desde los parámetros máquina. Cada eje dispone de los siguientes parámetros máquina para su configuración." ;
    ex:controla ex:EjeAnalogico .

ex:EjeAnalogico
    a ex:ComponenteMecanico ;
    ex:textoExtracto "Cada eje dispone de los siguientes parámetros máquina para su configuración." ;
    ex:controla ex:ConsignaAnalogica .

ex:ConsignaAnalogica
    a ex:Parametro ;
    ex:textoExtracto "La consigna para un eje analógico se puede tomar desde una salida analógica de los módulos remotos, de un regulador Sercos o de una contadora Sercos." .

ex:ModuloRCS_S
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S (contadora Sercos)" ;
    ex:textoExtracto "ANAOUTTYPE | Módulo RCS-S (contadora Sercos)" ;
    ex:tieneComponente ex:SalidaAnalogica_ContadoraSercos .

ex:SalidaAnalogica_ContadoraSercos
    a ex:ComponenteElectrico ;
    ex:textoExtracto "Las salidas analógicas del primer módulo serán 1 a 4, las del segundo 5 a 8 y así sucesivamente." ;
    ex:controla ex:ConsignaAnalogica .

ex:Tabla_ConfiguracionSalidasAnalogicas a ex:Tabla ;
     a ex:Tabla ;
    ex:textoExtracto "Configurar las salidas analógicas. [...] La selección se realiza mediante los parámetros ANAOUTTYPE y ANAOUTID." ;
    ex:documentadoEn ex:Manual_Configuracion ;
    ex:detalladoEnEsquema ex:Esquema_ParametrosEje .

ex:Esquema_ParametrosEje
    a ex:Esquema ;
    ex:textoExtracto "Parámetros máquina para configuración de salidas analógicas por eje." ;
    ex:ilustradoEn ex:Tabla_ConfiguracionSalidasAnalogicas .