@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_COUNTERTYPE a ex:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ex:textoExtracto "Parámetro. | COUNTERTYPE | Tipo de entrada de captación del eje." ;
    ex:valor "Tipo de entrada de captación del eje" .

ex:Parametro_COUNTERID a ex:Parametro ;
    rdfs:label "COUNTERID" ;
    ex:textoExtracto "Parámetro. | COUNTERID | Número de la entrada de captación del eje." ;
    ex:valor "Número de la entrada de captación del eje" .

ex:Parametro_SERCOUNTID a ex:Parametro ;
    rdfs:label "SERCOUNTID" ;
    ex:textoExtracto "Las contadoras Sercos se numeran según su orden lógico (parámetro SERCOUNTID)." .

ex:Sistema_ContadoraSercos a ex:Sistema ;
    rdfs:label "contadora Sercos" ;
    ex:textoExtracto "La entrada de captación del eje puede estar ubicada ... en una contadora Sercos ..." .

ex:Sistema_ModuloRemoto a ex:Sistema ;
    rdfs:label "módulos remotos" ;
    ex:textoExtracto "La entrada de captación del eje puede estar ubicada ... en los módulos remotos ..." .

ex:Sistema_ReguladorSercos a ex:Sistema ;
    rdfs:label "regulador Sercos" ;
    ex:textoExtracto "La entrada de captación del eje puede estar ubicada ... en la captación libre de un regulador Sercos ..." .

ex:Sistema_EntradaCaptacionLocal a ex:Sistema ;
    rdfs:label "entradas de captación locales de la unidad central" ;
    ex:textoExtracto "La entrada de captación del eje puede estar ubicada ... en las entradas de captación locales de la unidad central." .

ex:Parametro_COUNTERTYPE_SERCOS a ex:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ex:textoExtracto "Parámetro. | COUNTERTYPE | Módulo RCS-S (contadora Sercos)" ;
    ex:valor "Módulo RCS-S (contadora Sercos)" .

ex:Parametro_COUNTERID_Rango a ex:Parametro ;
    rdfs:label "COUNTERID" ;
    ex:textoExtracto "Parámetro. | COUNTERID | 1 - 32." ;
    ex:valor "1 - 32" .