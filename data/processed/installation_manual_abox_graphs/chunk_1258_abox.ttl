@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_COUNTERTYPE
    a ex:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ex:textoExtracto "COUNTERTYPE | Tipo de entrada de captación del eje." ;
    ex:valor "Módulo RCS-S (contadora Sercos)" .

ex:Parametro_COUNTERID
    a ex:Parametro ;
    rdfs:label "COUNTERID" ;
    ex:textoExtracto "COUNTERID | Número de la entrada de captación del eje." ;
    ex:textoExtracto "COUNTERID | 1 - 32." ;
    ex:valor "1-32" .

ex:Parametro_SERCOUNTID
    a ex:Parametro ;
    rdfs:label "SERCOUNTID" ;
    ex:textoExtracto "Las contadoras Sercos se numeran según su orden lógico (parámetro SERCOUNTID)." .

ex:Sistema_EntradasCaptacion
    a ex:Sistema ;
    rdfs:label "Sistema de entradas de captación" ;
    ex:textoExtracto "La entrada de captación del eje puede estar ubicada en los módulos remotos, en la captación libre de un regulador Sercos, en una contadora Sercos o en las entradas de captación locales de la unidad central." ;
    ex:tieneComponente ex:ContadoraSercos_RCS_S .

ex:ContadoraSercos_RCS_S
    a ex:ComponenteElectrico ;
    rdfs:label "Contadora Sercos (RCS-S)" ;
    ex:textoExtracto "Módulo RCS-S (contadora Sercos)" ;
    ex:textoExtracto "Las contadoras Sercos se numeran según su orden lógico (parámetro SERCOUNTID). Las entradas de captación del primer módulo serán 1 a 4, las del segundo 5 a 8 y así sucesivamente." ;
    ex:monitoreaParametro ex:Parametro_COUNTERID ;
    ex:monitoreaParametro ex:Parametro_SERCOUNTID .

ex:Tabla_ConfiguracionEntradasCaptacion a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Configuración de entradas de captación" ;
    ex:textoExtracto "| Parámetro. | Significado. | --- | --- | COUNTERTYPE | Tipo de entrada de captación del eje. | COUNTERID | Número de la entrada de captación del eje." ;
    ex:documentadoEn ex:Sistema_EntradasCaptacion .