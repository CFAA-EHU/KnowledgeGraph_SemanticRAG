@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FicheroDeCompensacionVolumetrica_a017d3b80e a ns1:Parametro ;
    rdfs:label "Fichero de compensación volumétrica" ;
    ns1:textoExtracto "El formato del fichero definido en VCOMPFILE no es correcto." .

ns1:NumeroDePuntosEnElEje1 a ns1:Parametro ;
    rdfs:label "Número de puntos en el eje 1" ;
    ns1:textoExtracto "El número de puntos viene definido por la expresión: NPOINTSAX1 × NPOINTSAX2 × NPOINTSAX3" .

ns1:NumeroDePuntosEnElEje2 a ns1:Parametro ;
    rdfs:label "Número de puntos en el eje 2" ;
    ns1:textoExtracto "El número de puntos viene definido por la expresión: NPOINTSAX1 × NPOINTSAX2 × NPOINTSAX3" .

ns1:NumeroDePuntosEnElEje3 a ns1:Parametro ;
    rdfs:label "Número de puntos en el eje 3" ;
    ns1:textoExtracto "El número de puntos viene definido por la expresión: NPOINTSAX1 × NPOINTSAX2 × NPOINTSAX3" .

ns1:SeleccionDeUnFicheroAdecuadoParaLaCompensacionVolumetrica a ns1:TareaMantenimiento ;
    rdfs:label "Selección de un fichero adecuado para la compensación volumétrica" ;
    ns1:solucionaFallo ns1:ErrorDelSistemaDeCompensacionVolumetrica_6e1a2cf973 ;
    ns1:textoExtracto "Seleccionar un fichero adecuado. En la compensación volumétrica básica, el fichero debe ser del tipo csv y tener todos los puntos definidos." .

ns1:ErrorDelSistemaDeCompensacionVolumetrica_6e1a2cf973 a ns1:DiagnosticoFallo ;
    rdfs:label "Error del sistema de compensación volumétrica" ;
    ns1:textoExtracto "'Error del sistema de compensación volumétrica;" .

