ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:DefinirUnaCompensacionVolumetricaAdecuadaEnLosParametrosMaquinaParametrosVOLCOMP a ns1:TareaMantenimiento ;
    rdfs:label "Definir una compensación volumétrica adecuada en los parámetros máquina (parámetros VOLCOMP)" ;
    ns1:solucionaFallo ns1:NoSePuedeActivarLaMarcaVOLCOMPSinUnaTablaValidada_fae891c7b2 ;
    ns1:textoExtracto "SOLUCIÓN Definir una compensación volumétrica adecuada en los parámetros máquina (parámetros VOLCOMP)." .

ns1:NoSePuedeActivarLaMarcaVOLCOMPConOtraTablaActivaSobreEjesComunes_ec82aa3cdb a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede activar la marca VOLCOMP con otra tabla activa sobre ejes comunes" ;
    ns1:textoExtracto "'No se puede activar la marca VOLCOMP con otra tabla activa sobre ejes comunes' DETECCIÓN Durante la ejecución." .

ns1:PongaseEnContactoConFagorAutomation a ns1:TareaMantenimiento ;
    rdfs:label "Póngase en contacto con Fagor Automation" ;
    ns1:solucionaFallo ns1:ErrorDelSistemaDeCompensacionVolumetricaCompensacionDesactivada_c23b859b00 ;
    ns1:textoExtracto "SOLUCIÓN Póngase en contacto con Fagor Automation." .

ns1:ErrorDelSistemaDeCompensacionVolumetricaCompensacionDesactivada_c23b859b00 a ns1:DiagnosticoFallo ;
    rdfs:label "Error del sistema de compensación volumétrica; compensación desactivada" ;
    ns1:textoExtracto "'Error del sistema de compensación volumétrica; compensación desactivada' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado un error interno en el cálculo de la compensación volumétrica, y ha anulado los valores de la compensación." .

ns1:NoSePuedeActivarLaMarcaVOLCOMPSinUnaTablaValidada_fae891c7b2 a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede activar la marca VOLCOMP sin una tabla validada" ;
    ns1:textoExtracto "'No se puede activar la marca VOLCOMP sin una tabla validada' DETECCIÓN Durante la ejecución. CAUSA El PLC ha intentado activar una compensación volumétrica que no está definida de forma correcta y por lo tanto no es posible la compensación de la máquina." .

