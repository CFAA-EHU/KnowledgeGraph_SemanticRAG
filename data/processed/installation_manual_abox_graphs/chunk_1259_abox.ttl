@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Volante_1259_676 a ex:ComponenteMecanico ;
    ex:textoExtracto "El volante se configura desde los parámetros máquina del modo manual." ;
    ex:tieneComponente ex:COUNTERTYPE_1259_676, ex:COUNTERID_1259_676 .

ex:COUNTERTYPE_1259_676 a ex:Parametro ;
    ex:identificador "COUNTERTYPE" ;
    ex:textoExtracto "Parámetro. | Significado. | COUNTERTYPE | Tipo de entrada de captación del volante." ;
    ex:valor "Tipo de entrada de captación del volante" .

ex:COUNTERID_1259_676 a ex:Parametro ;
    ex:identificador "COUNTERID" ;
    ex:textoExtracto "Parámetro. | Significado. | COUNTERID | Entrada de captación asociada al volante." ;
    ex:valor "Entrada de captación asociada al volante" .

ex:ModuloRCSS_1259_676 a ex:ComponenteElectrico ;
    ex:identificador "RCS-S (contadora Sercos)" ;
    ex:textoExtracto "COUNTERTYPE | Módulo RCS-S (contadora Sercos)" .

ex:EntradaCaptacionSercos_1259_676 a ex:Sensor ;
    ex:identificador "1 - 32" ;
    ex:textoExtracto "COUNTERID | 1 - 32." ;
    ex:valor "1 - 32" .