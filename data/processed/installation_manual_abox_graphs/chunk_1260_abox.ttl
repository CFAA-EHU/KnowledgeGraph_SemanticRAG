@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TablaDRIVEVAR a ex:Tabla ;
    ex:textoExtracto "En los parámetros máquina OEM, acceder a la tabla DRIVEVAR." .

ex:ParametroDRIVEVAR a ex:Parametro ;
    ex:textoExtracto "Las alarmas de las entradas de captación del módulo RCS-S (contadora Sercos) se pueden desactivar utilizando variables del regulador (parámetro DRIVEVAR)." .

ex:ModuloRCS_S a ex:ComponenteElectrico ;
    ex:textoExtracto "módulo RCS-S (contadora Sercos)" .

ex:VariableDRV_RCSALARM_4 a ex:Parametro ;
    ex:identificador "V.DRV.RCSALARM.4" ;
    ex:textoExtracto "El acceso desde el CNC será V.DRV.RCSALARM.4" .

ex:VariableDRV_RCSALARM_4_PLC a ex:Parametro ;
    ex:identificador "DRV.RCSALARM.4" ;
    ex:textoExtracto "El acceso desde el PLC será DRV.RCSALARM.4" .

ex:IDN_Sercos_33349 a ex:Parametro ;
    ex:identificador "33349" ;
    ex:textoExtracto "• IDN Sercos 33349 para la entrada de captación 2." .

ex:IDN_Sercos_33350 a ex:Parametro ;
    ex:identificador "33350" ;
    ex:textoExtracto "• IDN Sercos 33350 para la entrada de captación 3." .

ex:IDN_Sercos_33351 a ex:Parametro ;
    ex:identificador "33351" ;
    ex:textoExtracto "• IDN Sercos 33351 para la entrada de captación 4." .

ex:IDN_Sercos_33348 a ex:Parametro ;
    ex:identificador "33348" ;
    ex:textoExtracto "• IDN Sercos 33348 para la entrada de captación 1." .

ex:ParametroSERCOUNTID a ex:Parametro ;
    ex:identificador "SERCOUNTID" ;
    ex:textoExtracto "Número de nodo del módulo RCS-S (parámetro SERCOUNTID)." .

ex:TablaDRIVEVAR a ex:Tabla ;
    ex:tieneComponente ex:ParametroDRIVEVAR, ex:IDN_Sercos_33348, ex:IDN_Sercos_33349, ex:IDN_Sercos_33350, ex:IDN_Sercos_33351, ex:ParametroSERCOUNTID, ex:VariableDRV_RCSALARM_4, ex:VariableDRV_RCSALARM_4_PLC .