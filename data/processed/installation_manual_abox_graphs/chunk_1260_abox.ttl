ex:Parametro_RCSALARM_1260
    ex:activaAlarma          ex:Alarma_EntradaCaptacion1_1260 ,
                                ex:Alarma_EntradaCaptacion2_1260 ,
                                ex:Alarma_EntradaCaptacion3_1260 ,
                                ex:Alarma_EntradaCaptacion4_1260 .