    a                       ex:Alarma ;
    rdfs:label              "Alarma de entrada de captación 2 (IDN Sercos 33349)"@es ;
    ex:textoExtracto         "IDN Sercos 33349 para la entrada de captación 2."@es ;
    ex:identificador         "33349" ;
    ex:documentadoEn         ex:Tabla_DriveVar_1260 .

ex:Alarma_EntradaCaptacion3_1260
    a                       ex:Alarma ;
    rdfs:label              "Alarma de entrada de captación 3 (IDN Sercos 33350)"@es ;
    ex:textoExtracto         "IDN Sercos 33350 para la entrada de captación 3."@es ;
    ex:identificador         "33350" ;
    ex:documentadoEn         ex:Tabla_DriveVar_1260 .

ex:Alarma_EntradaCaptacion4_1260
    a                       ex:Alarma ;
