@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnulacionDeCompensacionesVolumetricas a ns1:TareaMantenimiento ;
    rdfs:label "Anulación de compensaciones volumétricas" ;
    ns1:solucionaFallo ns1:NoSePuedeActivarLaMarcaVOLCOMPConOtraTablaActivaSobreEjesComunes ;
    ns1:textoExtracto "No puede haber activas dos compensaciones volumétricas que tengan algún eje en común. Antes de activar una compensación, anular la activa mediante la marca de PLC correspondiente." .

ns1:NoSePuedeActivarLaMarcaVOLCOMPConOtraTablaActivaSobreEjesComunes a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede activar la marca VOLCOMP con otra tabla activa sobre ejes comunes" ;
    ns1:textoExtracto "'No se puede activar la marca VOLCOMP con otra tabla activa sobre ejes comunes'" .

