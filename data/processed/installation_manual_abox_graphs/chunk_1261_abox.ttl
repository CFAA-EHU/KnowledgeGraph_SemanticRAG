@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Sistema1261_1 a ex:Sistema ;
    ex:textoExtracto "El sistema dispone de 2 contadoras Sercos (nodos 3, 5) y de 3 reguladores Sercos AXD (nodos 1, 2, 4). Además, el sistema se compone de los siguientes ejes. • 3 ejes analógicos X Y Z. • 1 eje semisercos U. • 1 eje Sercos V. • 1 volante. • 1 cabezal Sercos S." ;
    ex:compuestoPor ex:ContadoraSercos3, ex:ContadoraSercos5, ex:ReguladorSercosAXD1, ex:ReguladorSercosAXD2, ex:ReguladorSercosAXD4, ex:EjeAnalogicoX, ex:EjeAnalogicoY, ex:EjeAnalogicoZ, ex:EjeSemisercosU, ex:EjeSercosV, ex:Volante1, ex:CabezalSercosS .

ex:ContadoraSercos3 a ex:ComponenteElectrico ;
    ex:identificador "nodo 3" ;
    ex:textoExtracto "2 contadoras Sercos (nodos 3, 5)" .

ex:ContadoraSercos5 a ex:ComponenteElectrico ;
    ex:identificador "nodo 5" ;
    ex:textoExtracto "2 contadoras Sercos (nodos 3, 5)" .

ex:ReguladorSercosAXD1 a ex:ComponenteElectrico ;
    ex:identificador "nodo 1" ;
    ex:textoExtracto "3 reguladores Sercos AXD (nodos 1, 2, 4)" .

ex:ReguladorSercosAXD2 a ex:ComponenteElectrico ;
    ex:identificador "nodo 2" ;
    ex:textoExtracto "3 reguladores Sercos AXD (nodos 1, 2, 4)" .

ex:ReguladorSercosAXD4 a ex:ComponenteElectrico ;
    ex:identificador "nodo 4" ;
    ex:textoExtracto "3 reguladores Sercos AXD (nodos 1, 2, 4)" .

ex:EjeAnalogicoX a ex:ComponenteMecanico ;
    ex:identificador "Eje X analógico" ;
    ex:textoExtracto "3 ejes analógicos X Y Z" .

ex:EjeAnalogicoY a ex:ComponenteMecanico ;
    ex:identificador "Eje Y analógico" ;
    ex:textoExtracto "3 ejes analógicos X Y Z" .

ex:EjeAnalogicoZ a ex:ComponenteMecanico ;
    ex:identificador "Eje Z analógico" ;
    ex:textoExtracto "3 ejes analógicos X Y Z" .

ex:EjeSemisercosU a ex:ComponenteMecanico ;
    ex:identificador "Eje U semisercos" ;
    ex:textoExtracto "1 eje semisercos U" .

ex:EjeSercosV a ex:ComponenteMecanico ;
    ex:identificador "Eje V Sercos" ;
    ex:textoExtracto "1 eje Sercos V" .

ex:Volante1 a ex:ComponenteMecanico ;
    ex:identificador "Volante 1" ;
    ex:textoExtracto "1 volante" .

ex:CabezalSercosS a ex:ComponenteMecanico ;
    ex:identificador "Cabezal S Sercos" ;
    ex:textoExtracto "1 cabezal Sercos S" .