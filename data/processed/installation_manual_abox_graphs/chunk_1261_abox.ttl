@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Sistema_ContadoresYEjes_1261
    a ex:Sistema ;
    rdfs:label "Sistema de contadoras Sercos y ejes"@es ;
    ex:textoExtracto "El sistema dispone de 2 contadoras Sercos (nodos 3, 5) y de 3 reguladores Sercos AXD (nodos 1, 2, 4). Además, el sistema se compone de los siguientes ejes. • 3 ejes analógicos X Y Z. • 1 eje semisercos U. • 1 eje Sercos V. • 1 volante. • 1 cabezal Sercos S."@es ;
    ex:compuestoPor ex:ContadoraSercos_Nodo3, ex:ContadoraSercos_Nodo5, ex:ReguladorSercosAXD_Nodo1, ex:ReguladorSercosAXD_Nodo2, ex:ReguladorSercosAXD_Nodo4 ;
    ex:tieneComponente ex:EjeAnalogico_X, ex:EjeAnalogico_Y, ex:EjeAnalogico_Z, ex:EjeSemisercos_U, ex:EjeSercos_V, ex:Volante_1, ex:CabezalSercos_S .

ex:ContadoraSercos_Nodo3
    a ex:ComponenteElectrico ;
    rdfs:label "Contadora Sercos (Nodo 3)"@es ;
    ex:identificador "Nodo 3" ;
    ex:textoExtracto "2 contadoras Sercos (nodos 3, 5)"@es ;
    ex:documentadoEn ex:Sistema_ContadoresYEjes_1261 .

ex:ContadoraSercos_Nodo5
    a ex:ComponenteElectrico ;
