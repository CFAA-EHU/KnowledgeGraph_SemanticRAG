@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_14976244d1 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "En la actualidad muchas piezas son diseñadas mediante sistemas de CAD/CAM. Este tipo de información es posteriormente postprocesada para generar un programa de CNC, típicamente formado por un gran número de bloques de todo tipo de tamaños, desde varios milímetros hasta unas pocas décimas de micra." .

ns1:ModoCONTERROR a ns1:ModoOperacion ;
    rdfs:label "modo CONTERROR" ;
    ns1:textoExtracto "optimizando el error de contorno (modo CONTERROR)" .

ns1:ModoFAST a ns1:ModoOperacion ;
    rdfs:label "modo FAST" ;
    ns1:textoExtracto "velocidad de mecanizado (modo FAST)." .

ns1:ModoHSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC" ;
    ns1:textoExtracto "La orden para ejecutar programas formados por muchos bloques pequeños, típicos del mecanizado a alta velocidad, se realiza mediante una única instrucción, #HSC." .

ns1:ModoSURFACE a ns1:ModoOperacion ;
    rdfs:label "modo SURFACE" ;
    ns1:textoExtracto "Esta función ofrece diferentes modos de trabajar; optimizando el acabado superficial (modo SURFACE)" .

