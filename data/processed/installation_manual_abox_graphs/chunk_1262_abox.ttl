@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ParametrizacionSercos_1262
    a ex:Parametro ;
    rdfs:label "Parametrización de contadoras Sercos (Ejemplo)" ;
    ex:textoExtracto "ANAOUT1 Eje Y analógico. NODO 4: Cabezal S Sercos E21B NODO 5: Eje U (segunda captación) E21C Eje Y analógico. E21A / ANAOUT4 Eje Z analógico. La parametrización podría quedar como sigue. NSERCOUNT 2 Número de contadoras Sercos en el sistema SERCOUNTID1 5 (No habitual, pero válido) SERCOUNTID2 3 [...] Los parámetros SERCOUNTID1 a SERCOUNTID8 determinan el orden de las entradas de captación. Como SERCOUNTID1=5 y SERCOUNTID2=3, la primera entrada de captación será la primera del nodo 5." ;
    ex:identificador "NSERCOUNT=2; SERCOUNTID1=5; SERCOUNTID2=3" ;
    ex:valor "NSERCOUNT:2|SERCOUNTID1:5|SERCOUNTID2:3" .

ex:SistemaSercos_1262
    a ex:Sistema ;
    rdfs:label "Sistema Sercos (Nodos 4 y 5)" ;
    ex:textoExtracto "NODO 4: Cabezal S Sercos E21B NODO 5: Eje U (segunda captación) E21C" ;
    ex:tieneComponente ex:ComponenteE21B_1262, ex:ComponenteE21C_1262 ;
    ex:monitoreaParametro ex:ParametrizacionSercos_1262 .

ex:ComponenteE21B_1262
    a ex:ComponenteElectrico ;
    rdfs:label "Cabezal S Sercos (E21B, Nodo 4)" ;
    ex:textoExtracto "NODO 4: Cabezal S Sercos E21B" ;
    ex:identificador "E21B" .

ex:ComponenteE21C_1262
    a ex:ComponenteElectrico ;
    rdfs:label "Eje U (E21C, Nodo 5)" ;
    ex:textoExtracto "NODO 5: Eje U (segunda captación) E21C" ;
    ex:identificador "E21C" .

ex:ComponenteE21A_1262
    a ex:ComponenteElectrico ;
    rdfs:label "Eje Y analógico (E21A)" ;
    ex:textoExtracto "Eje Y analógico. E21A" ;
    ex:identificador "E21A" .

ex:ComponenteANAOUT1_1262
    a ex:ComponenteElectrico ;
    rdfs:label "Salida analógica ANAOUT1 (Eje Y)" ;
    ex:textoExtracto "ANAOUT1 Eje Y analógico." ;
    ex:identificador "ANAOUT1" .

ex:ComponenteANAOUT4_1262
    a ex:ComponenteElectrico ;
    rdfs:label "Salida analógica ANAOUT4 (Eje Z)" ;
    ex:textoExtracto "ANAOUT4 Eje Z analógico." ;
    ex:identificador "ANAOUT4" .