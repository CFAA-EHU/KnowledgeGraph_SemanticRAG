@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_2f57fa2c16 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:MaquinaBrochadoraElectromecanicaExteriorA218 ;
    ns1:textoExtracto "Paralelamente el CNC controla de una manera mucho más suave el movimiento de la máquina reduciendo notablemente las vibraciones originadas por la geometría de la pieza o la dinámica de la máquina." .

ns1:ModoDeMecanizadoPorDefecto a ns1:Parametro ;
    rdfs:label "modo de mecanizado por defecto" ;
    ns1:identificador "HSCDEFAULTMODE" ;
    ns1:textoExtracto "El modo de mecanizado por defecto está definido en el parámetro HSCDEFAULTMODE, donde Fagor ofrece el modo SURFACE como modo por defecto." .

ns1:MaquinaBrochadoraElectromecanicaExteriorA218 a ns1:Maquina ;
    rdfs:label "Máquina Brochadora Electromecánica Exterior A218" ;
    ns1:textoExtracto "El modo de mecanizado por defecto está definido en el parámetro HSCDEFAULTMODE, donde Fagor ofrece el modo SURFACE como modo por defecto." .

