@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_c1d3b88b11 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "En este modo el CNC modifica la geometría mediante algoritmos inteligentes de eliminación de puntos innecesarios y generación de splines o transiciones polinómicas entre los bloques, respetando siempre los límites de error impuestos para este modo." ;
    ns1:tieneComponente ns1:TipoDeAceleracion .

ns1:TipoDeAceleracion a ns1:Parametro ;
    rdfs:label "Tipo de aceleración" ;
    ns1:identificador "SLOPETYPE" ;
    ns1:textoExtracto "Este modo utiliza el tipo de aceleración definido en el parámetro SLOPETYPE." .

