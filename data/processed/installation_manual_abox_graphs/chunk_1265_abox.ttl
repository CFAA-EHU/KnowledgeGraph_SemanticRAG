@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FiltroDefinidoParaSuavizadoDeVelocidadYAceleracion a ns1:Parametro ;
    rdfs:label "Filtro definido para suavizado de velocidad y aceleración" ;
    ns1:identificador "FILTER" ;
    ns1:textoExtracto "Los efectos de los filtros definidos mediante el parámetro FILTER se suman a los efectos de los filtros activos en HSC." .

ns1:FrecuenciaDeFiltroParaModoCONTERROR a ns1:Parametro ;
    rdfs:label "Frecuencia de filtro para modo CONTERROR" ;
    ns1:identificador "HSCFILTFREQ" ;
    ns1:textoExtracto "parámetro HSCFILTFREQ para el modo CONTERROR." .

ns1:FrecuenciaSuavizado a ns1:Frecuencia ;
    rdfs:label "Frecuencia de suavizado" ;
    ns1:textoExtracto "Al activar la frecuencia de suavizado se generan perfiles de velocidad y aceleración más suaves, pero aumenta el tiempo de ejecución." .

ns1:ModoHSCFAST a ns1:ModoOperacion ;
    rdfs:label "Modo FAST" ;
    ns1:textoExtracto "Mecanizado HSC optimizando el avance (modo FAST)." .

