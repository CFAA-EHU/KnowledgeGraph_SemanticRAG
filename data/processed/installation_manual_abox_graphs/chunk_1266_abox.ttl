@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceleracionLineal1 a ns1:Parametro ;
    rdfs:label "Aceleración lineal 1" ;
    ns1:identificador "LACC1" ;
    ns1:textoExtracto "parametrizados los parámetros LACC1 y LACC2" .

ns1:AceleracionLineal2 a ns1:Parametro ;
    rdfs:label "Aceleración lineal 2" ;
    ns1:identificador "LACC2" ;
    ns1:textoExtracto "parametrizados los parámetros LACC1 y LACC2" .

ns1:CNC8070_f8e757bb18 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "capaz de alcanzar el CNC en función de como se hayan parametrizado los parámetros LACC1 y LACC2" .

ns1:FactorDeAvanceRapido a ns1:Parametro ;
    rdfs:label "Factor de avance rápido" ;
    ns1:identificador "FASTFACTOR" ;
    ns1:textoExtracto "se asume el porcentaje definido en el parámetro FASTFACTOR" .

ns1:FiltroDeAceleracion a ns1:Parametro ;
    rdfs:label "Filtro de aceleración" ;
    ns1:identificador "FILTER" ;
    ns1:textoExtracto "el parámetro FILTER se suman a los efectos de los filtros activos en HSC" .

ns1:FrecuenciaDelFiltroParaElModoCONTERROR a ns1:Parametro ;
    rdfs:label "Frecuencia del filtro para el modo CONTERROR" ;
    ns1:identificador "HSCFILTFREQ" ;
    ns1:textoExtracto "parámetro HSCFILTFREQ para el modo CONTERROR" .

ns1:FrecuenciaDelFiltroParaElModoFAST a ns1:Parametro ;
    rdfs:label "Frecuencia del filtro para el modo FAST" ;
    ns1:identificador "FASTFILTFREQ" ;
    ns1:textoExtracto "se parametriza en el parámetro FASTFILTFREQ" .

ns1:ModoOperacionFAST a ns1:ModoOperacion ;
    rdfs:label "Modo FAST" ;
    ns1:textoExtracto "Mecanizado HSC optimizando el avance (modo FAST)" .

