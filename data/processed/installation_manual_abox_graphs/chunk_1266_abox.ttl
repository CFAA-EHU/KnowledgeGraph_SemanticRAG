@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PLC_1266 a ex:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ex:textoExtracto "Los bloques se pueden distribuir como se desee dentro del rango de recursos gestionados por PLC (1...1024)." .

ex:EntradaDigital_1266 a ex:ComponenteElectrico ;
    rdfs:label "entrada digital" ;
    ex:textoExtracto "Configurar las salidas digitales. La entradas y salidas digitales se configuran desde los parámetros máquina." .

ex:SalidaDigital_1266 a ex:ComponenteElectrico ;
    rdfs:label "salida digital" ;
    ex:textoExtracto "Configurar las salidas digitales. La entradas y salidas digitales se configuran desde los parámetros máquina." .

ex:ParametroMaquina_1266 a ex:Parametro ;
    rdfs:label "parámetros máquina" ;
    ex:textoExtracto "La entradas y salidas digitales se configuran desde los parámetros máquina." .