@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaControlMovimiento a ns1:Sistema ;
    rdfs:label "Sistema de control de movimiento" ;
    ns1:documentadoEn ns1:FrecuenciaDeFiltroParaSuavizarElMovimiento ;
    ns1:textoExtracto "Al no existir control de jerk es necesario un filtro para todos los ejes, que se introduce automáticamente, para suavizar el movimiento de la máquina." ;
    ns1:tieneComponente ns1:FiltroSuavizado .

ns1:FiltroSuavizado a ns1:ComponenteElectrico ;
    rdfs:label "Filtro de suavizado" ;
    ns1:textoExtracto "Al no existir control de jerk es necesario un filtro para todos los ejes, que se introduce automáticamente, para suavizar el movimiento de la máquina." .

ns1:FrecuenciaDeFiltroParaSuavizarElMovimiento a ns1:Parametro ;
    rdfs:label "frecuencia de filtro para suavizar el movimiento" ;
    ns1:identificador "FASTFILTFREQ" ;
    ns1:textoExtracto "La frecuencia de este filtro para todos los ejes se parametriza en el parámetro FASTFILTFREQ." .

