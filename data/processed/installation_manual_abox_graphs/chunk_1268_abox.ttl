@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FiltroDefinidoPorElParametroFILTER a ns1:Parametro ;
    rdfs:label "Filtro definido por el parámetro FILTER" ;
    ns1:textoExtracto "Los efectos de los filtros definidos mediante el parámetro FILTER se suman a los efectos de los filtros activos en HSC" .

ns1:FrecuenciaDeFiltroRapidoParaModoFAST a ns1:Parametro ;
    rdfs:label "Frecuencia de filtro rápido para modo FAST" ;
    ns1:textoExtracto "parámetro FASTFILTFREQ para el modo FAST" .

