@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivacionDeUnFiltroAutomaticoFIRParaTodosLosEjesDelCanalDuranteLaEje_d1f6047edf a ns1:Parametro ;
    rdfs:label "Activación de un filtro automático FIR para todos los ejes del canal durante la ejecución en modo CONTERROR" ;
    ns1:identificador "HSCFILTFREQ MPG" ;
    ns1:textoExtracto "Parámetro HSCFILTFREQ MPG: Este parámetro activa un filtro automático FIR para todos los ejes del canal durante la ejecución en modo CONTERROR." .

ns1:AjusteDelAvanceEnFuncionDeLaVelocidadDeLecturaDeBloquesYDelTamanoDeLosMismos a ns1:Parametro ;
    rdfs:label "Ajuste del avance en función de la velocidad de lectura de bloques y del tamaño de los mismos" ;
    ns1:identificador "FEEDAVRG MPG" ;
    ns1:textoExtracto "Parámetro FEEDAVRG MPG: Este parámetro habilita el ajuste del avance en función de la velocidad de lectura de bloques y del tamaño de los mismos." .

ns1:AnguloMaximoEntreDosTrayectoriasPorDebajoDelCualSeMecanizaEnAristaViva a ns1:Parametro ;
    rdfs:label "Ángulo máximo entre dos trayectorias por debajo del cual se mecaniza en arista viva" ;
    ns1:identificador "CORNER MPG" ;
    ns1:textoExtracto "Parámetro CORNER MPG: Este parámetro indica el ángulo máximo entre dos trayectorias, por debajo del cual se mecaniza en arista viva." .

ns1:FrecuenciaDeSuavizadoEnLaInterpolacionDeTrayectorias_3dda96be1c a ns1:Parametro ;
    rdfs:label "Frecuencia de suavizado en la interpolación de trayectorias" ;
    ns1:identificador "SMOOTHFREQ MPG" ;
    ns1:textoExtracto "Parámetro SMOOTHFREQ MPG: Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias." .

ns1:ModoPorDefectoAlProgramarHSCON_e5f7a3e13b a ns1:Parametro ;
    rdfs:label "Modo por defecto al programar #HSC ON" ;
    ns1:identificador "HSCDEFAULMODE MPG" ;
    ns1:textoExtracto "Parámetro HSCDEFAULMODE MPG: Modo por defecto al programar #HSC ON." .

