@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:BusCANopen_1269
    a ex:Sistema ;
    rdfs:label "Bus CANopen" ;
    ex:textoExtracto "Un bus CANopen dispone de los siguientes grupos remotos." ;
    ex:tieneComponente ex:Nodo1_1269, ex:Nodo2_1269, ex:Nodo3_1269 .

ex:Nodo1_1269
    a ex:ComponenteElectrico ;
    rdfs:label "Nodo 1 (Grupo remoto RIO5)" ;
    ex:identificador "Nodo 1" ;
    ex:textoExtracto "Nodo 1: Grupo remoto RIO5 con 1 módulos de 24 entradas digitales." ;
    ex:tieneComponente ex:ModuloEntradasDigitales_1_1269 .

ex:Nodo2_1269
    a ex:ComponenteElectrico ;
    rdfs:label "Nodo 2 (Grupo remoto RIO5)" ;
    ex:identificador "Nodo 2" ;
    ex:textoExtracto "Nodo 2: Grupo remoto RIO5 con 3 módulos de 24 entradas digitales cada uno." ;
    ex:tieneComponente ex:ModuloEntradasDigitales_2_1_1269, ex:ModuloEntradasDigitales_2_2_1269, ex:ModuloEntradasDigitales_2_3_1269 .

ex:Nodo3_1269
    a ex:ComponenteElectrico ;
    rdfs:label "Nodo 3 (Grupo remoto RIO5)" ;
    ex:identificador "Nodo 3" ;
    ex:textoExtracto "Nodo 3: Grupo remoto RIO5 con 2 módulos de 24 entradas digitales cada uno." ;
    ex:tieneComponente ex:ModuloEntradasDigitales_3_1_1269, ex:ModuloEntradasDigitales_3_2_1269 .

ex:ModuloEntradasDigitales_1_1269
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo de 24 entradas digitales (Nodo 1)" ;
    ex:valor "24 entradas digitales" ;
    ex:textoExtracto "1 módulos de 24 entradas digitales" .

ex:ModuloEntradasDigitales_2_1_1269
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo de 24 entradas digitales (Nodo 2, módulo 1)" ;
    ex:valor "24 entradas digitales" ;
    ex:textoExtracto "3 módulos de 24 entradas digitales cada uno" .

ex:ModuloEntradasDigitales_2_2_1269
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo de 24 entradas digitales (Nodo 2, módulo 2)" ;
    ex:valor "24 entradas digitales" ;
    ex:textoExtracto "3 módulos de 24 entradas digitales cada uno" .

ex:ModuloEntradasDigitales_2_3_1269
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo de 24 entradas digitales (Nodo 2, módulo 3)" ;
    ex:valor "24 entradas digitales" ;
    ex:textoExtracto "3 módulos de 24 entradas digitales cada uno" .

ex:ModuloEntradasDigitales_3_1_1269
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo de 24 entradas digitales (Nodo 3, módulo 1)" ;
    ex:valor "24 entradas digitales" ;
    ex:textoExtracto "2 módulos de 24 entradas digitales cada uno" .

ex:ModuloEntradasDigitales_3_2_1269
