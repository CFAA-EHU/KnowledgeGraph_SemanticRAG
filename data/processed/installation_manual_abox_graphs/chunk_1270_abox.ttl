@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:GrupoRemotoRIO5_Nodo2 a ex:Sistema ;
    rdfs:label "Grupo remoto RIO5 con 3 módulos de 24 entradas digitales cada uno" ;
    ex:textoExtracto "Nodo 2: Grupo remoto RIO5 con 3 módulos de 24 entradas digitales cada uno." ;
    ex:compuestoPor ex:Modulo24EntradasDigitales_Nodo2_1, ex:Modulo24EntradasDigitales_Nodo2_2, ex:Modulo24EntradasDigitales_Nodo2_3 .

ex:GrupoRemotoRIO5_Nodo3 a ex:Sistema ;
    rdfs:label "Grupo remoto RIO5 con 2 módulos de 24 entradas digitales cada uno" ;
    ex:textoExtracto "Nodo 3: Grupo remoto RIO5 con 2 módulos de 24 entradas digitales cada uno." ;
    ex:compuestoPor ex:Modulo24EntradasDigitales_Nodo3_1, ex:Modulo24EntradasDigitales_Nodo3_2 .

ex:Modulo24EntradasDigitales_Nodo2_1 a ex:ComponenteElectrico ;
    rdfs:label "Módulo de 24 entradas digitales (Nodo 2, módulo 1)" ;
    ex:textoExtracto "3 módulos de 24 entradas digitales cada uno" .

ex:Modulo24EntradasDigitales_Nodo2_2 a ex:ComponenteElectrico ;
    rdfs:label "Módulo de 24 entradas digitales (Nodo 2, módulo 2)" ;
    ex:textoExtracto "3 módulos de 24 entradas digitales cada uno" .

ex:Modulo24EntradasDigitales_Nodo2_3 a ex:ComponenteElectrico ;
    rdfs:label "Módulo de 24 entradas digitales (Nodo 2, módulo 3)" ;
    ex:textoExtracto "3 módulos de 24 entradas digitales cada uno" .

ex:Modulo24EntradasDigitales_Nodo3_1 a ex:ComponenteElectrico ;
    rdfs:label "Módulo de 24 entradas digitales (Nodo 3, módulo 1)" ;
    ex:textoExtracto "2 módulos de 24 entradas digitales cada uno" .

ex:Modulo24EntradasDigitales_Nodo3_2 a ex:ComponenteElectrico ;
    rdfs:label "Módulo de 24 entradas digitales (Nodo 3, módulo 2)" ;
    ex:textoExtracto "2 módulos de 24 entradas digitales cada uno" .