@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesfaseDeTrayectoria a ns1:Parametro ;
    rdfs:label "Desfase de trayectoria" ;
    ns1:textoExtracto "Este parámetro introduce un desfase no constante, dependiente de las frecuencias." .

ns1:FactorDeVelocidadEnEsquinas a ns1:Parametro ;
    rdfs:label "Factor de velocidad en esquinas" ;
    ns1:identificador "FASTFACTOR MPG" ;
    ns1:textoExtracto "Este parámetro afecta al avance en las esquinas e indica el" .

