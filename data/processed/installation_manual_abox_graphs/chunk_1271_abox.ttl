@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FactorDeAvanceRapidoEnModoFAST a ns1:Parametro ;
    rdfs:label "Factor de avance rápido en modo FAST" ;
    ns1:identificador "MPG.FASTFACTOR" ;
    ns1:textoExtracto "Este parámetro afecta al avance en las esquinas e indica el porcentaje de avance que se desea alcanzar, sobre el máximo que es capaz de conseguir el CNC, en el modo FAST." .

ns1:FrecuenciaDeSuavizadoEnInterpolacionDeTrayectorias a ns1:Parametro ;
    rdfs:label "Frecuencia de suavizado en interpolación de trayectorias" ;
    ns1:identificador "MPG.FSMOOTHFREQ" ;
    ns1:textoExtracto "Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias para el modo HSC FAST." .

ns1:LimiteDeTiempoParaInterpolacionDelAvance a ns1:Parametro ;
    rdfs:label "Límite de tiempo para interpolación del avance" ;
    ns1:identificador "MPG.FTIMELIM" ;
    ns1:textoExtracto "El parámetro FTIMELIM permite limitar el tiempo que emplea el CNC para la interpolación del avance en cada tramo." .

ns1:VelocidadMinimaEnLasEsquinas_a900b0be65 a ns1:Parametro ;
    rdfs:label "Velocidad mínima en las esquinas" ;
    ns1:identificador "MPG.MINCORFEED" ;
    ns1:textoExtracto "No se recomienda modificar este valor, porque se puede sobrepasar la dinámica de los ejes." .

