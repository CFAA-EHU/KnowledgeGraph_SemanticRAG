@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:GrupoRemoto_RIOW_Nodo1 a ex:ComponenteElectrico ;
    rdfs:label "Grupo remoto RIOW" ;
    ex:textoExtracto "Nodo 1: Grupo remoto RIOW con 16 entradas y 8 salidas digitales." .

ex:GrupoRemoto_RIOW_Nodo2 a ex:ComponenteElectrico ;
    rdfs:label "Grupo remoto RIOW" ;
    ex:textoExtracto "Nodo 2: Grupo remoto RIOW con 8 entradas y 8 salidas digitales." .

ex:GrupoRemoto_RIOR_Nodo1 a ex:ComponenteElectrico ;
    rdfs:label "Grupo remoto RIOR" ;
    ex:textoExtracto "Nodo 1: Grupo remoto RIOR con 48 entradas y 32 salidas digitales." .

ex:GrupoRemoto_RIOR_Nodo2 a ex:ComponenteElectrico ;
    rdfs:label "Grupo remoto RIOR" ;
    ex:textoExtracto "Nodo 2: Grupo remoto RIOR con 48 entradas y 32 salidas digitales." .