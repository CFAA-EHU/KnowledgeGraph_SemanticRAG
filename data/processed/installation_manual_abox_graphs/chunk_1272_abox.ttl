@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FiltroAutomaticoParaSuavizarLaRespuestaDeLosEjesEnModoHSCSURFACE a ns1:Parametro ;
    rdfs:label "Filtro automático para suavizar la respuesta de los ejes en modo HSC SURFACE" ;
    ns1:identificador "SURFFILFREQ" ;
    ns1:textoExtracto "Este parámetro activa un filtro automático para todos los ejes del canal durante la ejecución en modo HSC SURFACE, el cuál permite suavizar la respuesta de los ejes generando una trayectoria más suave." .

ns1:FiltroPasoBajoAutomaticoParaSuavizarLaRespuestaDeLosEjesEnModoHSCFAST a ns1:Parametro ;
    rdfs:label "Filtro paso bajo automático para suavizar la respuesta de los ejes en modo HSC FAST" ;
    ns1:identificador "FASTFILTFREQ" ;
    ns1:textoExtracto "Este parámetro activa un filtro \"paso bajo\" automático para todos los ejes del canal durante la ejecución en modo HSC FAST, el cuál permite suavizar la respuesta de los ejes generando una trayectoria más suave." .

ns1:FrecuenciaDeResonanciaQueElCNCDebeEliminarEnLaGeneracionDeLaConsigna a ns1:Parametro ;
    rdfs:label "Frecuencia de resonancia que el CNC debe eliminar en la generación de la consigna" ;
    ns1:identificador "FREQRES" ;
    ns1:textoExtracto "Frecuencia de resonancia que el CNC debe eliminar en la generación de la consigna. Este parámetro sólo es válido cuando el perfil de aceleración es trapezoidal o seno cuadrado (parámetro SLOPETYPE), que es el perfil de aceleración por defecto para el modo HSC CONTERROR." .

ns1:FrecuenciaDelFiltroDeTrayectoriaParaPerfilesDeAceleracionLinealEnModoHSCFAST a ns1:Parametro ;
    rdfs:label "Frecuencia del filtro de trayectoria para perfiles de aceleración lineal en modo HSC FAST" ;
    ns1:identificador "SOFTFREQ" ;
    ns1:textoExtracto "Este parámetro permite suavizar el perfil de velocidad en modo HSC FAST, lo que permite mejorar el tiempo y la calidad superficial del mecanizado." .

ns1:ValorPorDefectoDelErrorMaximoDeLaTrayectoriaEnHSC_280a71c0cb a ns1:Parametro ;
    rdfs:label "Valor por defecto del error máximo de la trayectoria en HSC" ;
    ns1:identificador "HSCROUND" ;
    ns1:textoExtracto "Valor por defecto del error máximo de la trayectoria en HSC." .

