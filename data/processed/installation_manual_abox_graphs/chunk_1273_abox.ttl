@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceleracionMaximaPermitidaEnCurvatura_b9b72998aa a ns1:Parametro ;
    rdfs:label "Aceleración máxima permitida en curvatura" ;
    ns1:identificador "CURVACC MPA" ;
    ns1:textoExtracto "Aceleración máxima permitida en curvatura. Si este parámetro se define con valor ꞏ0ꞏ, se respeta la aceleración máxima del eje." .

ns1:AceleracionMaximaPermitidaEnLaTransicionDeBloques a ns1:Parametro ;
    rdfs:label "Aceleración máxima permitida en la transición de bloques" ;
    ns1:identificador "CORNERACC MPA" ;
    ns1:textoExtracto "Este parámetro define la aceleración máxima que se va a permitir al eje en la transición de bloques. Si este parámetro se define con valor ꞏ0ꞏ, se respeta la aceleración máxima del eje." .

ns1:AceleracionMaximaPermitidaModoFAST_a200ad2287 a ns1:Parametro ;
    rdfs:label "Aceleración máxima permitida (modo FAST)" ;
    ns1:identificador "FASTACC MPA" ;
    ns1:textoExtracto "Aceleración máxima permitida (modo FAST). Si este parámetro se define con valor ꞏ0ꞏ, se respeta la aceleración máxima del eje." .

ns1:ErrorDePosicionMaximoErrorDePosicionDelEjeEnHSCCuandoTrabajaFueraDelPlanoTriedo a ns1:Parametro ;
    rdfs:label "Error de posición. Máximo error de posición del eje en HSC cuando trabaja fuera del plano/triedo" ;
    ns1:identificador "MAXERROR MPA" ;
    ns1:textoExtracto "Error de posición. Máximo error de posición del eje en HSC cuando trabaja fuera del plano/triedo." .

ns1:JerkMaximoPermitidoEnCurvatura_4304b916b1 a ns1:Parametro ;
    rdfs:label "Jerk máximo permitido en curvatura" ;
    ns1:identificador "CURVJERK MPA" ;
    ns1:textoExtracto "Jerk máximo permitido en curvatura. Si este parámetro se define con valor ꞏ0ꞏ, se respeta el jerk máximo del eje." .

ns1:JerkMaximoPermitidoEnLasEsquinas_561221f892 a ns1:Parametro ;
    rdfs:label "Jerk máximo permitido en las esquinas" ;
    ns1:identificador "CORNERJERK MPA" ;
    ns1:textoExtracto "Jerk máximo permitido en las esquinas. Si este parámetro se define con valor ꞏ0ꞏ, se respeta el jerk máximo del eje." .

