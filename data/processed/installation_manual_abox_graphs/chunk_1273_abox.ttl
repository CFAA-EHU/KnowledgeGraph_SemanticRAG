@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Nodo1_RIOR
    a ex:ComponenteElectrico ;
    rdfs:label "Nodo 1: Grupo remoto RIOR"@es ;
    ex:textoExtracto "Nodo 1: Grupo remoto RIOR con 48 entradas y 32 salidas digitales."@es ;
    ex:identificador "Nodo 1 (RIOR)" ;
    ex:tieneComponente ex:EntradasDigitales_Nodo1, ex:SalidasDigitales_Nodo1 .

ex:EntradasDigitales_Nodo1
    a ex:ComponenteElectrico ;
    rdfs:label "Bloque de 48 entradas digitales (Nodo 1)"@es ;
    ex:textoExtracto "48 entradas digitales. [...] El primer nodo RIOR como un bloque de 48 entradas a partir de la I1."@es ;
    ex:identificador "I1-I48" ;
    ex:compuestoPor ex:Parametro_I1 .

ex:SalidasDigitales_Nodo1
    a ex:ComponenteElectrico ;
    rdfs:label "Bloque de 32 salidas digitales (Nodo 1)"@es ;
    ex:textoExtracto "32 salidas digitales. [...] un bloque de 32 salidas a partir de la O1."@es ;
    ex:identificador "O1-O32" ;
    ex:compuestoPor ex:Parametro_O1 .

ex:Parametro_I1
    a ex:Parametro ;
    rdfs:label "Parámetro de entrada inicial (Nodo 1)"@es ;
    ex:textoExtracto "bloque de 48 entradas a partir de la I1"@es ;
    ex:identificador "I1" ;
    ex:valor "1" .

ex:Parametro_O1
    a ex:Parametro ;
    rdfs:label "Parámetro de salida inicial (Nodo 1)"@es ;
    ex:textoExtracto "bloque de 32 salidas a partir de la O1"@es ;
    ex:identificador "O1" ;
    ex:valor "1" .

ex:Nodo2_RIOR
    a ex:ComponenteElectrico ;
    rdfs:label "Nodo 2: Grupo remoto RIOR"@es ;
    ex:textoExtracto "Nodo 2: Grupo remoto RIOR con 48 entradas y 32 salidas digitales."@es ;
    ex:identificador "Nodo 2 (RIOR)" ;
    ex:tieneComponente ex:EntradasDigitales_Nodo2, ex:SalidasDigitales_Nodo2 .

ex:EntradasDigitales_Nodo2
    a ex:ComponenteElectrico ;
    rdfs:label "Bloques de 48 entradas digitales (Nodo 2)"@es ;
    ex:textoExtracto "El segundo nodo RIOR como tres bloques de 48 entradas a partir de la I97."@es ;
    ex:identificador "I97-I144, I145-I192, I193-I240" ;
    ex:compuestoPor ex:Parametro_I97 .

ex:SalidasDigitales_Nodo2
    a ex:ComponenteElectrico ;
    rdfs:label "Bloque de 32 salidas digitales (Nodo 2)"@es ;
    ex:textoExtracto "un bloque de 32 salidas a partir de la O81."@es ;
    ex:identificador "O81-O112" ;
    ex:compuestoPor ex:Parametro_O81 .

ex:Parametro_I97
    a ex:Parametro ;
    rdfs:label "Parámetro de entrada inicial (Nodo 2)"@es ;
    ex:textoExtracto "tres bloques de 48 entradas a partir de la I97"@es ;
    ex:identificador "I97" ;
    ex:valor "97" .

ex:Parametro_O81
    a ex:Parametro ;
    rdfs:label "Parámetro de salida inicial (Nodo 2)"@es ;
    ex:textoExtracto "bloque de 32 salidas a partir de la O81"@es ;
    ex:identificador "O81" ;
    ex:valor "81" .