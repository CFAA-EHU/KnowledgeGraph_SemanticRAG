@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:GrupoRemotoRIOR_1 a ex:ComponenteElectrico ;
    rdfs:label "Grupo remoto RIOR" ;
    ex:textoExtracto "Nodo 1: Grupo remoto RIOR con 48 entradas y 32 salidas digitales." ;
    ex:identificador "Nodo 1 (RIOR)" ;
    ex:valor "48 entradas digitales, 32 salidas digitales" .

ex:GrupoRemotoRIOR_2 a ex:ComponenteElectrico ;
    rdfs:label "Grupo remoto RIOR" ;
    ex:textoExtracto "Nodo 2: Grupo remoto RIOR con 48 entradas y 32 salidas digitales." ;
    ex:identificador "Nodo 2 (RIOR)" ;
    ex:valor "48 entradas digitales, 32 salidas digitales" .

ex:ConfiguracionNodoRIOR_1 a ex:Esquema ;
    ex:textoExtracto "El primer nodo RIOR como un bloque de 48 entradas a partir de la I1. También un bloque de 32 salidas a partir de la O1." ;
    ex:compuestoPor ex:GrupoRemotoRIOR_1 .

ex:ConfiguracionNodoRIOR_2 a ex:Esquema ;
    ex:textoExtracto "El segundo nodo RIOR como tres bloques de 48 entradas a partir de la I97. También un bloque de 32 salidas a partir de la O81." ;
    ex:compuestoPor ex:GrupoRemotoRIOR_2 .