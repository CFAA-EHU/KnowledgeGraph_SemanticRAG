@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:NDIMOD a ex:Parametro ;
    rdfs:label "NDIMOD" ;
    ex:valor "2" ;
    ex:textoExtracto "NDIMOD | 2 | 2 bloques, uno para cada nodo RIOR. En la serie RIOR, cada módulo se debe configurar como un bloque lógico." .

ex:DIMODADDR a ex:Parametro ;
    rdfs:label "DIMODADDR" ;
    ex:valor "- - -" ;
    ex:textoExtracto "DIMODADDR | - - - | Ver tabla inferior." .

ex:NDOMOD a ex:Parametro ;
    rdfs:label "NDOMOD" ;
    ex:valor "2" ;
    ex:textoExtracto "NDOMOD | 2 | 2 bloques, uno para cada nodo RIOR. En la serie RIOR, cada módulo se debe configurar como un bloque lógico." .

ex:DOMODADDR a ex:Parametro ;
    rdfs:label "DOMODADDR" ;
    ex:valor "- - -" ;
    ex:textoExtracto "DOMODADDR | - - - | Ver tabla inferior." .

ex:RIOR a ex:Sistema ;
    rdfs:label "RIOR" ;
    ex:textoExtracto "En la serie RIOR, cada módulo se debe configurar como un bloque lógico." .

ex:RIO5 a ex:ComponenteElectrico ;
    rdfs:label "RIO5" ;
    ex:textoExtracto "Nodo 1: Grupo remoto RIO5 con 3 módulos de 24 entradas digitales cada uno." .

ex:RIOW a ex:ComponenteElectrico ;
    rdfs:label "RIOW" ;
    ex:textoExtracto "Nodo 2: Grupo remoto RIOW con 64 entradas digitales." .

ex:busCANopen a ex:Sistema ;
    rdfs:label "bus CANopen" ;
    ex:textoExtracto "Un bus CANopen dispone de los siguientes grupos remotos." ;
    ex:tieneComponente ex:RIO5, ex:RIOW .