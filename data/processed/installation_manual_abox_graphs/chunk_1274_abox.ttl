@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Variable1 a ns1:Parametro ;
    rdfs:label "Variable 1" ;
    ns1:documentadoEn ns1:TablaVariables ;
    ns1:textoExtracto "El acceso a las variables desde el PLC, tanto para la lectura como para la escritura, será síncrono." .

ns1:Variable2 a ns1:Parametro ;
    rdfs:label "Variable 2" ;
    ns1:documentadoEn ns1:TablaVariables ;
    ns1:textoExtracto "El acceso a las variables desde el programa pieza devuelve el valor de la preparación de bloques, excepto cuando se indique lo contrario." .

ns1:CNC8070_2e22e7fec4 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Las siguientes variables son accesibles desde; (PRG) el programa pieza y desde el modo MDI/MDA, PLC e (INT) una aplicación externa." .

ns1:TablaVariables a ns1:Tabla ;
    rdfs:label "Tabla de Variables" ;
    ns1:documentadoEn ns1:CNC8070_2e22e7fec4 ;
    ns1:textoExtracto "La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W)." .

