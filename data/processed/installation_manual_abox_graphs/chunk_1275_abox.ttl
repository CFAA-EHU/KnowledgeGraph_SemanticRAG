@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PorcentajeDelTiempoDeCicloQueUtilizaElLazoDePosicion a ns1:Parametro ;
    rdfs:label "Porcentaje del tiempo de ciclo que utiliza el lazo de posición" ;
    ns1:identificador "G.LOOPTIMERATE" ;
    ns1:textoExtracto "Esta variable sirve de referencia para saber si el consumo de tiempo de interrupción es debido al número de ejes o al propio proceso de preparación de la trayectoria." .

ns1:PorcentajeDelTiempoDeCicloQueUtilizaLaParteDeTiempoRealDeCNC a ns1:Parametro ;
    rdfs:label "Porcentaje del tiempo de ciclo que utiliza la parte de tiempo real de CNC" ;
    ns1:identificador "G.NCTIMERATE" ;
    ns1:textoExtracto "Porcentaje del tiempo de ciclo que utiliza la parte de tiempo real de CNC. Esta variable sirve para evaluar la carga del sistema y el tiempo que la interrupción periódica que controla el movimiento de los ejes deja al sistema operativo para gestionar otras aplicaciones que puedan ejecutarse en paralelo al CNC." .

