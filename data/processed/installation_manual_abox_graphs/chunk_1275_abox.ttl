@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:RIO5 a ex:ComponenteElectrico ;
    ex:textoExtracto "Nodo 1: Grupo remoto RIO5 con 3 módulos de 24 entradas digitales cada uno." .

ex:RIOW a ex:ComponenteElectrico ;
    ex:textoExtracto "Nodo 2: Grupo remoto RIOW con 64 entradas digitales." .

ex:EntradaDigital a ex:ComponenteElectrico ;
    ex:textoExtracto "24 + 48 entradas digitales." .

ex:EsquemaConexionadoI_O a ex:Esquema ;
    ex:textoExtracto "X1 X2 X3 X4 X5 X6 X7 X8" ;
    ex:compuestoPor ex:RIO5, ex:RIOW, ex:EntradaDigital .