@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:NDIMOD a ex:Parametro ;
    rdfs:label "NDIMOD" ;
    ex:textoExtracto "NDIMOD" ;
    ex:valor "5" ;
    ex:textoExtracto "2 bloques para el RIOW y 3 bloques para el RIO5. En la serie RIO5, cada módulo se debe configurar como un bloque lógico. Cada módulo doble (módulo con dos placas) cuenta como dos bloques." .

ex:DIMODADDR a ex:Parametro ;
    rdfs:label "DIMODADDR" ;
    ex:textoExtracto "DIMODADDR" ;
    ex:valor "---" ;
    ex:textoExtracto "Ver tabla inferior." .

ex:Nodo_2_RIOW a ex:ComponenteElectrico ;
    rdfs:label "Nodo 2 (RIOW)" ;
    ex:textoExtracto "Nodo 2 (RIOW)" ;
    ex:textoExtracto "64 entradas digitales" ;
    ex:compuestoPor ex:NDIMOD, ex:DIMODADDR .