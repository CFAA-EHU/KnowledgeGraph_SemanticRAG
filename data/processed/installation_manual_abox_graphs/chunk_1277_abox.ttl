@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_NPT100 a ex:Parametro ;
    rdfs:label "NPT100" ;
    ex:textoExtracto "Parámetro. | Significado. | NPT100 | Número total de entradas PT100 activas. Valores posibles: De 0 a 10 (por defecto; 0)." ;
    ex:valor "0 a 10" .

ex:Parametro_PT100 a ex:Parametro ;
    rdfs:label "PT100" ;
    ex:textoExtracto "Parámetro. | Significado. | PT100 | Tabla de entradas PT100 activas." .

ex:Parametro_PT100_n a ex:Parametro ;
    rdfs:label "PT100 n" ;
    ex:textoExtracto "Parámetro. | Significado. | PT100 n | Entrada analógica asociada a la entrada PT100. Valores posibles: De 0 a 32 (por defecto; 0)." ;
    ex:valor "0 a 32" .

ex:Sistema_CNC a ex:Maquina ;
    rdfs:label "CNC" ;
    ex:textoExtracto "Para utilizar las sondas PT100, el CNC debe activar la entrada a la que está conectada." .

ex:Modulo_RIO5 a ex:ComponenteElectrico ;
    rdfs:label "RIO5" ;
    ex:textoExtracto "Los módulos RIO5 tienen 6 entradas analógicas; las cuatro entradas analógicas (AI1..AI4) más las dos entradas PT100 (AI5..AI6)." .

ex:Modulo_RIOR a ex:ComponenteElectrico ;
    rdfs:label "RIOR" ;
    ex:textoExtracto "Los módulos RIOR tienen tiene 4 entradas analógicas; las dos entradas analógicas (AI1..AI2) más las dos entradas PT100 (AI3..AI4)." .

ex:Entrada_PT100_1 a ex:ComponenteElectrico ;
    rdfs:label "AI5" ;
    ex:textoExtracto "Los módulos RIO5 tienen 6 entradas analógicas; las cuatro entradas analógicas (AI1..AI4) más las dos entradas PT100 (AI5..AI6)." .

ex:Entrada_PT100_2 a ex:ComponenteElectrico ;
    rdfs:label "AI6" ;
    ex:textoExtracto "Los módulos RIO5 tienen 6 entradas analógicas; las cuatro entradas analógicas (AI1..AI4) más las dos entradas PT100 (AI5..AI6)." .

ex:Entrada_PT100_3 a ex:ComponenteElectrico ;
    rdfs:label "AI3" ;
    ex:textoExtracto "Los módulos RIOR tienen tiene 4 entradas analógicas; las dos entradas analógicas (AI1..AI2) más las dos entradas PT100 (AI3..AI4)." .

ex:Entrada_PT100_4 a ex:ComponenteElectrico ;
    rdfs:label "AI4" ;
    ex:textoExtracto "Los módulos RIOR tienen tiene 4 entradas analógicas; las dos entradas analógicas (AI1..AI2) más las dos entradas PT100 (AI3..AI4)." .

ex:Tabla_Configuracion_PT100 a ex:Tabla ;
    ex:textoExtracto "Configurar las entradas PT100. Parámetros máquina generales. | Parámetro. | Significado. | NPT100 | Número total de entradas PT100 activas. Valores posibles: De 0 a 10 (por defecto; 0). | PT100 | Tabla de entradas PT100 activas. | PT100 n | Entrada analógica asociada a la entrada PT100. Valores posibles: De 0 a 32 (por defecto; 0)." ;
    ex:compuestoPor ex:Parametro_NPT100, ex:Parametro_PT100, ex:Parametro_PT100_n .