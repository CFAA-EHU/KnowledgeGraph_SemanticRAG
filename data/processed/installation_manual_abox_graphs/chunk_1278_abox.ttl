@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceRealFiltradoSobreLaTrayectoria a ns1:Parametro ;
    rdfs:label "Avance real filtrado sobre la trayectoria" ;
    ns1:identificador "V.G.FREAL" ;
    ns1:textoExtracto "(V.)[ch].G.FREAL Avance real filtrado sobre la trayectoria. Esta variable tiene en cuenta el override y las aceleraciones y deceleraciones de la máquina. Unidades: Milímetros/minuto o pulgadas/minuto." .

ns1:AvanceTeoricoSobreLaTrayectoria a ns1:Parametro ;
    rdfs:label "Avance teórico sobre la trayectoria" ;
    ns1:identificador "V.G.PATHFEED" ;
    ns1:textoExtracto "(V.)[ch].G.PATHFEED Avance teórico sobre la trayectoria. Unidades: Milímetros/minuto o pulgadas/minuto." .

