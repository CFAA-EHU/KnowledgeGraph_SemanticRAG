@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EntradaAnalogica_2 a ex:Sensor ;
    rdfs:label "Entradas analógicas"@es ;
    ex:identificador "2" ;
    ex:textoExtracto "5..6 • (address = 2) RIOR - Entradas analógicas."@es .

ex:EntradaPT100_1 a ex:Sensor ;
    rdfs:label "PT100 1"@es ;
    ex:identificador "PT100 1" ;
    ex:valor "5" ;
    ex:textoExtracto "PT100 1 = 5"@es .

ex:EntradaPT100_2 a ex:Sensor ;
    rdfs:label "PT100 2"@es ;
    ex:identificador "PT100 2" ;
    ex:valor "6" ;
    ex:textoExtracto "PT100 2 = 6"@es .

ex:EntradaPT100_3 a ex:Sensor ;
    rdfs:label "PT100 3"@es ;
    ex:identificador "PT100 3" ;
    ex:valor "9" ;
    ex:textoExtracto "PT100 3 = 9"@es .

ex:ParametroMaquina_NPT100 a ex:Parametro ;
    rdfs:label "NPT100"@es ;
    ex:identificador "NPT100" ;
    ex:valor "3" ;
    ex:textoExtracto "NPT100 = 3"@es .

ex:ParametroMaquina_PT100_1 a ex:Parametro ;
    rdfs:label "PT100 1"@es ;
    ex:identificador "PT100 1" ;
    ex:valor "5" ;
    ex:textoExtracto "PT100 1 = 5"@es .

ex:ParametroMaquina_PT100_2 a ex:Parametro ;
    rdfs:label "PT100 2"@es ;
    ex:identificador "PT100 2" ;
    ex:valor "6" ;
    ex:textoExtracto "PT100 2 = 6"@es .

ex:ParametroMaquina_PT100_3 a ex:Parametro ;
    rdfs:label "PT100 3"@es ;
    ex:identificador "PT100 3" ;
    ex:valor "9" ;
    ex:textoExtracto "PT100 3 = 9"@es .

ex:SistemaConfiguracionPT100 a ex:Sistema ;
    rdfs:label "Configuración de entradas PT100"@es ;
    ex:textoExtracto "Para tener 3 entradas PT100 activas (las dos del primer módulo y la primera del segundo módulo), los parámetros PT100 pueden estar definidos de la siguiente forma. NPT100 = 3 PT100 1 = 5 PT100 2 = 6 PT100 3 = 9 Habilitar/deshabilitar una sonda PT100 desde el PLC. Las entradas PT100 se activan desde los parámetro máquina. Para poder deshabilitar la sonda temporalmente (por ejemplo, en un cambio de cabezal), el PLC dispone de las siguientes marcas."@es ;
    ex:tieneComponente ex:EntradaAnalogica_2, ex:EntradaPT100_1, ex:EntradaPT100_2, ex:EntradaPT100_3, ex:ParametroMaquina_NPT100, ex:ParametroMaquina_PT100_1, ex:ParametroMaquina_PT100_2, ex:ParametroMaquina_PT100_3 .