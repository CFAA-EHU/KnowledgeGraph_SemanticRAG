ex:Parametro_PT100OFF1
    a               ex:Parametro ;
    rdfs:label      "PT100OFF1" ;
    ex:identificador "PT100OFF1" ;
    ex:textoExtracto "Si el PLC activa una de estas marcas, el CNC deshabilita la sonda correspondiente (parámetro PT100 n)." ;
    ex:monitoreaParametro ex:Sensor_PT100_1 .

ex:Parametro_PT100OFF20
    a               ex:Parametro ;
    rdfs:label      "PT100OFF20" ;
    ex:identificador "PT100OFF20" ;
    ex:textoExtracto "Si el PLC activa una de estas marcas, el CNC deshabilita la sonda correspondiente (parámetro PT100 n)." ;
    ex:monitoreaParametro ex:Sensor_PT100_20 .

ex:Sensor_PT100_1
    a               ex:Sensor ;
    ex:textoExtracto "sonda correspondiente (parámetro PT100 n)" .

ex:Sensor_PT100_20
    a               ex:Sensor ;
    ex:textoExtracto "sonda correspondiente (parámetro PT100 n)" .

ex:Tabla_ParametrosPT100 a ex:Tabla ;
     a               ex:Tabla ;
    ex:documentadoEn ex:Pagina_686 ;
    ex:tieneComponente ex:Parametro_PT100OFF1, ex:Parametro_PT100OFF20 ;
    ex:textoExtracto "| Parámetro. | Significado. | --- | --- | PT100OFF1 ꞏꞏ PT100OFF20 | Si el PLC activa una de estas marcas, el CNC deshabilita la sonda correspondiente (parámetro PT100 n)." .