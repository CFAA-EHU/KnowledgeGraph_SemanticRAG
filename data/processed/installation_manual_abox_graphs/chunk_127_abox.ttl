@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:BloqueLogico_127 a ex:Componente ;
    rdfs:label "bloque lógico"@es ;
    ex:textoExtracto "partir del cual se numeran las entradas digitales del bloque lógico"@es .

ex:FormulaIndiceBase_127 a ex:Parametro ;
    rdfs:label "fórmula '8n + 1'"@es ;
    ex:textoExtracto "Los valores del índice base deben cumplir con la fórmula \"8n + 1\" (es decir, 1, 9, 17, 25 ...)"@es ;
    ex:valor "8n + 1"@es .

ex:IndiceBase_127 a ex:Parametro ;
    rdfs:label "índice base"@es ;
    ex:textoExtracto "Los valores del índice base deben cumplir con la fórmula \"8n + 1\""@es .

ex:ModuloRIO5_127 a ex:Componente ;
    rdfs:label "módulo RIO5"@es ;
    ex:textoExtracto "En los nodos RIO5, cada módulo doble (módulo con dos placas) cuenta como dos; es decir, dos bloques lógicos"@es .

ex:Placa_127 a ex:Componente ;
    rdfs:label "placa"@es ;
    ex:textoExtracto "módulo con dos placas"@es .

ex:NDI_127 a ex:Parametro ;
    rdfs:label "NDI"@es ;
    ex:identificador "NDI"@es ;
    ex:textoExtracto "NDI Número de entradas digitales del bloque lógico. Valores posibles: De 8 a 1024. Valor por defecto: 0"@es ;
    ex:valor "0"@es .

ex:VariableMPG_DIMODNDI_127 a ex:Parametro ;
    rdfs:label "(V.)MPG.DIMODNDI[nb]"@es ;
    ex:identificador "(V.)MPG.DIMODNDI[nb]"@es ;
    ex:textoExtracto "Variable asociada: (V.)MPG.DIMODNDI[nb] Número de entradas digitales del bloque lógico; no puede ser cero y debe ser un múltiplo de 8 (8, 16, 24, ...1024)"@es ;
    ex:valor "0"@es .