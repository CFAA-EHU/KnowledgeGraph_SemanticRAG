@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_VariablesCNC_15_6_1 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de variables del CNC (15.6.1)"@es ;
    ex:textoExtracto "Las siguientes variables son accesibles desde el programa pieza y desde el modo MDI/MDA. Para cada una de ellas se indica si el acceso es de lectura (R) o de escritura (W)."@es ;
    ex:identificador "15.6.1" .

ex:Parametro_G_ANAI
    a ex:Parametro ;
    rdfs:label "G.ANAI[n]" ;
    ex:textoExtracto "(V.)G.ANAI[n] | R | Tensión en voltios de la entrada analógica [n] o temperatura en décimas de grado si es una sonda de temperatura PT100. Unidades: Voltios / décimas de grado."@es ;
    ex:valor "R (solo lectura)" ;
    ex:documentadoEn ex:Tabla_VariablesCNC_15_6_1 ;
    ex:monitoreaParametro ex:Sensor_EntradaAnalogica .

ex:Parametro_G_ANAO
    a ex:Parametro ;
    rdfs:label "G.ANAO[n]" ;
    ex:textoExtracto "(V.)G.ANAO[n] | R/W | Tensión en voltios de la salida [n]. Unidades: Voltios."@es ;
    ex:valor "R/W (lectura/escritura)" ;
    ex:documentadoEn ex:Tabla_VariablesCNC_15_6_1 ;
    ex:controla ex:Actuador_SalidaAnalogica .

ex:Sensor_EntradaAnalogica
    a ex:Sensor ;
    rdfs:label "Entrada analógica [n]"@es ;
    ex:textoExtracto "Tensión en voltios de la entrada analógica [n] o temperatura en décimas de grado si es una sonda de temperatura PT100."@es .

ex:Actuador_SalidaAnalogica
    a ex:Actuador ;
    rdfs:label "Salida analógica [n]"@es ;
    ex:textoExtracto "Tensión en voltios de la salida [n]."@es .