@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PorcentajeDeBloquesQueGestionaElCNCEnLaPreparacionDeBloquesRespectoEl_555266bb67 a ns1:Parametro ;
    rdfs:label "Porcentaje de bloques que gestiona el CNC en la preparación de bloques, respecto el óptimo alcanzable" ;
    ns1:identificador "G.PERFRATE" ;
    ns1:textoExtracto "(V.)[ch].G.PERFRATE Porcentaje de bloques que gestiona el CNC en la preparación de bloques, respecto el óptimo alcanzable, para alcanzar el avance máximo en cada tramo." .

ns1:PorcentajeDeReduccionDelAvanceMaximoAlcanzable_cb66bda76c a ns1:Parametro ;
    rdfs:label "Porcentaje de reducción del avance máximo alcanzable" ;
    ns1:identificador "G.DROPRATE" ;
    ns1:textoExtracto "(V.)[ch].G.DROPRATE Porcentaje de reducción del avance máximo alcanzable. La reducción del avance puede ser debida a un suministro inadecuado de bloques o a un avance programado inferior al posible." .

ns1:ValorDelErrorQueDesactivaLasSplinesModoCONTERROR_250a11055b a ns1:Parametro ;
    rdfs:label "Valor del error que desactiva las splines (modo CONTERROR)" ;
    ns1:identificador "G.LIMERROR" ;
    ns1:textoExtracto "(V.)[ch].G.LIMERROR Valor del error que desactiva las splines (modo CONTERROR). Esta variable permite valorar si el programa está generado con más error del que pedimos al modo HSC." .

