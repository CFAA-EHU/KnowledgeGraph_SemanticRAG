@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:LantekExpertInside
    a                     ex:Sistema ;
    rdfs:label            "Lantek Expert Inside" ;
    ex:textoExtracto      "Fagor Automation y Lantek han colaborado en la integración del software Lantek Expert Inside para los modelos CNC 8060 y 8070. A partir de figuras en formato dxf, dwg o ficheros paramétricos, este software permite distribuirlas en un chapa optimizando el aprovechamiento de la misma, definir la estrategia de entrada/salida (lead-in/lead-out), etc para finalmente generar un programa pieza en lenguaje Fagor."@es ;
    ex:identificador      "Lantek Expert Inside" .

ex:InterfazLantekExpertInside
    a                     ex:InterfazUsuario ;
    rdfs:label            "Interfaz de Lantek Expert Inside" ;
    ex:textoExtracto       "La sencilla interfaz, adecuada para pantallas táctiles, facilita la revisión del corte en tiempo real y las modificaciones a pie de máquina."@es ;
    ex:documentadoEn       ex:LantekExpertInside .

ex:ModoNestingManual
    a                     ex:ModoOperacion ;
    rdfs:label            "Nesting manual" ;
    ex:textoExtracto       "nesting manual (el usuario coloca las piezas en la chapa como le resulte conveniente)"@es ;
    ex:habilitadoPor       ex:LantekExpertInside .

ex:ModoNestingAutomatico
    a                     ex:ModoOperacion ;
    rdfs:label            "Nesting automático" ;
    ex:textoExtracto       "nesting automático (el software coloca la piezas en la chapa basándose en sus parámetros de configuración)"@es ;
    ex:habilitadoPor       ex:LantekExpertInside .

ex:PostprocesadorFagor
    a                     ex:Componente ;
    rdfs:label            "Postprocesador Fagor" ;
    ex:textoExtracto       "El postprocesador Fagor integrado creará el programa pieza para el CNC."@es ;
    ex:compuestoPor        ex:LantekExpertInside .

ex:ProgramaPiezaCNC
    a                     ex:Parametro ;
    rdfs:label            "Programa pieza CNC" ;
    ex:textoExtracto       "generar un programa pieza en lenguaje Fagor"@es ;
    ex:monitoreaParametro  ex:LantekExpertInside .

ex:PanelPC
    a                     ex:ComponenteElectrico ;
    rdfs:label            "PanelPC" ;
    ex:textoExtracto       "El software puede ir instalado bien en el CNC o bien en un PanelPC."@es .

ex:CNC_8060
    a                     ex:Maquina ;
    rdfs:label            "CNC 8060" ;
    ex:identificador      "8060" ;
    ex:textoExtracto       "para los modelos CNC 8060 y 8070"@es ;
    ex:tieneComponente     ex:LantekExpertInside .

ex:CNC_8070
    a                     ex:Maquina ;
    rdfs:label            "CNC 8070" ;
    ex:identificador      "8070" ;
    ex:textoExtracto       "para los modelos CNC 8060 y 8070"@es ;
    ex:tieneComponente     ex:LantekExpertInside .