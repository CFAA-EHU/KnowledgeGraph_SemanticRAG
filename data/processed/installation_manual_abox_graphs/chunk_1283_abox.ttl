@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ArchivoBat_CNC8070L a ex:ComponenteElectrico ;
    rdfs:label "CNC8070L.bat" ;
    ex:textoExtracto "El CNC arranca a través de un archivo bat (por ejemplo CNC8070L.bat). En este archivo bat, añadir la línea \"start c:\\Lantek\\Expert\\Expert.exe\"." .

ex:Expert_exe a ex:ComponenteElectrico ;
    rdfs:label "Expert.exe" ;
    ex:textoExtracto "añadir la línea \"start c:\\Lantek\\Expert\\Expert.exe\". El software del nesting arranca a continuación del CNC." .

ex:ParametroMaquina_HMI a ex:Parametro ;
    rdfs:label "USERKEY" ;
    ex:textoExtracto "En los parámetros máquina HMI, configurar la tecla USERKEY como \"Aplicación\" y asignarle el path \"c:\\Lantek\\Expert\\Expert.exe\"." .

ex:Tecla_CUSTOM a ex:InterfazUsuario ;
    rdfs:label "[CUSTOM]" ;
    ex:textoExtracto "El software del nesting arranca cuando el usuario pulsa la tecla [CUSTOM]." .

ex:Archivo_Apps_ini a ex:ComponenteElectrico ;
    rdfs:label "Apps.ini" ;
    ex:textoExtracto "En el archivo ..\\MTB\\MMC\\Config\\Apps.ini añadir la línea \"Lantek=c:\\Lantek\\Expert\\Expert.exe\"." .

ex:ModoDiagnosis a ex:ModoOperacion ;
    rdfs:label "Diagnosis" ;
    ex:textoExtracto "Para arrancar el nesting, ir al modo Diagnosis, y en el menú horizontal seleccionar Apps > Lantek." .

ex:Menu_Apps a ex:InterfazUsuario ;
    rdfs:label "Apps" ;
    ex:textoExtracto "en el menú horizontal seleccionar Apps > Lantek." .