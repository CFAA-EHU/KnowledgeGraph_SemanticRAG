@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ConfiguracionArranqueNesting_1283
    a                     ex:InterfazUsuario ;
    rdfs:label            "Configuración de arranque del nesting (pág. 691)"@es ;
    ex:textoExtracto      "Hay tres formas diferentes para arrancar el nesting. [...] Para arrancar el nesting, ir al modo Diagnosis, y en el menú horizontal seleccionar Apps > Lantek."@es ;
    ex:tieneComponente    ex:ArchivoBAT_CNC8070L ,
                          ex:TeclaUSERKEY ,
                          ex:ArchivoConfig_AppsINI ;
    ex:ilustradoEn        ex:Pagina_691 .

ex:ArchivoBAT_CNC8070L
    a                     ex:Componente ;
    rdfs:label            "Archivo BAT (ej. CNC8070L.bat)"@es ;
    ex:identificador      "CNC8070L.bat" ;
    ex:textoExtracto      "El CNC arranca a través de un archivo bat (por ejemplo CNC8070L.bat). En este archivo bat, añadir la línea 'start c:\\Lantek\\Expert\\Expert.exe'."@es .

ex:TeclaUSERKEY
    a                     ex:InterfazUsuario ;
    rdfs:label            "Tecla USERKEY (modo 'Aplicación')"@es ;
    ex:identificador      "USERKEY" ;
    ex:textoExtracto      "En los parámetros máquina HMI, configurar la tecla USERKEY como 'Aplicación' y asignarle el path 'c:\\Lantek\\Expert\\Expert.exe'."@es .

ex:ArchivoConfig_AppsINI
    a                     ex:Componente ;
    rdfs:label            "Archivo Apps.ini (configuración Lantek)"@es ;
    ex:identificador      "Apps.ini" ;
    ex:textoExtracto      "En el archivo ..\\MTB\\MMC\\Config\\Apps.ini añadir la línea 'Lantek=c:\\Lantek\\Expert\\Expert.exe'."@es .

ex:Pagina_693
    a                     ex:Pagina ;
    ex:identificador      "691" ;
    ex:textoExtracto      "Sección 16.1.3 Configuración del arranque de la aplicación."@es ;
    ex:documentadoEn      ex:Manual .