@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeBloquesDeProgramaEjecutadosOPreparados a ns1:Parametro ;
    rdfs:label "Número de bloques de programa ejecutados o preparados" ;
    ns1:documentadoEn ns1:SistemaInterfazUsuario ;
    ns1:identificador "V.ch.G.LINEN" ;
    ns1:textoExtracto "(V.)[ch].G.LINEN Número de bloques de programa ejecutados o preparados. La lectura de la variable desde el PLC o interfaz devuelve el número de bloques ejecutados; la lectura desde el programa pieza o MDI devuelve el número de bloques preparados. Unidades: -." .

ns1:UltimaEtiquetaEjecutadaNumero a ns1:Parametro ;
    rdfs:label "Última etiqueta ejecutada (número)" ;
    ns1:documentadoEn ns1:SistemaInterfazUsuario ;
    ns1:identificador "V.ch.G.BLKN" ;
    ns1:textoExtracto "(V.)[ch].G.BLKN Última etiqueta ejecutada (número). Si no se ha ejecutado ninguna etiqueta, la variable devuelve valor -1. Unidades: -." .

ns1:SistemaInterfazUsuario a ns1:Sistema ;
    rdfs:label "Interfaz Usuario" ;
    ns1:textoExtracto "Sintaxis de la variable. ꞏchꞏ Número de canal. | V.[2].G.BLKN | Canal ꞏ2ꞏ." .

