@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
ex:Idioma_en a ex:Parametro ;
    ex:identificador "en" ;
    ex:textoExtracto "Código. | Idioma. | --- | --- | Cs | Checo. | de | Alemán. | en | Inglés (Reino Unido). | en-US | Inglés (Estados Unidos). | es | Español (España). | es-MX | Español (Mexico). | fr | Francés. | it | Italiano. | ja | Japonés. | ko | Coreano. | nl | Holandés (Nederlands). | pl | Polaco. | pt | Portugués (Brasil). | pt-PT | Portugués (Portugal). | ru | Ruso. | sv | Sueco. | th | Tailandés. | tr | Turco. | zh-CHS | Chino (Simplificado). | zh-CHT | Chino (Tradicional)." .

ex:Idioma_en_US a ex:Parametro ;
    ex:identificador "en-US" ;
    ex:textoExtracto "Código. | Idioma. | --- | --- | Cs | Checo. | de | Alemán. | en | Inglés (Reino Unido). | en-US | Inglés (Estados Unidos). | es | Español (España). | es-MX | Español (Mexico). | fr | Francés. | it | Italiano. | ja | Japonés. | ko | Coreano. | nl | Holandés (Nederlands). | pl | Polaco. | pt | Portugués (Brasil). | pt-PT | Portugués (Portugal). | ru | Ruso. | sv | Sueco. | th | Tailandés. | tr | Turco. | zh-CHS | Chino (Simplificado). | zh-CHT | Chino (Tradicional)." .

ex:Idioma_es a ex:Parametro ;
    ex:identificador "es" ;
    ex:textoExtracto "Código. | Idioma. | --- | --- | Cs | Checo. | de | Alemán. | en | Inglés (Reino Unido). | en-US | Inglés (Estados Unidos). | es | Español (España). | es-MX | Español (Mexico). | fr | Francés. | it | Italiano. | ja | Japonés. | ko | Coreano. | nl | Holandés (Nederlands). | pl | Polaco. | pt | Portugués (Brasil). | pt-PT | Portugués (Portugal). | ru | Ruso. | sv | Sueco. | th | Tailandés. | tr | Turco. | zh-CHS | Chino (Simplificado). | zh-CHT | Chino (Tradicional)." .

ex:Idioma_zh_CHS a ex:Parametro ;
    ex:identificador "zh-CHS" ;
    ex:textoExtracto "Código. | Idioma. | --- | --- | Cs | Checo. | de | Alemán. | en | Inglés (Reino Unido). | en-US | Inglés (Estados Unidos). | es | Español (España). | es-MX | Español (Mexico). | fr | Francés. | it | Italiano. | ja | Japonés. | ko | Coreano. | nl | Holandés (Nederlands). | pl | Polaco. | pt | Portugués (Brasil). | pt-PT | Portugués (Portugal). | ru | Ruso. | sv | Sueco. | th | Tailandés. | tr | Turco. | zh-CHS | Chino (Simplificado). | zh-CHT | Chino (Tradicional)." .

ex:Parametro_Language a ex:Parametro ;
    ex:identificador "Language" ;
    ex:textoExtracto "Cambiar el parámetro para el primer idioma (se recomienda configurarlo como \"en\" (inglés UK) o \"en-US\" (inglés US). <setting name=\"Language\" serializeAs=\"String\"> <value>en</value>" .

ex:Parametro_LocalLanguage a ex:Parametro ;
    ex:identificador "LocalLanguage" ;
    ex:textoExtracto "Cambiar el parámetro para el idioma local; seleccionar el idioma deseado. <setting name=\"LocalLanguage\" serializeAs=\"String\"> <value>zh-CHS</value>" .

ex:Fichero_Expert_exe_config a ex:Manual ;
    ex:textoExtracto "Editar el fichero ..\\LantekInside\\Expert\\Expert.exe.config con un editor de texto." .