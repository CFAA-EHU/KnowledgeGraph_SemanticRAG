@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CotaTeoricaALaEntradaDelLazoDePosicionComponenteSn a ns1:Parametro ;
    rdfs:label "Cota teórica a la entrada del lazo de posición (componente sn)"@es ;
    ns1:identificador "LOOPTPOS.sn" ;
    ns1:textoExtracto "\"(V.)[ch].A.LOOPTPOS.sn Cota teórica a la entrada del lazo de posición. Unidades: Milímetros, pulgadas o grados.\""@es .

ns1:CotaTeoricaALaEntradaDelLazoDePosicionComponenteXn a ns1:Parametro ;
    rdfs:label "Cota teórica a la entrada del lazo de posición (componente xn)"@es ;
    ns1:identificador "LOOPTPOS.xn" ;
    ns1:textoExtracto "\"(V.)[ch].A.LOOPTPOS.xn Cota teórica a la entrada del lazo de posición. Unidades: Milímetros, pulgadas o grados.\""@es .

