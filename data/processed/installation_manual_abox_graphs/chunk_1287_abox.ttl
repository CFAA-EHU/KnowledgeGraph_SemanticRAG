ns1:CotaRealALaEntradaDelLazoDePosicionParaElCabezalSEnModoPreparacion a ns1:Parametro ;
    rdfs:label "Cota real a la entrada del lazo de posición para el cabezal S en modo preparación" ;
    ns1:identificador "V.SP.IPOPOS.S" ;
    ns1:textoExtracto "V.SP.IPOPOS.S | Cabezal S." .

ns1:CotaRealALaEntradaDelLazoDePosicionParaElEjeZ a ns1:Parametro ;
