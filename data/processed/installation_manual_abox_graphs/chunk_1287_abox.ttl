@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CotaRealALaEntradaDelLazoDePosicionParaElCabezalMasterEnModoPreparacion a ns1:Parametro ;
    rdfs:label "Cota real a la entrada del lazo de posición para el cabezal master en modo preparación" ;
    ns1:identificador "V.SP.IPOPOS" ;
    ns1:textoExtracto "V.SP.IPOPOS | Cabezal master." .

