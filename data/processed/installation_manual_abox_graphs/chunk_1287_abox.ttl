@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:GAPCTRL_ON_Z_GAP_1 a ex:ModoOperacion ;
    ex:identificador "#GAPCTRL ON [Z, GAP 1]" ;
    ex:textoExtracto "#GAPCTRL ON [Z, GAP 1]" .

ex:GAPCTRL_ON_Z_11_GAP_2 a ex:ModoOperacion ;
    ex:identificador "#GAPCTRL ON [Z-11, GAP 2]" ;
    ex:textoExtracto "#GAPCTRL ON [Z-11, GAP 2]" .

ex:GAPCTRL_ON_GAP_5 a ex:ModoOperacion ;
    ex:identificador "#GAPCTRL ON [GAP 5]" ;
    ex:textoExtracto "#GAPCTRL ON [GAP 5]" .

ex:GAPCTRL_ON_Z_10 a ex:ModoOperacion ;
    ex:identificador "#GAPCTRL ON [Z-10]" ;
    ex:textoExtracto "#GAPCTRL ON [Z-10]" .

ex:GAPCTRL_OFF a ex:ModoOperacion ;
    ex:identificador "#GAPCTRL OFF" ;
    ex:textoExtracto "#GAPCTRL OFF" .

ex:Sensor_GAP a ex:Sensor ;
    ex:textoExtracto "el eje asociado al sensor se mueve al avance programado (si no hay avance programado, al avance definido en MAXFEED), bien hasta detectar la pieza con el sensor o bien hasta la cota programada (POS)" .

ex:Parametro_GAPTOLCANCEL a ex:Parametro ;
    ex:identificador "GAPTOLCANCEL" ;
    ex:textoExtracto "dependiendo del parámetro máquina GAPTOLCANCEL" .

ex:Parametro_GAPTOL a ex:Parametro ;
    ex:identificador "GAPTOL" ;
    ex:textoExtracto "el CNC considera que el bloque de aproximación ha terminado cuando el sensor alcanza el gap con la tolerancia definida en el parámetro máquina GAPTOL" .

ex:Parametro_MAXFEED a ex:Parametro ;
    ex:identificador "MAXFEED" ;
    ex:textoExtracto "si no hay avance programado, al avance definido en MAXFEED" .

ex:Comando_CNCEX a ex:AccionProhibida ;
    ex:identificador "CNCEX" ;
    ex:textoExtracto "El PLC puede activar el control del gap ejecutando con el comando CNCEX el bloque de CNC correspondiente" .

ex:Bloque_CNC a ex:Sistema ;
    ex:identificador "bloque de CNC" ;
    ex:textoExtracto "ejecutando con el comando CNCEX el bloque de CNC correspondiente" .

ex:PLC a ex:Sistema ;
    ex:textoExtracto "Programación desde el PLC. El PLC puede activar el control del gap ejecutando con el comando CNCEX el bloque de CNC correspondiente" .