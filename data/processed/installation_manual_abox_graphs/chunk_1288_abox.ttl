@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:GAPCTRL a ex:ModoOperacion ;
    ex:textoExtracto "durante el movimiento de aproximación, el CNC permite detener el movimiento (señales _STOP o _FEEDHOL)" .

ex:_STOP a ex:Sensor ;
    ex:textoExtracto "señales _STOP" .

ex:_FEEDHOL a ex:Sensor ;
    ex:textoExtracto "señales _FEEDHOL" .

ex:CNC a ex:Maquina ;
    ex:textoExtracto "el CNC mantendrá el gap definido" ;
    ex:textoExtracto "el CNC permite detener el movimiento" .