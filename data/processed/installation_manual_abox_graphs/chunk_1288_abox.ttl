@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ControlGapLaser
    a ex:ModoOperacion ;
    rdfs:label "Control del gap láser"@es ;
    ex:textoExtracto "Una vez detectada la pieza, el CNC mantendrá el gap definido, incluso si detecta la pieza justo al ejecutar #GAPCTRL, sin empezar a bajar. Durante el movimiento de aproximación, el CNC permite detener el movimiento (señales _STOP o _FEEDHOL). En este caso el eje permanecerá parado y sin control del gap hasta que se reanude el movimiento."@es ;
    ex:identificador "#GAPCTRL" .

ex:Senal_STOP
    a ex:InterfazUsuario ;
    rdfs:label "Señal _STOP"@es ;
    ex:textoExtracto "señales _STOP"@es ;
    ex:habilitadoPor ex:ControlGapLaser .

ex:Senal_FEEDHOL
    a ex:InterfazUsuario ;
    rdfs:label "Señal _FEEDHOL"@es ;
    ex:textoExtracto "señales _FEEDHOL"@es ;
    ex:habilitadoPor ex:ControlGapLaser .