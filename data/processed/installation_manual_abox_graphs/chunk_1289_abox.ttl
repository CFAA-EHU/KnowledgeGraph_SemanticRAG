@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SensorGap1289 a ex:Sensor ;
    rdfs:label "sensor del gap"@es ;
    ex:textoExtracto "La entrada analógica para el sensor podrá estar situada en los módulos remotos CAN o en un regulador Sercos de cualquier eje."@es ;
    ex:textoExtracto "Utilizar los parámetros máquina GAPANAINTYPE y GAPANAINID para definir en el CNC dónde está la entrada del sensor."@es .

ex:ReguladorSercos1289 a ex:ComponenteElectrico ;
    rdfs:label "regulador Sercos"@es ;
    ex:textoExtracto "La entrada analógica para el sensor podrá estar situada en los módulos remotos CAN o en un regulador Sercos de cualquier eje."@es ;
    ex:textoExtracto "Fagor Automation recomienda utilizar una entrada del regulador."@es ;
    ex:textoExtracto "Conexión del sensor a una entrada analógica del regulador Sercos. El ejemplo utiliza la primera entrada analógica del regulador (pines 4 y 5); para utilizar la segunda, utilizar los pines 2 y 3."@es ;
    ex:textoExtracto "Las entradas analógicas del regulador son un opción de hardware; para disponer de ellas, el regulador debe disponer de una interfaz de comunicación con entradas analógicas A1 o SI."@es .

ex:ModuloRemotoCAN1289 a ex:ComponenteElectrico ;
    rdfs:label "módulos remotos CAN"@es ;
    ex:textoExtracto "La entrada analógica para el sensor podrá estar situada en los módulos remotos CAN o en un regulador Sercos de cualquier eje."@es ;
    ex:textoExtracto "Conexión del sensor a una entrada analógica de los módulos remotos. Las entradas analógicas están disponibles en los módulos RIO5 y RIOR."@es .

ex:ParametroGAPANAINTYPE1289 a ex:Parametro ;
    rdfs:label "GAPANAINTYPE"@es ;
    ex:identificador "GAPANAINTYPE" ;
    ex:textoExtracto "Utilizar los parámetros máquina GAPANAINTYPE y GAPANAINID para definir en el CNC dónde está la entrada del sensor."@es .

ex:ParametroGAPANAINID1289 a ex:Parametro ;
    rdfs:label "GAPANAINID"@es ;
    ex:identificador "GAPANAINID" ;
    ex:textoExtracto "Utilizar los parámetros máquina GAPANAINTYPE y GAPANAINID para definir en el CNC dónde está la entrada del sensor."@es .

ex:EsquemaElectricoConexionSensor1289 a ex:Esquema ;
    rdfs:label "Esquema eléctrico. Conexión del sensor a una entrada analógica del regulador Sercos."@es ;
    ex:textoExtracto "Esquema eléctrico. Conexión del sensor a una entrada analógica del regulador Sercos."@es ;
    ex:textoExtracto "Conexión del sensor a una entrada analógica del regulador Sercos. El ejemplo utiliza la primera entrada analógica del regulador (pines 4 y 5); para utilizar la segunda, utilizar los pines 2 y 3."@es ;
    ex:tieneComponente ex:SensorGap1289, ex:ReguladorSercos1289 .

ex:ModuloRIO51289 a ex:ComponenteElectrico ;
    rdfs:label "módulo RIO5"@es ;
    ex:textoExtracto "Las entradas analógicas están disponibles en los módulos RIO5 y RIOR."@es .

ex:ModuloRIOR1289 a ex:ComponenteElectrico ;
    rdfs:label "módulo RIOR"@es ;
    ex:textoExtracto "Las entradas analógicas están disponibles en los módulos RIO5 y RIOR."@es .