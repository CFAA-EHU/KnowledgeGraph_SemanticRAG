@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NombreNumeroLogicoOIndiceDelCabezalConIndice2EnElSistema a ns1:Parametro ;
    rdfs:label "Nombre, número lógico o índice del cabezal con índice 2 en el sistema" ;
    ns1:identificador "V.SP.TFEED.2" ;
    ns1:textoExtracto "V.SP.TFEED.2 | Cabezal con índice 2 en el sistema." .

ns1:NombreNumeroLogicoOIndiceDelCabezalConNumeroLogico4 a ns1:Parametro ;
    rdfs:label "Nombre, número lógico o índice del cabezal con número lógico 4" ;
    ns1:identificador "V.A.TFEED.4" ;
    ns1:textoExtracto "V.A.TFEED.4 | Eje o cabezal con número lógico 4." .

ns1:NombreNumeroLogicoOIndiceDelCabezalEnElEjeZ a ns1:Parametro ;
    rdfs:label "Nombre, número lógico o índice del cabezal en el eje Z" ;
    ns1:identificador "V.A.TFEED.Z" ;
    ns1:textoExtracto "V.A.TFEED.Z | Eje Z." .

ns1:NombreNumeroLogicoOIndiceDelCabezalMaster a ns1:Parametro ;
    rdfs:label "Nombre, número lógico o índice del cabezal master" ;
    ns1:identificador "V.SP.TFEED" ;
    ns1:textoExtracto "V.SP.TFEED | Cabezal master." .

ns1:NombreNumeroLogicoOIndiceDelCabezalS a ns1:Parametro ;
    rdfs:label "Nombre, número lógico o índice del cabezal S" ;
    ns1:identificador "V.SP.TFEED.S" ;
    ns1:textoExtracto "V.SP.TFEED.S | Cabezal S." .

