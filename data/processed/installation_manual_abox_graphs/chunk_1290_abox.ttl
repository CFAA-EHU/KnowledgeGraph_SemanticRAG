@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:EjeControlGap a ex:ComponenteMecanico ;
    ex:textoExtracto "El eje que controla el gap no debe ajustarse del modo estándar, sino que se hará con movimientos de aproximación con el control de gap activo." ;
    ex:tieneComponente ex:SensorGap .

ex:SensorGap a ex:Sensor ;
    ex:textoExtracto "De estos movimientos se obtendrán los parámetros GAPGAIN, PROGAIN, FFGAIN y ACFGAIN. Como referencia para evitar sobrepasamientos en el gap, se recomienda trabajar con los siguientes valores. | Sercos velocidad Analógico. | Sercos posición. |" .

ex:ParametroGAPGAIN a ex:Parametro ;
    ex:identificador "GAPGAIN" ;
    ex:valor "0.20" ;
    ex:textoExtracto "• GAPGAIN = 0.20." .

ex:ParametroFFGAIN a ex:Parametro ;
    ex:identificador "FFGAIN" ;
    ex:valor "90 %" ;
    ex:textoExtracto "• FFGAIN = 90 %." .

ex:ParametroACFGAIN a ex:Parametro ;
    ex:identificador "ACFGAIN" ;
    ex:valor "30 %" ;
    ex:textoExtracto "• ACFGAIN = 30 %." .

ex:ParametroLOOPTIME a ex:Parametro ;
    ex:identificador "LOOPTIME" ;
    ex:valor "2 milisegundos" ;
    ex:textoExtracto "Tiempo de lazo. Se recomienda utilizar un tiempo de ciclo de 2 milisegundos (LOOPTIME=2)." .

ex:VariableGGAP a ex:Parametro ;
    ex:identificador "G.GAP" ;
    ex:textoExtracto "(A) La variable G.GAP refleja el valor real del gap, detectado por el sensor." .

ex:VariableAFLWEZ a ex:Parametro ;
    ex:identificador "A.FLWE.Z" ;
    ex:textoExtracto "(B) La variable A.FLWE.Z refleja el error de seguimiento del eje Z (eje del sensor)." .

ex:SeñalDIFFATPOSZ a ex:Parametro ;
    ex:identificador "DIFF(A.TPOS.Z)" ;
    ex:textoExtracto "(C) La señal DIFF(A.TPOS.Z) nos indica la velocidad en Z." .

ex:SeñalDIFFDIFFATPOSZ a ex:Parametro ;
    ex:identificador "DIFF(DIFF(A.TPOS.Z))" ;
    ex:textoExtracto "(D) La señal DIFF(DIFF(A.TPOS.Z)) nos indica la aceleración en Z." .