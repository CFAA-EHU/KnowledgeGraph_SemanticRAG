@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ParametrosGap a ex:Tabla ;
    rdfs:label "Tabla de parámetros de configuración del gap"@es ;
    ex:textoExtracto "Configurar los límites del gap. | Parámetro. | Significado. | [...] Configurar la respuesta del CNC al sobrepasar los límites del gap."@es ;
    ex:ilustradoEn ex:Pagina_698 .

ex:Parametro_GAPMIN a ex:Parametro ;
    rdfs:label "GAPMIN" ;
    ex:identificador "GAPMIN" ;
    ex:textoExtracto "Mínimo valor permitido para el gap; por debajo de este valor, el CNC mostrará o no un error según lo definido en el parámetro GAPERRORCANCEL."@es ;
    ex:documentadoEn ex:Tabla_ParametrosGap .

ex:Parametro_GAPMAX a ex:Parametro ;
    rdfs:label "GAPMAX" ;
    ex:identificador "GAPMAX" ;
    ex:textoExtracto "Máximo valor permitido para el gap; por encima de este valor, el CNC mostrará o no un error según lo definido en el parámetro GAPERRORCANCEL. Este parámetro debe ser inferior a GAPDISTLIMIT."@es ;
    ex:documentadoEn ex:Tabla_ParametrosGap .

ex:Parametro_GAPTOL a ex:Parametro ;
    rdfs:label "GAPTOL" ;
    ex:identificador "GAPTOL" ;
    ex:textoExtracto "Este parámetro define una ventana de posicionamiento, sobre el gap programado, para dar por finalizado el bloque de aproximación."@es ;
    ex:documentadoEn ex:Tabla_ParametrosGap .

ex:Parametro_GAPERRORCANCEL a ex:Parametro ;
    rdfs:label "GAPERRORCANCEL" ;
    ex:identificador "GAPERRORCANCEL" ;
    ex:textoExtracto "Este parámetro indica si el CNC debe anular el error de gap fuera del rango, cuando el gap sobrepasa el rango GAPMIN - GAPMAX. Independientemente del valor de este parámetro, el CNC sigue vigilando la marca INPOSGAP."@es ;
    ex:documentadoEn ex:Tabla_ParametrosGap .

ex:Parametro_GAPTOLCANCEL a ex:Parametro ;
    rdfs:label "GAPTOLCANCEL" ;
    ex:identificador "GAPTOLCANCEL" ;
    ex:textoExtracto "Este parámetro indica si el CNC debe anular el error de gap fuera de tolerancia, cuando el gap supera el margen definido en el parámetro GAPTOL."@es ;
    ex:documentadoEn ex:Tabla_ParametrosGap .

ex:Pagina_698 a ex:Pagina ;
    rdfs:label "Página 698"@es ;
    ex:identificador "698" ;
    ex:textoExtracto "Sección 16.2.3 Configurar el gap."@es .