@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:GAPANAINTYPE a ex:Parametro ;
    ex:textoExtracto "Este parámetro indica dónde está ubicada la entrada analógica conectada al sensor; en los módulos remotos CAN o en un regulador Sercos. Se recomienda utilizar una entrada del regulador." ;
    rdfs:label "GAPANAINTYPE" .

ex:GAPANAINID a ex:Parametro ;
    ex:textoExtracto "Este parámetro identifica la entrada analógica donde está conectado el sensor; si remoto CAN, de 1 a 60; si regulador, de 101 a 132 o de 201 a 232. Entrada analógica de los módulos remotos. En este caso, este parámetro indica el número de la entrada analógica que utiliza el sensor del gap. Entrada analógica de un regulador Sercos. Opción recomendada. En este caso, este parámetro indica cuál es el número de la entrada analógica y el regulador a utilizar. El parámetro se define mediante un número de tres dígitos; el primer dígito indica el número de la entrada analógica a utilizar (1 ó 2) y los dos dígitos siguientes indican la dirección lógica del regulador (de 1 a 32)." ;
    rdfs:label "GAPANAINID" .

ex:GAPSENSOROFFSET a ex:Parametro ;
    ex:textoExtracto "Offset (en milivoltios) a aplicar al sensor desde el CNC. Si se utiliza una entrada analógica Fagor, no es necesario definir este parámetro, ya que todas ellas disponen de un offset propio." ;
    rdfs:label "GAPSENSOROFFSET" .

ex:GAPSENSORCH a ex:Parametro ;
    ex:textoExtracto "Cambiar el signo de la señal del sensor." ;
    rdfs:label "GAPSENSORCH" .

ex:GAPDISTLIMIT a ex:Parametro ;
    ex:textoExtracto "Distancia que corresponde a señal analógica límite del sensor (parámetro GAPVOLTLIMIT)." ;
    rdfs:label "GAPDISTLIMIT" .

ex:GAPVOLTLIMIT a ex:Parametro ;
    ex:textoExtracto "Voltaje (en milivoltios) que corresponde al recorrido límite del sensor (parámetro GAPDISTLIMIT)." ;
    rdfs:label "GAPVOLTLIMIT" .

ex:SensorGap a ex:Sensor ;
    ex:textoExtracto "sensor del gap" ;
    rdfs:label "sensor del gap" .