@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Senal_GAPCOLLISIONMODE
    a ex:Parametro ;
    rdfs:label "GAPCOLLISIONMODE" ;
    ex:textoExtracto "El sensor para el control del gap puede disponer de una señal de colisión que se conecta al CNC, y que el PLC la debe gestionar a través de la marca GAPCOLLISION. Si el PLC activa la marca GAPCOLLISION, el CNC mostrará o no un error según lo definido en este parámetro." ;
    ex:identificador "GAPCOLLISIONMODE" .

ex:SensorGap
    a ex:Sensor ;
    rdfs:label "Sensor del gap" ;
    ex:textoExtracto "El sensor para el control del gap puede disponer de una señal de colisión que se conecta al CNC" ;
    ex:monitoreaParametro ex:Senal_GAPCOLLISIONMODE .

ex:Tabla_SenalesPLC_699 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de señales del PLC (página 699)" ;
    ex:textoExtracto "| Señales del PLC. | Significado. | --- | --- | GAPCOLLISIONMODE | El sensor para el control del gap puede disponer de una señal de colisión que se conecta al CNC..." ;
    ex:documentadoEn ex:Pagina_699 .

ex:Pagina_699
    a ex:Pagina ;
    rdfs:label "Página 699 - Configuración del sensor del gap" ;
    ex:identificador "699" ;
    ex:textoExtracto "16.2.4 Configurar el sensor del gap." .