ns1:CNC8070_d31cfc13ed a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC dispone de un conjunto de variables, que analizadas durante la ejecución del mecanizado, permiten discernir aspectos mejorables del HSC." .

ns1:Herramienta_ad856c082b a ns1:Herramienta ;
    rdfs:label "Osciloscopio" ;
    ns1:textoExtracto "El osciloscopio servirá como herramienta análisis para ver la evolución del HSC durante el mecanizado." .

