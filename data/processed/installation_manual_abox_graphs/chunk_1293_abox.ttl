@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceleracionLineal1 a ns1:Parametro ;
    rdfs:label "Aceleración lineal 1" ;
    ns1:identificador "LACC1" ;
    ns1:textoExtracto "los parámetros G00FEED, ACCEL, LACC1, LACC2 y ACCJERK testeados y ajustados al máximo que la dinámica de la máquina permite." .

