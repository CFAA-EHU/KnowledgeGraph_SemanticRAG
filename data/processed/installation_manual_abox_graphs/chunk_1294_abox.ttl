@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:GAPGAIN a ex:Parametro ;
    rdfs:label "GAPGAIN" ;
    ex:textoExtracto "Ganancia proporcional aplicada a la señal del sensor, en posición. Para utilizar valores mayores de 0.2 (cercanos a 1) se recomienda utilizar el parámetro GAPSENSORFILTER." ;
    ex:valor "0.2" .

ex:GAPSENSORFILTER a ex:Parametro ;
    rdfs:label "GAPSENSORFILTER" ;
    ex:textoExtracto "Filtro paso bajo; se recomienda definir un filtro de orden 2 y frecuencia de corte de 30 Hz." .

ex:GAPAPPROACHDYN a ex:Parametro ;
    rdfs:label "GAPAPPROACHDYN" ;
    ex:textoExtracto "Respuesta dinámica durante la parte final del movimiento de aproximación a la chapa." .

ex:ORDER a ex:Parametro ;
    rdfs:label "ORDER" ;
    ex:textoExtracto "Orden del filtro." .

ex:FREQUENCY a ex:Parametro ;
    rdfs:label "FREQUENCY" ;
    ex:textoExtracto "Frecuencia de corte." .

ex:GAPCONTROL a ex:Sistema ;
    rdfs:label "GAPCONTROL" ;
    ex:textoExtracto "GAPCONTROL" .

ex:SensorPosicion a ex:Sensor ;
    rdfs:label "Sensor de posición" ;
    ex:textoExtracto "(V.)G.GAP Valor real del gap, detectado por el sensor." .

ex:CompensacionGap a ex:Parametro ;
    rdfs:label "Compensación del gap" ;
    ex:textoExtracto "(V.)A.GAPCOMP.Z Compensación que introduce el control del gap en el eje asociado al sensor para mantener el gap." .

ex:GAPCONTROL ex:compuestoPor ex:GAPGAIN, ex:GAPSENSORFILTER, ex:GAPAPPROACHDYN, ex:ORDER, ex:FREQUENCY, ex:SensorPosicion, ex:CompensacionGap ;
    ex:textoExtracto "Ajustar el lazo de posición del sensor." .