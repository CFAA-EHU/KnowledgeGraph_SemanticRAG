@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_GAPGAIN
    a ex:Parametro ;
    rdfs:label "GAPGAIN" ;
    ex:textoExtracto "Ganancia proporcional aplicada a la señal del sensor, en posición. Para utilizar valores mayores de 0.2 (cercanos a 1) se recomienda utilizar el parámetro GAPSENSORFILTER." ;
    ex:valor "0.2"^^xsd:float .

ex:Parametro_GAPSENSORFILTER
    a ex:Parametro ;
    rdfs:label "GAPSENSORFILTER" ;
    ex:textoExtracto "Filtro paso bajo; se recomienda definir un filtro de orden 2 y frecuencia de corte de 30 Hz." ;
    ex:identificador "GAPSENSORFILTER" .

ex:Parametro_GAPAPPROACHDYN
    a ex:Parametro ;
    rdfs:label "GAPAPPROACHDYN" ;
    ex:textoExtracto "Respuesta dinámica durante la parte final del movimiento de aproximación a la chapa." ;
    ex:identificador "GAPAPPROACHDYN" .

ex:Parametro_ORDER
    a ex:Parametro ;
    rdfs:label "ORDER" ;
    ex:textoExtracto "Orden del filtro." ;
    ex:identificador "ORDER" ;
    ex:valor "2"^^xsd:integer .

ex:Parametro_FREQUENCY
    a ex:Parametro ;
    rdfs:label "FREQUENCY" ;
    ex:textoExtracto "Frecuencia de corte." ;
    ex:identificador "FREQUENCY" ;
    ex:valor "30"^^xsd:integer .

ex:Sensor_GAP
    a ex:Sensor ;
    rdfs:label "Sensor de posición del gap" ;
    ex:textoExtracto "Valor real del gap, detectado por el sensor (V.)G.GAP." ;
    ex:monitoreaParametro ex:Parametro_GAPGAIN .

ex:Tabla_ParametrosGapControl a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros GAPCONTROL" ;
    ex:textoExtracto "GAPCONTROL | GAPGAIN | Ganancia proporcional aplicada a la señal del sensor, en posición. [...] FREQUENCY | Frecuencia de corte." ;
    ex:documentadoEn ex:Pagina_700 ;
    ex:detalladoEnEsquema ex:Sensor_GAP .

ex:Pagina_700
    a ex:Pagina ;
    rdfs:label "Página 700 - Ajuste del lazo de posición del sensor" ;
    ex:identificador "700" ;
    ex:textoExtracto "GAP SENSOR POSITION FEEDBACK LOOP GAP P-GAIN V.G.GAP CUTOF FILTER Ajuste con ayuda del osciloscopio." .