@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefineSiElCNCLimitaElAvanceEnFuncionDelSuministroDeBloques a ns1:Parametro ;
    rdfs:label "Define si el CNC limita el avance en función del suministro de bloques" ;
    ns1:identificador "FEEDAVRG" ;
    ns1:textoExtracto "Para analizar correctamente este aspecto, hay que definir el parámetro FEEDAVRG con valor 'No', para evitar que el CNC limite el avance en función del suministro de bloques." .

ns1:IndicaSiElCNCPodriaAumentarElAvanceSiTuvieraMasBloques a ns1:Parametro ;
    rdfs:label "Indica si el CNC podría aumentar el avance si tuviera más bloques" ;
    ns1:identificador "V.G.DROPRATE" ;
    ns1:textoExtracto "Un valor menor que 100 indica que el CNC podría aumentar el avance si tuviera más bloques." .

ns1:IndicaSiElCNCPuedeTratarMasBloques a ns1:Parametro ;
    rdfs:label "Indica si el CNC puede tratar más bloques" ;
    ns1:identificador "V.G.PERFRATE" ;
    ns1:textoExtracto "Un valor menor que 100 indica que el CNC puede tratar más bloques." .

ns1:PorcentajeDeTiempoDeCicloQueUtilizaElCNC a ns1:Parametro ;
    rdfs:label "Porcentaje de tiempo de ciclo que utiliza el CNC" ;
    ns1:identificador "V.G.NCTIMERATE" ;
    ns1:textoExtracto "Esta información se puede consultar con la siguiente variable. V.G.NCTIMERATE Con un valor menor que 50, se puede aumentar el parámetro PREPFREQ." .

ns1:PorcentajeDelTiempoDeCicloQueUtilizaElCanalParaLaPreparacionDeBloques_17235d3153 a ns1:Parametro ;
    rdfs:label "Porcentaje del tiempo de ciclo que utiliza el canal para la preparación de bloques" ;
    ns1:identificador "V.G.PREPTIMERATE" ;
    ns1:textoExtracto "V.G.PREPTIMERATE | Porcentaje del tiempo de ciclo que utiliza el canal para la preparación de bloques." .

ns1:PorcentajeDelTiempoDeCicloQueUtilizaElInterpoladorDelCanal_91fbcab8b2 a ns1:Parametro ;
    rdfs:label "Porcentaje del tiempo de ciclo que utiliza el interpolador del canal" ;
    ns1:identificador "V.G.IPOTIMERATE" ;
    ns1:textoExtracto "V.G.IPOTIMERATE | Porcentaje del tiempo de ciclo que utiliza el interpolador del canal." .

