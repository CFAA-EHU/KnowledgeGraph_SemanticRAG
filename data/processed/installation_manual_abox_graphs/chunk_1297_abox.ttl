@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceleracionDebidaALaCurvatura a ns1:Parametro ;
    rdfs:label "Aceleración debida a la curvatura" ;
    ns1:identificador "CURVACC" ;
    ns1:textoExtracto "La aceleración debida a la curvatura (parámetro CURVACC)." .

ns1:AceleracionEnLaEsquina a ns1:Parametro ;
    rdfs:label "Aceleración en la esquina" ;
    ns1:identificador "CORNERACC" ;
    ns1:textoExtracto "La aceleración en la esquina (parámetro CORNERACC)." .

ns1:JerkDebidoALaCurvatura a ns1:Parametro ;
    rdfs:label "Jerk debido a la curvatura" ;
    ns1:identificador "CURVJERK" ;
    ns1:textoExtracto "El jerk debido a la curvatura (parámetro CURVJERK)." .

ns1:JerkEnLaEsquina a ns1:Parametro ;
    rdfs:label "Jerk en la esquina" ;
    ns1:identificador "CORNERJERK" ;
    ns1:textoExtracto "El jerk en la esquina (parámetro CORNERJERK)." .

ns1:VariableVG_AXLIMC a ns1:Parametro ;
    rdfs:label "Eje que limita el avance en las esquinas" ;
    ns1:identificador "V.G.AXLIMC" ;
    ns1:textoExtracto "Consultar la variable V.G.AXLIMC para conocer cuál es el eje que está limitando el avance." .

ns1:VariableVG_LIMERROR a ns1:Parametro ;
    rdfs:label "Error que comete el spline" ;
    ns1:identificador "V.G.LIMERROR" ;
    ns1:textoExtracto "Consultar la variable V.G.LIMERROR para conocer el valor del error que desactiva los splines." .

ns1:VariableVG_PARLIMC a ns1:Parametro ;
    rdfs:label "Causa por la que un eje limita el avance en las esquinas" ;
    ns1:identificador "V.G.PARLIMC" ;
    ns1:textoExtracto "Consultar la variable V.G.PARLIMC para conocer la causa por la que este eje está limitando el avance." .

