@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SensorGAP_1299 a ex:Sensor ;
    rdfs:label "sensor" ;
    ex:textoExtracto "(V.)G.GAP Valor real del gap, detectado por el sensor." .

ex:EjeZ_1299 a ex:Sensor ;
    rdfs:label "Eje Z" ;
    ex:textoExtracto "(V.)A.POS.Z Eje Z. Cotas máquina reales del sensor." .

ex:EjeX_1299 a ex:Sensor ;
    rdfs:label "Eje X" ;
    ex:textoExtracto "(V.)A.POS.X Eje X. Cotas máquina reales." .

ex:CompensacionGapZ_1299 a ex:Sensor ;
    rdfs:label "Compensación que introduce el control del gap en el eje asociado al sensor para mantener el gap" ;
    ex:textoExtracto "(V.)A.GAPCOMP.Z Compensación que introduce el control del gap en el eje asociado al sensor para mantener el gap." .