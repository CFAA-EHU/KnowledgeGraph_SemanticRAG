@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaCompensacionVolumetrica a ns1:Tabla ;
    rdfs:label "Tabla VOLCOMP" ;
    ns1:textoExtracto "Parámetro incluido en la tabla VOLCOMP." ;
    ns1:tieneComponente ns1:VariableAsociadaAlEje1ParaCompensacionVolumetrica,
        ns1:VariableAsociadaAlEje2ParaCompensacionVolumetrica,
        ns1:VariableAsociadaAlEje3ParaCompensacionVolumetrica .

ns1:VariableAsociadaAlEje1ParaCompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Variable asociada al eje 1 para compensación volumétrica" ;
    ns1:identificador "MPG.VCOMPAXIS1" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.VCOMPAXIS1[tbl]" .

ns1:VariableAsociadaAlEje2ParaCompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Variable asociada al eje 2 para compensación volumétrica" ;
    ns1:identificador "MPG.VCOMPAXIS2" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.VCOMPAXIS2[tbl]" .

ns1:VariableAsociadaAlEje3ParaCompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Variable asociada al eje 3 para compensación volumétrica" ;
    ns1:identificador "MPG.VCOMPAXIS3" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.VCOMPAXIS3[tbl]" .

