@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:DFU a ex:Parametro ;
    ex:textoExtracto "DFU {conditions} AND NOT M666 AND NOT INCYCLE = RES ENABLEGAP = RES ENABLELEAP = SET IRESETZ = TG1 333 12 ; Tiempo de espera, 12 milisegundos." .

ex:M666 a ex:Parametro ;
    ex:textoExtracto "NOT M666" .

ex:INCYCLE a ex:Parametro ;
    ex:textoExtracto "NOT INCYCLE" .

ex:ENABLEGAP a ex:Parametro ;
    ex:textoExtracto "ENABLEGAP = RES" .

ex:ENABLELEAP a ex:Parametro ;
    ex:textoExtracto "ENABLELEAP = SET" .

ex:IRESETZ a ex:Parametro ;
    ex:textoExtracto "IRESETZ = TG1" .

ex:T333 a ex:Parametro ;
    ex:textoExtracto "T333 = M666" .

ex:B10KEYLED1 a ex:Sensor ;
    ex:textoExtracto "B10KEYLED1 = SET" .

ex:TiempoEspera_12ms a ex:Parametro ;
    ex:identificador "12" ;
    ex:valor "12" ;
    ex:textoExtracto "Tiempo de espera, 12 milisegundos." .

ex:MOVE_ABS_Z a ex:AccionProhibida ;
    ex:textoExtracto "MOVE ABS (Z, 513000,50000000,NULL)" .