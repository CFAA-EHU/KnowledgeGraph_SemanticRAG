@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TDATA1 a ex:Parametro ;
    rdfs:label "TDATA1" ;
    ex:textoExtracto "TDATA1 Indica la distancia entre la nariz del mandrino y el eje rotativo secundario, según el eje Z." ;
    ex:valor "positivo o negativo" .

ex:TDATA2 a ex:Parametro ;
    rdfs:label "TDATA2" ;
    ex:textoExtracto "TDATA2 Indica la distancia entre el eje rotativo secundario y el principal según el eje X." ;
    ex:valor "positivo o negativo" .

ex:TDATA3 a ex:Parametro ;
    rdfs:label "TDATA3" ;
    ex:textoExtracto "TDATA3 Indica la distancia entre el eje rotativo secundario y el principal según el eje Y." ;
    ex:valor "positivo o negativo" .

ex:TDATA5 a ex:Parametro ;
    rdfs:label "TDATA5" ;
    ex:textoExtracto "TDATA5 Indica la distancia entre el eje de la herramienta y el eje rotativo secundario según el eje X." ;
    ex:valor "positivo o negativo" .

ex:TDATA6 a ex:Parametro ;
    rdfs:label "TDATA6" ;
    ex:textoExtracto "TDATA6 Indica la distancia entre el eje de la herramienta y el eje rotativo secundario según el eje Y." ;
    ex:valor "positivo o negativo" .

ex:TDATA7 a ex:Parametro ;
    rdfs:label "TDATA7" ;
    ex:textoExtracto "TDATA7 Indica el ángulo entre los ejes rotativos principal y secundario, en los cabezales rotativos (en este caso TDATA7 = 45)." ;
    ex:valor "45" .

ex:CabezalAngularYZ a ex:Maquina ;
    rdfs:label "Cabezal angular YZ (TYPE=6)" ;
    ex:textoExtracto "Dimensiones a calcular en un cabezal angular YZ (TYPE=6). En este tipo de cinemática hay que definir las siguientes dimensiones. Todos los parámetros se pueden definir con valor positivo o negativo. El signo (+) en las figuras indica el sentido que se asume como positivo." .