@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA1
    a ex:Parametro ;
    rdfs:label "TDATA1" ;
    ex:identificador "TDATA1" ;
    ex:textoExtracto "TDATA1 Indica la distancia entre la nariz del mandrino y el eje rotativo secundario, según el eje Z." ;
    ex:valor "DATA 1(+)" .

ex:Parametro_TDATA2
    a ex:Parametro ;
    rdfs:label "TDATA2" ;
    ex:identificador "TDATA2" ;
    ex:textoExtracto "TDATA2 Indica la distancia entre el eje rotativo secundario y el principal según el eje X." ;
    ex:valor "DATA 2(-)" .

ex:Parametro_TDATA3
    a ex:Parametro ;
    rdfs:label "TDATA3" ;
    ex:identificador "TDATA3" ;
    ex:textoExtracto "TDATA3 Indica la distancia entre el eje rotativo secundario y el principal según el eje Y." ;
    ex:valor "DATA 3(+)" .

ex:Parametro_TDATA5
    a ex:Parametro ;
    rdfs:label "TDATA5" ;
    ex:identificador "TDATA5" ;
    ex:textoExtracto "TDATA5 Indica la distancia entre el eje de la herramienta y el eje rotativo secundario según el eje X." .

ex:Parametro_TDATA6
    a ex:Parametro ;
    rdfs:label "TDATA6" ;
    ex:identificador "TDATA6" ;
    ex:textoExtracto "TDATA6 Indica la distancia entre el eje de la herramienta y el eje rotativo secundario según el eje Y." ;
    ex:valor "DATA 6" .

ex:Parametro_TDATA7
    a ex:Parametro ;
    rdfs:label "TDATA7" ;
    ex:identificador "TDATA7" ;
    ex:textoExtracto "TDATA7 Indica el ángulo entre los ejes rotativos principal y secundario, en los cabezales rotativos (en este caso TDATA7 = 45)." ;
    ex:valor "45" .

ex:CabezalAngular_TYPE6
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal angular TYPE=6" ;
    ex:identificador "TYPE=6" ;
    ex:textoExtracto "Dimensiones a calcular en un cabezal angular YZ (TYPE=6)." ;
    ex:tieneComponente ex:Parametro_TDATA1, ex:Parametro_TDATA2, ex:Parametro_TDATA3, ex:Parametro_TDATA5, ex:Parametro_TDATA6, ex:Parametro_TDATA7 .

ex:Figura_DimensionesCabezalAngular
    a ex:Figura ;
    rdfs:label "Figura de dimensiones del cabezal angular TYPE=6" ;
    ex:textoExtracto "El signo (+) en las figuras indica el sentido que se asume como positivo." ;
    ex:ilustradoEn ex:CabezalAngular_TYPE6 .