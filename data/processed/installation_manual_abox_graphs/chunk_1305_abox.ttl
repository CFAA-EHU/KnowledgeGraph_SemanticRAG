@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TDATA1 a ex:Parametro ;
    ex:identificador "TDATA1" ;
    ex:textoExtracto "TDATA1 = Z +R–L" ;
    ex:valor "Z +R–L" .

ex:TDATA5 a ex:Parametro ;
    ex:identificador "TDATA5" ;
    ex:textoExtracto "TDATA5 = 05 Z" ;
    ex:valor "05 Z" .

ex:TDATA6 a ex:Parametro ;
    ex:identificador "TDATA6" ;
    ex:textoExtracto "Cálculo del parámetro TDATA6" ;
    ex:valor "Dimensión a calcular menos el diámetro de la bola del palpador" .

ex:DeltaZ a ex:Parametro ;
    ex:identificador "Z" ;
    ex:textoExtracto "Cota que indica el CNC" .

ex:DeltaX a ex:Parametro ;
    ex:identificador "X" ;
    ex:textoExtracto "Cota que indica el CNC" .

ex:LongitudPalpador a ex:Parametro ;
    ex:identificador "L" ;
    ex:textoExtracto "Longitud del palpador" .

ex:RadioBolaPalpador a ex:Parametro ;
    ex:identificador "R" ;
    ex:textoExtracto "Radio de la bola del palpador" .

ex:PuntoReferenciaHerramientas a ex:Parametro ;
    ex:identificador "OT" ;
    ex:textoExtracto "Punto de referencia de las herramientas" .

ex:EsquemaCálculoDimensiones a ex:Esquema ;
    ex:textoExtracto "Cálculo de las dimensiones con ayuda de un cabezal angular" ;
    ex:compuestoPor ex:TDATA1, ex:TDATA5, ex:TDATA6, ex:DeltaZ, ex:DeltaX, ex:LongitudPalpador, ex:RadioBolaPalpador, ex:PuntoReferenciaHerramientas .