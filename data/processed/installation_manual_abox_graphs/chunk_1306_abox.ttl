@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ProcesoCalibracionCabezalAngular_17_1
    a                     ex:TareaMantenimiento ;
    rdfs:label             "Proceso de calibración del cabezal angular (17.1)" ;
    ex:textoExtracto       "B=0º C=0º Z X X=D+2R Segunda palpación. Con el eje rotativo C posicionado en 0º y B en -90º realizar un movimiento de palpación sobre X'. la primera cara X. Anotar la cota que aparece en el CNC, denominada en el dibujo  Tercera palpación. Con el eje rotativo C posicionado en 0º y B en 90º realizar un movimiento de palpación sobre X. la segunda cara X. Anotar la cota que aparece en el CNC, denominada en el dibujo  B=-90º B=90º C=0º C=0º 2 1 2 1 Z X Cálculos matemáticos. Con el cambio de posición respecto al centro de giro ꞏ1ꞏ, el único dato desconocido tras ambos palpaciones es TDATA6. B=0º 1 C=0º TDATA6 cos45 . 2 B=-90º B=90º R C=0º C=0º 2 1 2 1 L D Z TDATA1 TDATA6 cos45 . X" ;
    ex:identificador       "17.1" ;
    ex:requiereMantenimiento ex:SistemaCNC_17_1 .

ex:SistemaCNC_17_1
    a                     ex:Sistema ;
    rdfs:label             "Sistema CNC para cabezal angular" ;
    ex:textoExtracto       "Anotar la cota que aparece en el CNC, denominada en el dibujo " ;
    ex:monitoreaParametro  ex:ParametroTDATA6_17_1 ,
                           ex:ParametroTDATA1_17_1 ,
                           ex:ParametroDeltaX_17_1 .

ex:ParametroTDATA6_17_1
    a                     ex:Parametro ;
    rdfs:label             "TDATA6" ;
    ex:textoExtracto       "el único dato desconocido tras ambos palpaciones es TDATA6" ;
    ex:valor               "TDATA6 cos45" .

ex:ParametroTDATA1_17_1
    a                     ex:Parametro ;
    rdfs:label             "TDATA1" ;
    ex:textoExtracto       "TDATA1" ;
    ex:valor               "TDATA1" .

ex:ParametroDeltaX_17_1
    a                     ex:Parametro ;
    rdfs:label             "Δ (Delta X)" ;
    ex:textoExtracto       "denominada en el dibujo " .