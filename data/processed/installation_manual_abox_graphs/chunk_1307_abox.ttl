@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA1
    a ex:Parametro ;
    rdfs:label "TDATA1" ;
    ex:textoExtracto "TDATA1 | Dimensión conocida." ;
    ex:identificador "TDATA1" .

ex:Parametro_TDATA2
    a ex:Parametro ;
    rdfs:label "TDATA2" ;
    ex:textoExtracto "TDATA2 = 0,5·ΔZ – TDATA5", "TDATA2 | Dimensión a calcular." ;
    ex:identificador "TDATA2" .

ex:Parametro_TDATA5
    a ex:Parametro ;
    rdfs:label "TDATA5" ;
    ex:textoExtracto "TDATA5 | Dimensión conocida." ;
    ex:identificador "TDATA5" .

ex:Parametro_TDATA6
    a ex:Parametro ;
    rdfs:label "TDATA6" ;
    ex:textoExtracto "TDATA6 = (ΔX + ΔX' – D – 2L – 2TDATA1) / (2·cos45)", "TDATA6 | Dimensión a calcular." ;
    ex:identificador "TDATA6" .

ex:Parametro_D
    a ex:Parametro ;
    rdfs:label "D (Longitud de la pieza)" ;
    ex:textoExtracto "D | Longitud de la pieza." ;
    ex:identificador "D" .

ex:Parametro_DeltaX
    a ex:Parametro ;
    rdfs:label "ΔX" ;
    ex:textoExtracto "ΔX | Cotas que indica el CNC." ;
    ex:identificador "DeltaX" .

ex:Parametro_DeltaX_prime
    a ex:Parametro ;
    rdfs:label "ΔX'" ;
    ex:textoExtracto "ΔX' | Cotas que indica el CNC." ;
    ex:identificador "DeltaX_prime" .

ex:Parametro_DeltaZ
    a ex:Parametro ;
    rdfs:label "ΔZ" ;
    ex:textoExtracto "ΔZ | Cota que indica el CNC." ;
    ex:identificador "DeltaZ" .

ex:Parametro_L
    a ex:Parametro ;
    rdfs:label "L (Longitud del palpador)" ;
    ex:textoExtracto "L | Longitud del palpador." ;
    ex:identificador "L" .

ex:Parametro_R
    a ex:Parametro ;
    rdfs:label "R (Radio de la bola del palpador)" ;
    ex:textoExtracto "R | Radio de la bola del palpador." ;
    ex:identificador "R" .

ex:Tabla_CalculoTDATA6 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Fórmula de cálculo para TDATA6" ;
    ex:textoExtracto "TDATA6 = (ΔX + ΔX' – D – 2L – 2TDATA1) / (2·cos45)" ;
    ex:ilustradoEn ex:Parametro_TDATA6 .

ex:Tabla_CalculoTDATA2 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Fórmula de cálculo para TDATA2" ;
    ex:textoExtracto "TDATA2 = 0,5·ΔZ – TDATA5" ;
    ex:ilustradoEn ex:Parametro_TDATA2 .