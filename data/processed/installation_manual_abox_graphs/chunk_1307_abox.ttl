@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TDATA1 a ex:Parametro ;
    rdfs:label "TDATA1" ;
    ex:identificador "TDATA1" ;
    ex:textoExtracto "Dimensión conocida." .

ex:TDATA6 a ex:Parametro ;
    rdfs:label "TDATA6" ;
    ex:identificador "TDATA6" ;
    ex:textoExtracto "Dimensión a calcular." .

ex:TDATA2 a ex:Parametro ;
    rdfs:label "TDATA2" ;
    ex:identificador "TDATA2" ;
    ex:textoExtracto "Dimensión a calcular." .

ex:TDATA5 a ex:Parametro ;
    rdfs:label "TDATA5" ;
    ex:identificador "TDATA5" ;
    ex:textoExtracto "Dimensión conocida." .

ex:Parametro_CNC a ex:Sistema ;
    ex:textoExtracto "Con el eje rotativo C posicionado en 0º y el eje B en 90º realizar un movimiento de palpación sobre la cara Z y preseleccionar la cota Z=0. B=90º C=0º" ;
    ex:tieneComponente ex:EjeB_90, ex:EjeC_0, ex:MovimientoPalpacion_Z .

ex:EjeB_90 a ex:Parametro ;
    rdfs:label "B=90º" ;
    ex:textoExtracto "eje B en 90º" .

ex:EjeC_0 a ex:Parametro ;
    rdfs:label "C=0º" ;
    ex:textoExtracto "eje rotativo C posicionado en 0º" .

ex:MovimientoPalpacion_Z a ex:AccionProhibida ;
    ex:textoExtracto "realizar un movimiento de palpación sobre la cara Z" .

ex:Parametro_CNC_2 a ex:Sistema ;
    ex:textoExtracto "Con el eje rotativo C posicionado en 0º y el eje B en -90º realizar un movimiento de palpación Z. sobre la cara Z. Anotar la cota que aparece en el CNC, denominada en el dibujo Z" ;
    ex:tieneComponente ex:EjeB_menos90, ex:EjeC_0_2, ex:MovimientoPalpacion_Z_2 .

ex:EjeB_menos90 a ex:Parametro ;
    rdfs:label "B=-90º" ;
    ex:textoExtracto "eje B en -90º" .

ex:EjeC_0_2 a ex:Parametro ;
    rdfs:label "C=0º" ;
    ex:textoExtracto "eje rotativo C posicionado en 0º" .

ex:MovimientoPalpacion_Z_2 a ex:AccionProhibida ;
    ex:textoExtracto "realizar un movimiento de palpación Z. sobre la cara Z" .

ex:DeltaZ a ex:Parametro ;
    rdfs:label "Z" ;
    ex:textoExtracto "cota que indica el CNC" .