@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PreparacionDeBloques_2d5018efad a ns1:TareaMantenimiento ;
    rdfs:label "Preparación de bloques" ;
    ns1:textoExtracto "El CNC comprueba si está cargada en memoria RAM, y si no lo está y hay espacio, la carga." .

ns1:SubrutinaFSTOEM a ns1:ComponenteElectrico ;
    rdfs:label "Subrutina FST OEM" ;
    ns1:documentadoEn ns1:CNC8070_017ff97a64 ;
    ns1:textoExtracto "Subrutinas con extensión fst guardadas en la carpeta ..mtb/sub." .

ns1:SubrutinaFSTUsuario a ns1:ComponenteElectrico ;
    rdfs:label "Subrutina FST de usuario" ;
    ns1:documentadoEn ns1:CNC8070_017ff97a64 ;
    ns1:textoExtracto "Subrutinas con extensión fst que no están guardadas en la carpeta ..mtb/sub." .

ns1:CNC8070_017ff97a64 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:ManualBrochadoraA218 ;
    ns1:textoExtracto "Para cargar una subrutina en la memoria RAM, está debe tener extensión fst." ;
    ns1:tieneComponente ns1:SubrutinaFSTOEM,
        ns1:SubrutinaFSTUsuario .

