@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:RelojComparador1 a ex:Sensor ;
    rdfs:label "reloj comparador" ;
    ex:textoExtracto "reloj comparador" .

ex:CabezalAngularYZ45_1 a ex:ComponenteMecanico ;
    rdfs:label "cabezal angular YZ de 45º" ;
    ex:identificador "TYPE=6" ;
    ex:textoExtracto "cabezal angular YZ de 45º (el mismo que el del ejemplo anterior), parámetro TYPE con valor ꞏ6ꞏ" .

ex:CilindroConocido1 a ex:ComponenteMecanico ;
    rdfs:label "cilindro de diámetro conocido" ;
    ex:textoExtracto "cilindro de diámetro conocido" .

ex:EjeY1 a ex:ComponenteMecanico ;
    rdfs:label "eje Y" ;
    ex:textoExtracto "eje Y" .

ex:EjeZ1 a ex:ComponenteMecanico ;
    rdfs:label "eje Z" ;
    ex:textoExtracto "eje Z" .

ex:Mesa1 a ex:ComponenteMecanico ;
    rdfs:label "mesa" ;
    ex:textoExtracto "mesa" .

ex:RelojComparador1 ex:monitoreaParametro ex:CabezalAngularYZ45_1 ;
    ex:textoExtracto "En el siguiente ejemplo se utiliza un reloj comparador y un cilindro de diámetro conocido colocado en el cabezal." .

ex:RelojComparador1 ex:compuestoPor ex:EjeY1 ;
    ex:textoExtracto "Colocar el reloj sobre la mesa, en la dirección del eje Y." .

ex:RelojComparador1 ex:compuestoPor ex:EjeZ1 ;
    ex:textoExtracto "Desplazar la mesa en el eje Y hasta que el reloj y el cilindro se toquen en el punto 1." .

ex:RelojComparador1 ex:compuestoPor ex:Mesa1 ;
    ex:textoExtracto "Posicionar los ejes rotativos B y C en 0º." .