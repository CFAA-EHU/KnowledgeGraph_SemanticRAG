@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Reloj_1309_1 a ex:Sensor ;
    rdfs:label "Reloj" ;
    ex:textoExtracto "Preseleccionar Y=R, para que Y=0 coincida con el eje del cilindro colocado en el cabezal." ;
    ex:identificador "1" .

ex:EjeRotativo_1309_1 a ex:ComponenteMecanico ;
    rdfs:label "Eje rotativo" ;
    ex:textoExtracto "posicionar el eje rotativo C en 180º" ;
    ex:identificador "C" .

ex:PuntoMedicion_1309_2 a ex:ComponenteMecanico ;
    rdfs:label "Punto de medición 2" ;
    ex:textoExtracto "Tocar con el reloj en el punto 2." ;
    ex:identificador "2" .

ex:SistemaCNC_1309_1 a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "Apuntar la cota que aparece en el CNC (Y)" .