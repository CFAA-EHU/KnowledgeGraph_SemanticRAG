@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArchivoConLosDatosDeLaCompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Archivo con los datos de la compensación volumétrica" ;
    ns1:identificador "MPG.VCOMPFILE" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.VCOMPFILE[tbl] Parámetro incluido en la tabla VOLCOMP." .

ns1:CNC8070_fe731ff1fd a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC aplica la compensación también al eje esclavo." .

ns1:UnidadesDeMedidaPulgadasOMilimetros a ns1:Parametro ;
    rdfs:label "Unidades de medida (pulgadas o milímetros)" ;
    ns1:identificador "INCHES" ;
    ns1:textoExtracto "Las unidades de los datos del archivo (milímetros o pulgadas) deben ser las definidas en el CNC (parámetro INCHES)." .

