@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TDATA1 a ex:Parametro ;
    rdfs:label "TDATA1" ;
    ex:identificador "TDATA1" ;
    ex:textoExtracto "TDATA1 = Y" ;
    ex:valor "Y" .

ex:TDATA5 a ex:Parametro ;
    rdfs:label "TDATA5" ;
    ex:identificador "TDATA5" ;
    ex:textoExtracto "TDATA5 = 0,5 X" ;
    ex:valor "0,5 X" .

ex:TDATA2 a ex:Parametro ;
    rdfs:label "TDATA2" ;
    ex:identificador "TDATA2" ;
    ex:textoExtracto "TDATA2" ;
    ex:valor "X" .