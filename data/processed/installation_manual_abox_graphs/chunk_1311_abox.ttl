@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TDATA1 a ex:Parametro ;
    rdfs:label "TDATA1" ;
    ex:textoExtracto "TDATA1 | Dimensión a calcular." ;
    ex:identificador "TDATA1" .

ex:TDATA5 a ex:Parametro ;
    rdfs:label "TDATA5" ;
    ex:textoExtracto "TDATA5 | Dimensión a calcular." ;
    ex:identificador "TDATA5" .

ex:TDATA6 a ex:Parametro ;
    rdfs:label "TDATA6" ;
    ex:textoExtracto "TDATA6 = 2·(X – TDATA1)" ;
    ex:identificador "TDATA6" .

ex:DeltaX a ex:Parametro ;
    rdfs:label "ΔX" ;
    ex:textoExtracto "ΔX | Cota que indica el CNC." ;
    ex:identificador "ΔX" .

ex:Reloj a ex:Sensor ;
    rdfs:label "reloj" ;
    ex:textoExtracto "reloj" .

ex:EjeX a ex:ComponenteMecanico ;
    rdfs:label "eje X" ;
    ex:textoExtracto "eje X" .

ex:EjeB a ex:ComponenteMecanico ;
    rdfs:label "eje rotativo B" ;
    ex:textoExtracto "ejes rotativos B" .

ex:EjeC a ex:ComponenteMecanico ;
    rdfs:label "eje rotativo C" ;
    ex:textoExtracto "ejes rotativos C" .

ex:CabezalAngular a ex:ComponenteMecanico ;
    rdfs:label "cabezal angular" ;
    ex:textoExtracto "cabezal angular" .

ex:CNC a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "CNC" .