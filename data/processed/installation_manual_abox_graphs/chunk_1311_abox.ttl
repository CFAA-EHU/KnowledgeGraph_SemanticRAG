@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BloqueUnico a ns1:AccionProhibida ;
    rdfs:label "Bloque único" ;
    ns1:textoExtracto "el CNC ejecuta la subrutina como un bloque único; es decir, no le afecta la ejecución bloque a bloque." .

ns1:CNC8070_36eccb7420 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC tampoco llama a la subrutina al ejecutar un ciclo desde el modo conversacional." .

ns1:EjecucionDeLaSubrutina a ns1:TareaMantenimiento ;
    rdfs:label "Ejecución de la subrutina" ;
    ns1:textoExtracto "Durante la ejecución, el CNC muestra en la barra general de estado el nombre de la subrutina." .

ns1:SubrutinaStart a ns1:AccionProhibida ;
    rdfs:label "Subrutina asociada al start" ;
    ns1:textoExtracto "En cada canal, el start de ejecución puede tener asociada una subrutina, que se ejecuta al pulsar la tecla [START]." .

