@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_2fdde6ef6e a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC admite los dos nombres para la subrutina asociada al primer canal; si existen ambas subrutinas, el CNC ejecuta PROGRAM_START." .

ns1:SubrutinaProgramStart a ns1:ComponenteElectrico ;
    rdfs:label "PROGRAM_START" ;
    ns1:textoExtracto "El nombre de la subrutina debe ser PROGRAM_START (sin extensión) y estará guardada en la carpeta ..\\Users\\Sub." .

ns1:SubrutinaProgramStartC1 a ns1:ComponenteElectrico ;
    rdfs:label "PROGRAM_START_C1" ;
    ns1:textoExtracto "PROGRAM_START_C1 | Canal 1. El CNC admite los dos nombres para la subrutina asociada al primer canal; si existen ambas subrutinas, el CNC ejecuta PROGRAM_START." .

ns1:SubrutinaProgramStartC2 a ns1:ComponenteElectrico ;
    rdfs:label "PROGRAM_START_C2" ;
    ns1:textoExtracto "PROGRAM_START_C2 | Canal 2." .

ns1:SubrutinaProgramStartC3 a ns1:ComponenteElectrico ;
    rdfs:label "PROGRAM_START_C3" ;
    ns1:textoExtracto "PROGRAM_START_C3 | Canal 3." .

ns1:SubrutinaProgramStartC4 a ns1:ComponenteElectrico ;
    rdfs:label "PROGRAM_START_C4" ;
    ns1:textoExtracto "PROGRAM_START_C4 | Canal 4." .

