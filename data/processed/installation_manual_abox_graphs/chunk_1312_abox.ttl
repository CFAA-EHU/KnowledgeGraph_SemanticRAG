@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TDATA5 a ex:Parametro ;
    ex:textoExtracto "TDATA5 | Dimensión a calcular." ;
    rdfs:label "TDATA5" .

ex:TDATA6 a ex:Parametro ;
    ex:textoExtracto "TDATA6 = 2(X – TDATA1)" ;
    rdfs:label "TDATA6" .

ex:TDATA1 a ex:Parametro ;
    ex:textoExtracto "TDATA1" ;
    rdfs:label "TDATA1" .

ex:X a ex:Parametro ;
    ex:textoExtracto "X = 0,5(X + X)" ;
    rdfs:label "X" .

ex:DeltaX a ex:Parametro ;
    ex:textoExtracto "X | Cota que indica el CNC." ;
    rdfs:label "X" .