ns1:CNC8070_c682cacc51 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:ejecuta ns1:EjecucionDeSubrutinaAsociadaAlReset ;
    ns1:textoExtracto "El CNC ejecuta inmediatamente después del reset la subrutina asociada." .

ns1:EjecucionDeSubrutinaAsociadaAlReset a ns1:TareaMantenimiento ;
    rdfs:label "Ejecución de Subrutina Asociada al Reset" ;
    ns1:textoExtracto "Esta subrutina permite, por ejemplo, poner unas condiciones iniciales diferentes de las que fija el reset o condicionadas a la configuración de la máquina." .

