@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TDATA3 a ex:Parametro ;
    rdfs:label "TDATA3" ;
    ex:textoExtracto "La coordenada en el eje Y es el parámetro TDATA3" ;
    ex:valor "TDATA3" .

ex:EjeA a ex:ComponenteMecanico ;
    rdfs:label "eje A" ;
    ex:textoExtracto "el centro del eje A" .

ex:PosicionMesaRotativa1 a ex:ModoOperacion ;
    rdfs:label "posición 1 de la mesa rotativa" ;
    ex:textoExtracto "dos posiciones distintas que tienen en común el centro del eje A" .

ex:PosicionMesaRotativa2 a ex:ModoOperacion ;
    rdfs:label "posición 2 de la mesa rotativa" ;
    ex:textoExtracto "dos posiciones distintas que tienen en común el centro del eje A" .

ex:MesaRotativa a ex:Sistema ;
    rdfs:label "mesa rotativa" ;
    ex:textoExtracto "En el dibujo se muestran dos posiciones distintas que tienen en común el centro del eje A" ;
    ex:compuestoPor ex:EjeA, ex:PosicionMesaRotativa1, ex:PosicionMesaRotativa2 ;
    ex:tieneComponente ex:TDATA3 .