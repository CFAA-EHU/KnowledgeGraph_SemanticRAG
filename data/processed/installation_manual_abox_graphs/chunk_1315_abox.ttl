@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EjeA a ex:ComponenteMecanico ;
    rdfs:label "eje A"@es ;
    ex:textoExtracto "En el dibujo se muestran dos posiciones distintas que tienen en común el centro del eje A."@es .

ex:EjeB a ex:ComponenteMecanico ;
    rdfs:label "eje B"@es ;
    ex:textoExtracto "En el dibujo se muestran dos posiciones distintas que tienen en común el centro del eje A."@es .

ex:ParametroTDATA3 a ex:Parametro ;
    rdfs:label "TDATA3"@es ;
    ex:textoExtracto "la coordenada en el eje Y es el parámetro TDATA3"@es .

ex:ParametroPz a ex:Parametro ;
    rdfs:label "Pz"@es ;
    ex:textoExtracto "la coordenada en el eje Z es Pz"@es .

ex:Punto1 a ex:ComponenteMecanico ;
    rdfs:label "punto 1"@es ;
    ex:textoExtracto "Realizar un movimiento de palpación en la dirección del eje Y, sobre el punto 1."@es .

ex:Punto2 a ex:ComponenteMecanico ;
    rdfs:label "punto 2"@es ;
    ex:textoExtracto "Realizar un movimiento de palpación en la dirección del eje Z, sobre el punto 1."@es .

ex:Punto3 a ex:ComponenteMecanico ;
    rdfs:label "punto 3"@es ;
    ex:textoExtracto "Realizar un movimiento de palpación en la dirección del eje Y, sobre el punto 3."@es .

ex:Punto4 a ex:ComponenteMecanico ;
    rdfs:label "punto 4"@es ;
    ex:textoExtracto "Realizar un movimiento de palpación en la dirección del eje Z, sobre el punto 4."@es .

ex:PosicionPrimera a ex:ModoOperacion ;
    rdfs:label "Primera posición"@es ;
    ex:textoExtracto "Primera posición. 1 Posicionar los ejes rotativos A y B en -90º."@es .

ex:PosicionSegunda a ex:ModoOperacion ;
    rdfs:label "Segunda posición"@es ;
    ex:textoExtracto "Segunda posición. 1 Posicionar el eje rotativo A en 90º y el eje B en -90º."@es .

ex:SistemaMesaRotativa a ex:Sistema ;
    rdfs:label "mesa rotativa"@es ;
    ex:textoExtracto "Cálculo de las coordenadas del eje A. En el dibujo se muestran dos posiciones distintas que tienen en común el centro del eje A."@es ;
    ex:compuestoPor ex:EjeA, ex:EjeB, ex:Punto1, ex:Punto2, ex:Punto3, ex:Punto4 ;
    ex:tieneComponente ex:ParametroTDATA3, ex:ParametroPz .