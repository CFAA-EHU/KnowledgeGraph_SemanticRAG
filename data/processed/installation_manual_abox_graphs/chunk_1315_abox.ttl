@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_2fdde6ef6e a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC admite los dos nombres para la subrutina asociada al primer canal; si existen ambas subrutinas, el CNC ejecuta PROGRAM_RESET." ;
    ns1:tieneComponente ns1:SubrutinaPROGRAMRESETParaCanal1,
        ns1:SubrutinaPROGRAMRESETParaCanal2,
        ns1:SubrutinaPROGRAMRESETParaCanal3,
        ns1:SubrutinaPROGRAMRESETParaCanal4,
        ns1:SubrutinaPROGRAM_RESET .

ns1:TiempoDeFinalizacionDelReset a ns1:Parametro ;
    rdfs:label "Tiempo de finalización del reset" ;
    ns1:textoExtracto "Esta marca permanece activa el tiempo fijado en el parámetro general MINAENDW." .

ns1:SubrutinaPROGRAMRESETParaCanal1 a ns1:ComponenteElectrico ;
    rdfs:label "Subrutina PROGRAM_RESET para Canal 1" ;
    ns1:textoExtracto "PROGRAM_RESET_C1 | Canal 1. El CNC admite los dos nombres para la subrutina asociada al primer canal; si existen ambas subrutinas, el CNC ejecuta PROGRAM_RESET." .

ns1:SubrutinaPROGRAMRESETParaCanal2 a ns1:ComponenteElectrico ;
    rdfs:label "Subrutina PROGRAM_RESET para Canal 2" ;
    ns1:textoExtracto "PROGRAM_RESET_C2 | Canal 2." .

ns1:SubrutinaPROGRAMRESETParaCanal3 a ns1:ComponenteElectrico ;
    rdfs:label "Subrutina PROGRAM_RESET para Canal 3" ;
    ns1:textoExtracto "PROGRAM_RESET_C3 | Canal 3." .

ns1:SubrutinaPROGRAMRESETParaCanal4 a ns1:ComponenteElectrico ;
    rdfs:label "Subrutina PROGRAM_RESET para Canal 4" ;
    ns1:textoExtracto "PROGRAM_RESET_C4 | Canal 4." .

ns1:SubrutinaPROGRAM_RESET a ns1:ComponenteElectrico ;
    rdfs:label "Subrutina PROGRAM_RESET" ;
    ns1:textoExtracto "El nombre de la subrutina debe ser PROGRAM_RESET (sin extensión) y estará guardada en la carpeta ..\\Users\\Sub." .

