@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_ed46874b50 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Para poder ejecutar programas del 8055 MC/TC, en el CNC deben existir dos subrutinas llamadas 9998 y 9999, escritas en lenguaje del 8070." ;
    ns1:tieneComponente ns1:Subrutina9998_30987dad27,
        ns1:Subrutina9999_b5f156daf7 .

ns1:Subrutina9998_30987dad27 a ns1:Componente ;
    rdfs:label "Subrutina 9998" ;
    ns1:textoExtracto "Rutina que ejecutará el CNC al principio de cada programa del 8055-MC y 8055-TC." .

ns1:Subrutina9999_b5f156daf7 a ns1:Componente ;
    rdfs:label "Subrutina 9999" ;
    ns1:textoExtracto "Rutina que ejecutará el CNC al final de cada programa del 8055-MC y 8055-TC." .

