@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TDATA3 a ex:Parametro ;
    rdfs:label "TDATA3" ;
    ex:textoExtracto "TDATA3 = 0,5·(ΔY1 + ΔY2)" ;
    ex:valor "0,5·(ΔY1 + ΔY2)" .

ex:Pz a ex:Parametro ;
    rdfs:label "Pz" ;
    ex:textoExtracto "Pz = 0,5·(ΔZ1 + ΔZ2 –R)" ;
    ex:valor "0,5·(ΔZ1 + ΔZ2 –R)" .

ex:DeltaY1 a ex:Parametro ;
    rdfs:label "ΔY1" ;
    ex:textoExtracto "ΔY1" .

ex:DeltaY2 a ex:Parametro ;
    rdfs:label "ΔY2" ;
    ex:textoExtracto "ΔY2" .

ex:DeltaZ1 a ex:Parametro ;
    rdfs:label "ΔZ1" ;
    ex:textoExtracto "ΔZ1" .

ex:DeltaZ2 a ex:Parametro ;
    rdfs:label "ΔZ2" ;
    ex:textoExtracto "ΔZ2" .

ex:RadioCilindro a ex:Parametro ;
    rdfs:label "R" ;
    ex:textoExtracto "R" .

ex:EjeA a ex:ModoOperacion ;
    rdfs:label "eje A" ;
    ex:textoExtracto "A=90º B=-90º" .

ex:EjeB a ex:ModoOperacion ;
    rdfs:label "eje B" ;
    ex:textoExtracto "B=-90º" .

ex:PosicionAnterior a ex:ModoOperacion ;
    rdfs:label "Posición anterior" ;
    ex:textoExtracto "Mantener la posición anterior, A=90º y B=-90º" .

ex:TDATA5 a ex:Parametro ;
    rdfs:label "TDATA5" ;
    ex:textoExtracto "TDATA5" .

ex:TDATA4 a ex:Parametro ;
    rdfs:label "TDATA4" ;
    ex:textoExtracto "TDATA4" .

ex:TDATA2 a ex:Parametro ;
    rdfs:label "TDATA2" ;
    ex:textoExtracto "TDATA2" .