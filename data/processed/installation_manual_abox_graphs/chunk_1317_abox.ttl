@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DirectorioPorDefectoParaSubrutinasDeUsuarioYProgramas8055MCY8055TC a ns1:Parametro ;
    rdfs:label "Directorio por defecto para subrutinas de usuario y programas 8055-MC y 8055-TC" ;
    ns1:identificador "SUBPATH CHN" ;
    ns1:textoExtracto "Este parámetro indica el directorio por defecto para las subrutinas de usuario y las subrutinas necesarias para poder ejecutar programas del 8055-MC y 8055-TC." .

ns1:Parametro_939e639905 a ns1:Parametro ;
    rdfs:label "Parámetro máquina; general del canal" ;
    ns1:identificador "CHN" ;
    ns1:textoExtracto "[CHN].......Parámetro máquina; general del canal. El nombre de las subrutinas es 9998 y 9999." .

