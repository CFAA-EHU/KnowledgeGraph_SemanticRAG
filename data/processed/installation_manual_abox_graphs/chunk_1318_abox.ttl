@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:DMC_ControlDinamicoMecanizado a ex:Sistema ;
    rdfs:label "DMC (Control Dinámico del Mecanizado)" ;
    ex:textoExtracto "El DMC (control dinámico del mecanizado) adapta el avance durante el mecanizado para mantener la potencia de corte lo más cercana posible a las condiciones idóneas de mecanizado." ;
    ex:identificador "DMC" .

ex:Parametro_DMCSPDL a ex:Parametro ;
    rdfs:label "Parámetro máquina DMCSPDL" ;
    ex:textoExtracto "El cabezal debe estar habilitado para al DMC en el parámetro máquina DMCSPDL." ;
    ex:identificador "DMCSPDL" .

ex:RegulacionDigital_Fagor_V9_01 a ex:ComponenteElectrico ;
    rdfs:label "Regulación digital Fagor (versión V9.01 o superior)" ;
    ex:textoExtracto "con regulación digital Fagor (versión V9.01 o superior)" ;
    ex:identificador "V9.01" .

ex:Herramienta_Fresado a ex:Herramienta ;
    rdfs:label "Herramienta de tipo Fresado" ;
    ex:textoExtracto "Esta función se puede aplicar a operaciones de fresado con herramientas de tipo 'Fresado' y 'Planeado'." .

ex:Herramienta_Planeado a ex:Herramienta ;
    rdfs:label "Herramienta de tipo Planeado" ;
    ex:textoExtracto "Esta función se puede aplicar a operaciones de fresado con herramientas de tipo 'Fresado' y 'Planeado'." .

ex:PotenciaObjetivo a ex:Parametro ;
    rdfs:label "Potencia objetivo" ;
    ex:textoExtracto "La base para la optimización es la potencia de corte a alcanzar, también llamada potencia objetivo." .