@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:MINDMCOVR a ex:Parametro ;
    ex:identificador "MINDMCOVR" ;
    ex:textoExtracto "MINDMCOVR | Mínimo override DMC de todos los ejes del canal." ;
    ex:valor "Mínimo override DMC de todos los ejes del canal" .

ex:MAXDMCOVR a ex:Parametro ;
    ex:identificador "MAXDMCOVR" ;
    ex:textoExtracto "MAXDMCOVR | Máximo override DMC de todos los ejes del canal." ;
    ex:valor "Máximo override DMC de todos los ejes del canal" .

ex:DMC a ex:Sistema ;
    ex:textoExtracto "control dinámico del mecanizado (DMC)" .

ex:MAXOVR a ex:Parametro ;
    ex:identificador "MAXOVR" ;
    ex:textoExtracto "El CNC siempre respeta el límite máximo definido en el parámetro máquina MAXOVR." ;
    ex:valor "límite máximo definido en el parámetro máquina" .

ex:OverrideJOG a ex:Parametro ;
    ex:identificador "OverrideJOG" ;
    ex:textoExtracto "OverrideJOG(%)" ;
    ex:valor "OverrideJOG (%)" .

ex:V_G_PRGFRO a ex:Parametro ;
    ex:identificador "V.G.PRGFRO" ;
    ex:textoExtracto "El porcentaje de avance fijado por programa (variable V.G.PRGFRO)" ;
    ex:valor "porcentaje de avance fijado por programa" .

ex:V_PLC_FRO a ex:Parametro ;
    ex:identificador "V.PLC.FRO" ;
    ex:textoExtracto "o por PLC (variable V.PLC.FRO)" ;
    ex:valor "porcentaje de avance fijado por PLC" .

ex:PanelMando a ex:InterfazUsuario ;
    ex:textoExtracto "conmutador del panel de mando" .

ex:CNC a ex:Sistema ;
    ex:textoExtracto "El CNC siempre respeta el límite máximo definido en el parámetro máquina MAXOVR." .