@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DuracionMinimaDeLaSenalAUXEND a ns1:Parametro ;
    rdfs:label "Duración mínima de la señal AUXEND" ;
    ns1:identificador "MPG.MINAENDW" ;
    ns1:textoExtracto "MINAENDW Duración mínima de la señal AUXEND. Valores posibles: De 0 a 65535 ms. Valor por defecto: 10 ms." .

ns1:TiempoEstimadoParaLaBusquedaDeCero a ns1:Parametro ;
    rdfs:label "Tiempo estimado para la búsqueda de cero" ;
    ns1:identificador "MPG.REFTIME" ;
    ns1:textoExtracto "REFTIME Tiempo estimado para la búsqueda de cero. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0." .

ns1:TiempoEstimadoParaUnaFuncionD a ns1:Parametro ;
    rdfs:label "Tiempo estimado para una función D" ;
    ns1:identificador "MPG.DTIME" ;
    ns1:textoExtracto "DTIME Tiempo estimado para una función D. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0." .

ns1:TiempoEstimadoParaUnaFuncionH a ns1:Parametro ;
    rdfs:label "Tiempo estimado para una función H" ;
    ns1:identificador "MPG.HTIME" ;
    ns1:textoExtracto "HTIME Tiempo estimado para una función H. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0." .

ns1:TiempoEstimadoParaUnaFuncionT a ns1:Parametro ;
    rdfs:label "Tiempo estimado para una función T" ;
    ns1:identificador "MPG.TTIME" ;
    ns1:textoExtracto "TTIME Tiempo estimado para una función T. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0." .

