@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_DMCSPDL a ex:Parametro ;
    rdfs:label "DMCSPDL" ;
    ex:identificador "DMCSPDL" ;
    ex:textoExtracto "Parámetro. | Significado. | DMCSPDL | Cabezal con control de potencia habilitable. Si este parámetro se define con valor ꞏNoꞏ, el CNC no podrá habilitar el DMC en el cabezal." ;
    ex:valor "No" .