@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_G_LEARNEDPWRSP
    a ex:Parametro ;
    rdfs:label "G.LEARNEDPWRSP" ;
    ex:identificador "G.LEARNEDPWRSP" ;
    ex:textoExtracto "Potencia objetivo calculada por el DMC en la fase de aprendizaje (porcentaje de la potencia nominal). Esta variable no incluye la potencia en vacío. Unidades: Porcentaje." ;
    ex:valor "Porcentaje"^^xsd:string .

ex:Parametro_G_DMCACTPWR
    a ex:Parametro ;
    rdfs:label "G.DMCACTPWR" ;
    ex:identificador "G.DMCACTPWR" ;
    ex:textoExtracto "Potencia activa en el cabezal, medida por el DMC (porcentaje de la potencia nominal). Unidades: Porcentaje." ;
    ex:valor "Porcentaje"^^xsd:string .

ex:Parametro_G_DMCOVR
    a ex:Parametro ;
    rdfs:label "G.DMCOVR" ;
    ex:identificador "G.DMCOVR" ;
    ex:textoExtracto "Porcentaje de avance (feed override) calculado por el DMC. Unidades: Porcentaje." ;
    ex:valor "Porcentaje"^^xsd:string .

ex:InterfazUsuario_ConfigDMC_osc
    a ex:InterfazUsuario ;
    rdfs:label "ConfigDMC.osc" ;
    ex:identificador "ConfigDMC.osc" ;
    ex:textoExtracto "Archivo que recoge las variables y los datos necesarios para su representación en el osciloscopio (en la carpeta ../Fagor/Tuning). Este archivo se puede cargar en el osciloscopio desde el menú de softkeys." .

ex:InterfazUsuario_ConfigDMC_osc
    ex:ilustradoEn ex:Parametro_G_LEARNEDPWRSP ,
                    ex:Parametro_G_DMCACTPWR ,
                    ex:Parametro_G_DMCOVR .