@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:V_G_LEARNEDPWRSP a ex:Parametro ;
    rdfs:label "G.LEARNEDPWRSP" ;
    ex:textoExtracto "Potencia objetivo calculada por el DMC en la fase de aprendizaje (porcentaje de la potencia nominal). Esta variable no incluye la potencia en vacío. Unidades: Porcentaje." ;
    ex:valor "Porcentaje" .

ex:V_G_DMCACTPWR a ex:Parametro ;
    rdfs:label "G.DMCACTPWR" ;
    ex:textoExtracto "Potencia activa en el cabezal, medida por el DMC (porcentaje de la potencia nominal). Unidades: Porcentaje." ;
    ex:valor "Porcentaje" .

ex:V_G_DMCOVR a ex:Parametro ;
    rdfs:label "G.DMCOVR" ;
    ex:textoExtracto "Porcentaje de avance (feed override) calculado por el DMC. Unidades: Porcentaje." ;
    ex:valor "Porcentaje" .

ex:ConfigDMC_osc a ex:Esquema ;
    ex:textoExtracto "Las variables y los datos necesarios para su representación en el osciloscopio están recogidas en el archivo ConfigDMC.osc (en la carpeta ../Fagor/Tuning)." ;
    ex:identificador "ConfigDMC.osc" ;
    ex:detalladoEnEsquema ex:V_G_LEARNEDPWRSP, ex:V_G_DMCACTPWR, ex:V_G_DMCOVR .

ex:Osciloscopio a ex:InterfazUsuario ;
    ex:textoExtracto "Para acceder a las variables desde el osciloscopio, omitir el prefijo 'V.' del mnemónico. Las variables y los datos necesarios para su representación en el osciloscopio están recogidas en el archivo ConfigDMC.osc (en la carpeta ../Fagor/Tuning). Este archivo se puede cargar en el osciloscopio desde el menú de softkeys, de la forma habitual." .