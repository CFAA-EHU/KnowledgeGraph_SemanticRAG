@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DMC
    a ex:ModoOperacion ;
    rdfs:label "Dynamic Milling Control (DMC)" ;
    ex:textoExtracto "La sentencia #DMCON activa el DMC, siempre sobre el cabezal master. El DMC sólo está disponible para operaciones de fresado con herramientas de tipo 'Fresado' y 'Planeado'." .

ex:Parametro_PWRSP
    a ex:Parametro ;
    rdfs:label "PWRSP (Potencia objetivo)" ;
    ex:textoExtracto "PWRSP{power} Potencia objetivo o potencia de corte idónea, definida como porcentaje de la potencia nominal del cabezal." ;
    ex:valor "0 — 100 %" .

ex:Parametro_OVRMIN
    a ex:Parametro ;
    rdfs:label "OVRMIN (Mínimo override permitido)" ;
    ex:textoExtracto "OVRMIN{%} Mínimo override permitido para el DMC. • Valores: 10 — 100 %." ;
    ex:valor "10 — 100 %" .

ex:Parametro_OVRMAX
    a ex:Parametro ;
    rdfs:label "OVRMAX (Máximo override permitido)" ;
    ex:textoExtracto "OVRMAX{%} Máximo override permitido para el DMC. • Valores: 100 — 255 %." ;
    ex:valor "100 — 255 %" .

ex:Parametro_FZMIN
    a ex:Parametro ;
    rdfs:label "FZMIN (Mínimo avance por diente)" ;
    ex:textoExtracto "FZMIN{feed} Mínimo avance por diente permitido durante el DMC. • Valores: 0 — 99999.9999 mm/diente 0 — 3937.00787 pulgada/diente." ;
    ex:valor "0 — 99999.9999 mm/diente" .

ex:Parametro_FZMAX
    a ex:Parametro ;
    rdfs:label "FZMAX (Máximo avance por diente)" ;
    ex:textoExtracto "FZMAX{feed} Máximo avance por diente permitido durante el DMC. • Valores: 0 — 99999.9999 mm/diente 0 — 3937.00787 pulgada/diente." ;
    ex:valor "0 — 99999.9999 mm/diente" .

ex:DMC ex:monitoreaParametro ex:Parametro_PWRSP .
ex:DMC ex:monitoreaParametro ex:Parametro_OVRMIN .
ex:DMC ex:monitoreaParametro ex:Parametro_OVRMAX .
ex:DMC ex:monitoreaParametro ex:Parametro_FZMIN .
ex:DMC ex:monitoreaParametro ex:Parametro_FZMAX .