@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:DMCON a ex:Parametro ;
    rdfs:label "#DMCON" ;
    ex:textoExtracto "La sentencia #DMCON activa el DMC, siempre sobre el cabezal master." .

ex:DMC a ex:ModoOperacion ;
    rdfs:label "DMC" ;
    ex:textoExtracto "El DMC se puede aplicar a operaciones de desbaste y acabado, pero será en operaciones de desbaste donde esta función aporte mayores beneficios en tiempo de mecanizado y vida de herramienta." .

ex:Fresado a ex:Herramienta ;
    rdfs:label "Fresado" ;
    ex:textoExtracto "El DMC, siempre sobre el cabezal master. El DMC sólo está disponible para operaciones de fresado con herramientas de tipo \"Fresado\" y \"Planeado\"." .

ex:Planeado a ex:Herramienta ;
    rdfs:label "Planeado" ;
    ex:textoExtracto "El DMC, siempre sobre el cabezal master. El DMC sólo está disponible para operaciones de fresado con herramientas de tipo \"Fresado\" y \"Planeado\"." .

ex:PWRSP a ex:Parametro ;
    rdfs:label "PWRSP" ;
    ex:textoExtracto "PWRSP{power} Potencia objetivo o potencia de corte idónea, definida como porcentaje de la potencia nominal del cabezal." .

ex:OVRMIN a ex:Parametro ;
    rdfs:label "OVRMIN" ;
    ex:textoExtracto "OVRMIN{%} Mínimo override permitido para el DMC." .

ex:OVRMAX a ex:Parametro ;
    rdfs:label "OVRMAX" ;
    ex:textoExtracto "OVRMAX{%} Máximo override permitido para el DMC." .

ex:FZMIN a ex:Parametro ;
    rdfs:label "FZMIN" ;
    ex:textoExtracto "FZMIN{feed} Mínimo avance por diente permitido durante el DMC." .

ex:FZMAX a ex:Parametro ;
    rdfs:label "FZMAX" ;
    ex:textoExtracto "FZMAX{feed} Máximo avance por diente permitido durante el DMC." .