@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:FZMAX a ex:Parametro ;
    rdfs:label "FZMAX" ;
    ex:identificador "FZMAX" ;
    ex:textoExtracto "FZMAX{feed} Máximo avance por diente permitido durante el DMC." ;
    ex:valor "0 — 99999.9999 mm/diente 0 — 3937.00787 pulgada/diente" .

ex:DMC a ex:ModoOperacion ;
    rdfs:label "DMC" ;
    ex:identificador "DMC" ;
    ex:textoExtracto "Máximo avance por diente permitido durante el DMC." .