@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ItActivatesPROBE1InSAFEMode a ns1:Parametro ;
    rdfs:label "It activates PROBE1 in SAFE mode" ;
    ns1:identificador "V.PLC.PROBE1MONIT" ;
    ns1:textoExtracto "$IF [V.PLC.PROBE1MONIT==0] #MSG[\"PROBE NOT IN SAFE MODE\"] $ENDIF" .

ns1:PROBE1IsEnabledConfirmationSignalToCNC a ns1:Parametro ;
    rdfs:label "PROBE1 is enabled confirmation signal to CNC" ;
    ns1:identificador "V.PLC.PROBE1ENA" ;
    ns1:textoExtracto "#WAIT FOR[V.PLC.PROBE1ENA==1]" .

ns1:SubrutinaSubProbeToolBegin a ns1:Sistema ;
    rdfs:label "Sub_Probe_Tool_Begin.fst" ;
    ns1:textoExtracto "Ejemplo de subrutina Sub_Probe_Tool_Begin.fst suministrada por Fagor (a adaptar por el OEM)." .

ns1:SubrutinaSubProbeToolEnd a ns1:Sistema ;
    rdfs:label "Sub_Probe_Tool_End.fst" ;
    ns1:textoExtracto "Ejemplo de subrutina Sub_Probe_Tool_End.fst suministrada por Fagor (a adaptar por el OEM)." .

