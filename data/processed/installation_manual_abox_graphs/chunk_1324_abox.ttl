@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:DMC_on_default ex:textoExtracto """#DMC ON
(El CNC activa el DMC con los valores por defecto). (El DMC inicia la fase de aprendizaje para calcular la potencia objetivo).""" ;
    a ex:ModoOperacion ;
    rdfs:label "#DMC ON" .

ex:DMC_on_programado_1 ex:textoExtracto """#DMC ON [PWRSP 80, OVRMIN 90, OVRMAX 110, FZMIN 0.8, FZMAX 1.3]
(El CNC activa el DMC con los valores programados).""" ;
    a ex:ModoOperacion ;
    rdfs:label "#DMC ON [PWRSP 80, OVRMIN 90, OVRMAX 110, FZMIN 0.8, FZMAX 1.3]" .

ex:DMC_on_programado_2 ex:textoExtracto """#DMC ON [OVRMIN 90, OVRMAX 110, FZMIN 0.8, FZMAX 1.3]
(El CNC activa el DMC con los valores programados). (El DMC inicia la fase de aprendizaje para calcular la potencia objetivo).""" ;
    a ex:ModoOperacion ;
    rdfs:label "#DMC ON [OVRMIN 90, OVRMAX 110, FZMAX 1.3]" .