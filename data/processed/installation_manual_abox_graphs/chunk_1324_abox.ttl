ns1:CNC8070_16577f193f a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:ejecuta ns1:SubrutinaSub_Probe_Piece_Begin,
        ns1:SubrutinaSub_Probe_Piece_End ;
    ns1:textoExtracto "El CNC ejecuta antes y después del ciclo." .

ns1:SubrutinaSub_Probe_Tool_Begin a ns1:Componente ;
    rdfs:label "Sub_Probe_Tool_Begin.fst" ;
    ns1:textoExtracto "Fagor suministra la subrutina Sub_Probe_Tool_Begin.fst asociada a la entrada de palpador 1." .

ns1:SubrutinaSub_Probe_Piece_Begin a ns1:Componente ;
    rdfs:label "Sub_Probe_Piece_Begin.fst" ;
    ns1:textoExtracto "Fagor suministra la subrutina Sub_Probe_Piece_Begin.fst asociada a la entrada de palpador 2." .

ns1:SubrutinaSub_Probe_Piece_End a ns1:Componente ;
    rdfs:label "Sub_Probe_Piece_End.fst" ;
    ns1:textoExtracto "Subrutina asociada al final del ciclo de medición de pieza." .

