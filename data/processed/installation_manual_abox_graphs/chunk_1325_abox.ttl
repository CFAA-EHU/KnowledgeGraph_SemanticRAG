@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_a8193b44bf a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para palpador en modo no seguro" ;
    ns1:documentadoEn ns1:SubrutinaSubProbePieceBegin ;
    ns1:textoExtracto "Se recomienda que OEM gestione ambas marca desde la subrutina Sub_Probe_Piece_Begin.fst para avisar, si están desactivadas, que el palpador está en modo no seguro." .

ns1:MarcaProbe1Monit a ns1:ComponenteElectrico ;
    rdfs:label "Marca PROBE1MONIT" ;
    ns1:textoExtracto "Gestión de las marcas PROBE1MONIT/PROBE2MONIT en la subrutina. Estas marcas están asociadas al modo seguro del palpador." .

ns1:MarcaProbe2Monit a ns1:ComponenteElectrico ;
    rdfs:label "Marca PROBE2MONIT" ;
    ns1:textoExtracto "Gestión de las marcas PROBE1MONIT/PROBE2MONIT en la subrutina. Estas marcas están asociadas al modo seguro del palpador." .

ns1:SubrutinaSubProbePieceBegin a ns1:Sistema ;
    rdfs:label "Subrutina Sub_Probe_Piece_Begin" ;
    ns1:textoExtracto "Gestión de las marcas PROBE1MONIT/PROBE2MONIT en la subrutina. Estas marcas están asociadas al modo seguro del palpador." ;
    ns1:tieneComponente ns1:MarcaProbe1Monit,
        ns1:MarcaProbe2Monit .

