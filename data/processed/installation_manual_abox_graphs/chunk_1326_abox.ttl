@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:DMC_ModoInspeccionHerramienta a ex:ModoOperacion ;
    rdfs:label "DMC" ;
    ex:textoExtracto "El entrar en el modo de inspección de herramienta, el DMC se desactiva." ;
    ex:textoExtracto "Al finalizar la inspección de herramienta, el DMC se activa automáticamente y permite repetir la fase de aprendizaje pulsando la softkey 'Aprendizaje DMC'." .

ex:AprendizajeDMC_Softkey a ex:InterfazUsuario ;
    rdfs:label "Aprendizaje DMC" ;
    ex:textoExtracto "permite repetir la fase de aprendizaje pulsando la softkey 'Aprendizaje DMC'" .