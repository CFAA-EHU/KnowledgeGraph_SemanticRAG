@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoInspeccionHerramienta
    a               ex:ModoOperacion ;
    rdfs:label      "Modo de inspección de herramienta"@es ;
    ex:textoExtracto "El entrar en el modo de inspección de herramienta, el DMC se desactiva. Al finalizar la inspección de herramienta, el DMC se activa automáticamente"@es .

ex:SoftkeyAprendizajeDMC
    a               ex:InterfazUsuario ;
    rdfs:label      "Softkey 'Aprendizaje DMC'"@es ;
    ex:textoExtracto "permite repetir la fase de aprendizaje pulsando la softkey 'Aprendizaje DMC'"@es ;
    ex:habilitadoPor ex:ModoInspeccionHerramienta .