@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:DMC a ex:ModoOperacion ;
    rdfs:label "DMC" ;
    ex:textoExtracto "el DMC se activa automáticamente y permite repetir la fase de aprendizaje pulsando la softkey \"Aprendizaje DMC\"" ;
    ex:textoExtracto "Las trayectorias en G0, parada de ejes con [STOP] y la softkey \"Set DMC off\" desactivan temporalmente DMC" ;
    ex:textoExtracto "Si el DMC no ha comenzado a medir la potencia en vacío, no da comienzo al proceso" ;
    ex:textoExtracto "Si el DMC está esperando a que el cabezal alcance la velocidad programada o está midiendo la potencia en vacío, el DMC se desactiva cuando acabe de medir la potencia en vacío" ;
    ex:textoExtracto "Durante la fase de aprendizaje, el DMC no cuenta como tiempo de aprendizaje el tiempo que dure la causa de desactivación" ;
    ex:textoExtracto "Durante la ejecución en vacío, el DMC se desactiva, pero seguirá detectando las entradas a la pieza" ;
    ex:textoExtracto "Si la herramienta está entrando en la pieza, el DMC se desactivará cuando termine la entrada" ;
    ex:textoExtracto "Si la herramienta está dentro de la pieza, el DMC se desactiva, pero seguirá detectando las salidas de pieza y los consumos excesivos de potencia" ;
    ex:textoExtracto "Si la herramienta está saliendo de la pieza, el DMC se desactiva cuando finaliza la salida" .

ex:Softkey_Aprendizaje_DMC a ex:InterfazUsuario ;
    rdfs:label "Softkey \"Aprendizaje DMC\"" ;
    ex:textoExtracto "pulsando la softkey \"Aprendizaje DMC\"" .

ex:Softkey_Set_DMC_off a ex:InterfazUsuario ;
    rdfs:label "Softkey \"Set DMC off\"" ;
    ex:textoExtracto "parada de ejes con [STOP] y la softkey \"Set DMC off\" desactivan temporalmente DMC" .

ex:Trayectoria_G0 a ex:ModoOperacion ;
    rdfs:label "Trayectoria en G0" ;
    ex:textoExtracto "Las trayectorias en G0 [...] desactivan temporalmente DMC" .

ex:Parada_ejes_STOP a ex:ModoOperacion ;
    rdfs:label "Parada de ejes con [STOP]" ;
    ex:textoExtracto "parada de ejes con [STOP] [...] desactivan temporalmente DMC" .

ex:Fase_aprendizaje_DMC a ex:TareaMantenimiento ;
    rdfs:label "Fase de aprendizaje DMC" ;
    ex:textoExtracto "repetir la fase de aprendizaje pulsando la softkey \"Aprendizaje DMC\"" ;
    ex:textoExtracto "Durante la fase de aprendizaje, el DMC no cuenta como tiempo de aprendizaje el tiempo que dure la causa de desactivación" .

ex:Ejecucion_vacio_DMC a ex:ModoOperacion ;
    rdfs:label "Ejecución en vacío DMC" ;
    ex:textoExtracto "Durante la ejecución en vacío, el DMC se desactiva, pero seguirá detectando las entradas a la pieza" .

ex:Herramienta_DMC a ex:ComponenteMecanico ;
    rdfs:label "Herramienta" ;
    ex:textoExtracto "Si la herramienta está entrando en la pieza, el DMC se desactivará cuando termine la entrada" ;
    ex:textoExtracto "Si la herramienta está dentro de la pieza, el DMC se desactiva, pero seguirá detectando las salidas de pieza y los consumos excesivos de potencia" ;
    ex:textoExtracto "Si la herramienta está saliendo de la pieza, el DMC se desactiva cuando finaliza la salida" .

ex:Potencia_vacio_DMC a ex:Parametro ;
    rdfs:label "Potencia en vacío" ;
    ex:textoExtracto "Si el DMC no ha comenzado a medir la potencia en vacío, no da comienzo al proceso" ;
    ex:textoExtracto "Si el DMC está esperando a que el cabezal alcance la velocidad programada o está midiendo la potencia en vacío, el DMC se desactiva cuando acabe de medir la potencia en vacío" .

ex:Cabezal_DMC a ex:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ex:textoExtracto "Si el DMC está esperando a que el cabezal alcance la velocidad programada [...] el DMC se desactiva cuando acabe de medir la potencia en vacío" .