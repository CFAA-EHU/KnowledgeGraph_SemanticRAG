@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DMC_ModoOperacion_1327
    a ex:ModoOperacion ;
    rdfs:label "DMC (Dynamic Machining Control)"@es ;
    ex:textoExtracto """
    de herramienta, el DMC se activa automáticamente y permite repetir la fase de aprendizaje pulsando la softkey \"Aprendizaje DMC\".
    Comportamiento del DMC tras ser desactivado. Las trayectorias en G0, parada de ejes con [STOP] y la softkey \"Set DMC off\" desactivan temporalmente DMC.
    """@es .

ex:Softkey_AprendizajeDMC_1327
    a ex:InterfazUsuario ;
    rdfs:label "Softkey \"Aprendizaje DMC\""@es ;
    ex:textoExtracto """
    pulsando la softkey \"Aprendizaje DMC\"
    """@es ;
    ex:habilitadoPor ex:DMC_ModoOperacion_1327 .

ex:Softkey_SetDMCOff_1327
    a ex:InterfazUsuario ;
    rdfs:label "Softkey \"Set DMC off\""@es ;
    ex:textoExtracto """
    la softkey \"Set DMC off\" desactivan temporalmente DMC
    """@es ;
    ex:activaAlarma ex:DMC_ModoOperacion_1327 .