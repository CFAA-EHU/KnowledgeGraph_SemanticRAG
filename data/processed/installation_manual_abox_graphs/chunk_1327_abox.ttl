@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ItActivatesPROBE2InSAFEMode a ns1:Parametro ;
    rdfs:label "It activates PROBE2 in SAFE mode" ;
    ns1:identificador "V.PLC.PROBE2MONIT" ;
    ns1:textoExtracto "$IF [V.PLC.PROBE2MONIT==0]" .

ns1:PROBE2IsEnabledConfirmationSignalToCNC a ns1:Parametro ;
    rdfs:label "PROBE 2 is enabled confirmation signal to CNC" ;
    ns1:identificador "V.PLC.PROBE2ENA" ;
    ns1:textoExtracto "#WAIT FOR[V.PLC.PROBE2ENA==1]" .

ns1:SubrutinaSubProbePieceBegin a ns1:Sistema ;
    rdfs:label "Sub_Probe_Piece_Begin.fst" ;
    ns1:documentadoEn ns1:SistemaCNC ;
    ns1:textoExtracto "Ejemplo de subrutina Sub_Probe_Piece_Begin.fst suministrada por Fagor (a adaptar por el OEM)." .

ns1:SubrutinaSubProbePieceEnd a ns1:Sistema ;
    rdfs:label "Sub_Probe_Piece_End.fst" ;
    ns1:documentadoEn ns1:SistemaCNC ;
    ns1:textoExtracto "Ejemplo de subrutina Sub_Probe_Piece_End.fst suministrada por Fagor (a adaptar por el OEM)." .

