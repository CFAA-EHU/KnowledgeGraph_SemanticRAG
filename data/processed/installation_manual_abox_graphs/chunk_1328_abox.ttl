@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Sentencia_DMCOFF a ex:Parametro ;
    rdfs:label "Sentencia #DMCOFF" ;
    ex:textoExtracto "La sentencia #DMCOFF desactiva el DMC." .

ex:Funcion_M02 a ex:ModoOperacion ;
    rdfs:label "Función M02" ;
    ex:textoExtracto "Las funciones M02 o M30 (fin de programa) y el reset también desactivan el DMC." .

ex:Funcion_M30 a ex:ModoOperacion ;
    rdfs:label "Función M30" ;
    ex:textoExtracto "Las funciones M02 o M30 (fin de programa) y el reset también desactivan el DMC." .

ex:Funcion_M5 a ex:ModoOperacion ;
    rdfs:label "Función M5" ;
    ex:textoExtracto "Una parada de cabezal, función M5, desactiva el DMC." .

ex:FormatoProgramacion_DMC_OFF a ex:Esquema ;
    rdfs:label "Formato de programación #DMC OFF" ;
    ex:textoExtracto "Formato de programación. El formato de programación es el siguiente. # DMC OFF #DMC OFF (El CNC desactiva el DMC)." .