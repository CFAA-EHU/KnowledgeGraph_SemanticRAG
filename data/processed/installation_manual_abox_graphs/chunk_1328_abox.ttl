@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_d346f4d809 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:ejecuta ns1:CambioDeHerramienta_aa84b3cc8d ;
    ns1:textoExtracto "Cuando el CNC selecciona una herramienta, la rutina asociada a T ejecuta la función M06 (cambio de herramienta)." .

ns1:FuncionM06 a ns1:AccionProhibida ;
    rdfs:label "Función M06" ;
    ns1:textoExtracto "Se recomienda que la rutina asociada a T incluya la función M06." .

ns1:SubrutinaT a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina asociada a la herramienta" ;
    ns1:solucionaFallo ns1:NoSeEjecutaElCambioDeHerramienta ;
    ns1:textoExtracto "Si la subrutina asociada a T no incluye la función M06, cuando el CNC selecciona una herramienta, internamente ejecuta un bloque T# M6 para ejecutar el cambio." .

ns1:CambioDeHerramienta_aa84b3cc8d a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta" ;
    ns1:textoExtracto "el proceso de carga de la herramienta se realizará cuando se ejecute el código \"T\"." .

ns1:NoSeEjecutaElCambioDeHerramienta a ns1:DiagnosticoFallo ;
    rdfs:label "No se ejecuta el cambio de herramienta" ;
    ns1:textoExtracto "No se ejecuta el cambio de herramienta" .

