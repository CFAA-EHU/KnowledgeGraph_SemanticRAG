ex:Variable_TM_NCUTTERS_offset a ex:Parametro ;
    ex:identificador "(V.)[ch].TM.NCUTTERS[offset]" ;
    ex:textoExtracto "Corrector [offset] de la herramienta activa. Número de dientes. Unidades: Dientes." ;
    ex:valor "Dientes" ;
    ex:tieneFrecuencia ex:Frecuencia_AccesoPRG, ex:Frecuencia_AccesoPLC, ex:Frecuencia_AccesoINT ;
    ex:detalladoEnEsquema ex:Tabla1329 .

ex:Frecuencia_AccesoPRG a ex:Frecuencia ;
    ex:valor "R/W" ;
    ex:textoExtracto "Acceso desde el programa pieza (PRG)." .

ex:Frecuencia_AccesoPLC a ex:Frecuencia ;
    ex:valor "R/W" ;
    ex:textoExtracto "Acceso desde el PLC (síncrono)." .

ex:Frecuencia_AccesoINT a ex:Frecuencia ;
    ex:valor "R" ;
    ex:textoExtracto "Acceso desde una aplicación externa (INT)." .