@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ResumenVariables_18_2_3 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Resumen de las variables accesibles desde PRG, PLC e INT"@es ;
    ex:textoExtracto "Las siguientes variables son accesibles desde; (PRG) el programa pieza y desde el modo MDI/MDA, PLC e (INT) una aplicación externa. La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W)."@es ;
    ex:identificador "18.2.3" .

ex:Parametro_MPG_MINDMCOVR
    a ex:Parametro ;
    rdfs:label "Mínimo override DMC de todos los ejes del canal"@es ;
    ex:textoExtracto "(V.)[ch].MPG.MINDMCOVR - Mínimo override DMC de todos los ejes del canal. Unidades: Porcentaje."@es ;
    ex:valor "Porcentaje" ;
    ex:documentadoEn ex:Tabla_ResumenVariables_18_2_3 .

ex:Parametro_MPG_MAXDMCOVR
    a ex:Parametro ;
    rdfs:label "Máximo override DMC de todos los ejes del canal"@es ;
    ex:textoExtracto "(V.)[ch].MPG.MAXDMCOVR - Máximo override DMC de todos los ejes del canal. Unidades: Porcentaje."@es ;
    ex:valor "Porcentaje" ;
    ex:documentadoEn ex:Tabla_ResumenVariables_18_2_3 .

