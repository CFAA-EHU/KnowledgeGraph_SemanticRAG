    ex:identificador "(V.)[ch].G.FRO" ;
    ex:textoExtracto "Porcentaje de avance (feed override) activo. Unidades: Porcentaje." ;
    ex:valor "Porcentaje" ;
    ex:tieneFrecuencia ex:Frecuencia_AccesoPRG, ex:Frecuencia_AccesoPLC, ex:Frecuencia_AccesoINT ;
