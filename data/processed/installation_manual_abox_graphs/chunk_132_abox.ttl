@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:BloqueLogico_132_1 a ex:Componente ;
    rdfs:label "bloque lógico" ;
    ex:textoExtracto "a partir del cual se numeran las salidas digitales del bloque lógico" .

ex:SalidaDigital_132_1 a ex:ComponenteElectrico ;
    rdfs:label "salida digital" ;
    ex:textoExtracto "Los valores del índice base deben cumplir con la fórmula \"8n + 1\" (es decir, 1, 9, 17, 25 ...)" .

ex:ModuloDoble_132_1 a ex:ComponenteElectrico ;
    rdfs:label "módulo doble" ;
    ex:textoExtracto "En los nodos RIO5, cada módulo doble (módulo con dos placas) cuenta como dos; es decir, dos bloques lógicos" .

ex:Placa_132_1 a ex:ComponenteElectrico ;
    rdfs:label "placa" ;
    ex:textoExtracto "uno para cada placa" .

ex:ParametroNDO_132_1 a ex:Parametro ;
    ex:identificador "NDO" ;
    rdfs:label "Número de salidas digitales del bloque lógico" ;
    ex:textoExtracto "NDO Número de salidas digitales del bloque lógico. Valores posibles: De 8 a 1024. Valor por defecto: 0. Variable asociada: (V.)MPG.DOMODNDO[nb] Número de salidas digitales del bloque lógico; no puede ser cero y debe ser un múltiplo de 8 (8, 16, 24, ...1024)" ;
    ex:valor "0" .

ex:ParametroNDO_132_2 a ex:Parametro ;
    rdfs:label "Número de salidas digitales del bloque lógico" ;
    ex:textoExtracto "Número de salidas digitales del bloque lógico; no puede ser cero y debe ser un múltiplo de 8 (8, 16, 24, ...1024)" ;
    ex:valor "8" .

ex:ParametroNDO_132_3 a ex:Parametro ;
    rdfs:label "Número de salidas digitales del bloque lógico" ;
    ex:textoExtracto "Número de salidas digitales del bloque lógico; no puede ser cero y debe ser un múltiplo de 8 (8, 16, 24, ...1024)" ;
    ex:valor "16" .

ex:ParametroNDO_132_4 a ex:Parametro ;
    rdfs:label "Número de salidas digitales del bloque lógico" ;
    ex:textoExtracto "Número de salidas digitales del bloque lógico; no puede ser cero y debe ser un múltiplo de 8 (8, 16, 24, ...1024)" ;
    ex:valor "24" .

ex:ParametroNDO_132_5 a ex:Parametro ;
    rdfs:label "Número de salidas digitales del bloque lógico" ;
    ex:textoExtracto "Número de salidas digitales del bloque lógico; no puede ser cero y debe ser un múltiplo de 8 (8, 16, 24, ...1024)" ;
    ex:valor "1024" .