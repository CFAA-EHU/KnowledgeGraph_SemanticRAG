@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_NCUTTERS
    a ex:Parametro ;
    rdfs:label "Número de dientes (TM.NCUTTERS)"@es ;
    ex:identificador "TM.NCUTTERS" ;
    ex:valor "Dientes"^^xsd:string ;
    ex:textoExtracto "Número de dientes. Unidades: Dientes. | R/W | R | R | [...] (V.)[ch].TM.NCUTTERS[offset]"@es .

ex:Parametro_CorrectorOffset_NCUTTERS
    a ex:Parametro ;
    rdfs:label "Corrector [offset] de la herramienta activa (TM.NCUTTERS)"@es ;
    ex:identificador "TM.NCUTTERS[offset]" ;
    ex:valor "Dientes"^^xsd:string ;
    ex:textoExtracto "Corrector [offset] de la herramienta activa. Número de dientes. Unidades: Dientes. | R/W(*) | R/W | R/W"@es .