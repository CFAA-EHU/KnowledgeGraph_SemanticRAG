@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SubrutinaConfiguracion a ns1:Componente ;
    rdfs:label "Subrutina configuración" ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:textoExtracto "Esta subrutina debe estar definida en la tabla de funciones \"M\" y estará guardada en la carpeta ..\\Mtb\\Sub." .

ns1:TablaFuncionesM a ns1:Tabla ;
    rdfs:label "Tabla de funciones M" ;
    ns1:textoExtracto "Esta subrutina debe estar definida en la tabla de funciones \"M\" y estará guardada en la carpeta ..\\Mtb\\Sub." .

