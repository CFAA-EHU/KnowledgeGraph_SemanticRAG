@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Tabla1331_725 a ex:Tabla ;
    ex:textoExtracto """| Variables. | PRG | PLC | INT |
| --- | --- | --- | --- |
| (V.)TM.NCUTTERST[tool][offset]
Corrector [offset] de la herramienta [tool]. Número de dientes. Unidades: Dientes. | R/W(*) | R/W | R/W |
| (V.)[ch].G.DMCPWRSP
Potencia objetivo, definida como porcentaje de la potencia nominal del
cabezal. Valor programado en el comando PWRSP de la sentencia
#DMCON. Unidades: Porcentaje. | R | R | R |
| (V.)[ch].G.DMCOVRMIN
Mínimo porcentaje de avance (feed override) permitido para el DMC. Valor programado en el comando OVRMIN de la sentencia #DMCON. Unidades: Porcentaje. | R | R | R |
| (V.)[ch].G.DMCOVRMAX
Máximo porcentaje de avance (feed override) permitido para el DMC. Valor programado en el comando OVRMAX de la sentencia #DMCON. Unidades: Porcentaje. | R | R | R |
| (V.)[ch].G.DMCFZMIN
Mínimo avance por diente permitido durante el DMC. Valor programado
en el comando FZMIN de la sentencia #DMCON. Unidades: Milímetros/diente o pulgadas/diente. | R | R | R |
| (V.)[ch].G.DMCFZMAX
Máximo avance por diente permitido durante el DMC. Valor
programado en el comando FZMAX de la sentencia #DMCON. Unidades: Milímetros/diente o pulgadas/diente. | R | R | R |
| (V.)[ch].G.DMCON
Estado del DMC. Unidades: -. | R(*) | R | R |
| (V.)[ch].G.LEARNEDPWRSP
Potencia objetivo calculada por el DMC en la fase de aprendizaje
(porcentaje de la potencia nominal). Unidades: Porcentaje.""" .

ex:Parametro_TM_NCUTTERST a ex:Parametro ;
    ex:textoExtracto "(V.)TM.NCUTTERST[tool][offset] Corrector [offset] de la herramienta [tool]. Número de dientes. Unidades: Dientes." ;
    rdfs:label "TM.NCUTTERST[tool][offset]" ;
    ex:valor "Dientes" .

ex:Parametro_ch_G_DMCPWRSP a ex:Parametro ;
    ex:textoExtracto "(V.)[ch].G.DMCPWRSP Potencia objetivo, definida como porcentaje de la potencia nominal del cabezal. Valor programado en el comando PWRSP de la sentencia #DMCON. Unidades: Porcentaje." ;
    rdfs:label "[ch].G.DMCPWRSP" ;
    ex:valor "Porcentaje" .

ex:Parametro_ch_G_DMCOVRMIN a ex:Parametro ;
    ex:textoExtracto "(V.)[ch].G.DMCOVRMIN Mínimo porcentaje de avance (feed override) permitido para el DMC. Valor programado en el comando OVRMIN de la sentencia #DMCON. Unidades: Porcentaje." ;
    rdfs:label "[ch].G.DMCOVRMIN" ;
    ex:valor "Porcentaje" .

ex:Parametro_ch_G_DMCOVRMAX a ex:Parametro ;
    ex:textoExtracto "(V.)[ch].G.DMCOVRMAX Máximo porcentaje de avance (feed override) permitido para el DMC. Valor programado en el comando OVRMAX de la sentencia #DMCON. Unidades: Porcentaje." ;
    rdfs:label "[ch].G.DMCOVRMAX" ;
    ex:valor "Porcentaje" .

ex:Parametro_ch_G_DMCFZMIN a ex:Parametro ;
    ex:textoExtracto "(V.)[ch].G.DMCFZMIN Mínimo avance por diente permitido durante el DMC. Valor programado en el comando FZMIN de la sentencia #DMCON. Unidades: Milímetros/diente o pulgadas/diente." ;
    rdfs:label "[ch].G.DMCFZMIN" ;
    ex:valor "Milímetros/diente o pulgadas/diente" .

ex:Parametro_ch_G_DMCFZMAX a ex:Parametro ;
    ex:textoExtracto "(V.)[ch].G.DMCFZMAX Máximo avance por diente permitido durante el DMC. Valor programado en el comando FZMAX de la sentencia #DMCON. Unidades: Milímetros/diente o pulgadas/diente." ;
    rdfs:label "[ch].G.DMCFZMAX" ;
    ex:valor "Milímetros/diente o pulgadas/diente" .

ex:Parametro_ch_G_DMCON a ex:Parametro ;
    ex:textoExtracto "(V.)[ch].G.DMCON Estado del DMC. Unidades: -." ;
    rdfs:label "[ch].G.DMCON" .

ex:Parametro_ch_G_LEARNEDPWRSP a ex:Parametro ;
    ex:textoExtracto "(V.)[ch].G.LEARNEDPWRSP Potencia objetivo calculada por el DMC en la fase de aprendizaje (porcentaje de la potencia nominal). Unidades: Porcentaje." ;
    rdfs:label "[ch].G.LEARNEDPWRSP" ;
    ex:valor "Porcentaje" .