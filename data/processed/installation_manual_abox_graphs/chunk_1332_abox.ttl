@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BusquedaDeReferenciaMaquina_9e7ec4ab3e a ns1:Parametro ;
    rdfs:label "Búsqueda de referencia máquina" ;
    ns1:identificador "G74" ;
    ns1:solucionaFallo ns1:FalloReferenciaManual ;
    ns1:textoExtracto "La función G74 (búsqueda de referencia máquina) se puede programar de 2 formas;" .

ns1:SubrutinaReferencia a ns1:Sistema ;
    rdfs:label "Subrutina asociada a la función G74" ;
    ns1:textoExtracto "Dentro de esta subrutina deben programarse los ejes y el orden en el que se deben referenciar los ejes y el cabezal." .

ns1:FalloReferenciaManual a ns1:DiagnosticoFallo ;
    rdfs:label "Búsqueda de referencia máquina en modo manual sin selección de eje" ;
    ns1:textoExtracto "También se efectúa una llamada a esta subrutina cuando se realiza una búsqueda de referencia máquina en modo manual sin selección de eje." .

