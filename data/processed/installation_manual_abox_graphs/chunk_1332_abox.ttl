@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_DMCLEARNEDPWRSP a ex:Parametro ;
    rdfs:label "(V.)[ch].G.LEARNEDPWRSP" ;
    ex:textoExtracto "Potencia objetivo calculada por el DMC en la fase de aprendizaje (porcentaje de la potencia nominal). Unidades: Porcentaje." ;
    ex:valor "Porcentaje" .

ex:Parametro_DMCACTPWR a ex:Parametro ;
    rdfs:label "(V.)[ch].G.DMCACTPWR" ;
    ex:textoExtracto "Potencia activa en el cabezal, medida por el DMC (porcentaje de la potencia nominal). Unidades: Porcentaje." ;
    ex:valor "Porcentaje" .

ex:Parametro_DMCOVR a ex:Parametro ;
    rdfs:label "(V.)[ch].G.DMCOVR" ;
    ex:textoExtracto "Porcentaje de avance (feed override) calculado por el DMC. Unidades: Porcentaje." ;
    ex:valor "Porcentaje" .

ex:Parametro_DMCFZ a ex:Parametro ;
    rdfs:label "(V.)[ch].G.DMCFZ" ;
    ex:textoExtracto "Avance por diente calculado por el DMC. Unidades: Milímetros/diente o pulgadas/diente." ;
    ex:valor "Milímetros/diente o pulgadas/diente" .

ex:Parametro_DMCNOLOADPWR a ex:Parametro ;
    rdfs:label "(V.)[ch].G.DMCNOLOADPWR" ;
    ex:textoExtracto "Potencia del cabezal en vacío medida por el DMC. Unidades: Kilowatios." ;
    ex:valor "Kilowatios" .

ex:Parametro_DMCSAVEDTIME a ex:Parametro ;
    rdfs:label "(V.)[ch].G.DMCSAVEDTIME" ;
    ex:textoExtracto "Tiempo ahorrado por acción del DMC. Unidades: Segundos." ;
    ex:valor "Segundos" .