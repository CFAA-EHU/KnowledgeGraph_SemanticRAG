@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:PotenciaCabezalVacio ex:textoExtracto "Potencia del cabezal en vacío medida por el DMC. Unidades: Kilowatios." ;
    a ex:Parametro ;
    ex:valor "Kilowatios" .

ex:TiempoAhorradoDMC ex:textoExtracto "Tiempo ahorrado por acción del DMC. Unidades: Segundos." ;
    a ex:Parametro ;
    ex:valor "Segundos" .

ex:DMCSAVEDTIME ex:textoExtracto "(V.)[ch].G.DMCSAVEDTIME" ;
    a ex:Parametro ;
    ex:identificador "DMCSAVEDTIME" .

ex:DMC ex:textoExtracto "DMC" ;
    a ex:Sistema .