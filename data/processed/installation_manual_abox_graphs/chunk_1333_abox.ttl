@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_DMC_PotenciaCabezalVacio
    a ex:Parametro ;
    rdfs:label "Potencia del cabezal en vacío medida por el DMC"@es ;
    ex:textoExtracto "Potencia del cabezal en vacío medida por el DMC. Unidades: Kilowatios."@es ;
    ex:identificador "(V.)[ch].G.DMCSAVEDPOWER" ;
    ex:valor "Kilowatios" .

ex:Parametro_DMC_TiempoAhorrado
    a ex:Parametro ;
    rdfs:label "Tiempo ahorrado por acción del DMC"@es ;
    ex:textoExtracto "Tiempo ahorrado por acción del DMC. Unidades: Segundos."@es ;
    ex:identificador "(V.)[ch].G.DMCSAVEDTIME" ;
    ex:valor "Segundos" .

ex:Sistema_DMC
    a ex:Sistema ;
    rdfs:label "DMC"@es ;
    ex:textoExtracto "Potencia del cabezal en vacío medida por el DMC [...] Tiempo ahorrado por acción del DMC"@es ;
    ex:monitoreaParametro ex:Parametro_DMC_PotenciaCabezalVacio ;
    ex:monitoreaParametro ex:Parametro_DMC_TiempoAhorrado .