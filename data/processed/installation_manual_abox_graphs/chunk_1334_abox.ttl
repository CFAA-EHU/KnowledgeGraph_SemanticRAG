@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_f9db592bc8 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:SubrutinaAsociadaMFuncion ;
    ns1:textoExtracto "Las funciones auxiliares \"M\" pueden tener una subrutina asociada, que el CNC ejecutará en lugar de la función." .

ns1:SubrutinaAsociadaMFuncion a ns1:Componente ;
    rdfs:label "Subrutina Asociada a Función M" ;
    ns1:textoExtracto "Si dentro de una subrutina asociada a una función \"M\" se programa la misma función \"M\", el CNC ejecutará ésta pero no la subrutina asociada." .

