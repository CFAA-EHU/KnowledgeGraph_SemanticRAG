@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NombreDeSubrutinaAsociadaALaFuncionM_16e2c3bc03 a ns1:Parametro ;
    rdfs:label "Nombre de subrutina asociada a la función M" ;
    ns1:documentadoEn ns1:TablaSubrutinas ;
    ns1:identificador "FUNM" ;
    ns1:textoExtracto "Parámetro máquina; tabla de funciones \"M\". Nombre y ubicación de la subrutina." .

ns1:TablaSubrutinas a ns1:Tabla ;
    rdfs:label "Tabla de funciones M" ;
    ns1:textoExtracto "Estas subrutinas deben estar definidas en la tabla de funciones \"M\", en el campo MPROGNAME, y estarán guardadas en la carpeta ..\\Mtb\\Sub." .

