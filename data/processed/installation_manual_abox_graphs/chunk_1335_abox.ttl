@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DMC_ModoOperacion
    a ex:ModoOperacion ;
    rdfs:label "Modo DMC (Dynamic Milling Control)" ;
    ex:textoExtracto "Tras ejecutar la sentencia #DMCON, el CNC activará el DMC siempre y cuando el cabezal tenga regulación digital, esté girando en M3 o M4 y haya alcanzado la velocidad de giro programada (marca REVOK)." ;
    ex:identificador "#DMCON" .

ex:FaseAprendizaje_DMC
    a ex:ModoOperacion ;
    rdfs:label "Fase de aprendizaje del DMC" ;
    ex:textoExtracto "Cada vez que se programa #DMCON sin potencia objetivo (comando PWRSP), el DMC la determina mediante una fase de aprendizaje que éste pondrá en marcha automáticamente. [...] La fase de aprendizaje dura un minuto, a partir de que la herramienta entre en la pieza una distancia igual al radio." .

ex:Softkey_AprendizajeDMC
    a ex:InterfazUsuario ;
    rdfs:label "Softkey 'Aprendizaje DMC'" ;
    ex:textoExtracto "La fase de aprendizaje se puede repetir en cualquier momento, con el DMC activo, pulsando la softkey 'Aprendizaje DMC' del modo automático." ;
    ex:habilitadoPor ex:DMC_ModoOperacion .

ex:Parametro_PWRSP
    a ex:Parametro ;
    rdfs:label "Potencia objetivo (PWRSP)" ;
    ex:textoExtracto "comando PWRSP [...] el DMC la determina mediante una fase de aprendizaje si no se programa." ;
    ex:identificador "PWRSP" .

ex:Parametro_PotenciaVacio
    a ex:Parametro ;
    rdfs:label "Potencia en vacío" ;
    ex:textoExtracto "el CNC mide la potencia consumida por el cabezal en vacío (sin mecanizar). Conocer la potencia en vacío permite al CNC detectar las entradas y salidas en la pieza durante el mecanizado." ;
    ex:monitoreaParametro ex:DMC_ModoOperacion .

ex:Parametro_PotenciaObjetivo
    a ex:Parametro ;
    rdfs:label "Potencia objetivo" ;
    ex:textoExtracto "calcula la potencia objetivo ('potencia consumida' – 'potencia en vacío')." ;
    ex:monitoreaParametro ex:DMC_ModoOperacion .