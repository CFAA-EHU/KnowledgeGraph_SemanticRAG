@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:FaseAprendizajeDMC a ex:TareaMantenimiento ;
    rdfs:label "Fase de aprendizaje del DMC"@es ;
    ex:textoExtracto "La fase de aprendizaje dura un minuto, a partir de que la herramienta entre en la pieza una distancia igual al radio."@es .

ex:HerramientaDMC a ex:ComponenteMecanico ;
    rdfs:label "Herramienta del DMC"@es ;
    ex:textoExtracto "la herramienta entre en la pieza"@es .

ex:VariableGLearnedPwrSp a ex:Parametro ;
    rdfs:label "Variable (V.)G.LEARNEDPWRSP"@es ;
    ex:identificador "(V.)G.LEARNEDPWRSP" ;
    ex:textoExtracto "El DMC escribirá en la variable (V.)G.LEARNEDPWRSP el valor de la potencia objetivo obtenida en la fase de aprendizaje"@es .

ex:DMC a ex:Sistema ;
    rdfs:label "DMC"@es ;
    ex:textoExtracto "El DMC escribirá en la variable (V.)G.LEARNEDPWRSP el valor de la potencia objetivo obtenida en la fase de aprendizaje"@es .