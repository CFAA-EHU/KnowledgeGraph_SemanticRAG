@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FaseAprendizajeDMC
    a               ex:ModoOperacion ;
    rdfs:label      "Fase de aprendizaje del DMC" ;
    ex:textoExtracto "La fase de aprendizaje dura un minuto, a partir de que la herramienta entre en la pieza una distancia igual al radio. Si la herramienta sale de la pieza, deja de contar el tiempo hasta que la herramienta vuelva a entrar en la pieza." ;
    ex:identificador "G.LEARNEDPWRSP" ;
    ex:valor         "potencia objetivo obtenida en la fase de aprendizaje" .

ex:VariablePotenciaObjetivo
    a               ex:Parametro ;
    rdfs:label      "Variable G.LEARNEDPWRSP" ;
    ex:identificador "V.G.LEARNEDPWRSP" ;
    ex:textoExtracto "El DMC escribirá en la variable (V.)G.LEARNEDPWRSP el valor de la potencia objetivo obtenida en la fase de aprendizaje" ;
    ex:valor         "potencia objetivo" .