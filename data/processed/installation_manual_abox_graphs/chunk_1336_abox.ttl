@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaVariables a ns1:Tabla ;
    rdfs:label "Tabla de variables accesibles" ;
    ns1:ilustra ns1:NombreDeSubrutinaAsociadaALaFuncionM_e31aa8e557,
        ns1:Posicion12DeLaTablaDeFuncionesM_93081f1c3b ;
    ns1:textoExtracto "La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W)." .

ns1:NombreDeSubrutinaAsociadaALaFuncionM_e31aa8e557 a ns1:Parametro ;
    rdfs:label "Nombre de subrutina asociada a la función M" ;
    ns1:identificador "MPM.MPROGNAME[pos]" ;
    ns1:textoExtracto "Variable (V.)MPM.MPROGNAME[pos] Nombre de subrutina asociada a la función M." .

ns1:Posicion12DeLaTablaDeFuncionesM_93081f1c3b a ns1:Parametro ;
    rdfs:label "Posición 12 de la tabla de funciones M" ;
    ns1:identificador "MPM.MPROGNAME[12]" ;
    ns1:textoExtracto "Sintaxis. ꞏposꞏ Posición dentro de la tabla de funciones \"M\"." .

