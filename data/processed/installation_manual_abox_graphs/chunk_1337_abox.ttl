@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_317ee913b9 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC permite al fabricante de la máquina definir hasta 30 subrutinas por canal y asociarlas a las funciones G180 a G189 y G380 a G399, de manera que cuando un canal ejecute una de estas funciones, ejecutará la subrutina que tiene asociada." .

ns1:SubrutinaOEMG399 a ns1:AccionProhibida ;
    rdfs:label "Subrutina OEM G399" ;
    ns1:textoExtracto "Estas subrutinas OEM se podrán ejecutar de forma no-modal o de forma modal, y además permite inicializar los parámetros locales de la subrutina." .

