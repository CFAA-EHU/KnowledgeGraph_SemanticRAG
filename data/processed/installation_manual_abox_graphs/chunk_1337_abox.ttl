@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:DMC a ex:Sistema ;
    rdfs:label "DMC" ;
    ex:textoExtracto "El DMC escribirá en la variable (V.)G.LEARNEDPWRSP el valor de la potencia objetivo obtenida en la fase de aprendizaje" ;
    ex:tieneComponente ex:Variable_G_LEARNEDPWRSP .

ex:Variable_G_LEARNEDPWRSP a ex:Parametro ;
    rdfs:label "G.LEARNEDPWRSP" ;
    ex:textoExtracto "(V.)G.LEARNEDPWRSP el valor de la potencia objetivo obtenida en la fase de aprendizaje" .

ex:Aviso_3103 a ex:AvisoSeguridad ;
    rdfs:label "aviso 3103" ;
    ex:textoExtracto "Si el DMC detecta una situación de este tipo, muestra el aviso 3103" .

ex:Override_de_avance a ex:Parametro ;
    rdfs:label "override de avance" ;
    ex:textoExtracto "el DMC adapta el avance modificando el override" .