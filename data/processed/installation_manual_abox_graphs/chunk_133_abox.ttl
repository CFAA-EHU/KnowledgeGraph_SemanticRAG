@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TiempoEstimadoParaLaEjecucionDeUnaFuncionM a ns1:Parametro ;
    rdfs:label "tiempo estimado para la ejecución de una función M" ;
    ns1:identificador "MTIME" ;
    ns1:textoExtracto "El parámetro máquina de la tabla de funciones –M– MTIME indica el tiempo estimado para la ejecución de una función M." .

ns1:TiempoEstimadoParaLaEjecucionDeUnaFuncionS a ns1:Parametro ;
    rdfs:label "tiempo estimado para la ejecución de una función S" ;
    ns1:identificador "SPDLTIME" ;
    ns1:textoExtracto "El parámetro máquina de cabezales SPDLTIME indica el tiempo estimado para la ejecución de una función S." .

