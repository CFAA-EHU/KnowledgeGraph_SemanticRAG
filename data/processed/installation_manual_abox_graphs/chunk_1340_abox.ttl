@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazUsuario_DMC_ModoAutomatico
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de usuario DMC (modo automático)"@es ;
    ex:textoExtracto "Durante la ejecución de un programa con el DMC activo, el modo automático puede mostrar el estado y el progreso de esta función; para ello, en la softkey \"Visualizar\" del menú horizontal, seleccionar la opción \"DMC\"."@es ;
    ex:ilustradoEn ex:Pagina_730_731 .

ex:Pagina_730_731
    a ex:Pagina ;
    rdfs:label "Páginas 730-731: Modo automático. Estado y progreso del DMC"@es ;
    ex:textoExtracto "Modo automático. Estado y progreso del DMC. A I F A B C B E D C D E F G H J A Estado del DMC; ON/OFF. B Override del DMC. [...] J Override final (override del DMC + override del conmutador)."@es ;
    ex:identificador "730-731" .

ex:Parametro_EstadoDMC
    a ex:Parametro ;
    rdfs:label "Estado del DMC (ON/OFF)"@es ;
    ex:textoExtracto "A Estado del DMC; ON/OFF."@es ;
    ex:monitoreaParametro ex:InterfazUsuario_DMC_ModoAutomatico .

ex:Parametro_OverrideDMC
    a ex:Parametro ;
    rdfs:label "Override del DMC"@es ;
    ex:textoExtracto "B Override del DMC. Los límites de la barra de consumo serán los definidos en los parámetros máquina."@es ;
    ex:monitoreaParametro ex:InterfazUsuario_DMC_ModoAutomatico .

ex:Parametro_AvancePorDiente
    a ex:Parametro ;
    rdfs:label "Avance por diente (FZMIN/FZMAX)"@es ;
    ex:textoExtracto "C Avance por diente. Los límites de la barra de consumo son los valores programados en la sentencia #DMCON (comandos FZMIN y FZMAX)."@es ;
    ex:monitoreaParametro ex:InterfazUsuario_DMC_ModoAutomatico .

ex:Parametro_PotenciaConsumidaCabezal
    a ex:Parametro ;
    rdfs:label "Potencia consumida por el cabezal (%)"@es ;
    ex:textoExtracto "D Potencia consumida por el cabezal (definida como porcentaje de la potencia nominal)."@es ;
    ex:monitoreaParametro ex:InterfazUsuario_DMC_ModoAutomatico .

ex:Parametro_PotenciaObjetivo
    a ex:Parametro ;
    rdfs:label "Potencia objetivo (PWRSP, %)"@es ;
    ex:textoExtracto "F Potencia objetivo o potencia de corte idónea (definida como porcentaje de la potencia nominal); potencia aprendida o potencia programada en la sentencia #DMCON (comando PWRSP)."@es ;
    ex:monitoreaParametro ex:InterfazUsuario_DMC_ModoAutomatico .

ex:Parametro_PotenciaVacio
    a ex:Parametro ;
    rdfs:label "Potencia en vacío (%)"@es ;
    ex:textoExtracto "G Potencia en vacío (definida como porcentaje de la potencia nominal)."@es ;
    ex:monitoreaParametro ex:InterfazUsuario_DMC_ModoAutomatico .

ex:Parametro_TiempoAhorradoDMC
    a ex:Parametro ;
    rdfs:label "Tiempo ahorrado por acción del DMC"@es ;
    ex:textoExtracto "H Tiempo ahorrado por acción del DMC."@es ;
    ex:monitoreaParametro ex:InterfazUsuario_DMC_ModoAutomatico .

ex:Parametro_OverrideFinal
    a ex:Parametro ;
    rdfs:label "Override final (DMC + conmutador)"@es ;
    ex:textoExtracto "J Override final (override del DMC + override del conmutador)."@es ;
    ex:monitoreaParametro ex:InterfazUsuario_DMC_ModoAutomatico .

ex:ModoOperacion_DMC_Activo
    a ex:ModoOperacion ;
    rdfs:label "Modo DMC activo"@es ;
    ex:textoExtracto "Cuando el DMC está activo, la historia del programa mostrará \"DMC\", y no cambiará aunque el CNC ejecute funciones incompatibles que desactiven temporalmente el DMC."@es ;
    ex:documentadoEn ex:Pagina_730_731 .

ex:TareaMantenimiento_RepetirAprendizajeDMC
    a ex:TareaMantenimiento ;
    rdfs:label "Repetir fase de aprendizaje del DMC"@es ;
    ex:textoExtracto "Opciones del DMC (menú desplegable): Repetir la fase de aprendizaje del DMC."@es ;
    ex:documentadoEn ex:Pagina_730_731 .

ex:TareaMantenimiento_DesactivarDMC
    a ex:TareaMantenimiento ;
    rdfs:label "Desactivar DMC"@es ;
    ex:textoExtracto "Opciones del DMC (menú desplegable): Desactivar el DMC."@es ;
    ex:documentadoEn ex:Pagina_730_731 .