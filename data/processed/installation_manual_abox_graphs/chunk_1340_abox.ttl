@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:DMC a ex:Sistema ;
    rdfs:label "DMC" ;
    ex:textoExtracto "Durante la ejecución de un programa con el DMC activo, el modo automático puede mostrar el estado y el progreso de esta función" ;
    ex:compuestoPor ex:SoftkeyVisualizar, ex:PaginaDMC, ex:ParametroOverrideDMC, ex:ParametroAvancePorDiente, ex:ParametroPotenciaConsumidaCabezal, ex:ParametroPotenciaObjetivo, ex:ParametroPotenciaVacio, ex:ParametroTiempoAhorrado, ex:ParametroOverrideFinal, ex:SoftkeyOpcionesDMC .

ex:SoftkeyVisualizar a ex:InterfazUsuario ;
    rdfs:label "Softkey Visualizar" ;
    ex:textoExtracto "en la softkey 'Visualizar' del menú horizontal, seleccionar la opción 'DMC'" .

ex:PaginaDMC a ex:InterfazUsuario ;
    rdfs:label "Página DMC" ;
    ex:textoExtracto "Los datos que muestra la página DMC son los mismos que los de la página estándar, excepto los propios del DMC (zona superior izquierda)" .

ex:ParametroOverrideDMC a ex:Parametro ;
    rdfs:label "Override del DMC" ;
    ex:textoExtracto "Override del DMC. Los límites de la barra de consumo serán los definidos en los parámetros máquina. A la derecha se muestra el override aplicado por el DMC." ;
    ex:valor "ON/OFF" .

ex:ParametroAvancePorDiente a ex:Parametro ;
    rdfs:label "Avance por diente" ;
    ex:textoExtracto "Avance por diente. Los límites de la barra de consumo son los valores programados en la sentencia #DMCON (comandos FZMIN y FZMAX)" .

ex:ParametroPotenciaConsumidaCabezal a ex:Parametro ;
    rdfs:label "Potencia consumida por el cabezal" ;
    ex:textoExtracto "Potencia consumida por el cabezal (definida como porcentaje de la potencia nominal)" .

ex:ParametroPotenciaObjetivo a ex:Parametro ;
    rdfs:label "Potencia objetivo" ;
    ex:textoExtracto "Potencia objetivo o potencia de corte idónea (definida como porcentaje de la potencia nominal)" .

ex:ParametroPotenciaVacio a ex:Parametro ;
    rdfs:label "Potencia en vacío" ;
    ex:textoExtracto "Potencia en vacío (definida como porcentaje de la potencia nominal)" .

ex:ParametroTiempoAhorrado a ex:Parametro ;
    rdfs:label "Tiempo ahorrado" ;
    ex:textoExtracto "Tiempo ahorrado por acción del DMC" .

ex:ParametroOverrideFinal a ex:Parametro ;
    rdfs:label "Override final" ;
    ex:textoExtracto "Override final (override del DMC + override del conmutador)" .

ex:SoftkeyOpcionesDMC a ex:InterfazUsuario ;
    rdfs:label "Softkey Opciones DMC" ;
    ex:textoExtracto "Opciones del DMC (menú desplegable). • Repetir la fase de aprendizaje del DMC. • Desactivar el DMC." .