@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:controla ns1:SubrutinaInterrupcion ;
    ns1:textoExtracto "Las subrutinas de interrupción las define el fabricante de la máquina y se ejecutan desde el PLC." .

ns1:SubrutinaInterrupcion a ns1:AccionProhibida ;
    rdfs:label "Subrutina de interrupción" ;
    ns1:textoExtracto "Cuando el PLC ordena la ejecución de una de estas subrutinas, el canal interrumpe la ejecución del programa y ejecuta la subrutina de interrupción correspondiente." .

