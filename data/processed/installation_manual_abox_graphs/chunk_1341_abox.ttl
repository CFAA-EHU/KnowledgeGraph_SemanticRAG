ns1:SubrutinaDeInterrupcionParaElCanal a ns1:Parametro ;
    rdfs:label "Subrutina de interrupción para el canal" ;
    ns1:identificador "INT1SUB CHN" ;
    ns1:textoExtracto "INT1SUB CHN... Subrutinas de interrupción." .

ns1:SubrutinaDeInterrupcionParaElCanal_3665df83c0 a ns1:Parametro ;
    rdfs:label "Subrutina de interrupción para el canal" ;
