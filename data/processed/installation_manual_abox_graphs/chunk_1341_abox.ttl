@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Softkey_DMC_RepetirAprendizaje rdfs:label "Softkey para repetir fase de aprendizaje del DMC" ;
    a ex:InterfazUsuario ;
    ex:textoExtracto "Esta softkey permite repetir la fase de aprendizaje del DMC en cualquier momento, siempre que el DMC esté activo." .

ex:Softkey_DMC_Desactivar rdfs:label "Softkey para desactivar el DMC" ;
    a ex:InterfazUsuario ;
    ex:textoExtracto "Esta softkey permite desactivar el DMC." .

ex:Softkey_DMC_Reactivar rdfs:label "Softkey para re-activar el DMC" ;
    a ex:InterfazUsuario ;
    ex:textoExtracto "Esta softkey permite re-activar el DMC." .