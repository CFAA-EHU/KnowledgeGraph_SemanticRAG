@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PorcentajeAvance_1342_732 a ex:Parametro ;
    rdfs:label "Porcentaje de avance (feed override)" ;
    ex:textoExtracto "El porcentaje de avance (feed override) se puede fijar, de más a más prioridad, por programa (variable V.G.PRGFRO), por PLC (variable V.PLC.FRO) o desde el conmutador del panel de mando." ;
    ex:valor "fijado por programa, PLC o conmutador del panel de mando" .

ex:VariablePrograma_1342_732 a ex:Parametro ;
    rdfs:label "Variable V.G.PRGFRO" ;
    ex:identificador "V.G.PRGFRO" ;
    ex:textoExtracto "por programa (variable V.G.PRGFRO)" .

ex:VariablePLC_1342_732 a ex:Parametro ;
    rdfs:label "Variable V.PLC.FRO" ;
    ex:identificador "V.PLC.FRO" ;
    ex:textoExtracto "por PLC (variable V.PLC.FRO)" .

ex:ConmutadorPanelMando_1342_732 a ex:InterfazUsuario ;
    rdfs:label "Conmutador del panel de mando" ;
    ex:textoExtracto "desde el conmutador del panel de mando" .

ex:VariableDMC_1342_732 a ex:Parametro ;
    rdfs:label "Variable DMC" ;
    ex:identificador "DMC" ;
    ex:textoExtracto "El porcentaje fijado por el DMC afecta al porcentaje fijado desde el conmutador." .

ex:SentenciaDMCON_1342_732 a ex:Esquema ;
    rdfs:label "#DMCON" ;
    ex:identificador "#DMCON" ;
    ex:textoExtracto "dentro de los límites fijados por la sentencia #DMCON (comandos OVRMIN, OVRMAX)" .

ex:ParametroMINDMCOVR_1342_732 a ex:Parametro ;
    rdfs:label "MINDMCOVR" ;
    ex:identificador "MINDMCOVR" ;
    ex:textoExtracto "los límites estarán fijados por los parámetros máquina MINDMCOVR y MAXDMCOVR" .

ex:ParametroMAXDMCOVR_1342_732 a ex:Parametro ;
    rdfs:label "MAXDMCOVR" ;
    ex:identificador "MAXDMCOVR" ;
    ex:textoExtracto "los límites estarán fijados por los parámetros máquina MINDMCOVR y MAXDMCOVR" .

ex:ParametroMAXOVR_1342_732 a ex:Parametro ;
    rdfs:label "MAXOVR" ;
    ex:identificador "MAXOVR" ;
    ex:textoExtracto "El CNC siempre respeta el límite máximo definido en el parámetro máquina MAXOVR" .

ex:ComandoOVRMIN_1342_732 a ex:Parametro ;
    rdfs:label "OVRMIN" ;
    ex:identificador "OVRMIN" ;
    ex:textoExtracto "comandos OVRMIN, OVRMAX" .

ex:ComandoOVRMAX_1342_732 a ex:Parametro ;
    rdfs:label "OVRMAX" ;
    ex:identificador "OVRMAX" ;
    ex:textoExtracto "comandos OVRMIN, OVRMAX" .

ex:ParametroFZMIN_1342_732 a ex:Parametro ;
    rdfs:label "FZMIN" ;
    ex:identificador "FZMIN" ;
    ex:textoExtracto "el avance por diente mínimo y máximo fijado para la herramienta en la sentencia #DMCON (comandos FZMIN, FZMAX)" .

ex:ParametroFZMAX_1342_732 a ex:Parametro ;
    rdfs:label "FZMAX" ;
    ex:identificador "FZMAX" ;
    ex:textoExtracto "el avance por diente mínimo y máximo fijado para la herramienta en la sentencia #DMCON (comandos FZMIN, FZMAX)" .

ex:PorcentajeAvance_1342_732 ex:tieneComponente ex:VariablePrograma_1342_732 ;
    ex:tieneComponente ex:VariablePLC_1342_732 ;
    ex:tieneComponente ex:ConmutadorPanelMando_1342_732 ;
    ex:tieneComponente ex:VariableDMC_1342_732 ;
    ex:tieneComponente ex:SentenciaDMCON_1342_732 ;
    ex:tieneComponente ex:ParametroMINDMCOVR_1342_732 ;
    ex:tieneComponente ex:ParametroMAXDMCOVR_1342_732 ;
    ex:tieneComponente ex:ParametroMAXOVR_1342_732 ;
    ex:tieneComponente ex:ComandoOVRMIN_1342_732 ;
    ex:tieneComponente ex:ComandoOVRMAX_1342_732 ;
    ex:tieneComponente ex:ParametroFZMIN_1342_732 ;
    ex:tieneComponente ex:ParametroFZMAX_1342_732 .