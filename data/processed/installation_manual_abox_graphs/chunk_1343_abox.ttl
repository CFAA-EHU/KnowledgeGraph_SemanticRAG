@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_c7cce956a2 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:ejecuta ns1:OperacionesInicialesDelLaser ;
    ns1:textoExtracto "CNC 8070" .

ns1:ConfiguracionDeSubrutinaLaser a ns1:TareaMantenimiento ;
    rdfs:label "Configuración de subrutina láser" ;
    ns1:textoExtracto "Las subrutinas suministradas por Fagor ofrecen una gestión básica del láser, por lo que deben ser configuradas de forma apropiada por el OEM." .

ns1:NoGarantizarAspectosDeSeguridadDelLaser a ns1:AccionProhibida ;
    rdfs:label "No garantizar aspectos de seguridad del láser" ;
    ns1:textoExtracto "Es responsabilidad del OEM garantizar que la subrutina cumple todos los aspectos de seguridad relativos al manejo del láser." .

ns1:OperacionesInicialesDelLaser a ns1:TareaMantenimiento ;
    rdfs:label "Operaciones iniciales del láser" ;
    ns1:textoExtracto "Este comando está orientado a máquina láser, donde esta subrutina debe realizar las operaciones iniciales del láser." .

