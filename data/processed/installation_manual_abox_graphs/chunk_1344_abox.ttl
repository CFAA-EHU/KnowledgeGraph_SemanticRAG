@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Parametros de Maquina (DMC)
ex:MINDMCOVR
    a ex:Parametro ;
    rdfs:label "MINDMCOVR" ;
    ex:identificador "MINDMCOVR" ;
    ex:valor "65" ;
    ex:textoExtracto "Mínimo override DMC de todos los ejes del canal. Valor: 65 %." .

ex:MAXDMCOVR
    a ex:Parametro ;
    rdfs:label "MAXDMCOVR" ;
    ex:identificador "MAXDMCOVR" ;
    ex:valor "135" ;
    ex:textoExtracto "Máximo override DMC de todos los ejes del canal. Valor: 135 %." .

### Modo de Operacion (DMC)
ex:ModoDMC
    a ex:ModoOperacion ;
    rdfs:label "Dynamic Machining Control (DMC)" ;
    ex:textoExtracto "Modo automático. Estado y progreso del DMC." ;
    ex:monitoreaParametro ex:MINDMCOVR, ex:MAXDMCOVR .

### Tabla de Informacion DMC
ex:TablaInfoDMC a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Información del modo automático DMC" ;
    ex:textoExtracto "A Estado del DMC; ON/OFF. B Override del DMC; mínimo = 65 %, máximo = 135, override activo = 124 %. C Avance por diente; mínimo 0.08, máximo 0.15, activo = 0.15 mm/diente. D Consumo de potencia; consumo instantáneo = 20,85 %. E Potencia a alcanzar en condiciones idóneas; 37.69 %. F Potencia objetivo aprendida; 34,73 %. G Potencia en vacío; 2.96 %. H Tiempo ahorrado por acción del DMC." ;
    ex:documentadoEn [
        a ex:Pagina ;
        ex:identificador "733-734"
    ] .

### Parametros Dinamicos (Fase de Aprendizaje)
ex:PotenciaEnVacio
    a ex:Parametro ;
    rdfs:label "No load power" ;
    ex:valor "2.96" ;
    ex:textoExtracto "No load power (potencia en vacío). 2.96 %" ;
    ex:documentadoEn ex:TablaInfoDMC .

ex:PotenciaObjetivoAprendida
    a ex:Parametro ;
    rdfs:label "PowerSetPoint" ;
    ex:valor "34.73" ;
    ex:textoExtracto "PowerSetPoint (potencia objetivo aprendida). 34.73 %" ;
    ex:documentadoEn ex:TablaInfoDMC .

### Esquema de Osciloscopio
ex:EsquemaOsciloscopioDMC
    a ex:Esquema ;
    rdfs:label "Captura del osciloscopio (DMC)" ;
    ex:textoExtracto "A Control del override para optimizar la potencia. B Mecanizado en G00. C Entrada a la pieza. D Movimiento en vacío; override máximo (parámetro máquina MAXDMCOVR)." ;
    ex:ilustradoEn [
        a ex:Pagina ;
        ex:identificador "734"
    ] ;
    ex:detalladoEnEsquema ex:MAXDMCOVR .