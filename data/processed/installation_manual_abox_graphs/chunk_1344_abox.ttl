@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MINDMCOVR a ex:Parametro ;
    rdfs:label "MINDMCOVR" ;
    ex:identificador "MINDMCOVR" ;
    ex:valor "65 %" ;
    ex:textoExtracto "Mínimo override DMC de todos los ejes del canal. Valor: 65 %." .

ex:MAXDMCOVR a ex:Parametro ;
    rdfs:label "MAXDMCOVR" ;
    ex:identificador "MAXDMCOVR" ;
    ex:valor "135 %" ;
    ex:textoExtracto "Máximo override DMC de todos los ejes del canal. Valor: 135 %." .

ex:DMC a ex:ModoOperacion ;
    rdfs:label "DMC" ;
    ex:textoExtracto "Sentencia para activar el DMC. # DMC ON [FZMAX 0.15, FZMIN 0.08] • No está programada la potencia objetivo; el DMC ejecuta la fase de aprendizaje. • El avance mínimo está limitado a 0.08 mm/diente; con las condiciones de corte F y S programadas, equivale a un 67 % de override mínimo. • El avance máximo está limitado a 0.15 mm/diente; con las condiciones de corte F y S programadas, equivale a un 125 % de override máximo." .

ex:FZMAX a ex:Parametro ;
    rdfs:label "FZMAX" ;
    ex:identificador "FZMAX" ;
    ex:valor "0.15" ;
    ex:textoExtracto "FZMAX 0.15" .

ex:FZMIN a ex:Parametro ;
    rdfs:label "FZMIN" ;
    ex:identificador "FZMIN" ;
    ex:valor "0.08" ;
    ex:textoExtracto "FZMIN 0.08" .

ex:NoLoadPower a ex:Parametro ;
    rdfs:label "NoLoadPower" ;
    ex:valor "2.96 %" ;
    ex:textoExtracto "No load power (potencia en vacío). 2.96 %" .

ex:PowerSetPoint a ex:Parametro ;
    rdfs:label "PowerSetPoint" ;
    ex:valor "34.73 %" ;
    ex:textoExtracto "PowerSetPoint (potencia objetivo aprendida). 34.73 %" .

ex:PotenciaObjetivoAprendida a ex:Parametro ;
    rdfs:label "PotenciaObjetivoAprendida" ;
    ex:valor "34,73 %" ;
    ex:textoExtracto "Potencia objetivo aprendida; 34,73 %." .

ex:PotenciaEnVacio a ex:Parametro ;
    rdfs:label "PotenciaEnVacio" ;
    ex:valor "2.96 %" ;
    ex:textoExtracto "Potencia en vacío; 2.96 %." .

ex:PotenciaAAlcanzar a ex:Parametro ;
    rdfs:label "PotenciaAAlcanzar" ;
    ex:valor "37.69 %" ;
    ex:textoExtracto "Potencia a alcanzar en condiciones idóneas; 37.69 % \"potencia objetivo\" + \"potencia en vacío\"." .

ex:TiempoAhorradoDMC a ex:Parametro ;
    rdfs:label "TiempoAhorradoDMC" ;
    ex:valor "H Tiempo ahorrado por acción del DMC." ;
    ex:textoExtracto "H Tiempo ahorrado por acción del DMC." .

ex:ConsumoPotencia a ex:Parametro ;
    rdfs:label "ConsumoPotencia" ;
    ex:valor "20,85 %" ;
    ex:textoExtracto "Consumo de potencia; consumo instantáneo = 20,85 %" .

ex:OverrideActivo a ex:Parametro ;
    rdfs:label "OverrideActivo" ;
    ex:valor "124 %" ;
    ex:textoExtracto "Override del DMC; mínimo = 65 %, máximo = 135, override activo = 124 %." .

ex:AvancePorDiente a ex:Parametro ;
    rdfs:label "AvancePorDiente" ;
    ex:valor "0.15 mm/diente" ;
    ex:textoExtracto "Avance por diente; mínimo 0.08, máximo 0.15, activo = 0.15 mm/diente." .

ex:Osciloscopio a ex:Herramienta ;
    rdfs:label "Osciloscopio" ;
    ex:textoExtracto "Captura del osciloscopio. Osciloscopio." .