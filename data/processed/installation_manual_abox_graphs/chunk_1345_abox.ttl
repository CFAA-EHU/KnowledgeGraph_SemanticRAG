ex:Figura_18_4_4_Osciloscopio
    a ex:Figura ;
    rdfs:label "Captura del osciloscopio (Sección 18.4.4)"@es ;
    ex:textoExtracto "Captura del osciloscopio. Osciloscopio. D E A F B C A Control del override para optimizar la potencia."@es ;
    ex:ilustradoEn ex:Pagina_733 .

ex:Parametro_MAXDMCOVR
    a ex:Parametro ;
    rdfs:label "Override máximo (parámetro máquina MAXDMCOVR)"@es ;
    ex:identificador "MAXDMCOVR" ;
    ex:textoExtracto "Movimiento en vacío; override máximo (parámetro máquina MAXDMCOVR)."@es ;
    ex:monitoreaParametro ex:Sistema_Override .

ex:Sistema_Override
    a ex:Sistema ;
    rdfs:label "Sistema de control de override para optimización de potencia"@es ;
    ex:textoExtracto "Control del override para optimizar la potencia."@es ;
    ex:detalladoEnEsquema ex:Figura_18_4_4_Osciloscopio .

