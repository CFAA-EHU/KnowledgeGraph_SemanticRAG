@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_91dd135e92 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:ConfiguracionDeSubrutinaLaser,
        ns1:GestionDeLaMarcaPIERCING,
        ns1:GestionDeSeguridadDelLaser,
        ns1:OperacionesInicialesDelPiercing ;
    ns1:textoExtracto "CNC 8070" .

ns1:VariableDelPiercing a ns1:Parametro ;
    rdfs:label "Variable del piercing" ;
    ns1:identificador "TTPIR.name" ;
    ns1:textoExtracto "El comando #PIERCING ejecuta la subrutina que tiene asociada después de actualizar las variables del piercing ((V.)TTPIR.name)." .

ns1:ConfiguracionDeSubrutinaLaser a ns1:TareaMantenimiento ;
    rdfs:label "Configuración de subrutina láser" ;
    ns1:textoExtracto "Las subrutinas suministradas por Fagor ofrecen una gestión básica del láser, por lo que deben ser configuradas de forma apropiada por el OEM." .

ns1:GestionDeLaMarcaPIERCING a ns1:AccionProhibida ;
    rdfs:label "Gestión de la marca PIERCING" ;
    ns1:textoExtracto "El OEM debe gestionar la marca PIERCING desde esta subrutina. Al comienzo de la subrutina (o cuando el OEM lo considere necesario), el OEM debe activar la marca PIERCING (asignarle valor 1) para indicar al PLC que empieza la operación de piercing." .

ns1:GestionDeSeguridadDelLaser a ns1:AccionProhibida ;
    rdfs:label "Gestión de seguridad del láser" ;
    ns1:textoExtracto "Es responsabilidad del OEM garantizar que la subrutina cumple todos los aspectos de seguridad relativos al manejo del láser." .

ns1:OperacionesInicialesDelPiercing a ns1:TareaMantenimiento ;
    rdfs:label "Operaciones iniciales del piercing" ;
    ns1:textoExtracto "Este comando está orientado a máquina láser, donde esta subrutina debe realizar las operaciones iniciales del piercing." .

