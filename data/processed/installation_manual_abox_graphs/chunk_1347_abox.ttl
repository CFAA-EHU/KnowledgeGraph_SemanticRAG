@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ProgramacionONOFF ex:textoExtracto "Es obligatorio programar ON/OFF." ;
    a ex:AccionProhibida .

ex:ComandoON ex:textoExtracto "#DMCON [...]" ;
    a ex:Parametro .

ex:ComandoOFF ex:textoExtracto "#DMC OFF" ;
    a ex:Parametro .

ex:ParametroDMCSPDL ex:textoExtracto "DMCSPDL = Sí" ;
    a ex:Parametro .

ex:Potencia ex:textoExtracto "3100 Potencia" ;
    a ex:Parametro .