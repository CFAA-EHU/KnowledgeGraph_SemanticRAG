@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDeLaOperacionDePiercing a ns1:Parametro ;
    rdfs:label "Estado de la operación de piercing" ;
    ns1:documentadoEn ns1:SubrutinaPiercing ;
    ns1:identificador "V.PLC.PIERCING" ;
    ns1:textoExtracto "Esta marca refleja el estado de la variable V.PLC.PIERCING." .

ns1:SentenciaPLC a ns1:AccionProhibida ;
    rdfs:label "#PLC" ;
    ns1:textoExtracto "La sentencia #PLC permite gestionar una marca de PLC desde el programa pieza o subrutina, sin detener la preparación de bloques." .

ns1:SubrutinaPiercing a ns1:Sistema ;
    rdfs:label "Subrutina Piercing.fst" ;
    ns1:textoExtracto "La subrutina asociada al piercing (por defecto, Piercing.fst)" .

