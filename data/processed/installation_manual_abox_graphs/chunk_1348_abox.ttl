    ns1:identificador "CHN" ;
    ns1:textoExtracto "[CHN].......Parámetro máquina; general del canal. Nombre y ubicación de la subrutina." .

ns1:SubrutinaAsociadaAlComandoPIERCING a ns1:Parametro ;
