@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:DMC a ex:Sistema ;
    rdfs:label "DMC" ;
    ex:textoExtracto "DMC" .

ex:Parametro_DMCSPDL a ex:Parametro ;
    rdfs:label "DMCSPDL" ;
    ex:textoExtracto "parámetro máquina DMCSPDL=Sí" .

ex:Error_3100 a ex:DiagnosticoFallo ;
    rdfs:label "3100" ;
    ex:textoExtracto "3100 Potencia excesiva en el cabezal detectada durante DMC." ;
    ex:valor "3100" .

ex:Error_3101 a ex:DiagnosticoFallo ;
    rdfs:label "3101" ;
    ex:textoExtracto "3101 Potencia excesiva en el cabezal detectada durante DMC." ;
    ex:valor "3101" .

ex:Error_3103 a ex:DiagnosticoFallo ;
    rdfs:label "3103" ;
    ex:textoExtracto "3103 Potencia objetivo insuficiente para el funcionamiento correcto con DMC." ;
    ex:valor "3103" .

ex:TV51 a ex:Parametro ;
    rdfs:label "TV51" ;
    ex:textoExtracto "variable TV51 del regulador" .

ex:CNC a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "CNC" .

ex:Herramienta a ex:PiezaRecambio ;
    rdfs:label "herramienta" ;
    ex:textoExtracto "herramienta" .

ex:ModoInspeccionHerramienta a ex:ModoOperacion ;
    rdfs:label "modo inspección de herramienta" ;
    ex:textoExtracto "entrar en modo inspección de herramienta" .