@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:GraficoF3D a ex:InterfazUsuario ;
    rdfs:label "gráficos F3D" ;
    ex:textoExtracto "En los gráficos F3D hay que cargar la configuración máquina (archivo xca) correspondiente a la configuración de ejes definida." .

ex:ArchivoXCA_1 a ex:Esquema ;
    rdfs:label "archivo xca" ;
    ex:identificador "xca" ;
    ex:textoExtracto "archivo xca" .

ex:CarpetaMachinesMill a ex:Esquema ;
    rdfs:label "carpeta ../Fagor/Grafdata/Machines/Mill" ;
    ex:textoExtracto "En la carpeta ../Fagor/Grafdata/Machines/Mill están los archivos de configuración para máquinas con plato divisor." .

ex:MaquinaConPlatoDivisor a ex:Maquina ;
    rdfs:label "máquina con plato divisor" ;
    ex:textoExtracto "los archivos de configuración para máquinas con plato divisor" .

ex:EjeRotativoMesa a ex:ComponenteMecanico ;
    rdfs:label "eje rotativo de la mesa (plato divisor)" ;
    ex:textoExtracto "eje rotativo de la mesa (plato divisor)" .

ex:EjeRotativoCabezal_1 a ex:ComponenteMecanico ;
    rdfs:label "eje rotativo en el cabezal" ;
    ex:textoExtracto "tienen otros dos ejes rotativos en el cabezal" .

ex:EjeRotativoCabezal_2 a ex:ComponenteMecanico ;
    rdfs:label "eje rotativo en el cabezal" ;
    ex:textoExtracto "tienen otros dos ejes rotativos en el cabezal" .

ex:GraficoF3D ex:compuestoPor ex:ArchivoXCA_1 ;
    ex:textoExtracto "En los gráficos F3D hay que cargar la configuración máquina (archivo xca) correspondiente a la configuración de ejes definida." .

ex:CarpetaMachinesMill ex:compuestoPor ex:MaquinaConPlatoDivisor ;
    ex:textoExtracto "En la carpeta ../Fagor/Grafdata/Machines/Mill están los archivos de configuración para máquinas con plato divisor." .

ex:MaquinaConPlatoDivisor ex:tieneComponente ex:EjeRotativoMesa, ex:EjeRotativoCabezal_1, ex:EjeRotativoCabezal_2 ;
    ex:textoExtracto "todas las configuraciones están diseñadas para un canal, y además del eje rotativo de la mesa (plato divisor), tienen otros dos ejes rotativos en el cabezal." .