@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IndiceBaseDeLosModulosDeEntradasDigitales a ns1:Parametro ;
    rdfs:label "Índice base de los módulos de entradas digitales" ;
    ns1:identificador "DIMOD[n]" ;
    ns1:textoExtracto "DIMOD n Índice base de los módulos de entradas digitales. Valores posibles: De 0 a 1009." .

ns1:NumeroTotalDeModulosDeEntradasDigitales a ns1:Parametro ;
    rdfs:label "Número total de módulos de entradas digitales" ;
    ns1:identificador "MPG.NDIMOD" ;
    ns1:textoExtracto "NDIMOD Número total de módulos de entradas digitales. Valores posibles: De 0 a 64." .

ns1:TablaDeModulosDeEntradasDigitales a ns1:Parametro ;
    rdfs:label "Tabla de módulos de entradas digitales" ;
    ns1:identificador "DIMODADDR" ;
    ns1:textoExtracto "DIMODADDR Tabla de módulos de entradas digitales. Este parámetro muestra la lista de módulos de entradas digitales conectados en el mismo bus CAN." .

