@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EntradaAnalogica_1 a ex:Sensor ;
    rdfs:label "Entradas analógicas" ;
    ex:textoExtracto "address = 0) CNC • (address = 1) RIO5 - Entradas analógicas. - 1..4 - Entradas PT100." ;
    ex:identificador "address = 0" ;
    ex:identificador "address = 1" ;
    ex:identificador "RIO5" .

ex:EntradaAnalogica_2 a ex:Sensor ;
    rdfs:label "Entradas analógicas" ;
    ex:textoExtracto "address = 2) RIOR - Entradas analógicas. - 7..8 - Entradas PT100." ;
    ex:identificador "address = 2" ;
    ex:identificador "RIOR" .

ex:ParametroPT100_1 a ex:Parametro ;
    rdfs:label "PT100 1" ;
    ex:textoExtracto "PT100 1 = 5" ;
    ex:valor "5" .

ex:ParametroPT100_2 a ex:Parametro ;
    rdfs:label "PT100 2" ;
    ex:textoExtracto "PT100 2 = 6" ;
    ex:valor "6" .

ex:ParametroPT100_3 a ex:Parametro ;
    rdfs:label "PT100 3" ;
    ex:textoExtracto "PT100 3 = 9" ;
    ex:valor "9" .

ex:SistemaCNC a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "CNC" ;
    ex:identificador "address = 0" .

ex:SistemaRIO5 a ex:Sistema ;
    rdfs:label "RIO5" ;
    ex:textoExtracto "RIO5" ;
    ex:identificador "address = 1" .

ex:SistemaRIOR a ex:Sistema ;
    rdfs:label "RIOR" ;
    ex:textoExtracto "RIOR" ;
    ex:identificador "address = 2" .