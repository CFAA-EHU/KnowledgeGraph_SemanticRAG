@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivacionDeMarcaCUTTING a ns1:TareaMantenimiento ;
    rdfs:label "Activación de marca CUTTING" ;
    ns1:textoExtracto "el OEM debe activar la marca CUTTING (asignarle valor 1) para indicar al PLC que empieza la operación de cutting." .

ns1:GarantizarSeguridadEnSubrutinasLaser a ns1:AccionProhibida ;
    rdfs:label "Garantizar seguridad en subrutinas láser" ;
    ns1:documentadoEn ns1:ConfiguracionDeSubrutinasLaser ;
    ns1:textoExtracto "Es su responsabilidad del OEM garantizar que la subrutina cumple todos los aspectos de seguridad relativos al manejo del láser." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "indicar al PLC que empieza la operación de cutting." .

ns1:VariableDelCorteTTCUTName a ns1:Parametro ;
    rdfs:label "Variable del corte TTCUT.name" ;
    ns1:identificador "TTCUT.name" ;
    ns1:textoExtracto "El comando #CUTTINGON ejecuta la subrutina que tiene asociada después de actualizar las variables del cutting ((V.)TTCUT.name)." .

ns1:ConfiguracionDeSubrutinasLaser a ns1:TareaMantenimiento ;
    rdfs:label "Configuración de subrutinas láser" ;
    ns1:textoExtracto "Las subrutinas suministradas por Fagor ofrecen una gestión básica del láser, por lo que deben ser configuradas de forma apropiada por el OEM." .

