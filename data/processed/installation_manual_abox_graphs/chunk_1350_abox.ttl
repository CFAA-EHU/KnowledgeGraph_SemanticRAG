@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Tabla_1350_1 a ex:Tabla ;
    ex:textoExtracto """| Archivo. | Tipo de máquina. |
| --- | --- |
| Mill A@table B,C@spindle.xca | Máquina con plato divisor en X. |
| Mill B@table A,C@spindle.xca | Máquina con plato divisor en Y. |
| Mill C@table A,B@spindle.xca | Máquina con plato divisor en Z. |""" ;
    ex:tieneComponente ex:Mill_A_table_B_C_spindle_xca, ex:Mill_B_table_A_C_spindle_xca, ex:Mill_C_table_A_B_spindle_xca .

ex:Mill_A_table_B_C_spindle_xca a ex:Maquina ;
    ex:textoExtracto "Mill A@table B,C@spindle.xca | Máquina con plato divisor en X." ;
    rdfs:label "Mill A@table B,C@spindle.xca" ;
    ex:identificador "Mill A@table B,C@spindle.xca" .

ex:Mill_B_table_A_C_spindle_xca a ex:Maquina ;
    ex:textoExtracto "Mill B@table A,C@spindle.xca | Máquina con plato divisor en Y." ;
    rdfs:label "Mill B@table A,C@spindle.xca" ;
    ex:identificador "Mill B@table A,C@spindle.xca" .

ex:Mill_C_table_A_B_spindle_xca a ex:Maquina ;
    ex:textoExtracto "Mill C@table A,B@spindle.xca | Máquina con plato divisor en Z." ;
    rdfs:label "Mill C@table A,B@spindle.xca" ;
    ex:identificador "Mill C@table A,B@spindle.xca" .