@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ArchivoXCA_Mill_A_tableB_C_spindle
    a                  ex:InterfazUsuario ;
    rdfs:label         "Archivo de configuración Mill A@table B, C@spindle.xca" ;
    ex:textoExtracto   "Para un eje rotativo A está el archivo \"Mill A@table B, C@spindle.xca\", en el cual la traslación del eje está definida como {translation = \"0 0 0\"}. <Connection plug=\"stdPlug@A1\" socket=\"stdSocket@home\" translation=\"0 0 0\"/>" ;
    ex:identificador   "Mill A@table B, C@spindle.xca" .

ex:EjeRotativo_A1
    a                  ex:ComponenteMecanico ;
    rdfs:label         "Eje rotativo A1 (plato divisor)" ;
    ex:textoExtracto   "Eje 4: Eje rotativo del plato divisor. [...] <Connection plug=\"stdPlug@A1\" socket=\"stdSocket@home\" translation=\"-300 -100 -250\"/>" ;
    ex:identificador   "A1" ;
    ex:documentadoEn   ex:ArchivoXCA_Mill_A_tableB_C_spindle .

ex:EjeRotativo_Cabezal_PrimerEje
    a                  ex:ComponenteMecanico ;
    rdfs:label         "Primer eje rotativo del cabezal" ;
    ex:textoExtracto   "Eje 5: Primer eje rotativo del cabezal." ;
    ex:identificador   "Eje 5" .

ex:EjeRotativo_Cabezal_SegundoEje
    a                  ex:ComponenteMecanico ;
    rdfs:label         "Segundo eje rotativo del cabezal" ;
    ex:textoExtracto   "Eje 6: Segundo eje rotativo del cabezal." ;
    ex:identificador   "Eje 6" .

ex:EjeLineal_X
    a                  ex:ComponenteMecanico ;
    rdfs:label         "Eje lineal X" ;
    ex:textoExtracto   "Eje 1: X" ;
    ex:identificador   "Eje 1" .

ex:EjeLineal_Y
    a                  ex:ComponenteMecanico ;
    rdfs:label         "Eje lineal Y" ;
    ex:textoExtracto   "Eje 2: Y" ;
    ex:identificador   "Eje 2" .

ex:EjeLineal_Z
    a                  ex:ComponenteMecanico ;
    rdfs:label         "Eje lineal Z" ;
    ex:textoExtracto   "Eje 3: Z" ;
    ex:identificador   "Eje 3" .

ex:ArchivoDEF_Ejemplo
    a                  ex:InterfazUsuario ;
    rdfs:label         "Archivo DEF de configuración de ejes" ;
    ex:textoExtracto   "En la carpeta de cada máquina hay un archivo def de ejemplo. Si se van a copiar a otra carpeta, hay que copiar ambos archivos (xca y def)." ;
    ex:identificador   "*.def" ;
    ex:documentadoEn   ex:ArchivoXCA_Mill_A_tableB_C_spindle .

ex:CarpetaGrafdata_Mtb
    a                  ex:Sistema ;
    rdfs:label         "Directorio ../Mtb/Grafdata" ;
    ex:textoExtracto   "copiar ambos archivos (xca y def) a la carpeta ../Mtb/Grafdata o ../Users/Session/Grafdata y modificarlo de la siguiente manera." ;
    ex:identificador   "../Mtb/Grafdata" .

ex:CarpetaGrafdata_Users
    a                  ex:Sistema ;
    rdfs:label         "Directorio ../Users/Session/Grafdata" ;
    ex:textoExtracto   "copiar ambos archivos (xca y def) a la carpeta ../Mtb/Grafdata o ../Users/Session/Grafdata y modificarlo de la siguiente manera." ;
    ex:identificador   "../Users/Session/Grafdata" .

ex:Conexion_A1_Home
    a                  ex:ComponenteElectrico ;
    rdfs:label         "Conexión plug stdPlug@A1 a socket stdSocket@home" ;
    ex:textoExtracto   "<Connection plug=\"stdPlug@A1\" socket=\"stdSocket@home\" translation=\"-300 -100 -250\"/>" ;
    ex:identificador   "stdPlug@A1-stdSocket@home" ;
    ex:documentadoEn   ex:ArchivoXCA_Mill_A_tableB_C_spindle .

ex:Conexion_SYS_Tool1_S1
    a                  ex:ComponenteElectrico ;
    rdfs:label         "Conexión plug stdPlug@SYS-Tool1 a socket stdSocket@S1" ;
    ex:textoExtracto   "<Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@S1\" rotation=\"0 1 0 -90\"/>" ;
    ex:identificador   "stdPlug@SYS-Tool1-stdSocket@S1" ;
    ex:documentadoEn   ex:ArchivoXCA_Mill_A_tableB_C_spindle .