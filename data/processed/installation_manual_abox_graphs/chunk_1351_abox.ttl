@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDeLaOperacionDeCutting a ns1:Parametro ;
    rdfs:label "Estado de la operación de cutting" ;
    ns1:identificador "V.PLC.CUTTING" ;
    ns1:textoExtracto "Esta marca refleja el estado de la variable V.PLC.CUTTING." .

ns1:SentenciaPLC a ns1:Sistema ;
    rdfs:label "Sentencia #PLC" ;
    ns1:textoExtracto "La sentencia #PLC permite gestionar una marca de PLC desde el programa pieza o subrutina, sin detener la preparación de bloques. Escribir esta variable detiene la preparación de bloques." .

ns1:SubrutinaCUTTINGOFF a ns1:Sistema ;
    rdfs:label "Subrutina asociada al comando #CUTTING OFF" ;
    ns1:documentadoEn ns1:ManualDeProgramacion ;
    ns1:textoExtracto "Al final de la subrutina asociada a #CUTTING OFF (o cuando el OEM lo considere necesario), el OEM debe desactivar esta marca (asignarle valor 0) para indicar al CNC que ha finalizado la operación de piercing." .

ns1:SubrutinaCUTTINGON a ns1:Sistema ;
    rdfs:label "Subrutina asociada al comando #CUTTING ON" ;
    ns1:textoExtracto "El OEM también puede utilizar esta variable en las subrutinas asociadas al cutting (por defecto, Cuttingon.fst / Cuttingoff.fst), para modificar el estado de esta marca." .

