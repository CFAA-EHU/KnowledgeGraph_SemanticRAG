@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Eje4RotativoPlatoDivisor a ex:ComponenteMecanico ;
    rdfs:label "Eje 4: Eje rotativo del plato divisor" ;
    ex:textoExtracto "Eje 4: Eje rotativo del plato divisor" .

ex:PrimerEjeRotativoCabezal a ex:ComponenteMecanico ;
    rdfs:label "Primer eje rotativo del cabezal" ;
    ex:textoExtracto "Eje 5: Primer eje rotativo del cabezal" .

ex:SegundoEjeRotativoCabezal a ex:ComponenteMecanico ;
    rdfs:label "Segundo eje rotativo del cabezal" ;
    ex:textoExtracto "Eje 6: Segundo eje rotativo del cabezal" .

ex:EjeX a ex:ComponenteMecanico ;
    rdfs:label "Eje X" ;
    ex:textoExtracto "Eje 1: X" .

ex:EjeY a ex:ComponenteMecanico ;
    rdfs:label "Eje Y" ;
    ex:textoExtracto "Eje 2: Y" .

ex:EjeZ a ex:ComponenteMecanico ;
    rdfs:label "Eje Z" ;
    ex:textoExtracto "Eje 3: Z" .

ex:ArchivoXCA a ex:Esquema ;
    rdfs:label "Archivo xca" ;
    ex:textoExtracto "La configuración de ejes por defecto en los archivos xca es la siguiente." .

ex:ArchivoDEF a ex:Esquema ;
    rdfs:label "Archivo def" ;
    ex:textoExtracto "editar un segundo archivo (con el mismo nombre y extensión def), con la asociación correcta entre los ejes del CNC y los definidos en el archivo xca." .

ex:MillATableBCSpindle a ex:Esquema ;
    rdfs:label "Mill A@table B, C@spindle.xca" ;
    ex:textoExtracto "Para un eje rotativo A está el archivo \"Mill A@table B, C@spindle.xca\"" .

ex:ConnectionPlugStdPlugA1 a ex:ComponenteElectrico ;
    rdfs:label "Connection plug stdPlug@A1" ;
    ex:textoExtracto "<Connection plug=\"stdPlug@A1\" socket=\"stdSocket@home\" translation=\"0 0 0\"/>" .

ex:ConnectionPlugStdPlugS1 a ex:ComponenteElectrico ;
    rdfs:label "Connection plug stdSocket@S1" ;
    ex:textoExtracto "<Connection plug=\"stdPlug@SYS-Tool1\" socket=\"stdSocket@S1\" rotation=\"0 1 0 -90\"/>" .

ex:MillATableBCSpindleDefinicionTraslacion a ex:Esquema ;
    rdfs:label "Definición de traslación del archivo Mill A@table B, C@spindle.xca" ;
    ex:textoExtracto "<Connection plug=\"stdPlug@A1\" socket=\"stdSocket@home\" translation=\"-300 -100 -250\"/>" .