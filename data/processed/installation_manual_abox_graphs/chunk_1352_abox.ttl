@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_7f9363508f a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Si se actualiza la versión, el CNC actúa de la siguiente manera." ;
    ns1:tieneComponente ns1:SubrutinaAsociadaAlComandoCUTTINGOFF,
        ns1:SubrutinaAsociadaAlComandoCUTTINGON .

ns1:SubrutinaAsociadaAlComandoCUTTINGOFF a ns1:Parametro ;
    rdfs:label "Subrutina asociada al comando #CUTTING OFF"@es ;
    ns1:identificador "CUTTINGOFF" ;
    ns1:textoExtracto "Estas subrutinas deben estar definidas en los parámetros generales CUTTINGOFF (por defecto Cuttingoff.fst)" .

ns1:SubrutinaAsociadaAlComandoCUTTINGON a ns1:Parametro ;
    rdfs:label "Subrutina asociada al comando #CUTTING ON"@es ;
    ns1:identificador "CUTTINGON" ;
    ns1:textoExtracto "Estas subrutinas deben estar definidas en los parámetros generales CUTTINGON (por defecto Cuttingon.fst)" .

