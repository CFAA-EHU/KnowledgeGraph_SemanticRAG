@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:stdPlug_A1 a ex:ComponenteElectrico ;
    ex:textoExtracto "Connection plug=\"stdPlug@A1\"" ;
    ex:identificador "stdPlug@A1" .

ex:stdSocket_home a ex:ComponenteElectrico ;
    ex:textoExtracto "socket=\"stdSocket@home\"" ;
    ex:identificador "stdSocket@home" .

ex:ParametroMaquina_FACEAXIS a ex:Parametro ;
    ex:textoExtracto "parámetros máquina de los ejes lineales (FACEAXIS y LONGAXIS)" ;
    ex:identificador "FACEAXIS" .

ex:ParametroMaquina_LONGAXIS a ex:Parametro ;
    ex:textoExtracto "parámetros máquina de los ejes lineales (FACEAXIS y LONGAXIS)" ;
    ex:identificador "LONGAXIS" .

ex:TablaHerramientas a ex:Tabla ;
    ex:textoExtracto "según la opción elegida en la tabla de herramientas" .

ex:Herramienta a ex:Herramienta ;
    ex:textoExtracto "Posicionar la herramienta" .

ex:SistemaCNC a ex:Maquina ;
    ex:textoExtracto "reiniciar el CNC" .