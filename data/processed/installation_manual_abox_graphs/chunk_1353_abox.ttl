@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ParametroLONGAXIS a ex:Parametro ;
    rdfs:label "LONGAXIS" ;
    ex:textoExtracto "los parámetros máquina LONGAXIS" .

ex:ParametroFACEAXIS a ex:Parametro ;
    rdfs:label "FACEAXIS" ;
    ex:textoExtracto "los parámetros máquina FACEAXIS" .

ex:SistemaCNC a ex:Maquina ;
    rdfs:label "CNC" ;
    ex:textoExtracto "reiniciar el CNC" .

ex:TablaHerramientas a ex:Tabla ;
    rdfs:label "tabla de herramientas" ;
    ex:textoExtracto "según la opción elegida en la tabla de herramientas" .

ex:ConfiguracionGraficos a ex:ModoOperacion ;
    rdfs:label "configurar los gráficos para los ciclos de ejes rotativos" ;
    ex:textoExtracto "configurar los gráficos para los ciclos de ejes rotativos" .

ex:ParametroEje a ex:Parametro ;
    rdfs:label "parámetros de eje" ;
    ex:textoExtracto "Si no están parametrizados los ejes" .