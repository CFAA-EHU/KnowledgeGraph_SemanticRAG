@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComandoFINALSUB a ns1:AccionProhibida ;
    rdfs:label "Comando #FINALSUB" ;
    ns1:textoExtracto "El comando #FINALSUB tiene una subrutina asociada, que el CNC ejecuta junto al comando. Este comando esta orientado a máquina láser, donde esta subrutina debe realizar las operaciones finales del láser." .

ns1:SubrutinaLaser a ns1:Sistema ;
    rdfs:label "Subrutina Láser" ;
    ns1:ejecutadoPor ns1:CNC8070_44a350f2b9 ;
    ns1:textoExtracto "Subrutina orientada al modelo láser. Las subrutinas suministradas por Fagor ofrecen una gestión básica del láser, por lo que deben ser configuradas de forma apropiada por el OEM." .

ns1:CNC8070_44a350f2b9 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC ejecuta junto al comando." .

