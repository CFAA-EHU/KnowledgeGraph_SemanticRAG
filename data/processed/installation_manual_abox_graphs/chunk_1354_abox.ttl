@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ConfiguracionEjesRotativos_19_1 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuración de ejes rotativos (19.1)"@es ;
    ex:textoExtracto """
| Archivo. | Posición por defecto de la herramienta. |
| --- | --- |
| Mill A@table B,C@spindle.xca | FACEAXIS = Z LONGAXIS =X |
| Mill B@table A,C@spindle.xca | FACEAXIS = Z LONGAXIS =X |
| Mill C@table A,B@spindle.xca | FACEAXIS = Z LONGAXIS =X """
    ;
    ex:identificador "19.1" ;
    ex:documentadoEn ex:Pagina_737_738 .

ex:Parametro_FACEAXIS
    a ex:Parametro ;
    rdfs:label "FACEAXIS" ;
    ex:textoExtracto "FACEAXIS = Z"@es ;
    ex:valor "Z" ;
    ex:documentadoEn ex:Tabla_ConfiguracionEjesRotativos_19_1 .

ex:Parametro_LONGAXIS
    a ex:Parametro ;
    rdfs:label "LONGAXIS" ;
    ex:textoExtracto "LONGAXIS =X"@es ;
    ex:valor "X" ;
    ex:documentadoEn ex:Tabla_ConfiguracionEjesRotativos_19_1 .

ex:ArchivoConfig_MillA
    a ex:InterfazUsuario ;
    rdfs:label "Mill A@table B,C@spindle.xca" ;
    ex:textoExtracto "Mill A@table B,C@spindle.xca" ;
    ex:identificador "MillA_tableBC_spindle" ;
    ex:documentadoEn ex:Tabla_ConfiguracionEjesRotativos_19_1 .

ex:ArchivoConfig_MillB
    a ex:InterfazUsuario ;
    rdfs:label "Mill B@table A,C@spindle.xca" ;
    ex:textoExtracto "Mill B@table A,C@spindle.xca" ;
    ex:identificador "MillB_tableAC_spindle" ;
    ex:documentadoEn ex:Tabla_ConfiguracionEjesRotativos_19_1 .

ex:ArchivoConfig_MillC
    a ex:InterfazUsuario ;
    rdfs:label "Mill C@table A,B@spindle.xca" ;
    ex:textoExtracto "Mill C@table A,B@spindle.xca" ;
    ex:identificador "MillC_tableAB_spindle" ;
    ex:documentadoEn ex:Tabla_ConfiguracionEjesRotativos_19_1 .

ex:Pagina_737_738
    a ex:Pagina ;
    rdfs:label "Páginas 737-738: Configuración de gráficos para ciclos de ejes rotativos"@es ;
    ex:textoExtracto "GRÁFICOS HD. - 19. 19.1 Configurar los gráficos para los ciclos de ejes rotativos"@es .