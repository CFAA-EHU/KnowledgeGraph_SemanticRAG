@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SubrutinaAsociadaAlComandoFINALSUB a ns1:Parametro ;
    rdfs:label "Subrutina asociada al comando #FINALSUB" ;
    ns1:identificador "MPG.FINALSUB" ;
    ns1:ilustradoEn ns1:TablaVariables ;
    ns1:textoExtracto "Variable (V.)[ch].MPG.FINALSUB Subrutina asociada al comando #FINALSUB. Unidades: Texto." .

ns1:TablaVariables a ns1:Tabla ;
    rdfs:label "Tabla de variables accesibles desde el programa pieza y modo MDI/MDA, PLC e INT" ;
    ns1:textoExtracto "La tabla indica, para cada variable, si el acceso es de lectura (R) o de escritura (W)." .

