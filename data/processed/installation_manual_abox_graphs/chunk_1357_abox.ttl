@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PC_InstalacionConfigurador a ex:Maquina ;
    rdfs:label "PC con Windows 7 32/64 bits o Windows 10 64 bits"@es ;
    ex:textoExtracto "Instalar el configurador en un PC con Windows 7 32/64 bits o Windows 10 64 bits."@es .

ex:PuertoUSB_InstalacionConfigurador a ex:ComponenteElectrico ;
    rdfs:label "puerto USB"@es ;
    ex:textoExtracto "Introducir el pendrive en el puerto USB"@es .

ex:Pendrive_InstalacionConfigurador a ex:ComponenteElectrico ;
    rdfs:label "pendrive"@es ;
    ex:textoExtracto "Introducir el pendrive en el puerto USB"@es .

ex:ArchivoSetupKPA_InstalacionConfigurador a ex:ComponenteElectrico ;
    ex:identificador "SetupKPA_xx_xx.exe"@es ;
    ex:textoExtracto "hacer doble clic en el archivo \"SetupKPA_xx_xx.exe\" (donde xx_xx indica la versión)"@es .

ex:IconoStudio_InstalacionConfigurador a ex:InterfazUsuario ;
    rdfs:label "Studio. Configurador EtherCAT"@es ;
    ex:textoExtracto "Icono. | Studio. Configurador EtherCAT."@es .

ex:IconoMaster_InstalacionConfigurador a ex:InterfazUsuario ;
    rdfs:label "Master (Win64). Acceso a los módulos EtherCAT a través de la red Ethernet"@es ;
    ex:textoExtracto "Icono. | Master (Win64). Acceso a los módulos EtherCAT a través de la red Ethernet."@es .

ex:IconoLicencia_InstalacionConfigurador a ex:InterfazUsuario ;
    rdfs:label "KPA Licensing utilities. Acceso a la licencia de uso"@es ;
    ex:textoExtracto "Icono. | KPA Licensing utilities. Acceso a la licencia de uso."@es .

ex:IconoAyuda_InstalacionConfigurador a ex:InterfazUsuario ;
    rdfs:label "Ayuda"@es ;
    ex:textoExtracto "Icono. | Ayuda. Para obtener información detallada sobre el funcionamiento del programa, consulte la ayuda del propio programa."@es .