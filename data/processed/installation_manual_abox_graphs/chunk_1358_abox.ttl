@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_7f9363508f a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Si se actualiza la versión, el CNC actúa de la siguiente manera." ;
    ns1:tieneComponente ns1:SubrutinaG500,
        ns1:SubrutinaG501,
        ns1:SubrutinaG599 .

ns1:SubrutinaG500 a ns1:ComponenteElectrico ;
    rdfs:label "Subrutina G500" ;
    ns1:identificador "G500" ;
    ns1:textoExtracto "La subrutina asociadas a las funciones G500 a G599 tendrán el mismo nombre que la función (sin extensión) y estarán guardadas en la carpeta ..\\Users\\Sub." .

ns1:SubrutinaG501 a ns1:ComponenteElectrico ;
    rdfs:label "Subrutina G501" ;
    ns1:identificador "G501" ;
    ns1:textoExtracto "La subrutina asociadas a las funciones G500 a G599 tendrán el mismo nombre que la función (sin extensión) y estarán guardadas en la carpeta ..\\Users\\Sub." .

ns1:SubrutinaG599 a ns1:ComponenteElectrico ;
    rdfs:label "Subrutina G599" ;
    ns1:identificador "G599" ;
    ns1:textoExtracto "La subrutina asociadas a las funciones G500 a G599 tendrán el mismo nombre que la función (sin extensión) y estarán guardadas en la carpeta ..\\Users\\Sub." .

