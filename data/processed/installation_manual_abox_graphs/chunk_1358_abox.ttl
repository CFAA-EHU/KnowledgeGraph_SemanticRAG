@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:MasterWin64
    a ex:Sistema ;
    rdfs:label "Master (Win64)" ;
    ex:textoExtracto "ejecutar el programa \"Master (Win64)\". Este programa permite acceder al bus a través del conector LAN de Ethernet." .

ex:KPA_EtherCAT_Studio
    a ex:Sistema ;
    rdfs:label "KPA EtherCAT Studio" ;
    ex:textoExtracto "Ejecutar el programa \"Studio\" para iniciar el configurador \"KPA EtherCAT Studio\"." .

ex:InterfazUsuario_KPA_EtherCAT_Studio
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de KPA EtherCAT Studio" ;
    ex:textoExtracto "A Topología EtherCAT. B Información ayuda. C Errores, avisos y mensajes del programa." ;
    ex:compuestoPor ex:PanelTopologiaEtherCAT, ex:PanelAyuda, ex:PanelMensajes .

ex:PanelTopologiaEtherCAT
    a ex:InterfazUsuario ;
    rdfs:label "Panel de Topología EtherCAT" ;
    ex:textoExtracto "A Topología EtherCAT." .

ex:PanelAyuda
    a ex:InterfazUsuario ;
    rdfs:label "Panel de Información de Ayuda" ;
    ex:textoExtracto "B Información ayuda." .

ex:PanelMensajes
    a ex:InterfazUsuario ;
    rdfs:label "Panel de Errores y Mensajes" ;
    ex:textoExtracto "C Errores, avisos y mensajes del programa." .