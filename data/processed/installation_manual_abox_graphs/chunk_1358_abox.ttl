@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ProgramaMasterWin64 a ex:ComponenteElectrico ;
    rdfs:label "Master (Win64)" ;
    ex:textoExtracto "Para una configuración online del bus, ejecutar el programa \"Master (Win64)\"." .

ex:ConectorLAN a ex:ComponenteElectrico ;
    rdfs:label "conector LAN de Ethernet" ;
    ex:textoExtracto "Este programa permite acceder al bus a través del conector LAN de Ethernet." .

ex:IconoNotificaciones a ex:AvisoSeguridad ;
    rdfs:label "icono en el área de notificaciones de la barra de tareas" ;
    ex:textoExtracto "Cuando el programa está en marcha, aparece un icono en el área de notificaciones de la barra de tareas (junto al reloj)." .

ex:ProgramaStudio a ex:ComponenteElectrico ;
    rdfs:label "Studio" ;
    ex:textoExtracto "Ejecutar el programa \"Studio\" para iniciar el configurador \"KPA EtherCAT Studio\"." .

ex:ConfiguradorKPAEtherCATStudio a ex:InterfazUsuario ;
    rdfs:label "KPA EtherCAT Studio" ;
    ex:textoExtracto "Ejecutar el programa \"Studio\" para iniciar el configurador \"KPA EtherCAT Studio\"." .