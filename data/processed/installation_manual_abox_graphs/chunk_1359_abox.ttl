@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PendriveLicencia a ex:ComponenteElectrico ;
    rdfs:label "pendrive con la licencia"@es ;
    ex:textoExtracto "El pendrive con la licencia debe estar conectado al PC."@es .

ex:PuertoUSB a ex:ComponenteElectrico ;
    rdfs:label "puerto USB"@es ;
    ex:textoExtracto "Insertar el pendrive en el puerto USB"@es .

ex:BotonOk a ex:InterfazUsuario ;
    rdfs:label "botón \"Ok\""@es ;
    ex:textoExtracto "pulse el botón \"Ok\""@es, "volver a pulsar el botón \"Ok\""@es .

ex:BotonBrowse a ex:InterfazUsuario ;
    rdfs:label "botón \"Browse\""@es ;
    ex:textoExtracto "Pulsar el botón \"Browse\""@es .

ex:LicenciaBasica a ex:Consumible ;
    rdfs:label "licencia \"Básica\""@es ;
    ex:textoExtracto "Fagor suministra la licencia \"Básica\", que permite configurar el bus."@es .

ex:ConfiguradorBus a ex:Sistema ;
    rdfs:label "configurador del bus"@es ;
    ex:textoExtracto "permite configurar el bus"@es .