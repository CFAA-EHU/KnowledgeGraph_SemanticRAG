@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_a241bbf1d9 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC permite al usuario definir hasta 1000 subrutinas, comunes a todos los canales, y que estarán asociadas a las funciones G8000 a G8999." ;
    ns1:tieneComponente ns1:ParametroLocal,
        ns1:SubrutinaUsuario .

ns1:ParametroLocal a ns1:Parametro ;
    rdfs:label "Parámetro Local" ;
    ns1:textoExtracto "Estas subrutinas se podrán ejecutar de forma no-modal o de forma modal, y además permite inicializar los parámetros locales de la subrutina." .

ns1:SubrutinaUsuario a ns1:Componente ;
    rdfs:label "Subrutina de Usuario" ;
    ns1:textoExtracto "Estas subrutinas se podrán ejecutar de forma no-modal o de forma modal, y además permite inicializar los parámetros locales de la subrutina." .

