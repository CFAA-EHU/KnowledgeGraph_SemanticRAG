@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IndiceBaseDeLosModulosDeSalidasDigitales a ns1:Parametro ;
    rdfs:label "Índice base de los módulos de salidas digitales" ;
    ns1:identificador "MPG.DOMODADDR[nb]" ;
    ns1:textoExtracto "DOMOD n Índice base de los módulos de salidas digitales. Valores posibles: De 0 a 1009." .

ns1:NumeroTotalDeModulosDeSalidasDigitales a ns1:Parametro ;
    rdfs:label "Número total de módulos de salidas digitales" ;
    ns1:identificador "MPG.NDOMOD" ;
    ns1:textoExtracto "NDOMOD Número total de módulos de salidas digitales. Valores posibles: De 0 a 64." .

ns1:TablaDeModulosDeSalidasDigitales a ns1:Parametro ;
    rdfs:label "Tabla de módulos de salidas digitales" ;
    ns1:textoExtracto "DOMODADDR Tabla de módulos de salidas digitales. Este parámetro muestra la lista de módulos de salidas digitales conectados en el mismo bus CAN." .

