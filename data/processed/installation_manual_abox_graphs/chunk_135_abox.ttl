@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:NSAI a ex:Parametro ;
    rdfs:label "Número de entradas analógicas especiales (no en tensión)" ;
    ex:textoExtracto "NSAI Número de entradas analógicas especiales (no en tensión). Valores posibles: De 0 a 30. Valor por defecto: 0 (todas las entradas analógicas son en tensión). Variable asociada: (V.)MPG.NSAI" ;
    ex:valor "0 a 30" .

ex:ADDRESS a ex:Parametro ;
    rdfs:label "ADDRESS" ;
    ex:textoExtracto "ADDRESS Número de entrada analógica. Valores posibles: De 0 a 60. Valor por defecto: 0. Variable asociada: (V.)MPG.ADDRESS[n]" ;
    ex:valor "0 a 60" .

ex:FACTOR a ex:Parametro ;
    rdfs:label "FACTOR" ;
    ex:textoExtracto "FACTOR Factor de conversión. Valores posibles: Entre ±999999999.999999999. Valor por defecto: 0.0061035. Variable asociada: (V.)MPG.FACTOR[n]" ;
    ex:valor "±999999999.999999999" .

ex:TablaEntradasAnalogicasEspeciales a ex:Tabla ;
    rdfs:label "Tabla de entradas analógicas especiales" ;
    ex:textoExtracto "SAI Tabla de entradas analógicas especiales. Este parámetro muestra la tabla para definir las entradas analógicas especiales del sistema." .

ex:EntradaAnalogica a ex:Sensor ;
    rdfs:label "Entrada analógica" ;
    ex:textoExtracto "Entrada analógica." .

ex:ModuloRIOR a ex:ComponenteElectrico ;
    rdfs:label "módulo RIOR" ;
    ex:textoExtracto "las entradas analógicas del módulo RIOR se pueden configurar en corriente" .

ex:ModuloRIOW a ex:ComponenteElectrico ;
    rdfs:label "módulo RIOW" ;
    ex:textoExtracto "las entradas analógicas del módulo RIOR se pueden configurar en corriente. • Para las entradas analógicas en corriente del módulo RIOR o RIOW, utilizar el valor por defecto y el CNC leerá los valores en decimiliamperios." .

ex:TablaEntradasAnalogicasEspeciales a ex:Tabla ;
    ex:compuestoPor ex:EntradaAnalogica ;
    ex:textoExtracto "Para cada entrada analógica hay que definir los siguientes campos. | SAI | Significado. | | --- | --- | | ADDRESS | Entrada analógica. | | FACTOR | Factor de conversión. |" .

ex:ModuloRIOR ex:tieneComponente ex:EntradaAnalogica ;
    ex:textoExtracto "Entradas analógicas del módulo RIOR. • Entradas analógicas de 16 bits (15 bits + signo); es decir, unos valores entre ±32767. • Rango de medida ±20 miliamperios." .