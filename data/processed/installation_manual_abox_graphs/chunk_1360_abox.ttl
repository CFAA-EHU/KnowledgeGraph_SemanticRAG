@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_7f9363508f a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Si se actualiza la versión, el CNC actúa de la siguiente manera." ;
    ns1:tieneComponente ns1:SubrutinaG8000,
        ns1:SubrutinaG8001,
        ns1:SubrutinaG8999 .

ns1:SubrutinaG8000 a ns1:ComponenteElectrico ;
    rdfs:label "Subrutina G8000" ;
    ns1:textoExtracto "La subrutina asociadas a las funciones G8000 a G8999 tendrán el mismo nombre que la función (sin extensión) y estarán guardadas en la carpeta ..\\Users\\Sub. G8000 tendrá asociada la subrutina G8000." .

ns1:SubrutinaG8001 a ns1:ComponenteElectrico ;
    rdfs:label "Subrutina G8001" ;
    ns1:textoExtracto "La subrutina asociadas a las funciones G8000 a G8999 tendrán el mismo nombre que la función (sin extensión) y estarán guardadas en la carpeta ..\\Users\\Sub. G8001 tendrá asociada la subrutina G8001." .

ns1:SubrutinaG8999 a ns1:ComponenteElectrico ;
    rdfs:label "Subrutina G8999" ;
    ns1:textoExtracto "La subrutina asociadas a las funciones G8000 a G8999 tendrán el mismo nombre que la función (sin extensión) y estarán guardadas en la carpeta ..\\Users\\Sub. G8999 tendrá asociada la subrutina G8999." .

