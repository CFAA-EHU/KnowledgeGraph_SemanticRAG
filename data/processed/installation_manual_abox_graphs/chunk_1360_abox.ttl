@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoOperacion_OnlineBusScan
    a ex:ModoOperacion ;
    rdfs:label "Modo online: Escanear el bus para detectar módulos"@es ;
    ex:textoExtracto "20.1.4 Modo online. Escanear el bus para detectar los módulos."@es ;
    ex:requiereMantenimiento ex:TareaMantenimiento_DetectarModulos .

ex:TareaMantenimiento_DetectarModulos
    a ex:TareaMantenimiento ;
    rdfs:label "Detección de módulos en bus MDP"@es ;
    ex:textoExtracto "Para detectar las cabeceras, colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción 'Scan configuration'. [...] Para detectar los recursos de cada nodo, [...] seleccionar la opción 'Attach master'. [...] Un paso previo para exportar la configuración es desaclopar el máster del bus."@es ;
    ex:ejecutadoPor ex:InterfazUsuario_ConfiguradorMDP .

ex:InterfazUsuario_ConfiguradorMDP
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz del configurador MDP"@es ;
    ex:textoExtracto "ventana izquierda [...] pestaña 'MDP modules' [...] opciones 'Scan configuration', 'Upload detected Module Ident list', 'Attach master', 'Detach master'."@es ;
    ex:ilustradoEn ex:Pagina_743_744 .

ex:Pagina_743_744
    a ex:Pagina ;
    ex:identificador "743-744" ;
    ex:documentadoEn ex:Manual_Broaching ;
    ex:textoExtracto "Sección 20.1.4 Modo online. Escanear el bus para detectar los módulos."@es .

ex:Sistema_BusMDP
    a ex:Sistema ;
    rdfs:label "Bus MDP con topología máster-nodo"@es ;
    ex:textoExtracto "máster de la topología [...] cabeceras detectadas [...] módulos detectados en cada nodo."@es ;
    ex:compuestoPor ex:Componente_MasterMDP ;
    ex:monitoreaParametro ex:Parametro_ModulosConectados .

ex:Componente_MasterMDP
    a ex:ComponenteElectrico ;
    rdfs:label "Máster de topología MDP"@es ;
    ex:textoExtracto "colocar el ratón sobre el máster de la topología (ventana izquierda) [...] seleccionar 'Attach master'/'Detach master'."@es ;
    ex:controla ex:Sistema_BusMDP .

ex:Parametro_ModulosConectados
    a ex:Parametro ;
    rdfs:label "Lista de módulos detectados (Module Ident list)"@es ;
    ex:textoExtracto "opción 'Upload detected Module Ident list' [...] el configurador muestra los módulos detectados."@es .