@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:AdaptadorRedEthernet_1360_1 a ex:ComponenteElectrico ;
    rdfs:label "adaptador de red Ethernet" ;
    ex:textoExtracto "el primer paso es seleccionar el adaptador de red Ethernet" .

ex:InterfazUsuario_Configurador_1360 a ex:InterfazUsuario ;
    ex:textoExtracto "el configurador muestra las cabeceras detectadas", "el configurador muestra los módulos detectadas" .

ex:Maquina_MasterTopologia_1360 a ex:Maquina ;
    rdfs:label "máster de la topología" ;
    ex:textoExtracto "colocar el ratón sobre el máster de la topología (ventana izquierda)", "colocar el ratón sobre el máster de la topología (ventana izquierda)" .

ex:AccionProhibida_DesacoplarMaster_1360 a ex:AccionProhibida ;
    rdfs:label "Desacoplar máster del bus" ;
    ex:textoExtracto "Un paso previo para exportar la configuración es desaclopar el máster del bus" .

ex:TareaMantenimiento_ExportarConfiguracion_1360 a ex:TareaMantenimiento ;
    rdfs:label "Exportar configuración" ;
    ex:textoExtracto "Un paso previo para exportar la configuración es desaclopar el máster del bus" .

ex:InterfazUsuario_OpcionScanConfiguration_1360 a ex:InterfazUsuario ;
    rdfs:label "Scan configuration" ;
    ex:textoExtracto "seleccionar la opción \"Scan configuration\"" .

ex:InterfazUsuario_OpcionUploadDetectedModuleIdentList_1360 a ex:InterfazUsuario ;
    rdfs:label "Upload detected Module Ident list" ;
    ex:textoExtracto "seleccionar la opción \"Upload detected Module Ident list\"" .

ex:InterfazUsuario_OpcionAttachMaster_1360 a ex:InterfazUsuario ;
    rdfs:label "Attach master" ;
    ex:textoExtracto "seleccionar la opción \"Attach master\"" .

ex:InterfazUsuario_OpcionDetachMaster_1360 a ex:InterfazUsuario ;
    rdfs:label "Detach master" ;
    ex:textoExtracto "seleccionar la opción \"Detach master\"" .

ex:InterfazUsuario_PestanaMDPModules_1360 a ex:InterfazUsuario ;
    rdfs:label "pestaña MDP modules" ;
    ex:textoExtracto "En la pestaña \"MDP modules\"" .

ex:InterfazUsuario_InformacionCabeceras_1360 a ex:InterfazUsuario ;
    rdfs:label "desplegar información de las cabeceras" ;
    ex:textoExtracto "Se recomienda desplegar la información de las cabeceras para facilitar la detección de los módulos" .

ex:InterfazUsuario_BotonDerecho_1360 a ex:InterfazUsuario ;
    rdfs:label "pulsar el botón derecho del ratón" ;
    ex:textoExtracto "pulsar el botón derecho del ratón" .

ex:InterfazUsuario_VentanaIzquierda_1360 a ex:InterfazUsuario ;
    rdfs:label "ventana izquierda" ;
    ex:textoExtracto "ventana izquierda" .