@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_b4a1d848e8 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:FicheroAyudaDibujo,
        ns1:FicheroAyudaTexto ;
    ns1:textoExtracto "La ventana de ayuda de las subrutinas sólo está disponible cuando el editor utilice el lenguaje del CNC." .

ns1:EditarFicherosDeAyuda a ns1:TareaMantenimiento ;
    rdfs:label "Editar ficheros de ayuda" ;
    ns1:documentadoEn ns1:FicheroAyudaDibujo,
        ns1:FicheroAyudaTexto ;
    ns1:textoExtracto "Editar los ficheros de ayuda. Cada subrutina puede disponer de dos ficheros de ayuda; uno de texto (txt) y otro de dibujo (bmp)." .

ns1:FicheroAyudaDibujo a ns1:DocumentoTecnico ;
    rdfs:label "Fichero de ayuda de dibujo" ;
    ns1:textoExtracto "Cada subrutina puede disponer de dos ficheros de ayuda; uno de texto (txt) y otro de dibujo (bmp)." .

ns1:FicheroAyudaTexto a ns1:DocumentoTecnico ;
    rdfs:label "Fichero de ayuda de texto" ;
    ns1:textoExtracto "Cada subrutina puede disponer de dos ficheros de ayuda; uno de texto (txt) y otro de dibujo (bmp)." .

