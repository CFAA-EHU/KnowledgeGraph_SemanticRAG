@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazUsuario_ConfiguradorTopologiaBus
    a ex:InterfazUsuario ;
    rdfs:label "Configurador de topología del bus (modo offline)"@es ;
    ex:textoExtracto "colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción \"Append Slave\"... Arrastrar los módulos desde la ventana derecha a la ventana izquierda."@es ;
    ex:identificador "Modo offline - Construcción manual de topología" .

ex:TareaMantenimiento_AgregarCabeceras
    a ex:TareaMantenimiento ;
    rdfs:label "Añadir cabeceras al bus"@es ;
    ex:textoExtracto "Para añadir cabeceras, colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción \"Append Slave\"."@es ;
    ex:ejecutadoPor ex:InterfazUsuario_ConfiguradorTopologiaBus .

ex:Sistema_ModulosMDP
    a ex:Sistema ;
    rdfs:label "Módulos MDP disponibles"@es ;
    ex:textoExtracto "En la pestaña \"MDP modules\" está la lista de módulos disponibles para la cabecera seleccionada."@es ;
    ex:ilustradoEn ex:InterfazUsuario_ConfiguradorTopologiaBus .

ex:Componente_MasterTopologia
    a ex:Componente ;
    rdfs:label "Máster de la topología"@es ;
    ex:textoExtracto "colocar el ratón sobre el máster de la topología (ventana izquierda)"@es ;
    ex:ilustradoEn ex:InterfazUsuario_ConfiguradorTopologiaBus .