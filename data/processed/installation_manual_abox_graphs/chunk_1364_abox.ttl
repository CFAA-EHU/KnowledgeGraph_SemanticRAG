@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_d7c2cfebc6 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC busca los ficheros de ayuda en ambas carpetas; si los archivos no están ahí, el CNC no mostrará ninguna ayuda." .

ns1:FicheroAyuda1 a ns1:DocumentoTecnico ;
    rdfs:label "FAGOR.NC" ;
    ns1:documentadoEn ns1:ArchivoSubrutinas ;
    ns1:textoExtracto "Ejemplo de un fichero con una lista de subrutinas." .

ns1:FicheroAyuda2 a ns1:DocumentoTecnico ;
    rdfs:label "SUBROUTINE.NC" ;
    ns1:documentadoEn ns1:ArchivoSubrutinas ;
    ns1:textoExtracto "Ejemplo de un fichero con una lista de subrutinas." .

ns1:FicheroAyuda3 a ns1:DocumentoTecnico ;
    rdfs:label "EXAMPLE.NC" ;
    ns1:documentadoEn ns1:ArchivoSubrutinas ;
    ns1:textoExtracto "Ejemplo de un fichero con una lista de subrutinas." .

ns1:FicheroAyuda4 a ns1:DocumentoTecnico ;
    rdfs:label "POSITIONING.NC" ;
    ns1:documentadoEn ns1:ArchivoSubrutinas ;
    ns1:textoExtracto "Ejemplo de un fichero con una lista de subrutinas." .

ns1:ManualDeProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación" ;
    ns1:identificador "CNC8070-User-Manual" ;
    ns1:textoExtracto "El editor permite tener en un archivo de texto (txt) una lista subrutinas que se mostrará durante la edición del programa pieza, cada vez que se edite una sentencia #PCALL ó #MCALL." .

ns1:ArchivoSubrutinas a ns1:DocumentoTecnico ;
    rdfs:label "Lista de subrutinas" ;
    ns1:documentadoEn ns1:ManualDeProgramacion ;
    ns1:identificador "pcall.txt" ;
    ns1:textoExtracto "El fichero se deberá editar de tal manera que cada línea sea el nombre de una posible subrutina a llamar." .

