@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tarea_CopiarArchivoConfiguracionCNC
    a                  ex:TareaMantenimiento ;
    rdfs:label         "Copiar archivo de configuración al CNC"@es ;
    ex:textoExtracto   "Para copiar el archivo de configuración al CNC (archivo xml), renombrarlo como \"fagor_ethercatConfFile.xml\" y copiarlo a la carpeta ../Mtb/Data."@es ;
    ex:identificador   "fagor_ethercatConfFile.xml" .

ex:ArchivoConfiguracionCNC
    a                  ex:InterfazUsuario ;
    rdfs:label         "Archivo de configuración EtherCAT para CNC"@es ;
    ex:textoExtracto   "archivo xml [...] renombrarlo como \"fagor_ethercatConfFile.xml\""@es ;
    ex:identificador   "fagor_ethercatConfFile.xml" ;
    ex:documentadoEn   ex:Tarea_CopiarArchivoConfiguracionCNC .