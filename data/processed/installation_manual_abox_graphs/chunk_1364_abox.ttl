@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:AccionCopiarArchivoConfiguracionCNC a ex:TareaMantenimiento ;
    rdfs:label "Copiar el archivo de configuración al CNC" ;
    ex:textoExtracto "Para copiar el archivo de configuración al CNC (archivo xml), renombrarlo como \"fagor_ethercatConfFile.xml\" y copiarlo a la carpeta ../Mtb/Data." ;
    ex:tieneFrecuencia ex:FrecuenciaCopiarArchivoConfiguracionCNC .

ex:FrecuenciaCopiarArchivoConfiguracionCNC a ex:Frecuencia ;
    ex:valor "No especificada" ;
    ex:textoExtracto "Para copiar el archivo de configuración al CNC (archivo xml), renombrarlo como \"fagor_ethercatConfFile.xml\" y copiarlo a la carpeta ../Mtb/Data." .