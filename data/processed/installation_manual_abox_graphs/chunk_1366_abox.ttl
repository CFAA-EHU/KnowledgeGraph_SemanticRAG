@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_d6633bf7b6 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Como el CNC puede tener conectados varios paneles de jog, desde el CNC se permite configurar el comportamiento de cada uno de ellos respecto a los canales." ;
    ns1:tieneComponente ns1:PanelDeJog,
        ns1:PanelDeJog_045ac3d389 .

ns1:PanelDeJog a ns1:Componente ;
    rdfs:label "Panel de Jog" ;
    ns1:textoExtracto "Un panel de jog podrá estar asociado a un canal en concreto (por ejemplo, en un torno TT)" .

ns1:PanelDeJog_045ac3d389 a ns1:Componente ;
    rdfs:label "Panel de Jog" ;
    ns1:textoExtracto "una máquina con dos puestos de trabajo donde ambos paneles de jog funcionan de igual forma." .

