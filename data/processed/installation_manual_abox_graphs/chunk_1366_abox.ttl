@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EntradaAnalogicaCorriente1 a ex:Parametro ;
    rdfs:label "Entradas analógicas en corriente (mA)" ;
    ex:textoExtracto "Entradas analógicas en corriente (mA)." ;
    ex:valor "Microamperios" .

ex:SalidaAnalogicaTension1 a ex:Parametro ;
    rdfs:label "Salidas analógicas en tensión (V)" ;
    ex:textoExtracto "Salidas analógicas en tensión (V)." ;
    ex:valor "Décimas de milivoltio" .

ex:SalidaAnalogicaCorriente1 a ex:Parametro ;
    rdfs:label "Salidas analógicas en corriente (mA)" ;
    ex:textoExtracto "Salidas analógicas en corriente (mA)." ;
    ex:valor "Microamperios" .

ex:EntradaSondaTemperaturaPt100 a ex:Sensor ;
    rdfs:label "Entradas para sondas de temperatura Pt100" ;
    ex:textoExtracto "Entradas para sondas de temperatura Pt100." ;
    ex:valor "Décimas de grado" .