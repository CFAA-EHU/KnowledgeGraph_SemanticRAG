@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PC_Externo_1367 a ex:ComponenteElectrico ;
    rdfs:label "PC externo" ;
    ex:textoExtracto "se recomienda la instalación en un PC externo, junto al configurador" .

ex:SistemaOperativo_1367 a ex:ComponenteElectrico ;
    rdfs:label "Windows 7 32/64 bits o Windows 10 64 bits" ;
    ex:textoExtracto "Utilizar un PC con Windows 7 32/64 bits o Windows 10 64 bits" .

ex:ArchivoInstalacion_1367 a ex:Componente ;
    rdfs:label "Setup fagorethercatmapper-x.x.x.exe" ;
    ex:identificador "fagorethercatmapper-x.x.x.exe" ;
    ex:textoExtracto "Ejecutar el archivo \"Setup fagorethercatmapper-x.x.x.exe\" (donde x.x.x indica la versión) para iniciar la instalación" .

ex:IconoMapeadorEtherCAT_1367 a ex:InterfazUsuario ;
    rdfs:label "Icono de mapeador de recursos EtherCAT" ;
    ex:textoExtracto "en el escritorio aparece el siguiente icono. | Icono. | Función. | |  | Mapeador de recursos EtherCAT." .