@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_08b289010a a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC numera los paneles de mando según el orden que ocupan dentro del bus CAN (conmutador Address)." ;
    ns1:tieneComponente ns1:PanelJog1,
        ns1:PanelJog2 .

ns1:PanelJog1 a ns1:ComponenteElectrico ;
    rdfs:label "Panel Jog 1" ;
    ns1:identificador "0" ;
    ns1:textoExtracto "El primer panel de jog será el de numeración más baja y así sucesivamente." .

ns1:PanelJog2 a ns1:ComponenteElectrico ;
    rdfs:label "Panel Jog 2" ;
    ns1:identificador "1" ;
    ns1:textoExtracto "El primer panel de jog será el de numeración más baja y así sucesivamente." .

