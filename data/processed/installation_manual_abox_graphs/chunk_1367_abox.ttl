@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FagorEtherCATMapper
    a                     ex:Sistema ;
    rdfs:label            "Fagor EtherCAT Mapper" ;
    ex:textoExtracto       "Aunque \"Fagor EtherCAT Mapper\" se puede ejecutar en el propio CNC, se recomienda la instalación en un PC externo, junto al configurador."@es ;
    ex:identificador       "fagorethercatmapper-x.x.x.exe" .

ex:InterfazUsuario_FagorEtherCATMapper
    a                     ex:InterfazUsuario ;
    rdfs:label            "Interfaz de usuario del Fagor EtherCAT Mapper" ;
    ex:textoExtracto       "Una vez instalado, en el escritorio aparece el siguiente icono. | Icono. | Función. | --- | --- |  | Mapeador de recursos EtherCAT."@es ;
    ex:ilustradoEn         ex:Tabla_IconosFagorEtherCATMapper .

ex:Tabla_IconosFagorEtherCATMapper a ex:Tabla ;
     a                     ex:Tabla ;
    rdfs:label            "Tabla de iconos del Fagor EtherCAT Mapper" ;
    ex:textoExtracto       "| Icono. | Función. | --- | --- |  | Mapeador de recursos EtherCAT."@es ;
    ex:documentadoEn       ex:Pagina_748 .