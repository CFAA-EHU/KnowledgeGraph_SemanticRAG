@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:BarraIconosNombreArchivoENI a ex:InterfazUsuario ;
    rdfs:label "Barra de iconos y nombre del archivo ENI cargado" ;
    ex:textoExtracto "Barra de iconos y nombre del archivo ENI cargado" .

ex:BarraConfiguracionMapeoRecursos a ex:InterfazUsuario ;
    rdfs:label "Barra de configuración por defecto para el mapeo de recursos" ;
    ex:textoExtracto "Barra de configuración por defecto para el mapeo de recursos" .

ex:ValidacionOpcionOverlapped a ex:InterfazUsuario ;
    rdfs:label "Validación de la opción \"Overlapped\"" ;
    ex:textoExtracto "Validación de la opción \"Overlapped\"" .

ex:TopologiaBusVistaArbol a ex:InterfazUsuario ;
    rdfs:label "Topología del bus (vista de árbol)" ;
    ex:textoExtracto "Topología del bus (vista de árbol)" .

ex:TopologiaBusVistaBloques a ex:InterfazUsuario ;
    rdfs:label "Topología del bus (vista de bloques)" ;
    ex:textoExtracto "Topología del bus (vista de bloques)" .