@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazConfiguracionEtherCAT
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de configuración EtherCAT" ;
    ex:textoExtracto "Barra de configuración por defecto para el mapeo de recursos. Esta barra muestra cuál es la configuración que asumen los recursos cuando se carga el archivo ENI por primera vez (configuración por defecto). Posteriormente, la asignación de recursos se puede personalizar manualmente." ;
    ex:tieneComponente ex:FichaDigitalInput ;
    ex:tieneComponente ex:FichaDigitalOutput ;
    ex:tieneComponente ex:FichaRegisterInput ;
    ex:tieneComponente ex:FichaRegisterOutput ;
    ex:tieneComponente ex:FichaOverlapped ;
    ex:tieneComponente ex:TopologiaBusEtherCAT .

ex:FichaDigitalInput
    a ex:Componente ;
    rdfs:label "Ficha 'Digital Input'" ;
    ex:textoExtracto "Las fichas 'Digital Input' y 'Digital Output' configuran el mapeo de las entradas y salidas digitales." .

ex:FichaDigitalOutput
    a ex:Componente ;
    rdfs:label "Ficha 'Digital Output'" ;
    ex:textoExtracto "Las fichas 'Digital Input' y 'Digital Output' configuran el mapeo de las entradas y salidas digitales." .

ex:FichaRegisterInput
    a ex:Componente ;
    rdfs:label "Ficha 'Register Input'" ;
    ex:textoExtracto "Las fichas 'Register Input' y 'Register Output' mapean a registros de PLC aquellos recursos del bus EtherCAT que no son asumidos como entradas/salidas digitales." .

ex:FichaRegisterOutput
    a ex:Componente ;
    rdfs:label "Ficha 'Register Output'" ;
    ex:textoExtracto "Las fichas 'Register Input' y 'Register Output' mapean a registros de PLC aquellos recursos del bus EtherCAT que no son asumidos como entradas/salidas digitales." .

ex:FichaOverlapped
    a ex:Componente ;
    rdfs:label "Ficha 'Overlapped'" ;
    ex:textoExtracto "La ficha 'Overlapped' define si se permite la superposición de recursos en diferentes módulos. Ver en la página 754. '20.2.5 Overlapped.'" .

ex:TopologiaBusEtherCAT
    a ex:Sistema ;
    rdfs:label "Topología del bus EtherCAT" ;
    ex:textoExtracto "Topología del bus (vista de árbol). El primer nivel está formado por los esclavos del bus. Al hacer clic sobre un esclavo, el programa muestra los módulos conectados al bus. Para mostrar todos los esclavos, hacer clic en el icono 'Ver esclavos'. El segundo nivel está formado por los módulos que pertenecen al esclavo. Al hacer clic sobre un módulo, el programa muestra su lista de recursos." ;
    ex:ilustradoEn ex:InterfazConfiguracionEtherCAT .

ex:ParametroStarts
    a ex:Parametro ;
    rdfs:label "Parámetro 'Starts'" ;
    ex:textoExtracto "Starts. Número de la primera entrada, salida o registro del bus." ;
    ex:documentadoEn ex:InterfazConfiguracionEtherCAT .

ex:ParametroOffset
    a ex:Parametro ;
    rdfs:label "Parámetro 'Offset'" ;
    ex:textoExtracto "Offset. Offset de numeración entre cabeceras. Si el offset es cero, la numeración será consecutiva entre cabeceras." ;
    ex:documentadoEn ex:InterfazConfiguracionEtherCAT .

ex:ParametroVisible
    a ex:Parametro ;
    rdfs:label "Parámetro 'Visible'" ;
    ex:textoExtracto "Visible. Mostrar la numeración en el gráfico." ;
    ex:documentadoEn ex:InterfazConfiguracionEtherCAT .