@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModuloRIOR a ex:ComponenteElectrico ;
    rdfs:label "módulo RIOR" ;
    ex:textoExtracto "Entradas analógicas del módulo RIOR" .

ex:EntradaAnalogica16Bits a ex:ComponenteElectrico ;
    ex:textoExtracto "Entradas analógicas de 16 bits (15 bits + signo); es decir, unos valores entre ±32767" .

ex:RangoMedida20mA a ex:Parametro ;
    ex:valor "±20 miliamperios" ;
    ex:textoExtracto "Rango de medida ±20 miliamperios" .

ex:FactorConversion200_32767 a ex:Parametro ;
    ex:valor "200 / 32767 = 0,0061035" ;
    ex:textoExtracto "Factor = 200 / 32767 = 0,0061035 (para devolver el valor en decimiliamperios)" .

ex:FactorTransformacionNoLineal a ex:Parametro ;
    ex:valor "1" ;
    ex:textoExtracto "Para entradas analógicas que tengan una conversión no lineal o con un offset asimétrico, definir un factor de \"1\"" .