@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:VerEsclavos a ex:InterfazUsuario ;
    rdfs:label "Ver esclavos"@es ;
    ex:textoExtracto "Para mostrar todos los esclavos, hacer clic en el icono \"Ver esclavos\"."@es .

ex:ModuloEsclavo1 a ex:ComponenteElectrico ;
    ex:textoExtracto "El segundo nivel está formado por los módulos que pertenecen al esclavo."@es .

ex:ListaRecursos a ex:InterfazUsuario ;
    ex:textoExtracto "Al hacer clic sobre un módulo, el programa muestra su lista de recursos."@es .

ex:TopologiaBus a ex:Esquema ;
    ex:textoExtracto "Topología del bus (vista de bloques)."@es .