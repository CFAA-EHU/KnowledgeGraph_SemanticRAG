@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_97b0fe09d6 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Primer panel de mando del sistema." ;
    ns1:tieneComponente ns1:ListaDePanelesDeJogDelSistemaPrimerPanel,
        ns1:ListaDePanelesDeJogDelSistemaSegundoPanel,
        ns1:NumeroDePanelesDeJog_c40127d676,
        ns1:TablaParaConfigurarLasTeclasDeJogDelPrimerPanel,
        ns1:TablaParaConfigurarLasTeclasDeJogDelSegundoPanel .

ns1:ListaDePanelesDeJogDelSistemaPrimerPanel a ns1:Parametro ;
    rdfs:label "Lista de paneles de jog del sistema (primer panel)" ;
    ns1:identificador "KEYBD1CH" ;
    ns1:textoExtracto "El parámetro KEYBDCH muestra la tabla para asignar los paneles de jog a los canales, donde el parámetro KEYBD1CH corresponde al primer panel de jog." .

ns1:ListaDePanelesDeJogDelSistemaSegundoPanel a ns1:Parametro ;
    rdfs:label "Lista de paneles de jog del sistema (segundo panel)" ;
    ns1:identificador "KEYBD2CH" ;
    ns1:textoExtracto "El parámetro KEYBDCH muestra la tabla para asignar los paneles de jog a los canales, donde el parámetro KEYBD2CH corresponde al segundo panel de jog." .

ns1:NumeroDePanelesDeJog_c40127d676 a ns1:Parametro ;
    rdfs:label "Número de paneles de jog" ;
    ns1:identificador "NKEYBD" ;
    ns1:textoExtracto "El parámetro NKEYBD establece el número de paneles de jog del sistema." .

ns1:TablaParaConfigurarLasTeclasDeJogDelPrimerPanel a ns1:Parametro ;
    rdfs:label "Tabla para configurar las teclas de jog del primer panel" ;
    ns1:identificador "JOGKEYDEF" ;
    ns1:textoExtracto "El parámetro JOGKEYDEF corresponde al primer panel de jog." .

ns1:TablaParaConfigurarLasTeclasDeJogDelSegundoPanel a ns1:Parametro ;
    rdfs:label "Tabla para configurar las teclas de jog del segundo panel" ;
    ns1:identificador "JOGKEYBD2DEF" ;
    ns1:textoExtracto "El parámetro JOGKEYBD2DEF corresponde al segundo panel de jog." .

