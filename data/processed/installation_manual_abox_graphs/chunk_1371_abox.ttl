@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_20_2_2_Interface a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de mapeo de recursos EtherCAT/PLC"@es ;
    ex:textoExtracto """
| Bloque. | Color y tipo de recurso. |
| --- | --- |
|  | Color azul. Entradas digitales. |
|  | Color morado. Salidas digitales. |
|  | Color rojo. Mapeo de recursos EtherCAT a registros de PLC. |
|  | Color gris. Mapeo de registros de PLC a recursos EtherCAT. |
|  | Color verde. Registros de las entradas analógicas Fagor. |
|  | Color amarillo. Registros de las salidas analógicas Fagor.
"""@es .

ex:Interfaz_EtherCAT_PLC
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de mapeo EtherCAT-PLC"@es ;
    ex:textoExtracto "Descripción del interface [...] Mapeo de recursos EtherCAT a registros de PLC [...] Mapeo de registros de PLC a recursos EtherCAT"@es ;
    ex:detalladoEnEsquema ex:Tabla_20_2_2_Interface .

ex:EntradasDigitales_Interface
    a ex:ComponenteElectrico ;
    rdfs:label "Entradas digitales (azul)"@es ;
    ex:textoExtracto "Color azul. Entradas digitales."@es ;
    ex:documentadoEn ex:Tabla_20_2_2_Interface .

ex:SalidasDigitales_Interface
    a ex:ComponenteElectrico ;
    rdfs:label "Salidas digitales (morado)"@es ;
    ex:textoExtracto "Color morado. Salidas digitales."@es ;
    ex:documentadoEn ex:Tabla_20_2_2_Interface .

ex:Mapeo_EtherCAT_a_PLC
    a ex:Sistema ;
    rdfs:label "Mapeo EtherCAT → PLC (rojo)"@es ;
    ex:textoExtracto "Color rojo. Mapeo de recursos EtherCAT a registros de PLC."@es ;
    ex:detalladoEnEsquema ex:Tabla_20_2_2_Interface .

ex:Mapeo_PLC_a_EtherCAT
    a ex:Sistema ;
    rdfs:label "Mapeo PLC → EtherCAT (gris)"@es ;
    ex:textoExtracto "Color gris. Mapeo de registros de PLC a recursos EtherCAT."@es ;
    ex:detalladoEnEsquema ex:Tabla_20_2_2_Interface .

ex:EntradasAnalogicas_Fagor
    a ex:Sensor ;
    rdfs:label "Entradas analógicas Fagor (verde)"@es ;
    ex:textoExtracto "Color verde. Registros de las entradas analógicas Fagor."@es ;
    ex:documentadoEn ex:Tabla_20_2_2_Interface .

ex:SalidasAnalogicas_Fagor
    a ex:Actuador ;
    rdfs:label "Salidas analógicas Fagor (amarillo)"@es ;
    ex:textoExtracto "Color amarillo. Registros de las salidas analógicas Fagor."@es ;
    ex:documentadoEn ex:Tabla_20_2_2_Interface .