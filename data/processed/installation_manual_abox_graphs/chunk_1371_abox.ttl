@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:InterfazUsuario1371 a ex:InterfazUsuario ;
    ex:textoExtracto "Color azul. Entradas digitales." ;
    ex:compuestoPor ex:EntradaDigital1371 ;
    ex:compuestoPor ex:SalidaDigital1371 ;
    ex:compuestoPor ex:MapeoEtherCAT_PLC1371 ;
    ex:compuestoPor ex:MapeoPLC_EtherCAT1371 ;
    ex:compuestoPor ex:EntradaAnalogicaFagor1371 ;
    ex:compuestoPor ex:SalidaAnalogicaFagor1371 .

ex:EntradaDigital1371 a ex:Sensor ;
    rdfs:label "Entradas digitales" ;
    ex:textoExtracto "Color azul. Entradas digitales." .

ex:SalidaDigital1371 a ex:Actuador ;
    rdfs:label "Salidas digitales" ;
    ex:textoExtracto "Color morado. Salidas digitales." .

ex:MapeoEtherCAT_PLC1371 a ex:Componente ;
    rdfs:label "Mapeo de recursos EtherCAT a registros de PLC" ;
    ex:textoExtracto "Color rojo. Mapeo de recursos EtherCAT a registros de PLC." .

ex:MapeoPLC_EtherCAT1371 a ex:Componente ;
    rdfs:label "Mapeo de registros de PLC a recursos EtherCAT" ;
    ex:textoExtracto "Color gris. Mapeo de registros de PLC a recursos EtherCAT." .

ex:EntradaAnalogicaFagor1371 a ex:Sensor ;
    rdfs:label "Registros de las entradas analógicas Fagor" ;
    ex:textoExtracto "Color verde. Registros de las entradas analógicas Fagor." .

ex:SalidaAnalogicaFagor1371 a ex:Actuador ;
    rdfs:label "Registros de las salidas analógicas Fagor" ;
    ex:textoExtracto "Color amarillo. Registros de las salidas analógicas Fagor." .