@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_28e4019301 a ns1:Parametro ;
    rdfs:label "Parámetro máquina JOGKEYBDkbDEF" ;
    ns1:textoExtracto "El significado de este parámetro es similar al parámetro máquina JOGKEYBDkbDEF." .

ns1:Parametro_62b0e19260 a ns1:Parametro ;
    rdfs:label "Parámetro máquina JOGTYPE" ;
    ns1:textoExtracto "respetando también lo definido en el parámetro máquina JOGTYPE." .

ns1:Parametro_d6e945ad3c a ns1:Parametro ;
    rdfs:label "Parámetro máquina AXISNAME" ;
    ns1:textoExtracto "según el parámetro AXISNAME." .

ns1:RegistroKEYBD1 a ns1:Parametro ;
    rdfs:label "Registro KEYBD1" ;
    ns1:textoExtracto "Los registros KEYBD1 y KEYBD2 son una copia del mapa de teclas pulsadas del último teclado utilizado." .

ns1:RegistroKEYBD2 a ns1:Parametro ;
    rdfs:label "Registro KEYBD2" ;
    ns1:textoExtracto "Los registros KEYBD1 y KEYBD2 son una copia del mapa de teclas pulsadas del último teclado utilizado." .

ns1:TeclasDeUsuario a ns1:ComponenteElectrico ;
    rdfs:label "Teclas de usuario" ;
    ns1:textoExtracto "Para definir el comportamiento de cada una de las teclas, se les asignará uno de los siguientes valores:" .

ns1:TeclasJOGPANEL a ns1:ComponenteElectrico ;
    rdfs:label "Teclas JOG-PANEL" ;
    ns1:textoExtracto "JOG-PANEL 1 2 15 16 GKEYS O J" .

