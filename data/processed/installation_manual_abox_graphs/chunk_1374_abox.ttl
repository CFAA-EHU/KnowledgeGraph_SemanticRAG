@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Ficha_Overlapped a ex:InterfazUsuario ;
    rdfs:label "Overlapped" ;
    ex:textoExtracto "La ficha \"Overlapped\" define si se permite la superposición de recursos en diferentes módulos." .

ex:Icono_LoadFilter a ex:InterfazUsuario ;
    rdfs:label "Load filter" ;
    ex:textoExtracto "validarla con el icono \"Load filter\" situado en la parte superior derecha." .

ex:Parametro_Overlapped a ex:Parametro ;
    rdfs:label "Overlapped" ;
    ex:valor "Right" ;
    ex:textoExtracto "Overlapped = Right." .

ex:Parametro_Starts a ex:Parametro ;
    rdfs:label "Starts" ;
    ex:valor "81" ;
    ex:textoExtracto "Starts=81 Overlapped = No." .

ex:Parametro_Overlapped_No a ex:Parametro ;
    rdfs:label "Overlapped" ;
    ex:valor "No" ;
    ex:textoExtracto "Overlapped = No." .

ex:Sistema_Programa a ex:Sistema ;
    rdfs:label "programa" ;
    ex:textoExtracto "el programa reordena los recursos siguientes" ;
    ex:textoExtracto "el programa dará error" .

ex:AccionProhibida_AsignarNumeroExistente a ex:AccionProhibida ;
    rdfs:label "asignar número existente en el bus" ;
    ex:textoExtracto "En el caso de asignar a un recurso un número que ya existe en el bus, el programa reordena los recursos siguientes (numeración superior)." ;
    ex:textoExtracto "En el caso de asignar a un recurso un número que ya existe en el bus, el programa dará error." .