@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MapaDeTeclasPulsadasDelUltimoTecladoUtilizado a ns1:Parametro ;
    rdfs:label "Mapa de teclas pulsadas del último teclado utilizado" ;
    ns1:identificador "KEYBD1" ;
    ns1:textoExtracto "Los registros KEYBD1 y KEYBD2 son una copia del mapa de teclas pulsadas del último teclado utilizado." .

ns1:MapaDeTeclasPulsadasDelUltimoTecladoUtilizado_30e438cf97 a ns1:Parametro ;
    rdfs:label "Mapa de teclas pulsadas del último teclado utilizado" ;
    ns1:identificador "KEYBD2" ;
    ns1:textoExtracto "Los registros KEYBD1 y KEYBD2 son una copia del mapa de teclas pulsadas del último teclado utilizado." .

ns1:MapaDeTeclasPulsadasEnCadaPanelDeMandoGeneral a ns1:Parametro ;
    rdfs:label "Mapa de teclas pulsadas en cada panel de mando (general)" ;
    ns1:identificador "KEYBD1_n" ;
    ns1:textoExtracto "Los registros KEYBD1_n y KEYBD2_n indican qué tecla se ha pulsado en cada panel de mando." .

ns1:MapaDeTeclasPulsadasEnCadaPanelDeMandoGeneral_67262c0c42 a ns1:Parametro ;
    rdfs:label "Mapa de teclas pulsadas en cada panel de mando (general)" ;
    ns1:identificador "KEYBD2_n" ;
    ns1:textoExtracto "Los registros KEYBD1_n y KEYBD2_n indican qué tecla se ha pulsado en cada panel de mando." .

ns1:MapaDeTeclasPulsadasEnElPrimerPanelDeJog a ns1:Parametro ;
    rdfs:label "Mapa de teclas pulsadas en el primer panel de jog" ;
    ns1:identificador "KEYBD1_1" ;
    ns1:textoExtracto "Los registros KEYBD1_1 y KEYBD2_1 corresponden al primer panel de jog." .

ns1:MapaDeTeclasPulsadasEnElPrimerPanelDeJog_864340cc17 a ns1:Parametro ;
    rdfs:label "Mapa de teclas pulsadas en el primer panel de jog" ;
