ns1:InhibicionDeTeclasYConmutadoresEnTodosLosPanelesDeMandoSimultaneamente a ns1:Parametro ;
    rdfs:label "Inhibición de teclas y conmutadores en todos los paneles de mando simultáneamente" ;
    ns1:identificador "KEYDIS1" ;
    ns1:textoExtracto "Los registros KEYDIS1, KEYDIS2 y KEYDIS3 inhiben (bit=1) las teclas y los conmutadores en todos los paneles de mando simultáneamente." .

