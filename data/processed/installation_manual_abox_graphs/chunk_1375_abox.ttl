ns1:ControlDeLedLamparasDeLasTeclasDeTodosLosPanelesDeMandoSimultaneamente a ns1:Parametro ;
    rdfs:label "Control de led (lámparas) de las teclas de todos los paneles de mando simultáneamente" ;
    ns1:identificador "KEYLED1" ;
    ns1:textoExtracto "Los registros KEYLED1 y KEYLED2 controlan los led (lámparas) de las teclas de todos los paneles de mando simultáneamente." .

