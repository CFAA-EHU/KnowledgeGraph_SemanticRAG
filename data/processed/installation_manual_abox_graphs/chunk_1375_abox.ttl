@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
ex:ModoOperacionConfiguracion a ex:ModoOperacion ;
    ex:textoExtracto "configuración del modo de trabajo (rango de medición)" .

ex:VistaBloques a ex:InterfazUsuario ;
    ex:textoExtracto "En la vista de bloques, hacer clic sobre un módulo para acceder a sus propiedades" .

ex:ModuloEntradasAnalogicasFagorIBILAI4UPAC a ex:ComponenteElectrico ;
    ex:identificador "Fagor IB IL AI 4 - U-PAC" ;
    ex:textoExtracto "Entradas analógicas Fagor (por ejemplo, el módulo Fagor IB IL AI 4 - U-PAC)" .

ex:ModuloSalidasAnalogicasFagorIBILOA2UPAC a ex:ComponenteElectrico ;
    ex:identificador "Fagor IB IL AO 2 - U-PAC" ;
    ex:textoExtracto "Salidas analógicas Fagor (por ejemplo, el módulo Fagor IB IL AO 2 - U-PAC)" .

ex:MaquinaConfigurable a ex:Maquina ;
    ex:textoExtracto "La configuración del modo de trabajo (rango de medición) de estos módulos se realiza desde el mapeador" ;
    ex:compuestoPor ex:ModuloEntradasAnalogicasFagorIBILAI4UPAC, ex:ModuloSalidasAnalogicasFagorIBILOA2UPAC .

ex:FrecuenciaMuestreo a ex:Frecuencia ;
    ex:textoExtracto "permiten configurar ... la frecuencia del muestreo" .

ex:ParametroRangoMedicion a ex:Parametro ;
    ex:textoExtracto "permiten configurar el rango de medición de cada entrada, así como la frecuencia del muestreo" .