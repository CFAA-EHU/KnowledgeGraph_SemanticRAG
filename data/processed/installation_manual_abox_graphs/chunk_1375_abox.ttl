@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModuloEntradaAnalogica_Fagor_IB_IL_AI_4_U_PAC
    a               ex:ComponenteElectrico ;
    rdfs:label      "Módulo Fagor IB IL AI 4 - U-PAC" ;
    ex:identificador "Fagor IB IL AI 4 - U-PAC" ;
    ex:textoExtracto "Entradas analógicas Fagor (por ejemplo, el módulo Fagor IB IL AI 4 - U-PAC). Estos módulos, además del número de la primera entrada, permiten configurar el rango de medición de cada entrada, así como la frecuencia del muestreo." .

ex:ModuloSalidaAnalogica_Fagor_IB_IL_AO_2_U_PAC
    a               ex:ComponenteElectrico ;
    rdfs:label      "Módulo Fagor IB IL AO 2 - U-PAC" ;
    ex:identificador "Fagor IB IL AO 2 - U-PAC" ;
    ex:textoExtracto "Salidas analógicas Fagor (por ejemplo, el módulo Fagor IB IL AO 2 - U-PAC). Estos módulos, además del número de la primera salida, permiten configurar el rango de medición de cada salida." .

ex:InterfazConfiguracionModulosAnalogicos
    a               ex:InterfazUsuario ;
    rdfs:label      "Interfaz de configuración de módulos analógicos (mapeador)" ;
    ex:textoExtracto "La configuración del modo de trabajo (rango de medición) de estos módulos se realiza desde el mapeador. En la vista de bloques, hacer clic sobre un módulo para acceder a sus propiedades." ;
    ex:controla    ex:ModuloEntradaAnalogica_Fagor_IB_IL_AI_4_U_PAC ;
    ex:controla    ex:ModuloSalidaAnalogica_Fagor_IB_IL_AO_2_U_PAC .

ex:ParametroRangoMedicion
    a               ex:Parametro ;
    rdfs:label      "Rango de medición" ;
    ex:textoExtracto "permiten configurar el rango de medición de cada entrada... el rango de medición de cada salida" ;
    ex:monitoreaParametro ex:ModuloEntradaAnalogica_Fagor_IB_IL_AI_4_U_PAC ;
    ex:monitoreaParametro ex:ModuloSalidaAnalogica_Fagor_IB_IL_AO_2_U_PAC .

ex:ParametroFrecuenciaMuestreo
    a               ex:Parametro ;
    rdfs:label      "Frecuencia de muestreo" ;
    ex:textoExtracto "permiten configurar... la frecuencia del muestreo" ;
    ex:monitoreaParametro ex:ModuloEntradaAnalogica_Fagor_IB_IL_AI_4_U_PAC .