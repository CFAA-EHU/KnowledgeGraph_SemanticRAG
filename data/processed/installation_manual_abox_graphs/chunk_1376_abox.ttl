ns1:ControlDeLosLedLamparasDeLasTeclasDeTodosLosPanelesDeMandoSimultaneamente a ns1:Parametro ;
    rdfs:label "Control de los led (lámparas) de las teclas de todos los paneles de mando simultáneamente" ;
    ns1:identificador "KEYLED1" ;
    ns1:textoExtracto "Los registros KEYLED1 y KEYLED2 controlan los led (lámparas) de las teclas de todos los paneles de mando simultáneamente." .

ns1:ControlDeLosLedLamparasDeLasTeclasDeTodosLosPanelesDeMandoSimultaneamente_20414ee451 a ns1:Parametro ;
