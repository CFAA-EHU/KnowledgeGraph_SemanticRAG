@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ExportarArchivoRutado_1376
    a                  ex:TareaMantenimiento ;
    rdfs:label         "Exportar archivo de rutado"@es ;
    ex:textoExtracto   "Para exportar el archivo de rutado, seleccionar la opción \"Exports router file\". El archivo se puede exportar con cualquier nombre (extensión *.xml). Este es el archivo que se debe copiar al CNC."@es ;
    ex:identificador   "Exports router file"@en .

ex:ArchivoRutado_1376
    a                  ex:InterfazUsuario ;
    rdfs:label         "Archivo de rutado (*.xml)"@es ;
    ex:textoExtracto   "archivo de rutado [...] extensión *.xml"@es ;
    ex:identificador   "*.xml" .