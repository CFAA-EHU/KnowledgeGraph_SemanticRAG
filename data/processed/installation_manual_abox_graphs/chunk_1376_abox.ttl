    ns1:identificador "KEYLED2" ;
    ns1:textoExtracto "Los registros KEYLED1 y KEYLED2 controlan los led (lámparas) de las teclas de todos los paneles de mando simultáneamente." .

ns1:ControlDeLosLedLamparasDeLasTeclasDelPrimerPanelDeJog a ns1:Parametro ;
    rdfs:label "Control de los led (lámparas) de las teclas del primer panel de jog" ;
    ns1:identificador "KEYLED1_1" ;
    ns1:textoExtracto "Los registros KEYLED1_n y KEYLED2_n controlan los led (lámparas) de las teclas de cada panel de mando. Los registros KEYLED1_1 y KEYLED2_1 corresponden al primer panel de jog." .

