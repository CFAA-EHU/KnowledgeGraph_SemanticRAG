    ns1:textoExtracto "Los registros KEYLED1_n y KEYLED2_n controlan los led (lámparas) de las teclas de cada panel de mando. Los registros KEYLED1_1 y KEYLED2_1 corresponden al primer panel de jog." .

ns1:ControlDeLosLedLamparasDeLasTeclasDelSegundoPanelDeJog a ns1:Parametro ;
    rdfs:label "Control de los led (lámparas) de las teclas del segundo panel de jog" ;
    ns1:identificador "KEYLED1_2" ;
    ns1:textoExtracto "Los registros KEYLED1_n y KEYLED2_n controlan los led (lámparas) de las teclas de cada panel de mando. Los registros KEYLED1_2 y KEYLED2_2 al segundo." .

