@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ExportarArchivoRutado_1376 a ex:InterfazUsuario ;
    rdfs:label "Exportar archivo de rutado"@es ;
    ex:textoExtracto "Para exportar el archivo de rutado, seleccionar la opción \"Exports router file\". El archivo se puede exportar con cualquier nombre (extensión *.xml). Este es el archivo que se debe copiar al CNC."@es .

ex:OpcionExportarRutado_1376 a ex:InterfazUsuario ;
    rdfs:label "Opción Exportar archivo de rutado"@es ;
    ex:textoExtracto "seleccionar la opción \"Exports router file\""@es ;
    ex:documentadoEn ex:ExportarArchivoRutado_1376 .

ex:ArchivoRutadoXML_1376 a ex:ComponenteElectrico ;
    rdfs:label "Archivo de rutado XML"@es ;
    ex:identificador "*.xml" ;
    ex:textoExtracto "El archivo se puede exportar con cualquier nombre (extensión *.xml). Este es el archivo que se debe copiar al CNC."@es .