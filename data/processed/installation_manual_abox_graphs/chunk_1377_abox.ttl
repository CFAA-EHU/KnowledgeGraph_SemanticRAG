@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Accion_GuardarProyecto_1377
    a               ex:AccionProhibida ;
    rdfs:label      "Guardar proyecto (incompleto)"@es ;
    ex:textoExtracto
        "El proyecto se puede guardar aunque no esté finalizado. En una sesión posterior, se puede recuperar la configuración guardada y continuar a partir de ese punto."@es ;
    ex:identificador "Generate project"@es .

ex:InterfazUsuario_GenerarProyecto_1377
    a               ex:InterfazUsuario ;
    rdfs:label      "Opción 'Generate project'"@es ;
    ex:textoExtracto
        "Para guardar el proyecto, seleccionar la opción \"Generate project\"."@es ;
    ex:habilitadoPor ex:Accion_GuardarProyecto_1377 .

ex:FormatoArchivo_FEM_1377
    a               ex:Parametro ;
    rdfs:label      "Formato de proyecto (*.fem)"@es ;
    ex:textoExtracto
        "Guardar el proyecto con cualquier nombre (extensión *.fem)."@es ;
    ex:valor        "*.fem" .