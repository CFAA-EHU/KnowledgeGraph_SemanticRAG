ns1:Parametro_8bf596bbbf a ns1:Parametro ;
    rdfs:label "Marca para deshabilitar el octavo panel de jog" ;
    ns1:identificador "PANELOFF8" ;
    ns1:textoExtracto "Si el PLC pone una de estas marcas a (=1) se deshabilita el panel de jog correspondiente." .

