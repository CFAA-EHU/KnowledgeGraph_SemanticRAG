ex:Tarea_CopiarArchivoRutadoCNC
    a               ex:TareaMantenimiento ;
    rdfs:label      "Copiar archivo de rutado al CNC"@es ;
    ex:textoExtracto "Para copiar el archivo de rutado al CNC (archivo xml), renombrarlo como 'resourceRouterConf.xml' y copiarlo a la carpeta ../Mtb/Data."@es ;
