@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:resourceRouterConf_xml a ex:ComponenteElectrico ;
    rdfs:label "resourceRouterConf.xml" ;
    ex:textoExtracto "renombrarlo como \"resourceRouterConf.xml\"" .

ex:archivo_xml a ex:ComponenteElectrico ;
    rdfs:label "archivo xml" ;
    ex:textoExtracto "archivo xml" .

ex:carpeta_Mtb_Data a ex:Sistema ;
    rdfs:label "../Mtb/Data" ;
    ex:textoExtracto "copiarlo a la carpeta ../Mtb/Data" .