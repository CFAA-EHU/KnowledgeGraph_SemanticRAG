@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ModoDiagnosis a ex:ModoOperacion ;
    ex:textoExtracto "El modo diagnosis ofrece toda la información necesaria de los módulos conectados al bus EtherCAT. Información general del bus. Información de los esclavos. Información de los módulos." .

ex:BusEtherCAT a ex:ComponenteElectrico ;
    ex:textoExtracto "los módulos conectados al bus EtherCAT" .

ex:ModuloEtherCAT a ex:ComponenteElectrico ;
    ex:textoExtracto "los módulos conectados al bus EtherCAT" ;
    ex:textoExtracto "Información de los módulos" .