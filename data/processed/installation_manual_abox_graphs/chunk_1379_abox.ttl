@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:GestionDeTeclas a ns1:TareaMantenimiento ;
    rdfs:label "Gestión de Teclas" ;
    ns1:textoExtracto "se recomienda gestionar las teclas de usuario mediante sus flancos de subida y bajada, para evitar la posible activación de dispositivos al cambiar de teclado." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:controla ns1:ComponenteElectrico_3dc5da897f ;
    ns1:textoExtracto "el canal asume el estado de las teclas y la posición de los conmutadores del nuevo teclado como los valores activos." .

ns1:ComponenteElectrico_3dc5da897f a ns1:ComponenteElectrico ;
    rdfs:label "Teclado" ;
    ns1:textoExtracto "Al habilitar un teclado (marca PANELOFF) y cada vez que hay un cambio en un teclado (pulsar una tecla, modificar un conmutador, etc)" ;
    ns1:tieneComponente ns1:IndicadorDeLed1,
        ns1:IndicadorDeLed2,
        ns1:Parametro_103e221124,
        ns1:RegistroDeDesactivacion1,
        ns1:RegistroDeDesactivacion2,
        ns1:RegistroDeDesactivacion3 .

ns1:IndicadorDeLed1 a ns1:Parametro ;
    rdfs:label "Indicador de Led 1" ;
    ns1:textoExtracto "la información de todas las marcas y registros asociados al propio teclado (KEYBD1_n, KEYBD2_n, KEYDIS1_n a KEYDIS3_n, KEYLED1_n, KEYLED2_n)" .

ns1:IndicadorDeLed2 a ns1:Parametro ;
    rdfs:label "Indicador de Led 2" ;
    ns1:textoExtracto "la información de todas las marcas y registros asociados al propio teclado (KEYBD1_n, KEYBD2_n, KEYDIS1_n a KEYDIS3_n, KEYLED1_n, KEYLED2_n)" .

ns1:Parametro_103e221124 a ns1:Parametro ;
    rdfs:label "Marca de Teclado 1",
        "Marca de Teclado 2" ;
    ns1:textoExtracto "la información de todas las marcas y registros asociados al propio teclado (KEYBD1_n, KEYBD2_n, KEYDIS1_n a KEYDIS3_n, KEYLED1_n, KEYLED2_n)" .

ns1:RegistroDeDesactivacion1 a ns1:Parametro ;
    rdfs:label "Registro de Desactivación 1" ;
    ns1:textoExtracto "la información de todas las marcas y registros asociados al propio teclado (KEYBD1_n, KEYBD2_n, KEYDIS1_n a KEYDIS3_n, KEYLED1_n, KEYLED2_n)" .

ns1:RegistroDeDesactivacion2 a ns1:Parametro ;
    rdfs:label "Registro de Desactivación 2" ;
    ns1:textoExtracto "la información de todas las marcas y registros asociados al propio teclado (KEYBD1_n, KEYBD2_n, KEYDIS1_n a KEYDIS3_n, KEYLED1_n, KEYLED2_n)" .

ns1:RegistroDeDesactivacion3 a ns1:Parametro ;
    rdfs:label "Registro de Desactivación 3" ;
    ns1:textoExtracto "la información de todas las marcas y registros asociados al propio teclado (KEYBD1_n, KEYBD2_n, KEYDIS1_n a KEYDIS3_n, KEYLED1_n, KEYLED2_n)" .

