@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Error24499 a ex:DiagnosticoFallo ;
    ex:textoExtracto "Error 24499. Error genérico de EtherCAT. El CNC muestra el siguiente error genérico cuando detecta un error en un nodo." ;
    ex:identificador "24499" .

ex:ModoDiagnosis a ex:ModoOperacion ;
    ex:textoExtracto "Para conocer los detalles del error, consultar el modo diagnosis." .

ex:ArbolConfiguracion a ex:Esquema ;
    ex:textoExtracto "El árbol de configuración identifica el nodo en error." .

ex:VentanaDerecha a ex:InterfazUsuario ;
    ex:textoExtracto "La ventana derecha muestra la información disponible para el módulo y el error." .