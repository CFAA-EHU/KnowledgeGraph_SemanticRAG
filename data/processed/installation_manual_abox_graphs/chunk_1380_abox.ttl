@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Error24499_EtherCAT
    a ex:AvisoSeguridad ;
    rdfs:label "Error 24499" ;
    ex:identificador "24499" ;
    ex:textoExtracto "Error 24499. Error genérico de EtherCAT. El CNC muestra el siguiente error genérico cuando detecta un error en un nodo." ;
    ex:mitigaRiesgo ex:ModoDiagnosis_EtherCAT .

ex:ModoDiagnosis_EtherCAT
    a ex:ModoOperacion ;
    rdfs:label "Modo diagnosis" ;
    ex:textoExtracto "Para conocer los detalles del error, consultar el modo diagnosis. Información detallada del módulo en error." ;
    ex:solucionaFallo ex:Error24499_EtherCAT .

ex:InterfazDiagnostico_EtherCAT
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de diagnóstico EtherCAT" ;
    ex:textoExtracto "El árbol de configuración identifica el nodo en error. La ventana derecha muestra la información disponible para el módulo y el error." ;
    ex:ilustradoEn ex:ModoDiagnosis_EtherCAT .