@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Interfaces de usuario y modos de operación
ex:InterfazConfiguracionDisco
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de configuración 'Configuration > Disk' (S.M.A.R.T.)" ;
    ex:textoExtracto "Captura de interfaz del panel 'Configuration > Disk' con lectura S.M.A.R.T. del disco M2-SATA. Se muestra una lista de atributos (modelo, firmware, recuento de errores, temperatura, horas de encendido, etc.) en un cuadro con iconos y valores por columna." ;
    ex:monitoreaParametro ex:ParametroEstadoDisco .

ex:ParametroEstadoDisco
    a ex:Parametro ;
    rdfs:label "Parámetros S.M.A.R.T. del disco M2-SATA" ;
    ex:textoExtracto "atributos (modelo, firmware, recuento de errores, temperatura, horas de encendido, etc.)" ;
    ex:valor "Umbral de aviso (>75%), umbral de error (>90%)" .

ex:VentanaReinicioModos
    a ex:InterfazUsuario ;
    rdfs:label "Ventana 'RESTART WINDOWS' (selección de modos)" ;
    ex:textoExtracto "Ventana de sistema 'RESTART WINDOWS' con tres botones que representan los modos de trabajo: 'Restart Windows in Administrator Mode', 'Restart Windows in Setup Mode' y 'Restart Windows in User Mode'." ;
    ex:ilustradoEn ex:ModoAdministrador, ex:ModoSetup, ex:ModoUsuario .

ex:ModoAdministrador
    a ex:ModoOperacion ;
    rdfs:label "Administrator Mode" ;
    ex:textoExtracto "botón 'Restart Windows in Administrator Mode' [...] cartela de estado con fondo rojo y texto 'ADMINISTRATOR MODE'." .

ex:ModoSetup
    a ex:ModoOperacion ;
    rdfs:label "Setup Mode" ;
    ex:textoExtracto "botón 'Restart Windows in Setup Mode' [...] cartela de estado con fondo amarillo y texto 'SETUP MODE'." .

ex:ModoUsuario
    a ex:ModoOperacion ;
    rdfs:label "User Mode" ;
    ex:textoExtracto "botón 'Restart Windows in User Mode'." .

ex:SenalizacionModoAdministrador
    a ex:InterfazUsuario ;
    rdfs:label "Cartela visual 'ADMINISTRATOR MODE' (fondo rojo)" ;
    ex:textoExtracto "imagen de escritorio [...] fondo rojo y texto 'ADMINISTRATOR MODE'. Funcionan como señalización visual del modo activo, advirtiendo que se trata de entornos no protegidos." ;
    ex:ilustradoEn ex:ModoAdministrador .

ex:SenalizacionModoSetup
    a ex:InterfazUsuario ;
    rdfs:label "Cartela visual 'SETUP MODE' (fondo amarillo)" ;
    ex:textoExtracto "imagen de escritorio [...] fondo amarillo y texto 'SETUP MODE'." ;
    ex:ilustradoEn ex:ModoSetup .

### Herramienta de soporte
ex:CambiadorIdiomaAyudaCNC
    a ex:Herramienta ;
    rdfs:label "CNC Help Language Changer" ;
    ex:identificador "SetupHelp_Vxx.xx.exe" ;
    ex:textoExtracto "listado donde figura 'CNC Help Language Changer'. La imagen contextualiza el procedimiento de obtención del instalador SetupHelp_Vxx.xx.exe y los tipos/idiomas de ayuda soportados." .