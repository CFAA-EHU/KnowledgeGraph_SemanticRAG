@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SistemaTandem rdfs:label "sistema tándem" ;
    ex:textoExtracto "Se aprecian campos de búsqueda/filtrado y el listado donde figura 'CNC Help Language Changer'. La imagen contextualiza el procedimiento de obtención del instalador SetupHelp_Vxx.xx.exe y los tipos/idiomas de ayuda soportados." ;
    a ex:Sistema .

ex:EjeTandem rdfs:label "eje tándem" ;
    ex:textoExtracto "Esquema mecánico de un eje tándem con dos motores (Master axis y Slave axis) que accionan sendos piñones sobre una misma cremallera ('Rack'). Las flechas/etiquetas indican maestro y esclavo; la disposición resalta la suma de par y la posibilidad de precarga para reducir holgura." ;
    a ex:ComponenteMecanico .

ex:MotorMaster rdfs:label "Master axis" ;
    ex:textoExtracto "Esquema mecánico de un eje tándem con dos motores (Master axis y Slave axis) que accionan sendos piñones sobre una misma cremallera ('Rack')." ;
    a ex:ComponenteElectrico .

ex:MotorSlave rdfs:label "Slave axis" ;
    ex:textoExtracto "Esquema mecánico de un eje tándem con dos motores (Master axis y Slave axis) que accionan sendos piñones sobre una misma cremallera ('Rack')." ;
    a ex:ComponenteElectrico .

ex:Piñon rdfs:label "piñones" ;
    ex:textoExtracto "Esquema mecánico de un eje tándem con dos motores (Master axis y Slave axis) que accionan sendos piñones sobre una misma cremallera ('Rack')." ;
    a ex:ComponenteMecanico .

ex:Cremallera rdfs:label "cremallera" ;
    ex:textoExtracto "Esquema mecánico de un eje tándem con dos motores (Master axis y Slave axis) que accionan sendos piñones sobre una misma cremallera ('Rack')." ;
    a ex:ComponenteMecanico .

ex:SistemaGantry rdfs:label "sistema gantry" ;
    ex:textoExtracto "Ilustración esquemática de una fresadora tipo puente en la que se muestran dos parejas de ejes gantry (X–U en la bancada y Z–W en el montante). Se aprecian los carros y el travesaño, con flechas implícitas de desplazamiento lineal y los rótulos de cada eje junto a su guía correspondiente." ;
    a ex:Sistema .

ex:EjeGantryXU rdfs:label "eje gantry X–U" ;
    ex:textoExtracto "Ilustración esquemática de una fresadora tipo puente en la que se muestran dos parejas de ejes gantry (X–U en la bancada y Z–W en el montante)." ;
    a ex:ComponenteMecanico .

ex:EjeGantryZW rdfs:label "eje gantry Z–W" ;
    ex:textoExtracto "Ilustración esquemática de una fresadora tipo puente en la que se muestran dos parejas de ejes gantry (X–U en la bancada y Z–W en el montante)." ;
    a ex:ComponenteMecanico .

ex:Bancada rdfs:label "bancada" ;
    ex:textoExtracto "Ilustración esquemática de una fresadora tipo puente en la que se muestran dos parejas de ejes gantry (X–U en la bancada y Z–W en el montante)." ;
    a ex:ComponenteMecanico .

ex:Pórtico rdfs:label "pórtico" ;
    ex:textoExtracto "Ilustración esquemática de una fresadora tipo puente en la que se muestran dos parejas de ejes gantry (X–U en la bancada y Z–W en el montante). La jerarquía visual distingue la estructura (bancada y pórtico) del conjunto móvil (cabezal)." ;
    a ex:ComponenteMecanico .

ex:Cabezal rdfs:label "cabezal" ;
    ex:textoExtracto "Ilustración esquemática de una fresadora tipo puente en la que se muestran dos parejas de ejes gantry (X–U en la bancada y Z–W en el montante). La jerarquía visual distingue la estructura (bancada y pórtico) del conjunto móvil (cabezal)." ;
    a ex:ComponenteMecanico .

ex:EjeMaestro rdfs:label "MOVAXIS" ;
    ex:textoExtracto "Diagrama conceptual de 'compensación cruzada' donde un eje maestro (MOVAXIS) provoca variaciones en un eje compensado (COMPAXIS)." ;
    a ex:ComponenteMecanico .

ex:EjeCompensado rdfs:label "COMPAXIS" ;
    ex:textoExtracto "Diagrama conceptual de 'compensación cruzada' donde un eje maestro (MOVAXIS) provoca variaciones en un eje compensado (COMPAXIS)." ;
    a ex:ComponenteMecanico .

ex:EsquemaCompensacionCruzada rdfs:label "compensación cruzada" ;
    ex:textoExtracto "Diagrama conceptual de 'compensación cruzada' donde un eje maestro (MOVAXIS) provoca variaciones en un eje compensado (COMPAXIS)." ;
    a ex:Esquema ;
    ex:compuestoPor ex:EjeMaestro, ex:EjeCompensado .