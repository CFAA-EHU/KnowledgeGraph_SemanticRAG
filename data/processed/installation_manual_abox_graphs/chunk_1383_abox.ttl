@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_e534ebe4eb a ns1:Parametro ;
    rdfs:label "Parámetro de control del sistema CNC" ;
    ns1:identificador "M1001" ;
    ns1:textoExtracto "DFU CLK100 = CNCWR (R103,PLC.FRO, M1001)" .

ns1:SistemaCLK100 a ns1:Sistema ;
    rdfs:label "Reloj CLK100" ;
    ns1:controla ns1:CNC8070_86d06fc892 ;
    ns1:textoExtracto "Con el flanco de subida en el reloj CLK100, fijar el valor de feed override calculado." .

ns1:CNC8070_86d06fc892 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:monitoreaParametro ns1:ValorDeFeedOverrideCalculado,
        ns1:ValorDelRegistroR103 ;
    ns1:textoExtracto "DFU CLK100 = CNCWR (R103,PLC.FRO, M1001)" .

ns1:ValorDeFeedOverrideCalculado a ns1:Parametro ;
    rdfs:label "Valor de feed override calculado" ;
    ns1:identificador "PLC.FRO" ;
    ns1:textoExtracto "Con el flanco de subida en el reloj CLK100, fijar el valor de feed override calculado." .

ns1:ValorDelRegistroR103 a ns1:Parametro ;
    rdfs:label "Valor del registro R103" ;
    ns1:identificador "R103" ;
    ns1:textoExtracto "Ajustar el valor del registro R103; ignorar el sentido de giro del volante (signo) y limitar el valor al 120%." .

