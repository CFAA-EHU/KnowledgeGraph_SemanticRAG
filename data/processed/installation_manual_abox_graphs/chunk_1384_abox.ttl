@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:DiagramaCompensacionCruzada_2_3_16
    a ex:Esquema ;
    rdfs:label "Diagrama de compensación cruzada MOVAXIS-COMPAXIS"@es ;
    ex:textoExtracto "Diagrama conceptual de 'compensación cruzada' donde un eje maestro (MOVAXIS) provoca variaciones en un eje compensado (COMPAXIS). El gráfico representa un volumen/carcasa con el eje maestro desplazándose; se señalan posiciones discretas 'POSITION n' y el error asociado 'POSERROR n'."@es ;
    ex:ilustradoEn ex:Pagina_77 .

ex:PalpadorSobremesaTorno_2_3_25
    a ex:Sensor ;
    rdfs:label "Palpador de sobremesa (torno)"@es ;
    ex:textoExtracto "Ilustración de un palpador de sobremesa para calibración de herramientas en torno: se observa el útil de torneado aproximándose al palpador fijo instalado en la bancada. El dibujo destaca el punto de contacto, el soporte del palpador y la geometría de la herramienta, enfatizando la detección por contacto y la orientación del conjunto en un entorno de medición estático."@es ;
    ex:detalladoEnEsquema ex:DiagramaPalpadorTorno_2_3_25 ;
    ex:documentadoEn ex:Pagina_92 .

ex:DiagramaPalpadorTorno_2_3_25
    a ex:Esquema ;
    rdfs:label "Esquema de palpador de sobremesa para torno"@es ;
    ex:textoExtracto "Ilustración de un palpador de sobremesa para calibración de herramientas en torno."@es .

ex:PalpadorMedidaMaquina_2_3_25
    a ex:Sensor ;
    rdfs:label "Palpador de medida (esférico)"@es ;
    ex:textoExtracto "Ilustración de un palpador de medida montado en máquina para inspección de pieza: se representa un palpador tipo esférico acercándose a la superficie de una pieza cilíndrica, con el vástago vertical y el punto de contacto marcado. La composición resalta la funcionalidad metrológica en ciclo (toma de puntos en la pieza), la dirección de aproximación y el rol del disparo del palpador como evento de medición."@es ;
    ex:detalladoEnEsquema ex:DiagramaPalpadorMedida_2_3_25 ;
    ex:documentadoEn ex:Pagina_92 .

ex:DiagramaPalpadorMedida_2_3_25
    a ex:Esquema ;
    rdfs:label "Esquema de palpador de medida esférico"@es ;
    ex:textoExtracto "Ilustración de un palpador de medida montado en máquina para inspección de pieza."@es .

ex:SensorGap_ParametrosGenerales
    a ex:Sensor ;
    rdfs:label "Sensor de gap"@es ;
    ex:textoExtracto "Gráfico del sensor de gap con ejes mV (horizontal) y mm/inch (vertical)."@es ;
    ex:detalladoEnEsquema ex:GraficoSensorGap_100 ;
    ex:documentadoEn ex:Pagina_100 ;
    ex:monitoreaParametro ex:ParametroGap .

ex:GraficoSensorGap_100
    a ex:Esquema ;
    rdfs:label "Gráfico de calibración del sensor de gap"@es ;
    ex:textoExtracto "Gráfico del sensor de gap con ejes mV (horizontal) y mm/inch (vertical)."@es .

ex:ParametroGap
    a ex:Parametro ;
    rdfs:label "Gap (mm/inch)"@es ;
    ex:textoExtracto "mm/inch (vertical)"@es ;
    ex:valor "mm/inch" .

