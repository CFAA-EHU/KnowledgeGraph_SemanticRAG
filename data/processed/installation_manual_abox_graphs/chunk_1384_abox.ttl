@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArchivoSoftkeyHelperTxt a ns1:DocumentoTecnico ;
    rdfs:label "Archivo SoftkeyHelper.txt" ;
    ns1:textoExtracto "Los textos de ayuda están definidos en el archivo SoftkeyHelper.txt, y puede haber un archivo por cada idioma, los cuales se guardan en la carpeta \"..\\MTB \\data \\Lang\"." .

ns1:EstadoCNC a ns1:ElementoSeguridad ;
    rdfs:label "Estado CNC" ;
    ns1:textoExtracto "En el archivo SoftkeyHelper.txt también es posible asignar un texto de ayuda a los iconos que muestran el estado del CNC, en la parte superior de la pantalla." .

ns1:HMI_INERROR a ns1:Parametro ;
    rdfs:label "En Error" ;
    ns1:identificador "HMI_INERROR" ;
    ns1:textoExtracto "[ HMI] HMI_INERROR=" .

ns1:HMI_INEXECUTION a ns1:Parametro ;
    rdfs:label "En Ejecución" ;
    ns1:identificador "HMI_INEXECUTION" ;
    ns1:textoExtracto "[ HMI] HMI_INEXECUTION=" .

ns1:HMI_INTERRUPTED a ns1:Parametro ;
    rdfs:label "Interrumpido" ;
    ns1:identificador "HMI_INTERRUPTED" ;
    ns1:textoExtracto "[ HMI] HMI_INTERRUPTED=" .

ns1:HMI_NOREADY a ns1:Parametro ;
    rdfs:label "Estado No Listo" ;
    ns1:identificador "HMI_NOREADY" ;
    ns1:textoExtracto "[ HMI] HMI_NOREADY=" .

ns1:HMI_READY a ns1:Parametro ;
    rdfs:label "Estado Listo" ;
    ns1:identificador "HMI_READY" ;
    ns1:textoExtracto "[ HMI] HMI_READY=" .

ns1:ModoOperacionAutomatico a ns1:ModoOperacion ;
    rdfs:label "Modo Operación Automático" ;
    ns1:textoExtracto "[ AUTOMATIC MODE] AUTO1=Seleccionar programa AUTO2=Prg en simulación AUTO3=Inspección AUTO4=Abandonar inspección AUTO5=Reposicionar AUTO6=Reposicionar inicio bloque AUTO7=Modo ejecución AUTO8=Cancelar bloque AUTO9=Gráficos" .

