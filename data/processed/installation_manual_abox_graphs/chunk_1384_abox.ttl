    a ex:Pagina ;
    ex:identificador "77" ;
    ex:textoExtracto "Sección 2.3.16: Tablas de compensación cruzada."@es .

ex:Pagina_92
    a ex:Pagina ;
    ex:identificador "92" ;
    ex:textoExtracto "Sección 2.3.25: Configuración del palpador."@es .

