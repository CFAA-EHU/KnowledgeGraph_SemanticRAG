@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaRCS_S a ns1:Sistema ;
    rdfs:label "Módulo RCS-S" ;
    ns1:textoExtracto "El módulo \"RCS-S\" permite disponer de un número adicional de entradas de contaje y salidas analógicas (I/Os remotas). Estos módulos se conectan a la unidad central a través del bus Sercos-II, siendo un nodo más dentro del bus." ;
    ns1:tieneComponente ns1:ConectorE21A,
        ns1:ConectorE21B,
        ns1:ConectorE21C,
        ns1:ConectorE21D,
        ns1:ConectorI37A,
        ns1:ConectorI37B .

ns1:ConectorE21A a ns1:ComponenteElectrico ;
    rdfs:label "Conector E21A" ;
    ns1:identificador "E21A" ;
    ns1:textoExtracto "Conector ꞏE21Aꞏ. Entrada de contaje." .

ns1:ConectorE21B a ns1:ComponenteElectrico ;
    rdfs:label "Conector E21B" ;
    ns1:identificador "E21B" ;
    ns1:textoExtracto "Conector ꞏE21Bꞏ. Entrada de contaje." .

ns1:ConectorE21C a ns1:ComponenteElectrico ;
    rdfs:label "Conector E21C" ;
    ns1:identificador "E21C" ;
    ns1:textoExtracto "Conector ꞏE21Cꞏ. Entrada de contaje." .

ns1:ConectorE21D a ns1:ComponenteElectrico ;
    rdfs:label "Conector E21D" ;
    ns1:identificador "E21D" ;
    ns1:textoExtracto "Conector ꞏE21Dꞏ. Entrada de contaje." .

ns1:ConectorI37A a ns1:ComponenteElectrico ;
    rdfs:label "Conector I37A" ;
    ns1:identificador "I37A" ;
    ns1:textoExtracto "Conector ꞏI37Aꞏ. 2 salidas analógicas de propósito general." .

ns1:ConectorI37B a ns1:ComponenteElectrico ;
    rdfs:label "Conector I37B" ;
    ns1:identificador "I37B" ;
    ns1:textoExtracto "Conector ꞏI37Bꞏ. 2 salidas analógicas de propósito general." .

