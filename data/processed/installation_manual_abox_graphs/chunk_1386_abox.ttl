@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaSercos a ns1:Sistema ;
    rdfs:label "Contadora Sercos" ;
    ns1:textoExtracto "La contadora Sercos es, al igual que los reguladores, un tipo de nodo del anillo Sercos." ;
    ns1:tieneComponente ns1:NumeroDeNodosContadorasSercosEnElBus,
        ns1:TablaDeIdentificadoresDeLaRuletaAsociadasALasContadorasSercos_c785ff59b0 .

ns1:NumeroDeNodosContadorasSercosEnElBus a ns1:Parametro ;
    rdfs:label "Número de nodos contadoras Sercos en el bus" ;
    ns1:identificador "NSERCOUNT" ;
    ns1:textoExtracto "NSERCOUNT | Número de nodos contadoras Sercos en el bus." .

ns1:TablaDeIdentificadoresDeLaRuletaAsociadasALasContadorasSercos_c785ff59b0 a ns1:Parametro ;
    rdfs:label "Tabla de identificadores de la ruleta asociadas a las contadoras Sercos" ;
    ns1:identificador "SERCOUNTID" ;
    ns1:textoExtracto "SERCOUNTID | Tabla de identificadores de la ruleta asociadas a las contadoras Sercos." .

