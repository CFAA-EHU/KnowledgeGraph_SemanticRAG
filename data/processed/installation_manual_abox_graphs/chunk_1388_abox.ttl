@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IndicaElNumeroDeLaSalidaAnalogicaQueSeUtilizaParaLaConsigna a ns1:Parametro ;
    rdfs:label "Indica el número de la salida analógica que se utiliza para la consigna" ;
    ns1:identificador "ANAOUTID" ;
    ns1:textoExtracto "el parámetro ANAOUTID indica el número de la salida analógica que se utiliza para la consigna." .

ns1:IndicaElOrdenLogicoDeLasContadorasSercos a ns1:Parametro ;
    rdfs:label "Indica el orden lógico de las contadoras Sercos" ;
    ns1:identificador "SERCOUNTID" ;
    ns1:textoExtracto "Las contadoras Sercos se numeran según su orden lógico (parámetro SERCOUNTID)." .

