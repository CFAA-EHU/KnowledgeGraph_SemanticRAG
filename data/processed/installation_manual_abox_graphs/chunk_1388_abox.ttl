@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EjeRotativo_1388_1 a ex:Sistema ;
    rdfs:label "eje rotativo"@es ;
    ex:textoExtracto "Las etiquetas aparecen situadas sobre el sólido 3D, indicando orientación y asociación funcional de cada eje para la personalización típica de torno y fresadora."@es .

ex:EjeRotativo_1388_2 a ex:Sistema ;
    rdfs:label "eje rotativo"@es ;
    ex:textoExtracto "Tres esquemas circulares comparan el comportamiento 'Módulo': posiciones programadas a 90° y 330° y desplazamientos relativos (B300/B–300) con flechas de sentido y arcos trazados."@es .

ex:EsquemaCircular_1388_1 a ex:Esquema ;
    rdfs:label "esquema circular"@es ;
    ex:textoExtracto "Tres esquemas circulares comparan el comportamiento 'Módulo': posiciones programadas a 90° y 330° y desplazamientos relativos (B300/B–300) con flechas de sentido y arcos trazados. Ilustran cómo, en G90/G91, el recorrido efectivo es inferior a una vuelta, y cómo el signo fija el sentido cuando no hay SHORTESTWAY ni UNIDIR."@es .

ex:ModoOperacion_G90 a ex:ModoOperacion ;
    rdfs:label "G90"@es ;
    ex:textoExtracto "Ilustran cómo, en G90/G91, el recorrido efectivo es inferior a una vuelta, y cómo el signo fija el sentido cuando no hay SHORTESTWAY ni UNIDIR."@es .

ex:ModoOperacion_G91 a ex:ModoOperacion ;
    rdfs:label "G91"@es ;
    ex:textoExtracto "Ilustran cómo, en G90/G91, el recorrido efectivo es inferior a una vuelta, y cómo el signo fija el sentido cuando no hay SHORTESTWAY ni UNIDIR."@es .

ex:EsquemaCircular_1388_2 a ex:Esquema ;
    rdfs:label "esquema circular"@es ;
    ex:textoExtracto "Esquema circular con arcos que muestran el 'Sentido de giro único (UNIDIR = Positivo)'. Se representan posiciones a 90°, 300° y –300° y la imposibilidad de girar en el sentido contrario, enfatizando que en G90 el eje siempre toma el sentido predeterminado."@es .

ex:ModoOperacion_UNIDIR a ex:ModoOperacion ;
    rdfs:label "UNIDIR"@es ;
    ex:textoExtracto "Esquema circular con arcos que muestran el 'Sentido de giro único (UNIDIR = Positivo)'. Se representan posiciones a 90°, 300° y –300° y la imposibilidad de girar en el sentido contrario, enfatizando que en G90 el eje siempre toma el sentido predeterminado."@es .

ex:EsquemaCircular_1388_3 a ex:Esquema ;
    rdfs:label "esquema circular"@es ;
    ex:textoExtracto "Esquema circular con arcos y flechas que ilustra 'Posicionamiento por el camino más corto (SHORTESTWAY = Sí)'. Se visualiza cómo, en G90, el eje elige el arco mínimo hasta la posición objetivo (ejemplo a 90° y 30°), con anotaciones B90/B–300/B300."@es .

ex:ModoOperacion_SHORTESTWAY a ex:ModoOperacion ;
    rdfs:label "SHORTESTWAY"@es ;
    ex:textoExtracto "Esquema circular con arcos y flechas que ilustra 'Posicionamiento por el camino más corto (SHORTESTWAY = Sí)'. Se visualiza cómo, en G90, el eje elige el arco mínimo hasta la posición objetivo (ejemplo a 90° y 30°), con anotaciones B90/B–300/B300."@es .

ex:EjeC_1388 a ex:Sistema ;
    rdfs:label "eje C"@es ;
    ex:textoExtracto "Render 3D del torno mostrando el eje C activado y el plano de trabajo XC (ejes X–C con Z visible al fondo)."@es .

ex:PlanoTrabajo_XC_1388 a ex:InterfazUsuario ;
    rdfs:label "plano de trabajo XC"@es ;
    ex:textoExtracto "Render 3D del torno mostrando el eje C activado y el plano de trabajo XC (ejes X–C con Z visible al fondo)."@es .