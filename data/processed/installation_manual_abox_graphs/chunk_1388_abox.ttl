@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Esquema_ComportamientoModulo
    a ex:Esquema ;
    rdfs:label "Esquema de comportamiento 'Módulo' para ejes rotativos"@es ;
    ex:textoExtracto "Tres esquemas circulares comparan el comportamiento 'Módulo': posiciones programadas a 90° y 330° y desplazamientos relativos (B300/B–300) con flechas de sentido y arcos trazados. Ilustran cómo, en G90/G91, el recorrido efectivo es inferior a una vuelta, y cómo el signo fija el sentido cuando no hay SHORTESTWAY ni UNIDIR."@es ;
    ex:ilustradoEn ex:Pagina_158 .

ex:Esquema_SentidoGiroUnico
    a ex:Esquema ;
    rdfs:label "Esquema de sentido de giro único (UNIDIR = Positivo)"@es ;
    ex:textoExtracto "Esquema circular con arcos que muestran el 'Sentido de giro único (UNIDIR = Positivo)'. Se representan posiciones a 90°, 300° y –300° y la imposibilidad de girar en el sentido contrario, enfatizando que en G90 el eje siempre toma el sentido predeterminado."@es ;
    ex:ilustradoEn ex:Pagina_158 ;
    ex:documentadoEn ex:Seccion_2.5.8_ConfiguracionEjesRotativos .

ex:Esquema_CaminoMasCorto
    a ex:Esquema ;
    rdfs:label "Esquema de posicionamiento por camino más corto (SHORTESTWAY = Sí)"@es ;
    ex:textoExtracto "Esquema circular con arcos y flechas que ilustra 'Posicionamiento por el camino más corto (SHORTESTWAY = Sí)'. Se visualiza cómo, en G90, el eje elige el arco mínimo hasta la posición objetivo (ejemplo a 90° y 30°), con anotaciones B90/B–300/B300."@es ;
    ex:ilustradoEn ex:Pagina_160 ;
    ex:documentadoEn ex:Seccion_2.5.11_ConfiguracionEjeC .

ex:Esquema_PlanoTrabajoXC
    a ex:Esquema ;
    rdfs:label "Render 3D del plano de trabajo XC con eje C activado"@es ;
    ex:textoExtracto "Render 3D del torno mostrando el eje C activado y el plano de trabajo XC (ejes X–C con Z visible al fondo). El gráfico contextualiza el mecanizado con eje C, destacando la orientación de la herramienta respecto al plato y el sistema de coordenadas."@es ;
    ex:ilustradoEn ex:Pagina_160 .

ex:Pagina_158
    a ex:Pagina ;
    rdfs:label "Página 158"@es ;
    ex:identificador "158" ;
    ex:textoExtracto "Páginas: 158 | Sección: 2.5.8 Configuración de los ejes rotativos"@es .

ex:Pagina_160
    a ex:Pagina ;
    rdfs:label "Página 160"@es ;
    ex:identificador "160" ;
    ex:textoExtracto "Páginas: 160 | Sección: 2.5.11 Configuración del eje C"@es .

ex:Seccion_2.5.8_ConfiguracionEjesRotativos
    a ex:Capitulo ;
    rdfs:label "Sección 2.5.8: Configuración de los ejes rotativos"@es ;
    ex:identificador "2.5.8" ;
    ex:textoExtracto "Sección: 2.5.8 Configuración de los ejes rotativos — UNIDIR / SHORTESTWAY"@es .

ex:Seccion_2.5.11_ConfiguracionEjeC
    a ex:Capitulo ;
    rdfs:label "Sección 2.5.11: Configuración del eje C"@es ;
    ex:identificador "2.5.11" ;
    ex:textoExtracto "Sección: 2.5.11 Configuración del eje C | Título: Plano de trabajo XC"@es .