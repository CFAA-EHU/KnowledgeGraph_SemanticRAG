@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:EjeC a ex:ComponenteMecanico ;
    ex:textoExtracto "eje C activado" .

ex:PlanoTrabajoXC a ex:Sistema ;
    ex:textoExtracto "plano de trabajo XC (ejes X–C con Z visible al fondo)" .

ex:PlanoTrabajoZC a ex:Sistema ;
    ex:textoExtracto "plano de trabajo ZC (ejes Z–C)" .

ex:HerramientaFrontal a ex:Herramienta ;
    ex:textoExtracto "herramienta frontal" .

ex:SistemaCoordenadas a ex:Sistema ;
    ex:textoExtracto "sistema de coordenadas" .

ex:SenalSERVOON a ex:Sensor ;
    ex:textoExtracto "señales SERVOON" .

ex:SenalENABLE a ex:Sensor ;
    ex:textoExtracto "señales ENABLE" .

ex:VelocityCommand a ex:Parametro ;
    ex:textoExtracto "Velocity Command" .

ex:FiltroPasoBajo a ex:ComponenteElectrico ;
    ex:textoExtracto "filtro paso bajo" .

ex:FrecuenciaCorte a ex:Frecuencia ;
    ex:textoExtracto "frecuencia de corte FREQUENCY" ;
    ex:valor "-3 dB (0,707·Ao)" .

ex:FiltroAntirresonante a ex:ComponenteElectrico ;
    ex:textoExtracto "Filtro antirresonante (banda eliminada)" .

ex:FrecuenciaCentral a ex:Frecuencia ;
    ex:textoExtracto "frecuencia central FREQUENCY" .