@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaHidraulicoCaptacion a ns1:Sistema ;
    rdfs:label "Sistema de Captación" ;
    ns1:textoExtracto "La entrada de captación se configura desde los parámetros máquina. Cada eje dispone de los siguientes parámetros máquina para su configuración." ;
    ns1:tieneComponente ns1:NumeroDeLaEntradaDeCaptacionDelEje_f6ca2329df,
        ns1:TipoDeEntradaDeCaptacionDelEje_218ba37db9 ;
    ns1:valor "1 - 32",
        "Módulo RCS-S (contadora Sercos)" .

ns1:NumeroDeLaEntradaDeCaptacionDelEje_f6ca2329df a ns1:Parametro ;
    rdfs:label "Número de la entrada de captación del eje" ;
    ns1:identificador "COUNTERID" ;
    ns1:textoExtracto "COUNTERID | Número de la entrada de captación del eje." .

ns1:TipoDeEntradaDeCaptacionDelEje_218ba37db9 a ns1:Parametro ;
    rdfs:label "Tipo de entrada de captación del eje" ;
    ns1:identificador "COUNTERTYPE" ;
    ns1:textoExtracto "COUNTERTYPE | Tipo de entrada de captación del eje." .

