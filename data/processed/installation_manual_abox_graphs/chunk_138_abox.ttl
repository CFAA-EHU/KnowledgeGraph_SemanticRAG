@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_57f3e15a6c a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "La configuración debe cumplir los siguientes requisitos. Si la parametrización no se ajusta a estos requisitos, el CNC la ignora y numera las entradas digitales secuencialmente, según el orden en que se encuentren los módulos en el bus." ;
    ns1:tieneComponente ns1:NumeroDeBloqueLogico,
        ns1:NumeroDeNodoDeLaCabeceraAlQuePerteneceElBloqueLogicoDeIOs .

ns1:NumeroDeBloqueLogico a ns1:Parametro ;
    rdfs:label "Número de bloque lógico" ;
    ns1:identificador "MPG.DIMODBLOCK" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.DIMODBLOCK[nb] Número de bloque lógico." .

ns1:NumeroDeNodoDeLaCabeceraAlQuePerteneceElBloqueLogicoDeIOs a ns1:Parametro ;
    rdfs:label "Número de nodo de la cabecera al que pertenece el bloque lógico de I/Os" ;
    ns1:identificador "MPG.DIMODNODE" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.DIMODNODE[nb] Número de nodo de la cabecera al que pertenece el bloque lógico de I/Os." .

