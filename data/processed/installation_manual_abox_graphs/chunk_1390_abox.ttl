@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_FrecuenciaCentral
    a ex:Parametro ;
    rdfs:label "Frecuencia central (FREQUENCY)"@es ;
    ex:textoExtracto "Se destacan la frecuencia central (FREQUENCY) y el ancho de banda efectivo del notch para eliminar vibraciones específicas."@es ;
    ex:identificador "FREQUENCY" .

ex:Parametro_AnchoBandaNotch
    a ex:Parametro ;
    rdfs:label "Ancho de banda efectivo del notch"@es ;
    ex:textoExtracto "Se destacan la frecuencia central (FREQUENCY) y el ancho de banda efectivo del notch para eliminar vibraciones específicas."@es .

ex:Parametro_AmplitudBase_Ao
    a ex:Parametro ;
    rdfs:label "Amplitud base (Ao)"@es ;
    ex:textoExtracto "Gráfico de respuesta de máquina que muestra amplitud base (Ao), sobrepasamiento en resonancia (Ar) y frecuencia de resonancia (fr)"@es ;
    ex:identificador "Ao" .

ex:Parametro_SobrepasamientoResonancia_Ar
    a ex:Parametro ;
    rdfs:label "Sobrepasamiento en resonancia (Ar)"@es ;
    ex:textoExtracto "Gráfico de respuesta de máquina que muestra amplitud base (Ao), sobrepasamiento en resonancia (Ar) y frecuencia de resonancia (fr)"@es ;
    ex:identificador "Ar" .

ex:Parametro_FrecuenciaResonancia_fr
    a ex:Parametro ;
    rdfs:label "Frecuencia de resonancia (fr)"@es ;
    ex:textoExtracto "Gráfico de respuesta de máquina que muestra amplitud base (Ao), sobrepasamiento en resonancia (Ar) y frecuencia de resonancia (fr)"@es ;
    ex:identificador "fr" .

ex:Parametro_SHARE
    a ex:Parametro ;
    rdfs:label "SHARE"@es ;
    ex:textoExtracto "acompañado de la fórmula SHARE=100(Ar–Ao)/Ar. Visualiza cómo ajustar el porcentaje de señal que atraviesa el filtro para contrarrestar la resonancia observada."@es ;
    ex:identificador "SHARE" .

ex:Parametro_REVEHYST
    a ex:Parametro ;
    rdfs:label "Histéresis de inversión (REVEHYST)"@es ;
    ex:textoExtracto "diagrama temporal 'Posición' frente a 't' que ilustra la histéresis REVEHYST en inversiones de movimiento. [...] La curva de posición incluye pequeñas oscilaciones; sobre ella se superponen tramos sombreados etiquetados REVEHYST a ambos lados del cero, indicando la banda de histéresis que debe superarse para aplicar/cancelar el impulso adicional de consigna."@es ;
    ex:identificador "REVEHYST" .

ex:Parametro_PROGAIN
    a ex:Parametro ;
    rdfs:label "Ganancia proporcional (PROGAIN)"@es ;
    ex:textoExtracto "útil para visualizar el ajuste de la ganancia proporcional (PROGAIN)."@es ;
    ex:identificador "PROGAIN" .

ex:Figura_RespuestaMaquinaResonancia
    a ex:Figura ;
    rdfs:label "Gráfico de respuesta de máquina (resonancia y SHARE)"@es ;
    ex:textoExtracto "Gráfico de respuesta de máquina que muestra amplitud base (Ao), sobrepasamiento en resonancia (Ar) y frecuencia de resonancia (fr), acompañado de la fórmula SHARE=100(Ar–Ao)/Ar."@es ;
    ex:ilustradoEn ex:Parametro_Ao ;
    ex:ilustradoEn ex:Parametro_Ar ;
    ex:ilustradoEn ex:Parametro_fr ;
    ex:ilustradoEn ex:Parametro_SHARE .

ex:Figura_HisteresisREVEHYST
    a ex:Figura ;
    rdfs:label "Diagrama temporal de histéresis REVEHYST"@es ;
    ex:textoExtracto "diagrama temporal 'Posición' frente a 't' que ilustra la histéresis REVEHYST en inversiones de movimiento. [...] La curva de posición incluye pequeñas oscilaciones; sobre ella se superponen tramos sombreados etiquetados REVEHYST a ambos lados del cero, indicando la banda de histéresis que debe superarse para aplicar/cancelar el impulso adicional de consigna."@es ;
    ex:ilustradoEn ex:Parametro_REVEHYST .

ex:Figura_FollowingError_PROGAIN
    a ex:Figura ;
    rdfs:label "Gráfico de 'Actual Feed' y 'Following Error' para ajuste de PROGAIN"@es ;
    ex:textoExtracto "gráfico con fondo cuadriculado que muestra 'Actual Feed' (avance real) y 'Following Error (E)' (error de seguimiento) durante una maniobra de aceleración y parada. [...] útil para visualizar el ajuste de la ganancia proporcional (PROGAIN)."@es ;
    ex:ilustradoEn ex:Parametro_PROGAIN .