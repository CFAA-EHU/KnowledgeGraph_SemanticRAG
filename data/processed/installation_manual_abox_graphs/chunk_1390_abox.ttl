@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeLaEntradaDeCaptacionQueSeUtiliza a ns1:Parametro ;
    rdfs:label "Número de la entrada de captación que se utiliza" ;
    ns1:identificador "COUNTERID" ;
    ns1:textoExtracto "El parámetro COUNTERID indica el número de la entrada de captación que se utiliza." .

ns1:OrdenLogicoDeLasContadorasSercos a ns1:Parametro ;
    rdfs:label "Orden lógico de las contadoras Sercos" ;
    ns1:identificador "SERCOUNTID" ;
    ns1:textoExtracto "Las contadoras Sercos se numeran según su orden lógico (parámetro SERCOUNTID)." .

