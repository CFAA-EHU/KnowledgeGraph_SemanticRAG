@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_9691f01b5e a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de seguridad para ejes compartiendo señal"@es ;
    ns1:textoExtracto "Esta opción es útil, por ejemplo, en multiejes donde se desea evitar que el eje no activo reporte alarmas que sean consecuencia del movimiento del eje activo (ejes/cabezales compartiendo señal de entrada, pero con diferentes resoluciones)." .

ns1:MascaraDeAlarmasDeLaEntradaCorrespondiente a ns1:Parametro ;
    rdfs:label "Máscara de alarmas de la entrada correspondiente"@es ;
    ns1:identificador "33348" ;
    ns1:textoExtracto "IDN Sercos 33348 para la entrada de captación 1." .

ns1:NumeroDeNodoDelModuloRCSS a ns1:Parametro ;
    rdfs:label "Número de nodo del módulo RCS-S"@es ;
    ns1:identificador "SERCOUNTID" ;
    ns1:textoExtracto "Número de nodo del módulo RCS-S (parámetro SERCOUNTID)." .

ns1:SistemaRCS_S a ns1:Sistema ;
    rdfs:label "Módulo RCS-S (contadora Sercos)"@es ;
    ns1:documentadoEn ns1:TablaDRIVEVAR ;
    ns1:textoExtracto "Las alarmas de las entradas de captación del módulo RCS-S (contadora Sercos) se pueden desactivar utilizando variables del regulador" .

ns1:TablaDRIVEVAR a ns1:Parametro ;
    rdfs:label "Tabla DRIVEVAR"@es ;
    ns1:identificador "DRIVEVAR" ;
    ns1:textoExtracto "Definir la variable en la tabla DRIVEVAR. En los parámetros máquina OEM, acceder a la tabla DRIVEVAR." .

