@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:InterfazUsuario_1395_1 a ex:InterfazUsuario ;
    ex:textoExtracto "Incluye leyenda de valores aceptados y muestra la distribución física para hasta 16 teclas de usuario." ;
    ex:tieneComponente ex:TeclaUsuario_1395_1 .

ex:TeclaUsuario_1395_1 a ex:Componente ;
    ex:textoExtracto "hasta 16 teclas de usuario" .

ex:InterfazUsuario_1395_2 a ex:InterfazUsuario ;
    ex:textoExtracto "Diagrama de teclado con nueve casillas activas que alterna teclas de sentido (+/−) y de eje (X, Y, 4, 5) más tecla R. Ilustra una asignación en la que el usuario primero selecciona el sentido y luego el eje, con la tecla R centrada para activar el avance rápido." ;
    ex:tieneComponente ex:TeclaSentido_1395_2, ex:TeclaEje_1395_2, ex:TeclaR_1395_2 .

ex:TeclaSentido_1395_2 a ex:Componente ;
    ex:textoExtracto "teclas de sentido (+/−)" .

ex:TeclaEje_1395_2 a ex:Componente ;
    ex:textoExtracto "teclas de eje (X, Y, 4, 5)" .

ex:TeclaR_1395_2 a ex:Componente ;
    ex:textoExtracto "tecla R centrada para activar el avance rápido" .

ex:InterfazUsuario_1395_3 a ex:InterfazUsuario ;
    ex:textoExtracto "Teclado con nueve teclas: X+, Y+, 4+, 5+, R, 5−, X−, Y−, 4−. El diagrama organiza las flechas por cuadrantes para expresar direccionalidad y agrupar por eje, ejemplificando una configuración directa 'eje con signo' para jog." ;
    ex:tieneComponente ex:TeclaXmas_1395_3, ex:TeclaYmas_1395_3, ex:Tecla4mas_1395_3, ex:Tecla5mas_1395_3, ex:TeclaR_1395_3, ex:Tecla5menos_1395_3, ex:TeclaXmenos_1395_3, ex:TeclaYmenos_1395_3, ex:Tecla4menos_1395_3 .

ex:TeclaXmas_1395_3 a ex:Componente ;
    ex:textoExtracto "X+" .

ex:TeclaYmas_1395_3 a ex:Componente ;
    ex:textoExtracto "Y+" .

ex:Tecla4mas_1395_3 a ex:Componente ;
    ex:textoExtracto "4+" .

ex:Tecla5mas_1395_3 a ex:Componente ;
    ex:textoExtracto "5+" .

ex:TeclaR_1395_3 a ex:Componente ;
    ex:textoExtracto "R" .

ex:Tecla5menos_1395_3 a ex:Componente ;
    ex:textoExtracto "5−" .

ex:TeclaXmenos_1395_3 a ex:Componente ;
    ex:textoExtracto "X−" .

ex:TeclaYmenos_1395_3 a ex:Componente ;
    ex:textoExtracto "Y−" .

ex:Tecla4menos_1395_3 a ex:Componente ;
    ex:textoExtracto "4−" .