@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaBrochadoraSercos a ns1:Sistema ;
    rdfs:label "Sistema con nodos Sercos" ;
    ns1:textoExtracto "El sistema dispone de 2 contadoras Sercos (nodos 3, 5) y de 3 reguladores Sercos AXD (nodos 1, 2, 4)." ;
    ns1:tieneComponente ns1:Nodo1,
        ns1:Nodo2,
        ns1:Nodo3,
        ns1:Nodo4,
        ns1:Nodo5 .

ns1:Nodo1 a ns1:Componente ;
    rdfs:label "Nodo 1" ;
    ns1:textoExtracto "NODO 1: Eje V Sercos." .

ns1:Nodo2 a ns1:Componente ;
    rdfs:label "Nodo 2" ;
    ns1:textoExtracto "NODO 2: Eje U Sercos. E21A / ANAOUT2" .

ns1:Nodo3 a ns1:Componente ;
    rdfs:label "Nodo 3" ;
    ns1:textoExtracto "NODO 3: Eje X analógico. E21B Volante 1. ANAOUT1 Eje Y analógico." .

ns1:Nodo4 a ns1:Componente ;
    rdfs:label "Nodo 4" ;
    ns1:textoExtracto "NODO 4: Cabezal S Sercos E21B" .

ns1:Nodo5 a ns1:Componente ;
    rdfs:label "Nodo 5" ;
    ns1:textoExtracto "NODO 5: Eje U (segunda captación) E21C Eje Y analógico. E21A / ANAOUT4 Eje Z analógico." .

