@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjeYAnalogico a ns1:Parametro ;
    rdfs:label "Eje Y analógico" ;
    ns1:identificador "ANAOUT1" ;
    ns1:textoExtracto "ANAOUT1 Eje Y analógico." .

ns1:EjeZAnalogico a ns1:Parametro ;
    rdfs:label "Eje Z analógico" ;
    ns1:identificador "ANAOUT4" ;
    ns1:textoExtracto "ANAOUT4 Eje Z analógico." .

ns1:IdentificadorDelPrimerNodoContable a ns1:Parametro ;
    rdfs:label "Identificador del primer nodo contable" ;
    ns1:identificador "SERCOUNTID1" ;
    ns1:textoExtracto "SERCOUNTID1 5 (No habitual, pero válido)" .

ns1:IdentificadorDelSegundoNodoContable a ns1:Parametro ;
    rdfs:label "Identificador del segundo nodo contable" ;
    ns1:identificador "SERCOUNTID2" ;
    ns1:textoExtracto "SERCOUNTID2 3" .

ns1:NumeroDeContadorasSercosEnElSistema a ns1:Parametro ;
    rdfs:label "Número de contadoras Sercos en el sistema" ;
    ns1:identificador "NSERCOUNT" ;
    ns1:textoExtracto "NSERCOUNT 2 Número de contadoras Sercos en el sistema" .

