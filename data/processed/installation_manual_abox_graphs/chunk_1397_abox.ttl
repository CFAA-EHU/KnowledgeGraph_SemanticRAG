ns1:FuenteDeRetroalimentacionParaElEjeU a ns1:Parametro ;
    rdfs:label "Fuente de retroalimentación para el eje U" ;
    ns1:identificador "FBACKSRC" ;
    ns1:textoExtracto "Eje U. FBACKSRC Externa." .

