@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:EsquemaPosicionReferenciaHEADTOOL a ex:Esquema ;
    ex:textoExtracto "Doble esquema de 'posición de referencia HEAD/TOOL' que compara 'Tool base/Auto tool base' frente a 'Head base'. Se marca la nariz del portaherramientas y vectores de referencia para visualizar dónde se sitúa el punto de referencia tras calibración o activación." ;
    ex:tieneComponente ex:NarizPortaherramientas, ex:VectoresReferencia .

ex:NarizPortaherramientas a ex:Componente ;
    ex:textoExtracto "Se marca la nariz del portaherramientas" .

ex:VectoresReferencia a ex:Componente ;
    ex:textoExtracto "vectores de referencia para visualizar dónde se sitúa el punto de referencia tras calibración o activación" .

ex:EsquemaCinematicasCabezales a ex:Esquema ;
    ex:textoExtracto "Tríptico A-B-C con siluetas de 'cabezal esférico', 'cabezal ortogonal' y 'cabezal angular', seguido de dos esquemas comparativos que muestran la condición geométrica correcta/incorrecta del eje rotativo principal respecto a los ejes X/Y/Z. Incluye letras A/B/C y ángulo α para orientar distancias TDATA." ;
    ex:tieneComponente ex:CabezalEsferico, ex:CabezalOrtogonal, ex:CabezalAngular, ex:EjeRotativoPrincipal .

ex:CabezalEsferico a ex:ComponenteMecanico ;
    ex:textoExtracto "cabezal esférico" .

ex:CabezalOrtogonal a ex:ComponenteMecanico ;
    ex:textoExtracto "cabezal ortogonal" .

ex:CabezalAngular a ex:ComponenteMecanico ;
    ex:textoExtracto "cabezal angular" .

ex:EjeRotativoPrincipal a ex:ComponenteMecanico ;
    ex:textoExtracto "eje rotativo principal" .

ex:EsquemaCotasTDATA1a5 a ex:Esquema ;
    ex:textoExtracto "Planchas con cinco viñetas (TYPE=1…5) que dibujan la cabeza y ejes con cotas TDATA1…TDATA7. Flechas y signos (+/−) identifican distancias desde la nariz del husillo al eje secundario, separaciones X/Y/Z entre centros de giro y el ángulo entre ejes rotativos." ;
    ex:tieneComponente ex:NarizHusillo, ex:EjeSecundario, ex:CentrosGiroX, ex:CentrosGiroY, ex:CentrosGiroZ, ex:AnguloEjesRotativos .

ex:NarizHusillo a ex:Componente ;
    ex:textoExtracto "nariz del husillo" .

ex:EjeSecundario a ex:ComponenteMecanico ;
    ex:textoExtracto "eje secundario" .

ex:CentrosGiroX a ex:ComponenteMecanico ;
    ex:textoExtracto "separaciones X entre centros de giro" .

ex:CentrosGiroY a ex:ComponenteMecanico ;
    ex:textoExtracto "separaciones Y entre centros de giro" .

ex:CentrosGiroZ a ex:ComponenteMecanico ;
    ex:textoExtracto "separaciones Z entre centros de giro" .

ex:AnguloEjesRotativos a ex:Parametro ;
    ex:textoExtracto "el ángulo entre ejes rotativos" .

ex:EsquemaCotasTDATA6a8 a ex:Esquema ;
    ex:textoExtracto "Tres viñetas (TYPE=6…8) con la misma gramática gráfica de cotas y signos para cabezales angulares YZ/ZX/ZY." ;
    ex:tieneComponente ex:CabezalAngularYZ, ex:CabezalAngularZX, ex:CabezalAngularZY .

ex:CabezalAngularYZ a ex:ComponenteMecanico ;
    ex:textoExtracto "cabezal angular YZ" .

ex:CabezalAngularZX a ex:ComponenteMecanico ;
    ex:textoExtracto "cabezal angular ZX" .

ex:CabezalAngularZY a ex:ComponenteMecanico ;
    ex:textoExtracto "cabezal angular ZY" .