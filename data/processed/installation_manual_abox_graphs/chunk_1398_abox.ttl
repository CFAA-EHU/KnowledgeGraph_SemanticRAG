@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_d329f2fd74 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Por defecto, el CNC numera las entradas digitales secuencialmente, según el orden en que se encuentren los módulos en el bus." ;
    ns1:tieneComponente ns1:BloqueLogico .

ns1:NodoRIO5 a ns1:Sistema ;
    rdfs:label "Nodo RIO5" ;
    ns1:textoExtracto "En los nodos RIO5 y RIOR, cada módulo es un bloque lógico" ;
    ns1:tieneComponente ns1:BloqueLogico,
        ns1:BloqueLogicoRIO5Doble .

ns1:NodoRIOR a ns1:Sistema ;
    rdfs:label "Nodo RIOR" ;
    ns1:textoExtracto "En los nodos RIO5 y RIOR, cada módulo es un bloque lógico" ;
    ns1:tieneComponente ns1:BloqueLogico .

ns1:NodoRIOW a ns1:Sistema ;
    rdfs:label "Nodo RIOW" ;
    ns1:textoExtracto "En los nodos RIOW y de terceros, se permite virtualizar los bloques lógicos que se desee" ;
    ns1:tieneComponente ns1:BloqueLogico .

ns1:Parametro_a894535e78 a ns1:Parametro ;
    rdfs:label "Parámetro de Configuración de Entradas y Salidas Digitales" ;
    ns1:textoExtracto "La entradas y salidas digitales se configuran desde los parámetros máquina." .

ns1:BloqueLogicoRIO5Doble a ns1:Sistema ;
    rdfs:label "Bloque Lógico RIO5 Doble" ;
    ns1:textoExtracto "En los nodos RIO5, cada módulo doble (módulo con dos placas) cuenta como dos; es decir, dos bloques lógicos." .

ns1:BloqueLogico a ns1:Sistema ;
    rdfs:label "Bloque Lógico" ;
    ns1:textoExtracto "el CNC permite dividir los nodos de I/Os digitales en bloques lógicos (módulos virtuales)" .

