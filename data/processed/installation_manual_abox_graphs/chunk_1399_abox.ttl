@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TDATA7 a ex:Parametro ;
    rdfs:label "TDATA7" ;
    ex:textoExtracto "Un diagrama adicional contrasta el origen de RTCP respecto a cero máquina/pieza (TDATA7) mediante ejes X′-Y′." .

ex:TDATA16 a ex:Parametro ;
    rdfs:label "TDATA16" ;
    ex:textoExtracto "Gráfico comparativo '#RTCP ON B-30' con dos escenas: TDATA16=0 (el sistema de coordenadas pieza gira con la pieza) frente a TDATA16=1 (el sistema pieza se mantiene paralelo al sistema máquina). Se visualizan ejes X′-Z′ y vector de inclinación B." .

ex:RTCP_ON_B_30 a ex:Esquema ;
    ex:textoExtracto "Gráfico comparativo '#RTCP ON B-30' con dos escenas: TDATA16=0 (el sistema de coordenadas pieza gira con la pieza) frente a TDATA16=1 (el sistema pieza se mantiene paralelo al sistema máquina). Se visualizan ejes X′-Z′ y vector de inclinación B." .

ex:Eje_X_Prima_Z_Prima a ex:Parametro ;
    rdfs:label "X′-Z′" ;
    ex:textoExtracto "Se visualizan ejes X′-Z′ y vector de inclinación B." .

ex:Vector_Inclinacion_B a ex:Parametro ;
    rdfs:label "B" ;
    ex:textoExtracto "Se visualizan ejes X′-Z′ y vector de inclinación B." .

ex:TDATA1 a ex:Parametro ;
    rdfs:label "TDATA1" ;
    ex:textoExtracto "Dos conjuntos de viñetas para las combinaciones A-B y A-C: cotas TDATA1…TDATA6 para separar nariz, ejes de rotación y referencia máquina, más TDATA13…TDATA15 para colocación del cabezal." .

