@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IndiceBaseParaNumeracionDeEntradasDigitalesDelBloqueLogico a ns1:Parametro ;
    rdfs:label "Índice base para numeración de entradas digitales del bloque lógico" ;
    ns1:identificador "MPG.DIMODADDR" ;
    ns1:textoExtracto "Este parámetro establece el índice base a partir del cual se numeran las entradas digitales del bloque lógico." .

ns1:SistemaCANopen a ns1:Sistema ;
    rdfs:label "Sistema CANopen" ;
    ns1:textoExtracto "El máximo número de bloques lógicos en el sistema será 64, tanto para entradas como para salidas digitales." .

