@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Esquema_Cinematica_TYPE15_16
    a ex:Esquema ;
    rdfs:label "Esquema de parámetros cinemáticos para TYPE=15 y TYPE=16"@es ;
    ex:textoExtracto "Viñetas para combinaciones B-A y C-B que detallan, con flechas y cotas, la posición del eje rotativo del cabezal (TDATA1–TDATA3), la ubicación del eje de mesa (TDATA4–TDATA6) y la colocación del cabezal (TDATA13–TDATA15), junto a los casos de TDATA11."@es ;
    ex:ilustradoEn ex:Pagina_270 ;
    ex:detalladoEnEsquema ex:Parametro_TDATA1, ex:Parametro_TDATA2, ex:Parametro_TDATA3, ex:Parametro_TDATA4, ex:Parametro_TDATA5, ex:Parametro_TDATA6, ex:Parametro_TDATA11, ex:Parametro_TDATA13, ex:Parametro_TDATA14, ex:Parametro_TDATA15 .

ex:Esquema_Cinematica_TYPE17
    a ex:Esquema ;
    rdfs:label "Esquema de cinemática TYPE=17 para cabezal/mesa con ejes lineales X-Y-Z y rotativos A/B/C"@es ;
    ex:textoExtracto "Esquema de cinemática TYPE=17 para cabezal/mesa con ejes lineales X-Y-Z y rotativos A/B/C. Se muestran los tres órdenes de rotación (1º, 2º, 3º) y las distancias/offsets etiquetadas como TDATA (1, 2, 3, 4, 6, 7, 8, 9, 10, 11, 12)."@es ;
    ex:ilustradoEn ex:Pagina_271 ;
    ex:detalladoEnEsquema ex:Parametro_TDATA1, ex:Parametro_TDATA2, ex:Parametro_TDATA3, ex:Parametro_TDATA4, ex:Parametro_TDATA6, ex:Parametro_TDATA7, ex:Parametro_TDATA8, ex:Parametro_TDATA9, ex:Parametro_TDATA10, ex:Parametro_TDATA11, ex:Parametro_TDATA12 .

ex:Esquema_CabezalOrtogonal_TresEjes
    a ex:Esquema ;
    rdfs:label "Ilustración del cabezal ortogonal con tres ejes de giro (principal, secundario, terciario)"@es ;
    ex:textoExtracto "Ilustración del cabezal ortogonal con tres ejes de giro (principal, secundario, terciario). Acompañada de la enumeración TDATA1…TDATA12, el gráfico identifica la nariz del mandrino, los centros de giro 1º–3º y las distancias entre centros y eje de herramienta, con indicación del signo positivo en cada eje."@es ;
    ex:ilustradoEn ex:Pagina_271 ;
    ex:detalladoEnEsquema ex:Parametro_TDATA1, ex:Parametro_TDATA2, ex:Parametro_TDATA3, ex:Parametro_TDATA4, ex:Parametro_TDATA5, ex:Parametro_TDATA6, ex:Parametro_TDATA7, ex:Parametro_TDATA8, ex:Parametro_TDATA9, ex:Parametro_TDATA10, ex:Parametro_TDATA11, ex:Parametro_TDATA12 .

