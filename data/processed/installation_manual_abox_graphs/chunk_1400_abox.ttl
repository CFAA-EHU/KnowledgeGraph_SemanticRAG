@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ParametrosMaquinaParaConfiguracionDeEntradasYSalidasDigitales a ns1:Parametro ;
    rdfs:label "Parámetros máquina para configuración de entradas y salidas digitales" ;
    ns1:textoExtracto "La entradas y salidas digitales se configuran desde los parámetros máquina." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "El PLC admite huecos, pero nunca solapamiento entre los diferentes bloques; es decir, una entrada o salida digital de PLC sólo puede pertenecer a un único nodo-módulo del bus." .

