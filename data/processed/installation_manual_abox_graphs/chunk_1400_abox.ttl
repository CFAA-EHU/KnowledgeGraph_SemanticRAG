ex:TDATA13 a ex:Parametro ;
    rdfs:label "TDATA13" ;
    ex:textoExtracto "Viñetas para combinaciones B-A y C-B que detallan [...] la colocación del cabezal (TDATA13–TDATA15)" ;
    ex:valor "TDATA13" .

ex:TDATA14 a ex:Parametro ;
    rdfs:label "TDATA14" ;
    ex:textoExtracto "Viñetas para combinaciones B-A y C-B que detallan [...] la colocación del cabezal (TDATA13–TDATA15)" ;
