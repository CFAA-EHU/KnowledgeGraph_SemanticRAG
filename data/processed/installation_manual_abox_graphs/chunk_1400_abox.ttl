@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TDATA11 a ex:Parametro ;
    rdfs:label "TDATA11" ;
    ex:textoExtracto "Incluye croquis de inversión del sentido de giro (TDATA11=0/1)." ;
    ex:valor "0/1" .

ex:TDATA1 a ex:Parametro ;
    rdfs:label "TDATA1" ;
    ex:textoExtracto "Viñetas para combinaciones B-A y C-B que detallan [...] la posición del eje rotativo del cabezal (TDATA1–TDATA3)" ;
    ex:valor "TDATA1" .

ex:TDATA2 a ex:Parametro ;
    rdfs:label "TDATA2" ;
    ex:textoExtracto "Viñetas para combinaciones B-A y C-B que detallan [...] la posición del eje rotativo del cabezal (TDATA1–TDATA3)" ;
    ex:valor "TDATA2" .

ex:TDATA3 a ex:Parametro ;
    rdfs:label "TDATA3" ;
    ex:textoExtracto "Viñetas para combinaciones B-A y C-B que detallan [...] la posición del eje rotativo del cabezal (TDATA1–TDATA3)" ;
    ex:valor "TDATA3" .

ex:TDATA4 a ex:Parametro ;
    rdfs:label "TDATA4" ;
    ex:textoExtracto "Viñetas para combinaciones B-A y C-B que detallan [...] la ubicación del eje de mesa (TDATA4–TDATA6)" ;
    ex:valor "TDATA4" .

