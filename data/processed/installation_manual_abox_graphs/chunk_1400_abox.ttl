ex:TDATA6 a ex:Parametro ;
    rdfs:label "TDATA6" ;
    ex:textoExtracto "Viñetas para combinaciones B-A y C-B que detallan [...] la ubicación del eje de mesa (TDATA4–TDATA6)" ;
    ex:textoExtracto "Esquema de cinemática TYPE=17 [...] etiquetadas como TDATA (1, 2, 3, 4, 6, 7, 8, 9, 10, 11, 12)" ;
    ex:valor "TDATA6" .

ex:TDATA7 a ex:Parametro ;
