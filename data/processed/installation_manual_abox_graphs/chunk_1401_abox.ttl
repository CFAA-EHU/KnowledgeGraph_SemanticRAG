@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Esquema_TYPE18 a ex:Esquema ;
    rdfs:label "Esquema de cinemática TYPE=18" ;
    ex:textoExtracto "Esquema de cinemática TYPE=18 con ejes X-Y-Z y rotaciones A/C. Incluye anotaciones TDATA (1, 2, 3, 4, 6, 7, 8, 9, 12) y numeración del orden de los giros (1º-3º). Las flechas y signos (+/−) marcan la dirección positiva según norma; se destaca la relación del eje rotativo con los lineales." ;
    ex:compuestoPor ex:Eje_X, ex:Eje_Y, ex:Eje_Z, ex:Eje_A, ex:Eje_C ;
    ex:tieneComponente ex:TDATA_1, ex:TDATA_2, ex:TDATA_3, ex:TDATA_4, ex:TDATA_6, ex:TDATA_7, ex:TDATA_8, ex:TDATA_9, ex:TDATA_12 .

ex:Esquema_TYPE19 a ex:Esquema ;
    rdfs:label "Esquema de cinemática TYPE=19" ;
    ex:textoExtracto "Esquema de cinemática TYPE=19 con ejes lineales X-Y-Z y rotaciones A/C/B. Se detallan TDATA 1, 2, 7, 8, 11 y otros para offsets y sentidos; incluye orden de rotaciones y referencias de signo para los vectores de giro." ;
    ex:compuestoPor ex:Eje_X_2, ex:Eje_Y_2, ex:Eje_Z_2, ex:Eje_A_2, ex:Eje_C_2, ex:Eje_B ;
    ex:tieneComponente ex:TDATA_1_2, ex:TDATA_2_2, ex:TDATA_7, ex:TDATA_8_2, ex:TDATA_11 .

ex:Esquema_TYPE20 a ex:Esquema ;
    rdfs:label "Esquema de cinemática TYPE=20" ;
    ex:textoExtracto "Esquema de cinemática TYPE=20 con ejes X-Y-Z y rotación B, con despieces laterales que indican TDATA (1, 2, 3, 4, 5, 7, 9, 10, 11) y la secuencia 1º-3º. Las flechas muestran direccionalidad y el signo de cada componente." ;
    ex:compuestoPor ex:Eje_X_3, ex:Eje_Y_3, ex:Eje_Z_3, ex:Eje_B_2 ;
    ex:tieneComponente ex:TDATA_1_3, ex:TDATA_2_3, ex:TDATA_3_2, ex:TDATA_4_2, ex:TDATA_5, ex:TDATA_7_2, ex:TDATA_9_2, ex:TDATA_10, ex:TDATA_11_2 .

