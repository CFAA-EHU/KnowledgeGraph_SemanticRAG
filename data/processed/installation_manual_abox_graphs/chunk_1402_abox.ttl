@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:EsquemaCinematica_TYPE21
    a               ex:Esquema ;
    rdfs:label      "Esquema de cinemática TYPE=21" ;
    ex:textoExtracto "Esquema de cinemática TYPE=21 con ejes X-Y-Z y rotaciones C/A/B. Presenta el orden de ejes (1º-3º), componentes TDATA (1, 2, 3, 4, 5, 7, 8, 9, 12) y flechas de sentido; organiza jerárquicamente dirección y posición de cada giro." ;
    ex:identificador "TYPE=21" ;
    ex:monitoreaParametro ex:ParametroTDATA_1, ex:ParametroTDATA_2, ex:ParametroTDATA_3, ex:ParametroTDATA_4, ex:ParametroTDATA_5, ex:ParametroTDATA_7, ex:ParametroTDATA_8, ex:ParametroTDATA_9, ex:ParametroTDATA_12 .

ex:EsquemaCinematica_TYPE22
    a               ex:Esquema ;
    rdfs:label      "Esquema de cinemática TYPE=22" ;
    ex:textoExtracto "Esquema de cinemática TYPE=22 con ejes X-Y-Z y rotación C/B. Se especifican TDATA (2, 5, 7, 8, 11) y el orden 1º-3º; las anotaciones (+/−) establecen polaridad y sentido del giro respecto a los ejes lineales." ;
    ex:identificador "TYPE=22" ;
    ex:monitoreaParametro ex:ParametroTDATA_2, ex:ParametroTDATA_5, ex:ParametroTDATA_7, ex:ParametroTDATA_8, ex:ParametroTDATA_11 .

ex:EsquemaCinematica_TYPE23
    a               ex:Esquema ;
    rdfs:label      "Esquema de cinemática TYPE=23" ;
    ex:textoExtracto "Esquema de cinemática TYPE=23 (A/B/C con X-Y-Z). Diagramas con TDATA 1–13 y 21–23 que representan posiciones, offsets y sentidos de giro; incluye numeración de ejes 1º-3º y convenciones de signo." ;
    ex:identificador "TYPE=23" ;
    ex:monitoreaParametro ex:ParametroTDATA_1, ex:ParametroTDATA_2, ex:ParametroTDATA_3, ex:ParametroTDATA_4, ex:ParametroTDATA_5, ex:ParametroTDATA_6, ex:ParametroTDATA_7, ex:ParametroTDATA_8, ex:ParametroTDATA_9, ex:ParametroTDATA_10, ex:ParametroTDATA_11, ex:ParametroTDATA_12, ex:ParametroTDATA_13, ex:ParametroTDATA_21, ex:ParametroTDATA_22, ex:ParametroTDATA_23 .

ex:EsquemaCinematica_TYPE24
    a               ex:Esquema ;
    rdfs:label      "Esquema de cinemática TYPE=24" ;
    ex:textoExtracto "Esquema de cinemática TYPE=24 (A/B/C con X-Y-Z). Muestra vectores asociados a TDATA (2, 4, 5, 8) y la correspondencia entre traslaciones/giros con indicación de orden y sentido." ;
    ex:identificador "TYPE=24" ;
    ex:monitoreaParametro ex:ParametroTDATA_2, ex:ParametroTDATA_4, ex:ParametroTDATA_5, ex:ParametroTDATA_8 .

