@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "El PLC admite huecos, pero nunca solapamiento entre los diferentes bloques; es decir, una entrada o salida digital de PLC sólo puede pertenecer a un único nodo-módulo del bus." ;
    ns1:tieneComponente ns1:EntradaDigitalPLC,
        ns1:NodoModuloCANopen,
        ns1:SalidaDigitalPLC .

ns1:EntradaDigitalPLC a ns1:ComponenteElectrico ;
    rdfs:label "Entrada digital PLC" ;
    ns1:textoExtracto "una entrada o salida digital de PLC sólo puede pertenecer a un único nodo-módulo del bus." .

ns1:NodoModuloCANopen a ns1:Componente ;
    rdfs:label "Nodo módulo CANopen" ;
    ns1:textoExtracto "una entrada o salida digital de PLC sólo puede pertenecer a un único nodo-módulo del bus." .

ns1:SalidaDigitalPLC a ns1:ComponenteElectrico ;
    rdfs:label "Salida digital PLC" ;
    ns1:textoExtracto "una entrada o salida digital de PLC sólo puede pertenecer a un único nodo-módulo del bus." .

