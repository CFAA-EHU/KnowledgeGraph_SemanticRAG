@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TDATA2 a ex:Parametro ;
    rdfs:label "TDATA2" ;
    ex:identificador "TDATA2" ;
    ex:textoExtracto "offsets TDATA2 (posición)" .

ex:TDATA4 a ex:Parametro ;
    rdfs:label "TDATA4" ;
    ex:identificador "TDATA4" ;
    ex:textoExtracto "offsets TDATA4 (offset angular)" .

ex:TDATA6 a ex:Parametro ;
    rdfs:label "TDATA6" ;
    ex:identificador "TDATA6" ;
    ex:textoExtracto "offsets TDATA6 (desalineamiento)" .

ex:TDATA8 a ex:Parametro ;
    rdfs:label "TDATA8" ;
    ex:identificador "TDATA8" ;
    ex:textoExtracto "vectores asociados a TDATA (2, 4, 5, 8)" .

ex:TDATA10 a ex:Parametro ;
    rdfs:label "TDATA10" ;
    ex:identificador "TDATA10" ;
    ex:textoExtracto "sentido de giro del eje giratorio (TDATA10)" .

ex:EjeC a ex:ComponenteMecanico ;
    rdfs:label "eje C" ;
    ex:identificador "eje C" ;
    ex:textoExtracto "eje C" .

ex:EjeX a ex:ComponenteMecanico ;
    rdfs:label "eje X" ;
    ex:identificador "eje X" ;
    ex:textoExtracto "ejes X-Y-Z" .

ex:EjeY a ex:ComponenteMecanico ;
    rdfs:label "eje Y" ;
    ex:identificador "eje Y" ;
    ex:textoExtracto "ejes X-Y-Z" .

ex:EjeZ a ex:ComponenteMecanico ;
    rdfs:label "eje Z" ;
    ex:identificador "eje Z" ;
    ex:textoExtracto "ejes X-Y-Z" .

ex:ReglaManoDerecha a ex:Figura ;
    rdfs:label "regla de la mano derecha" ;
    ex:textoExtracto "Ilustración 'regla de la mano derecha' para ejes X-Y-Z y sentido de giro en ejes rotativos" .

ex:DiagramaEjeC a ex:Esquema ;
    rdfs:label "diagrama del eje C" ;
    ex:textoExtracto "Diagrama del eje C respecto a X-Y y referencias de reposo/desalineamiento" .

ex:EsquemaEjeCCilindrico a ex:Esquema ;
    rdfs:label "esquema del eje C cilíndrico" ;
    ex:identificador "#CYL" ;
    ex:textoExtracto "Esquema del eje C cilíndrico (#CYL) mostrando relación entre Z-X-Y y el cilindro de pieza" .