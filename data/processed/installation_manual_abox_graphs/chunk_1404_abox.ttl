@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TDATA2 a ex:Parametro ;
    rdfs:label "TDATA2 (posición del rotativo)" ;
    ex:textoExtracto "Se resaltan TDATA2 (posición del rotativo) y TDATA4 (offset angular), con signos (+) y flechas que definen el sentido de giro (TDATA10)." ;
    ex:identificador "TDATA2" .

ex:TDATA4 a ex:Parametro ;
    rdfs:label "TDATA4 (offset angular)" ;
    ex:textoExtracto "Se resaltan TDATA2 (posición del rotativo) y TDATA4 (offset angular), con signos (+) y flechas que definen el sentido de giro (TDATA10)." ;
    ex:identificador "TDATA4" .

ex:TDATA10 a ex:Parametro ;
    rdfs:label "TDATA10" ;
    ex:textoExtracto "Se resaltan TDATA2 (posición del rotativo) y TDATA4 (offset angular), con signos (+) y flechas que definen el sentido de giro (TDATA10)." ;
    ex:identificador "TDATA10" .

ex:TDATA8 a ex:Parametro ;
    rdfs:label "TDATA8" ;
    ex:textoExtracto "Ilustración de la regla de la mano derecha junto a los ejes para fijar el sentido de giro del eje rotativo principal/secundario; incluye bocetos de mano y ejes rotulados, como apoyo a TDATA8/18 y a la distinción manual/servo (TDATA9/19)." ;
    ex:identificador "TDATA8" .

ex:TDATA18 a ex:Parametro ;
    rdfs:label "TDATA18" ;
    ex:textoExtracto "Ilustración de la regla de la mano derecha junto a los ejes para fijar el sentido de giro del eje rotativo principal/secundario; incluye bocetos de mano y ejes rotulados, como apoyo a TDATA8/18 y a la distinción manual/servo (TDATA9/19)." ;
    ex:identificador "TDATA18" .

ex:TDATA9 a ex:Parametro ;
    rdfs:label "TDATA9" ;
    ex:textoExtracto "Ilustración de la regla de la mano derecha junto a los ejes para fijar el sentido de giro del eje rotativo principal/secundario; incluye bocetos de mano y ejes rotulados, como apoyo a TDATA8/18 y a la distinción manual/servo (TDATA9/19)." ;
    ex:identificador "TDATA9" .

ex:TDATA19 a ex:Parametro ;
    rdfs:label "TDATA19" ;
    ex:textoExtracto "Ilustración de la regla de la mano derecha junto a los ejes para fijar el sentido de giro del eje rotativo principal/secundario; incluye bocetos de mano y ejes rotulados, como apoyo a TDATA8/18 y a la distinción manual/servo (TDATA9/19)." ;
    ex:identificador "TDATA19" .

ex:EsquemaCinematicasCabezales a ex:Esquema ;
    rdfs:label "Esquema de cinemáticas de cabezal (tipo 50)" ;
    ex:textoExtracto "Conjunto de diagramas: pictogramas de cabezales (esférico, ortogonal, angular) y tres vistas con vectores T1/T2/T3 (traslación) y V1/V2/V3 (dirección). Ejes X-Y-Z, flechas, y etiquetas TDATA1–26 indican componentes, posiciones de reposo y sentidos." ;
    ex:compuestoPor ex:TDATA2, ex:TDATA4, ex:TDATA10, ex:TDATA8, ex:TDATA18, ex:TDATA9, ex:TDATA19 .

ex:EsquemaCinematicasMesa a ex:Esquema ;
    rdfs:label "Esquema de cinemáticas de mesa (tipo 51)" ;
    ex:textoExtracto "Conjunto de diagramas de mesa basados en vectores T1/T2 y V1/V2." ;
    ex:compuestoPor ex:TDATA2, ex:TDATA4, ex:TDATA10 .