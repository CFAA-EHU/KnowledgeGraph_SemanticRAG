@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA1_16
    a ex:Parametro ;
    rdfs:label "TDATA1–16 (posiciones, direcciones y reposo/sentido del eje principal)"@es ;
    ex:textoExtracto "etiquetas TDATA1–16 para posiciones, direcciones y reposo/sentido del eje principal"@es ;
    ex:monitoreaParametro ex:Sistema_CinematicaMesa_Tipo51 .

ex:Parametro_TDATA1_6
    a ex:Parametro ;
    rdfs:label "TDATA1–6 (componentes vectoriales T1/T2)"@es ;
    ex:textoExtracto "Vista detallada de los vectores T1/T2 [...] con componentes TDATA1–6"@es ;
    ex:monitoreaParametro ex:Sistema_CinematicaMesa_Tipo51 .

ex:Parametro_TDATA11_16
    a ex:Parametro ;
    rdfs:label "TDATA11–16 (componentes vectoriales V1/V2)"@es ;
    ex:textoExtracto "TDATA11–16 [...] proyecciones sobre cada eje"@es ;
    ex:monitoreaParametro ex:Sistema_CinematicaMesa_Tipo51 .

ex:Parametro_TDATA31
    a ex:Parametro ;
    rdfs:label "TDATA31 (sistema de coordenadas pieza: 0=paralelo a máquina, 1=gira con pieza)"@es ;
    ex:textoExtracto "TDATA31=0/1 [...] si el sistema gira con la pieza o permanece paralelo al de máquina"@es ;
    ex:monitoreaParametro ex:Sistema_CinematicaMesa_Tipo51 ;
    ex:valor "0"^^xsd:string, "1"^^xsd:string .

ex:Sistema_CinematicaMesa_Tipo51
    a ex:Sistema ;
    rdfs:label "Sistema de cinemática de mesa (tipo 51)"@es ;
    ex:textoExtracto "Definición vectorial de cinemáticas de mesa (tipo 51) [...] Conjunto de diagramas de mesa basados en vectores T1/T2 y V1/V2"@es ;
    ex:ilustradoEn ex:Esquema_VectoresT1T2_V1V2, ex:Esquema_RTCP_B30 ;
    ex:detalladoEnEsquema ex:Esquema_ManoEjesGiro, ex:Esquema_CoordenadasPiezaMaquina .

ex:Esquema_VectoresT1T2_V1V2
    a ex:Esquema ;
    rdfs:label "Esquema de vectores T1/T2 y V1/V2 con proyecciones (+/−) en ejes X-Y-Z"@es ;
    ex:textoExtracto "Vista detallada de los vectores T1/T2 y V1/V2 con componentes TDATA1–6 y TDATA11–16 [...] proyecciones sobre cada eje"@es .

ex:Esquema_ManoEjesGiro
    a ex:Esquema ;
    rdfs:label "Esquema de mano y ejes para sentido de giro (RTCP vs. cero máquina/pieza)"@es ;
    ex:textoExtracto "Ilustración de mano y ejes para sentido de giro [...] origen RTCP respecto a cero máquina (C=0°) frente a cero pieza (C'=0°)"@es .

ex:Esquema_CoordenadasPiezaMaquina
    a ex:Esquema ;
    rdfs:label "Esquema de coordenadas pieza (X'-Y'-Z') y máquina (X-Y-Z) con orientación B-30°"@es ;
    ex:textoExtracto "Esquemas de RTCP con pieza girando alrededor de B y dos escenarios del sistema de coordenadas pieza (TDATA31=0/1) [...] X', Z' y la orientación B-30°"@es .

ex:Esquema_RTCP_B30
    a ex:Esquema ;
    rdfs:label "Esquema RTCP con pieza en B-30° (comparativa sistemas coordenados)"@es ;
    ex:textoExtracto "Se dibujan X', Z' y la orientación B-30°, explicando si el sistema gira con la pieza o permanece paralelo al de máquina"@es .