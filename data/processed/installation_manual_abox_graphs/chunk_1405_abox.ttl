@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaRIO5 a ns1:Sistema ;
    rdfs:label "Sistema RIO5" ;
    ns1:textoExtracto "Cada módulo RIO5 se debe configurar como un bloque lógico." ;
    ns1:tieneComponente ns1:NumeroDeBloquesLogicosPorModulo .

ns1:NumeroDeBloquesLogicosPorModulo a ns1:Parametro ;
    rdfs:label "Número de bloques lógicos por módulo" ;
    ns1:identificador "NDIMOD" ;
    ns1:textoExtracto "NDIMOD | 6 | En la serie RIO5, cada módulo se debe configurar como un bloque lógico." ;
    ns1:valor "6" .

