@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:DiagramaCinematicas52 a ex:Esquema ;
    ex:textoExtracto "Conjunto de diagramas de cinemática combinada: pictogramas de cabezal/mesa y esquema con cinco vectores de traslación (T1–T5) y cinco de dirección (V1–V5). Se representan ejes X-Y-Z, flechas, y jerarquía de elementos (cabezal vs mesa)." ;
    ex:tieneComponente ex:VectorTraslacionT1, ex:VectorTraslacionT2, ex:VectorTraslacionT3, ex:VectorTraslacionT4, ex:VectorTraslacionT5, ex:VectorDireccionV1, ex:VectorDireccionV2, ex:VectorDireccionV3, ex:VectorDireccionV4, ex:VectorDireccionV5, ex:EjeX, ex:EjeY, ex:EjeZ, ex:Cabezal, ex:Mesa .

ex:VectorTraslacionT1 a ex:Parametro ;
    ex:identificador "T1" ;
    ex:textoExtracto "cinco vectores de traslación (T1–T5)" .

ex:VectorTraslacionT2 a ex:Parametro ;
    ex:identificador "T2" ;
    ex:textoExtracto "cinco vectores de traslación (T1–T5)" .

