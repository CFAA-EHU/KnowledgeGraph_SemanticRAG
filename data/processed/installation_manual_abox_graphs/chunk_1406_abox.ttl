@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BloqueEntradaRIOW1_2 a ns1:ComponenteElectrico ;
    rdfs:label "Bloque Entrada RIOW 1 (I33-I40)" ;
    ns1:textoExtracto "El primer nodo RIOW como 2 bloques, el resto a partir de I33" .

ns1:DireccionesDeLosBloquesParaEntradasDigitales a ns1:Parametro ;
    rdfs:label "Direcciones de los bloques para entradas digitales" ;
    ns1:identificador "DIMODADDR" ;
    ns1:textoExtracto "DIMODADDR | - - - | Ver tabla inferior." .

ns1:DireccionesDeLosBloquesParaSalidasDigitales a ns1:Parametro ;
    rdfs:label "Direcciones de los bloques para salidas digitales" ;
    ns1:identificador "DOMODADDR" ;
    ns1:textoExtracto "DOMODADDR | - - - | Ver tabla inferior." .

ns1:NodoRIOW1_cee689bb19 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo RIOW 1" ;
    ns1:textoExtracto "Nodo 1: Grupo remoto RIOW con 16 entradas y 8 salidas digitales." ;
    ns1:tieneComponente ns1:BloqueEntradaRIOW1_1,
        ns1:BloqueSalidaRIOW1 .

ns1:NodoRIOW2_bd2735f523 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo RIOW 2" ;
    ns1:textoExtracto "Nodo 2: Grupo remoto RIOW con 8 entradas y 8 salidas digitales." ;
    ns1:tieneComponente ns1:BloqueEntradaRIOW2,
        ns1:BloqueSalidaRIOW2 .

ns1:NumeroDeBloquesParaEntradasDigitales a ns1:Parametro ;
    rdfs:label "Número de bloques para entradas digitales" ;
    ns1:identificador "NDIMOD" ;
    ns1:textoExtracto "NDIMOD | 3 | 3 bloques; 2 para el primer nodo y 1 para el segundo." ;
    ns1:valor "3" .

ns1:NumeroDeBloquesParaSalidasDigitales a ns1:Parametro ;
    rdfs:label "Número de bloques para salidas digitales" ;
    ns1:identificador "NDOMOD" ;
    ns1:textoExtracto "NDOMOD | 2 | 2 bloques, uno para cada nodo RIOW." ;
    ns1:valor "2" .

ns1:SistemaCANopen a ns1:Sistema ;
    rdfs:label "Sistema CANopen" ;
    ns1:textoExtracto "Un bus CANopen dispone de los siguientes grupos remotos." .

ns1:BloqueEntradaRIOW1_1 a ns1:ComponenteElectrico ;
    rdfs:label "Bloque Entrada RIOW 1 (I1-I8)" ;
    ns1:textoExtracto "El primer nodo RIOW como 2 bloques, uno de 8 entradas a partir de la I1" .

ns1:BloqueEntradaRIOW2 a ns1:ComponenteElectrico ;
    rdfs:label "Bloque Entrada RIOW 2 (I113-I120)" ;
    ns1:textoExtracto "El segundo nodo RIOW como un bloque de 8 entradas a partir de la I113" .

ns1:BloqueSalidaRIOW1 a ns1:ComponenteElectrico ;
    rdfs:label "Bloque Salida RIOW 1 (O81-O88)" ;
    ns1:textoExtracto "El primer nodo RIOW como un bloque de 8 salidas a partir de la O81" .

ns1:BloqueSalidaRIOW2 a ns1:ComponenteElectrico ;
    rdfs:label "Bloque Salida RIOW 2 (O49-O56)" ;
    ns1:textoExtracto "El segundo nodo RIOW como un bloque de 8 salidas a partir de O49" .

