    ex:identificador "T4" ;
    ex:textoExtracto "cinco vectores de traslación (T1–T5)" .

ex:VectorTraslacionT5 a ex:Parametro ;
    ex:identificador "T5" ;
    ex:textoExtracto "cinco vectores de traslación (T1–T5)" .

ex:VectorDireccionV1 a ex:Parametro ;
    ex:identificador "V1" ;
    ex:textoExtracto "cinco de dirección (V1–V5)" .

ex:VectorDireccionV2 a ex:Parametro ;
    ex:identificador "V2" ;
    ex:textoExtracto "cinco de dirección (V1–V5)" .

ex:VectorDireccionV3 a ex:Parametro ;
    ex:identificador "V3" ;
    ex:textoExtracto "cinco de dirección (V1–V5)" .

ex:VectorDireccionV4 a ex:Parametro ;
    ex:identificador "V4" ;
    ex:textoExtracto "cinco de dirección (V1–V5)" .

ex:VectorDireccionV5 a ex:Parametro ;
    ex:identificador "V5" ;
    ex:textoExtracto "cinco de dirección (V1–V5)" .

ex:EjeX a ex:Parametro ;
    ex:textoExtracto "Se representan ejes X-Y-Z" .

ex:EjeY a ex:Parametro ;
    ex:textoExtracto "Se representan ejes X-Y-Z" .

ex:EjeZ a ex:Parametro ;
    ex:textoExtracto "Se representan ejes X-Y-Z" .

ex:Cabezal a ex:ComponenteMecanico ;
    ex:textoExtracto "pictogramas de cabezal/mesa" .

