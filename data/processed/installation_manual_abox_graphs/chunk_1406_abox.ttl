@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA31_33
    a ex:Parametro ;
    rdfs:label "Parámetros TDATA31–33 (mesa)" ;
    ex:textoExtracto "componentes TDATA asociadas (p. ej., TDATA31–33 y 41–43 para mesa)" ;
    ex:identificador "TDATA31–33" .

ex:Parametro_TDATA41_43
    a ex:Parametro ;
    rdfs:label "Parámetros TDATA41–43 (mesa)" ;
    ex:textoExtracto "componentes TDATA asociadas (p. ej., TDATA31–33 y 41–43 para mesa)" ;
    ex:identificador "TDATA41–43" .

ex:Parametro_TDATA21_26
    a ex:Parametro ;
    rdfs:label "Parámetros TDATA21–26 (portaherramientas)" ;
    ex:textoExtracto "TDATA31–33 y 41–43 para mesa; 21–26 para portaherramientas" ;
    ex:identificador "TDATA21–26" .

ex:Parametro_TDATA8_18
    a ex:Parametro ;
    rdfs:label "Parámetros TDATA8/18 (regla de la mano derecha para cabezal)" ;
    ex:textoExtracto "regla de la mano derecha para el cabezal (TDATA8/18)" ;
    ex:identificador "TDATA8/18" .

ex:Esquema_CinematicaTipo52
    a ex:Esquema ;
    rdfs:label "Definición vectorial de cinemáticas cabezal-mesa (tipo 52)" ;
    ex:textoExtracto "Conjunto de diagramas de cinemática combinada: pictogramas de cabezal/mesa y esquema con cinco vectores de traslación (T1–T5) y cinco de dirección (V1–V5). Se representan ejes X-Y-Z, flechas, y jerarquía de elementos (cabezal vs mesa)" ;
    ex:detalladoEnEsquema ex:Parametro_TDATA31_33 , ex:Parametro_TDATA41_43 , ex:Parametro_TDATA21_26 , ex:Parametro_TDATA8_18 .

ex:Sistema_EjesXYZ
    a ex:Sistema ;
    rdfs:label "Sistema de ejes X-Y-Z con orientación B-30°" ;
    ex:textoExtracto "Se dibujan X', Z' y la orientación B-30°, explicando si el sistema gira con la pieza o permanece paralelo al de máquina" ;
    ex:ilustradoEn ex:Esquema_CinematicaTipo52 .

ex:Sistema_RTCP
    a ex:Sistema ;
    rdfs:label "Origen RTCP (mesa) con referencia a cero máquina (C=0°) y cero pieza (C'=0°)" ;
    ex:textoExtracto "Doble diagrama circular comparando origen RTCP en la mesa: aplicación respecto a cero máquina (C=0°) frente a cero pieza (C'=0°)" ;
    ex:ilustradoEn ex:Esquema_CinematicaTipo52 .