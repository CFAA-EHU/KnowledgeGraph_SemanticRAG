@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_CinematicaTipo52
    a ex:Parametro ;
    rdfs:label "Definición vectorial de cinemáticas cabezal-mesa (tipo 52)"@es ;
    ex:textoExtracto "Definición vectorial de cinemáticas cabezal-mesa (tipo 52)"@es ;
    ex:identificador "tipo 52" ;
    ex:documentadoEn ex:Manual_OpenPCS_SeccionParametrosMaquina .

ex:Parametro_TDATA38
    a ex:Parametro ;
    rdfs:label "Sentido de giro del eje rotativo principal de la mesa (TDATA38)"@es ;
    ex:textoExtracto "Ilustraciones de mano con ejes para sentido de giro del eje rotativo principal de la mesa (TDATA38), reforzando la convención de la mano derecha para signos y direcciones."@es ;
    ex:identificador "TDATA38" ;
    ex:documentadoEn ex:Manual_OpenPCS_SeccionParametrosMaquina .

ex:Parametro_TDATA51
    a ex:Parametro ;
    rdfs:label "Configuración RTCP (TDATA51)"@es ;
    ex:textoExtracto "Esquemas RTCP ON con pieza girada B-30° y comparación TDATA51=0/1."@es ;
    ex:identificador "TDATA51" ;
    ex:documentadoEn ex:Manual_OpenPCS_SeccionParametrosMaquina ;
    ex:valor "0/1" .

ex:Parametro_EjesNoOrtogonales
    a ex:Parametro ;
    rdfs:label "Transformación angular de eje inclinado (ejes no ortogonales)"@es ;
    ex:textoExtracto "Esquema de torno con representación de transformación angular de eje inclinado: se ven los ejes Z y X cartesianos y el eje X' inclinado; líneas y flechas azules marcan la direccionalidad, mostrando cómo un movimiento programado en X se descompone en componentes sobre Z y X'."@es ;
    ex:documentadoEn ex:Manual_OpenPCS_SeccionParametrosMaquina .

ex:Esquema_RTCP_Comparativo
    a ex:Esquema ;
    rdfs:label "Esquema comparativo RTCP ON/OFF (pieza girada B-30°)"@es ;
    ex:textoExtracto "Esquemas RTCP ON con pieza girada B-30° y comparación TDATA51=0/1. Se representan X', Z' y la posición de la herramienta, indicando si el sistema pieza gira con la mesa (RTCP completo) o mantiene paralelismo con coordenadas máquina."@es ;
    ex:ilustradoEn ex:Manual_OpenPCS_SeccionParametrosMaquina ;
    ex:detalladoEnEsquema ex:Parametro_TDATA51 .

ex:Esquema_EjesTornoInclinado
    a ex:Esquema ;
    rdfs:label "Esquema de torno con ejes no ortogonales (X, X', Z)"@es ;
    ex:textoExtracto "Esquema de torno con representación de transformación angular de eje inclinado: se ven los ejes Z y X cartesianos y el eje X' inclinado; líneas y flechas azules marcan la direccionalidad, mostrando cómo un movimiento programado en X se descompone en componentes sobre Z y X'."@es ;
    ex:ilustradoEn ex:Manual_OpenPCS_SeccionParametrosMaquina ;
    ex:detalladoEnEsquema ex:Parametro_EjesNoOrtogonales .

ex:Manual_OpenPCS_SeccionParametrosMaquina
    a ex:Manual ;
    rdfs:label "Sección 2: PARÁMETROS MÁQUINA (OpenPCS)"@es ;
    ex:textoExtracto "PARÁMETROS MÁQUINA · Definición vectorial de cinemáticas cabezal-mesa (tipo 52)"@es .