@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaRIORNodo1 a ns1:Sistema ;
    rdfs:label "Nodo 1 (RIOR)"@es ;
    ns1:textoExtracto "Nodo 1: Grupo remoto RIOR con 48 entradas y 32 salidas digitales." ;
    ns1:tieneComponente ns1:BloqueLogicoEntrada1,
        ns1:BloqueLogicoSalida1 .

ns1:SistemaRIORNodo2 a ns1:Sistema ;
    rdfs:label "Nodo 2 (RIOR)"@es ;
    ns1:textoExtracto "Nodo 2: Grupo remoto RIOR con 48 entradas y 32 salidas digitales." ;
    ns1:tieneComponente ns1:BloqueLogicoEntrada2_1,
        ns1:BloqueLogicoEntrada2_2,
        ns1:BloqueLogicoEntrada2_3,
        ns1:BloqueLogicoSalida2 .

ns1:BloqueLogicoEntrada1 a ns1:Sistema ;
    rdfs:label "Bloque de 48 entradas desde I1"@es ;
    ns1:textoExtracto "El primer nodo RIOR como un bloque de 48 entradas a partir de la I1." .

ns1:BloqueLogicoEntrada2_1 a ns1:Sistema ;
    rdfs:label "Bloque de 48 entradas desde I97"@es ;
    ns1:textoExtracto "El segundo nodo RIOR como tres bloques de 48 entradas a partir de la I97." .

ns1:BloqueLogicoEntrada2_2 a ns1:Sistema ;
    rdfs:label "Bloque de 48 entradas desde I145"@es ;
    ns1:textoExtracto "El segundo nodo RIOR como tres bloques de 48 entradas a partir de la I97." .

ns1:BloqueLogicoEntrada2_3 a ns1:Sistema ;
    rdfs:label "Bloque de 48 entradas desde I193"@es ;
    ns1:textoExtracto "El segundo nodo RIOR como tres bloques de 48 entradas a partir de la I97." .

ns1:BloqueLogicoSalida1 a ns1:Sistema ;
    rdfs:label "Bloque de 32 salidas desde O1"@es ;
    ns1:textoExtracto "También un bloque de 32 salidas a partir de la O1." .

ns1:BloqueLogicoSalida2 a ns1:Sistema ;
    rdfs:label "Bloque de 32 salidas desde O81"@es ;
    ns1:textoExtracto "También un bloque de 32 salidas a partir de la O81." .

