@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DireccionDeLosModulosDelBloque a ns1:Parametro ;
    rdfs:label "Dirección de los módulos del bloque" ;
    ns1:identificador "DIMODADDR" ;
    ns1:textoExtracto "DIMODADDR | - - - | Ver tabla inferior." .

ns1:DireccionDeLosModulosDelBloqueDOM a ns1:Parametro ;
    rdfs:label "Dirección de los módulos del bloque (DOM)" ;
    ns1:identificador "DOMMODADDR" ;
    ns1:textoExtracto "DOMMODADDR | - - - | Ver tabla inferior." .

ns1:NumeroDeBloquesParaCadaNodoRIOR a ns1:Parametro ;
    rdfs:label "Número de bloques para cada nodo RIOR" ;
    ns1:identificador "NDIMOD" ;
    ns1:textoExtracto "NDIMOD | 2 | 2 bloques, uno para cada nodo RIOR. En la serie RIOR, cada módulo se debe configurar como un bloque lógico." ;
    ns1:valor "2" .

ns1:NumeroDeBloquesParaCadaNodoRIORDOM a ns1:Parametro ;
    rdfs:label "Número de bloques para cada nodo RIOR (DOM)" ;
    ns1:identificador "NDOMOD" ;
    ns1:textoExtracto "NDOMOD | 2 | 2 bloques, uno para cada nodo RIOR. En la serie RIOR, cada módulo se debe configurar como un bloque lógico." ;
    ns1:valor "2" .

