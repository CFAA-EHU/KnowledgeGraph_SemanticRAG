@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Bancada rdfs:label "bancada" ;
    a ex:ComponenteMecanico ;
    ex:textoExtracto "Incluye rotulación 'X', 'X'' y 'Z' junto a la ilustración de bancada, carro y pieza" .

ex:Carro rdfs:label "carro" ;
    a ex:ComponenteMecanico ;
    ex:textoExtracto "Incluye rotulación 'X', 'X'' y 'Z' junto a la ilustración de bancada, carro y pieza" .

ex:Pieza rdfs:label "pieza" ;
    a ex:ComponenteMecanico ;
    ex:textoExtracto "Incluye rotulación 'X', 'X'' y 'Z' junto a la ilustración de bancada, carro y pieza" .

ex:EjeCartesianoZ rdfs:label "eje cartesiano Z" ;
    a ex:ComponenteMecanico ;
    ex:textoExtracto "Diagrama de definición de la transformación angular: se muestra un eje cartesiano Z" .

ex:GuiaInclinada rdfs:label "guía inclinada" ;
    a ex:ComponenteMecanico ;
    ex:textoExtracto "sobre una guía inclinada, el eje X' formando un ángulo ANGANTR con X" .

ex:EjeXPrima rdfs:label "eje X'" ;
    a ex:ComponenteMecanico ;
    ex:textoExtracto "el eje X' formando un ángulo ANGANTR con X" .

ex:SistemaInclinado rdfs:label "sistema inclinado" ;
    a ex:ComponenteMecanico ;
    ex:textoExtracto "el origen del sistema inclinado" .

ex:ParametroANGANTR rdfs:label "ANGANTR" ;
    a ex:Parametro ;
    ex:valor "60º" ;
    ex:textoExtracto "Las etiquetas 'ANGAXNA=X ORTAXNA=Z ANGANTR=60º' refuerzan la configuración" .

ex:ParametroOFFANGAX rdfs:label "OFFANGAX" ;
    a ex:Parametro ;
    ex:textoExtracto "aparece una cota de offset 'OFFANGAX' entre el cero máquina y el origen del sistema inclinado" .

ex:ParametroANGAXNA rdfs:label "ANGAXNA" ;
    a ex:Parametro ;
    ex:textoExtracto "Las etiquetas 'ANGAXNA=X ORTAXNA=Z ANGANTR=60º' refuerzan la configuración" .

ex:ParametroORTAXNA rdfs:label "ORTAXNA" ;
    a ex:Parametro ;
    ex:textoExtracto "Las etiquetas 'ANGAXNA=X ORTAXNA=Z ANGANTR=60º' refuerzan la configuración" .

ex:CabezalFresa rdfs:label "cabezal con fresa" ;
    a ex:ComponenteMecanico ;
    ex:textoExtracto "Ilustración de cinemática de ejes paralelos aplicada al husillo/herramienta: un cabezal con fresa" .

ex:FlechaCurvaAzul rdfs:label "flecha curva azul" ;
    a ex:ComponenteMecanico ;
    ex:textoExtracto "dos flechas curvas azules paralelas indican suma de desplazamientos de un eje aditivo sobre el eje principal" .

ex:EjeAditivo rdfs:label "eje aditivo" ;
    a ex:ComponenteMecanico ;
    ex:textoExtracto "suma de desplazamientos de un eje aditivo sobre el eje principal" .

ex:EjePrincipal rdfs:label "eje principal" ;
    a ex:ComponenteMecanico ;
    ex:textoExtracto "suma de desplazamientos de un eje aditivo sobre el eje principal" .

ex:CarruselGantry rdfs:label "carrusel-gantry" ;
    a ex:ComponenteMecanico ;
    ex:textoExtracto "Escena del tipo 'Asíncrono': un carrusel-gantry y brazo de doble pinza realizan el intercambio con la herramienta" .

ex:BrazoDoblePinza rdfs:label "brazo de doble pinza" ;
    a ex:ComponenteMecanico ;
    ex:textoExtracto "Escena del tipo 'Asíncrono': un carrusel-gantry y brazo de doble pinza realizan el intercambio con la herramienta" .

ex:CarruselSincrono rdfs:label "carrusel" ;
    a ex:ComponenteMecanico ;
    ex:textoExtracto "Escena del tipo 'Síncrono': un carrusel se aproxima al cabezal sin brazo cambiador" .

ex:BrazoCambiador rdfs:label "brazo cambiador" ;
    a ex:ComponenteMecanico ;
    ex:textoExtracto "Escena del tipo 'Síncrono': un carrusel se aproxima al cabezal sin brazo cambiador" .