@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Herramienta_1409_1 a ex:Herramienta ;
    ex:textoExtracto "la nueva herramienta en el husillo" ;
    ex:tieneComponente ex:Husillo_1409_1 .

ex:Husillo_1409_1 a ex:ComponenteMecanico ;
    ex:textoExtracto "husillo" .

ex:Torreta_1409_1 a ex:ComponenteMecanico ;
    ex:textoExtracto "torreta indexable" .

ex:TornoHorizontal_1409_1 a ex:Maquina ;
    ex:textoExtracto "Torno horizontal: representación esquemática del eje pieza con variantes de signo para X y Z (X±/Z±)" ;
    ex:compuestoPor ex:EjeX_1409_1, ex:EjeZ_1409_1, ex:Portaherramientas_1409_1 .

ex:EjeX_1409_1 a ex:ComponenteMecanico ;
    ex:textoExtracto "eje X" .

ex:EjeZ_1409_1 a ex:ComponenteMecanico ;
    ex:textoExtracto "eje Z" .

ex:Portaherramientas_1409_1 a ex:ComponenteMecanico ;
    ex:textoExtracto "portaherramientas" .

ex:TornoVertical_1409_2 a ex:Maquina ;
    ex:textoExtracto "Torno vertical: disposición vertical del husillo/plato con flechas de ejes X y Z en distintas combinaciones de signo" ;
    ex:compuestoPor ex:EjeX_1409_2, ex:EjeZ_1409_2, ex:Husillo_1409_2 .

ex:EjeX_1409_2 a ex:ComponenteMecanico ;
    ex:textoExtracto "eje X" .

ex:EjeZ_1409_2 a ex:ComponenteMecanico ;
    ex:textoExtracto "eje Z" .

ex:Husillo_1409_2 a ex:ComponenteMecanico ;
    ex:textoExtracto "husillo/plato" .

ex:EsquemaNumeracion_1409_1 a ex:Esquema ;
    ex:textoExtracto "Esquema de 'Numeración según el orden de los grupos remotos': tres bloques 'Remote Group (1–3)' con módulos encestados bajo un 'POWER SUPPLY'; flechas negras indican el orden de numeración (arriba-abajo, izquierda-derecha). Bajo cada grupo se anotan rangos resultantes de O e I (p. ej., O1…O32, I1…I48)" ;
    ex:tieneComponente ex:RemoteGroup_1409_1, ex:RemoteGroup_1409_2, ex:RemoteGroup_1409_3, ex:PowerSupply_1409_1 .

ex:RemoteGroup_1409_1 a ex:Sistema ;
    ex:textoExtracto "Remote Group (1)" .

ex:RemoteGroup_1409_2 a ex:Sistema ;
    ex:textoExtracto "Remote Group (2)" .

ex:RemoteGroup_1409_3 a ex:Sistema ;
    ex:textoExtracto "Remote Group (3)" .

ex:PowerSupply_1409_1 a ex:ComponenteElectrico ;
    ex:textoExtracto "POWER SUPPLY" .