@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCANopen a ns1:Sistema ;
    rdfs:label "Sistema CANopen" ;
    ns1:textoExtracto "Un bus CANopen dispone de los siguientes grupos remotos." ;
    ns1:tieneComponente ns1:Nodo1RIO5,
        ns1:Nodo2_b06ab00448 .

ns1:GrupoRemotoRIO5 a ns1:Componente ;
    rdfs:label "Grupo remoto RIO5" ;
    ns1:textoExtracto "Nodo 1: Grupo remoto RIO5 con 3 módulos de 24 entradas digitales cada uno." .

ns1:GrupoRemotoRIOW a ns1:Componente ;
    rdfs:label "Grupo remoto RIOW" ;
    ns1:textoExtracto "Nodo 2: Grupo remoto RIOW con 64 entradas digitales." .

ns1:Nodo1RIO5 a ns1:Componente ;
    rdfs:label "Nodo 1 (RIO5)" ;
    ns1:textoExtracto "Nodo 1: Grupo remoto RIO5 con 3 módulos de 24 entradas digitales cada uno." ;
    ns1:tieneComponente ns1:GrupoRemotoRIO5 .

ns1:Nodo2_b06ab00448 a ns1:Componente ;
    rdfs:label "Nodo 2" ;
    ns1:textoExtracto "Nodo 2: Grupo remoto RIOW con 64 entradas digitales." ;
    ns1:tieneComponente ns1:GrupoRemotoRIOW .

