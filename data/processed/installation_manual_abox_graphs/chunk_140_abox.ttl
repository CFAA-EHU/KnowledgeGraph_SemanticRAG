@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeEntradasDigitalesDelBloqueLogico a ns1:Parametro ;
    rdfs:label "Número de entradas digitales del bloque lógico" ;
    ns1:identificador "MPG.DIMODNDI" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.DIMODNDI[nb] Número de entradas digitales del bloque lógico; no puede ser cero y debe ser un múltiplo de 8 (8, 16, 24, ...1024)." .

ns1:SistemaRIO5 a ns1:Sistema ;
    rdfs:label "Sistema RIO5" ;
    ns1:textoExtracto "En los nodos RIO5, cada módulo doble (módulo con dos placas) cuenta como dos; es decir, dos bloques lógicos." ;
    ns1:tieneComponente ns1:ModuloDoble .

ns1:ModuloDoble a ns1:ComponenteElectrico ;
    rdfs:label "Módulo Doble" ;
    ns1:textoExtracto "En los nodos RIO5, cada módulo doble (módulo con dos placas) cuenta como dos; es decir, dos bloques lógicos." .

