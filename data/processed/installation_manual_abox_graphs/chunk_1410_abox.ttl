@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeBloquesParaLosModulosDeES a ns1:Parametro ;
    rdfs:label "Número de bloques para los módulos de E/S" ;
    ns1:identificador "NDIMOD" ;
    ns1:textoExtracto "NDIMOD | 5 | 2 bloques para el RIOW y 3 bloques para el RIO5." ;
    ns1:valor "5" .

ns1:CNC8070_5ff761684a a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:TablaConfiguracionRIOW ;
    ns1:textoExtracto "Se desea configurar el nodo RIOW en 2 bloques, uno de 24 entradas a partir de la I104 y el resto a partir de I200." .

ns1:TablaConfiguracionRIOW a ns1:Tabla ;
    rdfs:label "Configuración de nodos RIOW" ;
    ns1:ilustradoEn ns1:CNC8070_5ff761684a ;
    ns1:textoExtracto "Parámetro. | Valor. | Comentario." .

