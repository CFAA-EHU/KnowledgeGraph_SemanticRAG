@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TG2 a ex:Parametro ;
    rdfs:label "TG2" ;
    ex:textoExtracto "Si TG2 baja antes de completar el tiempo, la temporización se cancela y t mantiene el valor alcanzado."@es ;
    ex:textoExtracto "Diagrama del efecto de TEN en TG2: con el retardo en marcha, poner TEN=0 pausa la rampa de t; al devolver TEN=1, la temporización se reanuda. Se muestran, en secuencia, los estados de TG2, TEN, t y T."@es .

ex:TEN a ex:Parametro ;
    rdfs:label "TEN" ;
    ex:textoExtracto "Diagrama del efecto de TEN en TG2: con el retardo en marcha, poner TEN=0 pausa la rampa de t; al devolver TEN=1, la temporización se reanuda."@es ;
    ex:textoExtracto "Diagrama del efecto de TEN en TG3: con el retardo activo, TEN=0 pausa t; al restituir TEN=1, la cuenta continúa hasta completar la constante de tiempo, tras lo cual T se desactiva."@es .

ex:t a ex:Parametro ;
    rdfs:label "t" ;
    ex:textoExtracto "Si TG2 baja antes de completar el tiempo, la temporización se cancela y t mantiene el valor alcanzado."@es ;
    ex:textoExtracto "con el retardo en marcha, poner TEN=0 pausa la rampa de t"@es ;
    ex:textoExtracto "el retardo comienza con el flanco de bajada de TG3 (t sube desde 0)"@es ;
    ex:textoExtracto "al agotarse el tiempo, T pasa a 0"@es ;
    ex:textoExtracto "Un nuevo flanco de subida de TG3 antes de finalizar el retardo reinicia t y mantiene T=1."@es ;
    ex:textoExtracto "un flanco de subida en TRS inicializa el temporizador (T=0, t=0)"@es ;
    ex:textoExtracto "con el retardo activo, TEN=0 pausa t"@es .

ex:T a ex:Parametro ;
    rdfs:label "T" ;
    ex:textoExtracto "Se muestran, en secuencia, los estados de TG2, TEN, t y T."@es ;
    ex:textoExtracto "tras un flanco de subida en TG3, T=1"@es ;
    ex:textoExtracto "al agotarse el tiempo, T pasa a 0."@es ;
    ex:textoExtracto "Un nuevo flanco de subida de TG3 antes de finalizar el retardo reinicia t y mantiene T=1."@es ;
    ex:textoExtracto "un flanco de subida en TRS inicializa el temporizador (T=0, t=0)"@es ;
    ex:textoExtracto "tras lo cual T se desactiva."@es .

ex:TRS a ex:Parametro ;
    rdfs:label "TRS" ;
    ex:textoExtracto "Diagrama del efecto de TRS en TG3: un flanco de subida en TRS inicializa el temporizador (T=0, t=0) y exige una nueva activación por TG3 para reiniciar la secuencia."@es .

ex:ModoRetardoConexion a ex:ModoOperacion ;
    rdfs:label "Modo retardo a la conexión" ;
    ex:textoExtracto "3.5.2 Modo retardo a la conexión (TG2)"@es .

ex:ModoRetardoDesconexion a ex:ModoOperacion ;
    rdfs:label "Modo retardo a la desconexión" ;
    ex:textoExtracto "3.5.3 Modo retardo a la desconexión (TG3)"@es .