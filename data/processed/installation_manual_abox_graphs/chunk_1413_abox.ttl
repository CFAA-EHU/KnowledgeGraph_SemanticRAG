@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ModoLimitadorSenal_TG4 a ex:ModoOperacion ;
    ex:textoExtracto "un flanco de subida en TG4 activa T=1 y arranca t; T vuelve a 0 al cumplirse la constante de tiempo o por un flanco de bajada en TG4 anterior al vencimiento, conservándose el valor alcanzado de t en ese instante." ;
    ex:textoExtracto "la señal TRS, por flanco de subida, reinicia el temporizador (T=0, t=0) en cualquier momento del ciclo y requiere nueva activación mediante TG4." ;
    ex:textoExtracto "con la temporización activa, forzar TEN=0 congela t y mantiene el estado hasta recuperar TEN=1, cuando la temporización prosigue hasta su fin o hasta la caída de TG4." .

ex:Temporizador_T a ex:ComponenteElectrico ;
    ex:textoExtracto "arranca t" ;
    ex:textoExtracto "T vuelve a 0 al cumplirse la constante de tiempo" ;
    ex:textoExtracto "conservándose el valor alcanzado de t en ese instante" ;
    ex:textoExtracto "reinicia el temporizador (T=0, t=0)" ;
    ex:textoExtracto "forzar TEN=0 congela t" .

ex:Senal_TRS a ex:Parametro ;
    ex:textoExtracto "la señal TRS, por flanco de subida, reinicia el temporizador" .

ex:Senal_TEN a ex:Parametro ;
    ex:textoExtracto "forzar TEN=0 congela t" ;
    ex:textoExtracto "recuperar TEN=1, cuando la temporización prosigue" .

ex:Contador_PLC a ex:ComponenteElectrico ;
    ex:textoExtracto "Funcionamiento de un contador" ;
    ex:textoExtracto "entradas CUP (conteo), CDW (desconteo) y CEN (enable)" ;
    ex:textoExtracto "incrementos/decrementos por flancos de subida" ;
    ex:textoExtracto "efecto de CEN=0 (inhibe CUP/CDW)" ;
    ex:textoExtracto "la marca de estado C que vale 1 cuando la cuenta es cero" .

ex:Entrada_CUP a ex:Parametro ;
    ex:textoExtracto "entradas CUP (conteo)" .

ex:Entrada_CDW a ex:Parametro ;
    ex:textoExtracto "entradas CDW (desconteo)" .

ex:Entrada_CEN a ex:Parametro ;
    ex:textoExtracto "entradas CEN (enable)" ;
    ex:textoExtracto "efecto de CEN=0 (inhibe CUP/CDW)" .

ex:Estado_C a ex:Parametro ;
    ex:textoExtracto "la marca de estado C que vale 1 cuando la cuenta es cero" .