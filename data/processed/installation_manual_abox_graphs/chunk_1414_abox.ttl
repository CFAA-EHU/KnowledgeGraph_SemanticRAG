@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Esquema_TransferenciaBits_MOV
    a ex:Esquema ;
    rdfs:label "Esquema de transferencia de bits en =MOV con conversión Bin↔BCD" ;
    ex:textoExtracto "se representan bloques INPUT/OUTPUT con bits indexados (S1…S8/…S16) y su mapeo hacia salidas, indicando anchuras (4, 8, …, 32 bits) y códigos de origen/destino. La gráfica ilustra la conversión y el direccionamiento de grupos de bits." ;
    ex:identificador "4.4.4_Instrucciones_Aritméticas_MOV" .

ex:Esquema_RotacionRegistros_RL1_RR1
    a ex:Esquema ;
    rdfs:label "Diagrama de rotación de registros tipo 1 (RL1/RR1)" ;
    ex:textoExtracto "flechas muestran el desplazamiento de bits y la entrada/salida de '0' por el extremo opuesto, indicando la pérdida del bit expulsado. Se visualiza la dirección de giro y la estructura de 32 bits del registro." ;
    ex:identificador "4.4.5_Rotación_Tipo1_RL1_RR1" .

ex:Esquema_RotacionRegistros_RL2_RR2
    a ex:Esquema ;
    rdfs:label "Diagrama de rotación de registros tipo 2 (RL2/RR2)" ;
    ex:textoExtracto "rotación circular donde el bit desplazado reingresa por el extremo contrario, preservando el conjunto de 32 bits. Se ilustran, con flechas, los ciclos de rotación y la conservación de información." ;
    ex:identificador "4.4.5_Rotación_Tipo2_RL2_RR2" .

ex:Grafico_MovimientoPosicionamiento_MOVE_ABS
    a ex:Esquema ;
    rdfs:label "Gráfico 'F vs Pos' para bloques MOVE ABS" ;
    ex:textoExtracto "ejemplifica tres bloques consecutivos MOVE ABS con distintos parámetros de enlace (PRESENT, NEXT, NULL): el eje horizontal es la posición (marcas en 50 mm, 100 mm, 150 mm) y el vertical el avance F (niveles 125, 250, 500)." ;
    ex:identificador "4.4.8_MovimientoPosicionamiento_MOVE_ABS" .

ex:Parametro_Posicion_50mm
    a ex:Parametro ;
    rdfs:label "Posición 50 mm" ;
    ex:valor "50" ;
    ex:textoExtracto "marcas en 50 mm" ;
    ex:ilustradoEn ex:Grafico_MovimientoPosicionamiento_MOVE_ABS .

ex:Parametro_Posicion_100mm
    a ex:Parametro ;
    rdfs:label "Posición 100 mm" ;
    ex:valor "100" ;
    ex:textoExtracto "marcas en 100 mm" ;
    ex:ilustradoEn ex:Grafico_MovimientoPosicionamiento_MOVE_ABS .

ex:Parametro_Posicion_150mm
    a ex:Parametro ;
    rdfs:label "Posición 150 mm" ;
    ex:valor "150" ;
    ex:textoExtracto "marcas en 150 mm" ;
    ex:ilustradoEn ex:Grafico_MovimientoPosicionamiento_MOVE_ABS .

ex:Parametro_Avance_F_125
    a ex:Parametro ;
    rdfs:label "Avance F 125" ;
    ex:valor "125" ;
    ex:textoExtracto "niveles 125" ;
    ex:ilustradoEn ex:Grafico_MovimientoPosicionamiento_MOVE_ABS .

ex:Parametro_Avance_F_250
    a ex:Parametro ;
    rdfs:label "Avance F 250" ;
    ex:valor "250" ;
    ex:textoExtracto "niveles 250" ;
    ex:ilustradoEn ex:Grafico_MovimientoPosicionamiento_MOVE_ABS .

ex:Parametro_Avance_F_500
    a ex:Parametro ;
    rdfs:label "Avance F 500" ;
    ex:valor "500" ;
    ex:textoExtracto "niveles 500" ;
