@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Polilinea1415 a ex:Componente ;
    rdfs:label "Polilínea" ;
    ex:textoExtracto "La polilínea muestra cómo se alcanza cada posición con el avance del propio bloque, el del siguiente o avance nulo, evidenciando los cambios de consigna entre tramos." .

ex:SSTROBE a ex:Sensor ;
    rdfs:label "SSTROBE" ;
    ex:textoExtracto "tres señales digitales (SSTROBE, MSTROBE y AUXEND)" .

ex:MSTROBE a ex:Sensor ;
    rdfs:label "MSTROBE" ;
    ex:textoExtracto "tres señales digitales (SSTROBE, MSTROBE y AUXEND)" .

ex:AUXEND a ex:Sensor ;
    rdfs:label "AUXEND" ;
    ex:textoExtracto "tres señales digitales (SSTROBE, MSTROBE y AUXEND)" .

ex:MINAENDW1 a ex:Parametro ;
    rdfs:label "MINAENDW" ;
    ex:textoExtracto "Se resalta el parámetro de temporización MINAENDW mediante una cota horizontal." ;
    ex:valor "tiempo mínimo" .

ex:MINAENDW2 a ex:Parametro ;
    rdfs:label "MINAENDW" ;
    ex:textoExtracto "incluyendo una cota de duración MINAENDW" ;
    ex:valor "tiempo mínimo" .

ex:InterfazMensajesErrores a ex:InterfazUsuario ;
    rdfs:label "MESSAGES AND ERRORS" ;
    ex:textoExtracto "Captura de interfaz 'MESSAGES AND ERRORS' con una tabla tipo lista de mensajes numerados (MSG1… ERRxxx) y su estado, más un área inferior que muestra campos 'SHOW', 'MESSAGE FILE', 'PLC RUNNING', etc." .

ex:MSG1 a ex:AvisoSeguridad ;
    rdfs:label "MSG1" ;
    ex:textoExtracto "tabla tipo lista de mensajes numerados (MSG1… ERRxxx)" .

ex:ERRxxx a ex:AvisoSeguridad ;
    rdfs:label "ERRxxx" ;
    ex:textoExtracto "tabla tipo lista de mensajes numerados (MSG1… ERRxxx)" .

ex:CampoSHOW a ex:Parametro ;
    rdfs:label "SHOW" ;
    ex:textoExtracto "área inferior que muestra campos 'SHOW', 'MESSAGE FILE', 'PLC RUNNING', etc." .

ex:CampoMESSAGEFILE a ex:Parametro ;
    rdfs:label "MESSAGE FILE" ;
    ex:textoExtracto "área inferior que muestra campos 'SHOW', 'MESSAGE FILE', 'PLC RUNNING', etc." .

ex:CampoPLCRUNNING a ex:Parametro ;
    rdfs:label "PLC RUNNING" ;
    ex:textoExtracto "área inferior que muestra campos 'SHOW', 'MESSAGE FILE', 'PLC RUNNING', etc." .