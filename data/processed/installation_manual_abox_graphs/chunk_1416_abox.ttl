@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_683cc7c722 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:SoftwareLantekExpertInside ;
    ns1:textoExtracto "Fagor Automation y Lantek han colaborado en la integración del software Lantek Expert Inside para los modelos CNC 8060 y 8070." ;
    ns1:tieneComponente ns1:InterfazUsuarioLantekExpertInside .

ns1:NestingAutomatico a ns1:AccionProhibida ;
    rdfs:label "Nesting Automático" ;
    ns1:textoExtracto "nesting automático (el software coloca la piezas en la chapa basándose en sus parámetros de configuración)." .

ns1:NestingManual a ns1:AccionProhibida ;
    rdfs:label "Nesting Manual" ;
    ns1:textoExtracto "nesting manual (el usuario coloca las piezas en la chapa como le resulte conveniente)" .

ns1:InterfazUsuarioLantekExpertInside a ns1:InterfazUsuario ;
    rdfs:label "Interfaz Lantek Expert Inside" ;
    ns1:textoExtracto "La sencilla interfaz, adecuada para pantallas táctiles, facilita la revisión del corte en tiempo real y las modificaciones a pie de máquina." .

ns1:SoftwareLantekExpertInside a ns1:DocumentoTecnico ;
    rdfs:label "Lantek Expert Inside" ;
    ns1:textoExtracto "Fagor Automation y Lantek han colaborado en la integración del software Lantek Expert Inside para los modelos CNC 8060 y 8070." .

