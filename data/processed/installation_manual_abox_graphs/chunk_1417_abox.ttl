@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SeñalesConsultaEjesCabezalesPLC a ex:ModoOperacion ;
    ex:textoExtracto "Diagrama temporal análogo al anterior, pero para la maniobra iniciada desde el PLC. Representa PARK(axis), UNPARK(axis), PARKED(axis), DRENA(axis) y REFPOIN(axis) con numeración (1–4) de eventos. La gráfica distingue claramente la iniciación por PARKED, el comienzo de PARK/UNPARK por parte del CNC y la finalización con restablecimiento de habilitaciones." ;
    ex:compuestoPor ex:PARK, ex:UNPARK, ex:PARKED, ex:DRENA, ex:REFPOIN .

ex:PARK a ex:ModoOperacion ;
    ex:identificador "PARK(axis)" ;
    ex:textoExtracto "Representa PARK(axis)" .

ex:UNPARK a ex:ModoOperacion ;
    ex:identificador "UNPARK(axis)" ;
    ex:textoExtracto "Representa UNPARK(axis)" .

ex:PARKED a ex:ModoOperacion ;
    ex:identificador "PARKED(axis)" ;
    ex:textoExtracto "Representa PARKED(axis)" .

ex:DRENA a ex:ModoOperacion ;
    ex:identificador "DRENA(axis)" ;
    ex:textoExtracto "Representa DRENA(axis)" .

ex:REFPOIN a ex:ModoOperacion ;
    ex:identificador "REFPOIN(axis)" ;
    ex:textoExtracto "Representa REFPOIN(axis)" .

ex:PanelOP_PANEL a ex:InterfazUsuario ;
    ex:textoExtracto "Fotografía del panel OP-PANEL con teclado de usuario y bloque de teclas de jog. Se distinguen pulsadores iluminables, con agrupación jerárquica por funciones (usuario, jog, husillo, start/stop) y distribución matricial que el texto asocia a bits KEYBD1/2/3." ;
    ex:compuestoPor ex:TecladoUsuario, ex:BloqueTeclasJog, ex:PulsadoresIluminables .

ex:TecladoUsuario a ex:ComponenteElectrico ;
    ex:textoExtracto "teclado de usuario" .

ex:BloqueTeclasJog a ex:ComponenteElectrico ;
    ex:textoExtracto "bloque de teclas de jog" .

ex:PulsadoresIluminables a ex:ComponenteElectrico ;
    ex:textoExtracto "pulsadores iluminables" .

ex:PanelOP_PANEL_329 a ex:InterfazUsuario ;
    ex:textoExtracto "Fotografía del panel OP-PANEL-329 mostrando un layout compacto: selector circular, pulsadores de jog en columna y teclas de usuario en bloque." ;
    ex:compuestoPor ex:SelectorCircular, ex:PulsadoresJogColumna, ex:TeclasUsuarioBloque .

ex:SelectorCircular a ex:ComponenteElectrico ;
    ex:textoExtracto "selector circular" .

ex:PulsadoresJogColumna a ex:ComponenteElectrico ;
    ex:textoExtracto "pulsadores de jog en columna" .

ex:TeclasUsuarioBloque a ex:ComponenteElectrico ;
    ex:textoExtracto "teclas de usuario en bloque" .

ex:PanelQC_C65_10K a ex:InterfazUsuario ;
    ex:identificador "QC-C65□-10K" ;
    ex:textoExtracto "Fotografía del panel QC-C65□-10K con pantalla integrada y keypad numérico; a la derecha, un bloque de teclas de jog dispuesto en rejilla." ;
    ex:compuestoPor ex:PantallaIntegrada, ex:KeypadNumerico, ex:BloqueTeclasJogRejilla .

ex:PantallaIntegrada a ex:ComponenteElectrico ;
    ex:textoExtracto "pantalla integrada" .

ex:KeypadNumerico a ex:ComponenteElectrico ;
    ex:textoExtracto "keypad numérico" .

ex:BloqueTeclasJogRejilla a ex:ComponenteElectrico ;
    ex:textoExtracto "bloque de teclas de jog dispuesto en rejilla" .