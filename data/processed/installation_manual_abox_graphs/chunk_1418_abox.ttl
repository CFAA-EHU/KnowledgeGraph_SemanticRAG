@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Figura_1418_1 a ex:Figura ;
    rdfs:label "Figura que apoya la correspondencia entre posiciones físicas y bits de los registros KEYBDx"@es ;
    ex:textoExtracto "La figura apoya la correspondencia entre posiciones físicas y bits de los registros KEYBDx para este modelo."@es .

ex:Fotografia_OP_PANEL a ex:Figura ;
    rdfs:label "Fotografía OP-PANEL"@es ;
    ex:textoExtracto "Conjunto de tres fotografías (OP-PANEL, OP-PANEL-329 y QC-C65□-10K) repetidas para la sección de 'Teclas de jog' y 'Registros KEYBD2…'."@es .

ex:Fotografia_OP_PANEL_329 a ex:Figura ;
    rdfs:label "Fotografía OP-PANEL-329"@es ;
    ex:textoExtracto "Conjunto de tres fotografías (OP-PANEL, OP-PANEL-329 y QC-C65□-10K) repetidas para la sección de 'Teclas de jog' y 'Registros KEYBD2…'."@es .

ex:Fotografia_QC_C65_10K a ex:Figura ;
    rdfs:label "Fotografía QC-C65□-10K"@es ;
    ex:textoExtracto "Conjunto de tres fotografías (OP-PANEL, OP-PANEL-329 y QC-C65□-10K) repetidas para la sección de 'Teclas de jog' y 'Registros KEYBD2…'."@es .

ex:Esquema_USERKEYS a ex:Esquema ;
    rdfs:label "Esquema USERKEYS"@es ;
    ex:textoExtracto "Dos esquemas de keypad en formato rejilla ('USERKEYS' y 'JOGKEYS') con numeración 1–15."@es .

ex:Esquema_JOGKEYS a ex:Esquema ;
    rdfs:label "Esquema JOGKEYS"@es ;
    ex:textoExtracto "Dos esquemas de keypad en formato rejilla ('USERKEYS' y 'JOGKEYS') con numeración 1–15."@es .

ex:Diagrama_Proceso_Reset a ex:Esquema ;
    rdfs:label "Diagrama temporal 'Proceso de reset con RESETIN'"@es ;
    ex:textoExtracto "Diagrama temporal 'Proceso de reset con RESETIN' con trazas RESETIN, RESETOUT y etiqueta de subrutina PROGRAM_RESET; incluye marca temporal MINAENDW y un intervalo t."@es .

ex:Diagrama_Sincronizacion_AUXEND_MSTROBE a ex:Esquema ;
    rdfs:label "Diagrama de sincronización AUXEND/MSTROBE"@es ;
    ex:textoExtracto "Diagrama de sincronización AUXEND/MSTROBE con eje temporal y marcas numeradas (1–4) asociado a la ejecución de funciones auxiliares S/M."@es .