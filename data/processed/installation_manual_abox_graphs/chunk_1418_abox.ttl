@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArchivoBatCNC8070L a ns1:ComponenteElectrico ;
    rdfs:label "Archivo Bat CNC8070L" ;
    ns1:identificador "CNC8070L.bat" ;
    ns1:textoExtracto "El CNC arranca a través de un archivo bat (por ejemplo CNC8070L.bat)." .

ns1:CNC8070_dfb21e1768 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC arranca a través de un archivo bat (por ejemplo CNC8070L.bat)." .

ns1:ModoDiagnosis a ns1:ModoOperacion ;
    rdfs:label "Modo Diagnosis" ;
    ns1:textoExtracto "Para arrancar el nesting, ir al modo Diagnosis, y en el menú horizontal seleccionar Apps > Lantek." .

ns1:SoftwareNesting a ns1:ComponenteElectrico ;
    rdfs:label "Software Nesting Lantek Expert" ;
    ns1:identificador "c:\\Lantek\\Expert\\Expert.exe" ;
    ns1:textoExtracto "El software del nesting arranca a continuación del CNC." .

ns1:TeclaUSERKEY a ns1:ComponenteElectrico ;
    rdfs:label "Tecla USERKEY" ;
    ns1:textoExtracto "Configurar la tecla USERKEY como \"Aplicación\" y asignarle el path \"c:\\Lantek\\Expert\\Expert.exe\"." .

