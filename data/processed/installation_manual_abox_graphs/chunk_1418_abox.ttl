@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Figura_Keybdx_761_762
    a ex:Figura ;
    rdfs:label "Figura de correspondencia KEYBDx (OP-PANEL)"@es ;
    ex:textoExtracto "La figura apoya la correspondencia entre posiciones físicas y bits de los registros KEYBDx para este modelo."@es ;
    ex:ilustradoEn ex:Esquema_UserKeys_JogKeys_438 .

ex:Esquema_UserKeys_JogKeys_438
    a ex:Esquema ;
    rdfs:label "Esquemas USERKEYS y JOGKEYS (rejilla 1-15)"@es ;
    ex:textoExtracto "Dos esquemas de keypad en formato rejilla ('USERKEYS' y 'JOGKEYS') con numeración 1–15. Indican la disposición y orden de teclas genéricas y de jog, útil para interpretar la correspondencia física-lógica de los bits en KEYBD y los efectos de selectores/overrides."@es ;
    ex:detalladoEnEsquema ex:Interfaz_OPPanel_433 .

ex:Interfaz_OPPanel_433
    a ex:InterfazUsuario ;
    rdfs:label "OP-PANEL (teclas START/STOP, husillo, override, jog 1-15)"@es ;
    ex:textoExtracto "Conjunto de tres fotografías (OP-PANEL, OP-PANEL-329 y QC-C65□-10K) repetidas para la sección de 'Teclas de jog' y 'Registros KEYBD2…'. Subrayan la ubicación de START/STOP, sentido de husillo y override, así como la matriz de jog 1–15, apoyando la lectura de bits asignados a cada tecla/posición."@es ;
    ex:compuestoPor ex:Tecla_StartStop_433 ;
    ex:compuestoPor ex:Tecla_Husillo_433 ;
    ex:compuestoPor ex:Tecla_Override_433 ;
    ex:compuestoPor ex:Matriz_Jog_1_15_433 .

ex:Tecla_StartStop_433
    a ex:ComponenteElectrico ;
    rdfs:label "Tecla START/STOP (OP-PANEL)"@es ;
    ex:textoExtracto "ubicación de START/STOP"@es .

ex:Tecla_Husillo_433
    a ex:ComponenteElectrico ;
    rdfs:label "Tecla sentido de husillo (OP-PANEL)"@es ;
    ex:textoExtracto "sentido de husillo"@es .

ex:Tecla_Override_433
    a ex:ComponenteElectrico ;
    rdfs:label "Tecla override (OP-PANEL)"@es ;
    ex:textoExtracto "override"@es .

ex:Matriz_Jog_1_15_433
    a ex:ComponenteElectrico ;
    rdfs:label "Matriz de teclas jog 1-15 (OP-PANEL)"@es ;
    ex:textoExtracto "matriz de jog 1–15"@es .

ex:Diagrama_Reset_439
    a ex:Figura ;
    rdfs:label "Diagrama temporal 'Proceso de reset con RESETIN'"@es ;
    ex:textoExtracto "Diagrama temporal 'Proceso de reset con RESETIN' con trazas RESETIN, RESETOUT y etiqueta de subrutina PROGRAM_RESET; incluye marca temporal MINAENDW y un intervalo t. Muestra flancos de subida/bajada, orden de eventos y la relación entre marcas del PLC y respuesta del canal durante el reset."@es ;
    ex:ilustradoEn ex:Sistema_Reset_PLC_439 .

ex:Sistema_Reset_PLC_439
    a ex:Sistema ;
    rdfs:label "Sistema de reset PLC (RESETIN/RESETOUT)"@es ;
    ex:textoExtracto "Proceso de reset con RESETIN... relación entre marcas del PLC y respuesta del canal durante el reset"@es ;
    ex:tieneComponente ex:Senal_ResetIn_439 ;
    ex:tieneComponente ex:Senal_ResetOut_439 ;
    ex:tieneComponente ex:Parametro_MINAENDW_439 .

ex:Senal_ResetIn_439
    a ex:ComponenteElectrico ;
    rdfs:label "Señal RESETIN (PLC)"@es ;
    ex:textoExtracto "trazas RESETIN"@es .

ex:Senal_ResetOut_439
    a ex:ComponenteElectrico ;
    rdfs:label "Señal RESETOUT (PLC)"@es ;
    ex:textoExtracto "RESETOUT"@es .

ex:Parametro_MINAENDW_439
    a ex:Parametro ;
    rdfs:label "Parámetro MINAENDW (tiempo mínimo reset)"@es ;
    ex:textoExtracto "marca temporal MINAENDW"@es ;
    ex:valor "t" .

ex:Diagrama_Sincronizacion_439
    a ex:Figura ;
    rdfs:label "Diagrama de sincronización AUXEND/MSTROBE"@es ;
    ex:textoExtracto "Diagrama de sincronización AUXEND/MSTROBE con eje temporal y marcas numeradas (1–4) asociado a la ejecución de funciones auxiliares S/M. Representa la desactivación/activación de AUXEND respecto a STROBE y el tiempo mínimo MINAENDW para finalizar la sincronización."@es ;
    ex:ilustradoEn ex:Sistema_Sincronizacion_AUX_439 .

ex:Sistema_Sincronizacion_AUX_439
    a ex:Sistema ;
    rdfs:label "Sistema de sincronización AUXEND/STROBE"@es ;
    ex:textoExtracto "ejecución de funciones auxiliares S/M... tiempo mínimo MINAENDW para finalizar la sincronización"@es ;
    ex:tieneComponente ex:Senal_AUXEND_439 ;
    ex:tieneComponente ex:Senal_STROBE_439 ;
    ex:tieneComponente ex:Parametro_MINAENDW_Sinc_439 .

ex:Senal_AUXEND_439
    a ex:ComponenteElectrico ;
    rdfs:label "Señal AUXEND"@es ;
    ex:textoExtracto "desactivación/activación de AUXEND"@es .

ex:Senal_STROBE_439
    a ex:ComponenteElectrico ;
    rdfs:label "Señal STROBE"@es ;
    ex:textoExtracto "respecto a STROBE"@es .

ex:Parametro_MINAENDW_Sinc_439
    a ex:Parametro ;
    rdfs:label "Parámetro MINAENDW (sincronización)"@es ;
    ex:textoExtracto "tiempo mínimo MINAENDW para finalizar la sincronización"@es .