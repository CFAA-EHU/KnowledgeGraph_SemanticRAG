@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoDiagnosis a ns1:ModoOperacion ;
    rdfs:label "Diagnosis" ;
    ns1:textoExtracto "En el modo Diagnosis, en el menú horizontal seleccionar Apps > Lantek (si lo OEM lo ha configurado así)." .

ns1:PasarDelCNCALaAplicacionDeNesting a ns1:AccionProhibida ;
    rdfs:label "Pasar del CNC a la aplicación de nesting" ;
    ns1:textoExtracto "Para pasar del CNC a la aplicación de nesting:" .

ns1:UsarTeclaCUSTOMParaAccederAlSoftwareDeNesting a ns1:AccionProhibida ;
    rdfs:label "Usar tecla [CUSTOM] para acceder al software de nesting" ;
    ns1:textoExtracto "La tecla [CUSTOM] accede al software de nesting (si lo OEM lo ha configurado así)." .

ns1:UsarTeclasCTRLWParaCambiarDeAplicacion a ns1:AccionProhibida ;
    rdfs:label "Usar teclas [CTRL]+[W] para cambiar de aplicación" ;
    ns1:textoExtracto "Si sólo está abierta la aplicación de nesting y el CNC, las teclas [CTRL]+[W] cambian alternativamente de una o otra." .

