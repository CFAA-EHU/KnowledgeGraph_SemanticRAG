@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DireccionesBaseDeLosBloquesLogicosDeSalidasDigitales a ns1:Parametro ;
    rdfs:label "Direcciones base de los bloques lógicos de salidas digitales" ;
    ns1:identificador "DOMODADDR" ;
    ns1:textoExtracto "DOMODADDR Direcciones base de los bloques lógicos de salidas digitales." .

ns1:NumeroDeBloquesLogicosDeSalidasDigitales a ns1:Parametro ;
    rdfs:label "Número de bloques lógicos de salidas digitales" ;
    ns1:identificador "MPG.NDOMOD" ;
    ns1:textoExtracto "NDOMOD Número de bloques lógicos de salidas digitales. Valores posibles: De 0 a 42." .

