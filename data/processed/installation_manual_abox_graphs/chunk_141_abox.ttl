@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PRBPULSE1 a ex:Parametro ;
    rdfs:label "PRBPULSE1" ;
    ex:identificador "PRBPULSE1" ;
    ex:textoExtracto "PRBPULSE1 Nivel lógico de activación del palpador 1. Valores posibles: Positivo / Negativo. Valor por defecto: Positivo. Variable asociada: (V.)MPG.PRBPULSE1 Parámetro incluido en la tabla PROBEDATA." ;
    ex:valor "Positivo / Negativo" .

ex:PRBPULSE2 a ex:Parametro ;
    rdfs:label "PRBPULSE2" ;
    ex:identificador "PRBPULSE2" ;
    ex:textoExtracto "PRBPULSE2 Nivel lógico de activación del palpador 2. Valores posibles: Positivo / Negativo. Valor por defecto: Positivo. Variable asociada: (V.)MPG.PRBPULSE2 Parámetro incluido en la tabla PROBEDATA." ;
    ex:valor "Positivo / Negativo" .

ex:PROBEDATA a ex:Tabla ;
    ex:textoExtracto "Parámetro incluido en la tabla PROBEDATA." .

ex:Palpador1 a ex:Sensor ;
    rdfs:label "palpador 1" ;
    ex:textoExtracto "un palpador en cada canal y realizando ambos un movimiento de palpado" .

ex:Palpador2 a ex:Sensor ;
    rdfs:label "palpador 2" ;
    ex:textoExtracto "un palpador en cada canal y realizando ambos un movimiento de palpado" .

ex:MPG_PRBPULSE1 a ex:Parametro ;
    rdfs:label "(V.)MPG.PRBPULSE1" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.PRBPULSE1" .

ex:MPG_PRBPULSE2 a ex:Parametro ;
    rdfs:label "(V.)MPG.PRBPULSE2" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.PRBPULSE2" .

ex:INTOL a ex:Parametro ;
    rdfs:label "INTOL" ;
    ex:textoExtracto "la señal INTOL del PLC" .

ex:PRBPULSE1 ex:documentadoEn ex:PROBEDATA ;
    ex:textoExtracto "Parámetro incluido en la tabla PROBEDATA." .

ex:PRBPULSE2 ex:documentadoEn ex:PROBEDATA ;
    ex:textoExtracto "Parámetro incluido en la tabla PROBEDATA." .

ex:MPG_PRBPULSE1 ex:identificador "(V.)MPG.PRBPULSE1" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.PRBPULSE1" .

ex:MPG_PRBPULSE2 ex:identificador "(V.)MPG.PRBPULSE2" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.PRBPULSE2" .