@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaConfiguracionIdiomas a ns1:Tabla ;
    rdfs:label "Lista de idiomas disponibles" ;
    ns1:ilustra ns1:IdiomaLocalDeLaAplicacion,
        ns1:IdiomaPrincipalDeLaAplicacion ;
    ns1:textoExtracto "La aplicación tiene instalados dos idiomas, habitualmente el idioma inglés (recomendado) y un idioma local." .

ns1:IdiomaLocalDeLaAplicacion a ns1:Parametro ;
    rdfs:label "Idioma local de la aplicación" ;
    ns1:identificador "LocalLanguage" ;
    ns1:textoExtracto "<setting name=\"LocalLanguage\" serializeAs=\"String\"> <value>zh-CHS</value>" .

ns1:IdiomaPrincipalDeLaAplicacion a ns1:Parametro ;
    rdfs:label "Idioma principal de la aplicación" ;
    ns1:identificador "Language" ;
    ns1:textoExtracto "<setting name=\"Language\" serializeAs=\"String\"> <value>en</value>" .

