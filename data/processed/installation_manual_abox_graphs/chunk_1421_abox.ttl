@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:AlmacenSincronoSinBrazoCambiador a ex:Sistema ;
    rdfs:label "Almacén síncrono sin brazo cambiador" ;
    ex:textoExtracto "Ilustración de un almacén síncrono sin brazo cambiador: carrusel de herramientas dispuesto bajo una boquilla de husillo/cabezal; el carrusel se posiciona frente al husillo para realizar el intercambio directamente, sin intervención de brazo." ;
    ex:compuestoPor ex:CarruselHerramientas, ex:PlatoPortaherramientas, ex:Husillo .

ex:AlmacenSincronoConBrazoCambiador a ex:Sistema ;
    rdfs:label "Almacén síncrono con brazo cambiador" ;
    ex:textoExtracto "Ilustración de un almacén síncrono con brazo cambiador (1–2 pinzas): se aprecia un disco portaherramientas cercano al cabezal y un brazo basculante con pinzas que transfieren la herramienta entre carrusel y husillo." ;
    ex:compuestoPor ex:CarruselHerramientas, ex:PlatoPortaherramientas, ex:Husillo, ex:BrazoCambiador .

ex:AlmacenAsincronoConBrazoCambiador a ex:Sistema ;
    rdfs:label "Almacén asíncrono con brazo cambiador" ;
    ex:textoExtracto "Ilustración de un almacén asíncrono con brazo cambiador: cadena tipo 'crawler' o almacén lineal alejado del cabezal y un brazo de doble pinza desplazándose de forma independiente." ;
    ex:compuestoPor ex:CadenaCrawler, ex:BrazoCambiador .

ex:CarruselHerramientas a ex:ComponenteMecanico ;
    rdfs:label "Carrusel de herramientas" ;
    ex:textoExtracto "carrusel de herramientas dispuesto bajo una boquilla de husillo/cabezal" .

ex:PlatoPortaherramientas a ex:ComponenteMecanico ;
    rdfs:label "Plato portaherramientas" ;
    ex:textoExtracto "plato portaherramientas circular" .

ex:Husillo a ex:ComponenteMecanico ;
    rdfs:label "Husillo" ;
    ex:textoExtracto "boquilla de husillo/cabezal" .

ex:BrazoCambiador a ex:ComponenteMecanico ;
    rdfs:label "Brazo cambiador" ;
    ex:textoExtracto "brazo basculante con pinzas que transfieren la herramienta entre carrusel y husillo", "brazo de doble pinza desplazándose de forma independiente" .

ex:CadenaCrawler a ex:ComponenteMecanico ;
    rdfs:label "Cadena tipo 'crawler'" ;
    ex:textoExtracto "cadena tipo 'crawler' o almacén lineal alejado del cabezal" .