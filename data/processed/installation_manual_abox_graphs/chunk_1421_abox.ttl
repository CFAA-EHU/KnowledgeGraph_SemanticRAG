@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_f6c5182a8d a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:mitigaRiesgo ns1:ActivarControlDeGapDesdeOtroCanalCuandoYaEstaActivo,
        ns1:TrabajarConLeapfrogControlDelGapYConmutacionSincronizadaSimultaneamente ;
    ns1:monitoreaParametro ns1:OpcionDeSoftwareGAPCONTROL ;
    ns1:textoExtracto "Si se intenta activar el control de gap desde un canal cuando ya está activo en otro, el CNC mostrará el error correspondiente." .

ns1:SensorGap a ns1:Sensor ;
    rdfs:label "Sensor Gap" ;
    ns1:textoExtracto "Esta distancia la calcula un sensor conectado al CNC" .

ns1:ActivarControlDeGapDesdeOtroCanalCuandoYaEstaActivo a ns1:AccionProhibida ;
    rdfs:label "Activar control de gap desde otro canal cuando ya está activo" ;
    ns1:textoExtracto "Si se intenta activar el control de gap desde un canal cuando ya está activo en otro, el CNC mostrará el error correspondiente." .

ns1:OpcionDeSoftwareGAPCONTROL a ns1:Parametro ;
    rdfs:label "Opción de software GAP CONTROL" ;
    ns1:textoExtracto "Para el control del gap es necesario disponer de la opción de software 'GAP CONTROL'." .

ns1:TrabajarConLeapfrogControlDelGapYConmutacionSincronizadaSimultaneamente a ns1:AccionProhibida ;
    rdfs:label "Trabajar con leapfrog, control del gap y conmutación sincronizada simultáneamente" ;
    ns1:textoExtracto "El CNC no permite trabajar con las tres funcionalidades activas a la vez; leapfrog (#LEAP), control del gap (#GAPCTRL) y conmutación sincronizada (#SWTOUT)." .

