@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarControlDelGap a ns1:Parametro ;
    rdfs:label "Activar control del gap" ;
    ns1:identificador "GAPCTRL ON" ;
    ns1:textoExtracto "La sentencia #GAPCTRL ON permite activar el control del gap." .

ns1:CNC8070_9303814967 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "La sentencia ejecutada desde el PLC actualiza a la programada desde el CNC y viceversa." .

ns1:DesactivarControlDelGap a ns1:Parametro ;
    rdfs:label "Desactivar control del gap" ;
    ns1:identificador "GAPCTRL OFF" ;
    ns1:textoExtracto "La sentencia #GAPCTRL OFF desactiva el control del gap." .

ns1:DistanciaGapAMantenerRespectoDeLaSuperficie_419e4687df a ns1:Parametro ;
    rdfs:label "Distancia (gap) a mantener respecto de la superficie" ;
    ns1:identificador "GAP{gap}" ;
    ns1:textoExtracto "<GAP{gap}> Opcional (por defecto, el último valor programado). Distancia (gap) a mantener respecto de la superficie." .

ns1:EjeAsociadoAlSensorYCotaDeAproximacion a ns1:Parametro ;
    rdfs:label "Eje asociado al sensor y cota de aproximación" ;
    ns1:identificador "X..C{pos}" ;
    ns1:textoExtracto "<X..C{pos}> Opcional (por defecto, el último valor programado). Eje asociado al sensor y cota de aproximación." .

ns1:Sensor_efd8625a1b a ns1:Sensor ;
    rdfs:label "Sensor de Gap" ;
    ns1:textoExtracto "Calibración del sensor. Para conseguir un seguimiento correcto del sensor, se recomienda que la señal del sensor esté calibrada con el máximo número de puntos posible." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "La sentencia ejecutada desde el PLC actualiza a la programada desde el CNC y viceversa." .

