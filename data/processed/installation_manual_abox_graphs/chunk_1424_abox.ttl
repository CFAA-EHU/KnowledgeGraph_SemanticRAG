@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Teclado_e_idiomas_OpenPCS ex:textoExtracto "Captura de la ventana 'Teclados e idiomas' con el botón 'Cambiar teclados…'. Se aprecia la jerarquía de pestañas y el flujo para abrir el cuadro de 'Servicios instalados', paso necesario para agregar un idioma de entrada y su distribución de teclado." ;
    a ex:InterfazUsuario ;
    ex:compuestoPor ex:Boton_Cambiar_teclados, ex:Cuadro_Servicios_instalados, ex:Pestanas_jerarquicas .

ex:Boton_Cambiar_teclados ex:textoExtracto "botón 'Cambiar teclados…'" ;
    a ex:ComponenteElectrico .

ex:Cuadro_Servicios_instalados ex:textoExtracto "cuadro de 'Servicios instalados'" ;
    a ex:InterfazUsuario ;
    ex:compuestoPor ex:Arbol_lenguajes, ex:Boton_Agregar_idioma .

ex:Arbol_lenguajes ex:textoExtracto "árbol de lenguajes" ;
    a ex:InterfazUsuario .

ex:Boton_Agregar_idioma ex:textoExtracto "acción 'Agregar…'" ;
    a ex:ComponenteElectrico .

ex:Idioma_entrada_Spanish ex:textoExtracto "entradas 'Spanish'" ;
    a ex:Parametro ;
    ex:valor "Spanish" .

ex:Distribucion_teclado_US ex:textoExtracto "'United States'" ;
    a ex:Parametro ;
    ex:valor "United States" .

ex:Manual_variables_CNC ex:textoExtracto "manual 'Variables del CNC' (man_8070_var.pdf)" ;
    a ex:Manual ;
    ex:identificador "man_8070_var.pdf" ;
    ex:documentadoEn ex:Web_corporativa_Fagor_Automation .

ex:Web_corporativa_Fagor_Automation ex:textoExtracto "Captura de la web corporativa de Fagor Automation (página de descargas) donde localizar el manual 'Variables del CNC'" ;
    a ex:InterfazUsuario .