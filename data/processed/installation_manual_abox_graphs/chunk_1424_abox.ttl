@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivacionDelControlDelGapDesdeElPLC a ns1:TareaMantenimiento ;
    rdfs:label "Activación del control del gap desde el PLC" ;
    ns1:textoExtracto "El PLC puede activar el control del gap ejecutando con el comando CNCEX el bloque de CNC correspondiente." .

ns1:CNC8070_d38e5796b1 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "programación desde el PLC. El PLC puede activar el control del gap ejecutando con el comando CNCEX el bloque de CNC correspondiente." ;
    ns1:tieneComponente ns1:BloqueCNC,
        ns1:ComponenteElectrico_50667d8fe7 .

ns1:ControlDelGapActivado a ns1:Parametro ;
    rdfs:label "Control del gap activado" ;
    ns1:identificador "GAPCTRL ON" ;
    ns1:textoExtracto "#GAPCTRL ON [Z, GAP 1]" .

ns1:ControlDelGapDesactivado a ns1:Parametro ;
    rdfs:label "Control del gap desactivado" ;
    ns1:identificador "GAPCTRL OFF" ;
    ns1:textoExtracto "#GAPCTRL OFF" .

ns1:Parametro_ad0ecc48c3 a ns1:Parametro ;
    rdfs:label "Comando para ejecutar bloques de CNC" ;
    ns1:identificador "CNCEX" ;
    ns1:textoExtracto "{ condition} = CNCEX [{block}, {plc_mark}<,{channel}>]" .

ns1:BloqueCNC a ns1:ComponenteElectrico ;
    rdfs:label "Bloque de CNC" ;
    ns1:textoExtracto "{ block} Bloque a ejecutar." .

ns1:ComponenteElectrico_50667d8fe7 a ns1:ComponenteElectrico ;
    rdfs:label "Marca de control del PLC" ;
    ns1:textoExtracto "{ plc_mark} Marca de control. El PLC activa la marca cuando comienza la operación y la mantiene así hasta que finaliza la misma." .

