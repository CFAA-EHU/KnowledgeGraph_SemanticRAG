@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_8a161b3217 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:monitoreaParametro ns1:Sensor_8c51e41fb9 ;
    ns1:parametroMonitoradoPor ns1:CancelacionDelErrorPorFaltaDeSenalDelSensor,
        ns1:ToleranciaDelControlDeGap ;
    ns1:textoExtracto "El CNC considera que el bloque de aproximación ha terminado cuando el sensor alcanza el gap con la tolerancia definida en el parámetro máquina GAPTOL." .

ns1:CancelacionDelErrorPorFaltaDeSenalDelSensor a ns1:Parametro ;
    rdfs:label "Cancelación del error por falta de señal del sensor" ;
    ns1:identificador "GAPTOLCANCEL" ;
    ns1:textoExtracto "Si el eje alcanza la cota programada, sin recibir la señal del sensor, el CNC mostrará el error correspondiente o no, dependiendo del parámetro máquina GAPTOLCANCEL." .

ns1:Sensor_8c51e41fb9 a ns1:Sensor ;
    rdfs:label "Sensor de gap" ;
    ns1:textoExtracto "El sensor alcanza el gap con la tolerancia definida en el parámetro máquina GAPTOL." .

ns1:ToleranciaDelControlDeGap a ns1:Parametro ;
    rdfs:label "Tolerancia del control de gap" ;
    ns1:identificador "GAPTOL" ;
    ns1:textoExtracto "El CNC considera que el bloque de aproximación ha terminado cuando el sensor alcanza el gap con la tolerancia definida en el parámetro máquina GAPTOL." .

