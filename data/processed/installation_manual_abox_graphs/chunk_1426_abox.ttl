@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_3d6a973fe1 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:DetencionDelMovimientoDuranteAproximacion ;
    ns1:textoExtracto "Durante el movimiento de aproximación, el CNC permite detener el movimiento (señales _STOP o _FEEDHOL)." .

ns1:DetencionDelMovimientoDuranteAproximacion a ns1:AccionProhibida ;
    rdfs:label "Detención del Movimiento durante Aproximación" ;
    ns1:textoExtracto "En este caso el eje permanecerá parado y sin control del gap hasta que se reanude el movimiento." .

