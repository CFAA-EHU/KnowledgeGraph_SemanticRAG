@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_8e16065de5 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:EsquemaElectricoGapSensor ;
    ns1:textoExtracto "Ver \"16.2.4 Configurar el sensor del gap.\" la página 699. Esquema eléctrico." ;
    ns1:tieneComponente ns1:ModuloRIO5,
        ns1:ModuloRIOR,
        ns1:ReguladorSercos .

ns1:Sensor_a847ff6e11 a ns1:Sensor ;
    rdfs:label "Sensor del gap" ;
    ns1:monitoreaParametro ns1:IdentificadorDeEntradaAnalogicaDelGap,
        ns1:TipoDeEntradaAnalogicaDelGap ;
    ns1:textoExtracto "La entrada analógica para el sensor podrá estar situada en los módulos remotos CAN o en un regulador Sercos de cualquier eje." .

ns1:EsquemaElectricoGapSensor a ns1:Esquema ;
    ns1:textoExtracto "Conexión del sensor a una entrada analógica del regulador Sercos. El ejemplo utiliza la primera entrada analógica del regulador (pines 4 y 5); para utilizar la segunda, utilizar los pines 2 y 3." .

ns1:IdentificadorDeEntradaAnalogicaDelGap a ns1:Parametro ;
    rdfs:label "Identificador de entrada analógica del gap" ;
    ns1:identificador "GAPANAINID" ;
    ns1:textoExtracto "Utilizar los parámetros máquina GAPANAINTYPE y GAPANAINID para definir en el CNC dónde está la entrada del sensor." .

ns1:ModuloRIO5 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RIO5" ;
    ns1:textoExtracto "Las entradas analógicas están disponibles en los módulos RIO5 y RIOR." .

ns1:ModuloRIOR a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RIOR" ;
    ns1:textoExtracto "Las entradas analógicas están disponibles en los módulos RIO5 y RIOR." .

ns1:ReguladorSercos a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos" ;
    ns1:textoExtracto "Utilizar los parámetros máquina GAPANAINTYPE y GAPANAINID para definir en el CNC dónde está la entrada del sensor." .

ns1:TipoDeEntradaAnalogicaDelGap a ns1:Parametro ;
    rdfs:label "Tipo de entrada analógica del gap" ;
    ns1:identificador "GAPANAINTYPE" ;
    ns1:textoExtracto "Utilizar los parámetros máquina GAPANAINTYPE y GAPANAINID para definir en el CNC dónde está la entrada del sensor." .

