@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SistemaTandemControl a ex:Sistema ;
    ex:textoExtracto "Diagrama de bloques del sistema con CNC, regulador y dos ejes (MASTER DRIVE y SLAVE DRIVE). Se detallan lazos de posición y velocidad, señales de consigna y realimentación, y el bloque 'Tandem control' que aplica precarga y distribución de par." ;
    ex:compuestoPor ex:EjeMaestro, ex:EjeEsclavo, ex:ControladorTandem ;
    ex:tieneComponente ex:MotorMaestro, ex:MotorEsclavo .

ex:ControladorTandem a ex:Componente ;
    ex:textoExtracto "bloque 'Tandem control' que aplica precarga y distribución de par" ;
    ex:compuestoPor ex:BloquePrecarga, ex:BloqueDistribucionPar .

ex:EjeMaestro a ex:Componente ;
    ex:textoExtracto "dos ejes (MASTER DRIVE y SLAVE DRIVE)" ;
    ex:compuestoPor ex:MotorMaestro .

ex:EjeEsclavo a ex:Componente ;
    ex:textoExtracto "dos ejes (MASTER DRIVE y SLAVE DRIVE)" ;
    ex:compuestoPor ex:MotorEsclavo .

ex:MotorMaestro a ex:ComponenteElectrico ;
    ex:textoExtracto "MASTER DRIVE" ;
    ex:identificador "MASTER DRIVE" .

ex:MotorEsclavo a ex:ComponenteElectrico ;
    ex:textoExtracto "SLAVE DRIVE" ;
    ex:identificador "SLAVE DRIVE" .

ex:BloquePrecarga a ex:Componente ;
    ex:textoExtracto "bloque de 'Preload'" .

ex:BloqueDistribucionPar a ex:Componente ;
    ex:textoExtracto "distribución de par" .

ex:GrupoMultieje a ex:Sistema ;
    ex:textoExtracto "Grupo multieje compuesto por dos ejes, cada uno controlado por un motor." ;
    ex:compuestoPor ex:Eje1Multieje, ex:Eje2Multieje ;
    ex:tieneComponente ex:MotorGrupo1, ex:MotorGrupo2 .

ex:Eje1Multieje a ex:Componente ;
    ex:textoExtracto "dos ejes" .

ex:Eje2Multieje a ex:Componente ;
    ex:textoExtracto "dos ejes" .

ex:MotorGrupo1 a ex:ComponenteElectrico ;
    ex:textoExtracto "motor" .

ex:MotorGrupo2 a ex:ComponenteElectrico ;
    ex:textoExtracto "motor" .