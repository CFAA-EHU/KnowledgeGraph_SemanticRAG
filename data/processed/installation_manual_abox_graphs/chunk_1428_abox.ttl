@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Motor_A1 a ex:Maquina ;
    rdfs:label "motor" ;
    ex:textoExtracto "motor" ;
    ex:identificador "A1" ;
    ex:textoExtracto "A1 con captación directa al regulador" .

ex:Motor_A2 a ex:Maquina ;
    rdfs:label "motor" ;
    ex:textoExtracto "motor" ;
    ex:identificador "A2" ;
    ex:textoExtracto "A2 con captación a módulos remotos" .

ex:Regulador_Sercos a ex:ComponenteElectrico ;
    rdfs:label "regulador Sercos" ;
    ex:textoExtracto "regulador Sercos" ;
    ex:identificador "Sercos" .

ex:Modulo_Remoto_CANfagor a ex:ComponenteElectrico ;
    rdfs:label "módulo remoto CANfagor" ;
    ex:textoExtracto "módulo remoto CANfagor" ;
    ex:identificador "X1…X5" .

ex:Eje_A1 a ex:ComponenteMecanico ;
    rdfs:label "eje A1" ;
    ex:identificador "A1" ;
    ex:textoExtracto "dos ejes (A1, A2)" ;
    ex:textoExtracto "A1 con captación directa al regulador" .

ex:Eje_A2 a ex:ComponenteMecanico ;
    rdfs:label "eje A2" ;
    ex:identificador "A2" ;
    ex:textoExtracto "dos ejes (A1, A2)" ;
    ex:textoExtracto "A2 con captación a módulos remotos" .

ex:Esquema_Multieje a ex:Esquema ;
    rdfs:label "Esquema de conexión multieje" ;
    ex:textoExtracto "Diagrama donde un solo motor, mediante acoplamientos, gobierna alternativamente dos ejes (A1 y A2) seleccionados por el regulador" ;
    ex:tieneComponente ex:Motor_A1, ex:Motor_A2, ex:Eje_A1, ex:Eje_A2, ex:Regulador_Sercos, ex:Modulo_Remoto_CANfagor .

ex:Esquema_Captacion_Directa a ex:Esquema ;
    rdfs:label "Esquema de captación directa" ;
    ex:textoExtracto "Esquema de conexión donde la captación directa (encoder) entra en la segunda entrada del regulador Sercos" .

ex:Esquema_Captacion_Local a ex:Esquema ;
    rdfs:label "Esquema de captación local" ;
    ex:textoExtracto "Esquema donde la captación directa entra en las entradas locales de contaje de la unidad central" .

ex:Esquema_Captacion_Remota a ex:Esquema ;
    rdfs:label "Esquema de captación remota" ;
    ex:textoExtracto "Diagrama de cableado con módulo remoto CANfagor de contadoras (X1…X5, CAN L/H, alimentación y terminaciones)" .