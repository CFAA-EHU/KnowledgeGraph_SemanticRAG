@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_a6ad8bdf1c a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Tiempo de lazo. Se recomienda utilizar un tiempo de ciclo de 2 milisegundos (LOOPTIME=2)." .

ns1:GananciaDelGap a ns1:Parametro ;
    rdfs:label "Ganancia del gap" ;
    ns1:identificador "GAPGAIN" ;
    ns1:textoExtracto "GAPGAIN = 0.20." .

ns1:PorcentajeDeACForwardEnAutomatico a ns1:Parametro ;
    rdfs:label "Porcentaje de AC-Forward en automático" ;
    ns1:identificador "ACFGAIN" ;
    ns1:textoExtracto "Los valores de ACFGAIN pueden coincidir con los de un ajuste estándar." .

ns1:PorcentajeDeFeedForwardEnAutomatico_9ac46bea78 a ns1:Parametro ;
    rdfs:label "Porcentaje de feed forward en automático" ;
    ns1:identificador "FFGAIN" ;
    ns1:textoExtracto "FFGAIN = 90 %" .

ns1:TiempoDeCicloDelCNC a ns1:Parametro ;
    rdfs:label "Tiempo de ciclo del CNC" ;
    ns1:identificador "LOOPTIME" ;
    ns1:textoExtracto "Se recomienda utilizar un tiempo de ciclo de 2 milisegundos (LOOPTIME=2)." .

