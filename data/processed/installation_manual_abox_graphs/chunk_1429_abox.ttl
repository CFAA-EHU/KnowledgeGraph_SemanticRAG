@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Motor_A1_A2 a ex:ComponenteMecanico ;
    ex:textoExtracto "un único motor alimenta mecánicamente A1 y A2" .

ex:Sistema_Multieje a ex:Sistema ;
    ex:textoExtracto "Sistema con dos ejes y sólo un motor" ;
    ex:compuestoPor ex:Motor_A1_A2 .

ex:Eje_A1 a ex:ComponenteMecanico ;
    ex:textoExtracto "ambos ejes usan captación directa a módulos remotos diferentes (1 y 2)" .

ex:Eje_A2 a ex:ComponenteMecanico ;
    ex:textoExtracto "ambos ejes usan captación directa a módulos remotos diferentes (1 y 2)" .

ex:Sistema_Multieje ex:tieneComponente ex:Eje_A1, ex:Eje_A2 .

ex:Torno a ex:Maquina ;
    ex:textoExtracto "Dibujo esquemático de un torno que define cero máquina (OM), cero pieza (OW) y punto de referencia H" .

ex:Punto_Referencia_OM a ex:Componente ;
    ex:textoExtracto "cero máquina (OM)" ;
    rdfs:label "cero máquina (OM)" .

ex:Punto_Referencia_OW a ex:Componente ;
    ex:textoExtracto "cero pieza (OW)" ;
    rdfs:label "cero pieza (OW)" .

ex:Punto_Referencia_H a ex:Componente ;
    ex:textoExtracto "punto de referencia H" ;
    rdfs:label "punto de referencia H" .

ex:Torno ex:tieneComponente ex:Punto_Referencia_OM, ex:Punto_Referencia_OW, ex:Punto_Referencia_H .

ex:Eje_X a ex:ComponenteMecanico ;
    ex:textoExtracto "ejes X-Z" .

ex:Eje_Z a ex:ComponenteMecanico ;
    ex:textoExtracto "ejes X-Z" .

ex:Torno ex:tieneComponente ex:Eje_X, ex:Eje_Z .

ex:Esquema_Torno a ex:Esquema ;
    ex:textoExtracto "Dibujo esquemático de un torno que define cero máquina (OM), cero pieza (OW) y punto de referencia H, con cotas XMH/ZMH y XMW/ZMW" ;
    ex:ilustradoEn ex:Torno ;
    ex:compuestoPor ex:Punto_Referencia_OM, ex:Punto_Referencia_OW, ex:Punto_Referencia_H, ex:Eje_X, ex:Eje_Z .

ex:Perfil_Velocidad_REFFEED1 a ex:Parametro ;
    ex:textoExtracto "perfiles de velocidad (REFFEED1)" ;
    rdfs:label "REFFEED1" .

ex:Pulso_Micro a ex:Sensor ;
    ex:textoExtracto "pulsos de micro" .

ex:Pulso_I0 a ex:Sensor ;
    ex:textoExtracto "pulsos de I0" .

ex:Cronograma_Referenciado a ex:Esquema ;
    ex:textoExtracto "Cronograma de señales durante la búsqueda: perfiles de velocidad (REFFEED1) y aproximaciones, pulsos de micro y de I0" ;
    ex:compuestoPor ex:Perfil_Velocidad_REFFEED1, ex:Pulso_Micro, ex:Pulso_I0 .

ex:Limite_Fisico_FL a ex:Parametro ;
    ex:textoExtracto "límites físicos (FL)" ;
    rdfs:label "FL" .

ex:Limite_Software_SL a ex:Parametro ;
    ex:textoExtracto "límites de software (SL)" ;
    rdfs:label "SL" .

ex:Volumen_Trabajo_3D a ex:Esquema ;
    ex:textoExtracto "Ilustración 3D del volumen de trabajo con límites físicos (FL) y límites de software (SL) para X-Y-Z" ;
    ex:compuestoPor ex:Limite_Fisico_FL, ex:Limite_Software_SL .

ex:Punto_T a ex:Componente ;
    ex:textoExtracto "el punto T (portaherramientas)" ;
    rdfs:label "punto T (portaherramientas)" .

ex:Volumen_Trabajo_3D ex:compuestoPor ex:Punto_T .