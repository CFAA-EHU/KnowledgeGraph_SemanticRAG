@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Sistema de dos ejes con motor único (Ejemplo 2)
ex:SistemaMultieje_Ejemplo2
    a ex:Sistema ;
    rdfs:label "Sistema con dos ejes y un único motor (Ejemplo 2)" ;
    ex:textoExtracto "Disposición en la que un único motor alimenta mecánicamente A1 y A2; ambos ejes usan captación directa a módulos remotos diferentes (1 y 2)." ;
    ex:tieneComponente ex:Motor_Ejemplo2, ex:Eje_A1, ex:Eje_A2 ;
    ex:compuestoPor ex:ModuloRemoto_1, ex:ModuloRemoto_2 ;
    ex:detalladoEnEsquema ex:Esquema_ReguladorBusCAN_Ejemplo2 .

ex:Motor_Ejemplo2
    a ex:ComponenteMecanico ;
    rdfs:label "Motor del sistema multieje (Ejemplo 2)" ;
    ex:textoExtracto "un único motor alimenta mecánicamente A1 y A2" ;
    ex:alimenta ex:Eje_A1, ex:Eje_A2 .

ex:Eje_A1
    a ex:ComponenteMecanico ;
    rdfs:label "Eje A1" ;
    ex:textoExtracto "A1" ;
    ex:monitoreaParametro ex:Parametro_Posicion_A1 .

ex:Eje_A2
    a ex:ComponenteMecanico ;
    rdfs:label "Eje A2" ;
    ex:textoExtracto "A2" ;
    ex:monitoreaParametro ex:Parametro_Posicion_A2 .

ex:ModuloRemoto_1
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo remoto 1" ;
    ex:textoExtracto "módulos remotos diferentes (1)" .

ex:ModuloRemoto_2
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo remoto 2" ;
    ex:textoExtracto "módulos remotos diferentes (2)" .

ex:Esquema_ReguladorBusCAN_Ejemplo2
    a ex:Esquema ;
    rdfs:label "Esquema de regulador, bus CAN y contadoras (Ejemplo 2)" ;
    ex:textoExtracto "Se representan los bloques de regulador, bus CAN y contadoras." ;
    ex:ilustradoEn ex:SistemaMultieje_Ejemplo2 .

### Sistema de referencias del torno (OM, OW, H)
ex:SistemaReferencias_Torno
    a ex:Sistema ;
    rdfs:label "Sistema de referencias del torno (OM, OW, H)" ;
    ex:textoExtracto "Dibujo esquemático de un torno que define cero máquina (OM), cero pieza (OW) y punto de referencia H, con cotas XMH/ZMH y XMW/ZMW; flechas y ejes X-Z situan geometría de referencia respecto a la torreta." ;
    ex:detalladoEnEsquema ex:Esquema_ReferenciasTorno_Vista1, ex:Esquema_ReferenciasTorno_Vista2 .

ex:Esquema_ReferenciasTorno_Vista1
    a ex:Esquema ;
    rdfs:label "Vista lateral de referencias del torno (OM, OW, H)" ;
    ex:textoExtracto "Dibujo esquemático de un torno que define cero máquina (OM), cero pieza (OW) y punto de referencia H, con cotas XMH/ZMH y XMW/ZMW; flechas y ejes X-Z situan geometría de referencia respecto a la torreta." ;
    ex:ilustradoEn ex:SistemaReferencias_Torno .

ex:Esquema_ReferenciasTorno_Vista2
    a ex:Esquema ;
    rdfs:label "Vista frontal/planta de referencias del torno (OM, OW, H)" ;
    ex:textoExtracto "Segunda vista del mismo concepto de referencias (vista frontal/planta), con ejes X y Z y la localización de OM, OW, H; se remarcan distancias XMH, ZMH, ZMW y el desplazamiento relativo entre puntos de referencia y ceros." ;
    ex:ilustradoEn ex:SistemaReferencias_Torno .

ex:Parametro_XMH
    a ex:Parametro ;
    rdfs:label "Cota XMH" ;
    ex:textoExtracto "cotas XMH/ZMH" ;
    ex:valor "XMH" .

ex:Parametro_ZMH
    a ex:Parametro ;
    rdfs:label "Cota ZMH" ;
    ex:textoExtracto "cotas XMH/ZMH" ;
    ex:valor "ZMH" .

ex:Parametro_XMW
    a ex:Parametro ;
    rdfs:label "Cota XMW" ;
    ex:textoExtracto "XMW/ZMW" ;
    ex:valor "XMW" .

ex:Parametro_ZMW
    a ex:Parametro ;
    rdfs:label "Cota ZMW" ;
    ex:textoExtracto "XMW/ZMW" ;
    ex:valor "ZMW" .

### Cronograma de referenciado (Mechatrolink)
ex:Cronograma_ReferenciadoMechatrolink
    a ex:Esquema ;
    rdfs:label "Cronograma de señales durante búsqueda de referencia (Mechatrolink)" ;
    ex:textoExtracto "Cronograma de señales durante la búsqueda: perfiles de velocidad (REFFEED1) y aproximaciones, pulsos de micro y de I0; se indican fases 1–4 mediante marcas temporales y niveles lógicos que guían la secuencia de referenciado." ;
    ex:documentadoEn ex:SistemaReferencias_Torno .

ex:Parametro_REFFEED1
    a ex:Parametro ;
    rdfs:label "Perfil de velocidad REFFEED1" ;
    ex:textoExtracto "perfiles de velocidad (REFFEED1)" ;
    ex:valor "REFFEED1" .

### Límites de software y volumen de trabajo
ex:Esquema_LimitesSoftwareVolumenTrabajo
    a ex:Esquema ;
    rdfs:label "Volumen de trabajo con límites físicos (FL) y de software (SL)" ;
    ex:textoExtracto "Ilustración 3D del volumen de trabajo con límites físicos (FL) y límites de software (SL) para X-Y-Z; el punto T (portaherramientas) se relaciona con OM y se sombrean regiones válidas/inválidas para posiciones programables según herramienta activa." ;
    ex:ilustradoEn ex:SistemaReferencias_Torno .

ex:Parametro_FL_X
    a ex:Parametro ;
    rdfs:label "Límite físico en eje X (FL)" ;
    ex:textoExtracto "límites físicos (FL) para X-Y-Z" ;
    ex:valor "FL_X" .

ex:Parametro_SL_X
    a ex:Parametro ;
    rdfs:label "Límite de software en eje X (SL)" ;
    ex:textoExtracto "límites de software (SL) para X-Y-Z" ;
    ex:valor "SL_X" .

ex:Punto_T_Portaherramientas
    a ex:ComponenteMecanico ;
    rdfs:label "Punto T (portaherramientas)" ;
    ex:textoExtracto "el punto T (portaherramientas) se relaciona con OM" .