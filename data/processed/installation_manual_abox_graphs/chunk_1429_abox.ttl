@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IndicaSiElCNCDebeAnularElErrorDeGapFueraDeTolerancia a ns1:Parametro ;
    rdfs:label "Indica si el CNC debe anular el error de gap fuera de tolerancia" ;
    ns1:textoExtracto "GAPTOLCANCEL | Este parámetro indica si el CNC debe anular el error de gap fuera de tolerancia, cuando el gap supera el margen definido en el parámetro GAPTOL." .

ns1:IndicaSiElCNCDebeAnularElErrorDeGapFueraDelRango a ns1:Parametro ;
    rdfs:label "Indica si el CNC debe anular el error de gap fuera del rango" ;
    ns1:textoExtracto "GAPERRORCANCEL | Este parámetro indica si el CNC debe anular el error de gap fuera del rango, cuando el gap sobrepasa el rango GAPMIN - GAPMAX." .

ns1:MaximoValorPermitidoParaElGap a ns1:Parametro ;
    rdfs:label "Máximo valor permitido para el gap" ;
    ns1:textoExtracto "GAPMAX | Máximo valor permitido para el gap; por encima de este valor, el CNC mostrará o no un error según lo definido en el parámetro GAPERRORCANCEL. Este parámetro debe ser inferior a GAPDISTLIMIT." .

ns1:MinimoValorPermitidoParaElGap a ns1:Parametro ;
    rdfs:label "Mínimo valor permitido para el gap" ;
    ns1:textoExtracto "GAPMIN | Mínimo valor permitido para el gap; por debajo de este valor, el CNC mostrará o no un error según lo definido en el parámetro GAPERRORCANCEL." .

ns1:VentanaDePosicionamientoSobreElGapProgramado a ns1:Parametro ;
    rdfs:label "Ventana de posicionamiento sobre el gap programado" ;
    ns1:textoExtracto "GAPTOL | Este parámetro define una ventana de posicionamiento, sobre el gap programado, para dar por finalizado el bloque de aproximación." .

