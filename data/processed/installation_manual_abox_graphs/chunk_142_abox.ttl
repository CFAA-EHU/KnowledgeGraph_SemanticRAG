@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Parametro_PLCDATASIZE
    a               ex:Parametro ;
    rdfs:label      "PLCDATASIZE" ;
    ex:identificador "V.MPG.PLCDATASIZE" ;
    ex:valor         "0"^^xsd:integer ;
    ex:textoExtracto "PLCDATASIZE Tamaño de la zona de datos compartida del PLC. Valores posibles: De 0 a 500.000 bytes. Valor por defecto: 0. Variable asociada: (V.)MPG.PLCDATASIZE"@es ;
    ex:textoExtracto "Este parámetro permite definir un área de memoria para intercambiar datos entre un programa PLC escrito en lenguaje C y una aplicación externa."@es .

ex:Sistema_HBH3_HBH4
    a               ex:Sistema ;
    rdfs:label      "Terminal remoto HBH3/HBH4" ;
    ex:textoExtracto "El terminal remoto HBH3/HBH4 necesita un tamaño de memoria de 4096 bytes."@es .