@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioDeSignoDeLaSenalDelSensor a ns1:Parametro ;
    rdfs:label "Cambio de signo de la señal del sensor" ;
    ns1:identificador "GAPSENSORCH" ;
    ns1:textoExtracto "Cambiar el signo de la señal del sensor." .

ns1:DistanciaQueCorrespondeALaSenalAnalogicaLimiteDelSensor a ns1:Parametro ;
    rdfs:label "Distancia que corresponde a la señal analógica límite del sensor" ;
    ns1:identificador "GAPDISTLIMIT" ;
    ns1:textoExtracto "Distancia que corresponde a señal analógica límite del sensor (parámetro GAPVOLTLIMIT)." .

ns1:IdentificadorDeLaEntradaAnalogicaDondeEstaConectadoElSensor a ns1:Parametro ;
    rdfs:label "Identificador de la entrada analógica donde está conectado el sensor" ;
    ns1:identificador "GAPANAINID" ;
    ns1:textoExtracto "Este parámetro identifica la entrada analógica donde está conectado el sensor; si remoto CAN, de 1 a 60; si regulador, de 101 a 132 o de 201 a 232." .

ns1:IndicadorDeUbicacionDeLaEntradaAnalogicaConectadaAlSensor a ns1:Parametro ;
    rdfs:label "Indicador de ubicación de la entrada analógica conectada al sensor" ;
    ns1:identificador "GAPANAINTYPE" ;
    ns1:textoExtracto "Este parámetro indica dónde está ubicada la entrada analógica conectada al sensor; en los módulos remotos CAN o en un regulador Sercos." .

ns1:OffsetEnMilivoltiosAAplicarAlSensorDesdeElCNC a ns1:Parametro ;
    rdfs:label "Offset (en milivoltios) a aplicar al sensor desde el CNC" ;
    ns1:identificador "GAPSENSOROFFSET" ;
    ns1:textoExtracto "Offset (en milivoltios) a aplicar al sensor desde el CNC. Si se utiliza una entrada analógica Fagor, no es necesario definir este parámetro." .

ns1:VoltajeEnMilivoltiosQueCorrespondeAlRecorridoLimiteDelSensor a ns1:Parametro ;
    rdfs:label "Voltaje (en milivoltios) que corresponde al recorrido límite del sensor" ;
    ns1:identificador "GAPVOLTLIMIT" ;
    ns1:textoExtracto "Voltaje (en milivoltios) que corresponde al recorrido límite del sensor (parámetro GAPDISTLIMIT)." .

