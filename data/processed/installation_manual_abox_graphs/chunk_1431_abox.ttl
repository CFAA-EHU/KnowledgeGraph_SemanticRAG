@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ElSensorParaElControlDelGapPuedeDisponerDeUnaSenalDeColisionQueSeCone_04a129f3e3 a ns1:Parametro ;
    rdfs:label "El sensor para el control del gap puede disponer de una señal de colisión que se conecta al CNC, y que el PLC la debe gestionar a través de la marca GAPCOLLISION" ;
    ns1:identificador "GAPCOLLISIONMODE" ;
    ns1:textoExtracto "GAPCOLLISIONMODE | El sensor para el control del gap puede disponer de una señal de colisión que se conecta al CNC, y que el PLC la debe gestionar a través de la marca GAPCOLLISION." .

ns1:Parametro_11eba8d84a a ns1:Parametro ;
    rdfs:label "Marca que gestiona la señal de colisión del sensor del gap" ;
    ns1:identificador "GAPCOLLISION" ;
    ns1:textoExtracto "Si el PLC activa la marca GAPCOLLISION, el CNC mostrará o no un error según lo definido en este parámetro." .

