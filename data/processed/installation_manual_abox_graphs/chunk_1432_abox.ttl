@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Esquema3D_Paso3 a ex:Esquema ;
    rdfs:label "Esquema 3D (Paso 3)" ;
    ex:textoExtracto "Esquema 3D (Paso 3) del plano XY con el patrón de relleno completo en X para cada fila Y(Pn). Se resaltan los contadores NPOINTSAX1 y NPOINTSAX2 y cómo se genera la lista ordenada de puntos antes de subir de cota Z." ;
    ex:tieneComponente ex:Contador_NPOINTSAX1, ex:Contador_NPOINTSAX2 .

ex:Contador_NPOINTSAX1 a ex:Sensor ;
    rdfs:label "NPOINTSAX1" ;
    ex:identificador "NPOINTSAX1" ;
    ex:textoExtracto "Se resaltan los contadores NPOINTSAX1 y NPOINTSAX2" .

ex:Contador_NPOINTSAX2 a ex:Sensor ;
    rdfs:label "NPOINTSAX2" ;
    ex:identificador "NPOINTSAX2" ;
    ex:textoExtracto "Se resaltan los contadores NPOINTSAX1 y NPOINTSAX2" .

ex:Esquema3D_Paso4 a ex:Esquema ;
    rdfs:label "Esquema 3D (Paso 4)" ;
    ex:textoExtracto "Esquema 3D (Paso 4) que inicia el segundo nivel Z(P2): desde X(P1), Y(P1), Z(P2) se repite el barrido en X e Y. Flechas y etiquetas Z(P2) señalan el cambio de cota y la replicación del patrón del primer plano." ;
    ex:tieneComponente ex:Etiqueta_ZP2 .

ex:Etiqueta_ZP2 a ex:Sensor ;
    rdfs:label "Z(P2)" ;
    ex:identificador "Z(P2)" ;
    ex:textoExtracto "Flechas y etiquetas Z(P2) señalan el cambio de cota y la replicación del patrón del primer plano." .

ex:Esquema3D_Paso5 a ex:Esquema ;
    rdfs:label "Esquema 3D (Paso 5)" ;
    ex:textoExtracto "Esquema 3D (Paso 5) mostrando varios planos intermedios Z con la malla de puntos y las rutas de avance. La representación enfatiza la construcción volumétrica por capas, manteniendo los incrementos definidos para cada eje." ;
    ex:tieneComponente ex:MallaPuntos, ex:RutaAvance .

ex:MallaPuntos a ex:Sensor ;
    rdfs:label "Malla de puntos" ;
    ex:textoExtracto "mostrando varios planos intermedios Z con la malla de puntos" .

ex:RutaAvance a ex:Sensor ;
    rdfs:label "Ruta de avance" ;
    ex:textoExtracto "mostrando varios planos intermedios Z con la malla de puntos y las rutas de avance" .

ex:Esquema3D_Paso6 a ex:Esquema ;
    rdfs:label "Esquema 3D (Paso 6)" ;
    ex:textoExtracto "Esquema 3D (Paso 6) del volumen totalmente relleno hasta Z(Pn). Se observan todas las capas Z apiladas, el patrón de serpenteo por planos y la malla completa que sustenta la interpolación de errores dentro del volumen." ;
    ex:tieneComponente ex:CapaZ, ex:PatronSerpenteo, ex:MallaCompleta .

ex:CapaZ a ex:Sensor ;
    rdfs:label "Capa Z" ;
    ex:textoExtracto "todas las capas Z apiladas" .

ex:PatronSerpenteo a ex:Sensor ;
    rdfs:label "Patrón de serpenteo" ;
    ex:textoExtracto "el patrón de serpenteo por planos" .

ex:MallaCompleta a ex:Sensor ;
    rdfs:label "Malla completa" ;
    ex:textoExtracto "la malla completa que sustenta la interpolación de errores dentro del volumen" .