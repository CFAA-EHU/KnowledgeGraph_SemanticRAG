@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AjustarElValorDeGAPGAINDuranteLaParteFinalDeAproximacionALaChapa a ns1:Parametro ;
    rdfs:label "ajustar el valor de GAPGAIN durante la parte final de aproximación a la chapa" ;
    ns1:identificador "GAPAPPROACHDYN" ;
    ns1:textoExtracto "Utilizar el parámetro GAPAPPROACHDYN para ajustar el valor de GAPGAIN durante la parte final de aproximación a la chapa, cuando el CNC ha detectado la señal del sensor." .

ns1:CompensacionQueIntroduceElControlDelGapEnElEjeAsociadoAlSensorParaMantenerElGap a ns1:Parametro ;
    rdfs:label "Compensación que introduce el control del gap en el eje asociado al sensor para mantener el gap" ;
    ns1:identificador "A.GAPCOMP.Z" ;
    ns1:textoExtracto "V.)A.GAPCOMP.Z Compensación que introduce el control del gap en el eje asociado al sensor para mantener el gap." .

ns1:FrecuenciaDelFiltro a ns1:Parametro ;
    rdfs:label "frecuencia del filtro" ;
    ns1:identificador "FREQUENCY" ;
    ns1:textoExtracto "Reducir la frecuencia del filtro (parámetro máquina FREQUENCY) para obtener una respuesta más suave." .

ns1:GananciaProporcional_d4b2cf44e2 a ns1:Parametro ;
    rdfs:label "ganancia proporcional" ;
    ns1:identificador "GAPGAIN" ;
    ns1:textoExtracto "Intentar reducir el gap (variable G.GAP) incrementando la ganancia proporcional (parámetro GAPGAIN)." .

ns1:ValorRealDelGapDetectadoPorElSensor a ns1:Parametro ;
    rdfs:label "Valor real del gap, detectado por el sensor" ;
    ns1:identificador "G.GAP" ;
    ns1:textoExtracto "V.)G.GAP Valor real del gap, detectado por el sensor." .

