@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:FILTER a ex:ComponenteElectrico ;
    ex:textoExtracto "Diagrama de bloques del lazo de control del CNC que encadena SLOPE, INTERPOLATOR, TRANSFOR y FILTER, seguido de la entrada al lazo de posición." .

ex:SLOPE a ex:ComponenteElectrico ;
    ex:textoExtracto "Diagrama de bloques del lazo de control del CNC que encadena SLOPE, INTERPOLATOR, TRANSFOR y FILTER, seguido de la entrada al lazo de posición." .

ex:INTERPOLATOR a ex:ComponenteElectrico ;
    ex:textoExtracto "Diagrama de bloques del lazo de control del CNC que encadena SLOPE, INTERPOLATOR, TRANSFOR y FILTER, seguido de la entrada al lazo de posición." .

ex:TRANSFOR a ex:ComponenteElectrico ;
    ex:textoExtracto "Diagrama de bloques del lazo de control del CNC que encadena SLOPE, INTERPOLATOR, TRANSFOR y FILTER, seguido de la entrada al lazo de posición." .

ex:COMP a ex:ComponenteElectrico ;
    ex:textoExtracto "Diagrama de bloques del lazo de control del CNC que encadena SLOPE, INTERPOLATOR, TRANSFOR y FILTER, seguido de la entrada al lazo de posición. Incluye sumadores/compensadores (COMP, DELTA)" .

ex:DELTA a ex:ComponenteElectrico ;
    ex:textoExtracto "Diagrama de bloques del lazo de control del CNC que encadena SLOPE, INTERPOLATOR, TRANSFOR y FILTER, seguido de la entrada al lazo de posición. Incluye sumadores/compensadores (COMP, DELTA)" .

ex:RESETIN a ex:Sensor ;
    ex:textoExtracto "Diagrama temporal del proceso de reset con dos trazas digitales (RESETIN y RESETOUT) y la ventana MINAENDW marcada sobre RESETOUT." .

ex:RESETOUT a ex:Sensor ;
    ex:textoExtracto "Diagrama temporal del proceso de reset con dos trazas digitales (RESETIN y RESETOUT) y la ventana MINAENDW marcada sobre RESETOUT." .

ex:PROGRAM_RESET a ex:TareaMantenimiento ;
    ex:textoExtracto "Diagrama temporal del proceso de reset con dos trazas digitales (RESETIN y RESETOUT) y la ventana MINAENDW marcada sobre RESETOUT. La línea de tiempo (t) indica cuatro hitos numerados: activación de RESETIN, tiempo para asumir condiciones iniciales, activación de RESETOUT y final de reset, tras lo cual se ejecuta la subrutina PROGRAM_RESET." .

ex:Address_0 a ex:ComponenteElectrico ;
    ex:identificador "Address=0" ;
    ex:textoExtracto "Diagrama del bus CAN que ilustra la numeración y orden de los paneles de mando y grupos de E/S remotas. Se muestran iconos del CNC (Address=0), módulos de E/S remotas (Address=1,3,4) y dos 'Jog-Panel' (Address=2 y 5), dispuestos en un esquema lineal del bus." .

