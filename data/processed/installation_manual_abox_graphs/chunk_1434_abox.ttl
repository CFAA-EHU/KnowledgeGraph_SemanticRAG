ex:Manual_OPENPCS_15_1
    a ex:Manual ;
    rdfs:label "Sección 15.1: Gestión de varios teclados" ;
    ex:textoExtracto "Sección: 15.1 Gestión de varios teclados." .

ex:Manual_OPENPCS_15_4
    a ex:Manual ;
    rdfs:label "Sección 15.4: Módulo remoto RCS-S" ;
    ex:textoExtracto "Sección: 15.4 Módulo remoto RCS-S." .