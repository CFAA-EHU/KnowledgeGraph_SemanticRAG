@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_4750fdaabf a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC activa esta marca si el gap está dentro del rango definido por los parámetros GAPMIN-GAPMAX." .

ns1:Parametro_4e1aade0f9 a ns1:Parametro ;
    rdfs:label "Parámetro que controla si se muestra un error cuando el eje sobrepasa la tolerancia del gap" ;
    ns1:textoExtracto "según lo definido en el parámetro GAPTOLCANCEL." .

ns1:Parametro_6fcc0ffdd0 a ns1:Parametro ;
    rdfs:label "Parámetro que define el límite inferior del gap",
        "Parámetro que define el límite superior del gap" ;
    ns1:textoExtracto "los parámetros GAPMIN-GAPMAX." .

ns1:Parametro_fbd61d0eae a ns1:Parametro ;
    rdfs:label "Parámetro que controla si se muestra un error cuando el gap está fuera de rango" ;
    ns1:textoExtracto "según lo definido en el parámetro GAPERRORCANCEL." .

ns1:Parametro_fcbddc4855 a ns1:Parametro ;
    rdfs:label "Parámetro que define la tolerancia del gap" ;
    ns1:textoExtracto "definida por el parámetro GAPTOL." .

