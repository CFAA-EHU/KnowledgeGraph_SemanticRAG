@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Esquema1434_1 a ex:Esquema ;
    ex:textoExtracto "Se muestran iconos del CNC (Address=0), módulos de E/S remotas (Address=1,3,4) y dos 'Jog-Panel' (Address=2 y 5), dispuestos en un esquema lineal del bus." ;
    ex:tieneComponente ex:CNC_Address0, ex:ModuloE_S_Address1, ex:ModuloE_S_Address3, ex:ModuloE_S_Address4, ex:JogPanel_Address2, ex:JogPanel_Address5 .

ex:CNC_Address0 a ex:ComponenteElectrico ;
    ex:identificador "Address=0" ;
    ex:textoExtracto "Se muestran iconos del CNC (Address=0)" .

ex:ModuloE_S_Address1 a ex:ComponenteElectrico ;
    ex:identificador "Address=1" ;
    ex:textoExtracto "módulos de E/S remotas (Address=1,3,4)" .

ex:ModuloE_S_Address3 a ex:ComponenteElectrico ;
    ex:identificador "Address=3" ;
    ex:textoExtracto "módulos de E/S remotas (Address=1,3,4)" .

ex:ModuloE_S_Address4 a ex:ComponenteElectrico ;
    ex:identificador "Address=4" ;
    ex:textoExtracto "módulos de E/S remotas (Address=1,3,4)" .

ex:JogPanel_Address2 a ex:InterfazUsuario ;
    ex:identificador "Address=2" ;
    ex:textoExtracto "dos 'Jog-Panel' (Address=2 y 5)" .

ex:JogPanel_Address5 a ex:InterfazUsuario ;
    ex:identificador "Address=5" ;
    ex:textoExtracto "dos 'Jog-Panel' (Address=2 y 5)" .

ex:Esquema1434_2 a ex:Esquema ;
    ex:textoExtracto "Ilustración del teclado de jog con distribución de teclas numeradas (1–15) y ejemplo de mapeo de funciones para ejes y sentidos de desplazamiento (p. ej., X+, 7+)." ;
    ex:ilustradoEn ex:TecladoJog_Ilustracion .

ex:TecladoJog_Ilustracion a ex:InterfazUsuario ;
    ex:textoExtracto "Ilustración del teclado de jog con distribución de teclas numeradas (1–15) y ejemplo de mapeo de funciones para ejes y sentidos de desplazamiento (p. ej., X+, 7+)." .

ex:TeclaJog_1 a ex:ComponenteElectrico ;
    ex:identificador "1" ;
    ex:textoExtracto "distribución de teclas numeradas (1–15)" .

ex:TeclaJog_7 a ex:ComponenteElectrico ;
    ex:identificador "7" ;
    ex:textoExtracto "distribución de teclas numeradas (1–15)" .

ex:Esquema1434_3 a ex:Esquema ;
    ex:textoExtracto "Esquema compacto de 'Teclas de usuario' tratadas como teclas de jog. Se representa una banda de teclas numeradas (1, 2, …, 15, 16) bajo la leyenda 'JOGKEYS'" ;
    ex:tieneComponente ex:TeclaJog_16 .

ex:TeclaJog_16 a ex:ComponenteElectrico ;
    ex:identificador "16" ;
    ex:textoExtracto "banda de teclas numeradas (1, 2, …, 15, 16)" .

ex:ModuloRCS_S_4F4AO a ex:ComponenteElectrico ;
    ex:identificador "RCS-S-4F4AO" ;
    ex:textoExtracto "Vista frontal del módulo RCS-S-4F4AO con llamadas (callouts) a conectores y recursos: cuatro entradas de contaje (E21A–E21D) compatibles con TTL/TTL diferencial/Vpp y protocolos SSI/FeeDat/EnDat 2.1/2.2, y cuatro salidas analógicas ±10 V de 16 bits (I37A/I37B)." .

ex:EntradaConteo_E21A a ex:ComponenteElectrico ;
    ex:identificador "E21A" ;
    ex:textoExtracto "cuatro entradas de contaje (E21A–E21D)" .

ex:EntradaConteo_E21D a ex:ComponenteElectrico ;
    ex:identificador "E21D" ;
    ex:textoExtracto "cuatro entradas de contaje (E21A–E21D)" .

ex:SalidaAnalogica_I37A a ex:ComponenteElectrico ;
    ex:identificador "I37A" ;
    ex:textoExtracto "cuatro salidas analógicas ±10 V de 16 bits (I37A/I37B)" .

ex:SalidaAnalogica_I37B a ex:ComponenteElectrico ;
    ex:textoExtracto "cuatro salidas analógicas ±10 V de 16 bits (I37A/I37B)" .