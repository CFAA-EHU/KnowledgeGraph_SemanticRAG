ex:Esquema_RIO5_Grupo1
    a ex:Esquema ;
    rdfs:label "Esquema RIO5 Grupo 1 (24ED/16SD)" ;
    ex:textoExtracto "Imagen 'Grupo 1': conjunto RIO5 con 24 entradas digitales y 16 salidas digitales. Se muestran bastidores con conectores X1–X8 y leyendas de borneado (+24 V, GND), enfatizando el formato de módulo y su rol como bloque lógico único." ;
    ex:identificador "RIO5_Grupo1_24ED_16SD" .

ex:Modulo_RIO5_Grupo1
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo RIO5 Grupo 1 (24ED/16SD)" ;
    ex:textoExtracto "conjunto RIO5 con 24 entradas digitales y 16 salidas digitales [...] formato de módulo y su rol como bloque lógico único" ;
    ex:identificador "RIO5_24ED_16SD" ;
    ex:detalladoEnEsquema ex:Esquema_RIO5_Grupo1 ;
    ex:tieneComponente ex:Conector_RIO5_X1, ex:Conector_RIO5_X2, ex:Conector_RIO5_X3, ex:Conector_RIO5_X4, ex:Conector_RIO5_X5, ex:Conector_RIO5_X6, ex:Conector_RIO5_X7, ex:Conector_RIO5_X8 .

