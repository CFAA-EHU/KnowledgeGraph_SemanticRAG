ns1:Parametro_edf4761f39 a ns1:Parametro ;
    rdfs:label "Marca que detiene la ejecución del programa pieza" ;
    ns1:documentadoEn ns1:CNC8070_eb1fa9310c ;
    ns1:identificador "_STOP" ;
    ns1:textoExtracto "Si el PLC pone esta marca a nivel lógico bajo, el canal del CNC detiene la ejecución del programa pieza." .

ns1:Parametro_f464a1f5d4 a ns1:Parametro ;
    rdfs:label "Marca que detiene temporalmente el avance de los ejes" ;
    ns1:documentadoEn ns1:CNC8070_eb1fa9310c ;
    ns1:identificador "_FEEDHOL" ;
    ns1:textoExtracto "Si el PLC pone esta marca a nivel lógico bajo, el canal del CNC detiene temporalmente el avance de los ejes." .

ns1:CNC8070_eb1fa9310c a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El texto se refiere al control numerico CNC 8070 (Fagor CNC 8070, el CNC, el control numerico)." .

