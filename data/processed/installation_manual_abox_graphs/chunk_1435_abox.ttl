@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SistemaSercos a ex:Sistema ;
    ex:textoExtracto "Esquema de interconexión del sistema Sercos con dos contadoras RCS-S (nodos 3 y 5) y tres reguladores AXD (nodos 1, 2 y 4). Se muestran bloques para ejes analógicos (X, Y, Z), ejes Sercos (U, V), un volante y un cabezal S, con líneas que conectan salidas analógicas (ANAOUT) y entradas de captación (E21A/B/C). Las etiquetas de nodo y de conector (p. ej., E21A/ANAOUT2) guían la asignación física y lógica." ;
    ex:tieneComponente ex:Nodo3, ex:Nodo5, ex:Nodo1, ex:Nodo2, ex:Nodo4, ex:EjeX, ex:EjeY, ex:EjeZ, ex:EjeU, ex:EjeV, ex:Volante, ex:CabezalS, ex:SalidaAnalogicaANAOUT, ex:EntradaCaptacionE21A, ex:EntradaCaptacionE21B, ex:EntradaCaptacionE21C .

ex:Nodo3 a ex:ComponenteElectrico ;
    ex:identificador "3" ;
    ex:textoExtracto "dos contadoras RCS-S (nodos 3 y 5)" .

ex:Nodo5 a ex:ComponenteElectrico ;
    ex:identificador "5" ;
    ex:textoExtracto "dos contadoras RCS-S (nodos 3 y 5)" .

ex:Nodo1 a ex:ComponenteElectrico ;
    ex:identificador "1" ;
    ex:textoExtracto "tres reguladores AXD (nodos 1, 2 y 4)" .

ex:Nodo2 a ex:ComponenteElectrico ;
    ex:identificador "2" ;
    ex:textoExtracto "tres reguladores AXD (nodos 1, 2 y 4)" .

ex:Nodo4 a ex:ComponenteElectrico ;
    ex:identificador "4" ;
    ex:textoExtracto "tres reguladores AXD (nodos 1, 2 y 4)" .

ex:EjeX a ex:ComponenteElectrico ;
    ex:identificador "X" ;
    ex:textoExtracto "bloques para ejes analógicos (X, Y, Z)" .

ex:EjeY a ex:ComponenteElectrico ;
    ex:identificador "Y" ;
    ex:textoExtracto "bloques para ejes analógicos (X, Y, Z)" .

ex:EjeZ a ex:ComponenteElectrico ;
    ex:identificador "Z" ;
    ex:textoExtracto "bloques para ejes analógicos (X, Y, Z)" .

ex:EjeU a ex:ComponenteElectrico ;
    ex:identificador "U" ;
    ex:textoExtracto "ejes Sercos (U, V)" .

ex:EjeV a ex:ComponenteElectrico ;
    ex:identificador "V" ;
    ex:textoExtracto "ejes Sercos (U, V)" .

ex:Volante a ex:ComponenteElectrico ;
    ex:textoExtracto "un volante" .

ex:CabezalS a ex:ComponenteElectrico ;
    ex:textoExtracto "un cabezal S" .

ex:SalidaAnalogicaANAOUT a ex:ComponenteElectrico ;
    ex:identificador "ANAOUT" ;
    ex:textoExtracto "líneas que conectan salidas analógicas (ANAOUT)" .

ex:EntradaCaptacionE21A a ex:ComponenteElectrico ;
    ex:identificador "E21A" ;
    ex:textoExtracto "entradas de captación (E21A/B/C)" .

ex:EntradaCaptacionE21B a ex:ComponenteElectrico ;
    ex:identificador "E21B" ;
    ex:textoExtracto "entradas de captación (E21A/B/C)" .

ex:EntradaCaptacionE21C a ex:ComponenteElectrico ;
    ex:identificador "E21C" ;
    ex:textoExtracto "entradas de captación (E21A/B/C)" .

ex:Grupo1RIO5 a ex:Sistema ;
    ex:textoExtracto "Imagen 'Grupo 1': conjunto RIO5 con 24 entradas digitales y 16 salidas digitales. Se muestran bastidores con conectores X1–X8 y leyendas de borneado (+24 V, GND), enfatizando el formato de módulo y su rol como bloque lógico único." ;
    ex:tieneComponente ex:ConectorX1, ex:ConectorX2, ex:ConectorX3, ex:ConectorX4, ex:ConectorX5, ex:ConectorX6, ex:ConectorX7, ex:ConectorX8 .

ex:ConectorX1 a ex:ComponenteElectrico ;
    ex:identificador "X1" ;
    ex:textoExtracto "conectores X1–X8" .

ex:ConectorX2 a ex:ComponenteElectrico ;
    ex:identificador "X2" ;
    ex:textoExtracto "conectores X1–X8" .

ex:ConectorX3 a ex:ComponenteElectrico ;
    ex:identificador "X3" ;
    ex:textoExtracto "conectores X1–X8" .

ex:ConectorX4 a ex:ComponenteElectrico ;
    ex:identificador "X4" ;
    ex:textoExtracto "conectores X1–X8" .

ex:ConectorX5 a ex:ComponenteElectrico ;
    ex:identificador "X5" ;
    ex:textoExtracto "conectores X1–X8" .

ex:ConectorX6 a ex:ComponenteElectrico ;
    ex:identificador "X6" ;
    ex:textoExtracto "conectores X1–X8" .

ex:ConectorX7 a ex:ComponenteElectrico ;
    ex:identificador "X7" ;
    ex:textoExtracto "conectores X1–X8" .

ex:ConectorX8 a ex:ComponenteElectrico ;
    ex:identificador "X8" ;
    ex:textoExtracto "conectores X1–X8" .

ex:Grupo2RIO5 a ex:Sistema ;
    ex:textoExtracto "Imagen 'Grupo 2': bastidor RIO5 con 24+48 entradas y 16+32 salidas digitales. Los módulos apilados representan tres bloques lógicos de entradas y dos de salidas; se aprecian etiquetas de conectores y disposición modular repetitiva que ilustra la expansión." ;
    ex:tieneComponente ex:ModuloEntrada1Grupo2, ex:ModuloEntrada2Grupo2, ex:ModuloEntrada3Grupo2, ex:ModuloSalida1Grupo2, ex:ModuloSalida2Grupo2 .

ex:ModuloEntrada1Grupo2 a ex:ComponenteElectrico ;
    ex:textoExtracto "tres bloques lógicos de entradas" .

ex:ModuloEntrada2Grupo2 a ex:ComponenteElectrico ;
    ex:textoExtracto "tres bloques lógicos de entradas" .

ex:ModuloEntrada3Grupo2 a ex:ComponenteElectrico ;
    ex:textoExtracto "tres bloques lógicos de entradas" .

ex:ModuloSalida1Grupo2 a ex:ComponenteElectrico ;
    ex:textoExtracto "dos de salidas" .

ex:ModuloSalida2Grupo2 a ex:ComponenteElectrico ;
    ex:textoExtracto "dos de salidas" .

ex:Grupo3RIO5 a ex:Sistema ;
    ex:textoExtracto "Imagen 'Grupo 3': bastidor RIO5 con 24+24 entradas y 16+16 salidas digitales." .