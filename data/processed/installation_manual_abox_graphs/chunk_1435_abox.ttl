@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Esquema_Interconexion_Sercos_RCS_S_AXD
    a ex:Esquema ;
    rdfs:label "Esquema de interconexión Sercos con RCS-S y AXD" ;
    ex:textoExtracto "Esquema de interconexión del sistema Sercos con dos contadoras RCS-S (nodos 3 y 5) y tres reguladores AXD (nodos 1, 2 y 4). Se muestran bloques para ejes analógicos (X, Y, Z), ejes Sercos (U, V), un volante y un cabezal S, con líneas que conectan salidas analógicas (ANAOUT) y entradas de captación (E21A/B/C). Las etiquetas de nodo y de conector (p. ej., E21A/ANAOUT2) guían la asignación física y lógica." ;
    ex:identificador "15.5.1_Ejemplo_Interconexion_Sercos" .

ex:Sistema_Sercos_RCS_S_AXD
    a ex:Sistema ;
    rdfs:label "Sistema Sercos con contadoras RCS-S y reguladores AXD" ;
    ex:textoExtracto "sistema Sercos con dos contadoras RCS-S (nodos 3 y 5) y tres reguladores AXD (nodos 1, 2 y 4)" ;
    ex:detalladoEnEsquema ex:Esquema_Interconexion_Sercos_RCS_S_AXD ;
    ex:tieneComponente ex:Contadora_RCS_S_Nodo3, ex:Contadora_RCS_S_Nodo5, ex:Regulador_AXD_Nodo1, ex:Regulador_AXD_Nodo2, ex:Regulador_AXD_Nodo4 ;
    ex:tieneComponente ex:EjeAnalogico_X, ex:EjeAnalogico_Y, ex:EjeAnalogico_Z, ex:EjeSercos_U, ex:EjeSercos_V ;
    ex:tieneComponente ex:Volante, ex:Cabezal_S .

ex:Contadora_RCS_S_Nodo3
    a ex:ComponenteElectrico ;
    rdfs:label "Contadora RCS-S (nodo 3)" ;
    ex:textoExtracto "contadoras RCS-S (nodos 3 y 5)" ;
    ex:identificador "RCS-S_Nodo3" .

ex:Contadora_RCS_S_Nodo5
    a ex:ComponenteElectrico ;
    rdfs:label "Contadora RCS-S (nodo 5)" ;
    ex:textoExtracto "contadoras RCS-S (nodos 3 y 5)" ;
    ex:identificador "RCS-S_Nodo5" .

