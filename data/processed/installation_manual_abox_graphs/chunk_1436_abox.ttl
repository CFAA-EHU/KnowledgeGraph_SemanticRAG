@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_52680efbc9 a ns1:Parametro ;
    rdfs:label "marca ENABLEGAP" ;
    ns1:identificador "ENABLEGAP" ;
    ns1:textoExtracto "Marca activa por defecto. El PLC desactiva esta marca para deshabilitar" .

ns1:SenalSTOP a ns1:Parametro ;
    rdfs:label "señal STOP" ;
    ns1:identificador "STOP" ;
    ns1:textoExtracto "_STOP es similar al que recibe la tecla [STOP] del CNC." .

ns1:TeclaStopCNC a ns1:ComponenteElectrico ;
    rdfs:label "tecla [STOP]" ;
    ns1:textoExtracto "la tecla [STOP] del CNC" .

