@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Grupo3RIO5 a ex:Maquina ;
    rdfs:label "bastidor RIO5" ;
    ex:textoExtracto "Imagen 'Grupo 3': bastidor RIO5 con 24+24 entradas y 16+16 salidas digitales. El esquema visual refuerza la partición en dos bloques lógicos de entradas, mostrando la continuidad del cableado y las regletas de conexión." ;
    ex:tieneComponente ex:Nodo1RIOW, ex:Nodo2RIOW .

ex:Nodo1RIOW a ex:ComponenteElectrico ;
    rdfs:label "módulo RIOW con 16 entradas y 8 salidas" ;
    ex:textoExtracto "Imagen 'Nodo 1 (RIOW)': módulo RIOW con 16 entradas y 8 salidas. Se representan tarjetas con indicadores RUN/TX/RX y bloques 8DI/8DO, destacando la segmentación en bloques lógicos independientes (entradas/salidas) y su indexación inicial (I1/O81 en el ejemplo)." ;
    ex:compuestoPor ex:TarjetaRIOW1 .

ex:TarjetaRIOW1 a ex:ComponenteElectrico ;
    rdfs:label "tarjeta con indicadores RUN/TX/RX y bloques 8DI/8DO" ;
    ex:textoExtracto "Se representan tarjetas con indicadores RUN/TX/RX y bloques 8DI/8DO" .

ex:Nodo2RIOW a ex:ComponenteElectrico ;
    rdfs:label "módulo RIOW con 8 entradas y 8 salidas" ;
    ex:textoExtracto "Imagen 'Nodo 2 (RIOW)': módulo RIOW con 8 entradas y 8 salidas. El gráfico muestra bastidores más compactos 8DI y 8DO, con conectores y rotulación de canales, evidenciando su asignación a direcciones base no consecutivas para evitar solapamientos." ;
    ex:compuestoPor ex:TarjetaRIOW2 .

ex:TarjetaRIOW2 a ex:ComponenteElectrico ;
    rdfs:label "bastidor compacto 8DI y 8DO con conectores" ;
    ex:textoExtracto "El gráfico muestra bastidores más compactos 8DI y 8DO, con conectores y rotulación de canales" .

ex:Nodo1RIOR a ex:ComponenteElectrico ;
    rdfs:label "tarjeta RIOR con 48 entradas y 32 salidas digitales" ;
    ex:textoExtracto "Imagen 'Nodo 1 (RIOR)': tarjeta RIOR con 48 entradas y 32 salidas digitales. Se aprecia el formato de placa y conectividad, representando un único bloque lógico de 48 DI y uno de 32 DO, con mapeo desde las primeras direcciones (I1/O1)." ;
    ex:compuestoPor ex:TarjetaRIOR1 .

ex:TarjetaRIOR1 a ex:ComponenteElectrico ;
    rdfs:label "tarjeta RIOR con formato de placa y conectividad" ;
    ex:textoExtracto "Se aprecia el formato de placa y conectividad, representando un único bloque lógico de 48 DI y uno de 32 DO" .