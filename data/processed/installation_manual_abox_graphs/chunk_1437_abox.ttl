@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

### Nodos de E/S y sus componentes lógicos
ex:Nodo_RIOR
    a ex:ComponenteElectrico ;
    rdfs:label "Nodo 2 (RIOR)" ;
    ex:textoExtracto "tarjeta RIOR similar a la anterior, configurada como bloque de 48 entradas y 32 salidas con inicio en I97 y O81. La imagen enfatiza la equivalencia física con una numeración distinta por bloques lógicos." ;
    ex:identificador "I97-O81" .

ex:Nodo_RIO5
    a ex:ComponenteElectrico ;
    rdfs:label "Nodo 1 (RIO5)" ;
    ex:textoExtracto "chasis RIO5 con tres módulos de 24 entradas (24+48). Se muestran múltiples tarjetas 8DI agrupadas, con leyendas de conectores (X1–X8), velocidades y dirección, ilustrando la suma de bloques lógicos por módulo." ;
    ex:identificador "RIO5" .

ex:Nodo_RIOW
    a ex:ComponenteElectrico ;
    rdfs:label "Nodo 2 (RIOW)" ;
    ex:textoExtracto "bastidor RIOW con 64 entradas digitales, representado como dos bloques (24 y 40 entradas) iniciados en direcciones altas (I104 e I200)." ;
    ex:identificador "I104-I200" .

ex:Bloque_48DI_32DO
    a ex:Sistema ;
    rdfs:label "Bloque lógico de 48 DI y 32 DO (I1/O1)" ;
    ex:textoExtracto "un único bloque lógico de 48 DI y uno de 32 DO, con mapeo desde las primeras direcciones (I1/O1)." ;
    ex:identificador "I1/O1" .

### Interfaz de software
ex:Interfaz_LantekExpertInside
    a ex:InterfazUsuario ;
    rdfs:label "Lantek Expert Inside - Área de trabajo" ;
    ex:textoExtracto "Captura de interfaz de Lantek Expert Inside mostrando el área principal de trabajo con lista de piezas y opciones de importación (DXF/DWG/paramétricas). Se aprecian botones de acceso rápido y una disposición orientada a uso táctil para cargar figuras y configurar material, espesor y dimensiones de chapa." .

### Relaciones entre componentes y sistemas
ex:Nodo_RIOR
    ex:compuestoPor ex:Bloque_48DI_RIOR .
ex:Nodo_RIO5
    ex:compuestoPor ex:Modulo_24DI_1_RIO5 ,
                    ex:Modulo_24DI_2_RIO5 ,
                    ex:Modulo_24DI_3_RIO5 .
ex:Nodo_RIOW
    ex:compuestoPor ex:Bloque_24DI_RIOW ,
                    ex:Bloque_40DI_RIOW .

### Bloques lógicos específicos (inferidos de descripciones)
ex:Bloque_48DI_RIOR
    a ex:ComponenteElectrico ;
    rdfs:label "Bloque de 48 DI (Nodo RIOR, I97)" ;
    ex:textoExtracto "bloque de 48 entradas [...] con inicio en I97" ;
    ex:identificador "I97" .

ex:Modulo_24DI_1_RIO5
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo 24DI 1 (RIO5, conectores X1–X4)" ;
    ex:textoExtracto "tres módulos de 24 entradas (24+48). [...] tarjetas 8DI agrupadas, con leyendas de conectores (X1–X8)" ;
    ex:identificador "X1-X4" .

ex:Modulo_24DI_2_RIO5
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo 24DI 2 (RIO5, conectores X5–X8)" ;
    ex:textoExtracto "tarjetas 8DI agrupadas, con leyendas de conectores (X1–X8)" ;
    ex:identificador "X5-X8" .

ex:Modulo_24DI_3_RIO5
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo 24DI 3 (RIO5, extensión)" ;
    ex:textoExtracto "tres módulos de 24 entradas (24+48)" ;
    ex:identificador "24+48" .

ex:Bloque_24DI_RIOW
    a ex:ComponenteElectrico ;
    rdfs:label "Bloque 24 DI (RIOW, I104)" ;
    ex:textoExtracto "dos bloques (24 [...] entradas) iniciados en direcciones altas (I104)" ;
    ex:identificador "I104" .

ex:Bloque_40DI_RIOW
    a ex:ComponenteElectrico ;
    rdfs:label "Bloque 40 DI (RIOW, I200)" ;
    ex:textoExtracto "dos bloques ([...] 40 entradas) iniciados en [...] (I200)" ;
    ex:identificador "I200" .