@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_11eba8d84a a ns1:Parametro ;
    rdfs:label "Marca GAPCOLLISION del PLC" ;
    ns1:identificador "GAPCOLLISION" ;
    ns1:textoExtracto "El PLC activa esta marca para indicar que se ha activado el sensor de colisión. Esta marca no se memoriza." .

ns1:Parametro_52680efbc9 a ns1:Parametro ;
    rdfs:label "Marca ENABLEGAP del PLC" ;
    ns1:identificador "ENABLEGAP" ;
    ns1:textoExtracto "El PLC desactiva esta marca para deshabilitar el control del gap activo. El PLC activa esta marca para habilitar el control del gap activo en el CNC; si no hay un control del gap activo, esta marca no hace nada." .

ns1:Parametro_72ccf6aeef a ns1:Parametro ;
    rdfs:label "Parámetro GAPCOLLISIONMODE del CNC" ;
    ns1:identificador "GAPCOLLISIONMODE" ;
    ns1:textoExtracto "Con esta marca activa, el CNC mostrará o no un error según lo definido en el parámetro GAPCOLLISIONMODE." .

ns1:SenalSTOPDelCNC a ns1:Parametro ;
    rdfs:label "Señal STOP del CNC" ;
    ns1:identificador "STOP" ;
    ns1:textoExtracto "Con esta señal a nivel lógico bajo, todas las teclas permanecen habilitadas." .

