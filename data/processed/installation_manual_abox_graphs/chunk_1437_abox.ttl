@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PlacaConectividad rdfs:label "placa y conectividad" ;
    a ex:ComponenteElectrico ;
    ex:textoExtracto "Se aprecia el formato de placa y conectividad, representando un único bloque lógico de 48 DI y uno de 32 DO, con mapeo desde las primeras direcciones (I1/O1)." .

ex:BloqueLogico48DI rdfs:label "bloque lógico de 48 DI" ;
    a ex:ComponenteElectrico ;
    ex:textoExtracto "representando un único bloque lógico de 48 DI" .

ex:BloqueLogico32DO rdfs:label "bloque lógico de 32 DO" ;
    a ex:ComponenteElectrico ;
    ex:textoExtracto "uno de 32 DO" .

ex:Nodo2RIOR rdfs:label "Nodo 2 (RIOR)" ;
    a ex:ComponenteElectrico ;
    ex:textoExtracto "Imagen 'Nodo 2 (RIOR)': tarjeta RIOR similar a la anterior, configurada como bloque de 48 entradas y 32 salidas con inicio en I97 y O81." .

ex:Nodo1RIO5 rdfs:label "Nodo 1 (RIO5)" ;
    a ex:ComponenteElectrico ;
    ex:textoExtracto "Imagen 'Nodo 1 (RIO5)': chasis RIO5 con tres módulos de 24 entradas (24+48)." .

ex:Modulo24Entradas rdfs:label "módulo de 24 entradas" ;
    a ex:ComponenteElectrico ;
    ex:textoExtracto "chasis RIO5 con tres módulos de 24 entradas (24+48)" .

ex:Nodo2RIOW rdfs:label "Nodo 2 (RIOW)" ;
    a ex:ComponenteElectrico ;
    ex:textoExtracto "Imagen 'Nodo 2 (RIOW)': bastidor RIOW con 64 entradas digitales, representado como dos bloques (24 y 40 entradas) iniciados en direcciones altas (I104 e I200)." .

ex:Bloque24Entradas rdfs:label "bloque de 24 entradas" ;
    a ex:ComponenteElectrico ;
    ex:textoExtracto "representado como dos bloques (24 y 40 entradas)" .

ex:Bloque40Entradas rdfs:label "bloque de 40 entradas" ;
    a ex:ComponenteElectrico ;
    ex:textoExtracto "representado como dos bloques (24 y 40 entradas)" .

ex:InterfazLantekExpertInside rdfs:label "interfaz de Lantek Expert Inside" ;
    a ex:InterfazUsuario ;
    ex:textoExtracto "Captura de interfaz de Lantek Expert Inside mostrando el área principal de trabajo con lista de piezas y opciones de importación (DXF/DWG/paramétricas)." .