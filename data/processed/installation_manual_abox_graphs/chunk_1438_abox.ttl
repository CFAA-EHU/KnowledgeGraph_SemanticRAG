@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazUsuario_LantekExpertInside_Principal
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz principal de Lantek Expert Inside" ;
    ex:textoExtracto "Se aprecian botones de acceso rápido y una disposición orientada a uso táctil para cargar figuras y configurar material, espesor y dimensiones de chapa. --- Barra inferior de herramientas del entorno Lantek con iconografía de controles (abrir, guardar, simular, aceptar, deshacer) dispuesta en formato de grandes botones táctiles; sirve para facilitar acciones frecuentes a pie de máquina." .

ex:InterfazUsuario_LantekExpertInside_Anidado
    a ex:InterfazUsuario ;
    rdfs:label "Área de anidado de Lantek Expert Inside" ;
    ex:textoExtracto "Captura del área de anidado con piezas distribuidas manual o automáticamente sobre una chapa rectangular; se observan contornos, márgenes y la paleta de utilidades para gestión de lead-in/lead-out y microjuntas, con panel lateral de propiedades." .

ex:InterfazUsuario_LantekExpertInside_ConfiguracionTecnologica
    a ex:InterfazUsuario ;
    rdfs:label "Configuración tecnológica de Lantek Expert Inside" ;
    ex:textoExtracto "Captura de configuración tecnológica que destaca selección de puntos de entrada/salida, microjuntas y orden de corte. Incluye indicadores visuales de direccionalidad (flechas en trayectorias) y listas de parámetros para ajustar automáticamente o de forma manual." .

ex:InterfazUsuario_LantekExpertInside_Simulacion
    a ex:InterfazUsuario ;
    rdfs:label "Pantalla de simulación de Lantek Expert Inside" ;
    ex:textoExtracto "Pantalla de simulación previa con barra de controles para reproducir el recorrido, vista del trazado de corte y resumen para postprocesado Fagor; confirma la generación del programa pieza para el CNC tras verificación visual." .

ex:InterfazUsuario_LantekExpertInside_Idioma
    a ex:InterfazUsuario ;
    rdfs:label "Ventana de configuración de idioma de Lantek Expert Inside" ;
    ex:textoExtracto "Ventana de 'General/Idioma' de Lantek con menú desplegable para selección de idioma (en, es, fr, etc.)." .

ex:Parametro_LeadInLeadOut
    a ex:Parametro ;
    rdfs:label "Parámetro de lead-in/lead-out" ;
    ex:textoExtracto "paleta de utilidades para gestión de lead-in/lead-out y microjuntas" ;
    ex:monitoreaParametro ex:InterfazUsuario_LantekExpertInside_Anidado .

ex:Parametro_Microjuntas
    a ex:Parametro ;
    rdfs:label "Parámetro de microjuntas" ;
    ex:textoExtracto "paleta de utilidades para gestión de lead-in/lead-out y microjuntas" ;
    ex:monitoreaParametro ex:InterfazUsuario_LantekExpertInside_Anidado .

ex:Parametro_OrdenCorte
    a ex:Parametro ;
    rdfs:label "Parámetro de orden de corte" ;
    ex:textoExtracto "selección de puntos de entrada/salida, microjuntas y orden de corte" ;
    ex:monitoreaParametro ex:InterfazUsuario_LantekExpertInside_ConfiguracionTecnologica .

ex:Parametro_Idioma
    a ex:Parametro ;
    rdfs:label "Parámetro de selección de idioma" ;
    ex:textoExtracto "menú desplegable para selección de idioma (en, es, fr, etc.)" ;
    ex:monitoreaParametro ex:InterfazUsuario_LantekExpertInside_Idioma .