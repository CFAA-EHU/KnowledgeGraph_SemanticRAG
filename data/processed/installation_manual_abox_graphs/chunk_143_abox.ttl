@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_NLOCOUT
    a ex:Parametro ;
    rdfs:label "NLOCOUT" ;
    ex:textoExtracto "NLOCOUT Número de salidas digitales locales. Valores posibles: De 0 a 8. Valor por defecto: 0. Variable asociada: (V.)MPG.NLOCOUT" ;
    ex:valor "0-8" ;
    ex:identificador "MPG.NLOCOUT" .

ex:Parametro_EXPSCHK
    a ex:Parametro ;
    rdfs:label "EXPSCHK" ;
    ex:textoExtracto "EXPSCHK Activar la vigilancia de 24 V en las salidas digitales locales. Valores posibles: ON / OFF. Valor por defecto: ON. Variable asociada: (V.)MPG.EXPSCHK" ;
    ex:valor "ON/OFF" ;
    ex:identificador "MPG.EXPSCHK" .

ex:Sistema_EntradasSalidasLocales
    a ex:Sistema ;
    rdfs:label "Sistema de E/S locales LI/O1-LI/O8" ;
    ex:textoExtracto "La unidad central dispone de un conjunto de 8 señales digitales locales, identificadas como LI/O1 a LI/O8, que pueden configurarse tanto de entrada como de salida." ;
    ex:tieneComponente
        ex:ComponenteElectrico_LIO1 ,
        ex:ComponenteElectrico_LIO2 ,
        ex:ComponenteElectrico_LIO3 ,
        ex:ComponenteElectrico_LIO4 ,
        ex:ComponenteElectrico_LIO5 ,
        ex:ComponenteElectrico_LIO6 ,
        ex:ComponenteElectrico_LIO7 ,
        ex:ComponenteElectrico_LIO8 ;
    ex:controla ex:Parametro_NLOCOUT ;
    ex:monitoreaParametro ex:Parametro_EXPSCHK .

ex:ComponenteElectrico_LIO1
    a ex:ComponenteElectrico ;
    rdfs:label "LI/O1" ;
    ex:textoExtracto "señales digitales locales, identificadas como LI/O1 a LI/O8" .

ex:ComponenteElectrico_LIO2
    a ex:ComponenteElectrico ;
    rdfs:label "LI/O2" ;
    ex:textoExtracto "señales digitales locales, identificadas como LI/O1 a LI/O8" .

ex:ComponenteElectrico_LIO3
    a ex:ComponenteElectrico ;
    rdfs:label "LI/O3" ;
    ex:textoExtracto "señales digitales locales, identificadas como LI/O1 a LI/O8" .

ex:ComponenteElectrico_LIO4
    a ex:ComponenteElectrico ;
    rdfs:label "LI/O4" ;
    ex:textoExtracto "señales digitales locales, identificadas como LI/O1 a LI/O8" .

ex:ComponenteElectrico_LIO5
    a ex:ComponenteElectrico ;
    rdfs:label "LI/O5" ;
    ex:textoExtracto "señales digitales locales, identificadas como LI/O1 a LI/O8" .

ex:ComponenteElectrico_LIO6
    a ex:ComponenteElectrico ;
    rdfs:label "LI/O6" ;
    ex:textoExtracto "señales digitales locales, identificadas como LI/O1 a LI/O8" .

ex:ComponenteElectrico_LIO7
    a ex:ComponenteElectrico ;
    rdfs:label "LI/O7" ;
    ex:textoExtracto "señales digitales locales, identificadas como LI/O1 a LI/O8" .

ex:ComponenteElectrico_LIO8
    a ex:ComponenteElectrico ;
    rdfs:label "LI/O8" ;
    ex:textoExtracto "señales digitales locales, identificadas como LI/O1 a LI/O8" .

ex:Tabla_NumeracionLogicaPines a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Numeración lógica de pines LI/O1-LI/O8 según NLOCOUT" ;
    ex:textoExtracto "La siguiente tabla muestra la numeración lógica de los pines LI/O1-LI/O8 en función del parámetro NLOCOUT." ;
    ex:documentadoEn ex:Sistema_EntradasSalidasLocales .