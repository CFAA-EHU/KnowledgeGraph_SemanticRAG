@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:GAP_SENSOR a ex:Sensor ;
    ex:textoExtracto "Diagrama de conexión del sensor de gap a una entrada analógica en módulos remotos CAN (RIOR). Se identifican pines AI1+/AI1− y la cadena 'CNC – RIOR – CAN – GAP SENSOR', mostrando alternativa de cableado cuando no se usa el regulador." ;
    ex:identificador "GAP SENSOR" .

ex:GAP_SENSOR_FEEDBACK a ex:Sensor ;
    ex:textoExtracto "Diagrama de bloques del lazo de control del gap: 'GAP SENSOR FEEDBACK' → filtro paso bajo (ORDER/FREQUENCY) → 'POSITION LOOP' con 'GAP P-GAIN'." ;
    ex:identificador "GAP SENSOR FEEDBACK" .

ex:FiltroPasoBajo a ex:ComponenteElectrico ;
    ex:textoExtracto "filtro paso bajo (ORDER/FREQUENCY)" .

ex:POSITION_LOOP a ex:Sistema ;
    ex:textoExtracto "'POSITION LOOP' con 'GAP P-GAIN'." ;
    ex:identificador "POSITION LOOP" .

ex:GAP_P_GAIN a ex:Parametro ;
    ex:textoExtracto "'GAP P-GAIN'" ;
    ex:identificador "GAP P-GAIN" .

ex:GAPSENSOROFFSET a ex:Parametro ;
    ex:textoExtracto "Gráfico lineal distancia–voltaje del sensor con origen desplazado (GAPSENSOROFFSET), límites GAPDISTLIMIT (mm/in) y GAPVOLTLIMIT (mV)." ;
    ex:identificador "GAPSENSOROFFSET" .

ex:GAPDISTLIMIT a ex:Parametro ;
    ex:textoExtracto "límites GAPDISTLIMIT (mm/in) y GAPVOLTLIMIT (mV)" ;
    ex:identificador "GAPDISTLIMIT" .

ex:GAPVOLTLIMIT a ex:Parametro ;
    ex:textoExtracto "límites GAPDISTLIMIT (mm/in) y GAPVOLTLIMIT (mV)" ;
    ex:identificador "GAPVOLTLIMIT" .

ex:GAPGAIN a ex:Parametro ;
    ex:textoExtracto "Representa la cadena de señal y dónde actúan los parámetros GAPGAIN y GAPSENSORFILTER." ;
    ex:identificador "GAPGAIN" .

ex:GAPSENSORFILTER a ex:Parametro ;
    ex:textoExtracto "Representa la cadena de señal y dónde actúan los parámetros GAPGAIN y GAPSENSORFILTER." ;
    ex:identificador "GAPSENSORFILTER" .

ex:G_GAP a ex:Parametro ;
    ex:textoExtracto "se muestran G.GAP, A.POS.Z, A.POS.X y A.GAPCOMP.Z" ;
    ex:identificador "G.GAP" .

ex:A_FLWE_Z a ex:Parametro ;
    ex:textoExtracto "error de seguimiento A.FLWE.Z" ;
    ex:identificador "A.FLWE.Z" .

ex:DIFF_ATPOS_Z a ex:Parametro ;
    ex:textoExtracto "velocidad DIFF(A.TPOS.Z)" ;
    ex:identificador "DIFF(A.TPOS.Z)" .

ex:DIFF_DIFF_ATPOS_Z a ex:Parametro ;
    ex:textoExtracto "aceleración DIFF(DIFF(A.TPOS.Z))" ;
    ex:identificador "DIFF(DIFF(A.TPOS.Z))" .

ex:A_POS_Z a ex:Parametro ;
    ex:textoExtracto "se muestran G.GAP, A.POS.Z, A.POS.X y A.GAPCOMP.Z" ;
    ex:identificador "A.POS.Z" .

ex:A_POS_X a ex:Parametro ;
    ex:textoExtracto "se muestran G.GAP, A.POS.Z, A.POS.X y A.GAPCOMP.Z" ;
    ex:identificador "A.POS.X" .

ex:A_GAPCOMP_Z a ex:Parametro ;
    ex:textoExtracto "se muestran G.GAP, A.POS.Z, A.POS.X y A.GAPCOMP.Z" ;
    ex:identificador "A.GAPCOMP.Z" .