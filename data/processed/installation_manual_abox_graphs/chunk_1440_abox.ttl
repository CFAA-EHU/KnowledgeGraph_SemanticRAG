@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CinematicaAdicional a ns1:Sistema ;
    rdfs:label "Cinemática Adicional" ;
    ns1:textoExtracto "El OEM puede integrar 6 cinemáticas adicionales." .

ns1:CinematicaPredefinida a ns1:Sistema ;
    rdfs:label "Cinemática Predefinida" ;
    ns1:textoExtracto "El CNC ofrece una serie de cinemáticas predefinidas y que se pueden configurar fácilmente desde los parámetros máquina." .

ns1:TipoDeCinematica_be1d346f12 a ns1:Parametro ;
    rdfs:label "Tipo de Cinemática" ;
    ns1:identificador "TYPE" ;
    ns1:textoExtracto "Las dimensiones que hay que parametrizar dependen del tipo de cinemática, definido en el parámetro TYPE." .

