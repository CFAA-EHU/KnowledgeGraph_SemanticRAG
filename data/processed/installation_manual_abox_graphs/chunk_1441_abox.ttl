@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Sensor_GAP_702
    a ex:Sensor ;
    rdfs:label "Sensor de compensación de gap" ;
    ex:textoExtracto "la compensación del eje del sensor se ve como correcciones sincronizadas ante cambios abruptos de perfil" ;
    ex:monitoreaParametro ex:Parametro_GAP_702 .

ex:Parametro_GAP_702
    a ex:Parametro ;
    rdfs:label "G.GAP" ;
    ex:identificador "G.GAP" ;
    ex:textoExtracto "se muestran G.GAP, A.POS.Z, A.POS.X y A.GAPCOMP.Z" .

ex:Parametro_POS_Z_702
    a ex:Parametro ;
    rdfs:label "A.POS.Z" ;
    ex:identificador "A.POS.Z" ;
    ex:textoExtracto "se muestran G.GAP, A.POS.Z, A.POS.X y A.GAPCOMP.Z" .

ex:Parametro_POS_X_702
    a ex:Parametro ;
    rdfs:label "A.POS.X" ;
    ex:identificador "A.POS.X" ;
    ex:textoExtracto "se muestran G.GAP, A.POS.Z, A.POS.X y A.GAPCOMP.Z" .

ex:Parametro_GAPCOMP_Z_702
    a ex:Parametro ;
    rdfs:label "A.GAPCOMP.Z" ;
    ex:identificador "A.GAPCOMP.Z" ;
    ex:textoExtracto "se muestran G.GAP, A.POS.Z, A.POS.X y A.GAPCOMP.Z" .

ex:Sensor_CompensacionRampa_706
    a ex:Sensor ;
    rdfs:label "Sensor de compensación de perfil ascendente" ;
    ex:textoExtracto "Trazas para 'Pieza con perfil ascendente': representa la evolución del gap y la compensación progresiva del eje para mantener la distancia programada ante una rampa geométrica positiva" ;
    ex:monitoreaParametro ex:Parametro_GAP_706 .

ex:Parametro_GAP_706
    a ex:Parametro ;
    rdfs:label "Gap en perfil ascendente" ;
    ex:textoExtracto "representa la evolución del gap y la compensación progresiva del eje para mantener la distancia programada ante una rampa geométrica positiva" .

ex:Sistema_CabezalAngular_706
    a ex:Sistema ;
    rdfs:label "Cabezal angular YZ de 45° (TYPE=6)" ;
    ex:identificador "TYPE=6" ;
    ex:textoExtracto "Ilustración del cabezal angular YZ de 45° (TYPE=6) con iconografía de ejes y geometría; introduce el contexto de medición con palpador y la necesidad de conocer radio y longitud de la bola del palpador" ;
    ex:tieneComponente ex:Sensor_Palpador_706 .

ex:Sensor_Palpador_706
    a ex:Sensor ;
    rdfs:label "Palpador del cabezal angular" ;
    ex:textoExtracto "necesidad de conocer radio y longitud de la bola del palpador" .

ex:Esquema_TDATA_707
    a ex:Esquema ;
    rdfs:label "Esquema de dimensiones TDATA (TYPE=6)" ;
    ex:identificador "TDATA" ;
    ex:textoExtracto "Esquema de dimensiones TDATA (1,2,3,5,6,7) sobre ejes X-Y-Z y rotaciones B/C, con signos positivos indicados. Muestra relaciones espaciales entre nariz de husillo, ejes rotativos y eje de herramienta para parametrizar la cinemática TYPE=6" ;
    ex:detalladoEnEsquema ex:Sistema_CabezalAngular_706 .

ex:Parametro_TDATA1_707
    a ex:Parametro ;
    rdfs:label "Parámetro TDATA1" ;
    ex:identificador "TDATA1" ;
    ex:textoExtracto "Cálculo del parámetro TDATA1" ;
    ex:documentadoEn ex:Esquema_TDATA_707 .

ex:Diagrama_PrimeraPalpacion_707
    a ex:Figura ;
    rdfs:label "Diagrama 'Primera palpación' (B=0°, C=0°)" ;
    ex:textoExtracto "Diagrama 'Primera palpación': B=0°, C=0°, contacto sobre cara Z y preselección Z=0; flechas indican sentido de palpación y referencias OT y ejes Y-Z" ;
    ex:ilustradoEn ex:Sistema_CabezalAngular_706 .