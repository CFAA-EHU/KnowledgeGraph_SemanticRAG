@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCabezalAngularYZ a ns1:Sistema ;
    rdfs:label "Cabezal angular YZ" ;
    ns1:textoExtracto "Dimensiones a calcular en un cabezal angular YZ (TYPE=6)." ;
    ns1:tieneComponente ns1:AnguloEntreLosEjesRotativosPrincipalYSecundarioEnLosCabezalesRotativos,
        ns1:DistanciaEntreElEjeDeLaHerramientaYElEjeRotativoSecundarioSegunElEjeX,
        ns1:DistanciaEntreElEjeDeLaHerramientaYElEjeRotativoSecundarioSegunElEjeY,
        ns1:DistanciaEntreElEjeRotativoSecundarioYElPrincipalSegunElEjeX,
        ns1:DistanciaEntreElEjeRotativoSecundarioYElPrincipalSegunElEjeY,
        ns1:DistanciaEntreLaNarizDelMandrinoYElEjeRotativoSecundarioSegunElEjeZ .

ns1:AnguloEntreLosEjesRotativosPrincipalYSecundarioEnLosCabezalesRotativos a ns1:Parametro ;
    rdfs:label "Ángulo entre los ejes rotativos principal y secundario en los cabezales rotativos" ;
    ns1:identificador "TDATA7" ;
    ns1:textoExtracto "TDATA7 Indica el ángulo entre los ejes rotativos principal y secundario, en los cabezales rotativos (en este caso TDATA7 = 45)." .

ns1:DistanciaEntreElEjeDeLaHerramientaYElEjeRotativoSecundarioSegunElEjeX a ns1:Parametro ;
    rdfs:label "Distancia entre el eje de la herramienta y el eje rotativo secundario según el eje X" ;
    ns1:identificador "TDATA5" ;
    ns1:textoExtracto "TDATA5 Indica la distancia entre el eje de la herramienta y el eje rotativo secundario según el eje X." .

ns1:DistanciaEntreElEjeDeLaHerramientaYElEjeRotativoSecundarioSegunElEjeY a ns1:Parametro ;
    rdfs:label "Distancia entre el eje de la herramienta y el eje rotativo secundario según el eje Y" ;
    ns1:identificador "TDATA6" ;
    ns1:textoExtracto "TDATA6 Indica la distancia entre el eje de la herramienta y el eje rotativo secundario según el eje Y." .

ns1:DistanciaEntreElEjeRotativoSecundarioYElPrincipalSegunElEjeX a ns1:Parametro ;
    rdfs:label "Distancia entre el eje rotativo secundario y el principal según el eje X" ;
    ns1:identificador "TDATA2" ;
    ns1:textoExtracto "TDATA2 Indica la distancia entre el eje rotativo secundario y el principal según el eje X." .

ns1:DistanciaEntreElEjeRotativoSecundarioYElPrincipalSegunElEjeY a ns1:Parametro ;
    rdfs:label "Distancia entre el eje rotativo secundario y el principal según el eje Y" ;
    ns1:identificador "TDATA3" ;
    ns1:textoExtracto "TDATA3 Indica la distancia entre el eje rotativo secundario y el principal según el eje Y." .

ns1:DistanciaEntreLaNarizDelMandrinoYElEjeRotativoSecundarioSegunElEjeZ a ns1:Parametro ;
    rdfs:label "Distancia entre la nariz del mandrino y el eje rotativo secundario según el eje Z" ;
    ns1:identificador "TDATA1" ;
    ns1:textoExtracto "TDATA1 Indica la distancia entre la nariz del mandrino y el eje rotativo secundario, según el eje Z." .

