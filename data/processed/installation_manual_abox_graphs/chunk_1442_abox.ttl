@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Esquema_17.1_TDATA1
    a ex:Esquema ;
    ex:identificador "17.1 - Cálculo del parámetro TDATA1" ;
    ex:textoExtracto "Esquema combinado con variables TDATA1, ΔZ, L y R, y anotación de la solución TDATA1 = |ΔZ| − R − L; se incluye vista de referencias y vectores de medición." ;
    ex:ilustradoEn ex:Pagina_708 .

ex:Esquema_17.1_TDATA5_PrimeraPalpacion
    a ex:Esquema ;
    ex:identificador "17.1 - TDATA5 (Primera palpación)" ;
    ex:textoExtracto "Diagrama 'Primera palpación': B=0°, C=0°, contacto sobre cara X próxima al origen y preselección X=0; se señalan ejes X-Z y posición ①." ;
    ex:ilustradoEn ex:Pagina_708 .

ex:Esquema_17.1_TDATA5_SegundaPalpacion
    a ex:Esquema ;
    ex:identificador "17.1 - TDATA5 (Segunda palpación)" ;
    ex:textoExtracto "Diagrama 'Segunda palpación': B=0°, C=180°, contacto sobre misma cara con lectura ΔX, resaltando el giro alrededor de 2 y el desplazamiento resultante." ;
    ex:ilustradoEn ex:Pagina_708 .

ex:Esquema_17.1_TDATA5_Solucion
    a ex:Esquema ;
    ex:identificador "17.1 - TDATA5 (Solución)" ;
    ex:textoExtracto "Esquema de solución con marcadores de B/C y anotación TDATA5 = 0,5·|ΔX|; la figura asocia gráficamente la variación de lectura con el desfase geométrico del eje herramienta." ;
    ex:ilustradoEn ex:Pagina_709 .

ex:Esquema_17.1_TDATA6_PrimeraPalpacion
    a ex:Esquema ;
    ex:identificador "17.1 - TDATA6 (Primera palpación)" ;
    ex:textoExtracto "Diagrama 'Primera palpación': B=0°, C=0°, medición del ancho D entre dos caras X con corrección 2R (bola); se indica X = D + 2R." ;
    ex:ilustradoEn ex:Pagina_709 .

ex:Parametro_TDATA1
    a ex:Parametro ;
    ex:identificador "TDATA1" ;
    ex:textoExtracto "TDATA1 = |ΔZ| − R − L" ;
    ex:monitoreaParametro ex:Parametro_DeltaZ ;
    ex:monitoreaParametro ex:Parametro_R ;
    ex:monitoreaParametro ex:Parametro_L ;
    ex:documentadoEn ex:Esquema_17.1_TDATA1 .

ex:Parametro_TDATA5
    a ex:Parametro ;
    ex:identificador "TDATA5" ;
    ex:textoExtracto "TDATA5 = 0,5·|ΔX|" ;
    ex:monitoreaParametro ex:Parametro_DeltaX ;
    ex:documentadoEn ex:Esquema_17.1_TDATA5_Solucion .

ex:Parametro_TDATA6
    a ex:Parametro ;
    ex:identificador "TDATA6" ;
    ex:textoExtracto "X = D + 2R" ;
    ex:monitoreaParametro ex:Parametro_D ;
    ex:monitoreaParametro ex:Parametro_R ;
    ex:documentadoEn ex:Esquema_17.1_TDATA6_PrimeraPalpacion .

ex:Parametro_DeltaZ
    a ex:Parametro ;
    ex:identificador "ΔZ" ;
    ex:textoExtracto "lectura ΔZ" ;
    ex:documentadoEn ex:Esquema_17.1_TDATA1 .

ex:Parametro_DeltaX
    a ex:Parametro ;
    ex:identificador "ΔX" ;
    ex:textoExtracto "lectura ΔX" ;
    ex:documentadoEn ex:Esquema_17.1_TDATA5_SegundaPalpacion .

ex:Parametro_L
    a ex:Parametro ;
    ex:identificador "L" ;
    ex:textoExtracto "variable L" ;
    ex:documentadoEn ex:Esquema_17.1_TDATA1 .

ex:Parametro_R
    a ex:Parametro ;
    ex:identificador "R" ;
    ex:textoExtracto "variable R (radio de la bola)" ;
    ex:documentadoEn ex:Esquema_17.1_TDATA1 ;
    ex:documentadoEn ex:Esquema_17.1_TDATA6_PrimeraPalpacion .

ex:Parametro_D
    a ex:Parametro ;
    ex:identificador "D" ;
    ex:textoExtracto "ancho D entre dos caras X" ;
    ex:documentadoEn ex:Esquema_17.1_TDATA6_PrimeraPalpacion .

ex:Pagina_708
    a ex:Pagina ;
    ex:identificador "708" ;
    ex:textoExtracto "Página 708 del manual técnico (Sección 17.1)." .

ex:Pagina_709
    a ex:Pagina ;
    ex:identificador "709" ;
    ex:textoExtracto "Página 709 del manual técnico (Sección 17.1)." .