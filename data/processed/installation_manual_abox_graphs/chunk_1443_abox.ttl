@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Esquema_PalpacionTDATA6
    a ex:Esquema ;
    rdfs:label "Esquema combinado para cálculo de TDATA6"@es ;
    ex:textoExtracto "Esquema combinado con fórmula de solución TDATA6 = (ΔX + ΔX′ − 2L − D − 2·TDATA1)/(2·cos45°); incluye geometría del cabezal, posición del palpador (L, R) y referencias TDATA1/TDATA6."@es ;
    ex:ilustradoEn ex:Diagrama_SegundaPalpacion_X ,
                   ex:Diagrama_TerceraPalpacion_X ,
                   ex:Diagrama_PrimeraPalpacion_Z ,
                   ex:Diagrama_SegundaPalpacion_Z ;
    ex:detalladoEnEsquema ex:Parametro_TDATA6 ,
                          ex:Parametro_TDATA1 ,
                          ex:Parametro_DeltaX ,
                          ex:Parametro_DeltaX_Prima ,
                          ex:Parametro_DeltaZ .

ex:Diagrama_SegundaPalpacion_X
    a ex:Figura ;
    rdfs:label "Diagrama 'Segunda palpación' (TDATA6)"@es ;
    ex:textoExtracto "Diagrama 'Segunda palpación': B=−90°, C=0°, palpación de la primera cara X con lectura ΔX′; se representa orientación del cabezal y referencias 1 y 2."@es ;
    ex:ilustradoEn ex:Esquema_PalpacionTDATA6 .

ex:Diagrama_TerceraPalpacion_X
    a ex:Figura ;
    rdfs:label "Diagrama 'Tercera palpación' (TDATA6)"@es ;
    ex:textoExtracto "Diagrama 'Tercera palpación': B=+90°, C=0°, palpación de la segunda cara X con lectura ΔX; muestra la simetría del procedimiento respecto al giro de B."@es ;
    ex:ilustradoEn ex:Esquema_PalpacionTDATA6 .

ex:Diagrama_PrimeraPalpacion_Z
    a ex:Figura ;
    rdfs:label "Diagrama 'Primera palpación' (TDATA2)"@es ;
    ex:textoExtracto "Diagrama 'Primera palpación': C=0°, B=+90°, contacto sobre cara Z con preselección Z=0; se destaca la rotación de B y el sistema de ejes X-Z."@es ;
    ex:ilustradoEn ex:Esquema_PalpacionTDATA6 .

ex:Diagrama_SegundaPalpacion_Z
    a ex:Figura ;
    rdfs:label "Diagrama 'Segunda palpación' (TDATA2)"@es ;
    ex:textoExtracto "Diagrama 'Segunda palpación': C=0°, B=−90°, repetición sobre cara Z con lectura ΔZ; ilustra el cambio del centro de giro ① y la lectura que interviene en la ecuación de TDATA2."@es ;
    ex:ilustradoEn ex:Esquema_PalpacionTDATA6 .

ex:Parametro_TDATA6
    a ex:Parametro ;
    rdfs:label "TDATA6" ;
    ex:identificador "TDATA6" ;
    ex:textoExtracto "Parámetro calculado mediante TDATA6 = (ΔX + ΔX′ − 2L − D − 2·TDATA1)/(2·cos45°)"@es ;
    ex:monitoreaParametro ex:Esquema_PalpacionTDATA6 .

ex:Parametro_TDATA1
    a ex:Parametro ;
    rdfs:label "TDATA1" ;
    ex:identificador "TDATA1" ;
    ex:textoExtracto "Parámetro de referencia en la fórmula de TDATA6: 2·TDATA1"@es .

ex:Parametro_DeltaX
    a ex:Parametro ;
    rdfs:label "ΔX" ;
    ex:identificador "DeltaX" ;
    ex:textoExtracto "Lectura de desplazamiento en la segunda palpación de la cara X (B=+90°)"@es .

ex:Parametro_DeltaX_Prima
    a ex:Parametro ;
    rdfs:label "ΔX′" ;
    ex:identificador "DeltaX_Prima" ;
    ex:textoExtracto "Lectura de desplazamiento en la primera palpación de la cara X (B=−90°)"@es .

ex:Parametro_DeltaZ
    a ex:Parametro ;
    rdfs:label "ΔZ" ;
    ex:identificador "DeltaZ" ;
    ex:textoExtracto "Lectura de desplazamiento en la segunda palpación de la cara Z (B=−90°)"@es .