@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CotaDeltaX a ns1:Parametro ;
    rdfs:label "Cota que indica el CNC" ;
    ns1:identificador "X" ;
    ns1:textoExtracto "X | Cota que indica el CNC." .

ns1:CotaDeltaZ a ns1:Parametro ;
    rdfs:label "Cota que indica el CNC" ;
    ns1:identificador "Z" ;
    ns1:textoExtracto "Z | Cota que indica el CNC." .

ns1:DimensionACalcular a ns1:Parametro ;
    rdfs:label "Dimensión a calcular" ;
    ns1:identificador "TDATA1" ;
    ns1:textoExtracto "TDATA1 = Z +R–L" .

ns1:DimensionACalcular_c02bcbea1e a ns1:Parametro ;
    rdfs:label "Dimensión a calcular" ;
    ns1:identificador "TDATA5" ;
    ns1:textoExtracto "TDATA5 = 0.5  Z" .

ns1:LongitudPalpador a ns1:Parametro ;
    rdfs:label "Longitud del palpador" ;
    ns1:identificador "L" ;
    ns1:textoExtracto "L | Longitud del palpador." .

ns1:PuntoReferenciaHerramientas a ns1:Parametro ;
    rdfs:label "Punto de referencia de las herramientas" ;
    ns1:identificador "OT" ;
    ns1:textoExtracto "OT | Punto de referencia de las herramientas." .

ns1:RadioBolaPalpador a ns1:Parametro ;
    rdfs:label "Radio de la bola del palpador" ;
    ns1:identificador "R" ;
    ns1:textoExtracto "R | Radio de la bola del palpador." .

