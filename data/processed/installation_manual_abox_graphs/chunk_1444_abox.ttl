@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Esquema_17_1_CalculoParametroTDATA2
    a ex:Esquema ;
    rdfs:label "Esquema de solución con doble vista B=±90° para cálculo de TDATA2"@es ;
    ex:textoExtracto "Esquema de solución con doble vista B=±90° y anotaciones TDATA5 y ΔZ, junto a la relación TDATA2 = 0,5·|ΔZ| − |TDATA5|; se visualizan vectores y signos de las cotas para el cálculo final."@es ;
    ex:ilustradoEn ex:Pagina_711 ;
    ex:detalladoEnEsquema ex:Parametro_TDATA2, ex:Parametro_TDATA5, ex:Parametro_DeltaZ .

ex:Parametro_TDATA2
    a ex:Parametro ;
    rdfs:label "TDATA2" ;
    ex:textoExtracto "parámetro TDATA2 = 0,5·|ΔZ| − |TDATA5|"@es ;
    ex:valor "0.5*|ΔZ| - |TDATA5|"^^xsd:string .

ex:Parametro_TDATA5
    a ex:Parametro ;
    rdfs:label "TDATA5" ;
    ex:textoExtracto "anotaciones TDATA5"@es .

ex:Parametro_DeltaZ
    a ex:Parametro ;
    rdfs:label "ΔZ" ;
    ex:textoExtracto "anotaciones ΔZ"@es .

ex:Pagina_711
    a ex:Pagina ;
    ex:identificador "711" ;
    ex:textoExtracto "Sección 17.1: Cálculo del parámetro TDATA2"@es .

ex:Esquema_17_2_CabezalAngular_TYPE6
    a ex:Esquema ;
    rdfs:label "Esquema del cabezal angular TYPE=6 (YZ 45°)"@es ;
    ex:textoExtracto "Esquema del cabezal angular TYPE=6 (YZ 45°) con representación de ejes X-Y-Z y sentidos positivos de parámetros TDATA (1, 2, 3, 5, 6, 7). Se muestran tres vistas del cabezal con flechas y signos para la dirección de medida, ubicadas respecto al husillo y al cilindro patrón montado en el cabezal."@es ;
    ex:ilustradoEn ex:Pagina_712 ;
    ex:detalladoEnEsquema ex:ComponenteMecanico_CabezalAngular_TYPE6, ex:Parametro_TDATA1, ex:Parametro_TDATA3, ex:Parametro_TDATA6, ex:Parametro_TDATA7 .

ex:ComponenteMecanico_CabezalAngular_TYPE6
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal angular TYPE=6 (YZ 45°)"@es ;
    ex:identificador "TYPE=6" ;
    ex:textoExtracto "cabezal angular TYPE=6 (YZ 45°)"@es ;
    ex:compuestoPor ex:ComponenteMecanico_Husillo, ex:ComponenteMecanico_CilindroPatron .

ex:ComponenteMecanico_Husillo
    a ex:ComponenteMecanico ;
    rdfs:label "Husillo del cabezal angular"@es ;
    ex:textoExtracto "husillo"@es .

ex:ComponenteMecanico_CilindroPatron
    a ex:ComponenteMecanico ;
    rdfs:label "Cilindro patrón"@es ;
    ex:textoExtracto "cilindro patrón montado en el cabezal"@es .

ex:Parametro_TDATA1
    a ex:Parametro ;
    rdfs:label "TDATA1" ;
    ex:textoExtracto "parámetros TDATA (1, 2, 3, 5, 6, 7)"@es .

ex:Parametro_TDATA3
    a ex:Parametro ;
    rdfs:label "TDATA3" ;
    ex:textoExtracto "parámetros TDATA (1, 2, 3, 5, 6, 7)"@es .

ex:Parametro_TDATA6
    a ex:Parametro ;
    rdfs:label "TDATA6" ;
    ex:textoExtracto "parámetros TDATA (1, 2, 3, 5, 6, 7)"@es .

ex:Parametro_TDATA7
    a ex:Parametro ;
    rdfs:label "TDATA7" ;
    ex:textoExtracto "parámetros TDATA (1, 2, 3, 5, 6, 7)"@es .

ex:Pagina_712
    a ex:Pagina ;
    ex:identificador "712" ;
    ex:textoExtracto "Sección 17.2: Cabezal angular. Cálculo de las dimensiones con ayuda de un reloj comparador"@es .

ex:Herramienta_RelojComparador
    a ex:Herramienta ;
    rdfs:label "Reloj comparador"@es ;
    ex:textoExtracto "uso correcto del reloj comparador sobre un cilindro: palpado tangencial en la línea exterior del cilindro con el palpador lo más perpendicular posible a la tangente"@es ;
    ex:ilustradoEn ex:Esquema_17_2_UsoRelojComparador .

ex:Esquema_17_2_UsoRelojComparador
    a ex:Esquema ;
    rdfs:label "Ilustración del uso correcto e incorrecto del reloj comparador"@es ;
    ex:textoExtracto "Ilustración del uso correcto del reloj comparador sobre un cilindro: palpado tangencial en la línea exterior del cilindro con el palpador lo más perpendicular posible a la tangente. Dos esquemas con marcas de error (cruz) que ejemplifican colocaciones incorrectas del reloj comparador sobre el cilindro, indicando direccionalidad y geometría de contacto que producen errores al asignar el radio."@es ;
    ex:ilustradoEn ex:Pagina_712 ;
    ex:detalladoEnEsquema ex:Herramienta_RelojComparador, ex:ComponenteMecanico_CilindroPatron .