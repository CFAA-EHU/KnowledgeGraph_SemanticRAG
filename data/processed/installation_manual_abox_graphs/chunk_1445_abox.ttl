@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:RelojComparador712 a ex:Sensor ;
    rdfs:label "Reloj comparador" ;
    ex:textoExtracto "desplazamiento del reloj sobre la circunferencia hasta detectar cambio de giro de la aguja y retorno al valor inicial" .

ex:EjeCilindro712 a ex:ComponenteMecanico ;
    rdfs:label "Eje del cilindro" ;
    ex:textoExtracto "señalando que el punto exterior está a mitad del recorrido del eje" .

ex:DiagramaPrimerContactoTDATA1 a ex:Esquema ;
    rdfs:label "Diagrama 'Primer contacto' para TDATA1" ;
    ex:textoExtracto "Diagrama 'Primer contacto' para TDATA1 con B=0°, C=0° y palpado en eje Y sobre cilindro (punto 1), mostrando preselección Y=R para centrar el eje del cilindro. Incluye iconografía de reloj y vectores de movimiento." ;
    ex:tieneComponente ex:RelojComparador712, ex:EjeCilindro712 .

ex:DiagramaSegundoContactoTDATA1 a ex:Esquema ;
    rdfs:label "Diagrama 'Segundo contacto' para TDATA1" ;
    ex:textoExtracto "Diagrama 'Segundo contacto' para TDATA1 con C=180°, palpado en punto 2 y lectura de ΔY. Se destaca la relación TDATA1 = |ΔY| mediante flechas y cotas asociadas al eje Y." ;
    ex:tieneComponente ex:EjeCilindro712 .

ex:EjeX713 a ex:ComponenteMecanico ;
    rdfs:label "Eje X" ;
    ex:textoExtracto "palpado en eje X (punto 1) y preselección X=0" .

ex:EjeZ713 a ex:ComponenteMecanico ;
    rdfs:label "Eje Z" ;
    ex:textoExtracto "geometría de referencia X-Z" .

ex:DiagramaPrimerContactoTDATA5 a ex:Esquema ;
    rdfs:label "Diagrama 'Primer contacto' para TDATA5" ;
    ex:textoExtracto "Esquema 'Primer contacto' para TDATA5 con B=0°, C=0°, palpado en eje X (punto 1) y preselección X=0. Se presenta la geometría de referencia X-Z y el punto de lectura." ;
    ex:tieneComponente ex:RelojComparador712, ex:EjeX713, ex:EjeZ713 .

ex:DiagramaSegundoContactoTDATA5 a ex:Esquema ;
    rdfs:label "Diagrama 'Segundo contacto' para TDATA5" ;
    ex:textoExtracto "Esquema 'Segundo contacto' para TDATA5 con C=180°, palpado en punto 2 y lectura de ΔX." ;
    ex:tieneComponente ex:EjeX713 .