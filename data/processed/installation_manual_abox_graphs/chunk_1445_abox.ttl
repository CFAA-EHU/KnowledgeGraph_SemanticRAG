@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA1
    a ex:Parametro ;
    rdfs:label "Parámetro TDATA1" ;
    ex:textoExtracto "Cálculo del parámetro TDATA1 [...] TDATA1 = |ΔY|" ;
    ex:monitoreaParametro ex:Esquema_TDATA1 .

ex:Parametro_TDATA5
    a ex:Parametro ;
    rdfs:label "Parámetro TDATA5" ;
    ex:textoExtracto "Cálculo del parámetro TDATA5" ;
    ex:monitoreaParametro ex:Esquema_TDATA5 .

ex:Esquema_TDATA1
    a ex:Esquema ;
    rdfs:label "Diagrama de cálculo de TDATA1 (B=0°, C=0° y C=180°)" ;
    ex:textoExtracto "Diagrama 'Primer contacto' para TDATA1 con B=0°, C=0° y palpado en eje Y sobre cilindro (punto 1) [...] Segundo contacto para TDATA1 con C=180°, palpado en punto 2 y lectura de ΔY" ;
    ex:ilustradoEn ex:Pagina_713 .

ex:Esquema_TDATA5
    a ex:Esquema ;
    rdfs:label "Esquema de cálculo de TDATA5 (B=0°, C=0° y C=180°)" ;
    ex:textoExtracto "Esquema 'Primer contacto' para TDATA5 con B=0°, C=0°, palpado en eje X (punto 1) [...] Segundo contacto para TDATA5 con C=180°, palpado en punto 2 y lectura de ΔX" ;
    ex:ilustradoEn ex:Pagina_713, ex:Pagina_714 .

ex:Pagina_713
    a ex:Pagina ;
    rdfs:label "Página 713" ;
    ex:identificador "713" ;
    ex:textoExtracto "Sección 17.2 Cabezal angular. Cálculo de los parámetros TDATA1 y TDATA5" ;
    ex:documentadoEn ex:Manual_CabezalAngular .

ex:Pagina_714
    a ex:Pagina ;
    rdfs:label "Página 714" ;
    ex:identificador "714" ;
    ex:textoExtracto "Sección 17.2 Cabezal angular. Cálculo del parámetro TDATA5" ;
    ex:documentadoEn ex:Manual_CabezalAngular .

ex:Manual_CabezalAngular
    a ex:Manual ;
    rdfs:label "Manual de cabezal angular" ;
    ex:textoExtracto "Sección 17.2: Cabezal angular. Cálculo de dimensiones con reloj comparador y parámetros TDATA1/TDATA5" .

ex:Sensor_RelojComparador
    a ex:Sensor ;
    rdfs:label "Reloj comparador" ;
    ex:textoExtracto "Método gráfico para localizar la 'línea más exterior' del cilindro: desplazamiento del reloj sobre la circunferencia hasta detectar cambio de giro de la aguja" ;
    ex:monitoreaParametro ex:Parametro_TDATA1, ex:Parametro_TDATA5 .