@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_20aae39bed a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:CalculoDeLasDimensionesConAyudaDelCNC ;
    ns1:textoExtracto "Anotar la cota que aparece en el CNC, denominada en el dibujo Δ" .

ns1:DatoDesconocidoTrasLasPalpaciones a ns1:Parametro ;
    rdfs:label "Dato desconocido tras las palpaciones" ;
    ns1:identificador "TDATA6" ;
    ns1:textoExtracto "el único dato desconocido tras ambos palpaciones es TDATA6." .

ns1:CalculoDeLasDimensionesConAyudaDelCNC a ns1:TareaMantenimiento ;
    rdfs:label "Cálculo de las dimensiones con ayuda del CNC" ;
    ns1:solucionaFallo ns1:FalloCalculoDimensiones ;
    ns1:textoExtracto "Con el cambio de posición respecto al centro de giro ꞏ1ꞏ, el único dato desconocido tras ambos palpaciones es TDATA6." .

ns1:FalloCalculoDimensiones a ns1:DiagnosticoFallo ;
    rdfs:label "Error en el cálculo de las dimensiones" ;
    ns1:textoExtracto "el único dato desconocido tras ambos palpaciones es TDATA6." .

