@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:EsquemaSegundoContacto a ex:Esquema ;
    ex:textoExtracto "Esquema 'Segundo contacto' para TDATA5 con C=180°, palpado en punto 2 y lectura de ΔX. El gráfico indica la obtención de TDATA5 = 0,5·|ΔX| mediante cotas sobre el eje X." ;
    ex:tieneComponente ex:ParametroTDATA5 .

ex:ParametroTDATA5 a ex:Parametro ;
    ex:identificador "TDATA5" ;
    ex:textoExtracto "TDATA5 = 0,5·|ΔX|" .

ex:EsquemaTDATA2 a ex:Esquema ;
    ex:textoExtracto "Pareja de diagramas para TDATA2: posición de referencia con B=0°, C=0° (punto 1) y posición con B=180°, C=0° (punto 3). Se representan los palpados, las lecturas ΔX y la combinación con TDATA5 para calcular TDATA2, con flechas de giro y ejes X-Z." ;
    ex:tieneComponente ex:ParametroTDATA2 .

ex:ParametroTDATA2 a ex:Parametro ;
    ex:identificador "TDATA2" ;
    ex:textoExtracto "TDATA2" .

ex:EsquemaTDATA6PrimerContacto a ex:Esquema ;
    ex:textoExtracto "Secuencia 'Primer y segundo contacto': desde X=−R con B=0°, C=0° (punto 1) a B=−90° (punto 2). Se muestran lecturas Xa y la preselección para centrar X=0 en el eje del cilindro. Flechas indican los giros del eje B y los desplazamientos en X." ;
    ex:tieneComponente ex:ParametroTDATA6 .

ex:ParametroTDATA6 a ex:Parametro ;
    ex:identificador "TDATA6" ;
    ex:textoExtracto "TDATA6" .

ex:EsquemaTDATA6TercerContacto a ex:Esquema ;
    ex:textoExtracto "Secuencia 'Tercer y cuarto contacto': desde X=+R con B=0°, C=0° (punto 3) a B=+90° (punto 4). Se representa la lectura Xb y la simetría del procedimiento respecto a la secuencia anterior." ;
    ex:tieneComponente ex:ParametroTDATA6 .