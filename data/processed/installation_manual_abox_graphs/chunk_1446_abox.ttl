@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Esquema_TDATA5
    a ex:Esquema ;
    rdfs:label "Esquema 'Segundo contacto' para TDATA5"@es ;
    ex:textoExtracto "Esquema 'Segundo contacto' para TDATA5 con C=180°, palpado en punto 2 y lectura de ΔX. El gráfico indica la obtención de TDATA5 = 0,5·|ΔX| mediante cotas sobre el eje X."@es ;
    ex:ilustradoEn ex:Parametro_TDATA5 .

ex:Esquema_TDATA2
    a ex:Esquema ;
    rdfs:label "Diagramas para cálculo de TDATA2"@es ;
    ex:textoExtracto "Pareja de diagramas para TDATA2: posición de referencia con B=0°, C=0° (punto 1) y posición con B=180°, C=0° (punto 3). Se representan los palpados, las lecturas ΔX y la combinación con TDATA5 para calcular TDATA2, con flechas de giro y ejes X-Z."@es ;
    ex:ilustradoEn ex:Parametro_TDATA2 ;
    ex:detalladoEnEsquema ex:Parametro_TDATA5 .

ex:Esquema_TDATA6_1y2
    a ex:Esquema ;
    rdfs:label "Secuencia 'Primer y segundo contacto' para TDATA6"@es ;
    ex:textoExtracto "Secuencia 'Primer y segundo contacto': desde X=−R con B=0°, C=0° (punto 1) a B=−90° (punto 2). Se muestran lecturas Xa y la preselección para centrar X=0 en el eje del cilindro. Flechas indican los giros del eje B y los desplazamientos en X."@es ;
    ex:ilustradoEn ex:Parametro_TDATA6 .

ex:Esquema_TDATA6_3y4
    a ex:Esquema ;
    rdfs:label "Secuencia 'Tercer y cuarto contacto' para TDATA6"@es ;
    ex:textoExtracto "Secuencia 'Tercer y cuarto contacto': desde X=+R con B=0°, C=0° (punto 3) a B=+90° (punto 4). Se representa la lectura Xb y la simetría del procedimiento respecto a la secuencia anterior."@es ;
    ex:ilustradoEn ex:Parametro_TDATA6 .

ex:Parametro_TDATA5
    a ex:Parametro ;
    rdfs:label "TDATA5" ;
    ex:identificador "TDATA5" ;
    ex:textoExtracto "TDATA5 = 0,5·|ΔX|"@es ;
    ex:valor "0.5 * |ΔX|" .

ex:Parametro_TDATA2
    a ex:Parametro ;
    rdfs:label "TDATA2" ;
    ex:identificador "TDATA2" ;
    ex:textoExtracto "Cálculo de TDATA2 mediante combinación con TDATA5, lecturas ΔX y posiciones B=0°, C=0° (punto 1) y B=180°, C=0° (punto 3)."@es .

ex:Parametro_TDATA6
    a ex:Parametro ;
    rdfs:label "TDATA6" ;
    ex:identificador "TDATA6" ;
    ex:textoExtracto "Cálculo mediante secuencias simétricas: lecturas Xa (puntos 1-2) y Xb (puntos 3-4), con B=±90° y preselección X=0 en eje del cilindro."@es .