@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Esquema_Geometrico_XM_TDATA6
    a ex:Esquema ;
    rdfs:label "Diagrama de solución geométrica: construcción de XM = 0,5·(Xb+Xa) y cálculo TDATA6"@es ;
    ex:textoExtracto "Diagrama de solución geométrica: construcción de XM = 0,5·(Xb+Xa) y cálculo TDATA6 = 2·XM − TDATA1, con esquema Y-Z, marca de ángulo 45° y flechas de referencia; se destaca la relación entre la media de lecturas laterales y el descentramiento respecto a TDATA1."@es ;
    ex:identificador "TDATA6" .

ex:Parametro_TDATA6
    a ex:Parametro ;
    rdfs:label "Parámetro TDATA6 (descentramiento)"@es ;
    ex:textoExtracto "cálculo TDATA6 = 2·XM − TDATA1"@es ;
    ex:identificador "TDATA6" ;
    ex:valor "2·XM − TDATA1" .

ex:Parametro_TDATA1
    a ex:Parametro ;
    rdfs:label "Parámetro TDATA1 (referencia)"@es ;
    ex:textoExtracto "descentramiento respecto a TDATA1"@es ;
    ex:identificador "TDATA1" .

ex:Esquema_MesaRotativa_TYPE9
    a ex:Esquema ;
    rdfs:label "Conjunto de diagramas de mesa rotativa AB (TYPE=9)"@es ;
    ex:textoExtracto "Conjunto de diagramas de una mesa rotativa AB (TYPE=9) que definen sentidos positivos y parámetros TDATA2, TDATA3, TDATA4 y TDATA5. Se indican ejes A y B, la intersección de ejes en X-Y-Z y la distancia entre ejes con flechas, signos (+) y bloques etiquetados."@es ;
    ex:identificador "TYPE=9" .

ex:Parametro_TDATA2
    a ex:Parametro ;
    rdfs:label "Parámetro TDATA2 (mesa rotativa)"@es ;
    ex:textoExtracto "parámetros TDATA2, TDATA3, TDATA4 y TDATA5"@es ;
    ex:identificador "TDATA2" .

ex:Parametro_TDATA3
    a ex:Parametro ;
    rdfs:label "Parámetro TDATA3 (mesa rotativa)"@es ;
    ex:textoExtracto "parámetros TDATA2, TDATA3, TDATA4 y TDATA5"@es ;
    ex:identificador "TDATA3" .

ex:Parametro_TDATA4
    a ex:Parametro ;
    rdfs:label "Parámetro TDATA4 (mesa rotativa)"@es ;
    ex:textoExtracto "parámetros TDATA2, TDATA3, TDATA4 y TDATA5"@es ;
    ex:identificador "TDATA4" .

ex:Parametro_TDATA5
    a ex:Parametro ;
    rdfs:label "Parámetro TDATA5 (mesa rotativa)"@es ;
    ex:textoExtracto "parámetros TDATA2, TDATA3, TDATA4 y TDATA5"@es ;
    ex:identificador "TDATA5" .

ex:Esquema_PosicionesEjeA
    a ex:Esquema ;
    rdfs:label "Esquema de posiciones del eje A (A=−90°, B=−90° y A=+90°, B=−90°)"@es ;
    ex:textoExtracto "Esquema de dos posiciones con centro común del eje A (A=−90°, B=−90° y A=+90°, B=−90°)."@es ;
    ex:identificador "EjeA_Posiciones" .

# Relaciones entre esquemas y parámetros
ex:Esquema_Geometrico_XM_TDATA6
    ex:detalladoEnEsquema ex:Parametro_TDATA6 ;
    ex:detalladoEnEsquema ex:Parametro_TDATA1 .

ex:Esquema_MesaRotativa_TYPE9
    ex:detalladoEnEsquema ex:Parametro_TDATA2 , ex:Parametro_TDATA3 , ex:Parametro_TDATA4 , ex:Parametro_TDATA5 .