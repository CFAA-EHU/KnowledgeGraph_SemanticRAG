@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalAngularYZ45 a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal angular YZ de 45º" ;
    ns1:textoExtracto "En este ejemplo se calculan las dimensiones de un cabezal angular YZ de 45º (el mismo que el del ejemplo anterior)" .

ns1:CilindroConocido a ns1:ComponenteMecanico ;
    rdfs:label "Cilindro de diámetro conocido" ;
    ns1:textoExtracto "colocado en el cabezal. DATA 3(+) TYPE=6 DATA 2(-) D A DATA 7(+) T A B 6 C DATA 1(+) Z Z Z Y X DATA 5(-) Y X Cómo utilizar el reloj comparador." .

ns1:Parametro_5e05246d44 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA1" ;
    ns1:textoExtracto "Cálculo del parámetro TDATA1. Primer contacto." .

ns1:RelojComparador a ns1:Herramienta ;
    rdfs:label "Reloj comparador" ;
    ns1:textoExtracto "En caso contrario, al asignar a una preselección el valor del radio del cilindro, se estará cometiendo un error de medida. Es recomendable que el reloj esté lo más perpendicular posible a la tangente de la superficie a medir." .

ns1:TipoDeCabezal a ns1:Parametro ;
    rdfs:label "Tipo de cabezal" ;
    ns1:identificador "TYPE" ;
    ns1:textoExtracto "parámetro TYPE con valor ꞏ6ꞏ" ;
    ns1:valor "6" .

