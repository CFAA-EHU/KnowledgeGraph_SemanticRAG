@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalAngularC172 a ns1:Sistema ;
    rdfs:label "Cabezal angular" ;
    ns1:monitoreaParametro ns1:CoordenadaY ;
    ns1:textoExtracto "Preseleccionar Y=R, para que Y=0 coincida con el eje del cilindro colocado en el cabezal." ;
    ns1:tieneComponente ns1:PuntoDeContacto1_d04069970f .

ns1:CoordenadaY a ns1:Parametro ;
    rdfs:label "Coordenada Y" ;
    ns1:identificador "Y" ;
    ns1:textoExtracto "Apuntar la cota que aparece en el CNC ( Y)." .

ns1:PuntoDeContacto1_d04069970f a ns1:Componente ;
    rdfs:label "Punto de contacto 1" ;
    ns1:textoExtracto "Tocar con el reloj en el punto 2." .

