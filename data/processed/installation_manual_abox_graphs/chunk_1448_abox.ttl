@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
ex:Palpador a ex:Sensor ;
    ex:textoExtracto "lecturas ΔY1/ΔY2 y ΔZ1/ΔZ2, y la obtención de TDATA3 (Y) y Pz (Z) con cotas y radio R" ;
    ex:identificador "r" .

ex:MesaRotativa a ex:ComponenteMecanico ;
    ex:textoExtracto "palpado en X sobre la mesa" ;
    ex:identificador "mesa" .

ex:EjeB a ex:ComponenteMecanico ;
    ex:textoExtracto "disposiciones del eje B (A=0° con B=0° y B=−90°)" ;
    ex:identificador "B" .

ex:EjeA a ex:ComponenteMecanico ;
    ex:textoExtracto "distancias E y F desde la mesa hasta los ejes B y A respectivamente" ;
    ex:identificador "A" .

ex:InterfazHerramientaCNC a ex:InterfazUsuario ;
    ex:textoExtracto "Captura de interfaz de la tabla de herramientas del CNC con resaltados 'A' (tipo de herramienta) y 'B' (número de dientes 1–100)" ;
    ex:compuestoPor ex:CampoTipoHerramienta, ex:CampoNumeroDientes ;
    ex:identificador "tabla de herramientas del CNC" .

ex:CampoTipoHerramienta a ex:Parametro ;
    ex:textoExtracto "resaltados 'A' (tipo de herramienta)" ;
    ex:identificador "A" .

ex:CampoNumeroDientes a ex:Parametro ;
    ex:textoExtracto "resaltados 'B' (número de dientes 1–100)" ;
    ex:identificador "B" .