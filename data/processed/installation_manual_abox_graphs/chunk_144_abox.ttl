@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DireccionBaseDelBloqueLogico_58adb03393 a ns1:Parametro ;
    rdfs:label "Dirección base del bloque lógico" ;
    ns1:documentadoEn ns1:SistemaDigitalOutputs ;
    ns1:identificador "MPG.DOMODADDR" ;
    ns1:textoExtracto "ADDRESS Dirección base del bloque lógico. Valores posibles: De 1 a 1017. Valor por defecto: El primer valor válido." .

ns1:SistemaDigitalOutputs a ns1:Sistema ;
    rdfs:label "Sistema de salidas digitales" ;
    ns1:textoExtracto "El máximo número de bloques lógicos en el sistema será 64, tanto para entradas como para salidas digitales." .

