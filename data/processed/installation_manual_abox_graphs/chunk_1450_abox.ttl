@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:InterfazUsuario_KPA_EtherCAT_Studio a ex:InterfazUsuario ;
    ex:textoExtracto "Captura de la interfaz de 'KPA EtherCAT Studio' con la vista principal de topología a la izquierda, panel de mensajes/ayuda a la derecha y bandeja del sistema mostrando el servicio 'Master (Win64)'." ;
    ex:tieneComponente ex:PanelTopologia_KPA, ex:PanelMensajesAyuda_KPA, ex:BandejaSistema_KPA, ex:ServicioMasterWin64_KPA .

ex:PanelTopologia_KPA a ex:InterfazUsuario ;
    ex:textoExtracto "Se señalan zonas A, B, C para topología, ayuda y mensajes, respectivamente; incluye iconos de atajo a 'Master (Win64)', 'Studio' y utilidades de licencia." .

ex:PanelMensajesAyuda_KPA a ex:InterfazUsuario ;
    ex:textoExtracto "Se señalan zonas A, B, C para topología, ayuda y mensajes, respectivamente" .

ex:BandejaSistema_KPA a ex:InterfazUsuario ;
    ex:textoExtracto "bandeja del sistema mostrando el servicio 'Master (Win64)'" .

ex:ServicioMasterWin64_KPA a ex:ComponenteElectrico ;
    ex:textoExtracto "servicio 'Master (Win64)'" ;
    rdfs:label "Master (Win64)" .

ex:Esquema_Topologia_Bus_EtherCAT a ex:Esquema ;
    ex:textoExtracto "Se señalan hitos A–F (control del override, vacío, entrada, vacío con override máximo, mecanizado a FZ máx. y a FZ mín.) con leyenda y ejes temporales." ;
    ex:tieneComponente ex:HitoControlOverride, ex:HitoVacio, ex:HitoEntrada, ex:HitoVacioOverrideMaximo, ex:HitoMecanizadoFZMax, ex:HitoMecanizadoFZMin .

ex:HitoControlOverride a ex:Parametro ;
    ex:textoExtracto "control del override" .

ex:HitoVacio a ex:Parametro ;
    ex:textoExtracto "vacío" .

ex:HitoEntrada a ex:Parametro ;
    ex:textoExtracto "entrada" .

ex:HitoVacioOverrideMaximo a ex:Parametro ;
    ex:textoExtracto "vacío con override máximo" .

ex:HitoMecanizadoFZMax a ex:Parametro ;
    ex:textoExtracto "mecanizado a FZ máx." .

ex:HitoMecanizadoFZMin a ex:Parametro ;
    ex:textoExtracto "mecanizado a FZ mín." .

ex:CuadroDialogoErrorLicencia_1 a ex:InterfazUsuario ;
    ex:textoExtracto "Dos cuadros de diálogo de error/licencia: (1) aviso de 'No license found' al arrancar, con botón 'Browse' para seleccionar la unidad USB del dongle" ;
    ex:tieneComponente ex:BotonBrowse_Cuadro1 .

ex:BotonBrowse_Cuadro1 a ex:InterfazUsuario ;
    ex:textoExtracto "botón 'Browse' para seleccionar la unidad USB del dongle" ;
    rdfs:label "Browse" .

ex:CuadroDialogoErrorLicencia_2 a ex:InterfazUsuario ;
    ex:textoExtracto "advertencia de licencia durante la detección de módulos, indicada como ignorables con la licencia 'Básica'" .

ex:SecuenciaEscaneoOnline a ex:TareaMantenimiento ;
    ex:textoExtracto "Secuencia de capturas para el escaneo online del bus: selección del adaptador Ethernet, comando contextual 'Scan configuration' sobre el máster que descubre cabeceras, y pestaña 'MDP modules' con acción 'Upload detected Module Ident list'." ;
    ex:tieneComponente ex:AccionScanConfiguration, ex:PestanaMDPModules, ex:AccionUploadModuleIdentList .

ex:AccionScanConfiguration a ex:InterfazUsuario ;
    ex:textoExtracto "comando contextual 'Scan configuration' sobre el máster que descubre cabeceras" ;
    rdfs:label "Scan configuration" .

ex:PestanaMDPModules a ex:InterfazUsuario ;
    ex:textoExtracto "pestaña 'MDP modules'" ;
    rdfs:label "MDP modules" .

ex:AccionUploadModuleIdentList a ex:InterfazUsuario ;
    ex:textoExtracto "acción 'Upload detected Module Ident list'" ;
    rdfs:label "Upload detected Module Ident list" .

ex:VistaArbolNodosEsclavos a ex:InterfazUsuario ;
    ex:textoExtracto "la vista de árbol muestra nodos esclavos y módulos hallados" .