@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Sistema_1451_1 a ex:Sistema ;
    rdfs:label "Fagor EtherCAT Mapper" ;
    ex:textoExtracto "Vista general del 'Fagor EtherCAT Mapper': captura con (A) barra de iconos y nombre del ENI cargado, (B) barra de configuración por defecto (fichas de entradas/salidas y registros), (C) validación 'Overlapped', (D) topología en árbol, y (E) topología en bloques. Los bloques codifican tipo de recurso por color (DI/DO, registros, analógicas)." .

ex:InterfazUsuario_1451_2 a ex:InterfazUsuario ;
    rdfs:label "barra de iconos" ;
    ex:textoExtracto "barra de iconos y nombre del ENI cargado" ;
