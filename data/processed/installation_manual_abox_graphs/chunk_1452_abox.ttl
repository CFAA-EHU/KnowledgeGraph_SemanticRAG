@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Esquema_1452_761 a ex:Esquema ;
    ex:textoExtracto "Los bloques codifican tipo de recurso por color (DI/DO, registros, analógicas)." ;
    ex:tieneComponente ex:BloqueRecursosEtherCAT .

ex:Esquema_1452_761 a ex:Esquema ;
    ex:textoExtracto "Mapear los recursos EtherCAT a recursos del PLC" ;
    ex:tieneComponente ex:BarraConfiguracionEtherCAT, ex:VistaArbolEtherCAT .

ex:BarraConfiguracionEtherCAT a ex:InterfazUsuario ;
    ex:textoExtracto "barra de configuración por defecto para mapeo (fichas Digital Input/Output, Register Input/Output y Overlapped con campos 'Starts/Offset/Visible')" ;
    ex:tieneComponente ex:FichaDigitalInput, ex:FichaDigitalOutput, ex:FichaRegisterInput, ex:FichaRegisterOutput, ex:FichaOverlapped .

ex:FichaDigitalInput a ex:InterfazUsuario ;
    ex:textoExtracto "fichas Digital Input/Output" .

ex:FichaDigitalOutput a ex:InterfazUsuario ;
    ex:textoExtracto "fichas Digital Input/Output" .

ex:FichaRegisterInput a ex:InterfazUsuario ;
    ex:textoExtracto "fichas Register Input/Output" .

ex:FichaRegisterOutput a ex:InterfazUsuario ;
    ex:textoExtracto "fichas Register Input/Output" .

ex:FichaOverlapped a ex:InterfazUsuario ;
    ex:textoExtracto "fichas ... Overlapped con campos 'Starts/Offset/Visible'" .

ex:VistaArbolEtherCAT a ex:InterfazUsuario ;
    ex:textoExtracto "vista de árbol que despliega esclavos y módulos mostrando sus recursos; indicadores 'Starts/Offset' para numeración y opción 'Ver esclavos'" ;
    ex:tieneComponente ex:IndicadorStartsOffset, ex:OpcionVerEsclavos .

ex:IndicadorStartsOffset a ex:InterfazUsuario ;
    ex:textoExtracto "indicadores 'Starts/Offset' para numeración" .

ex:OpcionVerEsclavos a ex:InterfazUsuario ;
    ex:textoExtracto "opción 'Ver esclavos'" .

ex:BloqueRecursosEtherCAT a ex:InterfazUsuario ;
    ex:textoExtracto "Vista en bloques del bus con leyenda cromática: azul (entradas digitales), morado (salidas digitales), rojo/gris (mapeos a/desde registros PLC), verde/amarillo (AI/AO Fagor). La captura muestra tarjetas alineadas por cabecera, con numeración visible y separación por módulos." ;
    ex:tieneComponente ex:TarjetaEntradaDigital, ex:TarjetaSalidaDigital, ex:TarjetaRegistroPLC, ex:TarjetaAI_AO_Fagor .

ex:TarjetaEntradaDigital a ex:ComponenteElectrico ;
    ex:textoExtracto "azul (entradas digitales)" .

ex:TarjetaSalidaDigital a ex:ComponenteElectrico ;
    ex:textoExtracto "morado (salidas digitales)" .

ex:TarjetaRegistroPLC a ex:ComponenteElectrico ;
    ex:textoExtracto "rojo/gris (mapeos a/desde registros PLC)" .

ex:TarjetaAI_AO_Fagor a ex:ComponenteElectrico ;
    ex:textoExtracto "verde/amarillo (AI/AO Fagor)" .

ex:Esquema_1452_762 a ex:Esquema ;
    ex:textoExtracto "Dos ejemplos gráficos: (arriba) cambio global de numeración (DI primera=10, offset=100; DO primera=21, offset=50) aplicados desde la barra superior; (abajo) ajuste por nodo haciendo clic en el nombre de la cabecera para definir el inicio de sus recursos. Flechas indican dónde editar." ;
    ex:tieneComponente ex:EjemploNumeracionGlobal, ex:EjemploAjustePorNodo .

ex:EjemploNumeracionGlobal a ex:InterfazUsuario ;
    ex:textoExtracto "cambio global de numeración (DI primera=10, offset=100; DO primera=21, offset=50) aplicados desde la barra superior" .

ex:EjemploAjustePorNodo a ex:InterfazUsuario ;
    ex:textoExtracto "ajuste por nodo haciendo clic en el nombre de la cabecera para definir el inicio de sus recursos. Flechas indican dónde editar." .

ex:Esquema_1452_754 a ex:Esquema ;
    ex:textoExtracto "Cuadro de propiedades de un módulo en vista de bloques para redefinir el número inicial de sus recursos, numerándose el resto de forma correlativa. Se observan campos editables y previsualización del bloque afectado." ;
    ex:tieneComponente ex:CuadroPropiedadesModulo .