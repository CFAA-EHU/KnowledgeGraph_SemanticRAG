PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazUsuario_OpenPCSRemoto_21_21
    a                     ex:InterfazUsuario ;
    rdfs:label            "Interfaz de OpenPCS Remoto (Sección 21.21)"@es ;
    ex:textoExtracto       "Se observan campos editables y previsualización del bloque afectado."@es ;
    ex:ilustradoEn         ex:Esquema_OverlappedRight_Demo ;
    ex:ilustradoEn         ex:Esquema_OverlappedNo_Error ;
    ex:ilustradoEn         ex:Esquema_EntradasAnalogicas_Fagor_IB_IL_AI4_U-PAC ;
    ex:ilustradoEn         ex:Esquema_SalidasAnalogicas_Fagor_IB_IL_AO2_U-PAC ;
    ex:ilustradoEn         ex:Esquema_AccionesExportacion_OpenPCS .

ex:Esquema_OverlappedRight_Demo
    a                     ex:Esquema ;
    rdfs:label            "Demostración 'Overlapped = Right' en mapeo EtherCAT"@es ;
    ex:textoExtracto       "Demostración 'Overlapped = Right': al asignar un número ya existente, el mapeador reordena automáticamente los recursos posteriores (numeración superior), respetando los anteriores. La captura incluye bloques desplazados y avisos gráficos que señalan el solapamiento."@es ;
    ex:documentadoEn       ex:Pagina_755 .

ex:Esquema_OverlappedNo_Error
    a                     ex:Esquema ;
    rdfs:label            "Caso 'Overlapped = No' en mapeo EtherCAT"@es ;
    ex:textoExtracto       "Caso 'Overlapped = No': al duplicar numeración, el programa muestra un diálogo de error sobre el bloque implicado; se identifica la entrada I33 con icono de advertencia, impidiendo el solapamiento."@es ;
    ex:documentadoEn       ex:Pagina_756 ;
    ex:ilustradoEn         ex:AvisoSeguridad_Solapamiento_I33 .

ex:AvisoSeguridad_Solapamiento_I33
    a                     ex:AvisoSeguridad ;
    rdfs:label            "Advertencia de solapamiento en entrada I33"@es ;
    ex:textoExtracto       "se identifica la entrada I33 con icono de advertencia, impidiendo el solapamiento"@es ;
    ex:identificador       "I33" .

ex:ComponenteElectrico_EntradaAnalogica_Fagor_IB_IL_AI4_U-PAC
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Módulo de entradas analógicas Fagor (IB IL AI 4 - U-PAC)"@es ;
    ex:textoExtracto       "Propiedades de 'Entradas analógicas Fagor (IB IL AI 4 - U-PAC)': selección de primera entrada, rango de medición por canal y frecuencia de muestreo; interfaz con listas desplegables por canal."@es ;
    ex:identificador       "IB IL AI 4 - U-PAC" ;
    ex:detalladoEnEsquema  ex:Esquema_EntradasAnalogicas_Fagor_IB_IL_AI4_U-PAC ;
    ex:monitoreaParametro  ex:Parametro_FrecuenciaMuestreo_AI4 ;
    ex:monitoreaParametro  ex:Parametro_RangoMedicion_AI4 .

