ex:Esquema_AccionesExportacion_OpenPCS
    a                     ex:Esquema ;
    rdfs:label            "Acciones de exportación en OpenPCS Remoto"@es ;
    ex:textoExtracto       "Tres acciones ilustradas en capturas: (a) 'Export router file' para generar el XML de rutado, (b) 'Generate project' para guardar proyecto *.fem, (c) renombrar y copiar 'resourceRouterConf.xml' a ../Mtb/Data del CNC."@es ;
    ex:documentadoEn       ex:Pagina_762 ;
    ex:ilustradoEn         ex:InterfazUsuario_OpenPCSRemoto_21_21 .

