@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazDiagnosisEtherCAT
    a                     ex:InterfazUsuario ;
    rdfs:label            "Interfaz de diagnosis del bus EtherCAT en HMI del CNC"@es ;
    ex:textoExtracto       "Pantalla de diagnosis con tres paneles: información general del bus (estado del máster, contadores), detalle de esclavos (lista con estado/Info/Value) y detalle de módulos (árbol de dispositivos y panel derecho con valores). Disposición jerárquica y uso de iconos de estado."@es ;
    ex:ilustradoEn         ex:PantallaDiagnosisEtherCAT_759 .

ex:AlarmaError24499
    a                     ex:Alarma ;
    rdfs:label            "ERROR 24499 – EtherCAT: Error in slave"@es ;
    ex:identificador       "24499" ;
    ex:textoExtracto       "Captura de alarma 'ERROR 24499 – EtherCAT: Error in slave. More information in diagnostic' en la HMI del CNC, con barra roja, código y botones de navegación. Resalta el identificador del error y la indicación de consultar diagnosis."@es ;
    ex:activaAlarma        ex:InterfazDiagnosisEtherCAT .

ex:InterfazOpenPCSRemoto
    a                     ex:InterfazUsuario ;
    rdfs:label            "Interfaz de parametrización del PLC remoto en OpenPCS"@es ;
    ex:textoExtracto       "Captura del interfaz de parametrización del PLC remoto: tabla de significados para PLCTYPE (IEC/Fagor/IEC+Fagor) y efectos RUN/STOP/PLCREADY, junto a panel de opciones del CNC (IEC-61131) y botones aplicados. Se muestra también un cuadro con ruta de proyecto/plantilla de hardware."@es ;
    ex:ilustradoEn         ex:PantallaParametrizacionPLC_762 .

ex:DialogoConexionFagorCNCTCP
    a                     ex:InterfazUsuario ;
    rdfs:label            "Diálogo 'Connections → FagorCNCTCP → Edit' en OpenPCS"@es ;
    ex:textoExtracto       "(Elemento 1) Diálogo 'Connections → FagorCNCTCP → Edit' del OpenPCS para configurar conexión, con campos de nombre y parámetros. Se destaca el acceso a 'Settings'."@es ;
    ex:documentadoEn       ex:InterfazOpenPCSRemoto .

ex:PantallaDiagnosisEtherCAT_759
    a                     ex:Figura ;
    rdfs:label            "Pantalla de diagnosis EtherCAT (página 759)"@es ;
    ex:identificador       "759" ;
    ex:textoExtracto       "Pantalla de diagnosis con tres paneles: información general del bus, detalle de esclavos y detalle de módulos."@es .

ex:PantallaParametrizacionPLC_762
    a                     ex:Figura ;
    rdfs:label            "Pantalla de parametrización PLC remoto (página 762)"@es ;
    ex:identificador       "762" ;
    ex:textoExtracto       "Captura del interfaz de parametrización del PLC remoto con tabla de significados PLCTYPE y panel de opciones CNC."@es .