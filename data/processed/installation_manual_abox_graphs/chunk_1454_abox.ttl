@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_34926084ce a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Anotar Y1. la cota que aparece en el CNC, denominada en el dibujo" .

ns1:CalculoDeLasDimensionesConAyudaDelCNC_bf0c640313 a ns1:TareaMantenimiento ;
    rdfs:label "Cálculo de las dimensiones con ayuda del CNC",
        "Técnico autorizado" ;
    ns1:ejecutadoPor ns1:PersonalTecnico ;
    ns1:textoExtracto "Cálculo de las coordenadas del eje A. En el dibujo se muestran dos posiciones distintas que tienen en común el centro del eje A." .

ns1:CoordenadaEnElEjeY_3a060a75cc a ns1:Parametro ;
    rdfs:label "Coordenada en el eje Y" ;
    ns1:textoExtracto "la coordenada en el eje Y es el parámetro TDATA3" .

ns1:CoordenadaEnElEjeZ a ns1:Parametro ;
    rdfs:label "Coordenada en el eje Z" ;
    ns1:textoExtracto "la coordenada en el eje Z es Pz" .

