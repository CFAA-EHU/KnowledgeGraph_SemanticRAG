@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:DialogoRutasConfirmaciones rdfs:label "diálogos con rutas y confirmaciones" ;
    ex:textoExtracto "Se muestran diálogos con rutas y confirmaciones." ;
    a ex:InterfazUsuario .

ex:PantallaDiagnosisBusEtherCAT a ex:InterfazUsuario ;
    ex:textoExtracto "Pantalla de diagnosis con tres paneles: información general del bus (estado del máster, contadores), detalle de esclavos (lista con estado/Info/Value) y detalle de módulos (árbol de dispositivos y panel derecho con valores). Disposición jerárquica y uso de iconos de estado." ;
    ex:compuestoPor ex:PanelInformacionGeneral, ex:PanelDetalleEsclavos, ex:PanelDetalleModulos .

ex:PanelInformacionGeneral a ex:InterfazUsuario ;
    ex:textoExtracto "información general del bus (estado del máster, contadores)" .

ex:PanelDetalleEsclavos a ex:InterfazUsuario ;
    ex:textoExtracto "detalle de esclavos (lista con estado/Info/Value)" .

ex:PanelDetalleModulos a ex:InterfazUsuario ;
    ex:textoExtracto "detalle de módulos (árbol de dispositivos y panel derecho con valores)" .

ex:CapturaAlarmaError24499 a ex:Alarma ;
    ex:textoExtracto "Captura de alarma 'ERROR 24499 – EtherCAT: Error in slave. More information in diagnostic' en la HMI del CNC, con barra roja, código y botones de navegación. Resalta el identificador del error y la indicación de consultar diagnosis." ;
    ex:identificador "ERROR 24499" ;
    ex:tieneComponente ex:HMI_CNC .

ex:HMI_CNC a ex:InterfazUsuario ;
    ex:textoExtracto "en la HMI del CNC" .

ex:VistaArbolConfiguracion a ex:InterfazUsuario ;
    ex:textoExtracto "Vista de árbol de configuración localizando el nodo en error y panel derecho con 'Info/Value' del módulo afectado, para análisis detallado. Iconos a la izquierda marcan jerarquía de cabeceras y módulos." ;
    ex:compuestoPor ex:ArbolConfiguracion, ex:PanelInfoValue .

ex:ArbolConfiguracion a ex:InterfazUsuario ;
    ex:textoExtracto "árbol de configuración localizando el nodo en error" .

ex:PanelInfoValue a ex:InterfazUsuario ;
    ex:textoExtracto "panel derecho con 'Info/Value' del módulo afectado" .

ex:InterfazParametrizacionPLCRemoto a ex:InterfazUsuario ;
    ex:textoExtracto "Captura del interfaz de parametrización del PLC remoto: tabla de significados para PLCTYPE (IEC/Fagor/IEC+Fagor) y efectos RUN/STOP/PLCREADY, junto a panel de opciones del CNC (IEC-61131) y botones aplicados. Se muestra también un cuadro con ruta de proyecto/plantilla de hardware." ;
    ex:compuestoPor ex:TablaPLCTYPE, ex:PanelOpcionesCNC, ex:CuadroRutaProyecto .

ex:TablaPLCTYPE a ex:Tabla ;
    ex:textoExtracto "tabla de significados para PLCTYPE (IEC/Fagor/IEC+Fagor)" .

ex:PanelOpcionesCNC a ex:InterfazUsuario ;
    ex:textoExtracto "panel de opciones del CNC (IEC-61131)" .

ex:CuadroRutaProyecto a ex:InterfazUsuario ;
    ex:textoExtracto "cuadro con ruta de proyecto/plantilla de hardware" .

ex:DialogoConexionFagorCNCTCP a ex:InterfazUsuario ;
    ex:textoExtracto "Diálogo 'Connections → FagorCNCTCP → Edit' del OpenPCS para configurar conexión, con campos de nombre y parámetros. Se destaca el acceso a 'Settings'." ;
    ex:compuestoPor ex:CampoNombre, ex:CampoParametros, ex:BotonSettings .

ex:CampoNombre a ex:InterfazUsuario ;
    ex:textoExtracto "campos de nombre" .

ex:CampoParametros a ex:InterfazUsuario ;
    ex:textoExtracto "parámetros" .

ex:BotonSettings a ex:InterfazUsuario ;
    ex:textoExtracto "botones aplicados" .