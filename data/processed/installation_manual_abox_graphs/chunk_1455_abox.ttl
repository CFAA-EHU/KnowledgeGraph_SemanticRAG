@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:DialogoConexionesFagorCNCTCP a ex:InterfazUsuario ;
    rdfs:label "Diálogo \"Connections → FagorCNCTCP → Edit\" del OpenPCS para configurar conexión"@es ;
    ex:textoExtracto "Diálogo \"Connections → FagorCNCTCP → Edit\" del OpenPCS para configurar conexión, con campos de nombre y parámetros. Se destaca el acceso a \"Settings\"."@es ;
    ex:compuestoPor ex:CampoNombreConexion, ex:CampoParametrosConexion, ex:BotonSettings .

ex:CampoNombreConexion a ex:Parametro ;
    rdfs:label "Campo de nombre de conexión"@es ;
    ex:textoExtracto "campos de nombre"@es .

ex:CampoParametrosConexion a ex:Parametro ;
    rdfs:label "Campo de parámetros de conexión"@es ;
    ex:textoExtracto "campos de parámetros"@es .

ex:BotonSettings a ex:InterfazUsuario ;
    rdfs:label "Botón Settings"@es ;
    ex:textoExtracto "acceso a \"Settings\""@es .

ex:DialogoSettingsConexion a ex:InterfazUsuario ;
    rdfs:label "Diálogo \"Settings\" de la conexión"@es ;
    ex:textoExtracto "Diálogo \"Settings\" de la conexión mostrando edición de la dirección IP (sustitución de 127.0.0.1 por la IP del CNC); campos de host/puerto y botones \"OK/Cancel\"."@es ;
    ex:compuestoPor ex:CampoDireccionIP, ex:CampoHostPuerto, ex:BotonOK, ex:BotonCancel .

ex:CampoDireccionIP a ex:Parametro ;
    rdfs:label "Campo de dirección IP"@es ;
    ex:textoExtracto "edición de la dirección IP (sustitución de 127.0.0.1 por la IP del CNC)"@es .

ex:CampoHostPuerto a ex:Parametro ;
    rdfs:label "Campo de host/puerto"@es ;
    ex:textoExtracto "campos de host/puerto"@es .

ex:BotonOK a ex:InterfazUsuario ;
    rdfs:label "Botón OK"@es ;
    ex:textoExtracto "botones \"OK/Cancel\""@es .

ex:BotonCancel a ex:InterfazUsuario ;
    rdfs:label "Botón Cancel"@es ;
    ex:textoExtracto "botones \"OK/Cancel\""@es .