@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:CoordenadaDelEjeA a ns1:Parametro ;
    rdfs:label "Coordenada del eje A" ;
    ns1:identificador "Pz" ;
    ns1:textoExtracto "Pz | Coordenada del eje A." .

ns1:CotaQueIndicaElCNCEnLaDireccionX a ns1:Parametro ;
    rdfs:label "Cota que indica el CNC en la dirección X" ;
    ns1:identificador "ΔX" ;
    ns1:textoExtracto "TDATA2 = ΔX +r+ E" .

ns1:CotaQueIndicaElCNCEnLaDireccionZ a ns1:Parametro ;
    rdfs:label "Cota que indica el CNC en la dirección Z" ;
    ns1:identificador "ΔZ" ;
    ns1:textoExtracto "Calculo de los parámetros. F = ΔZ – Pz" .

ns1:DistanciaDesdeLaSuperficieDeLaMesaHastaElEjeA a ns1:Parametro ;
    rdfs:label "Distancia desde la superficie de la mesa hasta el eje A" ;
    ns1:identificador "F" ;
    ns1:textoExtracto "Calculo de los parámetros. F = ΔZ – Pz" .

ns1:DistanciaDesdeLaSuperficieDeLaMesaHastaElEjeB a ns1:Parametro ;
    rdfs:label "Distancia desde la superficie de la mesa hasta el eje B" ;
    ns1:identificador "E" ;
    ns1:textoExtracto "E = 0.5·(ΔX + ΔZ +2R+r)" .

ns1:RadioDeLaBolaDelPalpador_ae3fa73def a ns1:Parametro ;
    rdfs:label "Radio de la bola del palpador" ;
    ns1:identificador "r" ;
    ns1:textoExtracto "TDATA2 = ΔX +r+ E" .

ns1:RadioDelCilindro a ns1:Parametro ;
    rdfs:label "Radio del cilindro" ;
    ns1:identificador "R" ;
    ns1:textoExtracto "E = 0.5·(ΔX + ΔZ +2R+r)" .

