@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Parametro_DeltaY1 a ns1:Parametro ;
    rdfs:label "ΔY1" ;
    ns1:documentadoEn ns1:Tabla_17_3_1 ;
    ns1:textoExtracto "ΔY1, ΔZ1 [...] Cotas que indica el CNC." .

ns1:Parametro_DeltaY2 a ns1:Parametro ;
    rdfs:label "ΔY2" ;
    ns1:documentadoEn ns1:Tabla_17_3_1 ;
    ns1:textoExtracto "ΔY1, ΔY2 [...] Cotas que indica el CNC." .

ns1:Parametro_DeltaZ1 a ns1:Parametro ;
    rdfs:label "ΔZ1" ;
    ns1:documentadoEn ns1:Tabla_17_3_1 ;
    ns1:textoExtracto "ΔZ1, ΔZ2 [...] Cotas que indica el CNC." .

ns1:Parametro_DeltaZ2 a ns1:Parametro ;
    rdfs:label "ΔZ2" ;
    ns1:documentadoEn ns1:Tabla_17_3_1 ;
    ns1:textoExtracto "ΔZ1, ΔZ2 [...] Cotas que indica el CNC." .

ns1:Parametro_Pz a ns1:Parametro ;
    rdfs:label "Pz" ;
    ns1:documentadoEn ns1:Tabla_17_3_1 ;
    ns1:textoExtracto "Pz = 05Z + Z –R" ;
    ns1:valor "0.5*(ΔZ1 + ΔZ2 - R)"^^xsd:string .

ns1:Parametro_RadioCilindro a ns1:Parametro ;
    rdfs:label "R" ;
    ns1:documentadoEn ns1:Tabla_17_3_1 ;
    ns1:textoExtracto "R | Radio del cilindro." ;
    ns1:valor "Radio del cilindro (mm)"^^xsd:string .

ns1:Parametro_TDATA2 a ns1:Parametro ;
    rdfs:label "TDATA2" ;
    ns1:ilustradoEn ns1:Esquema_17_3_2 ;
    ns1:textoExtracto "TDATA2 (mostrado en esquema)" .

ns1:Parametro_TDATA3 a ns1:Parametro ;
    rdfs:label "TDATA3" ;
    ns1:documentadoEn ns1:Tabla_17_3_1 ;
    ns1:textoExtracto "TDATA3 = 05Y + Y " ;
    ns1:valor "0.5*(ΔY1 + ΔY2)"^^xsd:string .

ns1:Parametro_TDATA4 a ns1:Parametro ;
    rdfs:label "TDATA4" ;
    ns1:ilustradoEn ns1:Esquema_17_3_2 ;
    ns1:textoExtracto "TDATA4 (mostrado en esquema)" .

ns1:Parametro_TDATA5 a ns1:Parametro ;
    rdfs:label "TDATA5" ;
    ns1:ilustradoEn ns1:Esquema_17_3_2 ;
    ns1:textoExtracto "TDATA5 (mostrado en esquema)" .

ns1:Parametro_X1 a ns1:Parametro ;
    rdfs:label "X1" ;
    ns1:ilustradoEn ns1:Esquema_17_3_2 ;
    ns1:textoExtracto "Anotar X1, la cota que aparece en el CNC, denominada en el dibujo Δ" .

ns1:Parametro_X_Palpado a ns1:Parametro ;
    rdfs:label "X (cota palpada en eje X)" ;
    ns1:ilustradoEn ns1:Esquema_17_3_2 ;
    ns1:textoExtracto "Anotar la cota que aparece en el CNC, denominada en el dibujo X. Δ" .

ns1:Parametro_Z_Palpado a ns1:Parametro ;
    rdfs:label "Z (cota palpada en eje Z, punto 2)" ;
    ns1:ilustradoEn ns1:Esquema_17_3_2 ;
    ns1:textoExtracto "Anotar la cota que aparece en el CNC, denominada en el dibujo Z. Δ" .

ns1:Sistema_MesaRotativa a ns1:Sistema ;
    rdfs:label "Sistema de mesa rotativa con ejes A y B"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_17_3_2 ;
    ns1:documentadoEn ns1:Tabla_17_3_1 ;
    ns1:textoExtracto "Mesa rotativa. Cálculo de las dimensiones con ayuda de un [...] Preselección de origen en X. A=90º B=-90º" .

ns1:Esquema_17_3_2 a ns1:Esquema ;
    rdfs:label "Esquema de preselección de origen y palpado en mesa rotativa"@es ;
    ns1:textoExtracto """
Preselección de origen en X. A=90º B=-90º [...]
En el dibujo se muestran dos posiciones distintas del eje B manteniendo la posición del eje A. A=0º A=0º
1 B=-90º B=0º
""" .

ns1:Tabla_17_3_1 a ns1:Tabla ;
    rdfs:label "Tabla de fórmulas para cálculo de dimensiones de mesa rotativa"@es ;
    ns1:textoExtracto """
| Solución. |  |
| --- | --- |
| TDATA3 = 05Y + Y 
1 2
Pz = 05Z + Z –R
1 2
| TDATA3, Pz | Coordenada del eje A. |
| Y1, Z1, Y2, Z2 | Cotas que indica el CNC. |
| R | Radio del cilindro. |
""" .

