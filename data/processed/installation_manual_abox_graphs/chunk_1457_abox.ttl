ns1:OptimizacionDelControlDinamicoDelMecanizadoDMC a ns1:TareaMantenimiento ;
    rdfs:label "Optimización del control dinámico del mecanizado (DMC)" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "El DMC adapta el avance modificando el override. El DMC optimiza el uso de la máquina y la herramienta, lo que permite aumentar la tasa de arranque de material (MRR o material removal rate), sin perjudicar la vida de la herramienta." .

ns1:Parametro_609f33a725 a ns1:Parametro ;
    rdfs:label "Parámetro de habilitación del control dinámico del mecanizado (DMC)" ;
    ns1:identificador "DMCSPDL" ;
    ns1:textoExtracto "El cabezal debe estar habilitado para al DMC en el parámetro máquina DMCSPDL." .

ns1:Componente_55e7504b29 a ns1:Componente ;
    rdfs:label "Herramienta" ;
    ns1:textoExtracto "El DMC optimiza el uso de la máquina y la herramienta, lo que permite aumentar la tasa de arranque de material (MRR o material removal rate), sin perjudicar la vida de la herramienta." .

ns1:Componente_7acc22a294 a ns1:Componente ;
