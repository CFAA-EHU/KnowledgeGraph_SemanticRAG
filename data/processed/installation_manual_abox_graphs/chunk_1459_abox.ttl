@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DMC_ControlDinamicoMecanizado a ns1:Sistema ;
    rdfs:label "DMC (Control Dinámico del Mecanizado)"@es ;
    ns1:controla ns1:CabezalMaster ;
    ns1:monitoreaParametro ns1:ParametroAvanceMecanizado ;
    ns1:textoExtracto "El DMC (control dinámico del mecanizado) adapta el avance durante el mecanizado para mantener la potencia de corte lo más cercana posible a las condiciones idóneas de mecanizado. El DMC adapta el avance modificando el override."@es .

ns1:HerramientaMecanizado a ns1:Herramienta ;
    rdfs:label "Herramienta de mecanizado"@es ;
    ns1:requiereMantenimiento ns1:RevisionPorDesgasteDeHerramienta ;
    ns1:textoExtracto "La elección del avance de mecanizado depende del material a mecanizar, de la herramienta (material, número de dientes, etc) y de la profundidad de pasada."@es .

ns1:CabezalMaster a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal máster"@es ;
    ns1:habilitadoPor ns1:ParametroDMCSPDL ;
    ns1:textoExtracto "El DMC sólo está disponible para el cabezal máster, con regulación digital Fagor (versión V9.01 o superior)."@es .

ns1:ParametroAvanceMecanizado a ns1:Parametro ;
    rdfs:label "Avance de mecanizado"@es ;
    ns1:textoExtracto "El avance para un mecanizado se fija al comienzo del mismo y permanece constante hasta el final. [...] El DMC adapta el avance durante el mecanizado para mantener la potencia de corte lo más cercana posible a las condiciones idóneas."@es ;
    ns1:valor "variable (adaptado dinámicamente)"@es .

ns1:ParametroDMCSPDL a ns1:Parametro ;
    rdfs:label "Parámetro máquina DMCSPDL"@es ;
    ns1:identificador "DMCSPDL" ;
    ns1:textoExtracto "El cabezal debe estar habilitado para el DMC en el parámetro máquina DMCSPDL."@es .

ns1:RevisionPorDesgasteDeHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Revisión por desgaste de herramienta"@es ;
    ns1:textoExtracto "Si las condiciones del mecanizado cambian (por ejemplo, por el desgaste de la herramienta), el avance programado puede no ser ya el adecuado"@es .

