@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SWTG0FEED a ex:Parametro ;
    rdfs:label "SWTG0FEED" ;
    ex:textoExtracto "SWTG0FEED" ;
    ex:valor "Significado" .

ex:Parametro_G00FEED a ex:Parametro ;
    rdfs:label "G00FEED" ;
    ex:textoExtracto "parámetro G00FEED" .

ex:Parametro_G1 a ex:Parametro ;
    rdfs:label "G1" ;
    ex:textoExtracto "avance del G1/G2/G3 anterior" .

ex:Parametro_G2 a ex:Parametro ;
    rdfs:label "G2" ;
    ex:textoExtracto "avance del G1/G2/G3 anterior" .

ex:Parametro_G3 a ex:Parametro ;
    rdfs:label "G3" ;
    ex:textoExtracto "avance del G1/G2/G3 anterior" .

ex:Comando_SWTOUT a ex:Parametro ;
    rdfs:label "#SWTOUT" ;
    ex:textoExtracto "con la sentencia #SWTOUT" .

ex:ModoOperacion_AvanceRapido a ex:ModoOperacion ;
    rdfs:label "avance rápido" ;
    ex:textoExtracto "avance rápido (parámetro G00FEED)" .

ex:ModoOperacion_AvanceConstante a ex:ModoOperacion ;
    rdfs:label "avance constante" ;
    ex:textoExtracto "avance constante (con el avance del G1/G2/G3 anterior)" .

ex:Sistema_HistoriaVisualizacion a ex:Sistema ;
    rdfs:label "historia" ;
    ex:textoExtracto "en la historia se visualiza G0" .