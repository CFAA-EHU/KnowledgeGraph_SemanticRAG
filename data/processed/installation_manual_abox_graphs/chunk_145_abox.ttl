@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeSalidasDigitalesDelBloqueLogico a ns1:Parametro ;
    rdfs:label "Número de salidas digitales del bloque lógico" ;
    ns1:identificador "MPG.DOMODNDO" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.DOMODNDO[nb] Número de salidas digitales del bloque lógico; no puede ser cero y debe ser un múltiplo de 8 (8, 16, 24, ...1024)." .

ns1:SistemaHidraulico a ns1:Sistema ;
    rdfs:label "Sistema Hidraulico" ;
    ns1:textoExtracto "Se deben parametrizar todos los recursos de un nodo; no se pueden dejar I/Os sin numerar." .

