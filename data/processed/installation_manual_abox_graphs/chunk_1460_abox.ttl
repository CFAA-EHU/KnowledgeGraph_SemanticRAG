@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PorcentajeDeAvanceFeedOverrideCalculadoPorElDMC a ns1:Parametro ;
    rdfs:label "Porcentaje de avance (feed override) calculado por el DMC"@es ;
    ns1:identificador "DMCOVR" ;
    ns1:textoExtracto "\"(V.)G.DMCOVR | Porcentaje de avance (feed override) calculado por el DMC. Unidades: Porcentaje.\""@es .

ns1:PotenciaActivaEnElCabezalMedidaPorElDMCPorcentajeDeLaPotenciaNominal_bd84d845cb a ns1:Parametro ;
    rdfs:label "Potencia activa en el cabezal, medida por el DMC (porcentaje de la potencia nominal)"@es ;
    ns1:identificador "DMCACTPWR" ;
    ns1:textoExtracto "\"(V.)G.DMCACTPWR | Potencia activa en el cabezal, medida por el DMC (porcentaje de la potencia nominal). Unidades: Porcentaje.\""@es .

ns1:PotenciaObjetivoCalculadaPorElDMCEnLaFaseDeAprendizajePorcentajeDeLaP_385a46ea75 a ns1:Parametro ;
    rdfs:label "Potencia objetivo calculada por el DMC en la fase de aprendizaje (porcentaje de la potencia nominal)"@es ;
    ns1:identificador "GLEARNEDPWRSP" ;
    ns1:textoExtracto "\"(V.)G.LEARNEDPWRSP | Potencia objetivo calculada por el DMC en la fase de aprendizaje (porcentaje de la potencia nominal). Esta variable no incluye la potencia en vacío. Unidades: Porcentaje.\""@es .

