@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarDMCConSentenciaDMCON a ns1:AccionProhibida ;
    rdfs:label "Activar DMC con sentencia #DMCON" ;
    ns1:solucionaFallo ns1:DiagnosticoFalloTiempoMecanizado,
        ns1:DiagnosticoFalloVidaHerramienta ;
    ns1:textoExtracto "#DMCON activa el DMC, siempre sobre el cabezal master." .

ns1:HerramientaTipoFresado a ns1:Herramienta ;
    rdfs:label "Herramienta Tipo Fresado" ;
    ns1:textoExtracto "El DMC sólo está disponible para operaciones de fresado con herramientas de tipo 'Fresado' y 'Planeado'." .

ns1:HerramientaTipoPlaneado a ns1:Herramienta ;
    rdfs:label "Herramienta Tipo Planeado" ;
    ns1:textoExtracto "El DMC sólo está disponible para operaciones de fresado con herramientas de tipo 'Fresado' y 'Planeado'." .

ns1:SistemaDMC a ns1:Sistema ;
    rdfs:label "Sistema DMC" ;
    ns1:textoExtracto "El DMC sólo está disponible para operaciones de fresado con herramientas de tipo 'Fresado' y 'Planeado'." .

