@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaximoAvancePorDientePermitidoDuranteElDMC_43cfc60ed1 a ns1:Parametro ;
    rdfs:label "Máximo avance por diente permitido durante el DMC" ;
    ns1:identificador "FZMAX" ;
    ns1:textoExtracto "FZMAX{feed} Máximo avance por diente permitido durante el DMC." .

ns1:MaximoOverridePermitidoParaElDMC a ns1:Parametro ;
    rdfs:label "Máximo override permitido para el DMC" ;
    ns1:identificador "OVRMAX" ;
    ns1:textoExtracto "OVRMAX{%} Máximo override permitido para el DMC. • Opcional (por defecto, el valor del parámetro máquina MAXDMCOVR). • Valores: 100 — 255 %." .

ns1:MinimoAvancePorDientePermitidoDuranteElDMC a ns1:Parametro ;
    rdfs:label "Mínimo avance por diente permitido durante el DMC" ;
    ns1:identificador "FZMIN" ;
    ns1:textoExtracto "FZMIN{feed} Mínimo avance por diente permitido durante el DMC. • Opcional; si no se programa o FZMIN > FZMAX, el CNC no vigila el avance mínimo por diente. • Valores: 0 — 99999.9999 mm/diente 0 — 3937.00787 pulgada/diente." .

ns1:MinimoOverridePermitidoParaElDMC a ns1:Parametro ;
    rdfs:label "Mínimo override permitido para el DMC" ;
    ns1:identificador "OVRMIN" ;
    ns1:textoExtracto "OVRMIN{%} Mínimo override permitido para el DMC. • Opcional (por defecto, el valor del parámetro máquina MINDMCOVR). • Valores: 10 — 100 %." .

