@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "Control Numérico Computarizado (CNC)"@es ;
    ns1:textoExtracto "El CNC siempre respeta el límite máximo definido en el parámetro máquina MAXOVR"@es ;
    ns1:tieneComponente ns1:InterfazUsuario_ConmutadorOverride,
        ns1:Sistema_DMC .

ns1:InterfazUsuario_ConmutadorOverride a ns1:InterfazUsuario ;
    rdfs:label "Conmutador de override del panel de mando"@es ;
    ns1:controla ns1:Sistema_DMC ;
    ns1:textoExtracto "el usuario selecciona desde el conmutador del panel de mando, un override"@es .

ns1:Parametro_MAXOVR a ns1:Parametro ;
    rdfs:label "Límite máximo de override (MAXOVR)"@es ;
    ns1:identificador "MAXOVR" ;
    ns1:textoExtracto "el límite máximo definido en el parámetro máquina MAXOVR"@es .

ns1:Parametro_MINDMCOVR a ns1:Parametro ;
    rdfs:label "Límite mínimo de override para DMC (MINDMCOVR)"@es ;
    ns1:identificador "MINDMCOVR" ;
    ns1:textoExtracto "un override por debajo de MINDMCOVR"@es .

ns1:Parametro_VG_PRGFRO a ns1:Parametro ;
    rdfs:label "Porcentaje de avance por programa (V.G.PRGFRO)"@es ;
    ns1:identificador "V.G.PRGFRO" ;
    ns1:textoExtracto "el porcentaje de avance fijado por programa (variable V.G.PRGFRO)"@es .

ns1:Parametro_V_PLC_FRO a ns1:Parametro ;
    rdfs:label "Porcentaje de avance por PLC (V.PLC.FRO)"@es ;
    ns1:identificador "V.PLC.FRO" ;
    ns1:textoExtracto "el porcentaje de avance [...] por PLC (variable V.PLC.FRO)"@es .

ns1:Sistema_DMC a ns1:Sistema ;
    rdfs:label "Sistema DMC (Dynamic Machining Control)"@es ;
    ns1:monitoreaParametro ns1:Parametro_MAXOVR,
        ns1:Parametro_MINDMCOVR,
        ns1:Parametro_VG_PRGFRO,
        ns1:Parametro_V_PLC_FRO ;
    ns1:textoExtracto "el CNC inhibe el DMC (no lo desactiva); cuando el override vuelva a superar MINDMCOVR, el DMC volverá a funcionar con normalidad"@es .

