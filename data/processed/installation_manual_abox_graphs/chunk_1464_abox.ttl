@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_377925dccb a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controladoPor ns1:PotenciaDeReferencia,
        ns1:ValorMaximoDeAvancePorDiente,
        ns1:ValorMaximoDeSobrecarga,
        ns1:ValorMinimoDeAvancePorDiente,
        ns1:ValorMinimoDeSobrecarga ;
    ns1:textoExtracto "#DMC ON (El CNC activa el DMC con los valores por defecto)." .

ns1:PotenciaDeReferencia a ns1:Parametro ;
    rdfs:label "Potencia de referencia" ;
    ns1:identificador "PWRSP" ;
    ns1:textoExtracto "#DMC ON [PWRSP 80, OVRMIN 90, OVRMAX 110, FZMIN 0.8, FZMAX 1.3] (El CNC activa el DMC con los valores programados)." .

ns1:ValorMaximoDeAvancePorDiente a ns1:Parametro ;
    rdfs:label "Valor máximo de avance por diente" ;
    ns1:identificador "FZMAX" ;
    ns1:textoExtracto "#DMC ON [PWRSP 80, OVRMIN 90, OVRMAX 110, FZMIN 0.8, FZMAX 1.3] (El CNC activa el DMC con los valores programados)." .

ns1:ValorMaximoDeSobrecarga a ns1:Parametro ;
    rdfs:label "Valor máximo de sobrecarga" ;
    ns1:identificador "OVRMAX" ;
    ns1:textoExtracto "#DMC ON [PWRSP 80, OVRMIN 90, OVRMAX 110, FZMIN 0.8, FZMAX 1.3] (El CNC activa el DMC con los valores programados)." .

ns1:ValorMinimoDeAvancePorDiente a ns1:Parametro ;
    rdfs:label "Valor mínimo de avance por diente" ;
    ns1:identificador "FZMIN" ;
    ns1:textoExtracto "#DMC ON [PWRSP 80, OVRMIN 90, OVRMAX 110, FZMIN 0.8, FZMAX 1.3] (El CNC activa el DMC con los valores programados)." .

ns1:ValorMinimoDeSobrecarga a ns1:Parametro ;
    rdfs:label "Valor mínimo de sobrecarga" ;
    ns1:identificador "OVRMIN" ;
    ns1:textoExtracto "#DMC ON [PWRSP 80, OVRMIN 90, OVRMAX 110, FZMIN 0.8, FZMAX 1.3] (El CNC activa el DMC con los valores programados)." .

