@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinirDatosDeLaHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Definir datos de la herramienta" ;
    ns1:textoExtracto "Para que el CNC pueda vigilar el avance por diente, hay que definir el número de dientes de la herramienta en la tabla de herramientas." .

ns1:PotenciaObjetivo_aa6fbb373f a ns1:Parametro ;
    rdfs:label "Potencia Objetivo" ;
    ns1:textoExtracto "La potencia objetivo se programa como un porcentaje de la potencia nominal del cabezal." .

ns1:ProgramacionDelDMC a ns1:TareaMantenimiento ;
    rdfs:label "Programación del DMC" ;
    ns1:documentadoEn ns1:CNC8070_08a7c2aab2 ;
    ns1:textoExtracto "La programación de la potencia objetivo es opcional; si no se programa, el CNC realiza una fase de aprendizaje para determinarla." .

ns1:CNC8070_08a7c2aab2 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controladoPor ns1:SistemaDMC ;
    ns1:textoExtracto "El CNC realiza una fase de aprendizaje para determinarla." .

ns1:SistemaDMC a ns1:Sistema ;
    rdfs:label "DMC" ;
    ns1:textoExtracto "El DMC sólo puede estar activo en ejecución; en simulación, el CNC analizará las sentencias de activación y desactivación, pero no pondrá en marcha el DMC." .

