@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoAutomatico a ns1:ModoOperacion ;
    rdfs:label "modo automático" ;
    ns1:textoExtracto "El DMC sólo puede estar activo en modo automático;" .

ns1:ModoManual a ns1:ModoOperacion ;
    rdfs:label "modo manual" ;
    ns1:textoExtracto "no se activa en modo manual." .

ns1:Parametro_11fe20083e a ns1:Parametro ;
    rdfs:label "corrector" ;
    ns1:textoExtracto "Cambio de herramienta o corrector." .

ns1:SistemaDMC a ns1:Sistema ;
    rdfs:label "DMC" ;
    ns1:requiereMantenimiento ns1:CambioDeHerramienta_a508b893d0,
        ns1:EjecutarUnaM6,
        ns1:InspeccionDeHerramienta_8f5d51ea12 ;
    ns1:textoExtracto "El DMC sólo puede estar activo en modo automático; no se activa en modo manual." .

ns1:CambioDeHerramienta_a508b893d0 a ns1:TareaMantenimiento ;
    rdfs:label "cambio de herramienta" ;
    ns1:textoExtracto "Cambiar la herramienta." .

ns1:EjecutarUnaM6 a ns1:AccionProhibida ;
    rdfs:label "ejecutar una M6" ;
    ns1:textoExtracto "Ejecutar una M6." .

ns1:InspeccionDeHerramienta_8f5d51ea12 a ns1:TareaMantenimiento ;
    rdfs:label "inspección de herramienta" ;
    ns1:textoExtracto "El entrar en el modo de inspección de herramienta, el DMC se desactiva." .

