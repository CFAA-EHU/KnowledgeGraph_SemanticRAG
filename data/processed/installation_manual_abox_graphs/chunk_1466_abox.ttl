@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_DMC a ns1:ModoOperacion ;
    rdfs:label "Dynamic Milling Control (DMC)"@es ;
    ns1:monitoreaParametro ns1:Parametro_FZMAX,
        ns1:Parametro_FZMIN,
        ns1:Parametro_OVRMAX,
        ns1:Parametro_OVRMIN ;
    ns1:textoExtracto "18.2 Programar el DMC. - 18.2.1 Activar el DMC."@es .

ns1:Parametro_FZMAX a ns1:Parametro ;
    rdfs:label "Máximo avance por diente durante el DMC (FZMAX)"@es ;
    ns1:identificador "FZMAX" ;
    ns1:textoExtracto "FZMAX{feed} Máximo avance por diente permitido durante el DMC."@es .

ns1:Parametro_FZMIN a ns1:Parametro ;
    rdfs:label "Mínimo avance por diente durante el DMC (FZMIN)"@es ;
    ns1:identificador "FZMIN" ;
    ns1:textoExtracto "FZMIN{feed} Mínimo avance por diente permitido durante el DMC. • Opcional; si no se programa o FZMIN > FZMAX, el CNC no vigila el avance mínimo por diente. • Valores: 0 — 99999.9999 mm/diente 0 — 3937.00787 pulgada/diente."@es ;
    ns1:valor "0-99999.9999 mm/diente" .

ns1:Parametro_OVRMAX a ns1:Parametro ;
    rdfs:label "Máximo override permitido para el DMC (OVRMAX)"@es ;
    ns1:identificador "OVRMAX" ;
    ns1:textoExtracto "OVRMAX{%} Máximo override permitido para el DMC. • Opcional (por defecto, el valor del parámetro máquina MAXDMCOVR). • Valores: 100 — 255 %."@es ;
    ns1:valor "100-255%" .

ns1:Parametro_OVRMIN a ns1:Parametro ;
    rdfs:label "Mínimo override permitido para el DMC (OVRMIN)"@es ;
    ns1:identificador "OVRMIN" ;
    ns1:textoExtracto "OVRMIN{%} Mínimo override permitido para el DMC. • Opcional (por defecto, el valor del parámetro máquina MINDMCOVR). • Valores: 10 — 100 %."@es ;
    ns1:valor "10-100%" .

