@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Comando_DMC_ON_Defecto a ns1:ModoOperacion ;
    rdfs:label "Comando DMC ON (valores por defecto)" ;
    ns1:identificador "DMC ON" ;
    ns1:textoExtracto "#DMC ON (El CNC activa el DMC con los valores por defecto). (El DMC inicia la fase de aprendizaje para calcular la potencia objetivo)." .

ns1:Comando_DMC_ON_Programado_Completo a ns1:ModoOperacion ;
    rdfs:label "Comando DMC ON (valores programados completos)" ;
    ns1:habilitadoPor ns1:Fase_Aprendizaje_DMC ;
    ns1:identificador "DMC ON [PWRSP 80, OVRMIN 90, OVRMAX 110, FZMIN 0.8, FZMAX 1.3]" ;
    ns1:monitoreaParametro ns1:Parametro_FZMAX,
        ns1:Parametro_FZMIN,
        ns1:Parametro_OVRMAX,
        ns1:Parametro_OVRMIN,
        ns1:Parametro_PWRSP ;
    ns1:textoExtracto "#DMC ON [PWRSP 80, OVRMIN 90, OVRMAX 110, FZMIN 0.8, FZMAX 1.3] (El CNC activa el DMC con los valores programados)." .

ns1:Comando_DMC_ON_Programado_Parcial a ns1:ModoOperacion ;
    rdfs:label "Comando DMC ON (valores programados parciales)" ;
    ns1:habilitadoPor ns1:Fase_Aprendizaje_DMC ;
    ns1:identificador "DMC ON [OVRMIN 90, OVRMAX 110, FZMIN 0.8, FZMAX 1.3]" ;
    ns1:monitoreaParametro ns1:Parametro_FZMAX,
        ns1:Parametro_FZMIN,
        ns1:Parametro_OVRMAX,
        ns1:Parametro_OVRMIN ;
    ns1:textoExtracto "#DMC ON [OVRMIN 90, OVRMAX 110, FZMIN 0.8, FZMAX 1.3] (El CNC activa el DMC con los valores programados). (El DMC inicia la fase de aprendizaje para calcular la potencia objetivo)." .

ns1:Parametro_PWRSP a ns1:Parametro ;
    rdfs:label "PWRSP (Potencia objetivo)" ;
    ns1:identificador "PWRSP" ;
    ns1:textoExtracto "PWRSP 80" ;
    ns1:valor "80" .

ns1:Fase_Aprendizaje_DMC a ns1:ModoOperacion ;
    rdfs:label "Fase de aprendizaje del DMC" ;
    ns1:identificador "Fase_Aprendizaje_DMC" ;
    ns1:textoExtracto "(El DMC inicia la fase de aprendizaje para calcular la potencia objetivo)." .

ns1:Parametro_FZMAX a ns1:Parametro ;
    rdfs:label "FZMAX (Factor de fuerza máximo)" ;
    ns1:identificador "FZMAX" ;
    ns1:textoExtracto "FZMAX 1.3" ;
    ns1:valor "1.3" .

ns1:Parametro_FZMIN a ns1:Parametro ;
    rdfs:label "FZMIN (Factor de fuerza mínimo)" ;
    ns1:identificador "FZMIN" ;
    ns1:textoExtracto "FZMIN 0.8" ;
    ns1:valor "0.8" .

ns1:Parametro_OVRMAX a ns1:Parametro ;
    rdfs:label "OVRMAX (Límite máximo de sobrecarga)" ;
    ns1:identificador "OVRMAX" ;
    ns1:textoExtracto "OVRMAX 110" ;
    ns1:valor "110" .

ns1:Parametro_OVRMIN a ns1:Parametro ;
    rdfs:label "OVRMIN (Límite mínimo de sobrecarga)" ;
    ns1:identificador "OVRMIN" ;
    ns1:textoExtracto "OVRMIN 90" ;
    ns1:valor "90" .

