@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_3578e78550 a ns1:AccionProhibida ;
    rdfs:label "Herramienta dentro de la pieza" ;
    ns1:textoExtracto "Si la herramienta está dentro de la pieza, el DMC se desactiva, pero seguirá detectando las salidas de pieza y los consumos excesivos de potencia." .

ns1:AccionProhibida_65ca19232a a ns1:AccionProhibida ;
    rdfs:label "Herramienta saliendo de la pieza" ;
    ns1:textoExtracto "Si la herramienta está saliendo de la pieza, el DMC se desactiva cuando finaliza la salida." .

ns1:AccionProhibida_7563b2927f a ns1:AccionProhibida ;
    rdfs:label "Herramienta entrando en la pieza" ;
    ns1:textoExtracto "Si la herramienta está entrando en la pieza, el DMC se desactivará cuando termine la entrada." .

ns1:EsperaAQueElCabezalAlcanceLaVelocidadProgramada a ns1:AccionProhibida ;
    rdfs:label "Espera a que el cabezal alcance la velocidad programada" ;
    ns1:textoExtracto "Si el DMC está esperando a que el cabezal alcance la velocidad programada o está midiendo la potencia en vacío, el DMC se desactiva cuando acabe de medir la potencia en vacío." .

ns1:MedicionDePotenciaEnVacio a ns1:AccionProhibida ;
    rdfs:label "Medición de potencia en vacío" ;
    ns1:textoExtracto "Si el DMC está esperando a que el cabezal alcance la velocidad programada o está midiendo la potencia en vacío, el DMC se desactiva cuando acabe de medir la potencia en vacío." .

ns1:ParadaDeEjesConSTOPDesactivaTemporalmenteDMC a ns1:AccionProhibida ;
    rdfs:label "Parada de ejes con [STOP] desactiva temporalmente DMC" ;
    ns1:textoExtracto "Las trayectorias en G0, parada de ejes con [STOP] y la softkey \"Set DMC off\" desactivan temporalmente DMC." .

ns1:SoftkeySetDMCOffDesactivaTemporalmenteDMC a ns1:AccionProhibida ;
    rdfs:label "Softkey Set DMC off desactiva temporalmente DMC" ;
    ns1:textoExtracto "Las trayectorias en G0, parada de ejes con [STOP] y la softkey \"Set DMC off\" desactivan temporalmente DMC." .

ns1:TrayectoriasEnG0DesactivanTemporalmenteDMC a ns1:AccionProhibida ;
    rdfs:label "Trayectorias en G0 desactivan temporalmente DMC" ;
    ns1:textoExtracto "Las trayectorias en G0, parada de ejes con [STOP] y la softkey \"Set DMC off\" desactivan temporalmente DMC." .

