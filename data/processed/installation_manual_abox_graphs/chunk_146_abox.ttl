@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeLaEntradaAnalogicaAsociadaACadaUnaDeLasEntradasPT100Activas a ns1:Parametro ;
    rdfs:label "Número de la entrada analógica asociada a cada una de las entradas PT100 activas" ;
    ns1:identificador "MPG.PT100[nb]" ;
    ns1:textoExtracto "PT100 n Entrada analógica asociada a la entrada PT100. Valores posibles: De 0 a 32. Valor por defecto: 0 (no se desea activar la entrada PT100). Variable asociada: (V.)MPG.PT100[nb]" ;
    ns1:valor "0" .

ns1:NumeroTotalDeEntradasPT100Activas a ns1:Parametro ;
    rdfs:label "Número total de entradas PT100 activas" ;
    ns1:identificador "MPG.NPT100" ;
    ns1:textoExtracto "NPT100 Número total de entradas PT100 activas. Valores posibles: De 0 a 10. Valor por defecto: 0 (no hay entradas PT100 activas). Variable asociada: (V.)MPG.NPT100" ;
    ns1:valor "0" .

