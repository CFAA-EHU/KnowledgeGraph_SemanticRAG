@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PWMOUTPUT a ex:Parametro ;
    rdfs:label "PWMOUTPUT" ;
    ex:identificador "PWMOUTPUT" ;
    ex:textoExtracto "PWMOUTPUT Salida digital local asociada al PWM. Valores posibles: De 0 a 2. Valor por defecto: 0. Variable asociada: (V.)MPG.PWMOUTPUT Salida digital local asociada al PWM. Para el PWM sólo se podrán utilizar las salidas locales asociadas a los pines LI/O1 (salida local 1) y LI/O2 (salida local 2), ya que están personalizadas para aplicaciones de láser. Para ello será necesario parametrizar el parámetro NLOCOUT con valor 8." ;
    ex:valor "0 a 2" .

ex:PWMCANCEL a ex:Parametro ;
    rdfs:label "PWMCANCEL" ;
    ex:identificador "PWMCANCEL" ;
    ex:textoExtracto "PWMCANCEL Cancelar el PWM tras M30 o reset. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPG.PWMCANCEL Este parámetro indica si el CNC cancela el PWM tras ejecutar M02, M30 o después de un reset." ;
    ex:valor "Sí / No" .

ex:LI_O1 a ex:ComponenteElectrico ;
    rdfs:label "LI/O1" ;
    ex:identificador "LI/O1" ;
    ex:textoExtracto "Para el PWM sólo se podrán utilizar las salidas locales asociadas a los pines LI/O1 (salida local 1) y LI/O2 (salida local 2)" .

ex:LI_O2 a ex:ComponenteElectrico ;
    rdfs:label "LI/O2" ;
    ex:identificador "LI/O2" ;
    ex:textoExtracto "Para el PWM sólo se podrán utilizar las salidas locales asociadas a los pines LI/O1 (salida local 1) y LI/O2 (salida local 2)" .

ex:NLOCOUT a ex:Parametro ;
    rdfs:label "NLOCOUT" ;
    ex:identificador "NLOCOUT" ;
    ex:textoExtracto "Para ello será necesario parametrizar el parámetro NLOCOUT con valor 8." ;
    ex:valor "8" .

ex:SWTOUTPUT a ex:Parametro ;
    rdfs:label "SWTOUTPUT" ;
    ex:identificador "SWTOUTPUT" ;
    ex:textoExtracto "La salida para el PWM y para la conmutación sincronizada puede ser la misma y se pueden usar a la vez (mismo valor en los parámetros SWTOUTPUT y PWMOUTPUT)." .

ex:M30 a ex:AccionProhibida ;
    rdfs:label "M30" ;
    ex:identificador "M30" ;
    ex:textoExtracto "PWMCANCEL Cancelar el PWM tras M30 o reset." .

ex:M02 a ex:AccionProhibida ;
    rdfs:label "M02" ;
    ex:identificador "M02" ;
    ex:textoExtracto "Este parámetro indica si el CNC cancela el PWM tras ejecutar M02, M30 o después de un reset." .

ex:PLC a ex:Sistema ;
    rdfs:label "PLC" ;
    ex:textoExtracto "Cuando hay un error de CNC en el canal que tiene activo el PWM (o en cualquier canal si la gestión se hace desde PLC)" .