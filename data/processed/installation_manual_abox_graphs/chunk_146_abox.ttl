@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_PWMOUTPUT
    a ex:Parametro ;
    rdfs:label "PWMOUTPUT" ;
    ex:textoExtracto "PWMOUTPUT Salida digital local asociada al PWM. Valores posibles: De 0 a 2. Valor por defecto: 0." ;
    ex:valor "0"^^xsd:integer ;
    ex:identificador "V.MPG.PWMOUTPUT" .

ex:Parametro_PWMCANCEL
    a ex:Parametro ;
    rdfs:label "PWMCANCEL" ;
    ex:textoExtracto "PWMCANCEL Cancelar el PWM tras M30 o reset. Valores posibles: Sí / No. Valor por defecto: No." ;
    ex:valor "No"^^xsd:string ;
    ex:identificador "V.MPG.PWMCANCEL" .

ex:Tabla_ValoresPWMOUTPUT a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de valores PWMOUTPUT" ;
    ex:textoExtracto "| PWMOUTPUT | Significado. | --- | --- | 0 | No hay PWM. | 1 | Salida local 1 (pin LI/O1). | 2 | Salida local 2 (pin LI/O2)." .

ex:ComponenteElectrico_LIO1
    a ex:ComponenteElectrico ;
    rdfs:label "Salida local 1 (LI/O1)" ;
    ex:textoExtracto "Salida local 1 (pin LI/O1)." .

ex:ComponenteElectrico_LIO2
    a ex:ComponenteElectrico ;
    rdfs:label "Salida local 2 (LI/O2)" ;
    ex:textoExtracto "Salida local 2 (pin LI/O2)." .

ex:Parametro_NLOCOUT
    a ex:Parametro ;
    rdfs:label "NLOCOUT" ;
    ex:textoExtracto "Para el PWM sólo se podrán utilizar las salidas locales asociadas a los pines LI/O1 (salida local 1) y LI/O2 (salida local 2), ya que están personalizadas para aplicaciones de láser. Para ello será necesario parametrizar el parámetro NLOCOUT con valor 8." ;
    ex:valor "8"^^xsd:integer .

ex:Parametro_SWTOUTPUT
    a ex:Parametro ;
    rdfs:label "SWTOUTPUT" ;
    ex:textoExtracto "La salida para el PWM y para la conmutación sincronizada puede ser la misma y se pueden usar a la vez (mismo valor en los parámetros SWTOUTPUT y PWMOUTPUT)." .