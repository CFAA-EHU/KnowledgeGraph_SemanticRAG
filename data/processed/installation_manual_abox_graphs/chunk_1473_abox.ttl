    rdfs:label "Mínimo avance por diente permitido durante el DMC" ;
    ns1:identificador "G.DMCFZMIN" ;
    ns1:textoExtracto "(V.)[ch].G.DMCFZMIN Mínimo avance por diente permitido durante el DMC." .

ns1:MinimoPorcentajeDeAvancePermitidoParaElDMC a ns1:Parametro ;
    rdfs:label "Mínimo porcentaje de avance permitido para el DMC" ;
    ns1:identificador "G.DMCOVRMIN" ;
    ns1:textoExtracto "(V.)[ch].G.DMCOVRMIN Mínimo porcentaje de avance (feed override) permitido para el DMC." .

ns1:NumeroDeDientesDelCorrectorDeLaHerramienta_acfc59f0aa a ns1:Parametro ;
    rdfs:label "Número de dientes del corrector de la herramienta" ;
    ns1:identificador "TM.NCUTTERST" ;
