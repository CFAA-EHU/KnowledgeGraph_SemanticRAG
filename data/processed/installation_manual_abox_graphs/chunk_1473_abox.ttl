    ns1:identificador "G.DMCFZMAX" ;
    ns1:textoExtracto "(V.)[ch].G.DMCFZMAX Máximo avance por diente permitido durante el DMC." .

ns1:MaximoPorcentajeDeAvancePermitidoParaElDMC a ns1:Parametro ;
    rdfs:label "Máximo porcentaje de avance permitido para el DMC" ;
    ns1:identificador "G.DMCOVRMAX" ;
    ns1:textoExtracto "(V.)[ch].G.DMCOVRMAX Máximo porcentaje de avance (feed override) permitido para el DMC." .

