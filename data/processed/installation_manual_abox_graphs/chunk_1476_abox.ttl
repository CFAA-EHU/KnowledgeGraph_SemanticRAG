@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Componente_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de la máquina"@es ;
    ns1:monitoreaParametro ns1:Parametro_DMCACTPWR,
        ns1:Parametro_DMCNOLOADPWR ;
    ns1:textoExtracto "Componente mecánico cuya potencia (activa y en vacío) es medida y controlada por el DMC."@es .

ns1:Sistema_DMC a ns1:Sistema ;
    rdfs:label "Dynamic Machining Control (DMC)"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables_18_2_3 ;
    ns1:monitoreaParametro ns1:Parametro_DMCACTPWR,
        ns1:Parametro_DMCFZ,
        ns1:Parametro_DMCNOLOADPWR,
        ns1:Parametro_DMCOVR,
        ns1:Parametro_DMCSAVEDTIME,
        ns1:Parametro_LEARNEDPWRSP ;
    ns1:textoExtracto "Sistema que calcula y mide parámetros como potencia objetivo, potencia activa en el cabezal, avance por diente, y tiempo ahorrado en operaciones de mecanizado."@es .

ns1:Parametro_DMCFZ a ns1:Parametro ;
    rdfs:label "Avance por diente (DMC)"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables_18_2_3 ;
    ns1:identificador "(V.)[ch].G.DMCFZ" ;
    ns1:textoExtracto "Avance por diente calculado por el DMC. Unidades: Milímetros/diente o pulgadas/diente."@es ;
    ns1:valor "---"^^xsd:string .

ns1:Parametro_DMCOVR a ns1:Parametro ;
    rdfs:label "Porcentaje de avance (feed override) del DMC"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables_18_2_3 ;
    ns1:identificador "(V.)[ch].G.DMCOVR" ;
    ns1:textoExtracto "Porcentaje de avance (feed override) calculado por el DMC. Unidades: Porcentaje."@es ;
    ns1:valor "---"^^xsd:string .

ns1:Parametro_DMCSAVEDTIME a ns1:Parametro ;
    rdfs:label "Tiempo ahorrado por acción del DMC"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables_18_2_3 ;
    ns1:identificador "(V.)[ch].G.DMCSAVEDTIME" ;
    ns1:textoExtracto "Tiempo ahorrado por acción del DMC. Unidades: Segundos."@es ;
    ns1:valor "---"^^xsd:string .

ns1:Parametro_LEARNEDPWRSP a ns1:Parametro ;
    rdfs:label "Potencia objetivo calculada por el DMC (fase aprendizaje)"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables_18_2_3 ;
    ns1:identificador "(V.)[ch].G.LEARNEDPWRSP" ;
    ns1:textoExtracto "Potencia objetivo calculada por el DMC en la fase de aprendizaje (porcentaje de la potencia nominal). Unidades: Porcentaje."@es ;
    ns1:valor "---"^^xsd:string .

ns1:Parametro_DMCACTPWR a ns1:Parametro ;
    rdfs:label "Potencia activa en el cabezal (DMC)"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables_18_2_3 ;
    ns1:identificador "(V.)[ch].G.DMCACTPWR" ;
    ns1:textoExtracto "Potencia activa en el cabezal, medida por el DMC (porcentaje de la potencia nominal). Unidades: Porcentaje."@es ;
    ns1:valor "---"^^xsd:string .

ns1:Parametro_DMCNOLOADPWR a ns1:Parametro ;
    rdfs:label "Potencia del cabezal en vacío (DMC)"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables_18_2_3 ;
    ns1:identificador "(V.)[ch].G.DMCNOLOADPWR" ;
    ns1:textoExtracto "Potencia del cabezal en vacío medida por el DMC. Unidades: Kilowatios."@es ;
    ns1:valor "---"^^xsd:string .

ns1:Tabla_ResumenVariables_18_2_3 a ns1:Tabla ;
    rdfs:label "Resumen de las variables del DMC"@es ;
    ns1:documentadoEn ns1:Pagina_725_726 ;
    ns1:textoExtracto """
    (V.)[ch].G.LEARNEDPWRSP | Potencia objetivo calculada por el DMC en la fase de aprendizaje (porcentaje de la potencia nominal).
    (V.)[ch].G.DMCACTPWR | Potencia activa en el cabezal, medida por el DMC (porcentaje de la potencia nominal).
    (V.)[ch].G.DMCOVR | Porcentaje de avance (feed override) calculado por el DMC.
    (V.)[ch].G.DMCFZ | Avance por diente calculado por el DMC.
    (V.)[ch].G.DMCNOLOADPWR | Potencia del cabezal en vacío medida por el DMC.
    (V.)[ch].G.DMCSAVEDTIME | Tiempo ahorrado por acción del DMC.
    """@es .

