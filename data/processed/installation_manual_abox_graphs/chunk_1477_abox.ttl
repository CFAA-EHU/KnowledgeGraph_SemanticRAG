    rdfs:label "CNC 8070" ;
    ns1:controla ns1:Componente_abb19860d7 ;
    ns1:ejecuta ns1:MedicionDePotenciaEnVacio_590a8d6a4d ;
    ns1:textoExtracto "el CNC activará el DMC siempre y cuando el cabezal tenga regulación digital, esté girando en M3 o M4 y haya alcanzado la velocidad de giro programada (marca REVOK)." .

