@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AprendizajeDMC a ns1:AccionProhibida ;
    rdfs:label "Aprendizaje DMC" ;
    ns1:textoExtracto "La fase de aprendizaje se puede repetir en cualquier momento, con el DMC activo, pulsando la softkey \"Aprendizaje DMC\" del modo automático." .

ns1:FaseAprendizajeDMC a ns1:Componente ;
    rdfs:label "Fase de Aprendizaje DMC" ;
    ns1:textoExtracto "La fase de aprendizaje comienza cuando el DMC detecta la entrada a la pieza y dura un minuto, a partir de que la herramienta entre en la pieza una distancia igual al radio." .

ns1:Herramienta_678693a3ad a ns1:Herramienta ;
    rdfs:label "Herramienta de DMC" ;
    ns1:textoExtracto "La herramienta entra y sale de la pieza durante el proceso de aprendizaje." .

ns1:PotenciaObjetivo_21b39cc5a9 a ns1:Parametro ;
    rdfs:label "Potencia Objetivo" ;
    ns1:textoExtracto "El DMC calcula la potencia objetivo (\"potencia consumida\" – \"potencia en vacío\")." .

