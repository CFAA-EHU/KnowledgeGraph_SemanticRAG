@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ValorDeLaPotenciaObjetivoObtenidaEnLaFaseDeAprendizaje a ns1:Parametro ;
    rdfs:label "Valor de la potencia objetivo obtenida en la fase de aprendizaje" ;
    ns1:identificador "GLEARNEDPWRSP" ;
    ns1:textoExtracto "El DMC escribirá en la variable (V.)G.LEARNEDPWRSP el valor de la potencia objetivo obtenida en la fase de aprendizaje, para que se pueda utilizar en las" .

ns1:Herramienta a ns1:Herramienta ;
    rdfs:label "Herramienta" ;
    ns1:textoExtracto "Si la herramienta sale de la pieza, deja de contar el tiempo hasta que la herramienta vuelva a entrar en la pieza." .

