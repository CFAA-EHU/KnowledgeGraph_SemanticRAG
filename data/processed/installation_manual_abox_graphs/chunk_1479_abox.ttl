@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "CNC con control DMC" ;
    ns1:controla ns1:DMC_ModoOperacion ;
    ns1:textoExtracto "el CNC activará el DMC [...] el CNC detiene el avance de los ejes hasta que el cabezal alcanza la velocidad de giro programada [...] el CNC mide la potencia consumida por el cabezal en vacío." ;
    ns1:tieneComponente ns1:ComponenteElectrico_Cabezal .

ns1:Parametro_PotenciaObjetivo a ns1:Parametro ;
    rdfs:label "Potencia objetivo (PWRSP)" ;
    ns1:identificador "PWRSP" ;
    ns1:textoExtracto "comando PWRSP" .

ns1:ComponenteElectrico_Cabezal a ns1:ComponenteElectrico ;
    rdfs:label "Cabezal con regulación digital" ;
    ns1:monitoreaParametro ns1:Parametro_PotenciaVacio,
        ns1:Parametro_VelocidadGiro ;
    ns1:textoExtracto "el cabezal tenga regulación digital, esté girando en M3 o M4 y haya alcanzado la velocidad de giro programada (marca REVOK)." .

ns1:DMC_ModoOperacion a ns1:ModoOperacion ;
    rdfs:label "DMC (Dynamic Milling Control)" ;
    ns1:identificador "#DMCON" ;
    ns1:requiereMantenimiento ns1:FaseAprendizaje_DMC ;
    ns1:textoExtracto "Tras ejecutar la sentencia #DMCON, el CNC activará el DMC siempre y cuando el cabezal tenga regulación digital, esté girando en M3 o M4 y haya alcanzado la velocidad de giro programada (marca REVOK)." .

ns1:FaseAprendizaje_DMC a ns1:TareaMantenimiento ;
    rdfs:label "Fase de aprendizaje del DMC" ;
    ns1:textoExtracto "Cada vez que se programa #DMCON sin potencia objetivo (comando PWRSP), el DMC la determina mediante una fase de aprendizaje que éste pondrá en marcha automáticamente." .

ns1:Parametro_PotenciaVacio a ns1:Parametro ;
    rdfs:label "Potencia en vacío del cabezal" ;
    ns1:textoExtracto "el CNC mide la potencia consumida por el cabezal en vacío (sin mecanizar)." ;
    ns1:valor "medida durante detención de ejes" .

ns1:Parametro_VelocidadGiro a ns1:Parametro ;
    rdfs:label "Velocidad de giro programada (REVOK)" ;
    ns1:identificador "REVOK" ;
    ns1:textoExtracto "velocidad de giro programada (marca REVOK)." .

