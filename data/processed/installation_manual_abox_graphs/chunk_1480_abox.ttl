@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_781a4e4115 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 3103" ;
    ns1:textoExtracto "Si el DMC detecta una situación de este tipo, muestra el aviso 3103." .

ns1:FaseDeAprendizajeDelDMC a ns1:TareaMantenimiento ;
    rdfs:label "Fase de Aprendizaje del DMC" ;
    ns1:textoExtracto "Se recomienda realizar la fase de aprendizaje con una profundidad de pasada lo más aproximada posible a la que se va utilizar durante el mecanizado." .

ns1:ValorDeLaPotenciaObjetivoObtenidaEnLaFaseDeAprendizaje a ns1:Parametro ;
    rdfs:label "Valor de la potencia objetivo obtenida en la fase de aprendizaje" ;
    ns1:identificador "GLEARNEDPWRSP" ;
    ns1:textoExtracto "El DMC escribirá en la variable (V.)G.LEARNEDPWRSP el valor de la potencia objetivo obtenida en la fase de aprendizaje." .

