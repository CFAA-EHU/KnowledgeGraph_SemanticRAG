@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DMC_1481 a ns1:Sistema ;
    rdfs:label "DMC (Sistema de Control)"@es ;
    ns1:monitoreaParametro ns1:Variable_G_LEARNEDPWRSP_1481 ;
    ns1:textoExtracto "El DMC escribirá en la variable (V.)G.LEARNEDPWRSP el valor de la potencia objetivo obtenida en la fase de aprendizaje"@es .

ns1:Variable_G_LEARNEDPWRSP_1481 a ns1:Parametro ;
    rdfs:label "Variable G.LEARNEDPWRSP"@es ;
    ns1:identificador "V.G.LEARNEDPWRSP" ;
    ns1:textoExtracto "la variable (V.)G.LEARNEDPWRSP el valor de la potencia objetivo obtenida en la fase de aprendizaje"@es ;
    ns1:valor "potencia_objetivo_aprendizaje" .

