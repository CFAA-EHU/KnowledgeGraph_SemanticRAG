@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_3103 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 3103: Potencia objetivo insuficiente"@es ;
    ns1:activaAlarma ns1:DMC_ModoOperacion ;
    ns1:identificador "3103" ;
    ns1:textoExtracto "Si el DMC detecta una situación de este tipo, muestra el aviso 3103."@es .

ns1:FaseAprendizaje_DMC a ns1:TareaMantenimiento ;
    rdfs:label "Fase de aprendizaje del DMC"@es ;
    ns1:requiereMantenimiento ns1:DMC_ModoOperacion ;
    ns1:textoExtracto "Se recomienda realizar la fase de aprendizaje con una profundidad de pasada lo más aproximada posible a la que se va utilizar durante el mecanizado; en caso contrario, si la profundidad de pasada es más pequeña, la potencia objetivo calculada puede no ser la apropiada."@es .

ns1:OverrideAvance_DMC a ns1:Parametro ;
    rdfs:label "Override de avance (feed override) en DMC"@es ;
    ns1:controla ns1:DMC_ModoOperacion ;
    ns1:textoExtracto "El DMC adapta el avance modificando el override. [...] Para las entradas en la pieza, el DMC utiliza un 75 % de avance hasta que la herramienta entra en la pieza en una longitud igual al radio de la herramienta."@es ;
    ns1:valor "75% en entradas; adaptativo durante mecanizado"@es .

ns1:PotenciaObjetivo_DMC a ns1:Parametro ;
    rdfs:label "Potencia objetivo del DMC"@es ;
    ns1:monitoreaParametro ns1:DMC_ModoOperacion ;
    ns1:textoExtracto "potencia objetivo obtenida en la fase de aprendizaje [...] la potencia objetivo (programada u obtenida mediante el aprendizaje) debe ser al menos un 20 % de la potencia en vacío"@es ;
    ns1:valor ">=20% de la potencia en vacío"@es .

ns1:Variable_G_LEARNEDPWRSP a ns1:Parametro ;
    rdfs:label "Variable G.LEARNEDPWRSP"@es ;
    ns1:identificador "G.LEARNEDPWRSP" ;
    ns1:monitoreaParametro ns1:DMC_ModoOperacion ;
    ns1:textoExtracto "El DMC escribirá en la variable (V.)G.LEARNEDPWRSP el valor de la potencia objetivo obtenida en la fase de aprendizaje, para que se pueda utilizar en las siguientes piezas que se mecanicen con el mismo programa pieza"@es .

ns1:DMC_ModoOperacion a ns1:ModoOperacion ;
    rdfs:label "Modo de operación DMC (Dynamic Milling Control)"@es ;
    ns1:identificador "DMC" ;
    ns1:textoExtracto "Funcionamiento del DMC. Una vez conocida la potencia objetivo, y tras detectar la entrada a la pieza, comenzará el funcionamiento normal del DMC. Durante el mecanizado, el DMC adapta el avance para que la potencia de corte ('potencia consumida' – 'potencia en vacío') sea lo más cercana posible a la potencia objetivo."@es .

