@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DMC_1483 a ns1:Sistema ;
    rdfs:label "Sistema DMC"@es ;
    ns1:activaAlarma ns1:Aviso_3103 ;
    ns1:monitoreaParametro ns1:Parametro_PotenciaObjetivo_1483,
        ns1:Parametro_PotenciaVacio_1483 ;
    ns1:textoExtracto "Para garantizar un funcionamiento correcto del DMC, la potencia objetivo (programada u obtenida mediante el aprendizaje) debe ser al menos un 20 % de la potencia en vacío. Si el DMC detecta una situación de este tipo, muestra el aviso 3103."@es .

ns1:Aviso_3103 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso 3103"@es ;
    ns1:identificador "3103" ;
    ns1:textoExtracto "Si el DMC detecta una situación de este tipo, muestra el aviso 3103."@es .

ns1:Parametro_PotenciaObjetivo_1483 a ns1:Parametro ;
    rdfs:label "Potencia objetivo (DMC)"@es ;
    ns1:textoExtracto "la potencia objetivo (programada u obtenida mediante el aprendizaje) debe ser al menos un 20 % de la potencia en vacío."@es .

ns1:Parametro_PotenciaVacio_1483 a ns1:Parametro ;
    rdfs:label "Potencia en vacío (DMC)"@es ;
    ns1:textoExtracto "la potencia objetivo [...] debe ser al menos un 20 % de la potencia en vacío."@es .

