@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_9b350730ec a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Durante la ejecución de un programa con el DMC activo, el modo automático puede mostrar el estado y el progreso de esta función;" ;
    ns1:tieneComponente ns1:AvancePorDiente,
        ns1:EstadoDelDMC_83ab4666c2,
        ns1:OverrideDelDMC_0de385671c,
        ns1:OverrideFinal,
        ns1:PotenciaConsumida,
        ns1:PotenciaObjetivo,
        ns1:TiempoAhorrado .

ns1:ModoAutomatico a ns1:ModoOperacion ;
    rdfs:label "Modo Automático" ;
    ns1:textoExtracto "el modo automático puede mostrar el estado y el progreso de esta función" .

ns1:AvancePorDiente a ns1:AvisoSeguridad ;
    rdfs:label "Avance por diente" ;
    ns1:textoExtracto "C Avance por diente. Los límites de la barra de consumo son los valores programados en la sentencia #DMCON (comandos FZMIN y FZMAX)" .

ns1:EstadoDelDMC_83ab4666c2 a ns1:AvisoSeguridad ;
    rdfs:label "Estado del DMC" ;
    ns1:textoExtracto "A Estado del DMC; ON/OFF." .

ns1:OverrideDelDMC_0de385671c a ns1:AvisoSeguridad ;
    rdfs:label "Override del DMC" ;
    ns1:textoExtracto "B Override del DMC. Los límites de la barra de consumo serán los definidos en los parámetros máquina." .

ns1:OverrideFinal a ns1:AvisoSeguridad ;
    rdfs:label "Override final" ;
    ns1:textoExtracto "J Override final (override del DMC + override del conmutador)." .

ns1:PotenciaConsumida a ns1:AvisoSeguridad ;
    rdfs:label "Potencia consumida por el cabezal" ;
    ns1:textoExtracto "D Potencia consumida por el cabezal (definida como porcentaje de la potencia nominal)." .

ns1:PotenciaObjetivo a ns1:AvisoSeguridad ;
    rdfs:label "Potencia objetivo o potencia de corte idónea" ;
    ns1:textoExtracto "F Potencia objetivo o potencia de corte idónea (definida como porcentaje de la potencia nominal)" .

ns1:TiempoAhorrado a ns1:AvisoSeguridad ;
    rdfs:label "Tiempo ahorrado por acción del DMC" ;
    ns1:textoExtracto "H Tiempo ahorrado por acción del DMC." .

