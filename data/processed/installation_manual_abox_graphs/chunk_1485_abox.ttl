@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_6a5b5c54fe a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC siempre respeta el límite máximo definido en el parámetro máquina MAXOVR." ;
    ns1:tieneComponente ns1:LimiteMaximoDeAvance_07e3da1d2e,
        ns1:LimiteMaximoDeDMC,
        ns1:LimiteMinimoDeDMC,
        ns1:VariableDeProgramaParaPorcentajeDeAvance,
        ns1:VariablePLCParaPorcentajeDeAvance .

ns1:LimiteMaximoDeAvance_07e3da1d2e a ns1:Parametro ;
    rdfs:label "Límite máximo de avance" ;
    ns1:identificador "MAXOVR" ;
    ns1:textoExtracto "El CNC siempre respeta el límite máximo definido en el parámetro máquina MAXOVR." .

ns1:LimiteMaximoDeDMC a ns1:Parametro ;
    rdfs:label "Límite máximo de DMC" ;
    ns1:identificador "MAXDMCOVR" ;
    ns1:textoExtracto "los límites estarán fijados por los parámetros máquina MINDMCOVR y MAXDMCOVR." .

ns1:LimiteMinimoDeDMC a ns1:Parametro ;
    rdfs:label "Límite mínimo de DMC" ;
    ns1:identificador "MINDMCOVR" ;
    ns1:textoExtracto "los límites estarán fijados por los parámetros máquina MINDMCOVR y MAXDMCOVR." .

ns1:VariableDeProgramaParaPorcentajeDeAvance a ns1:Parametro ;
    rdfs:label "Variable de programa para porcentaje de avance" ;
    ns1:identificador "V.G.PRGFRO" ;
    ns1:textoExtracto "El porcentaje de avance (feed override) se puede fijar, de más a menos prioridad, por programa (variable V.G.PRGFRO)" .

ns1:VariablePLCParaPorcentajeDeAvance a ns1:Parametro ;
    rdfs:label "Variable PLC para porcentaje de avance" ;
    ns1:identificador "V.PLC.FRO" ;
    ns1:textoExtracto "El porcentaje de avance (feed override) se puede fijar, de más a menos prioridad, por programa (variable V.G.PRGFRO), por PLC (variable V.PLC.FRO)" .

