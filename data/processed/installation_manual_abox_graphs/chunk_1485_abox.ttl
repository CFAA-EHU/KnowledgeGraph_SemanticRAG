@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DMC_ModoAutomatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático con DMC activo" ;
    ns1:textoExtracto "Durante la ejecución de un programa con el DMC activo, el modo automático puede mostrar el estado y el progreso de esta función" ;
    ns1:tieneComponente ns1:InterfazUsuario_DMC_MenuOpciones,
        ns1:InterfazUsuario_DMC_Visualizacion,
        ns1:Parametro_DMC_AvancePorDiente,
        ns1:Parametro_DMC_Override,
        ns1:Parametro_DMC_OverrideFinal,
        ns1:Parametro_DMC_PotenciaConsumida,
        ns1:Parametro_DMC_PotenciaObjetivo,
        ns1:Parametro_DMC_PotenciaVacio,
        ns1:Parametro_DMC_TiempoAhorrado .

ns1:ComponenteMecanico_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de la máquina" ;
    ns1:compuestoPor ns1:Maquina_Brochadora ;
    ns1:textoExtracto "D Potencia consumida por el cabezal. E Potencia consumida por el cabezal en condiciones idóneas" .

ns1:InterfazUsuario_DMC_MenuOpciones a ns1:InterfazUsuario ;
    rdfs:label "Menú vertical de softkeys (Opciones DMC)" ;
    ns1:textoExtracto "Menú vertical de softkeys. Opciones del DMC (menú desplegable): Repetir la fase de aprendizaje del DMC. Desactivar el DMC." .

ns1:InterfazUsuario_DMC_Visualizacion a ns1:InterfazUsuario ;
    rdfs:label "Pantalla DMC (Visualización)" ;
    ns1:ilustradoEn ns1:ModoOperacion_DMC ;
    ns1:textoExtracto "en la softkey 'Visualizar' del menú horizontal, seleccionar la opción 'DMC'. Los datos que muestra la página DMC son los mismos que los de la página estándar, excepto los propios del DMC (zona superior izquierda)" .

ns1:Parametro_DMC_AvancePorDiente a ns1:Parametro ;
    rdfs:label "Avance por diente (DMC)" ;
    ns1:textoExtracto "C Avance por diente. Los límites de la barra de consumo son los valores programados en la sentencia #DMCON (comandos FZMIN y FZMAX)" ;
    ns1:valor "FZMIN/FZMAX (programado en #DMCON)" .

ns1:Parametro_DMC_Override a ns1:Parametro ;
    rdfs:label "Override del DMC" ;
    ns1:monitoreaParametro ns1:Maquina_Brochadora ;
    ns1:textoExtracto "B Override del DMC. Los límites de la barra de consumo serán los definidos en los parámetros máquina. A la derecha se muestra el override aplicado por el DMC" .

ns1:Parametro_DMC_OverrideFinal a ns1:Parametro ;
    rdfs:label "Override final (DMC + conmutador)" ;
    ns1:textoExtracto "J Override final (override del DMC + override del conmutador)" .

ns1:Parametro_DMC_PotenciaConsumida a ns1:Parametro ;
    rdfs:label "Potencia consumida por el cabezal" ;
    ns1:monitoreaParametro ns1:ComponenteMecanico_Cabezal ;
    ns1:textoExtracto "D Potencia consumida por el cabezal (definida como porcentaje de la potencia nominal)" .

ns1:Parametro_DMC_PotenciaObjetivo a ns1:Parametro ;
    rdfs:label "Potencia objetivo (DMC)" ;
    ns1:textoExtracto "F Potencia objetivo o potencia de corte idónea (definida como porcentaje de la potencia nominal); potencia aprendida o programada en la sentencia #DMCON (comando PWRSP)" ;
    ns1:valor "PWRSP (programado en #DMCON)" .

ns1:Parametro_DMC_PotenciaVacio a ns1:Parametro ;
    rdfs:label "Potencia en vacío (DMC)" ;
    ns1:textoExtracto "G Potencia en vacío (definida como porcentaje de la potencia nominal)" .

ns1:Parametro_DMC_TiempoAhorrado a ns1:Parametro ;
    rdfs:label "Tiempo ahorrado por acción del DMC" ;
    ns1:textoExtracto "H Tiempo ahorrado por acción del DMC" .

ns1:Maquina_Brochadora a ns1:Maquina ;
    rdfs:label "Máquina brochadora (con DMC)" ;
    ns1:textoExtracto "Los límites de la barra de consumo serán los definidos en los parámetros máquina" .

