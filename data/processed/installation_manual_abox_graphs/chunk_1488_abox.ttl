@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:Material_Aluminio_Kc350_733 a ns1:Consumible ;
    rdfs:label "Aluminio (Kc=350 N/mm²)"@es ;
    ns1:identificador "Al_Kc350" ;
    ns1:textoExtracto "Material. | Material: Aluminio. Kc: 350 N/mm²."@es .

ns1:Mecanizado_Aluminio_DMC_733 a ns1:ModoOperacion ;
    rdfs:label "Mecanizado automático de aluminio con DMC"@es ;
    ns1:monitoreaParametro ns1:Parametro_Avance_3420_733,
        ns1:Parametro_VelocidadCorte_1410_733,
        ns1:Parametro_VelocidadGiro_7124_733 ;
    ns1:textoExtracto "Este apartado muestra una imagen del modo automático y una captura del osciloscopio tomadas durante un mecanizado con DMC."@es ;
    ns1:tieneComponente ns1:Herramienta_63mm_4Dientes_733 .

ns1:Herramienta_63mm_4Dientes_733 a ns1:Herramienta ;
    rdfs:label "Herramienta de Ø63 mm (Nz=4, Fz=0.12 mm/diente)"@es ;
    ns1:identificador "Ø63mm_Nz4_Fz0.12" ;
    ns1:textoExtracto "Herramienta. | Diámetro: Ø 63 mm. Número de dientes: Nz = 4. Avance por diente: Fz = 0.12 mm/diente. Profundidad de pasada radial: Ae = 35 mm. Profundidad de pasada axial: Ap= 1.5 mm."@es .

ns1:Parametro_Avance_3420_733 a ns1:Parametro ;
    rdfs:label "Avance (F)"@es ;
    ns1:identificador "F_3420" ;
    ns1:textoExtracto "Avance: F = 3420 mm/min."@es ;
    ns1:valor "3420"^^xsd:string .

ns1:Parametro_VelocidadCorte_1410_733 a ns1:Parametro ;
    rdfs:label "Velocidad de corte (Vc)"@es ;
    ns1:identificador "Vc_1410" ;
    ns1:textoExtracto "Velocidad de corte: Vc = 1410 m/min."@es ;
    ns1:valor "1410"^^xsd:string .

ns1:Parametro_VelocidadGiro_7124_733 a ns1:Parametro ;
    rdfs:label "Velocidad de giro (S)"@es ;
    ns1:identificador "S_7124" ;
    ns1:textoExtracto "Velocidad de giro: S = 7124 RPM."@es ;
    ns1:valor "7124"^^xsd:string .

