@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnalisisDeUnMecanizado a ns1:TareaMantenimiento ;
    rdfs:label "Análisis de un mecanizado" ;
    ns1:textoExtracto "D E A F B C A Control del override para optimizar la potencia. B Mecanizado en G00. C Entrada a la pieza. D Movimiento en vacío; override máximo (parámetro máquina MAXDMCOVR). E Mecanizado al avance máximo por diente. F..." .

ns1:CNC8070_db1603f7d9 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Control del override para optimizar la potencia." .

ns1:ControlDelOverrideParaOptimizarLaPotencia a ns1:Parametro ;
    rdfs:label "Control del override para optimizar la potencia" ;
    ns1:identificador "MAXDMCOVR" ;
    ns1:textoExtracto "D Movimiento en vacío; override máximo (parámetro máquina MAXDMCOVR)." .

