@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_DMC a ns1:Sistema ;
    rdfs:label "Sistema DMC (Dynamic Machining Control)" ;
    ns1:monitoreaParametro ns1:Parametro_FZMAX,
        ns1:Parametro_FZMIN,
        ns1:Parametro_MAXDMCOVR,
        ns1:Parametro_MINDMCOVR,
        ns1:Parametro_NoLoadPower,
        ns1:Parametro_PowerSetPoint ;
    ns1:textoExtracto "Programación. Sentencia para activar el DMC. # DMC ON [FZMAX 0.15, FZMIN 0.08] • No está programada la potencia objetivo; el DMC ejecuta la fase de aprendizaje." .

ns1:Parametro_FZMAX a ns1:Parametro ;
    rdfs:label "Avance máximo programado (FZMAX)" ;
    ns1:identificador "FZMAX" ;
    ns1:textoExtracto "El avance máximo está limitado a 0.15 mm/diente; con las condiciones de corte F y S programadas, equivale a un 125 % de override máximo." ;
    ns1:valor "0.15 mm/diente" .

ns1:Parametro_FZMIN a ns1:Parametro ;
    rdfs:label "Avance mínimo programado (FZMIN)" ;
    ns1:identificador "FZMIN" ;
    ns1:textoExtracto "El avance mínimo está limitado a 0.08 mm/diente; con las condiciones de corte F y S programadas, equivale a un 67 % de override mínimo." ;
    ns1:valor "0.08 mm/diente" .

ns1:Parametro_MAXDMCOVR a ns1:Parametro ;
    rdfs:label "Máximo override DMC (MAXDMCOVR)" ;
    ns1:identificador "MAXDMCOVR" ;
    ns1:textoExtracto "Máximo override DMC de todos los ejes del canal. Valor: 135 %." ;
    ns1:valor "135 %" .

ns1:Parametro_MINDMCOVR a ns1:Parametro ;
    rdfs:label "Mínimo override DMC (MINDMCOVR)" ;
    ns1:identificador "MINDMCOVR" ;
    ns1:textoExtracto "Mínimo override DMC de todos los ejes del canal. Valor: 65 %." ;
    ns1:valor "65 %" .

ns1:Parametro_NoLoadPower a ns1:Parametro ;
    rdfs:label "Potencia en vacío (No load power)" ;
    ns1:textoExtracto "No load power (potencia en vacío). 2.96 %" ;
    ns1:valor "2.96 %" .

ns1:Parametro_PowerSetPoint a ns1:Parametro ;
    rdfs:label "Potencia objetivo aprendida (PowerSetPoint)" ;
    ns1:textoExtracto "PowerSetPoint (potencia objetivo aprendida)." .

