@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FactorDeConversion a ns1:Parametro ;
    rdfs:label "Factor de conversión" ;
    ns1:identificador "MPG.FACTOR[n]" ;
    ns1:textoExtracto "FACTOR Factor de conversión. Valores posibles: Entre ±999999999.999999999. Valor por defecto: 0.0061035." .

ns1:NumeroDeEntradaAnalogica a ns1:Parametro ;
    rdfs:label "Número de entrada analógica" ;
    ns1:identificador "MPG.ADDRESS[n]" ;
    ns1:textoExtracto "ADDRESS Número de entrada analógica. Valores posibles: De 0 a 60. Valor por defecto: 0." .

ns1:NumeroDeEntradasAnalogicasEspecialesNoEnTension_3c06b0fec4 a ns1:Parametro ;
    rdfs:label "Número de entradas analógicas especiales (no en tensión)" ;
    ns1:identificador "MPG.NSAI" ;
    ns1:textoExtracto "NSAI Número de entradas analógicas especiales (no en tensión). Valores posibles: De 0 a 30. Valor por defecto: 0 (todas las entradas analógicas son en tensión)." .

