@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:GAPCONTROL a ex:Tabla ;
    ex:textoExtracto "GAPCONTROL Tabla de parámetros del control del gap. Este parámetro muestra la tabla para definir el control del gap." ;
    ex:compuestoPor ex:GAPANAINTYPE, ex:GAPANAINID, ex:GAPDISTLIMIT, ex:GAPVOLTLIMIT, ex:GAPSENSOROFFSET, ex:GAPSENSORCH, ex:GAPGAIN, ex:GAPAPPROACHDYN, ex:GAPSENSORFILTER, ex:GAPERRORCANCEL, ex:GAPMIN, ex:GAPMAX, ex:GAPTOLCANCEL, ex:GAPTOL, ex:GAPCOLLISIONMODE, ex:GAPTONEG .

ex:GAPANAINTYPE a ex:Parametro ;
    ex:textoExtracto "GAPANAINTYPE Tipo de entrada analógica conectada al sensor. Valores posibles: Remoto CAN / Regulador / Captación / EtherCAT. Valor por defecto: Regulador. Variable asociada: (V.)MPG.GAPANAINITIME Este parámetro indica dónde está ubicada la salida analógica conectada al sensor. Se recomienda utilizar una entrada del regulador." ;
    ex:valor "Remoto CAN / Regulador / Captación / EtherCAT" .

ex:GAPANAINID a ex:Parametro ;
    ex:textoExtracto "GAPANAINID Número de entrada analógica conectada al sensor." .

ex:GAPDISTLIMIT a ex:Parametro ;
    ex:textoExtracto "GAPDISTLIMIT Distancia que corresponde a la señal analógica límite del sensor." .

ex:GAPVOLTLIMIT a ex:Parametro ;
    ex:textoExtracto "GAPVOLTLIMIT Voltaje que corresponde al recorrido límite del sensor." .

ex:GAPSENSOROFFSET a ex:Parametro ;
    ex:textoExtracto "GAPSENSOROFFSET Offset a aplicar al sensor." .

ex:GAPSENSORCH a ex:Parametro ;
    ex:textoExtracto "GAPSENSORCH Cambiar el signo de la señal del sensor." .

ex:GAPGAIN a ex:Parametro ;
    ex:textoExtracto "GAPGAIN Ganancia proporcional a aplicar en GAPCTRL." .

ex:GAPAPPROACHDYN a ex:Parametro ;
    ex:textoExtracto "GAPAPPROACHDYN Respuesta dinámica durante la parte final del movimiento de aproximación a la chapa." .

ex:GAPSENSORFILTER a ex:Parametro ;
    ex:textoExtracto "GAPSENSORFILTER Tabla para configurar el filtro del sensor." .

ex:GAPERRORCANCEL a ex:Parametro ;
    ex:textoExtracto "GAPERRORCANCEL Anular el error de gap fuera del rango definido por GAPMIN/GAPMAX." .

ex:GAPMIN a ex:Parametro ;
    ex:textoExtracto "GAPMIN Límite mínimo del sensor." .

ex:GAPMAX a ex:Parametro ;
    ex:textoExtracto "GAPMAX Límite máximo del sensor." .

ex:GAPTOLCANCEL a ex:Parametro ;
    ex:textoExtracto "GAPTOLCANCEL Anular el error de gap fuera del rango definido por GAPTOL." .

ex:GAPTOL a ex:Parametro ;
    ex:textoExtracto "GAPTOL Margen de tolerancia del error." .

ex:GAPCOLLISIONMODE a ex:Parametro ;
    ex:textoExtracto "GAPCOLLISIONMODE Comportamiento del CNC ante una colisión del sensor." .

ex:GAPTONEG a ex:Parametro ;
    ex:textoExtracto "GAPTONEG Bloque de movimiento en #GAPCTRL hacia cota descendente." .