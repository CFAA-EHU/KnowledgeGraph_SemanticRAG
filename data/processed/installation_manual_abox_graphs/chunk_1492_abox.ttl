@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Error_2430 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2430: FZMIN > FZMAX en #DMC ON" ;
    ns1:identificador "2430" ;
    ns1:monitoreaParametro ns1:Parametro_FZMAX,
        ns1:Parametro_FZMIN ;
    ns1:textoExtracto "2430 #DMC ON: FZMIN debe ser menor que FZMAX. [...] CAUSA En la función #DMC, el avance mínimo es mayor que el avance máximo." .

ns1:ManualProgramacion a ns1:Manual ;
    rdfs:label "Manual de programación" ;
    ns1:documentadoEn ns1:Error_2427,
        ns1:Error_2428,
        ns1:Error_2429 ;
    ns1:textoExtracto "Revisar en el manual de programación la sintaxis de la sentencia." .

ns1:Error_2427 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2427: Sintaxis incorrecta en #DMC ON" ;
    ns1:identificador "2427" ;
    ns1:monitoreaParametro ns1:Parametro_FZMAX,
        ns1:Parametro_FZMIN,
        ns1:Parametro_OVRMAX,
        ns1:Parametro_OVRMIN,
        ns1:Parametro_PWRSP ;
    ns1:textoExtracto "2427 #DMC ON [<PWRSP value><,OVRMIN value><,OVRMAX value><,FZMIN value><,FZMAX value>] [...] CAUSA La sintaxis de la sentencia no es correcta." .

ns1:Error_2428 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2428: Sintaxis incorrecta en #DMC OFF" ;
    ns1:identificador "2428" ;
    ns1:textoExtracto "2428 #DMC OFF [...] CAUSA La sintaxis de la sentencia no es correcta." .

ns1:Error_2429 a ns1:AvisoSeguridad ;
    rdfs:label "Error 2429: Parámetro DMC fuera de rango" ;
    ns1:identificador "2429" ;
    ns1:monitoreaParametro ns1:Parametro_DMC ;
    ns1:textoExtracto "2429 Parámetro DMC fuera de rango [...] CAUSA Algún comando de la sentencia #DMC tiene un valor no válido." .

ns1:Parametro_DMC a ns1:Parametro ;
    rdfs:label "Parámetro DMC" ;
    ns1:identificador "DMC" ;
    ns1:textoExtracto "Parámetro DMC fuera de rango" .

ns1:Parametro_OVRMAX a ns1:Parametro ;
    rdfs:label "OVRMAX" ;
    ns1:identificador "OVRMAX" ;
    ns1:textoExtracto "#DMC ON [<OVRMAX value>..." .

ns1:Parametro_OVRMIN a ns1:Parametro ;
    rdfs:label "OVRMIN" ;
    ns1:identificador "OVRMIN" ;
    ns1:textoExtracto "#DMC ON [<OVRMIN value>..." .

ns1:Parametro_PWRSP a ns1:Parametro ;
    rdfs:label "PWRSP" ;
    ns1:identificador "PWRSP" ;
    ns1:textoExtracto "#DMC ON [<PWRSP value>..." .

ns1:Parametro_FZMAX a ns1:Parametro ;
    rdfs:label "FZMAX" ;
    ns1:identificador "FZMAX" ;
    ns1:textoExtracto "#DMC ON [<FZMAX value>..." .

ns1:Parametro_FZMIN a ns1:Parametro ;
    rdfs:label "FZMIN" ;
    ns1:identificador "FZMIN" ;
    ns1:textoExtracto "#DMC ON [<FZMIN value>..." .

