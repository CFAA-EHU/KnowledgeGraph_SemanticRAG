@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComprobarElEstadoDeLaHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar el estado de la herramienta" ;
    ns1:solucionaFallo ns1:PotenciaExcesivaEnElCabezalDetectadaDuranteDMC ;
    ns1:textoExtracto "SOLUCIÓN Comprobar el estado de la herramienta." .

ns1:Parametro_609f33a725 a ns1:Parametro ;
    rdfs:label "Parámetro máquina DMCSPDL" ;
    ns1:identificador "DMCSPDL" ;
    ns1:textoExtracto "Para activar el DMC sobre un cabezal, éste debe tener su parámetro máquina DMCSPDL=Sí." .

ns1:PotenciaInstantaneaExcesivaEnElCabezalDetectadaDuranteDMC a ns1:DiagnosticoFallo ;
    rdfs:label "Potencia instantánea excesiva en el cabezal detectada durante DMC" ;
    ns1:textoExtracto "3101 Potencia excesiva en el cabezal detectada durante DMC.Pulse MARCHA para continuar. DETECCIÓN Durante la ejecución. CAUSA El DMC ha detectado que la potencia instantánea (variable TV51 del regulador) ha superado la potencia objetivo en un rango prefijado." .

ns1:SeHaIntentadoActivarElDMCEnUnCabezalQueNoTienePermisoParaEllo_e25eef16a2 a ns1:DiagnosticoFallo ;
    rdfs:label "Se ha intentado activar el DMC en un cabezal que no tiene permiso para ello" ;
    ns1:textoExtracto "CAUSA Se ha intentado activar el DMC en un cabezal que no tiene permiso para ello. SOLUCIÓN Para activar el DMC sobre un cabezal, éste debe tener su parámetro máquina DMCSPDL=Sí." .

ns1:VariableTV51DelRegulador a ns1:Parametro ;
    rdfs:label "Variable TV51 del regulador" ;
    ns1:identificador "TV51" ;
    ns1:textoExtracto "El DMC ha detectado un consumo de potencia (variable TV51 del regulador) excesivo durante cierto tiempo." .

ns1:PotenciaExcesivaEnElCabezalDetectadaDuranteDMC a ns1:DiagnosticoFallo ;
    rdfs:label "Potencia excesiva en el cabezal detectada durante DMC" ;
    ns1:textoExtracto "3100 Potencia excesiva en el cabezal detectada durante DMC. DETECCIÓN Durante la ejecución. CAUSA El DMC ha detectado un consumo de potencia (variable TV51 del regulador) excesivo durante cierto tiempo." .

