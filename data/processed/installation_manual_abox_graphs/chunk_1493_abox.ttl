@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AjustarPotenciaObjetivo a ns1:TareaMantenimiento ;
    rdfs:label "Ajustar potencia objetivo" ;
    ns1:solucionaFallo ns1:PotenciaObjetivoInsuficienteParaElFuncionamientoCorrectoConDMC ;
    ns1:textoExtracto "La potencia objetivo (programada u obtenida mediante el aprendizaje) debe ser al menos un 20 % de la potencia en vacío." .

ns1:ComprobarEstadoDeHerramientaYMecanizado a ns1:TareaMantenimiento ;
    rdfs:label "Comprobar estado de herramienta y mecanizado" ;
    ns1:solucionaFallo ns1:PotenciaInstantaneaSuperada ;
    ns1:textoExtracto "Comprobar el estado de la herramienta y del mecanizado. El CNC permite reanudar la ejecución pulsando [START], entrar en modo inspección de herramienta o dar por terminada la ejecución." .

ns1:PotenciaInstantanea a ns1:Parametro ;
    rdfs:label "Potencia instantánea" ;
    ns1:identificador "TV51" ;
    ns1:textoExtracto "variable TV51 del regulador" .

ns1:PotenciaInstantaneaSuperada a ns1:DiagnosticoFallo ;
    rdfs:label "Potencia instantánea superada" ;
    ns1:textoExtracto "El DMC ha detectado que la potencia instantánea (variable TV51 del regulador) ha superado la potencia objetivo en un rango prefijado." .

ns1:PotenciaObjetivoInsuficienteParaElFuncionamientoCorrectoConDMC a ns1:DiagnosticoFallo ;
    rdfs:label "Potencia objetivo insuficiente para el funcionamiento correcto con DMC" ;
    ns1:textoExtracto "Potencia objetivo insuficiente para el funcionamiento correcto con DMC." .

