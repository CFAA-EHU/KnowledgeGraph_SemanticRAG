@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesactivarFuncionDMC a ns1:TareaMantenimiento ;
    rdfs:label "Desactivar función DMC" ;
    ns1:solucionaFallo ns1:LaPotenciaObjetivoDebeSerAlMenosUn20DeLaPotenciaEnVacio ;
    ns1:textoExtracto "En este caso se recomienda desactivar la función DMC en este mecanizado." .

ns1:ProgramarUnaPotenciaObjetivoMayor a ns1:TareaMantenimiento ;
    rdfs:label "Programar una potencia objetivo mayor" ;
    ns1:textoExtracto "Programar una potencia objetivo mayor, que no se va a alcanzar realmente, puede tener como consecuencia que el DMC no detecte nunca entradas a la pieza, y realice todo el mecanizado como si la herramienta trabajara en vacío." .

ns1:LaPotenciaObjetivoDebeSerAlMenosUn20DeLaPotenciaEnVacio a ns1:DiagnosticoFallo ;
    rdfs:label "La potencia objetivo debe ser al menos un 20 % de la potencia en vacío" ;
    ns1:textoExtracto "La potencia objetivo (programada u obtenida mediante el aprendizaje) debe ser al menos un 20 % de la potencia en vacío." .

