@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalRotativo a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal Rotativo" ;
    ns1:esComponenteDe ns1:CNC8070_8cf519dfde ;
    ns1:textoExtracto "Todas las configuraciones están diseñadas para un canal, y además del eje rotativo de la mesa (plato divisor), tienen otros dos ejes rotativos en el cabezal." .

ns1:EjeRotativoMesa a ns1:ComponenteMecanico ;
    rdfs:label "Eje Rotativo de la Mesa" ;
    ns1:esComponenteDe ns1:CNC8070_8cf519dfde ;
    ns1:textoExtracto "Todas las configuraciones están diseñadas para un canal, y además del eje rotativo de la mesa (plato divisor), tienen otros dos ejes rotativos en el cabezal." .

ns1:ArchivoConfiguracionMquina a ns1:DocumentoTecnico ;
    rdfs:label "Archivo de Configuración Máquina" ;
    ns1:textoExtracto "Los archivos xca se pueden cargar bien desde el menú de softkeys o bien desde el programa mediante la sentencia #DEFGRAPH." .

ns1:CNC8070_8cf519dfde a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:ArchivoConfiguracionMquina ;
    ns1:textoExtracto "Los archivos xca se pueden cargar bien desde el menú de softkeys o bien desde el programa mediante la sentencia #DEFGRAPH." .

