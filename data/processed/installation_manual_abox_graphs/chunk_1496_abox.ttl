@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PlatoDivisorEnX a ns1:ComponenteElectrico ;
    rdfs:label "Plato divisor en X" ;
    ns1:ilustradoEn ns1:TablaConfiguracionGraficosRotativos ;
    ns1:textoExtracto "Máquina con plato divisor en X." .

ns1:PlatoDivisorEnY a ns1:ComponenteElectrico ;
    rdfs:label "Plato divisor en Y" ;
    ns1:ilustradoEn ns1:TablaConfiguracionGraficosRotativos ;
    ns1:textoExtracto "Máquina con plato divisor en Y." .

ns1:PlatoDivisorEnZ a ns1:ComponenteElectrico ;
    rdfs:label "Plato divisor en Z" ;
    ns1:ilustradoEn ns1:TablaConfiguracionGraficosRotativos ;
    ns1:textoExtracto "Máquina con plato divisor en Z." .

ns1:TablaConfiguracionGraficosRotativos a ns1:Tabla ;
    rdfs:label "Tabla Configuración Gráficos Rotativos" ;
    ns1:textoExtracto "Archivo. | Tipo de máquina." .

