@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_1eca685a23 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "hay que reiniciar el CNC para que los cambios surtan efecto." .

ns1:EjeFrontal_636c6d5818 a ns1:Parametro ;
    rdfs:label "Eje Frontal" ;
    ns1:identificador "FACEAXIS" ;
    ns1:textoExtracto "Los gráficos posicionan la herramienta según el eje frontal o longitudinal definido en los parámetros máquina de los ejes lineales (FACEAXIS y LONGAXIS)" .

ns1:EjeLongitudinal_af6cf7d0c2 a ns1:Parametro ;
    rdfs:label "Eje Longitudinal" ;
    ns1:identificador "LONGAXIS" ;
    ns1:textoExtracto "Los gráficos posicionan la herramienta según el eje frontal o longitudinal definido en los parámetros máquina de los ejes lineales (FACEAXIS y LONGAXIS)" .

ns1:PosicionarLaHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Posicionar la herramienta" ;
    ns1:textoExtracto "Posicionar la herramienta. Los gráficos posicionan la herramienta según el eje frontal o longitudinal definido en los parámetros máquina de los ejes lineales (FACEAXIS y LONGAXIS) y según la opción elegida en la tabla de herramientas." .

