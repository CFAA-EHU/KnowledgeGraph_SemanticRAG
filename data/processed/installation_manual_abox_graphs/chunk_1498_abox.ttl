@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:ArchivoConfiguracionEjesRotativos a ns1:Esquema ;
    ns1:textoExtracto "Los archivos xca se pueden cargar bien desde el menú de softkeys o bien desde el programa mediante la sentencia #DEFGRAPH. Definir la máquina. En la carpeta ../Fagor/Grafdata/Machines/Mill están los archivos de configuración para máquinas con plato divisor." ;
    ns1:tieneComponente ns1:ArchivoXCA .

ns1:ArchivoXCA a ns1:Esquema ;
    ns1:compuestoPor ns1:Canal,
        ns1:EjeRotativoCabezal1,
        ns1:EjeRotativoCabezal2,
        ns1:EjeRotativoMesa ;
    ns1:identificador "xca" ;
    ns1:textoExtracto "archivo xca" .

ns1:Canal a ns1:ComponenteElectrico ;
    ns1:textoExtracto "un canal" .

ns1:EjeRotativoCabezal1 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "otros dos ejes rotativos en el cabezal" .

ns1:EjeRotativoCabezal2 a ns1:ComponenteMecanico ;
    ns1:textoExtracto "otros dos ejes rotativos en el cabezal" .

ns1:EjeRotativoMesa a ns1:ComponenteMecanico ;
    ns1:textoExtracto "eje rotativo de la mesa (plato divisor)" .

