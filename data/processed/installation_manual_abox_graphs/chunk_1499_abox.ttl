@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_db675e2c89 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:monitoreaParametro ns1:PosicionDelEjeDeCara,
        ns1:PosicionDelEjeLongitudinal ;
    ns1:textoExtracto "Si los parámetros máquina LONGAXIS o FACEAXIS cambian, hay que reiniciar el CNC para que los gráficos asuman la nueva configuración." .

ns1:PosicionDelEjeDeCara a ns1:Parametro ;
    rdfs:label "Posición del eje de cara" ;
    ns1:identificador "FACEAXIS" ;
    ns1:textoExtracto "Si los parámetros máquina LONGAXIS o FACEAXIS cambian, hay que reiniciar el CNC para que los gráficos asuman la nueva configuración." .

ns1:PosicionDelEjeLongitudinal a ns1:Parametro ;
    rdfs:label "Posición del eje longitudinal" ;
    ns1:identificador "LONGAXIS" ;
    ns1:textoExtracto "Si los parámetros máquina LONGAXIS o FACEAXIS cambian, hay que reiniciar el CNC para que los gráficos asuman la nueva configuración." .

