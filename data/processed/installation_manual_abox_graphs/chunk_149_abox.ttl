@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SensorGap_149 a ex:Sensor ;
    ex:textoExtracto "El sensor del gap está conectado a la entrada X3 del regulador. El CNC controla el eje del sensor hasta que alcanza el gap programado (teniendo en cuenta GAPINPOSW). Una vez alcanzada esta posición, el regulador controla el gap." ;
    ex:identificador "sensor del gap" .

ex:Regulador_149 a ex:ComponenteElectrico ;
    ex:textoExtracto "Entrada analógica en un regulador. El sensor del gap está conectado a la entrada X3 del regulador. Una vez alcanzada esta posición, el regulador controla el gap." ;
    ex:identificador "regulador" .

ex:EntradaX3_149 a ex:ComponenteElectrico ;
    ex:textoExtracto "El sensor del gap está conectado a la entrada X3 del regulador." ;
    ex:identificador "X3" .

ex:ModuloRIOW_E_149 a ex:ComponenteElectrico ;
    ex:textoExtracto "Las entradas analógicas están disponibles en los módulos RIOW-E." ;
    ex:identificador "RIOW-E" .

ex:SensorGapEtherCAT_149 a ex:Sensor ;
    ex:textoExtracto "El sensor del gap está conectado a una entrada analógica del bus EtherCAT." ;
    ex:identificador "sensor del gap" .

ex:EntradaAnalogicaEtherCAT_149 a ex:ComponenteElectrico ;
    ex:textoExtracto "El sensor del gap está conectado a una entrada analógica del bus EtherCAT." .

ex:ModuloRIOW_E_149 ex:tieneComponente ex:EntradaAnalogicaEtherCAT_149 .

ex:Regulador_149 ex:controla ex:SensorGap_149 .
ex:Regulador_149 ex:tieneComponente ex:EntradaX3_149 .