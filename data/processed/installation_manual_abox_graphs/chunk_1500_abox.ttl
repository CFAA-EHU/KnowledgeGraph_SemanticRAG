@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArchivoMillA a ns1:DocumentoTecnico ;
    rdfs:label "Archivo Mill A" ;
    ns1:documentadoEn ns1:TablaConfiguracionGraficosRotativos ;
    ns1:textoExtracto "Mill A@table B,C@spindle.xca" .

ns1:ArchivoMillB a ns1:DocumentoTecnico ;
    rdfs:label "Archivo Mill B" ;
    ns1:documentadoEn ns1:TablaConfiguracionGraficosRotativos ;
    ns1:textoExtracto "Mill B@table A,C@spindle.xca" .

ns1:ArchivoMillC a ns1:DocumentoTecnico ;
    rdfs:label "Archivo Mill C" ;
    ns1:documentadoEn ns1:TablaConfiguracionGraficosRotativos ;
    ns1:textoExtracto "Mill C@table A,B@spindle.xca" .

ns1:EjeFrontalEsZ a ns1:Parametro ;
    rdfs:label "Eje frontal es Z" ;
    ns1:identificador "FACEAXIS=Z" ;
    ns1:ilustradoEn ns1:TablaConfiguracionGraficosRotativos ;
    ns1:textoExtracto "FACEAXIS = Z LONGAXIS =X" .

ns1:EjeLongitudinalEsX a ns1:Parametro ;
    rdfs:label "Eje longitudinal es X" ;
    ns1:identificador "LONGAXIS=X" ;
    ns1:ilustradoEn ns1:TablaConfiguracionGraficosRotativos ;
    ns1:textoExtracto "FACEAXIS = Z LONGAXIS =X" .

ns1:TablaConfiguracionGraficosRotativos a ns1:Tabla ;
    rdfs:label "Tabla Configuración Gráficos Rotativos" ;
    ns1:textoExtracto "Archivo. | Posición por defecto de la herramienta." .

