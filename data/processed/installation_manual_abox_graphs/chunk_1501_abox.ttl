@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_038bc72b3e a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:InterfazUsuarioEtherCAT ;
    ns1:textoExtracto "El CNC es el elemento máster del bus, y el resto de recursos estará repartido por nodos (hasta 32)." .

ns1:TiempoDeCicloDelBus a ns1:Parametro ;
    rdfs:label "Tiempo de ciclo del bus" ;
    ns1:identificador "LOOPTIME" ;
    ns1:textoExtracto "El tiempo de ciclo del bus está definido por el parámetro LOOPTIME." .

ns1:InterfazUsuarioEtherCAT a ns1:InterfazUsuario ;
    rdfs:label "Interfaz EtherCAT" ;
    ns1:textoExtracto "La plataforma Q7-A dispone de bus EtherCAT para la comunicación con módulos remotos de I/Os (propios o de terceros)." .

