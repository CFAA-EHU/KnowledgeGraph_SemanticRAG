@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_FACEAXIS a ns1:Parametro ;
    rdfs:label "FACEAXIS" ;
    ns1:monitoreaParametro ns1:ConfiguracionEjesRotativos_19_1 ;
    ns1:textoExtracto "parámetros máquina [...] FACEAXIS"@es .

ns1:Parametro_LONGAXIS a ns1:Parametro ;
    rdfs:label "LONGAXIS" ;
    ns1:monitoreaParametro ns1:ConfiguracionEjesRotativos_19_1 ;
    ns1:textoExtracto "parámetros máquina LONGAXIS"@es .

ns1:PosicionDefectoHerramienta a ns1:Parametro ;
    rdfs:label "Posición por defecto de la herramienta"@es ;
    ns1:monitoreaParametro ns1:ConfiguracionEjesRotativos_19_1 ;
    ns1:textoExtracto "la posición por defecto de la herramienta en las diferentes configuraciones de máquina"@es ;
    ns1:valor "No parametrizado (FACEAXIS/LONGAXIS no configurados)"@es .

ns1:Tabla_Herramientas_19_1 a ns1:Tabla ;
    rdfs:label "Tabla de herramientas para configuración de ejes rotativos"@es ;
    ns1:documentadoEn ns1:ConfiguracionEjesRotativos_19_1 ;
    ns1:textoExtracto "según la opción elegida en la tabla de herramientas"@es .

ns1:ConfiguracionEjesRotativos_19_1 a ns1:InterfazUsuario ;
    rdfs:label "Configuración de gráficos para ciclos de ejes rotativos"@es ;
    ns1:identificador "19.1" ;
    ns1:textoExtracto "Configurar los gráficos para los ciclos de ejes rotativos"@es .

