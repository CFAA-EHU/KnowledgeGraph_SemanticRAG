@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_8e172b6785 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:FicheroENI ;
    ns1:textoExtracto "El configurador de la topología genera el fichero ENI que contiene la información de los dispositivos EtherCAT conectados al CNC." .

ns1:KPAEtherCATStudio a ns1:Herramienta ;
    rdfs:label "KPA EtherCAT Studio" ;
    ns1:textoExtracto "Fagor suministra bajo licencia el configurador \"KPA EtherCAT Studio\" (de Koening-pa GmbH), que puede funcionar tanto en modo online como offline;" .

ns1:ProgramaFagorEtherCATMapper a ns1:Herramienta ;
    rdfs:label "Fagor EtherCAT Mapper" ;
    ns1:textoExtracto "Este fichero también lo utiliza el programa \"Fagor EtherCAT Mapper\" para conocer los recursos disponibles en el bus." .

ns1:FicheroENI a ns1:DocumentoTecnico ;
    rdfs:label "fagor_ethercatConfFile.xml" ;
    ns1:identificador "fagor_ethercatConfFile.xml" ;
    ns1:textoExtracto "Este fichero se debe copiar a la carpeta ../Mtb/Data del CNC con el nombre \"fagor_ethercatConfFile.xml\"." .

