ns1:Archivo_MillA_tableBC_spindle a ns1:InterfazUsuario ;
    rdfs:label "Archivo de configuración Mill A@table B,C@spindle.xca" ;
    ns1:controla ns1:Parametro_FACEAXIS_MillA,
        ns1:Parametro_LONGAXIS_MillA ;
    ns1:detalladoEnEsquema ns1:Tabla_ConfiguracionCiclosRotativos_19_1 ;
    ns1:identificador "Mill A@table B,C@spindle.xca" ;
    ns1:textoExtracto "Mill A@table B,C@spindle.xca | FACEAXIS = Z LONGAXIS =X" .

