@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArchivoENI_EtherCAT a ns1:InterfazUsuario ;
    rdfs:label "fagor_ethercatConfFile.xml" ;
    ns1:documentadoEn ns1:Manual_Q7_A ;
    ns1:identificador "fagor_ethercatConfFile.xml" ;
    ns1:textoExtracto "Copiar el archivo creado por 'KPA EtherCAT Studio' como fagor_ethercatConfFile.xml." .

ns1:ArchivoMapeoRecursos a ns1:InterfazUsuario ;
    rdfs:label "resourceRouterConf.xml" ;
    ns1:documentadoEn ns1:Manual_Q7_A ;
    ns1:identificador "resourceRouterConf.xml" ;
    ns1:textoExtracto "Copiar el archivo creado por 'Fagor EtherCAT Mapper' como resourceRouterConf.xml." .

ns1:CNC_Q7_A a ns1:Actuador ;
    rdfs:label "CNC (elemento máster del bus EtherCAT)" ;
    ns1:controla ns1:BusEtherCAT_Q7_A ;
    ns1:textoExtracto "El CNC es el elemento máster del bus, y el resto de recursos estará repartido por nodos (hasta 32)." .

ns1:Fagor_EtherCAT_Mapper a ns1:Herramienta ;
    rdfs:label "Fagor EtherCAT Mapper" ;
    ns1:documentadoEn ns1:Manual_Q7_A ;
    ns1:textoExtracto "Utilizar el programa 'Fagor EtherCAT Mapper' para mapear los recursos EtherCAT a recursos PLC (entradas, salidas y registros) y generar el archivo con la información del mapeo." .

ns1:KPA_EtherCAT_Studio a ns1:Herramienta ;
    rdfs:label "KPA EtherCAT Studio" ;
    ns1:documentadoEn ns1:Manual_Q7_A ;
    ns1:textoExtracto "Utilizar el configurador 'KPA EtherCAT Studio' para definir la topología del bus y generar el fichero ENI con la información de los dispositivos EtherCAT conectados al CNC." .

ns1:BusEtherCAT_Q7_A a ns1:Sistema ;
    rdfs:label "Bus EtherCAT de la plataforma Q7-A" ;
    ns1:controla ns1:DispositivosEtherCAT_Esclavos ;
    ns1:monitoreaParametro ns1:TiempoCicloBus ;
    ns1:textoExtracto "La plataforma Q7-A dispone de bus EtherCAT para la comunicación con módulos remotos de I/Os (propios o de terceros)." ;
    ns1:tieneComponente ns1:M_dulosIO_Remotos .

ns1:DispositivosEtherCAT_Esclavos a ns1:ComponenteElectrico ;
    rdfs:label "Dispositivos esclavo EtherCAT" ;
    ns1:compuestoPor ns1:EntradasAnal_gicasGP_EtherCAT,
        ns1:EntradasDigitales_EtherCAT,
        ns1:EntradasPt100_EtherCAT,
        ns1:SalidasAnal_gicasGP_EtherCAT,
        ns1:SalidasDigitales_EtherCAT ;
    ns1:textoExtracto "inicializa los esclavos conectados al bus." .

ns1:EntradasAnal_gicasGP_EtherCAT a ns1:ComponenteElectrico ;
    rdfs:label "Entradas analógicas de propósito general (EtherCAT)" ;
    ns1:identificador "40" ;
    ns1:textoExtracto "Entradas analógicas de propósito general. | 40" .

ns1:EntradasDigitales_EtherCAT a ns1:ComponenteElectrico ;
    rdfs:label "Entradas digitales (EtherCAT)" ;
    ns1:identificador "1024" ;
    ns1:textoExtracto "Entradas digitales. | 1024" .

ns1:EntradasPt100_EtherCAT a ns1:Sensor ;
    rdfs:label "Entradas para sondas Pt100 (EtherCAT)" ;
    ns1:identificador "10" ;
    ns1:textoExtracto "Entradas analógicas para sondas de temperatura Pt100. | 10" .

ns1:M_dulosIO_Remotos a ns1:ComponenteElectrico ;
    rdfs:label "Módulos remotos de I/O (EtherCAT)" ;
    ns1:textoExtracto "módulos remotos de I/Os (propios o de terceros)." .

ns1:SalidasAnal_gicasGP_EtherCAT a ns1:ComponenteElectrico ;
    rdfs:label "Salidas analógicas de propósito general (EtherCAT)" ;
    ns1:identificador "40" ;
    ns1:textoExtracto "Salidas analógicas de propósito general. | 40" .

ns1:SalidasDigitales_EtherCAT a ns1:ComponenteElectrico ;
    rdfs:label "Salidas digitales (EtherCAT)" ;
    ns1:identificador "1024" ;
    ns1:textoExtracto "Salidas digitales. | 1024" .

ns1:TiempoCicloBus a ns1:Parametro ;
    rdfs:label "Tiempo de ciclo del bus EtherCAT" ;
    ns1:identificador "LOOPTIME" ;
    ns1:textoExtracto "El tiempo de ciclo del bus está definido por el parámetro LOOPTIME." .

ns1:Manual_Q7_A a ns1:Manual ;
    rdfs:label "Manual de la plataforma Q7-A" ;
    ns1:textoExtracto "Proceso de configuración del bus EtherCAT en la plataforma Q7-A." .

