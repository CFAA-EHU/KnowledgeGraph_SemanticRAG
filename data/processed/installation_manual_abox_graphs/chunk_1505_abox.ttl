@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TareaMantenimiento_374885adee a ns1:TareaMantenimiento ;
    rdfs:label "Tarea de inserción de licencia" ;
    ns1:solucionaFallo ns1:AvisoSeguridad_7936149ba8 ;
    ns1:textoExtracto "Insertar el pendrive en el puerto USB y pulse el botón \"Ok\". Pulsar el botón \"Browse\" para seleccionar la unidad donde está conectado el pendrive y volver a pulsar el botón \"Ok\"." .

ns1:AvisoSeguridad_7936149ba8 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de error de licencia" ;
    ns1:solucionaFallo ns1:FalloDeteccionModulosLicencia ;
    ns1:textoExtracto "Ignorar este aviso. Fagor suministra la licencia \"Básica\", que permite configurar el bus." .

ns1:FalloDeteccionModulosLicencia a ns1:DiagnosticoFallo ;
    rdfs:label "Error de licencia durante la detección de módulos" ;
    ns1:textoExtracto "Error de licencia durante la detección de modulos. Ignorar este aviso." .

