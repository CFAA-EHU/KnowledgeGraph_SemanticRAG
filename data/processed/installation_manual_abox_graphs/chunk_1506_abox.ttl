@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesacoplarElMasterDelBus a ns1:TareaMantenimiento ;
    rdfs:label "Desacoplar el máster del bus" ;
    ns1:textoExtracto "Un paso previo para exportar la configuración es desaclopar el máster del bus. Para ello, colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción \"Detach master\"." .

ns1:DetectarRecursosDeCadaNodo a ns1:TareaMantenimiento ;
    rdfs:label "Detectar recursos de cada nodo" ;
    ns1:textoExtracto "Para detectar los recursos de cada nodo, colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción \"Attach master\"." .

ns1:EscanearElBusParaDetectarLosModulos a ns1:TareaMantenimiento ;
    rdfs:label "Escanear el bus para detectar los módulos" ;
    ns1:textoExtracto "Para detectar las cabeceras, colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción \"Scan configuration\"." .

ns1:InterfazUsuarioConfigurador a ns1:InterfazUsuario ;
    rdfs:label "Configurador" ;
    ns1:textoExtracto "El configurador muestra las cabeceras detectadas." .

ns1:ModoOperacionOnline a ns1:ModoOperacion ;
    rdfs:label "Modo online" ;
    ns1:textoExtracto "Con el programa arrancado, el primer paso es seleccionar el adaptador de red Ethernet." .

ns1:SubirListaDeModulosDetectados a ns1:TareaMantenimiento ;
    rdfs:label "Subir lista de módulos detectados" ;
    ns1:textoExtracto "En la pestaña \"MDP modules\", seleccionar la opción \"Upload detected Module Ident list\"." .

