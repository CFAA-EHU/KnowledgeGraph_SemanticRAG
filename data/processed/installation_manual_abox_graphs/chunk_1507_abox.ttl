@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConstruirManualmenteLaTopologiaDelBus a ns1:TareaMantenimiento ;
    rdfs:label "Construir manualmente la topología del bus" ;
    ns1:documentadoEn ns1:InterfazUsuarioConfiguracion ;
    ns1:textoExtracto "Para añadir cabeceras, colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción \"Append Slave\"." .

ns1:ModoOperacionOffline a ns1:ModoOperacion ;
    rdfs:label "Modo offline" ;
    ns1:textoExtracto "Para añadir cabeceras, colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción \"Append Slave\"." .

ns1:InterfazUsuarioConfiguracion a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de configuración" ;
    ns1:textoExtracto "En la pestaña \"MDP modules\" está la lista de módulos disponibles para la cabecera seleccionada. Arrastrar los módulos desde la ventana derecha a la ventana izquierda." .

