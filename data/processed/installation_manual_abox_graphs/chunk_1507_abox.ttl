@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteElectrico_ConectorLAN a ns1:ComponenteElectrico ;
    rdfs:label "Conector LAN de Ethernet" ;
    ns1:textoExtracto "acceder al bus a través del conector LAN de Ethernet" .

ns1:InterfazUsuario_KPAEtherCATStudio a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de KPA EtherCAT Studio" ;
    ns1:ilustradoEn ns1:Programa_KPAEtherCATStudio ;
    ns1:textoExtracto "A Topología EtherCAT. B Información ayuda. C Errores, avisos y mensajes del programa." .

ns1:Programa_MasterWin64 a ns1:Sistema ;
    rdfs:label "Master (Win64)" ;
    ns1:identificador "Master (Win64)" ;
    ns1:textoExtracto "ejecutar el programa \"Master (Win64)\". Este programa permite acceder al bus a través del conector LAN de Ethernet." .

ns1:Programa_KPAEtherCATStudio a ns1:Sistema ;
    rdfs:label "KPA EtherCAT Studio" ;
    ns1:identificador "KPA EtherCAT Studio" ;
    ns1:textoExtracto "Ejecutar el programa \"Studio\" para iniciar el configurador \"KPA EtherCAT Studio\"." .

