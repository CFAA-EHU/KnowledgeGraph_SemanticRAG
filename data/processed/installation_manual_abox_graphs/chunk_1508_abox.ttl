@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArchivoConfiguracion a ns1:Componente ;
    rdfs:label "Archivo de configuración" ;
    ns1:textoExtracto "El archivo se puede exportar con cualquier nombre (extensión *.xml). Este es el archivo que se debe copiar al CNC." .

ns1:DesacoplarElMasterDelBusParaExportarConfiguracionEnModoOnline a ns1:AccionProhibida ;
    rdfs:label "Desacoplar el máster del bus para exportar configuración en modo Online" ;
    ns1:textoExtracto "NOTA: En modo Online, para exportar la configuración hay que desaclopar el máster del bus (opción \"Detach master\")." .

ns1:ExportarArchivoDeConfiguracion a ns1:AccionProhibida ;
    rdfs:label "Exportar archivo de configuración" ;
    ns1:textoExtracto "Para exportar la configuración, colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción \"Export\" y \"Export Master Configuration ETG Standard\"." .

