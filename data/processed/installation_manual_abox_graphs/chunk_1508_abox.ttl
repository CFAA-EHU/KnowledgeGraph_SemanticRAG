@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorLicenciaArranque a ns1:AvisoSeguridad ;
    rdfs:label "Error de licencia al arrancar el programa"@es ;
    ns1:identificador "ErrorLicenciaArranque" ;
    ns1:textoExtracto "Error de licencia al arrancar el programa. El pendrive con la licencia debe estar conectado al PC. Si al arrancar el programa se produce el siguiente error, significa que el programa no encuentra la licencia."@es .

ns1:ErrorLicenciaModulos a ns1:AvisoSeguridad ;
    rdfs:label "Error de licencia durante la detección de módulos"@es ;
    ns1:identificador "ErrorLicenciaModulos" ;
    ns1:textoExtracto "Error de licencia durante la detección de modulos. Ignorar este aviso."@es .

ns1:LicenciaBasicaFagor a ns1:InterfazUsuario ;
    rdfs:label "Licencia Básica (Fagor)"@es ;
    ns1:identificador "LicenciaBasica" ;
    ns1:textoExtracto "Fagor suministra la licencia \"Básica\", que permite configurar el bus. Algunas opciones del configurador no estarán disponibles con esta licencia."@es .

