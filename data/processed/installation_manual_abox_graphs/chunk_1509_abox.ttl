@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacion_OnlineBusScan a ns1:ModoOperacion ;
    rdfs:label "Modo online: escaneo del bus"@es ;
    ns1:requiereMantenimiento ns1:TareaMantenimiento_DetectarModulos ;
    ns1:textoExtracto "20.1.4 Modo online. Escanear el bus para detectar los módulos."@es .

ns1:TareaMantenimiento_ExportarConfiguracion a ns1:TareaMantenimiento ;
    rdfs:label "Exportar configuración del bus"@es ;
    ns1:ejecutadoPor ns1:InterfazUsuario_Configurador ;
    ns1:requiereMantenimiento ns1:TareaMantenimiento_DetectarModulos ;
    ns1:textoExtracto "Un paso previo para exportar la configuración es desaclopar el máster del bus. Para ello, [...] seleccionar la opción 'Detach master'."@es .

ns1:Componente_AdaptadorEthernet a ns1:ComponenteElectrico ;
    rdfs:label "Adaptador de red Ethernet"@es ;
    ns1:textoExtracto "seleccionar el adaptador de red Ethernet"@es .

ns1:Sistema_TopologiaMaster a ns1:Sistema ;
    rdfs:label "Sistema de topología máster"@es ;
    ns1:compuestoPor ns1:Componente_AdaptadorEthernet ;
    ns1:textoExtracto "el máster de la topología (ventana izquierda)"@es .

ns1:InterfazUsuario_Configurador a ns1:InterfazUsuario ;
    rdfs:label "Interfaz del configurador (ventana izquierda)"@es ;
    ns1:textoExtracto "colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción 'Scan configuration' [...] seleccionar la opción 'Upload detected Module Ident list' [...] seleccionar la opción 'Attach master' [...] seleccionar la opción 'Detach master'."@es .

ns1:TareaMantenimiento_DetectarModulos a ns1:TareaMantenimiento ;
    rdfs:label "Detección de módulos en el bus"@es ;
    ns1:ejecutadoPor ns1:InterfazUsuario_Configurador ;
    ns1:habilitadoPor ns1:Sistema_TopologiaMaster ;
    ns1:textoExtracto "Para detectar las cabeceras, colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción 'Scan configuration'. [...] Para detectar los recursos de cada nodo, colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción 'Attach master'."@es .

