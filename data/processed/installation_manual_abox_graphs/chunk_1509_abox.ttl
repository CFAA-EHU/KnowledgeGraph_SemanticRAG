@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:GuardarElProyecto a ns1:TareaMantenimiento ;
    rdfs:label "Guardar el proyecto" ;
    ns1:textoExtracto "Para guardar el proyecto, seleccionar la opción File > Save. Guardar el proyecto con cualquier nombre (extensión *.ecsn)." .

ns1:NombreDelProyectoGuardado a ns1:Parametro ;
    rdfs:label "Nombre del Proyecto Guardado" ;
    ns1:textoExtracto "Guardar el proyecto con cualquier nombre (extensión *.ecsn)." .

