@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_1c3a01d90a a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC puede tener configurados dos palpadores; habitualmente será un palpador de sobremesa para calibrar herramientas y un palpador de medida para realizar mediciones en la pieza." ;
    ns1:tieneComponente ns1:ComponenteElectrico_687f0dbde1,
        ns1:ComponenteElectrico_db89b909b9,
        ns1:IndicaSiSeDisponeDeAlgunPalpadorEnLaMaquina .

ns1:TablaParametrosPalpador a ns1:Tabla ;
    rdfs:label "Parámetros del palpador" ;
    ns1:textoExtracto "Este parámetro muestra la tabla de parámetros necesarios para configurar el palpador." .

ns1:ComponenteElectrico_687f0dbde1 a ns1:ComponenteElectrico ;
    rdfs:label "Palpador de sobremesa" ;
    ns1:textoExtracto "Si el CNC dispone de un palpador de sobremesa, además de estos parámetros es necesario definir la posición del palpador." .

ns1:ComponenteElectrico_db89b909b9 a ns1:ComponenteElectrico ;
    rdfs:label "Palpador de medida" ;
    ns1:textoExtracto "El CNC puede tener configurados dos palpadores; habitualmente será un palpador de sobremesa para calibrar herramientas y un palpador de medida para realizar mediciones en la pieza." .

ns1:IndicaSiSeDisponeDeAlgunPalpadorEnLaMaquina a ns1:Parametro ;
    rdfs:label "Indica si se dispone de algún palpador en la máquina" ;
    ns1:identificador "MPG.PROBE" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.PROBE Este parámetro indica si se dispone de algún palpador en la máquina." .

