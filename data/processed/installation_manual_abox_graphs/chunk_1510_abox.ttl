@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArchivoConfiguracionFagorEthercatConfFile a ns1:DocumentoTecnico ;
    rdfs:label "archivo de configuración" ;
    ns1:textoExtracto "Para copiar el archivo de configuración al CNC (archivo xml), renombrarlo como \"fagor_ethercatConfFile.xml\" y copiarlo a la carpeta ../Mtb/Data." .

