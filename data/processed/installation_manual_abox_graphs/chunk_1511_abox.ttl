@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_763a509549 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:FicheroResourceRouterConf ;
    ns1:textoExtracto "CNC 8070" .

ns1:FicheroENI a ns1:DocumentoTecnico ;
    rdfs:label "fichero ENI generado por el configurador de EtherCAT" ;
    ns1:textoExtracto "A partir del fichero ENI generado por el configurador de EtherCAT, este programa hace una propuesta de mapeo." .

ns1:ModuloIBIL24DIDI32HDPAC a ns1:ComponenteElectrico ;
    rdfs:label "Módulo (1) IB IL 24 DI 32 - HD-PAC" ;
    ns1:textoExtracto "| Módulo (1) IB IL 24 DI 32 - HD-PAC | I9…I40 |" .

ns1:ModuloIBIL24DIDI8HD_ECO a ns1:ComponenteElectrico ;
    rdfs:label "Módulo (0) IB IL 24 DI 8 - HD-ECO" ;
    ns1:textoExtracto "| Módulo (0) IB IL 24 DI 8 - HD-ECO | I1…I8 |" .

ns1:ModuloIBIL24DODO32HDPAC a ns1:ComponenteElectrico ;
    rdfs:label "Módulo (3) IB IL 24 DO 32 - HD-PAC" ;
    ns1:textoExtracto "| Módulo (3) IB IL 24 DO 32 - HD-PAC | O9…O40 |" .

ns1:ModuloIBIL24DODO8HD_ECO a ns1:ComponenteElectrico ;
    rdfs:label "Módulo (2) IB IL 24 DO 8 - HD-ECO" ;
    ns1:textoExtracto "| Módulo (2) IB IL 24 DO 8 - HD-ECO | O1…O8 |" .

ns1:ModuloIBILAI4UPAC a ns1:ComponenteElectrico ;
    rdfs:label "Módulo (5) IB IL AI 4 - U-PAC" ;
    ns1:textoExtracto "| Módulo (5) IB IL AI 4 - U-PAC | R3...R6 |" .

ns1:ModuloIBILAO2UIPAC a ns1:ComponenteElectrico ;
