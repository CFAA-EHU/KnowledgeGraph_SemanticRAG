    ns1:textoExtracto "| Módulo (4) IB IL AO 2 - UI-PAC | R1…R2 |" .

ns1:ProgramaFagorEtherCATMapper a ns1:Herramienta ;
    rdfs:label "Fagor EtherCAT Mapper" ;
    ns1:textoExtracto "Fagor dispone del programa \"Fagor EtherCAT Mapper\" para realizar el mapeo."@es .

ns1:FicheroResourceRouterConf a ns1:DocumentoTecnico ;
    rdfs:label "resourceRouterConf.xml" ;
    ns1:textoExtracto "Este fichero se debe copiar a la carpeta ../Mtb/Data del CNC con el nombre \"resourceRouterConf.xml\"."@es .

