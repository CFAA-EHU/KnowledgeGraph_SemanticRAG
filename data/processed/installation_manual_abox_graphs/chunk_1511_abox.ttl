@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArchivoConfiguracion_1511 a ns1:InterfazUsuario ;
    rdfs:label "Archivo de configuración ETG (*.xml)"@es ;
    ns1:identificador "*.xml" ;
    ns1:textoExtracto "El archivo se puede exportar con cualquier nombre (extensión *.xml). Este es el archivo que se debe copiar al CNC."@es .

ns1:ExportarConfiguracion_1511 a ns1:TareaMantenimiento ;
    rdfs:label "Exportar archivo de configuración del máster"@es ;
    ns1:ejecutadoPor ns1:PersonalOperador_1511 ;
    ns1:requiereMantenimiento ns1:SistemaTopologia_1511 ;
    ns1:textoExtracto "Para exportar la configuración, colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción 'Export' y 'Export Master Configuration ETG Standard'. Este es el archivo que se debe copiar al CNC."@es .

ns1:ModoOnline_1511 a ns1:ModoOperacion ;
    rdfs:label "Modo Online (bus acoplado)"@es ;
    ns1:textoExtracto "En modo Online, para exportar la configuración hay que desaclopar el máster del bus (opción 'Detach master')."@es .

ns1:MasterETG_1511 a ns1:ComponenteElectrico ;
    rdfs:label "Máster ETG de la topología"@es ;
    ns1:identificador "ETG Standard" ;
    ns1:textoExtracto "máster de la topología [...] opción 'Export Master Configuration ETG Standard'"@es .

ns1:PersonalOperador_1511 a ns1:Personal ;
    rdfs:label "Operador del sistema"@es ;
    ns1:textoExtracto "colocar el ratón [...] pulsar el botón derecho del ratón y seleccionar la opción"@es .

ns1:SistemaTopologia_1511 a ns1:Sistema ;
    rdfs:label "Sistema de topología con máster ETG"@es ;
    ns1:textoExtracto "máster de la topología (ventana izquierda)"@es ;
    ns1:tieneComponente ns1:MasterETG_1511 .

