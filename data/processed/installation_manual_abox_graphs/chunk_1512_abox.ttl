@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EntradaAnalogicaEnCorriente a ns1:ComponenteElectrico ;
    rdfs:label "Entrada Analógica en Corriente" ;
    ns1:documentadoEn ns1:TablaMapeoRecursosEtherCATPLC ;
    ns1:textoExtracto "Entradas analógicas en corriente (mA)." .

ns1:SalidaAnalogicaEnCorriente a ns1:ComponenteElectrico ;
    rdfs:label "Salida Analógica en Corriente" ;
    ns1:documentadoEn ns1:TablaMapeoRecursosEtherCATPLC ;
    ns1:textoExtracto "Salidas analógicas en corriente (mA)." .

ns1:SalidaAnalogicaEnTension a ns1:ComponenteElectrico ;
    rdfs:label "Salida Analógica en Tensión" ;
    ns1:documentadoEn ns1:TablaMapeoRecursosEtherCATPLC ;
    ns1:textoExtracto "Salidas analógicas en tensión (V)." .

ns1:SondaDeTemperaturaPt100 a ns1:ComponenteElectrico ;
    rdfs:label "Sonda de Temperatura Pt100" ;
    ns1:documentadoEn ns1:TablaMapeoRecursosEtherCATPLC ;
    ns1:textoExtracto "Entradas para sondas de temperatura Pt100." .

ns1:TablaMapeoRecursosEtherCATPLC a ns1:Tabla ;
    rdfs:label "Tabla Mapeo Recursos EtherCAT PLC" ;
    ns1:textoExtracto "Entradas analógicas en corriente (mA). | Microamperios. Salidas analógicas en tensión (V). | Décimas de milivoltio. Salidas analógicas en corriente (mA). | Microamperios. Entradas para sondas de temperatura Pt100. | Déci..." .

