@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InstalarProgramaEnCNC a ns1:AccionProhibida ;
    rdfs:label "Instalar programa en CNC" ;
    ns1:textoExtracto "se recomienda la instalación en un PC externo, junto al configurador." .

ns1:InterfazUsuarioMapeadorEtherCAT a ns1:InterfazUsuario ;
    rdfs:label "Mapeador de recursos EtherCAT" ;
    ns1:textoExtracto "Función. | Mapeador de recursos EtherCAT." .

