@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioBarraConfiguracionPorDefecto a ns1:InterfazUsuario ;
    rdfs:label "Barra de configuración por defecto para el mapeo de recursos" ;
    ns1:textoExtracto "Barra de configuración por defecto para el mapeo de recursos. Esta barra muestra cuál es la configuración que asumen los recursos cuando se carga el archivo ENI por primera vez (configuración por defecto). Posteriormente, la asignación de recursos se puede personalizar manualmente." ;
    ns1:tieneComponente ns1:DigitalInput,
        ns1:DigitalOutput,
        ns1:RegisterInput,
        ns1:RegisterOutput .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:monitoreaParametro ns1:ValidacionDeLaOpcionOverlapped ;
    ns1:textoExtracto "Las fichas \"Register Input\" y \"Register Output\" mapean a registros de PLC aquellos recursos del bus EtherCAT que no son asumidos como entradas/salidas digitales." .

ns1:DigitalInput a ns1:ComponenteElectrico ;
    rdfs:label "Digital Input" ;
    ns1:textoExtracto "Las fichas \"Digital Input\" y \"Digital Output\" configuran el mapeo de las entradas y salidas digitales." .

ns1:DigitalOutput a ns1:ComponenteElectrico ;
    rdfs:label "Digital Output" ;
    ns1:textoExtracto "Las fichas \"Digital Input\" y \"Digital Output\" configuran el mapeo de las entradas y salidas digitales." .

ns1:RegisterInput a ns1:ComponenteElectrico ;
    rdfs:label "Register Input" ;
    ns1:textoExtracto "Las fichas \"Register Input\" y \"Register Output\" mapean a registros de PLC aquellos recursos del bus EtherCAT que no son asumidos como entradas/salidas digitales." .

ns1:RegisterOutput a ns1:ComponenteElectrico ;
    rdfs:label "Register Output" ;
    ns1:textoExtracto "Las fichas \"Register Input\" y \"Register Output\" mapean a registros de PLC aquellos recursos del bus EtherCAT que no son asumidos como entradas/salidas digitales." .

ns1:ValidacionDeLaOpcionOverlapped a ns1:Parametro ;
    rdfs:label "Validación de la opción Overlapped" ;
    ns1:textoExtracto "Validación de la opción \"Overlapped\". Ver en la página 754. \"20.2.5 Overlapped.\"" .

