@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArchivoInstalacion_FagorEtherCATMapper a ns1:InterfazUsuario ;
    rdfs:label "Setup fagorethercatmapper-x.x.x.exe" ;
    ns1:identificador "Setup fagorethercatmapper-x.x.x.exe" ;
    ns1:textoExtracto "Ejecutar el archivo \"Setup fagorethercatmapper-x.x.x.exe\" (donde x.x.x indica la versión) para iniciar la instalación." .

ns1:Icono_MapeadorEtherCAT a ns1:InterfazUsuario ;
    rdfs:label "Mapeador de recursos EtherCAT" ;
    ns1:documentadoEn ns1:FagorEtherCATMapper ;
    ns1:textoExtracto "en el escritorio aparece el siguiente icono. [...] | Icono. | Función. | [...] |  | Mapeador de recursos EtherCAT. |" .

ns1:FagorEtherCATMapper a ns1:Sistema ;
    rdfs:label "Fagor EtherCAT Mapper" ;
    ns1:identificador "fagorethercatmapper-x.x.x" ;
    ns1:textoExtracto "Aunque \"Fagor EtherCAT Mapper\" se puede ejecutar en el propio CNC, se recomienda la instalación en un PC externo, junto al configurador." .

