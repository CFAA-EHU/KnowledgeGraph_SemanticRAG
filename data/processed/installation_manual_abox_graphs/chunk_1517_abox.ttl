    ns1:textoExtracto "Color verde. Registros de las entradas analógicas Fagor." .

ns1:RegistrosDeLasSalidasAnalogicasFagor a ns1:ComponenteElectrico ;
    rdfs:label "Registros de las salidas analógicas Fagor" ;
