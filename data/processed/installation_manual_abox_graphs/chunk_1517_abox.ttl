@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioInterface a ns1:InterfazUsuario ;
    rdfs:label "Interface" ;
    ns1:ilustra ns1:EntradasDigitales_50a0e7375a,
        ns1:MapeoDeRecursosEtherCATARegistrosDePLC,
        ns1:MapeoDeRegistrosDePLCARecursosEtherCAT,
        ns1:RegistrosDeLasEntradasAnalogicasFagor,
        ns1:RegistrosDeLasSalidasAnalogicasFagor,
        ns1:SalidasDigitales_de8055056f ;
    ns1:textoExtracto "Bloque. Color y tipo de recurso." .

ns1:EntradasDigitales_50a0e7375a a ns1:ComponenteElectrico ;
    rdfs:label "Entradas digitales" ;
    ns1:textoExtracto "Color azul. Entradas digitales." .

ns1:MapeoDeRecursosEtherCATARegistrosDePLC a ns1:ComponenteElectrico ;
    rdfs:label "Mapeo de recursos EtherCAT a registros de PLC" ;
    ns1:textoExtracto "Color rojo. Mapeo de recursos EtherCAT a registros de PLC." .

