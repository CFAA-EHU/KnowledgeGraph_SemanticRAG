@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazConfiguracionEtherCAT a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de configuración de recursos EtherCAT"@es ;
    ns1:documentadoEn ns1:Manual_Seccion20_2_2 ;
    ns1:textoExtracto "Barra de configuración por defecto para el mapeo de recursos. Esta barra muestra cuál es la configuración que asumen los recursos cuando se carga el archivo ENI por primera vez (configuración por defecto). Posteriormente, la asignación de recursos se puede personalizar manualmente."@es ;
    ns1:tieneComponente ns1:FichaDigitalInput,
        ns1:FichaDigitalOutput,
        ns1:FichaOverlapped,
        ns1:FichaRegisterInput,
        ns1:FichaRegisterOutput,
        ns1:TopologiaBusEtherCAT .

ns1:ParametroOffset a ns1:Parametro ;
    rdfs:label "Offset de numeración entre cabeceras"@es ;
    ns1:textoExtracto "Offset. Offset de numeración entre cabeceras. Si el offset es cero, la numeración será consecutiva entre cabeceras."@es .

ns1:ParametroStarts a ns1:Parametro ;
    rdfs:label "Número de la primera entrada/salida/registro (Starts)"@es ;
    ns1:textoExtracto "Starts. Número de la primera entrada, salida o registro del bus."@es .

ns1:ParametroVisible a ns1:Parametro ;
    rdfs:label "Mostrar numeración en gráfico (Visible)"@es ;
    ns1:textoExtracto "Visible. Mostrar la numeración en el gráfico."@es .

ns1:FichaDigitalInput a ns1:Componente ;
    rdfs:label "Ficha 'Digital Input'"@es ;
    ns1:textoExtracto "Las fichas 'Digital Input' y 'Digital Output' configuran el mapeo de las entradas y salidas digitales."@es .

ns1:FichaDigitalOutput a ns1:Componente ;
    rdfs:label "Ficha 'Digital Output'"@es ;
    ns1:textoExtracto "Las fichas 'Digital Input' y 'Digital Output' configuran el mapeo de las entradas y salidas digitales."@es .

ns1:FichaOverlapped a ns1:Componente ;
    rdfs:label "Ficha 'Overlapped'"@es ;
    ns1:textoExtracto "La ficha 'Overlapped' define si se permite la superposición de recursos en diferentes módulos. Ver en la página 754. '20.2.5 Overlapped'."@es .

ns1:FichaRegisterInput a ns1:Componente ;
    rdfs:label "Ficha 'Register Input'"@es ;
    ns1:textoExtracto "Las fichas 'Register Input' y 'Register Output' mapean a registros de PLC aquellos recursos del bus EtherCAT que no son asumidos como entradas/salidas digitales."@es .

ns1:FichaRegisterOutput a ns1:Componente ;
    rdfs:label "Ficha 'Register Output'"@es ;
    ns1:textoExtracto "Las fichas 'Register Input' y 'Register Output' mapean a registros de PLC aquellos recursos del bus EtherCAT que no son asumidos como entradas/salidas digitales."@es .

ns1:Manual_Seccion20_2_2 a ns1:Manual ;
    rdfs:label "Sección 20.2.2 - Descripción del interface"@es ;
    ns1:identificador "20.2.2" ;
    ns1:textoExtracto "Descripción del interface. Barra de configuración por defecto para el mapeo de recursos EtherCAT."@es .

ns1:TopologiaBusEtherCAT a ns1:Componente ;
    rdfs:label "Topología del bus EtherCAT (vista de árbol)"@es ;
    ns1:textoExtracto "Topología del bus (vista de árbol). El primer nivel está formado por los esclavos del bus. Al hacer clic sobre un esclavo, el programa muestra los módulos conectados al bus. El segundo nivel está formado por los módulos que pertenecen al esclavo. Al hacer clic sobre un módulo, el programa muestra su lista de recursos."@es .

