@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AbrirUnaConfiguracionMapeoPorDefecto a ns1:TareaMantenimiento ;
    rdfs:label "Abrir una configuración (mapeo por defecto)" ;
    ns1:textoExtracto "El programa asigna los recursos según lo definido en la barra de configuración." .

ns1:DocumentoTecnicoConfiguracionDefault a ns1:DocumentoTecnico ;
    rdfs:label "Archivo ENI" ;
    ns1:textoExtracto "Cargar el archivo ENI creado con el configurador." .

