@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModificarLaNumeracionDeLosRecursos a ns1:TareaMantenimiento ;
    rdfs:label "Modificar la numeración de los recursos" ;
    ns1:textoExtracto "Modificar la numeración de los recursos de todo el bus. Modificar los recursos en la barra superior y el programa actualiza los recursos de todo el bus." .

ns1:ModificarLaNumeracionDeLosRecursosDeUnModulo a ns1:TareaMantenimiento ;
    rdfs:label "Modificar la numeración de los recursos de un módulo" ;
    ns1:textoExtracto "Modificar la numeración de los recursos de un módulo. En la vista de bloques, hacer clic sobre un módulo y definir el número con el que empiezan sus recursos; el resto de recursos se numeran de forma correlativa." .

ns1:ModificarLaNumeracionDeLosRecursosDeUnNodo a ns1:TareaMantenimiento ;
    rdfs:label "Modificar la numeración de los recursos de un nodo" ;
    ns1:textoExtracto "Modificar la numeración de los recursos de un nodo. En la vista de bloques, hacer clic sobre el nombre de la cabecera y definir el número con el que empiezan los recursos del nodo." .

ns1:OffsetSalidasDigitales a ns1:Parametro ;
    rdfs:label "Offset entradas digitales",
        "Offset salidas digitales" ;
    ns1:identificador "Offset" ;
    ns1:textoExtracto "• Entradas digitales. Primera = 10 Offset = 100",
        "• Salidas digitales. Primera = 21 Offset = 50 Offset = 100 Offset = 100" ;
    ns1:valor "100",
        "50" .

ns1:PrimeraSalidaDigital a ns1:Parametro ;
    rdfs:label "Primera entrada digital",
        "Primera salida digital" ;
    ns1:identificador "Primera" ;
    ns1:textoExtracto "• Entradas digitales. Primera = 10 Offset = 100",
        "• Salidas digitales. Primera = 21 Offset = 50 Offset = 100 Offset = 100" ;
    ns1:valor "10",
        "21" .

