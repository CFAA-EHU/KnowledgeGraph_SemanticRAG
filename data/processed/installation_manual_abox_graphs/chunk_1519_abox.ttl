@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_1519 a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de visualización de topología del bus" ;
    ns1:ilustradoEn ns1:Esquema_TopologiaBus_1519 ;
    ns1:textoExtracto "Para mostrar todos los esclavos, hacer clic en el icono \"Ver esclavos\". El segundo nivel está formado por los módulos que pertenecen al esclavo. Al hacer clic sobre un módulo, el programa muestra su lista de recursos. To..." .

ns1:Esquema_TopologiaBus_1519 a ns1:Esquema ;
    rdfs:label "Topología del bus (vista de bloques)" ;
    ns1:textoExtracto "Topología del bus (vista de bloques)." .

