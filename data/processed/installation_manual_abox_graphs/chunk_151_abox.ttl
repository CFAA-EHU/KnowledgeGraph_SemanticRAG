@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Regulador_v9_10 a ex:ComponenteElectrico ;
    ex:textoExtracto "Esta prestación requiere una versión de regulador v9.10 o posterior." ;
    ex:identificador "v9.10" .

ex:SensorGap a ex:Sensor ;
    ex:textoExtracto "consultar en el manual de i regulador el conexionado del sensor del gap" .

ex:ModuloRemotoEtherCAT a ex:ComponenteElectrico ;
    ex:textoExtracto "Entrada analógica de los módulos remotos EtherCAT" .

ex:RegistroPLC a ex:ComponenteElectrico ;
    ex:textoExtracto "este parámetro indica el registro del PLC que mapea la entrada" .