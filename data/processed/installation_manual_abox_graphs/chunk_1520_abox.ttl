@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsignarUnNumeroQueYaExisteEnElBus a ns1:AccionProhibida ;
    rdfs:label "Asignar un número que ya existe en el bus" ;
    ns1:solucionaFallo ns1:DiagnosticoFalloErrorPrograma ;
    ns1:textoExtracto "En el caso de asignar a un recurso un número que ya existe en el bus, el programa dará error." .

ns1:DefineElInicioDelRangoDeNumeracion a ns1:Parametro ;
    rdfs:label "Define el inicio del rango de numeración" ;
    ns1:identificador "Starts" ;
    ns1:textoExtracto "Starts=81 Overlapped = No." .

ns1:DefineSiSePermiteLaSuperposicionDeRecursosEnDiferentesModulos a ns1:Parametro ;
    rdfs:label "Define si se permite la superposición de recursos en diferentes módulos" ;
    ns1:identificador "Overlapped" ;
    ns1:textoExtracto "La ficha \"Overlapped\" define si se permite la superposición de recursos en diferentes módulos." .

ns1:ValidacionDelFiltro a ns1:TareaMantenimiento ;
    rdfs:label "Validación del filtro" ;
    ns1:textoExtracto "Cada vez que se modifica está opción, hay que validarla con el icono \"Load filter\" situado en la parte superior derecha." .

