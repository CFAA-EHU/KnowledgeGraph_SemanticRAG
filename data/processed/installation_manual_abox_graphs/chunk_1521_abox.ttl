@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArchivoENI_1521 a ns1:InterfazUsuario ;
    rdfs:label "Archivo ENI"@es ;
    ns1:habilitadoPor ns1:ConfiguracionPorDefecto_1521 ;
    ns1:textoExtracto "archivo ENI creado con el configurador"@es .

ns1:BarraConfiguracion_1521 a ns1:InterfazUsuario ;
    rdfs:label "Barra de configuración"@es ;
    ns1:documentadoEn ns1:ConfiguracionPorDefecto_1521 ;
    ns1:textoExtracto "barra de configuración"@es .

ns1:ConfiguracionPorDefecto_1521 a ns1:ModoOperacion ;
    rdfs:label "Configuración por defecto (mapeo)"@es ;
    ns1:identificador "20.2.3" ;
    ns1:textoExtracto "Abrir una configuración (mapeo por defecto). Cargar el archivo ENI creado con el configurador. El programa asigna los recursos según lo definido en la barra de configuración."@es .

