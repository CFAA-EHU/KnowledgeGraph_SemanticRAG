@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ExportarArchivoDeRutado a ns1:TareaMantenimiento ;
    rdfs:label "Exportar archivo de rutado" ;
    ns1:textoExtracto "Para exportar el archivo de rutado, seleccionar la opción \"Exports router file\". El archivo se puede exportar con cualquier nombre (extensión *.xml). Este es el archivo que se debe copiar al CNC." .

