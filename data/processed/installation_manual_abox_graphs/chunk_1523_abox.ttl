@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:GuardarElProyecto_e66014b033 a ns1:TareaMantenimiento ;
    rdfs:label "Guardar el proyecto" ;
    ns1:textoExtracto "Para guardar el proyecto, seleccionar la opción \"Generate project\". Guardar el proyecto con cualquier nombre (extensión *.fem)."@es .

ns1:GuardarSinFinalizar a ns1:AccionProhibida ;
    rdfs:label "Guardar sin finalizar" ;
    ns1:textoExtracto "El proyecto se puede guardar aunque no esté finalizado." .

