@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArchivoRutadoXML a ns1:Parametro ;
    rdfs:label "Archivo de rutado (*.xml)"@es ;
    ns1:textoExtracto "El archivo se puede exportar con cualquier nombre (extensión *.xml). Este es el archivo que se debe copiar al CNC."@es ;
    ns1:valor "*.xml" .

ns1:ExportarArchivoRutado_20_2_7 a ns1:TareaMantenimiento ;
    rdfs:label "Exportar archivo de rutado"@es ;
    ns1:identificador "20.2.7" ;
    ns1:textoExtracto "Para exportar el archivo de rutado, seleccionar la opción \"Exports router file\". El archivo se puede exportar con cualquier nombre (extensión *.xml). Este es el archivo que se debe copiar al CNC."@es .

ns1:OpcionExportsRouterFile a ns1:InterfazUsuario ;
    rdfs:label "Exports router file"@es ;
    ns1:textoExtracto "seleccionar la opción \"Exports router file\""@es .

