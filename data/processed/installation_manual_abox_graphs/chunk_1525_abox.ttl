@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoDiagnosis a ns1:ModoOperacion ;
    rdfs:label "modo diagnosis" ;
    ns1:textoExtracto "El modo diagnosis ofrece toda la información necesaria de los módulos conectados al bus EtherCAT." .

