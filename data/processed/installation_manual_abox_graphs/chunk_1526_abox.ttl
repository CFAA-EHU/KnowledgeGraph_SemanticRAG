@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_c92d530a50 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:monitoreaParametro ns1:ErrorGenericoDeEtherCAT ;
    ns1:textoExtracto "El CNC muestra el siguiente error genérico cuando detecta un error en un nodo." ;
    ns1:tieneComponente ns1:ModuloEnError,
        ns1:NodoEnError .

ns1:ErrorGenericoDeEtherCAT a ns1:Parametro ;
    rdfs:label "Error genérico de EtherCAT" ;
    ns1:identificador "24499" ;
    ns1:textoExtracto "Error 24499. Error genérico de EtherCAT." .

ns1:ModuloEnError a ns1:Componente ;
    rdfs:label "Módulo en Error" ;
    ns1:textoExtracto "Información detallada del módulo en error." .

ns1:NodoEnError a ns1:Componente ;
    rdfs:label "Nodo en Error" ;
    ns1:textoExtracto "El árbol de configuración identifica el nodo en error." .

