@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AtributoFirmware a ns1:Parametro ;
    rdfs:label "Versión del Firmware" ;
    ns1:identificador "FIRMWARE" ;
    ns1:textoExtracto "Se muestra una lista de atributos (modelo, firmware, recuento de errores, temperatura, horas de encendido, etc.)" .

ns1:AtributoHorasEncendido a ns1:Parametro ;
    rdfs:label "Horas de Encendido" ;
    ns1:identificador "POWER_ON_HOURS" ;
    ns1:textoExtracto "Se muestra una lista de atributos (modelo, firmware, recuento de errores, temperatura, horas de encendido, etc.)" .

ns1:AtributoModelo a ns1:Parametro ;
    rdfs:label "Modelo del Disco" ;
    ns1:identificador "MODEL" ;
    ns1:textoExtracto "Se muestra una lista de atributos (modelo, firmware, recuento de errores, temperatura, horas de encendido, etc.)" .

ns1:AtributoRecuentoErrores a ns1:Parametro ;
    rdfs:label "Recuento de Errores" ;
    ns1:identificador "ERROR_COUNT" ;
    ns1:textoExtracto "Se muestra una lista de atributos (modelo, firmware, recuento de errores, temperatura, horas de encendido, etc.)" .

ns1:AtributoTemperatura a ns1:Parametro ;
    rdfs:label "Temperatura del Disco" ;
    ns1:identificador "TEMPERATURE" ;
    ns1:textoExtracto "Se muestra una lista de atributos (modelo, firmware, recuento de errores, temperatura, horas de encendido, etc.)" .

ns1:CNC8070_547fb49974 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Definir la IP adecuada (la del CNC)." ;
    ns1:tieneComponente ns1:InterfazUsuarioConfiguracionDisco,
        ns1:InterfazUsuarioModosTrabajo .

ns1:EstadoAdministradorMode a ns1:Sistema ;
    rdfs:label "ADMINISTRATOR MODE" ;
    ns1:textoExtracto "Dos imágenes de escritorio a modo de cartelas de estado: una con fondo rojo y texto 'ADMINISTRATOR MODE'" .

ns1:EstadoSetupMode a ns1:Sistema ;
    rdfs:label "SETUP MODE" ;
    ns1:textoExtracto "y otra con fondo amarillo y texto 'SETUP MODE'. Funcionan como señalización visual del modo activo, advirtiendo que se trata de entornos no protegidos." .

ns1:InterfazUsuarioConfiguracionDisco a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de Configuración Disco" ;
    ns1:textoExtracto "Captura de interfaz del panel 'Configuration > Disk' con lectura S.M.A.R.T. del disco M2-SATA." .

ns1:InterfazUsuarioModosTrabajo a ns1:InterfazUsuario ;
    rdfs:label "Ventana de Modos de Trabajo" ;
    ns1:textoExtracto "Ventana de sistema 'RESTART WINDOWS' con tres botones que representan los modos de trabajo." .

