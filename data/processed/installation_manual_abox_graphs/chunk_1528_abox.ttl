@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoDiagnosisCNC a ns1:ModoOperacion ;
    rdfs:label "Modo diagnosis del CNC" ;
    ns1:monitoreaParametro ns1:ParametrosBusEtherCAT ;
    ns1:textoExtracto "El modo diagnosis ofrece toda la información necesaria de los módulos conectados al bus EtherCAT." .

ns1:ParametrosBusEtherCAT a ns1:Parametro ;
    rdfs:label "Parámetros del bus EtherCAT" ;
    ns1:textoExtracto "Información general del bus. Información de los esclavos. Información de los módulos." .

