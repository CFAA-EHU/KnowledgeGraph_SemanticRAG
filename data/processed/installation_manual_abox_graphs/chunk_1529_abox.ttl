@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteMecanico_3387d956a5 a ns1:ComponenteMecanico ;
    rdfs:label "Motor Esclavo",
        "Motor Maestro" ;
    ns1:compuestoPor ns1:CNC8070_521317e23b ;
    ns1:textoExtracto "Esquema mecánico de un eje tándem con dos motores (Master axis y Slave axis) que accionan sendos piñones sobre una misma cremallera ('Rack'). Las flechas/etiquetas indican maestro y esclavo; la disposición resalta la suma de par y la posibilidad de precarga para reducir holgura." .

ns1:EsquemaCompensacionCruzada a ns1:Esquema ;
    rdfs:label "Diagrama Compensación Cruzada" ;
    ns1:textoExtracto "Diagrama conceptual de 'compensación cruzada' donde un eje maestro (MOVAXIS) provoca variaciones en un eje compensado (COMPAXIS)." .

ns1:EsquemaEjeGantry a ns1:Esquema ;
    rdfs:label "Esquema Eje Gantry" ;
    ns1:textoExtracto "Ilustración esquemática de una fresadora tipo puente en la que se muestran dos parejas de ejes gantry (X–U en la bancada y Z–W en el montante). Se aprecian los carros y el travesaño, con flechas implícitas de desplazamiento lineal y los rótulos de cada eje junto a su guía correspondiente." .

ns1:EsquemaEjeTandem a ns1:Esquema ;
    rdfs:label "Esquema Eje Tándem" ;
    ns1:textoExtracto "Esquema mecánico de un eje tándem con dos motores (Master axis y Slave axis) que accionan sendos piñones sobre una misma cremallera ('Rack'). Las flechas/etiquetas indican maestro y esclavo; la disposición resalta la suma de par y la posibilidad de precarga para reducir holgura." .

ns1:CNC8070_521317e23b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "La imagen contextualiza el procedimiento de obtención del instalador SetupHelp_Vxx.xx.exe y los tipos/idiomas de ayuda soportados." .

