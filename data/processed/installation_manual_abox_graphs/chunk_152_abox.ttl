@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeEntradaAsociadaAlPalpador1_e33c761a96 a ns1:Parametro ;
    rdfs:label "Número de entrada asociada al palpador 1" ;
    ns1:identificador "MPG.PRBDI1" ;
    ns1:textoExtracto "PRBDI1 Número de entrada asociada al palpador 1. Valores posibles: De 1 a 1024 para el palpador remoto / de 1 a 2 para el palpador local. Valor por defecto: 0 (no hay palpador conectado)." .

ns1:NumeroDeEntradaAsociadaAlPalpador2_e018294409 a ns1:Parametro ;
    rdfs:label "Número de entrada asociada al palpador 2" ;
    ns1:identificador "MPG.PRBDI2" ;
    ns1:textoExtracto "PRBDI2 Número de entrada asociada al palpador 2. Valores posibles: De 1 a 1024 para el palpador remoto / de 1 a 2 para el palpador local. Valor por defecto: 0 (no hay palpador conectado)." .

ns1:TipoDePalpador1_1152d23ccd a ns1:Parametro ;
    rdfs:label "Tipo de palpador 1" ;
    ns1:identificador "MPG.PROBETYPE1" ;
    ns1:textoExtracto "PROBETYPE1 Tipo de palpador 1. Valores posibles: Remoto / Local / Gap (sólo modelo láser). Valor por defecto: Remoto." .

ns1:TipoDePalpador2_984ac946fc a ns1:Parametro ;
    rdfs:label "Tipo de palpador 2" ;
