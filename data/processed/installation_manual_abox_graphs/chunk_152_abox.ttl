@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_GAPDISTLIMIT
    a ex:Parametro ;
    rdfs:label "GAPDISTLIMIT" ;
    ex:identificador "GAPDISTLIMIT" ;
    ex:valor "10.0000 mm / 0.39370 inch" ;
    ex:textoExtracto "Distancia que corresponde a la señal analógica límite del sensor. Valores posibles: De 0 a 99999.9999 mm / De 0 a 3937.00787 inch. Valor por defecto: 10.0000 mm / 0.39370 inch." .

ex:Parametro_GAPVOLTLIMIT
    a ex:Parametro ;
    rdfs:label "GAPVOLTLIMIT" ;
    ex:identificador "GAPVOLTLIMIT" ;
    ex:valor "10000 mV" ;
    ex:textoExtracto "Voltaje que corresponde al recorrido límite del sensor. Valores posibles: De 0 a 10000 mV. Valor por defecto: 10000 mV." .

ex:Parametro_GAPSENSOROFFSET
    a ex:Parametro ;
    rdfs:label "GAPSENSOROFFSET" ;
    ex:identificador "GAPSENSOROFFSET" ;
    ex:valor "0 mV" ;
    ex:textoExtracto "Offset a aplicar al sensor. Valores posibles: Entre ±10000 mV. Valor por defecto: 0 mV. Offset (en milivoltios) a aplicar al sensor desde el CNC." .

ex:Parametro_GAPSENSORCH
    a ex:Parametro ;
    rdfs:label "GAPSENSORCH" ;
    ex:identificador "GAPSENSORCH" ;
    ex:valor "No" ;
    ex:textoExtracto "Cambiar el signo de la señal del sensor. Valores posibles: Sí / No. Valor por defecto: No." .

ex:Parametro_GAPGAIN
    a ex:Parametro ;
    rdfs:label "GAPGAIN" ;
    ex:identificador "GAPGAIN" ;
    ex:valor "0.2" ;
    ex:textoExtracto "Ganancia proporcional a aplicar en GAPCTRL. Valores posibles: De 0.0000 a 100.0000. Valor por defecto: 0.2." .

ex:Sensor_ControlGap
    a ex:Sensor ;
    rdfs:label "Sensor de control de gap" ;
    ex:textoExtracto "Entrada analógica de los módulos remotos EtherCAT. En este caso, este parámetro indica el registro del PLC que mapea la entrada analógica conectada al sensor." ;
    ex:monitoreaParametro ex:Parametro_GAPDISTLIMIT ;
    ex:monitoreaParametro ex:Parametro_GAPVOLTLIMIT .