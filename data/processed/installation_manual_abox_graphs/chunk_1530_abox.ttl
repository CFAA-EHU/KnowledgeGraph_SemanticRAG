@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConexionRed_OpenPCS_1530 a ns1:InterfazUsuario ;
    rdfs:label "Conexión de red FagorCNCTCP" ;
    ns1:documentadoEn ns1:Manual_OpenPCS_1530 ;
    ns1:identificador "FagorCNCTCP" ;
    ns1:textoExtracto "El script crea una conexión de red con una IP por defecto (la IP de loopback 127.0.0.1). Para conectarnos al CNC, hay que configurar la conexión con su IP. [...] En el cuadro de diálogo anterior, pulsar el botón Settings para mostrar los datos de la conexión. Definir la IP adecuada (la del CNC)."^^rdfs:Literal .

ns1:ModuloHardware_OpenPCS_1530 a ns1:Componente ;
    rdfs:label "Módulo hardware de OpenPCS remoto" ;
    ns1:detalladoEnEsquema ns1:Manual_OpenPCS_1530 ;
    ns1:textoExtracto "La carpeta contiene un script que hay que copiar y ejecutar en el PC de trabajo. Este script crea el módulo hardware para el que se va a compilar el programa PLC, y también crea una conexión de red para poder descargar el programa en el CNC, monitorizarlo y depurarlo."^^rdfs:Literal .

ns1:OpenPCS_Remoto_1530 a ns1:Sistema ;
    rdfs:label "OpenPCS remoto" ;
    ns1:cumpleNormativa ns1:Directiva_IEC_61131_1530 ;
    ns1:identificador "IEC-61131" ;
    ns1:textoExtracto "El OpenPCS deberá estar instalado en un PC externo, el cual podrá estar conectado al CNC a través de una red o un cable cruzado. El CNC debe estar en marcha y con la opción IEC activa para poder comunicarse con el OpenPCS y poder ejecutar el programa PLC remoto (IEC-61131)."^^rdfs:Literal .

ns1:Parametro_PLCTYPE_MPG_1530 a ns1:Parametro ;
    rdfs:label "PLCTYPE (MPG)" ;
    ns1:documentadoEn ns1:Tabla_ArranqueParadaPLC_1530 ;
    ns1:identificador "PLCTYPE MPG" ;
    ns1:textoExtracto "Tipo de PLC; estándar IEC-61131 y/o Fagor."^^rdfs:Literal .

ns1:ScriptConfiguracion_OpenPCS_1530 a ns1:Componente ;
    rdfs:label "Script de configuración de OpenPCS" ;
    ns1:detalladoEnEsquema ns1:Manual_OpenPCS_1530 ;
    ns1:textoExtracto "La carpeta contiene un script que hay que copiar y ejecutar en el PC de trabajo. Este script crea el módulo hardware para el que se va a compilar el programa PLC, y también crea una conexión de red para poder descargar el programa en el CNC, monitorizarlo y depurarlo."^^rdfs:Literal .

ns1:Directiva_IEC_61131_1530 a ns1:Directiva ;
    rdfs:label "IEC-61131" ;
    ns1:identificador "IEC-61131" ;
    ns1:textoExtracto "El CNC debe estar en marcha y con la opción IEC activa para poder comunicarse con el OpenPCS y poder ejecutar el programa PLC remoto (IEC-61131)."^^rdfs:Literal .

ns1:Tabla_ArranqueParadaPLC_1530 a ns1:Tabla ;
    rdfs:label "Tabla de afectación por arranque (RUN) y parada (STOP) del PLC" ;
    ns1:ilustradoEn ns1:Manual_OpenPCS_1530 ;
    ns1:textoExtracto "La siguiente tabla muestra a quién afecta el arranque (RUN) y la parada (STOP) del PLC en función de este parámetro, así como el estado de la marca PLCREADY."^^rdfs:Literal .

ns1:Manual_OpenPCS_1530 a ns1:Manual ;
    rdfs:label "Manual de configuración OpenPCS remoto" ;
    ns1:textoExtracto "Configurar el CNC para utilizar el PLC remoto. [...] La información que necesita el OpenPCS para generar el PLC adecuado para el CNC está en la carpeta ..\\Fagor\\Plc\\Openpcs del propio CNC."^^rdfs:Literal .

