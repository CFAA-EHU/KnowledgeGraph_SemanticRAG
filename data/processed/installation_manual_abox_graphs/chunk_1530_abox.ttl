@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteMecanico_b9720093d0 a ns1:ComponenteMecanico ;
    rdfs:label "Herramienta de torneado" ;
    ns1:textoExtracto "se observa el útil de torneado aproximándose al palpador fijo instalado en la bancada." .

ns1:ComponenteMecanico_f44f65d118 a ns1:ComponenteMecanico ;
    rdfs:label "Palpador de sobremesa" ;
    ns1:textoExtracto "Ilustración de un palpador de sobremesa para calibración de herramientas en torno." .

ns1:Sensor_9a0b597646 a ns1:Sensor ;
    rdfs:label "Sensor de gap" ;
    ns1:textoExtracto "Gráfico del sensor de gap con ejes mV (horizontal) y mm/inch (vertical)." .

ns1:SistemaCompensacionCruzada a ns1:Sistema ;
    rdfs:label "Sistema de compensación cruzada" ;
    ns1:textoExtracto "Diagrama conceptual de 'compensación cruzada' donde un eje maestro (MOVAXIS) provoca variaciones en un eje compensado (COMPAXIS)." ;
    ns1:tieneComponente ns1:EjeCompensado,
        ns1:EjeMaestro .

ns1:SistemaMedidaPalpador a ns1:Sistema ;
    rdfs:label "Sistema de medida con palpador" ;
    ns1:textoExtracto "Ilustración de un palpador de medida montado en máquina para inspección de pieza:" ;
    ns1:tieneComponente ns1:PalpadorTipoEsferico .

ns1:EjeCompensado a ns1:ComponenteMecanico ;
    rdfs:label "Eje Compensado" ;
    ns1:textoExtracto "Diagrama conceptual de 'compensación cruzada' donde un eje maestro (MOVAXIS) provoca variaciones en un eje compensado (COMPAXIS)." .

ns1:EjeMaestro a ns1:ComponenteMecanico ;
    rdfs:label "Eje Maestro" ;
    ns1:textoExtracto "Diagrama conceptual de 'compensación cruzada' donde un eje maestro (MOVAXIS) provoca variaciones en un eje compensado (COMPAXIS)." .

ns1:PalpadorTipoEsferico a ns1:ComponenteMecanico ;
    rdfs:label "Palpador tipo esférico" ;
    ns1:textoExtracto "se representa un palpador tipo esférico acercándose a la superficie de una pieza cilíndrica," .

