@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_c6635d4df1 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "útil para ajustar offset y límites del sensor desde el CNC." .

ns1:DiagramaCompensacion a ns1:Figura ;
    rdfs:label "Diagrama de compensación con eje esclavo" ;
    ns1:textoExtracto "Diagrama de compensación con eje esclavo (SLAVE) y trayectorias del rayo láser." .

ns1:EsquemaGapControl a ns1:Esquema ;
    rdfs:label "Diagrama funcional del lazo de control del gap" ;
    ns1:textoExtracto "Diagrama funcional del lazo de control del gap: la realimentación del sensor (GAP SENSOR FEEDBACK) entra a un bucle de posición (POSITION LOOP)" .

ns1:EsquemaGapOrientation a ns1:Esquema ;
    rdfs:label "Orientación del eje Z" ;
    ns1:textoExtracto "Esquema 'GAPTONEG = Sí': orienta el eje Z con Z+ hacia arriba (condición normal). El cabezal láser desciende (movimiento en sentido negativo) hasta alcanzar el gap respecto a la pieza (WORKPIECE)" .

ns1:EsquemaGapOrientationInverted a ns1:Esquema ;
    rdfs:label "Orientación del eje Z invertido" ;
    ns1:textoExtracto "Esquema 'GAPTONEG = No': representa un eje Z invertido (Z+ hacia abajo). El movimiento para lograr el gap se realiza en sentido positivo." .

ns1:FiltroDeCorte a ns1:Parametro ;
    rdfs:label "Filtro de corte" ;
    ns1:textoExtracto "Diagrama funcional del lazo de control del gap: ... un filtro de corte (CUTOFF FILTER), esquematizando dónde se atenúa la alta frecuencia antes del control de posición." .

ns1:GananciaProporcionalDelGap a ns1:Parametro ;
    rdfs:label "Ganancia proporcional del gap" ;
    ns1:textoExtracto "Diagrama funcional del lazo de control del gap: la realimentación del sensor (GAP SENSOR FEEDBACK) entra a un bucle de posición (POSITION LOOP) con ganancia proporcional de gap (GAP P-GAIN)" .

ns1:LimiteDeDistanciaDelSensorDeGap a ns1:Parametro ;
    rdfs:label "Límite de distancia del sensor de gap" ;
    ns1:textoExtracto "Gráfico del sensor de gap con ejes mV (horizontal) y mm/inch (vertical). Representa la señal del sensor (SENSOR SIGNAL) frente al offset aplicado (GAPSENSOROFFSET), el límite de voltaje (GAPVOLTLIMIT) y el límite de distancia (GAPDISTLIMIT)" .

ns1:LimiteDeVoltajeDelSensorDeGap a ns1:Parametro ;
    rdfs:label "Límite de voltaje del sensor de gap" ;
    ns1:textoExtracto "Gráfico del sensor de gap con ejes mV (horizontal) y mm/inch (vertical). Representa la señal del sensor (SENSOR SIGNAL) frente al offset aplicado (GAPSENSOROFFSET), el límite de voltaje (GAPVOLTLIMIT)" .

ns1:OffsetAplicadoDelSensorDeGap a ns1:Parametro ;
    rdfs:label "Offset aplicado del sensor de gap" ;
    ns1:textoExtracto "Gráfico del sensor de gap con ejes mV (horizontal) y mm/inch (vertical). Representa la señal del sensor (SENSOR SIGNAL) frente al offset aplicado (GAPSENSOROFFSET)" .

ns1:OrientacionDelEjeZ a ns1:Parametro ;
    rdfs:label "Orientación del eje Z" ;
    ns1:textoExtracto "Esquema 'GAPTONEG = Sí': orienta el eje Z con Z+ hacia arriba (condición normal). El cabezal láser desciende (movimiento en sentido negativo) hasta alcanzar el gap respecto a la pieza (WORKPIECE)" .

ns1:PiezaDeTrabajo a ns1:Componente ;
    rdfs:label "Pieza de trabajo" ;
    ns1:textoExtracto "Esquema 'GAPTONEG = Sí': orienta el eje Z con Z+ hacia arriba (condición normal). El cabezal láser desciende (movimiento en sentido negativo) hasta alcanzar el gap respecto a la pieza (WORKPIECE)" .

