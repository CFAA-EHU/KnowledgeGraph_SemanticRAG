@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_OpenPCSRemoto a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de OpenPCS Remoto" ;
    ns1:ilustradoEn ns1:Figura_InstaladorSetupHelp ;
    ns1:textoExtracto "Se aprecian campos de búsqueda/filtrado y el listado donde figura 'CNC Help Language Changer'." .

ns1:SistemaEjeGantry_FresadoraPuente a ns1:Sistema ;
    rdfs:label "Sistema de ejes gantry en fresadora puente (X-U, Z-W)" ;
    ns1:compuestoPor ns1:ComponenteMecanico_Cabezal,
        ns1:ComponenteMecanico_CarroU,
        ns1:ComponenteMecanico_CarroX,
        ns1:ComponenteMecanico_Travesano ;
    ns1:detalladoEnEsquema ns1:EsquemaFresadoraGantry ;
    ns1:textoExtracto "Ilustración esquemática de una fresadora tipo puente en la que se muestran dos parejas de ejes gantry (X–U en la bancada y Z–W en el montante)." .

ns1:SistemaEjeTandem a ns1:Sistema ;
    rdfs:label "Sistema de eje tándem con dos motores (Master-Slave)" ;
    ns1:compuestoPor ns1:ComponenteMecanico_Cremallera,
        ns1:ComponenteMecanico_MotorMaster,
        ns1:ComponenteMecanico_MotorSlave ;
    ns1:detalladoEnEsquema ns1:EsquemaEjeTandem ;
    ns1:textoExtracto "Esquema mecánico de un eje tándem con dos motores (Master axis y Slave axis) que accionan sendos piñones sobre una misma cremallera ('Rack'). Las flechas/etiquetas indican maestro y esclavo; la disposición resalta la suma de par y la posibilidad de precarga para reducir holgura." .

ns1:Tabla_CompensacionCruzada a ns1:Tabla ;
    rdfs:label "Tabla de compensación cruzada entre ejes" ;
    ns1:documentadoEn ns1:SistemaCompensacionCruzada ;
    ns1:textoExtracto "Diagrama conceptual de 'compensación cruzada' donde un eje maestro (MOVAXIS) provoca variaciones en un eje compensado (COMPAXIS)." .

ns1:ComponenteMecanico_Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal móvil (fresadora puente)" ;
    ns1:textoExtracto "la necesidad de sincronía maestro–esclavo en cada pareja de ejes... destacando la necesidad de sincronía maestro–esclavo en cada pareja de ejes." .

ns1:ComponenteMecanico_CarroU a ns1:ComponenteMecanico ;
    rdfs:label "Carro del eje U (gantry)" ;
    ns1:textoExtracto "X–U en la bancada" .

ns1:ComponenteMecanico_CarroX a ns1:ComponenteMecanico ;
    rdfs:label "Carro del eje X (gantry)" ;
    ns1:textoExtracto "X–U en la bancada" .

ns1:ComponenteMecanico_Cremallera a ns1:ComponenteMecanico ;
    rdfs:label "Cremallera ('Rack') del sistema tándem" ;
    ns1:textoExtracto "piñones sobre una misma cremallera ('Rack')" .

ns1:ComponenteMecanico_MotorMaster a ns1:ComponenteMecanico ;
    rdfs:label "Motor Master (eje tándem)" ;
    ns1:textoExtracto "Master axis" .

ns1:ComponenteMecanico_MotorSlave a ns1:ComponenteMecanico ;
    rdfs:label "Motor Slave (eje tándem)" ;
    ns1:textoExtracto "Slave axis" .

ns1:ComponenteMecanico_Travesano a ns1:ComponenteMecanico ;
    rdfs:label "Travesaño (fresadora puente)" ;
    ns1:textoExtracto "el travesaño" .

ns1:EsquemaEjeTandem a ns1:Esquema ;
    rdfs:label "Esquema mecánico de eje tándem (Master-Slave)" ;
    ns1:textoExtracto "Dibujo lineal, con jerarquía simple (motores arriba, transmisión abajo) para explicar la arquitectura y requisitos de configuración." .

ns1:EsquemaFresadoraGantry a ns1:Esquema ;
    rdfs:label "Esquema de fresadora puente con ejes gantry (X-U, Z-W)" ;
    ns1:textoExtracto "Se aprecian los carros y el travesaño, con flechas implícitas de desplazamiento lineal y los rótulos de cada eje junto a su guía correspondiente." .

ns1:Figura_InstaladorSetupHelp a ns1:Figura ;
    rdfs:label "Procedimiento de obtención del instalador SetupHelp_Vxx.xx.exe" ;
    ns1:textoExtracto "La imagen contextualiza el procedimiento de obtención del instalador SetupHelp_Vxx.xx.exe y los tipos/idiomas de ayuda soportados." .

ns1:SistemaCompensacionCruzada a ns1:Sistema ;
    rdfs:label "Sistema de compensación cruzada MOVAXIS-COMPAXIS" ;
    ns1:textoExtracto "un eje maestro (MOVAXIS) provoca variaciones en un eje compensado (COMPAXIS)." .

