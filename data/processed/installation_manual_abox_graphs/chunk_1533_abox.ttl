@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:CompensacionCruzada a ns1:Esquema ;
    ns1:textoExtracto "Diagrama conceptual de 'compensación cruzada' donde un eje maestro (MOVAXIS) provoca variaciones en un eje compensado (COMPAXIS). El gráfico representa un volumen/carcasa con el eje maestro desplazándose; se señalan posiciones discretas 'POSITION n' y el error asociado 'POSERROR n'. La disposición incluye flechas de dirección del movimiento, áreas sombreadas para el componente afectado y rótulos tipográficos que explicitan la relación causa–efecto y la necesidad de definir puntos de compensación a lo largo del recorrido." ;
    ns1:tieneComponente ns1:EjeCompensado,
        ns1:EjeMaestro,
        ns1:ErrorPosicion,
        ns1:Posicion .

ns1:PalpadorMedida a ns1:Sensor ;
    ns1:identificador "Palpador de medida" ;
    ns1:textoExtracto "Ilustración de un palpador de medida montado en máquina para inspección de pieza: se representa un palpador tipo esférico acercándose a la superficie de una pieza cilíndrica, con el vástago vertical y el punto de contacto marcado. La composición resalta la funcionalidad metrológica en ciclo (toma de puntos en la pieza), la dirección de aproximación y el rol del disparo del palpador como evento de medición." .

ns1:PalpadorSobremesa a ns1:Sensor ;
    ns1:identificador "Palpador de sobremesa (torno)" ;
    ns1:textoExtracto "Ilustración de un palpador de sobremesa para calibración de herramientas en torno: se observa el útil de torneado aproximándose al palpador fijo instalado en la bancada. El dibujo destaca el punto de contacto, el soporte del palpador y la geometría de la herramienta, enfatizando la detección por contacto y la orientación del conjunto en un entorno de medición estático." .

ns1:SensorGap a ns1:Sensor ;
    ns1:identificador "sensor de gap" ;
    ns1:textoExtracto "Gráfico del sensor de gap con ejes mV (horizontal) y mm/inch (vertical)." .

ns1:EjeCompensado a ns1:ComponenteMecanico ;
    ns1:textoExtracto "eje compensado (COMPAXIS)" .

ns1:EjeMaestro a ns1:ComponenteMecanico ;
    ns1:textoExtracto "eje maestro (MOVAXIS)" .

ns1:ErrorPosicion a ns1:Parametro ;
    ns1:identificador "POSERROR n" ;
    ns1:textoExtracto "error asociado 'POSERROR n'" .

ns1:Posicion a ns1:Parametro ;
    ns1:identificador "POSITION n" ;
    ns1:textoExtracto "posiciones discretas 'POSITION n'" .

