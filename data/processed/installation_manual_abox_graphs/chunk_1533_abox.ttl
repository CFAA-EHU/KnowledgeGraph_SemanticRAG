@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_a311235c08 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:ConfiguracionDelEjeC_ff4d803bbb,
        ns1:EjeLongitudinal_e77f468579,
        ns1:EjeRotativo_09738479fe,
        ns1:EjeTransversal_03b0ac8a81,
        ns1:EsquemaPosicionPalpador,
        ns1:TipoDeAceleracionPorDefecto_eb68ae50fd ;
    ns1:textoExtracto "Secuencia 'ALIGNC = No' (2 viñetas): la herramienta puede mecanizar diametralmente toda la superficie sin girar el eje C." .

ns1:ConfiguracionDelEjeC_ff4d803bbb a ns1:TareaMantenimiento ;
    rdfs:label "Configuración del eje C" ;
    ns1:textoExtracto "Secuencia 'ALIGNC = No' (2 viñetas): la herramienta puede mecanizar diametralmente toda la superficie sin girar el eje C." .

ns1:EjeLongitudinal_e77f468579 a ns1:Parametro ;
    rdfs:label "Eje longitudinal" ;
    ns1:textoExtracto "Diagrama isométrico del husillo y su entorno inmediato que identifica la relación entre los parámetros LONGAXIS (eje longitudinal), FACEAXIS (eje transversal) y CAXIS (eje rotativo)." .

ns1:EjeRotativo_09738479fe a ns1:Parametro ;
    rdfs:label "Eje rotativo" ;
    ns1:textoExtracto "Diagrama isométrico del husillo y su entorno inmediato que identifica la relación entre los parámetros LONGAXIS (eje longitudinal), FACEAXIS (eje transversal) y CAXIS (eje rotativo)." .

ns1:EjeTransversal_03b0ac8a81 a ns1:Parametro ;
    rdfs:label "Eje transversal" ;
    ns1:textoExtracto "Diagrama isométrico del husillo y su entorno inmediato que identifica la relación entre los parámetros LONGAXIS (eje longitudinal), FACEAXIS (eje transversal) y CAXIS (eje rotativo)." .

ns1:EsquemaPosicionPalpador a ns1:Esquema ;
    rdfs:label "Esquema de límites del palpador" ;
    ns1:textoExtracto "Esquema de límites PRB1/PRB2/PRB3 (máximos y mínimos) del palpador sobre los tres primeros ejes del canal." .

ns1:TipoDeAceleracionPorDefecto_eb68ae50fd a ns1:Parametro ;
    rdfs:label "Tipo de aceleración por defecto" ;
    ns1:textoExtracto "Conjunto de tres gráficos comparativos de perfiles de movimiento: LINEAR, TRAPEZOIDAL y SQUARE SINE." .

