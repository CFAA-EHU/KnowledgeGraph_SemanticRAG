@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaConfiguracionEjesRotativos a ns1:Esquema ;
    rdfs:label "Configuración de los ejes rotativos" ;
    ns1:ilustra ns1:SentidoDeGiroUnico_1ecb002b83 ;
    ns1:textoExtracto "Ilustran cómo, en G90/G91, el recorrido efectivo es inferior a una vuelta, y cómo el signo fija el sentido cuando no hay SHORTESTWAY ni UNIDIR." .

ns1:EsquemaPosicionamientoCortoCamino a ns1:Esquema ;
    rdfs:label "Posicionamiento por el camino más corto (SHORTESTWAY = Sí)" ;
    ns1:ilustra ns1:PosicionamientoPorElCaminoMasCorto_58d417b415 ;
    ns1:textoExtracto "Esquema circular con arcos y flechas que ilustra 'Posicionamiento por el camino más corto (SHORTESTWAY = Sí)'. Se visualiza cómo, en G90, el eje elige el arco mínimo hasta la posición objetivo." .

ns1:EsquemaSentidoGiroUnico a ns1:Esquema ;
    rdfs:label "Sentido de giro único (UNIDIR = Positivo)" ;
    ns1:ilustra ns1:SentidoDeGiroUnico_1ecb002b83 ;
    ns1:textoExtracto "Esquema circular con arcos que muestran el 'Sentido de giro único (UNIDIR = Positivo)'. Se representan posiciones a 90°, 300° y –300° y la imposibilidad de girar en el sentido contrario." .

ns1:Render3DTornoEjeC a ns1:Esquema ;
    rdfs:label "Render 3D del torno mostrando el eje C activado" ;
    ns1:textoExtracto "Render 3D del torno mostrando el eje C activado y el plano de trabajo XC (ejes X–C con Z visible al fondo)." .

ns1:PosicionamientoPorElCaminoMasCorto_58d417b415 a ns1:Parametro ;
    rdfs:label "Posicionamiento por el camino más corto" ;
    ns1:textoExtracto "Se visualiza cómo, en G90, el eje elige el arco mínimo hasta la posición objetivo (ejemplo a 90° y 30°), con anotaciones B90/B–300/B300." .

ns1:SentidoDeGiroUnico_1ecb002b83 a ns1:Parametro ;
    rdfs:label "Sentido de giro único" ;
    ns1:textoExtracto "Se representan posiciones a 90°, 300° y –300° y la imposibilidad de girar en el sentido contrario." .

