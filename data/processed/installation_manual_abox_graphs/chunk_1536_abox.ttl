@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceReal a ns1:Esquema ;
    rdfs:label "Gráfico de Actual Feed y Following Error durante una maniobra de aceleración y parada" ;
    ns1:ilustra ns1:AmplitudBase,
        ns1:SobrepasamientoEnResonancia ;
    ns1:textoExtracto "gráfico con fondo cuadriculado que muestra 'Actual Feed' (avance real) y 'Following Error (E)' (error de seguimiento) durante una maniobra de aceleración y parada." .

ns1:BandaAnchuraNotch a ns1:Frecuencia ;
    rdfs:label "Banda de anchura del notch" ;
    ns1:textoExtracto "Se destacan la frecuencia central (FREQUENCY) y el ancho de banda efectivo del notch para eliminar vibraciones específicas." .

ns1:FrecuenciaCentral a ns1:Frecuencia ;
    rdfs:label "Frecuencia central" ;
    ns1:textoExtracto "Se destacan la frecuencia central (FREQUENCY) y el ancho de banda efectivo del notch para eliminar vibraciones específicas." .

ns1:HisteresisRevehyst a ns1:Esquema ;
    rdfs:label "Diagrama temporal de posición frente a tiempo con histéresis REVEHYST" ;
    ns1:ilustra ns1:Revehyst ;
    ns1:textoExtracto "diagrama temporal 'Posición' frente a 't' que ilustra la histéresis REVEHYST en inversiones de movimiento." .

ns1:RespuestaMaquina a ns1:Esquema ;
    rdfs:label "Gráfico de respuesta de máquina" ;
    ns1:ilustra ns1:AmplitudBase,
        ns1:FrecuenciaResonancia,
        ns1:SobrepasamientoEnResonancia ;
    ns1:textoExtracto "Gráfico de respuesta de máquina que muestra amplitud base (Ao), sobrepasamiento en resonancia (Ar) y frecuencia de resonancia (fr)" .

ns1:FrecuenciaResonancia a ns1:Parametro ;
    rdfs:label "Frecuencia de resonancia" ;
    ns1:textoExtracto "Gráfico de respuesta de máquina que muestra amplitud base (Ao), sobrepasamiento en resonancia (Ar) y frecuencia de resonancia (fr)" ;
    ns1:valor "fr" .

ns1:Revehyst a ns1:Parametro ;
    rdfs:label "REVEHYST" ;
    ns1:textoExtracto "Se marcan con flechas los instantes de inversión de consigna (1), el umbral REVEHYST que habilita la compensación de holgura (2) y la cancelación de la compensación (3)." ;
    ns1:valor "REVEHYST" .

ns1:AmplitudBase a ns1:Parametro ;
    rdfs:label "Amplitud base" ;
    ns1:textoExtracto "Gráfico de respuesta de máquina que muestra amplitud base (Ao), sobrepasamiento en resonancia (Ar) y frecuencia de resonancia (fr)" ;
    ns1:valor "Ao" .

ns1:SobrepasamientoEnResonancia a ns1:Parametro ;
    rdfs:label "Sobrepasamiento en resonancia" ;
    ns1:textoExtracto "Gráfico de respuesta de máquina que muestra amplitud base (Ao), sobrepasamiento en resonancia (Ar) y frecuencia de resonancia (fr)" ;
    ns1:valor "Ar" .

