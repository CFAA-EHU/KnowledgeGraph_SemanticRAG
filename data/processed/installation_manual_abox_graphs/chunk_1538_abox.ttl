@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaAceleracionTrapezoidal a ns1:Esquema ;
    rdfs:label "Esquema de aceleración trapezoidal/seno-cuadrado" ;
    ns1:ilustra ns1:LimiteDeJerkDeAceleracion,
        ns1:Parametro_b68fbf57b2 ;
    ns1:textoExtracto "conjunto de tres gráficos sincronizados para aceleración trapezoidal/seno-cuadrado: velocidad v(t), aceleración a(t) y jerk j(t)." .

ns1:GananciaACForward a ns1:Parametro ;
    rdfs:label "Ganancia AC-forward" ;
    ns1:textoExtracto "respuesta del sistema sin ganancia AC-forward (10 µm por cuadro) frente a respuesta con AC-forward (1 µm por cuadro)." .

ns1:LimiteDeJerkDeAceleracion a ns1:Parametro ;
    rdfs:label "Límite de jerk de aceleración" ;
    ns1:textoExtracto "rampas con pendiente limitada por ACCJERK/DECJERK" .

ns1:Parametro_b68fbf57b2 a ns1:Parametro ;
    rdfs:label "Aceleración",
        "Deceleración" ;
    ns1:textoExtracto "mesetas a ACCEL/DECEL" .

