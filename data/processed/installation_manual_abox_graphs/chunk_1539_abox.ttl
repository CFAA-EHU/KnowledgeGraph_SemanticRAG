@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceleracionMaxima_66025724c7 a ns1:Parametro ;
    rdfs:label "Aceleración máxima" ;
    ns1:identificador "ACCEL" ;
    ns1:textoExtracto "Se comparan dos parametrizaciones: (i) ACCEL máxima y ACCJERK mínimo;" .

ns1:DesplazamientoAbsolutoDeReferencia a ns1:Parametro ;
    rdfs:label "Desplazamiento absoluto de referencia" ;
    ns1:identificador "ABSOFF" ;
    ns1:textoExtracto "se dibuja la regla con el 'cero del cristal (OG)', el 'cero máquina (OM)' y el desplazamiento 'ABSOFF'." .

ns1:FactorDinamicoDeErrorDeSeguimiento a ns1:Parametro ;
    rdfs:label "Factor dinámico de error de seguimiento" ;
    ns1:identificador "FEDYNFAC" ;
    ns1:textoExtracto "zona sombreada con límites proporcionales a F (pendiente ±%FEDYNFAC)" .

ns1:JerqueMaximo a ns1:Parametro ;
    rdfs:label "Jerque máximo" ;
    ns1:identificador "ACCJERK" ;
    ns1:textoExtracto "Se comparan dos parametrizaciones: (i) ACCEL máxima y ACCJERK mínimo;" .

ns1:MultiplicadorExternoDeReferencia a ns1:Parametro ;
    rdfs:label "Multiplicador externo de referencia" ;
    ns1:identificador "EXTMULT" ;
    ns1:textoExtracto "El diagrama contextualiza el uso de ABSOFF y EXTMULT en la referencia." .

ns1:UmbralMaximoDeErrorLinealDeSeguimiento a ns1:Parametro ;
    rdfs:label "Umbral máximo de error lineal de seguimiento" ;
    ns1:identificador "MAXFLWE" ;
    ns1:textoExtracto "umbral MAXFLWE desde el que se activa la supervisión dinámica." .

ns1:VelocidadDeDesplazamientoRapida a ns1:Parametro ;
    rdfs:label "Velocidad de desplazamiento rápida" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "Fórmulas anotadas relacionan ACCEL y ACCJERK con G00FEED y t." .

