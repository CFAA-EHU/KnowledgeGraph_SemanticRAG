@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:GAPGAIN a ex:Parametro ;
    rdfs:label "GAPGAIN" ;
    ex:identificador "GAPGAIN" ;
    ex:valor "0.0000 a 100.0000" ;
    ex:textoExtracto "GAPGAIN Ganancia proporcional a aplicar en GAPCTRL. Valores posibles: De 0.0000 a 100.0000. Valor por defecto: 0.2." ;
    ex:valor "0.2" .

ex:GAPAPPROACHDYN a ex:Parametro ;
    rdfs:label "GAPAPPROACHDYN" ;
    ex:identificador "GAPAPPROACHDYN" ;
    ex:valor "De 10 a 120 %" ;
    ex:textoExtracto "GAPAPPROACHDYN Respuesta dinámica durante la parte final del movimiento de aproximación a la chapa. Valores posibles: De 10 a 120 %. Valor por defecto: 80 %." ;
    ex:valor "80 %" .

ex:GAPSENSORFILTER a ex:Parametro ;
    rdfs:label "GAPSENSORFILTER" ;
    ex:identificador "GAPSENSORFILTER" ;
    ex:textoExtracto "Para utilizar valores mayores de 0.2 (cercanos a 1) se recomienda utilizar el parámetro GAPSENSORFILTER." .

ex:MPG_GAPGAIN a ex:Parametro ;
    rdfs:label "MPG.GAPGAIN" ;
    ex:identificador "MPG.GAPGAIN" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.GAPGAIN Ganancia proporcional aplicada a la señal del sensor, en posición." ;
    ex:valor "0.2" .

ex:MPG_GAPAPPROACHDYN a ex:Parametro ;
    rdfs:label "MPG.GAPAPPROACHDYN" ;
    ex:identificador "MPG.GAPAPPROACHDYN" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.GAPAPPROACHDYN Este parámetro reduce, en el porcentaje definido, el valor de GAPGAIN del eje del sensor durante la aproximación a la chapa." ;
    ex:valor "80 %" .

ex:sensor_posicion a ex:Sensor ;
    rdfs:label "sensor en posición" ;
    ex:textoExtracto "Ganancia proporcional aplicada a la señal del sensor, en posición." .