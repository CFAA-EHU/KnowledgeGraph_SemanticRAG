@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComponenteElectrico_caa1d83fd5 a ns1:ComponenteElectrico ;
    rdfs:label "Sensor de proximidad" ;
    ns1:textoExtracto "para un sensor de proximidad, no es necesario definir este parámetro." .

ns1:EntradaDigital a ns1:ComponenteElectrico ;
    rdfs:label "Entrada digital" ;
    ns1:textoExtracto "La entrada digital podrá ser una entrada física del módulo o una entrada lógica del PLC." .

ns1:ModuloRemoto a ns1:Sistema ;
    rdfs:label "Módulo remoto" ;
    ns1:textoExtracto "si en los módulos remotos están numeradas las entradas 1 a 256," .

ns1:NumeroDeLaEntradaDelPalpador a ns1:Parametro ;
    rdfs:label "Número de la entrada del palpador" ;
    ns1:textoExtracto "Este parámetro indica el número de la entrada a la que está conectado el palpador." .

ns1:PLC a ns1:Sistema ;
    rdfs:label "PLC" ;
    ns1:textoExtracto "el PLC considera entradas lógicas a aquellas entradas que no existen como físicas;" .

