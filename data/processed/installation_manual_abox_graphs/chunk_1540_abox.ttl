@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinicionDeTeclasDeJog a ns1:Parametro ;
    rdfs:label "Definición de teclas de jog" ;
    ns1:textoExtracto "Cada diagrama sitúa las teclas en cuadrículas 3×5 o 4×4, con numeración 1–15 y un recuadro específico para las teclas de usuario. Sirve para identificar la correspondencia física entre posiciones y parámetros (p. ej., JOGKEYDEF[jk]) durante la configuración del jog por eje y sentido." .

ns1:InterfazUsuarioLCD10K a ns1:InterfazUsuario ;
    rdfs:label "LCD-10K" ;
    ns1:ilustradoEn ns1:FiguraConfiguracionTeclasJog ;
    ns1:textoExtracto "Conjunto de tres diagramas de paneles (dos 'OP-PANEL' y un 'LCD-10K') que muestran la disposición de 15 teclas numeradas y el bloque 'USERKEYS'. Cada diagrama sitúa las teclas en cuadrículas 3×5 o 4×4, con numeración 1–15 y un recuadro específico para las teclas de usuario." .

ns1:InterfazUsuarioOPPanel a ns1:InterfazUsuario ;
    rdfs:label "OP-PANEL" ;
    ns1:ilustradoEn ns1:FiguraConfiguracionTeclasJog ;
    ns1:textoExtracto "Tres diagramas paralelos de teclados (dos 'OP-PANEL' y un 'LCD-10K') que indican, mediante casillas numeradas y bloques 'JOGKEYS/USERKEYS', cómo mapear teclas de usuario a funciones de jog (ejes 1…10 con signos ± y tecla R)." .

ns1:RetrasoRecomendadoParaAlinearCurvasDeErrorTeoricoYReal a ns1:Parametro ;
    rdfs:label "Retraso recomendado para alinear curvas de error teórico y real" ;
    ns1:textoExtracto "\"ESTDELAY\" señala el retardo recomendado para alinear ambas y evitar falsas alarmas (incluida protección antiembalamiento)." .

