@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagramaTecladoJogPanel a ns1:Esquema ;
    rdfs:label "Diagrama de teclado con nueve casillas activas" ;
    ns1:ilustra ns1:AsignacionDeTeclasAEjesLogicos,
        ns1:TeclaDeAvanceRapido ;
    ns1:textoExtracto "Diagrama de teclado con nueve casillas activas que alterna teclas de sentido (+/−) y de eje (X, Y, 4, 5) más tecla R. Ilustra una asignación en la que el usuario primero selecciona el sentido y luego el eje, con la tecla R centrada para activar el avance rápido." .

ns1:DiagramaTecladoLCD10K a ns1:Esquema ;
    rdfs:label "Diagrama de teclado LCD-10K" ;
    ns1:ilustra ns1:AsignacionDeTeclasAEjesLogicos,
        ns1:TeclaDeAvanceRapido ;
    ns1:textoExtracto "Teclado con nueve teclas: X+, Y+, 4+, 5+, R, 5−, X−, Y−, 4−. El diagrama organiza las flechas por cuadrantes para expresar direccionalidad y agrupar por eje, ejemplificando una configuración directa 'eje con signo' para jog." .

ns1:EsquemaEjemploTeclasJog a ns1:Esquema ;
    rdfs:label "Esquema de ejemplo que combina iconos de teclas con flechas de sentido" ;
    ns1:ilustra ns1:AsignacionDeTeclasAEjesLogicos,
        ns1:TeclaDeAvanceRapido ;
    ns1:textoExtracto "Esquema de ejemplo que combina iconos de teclas (X±, Y±, '4±', '5±', '+', '−', 'R') con flechas de sentido. Representa la asignación de teclas a ejes lógicos (AXISNAME) y a un volante general para Z y A, destacando la jerarquía entre selección de eje y sentido, y la tecla de rápido R." .

ns1:AsignacionDeTeclasAEjesLogicos a ns1:Parametro ;
    rdfs:label "Asignación de teclas a ejes lógicos" ;
    ns1:textoExtracto "Representa la asignación de teclas a ejes lógicos (AXISNAME) y a un volante general para Z y A, destacando la jerarquía entre selección de eje y sentido, y la tecla de rápido R." .

ns1:TeclaDeAvanceRapido a ns1:Parametro ;
    rdfs:label "Tecla de avance rápido" ;
    ns1:textoExtracto "Representa la asignación de teclas a ejes lógicos (AXISNAME) y a un volante general para Z y A, destacando la jerarquía entre selección de eje y sentido, y la tecla de rápido R." .

