@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_ade31cd910 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:ManualDeParametrosCinematicas,
        ns1:ManualDeParametrosMquina ;
    ns1:textoExtracto "Lámina con 12 mini-ilustraciones etiquetadas TYPE=1…12 que representan configuraciones de cinemática de cabezal y mesa." .

ns1:ConfiguracionesDeCinematica a ns1:Parametro ;
    rdfs:label "Configuraciones de cinemática" ;
    ns1:textoExtracto "Lámina con 12 mini-ilustraciones etiquetadas TYPE=1…12 que representan configuraciones de cinemática de cabezal y mesa." .

ns1:InterfazUsuarioTecladoLCD10K a ns1:InterfazUsuario ;
    rdfs:label "Teclado LCD-10K" ;
    ns1:textoExtracto "Disposición con teclas de eje (X, Y, 4, 5) separadas de sentido (+, −) y tecla R." .

ns1:InterfazUsuarioTecladoLCD10KandUSERKEYS a ns1:InterfazUsuario ;
    rdfs:label "Teclado LCD-10K y USERKEYS" ;
    ns1:textoExtracto "Diagrama mixto con bloque 'JOGKEYS' (X+, Y+, R, X−, Y−) y bloque 'USERKEYS' (4, 5, +, −)." .

ns1:LogicaEjeMantenidoPulsado a ns1:Parametro ;
    rdfs:label "Lógica 'eje mantenido/pulsado'" ;
    ns1:textoExtracto "El gráfico muestra cómo la lógica 'eje mantenido/pulsado' (JOGTYPE) condiciona el uso combinado de selección de eje y de sentido." .

ns1:ManualDeParametrosCinematicas a ns1:DocumentoTecnico ;
    rdfs:label "Manual de Parámetros Cinemáticas" ;
    ns1:textoExtracto "Lámina con 12 mini-ilustraciones etiquetadas TYPE=1…12 que representan configuraciones de cinemática de cabezal y mesa." .

ns1:ManualDeParametrosMquina a ns1:DocumentoTecnico ;
    rdfs:label "Manual de Parámetros Máquina" ;
    ns1:textoExtracto "Parámetros máquina del modo manual – 2.7.6 Ejemplo 5 (Teclado LCD-10K)" .

