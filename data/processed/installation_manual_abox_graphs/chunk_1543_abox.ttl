@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorDeSeguimiento a ns1:DiagnosticoFallo ;
    rdfs:label "Error de seguimiento" ;
    ns1:mitigaRiesgo ns1:ConfiguracionDeTeclasDeUsuario ;
    ns1:textoExtracto "oscilograma de ESTDELAY que compara 'Theoretical Following Error (1)' y 'Real Following Error (2)' durante una aceleración/parada (también se muestra 'Actual Feed'). La curva real aparece retrasada respecto a la teórica; una marca horizontal 'ESTDELAY' señala el retardo recomendado para alinear ambas y evitar falsas alarmas (incluida protección antiembalamiento)." .

ns1:TeclaDeJog a ns1:Herramienta ;
    rdfs:label "Tecla de jog" ;
    ns1:requiereMantenimiento ns1:ConfiguracionDeTeclasDeUsuario ;
    ns1:textoExtracto "Conjunto de tres diagramas de paneles (dos 'OP-PANEL' y un 'LCD-10K') que muestran la disposición de 15 teclas numeradas y el bloque 'USERKEYS'. Cada diagrama sitúa las teclas en cuadrículas 3×5 o 4×4, con numeración 1–15 y un recuadro específico para las teclas de usuario. Sirve para identificar la correspondencia física entre posiciones y parámetros (p. ej., JOGKEYDEF[jk]) durante la configuración del jog por eje y sentido." .

ns1:ConfiguracionDeTeclasDeUsuario a ns1:TareaMantenimiento ;
    rdfs:label "Configuración de teclas de usuario" ;
    ns1:textoExtracto "Tres diagramas paralelos de teclados (dos 'OP-PANEL' y un 'LCD-10K') que indican, mediante casillas numeradas y bloques 'JOGKEYS/USERKEYS', cómo mapear teclas de usuario a funciones de jog (ejes 1…10 con signos ± y tecla R). Incluye leyenda de valores aceptados y muestra la distribución física para hasta 16 teclas de usuario." .

