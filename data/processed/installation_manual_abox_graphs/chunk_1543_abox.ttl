@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaCabezalAngular a ns1:Esquema ;
    rdfs:label "Silueta de cabezal angular" ;
    ns1:textoExtracto "Tríptico A-B-C con siluetas de 'cabezal esférico', 'cabezal ortogonal' y 'cabezal angular', seguido de dos esquemas comparativos que muestran la condición geométrica correcta/incorrecta del eje rotativo principal respecto a los ejes X/Y/Z." .

ns1:EsquemaCabezalEsferico a ns1:Esquema ;
    rdfs:label "Silueta de cabezal esférico" ;
    ns1:textoExtracto "Tríptico A-B-C con siluetas de 'cabezal esférico', 'cabezal ortogonal' y 'cabezal angular', seguido de dos esquemas comparativos que muestran la condición geométrica correcta/incorrecta del eje rotativo principal respecto a los ejes X/Y/Z." .

ns1:EsquemaCabezalOrtogonal a ns1:Esquema ;
    rdfs:label "Silueta de cabezal ortogonal" ;
    ns1:textoExtracto "Tríptico A-B-C con siluetas de 'cabezal esférico', 'cabezal ortogonal' y 'cabezal angular', seguido de dos esquemas comparativos que muestran la condición geométrica correcta/incorrecta del eje rotativo principal respecto a los ejes X/Y/Z." .

ns1:EsquemaPosicionReferenciaHEADTOOL a ns1:Esquema ;
    rdfs:label "Doble esquema de posición de referencia HEAD/TOOL" ;
    ns1:textoExtracto "Doble esquema de 'posición de referencia HEAD/TOOL' que compara 'Tool base/Auto tool base' frente a 'Head base'. Se marca la nariz del portaherramientas y vectores de referencia para visualizar dónde se sitúa el punto de referencia tras calibración o activación." .

ns1:PlanchasConCincoVinetasTYPE15 a ns1:Esquema ;
    rdfs:label "Planchas con cinco viñetas (TYPE=1…5)" ;
    ns1:textoExtracto "Planchas con cinco viñetas (TYPE=1…5) que dibujan la cabeza y ejes con cotas TDATA1…TDATA7. Flechas y signos (+/−) identifican distancias desde la nariz del husillo al eje secundario, separaciones X/Y/Z entre centros de giro y el ángulo entre ejes rotativos." .

ns1:TresVinetasTYPE68 a ns1:Esquema ;
    rdfs:label "Tres viñetas (TYPE=6…8)" ;
    ns1:textoExtracto "Tres viñetas (TYPE=6…8) con la misma gramática gráfica de cotas y signos para cabezales angulares YZ/ZX/ZY." .

