@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Esquema_ConfiguracionTecladoJogPanel_246 a ns1:Esquema ;
    rdfs:label "Diagrama de teclado JOG-PANEL (pág. 246, Ejemplo 3)"@es ;
    ns1:detalladoEnEsquema ns1:InterfazUsuario_JogPanel ;
    ns1:ilustradoEn ns1:Pagina_246 ;
    ns1:textoExtracto "Diagrama de teclado con nueve casillas activas que alterna teclas de sentido (+/−) y de eje (X, Y, 4, 5) más tecla R. Ilustra una asignación en la que el usuario primero selecciona el sentido y luego el eje, con la tecla R centrada para activar el avance rápido."@es .

ns1:Esquema_ConfiguracionTecladoLCD10K_246 a ns1:Esquema ;
    rdfs:label "Diagrama de teclado LCD-10K (pág. 246, Ejemplo 4)"@es ;
    ns1:detalladoEnEsquema ns1:InterfazUsuario_LCD10K ;
    ns1:ilustradoEn ns1:Pagina_246 ;
    ns1:textoExtracto "Teclado con nueve teclas: X+, Y+, 4+, 5+, R, 5−, X−, Y−, 4−. El diagrama organiza las flechas por cuadrantes para expresar direccionalidad y agrupar por eje, ejemplificando una configuración directa 'eje con signo' para jog."@es .

ns1:Esquema_ConfiguracionTeclasJog_245 a ns1:Esquema ;
    rdfs:label "Esquema de ejemplo de personalización de volantes y teclas de jog (pág. 245)"@es ;
    ns1:detalladoEnEsquema ns1:InterfazUsuario_JogPanel ;
    ns1:ilustradoEn ns1:Pagina_245 ;
    ns1:textoExtracto "Esquema de ejemplo que combina iconos de teclas (X±, Y±, '4±', '5±', '+', '−', 'R') con flechas de sentido. Representa la asignación de teclas a ejes lógicos (AXISNAME) y a un volante general para Z y A, destacando la jerarquía entre selección de eje y sentido, y la tecla de rápido R."@es .

ns1:ModoOperacion_Manual a ns1:ModoOperacion ;
    rdfs:label "Modo manual (JOG)"@es ;
    ns1:documentadoEn ns1:Manual_OPENPCS ;
    ns1:textoExtracto "Modo de operación para avance manual de ejes mediante teclas de jog (X, Y, 4, 5) y volante general (Z, A)."@es .

ns1:Parametro_AXISNAME a ns1:Parametro ;
    rdfs:label "AXISNAME"@en ;
    ns1:documentadoEn ns1:Pagina_245 ;
    ns1:textoExtracto "Parámetro lógico que asigna nombres a ejes (X, Y, 4, 5, Z, A) en la configuración de jog."@es .

ns1:Parametro_AvanceRapido_R a ns1:Parametro ;
    rdfs:label "Tecla R (Avance rápido)"@es ;
    ns1:monitoreaParametro ns1:Parametro_Avance ;
    ns1:textoExtracto "Tecla dedicada para activar el avance rápido en operaciones de jog, presente en ambas configuraciones (JOG-PANEL y LCD-10K)."@es .

ns1:InterfazUsuario_LCD10K a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de usuario LCD-10K"@es ;
    ns1:textoExtracto "Teclado con configuración directa 'eje con signo' para operaciones de jog (X±, Y±, 4±, 5± y R)."@es .

ns1:InterfazUsuario_JogPanel a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de usuario JOG-PANEL"@es ;
    ns1:textoExtracto "Teclado con asignación jerárquica de sentido y eje, incluyendo tecla R para avance rápido."@es .

ns1:Pagina_245 a ns1:Pagina ;
    ns1:documentadoEn ns1:Manual_OPENPCS ;
    ns1:identificador "245" ;
    ns1:textoExtracto "Parámetros máquina del modo manual – 2.7.6 Ejemplo de personalización de volantes y teclas de jog."@es .

ns1:Pagina_246 a ns1:Pagina ;
    ns1:documentadoEn ns1:Manual_OPENPCS ;
    ns1:identificador "246" ;
    ns1:textoExtracto "Parámetros máquina del modo manual – 2.7.6 Ejemplo 3 (Teclado JOG-PANEL) y Ejemplo 4 (Teclado LCD-10K)."@es .

ns1:Manual_OPENPCS a ns1:Manual ;
    rdfs:label "Manual OPENPCS (Modo Remoto)"@es ;
    ns1:textoExtracto "Documentación técnica del sistema OPENPCS, sección: Parámetros máquina del modo manual."@es .

