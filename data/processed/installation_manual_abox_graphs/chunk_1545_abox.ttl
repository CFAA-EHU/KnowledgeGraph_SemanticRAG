@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Lamina_Cinematicas_TYPE13_52 a ns1:Figura ;
    rdfs:label "Lámina de cinemáticas predefinidas (TYPE=13–52)" ;
    ns1:ilustradoEn ns1:Manual_OpenPCS ;
    ns1:textoExtracto "Lámina con viñetas TYPE=13…24 (combinaciones cabeza-mesa de tres ejes rotativos como ABA, ACA, etc.) y los modos de eje C (TYPE=41–43) y definiciones vectoriales (TYPE=50–52). Las imágenes esquematizan la cadena cinemática y el reparto de grados de libertad." .

ns1:Lamina_Cinematicas_TYPE1_12 a ns1:Figura ;
    rdfs:label "Lámina de cinemáticas predefinidas (TYPE=1–12)" ;
    ns1:ilustradoEn ns1:Manual_OpenPCS ;
    ns1:textoExtracto "Lámina con 12 mini-ilustraciones etiquetadas TYPE=1…12 que representan configuraciones de cinemática de cabezal y mesa (p. ej., cabezal ortogonal XY/ZX, mesa rotativa AB/AC/BA/BC). Cada viñeta indica ejes lineales X-Y-Z y rotativos A-B-C, mostrando orientación relativa y ejes activos." .

ns1:TecladoLCD_10K_Ejemplo5 a ns1:InterfazUsuario ;
    rdfs:label "Teclado LCD-10K (Ejemplo 5)" ;
    ns1:monitoreaParametro ns1:Parametro_JOGTYPE ;
    ns1:textoExtracto "Disposición con teclas de eje (X, Y, 4, 5) separadas de sentido (+, −) y tecla R. El gráfico muestra cómo la lógica 'eje mantenido/pulsado' (JOGTYPE) condiciona el uso combinado de selección de eje y de sentido." .

ns1:TecladoLCD_10K_Ejemplo6 a ns1:InterfazUsuario ;
    rdfs:label "Teclado LCD-10K + USERKEYS (Ejemplo 6)" ;
    ns1:textoExtracto "Diagrama mixto con bloque 'JOGKEYS' (X+, Y+, R, X−, Y−) y bloque 'USERKEYS' (4, 5, +, −). Muestra una estrategia híbrida donde las teclas de usuario asumen funciones de jog para ejes adicionales y sentidos, integrándose con las teclas de jog nativas." ;
    ns1:tieneComponente ns1:Bloque_JOGKEYS,
        ns1:Bloque_USERKEYS .

ns1:Bloque_JOGKEYS a ns1:ComponenteElectrico ;
    rdfs:label "Bloque JOGKEYS (X+, Y+, R, X−, Y−)" ;
    ns1:textoExtracto "bloque 'JOGKEYS' (X+, Y+, R, X−, Y−)" .

ns1:Bloque_USERKEYS a ns1:ComponenteElectrico ;
    rdfs:label "Bloque USERKEYS (4, 5, +, −)" ;
    ns1:textoExtracto "bloque 'USERKEYS' (4, 5, +, −)" .

ns1:Parametro_JOGTYPE a ns1:Parametro ;
    rdfs:label "JOGTYPE (Lógica eje mantenido/pulsado)" ;
    ns1:textoExtracto "lógica 'eje mantenido/pulsado' (JOGTYPE)" ;
    ns1:valor "JOGTYPE" .

ns1:Manual_OpenPCS a ns1:Manual ;
    rdfs:label "Manual OpenPCS (Sección 2.7.6 y 2.9)" ;
    ns1:textoExtracto "Parámetros máquina del modo manual – 2.7.6; Parámetros máquina de las cinemáticas – 2.9 (Tipos predefinidos)" .

