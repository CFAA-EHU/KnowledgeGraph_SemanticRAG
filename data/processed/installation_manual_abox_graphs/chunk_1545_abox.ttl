@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ColocacionDelCabezal a ns1:Parametro ;
    rdfs:label "Colocación del cabezal" ;
    ns1:identificador "TDATA13" ;
    ns1:textoExtracto "Dos conjuntos de viñetas para las combinaciones A-B y A-C: cotas TDATA1…TDATA6 para separar nariz, ejes de rotación y referencia máquina, más TDATA13…TDATA15 para colocación del cabezal." .

ns1:ColocacionDelCabezal_5deee7899a a ns1:Parametro ;
    rdfs:label "Colocación del cabezal" ;
    ns1:identificador "TDATA15" ;
    ns1:textoExtracto "Dos conjuntos de viñetas para las combinaciones A-B y A-C: cotas TDATA1…TDATA6 para separar nariz, ejes de rotación y referencia máquina, más TDATA13…TDATA15 para colocación del cabezal." .

ns1:ColocacionDelCabezal_5e704d56ca a ns1:Parametro ;
    rdfs:label "Colocación del cabezal" ;
    ns1:identificador "TDATA14" ;
    ns1:textoExtracto "Dos conjuntos de viñetas para las combinaciones A-B y A-C: cotas TDATA1…TDATA6 para separar nariz, ejes de rotación y referencia máquina, más TDATA13…TDATA15 para colocación del cabezal." .

ns1:CotaParaEjeDeRotacion a ns1:Parametro ;
    rdfs:label "Cota para eje de rotación" ;
    ns1:identificador "TDATA2" ;
    ns1:textoExtracto "Dos conjuntos de viñetas para las combinaciones A-B y A-C: cotas TDATA1…TDATA6 para separar nariz, ejes de rotación y referencia máquina, más TDATA13…TDATA15 para colocación del cabezal." .

ns1:CotaParaSepararNariz a ns1:Parametro ;
    rdfs:label "Cota para separar nariz" ;
    ns1:identificador "TDATA1" ;
    ns1:textoExtracto "Dos conjuntos de viñetas para las combinaciones A-B y A-C: cotas TDATA1…TDATA6 para separar nariz, ejes de rotación y referencia máquina, más TDATA13…TDATA15 para colocación del cabezal." .

ns1:CroquisParaCabezalMesaTipos13Y14 a ns1:Esquema ;
    rdfs:label "Croquis para cabezal-mesa (tipos 13 y 14)" ;
    ns1:textoExtracto "Dos conjuntos de viñetas para las combinaciones A-B y A-C: cotas TDATA1…TDATA6 para separar nariz, ejes de rotación y referencia máquina, más TDATA13…TDATA15 para colocación del cabezal. Incluye croquis de inversión del sentido de giro (TDATA11=0/1)." .

ns1:DefinicionDelSistemaDeCoordenadasPieza a ns1:Parametro ;
    rdfs:label "Definición del sistema de coordenadas pieza" ;
    ns1:identificador "TDATA16" ;
    ns1:textoExtracto "Gráfico comparativo '#RTCP ON B-30' con dos escenas: TDATA16=0 (el sistema de coordenadas pieza gira con la pieza) frente a TDATA16=1 (el sistema pieza se mantiene paralelo al sistema máquina)." .

ns1:EsquemaCabezalMesa a ns1:Esquema ;
    rdfs:label "Iconos introductorios para cabezal-mesa" ;
    ns1:textoExtracto "Tres iconos introductorios que representan, en perspectiva, combinaciones de cabezal y mesa con un eje de giro en el cabezal y otro en la mesa. Funcionan como leyenda visual previa a las hojas de tipos 13–16." .

ns1:GraficoComparativoRTCPONB30_fdfe9900cf a ns1:Esquema ;
    rdfs:label "Gráfico comparativo #RTCP ON B-30" ;
    ns1:textoExtracto "Gráfico comparativo '#RTCP ON B-30' con dos escenas: TDATA16=0 (el sistema de coordenadas pieza gira con la pieza) frente a TDATA16=1 (el sistema pieza se mantiene paralelo al sistema máquina). Se visualizan ejes X′-Z′ y vector de inclinación B." .

ns1:InversionDelSentidoDeGiro a ns1:Parametro ;
    rdfs:label "Inversión del sentido de giro" ;
    ns1:identificador "TDATA11" ;
    ns1:textoExtracto "Incluye croquis de inversión del sentido de giro (TDATA11=0/1)." .

ns1:OrigenDeRTCPRespectoACeroMaquinaPieza a ns1:Parametro ;
    rdfs:label "Origen de RTCP respecto a cero máquina/pieza" ;
    ns1:identificador "TDATA7" ;
    ns1:textoExtracto "Un diagrama adicional contrasta el origen de RTCP respecto a cero máquina/pieza (TDATA7) mediante ejes X′-Y′." .

