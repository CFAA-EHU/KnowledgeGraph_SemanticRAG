@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaDeCinematicaTYPE17 a ns1:Esquema ;
    rdfs:label "Esquema de cinemática TYPE=17" ;
    ns1:ilustradoEn ns1:ColocacionDelCabezal,
        ns1:ColocacionDelCabezal_5deee7899a,
        ns1:ColocacionDelCabezal_5e704d56ca,
        ns1:InversionDelSentidoDeGiro,
        ns1:PosicionDelEjeRotativoDelCabezal,
        ns1:PosicionDelEjeRotativoDelCabezal_0c1237dbe6,
        ns1:PosicionDelEjeRotativoDelCabezal_cc1e25cb0f,
        ns1:UbicacionDelEjeDeMesa,
        ns1:UbicacionDelEjeDeMesa_154bab715f,
        ns1:UbicacionDelEjeDeMesa_26e247c53a ;
    ns1:textoExtracto "Esquema de cinemática TYPE=17 para cabezal/mesa con ejes lineales X-Y-Z y rotativos A/B/C. Se muestran los tres órdenes de rotación (1º, 2º, 3º) y las distancias/offsets etiquetadas como TDATA (1, 2, 3, 4, 6, 7, 8, 9, 10, 11, 12). Las flechas indican sentidos positivos (+/−) y la disposición espacial del conjunto." .

ns1:ColocacionDelCabezal a ns1:Parametro ;
    rdfs:label "Colocación del cabezal" ;
    ns1:identificador "TDATA13" ;
    ns1:textoExtracto "Viñetas para combinaciones B-A y C-B que detallan, con flechas y cotas, la colocación del cabezal (TDATA13–TDATA15)" .

