@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaEjeCCilindrico a ns1:Esquema ;
    rdfs:label "Esquema del eje C cilíndrico (#CYL) mostrando relación entre Z-X-Y y el cilindro de pieza" ;
    ns1:ilustradoEn ns1:Pagina277 ;
    ns1:textoExtracto "Esquema del eje C cilíndrico (#CYL) mostrando relación entre Z-X-Y y el cilindro de pieza. Se resaltan TDATA2 (posición del rotativo) y TDATA4 (offset angular), con signos (+) y flechas que definen el sentido de giro (TDATA10)." .

ns1:EsquemaEjeCOffsets a ns1:Esquema ;
    rdfs:label "Diagrama del eje C respecto a X-Y y referencias de reposo/desalineamiento" ;
    ns1:ilustradoEn ns1:Pagina275 ;
    ns1:textoExtracto "Diagrama del eje C respecto a X-Y y referencias de reposo/desalineamiento. Se representan offsets TDATA2 (posición), TDATA4 (offset angular) y TDATA6 (desalineamiento), con ejes dibujados y símbolos (+) que fijan el sentido positivo." .

ns1:EsquemaReglaManoDerechaEjeC a ns1:Esquema ;
    rdfs:label "Ilustración de la 'regla de la mano derecha' aplicada al eje C y a los ejes X-Y-Z para determinar el sentido de giro del eje giratorio (TDATA10)" ;
    ns1:ilustradoEn ns1:Pagina276 ;
    ns1:textoExtracto "Ilustración de la 'regla de la mano derecha' aplicada al eje C y a los ejes X-Y-Z para determinar el sentido de giro del eje giratorio (TDATA10). Incluye tres vistas de manos con ejes anotados." .

ns1:EsquemaReglaManoDerechaXYZ a ns1:Esquema ;
    rdfs:label "Ilustración 'regla de la mano derecha' para ejes X-Y-Z y sentido de giro en ejes rotativos" ;
    ns1:ilustradoEn ns1:Pagina274 ;
    ns1:textoExtracto "Ilustración 'regla de la mano derecha' para ejes X-Y-Z y sentido de giro en ejes rotativos. Tres bocetos de mano señalan dirección positiva del eje lineal (pulgar) y giro asociado (curvatura de dedos)." .

ns1:OffsetAngular_fd82e8a884 a ns1:Parametro ;
    rdfs:label "Offset Angular" ;
    ns1:identificador "TDATA4" ;
    ns1:textoExtracto "Se representan offsets TDATA2 (posición), TDATA4 (offset angular) y TDATA6 (desalineamiento)" .

ns1:Parametro_0c1f628ac1 a ns1:Parametro ;
    rdfs:label "Posición" ;
    ns1:identificador "TDATA2" ;
    ns1:textoExtracto "Se representan offsets TDATA2 (posición), TDATA4 (offset angular) y TDATA6 (desalineamiento)" .

ns1:SentidoDeGiroDelEjeGiratorio a ns1:Parametro ;
    rdfs:label "Sentido de giro del eje giratorio" ;
    ns1:identificador "TDATA10" ;
    ns1:textoExtracto "Ilustración de la 'regla de la mano derecha' aplicada al eje C y a los ejes X-Y-Z para determinar el sentido de giro del eje giratorio (TDATA10)" .

