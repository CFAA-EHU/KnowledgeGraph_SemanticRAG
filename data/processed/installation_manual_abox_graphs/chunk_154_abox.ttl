@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MPG_GAPAPPROACHDYN a ex:Parametro ;
    rdfs:label "MPG.GAPAPPROACHDYN" ;
    ex:identificador "(V.)MPG.GAPAPPROACHDYN" ;
    ex:valor "80 %" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.GAPAPPROACHDYN Este parámetro reduce, en el porcentaje definido, el valor de GAPGAIN del eje del sensor durante la aproximación a la chapa." ;
    ex:textoExtracto "Los valores por debajo del 100 % consiguen una aproximación más suave, eliminando los posibles sobrepasamientos del gap en estas aproximaciones." ;
    ex:textoExtracto "Aumentar el valor de este parámetro puede mejorar la velocidad de bajada, pero puede provocar un pequeño sobrepasamiento en el posicionamiento." ;
    ex:textoExtracto "Reducir en exceso este parámetro puede provocar cierta brusquedad al final de la aproximación, cuando empieza el movimiento en XY con control de gap, al haber un cambio brusco de GAPGAIN." .

ex:GAPSENSORFILTER a ex:Parametro ;
    rdfs:label "GAPSENSORFILTER" ;
    ex:textoExtracto "GAPSENSORFILTER Tabla para configurar el filtro del sensor. Este parámetro muestra la tabla para configurar el filtro del sensor." .

ex:Sensor_ControlGap a ex:Sensor ;
    ex:textoExtracto "el valor de GAPGAIN del eje del sensor durante la aproximación a la chapa" ;
    ex:textoExtracto "configurar el filtro del sensor" .