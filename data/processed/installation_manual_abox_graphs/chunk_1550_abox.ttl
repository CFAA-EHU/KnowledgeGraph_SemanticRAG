@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DistincionManualServo a ns1:Parametro ;
    rdfs:label "distinción manual/servo" ;
    ns1:textoExtracto "incluye bocetos de mano y ejes rotulados, como apoyo a TDATA8/18 y a la distinción manual/servo (TDATA9/19)." .

ns1:OffsetAngular a ns1:Parametro ;
    rdfs:label "offset angular" ;
    ns1:textoExtracto "y TDATA4 (offset angular)" .

ns1:PosicionDelRotativo a ns1:Parametro ;
    rdfs:label "posición del rotativo" ;
    ns1:textoExtracto "Se resaltan TDATA2 (posición del rotativo)" .

ns1:SentidoDeGiro a ns1:Parametro ;
    rdfs:label "sentido de giro" ;
    ns1:textoExtracto "con signos (+) y flechas que definen el sentido de giro (TDATA10)." .

ns1:SentidoDeGiroDelEjeRotativoPrincipalSecundario a ns1:Parametro ;
    rdfs:label "sentido de giro del eje rotativo principal/secundario" ;
    ns1:textoExtracto "Ilustración de la regla de la mano derecha junto a los ejes para fijar el sentido de giro del eje rotativo principal/secundario; incluye bocetos de mano y ejes rotulados, como apoyo a TDATA8/18" .

ns1:TablaDefinicionVectorialCabezal a ns1:Tabla ;
    rdfs:label "Definición vectorial de cinemáticas de cabezal" ;
    ns1:ilustradoEn ns1:FiguraPictogramasCabezales ;
    ns1:textoExtracto "Conjunto de diagramas: pictogramas de cabezales (esférico, ortogonal, angular) y tres vistas con vectores T1/T2/T3 (traslación) y V1/V2/V3 (dirección)." .

ns1:TablaDefinicionVectorialMesa a ns1:Tabla ;
    rdfs:label "Definición vectorial de cinemáticas de mesa" ;
    ns1:ilustradoEn ns1:FiguraDiagramasMesa ;
    ns1:textoExtracto "Conjunto de diagramas de mesa basados en vectores T1/T2 y V1/V2." .

