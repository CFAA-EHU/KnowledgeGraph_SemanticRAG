@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinicionVectorialDeCinematicasDeMesaTipo51_1b59716e45 a ns1:Esquema ;
    rdfs:label "Definición vectorial de cinemáticas de mesa (tipo 51)"@es ;
    ns1:ilustradoEn ns1:EjeX_47f4e9baea,
        ns1:EjeZ_0598347b45 ;
    ns1:textoExtracto "Conjunto de diagramas de mesa basados en vectores T1/T2 y V1/V2. Se representan dos configuraciones espaciales con ejes X-Y-Z, flechas de giro y etiquetas TDATA1–16 para posiciones, direcciones y reposo/sentido del eje principal." ;
    ns1:tieneComponente ns1:OrientacionDelSistemaDeCoordenadasPieza,
        ns1:PosicionYDireccionDelEjePrincipal .

ns1:SistemaRTCP a ns1:Sistema ;
    rdfs:label "Sistema RTCP"@es ;
    ns1:textoExtracto "Esquemas de RTCP con pieza girando alrededor de B y dos escenarios del sistema de coordenadas pieza (TDATA31=0/1)." .

ns1:EjeX_47f4e9baea a ns1:Componente ;
    rdfs:label "Eje X"@es ;
    ns1:textoExtracto "Ilustración de mano y ejes para sentido de giro, complementada por dos diagramas circulares comparativos que muestran el origen RTCP respecto a cero máquina (C=0°) frente a cero pieza (C'=0°). Incluye ejes X-Y y referencias X'-Y'." .

ns1:EjeZ_0598347b45 a ns1:Componente ;
    rdfs:label "Eje Z"@es ;
    ns1:textoExtracto "Esquemas de RTCP con pieza girando alrededor de B y dos escenarios del sistema de coordenadas pieza (TDATA31=0/1). Se dibujan X', Z' y la orientación B-30°, explicando si el sistema gira con la pieza o permanece paralelo al de máquina." .

ns1:OrientacionDelSistemaDeCoordenadasPieza a ns1:Parametro ;
    rdfs:label "Orientación del sistema de coordenadas pieza"@es ;
    ns1:textoExtracto "Esquemas de RTCP con pieza girando alrededor de B y dos escenarios del sistema de coordenadas pieza (TDATA31=0/1)." .

ns1:PosicionYDireccionDelEjePrincipal a ns1:Parametro ;
    rdfs:label "Posición y dirección del eje principal"@es ;
    ns1:textoExtracto "Vista detallada de los vectores T1/T2 y V1/V2 con componentes TDATA1–6 y TDATA11–16." .

