@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Ilustracion1552 a ns1:Figura ;
    ns1:ilustradoEn ns1:Esquema1552 ;
    ns1:textoExtracto "Ilustración 'regla de la mano derecha' para ejes X-Y-Z y sentido de giro en ejes rotativos. Tres bocetos de mano señalan dirección positiva del eje lineal (pulgar) y giro asociado (curvatura de dedos)." .

ns1:EjeC1552 a ns1:ComponenteElectrico ;
    ns1:textoExtracto "Esquema del eje C cilíndrico (#CYL) mostrando relación entre Z-X-Y y el cilindro de pieza. Se resaltan TDATA2 (posición del rotativo) y TDATA4 (offset angular), con signos (+) y flechas que definen el sentido de giro (TDATA10)." ;
    ns1:tieneComponente ns1:Maquina1552 .

ns1:Esquema1552 a ns1:Esquema ;
    ns1:detalladoEnEsquema ns1:Maquina1552 ;
    ns1:textoExtracto "Diagrama del eje C respecto a X-Y y referencias de reposo/desalineamiento. Se representan offsets TDATA2 (posición), TDATA4 (offset angular) y TDATA6 (desalineamiento), con ejes dibujados y símbolos (+) que fijan el sentido positivo." .

ns1:Maquina1552 a ns1:Maquina ;
    ns1:identificador "2, 4, 5, 8" ;
    ns1:textoExtracto "Muestra vectores asociados a TDATA (2, 4, 5, 8) y la correspondencia entre traslaciones/giros con indicación de orden y sentido." ;
    ns1:tieneComponente ns1:EjeC1552 .

