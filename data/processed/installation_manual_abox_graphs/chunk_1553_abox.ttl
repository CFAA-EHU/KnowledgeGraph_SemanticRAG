@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:Maquina1553 a ns1:Maquina ;
    ns1:identificador "Maquina1553" ;
    ns1:textoExtracto "Se resaltan TDATA2 (posición del rotativo) y TDATA4 (offset angular), con signos (+) y flechas que definen el sentido de giro (TDATA10). --- Páginas: 277 | Sección: 2. PARÁMETROS MÁQUINA · Definición vectorial de cinemáticas de cabezal (tipo 50) | Título: — ---"@en ;
    ns1:tieneComponente ns1:Cabezal1553,
        ns1:Mesa1553 .

ns1:Cabezal1553 a ns1:ComponenteElectrico,
        ns1:ComponenteMecanico ;
    ns1:identificador "Cabezal1553" ;
    ns1:textoExtracto "Conjunto de diagramas: pictogramas de cabezales (esférico, ortogonal, angular) y tres vistas con vectores T1/T2/T3 (traslación) y V1/V2/V3 (dirección). Ejes X-Y-Z, flechas, y etiquetas TDATA1–26 indican componentes, posiciones de reposo y sentidos. --- Páginas: 278 | Sección: 2. PARÁMETROS MÁQUINA · Definición vectorial de cinemáticas de cabezal (tipo 50) | Título: — ---"@en ;
    ns1:tieneComponente ns1:Vector1553,
        ns1:Vector2553,
        ns1:Vector3553 .

ns1:Mesa1553 a ns1:ComponenteElectrico,
        ns1:ComponenteMecanico ;
    ns1:identificador "Mesa1553" ;
    ns1:textoExtracto "Conjunto de diagramas de mesa basados en vectores T1/T2 y V1/V2. --- Páginas: 281 | Sección: 2. PARÁMETROS MÁQUINA · Definición vectorial de cinemáticas de mesa (tipo 51) | Título: — ---"@en ;
    ns1:tieneComponente ns1:VectorT1553,
        ns1:VectorT2553 .

ns1:Vector1553 a ns1:Parametro ;
    ns1:identificador "Vector1553" ;
    ns1:textoExtracto "vectores T1/T2/T3 (traslación) y V1/V2/V3 (dirección)"@en .

ns1:Vector2553 a ns1:Parametro ;
    ns1:identificador "Vector2553" ;
    ns1:textoExtracto "vectores T1/T2/T3 (traslación) y V1/V2/V3 (dirección)"@en .

ns1:Vector3553 a ns1:Parametro ;
    ns1:identificador "Vector3553" ;
    ns1:textoExtracto "vectores T1/T2/T3 (traslación) y V1/V2/V3 (dirección)"@en .

ns1:VectorT1553 a ns1:Parametro ;
    ns1:identificador "VectorT1553" ;
    ns1:textoExtracto "vectores T1/T2 y V1/V2"@en .

ns1:VectorT2553 a ns1:Parametro ;
    ns1:identificador "VectorT2553" ;
    ns1:textoExtracto "vectores T1/T2 y V1/V2"@en .

