@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCabezalMesa a ns1:Sistema ;
    rdfs:label "Sistema Cabezal-Mesa" ;
    ns1:detalladoEnEsquema ns1:EsquemaRTCPON,
        ns1:EsquemaTransformacionAngular ;
    ns1:textoExtracto "Definición vectorial de cinemáticas cabezal-mesa (tipo 52)" ;
    ns1:tieneComponente ns1:DefinicionVectorialDeCinematicasCabezalMesa,
        ns1:SentidoDeGiroDelEjeRotativoPrincipalDeLaMesa .

ns1:DefinicionVectorialDeCinematicasCabezalMesa a ns1:Parametro ;
    rdfs:label "Definición vectorial de cinemáticas cabezal-mesa" ;
    ns1:identificador "Tipo52" ;
    ns1:textoExtracto "Definición vectorial de cinemáticas cabezal-mesa (tipo 52)" .

ns1:EsquemaRTCPON a ns1:Esquema ;
    rdfs:label "Esquema RTCP ON" ;
    ns1:textoExtracto "Esquemas RTCP ON con pieza girada B-30° y comparación TDATA51=0/1." .

ns1:EsquemaTransformacionAngular a ns1:Esquema ;
    rdfs:label "Esquema de transformación angular de eje inclinado" ;
    ns1:textoExtracto "Esquema de torno con representación de transformación angular de eje inclinado" .

ns1:SentidoDeGiroDelEjeRotativoPrincipalDeLaMesa a ns1:Parametro ;
    rdfs:label "Sentido de giro del eje rotativo principal de la mesa" ;
    ns1:identificador "TDATA38" ;
    ns1:textoExtracto "Ilustraciones de mano con ejes para sentido de giro del eje rotativo principal de la mesa (TDATA38)" .

