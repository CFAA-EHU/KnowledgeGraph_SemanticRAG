@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnguloEntreEjesXYX a ns1:Parametro ;
    rdfs:label "Ángulo entre ejes X y X'" ;
    ns1:identificador "ANGANTR" ;
    ns1:textoExtracto "Las etiquetas 'ANGAXNA=X ORTAXNA=Z ANGANTR=60º' refuerzan la configuración." .

ns1:CNC8070_37142c1bb7 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Escena del tipo 'Asíncrono': un carrusel-gantry y brazo de doble pinza realizan el intercambio con la herramienta; flechas indican secuencia alrededor del cabezal." ;
    ns1:tieneComponente ns1:BrazoDoblePinza,
        ns1:CabezalHusillo,
        ns1:Carrusel,
        ns1:CarruselGantry .

ns1:EjeOrtogonalX a ns1:Parametro ;
    rdfs:label "Eje ortogonal X" ;
    ns1:identificador "ANGAXNA" ;
    ns1:textoExtracto "Las etiquetas 'ANGAXNA=X ORTAXNA=Z ANGANTR=60º' refuerzan la configuración." .

ns1:EjeOrtogonalZ a ns1:Parametro ;
    rdfs:label "Eje ortogonal Z" ;
    ns1:identificador "ORTAXNA" ;
    ns1:textoExtracto "Las etiquetas 'ANGAXNA=X ORTAXNA=Z ANGANTR=60º' refuerzan la configuración." .

ns1:Husillo a ns1:ComponenteMecanico ;
    rdfs:label "Husillo" ;
    ns1:textoExtracto "Ilustración de cinemática de ejes paralelos aplicada al husillo/herramienta: un cabezal con fresa y dos flechas curvas azules paralelas indican suma de desplazamientos de un eje aditivo sobre el eje principal." .

ns1:OffsetEntreElCeroMaquinaYElOrigenDelSistemaInclinado a ns1:Parametro ;
    rdfs:label "Offset entre el cero máquina y el origen del sistema inclinado" ;
    ns1:identificador "OFFANGAX" ;
    ns1:textoExtracto "aparece una cota de offset 'OFFANGAX' entre el cero máquina y el origen del sistema inclinado." .

ns1:BrazoDoblePinza a ns1:ComponenteMecanico ;
    rdfs:label "Brazo de doble pinza" ;
    ns1:textoExtracto "Escena del tipo 'Asíncrono': un carrusel-gantry y brazo de doble pinza realizan el intercambio con la herramienta; flechas indican secuencia alrededor del cabezal." .

ns1:CabezalHusillo a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal con fresa" ;
    ns1:textoExtracto "Ilustración de cinemática de ejes paralelos aplicada al husillo/herramienta: un cabezal con fresa y dos flechas curvas azules paralelas indican suma de desplazamientos de un eje aditivo sobre el eje principal." .

ns1:Carrusel a ns1:ComponenteMecanico ;
    rdfs:label "Carrusel" ;
    ns1:textoExtracto "Escena del tipo 'Síncrono': un carrusel se aproxima al cabezal sin brazo cambiador; flechas de aproximación/retirada muestran la imposibilidad de cambiar durante el mecanizado." .

ns1:CarruselGantry a ns1:ComponenteMecanico ;
    rdfs:label "Carrusel-Gantry" ;
    ns1:textoExtracto "Escena del tipo 'Asíncrono': un carrusel-gantry y brazo de doble pinza realizan el intercambio con la herramienta; flechas indican secuencia alrededor del cabezal." .

