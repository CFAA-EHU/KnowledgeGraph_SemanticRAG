@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaNumeracionGruposRemotos a ns1:Esquema ;
    rdfs:label "Esquema Numeración Grupos Remotos" ;
    ns1:textoExtracto "Esquema de 'Numeración según el orden de los grupos remotos': tres bloques 'Remote Group (1–3)' con módulos encestados bajo un 'POWER SUPPLY';" .

ns1:SistemaHidraulicoTornoHorizontal a ns1:Sistema ;
    rdfs:label "Sistema Hidraulico Torno Horizontal" ;
    ns1:textoExtracto "Diagrama 'Torno horizontal': representación esquemática del eje pieza con variantes de signo para X y Z (X±/Z±)." ;
    ns1:tieneComponente ns1:ModuloEncestado .

ns1:SistemaHidraulicoTornoVertical a ns1:Sistema ;
    rdfs:label "Sistema Hidraulico Torno Vertical" ;
    ns1:textoExtracto "Diagrama 'Torno vertical': disposición vertical del husillo/plato con flechas de ejes X y Z en distintas combinaciones de signo;" .

ns1:ModuloEncestado a ns1:ComponenteElectrico ;
    rdfs:label "Módulo Encestado" ;
    ns1:textoExtracto "Esquema de 'Numeración según el orden de los grupos remotos': tres bloques 'Remote Group (1–3)' con módulos encestados bajo un 'POWER SUPPLY';" .

