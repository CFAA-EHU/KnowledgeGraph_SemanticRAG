@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagramaTemporalEntradaTEN a ns1:Figura ;
    rdfs:label "Diagrama temporal de la entrada TEN" ;
    ns1:textoExtracto "Diagrama temporal de la entrada TEN (enable) y su efecto sobre el temporizador: se representan, en paralelo y a lo largo del eje temporal, las señales TEN y TG1/TGx (flancos de activación), la rampa de conteo t (creciente desde 0) y el estado lógico T (alto mientras la temporización está activa)." .

ns1:DiagramaTemporalEntradaTRS a ns1:Figura ;
    rdfs:label "Diagrama temporal de la entrada TRS" ;
    ns1:textoExtracto "Diagrama temporal de la entrada TRS (reset): se muestran los flancos de subida de TRS que inicializan el temporizador (T→0 y t→0), así como la dependencia de la reactivación mediante la entrada de arranque." .

ns1:EsquemaNumeracionParametrosMaquina a ns1:Esquema ;
    rdfs:label "Esquema de Numeración mediante parámetros máquina" ;
    ns1:ilustra ns1:IndiceBaseI1,
        ns1:IndiceBaseO1 ;
    ns1:textoExtracto "Esquema de 'Numeración mediante parámetros máquina': dos grupos remotos con módulos DI/DO; sobre cada columna aparecen índices base (p. ej., 033, 049) junto a los módulos." .

ns1:IndiceBaseI1 a ns1:Parametro ;
    rdfs:label "Índice base I1" ;
    ns1:textoExtracto "Bajo cada grupo se anotan rangos resultantes de O e I (p. ej., O1…O32, I1…I48)." .

ns1:IndiceBaseO1 a ns1:Parametro ;
    rdfs:label "Índice base O1" ;
    ns1:textoExtracto "Bajo cada grupo se anotan rangos resultantes de O e I (p. ej., O1…O32, I1…I48)." .

