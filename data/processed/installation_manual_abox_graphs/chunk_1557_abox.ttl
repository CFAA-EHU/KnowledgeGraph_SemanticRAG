@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DetencionDeLaRampa a ns1:Parametro ;
    rdfs:label "Detención de la rampa" ;
    ns1:textoExtracto "Diagrama del efecto de TEN en modo monoestable: con el temporizador ya activo, forzar TEN=0 detiene la rampa de t (línea horizontal) y congela T; al restablecer TEN=1, la temporización continúa hasta completar el tiempo programado." .

ns1:InicializacionInmediata a ns1:Parametro ;
    rdfs:label "Inicialización inmediata" ;
    ns1:textoExtracto "Diagrama del efecto de TRS en modo monoestable: un flanco de subida en TRS, tanto durante como después de la temporización, provoca la inicialización inmediata (T=0 y t=0), quedando el temporizador a la espera de nueva activación por TG1." .

ns1:ModoMonoestable a ns1:Parametro ;
    rdfs:label "Modo monoestable" ;
    ns1:textoExtracto "Diagrama del modo monoestable (TG1): tras un flanco de subida en TG1, T pasa a 1 y t asciende linealmente hasta la constante de tiempo; al alcanzarla, T retorna a 0 y t se mantiene." .

ns1:RetardoALaConexion a ns1:Parametro ;
    rdfs:label "Retardo a la conexión" ;
    ns1:textoExtracto "Diagrama del retardo a la conexión: un flanco de subida en TG2 inicia t desde 0 mientras T permanece a 0; al cumplirse la constante de tiempo, T pasa a 1 y se mantiene hasta un flanco de bajada en TG2." .

