@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnguloANTR a ns1:Parametro ;
    rdfs:label "ANGANTR"@es ;
    ns1:textoExtracto "ANGANTR=60º"@es ;
    ns1:valor "60º"@es .

ns1:Bancada a ns1:ComponenteMecanico ;
    rdfs:label "bancada"@es ;
    ns1:textoExtracto "ilustración de bancada"@es .

ns1:BrazoPinza a ns1:ComponenteMecanico ;
    rdfs:label "brazo de doble pinza"@es ;
    ns1:textoExtracto "brazo de doble pinza"@es .

ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "cabezal"@es ;
    ns1:textoExtracto "un cabezal con fresa"@es .

ns1:Carro a ns1:ComponenteMecanico ;
    rdfs:label "carro"@es ;
    ns1:textoExtracto "ilustración de ... carro"@es .

ns1:Carrusel a ns1:Sistema ;
    rdfs:label "carrusel"@es ;
    ns1:textoExtracto "un carrusel"@es .

ns1:CarruselGantry a ns1:Sistema ;
    rdfs:label "carrusel-gantry"@es ;
    ns1:textoExtracto "un carrusel-gantry"@es .

ns1:EjeAditivo a ns1:Sistema ;
    rdfs:label "eje aditivo"@es ;
    ns1:textoExtracto "eje aditivo sobre el eje principal"@es .

ns1:EjeXPrima a ns1:Sistema ;
    rdfs:label "eje X'"@es ;
    ns1:textoExtracto "el eje X' formando un ángulo ANGANTR con X"@es .

ns1:EjeZ a ns1:Sistema ;
    rdfs:label "eje cartesiano Z" ;
    ns1:textoExtracto "un eje cartesiano Z"@es .

ns1:Fresa a ns1:Herramienta ;
    rdfs:label "fresa"@es ;
    ns1:textoExtracto "un cabezal con fresa"@es .

ns1:GuiaInclinada a ns1:ComponenteMecanico ;
    rdfs:label "guía inclinada"@es ;
    ns1:textoExtracto "sobre una guía inclinada"@es .

ns1:Husillo a ns1:ComponenteMecanico ;
    rdfs:label "husillo"@es ;
    ns1:textoExtracto "husillo/herramienta"@es .

ns1:OffsetANGAX a ns1:Parametro ;
    rdfs:label "OFFANGAX"@es ;
    ns1:textoExtracto "cota de offset 'OFFANGAX' entre el cero máquina y el origen del sistema inclinado"@es .

ns1:Pieza a ns1:PiezaRecambio ;
    rdfs:label "pieza"@es ;
    ns1:textoExtracto "ilustración de ... pieza"@es .

