@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ControlDePausa a ns1:Parametro ;
    rdfs:label "Control de pausa" ;
    ns1:textoExtracto "con el retardo en marcha, poner TEN=0 pausa la rampa de t; al devolver TEN=1, la temporización se reanuda." .

ns1:EstadoDelTemporizador a ns1:Parametro ;
    rdfs:label "Estado del temporizador" ;
    ns1:textoExtracto "al agotarse el tiempo, T pasa a 0." .

ns1:InicializadorDelTemporizador a ns1:Parametro ;
    rdfs:label "Inicializador del temporizador" ;
    ns1:textoExtracto "un flanco de subida en TRS inicializa el temporizador (T=0, t=0) y exige una nueva activación por TG3 para reiniciar la secuencia." .

ns1:ModoRetardoALaConexion a ns1:Parametro ;
    rdfs:label "Modo retardo a la conexión" ;
    ns1:textoExtracto "Si TG2 baja antes de completar el tiempo, la temporización se cancela y t mantiene el valor alcanzado." .

ns1:ModoRetardoALaDesconexion a ns1:Parametro ;
    rdfs:label "Modo retardo a la desconexión" ;
    ns1:textoExtracto "tras un flanco de subida en TG3, T=1; el retardo comienza con el flanco de bajada de TG3 (t sube desde 0) y, al agotarse el tiempo, T pasa a 0." .

ns1:TiempoTranscurrido a ns1:Parametro ;
    rdfs:label "Tiempo transcurrido" ;
    ns1:textoExtracto "t sube desde 0" .

