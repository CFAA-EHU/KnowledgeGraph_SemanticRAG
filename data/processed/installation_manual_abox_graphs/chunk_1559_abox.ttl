@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:EntradaTEN a ns1:Sensor ;
    ns1:documentadoEn ns1:IntroduccionPLC ;
    ns1:identificador "EntradaTEN" ;
    ns1:textoExtracto "Diagrama temporal de la entrada TEN (enable) y su efecto sobre el temporizador: se representan, en paralelo y a lo largo del eje temporal, las señales TEN y TG1/TGx (flancos de activación), la rampa de conteo t (creciente desde 0) y el estado lógico T (alto mientras la temporización está activa). Se aprecian los flancos de subida/bajada que detienen (TEN=0) o reanudan (TEN=1) la cuenta y el mantenimiento del valor t al finalizar." .

ns1:EntradaTRS a ns1:Sensor ;
    ns1:documentadoEn ns1:IntroduccionPLC ;
    ns1:identificador "EntradaTRS" ;
    ns1:textoExtracto "Diagrama temporal de la entrada TRS (reset): se muestran los flancos de subida de TRS que inicializan el temporizador (T→0 y t→0), así como la dependencia de la reactivación mediante la entrada de arranque. Las trazas incluyen TGx, TRS, la evolución de t (repuesta a 0) y el estado T que se fuerza a nivel bajo tras el reset." .

ns1:Esquema1559 a ns1:Esquema ;
    ns1:detalladoEnEsquema ns1:NumeracionParametrosMaquina ;
    ns1:documentadoEn ns1:IntroduccionPLC ;
    ns1:identificador "Esquema1559" ;
    ns1:textoExtracto "Esquema de 'Numeración mediante parámetros máquina': dos grupos remotos con módulos DI/DO; sobre cada columna aparecen índices base (p. ej., 033, 049) junto a los módulos. El diagrama enfatiza asignación por índices múltiples de 16+1 y cómo se distribuyen las entradas/salidas a partir de dichos índices." .

ns1:NumeracionParametrosMaquina a ns1:Esquema ;
    ns1:documentadoEn ns1:IntroduccionPLC ;
    ns1:identificador "NumeracionParametrosMaquina" ;
    ns1:textoExtracto "Esquema de 'Numeración mediante parámetros máquina': dos grupos remotos con módulos DI/DO; sobre cada columna aparecen índices base (p. ej., 033, 049) junto a los módulos. El diagrama enfatiza asignación por índices múltiples de 16+1 y cómo se distribuyen las entradas/salidas a partir de dichos índices." .

ns1:IntroduccionPLC a ns1:Manual ;
    ns1:documentadoEn ns1:IntroduccionPLC ;
    ns1:identificador "IntroduccionPLC" ;
    ns1:textoExtracto "Bajo cada grupo se anotan rangos resultantes de O e I (p. ej., O1…O32, I1…I48). --- Páginas: 343 | Sección: Introducción al PLC – Numeración de las entradas y salidas físicas (3.4.1) | Título: — ---" .

