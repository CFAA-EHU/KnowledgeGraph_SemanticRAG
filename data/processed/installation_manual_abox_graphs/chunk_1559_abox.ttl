@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ContadorPLC a ns1:Sistema ;
    rdfs:label "Funcionamiento de un contador" ;
    ns1:textoExtracto "Diagrama temporal del contador con entradas CUP (conteo), CDW (desconteo) y CEN (enable), mostrando incrementos/decrementos por flancos de subida, efecto de CEN=0 (inhibe CUP/CDW), y la marca de estado C que vale 1 cuando la cuenta es cero." .

ns1:EntradaCDWDesconteo a ns1:Parametro ;
    rdfs:label "Entrada CDW (desconteo)" ;
    ns1:textoExtracto "Diagrama temporal del contador con entradas CUP (conteo), CDW (desconteo) y CEN (enable), mostrando incrementos/decrementos por flancos de subida, efecto de CEN=0 (inhibe CUP/CDW), y la marca de estado C que vale 1 cuando la cuenta es cero." .

ns1:EntradaCENEnable a ns1:Parametro ;
    rdfs:label "Entrada CEN (enable)" ;
    ns1:textoExtracto "Diagrama temporal del contador con entradas CUP (conteo), CDW (desconteo) y CEN (enable), mostrando incrementos/decrementos por flancos de subida, efecto de CEN=0 (inhibe CUP/CDW), y la marca de estado C que vale 1 cuando la cuenta es cero." .

ns1:EntradaCUPConteo a ns1:Parametro ;
    rdfs:label "Entrada CUP (conteo)" ;
    ns1:textoExtracto "Diagrama temporal del contador con entradas CUP (conteo), CDW (desconteo) y CEN (enable), mostrando incrementos/decrementos por flancos de subida, efecto de CEN=0 (inhibe CUP/CDW), y la marca de estado C que vale 1 cuando la cuenta es cero." .

ns1:FlancoDeSubidaEnTG4 a ns1:Parametro ;
    rdfs:label "Flanco de subida en TG4" ;
    ns1:textoExtracto "un flanco de subida en TG4 activa T=1 y arranca t;" .

ns1:ForzarTEN0 a ns1:Parametro ;
    rdfs:label "Forzar TEN=0" ;
    ns1:textoExtracto "con la temporización activa, forzar TEN=0 congela t y mantiene el estado hasta recuperar TEN=1, cuando la temporización prosigue hasta su fin o hasta la caída de TG4." .

ns1:ModoLimitadorDeLaSenalTG4 a ns1:ModoOperacion ;
    rdfs:label "Modo limitador de la señal (TG4)" ;
    ns1:textoExtracto "Diagrama del modo limitador (TG4): un flanco de subida en TG4 activa T=1 y arranca t; T vuelve a 0 al cumplirse la constante de tiempo o por un flanco de bajada en TG4 anterior al vencimiento, conservándose el valor alcanzado de t en ese instante." .

ns1:SenalTRSPorFlancoDeSubida a ns1:Parametro ;
    rdfs:label "Señal TRS por flanco de subida" ;
    ns1:textoExtracto "la señal TRS, por flanco de subida, reinicia el temporizador (T=0, t=0) en cualquier momento del ciclo y requiere nueva activación mediante TG4." .

