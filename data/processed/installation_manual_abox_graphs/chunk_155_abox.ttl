@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:GAPSENSORFILTER a ex:Tabla ;
    ex:textoExtracto """| GAPSENSORFILTER |  |
| --- | --- |
| ORDER | Orden del filtro. |
| TYPE | Tipo de filtro. |
| FREQUENCY | Frecuencia de corte. |""" .

ex:ORDER a ex:Parametro ;
    ex:identificador "ORDER" ;
    ex:textoExtracto "ORDER Orden del filtro. Valores posibles: De 0 a 50. Valor por defecto: 0 (no se aplica filtro). Variable asociada: (V.)MPG.ORDER Parámetro incluido en la tabla GAPSENSORFILTER." ;
    ex:valor "De 0 a 50" ;
    ex:valor "0 (no se aplica filtro)" .

ex:TYPE a ex:Parametro ;
    ex:identificador "TYPE" ;
    ex:textoExtracto "TYPE Tipo de filtro. Valores posibles: Paso bajo. Valor por defecto: Paso bajo. Variable asociada: (V.)MPG.TYPE Parámetro incluido en la tabla GAPSENSORFILTER." ;
    ex:valor "Paso bajo" .

ex:FREQUENCY a ex:Parametro ;
    ex:identificador "FREQUENCY" ;
    ex:textoExtracto "FREQUENCY Frecuencia de corte. Valores posibles: De 0 a 500.0000 Hz. Valor por defecto: 30.0000 Hz. Variable asociada: (V.)MPG.FREQUENCY Parámetro incluido en la tabla GAPSENSORFILTER." ;
    ex:valor "De 0 a 500.0000 Hz" ;
    ex:valor "30.0000 Hz" .

ex:GAPERRORCANCEL a ex:Parametro ;
    ex:identificador "GAPERRORCANCEL" ;
    ex:textoExtracto "GAPERRORCANCEL Anular el error de gap fuera del rango definido por GAPMIN/GAPMAX. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPG.GAPERRORCANCEL El parámetro GAPERRORCANCEL establece el comportamiento del CNC cuando el gap sobrepasa el rango GAPMIN - GAPMAX. Independientemente del valor de este parámetro, el CNC sigue vigilando la marca INPOSGAP." ;
    ex:valor "Sí / No" ;
    ex:valor "No" .