@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_5a802deddc a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "el CNC activa SSTROBE/MSTROBE y espera una única AUXEND a nivel alto el tiempo mínimo definido antes de concluir la operación." .

ns1:InterfazUsuarioMensajesErrores a ns1:InterfazUsuario ;
    rdfs:label "MESSAGES AND ERRORS" ;
    ns1:ilustradoEn ns1:TablaMensajesPLC ;
    ns1:textoExtracto "Captura de interfaz 'MESSAGES AND ERRORS' con una tabla tipo lista de mensajes numerados (MSG1… ERRxxx) y su estado, más un área inferior que muestra campos 'SHOW', 'MESSAGE FILE', 'PLC RUNNING', etc." .

ns1:TemporizacionMINAENDW a ns1:Parametro ;
    rdfs:label "temporización MINAENDW" ;
    ns1:textoExtracto "El gráfico ilustra que, al solicitar varias funciones M o S, el CNC activa SSTROBE/MSTROBE y espera una única AUXEND a nivel alto el tiempo mínimo definido antes de concluir la operación." .

ns1:TablaMensajesPLC a ns1:Tabla ;
    rdfs:label "Tabla de mensajes PLC" ;
    ns1:textoExtracto "Captura de interfaz 'MESSAGES AND ERRORS' con una tabla tipo lista de mensajes numerados (MSG1… ERRxxx) y su estado, más un área inferior que muestra campos 'SHOW', 'MESSAGE FILE', 'PLC RUNNING', etc." .

