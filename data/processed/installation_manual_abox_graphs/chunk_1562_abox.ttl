@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_6bd031d3d9 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de sobretemperatura (OVERTEMP)" ;
    ns1:textoExtracto "Recuadro de advertencia con icono triangular y texto sobre sobretemperatura (OVERTEMP). El bloque enfatiza que, si la marca se activa, existe riesgo para el equipo; el formato enmarcado y el símbolo de peligro aportan jerarquía visual y urgen a limitar la operativa del CNC hasta restablecer la temperatura." .

ns1:CNC8070_028b3aabbf a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Diagrama temporal multiseñal que muestra la secuencia de aparcado/desaparcado gestionada desde el CNC. Incluye trazas PARK(axis), UNPARK(axis), PARKED(axis), DRENA(axis) y REFPOIN(axis), numeradas (1–6) para los hitos del proceso." .

ns1:InterfazUsuarioAyudaAsociada a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de ayuda asociada" ;
    ns1:textoExtracto "A la izquierda de algunas filas aparece un icono que indica la existencia de archivo de ayuda asociado. La imagen ejemplifica cómo el CNC presenta, prioriza y permite abrir ayudas asociadas a mensajes/errores del PLC." .

ns1:InterfazUsuarioIconosEstado a ns1:InterfazUsuario ;
    rdfs:label "Conjunto de iconos de estado de mensajes" ;
    ns1:textoExtracto "Conjunto de iconos de estado de mensajes: un triángulo de advertencia que indica que el mensaje no tiene archivo de información adicional, y un icono verde que señala que sí existe archivo de ayuda asociado. Estos pictogramas actúan como leyenda visual para interpretar rápidamente la disponibilidad de ayuda contextual." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Diagrama temporal análogo al anterior, pero para la maniobra iniciada desde el PLC." .

