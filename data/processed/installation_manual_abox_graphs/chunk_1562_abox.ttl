@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:C a ns1:Parametro ;
    ns1:identificador "C" ;
    ns1:textoExtracto "Diagrama temporal del contador con entradas CUP (conteo), CDW (desconteo) y CEN (enable), mostrando incrementos/decrementos por flancos de subida, efecto de CEN=0 (inhibe CUP/CDW), y la marca de estado C que vale 1 cuando la cuenta es cero. Incluye trazas alineadas de entradas y evolución de la cuenta interna." .

ns1:CDW a ns1:Sensor ;
    ns1:identificador "CDW" ;
    ns1:textoExtracto "Diagrama temporal del contador con entradas CUP (conteo), CDW (desconteo) y CEN (enable), mostrando incrementos/decrementos por flancos de subida, efecto de CEN=0 (inhibe CUP/CDW), y la marca de estado C que vale 1 cuando la cuenta es cero. Incluye trazas alineadas de entradas y evolución de la cuenta interna." .

ns1:CEN a ns1:Sensor ;
    ns1:identificador "CEN" ;
    ns1:textoExtracto "Diagrama temporal del contador con entradas CUP (conteo), CDW (desconteo) y CEN (enable), mostrando incrementos/decrementos por flancos de subida, efecto de CEN=0 (inhibe CUP/CDW), y la marca de estado C que vale 1 cuando la cuenta es cero. Incluye trazas alineadas de entradas y evolución de la cuenta interna." .

ns1:CUP a ns1:Sensor ;
    ns1:identificador "CUP" ;
    ns1:textoExtracto "Diagrama temporal del contador con entradas CUP (conteo), CDW (desconteo) y CEN (enable), mostrando incrementos/decrementos por flancos de subida, efecto de CEN=0 (inhibe CUP/CDW), y la marca de estado C que vale 1 cuando la cuenta es cero. Incluye trazas alineadas de entradas y evolución de la cuenta interna." .

ns1:T a ns1:Parametro ;
    ns1:identificador "T" ;
    ns1:textoExtracto "Diagrama del modo limitador (TG4): un flanco de subida en TG4 activa T=1 y arranca t; T vuelve a 0 al cumplirse la constante de tiempo o por un flanco de bajada en TG4 anterior al vencimiento, conservándose el valor alcanzado de t en ese instante." .

ns1:TEN a ns1:Sensor ;
    ns1:identificador "TEN" ;
    ns1:textoExtracto "Diagrama del efecto de TEN en TG4: con la temporización activa, forzar TEN=0 congela t y mantiene el estado hasta recuperar TEN=1, cuando la temporización prosigue hasta su fin o hasta la caída de TG4." .

ns1:TG4 a ns1:Sensor ;
    ns1:identificador "TG4" ;
    ns1:textoExtracto "Diagrama del modo limitador (TG4): un flanco de subida en TG4 activa T=1 y arranca t; T vuelve a 0 al cumplirse la constante de tiempo o por un flanco de bajada en TG4 anterior al vencimiento, conservándose el valor alcanzado de t en ese instante." .

ns1:TRS a ns1:Sensor ;
    ns1:identificador "TRS" ;
    ns1:textoExtracto "Diagrama del efecto de TRS en TG4: la señal TRS, por flanco de subida, reinicia el temporizador (T=0, t=0) en cualquier momento del ciclo y requiere nueva activación mediante TG4." .

ns1:t a ns1:Parametro ;
    ns1:identificador "t" ;
    ns1:textoExtracto "Diagrama del modo limitador (TG4): un flanco de subida en TG4 activa T=1 y arranca t; T vuelve a 0 al cumplirse la constante de tiempo o por un flanco de bajada en TG4 anterior al vencimiento, conservándose el valor alcanzado de t en ese instante." .

