@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioOPPANEL a ns1:InterfazUsuario ;
    rdfs:label "Panel OP-PANEL" ;
    ns1:textoExtracto "Fotografía del panel OP-PANEL con teclado de usuario y bloque de teclas de jog. Se distinguen pulsadores iluminables, con agrupación jerárquica por funciones (usuario, jog, husillo, start/stop) y distribución matricial que el texto asocia a bits KEYBD1/2/3." .

ns1:InterfazUsuarioQCC65 a ns1:InterfazUsuario ;
    rdfs:label "Panel QC-C65" ;
    ns1:textoExtracto "Fotografía del panel QC-C65-10K con pantalla integrada y keypad numérico; a la derecha, un bloque de teclas de jog dispuesto en rejilla." .

ns1:PanelOPPANEL329 a ns1:InterfazUsuario ;
    rdfs:label "Panel OP-PANEL-329" ;
    ns1:textoExtracto "Fotografía del panel OP-PANEL-329 mostrando un layout compacto: selector circular, pulsadores de jog en columna y teclas de usuario en bloque." .

