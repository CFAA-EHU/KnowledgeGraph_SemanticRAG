@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagramaSincronizacionAuxEnd a ns1:Figura ;
    rdfs:label "Diagrama de sincronización AUXEND/MSTROBE" ;
    ns1:ilustradoEn ns1:Pagina439 ;
    ns1:textoExtracto "Diagrama de sincronización AUXEND/MSTROBE con eje temporal y marcas numeradas (1–4) asociado a la ejecución de funciones auxiliares S/M. Representa la desactivación/activación de AUXEND respecto a STROBE y el tiempo mínimo MINAENDW para finalizar la sincronización." .

ns1:DiagramaTemporalReset a ns1:Figura ;
    rdfs:label "Diagrama temporal Proceso de reset con RESETIN" ;
    ns1:ilustradoEn ns1:Pagina439 ;
    ns1:textoExtracto "Diagrama temporal 'Proceso de reset con RESETIN' con trazas RESETIN, RESETOUT y etiqueta de subrutina PROGRAM_RESET; incluye marca temporal MINAENDW y un intervalo t. Muestra flancos de subida/bajada, orden de eventos y la relación entre marcas del PLC y respuesta del canal durante el reset." .

ns1:EsquemaTeclasJog a ns1:Esquema ;
    rdfs:label "Esquema de teclas Jog" ;
    ns1:ilustradoEn ns1:Pagina438 ;
    ns1:textoExtracto "Dos esquemas de keypad en formato rejilla ('USERKEYS' y 'JOGKEYS') con numeración 1–15. Indican la disposición y orden de teclas genéricas y de jog, útil para interpretar la correspondencia física-lógica de los bits en KEYBD y los efectos de selectores/overrides." .

