@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_df7f5fee12 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:EsquemaCambioGama,
        ns1:EsquemaDiagramaEstadosServoon,
        ns1:EsquemaOscilacionCabezal ;
    ns1:textoExtracto "CNC 8070" .

ns1:EsquemaModuloOPPanel a ns1:Esquema ;
    rdfs:label "Imagen del módulo OP-PANEL-H/E" ;
    ns1:textoExtracto "Imagen del módulo OP-PANEL-H/E con distribución completa de teclado: override de husillo, sentidos de giro, posicionamiento, START/STOP, ZERO, RESET y teclas de usuario con leds." .

ns1:ModuloOPPANELHE a ns1:ComponenteElectrico ;
    rdfs:label "Módulo OP-PANEL-H/E" ;
    ns1:textoExtracto "Imagen del módulo OP-PANEL-H/E con distribución completa de teclado." .

ns1:EsquemaCambioGama a ns1:Esquema ;
    rdfs:label "Diagrama temporal de cambio de gama" ;
    ns1:textoExtracto "Diagrama temporal de cambio de gama (GEAR1→GEAR2) con señales MFUN, MSTROBE, AUXEND, indicadores GEAR1/GEAR2, pista 'CHANGE' y referencia MINAENDW." .

ns1:EsquemaDiagramaEstadosServoon a ns1:Esquema ;
    rdfs:label "Diagrama de estados para SERVOON/ENABLE" ;
    ns1:textoExtracto "Diagrama de estados para SERVOON/ENABLE con trazas 'Velocity Command', ventanas de DWELL y condición de ERROR." .

ns1:EsquemaOscilacionCabezal a ns1:Esquema ;
    rdfs:label "Diagrama temporal de oscilación del cabezal" ;
    ns1:textoExtracto "Diagrama temporal de oscilación del cabezal controlada por PLC durante cambio de gama, con trazas MFUN, MSTROBE, AUXEND, GEAR1/GEAR4 y señales SANALOG/PLCCNTL." .

