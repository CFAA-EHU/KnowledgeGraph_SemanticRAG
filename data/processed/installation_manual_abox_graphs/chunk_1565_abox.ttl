@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagramaTemporalPLC a ns1:Esquema ;
    rdfs:label "Diagrama temporal multiseñal del PLC"@es ;
    ns1:detalladoEnEsquema ns1:BloqueAdvertenciaOvertemp ;
    ns1:textoExtracto "Diagrama temporal multiseñal que muestra la secuencia de aparcado/desaparcado gestionada desde el CNC. Incluye trazas PARK(axis), UNPARK(axis), PARKED(axis), DRENA(axis) y REFPOIN(axis), numeradas (1–6) para los hitos del proceso. Se señalan ventanas temporales MINAENDW. El esquema clarifica la lógica: solicitud del CNC, actuación del PLC sobre habilitaciones/regulador y confirmación mediante PARKED/REFPOIN. --- Páginas: 422 | Sección: 6.2 Señales de consulta de los ejes y cabezales (Maniobra desde el PLC) | Título: — ---"@es .

ns1:IconoAdvertenciaTriangulo a ns1:Sensor ;
    rdfs:label "Triángulo de advertencia"@es ;
    ns1:mitigaRiesgo ns1:BloqueAdvertenciaOvertemp ;
    ns1:textoExtracto "A la izquierda de algunas filas aparece un icono que indica la existencia de archivo de ayuda asociado. La imagen ejemplifica cómo el CNC presenta, prioriza y permite abrir ayudas asociadas a mensajes/errores del PLC. --- Páginas: 403 | Sección: 5.5 Visualización de errores y mensajes del PLC | Título: — ---"@es .

ns1:IconoAyudaVerde a ns1:Sensor ;
    rdfs:label "Icono verde"@es ;
    ns1:textoExtracto "Conjunto de iconos de estado de mensajes: un triángulo de advertencia que indica que el mensaje no tiene archivo de información adicional, y un icono verde que señala que sí existe archivo de ayuda asociado. Estos pictogramas actúan como leyenda visual para interpretar rápidamente la disponibilidad de ayuda contextual. --- Páginas: 416 | Sección: 6.1 Señales de consulta generales | Título: — ---"@es .

ns1:BloqueAdvertenciaOvertemp a ns1:AvisoSeguridad ;
    rdfs:label "Bloque de advertencia sobretemperatura"@es ;
    ns1:textoExtracto "Recuadro de advertencia con icono triangular y texto sobre sobretemperatura (OVERTEMP). El bloque enfatiza que, si la marca se activa, existe riesgo para el equipo; el formato enmarcado y el símbolo de peligro aportan jerarquía visual y urgen a limitar la operativa del CNC hasta restablecer la temperatura. --- Páginas: 421 | Sección: 6.2 Señales de consulta de los ejes y cabezales (Maniobra desde el CNC) | Título: — ---"@es .

