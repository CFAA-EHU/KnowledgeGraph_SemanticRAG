@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaAlmacenamientoHerramientas a ns1:Sistema ;
    rdfs:label "almacén tipo torreta" ;
    ns1:textoExtracto "Ilustración de un almacén tipo torreta para torno: se observa una torreta indexable con varios portaherramientas montados radialmente, cada uno con su plaquita o fresa, y la posición de trabajo orientada hacia el punto de mecanizado. La vista enfatiza la disposición circular de estaciones y el giro de la torreta para presentar la herramienta activa." .

ns1:TablaAsignacionBitsTeclas a ns1:Tabla ;
    rdfs:label "Esquema de asignación de bits a teclas del OP-PANEL-H/E" ;
    ns1:ilustradoEn ns1:InterfazUsuarioOPPANEL ;
    ns1:textoExtracto "Esquema de asignación de bits a teclas del OP-PANEL-H/E (tabla gráfica sobre el teclado). Identifica para cada tecla el bit asociado (0–15 y 16–31) para control de leds y posibles inhibiciones, con énfasis en funciones de husillo, ejecución e interbloqueos." .

ns1:TeclasDeFuncion a ns1:ComponenteElectrico ;
    rdfs:label "teclas de función" ;
    ns1:textoExtracto "Rejilla ilustrativa de teclas de jog (1–15) y bloque de funciones (START, STOP, ZERO, RESET, husillo y override) para el mapeo KEYDIS2." .

ns1:TeclasDeJog a ns1:ComponenteElectrico ;
    rdfs:label "teclas de jog" ;
    ns1:compuestoPor ns1:TeclaDeJog1,
        ns1:TeclaDeJog10,
        ns1:TeclaDeJog11,
        ns1:TeclaDeJog12,
        ns1:TeclaDeJog13,
        ns1:TeclaDeJog14,
        ns1:TeclaDeJog15,
        ns1:TeclaDeJog2,
        ns1:TeclaDeJog3,
        ns1:TeclaDeJog4,
        ns1:TeclaDeJog5,
        ns1:TeclaDeJog6,
        ns1:TeclaDeJog7,
        ns1:TeclaDeJog8,
        ns1:TeclaDeJog9 ;
    ns1:textoExtracto "Rejilla ilustrativa de teclas de jog (1–15) y bloque de funciones (START, STOP, ZERO, RESET, husillo y override) para el mapeo KEYDIS2. Sirve para visualizar la jerarquía de funciones y la cobertura de inhibición por bit en cada modelo de panel." .

ns1:InterfazUsuarioOPPANEL a ns1:InterfazUsuario ;
    rdfs:label "OP-PANEL" ;
    ns1:textoExtracto "Conjunto de tres fotografías (OP-PANEL, OP-PANEL-329 y QC-C65□-10K) usadas como referencia visual para 'Registros KEYDIS…'. Muestran físicamente las teclas de usuario y de jog cuya inhibición se controla por bit, apoyando la relación entre hardware y registro." .

