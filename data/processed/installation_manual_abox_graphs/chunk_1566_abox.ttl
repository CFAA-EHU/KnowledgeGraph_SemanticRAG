@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiagramaTemporal_ParkUnpark_PLC a ns1:Figura ;
    rdfs:label "Diagrama temporal de señales PARK/UNPARK desde PLC"@es ;
    ns1:ilustradoEn ns1:Manual_OpenPCS_Remoto_Seccion6_2 ;
    ns1:textoExtracto "Diagrama temporal análogo al anterior, pero para la maniobra iniciada desde el PLC. Representa PARK(axis), UNPARK(axis), PARKED(axis), DRENA(axis) y REFPOIN(axis) con numeración (1–4) de eventos. La gráfica distingue claramente la iniciación por PARKED, el comienzo de PARK/UNPARK por parte del CNC y la finalización con restablecimiento de habilitaciones."@es .

ns1:Panel_OP_PANEL a ns1:InterfazUsuario ;
    rdfs:label "Panel OP-PANEL con teclado de usuario y bloque de teclas de jog"@es ;
    ns1:detalladoEnEsquema ns1:Manual_OpenPCS_Remoto_Pag432 ;
    ns1:textoExtracto "Fotografía del panel OP-PANEL con teclado de usuario y bloque de teclas de jog. Se distinguen pulsadores iluminables, con agrupación jerárquica por funciones (usuario, jog, husillo, start/stop) y distribución matricial que el texto asocia a bits KEYBD1/2/3."@es ;
    ns1:tieneComponente ns1:TeclasJog_OP_PANEL,
        ns1:TeclasUsuario_OP_PANEL .

ns1:Panel_OP_PANEL_329 a ns1:InterfazUsuario ;
    rdfs:label "Panel OP-PANEL-329 (layout compacto)"@es ;
    ns1:detalladoEnEsquema ns1:Manual_OpenPCS_Remoto_Pag432 ;
    ns1:textoExtracto "Fotografía del panel OP-PANEL-329 mostrando un layout compacto: selector circular, pulsadores de jog en columna y teclas de usuario en bloque. La imagen ilustra la codificación por bits de las teclas (user y jog) que se consultan en KEYBD1/2/3."@es ;
    ns1:tieneComponente ns1:SelectorCircular_OP_PANEL_329,
        ns1:TeclasJog_OP_PANEL_329 .

ns1:Panel_QC_C65_10K a ns1:InterfazUsuario ;
    rdfs:label "Panel QC-C65□-10K con pantalla y keypad numérico"@es ;
    ns1:detalladoEnEsquema ns1:Manual_OpenPCS_Remoto_Pag432 ;
    ns1:identificador "QC-C65□-10K" ;
    ns1:textoExtracto "Fotografía del panel QC-C65□-10K con pantalla integrada y keypad numérico; a la derecha, un bloque de teclas de jog dispuesto en rejilla. La figura apoya la correspondencia entre posiciones físicas y bits de los registros KEYBDx para este modelo."@es ;
    ns1:tieneComponente ns1:KeypadNumerico_QC_C65_10K,
        ns1:TeclasJog_QC_C65_10K .

ns1:KeypadNumerico_QC_C65_10K a ns1:ComponenteElectrico ;
    rdfs:label "Keypad numérico (QC-C65□-10K)"@es ;
    ns1:textoExtracto "keypad numérico"@es .

ns1:Manual_OpenPCS_Remoto_Seccion6_2 a ns1:Pagina ;
    rdfs:label "Sección 6.2: Señales de consulta de los ejes y cabezales (Maniobra desde el PLC)"@es ;
    ns1:identificador "6.2" ;
    ns1:textoExtracto "Señales de consulta de los ejes y cabezales (Maniobra desde el PLC)"@es .

ns1:SelectorCircular_OP_PANEL_329 a ns1:ComponenteElectrico ;
    rdfs:label "Selector circular (OP-PANEL-329)"@es ;
    ns1:textoExtracto "selector circular"@es .

ns1:TeclasJog_OP_PANEL a ns1:ComponenteElectrico ;
    rdfs:label "Bloque de teclas de jog (OP-PANEL)"@es ;
    ns1:textoExtracto "pulsadores iluminables [...] bloque de teclas de jog [...] distribución matricial que el texto asocia a bits KEYBD1/2/3."@es .

ns1:TeclasJog_OP_PANEL_329 a ns1:ComponenteElectrico ;
    rdfs:label "Pulsadores de jog en columna (OP-PANEL-329)"@es ;
    ns1:textoExtracto "pulsadores de jog en columna"@es .

ns1:TeclasJog_QC_C65_10K a ns1:ComponenteElectrico ;
    rdfs:label "Bloque de teclas de jog en rejilla (QC-C65□-10K)"@es ;
    ns1:textoExtracto "bloque de teclas de jog dispuesto en rejilla"@es .

ns1:TeclasUsuario_OP_PANEL a ns1:ComponenteElectrico ;
    rdfs:label "Teclas de usuario (OP-PANEL)"@es ;
    ns1:textoExtracto "teclado de usuario [...] agrupación jerárquica por funciones (usuario, jog, husillo, start/stop)."@es .

ns1:Manual_OpenPCS_Remoto_Pag432 a ns1:Pagina ;
    rdfs:label "Página 432: Entradas y salidas lógicas del CNC · Señales de consulta de las teclas"@es ;
    ns1:identificador "432" ;
    ns1:textoExtracto "Entradas y salidas lógicas del CNC · Señales de consulta de las teclas"@es .

