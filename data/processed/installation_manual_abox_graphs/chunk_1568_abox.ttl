@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaAlmacenamientoSincronoConBrazo1Pinza a ns1:Sistema ;
    rdfs:label "Almacén síncrono con brazo cambiador de 1 pinza" ;
    ns1:textoExtracto "Ilustración del carrusel cercano al cabezal con un brazo de una sola pinza. El brazo extrae la herramienta del carrusel y la entrega al husillo." .

ns1:SistemaAlmacenamientoSincronoConBrazo2Pinzas a ns1:Sistema ;
    rdfs:label "Almacén síncrono con brazo cambiador de 2 pinzas" ;
    ns1:textoExtracto "Ilustración del carrusel con brazo de dos pinzas: se distinguen dos mordazas para operaciones de toma y entrega en secuencia cruzada (pinza 1 ↔ cabezal, pinza 2 ↔ carrusel)." .

ns1:SistemaAlmacenamientoSincronoSinBrazo a ns1:Sistema ;
    rdfs:label "Almacén síncrono sin brazo cambiador" ;
    ns1:textoExtracto "Ilustración del carrusel próximo al cabezal sin brazo: el plato de herramientas se orienta y acerca al husillo para transferir la herramienta directamente." .

ns1:SistemaAlmacenamientoTorreta a ns1:Sistema ;
    rdfs:label "Almacén tipo torreta" ;
    ns1:textoExtracto "Ilustración de torreta de torno con varias estaciones y herramientas montadas; se destaca la herramienta activa alineada con el punto de trabajo." .

