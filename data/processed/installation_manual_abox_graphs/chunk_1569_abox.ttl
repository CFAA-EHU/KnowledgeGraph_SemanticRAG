@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:EsquemaAsignacionBits a ns1:Esquema ;
    ns1:detalladoEnEsquema ns1:TablaBitsTeclas ;
    ns1:documentadoEn ns1:ManualCNC ;
    ns1:identificador "Esquema de asignación de bits a teclas del OP-PANEL-H/E" ;
    ns1:ilustradoEn ns1:Pagina463 ;
    ns1:textoExtracto "Esquema de asignación de bits a teclas del OP-PANEL-H/E (tabla gráfica sobre el teclado). Identifica para cada tecla el bit asociado (0–15 y 16–31) para control de leds y posibles inhibiciones, con énfasis en funciones de husillo, ejecución e interbloqueos." .

ns1:TablaBitsTeclas a ns1:Tabla ;
    ns1:documentadoEn ns1:ManualCNC ;
    ns1:identificador "Tabla de bits de teclas" ;
    ns1:ilustradoEn ns1:Pagina463 ;
    ns1:textoExtracto "Tabla de bits de teclas del OP-PANEL-H/E (tabla gráfica sobre el teclado). Identifica para cada tecla el bit asociado (0–15 y 16–31) para control de leds y posibles inhibiciones, con énfasis en funciones de husillo, ejecución e interbloqueos." .

ns1:ManualCNC a ns1:Manual ;
    ns1:documentadoEn ns1:Pagina463 ;
    ns1:identificador "Manual del CNC" ;
    ns1:textoExtracto "Manual del CNC que incluye la sección de Entradas y salidas lógicas del CNC · Señales modificables de las teclas" .

ns1:Pagina463 a ns1:Pagina ;
    ns1:documentadoEn ns1:ManualCNC ;
    ns1:identificador "Página 463" ;
    ns1:textoExtracto "Página 463 que contiene el Esquema de asignación de bits a teclas del OP-PANEL-H/E (tabla gráfica sobre el teclado). Identifica para cada tecla el bit asociado (0–15 y 16–31) para control de leds y posibles inhibiciones, con énfasis en funciones de husillo, ejecución e interbloqueos." .

