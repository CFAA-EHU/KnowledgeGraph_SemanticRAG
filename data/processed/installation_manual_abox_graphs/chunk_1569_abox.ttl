@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioConfiguracionIdioma a ns1:InterfazUsuario ;
    rdfs:label "Panel de control de Windows" ;
    ns1:textoExtracto "Pareja de capturas del Panel de control de Windows (iconos 'Clock, Language, and Region' y enlace 'Change keyboard or other input methods'), usadas para ilustrar el acceso a la configuración de idioma y distribución de teclado del sistema operativo previo a la simulación desde PLC." .

ns1:InterfazUsuarioTecladosCNC a ns1:InterfazUsuario ;
    rdfs:label "Galería comparativa de teclados CNC" ;
    ns1:textoExtracto "Galería comparativa de cuatro teclados CNC según distribución: tres variantes rotuladas 'Español (España)' y una 'Inglés (Estados Unidos)'. Las vistas muestran la disposición física de teclas, presencia de teclas de función específicas del CNC y agrupación por bloques (alfanumérico, cursores, funciones), útil para asociar los 'scan codes' a su posición y entender las diferencias por idioma/distribución." .

ns1:InterfazUsuarioTecladosIdiomas a ns1:InterfazUsuario ;
    rdfs:label "Ventana Teclados e idiomas" ;
    ns1:textoExtracto "Captura de la ventana 'Teclados e idiomas' con el botón 'Cambiar teclados…'." .

ns1:SistemaAlmacenAsincrono a ns1:Sistema ;
    rdfs:label "Sistema Almacén Asíncrono" ;
    ns1:textoExtracto "Ilustración de almacén asíncrono tipo cadena con brazo cambiador desplazado del cabezal." ;
    ns1:tieneComponente ns1:BrazoCambiador_0401d640e8 .

ns1:BrazoCambiador_0401d640e8 a ns1:ComponenteElectrico ;
    rdfs:label "Brazo cambiador" ;
    ns1:textoExtracto "Ilustración de almacén asíncrono tipo cadena con brazo cambiador desplazado del cabezal." .

