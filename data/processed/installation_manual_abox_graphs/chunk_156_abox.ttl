@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TamanoDeLaZonaDeDatosCompartidaDelPLC a ns1:Parametro ;
    rdfs:label "Tamaño de la zona de datos compartida del PLC" ;
    ns1:identificador "MPG.PLCDATASIZE" ;
    ns1:textoExtracto "PLCDATASIZE Tamaño de la zona de datos compartida del PLC. Valores posibles: De 0 a 500.000 bytes. Valor por defecto: 0." .

ns1:TamanoDeMemoriaDelTerminalRemotoHBH3HBH4 a ns1:Parametro ;
    rdfs:label "Tamaño de memoria del terminal remoto HBH3/HBH4" ;
    ns1:textoExtracto "El terminal remoto HBH3/HBH4 necesita un tamaño de memoria de 4096 bytes." ;
    ns1:valor "4096 bytes" .

ns1:VariableAsociadaMPGPLCDATASIZE a ns1:Parametro ;
    rdfs:label "Variable asociada MPG.PLCDATASIZE" ;
    ns1:identificador "V.MPG.PLCDATASIZE" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.PLCDATASIZE Este parámetro permite definir un área de memoria para intercambiar datos entre un programa PLC escrito en lenguaje C y una aplicación externa." .

