@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaArquitecturaGantry a ns1:Esquema ;
    rdfs:label "Ilustración de arquitectura gantry" ;
    ns1:textoExtracto "Ilustración de arquitectura gantry con dos motores (maestro y esclavo) engranados sobre la misma cremallera." .

ns1:EsquemaComportamientoEjePosicionamiento a ns1:Esquema ;
    rdfs:label "Comportamiento de un eje rotativo de posicionamiento" ;
    ns1:textoExtracto "Tres diagramas polares comparan el comportamiento de un eje rotativo 'de posicionamiento' (camino más corto), mostrando arcos de 60° y 300° con flechas que indican trayectorias mínima y alternativa." .

ns1:EsquemaCotasEjesRotativos a ns1:Esquema ;
    rdfs:label "Visualización de cotas en ejes rotativos" ;
    ns1:textoExtracto "Conjunto de tres esquemas circulares que representan la visualización de cotas en ejes rotativos en modo 'módulo', con marcas de ±300° y flechas de sentido de giro." .

ns1:IlustracionConceptualDeLaNormaDIN66217 a ns1:Esquema ;
    rdfs:label "Ilustración conceptual de la norma DIN 66217" ;
    ns1:textoExtracto "Ilustración conceptual de la norma DIN 66217 para nomenclatura de ejes: dibujos con triedro XYZ y flechas que indican ejes principales (X, Y, Z), auxiliares paralelos (U, V, W) y rotativos (A, B, C) alrededor de X, Y, Z respectivamente." .

ns1:SistemaHidraulico a ns1:Sistema ;
    rdfs:label "Sistema Hidráulico" ;
    ns1:textoExtracto "Ilustración de arquitectura gantry con dos motores (maestro y esclavo) engranados sobre la misma cremallera." ;
    ns1:tieneComponente ns1:ComponenteElectrico_aa156bec19 .

ns1:ComponenteElectrico_aa156bec19 a ns1:ComponenteElectrico ;
    rdfs:label "Motor Esclavo",
        "Motor Maestro" ;
    ns1:textoExtracto "Ilustración de arquitectura gantry con dos motores (maestro y esclavo) engranados sobre la misma cremallera." .

