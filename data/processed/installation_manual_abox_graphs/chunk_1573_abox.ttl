@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaControlTandem a ns1:Sistema ;
    rdfs:label "Sistema de control tándem" ;
    ns1:textoExtracto "Diagrama de bloques del sistema con CNC, regulador y dos ejes (MASTER DRIVE y SLAVE DRIVE). Se detallan lazos de posición y velocidad, señales de consigna y realimentación, y el bloque 'Tandem control' que aplica precarga y distribución de par." ;
    ns1:tieneComponente ns1:CNC8070_50c9f5aea5,
        ns1:ComponenteMecanico_16949cd9a3,
        ns1:Componente_0da1995e70 .

ns1:CNC8070_50c9f5aea5 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Diagrama de bloques del sistema con CNC, regulador y dos ejes (MASTER DRIVE y SLAVE DRIVE)." .

ns1:ComponenteMecanico_16949cd9a3 a ns1:ComponenteMecanico ;
    rdfs:label "Motor Esclavo",
        "Motor Maestro" ;
    ns1:textoExtracto "Bloque simplificado de control: desde 'Position command' se generan 'Velocity command' hacia maestro y esclavo;" .

ns1:Componente_0da1995e70 a ns1:Componente ;
    rdfs:label "Regulador" ;
    ns1:textoExtracto "Diagrama de bloques del sistema con CNC, regulador y dos ejes (MASTER DRIVE y SLAVE DRIVE)." .

