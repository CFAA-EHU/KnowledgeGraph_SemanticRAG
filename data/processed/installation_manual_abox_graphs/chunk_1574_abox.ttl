@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaHidraulicoMultieje a ns1:Sistema ;
    rdfs:label "Sistema multieje compuesto por dos ejes controlados por un único motor" ;
    ns1:textoExtracto "Grupo multieje compuesto por dos ejes controlados por un único motor." ;
    ns1:tieneComponente ns1:ComponenteMecanico_9da0e03f3d,
        ns1:ModuloAccionamiento,
        ns1:ModuloRemotoCAN,
        ns1:ReguladorSercos .

ns1:ComponenteMecanico_9da0e03f3d a ns1:ComponenteMecanico ;
    rdfs:label "Motor principal del sistema multieje" ;
    ns1:textoExtracto "un solo motor, mediante acoplamientos, gobierna alternativamente dos ejes (A1 y A2)" .

ns1:ModuloAccionamiento a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de accionamiento" ;
    ns1:textoExtracto "la captación directa entra en la segunda entrada del regulador Sercos; se distinguen captación de motor y directa, y el lazo Sercos hacia el módulo de accionamiento." .

ns1:ModuloRemotoCAN a ns1:ComponenteElectrico ;
    rdfs:label "Módulo remoto CANfagor" ;
    ns1:textoExtracto "Diagrama de cableado con módulo remoto CANfagor de contadoras (X1…X5, CAN L/H, alimentación y terminaciones)." .

ns1:ReguladorSercos a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos" ;
    ns1:textoExtracto "seleccionados por el regulador; se muestra la captura directa y la arquitectura CAN entre módulos." .

