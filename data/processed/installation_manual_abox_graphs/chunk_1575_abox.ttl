@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:EjeLineal a ns1:ComponenteMecanico ;
    ns1:identificador "eje lineal" ;
    ns1:textoExtracto "Ilustración de arquitectura gantry con dos motores (maestro y esclavo) engranados sobre la misma cremallera. Se muestran reductores, flechas de sentido de movimiento, y la distribución mecánica del par aplicada simultáneamente por ambos piñones sobre el eje lineal."@es ;
    ns1:tieneComponente ns1:Reductor1 .

ns1:Sistema a ns1:Sistema ;
    ns1:identificador "sistema" ;
    ns1:textoExtracto "Ilustración de arquitectura gantry con dos motores (maestro y esclavo) engranados sobre la misma cremallera. Se muestran reductores, flechas de sentido de movimiento, y la distribución mecánica del par aplicada simultáneamente por ambos piñones sobre el eje lineal."@es ;
    ns1:tieneComponente ns1:EjeLineal,
        ns1:Motor1,
        ns1:Motor2,
        ns1:Reductor1 .

ns1:Motor1 a ns1:Maquina ;
    ns1:identificador "maestro" ;
    ns1:textoExtracto "Ilustración de arquitectura gantry con dos motores (maestro y esclavo) engranados sobre la misma cremallera. Se muestran reductores, flechas de sentido de movimiento, y la distribución mecánica del par aplicada simultáneamente por ambos piñones sobre el eje lineal."@es .

ns1:Motor2 a ns1:Maquina ;
    ns1:identificador "esclavo" ;
    ns1:textoExtracto "Ilustración de arquitectura gantry con dos motores (maestro y esclavo) engranados sobre la misma cremallera. Se muestran reductores, flechas de sentido de movimiento, y la distribución mecánica del par aplicada simultáneamente por ambos piñones sobre el eje lineal."@es .

ns1:Reductor1 a ns1:ComponenteMecanico ;
    ns1:identificador "reductor" ;
    ns1:textoExtracto "Ilustración de arquitectura gantry con dos motores (maestro y esclavo) engranados sobre la misma cremallera. Se muestran reductores, flechas de sentido de movimiento, y la distribución mecánica del par aplicada simultáneamente por ambos piñones sobre el eje lineal."@es ;
    ns1:tieneComponente ns1:Motor1,
        ns1:Motor2 .

