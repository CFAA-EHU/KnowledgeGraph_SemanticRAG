@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CronogramaSenalesReferenciado a ns1:Figura ;
    rdfs:label "Cronograma de señales durante la búsqueda" ;
    ns1:textoExtracto "Cronograma de señales durante la búsqueda: perfiles de velocidad (REFFEED1) y aproximaciones, pulsos de micro y de I0;" .

ns1:LimiteSoftwareX a ns1:Parametro ;
    rdfs:label "Límite de software en X" ;
    ns1:textoExtracto "Ilustración 3D del volumen de trabajo con límites físicos (FL) y límites de software (SL) para X-Y-Z;" .

ns1:LimiteSoftwareY a ns1:Parametro ;
    rdfs:label "Límite de software en Y" ;
    ns1:textoExtracto "Ilustración 3D del volumen de trabajo con límites físicos (FL) y límites de software (SL) para X-Y-Z;" .

ns1:LimiteSoftwareZ a ns1:Parametro ;
    rdfs:label "Límite de software en Z" ;
    ns1:textoExtracto "Ilustración 3D del volumen de trabajo con límites físicos (FL) y límites de software (SL) para X-Y-Z;" .

ns1:PuntoReferenciaH a ns1:Parametro ;
    rdfs:label "Punto de referencia H" ;
    ns1:textoExtracto "Dibujo esquemático de un torno que define cero máquina (OM), cero pieza (OW) y punto de referencia H, con cotas XMH/ZMH y XMW/ZMW;" .

ns1:ReferenciaOM a ns1:Parametro ;
    rdfs:label "Cero máquina" ;
    ns1:textoExtracto "Dibujo esquemático de un torno que define cero máquina (OM), cero pieza (OW) y punto de referencia H, con cotas XMH/ZMH y XMW/ZMW;" .

ns1:ReferenciaOW a ns1:Parametro ;
    rdfs:label "Cero pieza" ;
    ns1:textoExtracto "Dibujo esquemático de un torno que define cero máquina (OM), cero pieza (OW) y punto de referencia H, con cotas XMH/ZMH y XMW/ZMW;" .

ns1:SistemaConDosEjesYUnMotor a ns1:Sistema ;
    rdfs:label "Sistema con dos ejes y sólo un motor" ;
    ns1:textoExtracto "Disposición en la que un único motor alimenta mecánicamente A1 y A2; ambos ejes usan captación directa a módulos remotos diferentes (1 y 2)." ;
    ns1:tieneComponente ns1:BloqueReguladorA1,
        ns1:BloqueReguladorA2 .

ns1:SistemaConReferencias a ns1:Sistema ;
    rdfs:label "Sistema con referencias OM, OW y H" ;
    ns1:textoExtracto "Dibujo esquemático de un torno que define cero máquina (OM), cero pieza (OW) y punto de referencia H, con cotas XMH/ZMH y XMW/ZMW;" .

ns1:BloqueReguladorA1 a ns1:ComponenteElectrico ;
    rdfs:label "Bloque de regulador para eje A1" ;
    ns1:textoExtracto "Se representan los bloques de regulador, bus CAN y contadoras." .

ns1:BloqueReguladorA2 a ns1:ComponenteElectrico ;
    rdfs:label "Bloque de regulador para eje A2" ;
    ns1:textoExtracto "Se representan los bloques de regulador, bus CAN y contadoras." .

ns1:EjeA1 a ns1:ComponenteMecanico ;
    rdfs:label "Eje A1" ;
    ns1:alimentadoPor ns1:ComponenteMecanico_271b4ebb28 ;
    ns1:textoExtracto "Disposición en la que un único motor alimenta mecánicamente A1 y A2;" .

ns1:EjeA2 a ns1:ComponenteMecanico ;
    rdfs:label "Eje A2" ;
    ns1:alimentadoPor ns1:ComponenteMecanico_271b4ebb28 ;
    ns1:textoExtracto "Disposición en la que un único motor alimenta mecánicamente A1 y A2;" .

ns1:ComponenteMecanico_271b4ebb28 a ns1:ComponenteMecanico ;
    rdfs:label "Motor principal" ;
    ns1:alimenta ns1:EjeA1,
        ns1:EjeA2 ;
    ns1:textoExtracto "Disposición en la que un único motor alimenta mecánicamente A1 y A2;" .

