@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_0092d194bb a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:TablaCompensacionVolumetrica ;
    ns1:textoExtracto "el CNC detiene la ejecución al intentar salir de SL, con ejes indicados y zonas sombreadas." .

ns1:InterfazUsuarioCompensacion a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de usuario para compensación volumétrica" ;
    ns1:ilustra ns1:TablaCompensacionVolumetrica ;
    ns1:textoExtracto "Captura de interfaz de un editor mostrando un fichero CSV con tres columnas de datos etiquetables como 'Error X, Error Y, Error Z'." .

ns1:TablaCompensacionVolumetrica a ns1:Tabla ;
    rdfs:label "Tabla de compensación volumétrica básica" ;
    ns1:textoExtracto "Captura de interfaz de un editor mostrando un fichero CSV con tres columnas de datos etiquetables como 'Error X, Error Y, Error Z'." .

