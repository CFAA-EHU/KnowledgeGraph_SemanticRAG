@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_1d90a94208 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "La imagen ejemplifica el formato de archivo exigido para cargar la tabla de compensación en el CNC." .

ns1:SecuenciaParaDefinirLosValoresEnElArchivoPaso1 a ns1:Esquema ;
    rdfs:label "Secuencia para definir los valores en el archivo - Paso 1" ;
    ns1:textoExtracto "Esquema 3D (Paso 1) de un volumen con un plano basal y puntos en X a partir del origen X(P1), Y(P1), Z(P1)." .

ns1:SecuenciaParaDefinirLosValoresEnElArchivoPaso2 a ns1:Esquema ;
    rdfs:label "Secuencia para definir los valores en el archivo - Paso 2" ;
    ns1:textoExtracto "Esquema 3D (Paso 2) que prolonga la secuencia anterior: para cada posición fija en Y(P1), se completan todos los puntos de X; después se pasa a Y(P2)... hasta NPOINTSAX2." .

ns1:TablaCompensacionVolumetrica a ns1:Tabla ;
    rdfs:label "Archivo con los datos para la compensación volumétrica básica" ;
    ns1:textoExtracto "Se ven filas de valores decimales separadas por comas, que corresponden a los errores medidos en cada punto de la malla volumétrica." .

