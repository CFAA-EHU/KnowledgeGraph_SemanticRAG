@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaMultieje a ns1:Sistema ;
    rdfs:label "Sistema multieje"@es ;
    ns1:textoExtracto "Vista de instalación con un regulador y dos ejes (A1, A2) con sus motores y captaciones diferenciadas: A1 con captación directa al regulador y A2 con captación a módulos remotos; se anotan direcciones lógicas y Sercos."@es ;
    ns1:tieneComponente ns1:Motor1,
        ns1:Motor2,
        ns1:Regulador .

ns1:Eje1 a ns1:Maquina ;
    rdfs:label "Eje 1"@es ;
    ns1:identificador "A1" ;
    ns1:textoExtracto "Diagrama donde un solo motor, mediante acoplamientos, gobierna alternativamente dos ejes (A1 y A2) seleccionados por el regulador; se muestra la captura directa y la arquitectura CAN entre módulos."@es .

ns1:Eje2 a ns1:Maquina ;
    rdfs:label "Eje 2"@es ;
    ns1:identificador "A2" ;
    ns1:textoExtracto "Vista de instalación con un regulador y dos ejes (A1, A2) con sus motores y captaciones diferenciadas: A1 con captación directa al regulador y A2 con captación a módulos remotos; se anotan direcciones lógicas y Sercos."@es .

ns1:Regulador a ns1:Sistema ;
    rdfs:label "Regulador"@es ;
    ns1:controla ns1:Motor1,
        ns1:Motor2 ;
    ns1:textoExtracto "Diagrama donde un solo motor, mediante acoplamientos, gobierna alternativamente dos ejes (A1 y A2) seleccionados por el regulador; se muestra la captura directa y la arquitectura CAN entre módulos."@es .

ns1:Motor1 a ns1:Maquina ;
    rdfs:label "Motor 1"@es ;
    ns1:controla ns1:Eje1 ;
    ns1:identificador "A1" ;
    ns1:textoExtracto "Diagrama donde un solo motor, mediante acoplamientos, gobierna alternativamente dos ejes (A1 y A2) seleccionados por el regulador; se muestra la captura directa y la arquitectura CAN entre módulos."@es .

ns1:Motor2 a ns1:Maquina ;
    rdfs:label "Motor 2"@es ;
    ns1:controla ns1:Eje2 ;
    ns1:identificador "A2" ;
    ns1:textoExtracto "Vista de instalación con un regulador y dos ejes (A1, A2) con sus motores y captaciones diferenciadas: A1 con captación directa al regulador y A2 con captación a módulos remotos; se anotan direcciones lógicas y Sercos."@es .

