@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BusCAN a ns1:Sistema ;
    rdfs:label "Bus CAN" ;
    ns1:compuestoPor ns1:CNCModule_1fb780bd89,
        ns1:JogPanel2_a7e1def805,
        ns1:JogPanel5_5a5b39bc64,
        ns1:ModuloDeESRemota1,
        ns1:ModuloDeESRemota3,
        ns1:ModuloDeESRemota4 ;
    ns1:textoExtracto "Diagrama del bus CAN que ilustra la numeración y orden de los paneles de mando y grupos de E/S remotas." .

ns1:CNC8070_901019ab5c a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Diagrama de bloques del lazo de control del CNC que encadena SLOPE, INTERPOLATOR, TRANSFOR y FILTER." .

ns1:LazoControlCNC a ns1:Sistema ;
    rdfs:label "Lazo de Control del CNC" ;
    ns1:compuestoPor ns1:FiltroComponente,
        ns1:InterpolatorComponente,
        ns1:SlopeComponente,
        ns1:TransformadorComponente ;
    ns1:textoExtracto "Diagrama de bloques del lazo de control del CNC que encadena SLOPE, INTERPOLATOR, TRANSFOR y FILTER." .

ns1:LazoPosicionCNC a ns1:Sistema ;
    rdfs:label "Lazo de Posición del CNC" ;
    ns1:compuestoPor ns1:ConsignaPOSCMD,
        ns1:SenalRetroalimentacionPOSNC ;
    ns1:textoExtracto "entrada al lazo de posición." .

ns1:ResetIn a ns1:ComponenteElectrico ;
    rdfs:label "RESETIN" ;
    ns1:textoExtracto "trazas digitales (RESETIN)" .

ns1:ResetOut a ns1:ComponenteElectrico ;
    rdfs:label "RESETOUT" ;
    ns1:textoExtracto "trazas digitales (RESETOUT)" .

ns1:SubrutinaReset a ns1:Sistema ;
    rdfs:label "Subrutina asociada al reset" ;
    ns1:textoExtracto "Diagrama temporal del proceso de reset con dos trazas digitales (RESETIN y RESETOUT) y la ventana MINAENDW marcada sobre RESETOUT." .

ns1:CNCModule_1fb780bd89 a ns1:ComponenteElectrico ;
    rdfs:label "CNC Module" ;
    ns1:identificador "0" ;
    ns1:textoExtracto "iconos del CNC (Address=0)" .

ns1:ConsignaPOSCMD a ns1:ComponenteElectrico ;
    rdfs:label "POSCMD" ;
    ns1:textoExtracto "consignas (POSCMD)" .

ns1:FiltroComponente a ns1:ComponenteElectrico ;
    rdfs:label "FILTER" ;
    ns1:textoExtracto "Diagrama de bloques del lazo de control del CNC que encadena FILTER" .

ns1:InterpolatorComponente a ns1:ComponenteElectrico ;
    rdfs:label "INTERPOLATOR" ;
    ns1:textoExtracto "Diagrama de bloques del lazo de control del CNC que encadena INTERPOLATOR" .

ns1:JogPanel2_a7e1def805 a ns1:ComponenteElectrico ;
    rdfs:label "Jog-Panel 2" ;
    ns1:identificador "2" ;
    ns1:textoExtracto "dos 'Jog-Panel' (Address=2 y 5)" .

ns1:JogPanel5_5a5b39bc64 a ns1:ComponenteElectrico ;
    rdfs:label "Jog-Panel 5" ;
    ns1:identificador "5" ;
    ns1:textoExtracto "dos 'Jog-Panel' (Address=2 y 5)" .

ns1:ModuloDeESRemota1 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de E/S remota 1" ;
    ns1:identificador "1" ;
    ns1:textoExtracto "módulos de E/S remotas (Address=1)" .

ns1:ModuloDeESRemota3 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de E/S remota 3" ;
    ns1:identificador "3" ;
    ns1:textoExtracto "módulos de E/S remotas (Address=3)" .

ns1:ModuloDeESRemota4 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de E/S remota 4" ;
    ns1:identificador "4" ;
    ns1:textoExtracto "módulos de E/S remotas (Address=4)" .

ns1:SenalRetroalimentacionPOSNC a ns1:ComponenteElectrico ;
    rdfs:label "POSNC" ;
    ns1:textoExtracto "señales de retroalimentación (POSNC)" .

ns1:SlopeComponente a ns1:ComponenteElectrico ;
    rdfs:label "SLOPE" ;
    ns1:textoExtracto "Diagrama de bloques del lazo de control del CNC que encadena SLOPE" .

ns1:TransformadorComponente a ns1:ComponenteElectrico ;
