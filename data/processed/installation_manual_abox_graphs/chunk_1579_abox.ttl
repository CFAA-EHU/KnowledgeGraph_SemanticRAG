@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Interfaz_CargaCompensacion a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de carga de datos de compensación volumétrica"@es ;
    ns1:ilustradoEn ns1:Tabla_CompensacionVolumetrica_Basica ;
    ns1:textoExtracto "Editor que muestra fichero CSV con columnas 'Error X, Error Y, Error Z' para cargar la tabla de compensación en el CNC."@es .

ns1:Paginas_600_601_LimitesSoftwareEjes a ns1:Figura ;
    rdfs:label "Diagrama de límites de software de ejes (SL/FL)"@es ;
    ns1:ilustradoEn ns1:Manual_OpenPCS ;
    ns1:textoExtracto "Vista adicional del mismo concepto con otro plano de observación; se duplican anotaciones SL/FL y trayectorias de T para resaltar cómo el CNC detiene la ejecución al intentar salir de SL, con ejes indicados y zonas sombreadas. Diagrama de selección de límites donde dos grupos SL1/SL2 definen ventanas válidas; un gráfico a trazos y sombreado cruzado explica que el CNC aplica siempre el límite más restrictivo (superior e inferior), con pequeñas vistas esquemáticas en X-Y."@es .

ns1:Sistema_CompensacionVolumetrica a ns1:Sistema ;
    rdfs:label "Sistema de compensación volumétrica del CNC"@es ;
    ns1:detalladoEnEsquema ns1:Pagina_605_CompensacionVolumetrica ;
    ns1:documentadoEn ns1:Tabla_CompensacionVolumetrica_Basica ;
    ns1:textoExtracto "Volumen cúbico transparente sobre la mesa que contiene una nube de puntos azules como nodos de medida/interpolación para corrección espacial de errores geométricos en todo el recorrido."@es .

ns1:Pagina_605_CompensacionVolumetrica a ns1:Figura ;
    rdfs:label "Ilustración isométrica de compensación volumétrica"@es ;
    ns1:ilustradoEn ns1:Manual_OpenPCS ;
    ns1:textoExtracto "Ilustración isométrica de un centro de mecanizado con un volumen cúbico transparente sobre la mesa que contiene una nube de puntos azules. El cubo representa el volumen de trabajo a compensar y los puntos son nodos de medida/interpolación. Se aprecian ejes cartesianos implícitos y la relación del volumen con los elementos de la máquina (mesa, columna y husillo), enfatizando la idea de corrección espacial de errores geométricos en todo el recorrido."@es .

ns1:Tabla_CompensacionVolumetrica_Basica a ns1:Tabla ;
    rdfs:label "Archivo CSV de compensación volumétrica básica"@es ;
    ns1:documentadoEn ns1:Manual_OpenPCS ;
    ns1:identificador "Error X, Error Y, Error Z" ;
    ns1:textoExtracto "Captura de interfaz de un editor mostrando un fichero CSV con tres columnas de datos etiquetables como 'Error X, Error Y, Error Z'. Se ven filas de valores decimales separadas por comas, que corresponden a los errores medidos en cada punto de la malla volumétrica. La imagen ejemplifica el formato de archivo exigido para cargar la tabla de compensación en el CNC."@es .

