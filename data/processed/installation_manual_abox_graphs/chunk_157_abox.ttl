@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarLaVigilanciaDe24VEnLasSalidasDigitalesLocales a ns1:Parametro ;
    rdfs:label "Activar la vigilancia de 24 V en las salidas digitales locales" ;
    ns1:identificador "MPG.EXPSCHK" ;
    ns1:textoExtracto "EXPSCHK Activar la vigilancia de 24 V en las salidas digitales locales. Valores posibles: ON / OFF. Valor por defecto: ON." .

ns1:ComponenteElectrico_bf91e9bd9f a ns1:ComponenteElectrico ;
    rdfs:label "Conector" ;
    ns1:textoExtracto "Cuando hay activa alguna salida digital local, hay que alimentar el conector a 24 V DC." .

ns1:NumeroDeSalidasDigitalesLocales a ns1:Parametro ;
    rdfs:label "Número de salidas digitales locales" ;
    ns1:identificador "MPG.NLOCOUT" ;
    ns1:textoExtracto "NLOCOUT Número de salidas digitales locales. Valores posibles: De 0 a 8. Valor por defecto: 0." .

