@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_8f16d93993 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Se muestran iconos del CNC (Address=0), módulos de E/S remotas (Address=1,3,4) y dos 'Jog-Panel' (Address=2 y 5)" ;
    ns1:tieneComponente ns1:EntradaDeContajeE21A,
        ns1:EntradaDeContajeE21B,
        ns1:EntradaDeContajeE21C,
        ns1:EntradaDeContajeE21D .

ns1:SistemaRCS_S_4F4AO a ns1:Sistema ;
    rdfs:label "Módulo remoto RCS-S-4F4AO" ;
    ns1:textoExtracto "Vista frontal del módulo RCS-S-4F4AO con llamadas (callouts) a conectores y recursos" ;
    ns1:tieneComponente ns1:EntradaDeContajeE21A,
        ns1:EntradaDeContajeE21B,
        ns1:EntradaDeContajeE21C,
        ns1:EntradaDeContajeE21D,
        ns1:SalidaAnalogicaI37A,
        ns1:SalidaAnalogicaI37B .

ns1:SalidaAnalogicaI37A a ns1:ComponenteElectrico ;
    rdfs:label "Salida analógica I37A" ;
    ns1:textoExtracto "cuatro salidas analógicas ±10 V de 16 bits (I37A/I37B)" .

ns1:SalidaAnalogicaI37B a ns1:ComponenteElectrico ;
    rdfs:label "Salida analógica I37B" ;
    ns1:textoExtracto "cuatro salidas analógicas ±10 V de 16 bits (I37A/I37B)" .

ns1:EntradaDeContajeE21A a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de contaje E21A" ;
    ns1:textoExtracto "Vista frontal del módulo RCS-S-4F4AO con llamadas (callouts) a conectores y recursos: cuatro entradas de contaje (E21A–E21D)" .

