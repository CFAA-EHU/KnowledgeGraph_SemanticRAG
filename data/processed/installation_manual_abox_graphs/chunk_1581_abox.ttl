ns1:BloqueVolante a ns1:ComponenteElectrico ;
    rdfs:label "Bloque volante" ;
    ns1:textoExtracto "Se muestran bloques para ejes analógicos (X, Y, Z), ejes Sercos (U, V), un volante y un cabezal S, con líneas que conectan salidas analógicas (ANAOUT) y entradas de captación (E21A/B/C)." .

ns1:ConectorE21A a ns1:ComponenteElectrico ;
    rdfs:label "Conector E21A" ;
    ns1:textoExtracto "Las etiquetas de nodo y de conector (p. ej., E21A/ANAOUT2) guían la asignación física y lógica." .

ns1:ConectorX1 a ns1:ComponenteElectrico ;
    rdfs:label "Conector X1" ;
    ns1:textoExtracto "Imagen 'Grupo 1': conjunto RIO5 con 24 entradas digitales y 16 salidas digitales. Se muestran bastidores con conectores X1–X8 y leyendas de borneado (+24 V, GND), enfatizando el formato de módulo y su rol como bloque lógico único." .

ns1:ConectorX8 a ns1:ComponenteElectrico ;
    rdfs:label "Conector X8" ;
    ns1:textoExtracto "Imagen 'Grupo 1': conjunto RIO5 con 24 entradas digitales y 16 salidas digitales. Se muestran bastidores con conectores X1–X8 y leyendas de borneado (+24 V, GND), enfatizando el formato de módulo y su rol como bloque lógico único." .

ns1:ContadoraRCS_S_Nodo3 a ns1:ComponenteElectrico ;
    rdfs:label "Contadora RCS-S" ;
    ns1:textoExtracto "Esquema de interconexión del sistema Sercos con dos contadoras RCS-S (nodos 3 y 5) y tres reguladores AXD (nodos 1, 2 y 4)." .

ns1:ContadoraRCS_S_Nodo5 a ns1:ComponenteElectrico ;
    rdfs:label "Contadora RCS-S" ;
    ns1:textoExtracto "Esquema de interconexión del sistema Sercos con dos contadoras RCS-S (nodos 3 y 5) y tres reguladores AXD (nodos 1, 2 y 4)." .

ns1:EsquemaInterconexionSercos a ns1:Esquema ;
    rdfs:label "Esquema de interconexión del sistema Sercos" ;
    ns1:ilustradoEn ns1:BastidorRIO5,
        ns1:BastidorRIO5Expansivo,
        ns1:BastidorRIO5Expansivo2_162ca15bea ;
    ns1:textoExtracto "Esquema de interconexión del sistema Sercos con dos contadoras RCS-S (nodos 3 y 5) y tres reguladores AXD (nodos 1, 2 y 4)." .

ns1:EsquemaRIO5 a ns1:Esquema ;
    rdfs:label "Esquema RIO5" ;
    ns1:textoExtracto "Imagen 'Grupo 1': conjunto RIO5 con 24 entradas digitales y 16 salidas digitales. Se muestran bastidores con conectores X1–X8 y leyendas de borneado (+24 V, GND), enfatizando el formato de módulo y su rol como bloque lógico único." .

ns1:EsquemaRIO5Expansivo a ns1:Esquema ;
    rdfs:label "Esquema RIO5 Expansivo" ;
    ns1:textoExtracto "Imagen 'Grupo 2': bastidor RIO5 con 24+48 entradas y 16+32 salidas digitales. Los módulos apilados representan tres bloques lógicos de entradas y dos de salidas; se aprecian etiquetas de conectores y disposición modular repetitiva que ilustra la expansión." .

ns1:EsquemaRIO5Expansivo2_05fb6a7258 a ns1:Esquema ;
    rdfs:label "Esquema RIO5 Expansivo 2" ;
    ns1:textoExtracto "Imagen 'Grupo 3': bastidor RIO5 con 24+24 entradas y 16+16 salidas digitales." .

