@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BloqueCabezalS a ns1:ComponenteElectrico ;
    rdfs:label "Bloque cabezal S" ;
    ns1:textoExtracto "Se muestran bloques para ejes analógicos (X, Y, Z), ejes Sercos (U, V), un volante y un cabezal S, con líneas que conectan salidas analógicas (ANAOUT) y entradas de captación (E21A/B/C)." .

ns1:BloqueEjeX a ns1:ComponenteElectrico ;
    rdfs:label "Bloque eje X" ;
    ns1:textoExtracto "Se muestran bloques para ejes analógicos (X, Y, Z), ejes Sercos (U, V), un volante y un cabezal S, con líneas que conectan salidas analógicas (ANAOUT) y entradas de captación (E21A/B/C)." .

