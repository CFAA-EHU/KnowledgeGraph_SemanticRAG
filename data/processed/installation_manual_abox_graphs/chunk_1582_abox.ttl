@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BastidorRIO5 a ns1:Sistema ;
    rdfs:label "Bastidor RIO5" ;
    ns1:textoExtracto "Imagen 'Grupo 3': bastidor RIO5 con 24+24 entradas y 16+16 salidas digitales." ;
    ns1:tieneComponente ns1:BloqueEntradasBastidorRIO5,
        ns1:BloqueSalidasBastidorRIO5 .

ns1:ModuloRIOWNodo1_1f9275612f a ns1:Sistema ;
    rdfs:label "Módulo RIOW Nodo 1" ;
    ns1:textoExtracto "Imagen 'Nodo 1 (RIOW)': módulo RIOW con 16 entradas y 8 salidas." ;
    ns1:tieneComponente ns1:BloqueEntradasRIOWNodo1_4f2a858e00,
        ns1:BloqueSalidasRIOWNodo1_98432bed03 .

ns1:ModuloRIOWNodo2_3f0b9ea150 a ns1:Sistema ;
    rdfs:label "Módulo RIOW Nodo 2" ;
    ns1:textoExtracto "Imagen 'Nodo 2 (RIOW)': módulo RIOW con 8 entradas y 8 salidas." ;
    ns1:tieneComponente ns1:BloqueEntradasRIOWNodo2_d320b7d6fc,
        ns1:BloqueSalidasRIOWNodo2_3f26c22754 .

ns1:TarjetaRIORNodo1_224e70c397 a ns1:Sistema ;
    rdfs:label "Tarjeta RIOR Nodo 1" ;
    ns1:textoExtracto "Imagen 'Nodo 1 (RIOR)': tarjeta RIOR con 48 entradas y 32 salidas digitales." ;
    ns1:tieneComponente ns1:BloqueEntradasRIORNodo1_08dd4c5cb8,
        ns1:BloqueSalidasRIORNodo1_eaf925390c .

ns1:BloqueEntradasBastidorRIO5 a ns1:Sistema ;
    rdfs:label "Bloque Entradas Bastidor RIO5" ;
    ns1:textoExtracto "El esquema visual refuerza la partición en dos bloques lógicos de entradas, mostrando la continuidad del cableado y las regletas de conexión." .

ns1:BloqueEntradasRIORNodo1_08dd4c5cb8 a ns1:Sistema ;
    rdfs:label "Bloque Entradas RIOR Nodo 1" ;
    ns1:textoExtracto "Se aprecia el formato de placa y conectividad, representando un único bloque lógico de 48 DI y uno de 32 DO, con mapeo desde las primeras direcciones (I1/O1)." .

ns1:BloqueEntradasRIOWNodo1_4f2a858e00 a ns1:Sistema ;
    rdfs:label "Bloque Entradas RIOW Nodo 1" ;
    ns1:textoExtracto "Se representan tarjetas con indicadores RUN/TX/RX y bloques 8DI/8DO, destacando la segmentación en bloques lógicos independientes (entradas/salidas) y su indexación inicial (I1/O81 en el ejemplo)." .

ns1:BloqueEntradasRIOWNodo2_d320b7d6fc a ns1:Sistema ;
    rdfs:label "Bloque Entradas RIOW Nodo 2" ;
    ns1:textoExtracto "El gráfico muestra bastidores más compactos 8DI y 8DO, con conectores y rotulación de canales, evidenciando su asignación a direcciones base no consecutivas para evitar solapamientos." .

ns1:BloqueSalidasBastidorRIO5 a ns1:Sistema ;
    rdfs:label "Bloque Salidas Bastidor RIO5" ;
    ns1:textoExtracto "El esquema visual refuerza la partición en dos bloques lógicos de entradas, mostrando la continuidad del cableado y las regletas de conexión." .

ns1:BloqueSalidasRIORNodo1_eaf925390c a ns1:Sistema ;
    rdfs:label "Bloque Salidas RIOR Nodo 1" ;
    ns1:textoExtracto "Se aprecia el formato de placa y conectividad, representando un único bloque lógico de 48 DI y uno de 32 DO, con mapeo desde las primeras direcciones (I1/O1)." .

ns1:BloqueSalidasRIOWNodo1_98432bed03 a ns1:Sistema ;
    rdfs:label "Bloque Salidas RIOW Nodo 1" ;
    ns1:textoExtracto "Se representan tarjetas con indicadores RUN/TX/RX y bloques 8DI/8DO, destacando la segmentación en bloques lógicos independientes (entradas/salidas) y su indexación inicial (I1/O81 en el ejemplo)." .

ns1:BloqueSalidasRIOWNodo2_3f26c22754 a ns1:Sistema ;
    rdfs:label "Bloque Salidas RIOW Nodo 2" ;
    ns1:textoExtracto "El gráfico muestra bastidores más compactos 8DI y 8DO, con conectores y rotulación de canales, evidenciando su asignación a direcciones base no consecutivas para evitar solapamientos." .

