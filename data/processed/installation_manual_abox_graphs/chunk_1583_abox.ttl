@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BastidorRIOW a ns1:ComponenteElectrico ;
    rdfs:label "bastidor RIOW" ;
    ns1:textoExtracto "Imagen 'Nodo 2 (RIOW)': bastidor RIOW con 64 entradas digitales, representado como dos bloques (24 y 40 entradas) iniciados en direcciones altas (I104 e I200)." .

ns1:ChasisRIO5 a ns1:ComponenteElectrico ;
    rdfs:label "chasis RIO5" ;
    ns1:textoExtracto "Imagen 'Nodo 1 (RIO5)': chasis RIO5 con tres módulos de 24 entradas (24+48)." .

ns1:InterfazUsuarioLantekExpertInside a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de Lantek Expert Inside" ;
    ns1:textoExtracto "Captura de interfaz de Lantek Expert Inside mostrando el área principal de trabajo con lista de piezas y opciones de importación (DXF/DWG/paramétricas). Se aprecian botones de acceso rápido y una disposición orientada a uso táctil para cargar figuras y configurar material, espesor y dimensiones de chapa." .

ns1:SistemaOPENPCSRemoto a ns1:Sistema ;
    rdfs:label "Sistema OPENPCS Remoto" ;
    ns1:textoExtracto "Se aprecia el formato de placa y conectividad, representando un único bloque lógico de 48 DI y uno de 32 DO, con mapeo desde las primeras direcciones (I1/O1)." .

ns1:TarjetaRIOR a ns1:ComponenteElectrico ;
    rdfs:label "tarjeta RIOR" ;
    ns1:textoExtracto "Imagen 'Nodo 2 (RIOR)': tarjeta RIOR similar a la anterior, configurada como bloque de 48 entradas y 32 salidas con inicio en I97 y O81." .

