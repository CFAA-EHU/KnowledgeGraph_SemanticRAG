@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaConexionSensorGap a ns1:Esquema ;
    rdfs:label "Diagrama de conexión del sensor de gap" ;
    ns1:ilustra ns1:Componente_15b899c2b3 ;
    ns1:textoExtracto "Diagrama de conexión del sensor de gap a una entrada analógica en módulos remotos CAN (RIOR). Se identifican pines AI1+/AI1− y la cadena 'CNC – RIOR – CAN – GAP SENSOR', mostrando alternativa de cableado cuando no se usa el regulador." .

ns1:EsquemaControlGap a ns1:Esquema ;
    rdfs:label "Esquema del control de gap con boquilla láser" ;
    ns1:textoExtracto "Esquema del control de gap con boquilla láser, superficie de pieza y eje asociado (X/Z según máquina). Muestra el sensor manteniendo una distancia fija (gap) y la compensación en el eje longitudinal para seguir irregularidades; incluye rótulos 'LASER', 'GAP' y 'Workpiece surface'." .

ns1:BloqueCNC a ns1:ComponenteElectrico ;
    rdfs:label "Bloque CNC" ;
    ns1:textoExtracto "Diagrama eléctrico de conexión del sensor de gap a una entrada analógica del regulador Sercos. Representa bornes X7 (AI1+/AI1−), señal analógica ± y bloques 'CNC', 'DRIVE' y 'SERCOS', con flechas de señal entre módulos." .

ns1:BloqueDrive a ns1:ComponenteElectrico ;
    rdfs:label "Bloque DRIVE" ;
    ns1:textoExtracto "Diagrama eléctrico de conexión del sensor de gap a una entrada analógica del regulador Sercos. Representa bornes X7 (AI1+/AI1−), señal analógica ± y bloques 'CNC', 'DRIVE' y 'SERCOS', con flechas de señal entre módulos." .

ns1:BloqueSercos a ns1:ComponenteElectrico ;
    rdfs:label "Bloque SERCOS" ;
    ns1:textoExtracto "Diagrama eléctrico de conexión del sensor de gap a una entrada analógica del regulador Sercos. Representa bornes X7 (AI1+/AI1−), señal analógica ± y bloques 'CNC', 'DRIVE' y 'SERCOS', con flechas de señal entre módulos." .

ns1:Componente_15b899c2b3 a ns1:Componente ;
    rdfs:label "Sensor de gap" ;
    ns1:compuestoPor ns1:BloqueCNC,
        ns1:BloqueDrive,
        ns1:BloqueSercos ;
    ns1:textoExtracto "Diagrama eléctrico de conexión del sensor de gap a una entrada analógica del regulador Sercos. Representa bornes X7 (AI1+/AI1−), señal analógica ± y bloques 'CNC', 'DRIVE' y 'SERCOS', con flechas de señal entre módulos." .

