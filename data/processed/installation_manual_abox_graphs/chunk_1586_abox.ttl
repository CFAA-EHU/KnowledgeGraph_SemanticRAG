@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Esquema_NumeracionIOs a ns1:Esquema ;
    rdfs:label "Ejemplo de numeración de I/Os mediante parámetros máquina" ;
    ns1:ilustradoEn ns1:Nodo_RIO5,
        ns1:Nodo_RIOR,
        ns1:Nodo_RIOW ;
    ns1:textoExtracto "Se aprecia el formato de placa y conectividad, representando un único bloque lógico de 48 DI y uno de 32 DO, con mapeo desde las primeras direcciones (I1/O1)." .

ns1:Figura_Tarjetas8DI a ns1:Figura ;
    rdfs:label "Tarjetas 8DI agrupadas en módulos" ;
    ns1:ilustradoEn ns1:Nodo_RIO5,
        ns1:Nodo_RIOW ;
    ns1:textoExtracto "Se muestran múltiples tarjetas 8DI agrupadas, con leyendas de conectores (X1–X8), velocidades y dirección." .

ns1:Interfaz_LantekExpertInside a ns1:InterfazUsuario ;
    rdfs:label "Lantek Expert Inside - Área de trabajo" ;
    ns1:textoExtracto "Captura de interfaz de Lantek Expert Inside mostrando el área principal de trabajo con lista de piezas y opciones de importación (DXF/DWG/paramétricas). Se aprecian botones de acceso rápido y una disposición orientada a uso táctil para cargar figuras y configurar material, espesor y dimensiones de chapa." .

ns1:Nodo_RIOR a ns1:ComponenteElectrico ;
    rdfs:label "Nodo 2 (RIOR)" ;
    ns1:identificador "I97-O81" ;
    ns1:textoExtracto "tarjeta RIOR similar a la anterior, configurada como bloque de 48 entradas y 32 salidas con inicio en I97 y O81. La imagen enfatiza la equivalencia física con una numeración distinta por bloques lógicos." .

ns1:Nodo_RIO5 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo 1 (RIO5)" ;
    ns1:identificador "X1–X8" ;
    ns1:textoExtracto "chasis RIO5 con tres módulos de 24 entradas (24+48). Se muestran múltiples tarjetas 8DI agrupadas, con leyendas de conectores (X1–X8), velocidades y dirección, ilustrando la suma de bloques lógicos por módulo." .

ns1:Nodo_RIOW a ns1:ComponenteElectrico ;
    rdfs:label "Nodo 2 (RIOW)" ;
    ns1:identificador "I104-I200" ;
    ns1:textoExtracto "bastidor RIOW con 64 entradas digitales, representado como dos bloques (24 y 40 entradas) iniciados en direcciones altas (I104 e I200). El gráfico muestra repetición de tarjetas 8DI y distribución escalonada que facilita la indexación sin solapes." .

