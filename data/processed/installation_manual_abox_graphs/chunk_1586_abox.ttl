@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_ea5bfc2d73 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Diagrama de conexión del sensor de gap a una entrada analógica en módulos remotos CAN (RIOR)." ;
    ns1:tieneComponente ns1:FiltroPasoBajo,
        ns1:LazoPosicionGap,
        ns1:LimiteDeDistanciaDelSensorDeGap_b5b3fd72ae,
        ns1:LimiteDeVoltajeDelSensorDeGap_4119f0c895,
        ns1:OffsetDelSensorDeGap,
        ns1:Sensor_b3f72d817a .

ns1:FiltroPasoBajo a ns1:ComponenteElectrico ;
    rdfs:label "Filtro Paso Bajo" ;
    ns1:textoExtracto "Diagrama de bloques del lazo de control del gap: filtro paso bajo (ORDER/FREQUENCY)" .

ns1:LazoPosicionGap a ns1:Sistema ;
    rdfs:label "Lazo de Posición del Gap" ;
    ns1:textoExtracto "Diagrama de bloques del lazo de control del gap: POSITION LOOP con GAP P-GAIN" .

ns1:LimiteDeDistanciaDelSensorDeGap_b5b3fd72ae a ns1:Parametro ;
    rdfs:label "Límite de Distancia del Sensor de Gap" ;
    ns1:textoExtracto "Gráfico lineal distancia–voltaje del sensor con límites GAPDISTLIMIT (mm/in)" .

ns1:LimiteDeVoltajeDelSensorDeGap_4119f0c895 a ns1:Parametro ;
    rdfs:label "Límite de Voltaje del Sensor de Gap" ;
    ns1:textoExtracto "Gráfico lineal distancia–voltaje del sensor con límites GAPVOLTLIMIT (mV)" .

ns1:OffsetDelSensorDeGap a ns1:Parametro ;
    rdfs:label "Offset del Sensor de Gap" ;
    ns1:textoExtracto "Gráfico lineal distancia–voltaje del sensor con origen desplazado (GAPSENSOROFFSET)" .

ns1:Sensor_b3f72d817a a ns1:Sensor ;
    rdfs:label "Sensor de Gap" ;
    ns1:textoExtracto "Diagrama de conexión del sensor de gap a una entrada analógica en módulos remotos CAN (RIOR)." .

