ns1:CabezalAngularYZDe45_a2ed7ca33c a ns1:Sistema ;
    rdfs:label "Cabezal angular YZ de 45°" ;
    ns1:textoExtracto "Ilustración del cabezal angular YZ de 45° (TYPE=6) con iconografía de ejes y geometría; introduce el contexto de medición con palpador y la necesidad de conocer radio y longitud de la bola del palpador." ;
    ns1:tieneComponente ns1:Sensor_119d3ef5e6 .

ns1:ParametroTDATA1 a ns1:Parametro ;
    rdfs:label "parámetro TDATA1" ;
    ns1:textoExtracto "Diagrama 'Primera palpación': B=0°, C=0°, contacto sobre cara Z y preselección Z=0; flechas indican sentido de palpación y referencias OT y ejes Y-Z." .

ns1:Sensor_119d3ef5e6 a ns1:Sensor ;
    rdfs:label "palpador" ;
    ns1:textoExtracto "Ilustración del cabezal angular YZ de 45° (TYPE=6) con iconografía de ejes y geometría; introduce el contexto de medición con palpador y la necesidad de conocer radio y longitud de la bola del palpador." .

