@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_LantekExpertInside_ConfiguracionIdioma a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de configuración de idioma de Lantek Expert Inside"@es ;
    ns1:textoExtracto "Ventana de 'General/Idioma' de Lantek con menú desplegable para selección de idioma (en, es, fr, etc.)."@es .

ns1:InterfazUsuario_LantekExpertInside_Principal a ns1:InterfazUsuario ;
    rdfs:label "Interfaz principal de Lantek Expert Inside"@es ;
    ns1:ilustradoEn ns1:Figura_LantekExpertInside_BarraHerramientas ;
    ns1:textoExtracto "Se aprecian botones de acceso rápido y una disposición orientada a uso táctil para cargar figuras y configurar material, espesor y dimensiones de chapa. --- Barra inferior de herramientas del entorno Lantek con iconografía de controles (abrir, guardar, simular, aceptar, deshacer) dispuesta en formato de grandes botones táctiles; sirve para facilitar acciones frecuentes a pie de máquina."@es .

ns1:InterfazUsuario_LantekExpertInside_Simulacion a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de simulación de Lantek Expert Inside"@es ;
    ns1:textoExtracto "Pantalla de simulación previa con barra de controles para reproducir el recorrido, vista del trazado de corte y resumen para postprocesado Fagor; confirma la generación del programa pieza para el CNC tras verificación visual."@es .

ns1:Parametro_Lantek_LeadIn a ns1:Parametro ;
    rdfs:label "Parámetro Lead-In"@es ;
    ns1:monitoreaParametro ns1:InterfazUsuario_LantekExpertInside_Anidado ;
    ns1:textoExtracto "paleta de utilidades para gestión de lead-in/lead-out"@es .

ns1:Parametro_Lantek_LeadOut a ns1:Parametro ;
    rdfs:label "Parámetro Lead-Out"@es ;
    ns1:monitoreaParametro ns1:InterfazUsuario_LantekExpertInside_Anidado ;
    ns1:textoExtracto "paleta de utilidades para gestión de lead-in/lead-out"@es .

ns1:Parametro_Lantek_Microjuntas a ns1:Parametro ;
    rdfs:label "Parámetro Microjuntas"@es ;
    ns1:monitoreaParametro ns1:InterfazUsuario_LantekExpertInside_ConfiguracionTecnologica ;
    ns1:textoExtracto "paleta de utilidades para gestión de lead-in/lead-out y microjuntas --- listas de parámetros para ajustar automáticamente o de forma manual"@es .

ns1:Parametro_Lantek_OrdenCorte a ns1:Parametro ;
    rdfs:label "Parámetro Orden de Corte"@es ;
    ns1:monitoreaParametro ns1:InterfazUsuario_LantekExpertInside_ConfiguracionTecnologica ;
    ns1:textoExtracto "selección de puntos de entrada/salida, microjuntas y orden de corte"@es .

ns1:Parametro_Lantek_PuntosEntradaSalida a ns1:Parametro ;
    rdfs:label "Parámetro Puntos de Entrada/Salida"@es ;
    ns1:monitoreaParametro ns1:InterfazUsuario_LantekExpertInside_ConfiguracionTecnologica ;
    ns1:textoExtracto "selección de puntos de entrada/salida"@es .

ns1:Figura_LantekExpertInside_BarraHerramientas a ns1:Figura ;
    rdfs:label "Barra de herramientas táctil de Lantek Expert Inside"@es ;
    ns1:textoExtracto "Barra inferior de herramientas del entorno Lantek con iconografía de controles (abrir, guardar, simular, aceptar, deshacer) dispuesta en formato de grandes botones táctiles"@es .

ns1:InterfazUsuario_LantekExpertInside_Anidado a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de anidado de Lantek Expert Inside"@es ;
    ns1:textoExtracto "Captura del área de anidado con piezas distribuidas manual o automáticamente sobre una chapa rectangular; se observan contornos, márgenes y la paleta de utilidades para gestión de lead-in/lead-out y microjuntas, con panel lateral de propiedades."@es .

ns1:InterfazUsuario_LantekExpertInside_ConfiguracionTecnologica a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de configuración tecnológica de Lantek Expert Inside"@es ;
    ns1:textoExtracto "Captura de configuración tecnológica que destaca selección de puntos de entrada/salida, microjuntas y orden de corte. Incluye indicadores visuales de direccionalidad (flechas en trayectorias) y listas de parámetros para ajustar automáticamente o de forma manual."@es .

