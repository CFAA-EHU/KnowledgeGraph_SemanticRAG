@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Esquema_ConexionadoSensorGap_CAN a ns1:Esquema ;
    rdfs:label "Diagrama de conexión del sensor de gap vía CAN (RIOR)" ;
    ns1:detalladoEnEsquema ns1:ComponenteElectrico_EntradaAnalogicaRIOR,
        ns1:ComponenteElectrico_ModuloRIOR_CAN ;
    ns1:textoExtracto "Diagrama de conexión del sensor de gap a una entrada analógica en módulos remotos CAN (RIOR). Se identifican pines AI1+/AI1− y la cadena 'CNC – RIOR – CAN – GAP SENSOR'" .

ns1:InterfazUsuario_LantekExpertInside_SelectorIdioma a ns1:InterfazUsuario ;
    rdfs:label "Selector de idioma en Lantek Expert Inside" ;
    ns1:ilustradoEn ns1:Figura_LantekExpertInside_SelectorIdioma ;
    ns1:textoExtracto "Ventana de 'General/Idioma' de Lantek con menú desplegable para selección de idioma (en, es, fr, etc.) y botones superiores grandes; la captura ilustra la localización de la opción de idioma dentro del menú de ajustes." .

ns1:Sistema_ControlGapLaser a ns1:Sistema ;
    rdfs:label "Sistema de control de gap en láser" ;
    ns1:compuestoPor ns1:ComponenteMecanico_BoquillaLaser,
        ns1:Sensor_GapLaser ;
    ns1:documentadoEn ns1:Pagina_694 ;
    ns1:ilustradoEn ns1:Esquema_ControlGapLaser ;
    ns1:textoExtracto "Esquema del control de gap con boquilla láser, superficie de pieza y eje asociado (X/Z según máquina). Muestra el sensor manteniendo una distancia fija (gap) y la compensación en el eje longitudinal para seguir irregularidades" .

ns1:ComponenteElectrico_BornesX7_AI1 a ns1:ComponenteElectrico ;
    rdfs:label "Bornes X7 (AI1+/AI1−)" ;
    ns1:identificador "X7 (AI1+/AI1−)" ;
    ns1:textoExtracto "bornes X7 (AI1+/AI1−)" .

ns1:ComponenteElectrico_EntradaAnalogicaCNC a ns1:ComponenteElectrico ;
    rdfs:label "Entrada analógica del CNC" ;
    ns1:identificador "AI1+/AI1−" ;
    ns1:textoExtracto "entrada analógica del regulador Sercos" .

ns1:ComponenteElectrico_EntradaAnalogicaRIOR a ns1:ComponenteElectrico ;
    rdfs:label "Entrada analógica en módulo RIOR (AI1+/AI1−)" ;
    ns1:identificador "RIOR_AI1+/AI1−" ;
    ns1:textoExtracto "pines AI1+/AI1−" .

ns1:ComponenteElectrico_ModuloRIOR_CAN a ns1:ComponenteElectrico ;
    rdfs:label "Módulo remoto RIOR (CAN)" ;
    ns1:identificador "RIOR-CAN" ;
    ns1:textoExtracto "módulos remotos CAN (RIOR)" .

ns1:ComponenteElectrico_ReguladorSercos a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos" ;
    ns1:identificador "SERCOS" ;
    ns1:textoExtracto "regulador Sercos" .

ns1:ComponenteMecanico_BoquillaLaser a ns1:ComponenteMecanico ;
    rdfs:label "Boquilla láser" ;
    ns1:textoExtracto "boquilla láser" .

ns1:Esquema_ConexionadoSensorGap a ns1:Esquema ;
    rdfs:label "Diagrama eléctrico de conexión del sensor de gap" ;
    ns1:detalladoEnEsquema ns1:ComponenteElectrico_BornesX7_AI1,
        ns1:ComponenteElectrico_EntradaAnalogicaCNC,
        ns1:ComponenteElectrico_ReguladorSercos ;
    ns1:textoExtracto "Diagrama eléctrico de conexión del sensor de gap a una entrada analógica del regulador Sercos. Representa bornes X7 (AI1+/AI1−), señal analógica ± y bloques 'CNC', 'DRIVE' y 'SERCOS'" .

ns1:Esquema_ControlGapLaser a ns1:Esquema ;
    rdfs:label "Esquema de control de gap con boquilla láser" ;
    ns1:textoExtracto "Esquema del control de gap con boquilla láser, superficie de pieza y eje asociado (X/Z según máquina)." .

ns1:Figura_LantekExpertInside_SelectorIdioma a ns1:Figura ;
    rdfs:label "Captura del selector de idioma en Lantek Expert Inside" ;
    ns1:textoExtracto "Captura resumida del selector de idioma dentro del botón 'General', evidenciando la disponibilidad de dos idiomas instalados y la elección directa desde la interfaz." .

ns1:Parametro_DistanciaGap a ns1:Parametro ;
    rdfs:label "Distancia de gap (GAP)" ;
    ns1:textoExtracto "distancia fija (gap)" ;
    ns1:valor "GAP" .

ns1:Sensor_GapLaser a ns1:Sensor ;
    rdfs:label "Sensor de gap láser" ;
    ns1:detalladoEnEsquema ns1:Esquema_ConexionadoSensorGap ;
    ns1:monitoreaParametro ns1:Parametro_DistanciaGap ;
    ns1:textoExtracto "sensor manteniendo una distancia fija (gap) y la compensación en el eje longitudinal para seguir irregularidades" .

