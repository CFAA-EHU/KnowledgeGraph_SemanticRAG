@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaCalculoTDATA1 a ns1:Esquema ;
    rdfs:label "Esquema combinado para TDATA1" ;
    ns1:ilustra ns1:ParametroTDATA1 ;
    ns1:textoExtracto "\"Esquema combinado con variables TDATA1, ΔZ, L y R, y anotación de la solución TDATA1 = |ΔZ| − R − L\"" .

ns1:EsquemaCalculoTDATA5 a ns1:Esquema ;
    rdfs:label "Esquema combinado para TDATA5" ;
    ns1:ilustra ns1:ParametroTDATA5 ;
    ns1:textoExtracto "\"Esquema de solución con marcadores de B/C y anotación TDATA5 = 0,5·|ΔX|\"" .

ns1:EsquemaCalculoTDATA6 a ns1:Esquema ;
    rdfs:label "Esquema combinado para TDATA6" ;
    ns1:ilustra ns1:ParametroTDATA6 ;
    ns1:textoExtracto "\"Diagrama 'Primera palpación': B=0°, C=0°, medición del ancho D entre dos caras X con corrección 2R (bola); se indica X = D + 2R\"" .

ns1:ParametroTDATA1 a ns1:Parametro ;
    rdfs:label "parámetro TDATA1" ;
    ns1:textoExtracto "\"Esquema combinado con variables TDATA1, ΔZ, L y R, y anotación de la solución TDATA1 = |ΔZ| − R − L\"" .

ns1:ParametroTDATA5 a ns1:Parametro ;
    rdfs:label "parámetro TDATA5" ;
    ns1:textoExtracto "\"Esquema de solución con marcadores de B/C y anotación TDATA5 = 0,5·|ΔX|\"" .

ns1:ParametroTDATA6 a ns1:Parametro ;
    rdfs:label "parámetro TDATA6" ;
    ns1:textoExtracto "\"Diagrama 'Primera palpación': B=0°, C=0°, medición del ancho D entre dos caras X con corrección 2R (bola); se indica X = D + 2R\"" .

