@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Grafico_CompensacionGapEjemplo a ns1:InterfazUsuario ;
    rdfs:label "Trazas de compensación del gap para pieza con irregularidad" ;
    ns1:ilustradoEn ns1:Parametro_Gap ;
    ns1:textoExtracto "Trazas de ejemplo para 'Pieza con una irregularidad en el perfil': se muestran G.GAP, A.POS.Z, A.POS.X y A.GAPCOMP.Z; la compensación del eje del sensor se ve como correcciones sincronizadas ante cambios abruptos de perfil." .

ns1:Grafico_OsciloscopioPerfilGap a ns1:InterfazUsuario ;
    rdfs:label "Gráfico osciloscopio: Perfil de velocidad y aceleración en el gap" ;
    ns1:ilustradoEn ns1:Parametro_AceleracionEjeZ,
        ns1:Parametro_ErrorSeguimiento,
        ns1:Parametro_Gap,
        ns1:Parametro_VelocidadEjeZ ;
    ns1:textoExtracto "Gráfico tipo osciloscopio 'Perfil de velocidad y aceleración sin sobrepasamiento en el gap' con cuatro trazas etiquetadas: (A) G.GAP, (B) error de seguimiento A.FLWE.Z, (C) velocidad DIFF(A.TPOS.Z), (D) aceleración DIFF(DIFF(A.TPOS.Z))." .

ns1:Parametro_GAPDISTLIMIT a ns1:Parametro ;
    rdfs:label "Límite de distancia del gap (GAPDISTLIMIT)" ;
    ns1:textoExtracto "límite GAPDISTLIMIT (mm/in)" ;
    ns1:valor "mm/in"@es .

ns1:Parametro_GAPSENSOROFFSET a ns1:Parametro ;
    rdfs:label "Offset del sensor de gap (GAPSENSOROFFSET)" ;
    ns1:ilustradoEn ns1:Grafico_CalibracionSensorGap ;
    ns1:textoExtracto "origen desplazado (GAPSENSOROFFSET)" .

ns1:Parametro_GAPVOLTLIMIT a ns1:Parametro ;
    rdfs:label "Límite de voltaje del sensor (GAPVOLTLIMIT)" ;
    ns1:textoExtracto "límite GAPVOLTLIMIT (mV)" ;
    ns1:valor "mV"@es .

ns1:EntradaAnalogica_AI1 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada analógica AI1 (pines AI1+/AI1−)" ;
    ns1:compuestoPor ns1:ModuloRemotoCAN_RIOR ;
    ns1:textoExtracto "pines AI1+/AI1−" .

ns1:Esquema_ConexionSensorGapRIOR a ns1:Esquema ;
    rdfs:label "Diagrama de conexión del sensor de gap a entrada analógica (RIOR)" ;
    ns1:identificador "CNC – RIOR – CAN – GAP SENSOR" ;
    ns1:textoExtracto "Diagrama de conexión del sensor de gap a una entrada analógica en módulos remotos CAN (RIOR). Se identifican pines AI1+/AI1− y la cadena 'CNC – RIOR – CAN – GAP SENSOR', mostrando alternativa de cableado cuando no se usa el regulador." .

ns1:ModuloRemotoCAN_RIOR a ns1:ComponenteElectrico ;
    rdfs:label "Módulo remoto CAN (RIOR)" ;
    ns1:textoExtracto "módulos remotos CAN (RIOR)" ;
    ns1:tieneComponente ns1:EntradaAnalogica_AI1,
        ns1:SensorGap .

ns1:Parametro_GAPGAIN a ns1:Parametro ;
    rdfs:label "Ganancia del lazo de posición (GAP P-GAIN)" ;
    ns1:documentadoEn ns1:Esquema_LazoControlGap ;
    ns1:textoExtracto "GAP P-GAIN" .

ns1:Parametro_GAPSENSORFILTER a ns1:Parametro ;
    rdfs:label "Filtro paso bajo del sensor (ORDER/FREQUENCY)" ;
    ns1:documentadoEn ns1:Esquema_LazoControlGap ;
    ns1:textoExtracto "filtro paso bajo (ORDER/FREQUENCY)" .

ns1:SensorGap a ns1:Sensor ;
    rdfs:label "Sensor de gap" ;
    ns1:controla ns1:Parametro_Gap ;
    ns1:detalladoEnEsquema ns1:Esquema_ConexionSensorGapRIOR ;
    ns1:ilustradoEn ns1:Grafico_CalibracionSensorGap ;
    ns1:monitoreaParametro ns1:Parametro_AceleracionEjeZ,
        ns1:Parametro_ErrorSeguimiento,
        ns1:Parametro_Gap,
        ns1:Parametro_VelocidadEjeZ ;
    ns1:textoExtracto "sensor de gap" .

ns1:Esquema_LazoControlGap a ns1:Esquema ;
    rdfs:label "Diagrama de bloques del lazo de control del gap" ;
    ns1:detalladoEnEsquema ns1:Parametro_GAPGAIN,
        ns1:Parametro_GAPSENSORFILTER ;
    ns1:textoExtracto "Diagrama de bloques del lazo de control del gap: 'GAP SENSOR FEEDBACK' → filtro paso bajo (ORDER/FREQUENCY) → 'POSITION LOOP' con 'GAP P-GAIN'. Representa la cadena de señal y dónde actúan los parámetros GAPGAIN y GAPSENSORFILTER." .

ns1:Grafico_CalibracionSensorGap a ns1:InterfazUsuario ;
    rdfs:label "Gráfico lineal distancia–voltaje del sensor de gap" ;
    ns1:textoExtracto "Gráfico lineal distancia–voltaje del sensor con origen desplazado (GAPSENSOROFFSET), límites GAPDISTLIMIT (mm/in) y GAPVOLTLIMIT (mV). Incluye ejes con unidades, recta de calibración y flechas que marcan la correspondencia física y eléctrica." .

ns1:Parametro_AceleracionEjeZ a ns1:Parametro ;
    rdfs:label "Aceleración DIFF(DIFF(A.TPOS.Z))" ;
    ns1:textoExtracto "aceleración DIFF(DIFF(A.TPOS.Z))" .

ns1:Parametro_ErrorSeguimiento a ns1:Parametro ;
    rdfs:label "Error de seguimiento A.FLWE.Z" ;
    ns1:textoExtracto "error de seguimiento A.FLWE.Z" .

ns1:Parametro_VelocidadEjeZ a ns1:Parametro ;
    rdfs:label "Velocidad DIFF(A.TPOS.Z)" ;
    ns1:textoExtracto "velocidad DIFF(A.TPOS.Z)" .

ns1:Parametro_Gap a ns1:Parametro ;
    rdfs:label "Parámetro G.GAP" ;
    ns1:textoExtracto "G.GAP" ;
    ns1:valor "Distancia del gap (unidad: mm/in)"@es .

