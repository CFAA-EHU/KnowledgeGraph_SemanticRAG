@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_2.3.31_ControlGap
    a ex:Tabla ;
    rdfs:label "Tabla de configuración del eje Z para control del gap"@es ;
    ex:textoExtracto """
| Valor. | Significado. |
| --- | --- |
| Sí. | El sentido positivo del eje Z es hacia arriba y el negativo hacia abajo (condiciones normales). El eje se mueve en sentido negativo (hacia abajo) para alcanzar el gap. |
| No | El sentido positivo del eje Z es hacia abajo y el negativo hacia arriba (eje Z invertido). El eje se mueve en sentido positivo (hacia abajo) para alcanzar el gap. |
"""@es ;
    ex:documentadoEn ex:Pagina_98_103 .

ex:Parametro_ConfigEjeZ
    a ex:Parametro ;
    rdfs:label "Configuración del sentido del eje Z"@es ;
    ex:textoExtracto "El sentido positivo del eje Z es hacia arriba y el negativo hacia abajo (condiciones normales) [...] El sentido positivo del eje Z es hacia abajo y el negativo hacia arriba (eje Z invertido)."@es ;
    ex:valor "Sí/No"@es ;
    ex:documentadoEn ex:Tabla_2.3.31_ControlGap .

ex:ModoOperacion_GapNormal
    a ex:ModoOperacion ;
    rdfs:label "Modo de operación con eje Z normal (gap)"@es ;
    ex:textoExtracto "El sentido positivo del eje Z es hacia arriba y el negativo hacia abajo (condiciones normales). El eje se mueve en sentido negativo (hacia abajo) para alcanzar el gap."@es ;
    ex:ilustradoEn ex:Tabla_2.3.31_ControlGap .

ex:ModoOperacion_GapInvertido
    a ex:ModoOperacion ;
    rdfs:label "Modo de operación con eje Z invertido (gap)"@es ;
    ex:textoExtracto "El sentido positivo del eje Z es hacia abajo y el negativo hacia arriba (eje Z invertido). El eje se mueve en sentido positivo (hacia abajo) para alcanzar el gap."@es ;
    ex:ilustradoEn ex:Tabla_2.3.31_ControlGap .