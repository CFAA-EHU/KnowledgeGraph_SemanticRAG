@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_b0a2aa4420 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Se denomina conmutación sincronizada al proceso de controlar el estado de una salida digital local del CNC en función del tipo de movimiento programado en los ejes." ;
    ns1:tieneComponente ns1:SalidaLocal1,
        ns1:SalidaLocal2 .

ns1:NumeroDeSalidasDigitalesLocales_cd86af1b2f a ns1:Parametro ;
    rdfs:label "Número de salidas digitales locales" ;
    ns1:identificador "NLOCOUT" ;
    ns1:textoExtracto "Para ello será necesario parametrizar el parámetro NLOCOUT con valor 8." .

ns1:SalidaDigitalLocalAsociadaALaConmutacionSincronizada a ns1:Parametro ;
    rdfs:label "Salida digital local asociada a la conmutación sincronizada" ;
    ns1:identificador "MPG.SWTOUTPUT" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.SWTOUTPUT Salida digital local asociada a la conmutación sincronizada." .

ns1:SalidaLocal1 a ns1:ComponenteElectrico ;
    rdfs:label "Salida Local 1" ;
    ns1:textoExtracto "Para la conmutación sincronizada sólo se podrán utilizar las salidas locales asociadas a los pines LI/O1 (salida local 1)" .

ns1:SalidaLocal2 a ns1:ComponenteElectrico ;
    rdfs:label "Salida Local 2" ;
    ns1:textoExtracto "Para la conmutación sincronizada sólo se podrán utilizar las salidas locales asociadas a los pines LI/O2 (salida local 2)" .

