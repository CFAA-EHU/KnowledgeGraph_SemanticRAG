@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalAngularTYPE6YZ45_ff873a3838 a ns1:Sistema ;
    rdfs:label "Cabezal angular TYPE=6 (YZ 45°)" ;
    ns1:documentadoEn ns1:EsquemaColocacionIncorrectaRelojComparador,
        ns1:EsquemaDeSolucionConDobleVistaB90_60be6e1074 ;
    ns1:textoExtracto "Esquema del cabezal angular TYPE=6 (YZ 45°) con representación de ejes X-Y-Z y sentidos positivos de parámetros TDATA" ;
    ns1:tieneComponente ns1:CilindroPatron .

ns1:RelojComparador a ns1:Herramienta ;
    rdfs:label "Reloj comparador" ;
    ns1:textoExtracto "Ilustración del uso correcto del reloj comparador sobre un cilindro" .

ns1:CilindroPatron a ns1:ComponenteMecanico ;
    rdfs:label "Cilindro patrón" ;
    ns1:textoExtracto "cilindro patrón montado en el cabezal" .

ns1:EsquemaColocacionIncorrectaRelojComparador a ns1:Esquema ;
    rdfs:label "Esquemas de colocación incorrecta del reloj comparador" ;
    ns1:textoExtracto "Dos esquemas con marcas de error (cruz) que ejemplifican colocaciones incorrectas del reloj comparador sobre el cilindro" .

ns1:EsquemaDeSolucionConDobleVistaB90_60be6e1074 a ns1:Esquema ;
    rdfs:label "Esquema de solución con doble vista B=±90°" ;
    ns1:ilustra ns1:Parametro_0c1f628ac1 ;
    ns1:textoExtracto "Esquema de solución con doble vista B=±90° y anotaciones TDATA5 y ΔZ, junto a la relación TDATA2 = 0,5·|ΔZ| − |TDATA5|" .

ns1:Parametro_0c1f628ac1 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA2" ;
    ns1:identificador "TDATA2" ;
    ns1:textoExtracto "relación TDATA2 = 0,5·|ΔZ| − |TDATA5|" .

