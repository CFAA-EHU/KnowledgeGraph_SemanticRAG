@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EsquemaPosicionReferenciaTDATA2 a ns1:Esquema ;
    rdfs:label "Pareja de diagramas para TDATA2" ;
    ns1:ilustra ns1:CalculoDelParametroTDATA2_3e63bfb9b3 ;
    ns1:textoExtracto "Pareja de diagramas para TDATA2: posición de referencia con B=0°, C=0° (punto 1) y posición con B=180°, C=0° (punto 3)." .

ns1:EsquemaPrimerSegundoContactoTDATA6 a ns1:Esquema ;
    rdfs:label "Secuencia Primer y Segundo Contacto TDATA6" ;
    ns1:ilustra ns1:CalculoDelParametroTDATA6_a111c673af ;
    ns1:textoExtracto "Secuencia 'Primer y segundo contacto': desde X=−R con B=0°, C=0° (punto 1) a B=−90° (punto 2)." .

ns1:EsquemaSegundoContactoTDATA5 a ns1:Esquema ;
    rdfs:label "Esquema Segundo Contacto TDATA5" ;
    ns1:ilustra ns1:CalculoDelParametroTDATA5 ;
    ns1:textoExtracto "Esquema 'Segundo contacto' para TDATA5 con C=180°, palpado en punto 2 y lectura de ΔX." .

ns1:EsquemaTercerCuartoContactoTDATA6 a ns1:Esquema ;
    rdfs:label "Secuencia Tercer y Cuarto Contacto TDATA6" ;
    ns1:ilustra ns1:CalculoDelParametroTDATA6_a111c673af ;
    ns1:textoExtracto "Secuencia 'Tercer y cuarto contacto': desde X=+R con B=0°, C=0° (punto 3) a B=+90° (punto 4)." .

ns1:CalculoDelParametroTDATA2_3e63bfb9b3 a ns1:Parametro ;
    rdfs:label "Cálculo del parámetro TDATA2" ;
    ns1:identificador "TDATA2" ;
    ns1:textoExtracto "Pareja de diagramas para TDATA2: posición de referencia con B=0°, C=0° (punto 1) y posición con B=180°, C=0° (punto 3)." .

ns1:CalculoDelParametroTDATA5 a ns1:Parametro ;
    rdfs:label "Cálculo del parámetro TDATA5" ;
    ns1:identificador "TDATA5" ;
    ns1:textoExtracto "Esquema 'Segundo contacto' para TDATA5 con C=180°, palpado en punto 2 y lectura de ΔX." .

ns1:CalculoDelParametroTDATA6_a111c673af a ns1:Parametro ;
    rdfs:label "Cálculo del parámetro TDATA6" ;
    ns1:identificador "TDATA6" ;
    ns1:textoExtracto "Secuencia 'Primer y segundo contacto': desde X=−R con B=0°, C=0° (punto 1) a B=−90° (punto 2)." .

