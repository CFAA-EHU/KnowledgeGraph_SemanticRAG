@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_Palpador a ns1:ComponenteMecanico ;
    rdfs:label "Palpador"@es ;
    ns1:compuestoPor ns1:Esquema_PalpacionTDATA6 ;
    ns1:textoExtracto "geometría del cabezal, posición del palpador (L, R)"@es .

ns1:Sistema_EjesXZ a ns1:Sistema ;
    rdfs:label "Sistema de ejes X-Z"@es ;
    ns1:compuestoPor ns1:Diagrama_PrimeraPalpacion_Z ;
    ns1:textoExtracto "sistema de ejes X-Z"@es .

ns1:Diagrama_SegundaPalpacion_X a ns1:Figura ;
    rdfs:label "Diagrama 'Segunda palpación' (B=−90°, C=0°)"@es ;
    ns1:ilustradoEn ns1:Esquema_PalpacionTDATA6 ;
    ns1:textoExtracto "Diagrama 'Segunda palpación': B=−90°, C=0°, palpación de la primera cara X con lectura ΔX′; se representa orientación del cabezal y referencias 1 y 2."@es .

ns1:Diagrama_SegundaPalpacion_Z a ns1:Figura ;
    rdfs:label "Diagrama 'Segunda palpación' (C=0°, B=−90°)"@es ;
    ns1:ilustradoEn ns1:Esquema_PalpacionTDATA6 ;
    ns1:textoExtracto "Diagrama 'Segunda palpación': C=0°, B=−90°, repetición sobre cara Z con lectura ΔZ; ilustra el cambio del centro de giro ① y la lectura que interviene en la ecuación de TDATA2."@es .

ns1:Diagrama_TerceraPalpacion_X a ns1:Figura ;
    rdfs:label "Diagrama 'Tercera palpación' (B=+90°, C=0°)"@es ;
    ns1:ilustradoEn ns1:Esquema_PalpacionTDATA6 ;
    ns1:textoExtracto "Diagrama 'Tercera palpación': B=+90°, C=0°, palpación de la segunda cara X con lectura ΔX; muestra la simetría del procedimiento respecto al giro de B."@es .

ns1:Parametro_TDATA1 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA1"@es ;
    ns1:identificador "TDATA1" ;
    ns1:monitoreaParametro ns1:Esquema_PalpacionTDATA6 ;
    ns1:textoExtracto "referencias TDATA1/TDATA6"@es .

ns1:Parametro_TDATA2 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA2"@es ;
    ns1:identificador "TDATA2" ;
    ns1:monitoreaParametro ns1:Esquema_PalpacionTDATA6 ;
    ns1:textoExtracto "lectura ΔZ; ilustra el cambio del centro de giro ① y la lectura que interviene en la ecuación de TDATA2"@es .

ns1:Parametro_TDATA6 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA6"@es ;
    ns1:identificador "TDATA6" ;
    ns1:monitoreaParametro ns1:Esquema_PalpacionTDATA6 ;
    ns1:textoExtracto "TDATA6 = (ΔX + ΔX′ − 2L − D − 2·TDATA1)/(2·cos45°)"@es .

ns1:Diagrama_PrimeraPalpacion_Z a ns1:Figura ;
    rdfs:label "Diagrama 'Primera palpación' (C=0°, B=+90°)"@es ;
    ns1:ilustradoEn ns1:Esquema_PalpacionTDATA6 ;
    ns1:textoExtracto "Diagrama 'Primera palpación': C=0°, B=+90°, contacto sobre cara Z con preselección Z=0; se destaca la rotación de B y el sistema de ejes X-Z."@es .

ns1:Esquema_PalpacionTDATA6 a ns1:Esquema ;
    rdfs:label "Esquema combinado para cálculo de TDATA6"@es ;
    ns1:detalladoEnEsquema ns1:Parametro_TDATA1,
        ns1:Parametro_TDATA2,
        ns1:Parametro_TDATA6 ;
    ns1:ilustradoEn ns1:Diagrama_PrimeraPalpacion_Z,
        ns1:Diagrama_SegundaPalpacion_X,
        ns1:Diagrama_SegundaPalpacion_Z,
        ns1:Diagrama_TerceraPalpacion_X ;
    ns1:textoExtracto "Esquema combinado con fórmula de solución TDATA6 = (ΔX + ΔX′ − 2L − D − 2·TDATA1)/(2·cos45°); incluye geometría del cabezal, posición del palpador (L, R) y referencias TDATA1/TDATA6."@es .

