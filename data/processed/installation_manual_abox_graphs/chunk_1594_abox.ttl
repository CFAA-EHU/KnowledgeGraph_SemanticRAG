@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DistanciaE a ns1:Parametro ;
    rdfs:label "Distancia E" ;
    ns1:textoExtracto "Dos disposiciones del eje B (A=0° con B=0° y B=−90°) para determinar TDATA2, TDATA4 y TDATA5. Se anotan lecturas ΔX1, ΔZ y ΔZ1, y se marcan distancias E y F desde la mesa hasta los ejes B y A respectivamente, con líneas de cota y referencias Pz y r." .

ns1:DistanciaF a ns1:Parametro ;
    rdfs:label "Distancia F" ;
    ns1:textoExtracto "Dos disposiciones del eje B (A=0° con B=0° y B=−90°) para determinar TDATA2, TDATA4 y TDATA5. Se anotan lecturas ΔX1, ΔZ y ΔZ1, y se marcan distancias E y F desde la mesa hasta los ejes B y A respectivamente, con líneas de cota y referencias Pz y r." .

ns1:InterfazUsuarioTablaHerramientas a ns1:InterfazUsuario ;
    rdfs:label "Captura de interfaz de la tabla de herramientas del CNC" ;
    ns1:textoExtracto "Captura de interfaz de la tabla de herramientas del CNC con resaltados 'A' (tipo de herramienta) y 'B' (número de dientes 1–100). Incluye lista de herramientas, iconos, campos editables y un panel contextual de parámetros, útil para que el DMC limite el avance por diente." .

ns1:LecturaX a ns1:Parametro ;
    rdfs:label "Lectura ΔX" ;
    ns1:textoExtracto "Dibujo de preselección X con A=90°, B=−90° y palpado en X sobre la mesa; se representa la lectura ΔX y la asignación X=−r para hacer coincidir X=0 con la superficie de la mesa, indicando el radio de bola del palpador r." .

ns1:LecturaY1 a ns1:Parametro ;
    rdfs:label "Lectura ΔY1" ;
    ns1:textoExtracto "Se muestran palpados en Y y Z sobre un cilindro (puntos 1–4), las lecturas ΔY1/ΔY2 y ΔZ1/ΔZ2, y la obtención de TDATA3 (Y) y Pz (Z) con cotas y radio R." .

ns1:LecturaY2 a ns1:Parametro ;
    rdfs:label "Lectura ΔY2" ;
    ns1:textoExtracto "Se muestran palpados en Y y Z sobre un cilindro (puntos 1–4), las lecturas ΔY1/ΔY2 y ΔZ1/ΔZ2, y la obtención de TDATA3 (Y) y Pz (Z) con cotas y radio R." .

ns1:LecturaZ a ns1:Parametro ;
    rdfs:label "Lectura ΔZ" ;
    ns1:textoExtracto "Dos disposiciones del eje B (A=0° con B=0° y B=−90°) para determinar TDATA2, TDATA4 y TDATA5. Se anotan lecturas ΔX1, ΔZ y ΔZ1, y se marcan distancias E y F desde la mesa hasta los ejes B y A respectivamente, con líneas de cota y referencias Pz y r." .

ns1:LecturaZ1 a ns1:Parametro ;
    rdfs:label "Lectura ΔZ1" ;
    ns1:textoExtracto "Se muestran palpados en Y y Z sobre un cilindro (puntos 1–4), las lecturas ΔY1/ΔY2 y ΔZ1/ΔZ2, y la obtención de TDATA3 (Y) y Pz (Z) con cotas y radio R." .

ns1:ObtencionDePzZ a ns1:Parametro ;
    rdfs:label "Obtención de Pz (Z)" ;
    ns1:textoExtracto "Se muestran palpados en Y y Z sobre un cilindro (puntos 1–4), las lecturas ΔY1/ΔY2 y ΔZ1/ΔZ2, y la obtención de TDATA3 (Y) y Pz (Z) con cotas y radio R." .

ns1:ObtencionDeTDATA3Y a ns1:Parametro ;
    rdfs:label "Obtención de TDATA3 (Y)" ;
    ns1:textoExtracto "Se muestran palpados en Y y Z sobre un cilindro (puntos 1–4), las lecturas ΔY1/ΔY2 y ΔZ1/ΔZ2, y la obtención de TDATA3 (Y) y Pz (Z) con cotas y radio R." .

