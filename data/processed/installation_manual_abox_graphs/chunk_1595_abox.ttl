@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Esquema_TDATA2 a ns1:Esquema ;
    rdfs:label "Diagramas para TDATA2 (posiciones de referencia)"@es ;
    ns1:ilustradoEn ns1:Parametro_TDATA2 ;
    ns1:textoExtracto "Pareja de diagramas para TDATA2: posición de referencia con B=0°, C=0° (punto 1) y posición con B=180°, C=0° (punto 3). Se representan los palpados, las lecturas ΔX y la combinación con TDATA5 para calcular TDATA2, con flechas de giro y ejes X-Z."@es .

ns1:Esquema_TDATA5 a ns1:Esquema ;
    rdfs:label "Esquema 'Segundo contacto' para TDATA5"@es ;
    ns1:ilustradoEn ns1:Parametro_TDATA5 ;
    ns1:textoExtracto "Esquema 'Segundo contacto' para TDATA5 con C=180°, palpado en punto 2 y lectura de ΔX. El gráfico indica la obtención de TDATA5 = 0,5·|ΔX| mediante cotas sobre el eje X."@es .

ns1:Esquema_TDATA6_1y2 a ns1:Esquema ;
    rdfs:label "Secuencia 'Primer y segundo contacto' para TDATA6"@es ;
    ns1:ilustradoEn ns1:Parametro_TDATA6 ;
    ns1:textoExtracto "Secuencia 'Primer y segundo contacto': desde X=−R con B=0°, C=0° (punto 1) a B=−90° (punto 2). Se muestran lecturas Xa y la preselección para centrar X=0 en el eje del cilindro. Flechas indican los giros del eje B y los desplazamientos en X."@es .

ns1:Esquema_TDATA6_3y4 a ns1:Esquema ;
    rdfs:label "Secuencia 'Tercer y cuarto contacto' para TDATA6"@es ;
    ns1:ilustradoEn ns1:Parametro_TDATA6 ;
    ns1:textoExtracto "Secuencia 'Tercer y cuarto contacto': desde X=+R con B=0°, C=0° (punto 3) a B=+90° (punto 4). Se representa la lectura Xb y la simetría del procedimiento respecto a la secuencia anterior."@es .

ns1:Parametro_TDATA2 a ns1:Parametro ;
    rdfs:label "TDATA2" ;
    ns1:identificador "TDATA2" ;
    ns1:monitoreaParametro ns1:Componente_CabezalAngular ;
    ns1:textoExtracto "parámetro TDATA2 calculado mediante combinación con TDATA5"@es .

ns1:Parametro_TDATA5 a ns1:Parametro ;
    rdfs:label "TDATA5" ;
    ns1:identificador "TDATA5" ;
    ns1:monitoreaParametro ns1:Componente_CabezalAngular ;
    ns1:textoExtracto "parámetro TDATA5 = 0,5·|ΔX|"@es .

ns1:Parametro_TDATA6 a ns1:Parametro ;
    rdfs:label "TDATA6" ;
    ns1:identificador "TDATA6" ;
    ns1:monitoreaParametro ns1:Componente_CabezalAngular ;
    ns1:textoExtracto "parámetro TDATA6 obtenido mediante lecturas Xa y Xb en secuencias simétricas"@es .

ns1:Componente_CabezalAngular a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal angular"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_TDATA2,
        ns1:Esquema_TDATA5,
        ns1:Esquema_TDATA6_1y2,
        ns1:Esquema_TDATA6_3y4 ;
    ns1:textoExtracto "Cabezal angular (cálculo de parámetros TDATA2, TDATA5, TDATA6 mediante palpados en puntos de referencia y giros en ejes B/C)"@es .

