@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioModoAutomaticoDMC a ns1:InterfazUsuario ;
    rdfs:label "Pantalla del modo automático con vista 'DMC'"@es ;
    ns1:ilustra ns1:AvancePorDiente_985154dc89,
        ns1:OverrideDelDMC_d0a3c0a496,
        ns1:PotenciaConsumida,
        ns1:PotenciaObjetivo_0ee89a5cef,
        ns1:TiempoAhorrado ;
    ns1:textoExtracto "Pantalla del modo automático con vista 'DMC': barras e indicadores para estado ON/OFF, override del DMC (con límites), avance por diente (FZ), potencia consumida, potencia objetivo y potencia en vacío; además de 'Saved Time' y override final." .

ns1:InterfazUsuarioOpcionesDMC a ns1:InterfazUsuario ;
    rdfs:label "Menú vertical de softkeys 'Opciones DMC'"@es ;
    ns1:textoExtracto "Menú vertical de softkeys 'Opciones DMC' con tres acciones: repetir fase de aprendizaje, desactivar DMC y re-activar DMC." .

ns1:AvancePorDiente_985154dc89 a ns1:Parametro ;
    rdfs:label "Avance por diente"@es ;
    ns1:textoExtracto "avance por diente (FZ)" .

ns1:OverrideDelDMC_d0a3c0a496 a ns1:Parametro ;
    rdfs:label "Override del DMC"@es ;
    ns1:textoExtracto "override del DMC (con límites)" .

ns1:PotenciaConsumida a ns1:Parametro ;
    rdfs:label "Potencia consumida"@es ;
    ns1:textoExtracto "potencia consumida" .

ns1:PotenciaObjetivo_0ee89a5cef a ns1:Parametro ;
    rdfs:label "Potencia objetivo"@es ;
    ns1:textoExtracto "potencia objetivo" .

ns1:TiempoAhorrado a ns1:Parametro ;
    rdfs:label "Tiempo ahorrado"@es ;
    ns1:textoExtracto "Saved Time" .

