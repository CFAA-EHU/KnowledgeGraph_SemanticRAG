@prefix ns1: <https://vocab.cfaa.eus/broaching/> .

ns1:DiagramaMesaRotativaAB1596 a ns1:Esquema ;
    ns1:textoExtracto "Conjunto de diagramas de una mesa rotativa AB (TYPE=9) que definen sentidos positivos y parámetros TDATA2, TDATA3, TDATA4 y TDATA5. Se indican ejes A y B, la intersección de ejes en X-Y-Z y la distancia entre ejes con flechas, signos (+) y bloques etiquetados." ;
    ns1:tieneComponente ns1:BloqueEtiquetado_1596,
        ns1:DistanciaEjes_1596,
        ns1:EjeA_1596,
        ns1:EjeB_1596,
        ns1:FlechaSentidoPositivo_1596,
        ns1:InterseccionEjesXYZ_1596,
        ns1:SignoPositivo_1596 .

ns1:DiagramaSolucionGeometrica1596 a ns1:Esquema ;
    ns1:textoExtracto "Diagrama de solución geométrica: construcción de XM = 0,5·(Xb+Xa) y cálculo TDATA6 = 2·XM − TDATA1, con esquema Y-Z, marca de ángulo 45° y flechas de referencia; se destaca la relación entre la media de lecturas laterales y el descentramiento respecto a TDATA1." ;
    ns1:tieneComponente ns1:EjeYZ_1596,
        ns1:FlechaReferencia1_1596,
        ns1:FlechaReferencia2_1596,
        ns1:MarcaAngulo45_1596 .

ns1:EsquemaPosicionesEjeA1596 a ns1:Esquema ;
    ns1:textoExtracto "Esquema de dos posiciones con centro común del eje A (A=−90°, B=−90° y A=+90°, B=−90°)." ;
    ns1:tieneComponente ns1:PosicionEjeAmas90_1596,
        ns1:PosicionEjeAmenos90_1596 .

ns1:BloqueEtiquetado_1596 a ns1:Figura ;
    ns1:textoExtracto "bloques etiquetados" .

ns1:DistanciaEjes_1596 a ns1:Figura ;
    ns1:textoExtracto "la distancia entre ejes" .

ns1:EjeA_1596 a ns1:Figura ;
    ns1:identificador "A" ;
    ns1:textoExtracto "ejes A" .

ns1:EjeB_1596 a ns1:Figura ;
    ns1:identificador "B" ;
    ns1:textoExtracto "ejes B" .

ns1:EjeYZ_1596 a ns1:Figura ;
    ns1:textoExtracto "esquema Y-Z" .

ns1:FlechaReferencia1_1596 a ns1:Figura ;
    ns1:textoExtracto "flechas de referencia" .

ns1:FlechaReferencia2_1596 a ns1:Figura ;
    ns1:textoExtracto "flechas de referencia" .

ns1:FlechaSentidoPositivo_1596 a ns1:Figura ;
    ns1:textoExtracto "flechas, signos (+)" .

ns1:InterseccionEjesXYZ_1596 a ns1:Figura ;
    ns1:textoExtracto "la intersección de ejes en X-Y-Z" .

ns1:MarcaAngulo45_1596 a ns1:Figura ;
    ns1:textoExtracto "marca de ángulo 45°" .

ns1:PosicionEjeAmas90_1596 a ns1:Figura ;
    ns1:textoExtracto "A=+90°, B=−90°" .

ns1:PosicionEjeAmenos90_1596 a ns1:Figura ;
    ns1:textoExtracto "A=−90°, B=−90°" .

ns1:SignoPositivo_1596 a ns1:Figura ;
