@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AdvertenciaDeLicenciaDuranteLaDeteccionDeModulos a ns1:AvisoSeguridad ;
    rdfs:label "Advertencia de licencia durante la detección de módulos" ;
    ns1:textoExtracto "(2) advertencia de licencia durante la detección de módulos, indicada como ignorables con la licencia 'Básica'." .

ns1:AvisoSeguridad_fdde2a1c8c a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de error de licencia" ;
    ns1:textoExtracto "Dos cuadros de diálogo de error/licencia: (1) aviso de 'No license found' al arrancar, con botón 'Browse' para seleccionar la unidad USB del dongle;" .

ns1:ComponenteElectrico_74620bacd0 a ns1:ComponenteElectrico ;
    rdfs:label "dongle" ;
    ns1:textoExtracto "aviso de 'No license found' al arrancar, con botón 'Browse' para seleccionar la unidad USB del dongle;" .

ns1:EscaneoOnlineDelBus a ns1:TareaMantenimiento ;
    rdfs:label "Escaneo online del bus" ;
    ns1:textoExtracto "Secuencia de capturas para el escaneo online del bus: selección del adaptador Ethernet, comando contextual 'Scan configuration' sobre el máster que descubre cabeceras, y pestaña 'MDP modules' con acción 'Upload detected Module Ident list'. Flechas azules indican el flujo de pasos; la vista de árbol muestra nodos esclavos y módulos hallados." .

ns1:InterfazUsuarioKPAEtherCATStudio a ns1:InterfazUsuario ;
    rdfs:label "KPA EtherCAT Studio" ;
    ns1:textoExtracto "Captura de la interfaz de 'KPA EtherCAT Studio' con la vista principal de topología a la izquierda, panel de mensajes/ayuda a la derecha y bandeja del sistema mostrando el servicio 'Master (Win64)'. Se señalan zonas A, B, C para topología, ayuda y mensajes, respectivamente; incluye iconos de atajo a 'Master (Win64)', 'Studio' y utilidades de licencia." .

