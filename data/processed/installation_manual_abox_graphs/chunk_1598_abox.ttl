@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuario_AnalisisMecanizado a ns1:InterfazUsuario ;
    rdfs:label "Pantalla Análisis de Mecanizado (DMC)"@es ;
    ns1:ilustradoEn ns1:Pagina_734 ;
    ns1:monitoreaParametro ns1:Parametro_AvancePorDiente_FZ,
        ns1:Parametro_OverrideDMC,
        ns1:Parametro_PotenciaConsumida,
        ns1:Parametro_PotenciaObjetivo,
        ns1:Parametro_PotenciaVacio,
        ns1:Parametro_TiempoAhorrado ;
    ns1:textoExtracto "Pantalla 'Modo automático. Estado y progreso del DMC' con datos ejemplo: límites de override, FZ mínimo/máximo y valores activos; potencias 'Power', 'Power Set Point' y 'No Load Power', y tiempo ahorrado."@es .

ns1:InterfazUsuario_DMC_ModoAutomatico a ns1:InterfazUsuario ;
    rdfs:label "Pantalla DMC - Modo automático (vista DMC)"@es ;
    ns1:ilustradoEn ns1:Pagina_731 ;
    ns1:monitoreaParametro ns1:Parametro_AvancePorDiente_FZ,
        ns1:Parametro_OverrideDMC,
        ns1:Parametro_PotenciaConsumida,
        ns1:Parametro_PotenciaObjetivo,
        ns1:Parametro_PotenciaVacio,
        ns1:Parametro_TiempoAhorrado ;
    ns1:textoExtracto "Pantalla del modo automático con vista 'DMC': barras e indicadores para estado ON/OFF, override del DMC (con límites), avance por diente (FZ), potencia consumida, potencia objetivo y potencia en vacío; además de 'Saved Time' y override final."@es .

ns1:InterfazUsuario_OpcionesDMC a ns1:InterfazUsuario ;
    rdfs:label "Menú Opciones DMC (softkeys)"@es ;
    ns1:controla ns1:ModoOperacion_DMC_ModoAutomatico ;
    ns1:ilustradoEn ns1:Pagina_734 ;
    ns1:textoExtracto "Menú vertical de softkeys 'Opciones DMC' con tres acciones: repetir fase de aprendizaje, desactivar DMC y re-activar DMC."@es .

ns1:InterfazUsuario_OsciloscopioEtherCAT a ns1:InterfazUsuario ;
    rdfs:label "Captura de osciloscopio (Bus EtherCAT)"@es ;
    ns1:ilustradoEn ns1:Pagina_741 ;
    ns1:monitoreaParametro ns1:Parametro_AvancePorDiente_FZ,
        ns1:Parametro_EntradaSalidaPieza,
        ns1:Parametro_OverrideDMC ;
    ns1:textoExtracto "Captura del osciloscopio con trazas de override, detección de G00, entradas/salidas a pieza y tramos a avance mínimo/máximo por diente."@es .

ns1:Pagina_730 a ns1:Pagina ;
    ns1:identificador "730" ;
    ns1:textoExtracto "Incluye lista de herramientas, iconos, campos editables y un panel contextual de parámetros, útil para que el DMC limite el avance por diente."@es .

ns1:ModoOperacion_DMC_ModoAutomatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático (DMC)"@es ;
    ns1:documentadoEn ns1:Pagina_731,
        ns1:Pagina_734 ;
    ns1:textoExtracto "Modo automático. Estado y progreso del DMC"@es .

ns1:Pagina_741 a ns1:Pagina ;
    ns1:identificador "741" ;
    ns1:textoExtracto "Captura del osciloscopio con trazas de override, detección de G00, entradas/salidas a pieza [...] Se señalan hitos A–F (control del override, vacío, entrada, vacío con override máximo, mecanizado a FZ máx. y a FZ mín.)."@es .

ns1:Parametro_EntradaSalidaPieza a ns1:Parametro ;
    rdfs:label "Entradas/salidas a pieza (G00)"@es ;
    ns1:textoExtracto "detección de G00, entradas/salidas a pieza"@es .

ns1:Pagina_731 a ns1:Pagina ;
    ns1:identificador "731" ;
    ns1:textoExtracto "Pantalla del modo automático con vista 'DMC' [...] Se señalan zonas A–J que describen cada elemento de la UI."@es .

ns1:Parametro_PotenciaConsumida a ns1:Parametro ;
    rdfs:label "Potencia consumida (Power)"@es ;
    ns1:textoExtracto "potencia consumida ('Power')"@es .

ns1:Parametro_PotenciaObjetivo a ns1:Parametro ;
    rdfs:label "Potencia objetivo (Power Set Point)"@es ;
    ns1:textoExtracto "potencia objetivo ('Power Set Point')"@es .

ns1:Parametro_PotenciaVacio a ns1:Parametro ;
    rdfs:label "Potencia en vacío (No Load Power)"@es ;
    ns1:textoExtracto "potencia en vacío ('No Load Power')"@es .

ns1:Parametro_TiempoAhorrado a ns1:Parametro ;
    rdfs:label "Tiempo ahorrado (Saved Time)"@es ;
    ns1:textoExtracto "'Saved Time'"@es .

ns1:Pagina_734 a ns1:Pagina ;
    ns1:identificador "734" ;
    ns1:textoExtracto "Menú vertical de softkeys 'Opciones DMC' [...] Pantalla 'Modo automático. Estado y progreso del DMC' con datos ejemplo [...] Marcadores A–H identifican cada métrica visualizada."@es .

ns1:Parametro_AvancePorDiente_FZ a ns1:Parametro ;
    rdfs:label "Avance por diente (FZ)"@es ;
    ns1:textoExtracto "avance por diente (FZ), [...] FZ mínimo/máximo y valores activos"@es .

ns1:Parametro_OverrideDMC a ns1:Parametro ;
    rdfs:label "Override DMC (con límites)"@es ;
    ns1:textoExtracto "override del DMC (con límites)"@es .

