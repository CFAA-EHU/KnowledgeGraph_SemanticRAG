@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaEtherCAT a ns1:Sistema ;
    rdfs:label "Sistema EtherCAT" ;
    ns1:documentadoEn ns1:InterfazUsuarioConfiguracion ;
    ns1:textoExtracto "Los bloques codifican tipo de recurso por color (DI/DO, registros, analógicas)." ;
    ns1:tieneComponente ns1:EntradaAnalogica,
        ns1:EntradaDigital,
        ns1:SalidaAnalogica,
        ns1:SalidaDigital .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "mapeos a/desde registros PLC" .

ns1:EntradaAnalogica a ns1:ComponenteElectrico ;
    rdfs:label "Entrada Analógica" ;
    ns1:textoExtracto "verde/amarillo (AI/AO Fagor)" .

ns1:EntradaDigital a ns1:ComponenteElectrico ;
    rdfs:label "Entrada Digital" ;
    ns1:textoExtracto "azul (entradas digitales)" .

ns1:InterfazUsuarioConfiguracion a ns1:InterfazUsuario ;
    rdfs:label "Barra de configuración por defecto" ;
    ns1:textoExtracto "barra de configuración por defecto para mapeo (fichas Digital Input/Output, Register Input/Output y Overlapped con campos 'Starts/Offset/Visible')" .

ns1:SalidaAnalogica a ns1:ComponenteElectrico ;
    rdfs:label "Salida Analógica" ;
    ns1:textoExtracto "verde/amarillo (AI/AO Fagor)" .

ns1:SalidaDigital a ns1:ComponenteElectrico ;
    rdfs:label "Salida Digital" ;
    ns1:textoExtracto "morado (salidas digitales)" .

