@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_a4800dbf80 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de solapamiento" ;
    ns1:textoExtracto "\"Caso 'Overlapped = No': al duplicar numeración, el programa muestra un diálogo de error sobre el bloque implicado; se identifica la entrada I33 con icono de advertencia, impidiendo el solapamiento.\""@es .

ns1:AvisoSeguridad_ca90c150da a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de reordenación" ;
    ns1:textoExtracto "\"Demostración 'Overlapped = Right': al asignar un número ya existente, el mapeador reordena automáticamente los recursos posteriores (numeración superior), respetando los anteriores. La captura incluye bloques desplazados y avisos gráficos que señalan el solapamiento.\""@es .

ns1:InterfazUsuarioPropiedadesEntradasAnalogicas a ns1:InterfazUsuario ;
    rdfs:label "Propiedades de Entradas analógicas Fagor (IB IL AI 4 - U-PAC)"@es ;
    ns1:textoExtracto "\"Propiedades de 'Entradas analógicas Fagor (IB IL AI 4 - U-PAC)': selección de primera entrada, rango de medición por canal y frecuencia de muestreo; interfaz con listas desplegables por canal.\""@es .

ns1:InterfazUsuarioPropiedadesSalidasAnalogicas a ns1:InterfazUsuario ;
    rdfs:label "Propiedades de Salidas analógicas Fagor (IB IL AO 2 - U-PAC)"@es ;
    ns1:textoExtracto "\"Propiedades de 'Salidas analógicas Fagor (IB IL AO 2 - U-PAC)': definición de la primera salida y del rango de cada canal; panel con campos por salida y tipos de rango.\""@es .

