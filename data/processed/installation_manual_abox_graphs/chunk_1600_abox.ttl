@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_a3b585b60f a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "HMI del CNC" ;
    ns1:tieneComponente ns1:ERROR24499EtherCATErrorInSlaveMoreInformationInDiagnostic .

ns1:DiaologConfiguracionConexion a ns1:Pagina ;
    rdfs:label "Diálogo Connections → FagorCNCTCP → Edit" ;
    ns1:textoExtracto "Diálogo 'Connections → FagorCNCTCP → Edit' del OpenPCS para configurar conexión, con campos de nombre y parámetros." .

ns1:TablaSignificadosPLCTYPE a ns1:Tabla ;
    rdfs:label "Tabla de significados para PLCTYPE" ;
    ns1:ilustradoEn ns1:InterfazParametrizacionPLC ;
    ns1:textoExtracto "tabla de significados para PLCTYPE (IEC/Fagor/IEC+Fagor)" .

ns1:ERROR24499EtherCATErrorInSlaveMoreInformationInDiagnostic a ns1:Alarma ;
    rdfs:label "ERROR 24499 – EtherCAT: Error in slave. More information in diagnostic" ;
    ns1:textoExtracto "\"ERROR 24499 – EtherCAT: Error in slave. More information in diagnostic\" en la HMI del CNC, con barra roja, código y botones de navegación." .

ns1:InterfazParametrizacionPLC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de parametrización del PLC remoto" ;
    ns1:textoExtracto "Captura del interfaz de parametrización del PLC remoto: tabla de significados para PLCTYPE (IEC/Fagor/IEC+Fagor) y efectos RUN/STOP/PLCREADY, junto a panel de opciones del CNC (IEC-61131) y botones aplicados." .

