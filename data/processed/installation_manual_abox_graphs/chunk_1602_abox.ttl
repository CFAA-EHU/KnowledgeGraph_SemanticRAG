@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BloqueAfectado a ns1:ComponenteElectrico ;
    rdfs:label "Bloque afectado" ;
    ns1:textoExtracto "Se observan campos editables y previsualización del bloque afectado."@es .

ns1:EntradasAnalogicas a ns1:ComponenteElectrico ;
    rdfs:label "Entradas analógicas Fagor (IB IL AI 4 - U-PAC)" ;
    ns1:textoExtracto "(Elemento 1) Propiedades de 'Entradas analógicas Fagor (IB IL AI 4 - U-PAC)': selección de primera entrada, rango de medición por canal y frecuencia de muestreo; interfaz con listas desplegables por canal."@es ;
    ns1:tieneComponente ns1:EntradaI33 .

ns1:ExportRouterFile a ns1:AccionProhibida ;
    rdfs:label "Export router file" ;
    ns1:ejecutadoPor ns1:Programa ;
    ns1:textoExtracto "Tres acciones ilustradas en capturas de la vista en bloques: (a) 'Export router file' para generar el XML de rutado, (b) 'Generate project' para guardar proyecto *.fem, (c) renombrar y copiar 'resourceRouterConf.xml' a ../Mtb/Data del CNC."@es .

ns1:GenerateProject a ns1:AccionProhibida ;
    rdfs:label "Generate project" ;
    ns1:ejecutadoPor ns1:Programa ;
    ns1:textoExtracto "Tres acciones ilustradas en capturas de la vista en bloques: (a) 'Export router file' para generar el XML de rutado, (b) 'Generate project' para guardar proyecto *.fem, (c) renombrar y copiar 'resourceRouterConf.xml' a ../Mtb/Data del CNC."@es .

ns1:Mapeador a ns1:Herramienta ;
    rdfs:label "Mapeador" ;
    ns1:ejecutadoPor ns1:Programa ;
    ns1:textoExtracto "Demostración 'Overlapped = Right': al asignar un número ya existente, el mapeador reordena automáticamente los recursos posteriores (numeración superior), respetando los anteriores."@es .

ns1:SalidasAnalogicas a ns1:ComponenteElectrico ;
    rdfs:label "Salidas analógicas Fagor (IB IL AO 2 - U-PAC)" ;
    ns1:textoExtracto "(Elemento 2) Propiedades de 'Salidas analógicas Fagor (IB IL AO 2 - U-PAC)': definición de la primera salida y del rango de cada canal; panel con campos por salida y tipos de rango."@es .

ns1:EntradaI33 a ns1:Alarma ;
    rdfs:label "Entrada I33" ;
    ns1:identificador "I33" ;
    ns1:textoExtracto "Caso 'Overlapped = No': al duplicar numeración, el programa muestra un diálogo de error sobre el bloque implicado; se identifica la entrada I33 con icono de advertencia, impidiendo el solapamiento."@es .

ns1:Programa a ns1:Sistema ;
    rdfs:label "Programa" ;
    ns1:textoExtracto "Caso 'Overlapped = No': al duplicar numeración, el programa muestra un diálogo de error sobre el bloque implicado; se identifica la entrada I33 con icono de advertencia, impidiendo el solapamiento."@es .

