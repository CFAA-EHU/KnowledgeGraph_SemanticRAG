@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DialogoConnectionsFagorCNCTCPEdit a ns1:InterfazUsuario ;
    rdfs:label "Diálogo 'Connections → FagorCNCTCP → Edit' del OpenPCS para configurar conexión, con campos de nombre y parámetros. Se destaca el acceso a 'Settings'" ;
    ns1:textoExtracto "OPENPCS REMOTO | Título: — --- (Elemento 1) Diálogo 'Connections → FagorCNCTCP → Edit' del OpenPCS para configurar conexión, con campos de nombre y parámetros. Se destaca el acceso a 'Settings'" ;
    ns1:tieneComponente ns1:DialogoSettings .

ns1:DialogoSettings a ns1:InterfazUsuario ;
    rdfs:label "Diálogo 'Settings' de la conexión mostrando edición de la dirección IP (sustitución de 127.0.0.1 por la IP del CNC); campos de host/puerto y botones 'OK/Cancel'" ;
    ns1:textoExtracto "OPENPCS REMOTO | Título: — --- (Elemento 2) Diálogo 'Settings' de la conexión mostrando edición de la dirección IP (sustitución de 127.0.0.1 por la IP del CNC); campos de host/puerto y botones 'OK/Cancel'" .

