@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceRapidoParaG0 a ns1:Parametro ;
    rdfs:label "Avance rápido para G0" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "Los tramos en G0 se ejecutan a avance rápido (parámetro G00FEED)." .

ns1:ConmutacionSincronizada a ns1:Parametro ;
    rdfs:label "Conmutación sincronizada" ;
    ns1:identificador "SWTG0FEED" ;
    ns1:textoExtracto "Los tramos en G0 se ejecutan a avance rápido (parámetro G00FEED)." .

ns1:ExcitacionDeFrecuenciasDeLaMaquina a ns1:AccionProhibida ;
    rdfs:label "Excitación de frecuencias de la máquina" ;
    ns1:mitigaRiesgo ns1:FalloCalidadCorte,
        ns1:FalloCalidadPrecision,
        ns1:FalloCalidadSuperficial,
        ns1:FalloPrecisionCorte,
        ns1:FalloPresionHidraulicaBaja,
        ns1:FalloSuperficieCorte ;
    ns1:textoExtracto "Esta opción permite evitar posibles problemas de excitación de frecuencias de la máquina, obteniendo mejor calidad del corte, tanto en precisión como superficial." .

