@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CancelarElPWMTrasM30OReset a ns1:Parametro ;
    rdfs:label "Cancelar el PWM tras M30 o reset" ;
    ns1:identificador "MPG.PWMCANCEL" ;
    ns1:textoExtracto "PWMCANCEL Cancelar el PWM tras M30 o reset. Valores posibles: Sí / No." .

ns1:NumeroDeSalidasLocales a ns1:Parametro ;
    rdfs:label "Número de salidas locales" ;
    ns1:identificador "NLOCOUT" ;
    ns1:textoExtracto "Para ello será necesario parametrizar el parámetro NLOCOUT con valor 8." .

ns1:SalidaDigitalLocalAsociadaAlPWM a ns1:Parametro ;
    rdfs:label "Salida digital local asociada al PWM" ;
    ns1:identificador "MPG.PWMOUTPUT" ;
    ns1:textoExtracto "PWMOUTPUT Salida digital local asociada al PWM. Valores posibles: De 0 a 2." .

