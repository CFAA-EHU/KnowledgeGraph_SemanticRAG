@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ParametroLACC1 a ex:Parametro ;
    rdfs:label "LACC1" ;
    ex:textoExtracto "El CNC ejecuta la aproximación a la chapa con aceleración lineal LACC1 y LACC2"@es .

ex:ParametroLACC2 a ex:Parametro ;
    rdfs:label "LACC2" ;
    ex:textoExtracto "El CNC ejecuta la aproximación a la chapa con aceleración lineal LACC1 y LACC2"@es .

ex:ParametroACEL a ex:Parametro ;
    rdfs:label "ACEL" ;
    ex:textoExtracto "no debería ser muy alta (del orden de un tercio de ACEL y DECEL)"@es .

ex:ParametroDECEL a ex:Parametro ;
    rdfs:label "DECEL" ;
    ex:textoExtracto "no debería ser muy alta (del orden de un tercio de ACEL y DECEL)"@es .