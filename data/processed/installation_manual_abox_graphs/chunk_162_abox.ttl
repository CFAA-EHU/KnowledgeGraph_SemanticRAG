@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_LACC1
    a ex:Parametro ;
    rdfs:label "LACC1" ;
    ex:identificador "LACC1" ;
    ex:textoExtracto "Aceleración del primer tramo. Los parámetros LACC1 y LACC2 fijan los valores de la aceleración cuando ésta es lineal (parámetro SLOPETYPE)." ;
    ex:valor "6000 mm/s²" .

ex:Parametro_LACC2
    a ex:Parametro ;
    rdfs:label "LACC2" ;
    ex:identificador "LACC2" ;
    ex:textoExtracto "Aceleración del segundo tramo. Los parámetros LACC1 y LACC2 fijan los valores de la aceleración cuando ésta es lineal (parámetro SLOPETYPE)." ;
    ex:valor "6000 mm/s²" .

ex:Tabla_ParametrosLeapfrog_162 a ex:Tabla ;
     a ex:Tabla ;
    ex:textoExtracto "| Parámetro. | Significado. | --- | --- | LACC1 LACC2 | Aceleración del primer y segundo tramo. Los parámetros LACC1 y LACC2 fijan los valores de la aceleración cuando ésta es lineal (parámetro SLOPETYPE)." ;
    ex:documentadoEn ex:Pagina_104 ;
    ex:tieneComponente ex:Parametro_LACC1, ex:Parametro_LACC2 .