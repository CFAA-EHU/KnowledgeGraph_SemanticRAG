@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AFeedXn a ns1:Parametro ;
    rdfs:label "Avance real" ;
    ns1:textoExtracto "El CNC gestiona la potencia en función del avance real (variable (V.)A.FEED.xn)." .

ns1:AvanceTeorico a ns1:Parametro ;
    rdfs:label "Avance teórico" ;
    ns1:textoExtracto "El CNC gestiona la potencia en función del avance teórico (variable (V.)A.TFEED.xn)." .

ns1:CancelarElControlDePotenciaConResetM2M30 a ns1:Parametro ;
    rdfs:label "Cancelar el control de potencia con reset/M2/M30" ;
    ns1:identificador "MPG.PWRCTRLCANCEL" ;
    ns1:textoExtracto "PWRCTRLCANCEL Cancelar el control de potencia con reset/M2/M30. Valores posibles: Sí / No. Valor por defecto: No." .

ns1:GestionarLaPotenciaEnFuncionDelAvanceReal a ns1:Parametro ;
    rdfs:label "Gestionar la potencia en función del avance real" ;
    ns1:identificador "MPG.PWRCTRLACT" ;
    ns1:textoExtracto "PWRCTRLACT Gestionar la potencia en función del avance real. Valores posibles: Sí / No. Valor por defecto: No." .

