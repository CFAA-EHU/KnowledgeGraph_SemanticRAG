@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_LACC1 a ex:Parametro ;
    rdfs:label "LACC1" ;
    ex:identificador "LACC1" ;
    ex:textoExtracto "Parámetro LACC1. Aceleración del primer tramo. Los parámetros LACC1 y LACC2 fijan los valores de la aceleración cuando ésta es lineal (parámetro SLOPETYPE)." .

ex:Parametro_LACC2 a ex:Parametro ;
    rdfs:label "LACC2" ;
    ex:identificador "LACC2" ;
    ex:textoExtracto "Parámetro LACC2. Aceleración del segundo tramo. Los parámetros LACC1 y LACC2 fijan los valores de la aceleración cuando ésta es lineal (parámetro SLOPETYPE)." .

ex:Parametro_SLOPETYPE a ex:Parametro ;
    rdfs:label "SLOPETYPE" ;
    ex:textoExtracto "Parámetro SLOPETYPE. Indica el tipo de aceleración lineal." .

ex:Parametro_ACCEL a ex:Parametro ;
    rdfs:label "ACCEL" ;
    ex:textoExtracto "Parámetro ACCEL. Valor de aceleración." .

ex:Parametro_DECEL a ex:Parametro ;
    rdfs:label "DECEL" ;
    ex:textoExtracto "Parámetro DECEL. Valor de deceleración." .

ex:Parametro_ACCJERK a ex:Parametro ;
    rdfs:label "ACCJERK" ;
    ex:textoExtracto "Parámetro ACCJERK. Valor de aceleración en términos de jerk (mm/s³)." .

ex:Parametro_DECJERK a ex:Parametro ;
    rdfs:label "DECJERK" ;
    ex:textoExtracto "Parámetro DECJERK. Valor de deceleración en términos de jerk (mm/s³)." .