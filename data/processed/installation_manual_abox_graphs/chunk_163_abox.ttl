@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:LASERFOLLOW a ex:Parametro ;
    ex:textoExtracto "LASERFOLLOW Compensar la dispersión por el recorrido del láser de CO2. Este parámetro muestra la tabla para definir la compensación." ;
    rdfs:label "LASERFOLLOW" .

ex:TablaCompensacionDispersion a ex:Tabla ;
    ex:textoExtracto "Este parámetro muestra la tabla para definir la compensación." ;
    ex:documentadoEn ex:LASERFOLLOW .

ex:EjeEsclavoCompensacion a ex:ComponenteMecanico ;
    ex:textoExtracto "Para la compensación se utiliza un eje esclavo que sigue a los ejes principales." ;
    ex:compuestoPor ex:EjesPrincipales .

ex:EjesPrincipales a ex:ComponenteMecanico ;
    ex:textoExtracto "Para la compensación se utiliza un eje esclavo que sigue a los ejes principales." .

ex:ProgramaLASERFOLLOW a ex:InterfazUsuario ;
    ex:textoExtracto "La compensación de la dispersión se activa desde el programa mediante la sentencia #FOLLOW" ;
    ex:controla ex:LASERFOLLOW .

ex:PLC_LASERFOLLOW a ex:ComponenteElectrico ;
    ex:textoExtracto "o desde el PLC mediante el comando FOLLOW." ;
    ex:controla ex:LASERFOLLOW .