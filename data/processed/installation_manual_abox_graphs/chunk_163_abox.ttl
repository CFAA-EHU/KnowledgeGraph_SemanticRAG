@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_d7f5c6ae94 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC cancela el control de potencia." .

ns1:EstadoDelControlDePotenciaCuandoEstaActivado a ns1:Parametro ;
    rdfs:label "Estado del control de potencia cuando está activado" ;
    ns1:identificador "Sí" ;
    ns1:textoExtracto "El CNC cancela el control de potencia. Un error en el canal cancela el control de potencia." .

ns1:EstadoDelControlDePotenciaCuandoEstaDesactivado a ns1:Parametro ;
    rdfs:label "Estado del control de potencia cuando está desactivado" ;
    ns1:identificador "No" ;
    ns1:textoExtracto "El CNC no cancela el control de potencia. Un error en el canal no cancela el control de potencia;" .

