@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:LASERFOLLOW a ex:Parametro ;
    ex:textoExtracto "LASERFOLLOW" .

ex:LASERFOLLOWAXIS a ex:Parametro ;
    ex:textoExtracto "LASERFOLLOWAXIS Eje esclavo al que se aplica el FOLLOW." .

ex:LASERFOLLOWOFFSET a ex:Parametro ;
    ex:textoExtracto "LASERFOLLOWOFFSET Offset de los ejes del triedro con respecto al eje esclavo." .

ex:LASERFOLLOW1 a ex:Parametro ;
    ex:textoExtracto "LASERFOLLOW1 Indica como afecta el primer eje del triedro al eje esclavo." .

ex:LASERFOLLOW2 a ex:Parametro ;
    ex:textoExtracto "LASERFOLLOW2 Indica como afecta el segundo eje del triedro al eje esclavo." .

ex:LASERFOLLOW3 a ex:Parametro ;
    ex:textoExtracto "LASERFOLLOW3 Indica como afecta el tercer eje del triedro al eje esclavo." .