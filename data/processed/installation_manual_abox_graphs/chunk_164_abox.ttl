@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ParametrosLaserFollow a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros LASERFOLLOW"@es ;
    ex:textoExtracto """
| LASERFOLLOW |  |
| --- | --- |
| LASERFOLLOWAXIS | Eje esclavo al que se aplica el FOLLOW. |
| LASERFOLLOWOFFSET | Offset de los ejes del triedro con respecto al eje esclavo. |
| LASERFOLLOW1 | Indica como afecta el primer eje del triedro al eje esclavo. |
| LASERFOLLOW2 | Indica como afecta el segundo eje del triedro al eje esclavo. |
| LASERFOLLOW3 | Indica como afecta el tercer eje del triedro al eje esclavo. |
"""@es ;
    ex:tieneComponente ex:Param_LASERFOLLOWAXIS,
                       ex:Param_LASERFOLLOWOFFSET,
                       ex:Param_LASERFOLLOW1,
                       ex:Param_LASERFOLLOW2,
                       ex:Param_LASERFOLLOW3 .

ex:Param_LASERFOLLOWAXIS
    a ex:Parametro ;
    rdfs:label "LASERFOLLOWAXIS"@es ;
    ex:identificador "LASERFOLLOWAXIS" ;
    ex:textoExtracto "Eje esclavo al que se aplica el FOLLOW."@es .

ex:Param_LASERFOLLOWOFFSET
    a ex:Parametro ;
    rdfs:label "LASERFOLLOWOFFSET"@es ;
    ex:identificador "LASERFOLLOWOFFSET" ;
    ex:textoExtracto "Offset de los ejes del triedro con respecto al eje esclavo."@es .

ex:Param_LASERFOLLOW1
    a ex:Parametro ;
    rdfs:label "LASERFOLLOW1"@es ;
    ex:identificador "LASERFOLLOW1" ;
    ex:textoExtracto "Indica como afecta el primer eje del triedro al eje esclavo."@es .

ex:Param_LASERFOLLOW2
    a ex:Parametro ;
    rdfs:label "LASERFOLLOW2"@es ;
    ex:identificador "LASERFOLLOW2" ;
    ex:textoExtracto "Indica como afecta el segundo eje del triedro al eje esclavo."@es .

ex:Param_LASERFOLLOW3
    a ex:Parametro ;
    rdfs:label "LASERFOLLOW3"@es ;
    ex:identificador "LASERFOLLOW3" ;
    ex:textoExtracto "Indica como afecta el tercer eje del triedro al eje esclavo."@es .