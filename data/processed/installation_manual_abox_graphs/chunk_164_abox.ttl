@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaParametrosControlGap a ns1:Tabla ;
    rdfs:label "Tabla de parámetros del control del gap" ;
    ns1:ilustradoEn ns1:AnularElErrorDeGapFueraDelRangoDefinidoPorGAPMINGAPMAX_1c5fcce0d0,
        ns1:CambiarElSignoDeLaSenalDelSensor,
        ns1:DistanciaQueCorrespondeALaSenalAnalogicaLimiteDelSensor,
        ns1:GananciaProporcionalAAplicarEnGAPCTRL,
        ns1:LimiteMinimoDelSensor,
        ns1:NumeroDeEntradaAnalogicaConectadaAlSensor,
        ns1:OffsetAAplicarAlSensor_cca66490cb,
        ns1:RespuestaDinamicaDuranteLaParteFinalDelMovimientoDeAproximacionALaChapa_1d80d116df,
        ns1:TablaParaConfigurarElFiltroDelSensor,
        ns1:TipoDeEntradaAnalogicaConectadaAlSensor,
        ns1:VoltajeQueCorrespondeAlRecorridoLimiteDelSensor ;
    ns1:textoExtracto "GAPCONTROL Tabla de parámetros del control del gap. Este parámetro muestra la tabla para definir el control del gap." .

ns1:AnularElErrorDeGapFueraDelRangoDefinidoPorGAPMINGAPMAX_1c5fcce0d0 a ns1:Parametro ;
    rdfs:label "Anular el error de gap fuera del rango definido por GAPMIN/GAPMAX" ;
    ns1:identificador "GAPERRORCANCEL" ;
    ns1:textoExtracto "GAPERRORCANCEL | Anular el error de gap fuera del rango definido por GAPMIN/GAPMAX." .

ns1:CambiarElSignoDeLaSenalDelSensor a ns1:Parametro ;
    rdfs:label "Cambiar el signo de la señal del sensor" ;
    ns1:identificador "GAPSENSORCH" ;
    ns1:textoExtracto "GAPSENSORCH | Cambiar el signo de la señal del sensor." .

ns1:DistanciaQueCorrespondeALaSenalAnalogicaLimiteDelSensor a ns1:Parametro ;
    rdfs:label "Distancia que corresponde a la señal analógica límite del sensor" ;
    ns1:identificador "GAPDISTLIMIT" ;
    ns1:textoExtracto "GAPDISTLIMIT | Distancia que corresponde a la señal analógica límite del sensor." .

ns1:GananciaProporcionalAAplicarEnGAPCTRL a ns1:Parametro ;
    rdfs:label "Ganancia proporcional a aplicar en GAPCTRL" ;
    ns1:identificador "GAPGAIN" ;
    ns1:textoExtracto "GAPGAIN | Ganancia proporcional a aplicar en GAPCTRL." .

ns1:LimiteMinimoDelSensor a ns1:Parametro ;
    rdfs:label "Límite mínimo del sensor" ;
    ns1:identificador "GAPMIN" ;
    ns1:textoExtracto "GAPMIN | Límite mínimo del sensor." .

ns1:NumeroDeEntradaAnalogicaConectadaAlSensor a ns1:Parametro ;
    rdfs:label "Número de entrada analógica conectada al sensor" ;
    ns1:identificador "GAPANAINID" ;
    ns1:textoExtracto "GAPANAINID | Número de entrada analógica conectada al sensor." .

ns1:OffsetAAplicarAlSensor_cca66490cb a ns1:Parametro ;
    rdfs:label "Offset a aplicar al sensor" ;
    ns1:identificador "GAPSENSOROFFSET" ;
    ns1:textoExtracto "GAPSENSOROFFSET | Offset a aplicar al sensor." .

ns1:RespuestaDinamicaDuranteLaParteFinalDelMovimientoDeAproximacionALaChapa_1d80d116df a ns1:Parametro ;
    rdfs:label "Respuesta dinámica durante la parte final del movimiento de aproximación a la chapa" ;
    ns1:identificador "GAPAPPROACHDYN" ;
    ns1:textoExtracto "GAPAPPROACHDYN | Respuesta dinámica durante la parte final del movimiento de aproximación a la chapa." .

ns1:TablaParaConfigurarElFiltroDelSensor a ns1:Parametro ;
    rdfs:label "Tabla para configurar el filtro del sensor" ;
    ns1:identificador "GAPSENSORFILTER" ;
    ns1:textoExtracto "GAPSENSORFILTER | Tabla para configurar el filtro del sensor." .

ns1:TipoDeEntradaAnalogicaConectadaAlSensor a ns1:Parametro ;
    rdfs:label "Tipo de entrada analógica conectada al sensor" ;
    ns1:identificador "GAPANAINTYPE" ;
    ns1:textoExtracto "GAPANAINTYPE | Tipo de entrada analógica conectada al sensor." .

ns1:VoltajeQueCorrespondeAlRecorridoLimiteDelSensor a ns1:Parametro ;
    rdfs:label "Voltaje que corresponde al recorrido límite del sensor" ;
    ns1:identificador "GAPVOLTLIMIT" ;
    ns1:textoExtracto "GAPVOLTLIMIT | Voltaje que corresponde al recorrido límite del sensor." .

