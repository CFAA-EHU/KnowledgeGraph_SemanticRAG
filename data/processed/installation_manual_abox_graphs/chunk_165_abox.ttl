@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnularElErrorDeGapFueraDelRangoDefinidoPorGAPMINGAPMAX a ns1:Parametro ;
    rdfs:label "Anular el error de gap fuera del rango definido por GAPMIN/GAPMAX" ;
    ns1:textoExtracto "GAPERRORCANCEL | Anular el error de gap fuera del rango definido por GAPMIN/GAPMAX." .

ns1:AnularElErrorDeGapFueraDelRangoDefinidoPorGAPTOL a ns1:Parametro ;
    rdfs:label "Anular el error de gap fuera del rango definido por GAPTOL" ;
    ns1:textoExtracto "GAPTOLCANCEL | Anular el error de gap fuera del rango definido por GAPTOL." .

ns1:BloqueDeMovimientoEnGAPCTRLHaciaCotaDescendente a ns1:Parametro ;
    rdfs:label "Bloque de movimiento en #GAPCTRL hacia cota descendente" ;
    ns1:textoExtracto "GAPTONEG | Bloque de movimiento en #GAPCTRL hacia cota descendente." .

ns1:ComportamientoDelCNCAnteUnaColisionDelSensor a ns1:Parametro ;
    rdfs:label "Comportamiento del CNC ante una colisión del sensor" ;
    ns1:textoExtracto "GAPCOLLISIONMODE | Comportamiento del CNC ante una colisión del sensor." .

ns1:IndicarDondeEstaUbicadaLaSalidaAnalogicaConectadaAlSensor a ns1:Parametro ;
    rdfs:label "Indicar dónde está ubicada la salida analógica conectada al sensor" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.GAPANAINTIME Este parámetro indica dónde está ubicada la salida analógica conectada al sensor. Se recomienda utilizar una entrada del regulador." .

ns1:LimiteMaximoDelSensor a ns1:Parametro ;
    rdfs:label "Límite máximo del sensor" ;
    ns1:textoExtracto "GAPMAX | Límite máximo del sensor." .

ns1:LimiteMinimoDelSensor_9187959d18 a ns1:Parametro ;
    rdfs:label "Límite mínimo del sensor" ;
    ns1:textoExtracto "GAPMIN | Límite mínimo del sensor." .

ns1:MargenDeToleranciaDelError a ns1:Parametro ;
    rdfs:label "Margen de tolerancia del error" ;
    ns1:textoExtracto "GAPTOL | Margen de tolerancia del error." .

ns1:TipoDeEntradaAnalogicaConectadaAlSensor_ee1f534122 a ns1:Parametro ;
    rdfs:label "Tipo de entrada analógica conectada al sensor" ;
    ns1:textoExtracto "GAPANAINTYPE Tipo de entrada analógica conectada al sensor. Valores posibles: Remoto CAN / Regulador / Captación / EtherCAT. Valor por defecto: Regulador." .

