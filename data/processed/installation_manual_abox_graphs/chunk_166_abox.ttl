@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_3ee3b9bc89 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC controla el eje del sensor hasta que alcanza el gap programado (teniendo en cuenta GAPINPOSW)." .

ns1:PosicionInicialDelGap a ns1:Parametro ;
    rdfs:label "Posición inicial del gap" ;
    ns1:identificador "GAPINPOSW" ;
    ns1:textoExtracto "El CNC controla el eje del sensor hasta que alcanza el gap programado (teniendo en cuenta GAPINPOSW)." .

ns1:SistemaControlGap a ns1:Sistema ;
    rdfs:label "Control del gap" ;
    ns1:textoExtracto "El sensor del gap está conectado a la entrada X3 del regulador. El CNC controla el eje del sensor hasta que alcanza el gap programado (teniendo en cuenta GAPINPOSW). Una vez alcanzada esta posición, el regulador controla el gap." ;
    ns1:tieneComponente ns1:Regulador,
        ns1:Sensor_3c881edc44 .

ns1:Regulador a ns1:Sistema ;
    rdfs:label "Regulador" ;
    ns1:textoExtracto "Entrada analógica en un regulador. El sensor del gap está conectado a la entrada X3 del regulador." .

ns1:Sensor_3c881edc44 a ns1:Sensor ;
    rdfs:label "Sensor del gap" ;
    ns1:textoExtracto "El sensor del gap está conectado a la entrada X3 del regulador." .

