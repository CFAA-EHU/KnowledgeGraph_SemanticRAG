@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DireccionLogicaDelReguladorSercos_25ac4f2c3f a ns1:Parametro ;
    rdfs:label "Dirección lógica del regulador Sercos" ;
    ns1:identificador "address" ;
    ns1:textoExtracto "La dirección lógica la establece el conmutador rotativo \"address\"." .

ns1:ModuloSalidaAnalogaCAN a ns1:ComponenteElectrico ;
    rdfs:label "Módulo Salida Analógica CAN" ;
    ns1:textoExtracto "Entrada analógica de los módulos remotos CAN." .

ns1:NumeroDeEntradaAnalogicaConectadaAlSensor a ns1:Parametro ;
    rdfs:label "Número de entrada analógica conectada al sensor" ;
    ns1:identificador "GAPANAINID" ;
    ns1:textoExtracto "GAPANAINID Número de entrada analógica conectada al sensor." .

ns1:ReguladorSercos a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos" ;
    ns1:textoExtracto "Gestión de la consigna analógica desde los reguladores Sercos." .

ns1:SensorGap a ns1:Sensor ;
    rdfs:label "Sensor Gap" ;
    ns1:textoExtracto "El sensor puede estar conectado a una salida analógica de los módulos remotos CAN o de un regulador Sercos." .

ns1:VariableAsociadaAlNumeroDeEntradaAnalogicaConectadaAlSensor a ns1:Parametro ;
    rdfs:label "Variable asociada al número de entrada analógica conectada al sensor" ;
    ns1:identificador "MPG.GAPANAINID" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.GAPANAINID" .

