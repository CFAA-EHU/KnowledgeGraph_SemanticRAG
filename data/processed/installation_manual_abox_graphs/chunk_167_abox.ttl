@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_LASERFOLLOW3
    a ex:Parametro ;
    rdfs:label "LASERFOLLOW3" ;
    ex:identificador "MPG.LASERFOLLOW3" ;
    ex:textoExtracto "LASERFOLLOW3 Efecto del tercer eje del triedro sobre el eje esclavo. Valores posibles: No afecta / Positivo / Negativo. Valor por defecto: No afecta." ;
    ex:valor "No afecta" .

ex:Parametro_LASERFOLLOW1
    a ex:Parametro ;
    rdfs:label "LASERFOLLOW1" ;
    ex:identificador "MPG.LASERFOLLOW1" ;
    ex:textoExtracto "parámetro LASERFOLLOW1" .

ex:Parametro_LASERFOLLOW2
    a ex:Parametro ;
    rdfs:label "LASERFOLLOW2" ;
    ex:identificador "MPG.LASERFOLLOW2" ;
    ex:textoExtracto "parámetro LASERFOLLOW2" .

ex:Parametro_LASERFOLLOWAXIS
    a ex:Parametro ;
    rdfs:label "LASERFOLLOWAXIS" ;
    ex:identificador "V.A.FLWMASTER.xn" ;
    ex:textoExtracto "variable V.A.FLWMASTER.xn del eje esclavo (parámetro LASERFOLLOWAXIS)" .

ex:Parametro_LASERFOLLOWOFFSET
    a ex:Parametro ;
    rdfs:label "LASERFOLLOWOFFSET" ;
    ex:identificador "V.MPG.LASERFOLLOWOFFSET" ;
    ex:textoExtracto "V.MPG.LASERFOLLOWOFFSET" .

ex:Tabla_LASERFOLLOW a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla LASERFOLLOW" ;
    ex:textoExtracto "Parámetro incluido en la tabla LASERFOLLOW." ;
    ex:tieneComponente ex:Parametro_LASERFOLLOW1 ,
                       ex:Parametro_LASERFOLLOW2 ,
                       ex:Parametro_LASERFOLLOW3 .