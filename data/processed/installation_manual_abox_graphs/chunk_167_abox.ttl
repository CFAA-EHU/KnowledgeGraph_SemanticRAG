@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:LASERFOLLOW3 a ex:Parametro ;
    rdfs:label "LASERFOLLOW3" ;
    ex:textoExtracto "LASERFOLLOW3 Efecto del tercer eje del triedro sobre el eje esclavo. Valores posibles: No afecta / Positivo / Negativo. Valor por defecto: No afecta. Variable asociada: (V.)MPG.LASERFOLLOW3 Parámetro incluido en la tabla LASERFOLLOW." ;
    ex:identificador "LASERFOLLOW3" .

ex:MPG.LASERFOLLOW3 a ex:Parametro ;
    rdfs:label "MPG.LASERFOLLOW3" ;
    ex:textoExtracto "(V.)MPG.LASERFOLLOW3 Parámetro incluido en la tabla LASERFOLLOW. Este parámetro indica si el tercer eje (según los parámetros máquina) del canal que gestiona compensación afecta al eje esclavo, y en qué sentido." ;
    ex:identificador "MPG.LASERFOLLOW3" .

ex:V.A.FLWMASTER.xn a ex:Parametro ;
    rdfs:label "V.A.FLWMASTER.xn" ;
    ex:textoExtracto "el CNC actualiza automáticamente la variable V.A.FLWMASTER.xn del eje esclavo (parámetro LASERFOLLOWAXIS) de la siguiente manera. V.A.FLWMASTER.xn = V.MPG.LASERFOLLOWOFFSET + V.MPG.LASERFOLLOW1 * V.A.TPOS.X + V.MPG.LASERFOLLOW2 * V.A.TPOS.Y + V.MPG.LASERFOLLOW3 * V.A.TPOS.Z" ;
    ex:identificador "V.A.FLWMASTER.xn" .

ex:V.MPG.LASERFOLLOWOFFSET a ex:Parametro ;
    rdfs:label "V.MPG.LASERFOLLOWOFFSET" ;
    ex:textoExtracto "V.A.FLWMASTER.xn = V.MPG.LASERFOLLOWOFFSET + V.MPG.LASERFOLLOW1 * V.A.TPOS.X + V.MPG.LASERFOLLOW2 * V.A.TPOS.Y + V.MPG.LASERFOLLOW3 * V.A.TPOS.Z" ;
    ex:identificador "V.MPG.LASERFOLLOWOFFSET" .

ex:V.MPG.LASERFOLLOW1 a ex:Parametro ;
    rdfs:label "V.MPG.LASERFOLLOW1" ;
    ex:textoExtracto "V.A.FLWMASTER.xn = V.MPG.LASERFOLLOWOFFSET + V.MPG.LASERFOLLOW1 * V.A.TPOS.X + V.MPG.LASERFOLLOW2 * V.A.TPOS.Y + V.MPG.LASERFOLLOW3 * V.A.TPOS.Z" ;
    ex:identificador "V.MPG.LASERFOLLOW1" .

ex:V.MPG.LASERFOLLOW2 a ex:Parametro ;
    rdfs:label "V.MPG.LASERFOLLOW2" ;
    ex:textoExtracto "V.A.FLWMASTER.xn = V.MPG.LASERFOLLOWOFFSET + V.MPG.LASERFOLLOW1 * V.A.TPOS.X + V.MPG.LASERFOLLOW2 * V.A.TPOS.Y + V.MPG.LASERFOLLOW3 * V.A.TPOS.Z" ;
    ex:identificador "V.MPG.LASERFOLLOW2" .

ex:V.A.TPOS.X a ex:Parametro ;
    rdfs:label "V.A.TPOS.X" ;
    ex:textoExtracto "V.A.FLWMASTER.xn = V.MPG.LASERFOLLOWOFFSET + V.MPG.LASERFOLLOW1 * V.A.TPOS.X + V.MPG.LASERFOLLOW2 * V.A.TPOS.Y + V.MPG.LASERFOLLOW3 * V.A.TPOS.Z" ;
    ex:identificador "V.A.TPOS.X" .

ex:V.A.TPOS.Y a ex:Parametro ;
    rdfs:label "V.A.TPOS.Y" ;
    ex:textoExtracto "V.A.FLWMASTER.xn = V.MPG.LASERFOLLOWOFFSET + V.MPG.LASERFOLLOW1 * V.A.TPOS.X + V.MPG.LASERFOLLOW2 * V.A.TPOS.Y + V.MPG.LASERFOLLOW3 * V.A.TPOS.Z" ;
    ex:identificador "V.A.TPOS.Y" .

ex:V.A.TPOS.Z a ex:Parametro ;
    rdfs:label "V.A.TPOS.Z" ;
    ex:textoExtracto "V.A.FLWMASTER.xn = V.MPG.LASERFOLLOWOFFSET + V.MPG.LASERFOLLOW1 * V.A.TPOS.X + V.MPG.LASERFOLLOW2 * V.A.TPOS.Y + V.MPG.LASERFOLLOW3 * V.A.TPOS.Z" ;
    ex:identificador "V.A.TPOS.Z" .

ex:LASERFOLLOW a ex:Tabla ;
    ex:textoExtracto "Parámetro incluido en la tabla LASERFOLLOW." ;
    ex:identificador "LASERFOLLOW" ;
    ex:tieneComponente ex:LASERFOLLOW3, ex:MPG.LASERFOLLOW3 .