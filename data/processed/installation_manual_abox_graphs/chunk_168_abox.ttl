@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeNodoDelRegulador a ns1:Parametro ;
    rdfs:label "Número de nodo del regulador" ;
    ns1:textoExtracto "En este caso, este parámetro indica el número de nodo del regulador." .

ns1:RegistroDelPLCQueMapeaLaEntrada a ns1:Parametro ;
    rdfs:label "Registro del PLC que mapea la entrada" ;
    ns1:textoExtracto "En este caso, este parámetro indica el registro del PLC que mapea la entrada" .

