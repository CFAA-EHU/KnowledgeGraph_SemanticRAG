@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:BKUPREG a ex:Parametro ;
    rdfs:label "BKUPREG" ;
    ex:identificador "BKUPREG" ;
    ex:textoExtracto "BKUPREG Número de registros de PLC no volátiles. Valores posibles: De 0 a 20. Valor por defecto: 0. Variable asociada: (V.)MPG.BKUPREG Este parámetro indica el número de registros de PLC que se almacenan en la RAM con batería." ;
    ex:valor "De 0 a 20" .

ex:BKUPCOUN a ex:Parametro ;
    rdfs:label "BKUPCOUN" ;
    ex:identificador "BKUPCOUN" ;
    ex:textoExtracto "BKUPCOUN Número de contadores de PLC no volátiles. Valores posibles: De 0 a 20. Valor por defecto: 0. Variable asociada: (V.)MPG.BKUPCOUN Este parámetro indica el número de contadores de PLC que se almacenan en la RAM con batería." ;
    ex:valor "De 0 a 20" .

ex:MPG.BKUPREG a ex:Parametro ;
    rdfs:label "(V.)MPG.BKUPREG" ;
    ex:identificador "(V.)MPG.BKUPREG" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.BKUPREG Este parámetro indica el número de registros de PLC que se almacenan en la RAM con batería." .

ex:MPG.BKUPCOUN a ex:Parametro ;
    rdfs:label "(V.)MPG.BKUPCOUN" ;
    ex:identificador "(V.)MPG.BKUPCOUN" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.BKUPCOUN Este parámetro indica el número de contadores de PLC que se almacenan en la RAM con batería." .