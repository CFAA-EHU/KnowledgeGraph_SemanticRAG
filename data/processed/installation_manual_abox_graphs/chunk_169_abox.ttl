@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DistanciaQueCorrespondeALaSenalAnalogicaLimiteDelSensor a ns1:Parametro ;
    rdfs:label "Distancia que corresponde a la señal analógica límite del sensor" ;
    ns1:identificador "GAPDISTLIMIT" ;
    ns1:monitoreaParametro ns1:Sensor_a78d652fa2 ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.GAPDISTLIMIT Distancia que corresponde a señal analógica límite del sensor (parámetro GAPVOLTLIMIT)." .

ns1:VoltajeQueCorrespondeAlRecorridoLimiteDelSensor a ns1:Parametro ;
    rdfs:label "Voltaje que corresponde al recorrido límite del sensor" ;
    ns1:identificador "GAPVOLTLIMIT" ;
    ns1:monitoreaParametro ns1:Sensor_a78d652fa2 ;
    ns1:textoExtracto "GAPVOLTLIMIT Voltaje que corresponde al recorrido límite del sensor." .

ns1:Sensor_a78d652fa2 a ns1:Sensor ;
    rdfs:label "Sensor de gap" ;
    ns1:textoExtracto "Entrada analógica de los módulos remotos EtherCAT. En este caso, este parámetro indica el registro del PLC que mapea la entrada analógica conectada al sensor." .

