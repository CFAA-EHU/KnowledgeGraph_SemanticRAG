@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:CambiarElSignoDeLaSenalDelSensor_b2efd366a7 a ns1:Parametro ;
    rdfs:label "Cambiar el signo de la señal del sensor" ;
    ns1:identificador "MPG.GAPSENSORCH" ;
    ns1:textoExtracto "GAPSENSORCH Cambiar el signo de la señal del sensor. Valores posibles: Sí / No. Valor por defecto: No." ;
    ns1:valor "No"^^xsd:string .

ns1:GananciaProporcionalAplicadaALaSenalDelSensorEnPosicion a ns1:Parametro ;
    rdfs:label "Ganancia proporcional aplicada a la señal del sensor, en posición" ;
    ns1:identificador "MPG.GAPGAIN" ;
    ns1:textoExtracto "GAPGAIN Ganancia proporcional a aplicar en GAPCTRL. Valores posibles: De 0.0000 a 100.0000. Valor por defecto: 0.2." ;
    ns1:valor "0.2"^^xsd:string .

ns1:OffsetAAplicarAlSensor a ns1:Parametro ;
    rdfs:label "Offset a aplicar al sensor" ;
    ns1:identificador "MPG.GAPSENSOROFFSET" ;
    ns1:textoExtracto "GAPSENSOROFFSET Offset a aplicar al sensor. Valores posibles: Entre ±10000 mV. Valor por defecto: 0 mV." ;
    ns1:valor "0 mV"^^xsd:string .

