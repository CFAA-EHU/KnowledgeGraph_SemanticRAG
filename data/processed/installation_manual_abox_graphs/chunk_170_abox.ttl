@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SYNCCANCEL a ex:Parametro ;
    rdfs:label "SYNCCANCEL" ;
    ex:identificador "(V.)MPG.SYNCCANCEL" ;
    ex:textoExtracto "SYNCCANCEL Cancelar la sincronización de cabezales. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)MPG.SYNCCANCEL Este parámetro indica si el CNC cancela la sincronización de cabezales tras ejecutar M02, M30 o después de un error o reset." ;
    ex:valor "Sí / No" .

ex:MPG.SYNCCANCEL a ex:Parametro ;
    rdfs:label "MPG.SYNCCANCEL" ;
    ex:textoExtracto "SYNCCANCEL Cancelar la sincronización de cabezales. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)MPG.SYNCCANCEL Este parámetro indica si el CNC cancela la sincronización de cabezales tras ejecutar M02, M30 o después de un error o reset." .