@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SYNCCANCEL
    a ex:Parametro ;
    rdfs:label "SYNCCANCEL" ;
    ex:textoExtracto "SYNCCANCEL Cancelar la sincronización de cabezales. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)MPG.SYNCCANCEL" ;
    ex:identificador "MPG.SYNCCANCEL" ;
    ex:valor "Sí" .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "Este parámetro indica si el CNC cancela la sincronización de cabezales tras ejecutar M02, M30 o después de un error o reset." ;
    ex:monitoreaParametro ex:Parametro_SYNCCANCEL .