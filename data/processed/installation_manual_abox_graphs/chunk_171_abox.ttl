@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_NKEYBD a ex:Parametro ;
    rdfs:label "NKEYBD" ;
    ex:identificador "NKEYBD" ;
    ex:textoExtracto "NKEYBD Número de paneles de jog. Valores posibles: De 1 a 8. Valor por defecto: 1." ;
    ex:valor "De 1 a 8" .

ex:Parametro_KEYBDCH a ex:Parametro ;
    rdfs:label "KEYBDCH" ;
    ex:identificador "KEYBDCH" ;
    ex:textoExtracto "KEYBDCH Lista de paneles de jog del sistema. Este parámetro muestra la tabla para asignar los paneles de jog a los canales." .

ex:Tabla_KEYBDCH a ex:Tabla ;
    ex:identificador "KEYBDCH" ;
    ex:textoExtracto "KEYBDCH |  |\n| --- | --- |\n| KEYBDnCH | Canal al que está asignado el panel de jog. |" .

ex:Parametro_KEYBDnCH a ex:Parametro ;
    rdfs:label "KEYBDnCH" ;
    ex:identificador "KEYBDnCH" ;
    ex:textoExtracto "KEYBDnCH Canal al que está asignado el panel de jog." ;
    ex:valor "Canal activo / CH1 / CH2 / CH3 / CH4" .

ex:Parametro_KEYBDCH_jog a ex:Parametro ;
    rdfs:label "KEYBDCH[jog]" ;
    ex:identificador "KEYBDCH[jog]" ;
    ex:textoExtracto "KEYBDCH[jog] Parámetro incluido en la tabla KEYBDCH. Cada panel de jog podrá estar a asignado a un canal en concreto o siempre al canal activo." .

ex:Sistema_CNC a ex:Sistema ;
    ex:textoExtracto "El CNC numera los paneles de mando según el orden que ocupan dentro del bus CAN (conmutador Address)." .

ex:PanelJog a ex:Componente ;
    ex:textoExtracto "paneles de jog" .