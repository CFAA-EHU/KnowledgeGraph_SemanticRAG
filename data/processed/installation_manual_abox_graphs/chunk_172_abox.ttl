@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MPG.PLCTYPE a ex:Parametro ;
    rdfs:label "PLCTYPE" ;
    ex:identificador "(V.)MPG.PLCTYPE" ;
    ex:textoExtracto "Variable asociada: (V.)MPG.PLCTYPE Este parámetro selecciona el tipo de PLC a utilizar; el propio de Fagor, el estándar IEC-61131 o ambos." ;
    ex:valor "IEC" .

ex:TipoPLC a ex:Parametro ;
    rdfs:label "Tipo de PLC" ;
    ex:textoExtracto "PLCTYPE Tipo de PLC. Valores posibles: IEC / IEC+Fagor / Fagor. Valor por defecto: IEC." .

ex:Tabla109 a ex:Tabla ;
    ex:textoExtracto "La siguiente tabla muestra a quién afecta el arranque (RUN) y la parada (STOP) del PLC en función de este parámetro, así como el estado de la marca PLCREADY." .