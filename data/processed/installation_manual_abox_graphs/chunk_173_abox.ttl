@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sensor_cc151ea312 a ns1:Sensor ;
    rdfs:label "Sensor de filtro" ;
    ns1:textoExtracto "Este parámetro muestra la tabla para configurar el filtro del sensor." .

ns1:TablaParaConfigurarElFiltroDelSensor a ns1:Parametro ;
    rdfs:label "Tabla para configurar el filtro del sensor" ;
    ns1:identificador "GAPSENSORFILTER" ;
    ns1:textoExtracto "GAPSENSORFILTER Tabla para configurar el filtro del sensor. Este parámetro muestra la tabla para configurar el filtro del sensor." .

