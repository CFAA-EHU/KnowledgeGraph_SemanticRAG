@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FrecuenciaDeCorte a ns1:Parametro ;
    rdfs:label "Frecuencia de corte" ;
    ns1:identificador "MPG.FREQUENCY" ;
    ns1:textoExtracto "Variable asociada: FREQUENCY Parámetro incluido en la tabla GAPSENSORFILTER." .

ns1:OrdenDelFiltro a ns1:Parametro ;
    rdfs:label "Orden del filtro" ;
    ns1:identificador "MPG.ORDER" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.ORDER Parámetro incluido en la tabla GAPSENSORFILTER." .

ns1:TipoDeFiltro a ns1:Parametro ;
    rdfs:label "Tipo de filtro" ;
    ns1:identificador "MPG.TYPE" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.TYPE Parámetro incluido en la tabla GAPSENSORFILTER." .

