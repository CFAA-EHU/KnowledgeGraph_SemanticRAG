@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_FINEORG a ex:Parametro ;
    rdfs:label "FINEORG" ;
    ex:identificador "(V.)MPG.FINEORG" ;
    ex:textoExtracto "FINEORG Definición fina de los traslados de origen. Valores posibles: Sí / No. Valor por defecto: No." ;
    ex:valor "No" .

ex:Tabla_TrasladosOrigen a ex:Tabla ;
    rdfs:label "Tabla de traslados de orígenes" ;
    ex:textoExtracto "Este parámetro habilita en la tabla de traslados de orígenes la posibilidad de definir cada traslado con un valor grueso (o absoluto) y otro fino (o incremental)." .

ex:Parametro_FINEORG ex:habilitadoPor ex:Tabla_TrasladosOrigen .