@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:NSERCOUNT a ex:Parametro ;
    ex:textoExtracto "NSERCOUNT Número de nodos contadoras Sercos en el bus. Valores posibles: De 0 a 8. Valor por defecto: 0." ;
    ex:valor "De 0 a 8" ;
    ex:identificador "NSERCOUNT" .

ex:SERCOUNTID a ex:Parametro ;
    ex:textoExtracto "SERCOUNTID n Tabla de identificadores de la ruleta asociadas a las contadoras Sercos. Valores posibles: De 1 a 15." ;
    ex:valor "De 1 a 15" ;
    ex:identificador "SERCOUNTID" .

ex:RCS_S a ex:ComponenteElectrico ;
    ex:textoExtracto "módulos RCS-S en el bus" ;
    ex:identificador "RCS-S" .

ex:ConmutadorRotativo a ex:ComponenteElectrico ;
    ex:textoExtracto "conmutador rotativo (número de nodo)" .

ex:AnilloSercos a ex:Sistema ;
    ex:textoExtracto "Aunque en el anillo Sercos puede haber hasta 32 nodos, los módulos RCS-S siempre ocupan posiciones entre la 1 y la 15." .