@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnularElErrorDeGapFueraDelRangoDefinidoPorGAPMINGAPMAX_63f46180e7 a ns1:Parametro ;
    rdfs:label "Anular el error de gap fuera del rango definido por GAPMIN/GAPMAX" ;
    ns1:identificador "MPG.GAPERRORCANCEL" ;
    ns1:textoExtracto "Valores posibles: Sí / No. Valor por defecto: No." ;
    ns1:valor "No" .

ns1:FrecuenciaDeCorte a ns1:Parametro ;
    rdfs:label "Frecuencia de corte" ;
    ns1:identificador "MPG.FREQUENCY" ;
    ns1:textoExtracto "Frecuencia de corte. Valores posibles: De 0 a 500.0000 Hz. Valor por defecto: 30.0000 Hz." ;
    ns1:valor "30.0000 Hz" .

