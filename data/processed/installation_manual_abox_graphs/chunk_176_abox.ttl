@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AnularElErrorDeGapFueraDelRangoDefinidoPorGAPTOL_5610653bdc a ns1:Parametro ;
    rdfs:label "Anular el error de gap fuera del rango definido por GAPTOL" ;
    ns1:identificador "MPG.GAPTOLCANCEL" ;
    ns1:textoExtracto "El parámetro GAPTOLCANCEL establece el comportamiento del CNC cuando el gap supera el margen definido en el parámetro GAPTOL." .

ns1:LimiteMaximoDelSensor_6157c70841 a ns1:Parametro ;
    rdfs:label "Límite máximo del sensor" ;
    ns1:identificador "MPG.GAPMAX" ;
    ns1:textoExtracto "GAPMAX Límite máximo del sensor. Valores posibles: De 0 a 99999.9999 mm / De 0 a 3937.00787 inch. Valor por defecto: 5.0000 mm / 0.19685 inch." .

ns1:LimiteMinimoDelSensor_25864c2756 a ns1:Parametro ;
    rdfs:label "Límite mínimo del sensor" ;
    ns1:identificador "MPG.GAPMIN" ;
    ns1:textoExtracto "GAPMIN Límite mínimo del sensor. Valores posibles: De 0 a 99999.9999 mm / De 0 a 3937.00787 inch. Valor por defecto: 0." .

