@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:GrupoCanal ex:textoExtracto "Grupo al que pertenece el canal. Valores posibles: De 0 a 2. Valor por defecto: 0 (no pertenece a ningún grupo)." ;
    a ex:Parametro ;
    ex:valor "0 a 2" ;
    ex:identificador "(V.)[ch].MPG.GROUPID" .

ex:ModoManual ex:textoExtracto "modos manual o automático" ;
    a ex:ModoOperacion .

ex:ModoAutomatico ex:textoExtracto "modos manual o automático" ;
    a ex:ModoOperacion .

ex:ModoMDI_MDA ex:textoExtracto "modo MDI/MDA" ;
    a ex:ModoOperacion .

ex:ModoEDISIMU ex:textoExtracto "modo EDISIMU" ;
    a ex:ModoOperacion .

ex:TipoCanalCNC ex:textoExtracto "CNC" ;
    a ex:ModoOperacion .

ex:TipoCanalPLC ex:textoExtracto "PLC" ;
    a ex:ModoOperacion .

ex:TipoCanalCNC_PLC ex:textoExtracto "CNC+PLC" ;
    a ex:ModoOperacion .

ex:ParametroCHTYPE ex:textoExtracto "CHTYPE Tipo de canal. Valores posibles: CNC / PLC / CNC+PLC. Valor por defecto: CNC. Variable asociada: (V.)[ch].MPG.CHTYPE" ;
    a ex:Parametro ;
    ex:valor "CNC / PLC / CNC+PLC" ;
    ex:identificador "(V.)[ch].MPG.CHTYPE" .

ex:ParametroHIDDENCH ex:textoExtracto "HIDDENCH Canal oculto. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPG.HIDDENCH" ;
    a ex:Parametro ;
    ex:valor "Sí / No" ;
    ex:identificador "(V.)[ch].MPG.HIDDENCH" .

ex:MarcaRESETIN ex:textoExtracto "resetearlo desde el PLC mediante la marca RESETIN" ;
    a ex:Parametro .