@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BloqueDeMovimientoEnGAPCTRLHaciaCotaDescendente_c290fdf2d9 a ns1:Parametro ;
    rdfs:label "Bloque de movimiento en #GAPCTRL hacia cota descendente" ;
    ns1:identificador "MPG.GAPTONEG" ;
    ns1:textoExtracto "Este parámetro indica si el movimiento hacia abajo del eje Z para alcanzar el gap es en sentido negativo (condiciones normales) o positivo (eje Z invertido)." .

ns1:ComportamientoDelCNCAnteUnaColisionDelSensor_36cdd5a493 a ns1:Parametro ;
    rdfs:label "Comportamiento del CNC ante una colisión del sensor" ;
    ns1:identificador "MPG.GAPCOLLISIONMODE" ;
    ns1:textoExtracto "El sensor para el control del gap puede disponer de una señal de colisión que se conecta al CNC, y que el PLC la debe gestionar a través de la marca GAPCOLLISION." .

ns1:MargenDeToleranciaDelError_aa3a21856c a ns1:Parametro ;
    rdfs:label "Margen de tolerancia del error" ;
    ns1:identificador "MPG.GAPTOL" ;
    ns1:textoExtracto "Este parámetro define una ventana de posicionamiento, sobre el gap programado, para dar por finalizado el bloque de aproximación." .

