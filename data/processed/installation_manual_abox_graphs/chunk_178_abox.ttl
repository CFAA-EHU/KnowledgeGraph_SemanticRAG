@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ControlDelGapInvertido a ns1:Parametro ;
    rdfs:label "Control del gap invertido" ;
    ns1:identificador "GAPSENSORDELAY_NO" ;
    ns1:textoExtracto "El sentido positivo del eje Z es hacia abajo y el negativo hacia arriba (eje Z invertido). El eje se mueve en sentido positivo (hacia abajo) para alcanzar el gap." .

ns1:ControlDelGap_9a1cae3533 a ns1:Parametro ;
    rdfs:label "Control del gap" ;
    ns1:identificador "GAPSENSORDELAY" ;
    ns1:textoExtracto "El sentido positivo del eje Z es hacia arriba y el negativo hacia abajo (condiciones normales). El eje se mueve en sentido negativo (hacia abajo) para alcanzar el gap." .

