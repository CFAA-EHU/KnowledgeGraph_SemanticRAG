@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaConfiguracionEjes a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuración de ejes del canal"@es ;
    ex:textoExtracto "CHAXISNAME n | Índice en el canal. [...] CHAXISNAME 3 | Índice ꞏ3ꞏ."@es ;
    ex:ilustradoEn ex:Manual_Seccion2.4.2 .

ex:Parametro_CHAXISNAME1
    a ex:Parametro ;
    rdfs:label "CHAXISNAME 1"@es ;
    ex:identificador "1" ;
    ex:valor "Índice ꞏ1ꞏ"@es ;
    ex:textoExtracto "CHAXISNAME 1 | Índice ꞏ1ꞏ."@es ;
    ex:documentadoEn ex:TablaConfiguracionEjes .

ex:Parametro_CHAXISNAME2
    a ex:Parametro ;
    rdfs:label "CHAXISNAME 2"@es ;
    ex:identificador "2" ;
    ex:valor "Índice ꞏ2ꞏ"@es ;
    ex:textoExtracto "CHAXISNAME 2 | Índice ꞏ2ꞏ."@es ;
    ex:documentadoEn ex:TablaConfiguracionEjes .

ex:Parametro_CHAXISNAME3
    a ex:Parametro ;
    rdfs:label "CHAXISNAME 3"@es ;
    ex:identificador "3" ;
    ex:valor "Índice ꞏ3ꞏ"@es ;
    ex:textoExtracto "CHAXISNAME 3 | Índice ꞏ3ꞏ."@es ;
    ex:documentadoEn ex:TablaConfiguracionEjes .

ex:SistemaPlanosTrabajo
    a ex:Sistema ;
    rdfs:label "Sistema de planos de trabajo (G17, G18, G19, G20)"@es ;
    ex:textoExtracto "El orden de los ejes y los planos de trabajo (modelo fresadora). [...] Con la función G20 podemos formar cualquier plano de trabajo con los ejes del canal."@es ;
    ex:detalladoEnEsquema ex:Manual_Seccion2.4.2 .

ex:Funcion_G17 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G17"@es ;
    ex:identificador "G17" ;
    ex:textoExtracto "los que seleccionamos con las funciones G17, G18 y G19"@es ;
    ex:monitoreaParametro ex:SistemaPlanosTrabajo .

ex:Funcion_G18 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G18"@es ;
    ex:identificador "G18" ;
    ex:textoExtracto "los que seleccionamos con las funciones G17, G18 y G19"@es ;
    ex:monitoreaParametro ex:SistemaPlanosTrabajo .

ex:Funcion_G19 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G19"@es ;
    ex:identificador "G19" ;
    ex:textoExtracto "los que seleccionamos con las funciones G17, G18 y G19"@es ;
    ex:monitoreaParametro ex:SistemaPlanosTrabajo .

ex:Funcion_G20 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Función G20"@es ;
    ex:identificador "G20" ;
    ex:textoExtracto "Con la función G20 podemos formar cualquier plano de trabajo con los ejes del canal."@es ;
    ex:monitoreaParametro ex:SistemaPlanosTrabajo .