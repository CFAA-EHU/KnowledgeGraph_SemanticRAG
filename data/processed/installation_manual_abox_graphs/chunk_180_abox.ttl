@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla180 a ex:Tabla ;
    ex:textoExtracto """| Plano. | Eje de abscisas. | Eje de ordenadas. | Eje longitudinal. |
| --- | --- | --- | --- |
| G17 | CHAXISNAME 1 | CHAXISNAME 2 | CHAXISNAME 3 |
| G18 | CHAXISNAME 3 | CHAXISNAME 1 | CHAXISNAME 2 |
| G19 | CHAXISNAME 2 | CHAXISNAME 3 | CHAXISNAME 1 |""" .

ex:ParametroGEOCONFIG a ex:Parametro ;
    ex:identificador "GEOCONFIG" ;
    ex:textoExtracto "GEOCONFIG Configuración geométrica de los ejes del canal. Valores posibles: Plano / Triedro. Valor por defecto: Triedro. Variable asociada: (V.)[ch].MPG.GEOCONFIG Sin función en el modelo fresadora. En el modelo torno, este parámetro indica la configuración de ejes de la máquina, triedro o plano." ;
    ex:valor "Triedro" .

ex:ParametroIPLANE a ex:Parametro ;
    ex:textoExtracto "el plano habitual de trabajo será G18 (si se ha configurado así en el parámetro IPLANE)" .

ex:FuncionG17 a ex:ModoOperacion ;
    ex:identificador "G17" ;
    ex:textoExtracto "Con la función G17, G18 y G19" .

ex:FuncionG18 a ex:ModoOperacion ;
    ex:identificador "G18" ;
    ex:textoExtracto "Con la función G17, G18 y G19" .

ex:FuncionG19 a ex:ModoOperacion ;
    ex:identificador "G19" ;
    ex:textoExtracto "Con la función G17, G18 y G19" .

ex:FuncionG20 a ex:ModoOperacion ;
    ex:identificador "G20" ;
    ex:textoExtracto "Con la función G20 podemos formar cualquier plano de trabajo con los ejes del canal." .

ex:ConfiguracionPlano a ex:ModoOperacion ;
    ex:identificador "Plano" ;
    ex:textoExtracto "Configuración de ejes tipo \"plano\"." .

ex:ConfiguracionTriedro a ex:ModoOperacion ;
    ex:identificador "Triedro" ;
    ex:textoExtracto "Configuración de ejes tipo \"triedro\"." .

ex:EjeX a ex:Parametro ;
    ex:identificador "X" ;
    ex:textoExtracto "Y+ X+ X+ Z+ Z+" .

ex:EjeY a ex:Parametro ;
    ex:identificador "Y" ;
    ex:textoExtracto "Y+ X+ X+ Z+ Z+" .

ex:EjeZ a ex:Parametro ;
    ex:identificador "Z" ;
    ex:textoExtracto "Y+ X+ X+ Z+ Z+" .