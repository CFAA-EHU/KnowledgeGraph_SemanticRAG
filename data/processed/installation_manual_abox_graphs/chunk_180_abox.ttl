@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:JerkDeAceleracion a ns1:Parametro ;
    rdfs:label "Jerk de aceleración" ;
    ns1:textoExtracto "ACCJERK Jerk de aceleración y deceleración. Los parámetros ACCJERK y DECJERK definen la pendiente de la aceleración y deceleración." .

ns1:JerkDeDeceleracion a ns1:Parametro ;
    rdfs:label "Jerk de deceleración" ;
    ns1:textoExtracto "DECJERK Jerk de aceleración y deceleración. Los parámetros ACCJERK y DECJERK definen la pendiente de la aceleración y deceleración." .

ns1:Parametro_a7d7fa460e a ns1:Parametro ;
    rdfs:label "Deceleración" ;
    ns1:textoExtracto "DECEL Aceleración y deceleración. Los parámetros ACCEL y DECEL fijan los valores de la aceleración cuando ésta es trapezoidal o seno cuadrado (parámetro SLOPETYPE)." .

ns1:Parametro_fd6bf32cb6 a ns1:Parametro ;
    rdfs:label "Aceleración" ;
    ns1:textoExtracto "ACCEL Aceleración y deceleración. Los parámetros ACCEL y DECEL fijan los valores de la aceleración cuando ésta es trapezoidal o seno cuadrado (parámetro SLOPETYPE)." .

ns1:RespuestaDinamicaDelSaltoDuranteElLeapfrog a ns1:Parametro ;
    rdfs:label "Respuesta dinámica del salto durante el leapfrog" ;
    ns1:identificador "MPG.LEAPDYNOVR" ;
    ns1:textoExtracto "LEAPDYNOVR Respuesta dinámica del salto durante el leapfrog. Valores posibles: De 10 a 100000 %. Valor por defecto: 100 %" .

ns1:TipoDeAceleracionPorDefecto_d4dcf04d23 a ns1:Parametro ;
    rdfs:label "Tipo de aceleración por defecto" ;
    ns1:textoExtracto "SLOPETYPE Tipo de aceleración por defecto; lineal, trapezoidal y seno cuadrado (square sine)." .

