@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ConfiguracionEjesCNC a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de configuración de ejes por plano (G17, G18, G19)"@es ;
    ex:textoExtracto """
| Plano. | Eje de abscisas. | Eje de ordenadas. | Eje longitudinal. |
| --- | --- | --- | --- |
| G17 | CHAXISNAME 1 | CHAXISNAME 2 | CHAXISNAME 3 |
| G18 | CHAXISNAME 3 | CHAXISNAME 1 | CHAXISNAME 2 |
| G19 | CHAXISNAME 2 | CHAXISNAME 3 | CHAXISNAME 1 |
"""@es ;
    ex:documentadoEn ex:Manual_CNC .

ex:Parametro_IPLANE
    a ex:Parametro ;
    rdfs:label "Parámetro máquina IPLANE"@es ;
    ex:textoExtracto "El parámetro máquina IPLANE no se aplica y no se permite cambiar de plano desde el programa pieza."@es ;
    ex:valor "No aplicable (fijo en G18)"@es ;
    ex:documentadoEn ex:Manual_CNC .

ex:ModoOperacion_G17
    a ex:ModoOperacion ;
    rdfs:label "Modo G17 (Plano XY)"@es ;
    ex:identificador "G17" ;
    ex:textoExtracto "G17: CHAXISNAME 1 (abscisas), CHAXISNAME 2 (ordenadas), CHAXISNAME 3 (longitudinal)."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionEjesCNC .

ex:ModoOperacion_G18
    a ex:ModoOperacion ;
    rdfs:label "Modo G18 (Plano ZX)"@es ;
    ex:identificador "G18" ;
    ex:textoExtracto """
G18: CHAXISNAME 3 (abscisas), CHAXISNAME 1 (ordenadas), CHAXISNAME 2 (longitudinal).
El plano de trabajo siempre es G18; el parámetro máquina IPLANE no se aplica.
"""@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionEjesCNC .

ex:ModoOperacion_G19
    a ex:ModoOperacion ;
    rdfs:label "Modo G19 (Plano YZ)"@es ;
    ex:identificador "G19" ;
    ex:textoExtracto "G19: CHAXISNAME 2 (abscisas), CHAXISNAME 3 (ordenadas), CHAXISNAME 1 (longitudinal)."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionEjesCNC .

ex:SistemaEjes_CNC
    a ex:Sistema ;
    rdfs:label "Sistema de ejes del canal CNC (configuración por planos)"@es ;
    ex:textoExtracto """
Configuración de ejes tipo 'plano'. Esta configuración dispone de dos ejes formando el habitual plano de trabajo en torno.
Puede haber más ejes, pero no pueden formar parte del triedro; deberán ser ejes auxiliares, rotativos, etc.
"""@es ;
    ex:detalladoEnEsquema ex:Tabla_ConfiguracionEjesCNC ;
    ex:tieneComponente ex:ModoOperacion_G17, ex:ModoOperacion_G18, ex:ModoOperacion_G19 .