@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PlanoG18 a ex:ModoOperacion ;
    rdfs:label "Plano de trabajo G18" ;
    ex:textoExtracto "El plano de trabajo siempre es G18 y estará formado por los dos primeros ejes definidos en el canal." ;
    ex:textoExtracto "El plano de trabajo siempre es G18; el parámetro máquina IPLANE no se aplica y no se permite cambiar de plano desde el programa pieza." .

ex:EjeX a ex:Componente ;
    rdfs:label "Eje X" ;
    ex:textoExtracto "Si se han definido los ejes X (primer eje del canal) y Z (segundo eje del canal), el plano de trabajo será ZX (eje Z como abscisas y eje X como ordenadas)." .

ex:EjeZ a ex:Componente ;
    rdfs:label "Eje Z" ;
    ex:textoExtracto "Si se han definido los ejes X (primer eje del canal) y Z (segundo eje del canal), el plano de trabajo será ZX (eje Z como abscisas y eje X como ordenadas)." .

ex:PlanoTrabajoZX a ex:ModoOperacion ;
    rdfs:label "Plano de trabajo ZX" ;
    ex:textoExtracto "Si se han definido los ejes X (primer eje del canal) y Z (segundo eje del canal), el plano de trabajo será ZX (eje Z como abscisas y eje X como ordenadas)." ;
    ex:compuestoPor ex:EjeZ, ex:EjeX .