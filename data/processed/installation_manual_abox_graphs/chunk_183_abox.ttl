@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CompensarLaDispersionPorElRecorridoDelLaserDeCO2 a ns1:Parametro ;
    rdfs:label "Compensar la dispersión por el recorrido del láser de CO2" ;
    ns1:textoExtracto "LASERFOLLOW Compensar la dispersión por el recorrido del láser de CO2. Este parámetro muestra la tabla para definir la compensación." .

ns1:FOLLOWPLC a ns1:AccionProhibida ;
    rdfs:label "FOLLOW (PLC)" ;
    ns1:textoExtracto "La compensación se activa desde el programa mediante la sentencia #FOLLOW o desde el PLC mediante el comando FOLLOW." .

ns1:SentenciaFollow a ns1:AccionProhibida ;
    rdfs:label "#FOLLOW" ;
    ns1:textoExtracto "La compensación se activa desde el programa mediante la sentencia #FOLLOW o desde el PLC mediante el comando FOLLOW." .

