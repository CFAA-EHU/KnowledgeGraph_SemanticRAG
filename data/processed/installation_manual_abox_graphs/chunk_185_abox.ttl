@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EfectoDelPrimerEjeDelTriedroSobreElEjeEsclavo a ns1:Parametro ;
    rdfs:label "Efecto del primer eje del triedro sobre el eje esclavo" ;
    ns1:identificador "MPG.LASERFOLLOW1" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.LASERFOLLOW1 Parámetro incluido en la tabla LASERFOLLOW." .

ns1:NombreDelEjeEsclavoParaLaCompensacion a ns1:Parametro ;
    rdfs:label "Nombre del eje esclavo para la compensación" ;
    ns1:identificador "MPG.LASERFOLLOW" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.LASERFOLLOW Parámetro incluido en la tabla LASERFOLLOW." .

ns1:OffsetDelOrigenDelTriedroRespectoDelEjeEsclavo a ns1:Parametro ;
    rdfs:label "Offset del origen del triedro respecto del eje esclavo" ;
    ns1:identificador "MPG.LASERFOLLOWOFFSET" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.LASERFOLLOWOFFSET Parámetro incluido en la tabla LASERFOLLOW." .

