@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EfectoDelSegundoEjeDelTriedroSobreElEjeEsclavo a ns1:Parametro ;
    rdfs:label "Efecto del segundo eje del triedro sobre el eje esclavo" ;
    ns1:identificador "MPG.LASERFOLLOW2" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.LASERFOLLOW2 Parámetro incluido en la tabla LASERFOLLOW. Este parámetro indica si el segundo eje (según los parámetros máquina) del canal que gestiona compensación afecta al eje esclavo, y en qué sentido." .

ns1:EfectoDelTercerEjeDelTriedroSobreElEjeEsclavo a ns1:Parametro ;
    rdfs:label "Efecto del tercer eje del triedro sobre el eje esclavo" ;
    ns1:identificador "MPG.LASERFOLLOW3" ;
    ns1:textoExtracto "Este parámetro indica si el segundo eje (según los parámetros máquina) del canal que gestiona compensación afecta al eje esclavo, y en qué sentido. LASERFOLLOW3 Efecto del tercer eje del triedro sobre el eje esclavo." .

