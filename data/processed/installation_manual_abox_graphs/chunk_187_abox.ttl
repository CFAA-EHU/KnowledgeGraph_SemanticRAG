@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjeEsclavoDeCompensacion a ns1:Parametro ;
    rdfs:label "Eje esclavo de compensación" ;
    ns1:textoExtracto "variable V.A.FLWMASTER.xn del eje esclavo (parámetro LASERFOLLOWAXIS)" .

ns1:TablaLASERFOLLOW a ns1:Tabla ;
    rdfs:label "Tabla LASERFOLLOW" ;
    ns1:ilustra ns1:EfectoDelTercerEjeDelTriedroSobreElEjeEsclavo ;
    ns1:textoExtracto "Parámetro incluido en la tabla LASERFOLLOW." .

ns1:EfectoDelTercerEjeDelTriedroSobreElEjeEsclavo a ns1:Parametro ;
    rdfs:label "Efecto del tercer eje del triedro sobre el eje esclavo" ;
    ns1:identificador "MPG.LASERFOLLOW3" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.LASERFOLLOW3 Parámetro incluido en la tabla LASERFOLLOW." .

