@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CoeficienteDeCompensacionEnX a ns1:Parametro ;
    rdfs:label "Coeficiente de compensación en X" ;
    ns1:identificador "V.MPG.LASERFOLLOW1" ;
    ns1:textoExtracto "Si todos los parámetros LASERFOLLOW1, LASERFOLLOW2 o LASERFOLLOW3 son 0, el OEM debe escribir el valor de la variable V.A.FLWMASTER.xn (por ejemplo, desde el PLC)." .

ns1:CoeficienteDeCompensacionEnY a ns1:Parametro ;
    rdfs:label "Coeficiente de compensación en Y" ;
    ns1:identificador "V.MPG.LASERFOLLOW2" ;
    ns1:textoExtracto "Si todos los parámetros LASERFOLLOW1, LASERFOLLOW2 o LASERFOLLOW3 son 0, el OEM debe escribir el valor de la variable V.A.FLWMASTER.xn (por ejemplo, desde el PLC)." .

ns1:CoeficienteDeCompensacionEnZ a ns1:Parametro ;
    rdfs:label "Coeficiente de compensación en Z" ;
    ns1:identificador "V.MPG.LASERFOLLOW3" ;
    ns1:textoExtracto "Si todos los parámetros LASERFOLLOW1, LASERFOLLOW2 o LASERFOLLOW3 son 0, el OEM debe escribir el valor de la variable V.A.FLWMASTER.xn (por ejemplo, desde el PLC)." .

ns1:CompensacionDeDispersionPorRecorridoDelLaserCO2 a ns1:Parametro ;
    rdfs:label "Compensación de dispersión por recorrido del láser CO2" ;
    ns1:identificador "V.A.FLWMASTER.xn" ;
    ns1:textoExtracto "V.A.FLWMASTER.xn = V.MPG.LASERFOLLOWOFFSET + V.MPG.LASERFOLLOW1 * V.A.TPOS.X + V.MPG.LASERFOLLOW2 * V.A.TPOS.Y + V.MPG.LASERFOLLOW3 * V.A.TPOS.Z" .

ns1:OffsetDeCompensacionDelLaser a ns1:Parametro ;
    rdfs:label "Offset de compensación del láser" ;
    ns1:identificador "V.MPG.LASERFOLLOWOFFSET" ;
    ns1:textoExtracto "V.A.FLWMASTER.xn = V.MPG.LASERFOLLOWOFFSET + V.MPG.LASERFOLLOW1 * V.A.TPOS.X + V.MPG.LASERFOLLOW2 * V.A.TPOS.Y + V.MPG.LASERFOLLOW3 * V.A.TPOS.Z" .

