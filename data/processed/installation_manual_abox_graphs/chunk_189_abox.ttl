@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeContadoresDePLCNoVolatiles a ns1:Parametro ;
    rdfs:label "Número de contadores de PLC no volátiles" ;
    ns1:identificador "MPG.BKUPCOUN" ;
    ns1:textoExtracto "BKUPCOUN Número de contadores de PLC no volátiles. Valores posibles: De 0 a 20. Valor por defecto: 0." .

ns1:NumeroDeRegistrosDePLCNoVolatiles a ns1:Parametro ;
    rdfs:label "Número de registros de PLC no volátiles" ;
    ns1:identificador "MPG.BKUPREG" ;
    ns1:textoExtracto "BKUPREG Número de registros de PLC no volátiles. Valores posibles: De 0 a 20. Valor por defecto: 0." .

