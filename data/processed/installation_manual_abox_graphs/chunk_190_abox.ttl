@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceiteHidraulicoISO46_2bd78f2965 a ns1:Consumible ;
    rdfs:label "Aceite Hidráulico ISO 46" ;
    ns1:textoExtracto "En la tabla de herramientas se puede definir si el desgaste se introduce con valor incremental o absoluto." .

ns1:CriterioDeSignosParaOffsetsYDesgasteDeHerramienta a ns1:Parametro ;
    rdfs:label "Criterio de signos para offsets y desgaste de herramienta" ;
    ns1:identificador "MPG.TOOLOFSG" ;
    ns1:textoExtracto "Este parámetro define el criterio de signos relativo a los offsets y sus desgastes." .

ns1:Herramienta_ff3d7b9ba1 a ns1:Herramienta ;
    rdfs:label "Herramienta de tornear" ;
    ns1:textoExtracto "Las dimensiones de las herramientas de tornear se definen mediante estos offsets;" .

ns1:RevisionDeHerramientasYOffsets a ns1:TareaMantenimiento ;
    rdfs:label "Revisión de dimensiones incorrectas",
        "Revisión de herramientas y offsets" ;
    ns1:solucionaFallo ns1:FalloDimensionesIncorrectas ;
    ns1:textoExtracto "Los offsets se utilizan para definir las dimensiones de la herramienta en cada uno de los ejes." .

ns1:FalloDimensionesIncorrectas a ns1:DiagnosticoFallo ;
    rdfs:label "Dimensiones incorrectas de herramienta" ;
    ns1:textoExtracto "Los offsets se utilizan para definir las dimensiones de la herramienta en cada uno de los ejaes." .

