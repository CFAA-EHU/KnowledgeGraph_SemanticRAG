@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Tabla190 a ex:Tabla ;
    ex:textoExtracto """| HSC |  |
| --- | --- |
| HSCDEFAULTMODE | Modo por defecto al programar #HSC ON. |
| FEEDAVRG | Calcular el promedio del avance. |
| MINCORFEED | Velocidad mínima en las esquinas. |
| CORNER | Ángulo máximo de la esquina para mecanizarla en arista viva. |
| SMOOTHFREQ | Frecuencia de suavizado en la interpolación. |
| HSCFILTFREQ | Frecuencia del filtro (modo CONTERROR). |
| FASTFACTOR | Porcentaje de avance por defecto (modo FAST). |
| FTIMELIM | Diferencia de tiempo admisible en la interpolación del avance (modo FAST). |
| FSMOOTHFREQ | Frecuencia de suavizado en la interpolación (modo FAST). |
| FASTFILTFREQ | Frecuencia del filtro (modo FAST). |
| SURFFILTFREQ | Frecuencia del filtro de ejes (modo SURFACE). |
| FREQRES | Primera frecuencia de resonancia de la máquina. |
| SOFTFREQ | Frecuencia del filtro de trayectoria para perfiles de aceleración lineal. |
| HSCROUND | Valor por defecto del error máximo de la trayectoria en HSC. |
| ORISMOOTH | Suavizado de la orientación de los ejes rotativos trabajando con RTCP.""" .

ex:ParametroHSCDEFAULTMODE a ex:Parametro ;
    rdfs:label "HSCDEFAULTMODE" ;
    ex:textoExtracto "Modo por defecto al programar #HSC ON." .

ex:ParametroFEEDAVRG a ex:Parametro ;
    rdfs:label "FEEDAVRG" ;
    ex:textoExtracto "Calcular el promedio del avance." .

ex:ParametroMINCORFEED a ex:Parametro ;
    rdfs:label "MINCORFEED" ;
    ex:textoExtracto "Velocidad mínima en las esquinas." .

ex:ParametroCORNER a ex:Parametro ;
    rdfs:label "CORNER" ;
    ex:textoExtracto "Ángulo máximo de la esquina para mecanizarla en arista viva." .

ex:ParametroSMOOTHFREQ a ex:Parametro ;
    rdfs:label "SMOOTHFREQ" ;
    ex:textoExtracto "Frecuencia de suavizado en la interpolación." .

ex:ParametroHSCFILTFREQ a ex:Parametro ;
    rdfs:label "HSCFILTFREQ" ;
    ex:textoExtracto "Frecuencia del filtro (modo CONTERROR)." .

ex:ParametroFASTFACTOR a ex:Parametro ;
    rdfs:label "FASTFACTOR" ;
    ex:textoExtracto "Porcentaje de avance por defecto (modo FAST)." .

ex:ParametroFTIMELIM a ex:Parametro ;
    rdfs:label "FTIMELIM" ;
    ex:textoExtracto "Diferencia de tiempo admisible en la interpolación del avance (modo FAST)." .

ex:ParametroFSMOOTHFREQ a ex:Parametro ;
    rdfs:label "FSMOOTHFREQ" ;
    ex:textoExtracto "Frecuencia de suavizado en la interpolación (modo FAST)." .

ex:ParametroFASTFILTFREQ a ex:Parametro ;
    rdfs:label "FASTFILTFREQ" ;
    ex:textoExtracto "Frecuencia del filtro (modo FAST)." .

ex:ParametroSURFFILTFREQ a ex:Parametro ;
    rdfs:label "SURFFILTFREQ" ;
    ex:textoExtracto "Frecuencia del filtro de ejes (modo SURFACE)." .

ex:ParametroFREQRES a ex:Parametro ;
    rdfs:label "FREQRES" ;
    ex:textoExtracto "Primera frecuencia de resonancia de la máquina." .

ex:ParametroSOFTFREQ a ex:Parametro ;
    rdfs:label "SOFTFREQ" ;
    ex:textoExtracto "Frecuencia del filtro de trayectoria para perfiles de aceleración lineal." .

ex:ParametroHSCROUND a ex:Parametro ;
    rdfs:label "HSCROUND" ;
    ex:textoExtracto "Valor por defecto del error máximo de la trayectoria en HSC." .

ex:ParametroORISMOOTH a ex:Parametro ;
    rdfs:label "ORISMOOTH" ;
    ex:textoExtracto "Suavizado de la orientación de los ejes rotativos trabajando con RTCP." .

ex:Tabla190 a ex:Tabla ;
    ex:tieneComponente ex:ParametroHSCDEFAULTMODE, ex:ParametroFEEDAVRG, ex:ParametroMINCORFEED, ex:ParametroCORNER, ex:ParametroSMOOTHFREQ, ex:ParametroHSCFILTFREQ, ex:ParametroFASTFACTOR, ex:ParametroFTIMELIM, ex:ParametroFSMOOTHFREQ, ex:ParametroFASTFILTFREQ, ex:ParametroSURFFILTFREQ, ex:ParametroFREQRES, ex:ParametroSOFTFREQ, ex:ParametroHSCROUND, ex:ParametroORISMOOTH .