@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:HSCDEFAULTMODE a ex:Parametro ;
    ex:identificador "HSCDEFAULTMODE" ;
    ex:textoExtracto "HSCDEFAULTMODE Modo por defecto al programar #HSC ON. Valores posibles: SURFACE / CONTERROR / FAST. Valor por defecto: SURFACE." ;
    ex:valor "SURFACE" .

ex:FEEDAVRG a ex:Parametro ;
    ex:identificador "FEEDAVRG" ;
    ex:textoExtracto "FEEDAVRG Calcular el promedio del avance. Valores posibles: Sí / No. Valor por defecto: Sí." ;
    ex:valor "Sí" .

ex:MINCORFEED a ex:Parametro ;
    ex:identificador "MINCORFEED" ;
    ex:textoExtracto "MINCORFEED Velocidad mínima en las esquinas. Valores posibles: De 0 a 200000.0000 mm/min / de 0 a 7874.01575 inch/min. Valor por defecto: 0." ;
    ex:valor "0" .

ex:CORNER a ex:Parametro ;
    ex:identificador "CORNER" ;
    ex:textoExtracto "CORNER Ángulo máximo de la esquina para mecanizarla en arista viva. Valores posibles: De 0 a 180.0000º. Valor por defecto: 0." ;
    ex:valor "0" .

ex:SMOOTHFREQ a ex:Parametro ;
    ex:identificador "SMOOTHFREQ" ;
    ex:textoExtracto "SMOOTHFREQ Frecuencia de suavizado en la interpolación. Valores posibles: De 0 a 500.0000. Valor por defecto: 0 (no está activa)." ;
    ex:valor "0" .

ex:ModoHSC a ex:ModoOperacion ;
    ex:identificador "HSC" ;
    ex:textoExtracto "Modo por defecto al programar #HSC ON." ;
    ex:tieneComponente ex:HSCDEFAULTMODE, ex:FEEDAVRG, ex:MINCORFEED, ex:CORNER, ex:SMOOTHFREQ .