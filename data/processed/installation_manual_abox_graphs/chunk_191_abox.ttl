@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_HSCDEFAULTMODE
    a ex:Parametro ;
    rdfs:label "HSCDEFAULTMODE" ;
    ex:textoExtracto "HSCDEFAULTMODE Modo por defecto al programar #HSC ON. Valores posibles: SURFACE / CONTERROR / FAST. Valor por defecto: SURFACE. Variable asociada: (V.)[ch].MPG.HSCDEFAULTMODE Modo por defecto para activar el mecanizado HSC." ;
    ex:valor "SURFACE" ;
    ex:identificador "(V.)[ch].MPG.HSCDEFAULTMODE" .

ex:Parametro_FEEDAVRG
    a ex:Parametro ;
    rdfs:label "FEEDAVRG" ;
    ex:textoExtracto "FEEDAVRG Calcular el promedio del avance. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)[ch].MPG.FEEDAVRG Este parámetro habilita el ajuste del avance en función de la velocidad de lectura de bloques y del tamaño de los mismos. Este ajuste evita tener que frenar por un suministro inadecuado de bloques pequeños; aunque como consecuencia de ello la velocidad alcanzada sea menor, el tiempo total de mecanizado mejorará." ;
    ex:valor "Sí" ;
    ex:identificador "(V.)[ch].MPG.FEEDAVRG" .

ex:Parametro_MINCORFEED
    a ex:Parametro ;
    rdfs:label "MINCORFEED" ;
    ex:textoExtracto "MINCORFEED Velocidad mínima en las esquinas. Valores posibles: De 0 a 200000.0000 mm/min / de 0 a 7874.01575 inch/min. Valor por defecto: 0. Variable asociada: (V.)[ch].MPG.MINCORFEED No se recomienda modificar este valor, porque se puede sobrepasar la dinámica de los ejes." ;
    ex:valor "0" ;
    ex:identificador "(V.)[ch].MPG.MINCORFEED" .

ex:Parametro_CORNER
    a ex:Parametro ;
    rdfs:label "CORNER" ;
    ex:textoExtracto "CORNER Ángulo máximo de la esquina para mecanizarla en arista viva. Valores posibles: De 0 a 180.0000º. Valor por defecto: 0. Variable asociada: (V.)[ch].MPG.CORNER Este parámetro indica el ángulo máximo entre dos trayectorias, por debajo del cual se mecaniza en arista viva." ;
    ex:valor "0" ;
    ex:identificador "(V.)[ch].MPG.CORNER" .

ex:Parametro_SMOOTHFREQ
    a ex:Parametro ;
    rdfs:label "SMOOTHFREQ" ;
    ex:textoExtracto "SMOOTHFREQ Frecuencia de suavizado en la interpolación. Valores posibles: De 0 a 500.0000. Valor por defecto: 0 (no está activa). Variable asociada: (V.)[ch].MPG.SMOOTHFREQ Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias." ;
    ex:valor "0" ;
    ex:identificador "(V.)[ch].MPG.SMOOTHFREQ" .

ex:ModoOperacion_HSC
    a ex:ModoOperacion ;
    rdfs:label "Modo HSC (High Speed Cutting)" ;
    ex:textoExtracto "Modo por defecto al programar #HSC ON. [...] Modo por defecto para activar el mecanizado HSC." ;
    ex:tieneFrecuencia ex:Parametro_SMOOTHFREQ ;
    ex:monitoreaParametro ex:Parametro_HSCDEFAULTMODE ;
    ex:monitoreaParametro ex:Parametro_FEEDAVRG ;
    ex:monitoreaParametro ex:Parametro_MINCORFEED ;
    ex:monitoreaParametro ex:Parametro_CORNER .