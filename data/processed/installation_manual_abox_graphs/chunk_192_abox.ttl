@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SMOOTHFREQ
    a ex:Parametro ;
    rdfs:label "Frecuencia de suavizado (SMOOTHFREQ)"@es ;
    ex:identificador "V.[ch].MPG.SMOOTHFREQ" ;
    ex:textoExtracto "Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias. Este parámetro evita acelerar y decelerar a lo largo de una trayectoria, por encima de una determinada frecuencia al generar una velocidad promediada."@es ;
    ex:valor "0"^^xsd:decimal ;
    .

ex:Parametro_HSCFILTFREQ
    a ex:Parametro ;
    rdfs:label "Frecuencia del filtro (HSCFILTFREQ)"@es ;
    ex:identificador "HSCFILTFREQ" ;
    ex:textoExtracto "Frecuencia del filtro (modo CONTERROR)."@es ;
    .

ex:ModoOperacion_HSC
    a ex:ModoOperacion ;
    rdfs:label "Modo HSC (High Speed Cutting)"@es ;
    ex:textoExtracto "modo HSC CONTERROR"@es ;
    .

ex:ModoOperacion_HSC_CONTERROR
    a ex:ModoOperacion ;
    rdfs:label "Modo HSC CONTERROR"@es ;
    ex:textoExtracto "modo HSC CONTERROR"@es ;
    .