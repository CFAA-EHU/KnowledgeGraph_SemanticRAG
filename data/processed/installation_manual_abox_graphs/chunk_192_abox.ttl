@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_HSCFILTFREQ a ex:Parametro ;
    rdfs:label "HSCFILTFREQ" ;
    ex:identificador "HSCFILTFREQ" ;
    ex:textoExtracto "HSCFILTFREQ Frecuencia del filtro (modo CONTERROR). Valores posibles: De 0 a 500.0000. Valor por defecto:"@es ;
    ex:valor "0 a 500.0000" .

ex:Parametro_SLOPETYPE a ex:Parametro ;
    rdfs:label "SLOPETYPE" ;
    ex:identificador "SLOPETYPE" ;
    ex:textoExtracto "parámetro SLOPETYPE"@es .

ex:Parametro_MPG_SMOOTHFREQ a ex:Parametro ;
    rdfs:label "(V.)[ch].MPG.SMOOTHFREQ" ;
    ex:identificador "(V.)[ch].MPG.SMOOTHFREQ" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPG.SMOOTHFREQ Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias."@es .