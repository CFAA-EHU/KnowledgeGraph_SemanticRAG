@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_08b289010a a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC numera los paneles de mando según el orden que ocupan dentro del bus CAN (conmutador Address)." .

ns1:ListaDePanelesDeJogDelSistema a ns1:Parametro ;
    rdfs:label "Lista de paneles de jog del sistema" ;
    ns1:identificador "MPG.KEYBDCH[jog]" ;
    ns1:textoExtracto "KEYBDCH Lista de paneles de jog del sistema. Este parámetro muestra la tabla para asignar los paneles de jog a los canales." .

ns1:NumeroDePanelesDeJog_85aed12498 a ns1:Parametro ;
    rdfs:label "Número de paneles de jog" ;
    ns1:identificador "MPG.NKEYBD" ;
    ns1:textoExtracto "NKEYBD Número de paneles de jog. Valores posibles: De 1 a 8. Valor por defecto: 1." .

