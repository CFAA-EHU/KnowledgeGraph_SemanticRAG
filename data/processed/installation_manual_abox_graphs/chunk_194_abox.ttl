@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:FTIMELIM a ex:Parametro ;
    rdfs:label "FTIMELIM" ;
    ex:textoExtracto "El parámetro FTIMELIM permite limitar el tiempo que emplea el CNC para la interpolación del avance en cada tramo." ;
    ex:valor "0" .

ex:ParametroInterpolacionAvance a ex:Parametro ;
    rdfs:label "Parámetro de interpolación del avance" ;
    ex:textoExtracto "el tiempo que emplea el CNC para la interpolación del avance en cada tramo" .