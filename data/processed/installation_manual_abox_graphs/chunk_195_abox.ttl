@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinicionFinaDeLosTrasladosDeOrigen a ns1:Parametro ;
    rdfs:label "Definición fina de los traslados de origen" ;
    ns1:identificador "MPG.FINEORG" ;
    ns1:textoExtracto "Variable asociada: (V.)MPG.FINEORG Este parámetro habilita en la tabla de traslados de orígenes la posibilidad de definir cada traslado con un valor grueso (o absoluto) y otro fino (o incremental)." .

