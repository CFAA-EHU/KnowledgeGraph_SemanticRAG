@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_FTIMELIM
    a ex:Parametro ;
    rdfs:label "FTIMELIM" ;
    ex:textoExtracto "aumenta el tiempo máximo permitido de ejecución total; por ejemplo, un valor de 200% o 300% permitirá hasta el doble o triple de tiempo de ejecución en el tramo interpolado. En aquellos bloques relativamente grandes, en los que la adaptación del avance suponga un tiempo adicional mayor del especificado en FTIMELIM, el CNC adaptará el avance usando la máxima dinámica, para evitar pérdidas de tiempo innecesarias." ;
    ex:valor "200% / 300%" .

ex:Parametro_FSMOOTHFREQ
    a ex:Parametro ;
    rdfs:label "FSMOOTHFREQ" ;
    ex:identificador "(V.)[ch].MPG.FSMOOTHFREQ" ;
    ex:textoExtracto "Frecuencia de suavizado en la interpolación (modo FAST y SURFACE). Valores posibles: De 0 a 500.0000. Valor por defecto: 20. Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias para los modos HSC FAST y SURFACE. Este parámetro evita acelerar y decelerar a lo largo de una trayectoria, por encima de una determinada frecuencia al generar una velocidad promediada." ;
    ex:valor "20" .

ex:Parametro_FASTFILTFREQ
    a ex:Parametro ;
    rdfs:label "FASTFILTFREQ" ;
    ex:identificador "(V.)[ch].MPG.FASTFILTFREQ" ;
    ex:textoExtracto "Frecuencia del filtro (modo FAST). Valores posibles: De 0 a 500.0000. Valor por defecto: 17. Este parámetro activa un filtro 'paso bajo' automático para todos los ejes del canal durante la ejecución en modo HSC FAST, el cuál permite suavizar la respuesta de los ejes generando una trayectoria más suave. Este filtro tiene el inconveniente de redondear ligeramente las aristas." ;
    ex:valor "17" .

ex:Parametro_SURFFILTFREQ
    a ex:Parametro ;
    rdfs:label "SURFFILTFREQ" ;
    ex:textoExtracto "Frecuencia del filtro de ejes (modo SURFACE). Valores posibles: De 0 a 500.0000 Hz. Valor por defecto: 25 Hz." ;
    ex:valor "25 Hz" .

ex:ModoOperacion_HSC_FAST
    a ex:ModoOperacion ;
    rdfs:label "HSC FAST" ;
    ex:textoExtracto "modo HSC FAST" .

ex:ModoOperacion_HSC_SURFACE
    a ex:ModoOperacion ;
    rdfs:label "HSC SURFACE" ;
    ex:textoExtracto "modo HSC SURFACE" .

ex:Parametro_FSMOOTHFREQ
    ex:monitoreaParametro ex:ModoOperacion_HSC_FAST ;
    ex:monitoreaParametro ex:ModoOperacion_HSC_SURFACE .

ex:Parametro_FASTFILTFREQ
    ex:monitoreaParametro ex:ModoOperacion_HSC_FAST .

ex:Parametro_SURFFILTFREQ
    ex:monitoreaParametro ex:ModoOperacion_HSC_SURFACE .