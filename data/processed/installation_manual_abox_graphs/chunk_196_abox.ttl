@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_DesfaseHSC
    a ex:Parametro ;
    rdfs:label "Parámetro de desfase constante (modo HSC)"@es ;
    ex:textoExtracto "Este parámetro introduce un desfase constante, independiente de las frecuencias."@es ;
    ex:documentadoEn ex:Manual_ModoHSC .

ex:Parametro_SURFFILTFREQ
    a ex:Parametro ;
    rdfs:label "SURFFILTFREQ" ;
    ex:identificador "(V.)[ch].MPG.SURFFILTFREQ" ;
    ex:valor "25" ;
    ex:textoExtracto "Frecuencia del filtro de ejes (modo SURFACE). Valores posibles: De 0 a 500.0000 Hz. Valor por defecto: 25 Hz."@es ;
    ex:documentadoEn ex:Manual_ModoHSC ;
    ex:monitoreaParametro ex:ModoOperacion_HSC_SURFACE .

ex:ModoOperacion_HSC_SURFACE
    a ex:ModoOperacion ;
    rdfs:label "Modo HSC SURFACE"@es ;
    ex:textoExtracto "modo HSC SURFACE"@es .

ex:Parametro_FREQRES
    a ex:Parametro ;
    rdfs:label "FREQRES" ;
    ex:identificador "(V.)[ch].MPG.FREQRES" ;
    ex:valor "0" ;
    ex:textoExtracto "Primera frecuencia de resonancia de la máquina. Valores posibles: De 0 a 500.0000. Valor por defecto: 0."@es ;
    ex:documentadoEn ex:Manual_ModoHSC ;
    ex:monitoreaParametro ex:Maquina_HSC .