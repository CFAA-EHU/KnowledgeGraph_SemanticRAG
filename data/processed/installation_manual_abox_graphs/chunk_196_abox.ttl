@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SURFFILTFREQ a ex:Parametro ;
    rdfs:label "SURFFILTFREQ" ;
    ex:identificador "(V.)[ch].MPG.SURFFILTFREQ" ;
    ex:textoExtracto "Este parámetro introduce un desfase constante, independiente de las frecuencias. SURFFILTFREQ Frecuencia del filtro de ejes (modo SURFACE). Valores posibles: De 0 a 500.0000 Hz. Valor por defecto: 25 Hz. Variable asociada: (V.)[ch].MPG.SURFFILTFREQ Este parámetro activa un filtro automático para todos los ejes del canal durante la ejecución en modo HSC SURFACE, el cuál permite suavizar la respuesta de los ejes generando una trayectoria más suave." ;
    ex:valor "25 Hz" .

ex:FREQRES a ex:Parametro ;
    rdfs:label "FREQRES" ;
    ex:identificador "(V.)[ch].MPG.FREQRES" ;
    ex:textoExtracto "FREQRES Primera frecuencia de resonancia de la máquina. Valores posibles: De 0 a 500.0000. Valor por defecto: 0. Variable asociada: (V.)[ch].MPG.FREQRES Frecuencia de resonancia que" ;
    ex:valor "0" .