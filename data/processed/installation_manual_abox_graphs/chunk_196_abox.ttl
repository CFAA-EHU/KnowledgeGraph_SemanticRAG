@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeNodosContadorasSercosEnElBus a ns1:Parametro ;
    rdfs:label "Número de nodos contadoras Sercos en el bus" ;
    ns1:identificador "NSERCOUNT" ;
    ns1:textoExtracto "NSERCOUNT Número de nodos contadoras Sercos en el bus. Valores posibles: De 0 a 8. Valor por defecto: 0." .

ns1:SistemaSercos a ns1:Sistema ;
    rdfs:label "Sistema Sercos" ;
    ns1:textoExtracto "Aunque en el anillo Sercos puede haber hasta 32 nodos, los módulos RCS-S siempre ocupan posiciones entre la 1 y la 15." ;
    ns1:tieneComponente ns1:ModuloRemotoRCSS_b7dc0aeb35 .

ns1:TablaDeIdentificadoresDeLaRuletaAsociadasALasContadorasSercos a ns1:Parametro ;
    rdfs:label "Tabla de identificadores de la ruleta asociadas a las contadoras Sercos" ;
    ns1:identificador "SERCOUNTID n" ;
    ns1:textoExtracto "SERCOUNTID n Tabla de identificadores de la ruleta asociadas a las contadoras Sercos. Valores posibles: De 1 a 15." .

ns1:ModuloRemotoRCSS_b7dc0aeb35 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo remoto RCS-S" ;
    ns1:textoExtracto "Definir en cada parámetro la dirección (número de nodo) del módulo RCS-S." .

