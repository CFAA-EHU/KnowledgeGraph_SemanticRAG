@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaDeParametrosMaquinaDelCanal a ns1:Parametro ;
    rdfs:label "Tabla de parámetros máquina del canal" ;
    ns1:identificador "CHANNEL n" ;
    ns1:textoExtracto "Este parámetro muestra la tabla de parámetros máquina del canal." .

ns1:TablaParametrosCanal a ns1:Tabla ;
    rdfs:label "Tabla de parámetros del canal" ;
    ns1:textoExtracto "CHANNEL n Tabla de parámetros del canal." .

