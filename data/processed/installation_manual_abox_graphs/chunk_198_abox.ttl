@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:EjeVirtualHerramienta_198 a ex:ModoOperacion ;
    ex:textoExtracto "automático, manual, inspección de herramienta, reposición de ejes, etc." .

ex:EjeVirtualHerramienta_198 a ex:ModoOperacion ;
    ex:textoExtracto "Este parámetro indica si el CNC anula o no el eje virtual de la herramienta tras ejecutar M02/M30 y tras un reset." .

ex:Parametro_VIRTAXCANCEL_198 a ex:Parametro ;
    ex:identificador "VIRTAXCANCEL" ;
    ex:textoExtracto "VIRTAXCANCEL Cancelación automática del eje virtual de la herramienta tras M30 y Reset. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPG.VIRTAXCANCEL Este parámetro indica si el CNC anula o no el eje virtual de la herramienta tras ejecutar M02/M30 y tras un reset." ;
    ex:valor "No" .

ex:Parametro_VIRTAXISNAME_198 a ex:Parametro ;
    ex:identificador "VIRTAXISNAME" ;
    ex:textoExtracto "VIRTAXISNAME Nombre del eje virtual de la herramienta. Valores posibles: Cualquier nombre de eje válido; X, X1ꞏꞏX9, ꞏꞏ , C, C1ꞏꞏC9. Valor por defecto: ninguno. Variable asociada: (V.)[ch].MPG.VIRTAXISNAME Nombre con el que se identifica el eje virtual de la herramienta." ;
    ex:valor "ninguno" .