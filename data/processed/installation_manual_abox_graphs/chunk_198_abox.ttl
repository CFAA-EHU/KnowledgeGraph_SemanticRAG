@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:GrupoAlQuePerteneceElCanal a ns1:Parametro ;
    rdfs:label "Grupo al que pertenece el canal" ;
    ns1:identificador "GROUPID" ;
    ns1:textoExtracto "GROUPID Grupo al que pertenece el canal. Valores posibles: De 0 a 2. Valor por defecto: 0 (no pertenece a ningún grupo)." .

ns1:Parametro_24e86b704c a ns1:Parametro ;
    rdfs:label "Canal oculto" ;
    ns1:identificador "HIDDENCH" ;
    ns1:textoExtracto "HIDDENCH Canal oculto. Valores posibles: Sí / No. Valor por defecto: No." .

ns1:TipoDeCanal a ns1:Parametro ;
    rdfs:label "Tipo de canal" ;
    ns1:identificador "CHTYPE" ;
    ns1:textoExtracto "CHTYPE Tipo de canal. Valores posibles: CNC / PLC / CNC+PLC. Valor por defecto: CNC." .

