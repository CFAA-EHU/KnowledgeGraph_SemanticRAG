@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:KINID a ex:Parametro ;
    rdfs:label "KINID" ;
    ex:identificador "KINID" ;
    ex:textoExtracto "KINID Número de cinemática por defecto. Valores posibles: De 0 a 6 o nada. Valor por defecto: Nada (el CNC no asume ninguna cinemática tras el encendido). Variable asociada: (V.)[ch].MPG.KINID Este parámetro indica el número de cinemática (no tipo) que asume el CNC en el momento de encendido, después de ejecutarse M02, M30 o después de reset; la validación de parámetros máquina no cambia la cinemática activa. Si se define con valor ꞏ0ꞏ, en el encendido el CNC recupera la cinemática que se encontraba activa cuando se apagó. Si se define con valor \"Ninguna\", el CNC no activa ninguna cinemática por defecto. El CNC puede tener definidas hasta 6 cinemáticas distintas. Para seleccionar otra cinemática desde el programa pieza utilizar la sentencia #KIN ID." ;
    ex:valor "De 0 a 6 o nada" .

ex:CSCANCEL a ex:Parametro ;
    rdfs:label "CSCANCEL" ;
    ex:identificador "CSCANCEL" ;
    ex:textoExtracto "CSCANCEL Cancelar el plano inclinado en el arranque. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)[ch].MPG.CSCANCEL Este parámetro indica si en el arranque, el CNC cancela el plano inclinado (#CS/#ACS) que se encontraba activo cuando se apagó. Con valor \"No\", el CNC guarda el resultado final de los CS+ACS programados en un único CS; no mantiene el anidamiento programado." ;
    ex:valor "Sí / No" .

ex:LINKCANCEL a ex:Parametro ;
    rdfs:label "LINKCANCEL" ;
    ex:identificador "LINKCANCEL" ;
    ex:textoExtracto "LINKCANCEL Cancelar el acoplamiento de ejes por defecto. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)[ch].MPG.LINKCANCEL Este parámetro indica si se anulan o no los acoplamientos de ejes activos (#LINK) cuando finaliza el programa pieza, tras una emergencia y tras un reset." ;
    ex:valor "Sí / No" .

ex:MIRRORCANCEL a ex:Parametro ;
    rdfs:label "MIRRORCANCEL" ;
    ex:identificador "MIRRORCANCEL" ;
    ex:textoExtracto "MIRRORCANCEL Cancelar la imagen espejo (G11/G12/G13/G14) tras M30 y reset. Valores posibles: Sí / No." ;
    ex:valor "Sí / No" .