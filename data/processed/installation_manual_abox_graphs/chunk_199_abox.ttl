@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_KINID
    a ex:Parametro ;
    rdfs:label "Número de cinemática por defecto (KINID)" ;
    ex:textoExtracto "KINID Número de cinemática por defecto. Valores posibles: De 0 a 6 o nada. Valor por defecto: Nada (el CNC no asume ninguna cinemática tras el encendido)." ;
    ex:valor "Nada" ;
    ex:identificador "KINID" .

ex:Parametro_CSCANCEL
    a ex:Parametro ;
    rdfs:label "Cancelar el plano inclinado en el arranque (CSCANCEL)" ;
    ex:textoExtracto "CSCANCEL Cancelar el plano inclinado en el arranque. Valores posibles: Sí / No. Valor por defecto: Sí." ;
    ex:valor "Sí" ;
    ex:identificador "CSCANCEL" .

ex:Parametro_LINKCANCEL
    a ex:Parametro ;
    rdfs:label "Cancelar el acoplamiento de ejes por defecto (LINKCANCEL)" ;
    ex:textoExtracto "LINKCANCEL Cancelar el acoplamiento de ejes por defecto. Valores posibles: Sí / No. Valor por defecto: Sí." ;
    ex:valor "Sí" ;
    ex:identificador "LINKCANCEL" .

ex:Parametro_MIRRORCANCEL
    a ex:Parametro ;
    rdfs:label "Cancelar la imagen espejo tras M30 y reset (MIRRORCANCEL)" ;
    ex:textoExtracto "MIRRORCANCEL Cancelar la imagen espejo (G11/G12/G13/G14) tras M30 y reset. Valores posibles: Sí / No." ;
    ex:identificador "MIRRORCANCEL" .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC (control numérico)" ;
    ex:textoExtracto "El CNC asume parámetros por defecto tras encendido, M02, M30 o reset." ;
    ex:tieneComponente ex:Parametro_KINID ;
    ex:tieneComponente ex:Parametro_CSCANCEL ;
    ex:tieneComponente ex:Parametro_LINKCANCEL ;
    ex:tieneComponente ex:Parametro_MIRRORCANCEL .