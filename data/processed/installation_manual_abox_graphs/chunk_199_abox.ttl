@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ListaDeEjesDelCanal a ns1:Parametro ;
    rdfs:label "Lista de ejes del canal" ;
    ns1:identificador "MPG.CHAXISNAME" ;
    ns1:textoExtracto "CHAXISNAME Lista de ejes del canal. Este parámetro muestra la tabla para definir los nombres de los ejes." .

ns1:NumeroDeEjesDelCanal_3c8e905690 a ns1:Parametro ;
    rdfs:label "Número de ejes del canal" ;
    ns1:identificador "MPG.CHNAXIS" ;
    ns1:textoExtracto "CHNAXIS Número de ejes del canal. Valores posibles: De 0 a 28. Valor por defecto: 3." .

