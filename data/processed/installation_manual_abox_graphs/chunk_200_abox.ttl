@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MIRRORCANCEL a ex:Parametro ;
    rdfs:label "MIRRORCANCEL" ;
    ex:identificador "G11/G12/G13/G14" ;
    ex:textoExtracto "Cancelar la imagen espejo (G11/G12/G13/G14) tras M30 y reset. Valores posibles: Sí / No. Valor por defecto: Sí." ;
    ex:valor "Sí" .

ex:SLOPETYPE a ex:Parametro ;
    rdfs:label "SLOPETYPE" ;
    ex:textoExtracto "Tipo de aceleración por defecto. Valores posibles: Lineal / Trapezoidal / Seno cuadrado (Square" ;
    ex:valor "Lineal / Trapezoidal / Seno cuadrado (Square" .