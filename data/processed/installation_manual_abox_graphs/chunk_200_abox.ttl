@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NombreDeLosEjes a ns1:Parametro ;
    rdfs:label "Nombre de los ejes" ;
    ns1:identificador "MPG.CHAXISNAMEn" ;
    ns1:textoExtracto "CHAXISNAME n Nombre de los ejes. Valores posibles: Cualquier eje definido en AXISNAME." .

ns1:NumeroDeEjesDelCanal_a38f0a0bcf a ns1:Parametro ;
    rdfs:label "Número de ejes del canal" ;
    ns1:textoExtracto "El número de ejes del canal lo establece el parámetro CHNAXIS." .

ns1:TablaEjes a ns1:Tabla ;
    rdfs:label "Tabla CHAXISNAME" ;
    ns1:ilustradoEn ns1:ListaDeEjesDelCanal_98ac312e8b ;
    ns1:textoExtracto "CHAXISNAME Lista de ejes del canal. Este parámetro muestra la tabla para definir los nombres de los ejes." .

ns1:ListaDeEjesDelCanal_98ac312e8b a ns1:Parametro ;
    rdfs:label "Lista de ejes del canal" ;
    ns1:textoExtracto "CHAXISNAME Lista de ejes del canal. Este parámetro muestra la tabla para definir los nombres de los ejes." .

