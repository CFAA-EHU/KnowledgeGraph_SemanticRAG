@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MIRRORCANCEL
    a ex:Parametro ;
    rdfs:label "MIRRORCANCEL" ;
    ex:textoExtracto "Cancelar la imagen espejo (G11/G12/G13/G14) tras M30 y reset. Valores posibles: Sí / No. Valor por defecto: Sí." ;
    ex:valor "Sí" ;
    ex:identificador "(V.)[ch].MPG.MIRRORCANCEL" .

ex:Parametro_SLOPETYPE
    a ex:Parametro ;
    rdfs:label "SLOPETYPE" ;
    ex:textoExtracto "Tipo de aceleración por defecto. Valores posibles: Lineal / Trapezoidal / Seno cuadrado (Square" ;
    ex:valor "Lineal" .  # Asumiendo valor por defecto implícito (no explícito en el texto)