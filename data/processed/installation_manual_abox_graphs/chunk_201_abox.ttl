@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SLOPETYPE
    a ex:Parametro ;
    rdfs:label "SLOPETYPE" ;
    ex:textoExtracto "Tipo de aceleración por defecto. Valores posibles: Lineal / Trapezoidal / Seno cuadrado (Square sine). Valor por defecto: Seno cuadrado. Variable asociada: (V.)[ch].MPG.SLOPETYPE" ;
    ex:valor "Seno cuadrado" .

ex:ModoOperacion_Automatico
    a ex:ModoOperacion ;
    rdfs:label "Modo automático" ;
    ex:textoExtracto "Este parámetro indica el tipo de aceleración que se aplica por defecto en los movimientos automáticos." .

ex:ModoOperacion_Manual
    a ex:ModoOperacion ;
    rdfs:label "Modo manual" ;
    ex:textoExtracto "Cuando se trabaja en modo manual el CNC aplica siempre la aceleración lineal." .

ex:Parametro_AceleracionLineal
    a ex:Parametro ;
    rdfs:label "Aceleración lineal" ;
    ex:textoExtracto "La peor respuesta se consigue con la aceleración lineal. [...] Los desplazamientos más rápidos se consiguen con la aceleración lineal." .

ex:Parametro_AceleracionTrapezoidal
    a ex:Parametro ;
    rdfs:label "Aceleración trapezoidal" ;
    ex:textoExtracto "La aceleración trapezoidal permite programar rampas con objeto de suavizar los cambios de aceleración y deceleración." .

ex:Parametro_AceleracionSenoCuadrado
    a ex:Parametro ;
    rdfs:label "Aceleración seno cuadrado" ;
    ex:textoExtracto "La aceleración seno cuadrado es una mejora a la aceleración trapezoidal, que suaviza el jerk para que los desplazamientos sean más suaves y sufra menos la mecánica del eje. [...] Con la aceleración seno cuadrado se obtiene la mejor respuesta del sistema, los desplazamientos son más suaves y sufre menos la mecánica del eje." .

ex:Figura_GraficasAceleracion
    a ex:Figura ;
    rdfs:label "Gráficas de velocidad, aceleración y jerk por tipo de aceleración" ;
    ex:textoExtracto "La siguiente figura muestra, para cada uno de los casos, las gráficas de velocidad (v), aceleración (a) y jerk (j)." .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "La dinámica de las aceleraciones trapezoidal y seno cuadrado es similar. [...] En función del tipo de aceleración seleccionado, en los parámetros máquina de los ejes se mostrarán los necesarios para configurar la aceleración." ;
    ex:tieneComponente ex:Parametro_SLOPETYPE ;
    ex:ilustradoEn ex:Figura_GraficasAceleracion .