@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Indice1DelCanal a ns1:Parametro ;
    rdfs:label "Índice 1 del canal" ;
    ns1:identificador "CHAXISNAME 1" ;
    ns1:textoExtracto "CHAXISNAME 1 | Índice ꞏ1ꞏ." .

ns1:Indice2DelCanal a ns1:Parametro ;
    rdfs:label "Índice 2 del canal" ;
    ns1:identificador "CHAXISNAME 2" ;
    ns1:textoExtracto "CHAXISNAME 2 | Índice ꞏ2ꞏ." .

ns1:Indice3DelCanal a ns1:Parametro ;
    rdfs:label "Índice 3 del canal" ;
    ns1:identificador "CHAXISNAME 3" ;
    ns1:textoExtracto "CHAXISNAME 3 | Índice ꞏ3ꞏ." .

