@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_SLOPETYPE a ex:Parametro ;
    ex:textoExtracto "Parámetro SLOPETYPE en el cabezal." ;
    rdfs:label "SLOPETYPE" .

ex:Parametro_ACCEL a ex:Parametro ;
    ex:textoExtracto "parámetros ACCEL/DECEL" ;
    rdfs:label "ACCEL/DECEL" .

ex:Parametro_ACCJERK a ex:Parametro ;
    ex:textoExtracto "parámetros ACCJERK/DECJERK" ;
    rdfs:label "ACCJERK/DECJERK" .

ex:Maquina_M3_M4 a ex:Maquina ;
    ex:textoExtracto "cabezal (M3/M4)" ;
    rdfs:label "M3/M4" .

ex:Maquina_CabezalEjeC a ex:Maquina ;
    ex:textoExtracto "Cuando el cabezal trabaja como eje C" ;
    rdfs:label "cabezal como eje C" .