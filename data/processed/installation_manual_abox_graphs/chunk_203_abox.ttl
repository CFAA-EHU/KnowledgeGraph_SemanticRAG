@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SLOPETYPE
    a               ex:Parametro ;
    rdfs:label      "SLOPETYPE" ;
    ex:textoExtracto "El parámetro SLOPETYPE no afecta al cabezal (M3/M4), que siempre utiliza aceleración con jerk (parámetros ACCEL/DECEL y ACCJERK/DECJERK). Cuando el cabezal trabaja como eje C, utilizará aceleración lineal o aceleración con jerk en función del tipo de mecanizado." ;
    ex:monitoreaParametro ex:ModoOperacion_Cabezal .

ex:Parametro_ACCEL
    a               ex:Parametro ;
    rdfs:label      "ACCEL" ;
    ex:textoExtracto "aceleración con jerk (parámetros ACCEL/DECEL y ACCJERK/DECJERK)" .

ex:Parametro_DECEL
    a               ex:Parametro ;
    rdfs:label      "DECEL" ;
    ex:textoExtracto "aceleración con jerk (parámetros ACCEL/DECEL y ACCJERK/DECJERK)" .

ex:Parametro_ACCJERK
    a               ex:Parametro ;
    rdfs:label      "ACCJERK" ;
    ex:textoExtracto "aceleración con jerk (parámetros ACCEL/DECEL y ACCJERK/DECJERK)" .

ex:Parametro_DECJERK
    a               ex:Parametro ;
    rdfs:label      "DECJERK" ;
    ex:textoExtracto "aceleración con jerk (parámetros ACCEL/DECEL y ACCJERK/DECJERK)" .

ex:ModoOperacion_Cabezal
    a               ex:ModoOperacion ;
    rdfs:label      "Modo de operación del cabezal (M3/M4)" ;
    ex:textoExtracto "El parámetro SLOPETYPE no afecta al cabezal (M3/M4), que siempre utiliza aceleración con jerk [...] Cuando el cabezal trabaja como eje C, utilizará aceleración lineal o aceleración con jerk en función del tipo de mecanizado." .