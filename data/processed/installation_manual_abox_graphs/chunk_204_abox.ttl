@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_LACC1
    a ex:Parametro ;
    rdfs:label "LACC1" ;
    ex:textoExtracto "El CNC utiliza los parámetros LACC1/LACC2/LFEED." ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Parametro_LACC2
    a ex:Parametro ;
    rdfs:label "LACC2" ;
    ex:textoExtracto "El CNC utiliza los parámetros LACC1/LACC2/LFEED." ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Parametro_LFEED
    a ex:Parametro ;
    rdfs:label "LFEED" ;
    ex:textoExtracto "El CNC utiliza los parámetros LACC1/LACC2/LFEED." ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Parametro_ACCEL
    a ex:Parametro ;
    rdfs:label "ACCEL" ;
    ex:textoExtracto "El CNC utiliza los parámetros ACCEL/DECEL/ACCJERK/DECJERK." ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Parametro_DECEL
    a ex:Parametro ;
    rdfs:label "DECEL" ;
    ex:textoExtracto "El CNC utiliza los parámetros ACCEL/DECEL/ACCJERK/DECJERK." ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Parametro_ACCJERK
    a ex:Parametro ;
    rdfs:label "ACCJERK" ;
    ex:textoExtracto "El CNC utiliza los parámetros ACCEL/DECEL/ACCJERK/DECJERK." ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Parametro_DECJERK
    a ex:Parametro ;
    rdfs:label "DECJERK" ;
    ex:textoExtracto "El CNC utiliza los parámetros ACCEL/DECEL/ACCJERK/DECJERK." ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Parametro_SLOPETYPE
    a ex:Parametro ;
    rdfs:label "SLOPETYPE" ;
    ex:textoExtracto "Modo no-HSC (G7/G50/G5) cuando SLOPETYPE=Lineal. Modo HSC CONTERROR cuando SLOPETYPE=Lineal. Modo HSC SURFACE/FAST." ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Parametro_IPLANE
    a ex:Parametro ;
    rdfs:label "IPLANE" ;
    ex:identificador "G17/G18" ;
    ex:valor "G17" ;
    ex:textoExtracto "IPLANE Plano principal (G17/G18) por defecto. Valores posibles: G17 / G18. Valor por defecto: G17. Este parámetro indica el plano de trabajo principal que asume el CNC por defecto." ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Parametro_CHAXISNAME
    a ex:Parametro ;
    rdfs:label "CHAXISNAME" ;
    ex:textoExtracto "Los ejes que forman el plano de trabajo dependen del parámetro máquina CHAXISNAME." ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "El CNC utiliza los parámetros LACC1/LACC2/LFEED. Modo no-HSC (G7/G50/G5) cuando SLOPETYPE=Lineal. Modo HSC CONTERROR cuando SLOPETYPE=Lineal. Modo HSC SURFACE/FAST." .

ex:ModoOperacion_NoHSC
    a ex:ModoOperacion ;
    rdfs:label "Modo no-HSC" ;
    ex:identificador "G7/G50/G5" ;
    ex:textoExtracto "Modo no-HSC (G7/G50/G5) cuando SLOPETYPE=Lineal. Modo no-HSC (G7/G50/G5) cuando SLOPETYPE=Trapezoidal. Modo no-HSC (G7/G50/G5) cuando SLOPETYPE=Seno cuadrado." ;
    ex:habilitadoPor ex:Parametro_SLOPETYPE .

ex:ModoOperacion_HSC_CONTERROR
    a ex:ModoOperacion ;
    rdfs:label "Modo HSC CONTERROR" ;
    ex:textoExtracto "Modo HSC CONTERROR cuando SLOPETYPE=Lineal. Modo HSC CONTERROR cuando SLOPETYPE=Trapezoidal. Modo HSC CONTERROR cuando SLOPETYPE=Seno cuadrado." ;
    ex:habilitadoPor ex:Parametro_SLOPETYPE .

ex:ModoOperacion_HSC_SURFACE_FAST
    a ex:ModoOperacion ;
    rdfs:label "Modo HSC SURFACE/FAST" ;
    ex:textoExtracto "Modo HSC SURFACE/FAST." ;
    ex:habilitadoPor ex:Parametro_SLOPETYPE .

ex:Tabla_2.4.8_CondicionesDefectoCanal
    a ex:Tabla ;
    rdfs:label "Tabla 2.4.8: Condiciones por defecto (canal)" ;
    ex:textoExtracto "| Tipo de aceleración. | Cabezal como eje C. Tipo de mecanizado. | --- | --- | Lineal. | El CNC utiliza los parámetros LACC1/LACC2/LFEED. • Modo no-HSC (G7/G50/G5) cuando SLOPETYPE=Lineal. • Modo HSC CONTERROR cuando SLOPETYPE=Lineal. • Modo HSC SURFACE/FAST. | Trapezoidal. | El CNC utiliza los parámetros ACCEL/DECEL/ACCJERK/DECJERK. • Modo no-HSC (G7/G50/G5) cuando SLOPETYPE=Trapezoidal. • Modo HSC CONTERROR cuando SLOPETYPE=Trapezoidal. | Seno cuadrado. | El CNC utiliza los parámetros ACCEL/DECEL/ACCJERK/DECJERK. • Modo no-HSC (G7/G50/G5) cuando SLOPETYPE=Seno cuadrado. • Modo HSC CONTERROR cuando SLOPETYPE=Seno cuadrado." ;
    ex:documentadoEn ex:Pagina_124_130 .