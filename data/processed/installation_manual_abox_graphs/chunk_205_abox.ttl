@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:G17 a ex:ModoOperacion ;
    rdfs:label "G17" ;
    ex:textoExtracto "Para cambiar el plano de trabajo desde el programa pieza utilizar las funciones G17, G18, G19 ó G20." .

ex:G18 a ex:ModoOperacion ;
    rdfs:label "G18" ;
    ex:textoExtracto "Para cambiar el plano de trabajo desde el programa pieza utilizar las funciones G17, G18, G19 ó G20." .

ex:G19 a ex:ModoOperacion ;
    rdfs:label "G19" ;
    ex:textoExtracto "Para cambiar el plano de trabajo desde el programa pieza utilizar las funciones G17, G18, G19 ó G20." .

ex:G20 a ex:ModoOperacion ;
    rdfs:label "G20" ;
    ex:textoExtracto "Para cambiar el plano de trabajo desde el programa pieza utilizar las funciones G17, G18, G19 ó G20." .

ex:G90 a ex:ModoOperacion ;
    rdfs:label "G90" ;
    ex:textoExtracto "ISYSTEM Tipo de coordenadas (G90/G91) por defecto. Valores posibles: G90 / G91. Valor por defecto: G90." .

ex:G91 a ex:ModoOperacion ;
    rdfs:label "G91" ;
    ex:textoExtracto "ISYSTEM Tipo de coordenadas (G90/G91) por defecto. Valores posibles: G90 / G91. Valor por defecto: G90." .

ex:G0 a ex:ModoOperacion ;
    rdfs:label "G0" ;
    ex:textoExtracto "IMOVE Tipo de movimiento (G0/G1) por defecto. Valores posibles: G0 / G1. Valor por defecto: G01." .

ex:G1 a ex:ModoOperacion ;
    rdfs:label "G1" ;
    ex:textoExtracto "IMOVE Tipo de movimiento (G0/G1) por defecto. Valores posibles: G0 / G1. Valor por defecto: G01." .

ex:IPLANE a ex:Parametro ;
    rdfs:label "IPLANE" ;
    ex:textoExtracto "Se recomienda definir el parámetro IPLANE como G17." .

ex:ISYSTEM a ex:Parametro ;
    rdfs:label "ISYSTEM" ;
    ex:textoExtracto "ISYSTEM Tipo de coordenadas (G90/G91) por defecto. Valores posibles: G90 / G91. Valor por defecto: G90." .

ex:IMOVE a ex:Parametro ;
    rdfs:label "IMOVE" ;
    ex:textoExtracto "IMOVE Tipo de movimiento (G0/G1) por defecto. Valores posibles: G0 / G1. Valor por defecto: G01." .

ex:TablaPlanos a ex:Tabla ;
    ex:textoExtracto "| Plano. | Eje de abscisas. | Eje de ordenadas. | Eje longitudinal. |\n| --- | --- | --- | --- |\n| G17 | CHAXISNAME 1 | CHAXISNAME 2 | CHAXISNAME 3 |\n| G18 | CHAXISNAME 3 | CHAXISNAME 1 | CHAXISNAME 2 |" ;
    ex:tieneComponente ex:G17, ex:G18 .

ex:ModeloM a ex:Maquina ;
    rdfs:label "Modelo M (fresadora)" ;
    ex:textoExtracto "Modelos M (fresadora), L (láser), OL (Open Line) y GL (General Line). Se recomienda definir el parámetro IPLANE como G17." .

ex:ModeloL a ex:Maquina ;
    rdfs:label "Modelo L (láser)" ;
    ex:textoExtracto "Modelos M (fresadora), L (láser), OL (Open Line) y GL (General Line). Se recomienda definir el parámetro IPLANE como G17." .

ex:ModeloOL a ex:Maquina ;
    rdfs:label "Modelo OL (Open Line)" ;
    ex:textoExtracto "Modelos M (fresadora), L (láser), OL (Open Line) y GL (General Line). Se recomienda definir el parámetro IPLANE como G17." .

ex:ModeloGL a ex:Maquina ;
    rdfs:label "Modelo GL (General Line)" ;
    ex:textoExtracto "Modelos M (fresadora), L (láser), OL (Open Line) y GL (General Line). Se recomienda definir el parámetro IPLANE como G17." .

ex:ModeloT_Triedro a ex:Maquina ;
    rdfs:label "Modelo T (torno) Configuración de ejes tipo \"triedro\"" ;
    ex:textoExtracto "Modelo T (torno). Configuración de ejes tipo \"triedro\". Se recomienda definir el parámetro IPLANE como G17." .

ex:ModeloT_Plano a ex:Maquina ;
    rdfs:label "Modelo T (torno) Configuración de ejes tipo \"plano\"" ;
    ex:textoExtracto "Modelo T (torno). Configuración de ejes tipo \"plano\". El plano de trabajo siempre es G18; el parámetro máquina IPLANE no se aplica y no se permite cambiar de plano desde el programa pieza, sólo el eje longitudinal (G20)." .