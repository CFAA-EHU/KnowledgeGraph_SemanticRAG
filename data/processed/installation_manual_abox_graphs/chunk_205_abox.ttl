ns1:CNC8070_11b6eb89ae a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC no visualiza las funciones ꞏGꞏ asociadas a los planos de trabajo, ya que siempre es el mismo plano." .

ns1:NoCambiaDePlanoYMuestraUnWarningAvisandoDeEllo a ns1:Parametro ;
    rdfs:label "No cambia de plano y muestra un warning avisando de ello" ;
    ns1:identificador "G17" ;
    ns1:textoExtracto "G17 | No cambia de plano y muestra un warning avisando de ello." .

ns1:NoCambiaDePlanoYMuestraUnWarningAvisandoDeEllo_e607be99a7 a ns1:Parametro ;
    rdfs:label "No cambia de plano y muestra un warning avisando de ello" ;
    ns1:identificador "G19" ;
    ns1:textoExtracto "G19 | No cambia de plano y muestra un warning avisando de ello." .

ns1:NoProduceNingunEfectoSalvoQueEsteActivaLaFuncionG20 a ns1:Parametro ;
    rdfs:label "No produce ningún efecto (salvo que esté activa la función G20)" ;
    ns1:identificador "G18" ;
    ns1:textoExtracto "G18 | No produce ningún efecto (salvo que esté activa la función G20)." .

ns1:SePermiteSiNoAlteraElPlanoPrincipalEsDecirSoloSePuedeUsarParaCambiarE_dced531498 a ns1:Parametro ;
    rdfs:label "Se permite si no altera el plano principal; es decir, sólo se puede usar para cambiar el eje longitudinal" ;
    ns1:identificador "G20" ;
    ns1:textoExtracto "G20 | Se permite si no altera el plano principal; es decir, sólo se puede usar para cambiar el eje longitudinal." .

