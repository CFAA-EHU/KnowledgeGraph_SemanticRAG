@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionDeEjesTipoPlano_8a05a4eeae a ns1:TareaMantenimiento ;
    rdfs:label "Configuración de ejes tipo 'plano'" ;
    ns1:solucionaFallo ns1:IntercambioDeEjesSinConsiderarElComportamientoAnterior ;
    ns1:textoExtracto "Configuración de ejes tipo \"plano\". Intercambio de ejes." .

ns1:Parametro_c50d42cac3 a ns1:Parametro ;
    rdfs:label "Función para cambiar eje de compensación longitudinal" ;
    ns1:identificador "G20" ;
    ns1:textoExtracto "se puede cambiar el eje de compensación longitudinal con la sentencia #TOOL AX o la función G20." .

ns1:SentenciaParaCambiarEjeDeCompensacionLongitudinal a ns1:Parametro ;
    rdfs:label "Sentencia para cambiar eje de compensación longitudinal" ;
    ns1:identificador "TOOL AX" ;
    ns1:textoExtracto "se puede cambiar el eje de compensación longitudinal con la sentencia #TOOL AX o la función G20." .

ns1:IntercambioDeEjesSinConsiderarElComportamientoAnterior a ns1:AccionProhibida ;
    rdfs:label "Intercambio de ejes sin considerar el comportamiento anterior" ;
    ns1:textoExtracto "Se permite el intercambio de ejes, pero se debe tener en cuenta que el comportamiento anterior se mantiene;" .

