@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:G0MODAL_Si a ex:ModoOperacion ;
    rdfs:label "G0MODAL=Sí" ;
    ex:textoExtracto "La función G00 es modal. Una vez programada permanece activa hasta que se programe G01, G02, G03, G33 o G63." ;
    ex:valor "Sí" .

ex:G0MODAL_No a ex:ModoOperacion ;
    rdfs:label "G0MODAL=No" ;
    ex:textoExtracto "La función G00 no es modal; hay que programarla en cada bloque de avance rápido. En el siguiente bloque de programa, si no hay función de movimiento programada (G0, G1, G2, G3, G33 o G63), el CNC aplica G1; es decir, G1 se mantiene modal. En el ámbito de influencia de un ciclo fijo se mantendrá activa la última G programada; G0 mantiene la condición de modal." ;
    ex:valor "No" .

ex:Parametro_IMOVE a ex:Parametro ;
    rdfs:label "IMOVE" ;
    ex:textoExtracto "Parámetro IMOVE; tipo de movimiento (G0/G1) en el arranque, tras un reset o M30. El valor IMOVE=G0 tiene prioridad sobre G0MODAL=No. Aunque la función G0 esté definida como no-modal, con IMOVE=G0 el CNC asume la función G0 en el arranque, tras un reset o M30. A partir de la programación de G1, G2 o G3, el CNC recupera G1 como función modal hasta el siguiente reset o M30." ;
    ex:identificador "IMOVE" ;
    ex:valor "G0" .

ex:G2G3MODAL_Si a ex:ModoOperacion ;
    rdfs:label "G2G3MODAL=Sí" ;
    ex:textoExtracto "G2G3MODAL La programación en G2/G3 se mantiene modal. Valores posibles: Sí / No. Valor por defecto: Sí." ;
    ex:valor "Sí" .

ex:G2G3MODAL_No a ex:ModoOperacion ;
    rdfs:label "G2G3MODAL=No" ;
    ex:textoExtracto "G2G3MODAL La programación en G2/G3 se mantiene modal. Valores posibles: Sí / No. Valor por defecto: Sí." ;
    ex:valor "No" .