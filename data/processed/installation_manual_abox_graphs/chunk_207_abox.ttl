@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeCabezalesDelCanal a ns1:Parametro ;
    rdfs:label "Número de cabezales del canal" ;
    ns1:documentadoEn ns1:TablaCabezalesCanal ;
    ns1:identificador "MPG.CHNSPDL" ;
    ns1:textoExtracto "CHNSPDL Número de cabezales del canal. Valores posibles: De 0 a 4. Valor por defecto: 1." .

ns1:NumeroDeCabezalesDelSistema a ns1:Parametro ;
    rdfs:label "Número de cabezales del sistema" ;
    ns1:textoExtracto "definido en el parámetro NSPDL." .

ns1:TablaCabezalesCanal a ns1:Tabla ;
    rdfs:label "Lista de cabezales del canal" ;
    ns1:textoExtracto "CHSPDLNAME Lista de cabezales del canal. Este parámetro muestra la tabla para definir los nombres de los cabezales." .

