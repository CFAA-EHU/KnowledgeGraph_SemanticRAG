@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_588853c1ab a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "En el arranque del CNC y tras un reset, el canal asume como cabezal master el primer cabezal definido en los parámetros máquina del canal (master original)." .

ns1:NombreDeLosCabezales a ns1:Parametro ;
    rdfs:label "Nombre de los cabezales" ;
    ns1:identificador "MPG.SPDLNAMEn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.SPDLNAMEn Parámetro incluido en la tabla CHSPDLNAME." .

ns1:TablaCHSPDLNAME a ns1:Tabla ;
    rdfs:label "Tabla CHSPDLNAME" ;
    ns1:ilustradoEn ns1:ListaDeCabezalesDelCanal ;
    ns1:textoExtracto "CHSPDLNAME Lista de cabezales del canal. Este parámetro muestra la tabla para definir los nombres de los cabezales." .

ns1:ListaDeCabezalesDelCanal a ns1:Parametro ;
    rdfs:label "Lista de cabezales del canal" ;
    ns1:identificador "CHSPDLNAME" ;
    ns1:textoExtracto "CHSPDLNAME Lista de cabezales del canal. Este parámetro muestra la tabla para definir los nombres de los cabezales." .

