@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:G2G3MODAL a ex:Parametro ;
    rdfs:label "G2G3MODAL" ;
    ex:textoExtracto "G2G3MODAL" ;
    ex:valor "Sí / No" .

ex:G02 a ex:Parametro ;
    rdfs:label "G02" ;
    ex:textoExtracto "Las funciones G02 y G03 son modales; una vez programadas permanecen activas hasta que se programe G00, G01, G33 o G63." ;
    ex:valor "G02" .

ex:G03 a ex:Parametro ;
    rdfs:label "G03" ;
    ex:textoExtracto "Las funciones G02 y G03 son modales; una vez programadas permanecen activas hasta que se programe G00, G01, G33 o G63." ;
    ex:valor "G03" .

ex:G00 a ex:Parametro ;
    rdfs:label "G00" ;
    ex:textoExtracto "Las funciones G02 y G03 son modales; una vez programadas permanecen activas hasta que se programe G00, G01, G33 o G63." ;
    ex:valor "G00" .

ex:G01 a ex:Parametro ;
    rdfs:label "G01" ;
    ex:textoExtracto "Las funciones G02 y G03 son modales; una vez programadas permanecen activas hasta que se programe G00, G01, G33 o G63." ;
    ex:valor "G01" .

ex:G33 a ex:Parametro ;
    rdfs:label "G33" ;
    ex:textoExtracto "Las funciones G02 y G03 son modales; una vez programadas permanecen activas hasta que se programe G00, G01, G33 o G63." ;
    ex:valor "G33" .

ex:G63 a ex:Parametro ;
    rdfs:label "G63" ;
    ex:textoExtracto "Las funciones G02 y G03 son modales; una vez programadas permanecen activas hasta que se programe G00, G01, G33 o G63." ;
    ex:valor "G63" .

ex:IFEED a ex:Parametro ;
    rdfs:label "IFEED" ;
    ex:textoExtracto "IFEED Tipo de avance (G94/G95) por defecto. Valores posibles: G94 / G95. Valor por defecto: G94. Variable asociada: (V.)[ch].MPG.IFEED Este parámetro indica el tipo de avance que asume el CNC por defecto. • Con G94 el avance se asume en mm/min, grados/min o inch/min. • Con G95 el avance se asume en mm/rev, grados/rev o inch/rev. La configuración típica para el modelo fresadora será G94. La configuración típica para el modelo torno será G95. Para cambiar el tipo de avance desde el programa pieza utilizar las funciones G94 ó G95." ;
    ex:valor "G94 / G95" .

ex:G94 a ex:Parametro ;
    rdfs:label "G94" ;
    ex:textoExtracto "IFEED Tipo de avance (G94/G95) por defecto. Valores posibles: G94 / G95. Valor por defecto: G94. Variable asociada: (V.)[ch].MPG.IFEED Este parámetro indica el tipo de avance que asume el CNC por defecto. • Con G94 el avance se asume en mm/min, grados/min o inch/min." ;
    ex:valor "G94" .

ex:G95 a ex:Parametro ;
    rdfs:label "G95" ;
    ex:textoExtracto "IFEED Tipo de avance (G94/G95) por defecto. Valores posibles: G94 / G95. Valor por defecto: G94. Variable asociada: (V.)[ch].MPG.IFEED Este parámetro indica el tipo de avance que asume el CNC por defecto. • Con G95 el avance se asume en mm/rev, grados/rev o inch/rev." ;
    ex:valor "G95" .

ex:FPRMAN a ex:Parametro ;
    rdfs:label "FPRMAN" ;
    ex:textoExtracto "FPRMAN Función G95 permitida en modo manual. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)[ch].MPG.FPRMAN Este parámetro indica si se permite la función G95 (avance por vuelta) para los movimientos en jog desde el modo manual; no afecta al movimiento con volantes o en modo MDI/MDA." ;
    ex:valor "Sí / No" .