@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_G2G3MODAL
    a ex:Parametro ;
    rdfs:label "G2G3MODAL" ;
    ex:textoExtracto "Las funciones G02 y G03 son modales; una vez programadas permanecen activas hasta que se programe G00, G01, G33 o G63. / Las funciones G02 y G03 no son modales; hay que programarlas en cada bloque de interpolación circular." ;
    ex:valor "Sí/No" .

ex:Parametro_IFEED
    a ex:Parametro ;
    rdfs:label "IFEED (Tipo de avance por defecto)" ;
    ex:identificador "G94/G95" ;
    ex:textoExtracto "Este parámetro indica el tipo de avance que asume el CNC por defecto. • Con G94 el avance se asume en mm/min, grados/min o inch/min. • Con G95 el avance se asume en mm/rev, grados/rev o inch/rev." ;
    ex:valor "G94" .

ex:Parametro_FPRMAN
    a ex:Parametro ;
    rdfs:label "FPRMAN (G95 permitida en modo manual)" ;
    ex:identificador "Sí/No" ;
    ex:textoExtracto "Este parámetro indica si se permite la función G95 (avance por vuelta) para los movimientos en jog desde el modo manual; no afecta al movimiento con volantes o en modo MDI/MDA." ;
    ex:valor "Sí" .

ex:ModoOperacion_Manual
    a ex:ModoOperacion ;
    rdfs:label "Modo manual (jog)" ;
    ex:textoExtracto "movimientos en jog desde el modo manual" .

ex:ModoOperacion_MDI
    a ex:ModoOperacion ;
    rdfs:label "Modo MDI/MDA" ;
    ex:textoExtracto "modo MDI/MDA" .

ex:Parametro_FPRMAN
    ex:habilitadoPor ex:ModoOperacion_Manual .