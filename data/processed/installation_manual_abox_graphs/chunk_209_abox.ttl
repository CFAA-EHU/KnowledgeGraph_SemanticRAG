@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_4a2c95fd21 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Si este cabezal se encuentra aparcado o cedido a otro canal, el canal asume como master el siguiente cabezal definido en los parámetros máquina y así sucesivamente." ;
    ns1:tieneComponente ns1:CabezalMaquina .

ns1:IndiceDelCabezal a ns1:Parametro ;
    rdfs:label "Índice del Cabezal" ;
    ns1:textoExtracto "El primer cabezal de la tabla tendrá índice ꞏ1ꞏ y así sucesivamente." ;
    ns1:valor "1" .

ns1:CabezalMaquina a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal del Canal" ;
    ns1:textoExtracto "Al igual que el nombre del cabezal, el índice en el canal permite identificar el cabezal en variables, marcas de PLC, etc." .

