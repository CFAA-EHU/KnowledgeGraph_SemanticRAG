@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_G95
    a ex:Parametro ;
    rdfs:label "Función G95 (avance por vuelta)"@es ;
    ex:textoExtracto "Se permite la función G95 (avance por vuelta) para los movimientos en jog desde el modo manual. [...] No se permite la función G95 (avance por vuelta) para los movimientos en jog desde el modo manual."@es ;
    ex:valor "G95" .

ex:Parametro_G94
    a ex:Parametro ;
    rdfs:label "Función G94 (avance por minuto)"@es ;
    ex:textoExtracto "los movimientos en jog serán en G94 (avance por minuto)."@es ;
    ex:valor "G94" .

ex:Parametro_IRCOMP
    a ex:Parametro ;
    rdfs:label "Modo de compensación de radio (G136/G137)"@es ;
    ex:identificador "IRCOMP" ;
    ex:textoExtracto "IRCOMP Modo de compensación de radio (G136/G137) por defecto. Valores posibles: G136 / G137. [...] Este parámetro indica el modo de compensación que asume el CNC en el momento de encendido, después de ejecutarse M02, M30 o después de reset."@es .

ex:Parametro_G136
    a ex:Parametro ;
    rdfs:label "Compensación de radio con trayectorias circulares (G136)"@es ;
    ex:textoExtracto "trayectorias compensadas se pueden enlazar entre sí mediante trayectorias circulares (G136)"@es ;
    ex:valor "G136" .

ex:Parametro_G137
    a ex:Parametro ;
    rdfs:label "Compensación de radio con trayectorias lineales (G137)"@es ;
    ex:textoExtracto "trayectorias compensadas se pueden enlazar entre sí mediante [...] trayectorias lineales (G137)"@es ;
    ex:valor "G137" .

ex:ModoOperacion_Manual
    a ex:ModoOperacion ;
    rdfs:label "Modo manual (jog)"@es ;
    ex:textoExtracto "movimientos en jog desde el modo manual"@es .

ex:ModoOperacion_Automatico
    a ex:ModoOperacion ;
    rdfs:label "Modo automático"@es ;
    ex:textoExtracto "al pasar del modo automático al modo manual con G95 activa"@es .

ex:ModoOperacion_MDI
    a ex:ModoOperacion ;
    rdfs:label "Modo MDI"@es ;
    ex:textoExtracto "si se activa G95 desde en MDI sobre el modo manual"@es .

ex:InterfazUsuario_CNC
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de usuario del CNC"@es ;
    ex:textoExtracto "El avance real (Freal) que se visualiza en los modos manual y conversacional"@es ;
    ex:ilustradoEn ex:Parametro_G95 .

ex:Tabla_CondicionesDefectoCanal a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla 2.4.8: Condiciones por defecto (canal)"@es ;
    ex:documentadoEn ex:Manual ;
    ex:textoExtracto "Valor. | Significado. [...] IRCOMP Modo de compensación de radio (G136/G137) por defecto."@es ;
    ex:detalladoEnEsquema ex:Parametro_G95, ex:Parametro_G94, ex:Parametro_IRCOMP, ex:Parametro_G136, ex:Parametro_G137 .