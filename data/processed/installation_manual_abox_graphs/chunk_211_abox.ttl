@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ModoOperacion_PlanCancel_Si ex:textoExtracto """En el momento del encendido, después de ejecutar M02 ó M30, y después de un reset, el CNC asume el plano definido en el parámetro IPLANE.""" ;
    a ex:ModoOperacion ;
    ex:identificador "PLANECANCEL. Sí" .

ex:ModoOperacion_PlanCancel_No ex:textoExtracto """En el momento del encendido, el CNC asume el plano definido en el parámetro IPLANE; después de ejecutar M02 ó M30, y después de un reset, el CNC mantiene el plano principal activo.""" ;
    a ex:ModoOperacion ;
    ex:identificador "PLANECANCEL. No" .

ex:Parametro_IPLANE ex:textoExtracto """el plano definido en el parámetro IPLANE""" ;
    a ex:Parametro ;
    ex:identificador "IPLANE" .

ex:Accion_M02 ex:textoExtracto """después de ejecutar M02 ó M30""" ;
    a ex:AccionProhibida ;
    ex:identificador "M02" .

ex:Accion_M30 ex:textoExtracto """después de ejecutar M02 ó M30""" ;
    a ex:AccionProhibida ;
    ex:identificador "M30" .

ex:Accion_Reset ex:textoExtracto """después de un reset""" ;
    a ex:AccionProhibida ;
    ex:identificador "reset" .