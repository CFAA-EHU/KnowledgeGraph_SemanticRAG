@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlineamientoDelEjeCParaMecanizadoDiametral a ns1:Parametro ;
    rdfs:label "Alineamiento del eje C para mecanizado diametral" ;
    ns1:identificador "MPG.ALIGNC" ;
    ns1:textoExtracto "ALIGNC Alineamiento del eje C para mecanizado diametral. Valores posibles: Sí / No. Valor por defecto: Sí." .

ns1:NombrePorDefectoDelEjeC a ns1:Parametro ;
    rdfs:label "Nombre por defecto del eje C" ;
    ns1:identificador "MPG.CAXNAME" ;
    ns1:textoExtracto "CAXNAME Nombre por defecto del eje C. Valores posibles: X, X1...X9, C, C1...C9. Valor por defecto: C." .

