@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionDelEjeC_f6ee021f30 a ns1:Parametro ;
    rdfs:label "Configuración del eje C" ;
    ns1:identificador "ALIGNC" ;
    ns1:solucionaFallo ns1:ContinuarElMecanizadoRetrocediendoLaHerramienta,
        ns1:Girar180ElEjeC,
        ns1:MecanizadoHastaElCentro ;
    ns1:textoExtracto "\"ALIGNC | Significado.\"" .

ns1:Herramienta_6d13b1d257 a ns1:Herramienta ;
    rdfs:label "herramienta" ;
    ns1:textoExtracto "\"retrocediendo la herramienta\"." .

ns1:ContinuarElMecanizadoRetrocediendoLaHerramienta a ns1:AccionProhibida ;
    rdfs:label "Continuar el mecanizado retrocediendo la herramienta" ;
    ns1:textoExtracto "\"(3)Continuar el mecanizado retrocediendo la herramienta.\"" .

ns1:Girar180ElEjeC a ns1:AccionProhibida ;
    rdfs:label "Girar 180° el eje C" ;
    ns1:textoExtracto "\"(2)Girar 180° el eje C.\"" .

ns1:MecanizadoHastaElCentro a ns1:AccionProhibida ;
    rdfs:label "Mecanizado hasta el centro" ;
    ns1:textoExtracto "\"(1)Mecanizado hasta el centro.\"" .

