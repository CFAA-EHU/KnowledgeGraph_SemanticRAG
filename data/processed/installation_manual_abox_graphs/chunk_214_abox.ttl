@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MAXROUND
    a ex:Parametro ;
    rdfs:label "Parámetro MAXROUND" ;
    ex:identificador "V.[ch].MPG.MAXROUND" ;
    ex:textoExtracto "Este parámetro define la desviación máxima permitida entre el punto programado y el perfil resultante del matado de arista. El CNC lo tiene en cuenta con ROUNDTYPE = Error cordal. Este parámetro también define el error de contorno máximo permitido para el modo HSC cuando no se programa CONTERROR (modo CONTERROR) ni E (modo FAST)." ;
    ex:valor "0.00394 inch" .

ex:Parametro_ROUNDFEED
    a ex:Parametro ;
    rdfs:label "Parámetro ROUNDFEED" ;
    ex:identificador "V.[ch].MPG.ROUNDFEED" ;
    ex:textoExtracto "Este parámetro define el porcentaje del avance activo que se va a emplear en el mecanizado. El CNC lo tiene en cuenta con ROUNDTYPE = %Avance." ;
    ex:valor "100" .

ex:ModoOperacion_HSC
    a ex:ModoOperacion ;
    rdfs:label "Modo HSC" ;
    ex:textoExtracto "modo HSC cuando no se programa CONTERROR (modo CONTERROR) ni E (modo FAST)" .

ex:ModoOperacion_FAST
    a ex:ModoOperacion ;
    rdfs:label "Modo FAST" ;
    ex:textoExtracto "modo FAST" .

ex:ModoOperacion_CONTERROR
    a ex:ModoOperacion ;
    rdfs:label "Modo CONTERROR" ;
    ex:textoExtracto "modo CONTERROR" .

ex:Parametro_ROUNDFEED ex:monitoreaParametro ex:ModoOperacion_HSC .
ex:Parametro_MAXROUND ex:monitoreaParametro ex:ModoOperacion_HSC .