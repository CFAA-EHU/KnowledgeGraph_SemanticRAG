@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TiempoDeAnticipacion a ns1:Parametro ;
    rdfs:label "Tiempo de anticipación" ;
    ns1:documentadoEn ns1:SistemaPunzonadoraExcentrica ;
    ns1:identificador "MPG.ANTIME" ;
    ns1:textoExtracto "ANTEIME Tiempo de anticipación. Valores posibles: De 0 a 10000000 ms. Valor por defecto: 0." .

ns1:SistemaPunzonadoraExcentrica a ns1:Sistema ;
    rdfs:label "Sistema de punzonadora con excéntrica" ;
    ns1:textoExtracto "Este parámetro se utiliza en las punzonadoras que tienen una excéntrica como sistema de golpeo." .

