@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_CIRINERR a ex:Parametro ;
    rdfs:label "CIRINERR" ;
    ex:identificador "CIRINERR" ;
    ex:textoExtracto "CIRINERR Error absoluto máximo permitido en el radio. Valores posibles: De 0 a 99999.9999 mm o grados / de 0 a 3937.00787 inch. Valor por defecto: 0.0100 mm o grados / 0.00039 inch. Variable asociada: (V.)[ch].MPG.CIRINERR Consultar el parámetro máquina general CIRINFACT." ;
    ex:valor "0.0100 mm o grados / 0.00039 inch" .

ex:Parametro_CIRINFACT a ex:Parametro ;
    rdfs:label "CIRINFACT" ;
    ex:identificador "CIRINFACT" ;
    ex:textoExtracto "CIRINFACT Error relativo máximo permitido en el radio. Valores posibles: De 0 a 100.0 %. Valor por defecto: 0.1 %. Variable asociada: (V.)[ch].MPG.CIRINFACT Estos parámetros definen las condiciones en las que se va a corregir la posición del centro en las interpolaciones circulares." ;
    ex:valor "0.1 %" .

ex:Parametro_MPG_CIRINERR a ex:Parametro ;
    rdfs:label "(V.)[ch].MPG.CIRINERR" ;
    ex:identificador "(V.)[ch].MPG.CIRINERR" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPG.CIRINERR Consultar el parámetro máquina general CIRINFACT." .

ex:Parametro_MPG_CIRINFACT a ex:Parametro ;
    rdfs:label "(V.)[ch].MPG.CIRINFACT" ;
    ex:identificador "(V.)[ch].MPG.CIRINFACT" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPG.CIRINFACT Estos parámetros definen las condiciones en las que se va a corregir la posición del centro en las interpolaciones circulares." .

ex:Sistema_CNC a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "En las interpolaciones circulares el CNC calcula los radios del punto inicial y final de la trayectoria." .

ex:AccionProhibida_CorreccionCentroArco a ex:AccionProhibida ;
    rdfs:label "Corrección del centro del arco" ;
    ex:textoExtracto "Estos parámetros definen las condiciones en las que se va a corregir la posición del centro en las interpolaciones circulares." .

ex:Funcion_G264 a ex:Parametro ;
    rdfs:label "G264" ;
    ex:identificador "G264" ;
    ex:textoExtracto "Esta funcionalidad se controla desde el programa mediante las funciones G264 y G265." .

ex:Funcion_G265 a ex:Parametro ;
    rdfs:label "G265" ;
    ex:identificador "G265" ;
    ex:textoExtracto "Esta funcionalidad se controla desde el programa mediante las funciones G264 y G265." .