@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DuracionTotalDelMovimiento a ns1:Parametro ;
    rdfs:label "Duración total del movimiento" ;
    ns1:solucionaFallo ns1:SenalDeAnticipacionADVINPOSSiempreActiva ;
    ns1:textoExtracto "Si la duración total del movimiento es inferior al valor especificado en el parámetro, la señal de anticipación ADVINPOS se activará inmediatamente." .

ns1:SenalAnticipacionADVINPOS a ns1:AccionProhibida ;
    rdfs:label "señal de anticipación ADVINPOS" ;
    ns1:textoExtracto "Si la duración total del movimiento es inferior al valor especificado en el parámetro, la señal de anticipación ADVINPOS se activará inmediatamente." .

ns1:SenalDeAnticipacionADVINPOSSiempreActiva a ns1:AccionProhibida ;
    rdfs:label "señal de anticipación ADVINPOS siempre activa" ;
    ns1:textoExtracto "Si se define con valor cero, la señal de anticipación ADVINPOS está siempre activa." .

