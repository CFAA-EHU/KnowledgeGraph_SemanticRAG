@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_CIRINERR
    a ex:Parametro ;
    rdfs:label "CIRINERR" ;
    ex:textoExtracto "CIRINERR Error absoluto máximo permitido en el radio. Valores posibles: De 0 a 99999.9999 mm o grados / de 0 a 3937.00787 inch. Valor por defecto: 0.0100 mm o grados / 0.00039 inch." ;
    ex:identificador "CIRINERR" ;
    ex:valor "0.0100 mm / 0.00039 inch" .

ex:Parametro_CIRINFACT
    a ex:Parametro ;
    rdfs:label "CIRINFACT" ;
    ex:textoExtracto "CIRINFACT Error relativo máximo permitido en el radio. Valores posibles: De 0 a 100.0 %. Valor por defecto: 0.1 %." ;
    ex:identificador "CIRINFACT" ;
    ex:valor "0.1 %" .

ex:Sistema_InterpolacionCircular
    a ex:Sistema ;
    rdfs:label "Sistema de corrección de interpolaciones circulares" ;
    ex:textoExtracto "Estos parámetros definen las condiciones en las que se va a corregir la posición del centro en las interpolaciones circulares. En las interpolaciones circulares el CNC calcula los radios del punto inicial y final de la trayectoria." ;
    ex:tieneComponente ex:Parametro_CIRINERR ;
    ex:tieneComponente ex:Parametro_CIRINFACT ;
    ex:monitoreaParametro ex:Parametro_CIRINERR ;
    ex:monitoreaParametro ex:Parametro_CIRINFACT .