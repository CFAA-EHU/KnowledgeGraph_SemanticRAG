@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MAXOVR a ex:Parametro ;
    rdfs:label "MAXOVR" ;
    ex:identificador "MAXOVR" ;
    ex:valor "De 0 a 255" ;
    ex:textoExtracto "MAXOVR Override (%) máximo permitido. Valores posibles: De 0 a 255. Valor por defecto: 200." ;
    ex:valor "200" .

ex:RAPIDOVR a ex:Parametro ;
    rdfs:label "RAPIDOVR" ;
    ex:identificador "RAPIDOVR" ;
    ex:valor "Sí / No" ;
    ex:textoExtracto "RAPIDOVR Override actúa en G00 (entre 0 y 100%). Valores posibles: Sí / No. Valor por defecto: Sí." ;
    ex:valor "Sí" .

ex:FEEDND a ex:Parametro ;
    rdfs:label "FEEDND" ;
    ex:identificador "FEEDND" ;
    ex:valor "Sí / No" ;
    ex:textoExtracto "FEEDND Aplicar el avance programado a todos los ejes del canal. Valores posibles: Sí / No. Valor por defecto: No." ;
    ex:valor "No" .

ex:ModoOperacion_G00 a ex:ModoOperacion ;
    rdfs:label "G00" ;
    ex:textoExtracto "Override actúa en G00 (entre 0 y 100%)." .

ex:ModoOperacion_Manual a ex:ModoOperacion ;
    rdfs:label "Manual" ;
    ex:textoExtracto "En los desplazamientos en modo manual siempre está permitido modificar el porcentaje de avance." .