@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:FEEDND a ex:Parametro ;
    ex:textoExtracto "FEEDND | Significado." ;
    rdfs:label "FEEDND" .

ex:Parametro_FeedOverride a ex:Parametro ;
    ex:textoExtracto "El avance programado será la resultante de componer los movimientos sobre todos los ejes del canal." ;
    rdfs:label "Avance programado (todos los ejes)" .

ex:Parametro_FeedOverride_SoloEjesPrincipales a ex:Parametro ;
    ex:textoExtracto "Si alguno de los ejes principales tiene desplazamiento programado, el avance programado será la resultante de componer el movimiento sólo sobre estos ejes. El resto de los ejes se desplazan al avance que les corresponda para terminar el movimiento todos a la vez. Sólo se limita el avance programado si algún eje pudiera sobrepasar su MAXFEED." ;
    rdfs:label "Avance programado (ejes principales)" .

ex:Parametro_FeedOverride_EjeMaxMovimiento a ex:Parametro ;
    ex:textoExtracto "Si no están programados ninguno de los ejes principales, el avance programado se alcanzará en aquel eje que más movimiento realiza, terminando todos a la vez." ;
    rdfs:label "Avance programado (eje de máximo movimiento)" .

ex:Parametro_MAXFEED a ex:Parametro ;
    ex:textoExtracto "MAXFEED" ;
    rdfs:label "MAXFEED" .