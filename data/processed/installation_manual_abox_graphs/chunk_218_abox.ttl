ns1:AnguloMaximoDeLaEsquinaParaMecanizarlaEnAristaViva_98073ce9bb a ns1:Parametro ;
    rdfs:label "Ángulo máximo de la esquina para mecanizarla en arista viva" ;
    ns1:identificador "MPG.CORNER" ;
    ns1:textoExtracto "CORNER Ángulo máximo de la esquina para mecanizarla en arista viva. Valores posibles: De 0 a 180.0000º. Valor por defecto: 0." .

ns1:CalcularElPromedioDelAvance a ns1:Parametro ;
    rdfs:label "Calcular el promedio del avance" ;
    ns1:identificador "MPG.FEEDAVRG" ;
    ns1:textoExtracto "FEEDAVRG Calcular el promedio del avance. Valores posibles: Sí / No. Valor por defecto: Sí." .

ns1:FrecuenciaDeSuavizadoEnLaInterpolacion a ns1:Parametro ;
    rdfs:label "Frecuencia de suavizado en la interpolación" ;
    ns1:identificador "MPG.SMOOTHFREQ" ;
    ns1:textoExtracto "SMOOTHFREQ Frecuencia de suavizado en la interpolación. Valores posibles: De 0 a 500.0000. Valor por defecto: 0 (no está activa)." .

ns1:ModoPorDefectoAlProgramarHSCON_51f3485bb6 a ns1:Parametro ;
    rdfs:label "Modo por defecto al programar #HSC ON" ;
    ns1:identificador "MPG.HSCDEFAULTMODE" ;
    ns1:textoExtracto "HSCDEFAULTMODE Modo por defecto al programar #HSC ON. Valores posibles: SURFACE / CONTERROR / FAST. Valor por defecto: SURFACE." .

ns1:VelocidadMinimaEnLasEsquinas_a900b0be65 a ns1:Parametro ;
