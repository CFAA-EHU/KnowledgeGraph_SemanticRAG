    ns1:identificador "MPG.MINCORFEED" ;
    ns1:textoExtracto "MINCORFEED Velocidad mínima en las esquinas. Valores posibles: De 0 a 200000.0000 mm/min / de 0 a 7874.01575 inch/min. Valor por defecto: 0." .

