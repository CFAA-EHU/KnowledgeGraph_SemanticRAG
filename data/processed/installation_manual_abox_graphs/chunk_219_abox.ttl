@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FrecuenciaDeSuavizadoEnLaInterpolacionDeTrayectorias a ns1:Parametro ;
    rdfs:label "frecuencia de suavizado en la interpolación de trayectorias" ;
    ns1:identificador "MPG.SMOOTHFREQ" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.SMOOTHFREQ Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias." .

ns1:FrecuenciaDelFiltroModoCONTERROR a ns1:Parametro ;
    rdfs:label "frecuencia del filtro (modo CONTERROR)" ;
    ns1:identificador "HSCFILTFREQ" ;
    ns1:textoExtracto "HSCFILTFREQ Frecuencia del filtro (modo CONTERROR)." .

