@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MINDMCOVR a ex:Parametro ;
    rdfs:label "MINDMCOVR" ;
    ex:identificador "MINDMCOVR" ;
    ex:textoExtracto "MINDMCOVR Mínimo override DMC de todos los ejes del canal. Valores posibles: De 10 a 100 %. Valor por defecto: 80 %. Variable asociada: (V.)[ch].MPG.MINDMCOVR Consultar el parámetro máquina MAXDMCOVR." ;
    ex:valor "De 10 a 100 %; Valor por defecto: 80 %" .

ex:MAXDMCOVR a ex:Parametro ;
    rdfs:label "MAXDMCOVR" ;
    ex:identificador "MAXDMCOVR" ;
    ex:textoExtracto "MAXDMCOVR Máximo override DMC de todos los ejes del canal. Valores posibles: De 100 a 255 %. Valor por defecto: 120 %. Variable asociada: (V.)[ch].MPG.MAXDMCOVR" ;
    ex:valor "De 100 a 255 %; Valor por defecto: 120 %" .

ex:DMCPEAKSIZE a ex:Parametro ;
    rdfs:label "DMCPEAKSIZE" ;
    ex:identificador "DMCPEAKSIZE" ;
    ex:textoExtracto "DMCPEAKSIZE Exceso porcentual de potencia para monitorizar los picos de potencia en el DMC. Valores posibles: De 0 a 100 %. Valor por defecto: 20 %. Variable asociada: (V.)[ch].MPG.DMCPEAKSIZE Exceso porcentual de potencia, sobre la potencia nominal, para monitorizar los picos de potencia en el DMC." ;
    ex:valor "De 0 a 100 %; Valor por defecto: 20 %" .

ex:DMC a ex:Sistema ;
    rdfs:label "DMC" ;
    ex:textoExtracto "control dinámico del mecanizado (DMC)" .

ex:MAXOVR a ex:Parametro ;
    rdfs:label "MAXOVR" ;
    ex:identificador "MAXOVR" ;
    ex:textoExtracto "El CNC siempre respeta el límite máximo definido en el parámetro máquina MAXOVR." .

ex:OverrideJOG a ex:Parametro ;
    rdfs:label "OverrideJOG" ;
    ex:textoExtracto "overrideJOG (%)" .

ex:OverrideDMC a ex:Parametro ;
    rdfs:label "OverrideDMC" ;
    ex:textoExtracto "OverrideDMC (%)" .

ex:PRGFRO a ex:Parametro ;
    rdfs:label "PRGFRO" ;
    ex:textoExtracto "porcentaje de avance fijado por programa (variable V.G.PRGFRO)" .

ex:PLCFRO a ex:Parametro ;
    rdfs:label "PLCFRO" ;
    ex:textoExtracto "porcentaje de avance por PLC (variable V.PLC.FRO)" .