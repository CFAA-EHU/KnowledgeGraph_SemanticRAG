@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:MINDMCOVR
    a ex:Parametro ;
    rdfs:label "MINDMCOVR" ;
    ex:textoExtracto "MINDMCOVR Mínimo override DMC de todos los ejes del canal. Valores posibles: De 10 a 100 %. Valor por defecto: 80 %." ;
    ex:identificador "(V.)[ch].MPG.MINDMCOVR" ;
    ex:valor "80" .

ex:MAXDMCOVR
    a ex:Parametro ;
    rdfs:label "MAXDMCOVR" ;
    ex:textoExtracto "MAXDMCOVR Máximo override DMC de todos los ejes del canal. Valores posibles: De 100 a 255 %. Valor por defecto: 120 %." ;
    ex:identificador "(V.)[ch].MPG.MAXDMCOVR" ;
    ex:valor "120" .

ex:DMCPEAKSIZE
    a ex:Parametro ;
    rdfs:label "DMCPEAKSIZE" ;
    ex:textoExtracto "DMCPEAKSIZE Exceso porcentual de potencia para monitorizar los picos de potencia en el DMC. Valores posibles: De 0 a 100 %. Valor por defecto: 20 %." ;
    ex:identificador "(V.)[ch].MPG.DMCPEAKSIZE" ;
    ex:valor "20" .

ex:MAXOVR
    a ex:Parametro ;
    rdfs:label "MAXOVR" ;
    ex:textoExtracto "El CNC siempre respeta el límite máximo definido en el parámetro máquina MAXOVR." .

ex:OverrideJOG
    a ex:Parametro ;
    rdfs:label "OverrideJOG" ;
    ex:textoExtracto "OverrideDMC%OverrideJOG% / 100" .

ex:OverrideDMC
    a ex:Parametro ;
    rdfs:label "OverrideDMC" ;
    ex:textoExtracto "OverrideDMC%OverrideJOG% / 100" .

ex:V_G_PRGFRO
    a ex:Parametro ;
    rdfs:label "V.G.PRGFRO" ;
    ex:textoExtracto "El porcentaje de avance fijado por programa (variable V.G.PRGFRO) [...] inhiben el DMC" ;
    ex:identificador "V.G.PRGFRO" .

ex:V_PLC_FRO
    a ex:Parametro ;
    rdfs:label "V.PLC.FRO" ;
    ex:textoExtracto "El porcentaje de avance fijado [...] por PLC (variable V.PLC.FRO) inhiben el DMC" ;
    ex:identificador "V.PLC.FRO" .

ex:DMC
    a ex:Sistema ;
    rdfs:label "DMC (Control Dinámico del Mecanizado)" ;
    ex:textoExtracto "DMC (control dinámico del mecanizado)" ;
    ex:monitoreaParametro ex:MINDMCOVR ;
    ex:monitoreaParametro ex:MAXDMCOVR ;
    ex:monitoreaParametro ex:DMCPEAKSIZE ;
    ex:monitoreaParametro ex:OverrideDMC ;
    ex:monitoreaParametro ex:OverrideJOG .