@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MPG.DMCPEAKSIZE a ex:Parametro ;
    rdfs:label "MPG.DMCPEAKSIZE" ;
    ex:identificador "(V.)[ch].MPG.DMCPEAKSIZE" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPG.DMCPEAKSIZE Exceso porcentual de potencia, sobre la potencia nominal, para monitorizar los picos de potencia en el DMC." ;
    ex:valor "20 %" .

ex:DMCPWRPEAK a ex:AvisoSeguridad ;
    ex:textoExtracto "el CNC muestra un warning, detiene los ejes manteniendo el giro de cabezal y activa la marca DMCPWRPEAK" .

ex:Parametro_0_100 a ex:Parametro ;
    ex:textoExtracto "Valores posibles: De 0 a 100 %." ;
    ex:valor "0 a 100 %" .

ex:Parametro_ValorDefecto_20 a ex:Parametro ;
    ex:textoExtracto "Valor por defecto: 20 %." ;
    ex:valor "20 %" .