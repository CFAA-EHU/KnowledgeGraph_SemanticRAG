@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DiferenciaDeTiempoAdmisibleEnLaInterpolacionDelAvanceModoFASTYSURFACE a ns1:Parametro ;
    rdfs:label "Diferencia de tiempo admisible en la interpolación del avance (modo FAST y SURFACE)" ;
    ns1:identificador "MPG.FTIMELIM" ;
    ns1:textoExtracto "El parámetro FTIMELIM permite limitar el tiempo que emplea el CNC para la interpolación del avance en cada tramo." .

ns1:FrecuenciaDelFiltroModoCONTERROR_acaf01b6e9 a ns1:Parametro ;
    rdfs:label "Frecuencia del filtro (modo CONTERROR)" ;
    ns1:identificador "MPG.HSCFILTFREQ" ;
    ns1:textoExtracto "Este parámetro activa un filtro automático FIR para todos los ejes del canal durante la ejecución en modo CONTERROR." .

ns1:PorcentajeDeAvancePorDefectoModoFAST a ns1:Parametro ;
    rdfs:label "Porcentaje de avance por defecto (modo FAST)" ;
    ns1:identificador "MPG.FASTFACTOR" ;
    ns1:textoExtracto "Este parámetro afecta al avance en las esquinas e indica el porcentaje de aceleración que se desea alcanzar, sobre el máximo que es capaz de conseguir el CNC, en el modo FAST." .

