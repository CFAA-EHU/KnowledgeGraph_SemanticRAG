@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_DMCPWRPEAK
    a ex:Parametro ;
    rdfs:label "DMCPWRPEAK" ;
    ex:textoExtracto "el CNC [...] activa la marca DMCPWRPEAK. Este parámetro permite detectar un pico de potencia, que puede ser debido a la rotura de la herramienta, profundización de pasada demasiado grande, etc." ;
    ex:identificador "DMCPWRPEAK" .

ex:Parametro_DMCPWRFACTOR
    a ex:Parametro ;
    rdfs:label "DMCPWRFACTOR" ;
    ex:textoExtracto "DMCPWRFACTOR Factor multiplicador de la potencia objetivo, para monitorizar el exceso de potencia consumida en el DMC. Valores posibles: De 0.0 a 100.0. Valor por defecto: 2.0." ;
    ex:identificador "DMCPWRFACTOR" ;
    ex:valor "2.0" .

ex:Parametro_DMCPWRHOLD
    a ex:Parametro ;
    rdfs:label "DMCPWRHOLD" ;
    ex:textoExtracto "Si todos los valores de la potencia leídos durante 2 segundos exceden la potencia a alcanzar multiplicada por este factor, el CNC muestra un warning y activa la marca DMCPWRHOLD. Este parámetro permite detectar un consumo excesivo de potencia que puede ser debido a un desgaste de herramienta." ;
    ex:identificador "DMCPWRHOLD" .

ex:AvisoSeguridad_WarningPotenciaDMC
    a ex:AvisoSeguridad ;
    rdfs:label "Warning de potencia en DMC" ;
    ex:textoExtracto "el CNC muestra un warning, detiene los ejes manteniendo el giro de cabezal y activa la marca DMCPWRPEAK" .

ex:Sistema_DMC
    a ex:Sistema ;
    rdfs:label "DMC (Dynamic Machining Control)" ;
    ex:textoExtracto "Configuración del DMC" ;
    ex:tieneComponente ex:Parametro_DMCPWRPEAK ;
    ex:tieneComponente ex:Parametro_DMCPWRFACTOR ;
    ex:tieneComponente ex:Parametro_DMCPWRHOLD ;
    ex:activaAlarma ex:AvisoSeguridad_WarningPotenciaDMC .

ex:Parametro_DMCPWRFACTOR
    ex:monitoreaParametro ex:Parametro_DMCPWRPEAK ;
    ex:monitoreaParametro ex:Parametro_DMCPWRHOLD .