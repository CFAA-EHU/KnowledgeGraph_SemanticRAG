@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LimitarElTiempoDeInterpolacionDelAvanceEnCadaTramo a ns1:Parametro ;
    rdfs:label "Limitar el tiempo de interpolación del avance en cada tramo" ;
    ns1:identificador "FTIMELIM" ;
    ns1:textoExtracto "El parámetro FTIMELIM permite limitar el tiempo que emplea el CNC para la interpolación del avance en cada tramo." .

