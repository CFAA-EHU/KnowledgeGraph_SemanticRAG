@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_DMCPWRFACTOR a ex:Parametro ;
    rdfs:label "DMCPWRFACTOR" ;
    ex:identificador "DMCPWRFACTOR" ;
    ex:textoExtracto "DMCPWRFACTOR Factor multiplicador de la potencia objetivo, para monitorizar el exceso de potencia consumida en el DMC." ;
    ex:valor "2.0" ;
    ex:tieneFrecuencia ex:Frecuencia_2_segundos .

ex:Parametro_DMCPWRHOLD a ex:Parametro ;
    rdfs:label "DMCPWRHOLD" ;
    ex:identificador "DMCPWRHOLD" ;
    ex:textoExtracto "activa la marca DMCPWRHOLD" ;
    ex:valor "1" .

ex:Parametro_DMCPWRPEAK a ex:Parametro ;
    rdfs:label "DMCPWRPEAK" ;
    ex:identificador "DMCPWRPEAK" ;
    ex:textoExtracto "activa la marca DMCPWRPEAK" .

ex:Frecuencia_2_segundos a ex:Frecuencia ;
    ex:identificador "2 segundos" ;
    ex:textoExtracto "Si todos los valores de la potencia leídos durante 2 segundos exceden la potencia a alcanzar multiplicada por este factor, el CNC muestra un warning y activa la marca DMCPWRHOLD." .