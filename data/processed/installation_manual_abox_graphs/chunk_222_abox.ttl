@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:FrecuenciaDeSuavizadoEnLaInterpolacionModoFASTYSURFACE a ns1:Parametro ;
    rdfs:label "Frecuencia de suavizado en la interpolación (modo FAST y SURFACE)"@es ;
    ns1:identificador "MPG.FSMOOTHFREQ" ;
    ns1:textoExtracto "Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias para los modos HSC FAST y SURFACE." ;
    ns1:valor "20"^^xsd:string .

ns1:FrecuenciaDelFiltroDeEjesModoSURFACE_b994420bc9 a ns1:Parametro ;
    rdfs:label "Frecuencia del filtro de ejes (modo SURFACE)"@es ;
    ns1:identificador "MPG.SURFFILTFREQ" ;
    ns1:textoExtracto "Este parámetro introduce un desfase constante, independiente de las frecuencias." ;
    ns1:valor "25 Hz"^^xsd:string .

ns1:FrecuenciaDelFiltroModoFAST_5031fd97c5 a ns1:Parametro ;
    rdfs:label "Frecuencia del filtro (modo FAST)"@es ;
    ns1:identificador "MPG.FASTFILTFREQ" ;
    ns1:textoExtracto "Este parámetro activa un filtro \"paso bajo\" automático para todos los ejes del canal durante la ejecución en modo HSC FAST."@es ;
    ns1:valor "17"^^xsd:string .

