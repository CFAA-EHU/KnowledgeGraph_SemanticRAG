@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_SubrutinasFabricante a ex:Tabla ;
     a                       ex:Tabla ;
    rdfs:label              "Tabla de subrutinas del fabricante"@es ;
    ex:textoExtracto         "SUBTABLE Tabla de subrutinas del fabricante. Las subrutinas de fabricante son aquellas guardadas la carpeta ..\\MTB\\Sub. Estas subrutinas están asociadas a algunas funciones del CNC como el cambio de herramienta, G74, G180 a G189, G380 a G399, etc."@es ;
    ex:identificador         "SUBTABLE" .

ex:Subrutina_TOOLSUB
    a                       ex:Parametro ;
    rdfs:label              "TOOLSUB"@es ;
    ex:textoExtracto         "TOOLSUB Subrutina asociada a la función T. Valores posibles: Cualquier texto de hasta 64 caracteres. Variable asociada: (V.)[ch].MPG.TOOLSUB Esta subrutina se ejecuta automáticamente cada vez que se ejecuta una función T (selección de herramienta)."@es ;
    ex:identificador         "TOOLSUB" ;
    ex:valor                 "Cualquier texto de hasta 64 caracteres"@es ;
    ex:documentadoEn         ex:Tabla_SubrutinasFabricante .

ex:Subrutina_REFPSUB_G74
    a                       ex:Parametro ;
    rdfs:label              "REFPSUB (G74)"@es ;
    ex:textoExtracto         "REFPSUB (G74) Subrutina asociada a la función G74. Valores posibles: Cualquier texto de hasta 64 caracteres. Variable asociada: (V.)[ch].MPG.REFPSUB La función G74 (búsqueda de referencia máquina) se puede programar de 2 formas. Indicando los ejes y el orden en que se efectúa la búsqueda o programando sólo G74 (sin ejes)."@es ;
    ex:identificador         "REFPSUB" ;
    ex:valor                 "Cualquier texto de hasta 64 caracteres"@es ;
    ex:documentadoEn         ex:Tabla_SubrutinasFabricante .

ex:Subrutina_INT1SUB
    a                       ex:Parametro ;
    rdfs:label              "INT1SUB"@es ;
    ex:textoExtracto         "INT1SUB··INT4SUB Subrutinas de interrupción."@es ;
    ex:identificador         "INT1SUB" ;
    ex:documentadoEn         ex:Tabla_SubrutinasFabricante .

ex:Subrutina_INT2SUB
    a                       ex:Parametro ;
    rdfs:label              "INT2SUB"@es ;
    ex:textoExtracto         "INT1SUB··INT4SUB Subrutinas de interrupción."@es ;
    ex:identificador         "INT2SUB" ;
    ex:documentadoEn         ex:Tabla_SubrutinasFabricante .

ex:Subrutina_INT3SUB
    a                       ex:Parametro ;
    rdfs:label              "INT3SUB"@es ;
    ex:textoExtracto         "INT1SUB··INT4SUB Subrutinas de interrupción."@es ;
    ex:identificador         "INT3SUB" ;
    ex:documentadoEn         ex:Tabla_SubrutinasFabricante .

ex:Subrutina_INT4SUB
    a                       ex:Parametro ;
