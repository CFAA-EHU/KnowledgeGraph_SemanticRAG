@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SubrutinaBusquedaEjes
    a                     ex:ModoOperacion ;
    rdfs:label            "Subrutina de búsqueda de ejes y referencia máquina"@es ;
    ex:textoExtracto      "Dentro de esta subrutina deben programarse los ejes y el orden en que se efectúa la búsqueda. También se efectúa una llamada a esta subrutina cuando se realiza una búsqueda de referencia máquina en modo manual sin selección de eje."@es ;
    ex:identificador      "INT1SUB··INT4SUB" .

ex:ParametroINT1SUB
    a                     ex:Parametro ;
    rdfs:label            "Parámetro INT1SUB"@es ;
    ex:textoExtracto      "Variable asociada: (V.)[ch].MPG.INT1SUB"@es ;
    ex:identificador      "(V.)[ch].MPG.INT1SUB" ;
    ex:valor              "Cualquier texto de hasta 64 caracteres"@es .

ex:ParametroINT4SUB
    a                     ex:Parametro ;
    rdfs:label            "Parámetro INT4SUB"@es ;
    ex:textoExtracto      "Variable asociada: (V.)[ch].MPG.INT4SUB"@es ;
    ex:identificador      "(V.)[ch].MPG.INT4SUB" ;
    ex:valor              "Cualquier texto de hasta 64 caracteres"@es .

ex:SubrutinaBusquedaEjes
    ex:monitoreaParametro  ex:ParametroINT1SUB ;
    ex:monitoreaParametro  ex:ParametroINT4SUB .