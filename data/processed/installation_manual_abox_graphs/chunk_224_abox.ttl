@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:INT1SUB a ex:Parametro ;
    rdfs:label "INT1SUB" ;
    ex:identificador "INT1SUB" ;
    ex:textoExtracto "INT1SUB··INT4SUB Subrutinas de interrupción. Valores posibles: Cualquier texto de hasta 64 caracteres." ;
    ex:valor "Cualquier texto de hasta 64 caracteres" .

ex:INT4SUB a ex:Parametro ;
    rdfs:label "INT4SUB" ;
    ex:identificador "INT4SUB" ;
    ex:textoExtracto "INT1SUB··INT4SUB Subrutinas de interrupción. Valores posibles: Cualquier texto de hasta 64 caracteres." ;
    ex:valor "Cualquier texto de hasta 64 caracteres" .

ex:MPG_INT1SUB a ex:Parametro ;
    rdfs:label "(V.)[ch].MPG.INT1SUB" ;
    ex:identificador "(V.)[ch].MPG.INT1SUB" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPG.INT1SUB / (V.)[ch].MPG.INT4SUB Estos parámetros indican el nombre" ;
    ex:valor "(V.)[ch].MPG.INT1SUB" .

ex:MPG_INT4SUB a ex:Parametro ;
    rdfs:label "(V.)[ch].MPG.INT4SUB" ;
    ex:identificador "(V.)[ch].MPG.INT4SUB" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPG.INT1SUB / (V.)[ch].MPG.INT4SUB Estos parámetros indican el nombre" ;
    ex:valor "(V.)[ch].MPG.INT4SUB" .