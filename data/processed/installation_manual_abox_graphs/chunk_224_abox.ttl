@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FrecuenciaDelFiltroDeTrayectoriaParaPerfilesDeAceleracionLineal_5fad1f4ca5 a ns1:Parametro ;
    rdfs:label "Frecuencia del filtro de trayectoria para perfiles de aceleración lineal" ;
    ns1:identificador "MPG.SOFTFREQ" ;
    ns1:textoExtracto "SOFTFREQ Frecuencia del filtro de trayectoria para perfiles de aceleración lineal. Valores posibles: De 0 a 500.0000 Hz. Valor por defecto: 25 Hz." .

ns1:PrimeraFrecuenciaDeResonanciaDeLaMaquina_c807efd00d a ns1:Parametro ;
    rdfs:label "Primera frecuencia de resonancia de la máquina" ;
    ns1:identificador "MPG.FREQRES" ;
    ns1:textoExtracto "FREQRES Primera frecuencia de resonancia de la máquina. Valores posibles: De 0 a 500.0000. Valor por defecto: 0." .

ns1:SuavizadoDeLaOrientacionDeLosEjesRotativosTrabajandoConRTCP a ns1:Parametro ;
    rdfs:label "Suavizado de la orientación de los ejes rotativos trabajando con RTCP" ;
    ns1:identificador "MPG.ORISMOOTH" ;
    ns1:textoExtracto "ORISMOOTH Suavizado de la orientación de los ejes rotativos, sin error en la punta de la herramienta, al trabajar con RTCP en modo HSC SURFACE. Valores posibles: De 0 a 200 ms. Valor por defecto: 60 ms." .

ns1:ValorPorDefectoDelErrorMaximoDeLaTrayectoriaEnHSC_be6cde5150 a ns1:Parametro ;
    rdfs:label "Valor por defecto del error máximo de la trayectoria en HSC" ;
    ns1:identificador "MPG.HSCROUND" ;
    ns1:textoExtracto "HSCROUND Valor por defecto del error máximo de la trayectoria en HSC. Valores posibles: De 0.0001 a 99999.9999 mm / de 0 a 3937.00787 inch. Valor por defecto: 0.06 mm / 0.00236 inch." .

