@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NombreDelEjeVirtualDeLaHerramienta a ns1:Parametro ;
    rdfs:label "Nombre del eje virtual de la herramienta" ;
    ns1:identificador "VIRTAXISNAME" ;
    ns1:textoExtracto "VIRTAXISNAME Nombre del eje virtual de la herramienta. Valores posibles: Cualquier nombre de eje válido; X, X1...X9, ..., C, C1...C9. Valor por defecto: ninguno." .

