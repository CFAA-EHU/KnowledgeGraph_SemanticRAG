@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Subrutina_CUTTINGON a ex:Parametro ;
    rdfs:label "Subrutina asociada al comando #CUTTING ON" ;
    ex:textoExtracto "Subrutina asociada al comando #CUTTING ON." ;
    ex:valor "Cualquier texto de hasta 64 caracteres" .

ex:Variable_asociada_V_MPG_CUTTINGON a ex:Parametro ;
    rdfs:label "Variable asociada: (V.)[ch].MPG.CUTTINGON" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPG.CUTTINGON Este parámetro indica el nombre de la subrutina asociada a la sentencia #CUTTINGON." ;
    ex:identificador "(V.)[ch].MPG.CUTTINGON" .

ex:Marca_desactivar_OEM a ex:Parametro ;
    rdfs:label "Marca para desactivar por OEM" ;
    ex:textoExtracto "el OEM debe desactivar esta marca (asignarle valor 0) para indicar al CNC que ha finalizado la operación de piercing." .