@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IndicaSiElCNCAnulaONoElEjeVirtualDeLaHerramientaTrasEjecutarM02M30YTrasUnReset a ns1:Parametro ;
    rdfs:label "Indica si el CNC anula o no el eje virtual de la herramienta tras ejecutar M02/M30 y tras un reset" ;
    ns1:identificador "MPG.VIRTAXCANCEL" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.VIRTAXCANCEL Este parámetro indica si el CNC anula o no el eje virtual de la herramienta tras ejecutar M02/M30 y tras un reset." .

ns1:NombreConElQueSeIdentificaElEjeVirtualDeLaHerramienta a ns1:Parametro ;
    rdfs:label "Nombre con el que se identifica el eje virtual de la herramienta" ;
    ns1:identificador "MPG.VIRTAXISNAME" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.VIRTAXISNAME Nombre con el que se identifica el eje virtual de la herramienta." .

