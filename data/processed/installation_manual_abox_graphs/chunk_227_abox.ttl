@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Subrutina_CUTTINGON a ex:Parametro ;
    rdfs:label "CUTTINGON" ;
    ex:identificador "(V.)[ch].MPG.CUTTINGON" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPG.CUTTINGON Este parámetro indica el nombre de las subrutina asociada a la sentencia #CUTTINGON." ;
    ex:valor "Cualquier texto de hasta 64 caracteres." .

ex:Subrutina_CUTTINGOFF a ex:Parametro ;
    rdfs:label "CUTTINGOFF" ;
    ex:identificador "(V.)[ch].MPG.CUTTINGOFF" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPG.CUTTINGOFF Este parámetro indica el nombre de las subrutina asociada a la sentencia #CUTTINGOFF." ;
    ex:valor "Cualquier texto de hasta 64 caracteres." .

ex:Subrutina_FINALSUB a ex:Parametro ;
    rdfs:label "FINALSUB" ;
    ex:identificador "(V.)[ch].MPG.FINALSUB" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPG.FINALSUB Este parámetro indica el nombre de las subrutina asociada a la sentencia #FINALSUB." ;
    ex:valor "Cualquier texto de hasta 64 caracteres." .

ex:Subrutina_OEMSUB a ex:Parametro ;
    rdfs:label "OEMSUB (G18x)" ;
    ex:identificador "(G18x)" ;
    ex:textoExtracto "Subrutinas asociadas a las funciones G180 a G189." ;
    ex:valor "Cualquier texto de hasta 64 caracteres." .

ex:Sistema_CNC a ex:Sistema ;
    ex:textoExtracto "Cada vez que el CNC ejecuta esta sentencia, efectúa una llamada a la subrutina asociada (por defecto, Cuttingon.fst)." .

ex:Subrutina_Cuttingon_fst a ex:Componente ;
    rdfs:label "Cuttingon.fst" ;
    ex:textoExtracto "por defecto, Cuttingon.fst" .

ex:Subrutina_Cuttingoff_fst a ex:Componente ;
    rdfs:label "Cuttingoff.fst" ;
    ex:textoExtracto "por defecto, Cuttingoff.fst" .

ex:Marca_CUTTING a ex:Parametro ;
    rdfs:label "CUTTING" ;
    ex:textoExtracto "el OEM debe activar la marca CUTTING (asignarle valor 1) para indicar al PLC que empieza la operación de cutting" ;
    ex:valor "1" .

ex:Marca_CUTTING_0 a ex:Parametro ;
    rdfs:label "CUTTING" ;
    ex:textoExtracto "el OEM debe desactivar la marca CUTTING (asignarle valor 0) para indicar al CNC que ha finalizado la operación de cutting" ;
    ex:valor "0" .