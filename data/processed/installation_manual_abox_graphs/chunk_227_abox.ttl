@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeCinematicaPorDefecto a ns1:Parametro ;
    rdfs:label "Número de cinemática por defecto" ;
    ns1:identificador "MPG.KINID" ;
    ns1:monitoreaParametro ns1:CNC8070_c367b8fbe2 ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.KINID Este parámetro indica el número de cinemática que asume el CNC en el momento de encendido, después de ejecutarse M02, M30 o después de reset." .

ns1:CNC8070_c367b8fbe2 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC puede tener definidas hasta 6 cinemáticas distintas." .

