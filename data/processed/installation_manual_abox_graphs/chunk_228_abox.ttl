@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_5bace476a7 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Si se define con valor \"Ninguna\", el CNC no activa ninguna cinemática por defecto. El CNC puede tener definidas hasta 6 cinemáticas distintas." .

ns1:IndicaSiEnElArranqueElCNCCancelaElAcoplamientoDeEjesPorDefecto a ns1:Parametro ;
    rdfs:label "Indica si en el arranque, el CNC cancela el acoplamiento de ejes por defecto" ;
    ns1:identificador "LINKCANCEL" ;
    ns1:textoExtracto "LINKCANCEL Cancelar el acoplamiento de ejes por defecto. Valores posibles: Sí / No. Valor por defecto: Sí." .

ns1:IndicaSiEnElArranqueElCNCCancelaElPlanoInclinadoQueSeEncontrabaActivo_c2f231f3d5 a ns1:Parametro ;
    rdfs:label "Indica si en el arranque, el CNC cancela el plano inclinado que se encontraba activo cuando se apagó" ;
    ns1:identificador "MPG.CSCANCEL" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.CSCANCEL Este parámetro indica si en el arranque, el CNC cancela el plano inclinado (#CS/#ACS) que se encontraba activo cuando se apagó." .

