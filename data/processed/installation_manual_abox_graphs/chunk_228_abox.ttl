@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Subrutina_OEMSUB_G18x
    a                     ex:InterfazUsuario ;
    rdfs:label            "Subrutinas OEMSUB (G180-G189)"@es ;
    ex:textoExtracto      "OEMSUB (G18x) Subrutinas asociadas a las funciones G180 a G189. Valores posibles: Cualquier texto de hasta 64 caracteres. Variable asociada: (V.)[ch].MPG.OEMSUB1ꞏꞏ10 Estos parámetros indican el nombre de las subrutinas que se asocian a las funciones G180 a G189."@es ;
    ex:identificador      "G180-G189" .

ex:Parametro_V_OEMSUB1
    a                     ex:Parametro ;
    rdfs:label            "Variable OEMSUB1 (G18x)"@es ;
    ex:textoExtracto      "Variable asociada: (V.)[ch].MPG.OEMSUB1ꞏꞏ10"@es ;
    ex:identificador      "V.[ch].MPG.OEMSUB1" ;
    ex:monitoreaParametro ex:Subrutina_OEMSUB_G18x .

ex:Parametro_V_OEMSUB10
    a                     ex:Parametro ;
    rdfs:label            "Variable OEMSUB10 (G18x)"@es ;
    ex:textoExtracto      "Variable asociada: (V.)[ch].MPG.OEMSUB1ꞏꞏ10"@es ;
    ex:identificador      "V.[ch].MPG.OEMSUB10" ;
    ex:monitoreaParametro ex:Subrutina_OEMSUB_G18x .