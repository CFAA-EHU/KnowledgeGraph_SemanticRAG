@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_OEMSUB
    a ex:Parametro ;
    rdfs:label "OEMSUB (G38x)" ;
    ex:textoExtracto "OEMSUB (G38x) Subrutinas asociadas a las funciones G380 a G399. Valores posibles: Cualquier texto de hasta 64 caracteres." ;
    ex:identificador "V.[ch].MPG.OEMSUB11ꞏꞏ30" ;
    ex:valor "Nombre de subrutina (hasta 64 caracteres)" .

ex:Parametro_SUBPATH
    a ex:Parametro ;
    rdfs:label "SUBPATH" ;
    ex:textoExtracto "SUBPATH Path de las subrutinas de programa. Este parámetro indica el directorio, por defecto, en que se encuentran las subrutinas de usuario y las subrutinas necesarias para poder ejecutar programas del 8055 MC y 8055 TC." ;
    ex:identificador "V.[ch].MPG.SUBPATH" ;
    ex:valor "Directorio por defecto para subrutinas" .

ex:Subrutina_9998
    a ex:Componente ;
    rdfs:label "Subrutina 9998" ;
    ex:textoExtracto "9998 Rutina que ejecutará el CNC al principio de cada programa." ;
    ex:identificador "9998" .

ex:Subrutina_9999
    a ex:Componente ;
    rdfs:label "Subrutina 9999" ;
    ex:textoExtracto "9999 Rutina que ejecutará el CNC al final de cada programa." ;
    ex:identificador "9999" .

ex:Sistema_8055
    a ex:Sistema ;
    rdfs:label "Sistema 8055 MC/TC" ;
    ex:textoExtracto "Para poder ejecutar programas del 8055 MC/TC, en el CNC deben existir dos subrutinas llamadas 9998 y 9999, escritas en lenguaje del 8070." ;
    ex:tieneComponente ex:Subrutina_9998, ex:Subrutina_9999 .