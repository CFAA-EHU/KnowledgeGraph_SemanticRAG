@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CancelarElAcoplamientoDeEjesPorDefecto a ns1:Parametro ;
    rdfs:label "Cancelar el acoplamiento de ejes por defecto" ;
    ns1:identificador "MPG.LINKCANCEL" ;
    ns1:textoExtracto "LINKCANCEL Cancelar el acoplamiento de ejes por defecto. Valores posibles: Sí / No. Valor por defecto: Sí." .

ns1:CancelarLaImagenEspejoTrasM30YReset a ns1:Parametro ;
    rdfs:label "Cancelar la imagen espejo tras M30 y reset" ;
    ns1:identificador "MPG.MIRRORCANCEL" ;
    ns1:textoExtracto "MIRRORCANCEL Cancelar la imagen espejo (G11/G12/G13/G14) tras M30 y reset. Valores posibles: Sí / No. Valor por defecto: Sí." .

ns1:TipoDeAceleracionPorDefecto a ns1:Parametro ;
    rdfs:label "Tipo de aceleración por defecto" ;
    ns1:identificador "MPG.SLOPETYPE" ;
    ns1:textoExtracto "SLOPETYPE Tipo de aceleración por defecto. Valores posibles: Lineal / Trapezoidal / Seno cuadrado (Square)" .

