@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Subrutina_9998 a ex:Componente ;
    rdfs:label "9998" ;
    ex:textoExtracto "9998 Rutina que ejecutará el CNC al principio de cada programa." ;
    ex:identificador "9998" .

ex:Subrutina_9999 a ex:Componente ;
    rdfs:label "9999" ;
    ex:textoExtracto "9999 Rutina que ejecutará el CNC al final de cada programa." ;
    ex:identificador "9999" .

ex:Sistema_CNC a ex:Maquina ;
    rdfs:label "CNC" ;
    ex:textoExtracto "Para poder ejecutar programas del 8055 MC/TC, en el CNC deben existir dos subrutinas llamadas 9998 y 9999" .