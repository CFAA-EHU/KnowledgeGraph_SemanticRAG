@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SubrutinaInicioProgramaPieza
    a ex:Componente ;
    rdfs:label "Subrutina de inicio de programa pieza" ;
    ex:textoExtracto "rutinas [...] al principio [...] del programa pieza"@es ;
    ex:tieneFrecuencia ex:FrecuenciaEjecucionPrograma .

ex:SubrutinaFinProgramaPieza
    a ex:Componente ;
    rdfs:label "Subrutina de fin de programa pieza" ;
    ex:textoExtracto "rutinas [...] al final del programa pieza"@es ;
    ex:tieneFrecuencia ex:FrecuenciaEjecucionPrograma .

ex:FrecuenciaEjecucionPrograma
    a ex:Frecuencia ;
    rdfs:label "Frecuencia de ejecución por programa pieza" ;
    ex:textoExtracto "cada vez que se intente ejecutar un programa pieza"@es .

ex:InterfazCNC
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de control numérico (CNC)" ;
    ex:textoExtracto "el CNC mostrará un error"@es ;
    ex:activaAlarma ex:AlarmaSubrutinaFaltante .

ex:AlarmaSubrutinaFaltante
    a ex:Alarma ;
    rdfs:label "Alarma por subrutina no definida" ;
    ex:textoExtracto "mostrará un error cada vez que se intente ejecutar un programa pieza"@es .