@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceleracionLineal a ns1:Parametro ;
    rdfs:label "Aceleración lineal" ;
    ns1:documentadoEn ns1:SistemaCNC8070_32ce6ad793 ;
    ns1:textoExtracto "La peor respuesta se consigue con la aceleración lineal." .

ns1:AceleracionSenoCuadrado a ns1:Parametro ;
    rdfs:label "Aceleración seno cuadrado" ;
    ns1:documentadoEn ns1:SistemaCNC8070_32ce6ad793 ;
    ns1:textoExtracto "La aceleración seno cuadrado es una mejora a la aceleración trapezoidal, que suaviza el jerk para que los desplazamientos sean más suaves y sufra menos la mecánica del eje." .

ns1:AceleracionTrapezoidal a ns1:Parametro ;
    rdfs:label "Aceleración trapezoidal" ;
    ns1:documentadoEn ns1:SistemaCNC8070_32ce6ad793 ;
    ns1:textoExtracto "La aceleración trapezoidal permite programar rampas con objeto de suavizar los cambios de aceleración y deceleración." .

ns1:SistemaCNC8070_32ce6ad793 a ns1:Sistema ;
    rdfs:label "Sistema CNC 8070" ;
    ns1:textoExtracto "Para seleccionar una aceleración distinta desde el programa pieza, para el modo automático, utilizar la sentencia #SLOPE." .

