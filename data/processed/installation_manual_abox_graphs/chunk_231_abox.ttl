@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SubrutinaInicio ex:textoExtracto "Ambas rutinas deben estar definidas, aunque no se desee efectuar ninguna operación al principio y final del programa pieza, en cuyo caso las subrutinas estarán vacías (excepto el bloque de fin de subrutina)." ;
    a ex:TareaMantenimiento ;
    ex:identificador "SubrutinaInicio" .

ex:SubrutinaFin ex:textoExtracto "Ambas rutinas deben estar definidas, aunque no se desee efectuar ninguna operación al principio y final del programa pieza, en cuyo caso las subrutinas estarán vacías (excepto el bloque de fin de subrutina)." ;
    a ex:TareaMantenimiento ;
    ex:identificador "SubrutinaFin" .

ex:CNC ex:textoExtracto "el CNC mostrará un error cada vez que se intente ejecutar un programa pieza" ;
    a ex:Maquina ;
    ex:identificador "CNC" .

ex:ProgramaPieza ex:textoExtracto "un programa pieza" ;
    a ex:Componente ;
    ex:identificador "ProgramaPieza" .