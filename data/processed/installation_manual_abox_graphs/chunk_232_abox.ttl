@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PROBEDATA a ex:Parametro ;
    rdfs:label "PROBEDATA" ;
    ex:textoExtracto "PROBEDATA Parámetros del palpador relativos al canal. Este parámetro muestra la tabla para definir la posición del palpador de sobremesa en los tres primeros ejes del canal, según el parámetro CHAXISNAME. La tabla dispone de los siguientes parámetros para su configuración."@es .

ex:ParametroPosicionPalpador a ex:Parametro ;
    rdfs:label "Parámetro de posición del palpador" ;
    ex:textoExtracto "parámetro para definir la posición del palpador de sobremesa en los tres primeros ejes del canal"@es ;
    ex:valor "CHAXISNAME" ;
    ex:textoExtracto "según el parámetro CHAXISNAME"@es .

ex:TablaPosicionPalpador a ex:Tabla ;
    ex:textoExtracto "La tabla para definir la posición del palpador de sobremesa en los tres primeros ejes del canal"@es .