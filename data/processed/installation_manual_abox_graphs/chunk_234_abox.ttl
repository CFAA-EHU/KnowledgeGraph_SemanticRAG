ex:Parametro_PRB1MAX
    a ex:Parametro ;
    rdfs:label "PRB1MAX" ;
    ex:identificador "PRB1MAX" ;
    ex:textoExtracto "Cota máxima del palpador (primer eje del canal). Valores posibles: Entre ±99999.9999 mm / entre ±3937.00787 inch. Valor por defecto: 0." ;
    ex:valor "0"^^xsd:decimal .

