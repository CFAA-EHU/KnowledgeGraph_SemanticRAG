@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjesQueFormanElPlanoDeTrabajo a ns1:Parametro ;
    rdfs:label "Ejes que forman el plano de trabajo" ;
    ns1:identificador "CHAXISNAME" ;
    ns1:textoExtracto "Los ejes que forman el plano de trabajo dependen del parámetro máquina CHAXISNAME." .

ns1:PlanoPrincipalG17G18PorDefecto a ns1:Parametro ;
    rdfs:label "Plano principal (G17/G18) por defecto" ;
    ns1:identificador "MPG.IPLANE" ;
    ns1:textoExtracto "IPLANE Plano principal (G17/G18) por defecto. Valores posibles: G17 / G18. Valor por defecto: G17." .

