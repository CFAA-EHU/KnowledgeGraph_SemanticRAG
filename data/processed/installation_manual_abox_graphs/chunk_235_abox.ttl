@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PRB3MAX a ex:Parametro ;
    rdfs:label "PRB3MAX" ;
    ex:identificador "[ch].MPG.PRB3MAX" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPG.PRB3MAX Consultar el parámetro máquina general PRB3MIN. PRB3MIN Cota mínima del palpador (tercer eje del canal). Valores posibles: Entre ±99999.9999 mm / entre ±3937.00787 inch. Valor por defecto: 0." ;
    ex:valor "Entre ±99999.9999 mm / entre ±3937.00787 inch" .

ex:PRB3MIN a ex:Parametro ;
    rdfs:label "PRB3MIN" ;
    ex:identificador "[ch].MPG.PRB3MIN" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPG.PRB3MIN. PRB3MIN Cota mínima del palpador (tercer eje del canal). Valores posibles: Entre ±99999.9999 mm / entre ±3937.00787 inch. Valor por defecto: 0. Estos parámetros definen la posición que ocupa el palpador de sobremesa que se utiliza para la calibración de herramientas." ;
    ex:valor "Entre ±99999.9999 mm / entre ±3937.00787 inch" .

ex:PalpadorDeSobremesa a ex:Componente ;
    rdfs:label "palpador de sobremesa" ;
    ex:textoExtracto "el palpador de sobremesa que se utiliza para la calibración de herramientas" .

ex:CeroMaquina a ex:Parametro ;
    rdfs:label "cero máquina" ;
    ex:textoExtracto "estarán referidas al cero máquina" .

ex:CNC_Torno a ex:Maquina ;
    rdfs:label "CNC modelo TORNO" ;
    ex:textoExtracto "Si se trata de un CNC modelo TORNO, las cotas deben expresarse en radios." .