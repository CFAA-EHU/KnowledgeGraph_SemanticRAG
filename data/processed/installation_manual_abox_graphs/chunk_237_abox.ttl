@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_1cd684e979 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Configuración de ejes tipo \"plano\". El plano de trabajo siempre es G18; el parámetro máquina IPLANE no se aplica y no se permite cambiar de plano desde el programa pieza, sólo el eje longitudinal (G20). ISYSTEM Tipo de coordenadas (G90/G91) por defecto." ;
    ns1:tieneComponente ns1:TipoDeCoordenadasPorDefecto,
        ns1:TipoDeMovimientoPorDefecto .

ns1:TipoDeCoordenadasPorDefecto a ns1:Parametro ;
    rdfs:label "Tipo de coordenadas por defecto" ;
    ns1:identificador "MPG.ISYSTEM" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.ISYSTEM Este parámetro indica el tipo de coordenadas que asume el CNC por defecto." .

ns1:TipoDeMovimientoPorDefecto a ns1:Parametro ;
    rdfs:label "Tipo de movimiento por defecto" ;
    ns1:identificador "IMOVE" ;
    ns1:textoExtracto "IMOVE Tipo de movimiento (G0/G1) por defecto. Valores posibles: G0 / G1. Valor por defecto: G01." .

