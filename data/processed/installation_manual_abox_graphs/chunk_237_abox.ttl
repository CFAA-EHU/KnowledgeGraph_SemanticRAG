@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:FUNPLC a ex:Parametro ;
    rdfs:label "FUNPLC" ;
    ex:textoExtracto "FUNPLC Enviar las funciones M, H, S al PLC en la búsqueda de bloque. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPG.FUNPLC" ;
    ex:valor "No" ;
    ex:identificador "FUNPLC" .

ex:Parametro_MPG_FUNPLC a ex:Parametro ;
    rdfs:label "MPG.FUNPLC" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPG.FUNPLC" ;
    ex:identificador "[ch].MPG.FUNPLC" .

ex:Tabla_Funciones_M a ex:Tabla ;
    ex:textoExtracto "La tabla de funciones M dispone del campo MPLC para definir si el CNC envía o no la función al PLC." .

ex:Campo_MPLC a ex:Parametro ;
    rdfs:label "MPLC" ;
    ex:textoExtracto "La tabla de funciones M dispone del campo MPLC para definir si el CNC envía o no la función al PLC." ;
    ex:identificador "MPLC" .

ex:Softkey_MHSF a ex:InterfazUsuario ;
    rdfs:label "MHSF" ;
    ex:textoExtracto "el CNC muestra la softkey \"MHSF\" para poder ejecutar cualquier función de este tipo" ;
    ex:identificador "MHSF" .

ex:Parametro_FUNPLC_Si a ex:Parametro ;
    rdfs:label "FUNPLC=Sí" ;
    ex:textoExtracto "Sí | En este caso las funciones se envían al PLC durante la búsqueda de bloque, a medida que se van leyendo." ;
    ex:valor "Sí" .

ex:Parametro_FUNPLC_No a ex:Parametro ;
    rdfs:label "FUNPLC=No" ;
    ex:textoExtracto "No | En este caso las funciones no se envían al PLC durante la búsqueda de bloque." ;
    ex:valor "No" .