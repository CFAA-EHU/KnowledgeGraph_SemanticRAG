@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioDelTipoDeMovimientoDesdeElProgramaPieza a ns1:TareaMantenimiento ;
    rdfs:label "Cambio del tipo de movimiento desde el programa pieza" ;
    ns1:textoExtracto "Para cambiarlo desde el programa pieza utilizar las funciones G0 ó G1." .

ns1:TipoDeMovimientoG0G1PorDefecto a ns1:Parametro ;
    rdfs:label "Tipo de movimiento (G0/G1) por defecto" ;
    ns1:identificador "MPG.IMOVE" ;
    ns1:textoExtracto "IMOVE Tipo de movimiento (G0/G1) por defecto. Valores posibles: G0 / G1. Valor por defecto: G01." .

