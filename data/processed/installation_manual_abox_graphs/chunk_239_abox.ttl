@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_b8393bdc6d a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:ConfiguracionDeG0MODAL ;
    ns1:monitoreaParametro ns1:AvanceRapidoDefinidoEnElParametroG00FEED,
        ns1:MantenerLaFuncionG0ModalONo ;
    ns1:textoExtracto "El CNC asume la función G0. Los desplazamientos en G0 se realizan al avance rápido definido en el parámetro G00FEED." .

ns1:AvanceRapidoDefinidoEnElParametroG00FEED a ns1:Parametro ;
    rdfs:label "Avance rápido definido en el parámetro G00FEED" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "Los desplazamientos en G0 se realizan al avance rápido definido en el parámetro G00FEED." .

ns1:ConfiguracionDeG0MODAL a ns1:TareaMantenimiento ;
    rdfs:label "Configuración de G0MODAL" ;
    ns1:textoExtracto "Parámetro G0MODAL; mantener la función G0 modal o no. El valor IMOVE=G0 tiene prioridad sobre G0MODAL=No." .

ns1:MantenerLaFuncionG0ModalONo a ns1:Parametro ;
    rdfs:label "Mantener la función G0 modal o no" ;
    ns1:identificador "MPG.G0MODAL" ;
    ns1:textoExtracto "Parámetro G0MODAL; mantener la función G0 modal o no." .

