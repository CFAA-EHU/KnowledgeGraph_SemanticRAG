@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_MPG_DEFAULTFEED a ex:Parametro ;
    rdfs:label "MPG.DEFAULTFEED" ;
    ex:identificador "(V.)[ch].MPG.DEFAULTFEED" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPG.DEFAULTFEED Este parámetro determina si los ejes se desplazan al avance definido en MAXFEED cuando se programa un movimiento en G01/G02/G03 sin programar el avance." ;
    ex:valor "No" .

ex:Parametro_MAXFEED a ex:Parametro ;
    rdfs:label "MAXFEED" ;
    ex:textoExtracto "El CNC sólo tiene en cuenta este parámetro cuando se ha definido MAXFEED con un valor distinto de ꞏ0ꞏ." ;
    ex:valor "0" .