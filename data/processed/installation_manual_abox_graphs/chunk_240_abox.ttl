@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_2405f6d053 a ns1:Parametro ;
    rdfs:label "Función G00 modal" ;
    ns1:identificador "G0MODAL" ;
    ns1:textoExtracto "La función G00 es modal. Una vez programada permanece activa hasta que se programe G01, G02, G03, G33 o G63." .

ns1:TipoDeMovimientoG0G1EnElArranqueTrasUnResetOM30 a ns1:Parametro ;
    rdfs:label "Tipo de movimiento (G0/G1) en el arranque, tras un reset o M30" ;
    ns1:identificador "IMOVE" ;
    ns1:textoExtracto "Parámetro IMOVE; tipo de movimiento (G0/G1) en el arranque, tras un reset o M30. El valor IMOVE=G0 tiene prioridad sobre G0MODAL=No." .

