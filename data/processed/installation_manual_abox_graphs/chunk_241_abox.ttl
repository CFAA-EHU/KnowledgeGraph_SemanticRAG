@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_RAPIDEN
    a ex:Parametro ;
    rdfs:label "RAPIDEN" ;
    ex:textoExtracto "RAPIDEN Permitir habilitar el avance rápido para el modo automático. Valores posibles: Deshabilitado / EXRAPID o tecla rápido / EXRAPID y tecla rápido. Valor por defecto: Deshabilitado."@es ;
    ex:identificador "V.[ch].MPG.RAPIDEN" ;
    ex:valor "Deshabilitado" .

ex:ModoOperacion_AvanceRapidoAutomatico
    a ex:ModoOperacion ;
    rdfs:label "Avance rápido para modo automático" ;
    ex:textoExtracto "Este parámetro indica si se permite habilitar el avance rápido durante la ejecución de un programa, para los desplazamientos programados."@es ;
    ex:habilitadoPor ex:Parametro_RAPIDEN .