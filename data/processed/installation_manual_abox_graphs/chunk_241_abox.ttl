@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_RAPIDEN a ex:Parametro ;
    rdfs:label "RAPIDEN" ;
    ex:identificador "(V.)[ch].MPG.RAPIDEN" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPG.RAPIDEN Este parámetro indica si se permite habilitar el avance rápido durante la ejecución de un programa, para los desplazamientos programados." ;
    ex:valor "Deshabilitado / EXRAPID o tecla rápido / EXRAPID y tecla rápido" .

ex:ModoOperacion_AvanceRapido a ex:ModoOperacion ;
    rdfs:label "avance rápido" ;
    ex:textoExtracto "habilitar el avance rápido para el modo automático" .

ex:Sistema_ControlAvanceRapido a ex:Sistema ;
    ex:textoExtracto "Este parámetro indica si se permite habilitar el avance rápido durante la ejecución de un programa, para los desplazamientos programados." ;
    ex:compuestoPor ex:Parametro_RAPIDEN ;
    ex:controla ex:ModoOperacion_AvanceRapido .