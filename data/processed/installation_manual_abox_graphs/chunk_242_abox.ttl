@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoOperacion_242_1 a ex:ModoOperacion ;
    ex:textoExtracto "El avance rápido no está disponible para el modo automático." ;
    rdfs:label "modo automático" .

ex:InterfazUsuario_242_2 a ex:InterfazUsuario ;
    ex:textoExtracto "pulsar la tecla \"rápido\" del panel de jog" ;
    rdfs:label "tecla rápido del panel de jog" .

ex:Parametro_242_3 a ex:Parametro ;
    ex:identificador "EXRAPID" ;
    ex:textoExtracto "activar la marca EXRAPID de PLC" ;
    rdfs:label "marca EXRAPID de PLC" .

ex:Sistema_242_4 a ex:Sistema ;
    ex:textoExtracto "Para activar el avance rápido hay que activar la marca EXRAPID de PLC y pulsar la tecla \"rápido\" del panel de jog." ;
    ex:tieneComponente ex:Parametro_242_3, ex:InterfazUsuario_242_2 .