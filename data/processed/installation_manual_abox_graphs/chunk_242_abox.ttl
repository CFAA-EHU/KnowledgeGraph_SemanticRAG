@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceEnMmMinGradosMinOInchMin a ns1:Parametro ;
    rdfs:label "Avance en mm/min, grados/min o inch/min" ;
    ns1:identificador "G94" ;
    ns1:textoExtracto "Con G94 el avance se asume en mm/min, grados/min o inch/min." .

ns1:AvanceEnMmRevGradosRevOInchRev a ns1:Parametro ;
    rdfs:label "Avance en mm/rev, grados/rev o inch/rev" ;
    ns1:identificador "G95" ;
    ns1:textoExtracto "Con G95 el avance se asume en mm/rev, grados/rev o inch/rev." .

ns1:CNC8070_682f3d3886 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "el CNC aplica G1." .

ns1:TipoDeAvancePorDefecto a ns1:Parametro ;
    rdfs:label "Tipo de avance por defecto" ;
    ns1:identificador "MPG.IFEED" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.IFEED Este parámetro indica el tipo de avance que asume el CNC por defecto." .

