@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionDeAvance a ns1:TareaMantenimiento ;
    rdfs:label "Configuración de avance" ;
    ns1:textoExtracto "Para cambiar el tipo de avance desde el programa pieza utilizar las funciones G94 ó G95." .

ns1:Parametro_82dced9a89 a ns1:Parametro ;
    rdfs:label "Función G95 permitida en modo manual" ;
    ns1:identificador "MPG.FPRMAN" ;
    ns1:textoExtracto "FPRMAN Función G95 permitida en modo manual. Valores posibles: Sí / No. Valor por defecto: Sí." .

