@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvancePorMinutoEnModoManual a ns1:Parametro ;
    rdfs:label "Avance por minuto en modo manual" ;
    ns1:identificador "G.FMAN" ;
    ns1:textoExtracto "(V.)G.FMAN (avance por minuto) para movimientos en jog." .

ns1:AvancePorVueltaEnModoAutomatico a ns1:Parametro ;
    rdfs:label "Avance por vuelta en modo automático" ;
    ns1:identificador "G.PRGFPR" ;
    ns1:textoExtracto "(V.)G.PRGFPR (avance por vuelta) para modo automático." .

ns1:CNC8070_86e3f19d68 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC aplica la función G95 a los ejes principales del canal;" .

ns1:ModoDeCompensacionDeRadioPorDefecto a ns1:Parametro ;
    rdfs:label "Modo de compensación de radio por defecto" ;
    ns1:identificador "[ch].MPG.IRCOMP" ;
    ns1:textoExtracto "Este parámetro indica el modo de compensación que asume el CNC en el momento de encendido, después de ejecutarse M02, M30 o después de reset." .

ns1:Parametro_2ea8ead690 a ns1:Parametro ;
    rdfs:label "Función G95 (avance por vuelta)" ;
    ns1:textoExtracto "Se permite la función G95 (avance por vuelta) para los movimientos en jog desde el modo manual." .

ns1:Parametro_3a23f004a7 a ns1:Parametro ;
    rdfs:label "Función G94 (avance por minuto)" ;
    ns1:textoExtracto "los movimientos en jog serán en G94 (avance por minuto)." .

