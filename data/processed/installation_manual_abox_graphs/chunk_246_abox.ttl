@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsumirIPLANEComoPlanoActivoTrasM30RESETOMantenerElActivo a ns1:Parametro ;
    rdfs:label "Asumir IPLANE como plano activo tras M30/RESET o mantener el activo"@es ;
    ns1:identificador "PLANECANCEL" ;
    ns1:textoExtracto "PLANECANCEL Asumir IPLANE como plano activo tras M30/RESET o mantener el activo. Valores posibles: Sí / No. Valor por defecto: Sí." .

ns1:MantenerElEjeLongitudinalAlCambiarPlanoG17G18G19 a ns1:Parametro ;
    rdfs:label "Mantener el eje longitudinal al cambiar plano (G17/G18/G19)"@es ;
    ns1:identificador "MPG.LCOMPTYPE" ;
    ns1:textoExtracto "LCOMPTYP Mantener el eje longitudinal al cambiar plano (G17/G18/G19). Valores posibles: Sí / No. Valor por defecto: No." .

