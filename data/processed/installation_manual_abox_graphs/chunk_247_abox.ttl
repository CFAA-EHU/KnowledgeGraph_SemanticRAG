@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:V_G_MAXJERK a ex:Parametro ;
    rdfs:label "V.G.MAXJERK" ;
    ex:textoExtracto "La variable (V.)[ch].G.MAXJERK permite modificar temporalmente, en un momento dado y en tiempo real, el valor definido por el parámetro máquina." ;
    ex:valor "0" ;
    ex:textoExtracto "Si la variable toma valor ꞏ0ꞏ, el CNC no aplica ningún límite al jerk sobre la trayectoria, ni" .

ex:ParametroMaquina_Jerk a ex:Parametro ;
    ex:textoExtracto "el valor definido por el parámetro máquina" .

ex:CNC a ex:Maquina ;
    ex:textoExtracto "El CNC asume el cambio inmediatamente y permanece activo hasta ejecutar M30 o reset, en cuyo caso el CNC recupera el valor fijado por el parámetro máquina." .

ex:AccionReset a ex:AccionProhibida ;
    ex:textoExtracto "hasta ejecutar M30 o reset, en cuyo caso el CNC recupera el valor fijado por el parámetro máquina." .