@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CondicionPorDefectoDelPlano a ns1:Parametro ;
    rdfs:label "Condición por defecto del plano" ;
    ns1:identificador "PLANECANCEL" ;
    ns1:textoExtracto "En el momento del encendido, después de ejecutar M02 ó M30, y después de un reset, el CNC asume el plano definido en el parámetro IPLANE." .

ns1:PlanoDefinidoPorDefecto a ns1:Parametro ;
    rdfs:label "Plano definido por defecto" ;
    ns1:identificador "IPLANE" ;
    ns1:textoExtracto "el CNC asume el plano definido en el parámetro IPLANE." .

