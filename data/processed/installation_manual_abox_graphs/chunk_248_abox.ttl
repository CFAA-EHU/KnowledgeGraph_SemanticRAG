@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_Maquina_248 a ex:Parametro ;
    rdfs:label "parámetro máquina" ;
    ex:textoExtracto "el parámetro máquina" .

ex:Variable_Jerk_Trayectoria_248 a ex:Parametro ;
    rdfs:label "variable de jerk sobre la trayectoria" ;
    ex:textoExtracto "la variable toma valor ꞏ0ꞏ, el CNC no aplica ningún límite al jerk sobre la trayectoria, ni siquiera el fijado por parámetro máquina" .

ex:Accion_M30_Reset_248 a ex:AccionProhibida ;
    rdfs:label "ejecutar M30 o reset" ;
    ex:textoExtracto "hasta ejecutar M30 o reset" .

ex:Sistema_CNC_248 a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "el CNC recupera el valor fijado por el parámetro máquina" ;
    ex:controla ex:Variable_Jerk_Trayectoria_248 .