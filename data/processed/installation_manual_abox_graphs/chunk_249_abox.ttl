@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MAXFREQ a ex:Parametro ;
    ex:identificador "MAXFREQ" ;
    ex:textoExtracto "MAXFREQ Máxima frecuencia generada sobre la trayectoria de mecanizado. Valores posibles: De 0 a 500 Hz. Valor por defecto: 0. Variable asociada: (V.)[ch].MPG.MAXFREQ Este parámetro permite parametrizar el filtro de suavizado para el mecanizado en G5. El filtro mejora el mecanizado de piezas CAD sin necesidad de activar la prestación HSC. Este parámetro se debe ajustar con ayuda de la aplicación FineTune." ;
    rdfs:label "MAXFREQ Máxima frecuencia generada sobre la trayectoria de mecanizado" .

ex:Parametro_FiltroSuavizado a ex:Parametro ;
    ex:textoExtracto "Este parámetro permite parametrizar el filtro de suavizado para el mecanizado en G5." ;
    rdfs:label "Parámetro de filtro de suavizado para mecanizado en G5" .

ex:Aplicacion_FineTune a ex:InterfazUsuario ;
    ex:textoExtracto "Este parámetro se debe ajustar con ayuda de la aplicación FineTune." ;
    rdfs:label "Aplicación FineTune" .