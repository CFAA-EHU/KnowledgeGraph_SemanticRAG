@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:RETRACAC a ex:Parametro ;
    rdfs:label "RETRACAC" ;
    ex:identificador "(V.)[ch].MPG.RETRACAC" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPG.RETRACAC Este parámetro indica si se permite utilizar la función retrace en el CNC." ;
    ex:valor "Sí / No" ;
    ex:valor "No" .

ex:NRETBLK a ex:Parametro ;
    rdfs:label "NRETBLK" ;
    ex:identificador "(V.)[ch].MPG.NRETBLK" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPG.NRETBLK Este parámetro establece el máximo número de bloques que se pueden retroceder con la función retrace." ;
    ex:valor "De 0 a 300" ;
    ex:valor "75" .

ex:RETMFUNC a ex:Parametro ;
    rdfs:label "RETMFUNC" ;
    ex:identificador "(V.)[ch].MPG.RETMFUNC" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPG.RETMFUNC Este parámetro establece el comportamiento de la función retrace cuando se ejecutan funciones M." ;
    ex:valor "Ignorar / Cancelar" ;
    ex:valor "Ignorar" .