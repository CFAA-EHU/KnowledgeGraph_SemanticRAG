@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorAbsolutoMaximoPermitidoEnElRadio a ns1:Parametro ;
    rdfs:label "Error absoluto máximo permitido en el radio" ;
    ns1:identificador "MPG.CIRINERR" ;
    ns1:textoExtracto "Error absoluto máximo permitido en el radio" ;
    ns1:valor "0.0100 mm o grados / 0.00039 inch"^^ns1:textoExtracto .

ns1:ErrorRelativoMaximoPermitidoEnElRadio a ns1:Parametro ;
    rdfs:label "Error relativo máximo permitido en el radio" ;
    ns1:identificador "MPG.CIRINFACT" ;
    ns1:textoExtracto "Error relativo máximo permitido en el radio" ;
    ns1:valor "0.1 %"^^ns1:textoExtracto .

