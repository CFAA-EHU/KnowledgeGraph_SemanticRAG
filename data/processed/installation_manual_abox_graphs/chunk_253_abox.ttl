@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MASTERSPDL a ex:Parametro ;
    rdfs:label "MASTERSPDL" ;
    ex:identificador "MASTERSPDL" ;
    ex:textoExtracto "MASTERSPDL Cabezal master mantenido. Valores posibles: Temporal / Mantenido. Valor por defecto: Temporal. Variable asociada: (V.)[ch].MPG.MASTERSPDL Este parámetro indica si el canal mantiene el cabezal master actual o recupera su cabezal master original, tras ejecutar M02, M30, después de una emergencia o reset y tras reiniciar el CNC." ;
    ex:valor "Temporal / Mantenido" .

ex:ModoOperacionTemporal a ex:ModoOperacion ;
    rdfs:label "Temporal" ;
    ex:textoExtracto "Temporal. El canal recupera su cabezal master original si está libre; sino, selecciona como master el primer cabezal disponible de la configuración original." .

ex:ModoOperacionMantenido a ex:ModoOperacion ;
    rdfs:label "Mantenido" ;
    ex:textoExtracto "Mantenido. El canal mantiene el cabezal master activo." .

ex:AXISEXCH a ex:Parametro ;
    rdfs:label "AXISEXCH" ;
    ex:textoExtracto "En una situación con intercambio de cabezales entre canales, el comportamiento de este parámetro también depende del parámetro AXISEXCH, el cual define si el cambio de canal de un cabezal es temporal o permanente." ;
    ex:valor "Temporal / Permanente" .

ex:ModoOperacionTemporalAXISEXCH a ex:ModoOperacion ;
    rdfs:label "Temporal" ;
    ex:textoExtracto "Si el permiso de cambio de canal es temporal (AXISEXCH=Temporal), el cabezal vuelve a su canal original." .