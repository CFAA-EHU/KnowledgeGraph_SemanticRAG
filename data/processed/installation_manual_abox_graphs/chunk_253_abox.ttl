@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorAbsolutoMaximoPermitido a ns1:Parametro ;
    rdfs:label "error absoluto máximo permitido" ;
    ns1:textoExtracto "El parámetro CIRINERR indica el error absoluto máximo permitido." .

ns1:ErrorRelativoMaximoPermitidoDelRadio a ns1:Parametro ;
    rdfs:label "error relativo máximo permitido (% del radio)" ;
    ns1:textoExtracto "El parámetro CIRINFACT indica el error relativo máximo permitido (% del radio)." .

