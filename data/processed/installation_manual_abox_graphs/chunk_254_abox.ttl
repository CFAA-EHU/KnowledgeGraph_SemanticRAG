@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AplicarElAvanceProgramadoATodosLosEjesDelCanal a ns1:Parametro ;
    rdfs:label "Aplicar el avance programado a todos los ejes del canal" ;
    ns1:identificador "MPG.FEEDND" ;
    ns1:textoExtracto "FEEDND Aplicar el avance programado a todos los ejes del canal. Valores posibles: Sí / No. Valor por defecto: No." .

ns1:OverrideMaximoPermitidoDelAvanceProgramado a ns1:Parametro ;
    rdfs:label "Override máximo permitido del avance programado" ;
    ns1:identificador "MPG.MAXOVR" ;
    ns1:textoExtracto "MAXOVR Override (%) máximo permitido. Valores posibles: De 0 a 255. Valor por defecto: 200." .

ns1:PermitirModificacionDelPorcentajeDeAvanceEnG0 a ns1:Parametro ;
    rdfs:label "Permitir modificación del porcentaje de avance en G0" ;
    ns1:identificador "MPG.RAPIDOVR" ;
    ns1:textoExtracto "RAPIDOVR Override actúa en G00 (entre 0 y 100%). Valores posibles: Sí / No. Valor por defecto: Sí." .

