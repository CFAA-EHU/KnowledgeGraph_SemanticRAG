@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComportamientoDelAvanceYDelFeedOverride a ns1:Parametro ;
    rdfs:label "Comportamiento del avance y del feed override" ;
    ns1:identificador "FEEDND" ;
    ns1:textoExtracto "El avance programado será la resultante de componer los movimientos sobre todos los ejes del canal." .

ns1:LimiteMaximoDeVelocidadDeAvance a ns1:Parametro ;
    rdfs:label "Límite máximo de velocidad de avance" ;
    ns1:identificador "MAXFEED" ;
    ns1:textoExtracto "Sólo se limita el avance programado si algún eje pudiera sobrepasar su MAXFEED." .

