@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoOperacionNo ex:textoExtracto """No.""" ;
    rdfs:label "No" ;
    a ex:ModoOperacion .

ex:ModoOperacionTemporal ex:textoExtracto """Temporal.""" ;
    rdfs:label "Temporal" ;
    a ex:ModoOperacion .

ex:ModoOperacionMantenido ex:textoExtracto """Mantenido.""" ;
    rdfs:label "Mantenido" ;
    a ex:ModoOperacion .

ex:ParametroMaquina ex:textoExtracto """parámetros máquina""" ;
    rdfs:label "parámetros máquina" ;
    a ex:Parametro .

ex:ParametroMaquinaOriginal ex:textoExtracto """configuración original (la definida en los parámetros máquina) de un canal con ejes y cabezales del tipo AXISEXCH=Mantenido""" ;
    rdfs:label "configuración original de canal AXISEXCH=Mantenido" ;
    a ex:Parametro .