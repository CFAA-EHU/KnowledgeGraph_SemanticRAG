@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_98972b3bcd a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Si ambos parámetros MINDYNOVR y MAXDYNOVR se definen con valor 100 %, el CNC no muestra la barra y no será posible cambiar en tiempo real la dinámica del mecanizado." .

ns1:MaximoOverrideDinamicoParaTodosLosEjesDelCanal a ns1:Parametro ;
    rdfs:label "Máximo override dinámico para todos los ejes del canal" ;
    ns1:identificador "MPG.MAXDYNOVR" ;
    ns1:textoExtracto "MAXDYNOVR Máximo override dinámico para todos los ejes del canal. Valores posibles: De 100 a 500 %. Valor por defecto: 200 %." .

ns1:MinimoOverrideDinamicoParaTodosLosEjesDelCanal a ns1:Parametro ;
    rdfs:label "Mínimo override dinámico para todos los ejes del canal" ;
    ns1:identificador "MPG.MINDYNOVR" ;
    ns1:textoExtracto "MINDYNOVR Mínimo override dinámico para todos los ejes del canal. Valores posibles: De 10 a 100 %. Valor por defecto: 30 %." .

