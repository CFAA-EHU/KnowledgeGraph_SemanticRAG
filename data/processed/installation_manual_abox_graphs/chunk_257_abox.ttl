@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:AXISTYPE a ex:Parametro ;
    rdfs:label "AXISTYPE" ;
    ex:textoExtracto "AXISTYPE Tipo de eje. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Lineal / Rotativo / Cabezal. Valor por defecto: Lineal. Variable asociada: (V.)[ch].MPA.AXISTYPE.xn" ;
    ex:valor "Lineal / Rotativo / Cabezal" ;
    ex:identificador "(V.)[ch].MPA.AXISTYPE.xn" .

ex:DRIVETYPE a ex:Parametro ;
    rdfs:label "DRIVETYPE" ;
    ex:textoExtracto "DRIVETYPE Tipo de regulador. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos, Mlink (Mechatrolink) y simulado. Valores posibles: Analógico / Sercos / Mlink / Simulado. Valor por defecto: Simulado. Variable asociada: (V.)[ch].MPA.DRIVETYPE.xn Este parámetro establece el tipo de regulador, a saber analógico, Sercos, Mlink (Mechatrolink) o simulado." ;
    ex:valor "Analógico / Sercos / Mlink / Simulado" ;
    ex:identificador "(V.)[ch].MPA.DRIVETYPE.xn" .

ex:POSUNITS a ex:Parametro ;
    rdfs:label "POSUNITS" ;
    ex:textoExtracto "POSUNITS Unidades del sistema de captación." .