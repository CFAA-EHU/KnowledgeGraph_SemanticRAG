@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ExcesoPorcentualDePotenciaParaMonitorizarLosPicosDePotenciaEnElDMC a ns1:Parametro ;
    rdfs:label "Exceso porcentual de potencia para monitorizar los picos de potencia en el DMC" ;
    ns1:identificador "MPG.DMCPEAKSIZE" ;
    ns1:textoExtracto "DMCPEAKSIZE Exceso porcentual de potencia para monitorizar los picos de potencia en el DMC. Valores posibles: De 0 a 100 %. Valor por defecto: 20 %." .

ns1:MaximoOverrideDMCDeTodosLosEjesDelCanal a ns1:Parametro ;
    rdfs:label "Máximo override DMC de todos los ejes del canal" ;
    ns1:identificador "MPG.MAXDMCOVR" ;
    ns1:textoExtracto "MAXDMCOVR Máximo override DMC de todos los ejes del canal. Valores posibles: De 100 a 255 %. Valor por defecto: 120 %." .

ns1:MinimoOverrideDMCDeTodosLosEjesDelCanal a ns1:Parametro ;
    rdfs:label "Mínimo override DMC de todos los ejes del canal" ;
    ns1:identificador "MPG.MINDMCOVR" ;
    ns1:textoExtracto "MINDMCOVR Mínimo override DMC de todos los ejes del canal. Valores posibles: De 10 a 100 %. Valor por defecto: 80 %." .

