@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_0da8509f2a a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:MarcaDMCPWRHOLD,
        ns1:MarcaDMCPWRPEAK ;
    ns1:textoExtracto "el CNC muestra un warning y activa la marca DMCPWRHOLD. Este parámetro permite detectar un consumo excesivo de potencia que puede ser debido a un desgaste de herramienta." .

ns1:FactorMultiplicadorDeLaPotenciaObjetivo a ns1:Parametro ;
    rdfs:label "Factor multiplicador de la potencia objetivo" ;
    ns1:identificador "DMCPWRFACTOR" ;
    ns1:textoExtracto "DMCPWRFACTOR Factor multiplicador de la potencia objetivo, para monitorizar el exceso de potencia consumida en el DMC." ;
    ns1:valor "2.0" .

ns1:FactorMultiplicadorDeLaPotenciaObjetivoVChMPGDMCPWRFACTOR a ns1:Parametro ;
    rdfs:label "Factor multiplicador de la potencia objetivo (V.[ch].MPG.DMCPWRFACTOR)" ;
    ns1:identificador "MPG.DMCPWRFACTOR" ;
    ns1:textoExtracto "(V.)[ch].MPG.DMCPWRFACTOR Factor multiplicador de la potencia objetivo, para considerar excesiva de potencia consumida." .

ns1:Herramienta a ns1:Herramienta ;
    rdfs:label "Herramienta" ;
    ns1:textoExtracto "Este parámetro permite detectar un pico de potencia, que puede ser debido a la rotura de la herramienta, profundización de pasada demasiado grande, etc." .

ns1:MarcaDMCPWRHOLD a ns1:AvisoSeguridad ;
    rdfs:label "Marca DMCPWRHOLD" ;
    ns1:textoExtracto "el CNC muestra un warning y activa la marca DMCPWRHOLD. Este parámetro permite detectar un consumo excesivo de potencia que puede ser debido a un desgaste de herramienta." .

ns1:MarcaDMCPWRPEAK a ns1:AvisoSeguridad ;
    rdfs:label "Marca DMCPWRPEAK" ;
    ns1:textoExtracto "activa la marca DMCPWRPEAK. Este parámetro permite detectar un pico de potencia, que puede ser debido a la rotura de la herramienta, profundización de pasada demasiado grande, etc." .

