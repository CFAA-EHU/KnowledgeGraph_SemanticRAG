@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Frecuencia_260_1 a ex:Frecuencia ;
    rdfs:label "Medición" ;
    ex:textoExtracto "La comunicación con el regulador se realiza en milímetros o grados." ;
    ex:valor "milímetros o grados" .

ex:Frecuencia_260_2 a ex:Frecuencia ;
    rdfs:label "Pulsos" ;
    ex:textoExtracto "La comunicación con el regulador se realiza en pulsos." ;
    ex:valor "pulsos" .