@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_PosUnits_260 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de unidades de posición (POSUNITS)"@es ;
    ex:textoExtracto "Medición. | La comunicación con el regulador se realiza en milímetros o grados. Pulsos. | La comunicación con el regulador se realiza en pulsos."@es ;
    ex:documentadoEn ex:Manual_Principal .

ex:Parametro_Medicion_MilimetrosGrados
    a ex:Parametro ;
    rdfs:label "Unidad de medición (milímetros/grados)"@es ;
    ex:textoExtracto "La comunicación con el regulador se realiza en milímetros o grados."@es ;
    ex:valor "milímetros/grados"@es ;
    ex:documentadoEn ex:Tabla_PosUnits_260 .

ex:Parametro_Pulsos
    a ex:Parametro ;
    rdfs:label "Unidad de pulsos"@es ;
    ex:textoExtracto "La comunicación con el regulador se realiza en pulsos."@es ;
    ex:valor "pulsos"@es ;
    ex:documentadoEn ex:Tabla_PosUnits_260 .