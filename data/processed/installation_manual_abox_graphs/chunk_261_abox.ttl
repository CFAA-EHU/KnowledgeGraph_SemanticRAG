@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SERCOSDATA
    a               ex:Parametro ;
    rdfs:label      "SERCOSDATA" ;
    ex:textoExtracto "SERCOSDATA Datos del regulador Sercos. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos." ;
    ex:identificador "SERCOSDATA" .

ex:Tabla_ConfiguracionSercos a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de configuración del regulador Sercos" ;
    ex:textoExtracto "Este parámetro muestra la tabla para definir la comunicación con el regulador Sercos." ;
    ex:documentadoEn ex:Parametro_SERCOSDATA .