@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_ec779a1644 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Con el CNC en modo USER, las rutinas OEM cuya extensión sea .fst, se cargan en la memoria RAM en el arranque de la aplicación CNC." ;
    ns1:tieneComponente ns1:TablaSubrutinasFabricante .

ns1:ModoSetup a ns1:ModoOperacion ;
    rdfs:label "SETUP" ;
    ns1:textoExtracto "Con el CNC en modo SETUP (puesta a punto), las rutinas OEM cuya extensión sea .fst se cargarán en la memoria RAM la primera vez que se ejecutan dentro del programa." .

ns1:ModoUser a ns1:ModoOperacion ;
    rdfs:label "USER" ;
    ns1:textoExtracto "Con el CNC en modo USER, las rutinas OEM cuya extensión sea .fst, se cargan en la memoria RAM en el arranque de la aplicación CNC." .

ns1:SubrutinaCambioHerramienta a ns1:Componente ;
    rdfs:label "Subrutina de cambio de herramienta" ;
    ns1:textoExtracto "Las subrutinas de fabricante son aquellas guardadas la carpeta ..\\MTB\\Sub. Estas subrutinas están asociadas a algunas funciones del CNC como el cambio de herramienta, G74, G180 a G189, G380 a G399, etc." .

ns1:TablaSubrutinasFabricante a ns1:Tabla ;
    rdfs:label "Tabla de subrutinas del fabricante" ;
    ns1:textoExtracto "SUBTABLE Tabla de subrutinas del fabricante. Las subrutinas de fabricante son aquellas guardadas la carpeta ..\\MTB\\Sub." .

