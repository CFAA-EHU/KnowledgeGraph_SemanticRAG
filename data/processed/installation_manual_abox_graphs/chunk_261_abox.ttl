@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ReguladorSercos_261 a ex:ComponenteElectrico ;
    rdfs:label "regulador Sercos"@es ;
    ex:textoExtracto "SERCOSDATA Datos del regulador Sercos. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos. Este parámetro muestra la tabla para definir la comunicación con el regulador Sercos."@es .

ex:TablaComunicacionSercos_261 a ex:Tabla ;
    ex:textoExtracto "Este parámetro muestra la tabla para definir la comunicación con el regulador Sercos."@es ;
    ex:detalladoEnEsquema ex:ReguladorSercos_261 .