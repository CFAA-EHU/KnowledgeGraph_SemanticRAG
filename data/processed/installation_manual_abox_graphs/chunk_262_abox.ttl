@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ReguladorSercos_262 a ex:Sistema ;
    ex:textoExtracto "Configurar un regulador Sercos" ;
    ex:compuestoPor ex:Parametro_SERCOSDATA_DRIVEID, ex:Parametro_SERCOSDATA_OPMODEP, ex:Parametro_SERCOSDATA_FBACKSRC, ex:Parametro_SERCOSDATA_FBACKDIFF, ex:Parametro_SERCOSDATA_ULTRAIPO, ex:Parametro_SERCOSDATA_FBACKTIME .

ex:Parametro_SERCOSDATA_DRIVEID a ex:Parametro ;
    ex:identificador "DRIVEID" ;
    ex:textoExtracto "Dirección del regulador Sercos." .

ex:Parametro_SERCOSDATA_OPMODEP a ex:Parametro ;
    ex:identificador "OPMODEP" ;
    ex:textoExtracto "Modo de operación principal del regulador Sercos." .

ex:Parametro_SERCOSDATA_FBACKSRC a ex:Parametro ;
    ex:identificador "FBACKSRC" ;
    ex:textoExtracto "Tipo de captación." .

ex:Parametro_SERCOSDATA_FBACKDIFF a ex:Parametro ;
    ex:identificador "FBACKDIFF" ;
    ex:textoExtracto "Máxima diferencia entre captaciones." .

ex:Parametro_SERCOSDATA_ULTRAIPO a ex:Parametro ;
    ex:identificador "ULTRAIPO" ;
    ex:textoExtracto "Parámetro actualmente sin función." .

ex:Parametro_SERCOSDATA_FBACKTIME a ex:Parametro ;
    ex:identificador "FBACKTIME" ;
    ex:textoExtracto "Constante de tiempo para la captación mixta." .