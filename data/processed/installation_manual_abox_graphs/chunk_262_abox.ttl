@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SubrutinaAsociadaALaFuncionG74 a ns1:Parametro ;
    rdfs:label "Subrutina asociada a la función G74" ;
    ns1:identificador "MPG.REFPSUB" ;
    ns1:textoExtracto "\"(V.)[ch].MPG.REFPSUB La función G74 (búsqueda de referencia máquina) se puede programar de 2 formas.\"" .

ns1:SubrutinaAsociadaALaFuncionT a ns1:Parametro ;
    rdfs:label "Subrutina asociada a la función T" ;
    ns1:identificador "MPG.TOOLSUB" ;
    ns1:textoExtracto "\"(V.)[ch].MPG.TOOLSUB Esta subrutina se ejecuta automáticamente cada vez que se ejecuta una función T (selección de herramienta).\"" .

