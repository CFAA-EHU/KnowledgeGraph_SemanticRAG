@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NombreDeLaSubrutinaDeInterrupcion1 a ns1:Parametro ;
    rdfs:label "Nombre de la subrutina de interrupción 1" ;
    ns1:identificador "MPG.INT1SUB" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.INT1SUB / (V.)[ch].MPG.INT4SUB Estos parámetros indican el nombre" .

ns1:NombreDeLaSubrutinaDeInterrupcion4 a ns1:Parametro ;
    rdfs:label "Nombre de la subrutina de interrupción 4" ;
    ns1:identificador "MPG.INT4SUB" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.INT1SUB / (V.)[ch].MPG.INT4SUB Estos parámetros indican el nombre" .

