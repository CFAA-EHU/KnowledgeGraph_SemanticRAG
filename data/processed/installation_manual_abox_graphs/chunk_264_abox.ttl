@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NombreDeLaSubrutinaAsociadaALaSentenciaINITIALSUB a ns1:Parametro ;
    rdfs:label "Nombre de la subrutina asociada a la sentencia #INITIALSUB" ;
    ns1:identificador "MPG.INITIALSUB" ;
    ns1:textoExtracto "Este parámetro indica el nombre de las subrutina asociada a la sentencia #INITIALSUB." .

ns1:NombreDeLaSubrutinaAsociadaALaSentenciaPIERCING a ns1:Parametro ;
    rdfs:label "Nombre de la subrutina asociada a la sentencia #PIERCING" ;
    ns1:identificador "MPG.PIERCING" ;
    ns1:textoExtracto "Este parámetro indica el nombre de las subrutina asociada a la sentencia #PIERCING." .

ns1:NombreDeLasSubrutinasDeInterrupcionAsociadasALasMarcasINT1 a ns1:Parametro ;
    rdfs:label "Nombre de las subrutinas de interrupción asociadas a las marcas INT1" ;
    ns1:identificador "MPG.INT1SUB" ;
    ns1:textoExtracto "Estos parámetros indican el nombre de las subrutinas de interrupción asociadas a las marcas INT1 a INT4 del PLC." .

ns1:NombreDeLasSubrutinasDeInterrupcionAsociadasALasMarcasINT4 a ns1:Parametro ;
    rdfs:label "Nombre de las subrutinas de interrupción asociadas a las marcas INT4" ;
    ns1:identificador "MPG.INT4SUB" ;
    ns1:textoExtracto "Estos parámetros indican el nombre de las subrutinas de interrupción asociadas a las marcas INT1 a INT4 del PLC." .

