@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SistemaCNC a ex:Maquina ;
    ex:textoExtracto "La búsqueda de cero la controla el CNC." ;
    ex:tieneComponente ex:AccionBusquedaCero .

ex:AccionBusquedaCero a ex:AccionProhibida ;
    ex:textoExtracto "La búsqueda de cero se realiza sin parar el cabezal, si previamente se encontraba girando." .

ex:ModoOperacionM03 a ex:ModoOperacion ;
    ex:identificador "M03" ;
    ex:textoExtracto "Si está girando en M03 ó M04 y se programa M19, el cabezal decelera hasta REFFEED1 y comienza el proceso de búsqueda de cero." .

ex:ModoOperacionM04 a ex:ModoOperacion ;
    ex:identificador "M04" ;
    ex:textoExtracto "Si está girando en M03 ó M04 y se programa M19, el cabezal decelera hasta REFFEED1 y comienza el proceso de búsqueda de cero." .

ex:ModoOperacionM19 a ex:ModoOperacion ;
    ex:identificador "M19" ;
    ex:textoExtracto "Si está girando en M03 ó M04 y se programa M19, el cabezal decelera hasta REFFEED1 y comienza el proceso de búsqueda de cero." .

ex:ParametroREFFEED1 a ex:Parametro ;
    ex:identificador "REFFEED1" ;
    ex:textoExtracto "el cabezal decelera hasta REFFEED1 y comienza el proceso de búsqueda de cero." .

ex:SistemaCNC ex:controla ex:AccionBusquedaCero ;
    ex:textoExtracto "La búsqueda de cero la controla el CNC." .