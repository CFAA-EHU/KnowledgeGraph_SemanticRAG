@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ReguladorSercos_Posicion
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Regulador Sercos en modo posición"@es ;
    ex:textoExtracto      "Modo de operación del regulador en Sercos posición. • La consigna se envía al regulador en cotas absolutas, en diezmilésimas de milímetro (ejes lineales) o milésimas de grado (ejes rotativos). [...] El regulador suaviza la consigna mediante una interpolación cúbica y cierra el lazo de posición cada 256 microsegundos."@es ;
    ex:monitoreaParametro ex:Parametro_FBACKSRC .

ex:Parametro_FBACKSRC
    a                     ex:Parametro ;
    rdfs:label            "FBACKSRC (Tipo de captación)"@es ;
    ex:identificador      "FBACKSRC" ;
    ex:textoExtracto      "FBACKSRC Tipo de captación. Parámetro válido para ejes lineales, rotativos y cabezales. [...] Valores posibles: Interna / Externa / Interna + Externa. Valor por defecto: Interna. Variable asociada: (V.)[ch].MPA.FBACKSRC.xn"@es ;
    ex:valor              "Interna" .

ex:Tabla_SERCOSDATA a ex:Tabla ;
     a                     ex:Tabla ;
    rdfs:label            "Tabla SERCOSDATA"@es ;
    ex:textoExtracto      "Parámetro incluido en la tabla SERCOSDATA."@es ;
    ex:documentadoEn      ex:Manual_ReguladorSercos .

ex:Manual_ReguladorSercos
    a                     ex:Manual ;
    rdfs:label            "Manual del regulador Sercos"@es ;
    ex:textoExtracto      "Consultar el manual del regulador para obtener más información."@es .

ex:ComponenteElectrico_CaptacionMotor
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Captación interna (motor)"@es ;
    ex:textoExtracto      "Si se utiliza captación interna, el valor de la posición se toma de la captación motor"@es .

ex:ComponenteElectrico_CaptacionDirecta
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Captación externa (directa)"@es ;
    ex:textoExtracto      "si utiliza captación directa"@es .

ex:Sistema_ConmutacionCaptacion
    a                     ex:Sistema ;
    rdfs:label            "Sistema de conmutación de captación (FBACKSEL)"@es ;
    ex:identificador      "FBACKSEL" ;
    ex:textoExtracto      "Cuando el tipo de captación es interna+externa, desde el PLC se puede conmutar entre ambas captaciones con la marca FBACKSEL(axis)."@es ;
    ex:controla           ex:ComponenteElectrico_CaptacionMotor ;
    ex:controla           ex:ComponenteElectrico_CaptacionDirecta .