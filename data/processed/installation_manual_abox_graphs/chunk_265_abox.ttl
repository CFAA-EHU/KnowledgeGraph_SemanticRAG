@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NombreDeLaSubrutinaAsociadaAlComandoCUTTINGON a ns1:Parametro ;
    rdfs:label "nombre de la subrutina asociada al comando #CUTTING ON" ;
    ns1:identificador "MPG.CUTTINGON" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.CUTTINGON Este parámetro indica el nombre de las subrutina asociada a la sentencia #CUTTINGON." .

