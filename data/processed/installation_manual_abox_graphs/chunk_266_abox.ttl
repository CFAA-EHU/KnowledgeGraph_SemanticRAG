@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Motor_266_1 a ex:ComponenteMecanico ;
    ex:textoExtracto "el valor de la posición se toma de la captación motor" ;
    rdfs:label "captación motor" .

ex:Parametro_FBACKSEL_266_2 a ex:Parametro ;
    ex:identificador "FBACKSEL(axis)" ;
    ex:textoExtracto "con la marca FBACKSEL(axis)" .

ex:Parametro_FBACKDIFF_266_3 a ex:Parametro ;
    ex:identificador "FBACKDIFF" ;
    ex:textoExtracto "se recomienda definir el parámetro FBACKDIFF" .

ex:Sistema_CNC_266_4 a ex:Sistema ;
    ex:textoExtracto "el CNC permite habilitar la mezcla" .