@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NombreDeLaSubrutinaAsociadaALaSentenciaCUTTINGOFF a ns1:Parametro ;
    rdfs:label "Nombre de la subrutina asociada a la sentencia #CUTTINGOFF" ;
    ns1:identificador "MPG.CUTTINGOFF" ;
    ns1:textoExtracto "Este parámetro indica el nombre de las subrutina asociada a la sentencia #CUTTINGOFF." .

ns1:NombreDeLaSubrutinaAsociadaALaSentenciaCUTTINGON a ns1:Parametro ;
    rdfs:label "Nombre de la subrutina asociada a la sentencia #CUTTINGON" ;
    ns1:identificador "MPG.CUTTINGON" ;
    ns1:textoExtracto "Este parámetro indica el nombre de las subrutina asociada a la sentencia #CUTTINGON." .

ns1:NombreDeLaSubrutinaAsociadaALaSentenciaFINALSUB a ns1:Parametro ;
    rdfs:label "Nombre de la subrutina asociada a la sentencia #FINALSUB" ;
    ns1:identificador "MPG.FINALSUB" ;
    ns1:textoExtracto "Este parámetro indica el nombre de las subrutina asociada a la sentencia #FINALSUB." .

