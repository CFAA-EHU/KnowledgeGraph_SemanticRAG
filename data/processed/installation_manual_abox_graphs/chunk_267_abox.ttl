@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_FBACKDIFF
    a ex:Parametro ;
    rdfs:label "FBACKDIFF" ;
    ex:textoExtracto "definir el parámetro FBACKDIFF. Cuando el tipo de captación es externa o interna+externa"@es ;
    ex:monitoreaParametro ex:Sistema_ReguladorSercos .

ex:Parametro_FBMIXTIME
    a ex:Parametro ;
    rdfs:label "FBMIXTIME" ;
    ex:textoExtracto "el CNC permite habilitar la mezcla de captaciones; parámetro FBMIXTIME"@es ;
    ex:monitoreaParametro ex:Sistema_ReguladorSercos .

ex:Sistema_ReguladorSercos
    a ex:Sistema ;
    rdfs:label "Sistema de regulación Sercos" ;
    ex:textoExtracto "Configurar un regulador Sercos"@es .