@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_FBACKDIFF a ex:Parametro ;
    rdfs:label "FBACKDIFF" ;
    ex:textoExtracto "Cuando se utilice captación externa o interna+externa se recomienda definir el parámetro FBACKDIFF." ;
    ex:valor "definir" .

ex:Parametro_FBMIXTIME a ex:Parametro ;
    rdfs:label "FBMIXTIME" ;
    ex:textoExtracto "Cuando el tipo de captación es externa o interna+externa, el CNC permite habilitar la mezcla de captaciones; parámetro FBMIXTIME." ;
    ex:valor "habilitar" .

ex:Sistema_CNC a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "el CNC permite habilitar la mezcla de captaciones; parámetro FBMIXTIME." .