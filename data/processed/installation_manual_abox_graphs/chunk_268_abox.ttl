@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PathDeLasSubrutinasDePrograma a ns1:Parametro ;
    rdfs:label "Path de las subrutinas de programa" ;
    ns1:identificador "MPG.SUBPATH" ;
    ns1:textoExtracto "Este parámetro indica el directorio, por defecto, en que se encuentran las subrutinas de usuario y las subrutinas necesarias para poder ejecutar programas del 8055 MC y 8055 TC." .

ns1:RutinaQueEjecutaraElCNCAlFinalDeCadaPrograma a ns1:Sistema ;
    rdfs:label "Rutina que ejecutará el CNC al final de cada programa" ;
    ns1:textoExtracto "9999 Rutina que ejecutará el CNC al final de cada programa." .

ns1:RutinaQueEjecutaraElCNCAlPrincipioDeCadaPrograma a ns1:Sistema ;
    rdfs:label "Rutina que ejecutará el CNC al principio de cada programa" ;
    ns1:textoExtracto "9998 Rutina que ejecutará el CNC al principio de cada programa." .

ns1:SubrutinaAsociadaALasFuncionesG380AG399 a ns1:Parametro ;
    rdfs:label "Subrutina asociada a las funciones G380 a G399" ;
    ns1:identificador "MPG.OEMSUB11" ;
    ns1:textoExtracto "Estos parámetros indican el nombre de las subrutinas que se asocian a las funciones G380 a G399." .

