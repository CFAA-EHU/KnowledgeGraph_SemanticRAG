@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:FBACKSRC a ex:Parametro ;
    rdfs:label "FBACKSRC" ;
    ex:textoExtracto "FBACKSRC" .

ex:FBMIXTIME a ex:Parametro ;
    rdfs:label "FBMIXTIME" ;
    ex:textoExtracto "FBMIXTIME" .

ex:CaptacionInterna a ex:ModoOperacion ;
    rdfs:label "Captación interna" ;
    ex:textoExtracto "Captación interna." .

ex:CaptacionExterna a ex:ModoOperacion ;
    rdfs:label "Captación externa" ;
    ex:textoExtracto "Captación externa." .

ex:MezclaCaptaciones a ex:ModoOperacion ;
    rdfs:label "Mezcla de captaciones" ;
    ex:textoExtracto "Está activa la mezcla de captaciones." .

ex:FBACKSEL a ex:Parametro ;
    rdfs:label "FBACKSEL(axis)" ;
    ex:textoExtracto "mediante la marca FBACKSEL(axis)" .