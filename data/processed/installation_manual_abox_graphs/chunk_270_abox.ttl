@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_ConstanteTiempoMezclaCaptaciones
    a               ex:Parametro ;
    rdfs:label      "Constante de tiempo para mezcla de captaciones"@es ;
    ex:textoExtracto "Este parámetro permite definir la constante de tiempo a utilizar en la mezcla de captaciones; es decir, determina el retraso entre las cotas que se introducen al lazo de posición del encóder y de la regla. El CNC sólo tiene en cuenta este parámetro cuando la captación es externa o externa+interna."@es ;
    ex:valor        "0"^^xsd:string .  # Valor canónico de desactivación según texto