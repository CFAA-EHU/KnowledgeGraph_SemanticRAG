@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NombreDelEjeDelCanal a ns1:Parametro ;
    rdfs:label "Nombre del eje del canal" ;
    ns1:identificador "CHAXISNAME" ;
    ns1:textoExtracto "La tabla dispone de los siguientes parámetros para su configuración." .

ns1:TablaPosicionPalpador a ns1:Tabla ;
    rdfs:label "Tabla de posición del palpador de sobremesa" ;
    ns1:documentadoEn ns1:ParametrosDelPalpadorRelativosAlCanal ;
    ns1:textoExtracto "Este parámetro muestra la tabla para definir la posición del palpador de sobremesa en los tres primeros ejes del canal, según el parámetro CHAXISNAME." .

ns1:ParametrosDelPalpadorRelativosAlCanal a ns1:Parametro ;
    rdfs:label "Parámetros del palpador relativos al canal" ;
    ns1:identificador "PROBEDATA" ;
    ns1:textoExtracto "PROBEDATA Parámetros del palpador relativos al canal." .

