@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MezclaCaptacionesSercos
    a ex:Parametro ;
    rdfs:label "Parámetro de mezcla de captaciones Sercos" ;
    ex:textoExtracto "el parámetro se define con valor distinto de ꞏ0ꞏ, se habilita la mezcla de captaciones; si se define con valor ꞏ0ꞏ, sólo se utilizará la captación externa. Un cambio en este parámetro supondrá que la validación de parámetros fuerce la inicialización del anillo Sercos." ;
    ex:valor "0 (solo externa) / ≠0 (mezcla)" ;
    ex:requiereMantenimiento ex:TareaMantenimiento_ValidacionParametrosSercos ;
    ex:monitoreaParametro ex:Sistema_AnilloSercos .

ex:Sistema_AnilloSercos
    a ex:Sistema ;
    rdfs:label "Anillo Sercos" ;
    ex:textoExtracto "Un cambio en este parámetro supondrá que la validación de parámetros fuerce la inicialización del anillo Sercos." ;
    ex:controla ex:Maquina_ConHolgura .

ex:Maquina_ConHolgura
    a ex:Maquina ;
    rdfs:label "Máquina con holgura" ;
    ex:textoExtracto "En máquinas con mucha holgura, en las que se utiliza captación externa para conseguir mayor precisión, es posible que se produzca cierta inestabilidad." .

ex:TareaMantenimiento_ValidacionParametrosSercos
    a ex:TareaMantenimiento ;
    rdfs:label "Validación de parámetros Sercos" ;
    ex:textoExtracto "Un cambio en este parámetro supondrá que la validación de parámetros fuerce la inicialización del anillo Sercos." ;
    ex:tieneFrecuencia ex:Frecuencia_CambioParametroSercos .

ex:Frecuencia_CambioParametroSercos
    a ex:Frecuencia ;
    rdfs:label "Frecuencia de cambio de parámetro Sercos" ;
    ex:textoExtracto "Este parámetro requiere una versión de regulador V6.13 o superior." ;
    ex:valor "V6.13+" .