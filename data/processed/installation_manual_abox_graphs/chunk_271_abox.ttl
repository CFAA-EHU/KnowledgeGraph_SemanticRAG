@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_MezclaCaptaciones a ex:Parametro ;
    rdfs:label "parámetro mezcla de captaciones" ;
    ex:identificador "Sercos" ;
    ex:valor "distinto de 0" ;
    ex:textoExtracto "el parámetro se define con valor distinto de ꞏ0ꞏ, se habilita la mezcla de captaciones; si se define con valor ꞏ0ꞏ, sólo se utilizará la captación externa." .

ex:Parametro_CaptacionExterna a ex:Parametro ;
    rdfs:label "parámetro captación externa" ;
    ex:identificador "Sercos" ;
    ex:valor "0" ;
    ex:textoExtracto "si se define con valor ꞏ0ꞏ, sólo se utilizará la captación externa." .

ex:Regulador_Sercos_V6_13 a ex:ComponenteElectrico ;
    rdfs:label "regulador Sercos V6.13" ;
    ex:identificador "V6.13" ;
    ex:textoExtracto "Este parámetro requiere una versión de regulador V6.13 o superior." .

ex:Parametro_ValidacionInicializacion a ex:Parametro ;
    rdfs:label "parámetro validación inicialización anillo Sercos" ;
    ex:textoExtracto "Un cambio en este parámetro supondrá que la validación de parámetros fuerce la inicialización del anillo Sercos." .

ex:Anillo_Sercos a ex:ComponenteElectrico ;
    rdfs:label "anillo Sercos" ;
    ex:textoExtracto "la validación de parámetros fuerce la inicialización del anillo Sercos" .

ex:CNC a ex:ComponenteElectrico ;
    rdfs:label "CNC" ;
    ex:textoExtracto "El CNC utiliza la mezcla de captaciones para el cálculo de la consigna; para el calculo de las compensaciones, test de circularidad, etc el CNC utiliza la captación externa (captación directa)." .

ex:Parametro_CaptacionInterna a ex:Parametro ;
    rdfs:label "parámetro captación interna" ;
    ex:textoExtracto "con captación interna va suave pero es posible que pierda precisión" .

ex:Parametro_CaptacionMixta a ex:Parametro ;
    rdfs:label "parámetro captación mixta" ;
    ex:textoExtracto "Mezclando ambas captaciones se consigue el efecto deseado de precisión y suavidad." .