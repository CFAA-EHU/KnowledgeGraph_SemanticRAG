@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla273_152 a ex:Tabla ;
    ex:textoExtracto "MLINKDATA |  | DRIVEID | Dirección del regulador. | OPMODEP | Modo de operación principal del regulador. | OPTION | Activar las opciones del regulador." ;
    ex:tieneComponente ex:ParametroDRIVEID, ex:ParametroOPMODEP, ex:ParametroOPTION .

ex:ParametroDRIVEID a ex:Parametro ;
    ex:identificador "DRIVEID" ;
    ex:textoExtracto "DRIVEID | Dirección del regulador." .

ex:ParametroOPMODEP a ex:Parametro ;
    ex:identificador "OPMODEP" ;
    ex:textoExtracto "OPMODEP | Modo de operación principal del regulador." .

ex:ParametroOPTION a ex:Parametro ;
    ex:identificador "OPTION" ;
    ex:textoExtracto "OPTION | Activar las opciones del regulador." .