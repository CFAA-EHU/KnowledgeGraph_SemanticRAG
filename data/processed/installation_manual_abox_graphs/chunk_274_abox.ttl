@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_DRIVEID
    a ex:Parametro ;
    rdfs:label "DRIVEID" ;
    ex:textoExtracto "DRIVEID Dirección del regulador. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Mechatrolink. Valores posibles: De 1 a 14 (Mlink-I) / De 1 a 30 (Mlink-II). Valor por defecto: 1." ;
    ex:valor "1" ;
    ex:documentadoEn ex:Tabla_MLINKDATA .

ex:Parametro_OPMODEP
    a ex:Parametro ;
    rdfs:label "OPMODEP" ;
    ex:textoExtracto "OPMODEP Modo de operación principal del regulador. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Mechatrolink. Valores posibles: Posición / Velocidad / Inverter. Valor por defecto: Posición (ejes) / Velocidad (cabezales)." ;
    ex:valor "Posición (ejes) / Velocidad (cabezales)" ;
    ex:documentadoEn ex:Tabla_MLINKDATA .

ex:Parametro_OPTION
    a ex:Parametro ;
    rdfs:label "OPTION" ;
    ex:textoExtracto "OPTION Activar las opciones del regulador. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Mechatrolink. Valores posibles: De $00000000 a $0000FFFF. Valor por defecto: $00000000." ;
    ex:valor "$00000000" ;
    ex:documentadoEn ex:Tabla_MLINKDATA .

ex:Tabla_MLINKDATA a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "MLINKDATA" ;
    ex:textoExtracto "Parámetro incluido en la tabla MLINKDATA." .