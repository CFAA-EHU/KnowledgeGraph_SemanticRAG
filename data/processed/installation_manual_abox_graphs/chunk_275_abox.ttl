@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MLINKDATA_OPTION
    a ex:Parametro ;
    rdfs:label "Parámetro OPTION del regulador Mechatrolink"@es ;
    ex:textoExtracto "Parámetro válido para regulador Mechatrolink. Valores posibles: De $00000000 a $0000FFFF. Valor por defecto: $00000000. Variable asociada: (V.)[ch].MPA.OPTION.xn"@es ;
    ex:identificador "MPA.OPTION.xn" ;
    ex:valor "$00000000"^^xsd:string ;  # Valor por defecto
    ex:documentadoEn ex:Tabla_MLINKDATA .

ex:Tabla_MLINKDATA a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla MLINKDATA"@es ;
    ex:textoExtracto "Parámetro incluido en la tabla MLINKDATA."@es .