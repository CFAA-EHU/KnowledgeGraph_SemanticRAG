@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ReguladorMechatrolink_276
    a               ex:ComponenteElectrico ;
    rdfs:label      "Regulador Mechatrolink" ;
    ex:textoExtracto "permite configurar diferentes opciones del regulador Mechatrolink, como activar filtros de aceleración o deceleración, activar la primera o segunda captación, elegir un control P o PI para el lazo de velocidad, etc." ;
    ex:identificador "16 bits" .

ex:Parametro_FiltroAceleracion_276
    a               ex:Parametro ;
    rdfs:label      "Filtro de aceleración" ;
    ex:textoExtracto "activar filtros de aceleración" ;
    ex:monitoreaParametro ex:ReguladorMechatrolink_276 .

ex:Parametro_FiltroDeceleracion_276
    a               ex:Parametro ;
    rdfs:label      "Filtro de deceleración" ;
    ex:textoExtracto "activar filtros de aceleración o deceleración" ;
    ex:monitoreaParametro ex:ReguladorMechatrolink_276 .

ex:Parametro_CaptacionPrimera_276
    a               ex:Parametro ;
    rdfs:label      "Primera captación" ;
    ex:textoExtracto "activar la primera o segunda captación" ;
    ex:monitoreaParametro ex:ReguladorMechatrolink_276 .

ex:Parametro_CaptacionSegunda_276
    a               ex:Parametro ;
    rdfs:label      "Segunda captación" ;
    ex:textoExtracto "activar la primera o segunda captación" ;
    ex:monitoreaParametro ex:ReguladorMechatrolink_276 .

ex:Parametro_ControlP_276
    a               ex:Parametro ;
    rdfs:label      "Control P (proporcional)" ;
    ex:textoExtracto "elegir un control P o PI para el lazo de velocidad" ;
    ex:monitoreaParametro ex:ReguladorMechatrolink_276 .

ex:Parametro_ControlPI_276
    a               ex:Parametro ;
    rdfs:label      "Control PI (proporcional-integral)" ;
    ex:textoExtracto "elegir un control P o PI para el lazo de velocidad" ;
    ex:monitoreaParametro ex:ReguladorMechatrolink_276 .