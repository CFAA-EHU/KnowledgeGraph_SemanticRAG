ns1:CNC8070_08e3d1d56c a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:textoExtracto "Este parámetro establece si el CNC envía el PLC las funciones M, S, H durante la búsqueda de bloque." .

ns1:EnvioDeFuncionMPersonalizadaAlPLC a ns1:Parametro ;
    rdfs:label "Envío de función M personalizada al PLC" ;
    ns1:identificador "MPLC" ;
    ns1:textoExtracto "La tabla de funciones M dispone del campo MPLC para definir si el CNC envía o no la función al PLC." .

ns1:EnvioDeFuncionesMHSAlPLCEnLaBusquedaDeBloque a ns1:Parametro ;
    rdfs:label "Envío de funciones M, H, S al PLC en la búsqueda de bloque" ;
    ns1:identificador "MPG.FUNPLC" ;
    ns1:textoExtracto "FUNPLC Enviar las funciones M, H, S al PLC en la búsqueda de bloque." .

ns1:TablaFuncionesM a ns1:Tabla ;
    rdfs:label "Tabla de funciones M" ;
    ns1:textoExtracto "La tabla de funciones M dispone del campo MPLC para definir si el CNC envía o no la función al PLC." .

