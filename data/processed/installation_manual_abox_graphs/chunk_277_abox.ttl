@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EjeHirth_277_1 a ex:ComponenteMecanico ;
    rdfs:label "Eje Hirth" ;
    ex:textoExtracto "HIRTH Eje con dentado Hirth." ;
    ex:identificador "HIRTH" ;
    ex:valor "Sí / No" ;
    ex:valor "No" .

ex:ParametroHirth_277_1 a ex:Parametro ;
    rdfs:label "Parámetro Hirth" ;
    ex:textoExtracto "Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No." ;
    ex:identificador "(V.)[ch].MPA.HIRTH.xn" .

ex:ParametroHPITCH_277_1 a ex:Parametro ;
    rdfs:label "Parámetro HPITCH" ;
    ex:textoExtracto "HPITCH Paso del eje Hirth. Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0 a 99999.9999 mm. Valores posibles (2): De 0 a 3937.00787 inch. Valores posibles (3): De 0 a 99999.9999 grados. Valor por defecto: 1 mm / 0.03937 inch / 1 grado. Variable asociada: (V.)[ch].MPA.HPITCH.xn" ;
    ex:identificador "(V.)[ch].MPA.HPITCH.xn" .

ex:ParametroREFVALUE_277_1 a ex:Parametro ;
    rdfs:label "Parámetro REFVALUE" ;
    ex:textoExtracto "Cuando el eje está definido como eje hirth, este parámetro indica el paso del mismo. El parámetro REFVALUE será tomado como cota inicial para los sucesivos incrementos." .

ex:SistemaCNC_277_1 a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "el CNC dará error" .

ex:InterfazFGUIM_277_1 a ex:InterfazUsuario ;
    rdfs:label "FGUIM" ;
    ex:textoExtracto "La visualización en pantalla de los decimales de un eje Hirth se configurará desde el FGUIM." .