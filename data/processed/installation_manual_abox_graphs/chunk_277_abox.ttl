@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjecutarSubrutinasDeInterrupcionConProgramaParadoOSinProgramaEnEjecucion a ns1:Parametro ;
    rdfs:label "Ejecutar subrutinas de interrupción con programa parado o sin programa en ejecución" ;
    ns1:identificador "MPG.SUBINTSTOP" ;
    ns1:textoExtracto "SUBINTSTOP Ejecutar subrutinas de interrupción con programa parado o sin programa en ejecución. Valores posibles: Sí / No. Valor por defecto: No." .

