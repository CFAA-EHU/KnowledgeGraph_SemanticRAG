@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AsumirMAXFEEDParaLosDesplazamientosEnG1G2G3SinAvanceActivo a ns1:Parametro ;
    rdfs:label "Asumir MAXFEED para los desplazamientos en G1/G2/G3 sin avance activo" ;
    ns1:identificador "MPG.DEFAULTFEED" ;
    ns1:textoExtracto "DEFAULTFEED Asumir MAXFEED para los desplazamientos en G1/G2/G3 sin avance activo. Valores posibles: Sí / No." .

ns1:MaximoAvanceDeMecanizadoSobreLaTrayectoria a ns1:Parametro ;
    rdfs:label "Máximo avance de mecanizado sobre la trayectoria" ;
    ns1:identificador "MPG.MAXFEED" ;
    ns1:textoExtracto "MAXFEED Máximo avance de mecanizado sobre la trayectoria. Valores posibles: De 0 a 500000.0000 mm/min / de 0 a 19685.03937 inch/min." .

ns1:VariablePLCG00FEED a ns1:Parametro ;
    rdfs:label "Variable que permite limitar el avance en el canal" ;
    ns1:identificador "PLC.G00FEED" ;
    ns1:textoExtracto "El PLC dispone de la variable (V.)[ch].PLC.G00FEED que permite limitar el avance en el canal para cualquier tipo de movimiento (G00, G01, etc)." .

