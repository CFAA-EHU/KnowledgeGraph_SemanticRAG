@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:FACEAXIS a ex:Parametro ;
    rdfs:label "FACEAXIS" ;
    ex:textoExtracto "FACEAXIS Eje transversal. Parámetro válido para ejes lineales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPA.FACEAXIS.xn Consultar el parámetro máquina de ejes LONGAXIS." ;
    ex:valor "Sí / No" ;
    ex:identificador "FACEAXIS" .

ex:LONGAXIS a ex:Parametro ;
    rdfs:label "LONGAXIS" ;
    ex:textoExtracto "LONGAXIS Eje longitudinal. Parámetro válido para ejes lineales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPA.LONGAXIS.xn" ;
    ex:valor "Sí / No" ;
    ex:identificador "LONGAXIS" .

ex:CAXIS a ex:Parametro ;
    rdfs:label "CAXIS" ;
    ex:textoExtracto "el parámetro máquina CAXIS = Sí" ;
    ex:valor "Sí" ;
    ex:identificador "CAXIS" .

ex:EjeX a ex:Parametro ;
    rdfs:label "Eje X" ;
    ex:textoExtracto "Eje X. FACEAXIS = Sí | LONGAXIS = No" ;
    ex:valor "FACEAXIS = Sí, LONGAXIS = No" .

ex:EjeZ a ex:Parametro ;
    rdfs:label "Eje Z" ;
    ex:textoExtracto "Eje Z. FACEAXIS = No | LONGAXIS = Sí" ;
    ex:valor "FACEAXIS = No, LONGAXIS = Sí" .

ex:ParametroMaquinaEjes a ex:Esquema ;
    rdfs:label "Configuración de ejes en máquinas tipo torno" ;
    ex:textoExtracto "Personalización habitual en torno: En tornos hay indicar cuál es el eje longitudinal y el transversal. | Personalización habitual en fresadora sin ejes rotativos: En este tipo de máquina no es necesario indicar cuál es el eje longitudinal ni el transversal. | Personalización habitual en fresadora con ejes rotativos: En este tipo de máquina, para utilizar los ciclos asociados a los eje rotativos, es necesario indicar cuál es el eje longitudinal y el transversal. El eje rotativo debe tener su parámetro máquina CAXIS = Sí; el eje lineal asociado al eje rotativo debe tener su parámetro máquina LONGAXIS=Sí; el eje transversal debe tener su parámetro máquina FACEAXIS=Sí." ;
    ex:tieneComponente ex:FACEAXIS, ex:LONGAXIS, ex:CAXIS, ex:EjeX, ex:EjeZ .