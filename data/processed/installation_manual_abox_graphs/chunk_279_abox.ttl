@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:EjeRotativoA ex:textoExtracto "El eje rotativo debe tener su parámetro máquina CAXIS = Sí" ;
    a ex:ComponenteMecanico ;
    ex:identificador "A" ;
    ex:valor "CAXIS=Sí" .

ex:EjeLinealAsociadoRotativo ex:textoExtracto "el eje lineal asociado al eje rotativo debe tener su parámetro máquina LONGAXIS=Sí" ;
    a ex:ComponenteMecanico ;
    ex:identificador "X" ;
    ex:valor "LONGAXIS=Sí" .

ex:EjeTransversal ex:textoExtracto "el eje transversal debe tener su parámetro máquina FACEAXIS=Sí" ;
    a ex:ComponenteMecanico ;
    ex:identificador "Z" ;
    ex:valor "FACEAXIS=Sí" .