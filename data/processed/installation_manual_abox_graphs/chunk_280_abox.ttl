@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PermitirHabilitarElAvanceRapidoParaElModoAutomatico a ns1:Parametro ;
    rdfs:label "Permitir habilitar el avance rápido para el modo automático" ;
    ns1:identificador "MPG.RAPIDEN" ;
    ns1:textoExtracto "RAPIDEN Permitir habilitar el avance rápido para el modo automático. Valores posibles: Deshabilitado / EXRAPID o tecla rápido / EXRAPID y tecla rápido. Valor por defecto: Deshabilitado." .

ns1:VariableAsociadaMPGRAPIDEN a ns1:Parametro ;
    rdfs:label "Variable asociada MPG.RAPIDEN" ;
    ns1:identificador "(V.)[ch].MPG.RAPIDEN" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.RAPIDEN Este parámetro indica si se permite habilitar el avance rápido durante la ejecución de un programa, para los desplazamientos programados." .

