@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:EjeB a ex:ModoOperacion ;
    ex:textoExtracto "Eje B. CAXIS=Sí" .

ex:EjeY a ex:ModoOperacion ;
    ex:textoExtracto "Eje Y (eje lineal asociado al rotativo). FACEAXIS = No LONGAXIS = Sí CAXIS=No" .

ex:EjeZ_rotativoB a ex:ModoOperacion ;
    ex:textoExtracto "Eje Z. FACEAXIS = Sí LONGAXIS = No CAXIS=No" .

ex:EjeC a ex:ModoOperacion ;
    ex:textoExtracto "Eje C. CAXIS=Sí" .

ex:EjeZ_rotativoC a ex:ModoOperacion ;
    ex:textoExtracto "Eje Z (eje lineal asociado al rotativo). FACEAXIS = No LONGAXIS = Sí CAXIS=No" .

ex:EjeXoY a ex:ModoOperacion ;
    ex:textoExtracto "Eje X o Y (sólo uno de los dos) FACEAXIS = Sí LONGAXIS = No CAXIS=No" .

ex:ParametroFACEAXIS a ex:Parametro ;
    ex:textoExtracto "FACEAXIS" .

ex:ParametroLONGAXIS a ex:Parametro ;
    ex:textoExtracto "LONGAXIS" .

ex:ParametroCAXIS a ex:Parametro ;
    ex:textoExtracto "CAXIS" .

ex:ParametroFIXORI a ex:Parametro ;
    ex:textoExtracto "FIXORI" .

ex:EsquemaModelizado a ex:Esquema ;
    ex:textoExtracto "archivo *.def que acompaña al esquema modelizado de la máquina (archivo xca) define si los gráficos trabajan con cotas de la base o de la punta de la herramienta" .

ex:ParametroFACEAXIS ex:detalladoEnEsquema ex:EsquemaModelizado ;
    ex:textoExtracto "FACEAXIS define si los gráficos trabajan con cotas de la base o de la punta de la herramienta" .

ex:ParametroLONGAXIS ex:detalladoEnEsquema ex:EsquemaModelizado ;
    ex:textoExtracto "LONGAXIS define si los gráficos trabajan con cotas de la base o de la punta de la herramienta" .

ex:ParametroFIXORI ex:detalladoEnEsquema ex:EsquemaModelizado ;
    ex:textoExtracto "FIXORI define si la herramienta está orientada según los ejes definidos en FACEAXIS y LONGAXIS" .