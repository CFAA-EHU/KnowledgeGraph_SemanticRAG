@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Parametro_FIXORI a ex:Parametro ;
    ex:textoExtracto "para cada herramienta, el parámetro FIXORI define si la herramienta está orientada según los ejes definidos en FACEAXIS y LONGAXIS" .

ex:Parametro_FACEAXIS a ex:Parametro ;
    ex:textoExtracto "los parámetros FACEAXIS y LONGAXIS" .

ex:Parametro_LONGAXIS a ex:Parametro ;
    ex:textoExtracto "los parámetros FACEAXIS y LONGAXIS" .

ex:Grafico_HD a ex:InterfazUsuario ;
    ex:textoExtracto "Si los gráficos HD trabajan con las cotas de la punta de la herramienta, hacen caso a los parámetros FACEAXIS y LONGAXIS. Si los gráficos HD trabajan con las cotas de la base de la herramienta, no hacen caso a los parámetros FACEAXIS y LONGAXIS" .