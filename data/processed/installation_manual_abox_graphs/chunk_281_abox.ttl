@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoAutomatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático" ;
    ns1:textoExtracto "El avance rápido no está disponible para el modo automático." .

ns1:Parametro_0c4eae3f15 a ns1:Parametro ;
    rdfs:label "Marca EXRAPID de PLC para activar avance rápido" ;
    ns1:identificador "EXRAPID" ;
    ns1:textoExtracto "Para activar el avance rápido sólo es necesario activar la marca EXRAPID de PLC o pulsar la tecla \"rápido\" del panel de jog." .

ns1:TeclaRapido a ns1:ComponenteElectrico ;
    rdfs:label "Tecla rápida del panel de jog" ;
    ns1:textoExtracto "Para activar el avance rápido sólo es necesario activar la marca EXRAPID de PLC o pulsar la tecla \"rápido\" del panel de jog." .

