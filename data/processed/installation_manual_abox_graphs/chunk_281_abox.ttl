@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_FIXORI
    a ex:Parametro ;
    rdfs:label "FIXORI" ;
    ex:textoExtracto "el parámetro FIXORI define si la herramienta está orientada según los ejes definidos en FACEAXIS y LONGAXIS"@es ;
    ex:monitoreaParametro ex:Sistema_GraficosHD .

ex:Parametro_FACEAXIS
    a ex:Parametro ;
    rdfs:label "FACEAXIS" ;
    ex:textoExtracto "ejes definidos en FACEAXIS"@es ;
    ex:monitoreaParametro ex:Sistema_GraficosHD .

ex:Parametro_LONGAXIS
    a ex:Parametro ;
    rdfs:label "LONGAXIS" ;
    ex:textoExtracto "ejes definidos en [...] LONGAXIS"@es ;
    ex:monitoreaParametro ex:Sistema_GraficosHD .

ex:Sistema_GraficosHD
    a ex:Sistema ;
    rdfs:label "Gráficos HD" ;
    ex:textoExtracto "gráficos HD trabajan con las cotas de la punta de la herramienta [...] gráficos HD trabajan con las cotas de la base de la herramienta"@es .