@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceDefinidoParaDesplazamientosG00 a ns1:Parametro ;
    rdfs:label "Avance definido para desplazamientos G00" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "Los desplazamientos en G00 se ejecutan al avance definido en el parámetro G00FEED." .

ns1:AvanceMaximoEnElCanalParaElProgramaEnEjecucion a ns1:Parametro ;
    rdfs:label "Avance máximo en el canal para el programa en ejecución" ;
    ns1:identificador "MPG.FRAPIDEN" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.FRAPIDEN Avance máximo en el canal para el programa en ejecución, cuando está activo el avance rápido para el modo automático." .

ns1:AvanceRapidoEnElCanalParaLosDesplazamientosEnElModoAutomatico a ns1:Parametro ;
    rdfs:label "Avance rápido en el canal, para los desplazamientos en el modo automático" ;
    ns1:identificador "FRAPIDEN" ;
    ns1:textoExtracto "FRAPIDEN Avance rápido en el canal, para los desplazamientos en el modo automático." .

ns1:CNC8070_ead081ceff a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Si la opción elegida para RAPIDEN es \"EXRAPID o tecla de rápido\" y el CNC dispone de varios canales, la marca EXRAPID únicamente afecta al canal correspondiente." .

