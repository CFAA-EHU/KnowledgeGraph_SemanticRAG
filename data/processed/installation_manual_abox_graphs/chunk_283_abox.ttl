@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SYNSPEED
    a ex:Parametro ;
    rdfs:label "Parámetro SYNSPEED" ;
    ex:textoExtracto "Si se supera el valor definido en este parámetro, la señal SYNSPEED se pone a nivel lógico bajo" ;
    ex:identificador "SYNSPEED" .

ex:Sensor_SYNSPEED
    a ex:Sensor ;
    rdfs:label "Señal SYNSPEED" ;
    ex:textoExtracto "la señal SYNSPEED se pone a nivel lógico bajo" ;
    ex:monitoreaParametro ex:Parametro_SYNSPEED .

ex:ModoOperacion_SincronizacionEjes
    a ex:ModoOperacion ;
    rdfs:label "Sincronización de ejes" ;
    ex:textoExtracto "el eje esclavo se mueve al mismo avance que el eje maestro (teniendo en cuenta el ratio)" .

ex:ModoOperacion_SincronizacionCabezales
    a ex:ModoOperacion ;
    rdfs:label "Sincronización de cabezales" ;
    ex:textoExtracto "el cabezal esclavo gira a la misma velocidad que el cabezal maestro (teniendo en cuenta el ratio)" .