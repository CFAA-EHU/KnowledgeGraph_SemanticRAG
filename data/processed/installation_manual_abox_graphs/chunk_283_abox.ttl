@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceMaximoFijadoPorPLC_ce0f7dc77b a ns1:Parametro ;
    rdfs:label "Avance máximo fijado por PLC" ;
    ns1:textoExtracto "ni tampoco al avance máximo fijado por PLC (variable)" .

ns1:AvanceParaDesplazamientosProgramadosEnG00 a ns1:Parametro ;
    rdfs:label "Avance para desplazamientos programados en G00" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "Los desplazamientos en G00 se ejecutan al avance definido en el parámetro G00FEED." .

ns1:AvanceRapido a ns1:Parametro ;
    rdfs:label "Avance rápido" ;
    ns1:identificador "FRAPIDEN" ;
    ns1:textoExtracto "El avance rápido no podrá superar al definido en los parámetros de eje G00FEED y FRAPIDEN." .

