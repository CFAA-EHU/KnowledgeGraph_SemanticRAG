@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:DSYNCPOSW a ex:Parametro ;
    rdfs:label "DSYNCPOSW" ;
    ex:identificador "DSYNCPOSW" ;
    ex:textoExtracto "DSYNCPOSW Ventana de sincronización en posición. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0 a 99999.9999 mm/min. Valores posibles (2): De 0 a 3937.00787 inch/min. Valores posibles (3): De 0 a 99999.9999 grados/min. Valor por defecto: 0.0100 mm/min / 0.00039 inch/min / 0.0100 grados/min." ;
    ex:valor "0.0100 mm/min / 0.00039 inch/min / 0.0100 grados/min" .

ex:INSYNC a ex:AvisoSeguridad ;
    rdfs:label "INSYNC" ;
    ex:textoExtracto "se desactiva la marca INSYNC del PLC" .

ex:SYNCHRONP a ex:AvisoSeguridad ;
    rdfs:label "SYNCHRONP" ;
    ex:textoExtracto "se activara la marca SYNCHRONP del PLC para indicar que el cabezal se ha sincronizado en posición como esclavo" .

ex:SYNCPOSI a ex:AvisoSeguridad ;
    rdfs:label "SYNCPOSI" ;
    ex:textoExtracto "se desactiva la marca SYNCPOSI del PLC" .

ex:V_MPA_DSYNCPOSW_xn a ex:Parametro ;
    rdfs:label "[V.][ch].MPA.DSYNCPOSW.xn" ;
    ex:identificador "[V.][ch].MPA.DSYNCPOSW.xn" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.DSYNCPOSW.xn" ;
    ex:valor "0.0100 mm/min / 0.00039 inch/min / 0.0100 grados/min" .