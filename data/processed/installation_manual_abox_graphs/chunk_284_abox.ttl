@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_DSYNCPOSW
    a ex:Parametro ;
    rdfs:label "Ventana de sincronización en posición (DSYNCPOSW)" ;
    ex:textoExtracto "DSYNCPOSW Ventana de sincronización en posición. Parámetro válido para ejes lineales, rotativos y cabezales. [...] Este parámetro se define para el elemento esclavo de la sincronización e indica el margen de posición admisible dentro del cual se considera que la sincronización es correcta." ;
    ex:valor "0.0100 mm/min / 0.00039 inch/min / 0.0100 grados/min" ;
    ex:monitoreaParametro ex:Variable_MPA_DSYNCPOSW .

ex:Variable_MPA_DSYNCPOSW
    a ex:Parametro ;
    rdfs:label "Variable asociada MPA.DSYNCPOSW.xn" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.DSYNCPOSW.xn" ;
    ex:identificador "MPA.DSYNCPOSW.xn" .

ex:Marca_INSYNC
    a ex:InterfazUsuario ;
    rdfs:label "Marca INSYNC (PLC)" ;
    ex:textoExtracto "Si la diferencia entre la velocidad de sincronización calculada para el eje esclavo y su velocidad real supera el valor definido en este parámetro, se desactiva la marca INSYNC del PLC." .

ex:Marca_SYNCHRONP
    a ex:InterfazUsuario ;
    rdfs:label "Marca SYNCHRONP (PLC)" ;
    ex:textoExtracto "se activará la marca SYNCHRONP del PLC para indicar que el cabezal se ha sincronizado en posición como esclavo." .

ex:Marca_SYNCPOSI
    a ex:InterfazUsuario ;
    rdfs:label "Marca SYNCPOSI (PLC)" ;
    ex:textoExtracto "Si se supera el valor definido en este parámetro, se desactiva la marca SYNCPOSI del PLC; no se detiene el movimiento ni se muestra ningún error." .