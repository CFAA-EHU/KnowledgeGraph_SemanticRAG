@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceActivoFijadoPorPLC a ns1:Parametro ;
    rdfs:label "Avance activo fijado por PLC" ;
    ns1:identificador "PLC.F" ;
    ns1:textoExtracto "El avance rápido podrá superar al definido en el parámetro MAXFEED del canal y al avance activo definido por PLC (variable (V.)PLC.F)." .

ns1:AvanceMaximoDelCanal a ns1:Parametro ;
    rdfs:label "Avance máximo del canal" ;
    ns1:identificador "MAXFEED" ;
    ns1:textoExtracto "El avance rápido podrá superar al definido en el parámetro MAXFEED del canal y al avance activo definido por PLC (variable (V.)PLC.F)." .

ns1:AvanceRapidoFijadoPorPLC a ns1:Parametro ;
    rdfs:label "Avance rápido fijado por PLC" ;
    ns1:identificador "PLC.G00FEED" ;
    ns1:textoExtracto "El avance rápido no podrá superar al definido en los parámetros de eje G00FEED y FRAPIDEN, ni tampoco al avance máximo fijado por PLC (variable (V.)PLC.G00FEED)." .

ns1:AvanceRapidoProgramado a ns1:Parametro ;
    rdfs:label "Avance rápido programado" ;
    ns1:identificador "FRAPIDEN" ;
    ns1:textoExtracto "El avance rápido no podrá superar al definido en los parámetros de eje G00FEED y FRAPIDEN." .

ns1:AvanceRapidoProgramado_40ccad14d9 a ns1:Parametro ;
    rdfs:label "Avance rápido programado" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "El avance rápido no podrá superar al definido en los parámetros de eje G00FEED y FRAPIDEN." .

