@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaximaAceleracionSobreLaTrayectoriaDeMecanizado a ns1:Parametro ;
    rdfs:label "Máxima aceleración sobre la trayectoria de mecanizado" ;
    ns1:identificador "MPG.MAXACCEL" ;
    ns1:textoExtracto "MAXACCEL Máxima aceleración sobre la trayectoria de mecanizado. Valores posibles: De 0.0010 a 600000000.0000 mm/min / de 0.00004 a 23622047.24409 inch/min." .

ns1:MaximoJerkSobreLaTrayectoriaDeMecanizado a ns1:Parametro ;
    rdfs:label "Máximo jerk sobre la trayectoria de mecanizado" ;
    ns1:identificador "MPG.MAXJERK" ;
    ns1:textoExtracto "MAXJERK Máximo jerk sobre la trayectoria de mecanizado. Valores posibles: De 0.0010 a 6E11 mm/min / de 0.00004 a 2.362E10 inch/min." .

ns1:VariableVGMAXJERK a ns1:Parametro ;
    rdfs:label "Variable asociada para modificar temporalmente el jerk máximo" ;
    ns1:identificador "V.G.MAXJERK" ;
    ns1:textoExtracto "La variable (V.)[ch].G.MAXJERK permite modificar temporalmente, en un momento dado y en tiempo real, el valor definido por el parámetro máquina." .

ns1:VariableVMPGMAXACCEL a ns1:Parametro ;
    rdfs:label "Variable asociada para modificar temporalmente la aceleración máxima" ;
    ns1:identificador "V.MPG.MAXACCEL" ;
    ns1:textoExtracto "La variable (V.)[ch].MPG.MAXACCEL permite modificar temporalmente, en un momento dado y en tiempo real, el valor definido por el parámetro máquina." .

