@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_c7c75703e2 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC asume el cambio inmediatamente y permanece activo hasta ejecutar M30 o reset, en cuyo caso el CNC recupera el valor fijado por el parámetro máquina." .

ns1:MaximaAceleracionYJerkSobreLaTrayectoria a ns1:Parametro ;
    rdfs:label "Máxima aceleración y jerk sobre la trayectoria" ;
    ns1:identificador "G.MAXJERK" ;
    ns1:textoExtracto "La variable (V.)[ch].G.MAXJERK permite modificar temporalmente, en un momento dado y en tiempo real, el valor definido por el parámetro máquina." .

