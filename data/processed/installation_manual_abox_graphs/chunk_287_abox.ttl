@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:UNIDIR a ex:Parametro ;
    rdfs:label "UNIDIR" ;
    ex:textoExtracto "UNIDIR Sentido de giro único. Parámetro válido para ejes rotativos." ;
    ex:valor "No (ambos sentidos) / Positivo / Negativo" ;
    ex:valor "Valor por defecto: No (ambos sentidos)" .

ex:SHORTESTWAY a ex:Parametro ;
    rdfs:label "SHORTESTWAY" ;
    ex:textoExtracto "SHORTESTWAY Posicionamiento por el camino más corto. Parámetro válido para ejes rotativos." ;
    ex:valor "Sí / No" ;
    ex:valor "Valor por defecto: No" .

ex:MODUPLIM a ex:Parametro ;
    rdfs:label "MODUPLIM" ;
    ex:textoExtracto "los de gama MODUPLIM y MODLOWLIM no tienen significado" .

ex:MODLOWLIM a ex:Parametro ;
    rdfs:label "MODLOWLIM" ;
    ex:textoExtracto "los de gama MODUPLIM y MODLOWLIM no tienen significado" .

ex:AXISMODE a ex:Parametro ;
    rdfs:label "AXISMODE" ;
    ex:textoExtracto "El CNC sólo tiene en cuenta este parámetro cuando AXISMODE = Módulo" .

ex:G90 a ex:ModoOperacion ;
    rdfs:label "G90" ;
    ex:textoExtracto "los desplazamientos (G00/G01) en G90 de los ejes rotativos" .

ex:G91 a ex:ModoOperacion ;
    rdfs:label "G91" ;
    ex:textoExtracto "Los desplazamientos en G91 se realizan en el sentido programado" .

ex:MPA_UNIDIR a ex:Parametro ;
    rdfs:label "MPA.UNIDIR.xn" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.UNIDIR.xn" .

ex:MPA_SHORTESTWAY a ex:Parametro ;
    rdfs:label "MPA.SHORTESTWAY.xn" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.SHORTESTWAY.xn" .