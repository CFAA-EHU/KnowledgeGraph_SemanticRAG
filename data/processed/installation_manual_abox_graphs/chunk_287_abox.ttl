@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LimiteAlJerkSobreLaTrayectoria a ns1:Parametro ;
    rdfs:label "Límite al jerk sobre la trayectoria" ;
    ns1:textoExtracto "Si la variable toma valor ꞏ0ꞏ, el CNC no aplica ningún límite al jerk sobre la trayectoria, ni siquiera el fijado por parámetro máquina." .

ns1:ValorFijadoPorElParametroMaquina a ns1:Parametro ;
    rdfs:label "Valor fijado por el parámetro máquina" ;
    ns1:identificador "M30" ;
    ns1:textoExtracto "hasta ejecutar M30 o reset, en cuyo caso el CNC recupera el valor fijado por el parámetro máquina." .

