@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaximaFrecuenciaGeneradaSobreLaTrayectoriaDeMecanizado a ns1:Parametro ;
    rdfs:label "Máxima frecuencia generada sobre la trayectoria de mecanizado" ;
    ns1:identificador "MPG.MAXFREQ" ;
    ns1:textoExtracto "MAXFREQ Máxima frecuencia generada sobre la trayectoria de mecanizado. Valores posibles: De 0 a 500 Hz. Valor por defecto: 0." .

