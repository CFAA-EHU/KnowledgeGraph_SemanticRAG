@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:DMCSPDL a ex:Parametro ;
    rdfs:label "DMCSPDL" ;
    ex:identificador "DMCSPDL" ;
    ex:textoExtracto "DMCSPDL Cabezal con control de potencia habilitable. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPA.DMCSPDL.sn Este parámetro indica si el DMC puede actuar o no sobre el cabezal." ;
    ex:valor "No" .

ex:MPA_DMCSPDL_sn a ex:Parametro ;
    rdfs:label "MPA.DMCSPDL.sn" ;
    ex:identificador "MPA.DMCSPDL.sn" ;
    ex:textoExtracto "DMCSPDL Cabezal con control de potencia habilitable. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPA.DMCSPDL.sn Este parámetro indica si el DMC puede actuar o no sobre el cabezal." ;
    ex:valor "No" .