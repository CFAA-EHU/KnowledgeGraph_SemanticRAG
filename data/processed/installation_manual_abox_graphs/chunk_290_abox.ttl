@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaximoNumeroDeBloquesPermitidosParaLaFuncionRetrace a ns1:Parametro ;
    rdfs:label "Máximo número de bloques permitidos para la función retrace" ;
    ns1:identificador "MPG.NRETBLK" ;
    ns1:textoExtracto "NRETBLK Máximo número de bloques permitidos para la función retrace. Valores posibles: De 0 a 300. Valor por defecto: 75." .

ns1:PermiteHabilitarLaFuncionRetrace a ns1:Parametro ;
    rdfs:label "Permite habilitar la función retrace" ;
    ns1:identificador "MPG.RETRACAC" ;
    ns1:textoExtracto "RETRACAC Permitir habilitar la función retrace. Valores posibles: Sí / No. Valor por defecto: No." .

ns1:TratamientoDeLasFuncionesMConLaFuncionRetrace a ns1:Parametro ;
    rdfs:label "Tratamiento de las funciones M con la función retrace" ;
    ns1:identificador "MPG.RETMFUNC" ;
    ns1:textoExtracto "RETMFUNC Tratamiento de las funciones M con la función retrace. Valores posibles: Ignorar / Cancelar. Valor por defecto: Ignorar." .

