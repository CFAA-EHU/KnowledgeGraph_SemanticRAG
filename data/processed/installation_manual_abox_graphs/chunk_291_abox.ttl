@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefineLaDistanciaQueSeRetiranLosEjesDeLaPieza a ns1:Parametro ;
    rdfs:label "Define la distancia que se retiran los ejes de la pieza" ;
    ns1:textoExtracto "Si G233 no está activa, los ejes se detienen al final de la pasada." .

ns1:HabilitarLaRetiradaDeHerramientaEnLosRoscados a ns1:Parametro ;
    rdfs:label "Habilitar la retirada de herramienta en los roscados" ;
    ns1:identificador "RETRACTTHREAD" ;
    ns1:textoExtracto "RETRACTTHREAD Habilitar la retirada de herramienta en los roscados. Valores posibles: ON / OFF. Valor por defecto: ON." .

ns1:VariableAsociadaAlRETRACTTHREAD a ns1:Parametro ;
    rdfs:label "Variable asociada al RETRACTTHREAD" ;
    ns1:identificador "MPG.RETRACTTHREAD" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.RETRACTTHREAD Este parámetro define el comportamiento del CNC cuando se interrumpe un roscado (tecla [STOP] o marca _FEEDHOL del PLC)." .

