@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_SPDLTIME a ex:Parametro ;
    rdfs:label "SPDLTIME" ;
    ex:identificador "(V.)[ch].MPA.SPDLTIME.xn" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.SPDLTIME.xn" .

ex:ModoOperacion_EDISIMU a ex:ModoOperacion ;
    rdfs:label "EDISIMU" ;
    ex:textoExtracto "En el modo de trabajo EDISIMU hay una opción que permite calcular el tiempo que se necesitará para ejecutar la pieza con las condiciones de mecanizado establecidas en el programa." .

ex:AccionProhibida_SPDLSTOP a ex:AccionProhibida ;
    rdfs:label "SPDLSTOP" ;
    ex:textoExtracto "Parámetro válido para SPDLSTOP Las funciones M2, M30, un error o un reset paran el cabezal." .

ex:Sistema_CNC a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "el CNC entiende que se debe pasar el valor de la S al PLC mediante las señales SSTROBE + SFUN1." .

ex:Sistema_PLC a ex:Sistema ;
    rdfs:label "PLC" ;
    ex:textoExtracto "el CNC entiende que se debe pasar el valor de la S al PLC mediante las señales SSTROBE + SFUN1." .