@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_b0186d1a6d a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "tras reiniciar el CNC." .

ns1:CabezalMasterMantenido a ns1:Parametro ;
    rdfs:label "Cabezal master mantenido" ;
    ns1:identificador "MPG.MASTERSPDL" ;
    ns1:textoExtracto "MASTERSPDL Cabezal master mantenido. Valores posibles: Temporal / Mantenido." .

ns1:DefinicionDeCambioTemporalOPermanenteDelCanalDeUnCabezal a ns1:Parametro ;
    rdfs:label "Definición de cambio temporal o permanente del canal de un cabezal" ;
    ns1:textoExtracto "el parámetro AXISEXCH, el cual define si el cambio de canal de un cabezal es temporal o permanente." .

