ns1:PotenciaDelCabezal a ns1:Parametro ;
    rdfs:label "potencia del cabezal" ;
    ns1:textoExtracto "En el modelo láser, los parámetros relacionados con la velocidad del cabezal (definida en rpm), definen la potencia (definida en watios)." .

