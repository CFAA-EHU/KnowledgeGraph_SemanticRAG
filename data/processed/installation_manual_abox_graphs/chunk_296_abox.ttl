@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_STEPOVR_296 a ex:Parametro ;
    rdfs:label "STEPOVR" ;
    ex:identificador "(V.)[ch].MPA.STEPOVR.xn" ;
    ex:textoExtracto "Este parámetro define el paso incremental para modificar la velocidad de giro programada, mediante las teclas de speed override del panel de mando. Parámetro sin función cuando el panel de mando dispone del conmutador speed override." ;
    ex:valor "De 0 a 255" ;
    ex:valor "5" .

ex:Parametro_MINOVR_296 a ex:Parametro ;
    rdfs:label "MINOVR" ;
    ex:identificador "(V.)[ch].MPA.MINOVR.xn" ;
    ex:textoExtracto "Este parámetro establece el porcentaje mínimo permitido a aplicar a la velocidad de giro del cabezal, cuando ésta se modifica desde el panel de mando (teclas o conmutador speed override)." ;
    ex:valor "De 0 a 255" ;
    ex:valor "50" .

ex:Parametro_MAXOVR_296 a ex:Parametro ;
    rdfs:label "MAXOVR" ;
    ex:identificador "(V.)[ch].MPA.MAXOVR.xn" ;
    ex:textoExtracto "Este parámetro establece el porcentaje máximo permitido a aplicar a la velocidad de giro del cabezal, cuando ésta se modifica desde el panel de mando (teclas o conmutador speed override)." ;
    ex:valor "De 0 a 255" ;
    ex:valor "150" .

ex:PanelMando_296 a ex:InterfazUsuario ;
    ex:textoExtracto "mediante las teclas de speed override del panel de mando. Parámetro sin función cuando el panel de mando dispone del conmutador speed override." .

ex:TeclasSpeedOverride_296 a ex:Componente ;
    ex:textoExtracto "mediante las teclas de speed override del panel de mando" .

ex:ConmutadorSpeedOverride_296 a ex:Componente ;
    ex:textoExtracto "cuando el panel de mando dispone del conmutador speed override" .

ex:ReguladorAnalogico_296 a ex:ComponenteElectrico ;
    ex:textoExtracto "válido para regulador analógico, Sercos y simulado" .

ex:Sercos_296 a ex:ComponenteElectrico ;
    ex:textoExtracto "válido para regulador analógico, Sercos y simulado" .

ex:Simulado_296 a ex:ComponenteElectrico ;
    ex:textoExtracto "válido para regulador analógico, Sercos y simulado" .

ex:Cabezal_296 a ex:ComponenteMecanico ;
    ex:textoExtracto "Parámetro válido para cabezales." .