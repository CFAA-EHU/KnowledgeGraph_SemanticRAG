@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_5d2cef7c31 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC puede modificar la posición del eje o cabezal dentro de su canal." .

ns1:ConfiguracionMantenidaQuePermiteCambiosEnElCanalYLosMantiene a ns1:Parametro ;
    rdfs:label "Configuración mantenida que permite cambios en el canal y los mantiene" ;
    ns1:identificador "AXISEXCH=Mantenido" ;
    ns1:textoExtracto "El CNC mantiene los cambios al reiniciar el programa pieza, tras un reset o tras reiniciar el CNC." .

ns1:ConfiguracionQueNoPermiteCambiosEnElCanal a ns1:Parametro ;
    rdfs:label "Configuración que no permite cambios en el canal" ;
    ns1:identificador "AXISEXCH=No" ;
    ns1:textoExtracto "El CNC no puede cambiar el eje o cabezal de canal." .

ns1:ConfiguracionTemporalQuePermiteCambiosEnElCanal a ns1:Parametro ;
    rdfs:label "Configuración temporal que permite cambios en el canal" ;
    ns1:identificador "AXISEXCH=Temporal" ;
    ns1:textoExtracto "El CNC puede cambiar el eje o cabezal de canal." .

