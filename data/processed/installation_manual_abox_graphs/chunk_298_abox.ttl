@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:OverrideCabezalRoscado
    a ex:Parametro ;
    rdfs:label "Override del cabezal durante el roscado"@es ;
    ex:textoExtracto "Los ciclos de roscado permiten modificar la velocidad del cabezal durante las pasadas de roscado, excepto en las que se realizan a la profundidad final de la rosca (una o dos pasadas finales), las cuales se realizan al override activo al comenzar la pasada."@es .

ex:TareaCambioOverrideRoscado
    a ex:TareaMantenimiento ;
    rdfs:label "Cambio del override del cabezal durante el roscado"@es ;
    ex:textoExtracto "Cambio del override del cabezal durante el roscado. [...] No se recomienda modificar el override en roscas donde la penetración se realice por flanco."@es ;
    ex:monitoreaParametro ex:OverrideCabezalRoscado .

ex:RoscadoElectronicoG33
    a ex:ModoOperacion ;
    rdfs:label "Roscado electrónico G33"@es ;
    ex:textoExtracto "Roscado electrónico G33. Consideraciones"@es ;
    ex:tieneComponente ex:OverrideCabezalRoscado .