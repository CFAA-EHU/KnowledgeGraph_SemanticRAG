@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:OverrideCNC a ex:Parametro ;
    rdfs:label "Override" ;
    ex:textoExtracto "el override, el CNC respeta el paso y la entrada de la rosca" ;
    ex:valor "THREADOVR distinto de 0 (cero)" .

ex:OVRFILTER a ex:Parametro ;
    rdfs:label "OVRFILTER" ;
    ex:identificador "OVRFILTER" ;
    ex:textoExtracto "OVRFILTER Tiempo para hacer efectivo el cambio de override. Parámetro válido para cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.OVRFILTER.xn El CNC sólo tiene en cuenta este parámetro con THREADOVR distinto de 0 (cero). Este parámetro actúa como filtro para hacer efectivo el cambio de override. El cambio de override se aplica progresivamente durante el tiempo especificado." ;
    ex:valor "De 0 a 1000000 ms" .

ex:THREADOVR a ex:Parametro ;
    rdfs:label "THREADOVR" ;
    ex:textoExtracto "Este parámetro actúa como filtro para hacer efectivo el cambio de override. El CNC sólo tiene en cuenta este parámetro con THREADOVR distinto de 0 (cero)" ;
    ex:valor "distinto de 0 (cero)" .

ex:G33 a ex:ModoOperacion ;
    rdfs:label "G33" ;
    ex:textoExtracto "Roscado electrónico G33" .

ex:Cabezal a ex:ComponenteMecanico ;
    rdfs:label "cabezal" ;
    ex:textoExtracto "Parámetro válido para cabezales" .

ex:ReguladorAnalogico a ex:ComponenteElectrico ;
    rdfs:label "regulador analógico" ;
    ex:textoExtracto "Parámetro válido para regulador analógico" .

ex:Sercos a ex:ComponenteElectrico ;
    rdfs:label "Sercos" ;
    ex:textoExtracto "Parámetro válido para Sercos" .

ex:Simulado a ex:ModoOperacion ;
    rdfs:label "simulado" ;
    ex:textoExtracto "Parámetro válido para simulado" .