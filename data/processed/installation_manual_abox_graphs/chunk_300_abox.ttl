@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaTiposEjesReguladores a ns1:Tabla ;
    ns1:ilustra ns1:TipoDeEjeYRegulador ;
    ns1:textoExtracto "Consultar el manual del regulador para obtener más información." .

ns1:TipoDeEjeYRegulador a ns1:Parametro ;
    rdfs:label "Tipo de eje y regulador" ;
    ns1:identificador "POSUNITS" ;
    ns1:textoExtracto "POSUNITS | Significado." .

