@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaConfiguracionRegulador a ns1:Tabla ;
    rdfs:label "Tabla de configuración del regulador Sercos" ;
    ns1:ilustradoEn ns1:DatosDelReguladorSercos ;
    ns1:textoExtracto "Este parámetro muestra la tabla para definir la comunicación con el regulador Sercos." .

ns1:DatosDelReguladorSercos a ns1:Parametro ;
    rdfs:label "Datos del regulador Sercos" ;
    ns1:textoExtracto "SERCOSDATA Datos del regulador Sercos. Parámetro válido para ejes lineales, rotativos y cabezales." .

