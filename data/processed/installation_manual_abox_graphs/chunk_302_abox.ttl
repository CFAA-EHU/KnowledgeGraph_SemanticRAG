@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConstanteDeTiempoParaLaCaptacionMixta a ns1:Parametro ;
    rdfs:label "Constante de tiempo para la captación mixta" ;
    ns1:documentadoEn ns1:TablaConfiguracionReguladorSercos ;
    ns1:identificador "FBACKTIME" ;
    ns1:textoExtracto "FBACKTIME | Constante de tiempo para la captación mixta." .

ns1:DireccionDelReguladorSercos a ns1:Parametro ;
    rdfs:label "Dirección del regulador Sercos" ;
    ns1:documentadoEn ns1:TablaConfiguracionReguladorSercos ;
    ns1:identificador "DRIVEID" ;
    ns1:textoExtracto "DRIVEID | Dirección del regulador Sercos." .

ns1:MaximaDiferenciaEntreCaptaciones a ns1:Parametro ;
    rdfs:label "Máxima diferencia entre captaciones" ;
    ns1:documentadoEn ns1:TablaConfiguracionReguladorSercos ;
    ns1:identificador "FBACKDIFF" ;
    ns1:textoExtracto "FBACKDIFF | Máxima diferencia entre captaciones." .

ns1:ModoDeOperacionPrincipalDelReguladorSercos a ns1:Parametro ;
    rdfs:label "Modo de operación principal del regulador Sercos" ;
    ns1:documentadoEn ns1:TablaConfiguracionReguladorSercos ;
    ns1:identificador "OPMODEP" ;
    ns1:textoExtracto "OPMODEP | Modo de operación principal del regulador Sercos." .

ns1:Parametro_1e1abc0cf9 a ns1:Parametro ;
    rdfs:label "Parámetro actualmente sin función" ;
    ns1:documentadoEn ns1:TablaConfiguracionReguladorSercos ;
    ns1:identificador "ULTRAIPO" ;
    ns1:textoExtracto "ULTRAIPO | Parámetro actualmente sin función." .

ns1:TipoDeCaptacion a ns1:Parametro ;
    rdfs:label "Tipo de captación" ;
    ns1:documentadoEn ns1:TablaConfiguracionReguladorSercos ;
    ns1:identificador "FBACKSRC" ;
    ns1:textoExtracto "FBACKSRC | Tipo de captación." .

ns1:TablaConfiguracionReguladorSercos a ns1:Tabla ;
    rdfs:label "Configurar un regulador Sercos" ;
    ns1:textoExtracto "DRIVEID | Dirección del regulador Sercos. OPMODEP | Modo de operación principal del regulador Sercos. FBACKSRC | Tipo de captación. FBACKDIFF | Máxima diferencia entre captaciones. ULTRAIPO | Parámetro actualmente sin función. FBACKTIME | Constante de tiempo para la captación mixta." .

