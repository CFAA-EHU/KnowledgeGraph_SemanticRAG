@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SERCOSDATA a ns1:Tabla ;
    rdfs:label "SERCOSDATA" ;
    ns1:textoExtracto "Parámetro incluido en la tabla SERCOSDATA." ;
    ns1:tieneComponente ns1:DireccionDelReguladorSercos,
        ns1:ModoDeOperacionPrincipalDelReguladorSercos .

ns1:DireccionDelReguladorSercos a ns1:Parametro ;
    rdfs:label "Dirección del regulador Sercos" ;
    ns1:identificador "DRIVEID" ;
    ns1:textoExtracto "DRIVEID Dirección del regulador Sercos. Parámetro válido para ejes lineales, rotativos y cabezales." ;
    ns1:valor "1" .

ns1:ModoDeOperacionPrincipalDelReguladorSercos a ns1:Parametro ;
    rdfs:label "Modo de operación principal del regulador Sercos" ;
    ns1:identificador "OPMODEP" ;
    ns1:textoExtracto "OPMODEP Modo de operación principal del regulador Sercos. Parámetro válido para ejes lineales, rotativos y cabezales." ;
    ns1:valor "Posición" .

