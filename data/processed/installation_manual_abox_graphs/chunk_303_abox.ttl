@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ZONELIMITTOL a ex:Parametro ;
    ex:textoExtracto "ZONELIMITTOL Distancia de seguridad de los límites de las zonas de trabajo. Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 99999.9999 mm o grados / de 0 a 3937.00787 inch. Valor por defecto: 0.1000 mm o grados / 0.00394 inch." ;
    ex:identificador "ZONELIMITTOL" ;
    ex:valor "0.1000 mm o grados / 0.00394 inch" .

ex:MPA_ZONELIMITTOL a ex:Parametro ;
    ex:textoExtracto "(V.)[ch].MPA.ZONELIMITTOL.xn Distancia de seguridad que aplica el CNC al eje respecto el límite de la zona de trabajo. Cuando una zona de trabajo está activa, el CNC detiene los ejes cuando alguno de ellos alcanza la distancia de seguridad. La distancia de seguridad se define por eje, el cual tendrá la misma distancia de seguridad en todas las zonas." ;
    ex:identificador "[ch].MPA.ZONELIMITTOL.xn" ;
    ex:valor "Distancia de seguridad que aplica el CNC al eje respecto el límite de la zona de trabajo" .

ex:A_ZONELIMITTOL a ex:Parametro ;
    ex:textoExtracto "( V.)[ch].A.ZONELIMITTOL.xn Distancia de seguridad de los límites de las zonas de trabajo." ;
    ex:identificador "[ch].A.ZONELIMITTOL.xn" ;
    ex:valor "Distancia de seguridad de los límites de las zonas de trabajo" .