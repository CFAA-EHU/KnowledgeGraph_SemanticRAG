@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_4aaed3e951 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "La búsqueda de cero la controla el CNC." .

ns1:EjesTandem a ns1:ComponenteMecanico ;
    rdfs:label "ejes tándem" ;
    ns1:requiereMantenimiento ns1:ConfigurarModoDeOperacionDelReguladorSercos ;
    ns1:textoExtracto "Sin embargo, los ejes tándem deberán operar obligatoriamente en modo Sercos velocidad." .

ns1:ModoSercosVelocidad a ns1:Parametro ;
    rdfs:label "modo Sercos velocidad" ;
    ns1:textoExtracto "Modo de operación del regulador en Sercos velocidad." .

ns1:SistemaReguladorSercos a ns1:Sistema ;
    rdfs:label "regulador Sercos" ;
    ns1:textoExtracto "Consultar el manual del regulador para obtener más información." ;
    ns1:tieneComponente ns1:ModoDeOperacionDelReguladorSercos .

ns1:ConfigurarModoDeOperacionDelReguladorSercos a ns1:TareaMantenimiento ;
    rdfs:label "configurar modo de operación del regulador Sercos" ;
    ns1:solucionaFallo ns1:FalloConfiguracionIncorrecta ;
    ns1:textoExtracto "Se recomienda que los ejes (excepto ejes tándem) operen en modo Sercos posición y que los cabezales lo hagan en modo Sercos velocidad." .

ns1:ModoDeOperacionDelReguladorSercos a ns1:Parametro ;
    rdfs:label "modo de operación del regulador Sercos" ;
    ns1:textoExtracto "Este parámetro indica el modo de operación del regulador Sercos; consigna de velocidad o de posición." .

