ns1:CNC8070_646bb6c98c a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:CabezalPrincipal ;
    ns1:textoExtracto "La búsqueda de cero la controla el CNC. La búsqueda de cero se realiza sin parar el cabezal, si previamente se encontraba girando." .

ns1:ErrorDeSeguimiento_ea7259292f a ns1:Parametro ;
    rdfs:label "Error de seguimiento" ;
    ns1:identificador "REFFEED1" ;
    ns1:textoExtracto "el cabezal decelera hasta REFFEED1 y comienza el proceso de búsqueda de cero." .

ns1:CabezalPrincipal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal Principal" ;
    ns1:textoExtracto "La búsqueda de cero la controla el CNC. La búsqueda de cero se realiza sin parar el cabezal, si previamente se encontraba girando." .

