@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_DWELL a ex:Parametro ;
    rdfs:label "DWELL" ;
    ex:textoExtracto "DWELL Temporización para ejes muertos. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0 (no hay temporización). Variable asociada: (V.)[ch].MPA.DWELL.xn" ;
    ex:valor "0 a 1000000 ms" ;
    ex:identificador "DWELL" .

ex:Eje_Vertical_Pesado a ex:ComponenteMecanico ;
    rdfs:label "eje vertical pesado" ;
    ex:textoExtracto "Cuando un eje dispone de freno, por ejemplo ejes verticales muy pesados" .

ex:Freno_Eje a ex:ComponenteMecanico ;
    rdfs:label "freno de eje" ;
    ex:textoExtracto "Cuando un eje dispone de freno" .

ex:ModoOperacion_Vivo a ex:ModoOperacion ;
    rdfs:label "eje vivo" ;
    ex:textoExtracto "Cuando está gobernado por el CNC (desplazamientos) se dice que el eje está 'vivo'" .

ex:ModoOperacion_Muerto a ex:ModoOperacion ;
    rdfs:label "eje muerto" ;
    ex:textoExtracto "Cuando está quieto (freno activo) se dice que el eje está 'muerto'" .

ex:SERVOON a ex:AccionProhibida ;
    rdfs:label "SERVOON" ;
    ex:textoExtracto "Para pasar de 'muerto' a 'vivo' hay que quitar el freno y cerrar el lazo de posición. El tiempo que se necesita para esta operación tiene que estar definido en el parámetro DWELL. SERVOON" .