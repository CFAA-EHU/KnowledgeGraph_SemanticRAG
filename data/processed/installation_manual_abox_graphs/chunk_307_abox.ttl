@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfigurarUnReguladorSercos a ns1:TareaMantenimiento ;
    rdfs:label "Configurar un regulador Sercos" ;
    ns1:textoExtracto "Consultar el manual del regulador para obtener más información." .

ns1:SistemaReguladorSercos a ns1:Sistema ;
    rdfs:label "regulador Sercos" ;
    ns1:textoExtracto "La búsqueda de cero la controla el regulador. Antes de comenzar la búsqueda de cero, el cabezal se detiene si previamente se encontraba girando." .

ns1:TipoDeCaptacionUtilizadaParaCerrarElLazoDePosicion a ns1:Parametro ;
    rdfs:label "Tipo de captación utilizada para cerrar el lazo de posición" ;
    ns1:documentadoEn ns1:TablaSERCOSDATA ;
    ns1:identificador "MPA.FBACKSRC" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos." .

ns1:TablaSERCOSDATA a ns1:Tabla ;
    rdfs:label "tabla SERCOSDATA" ;
    ns1:textoExtracto "Parámetro incluido en la tabla SERCOSDATA." .

