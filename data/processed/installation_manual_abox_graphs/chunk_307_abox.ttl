@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ENABLE ex:textoExtracto "ENABLE Velocity Command DWELL La señal ENABLE indica al PLC que permita el movimiento del eje y la señal SERVOON que el regulador está listo." ;
    a ex:Parametro ;
    rdfs:label "ENABLE" .

ex:SERVOON ex:textoExtracto "la señal SERVOON que el regulador está listo" ;
    a ex:Parametro ;
    rdfs:label "SERVOON" .

ex:DWELL ex:textoExtracto "el tiempo parametrizado en DWELL" ;
    a ex:Parametro ;
    rdfs:label "DWELL" .

ex:DEAD_axis ex:textoExtracto "señal DEAD(axis)" ;
    a ex:Parametro ;
    rdfs:label "DEAD(axis)" .

ex:PLC ex:textoExtracto "al PLC que permita el movimiento del eje" ;
    a ex:Sistema ;
    rdfs:label "PLC" .

ex:CNC ex:textoExtracto "El CNC esperará el tiempo parametrizado en DWELL antes de generar movimiento en el eje" ;
    a ex:Sistema ;
    rdfs:label "CNC" .

ex:ModoOperacion_EjeMuerto ex:textoExtracto "eje \"muerto\"" ;
    a ex:ModoOperacion ;
    rdfs:label "Modo Operación Eje Muerto" .

ex:ModoOperacion_EjeTandem ex:textoExtracto "eje tándem" ;
    a ex:ModoOperacion ;
    rdfs:label "Modo Operación Eje Tándem" .

ex:ModoOperacion_EjeMaestro ex:textoExtracto "eje maestro" ;
    a ex:ModoOperacion ;
    rdfs:label "Modo Operación Eje Maestro" .

ex:ModoOperacion_EjeEsclavo ex:textoExtracto "eje esclavo" ;
    a ex:ModoOperacion ;
    rdfs:label "Modo Operación Eje Esclavo" .

ex:Parametro_DWELL ex:textoExtracto "tiempo parametrizado en DWELL" ;
    a ex:Parametro ;
    rdfs:label "Parámetro DWELL" .

ex:Parametro_SERVOON_EjeMaestro ex:textoExtracto "el CNC sólo aplica el tiempo parametrizado en DWELL a la señal SERVOON del eje maestro" ;
    a ex:Parametro ;
    rdfs:label "Parámetro SERVOON Eje Maestro" .

ex:Error_EjeBloqueado ex:textoExtracto "podría dar error de eje bloqueado" ;
    a ex:DiagnosticoFallo ;
    rdfs:label "Error Eje Bloqueado" .

ex:Trayectoria_G5 ex:textoExtracto "programa con empalme de trayectorias G5" ;
    a ex:Parametro ;
    rdfs:label "Trayectoria G5" .

ex:Trayectoria_G50 ex:textoExtracto "programa con empalme de trayectorias G50" ;
    a ex:Parametro ;
    rdfs:label "Trayectoria G50" .

ex:Trayectoria_HSC ex:textoExtracto "programa con empalme de trayectorias HSC" ;
    a ex:Parametro ;
    rdfs:label "Trayectoria HSC" .