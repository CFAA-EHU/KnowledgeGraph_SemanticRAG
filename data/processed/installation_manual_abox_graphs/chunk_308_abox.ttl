@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:DIAMPROG a ex:Parametro ;
    rdfs:label "DIAMPROG" ;
    ex:textoExtracto "DIAMPROG Programación en diámetros. Parámetro válido para ejes lineales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPA.DIAMPROG.xn El CNC sólo tiene en cuenta este parámetro cuando FACEAXIS = Sí. En máquinas tipo torno, las cotas del eje transversal se pueden programar en radios o diámetros. Para cambiar el tipo de cotas desde el programa utilizar las funciones G151 ó G152. Los desplazamientos respecto al cero máquina (#MCS) siempre se realizan según este parámetro." ;
    ex:valor "Sí / No" ;
    ex:identificador "DIAMPROG" .

ex:ParametroEjeLineal a ex:Parametro ;
    rdfs:label "Parámetro para ejes lineales" ;
    ex:textoExtracto "Parámetro válido para ejes lineales" .

ex:ReguladorAnalogico a ex:ComponenteElectrico ;
    rdfs:label "Regulador analógico" ;
    ex:textoExtracto "Parámetro válido para regulador analógico" .

ex:Sercos a ex:ComponenteElectrico ;
    rdfs:label "Sercos" ;
    ex:textoExtracto "Parámetro válido para ... Sercos ..." .

ex:Simulado a ex:ComponenteElectrico ;
    rdfs:label "Simulado" ;
    ex:textoExtracto "Parámetro válido para ... simulado" .

ex:FACEAXIS a ex:Parametro ;
    rdfs:label "FACEAXIS" ;
    ex:textoExtracto "El CNC sólo tiene en cuenta este parámetro cuando FACEAXIS = Sí" ;
    ex:valor "Sí" .

ex:G151 a ex:Parametro ;
    rdfs:label "G151" ;
    ex:textoExtracto "Para cambiar el tipo de cotas desde el programa utilizar las funciones G151 ó G152" .

ex:G152 a ex:Parametro ;
    rdfs:label "G152" ;
    ex:textoExtracto "Para cambiar el tipo de cotas desde el programa utilizar las funciones G151 ó G152" .

ex:MCS a ex:Parametro ;
    rdfs:label "#MCS" ;
    ex:textoExtracto "Los desplazamientos respecto al cero máquina (#MCS) siempre se realizan según este parámetro" .