@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionReguladorSercos a ns1:Sistema ;
    rdfs:label "Configurar un regulador Sercos" ;
    ns1:textoExtracto "Configurar un regulador Sercos." ;
    ns1:tieneComponente ns1:TiempoDeMezclaDeCaptaciones_018d8ce25b,
        ns1:TipoDeCaptacion_0fa73967fd .

ns1:SeleccionDeCaptacion a ns1:Parametro ;
    rdfs:label "Selección de captación" ;
    ns1:textoExtracto "mediante la marca FBACKSEL(axis). Captación interna o externa." .

ns1:TiempoDeMezclaDeCaptaciones_018d8ce25b a ns1:Parametro ;
    rdfs:label "Tiempo de mezcla de captaciones" ;
    ns1:textoExtracto "FBACKSRC | FBMIXTIME | Tipo de captación." .

ns1:TipoDeCaptacion_0fa73967fd a ns1:Parametro ;
    rdfs:label "Tipo de captación" ;
    ns1:textoExtracto "FBACKSRC | FBMIXTIME | Tipo de captación." .

