@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_7dbace53f5 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC utiliza la captación interna (captación motor) en el encendido, cuando se resetea el regulador y cuando se inicializa el anillo Sercos." .

ns1:ConstanteDeTiempoParaLaCaptacionMixta_cdbcb6cd1e a ns1:Parametro ;
    rdfs:label "Constante de tiempo para la captación mixta" ;
    ns1:identificador "MPA.FBMIXTIME.xn" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos." ;
    ns1:valor "0" .

ns1:MaximaDiferenciaEntreCaptaciones_083937b49f a ns1:Parametro ;
    rdfs:label "Máxima diferencia entre captaciones" ;
    ns1:identificador "MPA.FBACKDIFF.xn" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador Sercos posición." ;
    ns1:valor "0 (no hay vigilancia)" .

ns1:SistemaReguladorSercos a ns1:Sistema ;
    rdfs:label "Regulador Sercos" ;
    ns1:textoExtracto "Parámetro válido para regulador Sercos posición." .

