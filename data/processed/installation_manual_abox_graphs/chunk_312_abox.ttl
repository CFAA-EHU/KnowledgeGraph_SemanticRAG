@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_DECINPUT
    a ex:Parametro ;
    rdfs:label "Parámetro DECINPUT"@es ;
    ex:textoExtracto "el parámetro DECINPUT debe tener valor"@es ;
    ex:valor "•" .

ex:Parametro_REFFEED1
    a ex:Parametro ;
    rdfs:label "Parámetro REFFEED1"@es ;
    ex:textoExtracto "La primera vuelta se da a la velocidad definida en REFFEED1"@es .

ex:ModoOperacion_BusquedaReferencia
    a ex:ModoOperacion ;
    rdfs:label "Búsqueda de referencia (eje rotativo sin I0 codificados)"@es ;
    ex:textoExtracto "Si el eje rotativo no dispone de I0 codificados, el parámetro DECINPUT debe tener valor •"@es ;
    ex:monitoreaParametro ex:Parametro_DECINPUT .

ex:ModoOperacion_CalculoPosicionMicro
    a ex:ModoOperacion ;
    rdfs:label "Cálculo de posición del micro (primera vuelta)"@es ;
    ex:textoExtracto "La primera vuelta se da a la velocidad definida en REFFEED1 y sirve para calcular la posición del micro"@es ;
    ex:monitoreaParametro ex:Parametro_REFFEED1 .

ex:ModoOperacion_AproximacionMicro
    a ex:ModoOperacion ;
    rdfs:label "Aproximación al micro (segunda vuelta)"@es ;
    ex:textoExtracto "La segunda vuelta se da a la misma velocidad hasta alcanzar el micro, pasando sobre él"@es .