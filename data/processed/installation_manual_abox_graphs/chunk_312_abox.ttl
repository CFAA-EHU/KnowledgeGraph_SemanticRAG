@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConstanteDeTiempoEnLaMezclaDeCaptaciones a ns1:Parametro ;
    rdfs:label "constante de tiempo en la mezcla de captaciones" ;
    ns1:documentadoEn ns1:CNC8070_b174bcbebb ;
    ns1:textoExtracto "Este parámetro permite definir la constante de tiempo a utilizar en la mezcla de captaciones; es decir, determina el retraso entre las cotas que se introducen al lazo de posición del encóder y de la regla." .

ns1:CNC8070_b174bcbebb a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro cuando la captación es externa o externa+interna." .

