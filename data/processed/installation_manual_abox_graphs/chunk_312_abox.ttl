@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_DECINPUT a ex:Parametro ;
    rdfs:label "DECINPUT" ;
    ex:textoExtracto "el parámetro DECINPUT debe tener valor" ;
    ex:valor "•" .

ex:ModoOperacion_REFFEED1 a ex:ModoOperacion ;
    rdfs:label "REFFEED1" ;
    ex:textoExtracto "velocidad definida en REFFEED1" .

ex:Sensor_micro_I0 a ex:Sensor ;
    rdfs:label "micro de I0" ;
    ex:textoExtracto "cabezales con micro de I0" .

ex:Sistema_cabezal a ex:Sistema ;
    rdfs:label "cabezal" ;
    ex:textoExtracto "el cabezal pasa dos veces sobre el micro" ;
    ex:compuestoPor ex:Sensor_micro_I0 ;
    ex:tieneComponente ex:ModoOperacion_REFFEED1 .