@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_REFFEED1
    a ex:Parametro ;
    rdfs:label "REFFEED1" ;
    ex:textoExtracto "La primera vuelta se da a la velocidad definida en REFFEED1 y sirve para calcular la posición del micro." ;
    ex:valor "velocidad_de_referencia_1" .

ex:Parametro_REFFEED2
    a ex:Parametro ;
    rdfs:label "REFFEED2" ;
    ex:textoExtracto "pasando sobre él a la velocidad definida en REFFEED2 y realizando la búsqueda de I0 habitual." ;
    ex:valor "velocidad_de_referencia_2" .

ex:Parametro_REFINI
    a ex:Parametro ;
    rdfs:label "REFINI" ;
    ex:identificador "MPA.REFINI.xn" ;
    ex:textoExtracto "REFINI Búsqueda de cero en el primer movimiento. Parámetro válido para cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)[ch].MPA.REFINI.xn Este parámetro establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento." ;
    ex:valor "Sí/No" .

ex:Parametro_NPULSES
    a ex:Parametro ;
    rdfs:label "NPULSES" ;
    ex:textoExtracto "Este parámetro sólo se tiene en cuenta cuando los parámetros NPULSES y NPULSES2 se han definido con valor distinto de 0." ;
    ex:valor "pulsos" .

ex:Parametro_NPULSES2
    a ex:Parametro ;
    rdfs:label "NPULSES2" ;
    ex:textoExtracto "Este parámetro sólo se tiene en cuenta cuando los parámetros NPULSES y NPULSES2 se han definido con valor distinto de 0." ;
    ex:valor "pulsos" .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "Este parámetro establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento." ;
    ex:tieneComponente ex:Parametro_REFINI, ex:Parametro_REFFEED1, ex:Parametro_REFFEED2, ex:Parametro_NPULSES, ex:Parametro_NPULSES2 .