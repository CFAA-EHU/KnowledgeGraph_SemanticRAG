@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:REFFEED1 a ex:Parametro ;
    rdfs:label "REFFEED1" ;
    ex:textoExtracto "velocidad definida en REFFEED1" ;
    ex:valor "definida en contexto" .

ex:REFFEED2 a ex:Parametro ;
    rdfs:label "REFFEED2" ;
    ex:textoExtracto "velocidad definida en REFFEED2" ;
    ex:valor "definida en contexto" .

ex:REFINI a ex:Parametro ;
    rdfs:label "REFINI" ;
    ex:textoExtracto "Parámetro válido para cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)[ch].MPA.REFINI.xn Este parámetro establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento. Este parámetro sólo se tiene en cuenta cuando los parámetros NPULSES y NPULSES2 se han definido con valor distinto de 0." ;
    ex:valor "Sí / No" .

ex:NPULSES a ex:Parametro ;
    rdfs:label "NPULSES" ;
    ex:textoExtracto "parámetros NPULSES y NPULSES2 se han definido con valor distinto de 0" .

ex:NPULSES2 a ex:Parametro ;
    rdfs:label "NPULSES2" ;
    ex:textoExtracto "parámetros NPULSES y NPULSES2 se han definido con valor distinto de 0" .

ex:ParametroBusquedaReferencia a ex:Parametro ;
    rdfs:label "Parámetro de búsqueda de referencia" ;
    ex:textoExtracto "Este parámetro establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento." .