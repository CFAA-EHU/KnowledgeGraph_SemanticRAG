@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionDeMezclaDeCaptaciones a ns1:Parametro ;
    rdfs:label "Configuración de mezcla de captaciones" ;
    ns1:documentadoEn ns1:SistemaReguladorSercos ;
    ns1:identificador "ReguladorSercos" ;
    ns1:textoExtracto "el parámetro se define con valor distinto de ꞏ0ꞏ, se habilita la mezcla de captaciones; si se define con valor ꞏ0ꞏ, sólo se utilizará la captación externa." .

ns1:SistemaReguladorSercos a ns1:Sistema ;
    rdfs:label "Regulador Sercos" ;
    ns1:textoExtracto "Este parámetro requiere una versión de regulador V6.13 o superior." .

