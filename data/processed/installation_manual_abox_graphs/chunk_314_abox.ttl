@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_PROBEAXIS
    a ex:Parametro ;
    rdfs:label "PROBEAXIS" ;
    ex:textoExtracto "PROBEAXIS [...] Este parámetro indica si el eje es participante en movimiento con palpador (G100)." ;
    ex:valor "Sí / No" ;
    ex:identificador "(V.)[ch].MPA.PROBEAXIS.xn" .

ex:Parametro_PROBERANGE
    a ex:Parametro ;
    rdfs:label "PROBERANGE" ;
    ex:textoExtracto "PROBERANGE [...] Este parámetro fija la máxima distancia de frenado del palpador tras realizar la palpación, evitando de esta forma la rotura del mismo (cerámicos, etc)." ;
    ex:valor "1.0000 mm / 0.03937 inch / 1.0000 grado" ;
    ex:identificador "(V.)[ch].MPA.PROBERANGE.xn" .

ex:Parametro_PROBEFEED
    a ex:Parametro ;
    rdfs:label "PROBEFEED" ;
    ex:textoExtracto "PROBEFEED [...] El valor de este parámetro debe ser inferior que el avance necesario para frenar en el espacio definido en PROBERANGE con los valores de aceleración y de jerk del eje." ;
    ex:valor "0" ;
    ex:identificador "(V.)[ch].MPA.PROBEFEED.xn" .

ex:Sistema_ConfiguracionMovimientoPalpador
    a ex:Sistema ;
    rdfs:label "Configuración del movimiento con palpador" ;
    ex:textoExtracto "Configuración del movimiento con palpador. Parámetros válidos para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ex:tieneComponente ex:Parametro_PROBEAXIS ;
    ex:tieneComponente ex:Parametro_PROBERANGE ;
    ex:tieneComponente ex:Parametro_PROBEFEED .