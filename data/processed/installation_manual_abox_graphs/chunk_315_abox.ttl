@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaReguladorMechatrolink a ns1:Tabla ;
    rdfs:label "Tabla de configuración del regulador Mechatrolink" ;
    ns1:ilustradoEn ns1:DatosDelReguladorMechatrolink ;
    ns1:textoExtracto "Este parámetro muestra la tabla para definir la comunicación con el regulador Mechatrolink." .

ns1:DatosDelReguladorMechatrolink a ns1:Parametro ;
    rdfs:label "Datos del regulador Mechatrolink" ;
    ns1:identificador "MLINKDATA" ;
    ns1:textoExtracto "MLINKDATA Datos del regulador Mechatrolink. Parámetro válido para ejes lineales, rotativos y cabezales." .

