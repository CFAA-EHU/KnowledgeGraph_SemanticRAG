@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarLasOpcionesDelRegulador a ns1:Parametro ;
    rdfs:label "Activar las opciones del regulador" ;
    ns1:documentadoEn ns1:TablaConfiguracionReguladorMechatrolink ;
    ns1:identificador "OPTION" ;
    ns1:textoExtracto "OPTION | Activar las opciones del regulador." .

ns1:DireccionDelRegulador a ns1:Parametro ;
    rdfs:label "Dirección del regulador" ;
    ns1:documentadoEn ns1:TablaConfiguracionReguladorMechatrolink ;
    ns1:identificador "DRIVEID" ;
    ns1:textoExtracto "DRIVEID | Dirección del regulador." .

ns1:ModoDeOperacionPrincipalDelRegulador a ns1:Parametro ;
    rdfs:label "Modo de operación principal del regulador" ;
    ns1:documentadoEn ns1:TablaConfiguracionReguladorMechatrolink ;
    ns1:identificador "OPMODEP" ;
    ns1:textoExtracto "OPMODEP | Modo de operación principal del regulador." .

ns1:TablaConfiguracionReguladorMechatrolink a ns1:Tabla ;
    rdfs:label "Tabla de configuración del regulador Mechatrolink" ;
    ns1:textoExtracto "MLINKDATA |  | DRIVEID | Dirección del regulador. | OPMODEP | Modo de operación principal del regulador. | OPTION | Activar las opciones del regulador." .

