@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DireccionDelRegulador a ns1:Parametro ;
    rdfs:label "Dirección del regulador" ;
    ns1:identificador "DRIVEID" ;
    ns1:textoExtracto "DRIVEID Dirección del regulador. Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:ModoDeOperacionPrincipalDelRegulador a ns1:Parametro ;
    rdfs:label "Modo de operación principal del regulador" ;
    ns1:identificador "OPMODEP" ;
    ns1:textoExtracto "OPMODEP Modo de operación principal del regulador. Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:TablaMLINKDATA a ns1:Tabla ;
    rdfs:label "Tabla MLINKDATA" ;
    ns1:textoExtracto "Este parámetro indica la posición (nodo) que ocupa el regulador en el bus Mechatrolink. Los reguladores ocuparán posiciones correlativas comenzando por ꞏ1ꞏ." .

ns1:VariableMPADRIVEIDXN a ns1:Parametro ;
    rdfs:label "Variable asociada al parámetro DRIVEID" ;
    ns1:identificador "MPA.DRIVEID.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.DRIVEID.xn Parámetro incluido en la tabla MLINKDATA." .

