@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_REPOSFEED a ex:Parametro ;
    rdfs:label "REPOSFEED" ;
    ex:identificador "REPOSFEED" ;
    ex:textoExtracto "REPOSFEED Avance máximo de reposicionamiento. Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0 a 200000.0000 mm/min. Valores posibles (2): De 0 a 7874.01575 inch/min. Valores posibles (3): De 0 a 36000000.0000 grados/min. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.REPOSFEED.xn Avance de reposicionamiento tras una inspección de herramienta o una subrutina de interrupción. Si no se define, el CNC asume para el reposicionamiento el avance definido para el modo jog continuo (parámetro JOGFEED). El valor del parámetro REPOSFEED deberá ser siempre menor que G00FEED, MAXMANFEED y JOGRAPFEED." ;
    ex:valor "De 0 a 200000.0000 mm/min, De 0 a 7874.01575 inch/min, De 0 a 36000000.0000 grados/min" .

ex:Parametro_JOGFEED a ex:Parametro ;
    rdfs:label "JOGFEED" ;
    ex:identificador "JOGFEED" ;
    ex:textoExtracto "El valor del parámetro REPOSFEED deberá ser siempre menor que G00FEED, MAXMANFEED y JOGRAPFEED." .

ex:Parametro_G00FEED a ex:Parametro ;
    rdfs:label "G00FEED" ;
    ex:identificador "G00FEED" ;
    ex:textoExtracto "El valor del parámetro REPOSFEED deberá ser siempre menor que G00FEED, MAXMANFEED y JOGRAPFEED." .

ex:Parametro_MAXMANFEED a ex:Parametro ;
    rdfs:label "MAXMANFEED" ;
    ex:identificador "MAXMANFEED" ;
    ex:textoExtracto "El valor del parámetro REPOSFEED deberá ser siempre menor que G00FEED, MAXMANFEED y JOGRAPFEED." .

ex:Parametro_JOGRAPFEED a ex:Parametro ;
    rdfs:label "JOGRAPFEED" ;
    ex:identificador "JOGRAPFEED" ;
    ex:textoExtracto "El valor del parámetro REPOSFEED deberá ser siempre menor que G00FEED, MAXMANFEED y JOGRAPFEED." .