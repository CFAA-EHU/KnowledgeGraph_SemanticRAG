@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_REPOSFEED
    a ex:Parametro ;
    rdfs:label "REPOSFEED" ;
    ex:identificador "REPOSFEED" ;
    ex:textoExtracto "REPOSFEED Avance máximo de reposicionamiento. Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ex:valor "0 a 200000.0000 mm/min / 0 a 7874.01575 inch/min / 0 a 36000000.0000 grados/min" ;
    ex:textoExtracto "Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.REPOSFEED.xn Avance de reposicionamiento tras una inspección de herramienta o una subrutina de interrupción." ;
    ex:textoExtracto "El valor del parámetro REPOSFEED deberá ser siempre menor que G00FEED, MAXMANFEED y JOGRAPFEED." .

ex:Parametro_G00FEED
    a ex:Parametro ;
    rdfs:label "G00FEED" ;
    ex:identificador "G00FEED" ;
    ex:textoExtracto "El valor del parámetro REPOSFEED deberá ser siempre menor que G00FEED, MAXMANFEED y JOGRAPFEED." .

ex:Parametro_MAXMANFEED
    a ex:Parametro ;
    rdfs:label "MAXMANFEED" ;
    ex:identificador "MAXMANFEED" ;
    ex:textoExtracto "El valor del parámetro REPOSFEED deberá ser siempre menor que G00FEED, MAXMANFEED y JOGRAPFEED." .

ex:Parametro_JOGRAPFEED
    a ex:Parametro ;
    rdfs:label "JOGRAPFEED" ;
    ex:identificador "JOGRAPFEED" ;
    ex:textoExtracto "El valor del parámetro REPOSFEED deberá ser siempre menor que G00FEED, MAXMANFEED y JOGRAPFEED." .

ex:Parametro_JOGFEED
    a ex:Parametro ;
    rdfs:label "JOGFEED" ;
    ex:identificador "JOGFEED" ;
    ex:textoExtracto "Si no se define, el CNC asume para el reposicionamiento el avance definido para el modo jog continuo (parámetro JOGFEED)." .