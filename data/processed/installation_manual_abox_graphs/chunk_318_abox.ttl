@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_POSFEED
    a ex:Parametro ;
    rdfs:label "POSFEED (Avance de posicionamiento)"@es ;
    ex:textoExtracto "POSFEED Avance de posicionamiento. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado."@es ;
    ex:valor "0-200000.0000 mm/min / 0-7874.01575 inch/min / 0-36000000.0000 grados/min / 0-100000.0000 rpm" ;
    ex:identificador "POSFEED" .

ex:ValorDefecto_POSFEED
    a ex:Parametro ;
    rdfs:label "Valor por defecto de POSFEED"@es ;
    ex:textoExtracto "Valor por defecto: 1000.0000 mm/min / 39.37008 inch/min / 1000.0000 grados/min / 1000 rpm."@es ;
    ex:valor "1000.0000 mm/min / 39.37008 inch/min / 1000.0000 grados/min / 1000 rpm" ;
    ex:identificador "POSFEED_DEFAULT" .