@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:OpcionesDelRegulador a ns1:Parametro ;
    rdfs:label "Opciones del regulador" ;
    ns1:identificador "OPTION" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Mechatrolink." .

ns1:TablaMLINKDATA a ns1:Parametro ;
    rdfs:label "Tabla MLINKDATA" ;
    ns1:identificador "MLINKDATA" ;
    ns1:textoExtracto "Parámetro incluido en la tabla MLINKDATA." .

ns1:TipoDeReguladorYModoDeOperacion a ns1:Parametro ;
    rdfs:label "Tipo de regulador y modo de operación" ;
    ns1:identificador "MPA.OPMODEP.xn" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Mechatrolink." .

ns1:VariableVchMPAOPMODEP a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.OPMODEP.xn" ;
    ns1:identificador "V.ch.MPA.OPMODEP.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.OPMODEP.xn" .

