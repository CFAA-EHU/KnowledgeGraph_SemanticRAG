@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaReguladorMechatrolink a ns1:Sistema ;
    rdfs:label "Sistema Regulador Mechatrolink" ;
    ns1:textoExtracto "permite configurar diferentes opciones del regulador Mechatrolink, como activar filtros de aceleración o deceleración, activar la primera o segunda captación, elegir un control P o PI para el lazo de velocidad, etc." ;
    ns1:tieneComponente ns1:OpcionesDelReguladorCodificadasEnFormatoDe16Bits .

ns1:OpcionesDelReguladorCodificadasEnFormatoDe16Bits a ns1:Parametro ;
    rdfs:label "Opciones del regulador codificadas en formato de 16 bits" ;
    ns1:textoExtracto "Las opciones del regulador están codificadas en formato de 16 bits. Consulte el manual de regulador para conocer el significado de cada bit." ;
    ns1:valor "16 bits" .

