@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SLIMITAC a ex:ComponenteElectrico ;
    rdfs:label "SLIMITAC" ;
    ex:textoExtracto "desde el PLC (marcas SLIMITAC o SLIMITACSPDL)" .

ex:SLIMITACSPDL a ex:ComponenteElectrico ;
    rdfs:label "SLIMITACSPDL" ;
    ex:textoExtracto "desde el PLC (marcas SLIMITAC o SLIMITACSPDL)" .

ex:PLCCNTL a ex:ComponenteElectrico ;
    rdfs:label "PLCCNTL" ;
    ex:textoExtracto "cabezales controlados por PLC (marca PLCCNTL)" .

ex:Parametro_velocidad_maxima_mecanizado a ex:Parametro ;
    ex:valor "0" ;
    ex:textoExtracto "Si el parámetro se define con valor ꞏ0ꞏ, no se limita la velocidad." .

ex:Funcion_G192 a ex:ModoOperacion ;
    rdfs:label "G192" ;
    ex:textoExtracto "fijar una velocidad máxima de giro para el mecanizado, por programa (función G192)" .

ex:Variable_PLC_SL_sn a ex:Parametro ;
    rdfs:label "V.PLC.SL.sn" ;
    ex:textoExtracto "por PLC (variable (V.)PLC.SL.sn)" .

ex:PLC a ex:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ex:textoExtracto "desde el PLC (marcas SLIMITAC o SLIMITACSPDL) y el CNC lo aplica en el bloque en ejecución." .

ex:CNC a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "el CNC lo aplica en el bloque en ejecución. Al desactivar los límites, el CNC recupera la velocidad programada." .