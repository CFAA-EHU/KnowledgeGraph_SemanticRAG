@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjeHirth_63f38ddd54 a ns1:Parametro ;
    rdfs:label "Eje Hirth" ;
    ns1:documentadoEn ns1:TablaParametrosEje ;
    ns1:identificador "MPA.HIRTH.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.HIRTH.xn Se denomina eje Hirth al que debe posicionarse siempre en posiciones múltiplos de un valor dado." .

ns1:PasoDelEjeHirth a ns1:Parametro ;
    rdfs:label "Paso del eje Hirth" ;
    ns1:documentadoEn ns1:TablaParametrosEje ;
    ns1:identificador "MPA.HPITCH.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.HPITCH.xn Cuando el eje está definido como eje hirth, este parámetro indica el paso del mismo." .

ns1:TablaParametrosEje a ns1:Tabla ;
    rdfs:label "Tabla de parámetros del eje" ;
    ns1:textoExtracto "Las posiciones del conmutador para los movimientos en jog se pueden personalizar en la tabla de parámetros del eje, para que se correspondan con los pasos deseados." .

