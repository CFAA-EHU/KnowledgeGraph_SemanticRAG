@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla322_2_5_24 a ex:Tabla ;
    ex:textoExtracto "Límite de seguridad para la velocidad. | Límite para la velocidad de mecanizado. | Límite de velocidad activo." ;
    ex:tieneComponente ex:LimiteSeguridadVelocidad, ex:LimiteVelocidadMecanizado, ex:LimiteVelocidadActivo .

ex:LimiteSeguridadVelocidad a ex:Parametro ;
    ex:textoExtracto "Límite de seguridad para la velocidad." ;
    ex:valor "0, 50, 50, 150" .

ex:LimiteVelocidadMecanizado a ex:Parametro ;
    ex:textoExtracto "Límite para la velocidad de mecanizado." ;
    ex:valor "100, 0, 100, 100" .

ex:LimiteVelocidadActivo a ex:Parametro ;
    ex:textoExtracto "Límite de velocidad activo." ;
    ex:valor "100, 50, 50, 100" .