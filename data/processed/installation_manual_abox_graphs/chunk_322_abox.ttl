@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjeX a ns1:Componente ;
    rdfs:label "Eje X" ;
    ns1:textoExtracto "Eje X. FACEAXIS = Sí | LONGAXIS = No" ;
    ns1:tieneComponente ns1:EjeTransversal_442d07fd82 .

ns1:EjeZ a ns1:Componente ;
    rdfs:label "Eje Z" ;
    ns1:textoExtracto "Eje Z. FACEAXIS = No | LONGAXIS = Sí" ;
    ns1:tieneComponente ns1:EjeLongitudinal_833c178edf .

ns1:PersonalizacionHabitualEnTorno a ns1:TareaMantenimiento ;
    rdfs:label "Personalización habitual en torno" ;
    ns1:documentadoEn ns1:TablaConfiguracionEjesTorno ;
    ns1:textoExtracto "En tornos hay indicar cuál es el eje longitudinal y el transversal." .

ns1:EjeLongitudinal_833c178edf a ns1:Parametro ;
    rdfs:label "Eje longitudinal" ;
    ns1:identificador "MPA.LONGAXIS.xn" ;
    ns1:textoExtracto "LONGAXIS Eje longitudinal. Parámetro válido para ejes lineales." .

ns1:EjeTransversal_442d07fd82 a ns1:Parametro ;
    rdfs:label "Eje transversal" ;
    ns1:identificador "MPA.FACEAXIS.xn" ;
    ns1:textoExtracto "FACEAXIS Eje transversal. Parámetro válido para ejes lineales." .

ns1:TablaConfiguracionEjesTorno a ns1:Tabla ;
    rdfs:label "Tabla de configuración de ejes en torno" ;
    ns1:textoExtracto "Personalización habitual en torno:" .

