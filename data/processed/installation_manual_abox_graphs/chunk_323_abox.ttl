@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TablaParametrosModoManual a ex:Tabla ;
    ex:textoExtracto "Tabla de parámetros del modo manual. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Este parámetro muestra la tabla de parámetros para definir los desplazamientos en modo manual. En los cabezales, estos parámetros sólo se aplicarán cuando el cabezal se interpole con ejes durante el roscado rígido o cuando el cabezal trabaje como eje C." ;
    rdfs:label "Tabla de parámetros del modo manual" .

ex:ParametroDesplazamientoModoManual a ex:Parametro ;
    ex:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Este parámetro muestra la tabla de parámetros para definir los desplazamientos en modo manual." ;
    rdfs:label "Parámetro de desplazamiento en modo manual" .

ex:ModoOperacionManual a ex:ModoOperacion ;
    ex:textoExtracto "modo manual" ;
    rdfs:label "Modo de operación manual" ;
    ex:detalladoEnEsquema ex:TablaParametrosModoManual .

ex:EjeLineal a ex:Componente ;
    ex:textoExtracto "ejes lineales" ;
    rdfs:label "Eje lineal" ;
    ex:compuestoPor ex:ParametroDesplazamientoModoManual .

ex:EjeRotativo a ex:Componente ;
    ex:textoExtracto "ejes rotativos" ;
    rdfs:label "Eje rotativo" ;
    ex:compuestoPor ex:ParametroDesplazamientoModoManual .

ex:Cabezal a ex:Componente ;
    ex:textoExtracto "cabezales" ;
    rdfs:label "Cabezal" ;
    ex:compuestoPor ex:ParametroDesplazamientoModoManual .

ex:ReguladorAnalogico a ex:Componente ;
    ex:textoExtracto "regulador analógico" ;
    rdfs:label "Regulador analógico" ;
    ex:compuestoPor ex:ParametroDesplazamientoModoManual .

ex:SistemaSercos a ex:Sistema ;
    ex:textoExtracto "Sercos" ;
    rdfs:label "Sistema Sercos" ;
    ex:compuestoPor ex:ParametroDesplazamientoModoManual .

ex:SimulacionModoManual a ex:ModoOperacion ;
    ex:textoExtracto "simulado" ;
    rdfs:label "Simulación en modo manual" ;
    ex:compuestoPor ex:ParametroDesplazamientoModoManual .

ex:RoscadoRigido a ex:AccionProhibida ;
    ex:textoExtracto "roscado rígido" ;
    rdfs:label "Roscado rígido" .

ex:EjeC a ex:Componente ;
    ex:textoExtracto "eje C" ;
    rdfs:label "Eje C" .