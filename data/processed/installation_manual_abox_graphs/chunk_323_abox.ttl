@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaParametrosModoManual a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros del modo manual"@es ;
    ex:textoExtracto "Tabla de parámetros del modo manual. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado."@es ;
    ex:identificador "Tabla_2.5.25" .

ex:Parametro_DesplazamientoManual
    a ex:Parametro ;
    rdfs:label "Parámetro de desplazamiento en modo manual"@es ;
    ex:textoExtracto "Este parámetro muestra la tabla de parámetros para definir los desplazamientos en modo manual."@es ;
    ex:documentadoEn ex:TablaParametrosModoManual ;
    ex:valor "Definición de desplazamientos (ejes lineales, rotativos, cabezales en roscado rígido o eje C)"@es .

ex:ModoOperacion_Manual
    a ex:ModoOperacion ;
    rdfs:label "Modo de trabajo manual"@es ;
    ex:textoExtracto "Modo de trabajo manual"@es ;
    ex:detalladoEnEsquema ex:TablaParametrosModoManual .