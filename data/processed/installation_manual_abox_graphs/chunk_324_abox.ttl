@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefineLaOrientacionDeLaHerramientaSegunLosEjesFACEAXISYLONGAXIS a ns1:Parametro ;
    rdfs:label "Define la orientación de la herramienta según los ejes FACEAXIS y LONGAXIS" ;
    ns1:textoExtracto "parámetro FIXORI define si la herramienta está orientada según los ejes definidos en FACEAXIS y LONGAXIS" .

ns1:SistemaHidraulicoTorno a ns1:Sistema ;
    rdfs:label "Sistema de configuración de ejes en torno" ;
    ns1:textoExtracto "Personalización habitual en torno (si el eje rotativo es el B)" ;
    ns1:tieneComponente ns1:EjeB,
        ns1:EjeC,
        ns1:EjeY,
        ns1:EjeZ .

ns1:EjeB a ns1:ComponenteMecanico ;
    rdfs:label "Eje B (rotativo)" ;
    ns1:parametroMonitoradoPor ns1:IndicaSiElEjeEsRotativo ;
    ns1:textoExtracto "Eje B. CAXIS=Sí" .

ns1:EjeC a ns1:ComponenteMecanico ;
    rdfs:label "Eje C (rotativo)" ;
    ns1:parametroMonitoradoPor ns1:IndicaSiElEjeEsRotativo ;
    ns1:textoExtracto "Eje C. CAXIS=Sí" .

ns1:EjeY a ns1:ComponenteMecanico ;
    rdfs:label "Eje Y (lineal asociado al rotativo)" ;
    ns1:parametroMonitoradoPor ns1:IndicaSiElEjeEsFrontal,
        ns1:IndicaSiElEjeEsLongitudinal,
        ns1:IndicaSiElEjeEsRotativo ;
    ns1:textoExtracto "Eje Y (eje lineal asociado al rotativo). FACEAXIS = No LONGAXIS = Sí CAXIS=No" .

ns1:EjeZ a ns1:ComponenteMecanico ;
    rdfs:label "Eje Z (lineal)" ;
    ns1:parametroMonitoradoPor ns1:IndicaSiElEjeEsFrontal,
        ns1:IndicaSiElEjeEsLongitudinal,
        ns1:IndicaSiElEjeEsRotativo ;
    ns1:textoExtracto "Eje Z. FACEAXIS = Sí LONGAXIS = No CAXIS=No" .

ns1:IndicaSiElEjeEsFrontal a ns1:Parametro ;
    rdfs:label "Indica si el eje es frontal" ;
    ns1:textoExtracto "FACEAXIS = Sí" .

ns1:IndicaSiElEjeEsLongitudinal a ns1:Parametro ;
    rdfs:label "Indica si el eje es longitudinal" ;
    ns1:textoExtracto "LONGAXIS = Sí" .

ns1:IndicaSiElEjeEsRotativo a ns1:Parametro ;
    rdfs:label "Indica si el eje es rotativo" ;
    ns1:textoExtracto "CAXIS=Sí" .

