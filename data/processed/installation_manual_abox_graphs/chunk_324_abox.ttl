@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ModoOperacionManual a ex:ModoOperacion ;
    ex:textoExtracto "Modo de trabajo manual." ;
    ex:compuestoPor ex:JOGFEED, ex:JOGRAPFEED, ex:MAXMANFEED, ex:MAXMANACC, ex:INCJOGDIST, ex:INCJOGFEED, ex:MPGRESOL, ex:MPGFILTER, ex:MANPOSSW, ex:MANNEGSW, ex:MANFEEDP, ex:IPOFEEDP, ex:MANACCP, ex:IPOACCP .

ex:JOGFEED a ex:Parametro ;
    ex:identificador "JOGFEED" ;
    ex:textoExtracto "Avance en modo jog continuo." .

ex:JOGRAPFEED a ex:Parametro ;
    ex:identificador "JOGRAPFEED" ;
    ex:textoExtracto "Avance rápido en modo jog continuo." .

ex:MAXMANFEED a ex:Parametro ;
    ex:identificador "MAXMANFEED" ;
    ex:textoExtracto "Avance máximo en modo jog continuo." .

ex:MAXMANACC a ex:Parametro ;
    ex:identificador "MAXMANACC" ;
    ex:textoExtracto "Aceleración máxima en modo jog continuo." .

ex:INCJOGDIST a ex:Parametro ;
    ex:identificador "INCJOGDIST" ;
    ex:textoExtracto "Distancia a recorrer en jog incremental." .

ex:INCJOGFEED a ex:Parametro ;
    ex:identificador "INCJOGFEED" ;
    ex:textoExtracto "Avance en jog incremental." .

ex:MPGRESOL a ex:Parametro ;
    ex:identificador "MPGRESOL" ;
    ex:textoExtracto "Resolución del volante." .

ex:MPGFILTER a ex:Parametro ;
    ex:identificador "MPGFILTER" ;
    ex:textoExtracto "Tiempo de filtro para el volante." .

ex:MANPOSSW a ex:Parametro ;
    ex:identificador "MANPOSSW" ;
    ex:textoExtracto "Máximo recorrido positivo con G201." .

ex:MANNEGSW a ex:Parametro ;
    ex:identificador "MANNEGSW" ;
    ex:textoExtracto "Máximo recorrido negativo con G201." .

ex:MANFEEDP a ex:Parametro ;
    ex:identificador "MANFEEDP" ;
    ex:textoExtracto "Máximo porcentaje de avance manual en G201." .

ex:IPOFEEDP a ex:Parametro ;
    ex:identificador "IPOFEEDP" ;
    ex:textoExtracto "Máximo porcentaje de avance de ejecución en G201." .

ex:MANACCP a ex:Parametro ;
    ex:identificador "MANACCP" ;
    ex:textoExtracto "Máximo porcentaje de aceleración manual en G201." .

ex:IPOACCP a ex:Parametro ;
    ex:identificador "IPOACCP" ;
    ex:textoExtracto "Máximo porcentaje de aceleración de ejecución en G201." .