@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefineElEjeFacialDeLaHerramienta a ns1:Parametro ;
    rdfs:label "Define el eje facial de la herramienta"@es ;
    ns1:identificador "FACEAXIS" ;
    ns1:textoExtracto "los parámetros FACEAXIS y LONGAXIS" .

ns1:DefineElEjeLongitudinalDeLaHerramienta a ns1:Parametro ;
    rdfs:label "Define el eje longitudinal de la herramienta"@es ;
    ns1:identificador "LONGAXIS" ;
    ns1:textoExtracto "los parámetros FACEAXIS y LONGAXIS" .

ns1:DefineLaOrientacionDeLaHerramientaSegunLosEjesDefinidosEnFACEAXISYLONGAXIS a ns1:Parametro ;
    rdfs:label "Define la orientación de la herramienta según los ejes definidos en FACEAXIS y LONGAXIS"@es ;
    ns1:identificador "FIXORI" ;
    ns1:textoExtracto "el parámetro FIXORI define si la herramienta está orientada según los ejes definidos en FACEAXIS y LONGAXIS" .

