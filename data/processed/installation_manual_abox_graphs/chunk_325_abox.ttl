@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoOperacion_ManualJogContinuo
    a ex:ModoOperacion ;
    rdfs:label "Modo de trabajo manual. Jog continuo"@es ;
    ex:textoExtracto "MODO DE TRABAJO MANUAL. JOG CONTINUO."@es ;
    ex:tieneComponente ex:Parametro_JOGFEED, ex:Parametro_JOGRAPFEED, ex:Parametro_MAXMANFEED .

ex:Parametro_JOGFEED
    a ex:Parametro ;
    rdfs:label "JOGFEED" ;
    ex:identificador "JOGFEED" ;
    ex:textoExtracto "JOGFEED Avance en jog continuo. Parámetro válido para ejes lineales, rotativos y cabezales. [...] Este parámetro define el avance para los desplazamientos en jog continuo en modo manual."@es ;
    ex:valor "1000.0000" ;
    ex:documentadoEn ex:Tabla_Manual .

ex:Parametro_JOGRAPFEED
    a ex:Parametro ;
    rdfs:label "JOGRAPFEED" ;
    ex:identificador "JOGRAPFEED" ;
    ex:textoExtracto "JOGRAPFEED Avance rápido en jog continuo. [...] Este parámetro define el avance rápido para los desplazamientos en jog continuo en modo manual."@es ;
    ex:valor "10000.0000" ;
    ex:documentadoEn ex:Tabla_Manual .

ex:Parametro_MAXMANFEED
    a ex:Parametro ;
    rdfs:label "MAXMANFEED" ;
    ex:identificador "MAXMANFEED" ;
    ex:textoExtracto "MAXMANFEED Avance máximo en jog continuo. Parámetro válido para ejes lineales, rotativos y cabezales. [...]"@es ;
    ex:documentadoEn ex:Tabla_Manual .

ex:Tabla_Manual a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla MANUAL"@es ;
    ex:textoExtracto "Parámetro incluido en la tabla MANUAL."@es .