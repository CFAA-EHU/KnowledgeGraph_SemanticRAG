@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SetDeParametrosParaLaSincronizacion a ns1:Parametro ;
    rdfs:label "Set de parámetros para la sincronización" ;
    ns1:identificador "MPA.SYNCSET.xn" ;
    ns1:textoExtracto "Parámetro válido para ejes rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "1" .

ns1:VentanaDeSincronizacionEnVelocidad a ns1:Parametro ;
    rdfs:label "Ventana de sincronización en velocidad" ;
    ns1:identificador "MPA.DSYNCVELW.xn" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "100 mm/min / 3.937 inch/min / 3600 grados/min / 10 rpm" .

