@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SincronizacionDeVelocidad a ns1:Parametro ;
    rdfs:label "Sincronización de velocidad" ;
    ns1:textoExtracto "Si se supera el valor definido en este parámetro, la señal SYNSPEED se pone a nivel lógico bajo;" .

