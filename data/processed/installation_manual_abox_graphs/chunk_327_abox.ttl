@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MPA_MAXMANACC_xn a ex:Parametro ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.MAXMANACC.xn Parámetro incluido en la tabla MANUAL. Este parámetro define la aceleración máxima para los desplazamientos en jog continuo en modo manual." ;
    rdfs:label "[ch].MPA.MAXMANACC.xn" .

ex:INCJOGDIST a ex:Tabla ;
    ex:textoExtracto "INCJOGDIST Tabla de desplazamientos en jog incremental. La tabla consta de cinco parámetros, uno para cada posición del conmutador del panel de mando. INCJOGDIST1 Posición ꞏ1ꞏ del conmutador. INCJOGDIST2 Posición ꞏ10ꞏ del conmutador. INCJOGDIST3 Posición ꞏ100ꞏ del conmutador. INCJOGDIST4 Posición ꞏ1000ꞏ del conmutador. INCJOGDIST5 Posición ꞏ10000ꞏ del conmutador. INCJOGDIST n Distancia recorrida en jog incremental." ;
    ex:compuestoPor ex:INCJOGDIST1, ex:INCJOGDIST2, ex:INCJOGDIST3, ex:INCJOGDIST4, ex:INCJOGDIST5 .

ex:INCJOGDIST1 a ex:Parametro ;
    ex:textoExtracto "INCJOGDIST1 Posición ꞏ1ꞏ del conmutador." ;
    rdfs:label "INCJOGDIST1" .

ex:INCJOGDIST2 a ex:Parametro ;
    ex:textoExtracto "INCJOGDIST2 Posición ꞏ10ꞏ del conmutador." ;
    rdfs:label "INCJOGDIST2" .

ex:INCJOGDIST3 a ex:Parametro ;
    ex:textoExtracto "INCJOGDIST3 Posición ꞏ100ꞏ del conmutador." ;
    rdfs:label "INCJOGDIST3" .

ex:INCJOGDIST4 a ex:Parametro ;
    ex:textoExtracto "INCJOGDIST4 Posición ꞏ1000ꞏ del conmutador." ;
    rdfs:label "INCJOGDIST4" .

ex:INCJOGDIST5 a ex:Parametro ;
    ex:textoExtracto "INCJOGDIST5 Posición ꞏ10000ꞏ del conmutador." ;
    rdfs:label "INCJOGDIST5" .