    ex:valor "De 0.0000 a 3937.00787 inch" .

ex:Parametro_328_3 a ex:Parametro ;
    rdfs:label "Parámetro válido para regulador analógico, Sercos y simulado" ;
    ex:identificador "3" ;
    ex:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado." ;
    ex:valor "De 0.0001 a 99999.9999 grados" .

ex:VariableAsociada_328 a ex:Parametro ;
