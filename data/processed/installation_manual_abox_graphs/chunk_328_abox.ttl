@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_328_1 a ex:Parametro ;
    rdfs:label "Parámetro válido para regulador analógico, Sercos y simulado" ;
