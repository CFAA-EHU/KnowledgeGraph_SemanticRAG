@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_0a0dc5f3a2 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro cuando AXISMODE = Módulo y SHORTESTWAY = No." .

ns1:PosicionamientoPorElCaminoMasCorto a ns1:Parametro ;
    rdfs:label "Posicionamiento por el camino más corto" ;
    ns1:identificador "SHORTESTWAY" ;
    ns1:textoExtracto "Parámetro válido para ejes rotativos. Valores posibles: Sí / No." .

ns1:SentidoDeGiroUnico a ns1:Parametro ;
    rdfs:label "Sentido de giro único" ;
    ns1:identificador "UNIDIR" ;
    ns1:textoExtracto "Parámetro válido para ejes rotativos. Valores posibles: No (ambos sentidos) / Positivo / Negativo." .

ns1:VariableMPASHORTESTWAY a ns1:Parametro ;
    rdfs:label "Variable asociada al parámetro SHORTESTWAY" ;
    ns1:identificador "MPA.SHORTESTWAY.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.SHORTESTWAY.xn" .

ns1:VariableMPAUNIDIR a ns1:Parametro ;
    rdfs:label "Variable asociada al parámetro UNIDIR" ;
    ns1:identificador "MPA.UNIDIR.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.UNIDIR.xn" .

