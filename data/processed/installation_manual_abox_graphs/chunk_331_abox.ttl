@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MPGRESOL1 a ex:Parametro ;
    rdfs:label "MPGRESOL1" ;
    ex:textoExtracto "MPGRESOL1 Posición ꞏ1ꞏ del conmutador." ;
    ex:valor "1" .

ex:MPGRESOL2 a ex:Parametro ;
    rdfs:label "MPGRESOL2" ;
    ex:textoExtracto "MPGRESOL2 Posición ꞏ10ꞏ del conmutador." ;
    ex:valor "10" .

ex:MPGRESOL3 a ex:Parametro ;
    rdfs:label "MPGRESOL3" ;
    ex:textoExtracto "MPGRESOL3 Posición ꞏ100ꞏ del conmutador." ;
    ex:valor "100" .

ex:MPGRESOLn a ex:Parametro ;
    rdfs:label "MPGRESOLn" ;
    ex:textoExtracto "MPGRESOL n Resolución del volante en cada posición del conmutador." .

ex:ModoTrabajoManual a ex:ModoOperacion ;
    rdfs:label "Modo de trabajo manual" ;
    ex:textoExtracto "Este parámetro muestra la tabla para definir la resolución del volante en cada posición del conmutador de jog." .

ex:TablaResolucionVolante a ex:Tabla ;
    rdfs:label "Tabla de resolución del volante" ;
    ex:textoExtracto "La tabla consta de tres parámetros, uno para cada posición del conmutador del panel de mando." ;
    ex:compuestoPor ex:MPGRESOL1, ex:MPGRESOL2, ex:MPGRESOL3, ex:MPGRESOLn .

ex:ConmutadorJog a ex:ComponenteElectrico ;
    rdfs:label "Conmutador de jog" ;
    ex:textoExtracto "posición del conmutador de jog" .

ex:PanelMando a ex:InterfazUsuario ;
    rdfs:label "Panel de mando" ;
    ex:textoExtracto "posición del conmutador del panel de mando" .

ex:ParametroResolucion a ex:Parametro ;
    rdfs:label "Resolución del volante" ;
    ex:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." .