@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ResolucionVolante_Jog a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de resolución del volante por posición del conmutador de jog"@es ;
    ex:textoExtracto "Este parámetro muestra la tabla para definir la resolución del volante en cada posición del conmutador de jog. La tabla consta de tres parámetros, uno para cada posición del conmutador del panel de mando."@es ;
    ex:detalladoEnEsquema ex:InterfazUsuario_PanelMando .

ex:Parametro_MPGRESOL1
    a ex:Parametro ;
    rdfs:label "MPGRESOL1 (Resolución en posición '1' del conmutador)"@es ;
    ex:identificador "MPGRESOL1" ;
    ex:textoExtracto "MPGRESOL1 Posición ꞏ1ꞏ del conmutador."@es ;
    ex:valor "±99999.9999 mm / ±3937.00787 inch / ±99999.9999 grados (no admite '0')"@es ;
    ex:documentadoEn ex:Tabla_ResolucionVolante_Jog .

ex:Parametro_MPGRESOL2
    a ex:Parametro ;
    rdfs:label "MPGRESOL2 (Resolución en posición '10' del conmutador)"@es ;
    ex:identificador "MPGRESOL2" ;
    ex:textoExtracto "MPGRESOL2 Posición ꞏ10ꞏ del conmutador."@es ;
    ex:valor "±99999.9999 mm / ±3937.00787 inch / ±99999.9999 grados (no admite '0')"@es ;
    ex:documentadoEn ex:Tabla_ResolucionVolante_Jog .

ex:Parametro_MPGRESOL3
    a ex:Parametro ;
    rdfs:label "MPGRESOL3 (Resolución en posición '100' del conmutador)"@es ;
    ex:identificador "MPGRESOL3" ;
    ex:textoExtracto "MPGRESOL3 Posición ꞏ100ꞏ del conmutador."@es ;
    ex:valor "±99999.9999 mm / ±3937.00787 inch / ±99999.9999 grados (no admite '0')"@es ;
    ex:documentadoEn ex:Tabla_ResolucionVolante_Jog .

ex:InterfazUsuario_PanelMando
    a ex:InterfazUsuario ;
    rdfs:label "Panel de mando (conmutador de jog)"@es ;
    ex:textoExtracto "conmutador del panel de mando"@es ;
    ex:tieneComponente ex:ComponenteElectrico_ConmutadorJog .

ex:ComponenteElectrico_ConmutadorJog
    a ex:ComponenteElectrico ;
    rdfs:label "Conmutador de jog (3 posiciones: 1, 10, 100)"@es ;
    ex:textoExtracto "conmutador de jog [...] Posición ꞏ1ꞏ [...] Posición ꞏ10ꞏ [...] Posición ꞏ100ꞏ"@es ;
    ex:ilustradoEn ex:Tabla_ResolucionVolante_Jog .