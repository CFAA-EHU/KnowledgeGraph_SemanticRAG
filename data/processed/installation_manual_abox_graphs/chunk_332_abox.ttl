@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IndicaSiLosDesplazamientosEnG90DeLosEjesRotativosSeRealizanPorElCaminoMasCorto a ns1:Parametro ;
    rdfs:label "Indica si los desplazamientos en G90 de los ejes rotativos se realizan por el camino más corto" ;
    ns1:identificador "SHORTESTWAY" ;
    ns1:textoExtracto "Este parámetro indica si los desplazamientos en G90 de los ejes rotativos se realizan por el camino más corto. En caso contrario, el signo programado indicará el sentido de giro mientras que el valor absoluto de la cota indicará la posición a alcanzar." .

