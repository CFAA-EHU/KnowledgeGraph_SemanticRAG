@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ParametroMPGRESOLxn a ex:Parametro ;
    rdfs:label "MPA.MPGRESOL[pos].xn" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.MPGRESOL[pos].xn En cada parámetro hay que definir la distancia que se desplaza el eje por cada impulso del volante." ;
    ex:valor "Entre ±99999.9999 mm (no se admite ꞏ0ꞏ)" .

ex:ParametroMPGRESOLxnUnidadMM a ex:Parametro ;
    ex:textoExtracto "Valores posibles (1): Entre ±99999.9999 mm (no se admite ꞏ0ꞏ)." ;
    ex:valor "±99999.9999" .

ex:ParametroMPGRESOLxnUnidadInch a ex:Parametro ;
    ex:textoExtracto "Valores posibles (2): Entre ±3937.00787 inch (no se admite ꞏ0ꞏ)." ;
    ex:valor "±3937.00787" .

ex:ParametroMPGRESOLxnUnidadGrados a ex:Parametro ;
    ex:textoExtracto "Valores posibles (3): Entre ±99999.9999 grados (no se admite ꞏ0ꞏ)." ;
    ex:valor "±99999.9999" .