@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ResolucionMPG a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de resolución de parámetros MPG"@es ;
    ex:textoExtracto """
| Parámetro. | Resolución. |
| --- | --- |
| MPGRESOL1 | 0.0010 mm o grados / 0.00003937 inch. |
| MPGRESOL2 | 0.0100 mm o grados / 0.00039370 inch. |
| MPGRESOL3 | 0.1000 mm o grados / 0.00393700 inch.
""" .

ex:Parametro_MPGRESOL1
    a ex:Parametro ;
    rdfs:label "MPGRESOL1" ;
    ex:identificador "MPGRESOL1" ;
    ex:valor "0.0010 mm o grados / 0.00003937 inch" ;
    ex:documentadoEn ex:Tabla_ResolucionMPG ;
    ex:textoExtracto "MPGRESOL1 | 0.0010 mm o grados / 0.00003937 inch." .

ex:Parametro_MPGRESOL2
    a ex:Parametro ;
    rdfs:label "MPGRESOL2" ;
    ex:identificador "MPGRESOL2" ;
    ex:valor "0.0100 mm o grados / 0.00039370 inch" ;
    ex:documentadoEn ex:Tabla_ResolucionMPG ;
    ex:textoExtracto "MPGRESOL2 | 0.0100 mm o grados / 0.00039370 inch." .

ex:Parametro_MPGRESOL3
    a ex:Parametro ;
    rdfs:label "MPGRESOL3" ;
    ex:identificador "MPGRESOL3" ;
    ex:valor "0.1000 mm o grados / 0.00393700 inch" ;
    ex:documentadoEn ex:Tabla_ResolucionMPG ;
    ex:textoExtracto "MPGRESOL3 | 0.1000 mm o grados / 0.00393700 inch." .