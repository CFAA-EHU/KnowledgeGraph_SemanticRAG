@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CompensacionDeModulo a ns1:Parametro ;
    rdfs:label "Compensación de módulo" ;
    ns1:identificador "MPA.MODCOMP.xn" ;
    ns1:textoExtracto "MODCOMP Compensación de módulo. Parámetro válido para ejes rotativos y cabezales." .

ns1:ParametrosDeGamaMODERR a ns1:Parametro ;
    rdfs:label "Parámetros de gama MODERR" ;
    ns1:identificador "MODERR" ;
    ns1:textoExtracto "Los parámetros de gama MODNROT y MODERR fijan la compensación que se debe aplicar para obtener un contaje exacto." .

ns1:ParametrosDeGamaMODNROT a ns1:Parametro ;
    rdfs:label "Parámetros de gama MODNROT" ;
    ns1:identificador "MODNROT" ;
    ns1:textoExtracto "Los parámetros de gama MODNROT y MODERR fijan la compensación que se debe aplicar para obtener un contaje exacto." .

