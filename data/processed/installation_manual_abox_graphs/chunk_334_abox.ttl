@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalControlPotencia a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal con control de potencia" ;
    ns1:textoExtracto "DMCSPDL Cabezal con control de potencia habilitable." .

ns1:ControlDePotenciaDelCabezalDMC a ns1:Parametro ;
    rdfs:label "Control de potencia del cabezal DMC" ;
    ns1:identificador "MPA.DMCSPDL.sn" ;
    ns1:textoExtracto "DMCSPDL Cabezal con control de potencia habilitable. Valores posibles: Sí / No. Valor por defecto: No." .

