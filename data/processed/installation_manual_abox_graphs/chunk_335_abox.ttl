@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_fef1962464 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro con CAXIS = Sí." .

ns1:EjeCMantenido a ns1:Parametro ;
    rdfs:label "Eje C mantenido" ;
    ns1:identificador "PERCAX" ;
    ns1:textoExtracto "Parámetro válido para ejes rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "No" .

ns1:PosibilidadDeTrabajarComoEjeC a ns1:Parametro ;
    rdfs:label "Posibilidad de trabajar como eje C" ;
    ns1:identificador "CAXIS" ;
    ns1:textoExtracto "Parámetro válido para ejes rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "No" .

ns1:SetDeParametrosParaTrabajarComoEjeC a ns1:Parametro ;
    rdfs:label "Set de parámetros para trabajar como eje C" ;
    ns1:identificador "CAXSET" ;
    ns1:textoExtracto "Parámetro válido para ejes rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "1" .

