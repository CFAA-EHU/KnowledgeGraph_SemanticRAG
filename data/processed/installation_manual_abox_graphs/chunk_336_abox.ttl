@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoOperacion_ManualSuperpuesto_G201
    a ex:ModoOperacion ;
    rdfs:label "Modo manual superpuesto (G201)" ;
    ex:textoExtracto "modo manual superpuesto al modo automático, estos parámetros indican cuánto se puede mover en modo manual el eje en ambos sentidos." .

ex:Tabla_ParametrosManual a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla MANUAL" ;
    ex:textoExtracto "Parámetro incluido en la tabla MANUAL." .

ex:Parametro_MANNEGSW
    a ex:Parametro ;
    rdfs:label "MANNEGSW" ;
    ex:identificador "(V.)[ch].MPA.MANNEGSW.xn" ;
    ex:valor "De 0 a 100" ;
    ex:textoExtracto "MANNEGSW. Parámetro incluido en la tabla MANUAL. Cuando se trabaja con la función G201, modo manual superpuesto al modo automático, estos parámetros indican cuánto se puede mover en modo manual el eje en ambos sentidos." ;
    ex:documentadoEn ex:Tabla_ParametrosManual ;
    ex:monitoreaParametro ex:ModoOperacion_ManualSuperpuesto_G201 .

ex:Parametro_MANFEEDP
    a ex:Parametro ;
    rdfs:label "MANFEEDP" ;
    ex:identificador "(V.)[ch].MPA.MANFEEDP.xn" ;
    ex:valor "20" ;
    ex:textoExtracto "MANFEEDP. Máximo porcentaje de avance manual en G201. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 100. Valor por defecto: 20." ;
    ex:documentadoEn ex:Tabla_ParametrosManual ;
    ex:monitoreaParametro ex:ModoOperacion_ManualSuperpuesto_G201 .

ex:Parametro_IPOFEEDP
    a ex:Parametro ;
    rdfs:label "IPOFEEDP" ;
    ex:identificador "(V.)[ch].MPA.IPOFEEDP.xn" ;
    ex:valor "80" ;
    ex:textoExtracto "IPOFEEDP. Máximo porcentaje de avance de ejecución en G201. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 100. Valor por defecto: 80. Cuando se activa la función G201, el avance asume instantáneamente el valor fijado por IPOFEEDP." ;
    ex:documentadoEn ex:Tabla_ParametrosManual ;
    ex:monitoreaParametro ex:ModoOperacion_ManualSuperpuesto_G201 .

ex:Parametro_MANACCP
    a ex:Parametro ;
    rdfs:label "MANACCP" ;
    ex:identificador "(V.)[ch].MPA.MANACCP.xn" ;
    ex:valor "20" ;
    ex:textoExtracto "MANACCP. Máximo porcentaje aceleración manual en G201. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 100. Valor por defecto: 20." ;
    ex:documentadoEn ex:Tabla_ParametrosManual ;
    ex:monitoreaParametro ex:ModoOperacion_ManualSuperpuesto_G201 .