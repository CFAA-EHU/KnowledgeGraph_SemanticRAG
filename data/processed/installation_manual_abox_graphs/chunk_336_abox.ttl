@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioDeGamaAutomatico a ns1:Parametro ;
    rdfs:label "Cambio de gama automático" ;
    ns1:identificador "MPA.AUTOGEAR.xn" ;
    ns1:textoExtracto "Parámetro válido para cabezales. Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:PorcentajeInferiorDeRpmOK a ns1:Parametro ;
    rdfs:label "Porcentaje inferior de rpm OK" ;
    ns1:identificador "MPA.LOSPDLIM.xn" ;
    ns1:textoExtracto "Parámetro válido para cabezales. Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:PorcentajeSuperiorDeRpmOK a ns1:Parametro ;
    rdfs:label "Porcentaje superior de rpm OK" ;
    ns1:identificador "MPA.UPSPDLIM.xn" ;
    ns1:textoExtracto "Parámetro válido para cabezales. Parámetro válido para regulador analógico, Sercos y simulado." .

