@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Parametro_MANUAL ex:textoExtracto """Parámetro incluido en la tabla MANUAL.""" ;
    a ex:Parametro ;
    ex:identificador "MANUAL" ;
    ex:valor "De 0 a 100" .

ex:Parametro_IPOACCP ex:textoExtracto """IPOACCP Máximo porcentaje aceleración de ejecución en G201.""" ;
    a ex:Parametro ;
    ex:identificador "IPOACCP" ;
    ex:valor "De 0 a 100" .

ex:Tabla_MANUAL a ex:Tabla ;
    ex:textoExtracto """Parámetro incluido en la tabla MANUAL.""" ;
    a ex:Tabla ;
    ex:identificador "MANUAL" .

ex:Tabla_MANUAL a ex:Tabla ;
    ex:tieneComponente ex:Parametro_MANUAL, ex:Parametro_IPOACCP .