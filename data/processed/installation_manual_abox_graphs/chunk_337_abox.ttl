@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PorcentajeSuperiorDeRpmOK_be18d79c6c a ns1:Parametro ;
    rdfs:label "Porcentaje superior de rpm OK" ;
    ns1:identificador "UPSPDLIM" ;
    ns1:textoExtracto "UPSPDLIM Porcentaje superior de rpm OK. Parámetro válido para cabezales." ;
    ns1:valor "150" .

ns1:TiempoEstimadoParaUnaFuncionS a ns1:Parametro ;
    rdfs:label "Tiempo estimado para una función S" ;
    ns1:identificador "SPDLTIME" ;
    ns1:textoExtracto "SPDLTIME Tiempo estimado para una función S. Parámetro válido para cabezales." ;
    ns1:valor "0 ms" .

ns1:VariableMPAUPSPDLIM a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.UPSPDLIM.xn" ;
    ns1:identificador "MPA.UPSPDLIM.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.UPSPDLIM.xn" .

