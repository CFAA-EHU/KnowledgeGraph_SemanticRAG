@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_IPOACCP
    a ex:Parametro ;
    rdfs:label "Parámetro IPOACCP (Aceleración en modo manual superpuesto)"@es ;
    ex:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 100. Valor por defecto: 80. Variable asociada: (V.)[ch].MPA.IPOACCP.xn [...] ambos parámetros indican la máxima aceleración a utilizar de cada modo."@es ;
    ex:identificador "IPOACCP" ;
    ex:valor "80"^^xsd:integer ;
    ex:documentadoEn ex:Tabla_MANUAL .

ex:Tabla_MANUAL a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla MANUAL (Parámetros de modo de trabajo)"@es ;
    ex:textoExtracto "Parámetro incluido en la tabla MANUAL."@es .

ex:ModoOperacion_G201
    a ex:ModoOperacion ;
    rdfs:label "Modo G201 (Manual superpuesto a automático)"@es ;
    ex:textoExtracto "Cuando se trabaja con la función G201, modo manual superpuesto al modo automático, ambos parámetros indican la máxima aceleración a utilizar de cada modo."@es ;
    ex:identificador "G201" ;
    ex:controla ex:Parametro_IPOACCP .

ex:AvisoSeguridad_LimiteDinamico
    a ex:AvisoSeguridad ;
    rdfs:label "Advertencia: Límite dinámico de aceleración combinada"@es ;
    ex:textoExtracto "Se recomienda que la suma de ambos parámetros no sea superior a 100 para evitar que, en determinadas condiciones, se superen los límites dinámicos de la máquina."@es ;
    ex:mitigaRiesgo ex:Parametro_IPOACCP .