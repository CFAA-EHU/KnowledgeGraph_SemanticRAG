@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_MANUAL a ex:Parametro ;
    rdfs:label "MANUAL" ;
    ex:textoExtracto "Parámetro incluido en la tabla MANUAL." ;
    ex:valor "MANUAL" .

ex:Parametro_IPOACCP a ex:Parametro ;
    rdfs:label "IPOACCP" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.IPOACCP.xn" ;
    ex:valor "IPOACCP" .

ex:Parametro_0_100 a ex:Parametro ;
    rdfs:label "0 a 100" ;
    ex:textoExtracto "Valores posibles: De 0 a 100." ;
    ex:valor "0 a 100" .

ex:Parametro_80 a ex:Parametro ;
    rdfs:label "80" ;
    ex:textoExtracto "Valor por defecto: 80." ;
    ex:valor "80" .

ex:Tabla_MANUAL a ex:Tabla ;
    ex:textoExtracto "Parámetro incluido en la tabla MANUAL." ;
    ex:tieneComponente ex:Parametro_MANUAL, ex:Parametro_IPOACCP, ex:Parametro_0_100, ex:Parametro_80 .

ex:Funcion_G201 a ex:ModoOperacion ;
    rdfs:label "G201" ;
    ex:textoExtracto "Cuando se trabaja con la función G201, modo manual superpuesto al modo automático, ambos parámetros indican la máxima aceleración a utilizar de cada modo." .

ex:ModoManual a ex:ModoOperacion ;
    rdfs:label "modo manual" ;
    ex:textoExtracto "modo manual superpuesto al modo automático" .

ex:ModoAutomatico a ex:ModoOperacion ;
    rdfs:label "modo automático" ;
    ex:textoExtracto "modo manual superpuesto al modo automático" .

ex:Parametro_IPOACCP_MaxAceleracion a ex:Parametro ;
    rdfs:label "IPOACCP (máxima aceleración)" ;
    ex:textoExtracto "ambos parámetros indican la máxima aceleración a utilizar de cada modo" ;
    ex:valor "IPOACCP" .

ex:Parametro_MANUAL_MaxAceleracion a ex:Parametro ;
    rdfs:label "MANUAL (máxima aceleración)" ;
    ex:textoExtracto "ambos parámetros indican la máxima aceleración a utilizar de cada modo" ;
    ex:valor "MANUAL" .

ex:Parametro_SumaMaxAceleracion a ex:Parametro ;
    rdfs:label "Suma máxima aceleración" ;
    ex:textoExtracto "Se recomienda que la suma de ambos parámetros no sea superior a 100 para evitar que, en determinadas condiciones, se superen los límites dinámicos de la máquina." ;
    ex:valor "100" .

ex:Parametro_ValorAvanceIPOACCP a ex:Parametro ;
    rdfs:label "Valor avance IPOACCP" ;
    ex:textoExtracto "Cuando se activa la función G201, el avance asume instantáneamente el valor fijado por IPOACCP." ;
    ex:valor "IPOACCP" .