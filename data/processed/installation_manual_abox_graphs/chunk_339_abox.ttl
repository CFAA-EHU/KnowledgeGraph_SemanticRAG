@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefineSiLaMarcaSPDLEREVDelPLCInvertirElSentidoDeGiroTambienAfectaALos_3621da6e19 a ns1:Parametro ;
    rdfs:label "Define si la marca SPDLEREV del PLC (invertir el sentido de giro) también afecta a los cabezales en M19" ;
    ns1:identificador "MPA.M19SPDLEREV.xn" ;
    ns1:textoExtracto "Este parámetro define si la marca SPDLEREV del PLC (invertir el sentido de giro) también afecta a los cabezales en M19." .

ns1:IndicaSiElCabezalSeDetieneCuandoSeEjecutaM02M30SeRealizaUnResetOSeProduceUnError a ns1:Parametro ;
    rdfs:label "Indica si el cabezal se detiene cuando se ejecuta M02, M30, se realiza un reset o se produce un error" ;
    ns1:identificador "MPA.SPDLSTOP.xn" ;
    ns1:textoExtracto "Este parámetro indica si el cabezal se detiene cuando se ejecuta M02, M30, se realiza un reset o se produce un error; en caso contrario se hará necesario programar la función M5." .

ns1:IndicaSiEnCicloDeRoscadoConMachoEsNecesarioPararElCabezalConM5EnLasIn_c8dc4eaacd a ns1:Parametro ;
    rdfs:label "Indica si en ciclo de roscado con macho es necesario parar el cabezal (con M5) en las inversiones de sentido de giro" ;
    ns1:identificador "MPA.SREVM05.xn" ;
    ns1:textoExtracto "Este parámetro indica si en ciclo de roscado con macho es necesario parar el cabezal (con M5) en las inversiones de sentido de giro." .

