@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_G00FEED a ex:Parametro ;
    rdfs:label "G00FEED" ;
    ex:textoExtracto "G00FEED: 1000 mm/min." ;
    ex:valor "1000 mm/min" .

ex:Parametro_JOGFEED a ex:Parametro ;
    rdfs:label "JOGFEED" ;
    ex:textoExtracto "JOGFEED: 100 mm/min." ;
    ex:valor "100 mm/min" .

ex:Parametro_MAXMANFEED a ex:Parametro ;
    rdfs:label "MAXMANFEED" ;
    ex:textoExtracto "MAXMANFEED: 120 mm/min." ;
    ex:valor "120 mm/min" .

ex:Parametro_IPOFEEDP a ex:Parametro ;
    rdfs:label "IPOFEEDP" ;
    ex:textoExtracto "IPOFEEDP: 50%" ;
    ex:valor "50%" .

ex:Parametro_MANFEEDP a ex:Parametro ;
    rdfs:label "MANFEEDP" ;
    ex:textoExtracto "MANFEEDP: 50%" ;
    ex:valor "50%" .

ex:ModoOperacion_Manual a ex:ModoOperacion ;
    rdfs:label "Modo de trabajo manual" ;
    ex:textoExtracto "Modo de trabajo manual" ;
    ex:tieneComponente ex:Parametro_G00FEED, ex:Parametro_JOGFEED, ex:Parametro_MAXMANFEED, ex:Parametro_IPOFEEDP, ex:Parametro_MANFEEDP .

ex:Sistema_EjeY a ex:Sistema ;
    rdfs:label "Eje Y" ;
    ex:textoExtracto "eje Y" ;
    ex:monitoreaParametro ex:Parametro_G00FEED, ex:Parametro_JOGFEED, ex:Parametro_MAXMANFEED, ex:Parametro_IPOFEEDP, ex:Parametro_MANFEEDP .