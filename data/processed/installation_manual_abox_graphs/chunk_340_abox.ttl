@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefineElPasoIncrementalParaElOverrideDelCabezal a ns1:Parametro ;
    rdfs:label "Define el paso incremental para el override del cabezal" ;
    ns1:identificador "MPA.STEPOVR.xn" ;
    ns1:textoExtracto "Este parámetro define el paso incremental para el override del cabezal." .

ns1:DefineSiLaMarcaSPDLEREVDelPLCAfectaALosCabezalesEnM19 a ns1:Parametro ;
    rdfs:label "Define si la marca SPDLEREV del PLC afecta a los cabezales en M19" ;
    ns1:identificador "MPA.M19SPDLEREV.xn" ;
    ns1:textoExtracto "Este parámetro define si la marca SPDLEREV del PLC (invertir el sentido de giro) también afecta a los cabezales en M19." .

