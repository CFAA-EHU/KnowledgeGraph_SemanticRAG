@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_LSCRWDATA_NPOINTS
    a ex:Parametro ;
    rdfs:label "NPOINTS" ;
    ex:textoExtracto "NPOINTS | Número de puntos de la tabla." ;
    ex:valor "Número de puntos de la tabla" .

ex:Parametro_LSCRWDATA_TYPLSCRW
    a ex:Parametro ;
    rdfs:label "TYPLSCRW" ;
    ex:textoExtracto "TYPLSCRW | Método de compensación." ;
    ex:valor "Método de compensación" .

ex:Parametro_LSCRWDATA_BIDIR
    a ex:Parametro ;
    rdfs:label "BIDIR" ;
    ex:textoExtracto "BIDIR | Compensación bidireccional." ;
    ex:valor "Compensación bidireccional" .

ex:Parametro_LSCRWDATA_REFNEED
    a ex:Parametro ;
    rdfs:label "REFNEED" ;
    ex:textoExtracto "REFNEED | Búsqueda de referencia necesaria para compensar." ;
    ex:valor "Búsqueda de referencia necesaria para compensar" .

ex:Tabla_LSCRWDATA_DATA a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de compensación de husillo (DATA)" ;
    ex:textoExtracto "DATA | Tabla para definir los valores de compensación." ;
    ex:identificador "DATA" .

ex:Sistema_CompensacionHusillo
    a ex:Sistema ;
    rdfs:label "Sistema de compensación de husillo" ;
    ex:textoExtracto "Compensación de husillo" ;
    ex:tieneComponente ex:Parametro_LSCRWDATA_NPOINTS ;
    ex:tieneComponente ex:Parametro_LSCRWDATA_TYPLSCRW ;
    ex:tieneComponente ex:Parametro_LSCRWDATA_BIDIR ;
    ex:tieneComponente ex:Parametro_LSCRWDATA_REFNEED ;
    ex:detalladoEnEsquema ex:Tabla_LSCRWDATA_DATA .