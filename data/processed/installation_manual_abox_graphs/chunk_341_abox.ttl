@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:LSCRWDATA a ex:Tabla ;
    ex:textoExtracto "LSCRWDATA |  | NPOINTS | Número de puntos de la tabla. | TYPLSCRW | Método de compensación. | BIDIR | Compensación bidireccional. | REFNEED | Búsqueda de referencia necesaria para compensar. | DATA | Tabla para definir los valores de compensación." .

ex:NPOINTS a ex:Parametro ;
    ex:textoExtracto "NPOINTS | Número de puntos de la tabla." .

ex:TYPLSCRW a ex:Parametro ;
    ex:textoExtracto "TYPLSCRW | Método de compensación." .

ex:BIDIR a ex:Parametro ;
    ex:textoExtracto "BIDIR | Compensación bidireccional." .

ex:REFNEED a ex:Parametro ;
    ex:textoExtracto "REFNEED | Búsqueda de referencia necesaria para compensar." .

ex:DATA a ex:Tabla ;
    ex:textoExtracto "DATA | Tabla para definir los valores de compensación." .