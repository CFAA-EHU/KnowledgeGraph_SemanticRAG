@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PasoIncrementalParaModificarLaVelocidadDeGiroProgramada a ns1:Parametro ;
    rdfs:label "Paso incremental para modificar la velocidad de giro programada" ;
    ns1:identificador "MPA.STEPOVR.xn" ;
    ns1:textoExtracto "Este parámetro define el paso incremental para modificar la velocidad de giro programada, mediante las teclas de speed override del panel de mando." ;
    ns1:valor "5" .

ns1:PorcentajeMaximoPermitidoAAplicarALaVelocidadDeGiroDelCabezal a ns1:Parametro ;
    rdfs:label "Porcentaje máximo permitido a aplicar a la velocidad de giro del cabezal" ;
    ns1:identificador "MPA.MAXOVR.xn" ;
    ns1:textoExtracto "Este parámetro establece el porcentaje máximo permitido a aplicar a la velocidad de giro del cabezal, cuando ésta se modifica desde el panel de mando (teclas o conmutador speed override)." ;
    ns1:valor "150" .

ns1:PorcentajeMinimoPermitidoAAplicarALaVelocidadDeGiroDelCabezal a ns1:Parametro ;
    rdfs:label "Porcentaje mínimo permitido a aplicar a la velocidad de giro del cabezal" ;
    ns1:identificador "MPA.MINOVR.xn" ;
    ns1:textoExtracto "Este parámetro establece el porcentaje mínimo permitido a aplicar a la velocidad de giro del cabezal, cuando ésta se modifica desde el panel de mando (teclas o conmutador speed override)." ;
    ns1:valor "50" .

