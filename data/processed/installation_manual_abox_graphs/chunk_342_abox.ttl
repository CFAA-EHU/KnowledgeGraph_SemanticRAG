@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_7231a87eb9 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC no permite modificar el override del cabezal durante un roscado si detecta que en alguna gama de los ejes implicados no está activo el feed forward (parámetro FFWTYPE) o si el feed forward activo es inferior al 90%." ;
    ns1:tieneComponente ns1:DefinicionDelFeedForward,
        ns1:VariacionMaximaPermitidaParaElOverrideDuranteElRoscado .

ns1:CambioDelOverrideDelCabezalDuranteElRoscado_0e92076983 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio del override del cabezal durante el roscado" ;
    ns1:textoExtracto "Sección 2.5.13 Cambio del override del cabezal durante el roscado." .

ns1:DefinicionDelFeedForward a ns1:Parametro ;
    rdfs:label "Definición del feed forward" ;
    ns1:identificador "FFGAIN" ;
    ns1:textoExtracto "El feed forward se define con el parámetro FFGAIN y se puede modificar desde el PLC mediante variables." .

ns1:FalloSeguimientoRoscado a ns1:DiagnosticoFallo ;
    rdfs:label "Error de seguimiento durante el roscado" ;
    ns1:textoExtracto "Para evitar daños en la rosca al variar el override del cabezal, se recomienda utilizar en los ejes implicados en el roscado un valor de feed forward próximo al 100%, de manera que el error de seguimiento sea el mínimo posible." .

ns1:VariacionMaximaPermitidaParaElOverrideDuranteElRoscado a ns1:Parametro ;
    rdfs:label "Variación máxima permitida para el override durante el roscado" ;
    ns1:identificador "MPA.THREADOVR.xn" ;
    ns1:solucionaFallo ns1:FalloSeguimientoRoscado ;
    ns1:textoExtracto "THREADOVR Variación máxima permitida para el override durante el roscado. Parámetro válido para cabezales." .

