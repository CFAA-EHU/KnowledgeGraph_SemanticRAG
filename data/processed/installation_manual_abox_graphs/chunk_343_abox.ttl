@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioDelOverrideDelCabezalDuranteElRoscado_9020097422 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio del override del cabezal durante el roscado",
        "Personal técnico" ;
    ns1:ejecutadoPor ns1:PersonalTecnico ;
    ns1:textoExtracto "Los ciclos de roscado permiten modificar la velocidad del cabezal durante las pasadas de roscado, excepto en las que se realizan a la profundidad final de la rosca (una o dos pasadas finales), las cuales se realizan al override activo al comenzar la pasada." .

ns1:Componente_ed743dfa48 a ns1:Componente ;
    rdfs:label "cabezal" ;
    ns1:textoExtracto "Los ciclos de roscado permiten modificar la velocidad del cabezal durante las pasadas de roscado, excepto en las que se realizan a la profundidad final de la rosca (una o dos pasadas finales), las cuales se realizan al override activo al comenzar la pasada." .

ns1:ModificacionDelOverrideEnRoscasConPenetracionPorFlanco a ns1:AccionProhibida ;
    rdfs:label "Modificación del override en roscas con penetración por flanco" ;
    ns1:textoExtracto "No se recomienda modificar el override en roscas donde la penetración se realice por flanco." .

