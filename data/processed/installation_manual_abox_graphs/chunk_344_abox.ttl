@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_NPOINTS a ex:Parametro ;
    rdfs:label "NPOINTS" ;
    ex:textoExtracto "El número de puntos viene definido por el parámetro NPOINTS." ;
    ex:valor "NPOINTS" .

ex:Tabla_DATA a ex:Tabla ;
    ex:textoExtracto "En la tabla DATA se debe definir el error que se desea compensar en determinadas posiciones del eje." .

ex:Parametro_POSITION a ex:Parametro ;
    rdfs:label "POSITION" ;
    ex:textoExtracto "Para cada uno de los puntos se deben definir los parámetros POSITION, POSERROR y NEGERROR." ;
    ex:valor "POSITION" .

ex:Parametro_POSERROR a ex:Parametro ;
    rdfs:label "POSERROR" ;
    ex:textoExtracto "Para cada uno de los puntos se deben definir los parámetros POSITION, POSERROR y NEGERROR." ;
    ex:valor "POSERROR" .

ex:Parametro_NEGERROR a ex:Parametro ;
    rdfs:label "NEGERROR" ;
    ex:textoExtracto "Para cada uno de los puntos se deben definir los parámetros POSITION, POSERROR y NEGERROR. El parámetro NEGERROR sólo se muestra si se ha definido la tabla con compensación bidireccional (BIDIR = Sí)." ;
    ex:valor "NEGERROR" .

ex:Parametro_BIDIR a ex:Parametro ;
    rdfs:label "BIDIR" ;
    ex:textoExtracto "El parámetro NEGERROR sólo se muestra si se ha definido la tabla con compensación bidireccional (BIDIR = Sí)." ;
    ex:valor "BIDIR" .

ex:Parametro_CompensacionHusillo a ex:Parametro ;
    rdfs:label "Compensación de husillo" ;
    ex:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado. Este parámetro muestra la lista de puntos y valores de compensación. El CNC sólo permite acceder a esta tabla cuando está definido el parámetro NPOINTS." ;
    ex:valor "Compensación de husillo" .