@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_d187a17ccb a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro con THREADOVR distinto de 0 (cero)." .

ns1:FiltroParaHacerEfectivoElCambioDeOverride a ns1:Parametro ;
    rdfs:label "Filtro para hacer efectivo el cambio de override" ;
    ns1:identificador "MPA.OVRFILTER.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.OVRFILTER.xn El CNC sólo tiene en cuenta este parámetro con THREADOVR distinto de 0 (cero). Este parámetro actúa como filtro para hacer efectivo el cambio de override. El cambio de override se aplica progresivamente durante el tiempo especificado." ;
    ns1:valor "0" .

