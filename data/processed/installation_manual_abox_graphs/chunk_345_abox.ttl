@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:LSCRWCOMP_InterfazUsuario
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de compensación de husillo (LSCRWCOMP)"@es ;
    ex:textoExtracto "LSCRWCOMP DATA | POSITION | Posición del eje. | POSERROR | Error a compensar en los desplazamientos en sentido positivo. | NEGERROR | Error a compensar en los desplazamientos en sentido negativo."@es ;
    ex:tieneComponente ex:LSCRWCOMP_POSITION_Parametro,
                      ex:LSCRWCOMP_POSERROR_Parametro,
                      ex:LSCRWCOMP_NEGERROR_Parametro .

ex:LSCRWCOMP_POSITION_Parametro
    a ex:Parametro ;
    rdfs:label "POSITION (Posición del eje)"@es ;
    ex:identificador "POSITION" ;
    ex:textoExtracto "POSITION | Posición del eje."@es .

ex:LSCRWCOMP_POSERROR_Parametro
    a ex:Parametro ;
    rdfs:label "POSERROR (Error positivo)"@es ;
    ex:identificador "POSERROR" ;
    ex:textoExtracto "POSERROR | Error a compensar en los desplazamientos en sentido positivo."@es .

ex:LSCRWCOMP_NEGERROR_Parametro
    a ex:Parametro ;
    rdfs:label "NEGERROR (Error negativo)"@es ;
    ex:identificador "NEGERROR" ;
    ex:textoExtracto "NEGERROR | Error a compensar en los desplazamientos en sentido negativo."@es .