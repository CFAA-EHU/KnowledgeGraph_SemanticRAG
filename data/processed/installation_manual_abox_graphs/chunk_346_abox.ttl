ns1:LimiteDeSoftwareNegativo_79dc7258de a ns1:Parametro ;
    rdfs:label "Límite de software negativo" ;
    ns1:identificador "LIMIT-" ;
    ns1:textoExtracto "LIMIT- Límite de software negativo. Parámetro válido para ejes lineales y rotativos." ;
    ns1:valor "-99999.9999 mm / -3937.00787 inch / -99999.9999 grados" .

ns1:LimiteDeSoftwarePositivo_bde359a446 a ns1:Parametro ;
    rdfs:label "Límite de software positivo" ;
