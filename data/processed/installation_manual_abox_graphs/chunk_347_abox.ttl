@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaximaVariacionUOscilacionPermitidaAUnEjeQueEstaPosicionadoEnElLimite a ns1:Parametro ;
    rdfs:label "Máxima variación u oscilación permitida a un eje que está posicionado en el límite" ;
    ns1:identificador "MPA.SWLIMITTOL.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.SWLIMITTOL.xn Este parámetro indica la máxima variación u oscilación permitida a un eje que está posicionado en el límite." .

