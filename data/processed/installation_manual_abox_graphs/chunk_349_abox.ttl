@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:FiltroFrecuenciaResonancia1 a ex:Tabla ;
    rdfs:label "Tabla de filtros"@es ;
    ex:textoExtracto "FILTER Tabla de filtros. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Este parámetro muestra las tablas para configurar los filtros de frecuencia."@es .

ex:FiltroFrecuenciaResonancia2 a ex:Parametro ;
    rdfs:label "Configuración del filtro"@es ;
    ex:textoExtracto "FILTER n Configuración del filtro. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado."@es .

ex:FiltroAntirresonante a ex:Frecuencia ;
    rdfs:label "filtro antirresonante"@es ;
    ex:textoExtracto "El filtro \"antirresonante\" (banda eliminada), que limita una zona de la banda pasante"@es .

ex:FiltroPasoBajo a ex:Frecuencia ;
    rdfs:label "filtro paso bajo"@es ;
    ex:textoExtracto "los filtros \"paso bajo\", que limitan la banda pasante a partir de una determinada frecuencia."@es .

ex:EjeLineal a ex:ComponenteMecanico ;
    rdfs:label "eje lineal"@es ;
    ex:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales."@es .

ex:EjeRotativo a ex:ComponenteMecanico ;
    rdfs:label "eje rotativo"@es ;
    ex:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales."@es .

ex:Cabezal a ex:ComponenteMecanico ;
    rdfs:label "cabezal"@es ;
    ex:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales."@es .

ex:ReguladorAnalogico a ex:ComponenteElectrico ;
    rdfs:label "regulador analógico"@es ;
    ex:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado."@es .

ex:SistemaSercos a ex:ComponenteElectrico ;
    rdfs:label "Sercos"@es ;
    ex:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado."@es .

ex:ModoSimulado a ex:ModoOperacion ;
    rdfs:label "simulado"@es ;
    ex:textoExtracto "Parámetro válido para regulador analógico, Sercos y simulado."@es .

ex:FiltroFrecuenciaResonancia1 ex:compuestoPor ex:FiltroAntirresonante, ex:FiltroPasoBajo .
ex:FiltroFrecuenciaResonancia1 ex:tieneComponente ex:EjeLineal, ex:EjeRotativo, ex:Cabezal, ex:ReguladorAnalogico, ex:SistemaSercos, ex:ModoSimulado .