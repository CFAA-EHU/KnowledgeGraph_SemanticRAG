@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaFiltrosFrecuencia a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de filtros para frecuencias de resonancia" ;
    ex:textoExtracto "FILTER Tabla de filtros. Parámetro válido para ejes lineales, rotativos y cabezales. [...] Este parámetro muestra las tablas para configurar los filtros de frecuencia." ;
    ex:detalladoEnEsquema ex:ParametroFILTER .

ex:ParametroFILTER
    a ex:Parametro ;
    rdfs:label "FILTER" ;
    ex:identificador "FILTER" ;
    ex:textoExtracto "FILTER n Configuración del filtro. Parámetro válido para ejes lineales, rotativos y cabezales." ;
    ex:monitoreaParametro ex:FiltroAntirresonante, ex:FiltroPasoBajo .

ex:FiltroAntirresonante
    a ex:Componente ;
    rdfs:label "Filtro antirresonante (banda eliminada)" ;
    ex:textoExtracto "El filtro \"antirresonante\" (banda eliminada), que limita una zona de la banda pasante." .

ex:FiltroPasoBajo
    a ex:Componente ;
    rdfs:label "Filtro paso bajo" ;
    ex:textoExtracto "Los filtros \"paso bajo\", que limitan la banda pasante a partir de una determinada frecuencia." .

ex:SistemaCNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "El CNC dispone de diferentes filtros." ;
    ex:tieneComponente ex:FiltroAntirresonante, ex:FiltroPasoBajo ;
    ex:controla ex:EjeLineal, ex:EjeRotativo, ex:Cabezal .