@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DistanciaDeSeguridadDeLosLimitesDeLasZonasDeTrabajo_37114acc08 a ns1:Parametro ;
    rdfs:label "Distancia de seguridad de los límites de las zonas de trabajo" ;
    ns1:identificador "ZONELIMITTOL" ;
    ns1:textoExtracto "ZONELIMITTOL Distancia de seguridad de los límites de las zonas de trabajo. Parámetro válido para ejes lineales y rotativos." .

ns1:VariableMPAZONELIMITTOL a ns1:Parametro ;
    rdfs:label "Distancia de seguridad que aplica el CNC al eje respecto el límite de la zona de trabajo" ;
    ns1:identificador "MPA.ZONELIMITTOL.xn" ;
    ns1:textoExtracto "(V.)[ch].MPA.ZONELIMITTOL.xn Distancia de seguridad que aplica el CNC al eje respecto el límite de la zona de trabajo." .

