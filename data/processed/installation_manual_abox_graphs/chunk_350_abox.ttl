@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Filtro_Resonancia_350 a ex:ComponenteElectrico ;
    rdfs:label "Filtro" ;
    ex:textoExtracto "FILTER" ;
    ex:tieneFrecuencia ex:FrecuenciaCorte_350 .

ex:FrecuenciaCorte_350 a ex:Frecuencia ;
    rdfs:label "Frecuencia de corte o central" ;
    ex:textoExtracto "FREQUENCY" .

ex:Tabla_Filtros_350 a ex:Tabla ;
    ex:textoExtracto "| FILTER |  |\n| --- | --- |\n| ORDER | Orden del filtro. |\n| TYPE | Tipo de filtro. |\n| FREQUENCY | Frecuencia de corte o central. |\n| NORBWIDTH | Anchura de banda normalizada. |\n| SHARE | Porcentaje de señal que pasa a través del filtro. |" ;
    ex:compuestoPor ex:Filtro_Resonancia_350 .