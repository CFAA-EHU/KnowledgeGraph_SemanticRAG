@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_FiltrosResonancia a ex:Tabla ;
     a                       ex:Tabla ;
    rdfs:label              "Tabla de parámetros de filtros para eliminar frecuencias de resonancia"@es ;
    ex:textoExtracto         "FILTER | ... | ORDER | Orden del filtro. | TYPE | Tipo de filtro. | FREQUENCY | Frecuencia de corte o central. | NORBWIDTH | Anchura de banda normalizada. | SHARE | Porcentaje de señal que pasa a través del filtro."@es ;
    ex:tieneComponente       ex:Parametro_Order ,
                                ex:Parametro_Type ,
                                ex:Parametro_Frequency ,
                                ex:Parametro_NorbWidth ,
                                ex:Parametro_Share .

ex:Parametro_Order
    a                   ex:Parametro ;
    rdfs:label          "ORDER"@es ;
    ex:textoExtracto    "Orden del filtro."@es ;
    ex:valor            "ORDER" .

ex:Parametro_Type
    a                   ex:Parametro ;
    rdfs:label          "TYPE"@es ;
    ex:textoExtracto    "Tipo de filtro."@es ;
    ex:valor            "TYPE" .

ex:Parametro_Frequency
    a                   ex:Parametro ;
    rdfs:label          "FREQUENCY"@es ;
    ex:textoExtracto    "Frecuencia de corte o central."@es ;
    ex:valor            "FREQUENCY" .

ex:Parametro_NorbWidth
    a                   ex:Parametro ;
    rdfs:label          "NORBWIDTH"@es ;
    ex:textoExtracto    "Anchura de banda normalizada."@es ;
    ex:valor            "NORBWIDTH" .

ex:Parametro_Share
    a                   ex:Parametro ;
    rdfs:label          "SHARE"@es ;
    ex:textoExtracto    "Porcentaje de señal que pasa a través del filtro."@es ;
    ex:valor            "SHARE" .