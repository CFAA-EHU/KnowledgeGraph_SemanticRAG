@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:FiltroPasoBajo a ex:Parametro ;
    rdfs:label "Filtro paso bajo" ;
    ex:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Para filtro paso bajo, de 0 a 10 / Para filtro antirresonante, de 0 a 5 / Para filtro paso bajo FAGOR, de 0 a 50. Valor por defecto: 0 (no se aplica filtro). Variable asociada: (V.)[ch].MPA.ORDER[nb].xn Parámetro incluido en la tabla FILTER." ;
    ex:identificador "ORDER" ;
    ex:valor "0 a 10" .

ex:FiltroAntirresonante a ex:Parametro ;
    rdfs:label "Filtro antirresonante" ;
    ex:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Para filtro paso bajo, de 0 a 10 / Para filtro antirresonante, de 0 a 5 / Para filtro paso bajo FAGOR, de 0 a 50. Valor por defecto: 0 (no se aplica filtro). Variable asociada: (V.)[ch].MPA.ORDER[nb].xn Parámetro incluido en la tabla FILTER." ;
    ex:identificador "ORDER" ;
    ex:valor "0 a 5" .

ex:FiltroPasoBajoFAGOR a ex:Parametro ;
    rdfs:label "Filtro paso bajo FAGOR" ;
    ex:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Para filtro paso bajo, de 0 a 10 / Para filtro antirresonante, de 0 a 5 / Para filtro paso bajo FAGOR, de 0 a 50. Valor por defecto: 0 (no se aplica filtro). Variable asociada: (V.)[ch].MPA.ORDER[nb].xn Parámetro incluido en la tabla FILTER." ;
    ex:identificador "ORDER" ;
    ex:valor "0 a 50" .

ex:TipoFiltro a ex:Parametro ;
    rdfs:label "Tipo de filtro" ;
    ex:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Paso bajo / Antirresonante (banda eliminada) / Paso bajo FAGOR. Valor por defecto: Paso bajo. Variable asociada: (V.)[ch].MPA.TYPE[nb].xn Parámetro incluido en la tabla FILTER." ;
    ex:identificador "TYPE" .

ex:TablaFILTER a ex:Tabla ;
    rdfs:label "Tabla FILTER" ;
    ex:textoExtracto "Parámetro incluido en la tabla FILTER." ;
    ex:tieneComponente ex:FiltroPasoBajo, ex:FiltroAntirresonante, ex:FiltroPasoBajoFAGOR, ex:TipoFiltro .