@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_4b830ac4b3 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Si se desactiva esta alarma, el CNC muestra en el encendido un mensaje indicando que dicha seguridad está deshabilitada." .

ns1:ProteccionFrenteAlEmbalamiento a ns1:AvisoSeguridad ;
    rdfs:label "Protección frente al embalamiento" ;
    ns1:textoExtracto "Este test vigila el movimiento real del eje desde el arranque, para detectar su embalamiento." .

ns1:PuestaAPunto a ns1:TareaMantenimiento ;
    rdfs:label "puesta a punto" ;
    ns1:textoExtracto "Esta situación únicamente debería permitirse durante la puesta a punto; una vez finalizada la puesta a punto, esta alarma debe estar habilitada." .

ns1:TENDENCYActivacionDelTestDeTendencia a ns1:Parametro ;
    rdfs:label "TENDENCY Activación del test de tendencia" ;
    ns1:identificador "MPA.TENDENCY.xn" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos." .

ns1:TENDTIMETiempoParaDetectarElEmbalamientoDelEje a ns1:Parametro ;
    rdfs:label "TENDTIME Tiempo para detectar el embalamiento del eje" ;
    ns1:identificador "MPA.TENDTIME.xn" ;
    ns1:textoExtracto "Valores posibles: De 0 a 65535 ms. Valor por defecto: 0." .

ns1:TiempoParametrizadoEnElParametroESTDELAY_f94a80a1dd a ns1:Parametro ;
    rdfs:label "Tiempo parametrizado en el parámetro ESTDELAY" ;
    ns1:textoExtracto "a partir del tiempo parametrizado en el parámetro ESTDELAY." .

