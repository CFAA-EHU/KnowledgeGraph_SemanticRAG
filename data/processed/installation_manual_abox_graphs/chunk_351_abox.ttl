@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_FILTER a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla FILTER" ;
    ex:textoExtracto "Parámetro incluido en la tabla FILTER." .

ex:Parametro_ORDER
    a ex:Parametro ;
    rdfs:label "ORDER (Orden del filtro)" ;
    ex:identificador "ORDER" ;
    ex:textoExtracto "ORDER Orden del filtro. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Para filtro paso bajo, de 0 a 10 / Para filtro antirresonante, de 0 a 5 / Para filtro paso bajo FAGOR, de 0 a 50. Valor por defecto: 0 (no se aplica filtro). Variable asociada: (V.)[ch].MPA.ORDER[nb].xn" ;
    ex:valor "0"^^xsd:integer ;
    ex:documentadoEn ex:Tabla_FILTER .

ex:Parametro_TYPE
    a ex:Parametro ;
    rdfs:label "TYPE (Tipo de filtro)" ;
    ex:identificador "TYPE" ;
    ex:textoExtracto "TYPE Tipo de filtro. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Paso bajo / Antirresonante (banda eliminada) / Paso bajo FAGOR. Valor por defecto: Paso bajo. Variable asociada: (V.)[ch].MPA.TYPE[nb].xn" ;
    ex:valor "Paso bajo" ;
    ex:documentadoEn ex:Tabla_FILTER .

ex:FiltroPasoBajo
    a ex:Componente ;
    rdfs:label "Filtro paso bajo" ;
    ex:textoExtracto "Filtros \"paso bajo\". Si la máquina presenta la frecuencia de resonancia al final de su banda pasante, bastará con eliminarla mediante un filtro \"paso bajo\"." ;
    ex:monitoreaParametro ex:Parametro_ORDER ;
    ex:monitoreaParametro ex:Parametro_TYPE .

ex:FiltroAntirresonante
    a ex:Componente ;
    rdfs:label "Filtro antirresonante" ;
    ex:textoExtracto "Antirresonante (banda eliminada)" ;
    ex:monitoreaParametro ex:Parametro_ORDER ;
    ex:monitoreaParametro ex:Parametro_TYPE .

ex:FiltroPasoBajoFAGOR
    a ex:Componente ;
    rdfs:label "Filtro paso bajo FAGOR" ;
    ex:textoExtracto "Paso bajo FAGOR" ;
    ex:monitoreaParametro ex:Parametro_ORDER ;
    ex:monitoreaParametro ex:Parametro_TYPE .