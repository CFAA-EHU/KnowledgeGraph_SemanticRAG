@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:FiltroPasoBajo a ex:ComponenteElectrico ;
    rdfs:label "filtro paso bajo" ;
    ex:textoExtracto "El filtro \"paso bajo\", para un misma frecuencia, necesita menos orden y como consecuencia, introduce menos retardo." ;
    ex:valor "paso bajo" .

ex:SistemaCNC a ex:Maquina ;
    rdfs:label "CNC" ;
    ex:textoExtracto "el CNC suaviza los movimientos" .