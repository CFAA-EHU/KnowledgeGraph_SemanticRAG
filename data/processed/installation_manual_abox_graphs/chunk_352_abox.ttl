@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IncrementoDelOffsetDePLCPorCiclo a ns1:Parametro ;
    rdfs:label "Incremento del offset de PLC por ciclo" ;
    ns1:identificador "PLCOINC" ;
    ns1:textoExtracto "PLCOINC Incremento del offset de PLC por ciclo. Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:OffsetDePLCAAplicar a ns1:Parametro ;
    rdfs:label "Offset de PLC a aplicar" ;
    ns1:identificador "A.PLCOF.xn" ;
    ns1:textoExtracto "El offset de PLC a aplicar está definido en la variable (V.)A.PLCOF.xn." .

ns1:OffsetDePLCAplicadoHastaElMomento a ns1:Parametro ;
    rdfs:label "Offset de PLC aplicado hasta el momento" ;
    ns1:identificador "A.ACTPLCOF.xn" ;
    ns1:textoExtracto "El offset de PLC aplicado hasta el momento se puede consultar en la variable (V.)A.ACTPLCOF.xn." .

ns1:VariableAsociadaAlIncrementoDelOffsetDePLC a ns1:Parametro ;
    rdfs:label "Variable asociada al incremento del offset de PLC" ;
    ns1:identificador "MPA.PLCOINC.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.PLCOINC.xn" .

