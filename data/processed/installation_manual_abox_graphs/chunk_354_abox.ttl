@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorDeEjeBloqueado a ns1:AccionProhibida ;
    rdfs:label "Error de eje bloqueado" ;
    ns1:textoExtracto "el CNC no temporizará pero podría dar error de eje bloqueado si como consecuencia de la lógica de desconexión, termina cayendo la señal SERVOON." .

ns1:RetardoEnLaDesconexionDelEje a ns1:AccionProhibida ;
    rdfs:label "Retardo en la desconexión del eje" ;
    ns1:textoExtracto "Hay que tener especial atención al retardo de la desconexión del eje, cuando pasa a ser un eje 'muerto'." .

ns1:TiempoDeEsperaAntesDelMovimiento a ns1:Parametro ;
    rdfs:label "Tiempo de espera antes del movimiento" ;
    ns1:identificador "DWELL" ;
    ns1:textoExtracto "El CNC esperará el tiempo parametrizado en DWELL antes de generar movimiento en el eje 'muerto'." .

ns1:senalDEADaxis a ns1:ComponenteElectrico ;
    rdfs:label "Señal DEAD(axis)" ;
    ns1:textoExtracto "será necesario habilitar el eje desde PLC como eje 'muerto' (señal DEAD(axis))." .

ns1:senalENABLE a ns1:ComponenteElectrico ;
    rdfs:label "Señal ENABLE" ;
    ns1:textoExtracto "La señal ENABLE indica al PLC que permita el movimiento del eje y la señal SERVOON que el regulador está listo." .

ns1:senalSERVOON a ns1:ComponenteElectrico ;
    rdfs:label "Señal SERVOON" ;
    ns1:textoExtracto "La señal SERVOON indica que el regulador está listo para permitir el movimiento del eje." .

