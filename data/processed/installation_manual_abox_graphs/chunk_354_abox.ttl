@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Filtro_354_1 a ex:Parametro ;
    rdfs:label "FREQUENCY" ;
    ex:textoExtracto "Parámetro incluido en la tabla FILTER. En los filtros \"paso bajo\", este parámetro indica la frecuencia de corte o frecuencia a la que la amplitud cae 3 dB o alcanza el 70% de la amplitud nominal. En el filtro \"Antirresonante (banda eliminada)\", este parámetro indica la frecuencia central o frecuencia en que la resonancia alcanza su valor máximo." ;
    ex:valor "De 0 a 500.0 Hz" ;
    ex:identificador "(V.)[ch].MPA.FREQUENCY[nb].xn" .

ex:Filtro_354_2 a ex:Parametro ;
    rdfs:label "NORBWIDTH" ;
    ex:textoExtracto "Parámetro incluido en la tabla FILTER. Este parámetro se calcula con la siguiente formula. Los valores f1 y f2 corresponden a la frecuencia de corte o frecuencia a la que la amplitud cae 3 dB o alcanza el 70% de la amplitud nominal." ;
    ex:valor "De 0 a 100.0" ;
    ex:identificador "(V.)[ch].MPA.NORWIDTH[nb].xn" .

ex:Filtro_354_3 a ex:Parametro ;
    rdfs:label "SHARE" ;
    ex:textoExtracto "Parámetro incluido en la tabla FILTER. Este parámetro indica el porcentaje de señal que pasa a través del filtro. Este valor debe ser equivalente al sobrepasamiento porcentual de la resonancia, ya que debe contrarrestar a la misma." ;
    ex:valor "De 0 a 100" ;
    ex:identificador "(V.)[ch].MPA.SHARE[nb].xn" .

ex:Tabla_Filter_354 a ex:Tabla ;
    ex:textoExtracto "Parámetro incluido en la tabla FILTER." ;
    ex:tieneComponente ex:Filtro_354_1, ex:Filtro_354_2, ex:Filtro_354_3 .