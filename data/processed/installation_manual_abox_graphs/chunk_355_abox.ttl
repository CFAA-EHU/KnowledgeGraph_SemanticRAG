@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_FiltroMPA_SHARE
    a ex:Parametro ;
    rdfs:label "Parámetro MPA.SHARE[nb].xn"@es ;
    ex:identificador "MPA.SHARE[nb].xn" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.SHARE[nb].xn Parámetro incluido en la tabla FILTER. Este parámetro indica el porcentaje de señal que pasa a través del filtro."@es ;
    ex:valor "SHARE=100(Ar-Ao)/Ar" .

ex:Tabla_FILTER a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla FILTER"@es ;
    ex:textoExtracto "Parámetro incluido en la tabla FILTER."@es ;
    ex:tieneComponente ex:Parametro_FiltroMPA_SHARE .