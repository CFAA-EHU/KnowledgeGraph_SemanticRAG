@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_7cd378c77a a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "el CNC detiene el giro e inicia la búsqueda de referencia en el sentido indicado por REFDIREC." .

ns1:CabezalRotativo a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal Rotativo" ;
    ns1:monitoreaParametro ns1:ModoDeBusquedaDeCero ;
    ns1:textoExtracto "Si el cabezal está girando, el CNC respeta el sentido de giro del mismo para empezar la búsqueda de cero." .

ns1:ModoDeBusquedaDeCero a ns1:Parametro ;
    rdfs:label "Modo de búsqueda de cero" ;
    ns1:identificador "MPA.REFMODE.xn" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales." .

