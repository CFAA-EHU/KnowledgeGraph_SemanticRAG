@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SYNCSET
    a ex:Parametro ;
    rdfs:label "SYNCSET" ;
    ex:textoExtracto "parámetro SYNCSET"@es .

ex:Parametro_DEFAULTSET
    a ex:Parametro ;
    rdfs:label "DEFAULTSET" ;
    ex:textoExtracto "parámetro DEFAULTSET"@es .

ex:Parametro_S
    a ex:Parametro ;
    rdfs:label "S" ;
    ex:textoExtracto "la S"@es ;
    ex:textoExtracto "la que corresponde a la S"@es .

ex:GamaPorDefecto
    a ex:ModoOperacion ;
    rdfs:label "Gama por defecto" ;
    ex:textoExtracto "la gama por defecto"@es .

ex:GamaAdecuada
    a ex:ModoOperacion ;
    rdfs:label "Gama adecuada" ;
    ex:textoExtracto "la gama adecuada, la que corresponde a la S"@es .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "El CNC arranca sin gama"@es ;
    ex:monitoreaParametro ex:Parametro_SYNCSET ;
    ex:monitoreaParametro ex:Parametro_DEFAULTSET ;
    ex:monitoreaParametro ex:Parametro_S .

ex:Sistema_PLC
    a ex:Sistema ;
    rdfs:label "PLC" ;
    ex:textoExtracto "la maniobra del PLC"@es ;
    ex:textoExtracto "el CNC pone la gama que indica el PLC"@es ;
    ex:controla ex:Sistema_CNC .

ex:AnilloSercos
    a ex:ComponenteElectrico ;
    rdfs:label "Anillo Sercos" ;
    ex:textoExtracto "anillo Sercos"@es .