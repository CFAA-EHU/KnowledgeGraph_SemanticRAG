@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ParametroDinamicaEje1 a ex:Parametro ;
    rdfs:label "Parámetros de dinámica del eje (set 1)" ;
    ex:textoExtracto "Se pueden definir hasta 4 sets de parámetros distintos para indicar la dinámica del eje en cada una de ellas (avances, ganancias, aceleraciones, etc)." ;
    ex:valor "set 1" .

ex:ParametroDinamicaEje2 a ex:Parametro ;
    rdfs:label "Parámetros de dinámica del eje (set 2)" ;
    ex:textoExtracto "Se pueden definir hasta 4 sets de parámetros distintos para indicar la dinámica del eje en cada una de ellas (avances, ganancias, aceleraciones, etc)." ;
    ex:valor "set 2" .

ex:ParametroDinamicaEje3 a ex:Parametro ;
    rdfs:label "Parámetros de dinámica del eje (set 3)" ;
    ex:textoExtracto "Se pueden definir hasta 4 sets de parámetros distintos para indicar la dinámica del eje en cada una de ellas (avances, ganancias, aceleraciones, etc)." ;
    ex:valor "set 3" .

ex:ParametroDinamicaEje4 a ex:Parametro ;
    rdfs:label "Parámetros de dinámica del eje (set 4)" ;
    ex:textoExtracto "Se pueden definir hasta 4 sets de parámetros distintos para indicar la dinámica del eje en cada una de ellas (avances, ganancias, aceleraciones, etc)." ;
    ex:valor "set 4" .

ex:ParametroVelocidadCabezal a ex:Parametro ;
    rdfs:label "Parámetro de velocidad del cabezal" ;
    ex:textoExtracto "los parámetros relacionados con la velocidad del cabezal (definida en rpm)" .

ex:ParametroPotenciaCabezal a ex:Parametro ;
    rdfs:label "Parámetro de potencia del cabezal" ;
    ex:textoExtracto "definen la potencia (definida en watios)" .