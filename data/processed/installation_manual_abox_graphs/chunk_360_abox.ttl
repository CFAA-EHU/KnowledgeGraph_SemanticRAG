@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ValorParaEjeRotativoSinI0Codificados a ns1:Parametro ;
    rdfs:label "Valor para eje rotativo sin I0 codificados" ;
    ns1:identificador "DECINPUT" ;
    ns1:textoExtracto "Si el eje rotativo no dispone de I0 codificados, el parámetro DECINPUT debe tener valor." .

ns1:VelocidadParaCalcularPosicionDelMicroEnCabezalConMicroDeI0 a ns1:Parametro ;
    rdfs:label "Velocidad para calcular posición del micro en cabezal con micro de I0" ;
    ns1:identificador "REFFEED1" ;
    ns1:textoExtracto "La primera vuelta se da a la velocidad definida en REFFEED1 y sirve para calcular la posición del micro." .

