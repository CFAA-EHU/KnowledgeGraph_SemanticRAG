@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_PITCH
    a ex:Parametro ;
    rdfs:label "PITCH (Paso de husillo)" ;
    ex:identificador "MPA.PITCH[set].xn" ;
    ex:textoExtracto "PITCH Paso de husillo. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0 a 99999.9999 mm. Valores posibles (2): De 0 a 3937.00787 inch. Valores posibles (3): De 0 a 99999.9999 grados. Valor por defecto: 5 mm / 0.19685 inch / 360º." ;
    ex:valor "5 mm / 0.19685 inch / 360º" .

ex:Sistema_EjeLinealConEncoderYHusillo
    a ex:Sistema ;
    rdfs:label "Sistema de eje lineal con encoder y husillo" ;
    ex:textoExtracto "En un eje lineal con encoder y husillo, el parámetro define el paso de husillo." ;
    ex:monitoreaParametro ex:Parametro_PITCH .

ex:Sistema_EjeLinealConTransductorLineal
    a ex:Sistema ;
    rdfs:label "Sistema de eje lineal con transductor lineal (regla)" ;
    ex:textoExtracto "En un eje lineal con transductor lineal (regla), el parámetro define el paso de la regla." ;
    ex:monitoreaParametro ex:Parametro_PITCH .

ex:Sistema_EjeRotativo
    a ex:Sistema ;
    rdfs:label "Sistema de eje rotativo" ;
    ex:textoExtracto "En un eje rotativo, el parámetro define el número de grados por vuelta de encoder." ;
    ex:monitoreaParametro ex:Parametro_PITCH .