@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BusquedaDeCeroEnElPrimerMovimiento a ns1:Parametro ;
    rdfs:label "Búsqueda de cero en el primer movimiento" ;
    ns1:identificador "MPA.REFINI.xn" ;
    ns1:textoExtracto "Parámetro válido para cabezales. Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:CNC8070_0074b25e3b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Este parámetro establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento." .

ns1:VelocidadDeLaPrimeraVuelta a ns1:Parametro ;
    rdfs:label "Velocidad de la primera vuelta" ;
    ns1:textoExtracto "La primera vuelta se da a la velocidad definida en REFFEED1 y sirve para calcular la posición del micro." .

ns1:VelocidadDeLaSegundaVuelta a ns1:Parametro ;
    rdfs:label "Velocidad de la segunda vuelta" ;
    ns1:textoExtracto "La segunda vuelta se da a la misma velocidad hasta alcanzar el micro, pasando sobre él a la velocidad definida en REFFEED2 y realizando la búsqueda de I0 habitual." .

