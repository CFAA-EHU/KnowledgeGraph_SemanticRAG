@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EjeConHusillo5mm a ex:ComponenteMecanico ;
    rdfs:label "Eje con husillo de 5 mm." ;
    ex:identificador "PITCH" ;
    ex:valor "5 mm." ;
    ex:textoExtracto "Eje con husillo de 5 mm." .

ex:EjeConReglaFagorPaso20um a ex:ComponenteMecanico ;
    rdfs:label "Eje con regla Fagor de paso 20 µm." ;
    ex:identificador "PITCH" ;
    ex:valor "0.020 mm." ;
    ex:textoExtracto "Eje con regla Fagor de paso 20 µm." .

ex:EjeRotativoConReduccion1_10 a ex:ComponenteMecanico ;
    rdfs:label "Eje rotativo con reducción 1/10" ;
    ex:identificador "PITCH" ;
    ex:valor "36º." ;
    ex:textoExtracto "Eje rotativo con reducción 1/10." .