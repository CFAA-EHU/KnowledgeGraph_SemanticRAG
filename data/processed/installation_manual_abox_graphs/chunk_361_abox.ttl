@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ResolucionCaptacion_Pag188_191
    a ex:Tabla ;
    rdfs:label "Tabla de resolución de captación por tipo de eje"@es ;
    ex:textoExtracto """
| Tipo de eje. | PITCH |
| --- | --- |
| Eje con husillo de 5 mm. | 5 mm. |
| Eje con regla Fagor de paso 20 µm. | 0.020 mm. |
| Eje rotativo con reducción 1/10. | 36º. |
"""@es ;
    ex:documentadoEn ex:Pagina_188, ex:Pagina_189, ex:Pagina_190, ex:Pagina_191 .

ex:Parametro_Pitch_Husillo5mm
    a ex:Parametro ;
    rdfs:label "PITCH (husillo 5 mm)"@es ;
    ex:valor "5 mm" ;
    ex:textoExtracto "Eje con husillo de 5 mm. | 5 mm."@es ;
    ex:documentadoEn ex:Tabla_ResolucionCaptacion_Pag188_191 .

ex:Parametro_Pitch_ReglaFagor20um
    a ex:Parametro ;
    rdfs:label "PITCH (regla Fagor 20 µm)"@es ;
    ex:valor "0.020 mm" ;
    ex:textoExtracto "Eje con regla Fagor de paso 20 µm. | 0.020 mm."@es ;
    ex:documentadoEn ex:Tabla_ResolucionCaptacion_Pag188_191 .

ex:Parametro_Pitch_EjeRotativoRed1_10
    a ex:Parametro ;
    rdfs:label "PITCH (eje rotativo, reducción 1/10)"@es ;
    ex:valor "36°" ;
    ex:textoExtracto "Eje rotativo con reducción 1/10. | 36º."@es ;
    ex:documentadoEn ex:Tabla_ResolucionCaptacion_Pag188_191 .

ex:Componente_Husillo5mm
    a ex:ComponenteMecanico ;
    rdfs:label "Husillo (5 mm)"@es ;
    ex:textoExtracto "Eje con husillo de 5 mm."@es ;
    ex:monitoreaParametro ex:Parametro_Pitch_Husillo5mm ;
    ex:documentadoEn ex:Tabla_ResolucionCaptacion_Pag188_191 .

ex:Componente_ReglaFagor20um
    a ex:ComponenteMecanico ;
    rdfs:label "Regla Fagor (paso 20 µm)"@es ;
    ex:textoExtracto "Eje con regla Fagor de paso 20 µm."@es ;
    ex:monitoreaParametro ex:Parametro_Pitch_ReglaFagor20um ;
    ex:documentadoEn ex:Tabla_ResolucionCaptacion_Pag188_191 .

ex:Componente_EjeRotativoRed1_10
    a ex:ComponenteMecanico ;
    rdfs:label "Eje rotativo (reducción 1/10)"@es ;
    ex:textoExtracto "Eje rotativo con reducción 1/10."@es ;
    ex:monitoreaParametro ex:Parametro_Pitch_EjeRotativoRed1_10 ;
    ex:documentadoEn ex:Tabla_ResolucionCaptacion_Pag188_191 .