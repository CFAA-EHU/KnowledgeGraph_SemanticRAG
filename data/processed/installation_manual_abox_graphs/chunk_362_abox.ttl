@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_0b456ab8de a ns1:Parametro ;
    rdfs:label "Parámetro que indica el avance máximo de palpado" ;
    ns1:identificador "MPA.PROBEFEED.xn" ;
    ns1:textoExtracto "PROBEFEED Avance máximo de palpado. Parámetro válido para ejes lineales y rotativos." .

ns1:Parametro_14ddd17d96 a ns1:Parametro ;
    rdfs:label "Parámetro que fija la máxima distancia de frenado del palpador" ;
    ns1:identificador "MPA.PROBERANGE.xn" ;
    ns1:textoExtracto "PROBERANGE Distancia máxima de frenado. Parámetro válido para ejes lineales y rotativos." .

ns1:Parametro_c1a833281a a ns1:Parametro ;
    rdfs:label "Parámetro que indica si el eje es participante en movimiento con palpador" ;
    ns1:identificador "MPA.PROBEAXIS.xn" ;
    ns1:textoExtracto "PROBEAXIS El eje puede participar en los movimientos con palpador. Parámetro válido para ejes lineales y rotativos." .

