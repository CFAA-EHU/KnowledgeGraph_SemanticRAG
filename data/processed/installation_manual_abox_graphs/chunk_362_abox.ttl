@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_INPUTREV
    a ex:Parametro ;
    rdfs:label "INPUTREV" ;
    ex:identificador "INPUTREV" ;
    ex:textoExtracto "Vueltas eje motor. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 1 a 32767. Valor por defecto: 1." ;
    ex:valor "1"^^<http://www.w3.org/2001/XMLSchema#integer> ;
    ex:monitoreaParametro ex:ComponenteMecanico_Motor .

ex:Parametro_OUTPUTREV
    a ex:Parametro ;
    rdfs:label "OUTPUTREV" ;
    ex:identificador "OUTPUTREV" ;
    ex:textoExtracto "Vueltas eje máquina. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 1 a 32767. Valor por defecto: 1." ;
    ex:valor "1"^^<http://www.w3.org/2001/XMLSchema#integer> .

ex:Parametro_NPULSES
    a ex:Parametro ;
    rdfs:label "NPULSES" ;
    ex:identificador "NPULSES" ;
    ex:textoExtracto "Número de impulsos del encoder. Parámetro válido para ejes lineales, rotativos y cabezales. Valores posibles: De 0 a 1000000. Valor por defecto: 1250. Este parámetro define el número de impulsos por vuelta del encoder." ;
    ex:valor "1250"^^<http://www.w3.org/2001/XMLSchema#integer> ;
    ex:monitoreaParametro ex:ComponenteElectrico_Encoder .

ex:Parametro_PITCH
    a ex:Parametro ;
    rdfs:label "PITCH" ;
    ex:identificador "PITCH" ;
    ex:textoExtracto "La posible reducción existente entre el motor y el encoder también se puede introducir directamente a través del parámetro PITCH." .

ex:Parametro_PITCH2
    a ex:Parametro ;
    rdfs:label "PITCH2" ;
    ex:identificador "PITCH2" ;
    ex:textoExtracto "Paso de husillo (captación externa)." .

ex:ComponenteMecanico_Motor
    a ex:ComponenteMecanico ;
    rdfs:label "Motor" ;
    ex:textoExtracto "Vueltas eje motor. Parámetro válido para ejes lineales, rotativos y cabezales." .

ex:ComponenteElectrico_Encoder
    a ex:ComponenteElectrico ;
    rdfs:label "Encoder" ;
    ex:textoExtracto "Número de impulsos del encoder. Este parámetro define el número de impulsos por vuelta del encoder." .