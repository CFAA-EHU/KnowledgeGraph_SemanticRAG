@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_NPULSES
    a ex:Parametro ;
    rdfs:label "NPULSES" ;
    ex:textoExtracto "Si se definen los parámetros NPULSES y NPULSES2 con valor distinto de ꞏ0ꞏ..." ;
    ex:valor "distinto de 0" .

ex:Parametro_NPULSES2
    a ex:Parametro ;
    rdfs:label "NPULSES2" ;
    ex:textoExtracto "Si se definen los parámetros NPULSES y NPULSES2 con valor distinto de ꞏ0ꞏ..." ;
    ex:valor "distinto de 0" .

ex:Parametro_REFINI
    a ex:Parametro ;
    rdfs:label "REFINI" ;
    ex:textoExtracto "el parámetro REFINI establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento." .

ex:Parametro_PITCH2
    a ex:Parametro ;
    rdfs:label "PITCH2" ;
    ex:textoExtracto "PITCH2 Paso de husillo (captación externa). Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos." ;
    ex:valor "5 mm / 0.19685 inch"@es .

ex:RangoValor_PITCH2_mm
    a ex:Parametro ;
    rdfs:label "Rango de valores PITCH2 (mm)" ;
    ex:textoExtracto "Valores posibles (1): De 0 a 99999.9999 mm." ;
    ex:valor "0-99999.9999 mm" .

ex:RangoValor_PITCH2_inch
    a ex:Parametro ;
    rdfs:label "Rango de valores PITCH2 (inch)" ;
    ex:textoExtracto "Valores posibles (2): De 0 a 3937.00787 inch." ;
    ex:valor "0-3937.00787 inch" .

ex:RangoValor_PITCH2_grados
    a ex:Parametro ;
    rdfs:label "Rango de valores PITCH2 (grados)" ;
    ex:textoExtracto "Valores posibles (3): De 0 a 99999.9999 grados." ;
    ex:valor "0-99999.9999 grados" .