@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_NPULSES a ex:Parametro ;
    ex:identificador "NPULSES" ;
    ex:textoExtracto "Si se definen los parámetros NPULSES y NPULSES2 con valor distinto de ꞏ0ꞏ" ;
    ex:valor "distinto de ꞏ0ꞏ" .

ex:Parametro_NPULSES2 a ex:Parametro ;
    ex:identificador "NPULSES2" ;
    ex:textoExtracto "Si se definen los parámetros NPULSES y NPULSES2 con valor distinto de ꞏ0ꞏ" ;
    ex:valor "distinto de ꞏ0ꞏ" .

ex:Parametro_REFINI a ex:Parametro ;
    ex:identificador "REFINI" ;
    ex:textoExtracto "el parámetro REFINI establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento" ;
    ex:valor "establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento" .

ex:Parametro_PITCH2 a ex:Parametro ;
    ex:identificador "PITCH2" ;
    ex:textoExtracto "PITCH2 Paso de husillo (captación externa). Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos." ;
    rdfs:label "Paso de husillo (captación externa)" ;
    ex:valor "De 0 a 99999.9999 mm. De 0 a 3937.00787 inch. De 0 a 99999.9999 grados. Valor por defecto: 5 mm / 0.19685 inch" .