@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_PITCH2
    a ex:Parametro ;
    rdfs:label "Parámetro PITCH2 para regulador Sercos"@es ;
    ex:textoExtracto "para regulador Sercos. [...] Variable asociada: (V.)[ch].MPA.PITCH2[set].xn"@es ;
    ex:identificador "MPA.PITCH2[set].xn" ;
    ex:valor "5 mm / 0.19685 inch / 360º" ;
    ex:textoExtracto "Valor por defecto: 5 mm / 0.19685 inch / 360º."@es .

ex:Sistema_ReguladorSercos
    a ex:Sistema ;
    rdfs:label "Sistema de regulación Sercos"@es ;
    ex:textoExtracto "para regulador Sercos"@es ;
    ex:tieneComponente ex:Parametro_PITCH2 ;
    ex:monitoreaParametro ex:Parametro_PITCH2 .