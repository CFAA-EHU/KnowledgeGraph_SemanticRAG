@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Parametro_MPA_PITCH2_set ex:textoExtracto """Valor por defecto: 5 mm / 0.19685 inch / 360º. Variable asociada: (V.)[ch].MPA.PITCH2[set].xn El significado de este parámetro depende del tipo captación. • En un eje lineal con encoder y husillo, el parámetro define el paso de husillo. • En un eje rotativo, el parámetro define el número de grados por vuelta de encoder.""" ;
    a ex:Parametro ;
    ex:identificador "(V.)[ch].MPA.PITCH2[set].xn" ;
    ex:valor "5 mm / 0.19685 inch / 360º" .

ex:Esquema_Regulador_Sercos ex:textoExtracto """para regulador Sercos.""" ;
    a ex:Esquema ;
    ex:identificador "Sercos" .

ex:Parametro_MPA_PITCH2_set ex:detalladoEnEsquema ex:Esquema_Regulador_Sercos .