@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceDeReposicionamientoTrasUnaInspeccionDeHerramientaOUnaSubrutinaD_a3315b721f a ns1:Parametro ;
    rdfs:label "Avance de reposicionamiento tras una inspección de herramienta o una subrutina de interrupción" ;
    ns1:identificador "MPA.REPOSFEED.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.REPOSFEED.xn Avance de reposicionamiento tras una inspección de herramienta o una subrutina de interrupción." .

ns1:AvanceDefinidoParaElModoJogContinuo a ns1:Parametro ;
    rdfs:label "Avance definido para el modo jog continuo" ;
    ns1:identificador "JOGFEED" ;
    ns1:textoExtracto "El valor del parámetro REPOSFEED deberá ser siempre menor que G00FEED, MAXMANFEED y JOGRAPFEED." .

ns1:AvanceMaximoDeReposicionamiento a ns1:Parametro ;
    rdfs:label "Avance máximo de reposicionamiento" ;
    ns1:identificador "REPOSFEED" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado." .

