@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:param_SINMAGNI
    a ex:Parametro ;
    rdfs:label "SINMAGNI" ;
    ex:identificador "SINMAGNI" ;
    ex:textoExtracto "SINMAGNI Factor de multiplicación para la señal de captación senoidal. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y simulado. Valores posibles: De 0 a 255. Valor por defecto: 0." ;
    ex:valor "0-255" ;
    .

ex:param_PITCH
    a ex:Parametro ;
    rdfs:label "PITCH" ;
    ex:identificador "PITCH" ;
    ex:textoExtracto "Los parámetros SINMAGNI, PITCH y NPULSES definen la resolución de contaje del eje" ;
    .

ex:param_NPULSES
    a ex:Parametro ;
    rdfs:label "NPULSES" ;
    ex:identificador "NPULSES" ;
    ex:textoExtracto "Los parámetros SINMAGNI, PITCH y NPULSES definen la resolución de contaje del eje" ;
    .