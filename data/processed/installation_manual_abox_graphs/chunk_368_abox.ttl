@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Esquema368 a ex:Tabla ;
    ex:textoExtracto """| Tipo de encóder. | PITCH | NPULSES | SINMAGNI |
| --- | --- | --- | --- |
| Eje rotativo. Encoder rotativo. Señales cuadradas. | Giro del eje por vuelta
del encoder | Número de impulsos. | 0 |
| Eje rotativo. Encóder rotativo. Señales senoidales. | Giro del eje por vuelta
del encoder | Número de impulsos. | Factor de
multiplicación. |
| Eje lineal. Encoder rotativo. Señales cuadradas. | Paso del husillo. | Número de impulsos. | 0 |
| Eje lineal. Encóder rotativo. Señales senoidales. | Paso del husillo. | Número de impulsos. | Factor de
multiplicación. |
| Encoder lineal. Señales cuadradas. | Paso del encoder. | 0 | 0 |
| Encóder lineal. Señales senoidales. | Paso del encoder. | 0 | Factor de
multiplicación. |""" .

ex:EncoderRotativoSeñalesCuadradas a ex:ComponenteElectrico ;
    rdfs:label "Encoder rotativo. Señales cuadradas." ;
    ex:textoExtracto "Eje rotativo. Encoder rotativo. Señales cuadradas." .

ex:EncoderRotativoSeñalesSenoidales a ex:ComponenteElectrico ;
    rdfs:label "Encóder rotativo. Señales senoidales." ;
    ex:textoExtracto "Eje rotativo. Encóder rotativo. Señales senoidales." .

ex:EncoderLinealSeñalesCuadradas a ex:ComponenteElectrico ;
    rdfs:label "Encoder lineal. Señales cuadradas." ;
    ex:textoExtracto "Encoder lineal. Señales cuadradas." .

ex:EncoderLinealSeñalesSenoidales a ex:ComponenteElectrico ;
    rdfs:label "Encóder lineal. Señales senoidales." ;
    ex:textoExtracto "Encóder lineal. Señales senoidales." .

ex:Esquema368 ex:tieneComponente ex:EncoderRotativoSeñalesCuadradas, ex:EncoderRotativoSeñalesSenoidales, ex:EncoderLinealSeñalesCuadradas, ex:EncoderLinealSeñalesSenoidales .