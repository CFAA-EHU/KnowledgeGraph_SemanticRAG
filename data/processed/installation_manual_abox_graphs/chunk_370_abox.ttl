ns1:LimiteMaximoDeSeguridadParaElAvanceYLaVelocidad a ns1:Parametro ;
    rdfs:label "Límite máximo de seguridad para el avance y la velocidad" ;
    ns1:identificador "SLIMITAC" ;
    ns1:textoExtracto "desde el PLC (marcas SLIMITAC o SLIMITACSPDL) y el CNC lo aplica en el bloque en ejecución." .

