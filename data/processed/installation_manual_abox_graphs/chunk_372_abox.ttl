@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "En los cabezales, estos parámetros sólo se aplicarán cuando el cabezal se interpole con ejes durante el roscado rígido o cuando el cabezal trabaje como eje C." .

ns1:TablaDeParametrosDelModoManual a ns1:Parametro ;
    rdfs:label "Tabla de parámetros del modo manual" ;
    ns1:documentadoEn ns1:TablaParametrosManual ;
    ns1:textoExtracto "Tabla de parámetros del modo manual. Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:ModoOperacionManual a ns1:ModoOperacion ;
    rdfs:label "Modo de trabajo manual" ;
    ns1:textoExtracto "MANUAL Tabla de parámetros del modo manual. Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:TablaParametrosManual a ns1:Tabla ;
    rdfs:label "Tabla de parámetros para definir los desplazamientos en modo manual" ;
    ns1:ilustradoEn ns1:ModoOperacionManual ;
    ns1:textoExtracto "Este parámetro muestra la tabla de parámetros para definir los desplazamientos en modo manual." .

