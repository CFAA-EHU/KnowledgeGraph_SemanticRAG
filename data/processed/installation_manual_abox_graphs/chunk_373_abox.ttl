@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_BACKLASH
    a               ex:Parametro ;
    rdfs:label      "BACKLASH (compensación de holgura)"@es ;
    ex:textoExtracto "BACKLASH Holgura a compensar. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): Entre ±3.2768 mm. Valores posibles (2): Entre ±0.12901 inch. Valores posibles (3): Entre ±3.2768 grados. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.BACKLASH[set].xn"@es ;
    ex:valor        "0"^^xsd:string ;
    ex:identificador "(V.)[ch].MPA.BACKLASH[set].xn" .

ex:ComponenteMecanico_Husillo
    a               ex:ComponenteMecanico ;
    rdfs:label      "Husillo (eje con posible holgura)"@es ;
    ex:textoExtracto "Normalmente ocurre en ejes con encoder y en máquinas viejas en las que el juego entre husillo y soporte es defectuoso (gastado)."@es .

ex:ComponenteMecanico_Encoder
    a               ex:ComponenteMecanico ;
    rdfs:label      "Encoder (sensor de posición en eje)"@es ;
    ex:textoExtracto "Normalmente ocurre en ejes con encoder y en máquinas viejas en las que el juego entre husillo y soporte es defectuoso (gastado)."@es .

ex:ComponenteMecanico_SoporteHusillo
    a               ex:ComponenteMecanico ;
    rdfs:label      "Soporte de husillo"@es ;
    ex:textoExtracto "juego entre husillo y soporte es defectuoso (gastado)"@es .

ex:Sensor_RelojComparador
    a               ex:Sensor ;
    rdfs:label      "Reloj comparador"@es ;
    ex:textoExtracto "Para medir la holgura utilizar un reloj comparador. Desplazar el eje en una dirección y poner el reloj a 0. Desplazar el eje en sentido contrario en modo incremental hasta detectar que el eje se mueve."@es ;
    ex:monitoreaParametro ex:Parametro_BACKLASH .

ex:ComponenteMecanico_MotorEje
    a               ex:ComponenteMecanico ;
    rdfs:label      "Motor de eje"@es ;
    ex:textoExtracto "al invertir el sentido de giro hay un retardo desde que comienza a moverse el motor hasta que se mueve el carro"@es ;
    ex:controla     ex:ComponenteMecanico_Husillo .

ex:ComponenteMecanico_Carro
    a               ex:ComponenteMecanico ;
    rdfs:label      "Carro (elemento móvil del eje)"@es ;
    ex:textoExtracto "retardo desde que comienza a moverse el motor hasta que se mueve el carro"@es .