@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceleracionMaximaEnJogContinuo a ns1:Parametro ;
    rdfs:label "Aceleración máxima en jog continuo" ;
    ns1:identificador "MAXMANACC" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:AvanceMaximoParaDesplazamientosEnJogContinuoEnModoManual a ns1:Parametro ;
    rdfs:label "Avance máximo para desplazamientos en jog continuo en modo manual" ;
    ns1:identificador "MPA.MAXMANFEED.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.MAXMANFEED.xn Parámetro incluido en la tabla MANUAL. Este parámetro define el avance máximo para los desplazamientos en jog continuo en modo manual." ;
    ns1:valor "10000.0000 mm/min / 393.70079 inch/min / 10000.0000 grados/min" .

