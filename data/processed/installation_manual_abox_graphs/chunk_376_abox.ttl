@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceleracionMaximaParaDesplazamientosEnJogContinuo a ns1:Parametro ;
    rdfs:label "Aceleración máxima para desplazamientos en jog continuo" ;
    ns1:identificador "MPA.MAXMANACC.xn" ;
    ns1:textoExtracto "Este parámetro define la aceleración máxima para los desplazamientos en jog continuo en modo manual." .

ns1:Posicion10000DelConmutador a ns1:Parametro ;
    rdfs:label "Posición ꞏ10000ꞏ del conmutador" ;
    ns1:identificador "INCJOGDIST5" ;
    ns1:textoExtracto "INCJOGDIST5 Posición ꞏ10000ꞏ del conmutador." .

ns1:Posicion1000DelConmutador a ns1:Parametro ;
    rdfs:label "Posición ꞏ1000ꞏ del conmutador" ;
    ns1:identificador "INCJOGDIST4" ;
    ns1:textoExtracto "INCJOGDIST4 Posición ꞏ1000ꞏ del conmutador." .

ns1:Posicion100DelConmutador a ns1:Parametro ;
    rdfs:label "Posición ꞏ100ꞏ del conmutador" ;
    ns1:identificador "INCJOGDIST3" ;
    ns1:textoExtracto "INCJOGDIST3 Posición ꞏ100ꞏ del conmutador." .

ns1:Posicion10DelConmutador a ns1:Parametro ;
    rdfs:label "Posición ꞏ10ꞏ del conmutador" ;
    ns1:identificador "INCJOGDIST2" ;
    ns1:textoExtracto "INCJOGDIST2 Posición ꞏ10ꞏ del conmutador." .

ns1:Posicion1DelConmutador a ns1:Parametro ;
    rdfs:label "Posición ꞏ1ꞏ del conmutador" ;
    ns1:identificador "INCJOGDIST1" ;
    ns1:textoExtracto "INCJOGDIST1 Posición ꞏ1ꞏ del conmutador." .

ns1:TablaDeDesplazamientosEnJogIncremental a ns1:Parametro ;
    rdfs:label "Tabla de desplazamientos en jog incremental" ;
    ns1:identificador "INCJOGDIST" ;
    ns1:textoExtracto "Este parámetro muestra la tabla para definir los desplazamientos del eje en cada posición del conmutador de jog." .

