@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_BAKANOUT
    a ex:Parametro ;
    rdfs:label "BAKANOUT" ;
    ex:textoExtracto "cuando LOOPCH=Sí hay que definir BAKANOUT con valor negativo para que el CNC aplique el pico de inversión en sentido correcto. Cuando se define un impulso adicional de consigna también hay que definir los parámetros BAKTIME, ACTBAKAN y PEAKDISP." ;
    ex:valor "negativo (distinto de cero)" .

ex:Parametro_BAKTIME
    a ex:Parametro ;
    rdfs:label "BAKTIME" ;
    ex:textoExtracto "BAKTIME: Duración del impulso adicional de consigna. Parámetro válido para ejes lineales, rotativos y cabezales. [...] Valores posibles: De 0 a 100 ms. Valor por defecto: 0." ;
    ex:valor "0-100 ms" .

ex:Parametro_ACTBAKAN
    a ex:Parametro ;
    rdfs:label "ACTBAKAN" ;
    ex:textoExtracto "ACTBAKAN: Aplicación del impulso adicional de consigna. [...] Valores posibles: Siempre / G2-G3. Valor por defecto: Siempre." ;
    ex:valor "Siempre, G2-G3" .

ex:Parametro_PEAKDISP
    a ex:Parametro ;
    rdfs:label "PEAKDISP" ;
    ex:textoExtracto "PEAKDISP: Distancia de corte del pico de holgura. [...] Valores posibles (1): De 0 a 99999.9999 mm. Valores posibles (2): De 0 a 3937.00787 inch. Valores posibles (3): De 0 a 99999.9999 grados." ;
    ex:valor "0-99999.9999 mm / 0-3937.00787 inch / 0-99999.9999 grados" .

ex:Sistema_CompensacionHolgura
    a ex:Sistema ;
    rdfs:label "Sistema de compensación de holgura con impulso adicional de consigna" ;
    ex:textoExtracto "En los ejes analógicos, cuando LOOPCH=Sí hay que definir BAKANOUT con valor negativo para que el CNC aplique el pico de inversión en sentido correcto." ;
    ex:tieneComponente ex:Parametro_BAKANOUT, ex:Parametro_BAKTIME, ex:Parametro_ACTBAKAN, ex:Parametro_PEAKDISP .