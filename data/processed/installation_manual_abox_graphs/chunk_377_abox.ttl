@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinicionDeDistanciaPorTeclaDeJog a ns1:TareaMantenimiento ;
    rdfs:label "Definición de distancia por tecla de jog" ;
    ns1:solucionaFallo ns1:DistanciaIncorrectaPorTeclaDeJog ;
    ns1:textoExtracto "En cada parámetro hay que definir la distancia que se desplaza el eje cada vez que se pulsa la tecla de jog." .

ns1:DistanciaDeDesplazamientoPorTeclaDeJog a ns1:Parametro ;
    rdfs:label "Distancia de desplazamiento por tecla de jog" ;
    ns1:identificador "MPA.INCJOGDIST" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.INCJOGDIST[pos].xn En cada parámetro hay que definir la distancia que se desplaza el eje cada vez que se pulsa la tecla de jog." .

ns1:DistanciaIncorrectaPorTeclaDeJog a ns1:DiagnosticoFallo ;
    rdfs:label "Distancia incorrecta por tecla de jog" ;
    ns1:textoExtracto "Los valores más habituales son los definidos por defecto." .

