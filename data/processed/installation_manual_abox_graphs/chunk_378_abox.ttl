@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesplazamientoIncremental1 a ns1:Parametro ;
    rdfs:label "Desplazamiento incremental 1" ;
    ns1:identificador "INCJOGDIST1" ;
    ns1:textoExtracto "INCJOGDIST1 | 0.0010 mm o grados / 0.00003937 inch." .

ns1:DesplazamientoIncremental2 a ns1:Parametro ;
    rdfs:label "Desplazamiento incremental 2" ;
    ns1:identificador "INCJOGDIST2" ;
    ns1:textoExtracto "INCJOGDIST2 | 0.0100 mm o grados / 0.00039370 inch." .

ns1:DesplazamientoIncremental3 a ns1:Parametro ;
    rdfs:label "Desplazamiento incremental 3" ;
    ns1:identificador "INCJOGDIST3" ;
    ns1:textoExtracto "INCJOGDIST3 | 0.1000 mm o grados / 0.00393700 inch." .

ns1:DesplazamientoIncremental4 a ns1:Parametro ;
    rdfs:label "Desplazamiento incremental 4" ;
    ns1:identificador "INCJOGDIST4" ;
    ns1:textoExtracto "INCJOGDIST4 | 1.0000 mm o grados / 0.03937007 inch." .

ns1:DesplazamientoIncremental5 a ns1:Parametro ;
    rdfs:label "Desplazamiento incremental 5" ;
    ns1:identificador "INCJOGDIST5" ;
    ns1:textoExtracto "INCJOGDIST5 | 10.000 mm o grados / 0.39370078 inch." .

