@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:OrdenCompensacionHolgura a ex:TareaMantenimiento ;
    rdfs:label "Orden para iniciar la compensación de holgura" ;
    ex:textoExtracto "Orden para iniciar la compensación de holgura." ;
    ex:tieneFrecuencia ex:FrecuenciaCompensacionHolgura .

ex:FrecuenciaCompensacionHolgura a ex:Frecuencia ;
    ex:textoExtracto "Amplitud del parametriza de posición." .