@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_BACKLASH a ex:Parametro ;
    rdfs:label "BACKLASH" ;
    ex:textoExtracto "En el caso de que se tengan ejes definidos como visualizador, en estos ejes se tendrá en cuenta el valor del parámetro BACKLASH." .

ex:Parametro_REVEHYST a ex:Parametro ;
    rdfs:label "REVEHYST" ;
    ex:textoExtracto "especialmente si se tiene captación senoidal, se recomienda tener un valor REVEHYST distinto de 0, para aplicar el backlash." .

ex:Sistema_CNC a ex:Maquina ;
    rdfs:label "CNC" ;
    ex:textoExtracto "Si REVEHYST= 0.0005 mm, el CNC no activará la compensación en las inversiones posteriores a la primera mientras la posición del" .