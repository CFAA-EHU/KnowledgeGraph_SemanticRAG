@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_BACKlash
    a ex:Parametro ;
    rdfs:label "BACKLASH" ;
    ex:textoExtracto "valor del parámetro BACKLASH"@es ;
    ex:monitoreaParametro ex:Sistema_CompensacionHolgura .

ex:Parametro_REVEHYST
    a ex:Parametro ;
    rdfs:label "REVEHYST" ;
    ex:identificador "REVEHYST" ;
    ex:textoExtracto "valor REVEHYST distinto de 0 [...] REVEHYST= 0.0005 mm"@es ;
    ex:valor "0.0005" ;
    ex:monitoreaParametro ex:Sistema_CompensacionHolgura .

ex:Sistema_CompensacionHolgura
    a ex:Sistema ;
    rdfs:label "Sistema de compensación de holgura con impulso adicional"@es ;
    ex:textoExtracto "compensación de holgura con impulso adicional de consigna [...] Inversión de la consigna de posición. 2 Límite definido en REVEHYST. Inicio de la compensación de holgura. 3 Cancelación de la compensación de holgura"@es ;
    ex:tieneComponente ex:Componente_EjeVisualizador .

ex:Componente_EjeVisualizador
    a ex:ComponenteMecanico ;
    rdfs:label "Eje definido como visualizador"@es ;
    ex:textoExtracto "ejes definidos como visualizador"@es .