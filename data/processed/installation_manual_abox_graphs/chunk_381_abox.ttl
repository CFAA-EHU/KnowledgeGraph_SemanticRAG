@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ResolucionDelMovimientoManual a ns1:Parametro ;
    rdfs:label "Resolución del movimiento manual" ;
    ns1:identificador "MPGRESOL" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.MPGRESOL[pos].xn En cada parámetro hay que definir la distancia que se desplaza el eje por cada impulso del volante." ;
    ns1:valor "-99999.9999 grados",
        "-99999.9999 mm",
        "3937.00787 inch" .

