@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaximoRecorridoNegativoConG201 a ns1:Parametro ;
    rdfs:label "Máximo recorrido negativo con G201" ;
    ns1:identificador "MANNEGSW" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:MaximoRecorridoPositivoConG201 a ns1:Parametro ;
    rdfs:label "Máximo recorrido positivo con G201" ;
    ns1:identificador "MANPOSSW" ;
    ns1:textoExtracto "Valores posibles (1): Entre ±99999.9999 mm." .

ns1:ResolucionDelVolanteParaLaPosicion1DelConmutador a ns1:Parametro ;
    rdfs:label "Resolución del volante para la posición ꞏ1ꞏ del conmutador" ;
    ns1:identificador "MPGRESOL1" ;
    ns1:textoExtracto "MPGRESOL1 = 0.0010 mm." .

ns1:TiempoDeFiltroParaElVolante a ns1:Parametro ;
    rdfs:label "Tiempo de filtro para el volante" ;
    ns1:identificador "MPGFILTER" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales." .

