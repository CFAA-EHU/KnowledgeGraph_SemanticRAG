@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:G00FEED
    a ex:Parametro ;
    rdfs:label "G00FEED" ;
    ex:identificador "G00FEED" ;
    ex:textoExtracto "G00FEED Avance en G00. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ex:valor "20000.0000 mm/min / 787.40157 inch/min / 1080000 grados/min / 3000.0000 rpm"^^xsd:string ;
    ex:monitoreaParametro ex:AvanceRapidoG00 .

ex:AvanceRapidoG00
    a ex:ModoOperacion ;
    rdfs:label "Avance rápido G00" ;
    ex:textoExtracto "Los posicionamientos rápidos (G00) se realizan siempre al máximo avance posible, el indicado por G00FEED." .

ex:MAXFEED
    a ex:Parametro ;
    rdfs:label "MAXFEED" ;
    ex:identificador "MAXFEED" ;
    ex:textoExtracto "MAXFEED Máximo avance de mecanizado del eje. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ex:monitoreaParametro ex:AvanceMecanizado .

ex:AvanceMecanizado
    a ex:ModoOperacion ;
    rdfs:label "Avance de mecanizado" ;
    ex:textoExtracto "Máximo avance de mecanizado del eje." .

ex:VariablePLC_G00FEED
    a ex:Parametro ;
    rdfs:label "PLC.G00FEED" ;
    ex:identificador "(V.)[ch].PLC.G00FEED" ;
    ex:textoExtracto "El PLC dispone de la variable (V.)[ch].PLC.G00FEED que permite limitar el avance en el canal para cualquier tipo de movimiento (G00, G01, etc)." ;
    ex:monitoreaParametro ex:AvanceRapidoG00 .

ex:VariableMPA_G00FEED
    a ex:Parametro ;
    rdfs:label "MPA.G00FEED" ;
    ex:identificador "(V.)[ch].MPA.G00FEED[set].xn" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.G00FEED[set].xn" ;
    ex:monitoreaParametro ex:AvanceRapidoG00 .

ex:MAXVOLT
    a ex:Parametro ;
    rdfs:label "MAXVOLT" ;
    ex:identificador "MAXVOLT" ;
    ex:textoExtracto "los watios definidos en el parámetro G00FEED como potencia del generador deben corresponder al nivel de voltios definidos en el parámetro MAXVOLT." ;
    ex:valor "Potencia máxima del generador (modelo láser)"^^xsd:string .

ex:PWRCTRLON
    a ex:Parametro ;
    rdfs:label "PWRCTRLON" ;
    ex:identificador "#PWRCTRLON[OUT]" ;
    ex:textoExtracto "Para que la gestión del control de la potencia a través de una salida analógica sea correcta (#PWRCTRLON[OUT]..." .