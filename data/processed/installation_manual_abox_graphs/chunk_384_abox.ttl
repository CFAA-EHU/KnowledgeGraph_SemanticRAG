@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MAXFEED
    a ex:Parametro ;
    rdfs:label "MAXFEED" ;
    ex:identificador "MPA.MAXFEED[set].xn" ;
    ex:textoExtracto "MAXFEED Máximo avance de mecanizado del eje. Parámetro válido para ejes lineales, rotativos y cabezales. [...] Este parámetro establece el avance máximo de mecanizado (movimientos en G01/G02/G03) del eje; si se define con valor ꞏ0ꞏ, no se limita el" ;
    ex:valor "0"^^xsd:string .  # Valor por defecto textual (sin conversión de unidades)