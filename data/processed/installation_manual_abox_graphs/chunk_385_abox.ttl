@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IndicadorDeMovimientoEnModoManualDelEje a ns1:Parametro ;
    rdfs:label "Indicador de movimiento en modo manual del eje" ;
    ns1:identificador "MPA.MANNEGSW" ;
    ns1:textoExtracto "Cuando se trabaja con la función G201, modo manual superpuesto al modo automático, estos parámetros indican cuánto se puede mover en modo manual el eje en ambos sentidos." .

ns1:MaximoPorcentajeAceleracionManualEnG201 a ns1:Parametro ;
    rdfs:label "Máximo porcentaje aceleración manual en G201" ;
    ns1:identificador "MPA.MANACCP" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "20" .

ns1:MaximoPorcentajeDeAvanceDeEjecucionEnG201 a ns1:Parametro ;
    rdfs:label "Máximo porcentaje de avance de ejecución en G201" ;
    ns1:identificador "IPOFEEDP" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "80" .

ns1:MaximoPorcentajeDeAvanceManualEnG201 a ns1:Parametro ;
    rdfs:label "Máximo porcentaje de avance manual en G201" ;
    ns1:identificador "MANFEEDP" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "20" .

