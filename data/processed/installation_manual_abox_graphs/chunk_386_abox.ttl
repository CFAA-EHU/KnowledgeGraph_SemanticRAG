@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Tabla386_196 a ex:Tabla ;
    ex:textoExtracto "Variable. | Parámetros máquina. |  | Avance. | | (V.)PLC.G00FEED | G00FEED (eje) | MAXFEED (eje) | G00 | G01, G02, ꞏꞏꞏ | 0 | 10000 | 0 | 10000 | 10000 | 0 | 10000 | 6000 | 10000 | 6000 | 4000 | 10000 | 6000 | 4000 | 4000 | 7000 | 10000 | 6000 | 7000 | 6000 | 12000 | 10000 | 6000 | 10000 | 6000 ." .

ex:ParametroG00FEED a ex:Parametro ;
    ex:identificador "G00FEED" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.MAXVOLT[set].xn Modelos torno y fresadora. Consigna que debe proporcionar el CNC para que el eje alcance el avance de posicionamiento rápido G00FEED. Modelo láser. Consigna que debe proporcionar el CNC para que el cabezal alcance la potencia del generado definida en G00FEED." ;
    rdfs:label "G00FEED (eje)"@es .

ex:ParametroMAXVOLT a ex:Parametro ;
    ex:identificador "MAXVOLT" ;
    ex:textoExtracto "MAXVOLT Consigna para alcanzar G00FEED. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos velocidad. Valores posibles: De 0 a 10000.0000 mV. Valor por defecto: 9500 mV (9.5 V)." ;
    ex:valor "0 a 10000.0000 mV"@es ;
    ex:valor "9500 mV (9.5 V)"@es .

ex:ParametroMAXFREQ a ex:Parametro ;
    ex:identificador "MAXFREQ" ;
    ex:textoExtracto "MAXFREQ Frecuencia necesaria para alcanzar G00FEED. Parámetro válido para cabezales. Parámetro válido para Inverter Mechatrolink. Valores posibles: De 0.0010 a 10000.0000 Hz. Valor por defecto: 50 Hz. Variable asociada: (V.)[ch].MPA.MAXFREQ[set].xn Cuando el regulador sea un inverter, este parámetro indica la frecuencia que debe proporcionar el CNC para que el cabezal alcance la velocidad definida en el parámetro G00FEED." ;
    ex:valor "0.0010 a 10000.0000 Hz"@es ;
    ex:valor "50 Hz"@es .

ex:ParametroMAXRPM a ex:Parametro ;
    ex:identificador "MAXRPM" ;
    ex:textoExtracto "MAXRPM Revoluciones máximas del motor. Parámetro válido para ejes lineales, rotativos y cabezales." .

ex:ParametroMAXFEED a ex:Parametro ;
    ex:identificador "MAXFEED" ;
    ex:textoExtracto "MAXFEED (eje)" ;
    rdfs:label "MAXFEED (eje)"@es .

ex:SistemaAvanceRapido a ex:Sistema ;
    ex:textoExtracto "Ajuste del avance rápido G00 y de la velocidad máxima." ;
    ex:tieneComponente ex:ParametroG00FEED, ex:ParametroMAXVOLT, ex:ParametroMAXFREQ, ex:ParametroMAXRPM, ex:ParametroMAXFEED .