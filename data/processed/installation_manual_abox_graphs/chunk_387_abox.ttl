@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaximaAceleracionEnModoManual a ns1:Parametro ;
    rdfs:label "Máxima aceleración en modo manual" ;
    ns1:identificador "MPA.IPOACCP.xn" ;
    ns1:solucionaFallo ns1:FalloLimitesDinamicos ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.IPOACCP.xn Parámetro incluido en la tabla MANUAL." ;
    ns1:valor "80" .

ns1:RecomendacionDeAceleracionMaxima a ns1:TareaMantenimiento ;
    rdfs:label "Recomendación de aceleración máxima" ;
    ns1:textoExtracto "Se recomienda que la suma de ambos parámetros no sea superior a 100 para evitar que, en determinadas condiciones, se superen los límites dinámicos de la máquina." .

ns1:FalloLimitesDinamicos a ns1:DiagnosticoFallo ;
    rdfs:label "Superación de límites dinámicos" ;
    ns1:textoExtracto "Se recomienda que la suma de ambos parámetros no sea superior a 100 para evitar que, en determinadas condiciones, se superen los límites dinámicos de la máquina." .

