@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceDeJOG a ns1:Parametro ;
    rdfs:label "Avance de JOG" ;
    ns1:identificador "JOGFEED" ;
    ns1:textoExtracto "JOGFEED: 100 mm/min." .

ns1:AvanceRapido_75a0b33a86 a ns1:Parametro ;
    rdfs:label "Avance rápido" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "G00FEED: 1000 mm/min." .

ns1:MaximoAvanceManual a ns1:Parametro ;
    rdfs:label "Máximo avance manual" ;
    ns1:identificador "MAXMANFEED" ;
    ns1:textoExtracto "MAXMANFEED: 120 mm/min." .

ns1:ModoOperacionManual a ns1:ModoOperacion ;
    rdfs:label "Modo de trabajo manual" ;
    ns1:textoExtracto "modo de trabajo manual." .

ns1:PorcentajeDeLimitacionIPOFEED a ns1:Parametro ;
    rdfs:label "Porcentaje de limitación IPOFEED" ;
    ns1:identificador "IPOFEEDP" ;
    ns1:textoExtracto "IPOFEEDP: 50%" .

ns1:PorcentajeDeLimitacionMANFEEDP a ns1:Parametro ;
    rdfs:label "Porcentaje de limitación MANFEEDP" ;
    ns1:identificador "MANFEEDP" ;
    ns1:textoExtracto "MANFEEDP: 50%" .

