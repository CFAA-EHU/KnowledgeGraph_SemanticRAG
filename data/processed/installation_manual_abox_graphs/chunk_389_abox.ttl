@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla389_198 a ex:Tabla ;
    ex:textoExtracto """El avance rápido podrá superar al definido en el parámetro MAXFEED del canal y al avance activo definido por PLC (variable (V.)PLC.F). | Variable. | Parámetros máquina. |  | Avance rápido. |  |
| --- | --- | --- | --- | --- |
| (V.)PLC.G00FEED | G00FEED (eje) | FRAPIDEN (eje) | G00 | G01, G02, ꞏꞏꞏ |
| 0 | 10000 | 0 | 10000 | 10000 |
| 0 | 10000 | 6000 | 10000 | 6000 |
| 4000 | 10000 | 6000 | 4000 | 4000 |
| 7000 | 10000 | 6000 | 7000 | 6000 |
| 12000 | 10000 | 6000 | 10000 | 6000""" .

ex:Parametro_MAXFEED a ex:Parametro ;
    ex:identificador "MAXFEED" ;
    ex:textoExtracto "parámetro MAXFEED del canal" .

ex:Variable_PLC_F a ex:Parametro ;
    ex:identificador "(V.)PLC.F" ;
    ex:textoExtracto "avance activo definido por PLC (variable (V.)PLC.F)" .

ex:Parametro_G00FEED a ex:Parametro ;
    ex:identificador "(V.)PLC.G00FEED" ;
    ex:textoExtracto "(V.)PLC.G00FEED" .

ex:Parametro_G00FEED_eje a ex:Parametro ;
    ex:identificador "G00FEED (eje)" ;
    ex:textoExtracto "G00FEED (eje)" .

ex:Parametro_FRAPIDEN_eje a ex:Parametro ;
    ex:identificador "FRAPIDEN (eje)" ;
    ex:textoExtracto "FRAPIDEN (eje)" .

ex:ModoOperacion_G00 a ex:ModoOperacion ;
    ex:identificador "G00" ;
    ex:textoExtracto "G00" .

ex:ModoOperacion_G01 a ex:ModoOperacion ;
    ex:identificador "G01" ;
    ex:textoExtracto "G01" .

ex:ModoOperacion_G02 a ex:ModoOperacion ;
    ex:identificador "G02" ;
    ex:textoExtracto "G02" .

ex:Tabla389_198 a ex:Tabla ;
    ex:compuestoPor ex:Parametro_G00FEED, ex:Parametro_G00FEED_eje, ex:Parametro_FRAPIDEN_eje, ex:ModoOperacion_G00, ex:ModoOperacion_G01, ex:ModoOperacion_G02 .