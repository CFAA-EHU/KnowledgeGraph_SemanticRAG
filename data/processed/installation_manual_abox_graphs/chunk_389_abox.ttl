@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ParametrosAvanceRapido a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de avance rápido (G00)"@es ;
    ex:textoExtracto """
    | Variable. | Parámetros máquina. |  | Avance rápido. |  |
    | --- | --- | --- | --- | --- |
    | (V.)PLC.G00FEED | G00FEED (eje) | FRAPIDEN (eje) | G00 | G01, G02, ꞏꞏꞏ |
    | 0 | 10000 | 0 | 10000 | 10000 |
    | 0 | 10000 | 6000 | 10000 | 6000 |
    | 4000 | 10000 | 6000 | 4000 | 4000 |
    | 7000 | 10000 | 6000 | 7000 | 6000 |
    | 12000 | 10000 | 6000 | 10000 | 6000
    """ .

ex:Parametro_G00FEED
    a ex:Parametro ;
    rdfs:label "G00FEED (eje)"@es ;
    ex:identificador "(V.)PLC.G00FEED" ;
    ex:textoExtracto "G00FEED (eje)"@es ;
    ex:documentadoEn ex:Tabla_ParametrosAvanceRapido ;
    ex:valor "10000" .

ex:Parametro_FRAPIDEN
    a ex:Parametro ;
    rdfs:label "FRAPIDEN (eje)"@es ;
    ex:textoExtracto "FRAPIDEN (eje)"@es ;
    ex:documentadoEn ex:Tabla_ParametrosAvanceRapido ;
    ex:valor "6000" .

ex:Parametro_MAXFEED
    a ex:Parametro ;
    rdfs:label "Avance rápido máximo (MAXFEED)"@es ;
    ex:identificador "MAXFEED" ;
    ex:textoExtracto "El avance rápido podrá superar al definido en el parámetro MAXFEED del canal"@es .