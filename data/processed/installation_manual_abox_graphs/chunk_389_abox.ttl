@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CompensacionDeHusillo_953d333dd2 a ns1:Parametro ;
    rdfs:label "Compensación de husillo" ;
    ns1:identificador "LSCRWCOMP" ;
    ns1:textoExtracto "LSCRWCOMP Compensación de husillo. Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:TablaDeCompensacionDeHusillo a ns1:Parametro ;
    rdfs:label "Tabla de compensación de husillo" ;
    ns1:identificador "LSCRWDATA" ;
    ns1:textoExtracto "LSCRWDATA Tabla de compensación de husillo. Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:VariableMPALSCRWCOMP a ns1:Parametro ;
    rdfs:label "Variable asociada a la compensación de husillo" ;
    ns1:identificador "MPA.LSCRWCOMP.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.LSCRWCOMP.xn Este parámetro indica si el eje dispone de compensación de husillo." .

