@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_FFGAIN
    a ex:Parametro ;
    rdfs:label "Parámetro FFGAIN" ;
    ex:identificador "(V.)[ch].MPA.FFGAIN[set].xn" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.FFGAIN[set].xn. El CNC sólo tiene en cuenta este parámetro cuando trabaja con feed forward; parámetro FFWTYPE si regulador analógico o simulado y parámetro OPMODEP si regulador Sercos." ;
    ex:valor "0" .

ex:Parametro_FFWTYPE
    a ex:Parametro ;
    rdfs:label "Parámetro FFWTYPE" ;
    ex:textoExtracto "parámetro FFWTYPE si regulador analógico o simulado" .

ex:Parametro_OPMODEP
    a ex:Parametro ;
    rdfs:label "Parámetro OPMODEP" ;
    ex:textoExtracto "parámetro OPMODEP si regulador Sercos" .

ex:ModoOperacion_Automatico
    a ex:ModoOperacion ;
    rdfs:label "Modo automático" ;
    ex:textoExtracto "Un eje que vaya a trabajar como eje independiente debería tener definido el mismo feed forward en los modos automáticos y manual" .

ex:ModoOperacion_Manual
    a ex:ModoOperacion ;
    rdfs:label "Modo manual" ;
    ex:textoExtracto "Un eje que vaya a trabajar como eje independiente debería tener definido el mismo feed forward en los modos automáticos y manual" .