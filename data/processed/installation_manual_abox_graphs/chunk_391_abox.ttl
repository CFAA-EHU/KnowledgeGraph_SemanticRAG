@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaLSCRWCOMP a ns1:Tabla ;
    rdfs:label "Tabla LSCRWCOMP" ;
    ns1:ilustra ns1:BusquedaDeCeroNecesaria,
        ns1:CompensacionBidireccional,
        ns1:MetodoDeCompensacionTipoDeCotas_586bbc7fd8,
        ns1:NumeroDePuntosDeLaTabla_925e82171f ;
    ns1:textoExtracto "La tabla de compensación de husillo puede disponer de hasta 1000 puntos." .

ns1:BusquedaDeCeroNecesaria a ns1:Parametro ;
    rdfs:label "Búsqueda de cero necesaria" ;
    ns1:identificador "REFNEED" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:CompensacionBidireccional a ns1:Parametro ;
    rdfs:label "Compensación bidireccional" ;
    ns1:identificador "BIDIR" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:MetodoDeCompensacionTipoDeCotas_586bbc7fd8 a ns1:Parametro ;
    rdfs:label "Método de compensación (tipo de cotas)" ;
    ns1:identificador "TYPLSCRW" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:NumeroDePuntosDeLaTabla_925e82171f a ns1:Parametro ;
    rdfs:label "Número de puntos de la tabla" ;
    ns1:identificador "NPOINTS" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." .

