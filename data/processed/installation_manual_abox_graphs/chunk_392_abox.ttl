@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:FFGAIN a ex:Parametro ;
    rdfs:label "FFGAIN" ;
    ex:textoExtracto "los parámetros FFGAIN y MANFFGAIN deberían ser iguales" ;
    ex:valor "iguales" .

ex:MANFFGAIN a ex:Parametro ;
    rdfs:label "MANFFGAIN" ;
    ex:textoExtracto "los parámetros FFGAIN y MANFFGAIN deberían ser iguales" ;
    ex:valor "iguales" .

ex:Parametro_Feedforward a ex:Parametro ;
    rdfs:label "Feed forward" ;
    ex:textoExtracto "Este parámetro permite mejorar el lazo de posición minimizando el error de seguimiento" .

ex:Parametro_ProgGain a ex:Parametro ;
    rdfs:label "PROGAIN" ;
    ex:textoExtracto "el resto de la consigna será proporcional al error de seguimiento" .

ex:ErrorSeguimiento a ex:Parametro ;
    rdfs:label "error de seguimiento" ;
    ex:textoExtracto "minimizando el error de seguimiento" .