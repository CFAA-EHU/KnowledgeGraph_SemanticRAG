@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaLSCRWCOMP a ns1:Tabla ;
    rdfs:label "LSCRWCOMP" ;
    ns1:ilustra ns1:IndicaSiEsNecesarioReferenciarElEjeParaEmpezarAAplicarLaCompensacion ;
    ns1:textoExtracto "Parámetro incluido en la tabla LSCRWCOMP." .

ns1:IndicaSiEsNecesarioReferenciarElEjeParaEmpezarAAplicarLaCompensacion a ns1:Parametro ;
    rdfs:label "Indica si es necesario referenciar el eje para empezar a aplicar la compensación" ;
    ns1:identificador "MPA.REFNEED.xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.REFNEED.xn Parámetro incluido en la tabla LSCRWCOMP." .

