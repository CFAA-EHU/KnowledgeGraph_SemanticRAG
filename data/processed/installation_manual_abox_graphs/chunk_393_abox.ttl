@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorNegativoEnLaPosicion a ns1:Parametro ;
    rdfs:label "Error negativo en la posición" ;
    ns1:textoExtracto "El parámetro NEGERROR sólo se muestra si se ha definido la tabla con compensación bidireccional (BIDIR = Sí)." .

ns1:ErrorPositivoEnLaPosicion a ns1:Parametro ;
    rdfs:label "Error positivo en la posición" ;
    ns1:textoExtracto "Para cada uno de los puntos se deben definir los parámetros POSITION, POSERROR y NEGERROR." .

ns1:NumeroDePuntos_850d9256c3 a ns1:Parametro ;
    rdfs:label "Número de puntos" ;
    ns1:textoExtracto "El número de puntos viene definido por el parámetro NPOINTS." .

ns1:PosicionDelPunto a ns1:Parametro ;
    rdfs:label "Posición del punto" ;
    ns1:textoExtracto "Para cada uno de los puntos se deben definir los parámetros POSITION, POSERROR y NEGERROR." .

ns1:TablaCompensacionHusillo a ns1:Tabla ;
    rdfs:label "Tabla de Compensación de Husillo" ;
    ns1:documentadoEn ns1:CNC8070_156e144c9b ;
    ns1:textoExtracto "En la tabla DATA se debe definir el error que se desea compensar en determinadas posiciones del eje." .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

