@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MANFFGAIN
    a ex:Parametro ;
    rdfs:label "MANFFGAIN" ;
    ex:identificador "MANFFGAIN" ;
    ex:textoExtracto "MANFFGAIN Porcentaje de feed forward en manual. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y simulado. Valores posibles: De 0 a 120 %. Valor por defecto: 0." ;
    ex:valor "0" .

ex:Parametro_ACFWFACTOR
    a ex:Parametro ;
    rdfs:label "ACFWFACTOR" ;
    ex:identificador "ACFWFACTOR" ;
    ex:textoExtracto "ACFWFACTOR Constante de tiempo de aceleración. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos velocidad y simulado. Valores posibles: De 0.001 a 1000000.0000 ms. Valor por defecto: 1000.0000 ms." ;
    ex:valor "1000.0000 ms" .

ex:Parametro_FFGAIN
    a ex:Parametro ;
    rdfs:label "FFGAIN" ;
    ex:identificador "FFGAIN" ;
    ex:textoExtracto "Un eje que vaya a trabajar como eje independiente debería tener definido el mismo feed forward en los modos automáticos y manual; es decir, los parámetros FFGAIN y MANFFGAIN deberían ser iguales." .

ex:Parametro_FFWTYPE
    a ex:Parametro ;
    rdfs:label "FFWTYPE" ;
    ex:identificador "FFWTYPE" ;
    ex:textoExtracto "El CNC sólo tiene en cuenta este parámetro [MANFFGAIN] cuando trabaja con feed forward; parámetro FFWTYPE si regulador analógico o simulado y parámetro OPMODEP si regulador Sercos." .

ex:Parametro_OPMODEP
    a ex:Parametro ;
    rdfs:label "OPMODEP" ;
    ex:identificador "OPMODEP" ;
    ex:textoExtracto "El CNC sólo tiene en cuenta este parámetro [ACFWFACTOR] cuando trabaja con AC-forward; parámetro FFWTYPE si regulador analógico o simulado y parámetro OPMODEP si regulador Sercos velocidad." .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "El CNC sólo tiene en cuenta este parámetro cuando trabaja con feed forward; parámetro FFWTYPE si regulador analógico o simulado y parámetro OPMODEP si regulador Sercos." ;
    ex:tieneComponente ex:Parametro_MANFFGAIN ;
    ex:tieneComponente ex:Parametro_ACFWFACTOR ;
    ex:tieneComponente ex:Parametro_FFGAIN ;
    ex:tieneComponente ex:Parametro_FFWTYPE ;
    ex:tieneComponente ex:Parametro_OPMODEP .