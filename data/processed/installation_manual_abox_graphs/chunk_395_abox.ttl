@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoOperacion1 a ex:ModoOperacion ;
    rdfs:label "Respuesta del sistema sin ganancia AC-forward" ;
    ex:textoExtracto "Respuesta del sistema sin ganancia AC-forward (10 µm por cuadro)." .

ex:ModoOperacion2 a ex:ModoOperacion ;
    rdfs:label "Respuesta del sistema con ganancia AC-forward" ;
    ex:textoExtracto "Respuesta del sistema con ganancia AC-forward (1 µm por cuadro)." .

ex:Parametro1 a ex:Parametro ;
    rdfs:label "ganancia AC-forward" ;
    ex:valor "10 µm por cuadro" ;
    ex:textoExtracto "ganancia AC-forward (10 µm por cuadro)" .

ex:Parametro2 a ex:Parametro ;
    rdfs:label "ganancia AC-forward" ;
    ex:valor "1 µm por cuadro" ;
    ex:textoExtracto "ganancia AC-forward (1 µm por cuadro)" .