@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorDelEje a ns1:Parametro ;
    rdfs:label "Error del eje" ;
    ns1:identificador "MPA.POSERROR" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.POSERROR[pt].xn Parámetro incluido en la tabla LSCRWCOMP // DATA. Este parámetro indica el error cuando el eje" .

