@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaLSCRWCOMP a ns1:Tabla ;
    rdfs:label "Tabla LSCRWCOMP // DATA" ;
    ns1:textoExtracto "Parámetro incluido en la tabla LSCRWCOMP // DATA." ;
    ns1:tieneComponente ns1:ErrorCuandoElEjeSeDesplazaEnSentidoPositivo,
        ns1:ErrorEnSentidoNegativo .

ns1:ErrorCuandoElEjeSeDesplazaEnSentidoPositivo a ns1:Parametro ;
    rdfs:label "Error cuando el eje se desplaza en sentido positivo" ;
    ns1:identificador "MPA.POSERROR" ;
    ns1:textoExtracto "Este parámetro indica el error cuando el eje se desplaza en sentido positivo." ;
    ns1:valor "0" .

ns1:ErrorEnSentidoNegativo a ns1:Parametro ;
    rdfs:label "Error en sentido negativo" ;
    ns1:identificador "MPA.NEGERROR" ;
    ns1:textoExtracto "Este parámetro indica el error cuando el eje se desplaza en sentido negativo." ;
    ns1:valor "0" .

