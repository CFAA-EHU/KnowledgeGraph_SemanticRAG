@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Parametro_LACC1 a ex:Parametro ;
    ex:textoExtracto "El CNC aplica los parámetros LACC1 y LACC2 a los movimientos en G1, G2 y G3; los movimientos en G0 dependen del parámetro G0ACDCJERK." .

ex:Parametro_LACC2 a ex:Parametro ;
    ex:textoExtracto "El CNC aplica los parámetros LACC1 y LACC2 a los movimientos en G1, G2 y G3; los movimientos en G0 dependen del parámetro G0ACDCJERK." .

ex:Parametro_G0ACDCJERK a ex:Parametro ;
    ex:textoExtracto "los movimientos en G0 dependen del parámetro G0ACDCJERK." .

ex:Parametro_LACC1G0 a ex:Parametro ;
    ex:textoExtracto "Los movimientos en G0 utilizan los parámetros LACC1G0, LACC2G0 y LFEEDG0." .

ex:Parametro_LACC2G0 a ex:Parametro ;
    ex:textoExtracto "Los movimientos en G0 utilizan los parámetros LACC1G0, LACC2G0 y LFEEDG0." .

ex:Parametro_LFEEDG0 a ex:Parametro ;
    ex:textoExtracto "Los movimientos en G0 utilizan los parámetros LACC1G0, LACC2G0 y LFEEDG0." .

ex:Parametro_LFEED a ex:Parametro ;
    ex:textoExtracto "Los movimientos en G0 utilizan los parámetros LACC1, LACC2 y LFEED." .

ex:Tabla_2_6_8 a ex:Tabla ;
    ex:textoExtracto "| G0ACDCJERK | Significado. |\n| --- | --- |\n| Sí. | Los movimientos en G0 utilizan los parámetros LACC1G0, LACC2G0 y LFEEDG0. |\n| No. | Los movimientos en G0 utilizan los parámetros LACC1, LACC2 y LFEED. |" ;
    ex:tieneComponente ex:Parametro_G0ACDCJERK, ex:Parametro_LACC1G0, ex:Parametro_LACC2G0, ex:Parametro_LFEEDG0, ex:Parametro_LACC1, ex:Parametro_LACC2, ex:Parametro_LFEED .