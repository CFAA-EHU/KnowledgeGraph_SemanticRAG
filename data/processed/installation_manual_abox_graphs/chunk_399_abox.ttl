@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaLSCRWCOMP a ns1:Tabla ;
    rdfs:label "LSCRWCOMP" ;
    ns1:ilustra ns1:ErrorCuandoElEjeSeDesplazaEnSentidoNegativo ;
    ns1:textoExtracto "Este parámetro sólo estará disponible si se ha definido la tabla con compensación bidireccional." .

ns1:ErrorCuandoElEjeSeDesplazaEnSentidoNegativo a ns1:Parametro ;
    rdfs:label "Error cuando el eje se desplaza en sentido negativo" ;
    ns1:identificador "MPA.NEGERROR" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.NEGERROR[pt].xn Parámetro incluido en la tabla LSCRWCOMP // DATA. Este parámetro indica el error cuando el eje se desplaza en sentido negativo." .

