@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_9a0684a877 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC dispone de diferentes filtros." .

ns1:ConfiguracionDelFiltro a ns1:Parametro ;
    rdfs:label "Configuración del filtro" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:FiltroAntirresonante a ns1:ComponenteElectrico ;
    rdfs:label "Filtro antirresonante (banda eliminada)" ;
    ns1:textoExtracto "El filtro 'antirresonante' (banda eliminada), que limita una zona de la banda pasante" .

ns1:FiltroPasoBajo a ns1:ComponenteElectrico ;
    rdfs:label "Filtro paso bajo" ;
    ns1:textoExtracto "Los filtros 'paso bajo', que limitan la banda pasante a partir de una determinada frecuencia." .

ns1:TablaDeFiltros a ns1:Parametro ;
    rdfs:label "Tabla de filtros" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." .

