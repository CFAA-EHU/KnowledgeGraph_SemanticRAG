@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_ACCELG0 a ex:Parametro ;
    rdfs:label "ACCELG0" ;
    ex:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCELG0 y DECELG0." ;
    ex:valor "ACCELG0" .

ex:Parametro_DECELG0 a ex:Parametro ;
    rdfs:label "DECELG0" ;
    ex:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCELG0 y DECELG0." ;
    ex:valor "DECELG0" .

ex:Parametro_ACCEL a ex:Parametro ;
    rdfs:label "ACCEL" ;
    ex:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCEL y DECEL." ;
    ex:valor "ACCEL" .

ex:Parametro_DECEL a ex:Parametro ;
    rdfs:label "DECEL" ;
    ex:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCEL y DECEL." ;
    ex:valor "DECEL" .