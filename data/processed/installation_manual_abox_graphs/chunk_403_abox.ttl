@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_037952d679 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "\"De esta forma el CNC suaviza los movimientos, aunque tiene el inconveniente de redondear ligeramente las aristas.\"" .

ns1:FiltroPasoBajo a ns1:Componente ;
    rdfs:label "Filtro paso bajo" ;
    ns1:monitoreaParametro ns1:FrecuenciaResonancia ;
    ns1:textoExtracto "\"El filtro 'paso bajo', para una misma frecuencia, necesita menos orden y como consecuencia, introduce menos retardo.\"" .

ns1:FrecuenciaResonancia a ns1:Frecuencia ;
    rdfs:label "Frecuencia de resonancia" ;
    ns1:textoExtracto "\"De esta forma el CNC suaviza los movimientos, aunque tiene el inconveniente de redondear ligeramente las aristas.\"" .

