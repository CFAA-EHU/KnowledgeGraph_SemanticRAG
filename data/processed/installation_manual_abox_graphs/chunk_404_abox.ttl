@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FiltroAntiresonante a ns1:ComponenteElectrico ;
    rdfs:label "Filtro antirresonante" ;
    ns1:esComponenteDe ns1:MaquinaPrincipal ;
    ns1:textoExtracto "Si la máquina tiene una frecuencia de resonancia en una zona intermedia de su banda pasante, será conveniente eliminar esa frecuencia con un filtro \"antiresonante\"." .

ns1:FiltroPasoBajoFAGOR a ns1:ComponenteElectrico ;
    rdfs:label "Filtro paso bajo FAGOR" ;
    ns1:esComponenteDe ns1:MaquinaPrincipal ;
    ns1:textoExtracto "El filtro \"paso bajo FAGOR\" introduce un desfase constante, independiente de la frecuencia." .

ns1:MaquinaPrincipal a ns1:Maquina ;
    rdfs:label "Máquina principal" ;
    ns1:textoExtracto "Si la máquina tiene una frecuencia de resonancia en una zona intermedia de su banda pasante, será conveniente eliminar esa frecuencia con un filtro \"antiresonante\"." .

