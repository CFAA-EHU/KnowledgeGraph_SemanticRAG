@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaFILTER a ns1:Tabla ;
    rdfs:label "Filtros para eliminar frecuencias de resonancia" ;
    ns1:textoExtracto "Parámetros incluidos en la tabla FILTER." ;
    ns1:tieneComponente ns1:AnchuraDeBandaNormalizada_b3f059b4b5,
        ns1:FrecuenciaDeCorteOCentral_d7fd2374d2,
        ns1:PorcentajeDeSenalQuePasaATravesDelFiltro_6ae49b0c4c .

ns1:AnchuraDeBandaNormalizada_b3f059b4b5 a ns1:Parametro ;
    rdfs:label "Anchura de banda normalizada" ;
    ns1:identificador "MPA.NORWIDTH" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "1.0" .

ns1:FrecuenciaDeCorteOCentral_d7fd2374d2 a ns1:Parametro ;
    rdfs:label "Frecuencia de corte o central" ;
    ns1:identificador "MPA.FREQUENCY" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "30.0 Hz" .

ns1:PorcentajeDeSenalQuePasaATravesDelFiltro_6ae49b0c4c a ns1:Parametro ;
    rdfs:label "Porcentaje de señal que pasa a través del filtro" ;
    ns1:identificador "MPA.SHARE" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "100" .

