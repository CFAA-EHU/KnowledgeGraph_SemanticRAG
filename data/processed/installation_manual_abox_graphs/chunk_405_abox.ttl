@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_ACCEL a ex:Parametro ;
    rdfs:label "ACCEL" ;
    ex:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1, G2 y G3" ;
    ex:valor "parámetro de aceleración" .

ex:Parametro_DECEL a ex:Parametro ;
    rdfs:label "DECEL" ;
    ex:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1, G2 y G3" ;
    ex:valor "parámetro de deceleración" .

ex:Parametro_G0ACDCJERK a ex:Parametro ;
    rdfs:label "G0ACDCJERK" ;
    ex:textoExtracto "los movimientos en G0 dependen del parámetro G0ACDCJERK" ;
    ex:valor "parámetro de jerk para movimientos G0" .

ex:Movimiento_G1 a ex:ModoOperacion ;
    rdfs:label "G1" ;
    ex:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1, G2 y G3" .

ex:Movimiento_G2 a ex:ModoOperacion ;
    rdfs:label "G2" ;
    ex:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1, G2 y G3" .

ex:Movimiento_G3 a ex:ModoOperacion ;
    rdfs:label "G3" ;
    ex:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1, G2 y G3" .

ex:Movimiento_G0 a ex:ModoOperacion ;
    rdfs:label "G0" ;
    ex:textoExtracto "los movimientos en G0 dependen del parámetro G0ACDCJERK" .

ex:Movimiento_G33 a ex:ModoOperacion ;
    rdfs:label "G33" ;
    ex:textoExtracto "El CNC no tiene en cuenta estos parámetros en los movimientos con roscado (G33)" .

ex:Parametro_FFGAIN a ex:Parametro ;
    rdfs:label "FFGAIN" ;
    ex:textoExtracto "valores de FFGAIN cercanos al 100%" ;
    ex:valor "ganancia de feedforward" .