@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_ACCEL
    a ex:Parametro ;
    rdfs:label "ACCEL" ;
    ex:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1, G2 y G3" ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Parametro_DECEL
    a ex:Parametro ;
    rdfs:label "DECEL" ;
    ex:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1, G2 y G3" ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Parametro_FFGAIN
    a ex:Parametro ;
    rdfs:label "FFGAIN" ;
    ex:textoExtracto "valores de FFGAIN cercanos al 100%" ;
    ex:textoExtracto "Cuanto menor sea el valor asignado a estos parámetros, la respuesta de la máquina será más suave" ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Parametro_G0ACDCJERK
    a ex:Parametro ;
    rdfs:label "G0ACDCJERK" ;
    ex:textoExtracto "los movimientos en G0 dependen del parámetro G0ACDCJERK" ;
    ex:monitoreaParametro ex:Sistema_CNC .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1, G2 y G3" ;
    ex:textoExtracto "El CNC no tiene en cuenta estos parámetros en los movimientos con roscado (G33) y con HSC FAST" .