@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Parametro_ACCJERKG0 a ex:Parametro ;
    ex:identificador "ACCJERKG0" ;
    ex:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCJERKG0 y DECJERKG0." .

ex:Parametro_DECJERKG0 a ex:Parametro ;
    ex:identificador "DECJERKG0" ;
    ex:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCJERKG0 y DECJERKG0." .

ex:Parametro_ACCJERK a ex:Parametro ;
    ex:identificador "ACCJERK" ;
    ex:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCJERK y DECJERK." .

ex:Parametro_DECJERK a ex:Parametro ;
    ex:identificador "DECJERK" ;
    ex:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCJERK y DECJERK." .

ex:Tabla_G0ACDCJERK a ex:Tabla ;
    ex:textoExtracto "| G0ACDCJERK | Significado. |\n| --- | --- |\n| Sí. | Los movimientos en G0 utilizan los parámetros ACCJERKG0 y DECJERKG0. |\n| No. | Los movimientos en G0 utilizan los parámetros ACCJERK y DECJERK. |" .

ex:Esquema_AceleracionTrapezoidal a ex:Esquema ;
    ex:textoExtracto "Ejemplo. Aceleración trapezoidal. A continuación se muestran dos ejemplos para que un eje parado alcance G00FEED a la máxima aceleración, en un tiempo determinado (0,5 segundos). • El eje se puede parametrizar con aceleración máxima y jerk mínimo. v a j ACCEL G00FEED ACCJERK t t t t/2 t t/2 t t/2 t G00FEED ACCEL ACCEL = 2 x ACCJERK = 2 x 60 x 0,5 0,5 • El eje se puede parametrizar con una aceleración menor y jerk mayor, de manera que el eje alcance la aceleración máxima más rápido y esté más tiempo en aceleración máxima." .

ex:Esquema_AceleracionSenoCuadrado a ex:Esquema ;
    ex:textoExtracto "Ejemplo. Aceleración seno cuadrado. A continuación se muestran dos ejemplos para que un eje parado alcance G00FEED a la máxima aceleración, en un tiempo determinado (0,5 segundos). • El eje se puede parametrizar con aceleración máxima y jerk mínimo. v a j ACCEL G00FEED ACCJERK t/2 t t t t t/2 t t/2 t G00FEED ACCEL ACCEL = 2 x ACCJERK = 2 x 60 x 0,5 0,5 • El eje se puede parametrizar con una aceleración menor y jerk mayor, de manera que el eje alcance la aceleración máxima más rápido y esté más tiempo en aceleración máxima." .