    rdfs:label "ACCEL" .

ex:Parametro_ACCELJERK a ex:Parametro ;
    ex:textoExtracto "ACCJERK" ;
    rdfs:label "ACCJERK" .

ex:Parametro_G00FEED a ex:Parametro ;
    ex:textoExtracto "G00FEED" ;
    rdfs:label "G00FEED" .

ex:Parametro_t a ex:Parametro ;
    ex:textoExtracto "t" ;
    rdfs:label "t" .

ex:Tabla_2_6_9 a ex:Tabla ;
    ex:textoExtracto "v a j G00FEED ACCEL ACCJERK t t t t/3 t t/3 t t/3 t 3 G00FEED ACCEL ACCEL = x ACCJERK = 3 x 2 60 x 0,5 0,5" ;
    ex:detalladoEnEsquema ex:Parametro_G00FEED, ex:Parametro_ACCEL, ex:Parametro_ACCELJERK, ex:Parametro_t .