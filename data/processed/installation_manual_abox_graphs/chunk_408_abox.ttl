@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_9df2a39224 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC arranca sin gama, y nada mas arrancar se sincronizan cabezales que no tienen definido el parámetro SYNCSET." .

ns1:GamaPorDefecto a ns1:Parametro ;
    rdfs:label "Gama por defecto" ;
    ns1:identificador "DEFAULTSET" ;
    ns1:textoExtracto "El encendido y el reset no utilizan el parámetro DEFAULTSET; ambas situaciones se gestionan desde la maniobra del PLC." .

ns1:SincronizacionDeCabezal a ns1:Parametro ;
    rdfs:label "Sincronización de cabezal" ;
    ns1:identificador "SYNCSET" ;
    ns1:textoExtracto "El CNC arranca sin gama, y nada mas arrancar se sincronizan cabezales que no tienen definido el parámetro SYNCSET." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "En el encendido, el CNC pone la gama que indica el PLC; si no indica ninguna, el CNC arranca sin gama. Tras un reset, el CNC pone la gama." .

