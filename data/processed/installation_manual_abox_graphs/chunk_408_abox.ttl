PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:G0ACDCJERK
    a               ex:Parametro ;
    rdfs:label      "G0ACDCJERK" ;
    ex:identificador "G0ACDCJERK" ;
    ex:textoExtracto "G0ACDCJERK Ampliación de parámetros si G0. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPA.G0ACDCJERK[set].xn Este parámetro permite definir unos valores específicos de aceleración y jerk para los movimientos en G0." ;
    ex:valor        "No"^^xsd:string .

ex:LACC1G0
    a               ex:Parametro ;
    rdfs:label      "LACC1G0 (Aceleración lineal primer tramo en G0)" ;
    ex:identificador "LACC1G0" ;
    ex:textoExtracto "Aceleración lineal (movimientos en G0). • Aceleración del primer tramo: LACC1G0" .

ex:LACC2G0
    a               ex:Parametro ;
    rdfs:label      "LACC2G0 (Aceleración lineal segundo tramo en G0)" ;
    ex:identificador "LACC2G0" ;
    ex:textoExtracto "Aceleración lineal (movimientos en G0). • Aceleración del segundo tramo: LACC2G0" .

ex:LFEEDG0
    a               ex:Parametro ;
    rdfs:label      "LFEEDG0 (Velocidad de cambio de aceleración en G0)" ;
    ex:identificador "LFEEDG0" ;
    ex:textoExtracto "Aceleración lineal (movimientos en G0). • Velocidad de cambio de aceleración: LFEEDG0" .

ex:ACCELG0
    a               ex:Parametro ;
    rdfs:label      "ACCELG0 (Aceleración trapezoidal en G0)" ;
    ex:identificador "ACCELG0" ;
    ex:textoExtracto "Aceleración trapezoidal y seno cuadrado (movimientos en G0). • Aceleración: ACCELG0" .

ex:DECELG0
    a               ex:Parametro ;
    rdfs:label      "DECELG0 (Deceleración trapezoidal en G0)" ;
    ex:identificador "DECELG0" ;
    ex:textoExtracto "Aceleración trapezoidal y seno cuadrado (movimientos en G0). • Deceleración: DECELG0" .

ex:ACCJERKG0
    a               ex:Parametro ;
    rdfs:label      "ACCJERKG0 (Jerk de aceleración en G0)" ;
    ex:identificador "ACCJERKG0" ;
    ex:textoExtracto "Aceleración trapezoidal y seno cuadrado (movimientos en G0). • Jerk de aceleración: ACCJERKG0" .

ex:DECJERKG0
    a               ex:Parametro ;
    rdfs:label      "DECJERKG0 (Jerk de deceleración en G0)" ;
    ex:identificador "DECJERKG0" ;
    ex:textoExtracto "Aceleración trapezoidal y seno cuadrado (movimientos en G0). • Jerk de deceleración: DECJERKG0" .

ex:Tabla_ParametrosG0_208 a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de parámetros para movimientos en G0 (página 208)" ;
    ex:textoExtracto "Parámetros a utilizar en los movimientos en G0." ;
    ex:documentadoEn ex:Manual ;
    ex:tieneComponente ex:G0ACDCJERK ;
