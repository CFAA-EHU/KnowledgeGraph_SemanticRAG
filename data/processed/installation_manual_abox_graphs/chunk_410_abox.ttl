@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_LACC1G0
    a ex:Parametro ;
    rdfs:label "LACC1G0" ;
    ex:textoExtracto "El CNC aplica los parámetros LACC1G0 y LACC2G0 a los movimientos en G0." ;
    ex:identificador "LACC1G0" .

ex:Parametro_LACC2G0
    a ex:Parametro ;
    rdfs:label "LACC2G0" ;
    ex:textoExtracto "El CNC aplica los parámetros LACC1G0 y LACC2G0 a los movimientos en G0." ;
    ex:identificador "LACC2G0" .

ex:Parametro_LFEEDG0
    a ex:Parametro ;
    rdfs:label "LFEEDG0" ;
    ex:textoExtracto "LFEEDG0 Velocidad de cambio de aceleración (movimientos en G0)." ;
    ex:identificador "LFEEDG0" ;
    ex:valor "3000 mm/min / 118.11023 inch/min / 1080000 grados/min / 3000 rpm" ;
    ex:textoExtracto "Valor por defecto: 3000 mm/min / 118.11023 inch/min / 1080000 grados/min / 3000 rpm." .

ex:ModoOperacion_G0
    a ex:ModoOperacion ;
    rdfs:label "Movimiento en G0" ;
    ex:textoExtracto "El CNC aplica los parámetros LACC1G0 y LACC2G0 a los movimientos en G0." ;
    ex:identificador "G0" ;
    ex:monitoreaParametro ex:Parametro_LACC1G0 ;
    ex:monitoreaParametro ex:Parametro_LACC2G0 ;
    ex:monitoreaParametro ex:Parametro_LFEEDG0 .