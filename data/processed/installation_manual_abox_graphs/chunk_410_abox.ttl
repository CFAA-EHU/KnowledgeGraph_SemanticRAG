@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:LACC1G0 a ex:Parametro ;
    rdfs:label "LACC1G0" ;
    ex:textoExtracto "El CNC aplica los parámetros LACC1G0 y LACC2G0 a los movimientos en G0." ;
    ex:valor "Parámetro válido para ejes lineales, rotativos y cabezales." .

ex:LACC2G0 a ex:Parametro ;
    rdfs:label "LACC2G0" ;
    ex:textoExtracto "El CNC aplica los parámetros LACC1G0 y LACC2G0 a los movimientos en G0." ;
    ex:valor "Parámetro válido para ejes lineales, rotativos y cabezales." .

ex:LFEEDG0 a ex:Parametro ;
    rdfs:label "LFEEDG0" ;
    ex:textoExtracto "LFEEDG0 Velocidad de cambio de aceleración (movimientos en G0)." ;
    ex:valor "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0 a 200000.0000 mm/min. Valores posibles (2): De 0 a 7874.01575 inch/min. Valores posibles (3): De 0 a 36000000.0000 grados/min. Valores posibles (4): De 0 a 100000.0000 rpm. Valor por defecto: 3000 mm/min / 118.11023 inch/min / 1080000 grados/min / 3000 rpm." .

ex:MPA_LFEEDG0 a ex:Parametro ;
    rdfs:label "MPA.LFEEDG0[set].xn" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.LFEEDG0[set].xn" .