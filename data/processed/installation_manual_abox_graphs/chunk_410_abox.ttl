@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SetDeParametrosParaLaDinamicaDelEje a ns1:Parametro ;
    rdfs:label "Set de parámetros para la dinámica del eje" ;
    ns1:textoExtracto "Se pueden definir hasta 4 sets de parámetros distintos para indicar la dinámica del eje en cada una de ellas (avances, ganancias, aceleraciones, etc)." .

ns1:SistemaLaser a ns1:Sistema ;
    rdfs:label "Sistema Láser" ;
    ns1:textoExtracto "En el modelo láser, los parámetros relacionados con la velocidad del cabezal (definida en rpm), definen la potencia (definida en watios)." ;
    ns1:tieneComponente ns1:Parametro_1655a4a6b6,
        ns1:VelocidadDelCabezal_7ae2626d27 .

ns1:Parametro_1655a4a6b6 a ns1:Parametro ;
    rdfs:label "Potencia" ;
    ns1:textoExtracto "En el modelo láser, los parámetros relacionados con la velocidad del cabezal (definida en rpm), definen la potencia (definida en watios)." .

ns1:VelocidadDelCabezal_7ae2626d27 a ns1:Parametro ;
    rdfs:label "Velocidad del cabezal" ;
    ns1:textoExtracto "En el modelo láser, los parámetros relacionados con la velocidad del cabezal (definida en rpm), definen la potencia (definida en watios)." .

