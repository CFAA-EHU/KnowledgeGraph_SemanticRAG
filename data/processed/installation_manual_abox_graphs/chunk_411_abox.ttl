@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_AvanceTransicion
    a               ex:Parametro ;
    rdfs:label      "Parámetro de avance para transición de aceleración"@es ;
    ex:textoExtracto "cuando se alcanza el avance definido en este parámetro se cambia la aceleración de LACC2G0 a LACC1G0"@es ;
    ex:identificador "AvanceTransicion_G0" .

ex:Parametro_LACC1G0
    a               ex:Parametro ;
    rdfs:label      "LACC1G0"@es ;
    ex:textoExtracto "se cambia la aceleración de LACC1G0 a LACC2G0"@es ;
    ex:identificador "LACC1G0" .

ex:Parametro_LACC2G0
    a               ex:Parametro ;
    rdfs:label      "LACC2G0"@es ;
    ex:textoExtracto "se cambia la aceleración de LACC1G0 a LACC2G0"@es ;
    ex:identificador "LACC2G0" ;
    ex:monitoreaParametro ex:Parametro_AvanceTransicion .