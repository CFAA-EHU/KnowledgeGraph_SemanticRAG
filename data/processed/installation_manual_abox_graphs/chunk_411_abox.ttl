@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PasoDeHusillo a ns1:Parametro ;
    rdfs:label "Paso de husillo" ;
    ns1:identificador "MPA.PITCH" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Valores posibles (1): De 0 a 99999.9999 mm. Valor por defecto: 5 mm / 0.19685 inch / 360º." ;
    ns1:valor "0.19685 inch",
        "360º",
        "5 mm" .

ns1:VariableMPAPITCH a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.PITCH[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.PITCH[set].xn El significado de este parámetro depende del tipo captación." .

