@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:LACC1G0 a ex:Parametro ;
    rdfs:label "LACC1G0" ;
    ex:textoExtracto "definido en este parámetro se cambia la aceleración de LACC1G0 a LACC2G0" ;
    ex:valor "aceleración" .

ex:LACC2G0 a ex:Parametro ;
    rdfs:label "LACC2G0" ;
    ex:textoExtracto "se cambia la aceleración de LACC1G0 a LACC2G0" ;
    ex:valor "aceleración" .