@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ACCELG0 a ex:Parametro ;
    rdfs:label "ACCELG0" ;
    ex:identificador "ACCELG0" ;
    ex:textoExtracto "ACCELG0 Aceleración (movimientos en G0). Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0.0010 a 600000000.0000 mm/s². Valores posibles (2): De 0.00004 a 23622047.2440 inch/s². Valores posibles (3): De 0.0010 a 600000000.0000 grados/s². Valor por defecto: 4000.0000 mm/s² / 157.48031 inch/s² / 4000.0000 grados/s². Variable asociada: (V.)[ch].MPA.ACCELG0[set].xn" ;
    ex:valor "4000.0000 mm/s² / 157.48031 inch/s² / 4000.0000 grados/s²" .

ex:DECELG0 a ex:Parametro ;
    rdfs:label "DECELG0" ;
    ex:identificador "DECELG0" ;
    ex:textoExtracto "DECELG0 Deceleración (movimientos en G0). Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0.0010 a 600000000.0000 mm/s². Valores posibles (2): De 0.00004 a 23622047.2440 inch/s². Valores posibles (3): De 0.0010 a 600000000.0000 grados/s². Valor por defecto: 4000.0000 mm/s² / 157.48031 inch/s² / 4000.0000 grados/s². Variable asociada: (V.)[ch].MPA.DECELG0[set].xn" ;
    ex:valor "4000.0000 mm/s² / 157.48031 inch/s² / 4000.0000 grados/s²" .

ex:SLOPETYPE a ex:Parametro ;
    rdfs:label "SLOPETYPE" ;
    ex:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1, G2 y G3; los movimientos en G0 dependen del parámetro G0ACDCJERK." ;
    ex:valor "G0ACDCJERK" .