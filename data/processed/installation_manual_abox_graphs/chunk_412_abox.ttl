@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjeRotativoConReduccion110_ef6f01e5fd a ns1:Componente ;
    rdfs:label "Eje rotativo con reducción 1/10" ;
    ns1:ilustradoEn ns1:TablaTipoDeEje ;
    ns1:textoExtracto "Eje rotativo con reducción 1/10. | 36º." .

ns1:HusilloDe5Mm a ns1:Componente ;
    rdfs:label "Husillo de 5 mm" ;
    ns1:ilustradoEn ns1:TablaTipoDeEje ;
    ns1:textoExtracto "Eje con husillo de 5 mm. | 5 mm." .

ns1:ReglaFagorDePaso20M a ns1:Componente ;
    rdfs:label "Regla Fagor de paso 20 µm" ;
    ns1:ilustradoEn ns1:TablaTipoDeEje ;
    ns1:textoExtracto "Eje con regla Fagor de paso 20 µm. | 0.020 mm." .

ns1:TablaTipoDeEje a ns1:Tabla ;
    rdfs:label "Tabla Tipo de eje" ;
    ns1:textoExtracto """Tipo de eje. | PITCH
--- | ---
Eje con husillo de 5 mm. | 5 mm.
Eje con regla Fagor de paso 20 µm. | 0.020 mm.
Eje rotativo con reducción 1/10. | 36º.""" .

