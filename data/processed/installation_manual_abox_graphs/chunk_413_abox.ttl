ex:ModoOperacion_G0
    a ex:ModoOperacion ;
    rdfs:label "Movimientos en G0"@es ;
    ex:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCELG0 y DECELG0... Los parámetros ACCJERKG0 y DECJERKG0 definen la pendiente de la aceleración y deceleración."@es ;
