ex:Tabla_413_G0ACDCJERK a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros G0ACDCJERK (movimientos en G0)"@es ;
    ex:textoExtracto "G0ACDCJERK | Significado... Los parámetros ACCJERKG0 y DECJERKG0 definen la pendiente de la aceleración y deceleración."@es ;
    ex:documentadoEn ex:Pagina_210_211 .

ex:Parametro_ACCJERKG0
    a ex:Parametro ;
    rdfs:label "ACCJERKG0" ;
    ex:identificador "ACCJERKG0" ;
    ex:valor "55000.000" ;
    ex:textoExtracto "ACCJERKG0 Jerk de aceleración (movimientos en G0)... Valor por defecto: 55000.000 mm/s³ / 2165.35433 inch/s³ / 55000.000 grados/s³."@es ;
    ex:documentadoEn ex:Tabla_413_G0ACDCJERK .

ex:Parametro_DECJERKG0
    a ex:Parametro ;
    rdfs:label "DECJERKG0" ;
    ex:identificador "DECJERKG0" ;
    ex:valor "55000.000" ;
    ex:textoExtracto "DECJERKG0 Jerk de deceleración (movimientos en G0)... Valor por defecto: 55000.000 mm/s³ / 2165.35433 inch/s³ / 55000.000 grados/s³."@es ;
    ex:documentadoEn ex:Tabla_413_G0ACDCJERK .

