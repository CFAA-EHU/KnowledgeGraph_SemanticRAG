@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ParametroACCEL a ex:Parametro ;
    rdfs:label "ACCEL" ;
    ex:textoExtracto "Ambos parámetros permiten limitar los cambios de aceleración" ;
    ex:valor "ACCEL" .

ex:ParametroDECEL a ex:Parametro ;
    rdfs:label "DECEL" ;
    ex:textoExtracto "Ambos parámetros permiten limitar los cambios de aceleración" ;
    ex:valor "DECEL" .

ex:ParametroG0ACDCJERK a ex:Parametro ;
    rdfs:label "G0ACDCJERK" ;
    ex:textoExtracto "los movimientos en G0 dependen del parámetro G0ACDCJERK" ;
    ex:valor "G0ACDCJERK" .

ex:MovimientoG0 a ex:ModoOperacion ;
    rdfs:label "G0" ;
    ex:textoExtracto "los movimientos en G0 dependen del parámetro G0ACDCJERK" .

ex:MovimientoG1 a ex:ModoOperacion ;
    rdfs:label "G1" ;
    ex:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1, G2 y G3" .

ex:MovimientoG2 a ex:ModoOperacion ;
    rdfs:label "G2" ;
    ex:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1, G2 y G3" .

ex:MovimientoG3 a ex:ModoOperacion ;
    rdfs:label "G3" ;
    ex:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1, G2 y G3" .

ex:MovimientoG33 a ex:ModoOperacion ;
    rdfs:label "G33" ;
    ex:textoExtracto "El CNC no tiene en cuenta estos parámetros en los movimientos con roscado (G33)" .

ex:MovimientoHSCFAST a ex:ModoOperacion ;
    rdfs:label "HSC FAST" ;
    ex:textoExtracto "El CNC no tiene en cuenta estos parámetros en ... HSC FAST" .