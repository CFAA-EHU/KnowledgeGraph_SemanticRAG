@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BusquedaDeReferenciaInicial a ns1:Parametro ;
    rdfs:label "Búsqueda de referencia inicial" ;
    ns1:identificador "REFINI" ;
    ns1:textoExtracto "Si se definen los parámetros NPULSES y NPULSES2 con valor distinto de ꞏ0ꞏ, el parámetro REFINI establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento." .

ns1:NumeroDePulsos a ns1:Parametro ;
    rdfs:label "Número de pulsos" ;
    ns1:identificador "NPULSES" ;
    ns1:textoExtracto "Si se definen los parámetros NPULSES y NPULSES2 con valor distinto de ꞏ0ꞏ, el parámetro REFINI establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento." .

ns1:NumeroDePulsos2 a ns1:Parametro ;
    rdfs:label "Número de pulsos 2" ;
    ns1:identificador "NPULSES2" ;
    ns1:textoExtracto "Si se definen los parámetros NPULSES y NPULSES2 con valor distinto de ꞏ0ꞏ, el parámetro REFINI establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento." .

ns1:PasoDeHusilloCaptacionExterna_f752012a9c a ns1:Parametro ;
    rdfs:label "Paso de husillo (captación externa)" ;
    ns1:identificador "PITCH2" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos." ;
    ns1:valor "5 mm / 0.19685 inch" .

