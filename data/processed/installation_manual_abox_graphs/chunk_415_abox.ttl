@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PasoDeHusilloReglaONumeroDeGradosPorVueltaDeEncoder a ns1:Parametro ;
    rdfs:label "Paso de husillo, regla o número de grados por vuelta de encoder" ;
    ns1:identificador "MPA.PITCH2" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.PITCH2[set].xn El significado de este parámetro depende del tipo captación." ;
    ns1:valor "5 mm / 0.19685 inch / 360º" .

