    a ex:Parametro ;
    rdfs:label "Parámetro ACCJERKG0"@es ;
    ex:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCJERKG0 y DECJERKG0."@es ;
    ex:identificador "ACCJERKG0" ;
