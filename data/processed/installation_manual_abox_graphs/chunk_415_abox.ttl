ex:ModoOperacion_G0
    a ex:ModoOperacion ;
    rdfs:label "Modo de operación G0 (movimientos rápidos)"@es ;
    ex:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCJERKG0 y DECJERKG0. [...] Los movimientos en G0 utilizan los parámetros ACCJERK y DECJERK."@es ;
