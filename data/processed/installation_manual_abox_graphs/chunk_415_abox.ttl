ex:Tabla_G0ACDCJERK a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de aceleración/desaceleración en G0"@es ;
    ex:textoExtracto "G0ACDCJERK | Significado. [...] Los movimientos en G0 utilizan los parámetros ACCJERKG0 y DECJERKG0. [...] Los movimientos en G0 utilizan los parámetros ACCJERK y DECJERK."@es ;
    ex:identificador "G0ACDCJERK" ;
    ex:documentadoEn ex:Pagina_210_211 .

