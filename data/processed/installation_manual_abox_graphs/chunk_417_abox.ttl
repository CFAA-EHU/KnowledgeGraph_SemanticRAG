ex:Parametro_CORNERACC a ex:Parametro ;
    rdfs:label "CORNERACC" ;
    ex:identificador "CORNERACC" ;
    ex:textoExtracto "CORNERACC | Aceleración máxima permitida en las esquinas." ;
