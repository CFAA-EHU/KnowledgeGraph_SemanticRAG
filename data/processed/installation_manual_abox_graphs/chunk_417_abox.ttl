@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:CNC8070_1858a1ad83 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Con transductor lineal (regla), definir NPULSES2 Si se definen los parámetros NPULSES y NPULSES2 con valor distinto de ꞏ0ꞏ, el parámetro REFINI establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento." .

ns1:NumeroDeImpulsosDelEncoderCaptacionExterna a ns1:Parametro ;
    rdfs:label "Número de impulsos del encoder (captación externa)" ;
    ns1:identificador "MPA.NPULSES2" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos. Valores posibles: De 0 a 1000000. Valor por defecto: 1250." ;
    ns1:valor 1250 .

ns1:VueltasEjeMaquinaCaptacionExterna a ns1:Parametro ;
    rdfs:label "Vueltas eje máquina (captación externa)" ;
    ns1:identificador "MPA.OUTPUTREV2" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos. Valores posibles: De 1 a 32767. Valor por defecto: 1." ;
    ns1:valor 1 .

ns1:VueltasEjeMotorCaptacionExterna a ns1:Parametro ;
    rdfs:label "Vueltas eje motor (captación externa)" ;
    ns1:identificador "MPA.INPUTREV2" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos. Valores posibles: De 1 a 32767. Valor por defecto: 1." ;
    ns1:valor 1 .

