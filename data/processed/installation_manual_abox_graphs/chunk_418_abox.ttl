@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaResolucionContaje a ns1:Tabla ;
    rdfs:label "Tabla de resolución de contaje del eje" ;
    ns1:ilustra ns1:DefinicionDeResolucionDeContajeDelEjeParte,
        ns1:DefinicionDeResolucionDeContajeDelEjeParte_d532d62ccf,
        ns1:FactorDeMultiplicacionParaLaSenalDeCaptacionSenoidal ;
    ns1:textoExtracto "Los parámetros SINMAGNI, PITCH y NPULSES definen la resolución de contaje del eje, tal y como se muestra en la siguiente tabla." .

ns1:DefinicionDeResolucionDeContajeDelEjeParte a ns1:Parametro ;
    rdfs:label "Definición de resolución de contaje del eje (parte)" ;
    ns1:identificador "NPULSES" ;
    ns1:textoExtracto "Los parámetros SINMAGNI, PITCH y NPULSES definen la resolución de contaje del eje." .

ns1:DefinicionDeResolucionDeContajeDelEjeParte_d532d62ccf a ns1:Parametro ;
    rdfs:label "Definición de resolución de contaje del eje (parte)" ;
    ns1:identificador "PITCH" ;
    ns1:textoExtracto "Los parámetros SINMAGNI, PITCH y NPULSES definen la resolución de contaje del eje." .

ns1:FactorDeMultiplicacionParaLaSenalDeCaptacionSenoidal a ns1:Parametro ;
    rdfs:label "Factor de multiplicación para la señal de captación senoidal" ;
    ns1:identificador "SINMAGNI" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y simulado." ;
    ns1:valor "0 a 255" .

