@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_CORNERJERK a ex:Parametro ;
    rdfs:label "CORNERJERK" ;
    ex:identificador "(V.)[ch].MPA.CORNERJERK[set].xn" ;
    ex:textoExtracto "CORNERJERK Jerk máximo permitido en las esquinas. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0 a 1E+009 mm/s³. Valores posibles (2): De 0 a 39370078.74016 inch/s³. Valores posibles (3): De 0 a 1E+009 grados/s³. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.CORNERJERK[set].xn Si este parámetro se define con valor ꞏ0ꞏ, se respeta el jerk máximo del eje." ;
    ex:valor "De 0 a 1E+009 mm/s³, De 0 a 39370078.74016 inch/s³, De 0 a 1E+009 grados/s³" .

ex:Parametro_CURVJERK a ex:Parametro ;
    rdfs:label "CURVJERK" ;
    ex:textoExtracto "CURVJERK Jerk máximo permitido en curvatura. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0 a 1E+009 mm/s³." .