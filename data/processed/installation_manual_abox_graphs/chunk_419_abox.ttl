@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaResolucionCaptacion a ns1:Tabla ;
    rdfs:label "Tabla de resolución de captación" ;
    ns1:ilustra ns1:FactorDeMultiplicacionO0,
        ns1:GiroDelEjePorVueltaDelEncoderOPasoDelHusilloOPasoDelEncoder,
        ns1:NumeroDeImpulsos ;
    ns1:textoExtracto "Tipo de encóder. | PITCH | NPULSES | SINMAGNI" .

ns1:FactorDeMultiplicacionO0 a ns1:Parametro ;
    rdfs:label "Factor de multiplicación o 0" ;
    ns1:textoExtracto "Factor de multiplicación. | 0" .

ns1:GiroDelEjePorVueltaDelEncoderOPasoDelHusilloOPasoDelEncoder a ns1:Parametro ;
    rdfs:label "Giro del eje por vuelta del encoder o Paso del husillo o Paso del encoder" ;
    ns1:textoExtracto "Giro del eje por vuelta del encoder | Paso del husillo. | Paso del encoder." .

ns1:NumeroDeImpulsos a ns1:Parametro ;
    rdfs:label "Número de impulsos" ;
    ns1:textoExtracto "Número de impulsos." .

