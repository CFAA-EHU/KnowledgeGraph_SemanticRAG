@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConectorDeAlarma a ns1:ComponenteElectrico ;
    rdfs:label "Conector de alarma" ;
    ns1:activaAlarma ns1:Alarma_61bca53e46 ;
    ns1:textoExtracto "a través del pin de alarma del conector." .

ns1:Alarma_61bca53e46 a ns1:Alarma ;
    rdfs:label "Alarma de captación por hardware" ;
    ns1:habilitadoPor ns1:HabilitacionDeAlarmaDeCaptacionPorHardware ;
    ns1:textoExtracto "Esta alarma pretende habilitar la alarma de captación por hardware, a través del pin de alarma del conector." .

ns1:HabilitacionDeAlarmaDeCaptacionPorHardware a ns1:Parametro ;
    rdfs:label "Habilitación de alarma de captación por hardware" ;
    ns1:identificador "MPA.HWFBACKAL" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.HWFBACKAL[set].xn Este parámetro habilita la alarma de captación por hardware, a través del pin de alarma del conector." .

