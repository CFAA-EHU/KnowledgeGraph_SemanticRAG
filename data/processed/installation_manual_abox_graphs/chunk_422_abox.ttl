ns1:SercosVelocidadConCaptacionInternaExternaConContajesLocales_30da2d07a8 a ns1:Parametro ;
    rdfs:label "Sercos velocidad con captación interna+externa con contajes locales" ;
    ns1:habilita ns1:Alarma_7e3e818ecc ;
    ns1:textoExtracto "Este parámetro habilita la alarma de captación por hardware, a través del pin de alarma del conector." .

