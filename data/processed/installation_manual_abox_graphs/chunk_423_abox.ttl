@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BandaDeMuerte a ns1:Parametro ;
    rdfs:label "Banda de muerte" ;
    ns1:identificador "INPOSW" ;
    ns1:textoExtracto "INPOSW Banda de muerte." .

ns1:CambioDeSignoDeLaConsigna a ns1:Parametro ;
    rdfs:label "Cambio de signo de la consigna" ;
    ns1:identificador "LOOPCH" ;
    ns1:textoExtracto "LOOPCH Cambio de signo de la consigna. Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:CambioDeSignoDelContaje a ns1:Parametro ;
    rdfs:label "Cambio de signo del contaje" ;
    ns1:identificador "AXISCH" ;
    ns1:textoExtracto "AXISCH Cambio de signo del contaje. Parámetro válido para ejes lineales, rotativos y cabezales." .

