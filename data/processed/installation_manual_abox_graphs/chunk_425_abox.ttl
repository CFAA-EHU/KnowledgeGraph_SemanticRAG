@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:REFSHIFT a ex:Parametro ;
    rdfs:label "REFSHIFT" ;
    ex:textoExtracto "El valor a definir en REFSHIFT hay que medirlo sin compensación de husillo activa, ya que se considera una corrección a la cota del encoder." ;
    ex:valor "cota del encoder" .

ex:SercosPosicion a ex:ModoOperacion ;
    rdfs:label "Sercos posición" ;
    ex:textoExtracto "Cuando los ejes son Sercos posición, en la homogeneización de parámetros el CNC envía el valor del parámetro REFSHIFT al regulador para que éste lo tenga en cuenta" .

ex:REFFEED1 a ex:Parametro ;
    rdfs:label "REFFEED1" ;
    ex:textoExtracto "REFFEED1 Velocidad rápida de búsqueda de referencia. Parámetro válido para ejes lineales, rotativos y cabezales." .