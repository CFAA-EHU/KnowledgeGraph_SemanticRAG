@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_REFSHIFT
    a ex:Parametro ;
    rdfs:label "REFSHIFT" ;
    ex:textoExtracto "El valor a definir en REFSHIFT hay que medirlo sin compensación de husillo activa, ya que se considera una corrección a la cota del encoder. Cuando los ejes son Sercos posición, en la homogeneización de parámetros el CNC envía el valor del parámetro REFSHIFT al regulador para que éste lo tenga en cuenta; de esta manera, la cota del CNC y la del regulador es la misma." ;
    ex:identificador "REFSHIFT" .

ex:Parametro_REFFEED1
    a ex:Parametro ;
    rdfs:label "REFFEED1" ;
    ex:textoExtracto "REFFEED1 Velocidad rápida de búsqueda de referencia. Parámetro válido para ejes lineales, rotativos y cabezales." ;
    ex:identificador "REFFEED1" ;
    ex:valor "Velocidad rápida de búsqueda de referencia" .