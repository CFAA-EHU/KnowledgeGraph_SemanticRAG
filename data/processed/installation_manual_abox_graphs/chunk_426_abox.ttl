@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:REFFEED1 a ex:Parametro ;
    rdfs:label "REFFEED1" ;
    ex:textoExtracto "REFFEED1 Velocidad rápida de búsqueda de referencia. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0 a 200000.0000 mm/min. Valores posibles (2): De 0 a 7873.992 inch/min. Valores posibles (3): De 0 a 200000.0000 grados/min. Valores posibles (4): De 0 a 100000.0000 rpm. Valor por defecto: 1000.0000 mm/min / 39.37001 inch/min / 1000.0000 grados/min / 100.0000 rpm. Variable asociada: (V.)[ch].MPA.REFFEED1[set].xn Consultar el parámetro máquina REFFEED2." ;
    ex:valor "De 0 a 200000.0000 mm/min / De 0 a 7873.992 inch/min / De 0 a 200000.0000 grados/min / De 0 a 100000.0000 rpm" .

ex:REFFEED2 a ex:Parametro ;
    rdfs:label "REFFEED2" ;
    ex:textoExtracto "REFFEED2 Velocidad lenta de búsqueda de referencia. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0 a 200000.0000 mm/min. Valores posibles (2): De 0 a 7873.992 inch/min. Valores posibles (3): De 0 a 200000.0000 grados/min. Valores posibles (4): De 0 a 100000.0000 rpm. Valor por defecto: 100.0000 mm/min / 3.93700 inch/min / 100.0000 grados/min / 10.0000 rpm. Variable asociada: (V.)[ch].MPA.REFFEED2[set].xn" ;
    ex:valor "De 0 a 200000.0000 mm/min / De 0 a 7873.992 inch/min / De 0 a 200000.0000 grados/min / De 0 a 100000.0000 rpm" .

ex:REFPULSE a ex:Parametro ;
    rdfs:label "REFPULSE" ;
    ex:textoExtracto "REFPULSE Tipo de impulso del I0." .

ex:I0 a ex:Sensor ;
    rdfs:label "I0" ;
    ex:textoExtracto "Cuando el sistema de captación no dispone de I0 codificado la búsqueda de referencia se ejecuta al avance indicado en REFFEED1 hasta que se pulsa el micro de referencia máquina, invierte el sentido a REFFEED2 y, tras despulsar el micro, continúa al avance indicado en REFFEED2 hasta que se recibe el impulso de I0 del sistema de captación." .

ex:micro_referencia_maquina a ex:Sensor ;
    rdfs:label "micro de referencia máquina" ;
    ex:textoExtracto "Cuando el sistema de captación no dispone de I0 codificado la búsqueda de referencia se ejecuta al avance indicado en REFFEED1 hasta que se pulsa el micro de referencia máquina, invierte el sentido a REFFEED2 y, tras despulsar el micro, continúa al avance indicado en REFFEED2 hasta que se recibe el impulso de I0 del sistema de captación." .