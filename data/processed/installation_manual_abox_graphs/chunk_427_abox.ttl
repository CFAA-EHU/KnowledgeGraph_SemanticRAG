@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsignaAdicional a ns1:Parametro ;
    rdfs:label "consigna adicional" ;
    ns1:identificador "consgnA" ;
    ns1:textoExtracto "la consigna adicional se expresará en unidades del conversor D/A, admitiendo cualquier número entero entre ±32767." .

ns1:Parametro_0cd2fdc3ac a ns1:Parametro ;
    rdfs:label "32767" ;
    ns1:textoExtracto "al valor 32767, una consigna de 10 V." .

ns1:Parametro_85a18684df a ns1:Parametro ;
    rdfs:label "-32767" ;
    ns1:textoExtracto "Al valor -32767 le corresponderá una consigna de -10 V;" .

