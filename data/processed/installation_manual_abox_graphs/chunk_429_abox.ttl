@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:MAXDIFREF a ex:Parametro ;
    ex:identificador "MAXDIFREF" ;
    ex:textoExtracto "Si la diferencia es menor que MAXDIFREF" .

ex:REFPOIN a ex:Parametro ;
    ex:identificador "REFPOIN" ;
    ex:textoExtracto "poniendo la marca de PLC REFPOIN = 1" .

ex:Error3753 a ex:DiagnosticoFallo ;
    ex:identificador "3753" ;
    ex:textoExtracto "mostrará el error 3753" .

ex:SistemaCNC a ex:Sistema ;
    ex:textoExtracto "el CNC arranca con la nueva posición calculada por el encóder y pone la marca de PLC REFPOIN = 1. Si la diferencia es mayor que MAXDIFREF, el CNC arrancará con la posición guardada por el CNC en el apagado y mostrará el error 3753" .