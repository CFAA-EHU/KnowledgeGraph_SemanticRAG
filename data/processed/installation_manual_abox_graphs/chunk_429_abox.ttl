@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AplicacionDelImpulsoAdicionalDeConsigna a ns1:Parametro ;
    rdfs:label "Aplicación del impulso adicional de consigna" ;
    ns1:identificador "MPA.ACTBAKAN" ;
    ns1:textoExtracto "ACTBAKAN Aplicación del impulso adicional de consigna. Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:DistanciaDeCorteDelPicoDeHolgura a ns1:Parametro ;
    rdfs:label "Distancia de corte del pico de holgura" ;
    ns1:identificador "MPA.PEAKDISP" ;
    ns1:textoExtracto "PEAKDISP Distancia de corte del pico de holgura. Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:DuracionDelImpulsoAdicionalDeConsigna a ns1:Parametro ;
    rdfs:label "Duración del impulso adicional de consigna" ;
    ns1:identificador "MPA.BAKTIME" ;
    ns1:textoExtracto "BAKTIME Duración del impulso adicional de consigna. Parámetro válido para ejes lineales, rotativos y cabezales." .

