@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_c731efbd25 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro cuando trabaja con impulso adicional de consigna" .

ns1:DistanciaRealRecorridaPorElEjeDespuesDeLaInversionDeMovimientoTeorica a ns1:Parametro ;
    rdfs:label "Distancia real recorrida por el eje después de la inversión de movimiento teórica" ;
    ns1:identificador "MPA.PEAKDISP" ;
    ns1:textoExtracto "Parámetro PEAKDISP define la distancia real recorrida por el eje, después de la inversión de movimiento teórica" ;
    ns1:valor "0.0050 mm / 0.00020 inch / 0.0050 grados" .

