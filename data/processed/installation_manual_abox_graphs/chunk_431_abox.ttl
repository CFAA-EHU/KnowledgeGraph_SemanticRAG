@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ParametroPersonalizadoPosicionCNC a ex:Parametro ;
    rdfs:label "Parámetro personalizado para mostrar posición respecto al cero máquina (OM)" ;
    ex:textoExtracto "Para que el CNC muestre la posición respecto al cero máquina (OM) es necesario personalizar este parámetro con la posición" .

ex:PosicionCeroMaquina a ex:ModoOperacion ;
    rdfs:label "Cero máquina (OM)" ;
    ex:textoExtracto "cero máquina (OM)" .

ex:PosicionCeroCristal a ex:ModoOperacion ;
    rdfs:label "Cero del cristal (OG)" ;
    ex:textoExtracto "cero del cristal (OG)" .