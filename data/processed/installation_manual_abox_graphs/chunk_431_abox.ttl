@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DistanciaRealRecorridaPorElEjeDespuesDeLaInversionDeMovimientoTeorica_164a9d2064 a ns1:Parametro ;
    rdfs:label "Distancia real recorrida por el eje después de la inversión de movimiento teórica" ;
    ns1:identificador "PEAKDISP" ;
    ns1:textoExtracto "El parámetro PEAKDISP define la distancia real recorrida por el eje, después de la inversión de movimiento teórica, a la que el CNC corta el pico de inversión en dicho eje (impulso adicional de consigna)." .

ns1:ImpulsoAdicionalDeConsigna_7120dfd06b a ns1:Parametro ;
    rdfs:label "Impulso adicional de consigna" ;
    ns1:identificador "BAKANOUT" ;
    ns1:textoExtracto "parámetro BAKANOUT distinto de cero." .

