@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_CeroMaquina_431
    a               ex:Parametro ;
    rdfs:label      "Parámetro de cero máquina (OM)"@es ;
    ex:textoExtracto "Para que el CNC muestre la posición respecto al cero máquina (OM) es necesario personalizar este parámetro con la posición"@es ;
    ex:identificador "OM" .

ex:Parametro_CeroCristal_431
    a               ex:Parametro ;
    rdfs:label      "Cero del cristal (OG)"@es ;
    ex:textoExtracto "Tras leer dos I0 codificados seguidos (separados 20 ó 100 mm) se conoce la posición de la máquina respecto al cero del cristal (OG)"@es ;
    ex:identificador "OG" .

ex:Sistema_CNC_431
    a               ex:Sistema ;
    rdfs:label      "Sistema CNC de posicionamiento"@es ;
    ex:textoExtracto "Para que el CNC muestre la posición respecto al cero máquina (OM)"@es ;
    ex:monitoreaParametro ex:Parametro_CeroMaquina_431 ;
    ex:monitoreaParametro ex:Parametro_CeroCristal_431 .