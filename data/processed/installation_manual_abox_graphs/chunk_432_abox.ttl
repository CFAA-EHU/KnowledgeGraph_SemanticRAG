@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:OrdenParaFinDeHolguraCompensacionDePosicion a ns1:Parametro ;
    rdfs:label "Orden para fin de holgura (compensación de posición)"@es ;
    ns1:identificador "BAKANOUT" ;
    ns1:textoExtracto "\"Orden para fin de holgura (co que el eje ha indicada en el [m]\""@es .

ns1:OrdenParaIniciarLaCompensacionDeHolguraAmplitudDelParametroDePosicion a ns1:Parametro ;
    rdfs:label "Orden para iniciar la compensación de holgura. Amplitud del parámetro de posición."@es ;
    ns1:identificador "BAKANIN" ;
    ns1:textoExtracto "\"Orden para iniciar la compensación de holgura. Amplitud del parametriza de posición.\""@es .

