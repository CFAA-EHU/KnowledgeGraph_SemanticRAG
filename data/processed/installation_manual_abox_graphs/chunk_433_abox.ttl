@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:FOX ex:textoExtracto """El transductor lineal Fagor "FOX" dispone de un periodo de gramaje del cristal de 100 µm y de un periodo de señal de contaje de 4 µm.""" ;
    a ex:Sensor ;
    ex:identificador "FOX" ;
    ex:valor "100 µm (periodo de gramaje), 4 µm (periodo de señal de contaje)" .

ex:EncoderRotativo_HOSO90000 ex:textoExtracto """HO SO 90.000 imp ulsos.""" ;
    a ex:ComponenteElectrico ;
    ex:identificador "HO SO 90.000 imp" ;
    ex:valor "90000 impulsos" .

ex:EncoderRotativo_HOSO180000 ex:textoExtracto """HO SO 180.000 im pulsos.""" ;
    a ex:ComponenteElectrico ;
    ex:identificador "HO SO 180.000 im" ;
    ex:valor "180000 impulsos" .

ex:EncoderRotativo_HOPSOP18000 ex:textoExtracto """HOP SOP 18.000 imp ulsos.""" ;
    a ex:ComponenteElectrico ;
    ex:identificador "HOP SOP 18.000 imp" ;
    ex:valor "18000 impulsos" .

ex:Parametro_I0CODDI1 ex:textoExtracto """I0CODDI1 Paso entre 2 I0 codificados fijos. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 65535. Valor por defecto: 1000. Variable asociada: (V.)[ch].MPA.I0CODDI1[set].xn Consultar el parámetro máquina I0CODDI2.""" ;
    a ex:Parametro ;
    ex:identificador "I0CODDI1" ;
    ex:valor "0 a 65535 (rango), 1000 (por defecto)" .

ex:Parametro_I0CODDI2 ex:textoExtracto """I0CODDI2 Paso entre 2 I0 codificados variables. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 65535. Valor por defecto: 1001. Variable asociada: (V.)[ch].MPA.I0CODDI2[set].xn El CNC sólo tiene en cuenta este parámetro con I0TYPE = Codificado. El paso entre los I0 se define en número de ondas.""" ;
    a ex:Parametro ;
    ex:identificador "I0CODDI2" ;
    ex:valor "0 a 65535 (rango), 1001 (por defecto)" .

ex:Esquema_EncodersFagor ex:textoExtracto """| Encoder rotativo. |  | EXTMULT |
| --- | --- | --- |
| HO SO 90.000 imp ulsos. |  | 5 |
| HO SO 180.000 im pulsos. |  | 10 |
| HOP SOP 18.000 imp ulsos. |  | 1 |""" ;
    a ex:Esquema ;
    ex:tieneComponente ex:EncoderRotativo_HOSO90000, ex:EncoderRotativo_HOSO180000, ex:EncoderRotativo_HOPSOP18000 .