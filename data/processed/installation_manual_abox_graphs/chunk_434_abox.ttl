@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CompensacionDeHolguraConImpulsoAdicionalDeConsigna a ns1:TareaMantenimiento ;
    rdfs:label "Compensación de holgura con impulso adicional de consigna" ;
    ns1:textoExtracto "En el caso de que se tengan ejes definidos como visualizador, en estos ejes se tendrá en cuenta el valor del parámetro BACKLASH." .

ns1:ValorDeREVEHYSTParaAplicarElBacklash a ns1:Parametro ;
    rdfs:label "Valor de REVEHYST para aplicar el backlash" ;
    ns1:identificador "REVEHYST" ;
    ns1:solucionaFallo ns1:FalloCompensacionHolgura ;
    ns1:textoExtracto "se recomienda tener un valor REVEHYST distinto de 0, para aplicar el backlash." .

ns1:ValorDelParametroBACKLASH a ns1:Parametro ;
    rdfs:label "Valor del parámetro BACKLASH" ;
    ns1:solucionaFallo ns1:FalloCompensacionHolgura ;
    ns1:textoExtracto "En estos ejes se tendrá en cuenta el valor del parámetro BACKLASH." .

ns1:FalloCompensacionHolgura a ns1:DiagnosticoFallo ;
    rdfs:label "Fallo en la compensación de holgura" ;
    ns1:textoExtracto "Si REVEHYST= 0.0005 mm, el CNC no activará la compensación en las inversiones posteriores a la primera mientras la posición del" .

