@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_1001 a ex:Parametro ;
    rdfs:label "I0CODDI2[set].xn" ;
    ex:identificador "1001" ;
    ex:textoExtracto "Valor por defecto: 1001. Variable asociada: (V.)[ch].MPA.I0CODDI2[set].xn" .

ex:Parametro_1000 a ex:Parametro ;
    rdfs:label "I0CODDI1" ;
    ex:identificador "1000" ;
    ex:textoExtracto "Valores que se deben asignar para los encóder Fagor con señal I0 codificada." .

ex:Esquema_2_6_14 a ex:Esquema ;
    ex:textoExtracto "Valor por defecto: 1001. Variable asociada: (V.)[ch].MPA.I0CODDI2[set].xn El CNC sólo tiene en cuenta este parámetro con I0TYPE = Codificado. El paso entre los I0 se define en número de ondas. | Ejemplo con encóder lineal Fagor. |  |  | Paso entre I0 fijos | 20.000 mm | | Paso entre I0 variables | 20.020 mm | | Periodo de señal senoidal | 20 µm | | Número de ondas entre I0 fijos | 20000/(20 x EXTMULT) = 1000 | | Número de ondas entre I0 variables | 20020/(20 x EXTMULT) = 1001 | Valores que se deben asignar para los encóder Fagor con señal I0 codificada. | Encoder rotativo. |  |  | I0CODDI1 | I0CODDI2 | | HO | SO | 90.000 impulsos. | 1000 | 1001 | | HO | SO | 180.000 impulsos. | 1000 | 1001 | | HOP | SOP | 18.000 impulsos. | 1000 | 1001 |" ;
    ex:tieneComponente ex:Parametro_1000, ex:Parametro_1001 .