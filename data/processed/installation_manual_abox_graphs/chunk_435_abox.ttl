@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_8630088267 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "el CNC no activará la compensación en las inversiones posteriores a la primera mientras la posición del eje no varíe al menos el valor definido en este parámetro." .

ns1:CancelacionDeLaCompensacionDeHolgura a ns1:Parametro ;
    rdfs:label "Cancelación de la compensación de holgura" ;
    ns1:identificador "REVEHYST" ;
    ns1:textoExtracto "Si REVEHYST= 0.0005 mm, el CNC no activará la compensación en las inversiones posteriores a la primera mientras la posición del eje no varíe al menos el valor definido en este parámetro." ;
    ns1:valor "0.0005 mm" .

