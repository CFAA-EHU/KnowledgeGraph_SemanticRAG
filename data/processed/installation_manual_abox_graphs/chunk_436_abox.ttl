@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceEnG00 a ns1:Parametro ;
    rdfs:label "Avance en G00" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Valores posibles (1): De 0 a 500000.0000 mm/min." .

ns1:MaximoAvanceDeMecanizadoDelEje_b70d284b41 a ns1:Parametro ;
    rdfs:label "Máximo avance de mecanizado del eje" ;
    ns1:identificador "MAXFEED" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:VariablePLCG00FEED a ns1:Parametro ;
    rdfs:label "Variable PLC.G00FEED" ;
    ns1:identificador "PLC.G00FEED" ;
    ns1:textoExtracto "El PLC dispone de la variable (V.)[ch].PLC.G00FEED que permite limitar el avance en el canal para cualquier tipo de movimiento (G00, G01, etc)." .

