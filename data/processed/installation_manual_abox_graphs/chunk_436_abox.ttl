@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MPA_MINFLWE_set_xn a ex:Parametro ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.MINFLWE[set].xn" ;
    ex:identificador "[ch].MPA.MINFLWE[set].xn" .

ex:Parametro_FLWEMONITOR a ex:Parametro ;
    ex:textoExtracto "El CNC sólo tiene en cuenta este parámetro con FLWEMONITOR" ;
    rdfs:label "FLWEMONITOR" .