@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MINFLWE a ex:Parametro ;
    rdfs:label "MINFLWE" ;
    ex:identificador "(V.)[ch].MPA.MINFLWE[set].xn" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.MINFLWE[set].xn El CNC sólo tiene en cuenta este parámetro con FLWEMONITOR distinto de OFF. Este parámetro indica el máximo error de seguimiento permitido cuando el eje está parado." ;
    ex:valor "De 0.001 a 99999.9999 grados. Valor por defecto: 1.0000 mm / 0.03937 inch / 1.0000 grados." .

ex:MAXFLWE a ex:Parametro ;
    rdfs:label "MAXFLWE" ;
    ex:identificador "(V.)[ch].MPA.MAXFLWE[set].xn" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.MAXFLWE[set].xn El CNC sólo tiene en cuenta este parámetro con FLWEMONITOR distinto de OFF. El significado de este parámetro depende del valor de FLWEMONITOR. • Con FLWEMONITOR = Standard, MAXFLWE indica el máximo error de seguimiento permitido cuando el eje está en movimiento. • Con FLWEMONITOR = Lineal, MAXFLWE indica a partir de qué valor del error de seguimiento comienza la supervisión dinámica." ;
    ex:valor "Valores posibles (1): De 0.001 a 99999.9999 mm. Valores posibles (2): De 0.001 a 3937.00787 inch. Valores posibles (3): De 0.001 a 99999.9999 grados. Valor por defecto: 30.0000 mm / 1.18110 inch / 30.0000 grados." .

ex:FEDYNFAC a ex:Parametro ;
    rdfs:label "FEDYNFAC" ;
    ex:identificador "(V.)[ch].MPA.FEDYNFAC[set].xn" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.FEDYNFAC[set].xn El CNC sólo tiene en cuenta este parámetro con FLWEMONITOR distinto de OFF." ;
    ex:valor "Valores posibles: De 0 a 100 %. Valor por defecto: 50." .