@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaximoAvanceDeMecanizadoDelEje a ns1:Parametro ;
    rdfs:label "Máximo avance de mecanizado del eje" ;
    ns1:identificador "MPA.MAXFEED" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:VariableAsociadaMAXFEED a ns1:Parametro ;
    rdfs:label "(V.)[ch].MPA.MAXFEED[set].xn" ;
    ns1:identificador "V.MPA.MAXFEED" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.MAXFEED[set].xn" .

