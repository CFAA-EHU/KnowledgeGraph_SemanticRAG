@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceMaximoDeMecanizado a ns1:Parametro ;
    rdfs:label "Avance máximo de mecanizado" ;
    ns1:identificador "MPA.MAXFEED" ;
    ns1:textoExtracto "Este parámetro establece el avance máximo de mecanizado (movimientos en G01/G02/G03) del eje;" .

ns1:AvanceRapidoG00 a ns1:Parametro ;
    rdfs:label "Avance rápido G00" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "Este parámetro no se podrá definir con un valor superior al del parámetro G00FEED." .

ns1:CNC8070_26c4f419df a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "el CNC limita el avance al valor definido en MAXFEED sin mostrar ningún error ni warning." .

