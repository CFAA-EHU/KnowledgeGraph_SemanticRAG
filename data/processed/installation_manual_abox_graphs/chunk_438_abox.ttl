@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_FEDYNFAC
    a ex:Parametro ;
    rdfs:label "Parámetro FEDYNFAC (Factor de error dinámico de seguimiento)"@es ;
    ex:textoExtracto "Parámetro válido para regulador analógico y Sercos. Valores posibles: De 0 a 100 %. Valor por defecto: 50. Variable asociada: (V.)[ch].MPA.FEDYNFAC[set].xn [...] Este parámetro indica el error porcentual permitido; es decir, la desviación del error de seguimiento real respecto al teórico."@es ;
    ex:identificador "FEDYNFAC" ;
    ex:valor "50"^^xsd:integer .

ex:Parametro_MAXFLWE
    a ex:Parametro ;
    rdfs:label "Parámetro MAXFLWE (Umbral de error de seguimiento)"@es ;
    ex:textoExtracto "El parámetro MAXFLWE indica a partir de qué valor del error de [...]"@es ;
    ex:identificador "MAXFLWE" .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC (Control Numérico Computarizado)"@es ;
    ex:textoExtracto "El CNC sólo tiene en cuenta este parámetro con FLWEMONITOR distinto de OFF. El CNC calcula, en función del avance (F), el error de seguimiento (Fe) máximo y mínimo permitido en cada momento."@es ;
    ex:monitoreaParametro ex:Parametro_FEDYNFAC ;
    ex:monitoreaParametro ex:Parametro_MAXFLWE .

ex:Figura_BandaErrorSeguimiento
    a ex:Figura ;
    rdfs:label "Banda de error de seguimiento (zona sombreada)"@es ;
    ex:textoExtracto "Si no está dentro de la banda permitida (zona sombreada en la figura) se muestra el error correspondiente."@es ;
    ex:ilustradoEn ex:Sistema_CNC .