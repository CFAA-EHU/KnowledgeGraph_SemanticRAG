@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_MAXFLWE a ex:Parametro ;
    rdfs:label "MAXFLWE" ;
    ex:identificador "MAXFLWE" ;
    ex:textoExtracto "Parámetro válido para regulador analógico y Sercos. Valores posibles: De 0 a 100 %. Valor por defecto: 50. Variable asociada: (V.)[ch].MPA.FEDYNFAC[set].xn El CNC sólo tiene en cuenta este parámetro con FLWEMONITOR distinto de OFF. Este parámetro indica el error porcentual permitido; es decir, la desviación del error de seguimiento real respecto al teórico. El CNC calcula, en función del avance (F), el error de seguimiento (Fe) máximo y mínimo permitido en cada momento. Si no está dentro de la banda permitida (zona sombreada en la figura) se muestra el error correspondiente. El parámetro MAXFLWE indica a partir de qué valor del error de" ;
    ex:valor "0 a 100 %" .

ex:Parametro_FLWEMONITOR a ex:Parametro ;
    rdfs:label "FLWEMONITOR" ;
    ex:identificador "FLWEMONITOR" ;
    ex:textoExtracto "Parámetro válido para regulador analógico y Sercos. Valores posibles: De 0 a 100 %. Valor por defecto: 50. Variable asociada: (V.)[ch].MPA.FEDYNFAC[set].xn El CNC sólo tiene en cuenta este parámetro con FLWEMONITOR distinto de OFF. Este parámetro indica el error porcentual permitido; es decir, la desviación del error de seguimiento real respecto al teórico. El CNC calcula, en función del avance (F), el error de seguimiento (Fe) máximo y mínimo permitido en cada momento. Si no está dentro de la banda permitida (zona sombreada en la figura) se muestra el error correspondiente. El parámetro MAXFLWE indica a partir de qué valor del error de" .

ex:Sistema_CNC a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "El CNC calcula, en función del avance (F), el error de seguimiento (Fe) máximo y mínimo permitido en cada momento." .

ex:Parametro_F a ex:Parametro ;
    rdfs:label "F" ;
    ex:identificador "F" ;
    ex:textoExtracto "El CNC calcula, en función del avance (F), el error de seguimiento (Fe) máximo y mínimo permitido en cada momento." .

ex:Parametro_Fe a ex:Parametro ;
    rdfs:label "Fe" ;
    ex:identificador "Fe" ;
    ex:textoExtracto "El CNC calcula, en función del avance (F), el error de seguimiento (Fe) máximo y mínimo permitido en cada momento." .