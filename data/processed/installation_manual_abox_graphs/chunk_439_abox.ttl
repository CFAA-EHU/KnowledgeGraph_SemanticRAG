@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceRapidoG00_5cea808a37 a ns1:Parametro ;
    rdfs:label "Avance rápido G00" ;
    ns1:textoExtracto "(V.)PLC.G00FEED | G00FEED (eje) | MAXFEED (eje)" .

ns1:ConsignaParaAlcanzarG00FEED a ns1:Parametro ;
    rdfs:label "Consigna para alcanzar G00FEED" ;
    ns1:identificador "MAXVOLT" ;
    ns1:textoExtracto "MAXVOLT Consigna para alcanzar G00FEED. Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:FrecuenciaNecesariaParaAlcanzarG00FEED a ns1:Parametro ;
    rdfs:label "Frecuencia necesaria para alcanzar G00FEED" ;
    ns1:identificador "MAXFREQ" ;
    ns1:textoExtracto "MAXFREQ Frecuencia necesaria para alcanzar G00FEED. Parámetro válido para cabezales." .

ns1:RevolucionesMaximasDelMotor_61b781bd28 a ns1:Parametro ;
    rdfs:label "Revoluciones máximas del motor" ;
    ns1:identificador "MAXRPM" ;
    ns1:textoExtracto "MAXRPM Revoluciones máximas del motor. Parámetro válido para ejes lineales, rotativos y cabezales." .

