@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:RevolucionesMaximasDelMotor_04919af231 a ns1:Parametro ;
    rdfs:label "Revoluciones máximas del motor" ;
    ns1:identificador "MPA.MAXRPM" ;
    ns1:textoExtracto "MAXRPM Revoluciones máximas del motor. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para Mechatrolink velocidad e Inverter. Valores posibles: De 0 a 100000 rpm. Valor por defecto: 3000 rpm." ;
    ns1:valor "3000 rpm"^^xsd:string .

