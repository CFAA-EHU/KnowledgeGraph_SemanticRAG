@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceDeEjeEnG00 a ns1:Parametro ;
    rdfs:label "Avance de eje en G00" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "Este parámetro deberá ser siempre menor que el parámetro de eje G00FEED." .

ns1:AvanceMaximoDelCanal a ns1:Parametro ;
    rdfs:label "Avance máximo del canal" ;
    ns1:identificador "MAXFEED" ;
    ns1:textoExtracto "El avance rápido no podrá superar al definido en los parámetros G00FEED del eje ni FRAPIDEN del canal, ni tampoco al avance máximo fijado por PLC." .

ns1:AvanceRapidoDelEje_bdc7400ae5 a ns1:Parametro ;
    rdfs:label "Avance rápido del eje" ;
    ns1:identificador "FRAPIDEN" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:VariableMPAFRAPIDEN a ns1:Parametro ;
    rdfs:label "Avance máximo del eje para el programa en ejecución" ;
    ns1:identificador "MPA.FRAPIDEN" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.FRAPIDEN[set].xn Avance máximo del eje para el programa en ejecución." .

ns1:VariablePLCF a ns1:Parametro ;
    rdfs:label "Avance activo definido por PLC" ;
    ns1:identificador "PLC.F" ;
    ns1:textoExtracto "El avance rápido no podrá superar al definido en los parámetros G00FEED del eje ni FRAPIDEN del canal, ni tampoco al avance máximo fijado por PLC (variable (V.)PLC.G00FEED)." .

ns1:VariablePLCG00FEED a ns1:Parametro ;
    rdfs:label "Avance de eje G00 definido por PLC" ;
    ns1:identificador "PLC.G00FEED" ;
    ns1:textoExtracto "El avance rápido no podrá superar al definido en los parámetros G00FEED del eje ni FRAPIDEN del canal, ni tampoco al avance máximo fijado por PLC (variable (V.)PLC.G00FEED)." .

