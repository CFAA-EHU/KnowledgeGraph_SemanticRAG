@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceRapidoDelCanal a ns1:Parametro ;
    rdfs:label "Avance rápido del canal" ;
    ns1:identificador "PLC.G00FEED" ;
    ns1:textoExtracto "El avance rápido podrá superar al definido en el parámetro MAXFEED del canal y al avance activo definido por PLC (variable (V.)PLC.F)." .

ns1:AvanceRapidoDelEje_6d5c551e99 a ns1:Parametro ;
    rdfs:label "Avance rápido del eje" ;
    ns1:identificador "G00FEED" ;
    ns1:textoExtracto "(V.)PLC.G00FEED | G00FEED (eje)" .

ns1:AvanceRapidoDelEje_bdc7400ae5 a ns1:Parametro ;
    rdfs:label "Avance rápido del eje" ;
    ns1:identificador "FRAPIDEN" ;
    ns1:textoExtracto "(V.)PLC.G00FEED | G00FEED (eje) | FRAPIDEN (eje)" .

