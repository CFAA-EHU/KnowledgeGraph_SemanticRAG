@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MODUPLIM
    a ex:Parametro ;
    rdfs:label "Límite superior del módulo (MODUPLIM)" ;
    ex:textoExtracto "MODUPLIM Límite superior del módulo. Parámetro válido para ejes rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Entre ±99999.9999º. Valor por defecto: 360." ;
    ex:valor "360" ;
    ex:identificador "MODUPLIM" .

ex:Parametro_MODLOWLIM
    a ex:Parametro ;
    rdfs:label "Límite inferior del módulo (MODLOWLIM)" ;
    ex:textoExtracto "MODLOWLIM Límite inferior del módulo. Parámetro válido para ejes rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0." ;
    ex:valor "0" ;
    ex:identificador "MODLOWLIM" .

ex:Parametro_MODNROT
    a ex:Parametro ;
    rdfs:label "Error de módulo: Número de vueltas (MODNROT)" ;
    ex:textoExtracto "MODNROT Error de módulo. Número de vueltas. Parámetro válido para ejes rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 1 a 32767 vueltas. Valor por defecto: 1." ;
    ex:valor "1" ;
    ex:identificador "MODNROT" .

ex:Parametro_MODERR
    a ex:Parametro ;
    rdfs:label "Error de módulo: Número de incrementos (MODERR)" ;
    ex:textoExtracto "MODERR Error de módulo. Número de incrementos. Parámetro válido para ejes rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Entre ±32767. Valor por defecto: 0." ;
    ex:valor "0" ;
    ex:identificador "MODERR" .

ex:Parametro_AXISMODE
    a ex:Parametro ;
    rdfs:label "Modo de eje (AXISMODE)" ;
    ex:textoExtracto "El CNC sólo tiene en cuenta estos parámetros con AXISMODE = Módulo." ;
    ex:identificador "AXISMODE" .

ex:Parametro_MODCOMP
    a ex:Parametro ;
    rdfs:label "Compensación de módulo (MODCOMP)" ;
    ex:textoExtracto "EL CNC sólo tiene en cuenta estos parámetros con AXISMODE = Módulo y MODCOMP = Sí." ;
    ex:identificador "MODCOMP" .

ex:Sistema_ModuloEjesRotativos
    a ex:Sistema ;
    rdfs:label "Sistema de configuración de módulo para ejes rotativos y cabezales" ;
    ex:textoExtracto "Configuración del módulo (ejes rotativos y cabezales)." ;
    ex:tieneComponente ex:Parametro_MODUPLIM ;
    ex:tieneComponente ex:Parametro_MODLOWLIM ;
    ex:tieneComponente ex:Parametro_MODNROT ;
    ex:tieneComponente ex:Parametro_MODERR ;
    ex:tieneComponente ex:Parametro_AXISMODE ;
    ex:tieneComponente ex:Parametro_MODCOMP .