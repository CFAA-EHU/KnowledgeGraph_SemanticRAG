@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MODERR
    a ex:Parametro ;
    rdfs:label "Parámetro MODERR"@es ;
    ex:textoExtracto "El parámetro MODERR indica el error que hay que compensar cuando el eje ha girado las vueltas indicadas en el parámetro MODNROT."@es ;
    ex:identificador "MODERR" .

ex:Parametro_MODNROT
    a ex:Parametro ;
    rdfs:label "Parámetro MODNROT"@es ;
    ex:textoExtracto "el parámetro MODNROT [...] las vueltas indicadas en el parámetro MODNROT."@es ;
    ex:identificador "MODNROT" .

ex:Sistema_CompensacionModulo
    a ex:Sistema ;
    rdfs:label "Sistema de compensación de módulo (ejes rotativos)"@es ;
    ex:textoExtracto "Estos parámetros indican, cuando la resolución del eje no es exacta, la compensación que se debe aplicar para obtener un contaje exacto. El CNC aplica la compensación de módulo a lo largo de toda la vuelta."@es ;
    ex:tieneComponente ex:Parametro_MODERR ;
    ex:tieneComponente ex:Parametro_MODNROT .