@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
ex:Parametro_MODERR rdfs:label "MODERR" ;
    a ex:Parametro ;
    ex:textoExtracto "El parámetro MODERR indica el error que hay que compensar cuando el eje ha girado las vueltas indicadas en el parámetro MODNROT."@es .

ex:Parametro_MODNROT rdfs:label "MODNROT" ;
    a ex:Parametro ;
    ex:textoExtracto "El parámetro MODNROT indica las vueltas que ha girado el eje."@es .

ex:Sistema_CNC rdfs:label "CNC" ;
    a ex:Sistema ;
    ex:textoExtracto "El CNC aplica la compensación de módulo a lo largo de toda la vuelta."@es .

ex:ComponenteElectrico_Encoder rdfs:label "encoder de 1024 impulsos" ;
    a ex:ComponenteElectrico ;
    ex:textoExtracto "cuando se usa un encoder de 1024 impulsos parametrizado a 1000 impulsos."@es .