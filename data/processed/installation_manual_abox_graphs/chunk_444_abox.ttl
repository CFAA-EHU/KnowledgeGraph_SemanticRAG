@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FeedForwardGain a ns1:Parametro ;
    rdfs:label "Feed Forward Gain" ;
    ns1:identificador "MPA.FFGAIN" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.FFGAIN[set].xn" .

ns1:FeedForwardType a ns1:Parametro ;
    rdfs:label "Feed Forward Type" ;
    ns1:textoExtracto "parámetro FFWTYPE si regulador analógico o simulado" .

ns1:OperationalModeParameter a ns1:Parametro ;
    rdfs:label "Operational Mode Parameter" ;
    ns1:textoExtracto "parámetro OPMODEP si regulador Sercos" .

