@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AjusteOptimo a ns1:TareaMantenimiento ;
    rdfs:label "Ajuste óptimo del Feed Forward Gain" ;
    ns1:solucionaFallo ns1:ErrorDeSeguimiento_8af2712235 ;
    ns1:textoExtracto "El ajuste óptimo se consigue cuando se minimiza el error de seguimiento al máximo sin invertir su signo, manteniendo el sentido de movimiento del eje." .

ns1:FeedForwardGain_fd02dc121e a ns1:Parametro ;
    rdfs:label "Feed Forward Gain" ;
    ns1:identificador "FFGAIN" ;
    ns1:textoExtracto "los parámetros FFGAIN y MANFFGAIN deberían ser iguales. Este parámetro permite mejorar el lazo de posición minimizando el error de seguimiento \"\"." .

ns1:ManualFeedForwardGain a ns1:Parametro ;
    rdfs:label "Manual Feed Forward Gain" ;
    ns1:identificador "MANFFGAIN" ;
    ns1:textoExtracto "los parámetros FFGAIN y MANFFGAIN deberían ser iguales. Este parámetro permite mejorar el lazo de posición minimizando el error de seguimiento \"\"." .

ns1:ErrorDeSeguimiento_8af2712235 a ns1:DiagnosticoFallo ;
    rdfs:label "Error de seguimiento" ;
    ns1:textoExtracto "Este parámetro permite mejorar el lazo de posición minimizando el error de seguimiento \"\"." .

