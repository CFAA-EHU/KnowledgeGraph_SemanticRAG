@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_POLARM3 a ex:Parametro ;
    rdfs:label "POLARM3" ;
    ex:textoExtracto "Los parámetros POLARM3 y POLARM4 indican el signo de la consigna para las funciones M3 y M4 respectivamente." ;
    ex:valor "Positivo" .

ex:Parametro_POLARM4 a ex:Parametro ;
    rdfs:label "POLARM4" ;
    ex:textoExtracto "Los parámetros POLARM3 y POLARM4 indican el signo de la consigna para las funciones M3 y M4 respectivamente." ;
    ex:valor "Positivo" .

ex:Variable_V_CH_A_POLARITY_SN a ex:Parametro ;
    rdfs:label "V.[ch].A.POLARITY.sn" ;
    ex:textoExtracto "Esta variable permite invertir el significado de los parámetros POLARM3 y POLARM4. La variable no modifica los valores de los parámetros máquina." .

ex:Variable_V_CH_SP_POLARITY_SN a ex:Parametro ;
    rdfs:label "V.[ch].SP.POLARITY.sn" ;
    ex:textoExtracto "Esta variable permite invertir el significado de los parámetros POLARM3 y POLARM4. La variable no modifica los valores de los parámetros máquina." .