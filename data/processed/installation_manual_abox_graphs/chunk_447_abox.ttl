@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SERVOOFF a ex:Parametro ;
    rdfs:label "SERVOOFF" ;
    ex:textoExtracto "SERVOOFF Compensación del offset. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico. Valores posibles: Entre ±32767. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.SERVOOFF[set].xn Consigna que se aplica como offset al regulador. La consigna se expresa en unidades del conversor D/A, admitiendo cualquier número entero entre ±32767, correspondiendo para el valor ±32767 la consigna de ±10 V." ;
    ex:valor "Entre ±32767" ;
    ex:identificador "(V.)[ch].MPA.SERVOOFF[set].xn" .

ex:MINANOUT a ex:Parametro ;
    rdfs:label "MINANOUT" ;
    ex:textoExtracto "MINANOUT Consigna mínima. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico. Valores posibles: De 0 a 32767. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.MINANOUT[set].xn La consigna se expresa en unidades del conversor D/A, admitiendo cualquier número entero entre 0 y 32767, correspondiendo para el valor 32767 la consigna de 10 V." ;
    ex:valor "De 0 a 32767" ;
    ex:identificador "(V.)[ch].MPA.MINANOUT[set].xn" .

ex:ReguladorAnalogico a ex:Sistema ;
    rdfs:label "regulador analógico" ;
    ex:textoExtracto "Parámetro válido para regulador analógico." .

ex:TablaSERVOOFF a ex:Tabla ;
    rdfs:label "Tabla SERVOOFF" ;
    ex:textoExtracto "| SERVOOFF | Consigna. |" ;
    ex:compuestoPor ex:SERVOOFF, ex:ValorMenos32767SERVOOFF, ex:ValorMenos3277SERVOOFF, ex:Valor1SERVOOFF, ex:Valor3277SERVOOFF, ex:Valor32767SERVOOFF .

ex:ValorMenos32767SERVOOFF a ex:Parametro ;
    rdfs:label "-32767" ;
    ex:textoExtracto "-32767" ;
    ex:valor "-10 V." .

ex:ValorMenos3277SERVOOFF a ex:Parametro ;
    rdfs:label "-3277" ;
    ex:textoExtracto "-3277" ;
    ex:valor "-1 V." .

ex:Valor1SERVOOFF a ex:Parametro ;
    rdfs:label "1" ;
    ex:textoExtracto "1" ;
    ex:valor "0,3 mV." .

ex:Valor3277SERVOOFF a ex:Parametro ;
    rdfs:label "3277" ;
    ex:textoExtracto "3277" ;
    ex:valor "1 V." .

ex:Valor32767SERVOOFF a ex:Parametro ;
    rdfs:label "32767" ;
    ex:textoExtracto "32767" ;
    ex:valor "10 V." .

ex:TablaMINANOUT a ex:Tabla ;
    rdfs:label "Tabla MINANOUT" ;
    ex:textoExtracto "| MINANOUT | Consigna. |" ;
    ex:compuestoPor ex:MINANOUT, ex:Valor1MINANOUT, ex:Valor3277MINANOUT, ex:Valor32767MINANOUT .

ex:Valor1MINANOUT a ex:Parametro ;
    rdfs:label "1" ;
    ex:textoExtracto "1" ;
    ex:valor "0,3 mV." .

ex:Valor3277MINANOUT a ex:Parametro ;
    rdfs:label "3277" ;
    ex:textoExtracto "3277" ;
    ex:valor "1 V." .

ex:Valor32767MINANOUT a ex:Parametro ;
    rdfs:label "32767" ;
    ex:textoExtracto "32767" ;
    ex:valor "10 V." .