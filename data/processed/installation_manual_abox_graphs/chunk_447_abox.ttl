@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaMecanico a ns1:Sistema ;
    rdfs:label "sistema mecánico" ;
    ns1:textoExtracto "Como el tiempo de respuesta del sistema es un valor (normalmente desconocido) que depende de las inercias de la máquina y del ajuste del regulador, se aconseja probar con varios valores." ;
    ns1:tieneComponente ns1:ReguladorPosicion .

ns1:TiempoDeRespuestaDelSistema a ns1:Parametro ;
    rdfs:label "tiempo de respuesta del sistema" ;
    ns1:textoExtracto "Se aconseja asignar a este parámetro un valor del orden del tiempo de respuesta del sistema." .

ns1:ReguladorPosicion a ns1:ComponenteElectrico ;
    rdfs:label "regulador de posición" ;
    ns1:textoExtracto "Sin función en Sercos posición. Se aconseja asignar a este parámetro un valor del orden del tiempo de respuesta del sistema." .

