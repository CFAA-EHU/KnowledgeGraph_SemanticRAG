@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:GananciaACForwardAjusteApropiado a ns1:Parametro ;
    rdfs:label "ganancia AC-forward ajuste apropiado" ;
    ns1:identificador "ganancia_AC_forward_ajuste_apropiado" ;
    ns1:textoExtracto "Respuesta del sistema sin ganancia AC-forward (10 µm por cuadro)" .

ns1:GananciaACForwardAjusteInapropiado a ns1:Parametro ;
    rdfs:label "ganancia AC-forward ajuste inapropiado" ;
    ns1:identificador "ganancia_AC_forward_ajuste_inapropiado" ;
    ns1:textoExtracto "Respuesta del sistema con ganancia AC-forward (1 µm por cuadro)" .

ns1:Sistema a ns1:Sistema ;
    rdfs:label "Sistema" ;
    ns1:monitoreaParametro ns1:GananciaACForwardAjusteApropiado,
        ns1:GananciaACForwardAjusteInapropiado ;
    ns1:textoExtracto "Respuesta del sistema sin ganancia AC-forward (10 µm por cuadro)" .

