@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_f2e9a051d4 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro cuando trabaja con AC-forward; parámetro ACFWFACTOR." .

ns1:FactorDeCompensacionDeAdelantoACForward a ns1:Parametro ;
    rdfs:label "Factor de compensación de adelanto AC-Forward" ;
    ns1:identificador "ACFWFACTOR" ;
    ns1:textoExtracto "La compensación de los retardos se realiza con el parámetro ACFWFACTOR" .

ns1:PorcentajeDeACForwardEnAutomatico a ns1:Parametro ;
    rdfs:label "Porcentaje de AC-Forward en automático" ;
    ns1:identificador "ACFGAIN" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:PorcentajeDeACForwardEnManual_a5848c266a a ns1:Parametro ;
    rdfs:label "Porcentaje de AC-Forward en manual" ;
    ns1:identificador "MANACFGAIN" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:TiempoDeTransicion a ns1:Parametro ;
    rdfs:label "Tiempo de transición" ;
    ns1:identificador "TRANSDELAY" ;
    ns1:textoExtracto "el parámetro TRANSDELAY del eje asociado al sensor debe valor 0 (cero)" .

