@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModuloSalidaAnalogica1 a ex:ComponenteElectrico ;
    ex:textoExtracto "Los módulos de salidas analógicas se numeran según el orden lógico de los grupos remotos (conmutador rotativo de la fuente de alimentación)." ;
    rdfs:label "módulo de salidas analógicas" .

ex:ModuloSalidaAnalogica2 a ex:ComponenteElectrico ;
    ex:textoExtracto "Si hay más de un módulo de salidas analógicas dentro de cada grupo, el orden es de arriba abajo y de izquierda a derecha." ;
    rdfs:label "módulo de salidas analógicas" .

ex:SalidaAnalogica1_4 a ex:ComponenteElectrico ;
    ex:textoExtracto "Las salidas analógicas del primer módulo serán 1 a 4" ;
    rdfs:label "salida analógica 1 a 4" .

ex:SalidaAnalogica5_8 a ex:ComponenteElectrico ;
    ex:textoExtracto "las del segundo 5 a 8" ;
    rdfs:label "salida analógica 5 a 8" .

ex:ReguladorSercos1 a ex:ComponenteElectrico ;
    ex:textoExtracto "Gestión de la consigna analógica desde los reguladores Sercos." ;
    rdfs:label "regulador Sercos" .

ex:ParametroNumeroSalidaAnalogica a ex:Parametro ;
    ex:textoExtracto "En este caso, este parámetro indica cuál es el número de la salida analógica y el regulador a utilizar. El parámetro se define mediante un" ;
    rdfs:label "parámetro número de salida analógica" .