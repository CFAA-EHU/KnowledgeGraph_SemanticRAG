@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_107 a ex:Parametro ;
    rdfs:label "Número de salida analógica y de captación asociada al eje" ;
    ex:identificador "107" ;
    ex:valor "107" ;
    ex:textoExtracto "el parámetro se define con el valor ꞏ107ꞏ, indica que se utiliza la entrada analógica ꞏ1ꞏ del regulador cuya dirección lógica es ꞏ7ꞏ" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.COUNTERTYPE[set].xn" .

ex:Parametro_OP1 a ex:Parametro ;
    rdfs:label "Parámetro OP1 del regulador" ;
    ex:identificador "OP1" ;
    ex:valor "0" ;
    ex:textoExtracto "Los parámetros OP1 y OP2 del regulador se deben definir con valor 0" .

ex:Parametro_OP2 a ex:Parametro ;
    rdfs:label "Parámetro OP2 del regulador" ;
    ex:identificador "OP2" ;
    ex:valor "0" ;
    ex:textoExtracto "Los parámetros OP1 y OP2 del regulador se deben definir con valor 0" .

ex:Parametro_SERCOUNTID a ex:Parametro ;
    rdfs:label "Parámetro SERCOUNTID" ;
    ex:textoExtracto "Los módulos RCS-S se numeran según su orden lógico (parámetro SERCOUNTID)" .

ex:Parametro_COUNTERTYPE a ex:Parametro ;
    rdfs:label "Tipo de entrada de captación del eje" ;
    ex:identificador "COUNTERTYPE" ;
    ex:valor "Remoto CAN" ;
    ex:textoExtracto "COUNTERTYPE Tipo de entrada de captación del eje. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos velocidad. Valores posibles: Remoto CAN / Regulador / Contadora Sercos / Local. Valor por defecto: Remoto" .

ex:Regulador_Sercos_7 a ex:ComponenteElectrico ;
    rdfs:label "Regulador Sercos con dirección lógica 7" ;
    ex:identificador "7" ;
    ex:textoExtracto "el regulador cuya dirección lógica es ꞏ7ꞏ" .

ex:Entrada_Analogica_1 a ex:ComponenteElectrico ;
    rdfs:label "Entrada analógica 1" ;
    ex:identificador "1" ;
    ex:textoExtracto "se utiliza la entrada analógica ꞏ1ꞏ del regulador" .

ex:Modulo_RCS_S a ex:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S" ;
    ex:textoExtracto "Gestión de la consigna analógica desde el módulo RCS-S" .

ex:Variable_V_G_ANAO_107 a ex:Parametro ;
    rdfs:label "Variable V.G.ANAO[107]" ;
    ex:textoExtracto "para consultar la tensión en esa salida hay que escribir la variable de la forma V.G.ANAO[107]" .