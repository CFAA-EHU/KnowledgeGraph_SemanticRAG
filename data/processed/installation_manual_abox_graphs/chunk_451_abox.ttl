@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_PP5 a ex:Parametro ;
    rdfs:label "PP5" ;
    ex:identificador "PP5" ;
    ex:textoExtracto "Este parámetro indica dónde está ubicada la entrada de captación del eje; ... parametrizar el parámetro PP5=-0,0001."@es .

ex:Regulador_Sercos a ex:ComponenteElectrico ;
    rdfs:label "regulador Sercos" ;
    ex:textoExtracto "en los módulos remotos, en la captación libre de un regulador Sercos, en un módulo RCS-S (contadora Sercos) o en las entradas de captación locales de la unidad central."@es .

ex:Modulo_RCS_S a ex:ComponenteElectrico ;
    rdfs:label "módulo RCS-S" ;
    ex:textoExtracto "en un módulo RCS-S (contadora Sercos)"@es .

ex:Unidad_Central a ex:ComponenteElectrico ;
    rdfs:label "unidad central" ;
    ex:textoExtracto "en las entradas de captación locales de la unidad central."@es .

ex:Eje_Sercos_Velocidad a ex:ComponenteMecanico ;
    rdfs:label "eje Sercos velocidad" ;
    ex:textoExtracto "Significado para un eje Sercos velocidad."@es .

ex:AccionProhibida_BusquedaReferencia a ex:AccionProhibida ;
    rdfs:label "búsqueda de referencia del eje" ;
    ex:textoExtracto "Cuando la entrada de captación está en un regulador, el CNC no permite realizar la búsqueda de referencia del eje."@es .