@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceleracionDelPrimerTramo a ns1:Parametro ;
    rdfs:label "Aceleración del primer tramo" ;
    ns1:identificador "LACC1" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "1000.0000 mm/s² / 39.37008 inch/s² / 1000.0000 grados/s²" .

ns1:AceleracionDelSegundoTramo a ns1:Parametro ;
    rdfs:label "Aceleración del segundo tramo" ;
    ns1:identificador "LACC2" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "1000.0000 mm/s² / 39.37008 inch/s² / 1000.0000 grados/s²" .

ns1:SignificadoDeG0ACDCJERK a ns1:Parametro ;
    rdfs:label "Significado de G0ACDCJERK" ;
    ns1:identificador "G0ACDCJERK" ;
    ns1:textoExtracto "Los movimientos en G0 dependen del parámetro G0ACDCJERK." .

