@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EjeSercosVelocidad a ex:Maquina ;
    rdfs:label "eje Sercos velocidad" ;
    ex:textoExtracto "eje Sercos velocidad" .

ex:ParametroPP5 a ex:Parametro ;
    ex:identificador "PP5" ;
    ex:valor "-0,0001" ;
    ex:textoExtracto "parametrizar el parámetro PP5=-0,0001" .

ex:ReguladorSercos a ex:ComponenteElectrico ;
    rdfs:label "regulador Sercos" ;
    ex:textoExtracto "regulador Sercos" .

ex:ModuloRCSS a ex:ComponenteElectrico ;
    rdfs:label "módulo RCS-S (contadora Sercos)" ;
    ex:textoExtracto "módulo RCS-S (contadora Sercos)" .

ex:EntradaCaptacionExterna a ex:Sensor ;
    rdfs:label "entrada para la captación externa (directa) del eje" ;
    ex:textoExtracto "entrada para la captación externa (directa) del eje" .

ex:EntradaCaptacionLocal a ex:Sensor ;
    rdfs:label "entradas de captación locales de la unidad central" ;
    ex:textoExtracto "entradas de captación locales de la unidad central" .

ex:EntradaCaptacionLibre a ex:Sensor ;
    rdfs:label "captación libre de un regulador Sercos" ;
    ex:textoExtracto "captación libre de un regulador Sercos" .

ex:ParametroCOUNTERID a ex:Parametro ;
    ex:identificador "COUNTERID" ;
    ex:textoExtracto "COUNTERID Número de la entrada de captación del eje" .

ex:UnidadCentral a ex:Maquina ;
    rdfs:label "unidad central" ;
    ex:textoExtracto "unidad central" .

ex:ModuloRemoto a ex:ComponenteElectrico ;
    rdfs:label "módulos remotos" ;
    ex:textoExtracto "Módulos remotos" .

ex:EjeAnalogico a ex:Maquina ;
    rdfs:label "eje analógico" ;
    ex:textoExtracto "eje analógico" .

ex:EjeLineal a ex:Maquina ;
    rdfs:label "ejes lineales" ;
    ex:textoExtracto "ejes lineales" .

ex:EjeRotativo a ex:Maquina ;
    rdfs:label "ejes rotativos" ;
    ex:textoExtracto "ejes rotativos" .

ex:EjeCabezales a ex:Maquina ;
    rdfs:label "cabezales" ;
    ex:textoExtracto "cabezales" .

ex:VariableMPACOUNTERID a ex:Parametro ;
    ex:identificador "(V.)[ch].MPA.COUNTERID[set].xn" ;
    ex:textoExtracto "Variable asociada: (V.)[ch].MPA.COUNTERID[set].xn" .