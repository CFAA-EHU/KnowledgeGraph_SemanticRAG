    rdfs:label "Aceleración lineal para movimientos G0 (Sí)" ;
    ns1:identificador "LACC2G0" ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros LACC1G0, LACC2G0 y LFEEDG0." .

ns1:AceleracionLinealParaMovimientosG1G2YG3 a ns1:Parametro ;
    rdfs:label "Aceleración lineal para movimientos G1, G2 y G3" ;
    ns1:identificador "LACC1" ;
    ns1:textoExtracto "El CNC aplica los parámetros LACC1 y LACC2 a los movimientos en G1, G2 y G3;" .

ns1:AceleracionLinealParaMovimientosG1G2YG3_66d94bc1a5 a ns1:Parametro ;
    rdfs:label "Aceleración lineal para movimientos G1, G2 y G3" ;
    ns1:identificador "LACC2" ;
    ns1:textoExtracto "El CNC aplica los parámetros LACC1 y LACC2 a los movimientos en G1, G2 y G3;" .

ns1:ControlDeAceleracionParaMovimientosG0 a ns1:Parametro ;
    rdfs:label "Control de aceleración para movimientos G0" ;
    ns1:identificador "G0ACDCJERK" ;
    ns1:textoExtracto "Los movimientos en G0 dependen del parámetro G0ACDCJERK." .

ns1:VelocidadDeAvanceParaMovimientosG0No a ns1:Parametro ;
    rdfs:label "Velocidad de avance para movimientos G0 (No)" ;
    ns1:identificador "LFEED" ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros LACC1, LACC2 y LFEED." .

