@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_EntradaCaptacionEje
    a ex:Parametro ;
    rdfs:label "Parámetro de entrada de captación asociada al eje"@es ;
    ex:textoExtracto "este parámetro indicará cuál es la entrada de captación a utilizar (si la captación es local o remota) o el número de regulador o contadora"@es ;
    ex:identificador "2.6.20" .

ex:ModuloContadoras_CANfagor
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo de contadoras CANfagor"@es ;
    ex:textoExtracto "Para la entrada de captación se utiliza un módulo de contadoras"@es .

ex:SistemaCaptacionRemota
    a ex:Sistema ;
    rdfs:label "Sistema de captación remota CANfagor"@es ;
    ex:textoExtracto "Entrada de captación en los módulos remotos CANfagor"@es ;
    ex:tieneComponente ex:ModuloContadoras_CANfagor ;
    ex:monitoreaParametro ex:Parametro_EntradaCaptacionEje .