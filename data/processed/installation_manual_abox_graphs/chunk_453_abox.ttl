@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EntradaCaptacion_453_1 a ex:Sensor ;
    rdfs:label "Entrada de captación" ;
    ex:textoExtracto "En función de dónde esté la entrada de captación, este parámetro indicará cuál es la entrada de captación a utilizar (si la captación es local o remota) o el número de regulador o contadora." .

ex:ModuloContadoras_453_1 a ex:ComponenteElectrico ;
    rdfs:label "módulo de contadoras" ;
    ex:textoExtracto "Para la entrada de captación se utiliza un módulo de contadoras" .

ex:ModuloRemotoCANfagor_453_1 a ex:ComponenteElectrico ;
    rdfs:label "módulos remotos CANfagor" ;
    ex:textoExtracto "Entrada de captación en los módulos remotos CANfagor." .