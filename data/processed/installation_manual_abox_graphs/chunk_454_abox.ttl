@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ModuloContadoras1 a ex:ComponenteElectrico ;
    ex:textoExtracto "Los módulos de las contadoras se numeran según el orden lógico de los grupos remotos (conmutador rotativo de la fuente de alimentación)." ;
    ex:identificador "1" .

ex:ModuloContadoras2 a ex:ComponenteElectrico ;
    ex:textoExtracto "Los módulos de las contadoras se numeran según el orden lógico de los grupos remotos (conmutador rotativo de la fuente de alimentación)." ;
    ex:identificador "2" .

ex:ModuloRCS_S1 a ex:ComponenteElectrico ;
    ex:textoExtracto "Los módulos RCS-S se numeran según su orden lógico (parámetro SERCOUNTID)." ;
    ex:identificador "1" .

ex:ModuloRCS_S2 a ex:ComponenteElectrico ;
    ex:textoExtracto "Los módulos RCS-S se numeran según su orden lógico (parámetro SERCOUNTID)." ;
    ex:identificador "2" .

ex:ReguladorSercos a ex:ComponenteElectrico ;
    ex:textoExtracto "Entrada de captación en los reguladores Sercos. En este caso siempre se utilizará la segunda entrada de captación del regulador." ;
    ex:identificador "Sercos" .

ex:CNC a ex:Sistema ;
    ex:textoExtracto "el CNC permite que ambos ejes utilicen la misma entrada de captación." ;
    ex:identificador "CNC" .

ex:EntradaCaptacionLocal a ex:Parametro ;
    ex:textoExtracto "Entrada de captación local. No es necesario definir este parámetro." ;
    ex:identificador "0" .

ex:EntradaCaptacionLaser a ex:Parametro ;
    ex:textoExtracto "En el modelo láser, la entrada de captación del cabezal será 0 ya que no hay captación real." ;
    ex:identificador "0" .