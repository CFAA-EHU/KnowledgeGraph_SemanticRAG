@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_8e2b595217 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC aplica los parámetros ACCEL y DECEL a los movimientos en G1, G2 y G3; los movimientos en G0 dependen del parámetro G0ACDCJERK." ;
    ns1:tieneComponente ns1:Parametro_602c4a5d6a,
        ns1:Parametro_7a01575dc8 .

ns1:ControlDeAceleracionParaG0 a ns1:Parametro ;
    rdfs:label "Control de aceleración para G0" ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCEL y DECEL si el valor es 'No'." .

ns1:Parametro_602c4a5d6a a ns1:Parametro ;
    rdfs:label "Aceleración" ;
    ns1:identificador "MPA.ACCEL" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "3000.0000 mm/s² / 118.12023 inch/s² / 3000.0000 grados/s²" .

ns1:Parametro_7a01575dc8 a ns1:Parametro ;
    rdfs:label "Deceleración" ;
    ns1:identificador "MPA.DECEL" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "3000.0000 mm/s² / 118.12023 inch/s² / 3000.0000 grados/s²" .

