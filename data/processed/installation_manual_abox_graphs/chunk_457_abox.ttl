@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:FEEDBACKTYPE a ex:Parametro ;
    ex:textoExtracto "parámetro FEEDBACKTYPE" .

ex:EnDat a ex:Parametro ;
    ex:textoExtracto "tipo de captación es FeeDat o EnDat (parámetro FEEDBACKTYPE)" .

ex:FeeDat a ex:Parametro ;
    ex:textoExtracto "tipo de captación es FeeDat o EnDat (parámetro FEEDBACKTYPE)" .

ex:ENCODERINFO a ex:Parametro ;
    ex:textoExtracto "ENCODERINFO Información del encóder" ;
    ex:valor "Información del encóder" .

ex:Tabla_Parametros_EnDat a ex:Tabla ;
    ex:textoExtracto "muestra una tabla de parámetros con la información del encóder" ;
    ex:detalladoEnEsquema ex:ENCODERINFO .