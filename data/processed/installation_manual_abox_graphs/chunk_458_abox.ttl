@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_NAME a ex:Parametro ;
    rdfs:label "NAME" ;
    ex:textoExtracto "Parámetro: NAME. Nomenclatura del encóder." ;
    ex:identificador "NAME" .

ex:Parametro_TYPE a ex:Parametro ;
    rdfs:label "TYPE" ;
    ex:textoExtracto "Parámetro: TYPE. Tipo de encóder." ;
    ex:identificador "TYPE" .

ex:Parametro_RESOLUTION a ex:Parametro ;
    rdfs:label "RESOLUTION" ;
    ex:textoExtracto "Parámetro: RESOLUTION. Resolución del encóder." ;
    ex:identificador "RESOLUTION" .

ex:Parametro_SERIALNUMBER a ex:Parametro ;
    rdfs:label "SERIALNUMBER" ;
    ex:textoExtracto "Parámetro: SERIALNUMBER. Número de serie del encóder." ;
    ex:identificador "SERIALNUMBER" .

ex:Parametro_DATALENGTH a ex:Parametro ;
    rdfs:label "DATALENGTH" ;
    ex:textoExtracto "Parámetro: DATALENGTH. Número de bits que constituyen el dato en la transmisión." ;
    ex:identificador "DATALENGTH" .