@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceleracionJerk a ns1:Parametro ;
    rdfs:label "Aceleración jerk" ;
    ns1:identificador "ACCJERK" ;
    ns1:textoExtracto "Los parámetros ACCJERK y DECJERK definen la pendiente de la aceleración y deceleración." .

ns1:JerkDeDeceleracion_e52b6d0bd7 a ns1:Parametro ;
    rdfs:label "Jerk de deceleración" ;
    ns1:identificador "DECJERK" ;
    ns1:textoExtracto "DECJERK Jerk de deceleración. Parámetro válido para ejes lineales, rotativos y cabezales." ;
    ns1:valor "45000.000 mm/s³ / 1771.65354 inch/s³ / 45000.000 grados/s³" .

