@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_Encoder_Nombre
    a               ex:Parametro ;
    rdfs:label      "NAME (Nomenclatura del encóder)"@es ;
    ex:textoExtracto "NAME Nomenclatura del encóder. [...] • Si es un encóder Fagor, nombre del encóder. • Si es un encóder EnDat, texto 'EnDat'."@es ;
    ex:identificador "(V.)[ch].MPA.DE_NAME[set].xn", "(V.)[ch].A.CDE_NAME[set].xn" ;
    ex:monitoreaParametro ex:Componente_Encoder .

ex:Parametro_Encoder_Tipo
    a               ex:Parametro ;
    rdfs:label      "TYPE (Tipo de encóder)"@es ;
    ex:textoExtracto "TYPE Tipo de encóder. [...] Tipo de encóder (absoluto rotativo multivuelta, absoluto rotativo, absoluto lineal, etc)."@es ;
    ex:identificador "(V.)[ch].MPA.DE_TYPE[set].xn", "(V.)[ch].A.CDE_TYPE[set].xn" ;
    ex:monitoreaParametro ex:Componente_Encoder .

ex:Parametro_Encoder_Resolucion
    a               ex:Parametro ;
    rdfs:label      "RESOLUTION (Resolución del encóder)"@es ;
    ex:textoExtracto "RESOLUTION Resolución del encóder. [...] • Si el encóder es lineal, resolución en nanómetros. • Si el encóder es angular, número de impulsos por vuelta."@es ;
    ex:identificador "(V.)[ch].MPA.DE_RESOLUTION[set].xn", "(V.)[ch].A.CDE_RESOLUTION[set].xn" ;
    ex:monitoreaParametro ex:Componente_Encoder .

ex:Parametro_Encoder_NumeroSerie
    a               ex:Parametro ;
    rdfs:label      "SERIALNUMBER (Número de serie del encóder)"@es ;
    ex:textoExtracto "SERIALNUMBER Número de serie del encóder."@es ;
    ex:monitoreaParametro ex:Componente_Encoder .

ex:Componente_Encoder
    a               ex:Sensor ;
    rdfs:label      "Encóder"@es ;
    ex:textoExtracto "El CNC obtiene esta información del propio encóder, por lo que estos parámetros no se pueden modificar."@es .

ex:Tabla_ParametrosEncoder a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla de parámetros del encóder"@es ;
    ex:textoExtracto "En el caso de que los datos leídos del encóder no coincidan con los guardados en la tabla de parámetros, el CNC mostrará una nueva tabla con ambos grupos de valores."@es ;
    ex:documentadoEn ex:Manual_CNC .

ex:InterfazUsuario_SoftkeyGuardar
    a               ex:InterfazUsuario ;
    rdfs:label      "Softkey para salvar datos del encóder"@es ;
    ex:textoExtracto "Al mismo tiempo mostrará una softkey para salvar los nuevos datos en la tabla. El CNC sólo mostrará esta softkey si los datos leídos del encóder son válidos (encóder conectado y correctamente identificado) y no coinciden con los guardados."@es .