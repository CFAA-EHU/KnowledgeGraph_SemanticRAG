@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IndicaSiLosMovimientosEnG0UtilizanParametrosEspecificosDeAceleracion a ns1:Parametro ;
    rdfs:label "Indica si los movimientos en G0 utilizan parámetros específicos de aceleración" ;
    ns1:textoExtracto "Sí. Los movimientos en G0 utilizan los parámetros ACCJERKG0 y DECJERKG0." .

ns1:Parametro_e88085e3f1 a ns1:Parametro ;
    rdfs:label "Parámetro de jerk para aceleración",
        "Parámetro de jerk para desaceleración" ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCJERK y DECJERK." .

ns1:Parametro_f61a7f6cee a ns1:Parametro ;
    rdfs:label "Parámetro de jerk para aceleración en G0",
        "Parámetro de jerk para desaceleración en G0" ;
    ns1:textoExtracto "Los movimientos en G0 utilizan los parámetros ACCJERKG0 y DECJERKG0." .

