@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Encoder_Parametro_SERIALNUMBER
    a ex:Parametro ;
    rdfs:label "Número de serie del encóder" ;
    ex:identificador "SERIALNUMBER" ;
    ex:textoExtracto "SERIALNUMBER • Número de serie del encóder." ;
    ex:valor "(V.)[ch].MPA.DE_SERIALNUMBER[set].xn (guardado), (V.)[ch].A.CDE_SERIALNUMBER[set].xn (leído)"^^xsd:string .

ex:Encoder_Parametro_DATALENGTH
    a ex:Parametro ;
    rdfs:label "Longitud de datos del encóder" ;
    ex:identificador "DATALENGTH" ;
    ex:textoExtracto "DATALENGTH • Número de bits que constituyen el dato en la transmisión." ;
    ex:valor "(V.)[ch].MPA.DE_DATALENGTH[set].xn"^^xsd:string .

ex:Encoder_Componente
    a ex:ComponenteElectrico ;
    rdfs:label "Encóder" ;
    ex:textoExtracto "Si el encóder es lineal, resolución en nanómetros. • Si el encóder es angular, número de impulsos por vuelta." ;
    ex:monitoreaParametro ex:Encoder_Parametro_SERIALNUMBER ;
    ex:monitoreaParametro ex:Encoder_Parametro_DATALENGTH .