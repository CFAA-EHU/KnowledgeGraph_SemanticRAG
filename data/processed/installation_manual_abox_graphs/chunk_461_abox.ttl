@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_DATALENGTH a ex:Parametro ;
    rdfs:label "DATALENGTH" ;
    ex:textoExtracto "parámetro del encóder. DATALENGTH Número de bits que constituyen el dato en la transmisión." ;
    ex:valor "Número de bits que constituyen el dato en la transmisión" .

ex:Variable_MPA_DE_DATALENGTH a ex:Parametro ;
    rdfs:label "(V.)[ch].MPA.DE_DATALENGTH[set].xn" ;
    ex:textoExtracto "Variable asociada (valor guardado en la tabla): (V.)[ch].MPA.DE_DATALENGTH[set].xn" .

ex:Variable_CDE_DATALENGTH a ex:Parametro ;
    rdfs:label "(V.)[ch].A.CDE_DATALENGTH[set].xn" ;
    ex:textoExtracto "Variable asociada (valor leído del encóder): (V.)[ch].A.CDE_DATALENGTH[set].xn" .

ex:Sistema_CNC a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "Parámetro no modificable; el CNC lee este parámetro del encóder." .

ex:Parametro_DATALENGTH ex:valor "Parámetro no modificable" ;
    ex:monitoreaParametro ex:Sistema_CNC .