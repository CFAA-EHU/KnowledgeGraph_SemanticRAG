@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceleracionJerkG0 a ns1:Parametro ;
    rdfs:label "Jerk de aceleración (movimientos en G0)" ;
    ns1:identificador "ACCJERKG0" ;
    ns1:textoExtracto "Valores posibles para jerk de aceleración en movimientos G0." .

ns1:AceleracionLinealG0 a ns1:Parametro ;
    rdfs:label "Aceleración lineal (movimientos en G0)" ;
    ns1:identificador "LACC1G0" ;
    ns1:textoExtracto "Valores posibles para aceleración del primer tramo en movimientos G0." .

ns1:AceleracionSegundoTramoG0 a ns1:Parametro ;
    rdfs:label "Aceleración del segundo tramo (movimientos en G0)" ;
    ns1:identificador "LACC2G0" ;
    ns1:textoExtracto "Valores posibles para aceleración del segundo tramo en movimientos G0." .

ns1:AceleracionTrapezoidalG0 a ns1:Parametro ;
    rdfs:label "Aceleración trapezoidal (movimientos en G0)" ;
    ns1:identificador "ACCELG0" ;
    ns1:textoExtracto "Valores posibles para aceleración trapezoidal en movimientos G0." .

ns1:AmpliacionDeParametrosSiG0 a ns1:Parametro ;
    rdfs:label "Ampliación de parámetros si G0" ;
    ns1:identificador "MPA.G0ACDCJERK" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.G0ACDCJERK[set].xn Este parámetro permite definir unos valores específicos de aceleración y jerk para los movimientos en G0." .

ns1:DeceleracionJerkG0 a ns1:Parametro ;
    rdfs:label "Jerk de deceleración (movimientos en G0)" ;
    ns1:identificador "DECJERKG0" ;
    ns1:textoExtracto "Valores posibles para jerk de deceleración en movimientos G0." .

ns1:DeceleracionTrapezoidalG0 a ns1:Parametro ;
    rdfs:label "Deceleración trapezoidal (movimientos en G0)" ;
    ns1:identificador "DECELG0" ;
    ns1:textoExtracto "Valores posibles para deceleración trapezoidal en movimientos G0." .

ns1:VelocidadCambioAceleracionG0 a ns1:Parametro ;
    rdfs:label "Velocidad de cambio de aceleración (movimientos en G0)" ;
    ns1:identificador "LFEEDG0" ;
    ns1:textoExtracto "Valores posibles para velocidad de cambio de aceleración en movimientos G0." .

