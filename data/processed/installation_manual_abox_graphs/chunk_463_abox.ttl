@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SSITYPE a ex:Parametro ;
    ex:textoExtracto "SSITYPE Tipo de captación SSI conectada a la captación correspondiente. Valores posibles: SSITYPE Fagor / Usuario G / Usuario. Valor por defecto: Usuario. Variable asociada: (V.)[ch].MPA.SSITYPE[set].xn Cuando FEEDBACKTYPE=SSI, este parámetro permite definir el formato de la transmisión SSI. El parámetro ofrece una serie de tipos predefinidos para la conexión a los encoders lineales y rotativos más usuales. Si el encoder no aparece en la lista, se podrá seleccionar la opción usuario para personalizar las propiedades de la comunicación SSI." ;
    rdfs:label "SSITYPE" .

ex:SSI a ex:Tabla ;
    ex:textoExtracto "SSI Tabla de parámetros SSI (Synchronous Serial Interface). Este parámetro muestra la tabla de parámetros para configurar el formato de transmisión SSI. En función del tipo de regla seleccionado (parámetro SSITYPE), algunos de estos valores estarán prefijados y no se podrán modificar. El tipo de regla \"usuario\" permite personalizar todos los valores." ;
    rdfs:label "Tabla de parámetros SSI" .

ex:Fagor_LA a ex:ComponenteElectrico ;
    ex:textoExtracto "Fagor LA | Regla Fagor." ;
    rdfs:label "Fagor LA" .

ex:Fagor_GA a ex:ComponenteElectrico ;
    ex:textoExtracto "Fagor GA | Regla Fagor." ;
    rdfs:label "Fagor GA" .

ex:Fagor_SA a ex:ComponenteElectrico ;
    ex:textoExtracto "Fagor SA | Regla Fagor." ;
    rdfs:label "Fagor SA" .

ex:Fagor_SVA a ex:ComponenteElectrico ;
    ex:textoExtracto "Fagor SVA | Regla Fagor." ;
    rdfs:label "Fagor SVA" .

ex:Fagor_HA_27_D200 a ex:ComponenteElectrico ;
    ex:textoExtracto "Fagor HA-27-D200 | Encoder Fagor." ;
    rdfs:label "Fagor HA-27-D200" .

ex:Fagor_HA_23_D90 a ex:ComponenteElectrico ;
    ex:textoExtracto "Fagor HA-23-D90 | Encoder Fagor." ;
    rdfs:label "Fagor HA-23-D90" .

ex:Fagor_SA_23_D90 a ex:ComponenteElectrico ;
    ex:textoExtracto "Fagor SA-23-D90 | Encoder Fagor." ;
    rdfs:label "Fagor SA-23-D90" .

ex:Fagor_SA_23_D170 a ex:ComponenteElectrico ;
    ex:textoExtracto "Fagor SA-23-D170 | Encoder Fagor." ;
    rdfs:label "Fagor SA-23-D170" .

ex:ABSIND_inductosyn_LIN_ABS a ex:ComponenteElectrico ;
    ex:textoExtracto "ABSIND (inductosyn LIN+ABS) | Captador lineal absoluto." ;
    rdfs:label "ABSIND (inductosyn LIN+ABS)" .

ex:ABSIND_inductosyn_ROT_ABS a ex:ComponenteElectrico ;
    ex:textoExtracto "ABSIND (inductosyn ROT+ABS) | Captador rotativo absoluto en una vuelta del encoder." ;
    rdfs:label "ABSIND (inductosyn ROT+ABS)" .

ex:ABSIND_resolver a ex:ComponenteElectrico ;
    ex:textoExtracto "ABSIND (resolver) | Captador rotativo absoluto en una vuelta." ;
    rdfs:label "ABSIND (resolver)" .

ex:ABSIND_inductosyn_LIN a ex:ComponenteElectrico ;
    ex:textoExtracto "ABSIND (inductosyn LIN) | Captador lineal absoluto en el pitch. Hace falta referenciar la regla." ;
    rdfs:label "ABSIND (inductosyn LIN)" .

ex:ABSIND_inductosyn_ROT a ex:ComponenteElectrico ;
    ex:textoExtracto "ABSIND (inductosyn ROT) | Captador rotativo absoluto en el pitch. Hace falta referenciar la regla." ;
    rdfs:label "ABSIND (inductosyn ROT)" .

ex:Usuario_G a ex:ComponenteElectrico ;
    ex:textoExtracto "Usuario G | Configuración de usuario." ;
    rdfs:label "Usuario G" .

ex:Usuario a ex:ComponenteElectrico ;
    ex:textoExtracto "Usuario | Configuración de usuario." ;
    rdfs:label "Usuario" .

ex:SSITYPE ex:tieneComponente ex:Fagor_LA, ex:Fagor_GA, ex:Fagor_SA, ex:Fagor_SVA, ex:Fagor_HA_27_D200, ex:Fagor_HA_23_D90, ex:Fagor_SA_23_D90, ex:Fagor_SA_23_D170, ex:ABSIND_inductosyn_LIN_ABS, ex:ABSIND_inductosyn_ROT_ABS, ex:ABSIND_resolver, ex:ABSIND_inductosyn_LIN, ex:ABSIND_inductosyn_ROT, ex:Usuario_G, ex:Usuario ;
    ex:documentadoEn ex:SSI .