ex:Parametro_SSITYPE
    a ex:Parametro ;
    rdfs:label "SSITYPE" ;
    ex:textoExtracto "SSITYPE Tipo de captación SSI conectada a la captación correspondiente. Valores posibles: SSITYPE Fagor / Usuario G / Usuario. Valor por defecto: Usuario." ;
    ex:identificador "V.[ch].MPA.SSITYPE[set].xn" ;
    ex:valor "Usuario"^^xsd:string .

ex:Tabla_ParametrosSSI a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros SSI" ;
    ex:textoExtracto "SSI Tabla de parámetros SSI (Synchronous Serial Interface). Este parámetro muestra la tabla de parámetros para configurar el formato de transmisión SSI." ;
    ex:detalladoEnEsquema ex:Parametro_SSITYPE .

