@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceleracionLinealMovimientosEnG0 a ns1:Parametro ;
    rdfs:label "Aceleración lineal (movimientos en G0)" ;
    ns1:identificador "LACC1G0" ;
    ns1:textoExtracto "El CNC aplica los parámetros LACC1G0 y LACC2G0 a los movimientos en G0." .

ns1:AceleracionLinealMovimientosEnG0_5e09130d5f a ns1:Parametro ;
    rdfs:label "Aceleración lineal (movimientos en G0)" ;
    ns1:identificador "LACC2G0" ;
    ns1:textoExtracto "El CNC aplica los parámetros LACC1G0 y LACC2G0 a los movimientos en G0." .

ns1:VariableMPALFEEDG0 a ns1:Parametro ;
    rdfs:label "Variable asociada al parámetro LFEEDG0" ;
    ns1:identificador "MPA.LFEEDG0" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.LFEEDG0[set].xn" .

ns1:VelocidadDeCambioDeAceleracionMovimientosEnG0_2b2bac1672 a ns1:Parametro ;
    rdfs:label "Velocidad de cambio de aceleración (movimientos en G0)" ;
    ns1:identificador "LFEEDG0" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "3000 mm/min / 118.11023 inch/min / 1080000 grados/min / 3000 rpm" .

