@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ParametroSSICLKFREQ a ex:Parametro ;
    rdfs:label "SSICLKFREQ" ;
    ex:identificador "SSICLKFREQ" ;
    ex:textoExtracto "SSICLKFREQ = 1 / T = 400."@es ;
    ex:valor "400 kHz" .

ex:ParametroSSIDATALENGTH a ex:Parametro ;
    rdfs:label "SSIDATALENGTH" ;
    ex:identificador "SSIDATALENGTH" ;
    ex:textoExtracto "SSIDATALENGTH = n | Longitud de bits de la cota."@es .

ex:ParametroSSICRCBITS a ex:Parametro ;
    rdfs:label "SSICRCBITS" ;
    ex:identificador "SSICRCBITS" ;
    ex:textoExtracto "SSICRCBITS = 0 | No hay bits de CRC."@es .

ex:ParametroSSISTARTBITS a ex:Parametro ;
    rdfs:label "SSISTARTBITS" ;
    ex:identificador "SSISTARTBITS" ;
    ex:textoExtracto "SSISTARTBITS = 0 | No hay bits de start."@es .

ex:ParametroSSIPACKFORMAT a ex:Parametro ;
    rdfs:label "SSIPACKFORMAT" ;
    ex:identificador "SSIPACKFORMAT" ;
    ex:textoExtracto "SSIPACKFORMAT = 3 | Data + Alarm."@es .

ex:ParametroSSIALARMBITS a ex:Parametro ;
    rdfs:label "SSIALARMBITS" ;
    ex:identificador "SSIALARMBITS" ;
    ex:textoExtracto "SSIALARMBITS = 1 | 1 bit de alarma/acknowledge."@es .

ex:ParametroSSIDATAMODE a ex:Parametro ;
    rdfs:label "SSIDATAMODE" ;
    ex:identificador "SSIDATAMODE" ;
    ex:textoExtracto "SSIDATAMODE = 1 | MSB Primero."@es .

ex:ParametroSSIALARMLEVEL a ex:Parametro ;
    rdfs:label "SSIALARMLEVEL" ;
    ex:identificador "SSIALARMLEVEL" ;
    ex:textoExtracto "SSIALARMLEVEL = 1 | El acknowledge se indica con data a 0; por tanto, se produce una señal de alarma cuando el bit es un 1."@es .

ex:FrecuenciaSSI a ex:Frecuencia ;
    rdfs:label "Frecuencia SSI" ;
    ex:identificador "SSICLKFREQ" ;
    ex:textoExtracto "Frecuencia para la comunicación SSI. Valores posibles: De 59 a 7500 kHz. Valor por defecto: 150 kHz. Variable asociada: (V.)[ch].MPA.SSICLKFREQ[set].xn Frecuencia del reloj para la comunicación SSI. La frecuencia máxima recomendada depende de la longitud del cable."@es ;
    ex:valor "De 59 a 7500 kHz" .

ex:TablaFrecuenciaMaxima a ex:Tabla ;
    rdfs:label "Tabla de frecuencia máxima por longitud de cable" ;
    ex:textoExtracto "Longitud. | Frecuencia máxima. | Hasta 20 metros. | 600 kHz. | Hasta 50 metros. | 400 kHz. | Hasta 75 metros. | 300 kHz. | Hasta 100 metros. | 250 kHz."@es .

ex:ParametroSSIDATAFORMAT a ex:Parametro ;
    rdfs:label "SSIDATAFORMAT" ;
    ex:identificador "SSIDATAFORMAT" ;
    ex:textoExtracto "SSIDATAFORMAT Parámetros para definir el formato de los datos de lectura de la transmisión SSI. La cota que leemos a través de la transmisión SSI nos puede llegar en formatos diferentes. • Los siguientes parámetros definen la cantidad de datos SSI que se van a leer."@es .