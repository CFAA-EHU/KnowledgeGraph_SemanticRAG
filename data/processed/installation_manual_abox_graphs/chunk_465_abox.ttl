@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceleracionLinealMovimientosEnG0LACC1G0 a ns1:Parametro ;
    rdfs:label "Aceleración lineal (movimientos en G0) - LACC1G0" ;
    ns1:textoExtracto "definido en este parámetro se cambia la aceleración de LACC1G0 a LACC2G0." .

ns1:AceleracionLinealMovimientosEnG0LACC2G0 a ns1:Parametro ;
    rdfs:label "Aceleración lineal (movimientos en G0) - LACC2G0" ;
    ns1:textoExtracto "definido en este parámetro se cambia la aceleración de LACC1G0 a LACC2G0." .

