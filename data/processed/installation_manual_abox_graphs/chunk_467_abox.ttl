@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:JerkDeAceleracionMovimientosEnG0 a ns1:Parametro ;
    rdfs:label "Jerk de aceleración (movimientos en G0)"@es ;
    ns1:identificador "ACCJERKG0" ;
    ns1:textoExtracto "ACCJERKG0 Jerk de aceleración (movimientos en G0). Parámetro válido para ejes lineales, rotativos y cabezales." ;
    ns1:valor "55000.000 mm/s³ / 2165.35433 inch/s³ / 55000.000 grados/s³"@es .

ns1:JerkDeDeceleracionMovimientosEnG0 a ns1:Parametro ;
    rdfs:label "Jerk de deceleración (movimientos en G0)"@es ;
    ns1:identificador "DECJERKG0" ;
    ns1:textoExtracto "DECJERKG0 Jerk de deceleración (movimientos en G0). Parámetro válido para ejes lineales, rotativos y cabezales." ;
    ns1:valor "55000.000 mm/s³ / 2165.35433 inch/s³ / 55000.000 grados/s³"@es .

