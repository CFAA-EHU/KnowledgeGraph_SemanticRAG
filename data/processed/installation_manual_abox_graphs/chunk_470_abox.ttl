@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SSICRCBITS
    a ex:Parametro ;
    rdfs:label "SSICRCBITS" ;
    ex:textoExtracto "Número de bits que componen el CRC de la transmisión SSI que constituyen el chequeo de transmisión válida. Valores posibles: De 0 a 31. Valor por defecto: 0." ;
    ex:valor "0-31" ;
    ex:identificador "(V.)[ch].MPA.SSICRCBITS[set].xn" .

ex:Parametro_SSIDATALENGTH
    a ex:Parametro ;
    rdfs:label "SSIDATALENGTH" ;
    ex:textoExtracto "Si una regla está configurada en este modo deberá programarse SSIDATALENGTH=27 y SSICRCBITS=5." ;
    ex:valor "27" ;
    ex:identificador "SSIDATALENGTH" .

ex:Parametro_SSISTARTBITS
    a ex:Parametro ;
    rdfs:label "SSISTARTBITS" ;
    ex:textoExtracto "Número de bits, si los hubiese, que es necesario esperar para empezar a recibir la información de cota. Valores posibles: De 0 a 3. Valor por defecto: 0." ;
    ex:valor "0-3" ;
    ex:identificador "(V.)[ch].MPA.SSISTARTBITS[set].xn" .

ex:Parametro_SSIALARMBITS
    a ex:Parametro ;
    rdfs:label "SSIALARMBITS" ;
    ex:textoExtracto "El captador puede mandar uno o varios bits indicando una condición de alarma si algo ha ido mal, o bien uno o varios bits de reconocimiento (acknowledge) si la transmisión ha sido efectuada correctamente. Valores posibles: De 0 a 2. Valor por defecto: 0." ;
    ex:valor "0-2" ;
    ex:identificador "(V.)[ch].MPA.SSIALARMBITS[set].xn" .

ex:Parametro_SSIALARMLEVEL
    a ex:Parametro ;
    rdfs:label "SSIALARMLEVEL" ;
    ex:textoExtracto "Valor que tienen que tener los bits de alarma/acknowledge para que se produzca una condición de error. Valores posibles: De 0 a 3. Valor por defecto: 0." ;
    ex:valor "0-3" ;
    ex:identificador "(V.)[ch].MPA.SSIALARMLEVEL[set].xn" .

ex:Sistema_Inductosyn
    a ex:Sistema ;
    rdfs:label "Sistema de captación INDUCTOSYN" ;
    ex:textoExtracto "Algoritmo de comprobación de datos empleado en el conexionado con un módulo INDUCTOSYN." ;
    ex:tieneComponente ex:Parametro_SSICRCBITS ;
    ex:tieneComponente ex:Parametro_SSISTARTBITS ;
    ex:tieneComponente ex:Parametro_SSIALARMBITS ;
    ex:tieneComponente ex:Parametro_SSIALARMLEVEL .