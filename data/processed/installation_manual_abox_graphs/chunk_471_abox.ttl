@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SSIALARMBITS a ex:Parametro ;
    ex:textoExtracto "SSIALARMBITS = 2" ;
    ex:valor "2" .

ex:SSIALARMLEVEL a ex:Parametro ;
    ex:textoExtracto "SSIALARMLEVEL = 2" ;
    ex:valor "2" .

ex:SSIALARMBITS_1 a ex:Parametro ;
    ex:textoExtracto "SSIALARMBITS = 1" ;
    ex:valor "1" .

ex:SSIALARMLEVEL_1 a ex:Parametro ;
    ex:textoExtracto "SSIALARMLEVEL = 1" ;
    ex:valor "1" .

ex:SSIDATAMODE a ex:Parametro ;
    ex:textoExtracto "SSIDATAMODE Modo de transmisión. Valores posibles: De 0 a 1. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.SSIDATAMODE[set].xn Orden en el que se transmite el bit más significativo." ;
    ex:valor "0" .

ex:SSIDATAMODE_0 a ex:Parametro ;
    ex:textoExtracto "Valor. | Significado. | 0 | El primer bit es el LSB (Least Significant Bit)." ;
    ex:valor "0" .

ex:SSIDATAMODE_1 a ex:Parametro ;
    ex:textoExtracto "1 | El primer bit es el MSB (Most Significant Bit)." ;
    ex:valor "1" .

ex:STARTDELAY a ex:Parametro ;
    ex:textoExtracto "STARTDELAY Número de clocks a esperar entre el primer flanco de bajada y el primer flanco de subida. Valores posibles: De 0 a 255. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.STARTDELAY[set].xn Este parámetro define el número de clocks SSI que hay que esperar desde el primer flanco de bajada SSI hasta que se genera el primer flanco de subida." ;
    ex:valor "0" .

ex:STARTDELAY_3 a ex:Parametro ;
    ex:textoExtracto "STARTDELAY = 3 Tiempo de espera = (1/400*1000)*3 = 7,5 clocks." ;
    ex:valor "3" .

ex:CLOCKFREQ a ex:Parametro ;
    ex:textoExtracto "CLOCKFREQ = 400 kHz" ;
    ex:valor "400 kHz" .

ex:SSIRESOL a ex:Parametro ;
    ex:textoExtracto "SSIRESOL Resolución del contaje digital. Valores posibles: De 1 a 999999999. Valor por defecto: 10000. Variable asociada: (V.)[ch].MPA.SSIRESOL[set].xn Número de unidades de contaje digital que hay contenidas en un pitch." ;
    ex:valor "10000" .