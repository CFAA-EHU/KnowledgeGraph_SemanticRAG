@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SSIALARMBITS
    a ex:Parametro ;
    rdfs:label "SSIALARMBITS" ;
    ex:textoExtracto "SSIALARMBITS = 2" ;
    ex:valor "2" .

ex:Parametro_SSIALARMLEVEL
    a ex:Parametro ;
    rdfs:label "SSIALARMLEVEL" ;
    ex:textoExtracto "SSIALARMLEVEL = 2" ;
    ex:valor "2" .

ex:Parametro_SSIDATAMODE
    a ex:Parametro ;
    rdfs:label "SSIDATAMODE" ;
    ex:textoExtracto "SSIDATAMODE Modo de transmisión. Valores posibles: De 0 a 1. Valor por defecto: 0." ;
    ex:valor "0" .

ex:Parametro_STARTDELAY
    a ex:Parametro ;
    rdfs:label "STARTDELAY" ;
    ex:textoExtracto "STARTDELAY Número de clocks a esperar entre el primer flanco de bajada y el primer flanco de subida. Valores posibles: De 0 a 255. Valor por defecto: 0." ;
    ex:valor "0" .

ex:Parametro_SSIRESOL
    a ex:Parametro ;
    rdfs:label "SSIRESOL" ;
    ex:textoExtracto "SSIRESOL Resolución del contaje digital. Valores posibles: De 1 a 999999999. Valor por defecto: 10000." ;
    ex:valor "10000" .

ex:Tabla_ModoTransmisionSSIDATAMODE a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Modo de transmisión SSIDATAMODE" ;
    ex:textoExtracto "| Valor. | Significado. | --- | --- | 0 | El primer bit es el LSB (Least Significant Bit). | 1 | El primer bit es el MSB (Most Significant Bit)." ;
    ex:ilustradoEn ex:Parametro_SSIDATAMODE .