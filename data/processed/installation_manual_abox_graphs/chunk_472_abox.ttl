@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SSIRESOL_Regla20Micras
    a ex:Parametro ;
    rdfs:label "SSIRESOL (Regla absoluta Fagor 20µ)" ;
    ex:textoExtracto "Regla absoluta Fagor de 20 micras de paso de regla y una resolución digital de 1 dµ. SSIRESOL = 20 µ / 0,1 µ = 200." ;
    ex:valor "200" .

ex:Parametro_PITCH_Regla20Micras
    a ex:Parametro ;
    rdfs:label "PITCH (Regla absoluta Fagor 20µ)" ;
    ex:textoExtracto "Regla absoluta Fagor de 20 micras de paso de regla y una resolución digital de 1 dµ." ;
    ex:valor "20" ;
    ex:identificador "20µ" .

ex:Parametro_SSIRESOL_Encoder8192
    a ex:Parametro ;
    rdfs:label "SSIRESOL (Encoder 8192 pulsos)" ;
    ex:textoExtracto "Para el caso de un encoder de 8192 pulsos por vuelta y un husillo de paso 10 mm. SSIRESOL = 8192." ;
    ex:valor "8192" .

ex:Parametro_PITCH_Encoder8192
    a ex:Parametro ;
    rdfs:label "PITCH (Husillo 10mm)" ;
    ex:textoExtracto "Para el caso de un encoder de 8192 pulsos por vuelta y un husillo de paso 10 mm. PITCH = 10 mm." ;
    ex:valor "10" ;
    ex:identificador "10mm" .

ex:Parametro_ResolucionEje_Encoder8192
    a ex:Parametro ;
    rdfs:label "Resolución del eje (Encoder 8192 + Husillo 10mm)" ;
    ex:textoExtracto "La resolución del eje será; 10 / 8192 = 0,0012 mm." ;
    ex:valor "0.0012" ;
    ex:identificador "0.0012mm" .

ex:Parametro_SSIRESOL_InductosynABS
    a ex:Parametro ;
    rdfs:label "SSIRESOL (Inductosyn ABSIND)" ;
    ex:textoExtracto "Para el caso de SSITYPE = ABSIND (inductosyn ROT+ABS), el incremento del contaje es de 10000 unidades. SSIRESOL = 10000" ;
    ex:valor "10000" .

ex:Parametro_PITCH_Inductosyn2Grad
    a ex:Parametro ;
    rdfs:label "PITCH (Inductosyn 2°)" ;
    ex:textoExtracto "PITCH = 2° ó 4°" ;
    ex:valor "2" ;
    ex:identificador "2°" .

ex:Parametro_PITCH_Inductosyn4Grad
    a ex:Parametro ;
    rdfs:label "PITCH (Inductosyn 4°)" ;
    ex:textoExtracto "PITCH = 2° ó 4°" ;
    ex:valor "4" ;
    ex:identificador "4°" .

ex:Parametro_ResolucionEje_Inductosyn2Grad
    a ex:Parametro ;
    rdfs:label "Resolución del eje (Inductosyn 2°)" ;
    ex:textoExtracto "La resolución del eje será; 2° / 10000 = 0,0002 grados." ;
    ex:valor "0.0002" ;
    ex:identificador "0.0002°" .

ex:Parametro_ResolucionEje_Inductosyn4Grad
    a ex:Parametro ;
    rdfs:label "Resolución del eje (Inductosyn 4°)" ;
    ex:textoExtracto "La resolución del eje será; 4° / 10000 = 0,0004 grados." ;
    ex:valor "0.0004" ;
    ex:identificador "0.0004°" .