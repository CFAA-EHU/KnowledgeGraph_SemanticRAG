@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AceleracionMaximaPermitidaEnCurvatura a ns1:Parametro ;
    rdfs:label "Aceleración máxima permitida en curvatura" ;
    ns1:identificador "MPA.CURVACC" ;
    ns1:textoExtracto "CURVACC Aceleración máxima permitida en curvatura. Parámetro válido para ejes lineales, rotativos y cabezales." ;
    ns1:valor "0" .

ns1:AceleracionMaximaPermitidaEnLasEsquinas a ns1:Parametro ;
    rdfs:label "Aceleración máxima permitida en las esquinas" ;
    ns1:identificador "MPA.CORNERACC" ;
    ns1:textoExtracto "CORNERACC Aceleración máxima permitida en las esquinas. Parámetro válido para ejes lineales, rotativos y cabezales." ;
    ns1:valor "0" .

ns1:JerkMaximoPermitidoEnLasEsquinas a ns1:Parametro ;
    rdfs:label "Jerk máximo permitido en las esquinas" ;
    ns1:identificador "MPA.CORNERJERK" ;
    ns1:textoExtracto "CORNERJERK Jerk máximo permitido en las esquinas. Parámetro válido para ejes lineales, rotativos y cabezales." .

