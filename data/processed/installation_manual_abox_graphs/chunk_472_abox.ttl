@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ReglaAbsolutaFagor20Micras a ex:ComponenteMecanico ;
    rdfs:label "Regla absoluta Fagor" ;
    ex:textoExtracto "Regla absoluta Fagor de 20 micras de paso de regla" ;
    ex:identificador "20 micras" .

ex:Encoder8192PulsosVuelta a ex:ComponenteElectrico ;
    rdfs:label "Encoder de 8192 pulsos por vuelta" ;
    ex:textoExtracto "encoder de 8192 pulsos por vuelta" .

ex:HusilloPaso10mm a ex:ComponenteMecanico ;
    rdfs:label "Husillo de paso 10 mm" ;
    ex:textoExtracto "husillo de paso 10 mm" ;
    ex:identificador "10 mm" .

ex:InductosynROTABS a ex:ComponenteElectrico ;
    rdfs:label "Inductosyn ROT+ABS" ;
    ex:textoExtracto "inductosyn ROT+ABS" .

ex:SSIRESOL200 a ex:Parametro ;
    rdfs:label "SSIRESOL = 200" ;
    ex:textoExtracto "SSIRESOL = 20 µ / 0,1 µ = 200" ;
    ex:valor "200" .

ex:SSIRESOL8192 a ex:Parametro ;
    rdfs:label "SSIRESOL = 8192" ;
    ex:textoExtracto "SSIRESOL = 8192" ;
    ex:valor "8192" .

ex:SSIRESOL10000 a ex:Parametro ;
    rdfs:label "SSIRESOL = 10000" ;
    ex:textoExtracto "SSIRESOL = 10000" ;
    ex:valor "10000" .

ex:ResolucionEje00012mm a ex:Parametro ;
    rdfs:label "Resolución del eje = 0,0012 mm" ;
    ex:textoExtracto "La resolución del eje será; 10 / 8192 = 0,0012 mm" ;
    ex:valor "0,0012 mm" .

ex:ResolucionEje0002Grados a ex:Parametro ;
    rdfs:label "Resolución del eje = 0,0002 grados" ;
    ex:textoExtracto "La resolución del eje será; 2º / 10000 = 0,0002 grados" ;
    ex:valor "0,0002 grados" .

ex:ResolucionEje0004Grados a ex:Parametro ;
    rdfs:label "Resolución del eje = 0,0004 grados" ;
    ex:textoExtracto "La resolución del eje será; 4º / 10000 = 0,0004 grados" ;
    ex:valor "0,0004 grados" .

ex:TablaSSI2625 a ex:Tabla ;
    rdfs:label "Tabla de ejemplos SSI" ;
    ex:textoExtracto "| Ejemplo:\nRegla absoluta Fagor de 20 micras de paso de regla y una resolución digital de 1 dµ.\nSSIRESOL = 20 µ / 0,1 µ = 200.\n| --- |\n| Ejemplo:\nPara el caso de un encoder de 8192 pulsos por vuelta y un husillo de paso 10 mm. PITCH = 10 mm. SSIRESOL = 8192. La resolución del eje será; 10 / 8192 = 0,0012 mm. |\n| Ejemplo:\nPara el caso de SSITYPE = ABSIND (inductosyn ROT+ABS), para un giro de 2 ó 4 grados, y\ndependiendo de si el encoder es de alta o baja resolución, el incremento del contaje es de 10000\nunidades. PITCH = 2º ó 4º\nSSIRESOL = 10000\nLa resolución del eje será; 2º ó 4º / 10000 = 0,0002 ó 0,0004 grados. |" ;
    ex:compuestoPor ex:ReglaAbsolutaFagor20Micras, ex:SSIRESOL200, ex:Encoder8192PulsosVuelta, ex:HusilloPaso10mm, ex:SSIRESOL8192, ex:ResolucionEje00012mm, ex:InductosynROTABS, ex:SSIRESOL10000, ex:ResolucionEje0002Grados, ex:ResolucionEje0004Grados .