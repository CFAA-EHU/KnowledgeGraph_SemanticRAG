@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TRANSDELAY
    a ex:Parametro ;
    rdfs:label "TRANSDELAY" ;
    ex:identificador "TRANSDELAY" ;
    ex:textoExtracto "TRANSDELAY Corrección del retardo introducido por el bus y el regulador. Parámetro valido para ejes lineales y rotativos. Parámetro valido para regulador analógico, Sercos velocidad y simulado. Valores posibles: De 0 a 4*LOOPTIME µs. Valor por defecto: 0." ;
    ex:valor "0-4*LOOPTIME µs"@es .

ex:Parametro_ACFWFACTOR
    a ex:Parametro ;
    rdfs:label "ACFWFACTOR" ;
    ex:identificador "ACFWFACTOR" ;
    ex:textoExtracto "La compensación de los retardos se realiza con el parámetro ACFWFACTOR, que tendrá un valor más alto que si se aplicara el parámetro TRANSDELAY (aproximadamente la suma de TRANSDELAY y ACFWFACTOR en un ajuste analógico o Sercos velocidad)." .

ex:Parametro_ACFGAIN
    a ex:Parametro ;
    rdfs:label "ACFGAIN" ;
    ex:identificador "ACFGAIN" ;
    ex:textoExtracto "Este parámetro afecta al ajuste del ACFWFACTOR y ACFGAIN, y permite conseguir mejores resultados en los cambios de velocidad con menos error de seguimiento." .

ex:Sensor_ControlGapLaser
    a ex:Sensor ;
    rdfs:label "Sensor de control de gap (máquina láser)" ;
    ex:textoExtracto "En máquinas láser con control de gap, el parámetro TRANSDELAY del eje asociado al sensor debe valor 0 (cero), para que la respuesta de la máquina sea igual con y sin control de gap." .

ex:Parametro_TRANSDELAY
    ex:monitoreaParametro ex:Parametro_ACFWFACTOR ;
    ex:monitoreaParametro ex:Parametro_ACFGAIN .

ex:Sensor_ControlGapLaser
    ex:monitoreaParametro ex:Parametro_TRANSDELAY .