@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:NMPG
    a ex:Parametro ;
    rdfs:label "NMPG" ;
    ex:identificador "MPMAN.NMPG" ;
    ex:textoExtracto "NMPG Número de volantes conectados al CNC. Valores posibles: De 0 a 12. Valor por defecto: 0 (no hay volantes). Variable asociada: (V.)MPMAN.NMPG" ;
    ex:valor "0-12" .

ex:MPGRESOL
    a ex:Parametro ;
    rdfs:label "MPGRESOL" ;
    ex:textoExtracto "Para fijar la resolución de cada volante, cuánto avanza en cada una de las posiciones del conmutador, se debe personalizar el parámetro MPGRESOL." .

ex:MANPG
    a ex:Tabla ;
    rdfs:label "MANPG" ;
    ex:textoExtracto "MANPG Tabla de volantes. Este parámetro muestra la lista de volantes disponibles." ;
    ex:documentadoEn ex:ManualModoManual .

ex:MANPG_n
    a ex:Tabla ;
    rdfs:label "MANPG n" ;
    ex:textoExtracto "MANPG n Configuración del volante. Este parámetro muestra la tabla para configurar los volantes." ;
    ex:documentadoEn ex:ManualModoManual .

ex:ManualModoManual
    a ex:Manual ;
    ex:textoExtracto "2.7 Parámetros máquina del modo manual. - 2.7.1 Configuración de los volantes." .

ex:HBLS
    a ex:ComponenteElectrico ;
    rdfs:label "Mando portátil HBLS" ;
    ex:textoExtracto "El mando portátil HBLS no cuenta como volante a la hora de definir este parámetro." .

ex:HBH3
    a ex:ComponenteElectrico ;
    rdfs:label "Terminal remoto HBH3" ;
    ex:textoExtracto "El terminal remoto HBH3/HBH4 cuenta como un volante." .

ex:HBH4
    a ex:ComponenteElectrico ;
    rdfs:label "Terminal remoto HBH4" ;
    ex:textoExtracto "El terminal remoto HBH3/HBH4 cuenta como un volante." .

ex:VolanteGeneral
    a ex:ComponenteElectrico ;
    rdfs:label "Volante general" ;
    ex:textoExtracto "volantes generales para desplazar cualquier eje de la máquina" .

ex:VolanteIndividual
    a ex:ComponenteElectrico ;
    rdfs:label "Volante individual" ;
    ex:textoExtracto "volantes individuales que sólo desplazan el eje al que está asociado" .