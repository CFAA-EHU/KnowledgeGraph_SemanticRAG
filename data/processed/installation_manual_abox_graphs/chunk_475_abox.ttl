@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:VolanteGeneral a ex:ComponenteElectrico ;
    rdfs:label "volante general"@es ;
    ex:textoExtracto "El CNC puede disponer de volantes generales para desplazar cualquier eje de la máquina"@es .

ex:VolanteIndividual a ex:ComponenteElectrico ;
    rdfs:label "volante individual"@es ;
    ex:textoExtracto "volantes individuales que sólo desplazan el eje al que está asociado"@es .

ex:MandoPortatilHBLS a ex:ComponenteElectrico ;
    rdfs:label "mando portátil HBLS"@es ;
    ex:textoExtracto "El mando portátil HBLS no cuenta como volante a la hora de definir este parámetro"@es .

ex:TerminalRemotoHBH3_HBH4 a ex:ComponenteElectrico ;
    rdfs:label "terminal remoto HBH3/HBH4"@es ;
    ex:textoExtracto "El terminal remoto HBH3/HBH4 cuenta como un volante"@es .

ex:ParametroNMPG a ex:Parametro ;
    rdfs:label "NMPG"@es ;
    ex:identificador "NMPG" ;
    ex:textoExtracto "NMPG Número de volantes conectados al CNC. Valores posibles: De 0 a 12. Valor por defecto: 0 (no hay volantes). Variable asociada: (V.)MPMAN.NMPG"@es .

ex:ParametroMPGRESOL a ex:Parametro ;
    rdfs:label "MPGRESOL"@es ;
    ex:identificador "MPGRESOL" ;
    ex:textoExtracto "Para fijar la resolución de cada volante, cuánto avanza en cada una de las posiciones del conmutador, se debe personalizar el parámetro MPGRESOL"@es .

ex:TablaMANPG a ex:Tabla ;
    rdfs:label "tabla de volantes"@es ;
    ex:identificador "MANPG" ;
    ex:textoExtracto "MANPG Tabla de volantes. Este parámetro muestra la lista de volantes disponibles"@es .

ex:TablaConfiguracionVolante a ex:Tabla ;
    rdfs:label "tabla para configurar los volantes"@es ;
    ex:identificador "MANPG n" ;
    ex:textoExtracto "MANPG n Configuración del volante. Este parámetro muestra la tabla para configurar los volantes"@es .