@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaximoErrorDePosicionDelEjeEnHSCCuandoTrabajaFueraDelPlanoTriedo_e9040893f0 a ns1:Parametro ;
    rdfs:label "Máximo error de posición del eje en HSC cuando trabaja fuera del plano/triedo" ;
    ns1:identificador "MPA.MAXERROR" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.MAXERROR[set].xn Máximo error de posición del eje en HSC cuando trabaja fuera del plano/triedo." ;
    ns1:valor "0.1000 mm / 0.00394 inch / 0.1000 grados" .

ns1:ToleranciaPorEjeParaElSuavizadoDeLaTrayectoriaNDimensionalGenerada a ns1:Parametro ;
    rdfs:label "Tolerancia por eje para el suavizado de la trayectoria n-dimensional generada" ;
    ns1:identificador "MPA.CONTERROR" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.CONTERROR[set].xn Para el mecanizado en 5 ejes, este parámetro permite fijar la tolerancia por eje para el suavizado de la trayectoria n-dimensional generada." ;
    ns1:valor "0.1000 mm/º" .

