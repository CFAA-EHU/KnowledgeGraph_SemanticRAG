@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla477_238 a ex:Tabla ;
    ex:textoExtracto """| Orden del teclado. | Numeración de los volantes. |
| --- | --- |
| Primer teclado en el bus. | -1 -2 -3 |
| Segundo teclado en el bus. | -4 -5 -6 |
| Tercer teclado en el bus. | -7 -8 -9 |""" .

ex:Volante_1 a ex:ComponenteMecanico ;
    ex:identificador "-1" ;
    ex:textoExtracto "Numeración de los volantes: -1 -2 -3" .

