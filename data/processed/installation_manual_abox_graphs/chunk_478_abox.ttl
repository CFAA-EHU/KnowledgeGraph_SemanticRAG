@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:OffsetDelPuntoDeReferencia_fc23492bb4 a ns1:Parametro ;
    rdfs:label "Offset del punto de referencia" ;
    ns1:identificador "MPA.REFSHIFT" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales y rotativos." ;
    ns1:valor "0" .

ns1:PosicionDelPuntoDeReferencia a ns1:Parametro ;
    rdfs:label "Posición del punto de referencia" ;
    ns1:identificador "MPA.REFVALUE" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales." ;
    ns1:valor "0" .

ns1:SistemaCaptacion a ns1:Sistema ;
    rdfs:label "Sistema de captación" ;
    ns1:textoExtracto "El sistema de captación no dispone de I0 codificado." ;
    ns1:tieneComponente ns1:DefinirLaCotaDelPuntoDeReferenciaRespectoAlCeroMaquina .

ns1:DefinirLaCotaDelPuntoDeReferenciaRespectoAlCeroMaquina a ns1:AccionProhibida ;
    rdfs:label "Definir la cota del punto de referencia respecto al cero máquina" ;
    ns1:textoExtracto "Definir la cota del punto de referencia respecto al cero máquina." .

