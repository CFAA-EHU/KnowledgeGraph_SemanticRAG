@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:VolanteIndividual a ex:ComponenteMecanico ;
    rdfs:label "volante individual"@es ;
    ex:textoExtracto "Para definir un volante individual, definir el nombre del eje al que está asociado."@es .

ex:VolanteGeneral a ex:ComponenteMecanico ;
    rdfs:label "volante general"@es ;
    ex:textoExtracto "Para definir un volante general, no asignar ningún valor al parámetro, dejarlo en blanco."@es .

ex:TerminalRemotoHBH3_HBH4 a ex:InterfazUsuario ;
    rdfs:label "terminal remoto HBH3/HBH4"@es ;
    ex:textoExtracto "Para el terminal remoto HBH3/HBH4, dejar este parámetro sin definir."@es .

ex:Eje a ex:ComponenteMecanico ;
    rdfs:label "eje"@es ;
    ex:textoExtracto "Un eje se podrá mover indistintamente con su volante individual o con un volante general."@es .

ex:TecladoJog a ex:InterfazUsuario ;
    rdfs:label "teclado de jog"@es ;
    ex:textoExtracto "Para mover un eje con un volante general, hay que seleccionar desde el teclado de jog el eje a desplazar."@es .