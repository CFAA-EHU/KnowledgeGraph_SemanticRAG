@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_ConfiguracionVolantes
    a ex:Parametro ;
    rdfs:label "Parámetro de configuración de volantes"@es ;
    ex:textoExtracto "Para definir un volante individual, definir el nombre del eje al que está asociado. Para definir un volante general, no asignar ningún valor al parámetro, dejarlo en blanco. Para el terminal remoto HBH3/HBH4, dejar este parámetro sin definir."@es ;
    ex:identificador "2.7.1_ConfiguracionVolantes" .

ex:ModoOperacion_Manual
    a ex:ModoOperacion ;
    rdfs:label "Modo manual"@es ;
    ex:textoExtracto "2.7 Parámetros máquina del modo manual."@es ;
    ex:monitoreaParametro ex:Parametro_ConfiguracionVolantes .

ex:InterfazUsuario_TecladoJog
    a ex:InterfazUsuario ;
    rdfs:label "Teclado de jog"@es ;
    ex:textoExtracto "Para mover un eje con un volante general, hay que seleccionar desde el teclado de jog el eje a desplazar."@es ;
    ex:controla ex:Parametro_ConfiguracionVolantes .

ex:TerminalRemoto_HBH3_HBH4
    a ex:InterfazUsuario ;
    rdfs:label "Terminal remoto HBH3/HBH4"@es ;
    ex:textoExtracto "Para el terminal remoto HBH3/HBH4, dejar este parámetro sin definir."@es .