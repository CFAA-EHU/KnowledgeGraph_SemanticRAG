@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CorreccionDeLaCotaDelEncoder a ns1:Parametro ;
    rdfs:label "Corrección de la cota del encoder" ;
    ns1:identificador "REFSHIFT" ;
    ns1:textoExtracto "El valor a definir en REFSHIFT hay que medirlo sin compensación de husillo activa, ya que se considera una corrección a la cota del encoder." .

ns1:VelocidadRapidaDeBusquedaDeReferencia_22cbb8d792 a ns1:Parametro ;
    rdfs:label "Velocidad rápida de búsqueda de referencia" ;
    ns1:identificador "REFFEED1" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales." .

