ex:TablaJOGKEYDEF a ex:Tabla ;
    ex:textoExtracto "Parámetro incluido en la tabla JOGKEYDEF. Hay disponible una tabla para cada teclado de jog." ;
    ex:tieneComponente ex:JOGKEYDEF .

