@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_JOGTYPE
    a ex:Parametro ;
    rdfs:label "JOGTYPE" ;
    ex:textoExtracto "JOGTYPE Comportamiento de las teclas de jog. Valores posibles: Eje pulsado / Eje mantenido. Valor por defecto: Eje pulsado." ;
    ex:valor "Eje pulsado" .

ex:Tabla_ComportamientoTeclasJog a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de valores para teclas de jog" ;
    ex:textoExtracto "Los valores definen el siguiente comportamiento de las teclas. | Valor. | Significado. | --- | --- | 1-, 2-, 3-, .. 10- 1+, 2+, 3+, .. 10+ | Teclas para definir el eje y el sentido de desplazamiento. [...] + - | Teclas para definir el sentido de desplazamiento. [...] R | Tecla de rápido." ;
    ex:detalladoEnEsquema ex:InterfazUsuario_TecladoJog .

ex:InterfazUsuario_TecladoJog
    a ex:InterfazUsuario ;
    rdfs:label "Teclado de jog" ;
    ex:textoExtracto "Este parámetro se aplica cuando en el teclado de jog se dispone de teclas distintas para seleccionar el eje y el sentido de desplazamiento." ;
    ex:tieneComponente ex:Parametro_JOGTYPE .

ex:Parametro_AXISNAME
    a ex:Parametro ;
    rdfs:label "AXISNAME" ;
    ex:textoExtracto "El número corresponde al eje lógico, según el parámetro AXISNAME." .