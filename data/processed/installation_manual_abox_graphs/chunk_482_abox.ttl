@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BusquedaDeReferenciaAvance a ns1:Parametro ;
    rdfs:label "Búsqueda de referencia avance" ;
    ns1:identificador "MPA.REFFEED2" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.REFFEED2[set].xn" .

ns1:TipoDeImpulsoDelI0ParaBusquedaDeReferencia a ns1:Parametro ;
    rdfs:label "Tipo de impulso del I0 para búsqueda de referencia" ;
    ns1:identificador "REFPULSE" ;
    ns1:textoExtracto "REFPULSE Tipo de impulso del I0." .

