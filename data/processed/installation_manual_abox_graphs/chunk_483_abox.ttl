@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:USERKEYDEF a ex:Parametro ;
    rdfs:label "USERKEYDEF" ;
    ex:textoExtracto "USERKEYDEF USERKEYBD2DEF USERKEYBD8DEF Tablas para configurar las teclas de usuario como teclas de jog. Estos parámetros permiten configurar las teclas de usuario de cada panel como teclas de jog . El parámetro USERKEYDEF corresponde al primer panel de jog, USERKEYBD2DEF al segundo y así sucesivamente."@es ;
    ex:valor "n" .

ex:USERKEYBD2DEF a ex:Parametro ;
    rdfs:label "USERKEYBD2DEF" ;
    ex:textoExtracto "USERKEYDEF USERKEYBD2DEF USERKEYBD8DEF Tablas para configurar las teclas de usuario como teclas de jog. Estos parámetros permiten configurar las teclas de usuario de cada panel como teclas de jog . El parámetro USERKEYDEF corresponde al primer panel de jog, USERKEYBD2DEF al segundo y así sucesivamente."@es ;
    ex:valor "n" .

ex:USERKEYBD8DEF a ex:Parametro ;
    rdfs:label "USERKEYBD8DEF" ;
    ex:textoExtracto "USERKEYDEF USERKEYBD2DEF USERKEYBD8DEF Tablas para configurar las teclas de usuario como teclas de jog. Estos parámetros permiten configurar las teclas de usuario de cada panel como teclas de jog . El parámetro USERKEYDEF corresponde al primer panel de jog, USERKEYBD2DEF al segundo y así sucesivamente."@es ;
    ex:valor "n" .

ex:MPMAN_USERKEYDEF a ex:Parametro ;
    rdfs:label "(V.)MPMAN.USERKEYDEF[uk]" ;
    ex:textoExtracto "Variable asociada: (V.)MPMAN.USERKEYDEF[uk] / (V.)MPMAN.USERKEYBDkbDEF[uk]"@es .

ex:MPMAN_USERKEYBDkbDEF a ex:Parametro ;
    rdfs:label "(V.)MPMAN.USERKEYBDkbDEF[uk]" ;
    ex:textoExtracto "Variable asociada: (V.)MPMAN.USERKEYDEF[uk] / (V.)MPMAN.USERKEYBDkbDEF[uk]"@es .

ex:JOGKEYDEF a ex:Parametro ;
    rdfs:label "JOGKEYDEF" ;
    ex:textoExtracto "El significado de este parámetro es similar al parámetro máquina JOGKEYDEF."@es .

ex:Tabla_USERKEYDEF a ex:Tabla ;
    ex:textoExtracto "Parámetro incluido en la tabla USERKEYDEF. Hay disponible una tabla para cada teclado de jog."@es ;
    ex:compuestoPor ex:USERKEYDEF, ex:USERKEYBD2DEF, ex:USERKEYBD8DEF, ex:MPMAN_USERKEYDEF, ex:MPMAN_USERKEYBDkbDEF, ex:JOGKEYDEF .