@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_USERKEYDEF a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla USERKEYDEF" ;
    ex:textoExtracto "Tablas para configurar las teclas de usuario como teclas de jog. [...] Hay disponible una tabla para cada teclado de jog." ;
    ex:identificador "USERKEYDEF" .

ex:Tabla_USERKEYBD2DEF a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla USERKEYBD2DEF" ;
    ex:textoExtracto "USERKEYBD2DEF al segundo [panel de jog]." ;
    ex:identificador "USERKEYBD2DEF" .

ex:Tabla_USERKEYBD8DEF a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla USERKEYBD8DEF" ;
    ex:textoExtracto "USERKEYBD8DEF n" ;
    ex:identificador "USERKEYBD8DEF" .

ex:Parametro_USERKEYDEF
    a ex:Parametro ;
    rdfs:label "Parámetro USERKEYDEF" ;
    ex:textoExtracto "El parámetro USERKEYDEF corresponde al primer panel de jog. [...] Parámetro incluido en la tabla USERKEYDEF." ;
    ex:identificador "USERKEYDEF" ;
    ex:documentadoEn ex:Tabla_USERKEYDEF .

ex:Parametro_USERKEYBD2DEF
    a ex:Parametro ;
    rdfs:label "Parámetro USERKEYBD2DEF" ;
    ex:textoExtracto "USERKEYBD2DEF al segundo [panel de jog]." ;
    ex:identificador "USERKEYBD2DEF" ;
    ex:documentadoEn ex:Tabla_USERKEYBD2DEF .

ex:Parametro_USERKEYBD8DEF
    a ex:Parametro ;
    rdfs:label "Parámetro USERKEYBD8DEF" ;
    ex:textoExtracto "USERKEYBD8DEF n" ;
    ex:identificador "USERKEYBD8DEF" ;
    ex:documentadoEn ex:Tabla_USERKEYBD8DEF .

ex:InterfazUsuario_TecladoJog
    a ex:InterfazUsuario ;
    rdfs:label "Teclado de jog" ;
    ex:textoExtracto "teclado de jog. [...] Cada uno de estos parámetros define la función de una de las teclas de usuario. El número de teclas de usuario disponibles depende del tipo teclado, que en algunos casos puede tener hasta 16 teclas." ;
    ex:tieneComponente ex:Parametro_USERKEYDEF , ex:Parametro_USERKEYBD2DEF , ex:Parametro_USERKEYBD8DEF .

ex:Parametro_JOGKEYDEF
    a ex:Parametro ;
    rdfs:label "Parámetro JOGKEYDEF" ;
    ex:textoExtracto "El significado de este parámetro es similar al parámetro máquina JOGKEYDEF." ;
    ex:identificador "JOGKEYDEF" .