@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:POSINREFBusquedaDeReferenciaConMovimientoDelEjeAlPuntoDeReferencia a ns1:AccionProhibida ;
    rdfs:label "POSINREF Búsqueda de referencia con movimiento del eje al punto de referencia" ;
    ns1:textoExtracto "POSINREF Búsqueda de referencia con movimiento del eje al punto de referencia." .

ns1:TipoDeFlancoDeLaSenalDeI0ParaBusquedaDelPuntoDeReferenciaMaquina a ns1:Parametro ;
    rdfs:label "Tipo de flanco de la señal de I0 para búsqueda del punto de referencia máquina" ;
    ns1:identificador "MPA.REFPULSE" ;
    ns1:textoExtracto "Este parámetro indica el tipo de flanco de la señal de I0 que se utiliza para realizar la búsqueda del punto de referencia máquina." .

