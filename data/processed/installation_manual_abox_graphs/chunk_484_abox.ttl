@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BusquedaDeReferenciaConMovimientoDelEjeAlPuntoDeReferencia a ns1:Parametro ;
    rdfs:label "Búsqueda de referencia con movimiento del eje al punto de referencia" ;
    ns1:identificador "MPA.POSINREF" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:ComponenteElectrico_e297a770be a ns1:ComponenteElectrico ;
    rdfs:label "Motor principal" ;
    ns1:textoExtracto "En ejes con captación motor absoluta, el CNC conoce en todo momento la posición relativa del eje por vuelta del motor." .

ns1:MaximaDiferenciaDePosicionPermitidaParaConsiderarQueNoEsNecesarioVolv_dcbca1b4c0 a ns1:Parametro ;
    rdfs:label "Máxima diferencia de posición permitida para considerar que no es necesario volver a referenciar" ;
    ns1:identificador "MPA.MAXDIFREF" ;
    ns1:textoExtracto "Valores posibles (1): De 0.0001 a 99999.0000 mm. Valores posibles (2): De de 0 a 3936.96850 inch. Valores posibles (3): De 0.0001 a 99999.0000 grados." .

