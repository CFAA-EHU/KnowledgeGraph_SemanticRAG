@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MandoPortatilHBLS a ex:ComponenteElectrico ;
    rdfs:label "mando portátil HBLS"@es ;
    ex:textoExtracto "HBLS Activar mando portátil HBLS. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPMAN.HBLS Este parámetro indica si hay un panel portátil HBLS conectado al CNC a través de la línea serie."@es .

ex:ParametroRSTYPE a ex:Parametro ;
    rdfs:label "RSTYPE"@en ;
    ex:textoExtracto "la línea serie debe estar configurada como RS422 (parámetro RSTYPE)"@es .

ex:ParametroNMPG a ex:Parametro ;
    rdfs:label "NMPG"@en ;
    ex:textoExtracto "El mando portátil HBLS no afecta al cómputo total de volantes del sistema (parámetro NMPG)."@es .

ex:ParametroMPMAN_HBLS a ex:Parametro ;
    rdfs:label "MPMAN.HBLS"@en ;
    ex:identificador "(V.)MPMAN.HBLS" ;
    ex:textoExtracto "Variable asociada: (V.)MPMAN.HBLS Este parámetro indica si hay un panel portátil HBLS conectado al CNC a través de la línea serie."@es .