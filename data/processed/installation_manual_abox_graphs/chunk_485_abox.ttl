@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_HBLS
    a ex:Parametro ;
    rdfs:label "HBLS (Activar mando portátil)"@es ;
    ex:identificador "MPMAN.HBLS" ;
    ex:valor "No" ;
    ex:textoExtracto "HBLS Activar mando portátil HBLS. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPMAN.HBLS"@es .

ex:InterfazUsuario_HBLS
    a ex:InterfazUsuario ;
    rdfs:label "Mando portátil HBLS"@es ;
    ex:textoExtracto "mando portátil HBLS conectado al CNC a través de la línea serie"@es ;
    ex:monitoreaParametro ex:Parametro_HBLS .

ex:Parametro_RSTYPE
    a ex:Parametro ;
    rdfs:label "RSTYPE (Tipo de línea serie)"@es ;
    ex:identificador "RSTYPE" ;
    ex:textoExtracto "la línea serie debe estar configurada como RS422 (parámetro RSTYPE)"@es .

ex:Parametro_NMPG
    a ex:Parametro ;
    rdfs:label "NMPG (Volantes del sistema)"@es ;
    ex:identificador "NMPG" ;
    ex:textoExtracto "no afecta al cómputo total de volantes del sistema (parámetro NMPG)"@es .