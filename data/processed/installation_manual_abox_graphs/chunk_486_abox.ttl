@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_1d0c7c95a0 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:monitoreaParametro ns1:MaximaDiferenciaDePosicion,
        ns1:OffsetRespectoAlI0Codificado,
        ns1:VariableVMPAABSOFF ;
    ns1:textoExtracto "Si MAXDIFREF es igual a 0, el CNC siempre desactiva la marca REFPOIN(axis)." .

ns1:MaximaDiferenciaDePosicion a ns1:Parametro ;
    rdfs:label "Máxima diferencia de posición" ;
    ns1:identificador "MAXDIFREF" ;
    ns1:textoExtracto "Si tras un error o una caída del anillo Sercos, la diferencia es mayor que MAXDIFREF" .

ns1:OffsetRespectoAlI0Codificado a ns1:Parametro ;
    rdfs:label "Offset respecto al I0 codificado" ;
    ns1:identificador "ABSOFF" ;
    ns1:textoExtracto "Valores posibles (3): Entre ±99999.9999 grados." .

ns1:VariableVMPAABSOFF a ns1:Parametro ;
    rdfs:label "Variable asociada al offset del I0 codificado" ;
    ns1:identificador "V.MPA.ABSOFF" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.ABSOFF[set].xn" .

