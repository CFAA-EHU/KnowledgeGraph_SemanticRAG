@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:VolanteIndividualX a ex:ComponenteMecanico ;
    rdfs:label "Volante individual del eje X" ;
    ex:textoExtracto "Volante individual para el eje X. Entrada captación: Teclado (MPG1). Disco graduado de 100 posiciones. Impulsos/vuelta: 100 Resoluciones (X): 0.001, 0.01, 0.1" .

ex:VolanteIndividualY a ex:ComponenteMecanico ;
    rdfs:label "Volante individual del eje Y" ;
    ex:textoExtracto "Volante individual para el eje Y. Entrada captación: Teclado (MPG2). Disco graduado de 100 posiciones. Impulsos/vuelta: 200 Resoluciones (Y): 0.001, 0.01, 0.1" .

ex:VolanteGeneralZA a ex:ComponenteMecanico ;
    rdfs:label "Volante general para los ejes Z, A" ;
    ex:textoExtracto "Volante general para el resto de ejes (Z, A). Entrada captación: Contador (X1). Disco graduado de 100 posiciones. Impulsos/vuelta: 100 Resoluciones (Z): 0.001, 0.01, 0.1 Resoluciones (A): 0.01, 0.1, 1" .

ex:TecladoMPG1 a ex:ComponenteElectrico ;
    rdfs:label "Teclado (MPG1)" ;
    ex:textoExtracto "Entrada captación: Teclado (MPG1)" .

ex:TecladoMPG2 a ex:ComponenteElectrico ;
    rdfs:label "Teclado (MPG2)" ;
    ex:textoExtracto "Entrada captación: Teclado (MPG2)" .

ex:ContadorX1 a ex:ComponenteElectrico ;
    rdfs:label "Contador (X1)" ;
    ex:textoExtracto "Entrada captación: Contador (X1)" .

ex:EsquemaPersonalizacionVolantes a ex:Esquema ;
    rdfs:label "Esquema de personalización de volantes" ;
    ex:textoExtracto "Personalización de los volantes. En una máquina con ejes X, Y, Z, A se desea disponer de un volante individual para el eje X, un volante individual para el eje Y e un volante general para los ejes Z, A." ;
    ex:tieneComponente ex:VolanteIndividualX, ex:VolanteIndividualY, ex:VolanteGeneralZA, ex:TecladoMPG1, ex:TecladoMPG2, ex:ContadorX1 .