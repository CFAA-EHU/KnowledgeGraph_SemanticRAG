@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_4b2aeea3bc a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:ManualDeOperacion ;
    ns1:textoExtracto "Para que el CNC muestre la posición respecto al cero máquina (OM) es necesario personalizar este parámetro con la posición",
        "Tras leer dos I0 codificados seguidos (separados 20 ó 100 mm) se conoce la posición de la máquina respecto al cero del cristal (OG). Para que el CNC muestre la posición respecto al cero máquina (OM) es necesario personal..." .

ns1:PosicionRespectoAlCeroMaquinaOM a ns1:Parametro ;
    rdfs:label "Posición respecto al cero máquina (OM)" ;
    ns1:documentadoEn ns1:ManualDeOperacion ;
    ns1:textoExtracto "Para que el CNC muestre la posición respecto al cero máquina (OM) es necesario personalizar este parámetro con la posición" .

