ex:Tabla_ParametrosMPG_488 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de configuración MPG (volante y teclado)"@es ;
    ex:textoExtracto "COUNTERTYPE | Teclado. | Volante conectado al teclado. [...] MPGRESOL 100 | 0.05 | Resolución 0.1"@es ;
    ex:documentadoEn ex:Pagina_244_247 .

ex:Parametro_COUNTERTYPE
    a ex:Parametro ;
    rdfs:label "COUNTERTYPE" ;
    ex:identificador "COUNTERTYPE" ;
    ex:valor "Teclado" ;
    ex:textoExtracto "COUNTERTYPE | Teclado. | Volante conectado al teclado."@es ;
    ex:documentadoEn ex:Tabla_ParametrosMPG_488 .

