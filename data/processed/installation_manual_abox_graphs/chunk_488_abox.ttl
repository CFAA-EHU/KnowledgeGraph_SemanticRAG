    a ex:Parametro ;
    rdfs:label "COUNTERID" ;
    ex:identificador "COUNTERID" ;
    ex:valor "-2" ;
    ex:textoExtracto "COUNTERID | -2 | Conector MPG2."@es ;
    ex:documentadoEn ex:Tabla_ParametrosMPG_488 .

ex:Parametro_MPGAXIS
    a ex:Parametro ;
    rdfs:label "MPGAXIS" ;
    ex:identificador "MPGAXIS" ;
