ex:InterfazUsuario_VolanteTeclado
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de volante conectado a teclado"@es ;
    ex:textoExtracto "Volante conectado al teclado. [...] Volante asociado al resto de ejes (Z + A)."@es ;
    ex:documentadoEn ex:Tabla_ParametrosMPG_488 ;
