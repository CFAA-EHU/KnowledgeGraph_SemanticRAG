@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FactorExternoParaI0Codificados a ns1:Parametro ;
    rdfs:label "Factor externo para I0 codificados" ;
    ns1:identificador "EXTMULT" ;
    ns1:textoExtracto "EXTMULT Factor externo para I0 codificados. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y simulado. Valores posibles: De 0 a 65535. Valor por defecto: 0." ;
    ns1:valor "De 0 a 65535. Valor por defecto: 0." .

ns1:PosicionCeroDelCristal a ns1:Parametro ;
    rdfs:label "Posición cero del cristal" ;
    ns1:textoExtracto "OG Posición cero del cristal." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "Para que el CNC muestre la posición respecto al cero máquina (OM) es necesario personalizar este parámetro con la posición que ocupa el cero máquina (OM) respecto al cero del cristal (OG)." .

ns1:SistemaHidraulico a ns1:Sistema ;
    rdfs:label "Sistema Hidráulico" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro con I0TYPE = Codificado." .

