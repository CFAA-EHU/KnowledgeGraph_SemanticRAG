@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Esquema_488 a ex:Tabla ;
    ex:textoExtracto """| Parámetro máquina. | Valor. | Significado. |
| --- | --- | --- |
| COUNTERTYPE | Teclado. | Volante conectado al teclado. |
| COUNTERID | -2 | Conector MPG2. |
| MPGAXIS | Y | Eje asociado. |
| MPGRESOL 1 | 0.0005 | Resolución 0.001 |
| MPGRESOL 10 | 0.005 | Resolución 0.01 |
| MPGRESOL 100 | 0.05 | Resolución 0.1 |
 Volante asociado al resto de ejes (Z + A).""" .

ex:ComponenteElectrico_MPG2 a ex:ComponenteElectrico ;
    ex:identificador "MPG2" ;
    ex:textoExtracto "Conector MPG2." .

ex:ComponenteElectrico_Teclado a ex:ComponenteElectrico ;
    ex:textoExtracto "Teclado." .

ex:Parametro_COUNTERTYPE a ex:Parametro ;
    ex:identificador "COUNTERTYPE" ;
    ex:valor "Teclado" ;
    ex:textoExtracto "COUNTERTYPE | Teclado. | Volante conectado al teclado." ;
    ex:detalladoEnEsquema ex:Esquema_488 .

ex:Parametro_COUNTERID a ex:Parametro ;
    ex:identificador "COUNTERID" ;
    ex:valor "-2" ;
    ex:textoExtracto "COUNTERID | -2 | Conector MPG2." ;
    ex:detalladoEnEsquema ex:Esquema_488 .

ex:Parametro_MPGAXIS a ex:Parametro ;
    ex:identificador "MPGAXIS" ;
    ex:valor "Y" ;
    ex:textoExtracto "MPGAXIS | Y | Eje asociado." ;
    ex:detalladoEnEsquema ex:Esquema_488 .

ex:Parametro_MPGRESOL_1 a ex:Parametro ;
    ex:identificador "MPGRESOL 1" ;
    ex:valor "0.0005" ;
    ex:textoExtracto "MPGRESOL 1 | 0.0005 | Resolución 0.001" ;
    ex:detalladoEnEsquema ex:Esquema_488 .

ex:Parametro_MPGRESOL_10 a ex:Parametro ;
    ex:identificador "MPGRESOL 10" ;
    ex:valor "0.005" ;
    ex:textoExtracto "MPGRESOL 10 | 0.005 | Resolución 0.01" ;
    ex:detalladoEnEsquema ex:Esquema_488 .

ex:Parametro_MPGRESOL_100 a ex:Parametro ;
    ex:identificador "MPGRESOL 100" ;
    ex:valor "0.05" ;
    ex:textoExtracto "MPGRESOL 100 | 0.05 | Resolución 0.1" ;
    ex:detalladoEnEsquema ex:Esquema_488 .

ex:Parametro_COUNTERTYPE ex:alimenta ex:ComponenteElectrico_Teclado ;
    ex:textoExtracto "COUNTERTYPE | Teclado. | Volante conectado al teclado." .

ex:Parametro_COUNTERID ex:alimenta ex:ComponenteElectrico_MPG2 ;
    ex:textoExtracto "COUNTERID | -2 | Conector MPG2." .