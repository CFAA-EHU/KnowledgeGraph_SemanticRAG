@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_9aab83cf91 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro con I0TYPE = Codificado." .

ns1:PasoEntre2I0CodificadosFijos a ns1:Parametro ;
    rdfs:label "Paso entre 2 I0 codificados fijos" ;
    ns1:identificador "I0CODDI1" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "1000" .

ns1:PasoEntre2I0CodificadosVariables a ns1:Parametro ;
    rdfs:label "Paso entre 2 I0 codificados variables" ;
    ns1:identificador "I0CODDI2" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." ;
    ns1:valor "1001" .

