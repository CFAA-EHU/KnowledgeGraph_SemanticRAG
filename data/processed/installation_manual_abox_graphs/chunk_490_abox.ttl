@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MTABLESIZE a ex:Parametro ;
    rdfs:label "MTABLESIZE" ;
    ex:identificador "MTABLESIZE" ;
    ex:textoExtracto "MTABLESIZE Número de elementos de la tabla. Valores posibles: de 0 a 200. Valor por defecto: 50. Variable asociada: (V.)MPM.MTABLESIZE Este parámetro indica el número de funciones M a definir en la tabla." ;
    ex:valor "50" .

ex:MPM_MTABLESIZE a ex:Parametro ;
    rdfs:label "(V.)MPM.MTABLESIZE" ;
    ex:identificador "(V.)MPM.MTABLESIZE" ;
    ex:textoExtracto "Variable asociada: (V.)MPM.MTABLESIZE" .

ex:DATA a ex:Tabla ;
    rdfs:label "DATA" ;
    ex:textoExtracto "DATA Tabla de funciones M. Muestra la tabla de personalización de funciones M." .

ex:MNUM a ex:Parametro ;
    rdfs:label "MNUM" ;
    ex:identificador "MNUM" ;
    ex:textoExtracto "MNUM Número de la función M. Valores posibles: de 0 a 65535. Variable asociada: (V.)MPM.MNUM[pos] Parámetro incluido en la tabla DATA. Este parámetro indica el número de la función M." .

ex:MPM_MNUM a ex:Parametro ;
    rdfs:label "(V.)MPM.MNUM[pos]" ;
    ex:identificador "(V.)MPM.MNUM[pos]" ;
    ex:textoExtracto "Variable asociada: (V.)MPM.MNUM[pos]" .

ex:SYNCHTYPE a ex:Parametro ;
    rdfs:label "SYNCHTYPE" ;
    ex:identificador "SYNCHTYPE" ;
    ex:textoExtracto "SYNCHTYPE Tipo de sincronización. Valores posibles: Sin sincronización / Antes-Antes / Antes-Después / Después-Después. Valor por defecto: Antes-Antes. Variable asociada: (V.)MPM.SYNCHTYPE[pos] Parámetro incluido en la tabla DATA. Como las funciones M pueden programarse junto al desplazamiento de los ejes en un mismo bloque, hay que indicar cuándo se envía la función al PLC y cuándo se comprueba que ya ha sido ejecutada (sincronización)." .

ex:MPM_SYNCHTYPE a ex:Parametro ;
    rdfs:label "(V.)MPM.SYNCHTYPE[pos]" ;
    ex:identificador "(V.)MPM.SYNCHTYPE[pos]" ;
    ex:textoExtracto "Variable asociada: (V.)MPM.SYNCHTYPE[pos]" .

ex:MPROGNAME a ex:Parametro ;
    rdfs:label "MPROGNAME" ;
    ex:identificador "MPROGNAME" ;
    ex:textoExtracto "Para cada función M hay que definir los siguientes campos. | DATA |  | | --- | --- | | MNUM | Número de la función M. | | SYNCHTYPE | Tipo de sincronización. | | MPROGNAME | Nombre de subrutina asociada a la función M. | | MTIME | Tiempo estimado para la función M. | | MPLC | Enviar la función M al PLC en la búsqueda de bloque. | | COMMENT | Descripción de la función M." .

ex:MTIME a ex:Parametro ;
    rdfs:label "MTIME" ;
    ex:identificador "MTIME" ;
    ex:textoExtracto "Para cada función M hay que definir los siguientes campos. | DATA |  | | --- | --- | | MNUM | Número de la función M. | | SYNCHTYPE | Tipo de sincronización. | | MPROGNAME | Nombre de subrutina asociada a la función M. | | MTIME | Tiempo estimado para la función M. | | MPLC | Enviar la función M al PLC en la búsqueda de bloque. | | COMMENT | Descripción de la función M." .

ex:MPLC a ex:Parametro ;
    rdfs:label "MPLC" ;
    ex:identificador "MPLC" ;
    ex:textoExtracto "Para cada función M hay que definir los siguientes campos. | DATA |  | | --- | --- | | MNUM | Número de la función M. | | SYNCHTYPE | Tipo de sincronización. | | MPROGNAME | Nombre de subrutina asociada a la función M. | | MTIME | Tiempo estimado para la función M. | | MPLC | Enviar la función M al PLC en la búsqueda de bloque. | | COMMENT | Descripción de la función M." .

ex:COMMENT a ex:Parametro ;
    rdfs:label "COMMENT" ;
    ex:identificador "COMMENT" ;
    ex:textoExtracto "Para cada función M hay que definir los siguientes campos. | DATA |  | | --- | --- | | MNUM | Número de la función M. | | SYNCHTYPE | Tipo de sincronización. | | MPROGNAME | Nombre de subrutina asociada a la función M. | | MTIME | Tiempo estimado para la función M. | | MPLC | Enviar la función M al PLC en la búsqueda de bloque. | | COMMENT | Descripción de la función M." .

