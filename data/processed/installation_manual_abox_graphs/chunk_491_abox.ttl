@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TablaFuncionesM a ex:Tabla ;
    ex:textoExtracto """| Tipo de sincronización. | Significado. |
| --- | --- |
| Sin sincronización. | Función M sin sincronización. |
| Antes - Antes. | La función M se envía al PLC y se sincroniza antes del
movimiento. |
| Antes - Después. | La función M se envía al PLC antes del movimiento y se
sincroniza después. |
| Después - Después. | La función M se envía al PLC y se sincroniza después del
movimiento. |""" .

ex:SinSincronizacion a ex:ModoOperacion ;
    ex:textoExtracto "Sin sincronización. | Función M sin sincronización." .

ex:AntesAntes a ex:ModoOperacion ;
    ex:textoExtracto "Antes - Antes. | La función M se envía al PLC y se sincroniza antes del movimiento." .

ex:AntesDespues a ex:ModoOperacion ;
    ex:textoExtracto "Antes - Después. | La función M se envía al PLC antes del movimiento y se sincroniza después." .

ex:DespuesDespues a ex:ModoOperacion ;
    ex:textoExtracto "Después - Después. | La función M se envía al PLC y se sincroniza después del movimiento." .

ex:TablaFuncionesM a ex:Tabla ;
    ex:compuestoPor ex:SinSincronizacion, ex:AntesAntes, ex:AntesDespues, ex:DespuesDespues .