@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaFuncionesM_491 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de funciones M (sincronización)"@es ;
    ex:textoExtracto """
| Tipo de sincronización. | Significado. |
| --- | --- |
| Sin sincronización. | Función M sin sincronización. |
| Antes - Antes. | La función M se envía al PLC y se sincroniza antes del movimiento. |
| Antes - Después. | La función M se envía al PLC antes del movimiento y se sincroniza después. |
| Después - Después. | La función M se envía al PLC y se sincroniza después del movimiento. |
"""@es ;
    ex:documentadoEn ex:ManualBrochado ;
    ex:identificador "2.8.1" .

ex:Parametro_SinSincronizacion
    a ex:Parametro ;
    rdfs:label "Sin sincronización (función M)"@es ;
    ex:textoExtracto "Función M sin sincronización."@es ;
    ex:documentadoEn ex:TablaFuncionesM_491 ;
    ex:valor "Sin sincronización" .

ex:Parametro_AntesAntes
    a ex:Parametro ;
    rdfs:label "Antes - Antes (sincronización función M)"@es ;
    ex:textoExtracto "La función M se envía al PLC y se sincroniza antes del movimiento."@es ;
    ex:documentadoEn ex:TablaFuncionesM_491 ;
    ex:valor "Antes - Antes" .

ex:Parametro_AntesDespues
    a ex:Parametro ;
    rdfs:label "Antes - Después (sincronización función M)"@es ;
    ex:textoExtracto "La función M se envía al PLC antes del movimiento y se sincroniza después."@es ;
    ex:documentadoEn ex:TablaFuncionesM_491 ;
    ex:valor "Antes - Después" .

ex:Parametro_DespuesDespues
    a ex:Parametro ;
    rdfs:label "Después - Después (sincronización función M)"@es ;
    ex:textoExtracto "La función M se envía al PLC y se sincroniza después del movimiento."@es ;
    ex:documentadoEn ex:TablaFuncionesM_491 ;
    ex:valor "Después - Después" .