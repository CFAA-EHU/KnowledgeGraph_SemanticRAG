@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CodificacionDelEncoderRotativo1 a ns1:Parametro ;
    rdfs:label "Codificación del encoder rotativo 1" ;
    ns1:identificador "I0CODDI1" ;
    ns1:textoExtracto "HO | SO | 90.000 impulsos. | 1000 | 1001" .

ns1:CodificacionDelEncoderRotativo2 a ns1:Parametro ;
    rdfs:label "Codificación del encoder rotativo 2" ;
    ns1:identificador "I0CODDI2" ;
    ns1:textoExtracto "HO | SO | 90.000 impulsos. | 1000 | 1001" .

ns1:MultiplicadorExterno a ns1:Parametro ;
    rdfs:label "Multiplicador externo" ;
    ns1:identificador "EXTMULT" ;
    ns1:textoExtracto "Número de ondas entre I0 fijos | 20000/(20 x EXTMULT) = 1000" .

ns1:TipoDeCodificacionI0 a ns1:Parametro ;
    rdfs:label "Tipo de codificación I0" ;
    ns1:identificador "I0TYPE" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro con I0TYPE = Codificado." .

ns1:VariableAsociadaAlCodificadoI0 a ns1:Parametro ;
    rdfs:label "Variable asociada al codificado I0" ;
    ns1:identificador "MPA.I0CODDI2" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.I0CODDI2[set].xn" .

