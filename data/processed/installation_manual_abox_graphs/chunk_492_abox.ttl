@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_bf2848404f a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Si se desactiva esta vigilancia, el CNC muestra en el encendido un mensaje indicando que dicha seguridad está deshabilitada." .

ns1:ErrorDeSeguimientoMaximoEnParado_1032c54164 a ns1:Parametro ;
    rdfs:label "Error de seguimiento máximo en parado" ;
    ns1:identificador "MINFLWE" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos." .

ns1:PuestaAPunto a ns1:TareaMantenimiento ;
    rdfs:label "Puesta a punto" ;
    ns1:textoExtracto "Esta situación únicamente debería permitirse durante la puesta a punto; una vez finalizada la puesta a punto, esta vigilancia debe estar habilitada." .

ns1:TipoDeMonitorizacionDelErrorDeSeguimiento_60c7e14d93 a ns1:Parametro ;
    rdfs:label "Tipo de monitorización del error de seguimiento" ;
    ns1:identificador "FLWEMONITOR" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." .

