@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MPLC
    a ex:Parametro ;
    rdfs:label "MPLC" ;
    ex:textoExtracto "MPLC Enviar la función M al PLC en la búsqueda de bloque. Valores posibles: Sí / No. Valor por defecto: Sí." ;
    ex:valor "Sí" ;
    ex:identificador "MPM.MPLC[pos]" .

ex:Tabla_FuncionesM a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de funciones M" ;
    ex:textoExtracto "2.8.1 Tabla de funciones M" ;
    ex:tieneComponente ex:Parametro_MPLC .