@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MPLC a ex:Parametro ;
    rdfs:label "MPLC" ;
    ex:identificador "(V.)MPM.MPLC[pos]" ;
    ex:textoExtracto "MPLC Enviar la función M al PLC en la búsqueda de bloque. Valores posibles: Sí / No. Valor por defecto: Sí." ;
    ex:valor "Sí" .

ex:TablaFuncionesM a ex:Tabla ;
    ex:textoExtracto "tabla de funciones M" ;
    ex:detalladoEnEsquema ex:MPLC .