@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MPLC a ex:Parametro ;
    rdfs:label "MPLC" ;
    ex:identificador "(V.)MPM.MPLC[pos]" ;
    ex:textoExtracto "MPLC Enviar la función M al PLC en la búsqueda de bloque. Valores posibles: Sí / No. Valor por defecto: Sí." ;
    ex:valor "Sí" ;
    ex:tieneFrecuencia ex:FrecuenciaInclusionTablaDATA .

ex:COMMENT a ex:Parametro ;
    rdfs:label "COMMENT" ;
    ex:identificador "(V.)MPM.COMMENT[pos]" ;
    ex:textoExtracto "Parámetro incluido en la tabla DATA. Este campo indica si se debe enviar la función M al PLC durante la búsqueda de bloque. COMMENT Descripción de la función M. Variable asociada: (V.)MPM.COMMENT[pos] Parámetro incluido en la tabla DATA. Este campo ofrece la posibilidad de asociar una pequeña descripción a la función M. Este campo es informativo; no es utilizado por el CNC. Los comentarios se guardan en el archivo MComments.txt y se puede tener un archivo por cada idioma. Estos archivos se guardan en la carpeta ..\\MTB\\Data\\Lang." ;
    ex:valor "Descripción de la función M" .

ex:FrecuenciaInclusionTablaDATA a ex:Frecuencia ;
    ex:textoExtracto "Parámetro incluido en la tabla DATA." .

ex:TablaDATA a ex:Tabla ;
    ex:textoExtracto "Parámetro incluido en la tabla DATA." ;
    ex:compuestoPor ex:MPLC, ex:COMMENT .