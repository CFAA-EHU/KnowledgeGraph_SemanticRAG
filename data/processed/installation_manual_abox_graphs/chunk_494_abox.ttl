@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MPLC
    a               ex:Parametro ;
    rdfs:label      "MPLC" ;
    ex:textoExtracto "MPLC Enviar la función M al PLC en la búsqueda de bloque. Valores posibles: Sí / No. Valor por defecto: Sí."@es ;
    ex:valor         "Sí" ;
    ex:identificador "(V.)MPM.MPLC[pos]" .

ex:Parametro_COMMENT
    a               ex:Parametro ;
    rdfs:label      "COMMENT" ;
    ex:textoExtracto "COMMENT Descripción de la función M. Este campo ofrece la posibilidad de asociar una pequeña descripción a la función M. Este campo es informativo; no es utilizado por el CNC."@es ;
    ex:identificador "(V.)MPM.COMMENT[pos]" .

ex:Tabla_DATA a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla DATA" ;
    ex:textoExtracto "Parámetro incluido en la tabla DATA."@es ;
    ex:documentadoEn ex:Manual_Maquina .

ex:Archivo_MComments
    a               ex:InterfazUsuario ;
    rdfs:label      "MComments.txt" ;
    ex:textoExtracto "Los comentarios se guardan en el archivo MComments.txt y se puede tener un archivo por cada idioma. Estos archivos se guardan en la carpeta ..\\MTB\\Data\\Lang."@es .