@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorDeSeguimientoMaximoEnMovimiento a ns1:Parametro ;
    rdfs:label "Error de seguimiento máximo en movimiento" ;
    ns1:identificador "MPA.MAXFLWE" ;
    ns1:textoExtracto "Valores posibles (1): De 0.001 a 99999.9999 mm. Valor por defecto: 30.0000 mm / 1.18110 inch / 30.0000 grados." .

ns1:MaximoErrorDeSeguimientoPermitidoCuandoElEjeEstaParado_2f387123a1 a ns1:Parametro ;
    rdfs:label "Máximo error de seguimiento permitido cuando el eje está parado" ;
    ns1:identificador "MPA.MINFLWE" ;
    ns1:textoExtracto "De 0.001 a 99999.9999 grados. Valor por defecto: 1.0000 mm / 0.03937 inch / 1.0000 grados." .

ns1:PorcentajeDeDesviacionPermitidoParaElErrorDeSeguimiento a ns1:Parametro ;
    rdfs:label "Porcentaje de desviación permitido para el error de seguimiento" ;
    ns1:identificador "MPA.FEDYNFAC" ;
    ns1:textoExtracto "Valores posibles: De 0 a 100 %. Valor por defecto: 50." .

