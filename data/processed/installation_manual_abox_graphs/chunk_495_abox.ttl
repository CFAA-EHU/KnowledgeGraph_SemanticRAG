@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_KINID
    a ex:Parametro ;
    rdfs:label "Parámetro máquina de canal KINID"@es ;
    ex:textoExtracto "El parámetro máquina de canal KINID indica el número de cinemática (no tipo) que asume el CNC en ese canal tras el encendido."@es ;
    ex:identificador "KINID" .

ex:Sentencia_KIN_ID
    a ex:InterfazUsuario ;
    rdfs:label "Sentencia #KIN ID"@es ;
    ex:textoExtracto "Para seleccionar una cinemática desde el programa pieza, utilizar la sentencia #KIN ID."@es ;
    ex:identificador "#KIN ID" .

ex:Tabla_OrdenEjesCinematica a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Orden de ejes en cinemática"@es ;
    ex:textoExtracto "Orden del eje | Significado | Eje 1º | Primer eje principal del plano (abscisas) | Eje 2º | Segundo eje principal del plano (ordenadas) | Eje 3º | Eje longitudinal | Eje 4º | Cuarto eje de la cinemática | Eje 5º | Quinto eje de la cinemática | Eje 6º | Sexto eje de la cinemática | Eje 7º | Séptimo eje de la cinemática | Eje 8º | Octavo eje de la cinemática | Eje 9º y siguientes | Resto de los ejes."@es ;
    ex:documentadoEn ex:Manual_CNC .

ex:Parametro_NumEjesCinematica
    a ex:Parametro ;
    rdfs:label "Número de ejes por cinemática"@es ;
    ex:textoExtracto "Una cinemática puede estar configurada por entre 3 y 8 ejes."@es ;
    ex:valor "3-8" .

ex:Parametro_CompensacionCabezal
    a ex:Parametro ;
    rdfs:label "Compensación de cabezal en ejes lineales"@es ;
    ex:textoExtracto "Los 3 primeros ejes deben ser lineales sobre los que se aplica la compensación de cabezal."@es .