@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ParametroMaquina_KINID a ex:Parametro ;
    rdfs:label "KINID" ;
    ex:textoExtracto "El parámetro máquina de canal KINID indica el número de cinemática (no tipo) que asume el CNC en ese canal tras el encendido." ;
    ex:valor "Canal KINID" .

ex:Sentencia_KIN_ID a ex:InterfazUsuario ;
    rdfs:label "#KIN ID" ;
    ex:textoExtracto "Para seleccionar una cinemática desde el programa pieza, utilizar la sentencia #KIN ID." .

ex:ModoOperacion_Cinematica a ex:ModoOperacion ;
    rdfs:label "Cinemática" ;
    ex:textoExtracto "Se pueden personalizar hasta 6 cinemáticas distintas para una misma máquina, debiendo indicarse en cada una de ellas el tipo de cinemática a aplicar." .

ex:ModoOperacion_CinematicaPredefinida a ex:ModoOperacion ;
    rdfs:label "Cinemática predefinida" ;
    ex:textoExtracto "El CNC ofrece una serie de cinemáticas predefinidas y que se pueden configurar fácilmente desde los parámetros máquina." .

ex:ModoOperacion_CinematicaOEM a ex:ModoOperacion ;
    rdfs:label "Cinemática OEM" ;
    ex:textoExtracto "Además de estas cinemáticas, el OEM puede integrar 6 cinemáticas adicionales. La integración de las cinemáticas OEM se realiza a través de un API genérico y posteriormente se configuran en estos parámetros máquina." .

ex:Sistema_CNC a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "El CNC ofrece una serie de cinemáticas predefinidas y que se pueden configurar fácilmente desde los parámetros máquina." .

ex:ParametroMaquina_Canal a ex:Parametro ;
    rdfs:label "Canal" ;
    ex:textoExtracto "Puede haber activa una cinemática por canal." .

ex:ComponenteElectrico_CanalCinematica a ex:ComponenteElectrico ;
    rdfs:label "Canal de cinemática" ;
    ex:textoExtracto "Puede haber activa una cinemática por canal." .

ex:ParametroMaquina_Eje1 a ex:Parametro ;
    rdfs:label "Eje 1º" ;
    ex:textoExtracto "Eje 1º: Primer eje principal del plano (abscisas)." .

ex:ParametroMaquina_Eje2 a ex:Parametro ;
    rdfs:label "Eje 2º" ;
    ex:textoExtracto "Eje 2º: Segundo eje principal del plano (ordenadas)." .

ex:ParametroMaquina_Eje3 a ex:Parametro ;
    rdfs:label "Eje 3º" ;
    ex:textoExtracto "Eje 3º: Eje longitudinal." .

ex:ParametroMaquina_Eje4 a ex:Parametro ;
    rdfs:label "Eje 4º" ;
    ex:textoExtracto "Eje 4º: Cuarto eje de la cinemática." .

ex:ParametroMaquina_Eje5 a ex:Parametro ;
    rdfs:label "Eje 5º" ;
    ex:textoExtracto "Eje 5º: Quinto eje de la cinemática." .

ex:ParametroMaquina_Eje6 a ex:Parametro ;
    rdfs:label "Eje 6º" ;
    ex:textoExtracto "Eje 6º: Sexto eje de la cinemática." .

ex:ParametroMaquina_Eje7 a ex:Parametro ;
    rdfs:label "Eje 7º" ;
    ex:textoExtracto "Eje 7º: Séptimo eje de la cinemática." .

ex:ParametroMaquina_Eje8 a ex:Parametro ;
    rdfs:label "Eje 8º" ;
    ex:textoExtracto "Eje 8º: Octavo eje de la cinemática." .

ex:Tabla_OrdenEjesCinematica a ex:Tabla ;
    ex:textoExtracto "Orden del eje. | Significado. | Eje 1º | Primer eje principal del plano (abscisas). | Eje 2º | Segundo eje principal del plano (ordenadas). | Eje 3º | Eje longitudinal. | Eje 4º | Cuarto eje de la cinemática. | Eje 5º | Quinto eje de la cinemática. | Eje 6º | Sexto eje de la cinemática. | Eje 7º | Séptimo eje de la cinemática. | Eje 8º | Octavo eje de la cinemática. | Eje 9º y siguientes. | Resto de los ejes." ;
    ex:detalladoEnEsquema ex:ParametroMaquina_Eje1, ex:ParametroMaquina_Eje2, ex:ParametroMaquina_Eje3, ex:ParametroMaquina_Eje4, ex:ParametroMaquina_Eje5, ex:ParametroMaquina_Eje6, ex:ParametroMaquina_Eje7, ex:ParametroMaquina_Eje8 .