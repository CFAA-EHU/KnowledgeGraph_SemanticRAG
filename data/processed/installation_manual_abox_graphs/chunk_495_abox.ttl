@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FactorDinamicoDeSeguimiento a ns1:Parametro ;
    rdfs:label "Factor dinámico de seguimiento" ;
    ns1:identificador "MPA.FEDYNFAC" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.FEDYNFAC[set].xn" .

ns1:MonitoreoDeSeguimiento a ns1:Parametro ;
    rdfs:label "Monitoreo de seguimiento" ;
    ns1:identificador "FLWEMONITOR" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro con FLWEMONITOR distinto de OFF." .

ns1:ValorMaximoDelErrorDeSeguimiento a ns1:Parametro ;
    rdfs:label "Valor máximo del error de seguimiento" ;
    ns1:identificador "MAXFLWE" ;
    ns1:textoExtracto "El parámetro MAXFLWE indica a partir de qué valor del error de" .

