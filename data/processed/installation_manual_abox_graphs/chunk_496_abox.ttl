@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Eje8
    a ex:ComponenteMecanico ;
    rdfs:label "Eje 8º" ;
    ex:textoExtracto "Octavo eje de la cinemática." .

ex:Ejes9ySiguientes
    a ex:ComponenteMecanico ;
    rdfs:label "Ejes 9º y siguientes" ;
    ex:textoExtracto "Resto de los ejes." .

ex:EjesLinealesCompensacion
    a ex:ComponenteMecanico ;
    rdfs:label "Primeros 3 ejes lineales" ;
    ex:textoExtracto "Los 3 primeros ejes deben ser lineales sobre los que se aplica la compensación de cabezal." .

ex:SistemaCinematico
    a ex:Sistema ;
    rdfs:label "Sistema de cinemática" ;
    ex:textoExtracto "El resto de los ejes podrán ser rotativos o lineales, dependiendo del tipo de cinemática." ;
    ex:tieneComponente ex:Eje8 ;
    ex:tieneComponente ex:Ejes9ySiguientes ;
    ex:tieneComponente ex:EjesLinealesCompensacion .