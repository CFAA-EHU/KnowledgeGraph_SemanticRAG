@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IndicaAPartirDeQueValorDelErrorDeSeguimientoComienzaLaSupervisionDinamica a ns1:Parametro ;
    rdfs:label "Indica a partir de qué valor del error de seguimiento comienza la supervisión dinámica" ;
    ns1:textoExtracto "El parámetro MAXFLWE indica a partir de qué valor del error de seguimiento comienza la supervisión dinámica." .

ns1:RetardoDelErrorDeSeguimiento_f1472de1c2 a ns1:Parametro ;
    rdfs:label "Retardo del error de seguimiento" ;
    ns1:identificador "MPA.ESTDELAY" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos." .

ns1:TiempoParaEntrarEnBandaDeMuerte a ns1:Parametro ;
    rdfs:label "Tiempo para entrar en banda de muerte" ;
    ns1:identificador "MPA.INPOMAX" ;
    ns1:textoExtracto "El parámetro INPOMAX limita (tiempo máximo) el tiempo que necesita el eje en situarse dentro de la banda de muerte." .

