@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:NKIN a ex:Parametro ;
    ex:identificador "(V.)MPK.NKIN" ;
    ex:textoExtracto "NKIN Número de cinemáticas definidas. Valores posibles: De 0 a 6. Valor por defecto: 0." ;
    ex:valor "De 0 a 6" .

ex:MPK_NKIN a ex:Parametro ;
    ex:identificador "MPK.NKIN" ;
    ex:textoExtracto "Variable asociada: (V.)MPK.NKIN" .

ex:KINID a ex:Parametro ;
    ex:identificador "KINID" ;
    ex:textoExtracto "El parámetro máquina de canal KINID indica el número de cinemática (no tipo) que asume el CNC en ese canal tras el encendido." .

ex:KIN_ID a ex:Parametro ;
    ex:identificador "#KIN ID" ;
    ex:textoExtracto "Para seleccionar una cinemática desde el programa pieza, utilizar la sentencia #KIN ID. KINEMATIC n" .

ex:TablaCinematicas a ex:Tabla ;
    ex:textoExtracto "Tabla de cinemáticas. Muestra la tabla para definir las cinemáticas del sistema." .

ex:Parametro_TYPE_Predefinido a ex:Parametro ;
    ex:identificador "TYPE" ;
    ex:textoExtracto "TYPE Tipo de cinemática. Valores posibles: De 0 a 99 (cinemáticas predefinidas por Fagor) / de 100 a 105 (cinemáticas OEM). Valor por defecto: 0." ;
    ex:valor "De 0 a 99" .

ex:Parametro_HEADREF a ex:Parametro ;
    ex:identificador "HEADREF" ;
    ex:textoExtracto "HEADREF Posición de referencia máquina HEAD/TOOL." .

ex:Parametro_TDATA_n a ex:Parametro ;
    ex:identificador "TDATA n" ;
    ex:textoExtracto "TDATA n Parámetro numérico en formato decimal." .

ex:Parametro_TDATA_I_n a ex:Parametro ;
    ex:identificador "TDATA_I n" ;
    ex:textoExtracto "TDATA_I n Parámetro numérico en formato entero." .

ex:Parametro_NKINAX a ex:Parametro ;
    ex:identificador "NKINAX" ;
    ex:textoExtracto "NKINAX Número de ejes de la cinemática." .

ex:Parametro_PARAM_D_SIZE a ex:Parametro ;
    ex:identificador "PARAM_D_SIZE" ;
    ex:textoExtracto "PARAM_D_SIZE Número de parámetros numéricos en formato decimal." .

ex:Parametro_PARAM_I_SIZE a ex:Parametro ;
    ex:identificador "PARAM_I_SIZE" ;
    ex:textoExtracto "PARAM_I_SIZE Número de parámetros en formato entero de la cinemática." .

ex:Parametro_AUXCTE_SIZE a ex:Parametro ;
    ex:identificador "AUXCTE_SIZE" ;
    ex:textoExtracto "AUXCTE_SIZE Tamaño del área de variables auxiliares." .

ex:Parametro_KINDATA_SIZE a ex:Parametro ;
    ex:identificador "KINDATA_SIZE" ;
    ex:textoExtracto "KINDATA_SIZE Tamaño del área de datos de propósito general." .