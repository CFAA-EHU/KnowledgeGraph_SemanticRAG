@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TiempoMinimoEnBandaDeMuerte a ns1:Parametro ;
    rdfs:label "Tiempo mínimo en banda de muerte" ;
    ns1:identificador "INPOTIME" ;
    ns1:textoExtracto "Este parámetro proporciona una vigilancia en el posicionamiento del eje que garantiza que éste entra en posición en un tiempo determinado, dando un error en caso contrario. INPOTIME Tiempo mínimo en banda de muerte." .

