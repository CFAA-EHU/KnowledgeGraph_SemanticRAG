@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_KINDATA_SIZE
    a ex:Parametro ;
    rdfs:label "KINDATA_SIZE" ;
    ex:textoExtracto "KINDATA_SIZE | Tamaño del área de datos de propósito general." ;
    ex:identificador "KINDATA_SIZE" .

ex:Parametro_MPK_TYPE
    a ex:Parametro ;
    rdfs:label "MPK.TYPE" ;
    ex:textoExtracto "TYPE Tipo de cinemática. Valores posibles: De 0 a 99 (cinemáticas predefinidas por Fagor) / de 100 a 105 (cinemáticas OEM). Valor por defecto: 0. Variable asociada: (V.)MPK.TYPE" ;
    ex:identificador "MPK.TYPE" ;
    ex:valor "0" .

ex:Tabla_TiposCinematicas a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tipos de cinemáticas" ;
    ex:textoExtracto "De los 106 tipos posibles de cinemáticas, los 100 primeros son para las cinemáticas predefinidas de Fagor y los 6 tipos restantes son para las cinemáticas que el fabricante integre en el CNC." .