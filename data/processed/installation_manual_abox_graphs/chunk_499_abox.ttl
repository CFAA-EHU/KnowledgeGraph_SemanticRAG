@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DistanciaARecorrerParaLubricarElEje a ns1:Parametro ;
    rdfs:label "Distancia a recorrer para lubricar el eje" ;
    ns1:identificador "DISTLUBRI" ;
    ns1:textoExtracto "DISTLUBRI Distancia a recorrer para lubricar el eje. Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:Parametro_09ac959ab8 a ns1:Parametro ;
    rdfs:label "Marca LUBR para indicar al PLC que debe engrasar el eje" ;
    ns1:identificador "LUBR" ;
    ns1:textoExtracto "el CNC se activa la marca LUBR(axis) para indicar al PLC que debe engrasar el eje." .

ns1:Parametro_45f81e4258 a ns1:Parametro ;
    rdfs:label "Marca LUBROK para indicar que el eje ya ha sido engrasado" ;
    ns1:identificador "LUBROK" ;
    ns1:textoExtracto "El PLC tras engrasar el eje pone la marca LUBROK(axis)= 1 para indicar al CNC que ya se ha engrasado el eje." .

ns1:Parametro_48e834d453 a ns1:Parametro ;
    rdfs:label "Marca LUBRENA para indicar si se desea la prestación de lubricación" ;
    ns1:identificador "LUBRENA" ;
    ns1:textoExtracto "La marca LUBRENA(axis) indica si se desea esta prestación." .

ns1:VariableMPADISTLUBRI a ns1:Parametro ;
    rdfs:label "Variable asociada al parámetro DISTLUBRI" ;
    ns1:identificador "MPA.DISTLUBRI" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.DISTLUBRI[set].xn La lectura desde el PLC de este parámetro se realiza en milímetros en lugar de diezmilésimas de milímetro." .

