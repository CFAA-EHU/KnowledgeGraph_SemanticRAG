@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorDeModuloNumeroDeIncrementos a ns1:Parametro ;
    rdfs:label "Error de módulo. Número de incrementos" ;
    ns1:identificador "MODERR" ;
    ns1:textoExtracto "MODERR Error de módulo. Número de incrementos." ;
    ns1:valor "0" .

ns1:ErrorDeModuloNumeroDeVueltas a ns1:Parametro ;
    rdfs:label "Error de módulo. Número de vueltas" ;
    ns1:identificador "MODNROT" ;
    ns1:textoExtracto "MODNROT Error de módulo. Número de vueltas." ;
    ns1:valor "1" .

ns1:LimiteInferiorDelModulo_89c14f30f9 a ns1:Parametro ;
    rdfs:label "Límite inferior del módulo" ;
    ns1:identificador "MODLOWLIM" ;
    ns1:textoExtracto "MODLOWLIM Límite inferior del módulo. Parámetro válido para ejes rotativos y cabezales." ;
    ns1:valor "0" .

ns1:LimiteSuperiorDelModulo_b06aef9c56 a ns1:Parametro ;
    rdfs:label "Límite superior del módulo" ;
    ns1:identificador "MODUPLIM" ;
    ns1:textoExtracto "MODUPLIM Límite superior del módulo. Parámetro válido para ejes rotativos y cabezales." ;
    ns1:valor "360" .

