@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ErrorDeModuloQueHayQueCompensar a ns1:Parametro ;
    rdfs:label "Error de módulo que hay que compensar" ;
    ns1:identificador "MODERR" ;
    ns1:textoExtracto "El parámetro MODERR indica el error que hay que compensar cuando el eje ha girado las vueltas indicadas en el parámetro MODNROT." .

ns1:NumeroDeVueltasParaLaCompensacionDelModulo a ns1:Parametro ;
    rdfs:label "Número de vueltas para la compensación del módulo" ;
    ns1:identificador "MODNROT" ;
    ns1:textoExtracto "El parámetro MODERR indica el error que hay que compensar cuando el eje ha girado las vueltas indicadas en el parámetro MODNROT." .

