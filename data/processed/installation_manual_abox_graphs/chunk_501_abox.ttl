@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_HEADREF a ex:Parametro ;
    rdfs:label "HEADREF" ;
    ex:textoExtracto "HEADREF Posición de referencia máquina HEAD/TOOL. Valores posibles: Tool base / Head base / Auto tool base. Valor por defecto: Tool base. Variable asociada: (V.)MPK.HEADREF Este parámetro permite colocar el punto de referencia de la cinemática en la nariz del portaherramientas, tras la calibración (Tool Base) o la activación (Auto Tool Base)." ;
    ex:valor "Tool base / Head base / Auto tool base" .

ex:ModoOperacion_ToolBase a ex:ModoOperacion ;
    rdfs:label "Tool base" ;
    ex:textoExtracto "Tool base. La calibración de cinemática coloca el punto de referencia de la cinemática en la nariz del portaherramientas. A partir de los parámetros TDATA13 a TDATA15 (cinemáticas no vectoriales) o TDATA1 a TDATA3 (cinemáticas vectoriales), la calibración calcula el nuevo punto de referencia de la cinemática. Esta opción modifica el valor de estos parámetros en la tabla. Esta es la opción recomendada cuando la máquina dispone de un único cabezal que se va a calibrar regularmente." .

ex:ModoOperacion_HeadBase a ex:ModoOperacion ;
    rdfs:label "Head base" ;
    ex:textoExtracto "Head base. La calibración de cinemática no modifica el punto de referencia de la cinemática, aquel utilizado para definir la cinemática en los parámetros máquina. Esta es la opción recomendada cuando la máquina dispone de cambio de cabezal." .

ex:ModoOperacion_AutoToolBase a ex:ModoOperacion ;
    rdfs:label "Auto tool base" ;
    ex:textoExtracto "Auto tool base. Al activar la cinemática, el CNC coloca el punto de referencia de la cinemática en la nariz del portaherramientas. A partir de los parámetros TDATA13 a TDATA15 (cinemáticas no vectoriales) o TDATA1 a TDATA3 (cinemáticas vectoriales), el CNC calcula el nuevo punto de referencia de la cinemática. No se modifica el valor de estos parámetros en la tabla de parámetros." .

ex:Parametro_TDATA a ex:Parametro ;
    rdfs:label "TDATA n" ;
    ex:textoExtracto "TDATA n Parámetro numérico en formato decimal. Valores posibles: Entre ±999999999.0000 Valor por defecto: 0." ;
    ex:valor "Entre ±999999999.0000" .