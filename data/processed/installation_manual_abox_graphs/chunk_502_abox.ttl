@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Tabla_Parametros_2_9_1 a ex:Tabla ;
    ex:textoExtracto "No se modifica el valor de estos parámetros en la tabla de parámetros. | TDATA n Parámetro numérico en formato decimal. Valores posibles: Entre ±999999999.0000 Valor por defecto: 0. Variable asociada: (V.)MPK.TDATAkin[nb] Variable asociada: (V.)MPK.MAXOFTDATAkin[nb] Parámetro numérico en formato decimal. Para cada parámetro hay que definir los siguientes campos." ;
    rdfs:label "Tabla de parámetros de cinemáticas" .

ex:Parametro_TDATA a ex:Parametro ;
    ex:textoExtracto "TDATA n Parámetro numérico en formato decimal. Valores posibles: Entre ±999999999.0000 Valor por defecto: 0." ;
    rdfs:label "TDATA" .

ex:Parametro_MAXOFTDATAkin a ex:Parametro ;
    ex:textoExtracto "Variable asociada: (V.)MPK.MAXOFTDATAkin[nb] Parámetro numérico en formato decimal." ;
    rdfs:label "MAXOFTDATAkin" .