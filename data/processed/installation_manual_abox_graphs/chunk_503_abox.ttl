@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SignoDeLaConsignaParaLaFuncionM3 a ns1:Parametro ;
    rdfs:label "signo de la consigna para la función M3" ;
    ns1:identificador "POLARM3" ;
    ns1:textoExtracto "Los parámetros POLARM3 y POLARM4 indican el signo de la consigna para las funciones M3 y M4 respectivamente. Ambos parámetros se deben definir con valor \"Positivo\"." .

ns1:SignoDeLaConsignaParaLaFuncionM4 a ns1:Parametro ;
    rdfs:label "signo de la consigna para la función M4" ;
    ns1:identificador "POLARM4" ;
    ns1:textoExtracto "Los parámetros POLARM3 y POLARM4 indican el signo de la consigna para las funciones M3 y M4 respectivamente. Ambos parámetros se deben definir con valor \"Positivo\"." .

ns1:VariableQuePermiteInvertirElSignificadoDeLosParametrosPOLARM3YPOLARM4 a ns1:Parametro ;
    rdfs:label "variable que permite invertir el significado de los parámetros POLARM3 y POLARM4" ;
    ns1:textoExtracto "Esta variable permite invertir el significado de los parámetros POLARM3 y POLARM4. La variable no modifica los valores de los parámetros máquina." .

