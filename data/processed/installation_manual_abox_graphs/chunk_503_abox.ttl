@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Parametro_TDATA_I a ex:Parametro ;
    ex:identificador "TDATA_I" ;
    ex:textoExtracto "Parámetro numérico en formato entero. Valores posibles: Entre ±2147483647 Valor por defecto: 0." ;
    ex:valor "0" .

ex:Variable_MPK_TDATA_Ikin a ex:Parametro ;
    ex:identificador "MPK.TDATA_Ikin[nb]" ;
    ex:textoExtracto "Variable asociada: (V.)MPK.TDATA_Ikin[nb]" .

ex:Variable_MPK_MAXOFTDATA_Ikin a ex:Parametro ;
    ex:identificador "MPK.MAXOFTDATA_Ikin[nb]" ;
    ex:textoExtracto "Variable asociada: (V.)MPK.MAXOFTDATA_Ikin[nb]" .

ex:Sistema_Cinematica a ex:Sistema ;
    ex:identificador "#KIN ID" ;
    ex:textoExtracto "activar la cinemática (#KIN ID) o el RTCP" .

ex:Sistema_RTCP a ex:Sistema ;
    ex:identificador "RTCP" ;
    ex:textoExtracto "activar la cinemática (#KIN ID) o el RTCP" .