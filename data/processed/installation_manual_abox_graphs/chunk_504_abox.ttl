@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CompensacionDelOffset a ns1:Parametro ;
    rdfs:label "Compensación del offset" ;
    ns1:identificador "SERVOOFF" ;
    ns1:textoExtracto "SERVOOFF Compensación del offset. Parámetro válido para ejes lineales, rotativos y cabezales." ;
    ns1:valor "-32767 a 32767" .

ns1:ConsignaMinima a ns1:Parametro ;
    rdfs:label "Consigna mínima" ;
    ns1:identificador "MINANOUT" ;
    ns1:textoExtracto "MINANOUT Consigna mínima. Parámetro válido para ejes lineales, rotativos y cabezales." ;
    ns1:valor "0 a 32767" .

