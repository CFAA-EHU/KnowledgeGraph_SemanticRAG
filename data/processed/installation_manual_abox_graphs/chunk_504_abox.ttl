@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ParametroOffset a ex:Parametro ;
    ex:textoExtracto "En la columna 'Value' el fabricante determina el valor del parámetro, que podrá ser modificado por el usuario mediante la columna 'OFFSET' o su variable asociada. En la columna 'MAX OFFSET', el fabricante determina el offset máximo que puede definir el usuario. Esta columna siempre será un valor positivo, y el offset definido por el usuario será un valor comprendido entre '- MAX OFFSET' y '+ MAX OFFSET'. Si define un offset máximo de cero, el usuario no podrá definir ningún offset. Los valores de offset definidos por el usuario se sumarán a su parámetro TDATA correspondiente. El nuevo valor se hará efectivo al activar la cinemática (#KIN ID) o el RTCP." ;
    rdfs:label "Parámetro Offset" .

ex:ParametroTDATA a ex:Parametro ;
    ex:textoExtracto "Los valores de offset definidos por el usuario se sumarán a su parámetro TDATA correspondiente." ;
    rdfs:label "Parámetro TDATA" .

ex:EsquemaCinematicas a ex:Esquema ;
    ex:textoExtracto "En la columna 'Value' el fabricante determina el valor del parámetro, que podrá ser modificado por el usuario mediante la columna 'OFFSET' o su variable asociada. En la columna 'MAX OFFSET', el fabricante determina el offset máximo que puede definir el usuario. Esta columna siempre será un valor positivo, y el offset definido por el usuario será un valor comprendido entre '- MAX OFFSET' y '+ MAX OFFSET'. Si define un offset máximo de cero, el usuario no podrá definir ningún offset. Los valores de offset definidos por el usuario se sumarán a su parámetro TDATA correspondiente. El nuevo valor se hará efectivo al activar la cinemática (#KIN ID) o el RTCP." ;
    ex:tieneComponente ex:ParametroOffset, ex:ParametroTDATA ;
    rdfs:label "Esquema de Configuración de Cinemáticas" .