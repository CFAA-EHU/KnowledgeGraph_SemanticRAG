@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:CabezalEsferico a ex:Maquina ;
    rdfs:label "Cabezal esférico" ;
    ex:textoExtracto "Se pueden controlar cabezales esféricos, ortogonales y angulares. A C B Cabezal esférico." .

ex:CabezalOrtogonal a ex:Maquina ;
    rdfs:label "Cabezal ortogonal" ;
    ex:textoExtracto "Se pueden controlar cabezales esféricos, ortogonales y angulares. Cabezal ortogonal." .

ex:CabezalAngular a ex:Maquina ;
    rdfs:label "Cabezal angular" ;
    ex:textoExtracto "Se pueden controlar cabezales esféricos, ortogonales y angulares. Cabezal angular." .

ex:EjeRotativoPrincipal a ex:ComponenteMecanico ;
    rdfs:label "eje rotativo principal" ;
    ex:identificador "(4)" ;
    ex:textoExtracto "Cuando se dispone de un cabezal angular, el eje rotativo principal (4) debe girar sobre uno de los ejes principales (X, Y, Z) y el eje secundario o arrastrado (5) formará un determinado ángulo." .

ex:EjePrincipalX a ex:ComponenteMecanico ;
    rdfs:label "eje principal X" ;
    ex:identificador "X" ;
    ex:textoExtracto "el eje rotativo principal (4) debe girar sobre uno de los ejes principales (X, Y, Z)" .

ex:EjePrincipalY a ex:ComponenteMecanico ;
    rdfs:label "eje principal Y" ;
    ex:identificador "Y" ;
    ex:textoExtracto "el eje rotativo principal (4) debe girar sobre uno de los ejes principales (X, Y, Z)" .

ex:EjePrincipalZ a ex:ComponenteMecanico ;
    rdfs:label "eje principal Z" ;
    ex:identificador "Z" ;
    ex:textoExtracto "el eje rotativo principal (4) debe girar sobre uno de los ejes principales (X, Y, Z)" .

ex:EjeSecundario a ex:ComponenteMecanico ;
    rdfs:label "eje secundario o arrastrado" ;
    ex:identificador "(5)" ;
    ex:textoExtracto "el eje secundario o arrastrado (5) formará un determinado ángulo." .

ex:ParametroTDATA1 a ex:Parametro ;
    rdfs:label "TDATA1" ;
    ex:identificador "TDATA1" ;
    ex:valor "distancia entre la nariz del mandrino y el eje rotativo secundario, según el eje Z" ;
    ex:textoExtracto "TDATA1 Indica la distancia entre la nariz del mandrino y el eje rotativo secundario, según el eje Z." .

ex:ParametroTDATA2 a ex:Parametro ;
    rdfs:label "TDATA2" ;
    ex:identificador "TDATA2" ;
    ex:valor "distancia entre el eje rotativo secundario y el principal según el eje X" ;
    ex:textoExtracto "TDATA2 Indica la distancia entre el eje rotativo secundario y el principal según el eje X." .

ex:ParametroTDATA3 a ex:Parametro ;
    rdfs:label "TDATA3" ;
    ex:identificador "TDATA3" ;
    ex:valor "distancia entre el eje rotativo secundario y el principal según el eje Y" ;
    ex:textoExtracto "TDATA3 Indica la distancia entre el eje rotativo secundario y el principal según el eje Y." .

ex:ParametroTDATA4 a ex:Parametro ;
    rdfs:label "TDATA4" ;
    ex:identificador "TDATA4" ;
    ex:valor "distancia entre el eje rotativo secundario y el principal según el eje Z" ;
    ex:textoExtracto "TDATA4 Indica la distancia entre el eje rotativo secundario y el principal según el eje Z." .

ex:ParametroTDATA5 a ex:Parametro ;
    rdfs:label "TDATA5" ;
    ex:identificador "TDATA5" ;
    ex:valor "distancia entre el eje de la herramienta y el eje rotativo secundario según el eje X" ;
    ex:textoExtracto "TDATA5 Indica la distancia entre el eje de la herramienta y el eje rotativo secundario según el eje X." .

ex:ParametroTDATA6 a ex:Parametro ;
    rdfs:label "TDATA6" ;
    ex:identificador "TDATA6" ;
    ex:valor "distancia entre el eje de la herramienta y el eje rotativo secundario según el eje Y" ;
    ex:textoExtracto "TDATA6 Indica la distancia entre el eje de la herramienta y el eje rotativo secundario según el eje Y." .

ex:ParametroTDATA7 a ex:Parametro ;
    rdfs:label "TDATA7" ;
    ex:identificador "TDATA7" ;
    ex:valor "ángulo entre los ejes rotativos principal y secundario, en los cabezales rotativos" ;
    ex:textoExtracto "TDATA7 Indica el ángulo entre los ejes rotativos principal y secundario, en los cabezales rotativos." .