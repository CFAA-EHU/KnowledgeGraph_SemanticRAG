@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaSalidasAnalogicas a ns1:Sistema ;
    rdfs:label "Sistema de Salidas Analógicas" ;
    ns1:textoExtracto "Los módulos de salidas analógicas se numeran según el orden lógico de los grupos remotos (conmutador rotativo de la fuente de alimentación)." ;
    ns1:tieneComponente ns1:NumeroDeSalidaAnalogicaYReguladorSercos .

ns1:NumeroDeSalidaAnalogicaYReguladorSercos a ns1:Parametro ;
    rdfs:label "Número de salida analógica y regulador Sercos" ;
    ns1:textoExtracto "En este caso, este parámetro indica cuál es el número de la salida analógica y el regulador a utilizar." .

