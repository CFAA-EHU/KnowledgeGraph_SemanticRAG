@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TDATA8 a ex:Parametro ;
    ex:identificador "TDATA8" ;
    ex:textoExtracto "TDATA8 Posición de reposo del eje rotativo principal. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0. Consultar el parámetro TDATA9." ;
    ex:valor "Entre ±99999.9999º" .

ex:TDATA9 a ex:Parametro ;
    ex:identificador "TDATA9" ;
    ex:textoExtracto "TDATA9 Posición de reposo del eje rotativo secundario. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0. Se denomina posición de reposo cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal)." ;
    ex:valor "Entre ±99999.9999º" .

ex:TDATA10 a ex:Parametro ;
    ex:identificador "TDATA10" ;
    ex:textoExtracto "TDATA10 Sentido de giro del eje rotativo principal. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0. Consultar el parámetro TDATA11." ;
    ex:valor "0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217)" .

ex:TDATA11 a ex:Parametro ;
    ex:identificador "TDATA11" ;
    ex:textoExtracto "TDATA11 Sentido de giro del eje rotativo secundario. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0. La dirección de los ejes X Y Z, según la norma DIN 66217, se puede recordar fácilmente utilizando la regla de la mano derecha." ;
    ex:valor "0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217)" .

ex:NormaDIN66217 a ex:Directiva ;
    ex:identificador "DIN 66217" ;
    ex:textoExtracto "La dirección de los ejes X Y Z, según la norma DIN 66217, se puede recordar fácilmente utilizando la regla de la mano derecha." .