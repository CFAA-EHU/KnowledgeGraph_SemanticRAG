@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA8
    a ex:Parametro ;
    rdfs:label "Posición de reposo del eje rotativo principal" ;
    ex:textoExtracto "TDATA8 Posición de reposo del eje rotativo principal. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0." ;
    ex:valor "0" ;
    ex:identificador "TDATA8" .

ex:Parametro_TDATA9
    a ex:Parametro ;
    rdfs:label "Posición de reposo del eje rotativo secundario" ;
    ex:textoExtracto "TDATA9 Posición de reposo del eje rotativo secundario. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0. Se denomina posición de reposo cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal)." ;
    ex:valor "0" ;
    ex:identificador "TDATA9" .

ex:Parametro_TDATA10
    a ex:Parametro ;
    rdfs:label "Sentido de giro del eje rotativo principal" ;
    ex:textoExtracto "TDATA10 Sentido de giro del eje rotativo principal. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." ;
    ex:valor "0" ;
    ex:identificador "TDATA10" .

ex:Parametro_TDATA11
    a ex:Parametro ;
    rdfs:label "Sentido de giro del eje rotativo secundario" ;
    ex:textoExtracto "TDATA11 Sentido de giro del eje rotativo secundario. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." ;
    ex:valor "0" ;
    ex:identificador "TDATA11" .

ex:Directiva_DIN66217
    a ex:Directiva ;
    rdfs:label "Norma DIN 66217" ;
    ex:textoExtracto "La dirección de los ejes X Y Z, según la norma DIN 66217, se puede recordar fácilmente utilizando la regla de la mano derecha." ;
    ex:identificador "DIN 66217" .

ex:Parametro_TDATA10 ex:cumpleNormativa ex:Directiva_DIN66217 .
ex:Parametro_TDATA11 ex:cumpleNormativa ex:Directiva_DIN66217 .