@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TDATA2 a ex:Parametro ;
    rdfs:label "TDATA2" ;
    ex:identificador "TDATA2" ;
    ex:textoExtracto "TDATA2 Distancia del eje rotativo secundario al punto de referencia máquina o a la intersección con el eje primario, según el eje X." .

ex:TDATA3 a ex:Parametro ;
    rdfs:label "TDATA3" ;
    ex:identificador "TDATA3" ;
    ex:textoExtracto "TDATA3 Distancia del eje rotativo secundario al punto de referencia máquina o a la intersección con el eje primario, según el eje Y." .

ex:TDATA4 a ex:Parametro ;
    rdfs:label "TDATA4" ;
    ex:identificador "TDATA4" ;
    ex:textoExtracto "TDATA4 Distancia del eje rotativo secundario al punto de referencia máquina o a la intersección con el eje primario, según el eje Z." .

ex:TDATA5 a ex:Parametro ;
    rdfs:label "TDATA5" ;
    ex:identificador "TDATA5" ;
    ex:textoExtracto "TDATA5 Indica la distancia entre el eje rotativo secundario y el principal." .

ex:TDATA7 a ex:Parametro ;
    rdfs:label "TDATA7" ;
    ex:identificador "TDATA7" ;
    ex:textoExtracto "TDATA7 Origen para aplicar el RTCP. Valores posibles: 0 (cero máquina) / 1 (cero pieza). Valor por defecto: 0. Este parámetro indica si el CNC aplica el RTCP respecto el cero máquina o el cero pieza. En este tipo de cinemática se recomienda definir este parámetro con valor ꞏ1ꞏ." .