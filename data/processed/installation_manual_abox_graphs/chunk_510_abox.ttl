@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModuloContadoras a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de contadoras" ;
    ns1:textoExtracto "Para la entrada de captación se utiliza un módulo de contadoras" .

ns1:NumeroDeSalidaAnalogicaYEntradaDeCaptacionAsociadaAlEje a ns1:Parametro ;
    rdfs:label "Número de salida analógica y entrada de captación asociada al eje" ;
    ns1:textoExtracto "En función de dónde esté la entrada de captación, este parámetro indicará cuál es la entrada de captación a utilizar (si la captación es local o remota) o el número de regulador o contadora." .

