@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeEntradaDeCaptacionEnLosModulosRemotosCANfagor a ns1:Parametro ;
    rdfs:label "Número de entrada de captación en los módulos remotos CANfagor" ;
    ns1:textoExtracto "Este parámetro indica el número de la entrada de captación que se utiliza." .

ns1:NumeroDeEntradaDeCaptacionEnLosReguladoresSercos a ns1:Parametro ;
    rdfs:label "Número de entrada de captación en los reguladores Sercos" ;
    ns1:textoExtracto "El parámetro indica la dirección lógica del regulador (de 1 a 32)." .

ns1:NumeroDeEntradaDeCaptacionEnUnModuloRCSS a ns1:Parametro ;
    rdfs:label "Número de entrada de captación en un módulo RCS-S" ;
    ns1:textoExtracto "Este parámetro indica el número de la entrada de captación que se utiliza." .

