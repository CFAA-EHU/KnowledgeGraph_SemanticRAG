@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TDATA8
    a ex:Parametro ;
    rdfs:label "Posición de reposo del eje rotativo principal" ;
    ex:textoExtracto "TDATA8 Posición de reposo del eje rotativo principal. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0. Consultar el parámetro TDATA9." ;
    ex:identificador "TDATA8" ;
    ex:valor "0" .

ex:TDATA9
    a ex:Parametro ;
    rdfs:label "Posición de reposo del eje rotativo secundario" ;
    ex:textoExtracto "TDATA9 Posición de reposo del eje rotativo secundario. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0. Se denomina posición de reposo cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal)." ;
    ex:identificador "TDATA9" ;
    ex:valor "0" .

ex:TDATA10
    a ex:Parametro ;
    rdfs:label "Sentido de giro del eje rotativo principal" ;
    ex:textoExtracto "TDATA10 Sentido de giro del eje rotativo principal. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0. Consultar el parámetro TDATA11." ;
    ex:identificador "TDATA10" ;
    ex:valor "0" .

ex:TDATA11
    a ex:Parametro ;
    rdfs:label "Sentido de giro del eje rotativo secundario" ;
    ex:textoExtracto "TDATA11 Sentido de giro del eje rotativo secundario. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 1." ;
    ex:identificador "TDATA11" ;
    ex:valor "1" .

ex:NormaDIN66217
    a ex:Directiva ;
    rdfs:label "DIN 66217" ;
    ex:textoExtracto "La dirección de los ejes X Y Z, según la norma DIN 66217, se puede recordar fácilmente utilizando la regla de la mano derecha. En los ejes rotativos, el sentido de giro viene determinado al doblar los dedos alrededor del eje lineal asociado con el dedo pulgar señalando la dirección positiva del eje lineal." ;
    ex:identificador "DIN 66217" .

ex:TDATA10
    ex:cumpleNormativa ex:NormaDIN66217 .

ex:TDATA11
    ex:cumpleNormativa ex:NormaDIN66217 .

ex:CinematicaTipo9
    a ex:ModoOperacion ;
    rdfs:label "Cinemática Tipo 9 (ejes rotativos en mesa)" ;
    ex:textoExtracto "TYPE=9 [...] En las cinemáticas con ejes rotativos en la mesa, el sentido de giro se determina desde el punto de vista de la herramienta, por lo que se parametrizará TDATA10=1 TDATA11=1." ;
    ex:identificador "TYPE=9" .

ex:CinematicaTipo9
    ex:tieneComponente ex:TDATA10, ex:TDATA11 .