ns1:ACForward_3223f13dc7 a ns1:Parametro ;
    rdfs:label "AC forward" ;
    ns1:identificador "ACFGAIN" ;
    ns1:textoExtracto "El CNC envía los cambios de Kv, feed forward (parámetro FFGAIN) y AC forward (parámetro ACFGAIN)" .

ns1:CNC8070_d62cce714e a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC envía los cambios de Kv, feed forward (parámetro FFGAIN) y AC forward (parámetro ACFGAIN) al set indicado en este parámetro." .

ns1:FeedForward_ad9913b2e3 a ns1:Parametro ;
    rdfs:label "Feed forward" ;
    ns1:identificador "FFGAIN" ;
    ns1:textoExtracto "El CNC envía los cambios de Kv, feed forward (parámetro FFGAIN) y AC forward (parámetro ACFGAIN)" .

ns1:SetDelReguladorAUtilizar a ns1:Parametro ;
    rdfs:label "Set del regulador a utilizar" ;
    ns1:identificador "DRIVESET" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador Sercos." ;
    ns1:valor "0" .

ns1:SistemaRegulador a ns1:Sistema ;
    rdfs:label "Sistema Regulador" ;
    ns1:textoExtracto "Parámetro válido para regulador Sercos." .

