@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TDATA16 a ex:Parametro ;
    ex:identificador "TDATA16" ;
    ex:textoExtracto "TDATA16" .

ex:SistemaCoordenadasPieza a ex:Sistema ;
    ex:textoExtracto "El sistema de coordenadas está fijo sobre la pieza y gira con ella." .

ex:SistemaCoordenadasMaquina a ex:Sistema ;
    ex:textoExtracto "El sistema de coordenadas se mantiene paralelo al sistema de coordenadas máquina." .

ex:OrientacionPieza a ex:ModoOperacion ;
    ex:textoExtracto "Al variar la orientación de la pieza" .

ex:PosicionPuntaHerramienta a ex:Parametro ;
    ex:textoExtracto "la posición que ocupa la punta de la herramienta sobre la pieza" .

ex:PuntoCeroPieza a ex:Parametro ;
    ex:textoExtracto "el punto definido como cero pieza" .

ex:RTCPN a ex:ModoOperacion ;
    ex:textoExtracto "#RTCP ON B-30 B TDATA16 = 0 TDATA16 = 1" .