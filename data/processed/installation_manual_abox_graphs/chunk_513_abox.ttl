@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaControlNumerico a ns1:Sistema ;
    rdfs:label "Sistema Control Numérico" ;
    ns1:documentadoEn ns1:TipoDeCaptacionDelModuloRCSS_8fd37a442a,
        ns1:VariableAsociadaAlTipoDeCaptacion ;
    ns1:textoExtracto "FEEDBACKTYPE Tipo de captación del módulo RCS-S. Parámetro válido para ejes lineales, rotativos y cabezales." ;
    ns1:tieneComponente ns1:ModuloRCSS_64545cf189 .

ns1:ModuloRCSS_64545cf189 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo RCS-S" ;
    ns1:textoExtracto "FEEDBACKTYPE Tipo de captación del módulo RCS-S. Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:TipoDeCaptacionDelModuloRCSS_8fd37a442a a ns1:Parametro ;
    rdfs:label "Tipo de captación del módulo RCS-S" ;
    ns1:identificador "FEEDBACKTYPE" ;
    ns1:textoExtracto "FEEDBACKTYPE Tipo de captación del módulo RCS-S. Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:VariableAsociadaAlTipoDeCaptacion a ns1:Parametro ;
    rdfs:label "Variable asociada al tipo de captación" ;
    ns1:identificador "MPA.FEEDBACKTYPE" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.FEEDBACKTYPE[set].xn Cuando la entrada de captación del eje se encuentra en la entrada local o en un módulo RCS-S (contadora Sercos), este parámetro define el tipo de señal." .

