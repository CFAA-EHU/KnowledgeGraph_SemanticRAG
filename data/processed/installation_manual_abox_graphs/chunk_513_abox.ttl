@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA16
    a ex:Parametro ;
    rdfs:label "TDATA16" ;
    ex:identificador "TDATA16" ;
    ex:textoExtracto "TDATA16 | Significado." ;
    ex:valor "0" , "1" .

ex:ModoOperacion_RTCP_ON
    a ex:ModoOperacion ;
    rdfs:label "RTCP ON" ;
    ex:identificador "RTCP ON" ;
    ex:textoExtracto "#RTCP ON B-30 B" .

ex:Tabla_DefinicionCinematicas a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de definición de cinemáticas (TDATA16)" ;
    ex:textoExtracto "TDATA16 | Significado."@es ;
    ex:documentadoEn ex:Manual_Brochado ;
    ex:detalladoEnEsquema ex:Esquema_CoordenadasRTCP .

ex:Esquema_CoordenadasRTCP
    a ex:Esquema ;
    rdfs:label "Esquema de sistemas de coordenadas (Z' X' con RTCP)" ;
    ex:textoExtracto "Z' X' Z' X' #RTCP ON B-30 B TDATA16 = 0 TDATA16 = 1" ;
    ex:ilustradoEn ex:Tabla_DefinicionCinematicas .

ex:Parametro_TDATA16_Valor0
    a ex:Parametro ;
    rdfs:label "TDATA16 = 0 (sistema de coordenadas fijo a pieza)" ;
    ex:identificador "TDATA16=0" ;
    ex:valor "0" ;
    ex:textoExtracto "Al variar la orientación de la pieza, no se modifica la posición que ocupa la punta de la herramienta sobre la pieza. El sistema de coordenadas está fijo sobre la pieza y gira con ella."@es ;
    ex:monitoreaParametro ex:Parametro_TDATA16 .

ex:Parametro_TDATA16_Valor1
    a ex:Parametro ;
    rdfs:label "TDATA16 = 1 (sistema de coordenadas paralelo a máquina)" ;
    ex:identificador "TDATA16=1" ;
    ex:valor "1" ;
    ex:textoExtracto "Al variar la orientación de la pieza, no se modifica la posición que ocupa el punto definido como cero pieza. El sistema de coordenadas se mantiene paralelo al sistema de coordenadas máquina."@es ;
    ex:monitoreaParametro ex:Parametro_TDATA16 .