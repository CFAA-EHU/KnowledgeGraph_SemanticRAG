@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TipoDeCaptacionDelEncoder a ns1:Parametro ;
    rdfs:label "Tipo de captación del encóder" ;
    ns1:documentadoEn ns1:TablaInformacionEncoder ;
    ns1:identificador "FEEDBACKTYPE" ;
    ns1:textoExtracto "parámetro FEEDBACKTYPE" .

ns1:TablaInformacionEncoder a ns1:Tabla ;
    rdfs:label "Tabla de información del encóder" ;
    ns1:textoExtracto "muestra una tabla de parámetros con la información del encóder" .

