@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA1 a ex:Parametro ;
    rdfs:label "TDATA1" ;
    ex:textoExtracto "TDATA1 Indica la distancia entre la nariz del mandrino y el eje rotativo del cabezal, según el eje Z." ;
    ex:valor "distancia (eje Z): nariz mandrino ↔ eje rotativo cabezal" .

ex:Parametro_TDATA2 a ex:Parametro ;
    rdfs:label "TDATA2" ;
    ex:textoExtracto "TDATA2 Indica la distancia entre el eje de la herramienta y el eje rotativo del cabezal, según el eje X." ;
    ex:valor "distancia (eje X): eje herramienta ↔ eje rotativo cabezal" .

ex:Parametro_TDATA3 a ex:Parametro ;
    rdfs:label "TDATA3" ;
    ex:textoExtracto "TDATA3 Indica la distancia entre el eje de la herramienta y el eje rotativo del cabezal, según el eje Y." ;
    ex:valor "distancia (eje Y): eje herramienta ↔ eje rotativo cabezal" .

ex:Parametro_TDATA4 a ex:Parametro ;
    rdfs:label "TDATA4" ;
    ex:textoExtracto "TDATA4 Distancia del eje rotativo de la mesa al punto de referencia máquina, según el eje X." ;
    ex:valor "distancia (eje X): eje rotativo mesa ↔ referencia máquina" .

ex:Parametro_TDATA5 a ex:Parametro ;
    rdfs:label "TDATA5" ;
    ex:textoExtracto "TDATA5 Distancia del eje rotativo de la mesa al punto de referencia máquina, según el eje Y." ;
    ex:valor "distancia (eje Y): eje rotativo mesa ↔ referencia máquina" .

ex:Parametro_TDATA6 a ex:Parametro ;
    rdfs:label "TDATA6" ;
    ex:textoExtracto "TDATA6 Distancia del eje rotativo de la mesa al punto de referencia máquina, según el eje Z." ;
    ex:valor "distancia (eje Z): eje rotativo mesa ↔ referencia máquina" .

ex:Parametro_TDATA7 a ex:Parametro ;
    rdfs:label "TDATA7" ;
    ex:identificador "0/1" ;
    ex:textoExtracto "TDATA7 Origen para aplicar el RTCP. Valores posibles: 0 (cero máquina) / 1 (cero pieza). Valor por defecto: 0." ;
    ex:valor "0" .

ex:Sistema_CinematicaCabezalMesa_Tipos13_16 a ex:Sistema ;
    rdfs:label "Cinemática cabezal-mesa (tipos 13-16)" ;
    ex:textoExtracto "En este tipo de cinemáticas un eje de giro se encuentra en el cabezal y el otro en la mesa. El del cabezal se encarga de orientar la herramienta y el de la mesa de trabajo orienta la pieza." ;
    ex:tieneComponente ex:Parametro_TDATA1, ex:Parametro_TDATA2, ex:Parametro_TDATA3,
                       ex:Parametro_TDATA4, ex:Parametro_TDATA5, ex:Parametro_TDATA6,
                       ex:Parametro_TDATA7 .