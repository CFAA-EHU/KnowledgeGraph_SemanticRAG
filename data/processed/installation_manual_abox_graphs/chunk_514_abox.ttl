@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EjeGiroCabezal a ex:ComponenteMecanico ;
    rdfs:label "eje de giro del cabezal"@es ;
    ex:textoExtracto "El del cabezal se encarga de orientar la herramienta"@es .

ex:EjeGiroMesa a ex:ComponenteMecanico ;
    rdfs:label "eje de giro de la mesa"@es ;
    ex:textoExtracto "el otro en la mesa. [...] el de la mesa de trabajo orienta la pieza"@es .

ex:EjeHerramienta a ex:ComponenteMecanico ;
    rdfs:label "eje de la herramienta"@es ;
    ex:textoExtracto "El tercer eje corresponde al eje de la herramienta"@es .

ex:EjeRotativoCabezal a ex:ComponenteMecanico ;
    rdfs:label "eje rotativo del cabezal"@es ;
    ex:textoExtracto "El cuarto eje corresponde al eje rotativo del cabezal"@es .

ex:EjeRotativoMesa a ex:ComponenteMecanico ;
    rdfs:label "eje rotativo de la mesa"@es ;
    ex:textoExtracto "El quinto eje corresponde al eje rotativo de la mesa"@es .

ex:ParametroTDATA1 a ex:Parametro ;
    rdfs:label "TDATA1"@es ;
    ex:identificador "TDATA1" ;
    ex:textoExtracto "TDATA1 Indica la distancia entre la nariz del mandrino y el eje rotativo del cabezal, según el eje Z."@es .

ex:ParametroTDATA2 a ex:Parametro ;
    rdfs:label "TDATA2"@es ;
    ex:identificador "TDATA2" ;
    ex:textoExtracto "TDATA2 Indica la distancia entre el eje de la herramienta y el eje rotativo del cabezal, según el eje X."@es .

ex:ParametroTDATA3 a ex:Parametro ;
    rdfs:label "TDATA3"@es ;
    ex:identificador "TDATA3" ;
    ex:textoExtracto "TDATA3 Indica la distancia entre el eje de la herramienta y el eje rotativo del cabezal, según el eje Y."@es .

ex:ParametroTDATA4 a ex:Parametro ;
    rdfs:label "TDATA4"@es ;
    ex:identificador "TDATA4" ;
    ex:textoExtracto "TDATA4 Distancia del eje rotativo de la mesa al punto de referencia máquina, según el eje X."@es .

ex:ParametroTDATA5 a ex:Parametro ;
    rdfs:label "TDATA5"@es ;
    ex:identificador "TDATA5" ;
    ex:textoExtracto "TDATA5 Distancia del eje rotativo de la mesa al punto de referencia máquina, según el eje Y."@es .

ex:ParametroTDATA6 a ex:Parametro ;
    rdfs:label "TDATA6"@es ;
    ex:identificador "TDATA6" ;
    ex:textoExtracto "TDATA6 Distancia del eje rotativo de la mesa al punto de referencia máquina, según el eje Z."@es .

ex:ParametroTDATA7 a ex:Parametro ;
    rdfs:label "TDATA7"@es ;
    ex:identificador "TDATA7" ;
    ex:textoExtracto "TDATA7 Origen para aplicar el RTCP. Valores posibles: 0 (cero máquina) / 1 (cero pieza). Valor por defecto: 0. Este parámetro indica si el CNC aplica el RTCP respecto el cero máquina o el cero pieza."@es .

ex:CinematicaCabezalMesa a ex:Sistema ;
    rdfs:label "cinemática cabezal-mesa"@es ;
    ex:textoExtracto "En este tipo de cinemáticas un eje de giro se encuentra en el cabezal y el otro en la mesa."@es ;
    ex:compuestoPor ex:EjeGiroCabezal, ex:EjeGiroMesa, ex:EjeHerramienta, ex:EjeRotativoCabezal, ex:EjeRotativoMesa ;
    ex:tieneComponente ex:ParametroTDATA1, ex:ParametroTDATA2, ex:ParametroTDATA3, ex:ParametroTDATA4, ex:ParametroTDATA5, ex:ParametroTDATA6, ex:ParametroTDATA7 .