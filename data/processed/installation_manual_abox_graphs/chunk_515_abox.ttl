@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Parametro_CNC_RTCP ex:identificador "TDATA7" ;
    a ex:Parametro ;
    ex:textoExtracto "Valores posibles: 0 (cero máquina) / 1 (cero pieza). Valor por defecto: 0. Este parámetro indica si el CNC aplica el RTCP respecto el cero máquina o el cero pieza. TDATA7=0 TDATA7=1 Y=Y' Y Y'" .

ex:CNC_RTCP ex:identificador "RTCP" ;
    a ex:Sistema ;
    ex:textoExtracto "Este parámetro indica si el CNC aplica el RTCP respecto el cero máquina o el cero pieza." .