@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NomenclaturaDelEncoder a ns1:Parametro ;
    rdfs:label "Nomenclatura del encóder" ;
    ns1:textoExtracto "NAME | Nomenclatura del encóder." .

ns1:NumeroDeBitsQueConstituyenElDatoEnLaTransmision a ns1:Parametro ;
    rdfs:label "Número de bits que constituyen el dato en la transmisión" ;
    ns1:textoExtracto "DATALENGTH | Número de bits que constituyen el dato en la transmisión." .

ns1:NumeroDeSerieDelEncoder a ns1:Parametro ;
    rdfs:label "Número de serie del encóder" ;
    ns1:textoExtracto "SERIALNUMBER | Número de serie del encóder." .

ns1:ResolucionDelEncoder a ns1:Parametro ;
    rdfs:label "Resolución del encóder" ;
    ns1:textoExtracto "RESOLUTION | Resolución del encóder." .

ns1:TipoDeEncoder a ns1:Parametro ;
    rdfs:label "Tipo de encóder" ;
    ns1:textoExtracto "TYPE | Tipo de encóder." .

