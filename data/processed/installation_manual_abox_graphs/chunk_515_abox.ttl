PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA7
    a ex:Parametro ;
    rdfs:label "Parámetro TDATA7" ;
    ex:identificador "TDATA7" ;
    ex:textoExtracto "Valores posibles: 0 (cero máquina) / 1 (cero pieza). Valor por defecto: 0. Este parámetro indica si el CNC aplica el RTCP respecto el cero máquina o el cero pieza." ;
    ex:valor "0" .