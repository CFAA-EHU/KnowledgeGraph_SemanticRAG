@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TDATA8 a ex:Parametro ;
    ex:identificador "TDATA8" ;
    ex:textoExtracto "Posición de reposo del eje rotativo principal. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0. Consultar el parámetro TDATA9." ;
    ex:valor "Entre ±99999.9999º" ;
    rdfs:label "Posición de reposo del eje rotativo principal" .

ex:TDATA9 a ex:Parametro ;
    ex:identificador "TDATA9" ;
    ex:textoExtracto "Posición de reposo del eje rotativo secundario. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0. Se denomina posición de reposo cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal)." ;
    ex:valor "Entre ±99999.9999º" ;
    rdfs:label "Posición de reposo del eje rotativo secundario" .

ex:TDATA10 a ex:Parametro ;
    ex:identificador "TDATA10" ;
    ex:textoExtracto "Sentido de giro del eje rotativo principal. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0. Consultar el parámetro TDATA11." ;
    ex:valor "0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217)" ;
    rdfs:label "Sentido de giro del eje rotativo principal" .

ex:TDATA11 a ex:Parametro ;
    ex:identificador "TDATA11" ;
    ex:textoExtracto "Sentido de giro del eje rotativo secundario. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." ;
    ex:valor "0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217)" ;
    rdfs:label "Sentido de giro del eje rotativo secundario" .