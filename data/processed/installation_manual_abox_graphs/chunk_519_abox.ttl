@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FrecuenciaParaLaComunicacionEnDat a ns1:Parametro ;
    rdfs:label "Frecuencia para la comunicación EnDat" ;
    ns1:identificador "ENDATCLKFREQ" ;
    ns1:textoExtracto "ENDATCLKFREQ Frecuencia para la comunicación EnDat. Parámetro válido para ejes lineales, rotativos y cabezales." .

ns1:TipoDeCaptacion_0bd03ccfea a ns1:Parametro ;
    rdfs:label "Tipo de captación" ;
    ns1:identificador "FEEDBACKTYPE" ;
    ns1:textoExtracto "Cuando el tipo de captación es EnDat (parámetro FEEDBACKTYPE), este parámetro muestra la tabla de parámetros para configurar la transmisión." .

