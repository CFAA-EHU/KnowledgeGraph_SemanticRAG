@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Parametro1 a ex:Parametro ;
    ex:textoExtracto "parámetros" ;
    ex:valor "TDATA1··TDATA12" .
ex:Parametro2 a ex:Parametro ;
    ex:textoExtracto "parámetros" ;
    ex:valor "1º, 2º, 3º" .
ex:Parametro3 a ex:Parametro ;
    ex:textoExtracto "sentido que se asume como positivo" ;
    ex:valor "(+)" .
ex:EjeRotativo1 a ex:ComponenteMecanico ;
    ex:textoExtracto "tres ejes rotativos" ;
    ex:identificador "1" .
ex:EjeRotativo2 a ex:ComponenteMecanico ;
    ex:textoExtracto "tres ejes rotativos" ;
    ex:identificador "2" .
ex:EjeRotativo3 a ex:ComponenteMecanico ;
    ex:textoExtracto "tres ejes rotativos" ;
    ex:identificador "3" .
ex:CabezalOrtogonal1 a ex:ComponenteMecanico ;
    ex:textoExtracto "cabezales ortogonales" ;
    ex:identificador "1" .
ex:CabezalOrtogonal2 a ex:ComponenteMecanico ;
    ex:textoExtracto "cabezales ortogonales" ;
    ex:identificador "2" .