ex:Sistema_CinematicaCabezal_270
    a               ex:Sistema ;
    rdfs:label      "Sistema de cinemática del cabezal (tipos 17-24)"@es ;
    ex:textoExtracto "Se pueden controlar cabezales ortogonales con tres ejes rotativos. [...] El signo (+) en las figuras indica el sentido que se asume como positivo, los números 1º, 2º, 3º indican los centros de giro."@es ;
    ex:tieneComponente
        ex:Parametro_TDATA1_270 , ex:Parametro_TDATA2_270 , ex:Parametro_TDATA3_270 ,
        ex:Parametro_TDATA4_270 , ex:Parametro_TDATA5_270 , ex:Parametro_TDATA6_270 ,
        ex:Parametro_TDATA7_270 , ex:Parametro_TDATA8_270 , ex:Parametro_TDATA9_270 ,
        ex:Parametro_TDATA10_270 , ex:Parametro_TDATA11_270 , ex:Parametro_TDATA12_270 .