@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FrecuenciaEnDat4MHz a ns1:Frecuencia ;
    rdfs:label "Frecuencia EnDat 4 MHz" ;
    ns1:textoExtracto "Para seleccionar la velocidad de 4 MHz, el encoder debe poder trabajar a esa velocidad y la longitud del cable debe ser inferior a los 50m." ;
    ns1:valor "4 MHz" .

ns1:FrecuenciaEnDatDefault a ns1:Frecuencia ;
    rdfs:label "Frecuencia por defecto EnDat" ;
    ns1:textoExtracto "Se recomienda utilizar la frecuencia por defecto (2 MHz), válida hasta 100 m de cable." ;
    ns1:valor "2 MHz" .

