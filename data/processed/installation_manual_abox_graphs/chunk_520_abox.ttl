@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TDATA1 a ex:Parametro ;
    rdfs:label "TDATA1" ;
    ex:identificador "TDATA1" ;
    ex:textoExtracto "TDATA1 Indica la distancia entre la nariz del mandrino y el centro de giro terciario, eje rotativo terciario, según el eje Z." .

ex:TDATA2 a ex:Parametro ;
    rdfs:label "TDATA2" ;
    ex:identificador "TDATA2" ;
    ex:textoExtracto "TDATA2 Indica la distancia del cabezal desde el 1º centro de giro hasta el punto de referencia máquina, según el eje X." .

ex:TDATA3 a ex:Parametro ;
    rdfs:label "TDATA3" ;
    ex:identificador "TDATA3" ;
    ex:textoExtracto "TDATA3 Indica la distancia del cabezal desde el 1º centro de giro hasta el punto de referencia máquina, según el eje Y." .

ex:TDATA4 a ex:Parametro ;
    rdfs:label "TDATA4" ;
    ex:identificador "TDATA4" ;
    ex:textoExtracto "TDATA4 Indica la distancia del cabezal desde el 1º centro de giro hasta el punto de referencia máquina, según el eje Z." .

ex:TDATA5 a ex:Parametro ;
    rdfs:label "TDATA5" ;
    ex:identificador "TDATA5" ;
    ex:textoExtracto "TDATA5 Indica la distancia desde el 2º centro de giro hasta el 1º centro de giro, según el eje X." .

ex:TDATA6 a ex:Parametro ;
    rdfs:label "TDATA6" ;
    ex:identificador "TDATA6" ;
    ex:textoExtracto "TDATA6 Indica la distancia desde el 2º centro de giro hasta el 1º centro de giro, según el eje Y." .

ex:TDATA7 a ex:Parametro ;
    rdfs:label "TDATA7" ;
    ex:identificador "TDATA7" ;
    ex:textoExtracto "TDATA7 Indica la distancia desde el 2º centro de giro hasta el 1º centro de giro, según el eje Z." .

ex:TDATA8 a ex:Parametro ;
    rdfs:label "TDATA8" ;
    ex:identificador "TDATA8" ;
    ex:textoExtracto "TDATA8 Indica la distancia desde el 3º centro de giro hasta el 2º centro de giro, según el eje X." .

ex:TDATA9 a ex:Parametro ;
    rdfs:label "TDATA9" ;
    ex:identificador "TDATA9" ;
    ex:textoExtracto "TDATA9 Indica la distancia desde el 3º centro de giro hasta el 2º centro de giro, según el eje Y." .

ex:TDATA10 a ex:Parametro ;
    rdfs:label "TDATA10" ;
    ex:identificador "TDATA10" ;
    ex:textoExtracto "TDATA10 Indica la distancia desde el 3º centro de giro hasta el 2º centro de giro, según el eje Z." .

ex:TDATA11 a ex:Parametro ;
    rdfs:label "TDATA11" ;
    ex:identificador "TDATA11" ;
    ex:textoExtracto "TDATA11 Indica la distancia desde el eje de la herramienta hasta el 3º centro de giro, según el eje X." .

ex:TDATA12 a ex:Parametro ;
    rdfs:label "TDATA12" ;
    ex:identificador "TDATA12" ;
    ex:textoExtracto "TDATA12 Indica la distancia desde el eje de la herramienta hasta el 3º centro de giro, según el eje Y." .

ex:EjeRotativoPrincipal a ex:ComponenteMecanico ;
    rdfs:label "eje rotativo principal" ;
    ex:textoExtracto "Se llama eje rotativo principal, al eje rotativo del cabezal que en su giro arrastra a los otros dos ejes de giro." .