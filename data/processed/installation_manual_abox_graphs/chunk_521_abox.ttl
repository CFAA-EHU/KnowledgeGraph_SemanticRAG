@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EjeRotativoSecundario a ex:ComponenteMecanico ;
    rdfs:label "eje rotativo secundario" ;
    ex:textoExtracto "Se llama eje rotativo secundario, al eje rotativo del cabezal que en su giro arrastra a un eje de giro." .

ex:EjeRotativoTerciario a ex:ComponenteMecanico ;
    rdfs:label "eje rotativo terciario" ;
    ex:textoExtracto "Se llama eje rotativo terciario, al eje rotativo del cabezal que en su" .