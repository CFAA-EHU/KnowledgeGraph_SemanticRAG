@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_CinematicasCabezal_Tipos17_24
    a ex:Tabla ;
    rdfs:label "Tabla de cinemáticas del cabezal (tipos 17 a 24)"@es ;
    ex:textoExtracto """
TYPE=17 TDATA 2(+) TDATA 3(+)
A 1º TDATA 4(+) 1º
TDATA 7(+) TDATA 12(+)
2º 2º
3º TDATA 10(+) 3º
TDATA 8(+)
B TDATA 1(+)
A
Z Z Z TDATA 6(+)
Y X X Y

[...]

TYPE=24 TDATA 2(+) TDATA 3(+) TDATA 6(+)
TDATA 4(+)
TDATA 5(+)
C 2º 1º 1º 2º
B
3º 3º TDATA 10(+)
TDATA 8(+) TDATA 1(+)
Z A Z Z
Y X
X Y TDATA 12(+)
""" ;
    ex:identificador "2.9.5" .

ex:Sistema_Cinematica_Tipo17
    a ex:Sistema ;
    rdfs:label "Cinemática Tipo 17"@es ;
    ex:textoExtracto "TYPE=17 TDATA 2(+) TDATA 3(+)" ;
    ex:identificador "17" ;
    ex:detalladoEnEsquema ex:Tabla_CinematicasCabezal_Tipos17_24 .

