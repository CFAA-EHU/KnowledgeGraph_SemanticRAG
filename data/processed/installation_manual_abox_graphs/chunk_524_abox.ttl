@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TDATA13
    a ex:Parametro ;
    rdfs:label "Posición de reposo del eje rotativo principal" ;
    ex:identificador "TDATA13" ;
    ex:valor "0" ;
    ex:textoExtracto "TDATA13 Posición de reposo del eje rotativo principal. Valores posibles: Entre ±999999999.0000º. Por defecto: 0º." .

ex:TDATA14
    a ex:Parametro ;
    rdfs:label "Posición de reposo del eje rotativo secundario" ;
    ex:identificador "TDATA14" ;
    ex:valor "0" ;
    ex:textoExtracto "TDATA14 Posición de reposo del eje rotativo secundario. Valores posibles: Entre ±999999999.0000º. Por defecto: 0º." .

ex:TDATA15
    a ex:Parametro ;
    rdfs:label "Posición de reposo del eje rotativo terciario" ;
    ex:identificador "TDATA15" ;
    ex:valor "0" ;
    ex:textoExtracto "TDATA15 Posición de reposo del eje rotativo terciario. Valores posibles: Entre ±999999999.0000º. Por defecto: 0º. Se denomina posición de reposo cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal)." .

ex:TDATA16
    a ex:Parametro ;
    rdfs:label "Sentido de giro del eje rotativo principal" ;
    ex:identificador "TDATA16" ;
    ex:valor "0" ;
    ex:textoExtracto "TDATA16 Sentido de giro del eje rotativo principal. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." .

ex:TDATA17
    a ex:Parametro ;
    rdfs:label "Sentido de giro del eje rotativo secundario" ;
    ex:identificador "TDATA17" ;
    ex:valor "0" ;
    ex:textoExtracto "TDATA17 Sentido de giro del eje rotativo secundario. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." .

ex:TDATA18
    a ex:Parametro ;
    rdfs:label "Sentido de giro del eje rotativo terciario" ;
    ex:identificador "TDATA18" ;
    ex:valor "0" ;
    ex:textoExtracto "TDATA18 Sentido de giro del eje rotativo terciario. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." .

ex:TDATA19
    a ex:Parametro ;
    rdfs:label "Ejes rotativos manuales o servocontrolados" ;
    ex:identificador "TDATA19" ;
    ex:valor "0" ;
    ex:textoExtracto "TDATA19 Ejes rotativos manuales o servocontrolados. Valores posibles: 0 a 7. Valor por defecto: 0. Este parámetro indica si los ejes rotativos son manuales o servocontrolados." .

ex:DIN66217
    a ex:Directiva ;
    rdfs:label "Norma DIN 66217" ;
    ex:textoExtracto "La dirección de los ejes X Y Z, según la norma DIN 66217, se puede recordar fácilmente utilizando la regla de la mano derecha. En los ejes rotativos, el sentido de giro viene determinado al doblar los dedos alrededor del eje lineal asociado con el dedo pulgar señalando la dirección positiva del eje lineal." .