@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FormatoDePaqueteSSI a ns1:Parametro ;
    rdfs:label "Formato de paquete SSI" ;
    ns1:identificador "SSIPACKFORMAT" ;
    ns1:textoExtracto "SSIPACKFORMAT Formato de paquete SSI. Valores posibles: Data / Data-CRC / CRC-Data / Data-Alarm / Alarm-Data / Data-CRC-Alarm / Alarm-Data-CRC / Data-Alarm-CRC / Alarm-CRC-Data / CRC-Data-Alarm / CRC-Alarm-Data." .

ns1:NumeroDeBitsDeLaTransmisionSSIQueConstituyenLaCota_0cb29d9dff a ns1:Parametro ;
    rdfs:label "Número de bits de la transmisión SSI que constituyen la cota" ;
    ns1:identificador "SSIDATALENGTH" ;
    ns1:textoExtracto "SSIDATALENGTH Número de bits de la transmisión SSI que constituyen la cota. Valores posibles: De 0 a 255. Valor por defecto: 0." .

ns1:TipoDeCalculoARealizarCuandoElEncoderTransmiteInformacionAdicionalALa_a8e4df57bd a ns1:Parametro ;
    rdfs:label "Tipo de cálculo a realizar cuando el encoder transmite información adicional a la cota para realizar algún tipo de comprobación de coherencia en los datos" ;
    ns1:identificador "SSICRCTYPE" ;
    ns1:textoExtracto "SSICRCTYPE Tipo de cálculo a realizar cuando el encoder transmite información adicional a la cota para realizar algún tipo de comprobación de coherencia en los datos." .

ns1:TipoDeOperacionSobreLosDatosAntesDeLeerlos a ns1:Parametro ;
    rdfs:label "Tipo de operación sobre los datos antes de leerlos" ;
    ns1:identificador "SSIOPERATION" ;
    ns1:textoExtracto "SSIOPERATION Tipo de operación sobre los datos antes de leerlos. Valores posibles: De 0 a 1." .

ns1:ValoresQuePuedenProvocarQueElEncoderTransmitaUnoOMasBitsIndicandoAlgu_70b5867337 a ns1:Parametro ;
    rdfs:label "Valores que pueden provocar que el encoder transmita uno o más bits indicando algún tipo de error" ;
    ns1:identificador "SSIALARMLEVEL" ;
    ns1:textoExtracto "SSIALARMLEVEL Valores que pueden provocar que el encoder transmita uno o más bits indicando algún tipo de error." .

