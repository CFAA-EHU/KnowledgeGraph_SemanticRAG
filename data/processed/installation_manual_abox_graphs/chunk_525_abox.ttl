@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TDATA12 a ex:Tabla ;
    ex:textoExtracto "TDATA12 | Significado." ;
    ex:tieneComponente ex:TDATA12_0, ex:TDATA12_1, ex:TDATA12_2, ex:TDATA12_3, ex:TDATA12_4, ex:TDATA12_5, ex:TDATA12_6, ex:TDATA12_7 .

ex:TDATA12_0 a ex:ModoOperacion ;
    ex:identificador "0" ;
    ex:textoExtracto "Los tres ejes son servocontrolados." ;
    ex:valor "Los tres ejes son servocontrolados." .

ex:TDATA12_1 a ex:ModoOperacion ;
    ex:identificador "1" ;
    ex:textoExtracto "Eje principal manual y el resto servocontrolados." ;
    ex:valor "Eje principal manual y el resto servocontrolados." .

ex:TDATA12_2 a ex:ModoOperacion ;
    ex:identificador "2" ;
    ex:textoExtracto "Eje secundario manual y el resto servocontrolados." ;
    ex:valor "Eje secundario manual y el resto servocontrolados." .

ex:TDATA12_3 a ex:ModoOperacion ;
    ex:identificador "3" ;
    ex:textoExtracto "Ejes principal y secundario manuales, eje terciario servocontrolado." ;
    ex:valor "Ejes principal y secundario manuales, eje terciario servocontrolado." .

ex:TDATA12_4 a ex:ModoOperacion ;
    ex:identificador "4" ;
    ex:textoExtracto "Eje terciario manual y el resto servocontrolados." ;
    ex:valor "Eje terciario manual y el resto servocontrolados." .

ex:TDATA12_5 a ex:ModoOperacion ;
    ex:identificador "5" ;
    ex:textoExtracto "Ejes principal y terciario manuales, eje secundario servocontrolado." ;
    ex:valor "Ejes principal y terciario manuales, eje secundario servocontrolado." .

ex:TDATA12_6 a ex:ModoOperacion ;
    ex:identificador "6" ;
    ex:textoExtracto "Ejes secundario y terciario manuales, eje principal servocontrolado." ;
    ex:valor "Ejes secundario y terciario manuales, eje principal servocontrolado." .

ex:TDATA12_7 a ex:ModoOperacion ;
    ex:identificador "7" ;
    ex:textoExtracto "Todos los ejes son manuales." ;
    ex:valor "Todos los ejes son manuales." .