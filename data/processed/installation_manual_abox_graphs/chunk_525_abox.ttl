@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_TDATA12_CinematicasCabezal a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros TDATA12 para cinemáticas del cabezal (tipos 17-24)"@es ;
    ex:textoExtracto """
| TDATA12 | Significado. |
| --- | --- |
| 0 | Los tres ejes son servocontrolados. |
| 1 | Eje principal manual y el resto servocontrolados. |
| 2 | Eje secundario manual y el resto servocontrolados. |
| 3 | Ejes principal y secundario manuales, eje terciario servocontrolado. |
| 4 | Eje terciario manual y el resto servocontrolados. |
| 5 | Ejes principal y terciario manuales, eje secundario servocontrolado. |
| 6 | Ejes secundario y terciario manuales, eje principal servocontrolado. |
| 7 | Todos los ejes son manuales.
""" ;
    ex:identificador "TDATA12" .

ex:Parametro_TDATA12_0
    a ex:Parametro ;
    rdfs:label "TDATA12=0 (tres ejes servocontrolados)"@es ;
    ex:textoExtracto "Los tres ejes son servocontrolados."@es ;
    ex:valor "0" ;
    ex:documentadoEn ex:Tabla_TDATA12_CinematicasCabezal .

ex:Parametro_TDATA12_1
    a ex:Parametro ;
    rdfs:label "TDATA12=1 (eje principal manual, resto servocontrolados)"@es ;
    ex:textoExtracto "Eje principal manual y el resto servocontrolados."@es ;
    ex:valor "1" ;
    ex:documentadoEn ex:Tabla_TDATA12_CinematicasCabezal .

ex:Parametro_TDATA12_2
    a ex:Parametro ;
    rdfs:label "TDATA12=2 (eje secundario manual, resto servocontrolados)"@es ;
    ex:textoExtracto "Eje secundario manual y el resto servocontrolados."@es ;
    ex:valor "2" ;
    ex:documentadoEn ex:Tabla_TDATA12_CinematicasCabezal .

ex:Parametro_TDATA12_3
    a ex:Parametro ;
    rdfs:label "TDATA12=3 (ejes principal/secundario manuales, terciario servocontrolado)"@es ;
    ex:textoExtracto "Ejes principal y secundario manuales, eje terciario servocontrolado."@es ;
    ex:valor "3" ;
    ex:documentadoEn ex:Tabla_TDATA12_CinematicasCabezal .

ex:Parametro_TDATA12_4
    a ex:Parametro ;
    rdfs:label "TDATA12=4 (eje terciario manual, resto servocontrolados)"@es ;
    ex:textoExtracto "Eje terciario manual y el resto servocontrolados."@es ;
    ex:valor "4" ;
    ex:documentadoEn ex:Tabla_TDATA12_CinematicasCabezal .

ex:Parametro_TDATA12_5
    a ex:Parametro ;
    rdfs:label "TDATA12=5 (ejes principal/terciario manuales, secundario servocontrolado)"@es ;
    ex:textoExtracto "Ejes principal y terciario manuales, eje secundario servocontrolado."@es ;
    ex:valor "5" ;
    ex:documentadoEn ex:Tabla_TDATA12_CinematicasCabezal .

ex:Parametro_TDATA12_6
    a ex:Parametro ;
    rdfs:label "TDATA12=6 (ejes secundario/terciario manuales, principal servocontrolado)"@es ;
    ex:textoExtracto "Ejes secundario y terciario manuales, eje principal servocontrolado."@es ;
    ex:valor "6" ;
    ex:documentadoEn ex:Tabla_TDATA12_CinematicasCabezal .

ex:Parametro_TDATA12_7
    a ex:Parametro ;
    rdfs:label "TDATA12=7 (todos los ejes manuales)"@es ;
    ex:textoExtracto "Todos los ejes son manuales."@es ;
    ex:valor "7" ;
    ex:documentadoEn ex:Tabla_TDATA12_CinematicasCabezal .