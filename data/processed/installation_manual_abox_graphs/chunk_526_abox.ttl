@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BitsCRC a ns1:Parametro ;
    rdfs:label "Bits CRC" ;
    ns1:textoExtracto "Este parámetro sólo tiene sentido en el caso de que SSICRCBITS sea distinto de 0." .

ns1:TipoDeCRC a ns1:Parametro ;
    rdfs:label "Tipo de CRC" ;
    ns1:identificador "MPA.SSICRCTYPE" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.SSICRCTYPE[set].xn Cuando el encoder transmite información adicional a la cota, este parámetro define el tipo de cálculo a realizar para comprobar la coherencia en los datos." .

