@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA6 a ex:Parametro ;
    rdfs:label "Radio de zona inaccesible por desalineamiento (TDATA6)"@es ;
    ex:textoExtracto "El desalineamiento de la herramienta da lugar a una zona circular, de radio TDATA6, que no es accesible al mecanizado."@es ;
    ex:identificador "TDATA6" ;
    ex:valor "radio de zona inaccesible"@es .

ex:Parametro_TDATA10 a ex:Parametro ;
    rdfs:label "Sentido de giro del eje giratorio (TDATA10)"@es ;
    ex:textoExtracto "TDATA10 Sentido de giro del eje giratorio. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0."@es ;
    ex:identificador "TDATA10" ;
    ex:valor "0 (DIN 66217) / 1 (contrario a DIN 66217)"@es .

ex:Directiva_DIN66217 a ex:Directiva ;
    rdfs:label "Norma DIN 66217 (sentido de giro)"@es ;
    ex:textoExtracto "según la norma DIN 66217"@es ;
    ex:identificador "DIN 66217" .