@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TipoDeCaptacionSSIChecksumFagor a ns1:Parametro ;
    rdfs:label "Tipo de captación SSI - Checksum Fagor" ;
    ns1:identificador "Checksum Fagor" ;
    ns1:textoExtracto "Algoritmo de comprobación de datos empleado en las captaciones de Fagor Automation." .

ns1:TipoDeCaptacionSSIChecksumINDUCTOSYN a ns1:Parametro ;
    rdfs:label "Tipo de captación SSI - Checksum INDUCTOSYN" ;
    ns1:identificador "Checksum INDUCTOSYN" ;
    ns1:textoExtracto "Algoritmo de comprobación de datos empleado en el conexionado con un módulo INDUCTOSYN." .

ns1:TipoDeCaptacionSSINoCalcularCRC a ns1:Parametro ;
    rdfs:label "Tipo de captación SSI - No calcular CRC" ;
    ns1:identificador "No calcular CRC" ;
    ns1:textoExtracto "Aunque el CNC recibe los bits de CRC, no se hace ningún procesamiento de los mismos y por lo tanto no se reportan errores si la transmisión es errónea." .

