@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:EjeRotativoTipo43 a ex:ComponenteMecanico ;
    ex:textoExtracto "En este tipo de cinemáticas se define la situación física del eje rotativo respecto de los ejes lineales." ;
    ex:tieneComponente ex:TDATA2PosicionEjeRotativo, ex:TDATA4OffsetAngular, ex:TDATA10SentidoGiroEjeGiratorio .

ex:TDATA2PosicionEjeRotativo a ex:Parametro ;
    ex:textoExtracto "TDATA2 Posición del eje rotativo. Valores posibles: Entre ±999999999.0000 Valor por defecto: 0. Indica la posición del eje rotativo según el eje de la herramienta. Si se define con valor ꞏ0ꞏ, se asume que el eje rotativo coincide con el eje lineal (por ejemplo el cabezal de un torno)." ;
    ex:valor "Entre ±999999999.0000" ;
    ex:identificador "TDATA2" .

ex:TDATA4OffsetAngular a ex:Parametro ;
    ex:textoExtracto "TDATA4 Offset angular para el eje rotativo. Valores posibles: Entre ±999999999.0000º Valor por defecto: 0." ;
    ex:valor "Entre ±999999999.0000º" ;
    ex:identificador "TDATA4" .

ex:TDATA10SentidoGiroEjeGiratorio a ex:Parametro ;
    ex:textoExtracto "TDATA10 Sentido de giro del eje giratorio. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." ;
    ex:valor "0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217)" ;
    ex:identificador "TDATA10" .

ex:CNC a ex:Maquina ;
    ex:textoExtracto "Si al ejecutar esta función no se selecciona la cinemática, el CNC cogerá de la primera cinemática del tipo 43 definida en la tabla." .

ex:FuncionCYL a ex:InterfazUsuario ;
    ex:textoExtracto "Estas cinemáticas se seleccionan mediante la función #CYL desde el programa pieza." ;
    ex:identificador "#CYL" .