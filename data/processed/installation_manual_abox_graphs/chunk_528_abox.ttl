@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NivelDeLosBitsDeAlarmaParaDarError a ns1:Parametro ;
    rdfs:label "Nivel de los bits de alarma para dar error" ;
    ns1:identificador "MPA.SSIALARMLEVEL" ;
    ns1:textoExtracto "SSIALARMLEVEL Nivel de los bits de alarma para dar error." .

ns1:NumeroDeBitsDeAlarma a ns1:Parametro ;
    rdfs:label "Número de bits de alarma" ;
    ns1:identificador "MPA.SSIALARMBITS" ;
    ns1:textoExtracto "SSIALARMBITS Número de bits de alarma." .

ns1:NumeroDeBitsDeStart a ns1:Parametro ;
    rdfs:label "Número de bits de start" ;
    ns1:identificador "MPA.SSISTARTBITS" ;
    ns1:textoExtracto "SSISTARTBITS Número de bits de start." .

ns1:NumeroDeBitsQueComponenElCRCDeLaTransmisionSSI a ns1:Parametro ;
    rdfs:label "Número de bits que componen el CRC de la transmisión SSI" ;
    ns1:identificador "MPA.SSICRCBITS" ;
    ns1:textoExtracto "SSICRCBITS Número de bits que componen el CRC de la transmisión SSI que constituyen el chequeo de transmisión válida." .

