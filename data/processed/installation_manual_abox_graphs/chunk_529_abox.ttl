@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:cinematica_cabezal_tipo50
    a ex:Sistema ;
    rdfs:label "Cinemática de cabezal tipo 50" ;
    ex:textoExtracto "Esta cinemática permite controlar cualquier tipo de cabezal que tenga como máximo dos ejes rotativos. [...] Definición vectorial de la cinemáticas." ;
    ex:tieneComponente ex:primer_eje_rotativo, ex:segundo_eje_rotativo, ex:portaherramientas .

ex:primer_eje_rotativo
    a ex:ComponenteMecanico ;
    rdfs:label "Primer eje rotativo" ;
    ex:textoExtracto "V1: Vector dirección del primer eje rotativo. T1: Vector traslación del primer eje rotativo." ;
    ex:compuestoPor ex:vector_traslacion_T1, ex:vector_direccion_V1 .

ex:segundo_eje_rotativo
    a ex:ComponenteMecanico ;
    rdfs:label "Segundo eje rotativo" ;
    ex:textoExtracto "V2: Vector dirección del segundo eje rotativo. T2: Vector traslación del segundo eje rotativo." ;
    ex:compuestoPor ex:vector_traslacion_T2, ex:vector_direccion_V2 .

ex:portaherramientas
    a ex:ComponenteMecanico ;
    rdfs:label "Portaherramientas" ;
    ex:textoExtracto "T3: Vector traslación del portaherramientas. V3: Vector dirección del portaherramientas." ;
    ex:compuestoPor ex:vector_traslacion_T3, ex:vector_direccion_V3 .

ex:vector_traslacion_T1
    a ex:Parametro ;
    rdfs:label "Vector traslación T1" ;
    ex:textoExtracto "T1: Vector traslación del primer eje rotativo." ;
    ex:valor "T1" .

ex:vector_direccion_V1
    a ex:Parametro ;
    rdfs:label "Vector dirección V1" ;
    ex:textoExtracto "V1: Vector dirección del primer eje rotativo." ;
    ex:valor "V1" .

ex:vector_traslacion_T2
    a ex:Parametro ;
    rdfs:label "Vector traslación T2" ;
    ex:textoExtracto "T2: Vector traslación del segundo eje rotativo." ;
    ex:valor "T2" .

ex:vector_direccion_V2
    a ex:Parametro ;
    rdfs:label "Vector dirección V2" ;
    ex:textoExtracto "V2: Vector dirección del segundo eje rotativo." ;
    ex:valor "V2" .

ex:vector_traslacion_T3
    a ex:Parametro ;
    rdfs:label "Vector traslación T3" ;
    ex:textoExtracto "T3: Vector traslación del portaherramientas." ;
    ex:valor "T3" .

ex:vector_direccion_V3
    a ex:Parametro ;
    rdfs:label "Vector dirección V3" ;
    ex:textoExtracto "V3: Vector dirección del portaherramientas." ;
    ex:valor "V3" .