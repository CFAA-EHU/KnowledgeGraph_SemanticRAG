@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoDeTransmisionSSI a ns1:Parametro ;
    rdfs:label "Modo de transmisión SSI" ;
    ns1:identificador "SSIDATAMODE" ;
    ns1:textoExtracto "SSIDATAMODE Modo de transmisión. Valores posibles: De 0 a 1. Valor por defecto: 0." .

ns1:NivelDeAlarmaSSI a ns1:Parametro ;
    rdfs:label "Nivel de alarma SSI" ;
    ns1:identificador "SSIALARMLEVEL" ;
    ns1:textoExtracto "En el caso de que un encoder indique una condición de error con 2 bits, donde el primero de ellos sea un 1 y el segundo un 0 SSIALARMBITS = 2 SSIALARMLEVEL = 2." .

ns1:NumeroDeBitsDeAlarmaSSI a ns1:Parametro ;
    rdfs:label "Número de bits de alarma SSI" ;
    ns1:identificador "SSIALARMBITS" ;
    ns1:textoExtracto "En el caso de que un encoder indique una condición de error con 2 bits, donde el primero de ellos sea un 1 y el segundo un 0 SSIALARMBITS = 2" .

ns1:ResolucionDelContajeDigitalSSI a ns1:Parametro ;
    rdfs:label "Resolución del contaje digital SSI" ;
    ns1:identificador "SSIRESOL" ;
    ns1:textoExtracto "SSIRESOL Resolución del contaje digital. Valores posibles: De 1 a 999999999. Valor por defecto: 10000." .

ns1:TiempoDeEsperaEntreFlancosSSI a ns1:Parametro ;
    rdfs:label "Tiempo de espera entre flancos SSI" ;
    ns1:identificador "STARTDELAY" ;
    ns1:textoExtracto "STARTDELAY Número de clocks a esperar entre el primer flanco de bajada y el primer flanco de subida." .

