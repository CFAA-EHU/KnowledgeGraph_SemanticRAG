@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ResolucionDelEjeParaSSITYPEABSIND a ns1:Parametro ;
    rdfs:label "Resolución del eje para SSITYPE ABSIND",
        "Resolución del eje para encoder de 8192 pulsos por vuelta" ;
    ns1:identificador "SSIRESOL" ;
    ns1:textoExtracto "Para el caso de SSITYPE = ABSIND (inductosyn ROT+ABS), para un giro de 2 ó 4 grados, y dependiendo de si el encoder es de alta o baja resolución, el incremento del contaje es de 10000 unidades. PITCH = 2º ó 4º SSIRESOL = 10000",
        "Para el caso de un encoder de 8192 pulsos por vuelta y un husillo de paso 10 mm. PITCH = 10 mm. SSIRESOL = 8192." .

