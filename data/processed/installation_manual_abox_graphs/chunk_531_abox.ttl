@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstimacionDelRetardoEnElRegulador_244e01530b a ns1:Parametro ;
    rdfs:label "Estimación del retardo en el regulador" ;
    ns1:identificador "AXDELAY" ;
    ns1:textoExtracto "Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado." .

ns1:ValorEstandar a ns1:Parametro ;
    rdfs:label "Estándar" ;
    ns1:textoExtracto "Para regulación Fagor, donde no es necesaria ninguna compensación de retardo." ;
    ns1:valor "Estándar" .

ns1:VariableAsociadaAlRetardoDelRegulador a ns1:Parametro ;
    rdfs:label "Variable asociada al retardo del regulador" ;
    ns1:identificador "MPA.AXDELAY" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.AXDELAY[set].xn" .

