@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA1
    a ex:Parametro ;
    rdfs:label "TDATA1 (Distancia eje X)" ;
    ex:textoExtracto "TDATA1 Distancia del eje rotativo principal al punto de referencia máquina (eje X)." ;
    ex:valor "0 a 99999.9999 mm" ;
    ex:identificador "TDATA1" .

ex:Parametro_TDATA2
    a ex:Parametro ;
    rdfs:label "TDATA2 (Distancia eje Y)" ;
    ex:textoExtracto "TDATA2 Distancia del eje rotativo principal al punto de referencia máquina (eje Y)." ;
    ex:valor "0 a 99999.9999 mm" ;
    ex:identificador "TDATA2" .

ex:Parametro_TDATA3
    a ex:Parametro ;
    rdfs:label "TDATA3 (Distancia eje Z)" ;
    ex:textoExtracto "TDATA3 Distancia del eje rotativo principal al punto de referencia máquina (eje Z)." ;
    ex:valor "0 a 99999.9999 mm" ;
    ex:identificador "TDATA3" .

ex:Parametro_TDATA4
    a ex:Parametro ;
    rdfs:label "TDATA4 (Componente vector dirección eje X)" ;
    ex:textoExtracto "TDATA4 Componente del vector dirección del eje rotativo principal (eje X)." ;
    ex:identificador "TDATA4" .

ex:Parametro_TDATA5
    a ex:Parametro ;
    rdfs:label "TDATA5 (Componente vector dirección eje Y)" ;
    ex:textoExtracto "TDATA5 Componente del vector dirección del eje rotativo principal (eje Y)." ;
    ex:identificador "TDATA5" .

ex:Parametro_TDATA6
    a ex:Parametro ;
    rdfs:label "TDATA6 (Componente vector dirección eje Z)" ;
    ex:textoExtracto "TDATA6 Componente del vector dirección del eje rotativo principal (eje Z)." ;
    ex:identificador "TDATA6" .

ex:Parametro_TDATA7
    a ex:Parametro ;
    rdfs:label "TDATA7 (Posición de reposo)" ;
    ex:textoExtracto "TDATA7 Posición de reposo del eje rotativo principal. Se denomina posición de reposo cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal)." ;
    ex:valor "±99999.9999°" ;
    ex:identificador "TDATA7" .

ex:Parametro_TDATA8
    a ex:Parametro ;
    rdfs:label "TDATA8 (Sentido de giro)" ;
    ex:textoExtracto "TDATA8 Sentido de giro del eje rotativo principal. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217)." ;
    ex:valor "0 o 1" ;
    ex:identificador "TDATA8" .

ex:Parametro_TDATA9
    a ex:Parametro ;
    rdfs:label "TDATA9 (Tipo de control)" ;
    ex:textoExtracto "TDATA9 Eje rotativo principal manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual)." ;
    ex:valor "0 o 1" ;
    ex:identificador "TDATA9" .

ex:Parametro_TDATA22
    a ex:Parametro ;
    rdfs:label "TDATA22 (Vector traslación)" ;
    ex:textoExtracto "Z TDATA 22(-) X Y TDATA 1··TDATA3 Vector traslación del eje rotativo principal. Valores posibles: De 0 a 99999.9999 mm / de 0 a 3937.00787 inch." ;
    ex:valor "0 a 99999.9999 mm" ;
    ex:identificador "TDATA22" .

ex:Sistema_CinematicaCabezalTipo50
    a ex:Sistema ;
    rdfs:label "Sistema de cinemática de cabezal (tipo 50)" ;
    ex:textoExtracto "Definición vectorial de cinemáticas de cabezal (tipo 50)." ;
    ex:tieneComponente ex:Parametro_TDATA1, ex:Parametro_TDATA2, ex:Parametro_TDATA3,
                       ex:Parametro_TDATA4, ex:Parametro_TDATA5, ex:Parametro_TDATA6,
                       ex:Parametro_TDATA7, ex:Parametro_TDATA8, ex:Parametro_TDATA9,
                       ex:Parametro_TDATA22 .