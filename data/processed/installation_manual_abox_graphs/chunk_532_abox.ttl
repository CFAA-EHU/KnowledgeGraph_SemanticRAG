@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CiclosDeRetardoEnElRegulador_b5a46261de a ns1:Parametro ;
    rdfs:label "Ciclos de retardo en el regulador" ;
    ns1:documentadoEn ns1:CNC8070_131a897fed ;
    ns1:textoExtracto "Ciclos de retardo en el regulador. El CNC compensa automáticamente las diferencias de retardo entre los reguladores de los ejes del canal." .

ns1:CNC8070_131a897fed a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC también tiene en cuenta este retardo en el calculo del tiempo de anticipación (marca ADVINPOS), en el repaso de roscas y en el cálculo de la distancia de frenado del palpador." .

