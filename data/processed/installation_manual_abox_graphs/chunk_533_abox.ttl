@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TDATA11 a ex:Parametro ;
    rdfs:label "TDATA11" ;
    ex:textoExtracto "TDATA11 Distancia del eje rotativo secundario al principal (eje X)." ;
    ex:valor "De 0 a 99999.9999 mm / de 0 a 3937.00787 inch. Valor por defecto: 0." .

ex:TDATA12 a ex:Parametro ;
    rdfs:label "TDATA12" ;
    ex:textoExtracto "TDATA12 Distancia del eje rotativo secundario al principal (eje Y)." ;
    ex:valor "De 0 a 99999.9999 mm / de 0 a 3937.00787 inch. Valor por defecto: 0." .

ex:TDATA13 a ex:Parametro ;
    rdfs:label "TDATA13" ;
    ex:textoExtracto "TDATA13 Distancia del eje rotativo secundario al principal (eje Z)." ;
    ex:valor "De 0 a 99999.9999 mm / de 0 a 3937.00787 inch. Valor por defecto: 0." .

ex:TDATA14 a ex:Parametro ;
    rdfs:label "TDATA14" ;
    ex:textoExtracto "TDATA14 Componente del vector dirección del eje rotativo secundario (eje X)." ;
    ex:valor "Valores posibles: De 0 a 99999.9999 mm / de 0 a 3937.00787 inch." .

ex:TDATA15 a ex:Parametro ;
    rdfs:label "TDATA15" ;
    ex:textoExtracto "TDATA15 Componente del vector dirección del eje rotativo secundario (eje Y)." ;
    ex:valor "Valores posibles: De 0 a 99999.9999 mm / de 0 a 3937.00787 inch." .

ex:TDATA16 a ex:Parametro ;
    rdfs:label "TDATA16" ;
    ex:textoExtracto "TDATA16 Componente del vector dirección del eje rotativo secundario (eje Z)." ;
    ex:valor "Valores posibles: De 0 a 99999.9999 mm / de 0 a 3937.00787 inch." .

ex:TDATA17 a ex:Parametro ;
    rdfs:label "TDATA17" ;
    ex:textoExtracto "TDATA17 Posición de reposo del eje rotativo secundario. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0. Se denomina posición de reposo cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal)." .

ex:TDATA18 a ex:Parametro ;
    rdfs:label "TDATA18" ;
    ex:textoExtracto "TDATA18 Sentido de giro del eje rotativo secundario. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0. Consultar el parámetro TDATA8." .

ex:TDATA19 a ex:Parametro ;
    rdfs:label "TDATA19" ;
    ex:textoExtracto "TDATA19 Eje rotativo secundario manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0. Este parámetro indica si el eje rotativo es manual o servocontrolado." .

ex:TDATA21 a ex:Parametro ;
    rdfs:label "TDATA21" ;
    ex:textoExtracto "TDATA21··TDATA23 Vector traslación del portaherramientas. Valores posibles: De 0 a 99999.9999 mm / de 0 a 3937.00787 inch. Valor por defecto: 0. Este vector traslación indica la distancia desde la base del portaherramientas al punto de referencia del eje rotativo secundario." ;
    ex:valor "De 0 a 99999.9999 mm / de 0 a 3937.00787 inch. Valor por defecto: 0." .

ex:TDATA22 a ex:Parametro ;
    rdfs:label "TDATA22" ;
    ex:textoExtracto "TDATA21··TDATA23 Vector traslación del portaherramientas." ;
    ex:valor "De 0 a 99999.9999 mm / de 0 a 3937.00787 inch. Valor por defecto: 0." .

ex:TDATA23 a ex:Parametro ;
    rdfs:label "TDATA23" ;
    ex:textoExtracto "TDATA21··TDATA23 Vector traslación del portaherramientas." ;
    ex:valor "De 0 a 99999.9999 mm / de 0 a 3937.00787 inch. Valor por defecto: 0." .