@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaControlGap a ns1:Sistema ;
    rdfs:label "Sistema de Control de Gap en Máquina Láser" ;
    ns1:textoExtracto "En máquinas láser con control de gap, el parámetro TRANSDELAY del eje asociado al sensor debe valor 0 (cero)" ;
    ns1:tieneComponente ns1:CompensacionDeLosRetardosEnElControlDeGap,
        ns1:RetrasoDeTransmisionDelEjeAsociadoAlSensor .

ns1:CompensacionDeLosRetardosEnElControlDeGap a ns1:Parametro ;
    rdfs:label "Compensación de los retardos en el control de gap" ;
    ns1:identificador "ACFWFACTOR" ;
    ns1:textoExtracto "La compensación de los retardos se realiza con el parámetro ACFWFACTOR" .

ns1:RetrasoDeTransmisionDelEjeAsociadoAlSensor a ns1:Parametro ;
    rdfs:label "Retraso de transmisión del eje asociado al sensor" ;
    ns1:identificador "TRANSDELAY" ;
    ns1:textoExtracto "el parámetro TRANSDELAY del eje asociado al sensor debe valor 0 (cero)" .

