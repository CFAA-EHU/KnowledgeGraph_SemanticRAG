@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA21
    a ex:Parametro ;
    rdfs:label "TDATA21" ;
    ex:identificador "TDATA21" ;
    ex:textoExtracto "TDATA21 Distancia de la base de la herramienta al eje rotativo secundario (eje X)." ;
    ex:valor "0 a 99999.9999 mm / 0 a 3937.00787 inch" .

ex:Parametro_TDATA22
    a ex:Parametro ;
    rdfs:label "TDATA22" ;
    ex:identificador "TDATA22" ;
    ex:textoExtracto "TDATA22 Distancia de la base de la herramienta al eje rotativo secundario (eje Y)." ;
    ex:valor "0 a 99999.9999 mm / 0 a 3937.00787 inch" .

ex:Parametro_TDATA23
    a ex:Parametro ;
    rdfs:label "TDATA23" ;
    ex:identificador "TDATA23" ;
    ex:textoExtracto "TDATA23 Distancia de la base de la herramienta al eje rotativo secundario (eje Z)." ;
    ex:valor "0 a 99999.9999 mm / 0 a 3937.00787 inch" .

ex:Parametro_TDATA24
    a ex:Parametro ;
    rdfs:label "TDATA24" ;
    ex:identificador "TDATA24" ;
    ex:textoExtracto "TDATA24 Componente del vector dirección del portaherramientas." ;
    ex:valor "0 a 99999.9999 mm / 0 a 3937.00787 inch" .

ex:Sistema_CinematicaCabezalTipo50
    a ex:Sistema ;
    rdfs:label "Sistema de cinemática de cabezal (tipo 50)" ;
    ex:textoExtracto "Definición vectorial de cinemáticas de cabezal (tipo 50)." ;
    ex:tieneComponente ex:Parametro_TDATA21 ;
    ex:tieneComponente ex:Parametro_TDATA22 ;
    ex:tieneComponente ex:Parametro_TDATA23 ;
    ex:tieneComponente ex:Parametro_TDATA24 .