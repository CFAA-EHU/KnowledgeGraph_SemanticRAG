@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA23 a ex:Parametro ;
    rdfs:label "TDATA23" ;
    ex:identificador "TDATA23" ;
    ex:textoExtracto "Distancia de la base de la herramienta al eje rotativo secundario (eje Z)." ;
    ex:valor "Distancia al eje Z" .

ex:Parametro_TDATA24 a ex:Parametro ;
    rdfs:label "TDATA24" ;
    ex:identificador "TDATA24" ;
    ex:textoExtracto "Componente del vector dirección del portaherramientas (eje X)." ;
    ex:valor "Componente X" .

ex:Parametro_TDATA25 a ex:Parametro ;
    rdfs:label "TDATA25" ;
    ex:identificador "TDATA25" ;
    ex:textoExtracto "Componente del vector dirección del portaherramientas (eje Y)." ;
    ex:valor "Componente Y" .

ex:Parametro_TDATA26 a ex:Parametro ;
    rdfs:label "TDATA26" ;
    ex:identificador "TDATA26" ;
    ex:textoExtracto "Componente del vector dirección del portaherramientas (eje Z)." ;
    ex:valor "Componente Z" .

ex:Sistema_VectorDireccionPortaherramientas a ex:Sistema ;
    rdfs:label "Vector dirección del portaherramientas" ;
    ex:textoExtracto "Vector dirección del portaherramientas." ;
    ex:compuestoPor ex:Parametro_TDATA24, ex:Parametro_TDATA25, ex:Parametro_TDATA26 .