@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionDelVolante a ns1:Parametro ;
    rdfs:label "Configuración del volante" ;
    ns1:identificador "MANPG n Configuración del volante" ;
    ns1:textoExtracto "MANPG n Configuración del volante. Este parámetro muestra la tabla para configurar los volantes." .

ns1:TablaDeVolantes a ns1:Parametro ;
    rdfs:label "Tabla de volantes" ;
    ns1:identificador "MANPG Tabla de volantes" ;
    ns1:textoExtracto "MANPG Tabla de volantes. Este parámetro muestra la lista de volantes disponibles." .

