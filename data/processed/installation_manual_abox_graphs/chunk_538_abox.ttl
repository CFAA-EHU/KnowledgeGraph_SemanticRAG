@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PrimerTecladoEnElBus a ns1:ComponenteElectrico ;
    rdfs:label "Primer teclado en el bus" ;
    ns1:ilustradoEn ns1:TablaConfiguracionVolantes ;
    ns1:textoExtracto "Primer teclado en el bus. | -1 -2 -3" .

ns1:SegundoTecladoEnElBus a ns1:ComponenteElectrico ;
    rdfs:label "Segundo teclado en el bus" ;
    ns1:ilustradoEn ns1:TablaConfiguracionVolantes ;
    ns1:textoExtracto "Segundo teclado en el bus. | -4 -5 -6" .

ns1:TercerTecladoEnElBus a ns1:ComponenteElectrico ;
    rdfs:label "Tercer teclado en el bus" ;
    ns1:ilustradoEn ns1:TablaConfiguracionVolantes ;
    ns1:textoExtracto "Tercer teclado en el bus. | -7 -8 -9" .

ns1:TablaConfiguracionVolantes a ns1:Tabla ;
    rdfs:label "Configuración de los volantes" ;
    ns1:textoExtracto "Orden del teclado. | Numeración de los volantes." .

