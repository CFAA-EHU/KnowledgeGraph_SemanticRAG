@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Parametro_RTCP ex:identificador "TDATA10" ;
    a ex:Parametro ;
    ex:textoExtracto "Este parámetro indica si el CNC aplica el RTCP respecto el cero máquina o el cero pieza. TDATA10=0 TDATA10=1"@es ;
    ex:valor "0 (cero máquina) / 1 (cero pieza)"@es .

ex:ModoOperacion_RTCP ex:identificador "0" ;
    a ex:ModoOperacion ;
    ex:textoExtracto "Valor por defecto: 0"@es .

ex:ModoOperacion_RTCP_1 ex:identificador "1" ;
    a ex:ModoOperacion ;
    ex:textoExtracto "Valor por defecto: 1"@es .