@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_RTCP_TDATA10
    a               ex:Parametro ;
    rdfs:label      "Parámetro TDATA10 (RTCP)" ;
    ex:identificador "TDATA10" ;
    ex:valor        "0" , "1" ;
    ex:textoExtracto "Origen para aplicar el RTCP. Valores posibles: 0 (cero máquina) / 1 (cero pieza). Valor por defecto: 0. Este parámetro indica si el CNC aplica el RTCP respecto el cero máquina o el cero pieza." .