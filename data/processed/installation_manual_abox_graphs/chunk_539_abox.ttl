@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaMANPG a ns1:Tabla ;
    rdfs:label "Tabla MANPG" ;
    ns1:ilustra ns1:NombreDelEjeAsociadoAlVolante,
        ns1:TipoDeCaptacionAsociadaALaEntradaDelVolante_a10e50dbaa ;
    ns1:textoExtracto "Parámetro incluido en la tabla MANPG." .

ns1:NombreDelEjeAsociadoAlVolante a ns1:Parametro ;
    rdfs:label "Nombre del eje asociado al volante" ;
    ns1:identificador "MPGMAN.MPGAXIS" ;
    ns1:textoExtracto "MPGAXIS Nombre del eje asociado al volante. Valores posibles: Cualquier eje definido en AXISNAME." .

ns1:TipoDeCaptacionAsociadaALaEntradaDelVolante_a10e50dbaa a ns1:Parametro ;
    rdfs:label "Tipo de captación asociada a la entrada del volante" ;
    ns1:identificador "MPGMAN.HWFBTYPE" ;
    ns1:textoExtracto "HWFBTYPE Tipo de captación asociada a la entrada del volante. Valores posibles: TTL / TTLDIFF. Valor por defecto: TTLDIFF." .

