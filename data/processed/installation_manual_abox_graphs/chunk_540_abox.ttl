@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionDeVolanteGeneral a ns1:Parametro ;
    rdfs:label "Configuración de volante general" ;
    ns1:textoExtracto "Para definir un volante general, no asignar ningún valor al parámetro, dejarlo en blanco." .

ns1:NombreDelEjeAsociadoAlVolanteIndividual a ns1:Parametro ;
    rdfs:label "Nombre del eje asociado al volante individual" ;
    ns1:textoExtracto "Para definir un volante individual, definir el nombre del eje al que está asociado." .

ns1:TerminalRemotoHBH3_HBH4 a ns1:ComponenteElectrico ;
    rdfs:label "Terminal remoto HBH3/HBH4" ;
    ns1:textoExtracto "Para el terminal remoto HBH3/HBH4, dejar este parámetro sin definir." .

