@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TDATA19 a ex:Parametro ;
    rdfs:label "TDATA19" ;
    ex:identificador "TDATA19" ;
    ex:textoExtracto "TDATA19 Eje rotativo secundario manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0. Este parámetro indica si el eje rotativo es manual o servocontrolado." ;
    ex:valor "0 (servocontrolado) / 1 (manual)" .

ex:TDATA20 a ex:Parametro ;
    rdfs:label "TDATA20" ;
    ex:identificador "TDATA20" ;
    ex:textoExtracto "TDATA20 Origen para aplicar el RTCP. Valores posibles: 0 (cero máquina) / 1 (cero pieza). Valor por defecto: 0. Consultar el parámetro TDATA10." ;
    ex:valor "0 (cero máquina) / 1 (cero pieza)" .

ex:TDATA31 a ex:Parametro ;
    rdfs:label "TDATA31" ;
    ex:identificador "TDATA31" ;
    ex:textoExtracto "TDATA31 Girar el sistema de coordenadas pieza al girar la mesa. Valores posibles: 0 (sí) / 1 (no). Valor por defecto: 0. Con el modo RTCP activo, este parámetro establece si el sistema de coordenadas pieza está fijo sobre la pieza y gira con ella o si por el contrario se mantiene paralelo al sistema de coordenadas" ;
    ex:valor "0 (sí) / 1 (no)" .