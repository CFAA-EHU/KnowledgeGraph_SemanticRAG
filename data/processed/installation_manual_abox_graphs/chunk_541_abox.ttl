@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_720fe8f988 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Si se utilizan ambos volantes simultáneamente, el CNC sumará o restará los impulsos de ambos volantes, dependiendo del sentido de giro de los mismos." ;
    ns1:tieneComponente ns1:VolanteGeneral1,
        ns1:VolanteIndividual1 .

ns1:VolanteGeneral1 a ns1:ComponenteElectrico ;
    rdfs:label "Volante General 1" ;
    ns1:textoExtracto "Si hay varios ejes seleccionados en modo volante, con el volante general se desplazarán todos ellos." .

ns1:VolanteIndividual1 a ns1:ComponenteElectrico ;
    rdfs:label "Volante Individual 1" ;
    ns1:textoExtracto "Para mover un eje con un volante individual, no hay que hacer ninguna selección previa." .

