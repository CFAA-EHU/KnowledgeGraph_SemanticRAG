@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoOperacion_RTCP
    a               ex:ModoOperacion ;
    rdfs:label      "Modo RTCP" ;
    ex:textoExtracto "Con el modo RTCP activo, este parámetro establece si el sistema de coordenadas pieza está fijo sobre la pieza y gira con ella o si por el contrario se mantiene paralelo al sistema de coordenadas máquina." .

ex:Parametro_CoordenadasPiezaFija
    a               ex:Parametro ;
    rdfs:label      "Parámetro de sistema de coordenadas pieza fija/rotatoria" ;
    ex:textoExtracto "este parámetro establece si el sistema de coordenadas pieza está fijo sobre la pieza y gira con ella o si por el contrario se mantiene paralelo al sistema de coordenadas máquina" ;
    ex:controla    ex:ModoOperacion_RTCP .