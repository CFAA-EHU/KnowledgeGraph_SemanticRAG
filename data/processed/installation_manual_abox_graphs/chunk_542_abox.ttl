@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_f3df4bf726 a ns1:Parametro ;
    rdfs:label "Función de una de las teclas de jog" ;
    ns1:identificador "MPMAN.JOGKEYDEF[jk]" ;
    ns1:textoExtracto "Variable asociada: (V.)MPMAN.JOGKEYDEF[jk] / (V.)MPMAN.JOGKEYBDkbDEF[jk]" .

ns1:Parametro_f8d0894930 a ns1:Parametro ;
    rdfs:label "Función de una de las teclas de jog" ;
    ns1:identificador "MPMAN.JOGKEYBDkbDEF[jk]" ;
    ns1:textoExtracto "Variable asociada: (V.)MPMAN.JOGKEYDEF[jk] / (V.)MPMAN.JOGKEYBDkbDEF[jk]" .

ns1:TablaConfiguracionTeclas a ns1:Tabla ;
    rdfs:label "Tablas para configurar las teclas de jog" ;
    ns1:ilustra ns1:ConfiguracionDeTeclasDeJogParaElOctavoPanel,
        ns1:ConfiguracionDeTeclasDeJogParaElPrimerPanel,
        ns1:ConfiguracionDeTeclasDeJogParaElSegundoPanel ;
    ns1:textoExtracto "JOGKEYDEF JOGKEYBD2DEF JOGKEYBD8DEF Tablas para configurar las teclas de jog." .

ns1:ConfiguracionDeTeclasDeJogParaElOctavoPanel a ns1:Parametro ;
    rdfs:label "Configuración de teclas de jog para el octavo panel" ;
    ns1:identificador "JOGKEYBD8DEF" ;
    ns1:textoExtracto "El parámetro JOGKEYBD8DEF corresponde al octavo panel de jog." .

ns1:ConfiguracionDeTeclasDeJogParaElPrimerPanel a ns1:Parametro ;
    rdfs:label "Configuración de teclas de jog para el primer panel" ;
    ns1:identificador "JOGKEYDEF" ;
    ns1:textoExtracto "El parámetro JOGKEYDEF corresponde al primer panel de jog." .

ns1:ConfiguracionDeTeclasDeJogParaElSegundoPanel a ns1:Parametro ;
    rdfs:label "Configuración de teclas de jog para el segundo panel" ;
    ns1:identificador "JOGKEYBD2DEF" ;
    ns1:textoExtracto "El parámetro JOGKEYBD2DEF corresponde al segundo panel de jog." .

