@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoOperacion_RTCP ex:textoExtracto "Con el modo RTCP activo, este parámetro establece si el sistema de coordenadas pieza está fijo sobre la pieza y gira con ella o si por el contrario se mantiene paralelo al sistema de coordenadas máquina." ;
    a ex:ModoOperacion ;
    rdfs:label "Modo RTCP"@es .

ex:Parametro_coordenadas_pieza ex:textoExtracto "este parámetro establece si el sistema de coordenadas pieza está fijo sobre la pieza y gira con ella o si por el contrario se mantiene paralelo al sistema de coordenadas máquina" ;
    a ex:Parametro ;
    rdfs:label "Parámetro de coordenadas de pieza"@es .

ex:Sistema_coordenadas_pieza ex:textoExtracto "sistema de coordenadas pieza" ;
    a ex:Sistema ;
    rdfs:label "Sistema de coordenadas de pieza"@es .

ex:Sistema_coordenadas_maquina ex:textoExtracto "sistema de coordenadas máquina" ;
    a ex:Sistema ;
    rdfs:label "Sistema de coordenadas de máquina"@es .