@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComportamientoDeLasTeclasDeJog a ns1:Parametro ;
    rdfs:label "Comportamiento de las teclas de jog" ;
    ns1:identificador "MPMAN.JOGTYPE" ;
    ns1:textoExtracto "JOGTYPE Comportamiento de las teclas de jog. Valores posibles: Eje pulsado / Eje mantenido." .

ns1:ConfigurarLasTeclasDeJog a ns1:TareaMantenimiento ;
    rdfs:label "Configurar las teclas de jog" ;
    ns1:textoExtracto "Los valores definen el siguiente comportamiento de las teclas." .

