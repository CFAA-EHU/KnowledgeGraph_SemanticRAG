@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_70598e1735 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC siempre ofrece 16 parámetros" .

ns1:EjeYSentidoDeMovimientoDeCadaTeclaDeUsuario a ns1:Parametro ;
    rdfs:label "Eje y sentido de movimiento de cada tecla de usuario" ;
    ns1:identificador "MPMAN.USERKEYBDkbDEF[uk]" ;
    ns1:textoExtracto "Variable asociada: (V.)MPMAN.USERKEYDEF[uk] / (V.)MPMAN.USERKEYBDkbDEF[uk]" .

ns1:EjeYSentidoDeMovimientoDeCadaTeclaDeUsuario_b741acdd8c a ns1:Parametro ;
    rdfs:label "Eje y sentido de movimiento de cada tecla de usuario" ;
    ns1:identificador "MPMAN.USERKEYDEF[uk]" ;
    ns1:textoExtracto "Variable asociada: (V.)MPMAN.USERKEYDEF[uk] / (V.)MPMAN.USERKEYBDkbDEF[uk]" .

ns1:TablaTeclasJog a ns1:Tabla ;
    rdfs:label "Tablas para configurar las teclas de usuario como teclas de jog" ;
    ns1:ilustradoEn ns1:ConfiguracionDeTeclasDeUsuarioComoTeclasDeJogParaElOctavoPanel,
        ns1:ConfiguracionDeTeclasDeUsuarioComoTeclasDeJogParaElPrimerPanel,
        ns1:ConfiguracionDeTeclasDeUsuarioComoTeclasDeJogParaElSegundoPanel ;
    ns1:textoExtracto "USERKEYDEF USERKEYBD2DEF USERKEYBD8DEF Tablas para configurar las teclas de usuario como teclas de jog." .

ns1:ConfiguracionDeTeclasDeUsuarioComoTeclasDeJogParaElOctavoPanel a ns1:Parametro ;
    rdfs:label "Configuración de teclas de usuario como teclas de jog para el octavo panel" ;
    ns1:identificador "USERKEYBD8DEF" ;
    ns1:textoExtracto "El parámetro USERKEYBD8DEF corresponde al octavo panel de jog" .

ns1:ConfiguracionDeTeclasDeUsuarioComoTeclasDeJogParaElPrimerPanel a ns1:Parametro ;
    rdfs:label "Configuración de teclas de usuario como teclas de jog para el primer panel" ;
    ns1:identificador "USERKEYDEF" ;
    ns1:textoExtracto "El parámetro USERKEYDEF corresponde al primer panel de jog" .

ns1:ConfiguracionDeTeclasDeUsuarioComoTeclasDeJogParaElSegundoPanel a ns1:Parametro ;
    rdfs:label "Configuración de teclas de usuario como teclas de jog para el segundo panel" ;
    ns1:identificador "USERKEYBD2DEF" ;
    ns1:textoExtracto "El parámetro USERKEYBD2DEF corresponde al segundo panel de jog" .

