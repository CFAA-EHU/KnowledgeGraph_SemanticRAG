@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:CinematicaTipo52
    a ex:Sistema ;
    rdfs:label "Cinemática tipo 52 (cabezal-mesa)"@es ;
    ex:textoExtracto "Esta cinemática permite controlar cualquier tipo de cinemática compuesta por un cabezal y una mesa, que tenga como máximo dos ejes rotativos en el cabezal y otros dos en la mesa."@es ;
    ex:tieneComponente ex:CabezalTipo52, ex:MesaTipo52 ;
    ex:identificador "52" .

ex:CabezalTipo52
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal (cinemática tipo 52)"@es ;
    ex:textoExtracto "Cabezal: T1: Vector traslación del primer eje rotativo. T2: Vector traslación del segundo eje rotativo. T3: Vector traslación del portaherramientas."@es ;
    ex:tieneComponente ex:EjeRotativo1_Cabezal, ex:EjeRotativo2_Cabezal, ex:Portaherramientas_Cabezal .

ex:MesaTipo52
    a ex:ComponenteMecanico ;
    rdfs:label "Mesa (cinemática tipo 52)"@es ;
    ex:textoExtracto "Mesa: T4: Vector traslación del tercer eje rotativo. T5: Vector traslación del cuarto eje rotativo."@es ;
    ex:tieneComponente ex:EjeRotativo3_Mesa, ex:EjeRotativo4_Mesa .

ex:EjeRotativo1_Cabezal
    a ex:ComponenteMecanico ;
    rdfs:label "Primer eje rotativo (cabezal, cinemática tipo 52)"@es ;
    ex:textoExtracto "V1: Vector dirección del primer eje rotativo. T1: Vector traslación del primer eje rotativo."@es .

ex:EjeRotativo2_Cabezal
    a ex:ComponenteMecanico ;
    rdfs:label "Segundo eje rotativo (cabezal, cinemática tipo 52)"@es ;
    ex:textoExtracto "V2: Vector dirección del segundo eje rotativo. T2: Vector traslación del segundo eje rotativo."@es .

ex:Portaherramientas_Cabezal
    a ex:ComponenteMecanico ;
    rdfs:label "Portaherramientas (cabezal, cinemática tipo 52)"@es ;
    ex:textoExtracto "T3: Vector traslación del portaherramientas. V3: Vector dirección del portaherramientas."@es .

ex:EjeRotativo3_Mesa
    a ex:ComponenteMecanico ;
    rdfs:label "Tercer eje rotativo (mesa, cinemática tipo 52)"@es ;
    ex:textoExtracto "V4: Vector dirección del tercer eje rotativo. T4: Vector traslación del tercer eje rotativo."@es .

ex:EjeRotativo4_Mesa
    a ex:ComponenteMecanico ;
    rdfs:label "Cuarto eje rotativo (mesa, cinemática tipo 52)"@es ;
    ex:textoExtracto "V5: Vector dirección del cuarto eje rotativo. T5: Vector traslación del cuarto eje rotativo."@es .