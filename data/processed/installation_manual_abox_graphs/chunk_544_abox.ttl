@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:CinematicaCompuestaCabezalMesaTipo52 a ex:Sistema ;
    ex:textoExtracto "Esta cinemática permite controlar cualquier tipo de cinemática compuesta por un cabezal y una mesa, que tenga como máximo dos ejes rotativos en el cabezal y otros dos en la mesa." ;
    ex:compuestoPor ex:EjeRotativoCabezal1, ex:EjeRotativoCabezal2, ex:EjeRotativoMesa3, ex:EjeRotativoMesa4, ex:Portaherramientas .

ex:EjeRotativoCabezal1 a ex:ComponenteMecanico ;
    ex:textoExtracto "T1: Vector traslación del primer eje rotativo." ;
    ex:identificador "T1" .

ex:EjeRotativoCabezal2 a ex:ComponenteMecanico ;
    ex:textoExtracto "T2: Vector traslación del segundo eje rotativo." ;
    ex:identificador "T2" .

ex:Portaherramientas a ex:ComponenteMecanico ;
    ex:textoExtracto "T3: Vector traslación del portaherramientas." ;
    ex:identificador "T3" .

ex:EjeRotativoMesa3 a ex:ComponenteMecanico ;
    ex:textoExtracto "T4: Vector traslación del tercer eje rotativo." ;
    ex:identificador "T4" .

ex:EjeRotativoMesa4 a ex:ComponenteMecanico ;
    ex:textoExtracto "T5: Vector traslación del cuarto eje rotativo." ;
    ex:identificador "T5" .

ex:VectorDireccionEjeRotativoCabezal1 a ex:Parametro ;
    ex:textoExtracto "V1: Vector dirección del primer eje rotativo." ;
    ex:identificador "V1" .

ex:VectorDireccionEjeRotativoCabezal2 a ex:Parametro ;
    ex:textoExtracto "V2: Vector dirección del segundo eje rotativo." ;
    ex:identificador "V2" .

ex:VectorDireccionPortaherramientas a ex:Parametro ;
    ex:textoExtracto "V3: Vector dirección del portaherramientas." ;
    ex:identificador "V3" .

ex:VectorDireccionEjeRotativoMesa3 a ex:Parametro ;
    ex:textoExtracto "V4: Vector dirección del tercer eje rotativo." ;
    ex:identificador "V4" .

ex:VectorDireccionEjeRotativoMesa4 a ex:Parametro ;
    ex:textoExtracto "V5: Vector dirección del cuarto eje rotativo." ;
    ex:identificador "V5" .