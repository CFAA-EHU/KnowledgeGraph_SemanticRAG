@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:VectorDireccionCuartoEjeRotativo a ex:Parametro ;
    rdfs:label "V5" ;
    ex:textoExtracto "V5: Vector dirección del cuarto eje rotativo." ;
    ex:valor "0,0,1" .

ex:VectorTraslacionEjeInexistente a ex:Parametro ;
    ex:textoExtracto "Vector traslación del eje: 0,0,0" ;
    ex:valor "0,0,0" .

ex:PosicionReposoEjeInexistente a ex:Parametro ;
    ex:textoExtracto "Posición de reposo: 0º" ;
    ex:valor "0" .

ex:EjeRotativoManualServocontrolado a ex:Parametro ;
    ex:textoExtracto "Eje rotativo manual o servocontrolado: 1 (manual)" ;
    ex:valor "1" .

ex:VariableComponentePosicionRotacion a ex:Parametro ;
    rdfs:label "V.G.POSROTn" ;
    ex:textoExtracto "La variable del componente correspondiente: V.G.POSROTn = 0" ;
    ex:valor "0" .

