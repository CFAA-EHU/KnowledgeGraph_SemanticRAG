PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_V5
    a ex:Parametro ;
    rdfs:label "Vector dirección del cuarto eje rotativo (V5)"@es ;
    ex:textoExtracto "V5: Vector dirección del cuarto eje rotativo."@es ;
    ex:valor "0,0,1"^^xsd:string ;
    ex:documentadoEn ex:Pagina_285_291 .

ex:Parametro_T5
    a ex:Parametro ;
    rdfs:label "Definición de ejes no físicos (T5)"@es ;
    ex:textoExtracto "T5 Definición de los ejes que no están presentes en la cinemática. Cuando uno de los ejes de la cinemática no exista físicamente en la máquina, se parametrizará de la siguiente forma."@es ;
    ex:documentadoEn ex:Pagina_285_291 .

ex:Parametro_V1
    a ex:Parametro ;
    rdfs:label "Vector dirección del primer eje (V1)"@es ;
    ex:textoExtracto "V1 (TDATA4, TDATA5, TDATA6)"@es ;
    ex:identificador "TDATA4,TDATA5,TDATA6" ;
    ex:documentadoEn ex:Pagina_285_291 .

ex:Parametro_T1
    a ex:Parametro ;
    rdfs:label "Vector traslación del primer eje (T1)"@es ;
    ex:textoExtracto "T1 (TDATA1, TDATA2, TDATA3)"@es ;
    ex:identificador "TDATA1,TDATA2,TDATA3" ;
    ex:documentadoEn ex:Pagina_285_291 .

ex:Parametro_V2
    a ex:Parametro ;
    rdfs:label "Vector dirección del segundo eje (V2)"@es ;
    ex:textoExtracto "V2 (TDATA14, TDATA15, TDATA16)"@es ;
    ex:identificador "TDATA14,TDATA15,TDATA16" ;
    ex:documentadoEn ex:Pagina_285_291 .

ex:Parametro_T2
    a ex:Parametro ;
    rdfs:label "Vector traslación del segundo eje (T2)"@es ;
    ex:textoExtracto "T2 (TDATA11, TDATA12, TDATA13)"@es ;
    ex:identificador "TDATA11,TDATA12,TDATA13" ;
    ex:documentadoEn ex:Pagina_285_291 .

ex:Parametro_T3
    a ex:Parametro ;
    rdfs:label "Vector traslación del tercer eje (T3)"@es ;
    ex:textoExtracto "T3 (TDATA21, TDATA22, TDATA23)"@es ;
    ex:identificador "TDATA21,TDATA22,TDATA23" ;
    ex:documentadoEn ex:Pagina_285_291 .

ex:Parametro_V3
    a ex:Parametro ;
    rdfs:label "Vector dirección del tercer eje (V3)"@es ;
    ex:textoExtracto "V3 (TDATA24, TDATA25, TDATA26)"@es ;
    ex:identificador "TDATA24,TDATA25,TDATA26" ;
    ex:documentadoEn ex:Pagina_285_291 .

ex:Parametro_POSROTn
    a ex:Parametro ;
    rdfs:label "Posición de reposo de eje rotativo (V.G.POSROTn)"@es ;
    ex:textoExtracto "La variable del componente correspondiente: V.G.POSROTn = 0"@es ;
    ex:valor "0"^^xsd:string ;
    ex:documentadoEn ex:Pagina_285_291 .

ex:Pagina_285_291
    a ex:Pagina ;
    rdfs:label "Páginas 285-291: Definición vectorial de cinemáticas de cabezal–mesa (tipo 52)"@es ;
    ex:textoExtracto "Sección 2.9.10 Definición vectorial de cinemáticas de cabezal–mesa (tipo 52)."@es .