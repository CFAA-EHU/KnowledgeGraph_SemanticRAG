@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA33_VectorTraslacion
    a ex:Parametro ;
    rdfs:label "Vector traslación del eje rotativo principal del cabezal (TDATA1-TDATA3)"@es ;
    ex:identificador "TDATA1··TDATA3" ;
    ex:textoExtracto "Vector traslación del eje rotativo principal del cabezal. Valores posibles: De 0 a 99999.9999 mm / de 0 a 3937.00787 inch. [...] TDATA1 Distancia del eje rotativo principal al punto de referencia máquina (eje X). TDATA2 Distancia del eje rotativo principal al punto de referencia máquina (eje Y). TDATA3 Distancia del eje rotativo principal al punto de referencia máquina (eje Z)."@es ;
    ex:valor "0"^^xsd:string .  # Valor por defecto

ex:Parametro_TDATA4_6_VectorDireccion
    a ex:Parametro ;
    rdfs:label "Vector dirección del eje rotativo principal del cabezal (TDATA4-TDATA6)"@es ;
    ex:identificador "TDATA4··TDATA6" ;
    ex:textoExtracto "Vector dirección del eje rotativo principal del cabezal. [...] TDATA4 Componente del vector dirección del eje rotativo principal (eje X). TDATA5 Componente del vector dirección del eje rotativo principal (eje Y). TDATA6 Componente del vector dirección del eje rotativo principal (eje Z)."@es ;
    ex:valor "[0, 0, 1]"^^xsd:string .  # Valor por defecto cuando el eje no existe

ex:Parametro_TDATA7_PosicionReposo
    a ex:Parametro ;
    rdfs:label "Posición de reposo del eje rotativo principal del cabezal"@es ;
    ex:identificador "TDATA7" ;
    ex:textoExtracto "Posición de reposo del eje rotativo principal del cabezal. Valores posibles: Entre ±99999.9999º. [...] Se denomina posición de reposo cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal)."@es ;
    ex:valor "0"^^xsd:string .  # Valor por defecto

ex:Parametro_TDATA8_SentidoGiro
    a ex:Parametro ;
    rdfs:label "Sentido de giro del eje rotativo principal del cabezal"@es ;
    ex:identificador "TDATA8" ;
    ex:textoExtracto "Sentido de giro del eje rotativo principal del cabezal. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217)."@es ;
    ex:valor "0"^^xsd:string .  # Valor por defecto

ex:Directiva_DIN66217
    a ex:Directiva ;
    rdfs:label "Norma DIN 66217 (regla de la mano derecha para ejes X, Y, Z)"@es ;
    ex:identificador "DIN 66217" ;
    ex:textoExtracto "La dirección de los ejes X Y Z, según la norma DIN 66217, se puede recordar fácilmente utilizando la regla de la mano derecha."@es .

ex:Parametro_TDATA8_SentidoGiro
    ex:cumpleNormativa ex:Directiva_DIN66217 .