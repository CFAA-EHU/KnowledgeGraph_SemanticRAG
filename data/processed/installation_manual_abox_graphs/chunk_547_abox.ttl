@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DireccionIPDelVolanteHBH a ns1:Parametro ;
    rdfs:label "Dirección IP del volante HBH" ;
    ns1:identificador "MPMAN.HBHIP" ;
    ns1:textoExtracto "Variable asociada: (V.)MPMAN.HBHIP Dirección IP del volante HBH." .

ns1:ManualTerminalRemotoHBH3 a ns1:Manual ;
    rdfs:label "Manual de terminal remoto HBH3/HBH4" ;
    ns1:textoExtracto "Para obtener mas información sobre el terminal remoto HBH3/HBH4, consultar su manual." .

