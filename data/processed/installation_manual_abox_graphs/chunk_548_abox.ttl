@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA9
    a ex:Parametro ;
    rdfs:label "TDATA9 - Eje rotativo principal del cabezal"@es ;
    ex:textoExtracto "TDATA9 Eje rotativo principal del cabezal manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0."@es ;
    ex:valor "0" ;
    ex:identificador "TDATA9" .

ex:Directiva_DIN66217
    a ex:Directiva ;
    rdfs:label "DIN 66217" ;
    ex:textoExtracto "Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). La dirección de los ejes X Y Z, según la norma DIN 66217, se puede recordar fácilmente utilizando la regla de la mano derecha."@es ;
    ex:identificador "DIN 66217" .

ex:Parametro_TDATA9
    ex:cumpleNormativa ex:Directiva_DIN66217 .