@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TDATA9 a ex:Parametro ;
    ex:identificador "TDATA9" ;
    ex:textoExtracto "Eje rotativo principal del cabezal manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0. Este parámetro indica si el eje rotativo es manual o servocontrolado. Si el eje no existe en la cinemática, se definirá como TDATA9=1." ;
    ex:valor "0 (servocontrolado) / 1 (manual)" .

ex:TDATA11 a ex:Parametro ;
    ex:identificador "TDATA11" ;
    ex:textoExtracto "TDATA11 Distancia del eje rotativo secundario al principal (eje X). Si el eje no existe en la cinemática, se definirá como TDATA11=0." ;
    ex:valor "0 a 99999.9999 mm / 0 a 3937.00787 inch" .

ex:TDATA12 a ex:Parametro ;
    ex:identificador "TDATA12" ;
    ex:textoExtracto "TDATA12 Distancia del eje rotativo secundario al principal (eje Y). Si el eje no existe en la cinemática, se definirá como TDATA12=0." ;
    ex:valor "0 a 99999.9999 mm / 0 a 3937.00787 inch" .

ex:TDATA13 a ex:Parametro ;
    ex:identificador "TDATA13" ;
    ex:textoExtracto "TDATA13 Distancia del eje rotativo secundario al principal (eje Z). Si el eje no existe en la cinemática, se definirá como TDATA13=0." ;
    ex:valor "0 a 99999.9999 mm / 0 a 3937.00787 inch" .

ex:TDATA14 a ex:Parametro ;
    ex:identificador "TDATA14" ;
    ex:textoExtracto "TDATA14 Componente del vector dirección del eje rotativo secundario (eje X). Si el eje no existe en la cinemática, se definirá como TDATA14=0." ;
    ex:valor "0 a 99999.9999" .

ex:TDATA15 a ex:Parametro ;
    ex:identificador "TDATA15" ;
    ex:textoExtracto "TDATA15 Componente del vector dirección del eje rotativo secundario (eje Y). Si el eje no existe en la cinemática, se definirá como TDATA15=0." ;
    ex:valor "0 a 99999.9999" .

ex:TDATA16 a ex:Parametro ;
    ex:identificador "TDATA16" ;
    ex:textoExtracto "TDATA16 Componente del vector dirección del eje rotativo secundario (eje Z). Si el eje no existe en la cinemática, se definirá como TDATA16=1." ;
    ex:valor "0 a 99999.9999" .

ex:TDATA17 a ex:Parametro ;
    ex:identificador "TDATA17" ;
    ex:textoExtracto "TDATA17 Posición de reposo del eje rotativo secundario del cabezal. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0. Se denomina posición de reposo cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal). Si el eje no existe en la cinemática, se definirá como TDATA17=0." ;
    ex:valor "Entre ±99999.9999º" .

ex:TDATA18 a ex:Parametro ;
    ex:identificador "TDATA18" ;
    ex:textoExtracto "TDATA18 Sentido de giro del eje rotativo secundario del cabezal." .