@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA9
    a ex:Parametro ;
    rdfs:label "TDATA9" ;
    ex:identificador "TDATA9" ;
    ex:textoExtracto "TDATA9 Eje rotativo principal del cabezal manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0. Este parámetro indica si el eje rotativo es manual o servocontrolado. Si el eje no existe en la cinemática, se definirá como TDATA9=1." ;
    ex:valor "0" .

ex:Parametro_TDATA11
    a ex:Parametro ;
    rdfs:label "TDATA11" ;
    ex:identificador "TDATA11" ;
    ex:textoExtracto "TDATA11 Distancia del eje rotativo secundario al principal (eje X)." ;
    ex:valor "0" .

ex:Parametro_TDATA12
    a ex:Parametro ;
    rdfs:label "TDATA12" ;
    ex:identificador "TDATA12" ;
    ex:textoExtracto "TDATA12 Distancia del eje rotativo secundario al principal (eje Y)." ;
    ex:valor "0" .

ex:Parametro_TDATA13
    a ex:Parametro ;
    rdfs:label "TDATA13" ;
    ex:identificador "TDATA13" ;
    ex:textoExtracto "TDATA13 Distancia del eje rotativo secundario al principal (eje Z)." ;
    ex:valor "0" .

ex:Parametro_TDATA14
    a ex:Parametro ;
    rdfs:label "TDATA14" ;
    ex:identificador "TDATA14" ;
    ex:textoExtracto "TDATA14 Componente del vector dirección del eje rotativo secundario (eje X)." ;
    ex:valor "0" .

ex:Parametro_TDATA15
    a ex:Parametro ;
    rdfs:label "TDATA15" ;
    ex:identificador "TDATA15" ;
    ex:textoExtracto "TDATA15 Componente del vector dirección del eje rotativo secundario (eje Y)." ;
    ex:valor "0" .

ex:Parametro_TDATA16
    a ex:Parametro ;
    rdfs:label "TDATA16" ;
    ex:identificador "TDATA16" ;
    ex:textoExtracto "TDATA16 Componente del vector dirección del eje rotativo secundario (eje Z)." ;
    ex:valor "1" .

ex:Parametro_TDATA17
    a ex:Parametro ;
    rdfs:label "TDATA17" ;
    ex:identificador "TDATA17" ;
    ex:textoExtracto "TDATA17 Posición de reposo del eje rotativo secundario del cabezal. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0. Se denomina posición de reposo cuando la herramienta está perpendicular al plano de trabajo (paralela al eje longitudinal). Si el eje no existe en la cinemática, se definirá como TDATA17=0." ;
    ex:valor "0" .

ex:Parametro_TDATA18
    a ex:Parametro ;
    rdfs:label "TDATA18" ;
    ex:identificador "TDATA18" ;
    ex:textoExtracto "TDATA18 Sentido de giro del eje rotativo secundario del cabezal." .

ex:Sistema_CinematicaCabezalMesa_Tipo52
    a ex:Sistema ;
    rdfs:label "Sistema de cinemática cabezal-mesa (tipo 52)" ;
    ex:textoExtracto "Definición vectorial de cinemáticas de cabezal–mesa (tipo 52)." ;
    ex:tieneComponente ex:Parametro_TDATA9 ;
    ex:tieneComponente ex:Parametro_TDATA11 ;
    ex:tieneComponente ex:Parametro_TDATA12 ;
    ex:tieneComponente ex:Parametro_TDATA13 ;
    ex:tieneComponente ex:Parametro_TDATA14 ;
    ex:tieneComponente ex:Parametro_TDATA15 ;
    ex:tieneComponente ex:Parametro_TDATA16 ;
    ex:tieneComponente ex:Parametro_TDATA17 ;
    ex:tieneComponente ex:Parametro_TDATA18 .