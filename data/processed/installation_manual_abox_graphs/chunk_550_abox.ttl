@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TDATA17 a ex:Parametro ;
    ex:identificador "TDATA17" ;
    ex:textoExtracto "Se definirá como TDATA17=0" ;
    ex:valor "0" .

ex:TDATA18 a ex:Parametro ;
    ex:identificador "TDATA18" ;
    ex:textoExtracto "TDATA18 Sentido de giro del eje rotativo secundario del cabezal. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0. Consultar el parámetro TDATA8." ;
    ex:valor "0" .

ex:TDATA19 a ex:Parametro ;
    ex:identificador "TDATA19" ;
    ex:textoExtracto "TDATA19 Eje rotativo secundario del cabezal manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0." ;
    ex:valor "0" .

ex:ParametroTDATA8 a ex:Parametro ;
    ex:identificador "TDATA8" ;
    ex:textoExtracto "Consultar el parámetro TDATA8." .