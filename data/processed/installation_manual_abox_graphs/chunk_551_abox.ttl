@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeElementosDeLaTabla a ns1:Parametro ;
    rdfs:label "Número de elementos de la tabla" ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:identificador "MPM.MTABLESIZE" ;
    ns1:textoExtracto "MTABLESIZE Número de elementos de la tabla. Valores posibles: de 0 a 200. Valor por defecto: 50." .

ns1:NumeroDeLaFuncionM a ns1:Parametro ;
    rdfs:label "Número de la función M" ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:identificador "MPM.MNUM[pos]" ;
    ns1:textoExtracto "MNUM Número de la función M. Valores posibles: de 0 a 65535." .

ns1:TipoDeSincronizacion a ns1:Parametro ;
    rdfs:label "Tipo de sincronización" ;
    ns1:documentadoEn ns1:TablaFuncionesM ;
    ns1:identificador "MPM.SYNCHTYPE[pos]" ;
    ns1:textoExtracto "SYNCHTYPE Tipo de sincronización. Valores posibles: Sin sincronización / Antes-Antes / Antes-Después / Después-Después. Valor por defecto: Antes-Antes." .

ns1:TablaFuncionesM a ns1:Tabla ;
    rdfs:label "Tabla de funciones M" ;
    ns1:textoExtracto "DATA Tabla de funciones M. Muestra la tabla de personalización de funciones M." .

