@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TDATA8 a ex:Parametro ;
    rdfs:label "TDATA8" ;
    ex:identificador "TDATA8" ;
    ex:textoExtracto "el parámetro TDATA8. TDATA19 Eje rotativo secundario del cabezal manual o servocontrolado." ;
    ex:valor "0 (servocontrolado) / 1 (manual)" ;
    ex:valor "0" .

ex:TDATA19 a ex:Parametro ;
    rdfs:label "TDATA19" ;
    ex:identificador "TDATA19" ;
    ex:textoExtracto "TDATA19 Eje rotativo secundario del cabezal manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0. Este parámetro indica si el eje rotativo es manual o servocontrolado. Si el eje no existe en la cinemática, se definirá como TDATA19=1." ;
    ex:valor "0 (servocontrolado) / 1 (manual)" ;
    ex:valor "1" ;
    ex:valor "0" .

ex:TDATA21 a ex:Parametro ;
    rdfs:label "TDATA21" ;
    ex:identificador "TDATA21" ;
    ex:textoExtracto "TDATA21 Distancia de la base de la herramienta al eje rotativo secundario (eje X)." ;
    ex:valor "De 0 a 99999.9999 mm / de 0 a 3937.00787 inch" ;
    ex:valor "0" .

