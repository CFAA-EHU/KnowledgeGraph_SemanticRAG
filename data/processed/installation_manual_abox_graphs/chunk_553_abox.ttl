@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArranqueDelCabezal a ns1:Parametro ;
    rdfs:label "Arranque del cabezal" ;
    ns1:identificador "M03" ;
    ns1:textoExtracto "Las funciones M03 y M04 para el arranque del cabezal, es conveniente ejecutarla y sincronizarla antes del movimiento." .

ns1:ArranqueDelCabezal_fcfe4328d7 a ns1:Parametro ;
    rdfs:label "Arranque del cabezal" ;
    ns1:identificador "M04" ;
    ns1:textoExtracto "Las funciones M03 y M04 para el arranque del cabezal, es conveniente ejecutarla y sincronizarla antes del movimiento." .

ns1:NombreDeSubrutinaAsociadaALaFuncionM a ns1:Parametro ;
    rdfs:label "Nombre de subrutina asociada a la función M" ;
    ns1:identificador "MPM.MPROGNAME" ;
    ns1:textoExtracto "MPROGNAME Nombre de subrutina asociada a la función M. Valores posibles: Cualquier texto de hasta 64 caracteres. Valor por defecto: Sin subrutina." .

ns1:PararElCabezal a ns1:Parametro ;
    rdfs:label "Parar el cabezal" ;
    ns1:identificador "M05" ;
    ns1:textoExtracto "La función M05 para parar el cabezal, es conveniente ejecutarla y sincronizarla tras el movimiento." .

