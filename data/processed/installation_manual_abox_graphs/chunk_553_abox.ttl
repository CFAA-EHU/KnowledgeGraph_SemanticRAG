@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TDATA34 a ex:Parametro ;
    rdfs:label "Componente del vector dirección del eje rotativo principal (eje X)" ;
    ex:identificador "TDATA34" ;
    ex:textoExtracto "TDATA34 Componente del vector dirección del eje rotativo principal (eje X)." ;
    ex:valor "0" .

ex:TDATA35 a ex:Parametro ;
    rdfs:label "Componente del vector dirección del eje rotativo principal (eje Y)" ;
    ex:identificador "TDATA35" ;
    ex:textoExtracto "TDATA35 Componente del vector dirección del eje rotativo principal (eje Y)." ;
    ex:valor "0" .

ex:TDATA36 a ex:Parametro ;
    rdfs:label "Componente del vector dirección del eje rotativo principal (eje Z)" ;
    ex:identificador "TDATA36" ;
    ex:textoExtracto "TDATA36 Componente del vector dirección del eje rotativo principal (eje Z)." ;
    ex:valor "1" .

ex:TDATA37 a ex:Parametro ;
    rdfs:label "Posición de reposo del eje rotativo principal de la mesa" ;
    ex:identificador "TDATA37" ;
    ex:textoExtracto "TDATA37 Posición de reposo del eje rotativo principal de la mesa. Valores posibles: Entre ±99999.9999º. Valor por defecto: 0." ;
    ex:valor "0" .

ex:TDATA38 a ex:Parametro ;
    rdfs:label "Sentido de giro del eje rotativo principal de la mesa" ;
    ex:identificador "TDATA38" ;
    ex:textoExtracto "TDATA38 Sentido de giro del eje rotativo principal de la mesa. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." ;
    ex:valor "0" .

ex:TDATA39 a ex:Parametro ;
    rdfs:label "Eje rotativo principal de la mesa manual o servocontrolado" ;
    ex:identificador "TDATA39" ;
    ex:textoExtracto "TDATA39 Eje rotativo principal de la mesa manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0." ;
    ex:valor "0" .

ex:TDATA40 a ex:Parametro ;
    rdfs:label "Origen para aplicar el RTCP" ;
    ex:identificador "TDATA40" ;
    ex:textoExtracto "TDATA40 Origen para aplicar el RTCP. Valores posibles: 0 (cero máquina) / 1 (cero pieza). Valor por defecto: 0." ;
    ex:valor "0" .