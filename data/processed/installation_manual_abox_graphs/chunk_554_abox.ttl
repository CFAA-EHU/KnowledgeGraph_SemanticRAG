@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TDATA41 a ex:Parametro ;
    ex:identificador "TDATA41" ;
    ex:textoExtracto "TDATA41 Distancia del eje rotativo secundario al principal (eje X)." ;
    ex:valor "De 0 a 99999.9999 mm / de 0 a 3937.00787 inch" ;
    ex:valor "Valor por defecto: 0" .

ex:TDATA42 a ex:Parametro ;
    ex:identificador "TDATA42" ;
    ex:textoExtracto "TDATA42 Distancia del eje rotativo secundario al principal (eje Y)." ;
    ex:valor "De 0 a 99999.9999 mm / de 0 a 3937.00787 inch" ;
    ex:valor "Valor por defecto: 0" .

ex:TDATA43 a ex:Parametro ;
    ex:identificador "TDATA43" ;
    ex:textoExtracto "TDATA43 Distancia del eje rotativo secundario al principal (eje Z)." ;
    ex:valor "De 0 a 99999.9999 mm / de 0 a 3937.00787 inch" ;
    ex:valor "Valor por defecto: 0" .

ex:TDATA44 a ex:Parametro ;
    ex:identificador "TDATA44" ;
    ex:textoExtracto "TDATA44 Componente del vector dirección del eje rotativo secundario (eje X)." ;
    ex:valor "Si el eje no existe en la cinemática, se definirá como TDATA44=0" .

ex:TDATA45 a ex:Parametro ;
    ex:identificador "TDATA45" ;
    ex:textoExtracto "TDATA45 Componente del vector dirección del eje rotativo secundario (eje Y)." ;
    ex:valor "Si el eje no existe en la cinemática, se definirá como TDATA45=0" .

ex:TDATA46 a ex:Parametro ;
    ex:identificador "TDATA46" ;
    ex:textoExtracto "TDATA46 Componente del vector dirección del eje rotativo secundario (eje Z)." ;
    ex:valor "Si el eje no existe en la cinemática, se definirá como TDATA46=1" .

ex:TDATA47 a ex:Parametro ;
    ex:identificador "TDATA47" ;
    ex:textoExtracto "TDATA47 Posición de reposo del eje rotativo secundario de la mesa." ;
    ex:valor "Valores posibles: Entre ±99999.9999º" ;
    ex:valor "Valor por defecto: 0" ;
    ex:valor "Se denomina posición de reposo a la posición en la que se han definido los vectores dirección de los ejes rotativos de la cinemática." ;
    ex:valor "Si el eje no existe en la cinemática, se definirá como TDATA7=0" .

ex:TDATA48 a ex:Parametro ;
    ex:identificador "TDATA48" ;
    ex:textoExtracto "TDATA48 Sentido de giro del eje rotativo secundario de la mesa." ;
    ex:valor "Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217)" ;
    ex:valor "Valor por defecto: 0" .