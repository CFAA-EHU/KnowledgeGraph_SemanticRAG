@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TiempoEstimadoParaLaFuncionM a ns1:Parametro ;
    rdfs:label "Tiempo estimado para la función M" ;
    ns1:identificador "MPM.MTIME[pos]" ;
    ns1:textoExtracto "MTIME Tiempo estimado para la función M. Valores posibles: De 0 a 1000000 ms. Valor por defecto: 0 ms." .

ns1:VariableG_CNCHANNEL a ns1:Parametro ;
    rdfs:label "Código de cada canal" ;
    ns1:identificador "G.CNCHANNEL" ;
    ns1:textoExtracto "dentro de la subrutina se puede diferenciar el código de cada canal mediante la variable (V.)G.CNCHANNEL." .

