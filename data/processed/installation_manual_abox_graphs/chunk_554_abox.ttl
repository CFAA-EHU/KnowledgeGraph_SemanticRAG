@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA41
    a ex:Parametro ;
    rdfs:label "TDATA41: Distancia eje rotativo secundario al principal (eje X)" ;
    ex:identificador "TDATA41" ;
    ex:textoExtracto "TDATA41 Distancia del eje rotativo secundario al principal (eje X)." ;
    ex:valor "0"^^xsd:decimal .

ex:Parametro_TDATA42
    a ex:Parametro ;
    rdfs:label "TDATA42: Distancia eje rotativo secundario al principal (eje Y)" ;
    ex:identificador "TDATA42" ;
    ex:textoExtracto "TDATA42 Distancia del eje rotativo secundario al principal (eje Y)." ;
    ex:valor "0"^^xsd:decimal .

ex:Parametro_TDATA43
    a ex:Parametro ;
    rdfs:label "TDATA43: Distancia eje rotativo secundario al principal (eje Z)" ;
    ex:identificador "TDATA43" ;
    ex:textoExtracto "TDATA43 Distancia del eje rotativo secundario al principal (eje Z)." ;
    ex:valor "0"^^xsd:decimal .

ex:Parametro_TDATA44
    a ex:Parametro ;
    rdfs:label "TDATA44: Componente vector dirección eje rotativo secundario (eje X)" ;
    ex:identificador "TDATA44" ;
    ex:textoExtracto "TDATA44 Componente del vector dirección del eje rotativo secundario (eje X)." ;
    ex:valor "0"^^xsd:decimal .

ex:Parametro_TDATA45
    a ex:Parametro ;
    rdfs:label "TDATA45: Componente vector dirección eje rotativo secundario (eje Y)" ;
    ex:identificador "TDATA45" ;
    ex:textoExtracto "TDATA45 Componente del vector dirección del eje rotativo secundario (eje Y)." ;
    ex:valor "0"^^xsd:decimal .

ex:Parametro_TDATA46
    a ex:Parametro ;
    rdfs:label "TDATA46: Componente vector dirección eje rotativo secundario (eje Z)" ;
    ex:identificador "TDATA46" ;
    ex:textoExtracto "TDATA46 Componente del vector dirección del eje rotativo secundario (eje Z)." ;
    ex:valor "1"^^xsd:decimal .

ex:Parametro_TDATA47
    a ex:Parametro ;
    rdfs:label "TDATA47: Posición de reposo eje rotativo secundario" ;
    ex:identificador "TDATA47" ;
    ex:textoExtracto "TDATA47 Posición de reposo del eje rotativo secundario de la mesa. Se denomina posición de reposo a la posición en la que se han definido los vectores dirección de los ejes rotativos de la cinemática." ;
    ex:valor "0"^^xsd:decimal .

ex:Parametro_TDATA48
    a ex:Parametro ;
    rdfs:label "TDATA48: Sentido de giro eje rotativo secundario" ;
    ex:identificador "TDATA48" ;
    ex:textoExtracto "TDATA48 Sentido de giro del eje rotativo secundario de la mesa. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217)." ;
    ex:valor "0"^^xsd:integer .

ex:Sistema_CinematicaTipo52
    a ex:Sistema ;
    rdfs:label "Sistema de cinemática tipo 52 (cabezal–mesa)" ;
    ex:textoExtracto "Definición vectorial de cinemáticas de cabezal–mesa (tipo 52)." ;
    ex:tieneComponente ex:Parametro_TDATA41, ex:Parametro_TDATA42, ex:Parametro_TDATA43, ex:Parametro_TDATA44, ex:Parametro_TDATA45, ex:Parametro_TDATA46, ex:Parametro_TDATA47, ex:Parametro_TDATA48 .