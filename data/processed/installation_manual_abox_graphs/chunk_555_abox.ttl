@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EnviarFuncionMAlPLC a ns1:Parametro ;
    rdfs:label "Enviar función M al PLC" ;
    ns1:identificador "MPM.MPLC[pos]" ;
    ns1:textoExtracto "Variable asociada: (V.)MPM.MPLC[pos] Parámetro incluido en la tabla." .

ns1:TiempoNecesarioParaEjecutarLaPieza a ns1:Parametro ;
    rdfs:label "Tiempo necesario para ejecutar la pieza" ;
    ns1:identificador "MPM.MTIME[pos]" ;
    ns1:textoExtracto "Variable asociada: (V.)MPM.MTIME[pos] Parámetro incluido en la tabla DATA." .

