@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA49
    a ex:Parametro ;
    rdfs:label "TDATA49 (Definición de eje inexistente en cinemática)"@es ;
    ex:textoExtracto "Si el eje no existe en la cinemática, se definirá como TDATA49=1."@es ;
    ex:identificador "TDATA49" ;
    ex:valor "1" .

ex:Parametro_TDATA50
    a ex:Parametro ;
    rdfs:label "TDATA50 (Origen para RTCP)"@es ;
    ex:textoExtracto "TDATA50 Origen para aplicar el RTCP. Valores posibles: 0 (cero máquina) / 1 (cero pieza). Valor por defecto: 0. Consultar el parámetro TDATA40."@es ;
    ex:identificador "TDATA50" ;
    ex:valor "0" .

ex:Parametro_TDATA51
    a ex:Parametro ;
    rdfs:label "TDATA51 (Rotación de sistema de coordenadas pieza)"@es ;
    ex:textoExtracto "TDATA51 Girar el sistema de coordenadas pieza al girar la mesa. Valores posibles: 0 (sí) / 1 (no). Valor por defecto: 0. Con el modo RTCP activo, este parámetro establece si el sistema de coordenadas pieza está fijo sobre la pieza y gira con ella o si por el contrario se mantiene paralelo al sistema de coordenadas máquina."@es ;
    ex:identificador "TDATA51" ;
    ex:valor "0" .

ex:ModoOperacion_RTCP
    a ex:ModoOperacion ;
    rdfs:label "RTCP (Control de Punto de Herramienta)"@es ;
    ex:textoExtracto "modo RTCP activo"@es ;
    ex:identificador "RTCP" .

ex:Parametro_TDATA51
    ex:monitoreaParametro ex:ModoOperacion_RTCP .