@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaDATA a ns1:Tabla ;
    rdfs:label "Tabla DATA" ;
    ns1:textoExtracto "Parámetro incluido en la tabla DATA." ;
    ns1:tieneComponente ns1:DescripcionDeLaFuncionM,
        ns1:EnviarLaFuncionMAlPLCEnLaBusquedaDeBloque .

ns1:DescripcionDeLaFuncionM a ns1:Parametro ;
    rdfs:label "Descripción de la función M" ;
    ns1:identificador "MPM.COMMENT[pos]" ;
    ns1:textoExtracto "Este campo ofrece la posibilidad de asociar una pequeña descripción a la función M." .

ns1:EnviarLaFuncionMAlPLCEnLaBusquedaDeBloque a ns1:Parametro ;
    rdfs:label "Enviar la función M al PLC en la búsqueda de bloque" ;
    ns1:identificador "MPM.MPLC[pos]" ;
    ns1:textoExtracto "Este campo indica si se debe enviar la función M al PLC durante la búsqueda de bloque." .

