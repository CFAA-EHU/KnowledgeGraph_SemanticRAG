@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TDATA49 a ex:Parametro ;
    rdfs:label "TDATA49" ;
    ex:identificador "TDATA49" ;
    ex:textoExtracto "Si el eje no existe en la cinemática, se definirá como TDATA49=1." ;
    ex:valor "1" .

ex:TDATA50 a ex:Parametro ;
    rdfs:label "TDATA50" ;
    ex:identificador "TDATA50" ;
    ex:textoExtracto "TDATA50 Origen para aplicar el RTCP. Valores posibles: 0 (cero máquina) / 1 (cero pieza). Valor por defecto: 0. Consultar el parámetro TDATA40." ;
    ex:valor "0" .

ex:TDATA51 a ex:Parametro ;
    rdfs:label "TDATA51" ;
    ex:identificador "TDATA51" ;
    ex:textoExtracto "TDATA51 Girar el sistema de coordenadas pieza al girar la mesa. Valores posibles: 0 (sí) / 1 (no). Valor por defecto: 0. Con el modo RTCP activo, este parámetro establece si el sistema de coordenadas pieza está fijo sobre la pieza y gira con ella o si por el contrario se mantiene paralelo al sistema de coordenadas máquina." ;
    ex:valor "0" .

ex:RTCP a ex:ModoOperacion ;
    rdfs:label "RTCP" ;
    ex:textoExtracto "Con el modo RTCP activo, este parámetro establece si el sistema de coordenadas pieza está fijo sobre la pieza y gira con ella o si por el contrario se mantiene paralelo al sistema de coordenadas máquina." .