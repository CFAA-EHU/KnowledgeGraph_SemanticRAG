@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TDATA51 a ex:Parametro ;
    ex:identificador "TDATA51" ;
    ex:textoExtracto "Al variar la orientación de la pieza, no se modifica la posición que ocupa la punta de la herramienta sobre la pieza. El sistema de coordenadas está fijo sobre la pieza y gira con ella." ;
    ex:valor "0" .

ex:TDATA51_1 a ex:Parametro ;
    ex:identificador "TDATA51" ;
    ex:textoExtracto "Al variar la orientación de la pieza, no se modifica la posición que ocupa el punto definido como cero pieza. El sistema de coordenadas se mantiene paralelo al sistema de coordenadas máquina." ;
    ex:valor "1" .

ex:TDATA52 a ex:Parametro ;
    ex:identificador "TDATA52" ;
    ex:textoExtracto "Este parámetro establece si el CNC aplica el RTCP a toda la cinemática o sólo a la parte del cabezal. Valores posibles: 0 (sí) / 1 (no). Valor por defecto: 0." ;
    ex:valor "0" .

ex:TDATA52_0 a ex:Parametro ;
    ex:identificador "TDATA52" ;
    ex:textoExtracto "RTCP completo, mesa + cabezal." ;
    ex:valor "0" .

ex:TDATA52_1 a ex:Parametro ;
    ex:identificador "TDATA52" ;
    ex:textoExtracto "RTCP sólo teniendo en cuenta la parte del cabezal." ;
    ex:valor "1" .