@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TDATA51
    a ex:Parametro ;
    rdfs:label "TDATA51" ;
    ex:identificador "TDATA51" ;
    ex:textoExtracto "TDATA51 = 0 / TDATA51 = 1" ;
    ex:textoExtracto "Al variar la orientación de la pieza, no se modifica la posición que ocupa la punta de la herramienta sobre la pieza. El sistema de coordenadas está fijo sobre la pieza y gira con ella. / Al variar la orientación de la pieza, no se modifica la posición que ocupa el punto definido como cero pieza. El sistema de coordenadas se mantiene paralelo al sistema de coordenadas máquina." ;
    ex:valor "0, 1" .

ex:Parametro_TDATA52
    a ex:Parametro ;
    rdfs:label "TDATA52" ;
    ex:identificador "TDATA52" ;
    ex:textoExtracto "TDATA52 = 0 / TDATA52 = 1" ;
    ex:textoExtracto "RTCP completo, mesa + cabezal. / RTCP sólo teniendo en cuenta la parte del cabezal." ;
    ex:textoExtracto "Aplicar RTCP completo. Valores posibles: 0 (sí) / 1 (no). Valor por defecto: 0." ;
    ex:valor "0, 1" .

ex:Tabla_ParametrosRTCP a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros RTCP (TDATA51, TDATA52)" ;
    ex:textoExtracto "TDATA51 | Significado. / TDATA52 | Significado." ;
    ex:documentadoEn ex:Parametro_TDATA51 ;
    ex:documentadoEn ex:Parametro_TDATA52 .