@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCinematicaEjes a ns1:Sistema ;
    rdfs:label "Sistema Cinemática Ejes" ;
    ns1:textoExtracto "Los 3 primeros ejes deben ser lineales sobre los que se aplica la compensación de cabezal. El resto de los ejes podrán ser rotativos o lineales, dependiendo del tipo de cinemática." ;
    ns1:tieneComponente ns1:OctavoEjeDeLaCinematica,
        ns1:RestoDeLosEjes .

ns1:OctavoEjeDeLaCinematica a ns1:Parametro ;
    rdfs:label "Octavo eje de la cinemática" ;
    ns1:textoExtracto "Eje 8º | Octavo eje de la cinemática." .

ns1:RestoDeLosEjes a ns1:Parametro ;
    rdfs:label "Resto de los ejes" ;
    ns1:textoExtracto "Eje 9º y siguientes. | Resto de los ejes." .

