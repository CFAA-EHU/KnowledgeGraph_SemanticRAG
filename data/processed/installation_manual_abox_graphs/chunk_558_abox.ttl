@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:NKINAX a ex:Parametro ;
    ex:textoExtracto "NKINAX Número de ejes de la cinemática. Valores posibles: De 0 a 8. Valor por defecto: 0. Variable asociada: (V.)MPK.NKINAX[kin]" .

ex:PARAM_D_SIZE a ex:Parametro ;
    ex:textoExtracto "PARAM_D_SIZE Número de parámetros en formato decimal. Valores posibles: De 0 a 100. Valor por defecto: 0. Variable asociada: (V.)MPK.PARAM_D_SIZE[kin]" .

ex:TDATA_D a ex:Parametro ;
    ex:textoExtracto "TDATA1··100 Parámetros para configurar la cinemática (formato decimal). Para las cinemáticas predefinidas de Fagor se ofrecen 100 parámetros. Para las cinemáticas propias del fabricante, la cantidad de parámetros es configurable." .

ex:PARAM_I_SIZE a ex:Parametro ;
    ex:textoExtracto "PARAM_I_SIZE Número de parámetros en formato entero. Valores posibles: De 0 a 100. Valor por defecto: 0. Variable asociada: (V.)MPK.PARAM_I_SIZE[kin]" .

ex:TDATA_I a ex:Parametro ;
    ex:textoExtracto "TDATA_I1··100 Parámetros para configurar la cinemática (formato entero). Para las cinemáticas predefinidas de Fagor se ofrecen 100 parámetros. Para las cinemáticas propias del fabricante, la cantidad de parámetros es configurable." .

ex:AUXCTE_SIZE a ex:Parametro ;
    ex:textoExtracto "AUXCTE_SIZE Tamaño del área de variables auxiliares. Valores posibles: De 0 a 1000 bytes. Valor por defecto: 0. Variable asociada: (V.)MPK.AUXCTE_SIZE[kin]" .

ex:KINDATA_SIZE a ex:Parametro ;
    ex:textoExtracto "KINDATA_SIZE Tamaño del área de datos de propósito general. Valores posibles: De 0 a 100000 bytes. Valor por defecto: 0. Variable asociada: (V.)MPK.KINDATA_SIZE[kin]" .