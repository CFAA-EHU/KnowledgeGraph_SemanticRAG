@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_aa0ffd6f39 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:TablaCinematicas ;
    ns1:textoExtracto "El parámetro máquina de canal KINID indica el número de cinemática (no tipo) que asume el CNC en ese canal tras el encendido." .

ns1:NumeroDeCinematica a ns1:Parametro ;
    rdfs:label "Número de cinemática" ;
    ns1:documentadoEn ns1:TablaCinematicas ;
    ns1:textoExtracto "El parámetro máquina de canal KINID indica el número de cinemática (no tipo) que asume el CNC en ese canal tras el encendido." .

ns1:NumeroDeCinematicasDefinidas a ns1:Parametro ;
    rdfs:label "Número de cinemáticas definidas" ;
    ns1:documentadoEn ns1:TablaCinematicas ;
    ns1:identificador "MPK.NKIN" ;
    ns1:textoExtracto "NKIN Número de cinemáticas definidas. Valores posibles: De 0 a 6. Valor por defecto: 0." .

ns1:TablaCinematicas a ns1:Tabla ;
    rdfs:label "Tabla de cinemáticas" ;
    ns1:textoExtracto "Muestra la tabla para definir las cinemáticas del sistema." .

