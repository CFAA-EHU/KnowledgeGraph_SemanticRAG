    a ex:Parametro ;
    rdfs:label "TYPE"@es ;
    ex:identificador "TYPE" ;
    ex:valor "50" ;
    ex:textoExtracto "| TYPE | 50 |"@es ;
    ex:documentadoEn ex:Tabla_RedefinicionCinematicaVectorial_293_308 .

