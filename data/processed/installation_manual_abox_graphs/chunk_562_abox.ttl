    a ex:Parametro ;
    ex:identificador "TYPE" ;
    ex:valor "50"^^<http://www.w3.org/2001/XMLSchema#integer> ;
    ex:textoExtracto "TYPE | 50"@es ;
    ex:documentadoEn ex:Tabla_RedefinicionCinematicaTipo1_16 .

