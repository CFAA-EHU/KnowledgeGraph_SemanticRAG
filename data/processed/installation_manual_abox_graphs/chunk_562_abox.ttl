        "Tipo de cinemática: Cabezal angular YZ",
        "Tipo de cinemática: Cabezal angular ZX",
        "Tipo de cinemática: Cabezal angular ZY",
        "Tipo de cinemática: Cabezal ortogonal o esférico XY",
        "Tipo de cinemática: Cabezal ortogonal o esférico YX",
        "Tipo de cinemática: Cabezal ortogonal o esférico ZX",
        "Tipo de cinemática: Cabezal ortogonal o esférico ZY",
        "Tipo de cinemática: Mesa rotativa AB",
        "Tipo de cinemática: Mesa rotativa AC" ;
    ns1:identificador "TYPE" ;
    ns1:textoExtracto "TYPE = 1 | Cabezal ortogonal o esférico YX.",
