@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla562 a ex:Tabla ;
    ex:textoExtracto """| Parámetro de la cinemática
vectorial (tipo 50). | Valor/parámetro equivalente en la
cinemática tipo 4. |
| --- | --- |
| TYPE | 50 |
| TDATA1 | TDATA13 |
| TDATA2 | TDATA14 |
| TDATA3 | TDATA4 |
| TDATA4 | 0 |
| TDATA5 | 0 |
| TDATA6 | 1 |
| TDATA7 | TDATA8 |
| TDATA8 | TDATA10 |
| TDATA9 | 0 |
| TDATA11 | TDATA2 |
| TDATA12 | TDATA3 |
| TDATA13 | 0 |
| TDATA14 | 0 |
| TDATA15 | 1 |
| TDATA16 | 0 |
| TDATA17 | TDATA9 |
| TDATA18 | TDATA11 |
| TDATA19 | 0 |
| TDATA21 | TDATA5 |
| TDATA22 | 0 |
| TDATA23 | TDATA1 |
| TDATA24 | 0 |
| TDATA25 | 0 |
| TDATA26 | 1 |""" ;
    ex:compuestoPor ex:ParametroCinematicaTipo50, ex:ParametroCinematicaTipo4, ex:Tipo50, ex:Tipo4, ex:TDATA1, ex:TDATA2, ex:TDATA3, ex:TDATA4, ex:TDATA5, ex:TDATA6, ex:TDATA7, ex:TDATA8, ex:TDATA9, ex:TDATA10, ex:TDATA11, ex:TDATA12, ex:TDATA13, ex:TDATA14, ex:TDATA15, ex:TDATA16, ex:TDATA17, ex:TDATA18, ex:TDATA19, ex:TDATA21, ex:TDATA22, ex:TDATA23, ex:TDATA24, ex:TDATA25, ex:TDATA26 .

ex:ParametroCinematicaTipo50 a ex:Parametro ;
    ex:textoExtracto "Parámetro de la cinemática vectorial (tipo 50)." .

ex:ParametroCinematicaTipo4 a ex:Parametro ;
    ex:textoExtracto "Valor/parámetro equivalente en la cinemática tipo 4." .

ex:Tipo50 a ex:Parametro ;
    ex:identificador "50" ;
    ex:textoExtracto "TYPE | 50" .

ex:Tipo4 a ex:Parametro ;
    ex:identificador "4" ;
    ex:textoExtracto "cinemática tipo 4." .

ex:TDATA1 a ex:Parametro ;
    ex:textoExtracto "TDATA1 | TDATA13" .

ex:TDATA2 a ex:Parametro ;
    ex:textoExtracto "TDATA2 | TDATA14" .

ex:TDATA3 a ex:Parametro ;
    ex:textoExtracto "TDATA3 | TDATA4" .

