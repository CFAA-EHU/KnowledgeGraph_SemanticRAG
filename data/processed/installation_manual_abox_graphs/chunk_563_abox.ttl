@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinicionVectorialDeCinematicasDeCabezal a ns1:Parametro ;
    rdfs:label "Definición vectorial de cinemáticas de cabezal."@es ;
    ns1:identificador "TYPE50" ;
    ns1:textoExtracto "TYPE = 50 | Definición vectorial de cinemáticas de cabezal." .

ns1:DefinicionVectorialDeCinematicasDeCabezalMesa a ns1:Parametro ;
    rdfs:label "Definición vectorial de cinemáticas de cabezal–mesa."@es ;
    ns1:identificador "TYPE52" ;
    ns1:textoExtracto "TYPE = 52 | Definición vectorial de cinemáticas de cabezal–mesa." .

ns1:DefinicionVectorialDeCinematicasDeMesa a ns1:Parametro ;
    rdfs:label "Definición vectorial de cinemáticas de mesa."@es ;
    ns1:identificador "TYPE51" ;
    ns1:textoExtracto "TYPE = 51 | Definición vectorial de cinemáticas de mesa." .

ns1:EjeCMecanizadoEnLaSuperficieCilindrica a ns1:Parametro ;
    rdfs:label "Eje C. Mecanizado en la superficie cilíndrica."@es ;
    ns1:identificador "TYPE43" ;
    ns1:textoExtracto "TYPE = 43 | Eje C. Mecanizado en la superficie cilíndrica." .

ns1:EjeCMecanizadoEnLaSuperficieFrontalCuandoALIGNCNO a ns1:Parametro ;
    rdfs:label "Eje C. Mecanizado en la superficie frontal cuando ALIGNC = NO."@es ;
    ns1:identificador "TYPE42" ;
    ns1:textoExtracto "TYPE = 42 | Eje C. Mecanizado en la superficie frontal cuando ALIGNC = NO." .

ns1:EjeCMecanizadoEnLaSuperficieFrontalCuandoALIGNCYES a ns1:Parametro ;
    rdfs:label "Eje C. Mecanizado en la superficie frontal cuando ALIGNC = YES."@es ;
    ns1:identificador "TYPE41" ;
    ns1:textoExtracto "TYPE = 41 | Eje C. Mecanizado en la superficie frontal cuando ALIGNC = YES." .

