@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TablaCinematicaTipo50 a ex:Tabla ;
    ex:textoExtracto """| Parámetro de la cinemática
vectorial (tipo 50). | Valor/parámetro equivalente en la
cinemática tipo 5. |
| --- | --- |
| TYPE | 50 |
| TDATA1 | TDATA2 |
| TDATA2 | TDATA14 |
| TDATA3 | TDATA15 |
| TDATA4 | 1 |
| TDATA5 | 0 |
| TDATA6 | 0 |
| TDATA7 | TDATA8 |
| TDATA8 | TDATA10 |
| TDATA9 | 0, si TDATA12=0 o TDATA12=2
1, si TDATA12=1 o TDATA12=3. |
| TDATA11 | TDATA5*COS(TDATA7) |
| TDATA12 | TDATA3 |
| TDATA13 | TDATA5*SIN(TDATA7) |
| TDATA14 | COS(TDATA7) |
| TDATA15 | 0 |
| TDATA16 | SIN(TDATA7) |
| TDATA17 | TDATA9 |
| TDATA18 | TDATA11 |
| TDATA19 | 0, si TDATA12=0 o TDATA12=1
1, si TDATA12=2 o TDATA12=3. |
| TDATA21 | 0 |
| TDATA22 | TDATA6 |
| TDATA23 | TDATA1 |
| TDATA24 | 0 |
| TDATA25 | 0 |
| TDATA26 | 1 |""" ;
    ex:compuestoPor ex:ParametroCinematicaTipo50_TYPE, ex:ParametroCinematicaTipo50_TDATA1, ex:ParametroCinematicaTipo50_TDATA2, ex:ParametroCinematicaTipo50_TDATA3, ex:ParametroCinematicaTipo50_TDATA4, ex:ParametroCinematicaTipo50_TDATA5, ex:ParametroCinematicaTipo50_TDATA6, ex:ParametroCinematicaTipo50_TDATA7, ex:ParametroCinematicaTipo50_TDATA8, ex:ParametroCinematicaTipo50_TDATA9, ex:ParametroCinematicaTipo50_TDATA11, ex:ParametroCinematicaTipo50_TDATA12, ex:ParametroCinematicaTipo50_TDATA13, ex:ParametroCinematicaTipo50_TDATA14, ex:ParametroCinematicaTipo50_TDATA15, ex:ParametroCinematicaTipo50_TDATA16, ex:ParametroCinematicaTipo50_TDATA17, ex:ParametroCinematicaTipo50_TDATA18, ex:ParametroCinematicaTipo50_TDATA19, ex:ParametroCinematicaTipo50_TDATA21, ex:ParametroCinematicaTipo50_TDATA22, ex:ParametroCinematicaTipo50_TDATA23, ex:ParametroCinematicaTipo50_TDATA24, ex:ParametroCinematicaTipo50_TDATA25, ex:ParametroCinematicaTipo50_TDATA26 .

ex:ParametroCinematicaTipo50_TYPE a ex:Parametro ;
    ex:identificador "TYPE" ;
    ex:textoExtracto "TYPE | 50" .

ex:ParametroCinematicaTipo50_TDATA1 a ex:Parametro ;
    ex:identificador "TDATA1" ;
    ex:textoExtracto "TDATA1 | TDATA2" .

ex:ParametroCinematicaTipo50_TDATA2 a ex:Parametro ;
    ex:identificador "TDATA2" ;
    ex:textoExtracto "TDATA2 | TDATA14" .

ex:ParametroCinematicaTipo50_TDATA3 a ex:Parametro ;
    ex:identificador "TDATA3" ;
    ex:textoExtracto "TDATA3 | TDATA15" .

ex:ParametroCinematicaTipo50_TDATA4 a ex:Parametro ;
    ex:textoExtracto "TDATA4 | 1" .

ex:ParametroCinematicaTipo50_TDATA5 a ex:Parametro ;
    ex:textoExtracto "TDATA5 | 0" .

ex:ParametroCinematicaTipo50_TDATA6 a ex:Parametro ;
    ex:textoExtracto "TDATA6 | 0" .

ex:ParametroCinematicaTipo50_TDATA7 a ex:Parametro ;
    ex:textoExtracto "TDATA7 | TDATA8" .

ex:ParametroCinematicaTipo50_TDATA8 a ex:Parametro ;
    ex:textoExtracto "TDATA8 | TDATA10" .

ex:ParametroCinematicaTipo50_TDATA9 a ex:Parametro ;
    ex:textoExtracto """TDATA9 | 0, si TDATA12=0 o TDATA12=2
1, si TDATA12=1 o TDATA12=3.""" .

ex:ParametroCinematicaTipo50_TDATA11 a ex:Parametro ;
    ex:textoExtracto "TDATA11 | TDATA5*COS(TDATA7)" .

ex:ParametroCinematicaTipo50_TDATA12 a ex:Parametro ;
    ex:textoExtracto "TDATA12 | TDATA3" .

ex:ParametroCinematicaTipo50_TDATA13 a ex:Parametro ;
    ex:textoExtracto "TDATA13 | TDATA5*SIN(TDATA7)" .

ex:ParametroCinematicaTipo50_TDATA14 a ex:Parametro ;
    ex:textoExtracto "TDATA14 | COS(TDATA7)" .

ex:ParametroCinematicaTipo50_TDATA15 a ex:Parametro ;
    ex:textoExtracto "TDATA15 | 0" .

ex:ParametroCinematicaTipo50_TDATA16 a ex:Parametro ;
    ex:textoExtracto "TDATA16 | SIN(TDATA7)" .

ex:ParametroCinematicaTipo50_TDATA17 a ex:Parametro ;
    ex:textoExtracto "TDATA17 | TDATA9" .

ex:ParametroCinematicaTipo50_TDATA18 a ex:Parametro ;
    ex:textoExtracto "TDATA18 | TDATA11" .

ex:ParametroCinematicaTipo50_TDATA19 a ex:Parametro ;
    ex:textoExtracto """TDATA19 | 0, si TDATA12=0 o TDATA12=1
1, si TDATA12=2 o TDATA12=3.""" .

ex:ParametroCinematicaTipo50_TDATA21 a ex:Parametro ;
    ex:textoExtracto "TDATA21 | 0" .

ex:ParametroCinematicaTipo50_TDATA22 a ex:Parametro ;
    ex:textoExtracto "TDATA22 | TDATA6" .

ex:ParametroCinematicaTipo50_TDATA23 a ex:Parametro ;
    ex:textoExtracto "TDATA23 | TDATA1" .

ex:ParametroCinematicaTipo50_TDATA24 a ex:Parametro ;
    ex:textoExtracto "TDATA24 | 0" .

ex:ParametroCinematicaTipo50_TDATA25 a ex:Parametro ;
    ex:textoExtracto "TDATA25 | 0" .

ex:ParametroCinematicaTipo50_TDATA26 a ex:Parametro ;
    ex:textoExtracto "TDATA26 | 1" .