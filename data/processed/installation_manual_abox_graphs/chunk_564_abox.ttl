ex:Tabla_RedefinicionCinematicaVectorial_293_308
    a ex:Tabla ;
    rdfs:label "Tabla para redefinir cinemáticas tipo 1..16 como vectoriales (TDATA11-TDATA26)"@es ;
    ex:textoExtracto """
TDATA11 | TDATA2
TDATA12 | TDATA6*COS(TDATA7)
TDATA13 | TDATA6*SIN(TDATA7)
TDATA14 | 0
TDATA15 | COS(TDATA7)
TDATA16 | SIN(TDATA7)
TDATA17 | TDATA9
TDATA18 | TDATA11
TDATA19 | 0, si TDATA12=0 o TDATA12=1
          1, si TDATA12=2 o TDATA12=3.
TDATA21 | TDATA5
TDATA22 | 0
TDATA23 | TDATA1
TDATA24 | 0
TDATA25 | 0
TDATA26 | 1
Adaptar una cinemática tipo 7 a una cinemática tipo 50."""@es ;
    ex:identificador "2.9.12" ;
    ex:ilustradoEn ex:Manual_Broaching .