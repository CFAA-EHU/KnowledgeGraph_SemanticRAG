@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaRedefinicionCinematicaTipo50_a_Tipo7 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de equivalencia: cinemática tipo 50 (vectorial) ↔ tipo 7"@es ;
    ex:textoExtracto """
| Parámetro de la cinemática vectorial (tipo 50). | Valor/parámetro equivalente en la cinemática tipo 7. |
| --- | --- |
| TYPE | 50 |
| TDATA1 | TDATA13 |
| TDATA2 | TDATA14 |
| TDATA3 | TDATA4 |
| TDATA4 | 0 |
| TDATA5 | 0 |
| TDATA6 | 1 |
| TDATA7 | TDATA8 |
| TDATA8 | TDATA10 |
| TDATA9 | 0, si TDATA12=0 o TDATA12=2; 1, si TDATA12=1 o TDATA12=3. |
| TDATA11 | TDATA5*SIN(TDATA7) |
| TDATA12 | TDATA3 |
| TDATA13 | TDATA5*COS(TDATA7) |
| TDATA14 | SIN(TDATA7) |
| TDATA15 | 0 |
| TDATA16 | COS(TDATA7) |
| TDATA17 | TDATA9 |
| TDATA18 | TDATA11 |
| TDATA19 | 0, si TDATA12=0 o TDATA12=1; 1, si TDATA12=2 o TDATA12=3. |
| TDATA21 | 0 |
| TDATA22 | TDATA6 |
| TDATA23 | TDATA1 |
| TDATA24 | 0 |
| TDATA25 | 0 |
| TDATA26 | 1 |
"""@es .

ex:TablaRedefinicionCinematicaTipo50_a_Tipo8 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de equivalencia: cinemática tipo 50 (vectorial) ↔ tipo 8"@es ;
    ex:textoExtracto """
| Parámetro de la cinemática vectorial (tipo 50). | Valor/parámetro equivalente en la cinemática tipo 8. |
| --- | --- |
| TYPE | 50 |
| TDATA1 | TDATA13 |
| TDATA2 | TDATA14 |
| TDATA3 | TDATA4 |
| TDATA4 | 0 |
| TDATA5 | 0 |
| TDATA6 | 1 |
| TDATA7 | TDATA8 |
| TDATA8 | TDATA10 |
| TDATA9 | 0, si TDATA12=0 o TDATA12=2; 1, si TDATA12=1 o TDATA12=3.
"""@es .

ex:Parametro_TYPE_Tipo50
    a ex:Parametro ;
    rdfs:label "TYPE (cinemática tipo 50)"@es ;
    ex:identificador "TYPE" ;
    ex:valor "50" ;
    ex:textoExtracto "TYPE | 50"@es ;
    ex:documentadoEn ex:TablaRedefinicionCinematicaTipo50_a_Tipo7 ;
    ex:documentadoEn ex:TablaRedefinicionCinematicaTipo50_a_Tipo8 .

ex:Parametro_TDATA1_Tipo50
    a ex:Parametro ;
    rdfs:label "TDATA1 (cinemática tipo 50)"@es ;
    ex:identificador "TDATA1" ;
    ex:textoExtracto "TDATA1 | TDATA13"@es ;
    ex:documentadoEn ex:TablaRedefinicionCinematicaTipo50_a_Tipo7 ;
    ex:documentadoEn ex:TablaRedefinicionCinematicaTipo50_a_Tipo8 .

ex:Parametro_TDATA13_Tipo7
    a ex:Parametro ;
    rdfs:label "TDATA13 (cinemática tipo 7)"@es ;
    ex:identificador "TDATA13" ;
    ex:textoExtracto "TDATA1 | TDATA13"@es ;
    ex:documentadoEn ex:TablaRedefinicionCinematicaTipo50_a_Tipo7 .

ex:Parametro_TDATA13_Tipo8
    a ex:Parametro ;
    rdfs:label "TDATA13 (cinemática tipo 8)"@es ;
    ex:identificador "TDATA13" ;
    ex:textoExtracto "TDATA1 | TDATA13"@es ;
    ex:documentadoEn ex:TablaRedefinicionCinematicaTipo50_a_Tipo8 .