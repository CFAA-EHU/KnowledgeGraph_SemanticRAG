@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaRedefinicionCinematica1_16 a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Tabla para redefinir cinemáticas tipo 1..16 como vectoriales"@es ;
    ex:textoExtracto """
TDATA11 | TDATA2
TDATA12 | TDATA6*SIN(TDATA7)
TDATA13 | TDATA6*COS(TDATA7)
TDATA14 | 0
TDATA15 | SIN(TDATA7)
TDATA16 | COS(TDATA7)
TDATA17 | TDATA9
TDATA18 | TDATA11
TDATA19 | 0, si TDATA12=0 o TDATA12=1
         | 1, si TDATA12=2 o TDATA12=3.
TDATA21 | TDATA5
TDATA22 | 0
TDATA23 | TDATA1
TDATA24 | 0
TDATA25 | 0
TDATA26 | 1
"""@es ;
    ex:identificador "2.9.12" .

ex:Parametro_TDATA1
    a               ex:Parametro ;
    ex:textoExtracto "TDATA23 | TDATA1"@es .

ex:Parametro_TDATA2
    a               ex:Parametro ;
    ex:textoExtracto "TDATA11 | TDATA2"@es .

ex:Parametro_TDATA5
    a               ex:Parametro ;
    ex:textoExtracto "TDATA21 | TDATA5"@es .

ex:Parametro_TDATA6
    a               ex:Parametro ;
    ex:textoExtracto "TDATA12 | TDATA6*SIN(TDATA7)", "TDATA13 | TDATA6*COS(TDATA7)"@es .

ex:Parametro_TDATA7
    a               ex:Parametro ;
    ex:textoExtracto "TDATA12 | TDATA6*SIN(TDATA7)",
                     "TDATA13 | TDATA6*COS(TDATA7)",
                     "TDATA15 | SIN(TDATA7)",
                     "TDATA16 | COS(TDATA7)"@es .

ex:Parametro_TDATA9
    a               ex:Parametro ;
    ex:textoExtracto "TDATA17 | TDATA9"@es .

ex:Parametro_TDATA11
    a               ex:Parametro ;
    ex:textoExtracto "TDATA11 | TDATA2", "TDATA18 | TDATA11"@es .

ex:Parametro_TDATA12
    a               ex:Parametro ;
    ex:textoExtracto "TDATA12 | TDATA6*SIN(TDATA7)",
                     "TDATA19 | 0, si TDATA12=0 o TDATA12=1                       1, si TDATA12=2 o TDATA12=3."@es .

ex:Parametro_TDATA17
    a               ex:Parametro ;
    ex:textoExtracto "TDATA17 | TDATA9"@es .

ex:Parametro_TDATA18
    a               ex:Parametro ;
    ex:textoExtracto "TDATA18 | TDATA11"@es .

ex:Parametro_TDATA19
    a               ex:Parametro ;
    ex:textoExtracto "TDATA19 | 0, si TDATA12=0 o TDATA12=1                       1, si TDATA12=2 o TDATA12=3."@es .

ex:Parametro_TDATA21
    a               ex:Parametro ;
    ex:textoExtracto "TDATA21 | TDATA5"@es .

ex:Parametro_TDATA26
    a               ex:Parametro ;
    ex:textoExtracto "TDATA26 | 1"@es .

ex:TablaRedefinicionCinematica1_16 a ex:Tabla ;
    ex:documentadoEn ex:ManualBroaching ;
    ex:tieneComponente
        ex:Parametro_TDATA1, ex:Parametro_TDATA2, ex:Parametro_TDATA5,
        ex:Parametro_TDATA6, ex:Parametro_TDATA7, ex:Parametro_TDATA9,
        ex:Parametro_TDATA11, ex:Parametro_TDATA12, ex:Parametro_TDATA17,
        ex:Parametro_TDATA18, ex:Parametro_TDATA19, ex:Parametro_TDATA21,
        ex:Parametro_TDATA26 .