@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TablaCinematicaTipo51 a ex:Tabla ;
    ex:textoExtracto "Adaptar una cinemática tipo 10 a una cinemática tipo 51. | Parámetro de la cinemática vectorial (tipo 51). | Valor/parámetro equivalente en la cinemática tipo 10." ;
    ex:tieneComponente ex:ParametroCinematicaTipo51_TYPE, ex:ParametroCinematicaTipo51_TDATA1, ex:ParametroCinematicaTipo51_TDATA2, ex:ParametroCinematicaTipo51_TDATA3, ex:ParametroCinematicaTipo51_TDATA4, ex:ParametroCinematicaTipo51_TDATA5, ex:ParametroCinematicaTipo51_TDATA6, ex:ParametroCinematicaTipo51_TDATA7, ex:ParametroCinematicaTipo51_TDATA8, ex:ParametroCinematicaTipo51_TDATA9, ex:ParametroCinematicaTipo51_TDATA10, ex:ParametroCinematicaTipo51_TDATA11, ex:ParametroCinematicaTipo51_TDATA12, ex:ParametroCinematicaTipo51_TDATA13, ex:ParametroCinematicaTipo51_TDATA14, ex:ParametroCinematicaTipo51_TDATA15, ex:ParametroCinematicaTipo51_TDATA16, ex:ParametroCinematicaTipo51_TDATA17, ex:ParametroCinematicaTipo51_TDATA18, ex:ParametroCinematicaTipo51_TDATA19, ex:ParametroCinematicaTipo51_TDATA20, ex:ParametroCinematicaTipo51_TDATA31 .

ex:ParametroCinematicaTipo51_TYPE a ex:Parametro ;
    ex:identificador "TYPE" ;
    ex:valor "51" ;
    ex:textoExtracto "TYPE | 51" .

ex:ParametroCinematicaTipo51_TDATA1 a ex:Parametro ;
