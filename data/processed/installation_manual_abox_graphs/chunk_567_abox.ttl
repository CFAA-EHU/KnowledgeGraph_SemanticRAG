@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:MaximoOffsetQuePuedeDefinirElUsuario_71177cb947 a ns1:Parametro ;
    rdfs:label "Máximo offset que puede definir el usuario" ;
    ns1:textoExtracto "En la columna \"MAX OFFSET\", el fabricante determina el offset máximo que puede definir el usuario. Esta columna siempre será un valor positivo, y el offset definido por el usuario será un valor comprendido entre \"- MAX OFFSET\" y \"+ MAX OFFSET\"." .

ns1:OffsetDelParametro a ns1:Parametro ;
    rdfs:label "Offset del parámetro" ;
    ns1:textoExtracto "En la columna \"OFFSET\", el usuario define el offset del parámetro. Los valores de offset definidos por el usuario se sumarán a su parámetro TDATA correspondiente." .

ns1:ValorDelParametro a ns1:Parametro ;
    rdfs:label "Valor del parámetro" ;
    ns1:textoExtracto "En la columna \"Value\" el fabricante determina el valor del parámetro, que podrá ser modificado por el usuario mediante la columna \"OFFSET\" o su variable asociada." .

