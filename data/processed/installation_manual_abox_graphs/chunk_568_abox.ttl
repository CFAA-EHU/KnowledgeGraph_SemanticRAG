@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla_568_2_9_12 a ex:Tabla ;
    ex:textoExtracto """| Parámetro de la cinemática
vectorial (tipo 51). | Valor/parámetro equivalente en la
cinemática tipo 11. |
| --- | --- |
| TYPE | 51 |
| TDATA1 | -(TDATA2) |
| TDATA2 | 0 |
| TDATA3 | -(TDATA5+TDATA4) |
| TDATA4 | 0 |
| TDATA5 | 1 |
| TDATA6 | 0 |
| TDATA7 | TDATA8 |
| TDATA8 | TDATA10 |
| TDATA9 | 0 |
| TDATA10 | TDATA7 |
| TDATA11 | 0 |
| TDATA12 | -TDATA3 |
| TDATA13 | TDATA5 |
| TDATA14 | 1 |
| TDATA15 | 0 |
| TDATA16 | 0 |
| TDATA17 | TDATA9 |
| TDATA18 | TDATA11 |
| TDATA19 | 0 |
| TDATA20 | TDATA17 |
| TDATA31 | TDATA16 |
 Adaptar una cinemática tipo 12 a una cinemática tipo 51.""" ;
    ex:tieneComponente ex:ParametroCinematicaVectorialTipo51, ex:ParametroCinematicaTipo11, ex:Tipo_51, ex:TDATA1, ex:TDATA2, ex:TDATA3, ex:TDATA4, ex:TDATA5, ex:TDATA6, ex:TDATA7, ex:TDATA8, ex:TDATA9, ex:TDATA10, ex:TDATA11, ex:TDATA12, ex:TDATA13, ex:TDATA14, ex:TDATA15, ex:TDATA16, ex:TDATA17, ex:TDATA18, ex:TDATA19, ex:TDATA20, ex:TDATA31 .

ex:ParametroCinematicaVectorialTipo51 a ex:Parametro ;
    ex:textoExtracto "Parámetro de la cinemática vectorial (tipo 51)." .

ex:ParametroCinematicaTipo11 a ex:Parametro ;
    ex:textoExtracto "Valor/parámetro equivalente en la cinemática tipo 11." .

ex:Tipo_51 a ex:Parametro ;
    ex:identificador "51" ;
    ex:textoExtracto "TYPE | 51" .

ex:TDATA1 a ex:Parametro ;
    ex:valor "-(TDATA2)" ;
    ex:textoExtracto "TDATA1 | -(TDATA2)" .

ex:TDATA2 a ex:Parametro ;
