ns1:AnguloEntreLosEjesRotativosPrincipalYSecundarioEnLosCabezalesRotativos a ns1:Parametro ;
    rdfs:label "Ángulo entre los ejes rotativos principal y secundario en los cabezales rotativos" ;
    ns1:identificador "TDATA7" ;
    ns1:textoExtracto "TDATA7 Indica el ángulo entre los ejes rotativos principal y secundario, en los cabezales rotativos." .

ns1:CabezalAngular a ns1:Sistema ;
    rdfs:label "Cabezal angular" ;
    ns1:textoExtracto "Cabezal angular." .

ns1:CabezalEsferico a ns1:Sistema ;
    rdfs:label "Cabezal esférico" ;
    ns1:textoExtracto "Cabezal esférico." .

ns1:CabezalOrtogonal a ns1:Sistema ;
