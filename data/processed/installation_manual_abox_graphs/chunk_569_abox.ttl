ns1:DefinicionDeLasCinematicasDelCabezalTipo1 a ns1:Parametro ;
    rdfs:label "Definición de las cinemáticas del cabezal tipo 1" ;
    ns1:identificador "TYPE=1" ;
    ns1:textoExtracto "TYPE=1 TDATA 13(+) TDATA 14(+)" .

