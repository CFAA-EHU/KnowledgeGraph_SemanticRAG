@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DireccionDeLosEjesXYZSegunLaNormaDIN66217 a ns1:Parametro ;
    rdfs:label "Dirección de los ejes X Y Z según la norma DIN 66217" ;
    ns1:textoExtracto "Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." .

ns1:EjesRotativosManualesOServocontrolados a ns1:Parametro ;
    rdfs:label "Ejes rotativos manuales o servocontrolados" ;
    ns1:identificador "TDATA12" ;
    ns1:textoExtracto "Valores posibles: 0 a 3. Valor por defecto: 0. Este parámetro indica si los ejes rotativos son manuales o servocontrolados." .

