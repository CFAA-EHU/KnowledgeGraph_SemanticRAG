@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_RedefinicionCinematica_15_a_52 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de redefinición de cinemática tipo 15 a tipo 52"@es ;
    ex:textoExtracto "Adaptar una cinemática tipo 15 a una cinemática tipo 52. [...] Parámetro de la cinemática vectorial (tipo 52). | Valor/parámetro equivalente en la cinemática tipo 15."@es ;
    ex:detalladoEnEsquema ex:SistemaCinematico_Tipo52 ;
    ex:documentadoEn ex:Manual_Broaching .

ex:SistemaCinematico_Tipo52
    a ex:Sistema ;
    rdfs:label "Sistema de cinemática vectorial tipo 52"@es ;
    ex:identificador "TYPE 52" ;
    ex:textoExtracto "TYPE | 52"@es ;
    ex:tieneComponente ex:Parametro_TDATA1, ex:Parametro_TDATA2, ex:Parametro_TDATA3, ex:Parametro_TDATA4, ex:Parametro_TDATA5,
                      ex:Parametro_TDATA6, ex:Parametro_TDATA7, ex:Parametro_TDATA8, ex:Parametro_TDATA9, ex:Parametro_TDATA11,
                      ex:Parametro_TDATA12, ex:Parametro_TDATA13, ex:Parametro_TDATA14, ex:Parametro_TDATA15, ex:Parametro_TDATA16,
                      ex:Parametro_TDATA17, ex:Parametro_TDATA18, ex:Parametro_TDATA19, ex:Parametro_TDATA21, ex:Parametro_TDATA22,
                      ex:Parametro_TDATA23, ex:Parametro_TDATA24, ex:Parametro_TDATA25, ex:Parametro_TDATA26 .

