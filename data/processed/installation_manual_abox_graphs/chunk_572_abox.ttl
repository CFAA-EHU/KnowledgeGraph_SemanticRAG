    ns1:identificador "TDATA14" ;
    ns1:textoExtracto "TDATA14 Distancia entre el eje rotativo principal y el punto de referencia, según el eje Y." .

ns1:DistanciaEntreElEjeRotativoPrincipalYElPuntoDeReferenciaSegunElEjeZ a ns1:Parametro ;
