@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla572 a ex:Tabla ;
    ex:textoExtracto "Adaptar una cinemática tipo 15 a una cinemática tipo 52. | Parámetro de la cinemática vectorial (tipo 52). | Valor/parámetro equivalente en la cinemática tipo 15. | TYPE | 52 | TDATA1 | TDATA13 | TDATA2 | TDATA14 | TDATA3 | TDATA15 | TDATA4 | 0 | TDATA5 | 0 | TDATA6 | 0 | TDATA7 | 0 | TDATA8 | 0 | TDATA9 | 1 | TDATA11 | 0 | TDATA12 | 0 | TDATA13 | 0 | TDATA14 | 0 | TDATA15 | 1 | TDATA16 | 0 | TDATA17 | TDATA8 | TDATA18 | TDATA10 | TDATA19 | 0 | TDATA21 | TDATA2 | TDATA22 | 0 | TDATA23 | TDATA1 | TDATA24 | 0 | TDATA25 | 0 | TDATA26 | 1" ;
    ex:tieneComponente ex:ParametroTYPE, ex:ParametroTDATA1, ex:ParametroTDATA2, ex:ParametroTDATA3, ex:ParametroTDATA4, ex:ParametroTDATA5, ex:ParametroTDATA6, ex:ParametroTDATA7, ex:ParametroTDATA8, ex:ParametroTDATA9, ex:ParametroTDATA11, ex:ParametroTDATA12, ex:ParametroTDATA13, ex:ParametroTDATA14, ex:ParametroTDATA15, ex:ParametroTDATA16, ex:ParametroTDATA17, ex:ParametroTDATA18, ex:ParametroTDATA19, ex:ParametroTDATA21, ex:ParametroTDATA22, ex:ParametroTDATA23, ex:ParametroTDATA24, ex:ParametroTDATA25, ex:ParametroTDATA26 .

ex:ParametroTYPE a ex:Parametro ;
    ex:identificador "TYPE" ;
    ex:textoExtracto "TYPE | 52" ;
    ex:valor "52" .

