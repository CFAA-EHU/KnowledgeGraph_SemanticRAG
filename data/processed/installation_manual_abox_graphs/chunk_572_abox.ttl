    ns1:identificador "TDATA13" ;
    ns1:textoExtracto "TDATA13 Distancia entre el eje rotativo principal y el punto de referencia, según el eje X." .

ns1:DistanciaEntreElEjeRotativoPrincipalYElPuntoDeReferenciaSegunElEjeY a ns1:Parametro ;
