@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_RedefinicionCinematica_15_a_52 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de equivalencia: cinemática tipo 15 → tipo 52"@es ;
    ex:textoExtracto """
| Parámetro de la cinemática vectorial (tipo 52). | Valor/parámetro equivalente en la cinemática tipo 15. |
| TDATA31 | 0 |
| TDATA32 | -TDATA5 |
| TDATA33 | -TDATA6 |
| TDATA34 | 1 |
| TDATA35 | 0 |
| TDATA36 | 0 |
| TDATA37 | TDATA9 |
| TDATA38 | TDATA11 |
| TDATA39 | 0 |
| TDATA40 | A elegir. |
| TDATA49 | 1 |
"""@es ;
    ex:documentadoEn ex:Manual_Seccion_2.9.12 .

ex:Tabla_RedefinicionCinematica_16_a_52 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de equivalencia: cinemática tipo 16 → tipo 52"@es ;
    ex:textoExtracto "Adaptar una cinemática tipo 16 a una cinemática tipo 52."@es ;
    ex:documentadoEn ex:Manual_Seccion_2.9.12 .

ex:Param_TDATA31_52
    a ex:Parametro ;
    rdfs:label "TDATA31 (cinemática tipo 52)"@es ;
    ex:identificador "TDATA31" ;
    ex:valor "0" ;
    ex:textoExtracto "| TDATA31 | 0 |"@es ;
    ex:documentadoEn ex:Tabla_RedefinicionCinematica_15_a_52 .

