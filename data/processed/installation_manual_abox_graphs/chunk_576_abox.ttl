@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjesRotativosManualesOServocontrolados a ns1:Parametro ;
    rdfs:label "Ejes rotativos manuales o servocontrolados" ;
    ns1:identificador "TDATA12" ;
    ns1:textoExtracto "Este parámetro indica si los ejes rotativos son manuales o servocontrolados." .

ns1:GirarElSistemaDeCoordenadasPiezaAlGirarLaMesa a ns1:Parametro ;
    rdfs:label "Girar el sistema de coordenadas pieza al girar la mesa" ;
    ns1:identificador "TDATA16" ;
    ns1:textoExtracto "Con el modo RTCP activo, este parámetro establece si el sistema de coordenadas pieza está fijo sobre la pieza y gira con ella o si por el contrario se mantiene paralelo al sistema de coordenadas máquina." .

ns1:IndicadorDeTipoDeCinematica a ns1:Parametro ;
    rdfs:label "Indicador de tipo de cinemática" ;
    ns1:identificador "TDATA10" ;
    ns1:textoExtracto "TYPE=10 C TDATA 10 = 0 TDATA 11 = 0 A TDATA 10 = 1 TDATA 11 = 1" .

ns1:IndicadorDeTipoDeCinematica_d3b875370a a ns1:Parametro ;
    rdfs:label "Indicador de tipo de cinemática" ;
    ns1:identificador "TDATA11" ;
    ns1:textoExtracto "TYPE=10 C TDATA 10 = 0 TDATA 11 = 0 A TDATA 10 = 1 TDATA 11 = 1" .

ns1:PosicionDelEjeX a ns1:Parametro ;
    rdfs:label "Posición del eje X" ;
    ns1:identificador "TDATA2" ;
    ns1:textoExtracto "X TDATA 2(+) Y" .

ns1:PosicionDelEjeY a ns1:Parametro ;
    rdfs:label "Posición del eje Y" ;
    ns1:identificador "TDATA4" ;
    ns1:textoExtracto "Y X Y X TDATA 5(-) TDATA 4(+)" .

ns1:PosicionDelEjeZ a ns1:Parametro ;
    rdfs:label "Posición del eje Z" ;
    ns1:identificador "TDATA3" ;
    ns1:textoExtracto "Z TDATA 3(+)" .

ns1:PosicionDelEjeZ_4587115156 a ns1:Parametro ;
    rdfs:label "Posición del eje Z" ;
    ns1:identificador "TDATA5" ;
    ns1:textoExtracto "Z Z TDATA 3(+) X Y TDATA 2(+) TDATA12 Ejes rotativos manuales o servocontrolados." .

