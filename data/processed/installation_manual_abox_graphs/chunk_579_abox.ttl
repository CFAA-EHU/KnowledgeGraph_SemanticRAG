@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CeroMaquina a ns1:Parametro ;
    rdfs:label "Cero Máquina" ;
    ns1:identificador "TDATA7=0" ;
    ns1:textoExtracto "Valores posibles: 0 (cero máquina)" ;
    ns1:valor "0" .

ns1:CeroPieza a ns1:Parametro ;
    rdfs:label "Cero Pieza" ;
    ns1:identificador "TDATA7=1" ;
    ns1:textoExtracto "Valores posibles: 1 (cero pieza)" ;
    ns1:valor "1" .

ns1:IndicaSiElCNCAplicaElRTCPRespectoAlCeroMaquinaOPieza a ns1:Parametro ;
    rdfs:label "Indica si el CNC aplica el RTCP respecto al cero máquina o pieza" ;
    ns1:identificador "TDATA7" ;
    ns1:textoExtracto "Este parámetro indica si el CNC aplica el RTCP respecto el cero máquina o el cero pieza." .

