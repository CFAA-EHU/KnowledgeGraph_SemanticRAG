@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla_579_1 a ex:Tabla ;
    ex:textoExtracto "PARALLEL n Tabla de cinemáticas de ejes paralelos. Muestra las tablas de configuración de las cinemáticas de ejes paralelos." .

ex:Parametro_PARALAX a ex:Parametro ;
    ex:identificador "PARALAX" ;
    ex:textoExtracto "PARALAX Eje principal de la transformación. Valores posibles: Cualquier eje definido en el parámetro AXISNAME. Valor por defecto: -. Variable asociada: (V.)MPK.PARALAX[nb] Parámetro incluido en la tabla PARALLEL n." .

ex:Parametro_ADDAX a ex:Parametro ;
    ex:identificador "ADDAX" ;
    ex:textoExtracto "ADDAX Eje aditivo paralelo. Valores posibles: Cualquier eje definido en el parámetro AXISNAME. Valor por defecto: -. Variable asociada: (V.)MPK.ADDAX[nb] Parámetro incluido en la tabla PARALLEL n." .

ex:Parametro_ADDORG a ex:Parametro ;
    ex:identificador "ADDORG" ;
    ex:textoExtracto "ADDORG Distancia entre los cero máquina de ambos ejes. Valores posibles: ±214748.3647 mm / Valor por defecto: 0 Variable asociada: (V.)MPK.ADDORG[nb] Parámetro incluido en la tabla PARALLEL n." .

ex:Parametro_PARALINI a ex:Parametro ;
    ex:identificador "PARALINI" ;
    ex:textoExtracto "PARALINI Estado de la cinemática paralela en el arranque." .

ex:Variable_MPK_NPARAL a ex:Parametro ;
    ex:identificador "(V.)MPK.NPARAL" ;
    ex:textoExtracto "NPARAL Número de cinemáticas de ejes paralelos. Valores posibles: De 0 a 6. Valor por defecto: 0." .

ex:Variable_MPK_PARALAX a ex:Parametro ;
    ex:identificador "(V.)MPK.PARALAX[nb]" ;
    ex:textoExtracto "Variable asociada: (V.)MPK.PARALAX[nb] Parámetro incluido en la tabla PARALLEL n." .

ex:Variable_MPK_ADDAX a ex:Parametro ;
    ex:identificador "(V.)MPK.ADDAX[nb]" ;
    ex:textoExtracto "Variable asociada: (V.)MPK.ADDAX[nb] Parámetro incluido en la tabla PARALLEL n." .

ex:Variable_MPK_ADDORG a ex:Parametro ;
    ex:identificador "(V.)MPK.ADDORG[nb]" ;
    ex:textoExtracto "Variable asociada: (V.)MPK.ADDORG[nb] Parámetro incluido en la tabla PARALLEL n." .