@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PosicionDeReposoDelEjeRotativoPrincipal a ns1:Parametro ;
    rdfs:label "Posición de reposo del eje rotativo principal" ;
    ns1:identificador "TDATA8" ;
    ns1:textoExtracto "Valores posibles: Entre ±99999.9999º. Valor por defecto: 0." .

ns1:PosicionDeReposoDelEjeRotativoSecundario a ns1:Parametro ;
    rdfs:label "Posición de reposo del eje rotativo secundario" ;
    ns1:identificador "TDATA9" ;
    ns1:textoExtracto "Valores posibles: Entre ±99999.9999º. Valor por defecto: 0." .

ns1:SentidoDeGiroDelEjeRotativoPrincipal a ns1:Parametro ;
    rdfs:label "Sentido de giro del eje rotativo principal" ;
    ns1:identificador "TDATA10" ;
    ns1:textoExtracto "Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." .

ns1:SentidoDeGiroDelEjeRotativoSecundario a ns1:Parametro ;
    rdfs:label "Sentido de giro del eje rotativo secundario" ;
    ns1:identificador "TDATA11" ;
    ns1:textoExtracto "Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." .

