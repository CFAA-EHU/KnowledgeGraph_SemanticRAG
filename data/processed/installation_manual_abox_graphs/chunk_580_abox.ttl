@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla_PARALLEL_n a ex:Tabla ;
    ex:textoExtracto "Parámetro incluido en la tabla PARALLEL n." ;
    ex:identificador "PARALLEL n" .

ex:Parametro_MPK_ADDORG a ex:Parametro ;
    ex:identificador "MPK.ADDORG[nb]" ;
    ex:textoExtracto "Variable asociada: (V.)MPK.ADDORG[nb]" ;
    ex:valor "±214748.3647 mm" ;
    ex:valor "0" .

ex:Parametro_MPK_PARALINI a ex:Parametro ;
    ex:identificador "MPK.PARALINI[nb]" ;
    ex:textoExtracto "Variable asociada: (V.)MPK.PARALINI[nb]" ;
    ex:valor "PARALAXOFF" ;
    ex:valor "PARALAX VIS" ;
    ex:valor "PARALAXOFF" .

ex:Estado_Cinematica_Paralela_Arranque a ex:ModoOperacion ;
    ex:identificador "PARALINI" ;
    ex:textoExtracto "Estado de la cinemática paralela en el arranque. Valores posibles: PARALAXOFF / PARALAX VIS. Valor por defecto: PARALAXOFF." .