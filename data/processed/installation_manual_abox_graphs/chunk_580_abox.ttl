@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_MPK_ADDORG
    a ex:Parametro ;
    rdfs:label "MPK.ADDORG[nb]" ;
    ex:identificador "MPK.ADDORG[nb]" ;
    ex:textoExtracto "Distancia entre los cero máquina de ambos ejes, del eje principal al eje aditivo. Valores posibles: ±214748.3647 mm / Valor por defecto: 0" ;
    ex:valor "±214748.3647 mm"^^<http://www.w3.org/2001/XMLSchema#string> ;
    ex:documentadoEn ex:Tabla_PARALLEL_n .

ex:Parametro_MPK_PARALINI
    a ex:Parametro ;
    rdfs:label "MPK.PARALINI[nb]" ;
    ex:identificador "MPK.PARALINI[nb]" ;
    ex:textoExtracto "Estado de la cinemática paralela en el arranque. Valores posibles: PARALAXOFF / PARALAX VIS. Valor por defecto: PARALAXOFF" ;
    ex:valor "PARALAXOFF"^^<http://www.w3.org/2001/XMLSchema#string> ;
    ex:documentadoEn ex:Tabla_PARALLEL_n .

ex:Tabla_PARALLEL_n a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla PARALLEL n" ;
    ex:textoExtracto "Parámetro incluido en la tabla PARALLEL n." .