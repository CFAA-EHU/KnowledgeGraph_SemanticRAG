@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoOperacion_PARALAX_OFF a ex:ModoOperacion ;
    rdfs:label "PARALAX OFF" ;
    ex:textoExtracto "PARALAX OFF | Cinemática desactivada." ;
    ex:valor "Cinemática desactivada." .

ex:ModoOperacion_PARALAX_VIS a ex:ModoOperacion ;
    rdfs:label "PARALAX VIS." ;
    ex:textoExtracto "PARALAX VIS. | Cinemática activa en modo visualización. El CNC actualiza la cota del eje maestro con el desplazamiento realizado por eje aditivo, de manera que el eje maestro siempre muestra la distancia de la herramienta a la pieza." ;
    ex:valor "Cinemática activa en modo visualización. El CNC actualiza la cota del eje maestro con el desplazamiento realizado por eje aditivo, de manera que el eje maestro siempre muestra la distancia de la herramienta a la pieza." .