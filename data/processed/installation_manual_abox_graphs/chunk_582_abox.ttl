@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DistanciaDeColocacionDelCabezalSegunElEjeX a ns1:Parametro ;
    rdfs:label "Distancia de colocación del cabezal según el eje X" ;
    ns1:identificador "TDATA13" ;
    ns1:textoExtracto "TDATA13 Distancia que define la colocación del cabezal, desde el eje rotativo, según el eje X." .

ns1:DistanciaDeColocacionDelCabezalSegunElEjeY a ns1:Parametro ;
    rdfs:label "Distancia de colocación del cabezal según el eje Y" ;
    ns1:identificador "TDATA14" ;
    ns1:textoExtracto "TDATA14 Distancia que define la colocación del cabezal, desde el eje rotativo, según el eje Y." .

ns1:DistanciaDeColocacionDelCabezalSegunElEjeZ a ns1:Parametro ;
    rdfs:label "Distancia de colocación del cabezal según el eje Z" ;
    ns1:identificador "TDATA15" ;
    ns1:textoExtracto "TDATA15 Distancia que define la colocación del cabezal, desde el eje rotativo, según el eje Z." .

ns1:IndicadorDeControlDeEjesRotativos a ns1:Parametro ;
    rdfs:label "Indicador de control de ejes rotativos" ;
    ns1:identificador "TDATA12" ;
    ns1:textoExtracto "TDATA12 Ejes rotativos manuales o servocontrolados. Valores posibles: 0 a 3." .

