@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TM_NTOOLMZ a ex:Parametro ;
    rdfs:label "NTOOLMZ" ;
    ex:identificador "NTOOLMZ" ;
    ex:textoExtracto "NTOOLMZ Número de almacenes. Valores posibles: De 0 a 4. Valor por defecto: 1. Variable asociada: (V.)TM.NTOOLMZ Número de almacenes del sistema." ;
    ex:valor "De 0 a 4" .

ex:TM_MZGROUND a ex:Parametro ;
    rdfs:label "GROUND" ;
    ex:identificador "GROUND" ;
    ex:textoExtracto "GROUND Se permiten herramientas de tierra (carga manual). Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)TM.MZGROUND[mz] Se denominan herramientas de tierra a las que no están situadas en el almacén." ;
    ex:valor "Sí / No" .

ex:ParametroAlmacenamiento a ex:Parametro ;
    rdfs:label "STORAGE" ;
    ex:identificador "STORAGE" ;
    ex:textoExtracto "STORAGE Parámetros relacionados con el almacenamiento." ;
    ex:valor "Parámetros relacionados con el almacenamiento." .

ex:ParametroGestionAlmacen a ex:Parametro ;
    rdfs:label "MANAGEMENT" ;
    ex:identificador "MANAGEMENT" ;
    ex:textoExtracto "MANAGEMENT Parámetros relacionados con la gestión del almacén." ;
    ex:valor "Parámetros relacionados con la gestión del almacén." .

ex:TablaAlmacen_n a ex:Tabla ;
    ex:identificador "MAGAZINE n" ;
    ex:textoExtracto "MAGAZINE n Tabla del almacén. Este parámetro muestra las tablas para definir los datos del almacén. Cada tabla dispone de los siguientes parámetros máquina para su configuración." ;
    ex:tieneComponente ex:ParametroAlmacenamiento, ex:ParametroGestionAlmacen .