@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla_MAGAZINE a ex:Tabla ;
    ex:textoExtracto """Este parámetro muestra los datos del almacén. Cada tabla dispone de los siguientes parámetros máquina para su configuración. | MAGAZINE n |  |
| --- | --- |
| SIZE | Tamaño del almacén (número de posiciones). |
| RANDOM | Almacén random |""" ;
    a ex:Tabla ;
    ex:tieneComponente ex:Parametro_SIZE, ex:Parametro_RANDOM .

ex:Parametro_SIZE ex:textoExtracto """SIZE Tamaño del almacén (número de posiciones). Valores posibles: De 0 a 1000. Valor por defecto: 20. Variable asociada: (V.)TM.MZSIZE[mz] Parámetro incluido en la tabla MAGAZINE // STORAGE. Este parámetro indica la capacidad del almacén, sin contar la herramientas de tierra.""" ;
    a ex:Parametro ;
    ex:valor "De 0 a 1000" ;
    ex:identificador "(V.)TM.MZSIZE[mz]" .

ex:Parametro_RANDOM ex:textoExtracto """RANDOM Almacén random. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)TM.MZRANDOM[mz] Parámetro incluido en la tabla MAGAZINE // STORAGE. Este parámetro indica si las herramientas debe ocupar siempre la misma posición (no- random) o si pueden ocupar cualquier posición (random).""" ;
    a ex:Parametro ;
    ex:valor "Sí / No" ;
    ex:identificador "(V.)TM.MZRANDOM[mz]" .