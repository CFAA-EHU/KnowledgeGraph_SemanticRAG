@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCabezalOrtogonal a ns1:Sistema ;
    rdfs:label "Sistema de cinemáticas del cabezal" ;
    ns1:textoExtracto "Se pueden controlar cabezales ortogonales con tres ejes rotativos." ;
    ns1:tieneComponente ns1:DimensionesDelCabezal,
        ns1:DimensionesDelCabezal_772dd10a68 .

ns1:DimensionesDelCabezal a ns1:Parametro ;
    rdfs:label "Dimensiones del cabezal" ;
    ns1:identificador "TDATA1" ;
    ns1:textoExtracto "TDATA1··TDATA12 Dimensiones del cabezal." .

ns1:DimensionesDelCabezal_772dd10a68 a ns1:Parametro ;
    rdfs:label "Dimensiones del cabezal" ;
    ns1:identificador "TDATA12" ;
    ns1:textoExtracto "TDATA1··TDATA12 Dimensiones del cabezal." .

