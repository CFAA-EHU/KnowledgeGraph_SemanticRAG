@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ParametroGestionAlmacen a ex:Parametro ;
    rdfs:label "Parámetros relacionados con la gestión del almacén"@es ;
    ex:textoExtracto "MANAGEMENT Parámetros relacionados con la gestión del almacén. Este parámetro muestra los datos para configurar la gestión del almacén."@es .

ex:TablaGestionAlmacen a ex:Tabla ;
    rdfs:label "Tabla de gestión del almacén"@es ;
    ex:textoExtracto "Cada tabla dispone de los siguientes parámetros máquina para su configuración."@es ;
    ex:compuestoPor ex:ParametroTipoAlmacen, ex:ParametroCyclic, ex:ParametroOptimize, ex:ParametroM6Alone ;
    ex:documentadoEn ex:ParametroGestionAlmacen .

ex:ParametroTipoAlmacen a ex:Parametro ;
    rdfs:label "Tipo de almacén"@es ;
    ex:identificador "TYPE" ;
    ex:textoExtracto "TYPE Tipo de almacén. Valores posibles: Asíncrono / Síncrono / Torreta / Síncrono + 2 Brazos / Síncrono + 1 Brazo. Valor por defecto: Síncrono. Variable asociada: (V.)TM.MZTYPE[mz] Parámetro incluido en la tabla MAGAZINE // MANAGEMENT. Tipo de almacén."@es .

ex:ParametroCyclic a ex:Parametro ;
    rdfs:label "Cambiador de herramientas cíclico"@es ;
    ex:identificador "CYCLIC" ;
    ex:textoExtracto "CYCLIC Cambiador de herramientas cíclico."@es .

ex:ParametroOptimize a ex:Parametro ;
    rdfs:label "Optimización de la gestión"@es ;
    ex:identificador "OPTIMIZE" ;
    ex:textoExtracto "OPTIMIZE Optimización de la gestión."@es .

ex:ParametroM6Alone a ex:Parametro ;
    rdfs:label "Acción al ejecutar una M06 sin T seleccionada"@es ;
    ex:identificador "M6ALONE" ;
    ex:textoExtracto "M6ALONE Acción al ejecutar una M06 sin T seleccionada."@es .