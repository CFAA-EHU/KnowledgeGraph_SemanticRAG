@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjeRotativoSecundarioCabezal a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo secundario del cabezal" ;
    ns1:textoExtracto "Se llama eje rotativo secundario, al eje rotativo del cabezal que en su giro arrastra a un eje de giro." .

ns1:EjeRotativoTerciarioCabezal a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo terciario del cabezal" ;
    ns1:textoExtracto "Se llama eje rotativo terciario, al eje rotativo del cabezal que en su" .

