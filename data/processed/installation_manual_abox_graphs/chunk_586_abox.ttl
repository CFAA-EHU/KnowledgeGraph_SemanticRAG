@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjeRotativoSecundario a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo secundario" ;
    ns1:textoExtracto "Se llama eje rotativo secundario, al eje rotativo del cabezal que en su giro arrastra a un eje de giro." .

ns1:EjeRotativoTerciario a ns1:ComponenteMecanico ;
    rdfs:label "Eje rotativo terciario" ;
    ns1:textoExtracto "Se llama eje rotativo terciario, al eje rotativo del cabezal que en su giro no arrastra a ningún otro eje de giro, solo a la herramienta." .

