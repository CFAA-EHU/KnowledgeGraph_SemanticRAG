@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ParametroComunicacionHMI a ex:Parametro ;
    rdfs:label "Parámetros máquina del HMI" ;
    ex:textoExtracto "Estos parámetros permiten definir el entorno de comunicación entre el operario y el CNC." ;
    ex:valor "entorno de comunicación entre el operario y el CNC" .

ex:CNC a ex:Maquina ;
    rdfs:label "CNC" ;
    ex:textoExtracto "Estos parámetros permiten definir el entorno de comunicación entre el operario y el CNC." .

ex:AccionReinicializarCNC a ex:AccionProhibida ;
    rdfs:label "Reinicializar el CNC" ;
    ex:textoExtracto "Para validar los cambios que se realicen en estos parámetros es necesario reinicializar el CNC." .