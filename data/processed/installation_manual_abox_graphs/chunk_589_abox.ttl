@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ConfiguracionVentanaPrincipal a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla WINDOW - Dimensiones y resolución de la ventana principal"@es ;
    ex:textoExtracto "La tabla dispone de los siguientes parámetros máquina: POSX, POSY, RESOLUTION, WIDTH, HEIGHT."@es ;
    ex:identificador "WINDOW" .

ex:Parametro_POSX
    a ex:Parametro ;
    rdfs:label "POSX" ;
    ex:textoExtracto "Coordenada X de la esquina superior izquierda. Valor por defecto: 0. Parámetro incluido en la tabla WINDOW."@es ;
    ex:valor "0" ;
    ex:documentadoEn ex:Tabla_ConfiguracionVentanaPrincipal .

ex:Parametro_POSY
    a ex:Parametro ;
    rdfs:label "POSY" ;
    ex:textoExtracto "Coordenada Y de la esquina superior izquierda. Valor por defecto: 0. Parámetro incluido en la tabla WINDOW."@es ;
    ex:valor "0" ;
    ex:documentadoEn ex:Tabla_ConfiguracionVentanaPrincipal .

ex:Parametro_RESOLUTION
    a ex:Parametro ;
    rdfs:label "RESOLUTION" ;
    ex:textoExtracto "Resolución de la pantalla. Valores posibles: CUSTOM / 10\" / 15\" / 19\" / 21\" LANDSCAPE / 21\" PORTRAIT. Valor por defecto: 10\"."@es ;
    ex:valor "10\"" ;
    ex:documentadoEn ex:Tabla_ConfiguracionVentanaPrincipal .

ex:Parametro_WIDTH
    a ex:Parametro ;
    rdfs:label "WIDTH" ;
    ex:textoExtracto "Anchura de la ventana. Parámetro incluido en la tabla WINDOW."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionVentanaPrincipal .

ex:Parametro_HEIGHT
    a ex:Parametro ;
    rdfs:label "HEIGHT" ;
    ex:textoExtracto "Altura de la ventana. Parámetro incluido en la tabla WINDOW."@es ;
    ex:documentadoEn ex:Tabla_ConfiguracionVentanaPrincipal .

ex:InterfazUsuario_VentanaPrincipal
    a ex:InterfazUsuario ;
    rdfs:label "Ventana principal (HMI)"@es ;
    ex:textoExtracto "Este parámetro muestra los datos para configurar la ventana principal. [...] El interface se podrá desplazar haciendo click con el ratón sobre el icono que muestra el estado del programa del canal activo."@es ;
    ex:tieneComponente ex:Parametro_POSX, ex:Parametro_POSY, ex:Parametro_RESOLUTION, ex:Parametro_WIDTH, ex:Parametro_HEIGHT ;
    ex:documentadoEn ex:Tabla_ConfiguracionVentanaPrincipal .