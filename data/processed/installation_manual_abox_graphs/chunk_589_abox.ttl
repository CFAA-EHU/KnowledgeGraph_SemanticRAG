@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinicionDeLasCinematicasDelCabezal a ns1:Parametro ;
    rdfs:label "Definición de las cinemáticas del cabezal" ;
    ns1:identificador "TDATA12" ;
    ns1:textoExtracto "TDATA12 | Significado." .

