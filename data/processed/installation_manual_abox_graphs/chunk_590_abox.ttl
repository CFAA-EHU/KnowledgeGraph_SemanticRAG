@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Tabla_Windows_318_319 a ex:Tabla ;
    ex:textoExtracto """| RESOLUTION. (valor) | Tamaño del interface (píxeles). |
| --- | --- |
| 19" | 1280 × 1024. |
| 21" LANDSCAPE
Panorámico horizontal. | 1300 × 1080. El interface no ocupa toda la pantalla para permitir un
teclado virtual. |
| 21" PORTRAIT
Panorámico vertical. | 1080 × 1400. El interface no ocupa toda la pantalla para permitir un
teclado virtual. |
 WIDTH Anchura de la ventana. Valores posibles: De 800 a 1680 píxeles. Valor por defecto: 800 píxeles. Parámetro incluido en la tabla WINDOW. Consultar el parámetro máquina del HMI HEIGHT. HEIGHT Altura de la ventana. Valores posibles: De 480 a 1050 píxeles. Valor por defecto: 600 píxeles. Parámetro incluido en la tabla WINDOW. Los parámetros WIDTH y HEIGHT definen el tamaño de la ventana. Estos parámetros sólo se pueden modificar cuando el parámetro RESOLUTION tiene el valor "CUSTOM".""" .

ex:Parametro_RESOLUTION a ex:Parametro ;
    ex:textoExtracto "RESOLUTION. (valor)" ;
    rdfs:label "RESOLUTION" .

ex:Parametro_WIDTH a ex:Parametro ;
    ex:textoExtracto "WIDTH Anchura de la ventana. Valores posibles: De 800 a 1680 píxeles. Valor por defecto: 800 píxeles." ;
    rdfs:label "WIDTH" ;
    ex:valor "800 a 1680 píxeles" ;
    ex:valor "800 píxeles" .

ex:Parametro_HEIGHT a ex:Parametro ;
    ex:textoExtracto "HEIGHT Altura de la ventana. Valores posibles: De 480 a 1050 píxeles. Valor por defecto: 600 píxeles." ;
    rdfs:label "HEIGHT" ;
    ex:valor "480 a 1050 píxeles" ;
    ex:valor "600 píxeles" .

ex:Parametro_CUSTOM a ex:Parametro ;
    ex:textoExtracto "cuando el parámetro RESOLUTION tiene el valor \"CUSTOM\"" ;
    rdfs:label "CUSTOM" .

ex:InterfazUsuario_VentanaPrincipal a ex:InterfazUsuario ;
    ex:textoExtracto "El interface no ocupa toda la pantalla para permitir un teclado virtual." ;
    ex:compuestoPor ex:Parametro_WIDTH, ex:Parametro_HEIGHT .

ex:Tabla_Windows_318_319 a ex:Tabla ;
    ex:detalladoEnEsquema ex:InterfazUsuario_VentanaPrincipal .