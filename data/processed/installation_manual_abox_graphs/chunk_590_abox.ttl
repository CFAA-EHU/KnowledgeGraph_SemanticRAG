@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DesalineamientoDeLaHerramientaSobreElEjeC a ns1:Parametro ;
    rdfs:label "Desalineamiento de la herramienta sobre el eje C" ;
    ns1:identificador "TDATA6" ;
    ns1:textoExtracto "TDATA6 Desalineamiento de la herramienta sobre el eje C. Valores posibles: Entre ±999999999.0000 Valor por defecto: 0." .

ns1:OffsetAngularDelEjeRotativo a ns1:Parametro ;
    rdfs:label "Offset angular del eje rotativo" ;
    ns1:identificador "TDATA4" ;
    ns1:textoExtracto "TDATA4 Offset angular del eje rotativo. Valores posibles: Entre ±999999999.0000º Valor por defecto: 0." .

ns1:PosicionDelEjeDeGiro a ns1:Parametro ;
    rdfs:label "Posición del eje de giro" ;
    ns1:identificador "TDATA5" ;
    ns1:textoExtracto "TDATA5 Posición del eje de giro. Valores posibles: 0 (el eje de giro se encuentra en el cero pieza) / 1 (la posición del eje de giro viene indicada por DATA2). Valor por defecto: 0." .

ns1:PosicionDelEjeRotativo a ns1:Parametro ;
    rdfs:label "Posición del eje rotativo" ;
    ns1:identificador "TDATA2" ;
    ns1:textoExtracto "TDATA2 Posición del eje rotativo. Valores posibles: Entre ±999999999.0000 Valor por defecto: 0." .

ns1:SentidoDeGiroDelEjeGiratorio a ns1:Parametro ;
    rdfs:label "Sentido de giro del eje giratorio" ;
    ns1:identificador "TDATA10" ;
    ns1:textoExtracto "TDATA10 Sentido de giro del eje giratorio." .

ns1:CNC8070_bf2a572ef2 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:TablaCinematicas ;
    ns1:textoExtracto "Si al ejecutar esta función no se selecciona la cinemática, el CNC cogerá de la primera cinemática del tipo 41 o 42 definida en la tabla." .

ns1:TablaCinematicas a ns1:Tabla ;
    rdfs:label "Tabla de Cinemáticas" ;
    ns1:ilustradoEn ns1:CNC8070_bf2a572ef2 ;
    ns1:textoExtracto "TDATA2 Posición del eje rotativo. Valores posibles: Entre ±999999999.0000 Valor por defecto: 0." .

