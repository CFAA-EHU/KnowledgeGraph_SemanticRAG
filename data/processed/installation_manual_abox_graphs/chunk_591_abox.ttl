@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RadioDeLaZonaCircularNoAccesibleAlMecanizado a ns1:Parametro ;
    rdfs:label "Radio de la zona circular no accesible al mecanizado" ;
    ns1:identificador "TDATA6" ;
    ns1:textoExtracto "El desalineamiento de la herramienta da lugar a una zona circular, de radio TDATA6, que no es accesible al mecanizado." .

ns1:SentidoDeGiroDelEjeGiratorio a ns1:Parametro ;
    rdfs:label "Sentido de giro del eje giratorio" ;
    ns1:identificador "TDATA10" ;
    ns1:textoExtracto "TDATA10 Sentido de giro del eje giratorio. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." ;
    ns1:valor "0" .

