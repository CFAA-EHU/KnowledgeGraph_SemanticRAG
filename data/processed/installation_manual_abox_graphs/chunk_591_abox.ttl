@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_HMENUNSOFTKEY
    a ex:Parametro ;
    rdfs:label "HMENUNSOFTKEY" ;
    ex:textoExtracto "HMENUNSOFTKEY Número de softkeys del menú horizontal. Valores posibles: De 7 a 12. Valor por defecto: 7." ;
    ex:valor "7" ;
    ex:documentadoEn ex:InterfazUsuario_ConfiguracionSoftkeys .

ex:Parametro_VMENUNSOFTKEY
    a ex:Parametro ;
    rdfs:label "VMENUNSOFTKEY" ;
    ex:textoExtracto "VMENUNSOFTKEY Número de softkeys del menú vertical. Valores posibles: De 5 a 12. Valor por defecto: 5." ;
    ex:valor "5" ;
    ex:documentadoEn ex:InterfazUsuario_ConfiguracionSoftkeys .

ex:Parametro_SOFTKEYMETRICS
    a ex:Parametro ;
    rdfs:label "SOFTKEYMETRICS" ;
    ex:textoExtracto "SOFTKEYMETRICS Dimensiones de las softkeys. Valores posibles: Estándar / Avanzado. Valor por defecto: Estándar." ;
    ex:valor "Estándar" ;
    ex:documentadoEn ex:InterfazUsuario_ConfiguracionSoftkeys .

ex:InterfazUsuario_ConfiguracionSoftkeys
    a ex:InterfazUsuario ;
    rdfs:label "Configuración de Softkeys" ;
    ex:textoExtracto "Personalizar las softkeys: HMENUNSOFTKEY, VMENUNSOFTKEY y SOFTKEYMETRICS permiten ajustar número y dimensiones de las softkeys en menús horizontales y verticales." .