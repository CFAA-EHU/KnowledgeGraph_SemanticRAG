@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:OffsetAngularParaElEjeRotativo a ns1:Parametro ;
    rdfs:label "Offset angular para el eje rotativo" ;
    ns1:identificador "TDATA4" ;
    ns1:textoExtracto "TDATA4 Offset angular para el eje rotativo. Valores posibles: Entre ±999999999.0000º Valor por defecto: 0." .

ns1:PosicionDelEjeRotativo a ns1:Parametro ;
    rdfs:label "Posición del eje rotativo" ;
    ns1:identificador "TDATA2" ;
    ns1:textoExtracto "TDATA2 Posición del eje rotativo. Valores posibles: Entre ±999999999.0000 Valor por defecto: 0." .

ns1:SentidoDeGiroDelEjeGiratorio a ns1:Parametro ;
    rdfs:label "Sentido de giro del eje giratorio" ;
    ns1:identificador "TDATA10" ;
    ns1:textoExtracto "TDATA10 Sentido de giro del eje giratorio. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "el CNC cogerá de la primera cinemática del tipo 43 definida en la tabla." .

