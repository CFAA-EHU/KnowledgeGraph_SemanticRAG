@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalAngular a ns1:Sistema ;
    rdfs:label "Cabezal angular" ;
    ns1:textoExtracto "Cabezal angular." .

ns1:CabezalEsferico a ns1:Sistema ;
    rdfs:label "Cabezal esférico" ;
    ns1:textoExtracto "Cabezal esférico." .

ns1:CabezalOrtogonal a ns1:Sistema ;
    rdfs:label "Cabezal ortogonal" ;
    ns1:textoExtracto "Cabezal ortogonal." .

ns1:VectorDireccionPortaherramientas a ns1:ComponenteElectrico ;
    rdfs:label "Vector dirección del portaherramientas" ;
    ns1:textoExtracto "V3: Vector dirección del portaherramientas." .

ns1:VectorDireccionV1 a ns1:ComponenteElectrico ;
    rdfs:label "Vector dirección del primer eje rotativo" ;
    ns1:textoExtracto "V1: Vector dirección del primer eje rotativo." .

ns1:VectorDireccionV2 a ns1:ComponenteElectrico ;
    rdfs:label "Vector dirección del segundo eje rotativo" ;
    ns1:textoExtracto "V2: Vector dirección del segundo eje rotativo." .

ns1:VectorTraslacionPortaherramientas a ns1:ComponenteElectrico ;
    rdfs:label "Vector traslación del portaherramientas" ;
    ns1:textoExtracto "T3: Vector traslación del portaherramientas." .

ns1:VectorTraslacionV1 a ns1:ComponenteElectrico ;
    rdfs:label "Vector traslación del primer eje rotativo" ;
    ns1:textoExtracto "T1: Vector traslación del primer eje rotativo." .

ns1:VectorTraslacionV2 a ns1:ComponenteElectrico ;
    rdfs:label "Vector traslación del segundo eje rotativo" ;
    ns1:textoExtracto "T2: Vector traslación del segundo eje rotativo." .

