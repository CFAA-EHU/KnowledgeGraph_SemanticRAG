@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:USERKEY a ex:Parametro ;
    ex:textoExtracto "USERKEY Personalización de la tecla de usuario. Esta tabla muestra los parámetros para configurar la tecla de usuario. La tabla dispone de los siguientes parámetros máquina." ;
    ex:valor "Nada" .

ex:FUNCTION a ex:Parametro ;
    ex:textoExtracto "FUNCTION Función de la tecla de usuario. Valores posibles: Windows / Componente / Aplicación / CNC OFF / Nada. Valor por defecto: Nada. Parámetro incluido en la tabla USERKEY." ;
    ex:valor "Nada" .

ex:COMPONENT a ex:Parametro ;
    ex:textoExtracto "COMPONENT Acceder a uno de los componentes del CNC. Valores posibles: Diagnosis / PLC / Parámetros máquina / DDSSETUP / TUNING Parámetro incluido en la tabla USERKEY." .

ex:APPLICATION a ex:Parametro ;
    ex:textoExtracto "APPLICATION Ejecutar una aplicación del PC. Parámetro incluido en la tabla USERKEY. Cuando se define el parámetro USERKEY=Application, este parámetro permite seleccionar la aplicación. Hay que indicar el path completo de la aplicación; por ejemplo ..\\Fagor\\Release\\Fguim.exe." .

ex:InterfazUsuarioTeclado a ex:InterfazUsuario ;
    ex:textoExtracto "Configuración del teclado (tecla [CUSTOM])." ;
    ex:compuestoPor ex:USERKEY, ex:FUNCTION, ex:COMPONENT, ex:APPLICATION .