@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_CHANGEKEY a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla CHANGEKEY" ;
    ex:textoExtracto "Esta tabla muestra los parámetros para configurar la tecla de cambio. La tabla dispone de los siguientes parámetros máquina." ;
    ex:documentadoEn ex:Pagina_323_324 .

ex:Parametro_FUNCTION
    a ex:Parametro ;
    rdfs:label "FUNCTION" ;
    ex:textoExtracto "Función de la tecla de cambio. Valores posibles: Sg Página / Sg Canal / Menú. Valor por defecto: Sg Página." ;
    ex:valor "Sg Página" ;
    ex:documentadoEn ex:Tabla_CHANGEKEY .

ex:Parametro_SYSMENUMODE
    a ex:Parametro ;
    rdfs:label "SYSMENUMODE" ;
    ex:textoExtracto "Comportamiento del menú de sistema. Valores posibles: Volátil / Fijo. Valor por defecto: Volátil." ;
    ex:valor "Volátil" ;
    ex:documentadoEn ex:Tabla_CHANGEKEY .

ex:Parametro_SYSHMENU
    a ex:Parametro ;
    rdfs:label "SYSHMENU" ;
    ex:textoExtracto "Menú de sistema horizontal. Valores posibles: Deshabilitado / Páginas / Canales / Componentes. Valor por defecto: Deshabilitado." ;
    ex:valor "Deshabilitado" ;
    ex:documentadoEn ex:Tabla_CHANGEKEY .

ex:Parametro_SYSVMENU
    a ex:Parametro ;
    rdfs:label "SYSVMENU" ;
    ex:textoExtracto "Menú de sistema vertical. Valores posibles: Deshabilitado / Páginas / Canales / Componentes. Valor por defecto: Deshabilitado." ;
    ex:valor "Deshabilitado" ;
    ex:documentadoEn ex:Tabla_CHANGEKEY .

ex:InterfazUsuario_CHANGEKEY
    a ex:InterfazUsuario ;
    rdfs:label "Tecla de cambio (CHANGEKEY)" ;
    ex:textoExtracto "CHANGEKEY Personalización de la tecla de cambio." ;
    ex:ilustradoEn ex:Tabla_CHANGEKEY ;
    ex:monitoreaParametro ex:Parametro_FUNCTION ;
    ex:monitoreaParametro ex:Parametro_SYSMENUMODE ;
    ex:monitoreaParametro ex:Parametro_SYSHMENU ;
    ex:monitoreaParametro ex:Parametro_SYSVMENU .

ex:Pagina_323_324
    a ex:Pagina ;
    rdfs:label "Páginas 323-324" ;
    ex:textoExtracto "Sección 2.11.5 Configuración del teclado (tecla [NEXT])." ;
    ex:documentadoEn ex:Manual .