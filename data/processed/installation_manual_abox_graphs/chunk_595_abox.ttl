@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla_CHANGEKEY a ex:Tabla ;
    ex:textoExtracto """Esta tabla muestra los parámetros para configurar la tecla de cambio. La tabla dispone de los siguientes parámetros máquina. | CHANGEKEY |  | | --- | --- | | FUNCTION | Función de la tecla de cambio. | | SYSMENUMODE | Comportamiento del menú de sistema. | | SYSHMENU | Menú de sistema horizontal. | | SYSVMENU | Menú de sistema vertical.""" .

ex:Parametro_FUNCTION a ex:Parametro ;
    ex:identificador "FUNCTION" ;
    ex:textoExtracto """FUNCTION Función de la tecla de cambio. Valores posibles: Sg Página / Sg Canal / Menú. Valor por defecto: Sg Página. Parámetro incluido en la tabla CHANGEKEY.""" ;
    ex:valor "Sg Página" .

ex:Parametro_SYSMENUMODE a ex:Parametro ;
    ex:identificador "SYSMENUMODE" ;
    ex:textoExtracto """SYSMENUMODE Comportamiento del menú de sistema. Valores posibles: Volátil / Fijo. Valor por defecto: Volátil. Parámetro incluido en la tabla CHANGEKEY.""" ;
    ex:valor "Volátil" .

ex:Parametro_SYSHMENU a ex:Parametro ;
    ex:identificador "SYSHMENU" ;
    ex:textoExtracto """SYSHMENU Menú de sistema horizontal. Valores posibles: Deshabilitado / Páginas / Canales / Componentes. Valor por defecto: Deshabilitado.""" ;
    ex:valor "Deshabilitado" .

ex:Parametro_SYSVMENU a ex:Parametro ;
    ex:identificador "SYSVMENU" ;
    ex:textoExtracto """SYSVMENU Menú de sistema vertical. Valores posibles: Deshabilitado / Páginas / Canales / Componentes. Valor por defecto: Deshabilitado.""" ;
    ex:valor "Deshabilitado" .

ex:InterfazUsuario_tecla_NEXT a ex:InterfazUsuario ;
    ex:textoExtracto """Configuración del teclado (tecla [NEXT]).""" .

ex:Tabla_CHANGEKEY a ex:Tabla ;
    ex:compuestoPor ex:Parametro_FUNCTION, ex:Parametro_SYSMENUMODE, ex:Parametro_SYSHMENU, ex:Parametro_SYSVMENU .
ex:InterfazUsuario_tecla_NEXT ex:detalladoEnEsquema ex:Tabla_CHANGEKEY .