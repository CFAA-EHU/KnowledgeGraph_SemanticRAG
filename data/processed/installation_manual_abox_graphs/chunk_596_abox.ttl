@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_SYSVMENU a ex:Parametro ;
    rdfs:label "SYSVMENU" ;
    ex:identificador "SYSVMENU" ;
    ex:textoExtracto "Parámetro incluido en la tabla CHANGEKEY. Consultar el parámetro SYSHMENU. SYSVMENU Menú de sistema vertical. Valores posibles: Deshabilitado / Páginas / Canales / Componentes. Valor por defecto: Deshabilitado. Parámetro incluido en la tabla CHANGEKEY. Este parámetro establece las opciones que se mostrarán en cada menú de softkeys." ;
    ex:valor "Deshabilitado / Páginas / Canales / Componentes" .

ex:Tabla_CHANGEKEY a ex:Tabla ;
    ex:textoExtracto "Parámetro incluido en la tabla CHANGEKEY. Consultar el parámetro SYSHMENU. SYSVMENU Menú de sistema vertical. Valores posibles: Deshabilitado / Páginas / Canales / Componentes. Valor por defecto: Deshabilitado. Parámetro incluido en la tabla CHANGEKEY. Este parámetro establece las opciones que se mostrarán en cada menú de softkeys." ;
    ex:tieneComponente ex:Parametro_SYSVMENU .