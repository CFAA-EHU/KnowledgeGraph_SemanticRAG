@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_SYSHMENU
    a ex:Parametro ;
    rdfs:label "SYSHMENU" ;
    ex:textoExtracto "SYSVMENU Menú de sistema vertical. Valores posibles: Deshabilitado / Páginas / Canales / Componentes. Valor por defecto: Deshabilitado." ;
    ex:valor "Deshabilitado" .

ex:Parametro_SYSVMENU
    a ex:Parametro ;
    rdfs:label "SYSVMENU" ;
    ex:textoExtracto "SYSVMENU Menú de sistema vertical. Valores posibles: Deshabilitado / Páginas / Canales / Componentes. Valor por defecto: Deshabilitado." ;
    ex:valor "Deshabilitado" .

ex:Tabla_CHANGEKEY a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla CHANGEKEY" ;
    ex:textoExtracto "Parámetro incluido en la tabla CHANGEKEY." ;
    ex:tieneComponente ex:Parametro_SYSHMENU ;
    ex:tieneComponente ex:Parametro_SYSVMENU .

ex:InterfazUsuario_Teclado
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de teclado (tecla NEXT)" ;
    ex:textoExtracto "Configuración del teclado (tecla [NEXT])." ;
    ex:documentadoEn ex:Tabla_CHANGEKEY .