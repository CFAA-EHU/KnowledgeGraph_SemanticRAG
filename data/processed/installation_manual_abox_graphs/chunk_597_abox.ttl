@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoDeshabilitado a ex:ModoOperacion ;
    rdfs:label "Deshabilitado" ;
    ex:textoExtracto "El menú estará deshabilitado." .

ex:ModoPaginas a ex:ModoOperacion ;
    rdfs:label "Páginas" ;
    ex:textoExtracto "El menú muestra las distintas páginas o pantallas del modo de trabajo activo." .

ex:ModoCanales a ex:ModoOperacion ;
    rdfs:label "Canales" ;
    ex:textoExtracto "El menú muestra la lista de canales disponibles." .

ex:ModoComponentes a ex:ModoOperacion ;
    rdfs:label "Componentes" ;
    ex:textoExtracto "El menú muestra los componentes o modos de trabajo del CNC." .