@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ESCAPEKEY a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla ESCAPEKEY"@es ;
    ex:textoExtracto "Esta tabla muestra los parámetros para configurar la tecla de escape. La tabla dispone de los siguientes parámetros máquina."@es ;
    ex:ilustradoEn ex:InterfazUsuario_CNC .

ex:InterfazUsuario_CNC
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de usuario del CNC"@es ;
    ex:textoExtracto "El CNC sube de menú hasta alcanzar el menú principal del componente. A partir de ahí, el CNC cambia al modo principal (Main Menu)."@es .

ex:Parametro_FUNCTION
    a ex:Parametro ;
    rdfs:label "FUNCTION"@es ;
    ex:identificador "FUNCTION" ;
    ex:textoExtracto "Función asociada a la tecla de escape. Valores posibles: Menú previo / Componente previo / Menú-Componente previo. Valor por defecto: Menú previo."@es ;
    ex:valor "Menú previo" ;
    ex:documentadoEn ex:Tabla_ESCAPEKEY .

ex:Parametro_NPREVIOUS
    a ex:Parametro ;
    rdfs:label "NPREVIOUS"@es ;
    ex:identificador "NPREVIOUS" ;
    ex:textoExtracto "Número máximo de componentes previos memorizados. Valores posibles: De 1 a 5. Valor por defecto: 1."@es ;
    ex:valor "1" ;
    ex:documentadoEn ex:Tabla_ESCAPEKEY .

ex:ModoOperacion_MenuPrincipal
    a ex:ModoOperacion ;
    rdfs:label "Main Menu (Modo principal)"@es ;
    ex:textoExtracto "modo principal (Main Menu)."@es .

ex:ModoOperacion_ComponentePrevio
    a ex:ModoOperacion ;
    rdfs:label "Componente previo"@es ;
    ex:textoExtracto "el CNC alterna entre los últimos modos de trabajo anteriores (parámetro NPREVIOUS)."@es .