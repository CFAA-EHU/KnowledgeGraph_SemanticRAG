@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ESCAPEKEY a ex:Tabla ;
    ex:textoExtracto "Esta tabla muestra los parámetros para configurar la tecla de escape. La tabla dispone de los siguientes parámetros máquina. | ESCAPEKEY |  | FUNCTION | Función asociada a la tecla de escape. | NPREVIOUS | Número máximo de componentes previos memorizados. Valores posibles: De 1 a 5. Valor por defecto: 1. Parámetro incluido en la tabla ESCAPEKEY." ;
    ex:tieneComponente ex:FUNCTION, ex:NPREVIOUS .

ex:FUNCTION a ex:Parametro ;
    ex:identificador "FUNCTION" ;
    ex:textoExtracto "FUNCTION Función asociada a la tecla de escape. Valores posibles: Menú previo / Componente previo / Menú-Componente previo. Valor por defecto: Menú previo. Parámetro incluido en la tabla ESCAPEKEY." .

ex:NPREVIOUS a ex:Parametro ;
    ex:identificador "NPREVIOUS" ;
    ex:textoExtracto "NPREVIOUS Número máximo de componentes previos memorizados. Valores posibles: De 1 a 5. Valor por defecto: 1. Parámetro incluido en la tabla ESCAPEKEY." .