@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_NPREVIOUS a ex:Parametro ;
    rdfs:label "NPREVIOUS" ;
    ex:identificador "NPREVIOUS" ;
    ex:textoExtracto "Número máximo de componentes previos memorizados. Valores posibles: De 1 a 5. Valor por defecto: 1. Parámetro incluido en la tabla ESCAPEKEY. Número de componentes que memoriza al CNC para poder mostrarlos cuando se pulse la tecla escape." ;
    ex:valor "1" .

ex:Tabla_ESCAPEKEY a ex:Tabla ;
    ex:textoExtracto "Parámetro incluido en la tabla ESCAPEKEY" ;
    ex:identificador "ESCAPEKEY" ;
    ex:tieneComponente ex:Parametro_NPREVIOUS .