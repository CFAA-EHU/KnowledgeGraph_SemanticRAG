@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SIMJOGPANEL
    a ex:Parametro ;
    rdfs:label "SIMJOGPANEL" ;
    ex:identificador "SIMJOGPANEL" ;
    ex:valor "No" ;
    ex:textoExtracto "SIMJOGPANEL Teclado de JOG simulado. Valores posibles: Sí / No. Valor por defecto: No. Este parámetro indica si el teclado simulado está disponible." .

ex:TecladoJogSimulado
    a ex:InterfazUsuario ;
    rdfs:label "Teclado de JOG simulado" ;
    ex:textoExtracto "Se denomina Teclado de JOG simulado a una ventana que se superpone a la pantalla del CNC y que permite simular las teclas de JOG y las teclas de acceso a los modos de trabajo." ;
    ex:habilitadoPor ex:SIMJOGPANEL .

ex:ModoTelediagnosis
    a ex:ModoOperacion ;
    rdfs:label "Telediagnosis" ;
    ex:textoExtracto "Puede ser necesaria su utilización cuando se trabaja con telediagnosis (control remoto de CNC)." .