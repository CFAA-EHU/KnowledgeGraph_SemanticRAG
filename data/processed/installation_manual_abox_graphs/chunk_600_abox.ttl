@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CinematicaDeMesaTipo51_0035cde173 a ns1:Sistema ;
    rdfs:label "Cinemática de mesa tipo 51" ;
    ns1:textoExtracto "Esta cinemática permite controlar cualquier tipo de mesa que tenga como máximo dos ejes rotativos." ;
    ns1:tieneComponente ns1:EjeRotativoPrimero,
        ns1:EjeRotativoSegundo .

ns1:EjeRotativoPrimero a ns1:ComponenteMecanico ;
    rdfs:label "Primer eje rotativo" ;
    ns1:textoExtracto "V1 T1: Vector traslación del primer eje rotativo. V1 (TDATA4, TDATA5, TDATA6)" .

ns1:EjeRotativoSegundo a ns1:ComponenteMecanico ;
    rdfs:label "Segundo eje rotativo" ;
    ns1:textoExtracto "T2 T2: Vector traslación del segundo eje rotativo. V2 (TDATA14, TDATA15, TDATA16)" .

