@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_CierreCNC a ex:Parametro ;
    rdfs:label "WINEXIT" ;
    ex:identificador "WINEXIT" ;
    ex:textoExtracto "WINEXIT Salida de Windows al cerrar el CNC. Valores posibles: Sí / No. Valor por defecto: No (no se cierra Windows). Este parámetro indica si al salir del CNC, con [ALT][F4], se cierra Windows." ;
    ex:valor "No" .