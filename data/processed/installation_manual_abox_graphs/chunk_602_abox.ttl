@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla_GRAPHTYPE a ex:Tabla ;
    ex:textoExtracto "GRAPHTYPE Lista de gráficos en cada canal. En el modelo torno, este parámetro muestra la tabla para definir la configuración de los gráficos en cada canal." .

ex:Parametro_GRAPHTYPECH_n a ex:Parametro ;
    ex:textoExtracto "GRAPHTYPECH n Tipo de gráfico en cada canal. Valores posibles: Torno horizontal o vertical; X+ Z+ / X- Z+ / X+ Z- / X- Z-. Valor por defecto: Horizontal X+ Z+. Parámetro incluido en la tabla GRAPHTYPE. En el modelo torno, este parámetro establece la configuración de los gráficos del canal." ;
    ex:valor "Torno horizontal o vertical; X+ Z+ / X- Z+ / X+ Z- / X- Z-. Valor por defecto: Horizontal X+ Z+" .

ex:Parametro_Torno_horizontal a ex:Parametro ;
    ex:textoExtracto "Torno horizontal." .

ex:Parametro_Torno_vertical a ex:Parametro ;
    ex:textoExtracto "Torno vertical." .

ex:Parametro_Torno_TT a ex:Parametro ;
    ex:textoExtracto "También es posible representar los gráficos de un torno de doble torreta (torno TT)." .

ex:InterfazUsuario_FGUIM a ex:InterfazUsuario ;
    ex:textoExtracto "Para ello, utilizando la aplicación FGUIM, se deben modificar las propiedades Channel1 y Channel2 de la ventana gráfica para poder ver en un gráfico la ejecución de ambos canales." .

ex:Parametro_Channel1 a ex:Parametro ;
    ex:textoExtracto "propiedades Channel1 y Channel2 de la ventana gráfica" .

ex:Parametro_Channel2 a ex:Parametro ;
    ex:textoExtracto "propiedades Channel1 y Channel2 de la ventana gráfica" .

ex:Parametro_DIAGPSW a ex:Parametro ;
    ex:identificador "DIAGPSW" ;
    ex:textoExtracto "DIAGPSW (Reservado)" .