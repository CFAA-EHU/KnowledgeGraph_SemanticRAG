@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:DRIVEVAR a ex:Parametro ;
    ex:textoExtracto "DRIVEVAR" ;
    ex:valor "Número de elementos de la tabla de variables del regulador" .

ex:SIZE a ex:Parametro ;
    ex:identificador "(V.)DRV.SIZE" ;
    ex:textoExtracto "SIZE Número de variables a consultar en el regulador. Valores posibles: De 0 a 99. Valor por defecto: 0. Variable asociada: (V.)DRV.SIZE" ;
    ex:valor "Número de variables a consultar en el regulador" .

ex:DATA a ex:Parametro ;
    ex:textoExtracto "DATA Variables de los reguladores. Este parámetro muestra la tabla para definir la lista de variables DRV." ;
    ex:valor "Variables de los reguladores" .

ex:ModoOperacionMlinkII a ex:ModoOperacion ;
    ex:textoExtracto "acceso mediante variables DRV a los dispositivos Mechatrolink tiene las siguientes características y limitaciones. • El acceso a variables y/o parámetros de los dispositivos sólo está disponible para el modo Mlink-II a 32 bytes." ;
    ex:valor "Mlink-II a 32 bytes" .

ex:ReguladorMechatrolink a ex:ComponenteElectrico ;
    ex:textoExtracto "acceso mediante variables DRV a los dispositivos Mechatrolink" ;
    ex:valor "Mechatrolink" .

ex:ReguladorSercos a ex:ComponenteElectrico ;
    ex:textoExtracto "Para reguladores Sercos, en cada variable DRV hay que definir los siguientes campos." ;
    ex:valor "Sercos" .