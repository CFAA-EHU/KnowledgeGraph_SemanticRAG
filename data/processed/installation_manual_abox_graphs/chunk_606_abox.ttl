@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_0000_FFFF a ex:Parametro ;
    ex:textoExtracto "ID | Identificador del parámetro (0000-FFFF) o de la variable (0-F) a consultar en el dispositivo." ;
    ex:identificador "0000-FFFF" .

ex:Variable_0_F a ex:Parametro ;
    ex:textoExtracto "ID | Identificador del parámetro (0000-FFFF) o de la variable (0-F) a consultar en el dispositivo." ;
    ex:identificador "0-F" .

ex:ModoAcceso_SoloLectura a ex:ModoOperacion ;
    ex:textoExtracto "MODE | Modo de acceso. El acceso a las variables del regulador será siempre de solo lectura, mientras que el acceso a los parámetros podrá ser de lectura o escritura." ;
    rdfs:label "solo lectura" .

ex:ModoAcceso_LecturaEscritura a ex:ModoOperacion ;
    ex:textoExtracto "MODE | Modo de acceso. El acceso a las variables del regulador será siempre de solo lectura, mientras que el acceso a los parámetros podrá ser de lectura o escritura." ;
    rdfs:label "lectura o escritura" .