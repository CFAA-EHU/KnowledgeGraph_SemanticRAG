@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoRTCP a ns1:Parametro ;
    rdfs:label "Modo RTCP" ;
    ns1:textoExtracto "Con el modo RTCP activo, este parámetro establece si el sistema de coordenadas pieza está fijo sobre la pieza y gira con ella o si por el contrario se mantiene paralelo al sistema de coordenadas máquina." .

ns1:SistemaCoordenadasMaquina a ns1:Sistema ;
    rdfs:label "Sistema de Coordenadas Máquina" ;
    ns1:textoExtracto "Con el modo RTCP activo, este parámetro establece si el sistema de coordenadas pieza está fijo sobre la pieza y gira con ella o si por el contrario se mantiene paralelo al sistema de coordenadas máquina." .

ns1:SistemaCoordenadasPieza a ns1:Sistema ;
    rdfs:label "Sistema de Coordenadas Pieza" ;
    ns1:textoExtracto "Con el modo RTCP activo, este parámetro establece si el sistema de coordenadas pieza está fijo sobre la pieza y gira con ella o si por el contrario se mantiene paralelo al sistema de coordenadas máquina." .

