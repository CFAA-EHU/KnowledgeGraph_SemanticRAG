@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Regulador_V9_10 a ex:Maquina ;
    rdfs:label "regulador V9.10"@es ;
    ex:textoExtracto "la versión del regulador debe ser V9.10 o superior"@es .

ex:Parametro_PP216 a ex:Parametro ;
    rdfs:label "PP216 (VelocityFeedForwardPercentage)"@es ;
    ex:identificador "PP216" ;
    ex:textoExtracto "la variable deberá actuar sobre el parámetro PP216 (VelocityFeedForwardPercentage) del regulador"@es .

ex:Tabla_DRIVEVAR a ex:Tabla ;
    rdfs:label "tabla DRIVEVAR"@es ;
    ex:textoExtracto "En la tabla DRIVEVAR, definir la variable de la siguiente manera."@es ;
    ex:compuestoPor ex:Campo_MNEMONIC, ex:Campo_AXIS, ex:Campo_ID, ex:Campo_TYPE, ex:Campo_MODE .

ex:Campo_MNEMONIC a ex:Parametro ;
    rdfs:label "MNEMONIC"@es ;
    ex:textoExtracto "MNEMONIC | Mnemónico asignado a la variable DRV."@es .

ex:Campo_AXIS a ex:Parametro ;
    rdfs:label "AXIS"@es ;
    ex:textoExtracto "AXIS | Número de nodo del regulador."@es .

ex:Campo_ID a ex:Parametro ;
    rdfs:label "ID"@es ;
    ex:textoExtracto "ID | IDN Sercos de la variable a consultar en el regulador. IDN Sercos 00296 para el porcentaje de feed-forward (PP216)."@es .

ex:Campo_TYPE a ex:Parametro ;
    rdfs:label "TYPE"@es ;
    ex:textoExtracto "TYPE | Esta variable debe ser síncrona."@es .

ex:Campo_MODE a ex:Parametro ;
    rdfs:label "MODE"@es ;
    ex:textoExtracto "MODE | El acceso a la variable debe ser de escritura."@es .

ex:IDN_Sercos_00296 a ex:Parametro ;
    rdfs:label "IDN Sercos 00296"@es ;
    ex:identificador "00296" ;
    ex:textoExtracto "IDN Sercos 00296 para el porcentaje de feed-forward (PP216)"@es .

ex:Acceso_CNC_V_DRV_FFGAIN_2 a ex:InterfazUsuario ;
    rdfs:label "V.DRV.FFGAIN.2"@es ;
    ex:textoExtracto "El acceso desde el CNC será V.DRV.FFGAIN.2"@es .

ex:Acceso_PLC_DRV_FFGAIN_2 a ex:InterfazUsuario ;
    rdfs:label "DRV.FFGAIN.2"@es ;
    ex:textoExtracto "El acceso desde el PLC será DRV.FFGAIN.2"@es .

ex:Modo_Sincrono a ex:ModoOperacion ;
    rdfs:label "modo síncrono"@es ;
    ex:textoExtracto "modificar el FFGAIN en modo síncrono"@es .