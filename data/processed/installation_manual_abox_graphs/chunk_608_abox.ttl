@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaParametrosFabricante_MTBPAR a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "MTBPAR" ;
    ex:identificador "MTBPAR" ;
    ex:textoExtracto "MTBPAR Tabla de parámetros del fabricante. Esta tabla ofrece 1000 parámetros genéricos para que el fabricante los pueda utilizar a modo de parámetros máquina." ;
    ex:tieneComponente ex:Parametro_SIZE_MTBPAR, ex:Parametro_DATA_MTBPAR .

ex:Parametro_SIZE_MTBPAR
    a ex:Parametro ;
    rdfs:label "SIZE (Número de parámetros del fabricante)" ;
    ex:identificador "MTB.SIZE" ;
    ex:valor "0" ;
    ex:textoExtracto "SIZE Número de parámetros del fabricante. Valores posibles: De 0 a 1000. Valor por defecto: 0. Variable asociada: (V.)MTB.SIZE Este parámetro establece el número de parámetros de fabricante que se van a utilizar." ;
    ex:documentadoEn ex:TablaParametrosFabricante_MTBPAR .

ex:Parametro_DATA_MTBPAR
    a ex:Parametro ;
    rdfs:label "DATA (Lista de parámetros del fabricante)" ;
    ex:identificador "MTB.DATA" ;
    ex:textoExtracto "DATA Lista de parámetros del fabricante. Este parámetro muestra la tabla de parámetros del fabricante. Para cada parámetro hay que definir los siguientes campos." ;
    ex:documentadoEn ex:TablaParametrosFabricante_MTBPAR .