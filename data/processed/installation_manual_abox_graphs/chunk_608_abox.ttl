@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCinematicaTipo52_1994b435d4 a ns1:Sistema ;
    rdfs:label "Sistema Cinemática Tipo 52" ;
    ns1:textoExtracto "Esta cinemática permite controlar cualquier tipo de cinemática compuesta por un cabezal y una mesa, que tenga como máximo dos ejes rotativos en el cabezal y otros dos en la mesa." ;
    ns1:tieneComponente ns1:Componente_37dbe5cfa3,
        ns1:CuartoEjeRotativo,
        ns1:PrimerEjeRotativo,
        ns1:SegundoEjeRotativo,
        ns1:TercerEjeRotativo .

ns1:Componente_37dbe5cfa3 a ns1:Componente ;
    rdfs:label "Portaherramientas" ;
    ns1:textoExtracto "T3: Vector traslación del portaherramientas. V3: Vector dirección del portaherramientas." .

ns1:CuartoEjeRotativo a ns1:Componente ;
    rdfs:label "Cuarto eje rotativo" ;
    ns1:textoExtracto "T5: Vector traslación del cuarto eje rotativo. V5: Vector dirección del cuarto eje rotativo." .

ns1:PrimerEjeRotativo a ns1:Componente ;
    rdfs:label "Primer eje rotativo" ;
    ns1:textoExtracto "T1: Vector traslación del primer eje rotativo. V1: Vector dirección del primer eje rotativo." .

ns1:SegundoEjeRotativo a ns1:Componente ;
    rdfs:label "Segundo eje rotativo" ;
    ns1:textoExtracto "T2: Vector traslación del segundo eje rotativo. V2: Vector dirección del segundo eje rotativo." .

ns1:TercerEjeRotativo a ns1:Componente ;
    rdfs:label "Tercer eje rotativo" ;
    ns1:textoExtracto "T4: Vector traslación del tercer eje rotativo. V4: Vector dirección del tercer eje rotativo." .

