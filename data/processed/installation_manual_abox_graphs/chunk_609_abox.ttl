@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_Valor ex:textoExtracto """Valor del parámetro. Valores posibles: Entre ±99999.9999. Valor por defecto: 0.""" ;
    rdfs:label "Valor del parámetro" ;
    a ex:Parametro .

ex:Parametro_ModoAcceso ex:textoExtracto """Modo de acceso al parámetro desde su variable.""" ;
    rdfs:label "Modo de acceso al parámetro" ;
    a ex:Parametro .

ex:Parametro_Unidades ex:textoExtracto """El parámetro se ve afectado por el cambio de unidades.""" ;
    rdfs:label "Parámetro afectado por unidades" ;
    a ex:Parametro .

ex:Parametro_DescripcionOEM ex:textoExtracto """Descripción del parámetro OEM.""" ;
    rdfs:label "Descripción del parámetro OEM" ;
    a ex:Parametro .

ex:Parametro_ValorUnidades ex:textoExtracto """Si el parámetro se ve afectado por el cambio de unidades (campo INCHES), el valor se introduce en la tabla en las unidades seleccionadas por el parámetro máquina INCHES.""" ;
    rdfs:label "Parámetro con unidades afectadas" ;
    a ex:Parametro .

ex:Parametro_VariableAcceso ex:textoExtracto """Cada parámetro dispone de sus variables para poder leer o modificar (si tiene permiso de escritura) su valor a través del programa pieza, PLC o interface. El acceso a estos parámetros mediante variables será de la forma. ( V.)MTB.P[i] Valor del parámetro de fabricante [i]. ( V.)MTB.PF[i] Valor del parámetro de fabricante [i]. Valor por 10000.""" ;
    rdfs:label "Variables de acceso a parámetros" ;
    a ex:Parametro .