@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DefinicionDeLosEjesQueNoEstanPresentesEnLaCinematica a ns1:Parametro ;
    rdfs:label "Definición de los ejes que no están presentes en la cinemática" ;
    ns1:textoExtracto "T5 Definición de los ejes que no están presentes en la cinemática." .

ns1:PosicionDeReposoDelPrimerEje a ns1:Parametro ;
    rdfs:label "Posición de reposo del primer eje" ;
    ns1:textoExtracto "T1 (TDATA1, TDATA2, TDATA3)" .

ns1:PosicionDeReposoDelSegundoEje a ns1:Parametro ;
    rdfs:label "Posición de reposo del segundo eje" ;
    ns1:textoExtracto "T2 (TDATA11, TDATA12, TDATA13)" .

ns1:PosicionDeReposoDelTercerEje a ns1:Parametro ;
    rdfs:label "Posición de reposo del tercer eje" ;
    ns1:textoExtracto "T3 (TDATA21, TDATA22, TDATA23)" .

ns1:VectorDireccionDelCuartoEjeRotativo a ns1:Parametro ;
    rdfs:label "Vector dirección del cuarto eje rotativo" ;
    ns1:textoExtracto "V5: Vector dirección del cuarto eje rotativo." .

ns1:VectorTraslacionDelPrimerEje a ns1:Parametro ;
    rdfs:label "Vector traslación del primer eje" ;
    ns1:textoExtracto "V1 (TDATA4, TDATA5, TDATA6)" .

ns1:VectorTraslacionDelSegundoEje a ns1:Parametro ;
    rdfs:label "Vector traslación del segundo eje" ;
    ns1:textoExtracto "V2 (TDATA14, TDATA15, TDATA16)" .

ns1:VectorTraslacionDelTercerEje a ns1:Parametro ;
    rdfs:label "Vector traslación del tercer eje" ;
    ns1:textoExtracto "V3 (TDATA24, TDATA25, TDATA26)" .

