@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ParametrosGenericosFabricante a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros genéricos del fabricante"@es ;
    ex:textoExtracto """
| DATA |  |
| --- | --- |
| VALUE | Valor del parámetro. |
| MODE | Modo de acceso al parámetro desde su variable. |
| INCHES | El parámetro se ve afectado por el cambio de unidades. |
| COMMENT | Descripción del parámetro OEM.
"""@es ;
    ex:documentadoEn ex:Pagina_331_332 .

ex:ParametroFabricante_VALUE
    a ex:Parametro ;
    rdfs:label "Parámetro VALUE"@es ;
    ex:textoExtracto "VALUE: Valor del parámetro. Valores posibles: Entre ±99999.9999. Valor por defecto: 0."@es ;
    ex:valor "±99999.9999" ;
    ex:documentadoEn ex:Tabla_ParametrosGenericosFabricante .

ex:ParametroFabricante_MODE
    a ex:Parametro ;
    rdfs:label "Parámetro MODE"@es ;
    ex:textoExtracto "MODE: Modo de acceso al parámetro desde su variable."@es ;
    ex:documentadoEn ex:Tabla_ParametrosGenericosFabricante .

ex:ParametroFabricante_INCHES
    a ex:Parametro ;
    rdfs:label "Parámetro INCHES"@es ;
    ex:textoExtracto "INCHES: El parámetro se ve afectado por el cambio de unidades."@es ;
    ex:documentadoEn ex:Tabla_ParametrosGenericosFabricante .

ex:ParametroFabricante_COMMENT
    a ex:Parametro ;
    rdfs:label "Parámetro COMMENT"@es ;
    ex:textoExtracto "COMMENT: Descripción del parámetro OEM."@es ;
    ex:documentadoEn ex:Tabla_ParametrosGenericosFabricante .

ex:VariableAcceso_MTB.P
    a ex:InterfazUsuario ;
    rdfs:label "Variable de acceso MTB.P[i]"@es ;
    ex:textoExtracto "(V.)MTB.P[i]: Valor del parámetro de fabricante [i]."@es ;
    ex:identificador "MTB.P[i]" .

ex:VariableAcceso_MTB.PF
    a ex:InterfazUsuario ;
    rdfs:label "Variable de acceso MTB.PF[i]"@es ;
    ex:textoExtracto "(V.)MTB.PF[i]: Valor del parámetro de fabricante [i]. Valor por 10000."@es ;
    ex:identificador "MTB.PF[i]" ;
    ex:valor "10000" .