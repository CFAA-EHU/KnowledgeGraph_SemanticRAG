@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ParametroP0 a ex:Parametro ;
    rdfs:label "P0" ;
    ex:identificador "P0" ;
    ex:valor "7" ;
    ex:textoExtracto "P0 | 7 | V.MTB.P[0] = 7 | V.MTB.PF[0] = 70000" .

ex:ParametroP8 a ex:Parametro ;
    rdfs:label "P8" ;
    ex:identificador "P8" ;
    ex:valor "12,5" ;
    ex:textoExtracto "P8 | 12,5 | V.MTB.P[8] = 12,5 | V.MTB.PF[8] = 125000" .

ex:TablaMTB a ex:Tabla ;
    ex:textoExtracto "| Mnemónico. | Valor. | V.MTB.P[i] | V.MTB.PF[i] | ... | P0 | 7 | V.MTB.P[0] = 7 | V.MTB.PF[0] = 70000 | ... | P8 | 12,5 | V.MTB.P[8] = 12,5 | V.MTB.PF[8] = 125000 |" ;
    ex:tieneComponente ex:ParametroP0, ex:ParametroP8 .

ex:ModoAcceso a ex:ModoOperacion ;
    rdfs:label "MODE" ;
    ex:textoExtracto "MODE Modo de acceso al parámetro desde su variable. Valores posibles: Lectura / Escritura. Valor por defecto: Lectura." .

ex:ModoSetup a ex:ModoOperacion ;
    rdfs:label "Modo Setup" ;
    ex:textoExtracto "Modo Setup. Las variables pueden escribir los parámetros con permiso de escritura y de solo lectura." .

ex:ModoUser a ex:ModoOperacion ;
    rdfs:label "Modo User" ;
    ex:textoExtracto "Modo User. Las variables sólo pueden escribir los parámetros con permiso de escritura." .

ex:ParametroAfectadoUnidades a ex:Parametro ;
    rdfs:label "INCHES" ;
    ex:textoExtracto "INCHES El parámetro se ve afectado por el cambio de unidades. Valores posibles: Sí / No. Valor por defecto: Sí." .

ex:CampoComment a ex:Parametro ;
    rdfs:label "COMMENT" ;
    ex:textoExtracto "COMMENT Descripción del parámetro OEM. Este campo ofrece la posibilidad de asociar una pequeña descripción al parámetro." .