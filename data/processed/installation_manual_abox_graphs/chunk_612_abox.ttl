@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EditorLevasElectronicas a ex:InterfazUsuario ;
    rdfs:label "Editor de levas electrónicas" ;
    ex:textoExtracto "Editor de levas que ofrece una cómoda asistencia para analizar el comportamiento de la leva proyectada a través de las facilidades gráficas de edición de valores de velocidad, aceleración y jerk." .

ex:TablaCAMTABLE a ex:Tabla ;
    rdfs:label "Tabla de levas electrónicas" ;
    ex:textoExtracto "CAMTABLE Tabla de levas electrónicas. Esta tabla muestra los parámetros para definir las levas electrónicas. La tabla dispone de los siguientes parámetros máquina. | CAMTABLE |  | | SIZE | Número de levas electrónicas. | | DATA | Lista de levas. | | CAM n | Acceso al editor de levas. SIZE Número de levas electrónicas. Valores posibles: De 0 a 16. Valor por defecto: 0. Parámetro incluido en la tabla CAMTABLE. Este parámetro establece el número de levas electrónicas del sistema. DATA Lista de levas electrónicas. Este parámetro muestra la lista de levas disponibles. CAM n Editor de levas electrónicas." .

ex:ParametroSIZE a ex:Parametro ;
    rdfs:label "SIZE" ;
    ex:textoExtracto "SIZE Número de levas electrónicas. Valores posibles: De 0 a 16. Valor por defecto: 0. Parámetro incluido en la tabla CAMTABLE. Este parámetro establece el número de levas electrónicas del sistema." .

ex:ParametroDATA a ex:Parametro ;
    rdfs:label "DATA" ;
    ex:textoExtracto "DATA Lista de levas electrónicas. Este parámetro muestra la lista de levas disponibles." .

ex:ParametroCAMn a ex:Parametro ;
    rdfs:label "CAM n" ;
    ex:textoExtracto "CAM n Acceso al editor de levas." .

ex:TablaCAMTABLE a ex:Tabla ;
    ex:tieneComponente ex:ParametroSIZE, ex:ParametroDATA, ex:ParametroCAMn .