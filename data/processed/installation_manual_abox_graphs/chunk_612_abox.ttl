@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:EditorLevasElectronicas
    a                     ex:InterfazUsuario ;
    rdfs:label            "Editor de levas electrónicas"@es ;
    ex:textoExtracto      "El editor de levas es un elemento gráfico de ayuda para el diseño de levas. [...] Editor de levas que ofrece una cómoda asistencia para analizar el comportamiento de la leva proyectada a través de las facilidades gráficas de edición de valores de velocidad, aceleración y jerk."@es ;
    ex:documentadoEn      ex:ManualEspecificoEditorLevas .

ex:TablaCAMTABLE a ex:Tabla ;
     a                     ex:Tabla ;
    rdfs:label            "CAMTABLE (Tabla de levas electrónicas)"@es ;
    ex:textoExtracto      "CAMTABLE Tabla de levas electrónicas. Esta tabla muestra los parámetros para definir las levas electrónicas."@es ;
    ex:detalladoEnEsquema ex:EditorLevasElectronicas ;
    ex:tieneComponente    ex:Parametro_SIZE ,
                          ex:Parametro_DATA ,
                          ex:Parametro_CAMn .

ex:Parametro_SIZE
    a               ex:Parametro ;
    rdfs:label      "SIZE (Número de levas electrónicas)"@es ;
    ex:textoExtracto "SIZE Número de levas electrónicas. Valores posibles: De 0 a 16. Valor por defecto: 0. Parámetro incluido en la tabla CAMTABLE. Este parámetro establece el número de levas electrónicas del sistema."@es ;
    ex:valor        "0-16" ;
    ex:monitoreaParametro ex:SistemaLevasElectronicas .

ex:Parametro_DATA
    a               ex:Parametro ;
    rdfs:label      "DATA (Lista de levas electrónicas)"@es ;
    ex:textoExtracto "DATA Lista de levas electrónicas. Este parámetro muestra la lista de levas disponibles."@es .

ex:Parametro_CAMn
    a               ex:Parametro ;
    rdfs:label      "CAM n (Acceso al editor de levas)"@es ;
    ex:textoExtracto "CAM n Acceso al editor de levas."@es ;
    ex:habilitadoPor ex:EditorLevasElectronicas .

ex:SistemaLevasElectronicas
    a               ex:Sistema ;
    rdfs:label      "Sistema de levas electrónicas"@es ;
    ex:textoExtracto "Este parámetro establece el número de levas electrónicas del sistema."@es ;
    ex:compuestoPor ex:EditorLevasElectronicas .

ex:ManualEspecificoEditorLevas
    a               ex:Manual ;
    rdfs:label      "Manual específico del editor de levas"@es ;
    ex:textoExtracto "Esta funcionalidad dispone de un manual específico."@es .