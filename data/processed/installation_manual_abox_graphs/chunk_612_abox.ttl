@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DireccionDeLosEjesXYZSegunLaNormaDIN66217_b92110067c a ns1:Parametro ;
    rdfs:label "Dirección de los ejes X Y Z según la norma DIN 66217" ;
    ns1:textoExtracto "La dirección de los ejes X Y Z, según la norma DIN 66217, se puede recordar fácilmente utilizando la regla de la mano derecha." .

ns1:EjeRotativoPrincipalDelCabezalManualOServocontrolado a ns1:Parametro ;
    rdfs:label "Eje rotativo principal del cabezal manual o servocontrolado" ;
    ns1:identificador "TDATA9" ;
    ns1:textoExtracto "TDATA9 Eje rotativo principal del cabezal manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0." .

