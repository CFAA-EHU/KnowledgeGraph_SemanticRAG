@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:PLC_ProgramaEjecutable
    a                     ex:Sistema ;
    rdfs:label            "Programa ejecutable del PLC"@es ;
    ex:textoExtracto       "el CNC ejecuta el programa ejecutable del PLC almacenado en memoria"@es ;
    ex:identificador       "fichero objeto"@es .

ex:InterfazCNC_PLC
    a                     ex:InterfazUsuario ;
    rdfs:label            "Interfaz de intercambio CNC-PLC"@es ;
    ex:textoExtracto       "Existe un intercambio de información entre el CNC y el PLC que se realiza de modo automático. Desde el PLC se puede: • Controlar las entradas y salidas físicas (módulos remotos). • Consultar y/o modificar las variables de intercambio CNC-PLC. Desde el CNC se puede: • Transferir las funciones auxiliares M, H y S. • Acceder a los recursos del PLC desde cualquier programa pieza."@es ;
    ex:controla           ex:PLC_ProgramaEjecutable ;
    ex:monitoreaParametro  ex:Parametro_MaquinaGeneral .

ex:Parametro_MaquinaGeneral
    a                     ex:Parametro ;
    rdfs:label            "Parámetro máquina general (p.m.g.)"@es ;
    ex:textoExtracto       "( p.m.g.) Parámetro máquina general."@es ;
    ex:identificador       "p.m.g."@es .

ex:PanelFrontal_PLC
    a                     ex:InterfazUsuario ;
    rdfs:label            "Panel frontal del PLC"@es ;
    ex:textoExtracto       "El programa de PLC puede ser editado desde el panel frontal"@es .

ex:ModuloRemoto_E_S
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Módulo remoto de E/S"@es ;
    ex:textoExtracto       "Controlar las entradas y salidas físicas (módulos remotos)"@es ;
    ex:controla           ex:PLC_ProgramaEjecutable .