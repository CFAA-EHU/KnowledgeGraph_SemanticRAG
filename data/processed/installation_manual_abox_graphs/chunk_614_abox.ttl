@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ControlDelEjeRotativoSecundarioDelCabezal a ns1:Parametro ;
    rdfs:label "Control del eje rotativo secundario del cabezal" ;
    ns1:identificador "TDATA19" ;
    ns1:textoExtracto "TDATA19 Eje rotativo secundario del cabezal manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0." ;
    ns1:valor "0" .

ns1:PosicionDeReposoDelEjeRotativo a ns1:Parametro ;
    rdfs:label "Posición de reposo del eje rotativo" ;
    ns1:identificador "TDATA17" ;
    ns1:textoExtracto "Si el eje no existe en la cinemática, se definirá como TDATA17=0." .

ns1:SentidoDeGiroDelEjeRotativoSecundarioDelCabezal a ns1:Parametro ;
    rdfs:label "Sentido de giro del eje rotativo secundario del cabezal" ;
    ns1:identificador "TDATA18" ;
    ns1:textoExtracto "TDATA18 Sentido de giro del eje rotativo secundario del cabezal. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." ;
    ns1:valor "0" .

