@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ProgramaPLC_614
    a                     ex:Sistema ;
    rdfs:label            "Programa PLC con ficheros en mnemónicos, C y contactos"@es ;
    ex:textoExtracto       "El programa de PLC puede combinar varios ficheros en lenguaje de mnemónicos (extensión 'plc'), varios ficheros en lenguaje C (extensión 'c') y un fichero en lenguaje de contactos (extensión 'ld')."@es ;
    ex:compuestoPor        ex:FicheroMnemotecnicos_614 ;
    ex:compuestoPor        ex:FicheroC_614 ;
    ex:compuestoPor        ex:FicheroContactos_614 ;
    ex:compuestoPor        ex:SubrutinaSUMA_614 ;
    ex:identificador       "MTB\\PLC\\PROJECT" .

ex:FicheroMnemotecnicos_614
    a                     ex:Componente ;
    rdfs:label            "Fichero en lenguaje de mnemónicos (extensión .plc)"@es ;
    ex:textoExtracto       "ficheros en lenguaje de mnemónicos (extensión 'plc')... Se aconseja utilizar los ficheros en lenguaje de mnemónicos o de contactos como programa principal del PLC."@es ;
    ex:identificador       "Mnemónicos.plc" .

ex:FicheroC_614
    a                     ex:Componente ;
    rdfs:label            "Fichero en lenguaje C (extensión .c)"@es ;
    ex:textoExtracto       "ficheros en lenguaje C (extensión 'c')... para tareas auxiliares (por ejemplo, compensación de temperatura)."@es ;
    ex:identificador       "Lenguajec.c" .

ex:FicheroContactos_614
    a                     ex:Componente ;
    rdfs:label            "Fichero en lenguaje de contactos (extensión .ld)"@es ;
    ex:textoExtracto       "un fichero en lenguaje de contactos (extensión 'ld')."@es .

ex:SubrutinaSUMA_614
    a                     ex:Componente ;
    rdfs:label            "Subrutina SUMA"@es ;
    ex:textoExtracto       "SUB SUMA... Las subrutinas del programa en lenguaje de mnemónicos o de contactos hay que definirlas fuera de los módulos... El nombre de la subrutina debe estar redactado en mayúsculas en ambos ficheros."@es ;
    ex:identificador       "SUMA" .

ex:LibreriaMatematica_614
    a                     ex:Componente ;
    rdfs:label            "Librería matemática (trigonométrica, logarítmica)"@es ;
    ex:textoExtracto       "La programación en lenguaje C dispone de una librería matemática (trigonométrica, logarítmica, etc.)."@es .