@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModuloPeriodicoPE30000 a ex:ModoOperacion ;
    rdfs:label "PE 30000" ;
    ex:textoExtracto "Una tarea que es suficiente evaluarla cada 30 segundos se definirá en un módulo periódico que se ejecute cada 30 segundos (PE 30000)." ;
    ex:valor "30 segundos" .

ex:FrecuenciaEvaluacion30s a ex:Frecuencia ;
    ex:textoExtracto "evaluarla cada 30 segundos" ;
    ex:valor "30 segundos" .