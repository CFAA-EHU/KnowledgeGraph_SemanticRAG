@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
ex:PLC_Recursos a ex:Sistema ;
    ex:textoExtracto "El PLC dispone de los siguientes recursos. • Entradas (I1-I1024) y salidas (O1-O1024). • Entradas locales (LI1-LI16) y salidas locales (LO1-LO8). • Marcas (M1-M8192). • Mensajes (MSG1-MSG1024). • Errores (ERR1-ERR1024). • Relojes (CLK). • Registros (R1-R1024). • Temporizadores (T1-T512). • Contadores (C1-C256). • Registros y marcas de comunicación CNC-PLC."@es .

ex:Entrada_I1 a ex:Sensor ;
    ex:identificador "I1" ;
    ex:textoExtracto "Entradas (I1-I1024) ... Se representan mediante la letra I seguida del número de entrada que se desea referenciar, desde I1 hasta I1024."@es .

ex:Entrada_I1024 a ex:Sensor ;
    ex:identificador "I1024" ;
    ex:textoExtracto "Entradas (I1-I1024) ... Se representan mediante la letra I seguida del número de entrada que se desea referenciar, desde I1 hasta I1024."@es .

ex:Salida_O1 a ex:Actuador ;
    ex:identificador "O1" ;
    ex:textoExtracto "Las salidas son elementos que permiten al PLC activar o desactivar los distintos dispositivos o accionamientos del armario eléctrico. Se representan mediante la letra O seguida del número de salida que se desea referenciar, desde O1 hasta O1024."@es .

ex:Salida_O1024 a ex:Actuador ;
    ex:identificador "O1024" ;
    ex:textoExtracto "Las salidas son elementos que permiten al PLC activar o desactivar los distintos dispositivos o accionamientos del armario eléctrico. Se representan mediante la letra O seguida del número de salida que se desea referenciar, desde O1 hasta O1024."@es .

ex:EntradaLocal_LI1 a ex:Sensor ;
    ex:identificador "LI1" ;
    ex:textoExtracto "Entradas locales (LI1-LI16) ... Las entradas locales se representan mediante la letra LI seguida del número de entrada, desde LI1 hasta LI16."@es .

ex:EntradaLocal_LI16 a ex:Sensor ;
    ex:identificador "LI16" ;
    ex:textoExtracto "Entradas locales (LI1-LI16) ... Las entradas locales se representan mediante la letra LI seguida del número de entrada, desde LI1 hasta LI16."@es .

ex:SalidaLocal_LO1 a ex:Actuador ;
    ex:identificador "LO1" ;
    ex:textoExtracto "salidas locales (LO1-LO8)."@es .

ex:SalidaLocal_LO8 a ex:Actuador ;
    ex:identificador "LO8" ;
    ex:textoExtracto "salidas locales (LO1-LO8)."@es .

ex:Marca_M1 a ex:Componente ;
    ex:identificador "M1" ;
    ex:textoExtracto "Marcas (M1-M8192)."@es .

ex:Marca_M8192 a ex:Componente ;
    ex:identificador "M8192" ;
    ex:textoExtracto "Marcas (M1-M8192)."@es .

ex:Mensaje_MSG1 a ex:Componente ;
    ex:identificador "MSG1" ;
    ex:textoExtracto "Mensajes (MSG1-MSG1024)."@es .

ex:Mensaje_MSG1024 a ex:Componente ;
    ex:identificador "MSG1024" ;
    ex:textoExtracto "Mensajes (MSG1-MSG1024)."@es .

ex:Error_ERR1 a ex:DiagnosticoFallo ;
    ex:identificador "ERR1" ;
    ex:textoExtracto "Errores (ERR1-ERR1024)."@es .

ex:Error_ERR1024 a ex:DiagnosticoFallo ;
    ex:identificador "ERR1024" ;
    ex:textoExtracto "Errores (ERR1-ERR1024)."@es .

ex:Reloj_CLK a ex:Componente ;
    ex:identificador "CLK" ;
    ex:textoExtracto "Relojes (CLK)."@es .

ex:Registro_R1 a ex:Componente ;
    ex:identificador "R1" ;
    ex:textoExtracto "Registros (R1-R1024)."@es .

ex:Registro_R1024 a ex:Componente ;
    ex:identificador "R1024" ;
    ex:textoExtracto "Registros (R1-R1024)."@es .

ex:Temporizador_T1 a ex:Componente ;
    ex:identificador "T1" ;
    ex:textoExtracto "Temporizadores (T1-T512)."@es .

ex:Temporizador_T512 a ex:Componente ;
    ex:identificador "T512" ;
    ex:textoExtracto "Temporizadores (T1-T512)."@es .

ex:Contador_C1 a ex:Componente ;
    ex:identificador "C1" ;
    ex:textoExtracto "Contadores (C1-C256)."@es .

ex:Contador_C256 a ex:Componente ;
    ex:identificador "C256" ;
    ex:textoExtracto "Contadores (C1-C256)."@es .