@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjeRotativoSecundarioDeLaMesaManualOServocontrolado a ns1:Parametro ;
    rdfs:label "Eje rotativo secundario de la mesa manual o servocontrolado" ;
    ns1:identificador "TDATA49" ;
    ns1:textoExtracto "TDATA49 Eje rotativo secundario de la mesa manual o servocontrolado. Valores posibles: 0 (servocontrolado) / 1 (manual). Valor por defecto: 0." ;
    ns1:valor "0" .

ns1:OrigenParaAplicarElRTCP a ns1:Parametro ;
    rdfs:label "Origen para aplicar el RTCP" ;
    ns1:identificador "TDATA50" ;
    ns1:textoExtracto "TDATA50 Origen para aplicar el RTCP. Valores posibles: 0 (cero máquina) / 1 (cero pieza)." .

ns1:SentidoDeGiroDelEjeRotativoSecundarioDeLaMesa a ns1:Parametro ;
    rdfs:label "Sentido de giro del eje rotativo secundario de la mesa" ;
    ns1:identificador "TDATA48" ;
    ns1:textoExtracto "TDATA48 Sentido de giro del eje rotativo secundario de la mesa. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0." ;
    ns1:valor "0" .

