@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:LI1 a ex:ComponenteElectrico ;
    rdfs:label "LI1" ;
    ex:identificador "LI1" ;
    ex:textoExtracto "Las entradas locales se representan mediante la letra LI seguida del número de entrada, desde LI1 hasta LI16." .

ex:LI16 a ex:ComponenteElectrico ;
    rdfs:label "LI16" ;
    ex:identificador "LI16" ;
    ex:textoExtracto "Las entradas locales se representan mediante la letra LI seguida del número de entrada, desde LI1 hasta LI16." .

ex:LO1 a ex:ComponenteElectrico ;
    rdfs:label "LO1" ;
    ex:identificador "LO1" ;
    ex:textoExtracto "Las salidas locales se representan mediante la letra LO seguida del número de salida, desde LO1 hasta LO8." .

ex:LO8 a ex:ComponenteElectrico ;
    rdfs:label "LO8" ;
    ex:identificador "LO8" ;
    ex:textoExtracto "Las salidas locales se representan mediante la letra LO seguida del número de salida, desde LO1 hasta LO8." .