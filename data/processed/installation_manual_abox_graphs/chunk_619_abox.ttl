@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:EntradasLocalesPLC
    a ex:ComponenteElectrico ;
    rdfs:label "Entradas locales del PLC (LI1-LI16)" ;
    ex:textoExtracto "Las entradas locales se representan mediante la letra LI seguida del número de entrada, desde LI1 hasta LI16." ;
    ex:identificador "LI1-LI16" .

ex:SalidasLocalesPLC
    a ex:ComponenteElectrico ;
    rdfs:label "Salidas locales del PLC (LO1-LO8)" ;
    ex:textoExtracto "Las salidas locales se representan mediante la letra LO seguida del número de salida, desde LO1 hasta LO8." ;
    ex:identificador "LO1-LO8" .

ex:SistemaIO_PLC
    a ex:Sistema ;
    rdfs:label "Sistema de E/S locales del PLC" ;
    ex:textoExtracto "Se denominan entradas y salidas locales porque se encuentran en la unidad central y no en los módulos remotos." ;
    ex:tieneComponente ex:EntradasLocalesPLC ;
    ex:tieneComponente ex:SalidasLocalesPLC .