@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:IO_Local_LO1_LO8
    a ex:ComponenteElectrico ;
    rdfs:label "I/O digitales locales (LO1-LO8)"@es ;
    ex:textoExtracto "desde LO1 hasta LO8. Las I/O digitales locales no se tienen en cuenta a la hora de personalizar la numeración de los I/Os remotas ni cuando se salva la configuración del bus CAN. La referencia a las I/O locales será siempre la misma, independientemente de la configuración del sistema."@es ;
    ex:identificador "LO1-LO8" .

ex:Modulo_PE
    a ex:ComponenteElectrico ;
    rdfs:label "Módulo PE"@es ;
    ex:textoExtracto "El refresco de las I/O locales se realizará con la misma frecuencia que el de las I/O remotas y además desde el módulo PE."@es ;
    ex:identificador "PE" .

ex:Marca_M1_M8192
    a ex:Parametro ;
    rdfs:label "Marcas (M1-M8192)"@es ;
    ex:textoExtracto "Marcas (M1-M8192). Son elementos capaces de memorizar en un bit (como si fuera un relé interno) el valor definido por el usuario. Si la marca está a cero, se dirá que está a nivel lógico bajo (=0). Si la marca está a uno, se dirá que está a nivel lógico alto (=1)."@es ;
    ex:identificador "M1-M8192" ;
    ex:valor "0/1" .

ex:Mensaje_MSG1_MSG1024
    a ex:InterfazUsuario ;
    rdfs:label "Mensajes (MSG1-MSG1024)"@es ;
    ex:textoExtracto "Mensajes (MSG1-MSG1024). Al activarlas (=1) muestran un mensaje en la pantalla del CNC. Los textos asociados a los mensajes deben estar previamente definidos en la tabla de mensajes y errores del PLC."@es ;
    ex:identificador "MSG1-MSG1024" .

ex:Tabla_MensajesErrores_PLC a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de mensajes y errores del PLC"@es ;
    ex:textoExtracto "Los textos asociados a los mensajes deben estar previamente definidos en la tabla de mensajes y errores del PLC."@es .

ex:Error_ERR1_ERR1024
    a ex:AvisoSeguridad ;
    rdfs:label "Errores (ERR1-ERR1024)"@es ;
    ex:textoExtracto "Errores (ERR1-ERR1024). Al activarlas (=1) producen un error, muestran el mensaje de error e interrumpen la ejecución del CNC. Los errores del PLC pueden configurarse para que activen la señal de emergencia del PLC (_EMERGEN)."@es ;
    ex:identificador "ERR1-ERR1024" ;
    ex:activaAlarma ex:Senal_Emergencia_PLC .

ex:Senal_Emergencia_PLC
    a ex:Alarma ;
    rdfs:label "Señal de emergencia del PLC (_EMERGEN)"@es ;
    ex:textoExtracto "Los errores del PLC pueden configurarse para que activen la señal de emergencia del PLC (_EMERGEN)."@es ;
    ex:identificador "_EMERGEN" .

ex:Senal_Alarma_CNC
    a ex:Alarma ;
    rdfs:label "Señal de alarma del CNC (_ALARM)"@es ;
    ex:textoExtracto "Los errores no activan la alarma del CNC, señal (_ALARM)."@es ;
    ex:identificador "_ALARM" .

ex:Reloj_CLK
    a ex:Parametro ;
    rdfs:label "Relojes internos (CLK)"@es ;
    ex:textoExtracto "Relojes (CLK). Son relojes internos de diferentes periodos de tiempo que pueden ser utilizados en el programa de PLC."@es ;
    ex:identificador "CLK" .

ex:Mensaje_MSG1_MSG1024
    ex:documentadoEn ex:Tabla_MensajesErrores_PLC .

ex:Error_ERR1_ERR1024
    ex:documentadoEn ex:Tabla_MensajesErrores_PLC .