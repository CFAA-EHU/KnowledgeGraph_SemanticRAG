@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AplicarRTCPCompleto a ns1:Parametro ;
    rdfs:label "Aplicar RTCP completo" ;
    ns1:documentadoEn ns1:CNC8070_680e53b2d6 ;
    ns1:identificador "TDATA52" ;
    ns1:textoExtracto "Este parámetro establece si el CNC aplica el RTCP a toda la cinemática o sólo a la parte del cabezal." .

ns1:DefinicionVectorialDeCinematicasDeCabezalMesa_f26c8a54de a ns1:Parametro ;
    rdfs:label "Definición vectorial de cinemáticas de cabezal-mesa" ;
    ns1:documentadoEn ns1:CNC8070_680e53b2d6 ;
    ns1:identificador "TDATA51" ;
    ns1:textoExtracto "Al variar la orientación de la pieza, no se modifica la posición que ocupa la punta de la herramienta sobre la pieza. El sistema de coordenadas está fijo sobre la pieza y gira con ella." .

ns1:CNC8070_680e53b2d6 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Este parámetro establece si el CNC aplica el RTCP a toda la cinemática o sólo a la parte del cabezal." .

