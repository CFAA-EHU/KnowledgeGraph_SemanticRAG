    ex:textoExtracto "CLK32 | 32 ms | CLK3200 | 3.2 s | CLK32000 | 32 s | CLK64 | 64 ms | CLK6400 | 6.4 s | CLK64000 | 64 s | CLK128 | 128 ms | CLK12800 | 12.8 s | CLK128000 | 128 s" ;
    rdfs:label "Tabla de recursos temporales del PLC" .

