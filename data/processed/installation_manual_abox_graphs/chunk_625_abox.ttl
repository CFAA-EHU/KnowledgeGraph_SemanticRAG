@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SeñalCNCREADY a ex:Sensor ;
    rdfs:label "CNCREADY" ;
    ex:textoExtracto "Señales de consulta: CNCREADY, START, FHOUT, ..." ;
    ex:identificador "CNCREADY" .

ex:SeñalSTART a ex:Sensor ;
    rdfs:label "START" ;
    ex:textoExtracto "Señales de consulta: CNCREADY, START, FHOUT, ..." ;
    ex:identificador "START" .

ex:SeñalFHOUT a ex:Sensor ;
    rdfs:label "FHOUT" ;
    ex:textoExtracto "Señales de consulta: CNCREADY, START, FHOUT, ..." ;
    ex:identificador "FHOUT" .

ex:SeñalEMERGEN a ex:Actuador ;
    rdfs:label "_EMERGEN" ;
    ex:textoExtracto "Señales modificables: _EMERGEN, _STOP, _FEEDHOL, ..." ;
    ex:identificador "_EMERGEN" .

ex:SeñalSTOP a ex:Actuador ;
    rdfs:label "_STOP" ;
    ex:textoExtracto "Señales modificables: _EMERGEN, _STOP, _FEEDHOL, ..." ;
    ex:identificador "_STOP" .

ex:SeñalFEEDHOL a ex:Actuador ;
    rdfs:label "_FEEDHOL" ;
    ex:textoExtracto "Señales modificables: _EMERGEN, _STOP, _FEEDHOL, ..." ;
    ex:identificador "_FEEDHOL" .