@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ParametroNumeracionModulos a ex:Parametro ;
    rdfs:label "parámetros máquina" ;
    ex:textoExtracto "Desde los parámetros máquina se puede personalizar la numeración de los módulos de entradas y salidas." ;
    ex:valor "personalización de numeración de módulos de entradas y salidas" .

ex:ModuloEntradaSalida1 a ex:ComponenteElectrico ;
    rdfs:label "Módulo 1" ;
    ex:textoExtracto "Módulo 1. I1...I16 33 O33...O48" .

ex:ModuloEntradaSalida2 a ex:ComponenteElectrico ;
    rdfs:label "Módulo 2" ;
    ex:textoExtracto "Módulo 2. I33...I48 81 O81...O96" .

ex:ModuloEntradaSalida3 a ex:ComponenteElectrico ;
    rdfs:label "Módulo 3" ;
    ex:textoExtracto "Módulo 3. I97...I112 49 O49...O64" .

ex:ModuloEntradaSalida4 a ex:ComponenteElectrico ;
    rdfs:label "Módulo 4" ;
    ex:textoExtracto "Módulo 4. I113...I128 - - - - - -" .

ex:EsquemaNumeracionModulos a ex:Esquema ;
    ex:textoExtracto "Numeración según el orden de los grupos remotos (conmutador rotativo del elemento Power Supply). Dentro de cada grupo el orden es de arriba a abajo y de izquierda a derecha. | Grupo ꞏ1ꞏ | Grupo ꞏ2ꞏ Grup | o ꞏ3ꞏ | O1...O32 O33...O48 O49...O64 | I1...I48 I49...I64 I65...I96 | Numeración mediante parámetros máquina. Cuando se personaliza la numeración mediante los parámetros máquina, a cada módulo se le asigna un índice base a partir del cual se numeran las entradas o salidas de dicho módulo. Los valores del índice base deben ser múltiplos de 16, más 1 (es decir, 1, 17, 33...). Los índices base pueden seguir cualquier orden y además se permiten índices base salteados. Si se inserta un nuevo módulo, se asignará la numeración de la tabla a los primeros módulos y al último se le asignará el siguiente índice base válido al mayor asignado hasta el momento." ;
    ex:tieneComponente ex:ModuloEntradaSalida1, ex:ModuloEntradaSalida2, ex:ModuloEntradaSalida3, ex:ModuloEntradaSalida4 .