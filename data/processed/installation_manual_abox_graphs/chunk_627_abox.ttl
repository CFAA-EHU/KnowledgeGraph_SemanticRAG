@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Temporizador1 a ex:ComponenteElectrico ;
    rdfs:label "temporizador" ;
    ex:textoExtracto "Todos los temporizadores disponen de la salida de estado T y de las entradas TEN, TRS, TG1, TG2, TG3 y TG4." .

ex:EntradaEstadoT1 a ex:ComponenteElectrico ;
    rdfs:label "salida de estado T" ;
    ex:textoExtracto "Todos los temporizadores disponen de la salida de estado T" .

ex:EntradaEnable1 a ex:ComponenteElectrico ;
    rdfs:label "entrada TEN" ;
    ex:textoExtracto "Entrada de enable. Permite detener y reanudar la temporización. Se referencia mediante las letras TEN seguidas del número de temporizador, por ejemplo TEN 1, TEN 25, TEN 102, etc." ;
    ex:identificador "TEN 10" .

ex:EntradaReset1 a ex:ComponenteElectrico ;
    rdfs:label "entrada TRS" ;
    ex:textoExtracto "Entrada de reset. Permite inicializar el temporizador, asignando el valor 0 a su estado T y cancelando su cuenta (la inicializa a 0). Se referencia mediante las letras TRS seguidas del número de temporizador, por ejemplo TRS 1, TRS 25, TRS 102, etc." .

ex:EntradaTiempoTranscurrido1 a ex:ComponenteElectrico ;
    rdfs:label "tiempo t transcurrido" ;
    ex:textoExtracto "También es posible consultar en cualquier momento el tiempo t que lleva transcurrido desde que se activó el temporizador." .

ex:PLC1 a ex:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ex:textoExtracto "En el arranque del PLC se inicializan todos los temporizadores, asignando el valor 0 a su estado T y cancelando su cuenta (la inicializa a 0)." .