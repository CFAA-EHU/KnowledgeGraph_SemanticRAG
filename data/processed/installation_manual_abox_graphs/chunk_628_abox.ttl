@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Temporizador_T10 a ex:ComponenteElectrico ;
    ex:textoExtracto "el temporizador T10" ;
    ex:identificador "T10" .

ex:Entrada_I3 a ex:ComponenteElectrico ;
    ex:textoExtracto "la entrada I3" ;
    ex:identificador "I3" .

ex:Entrada_TG1 a ex:ComponenteElectrico ;
    ex:textoExtracto "TG1" ;
    ex:identificador "TG1" .

ex:Entrada_TG2 a ex:ComponenteElectrico ;
    ex:textoExtracto "TG2" ;
    ex:identificador "TG2" .

ex:Entrada_TG3 a ex:ComponenteElectrico ;
    ex:textoExtracto "TG3" ;
    ex:identificador "TG3" .

ex:Entrada_TG4 a ex:ComponenteElectrico ;
    ex:textoExtracto "TG4" ;
    ex:identificador "TG4" .

ex:ModoMonoestable a ex:ModoOperacion ;
    ex:textoExtracto "modo monoestable" .

ex:ModoRetardoConexion a ex:ModoOperacion ;
    ex:textoExtracto "modo retardo a la conexión" .

ex:ModoRetardoDesconexion a ex:ModoOperacion ;
    ex:textoExtracto "modo retardo a la desconexión" .

ex:ModoLimitadorSenal a ex:ModoOperacion ;
    ex:textoExtracto "modo limitador de señal" .

ex:Entrada_I3 ex:controla ex:Temporizador_T10 ;
    ex:textoExtracto "La entrada I3 controla la entrada de reset del temporizador T10" .

ex:Entrada_TG1 ex:controla ex:ModoMonoestable ;
    ex:textoExtracto "TG1 activa el modo monoestable" .

ex:Entrada_TG2 ex:controla ex:ModoRetardoConexion ;
    ex:textoExtracto "TG2 activa el modo retardo a la conexión" .

ex:Entrada_TG3 ex:controla ex:ModoRetardoDesconexion ;
    ex:textoExtracto "TG3 activa el modo retardo a la desconexión" .

ex:Entrada_TG4 ex:controla ex:ModoLimitadorSenal ;
    ex:textoExtracto "TG4 activa el modo limitador de señal" .