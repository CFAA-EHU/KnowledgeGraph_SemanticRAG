@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:T20 a ex:Sensor ;
    rdfs:label "T20" ;
    ex:textoExtracto "Activa el temporizador T20 en modo monoestable (TG1) con una constante de tiempo de 100 ms." .

ex:T22 a ex:Sensor ;
    rdfs:label "T22" ;
    ex:textoExtracto "Activa el temporizador T22 en modo de retardo a la conexión (TG2) con la constante de tiempo que fija el valor del registro R200, en ms." .

ex:R200 a ex:Parametro ;
    rdfs:label "R200" ;
    ex:textoExtracto "la constante de tiempo que fija el valor del registro R200, en ms." .

ex:T123 a ex:Sensor ;
    rdfs:label "T123" ;
    ex:textoExtracto "Indica el tiempo transcurrido en el temporizador desde que se activó el mismo. Se referencia mediante la letra T seguida del número de temporizador que se desea referenciar." .

ex:M100 a ex:Parametro ;
    rdfs:label "M100" ;
    ex:textoExtracto "Asigna a M100 el estado (0/1) de T123." ;
    ex:valor "0/1" .

ex:I2 a ex:Sensor ;
    rdfs:label "I2" ;
    ex:textoExtracto "I2 = MOV T123 R200" .

ex:T a ex:Sistema ;
    rdfs:label "T" ;
    ex:textoExtracto "Salida de estado. Indica el estado lógico del temporizador. Se referencia mediante la letra T seguida del número de temporizador que se desea referenciar, por ejemplo T1, T25, T102, etc." .