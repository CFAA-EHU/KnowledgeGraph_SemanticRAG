@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaCinematicaTipo50 a ns1:Tabla ;
    rdfs:label "Tablas para redefinir las cinemáticas de tipo 1..16 como vectoriales" ;
    ns1:ilustra ns1:CuartoDatoDeLaCinematica,
        ns1:DecimoCuartoDatoDeLaCinematica,
        ns1:DecimoNovenoDatoDeLaCinematica,
        ns1:DecimoOctavoDatoDeLaCinematica,
        ns1:DecimoPrimerDatoDeLaCinematica,
        ns1:DecimoQuintoDatoDeLaCinematica,
        ns1:DecimoSegundoDatoDeLaCinematica,
        ns1:DecimoSeptimoDatoDeLaCinematica,
        ns1:DecimoSextoDatoDeLaCinematica,
        ns1:DecimoTercerDatoDeLaCinematica,
        ns1:NovenoDatoDeLaCinematica,
        ns1:OctavoDatoDeLaCinematica,
        ns1:PrimerDatoDeLaCinematica,
        ns1:QuintoDatoDeLaCinematica,
        ns1:SegundoDatoDeLaCinematica,
        ns1:SeptimoDatoDeLaCinematica,
        ns1:SextoDatoDeLaCinematica,
        ns1:TercerDatoDeLaCinematica,
        ns1:TipoDeCinematica_be1d346f12,
        ns1:VigesimoCuartoDatoDeLaCinematica,
        ns1:VigesimoPrimerDatoDeLaCinematica,
        ns1:VigesimoQuintoDatoDeLaCinematica,
        ns1:VigesimoSegundoDatoDeLaCinematica,
        ns1:VigesimoSextoDatoDeLaCinematica,
        ns1:VigesimoTercerDatoDeLaCinematica ;
    ns1:textoExtracto "Parámetro de la cinemática vectorial (tipo 50). | Valor/parámetro equivalente en la cinemática tipo 7." .

ns1:CuartoDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Cuarto dato de la cinemática" ;
    ns1:identificador "TDATA4" ;
    ns1:textoExtracto "Parámetro TDATA4 con valor 0 para cinemática tipo 7." .

ns1:DecimoCuartoDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Décimo cuarto dato de la cinemática" ;
    ns1:identificador "TDATA14" ;
    ns1:textoExtracto "Parámetro TDATA14 con valor equivalente SIN(TDATA7) para cinemática tipo 7." .

ns1:DecimoNovenoDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Décimo noveno dato de la cinemática" ;
    ns1:identificador "TDATA19" ;
    ns1:textoExtracto "Parámetro TDATA19 con valor condicional basado en TDATA12 para cinemática tipo 7." .

ns1:DecimoOctavoDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Décimo octavo dato de la cinemática" ;
    ns1:identificador "TDATA18" ;
    ns1:textoExtracto "Parámetro TDATA18 con valor equivalente TDATA11 para cinemática tipo 7." .

ns1:DecimoPrimerDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Décimo primer dato de la cinemática" ;
    ns1:identificador "TDATA11" ;
    ns1:textoExtracto "Parámetro TDATA11 con valor equivalente TDATA5*SIN(TDATA7) para cinemática tipo 7." .

ns1:DecimoQuintoDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Décimo quinto dato de la cinemática" ;
    ns1:identificador "TDATA15" ;
    ns1:textoExtracto "Parámetro TDATA15 con valor 0 para cinemática tipo 7." .

ns1:DecimoSegundoDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Décimo segundo dato de la cinemática" ;
    ns1:identificador "TDATA12" ;
    ns1:textoExtracto "Parámetro TDATA12 con valor equivalente TDATA3 para cinemática tipo 7." .

ns1:DecimoSeptimoDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Décimo séptimo dato de la cinemática" ;
    ns1:identificador "TDATA17" ;
    ns1:textoExtracto "Parámetro TDATA17 con valor equivalente TDATA9 para cinemática tipo 7." .

ns1:DecimoSextoDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Décimo sexto dato de la cinemática" ;
    ns1:identificador "TDATA16" ;
    ns1:textoExtracto "Parámetro TDATA16 con valor equivalente COS(TDATA7) para cinemática tipo 7." .

ns1:DecimoTercerDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Décimo tercer dato de la cinemática" ;
    ns1:identificador "TDATA13" ;
    ns1:textoExtracto "Parámetro TDATA13 con valor equivalente TDATA5*COS(TDATA7) para cinemática tipo 7." .

ns1:NovenoDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Noveno dato de la cinemática" ;
    ns1:identificador "TDATA9" ;
    ns1:textoExtracto "Parámetro TDATA9 con valor condicional basado en TDATA12 para cinemática tipo 7." .

ns1:OctavoDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Octavo dato de la cinemática" ;
    ns1:identificador "TDATA8" ;
    ns1:textoExtracto "Parámetro TDATA8 con valor equivalente TDATA10 para cinemática tipo 7." .

ns1:PrimerDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Primer dato de la cinemática" ;
    ns1:identificador "TDATA1" ;
    ns1:textoExtracto "Parámetro TDATA1 con valor equivalente TDATA13 para cinemática tipo 7." .

ns1:QuintoDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Quinto dato de la cinemática" ;
    ns1:identificador "TDATA5" ;
    ns1:textoExtracto "Parámetro TDATA5 con valor 0 para cinemática tipo 7." .

ns1:SegundoDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Segundo dato de la cinemática" ;
    ns1:identificador "TDATA2" ;
    ns1:textoExtracto "Parámetro TDATA2 con valor equivalente TDATA14 para cinemática tipo 7." .

ns1:SeptimoDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Séptimo dato de la cinemática" ;
    ns1:identificador "TDATA7" ;
    ns1:textoExtracto "Parámetro TDATA7 con valor equivalente TDATA8 para cinemática tipo 7." .

ns1:SextoDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Sexto dato de la cinemática" ;
    ns1:identificador "TDATA6" ;
    ns1:textoExtracto "Parámetro TDATA6 con valor 1 para cinemática tipo 7." .

ns1:TercerDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Tercer dato de la cinemática" ;
    ns1:identificador "TDATA3" ;
    ns1:textoExtracto "Parámetro TDATA3 con valor equivalente TDATA4 para cinemática tipo 7." .

ns1:TipoDeCinematica_be1d346f12 a ns1:Parametro ;
    rdfs:label "Tipo de cinemática" ;
    ns1:identificador "TYPE" ;
    ns1:textoExtracto "Parámetro TYPE con valor 50 para cinemática vectorial (tipo 50)." ;
    ns1:valor "50" .

ns1:VigesimoCuartoDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Vigésimo cuarto dato de la cinemática" ;
    ns1:identificador "TDATA24" ;
    ns1:textoExtracto "Parámetro TDATA24 con valor 0 para cinemática tipo 7." .

ns1:VigesimoPrimerDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Vigésimo primer dato de la cinemática" ;
    ns1:identificador "TDATA21" ;
    ns1:textoExtracto "Parámetro TDATA21 con valor 0 para cinemática tipo 7." .

ns1:VigesimoQuintoDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Vigésimo quinto dato de la cinemática" ;
    ns1:identificador "TDATA25" ;
    ns1:textoExtracto "Parámetro TDATA25 con valor 0 para cinemática tipo 7." .

ns1:VigesimoSegundoDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Vigésimo segundo dato de la cinemática" ;
    ns1:identificador "TDATA22" ;
    ns1:textoExtracto "Parámetro TDATA22 con valor equivalente TDATA6 para cinemática tipo 7." .

ns1:VigesimoSextoDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Vigésimo sexto dato de la cinemática" ;
    ns1:identificador "TDATA26" ;
    ns1:textoExtracto "Parámetro TDATA26 con valor 1 para cinemática tipo 7." .

ns1:VigesimoTercerDatoDeLaCinematica a ns1:Parametro ;
    rdfs:label "Vigésimo tercer dato de la cinemática" ;
    ns1:identificador "TDATA23" ;
    ns1:textoExtracto "Parámetro TDATA23 con valor equivalente TDATA1 para cinemática tipo 7." .

