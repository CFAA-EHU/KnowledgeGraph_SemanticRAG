@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoRetardoConexionTG2 a ex:ModoOperacion ;
    rdfs:label "Modo retardo a la conexión. Entrada TG2" ;
    ex:textoExtracto "Este modo de funcionamiento permite realizar un retardo entre la activación de la entrada de arranque TG2 y la activación de la salida de estado T del temporizador." .

ex:EntradaTG2 a ex:ComponenteElectrico ;
    rdfs:label "Entrada TG2" ;
    ex:textoExtracto "activación de la entrada de arranque TG2" .

ex:SalidaEstadoT a ex:ComponenteElectrico ;
    rdfs:label "Salida de estado T" ;
    ex:textoExtracto "activación de la salida de estado T del temporizador" .

ex:Temporizador a ex:ComponenteElectrico ;
    rdfs:label "Temporizador" ;
    ex:textoExtracto "el temporizador se activa al producirse un flanco de subida en la entrada TG2" .

ex:ConstanteTiempo a ex:Parametro ;
    rdfs:label "Constante de tiempo" ;
    ex:textoExtracto "La duración del retardo la fija la constante de tiempo." .

ex:EntradaTRS a ex:ComponenteElectrico ;
    rdfs:label "Entrada TRS" ;
    ex:textoExtracto "Funcionamiento de la entrada TRS en este modo. Si se produce un flanco de subida en la entrada TRS" .

ex:EntradaTEN a ex:ComponenteElectrico ;
    rdfs:label "Entrada TEN" ;
    ex:textoExtracto "Funcionamiento de la entrada TEN en este modo. Si una vez activado el temporizador se selecciona TEN=0" .

ex:PLC a ex:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ex:textoExtracto "el PLC da por finalizada la temporización", "el PLC inicializa el temporizador", "el PLC detiene la temporización" .