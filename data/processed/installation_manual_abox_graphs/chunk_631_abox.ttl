@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CondicionParaTDATA19 a ns1:Parametro ;
    rdfs:label "Condición para TDATA19" ;
    ns1:identificador "TDATA19" ;
    ns1:textoExtracto """0, si TDATA12=0 o TDATA12=1
1, si TDATA12=2 o TDATA12=3.""" .

ns1:ValorDeTDATA11 a ns1:Parametro ;
    rdfs:label "Valor de TDATA11" ;
    ns1:identificador "TDATA11" ;
    ns1:textoExtracto "TDATA11 | TDATA2" .

ns1:ValorDeTDATA12 a ns1:Parametro ;
    rdfs:label "Valor de TDATA12" ;
    ns1:identificador "TDATA12" ;
    ns1:textoExtracto "TDATA12 | TDATA6*SIN(TDATA7)" .

ns1:ValorDeTDATA13 a ns1:Parametro ;
    rdfs:label "Valor de TDATA13" ;
    ns1:identificador "TDATA13" ;
    ns1:textoExtracto "TDATA13 | TDATA6*COS(TDATA7)" .

