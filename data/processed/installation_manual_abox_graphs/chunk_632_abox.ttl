@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoRetardoDesconexion_TG3
    a                     ex:ModoOperacion ;
    rdfs:label            "Modo retardo a la desconexión (entrada TG3)"@es ;
    ex:textoExtracto       "Este modo de funcionamiento permite realizar un retardo entre la desactivación de la entrada de arranque TG3 y la desactivación de la salida T del temporizador. La duración del retardo, está determinada por la constante de tiempo."@es ;
    ex:tieneComponente     ex:Entrada_TG3, ex:Salida_T, ex:Parametro_TEN, ex:Parametro_TRS, ex:Parametro_ConstanteTiempo ;
    ex:monitoreaParametro  ex:Parametro_T .

ex:Entrada_TG3
    a               ex:InterfazUsuario ;
    rdfs:label      "Entrada TG3"@es ;
    ex:textoExtracto "entrada de arranque TG3 [...] flanco de subida en la entrada TG3 [...] flanco de bajada de la entrada TG3"@es .

ex:Salida_T
    a               ex:InterfazUsuario ;
    rdfs:label      "Salida T (estado del temporizador)"@es ;
    ex:textoExtracto "salida T del temporizador [...] salida de estado del temporizador toma el valor T=1 [...] desactivándose la salida de estado del temporizador (T=0)"@es .

ex:Parametro_TEN
    a               ex:Parametro ;
    rdfs:label      "Parámetro TEN"@es ;
    ex:identificador "TEN" ;
    ex:textoExtracto "Con TEN=1 y TRS=0, el temporizador se activa [...] Si una vez activado el temporizador se selecciona TEN=0, el PLC detiene la temporización, siendo necesario asignar TEN=1 para que dicha temporización continúe."@es ;
    ex:valor         "0"@es, "1"@es .

ex:Parametro_TRS
    a               ex:Parametro ;
    rdfs:label      "Parámetro TRS"@es ;
    ex:identificador "TRS" ;
    ex:textoExtracto "Con TEN=1 y TRS=0 [...] Si se produce un flanco de subida en la entrada TRS, durante la temporización o después de ella, el PLC inicializa el temporizador"@es ;
    ex:valor         "0"@es .

ex:Parametro_ConstanteTiempo
    a               ex:Parametro ;
    rdfs:label      "Constante de tiempo"@es ;
    ex:textoExtracto "La duración del retardo, está determinada por la constante de tiempo [...] tiempo especificado mediante la constante de tiempo"@es .

ex:Parametro_T
    a               ex:Parametro ;
    rdfs:label      "Estado del temporizador (T)"@es ;
    ex:identificador "T" ;
    ex:textoExtracto "salida de estado del temporizador toma el valor T=1 [...] desactivándose la salida de estado del temporizador (T=0)"@es ;
    ex:valor         "0"@es, "1"@es .