@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoRetardoDesconexionTemporizador a ex:ModoOperacion ;
    rdfs:label "Modo retardo a la desconexión"@es ;
    ex:textoExtracto "Este modo de funcionamiento permite realizar un retardo entre la desactivación de la entrada de arranque TG3 y la desactivación de la salida T del temporizador."@es .

ex:EntradaTG3 a ex:ComponenteElectrico ;
    rdfs:label "Entrada TG3"@es ;
    ex:textoExtracto "entrada de arranque TG3"@es .

ex:SalidaT a ex:ComponenteElectrico ;
    rdfs:label "Salida T"@es ;
    ex:textoExtracto "salida T del temporizador"@es .

ex:Temporizador a ex:ComponenteElectrico ;
    rdfs:label "Temporizador"@es ;
    ex:textoExtracto "temporizador"@es .

ex:EntradaTRS a ex:ComponenteElectrico ;
    rdfs:label "Entrada TRS"@es ;
    ex:textoExtracto "entrada TRS"@es .

ex:EntradaTEN a ex:ComponenteElectrico ;
    rdfs:label "Entrada TEN"@es ;
    ex:textoExtracto "entrada TEN"@es .

ex:ConstanteTiempo a ex:Parametro ;
    rdfs:label "Constante de tiempo"@es ;
    ex:textoExtracto "duración del retardo, está determinada por la constante de tiempo"@es .

ex:PLC a ex:Sistema ;
    rdfs:label "PLC"@es ;
    ex:textoExtracto "el PLC"@es .

ex:ModoRetardoDesconexionTemporizador ex:controla ex:Temporizador ;
    ex:textoExtracto "Este modo de funcionamiento permite realizar un retardo entre la desactivación de la entrada de arranque TG3 y la desactivación de la salida T del temporizador."@es .

ex:Temporizador ex:monitoreaParametro ex:ConstanteTiempo ;
    ex:textoExtracto "la duración del retardo, está determinada por la constante de tiempo"@es .

ex:EntradaTG3 ex:alimenta ex:Temporizador ;
    ex:textoExtracto "entrada de arranque TG3"@es .

ex:SalidaT ex:controla ex:Temporizador ;
    ex:textoExtracto "salida T del temporizador"@es .

ex:PLC ex:controla ex:Temporizador ;
    ex:textoExtracto "el PLC"@es .