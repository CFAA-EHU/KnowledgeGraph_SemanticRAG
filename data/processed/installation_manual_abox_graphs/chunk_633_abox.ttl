@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ModoLimitadorSenal a ex:ModoOperacion ;
    ex:textoExtracto "En este modo de funcionamiento el estado del temporizador se mantiene a nivel lógico alto (T=1) desde que se activa la entrada TG4 hasta que transcurra el tiempo indicado mediante la constante de tiempo, o hasta que se produzca un flanco de bajada en la entrada TG4." ;
    ex:tieneComponente ex:EntradaTG4, ex:Temporizador .

ex:EntradaTG4 a ex:Sensor ;
    ex:textoExtracto "entrada TG4" .

ex:Temporizador a ex:ComponenteElectrico ;
    ex:textoExtracto "el temporizador se activa al producirse un flanco de subida en la entrada TG4. En este momento la salida de estado del temporizador (T) cambia de estado (T=1) y comienza la temporización t a partir del valor 0." ;
    ex:tieneComponente ex:SalidaEstadoTemporizador .

ex:SalidaEstadoTemporizador a ex:ComponenteElectrico ;
    ex:textoExtracto "salida de estado del temporizador (T)" .

ex:EntradaTRS a ex:Sensor ;
    ex:textoExtracto "entrada TRS" .

ex:EntradaTEN a ex:Sensor ;
    ex:textoExtracto "entrada TEN" .