@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ContadorC10 a ex:ComponenteElectrico ;
    ex:textoExtracto "I2 = CUP 10 Cada vez que se produce un flanco de subida en I2 se incrementa la cuenta del contador C10." ;
    rdfs:label "C10" .

ex:ContadorC20 a ex:ComponenteElectrico ;
    ex:textoExtracto "I3 = CDW 20 Cada vez que se produce un flanco de subida en I3 se decrementa la cuenta del contador C20." ;
    rdfs:label "C20" .

ex:EntradaCUP a ex:ComponenteElectrico ;
    ex:textoExtracto "Todos los contadores disponen de la salida estado C y de las entradas CUP, CDW, CEN y CPR." ;
    rdfs:label "CUP" .

ex:EntradaCDW a ex:ComponenteElectrico ;
    ex:textoExtracto "Todos los contadores disponen de la salida estado C y de las entradas CUP, CDW, CEN y CPR." ;
    rdfs:label "CDW" .

ex:EntradaCEN a ex:ComponenteElectrico ;
    ex:textoExtracto "Todos los contadores disponen de la salida estado C y de las entradas CUP, CDW, CEN y CPR." ;
    rdfs:label "CEN" .

ex:EntradaCPR a ex:ComponenteElectrico ;
    ex:textoExtracto "Todos los contadores disponen de la salida estado C y de las entradas CUP, CDW, CEN y CPR." ;
    rdfs:label "CPR" .

ex:CuentaInterna a ex:Parametro ;
    ex:textoExtracto "También es posible consultar en cualquier momento el valor de su cuenta interna. La cuenta de un contador se almacena en una variable de 32 bits, por lo que su valor puede estar comprendido entre ±2147483647." ;
    ex:valor "±2147483647" .