@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Contador_Generico
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Contador (genérico)"@es ;
    ex:textoExtracto      "Todos los contadores disponen de la salida estado C y de las entradas CUP, CDW, CEN y CPR. También es posible consultar en cualquier momento el valor de su cuenta interna. La cuenta de un contador se almacena en una variable de 32 bits, por lo que su valor puede estar comprendido entre ±2147483647."@es ;
    ex:tieneComponente    ex:Entrada_CUP, ex:Entrada_CDW, ex:Entrada_CEN, ex:Entrada_CPR, ex:Salida_Estado_C ;
    ex:monitoreaParametro ex:Parametro_CuentaInterna .

ex:Parametro_CuentaInterna
    a               ex:Parametro ;
    rdfs:label      "Cuenta interna del contador"@es ;
    ex:textoExtracto "La cuenta de un contador se almacena en una variable de 32 bits, por lo que su valor puede estar comprendido entre ±2147483647."@es ;
    ex:valor         "±2147483647" .

ex:Entrada_CUP
    a               ex:ComponenteElectrico ;
    rdfs:label      "Entrada CUP (contaje)"@es ;
    ex:textoExtracto "(CUP) Entrada de contaje. Cada vez que se produce un flanco de subida en esta entrada la cuenta interna del contador se incrementa en una unidad. Se referencia mediante las letras CUP seguidas del número de contador que se desea referenciar, por ejemplo CUP 1, CUP 25, CUP 102, etc."@es ;
    ex:identificador "CUP" .

ex:Entrada_CDW
    a               ex:ComponenteElectrico ;
    rdfs:label      "Entrada CDW (descontaje)"@es ;
    ex:textoExtracto "(CDW) Entrada de descontaje. Cada vez que se produce un flanco de subida en esta entrada la cuenta interna del contador se decrementa en una unidad. Se referencia mediante las letras CDW seguidas del número de contador que se desea referenciar, por ejemplo CDW 1, CDW 25, CDW 102, etc."@es ;
    ex:identificador "CDW" .

ex:Entrada_CEN
    a               ex:ComponenteElectrico ;
    rdfs:label      "Entrada CEN (enable)"@es ;
    ex:textoExtracto "(CEN) Entrada de enable. Permite detener la cuenta interna del contador. [...] Con CEN a (=0) se detiene la cuenta del contador y no se hace caso a las entradas CUP y CDW."@es ;
    ex:identificador "CEN" .

ex:Entrada_CPR
    a               ex:ComponenteElectrico ;
    rdfs:label      "Entrada CPR (preselección)"@es ;
    ex:textoExtracto "(CPR) Entrada de preselección. Permite preseleccionar el contador con el valor deseado. Se referencia mediante las letras CPR seguidas del número de contador y del valor que se desea asignar a su cuenta."@es ;
    ex:identificador "CPR" .

ex:Salida_Estado_C
    a               ex:ComponenteElectrico ;
    rdfs:label      "Salida estado C"@es ;
    ex:textoExtracto "Todos los contadores disponen de la salida estado C [...]."@es ;
    ex:identificador "C" .

ex:Ejemplo_CUP_10
    a               ex:ComponenteElectrico ;
    rdfs:label      "Entrada I2 asignada a CUP 10"@es ;
    ex:textoExtracto "I2 = CUP 10. Cada vez que se produce un flanco de subida en I2 se incrementa la cuenta del contador C10."@es ;
    ex:identificador "CUP 10" .

ex:Ejemplo_CDW_20
    a               ex:ComponenteElectrico ;
    rdfs:label      "Entrada I3 asignada a CDW 20"@es ;
    ex:textoExtracto "I3 = CDW 20. Cada vez que se produce un flanco de subida en I3 se decrementa la cuenta del contador C20."@es ;
    ex:identificador "CDW 20" .