@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:CPR_20_100 a ex:ModoOperacion ;
    ex:textoExtracto "Preselecciona el contador C20 con el valor 100." .

ex:CPR_22_R200 a ex:ModoOperacion ;
    ex:textoExtracto "Preselecciona el contador C22 con el valor del registro R200." .

ex:C20 a ex:Parametro ;
    ex:identificador "C20" ;
    ex:textoExtracto "Preselecciona el contador C20 con el valor 100." .

ex:C22 a ex:Parametro ;
    ex:identificador "C22" ;
    ex:textoExtracto "Preselecciona el contador C22 con el valor del registro R200." .

ex:C1 a ex:Parametro ;
    ex:identificador "C1" ;
    ex:textoExtracto "Se referencia mediante la letra C seguida del número de contador que se desea referenciar, por ejemplo C1, C25, C102, etc." .

ex:C25 a ex:Parametro ;
    ex:identificador "C25" ;
    ex:textoExtracto "Se referencia mediante la letra C seguida del número de contador que se desea referenciar, por ejemplo C1, C25, C102, etc." .

ex:C102 a ex:Parametro ;
    ex:identificador "C102" ;
    ex:textoExtracto "Se referencia mediante la letra C seguida del número de contador que se desea referenciar, por ejemplo C1, C25, C102, etc." .

ex:C123 a ex:Parametro ;
    ex:identificador "C123" ;
    ex:textoExtracto "Se referencia mediante la letra C seguida del número de contador que se desea referenciar, por ejemplo C1, C25, C102, etc. Su representación C123 coincide con la salida de estado pero se utilizan en instrucciones de tipo distinto." .

ex:M100 a ex:Parametro ;
    ex:identificador "M100" ;
    ex:textoExtracto "C123 = M100 Asigna a M100 el estado (0/1) de C123" .

ex:R200 a ex:Parametro ;
    ex:identificador "R200" ;
    ex:textoExtracto "Preselecciona el contador C22 con el valor del registro R200." .

ex:I2 a ex:Parametro ;
    ex:identificador "I2" ;
    ex:textoExtracto "I2 = MOV C123 R200" .

ex:Contador_C123 a ex:Componente ;
    ex:identificador "C123" ;
    ex:textoExtracto "El PLC dispone de una variable de 32 bits para almacenar la cuenta de cada contador." .