@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaCinematicas a ns1:Tabla ;
    rdfs:label "Tablas para redefinir las cinemáticas de tipo 1..16 como vectoriales" ;
    ns1:ilustra ns1:Parametro_095018bba2,
        ns1:Parametro_18fd6aee46,
        ns1:Parametro_2f1f6298af,
        ns1:Parametro_5e48f2bc45,
        ns1:Parametro_789ce7c0bf,
        ns1:Parametro_7d920d709a,
        ns1:Parametro_82af31c50b,
        ns1:Parametro_a8b7505f40,
        ns1:Parametro_aac45d6ee7 ;
    ns1:textoExtracto "Adaptar una cinemática tipo 16 a una cinemática tipo 52." .

ns1:Parametro_095018bba2 a ns1:Parametro ;
    rdfs:label "Parámetro de la cinemática vectorial (tipo 52)" ;
    ns1:identificador "TDATA31" ;
    ns1:textoExtracto "TDATA31 | 0" ;
    ns1:valor "0" .

