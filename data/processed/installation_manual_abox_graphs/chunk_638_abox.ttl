@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:PRG a ex:Esquema ;
    ex:textoExtracto "PRG ; Proposición directiva" ;
    ex:tieneComponente ex:I100_M102, ex:I28_AND_I30_O25, ex:I32_AND_I36_M300, ex:END_ProposicionDirectiva .

ex:I100_M102 a ex:Parametro ;
    ex:textoExtracto "I100 = M102 ; Proposición ejecutable" .

ex:I28_AND_I30_O25 a ex:Parametro ;
    ex:textoExtracto "I28 AND I30 = O25 ; Expresión lógica" .

ex:I32_AND_I36_M300 a ex:Parametro ;
    ex:textoExtracto "I32 AND I36 = M300 ; Instrucción de acción" .

ex:END_ProposicionDirectiva a ex:Parametro ;
    ex:textoExtracto "END ; Proposición directiva" .