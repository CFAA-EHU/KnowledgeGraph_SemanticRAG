@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Modulo_CY1
    a               ex:Sistema ;
    rdfs:label      "Módulo CY1" ;
    ex:textoExtracto "CY1 ; Comienzo del módulo CY1 [...] END ; Final del módulo CY1"@es ;
    ex:identificador "CY1" .

ex:Modulo_PRG
    a               ex:Sistema ;
    rdfs:label      "Módulo PRG" ;
    ex:textoExtracto "PRG ; Comienzo del módulo PRG [...] END ; Final del módulo PRG"@es ;
    ex:identificador "PRG" .

ex:Parametro_ValoresReales
    a               ex:Parametro ;
    rdfs:label      "Valor real (REA)" ;
    ex:textoExtracto "REA [...] Valor real es el que dispone el recurso en ese momento"@es ;
    ex:identificador "REA" .

ex:Parametro_ValoresImagen
    a               ex:Parametro ;
    rdfs:label      "Valor imagen (IMA)" ;
    ex:textoExtracto "IMA [...] valor imagen el que disponía cuando se finalizó el ciclo anterior"@es ;
    ex:identificador "IMA" .

ex:Parametro_Recurso_I3
    a               ex:Parametro ;
    rdfs:label      "Recurso I3" ;
    ex:textoExtracto "IMA I3 AND REA M4 = 02"@es ;
    ex:identificador "I3" .

ex:Parametro_Recurso_M4
    a               ex:Parametro ;
    rdfs:label      "Recurso M4" ;
    ex:textoExtracto "IMA I3 AND REA M4 = 02"@es ;
    ex:identificador "M4" .

ex:Parametro_Recurso_O32
    a               ex:Parametro ;
    rdfs:label      "Recurso O32" ;
    ex:textoExtracto "Las instrucciones de acción (=O32) siempre actualizan los valores reales de los recursos del PLC"@es ;
    ex:identificador "O32" .

ex:Tabla_EjemploValoresREA_IMA a ex:Tabla ;
     a               ex:Tabla ;
    rdfs:label      "Ejemplo de valores reales (REA) e imagen (IMA) en PLC" ;
    ex:textoExtracto "El siguiente ejemplo muestra cómo actúa el PLC trabajando con valores reales y con valores imagen. Para el programa de PLC dado y con los recursos inicializados a cero, se muestra el estado de estos recursos al final de cada scan o ciclo."@es .