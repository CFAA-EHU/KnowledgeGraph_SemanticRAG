@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivacionDeTransformacionesAngulares a ns1:Parametro ;
    rdfs:label "Activación de Transformaciones Angulares" ;
    ns1:identificador "ANGAX ON" ;
    ns1:textoExtracto "la activación de las transformaciones angulares se realiza desde el programa pieza mediante la sentencia #ANGAX ON." .

ns1:BusquedaDeReferenciaMaquinaConTransformacionAngularActiva a ns1:AccionProhibida ;
    rdfs:label "Búsqueda de Referencia Máquina con Transformación Angular Activa" ;
    ns1:textoExtracto "Con la transformación angular activa no se permite la búsqueda de referencia máquina." .

ns1:CNC8070_bc964dfc8f a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:ConfiguracionDeTransformacionesAngulares ;
    ns1:textoExtracto "El CNC no asume ninguna transformación tras el encendido; la activación de las transformaciones angulares se realiza desde el programa pieza mediante la sentencia #ANGAX ON." .

ns1:EjeXAngular a ns1:ComponenteMecanico ;
    rdfs:label "Eje X Angular" ;
    ns1:textoExtracto "Un caso típico es el eje X de torno que por motivos de robustez no forma 90º con el eje Z, sino que tiene otro valor." .

ns1:EjeZ a ns1:ComponenteMecanico ;
    rdfs:label "Eje Z" ;
    ns1:textoExtracto "Un caso típico es el eje X de torno que por motivos de robustez no forma 90º con el eje Z, sino que tiene otro valor." .

ns1:SistemaCoordenadasCartesiano a ns1:Sistema ;
    rdfs:label "Sistema Cartesiano (Z-X)" ;
    ns1:textoExtracto "Para poder programar en el sistema cartesiano (Z-X), hay que activar una transformación angular de eje inclinado." .

ns1:SistemaCoordenadasNoCartesiano a ns1:Sistema ;
    rdfs:label "Sistema No Cartesiano (Z-X')" ;
    ns1:textoExtracto "se pasa a hacer movimientos a lo largo del eje Z y del eje angular X'." .

ns1:ConfiguracionDeTransformacionesAngulares a ns1:TareaMantenimiento ;
    rdfs:label "Configuración de Transformaciones Angulares" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "Se pueden personalizar hasta 14 transformaciones angulares distintas en una misma máquina." .

