@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:M1 a ex:Parametro ;
    ex:textoExtracto "M1" .

ex:M2 a ex:Parametro ;
    ex:textoExtracto "M2" .

ex:O5 a ex:Sensor ;
    ex:textoExtracto "salida O5" .

ex:REA a ex:ModoOperacion ;
    ex:textoExtracto "valores reales (REA)" .

ex:IMA a ex:ModoOperacion ;
    ex:textoExtracto "valores imagen (IMA)" .

ex:L a ex:InterfazUsuario ;
    ex:textoExtracto "L Etiqueta. Sirve para identificar una línea de programa. Se puede definir de 2 formas: • Con L seguido de hasta 7 cifras (L1 - L9999999). • Con L_ seguido de hasta 8 caracteres (L_GEAR)." .

ex:CY1 a ex:ModoOperacion ;
    ex:textoExtracto "CY1" .

ex:PRG a ex:ModoOperacion ;
    ex:textoExtracto "PRG" .

ex:PE a ex:ModoOperacion ;
    ex:textoExtracto "PE" .

ex:END a ex:Directiva ;
    ex:textoExtracto "directiva END" .

ex:SUB a ex:Directiva ;
    ex:textoExtracto "SUB Definición de subrutina. Indica el comienzo de una subrutina. Se denomina subrutina a una parte de programa que puede ser llamada desde cualquier proposición ejecutable. Se define con SUB seguido de un espacio y hasta 24 caracteres. Una subrutina debe finalizar siempre con la directiva END." .

ex:A22 a ex:InterfazUsuario ;
    ex:textoExtracto "SUB A22 END" .

ex:EXTERN a ex:Directiva ;
    ex:textoExtracto "EXTERN Definición de subrutina externa. Las subrutinas definidas en el fichero de lenguaje C que utiliza el programa deben estar definidas como externas al principio del programa, antes que la directiva DEF y los módulos CY1, PRE y PEt." .

ex:DEF a ex:Directiva ;
    ex:textoExtracto "directiva DEF" .