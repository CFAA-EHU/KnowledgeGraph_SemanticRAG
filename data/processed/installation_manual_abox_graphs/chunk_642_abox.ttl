@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_bc964dfc8f a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC no asume ninguna transformación tras el encendido; la activación de las transformaciones angulares se realiza desde el programa pieza mediante la sentencia #ANGAX ON." .

ns1:ConfiguracionDeLasTransformacionesAngulares a ns1:TareaMantenimiento ;
    rdfs:label "Configuración de las transformaciones angulares" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "Se pueden personalizar hasta 14 transformaciones angulares distintas en una misma máquina. El CNC no asume ninguna transformación tras el encendido; la activación de las transformaciones angulares se realiza desde el programa pieza mediante la sentencia #ANGAX ON." .

ns1:NumeroDeTransformacionesAngularesDefinidas a ns1:Parametro ;
    rdfs:label "Número de transformaciones angulares definidas" ;
    ns1:identificador "MPK.NANG" ;
    ns1:textoExtracto "NANG Número de transformaciones angulares definidas. Valores posibles: De 0 a 14. Valor por defecto: 0." .

ns1:TablaTransformacionesAngulares a ns1:Tabla ;
    rdfs:label "Tabla de transformaciones angulares" ;
    ns1:textoExtracto "ANGTR Tabla de transformaciones angulares. Muestra las tablas de configuración de las transformaciones angulares." .

