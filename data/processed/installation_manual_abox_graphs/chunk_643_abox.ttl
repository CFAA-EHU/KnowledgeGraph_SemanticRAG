@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Directiva_EXTERN
    a ex:Directiva ;
    rdfs:label "Directiva EXTERN" ;
    ex:textoExtracto "La directiva EXTERN permite definir dichas subrutinas una a una. Se define con EXTERN seguido de un espacio y del nombre de la subrutina, hasta 24 caracteres." ;
    ex:identificador "EXTERN" .

ex:Directiva_DEF
    a ex:Directiva ;
    rdfs:label "Directiva DEF" ;
    ex:textoExtracto "DEF, PDEF Definición de símbolos. [...] La directiva DEF permite definir un número ilimitado de símbolos para usar solamente desde el PLC." ;
    ex:identificador "DEF" .

ex:Directiva_PDEF
    a ex:Directiva ;
    rdfs:label "Directiva PDEF" ;
    ex:textoExtracto "PDEF La directiva PDEF permite definir hasta 200 símbolos que se podrán usar en el propio PLC, en un programa pieza o una aplicación externa." ;
    ex:identificador "PDEF" .

ex:Sistema_PLC
    a ex:Sistema ;
    rdfs:label "Sistema PLC" ;
    ex:textoExtracto "El PLC permite definir una serie de símbolos para facilitar la programación y posterior comprensión del programa de PLC." ;
    ex:cumpleNormativa ex:Directiva_DEF ;
    ex:cumpleNormativa ex:Directiva_PDEF ;
    ex:cumpleNormativa ex:Directiva_EXTERN .

ex:AvisoSeguridad_WarningSimbolos
    a ex:AvisoSeguridad ;
    rdfs:label "Warning de símbolos excedidos" ;
    ex:textoExtracto "Los símbolos que superen este límite [200] serán ignorados y el CNC mostrará el warning correspondiente." ;
    ex:mitigaRiesgo ex:Sistema_PLC .