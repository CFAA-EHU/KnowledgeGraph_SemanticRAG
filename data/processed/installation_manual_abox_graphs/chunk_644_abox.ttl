@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_7b6a8cfb67 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:TablaCinematicasParalelas ;
    ns1:textoExtracto "El CNC no asume ninguna cinemática tras el encendido; la activación de la cinemática se realiza desde el programa pieza mediante la sentencia #PARALAX." .

ns1:EjeAditivoParalelo a ns1:Parametro ;
    rdfs:label "Eje aditivo paralelo" ;
    ns1:identificador "ADDAX" ;
    ns1:textoExtracto "ADDAX Eje aditivo paralelo." .

ns1:EjePrincipalDeLaTransformacion a ns1:Parametro ;
    rdfs:label "Eje principal de la transformación" ;
    ns1:identificador "PARALAX" ;
    ns1:textoExtracto "PARALAX Eje principal de la transformación." .

ns1:NumeroDeCinematicasDeEjesParalelos a ns1:Parametro ;
    rdfs:label "Número de cinemáticas de ejes paralelos" ;
    ns1:identificador "MPK.NPARAL" ;
    ns1:textoExtracto "NPARAL Número de cinemáticas de ejes paralelos. Valores posibles: De 0 a 6. Valor por defecto: 0." .

ns1:TablaCinematicasParalelas a ns1:Tabla ;
    rdfs:label "Tabla de cinemáticas de ejes paralelos" ;
    ns1:textoExtracto "PARALLEL n Tabla de cinemáticas de ejes paralelos. Muestra las tablas de configuración de las cinemáticas de ejes paralelos." .

