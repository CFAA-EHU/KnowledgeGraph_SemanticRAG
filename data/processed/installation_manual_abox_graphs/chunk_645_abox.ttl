@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DistanciaEntreLosCeroMaquinaDeAmbosEjes a ns1:Parametro ;
    rdfs:label "Distancia entre los cero máquina de ambos ejes" ;
    ns1:identificador "ADDORG" ;
    ns1:textoExtracto "ADDORG Distancia entre los cero máquina de ambos ejes." .

ns1:EjeAditivoParalelo a ns1:Parametro ;
    rdfs:label "Eje aditivo paralelo" ;
    ns1:identificador "ADDAX" ;
    ns1:textoExtracto "ADDAX Eje aditivo paralelo. Valores posibles: Cualquier eje definido en el parámetro AXISNAME." .

ns1:EjePrincipalDeLaTransformacion a ns1:Parametro ;
    rdfs:label "Eje principal de la transformación" ;
    ns1:identificador "PARALAX" ;
    ns1:textoExtracto "PARALAX Eje principal de la transformación. Valores posibles: Cualquier eje definido en el parámetro AXISNAME." .

