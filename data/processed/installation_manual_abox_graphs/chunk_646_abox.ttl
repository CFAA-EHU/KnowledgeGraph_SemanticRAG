@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Directiva_646_1 a ex:Directiva ;
    ex:textoExtracto "Programarla siempre al principio del programa, antes que la directiva DEF y los módulos CY1, PRG y PEt." ;
    rdfs:label "Programar al principio del programa" .

ex:Directiva_646_2 a ex:Directiva ;
    ex:textoExtracto "Se aconseja utilizar esta directiva cuando el tiempo de ejecución del programa de PLC es muy crítico." ;
    rdfs:label "Directiva para tiempo de ejecución crítico" .

ex:Directiva_646_3 a ex:Directiva ;
    ex:textoExtracto "Definirla tras depurar el programa de PLC." ;
    rdfs:label "Definir tras depuración" .