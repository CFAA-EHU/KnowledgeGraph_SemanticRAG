@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CinematicaActivaEnModoVisualizacionElCNCActualizaLaCotaDelEjeMaestroC_4606c4e76a a ns1:Parametro ;
    rdfs:label "Cinemática activa en modo visualización. El CNC actualiza la cota del eje maestro con el desplazamiento realizado por eje aditivo, de manera que el eje maestro siempre muestra la distancia de la herramienta a la pieza." ;
    ns1:identificador "PARALAX VIS" ;
    ns1:textoExtracto "PARALAX VIS. | Cinemática activa enmodo visualización. El CNC actualiza la cota del eje maestro con el desplazamiento realizado por eje aditivo, de manera que el eje maestro siempre muestra la distancia de la herramienta a la pieza." .

ns1:CinematicaDesactivada a ns1:Parametro ;
    rdfs:label "Cinemática desactivada" ;
    ns1:identificador "PARALAX OFF" ;
    ns1:textoExtracto "PARALAX OFF | Cinemática desactivada." .

