@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeAlmacenesDelSistema a ns1:Parametro ;
    rdfs:label "Número de almacenes del sistema" ;
    ns1:documentadoEn ns1:SistemaAlmacenamiento ;
    ns1:identificador "TM.NTOOLMZ" ;
    ns1:textoExtracto "NTOOLMZ Número de almacenes. Valores posibles: De 0 a 4. Valor por defecto: 1." .

ns1:PermiteHerramientasDeTierraCargaManual a ns1:Parametro ;
    rdfs:label "Permite herramientas de tierra (carga manual)" ;
    ns1:documentadoEn ns1:SistemaAlmacenamiento ;
    ns1:identificador "TM.MZGROUND[mz]" ;
    ns1:textoExtracto "GROUND Se permiten herramientas de tierra (carga manual). Valores posibles: Sí / No. Valor por defecto: No." .

ns1:SistemaAlmacenamiento a ns1:Sistema ;
    rdfs:label "Sistema de Almacenes" ;
    ns1:textoExtracto "Tabla del almacén. Este parámetro muestra las tablas para definir los datos del almacén." .

