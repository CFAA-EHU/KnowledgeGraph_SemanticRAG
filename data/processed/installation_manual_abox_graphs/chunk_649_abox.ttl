@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EntradaI12 a ex:Sensor ;
    rdfs:label "I12" ;
    ex:textoExtracto "Entradas (I1-I1024)" ;
    ex:valor "1" .

ex:TeclaStart a ex:Sensor ;
    rdfs:label "START" ;
    ex:textoExtracto "Devuelve un 1 cuando la tecla start del panel frontal está pulsada y un 0 en caso contrario." ;
    ex:valor "1" .

ex:PanelFrontal a ex:InterfazUsuario ;
    ex:textoExtracto "tecla start del panel frontal" ;
    ex:tieneComponente ex:TeclaStart .