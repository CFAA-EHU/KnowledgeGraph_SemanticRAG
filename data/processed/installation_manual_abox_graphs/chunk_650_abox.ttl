@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaMagazine a ns1:Tabla ;
    ns1:textoExtracto "Cada tabla dispone de los siguientes parámetros máquina para su configuración. | MAGAZINE n |  |" ;
    ns1:tieneComponente ns1:Parametro_d613d43edb,
        ns1:TamanoDelAlmacenNumeroDePosiciones .

ns1:Parametro_d613d43edb a ns1:Parametro ;
    rdfs:label "Almacén random" ;
    ns1:identificador "TM.MZRANDOM" ;
    ns1:textoExtracto "RANDOM Almacén random. Valores posibles: Sí / No. Valor por defecto: No." .

ns1:TamanoDelAlmacenNumeroDePosiciones a ns1:Parametro ;
    rdfs:label "Tamaño del almacén (número de posiciones)" ;
    ns1:identificador "TM.MZSIZE" ;
    ns1:textoExtracto "SIZE Tamaño del almacén (número de posiciones). Valores posibles: De 0 a 1000. Valor por defecto: 20." .

