@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Instruccion_CPS
    a                       ex:InterfazUsuario ;
    rdfs:label              "Instrucción CPS (Comparación)"@es ;
    ex:textoExtracto         "La instrucción CPS permite realizar comparaciones entre dos operandos, comprobando si el primer operando es mayor (GT), mayor o igual (GE), igual (EQ), distinto (NE), menor o igual (LE) o menor (LT) que el segundo. [...] El formato de programación es: T1ꞏꞏ512 GT CPS T1ꞏꞏ512 C1ꞏꞏ256 GE C1ꞏꞏ256 R1ꞏꞏ1024 EQ R1ꞏꞏ1024 R CNC-PLC NE R CNC-PLC LT"@es ;
    ex:identificador         "CPS" .

ex:Operando_Temporizador_C12
    a                       ex:ComponenteElectrico ;
    rdfs:label              "Temporizador C12"@es ;
    ex:textoExtracto         "CPS C12 GT R14 = M100 [...] Si la cuenta interna del contador C12 es MAYOR que el valor del registro R14"@es ;
    ex:identificador         "C12" .

ex:Operando_Registro_R14
    a                       ex:ComponenteElectrico ;
    rdfs:label              "Registro R14"@es ;
    ex:textoExtracto         "CPS C12 GT R14 = M100 [...] el valor del registro R14"@es ;
    ex:identificador         "R14" .

ex:Marca_M100
    a                       ex:ComponenteElectrico ;
    rdfs:label              "Marca M100"@es ;
    ex:textoExtracto         "el PLC asignará a la marca M100 el valor 1, y el valor 0 en caso contrario"@es ;
    ex:identificador         "M100" .

ex:Operando_Temporizador_T2
    a                       ex:ComponenteElectrico ;
    rdfs:label              "Temporizador T2"@es ;
    ex:textoExtracto         "CPS T2 EQ 100 = TG1 5 2000 [...] Cuando el tiempo que lleve transcurrido el temporizador T2 sea IGUAL al valor 100"@es ;
    ex:identificador         "T2" .

ex:Operando_Temporizador_T5
    a                       ex:ComponenteElectrico ;
    rdfs:label              "Temporizador T5 (monoestable)"@es ;
    ex:textoExtracto         "se activará el temporizador T5 funcionando como monoestable y con una constante de tiempo de 2 s"@es ;
    ex:identificador         "T5" ;
    ex:valor                 "2000"^^<http://www.w3.org/2001/XMLSchema#integer> .

ex:Ejemplo1_CPS_C12_GT_R14
    a                       ex:Tabla ;
    rdfs:label              "Ejemplo CPS: Comparación GT (C12 > R14)"@es ;
    ex:textoExtracto         "| CPS C12 GT R14 = M100 | Si la cuenta interna del contador C12 es MAYOR que el valor del registro R14, el PLC asignará a la marca M100 el valor 1, y el valor 0 en caso contrario. |"@es ;
    ex:ilustradoEn           ex:Instruccion_CPS .

ex:Ejemplo2_CPS_T2_EQ_100
    a                       ex:Tabla ;
    rdfs:label              "Ejemplo CPS: Comparación EQ (T2 == 100)"@es ;
    ex:textoExtracto         "| CPS T2 EQ 100 = TG1 5 2000 | Cuando el tiempo que lleve transcurrido el temporizador T2 sea IGUAL al valor 100, se activará el temporizador T5 funcionando como monoestable y con una constante de tiempo de 2 s. |"@es ;
    ex:ilustradoEn           ex:Instruccion_CPS .

ex:Instruccion_CPS
    ex:tieneComponente       ex:Operando_Temporizador_C12 , ex:Operando_Registro_R14 , ex:Marca_M100 ,
                            ex:Operando_Temporizador_T2 , ex:Operando_Temporizador_T5 .