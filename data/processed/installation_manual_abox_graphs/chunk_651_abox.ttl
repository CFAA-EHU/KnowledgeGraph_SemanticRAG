@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TipoDeAlmacen_1082777a36 a ns1:Parametro ;
    rdfs:label "Tipo de almacén" ;
    ns1:documentadoEn ns1:TablaGestionAlmacen ;
    ns1:identificador "TM.MZTYPE" ;
    ns1:textoExtracto "TYPE Tipo de almacén. Valores posibles: Asíncrono / Síncrono / Torreta / Síncrono + 2 Brazos / Síncrono + 1 Brazo. Valor por defecto: Síncrono." .

ns1:TablaGestionAlmacen a ns1:Tabla ;
    rdfs:label "Tabla de gestión del almacén" ;
    ns1:textoExtracto "MANAGEMENT Parámetros relacionados con la gestión del almacén. Este parámetro muestra los datos para configurar la gestión del almacén." .

