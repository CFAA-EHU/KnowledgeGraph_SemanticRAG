@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BrazoCambiador a ns1:ComponenteMecanico ;
    rdfs:label "Brazo Cambiador" ;
    ns1:textoExtracto "El brazo cambiador coge la herramienta del almacén y la trae junto al cabezal." .

ns1:CabezalHerramienta a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de Herramienta" ;
    ns1:textoExtracto "La segunda pinza del brazo cambiador coge la herramienta del cabezal y efectúa el cambio." .

ns1:Herramienta a ns1:ComponenteHidraulico ;
    rdfs:label "Herramienta" ;
    ns1:textoExtracto "El almacén selecciona la nueva herramienta y la coloca en el cabezal." .

ns1:SistemaAlmacenAsincrono a ns1:Sistema ;
    rdfs:label "Sistema de Almacén Asíncrono" ;
    ns1:textoExtracto "El almacén está alejado del cabezal. La mayoría de los movimientos se pueden efectuar durante el mecanizado de la pieza, minimizando tiempos." .

ns1:SistemaAlmacenSincrono a ns1:Sistema ;
    rdfs:label "Sistema de Almacén Síncrono" ;
    ns1:textoExtracto "En un almacén síncrono sin brazo cambiador el almacén debe desplazarse hasta el cabezal para efectuar el cambio." .

ns1:SistemaAlmacenTorreta a ns1:Sistema ;
    rdfs:label "Sistema de Almacén Torreta" ;
    ns1:textoExtracto "Almacén típico de torno. No es posible efectuar el cambio de herramienta durante el mecanizado de la pieza." .

