@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_b45a12261d a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:ejecuta ns1:CambioDeHerramienta_14be501bb8 ;
    ns1:textoExtracto "El CNC finaliza el movimiento de los ejes." .

ns1:SistemaAlmacenSincrono a ns1:Sistema ;
    rdfs:label "Almacén síncrono con brazo cambiador" ;
    ns1:ejecuta ns1:CambioDeHerramienta_14be501bb8 ;
    ns1:textoExtracto "Los almacenes síncronos con brazo cambiador (1 o 2 pinzas), tienen el almacén próximo al cabezal." ;
    ns1:tieneComponente ns1:BrazoCambiador,
        ns1:Herramienta .

ns1:BrazoCambiador a ns1:Componente ;
    rdfs:label "Brazo cambiador" ;
    ns1:textoExtracto "El brazo cambiador coge en cada pinza una herramienta (almacén y cabezal) y efectúa el cambio." .

ns1:Herramienta a ns1:Componente ;
    rdfs:label "Herramienta" ;
    ns1:textoExtracto "El cambio de herramienta se realiza de la siguiente manera..." .

ns1:CambioDeHerramienta_14be501bb8 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta" ;
    ns1:textoExtracto "(1)Durante el mecanizado, el almacén selecciona la nueva herramienta. (2)El CNC finaliza el movimiento de los ejes. (3)El brazo cambiador coge en cada pinza una herramienta (almacén y cabezal) y efectúa el cambio." .

