@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:InstruccionAccion_I2 a ex:Parametro ;
    rdfs:label "I2" ;
    ex:textoExtracto "La salida O3 mostrará el estado de la entrada I2." ;
    ex:valor "I2" .

ex:InstruccionAccion_O3 a ex:Actuador ;
    rdfs:label "O3" ;
    ex:textoExtracto "La salida O3 mostrará el estado de la entrada I2." ;
    ex:valor "O3" .

ex:InstruccionAccion_M100 a ex:Parametro ;
    rdfs:label "M100" ;
    ex:textoExtracto "La marca M100 mostrará el estado negado de la entrada I2." ;
    ex:valor "M100" .

ex:InstruccionAccion_TG1 a ex:Parametro ;
    rdfs:label "TG1" ;
    ex:textoExtracto "Un flanco de bajada en la entrada I2 activará la entrada de arranque TG1 del temporizador T2." ;
    ex:valor "TG1" .

ex:InstruccionAccion_T2 a ex:ComponenteElectrico ;
    rdfs:label "T2" ;
    ex:textoExtracto "Un flanco de bajada en la entrada I2 activará la entrada de arranque TG1 del temporizador T2." ;
    ex:valor "T2" .

ex:InstruccionAccion_C1 a ex:ComponenteElectrico ;
    rdfs:label "C1" ;
    ex:textoExtracto "Un flanco de subida en la entrada I2 preseleccionará el contador C1 con el valor 100." ;
    ex:valor "C1" .

ex:InstruccionAccion_100 a ex:Parametro ;
    rdfs:label "100" ;
    ex:textoExtracto "Un flanco de subida en la entrada I2 preseleccionará el contador C1 con el valor 100." ;
    ex:valor "100" .

ex:InstruccionAccion_CPR_1_100 a ex:Parametro ;
    rdfs:label "CPR 1 100" ;
    ex:textoExtracto "I2 = O3 = NOT M100 = NOT TG1 2 100 = CPR 1 100" ;
    ex:valor "CPR 1 100" .