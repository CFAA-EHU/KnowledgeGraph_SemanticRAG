@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:RecursoI3 a ex:Sensor ;
    ex:textoExtracto "Asigna a la entrada de arranque TG1 del temporizador T4 el estado de la entrada I3, por lo que un flanco de subida en I3 activará la entrada de arranque TG1 del temporizador T4." ;
    rdfs:label "I3" .

ex:TemporizadorT4 a ex:ComponenteElectrico ;
    ex:textoExtracto "Asigna a la entrada de arranque TG1 del temporizador T4 el estado de la entrada I3, por lo que un flanco de subida en I3 activará la entrada de arranque TG1 del temporizador T4." ;
    rdfs:label "T4" .

ex:EntradaArranqueTG1 a ex:Parametro ;
    ex:textoExtracto "Asigna a la entrada de arranque TG1 del temporizador T4 el estado de la entrada I3, por lo que un flanco de subida en I3 activará la entrada de arranque TG1 del temporizador T4." ;
    rdfs:label "TG1" .

ex:MarcaM111 a ex:Parametro ;
    ex:textoExtracto "Asigna a la marca M111 el valor obtenido en la evaluación de la Expresión lógica (I2 OR I3) AND (I4 OR (NOT I5 AND I6))." ;
    rdfs:label "M111" .

ex:ExpresionLogica1 a ex:Parametro ;
    ex:textoExtracto "( I2 OR I3) AND (I4 OR (NOT I5 AND I6))" ;
    rdfs:label "(I2 OR I3) AND (I4 OR (NOT I5 AND I6))" .