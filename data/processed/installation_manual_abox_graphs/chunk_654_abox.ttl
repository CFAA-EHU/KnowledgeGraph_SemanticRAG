@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_22cc4f7c9a a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC continúa con la ejecución del programa." ;
    ns1:tieneComponente ns1:CambiadorDeHerramientasCiclico,
        ns1:OptimizacionDeLaGestion .

ns1:CambiadorDeHerramientasCiclico a ns1:Parametro ;
    rdfs:label "Cambiador de herramientas cíclico" ;
    ns1:identificador "TM.MZCYCLIC[mz]" ;
    ns1:textoExtracto "Variable asociada: (V.)TM.MZCYCLIC[mz] Parámetro incluido en la tabla MAGAZINE // MANAGEMENT." .

ns1:OptimizacionDeLaGestion a ns1:Parametro ;
    rdfs:label "Optimización de la gestión" ;
    ns1:identificador "TM.MZOPTIMIZED[mz]" ;
    ns1:textoExtracto "Variable asociada: (V.)TM.MZOPTIMIZED[mz] Parámetro incluido en la tabla MAGAZINE // MANAGEMENT." .

