@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EnAlmacenRandomBuscarHuecosDelMismoTamano a ns1:Parametro ;
    rdfs:label "En almacén rándom, buscar huecos del mismo tamaño" ;
    ns1:identificador "TM.RESPECTSIZES" ;
    ns1:textoExtracto "RESPECTSIZES En almacén rándom, buscar huecos del mismo tamaño. Valores posibles: Sí / No. Valor por defecto: No." .

ns1:Parametro_76aa18c8df a ns1:Parametro ;
    rdfs:label "Acción al ejecutar una M06 sin herramienta seleccionada" ;
    ns1:identificador "M6ALONE" ;
    ns1:textoExtracto "M6ALONE Acción al ejecutar una M06 sin herramienta seleccionada. Valores posibles: Nada / Mostrar un aviso / Mostrar un error. Valor por defecto: Mostrar un error." .

