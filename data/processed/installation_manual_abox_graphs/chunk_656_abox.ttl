@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Instruccion_JMP
    a               ex:AccionProhibida ;
    rdfs:label      "JMP (Salto incondicional)"@es ;
    ex:textoExtracto "= JMP Salto incondicional. Si el resultado obtenido en la evaluación de la expresión lógica es un '1', provoca un salto a la etiqueta especificada. Si el resultado es '0' continúa en la siguiente línea de programa."@es ;
    ex:identificador "JMP" .

ex:Instruccion_CAL
    a               ex:AccionProhibida ;
    rdfs:label      "CAL (Llamada a subrutina)"@es ;
    ex:textoExtracto "= CAL Llamada a subrutina. Si el resultado obtenido en la evaluación de la expresión lógica es un '1' esta acción ejecuta la subrutina indicada. Si el resultado obtenido en la evaluación de la expresión lógica es un '0' esta acción será ignorada por el PLC, continuando el programa sin ejecutar dicha subrutina."@es ;
    ex:identificador "CAL" .

ex:Instruccion_RET
    a               ex:AccionProhibida ;
    rdfs:label      "RET (Retorno o final de subrutina)"@es ;
    ex:textoExtracto "= RET Retorno o final de subrutina."@es ;
    ex:identificador "RET" .

ex:Etiqueta_L123
    a               ex:Parametro ;
    rdfs:label      "Etiqueta L123"@es ;
    ex:textoExtracto "= JMP L123 Si la etiqueta se definió como L123."@es ;
    ex:identificador "L123" .

ex:Etiqueta_L_ASA2
    a               ex:Parametro ;
    rdfs:label      "Etiqueta L_ASA2"@es ;
    ex:textoExtracto "= JMP L_ASA2 Si la etiqueta se definió como L_ASA2."@es ;
    ex:identificador "L_ASA2" .

ex:Etiqueta_L12
    a               ex:Parametro ;
    rdfs:label      "Etiqueta L12"@es ;
    ex:textoExtracto "I8 = JMP L12 Si I8=1 el programa continúa en L12 y no se ejecutan los bloques intermedios."@es ;
    ex:identificador "L12" .

ex:Subrutina_OILING
    a               ex:Parametro ;
    rdfs:label      "Subrutina OILING"@es ;
    ex:textoExtracto "= CAL OILING Si se definió como SUB OILING."@es ;
    ex:identificador "OILING" .

ex:Subrutina_L234
    a               ex:Parametro ;
    rdfs:label      "Subrutina L234"@es ;
    ex:textoExtracto "= CAL L234 Si se definió como L234."@es ;
    ex:identificador "L234" .

ex:Subrutina_L_GEAR
    a               ex:Parametro ;
    rdfs:label      "Subrutina L_GEAR"@es ;
    ex:textoExtracto "= CAL L_GEAR Si se definió como L_GEAR."@es ;
    ex:identificador "L_GEAR" .

ex:Subrutina_L5
    a               ex:Parametro ;
    rdfs:label      "Subrutina L5"@es ;
    ex:textoExtracto "I2 = CAL L5 = O2 Con I2=1 se ejecuta la subrutina L5 y una vez finalizada ésta el PLC asigna a la salida O2 el valor de la entrada I2 (1)."@es ;
    ex:identificador "L5" .

ex:Parametro_I8
    a               ex:Parametro ;
    rdfs:label      "Entrada I8"@es ;
    ex:textoExtracto "I8 = JMP L12 Si I8=1 el programa continúa en L12 y no se ejecutan los bloques intermedios."@es ;
    ex:identificador "I8" .

ex:Parametro_I2
    a               ex:Parametro ;
    rdfs:label      "Entrada I2"@es ;
    ex:textoExtracto "I2 = CAL L5 = O2 Con I2=1 se ejecuta la subrutina L5 y una vez finalizada ésta el PLC asigna a la salida O2 el valor de la entrada I2 (1)."@es ;
    ex:identificador "I2" .

ex:Parametro_O2
    a               ex:Parametro ;
    rdfs:label      "Salida O2"@es ;
    ex:textoExtracto "I2 = CAL L5 = O2 Con I2=1 [...] el PLC asigna a la salida O2 el valor de la entrada I2 (1)."@es ;
    ex:identificador "O2" .