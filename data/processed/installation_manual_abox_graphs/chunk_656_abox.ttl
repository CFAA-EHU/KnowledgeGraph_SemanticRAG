@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaGestionAlmacen a ns1:Tabla ;
    rdfs:label "MAGAZINE // MANAGEMENT" ;
    ns1:ilustradoEn ns1:IndicaQueOcurreCuandoSeEjecutaUnaM06SinSeleccionPreviaDeHerramienta ;
    ns1:textoExtracto "Parámetro incluido en la tabla MAGAZINE // MANAGEMENT." .

ns1:IndicaQueOcurreCuandoSeEjecutaUnaM06SinSeleccionPreviaDeHerramienta a ns1:Parametro ;
    rdfs:label "Indica qué ocurre cuando se ejecuta una M06 sin selección previa de herramienta" ;
    ns1:identificador "TM.MZM6ALONE" ;
    ns1:textoExtracto "Variable asociada: (V.)TM.MZM6ALONE[mz] Parámetro incluido en la tabla MAGAZINE // MANAGEMENT. La función M06 implica cambio de herramienta. Este parámetro indica qué ocurre cuando se ejecuta una M06 sin selección previa de herramienta." .

