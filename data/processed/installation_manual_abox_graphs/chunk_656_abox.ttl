@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:JMP a ex:AccionProhibida ;
    rdfs:label "JMP" ;
    ex:textoExtracto "Estas acciones interrumpen la secuencia de un programa, haciendo que continúe su ejecución en otra parte del programa. = JMP Salto incondicional." .

ex:JMP_L123 a ex:AccionProhibida ;
    rdfs:label "JMP L123" ;
    ex:textoExtracto "= JMP L123 Si la etiqueta se definió como L123." .

ex:JMP_L_ASA2 a ex:AccionProhibida ;
    rdfs:label "JMP L_ASA2" ;
    ex:textoExtracto "= JMP L_ASA2." .

ex:JMP_L12 a ex:AccionProhibida ;
    rdfs:label "JMP L12" ;
    ex:textoExtracto "I8 = JMP L12 Si I8=1 el programa continúa en L12 y no se ejecutan los bloques intermedios." .

ex:CAL a ex:AccionProhibida ;
    rdfs:label "CAL" ;
    ex:textoExtracto "= CAL Llamada a subrutina." .

ex:CAL_OILING a ex:AccionProhibida ;
    rdfs:label "CAL OILING" ;
    ex:textoExtracto "= CAL OILING Si se definió como SUB OILING." .

ex:CAL_L234 a ex:AccionProhibida ;
    rdfs:label "CAL L234" ;
    ex:textoExtracto "= CAL L234 Si se definió como L234." .

ex:CAL_L_GEAR a ex:AccionProhibida ;
    rdfs:label "CAL L_GEAR" ;
    ex:textoExtracto "= CAL L_GEAR." .

ex:CAL_L5 a ex:AccionProhibida ;
    rdfs:label "CAL L5" ;
    ex:textoExtracto "I2 = CAL L5 = O2 Con I2=1 se ejecuta la subrutina L5 y una vez finalizada ésta el PLC asigna a la salida O2 el valor de la entrada I2 (1)." .

ex:RET a ex:AccionProhibida ;
    rdfs:label "RET" ;
    ex:textoExtracto "= RET Retorno o final de subrutina." .