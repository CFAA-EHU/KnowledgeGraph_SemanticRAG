@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PLC_657_370 a ex:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ex:textoExtracto "Con I2=0 no se ejecuta la subrutina y el PLC asigna a la salida O2 el valor de la entrada I2 (0). = RET Retorno o final de subrutina. Si el resultado obtenido en la evaluación de la expresión lógica es un \"1\" esta acción será tratada por el PLC como la proposición directiva END. Si el resultado es \"0\", será ignorada por el PLC. Si durante la ejecución de una subrutina el PLC detecta un RET validado dará por finalizada la subrutina." .

ex:Subrutina_657_370 a ex:TareaMantenimiento ;
    rdfs:label "subrutina" ;
    ex:textoExtracto "Con I2=0 no se ejecuta la subrutina y el PLC asigna a la salida O2 el valor de la entrada I2 (0). = RET Retorno o final de subrutina. Si el resultado obtenido en la evaluación de la expresión lógica es un \"1\" esta acción será tratada por el PLC como la proposición directiva END. Si el resultado es \"0\", será ignorada por el PLC. Si durante la ejecución de una subrutina el PLC detecta un RET validado dará por finalizada la subrutina." .

ex:SalidaO2_657_370 a ex:ComponenteElectrico ;
    rdfs:label "salida O2" ;
    ex:textoExtracto "Con I2=0 no se ejecuta la subrutina y el PLC asigna a la salida O2 el valor de la entrada I2 (0)." .

ex:EntradaI2_657_370 a ex:ComponenteElectrico ;
    rdfs:label "entrada I2" ;
    ex:textoExtracto "Con I2=0 no se ejecuta la subrutina y el PLC asigna a la salida O2 el valor de la entrada I2 (0)." .

ex:ProposicionEND_657_370 a ex:Directiva ;
    rdfs:label "END" ;
    ex:textoExtracto "Si el resultado obtenido en la evaluación de la expresión lógica es un \"1\" esta acción será tratada por el PLC como la proposición directiva END." .

ex:RET_657_370 a ex:Directiva ;
    rdfs:label "RET" ;
    ex:textoExtracto "= RET Retorno o final de subrutina. Si durante la ejecución de una subrutina el PLC detecta un RET validado dará por finalizada la subrutina." .