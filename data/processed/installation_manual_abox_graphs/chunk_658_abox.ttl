@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlturaDeLaVentana a ns1:Parametro ;
    rdfs:label "Altura de la ventana" ;
    ns1:identificador "HEIGHT" ;
    ns1:textoExtracto "HEIGHT Altura de la ventana." .

ns1:AnchuraDeLaVentana a ns1:Parametro ;
    rdfs:label "Anchura de la ventana" ;
    ns1:identificador "WIDTH" ;
    ns1:textoExtracto "WIDTH Anchura de la ventana." .

ns1:CoordenadaXDeLaEsquinaSuperiorIzquierda a ns1:Parametro ;
    rdfs:label "Coordenada X de la esquina superior izquierda" ;
    ns1:identificador "POSX" ;
    ns1:textoExtracto "POSX Coordenada X de la esquina superior izquierda. Valor por defecto: 0." .

ns1:CoordenadaYDeLaEsquinaSuperiorIzquierda a ns1:Parametro ;
    rdfs:label "Coordenada Y de la esquina superior izquierda" ;
    ns1:identificador "POSY" ;
    ns1:textoExtracto "POSY Coordenada Y de la esquina superior izquierda. Valor por defecto: 0." .

ns1:ResolucionDeLaPantalla a ns1:Parametro ;
    rdfs:label "Resolución de la pantalla" ;
    ns1:identificador "RESOLUTION" ;
    ns1:textoExtracto "RESOLUTION Resolución de la pantalla. Valores posibles: CUSTOM / 10\" / 15\" / 19\" / 21\" LANDSCAPE / 21\" PORTRAIT." .

