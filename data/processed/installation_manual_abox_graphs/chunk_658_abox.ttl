@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Instruccion_MOV
    a ex:AccionProhibida ;
    rdfs:label "Instrucción MOV (Mover)"@es ;
    ex:textoExtracto """
= MOV Mover. Permite mover información de un recurso a otro del PLC.
El formato de programación es:
Origen Destino Código origen Código destino Bits a transmitir
0(Bin) 0(Bin) 32 I1/1024 =MOV I1/1024 1(BCD) 1(BCD) 28 O1/1024
O1/1024 24 M1/8192 M1/8192 20 MSG1/1024 MSG1/1024 16 ERR1/1024
ERR1/1024 12 R1/1024 T1/512 8 R CNC-PLC C1/256 4 R1/1024 R CNC-PLC"""@es ;
    ex:identificador "MOV" .

ex:Parametro_BitsTransmitir
    a ex:Parametro ;
    rdfs:label "Bits a transmitir (MOV)"@es ;
    ex:textoExtracto "Se pueden transmitir 4, 8, 12, 16, 20, 24, 28 o 32 bits. Si no se definen los códigos y el número de bits a transmitir, se transmite de binario a binario y en 32 bits (0032)."@es ;
    ex:valor "32"^^<http://www.w3.org/2001/XMLSchema#integer> .

ex:Parametro_FormatoBinario
    a ex:Parametro ;
    rdfs:label "Formato binario (código 0)"@es ;
    ex:textoExtracto "Los códigos de origen y destino indican el formato (binario o BCD) en que se encuentra y se desea dejar la información."@es ;
    ex:identificador "0" ;
    ex:valor "binario"@es .

ex:Parametro_FormatoBCD
    a ex:Parametro ;
    rdfs:label "Formato BCD (código 1)"@es ;
    ex:textoExtracto "Los códigos de origen y destino indican el formato (binario o BCD) en que se encuentra y se desea dejar la información."@es ;
    ex:identificador "1" ;
    ex:valor "BCD"@es .

ex:Parametro_LimiteBCD_32bits
    a ex:Parametro ;
    rdfs:label "Límite máximo convertible (BCD, 32 bits)"@es ;
    ex:textoExtracto "El máximo valor convertible en BCD es: [...] 99999999 (con 32)."@es ;
    ex:valor "99999999"^^<http://www.w3.org/2001/XMLSchema#integer> .

ex:Instruccion_MOV
    ex:monitoreaParametro ex:Parametro_BitsTransmitir ;
    ex:monitoreaParametro ex:Parametro_FormatoBinario ;
    ex:monitoreaParametro ex:Parametro_FormatoBCD ;
    ex:monitoreaParametro ex:Parametro_LimiteBCD_32bits .