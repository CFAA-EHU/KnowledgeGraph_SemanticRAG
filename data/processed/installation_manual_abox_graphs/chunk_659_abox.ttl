@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Instruccion_MOV_I11_I14_O16
    a               ex:AccionProhibida ;
    rdfs:label      "Transferencia MOV I11 = MOV I14 O16 108" ;
    ex:textoExtracto "Si la entrada I11 vale '1' el PLC realiza una transferencia de los estados lógicos de las 8 entradas I14 y siguientes en código BCD, hacia las 8 salidas O16 y siguientes en código binario." ;
    ex:identificador "108" .

ex:Entrada_I11
    a               ex:ComponenteElectrico ;
    rdfs:label      "Entrada I11" ;
    ex:textoExtracto "Si la entrada I11 vale '1'..." .

ex:Entradas_I14
    a               ex:ComponenteElectrico ;
    rdfs:label      "Entradas I14 y siguientes" ;
    ex:textoExtracto "transferencia de los estados lógicos de las 8 entradas I14 y siguientes en código BCD" .

ex:Salidas_O16
    a               ex:ComponenteElectrico ;
    rdfs:label      "Salidas O16 y siguientes" ;
    ex:textoExtracto "hacia las 8 salidas O16 y siguientes en código binario" .

ex:Instruccion_MOV_I11_I14_O16
    ex:controla    ex:Entrada_I11 ;
    ex:activaAlarma ex:Salidas_O16 .  # Relación funcional implícita (activación de salida)