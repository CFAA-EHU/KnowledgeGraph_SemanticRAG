@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlturaDeLaVentana a ns1:Parametro ;
    rdfs:label "Altura de la ventana" ;
    ns1:documentadoEn ns1:TablaDimensionesVentanaPrincipal ;
    ns1:identificador "HEIGHT" ;
    ns1:textoExtracto "HEIGHT Altura de la ventana. Valores posibles: De 480 a 1050 píxeles. Valor por defecto: 600 píxeles." .

ns1:AnchuraDeLaVentana a ns1:Parametro ;
    rdfs:label "Anchura de la ventana" ;
    ns1:documentadoEn ns1:TablaDimensionesVentanaPrincipal ;
    ns1:identificador "WIDTH" ;
    ns1:textoExtracto "WIDTH Anchura de la ventana. Valores posibles: De 800 a 1680 píxeles. Valor por defecto: 800 píxeles." .

ns1:CNC8070_c80cd50492 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Los parámetros WIDTH y HEIGHT definen el tamaño de la ventana. Estos parámetros sólo se pueden modificar cuando el parámetro RESOLUTION tiene el valor \"CUSTOM\"." .

ns1:TablaDimensionesVentanaPrincipal a ns1:Tabla ;
    rdfs:label "Tablas de dimensiones y resolución de la ventana principal" ;
    ns1:ilustra ns1:CNC8070_c80cd50492 ;
    ns1:textoExtracto "RESOLUTION. (valor) | Tamaño del interface (píxeles). 19\" | 1280 × 1024. 21\" LANDSCAPE Panorámico horizontal. | 1300 × 1080. El interface no ocupa toda la pantalla para permitir un teclado virtual. 21\" PORTRAIT Panorámico vertical. | 1080 × 1400. El interface no ocupa toda la pantalla para permitir un teclado virtual." .

