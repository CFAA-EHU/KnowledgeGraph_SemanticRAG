@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:I11 a ex:Sensor ;
    rdfs:label "I11" ;
    ex:textoExtracto "Si la entrada I11 vale \"1\" el PLC realiza una transferencia de los estados lógicos de las 8 entradas I14 y siguientes en código BCD, hacia las 8 salidas O16 y siguientes en código binario." .

ex:I14 a ex:Sensor ;
    rdfs:label "I14" ;
    ex:textoExtracto "transferencia de los estados lógicos de las 8 entradas I14 y siguientes en código BCD" .

ex:O16 a ex:Actuador ;
    rdfs:label "O16" ;
    ex:textoExtracto "hacia las 8 salidas O16 y siguientes en código binario" .

ex:PLC a ex:Sistema ;
    rdfs:label "PLC" ;
    ex:textoExtracto "el PLC realiza una transferencia de los estados lógicos de las 8 entradas I14 y siguientes en código BCD, hacia las 8 salidas O16 y siguientes en código binario" .