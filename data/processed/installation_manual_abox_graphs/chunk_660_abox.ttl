@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Instruccion_NGU_R_1_1024
    a ex:AccionProhibida ;
    rdfs:label "NGU R 1/1024 (Complementación de bits)" ;
    ex:textoExtracto "NGU R 1/1024 Complementa los bits de un registro. Realiza una complementación de los 32 bits del registro (cambia el estado de cada uno de los bits). I15 = NGU R152 Si la entrada I15 vale \"1\" el PLC complementa los 32 bits del registro R152." ;
    ex:identificador "NGU R 1/1024" .

ex:Instruccion_NGS_R_1_1024
    a ex:AccionProhibida ;
    rdfs:label "NGS R 1/1024 (Cambio de signo)" ;
    ex:textoExtracto "NGS R 1/1024 Cambio de signo del registro. Cambia el signo del registro. I16 = NGS R89 Si la entrada I16 vale \"1\" el PLC cambia de signo el contenido del registro R89." ;
    ex:identificador "NGS R 1/1024" .

ex:Instruccion_ADS_R1_1024
    a ex:AccionProhibida ;
    rdfs:label "ADS R1/1024 (Suma aritmética)" ;
    ex:textoExtracto "ADS R1/1024 R1/1024 R1/1024" ;
    ex:identificador "ADS R1/1024" .

ex:Instruccion_SBS_R_CNC_PLC
    a ex:AccionProhibida ;
    rdfs:label "SBS R CNC-PLC (Resta aritmética)" ;
    ex:textoExtracto "SBS R CNC-PLC R CNC-PLC R CNC-PLC" ;
    ex:identificador "SBS R CNC-PLC" .

ex:Instruccion_DVS
    a ex:AccionProhibida ;
    rdfs:label "DVS (División aritmética)" ;
    ex:textoExtracto "DVS" ;
    ex:identificador "DVS" .

ex:Instruccion_MDS
    a ex:AccionProhibida ;
    rdfs:label "MDS (Módulo o resto de división)" ;
    ex:textoExtracto "MDS" ;
    ex:identificador "MDS" .

ex:Registro_R152
    a ex:Parametro ;
    rdfs:label "Registro R152" ;
    ex:textoExtracto "R152 antes: 0001 0001 0001 0001 0001 0001 0001 0001 R152 después: 1110 1110 1110 1110 1110 1110 1110 1110" ;
    ex:identificador "R152" ;
    ex:valor "00010001000100010001000100010001" .

ex:Registro_R89
    a ex:Parametro ;
    rdfs:label "Registro R89" ;
    ex:textoExtracto "R89 antes: 0001 0001 0001 0001 0001 0001 0001 0001 R89 después: 1110 1110 1110 1110 1110 1110 1110 1111" ;
    ex:identificador "R89" ;
    ex:valor "00010001000100010001000100010001" .

ex:Registro_R100
    a ex:Parametro ;
    rdfs:label "Registro R100" ;
    ex:textoExtracto "Ejemplos con R100=1234" ;
    ex:identificador "R100" ;
    ex:valor "1234" .

ex:Registro_R101
    a ex:Parametro ;
    rdfs:label "Registro R101" ;
    ex:textoExtracto "Ejemplos con R101=100" ;
    ex:identificador "R101" ;
    ex:valor "100" .

ex:Entrada_I15
    a ex:Parametro ;
    rdfs:label "Entrada I15" ;
    ex:textoExtracto "I15 = NGU R152 Si la entrada I15 vale \"1\" el PLC complementa los 32 bits del registro R152." ;
    ex:identificador "I15" .

ex:Entrada_I16
    a ex:Parametro ;
    rdfs:label "Entrada I16" ;
    ex:textoExtracto "I16 = NGS R89 Si la entrada I16 vale \"1\" el PLC cambia de signo el contenido del registro R89." ;
    ex:identificador "I16" .

ex:Instruccion_NGU_R_1_1024
    ex:monitoreaParametro ex:Registro_R152 ;
    ex:monitoreaParametro ex:Entrada_I15 .

ex:Instruccion_NGS_R_1_1024
    ex:monitoreaParametro ex:Registro_R89 ;
    ex:monitoreaParametro ex:Entrada_I16 .