@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DimensionesDeLasSoftkeys a ns1:Parametro ;
    rdfs:label "Dimensiones de las softkeys" ;
    ns1:identificador "SOFTKEYMETRICS" ;
    ns1:textoExtracto "SOFTKEYMETRICS Dimensiones de las softkeys. Valores posibles: Estándar / Avanzado. Valor por defecto: Estándar." .

ns1:NumeroDeSoftkeysDelMenuHorizontal a ns1:Parametro ;
    rdfs:label "Número de softkeys del menú horizontal" ;
    ns1:identificador "HMENUNSOFTKEY" ;
    ns1:textoExtracto "HMENUNSOFTKEY Número de softkeys del menú horizontal. Valores posibles: De 7 a 12. Valor por defecto: 7." .

ns1:NumeroDeSoftkeysDelMenuVertical a ns1:Parametro ;
    rdfs:label "Número de softkeys del menú vertical" ;
    ns1:identificador "VMENUNSOFTKEY" ;
    ns1:textoExtracto "VMENUNSOFTKEY Número de softkeys del menú vertical. Valores posibles: De 5 a 12. Valor por defecto: 5." .

