@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:R100 a ex:Parametro ;
    ex:identificador "R100" ;
    ex:textoExtracto "R100=1234" .

ex:R101 a ex:Parametro ;
    ex:identificador "R101" ;
    ex:textoExtracto "R101=100" .

ex:R102 a ex:Parametro ;
    ex:identificador "R102" ;
    ex:textoExtracto "R102 = 1234 + 100 = 1334" .

ex:R103 a ex:Parametro ;
    ex:identificador "R103" ;
    ex:textoExtracto "R103 = 1234 - 100 = 1134" .

ex:R104 a ex:Parametro ;
    ex:identificador "R104" ;
    ex:textoExtracto "R104 = 1234 x 100 = 123400" .

ex:R105 a ex:Parametro ;
    ex:identificador "R105" ;
    ex:textoExtracto "R105 = 1234 : 100 = 12" .

ex:R106 a ex:Parametro ;
    ex:identificador "R106" ;
    ex:textoExtracto "R106 = 1234 MOD 100 = 34" .

ex:R112 a ex:Parametro ;
    ex:identificador "R112" ;
    ex:textoExtracto "R112 = 1563 + 100 = 1663" .

ex:R113 a ex:Parametro ;
    ex:identificador "R113" ;
    ex:textoExtracto "R113 = 1234 - 1010 = 224" .

ex:R114 a ex:Parametro ;
    ex:identificador "R114" ;
    ex:textoExtracto "R114 = 1563 x 100 = 156300" .

ex:R115 a ex:Parametro ;
    ex:identificador "R115" ;
    ex:textoExtracto "MLS SANALOG 10000 R115 = DVS R115 32767 R115 ; Consigna cabezal en mV" .