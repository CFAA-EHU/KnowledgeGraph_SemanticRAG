@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TipoDeArbolDeSoftkeys a ns1:Parametro ;
    rdfs:label "Tipo de árbol de softkeys" ;
    ns1:identificador "SFTYPE" ;
    ns1:textoExtracto "SFTYPE Tipo de árbol de softkeys. Valores posibles: Estándar / Desplegables." .

ns1:TipoDeInterfaceDelCNC a ns1:Parametro ;
    rdfs:label "Tipo de interface del CNC" ;
    ns1:identificador "HMITYPE" ;
    ns1:textoExtracto "HMITYPE Tipo de interface del CNC. Valores posibles: Estándar / Clásico / Avanzado." .

ns1:ValorAvanzado a ns1:Parametro ;
    rdfs:label "Forma de operar basada en la tecla [Main-Menu]" ;
    ns1:textoExtracto "Avanzado. Forma de operar basada en la tecla [Main-Menu], que muestra un menú principal desde el que se accede, mediante softkeys, a los diferentes modos de trabajo (automático, manual, editor, etc)." .

ns1:ValorClasico a ns1:Parametro ;
    rdfs:label "Forma de operar basada en hotkeys" ;
    ns1:textoExtracto "Clásico. Forma de operar basada en hotkeys, para seleccionar el modo de trabajo (automático, manual, editor, etc)." .

ns1:ValorEstandar a ns1:Parametro ;
    rdfs:label "Forma de operar por defecto en el CNC" ;
    ns1:textoExtracto "Estándar. Forma de operar por defecto en el CNC, que podrá ser la forma clásica o avanzada, dependiendo del modelo de CNC." .

