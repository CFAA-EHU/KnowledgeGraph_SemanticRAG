@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:FormatoDeVisualizacionDeLaFProgramada a ns1:Parametro ;
    rdfs:label "Formato de visualización de la F programada" ;
    ns1:identificador "FFORMAT" ;
    ns1:textoExtracto "FFORMAT Formato de visualización de la F programada. Valor por defecto: 5.2." .

ns1:FormatoDeVisualizacionDeLaSProgramada a ns1:Parametro ;
    rdfs:label "Formato de visualización de la S programada" ;
    ns1:identificador "SFORMAT" ;
    ns1:textoExtracto "SFORMAT Formato de visualización de la S programada. Valor por defecto: 5.1." .

ns1:IdiomaDeTrabajo a ns1:Parametro ;
    rdfs:label "Idioma de trabajo" ;
    ns1:identificador "LANGUAGE" ;
    ns1:textoExtracto "LANGUAGE Idioma de trabajo. Valor por defecto: English." .

ns1:MostrarLaSoftkeyParaCambiarElFormatoDeVisualizacionEntreMilimetrosYPulgadas a ns1:Parametro ;
    rdfs:label "Mostrar la softkey para cambiar el formato de visualización entre milímetros y pulgadas" ;
    ns1:identificador "MMINCHSOFTKEY" ;
    ns1:textoExtracto "MMINCHSOFTKEY Mostrar la softkey para cambiar el formato de visualización entre milímetros y pulgadas. Valores posibles: Sí / No." .

ns1:PosicionDelMenuVerticalDeSoftkeys a ns1:Parametro ;
    rdfs:label "Posición del menú vertical de softkeys" ;
    ns1:identificador "VMENU" ;
    ns1:textoExtracto "VMENU Posición del menú vertical de softkeys. Valores posibles: Izquierda / Derecha." .

