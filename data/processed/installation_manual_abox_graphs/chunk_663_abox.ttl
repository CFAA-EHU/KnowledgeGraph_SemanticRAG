@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaUSERKEY a ns1:Tabla ;
    rdfs:label "Tabla de configuración del teclado" ;
    ns1:ilustradoEn ns1:AccederAUnoDeLosComponentesDelCNC,
        ns1:EjecutarUnaAplicacionDelPC,
        ns1:Parametro_56a790dfba,
        ns1:PersonalizacionDeLaTeclaDeUsuario ;
    ns1:textoExtracto "Esta tabla muestra los parámetros para configurar la tecla de usuario." .

ns1:AccederAUnoDeLosComponentesDelCNC a ns1:Parametro ;
    rdfs:label "Acceder a uno de los componentes del CNC" ;
    ns1:identificador "COMPONENT" ;
    ns1:textoExtracto "Valores posibles: Diagnosis / PLC / Parámetros máquina / DDSSETUP / TUNING." .

ns1:EjecutarUnaAplicacionDelPC a ns1:Parametro ;
    rdfs:label "Ejecutar una aplicación del PC" ;
    ns1:identificador "APPLICATION" ;
    ns1:textoExtracto "Parámetro incluido en la tabla USERKEY. Cuando se define el parámetro USERKEY=Application, este parámetro permite seleccionar la aplicación." .

ns1:Parametro_56a790dfba a ns1:Parametro ;
    rdfs:label "Función de la tecla de usuario" ;
    ns1:identificador "FUNCTION" ;
    ns1:textoExtracto "Valores posibles: Windows / Componente / Aplicación / CNC OFF / Nada. Valor por defecto: Nada." .

ns1:PersonalizacionDeLaTeclaDeUsuario a ns1:Parametro ;
    rdfs:label "Personalización de la tecla de usuario" ;
    ns1:textoExtracto "Esta tabla muestra los parámetros para configurar la tecla de usuario." .

