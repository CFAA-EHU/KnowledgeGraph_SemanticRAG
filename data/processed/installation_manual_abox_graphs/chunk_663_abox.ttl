@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Instruccion_RR1
    a ex:AccionProhibida ;
    rdfs:label "Rotación a derechas tipo 1 (RR1)" ;
    ex:textoExtracto "RR1 R100 1 R200 Realiza una rotación a derechas tipo 1 de R100 dejando el resultado en R200." ;
    ex:identificador "RR1" .

ex:Instruccion_RL2
    a ex:AccionProhibida ;
    rdfs:label "Rotación a izquierdas tipo 2 (RL2)" ;
    ex:textoExtracto "RL2 R102 4 R101 Realiza cuatro rotaciones a izquierdas tipo 2 de R102 dejando el resultado en R101." ;
    ex:identificador "RL2" .

ex:Registro_R100
    a ex:Componente ;
    rdfs:label "Registro R100" ;
    ex:textoExtracto "R100" ;
    ex:identificador "R100" .

ex:Registro_R200
    a ex:Componente ;
    rdfs:label "Registro R200" ;
    ex:textoExtracto "R200" ;
    ex:identificador "R200" .

ex:Registro_R102
    a ex:Componente ;
    rdfs:label "Registro R102" ;
    ex:textoExtracto "R102" ;
    ex:identificador "R102" .

ex:Registro_R101
    a ex:Componente ;
    rdfs:label "Registro R101" ;
    ex:textoExtracto "R101" ;
    ex:identificador "R101" .

ex:Instruccion_RR1
    ex:controla ex:Registro_R100 ;
    ex:controla ex:Registro_R200 .

ex:Instruccion_RL2
    ex:controla ex:Registro_R102 ;
    ex:controla ex:Registro_R101 .