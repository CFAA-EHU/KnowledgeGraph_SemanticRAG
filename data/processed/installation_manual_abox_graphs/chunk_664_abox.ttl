@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaConfiguracionTeclado a ns1:Tabla ;
    rdfs:label "Tabla de configuración del teclado" ;
    ns1:ilustra ns1:ComportamientoDelMenuDeSistema,
        ns1:MenuDeSistemaHorizontal,
        ns1:MenuDeSistemaVertical_2eac271054,
        ns1:Parametro_56a790dfba,
        ns1:PersonalizacionDeLaTeclaDeCambio ;
    ns1:textoExtracto "Esta tabla muestra los parámetros para configurar la tecla de cambio." .

ns1:ComportamientoDelMenuDeSistema a ns1:Parametro ;
    rdfs:label "Comportamiento del menú de sistema" ;
    ns1:identificador "SYSMENUMODE" ;
    ns1:textoExtracto "Valores posibles: Volátil / Fijo. Valor por defecto: Volátil." .

ns1:MenuDeSistemaHorizontal a ns1:Parametro ;
    rdfs:label "Menú de sistema horizontal" ;
    ns1:identificador "SYSHMENU" ;
    ns1:textoExtracto "Valores posibles: Deshabilitado / Páginas / Canales / Componentes. Valor por defecto: Deshabilitado." .

ns1:MenuDeSistemaVertical_2eac271054 a ns1:Parametro ;
    rdfs:label "Menú de sistema vertical" ;
    ns1:identificador "SYSVMENU" ;
    ns1:textoExtracto "Valores posibles: Deshabilitado / Páginas / Canales / Componentes. Valor por defecto: Deshabilitado." .

ns1:Parametro_56a790dfba a ns1:Parametro ;
    rdfs:label "Función de la tecla de cambio" ;
    ns1:identificador "FUNCTION" ;
    ns1:textoExtracto "Valores posibles: Sg Página / Sg Canal / Menú. Valor por defecto: Sg Página." .

ns1:PersonalizacionDeLaTeclaDeCambio a ns1:Parametro ;
    rdfs:label "Personalización de la tecla de cambio" ;
    ns1:textoExtracto "Esta tabla muestra los parámetros para configurar la tecla de cambio." .

