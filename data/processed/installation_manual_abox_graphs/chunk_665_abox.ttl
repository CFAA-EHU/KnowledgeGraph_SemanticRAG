@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaCHANGEKEY a ns1:Tabla ;
    rdfs:label "Tabla CHANGEKEY" ;
    ns1:textoExtracto "Parámetro incluido en la tabla CHANGEKEY." ;
    ns1:tieneComponente ns1:MenuDeSistemaVertical,
        ns1:MenuDeSistemaVertical_2eac271054 .

ns1:MenuDeSistemaVertical a ns1:Parametro ;
    rdfs:label "Menú de sistema vertical" ;
    ns1:identificador "SYSHMENU" ;
    ns1:textoExtracto "SYSVMENU Menú de sistema vertical. Valores posibles: Deshabilitado / Páginas / Canales / Componentes. Valor por defecto: Deshabilitado." .

ns1:MenuDeSistemaVertical_2eac271054 a ns1:Parametro ;
    rdfs:label "Menú de sistema vertical" ;
    ns1:identificador "SYSVMENU" ;
    ns1:textoExtracto "SYSVMENU Menú de sistema vertical. Valores posibles: Deshabilitado / Páginas / Canales / Componentes. Valor por defecto: Deshabilitado." .

