@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConfiguracionDelTecladoTeclaNEXTCanales a ns1:Parametro ;
    rdfs:label "Configuración del teclado (tecla [NEXT]) - Canales" ;
    ns1:identificador "Canales" ;
    ns1:textoExtracto "El menú muestra la lista de canales disponibles." .

ns1:ConfiguracionDelTecladoTeclaNEXTComponentes a ns1:Parametro ;
    rdfs:label "Configuración del teclado (tecla [NEXT]) - Componentes" ;
    ns1:identificador "Componentes" ;
    ns1:textoExtracto "El menú muestra los componentes o modos de trabajo del CNC." .

ns1:ConfiguracionDelTecladoTeclaNEXTDeshabilitado a ns1:Parametro ;
    rdfs:label "Configuración del teclado (tecla [NEXT]) - Deshabilitado" ;
    ns1:identificador "Deshabilitado" ;
    ns1:textoExtracto "El menú estará deshabilitado." .

ns1:ConfiguracionDelTecladoTeclaNEXTPaginas a ns1:Parametro ;
    rdfs:label "Configuración del teclado (tecla [NEXT]) - Páginas" ;
    ns1:identificador "Páginas" ;
    ns1:textoExtracto "El menú muestra las distintas páginas o pantallas del modo de trabajo activo." .

