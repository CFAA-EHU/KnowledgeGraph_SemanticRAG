    ns1:documentadoEn ns1:TablaConfiguracionTeclaEscape ;
    ns1:identificador "NPREVIOUS" ;
    ns1:textoExtracto "Valores posibles: De 1 a 5. Valor por defecto: 1." .

ns1:Parametro_56a790dfba a ns1:Parametro ;
    rdfs:label "Función asociada a la tecla de escape" ;
    ns1:documentadoEn ns1:TablaConfiguracionTeclaEscape ;
    ns1:identificador "FUNCTION" ;
    ns1:textoExtracto "Valores posibles: Menú previo / Componente previo / Menú-Componente previo. Valor por defecto: Menú previo." .

