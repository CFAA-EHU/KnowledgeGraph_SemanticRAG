@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Comando_CNCRD a ex:InterfazUsuario ;
    rdfs:label "Comando CNCRD (lectura de variables síncronas)"@es ;
    ex:textoExtracto "<condición> = CNCRD (G.FREAL, R12, M12) CPS R12 GT 2000 = ... no hace falta esperar para consultar los datos porque las variables síncronas se resuelven inmediatamente."@es ;
    ex:monitoreaParametro ex:Parametro_R12 .

ex:Parametro_R12 a ex:Parametro ;
    rdfs:label "Registro R12"@es ;
    ex:textoExtracto "R12"@es ;
    ex:valor "2000"^^xsd:integer .

ex:Comando_CNCWR a ex:InterfazUsuario ;
    rdfs:label "Comando CNCWR (escritura de variables síncronas)"@es ;
    ex:textoExtracto "<condición> = CNCWR (R13, PLC.TIMER, M13) Inicializa el reloj habilitado por el PLC con el valor que contiene el registro R13."@es ;
    ex:controla ex:Parametro_PLC_TIMER ;
    ex:monitoreaParametro ex:Parametro_R13 .

ex:Parametro_R13 a ex:Parametro ;
    rdfs:label "Registro R13"@es ;
    ex:textoExtracto "R13"@es .

ex:Parametro_PLC_TIMER a ex:Parametro ;
    rdfs:label "Temporizador PLC.TIMER"@es ;
    ex:textoExtracto "PLC.TIMER"@es .

ex:Comando_CNCEX a ex:InterfazUsuario ;
    rdfs:label "Comando CNCEX (ejecución de bloques CNC)"@es ;
    ex:textoExtracto "CNCEX Ejecución de un bloque de CNC. Permite ejecutar un bloque de CNC en el canal indicado, incluidas llamadas a subrutinas o a programas completos. Su formato de programación es el siguiente. CNCEX (bloque, marca, canal)"@es ;
    ex:ejecutadoPor ex:Canal_CNC_Principal ;
    ex:controla ex:Marca_FREE .

ex:Canal_CNC_Principal a ex:Componente ;
    rdfs:label "Canal CNC principal"@es ;
    ex:textoExtracto "el primer canal o canal principal"@es ;
    ex:identificador "1" .

ex:Canal_CNC_Secundario a ex:Componente ;
    rdfs:label "Canal CNC secundario"@es ;
    ex:textoExtracto "canal 2"@es ;
    ex:identificador "2" .

ex:Marca_FREE a ex:Parametro ;
    rdfs:label "Marca FREE (disponibilidad del canal CNC)"@es ;
    ex:textoExtracto "el canal del CNC activa la marca FREE para indicar al PLC que está listo para aceptar un nuevo bloque"@es .

ex:Marca_PLCABORT a ex:Parametro ;
    rdfs:label "Marca PLCABORT (abortar ejecución CNCEX)"@es ;
    ex:textoExtracto "La ejecución del comando CNCEX se podrá anular mediante la marca PLCABORT"@es .

ex:Comando_MOVEABS a ex:InterfazUsuario ;
    rdfs:label "Comando MOVEABS (movimiento absoluto)"@es ;
    ex:textoExtracto "Comandos MOVEABS, MOVEADD y MOVEINF. Los movimientos de ejes independientes se pueden programar directamente [...] El comando MOVEABS se ejecuta directamente en el interpolador"@es .

ex:Comando_MOVEADD a ex:InterfazUsuario ;
    rdfs:label "Comando MOVEADD (movimiento incremental)"@es ;
    ex:textoExtracto "Comandos MOVEABS, MOVEADD y MOVEINF. Los movimientos de ejes independientes se pueden programar directamente [...] Los comandos MOVE* se ejecutan directamente en el interpolador"@es .

ex:Comando_MOVEINF a ex:InterfazUsuario ;
    rdfs:label "Comando MOVEINF (movimiento infinito)"@es ;
    ex:textoExtracto "Comandos MOVEABS, MOVEADD y MOVEINF. Los movimientos de ejes independientes se pueden programar directamente [...] Los comandos MOVE* se ejecutan directamente en el interpolador"@es .

ex:Interpolador_CNC a ex:ComponenteElectrico ;
    rdfs:label "Interpolador del CNC"@es ;
    ex:textoExtracto "los comandos MOVE* se ejecutan directamente en el interpolador (habitualmente ejecución más rápida)"@es .