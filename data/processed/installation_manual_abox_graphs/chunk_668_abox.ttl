@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaESCAPEKEY a ns1:Tabla ;
    rdfs:label "ESCAPEKEY" ;
    ns1:textoExtracto "Parámetro incluido en la tabla ESCAPEKEY." ;
    ns1:tieneComponente ns1:NumeroMaximoDeComponentesPreviosMemorizados .

ns1:NumeroMaximoDeComponentesPreviosMemorizados a ns1:Parametro ;
    rdfs:label "Número máximo de componentes previos memorizados" ;
    ns1:identificador "NPREVIOUS" ;
    ns1:textoExtracto "NPREVIOUS Número máximo de componentes previos memorizados. Valores posibles: De 1 a 5. Valor por defecto: 1." .

