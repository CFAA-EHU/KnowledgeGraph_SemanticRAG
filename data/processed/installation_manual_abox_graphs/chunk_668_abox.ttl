@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:CNCRD a ex:Parametro ;
    rdfs:label "CNCRD" ;
    ex:textoExtracto "Ejemplos de acceso a variables síncronas: <condición> = CNCRD (G.FREAL, R12, M12)" .

ex:CNCWR a ex:Parametro ;
    rdfs:label "CNCWR" ;
    ex:textoExtracto "Inicializa el reloj habilitado por el PLC con el valor que contiene el registro R13. = CNCWR (R13, PLC.TIMER, M13)" .

ex:CNCEX a ex:Parametro ;
    rdfs:label "CNCEX" ;
    ex:textoExtracto "Ejecución de un bloque de CNC. Permite ejecutar un bloque de CNC en el canal indicado, incluidas llamadas a subrutinas o a programas completos. Su funcionamiento es similar a ejecutar un bloque en MDI. ... = CNCEX (bloque, marca, canal) ... = CNCEX (G00 X0 Y0, M99, 2) ... = CNCEX (#CALL sub3.nc, M34)" .

ex:FREE a ex:Parametro ;
    rdfs:label "FREE" ;
    ex:textoExtracto "Una vez ejecutado el bloque, el canal del CNC activa la marca FREE para indicar al PLC que está listo para aceptar un nuevo bloque." .

ex:PLCABORT a ex:Parametro ;
    rdfs:label "PLCABORT" ;
    ex:textoExtracto "La ejecución del comando CNCEX se podrá anular mediante la marca PLCABORT." .

ex:MOVEABS a ex:Parametro ;
    rdfs:label "MOVEABS" ;
    ex:textoExtracto "Comandos MOVEABS, MOVEADD y MOVEINF. Los movimientos de ejes independientes se pueden programar directamente o mediante el comando CNCEX" .

ex:MOVEADD a ex:Parametro ;
    rdfs:label "MOVEADD" ;
    ex:textoExtracto "Comandos MOVEABS, MOVEADD y MOVEINF. Los movimientos de ejes independientes se pueden programar directamente o mediante el comando CNCEX" .

ex:MOVEINF a ex:Parametro ;
    rdfs:label "MOVEINF" ;
    ex:textoExtracto "Comandos MOVEABS, MOVEADD y MOVEINF. Los movimientos de ejes independientes se pueden programar directamente o mediante el comando CNCEX" .

ex:InterfazUsuario_CNC a ex:InterfazUsuario ;
    rdfs:label "Interfaz de usuario del CNC" ;
    ex:textoExtracto "Ejecución de un bloque de CNC. Permite ejecutar un bloque de CNC en el canal indicado, incluidas llamadas a subrutinas o a programas completos. Su funcionamiento es similar a ejecutar un bloque en MDI." ;
    ex:compuestoPor ex:CNCEX .

ex:Sistema_PLC a ex:Sistema ;
    rdfs:label "Sistema PLC" ;
    ex:textoExtracto "Inicializa el reloj habilitado por el PLC con el valor que contiene el registro R13." ;
    ex:compuestoPor ex:CNCWR, ex:PLCABORT .

ex:Sistema_CNC a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "Ejecución de un bloque de CNC. Permite ejecutar un bloque de CNC en el canal indicado, incluidas llamadas a subrutinas o a programas completos." ;
    ex:compuestoPor ex:CNCRD, ex:CNCEX, ex:FREE, ex:MOVEABS, ex:MOVEADD, ex:MOVEINF .