@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ComandoCNCEX a ex:Parametro ;
    rdfs:label "CNCEX" ;
    ex:textoExtracto "El comando CNCEX se ejecuta a través de una canal del CNC" .

ex:ComandoMOVE a ex:Parametro ;
    rdfs:label "MOVE*" ;
    ex:textoExtracto "los comandos MOVE* se ejecutan directamente en el interpolador" .

ex:CanalCNC a ex:ComponenteElectrico ;
    rdfs:label "canal del CNC" ;
    ex:textoExtracto "a través de una canal del CNC" .

ex:Interpolador a ex:Componente ;
    rdfs:label "interpolador" ;
    ex:textoExtracto "directamente en el interpolador" .