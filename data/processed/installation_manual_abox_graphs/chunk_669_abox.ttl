@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_60a2edf76c a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Se denomina Teclado de JOG simulado a una ventana que se superpone a la pantalla del CNC y que permite simular las teclas de JOG y las teclas de acceso a los modos de trabajo." .

ns1:TecladoDeJOGSimulado a ns1:Parametro ;
    rdfs:label "Teclado de JOG simulado" ;
    ns1:identificador "SIMJOGPANEL" ;
    ns1:textoExtracto "SIMJOGPANEL Teclado de JOG simulado. Valores posibles: Sí / No. Valor por defecto: No." .

