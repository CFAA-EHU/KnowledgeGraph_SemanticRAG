@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SalidaDeWindowsAlCerrarElCNC a ns1:Parametro ;
    rdfs:label "Salida de Windows al cerrar el CNC" ;
    ns1:identificador "WINEXIT" ;
    ns1:textoExtracto "WINEXIT Salida de Windows al cerrar el CNC. Valores posibles: Sí / No. Valor por defecto: No (no se cierra Windows). Este parámetro indica si al salir del CNC, con [ALT][F4], se cierra Windows." .

