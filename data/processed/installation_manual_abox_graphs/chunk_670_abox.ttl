@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Instruccion_MOVEADD_670
    a               ex:TareaMantenimiento ;
    rdfs:label      "Instrucción MOVE ADD para movimientos independientes"@es ;
    ex:textoExtracto "Los movimientos independientes se pueden ejecutar de las siguientes maneras. [...] () = CNCEX(#MOVE ADD [X100,F100,NULL], M120,1) () = MOVEADD(X,100000,100000,NULL)"@es ;
    ex:identificador "MOVE ADD" .

ex:Parametro_X100_670
    a               ex:Parametro ;
    rdfs:label      "Parámetro X100 (posición)"@es ;
    ex:textoExtracto "X100"@es ;
    ex:valor         "100000" ;
    ex:monitoreaParametro ex:Instruccion_MOVEADD_670 .

ex:Parametro_F100_670
    a               ex:Parametro ;
    rdfs:label      "Parámetro F100 (velocidad/avance)"@es ;
    ex:textoExtracto "F100"@es ;
    ex:valor         "100000" ;
    ex:monitoreaParametro ex:Instruccion_MOVEADD_670 .

ex:Parametro_M120_670
    a               ex:Parametro ;
    rdfs:label      "Parámetro M120 (código auxiliar)"@es ;
    ex:textoExtracto "M120"@es ;
    ex:valor         "1" ;
    ex:monitoreaParametro ex:Instruccion_MOVEADD_670 .