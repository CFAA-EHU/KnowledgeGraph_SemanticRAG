@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TipoDeGraficoEnCadaCanal a ns1:Parametro ;
    rdfs:label "Tipo de gráfico en cada canal" ;
    ns1:documentadoEn ns1:TablaConfiguracionGraficos ;
    ns1:identificador "GRAPHTYPECH n" ;
    ns1:textoExtracto "GRAPHTYPECH n Tipo de gráfico en cada canal." .

ns1:ListaDeGraficosEnCadaCanal a ns1:Parametro ;
    rdfs:label "Lista de gráficos en cada canal" ;
    ns1:identificador "GRAPHTYPE" ;
    ns1:textoExtracto "GRAPHTYPE Lista de gráficos en cada canal." .

ns1:TablaConfiguracionGraficos a ns1:Tabla ;
    rdfs:label "Tabla para definir la configuración de los gráficos en cada canal" ;
    ns1:ilustradoEn ns1:ListaDeGraficosEnCadaCanal ;
    ns1:textoExtracto "este parámetro muestra la tabla para definir la configuración de los gráficos en cada canal." .

