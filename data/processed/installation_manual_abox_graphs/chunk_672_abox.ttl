@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_2313205137 a ns1:Parametro ;
    rdfs:label "Parámetro DRIVEVAR" ;
    ns1:identificador "DRIVEVAR" ;
    ns1:textoExtracto "El parámetro DRIVEVAR permite definir la lista de variables DRV, aquellas que permiten acceder a las variables y/o parámetros de los reguladores digitales desde el programa pieza, modo MDI/MDA, PLC o interfaz." .

ns1:TablaVariablesReguladores a ns1:Tabla ;
    rdfs:label "DRIVEVAR Tabla de variables de los reguladores" ;
    ns1:ilustra ns1:SistemaReguladorMechatrolink,
        ns1:SistemaReguladorSercos ;
    ns1:textoExtracto "DRIVEVAR Tabla de variables de los reguladores. El parámetro DRIVEVAR permite definir la lista de variables DRV, aquellas que permiten acceder a las variables y/o parámetros de los reguladores digitales desde el programa pieza, modo MDI/MDA, PLC o interfaz." .

ns1:SistemaReguladorMechatrolink a ns1:Sistema ;
    rdfs:label "Sistema Regulador Mechatrolink" ;
    ns1:textoExtracto "Las variables DRV pueden acceder a las variables y/o parámetros de los servos. El acceso a las variables del regulador será siempre de solo lectura, mientras que el acceso a los parámetros podrá ser de lectura o escritura." .

ns1:SistemaReguladorSercos a ns1:Sistema ;
    rdfs:label "Sistema Regulador Sercos" ;
    ns1:textoExtracto "Las variables DRV pueden acceder a las variables del regulador. El acceso a las variables podrá ser solo lectura o de lectura y escritura." .

