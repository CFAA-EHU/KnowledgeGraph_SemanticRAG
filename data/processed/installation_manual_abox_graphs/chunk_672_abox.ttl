@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_cam a ex:Parametro ;
    ex:identificador "cam" ;
    ex:textoExtracto "Parámetro. | cam | Número de leva." ;
    rdfs:label "Número de leva" .

ex:Parametro_master a ex:Parametro ;
    ex:identificador "master" ;
    ex:textoExtracto "Parámetro. | master | Nombre del eje maestro." ;
    rdfs:label "Nombre del eje maestro" .

ex:Parametro_TIME a ex:Parametro ;
    ex:identificador "TIME" ;
    ex:textoExtracto "Parámetro. | TIME | Leva de tiempo. Si en lugar de programar un nombre de eje se programa \"TIME\", la leva se interpreta como una leva en tiempo." ;
    rdfs:label "Leva de tiempo" .

ex:Parametro_slave a ex:Parametro ;
    ex:identificador "slave" ;
    ex:textoExtracto "Parámetro. | slave | Nombre del eje esclavo." ;
    rdfs:label "Nombre del eje esclavo" .

ex:Parametro_master_off a ex:Parametro ;
    ex:identificador "master_off" ;
    ex:textoExtracto "Parámetro. | master_off | Offset para el eje maestro." ;
    rdfs:label "Offset para el eje maestro" .

ex:Parametro_slave_off a ex:Parametro ;
    ex:identificador "slave_off" ;
    ex:textoExtracto "Parámetro. | slave_off | Offset para el eje esclavo." ;
    rdfs:label "Offset para el eje esclavo" .

ex:Parametro_range_master a ex:Parametro ;
    ex:identificador "range_master" ;
    ex:textoExtracto "Parámetro. | range_master | Escala o rango de activación del eje maestro." ;
    rdfs:label "Escala o rango de activación del eje maestro" .

ex:Parametro_range_slave a ex:Parametro ;
    ex:identificador "range_slave" ;
    ex:textoExtracto "Parámetro. | range_slave | Escala o rango de activación del eje esclavo." ;
    rdfs:label "Escala o rango de activación del eje esclavo" .

ex:Parametro_type a ex:Parametro ;
    ex:identificador "type" ;
    ex:textoExtracto "Parámetro. | type | Define el tipo de leva; periódica o no periódica. Se programa mediante los parámetros \"ONCE\" (leva no periódica) o \"CONT\" (leva periódica)." ;
    rdfs:label "Define el tipo de leva; periódica o no periódica" .