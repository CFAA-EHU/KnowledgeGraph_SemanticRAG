@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ModoLeva a ex:ModoOperacion ;
    ex:textoExtracto "Modo de leva. Se pueden activar dos tipos de leva; levas en función de tiempo o levas en función de la posición de un eje maestro." .

ex:LevaTiempo a ex:Componente ;
    ex:textoExtracto "levas en función de tiempo" .

ex:LevaPosicion a ex:Componente ;
    ex:textoExtracto "levas en función de la posición de un eje maestro" .

ex:ParametroMaquina a ex:Parametro ;
    ex:textoExtracto "parámetros máquina" .

ex:EjeMaestro a ex:Componente ;
    ex:textoExtracto "eje maestro" .

ex:PosicionMasterOff a ex:Parametro ;
    ex:textoExtracto "master_off" .

ex:PosicionMasterOffRange a ex:Parametro ;
    ex:textoExtracto "master_off + range_master" .

ex:PosicionSlaveOff a ex:Parametro ;
    ex:textoExtracto "slave_off" .

ex:PosicionSlaveOffRange a ex:Parametro ;
    ex:textoExtracto "slave_off + range_slave" .

ex:ParametroType a ex:Parametro ;
    ex:textoExtracto "parámetro type" .

ex:LevaPeriodica a ex:Componente ;
    ex:textoExtracto "leva periódica" .

ex:LevaNoPeriodica a ex:Componente ;
    ex:textoExtracto "leva no periódica" .

ex:ValorTypeOnce a ex:Parametro ;
    ex:identificador "ONCE" ;
    ex:textoExtracto "al parámetro type el valor \"ONCE\"" .

ex:ValorTypeCont a ex:Parametro ;
    ex:identificador "CONT" ;
    ex:textoExtracto "al parámetro type el valor \"CONT\"" .

ex:ComandoCamOff a ex:Componente ;
    ex:textoExtracto "comando CAM OFF" .

ex:ModoEjecucionNoPeriodica a ex:ModoOperacion ;
    ex:textoExtracto "Se define asignando al parámetro type el valor \"ONCE\". En este modo se mantiene la sincronización para el rango definido del eje maestro." .

ex:ModoEjecucionPeriodica a ex:ModoOperacion ;
    ex:textoExtracto "Se define asignando al parámetro type el valor \"CONT\". En este modo, al llegar al final del rango del eje maestro se recalcula el offset para volver a ejecutar la leva, desplazada en dicho rango." .

ex:SistemaLevaElectronica a ex:Sistema ;
    ex:textoExtracto "Modo de leva. Se pueden activar dos tipos de leva; levas en función de tiempo o levas en función de la posición de un eje maestro." ;
    ex:compuestoPor ex:LevaTiempo, ex:LevaPosicion, ex:EjeMaestro, ex:ParametroMaquina, ex:ParametroType, ex:ComandoCamOff, ex:ModoEjecucionNoPeriodica, ex:ModoEjecucionPeriodica ;
    ex:tieneComponente ex:PosicionMasterOff, ex:PosicionMasterOffRange, ex:PosicionSlaveOff, ex:PosicionSlaveOffRange, ex:ValorTypeOnce, ex:ValorTypeCont .