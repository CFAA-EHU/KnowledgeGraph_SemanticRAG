@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaVariablesRegulador a ns1:Tabla ;
    rdfs:label "Tabla de Variables del Regulador" ;
    ns1:documentadoEn ns1:SistemaRegulador ;
    ns1:textoExtracto "DRIVEVAR | SIZE | Número de elementos de la tabla de variables del regulador" .

ns1:NumeroDeElementosDeLaTablaDeVariablesDelRegulador a ns1:Parametro ;
    rdfs:label "Número de elementos de la tabla de variables del regulador" ;
    ns1:identificador "DRIVEVAR" ;
    ns1:textoExtracto "SIZE | Número de elementos de la tabla de variables del regulador" .

ns1:SistemaRegulador a ns1:Sistema ;
    rdfs:label "Sistema Regulador" ;
    ns1:textoExtracto "Características y limitaciones de los dispositivos Mechatrolink." ;
    ns1:tieneComponente ns1:NumeroDeElementosDeLaTablaDeVariablesDelRegulador .

