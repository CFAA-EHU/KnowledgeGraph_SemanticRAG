@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoLevaElectronica
    a ex:ModoOperacion ;
    rdfs:label "Modo de leva electrónica" ;
    ex:textoExtracto "Modo de leva. Se pueden activar dos tipos de leva; levas en función de tiempo o levas en función de la posición de un eje maestro." .

ex:ParametroType
    a ex:Parametro ;
    rdfs:label "Parámetro 'type'" ;
    ex:textoExtracto "La selección se realiza mediante el parámetro type." ;
    ex:valor "ONCE" , "CONT" .

ex:ParametroMasterOff
    a ex:Parametro ;
    rdfs:label "Parámetro 'master_off'" ;
    ex:textoExtracto "Rango de activación del eje maestro. La leva se activa cuando el eje maestro se encuentra entre las posiciones 'master_off' y 'master_off + range_master'." .

ex:ParametroRangeMaster
    a ex:Parametro ;
    rdfs:label "Parámetro 'range_master'" ;
    ex:textoExtracto "Rango de activación del eje maestro. La leva se activa cuando el eje maestro se encuentra entre las posiciones 'master_off' y 'master_off + range_master'." .

ex:ParametroSlaveOff
    a ex:Parametro ;
    rdfs:label "Parámetro 'slave_off'" ;
    ex:textoExtracto "Rango para el eje esclavo. La leva aplica al eje esclavo cuando éste se encuentra entre 'slave_off' y 'slave_off + range_slave'." .

ex:ParametroRangeSlave
    a ex:Parametro ;
    rdfs:label "Parámetro 'range_slave'" ;
    ex:textoExtracto "Rango para el eje esclavo. La leva aplica al eje esclavo cuando éste se encuentra entre 'slave_off' y 'slave_off + range_slave'." .

ex:ComandoCAMOFF
    a ex:InterfazUsuario ;
    rdfs:label "Comando CAM OFF" ;
    ex:textoExtracto "Alcanzado dicho comando, la ejecución de la leva finalizará la próxima vez que sea alcanzado el final del perfil de leva." .

ex:LevaPeriodica
    a ex:ModoOperacion ;
    rdfs:label "Leva periódica" ;
    ex:textoExtracto "Periódica. Se define asignando al parámetro type el valor 'CONT'. En este modo, al llegar al final del rango del eje maestro se recalcula el offset para volver a ejecutar la leva, desplazada en dicho rango." ;
    ex:monitoreaParametro ex:ParametroType .

ex:LevaNoPeriodica
    a ex:ModoOperacion ;
    rdfs:label "Leva no periódica" ;
    ex:textoExtracto "No periódica. Se define asignando al parámetro type el valor 'ONCE'. En este modo se mantiene la sincronización para el rango definido del eje maestro." ;
    ex:monitoreaParametro ex:ParametroType .

ex:ModoLevaElectronica
    ex:tieneComponente ex:LevaPeriodica , ex:LevaNoPeriodica ;
    ex:monitoreaParametro ex:ParametroMasterOff , ex:ParametroRangeMaster , ex:ParametroSlaveOff , ex:ParametroRangeSlave .