@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ModoOperacion_LevaElectronica a ex:ModoOperacion ;
    ex:textoExtracto "En los dos modos se mantiene la sincronización hasta la ejecución del comando CAM OFF." .

ex:Comando_CAM_OFF a ex:Parametro ;
    ex:identificador "CAM OFF" ;
    ex:textoExtracto "Alcanzado dicho comando, la ejecución de la leva finalizará la próxima vez que sea alcanzado el final del perfil de leva." .

ex:Comando_CAM_SELECT a ex:Parametro ;
    ex:identificador "CAM SELECT" ;
    ex:textoExtracto "Seleccionar (CAM SELECT) o anular una leva de archivo (CAM DESELECT)." .

ex:Comando_CAM_DESELECT a ex:Parametro ;
    ex:identificador "CAM DESELECT" ;
    ex:textoExtracto "Seleccionar (CAM SELECT) o anular una leva de archivo (CAM DESELECT)." .

ex:Sistema_LevaElectronica a ex:Sistema ;
    ex:textoExtracto "Los datos de la leva pueden estar definidos en un archivo, el cual se puede cargar desde el CNC o el PLC." ;
    ex:compuestoPor ex:Comando_CAM_OFF, ex:Comando_CAM_SELECT, ex:Comando_CAM_DESELECT .