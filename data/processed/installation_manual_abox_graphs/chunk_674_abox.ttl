@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroDeVariablesAConsultarEnElRegulador a ns1:Parametro ;
    rdfs:label "Número de variables a consultar en el regulador" ;
    ns1:documentadoEn ns1:TablaVariablesReguladores ;
    ns1:identificador "DRV.SIZE" ;
    ns1:textoExtracto "Este parámetro establece el número de variables a consultar en el regulador." .

ns1:TablaVariablesReguladores a ns1:Tabla ;
    rdfs:label "Tabla para definir la lista de variables DRV" ;
    ns1:textoExtracto "Este parámetro muestra la tabla para definir la lista de variables DRV." .

