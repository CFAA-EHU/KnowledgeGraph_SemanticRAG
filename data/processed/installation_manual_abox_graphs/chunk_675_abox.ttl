@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ComandoCAMSELECT a ex:AccionProhibida ;
    ex:textoExtracto "CAM SELECT (cam, file)" .

ex:ComandoCAMDESELECT a ex:AccionProhibida ;
    ex:textoExtracto "CAM DESELECT (cam)" .

ex:ComandoCAMON a ex:AccionProhibida ;
    ex:textoExtracto "#CAM ON (desde el CNC) o el comando CAM ON (desde el PLC)" .

ex:ComandoCAMOFF a ex:AccionProhibida ;
    ex:textoExtracto "el comando CAM OFF" .

ex:TablaLevasParametrosMaquina a ex:Parametro ;
    ex:textoExtracto "tabla de levas de los parámetros máquina" .

ex:SistemaCNC a ex:Sistema ;
    ex:textoExtracto "CNC" .

ex:SistemaPLC a ex:Sistema ;
    ex:textoExtracto "PLC" .