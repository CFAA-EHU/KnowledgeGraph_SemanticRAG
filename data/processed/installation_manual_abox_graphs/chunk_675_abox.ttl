@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IdentificadorDelParametro0000FFFFODeLaVariable0F_95d3b36f02 a ns1:Parametro ;
    rdfs:label "Identificador del parámetro (0000-FFFF) o de la variable (0-F)" ;
    ns1:textoExtracto "ID | Identificador del parámetro (0000-FFFF) o de la variable (0-F) a consultar en el dispositivo." .

ns1:IdentificadorIDSercosDeLaVariable a ns1:Parametro ;
    rdfs:label "Identificador ID Sercos de la variable" ;
    ns1:textoExtracto "ID | Identificador ID Sercos de la variable a consultar en el regulador." .

ns1:MnemonicoAsignadoALaVariableDRV a ns1:Parametro ;
    rdfs:label "Mnemónico asignado a la variable DRV" ;
    ns1:textoExtracto "MNEMONIC | Mnemónico asignado a la variable DRV. El acceso a la variable desde el CNC será de la forma: (V.)DRV.{mnemónico}.{eje} (V.)DRV.{mnemónico}.{cabezal}" .

ns1:ModoDeAcceso a ns1:Parametro ;
    rdfs:label "Modo de acceso" ;
    ns1:textoExtracto "MODE | Modo de acceso. El acceso a las variables podrá ser solo lectura o de lectura y escritura." .

ns1:ModoDeAcceso_355fae2179 a ns1:Parametro ;
    rdfs:label "Modo de acceso" ;
    ns1:textoExtracto "MODE | Modo de acceso." .

ns1:NombreDelEjeOCabezalAlQueAccedeLaVariable a ns1:Parametro ;
    rdfs:label "Nombre del eje o cabezal al que accede la variable" ;
    ns1:textoExtracto "AXIS | Nombre del eje o cabezal al que accede la variable; si se define como \"*\", todos los ejes y cabezales." .

ns1:TablaParametrosMaquinaOEM a ns1:Tabla ;
    rdfs:label "Tabla de parámetros máquina OEM" ;
    ns1:textoExtracto "Campo. | Significado. | MNEMONIC | Mnemónico asignado a la variable DRV. El acceso a la variable desde el CNC será de la forma: (V.)DRV.{mnemónico}.{eje} (V.)DRV.{mnemónico}.{cabezal}" .

ns1:TablaParametrosMecharotlink a ns1:Tabla ;
    rdfs:label "Tabla de parámetros Mechatrolink" ;
    ns1:textoExtracto "Campo. | Significado. | MNEMONIC | Mnemónico asignado a la variable DRV. El acceso a la variable desde el CNC será de la forma: (V.)DRV.{mnemónico}.{eje} (V.)DRV.{mnemónico}.{cabezal}" .

ns1:TipoDeAccesoSincronoOAsincrono a ns1:Parametro ;
    rdfs:label "Tipo de acceso, síncrono o asíncrono" ;
    ns1:textoExtracto "TYPE | Tipo de acceso, síncrono o asíncrono. Las variables de acceso síncrono se gestionan a través del canal cíclico." .

ns1:TipoDeConsultaVariableOParametro a ns1:Parametro ;
    rdfs:label "Tipo de consulta; variable o parámetro" ;
    ns1:textoExtracto "TYPE | Tipo de consulta; variable o parámetro." .

