@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IdentificadorDelParametroOVariable a ns1:Parametro ;
    rdfs:label "Identificador del parámetro o variable" ;
    ns1:textoExtracto "ID | Identificador del parámetro (0000-FFFF) o de la variable (0-F) a consultar en el dispositivo." .

ns1:ModoDeAccesoElAccesoALasVariablesDelReguladorSeraSiempreDeSoloLectura_d80c5eed84 a ns1:Parametro ;
    rdfs:label "Modo de acceso. El acceso a las variables del regulador será siempre de solo lectura, mientras que el acceso a los parámetros podrá ser de lectura o escritura" ;
    ns1:textoExtracto "MODE | Modo de acceso. El acceso a las variables del regulador será siempre de solo lectura, mientras que el acceso a los parámetros podrá ser de lectura o escritura." .

ns1:TipoDeConsultaVariableOParametro a ns1:Parametro ;
    rdfs:label "Tipo de consulta; variable o parámetro" ;
    ns1:textoExtracto "TYPE | Tipo de consulta; variable o parámetro." .

