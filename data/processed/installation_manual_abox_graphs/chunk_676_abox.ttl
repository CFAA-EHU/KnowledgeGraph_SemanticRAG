@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_cam a ex:Parametro ;
    rdfs:label "cam" ;
    ex:textoExtracto "Parámetro. cam Número de leva." ;
    ex:valor "Número de leva" .

ex:Parametro_file a ex:Parametro ;
    rdfs:label "file" ;
    ex:textoExtracto "Parámetro. file Nombre y dirección (path) del archivo con los datos de la leva." ;
    ex:valor "Nombre y dirección (path) del archivo con los datos de la leva." .