@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NodoDelRegulador2 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo del regulador 2" ;
    ns1:textoExtracto "Se desea modificar el FFGAIN del eje X (nodo 2)." .

ns1:Parametro_0dc6d920d1 a ns1:Parametro ;
    rdfs:label "VelocityFeedForwardPercentage" ;
    ns1:identificador "PP216" ;
    ns1:textoExtracto "La variable deberá actuar sobre el parámetro PP216 (VelocityFeedForwardPercentage) del regulador." .

ns1:VariableDRV a ns1:Parametro ;
    rdfs:label "DRV" ;
    ns1:identificador "DRV" ;
    ns1:textoExtracto "Mnemónico asignado a la variable DRV." .

