@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MOVE_ABS a ex:ModoOperacion ;
    rdfs:label "MOVE ABS" ;
    ex:textoExtracto "Movimiento de posicionamiento absoluto (MOVE ABS)" .

ex:MOVE_ADD a ex:ModoOperacion ;
    rdfs:label "MOVE ADD" ;
    ex:textoExtracto "Movimiento incremental (MOVE ADD)" .

ex:MOVE_INF a ex:ModoOperacion ;
    rdfs:label "MOVE INF" ;
    ex:textoExtracto "Movimiento sin fín (MOVE INF)" .

ex:FormatoProgramacion a ex:Esquema ;
    ex:textoExtracto "El formato de programación para cada uno de ellos es el siguiente. MOVE ABS (axis, pos, feed, blend) MOVE ADD (axis, pos, feed, blend) MOVE INF (axis, direction, feed, blend)" .