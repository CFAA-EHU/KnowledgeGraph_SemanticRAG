@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoOperacion_MoveAbs
    a ex:ModoOperacion ;
    rdfs:label "Movimiento de posicionamiento absoluto (MOVE ABS)"@es ;
    ex:textoExtracto "Movimiento de posicionamiento absoluto (MOVE ABS). El formato de programación para cada uno de ellos es el siguiente. MOVE ABS (axis, pos, feed, blend)"@es ;
    ex:identificador "MOVE ABS" .

ex:ModoOperacion_MoveAdd
    a ex:ModoOperacion ;
    rdfs:label "Movimiento de posicionamiento incremental (MOVE ADD)"@es ;
    ex:textoExtracto "incremental (MOVE ADD). El formato de programación para cada uno de ellos es el siguiente. MOVE ADD (axis, pos, feed, blend)"@es ;
    ex:identificador "MOVE ADD" .

ex:ModoOperacion_MoveInf
    a ex:ModoOperacion ;
    rdfs:label "Movimiento de posicionamiento sin fin (MOVE INF)"@es ;
    ex:textoExtracto "sin fín (MOVE INF). El formato de programación para cada uno de ellos es el siguiente. MOVE INF (axis, direction, feed, blend)"@es ;
    ex:identificador "MOVE INF" .

ex:Manual_EspecificoEjesIndependientes
    a ex:Manual ;
    rdfs:label "Manual específico de movimiento independiente y posicionamiento de ejes"@es ;
    ex:textoExtracto "Esta funcionalidad dispone de un manual específico. [...] Consulte la documentación específica para obtener más información acerca de los requisitos y el funcionamiento de los ejes independientes."@es .