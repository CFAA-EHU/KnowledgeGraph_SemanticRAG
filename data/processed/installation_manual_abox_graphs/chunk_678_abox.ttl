@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_axis a ex:Parametro ;
    ex:identificador "axis" ;
    ex:textoExtracto "Parámetro. | axis | Eje a posicionar." ;
    rdfs:label "axis" .

ex:Parametro_pos a ex:Parametro ;
    ex:identificador "pos" ;
    ex:textoExtracto "Parámetro. | pos | Posición a alcanzar." ;
    rdfs:label "pos" .

ex:Parametro_direction a ex:Parametro ;
    ex:identificador "direction" ;
    ex:textoExtracto "Parámetro. | direction | Sentido de desplazamiento. Se programa mediante los parámetros \"DIRPOS\" (sentido positivo) o \"DIRNEG\" (sentido negativo)." ;
    rdfs:label "direction" .

ex:Parametro_feed a ex:Parametro ;
    ex:identificador "feed" ;
    ex:textoExtracto "Parámetro. | feed | Avance de posicionamiento." ;
    rdfs:label "feed" .

ex:Parametro_blend a ex:Parametro ;
    ex:identificador "blend" ;
    ex:textoExtracto "Parámetro. | blend | Enlace dinámico con el siguiente bloque. Se programa mediante los parámetros \"PRESENT\", \"NULL\", \"NEXT\" o \"WAITINPOS\"." ;
    rdfs:label "blend" .

ex:Tabla_4_4_8 a ex:Tabla ;
    ex:textoExtracto "| Parámetro. | Significado. |\n| --- | --- |\n| axis | Eje a posicionar. |\n| pos | Posición a alcanzar. |\n| direction | Sentido de desplazamiento. Se programa mediante los parámetros \"DIRPOS\" (sentido positivo) o \"DIRNEG\" (sentido negativo). |\n| feed | Avance de posicionamiento. |\n| blend | Enlace dinámico con el siguiente bloque. Se programa mediante los parámetros \"PRESENT\", \"NULL\", \"NEXT\" o \"WAITINPOS\"." ;
    ex:tieneComponente ex:Parametro_axis, ex:Parametro_pos, ex:Parametro_direction, ex:Parametro_feed, ex:Parametro_blend .