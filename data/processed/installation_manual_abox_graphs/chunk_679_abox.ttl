@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoOperacion_NEXT ex:identificador "NEXT" ;
    rdfs:label "NEXT" ;
    ex:textoExtracto "El eje alcanza la posición indicada al avance especificado en el siguiente bloque." ;
    a ex:ModoOperacion .

ex:ModoOperacion_NULL ex:identificador "NULL" ;
    rdfs:label "NULL" ;
    ex:textoExtracto "El eje alcanza la posición indicada a avance nulo." ;
    a ex:ModoOperacion .

ex:ModoOperacion_WAITINPOS ex:identificador "WAITINPOS" ;
    rdfs:label "WAITINPOS" ;
    ex:textoExtracto "El eje alcanza la posición indicada a avance nulo y espera a estar en posición para ejecutar el siguiente bloque." ;
    a ex:ModoOperacion .

ex:Parametro_F_500_250 ex:identificador "F 500 250" ;
    rdfs:label "F 500 250" ;
    ex:textoExtracto "F 500 250" ;
    a ex:Parametro .