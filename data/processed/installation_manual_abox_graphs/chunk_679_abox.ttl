@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaParametrosFabricanteMTBPAR a ns1:Tabla ;
    rdfs:label "Tabla de parámetros del fabricante" ;
    ns1:textoExtracto "MTBPAR Tabla de parámetros del fabricante. Esta tabla ofrece 1000 parámetros genéricos para que el fabricante los pueda utilizar a modo de parámetros máquina." ;
    ns1:tieneComponente ns1:ListaDeParametrosDelFabricante,
        ns1:NumeroDeParametrosDelFabricante .

ns1:ListaDeParametrosDelFabricante a ns1:Parametro ;
    rdfs:label "Lista de parámetros del fabricante" ;
    ns1:textoExtracto "DATA Lista de parámetros del fabricante. Este parámetro muestra la tabla de parámetros del fabricante." .

ns1:NumeroDeParametrosDelFabricante a ns1:Parametro ;
    rdfs:label "Número de parámetros del fabricante" ;
    ns1:identificador "MTB.SIZE" ;
    ns1:textoExtracto "SIZE Número de parámetros del fabricante. Valores posibles: De 0 a 1000. Valor por defecto: 0." .

