@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Pos50mm a ex:Parametro ;
    rdfs:label "Pos 50mm" ;
    ex:identificador "125" ;
    ex:textoExtracto "125 Pos 50mm 100mm 150mm" .

ex:Pos100mm a ex:Parametro ;
