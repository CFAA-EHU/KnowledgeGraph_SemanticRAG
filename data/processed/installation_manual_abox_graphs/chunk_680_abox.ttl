@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaParametrosGenericos a ns1:Tabla ;
    rdfs:label "Tabla de Parámetros Genéricos" ;
    ns1:ilustra ns1:ValorDelParametroDeFabricantePor10000,
        ns1:ValorDelParametroDeFabricante_93d2ae4341 ;
    ns1:textoExtracto "VALUE Valor del parámetro. Valores posibles: Entre ±99999.9999. Valor por defecto: 0." .

ns1:ValorDelParametroDeFabricantePor10000 a ns1:Parametro ;
    rdfs:label "Valor del parámetro de fabricante (por 10000)" ;
    ns1:textoExtracto "VALUE Valor del parámetro. Valores posibles: Entre ±99999.9999. Valor por defecto: 0." .

ns1:ValorDelParametroDeFabricante_93d2ae4341 a ns1:Parametro ;
    rdfs:label "Valor del parámetro de fabricante" ;
    ns1:textoExtracto "VALUE Valor del parámetro. Valores posibles: Entre ±99999.9999. Valor por defecto: 0." .

