@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ValorDeLaVariableMTBP0 a ns1:Parametro ;
    rdfs:label "Valor de la variable MTB.P[0]"@es ;
    ns1:identificador "P0" ;
    ns1:textoExtracto "V.MTB.P[0] = 7" ;
    ns1:valor "7"@es .

ns1:ValorDeLaVariableMTBP8 a ns1:Parametro ;
    rdfs:label "Valor de la variable MTB.P[8]"@es ;
    ns1:identificador "P8" ;
    ns1:textoExtracto "V.MTB.P[8] = 12,5" ;
    ns1:valor "12,5"@es .

ns1:VariableMTBPFI a ns1:Parametro ;
    rdfs:label "Variable MTB.PF[i]"@es ;
    ns1:identificador "MTB.PF[i]" ;
    ns1:textoExtracto "V.MTB.PF[i]" .

ns1:VariableMTBPI a ns1:Parametro ;
    rdfs:label "Variable MTB.P[i]"@es ;
    ns1:identificador "MTB.P[i]" ;
    ns1:textoExtracto "V.MTB.P[i]" .

