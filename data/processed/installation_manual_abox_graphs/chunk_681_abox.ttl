@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ManualSincronizacionMovimiento a ex:Manual ;
    rdfs:label "Manual específico para funcionalidad de movimiento independiente y sincronización"@es ;
    ex:textoExtracto "Esta funcionalidad dispone de un manual específico. En este manual, que está usted leyendo, sólo se ofrece información orientativa sobre esta funcionalidad. Consulte la documentación específica para obtener más información acerca de los requisitos y el funcionamiento de los ejes independientes."@es .

ex:SistemaSincronizacionEjes a ex:Sistema ;
    rdfs:label "Sistema de sincronización de ejes independientes"@es ;
    ex:textoExtracto "Activar el movimiento de sincronización con las cotas reales (FOLLOW ON), con las cotas teóricas (TFOLLOW ON) o cancelar el movimiento de sincronización (FOLLOW OFF)."@es .

ex:ModoSincronizacionReal a ex:ModoOperacion ;
    rdfs:label "Modo FOLLOW ON (sincronización con cotas reales)"@es ;
    ex:identificador "FOLLOW ON" ;
    ex:textoExtracto "FOLLOW ON (master, slave, <Nnratio>, <Ddratio>, synctype)"@en .

ex:ModoSincronizacionTeorica a ex:ModoOperacion ;
    rdfs:label "Modo TFOLLOW ON (sincronización con cotas teóricas)"@es ;
    ex:identificador "TFOLLOW ON" ;
    ex:textoExtracto "TFOLLOW ON (master, slave, <Nnratio>, <Ddratio>, synctype)"@en .

ex:ModoCancelarSincronizacion a ex:ModoOperacion ;
    rdfs:label "Modo FOLLOW OFF (cancelar sincronización)"@es ;
    ex:identificador "FOLLOW OFF" ;
    ex:textoExtracto "FOLLOW OFF (slave)"@en .