@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_master a ex:Parametro ;
    rdfs:label "master" ;
    ex:textoExtracto "Nombre del eje maestro." ;
    ex:valor "master" .

ex:Parametro_slave a ex:Parametro ;
    rdfs:label "slave" ;
    ex:textoExtracto "Nombre del eje esclavo." ;
    ex:valor "slave" .

ex:Parametro_Nnratio a ex:Parametro ;
    rdfs:label "Nnratio" ;
    ex:textoExtracto "Opcional. Numerador del ratio de transmisión. Rotaciones del eje esclavo." ;
    ex:valor "Nnratio" .

ex:Parametro_Ddratio a ex:Parametro ;
    rdfs:label "Ddratio" ;
    ex:textoExtracto "Opcional. Denominador del ratio de transmisión. Rotaciones del eje maestro." ;
    ex:valor "Ddratio" .

ex:Parametro_synctype a ex:Parametro ;
    rdfs:label "synctype" ;
    ex:textoExtracto "Tipo de sincronización. Se programa mediante los parámetros \"POS\" (sincronización en posición) o \"VEL\" (sincronización en velocidad)." ;
    ex:valor "synctype" .