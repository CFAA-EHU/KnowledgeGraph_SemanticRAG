@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ArchivoMTBComments a ns1:DocumentoTecnico ;
    rdfs:label "Archivo MTBComments.txt" ;
    ns1:textoExtracto "Los comentarios se guardan en el archivo MTBComments.txt y se puede tener un archivo por cada idioma." .

ns1:Parametro_5111dfd7ba a ns1:Parametro ;
    rdfs:label "Parámetro OEM" ;
    ns1:identificador "OEM" ;
    ns1:textoExtracto "Descripción del parámetro OEM. Este campo ofrece la posibilidad de asociar una pequeña descripción al parámetro." .

