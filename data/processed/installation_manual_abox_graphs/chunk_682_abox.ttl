@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ParametrosSincronizacion_4_4_9 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de sincronización (4.4.9)"@es ;
    ex:textoExtracto """
| Parámetro. | Significado. |
| --- | --- |
| master | Nombre del eje maestro. |
| slave | Nombre del eje esclavo. |
| Nnratio | Opcional. Numerador del ratio de transmisión. Rotaciones del eje esclavo. |
| Ddratio | Opcional. Denominador del ratio de transmisión. Rotaciones del eje maestro. |
| synctype | Tipo de sincronización. Se programa mediante los parámetros \"POS\" (sincronización en posición) o \"VEL\" (sincronización en velocidad)."""@es ;
    ex:documentadoEn ex:Pagina_382_383 .

ex:Parametro_master
    a ex:Parametro ;
    rdfs:label "master" ;
    ex:identificador "master" ;
    ex:textoExtracto "Nombre del eje maestro."@es ;
    ex:documentadoEn ex:Tabla_ParametrosSincronizacion_4_4_9 .

ex:Parametro_slave
    a ex:Parametro ;
    rdfs:label "slave" ;
    ex:identificador "slave" ;
    ex:textoExtracto "Nombre del eje esclavo."@es ;
    ex:documentadoEn ex:Tabla_ParametrosSincronizacion_4_4_9 .

ex:Parametro_Nnratio
    a ex:Parametro ;
    rdfs:label "Nnratio" ;
    ex:identificador "Nnratio" ;
    ex:textoExtracto "Opcional. Numerador del ratio de transmisión. Rotaciones del eje esclavo."@es ;
    ex:documentadoEn ex:Tabla_ParametrosSincronizacion_4_4_9 .

ex:Parametro_Ddratio
    a ex:Parametro ;
    rdfs:label "Ddratio" ;
    ex:identificador "Ddratio" ;
    ex:textoExtracto "Opcional. Denominador del ratio de transmisión. Rotaciones del eje maestro."@es ;
    ex:documentadoEn ex:Tabla_ParametrosSincronizacion_4_4_9 .

ex:Parametro_synctype
    a ex:Parametro ;
    rdfs:label "synctype" ;
    ex:identificador "synctype" ;
    ex:textoExtracto "Tipo de sincronización. Se programa mediante los parámetros \"POS\" (sincronización en posición) o \"VEL\" (sincronización en velocidad)."@es ;
    ex:documentadoEn ex:Tabla_ParametrosSincronizacion_4_4_9 .

ex:Valor_synctype_POS
    a ex:Parametro ;
    rdfs:label "\"POS\"" ;
    ex:valor "POS" ;
    ex:textoExtracto "sincronización en posición"@es ;
    ex:documentadoEn ex:Parametro_synctype .

ex:Valor_synctype_VEL
    a ex:Parametro ;
    rdfs:label "\"VEL\"" ;
    ex:valor "VEL" ;
    ex:textoExtracto "sincronización en velocidad"@es ;
    ex:documentadoEn ex:Parametro_synctype .