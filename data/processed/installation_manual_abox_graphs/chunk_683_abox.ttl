@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_156e144c9b a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "CNC 8070" .

ns1:TablaLevasElectronicas a ns1:Tabla ;
    rdfs:label "Tabla de levas electrónicas" ;
    ns1:textoExtracto "CAMTABLE Tabla de levas electrónicas. Esta tabla muestra los parámetros para definir las levas electrónicas." ;
    ns1:tieneComponente ns1:ListaDeLevas,
        ns1:NumeroDeLevasElectronicas .

ns1:ListaDeLevas a ns1:Parametro ;
    rdfs:label "Lista de levas" ;
    ns1:textoExtracto "DATA Lista de levas electrónicas. Este parámetro muestra la lista de levas disponibles." .

ns1:NumeroDeLevasElectronicas a ns1:Parametro ;
    rdfs:label "Número de levas electrónicas" ;
    ns1:identificador "SIZE" ;
    ns1:textoExtracto "SIZE Número de levas electrónicas. Valores posibles: De 0 a 16. Valor por defecto: 0." .

