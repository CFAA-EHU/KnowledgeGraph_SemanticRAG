@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_Sincronizacion_POS
    a ex:Parametro ;
    rdfs:label "Parámetro de sincronización en posición (POS)" ;
    ex:textoExtracto "Se programa mediante los parámetros \"POS\" (sincronización en posición)" ;
    ex:identificador "POS" .

ex:Parametro_Sincronizacion_VEL
    a ex:Parametro ;
    rdfs:label "Parámetro de sincronización en velocidad (VEL)" ;
    ex:textoExtracto "Se programa mediante los parámetros \"VEL\" (sincronización en velocidad)" ;
    ex:identificador "VEL" .

ex:Variable_VASYNCVELOFF
    a ex:Parametro ;
    rdfs:label "Variable de offset de velocidad (V.A.SYNCVELOFF.xn)" ;
    ex:textoExtracto "Offset de velocidad. Permite variar la velocidad del eje esclavo independientemente de la velocidad del eje maestro. Se define con la variable V.A.SYNCVELOFF.xn" ;
    ex:identificador "V.A.SYNCVELOFF.xn" .

ex:Variable_GEARADJ
    a ex:Parametro ;
    rdfs:label "Variable de ajuste fino del ratio de transmisión (GEARADJ)" ;
    ex:textoExtracto "El ajuste fino del ratio se define con la variable GEARADJ" ;
    ex:identificador "GEARADJ" .

ex:Variable_VASYNCPOSOFF
    a ex:Parametro ;
    rdfs:label "Variable de offset de posición (V.A.SYNCPOSOFF.xn)" ;
    ex:textoExtracto "Offset de posición. Permite variar la posición del eje esclavo independientemente de la posición del eje maestro. Se define con la variable V.A.SYNCPOSOFF.xn" ;
    ex:identificador "V.A.SYNCPOSOFF.xn" .

ex:ModoOperacion_SincronizacionVelocidad
    a ex:ModoOperacion ;
    rdfs:label "Modo de sincronización en velocidad" ;
    ex:textoExtracto "Sincronización en velocidad. [...] FOLLOW ON (A1, Z, VEL)" ;
    ex:monitoreaParametro ex:Variable_VASYNCVELOFF ;
    ex:monitoreaParametro ex:Parametro_Sincronizacion_VEL .

ex:ModoOperacion_SincronizacionPosicion
    a ex:ModoOperacion ;
    rdfs:label "Modo de sincronización en posición" ;
    ex:textoExtracto "Sincronización en posición (en fase). [...] Se programa mediante los parámetros \"POS\"" ;
    ex:monitoreaParametro ex:Parametro_Sincronizacion_POS ;
    ex:monitoreaParametro ex:Variable_VASYNCPOSOFF .