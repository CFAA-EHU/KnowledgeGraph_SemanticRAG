@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioEditorDeLevas a ns1:InterfazUsuario ;
    rdfs:label "Editor de levas electrónicas" ;
    ns1:documentadoEn ns1:DocumentoTecnicoManualEditorDeLevas ;
    ns1:textoExtracto "CAM n Editor de levas electrónicas. Editor de levas que ofrece una cómoda asistencia para analizar el comportamiento de la leva proyectada a través de las facilidades gráficas de edición de valores de velocidad, aceleración y jerk." .

ns1:ListaDeLevasDisponibles a ns1:Parametro ;
    rdfs:label "Lista de levas disponibles" ;
    ns1:textoExtracto "Este parámetro muestra la lista de levas disponibles." .

ns1:DocumentoTecnicoManualEditorDeLevas a ns1:DocumentoTecnico ;
    rdfs:label "Manual específico del editor de levas" ;
    ns1:textoExtracto "Esta funcionalidad dispone de un manual específico." .

