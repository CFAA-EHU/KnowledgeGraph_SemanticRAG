@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:RatioTransmision_684_1 a ex:Parametro ;
    rdfs:label "ratio de transmisión" ;
    ex:textoExtracto "El ratio de transmisión se determina al programar la sentencia y su valor permanece constante durante toda la operación." ;
    ex:valor "constante durante toda la operación" .

ex:Sistema_684_2 a ex:Sistema ;
    rdfs:label "sistema" ;
    ex:textoExtracto "En este modo de sincronización no se contempla la posibilidad de modificar este valor mientras el sistema está operativo" .

ex:LevaElectronica_684_3 a ex:ComponenteElectrico ;
    rdfs:label "leva electrónica" ;
    ex:textoExtracto "ya que este comportamiento es más propio de una leva electrónica que de un engranaje electrónico" .

ex:EngranajeElectronico_684_4 a ex:ComponenteMecanico ;
    rdfs:label "engranaje electrónico" ;
    ex:textoExtracto "ya que este comportamiento es más propio de una leva electrónica que de un engranaje electrónico" .

ex:ProgramacionLevaElectronica_684_5 a ex:AccionProhibida ;
    rdfs:label "programación de una leva electrónica" ;
    ex:textoExtracto "Para solucionar esta cuestión puede recurrirse a la programación de una leva electrónica." .