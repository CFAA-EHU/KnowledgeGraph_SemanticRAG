@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:LatcheoCota a ex:AccionProhibida ;
    rdfs:label "Latcheo de cota"@es ;
    ex:textoExtracto "Se entiende por latcheo de cota a que el CNC capture la cota de un eje cuando se produce un evento dado."@es .

ex:TOUCHPROBE a ex:AccionProhibida ;
    rdfs:label "TOUCHPROBE"@es ;
    ex:textoExtracto "TOUCHPROBE Latcheo de la cota."@es .

ex:Palpador a ex:Sensor ;
    rdfs:label "palpador"@es ;
    ex:textoExtracto "el palpador actúa por nivel, no por flanco"@es .

ex:EntradaDigitalFisica a ex:ComponenteElectrico ;
    rdfs:label "entrada digital física"@es ;
    ex:textoExtracto "de una entrada digital física o de una entrada lógica"@es .

ex:EntradaLogica a ex:ComponenteElectrico ;
    rdfs:label "entrada lógica"@es ;
    ex:textoExtracto "Si el evento seleccionado es una entrada lógica, la activación de la misma puede realizarse desde programa PLC"@es .

ex:ParametroPRBDI1 a ex:Parametro ;
    rdfs:label "PRBDI1"@es ;
    ex:textoExtracto "Los eventos a utilizar serán las entradas digitales definidas en los parámetros PRBDI1 y PRBDI2."@es .

ex:ParametroPRBDI2 a ex:Parametro ;
    rdfs:label "PRBDI2"@es ;
    ex:textoExtracto "Los eventos a utilizar serán las entradas digitales definidas en los parámetros PRBDI1 y PRBDI2."@es .

ex:ParametroPROBEAXIS a ex:Parametro ;
    rdfs:label "PROBEAXIS"@es ;
    ex:textoExtracto "Los siguientes parámetros máquina asociados al palpador no tienen efecto; PROBEAXIS, PROBERANGE, PROBEFEED, PRB1MIN, PRB2MIN, PRB3MIN, PRB1MAX, PRB2MAX y PRB3MAX."@es .

ex:ParametroPROBERANGE a ex:Parametro ;
    rdfs:label "PROBERANGE"@es ;
    ex:textoExtracto "Los siguientes parámetros máquina asociados al palpador no tienen efecto; PROBEAXIS, PROBERANGE, PROBEFEED, PRB1MIN, PRB2MIN, PRB3MIN, PRB1MAX, PRB2MAX y PRB3MAX."@es .

ex:ParametroPROBEFEED a ex:Parametro ;
    rdfs:label "PROBEFEED"@es ;
    ex:textoExtracto "Los siguientes parámetros máquina asociados al palpador no tienen efecto; PROBEAXIS, PROBERANGE, PROBEFEED, PRB1MIN, PRB2MIN, PRB3MIN, PRB1MAX, PRB2MAX y PRB3MAX."@es .

ex:ParametroPRB1MIN a ex:Parametro ;
    rdfs:label "PRB1MIN"@es ;
    ex:textoExtracto "Los siguientes parámetros máquina asociados al palpador no tienen efecto; PROBEAXIS, PROBERANGE, PROBEFEED, PRB1MIN, PRB2MIN, PRB3MIN, PRB1MAX, PRB2MAX y PRB3MAX."@es .

ex:ParametroPRB2MIN a ex:Parametro ;
    rdfs:label "PRB2MIN"@es ;
    ex:textoExtracto "Los siguientes parámetros máquina asociados al palpador no tienen efecto; PROBEAXIS, PROBERANGE, PROBEFEED, PRB1MIN, PRB2MIN, PRB3MIN, PRB1MAX, PRB2MAX y PRB3MAX."@es .

ex:ParametroPRB3MIN a ex:Parametro ;
    rdfs:label "PRB3MIN"@es ;
    ex:textoExtracto "Los siguientes parámetros máquina asociados al palpador no tienen efecto; PROBEAXIS, PROBERANGE, PROBEFEED, PRB1MIN, PRB2MIN, PRB3MIN, PRB1MAX, PRB2MAX y PRB3MAX."@es .

ex:ParametroPRB1MAX a ex:Parametro ;
    rdfs:label "PRB1MAX"@es ;
    ex:textoExtracto "Los siguientes parámetros máquina asociados al palpador no tienen efecto; PROBEAXIS, PROBERANGE, PROBEFEED, PRB1MIN, PRB2MIN, PRB3MIN, PRB1MAX, PRB2MAX y PRB3MAX."@es .

ex:ParametroPRB2MAX a ex:Parametro ;
    rdfs:label "PRB2MAX"@es ;
    ex:textoExtracto "Los siguientes parámetros máquina asociados al palpador no tienen efecto; PROBEAXIS, PROBERANGE, PROBEFEED, PRB1MIN, PRB2MIN, PRB3MIN, PRB1MAX, PRB2MAX y PRB3MAX."@es .

ex:ParametroPRB3MAX a ex:Parametro ;
    rdfs:label "PRB3MAX"@es ;
    ex:textoExtracto "Los siguientes parámetros máquina asociados al palpador no tienen efecto; PROBEAXIS, PROBERANGE, PROBEFEED, PRB1MIN, PRB2MIN, PRB3MIN, PRB1MAX, PRB2MAX y PRB3MAX."@es .

ex:Eje a ex:ComponenteMecanico ;
    rdfs:label "eje"@es ;
    ex:textoExtracto "el CNC capture la cota de un eje cuando se produce un evento dado"@es .

ex:VentanaLatcheo a ex:Parametro ;
    rdfs:label "ventana de latcheo"@es ;
    ex:textoExtracto "se puede definir una ventana de latcheo. Si hay una ventana de latch, se podrá condicionar el latcheo de la cota a que el eje se encuentre dentro o fuera de la ventana."@es .

ex:ProgramaPLC a ex:Sistema ;
    rdfs:label "programa PLC"@es ;
    ex:textoExtracto "la activación de la misma puede realizarse desde programa PLC"@es .