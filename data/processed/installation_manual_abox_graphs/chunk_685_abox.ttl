@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Instruccion_LatcheoCota_TOUCHPROBE
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Instrucción TOUCHPROBE para latcheo de cota"@es ;
    ex:textoExtracto       "La instrucción TOUCHPROBE latchea la cota de un eje por evento de un palpador, de una entrada digital física o de una entrada lógica."@es ;
    ex:identificador       "TOUCHPROBE" ;
    ex:requiereMantenimiento ex:Sistema_LatcheoCota .

ex:Sistema_LatcheoCota
    a                     ex:Sistema ;
    rdfs:label            "Sistema de latcheo de cota por evento"@es ;
    ex:textoExtracto       "Se entiende por latcheo de cota a que el CNC capture la cota de un eje cuando se produce un evento dado."@es ;
    ex:compuestoPor        ex:Parametro_PRBDI1 , ex:Parametro_PRBDI2 , ex:Palpador_Evento , ex:EntradaDigital_Fisica , ex:EntradaLogica_PLC ;
    ex:tieneComponente     ex:ComponenteElectrico_EntradaDigital .

ex:Parametro_PRBDI1
    a                     ex:Parametro ;
    rdfs:label            "Parámetro PRBDI1 (entrada digital para latcheo)"@es ;
    ex:textoExtracto       "Los eventos a utilizar serán las entradas digitales definidas en los parámetros PRBDI1 y PRBDI2."@es ;
    ex:identificador       "PRBDI1" ;
    ex:monitoreaParametro  ex:Sistema_LatcheoCota .

ex:Parametro_PRBDI2
    a                     ex:Parametro ;
    rdfs:label            "Parámetro PRBDI2 (entrada digital para latcheo)"@es ;
    ex:textoExtracto       "Los eventos a utilizar serán las entradas digitales definidas en los parámetros PRBDI1 y PRBDI2."@es ;
    ex:identificador       "PRBDI2" ;
    ex:monitoreaParametro  ex:Sistema_LatcheoCota .

ex:Palpador_Evento
    a                     ex:Sensor ;
    rdfs:label            "Palpador para latcheo de cota"@es ;
    ex:textoExtracto       "La instrucción TOUCHPROBE latchea la cota de un eje por evento de un palpador [...] Si el evento seleccionado es un palpador y al activar el comando TOUCHPROBE el palpador ya ha alcanzado su nivel lógico, la cota latcheada será la del momento de activación del comando."@es ;
    ex:controla           ex:Sistema_LatcheoCota .

ex:EntradaDigital_Fisica
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Entrada digital física para latcheo"@es ;
    ex:textoExtracto       "La instrucción TOUCHPROBE latchea la cota de un eje por evento [...] de una entrada digital física."@es ;
    ex:tieneComponente     ex:Sistema_LatcheoCota .

ex:EntradaLogica_PLC
    a                     ex:InterfazUsuario ;
    rdfs:label            "Entrada lógica PLC para latcheo condicional"@es ;
    ex:textoExtracto       "Si el evento seleccionado es una entrada lógica, la activación de la misma puede realizarse desde programa PLC y por lo tanto estar condicionada indirectamente a cualquier otro evento gestionado por el PLC."@es ;
    ex:controla           ex:Sistema_LatcheoCota .

ex:ComponenteElectrico_EntradaDigital
    a                     ex:ComponenteElectrico ;
    rdfs:label            "Componente de entrada digital para latcheo"@es ;
    ex:textoExtracto       "Los eventos a utilizar serán las entradas digitales definidas en los parámetros PRBDI1 y PRBDI2."@es .