@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_axis a ex:Parametro ;
    ex:identificador "axis" ;
    ex:textoExtracto "Nombre del eje objeto del latcheo." ;
    rdfs:label "axis"@es .

ex:Parametro_probe a ex:Parametro ;
    ex:identificador "probe" ;
    ex:textoExtracto "Número de palpador a utilizar como evento para el latcheo." ;
    rdfs:label "probe"@es .

ex:Parametro_wintype a ex:Parametro ;
    ex:identificador "wintype" ;
    ex:textoExtracto "Tipo de ventana para el latcheo. Se programa mediante los comandos DISABLE (sin ventana), EXCLUSIVE (latch fuera de la ventana) e INCLUSIVE (latch dentro de la ventana)." ;
    rdfs:label "wintype"@es .

ex:Parametro_winminpos a ex:Parametro ;
    ex:identificador "winminpos" ;
    ex:textoExtracto "Límite inferior para la ventana del latch." ;
    rdfs:label "winminpos"@es .

ex:Parametro_winmaxpos a ex:Parametro ;
    ex:identificador "winmaxpos" ;
    ex:textoExtracto "Límite superior para la ventana del latch." ;
    rdfs:label "winmaxpos"@es .