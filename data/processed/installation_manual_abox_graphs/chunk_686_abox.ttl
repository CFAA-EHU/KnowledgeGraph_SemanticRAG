@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ParametrosLatcheo_4_4_10 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de latcheo (Sección 4.4.10)"@es ;
    ex:textoExtracto """
| Parámetro. | Significado. |
| --- | --- |
| axis | Nombre del eje objeto del latcheo. |
| probe | Número de palpador a utilizar como evento para el latcheo. |
| wintype | Tipo de ventana para el latcheo. Se programa mediante los comandos DISABLE (sin ventana), EXCLUSIVE (latch fuera de la ventana) e INCLUSIVE (latch dentro de la ventana). |
| winminpos | Límite inferior para la ventana del latch. |
| winmaxpos | Límite superior para la ventana del latch. |
"""@es .

ex:Parametro_axis
    a ex:Parametro ;
    rdfs:label "axis" ;
    ex:identificador "axis" ;
    ex:textoExtracto "Nombre del eje objeto del latcheo."@es ;
    ex:documentadoEn ex:Tabla_ParametrosLatcheo_4_4_10 .

ex:Parametro_probe
    a ex:Parametro ;
    rdfs:label "probe" ;
    ex:identificador "probe" ;
    ex:textoExtracto "Número de palpador a utilizar como evento para el latcheo."@es ;
    ex:documentadoEn ex:Tabla_ParametrosLatcheo_4_4_10 .

ex:Parametro_wintype
    a ex:Parametro ;
    rdfs:label "wintype" ;
    ex:identificador "wintype" ;
    ex:textoExtracto "Tipo de ventana para el latcheo. Se programa mediante los comandos DISABLE (sin ventana), EXCLUSIVE (latch fuera de la ventana) e INCLUSIVE (latch dentro de la ventana)."@es ;
    ex:documentadoEn ex:Tabla_ParametrosLatcheo_4_4_10 .

ex:Parametro_winminpos
    a ex:Parametro ;
    rdfs:label "winminpos" ;
    ex:identificador "winminpos" ;
    ex:textoExtracto "Límite inferior para la ventana del latch."@es ;
    ex:documentadoEn ex:Tabla_ParametrosLatcheo_4_4_10 .

ex:Parametro_winmaxpos
    a ex:Parametro ;
    rdfs:label "winmaxpos" ;
    ex:identificador "winmaxpos" ;
    ex:textoExtracto "Límite superior para la ventana del latch."@es ;
    ex:documentadoEn ex:Tabla_ParametrosLatcheo_4_4_10 .