@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_TOUCHPROBE_X1
    a ex:Parametro ;
    rdfs:label "TOUCHPROBE (X, 1)" ;
    ex:textoExtracto "TOUCHPROBE (X, 1, DISABLE)" ;
    ex:identificador "X,1" .

ex:Parametro_TOUCHPROBE_Y2_EXCLUSIVE
    a ex:Parametro ;
    rdfs:label "TOUCHPROBE (Y, 2, EXCLUSIVE)" ;
    ex:textoExtracto "TOUCHPROBE (Y, 2, EXCLUSIVE, 1000000, 2300000)" ;
    ex:identificador "Y,2" ;
    ex:valor "1000000,2300000" .

ex:Parametro_TOUCHPROBE_X3_INCLUSIVE
    a ex:Parametro ;
    rdfs:label "TOUCHPROBE (X3, 1, INCLUSIVE)" ;
    ex:textoExtracto "TOUCHPROBE (X3, 1, INCLUSIVE, 500000, 1105000)" ;
    ex:identificador "X3,1" ;
    ex:valor "500000,1105000" .

ex:Parametro_PRBDI1
    a ex:Parametro ;
    rdfs:label "Parámetro de palpador/entrada digital 1 (PRBDI1)" ;
    ex:textoExtracto "El palpador 1 será el asignado al parámetro PRBDI1 y el palpador 2 será el asignado al parámetro PRBDI2. En vez de un palpador, también se puede utilizar como evento una entrada digital física o de una entrada lógica. En este caso, la entrada a utilizar también deberá estar definida en los parámetros PRBDI1 o PRBDI2." ;
    ex:identificador "PRBDI1" .

ex:Parametro_PRBDI2
    a ex:Parametro ;
    rdfs:label "Parámetro de palpador/entrada digital 2 (PRBDI2)" ;
    ex:textoExtracto "el palpador 2 será el asignado al parámetro PRBDI2" ;
    ex:identificador "PRBDI2" .

ex:Sistema_LatcheoCotas
    a ex:Sistema ;
    rdfs:label "Sistema de latcheo de cotas con palpador o entrada digital" ;
    ex:textoExtracto "Instrucciones de latcheo de cotas con un palpador o entrada digital. [...] Funcionamiento del latcheo de cotas." ;
    ex:tieneComponente ex:Parametro_TOUCHPROBE_X1 ;
    ex:tieneComponente ex:Parametro_TOUCHPROBE_Y2_EXCLUSIVE ;
    ex:tieneComponente ex:Parametro_TOUCHPROBE_X3_INCLUSIVE ;
    ex:tieneComponente ex:Parametro_PRBDI1 ;
    ex:tieneComponente ex:Parametro_PRBDI2 .