@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_winminpos
    a ex:Parametro ;
    rdfs:label "winminpos" ;
    ex:textoExtracto "Los parámetros de llamada ꞏwinminposꞏ y ꞏwinmaxposꞏ establecen los límites inferior y superior de la ventana del latch." ;
    ex:valor "límite_inferior_ventana_latch" .

ex:Parametro_winmaxpos
    a ex:Parametro ;
    rdfs:label "winmaxpos" ;
    ex:textoExtracto "Los parámetros de llamada ꞏwinminposꞏ y ꞏwinmaxposꞏ establecen los límites inferior y superior de la ventana del latch." ;
    ex:valor "límite_superior_ventana_latch" .

ex:ModoOperacion_LatcheoCotas
    a ex:ModoOperacion ;
    rdfs:label "Latcheo de cotas" ;
    ex:textoExtracto "Funcionamiento del latcheo de cotas. Para un mismo palpador no es posible tener activos simultáneamente un proceso de latcheo de cota y un proceso de palpado programado con G100, aunque sea en ejes distintos; si se ejecuta uno de ellos estando el otro activo, el CNC mostrará un error." .

ex:ModoOperacion_PalpadoG100
    a ex:ModoOperacion ;
    rdfs:label "Palpado programado con G100" ;
    ex:textoExtracto "Para un mismo palpador no es posible tener activos simultáneamente un proceso de latcheo de cota y un proceso de palpado programado con G100, aunque sea en ejes distintos; si se ejecuta uno de ellos estando el otro activo, el CNC mostrará un error." .

ex:AccionProhibida_LatcheoYPalpadoSimultaneo
    a ex:AccionProhibida ;
    rdfs:label "Ejecutar latcheo de cotas y palpado G100 simultáneamente" ;
    ex:textoExtracto "Para un mismo palpador no es posible tener activos simultáneamente un proceso de latcheo de cota y un proceso de palpado programado con G100, aunque sea en ejes distintos; si se ejecuta uno de ellos estando el otro activo, el CNC mostrará un error." .