@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:G100
    a ex:ModoOperacion ;
    rdfs:label "G100 (palpado programado)" ;
    ex:textoExtracto "palpado programado con G100"@es .

ex:G101
    a ex:ModoOperacion ;
    rdfs:label "G101" ;
    ex:textoExtracto "funciones G101"@es .

ex:G102
    a ex:ModoOperacion ;
    rdfs:label "G102" ;
    ex:textoExtracto "funciones G102"@es .

ex:ErrorCNC_LatcheoConcurrente
    a ex:AvisoSeguridad ;
    rdfs:label "Error de latcheo concurrente" ;
    ex:textoExtracto "si se ejecuta uno de ellos estando el otro activo, el CNC mostrará un error"@es ;
    ex:mitigaRiesgo ex:G100 .

ex:SistemaLatcheoCotas
    a ex:Sistema ;
    rdfs:label "Sistema de latcheo de cotas" ;
    ex:textoExtracto "latcheo de cotas"@es ;
    ex:tieneComponente ex:G100, ex:G101, ex:G102 .