@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla690 a ex:Tabla ;
    ex:textoExtracto """| CNC | PLC |  |
| --- | --- | --- |
| #SELECT PROBE [1]
G100 X100 | ꞏꞏ = TOUCHPROBE (X,1) | Incorrecto. |
| #SELECT PROBE [1]
G100 X100 | ꞏꞏ = TOUCHPROBE (Z,1) | Incorrecto. |
| #SELECT PROBE [1]
G100 X100 | ꞏꞏ = TOUCHPROBE (X,2) | Correcto. |
| #SELECT PROBE [2]
G100 X100 | ꞏꞏ = TOUCHPROBE (X,1) | Correcto. |""" ;
    ex:tieneComponente ex:SelectProbe1, ex:SelectProbe2, ex:TouchProbeX1, ex:TouchProbeZ1, ex:TouchProbeX2, ex:TouchProbeX1_2 .

ex:SelectProbe1 a ex:Parametro ;
    ex:identificador "#SELECT PROBE [1]" ;
    ex:textoExtracto "#SELECT PROBE [1]" .

ex:SelectProbe2 a ex:Parametro ;
    ex:identificador "#SELECT PROBE [2]" ;
    ex:textoExtracto "#SELECT PROBE [2]" .

ex:TouchProbeX1 a ex:Sensor ;
    ex:identificador "TOUCHPROBE (X,1)" ;
    ex:textoExtracto "TOUCHPROBE (X,1)" .

ex:TouchProbeZ1 a ex:Sensor ;
    ex:identificador "TOUCHPROBE (Z,1)" ;
    ex:textoExtracto "TOUCHPROBE (Z,1)" .

ex:TouchProbeX2 a ex:Sensor ;
    ex:identificador "TOUCHPROBE (X,2)" ;
    ex:textoExtracto "TOUCHPROBE (X,2)" .

ex:TouchProbeX1_2 a ex:Sensor ;
    ex:identificador "TOUCHPROBE (X,1)" ;
    ex:textoExtracto "TOUCHPROBE (X,1)" .