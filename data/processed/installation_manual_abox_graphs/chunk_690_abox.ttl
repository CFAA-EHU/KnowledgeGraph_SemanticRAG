@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "El PLC dispone de los siguientes recursos." ;
    ns1:tieneComponente ns1:EntradaI1,
        ns1:EntradaLocalLI1,
        ns1:SalidaO1 .

ns1:EntradaI1 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada I1" ;
    ns1:identificador "I1" ;
    ns1:textoExtracto "Las entradas son elementos que proporcionan información al PLC de las señales que se reciben del exterior." .

ns1:EntradaLocalLI1 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada Local LI1" ;
    ns1:identificador "LI1" ;
    ns1:textoExtracto "Las entradas locales se representan mediante la letra LI seguida del número de entrada, desde LI1 hasta LI16." .

ns1:SalidaO1 a ns1:ComponenteElectrico ;
    rdfs:label "Salida O1" ;
    ns1:identificador "O1" ;
    ns1:textoExtracto "Las salidas son elementos que permiten al PLC activar o desactivar los distintos dispositivos o accionamientos del armario eléctrico." .

