@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaPLCLocal a ns1:Sistema ;
    rdfs:label "Sistema PLC Local" ;
    ns1:textoExtracto "Se denominan entradas y salidas locales porque se encuentran en la unidad central y no en los módulos remotos." ;
    ns1:tieneComponente ns1:EntradaLocal1_fb7184bf85,
        ns1:SalidaLocal1_7c068bd49e .

ns1:EntradaLocal1_fb7184bf85 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada Local 1" ;
    ns1:identificador "LI1" ;
    ns1:textoExtracto "Las entradas locales se representan mediante la letra LI seguida del número de entrada, desde LI1 hasta LI16." .

ns1:SalidaLocal1_7c068bd49e a ns1:ComponenteElectrico ;
    rdfs:label "Salida Local 1" ;
    ns1:identificador "LO1" ;
    ns1:textoExtracto "Las salidas locales se representan mediante la letra LO seguida del número de salida, desde LO1 hasta LO8." .

