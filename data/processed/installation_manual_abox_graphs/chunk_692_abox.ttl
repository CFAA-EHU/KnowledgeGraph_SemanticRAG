@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_8713e65b15 a ns1:Parametro ;
    rdfs:label "Marca M1" ;
    ns1:identificador "M1" ;
    ns1:textoExtracto "Se representan mediante la letra M seguida del número de marca que se desea referenciar, desde M1 hasta M8192." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "desde LO1 hasta LO8. Las I/O digitales locales no se tienen en cuenta a la hora de personalizar la numeración de los I/Os remotas ni cuando se salva la configuración del bus CAN." ;
    ns1:tieneComponente ns1:ComponenteElectrico_387b0bd89b,
        ns1:ComponenteElectrico_468bd98ad1,
        ns1:ErrorERR1,
        ns1:MensajeMSG1 .

ns1:ComponenteElectrico_387b0bd89b a ns1:ComponenteElectrico ;
    rdfs:label "Relojes" ;
    ns1:textoExtracto "Relojes (CLK). Son relojes internos de diferentes periodos de tiempo que pueden ser utilizados en el programa de PLC." .

ns1:ComponenteElectrico_468bd98ad1 a ns1:ComponenteElectrico ;
    rdfs:label "Marcas" ;
    ns1:textoExtracto "Marcas (M1-M8192). Son elementos capaces de memorizar en un bit (como si fuera un relé interno) el valor definido por el usuario." .

ns1:ErrorERR1 a ns1:Parametro ;
    rdfs:label "Error ERR1" ;
    ns1:identificador "ERR1" ;
    ns1:textoExtracto "Errores (ERR1-ERR1024). Al activarlas (=1) producen un error, muestran el mensaje de error e interrumpen la ejecución del CNC." .

ns1:MensajeMSG1 a ns1:Parametro ;
    rdfs:label "Mensaje MSG1" ;
    ns1:identificador "MSG1" ;
    ns1:textoExtracto "Mensajes (MSG1-MSG1024). Al activarlas (=1) muestran un mensaje en la pantalla del CNC." .

