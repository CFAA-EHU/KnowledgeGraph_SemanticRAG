    ns1:documentadoEn ns1:CNC8070_83017ad601 ;
    ns1:textoExtracto "Son relojes internos de diferentes periodos de tiempo que pueden ser utilizados en el programa de PLC." .

ns1:Alarma_13c1056be7 a ns1:Alarma ;
