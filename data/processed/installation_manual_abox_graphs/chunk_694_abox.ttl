@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoInicial a ns1:Parametro ;
    rdfs:label "Estado inicial de las marcas de reloj" ;
    ns1:textoExtracto "Todos ellos se inicializan a (=0) en el arranque del PLC." ;
    ns1:valor "=0" .

ns1:Parametro_1dd68db5c6 a ns1:Parametro ;
    rdfs:label "Marca de reloj en el programa PLC" ;
    ns1:textoExtracto "Se representan mediante CLK seguido del número de reloj que se desea referenciar." .

