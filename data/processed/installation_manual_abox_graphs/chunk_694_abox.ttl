@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Variable_LATCH1
    a ex:Parametro ;
    rdfs:label "Variable de latcheo 1 (V.A.LATCH1)"@es ;
    ex:textoExtracto "V.A.LATCH1.Z | Eje Z. [...] Variable válida para ejes rotativos y lineales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Cota máquina obtenida del latcheo del palpador 1 en el eje ꞏxnꞏ."@es ;
    ex:identificador "V.[ch].A.LATCH1.xn" ;
    ex:monitoreaParametro ex:Eje_Z, ex:Eje_Logico_4, ex:Eje_Indice_2_1 .

ex:Variable_LATCH2
    a ex:Parametro ;
    rdfs:label "Variable de latcheo 2 (V.A.LATCH2)"@es ;
    ex:textoExtracto "(V.)[ch].A.LATCH2.xn [...] Variable válida para ejes rotativos y lineales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Cota máquina obtenida del latcheo del palpador 2 en el eje ꞏxnꞏ."@es ;
    ex:identificador "V.[ch].A.LATCH2.xn" ;
    ex:monitoreaParametro ex:Eje_Z, ex:Eje_Logico_4, ex:Eje_Indice_2_1 .

ex:Variable_ACCUDIST
    a ex:Parametro ;
    rdfs:label "Variable de distancia acumulada (V.A.ACCUDIST)"@es ;
    ex:textoExtracto "(V.)[ch].A.ACCUDIST.xn [...] Variable válida para ejes rotativos, lineales y cabezales. Distancia recorrida por el eje o cabezal desde el último latcheo de cota. Esta variable se inicializa a ꞏ0ꞏ cuando se produce un evento de latcheo."@es ;
    ex:identificador "V.[ch].A.ACCUDIST.xn" ;
    ex:monitoreaParametro ex:Eje_Z, ex:Eje_Logico_4, ex:Eje_Indice_2_1 .

ex:Eje_Z
    a ex:ComponenteMecanico ;
    rdfs:label "Eje Z"@es ;
    ex:textoExtracto "V.A.LATCH1.Z | Eje Z. [...] V.A.LATCH2.Z | Eje Z."@es ;
    ex:identificador "Z" .

ex:Eje_Logico_4
    a ex:ComponenteMecanico ;
    rdfs:label "Eje con número lógico 4"@es ;
    ex:textoExtracto "V.A.LATCH1.4 | Eje con número lógico ꞏ4ꞏ. [...] V.A.LATCH2.4 | Eje con número lógico ꞏ4ꞏ."@es ;
    ex:identificador "4" .

ex:Eje_Indice_2_1
    a ex:ComponenteMecanico ;
    rdfs:label "Eje con índice 1 en canal 2"@es ;
    ex:textoExtracto "V.[2].A.LATCH1.1 | Eje con índice ꞏ1ꞏ en el canal ꞏ2ꞏ. [...] V.[2].A.LATCH2.1 | Eje con índice ꞏ1ꞏ en el canal ꞏ2ꞏ."@es ;
    ex:identificador "[2].1" .

ex:Interfaz_Latcheo
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de variables de latcheo (PLC/programa)"@es ;
    ex:textoExtracto "Variable de lectura desde el programa, PLC e interfaz. [...] Variable de lectura y escritura desde el programa, PLC e interfaz."@es ;
    ex:tieneComponente ex:Variable_LATCH1, ex:Variable_LATCH2, ex:Variable_ACCUDIST .