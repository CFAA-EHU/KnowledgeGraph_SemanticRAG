@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Variable_V_MPA_ACCUDIST_Z
    a               ex:Parametro ;
    rdfs:label      "V.MPA.ACCUDIST.Z" ;
    ex:identificador "V.MPA.ACCUDIST.Z" ;
    ex:textoExtracto "V.MPA.ACCUDIST.Z | Eje Z." ;
    ex:valor         "Eje Z" .

ex:Variable_V_MPA_ACCUDIST_4
    a               ex:Parametro ;
    rdfs:label      "V.MPA.ACCUDIST.4" ;
    ex:identificador "V.MPA.ACCUDIST.4" ;
    ex:textoExtracto "V.MPA.ACCUDIST.4 | Eje con número lógico '4'." ;
    ex:valor         "4" .

ex:Variable_V_2_MPA_ACCUDIST_1
    a               ex:Parametro ;
    rdfs:label      "V.[2].MPA.ACCUDIST.1" ;
    ex:identificador "V.[2].MPA.ACCUDIST.1" ;
    ex:textoExtracto "V.[2].MPA.ACCUDIST.1 | Eje con índice '1' en el canal '2'." ;
    ex:valor         "Canal: 2, Índice eje: 1" .

ex:Variable_V_A_PREVACCUDIST_xn
    a               ex:Parametro ;
    rdfs:label      "(V.)[ch].A.PREVACCUDIST.xn" ;
    ex:identificador "(V.)[ch].A.PREVACCUDIST.xn" ;
    ex:textoExtracto "(V.)[ch].A.PREVACCUDIST.xn Variable de lectura y escritura desde el programa, PLC e interfaz. Variable válida para ejes rotativos, lineales y cabezales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Distancia recorrida por el eje o cabezal entre los dos últimos latcheo de cota." .