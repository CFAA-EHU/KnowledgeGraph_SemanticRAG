@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:V_MPA_ACCUDIST_Z a ex:Parametro ;
    rdfs:label "V.MPA.ACCUDIST.Z" ;
    ex:textoExtracto "V.MPA.ACCUDIST.Z | Eje Z." ;
    ex:valor "Eje Z" .

ex:V_MPA_ACCUDIST_4 a ex:Parametro ;
    rdfs:label "V.MPA.ACCUDIST.4" ;
    ex:textoExtracto "V.MPA.ACCUDIST.4 | Eje con número lógico ꞏ4ꞏ." ;
    ex:valor "Eje con número lógico 4" .

ex:V_2_MPA_ACCUDIST_1 a ex:Parametro ;
    rdfs:label "V.[2].MPA.ACCUDIST.1" ;
    ex:textoExtracto "V.[2].MPA.ACCUDIST.1 | Eje con índice ꞏ1ꞏ en el canal ꞏ2ꞏ." ;
    ex:valor "Eje con índice 1 en el canal 2" .

ex:V_MPA_ACCUDIST_xn a ex:Parametro ;
    rdfs:label "V.[ch].MPA.ACCUDIST.xn" ;
    ex:textoExtracto "(V.)[ch].A.PREVACCUDIST.xn Variable de lectura y escritura desde el programa, PLC e interfaz. Variable válida para ejes rotativos, lineales y cabezales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Distancia recorrida por el eje o cabezal entre los dos últimos latcheo de cota. Esta variable actualiza su valor en cada evento de latcheo, por eso la variable tendrá valor ꞏ0ꞏ hasta que se produzca el primero." ;
    ex:valor "Variable de lectura y escritura desde el programa, PLC e interfaz. Variable válida para ejes rotativos, lineales y cabezales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques. Distancia recorrida por el eje o cabezal entre los dos últimos latcheo de cota. Esta variable actualiza su valor en cada evento de latcheo, por eso la variable tendrá valor 0 hasta que se produzca el primero." .