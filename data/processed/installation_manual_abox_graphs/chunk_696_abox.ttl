@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_696_ParametrosEje a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de parámetros de latcheo para ejes (pág. 384-387)"@es ;
    ex:textoExtracto """
| V.MPA.PREVACCUDIST.Z | Eje Z. |
| V.MPA.PREVACCUDIST.4 | Eje con número lógico ꞏ4ꞏ. |
| V.[2].MPA.PREVACCUDIST.1 | Eje con índice ꞏ1ꞏ en el canal ꞏ2ꞏ. |
"""@es .

ex:Parametro_V_MPA_PREVACCUDIST_Z
    a ex:Parametro ;
    rdfs:label "V.MPA.PREVACCUDIST.Z" ;
    ex:identificador "V.MPA.PREVACCUDIST.Z" ;
    ex:textoExtracto "Eje Z."@es ;
    ex:documentadoEn ex:Tabla_696_ParametrosEje .

ex:Parametro_V_MPA_PREVACCUDIST_4
    a ex:Parametro ;
    rdfs:label "V.MPA.PREVACCUDIST.4" ;
    ex:identificador "V.MPA.PREVACCUDIST.4" ;
    ex:textoExtracto "Eje con número lógico ꞏ4ꞏ."@es ;
    ex:documentadoEn ex:Tabla_696_ParametrosEje .

ex:Parametro_V_2_MPA_PREVACCUDIST_1
    a ex:Parametro ;
    rdfs:label "V.[2].MPA.PREVACCUDIST.1" ;
    ex:identificador "V.[2].MPA.PREVACCUDIST.1" ;
    ex:textoExtracto "Eje con índice ꞏ1ꞏ en el canal ꞏ2ꞏ."@es ;
    ex:documentadoEn ex:Tabla_696_ParametrosEje .