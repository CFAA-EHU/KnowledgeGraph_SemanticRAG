@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ContadorC1 a ns1:ComponenteElectrico ;
    rdfs:label "Contador C1" ;
    ns1:textoExtracto "Contadores (C1-C256). Son elementos capaces de contar o descontar una cantidad determinada de sucesos." .

ns1:RegistroR1 a ns1:ComponenteElectrico ;
    rdfs:label "Registro R1" ;
    ns1:textoExtracto "Registros (R1-R1024). Son elementos que permiten almacenar en 32 bits una variable numérica." .

ns1:RelojDe128Ms a ns1:Parametro ;
    rdfs:label "Reloj de 128 ms" ;
    ns1:identificador "CLK128" ;
    ns1:textoExtracto "CLK128 | 128 ms" .

ns1:RelojDe32Ms a ns1:Parametro ;
    rdfs:label "Reloj de 32 ms" ;
    ns1:identificador "CLK32" ;
    ns1:textoExtracto "CLK32 | 32 ms" .

ns1:RelojDe64Ms a ns1:Parametro ;
    rdfs:label "Reloj de 64 ms" ;
    ns1:identificador "CLK64" ;
    ns1:textoExtracto "CLK64 | 64 ms" .

ns1:TemporizadorT1 a ns1:ComponenteElectrico ;
    rdfs:label "Temporizador T1" ;
    ns1:textoExtracto "Temporizadores (T1-T512). Son elementos capaces de mantener su salida al mismo nivel lógico durante un determinado tiempo." .

