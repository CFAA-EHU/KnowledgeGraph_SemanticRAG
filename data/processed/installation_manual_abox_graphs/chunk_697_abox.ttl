@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_4dca0551ff a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controladoPor ns1:SenalModificableEMERGEN,
        ns1:SenalModificableSTOP ;
    ns1:parametroMonitoradoPor ns1:SenalConsultaCNCREADY,
        ns1:SenalConsultaSTART ;
    ns1:textoExtracto "El PLC tiene acceso a determinada información interna del CNC." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:controla ns1:SenalModificableEMERGEN,
        ns1:SenalModificableSTOP ;
    ns1:monitoreaParametro ns1:SenalConsultaCNCREADY,
        ns1:SenalConsultaSTART ;
    ns1:textoExtracto "El PLC tiene acceso a determinada información interna del CNC." .

ns1:SenalConsultaCNCREADY a ns1:Parametro ;
    rdfs:label "Señal de consulta CNCREADY" ;
    ns1:identificador "CNCREADY" ;
    ns1:textoExtracto "• Señales de consulta: CNCREADY, START, FHOUT, ..." .

ns1:SenalConsultaSTART a ns1:Parametro ;
    rdfs:label "Señal de consulta START" ;
    ns1:identificador "START" ;
    ns1:textoExtracto "• Señales de consulta: CNCREADY, START, FHOUT, ..." .

ns1:SenalModificableEMERGEN a ns1:Parametro ;
    rdfs:label "Señal modificable _EMERGEN" ;
    ns1:identificador "_EMERGEN" ;
    ns1:textoExtracto "• Señales modificables: _EMERGEN, _STOP, _FEEDHOL, ..." .

ns1:SenalModificableSTOP a ns1:Parametro ;
    rdfs:label "Señal modificable _STOP" ;
    ns1:identificador "_STOP" ;
    ns1:textoExtracto "• Señales modificables: _EMERGEN, _STOP, _FEEDHOL, ..." .

