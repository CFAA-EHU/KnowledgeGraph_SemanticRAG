@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ZonaTrabajoSistema a ex:Sistema ;
    ex:textoExtracto "Las zonas de trabajo se pueden definir, habilitar y deshabilitar desde el PLC mediante el comando CNCWR, escribiendo las variables correspondientes." ;
    ex:tieneComponente ex:VariableZonaLimiteTol, ex:VariableEstadoZona, ex:VariableLimiteInferiorZona, ex:VariableLimiteSuperiorZona, ex:VariableEjeCentroZona1, ex:VariableEjeCentroZona2, ex:VariableCotaCentroZona1, ex:VariableCotaCentroZona2, ex:VariableRadioZona, ex:VariableVigilanciaHerramienta .

ex:VariableZonaLimiteTol a ex:Parametro ;
    ex:identificador "[ch].A.ZONELIMITTOL.xn" ;
    ex:textoExtracto "[ch].A.ZONELIMITTOL.xn | Distancia de seguridad de los límites de las zonas de trabajo." .

ex:VariableEstadoZona a ex:Parametro ;
    ex:identificador "[ch].G.ZONEST[k]" ;
    ex:textoExtracto "[ch].G.ZONEST[k] | Estado de la zona de trabajo [k]. (0=Zona deshabilitada). (1=Zona habilitada como zona de no entrada). (2=Zona habilitada como zona de no salida)." .

ex:VariableLimiteInferiorZona a ex:Parametro ;
    ex:identificador "[ch].A.ZONELOWLIM[k].xn" ;
    ex:textoExtracto "[ch].A.ZONELOWLIM[k].xn | Límite inferior de la zona [k]." .

ex:VariableLimiteSuperiorZona a ex:Parametro ;
    ex:identificador "[ch].A.ZONEUPLIM[k].xn" ;
    ex:textoExtracto "[ch].A.ZONEUPLIM[k].xn | Límite superior de la zona [k]." .

ex:VariableEjeCentroZona1 a ex:Parametro ;
    ex:identificador "[ch].G.ZONECIRAX1[k]" ;
    ex:textoExtracto "[ch].G.ZONECIRAX1[k] | Eje lógico correspondiente a la primera cota del centro de la zona [k]." .

ex:VariableEjeCentroZona2 a ex:Parametro ;
    ex:identificador "[ch].G.ZONECIRAX2[k]" ;
    ex:textoExtracto "[ch].G.ZONECIRAX2[k] | Eje lógico correspondiente a la segunda cota del centro de la zona [k]." .

ex:VariableCotaCentroZona1 a ex:Parametro ;
    ex:identificador "[ch].G.ZONECIR1[k]" ;
    ex:textoExtracto "[ch].G.ZONECIR1[k] | Cota del centro de la zona [k], según el primer eje que define la zona circular." .

ex:VariableCotaCentroZona2 a ex:Parametro ;
    ex:identificador "[ch].G.ZONECIR2[k]" ;
    ex:textoExtracto "[ch].G.ZONECIR2[k] | Cota del centro de la zona [k], según el segundo eje que define la zona circular." .

ex:VariableRadioZona a ex:Parametro ;
    ex:identificador "[ch].G.ZONER[k]" ;
    ex:textoExtracto "[ch].G.ZONER[k] | Radio de la zona [k] (zona circular)." .

ex:VariableVigilanciaHerramienta a ex:Parametro ;
    ex:identificador "[ch].G.ZONETOOLWATCH[k]" ;
    ex:textoExtracto "[ch].G.ZONETOOLWATCH[k] | Vigilar la punta o la base de la herramienta. (0=Vigilar la punta de la herramienta). (1=Vigilar la base de la herramienta). (2=Vigilar tanto la punta como la base de la herramienta)." .