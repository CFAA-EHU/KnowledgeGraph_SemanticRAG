@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_5e43a1aeb4 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Desde los parámetros máquina se puede personalizar la numeración de los módulos de entradas y salidas." ;
    ns1:tieneComponente ns1:IndiceBaseParaElModulo1,
        ns1:IndiceBaseParaElModulo2,
        ns1:IndiceBaseParaElModulo3,
        ns1:IndiceBaseParaElModulo4 .

ns1:IndiceBaseParaElModulo1 a ns1:Parametro ;
    rdfs:label "Índice base para el Módulo 1" ;
    ns1:identificador "1" ;
    ns1:textoExtracto "Módulo 1. | 1 | I1...I16 | 33 O33...O48" .

ns1:IndiceBaseParaElModulo2 a ns1:Parametro ;
    rdfs:label "Índice base para el Módulo 2" ;
    ns1:identificador "33" ;
    ns1:textoExtracto "Módulo 2. | 33 | I33...I48 | 81 O81...O96" .

ns1:IndiceBaseParaElModulo3 a ns1:Parametro ;
    rdfs:label "Índice base para el Módulo 3" ;
    ns1:identificador "97" ;
    ns1:textoExtracto "Módulo 3. | 97 | I97...I112 | 49 O49...O64" .

ns1:IndiceBaseParaElModulo4 a ns1:Parametro ;
    rdfs:label "Índice base para el Módulo 4" ;
    ns1:identificador "113" ;
    ns1:textoExtracto "Módulo 4. | 113 | I113...I128 | - - - - - -" .

