@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoT a ns1:Parametro ;
    rdfs:label "Estado T" ;
    ns1:textoExtracto "En el arranque del PLC se inicializan todos los temporizadores, asignando el valor 0 a su estado T y cancelando su cuenta (la inicializa a 0)." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "En el arranque del PLC se inicializan todos los temporizadores, asignando el valor 0 a su estado T y cancelando su cuenta (la inicializa a 0)." ;
    ns1:tieneComponente ns1:EntradaI2,
        ns1:EntradaTRS,
        ns1:TemporizadorT10 .

ns1:EntradaI2 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada I2" ;
    ns1:controla ns1:EntradaTEN10_051d2a4840 ;
    ns1:textoExtracto "La entrada I2 controla la entrada de enable del temporizador T10." .

ns1:EntradaTEN10_051d2a4840 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada TEN 10" ;
    ns1:identificador "TEN 10" ;
    ns1:textoExtracto "La entrada I2 controla la entrada de enable del temporizador T10." .

ns1:EntradaTRS a ns1:ComponenteElectrico ;
    rdfs:label "Entrada TRS" ;
    ns1:textoExtracto "Permite inicializar el temporizador, asignando el valor 0 a su estado T y cancelando su cuenta (la inicializa a 0)." .

ns1:TemporizadorT10 a ns1:ComponenteElectrico ;
    rdfs:label "Temporizador T10" ;
    ns1:textoExtracto "La entrada I2 controla la entrada de enable del temporizador T10." .

