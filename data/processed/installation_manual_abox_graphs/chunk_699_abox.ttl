@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:PLC_RecursosProgramacion
    a ex:Sistema ;
    rdfs:label "Recursos de programación del PLC"@es ;
    ex:textoExtracto "Recursos disponibles en el PLC. Entradas (I1ꞏꞏI1024) Salidas (O1ꞏꞏO1024) Marcas (M1ꞏꞏM8192) Marcas de mensajes (MSG1ꞏꞏMSG1024) Marcas de errores (ERR1ꞏꞏERR1024) Relojes (CLK) Marcas CNC-PLC Temporizadores (T1ꞏꞏT512) Contadores (C1ꞏꞏC256) Registros (R1ꞏꞏR1024) Registros CNC-PLC"@es ;
    ex:compuestoPor ex:PLC_Entradas, ex:PLC_Salidas, ex:PLC_Marcas, ex:PLC_MarcasMensajes,
                    ex:PLC_MarcasErrores, ex:PLC_Relojes, ex:PLC_MarcasCNC,
                    ex:PLC_Temporizadores, ex:PLC_Contadores, ex:PLC_Registros .

ex:PLC_Entradas
    a ex:ComponenteElectrico ;
    rdfs:label "Entradas del PLC (I1-I1024)"@es ;
    ex:identificador "I1ꞏꞏI1024" ;
    ex:textoExtracto "Entradas (I1ꞏꞏI1024)"@es .

ex:PLC_Salidas
    a ex:ComponenteElectrico ;
    rdfs:label "Salidas del PLC (O1-O1024)"@es ;
    ex:identificador "O1ꞏꞏO1024" ;
    ex:textoExtracto "Salidas (O1ꞏꞏO1024)"@es .

ex:PLC_Marcas
    a ex:Parametro ;
    rdfs:label "Marcas del PLC (M1-M8192)"@es ;
    ex:identificador "M1ꞏꞏM8192" ;
    ex:textoExtracto "Marcas (M1ꞏꞏM8192)"@es .

