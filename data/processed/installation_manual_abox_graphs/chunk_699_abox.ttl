    ex:textoExtracto "Marcas de errores (ERR1ꞏꞏERR1024)"@es .

ex:PLC_Relojes
    a ex:Parametro ;
    rdfs:label "Relojes del PLC (CLK)"@es ;
    ex:identificador "CLK" ;
    ex:textoExtracto "Relojes (CLK)"@es .

ex:PLC_MarcasCNC
    a ex:Parametro ;
    rdfs:label "Marcas CNC-PLC"@es ;
    ex:textoExtracto "Marcas CNC-PLC"@es .

ex:PLC_Temporizadores
    a ex:Parametro ;
    rdfs:label "Temporizadores del PLC (T1-T512)"@es ;
    ex:identificador "T1ꞏꞏT512" ;
    ex:textoExtracto "Temporizadores (T1ꞏꞏT512)"@es .

ex:PLC_Contadores
    a ex:Parametro ;
