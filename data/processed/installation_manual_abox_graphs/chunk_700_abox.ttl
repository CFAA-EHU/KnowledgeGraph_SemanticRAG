@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConstanteDeTiempoTRS10 a ns1:Parametro ;
    rdfs:label "Constante de tiempo TRS 10" ;
    ns1:identificador "TRS10" ;
    ns1:textoExtracto "I3 = TRS 10" .

ns1:ModoLimitadorDeSenalTG4 a ns1:Parametro ;
    rdfs:label "Modo limitador de señal TG4" ;
    ns1:identificador "TG4" ;
    ns1:textoExtracto "TG4 activa el modo limitador de señal." .

ns1:ModoMonoestableTG1 a ns1:Parametro ;
    rdfs:label "Modo monoestable TG1" ;
    ns1:identificador "TG1" ;
    ns1:textoExtracto "TG1 activa el modo monoestable." .

ns1:ModoRetardoALaConexionTG2 a ns1:Parametro ;
    rdfs:label "Modo retardo a la conexión TG2" ;
    ns1:identificador "TG2" ;
    ns1:textoExtracto "TG2 activa el modo retardo a la conexión." .

ns1:ModoRetardoALaDesconexionTG3 a ns1:Parametro ;
    rdfs:label "Modo retardo a la desconexión TG3" ;
    ns1:identificador "TG3" ;
    ns1:textoExtracto "TG3 activa el modo retardo a la desconexión." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Por defecto y cada vez que se activa un temporizador el PLC pone esta entrada a (=0)." .

ns1:EntradaI3 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada I3" ;
    ns1:controla ns1:SistemaTemporizadorT10 ;
    ns1:textoExtracto "La entrada I3 controla la entrada de reset del temporizador T10." .

ns1:SistemaTemporizadorT10 a ns1:Sistema ;
    rdfs:label "Sistema Temporizador T10" ;
    ns1:textoExtracto "La entrada I3 controla la entrada de reset del temporizador T10." ;
    ns1:tieneComponente ns1:EntradaI3 .

