ns1:RegistroInternoRParaConstanteDeTiempo a ns1:Parametro ;
    rdfs:label "Registro interno R para constante de tiempo" ;
    ns1:identificador "R" ;
    ns1:textoExtracto "La constante de tiempo se define con un valor numérico o con el valor interno de un registro R." .

