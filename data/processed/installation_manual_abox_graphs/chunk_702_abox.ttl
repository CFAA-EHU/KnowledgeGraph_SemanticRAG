@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaTemporizadores a ns1:Sistema ;
    rdfs:label "Sistema de Temporizadores" ;
    ns1:textoExtracto "El temporizador se activa, dependiendo del número de entrada seleccionada, cuando se produce un flanco de subida, transición de (=0) a (=1), o un flanco de bajada." ;
    ns1:tieneComponente ns1:ModoDeRetardoALaConexionDelTemporizador,
        ns1:ModoMonoestableDelTemporizador,
        ns1:RegistroR200QueFijaElValorDelTiempo,
        ns1:SalidaDeEstadoDelTemporizador1,
        ns1:SalidaDeEstadoYTiempoTranscurridoDelTemporizador123 .

ns1:ModoDeRetardoALaConexionDelTemporizador a ns1:Parametro ;
    rdfs:label "Modo de retardo a la conexión del temporizador" ;
    ns1:identificador "TG2" ;
    ns1:textoExtracto "Activa el temporizador T22 en modo de retardo a la conexión (TG2) con la constante de tiempo que fija el valor del registro R200, en ms." .

ns1:ModoMonoestableDelTemporizador a ns1:Parametro ;
    rdfs:label "Modo monoestable del temporizador" ;
    ns1:identificador "TG1" ;
    ns1:textoExtracto "Activa el temporizador T20 en modo monoestable (TG1) con una constante de tiempo de 100 ms." .

ns1:RegistroR200QueFijaElValorDelTiempo a ns1:Parametro ;
    rdfs:label "Registro R200 que fija el valor del tiempo" ;
    ns1:identificador "R200" ;
    ns1:textoExtracto "Activa el temporizador T22 en modo de retardo a la conexión (TG2) con la constante de tiempo que fija el valor del registro R200, en ms." .

ns1:SalidaDeEstadoDelTemporizador1 a ns1:Parametro ;
    rdfs:label "Salida de estado del temporizador 1" ;
    ns1:identificador "T1" ;
    ns1:textoExtracto "Se referencia mediante la letra T seguido del número de temporizador que se desea referenciar, por ejemplo T1, T25, T102, etc." .

ns1:SalidaDeEstadoYTiempoTranscurridoDelTemporizador123 a ns1:Parametro ;
    rdfs:label "Salida de estado y tiempo transcurrido del temporizador 123" ;
    ns1:identificador "T123" ;
    ns1:textoExtracto "Su representación T123 coincide con la salida de estado pero se utilizan en instrucciones de tipo distinto." .

