@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConstanteDeTiempo_a479e7483a a ns1:Parametro ;
    rdfs:label "constante de tiempo" ;
    ns1:textoExtracto "desde que se activa la entrada TG1 hasta que transcurre el tiempo indicado en la constante de tiempo." .

ns1:EntradaTG1 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada TG1" ;
    ns1:textoExtracto "Con TEN=1 y TRS=0 el temporizador se activa al producirse un flanco de subida en la entrada TG1." .

ns1:EntradaTRS a ns1:ComponenteElectrico ;
    rdfs:label "Entrada TRS" ;
    ns1:textoExtracto "Si se produce un flanco de subida en la entrada TRS, durante la temporización o después de ella, el PLC inicializa el temporizador." .

ns1:ModoOperacionMonoestable a ns1:ModoOperacion ;
    rdfs:label "Modo monoestable" ;
    ns1:textoExtracto "En este modo de funcionamiento el estado del temporizador se mantiene a nivel lógico alto (T=1) desde que se activa la entrada TG1 hasta que transcurre el tiempo indicado en la constante de tiempo." .

ns1:Parametro_8a72e3263a a ns1:Parametro ;
    rdfs:label "TEN" ;
    ns1:textoExtracto "Si una vez activado el temporizador se selecciona TEN=0, el PLC detiene la temporización." .

ns1:SalidaEstadoTemporizador a ns1:ComponenteElectrico ;
    rdfs:label "Salida de estado del temporizador" ;
    ns1:textoExtracto "En este momento la salida de estado del temporizador (T) cambia de estado (T=1) y comienza la temporización t a partir del valor ꞏ0ꞏ." .

