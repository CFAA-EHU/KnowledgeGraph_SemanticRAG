@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoRetardoConexion a ns1:ModoOperacion ;
    rdfs:label "Modo retardo a la conexión" ;
    ns1:textoExtracto "Este modo de funcionamiento permite realizar un retardo entre la activación de la entrada de arranque TG2 y la activación de la salida de estado T del temporizador." ;
    ns1:tieneComponente ns1:ConstanteTiempo,
        ns1:EntradaArranqueTG2,
        ns1:EntradaTEN,
        ns1:EntradaTRS,
        ns1:SalidaEstadoT,
        ns1:Temporizador .

ns1:ConstanteTiempo a ns1:Parametro ;
    rdfs:label "constante de tiempo" ;
    ns1:identificador "TEN=1, TRS=0" ;
    ns1:textoExtracto "La duración del retardo la fija la constante de tiempo." .

ns1:EntradaArranqueTG2 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de arranque TG2" ;
    ns1:textoExtracto "la entrada de arranque TG2" .

ns1:EntradaTEN a ns1:ComponenteElectrico ;
    rdfs:label "Entrada TEN" ;
    ns1:textoExtracto "Funcionamiento de la entrada TEN en este modo." .

ns1:EntradaTRS a ns1:ComponenteElectrico ;
    rdfs:label "Entrada TRS" ;
    ns1:textoExtracto "Funcionamiento de la entrada TRS en este modo." .

ns1:SalidaEstadoT a ns1:ComponenteElectrico ;
    rdfs:label "Salida de estado T del temporizador" ;
    ns1:textoExtracto "activación de la salida de estado T del temporizador" .

ns1:Temporizador a ns1:Sistema ;
    rdfs:label "temporizador" ;
    ns1:textoExtracto "el temporizador se activa al producirse un flanco de subida en la entrada TG2" .

