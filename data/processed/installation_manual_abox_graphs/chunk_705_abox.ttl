@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:MFUN1 a ex:Parametro ;
    ex:identificador "MFUN1" ;
    ex:valor "100" ;
    ex:textoExtracto "MFUN1 | 100" .

ex:MFUN2 a ex:Parametro ;
    ex:identificador "MFUN2" ;
    ex:valor "120" ;
    ex:textoExtracto "MFUN2 | 120" .

ex:MFUN3 a ex:Parametro ;
    ex:identificador "MFUN3" ;
    ex:valor "135" ;
    ex:textoExtracto "MFUN3 | 135" .

ex:MFUN4_MFUN7 a ex:Parametro ;
    ex:identificador "MFUN4 - MFUN7" ;
    ex:valor "$FFFFFFFF" ;
    ex:textoExtracto "MFUN4 - MFUN7 | $FFFFFFFF" .