@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_MFUN a ex:Tabla ;
     a                       ex:Tabla ;
    ex:identificador        "MFUN" ;
    ex:textoExtracto        "| MFUN1 | MFUN2 | MFUN3 | MFUN4 - MFUN7 | --- | --- | --- | --- | 100 | 120 | 135 | $FFFFFFFF" ;
    rdfs:label              "Tabla de funciones auxiliares (MFUN)"@es .

ex:Parametro_MFUN1
    a                       ex:Parametro ;
    ex:identificador        "MFUN1" ;
    ex:valor                "100" ;
    ex:documentadoEn        ex:Tabla_MFUN ;
    ex:textoExtracto        "MFUN1 [...] 100" .

ex:Parametro_MFUN2
    a                       ex:Parametro ;
    ex:identificador        "MFUN2" ;
    ex:valor                "120" ;
    ex:documentadoEn        ex:Tabla_MFUN ;
    ex:textoExtracto        "MFUN2 [...] 120" .

ex:Parametro_MFUN3
    a                       ex:Parametro ;
    ex:identificador        "MFUN3" ;
    ex:valor                "135" ;
    ex:documentadoEn        ex:Tabla_MFUN ;
    ex:textoExtracto        "MFUN3 [...] 135" .

ex:Parametro_MFUN4_7
    a                       ex:Parametro ;
    ex:identificador        "MFUN4-MFUN7" ;
    ex:valor                "$FFFFFFFF" ;
    ex:documentadoEn        ex:Tabla_MFUN ;
    ex:textoExtracto        "MFUN4 - MFUN7 [...] $FFFFFFFF" .