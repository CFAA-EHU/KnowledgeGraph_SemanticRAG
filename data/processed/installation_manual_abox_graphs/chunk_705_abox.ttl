@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConstanteDeTiempo_d58e22c993 a ns1:Parametro ;
    rdfs:label "Constante de tiempo" ;
    ns1:identificador "constante_de_tiempo" ;
    ns1:textoExtracto "La duración del retardo, está determinada por la constante de tiempo." .

ns1:Parametro_786b2eb120 a ns1:Parametro ;
    rdfs:label "Parámetro TEN" ;
    ns1:identificador "TEN" ;
    ns1:textoExtracto "Si una vez activado el temporizador se selecciona TEN=0, el PLC detiene la temporización." .

ns1:Parametro_eac9a4ae87 a ns1:Parametro ;
    rdfs:label "Parámetro TRS" ;
    ns1:identificador "TRS" ;
    ns1:textoExtracto "Funcionamiento de la entrada TRS en este modo. Si se produce un flanco de subida en la entrada TRS, durante la temporización o después de ella, el PLC inicializa el temporizador." .

ns1:SistemaTemporizadorRetardo a ns1:Sistema ;
    rdfs:label "Sistema Temporizador Retardo" ;
    ns1:documentadoEn ns1:ManualBrochadoraA218 ;
    ns1:textoExtracto "Este modo de funcionamiento permite realizar un retardo entre la desactivación de la entrada de arranque TG3 y la desactivación de la salida T del temporizador." ;
    ns1:tieneComponente ns1:EntradaTG3,
        ns1:SalidaT .

ns1:EntradaTG3 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada TG3" ;
    ns1:textoExtracto "Con TEN=1 y TRS=0, el temporizador se activa al producirse un flanco de subida en la entrada TG3." .

ns1:SalidaT a ns1:ComponenteElectrico ;
    rdfs:label "Salida T" ;
    ns1:textoExtracto "En este momento la salida de estado del temporizador toma el valor T=1." .

