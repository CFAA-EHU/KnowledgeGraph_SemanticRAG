@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaContador a ns1:Sistema ;
    rdfs:label "Sistema de Contadores" ;
    ns1:textoExtracto "Todos los contadores disponen de la salida estado C y de las entradas CUP, CDW, CEN y CPR." ;
    ns1:tieneComponente ns1:EntradaCEN,
        ns1:EntradaCPR,
        ns1:EntradaDeContaje1,
        ns1:EntradaDeDescontaje20 .

ns1:EntradaCEN a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de enable" ;
    ns1:textoExtracto "Para poder modificar la cuenta interna (CUP y CDW) la entrada CEN debe estar a (=1)." .

ns1:EntradaCPR a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de preselección" ;
    ns1:textoExtracto "Permite preseleccionar el contador con el valor deseado." .

ns1:EntradaDeContaje1 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de contaje 1" ;
    ns1:textoExtracto "I2 = CUP 10 Cada vez que se produce un flanco de subida en I2 se incrementa la cuenta del contador C10." .

ns1:EntradaDeDescontaje20 a ns1:ComponenteElectrico ;
    rdfs:label "Entrada de descontaje 20" ;
    ns1:textoExtracto "I3 = CDW 20 Cada vez que se produce un flanco de subida en I3 se decrementa la cuenta del contador C20." .

