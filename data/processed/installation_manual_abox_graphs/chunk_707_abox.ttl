@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FuncionM11 a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "Función M11" ;
    ex:textoExtracto "Se envían las funciones M11, M12 y M13 al PLC." .

ex:FuncionM12 a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "Función M12" ;
    ex:textoExtracto "Se envían las funciones M11, M12 y M13 al PLC. Se espera a que el PLC ejecute la función M12." .

ex:FuncionM13 a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "Función M13" ;
    ex:textoExtracto "Se envían las funciones M11, M12 y M13 al PLC." .

ex:FuncionM14 a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "Función M14" ;
    ex:textoExtracto "Se envía la función M14 al PLC." .

ex:PLC_Controlador
    a ex:Sistema ;
    rdfs:label "PLC" ;
    ex:textoExtracto "Se envían las funciones M11, M12 y M13 al PLC. Se espera a que el PLC ejecute la función M12. Se envía la función M14 al PLC." ;
    ex:controla ex:FuncionM11, ex:FuncionM12, ex:FuncionM13, ex:FuncionM14 .

ex:EjeX
    a ex:ComponenteMecanico ;
    rdfs:label "Eje X" ;
    ex:textoExtracto "El CNC desplaza el eje a la cota X100." .

ex:CNC_Sistema
    a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "El CNC desplaza el eje a la cota X100." ;
    ex:controla ex:EjeX .