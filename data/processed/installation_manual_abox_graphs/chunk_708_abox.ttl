@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EntradaDePreseleccion a ns1:Parametro ;
    rdfs:label "Entrada de preselección" ;
    ns1:identificador "CPR" ;
    ns1:textoExtracto "Entrada de preseleccion. Permite preseleccionar el contador con el valor deseado." .

ns1:RegistroR a ns1:Parametro ;
    rdfs:label "Valor interno del registro R" ;
    ns1:identificador "R" ;
    ns1:textoExtracto "Su valor puede indicarse con el valor numérico o con el valor interno de un registro R." .

ns1:ValorDePreseleccionDelContador_e3cf8c7214 a ns1:Parametro ;
    rdfs:label "Valor de preselección del contador" ;
    ns1:identificador "valor" ;
    ns1:textoExtracto "El contador se preselecciona con el valor indicado cuando se produce un flanco de subida en la entrada CPR." .

