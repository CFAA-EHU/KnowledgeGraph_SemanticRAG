@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:M11 a ex:ModoOperacion ;
    rdfs:label "M11" ;
    ex:textoExtracto "Se envían las funciones M11, M12 y M13 al PLC." .

ex:M12 a ex:ModoOperacion ;
    rdfs:label "M12" ;
    ex:textoExtracto "Se envían las funciones M11, M12 y M13 al PLC." ;
    ex:textoExtracto "Se espera a que el PLC ejecute la función M12." .

ex:M13 a ex:ModoOperacion ;
    rdfs:label "M13" ;
    ex:textoExtracto "Se envían las funciones M11, M12 y M13 al PLC." ;
    ex:textoExtracto "Se espera a que el PLC ejecute las funciones M13 y M14." .

ex:M14 a ex:ModoOperacion ;
    rdfs:label "M14" ;
    ex:textoExtracto "Se envía la función M14 al PLC." ;
    ex:textoExtracto "Se espera a que el PLC ejecute las funciones M13 y M14." .

ex:PLC a ex:Sistema ;
    rdfs:label "PLC" ;
    ex:textoExtracto "Se envían las funciones M11, M12 y M13 al PLC." ;
    ex:textoExtracto "Se espera a que el PLC ejecute la función M12." ;
    ex:textoExtracto "Se espera a que el PLC ejecute las funciones M13 y M14." .

ex:CNC a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "El CNC desplaza el eje a la cota X100." .