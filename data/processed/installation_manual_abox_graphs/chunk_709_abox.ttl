@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_913dcd525c a ns1:Parametro ;
    rdfs:label "Marca M100 activada si la cuenta de C123 es mayor que 1000" ;
    ns1:identificador "M100" ;
    ns1:textoExtracto "CPS C123 GT 1000 = M100 Compara si la cuenta de C123 es mayor que 1000, en cuyo caso activa la marca M100." .

ns1:PreseleccionaElContadorC20ConElValor100 a ns1:Parametro ;
    rdfs:label "Preselecciona el contador C20 con el valor 100" ;
    ns1:identificador "CPR 20 100" ;
    ns1:textoExtracto "CPR 20 100 Preselecciona el contador C20 con el valor 100." .

ns1:PreseleccionaElContadorC22ConElValorDelRegistroR200 a ns1:Parametro ;
    rdfs:label "Preselecciona el contador C22 con el valor del registro R200" ;
    ns1:identificador "CPR 22 R200" ;
    ns1:textoExtracto "CPR 22 R200 Preselecciona el contador C22 con el valor del registro R200." .

ns1:RegistroR200UtilizadoParaAlmacenarElValorDeCuentaDelContadorC123 a ns1:Parametro ;
    rdfs:label "Registro R200 utilizado para almacenar el valor de cuenta del contador C123" ;
    ns1:identificador "R200" ;
    ns1:textoExtracto "I2 = MOV C123 R200 Transfiere la cuenta de C123 al registro R200." .

ns1:SalidaDeEstadoDelContadorC1 a ns1:Parametro ;
    rdfs:label "Salida de estado del contador C1" ;
    ns1:identificador "C1" ;
    ns1:textoExtracto "(C) Salida de estado. Indica el estado lógico del contador. Se referencia mediante la letra C seguida del número de contador que se desea referenciar, por ejemplo C1, C25, C102, etc." .

ns1:SalidaDeEstadoDelContadorC102 a ns1:Parametro ;
    rdfs:label "Salida de estado del contador C102" ;
    ns1:identificador "C102" ;
    ns1:textoExtracto "(C) Salida de estado. Indica el estado lógico del contador. Se referencia mediante la letra C seguida del número de contador que se desea referenciar, por ejemplo C1, C25, C102, etc." .

ns1:SalidaDeEstadoDelContadorC25 a ns1:Parametro ;
    rdfs:label "Salida de estado del contador C25" ;
    ns1:identificador "C25" ;
    ns1:textoExtracto "(C) Salida de estado. Indica el estado lógico del contador. Se referencia mediante la letra C seguida del número de contador que se desea referenciar, por ejemplo C1, C25, C102, etc." .

ns1:SalidaDeEstadoYValorDeLaCuentaDelContadorC123 a ns1:Parametro ;
    rdfs:label "Salida de estado y valor de la cuenta del contador C123" ;
    ns1:identificador "C123" ;
    ns1:textoExtracto "(C) Valor de la cuenta. Indica el valor de la cuenta interna del contador. Se referencia mediante la letra C seguida del número de contador que se desea referenciar, por ejemplo C1, C25, C102, etc." .

