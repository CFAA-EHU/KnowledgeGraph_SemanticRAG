@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "El programa PLC puede estar formado por los siguientes módulos." ;
    ns1:tieneComponente ns1:ModuloEjecucionPeriodica,
        ns1:ModuloPrimerCiclo,
        ns1:ModuloPrincipal .

ns1:ModuloEjecucionPeriodica a ns1:Componente ;
    rdfs:label "Módulo de ejecución periódica (PE)" ;
    ns1:compuestoPor ns1:ProposicionDirectivaPE ;
    ns1:textoExtracto "• Módulo de ejecución periódica (PE)." .

ns1:ModuloPrimerCiclo a ns1:Componente ;
    rdfs:label "Módulo del primer ciclo (CY1)" ;
    ns1:compuestoPor ns1:ProposicionDirectivaCY1 ;
    ns1:textoExtracto "• Módulo del primer ciclo (CY1)." .

ns1:ModuloPrincipal a ns1:Componente ;
    rdfs:label "Módulo principal (PRG)" ;
    ns1:compuestoPor ns1:ProposicionDirectivaPRG ;
    ns1:textoExtracto "• Módulo principal (PRG)." .

ns1:ProposicionDirectivaCY1 a ns1:Componente,
        ns1:Parametro ;
    rdfs:label "Proposición directiva CY1",
        "Proposición directiva para el primer ciclo" ;
    ns1:identificador "CY1" ;
    ns1:textoExtracto "Cada módulo debe empezar con la proposición directiva que lo define (CY1, PRG, PE)" .

ns1:ProposicionDirectivaPE a ns1:Componente,
        ns1:Parametro ;
    rdfs:label "Proposición directiva PE",
        "Proposición directiva para el módulo de ejecución periódica" ;
    ns1:identificador "PE" ;
    ns1:textoExtracto "Cada módulo debe empezar con la proposición directiva que lo define (CY1, PRG, PE)" .

ns1:ProposicionDirectivaPRG a ns1:Componente,
        ns1:Parametro ;
    rdfs:label "Proposición directiva PRG",
        "Proposición directiva para el módulo principal" ;
    ns1:identificador "PRG" ;
    ns1:textoExtracto "Cada módulo debe empezar con la proposición directiva que lo define (CY1, PRG, PE)" .

