@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ExpresionLogica a ns1:Parametro ;
    rdfs:label "Expresión lógica" ;
    ns1:documentadoEn ns1:EsquemaProgramacionPLC ;
    ns1:identificador "I28" ;
    ns1:textoExtracto "I28 AND I30 ; Expresión lógica" .

ns1:InstruccionDeAccion a ns1:Parametro ;
    rdfs:label "Instrucción de acción" ;
    ns1:documentadoEn ns1:EsquemaProgramacionPLC ;
    ns1:identificador "M300" ;
    ns1:textoExtracto "= M300 ; Instrucción de acción" .

ns1:InstruccionDeAccion_c4820c6ee1 a ns1:Parametro ;
    rdfs:label "Instrucción de acción" ;
    ns1:documentadoEn ns1:EsquemaProgramacionPLC ;
    ns1:identificador "O25" ;
    ns1:textoExtracto "= O25 ; Instrucción de acción" .

ns1:InstruccionDeConsulta1aParteDeExpresion a ns1:Parametro ;
    rdfs:label "Instrucción de consulta (1ª parte de expresión)" ;
    ns1:documentadoEn ns1:EsquemaProgramacionPLC ;
    ns1:identificador "I32" ;
    ns1:textoExtracto "I32 \\ ; Instrucción de consulta (1ª parte de expresión)" .

ns1:InstruccionDeConsulta2aParteDeExpresion a ns1:Parametro ;
    rdfs:label "Instrucción de consulta (2ª parte de expresión)" ;
    ns1:documentadoEn ns1:EsquemaProgramacionPLC ;
    ns1:identificador "I36" ;
    ns1:textoExtracto "AND I36 ; Instrucción de consulta (2ª parte de expresión)" .

ns1:ProposicionDirectiva a ns1:Parametro ;
    rdfs:label "Proposición directiva" ;
    ns1:documentadoEn ns1:EsquemaProgramacionPLC ;
    ns1:identificador "END" ;
    ns1:textoExtracto "END ; Proposición directiva" .

ns1:ProposicionDirectiva_c40c981ec0 a ns1:Parametro ;
    rdfs:label "Proposición directiva" ;
    ns1:documentadoEn ns1:EsquemaProgramacionPLC ;
    ns1:identificador "PRG" ;
    ns1:textoExtracto "PRG ; Proposición directiva" .

ns1:ProposicionEjecutable a ns1:Parametro ;
    rdfs:label "Proposición ejecutable" ;
    ns1:documentadoEn ns1:EsquemaProgramacionPLC ;
    ns1:identificador "I100" ;
    ns1:textoExtracto "I100 = M102 ; Proposición ejecutable" .

ns1:EsquemaProgramacionPLC a ns1:Esquema ;
    rdfs:label "Ejemplo de programación del PLC" ;
    ns1:textoExtracto "Ejemplo de programación: PRG ; Proposición directiva I100 = M102 ; Proposición ejecutable I28 AND I30 ; Expresión lógica = O25 ; Instrucción de acción I32 \\ ; Instrucción de consulta (1ª parte de expresión) AND I36 ; Instrucción de consulta (2ª parte de expresión) = M300 ; Instrucción de acción END ; Proposición directiva" .

