@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FuncionAuxiliarH12 a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "Función auxiliar H12" ;
    ex:textoExtracto "las funciones H11, H12 al PLC" ;
    ex:identificador "H12" .

ex:FuncionAuxiliarH11 a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "Función auxiliar H11" ;
    ex:textoExtracto "las funciones H11, H12 al PLC" ;
    ex:identificador "H11" .

ex:FuncionAuxiliarH20 a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "Función auxiliar H20" ;
    ex:textoExtracto "las funciones H12, H20 y H35" ;
    ex:identificador "H20" .

ex:FuncionAuxiliarH35 a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "Función auxiliar H35" ;
    ex:textoExtracto "las funciones H12, H20 y H35" ;
    ex:identificador "H35" .

ex:FuncionAuxiliarH77 a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "Función auxiliar H77" ;
    ex:textoExtracto "Ejemplo para detectar H77" ;
    ex:identificador "H77" .

ex:RegistroHFUN1
    a ex:Parametro ;
    rdfs:label "Registro HFUN1" ;
    ex:textoExtracto "HFUN1 [...] 12" ;
    ex:identificador "HFUN1" ;
    ex:valor "12" .

ex:RegistroHFUN2
    a ex:Parametro ;
    rdfs:label "Registro HFUN2" ;
    ex:textoExtracto "HFUN2 [...] 20" ;
    ex:identificador "HFUN2" ;
    ex:valor "20" .

ex:RegistroHFUN3
    a ex:Parametro ;
    rdfs:label "Registro HFUN3" ;
    ex:textoExtracto "HFUN3 [...] 35" ;
    ex:identificador "HFUN3" ;
    ex:valor "35" .

ex:RegistroHFUN4
    a ex:Parametro ;
    rdfs:label "Registro HFUN4" ;
    ex:textoExtracto "HFUN4 - HFUN7 [...] $FFFFFFFF" ;
    ex:identificador "HFUN4" ;
    ex:valor "$FFFFFFFF" .

ex:RegistroHFUN5
    a ex:Parametro ;
    rdfs:label "Registro HFUN5" ;
    ex:textoExtracto "HFUN4 - HFUN7 [...] $FFFFFFFF" ;
    ex:identificador "HFUN5" ;
    ex:valor "$FFFFFFFF" .

ex:RegistroHFUN6
    a ex:Parametro ;
    rdfs:label "Registro HFUN6" ;
    ex:textoExtracto "HFUN4 - HFUN7 [...] $FFFFFFFF" ;
    ex:identificador "HFUN6" ;
    ex:valor "$FFFFFFFF" .

ex:RegistroHFUN7
    a ex:Parametro ;
    rdfs:label "Registro HFUN7" ;
    ex:textoExtracto "HFUN4 - HFUN7 [...] $FFFFFFFF" ;
    ex:identificador "HFUN7" ;
    ex:valor "$FFFFFFFF" .

ex:TablaRegistrosHFUN a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de registros HFUN1 a HFUN7" ;
    ex:textoExtracto "| HFUN1 | HFUN2 | HFUN3 | HFUN4 - HFUN7 |" ;
    ex:tieneComponente ex:RegistroHFUN1, ex:RegistroHFUN2, ex:RegistroHFUN3, ex:RegistroHFUN4, ex:RegistroHFUN5, ex:RegistroHFUN6, ex:RegistroHFUN7 .

ex:ComandoHFUN
    a ex:InterfazUsuario ;
    rdfs:label "Comando HFUN*" ;
    ex:textoExtracto "Utilizar el formato HFUN* que permite analizar todos los registros HFUN a la vez" ;
    ex:identificador "HFUN*" ;
    ex:documentadoEn ex:TablaRegistrosHFUN .

ex:BloqueEjemploX100
    a ex:ModoOperacion ;
    rdfs:label "Bloque de ejemplo X100 F1000 H11 H12" ;
    ex:textoExtracto "Si se ejecuta un bloque del siguiente tipo. X100 F1000 H11 H12" ;
    ex:identificador "X100_F1000_H11_H12" ;
    ex:tieneComponente ex:FuncionAuxiliarH11, ex:FuncionAuxiliarH12 .