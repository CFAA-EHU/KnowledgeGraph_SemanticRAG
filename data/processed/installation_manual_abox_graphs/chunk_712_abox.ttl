@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DirectivaCY1 a ns1:Directiva ;
    rdfs:label "CY1" ;
    ns1:textoExtracto "CY1 Módulo de primer ciclo." .

ns1:DirectivaEND a ns1:Directiva ;
    rdfs:label "END" ;
    ns1:textoExtracto "END Final del módulo o subrutina. Hay que definirlo para cada módulo o subrutina." .

ns1:DirectivaPEt a ns1:Directiva ;
    rdfs:label "PE t" ;
    ns1:textoExtracto "PE t Módulo periódico. Se ejecuta cada t milisegundos." .

ns1:DirectivaPRG a ns1:Directiva ;
    rdfs:label "PRG" ;
    ns1:textoExtracto "PRG Módulo principal." .

