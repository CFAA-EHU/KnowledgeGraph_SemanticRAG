@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SistemaCNC a ex:Maquina ;
    ex:textoExtracto "El CNC puede disponer de hasta cuatro canales y cada canal puede ejecutar un programa pieza en paralelo con los demás. Esto significa que en cada canal se pueden ejecutar siete funciones auxiliares simultáneamente." ;
    ex:tieneComponente ex:Canal1, ex:Canal2, ex:Canal3, ex:Canal4 .

ex:Canal1 a ex:Componente ;
    ex:identificador "Canal1" ;
    ex:textoExtracto "HFUN1C1 - HFUN7C1 para el primer canal." ;
    ex:compuestoPor ex:RegistroHFUN1C1, ex:RegistroHFUN2C1, ex:RegistroHFUN3C1, ex:RegistroHFUN4C1, ex:RegistroHFUN5C1, ex:RegistroHFUN6C1, ex:RegistroHFUN7C1 ;
    ex:valor "10, 13, $FFFFFFFF" .

ex:Canal2 a ex:Componente ;
    ex:identificador "Canal2" ;
    ex:textoExtracto "HFUN1C2 - HFUN7C2 para el segundo canal." ;
    ex:compuestoPor ex:RegistroHFUN1C2, ex:RegistroHFUN2C2, ex:RegistroHFUN3C2, ex:RegistroHFUN4C2, ex:RegistroHFUN5C2, ex:RegistroHFUN6C2, ex:RegistroHFUN7C2 ;
    ex:valor "8, 10, $FFFFFFFF" .

ex:RegistroHFUN1C1 a ex:ComponenteElectrico ;
    ex:identificador "HFUN1C1" ;
    ex:textoExtracto "HFUN1C1 - HFUN7C1 para el primer canal." ;
    ex:valor "10" .

ex:RegistroHFUN2C1 a ex:ComponenteElectrico ;
    ex:identificador "HFUN2C1" ;
    ex:textoExtracto "HFUN1C1 - HFUN7C1 para el primer canal." ;
    ex:valor "13" .

ex:RegistroHFUN1C2 a ex:ComponenteElectrico ;
    ex:identificador "HFUN1C2" ;
    ex:textoExtracto "HFUN1C2 - HFUN7C2 para el segundo canal." ;
    ex:valor "8" .

ex:RegistroHFUN2C2 a ex:ComponenteElectrico ;
    ex:identificador "HFUN2C2" ;
    ex:textoExtracto "HFUN1C2 - HFUN7C2 para el segundo canal." ;
    ex:valor "10" .