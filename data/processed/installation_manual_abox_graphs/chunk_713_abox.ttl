@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DirectivaFinModuloCY1 a ns1:Directiva ;
    rdfs:label "Final del módulo CY1" ;
    ns1:textoExtracto "; Final del módulo CY1" .

ns1:DirectivaFinModuloPRG a ns1:Directiva ;
    rdfs:label "Final del módulo PRG" ;
    ns1:textoExtracto "; Final del módulo PRG" .

ns1:DirectivaModuloCY1 a ns1:Directiva ;
    rdfs:label "Comienzo del módulo CY1" ;
    ns1:textoExtracto "; Comienzo del módulo CY1" .

ns1:DirectivaModuloPRG a ns1:Directiva ;
    rdfs:label "Comienzo del módulo PRG" ;
    ns1:textoExtracto "; Comienzo del módulo PRG" .

ns1:ValoresImagen a ns1:Parametro ;
    rdfs:label "Valores imagen" ;
    ns1:textoExtracto "Indican si las consultas definidas a continuación se realizan teniendo en cuenta los valores imagen (IMA)" .

ns1:ValoresReales a ns1:Parametro ;
    rdfs:label "Valores reales" ;
    ns1:textoExtracto "Indican si las consultas definidas a continuación se realizan teniendo en cuenta los valores reales (REA)" .

