@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Comando_HFUNC1
    a               ex:InterfazUsuario ;
    rdfs:label      "Comando HFUNC1*" ;
    ex:textoExtracto "HFUNC1* Para el canal 1"@es ;
    ex:identificador "HFUNC1*" .

ex:Comando_HFUNC2
    a               ex:InterfazUsuario ;
    rdfs:label      "Comando HFUNC2*" ;
    ex:textoExtracto "HFUNC2* Para el canal 2"@es ;
    ex:identificador "HFUNC2*" .

ex:Comando_HFUNC3
    a               ex:InterfazUsuario ;
    rdfs:label      "Comando HFUNC3*" ;
    ex:textoExtracto "HFUNC3* Para el canal 3"@es ;
    ex:identificador "HFUNC3*" .

ex:Comando_HFUNC4
    a               ex:InterfazUsuario ;
    rdfs:label      "Comando HFUNC4*" ;
    ex:textoExtracto "HFUNC4* Para el canal 4"@es ;
    ex:identificador "HFUNC4*" .

ex:SistemaMulticabezal
    a               ex:Sistema ;
    rdfs:label      "Sistema de opción multicabezal y canales"@es ;
    ex:textoExtracto "Particularidades con la opción multicabezal y canales"@es ;
    ex:tieneComponente
        ex:Comando_HFUNC1 ,
        ex:Comando_HFUNC2 ,
        ex:Comando_HFUNC3 ,
        ex:Comando_HFUNC4 .