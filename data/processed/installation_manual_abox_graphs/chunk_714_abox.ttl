@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DirectivaEXTERN a ns1:Directiva ;
    rdfs:label "Definición de subrutina externa" ;
    ns1:textoExtracto "EXTERN Definición de subrutina externa. Las subrutinas definidas en el fichero de lenguaje C que utiliza el programa deben estar definidas como externas al principio del programa, antes que la directiva DEF y los módulos CY1, PRE y PEt." .

ns1:DirectivaL a ns1:Directiva ;
    rdfs:label "Etiqueta" ;
    ns1:textoExtracto "L Etiqueta. Sirve para identificar una línea de programa." .

ns1:DirectivaSUB a ns1:Directiva ;
    rdfs:label "Definición de subrutina" ;
    ns1:textoExtracto "SUB Definición de subrutina. Indica el comienzo de una subrutina." .

