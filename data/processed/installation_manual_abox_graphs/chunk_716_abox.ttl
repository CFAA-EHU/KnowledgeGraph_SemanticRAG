@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DirectivaDEF a ns1:Directiva ;
    rdfs:label "DEF" ;
    ns1:textoExtracto "La directiva DEF permite definir un número ilimitado de símbolos para usar solamente desde el PLC." .

ns1:DirectivaEXTERN a ns1:Directiva ;
    rdfs:label "EXTERN" ;
    ns1:textoExtracto "La directiva EXTERN permite definir dichas subrutinas una a una." .

ns1:DirectivaPDEF a ns1:Directiva ;
    rdfs:label "PDEF" ;
    ns1:textoExtracto "La directiva PDEF permite definir hasta 200 símbolos que se podrán usar en el propio PLC, en un programa pieza o una aplicación externa." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "Los símbolos que superen este límite serán ignorados y el CNC mostrará el warning correspondiente." .

