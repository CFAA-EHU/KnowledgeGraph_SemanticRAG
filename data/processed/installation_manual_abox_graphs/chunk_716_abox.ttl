@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SP1FUN a ex:Parametro ;
    ex:textoExtracto "SP1FUN*" ;
    rdfs:label "SP1FUN*".

ex:SP2FUN a ex:Parametro ;
    ex:textoExtracto "SP2FUN*" ;
    rdfs:label "SP2FUN*".

ex:SP3FUN a ex:Parametro ;
    ex:textoExtracto "SP3FUN*" ;
    rdfs:label "SP3FUN*".

ex:CPS a ex:Sistema ;
    ex:textoExtracto "CPS SP1FUN* EQ 5 = ..." ;
    rdfs:label "CPS".