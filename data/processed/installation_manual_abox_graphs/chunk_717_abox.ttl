@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:MSTROBE a ex:Sensor ;
    ex:textoExtracto "El CNC activa la salida lógica general MSTROBE para indicar al PLC que debe ejecutarlas." ;
    ex:valor "MSTROBE" .

ex:HSTROBE a ex:Sensor ;
    ex:textoExtracto "EL CNC activa la salida lógica general HSTROBE para indicar al PLC que debe ejecutarlas." ;
    ex:valor "HSTROBE" .

ex:SSTROBE a ex:Sensor ;
    ex:textoExtracto "El CNC activa la salida lógica general SSTROBE para indicar al PLC que debe ejecutarla." ;
    ex:valor "SSTROBE" .

ex:AUXEND a ex:Sensor ;
    ex:textoExtracto "el CNC esperará o no la activación de la entrada general AUXEND, indicativo de fin de ejecución del PLC" ;
    ex:valor "AUXEND" .

ex:MINAENDW a ex:Parametro ;
    ex:textoExtracto "Esta marca se mantiene a (=1) durante el tiempo indicado en el parámetro MINAENDW." ;
    ex:valor "MINAENDW" .

ex:MFUN1 a ex:Parametro ;
    ex:textoExtracto "El CNC asigna a los registros MFUN1 a MFUN7 del canal los números de las funciones M programadas en el bloque." ;
    ex:valor "MFUN1" .

ex:MFUN7 a ex:Parametro ;
    ex:textoExtracto "El CNC asigna a los registros MFUN1 a MFUN7 del canal los números de las funciones M programadas en el bloque." ;
    ex:valor "MFUN7" .

ex:HFUN1 a ex:Parametro ;
    ex:textoExtracto "El CNC asigna a los registros HFUN1 a HFUN7 del canal los números de las funciones H programadas." ;
    ex:valor "HFUN1" .

ex:HFUN7 a ex:Parametro ;
    ex:textoExtracto "El CNC asigna a los registros HFUN1 a HFUN7 del canal los números de las funciones H programadas." ;
    ex:valor "HFUN7" .

ex:SFUN1 a ex:Parametro ;
    ex:textoExtracto "El CNC asigna a los registros SFUN1 a SFUN4 los valores de la S programada en cada cabezal." ;
    ex:valor "SFUN1" .

ex:SFUN4 a ex:Parametro ;
    ex:textoExtracto "El CNC asigna a los registros SFUN1 a SFUN4 los valores de la S programada en cada cabezal." ;
    ex:valor "SFUN4" .

ex:PLC a ex:Sistema ;
    ex:textoExtracto "se pasa la siguiente información al PLC" ;
    ex:valor "PLC" .

ex:canal a ex:Parametro ;
    ex:textoExtracto "La transferencia de las funciones M y H se realiza por canal." ;
    ex:valor "canal" .