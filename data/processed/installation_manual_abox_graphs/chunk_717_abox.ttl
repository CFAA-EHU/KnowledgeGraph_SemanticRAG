@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConstanteFFFF3 a ns1:Parametro ;
    rdfs:label "Constante $FFFF3" ;
    ns1:identificador "CONSTANT" ;
    ns1:textoExtracto "PDEF CONSTANT $FFFF3" .

ns1:DatosD1 a ns1:Parametro ;
    rdfs:label "Datos D1" ;
    ns1:identificador "DATA_D1" ;
    ns1:textoExtracto "DEF DATA_D1 372893" ;
    ns1:valor "372893" .

ns1:DatosD3 a ns1:Parametro ;
    rdfs:label "Datos D3" ;
    ns1:identificador "DATA_D3" ;
    ns1:textoExtracto "DEF DATA_D3 -437289" ;
    ns1:valor "-437289" .

ns1:DirectivaNOMONIT a ns1:Directiva ;
    rdfs:label "NOMONIT" ;
    ns1:textoExtracto "NOMONIT No monitorización. Cuando se programa esta directiva no se genera la información necesaria para la monitorización del programa de PLC." .

ns1:DirectivaPDEF a ns1:Directiva ;
    rdfs:label "PDEF" ;
    ns1:textoExtracto "El archivo se guarda en la carpeta ..\\MTB\\PLC\\Project. PDEF COOL I12 PDEF CONSTANT $FFFF3 DEF DATA_D1 372893 DEF DATA_D3 -437289 DEF /FAN I23" .

ns1:Parametro_0eb9058d38 a ns1:Parametro ;
    rdfs:label "Parámetro FAN" ;
    ns1:identificador "FAN" ;
    ns1:textoExtracto "DEF /FAN I23" .

ns1:Parametro_b0131f5786 a ns1:Parametro ;
    rdfs:label "Parámetro COOL" ;
    ns1:identificador "COOL" ;
    ns1:textoExtracto "PDEF COOL I12" .

