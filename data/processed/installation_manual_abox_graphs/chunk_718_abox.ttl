@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SSTROBE a ex:ComponenteElectrico ;
    rdfs:label "SSTROBE" ;
    ex:textoExtracto "El CNC activa la salida lógica general SSTROBE para indicar al PLC que debe ejecutarla."@es ;
    ex:textoExtracto "El CNC desactiva la salida lógica general SSTROBE para dar por finalizada su ejecución."@es .

ex:AUXEND a ex:ComponenteElectrico ;
    rdfs:label "AUXEND" ;
    ex:textoExtracto "El CNC espera la activación de la entrada general AUXEND, indicativo de fin de ejecución del PLC."@es .