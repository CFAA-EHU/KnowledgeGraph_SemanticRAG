@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FuncionS a ex:ModoOperacion ;
    rdfs:label "Función S (transferencia sincronizada)" ;
    ex:textoExtracto "Este tipo de transferencia se efectúa con la función S [...] Transferencia de la función –S– 1 El CNC indica en los registros SFUN1 a SFUN4 el valor de la S programada en el bloque y activa la marca SSTROBE para que el PLC las ejecute." .

ex:FuncionesM a ex:ModoOperacion ;
    rdfs:label "Funciones M personalizadas (transferencia sincronizada)" ;
    ex:textoExtracto "Este tipo de transferencia se efectúa con [...] las funciones M personalizadas con sincronización. [...] Transferencia de las funciones –M– 1 El CNC indica en los registros MFUN1 a MFUN7 del canal las funciones M programadas en el bloque y activa la marca MSTROBE para que el PLC las ejecute." .

ex:Senal_SSTROBE a ex:ComponenteElectrico ;
    rdfs:label "SSTROBE" ;
    ex:textoExtracto "activa la marca SSTROBE para que el PLC las ejecute." .

ex:Senal_MSTROBE a ex:ComponenteElectrico ;
    rdfs:label "MSTROBE" ;
    ex:textoExtracto "activa la marca MSTROBE para que el PLC las ejecute." .

ex:Senal_AUXEND a ex:ComponenteElectrico ;
    rdfs:label "AUXEND" ;
    ex:textoExtracto "se activan las señales SSTROBE o MSTROBE correspondientes pero se espera a una única señal AUXEND para dar por finalizadas todas ellas." .

ex:Parametro_MINAENDW a ex:Parametro ;
    rdfs:label "MINAENDW" ;
    ex:textoExtracto "La marca AUXEND debe mantenerse a (=1) un tiempo superior al definido en el parámetro MINAENDW." ;
    ex:valor "Tiempo mínimo de activación de AUXEND" .

ex:Registro_SFUN1 a ex:ComponenteElectrico ;
    rdfs:label "SFUN1" ;
    ex:textoExtracto "El CNC indica en los registros SFUN1 a SFUN4 el valor de la S programada en el bloque" .

ex:Registro_SFUN2 a ex:ComponenteElectrico ;
    rdfs:label "SFUN2" ;
    ex:textoExtracto "El CNC indica en los registros SFUN1 a SFUN4 el valor de la S programada en el bloque" .

ex:Registro_SFUN3 a ex:ComponenteElectrico ;
    rdfs:label "SFUN3" ;
    ex:textoExtracto "El CNC indica en los registros SFUN1 a SFUN4 el valor de la S programada en el bloque" .

ex:Registro_SFUN4 a ex:ComponenteElectrico ;
    rdfs:label "SFUN4" ;
    ex:textoExtracto "El CNC indica en los registros SFUN1 a SFUN4 el valor de la S programada en el bloque" .

ex:Registro_MFUN1 a ex:ComponenteElectrico ;
    rdfs:label "MFUN1" ;
    ex:textoExtracto "El CNC indica en los registros MFUN1 a MFUN7 del canal las funciones M programadas en el bloque" .

ex:Registro_MFUN2 a ex:ComponenteElectrico ;
    rdfs:label "MFUN2" ;
    ex:textoExtracto "El CNC indica en los registros MFUN1 a MFUN7 del canal las funciones M programadas en el bloque" .

ex:Registro_MFUN3 a ex:ComponenteElectrico ;
    rdfs:label "MFUN3" ;
    ex:textoExtracto "El CNC indica en los registros MFUN1 a MFUN7 del canal las funciones M programadas en el bloque" .

ex:Registro_MFUN4 a ex:ComponenteElectrico ;
    rdfs:label "MFUN4" ;
    ex:textoExtracto "El CNC indica en los registros MFUN1 a MFUN7 del canal las funciones M programadas en el bloque" .

ex:Registro_MFUN5 a ex:ComponenteElectrico ;
    rdfs:label "MFUN5" ;
    ex:textoExtracto "El CNC indica en los registros MFUN1 a MFUN7 del canal las funciones M programadas en el bloque" .

ex:Registro_MFUN6 a ex:ComponenteElectrico ;
    rdfs:label "MFUN6" ;
    ex:textoExtracto "El CNC indica en los registros MFUN1 a MFUN7 del canal las funciones M programadas en el bloque" .

ex:Registro_MFUN7 a ex:ComponenteElectrico ;
    rdfs:label "MFUN7" ;
    ex:textoExtracto "El CNC indica en los registros MFUN1 a MFUN7 del canal las funciones M programadas en el bloque" .

ex:SistemaTransferenciaSincronizada a ex:Sistema ;
    rdfs:label "Sistema de transferencia sincronizada CNC-PLC" ;
    ex:textoExtracto "Este tipo de transferencia se efectúa con la función S y con las funciones M personalizadas con sincronización." ;
    ex:tieneComponente ex:Senal_SSTROBE, ex:Senal_MSTROBE, ex:Senal_AUXEND ;
    ex:tieneComponente ex:Registro_SFUN1, ex:Registro_SFUN2, ex:Registro_SFUN3, ex:Registro_SFUN4 ;
    ex:tieneComponente ex:Registro_MFUN1, ex:Registro_MFUN2, ex:Registro_MFUN3, ex:Registro_MFUN4, ex:Registro_MFUN5, ex:Registro_MFUN6, ex:Registro_MFUN7 ;
    ex:monitoreaParametro ex:Parametro_MINAENDW .

ex:FuncionS a ex:Tabla ;
    ex:documentadoEn ex:SistemaTransferenciaSincronizada .
ex:FuncionesM a ex:Tabla ;
    ex:documentadoEn ex:SistemaTransferenciaSincronizada .