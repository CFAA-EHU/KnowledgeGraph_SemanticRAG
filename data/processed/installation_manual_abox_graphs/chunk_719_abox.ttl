@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SSTROBE a ex:Sensor ;
    ex:textoExtracto "se activan las señales SSTROBE o MSTROBE correspondientes" ;
    rdfs:label "SSTROBE" .

ex:MSTROBE a ex:Sensor ;
    ex:textoExtracto "se activan las señales SSTROBE o MSTROBE correspondientes" ;
    rdfs:label "MSTROBE" .

ex:AUXEND a ex:Sensor ;
    ex:textoExtracto "se espera a una única señal AUXEND para dar por finalizadas todas ellas" ;
    rdfs:label "AUXEND" .

ex:MINAENDW a ex:Parametro ;
    ex:textoExtracto "un tiempo superior al definido en el parámetro MINAENDW" ;
    ex:valor "MINAENDW" ;
    rdfs:label "MINAENDW" .

ex:MFUN1 a ex:Parametro ;
    ex:textoExtracto "en los registros MFUN1 a MFUN7 del canal las funciones M programadas" ;
    ex:valor "MFUN1" ;
    rdfs:label "MFUN1" .

ex:MFUN7 a ex:Parametro ;
    ex:textoExtracto "en los registros MFUN1 a MFUN7 del canal las funciones M programadas" ;
    ex:valor "MFUN7" ;
    rdfs:label "MFUN7" .

ex:SFUN1 a ex:Parametro ;
    ex:textoExtracto "en los registros SFUN1 a SFUN4 el valor de la S programada" ;
    ex:valor "SFUN1" ;
    rdfs:label "SFUN1" .

ex:SFUN4 a ex:Parametro ;
    ex:textoExtracto "en los registros SFUN1 a SFUN4 el valor de la S programada" ;
    ex:valor "SFUN4" ;
    rdfs:label "SFUN4" .

ex:PLC a ex:Sistema ;
    ex:textoExtracto "el PLC debe desactivar la marca AUXEND para indicar al CNC que comienza la ejecución" ;
    rdfs:label "PLC" .

ex:CNC a ex:Sistema ;
    ex:textoExtracto "El CNC indica en los registros MFUN1 a MFUN7 del canal las funciones M programadas" ;
    rdfs:label "CNC" .