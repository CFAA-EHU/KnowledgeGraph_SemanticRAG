@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DirectivaProposicionesDirectivas a ns1:Directiva ;
    rdfs:label "Proposiciones directivas" ;
    ns1:cumpleNormativa ns1:DirectivaDEF,
        ns1:ModuloCY1,
        ns1:ModuloPEt,
        ns1:ModuloPRG ;
    ns1:textoExtracto "Programarla siempre al principio del programa, antes que la directiva DEF y los módulos CY1, PRG y PEt." .

ns1:DirectivaDEF a ns1:Directiva ;
    rdfs:label "DEF" ;
    ns1:textoExtracto "Programarla siempre al principio del programa, antes que la directiva DEF y los módulos CY1, PRG y PEt." .

ns1:ModuloCY1 a ns1:Sistema ;
    rdfs:label "Módulo CY1" ;
    ns1:textoExtracto "Programarla siempre al principio del programa, antes que la directiva DEF y los módulos CY1, PRG y PEt." .

ns1:ModuloPEt a ns1:Sistema ;
    rdfs:label "Módulo PEt" ;
    ns1:textoExtracto "Programarla siempre al principio del programa, antes que la directiva DEF y los módulos CY1, PRG y PEt." .

ns1:ModuloPRG a ns1:Sistema ;
    rdfs:label "Módulo PRG" ;
    ns1:textoExtracto "Programarla siempre al principio del programa, antes que la directiva DEF y los módulos CY1, PRG y PEt." .

