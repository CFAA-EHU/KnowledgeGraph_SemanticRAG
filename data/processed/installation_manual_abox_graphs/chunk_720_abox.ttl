@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:FuncionM a ex:Tabla ;
    ex:textoExtracto "El CNC indica en los registros MFUN1 a MFUN7 del canal las funciones M programadas en el bloque y activa la marca MSTROBE para que el PLC las ejecute." ;
    a ex:Parametro ;
    ex:identificador "MFUN1 a MFUN7" ;
    ex:valor "funciones M programadas en el bloque" .

ex:FuncionH a ex:Tabla ;
    ex:textoExtracto "El CNC indica en los registros HFUN1 a HFUN7 del canal las funciones H programadas en el bloque y activa la marca HSTROBE para que el PLC las ejecute." ;
    a ex:Parametro ;
    ex:identificador "HFUN1 a HFUN7" ;
    ex:valor "funciones H programadas en el bloque" .

ex:MarcaMSTROBE ex:textoExtracto "activa la marca MSTROBE para que el PLC las ejecute." ;
    a ex:Parametro ;
    ex:identificador "MSTROBE" .

ex:MarcaHSTROBE ex:textoExtracto "activa la marca HSTROBE para que el PLC las ejecute." ;
    a ex:Parametro ;
    ex:identificador "HSTROBE" .

ex:ParametroMINAENDW ex:textoExtracto "El CNC mantiene activa la marca MSTROBE durante el tiempo indicado en el parámetro MINAENDW." ;
    a ex:Parametro ;
    ex:identificador "MINAENDW" .

ex:ParametroPRGFREQ ex:textoExtracto "Es aconsejable que el valor del parámetro MINAENDW sea igual o superior a la periodicidad con que se ejecuta el programa de PLC, parámetro PRGFREQ" ;
    a ex:Parametro ;
    ex:identificador "PRGFREQ" .

ex:SistemaCNC ex:textoExtracto "Este tipo de transferencia se efectúa con la función H y las funciones M personalizadas sin sincronización." ;
    a ex:Sistema ;
    ex:identificador "CNC" .

ex:SistemaPLC ex:textoExtracto "para que el PLC las ejecute" ;
    a ex:Sistema ;
    ex:identificador "PLC" .