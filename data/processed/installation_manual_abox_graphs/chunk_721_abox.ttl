@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MSG1 a ex:Sensor ;
    rdfs:label "MSG1" ;
    ex:textoExtracto "MSG1 - MSG1024 para visualizar mensajes." ;
    ex:identificador "MSG1" .

ex:ERR1 a ex:Sensor ;
    rdfs:label "ERR1" ;
    ex:textoExtracto "ERR1 - ERR1024 para visualizar errores." ;
    ex:identificador "ERR1" .

ex:TablaMensajesErrores a ex:Tabla ;
    rdfs:label "Tabla de mensajes y errores" ;
    ex:textoExtracto "En el PLC hay una tabla de mensajes y errores en la que se puede asociar a cada mensaje o error lo siguiente: • Un número (campo ID). • Un texto (campo \"Mensaje\"). • Un archivo de información adicional (campo \"Archivo asociado\"), que podrá ser un fichero del tipo bmp, txt, jpg, gif, htm, html ó avi. • Si al activarse un error o mensaje, se debe mostrar directamente el fichero de ayuda adicional (campo \"Mostrar\" seleccionado) o sólo el texto del mensaje o error. • En el caso de los errores, si estos abren o no el relé de emergencia de la unidad central." .

ex:VentanaMensajesPLC a ex:InterfazUsuario ;
    rdfs:label "Ventana de mensajes del PLC" ;
    ex:textoExtracto "Al activarse una de las marcas MSG, el CNC muestra en la ventana de mensajes del PLC, dentro de la barra de estado, el número de mensaje y su texto asociado." .

ex:IconoAccesoMensaje a ex:ElementoSeguridad ;
    rdfs:label "Icono de acceso a mensaje" ;
    ex:textoExtracto "Si el mensaje tiene asociado un fichero de información adicional, se mostrará un icono de acceso a la izquierda del mensaje." .

ex:SimboloMasMensajes a ex:ElementoSeguridad ;
    rdfs:label "Símbolo +" ;
    ex:textoExtracto "En la ventana de mensajes del PLC aparece el símbolo \"+\", indicativo de que existen más mensajes activados por el PLC." .

ex:VentanaAzulMensaje a ex:InterfazUsuario ;
    rdfs:label "Ventana azul de mensaje" ;
    ex:textoExtracto "Si el mensaje tiene seleccionado el campo \"Mostrar\", el CNC muestra directamente en la pantalla el archivo de información adicional, y si no existe, una ventana azul con el texto del mensaje." .