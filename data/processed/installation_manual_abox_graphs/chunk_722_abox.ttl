@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDeLaEntradaI12 a ns1:Parametro ;
    rdfs:label "Estado de la entrada I12" ;
    ns1:identificador "I12" ;
    ns1:textoExtracto "Devuelve un 1 si la entrada I12 se encuentra activa y un 0 en caso contrario." .

ns1:EstadoDeLaTeclaStartDelPanelFrontal a ns1:Parametro ;
    rdfs:label "Estado de la tecla start del panel frontal" ;
    ns1:identificador "START" ;
    ns1:textoExtracto "Devuelve un 1 cuando la tecla start del panel frontal está pulsada y un 0 en caso contrario." .

