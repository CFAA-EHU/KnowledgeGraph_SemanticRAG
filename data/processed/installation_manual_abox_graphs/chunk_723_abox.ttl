@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:OEM_txt a ex:Esquema ;
    ex:textoExtracto "El fichero OEM.txt tendrá la siguiente estructura. [ 10] Texto de ayuda. [ 27] Texto de ayuda. [ 33] Texto de ayuda." ;
    ex:compuestoPor ex:texto_ayuda_10, ex:texto_ayuda_27, ex:texto_ayuda_33 .

ex:texto_ayuda_10 a ex:Tabla ;
    ex:textoExtracto "[ 10] Texto de ayuda." ;
    ex:identificador "10" .

ex:texto_ayuda_27 a ex:Tabla ;
    ex:textoExtracto "[ 27] Texto de ayuda." ;
    ex:identificador "27" .

ex:texto_ayuda_33 a ex:Tabla ;
    ex:textoExtracto "[ 33] Texto de ayuda." ;
    ex:identificador "33" .

ex:ruta_OEM_txt a ex:Tabla ;
    ex:textoExtracto "C:\\FAGORCNC\\MTB\\PLC\\LANG\\OEM.txt#27" ;
    ex:identificador "C:\\FAGORCNC\\MTB\\PLC\\LANG\\OEM.txt#27" .