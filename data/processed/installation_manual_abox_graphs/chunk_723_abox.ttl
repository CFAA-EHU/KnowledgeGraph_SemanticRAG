@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_42ad8ff953 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Marcas de comunicación CNC-PLC" .

ns1:DetectarFlancoDeBajada a ns1:Parametro ;
    rdfs:label "Detectar flanco de bajada" ;
    ns1:identificador "DFD" ;
    ns1:textoExtracto "DFD Detectar flanco de bajada. Detecta si se ha producido un flanco de bajada, cambio de estado de 1 a 0, en el recurso especificado." .

ns1:DetectarFlancoDeSubida a ns1:Parametro ;
    rdfs:label "Detectar flanco de subida" ;
    ns1:identificador "DFU" ;
    ns1:textoExtracto "DFU Detectar flanco de subida. Detecta si se ha producido un flanco de subida, cambio de estado de 0 a 1, en el recurso especificado." .

