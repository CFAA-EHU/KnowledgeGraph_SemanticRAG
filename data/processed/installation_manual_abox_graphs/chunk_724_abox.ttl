@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ContadorC12 a ns1:Parametro ;
    rdfs:label "Contador C12" ;
    ns1:textoExtracto "CPS C12 GT R14 = M100 Si la cuenta interna del contador C12 es MAYOR que el valor del registro R14, el PLC asignará a la marca M100 el valor 1, y el valor 0 en caso contrario." .

ns1:CuentaInternaDelTemporizadorT1 a ns1:Parametro ;
    rdfs:label "Cuenta interna del temporizador T1" ;
    ns1:textoExtracto "T1ꞏꞏ512 GT CPS T1ꞏꞏ512 C1ꞏꞏ256 GE C1ꞏꞏ256 R1ꞏꞏ1024 EQ R1ꞏꞏ1024 R CNC-PLC NE R CNC-PLC LT" .

ns1:InstruccionDeComparacionEntreOperandos a ns1:Parametro ;
    rdfs:label "Instrucción de comparación entre operandos" ;
    ns1:textoExtracto "La instrucción CPS permite realizar comparaciones entre dos operandos, comprobando si el primer operando es mayor (GT), mayor o igual (GE), igual (EQ), distinto (NE), menor o igual (LE) o menor (LT) que el segundo." .

ns1:RegistroR14 a ns1:Parametro ;
    rdfs:label "Registro R14" ;
    ns1:textoExtracto "CPS C12 GT R14 = M100 Si la cuenta interna del contador C12 es MAYOR que el valor del registro R14, el PLC asignará a la marca M100 el valor 1, y el valor 0 en caso contrario." .

ns1:TemporizadorT2_f8d6272bb2 a ns1:Parametro ;
    rdfs:label "Temporizador T2" ;
    ns1:textoExtracto "CPS T2 EQ 100 = TG1 5 2000 Cuando el tiempo que lleve transcurrido el temporizador T2 sea IGUAL al valor 100, se activará el temporizador T5 funcionando como monoestable y con una constante de tiempo de 2 s." .

ns1:TemporizadorTG1 a ns1:Parametro ;
    rdfs:label "Temporizador TG1" ;
    ns1:textoExtracto "CPS T2 EQ 100 = TG1 5 2000 Cuando el tiempo que lleve transcurrido el temporizador T2 sea IGUAL al valor 100, se activará el temporizador T5 funcionando como monoestable y con una constante de tiempo de 2 s." .

