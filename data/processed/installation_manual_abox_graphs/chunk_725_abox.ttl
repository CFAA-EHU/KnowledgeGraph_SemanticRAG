@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaLogicoConsultas a ns1:Sistema ;
    rdfs:label "Sistema de consultas lógicas" ;
    ns1:textoExtracto "Los operadores disponibles son NOT, AND, OR, XOR." ;
    ns1:tieneComponente ns1:AccionProhibida_28e20e3de3,
        ns1:AccionProhibida_663190d32b,
        ns1:AccionProhibida_7b68c74a44,
        ns1:AccionProhibida_f4d951638b .

ns1:AccionProhibida_28e20e3de3 a ns1:AccionProhibida ;
    rdfs:label "OR" ;
    ns1:textoExtracto "OR Función lógica \"O\"."@es .

ns1:AccionProhibida_663190d32b a ns1:AccionProhibida ;
    rdfs:label "XOR" ;
    ns1:textoExtracto "XOR Función lógica \"O Exclusivo\"."@es .

ns1:AccionProhibida_7b68c74a44 a ns1:AccionProhibida ;
    rdfs:label "NOT" ;
    ns1:textoExtracto "NOT Invierte el resultado de la consulta." .

ns1:AccionProhibida_f4d951638b a ns1:AccionProhibida ;
    rdfs:label "AND" ;
    ns1:textoExtracto "AND Función lógica \"Y\"."@es .

