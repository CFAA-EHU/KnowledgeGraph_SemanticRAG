@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EntradaSalidaFisicaCNC a ex:Sistema ;
    rdfs:label "Entradas y salidas físicas del CNC" ;
    ex:textoExtracto "Se denominan entradas y salidas físicas del CNC al conjunto de entradas y salidas del sistema que, siendo gobernadas por el PLC, se comunican con el exterior a través de los conectores del CNC." ;
    ex:compuestoPor ex:ConectorCNC .

ex:ConectorCNC a ex:ComponenteElectrico ;
    rdfs:label "Conectores del CNC" ;
    ex:textoExtracto "se comunican con el exterior a través de los conectores del CNC" .

ex:EntradaSalidaLogicaCNC a ex:Sistema ;
    rdfs:label "Entradas y salidas lógicas del CNC" ;
    ex:textoExtracto "El CNC dispone además de una serie de entradas y salidas lógicas para el intercambio de información interna con las marcas y registros del PLC." ;
    ex:compuestoPor ex:SenalLogicaCNC .

ex:SenalLogicaCNC a ex:Sensor ;
    rdfs:label "Señal lógica del CNC" ;
    ex:textoExtracto "Cada una de estas entradas y salidas lógicas puede referenciarse mediante su mnemónico asociado." .

ex:PLC a ex:Sistema ;
    rdfs:label "PLC" ;
    ex:textoExtracto "siendo gobernadas por el PLC" ;
    ex:controla ex:EntradaSalidaFisicaCNC, ex:EntradaSalidaLogicaCNC .

ex:Mnemonico_AUXEND a ex:Parametro ;
    rdfs:label "_AUXEND" ;
    ex:identificador "_AUXEND" ;
    ex:textoExtracto "CNCREADY _ALARM AUXEND _EMERGEN MANUAL _STOP" ;
    ex:valor "=0" .

ex:Mnemonico_EMERGEN a ex:Parametro ;
    rdfs:label "_EMERGEN" ;
    ex:identificador "_EMERGEN" ;
    ex:textoExtracto "CNCREADY _ALARM AUXEND _EMERGEN MANUAL _STOP" ;
    ex:valor "=0" .

ex:Mnemonico_STOP a ex:Parametro ;
    rdfs:label "_STOP" ;
    ex:identificador "_STOP" ;
    ex:textoExtracto "CNCREADY _ALARM AUXEND _EMERGEN MANUAL _STOP" ;
    ex:valor "=0" .

ex:SenalConsultaGeneral a ex:Sensor ;
    rdfs:label "Señal de consulta general" ;
    ex:textoExtracto "Las salidas lógicas del CNC o señales de consulta del PLC se agrupan en: • Señales de consulta generales." .

ex:SenalConsultaEje a ex:Sensor ;
    rdfs:label "Señal de consulta de los ejes" ;
    ex:textoExtracto "• Señales de consulta de los ejes." .

ex:SenalConsultaCabezales a ex:Sensor ;
    rdfs:label "Señal de consulta de los cabezales" ;
    ex:textoExtracto "• Señales de consulta de los cabezales." .

ex:SenalConsultaInterpolador a ex:Sensor ;
    rdfs:label "Señal de consulta del interpolador independiente" ;
    ex:textoExtracto "• Señales de consulta del interpolador independiente." .

ex:SenalConsultaGestorHerramientas a ex:Sensor ;
    rdfs:label "Señal de consulta del gestor de herramientas" ;
    ex:textoExtracto "• Señales de consulta del gestor de herramientas." .

ex:SenalConsultaLaser a ex:Sensor ;
    rdfs:label "Señal de consulta del laser" ;
    ex:textoExtracto "• Señales de consulta del laser." .

ex:SenalConsultaTeclas a ex:Sensor ;
    rdfs:label "Señal de consulta de las teclas" ;
    ex:textoExtracto "• Señales de consulta de las teclas." .

ex:SenalModificableGeneral a ex:Actuador ;
    rdfs:label "Señal modificable general" ;
    ex:textoExtracto "Las entradas lógicas del CNC o señales modificables por PLC se agrupan en: • Señales modificables generales." .

ex:SenalModificableEje a ex:Actuador ;
    rdfs:label "Señal modificable de los ejes" ;
    ex:textoExtracto "• Señales modificables de los ejes." .

ex:SenalModificableCabezales a ex:Actuador ;
    rdfs:label "Señal modificable de los cabezales" ;
    ex:textoExtracto "• Señales modificables de los cabezales." .

ex:SenalModificableInterpolador a ex:Actuador ;
    rdfs:label "Señal modificable del interpolador independiente" ;
    ex:textoExtracto "• Señales modificables del interpolador independiente." .

ex:SenalModificableGestorHerramientas a ex:Actuador ;
    rdfs:label "Señal modificable del gestor de herramientas" ;
    ex:textoExtracto "• Señales modificables del gestor de herramientas." .

ex:SenalModificableLaser a ex:Actuador ;
    rdfs:label "Señal modificable del laser" ;
    ex:textoExtracto "• Señales modificables del laser." .

ex:SenalModificableTeclas a ex:Actuador ;
    rdfs:label "Señal modificable de las teclas" ;
    ex:textoExtracto "• Señales modificables de las teclas." .