@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:CNCREADY a ex:Parametro ;
    rdfs:label "CNCREADY" ;
    ex:textoExtracto "Esta marca indica el estado del CNC. Tiene el valor (=0) cuando el CNC se encuentra en estado de error (ventana de status en rojo) y el valor (=1) el resto de los casos. Incluir esta marca en la maniobra del PLC para la habilitación de los reguladores." ;
    ex:valor "0 o 1" .

ex:READYC1 a ex:Parametro ;
    rdfs:label "READYC1" ;
    ex:textoExtracto "Esta marca indica el estado del canal del CNC. Tiene el valor (=0) cuando el CNC se encuentra en estado de error (ventana de status en rojo) y el valor (=1) el resto de los casos." ;
    ex:valor "0 o 1" .

ex:READYC2 a ex:Parametro ;
    rdfs:label "READYC2" ;
    ex:textoExtracto "Esta marca indica el estado del canal del CNC. Tiene el valor (=0) cuando el CNC se encuentra en estado de error (ventana de status en rojo) y el valor (=1) el resto de los casos." ;
    ex:valor "0 o 1" .

ex:READYC3 a ex:Parametro ;
    rdfs:label "READYC3" ;
    ex:textoExtracto "Esta marca indica el estado del canal del CNC. Tiene el valor (=0) cuando el CNC se encuentra en estado de error (ventana de status en rojo) y el valor (=1) el resto de los casos." ;
    ex:valor "0 o 1" .

ex:READYC4 a ex:Parametro ;
    rdfs:label "READYC4" ;
    ex:textoExtracto "Esta marca indica el estado del canal del CNC. Tiene el valor (=0) cuando el CNC se encuentra en estado de error (ventana de status en rojo) y el valor (=1) el resto de los casos." ;
    ex:valor "0 o 1" .

ex:SERCOSRDY a ex:Parametro ;
    rdfs:label "SERCOSRDY" ;
    ex:textoExtracto "En las configuraciones Sercos, esta marca indica el estado del anillo. El CNC pone esta marca a (=1) para indicar que el anillo Sercos se encuentra inicializado correctamente. Están condicionados por esta marca todos los procesos de consulta de estado de los reguladores (DRSTAF DRSTAS) y las operaciones de lectura y escritura (CNCRD CNCWR) de las variables del regulador." ;
    ex:valor "0 o 1" .

ex:START a ex:Parametro ;
    rdfs:label "START" ;
    ex:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. START Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. STARTC1 (también se puede programar como START) STARTC2 STARTC3 STARTC4 El canal del CNC activa esta marca para indicar al PLC que se ha pulsado la tecla [START] del panel de mando." ;
    ex:valor "0 o 1" .

ex:STARTC1 a ex:Parametro ;
    rdfs:label "STARTC1" ;
    ex:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. STARTC1 (también se puede programar como START) STARTC2 STARTC3 STARTC4 El canal del CNC activa esta marca para indicar al PLC que se ha pulsado la tecla [START] del panel de mando." ;
    ex:valor "0 o 1" .

ex:STARTC2 a ex:Parametro ;
    rdfs:label "STARTC2" ;
    ex:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. STARTC1 (también se puede programar como START) STARTC2 STARTC3 STARTC4 El canal del CNC activa esta marca para indicar al PLC que se ha pulsado la tecla [START] del panel de mando." ;
    ex:valor "0 o 1" .

ex:STARTC3 a ex:Parametro ;
    rdfs:label "STARTC3" ;
    ex:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. STARTC1 (también se puede programar como START) STARTC2 STARTC3 STARTC4 El canal del CNC activa esta marca para indicar al PLC que se ha pulsado la tecla [START] del panel de mando." ;
    ex:valor "0 o 1" .

ex:STARTC4 a ex:Parametro ;
    rdfs:label "STARTC4" ;
    ex:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. STARTC1 (también se puede programar como START) STARTC2 STARTC3 STARTC4 El canal del CNC activa esta marca para indicar al PLC que se ha pulsado la tecla [START] del panel de mando." ;
    ex:valor "0 o 1" .

ex:SERVOXON a ex:Parametro ;
    rdfs:label "SERVOXON" ;
    ex:textoExtracto "= SERVOXON ; Servo del eje X activo" ;
    ex:valor "0 o 1" .

ex:SPENAX a ex:Parametro ;
    rdfs:label "SPENAX" ;
    ex:textoExtracto "= SPENAX ; Habilitación Sercos del eje X" ;
    ex:valor "0 o 1" .

ex:DRENAX a ex:Parametro ;
    rdfs:label "DRENAX" ;
    ex:textoExtracto "= DRENAX ; Drive enable por Sercos READY" ;
    ex:valor "0 o 1" .

ex:TG3_2_500 a ex:Parametro ;
    rdfs:label "TG3 2 500" ;
    ex:textoExtracto "= TG3 2 500 ; Retardo para DRENAX" ;
    ex:valor "Tiempo de retardo" .

ex:B1R2 a ex:Parametro ;
    rdfs:label "B1R2" ;
    ex:textoExtracto "= NOT B1R2 ; FEEDHOLD por no potencia en el regulador X" ;
    ex:valor "0 o 1" .

ex:PARKEDX a ex:Parametro ;
    rdfs:label "PARKEDX" ;
    ex:textoExtracto "= NOT PARKEDX ; Eje X aparcado" ;
    ex:valor "0 o 1" .

ex:UNPARKX a ex:Parametro ;
    rdfs:label "UNPARKX" ;
    ex:textoExtracto "= NOT UNPARKX ; Desaparcar eje X" ;
    ex:valor "0 o 1" .

ex:PARKX a ex:Parametro ;
    rdfs:label "PARKX" ;
    ex:textoExtracto "= NOT PARKX ; Aparcar eje X" ;
    ex:valor "0 o 1" .