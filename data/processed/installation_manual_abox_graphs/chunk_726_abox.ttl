@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Senal_CNCREADY
    a ex:Parametro ;
    rdfs:label "CNCREADY" ;
    ex:textoExtracto "Esta marca indica el estado del CNC. Tiene el valor (=0) cuando el CNC se encuentra en estado de error (ventana de status en rojo) y el valor (=1) el resto de los casos." ;
    ex:valor "0,1" ;
    ex:monitoreaParametro ex:SistemaCNC .

ex:Senal_READYC1
    a ex:Parametro ;
    rdfs:label "READYC1" ;
    ex:textoExtracto "Esta marca indica el estado del canal del CNC. Tiene el valor (=0) cuando el CNC se encuentra en estado de error (ventana de status en rojo) y el valor (=1) el resto de los casos." ;
    ex:valor "0,1" ;
    ex:monitoreaParametro ex:CanalCNC_1 .

ex:Senal_READYC2
    a ex:Parametro ;
    rdfs:label "READYC2" ;
    ex:textoExtracto "Esta marca indica el estado del canal del CNC. Tiene el valor (=0) cuando el CNC se encuentra en estado de error (ventana de status en rojo) y el valor (=1) el resto de los casos." ;
    ex:valor "0,1" ;
    ex:monitoreaParametro ex:CanalCNC_2 .

ex:Senal_READYC3
    a ex:Parametro ;
    rdfs:label "READYC3" ;
    ex:textoExtracto "Esta marca indica el estado del canal del CNC. Tiene el valor (=0) cuando el CNC se encuentra en estado de error (ventana de status en rojo) y el valor (=1) el resto de los casos." ;
    ex:valor "0,1" ;
    ex:monitoreaParametro ex:CanalCNC_3 .

ex:Senal_READYC4
    a ex:Parametro ;
    rdfs:label "READYC4" ;
    ex:textoExtracto "Esta marca indica el estado del canal del CNC. Tiene el valor (=0) cuando el CNC se encuentra en estado de error (ventana de status en rojo) y el valor (=1) el resto de los casos." ;
    ex:valor "0,1" ;
    ex:monitoreaParametro ex:CanalCNC_4 .

ex:Senal_SERCOSRDY
    a ex:Parametro ;
    rdfs:label "SERCOSRDY" ;
    ex:textoExtracto "En las configuraciones Sercos, esta marca indica el estado del anillo. El CNC pone esta marca a (=1) para indicar que el anillo Sercos se encuentra inicializado correctamente." ;
    ex:valor "0,1" ;
    ex:monitoreaParametro ex:AnilloSercos .

ex:Senal_STARTC1
    a ex:Parametro ;
    rdfs:label "STARTC1" ;
    ex:textoExtracto "El canal del CNC activa esta marca para indicar al PLC que se ha pulsado la tecla [START] del panel de mando." ;
    ex:valor "0,1" ;
    ex:monitoreaParametro ex:InterfazPanelMando .

ex:Senal_START
    a ex:Parametro ;
    rdfs:label "START" ;
    ex:textoExtracto "Hay una marca para cada canal. STARTC1 (también se puede programar como START)." ;
    ex:valor "0,1" ;
    ex:monitoreaParametro ex:InterfazPanelMando .

ex:SistemaCNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC" ;
    ex:textoExtracto "CNCREADY: Esta marca indica el estado del CNC." ;
    ex:tieneComponente ex:CanalCNC_1, ex:CanalCNC_2, ex:CanalCNC_3, ex:CanalCNC_4, ex:AnilloSercos .

ex:CanalCNC_1
    a ex:Componente ;
    rdfs:label "Canal 1 del CNC" ;
    ex:textoExtracto "READYC1: Esta marca indica el estado del canal del CNC." ;
    ex:tieneComponente ex:InterfazPanelMando .

ex:CanalCNC_2
    a ex:Componente ;
    rdfs:label "Canal 2 del CNC" ;
    ex:textoExtracto "READYC2: Esta marca indica el estado del canal del CNC." .

ex:CanalCNC_3
    a ex:Componente ;
    rdfs:label "Canal 3 del CNC" ;
    ex:textoExtracto "READYC3: Esta marca indica el estado del canal del CNC." .

ex:CanalCNC_4
    a ex:Componente ;
    rdfs:label "Canal 4 del CNC" ;
    ex:textoExtracto "READYC4: Esta marca indica el estado del canal del CNC." .

ex:AnilloSercos
    a ex:ComponenteElectrico ;
    rdfs:label "Anillo Sercos" ;
    ex:textoExtracto "SERCOSRDY: En las configuraciones Sercos, esta marca indica el estado del anillo." .

ex:InterfazPanelMando
    a ex:InterfazUsuario ;
    rdfs:label "Panel de mando CNC" ;
    ex:textoExtracto "STARTC1: El canal del CNC activa esta marca para indicar al PLC que se ha pulsado la tecla [START] del panel de mando." .