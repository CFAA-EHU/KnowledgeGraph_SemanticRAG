@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_b6c488300d a ns1:Sistema ;
    rdfs:label "CNC 8070"@es ;
    ns1:monitoreaParametro ns1:EntradaI2 ;
    ns1:textoExtracto "Las instrucciones de acción, en función del resultado obtenido en la expresión lógica permiten alterar el estado de los recursos del PLC y de las marcas de comunicación CNC-PLC." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC"@es ;
    ns1:monitoreaParametro ns1:ContadorC1ConElValor100,
        ns1:EntradaDeArranqueTG1DelTemporizadorT2,
        ns1:EntradaI2,
        ns1:Parametro_e34c1f1cc4,
        ns1:SalidaO3 ;
    ns1:textoExtracto "Las instrucciones de acción, en función del resultado obtenido en la expresión lógica permiten alterar el estado de los recursos del PLC y de las marcas de comunicación CNC-PLC." .

ns1:ContadorC1ConElValor100 a ns1:Parametro ;
    rdfs:label "Contador C1 con el valor 100" ;
    ns1:textoExtracto "Un flanco de subida en la entrada I2 preseleccionará el contador C1 con el valor 100." .

ns1:EntradaDeArranqueTG1DelTemporizadorT2 a ns1:Parametro ;
    rdfs:label "Entrada de arranque TG1 del temporizador T2" ;
    ns1:textoExtracto "Un flanco de bajada en la entrada I2 activará la entrada de arranque TG1 del temporizador T2." .

ns1:Parametro_e34c1f1cc4 a ns1:Parametro ;
    rdfs:label "Marca M100" ;
    ns1:textoExtracto "La marca M100 mostrará el estado negado de la entrada I2." .

ns1:SalidaO3 a ns1:Parametro ;
    rdfs:label "Salida O3" ;
    ns1:textoExtracto "La salida O3 mostrará el estado de la entrada I2." .

ns1:EntradaI2 a ns1:Parametro ;
    rdfs:label "Entrada I2" ;
    ns1:textoExtracto "La salida O3 mostrará el estado de la entrada I2." .

