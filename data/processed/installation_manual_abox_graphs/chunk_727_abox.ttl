@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Marca_CYSTART
    a ex:ComponenteElectrico ;
    rdfs:label "Marca CYSTART" ;
    ex:textoExtracto "el PLC debe activar la marca CYSTART para que comience la ejecución del programa" ;
    ex:identificador "CYSTART" .

ex:Marca_RESETOUTC1
    a ex:ComponenteElectrico ;
    rdfs:label "Marca RESETOUTC1" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. RESETOUTC1 (también se puede programar como RESETOUT)" ;
    ex:identificador "RESETOUTC1" .

ex:Pagina_437
    a ex:Pagina ;
    rdfs:label "Página 437 (detalle de CYSTART)" ;
    ex:textoExtracto "Ver en la página 437" ;
    ex:identificador "437" .

ex:Marca_CYSTART
    ex:documentadoEn ex:Pagina_437 .