@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EntradaDeArranqueTG1DelTemporizadorT4 a ns1:Parametro ;
    rdfs:label "Entrada de arranque TG1 del temporizador T4" ;
    ns1:identificador "TG1" ;
    ns1:textoExtracto "Asigna a la entrada de arranque TG1 del temporizador T4 el estado de la entrada I3, por lo que un flanco de subida en I3 activará la entrada de arranque TG1 del temporizador T4." .

ns1:EstadoDeLaEntradaI2 a ns1:Parametro ;
    rdfs:label "Estado de la entrada I2" ;
    ns1:identificador "I2" ;
    ns1:textoExtracto "( I2 OR I3) AND (I4 OR (NOT I5 AND I6)) = M111 Asigna a la marca M111 el valor obtenido en la evaluación de la Expresión lógica (I2 OR I3) AND (I4 OR (NOT I5 AND I6))." .

ns1:EstadoDeLaEntradaI3 a ns1:Parametro ;
    rdfs:label "Estado de la entrada I3",
        "Estado de la entrada I3 para expresión lógica" ;
    ns1:identificador "I3" ;
    ns1:textoExtracto "( I2 OR I3) AND (I4 OR (NOT I5 AND I6)) = M111 Asigna a la marca M111 el valor obtenido en la evaluación de la Expresión lógica (I2 OR I3) AND (I4 OR (NOT I5 AND I6)).",
        "Asigna a la entrada de arranque TG1 del temporizador T4 el estado de la entrada I3, por lo que un flanco de subida en I3 activará la entrada de arranque TG1 del temporizador T4." .

ns1:EstadoDeLaEntradaI4 a ns1:Parametro ;
    rdfs:label "Estado de la entrada I4" ;
    ns1:identificador "I4" ;
    ns1:textoExtracto "( I2 OR I3) AND (I4 OR (NOT I5 AND I6)) = M111 Asigna a la marca M111 el valor obtenido en la evaluación de la Expresión lógica (I2 OR I3) AND (I4 OR (NOT I5 AND I6))." .

ns1:EstadoDeLaEntradaI5 a ns1:Parametro ;
    rdfs:label "Estado de la entrada I5" ;
    ns1:identificador "I5" ;
    ns1:textoExtracto "( I2 OR I3) AND (I4 OR (NOT I5 AND I6)) = M111 Asigna a la marca M111 el valor obtenido en la evaluación de la Expresión lógica (I2 OR I3) AND (I4 OR (NOT I5 AND I6))." .

ns1:EstadoDeLaEntradaI6 a ns1:Parametro ;
    rdfs:label "Estado de la entrada I6" ;
    ns1:identificador "I6" ;
    ns1:textoExtracto "( I2 OR I3) AND (I4 OR (NOT I5 AND I6)) = M111 Asigna a la marca M111 el valor obtenido en la evaluación de la Expresión lógica (I2 OR I3) AND (I4 OR (NOT I5 AND I6))." .

ns1:Parametro_4ca3d1ceae a ns1:Parametro ;
    rdfs:label "Marca M111" ;
    ns1:identificador "M111" ;
    ns1:textoExtracto "Asigna a la marca M111 el valor obtenido en la evaluación de la Expresión lógica (I2 OR I3) AND (I4 OR (NOT I5 AND I6))." .

