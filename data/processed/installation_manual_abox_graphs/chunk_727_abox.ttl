@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MarcaCYSTART a ex:Parametro ;
    rdfs:label "CYSTART" ;
    ex:textoExtracto "el PLC debe activar la marca CYSTART para que comience la ejecución del programa" ;
    ex:textoExtracto "Hay una marca para cada canal" .

ex:MarcaRESETOUTC1 a ex:Parametro ;
    rdfs:label "RESETOUTC1" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. RESETOUTC1 (también se puede programar como RESETOUT)" .

ex:MarcaRESETOUT a ex:Parametro ;
    rdfs:label "RESETOUT" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. RESETOUTC1 (también se puede programar como RESETOUT)" .