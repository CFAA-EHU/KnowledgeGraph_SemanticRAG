@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Marca_CYSTART
    a ex:Componente ;
    rdfs:label "Marca CYSTART" ;
    ex:textoExtracto "CYSTART\" START AND (resto de condiciones) = CYSTART RESETOUT. El canal activa la marca RESETOUT (RESETOUT=1) para indicar que ha finalizado el reset." ;
    ex:identificador "CYSTART" .

ex:Marca_RESETOUT
    a ex:Componente ;
    rdfs:label "Marca RESETOUT (canal genérico)" ;
    ex:textoExtracto "El canal activa la marca RESETOUT (RESETOUT=1) para indicar que ha finalizado el reset. Esta marca permanece activa el tiempo fijado en el parámetro general MINAENDW." ;
    ex:identificador "RESETOUT" .

ex:Marca_RESETOUTC1
    a ex:Componente ;
    rdfs:label "Marca RESETOUT Canal 1" ;
    ex:textoExtracto "RESETOUTC1 (también se puede programar como RESETOUT)" ;
    ex:identificador "RESETOUTC1" .

ex:Marca_RESETOUTC2
    a ex:Componente ;
    rdfs:label "Marca RESETOUT Canal 2" ;
    ex:textoExtracto "RESETOUTC2" ;
    ex:identificador "RESETOUTC2" .

ex:Marca_RESETOUTC3
    a ex:Componente ;
    rdfs:label "Marca RESETOUT Canal 3" ;
    ex:textoExtracto "RESETOUTC3" ;
    ex:identificador "RESETOUTC3" .

ex:Marca_RESETOUTC4
    a ex:Componente ;
    rdfs:label "Marca RESETOUT Canal 4" ;
    ex:textoExtracto "RESETOUTC4" ;
    ex:identificador "RESETOUTC4" .

ex:Parametro_MINAENDW
    a ex:Parametro ;
    rdfs:label "Parámetro MINAENDW" ;
    ex:textoExtracto "Esta marca [RESETOUT] permanece activa el tiempo fijado en el parámetro general MINAENDW." ;
    ex:identificador "MINAENDW" .

ex:Marca_FHOUT
    a ex:Componente ;
    rdfs:label "Marca FHOUT (canal genérico)" ;
    ex:textoExtracto "FHOUT. El canal del CNC pone esta marca a (=1) cuando está detenida la ejecución del programa pieza." ;
    ex:identificador "FHOUT" .

ex:Marca_FHOUTC1
    a ex:Componente ;
    rdfs:label "Marca FHOUT Canal 1" ;
    ex:textoExtracto "FHOUTC1 (también se puede programar como FHOUT)" ;
    ex:identificador "FHOUTC1" .

ex:Marca_FHOUTC2
    a ex:Componente ;
    rdfs:label "Marca FHOUT Canal 2" ;
    ex:textoExtracto "FHOUTC2" ;
    ex:identificador "FHOUTC2" .

ex:Marca_FHOUTC3
    a ex:Componente ;
    rdfs:label "Marca FHOUT Canal 3" ;
    ex:textoExtracto "FHOUTC3" ;
    ex:identificador "FHOUTC3" .

ex:Marca_FHOUTC4
    a ex:Componente ;
    rdfs:label "Marca FHOUT Canal 4" ;
    ex:textoExtracto "FHOUTC4" ;
    ex:identificador "FHOUTC4" .

ex:Marca_STOP
    a ex:Componente ;
    rdfs:label "Marca _STOP" ;
    ex:textoExtracto "Si el PLC ha puesto la marca \"_STOP\" a (=0), para reanudar la ejecución el PLC debe poner las marcas \"_STOP\" y \"CYSTART\" a (=1)." ;
    ex:identificador "_STOP" .

ex:Marca_FEEDHOL
    a ex:Componente ;
    rdfs:label "Marca _FEEDHOL" ;
    ex:textoExtracto "Si el PLC ha puesto la marca \"_FEEDHOL\" a (=0), para reanudar la ejecución el PLC debe poner la marca \"_FEEDHOL\" a (=1)." ;
    ex:identificador "_FEEDHOL" .

ex:Marca_ALARM
    a ex:Componente ;
    rdfs:label "Marca _ALARM (canal genérico)" ;
    ex:textoExtracto "_ALARM. El canal del CNC activa esta marca (nivel \"0\") cuando hay una alarma, una emergencia generada por el canal del CNC o cuando el PLC activa señal de emergencia _EMERGEN." ;
    ex:identificador "_ALARM" .

ex:Marca_ALARMC1
    a ex:Componente ;
    rdfs:label "Marca _ALARM Canal 1" ;
    ex:textoExtracto "_ALARMC1 (también se puede programar como _ALARM)" ;
    ex:identificador "_ALARMC1" .

ex:Marca_ALARMC2
    a ex:Componente ;
    rdfs:label "Marca _ALARM Canal 2" ;
    ex:textoExtracto "_ALARMC2" ;
    ex:identificador "_ALARMC2" .

ex:Marca_ALARMC3
    a ex:Componente ;
    rdfs:label "Marca _ALARM Canal 3" ;
    ex:textoExtracto "_ALARMC3" ;
    ex:identificador "_ALARMC3" .

ex:Marca_ALARMC4
    a ex:Componente ;
    rdfs:label "Marca _ALARM Canal 4" ;
    ex:textoExtracto "_ALARMC4" ;
    ex:identificador "_ALARMC4" .

ex:Marca_EMERGEN
    a ex:Componente ;
    rdfs:label "Marca _EMERGEN" ;
    ex:textoExtracto "cuando el PLC activa señal de emergencia _EMERGEN." ;
    ex:identificador "_EMERGEN" .

ex:Sistema_Se_alesConsulta
    a ex:Sistema ;
    rdfs:label "Sistema de Señales de Consulta Generales (CNC)" ;
    ex:textoExtracto "Sección 6.1 Señales de consulta generales. CYSTART, RESETOUT, FHOUT, _ALARM y marcas asociadas por canal." ;
    ex:tieneComponente
        ex:Marca_CYSTART, ex:Marca_RESETOUT, ex:Marca_RESETOUTC1, ex:Marca_RESETOUTC2,
        ex:Marca_RESETOUTC3, ex:Marca_RESETOUTC4, ex:Marca_FHOUT, ex:Marca_FHOUTC1,
        ex:Marca_FHOUTC2, ex:Marca_FHOUTC3, ex:Marca_FHOUTC4, ex:Marca_STOP,
        ex:Marca_FEEDHOL, ex:Marca_ALARM, ex:Marca_ALARMC1, ex:Marca_ALARMC2,
        ex:Marca_ALARMC3, ex:Marca_ALARMC4, ex:Marca_EMERGEN ;
    ex:monitoreaParametro ex:Parametro_MINAENDW .