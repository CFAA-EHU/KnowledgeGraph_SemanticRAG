@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:RESETOUTC1 a ex:Sensor ;
    rdfs:label "RESETOUTC1" ;
    ex:textoExtracto "RESETOUTC1 (también se puede programar como RESETOUT)" .

ex:RESETOUTC2 a ex:Sensor ;
    rdfs:label "RESETOUTC2" ;
    ex:textoExtracto "RESETOUTC2" .

ex:RESETOUTC3 a ex:Sensor ;
    rdfs:label "RESETOUTC3" ;
    ex:textoExtracto "RESETOUTC3" .

ex:RESETOUTC4 a ex:Sensor ;
    rdfs:label "RESETOUTC4" ;
    ex:textoExtracto "RESETOUTC4" .

ex:RESETOUT a ex:Sensor ;
    rdfs:label "RESETOUT" ;
    ex:textoExtracto "marca RESETOUT (RESETOUT=1)" .

ex:FHOUTC1 a ex:Sensor ;
    rdfs:label "FHOUTC1" ;
    ex:textoExtracto "FHOUTC1 (también se puede programar como FHOUT)" .

ex:FHOUTC2 a ex:Sensor ;
    rdfs:label "FHOUTC2" ;
    ex:textoExtracto "FHOUTC2" .

ex:FHOUTC3 a ex:Sensor ;
    rdfs:label "FHOUTC3" ;
    ex:textoExtracto "FHOUTC3" .

ex:FHOUTC4 a ex:Sensor ;
    rdfs:label "FHOUTC4" ;
    ex:textoExtracto "FHOUTC4" .

ex:FHOUT a ex:Sensor ;
    rdfs:label "FHOUT" ;
    ex:textoExtracto "marca FHOUT" .

ex:_ALARMC1 a ex:Sensor ;
    rdfs:label "_ALARMC1" ;
    ex:textoExtracto "_ALARMC1 (también se puede programar como _ALARM)" .

ex:_ALARMC2 a ex:Sensor ;
    rdfs:label "_ALARMC2" ;
    ex:textoExtracto "_ALARMC2" .

ex:_ALARMC3 a ex:Sensor ;
    rdfs:label "_ALARMC3" ;
    ex:textoExtracto "_ALARMC3" .

ex:_ALARMC4 a ex:Sensor ;
    rdfs:label "_ALARMC4" ;
    ex:textoExtracto "_ALARMC4" .

ex:_ALARM a ex:Sensor ;
    rdfs:label "_ALARM" ;
    ex:textoExtracto "marca _ALARM" .

ex:_STOP a ex:Sensor ;
    rdfs:label "_STOP" ;
    ex:textoExtracto "marca \"_STOP\"" .

ex:_FEEDHOL a ex:Sensor ;
    rdfs:label "_FEEDHOL" ;
    ex:textoExtracto "marca \"_FEEDHOL\"" .

ex:_EMERG a ex:Sensor ;
    rdfs:label "_EMERG" ;
    ex:textoExtracto "señal de emergencia _EMERG" .

ex:MINAENDW a ex:Parametro ;
    rdfs:label "MINAENDW" ;
    ex:textoExtracto "tiempo fijado en el parámetro general MINAENDW" .