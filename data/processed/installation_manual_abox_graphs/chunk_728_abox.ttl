    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Marca CNC-PLC" .

ns1:InstruccionCPL a ns1:Parametro ;
    rdfs:label "Instrucción CPL" ;
    ns1:identificador "CPL" ;
    ns1:textoExtracto "= CPL M 1/8192 MSG 1/1024 ERR 1/1024 B 0/31 R 1/1024 Marca CNC-PLC" .

ns1:InstruccionRES a ns1:Parametro ;
    rdfs:label "Instrucción RES" ;
    ns1:identificador "RES" ;
    ns1:textoExtracto "= RES O 1/1024" .

ns1:InstruccionSET a ns1:Parametro ;
