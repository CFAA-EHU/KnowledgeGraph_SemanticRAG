@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:RelayEmergencia_729_1 a ex:Actuador ;
    rdfs:label "relé de emergencia"@es ;
    ex:textoExtracto "abre el relé de emergencia"@es .

ex:SenalALARM_729_1 a ex:Sensor ;
    rdfs:label "señal _ALARM"@es ;
    ex:textoExtracto "activa la señal _ALARM (nivel \"0\")"@es .

ex:CanalCNC_729_1 a ex:Sistema ;
    rdfs:label "canal del CNC"@es ;
    ex:textoExtracto "El canal del CNC desactiva esta marca (nivel \"1\") cuando se ha eliminado el mensaje del canal del CNC y ha desaparecido la causa de la alarma o emergencia."@es .

ex:MovimientoAutomatico_729_1 a ex:ModoOperacion ;
    rdfs:label "movimientos en automático"@es ;
    ex:textoExtracto "Para movimientos en automático, si el CNC detecta una colisión en un movimiento de posicionamiento o retirada dentro de un ciclo de palpador (o incluso fuera de éste), detiene el movimiento, muestra el error correspondiente, abre el relé de emergencia y activa la señal _ALARM (nivel \"0\")."@es .

ex:CNC_729_1 a ex:Sistema ;
    rdfs:label "CNC"@es ;
    ex:textoExtracto "si el CNC detecta una colisión en un movimiento de posicionamiento o retirada dentro de un ciclo de palpador (o incluso fuera de éste)"@es .