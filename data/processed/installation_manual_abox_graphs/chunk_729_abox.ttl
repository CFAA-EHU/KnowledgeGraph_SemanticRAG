@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CALLlamadaASubrutina a ns1:AccionProhibida ;
    rdfs:label "CAL Llamada a subrutina" ;
    ns1:textoExtracto "CAL Llamada a subrutina. Si el resultado obtenido en la evaluación de la expresión lógica es un \"1\" esta acción ejecuta la subrutina indicada." .

ns1:JMPSaltoIncondicional a ns1:AccionProhibida ;
    rdfs:label "JMP Salto incondicional" ;
    ns1:textoExtracto "Estas acciones interrumpen la secuencia de un programa, haciendo que continúe su ejecución en otra parte del programa. = JMP Salto incondicional." .

ns1:RETRetornoOFinalDeSubrutina a ns1:AccionProhibida ;
    rdfs:label "RET Retorno o final de subrutina" ;
    ns1:textoExtracto "= RET Retorno o final de subrutina." .

