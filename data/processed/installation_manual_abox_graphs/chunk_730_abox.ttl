@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EjecucionDeSubrutina a ns1:TareaMantenimiento ;
    rdfs:label "Ejecución de subrutina" ;
    ns1:textoExtracto "Si el resultado obtenido en la evaluación de la expresión lógica es un \"1\" esta acción será tratada por el PLC como la proposición directiva END." .

ns1:FinalizacionDeSubrutina a ns1:AccionProhibida ;
    rdfs:label "Finalización de subrutina" ;
    ns1:textoExtracto "Si durante la ejecución de una subrutina el PLC detecta un RET validado dará por finalizada la subrutina." .

ns1:IgnorarRET a ns1:AccionProhibida ;
    rdfs:label "Ignorar RET" ;
    ns1:textoExtracto "Si el resultado es \"0\", será ignorada por el PLC." .

ns1:NoEjecucionDeSubrutina a ns1:AccionProhibida ;
    rdfs:label "No ejecución de subrutina" ;
    ns1:textoExtracto "Con I2=0 no se ejecuta la subrutina y el PLC asigna a la salida O2 el valor de la entrada I2 (0)." .

