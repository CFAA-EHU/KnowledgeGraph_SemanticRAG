@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BitsATransmitir_e5bfebce55 a ns1:Parametro ;
    rdfs:label "Bits a transmitir" ;
    ns1:identificador "Bits a transmitir" ;
    ns1:textoExtracto "El formato de programación es: Origen Destino Código origen Código destino Bits a transmitir" .

ns1:CodigoDestino a ns1:Parametro ;
    rdfs:label "Código destino" ;
    ns1:identificador "Destino" ;
    ns1:textoExtracto "El formato de programación es: Origen Destino Código origen Código destino Bits a transmitir" .

ns1:CodigoOrigen a ns1:Parametro ;
    rdfs:label "Código origen" ;
    ns1:identificador "Origen" ;
    ns1:textoExtracto "El formato de programación es: Origen Destino Código origen Código destino Bits a transmitir" .

ns1:MOVMover a ns1:AccionProhibida ;
    rdfs:label "MOV Mover" ;
    ns1:documentadoEn ns1:TablaInstruccionesMOV ;
    ns1:textoExtracto "MOV Mover. Permite mover información de un recurso a otro del PLC." .

ns1:TablaInstruccionesMOV a ns1:Tabla ;
    rdfs:label "Tabla de instrucciones MOV" ;
    ns1:textoExtracto "Origen Destino Código origen Código destino Bits a transmitir 0(Bin) 0(Bin) 32 I1/1024 =MOV I1/1024" .

