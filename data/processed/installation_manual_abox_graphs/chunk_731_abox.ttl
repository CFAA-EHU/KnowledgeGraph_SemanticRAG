@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ModoAutomatico a ex:ModoOperacion ;
    ex:textoExtracto "Si estando en modo automático se selecciona –bloque a bloque– se activan las marcas AUTOMAT y SBOUT." ;
    ex:identificador "AUTOMAT" .

ex:ModoManual a ex:ModoOperacion ;
    ex:textoExtracto "Si estando en modo manual se selecciona –bloque a bloque– se activan las marcas MANUAL y SBOUT." ;
    ex:identificador "MANUAL" .

ex:SBOUT a ex:Sensor ;
    ex:textoExtracto "se activan las marcas AUTOMAT y SBOUT" ;
    ex:identificador "SBOUT" .

ex:INCYCLE a ex:Sensor ;
    ex:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. INCYCLE Hay una marca para cada canal." ;
    ex:identificador "INCYCLE" .

ex:INCYCLEC1 a ex:Sensor ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. INCYCLEC1 (también se puede programar como INCYCLE) INCYCLEC2 INCYCLEC3 INCYCLEC4" ;
    ex:identificador "INCYCLEC1" .

ex:INCYCLEC2 a ex:Sensor ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. INCYCLEC1 (también se puede programar como INCYCLE) INCYCLEC2 INCYCLEC3 INCYCLEC4" ;
    ex:identificador "INCYCLEC2" .

ex:INCYCLEC3 a ex:Sensor ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. INCYCLEC1 (también se puede programar como INCYCLE) INCYCLEC2 INCYCLEC3 INCYCLEC4" ;
    ex:textoExtracto "El canal del CNC pone esta marca a" ;
    ex:identificador "INCYCLEC3" .

ex:INCYCLEC4 a ex:Sensor ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. INCYCLEC1 (también se puede programar como INCYCLE) INCYCLEC2 INCYCLEC3 INCYCLEC4" ;
    ex:identificador "INCYCLEC4" .