@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:INCYCLEC1
    a ex:Parametro ;
    rdfs:label "INCYCLEC1" ;
    ex:textoExtracto "INCYCLEC1 (también se puede programar como INCYCLE) [...] El canal del CNC pone esta marca a (=1) cuando está ejecutando un bloque o desplazando algún eje." ;
    ex:identificador "INCYCLEC1" .

