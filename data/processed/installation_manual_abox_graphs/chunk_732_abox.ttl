ex:InterfazSe_alesConsulta
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de señales de consulta generales del CNC" ;
    ex:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. INCYCLEC1 [...] RAPIDC1 [...] ZEROC1 [...] PROBEC1 [...] THREADC1 [...]" ;
    ex:tieneComponente ex:INCYCLEC1, ex:INCYCLEC2, ex:INCYCLEC3, ex:INCYCLEC4,
                      ex:RAPIDC1, ex:RAPIDC2, ex:RAPIDC3, ex:RAPIDC4,
                      ex:ZEROC1, ex:ZEROC2, ex:ZEROC3, ex:ZEROC4,
                      ex:PROBEC1, ex:PROBEC2, ex:PROBEC3, ex:PROBEC4,
                      ex:THREADC1, ex:THREADC2, ex:THREADC3, ex:THREADC4 .