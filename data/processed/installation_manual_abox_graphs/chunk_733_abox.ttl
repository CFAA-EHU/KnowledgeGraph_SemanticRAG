@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioDeSignoDelRegistroR89 a ns1:Parametro ;
    rdfs:label "Cambio de signo del registro R89" ;
    ns1:identificador "NGS R89" ;
    ns1:textoExtracto "I16 = NGS R89 Si la entrada I16 vale \"1\" el PLC cambia de signo el contenido del registro R89." .

ns1:ComplementaLosBitsDeUnRegistroR152 a ns1:Parametro ;
    rdfs:label "Complementa los bits de un registro R152" ;
    ns1:identificador "NGU R152" ;
    ns1:textoExtracto "I15 = NGU R152 Si la entrada I15 vale \"1\" el PLC complementa los 32 bits del registro R152." .

ns1:EstadoAnteriorDelRegistroR152 a ns1:Parametro ;
    rdfs:label "Estado anterior del registro R152" ;
    ns1:identificador "R152 antes" ;
    ns1:textoExtracto "R152 antes: 0001 0001 0001 0001 0001 0001 0001 0001" ;
    ns1:valor "0001 0001 0001 0001 0001 0001 0001 0001" .

ns1:EstadoAnteriorDelRegistroR89 a ns1:Parametro ;
    rdfs:label "Estado anterior del registro R89" ;
    ns1:identificador "R89 antes" ;
    ns1:textoExtracto "R89 antes: 0001 0001 0001 0001 0001 0001 0001 0001" ;
    ns1:valor "0001 0001 0001 0001 0001 0001 0001 0001" .

ns1:EstadoPosteriorDelRegistroR152 a ns1:Parametro ;
    rdfs:label "Estado posterior del registro R152" ;
    ns1:identificador "R152 después" ;
    ns1:textoExtracto "R152 después: 1110 1110 1110 1110 1110 1110 1110 1110" ;
    ns1:valor "1110 1110 1110 1110 1110 1110 1110 1110" .

ns1:EstadoPosteriorDelRegistroR89 a ns1:Parametro ;
    rdfs:label "Estado posterior del registro R89" ;
    ns1:identificador "R89 después" ;
    ns1:textoExtracto "R89 después: 1110 1110 1110 1110 1110 1110 1110 1111" ;
    ns1:valor "1110 1110 1110 1110 1110 1110 1110 1111" .

