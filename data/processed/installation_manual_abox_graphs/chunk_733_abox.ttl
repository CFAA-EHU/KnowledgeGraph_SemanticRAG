@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:THREADC1 a ex:Parametro ;
    ex:textoExtracto "THREADC1 (también se puede programar como THREAD)" ;
    rdfs:label "THREADC1" .

ex:THREADC2 a ex:Parametro ;
    ex:textoExtracto "THREADC2" ;
    rdfs:label "THREADC2" .

ex:THREADC3 a ex:Parametro ;
    ex:textoExtracto "THREADC3" ;
    rdfs:label "THREADC3" .

ex:THREADC4 a ex:Parametro ;
    ex:textoExtracto "THREADC4" ;
    rdfs:label "THREADC4" .

ex:TAPPINGC1 a ex:Parametro ;
    ex:textoExtracto "TAPPINGC1 (también se puede programar como TAPPING)" ;
    rdfs:label "TAPPINGC1" .

ex:TAPPINGC2 a ex:Parametro ;
    ex:textoExtracto "TAPPINGC2" ;
    rdfs:label "TAPPINGC2" .

ex:TAPPINGC3 a ex:Parametro ;
    ex:textoExtracto "TAPPINGC3" ;
    rdfs:label "TAPPINGC3" .

ex:TAPPINGC4 a ex:Parametro ;
    ex:textoExtracto "TAPPINGC4" ;
    rdfs:label "TAPPINGC4" .