@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Marca_INPOSI a ex:Parametro ;
    rdfs:label "INPOSI" ;
    ex:textoExtracto "La marca INTEREND puede utilizarse para activar mecanismos antes de llegar los ejes a posición. También puede utilizarse la marca ADVINPOS. [...] El canal del CNC pone la marca INPOSI a (=1) para indicar que todos sus ejes y cabezales activos han llegado a posición, exceptuando los ejes independientes programados desde el PLC." ;
    ex:valor "1" .

ex:Marca_ADVINPOS a ex:Parametro ;
    rdfs:label "ADVINPOS" ;
    ex:textoExtracto "También puede utilizarse la marca ADVINPOS." .

ex:Marca_INTEREND a ex:Parametro ;
    rdfs:label "INTEREND" ;
    ex:textoExtracto "La marca INTEREND puede utilizarse para activar mecanismos antes de llegar los ejes a posición." .

ex:Parametro_INPOSIC1 a ex:Parametro ;
    rdfs:label "INPOSIC1" ;
    ex:textoExtracto "INPOSIC1 (también se puede programar como INPOSI o INPOS)" .

ex:Parametro_INPOSIC2 a ex:Parametro ;
    rdfs:label "INPOSIC2" ;
    ex:textoExtracto "INPOSIC2" .

ex:Parametro_INPOSIC3 a ex:Parametro ;
    rdfs:label "INPOSIC3" ;
    ex:textoExtracto "INPOSIC3" .

ex:Parametro_INPOSIC4 a ex:Parametro ;
    rdfs:label "INPOSIC4" ;
    ex:textoExtracto "INPOSIC4" .

ex:CanalCNC a ex:InterfazUsuario ;
    ex:textoExtracto "El canal del CNC pone la marca INPOSI a (=1) para indicar que todos sus ejes y cabezales activos han llegado a posición, exceptuando los ejes independientes programados desde el PLC." ;
    ex:monitoreaParametro ex:Marca_INPOSI ;
    ex:monitoreaParametro ex:Parametro_INPOSIC1 ;
    ex:monitoreaParametro ex:Parametro_INPOSIC2 ;
    ex:monitoreaParametro ex:Parametro_INPOSIC3 ;
    ex:monitoreaParametro ex:Parametro_INPOSIC4 .