@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:INTEREND a ex:ComponenteElectrico ;
    rdfs:label "INTEREND" ;
    ex:textoExtracto "La marca INTEREND puede utilizarse para activar mecanismos antes de llegar los ejes a posición." .

ex:ADVINPOS a ex:ComponenteElectrico ;
    rdfs:label "ADVINPOS" ;
    ex:textoExtracto "También puede utilizarse la marca ADVINPOS. Ver en la página 414." .

ex:INPOSI a ex:ComponenteElectrico ;
    rdfs:label "INPOSI" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. INPOSIC1 (también se puede programar como INPOSI o INPOS) INPOSIC2 INPOSIC3 INPOSIC4" .

ex:INPOSIC1 a ex:ComponenteElectrico ;
    rdfs:label "INPOSIC1" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. INPOSIC1 (también se puede programar como INPOSI o INPOS) INPOSIC2 INPOSIC3 INPOSIC4" .

ex:INPOSIC2 a ex:ComponenteElectrico ;
    rdfs:label "INPOSIC2" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. INPOSIC1 (también se puede programar como INPOSI o INPOS) INPOSIC2 INPOSIC3 INPOSIC4" .

ex:INPOSIC3 a ex:ComponenteElectrico ;
    rdfs:label "INPOSIC3" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. INPOSIC1 (también se puede programar como INPOSI o INPOS) INPOSIC2 INPOSIC3 INPOSIC4" .

ex:INPOSIC4 a ex:ComponenteElectrico ;
    rdfs:label "INPOSIC4" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. INPOSIC1 (también se puede programar como INPOSI o INPOS) INPOSIC2 INPOSIC3 INPOSIC4" .

ex:Pagina414 a ex:Pagina ;
    ex:textoExtracto "Ver en la página 414." .