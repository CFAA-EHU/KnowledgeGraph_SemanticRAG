@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:OperacionLogicaAND a ns1:Parametro ;
    rdfs:label "Operación lógica AND" ;
    ns1:textoExtracto "= AND = OR = XOR Operaciones lógicas. Permiten realizar las operaciones lógicas AND, OR y XOR entre contenido de registros o entre contenidos de registro y número." .

ns1:OperacionLogicaOR a ns1:Parametro ;
    rdfs:label "Operación lógica OR" ;
    ns1:textoExtracto "= AND = OR = XOR Operaciones lógicas. Permiten realizar las operaciones lógicas AND, OR y XOR entre contenido de registros o entre contenidos de registro y número." .

ns1:OperacionLogicaXOR a ns1:Parametro ;
    rdfs:label "Operación lógica XOR" ;
    ns1:textoExtracto "= AND = OR = XOR Operaciones lógicas. Permiten realizar las operaciones lógicas AND, OR y XOR entre contenido de registros o entre contenidos de registro y número." .

ns1:RotacionDerechaTipo1 a ns1:Parametro ;
    rdfs:label "Rotación derecha tipo 1" ;
    ns1:textoExtracto "Tipo de rotación 1 (RL1 o RR1): Introduce un 0 en el bit menos significativo (RL1) o en el más significativo (RR1), desplazando los restantes bits del registro." .

ns1:RotacionDerechaTipo2 a ns1:Parametro ;
    rdfs:label "Rotación derecha tipo 2" ;
    ns1:textoExtracto "Tipo de rotación 2 (RL2 o RR2): Rotación circular del registro en el sentido indicado." .

ns1:RotacionIzquierdaTipo1 a ns1:Parametro ;
    rdfs:label "Rotación izquierda tipo 1" ;
    ns1:textoExtracto "Tipo de rotación 1 (RL1 o RR1): Introduce un 0 en el bit menos significativo (RL1) o en el más significativo (RR1), desplazando los restantes bits del registro." .

ns1:RotacionIzquierdaTipo2 a ns1:Parametro ;
    rdfs:label "Rotación izquierda tipo 2" ;
    ns1:textoExtracto "Tipo de rotación 2 (RL2 o RR2): Rotación circular del registro en el sentido indicado." .

