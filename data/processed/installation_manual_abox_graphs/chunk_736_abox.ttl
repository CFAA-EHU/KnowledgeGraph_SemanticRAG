@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:INPOSI a ex:Sensor ;
    rdfs:label "INPOSI" ;
    ex:textoExtracto "El canal del CNC pone la marca INPOSI a (=1) para indicar que todos sus ejes y cabezales activos han llegado a posición" ;
    ex:valor "1" .

ex:INPOSW a ex:Parametro ;
    rdfs:label "INPOSW" ;
    ex:textoExtracto "Un eje está en posición cuando permanece dentro de la banda de muerte (parámetro INPOSW)" .

ex:INPOTIME a ex:Parametro ;
    rdfs:label "INPOTIME" ;
    ex:textoExtracto "Un eje está en posición cuando permanece dentro de la banda de muerte el tiempo indicado en el parámetro INPOTIME" .

ex:SPN1 a ex:Sensor ;
    rdfs:label "SPN1" ;
    ex:textoExtracto "Hay un registro para cada canal. Los mnemónicos para cada canal son los siguientes. Se muestra como ejemplo los mnemónicos de SPN1; para el resto de registros es equivalente." .

ex:SPN1C1 a ex:Sensor ;
    rdfs:label "SPN1C1" ;
    ex:textoExtracto "SPN1C1 SPN1C2 SPN1C3 SPN1C4" .

ex:SPN1C2 a ex:Sensor ;
    rdfs:label "SPN1C2" ;
    ex:textoExtracto "SPN1C1 SPN1C2 SPN1C3 SPN1C4" .

ex:SPN1C3 a ex:Sensor ;
    rdfs:label "SPN1C3" ;
    ex:textoExtracto "SPN1C1 SPN1C2 SPN1C3 SPN1C4" .

ex:SPN1C4 a ex:Sensor ;
    rdfs:label "SPN1C4" ;
    ex:textoExtracto "SPN1C1 SPN1C2 SPN1C3 SPN1C4" .

ex:S1 a ex:ComponenteMecanico ;
    rdfs:label "S1" ;
    ex:textoExtracto "Giro a derechas del cabezal S1 a 1000 rpm" .

ex:S2 a ex:ComponenteMecanico ;
    rdfs:label "S2" ;
    ex:textoExtracto "Giro a izquierdas del cabezal S2 a 500 rpm" .