@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_MFUN a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de registros MFUN (Funciones M por canal)"@es ;
    ex:textoExtracto """
| MFUN1C1 | MFUN2C1 | MFUN3C1 - MFUN7C1 |
| --- | --- | --- |
| 3 | 4 | $FFFFFFFF
""" ;
    ex:ilustradoEn ex:Interfaz_CNC .

ex:Tabla_SPN a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de registros SPN (Funciones por cabezal)"@es ;
    ex:textoExtracto """
| SPN1C1 | SPN2C1 | SPN3C1 - SPN7C1 |
| --- | --- | --- |
| 1 | 2 | $FFFFFFFF
""" ;
    ex:ilustradoEn ex:Interfaz_CNC .

ex:Interfaz_CNC
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz CNC para programación de funciones M y análisis de cabezales"@es ;
    ex:textoExtracto """
Si en el bloque se programa una función sin hacer referencia al cabezal, se asume para el cabezal master del canal. Comandos SP1FUN* - SP4FUN*. Analizar si un cabezal recibe una función desde cualquier canal.
""" .

ex:Registro_MFUN1C1
    a ex:Parametro ;
    rdfs:label "Registro MFUN1C1 (Funciones M, Canal 1)"@es ;
    ex:identificador "MFUN1C1" ;
    ex:valor "3" ;
    ex:textoExtracto "MFUN1C1 (también se puede programar como MFUN1)"@es ;
    ex:monitoreaParametro ex:FuncionM_Canal1 ;
    ex:documentadoEn ex:Tabla_MFUN .

ex:Registro_MFUN2C1
    a ex:Parametro ;
    rdfs:label "Registro MFUN2C1 (Funciones M, Canal 1)"@es ;
    ex:identificador "MFUN2C1" ;
    ex:valor "4" ;
    ex:textoExtracto "MFUN2C1" ;
    ex:monitoreaParametro ex:FuncionM_Canal1 ;
    ex:documentadoEn ex:Tabla_MFUN .

ex:Registro_MFUN_Vacio
    a ex:Parametro ;
    rdfs:label "Registro MFUN no utilizado (Valor por defecto)"@es ;
    ex:identificador "MFUN_Libre" ;
    ex:valor "$FFFFFFFF" ;
    ex:textoExtracto """
Si no se utilizan todos los registros, el CNC asigna el valor hexadecimal $FFFFFFFF a los que queden libres, los de numeración más alta.
"""@es ;
    ex:documentadoEn ex:Tabla_MFUN .

ex:Registro_SPN1C1
    a ex:Parametro ;
    rdfs:label "Registro SPN1C1 (Funciones por cabezal, Cabezal 1)"@es ;
    ex:identificador "SPN1C1" ;
    ex:valor "1" ;
    ex:textoExtracto "SPN1C1" ;
    ex:monitoreaParametro ex:Funcion_Cabezal1 ;
    ex:documentadoEn ex:Tabla_SPN .

ex:Registro_SPN2C1
    a ex:Parametro ;
    rdfs:label "Registro SPN2C1 (Funciones por cabezal, Cabezal 1)"@es ;
    ex:identificador "SPN2C1" ;
    ex:valor "2" ;
    ex:textoExtracto "SPN2C1" ;
    ex:monitoreaParametro ex:Funcion_Cabezal1 ;
    ex:documentadoEn ex:Tabla_SPN .

ex:Registro_SPN_Vacio
    a ex:Parametro ;
    rdfs:label "Registro SPN no utilizado (Valor por defecto)"@es ;
    ex:identificador "SPN_Libre" ;
    ex:valor "$FFFFFFFF" ;
    ex:textoExtracto """
Si no se utilizan todos los registros, el CNC asigna el valor hexadecimal $FFFFFFFF a los que queden libres, los de numeración más alta.
"""@es ;
    ex:documentadoEn ex:Tabla_SPN .

ex:Comando_SP1FUN
    a ex:Parametro ;
    rdfs:label "Comando SP1FUN* (Análisis de funciones para Cabezal 1)"@es ;
    ex:identificador "SP1FUN*" ;
    ex:textoExtracto """
SP1FUN* Para el cabezal 1. [...] CPS SP1FUN* EQ 5 = ... Ejemplo para saber si el primer cabezal ha recibido una función M5 desde cualquier canal.
"""@es ;
    ex:monitoreaParametro ex:Funcion_Cabezal1 ;
    ex:documentadoEn ex:Interfaz_CNC .

ex:FuncionM_Canal1 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Funciones M asignadas al Canal 1"@es ;
    ex:textoExtracto """
El canal indica al PLC mediante estos registros las funciones auxiliares M que se han seleccionado para su ejecución. En cada canal puede haber hasta 7 funciones M.
"""@es .

ex:Funcion_Cabezal1 a ex:Tabla ;
     a ex:Parametro ;
    rdfs:label "Funciones asignadas al Cabezal 1"@es ;
    ex:textoExtracto """
Para poder conocer si un determinado cabezal ha recibido una determinada función, se pueden analizar todos los registros uno a uno o se pueden utilizar los siguientes comandos para analizar todos ellos a la vez.
"""@es .