@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EscrituraDeVariablesDelCNC a ns1:AccionProhibida ;
    rdfs:label "Escritura de variables del CNC" ;
    ns1:textoExtracto "CNCRD Lectura (CNCRD) y escritura (CNCWR) de las variables del CNC. Permiten la lectura (CNCRD) y escritura (CNCWR) de las variables internas del CNC, siendo su formato de programación: CNCWR (Registro, Variable, Marca)" .

ns1:LecturaDeVariablesDelCNC a ns1:AccionProhibida ;
    rdfs:label "Lectura de variables del CNC" ;
    ns1:textoExtracto "CNCRD Lectura (CNCRD) y escritura (CNCWR) de las variables del CNC. Permiten la lectura (CNCRD) y escritura (CNCWR) de las variables internas del CNC, siendo su formato de programación: CNCRD (Variable, Registro, Marca)" .

ns1:Parametro_7db576270f a ns1:Parametro ;
    rdfs:label "Marca de operación" ;
    ns1:textoExtracto "La marca se pone a \"1\" cuando comienza la operación y se mantiene a dicho valor hasta que finaliza la misma." .

ns1:RegistroDeLaVariable a ns1:Parametro ;
    rdfs:label "Registro de la variable" ;
    ns1:textoExtracto "CNCRD (Variable, Registro, Marca) CNCWR (Registro, Variable, Marca)" .

ns1:VariableInternaDelCNC a ns1:Parametro ;
    rdfs:label "Variable interna del CNC" ;
    ns1:textoExtracto "CNCRD (Variable, Registro, Marca) CNCWR (Registro, Variable, Marca)" .

