@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:MFUN1C1 a ex:Parametro ;
    ex:textoExtracto "MFUN1C1" .

ex:MFUN2C1 a ex:Parametro ;
    ex:textoExtracto "MFUN2C1" .

ex:MFUN3C1 a ex:Parametro ;
    ex:textoExtracto "MFUN3C1 - MFUN7C1" .

ex:MFUN1C2 a ex:Parametro ;
    ex:textoExtracto "MFUN1C2" .

ex:MFUN2C2 a ex:Parametro ;
    ex:textoExtracto "MFUN2C2" .

ex:MFUN3C2 a ex:Parametro ;
    ex:textoExtracto "MFUN3C2 - MFUN7C2" .

ex:SistemaControlCNC a ex:Sistema ;
    ex:textoExtracto "el CNC pasará al PLC la siguiente información" .

ex:PLC a ex:ComponenteElectrico ;
    ex:textoExtracto "PLC" .

ex:SistemaControlCNC ex:controla ex:PLC .