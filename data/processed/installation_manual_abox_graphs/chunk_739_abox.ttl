@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_1e51ebdc67 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:ConsultaDeVariablesSincronasYAsincronas ;
    ns1:textoExtracto "CNCWR carga el contenido del registro en la variable." .

ns1:VariableDeHerramienta a ns1:Parametro ;
    rdfs:label "Variable de herramienta" ;
    ns1:identificador "TM.TOOL" ;
    ns1:textoExtracto "<condición> AND NOT M11 = CNCRD (TM.TOOL, R11, M11)" .

ns1:VariableDePosicionDeEje a ns1:Parametro ;
    rdfs:label "Variable de posición de eje" ;
    ns1:identificador "G.GUP" ;
    ns1:textoExtracto "DEF PARAM 153 CNCWR (G.GUP[PARAM], R10, M1000)" .

ns1:ConsultaDeVariablesSincronasYAsincronas a ns1:TareaMantenimiento ;
    rdfs:label "Consulta de variables síncronas y asíncronas" ;
    ns1:textoExtracto "Se denominan variables síncronas a las que se resuelven inmediatamente y variables asíncronas a las que necesitan varios ciclos para resolverse." .

