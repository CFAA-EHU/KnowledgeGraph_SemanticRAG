@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:HFUN1C1 a ex:Parametro ;
    ex:identificador "HFUN1C1" ;
    ex:textoExtracto "HFUN1C1" .

ex:HFUN2C1 a ex:Parametro ;
    ex:identificador "HFUN2C1" ;
    ex:textoExtracto "HFUN2C1" .

ex:HFUN3C1 a ex:Parametro ;
    ex:identificador "HFUN3C1 - HFUN7C1" ;
    ex:textoExtracto "HFUN3C1 - HFUN7C1" .

ex:HFUN1C2 a ex:Parametro ;
    ex:identificador "HFUN1C2" ;
    ex:textoExtracto "HFUN1C2" .

ex:HFUN2C2 a ex:Parametro ;
    ex:identificador "HFUN2C2" ;
    ex:textoExtracto "HFUN2C2" .

ex:HFUN3C2 a ex:Parametro ;
    ex:identificador "HFUN3C2 - HFUN7C2" ;
    ex:textoExtracto "HFUN3C2 - HFUN7C2" .

ex:Tabla_HFUN_Canal1 a ex:Tabla ;
    ex:textoExtracto "Si no se utilizan todos los registros, el CNC asigna el valor hexadecimal $FFFFFFFF a los que queden libres, los de numeración más alta. De esta forma si en el primer canal se encuentran programadas las funciones H10 y H20 y en el segundo canal las funciones H30 y H40, el CNC pasará al PLC la siguiente información. | HFUN1C1 | HFUN2C1 | HFUN3C1 - HFUN7C1 | | --- | --- | --- | | 10 | 20 | $FFFFFFFF |" ;
    ex:tieneComponente ex:HFUN1C1, ex:HFUN2C1, ex:HFUN3C1 .

ex:Tabla_HFUN_Canal2 a ex:Tabla ;
    ex:textoExtracto " | HFUN1C2 | HFUN2C2 | HFUN3C2 - HFUN7C2 | | --- | --- | --- | | 30 | 40 | $FFFFFFFF |" ;
    ex:tieneComponente ex:HFUN1C1, ex:HFUN2C1, ex:HFUN3C1 .