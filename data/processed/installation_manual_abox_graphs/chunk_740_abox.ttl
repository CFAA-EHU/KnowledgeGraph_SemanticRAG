@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableAsincronaM11 a ns1:Parametro ;
    rdfs:label "Variable asíncrona M11" ;
    ns1:identificador "M11" ;
    ns1:textoExtracto "Ejemplo de acceso a variables asíncronas: <condición> AND NOT M11 = CNCRD (TM.TOOL, R11, M11)" .

ns1:VariableAsincronaR11 a ns1:Parametro ;
    rdfs:label "Variable asíncrona R11" ;
    ns1:identificador "R11" ;
    ns1:textoExtracto "DFD M11 AND CPS R11 EQ 3 = ... esperar a que finalice la consulta para evaluar los datos." .

ns1:VariableSincronaM12 a ns1:Parametro ;
    rdfs:label "Variable síncrona M12" ;
    ns1:identificador "M12" ;
    ns1:textoExtracto "<condición> = CNCRD (G.FREAL, R12, M12)" .

ns1:VariableSincronaR12 a ns1:Parametro ;
    rdfs:label "Variable síncrona R12" ;
    ns1:identificador "R12" ;
    ns1:textoExtracto "<condición> = CNCRD (G.FREAL, R12, M12) CPS R12 GT 2000 = ... no hace falta esperar para consultar los datos porque las variables síncronas se resuelven" .

