@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccesoAVariablesSincronas a ns1:Parametro ;
    rdfs:label "Acceso a variables síncronas" ;
    ns1:textoExtracto "<condición> = CNCRD (G.FREAL, R12, M12) CPS R12 GT 2000" .

ns1:EjecucionDeUnBloqueDeCNC_8b612b8083 a ns1:TareaMantenimiento ;
    rdfs:label "Ejecución de un bloque de CNC" ;
    ns1:textoExtracto "= CNCEX Ejecución de un bloque de CNC." .

ns1:FormatoDeProgramacionParaEjecucionDeBloquesCNC a ns1:Parametro ;
    rdfs:label "Formato de programación para ejecución de bloques CNC" ;
    ns1:textoExtracto "CNCEX (bloque, marca, canal)" .

ns1:InicializacionDelRelojHabilitadoPorElPLC a ns1:Parametro ;
    rdfs:label "Inicialización del reloj habilitado por el PLC" ;
    ns1:textoExtracto "<condición> = CNCWR (R13, PLC.TIMER, M13)" .

ns1:Parametro_5c9704a9eb a ns1:Parametro ;
    rdfs:label "Comando para adición de movimiento desde el PLC",
        "Comando para información de movimiento desde el PLC",
        "Comando para movimiento absoluto desde el PLC" ;
    ns1:textoExtracto "Los movimientos de ejes independientes se pueden programar directamente o mediante el comando CNCEX" .

ns1:UsoMixtoDeCNCEXYComandosMOVE a ns1:AccionProhibida ;
    rdfs:label "Uso mixto de CNCEX y comandos MOVE*" ;
    ns1:textoExtracto "no es recomendable utilizar ambos métodos en el mismo programa de PLC o subrutina" .

