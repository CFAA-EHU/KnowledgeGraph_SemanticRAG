@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_HFUNC_Programacion a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de registros HFUNC para programación de funciones por canal"@es ;
    ex:textoExtracto """
| HFUN1C2 | HFUN2C2 | HFUN3C2 - HFUN7C2 |
| --- | --- | --- |
| 30 | 40 | $FFFFFFFF |
Si a continuación se ejecuta en el primer canal la función H50 se tiene:
| HFUN1C1 | HFUN2C1 | HFUN3C1 - HFUN7C1 |
| --- | --- | --- |
| 50 | $FFFFFFFF | $FFFFFFFF
""" .

ex:Parametro_HFUN1C1
    a ex:Parametro ;
    rdfs:label "Registro HFUN1C1"@es ;
    ex:identificador "HFUN1C1" ;
    ex:valor "50" ;
    ex:documentadoEn ex:Tabla_HFUNC_Programacion ;
    ex:textoExtracto "HFUN1C1 [...] 50"@es .

ex:Parametro_HFUN2C1
    a ex:Parametro ;
    rdfs:label "Registro HFUN2C1"@es ;
    ex:identificador "HFUN2C1" ;
    ex:valor "$FFFFFFFF" ;
    ex:documentadoEn ex:Tabla_HFUNC_Programacion ;
    ex:textoExtracto "HFUN2C1 [...] $FFFFFFFF"@es .

ex:Parametro_HFUN1C2
    a ex:Parametro ;
    rdfs:label "Registro HFUN1C2"@es ;
    ex:identificador "HFUN1C2" ;
    ex:valor "30" ;
    ex:documentadoEn ex:Tabla_HFUNC_Programacion ;
    ex:textoExtracto "HFUN1C2 [...] 30"@es .

ex:Parametro_HFUN2C2
    a ex:Parametro ;
    rdfs:label "Registro HFUN2C2"@es ;
    ex:identificador "HFUN2C2" ;
    ex:valor "40" ;
    ex:documentadoEn ex:Tabla_HFUNC_Programacion ;
    ex:textoExtracto "HFUN2C2 [...] 40"@es .

ex:Comando_HFUNC1
    a ex:InterfazUsuario ;
    rdfs:label "Comando HFUNC1*"@es ;
    ex:identificador "HFUNC1*" ;
    ex:textoExtracto "HFUNC1* Para el canal 1. También se pueden programar como HFUN*."@es ;
    ex:documentadoEn ex:Tabla_HFUNC_Programacion .

ex:Comando_HFUNC2
    a ex:InterfazUsuario ;
    rdfs:label "Comando HFUNC2*"@es ;
    ex:identificador "HFUNC2*" ;
    ex:textoExtracto "HFUNC2* Para el canal 2."@es ;
    ex:documentadoEn ex:Tabla_HFUNC_Programacion .

ex:Comando_HFUNC3
    a ex:InterfazUsuario ;
    rdfs:label "Comando HFUNC3*"@es ;
    ex:identificador "HFUNC3*" ;
    ex:textoExtracto "HFUNC3* Para el canal 3."@es ;
    ex:documentadoEn ex:Tabla_HFUNC_Programacion .

ex:Comando_HFUNC4
    a ex:InterfazUsuario ;
    rdfs:label "Comando HFUNC4*"@es ;
    ex:identificador "HFUNC4*" ;
    ex:textoExtracto "HFUNC4* Para el canal 4."@es ;
    ex:documentadoEn ex:Tabla_HFUNC_Programacion .