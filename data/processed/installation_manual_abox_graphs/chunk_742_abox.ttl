ex:Parametro_SPDLTIME
    a ex:Parametro ;
    rdfs:label "SPDLTIME (tiempo de activación de cabezal)" ;
    ex:textoExtracto "El CNC sólo utiliza los registros de los cabezales cuyo parámetro SPDLTIME tenga un valor distinto de cero." ;
    ex:monitoreaParametro ex:Sistema_ControlCNC .

ex:Sistema_ControlCNC
    a ex:Sistema ;
    rdfs:label "Sistema de Control CNC" ;
    ex:textoExtracto "El canal del CNC pone esta marca a (=1) para indicar al PLC que debe ejecutar la(s) función(es) auxiliares M que se le indican en los registros MFUN1 a MFUN7 del canal." ;
    ex:tieneComponente ex:Parametro_MFUN1, ex:Parametro_MFUN2, ex:Parametro_MFUN3, ex:Parametro_MFUN4, ex:Parametro_MFUN5, ex:Parametro_MFUN6, ex:Parametro_MFUN7 ;
    ex:tieneComponente ex:Parametro_HFUN1, ex:Parametro_HFUN2, ex:Parametro_HFUN3, ex:Parametro_HFUN4, ex:Parametro_HFUN5, ex:Parametro_HFUN6, ex:Parametro_HFUN7 .

ex:Parametro_MFUN1
    a ex:Parametro ;
    rdfs:label "MFUN1 (función auxiliar M, canal)" ;
    ex:identificador "MFUN1" ;
    ex:textoExtracto "función(es) auxiliares M que se le indican en los registros MFUN1 a MFUN7" .

