@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ComandoCNCEX a ns1:AccionProhibida ;
    rdfs:label "Comando CNCEX" ;
    ns1:textoExtracto "El comando CNCEX se ejecuta a través de una canal del CNC mientras que los comandos MOVE* se ejecutan directamente en el interpolador (habitualmente ejecución más rápida)." .

ns1:ComandoMOVE a ns1:AccionProhibida ;
    rdfs:label "Comando MOVE*" ;
    ns1:textoExtracto "El comando CNCEX se ejecuta a través de una canal del CNC mientras que los comandos MOVE* se ejecutan directamente en el interpolador (habitualmente ejecución más rápida)." .

ns1:NoSeRecomiendaUtilizarAmbasEnElMismoProgramaOSubrutina a ns1:AccionProhibida ;
    rdfs:label "No se recomienda utilizar ambas en el mismo programa o subrutina" ;
    ns1:textoExtracto "No se recomienda utilizar ambas en el mismo programa o subrutina." .

