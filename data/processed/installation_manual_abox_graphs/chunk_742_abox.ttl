ex:Parametro_SFUN1
    a ex:Parametro ;
    rdfs:label "SFUN1 (velocidad cabezal 1)" ;
    ex:identificador "SFUN1" ;
    ex:textoExtracto "SFUN1 ... Estos registros indican la velocidad programada en cada uno de los cabezales." ;
    ex:monitoreaParametro ex:Sistema_ControlCNC .

