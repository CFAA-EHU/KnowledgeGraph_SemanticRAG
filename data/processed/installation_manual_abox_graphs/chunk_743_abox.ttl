@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_SFUN_Se_alesConsulta
    a ex:Tabla ;
    rdfs:label "Tabla de señales de consulta generales (SFUN1-SFUN4)" ;
    ex:textoExtracto """
| SFUN1 | SFUN2 | SFUN3 | SFUN4 |
| --- | --- | --- | --- |
| 1000 | 550 | $FFFFFFFF | $FFFFFFFF |
""" .

ex:Parametro_SFUN1
    a ex:Parametro ;
    rdfs:label "SFUN1" ;
    ex:valor "1000"^^<http://www.w3.org/2001/XMLSchema#string> ;
    ex:documentadoEn ex:Tabla_SFUN_Se_alesConsulta ;
    ex:textoExtracto "SFUN1 | ... | 1000" .

ex:Parametro_SFUN2
    a ex:Parametro ;
    rdfs:label "SFUN2" ;
    ex:valor "550"^^<http://www.w3.org/2001/XMLSchema#string> ;
    ex:documentadoEn ex:Tabla_SFUN_Se_alesConsulta ;
    ex:textoExtracto "SFUN2 | ... | 550" .

ex:Parametro_SFUN3
    a ex:Parametro ;
    rdfs:label "SFUN3" ;
    ex:valor "$FFFFFFFF"^^<http://www.w3.org/2001/XMLSchema#string> ;
    ex:documentadoEn ex:Tabla_SFUN_Se_alesConsulta ;
    ex:textoExtracto "SFUN3 | ... | $FFFFFFFF" .

ex:Parametro_SFUN4
    a ex:Parametro ;
    rdfs:label "SFUN4" ;
    ex:valor "$FFFFFFFF"^^<http://www.w3.org/2001/XMLSchema#string> ;
    ex:documentadoEn ex:Tabla_SFUN_Se_alesConsulta ;
    ex:textoExtracto "SFUN4 | ... | $FFFFFFFF" .