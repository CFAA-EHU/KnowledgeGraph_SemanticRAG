ex:Seccion6_1_SenalesConsultaGenerales
    a ex:InterfazUsuario ;
    rdfs:label "Sección 6.1: Señales de consulta generales" ;
    ex:textoExtracto "Señales de consulta generales. SSTROBE, DM00, DM03, BLKSEARCH y otras marcas asociadas a funciones M del CNC." ;
    ex:tieneComponente ex:SSTROBE1, ex:SSTROBE2, ex:SSTROBE3, ex:SSTROBE4, ex:SPDLTIME, ex:DM00, ex:DM00C1, ex:DM00C2, ex:DM00C3, ex:DM00C4, ex:DM03SP1, ex:BLKSEARCH .