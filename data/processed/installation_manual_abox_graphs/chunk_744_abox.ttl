@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarLaLevaElectronica a ns1:AccionProhibida ;
    rdfs:label "Activar la leva electrónica" ;
    ns1:textoExtracto "CAM ON = TCAM ON = CAM OFF Activar la leva electrónica con las cotas reales (CAM ON), con las cotas teóricas (TCAM ON) o cancelar la leva electrónica (CAM OFF)." .

ns1:CancelarLaLevaElectronica a ns1:AccionProhibida ;
    rdfs:label "Cancelar la leva electrónica" ;
    ns1:textoExtracto "La ejecución del comando CAM OFF implica eliminar la sincronización de la leva." .

ns1:InstruccionesDeAccionDeLaLevaElectronica a ns1:AccionProhibida ;
    rdfs:label "Instrucciones de acción de la leva electrónica" ;
    ns1:textoExtracto "Esta funcionalidad dispone de un manual específico. En este manual, que está usted leyendo, sólo se ofrece información orientativa sobre esta funcionalidad." .

ns1:Parametro_2b95a48bd3 a ns1:Parametro ;
    rdfs:label "Comando para activar la leva con cotas teóricas" ;
    ns1:identificador "TCAM ON" ;
    ns1:textoExtracto "TCAM ON (cam, master/\"TIME\", slave, master_off, slave_off, range_master, range_slave, type)" .

ns1:Parametro_4d7ad00a39 a ns1:Parametro ;
    rdfs:label "Comando para activar la leva con cotas reales" ;
    ns1:identificador "CAM ON" ;
    ns1:textoExtracto "CAM ON (cam, master/\"TIME\", slave, master_off, slave_off, range_master, range_slave, type)" .

ns1:Parametro_68f33a5af6 a ns1:Parametro ;
    rdfs:label "Comando para cancelar la leva electrónica" ;
    ns1:identificador "CAM OFF" ;
    ns1:textoExtracto "CAM OFF (slave)" .

