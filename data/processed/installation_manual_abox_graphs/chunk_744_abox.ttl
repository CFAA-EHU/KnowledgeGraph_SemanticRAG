ex:SPDLTIME
    a ex:Parametro ;
    rdfs:label "SPDLTIME" ;
    ex:textoExtracto "parámetro SPDLTIME tenga un valor distinto de cero" ;
    ex:identificador "SPDLTIME" .

ex:DM00
    a ex:Parametro ;
    rdfs:label "DM00" ;
    ex:textoExtracto "DM00. Estas marcas están asociadas a las funciones M00. El CNC indica en estas marcas el estado de las funciones auxiliares M de cabezal." ;
    ex:identificador "DM00" .

