@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SSTROBE1
    a ex:Parametro ;
    rdfs:label "SSTROBE1" ;
    ex:textoExtracto "SSTROBE1 (también se puede programar como SSTROBE). El canal del CNC pone esta marca a (=1) para indicar al PLC que hay seleccionada una nueva velocidad de cabezal." ;
    ex:identificador "SSTROBE1" .

