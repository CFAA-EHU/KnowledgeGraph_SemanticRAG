@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:BLKSEARCH a ex:Parametro ;
    ex:identificador "BLKSEARCH" ;
    ex:textoExtracto "La marca se pone a (=1) si la función está activa y a (=0) en caso contrario. Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. BLKSEARCHC1 (también se puede programar como BLKSEARCH) BLKSEARCHC2 BLKSEARCHC3 BLKSEARCHC4 El canal del CNC pone esta marca a (=1) para indicar que se encuentra activa la opción –búsqueda de bloque– en el modo de operación automático." .

ex:BLKSEARCHC1 a ex:Parametro ;
    ex:identificador "BLKSEARCHC1" ;
    ex:textoExtracto "BLKSEARCHC1 (también se puede programar como BLKSEARCH)" .

ex:BLKSEARCHC2 a ex:Parametro ;
    ex:identificador "BLKSEARCHC2" ;
    ex:textoExtracto "BLKSEARCHC2" .

ex:BLKSEARCHC3 a ex:Parametro ;
    ex:identificador "BLKSEARCHC3" ;
    ex:textoExtracto "BLKSEARCHC3" .

ex:BLKSEARCHC4 a ex:Parametro ;
    ex:identificador "BLKSEARCHC4" ;
    ex:textoExtracto "BLKSEARCHC4" .

ex:ADVINPOS a ex:Parametro ;
    ex:identificador "ADVINPOS" ;
    ex:textoExtracto "ADVINPOS Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. ADVINPOSC1 (también se puede programar como ADVINPOS) ADVINPOSC2 ADVINPOSC3 ADVINPOSC4 El canal del CNC pone esta señal" .

ex:ADVINPOSC1 a ex:Parametro ;
    ex:identificador "ADVINPOSC1" ;
    ex:textoExtracto "ADVINPOSC1 (también se puede programar como ADVINPOS)" .

ex:ADVINPOSC2 a ex:Parametro ;
    ex:identificador "ADVINPOSC2" ;
    ex:textoExtracto "ADVINPOSC2" .

ex:ADVINPOSC3 a ex:Parametro ;
    ex:identificador "ADVINPOSC3" ;
    ex:textoExtracto "ADVINPOSC3" .

ex:ADVINPOSC4 a ex:Parametro ;
    ex:identificador "ADVINPOSC4" ;
    ex:textoExtracto "ADVINPOSC4" .