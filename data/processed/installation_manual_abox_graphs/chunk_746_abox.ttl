@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ADVINPOSC1 a ex:Sensor ;
    rdfs:label "ADVINPOSC1" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. ADVINPOSC1 (también se puede programar como ADVINPOS) ... El canal del CNC pone esta señal a nivel lógico alto un tiempo antes de llegar los ejes a posición." .

ex:ADVINPOSC2 a ex:Sensor ;
    rdfs:label "ADVINPOSC2" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. ... ADVINPOSC2 ..." .

ex:ADVINPOSC3 a ex:Sensor ;
    rdfs:label "ADVINPOSC3" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. ... ADVINPOSC3 ..." .

ex:ADVINPOSC4 a ex:Sensor ;
    rdfs:label "ADVINPOSC4" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. ... ADVINPOSC4 ... El canal del CNC pone esta señal a nivel lógico alto un tiempo antes de llegar los ejes a posición." .

ex:CAXISC1 a ex:Sensor ;
    rdfs:label "CAXISC1" ;
    ex:textoExtracto "CAXISC1 (también se puede programar como CAXIS) ... El canal del CNC pone esta marca a (=1) cuando el cabezal está trabajando como eje C." .

ex:CAXISC2 a ex:Sensor ;
    rdfs:label "CAXISC2" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. ... CAXISC2 ..." .

ex:CAXISC3 a ex:Sensor ;
    rdfs:label "CAXISC3" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. ... CAXISC3 ..." .

ex:CAXISC4 a ex:Sensor ;
    rdfs:label "CAXISC4" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. ... CAXISC4 ... El canal del CNC pone esta marca a (=1) cuando el cabezal está trabajando como eje C." .

ex:FREEC1 a ex:Sensor ;
    rdfs:label "FREEC1" ;
    ex:textoExtracto "FREEC1 ... El canal del CNC pone esta señal a (=1) para indicar al PLC que está listo para aceptar un nuevo bloque, enviado mediante el comando CNCEX." .

ex:FREEC2 a ex:Sensor ;
    rdfs:label "FREEC2" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. ... FREEC2 ..." .

ex:FREEC3 a ex:Sensor ;
    rdfs:label "FREEC3" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. ... FREEC3 ..." .

ex:FREEC4 a ex:Sensor ;
    rdfs:label "FREEC4" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. ... FREEC4 ... El canal del CNC pone esta señal a (=1) para indicar al PLC que está listo para aceptar un nuevo bloque, enviado mediante el comando CNCEX." .

ex:WAITOUTC1 a ex:Sensor ;
    rdfs:label "WAITOUTC1" ;
    ex:textoExtracto "WAITOUTC1 ... Se aplica a la sincronización de canales. El canal del CNC pone esta señal a (=1) para indicar al PLC que está esperando una señal de sincronización." .

ex:WAITOUTC2 a ex:Sensor ;
    rdfs:label "WAITOUTC2" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. ... WAITOUTC2 ..." .

ex:WAITOUTC3 a ex:Sensor ;
    rdfs:label "WAITOUTC3" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. ... WAITOUTC3 ..." .

ex:WAITOUTC4 a ex:Sensor ;
    rdfs:label "WAITOUTC4" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. ... WAITOUTC4 ... Se aplica a la sincronización de canales. El canal del CNC pone esta señal a (=1) para indicar al PLC que está esperando una señal de sincronización." .

ex:ANTIME a ex:Parametro ;
    rdfs:label "ANTIME" ;
    ex:textoExtracto "Este tiempo lo fija el parámetro máquina ANTIME. Si la duración total del movimiento es inferior al valor especificado en el parámetro ANTIME, la marca se pone a (=1) inmediatamente. Si el parámetro ANTIME se ha definido con valor ꞏ0ꞏ, la marca está siempre activa." .