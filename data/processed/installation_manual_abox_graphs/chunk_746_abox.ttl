@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionLevaNoPeriodica a ns1:AccionProhibida ;
    rdfs:label "Accion Leva No Periódica" ;
    ns1:textoExtracto "Se define asignando al parámetro type el valor \"ONCE\"." .

ns1:AccionLevaPeriodica a ns1:AccionProhibida ;
    rdfs:label "Accion Leva Periódica" ;
    ns1:textoExtracto "Se define asignando al parámetro type el valor \"CONT\"." .

ns1:PosicionDeInicioDelEjeEsclavo a ns1:Parametro ;
    rdfs:label "Posición de inicio del eje esclavo" ;
    ns1:identificador "slave_off" ;
    ns1:textoExtracto "La leva aplica al eje esclavo cuando éste se encuentra entre \"slave_off\" y \"slave_off + range_slave\"." .

ns1:PosicionDeInicioDelEjeMaestro a ns1:Parametro ;
    rdfs:label "Posición de inicio del eje maestro" ;
    ns1:identificador "master_off" ;
    ns1:textoExtracto "La leva se activa cuando el eje maestro se encuentra entre las posiciones \"master_off\" y \"master_off + range_master\"." .

ns1:RangoDeActivacionDelEjeEsclavo a ns1:Parametro ;
    rdfs:label "Rango de activación del eje esclavo" ;
    ns1:identificador "range_slave" ;
    ns1:textoExtracto "La leva aplica al eje esclavo cuando éste se encuentra entre \"slave_off\" y \"slave_off + range_slave\"." .

ns1:RangoDeActivacionDelEjeMaestro a ns1:Parametro ;
    rdfs:label "Rango de activación del eje maestro" ;
    ns1:identificador "range_master" ;
    ns1:textoExtracto "La leva se activa cuando el eje maestro se encuentra entre las posiciones \"master_off\" y \"master_off + range_master\"." .

ns1:TipoDeLeva a ns1:Parametro ;
    rdfs:label "Tipo de leva" ;
    ns1:identificador "type" ;
    ns1:textoExtracto "La selección se realiza mediante el parámetro type." .

