@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CAMDESELECT a ns1:AccionProhibida ;
    rdfs:label "CAM DESELECT" ;
    ns1:textoExtracto "= CAM SELECT = CAM DESELECT anular una leva de archivo (CAM DESELECT)." .

ns1:CAMOFF_6b3f432488 a ns1:AccionProhibida ;
    rdfs:label "CAM OFF" ;
    ns1:textoExtracto "En los dos modos se mantiene la sincronización hasta la ejecución del comando CAM OFF." .

ns1:CAMSELECT a ns1:AccionProhibida ;
    rdfs:label "CAM SELECT" ;
    ns1:textoExtracto "= CAM SELECT = CAM DESELECT Seleccionar (CAM SELECT)" .

