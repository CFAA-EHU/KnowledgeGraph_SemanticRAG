@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:senalSincronizacionCNC a ex:Sensor ;
    rdfs:label "señal de sincronización"@es ;
    ex:textoExtracto "El canal del CNC pone esta señal a (=1) para indicar al PLC que está esperando una señal de sincronización."@es .

ex:senalEsperaSincronizacion a ex:Sensor ;
    rdfs:label "señal de espera de sincronización"@es ;
    ex:textoExtracto "El canal del CNC pone esta señal a (=1) para indicar al PLC que está esperando una señal de sincronización."@es .

ex:marcaEstadoSistemaOperativo a ex:Sensor ;
    rdfs:label "marca de estado del sistema operativo"@es ;
    ex:textoExtracto "MMCWDG Esta marca indica el estado del sistema operativo. Tiene el valor (=0) cuando el sistema operativo CNC funciona correctamente y valor (=1) en caso de bloqueo del"@es .

ex:sentenciaWAIT a ex:ModoOperacion ;
    rdfs:label "#WAIT"@en ;
    ex:textoExtracto "Las señales de sincronización se pueden ejecutar desde el programa pieza mediante las sentencias #WAIT o #MEET."@es .

ex:sentenciaMEET a ex:ModoOperacion ;
    rdfs:label "#MEET"@en ;
    ex:textoExtracto "Las señales de sincronización se pueden ejecutar desde el programa pieza mediante las sentencias #WAIT o #MEET."@es .