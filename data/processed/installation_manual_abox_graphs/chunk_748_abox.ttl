@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MMCWDG a ex:Sensor ;
    rdfs:label "MMCWDG" ;
    ex:textoExtracto "Esta marca indica el estado del sistema operativo. Tiene el valor (=0) cuando el sistema operativo CNC funciona correctamente y valor (=1) en caso de bloqueo del sistema operativo." ;
    ex:valor "0 (funcionamiento correcto), 1 (bloqueo)" .

ex:TANGACTIV a ex:Sensor ;
    rdfs:label "TANGACTIV" ;
    ex:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. TANGACTIVC1 TANGACTIVC2 TANGACTIVC3 TANGACTIVC4 El canal del CNC pone esta marca a (=1) para indicar que hay algún control tangencial activo en el canal." ;
    ex:valor "1 (control tangencial activo)" .

ex:TANGACTIVC1 a ex:Sensor ;
    rdfs:label "TANGACTIVC1" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. TANGACTIVC1 TANGACTIVC2 TANGACTIVC3 TANGACTIVC4" ;
    ex:valor "1 (control tangencial activo en canal 1)" .

ex:TANGACTIVC2 a ex:Sensor ;
    rdfs:label "TANGACTIVC2" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. TANGACTIVC1 TANGACTIVC2 TANGACTIVC3 TANGACTIVC4" ;
    ex:valor "1 (control tangencial activo en canal 2)" .

ex:TANGACTIVC3 a ex:Sensor ;
    rdfs:label "TANGACTIVC3" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. TANGACTIVC1 TANGACTIVC2 TANGACTIVC3 TANGACTIVC4" ;
    ex:valor "1 (control tangencial activo en canal 3)" .

ex:TANGACTIVC4 a ex:Sensor ;
    rdfs:label "TANGACTIVC4" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. TANGACTIVC1 TANGACTIVC2 TANGACTIVC3 TANGACTIVC4" ;
    ex:valor "1 (control tangencial activo en canal 4)" .

ex:RETRAEND a ex:Sensor ;
    rdfs:label "RETRAEND" ;
    ex:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. RETRAENDC1 RETRAENDC2 RETRAENDC3 RETRAENDC4 El canal del CNC pone esta marca a (=1) para cancelar la función retrace." ;
    ex:valor "1 (cancelación de función retrace)" .

ex:RETRAENDC1 a ex:Sensor ;
    rdfs:label "RETRAENDC1" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. RETRAENDC1 RETRAENDC2 RETRAENDC3 RETRAENDC4" ;
    ex:valor "1 (cancelación de función retrace en canal 1)" .

ex:RETRAENDC2 a ex:Sensor ;
    rdfs:label "RETRAENDC2" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. RETRAENDC1 RETRAENDC2 RETRAENDC3 RETRAENDC4" ;
    ex:valor "1 (cancelación de función retrace en canal 2)" .

ex:RETRAENDC3 a ex:Sensor ;
    rdfs:label "RETRAENDC3" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. RETRAENDC1 RETRAENDC2 RETRAENDC3 RETRAENDC4" ;
    ex:valor "1 (cancelación de función retrace en canal 3)" .

ex:RETRAENDC4 a ex:Sensor ;
    rdfs:label "RETRAENDC4" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. RETRAENDC1 RETRAENDC2 RETRAENDC3 RETRAENDC4" ;
    ex:valor "1 (cancelación de función retrace en canal 4)" .

ex:RETRACE a ex:Sensor ;
    rdfs:label "RETRACE" ;
    ex:textoExtracto "Si el PLC quita automáticamente la marca RETRACE con la marca RETRAEND, el CNC continua con la ejecución normal del programa, hacia a delante. En caso contrario, si la marca RETRACE continua activa, el CNC mostrará un aviso indicando que se debe desactivar esta marca para continuar con la ejecución del programa." ;
    ex:valor "activa (0/1 según estado)" .

ex:SistemaOperativoCNC a ex:Sistema ;
    rdfs:label "Sistema operativo CNC" ;
    ex:textoExtracto "Esta marca indica el estado del sistema operativo. Tiene el valor (=0) cuando el sistema operativo CNC funciona correctamente y valor (=1) en caso de bloqueo del sistema operativo." ;
    ex:valor "0 (funcionamiento correcto), 1 (bloqueo)" .