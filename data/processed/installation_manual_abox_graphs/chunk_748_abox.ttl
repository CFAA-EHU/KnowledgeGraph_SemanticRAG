@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AccionProhibida_cbd6874a46 a ns1:AccionProhibida ;
    rdfs:label "Comando CAM OFF" ;
    ns1:textoExtracto "La ejecución del comando CAM OFF implica eliminar la sincronización de la leva." .

ns1:AccionProhibida_ec90424ce9 a ns1:AccionProhibida ;
    rdfs:label "Comando CAM ON (desde el PLC)" ;
    ns1:textoExtracto "para activarla, utilizar la sentencia #CAM ON (desde el CNC) o el comando CAM ON (desde el PLC)." .

ns1:CNC8070_58509d41a1 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Los datos de la leva pueden estar definidos en un archivo, el cual se puede cargar desde el CNC o el PLC." .

ns1:SeleccionDeLevaDeArchivo a ns1:TareaMantenimiento ;
    rdfs:label "Selección de Leva de Archivo" ;
    ns1:textoExtracto "CAM DESELECT Seleccionar (CAM SELECT) o anular una leva de archivo (CAM DESELECT)." .

ns1:SentenciaCAMONDesdeElCNC a ns1:AccionProhibida ;
    rdfs:label "Sentencia #CAM ON (desde el CNC)" ;
    ns1:textoExtracto "para activarla, utilizar la sentencia #CAM ON (desde el CNC) o el comando CAM ON (desde el PLC)." .

ns1:ValidacionDeTablaDeLevas a ns1:AccionProhibida ;
    rdfs:label "Validación de Tabla de Levas" ;
    ns1:textoExtracto "Tras seleccionar una leva de archivo, ésta permanece disponible hasta que se valide la tabla de levas de los parámetros máquina o se apague el CNC." .

