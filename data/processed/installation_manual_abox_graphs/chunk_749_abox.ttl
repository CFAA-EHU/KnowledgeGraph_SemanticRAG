@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:FuncionRetrace a ex:Tabla ;
     a ex:ModoOperacion ;
    rdfs:label "Función retrace" ;
    ex:textoExtracto "La función retrace también se cancela tras ejecutar M30, con un reset o cuando al PLC pone a (=0) la marca RETRACE del canal." .

ex:MarcaRetrace
    a ex:Parametro ;
    rdfs:label "Marca RETRACE" ;
    ex:identificador "RETRACE" ;
    ex:textoExtracto "cuando al PLC pone a (=0) la marca RETRACE del canal" ;
    ex:monitoreaParametro ex:FuncionRetrace .

ex:PasswordFabricante
    a ex:ElementoSeguridad ;
    rdfs:label "Password de fabricante" ;
    ex:textoExtracto "El CNC activa esta marca cuando existe un password de fabricante." .

ex:MarcaPSWSET
    a ex:Parametro ;
    rdfs:label "Marca PSWSET" ;
    ex:identificador "PSWSET" ;
    ex:textoExtracto "El CNC activa esta marca cuando existe un password de fabricante." ;
    ex:mitigaRiesgo ex:PasswordFabricante .

ex:ParametroDINDISTC1
    a ex:Parametro ;
    rdfs:label "Parámetro DINDISTC1" ;
    ex:identificador "DINDISTC1" ;
    ex:textoExtracto "DINDISTC1" .