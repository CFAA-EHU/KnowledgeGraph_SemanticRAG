@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:FuncionRetrace a ex:AccionProhibida ;
    ex:textoExtracto "La función retrace también se cancela tras ejecutar M30, con un reset o cuando al PLC pone a (=0) la marca RETRACE del canal." ;
    ex:identificador "RETRACE" .

ex:MarcaRETRACE a ex:Parametro ;
    ex:textoExtracto "la marca RETRACE del canal" ;
    ex:identificador "RETRACE" .

ex:AccionM30 a ex:AccionProhibida ;
    ex:textoExtracto "tras ejecutar M30" ;
    ex:identificador "M30" .

ex:AccionReset a ex:AccionProhibida ;
    ex:textoExtracto "con un reset" .

ex:MarcaPSWSET a ex:Parametro ;
    ex:textoExtracto "PSWSET El CNC activa esta marca cuando existe un password de fabricante." ;
    ex:identificador "PSWSET" .

ex:PasswordFabricante a ex:Parametro ;
    ex:textoExtracto "password de fabricante" .

ex:SistemaCNC a ex:Sistema ;
    ex:textoExtracto "El CNC activa esta marca" ;
    rdfs:label "CNC" .