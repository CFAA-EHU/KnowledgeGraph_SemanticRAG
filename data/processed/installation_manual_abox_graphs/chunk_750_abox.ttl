@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InstruccionesDeMovimientoIndependiente a ns1:TareaMantenimiento ;
    rdfs:label "Instrucciones de movimiento independiente" ;
    ns1:documentadoEn ns1:ManualFuncionalidadMovimientoIndependiente ;
    ns1:textoExtracto "Esta funcionalidad dispone de un manual específico. En este manual, que está usted leyendo, sólo se ofrece información orientativa sobre esta funcionalidad." .

ns1:MovimientoDePosicionamientoAbsoluto a ns1:Parametro ;
    rdfs:label "Movimiento de posicionamiento absoluto" ;
    ns1:textoExtracto "MOVE ABS (axis, pos, feed, blend)" .

ns1:MovimientoIncremental a ns1:Parametro ;
    rdfs:label "Movimiento incremental" ;
    ns1:textoExtracto "MOVE ADD (axis, pos, feed, blend)" .

ns1:MovimientoSinFin a ns1:Parametro ;
    rdfs:label "Movimiento sin fin" ;
    ns1:textoExtracto "MOVE INF (axis, direction, feed, blend)" .

ns1:ManualFuncionalidadMovimientoIndependiente a ns1:Manual ;
    rdfs:label "Manual específico para instrucciones de movimiento independiente" ;
    ns1:textoExtracto "Consulte la documentación específica para obtener más información acerca de los requisitos y el funcionamiento de los ejes independientes." .

