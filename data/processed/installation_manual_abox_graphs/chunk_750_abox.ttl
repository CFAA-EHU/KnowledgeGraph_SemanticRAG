@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Marca_RETRACE
    a ex:Parametro ;
    rdfs:label "RETRACE" ;
    ex:textoExtracto "retrace también se cancela [...] cuando el PLC pone a (=0) la marca RETRACE del canal." ;
    ex:valor "0" .

ex:Marca_PSWSET
    a ex:Parametro ;
    rdfs:label "PSWSET" ;
    ex:textoExtracto "El CNC activa esta marca cuando existe un password de fabricante." .

ex:Marca_DINDISTC1
    a ex:Parametro ;
    rdfs:label "DINDISTC1" ;
    ex:textoExtracto "El CNC dispone de tres marcas para cada canal. Los mnemónicos para cada canal son los siguientes. DINDISTC1C2 DINDISTC1C3 DINDISTC1C4 [...] Estas marcas están asociadas a la distribución dinámica del mecanizado entre canales." .

ex:Marca_DINDISTC2
    a ex:Parametro ;
    rdfs:label "DINDISTC2" ;
    ex:textoExtracto "El CNC dispone de tres marcas para cada canal. Los mnemónicos para cada canal son los siguientes. DINDISTC2C1 DINDISTC2C3 DINDISTC2C4 [...] Estas marcas están asociadas a la distribución dinámica del mecanizado entre canales." .

ex:Marca_DINDISTC3
    a ex:Parametro ;
    rdfs:label "DINDISTC3" ;
    ex:textoExtracto "El CNC dispone de tres marcas para cada canal. Los mnemónicos para cada canal son los siguientes. DINDISTC3C1 DINDISTC3C2 DINDISTC3C4 [...] Estas marcas están asociadas a la distribución dinámica del mecanizado entre canales." .

ex:Marca_DINDISTC4
    a ex:Parametro ;
    rdfs:label "DINDISTC4" ;
    ex:textoExtracto "El CNC dispone de tres marcas para cada canal. Los mnemónicos para cada canal son los siguientes. DINDISTC4C1 DINDISTC4C2 DINDISTC4C3 [...] Estas marcas están asociadas a la distribución dinámica del mecanizado entre canales." .

ex:Marca_DINDISTC1C2
    a ex:Parametro ;
    rdfs:label "DINDISTC1C2" ;
    ex:textoExtracto "Si el ciclo se ejecuta en el canal ꞏ1ꞏ y el resto de pasadas se distribuyen con el canal ꞏ2ꞏ, el CNC activa la marca DINDISTC1C2." ;
    ex:monitoreaParametro ex:Marca_DINDISTC1 ;
    ex:monitoreaParametro ex:Marca_DINDISTC2 .

ex:Marca_DINDISTC2C1
    a ex:Parametro ;
    rdfs:label "DINDISTC2C1" ;
    ex:textoExtracto "Si el ciclo se ejecuta en el canal ꞏ2ꞏ y el resto de pasadas se distribuyen con los canales ꞏ1ꞏ, el CNC activa las marcas DINDISTC2C1 [...]" ;
    ex:monitoreaParametro ex:Marca_DINDISTC2 ;
    ex:monitoreaParametro ex:Marca_DINDISTC1 .

ex:Marca_DINDISTC2C3
    a ex:Parametro ;
    rdfs:label "DINDISTC2C3" ;
    ex:textoExtracto "Si el ciclo se ejecuta en el canal ꞏ2ꞏ y el resto de pasadas se distribuyen con los canales [...] ꞏ3ꞏ, el CNC activa las marcas [...] DINDISTC2C3." ;
    ex:monitoreaParametro ex:Marca_DINDISTC2 ;
    ex:monitoreaParametro ex:Marca_DINDISTC3 .

ex:CNC_SistemaDistribucionPasadas
    a ex:Sistema ;
    rdfs:label "Sistema de distribución dinámica de pasadas entre canales" ;
    ex:textoExtracto "El CNC dispone de tres marcas para cada canal [...] asociadas a la distribución dinámica del mecanizado entre canales (sentencia #DINDIST)." ;
    ex:tieneComponente ex:Marca_DINDISTC1, ex:Marca_DINDISTC2, ex:Marca_DINDISTC3, ex:Marca_DINDISTC4 ;
    ex:monitoreaParametro ex:Marca_DINDISTC1C2, ex:Marca_DINDISTC2C1, ex:Marca_DINDISTC2C3 .