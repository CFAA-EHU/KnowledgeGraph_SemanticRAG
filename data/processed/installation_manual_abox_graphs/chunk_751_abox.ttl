ns1:AvanceDePosicionamiento_1ac9d5a4e2 a ns1:Parametro ;
    rdfs:label "Avance de posicionamiento" ;
    ns1:textoExtracto "feed | Avance de posicionamiento." .

ns1:EjeAPosicionar a ns1:Parametro ;
    rdfs:label "Eje a posicionar" ;
    ns1:textoExtracto "axis | Eje a posicionar." .

ns1:EnlaceDinamicoConElSiguienteBloque a ns1:Parametro ;
    rdfs:label "Enlace dinámico con el siguiente bloque" ;
    ns1:textoExtracto "blend | Enlace dinámico con el siguiente bloque. Se programa mediante los parámetros 'PRESENT', 'NULL', 'NEXT' o 'WAITINPOS'." .

ns1:PosicionAAlcanzar a ns1:Parametro ;
    rdfs:label "Posición a alcanzar" ;
    ns1:textoExtracto "pos | Posición a alcanzar." .

ns1:SentidoDeDesplazamiento a ns1:Parametro ;
    rdfs:label "Sentido de desplazamiento" ;
    ns1:textoExtracto "direction | Sentido de desplazamiento. Se programa mediante los parámetros 'DIRPOS' (sentido positivo) o 'DIRNEG' (sentido negativo)." .

