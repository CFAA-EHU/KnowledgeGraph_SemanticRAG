@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:DINDISTC2C1 a ex:Sensor ;
    rdfs:label "DINDISTC2C1" ;
    ex:textoExtracto "el CNC activa las marcas DINDISTC2C1 y DINDISTC2C3"@es .

ex:DINDISTC2C3 a ex:Sensor ;
    rdfs:label "DINDISTC2C3" ;
    ex:textoExtracto "el CNC activa las marcas DINDISTC2C1 y DINDISTC2C3"@es .

ex:DINDISTYPEC1 a ex:Sensor ;
    rdfs:label "DINDISTYPEC1" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. DINDISTYPEC1 DINDISTYPEC2 DINDISTYPEC3 DINDISTYPEC4"@es .

ex:DINDISTYPEC2 a ex:Sensor ;
    rdfs:label "DINDISTYPEC2" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. DINDISTYPEC1 DINDISTYPEC2 DINDISTYPEC3 DINDISTYPEC4"@es .

ex:DINDISTYPEC3 a ex:Sensor ;
    rdfs:label "DINDISTYPEC3" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. DINDISTYPEC1 DINDISTYPEC2 DINDISTYPEC3 DINDISTYPEC4"@es .

ex:DINDISTYPEC4 a ex:Sensor ;
    rdfs:label "DINDISTYPEC4" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. DINDISTYPEC1 DINDISTYPEC2 DINDISTYPEC3 DINDISTYPEC4"@es .