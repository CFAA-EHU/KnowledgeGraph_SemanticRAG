@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InstruccionDeMovimientoConAvanceEspecificado a ns1:Parametro ;
    rdfs:label "Instrucción de movimiento con avance especificado" ;
    ns1:identificador "NEXT" ;
    ns1:textoExtracto "NEXT El eje alcanza la posición indicada al avance especificado en el siguiente bloque." .

ns1:InstruccionDeMovimientoConAvanceNulo a ns1:Parametro ;
    rdfs:label "Instrucción de movimiento con avance nulo" ;
    ns1:identificador "NULL" ;
    ns1:textoExtracto "NULL El eje alcanza la posición indicada a avance nulo." .

ns1:InstruccionDeMovimientoConAvanceNuloYEsperaEnPosicion a ns1:Parametro ;
    rdfs:label "Instrucción de movimiento con avance nulo y espera en posición" ;
    ns1:identificador "WAITINPOS" ;
    ns1:textoExtracto "WAITINPOS El eje alcanza la posición indicada a avance nulo y espera a estar en posición para ejecutar el siguiente bloque." .

