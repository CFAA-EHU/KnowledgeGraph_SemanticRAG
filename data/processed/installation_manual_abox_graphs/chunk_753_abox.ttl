@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MarcaSobretemperaturaPLC a ex:Parametro ;
    rdfs:label "Marca sobretemperatura PLC" ;
    ex:textoExtracto "Incluir esta marca en la maniobra del PLC para restringir la operativa del CNC en caso de sobretemperatura. Si el PLC activa esta marca, existe riesgo de sobretemperatura y está en peligro la integridad del equipo."@es .

ex:RiesgoSobretemperatura a ex:DiagnosticoFallo ;
    rdfs:label "Riesgo de sobretemperatura" ;
    ex:textoExtracto "Si el PLC activa esta marca, existe riesgo de sobretemperatura y está en peligro la integridad del equipo."@es .

ex:AccionCNCFinalizarEjecucion a ex:AccionProhibida ;
    rdfs:label "Acción prohibida: finalizar ejecución en marcha" ;
    ex:textoExtracto "El CNC permitirá finalizar la ejecución en marcha, pero no permitirá reanudarla tras una interrupción, una inspección de herramienta, etc."@es .