@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Sistema_Se_alesConsultaCNC
    a ex:Sistema ;
    rdfs:label "Sistema de señales de consulta generales del CNC" ;
    ex:textoExtracto "Señales de consulta generales: MLINKRDY, RETRACT, COLLISIONACTIV, etc." .

ex:Marca_MLINKRDY
    a ex:ComponenteElectrico ;
    rdfs:label "MLINKRDY" ;
    ex:textoExtracto "En las configuraciones Mechatrolink, esta marca indica el estado del bus. El CNC activa esta marca para indicar que el bus Mechatrolink se encuentra inicializado correctamente." ;
    ex:monitoreaParametro ex:Parametro_EstadoBusMechatrolink ;
    ex:tieneComponente ex:Sistema_Se_alesConsultaCNC .

ex:Parametro_EstadoBusMechatrolink
    a ex:Parametro ;
    rdfs:label "Estado del bus Mechatrolink" ;
    ex:textoExtracto "El estado del bus Mechatrolink se consulta mediante la marca MLINKRDY." .

ex:Marca_RETRACTC1
    a ex:ComponenteElectrico ;
    rdfs:label "RETRACTC1" ;
    ex:identificador "RETRACTC1" ;
    ex:textoExtracto "El CNC utiliza esta marca cuando retira los ejes de la pieza tras interrumpir un roscado (tecla [STOP] o marca _FEEDHOL del PLC)." ;
    ex:tieneComponente ex:Sistema_Se_alesConsultaCNC .

ex:Marca_RETRACTC2
    a ex:ComponenteElectrico ;
    rdfs:label "RETRACTC2" ;
    ex:identificador "RETRACTC2" ;
    ex:textoExtracto "Marca para canal 2 de retirada de ejes tras roscado." ;
    ex:tieneComponente ex:Sistema_Se_alesConsultaCNC .

ex:Marca_RETRACTC3
    a ex:ComponenteElectrico ;
    rdfs:label "RETRACTC3" ;
    ex:identificador "RETRACTC3" ;
    ex:textoExtracto "Marca para canal 3 de retirada de ejes tras roscado." ;
    ex:tieneComponente ex:Sistema_Se_alesConsultaCNC .

ex:Marca_RETRACTC4
    a ex:ComponenteElectrico ;
    rdfs:label "RETRACTC4" ;
    ex:identificador "RETRACTC4" ;
    ex:textoExtracto "Marca para canal 4 de retirada de ejes tras roscado." ;
    ex:tieneComponente ex:Sistema_Se_alesConsultaCNC .

ex:Parametro_RETRACTTHREAD
    a ex:Parametro ;
    rdfs:label "RETRACTTHREAD" ;
    ex:identificador "RETRACTTHREAD" ;
    ex:textoExtracto "La retirada de ejes se habilita en el parámetro RETRACTTHREAD, y se aplica al roscado electrónico (G33/G34) y los ciclos fijos de roscado del modelo -T-." ;
    ex:documentadoEn ex:Sistema_Se_alesConsultaCNC .

ex:Marca_COLLISIONACTIV
    a ex:ComponenteElectrico ;
    rdfs:label "COLLISIONACTIV" ;
    ex:identificador "COLLISIONACTIV" ;
    ex:textoExtracto "El CNC activa esta marca (cambio de 0 a 1) cuando la opción FCAS está activa. El CNC desactiva esta marca (cambio de 1 a 0) cuando la opción FCAS no está activa." ;
    ex:tieneComponente ex:Sistema_Se_alesConsultaCNC .

ex:Marca_COLLISIONACTIVC1
    a ex:ComponenteElectrico ;
    rdfs:label "COLLISIONACTIVC1" ;
    ex:identificador "COLLISIONACTIVC1" ;
    ex:textoExtracto "Marca de control de colisiones para el canal 1." ;
    ex:tieneComponente ex:Sistema_Se_alesConsultaCNC .

ex:Parametro_FCAS
    a ex:Parametro ;
    rdfs:label "FCAS" ;
    ex:identificador "FCAS" ;
    ex:textoExtracto "Opción de control de colisiones (FCAS) que activa/desactiva la marca COLLISIONACTIV." ;
    ex:documentadoEn ex:Sistema_Se_alesConsultaCNC .

ex:Parametro_VAMSTATUS
    a ex:Parametro ;
    rdfs:label "V.A.MSTATUS.xn" ;
    ex:identificador "V.A.MSTATUS.xn" ;
    ex:textoExtracto "Variable para consultar el estado de servos e inverters." ;
    ex:documentadoEn ex:Sistema_Se_alesConsultaCNC .

ex:Parametro_VAMSUBSTAT
    a ex:Parametro ;
    rdfs:label "V.A.MSUBSTAT.xn" ;
    ex:identificador "V.A.MSUBSTAT.xn" ;
    ex:textoExtracto "Variable para consultar el subestado de servos e inverters." ;
    ex:documentadoEn ex:Sistema_Se_alesConsultaCNC .

ex:Parametro_VAMALARM
    a ex:Parametro ;
    rdfs:label "V.A.MALARM.xn" ;
    ex:identificador "V.A.MALARM.xn" ;
    ex:textoExtracto "Variable para consultar alarmas de servos e inverters." ;
    ex:documentadoEn ex:Sistema_Se_alesConsultaCNC .

ex:Parametro_VAMIOMON
    a ex:Parametro ;
    rdfs:label "V.A.MIOMON.xn" ;
    ex:identificador "V.A.MIOMON.xn" ;
    ex:textoExtracto "Variable para monitorizar E/S de servos e inverters." ;
    ex:documentadoEn ex:Sistema_Se_alesConsultaCNC .

ex:AvisoSeguridad_Sobretemperatura
    a ex:AvisoSeguridad ;
    rdfs:label "Advertencia de sobretemperatura" ;
    ex:textoExtracto "restringir la operativa del CNC en caso de sobretemperatura. Si el PLC activa esta marca, existe riesgo de sobretemperatura y está en peligro la integridad del equipo. Apagar el equipo para evitar daños." ;
    ex:mitigaRiesgo ex:Sistema_Se_alesConsultaCNC .