@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarElMovimientoDeSincronizacionConLasCotasReales a ns1:Parametro ;
    rdfs:label "Activar el movimiento de sincronización con las cotas reales" ;
    ns1:identificador "FOLLOW ON" ;
    ns1:textoExtracto "FOLLOW ON (master, slave, <Nnratio>, <Ddratio>, synctype)" .

ns1:ActivarElMovimientoDeSincronizacionConLasCotasTeoricas a ns1:Parametro ;
    rdfs:label "Activar el movimiento de sincronización con las cotas teóricas" ;
    ns1:identificador "TFOLLOW ON" ;
    ns1:textoExtracto "TFOLLOW ON (master, slave, <Nnratio>, <Ddratio>, synctype)" .

ns1:CancelarElMovimientoDeSincronizacion a ns1:Parametro ;
    rdfs:label "Cancelar el movimiento de sincronización" ;
    ns1:identificador "FOLLOW OFF" ;
    ns1:textoExtracto "FOLLOW OFF (slave)" .

