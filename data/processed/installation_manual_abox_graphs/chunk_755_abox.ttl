@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ControlColisiones
    a ex:ModoOperacion ;
    rdfs:label "Control de colisiones"@es ;
    ex:textoExtracto "Para tener activo el control de colisiones, además de actuar sobre la marca COLLISIONOFF, debe estar cargado el esquema modelizado de la máquina (archivo xca) y deben estar seleccionados los gráficos HD."@es ;
    ex:identificador "COLLISIONOFF" .

ex:EsquemaModelizadoMaquina
    a ex:Esquema ;
    rdfs:label "Esquema modelizado de la máquina (archivo xca)"@es ;
    ex:textoExtracto "debe estar cargado el esquema modelizado de la máquina (archivo xca)"@es ;
    ex:identificador "xca" .

ex:GraficosHD
    a ex:InterfazUsuario ;
    rdfs:label "Gráficos HD"@es ;
    ex:textoExtracto "deben estar seleccionados los gráficos HD"@es .

ex:GraficosSTD
    a ex:InterfazUsuario ;
    rdfs:label "Gráficos estándar Fagor (STD)"@es ;
    ex:textoExtracto "El control de colisiones no estará activo si están seleccionados los gráficos STD (gráficos estándar Fagor)"@es .

ex:Parametro_DMCPWRPEAK
    a ex:Parametro ;
    rdfs:label "DMCPWRPEAK" ;
    ex:textoExtracto "DMCPWRPEAK. Hay una marca para cada canal."@es .

ex:Parametro_DMCPWRPEAKC1
    a ex:Parametro ;
    rdfs:label "DMCPWRPEAK Canal 1" ;
    ex:identificador "DMCPWRPEAKC1" ;
    ex:textoExtracto "DMCPWRPEAKC1" .

ex:Parametro_DMCPWRPEAKC2
    a ex:Parametro ;
    rdfs:label "DMCPWRPEAK Canal 2" ;
    ex:identificador "DMCPWRPEAKC2" ;
    ex:textoExtracto "DMCPWRPEAKC2" .

ex:Parametro_DMCPWRPEAKC3
    a ex:Parametro ;
    rdfs:label "DMCPWRPEAK Canal 3" ;
    ex:identificador "DMCPWRPEAKC3" ;
    ex:textoExtracto "DMCPWRPEAKC3" .

ex:Parametro_DMCPWRPEAKC4
    a ex:Parametro ;
    rdfs:label "DMCPWRPEAK Canal 4" ;
    ex:identificador "DMCPWRPEAKC4" ;
    ex:textoExtracto "DMCPWRPEAKC4" .

ex:ControlColisiones
    ex:habilitadoPor ex:EsquemaModelizadoMaquina ;
    ex:habilitadoPor ex:GraficosHD .

ex:ControlColisiones
    ex:monitoreaParametro ex:Parametro_DMCPWRPEAK ;
    ex:monitoreaParametro ex:Parametro_DMCPWRPEAKC1 ;
    ex:monitoreaParametro ex:Parametro_DMCPWRPEAKC2 ;
    ex:monitoreaParametro ex:Parametro_DMCPWRPEAKC3 ;
    ex:monitoreaParametro ex:Parametro_DMCPWRPEAKC4 .