ns1:TipoDeSincronizacion_52d74f42a0 a ns1:Parametro ;
    rdfs:label "Tipo de sincronización" ;
    ns1:textoExtracto "synctype | Tipo de sincronización. Se programa mediante los parámetros \"POS\" (sincronización en posición) o \"VEL\" (sincronización en velocidad)." .

