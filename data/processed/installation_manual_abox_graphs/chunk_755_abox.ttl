@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ControlColisiones a ex:Sistema ;
    rdfs:label "control de colisiones"@es ;
    ex:textoExtracto "Para tener activo el control de colisiones"@es .

ex:MarcaCollisionOff a ex:Componente ;
    rdfs:label "COLLISIONOFF"@es ;
    ex:textoExtracto "actuar sobre la marca COLLISIONOFF"@es .

ex:EsquemaModelizadoMaquina a ex:Esquema ;
    rdfs:label "esquema modelizado de la máquina (archivo xca)"@es ;
    ex:textoExtracto "debe estar cargado el esquema modelizado de la máquina (archivo xca)"@es .

ex:GraficosHD a ex:InterfazUsuario ;
    rdfs:label "gráficos HD"@es ;
    ex:textoExtracto "deben estar seleccionados los gráficos HD"@es .

ex:GraficosSTD a ex:InterfazUsuario ;
    rdfs:label "gráficos STD"@es ;
    ex:textoExtracto "gráficos estándar Fagor"@es .

ex:DMCPWRPEAK a ex:Parametro ;
    rdfs:label "DMCPWRPEAK"@es ;
    ex:textoExtracto "DMCPWRPEAK Hay una marca para cada canal"@es .

ex:DMCPWRPEAKC1 a ex:Parametro ;
    rdfs:label "DMCPWRPEAKC1"@es ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. DMCPWRPEAKC1"@es .

ex:DMCPWRPEAKC2 a ex:Parametro ;
    rdfs:label "DMCPWRPEAKC2"@es ;
    ex:textoExtracto "DMCPWRPEAKC2"@es .

ex:DMCPWRPEAKC3 a ex:Parametro ;
    rdfs:label "DMCPWRPEAKC3"@es ;
    ex:textoExtracto "DMCPWRPEAKC3"@es .

ex:DMCPWRPEAKC4 a ex:Parametro ;
    rdfs:label "DMCPWRPEAKC4"@es ;
    ex:textoExtracto "DMCPWRPEAKC4"@es .