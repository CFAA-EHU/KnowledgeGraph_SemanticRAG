@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AjusteFinoDelRatioDeTransmision a ns1:Parametro ;
    rdfs:label "Ajuste fino del ratio de transmisión" ;
    ns1:identificador "GEARADJ" ;
    ns1:textoExtracto "El ajuste fino del ratio se define con la variable GEARADJ." .

ns1:OffsetDePosicionDelEjeEsclavo a ns1:Parametro ;
    rdfs:label "Offset de posición del eje esclavo" ;
    ns1:identificador "V.A.SYNCPOSOFF.xn" ;
    ns1:textoExtracto "Se define con la variable V.A.SYNCPOSOFF.xn." .

ns1:OffsetDeVelocidadDelEjeEsclavo a ns1:Parametro ;
    rdfs:label "Offset de velocidad del eje esclavo" ;
    ns1:identificador "V.A.SYNCVELOFF.xn" ;
    ns1:textoExtracto "Se define con la variable V.A.SYNCVELOFF.xn." .

ns1:TipoDeSincronizacionEnPosicion a ns1:Parametro ;
    rdfs:label "Tipo de sincronización en posición" ;
    ns1:identificador "POS" ;
    ns1:textoExtracto "se programa mediante los parámetros \"POS\" (sincronización en posición)" .

ns1:TipoDeSincronizacionEnVelocidad a ns1:Parametro ;
    rdfs:label "Tipo de sincronización en velocidad" ;
    ns1:identificador "VEL" ;
    ns1:textoExtracto "se programa mediante los parámetros \"VEL\" (sincronización en velocidad)" .

