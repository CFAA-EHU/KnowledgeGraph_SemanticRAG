@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:DMCPWRPEAK a ex:Sensor ;
    rdfs:label "DMCPWRPEAK" ;
    ex:textoExtracto "los gráficos STD (gráficos estándar Fagor). DMCPWRPEAK Hay una marca para cada canal." .

ex:DMCPWRPEAKC1 a ex:Sensor ;
    rdfs:label "DMCPWRPEAKC1" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. DMCPWRPEAKC1 DMCPWRPEAKC2 DMCPWRPEAKC3 DMCPWRPEAKC4" .

ex:DMCPWRPEAKC2 a ex:Sensor ;
    rdfs:label "DMCPWRPEAKC2" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. DMCPWRPEAKC1 DMCPWRPEAKC2 DMCPWRPEAKC3 DMCPWRPEAKC4" .

ex:DMCPWRPEAKC3 a ex:Sensor ;
    rdfs:label "DMCPWRPEAKC3" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. DMCPWRPEAKC1 DMCPWRPEAKC2 DMCPWRPEAKC3 DMCPWRPEAKC4" .

ex:DMCPWRPEAKC4 a ex:Sensor ;
    rdfs:label "DMCPWRPEAKC4" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. DMCPWRPEAKC1 DMCPWRPEAKC2 DMCPWRPEAKC3 DMCPWRPEAKC4" .

ex:DMCPWRHOLD a ex:Sensor ;
    rdfs:label "DMCPWRHOLD" ;
    ex:textoExtracto "DMCPWRHOLD Hay una marca para cada canal." .

ex:DMCPWRHOLDC1 a ex:Sensor ;
    rdfs:label "DMCPWRHOLDC1" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. DMCPWRHOLDC1 DMCPWRHOLDC2 DMCPWRHOLDC3 DMCPWRHOLDC4" .

ex:DMCPWRHOLDC2 a ex:Sensor ;
    rdfs:label "DMCPWRHOLDC2" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. DMCPWRHOLDC1 DMCPWRHOLDC2 DMCPWRHOLDC3 DMCPWRHOLDC4" .

ex:DMCPWRHOLDC3 a ex:Sensor ;
    rdfs:label "DMCPWRHOLDC3" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. DMCPWRHOLDC1 DMCPWRHOLDC2 DMCPWRHOLDC3 DMCPWRHOLDC4" .

ex:DMCPWRHOLDC4 a ex:Sensor ;
    rdfs:label "DMCPWRHOLDC4" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. DMCPWRHOLDC1 DMCPWRHOLDC2 DMCPWRHOLDC3 DMCPWRHOLDC4" .

ex:ADVCUTOFF a ex:Sensor ;
    rdfs:label "ADVCUTOFF" ;
    ex:textoExtracto "ADVCUTOFF El CNC activa esta marca (cambio de 0 a 1) durante la ejecución de microjoints, cuando el láser alcanza la distancia G.ADVCUTOFFW o el tiempo G.ADVCUTOFFT antes del #CUTTING OFF." .

ex:G0 a ex:ModoOperacion ;
    rdfs:label "G0" ;
    ex:textoExtracto "El CNC desactiva esta marca (cambio de 1 a 0) al comenzar una G0 o al terminar la interpolación." .

ex:KINCOMP1 a ex:Sensor ;
    rdfs:label "KINCOMP1" ;
    ex:textoExtracto "KINCOMP1 KINCOMP6 El PLC activa esta marca cuando está activa la compensación de la cinemática (parámetro COMPID)." .

ex:KINCOMP6 a ex:Sensor ;
    rdfs:label "KINCOMP6" ;
    ex:textoExtracto "KINCOMP1 KINCOMP6 El PLC activa esta marca cuando está activa la compensación de la cinemática (parámetro COMPID)." .