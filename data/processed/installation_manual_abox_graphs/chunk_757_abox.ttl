@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:KINCOMP1 a ex:Parametro ;
    rdfs:label "KINCOMP1" ;
    ex:identificador "COMPID 1" ;
    ex:textoExtracto "KINCOMP1 está asociado a COMPID 1" .

ex:KINCOMP2 a ex:Parametro ;
    rdfs:label "KINCOMP2" ;
    ex:identificador "COMPID 2" ;
    ex:textoExtracto "KINCOMP2 a COMPID2" .

ex:KINCOMP3 a ex:Parametro ;
    rdfs:label "KINCOMP3" ;
    ex:identificador "COMPID 3" ;
    ex:textoExtracto "al activar esta cinemática, el PLC activa la marca KINCOMP3" .

ex:FWAITLIM a ex:Parametro ;
    rdfs:label "FWAITLIM" ;
    ex:textoExtracto "FWAITLIM El PLC activa esta marca cuando detiene la ejecución del programa por un #FOLLOW[WAITINLIMIT], para que la cota programada entre dentro de los límites (modelo láser)." .