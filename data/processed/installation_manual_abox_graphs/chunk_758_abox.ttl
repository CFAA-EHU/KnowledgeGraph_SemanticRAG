@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceDePalpador a ns1:Parametro ;
    rdfs:label "Avance de palpador" ;
    ns1:identificador "PROBEFEED" ;
    ns1:textoExtracto "Los siguientes parámetros máquina asociados al palpador no tienen efecto; PROBEAXIS, PROBERANGE, PROBEFEED, PRB1MIN, PRB2MIN, PRB3MIN, PRB1MAX, PRB2MAX y PRB3MAX." .

ns1:EjeDePalpador a ns1:Parametro ;
