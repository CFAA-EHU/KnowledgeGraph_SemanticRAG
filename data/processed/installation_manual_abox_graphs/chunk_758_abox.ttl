    rdfs:label "Entrada digital para latcheo de cota" ;
    ns1:identificador "PRBDI1" ;
    ns1:textoExtracto "Los eventos a utilizar serán las entradas digitales definidas en los parámetros PRBDI1 y PRBDI2." .

ns1:EntradaDigitalParaLatcheoDeCota_cfe72d3c8a a ns1:Parametro ;
