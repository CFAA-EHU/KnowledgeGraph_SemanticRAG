@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ENABLE_axis_759 a ex:Parametro ;
    rdfs:label "ENABLE(axis)" ;
    ex:textoExtracto "Si el PLC detiene el avance de los ejes (marca _FEEDHOL=0) la señal ENABLE(axis) se mantiene a (=1)" .

ex:REFPOIN_axis_759 a ex:Parametro ;
    rdfs:label "REFPOIN(axis)" ;
    ex:textoExtracto "El CNC activa esta marca (=1) cuando el eje o cabezal está referenciado. La marca REFPOIN(axis) siempre está activa (=1)" .

ex:ABSFEEDBACK_759 a ex:Parametro ;
    rdfs:label "ABSFEEDBACK" ;
    ex:textoExtracto "Captación absoluta total (parámetro ABSFEEDBACK=Sí)" .

ex:_FEEDHOL_759 a ex:Parametro ;
    rdfs:label "_FEEDHOL" ;
    ex:textoExtracto "marca _FEEDHOL=0" .