@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LimiteInferiorParaLaVentanaDelLatch a ns1:Parametro ;
    rdfs:label "Límite inferior para la ventana del latch" ;
    ns1:identificador "winminpos" ;
    ns1:textoExtracto "winminpos | Límite inferior para la ventana del latch." .

ns1:LimiteSuperiorParaLaVentanaDelLatch a ns1:Parametro ;
    rdfs:label "Límite superior para la ventana del latch" ;
    ns1:identificador "winmaxpos" ;
    ns1:textoExtracto "winmaxpos | Límite superior para la ventana del latch." .

ns1:NombreDelEjeObjetoDelLatcheo a ns1:Parametro ;
    rdfs:label "Nombre del eje objeto del latcheo" ;
    ns1:identificador "axis" ;
    ns1:textoExtracto "axis | Nombre del eje objeto del latcheo." .

ns1:NumeroDePalpadorAUtilizarComoEventoParaElLatcheo a ns1:Parametro ;
    rdfs:label "Número de palpador a utilizar como evento para el latcheo" ;
    ns1:identificador "probe" ;
    ns1:textoExtracto "probe | Número de palpador a utilizar como evento para el latcheo." .

ns1:TipoDeVentanaParaElLatcheo a ns1:Parametro ;
    rdfs:label "Tipo de ventana para el latcheo" ;
    ns1:identificador "wintype" ;
    ns1:textoExtracto "wintype | Tipo de ventana para el latcheo. Se programa mediante los comandos DISABLE (sin ventana), EXCLUSIVE (latch fuera de la ventana) e INCLUSIVE (latch dentro de la ventana)." .

