@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LatcheoDeCotasConUnPalpadorOEntradaDigital a ns1:TareaMantenimiento ;
    rdfs:label "Latcheo de cotas con un palpador o entrada digital" ;
    ns1:textoExtracto "Funcionamiento del latcheo de cotas." .

ns1:LimiteInferiorDeLaVentanaDeLatcheo a ns1:Parametro ;
    rdfs:label "Límite inferior de la ventana de latcheo" ;
    ns1:identificador "winminpos" ;
    ns1:textoExtracto "Los parámetros de llamada ꞏwinminposꞏ y ꞏwinmaxposꞏ establecen los límites inferior y superior de la ventana del latch." .

ns1:LimiteSuperiorDeLaVentanaDeLatcheo a ns1:Parametro ;
    rdfs:label "Límite superior de la ventana de latcheo" ;
    ns1:identificador "winmaxpos" ;
    ns1:textoExtracto "Los parámetros de llamada ꞏwinminposꞏ y ꞏwinmaxposꞏ establecen los límites inferior y superior de la ventana del latch." .

ns1:NumeroDePalpador1 a ns1:Parametro ;
    rdfs:label "Número de palpador 1" ;
    ns1:identificador "PRBDI1" ;
    ns1:textoExtracto "El palpador 1 será el asignado al parámetro PRBDI1." .

ns1:NumeroDePalpador2 a ns1:Parametro ;
    rdfs:label "Número de palpador 2" ;
    ns1:identificador "PRBDI2" ;
    ns1:textoExtracto "El palpador 2 será el asignado al parámetro PRBDI2." .

ns1:UsoDeCabezalesInactivosEnLatcheo a ns1:AccionProhibida ;
    rdfs:label "Uso de cabezales inactivos en latcheo" ;
    ns1:textoExtracto "Nombre del eje objeto del latcheo. Nombre del eje sobre el que se realiza el latcheo; no se admiten cabezales, excepto si están activos como eje C." .

