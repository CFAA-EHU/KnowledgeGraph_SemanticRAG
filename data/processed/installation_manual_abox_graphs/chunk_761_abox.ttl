@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Regulador_Seccion6_2
    a               ex:ComponenteElectrico ;
    rdfs:label      "Regulador de eje/cabezal" ;
    ex:textoExtracto "El regulador efectúa una comprobación interna. Si es correcta activa la salida System OK. [...] el regulador está funcionando correctamente."@es ;
    ex:monitoreaParametro ex:Parametro_DRSTAF, ex:Parametro_DRSTAS ;
    ex:tieneComponente  ex:Salida_SystemOK, ex:Entrada_DriveEnable, ex:Entrada_SpeedEnable .

ex:Salida_SystemOK
    a               ex:ComponenteElectrico ;
    rdfs:label      "Salida System OK" ;
    ex:textoExtracto "Si es correcta activa la salida System OK."@es .

ex:Entrada_DriveEnable
    a               ex:ComponenteElectrico ;
    rdfs:label      "Entrada Drive enable" ;
    ex:textoExtracto "activar las entradas Drive enable y Speed enable."@es .

ex:Entrada_SpeedEnable
    a               ex:ComponenteElectrico ;
    rdfs:label      "Entrada Speed enable" ;
    ex:textoExtracto "activar las entradas Drive enable y Speed enable."@es .

ex:Parametro_DRSTAF
    a               ex:Parametro ;
    ex:identificador "DRSTAF" ;
    ex:textoExtracto "Marcas DRSTAF(*)=0 [...] DRSTAF(*)=1"@es ;
    ex:valor         "0", "1" .

ex:Parametro_DRSTAS
    a               ex:Parametro ;
    ex:identificador "DRSTAS" ;
    ex:textoExtracto "Marcas DRSTAS(*)=1 [...] DRSTAS(*)=0"@es ;
    ex:valor         "0", "1" .