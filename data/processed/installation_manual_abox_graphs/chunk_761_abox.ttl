@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Regulador_761_1 a ex:ComponenteElectrico ;
    rdfs:label "regulador"@es ;
    ex:textoExtracto "El regulador efectúa una comprobación interna. Si es correcta activa la salida System OK. A partir de este momento suministrar potencia a la fuente."@es .

ex:System_OK_761_1 a ex:Sensor ;
    rdfs:label "System OK"@es ;
    ex:textoExtracto "activa la salida System OK"@es .

ex:Fuente_761_1 a ex:ComponenteElectrico ;
    rdfs:label "fuente"@es ;
    ex:textoExtracto "suministrar potencia a la fuente"@es .

ex:Drive_enable_761_1 a ex:Parametro ;
    rdfs:label "Drive enable"@es ;
    ex:textoExtracto "activar las entradas Drive enable y Speed enable"@es .

ex:Speed_enable_761_1 a ex:Parametro ;
    rdfs:label "Speed enable"@es ;
    rdfs:label "Speed enable"@en ;
    ex:textoExtracto "activar las entradas Drive enable y Speed enable"@es .