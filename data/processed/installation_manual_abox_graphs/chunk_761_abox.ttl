@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarSimultaneamenteLatcheoDeCotaYPalpadoProgramadoConG100 a ns1:AccionProhibida ;
    rdfs:label "Activar simultáneamente latcheo de cota y palpado programado con G100" ;
    ns1:textoExtracto "Para un mismo palpador no es posible tener activos simultáneamente un proceso de latcheo de cota y un proceso de palpado programado con G100, aunque sea en ejes distintos; si se ejecuta uno de ellos estando el otro activo, el CNC mostrará un error." .

ns1:ErrorAlIntentarLatcheoDeCotaConPalpadoG100Activo a ns1:Alarma ;
    rdfs:label "Error al intentar latcheo de cota con palpado G100 activo" ;
    ns1:textoExtracto "si se ejecuta uno de ellos estando el otro activo, el CNC mostrará un error." .

ns1:LimiteInferiorDeLaVentanaDelLatch a ns1:Parametro ;
    rdfs:label "Límite inferior de la ventana del latch" ;
    ns1:textoExtracto "Los parámetros de llamada ꞏwinminposꞏ y ꞏwinmaxposꞏ establecen los límites inferior y superior de la ventana del latch." .

ns1:LimiteSuperiorDeLaVentanaDelLatch a ns1:Parametro ;
    rdfs:label "Límite superior de la ventana del latch" ;
    ns1:textoExtracto "Los parámetros de llamada ꞏwinminposꞏ y ꞏwinmaxposꞏ establecen los límites inferior y superior de la ventana del latch." .

