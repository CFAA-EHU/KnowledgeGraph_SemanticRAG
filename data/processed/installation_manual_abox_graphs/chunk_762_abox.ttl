@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_fd7080393b a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de error del CNC" ;
    ns1:mitigaRiesgo ns1:LatcheoDeCotasConG100 ;
    ns1:textoExtracto "si se ejecuta uno de ellos estando el otro activo, el CNC mostrará un error." .

ns1:LatcheoDeCotasConG100 a ns1:AccionProhibida ;
    rdfs:label "Latcheo de cotas con G100" ;
    ns1:textoExtracto "de palpado programado con G100, aunque sea en ejes distintos; si se ejecuta uno de ellos estando el otro activo, el CNC mostrará un error." .

