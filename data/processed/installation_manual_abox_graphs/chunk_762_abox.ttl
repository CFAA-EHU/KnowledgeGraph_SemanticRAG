@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
ex:DriveEnable a ex:Parametro ;
    ex:textoExtracto "activar las entradas Drive enable y Speed enable" .

ex:SpeedEnable a ex:Parametro ;
    ex:textoExtracto "activar las entradas Drive enable y Speed enable" .

ex:DRSTAF a ex:Parametro ;
    ex:textoExtracto "Marcas DRSTAF(*)=1 DRSTAS(*)=0" .

ex:DRSTAS a ex:Parametro ;
    ex:textoExtracto "Marcas DRSTAF(*)=1 DRSTAS(*)=0" .

ex:INPOS a ex:Parametro ;
    ex:textoExtracto "INPOS(axis) El CNC pone esta marca a (=1) cuando el eje o cabezal correspondiente se encuentra en posición" .

ex:INPOSW a ex:Parametro ;
    ex:textoExtracto "INPOSW" .

ex:INPOTIME a ex:Parametro ;
    ex:textoExtracto "INPOTIME" .

ex:INPOSI a ex:Parametro ;
    ex:textoExtracto "INPOSI" .

ex:HIRTHON a ex:Parametro ;
    ex:textoExtracto "HIRTHON(axis) Esta marca está relacionada con ejes Hirth" .

ex:HIRTH a ex:Parametro ;
    ex:textoExtracto "El parámetro máquina HIRTH indica si el eje puede trabajar como eje Hirth" .

ex:ENABLE a ex:Parametro ;
    ex:textoExtracto "marca ENABLE(axis) desactivada" .

ex:Regulador a ex:ComponenteElectrico ;
    ex:textoExtracto "el regulador está funcionando correctamente" .

ex:BusDeContinua a ex:ComponenteElectrico ;
    ex:textoExtracto "No hay potencia en el bus de continua" .

ex:FuenteDeReguladores a ex:ComponenteElectrico ;
    ex:textoExtracto "se puede dar potencia a la fuente de los reguladores" .

ex:Eje a ex:ComponenteMecanico ;
    ex:textoExtracto "eje o cabezal correspondiente" .

ex:EjeHirth a ex:ComponenteMecanico ;
    ex:textoExtracto "eje Hirth" .

ex:CNC a ex:Sistema ;
    ex:textoExtracto "El CNC pone esta marca a (=1)" .