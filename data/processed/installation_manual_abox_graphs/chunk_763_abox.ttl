@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EjeHirth_763_1 a ex:ComponenteMecanico ;
    rdfs:label "eje Hirth" ;
    ex:textoExtracto "Podrán ser ejes Hirth tanto los ejes lineales como los rotativos." .

ex:ParametroMaquinaHIRTH_763_2 a ex:Parametro ;
    rdfs:label "parámetro máquina HIRTH" ;
    ex:textoExtracto "El parámetro máquina HIRTH indica si el eje puede trabajar como eje Hirth." .

ex:FuncionG170_763_3 a ex:ModoOperacion ;
    rdfs:label "función G170" ;
    ex:textoExtracto "Las funciones G170 y G171 indican si se desea que el eje trabaje como eje Hirth (G171, función por defecto) o como un eje rotativo o lineal normal (G170)." .

ex:FuncionG171_763_4 a ex:ModoOperacion ;
    rdfs:label "función G171" ;
    ex:textoExtracto "Las funciones G170 y G171 indican si se desea que el eje trabaje como eje Hirth (G171, función por defecto) o como un eje rotativo o lineal normal (G170)." .

ex:IndicadorMATCHaxis_763_5 a ex:Sensor ;
    rdfs:label "MATCH(axis)" ;
    ex:textoExtracto "La marca MATCH(axis) indica si el eje Hirth está bien" .