@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:G170 a ex:Parametro ;
    rdfs:label "G170" ;
    ex:textoExtracto "G170" ;
    ex:valor "eje rotativo o lineal normal" .

ex:G171 a ex:Parametro ;
    rdfs:label "G171" ;
    ex:textoExtracto "G171" ;
    ex:valor "eje Hirth (función por defecto)" .

ex:MATCH_axis a ex:Sensor ;
    rdfs:label "MATCH(axis)" ;
    ex:textoExtracto "La marca MATCH(axis) indica si el eje Hirth está bien posicionado (=1) o no (=0)" .

ex:LUBR_axis a ex:Sensor ;
    rdfs:label "LUBR(axis)" ;
    ex:textoExtracto "El CNC pone esta marca a (=1) cuando el eje o cabezal correspondiente debe ser engrasado. Ver en la página 449." .

ex:LUBRENA_axis a ex:Parametro ;
    rdfs:label "LUBRENA(axis)" ;
    ex:textoExtracto "LUBRENA(axis)" .

ex:LUBROK_axis a ex:Parametro ;
    rdfs:label "LUBROK(axis)" ;
    ex:textoExtracto "LUBROK(axis)" .

ex:DISTLUBRI a ex:Parametro ;
    rdfs:label "DISTLUBRI" ;
    ex:textoExtracto "El parámetro máquina DISTLUBRI indica la distancia que se debe mover antes de ser engrasado." .

ex:PARK_axis a ex:Sensor ;
    rdfs:label "PARK(axis)" ;
    ex:textoExtracto "El CNC pone la marca PARK(axis) a (=1) para indicar que se está aparcando un eje o cabezal" .

ex:UNPARK_axis a ex:Sensor ;
    rdfs:label "UNPARK(axis)" ;
    ex:textoExtracto "y la marca UNPARK(axis) a (=1) para indicar que se está desaparcando." .

ex:PARKED_axis a ex:Parametro ;
    rdfs:label "PARKED(axis)" ;
    ex:textoExtracto "También se emplea la marca PARKED(axis), que es modificable y está comentada más adelante. Ver en la página 449." .