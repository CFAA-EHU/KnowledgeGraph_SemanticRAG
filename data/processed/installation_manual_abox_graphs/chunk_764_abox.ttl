@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_fb6eb81d1d a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de Cancelación del Proceso de Latcheo" ;
    ns1:textoExtracto "Si el PLC activa la marca IRESET(axis), cancela el proceso de latcheo en el eje y el interpolador independiente desactiva la marca LATCH1ACTIVE(axis) o LATCH2ACTIVE(axis) asociada al proceso." .

ns1:InstruccionesDeLatcheoDeCotasConUnPalpadorOEntradaDigital a ns1:TareaMantenimiento ;
    rdfs:label "Instrucciones de latcheo de cotas con un palpador o entrada digital" ;
    ns1:textoExtracto "La instrucción TOUCHPROBE podrá activarse de forma simultánea para cualquiera de los 2 palpadores y para cualquiera de los ejes del sistema." .

ns1:Parametro_63f92aa3bb a ns1:Parametro ;
    rdfs:label "Parámetro PRBDI1" ;
    ns1:identificador "PRBDI1" ;
    ns1:textoExtracto "El palpador 1 será el asignado al parámetro PRBDI1." .

ns1:Parametro_986c2c4419 a ns1:Parametro ;
    rdfs:label "Marca LATCH1DONE" ;
    ns1:textoExtracto "El interpolador independiente sólo activará la marca LATCH1DONE(axis) del eje en el que se ha producido el evento." .

ns1:Parametro_a91eb53466 a ns1:Parametro ;
    rdfs:label "Parámetro PRBDI2" ;
    ns1:identificador "PRBDI2" ;
    ns1:textoExtracto "El palpador 2 será el asignado al parámetro PRBDI2." .

ns1:Parametro_e11eb5dfe7 a ns1:Parametro ;
    rdfs:label "Marca LATCH2DONE" ;
    ns1:textoExtracto "El interpolador independiente sólo activará la marca LATCH2DONE(axis) del eje en el que se ha producido el evento." .

ns1:SistemaInterpoladorIndependiente a ns1:Sistema ;
    rdfs:label "Sistema Interpolador Independiente" ;
    ns1:textoExtracto "El interpolador independiente dispone de una marca para cada palpador." .

