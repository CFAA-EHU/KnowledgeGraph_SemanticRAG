@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_2d4ed64193 a ns1:Parametro ;
    rdfs:label "Marca activada por el interpolador independiente durante un proceso de latcheo en el eje con el palpador 2" ;
    ns1:identificador "LATCH2ACTIVE(axis)" ;
    ns1:textoExtracto "El interpolador independiente activa esta marca al activar un proceso de latcheo en el eje con el palpador indicado; la desactiva cuando finaliza el proceso de latcheo o cuando se cancela el proceso." .

ns1:Parametro_521998d522 a ns1:Parametro ;
    rdfs:label "Marca que, si es activada por el PLC, cancela el proceso de latcheo en el eje" ;
    ns1:identificador "IRESET(axis)" ;
    ns1:textoExtracto "Si el PLC activa la marca IRESET(axis) se cancela el proceso de latcheo en el eje." .

ns1:Parametro_8837501e20 a ns1:Parametro ;
    rdfs:label "Marca activada por el interpolador independiente durante un proceso de latcheo en el eje con el palpador 1" ;
    ns1:identificador "LATCH1ACTIVE(axis)" ;
    ns1:textoExtracto "El interpolador independiente activa esta marca al activar un proceso de latcheo en el eje con el palpador indicado; la desactiva cuando finaliza el proceso de latcheo o cuando se cancela el proceso." .

ns1:Parametro_c3545c024b a ns1:Parametro ;
    rdfs:label "Marca activada por el interpolador independiente durante un proceso de latcheo con el palpador 2" ;
    ns1:identificador "PROBE2ACTIVE" ;
    ns1:textoExtracto "El interpolador independiente activa esta marca cuando hay algún proceso de latcheo activo con el palpador indicado y la desactiva cuando no hay ningún proceso de latcheo activo con el palpador indicado." .

ns1:Parametro_c71a35232b a ns1:Parametro ;
    rdfs:label "Marca activada por el interpolador independiente durante un proceso de latcheo con el palpador 1" ;
    ns1:identificador "PROBE1ACTIVE" ;
    ns1:textoExtracto "El interpolador independiente activa esta marca cuando hay algún proceso de latcheo activo con el palpador indicado y la desactiva cuando no hay ningún proceso de latcheo activo con el palpador indicado." .

