@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SistemaCNC a ex:Maquina ;
    ex:textoExtracto "El proceso de aparcar y desaparcar ejes se podrá realizar desde el CNC o desde el PLC." .

ex:SistemaPLC a ex:Maquina ;
    ex:textoExtracto "El proceso de aparcar y desaparcar ejes se podrá realizar desde el CNC o desde el PLC." .

ex:ConfiguracionEjesNormal a ex:ModoOperacion ;
    ex:textoExtracto "Con el cabezal normal, configuración de ejes X Y Z." .

ex:ConfiguracionEjesOrtogonal a ex:ModoOperacion ;
    ex:textoExtracto "Con el cabezal ortogonal, configuración de ejes X Y Z A B." .

ex:EjeX a ex:Componente ;
    ex:textoExtracto "configuración de ejes X Y Z" .

ex:EjeY a ex:Componente ;
    ex:textoExtracto "configuración de ejes X Y Z" .

ex:EjeZ a ex:Componente ;
    ex:textoExtracto "configuración de ejes X Y Z" .

ex:EjeA a ex:Componente ;
    ex:textoExtracto "configuración de ejes X Y Z A B" .

ex:EjeB a ex:Componente ;
    ex:textoExtracto "configuración de ejes X Y Z A B" .

ex:SistemaCaptacionEjes a ex:Sistema ;
    ex:textoExtracto "el CNC mostrará error porque los tiene en cuenta (reguladores, sistemas de captación, etc.)" .

ex:AccionAparcarEjes a ex:AccionProhibida ;
    ex:textoExtracto "El CNC no permitirá aparcar un eje en los siguientes casos." .