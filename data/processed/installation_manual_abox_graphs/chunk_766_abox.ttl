@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_767b904f4f a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Las funciones M02 y M30 no se darán por ejecutadas hasta que finalicen todos los procesos de latcheo activos en los ejes del canal." ;
    ns1:tieneComponente ns1:LATCH1DONEAxis,
        ns1:LATCH2DONEAxis,
        ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_c2cd3f5b4b .

ns1:LATCH1DONEAxis a ns1:Parametro ;
    rdfs:label "Marca de evento de latch" ;
    ns1:identificador "LATCH1DONE(axis)" ;
    ns1:textoExtracto "El interpolador independiente activa esta marca al producirse el evento de latch en el eje con el palpador indicado; la desactiva al activar un nuevo proceso de latch en el eje con el mismo palpador." .

ns1:LATCH2DONEAxis a ns1:Parametro ;
    rdfs:label "Marca de evento de latch" ;
    ns1:identificador "LATCH2DONE(axis)" ;
    ns1:textoExtracto "El interpolador independiente activa esta marca al producirse el evento de latch en el eje con el palpador indicado; la desactiva al activar un nuevo proceso de latch en el eje con el mismo palpador." .

ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_c2cd3f5b4b a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "A.LATCH1.xn" ;
    ns1:textoExtracto "( V.)[ch].A.LATCH1.xn Variable de lectura desde el programa, PLC e interfaz. Variable válida para ejes rotativos y lineales." .

