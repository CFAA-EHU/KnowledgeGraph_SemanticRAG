ns1:VariableDeLecturaDesdeElProgramaPLCEInterfaz_de459b6599 a ns1:Parametro ;
    rdfs:label "Variable de lectura desde el programa, PLC e interfaz" ;
    ns1:identificador "V.Ch.A.LATCH1.xn" ;
    ns1:monitoreaParametro ns1:Sensor_67344aba14,
        ns1:SistemaInterfazUsuario ;
    ns1:textoExtracto "V.)[ch].A.LATCH1.xn Variable de lectura desde el programa, PLC e interfaz. Variable válida para ejes rotativos y lineales." .

ns1:Sensor_67344aba14 a ns1:Sensor ;
    rdfs:label "Palpador 1" ;
    ns1:textoExtracto "Cota máquina obtenida del latcheo del palpador 1 en el eje ꞏxnꞏ." .

ns1:SistemaInterfazUsuario a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de usuario" ;
    ns1:textoExtracto "Variable válida para ejes rotativos y lineales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

