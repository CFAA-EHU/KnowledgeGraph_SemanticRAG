@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Senal_PARK
    a ex:InterfazUsuario ;
    rdfs:label "Señal PARK" ;
    ex:textoExtracto "El CNC utiliza las señales PARK y UNPARK para informar al PLC que se ha desencadenado el proceso correspondiente de aparcar o desaparcar." ;
    ex:monitoreaParametro ex:Parametro_Aparcado .

ex:Senal_UNPARK
    a ex:InterfazUsuario ;
    rdfs:label "Señal UNPARK" ;
    ex:textoExtracto "El CNC utiliza las señales PARK y UNPARK para informar al PLC que se ha desencadenado el proceso correspondiente de aparcar o desaparcar." ;
    ex:monitoreaParametro ex:Parametro_Desaparcado .

ex:Parametro_Aparcado
    a ex:Parametro ;
    rdfs:label "Estado aparcado" ;
    ex:valor "0" ;
    ex:textoExtracto "Para poder aparcar un eje o cabezal, sus señales de habilitación tienen que estar (=0)." .

ex:Parametro_Desaparcado
    a ex:Parametro ;
    rdfs:label "Estado desaparcado" ;
    ex:valor "1" ;
    ex:textoExtracto "tras desaparcar el eje las señales de habilitación del eje se deben poner a (=1)." .

ex:Sistema_ControlEjes
    a ex:Sistema ;
    rdfs:label "Sistema de control de ejes y cabezales" ;
    ex:textoExtracto "El CNC utiliza las señales PARK y UNPARK para informar al PLC que se ha desencadenado el proceso correspondiente de aparcar o desaparcar." ;
    ex:tieneComponente ex:Senal_PARK, ex:Senal_UNPARK ;
    ex:controla ex:Maquina_CNC .

ex:Maquina_CNC
    a ex:Maquina ;
    rdfs:label "CNC" ;
    ex:textoExtracto "El CNC utiliza las señales PARK y UNPARK para informar al PLC que se ha desencadenado el proceso correspondiente de aparcar o desaparcar." .