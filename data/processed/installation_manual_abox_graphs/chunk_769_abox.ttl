@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Sensor_PARKED ex:textoExtracto "Se resetean las señales UNPARK y REFPOIN. En el caso de ejes digitales el PLC activará la habilitación del regulador correspondiente al eje (DRENA)." ;
    a ex:Sensor ;
    rdfs:label "PARKED" .

ex:Sensor_UNPARK ex:textoExtracto "Se resetean las señales UNPARK y REFPOIN." ;
    a ex:Sensor ;
    rdfs:label "UNPARK" .

ex:Sensor_REFPOIN ex:textoExtracto "Se resetean las señales UNPARK y REFPOIN." ;
    a ex:Sensor ;
    rdfs:label "REFPOIN" .

ex:Sensor_DRENA ex:textoExtracto "el PLC activará la habilitación del regulador correspondiente al eje (DRENA)" ;
    a ex:Sensor ;
    rdfs:label "DRENA" .

ex:Sensor_PARKB ex:textoExtracto "La entrada I15 corresponde al sensor de presencia del eje \"B\" PARKB AND NOT I15 = SET PARKEDB" ;
    a ex:Sensor ;
    rdfs:label "PARKB" .

ex:Sensor_I15 ex:textoExtracto "La entrada I15 corresponde al sensor de presencia del eje \"B\"" ;
    a ex:Sensor ;
    rdfs:label "I15" .

ex:Sensor_PARKEDB ex:textoExtracto "Si hay una petición para aparcar el eje \"B\" (PARKB) y el eje no está presente (NOT I15), el eje está aparcado (SET PARKEDB)" ;
    a ex:Sensor ;
    rdfs:label "PARKEDB" .

ex:Sensor_UNPARKB ex:textoExtracto "Si hay una petición para desaparcar el eje \"B\" (UNPARKB) y el eje está presente (I15), el eje está desaparcado (RES PARKEDB)" ;
    a ex:Sensor ;
    rdfs:label "UNPARKB" .