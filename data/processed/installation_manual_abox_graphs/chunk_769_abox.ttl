@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:DistanciaRecorridaPorElEjeConIndice1EnElCanal2DesdeElUltimoLatcheoDeCota a ns1:Parametro ;
    rdfs:label "Distancia recorrida por el eje con índice 1 en el canal 2 desde el último latcheo de cota" ;
    ns1:identificador "V.[2].A.LATCH2.1" ;
    ns1:textoExtracto "Eje con índice ꞏ1ꞏ en el canal ꞏ2ꞏ." .

ns1:DistanciaRecorridaPorElEjeConNumeroLogico4DesdeElUltimoLatcheoDeCota a ns1:Parametro ;
    rdfs:label "Distancia recorrida por el eje con número lógico 4 desde el último latcheo de cota" ;
    ns1:identificador "V.A.LATCH2.4" ;
    ns1:textoExtracto "Eje con número lógico ꞏ4ꞏ." .

ns1:DistanciaRecorridaPorElEjeOCabezalDesdeElUltimoLatcheoDeCota a ns1:Parametro ;
    rdfs:label "Distancia recorrida por el eje o cabezal desde el último latcheo de cota" ;
    ns1:identificador "V.A.ACCUDIST.xn" ;
    ns1:textoExtracto "Variable válida para ejes rotativos, lineales y cabezales. La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

ns1:DistanciaRecorridaPorElEjeZDesdeElUltimoLatcheoDeCota a ns1:Parametro ;
    rdfs:label "Distancia recorrida por el eje Z desde el último latcheo de cota" ;
    ns1:identificador "V.A.LATCH2.Z" ;
    ns1:textoExtracto "Eje Z." .

