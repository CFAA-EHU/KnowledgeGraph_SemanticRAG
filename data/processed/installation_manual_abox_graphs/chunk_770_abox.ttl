@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:VariableDeLatcheoParaElEjeConIndice1EnElCanal2 a ns1:Parametro ;
    rdfs:label "Variable de latcheo para el eje con índice 1 en el canal 2" ;
    ns1:identificador "V.[2].MPA.ACCUDIST.1" ;
    ns1:textoExtracto "V.[2].MPA.ACCUDIST.1 | Eje con índice ꞏ1ꞏ en el canal ꞏ2ꞏ." .

ns1:VariableDeLatcheoParaElEjeConNumeroLogico4 a ns1:Parametro ;
    rdfs:label "Variable de latcheo para el eje con número lógico 4" ;
    ns1:identificador "V.MPA.ACCUDIST.4" ;
    ns1:textoExtracto "V.MPA.ACCUDIST.4 | Eje con número lógico ꞏ4ꞏ." .

ns1:VariableDeLatcheoParaElEjeZ a ns1:Parametro ;
    rdfs:label "Variable de latcheo para el eje Z" ;
    ns1:identificador "V.MPA.ACCUDIST.Z" ;
    ns1:textoExtracto "V.MPA.ACCUDIST.Z | Eje Z." .

ns1:VariableDeLecturaYEscrituraParaLaPosicionPreviaDelLatcheo a ns1:Parametro ;
    rdfs:label "Variable de lectura y escritura para la posición previa del latcheo" ;
    ns1:identificador "V.A.PREVACCUDIST.xn" ;
    ns1:textoExtracto "La variable devuelve el valor de ejecución; su lectura detiene la preparación de bloques." .

