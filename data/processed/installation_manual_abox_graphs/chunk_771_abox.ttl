@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PARKEDV a ex:Parametro ;
    ex:textoExtracto "PARKEDV" ;
    rdfs:label "PARKEDV" .

ex:UNPARKV a ex:Parametro ;
    ex:textoExtracto "UNPARKV" ;
    rdfs:label "UNPARKV" .

ex:PARKV a ex:Parametro ;
    ex:textoExtracto "PARKV" ;
    rdfs:label "PARKV" .

ex:DRENAV a ex:Parametro ;
    ex:textoExtracto "DRENAV" ;
    rdfs:label "DRENAV" .

ex:SPENAV a ex:Parametro ;
    ex:textoExtracto "SPENAV" ;
    rdfs:label "SPENAV" .

ex:SERVOVON a ex:Parametro ;
    ex:textoExtracto "SERVOVON" ;
    rdfs:label "SERVOVON" .

ex:FBACKSRC a ex:Parametro ;
    ex:textoExtracto "FBACKSRC" ;
    rdfs:label "FBACKSRC" .

ex:FBACKSEL_axis a ex:Parametro ;
    ex:textoExtracto "FBACKSEL(axis)" ;
    rdfs:label "FBACKSEL(axis)" .

ex:ACTFBACK a ex:Parametro ;
    ex:textoExtracto "ACTFBACK(axis)" ;
    rdfs:label "ACTFBACK(axis)" .

ex:PLC a ex:Sistema ;
    ex:textoExtracto "programa de PLC" ;
    rdfs:label "PLC" .

ex:CNC a ex:Sistema ;
    ex:textoExtracto "CNC" ;
    rdfs:label "CNC" .

ex:ReguladorEjeV a ex:ComponenteElectrico ;
    ex:textoExtracto "regulador correspondiente al eje" ;
    rdfs:label "Regulador del eje V" .

ex:SensorPresenciaEjeV a ex:Sensor ;
    ex:textoExtracto "Sensor de presencia del eje \"V\"" ;
    rdfs:label "Sensor de presencia del eje V" .