@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Se_al_PARKED
    a                   ex:Parametro ;
    rdfs:label          "Señal PARKED" ;
    ex:identificador    "PARKED" ;
    ex:textoExtracto    "Desde al programa de PLC se pone la marca PARKED a (=1) para aparcar el eje correspondiente." ;
    ex:valor            "1" .

ex:Se_al_PARK
    a                   ex:Parametro ;
    rdfs:label          "Señal PARK" ;
    ex:identificador    "PARK" ;
    ex:textoExtracto    "El CNC pone la marca PARK a (=1) y comienza a aparcar el eje." ;
    ex:valor            "1" .

ex:Se_al_UNPARK
    a                   ex:Parametro ;
    rdfs:label          "Señal UNPARK" ;
    ex:identificador    "UNPARK" ;
    ex:textoExtracto    "El CNC pone la marca UNPARK a (=1) y comienza a desaparcar el eje." ;
    ex:valor            "1" .

ex:Se_al_DRENAV
    a                   ex:Parametro ;
    rdfs:label          "Señal DRENA (habilitación regulador eje V)" ;
    ex:identificador    "DRENAV" ;
    ex:textoExtracto    "En el caso de ejes digitales el PLC debe quitar previamente la habilitación del regulador correspondiente al eje a aparcar (DRENA)." .

ex:Se_al_ACTFBACK
    a                   ex:Parametro ;
    rdfs:label          "Señal ACTFBACK" ;
    ex:identificador    "ACTFBACK(axis)" ;
    ex:textoExtracto    "El CNC utiliza esta marca cuando el sistema dispone de captación externa+interna. El CNC pone esta marca a (=1) para indicar que se está trabajando con la captación externa (captación directa)." ;
    ex:valor            "1" .

ex:Se_al_FBACKSEL
    a                   ex:Parametro ;
    rdfs:label          "Señal FBACKSEL" ;
    ex:identificador    "FBACKSEL(axis)" ;
    ex:textoExtracto    "El tipo de captación se podrá conmutar desde el PLC mediante la marca FBACKSEL(axis)." .

ex:Sensor_Presencia_EjeV
    a                   ex:Sensor ;
    rdfs:label          "Sensor de presencia del eje V" ;
    ex:identificador    "I10" ;
    ex:textoExtracto    "I10 = PARKEDV Eje presente. Sensor de presencia del eje 'V'." .

ex:Parametro_FBACKSRC
    a                   ex:Parametro ;
    rdfs:label          "Parámetro máquina FBACKSRC" ;
    ex:identificador    "FBACKSRC" ;
    ex:textoExtracto    "Consultar el parámetro máquina FBACKSRC." .

ex:Sistema_CaptacionExternaInterna
    a                   ex:Sistema ;
    rdfs:label          "Sistema de captación externa/interna" ;
    ex:textoExtracto    "El CNC utiliza esta marca cuando el sistema dispone de captación externa+interna." ;
    ex:compuestoPor     ex:Se_al_ACTFBACK, ex:Se_al_FBACKSEL .

ex:Tarea_AparcarEje
    a                   ex:TareaMantenimiento ;
    rdfs:label          "Tarea de aparcar eje" ;
    ex:textoExtracto    "Maniobra para aparcar un eje o cabezal desde el PLC." ;
    ex:requiereMantenimiento ex:Sensor_Presencia_EjeV ;
    ex:controla         ex:Se_al_PARK, ex:Se_al_PARKED, ex:Se_al_DRENAV .

ex:Tarea_DesaparcarEje
    a                   ex:TareaMantenimiento ;
    rdfs:label          "Tarea de desaparcar eje" ;
    ex:textoExtracto    "Maniobra para desaparcar un eje o cabezal desde el PLC." ;
    ex:requiereMantenimiento ex:Sensor_Presencia_EjeV ;
    ex:controla         ex:Se_al_UNPARK, ex:Se_al_PARKED, ex:Se_al_DRENAV .