@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
ex:FBACKSEL a ex:Parametro ;
    ex:textoExtracto "FBACKSEL(axis)" .

ex:TANGACT a ex:Parametro ;
    ex:textoExtracto "TANGACT(axis)" .

ex:LOPEN a ex:Parametro ;
    ex:textoExtracto "LOPEN(axis)" .

ex:marcaCNC a ex:Sensor ;
    ex:textoExtracto "El CNC pone esta marca a (=0) para indicar que se está trabajando con la captación interna (captación motor). El CNC pone esta marca a (=1) para indicar que el control tangencial se encuentra activo en el eje. El CNC pone esta marca a (=0) cuando se suspende (congela) o anula el control tangencial del eje." .

ex:captacionInterna a ex:ModoOperacion ;
    ex:textoExtracto "captación interna (captación motor)" .

ex:controlTangencial a ex:ModoOperacion ;
    ex:textoExtracto "control tangencial" .