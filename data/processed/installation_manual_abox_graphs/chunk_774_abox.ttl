@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Senal_REVOK a ex:Parametro ;
    rdfs:label "REVOK" ;
    ex:textoExtracto "Indica si las revoluciones reales del cabezal corresponden a las programadas (=1) o no (=0). Es decir, si se encuentran entre los porcentajes fijados por los parámetros máquina UPSPDLIM y LOSPDLIM." ;
    ex:identificador "REVOK1, REVOK2, REVOK3, REVOK4, REVOK5, REVOK6" ;
    ex:monitoreaParametro ex:Parametro_UPSPDLIM, ex:Parametro_LOSPDLIM .

ex:Senal_SYNCMASTER a ex:Parametro ;
    rdfs:label "SYNCMASTER" ;
    ex:textoExtracto "Esta marca se activa en el cabezal maestro e indica que ha comenzado una sincronización mediante la sentencia #SYNC." ;
    ex:identificador "SYNCMASTER1, SYNCMASTER2, SYNCMASTER3, SYNCMASTER4, SYNCMASTER5, SYNCMASTER6" .

ex:Senal_SYNCHRON a ex:Parametro ;
    rdfs:label "SYNCHRON" ;
    ex:textoExtracto "Hay una marca para cada cabezal." ;
    ex:identificador "SYNCHRON1, SYNCHRON2, SYNCHRON3, SYNCHRON4, SYNCHRON5, SYNCHRON6" .

ex:Parametro_UPSPDLIM a ex:Parametro ;
    rdfs:label "UPSPDLIM" ;
    ex:textoExtracto "porcentajes fijados por los parámetros máquina UPSPDLIM" .

ex:Parametro_LOSPDLIM a ex:Parametro ;
    rdfs:label "LOSPDLIM" ;
    ex:textoExtracto "porcentajes fijados por los parámetros máquina LOSPDLIM" .

ex:Senal_FeedHold a ex:AvisoSeguridad ;
    rdfs:label "Feed-hold" ;
    ex:textoExtracto "La señal REVOK se puede utilizar para gestionar la señal Feed-hold y evitar el mecanizado con revoluciones inferiores y superiores a las deseadas." ;
    ex:mitigaRiesgo ex:Senal_REVOK .

ex:Senal_SERVOON a ex:Parametro ;
    rdfs:label "SERVOON" ;
    ex:textoExtracto "se espera a la señal SERVOON (en el caso de tener DWELL)." .

ex:Senal_PLCCNTL a ex:Parametro ;
    rdfs:label "PLCCNTL" ;
    ex:textoExtracto "no se tienen en cuenta las señales PLCCNTL [...] durante el roscado" .

ex:Senal_INHIBIT a ex:Parametro ;
    rdfs:label "INHIBIT" ;
    ex:textoExtracto "no se tienen en cuenta las señales INHIBIT [...] durante el roscado" .

ex:Senal_SPDLEREV a ex:Parametro ;
    rdfs:label "SPDLEREV" ;
    ex:textoExtracto "no se tienen en cuenta las señales SPDLEREV [...] durante el roscado" .

ex:Senal_ENABLE a ex:Parametro ;
    rdfs:label "ENABLE" ;
    ex:textoExtracto "se activa la señal ENABLE en los dos cabezales" .