@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CotaDelCentroDeLaZonaSegunElPrimerEjeQueDefineLaZonaCircular a ns1:Parametro ;
    rdfs:label "Cota del centro de la zona según el primer eje que define la zona circular" ;
    ns1:identificador "G.ZONECIR1" ;
    ns1:textoExtracto "[ch].G.ZONECIR1[k] | Cota del centro de la zona [k], según el primer eje que define la zona circular." .

ns1:CotaDelCentroDeLaZonaSegunElSegundoEjeQueDefineLaZonaCircular a ns1:Parametro ;
    rdfs:label "Cota del centro de la zona según el segundo eje que define la zona circular" ;
    ns1:identificador "G.ZONECIR2" ;
    ns1:textoExtracto "[ch].G.ZONECIR2[k] | Cota del centro de la zona [k], según el segundo eje que define la zona circular." .

ns1:EjeLogicoCorrespondenteALaSegundaCotaDelCentroDeLaZona a ns1:Parametro ;
    rdfs:label "Eje lógico correspondente a la segunda cota del centro de la zona" ;
    ns1:identificador "G.ZONECIRAX2" ;
    ns1:textoExtracto "[ch].G.ZONECIRAX2[k] | Eje lógico correspondiente a la segunda cota del centro de la zona [k]." .

ns1:EjeLogicoCorrespondienteALaPrimeraCotaDelCentroDeLaZona a ns1:Parametro ;
    rdfs:label "Eje lógico correspondiente a la primera cota del centro de la zona" ;
    ns1:identificador "G.ZONECIRAX1" ;
    ns1:textoExtracto "[ch].G.ZONECIRAX1[k] | Eje lógico correspondiente a la primera cota del centro de la zona [k]." .

ns1:RadioDeLaZonaZonaCircular a ns1:Parametro ;
    rdfs:label "Radio de la zona (zona circular)" ;
    ns1:identificador "G.ZONER" ;
    ns1:textoExtracto "[ch].G.ZONER[k] | Radio de la zona [k] (zona circular)." .

ns1:VigilarLaPuntaOLaBaseDeLaHerramienta a ns1:Parametro ;
    rdfs:label "Vigilar la punta o la base de la herramienta" ;
    ns1:identificador "G.ZONETOOLWATCH" ;
    ns1:textoExtracto "[ch].G.ZONETOOLWATCH[k] | Vigilar la punta o la base de la herramienta. (0=Vigilar la punta de la herramienta). (1=Vigilar la base de la herramienta). (2=Vigilar tanto la punta como la base de la herramienta)." .

