@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SYNCHRON1 a ex:Sensor ;
    rdfs:label "SYNCHRON1" ;
    ex:textoExtracto "Los mnemónicos para cada cabezal son los siguientes. SYNCHRON1 SYNCHRON2 SYNCHRON3 SYNCHRON4 SYNCHRON5 SYNCHRON6" .

ex:SYNCHRON2 a ex:Sensor ;
    rdfs:label "SYNCHRON2" ;
    ex:textoExtracto "Los mnemónicos para cada cabezal son los siguientes. SYNCHRON1 SYNCHRON2 SYNCHRON3 SYNCHRON4 SYNCHRON5 SYNCHRON6" .

ex:SYNCHRON3 a ex:Sensor ;
    rdfs:label "SYNCHRON3" ;
    ex:textoExtracto "Los mnemónicos para cada cabezal son los siguientes. SYNCHRON1 SYNCHRON2 SYNCHRON3 SYNCHRON4 SYNCHRON5 SYNCHRON6" .

ex:SYNCHRON4 a ex:Sensor ;
    rdfs:label "SYNCHRON4" ;
    ex:textoExtracto "Los mnemónicos para cada cabezal son los siguientes. SYNCHRON1 SYNCHRON2 SYNCHRON3 SYNCHRON4 SYNCHRON5 SYNCHRON6" .

ex:SYNCHRON5 a ex:Sensor ;
    rdfs:label "SYNCHRON5" ;
    ex:textoExtracto "Los mnemónicos para cada cabezal son los siguientes. SYNCHRON1 SYNCHRON2 SYNCHRON3 SYNCHRON4 SYNCHRON5 SYNCHRON6" .

ex:SYNCHRON6 a ex:Sensor ;
    rdfs:label "SYNCHRON6" ;
    ex:textoExtracto "Los mnemónicos para cada cabezal son los siguientes. SYNCHRON1 SYNCHRON2 SYNCHRON3 SYNCHRON4 SYNCHRON5 SYNCHRON6" .

ex:senalReferenciaCabezalPrincipal a ex:Sensor ;
    rdfs:label "señal de referencia del cabezal principal" ;
    ex:textoExtracto "durante el roscado, sólo se tiene en cuenta el contaje y la señal de referencia del cabezal principal" .

ex:senalENABLE a ex:Sensor ;
    rdfs:label "ENABLE" ;
    ex:textoExtracto "Cuando se activa una sincronización, se activa la señal ENABLE en los dos cabezales" .

ex:senalSERVOON a ex:Sensor ;
    rdfs:label "SERVOON" ;
    ex:textoExtracto "se espera a la señal SERVOON (en el caso de tener DWELL)" .

ex:senalSYNC a ex:Sensor ;
    rdfs:label "#SYNC" ;
    ex:textoExtracto "Esta marca se activa en el cabezal esclavo e indica que ha comenzado una sincronización mediante la sentencia #SYNC" .