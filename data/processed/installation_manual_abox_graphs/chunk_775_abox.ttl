@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SistemaSincronizacionCabezales
    a ex:Sistema ;
    rdfs:label "Sistema de sincronización de cabezales" ;
    ex:textoExtracto "SYNCHRON Hay una marca para cada cabezal. Los mnemónicos para cada cabezal son los siguientes. SYNCHRON1 SYNCHRON2 SYNCHRON3 SYNCHRON4 SYNCHRON5 SYNCHRON6 Esta marca se activa en el cabezal esclavo e indica que ha comenzado una sincronización mediante la sentencia #SYNC." ;
    ex:identificador "SYNCHRON" .

ex:SenalSYNC
    a ex:ComponenteElectrico ;
    rdfs:label "Señal SYNC" ;
    ex:textoExtracto "Esta marca se activa en el cabezal esclavo e indica que ha comenzado una sincronización mediante la sentencia #SYNC." ;
    ex:tieneComponente ex:SistemaSincronizacionCabezales .

ex:SenalENABLE
    a ex:ComponenteElectrico ;
    rdfs:label "Señal ENABLE" ;
    ex:textoExtracto "Cuando se activa una sincronización, se activa la señal ENABLE en los dos cabezales" ;
    ex:tieneComponente ex:SistemaSincronizacionCabezales .

ex:SenalSERVOON
    a ex:ComponenteElectrico ;
    rdfs:label "Señal SERVOON" ;
    ex:textoExtracto "se espera a la señal SERVOON (en el caso de tener DWELL)" ;
    ex:tieneComponente ex:SistemaSincronizacionCabezales .