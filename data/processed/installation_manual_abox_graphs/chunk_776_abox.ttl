@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SincronizacionCabezales
    a ex:ModoOperacion ;
    rdfs:label "Sincronización de cabezales" ;
    ex:textoExtracto "Cuando se activa una sincronización, se activa la señal ENABLE en los dos cabezales y se espera a la señal SERVOON (en el caso de tener DWELL). Cuando está activa una sincronización de cabezales, no se tienen en cuenta las señales PLCCNTL, INHIBIT y SPDLEREV ni del cabezal maestro ni del esclavo." .

ex:SenalENABLE
    a ex:ComponenteElectrico ;
    rdfs:label "Señal ENABLE" ;
    ex:textoExtracto "se activa la señal ENABLE en los dos cabezales" ;
    ex:monitoreaParametro ex:ParametroSincronizacionActiva .

ex:SenalSERVOON
    a ex:ComponenteElectrico ;
    rdfs:label "Señal SERVOON" ;
    ex:textoExtracto "se espera a la señal SERVOON (en el caso de tener DWELL)" .

ex:SenalPLCCNTL
    a ex:ComponenteElectrico ;
    rdfs:label "Señal PLCCNTL" ;
    ex:textoExtracto "no se tienen en cuenta las señales PLCCNTL [...] ni del cabezal maestro ni del esclavo" .

ex:SenalINHIBIT
    a ex:ComponenteElectrico ;
    rdfs:label "Señal INHIBIT" ;
    ex:textoExtracto "no se tienen en cuenta las señales [...] INHIBIT [...] ni del cabezal maestro ni del esclavo" .

ex:SenalSPDLEREV
    a ex:ComponenteElectrico ;
    rdfs:label "Señal SPDLEREV" ;
    ex:textoExtracto "no se tienen en cuenta las señales [...] SPDLEREV ni del cabezal maestro ni del esclavo" .

ex:ParametroSincronizacionActiva
    a ex:Parametro ;
    rdfs:label "Estado de sincronización activa" ;
    ex:textoExtracto "Cuando está activa una sincronización de cabezales" .

ex:ParametroDSYNCVELW
    a ex:Parametro ;
    rdfs:label "DSYNCVELW" ;
    ex:identificador "DSYNCVELW" ;
    ex:textoExtracto "máximo error en velocidad permitido, cuyo valor por defecto se define en el parámetro máquina DSYNCVELW" ;
    ex:valor "valor por defecto (no especificado)" .

ex:ParametroDSYNCPOSW
    a ex:Parametro ;
    rdfs:label "DSYNCPOSW" ;
    ex:identificador "DSYNCPOSW" ;
    ex:textoExtracto "máximo error en posición permitido, cuyo valor por defecto se define en el parámetro máquina DSYNCPOSW" ;
    ex:valor "valor por defecto (no especificado)" .

ex:MarcaSYNCRONP
    a ex:ComponenteElectrico ;
    rdfs:label "Marca SYNCRONP (sincronización en posición)" ;
    ex:textoExtracto "SYNCRONP [...] Esta marca se activa en el cabezal esclavo e indica que ha comenzado una sincronización en posición. Esta marca permite distinguir entre una sincronización en posición o en velocidad" .

ex:MarcaSYNSPEED
    a ex:ComponenteElectrico ;
    rdfs:label "Marca SYNSPEED (sincronización en velocidad)" ;
    ex:textoExtracto "SYNSPEED [...] Esta marca se activa en el cabezal esclavo cuando está sincronizado en velocidad. Esta marca se pone a (=0) si se supera el máximo error en velocidad permitido" ;
    ex:monitoreaParametro ex:ParametroDSYNCVELW .

ex:MarcaSYNCPOSI
    a ex:ComponenteElectrico ;
    rdfs:label "Marca SYNCPOSI (sincronización en posición)" ;
    ex:textoExtracto "SYNCPOSI [...] Esta marca se activa en el cabezal esclavo cuando está sincronizado en posición. Esta marca se pone a (=0) si se supera el máximo error en posición permitido" ;
    ex:monitoreaParametro ex:ParametroDSYNCPOSW .

ex:MarcaGEAROK
    a ex:ComponenteElectrico ;
    rdfs:label "Marca GEAROK" ;
    ex:textoExtracto "GEAROK [...] Hay una marca para cada cabezal" .

ex:SincronizacionCabezales
    ex:tieneComponente ex:SenalENABLE, ex:SenalSERVOON, ex:SenalPLCCNTL, ex:SenalINHIBIT, ex:SenalSPDLEREV ;
    ex:controla ex:MarcaSYNCRONP, ex:MarcaSYNSPEED, ex:MarcaSYNCPOSI, ex:MarcaGEAROK .