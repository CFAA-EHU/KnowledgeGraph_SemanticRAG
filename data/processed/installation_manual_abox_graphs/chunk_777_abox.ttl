@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:DSYNCPOSW a ex:Parametro ;
    rdfs:label "DSYNCPOSW" ;
    ex:textoExtracto "cuyo valor por defecto se define en el parámetro máquina DSYNCPOSW" .

ex:M41 a ex:ModoOperacion ;
    rdfs:label "M41" ;
    ex:textoExtracto "deberá estar activa la función M41 en el CNC" .

ex:GEAR1 a ex:ModoOperacion ;
    rdfs:label "GEAR1" ;
    ex:textoExtracto "y la marca GEAR1" .

ex:CNC a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "el set de parámetros seleccionado en el CNC y en el PLC coinciden" .

ex:PLC a ex:Sistema ;
    rdfs:label "PLC" ;
    ex:textoExtracto "el set de parámetros seleccionado en el CNC y en el PLC coinciden" .

ex:GEAROK1 a ex:Parametro ;
    rdfs:label "GEAROK1" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. GEAROK1 (también se puede programar como GEAROK)" .

ex:GEAROK2 a ex:Parametro ;
    rdfs:label "GEAROK2" ;
    ex:textoExtracto "GEAROK2" .

ex:GEAROK3 a ex:Parametro ;
    rdfs:label "GEAROK3" ;
    ex:textoExtracto "GEAROK3" .

ex:GEAROK4 a ex:Parametro ;
    rdfs:label "GEAROK4" ;
    ex:textoExtracto "GEAROK4" .

ex:GEAROK5 a ex:Parametro ;
    rdfs:label "GEAROK5" ;
    ex:textoExtracto "GEAROK5" .

ex:GEAROK6 a ex:Parametro ;
    rdfs:label "GEAROK6" ;
    ex:textoExtracto "GEAROK6" .

ex:cabezal a ex:ComponenteMecanico ;
    rdfs:label "cabezal" ;
    ex:textoExtracto "Hay una marca para cada cabezal" ;
    ex:monitoreaParametro ex:DSYNCPOSW ;
    ex:controla ex:GEAROK1, ex:GEAROK2, ex:GEAROK3, ex:GEAROK4, ex:GEAROK5, ex:GEAROK6 ;
    ex:ejecutadoPor ex:CNC, ex:PLC .