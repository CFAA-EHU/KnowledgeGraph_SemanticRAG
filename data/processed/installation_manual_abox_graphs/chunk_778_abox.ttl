@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:M41 a ex:ModoOperacion ;
    rdfs:label "M41" ;
    ex:textoExtracto "activa esta marca cuando el set de parámetros seleccionado en el CNC y en el PLC coinciden" .

ex:GEAR1 a ex:ModoOperacion ;
    rdfs:label "GEAR1" ;
    ex:textoExtracto "deberá estar activa la función M41 en el CNC y la marca GEAR1 en el PLC" .

ex:M42 a ex:ModoOperacion ;
    rdfs:label "M42" ;
    ex:textoExtracto "M42 con GEAR2 y así sucesivamente" .

ex:GEAR2 a ex:ModoOperacion ;
    rdfs:label "GEAR2" ;
    ex:textoExtracto "M42 con GEAR2 y así sucesivamente" .

ex:Parametro a ex:Parametro ;
    ex:textoExtracto "set de parámetros seleccionado en el CNC y en el PLC" .

ex:AccionProhibida a ex:AccionProhibida ;
    rdfs:label "detener el cabezal" ;
    ex:textoExtracto "como detener el cabezal o la ejecución del programa pieza" .

ex:AccionProhibida a ex:AccionProhibida ;
    rdfs:label "ejecución del programa pieza" ;
    ex:textoExtracto "como detener el cabezal o la ejecución del programa pieza" .