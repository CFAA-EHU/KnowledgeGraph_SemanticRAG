@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Se_alCoincidenciaParametrosCNC_PLC
    a                     ex:Sensor ;
    rdfs:label            "Señal de coincidencia de parámetros CNC-PLC"@es ;
    ex:textoExtracto       "activa esta marca cuando el set de parámetros seleccionado en el CNC y en el PLC coinciden. Para que ambos sets de parámetros coincidan, deberá estar activa la función M41 en el CNC y la marca GEAR1 en el PLC, M42 con GEAR2 y así sucesivamente."@es ;
    ex:monitoreaParametro ex:ParametroSetCNC ,
                         ex:ParametroSetPLC .

ex:ParametroSetCNC
    a               ex:Parametro ;
    rdfs:label      "Set de parámetros CNC (M41, M42, ...)"@es ;
    ex:textoExtracto "el set de parámetros seleccionado en el CNC [...] función M41 en el CNC y la marca GEAR1 en el PLC, M42 con GEAR2"@es ;
    ex:identificador "M41; M42; ..." .

ex:ParametroSetPLC
    a               ex:Parametro ;
    rdfs:label      "Set de parámetros PLC (GEAR1, GEAR2, ...)"@es ;
    ex:textoExtracto "la marca GEAR1 en el PLC, M42 con GEAR2"@es ;
    ex:identificador "GEAR1; GEAR2; ..." .

ex:AccionDetencionCabezal
    a               ex:AccionProhibida ;
    rdfs:label      "Detención del cabezal por desajuste de parámetros"@es ;
    ex:textoExtracto "definir las acciones a realizar cuando ambos set de parámetros no coincidan, como detener el cabezal o la ejecución del programa pieza."@es .

ex:Se_alCoincidenciaParametrosCNC_PLC
    ex:activaAlarma ex:AccionDetencionCabezal .