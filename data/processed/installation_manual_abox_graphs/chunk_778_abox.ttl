@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConsultasSobreValoresImagen a ns1:Parametro ;
    rdfs:label "Consultas sobre valores imagen" ;
    ns1:textoExtracto "IMA Las consultas se realizarán sobre los valores imagen." .

ns1:ConsultasSobreValoresReales a ns1:Parametro ;
    rdfs:label "Consultas sobre valores reales" ;
    ns1:textoExtracto "REA Las consultas se realizarán sobre los valores reales." .

ns1:DefinicionDeSimbolo a ns1:Parametro ;
    rdfs:label "Definición de símbolo" ;
    ns1:textoExtracto "DEF Definición de símbolo." .

ns1:DefinicionDeSimboloExterno a ns1:Parametro ;
    rdfs:label "Definición de símbolo externo" ;
    ns1:textoExtracto "PDEF Definición de símbolo externo." .

ns1:DefinicionDeSubrutina a ns1:Parametro ;
    rdfs:label "Definición de subrutina" ;
    ns1:textoExtracto "SUB Definición de subrutina." .

ns1:DefinicionDeSubrutinaExterna a ns1:Parametro ;
    rdfs:label "Definición de subrutina externa" ;
    ns1:textoExtracto "EXTERN Definición de subrutina externa." .

ns1:FinalDeModulo a ns1:Parametro ;
    rdfs:label "Final de módulo" ;
    ns1:textoExtracto "END Final de módulo." .

ns1:ModuloDePrimerCiclo a ns1:Parametro ;
    rdfs:label "Módulo de primer ciclo" ;
    ns1:textoExtracto "CY1 Módulo de primer ciclo." .

ns1:ModuloPeriodico a ns1:Parametro ;
    rdfs:label "Módulo periódico" ;
    ns1:textoExtracto "PE t Módulo periódico. Se ejecuta cada t milisegundos." .

ns1:ModuloPrincipal a ns1:Parametro ;
    rdfs:label "Módulo principal" ;
    ns1:textoExtracto "Proposiciones directivas. PRG Módulo principal." .

ns1:NoMonitorizarElProgramaPLC a ns1:Parametro ;
    rdfs:label "No monitorizar el programa PLC" ;
    ns1:textoExtracto "NOMONIT No monitorizar el programa PLC." .

ns1:ResumenDeLosComandosDeProgramacion a ns1:TareaMantenimiento ;
    rdfs:label "Resumen de los comandos de programación" ;
    ns1:textoExtracto "Proposiciones directivas. PRG Módulo principal. PE t Módulo periódico. Se ejecuta cada t milisegundos. CY1 Módulo de primer ciclo. END Final de módulo." .

