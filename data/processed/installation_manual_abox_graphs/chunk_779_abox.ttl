@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Se_al_IBUSY
    a ex:Parametro ;
    rdfs:label "IBUSY(axis)" ;
    ex:textoExtracto "Para los movimientos de eje independiente, el interpolador del eje activa esta marca cuando tiene alguna sentencia pendiente de ejecución." ;
    ex:monitoreaParametro ex:InterpoladorEjeIndependiente .

ex:Se_al_IFREE
    a ex:Parametro ;
    rdfs:label "IFREE(axis)" ;
    ex:textoExtracto "Para los movimientos de eje independiente, el interpolador del eje activa esta marca cuando está listo para aceptar un nuevo bloque de movimiento." ;
    ex:monitoreaParametro ex:InterpoladorEjeIndependiente .

ex:Se_al_IFHOUT
    a ex:Parametro ;
    rdfs:label "IFHOUT(axis)" ;
    ex:textoExtracto "Para los movimientos de eje independiente, el interpolador del eje activa esta marca cuando la ejecución está detenida." ;
    ex:monitoreaParametro ex:InterpoladorEjeIndependiente .

ex:Se_al_IEND
    a ex:Parametro ;
    rdfs:label "IEND(axis)" ;
    ex:textoExtracto "Para los movimientos de eje independiente, el interpolador del eje activa esta marca cuando termina de generar el movimiento teórico." ;
    ex:monitoreaParametro ex:InterpoladorEjeIndependiente .

ex:Se_al_INSYNC
    a ex:Parametro ;
    rdfs:label "INSYNC(axis)" ;
    ex:textoExtracto "Para los movimientos de sincronización de eje independiente y leva electrónica, el interpolador del eje activa esta marca cuando se ha alcanzado la sincronización." ;
    ex:monitoreaParametro ex:InterpoladorEjeIndependiente .

ex:Se_al_PROBE1ACTIVE
    a ex:Parametro ;
    rdfs:label "PROBE1ACTIVE" ;
    ex:textoExtracto "Se aplica al proceso de latcheo de la cota de un eje. [...] El interpolador independiente activa esta marca cuando hay algún proceso de latcheo activo con el palpador 1." ;
    ex:monitoreaParametro ex:InterpoladorEjeIndependiente .

ex:Se_al_PROBE2ACTIVE
    a ex:Parametro ;
    rdfs:label "PROBE2ACTIVE" ;
    ex:textoExtracto "Se aplica al proceso de latcheo de la cota de un eje. [...] El interpolador independiente activa esta marca cuando hay algún proceso de latcheo activo con el palpador 2." ;
    ex:monitoreaParametro ex:InterpoladorEjeIndependiente .

ex:Se_al_LATCH1ACTIVE
    a ex:Parametro ;
    rdfs:label "LATCH1ACTIVE(axis)" ;
    ex:textoExtracto "Se aplica al proceso de latcheo de la cota de un eje. [...] El interpolador independiente activa esta marca al activar un proceso de latcheo en el eje con el palpador 1." ;
    ex:monitoreaParametro ex:InterpoladorEjeIndependiente .

ex:Se_al_LATCH2ACTIVE
    a ex:Parametro ;
    rdfs:label "LATCH2ACTIVE(axis)" ;
    ex:textoExtracto "Se aplica al proceso de latcheo de la cota de un eje. [...] El interpolador independiente activa esta marca al activar un proceso de latcheo en el eje con el palpador 2." ;
    ex:monitoreaParametro ex:InterpoladorEjeIndependiente .

ex:InterpoladorEjeIndependiente
    a ex:Sistema ;
    rdfs:label "Interpolador de eje independiente" ;
    ex:textoExtracto "El interpolador del eje activa esta marca cuando tiene alguna sentencia pendiente de ejecución [...] El interpolador independiente activa esta marca cuando hay algún proceso de latcheo activo con el palpador indicado." .

ex:Parametro_PRBDI1
    a ex:Parametro ;
    rdfs:label "PRBDI1" ;
    ex:textoExtracto "El palpador 1 será el asignado al parámetro PRBDI1." .

ex:Parametro_PRBDI2
    a ex:Parametro ;
    rdfs:label "PRBDI2" ;
    ex:textoExtracto "El palpador 2 será el asignado al parámetro PRBDI2." .