@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:InterpoladorIndependiente_780_426 a ex:Sistema ;
    rdfs:label "Interpolador independiente"@es ;
    ex:textoExtracto "El interpolador independiente activa esta marca al activar un proceso de latcheo en el eje con el palpador indicado; la desactiva cuando finaliza el proceso de latcheo o cuando se cancela el proceso."@es ;
    ex:tieneComponente ex:MarcaActivacion_780_426 ;
    ex:tieneComponente ex:ProcesoLatcheo_780_426 ;
    ex:tieneComponente ex:EjeConPalpador_780_426 .

ex:MarcaActivacion_780_426 a ex:Sensor ;
    rdfs:label "marca de activación"@es ;
    ex:textoExtracto "esta marca"@es .

ex:ProcesoLatcheo_780_426 a ex:AccionProhibida ;
    rdfs:label "proceso de latcheo"@es ;
    ex:textoExtracto "proceso de latcheo"@es .

ex:EjeConPalpador_780_426 a ex:ComponenteMecanico ;
    rdfs:label "eje con palpador"@es ;
    ex:textoExtracto "eje con el palpador indicado"@es .