@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:LATCH1DONE a ex:Parametro ;
    rdfs:label "LATCH1DONE(axis)" ;
    ex:textoExtracto "LATCH1DONE(axis) Se aplica al proceso de latcheo de la cota de un eje." .

ex:LATCH2DONE a ex:Parametro ;
    rdfs:label "LATCH2DONE(axis)" ;
    ex:textoExtracto "LATCH2DONE(axis) Se aplica al proceso de latcheo de la cota de un eje." .

ex:PRBDI1 a ex:Parametro ;
    rdfs:label "PRBDI1" ;
    ex:textoExtracto "el palpador 1 será el asignado al parámetro PRBDI1" .

ex:PRBDI2 a ex:Parametro ;
    rdfs:label "PRBDI2" ;
    ex:textoExtracto "el palpador 2 será el asignado al parámetro PRBDI2" .

ex:IRESET a ex:Parametro ;
    rdfs:label "IRESET(axis)" ;
    ex:textoExtracto "Si el PLC activa la marca IRESET(axis) se cancela el proceso de latcheo en el eje." .

ex:FOLLOW a ex:Parametro ;
    rdfs:label "FOLLOW(axis)" ;
    ex:textoExtracto "FOLLOW(axis) Para los movimientos de eje independiente, el interpolador del eje activa esta marca cuando está activa la sincronización en el eje (#FOLLOW)." .

ex:MOVCMD a ex:Parametro ;
    rdfs:label "MOVCMD(axis)" ;
    ex:textoExtracto "MOVCMD(axis) Para los movimientos de eje independiente, el interpolador del eje activa esta marca cuando está ejecutando un posicionamiento (#MOVE)." .