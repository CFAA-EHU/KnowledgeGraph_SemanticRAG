@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ProcesoLatcheoEje
    a ex:ModoOperacion ;
    rdfs:label "Proceso de latcheo en eje" ;
    ex:textoExtracto "activa esta marca al activar un proceso de latcheo en el eje con el palpador indicado; la desactiva cuando finaliza el proceso de latcheo o cuando se cancela el proceso." .

ex:Marca_IRESET
    a ex:Parametro ;
    rdfs:label "IRESET(axis)" ;
    ex:textoExtracto "Si el PLC activa la marca IRESET(axis) se cancela el proceso de latcheo en el eje." ;
    ex:monitoreaParametro ex:ProcesoLatcheoEje .

ex:Marca_LATCH1DONE
    a ex:Parametro ;
    rdfs:label "LATCH1DONE(axis)" ;
    ex:textoExtracto "LATCH1DONE(axis) [...] El interpolador independiente activa esta marca al producirse el evento de latch en el eje con el palpador indicado; la desactiva al activar un nuevo proceso de latch en el eje con el mismo palpador." ;
    ex:monitoreaParametro ex:ProcesoLatcheoEje .

ex:Marca_LATCH2DONE
    a ex:Parametro ;
    rdfs:label "LATCH2DONE(axis)" ;
    ex:textoExtracto "LATCH2DONE(axis) [...] El interpolador independiente activa esta marca al producirse el evento de latch en el eje con el palpador indicado; la desactiva al activar un nuevo proceso de latch en el eje con el mismo palpador." ;
    ex:monitoreaParametro ex:ProcesoLatcheoEje .

ex:Marca_FOLLOW
    a ex:Parametro ;
    rdfs:label "FOLLOW(axis)" ;
    ex:textoExtracto "FOLLOW(axis) [...] Para los movimientos de eje independiente, el interpolador del eje activa esta marca cuando está activa la sincronización en el eje (#FOLLOW)." ;
    ex:monitoreaParametro ex:ProcesoLatcheoEje .

ex:Marca_MOVCMD
    a ex:Parametro ;
    rdfs:label "MOVCMD(axis)" ;
    ex:textoExtracto "MOVCMD(axis) [...] Para los movimientos de eje independiente, el interpolador del eje activa esta marca cuando está ejecutando un posicionamiento (#MOVE)." ;
    ex:monitoreaParametro ex:ProcesoLatcheoEje .

ex:Parametro_PRBDI1
    a ex:Parametro ;
    rdfs:label "PRBDI1" ;
    ex:textoExtracto "El palpador 1 será el asignado al parámetro PRBDI1" ;
    ex:monitoreaParametro ex:ProcesoLatcheoEje .

ex:Parametro_PRBDI2
    a ex:Parametro ;
    rdfs:label "PRBDI2" ;
    ex:textoExtracto "el palpador 2 será el asignado al parámetro PRBDI2" ;
    ex:monitoreaParametro ex:ProcesoLatcheoEje .

ex:InterfazInterpoladorIndependiente
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz del interpolador independiente" ;
    ex:textoExtracto "Señales de consulta del interpolador independiente." ;
    ex:tieneComponente ex:Marca_IRESET ;
    ex:tieneComponente ex:Marca_LATCH1DONE ;
    ex:tieneComponente ex:Marca_LATCH2DONE ;
    ex:tieneComponente ex:Marca_FOLLOW ;
    ex:tieneComponente ex:Marca_MOVCMD ;
    ex:tieneComponente ex:Parametro_PRBDI1 ;
    ex:tieneComponente ex:Parametro_PRBDI2 .