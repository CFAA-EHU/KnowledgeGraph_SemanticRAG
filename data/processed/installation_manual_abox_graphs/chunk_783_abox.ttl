@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_224d57ccb6 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:TablaFuncionesAuxiliares ;
    ns1:textoExtracto "Si no se utilizan todos los registros, el CNC asigna el valor hexadecimal $FFFFFFFF a los que queden libres, los de numeración más alta." .

ns1:RegistroParaFuncionAuxiliarM a ns1:Parametro ;
    rdfs:label "Registro para función auxiliar M" ;
    ns1:identificador "MFUN1" ;
    ns1:textoExtracto "Cada uno de los registros indica el número de una de las funciones M programadas en el bloque." .

