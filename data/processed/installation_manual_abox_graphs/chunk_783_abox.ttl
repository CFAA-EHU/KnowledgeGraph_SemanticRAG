@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PLC_783 a ex:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ex:textoExtracto "El PLC debe desactivar esta marca cuando termina su gestión con estas variables." .

ex:marca_CUTVARACT_783 a ex:Parametro ;
    rdfs:label "CUTVARACT" ;
    ex:textoExtracto "El PLC debe desactivar esta marca cuando termina su gestión con estas variables. CUTVARACT El CNC activa esta marca cuando el usuario valida los parámetros de cutting de la tabla activa." .

ex:CNC_783 a ex:ComponenteElectrico ;
    rdfs:label "CNC" ;
    ex:textoExtracto "El CNC activa esta marca cuando el usuario valida los parámetros de cutting de la tabla activa." .

ex:marca_cutting_783 a ex:Parametro ;
    rdfs:label "marca cutting" ;
    ex:textoExtracto "El CNC activa esta marca cuando el usuario valida los parámetros de cutting de la tabla activa. Cuando la subrutina Cuttingon.fst sólo cambia el tipo de cutting (#CUTTING ON), el CNC no activa esta marca ya que la sincronización con el PLC es a través" .

ex:subrutina_Cuttingon_fst_783 a ex:TareaMantenimiento ;
    rdfs:label "subrutina Cuttingon.fst" ;
    ex:textoExtracto "Cuando la subrutina Cuttingon.fst sólo cambia el tipo de cutting (#CUTTING ON), el CNC no activa esta marca ya que la sincronización con el PLC es a través" .

ex:tabla_activa_783 a ex:Tabla ;
    rdfs:label "tabla activa" ;
    ex:textoExtracto "El CNC activa esta marca cuando el usuario valida los parámetros de cutting de la tabla activa." .