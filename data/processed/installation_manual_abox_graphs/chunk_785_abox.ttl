@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaCNC8070_564e04e45e a ns1:Sistema ;
    rdfs:label "Sistema CNC 8070" ;
    ns1:textoExtracto "Dentro de los parámetros máquina del CNC, en la tabla de funciones auxiliares –M– se indica cuándo se envía la función y cuándo se sincroniza la ejecución del PLC." ;
    ns1:tieneComponente ns1:Parametro_124d3de185,
        ns1:Parametro_7f1d359f9b,
        ns1:Parametro_89302d1a86,
        ns1:Parametro_a1bd340634,
        ns1:Parametro_ae9f08086d,
        ns1:Parametro_e3c996b893 .

ns1:Parametro_124d3de185 a ns1:Parametro ;
    rdfs:label "Función M30 programada" ;
    ns1:identificador "M30" ;
    ns1:textoExtracto "Ejemplo para detectar M30. Si se ha programado devolverá un \"1\"; un \"0\" en caso contrario." .

ns1:Parametro_7f1d359f9b a ns1:Parametro ;
    rdfs:label "Comando para analizar funciones programadas" ;
    ns1:identificador "MFUN*" ;
    ns1:textoExtracto "Comando MFUN*. Analizar si una función ha sido programada en el bloque." .

ns1:Parametro_89302d1a86 a ns1:Parametro ;
    rdfs:label "Función M11 sin sincronización" ;
    ns1:identificador "M11" ;
    ns1:textoExtracto "M11 sin sincronización." .

ns1:Parametro_a1bd340634 a ns1:Parametro ;
    rdfs:label "Función M13 se envía antes y se sincroniza tras el movimiento" ;
    ns1:identificador "M13" ;
    ns1:textoExtracto "M13 se envía antes y se sincroniza tras el movimiento." .

ns1:Parametro_ae9f08086d a ns1:Parametro ;
    rdfs:label "Función M14 se envía después y se sincroniza tras el movimiento" ;
    ns1:identificador "M14" ;
    ns1:textoExtracto "M14 se envía después y se sincroniza tras el movimiento." .

ns1:Parametro_e3c996b893 a ns1:Parametro ;
    rdfs:label "Función M12 se envía antes y se sincroniza antes del movimiento" ;
    ns1:identificador "M12" ;
    ns1:textoExtracto "M12 se envía antes y se sincroniza antes el movimiento." .

