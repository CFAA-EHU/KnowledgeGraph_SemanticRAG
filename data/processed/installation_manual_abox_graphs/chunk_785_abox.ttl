@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_SenalesLogicasConsultaLaser a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de señales lógicas de consulta (láser)"@es ;
    ex:textoExtracto """
| GAPERRORCANCEL | Significado. |
| --- | --- |
| Sí. | El CNC anula el error de gap fuera del rango y no detiene el movimiento de los ejes. |
| No | El CNC da error de gap fuera del rango y detiene el movimiento de los ejes, respetando la rampa de frenado y controlando el gap durante la rampa. |

INTOL El CNC activa esta marca si el gap está dentro de la tolerancia definida por el parámetro GAPTOL, respecto el valor de gap programado. Si el eje sobrepasa la tolerancia definida en el parámetro GAPTOL, el CNC desactiva la marca INTOL. El parámetro GAPTOLCANCEL establece el comportamiento del CNC cuando el gap sobrepasa la tolerancia definida en GAPTOL.

| GAPTOLCANCEL | Significado. |
| --- | --- |
| Sí. | El CNC anula el error de gap fuera del rango y no detiene el movimiento de los ejes. |
| No | El CNC da error de gap fuera del rango y detiene el movimiento de los ejes, respetando la rampa de frenado y controlando el gap durante la rampa.

INPOSLIMIT El CNC activa esta marca (cambio de 0 a 1) cuando el salto programado con un #LEAP alcanza el punto más alto (comando POSLIMIT). El CNC desactiva esta marca (cambio de 1 a 0) cuando el salto empieza a bajar de dicho punto. Si el salto no alcanza el punto más alto por falta de espacio, el CNC no activará esta marca. En cualquier situación de error, el CNC desactivará esta marca.

RESTARTPOINT El PLC activa esta marca cuando el CNC ejecuta un piercing o un cutting después de reiniciar por un punto interrumpido.
""" .

ex:Parametro_GAPERRORCANCEL
    a ex:Parametro ;
    rdfs:label "GAPERRORCANCEL" ;
    ex:identificador "GAPERRORCANCEL" ;
    ex:textoExtracto "El CNC anula el error de gap fuera del rango y no detiene el movimiento de los ejes."@es ;
    ex:documentadoEn ex:Tabla_SenalesLogicasConsultaLaser .

ex:Parametro_GAPTOL
    a ex:Parametro ;
    rdfs:label "GAPTOL" ;
    ex:identificador "GAPTOL" ;
    ex:textoExtracto "El CNC activa esta marca si el gap está dentro de la tolerancia definida por el parámetro GAPTOL, respecto el valor de gap programado."@es ;
    ex:documentadoEn ex:Tabla_SenalesLogicasConsultaLaser .

ex:Parametro_GAPTOLCANCEL
    a ex:Parametro ;
    rdfs:label "GAPTOLCANCEL" ;
    ex:identificador "GAPTOLCANCEL" ;
    ex:textoExtracto "El parámetro GAPTOLCANCEL establece el comportamiento del CNC cuando el gap sobrepasa la tolerancia definida en GAPTOL."@es ;
    ex:documentadoEn ex:Tabla_SenalesLogicasConsultaLaser .

ex:Parametro_INPOSLIMIT
    a ex:Parametro ;
    rdfs:label "INPOSLIMIT" ;
    ex:identificador "INPOSLIMIT" ;
    ex:textoExtracto "El CNC activa esta marca (cambio de 0 a 1) cuando el salto programado con un #LEAP alcanza el punto más alto (comando POSLIMIT)."@es ;
    ex:documentadoEn ex:Tabla_SenalesLogicasConsultaLaser .

ex:Parametro_RESTARTPOINT
    a ex:Parametro ;
    rdfs:label "RESTARTPOINT" ;
    ex:identificador "RESTARTPOINT" ;
    ex:textoExtracto "El PLC activa esta marca cuando el CNC ejecuta un piercing o un cutting después de reiniciar por un punto interrumpido."@es ;
    ex:documentadoEn ex:Tabla_SenalesLogicasConsultaLaser .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "CNC"@es ;
    ex:textoExtracto "El CNC anula el error de gap fuera del rango y no detiene el movimiento de los ejes."@es ;
    ex:controla ex:Parametro_GAPERRORCANCEL, ex:Parametro_GAPTOL, ex:Parametro_GAPTOLCANCEL, ex:Parametro_INPOSLIMIT ;
    ex:documentadoEn ex:Tabla_SenalesLogicasConsultaLaser .

ex:Sistema_PLC
    a ex:Sistema ;
    rdfs:label "PLC"@es ;
    ex:textoExtracto "El PLC activa esta marca cuando el CNC ejecuta un piercing o un cutting después de reiniciar por un punto interrumpido."@es ;
    ex:controla ex:Parametro_RESTARTPOINT ;
    ex:documentadoEn ex:Tabla_SenalesLogicasConsultaLaser .