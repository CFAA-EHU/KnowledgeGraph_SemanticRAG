@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TMOPERATION a ex:Parametro ;
    ex:identificador "TMOPERATION" ;
    ex:textoExtracto "Hay un registro para cada canal. Los mnemónicos para cada canal son los siguientes. TMOPERATIONC1 (equivalente a TMOPERATION) TMOPERATIONC2 TMOPERATIONC3 TMOPERATIONC4 Este registro indica el tipo de operación que desea realizar el gestor de herramientas." .

ex:TMOPERATIONC1 a ex:Parametro ;
    ex:identificador "TMOPERATIONC1" ;
    ex:textoExtracto "TMOPERATIONC1 (equivalente a TMOPERATION)" .

ex:TMOPERATIONC2 a ex:Parametro ;
    ex:identificador "TMOPERATIONC2" ;
    ex:textoExtracto "TMOPERATIONC2" .

ex:TMOPERATIONC3 a ex:Parametro ;
    ex:identificador "TMOPERATIONC3" ;
    ex:textoExtracto "TMOPERATIONC3" .

ex:TMOPERATIONC4 a ex:Parametro ;
    ex:identificador "TMOPERATIONC4" ;
    ex:textoExtracto "TMOPERATIONC4" .

ex:TMOPSTROBE a ex:Parametro ;
    ex:identificador "TMOPSTROBE" ;
    ex:textoExtracto "TMOPSTROBE Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. TMOPSTROBEC1 (equivalente a TMOPSTROBE) TMOPSTROBEC2 TMOPSTROBEC3 TMOPSTROBEC4 El canal del CNC pone esta marca a (=1) para indicar al PLC que debe ejecutar la operación indicada en TMOPERATION." .

ex:TMOPSTROBEC1 a ex:Parametro ;
    ex:identificador "TMOPSTROBEC1" ;
    ex:textoExtracto "TMOPSTROBEC1 (equivalente a TMOPSTROBE)" .

ex:TMOPSTROBEC2 a ex:Parametro ;
    ex:identificador "TMOPSTROBEC2" ;
    ex:textoExtracto "TMOPSTROBEC2" .

ex:TMOPSTROBEC3 a ex:Parametro ;
    ex:identificador "TMOPSTROBEC3" ;
    ex:textoExtracto "TMOPSTROBEC3" .

ex:TMOPSTROBEC4 a ex:Parametro ;
    ex:identificador "TMOPSTROBEC4" ;
    ex:textoExtracto "TMOPSTROBEC4" .

ex:LEAVEPOS a ex:Parametro ;
    ex:identificador "LEAVEPOS" ;
    ex:textoExtracto "LEAVEPOS Hay un registro para cada almacén. Los mnemónicos para cada almacén son los siguientes. LEAVEPOSMZ1 (también se puede programar como LEAVEPOS) LEAVEPOSMZ2 LEAVEPOSMZ3 LEAVEPOSMZ4 Este registro indica la posición de almacén en la que hay que dejar la herramienta. Durante la selección de una posición de la torreta (sentencia #ROTATEMZ), este registro tomará valor ꞏ0ꞏ si es un posicionamiento relativo positivo y valor ꞏ1ꞏ si es un posicionamiento relativo negativo." .

ex:LEAVEPOSMZ1 a ex:Parametro ;
    ex:identificador "LEAVEPOSMZ1" ;
    ex:textoExtracto "LEAVEPOSMZ1 (también se puede programar como LEAVEPOS)" .

ex:LEAVEPOSMZ2 a ex:Parametro ;
    ex:identificador "LEAVEPOSMZ2" ;
    ex:textoExtracto "LEAVEPOSMZ2" .

ex:LEAVEPOSMZ3 a ex:Parametro ;
    ex:identificador "LEAVEPOSMZ3" ;
    ex:textoExtracto "LEAVEPOSMZ3" .

ex:LEAVEPOSMZ4 a ex:Parametro ;
    ex:identificador "LEAVEPOSMZ4" ;
    ex:textoExtracto "LEAVEPOSMZ4" .

ex:TAKEPOS a ex:Parametro ;
    ex:identificador "TAKEPOS" ;
    ex:textoExtracto "TAKEPOS Hay un registro para cada almacén. Los mnemónicos para cada almacén son los siguientes. TAKEPOSMZ1 (también se puede programar como TAKEPOS) TAKEPOSMZ2 TAKEPOSMZ3 TAKEPOSMZ4 Este registro indica la posición de almacén que ocupa la herramienta que hay que coger. Durante la selección de una posición de la torreta (sentencia #ROTATEMZ), este registro tomará valor ꞏ0ꞏ si es un posicionamiento absoluto y valor ꞏ1ꞏ si es un posicionamiento relativo." .

ex:TAKEPOSMZ1 a ex:Parametro ;
    ex:identificador "TAKEPOSMZ1" ;
    ex:textoExtracto "TAKEPOSMZ1 (también se puede programar como TAKEPOS)" .

ex:TAKEPOSMZ2 a ex:Parametro ;
    ex:identificador "TAKEPOSMZ2" ;
    ex:textoExtracto "TAKEPOSMZ2" .

ex:TAKEPOSMZ3 a ex:Parametro ;
    ex:identificador "TAKEPOSMZ3" ;
    ex:textoExtracto "TAKEPOSMZ3" .

ex:TAKEPOSMZ4 a ex:Parametro ;
    ex:identificador "TAKEPOSMZ4" ;
    ex:textoExtracto "TAKEPOSMZ4" .

ex:NEXTPOS a ex:Parametro ;
    ex:identificador "NEXTPOS" ;
    ex:textoExtracto "NEXTPOS Hay un registro para cada almacén. Los mnemónicos para cada almacén son los siguientes." .