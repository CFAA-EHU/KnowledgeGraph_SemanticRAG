@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazGestorHerramientas
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de señales del gestor de herramientas" ;
    ex:textoExtracto "Señales de consulta del gestor de herramientas. TMOPERATION [...] TMOPSTROBE [...] LEAVEPOS [...] TAKEPOS [...] NEXTPOS" ;
    ex:tieneComponente ex:Registro_TMOPERATIONC1, ex:Registro_TMOPERATIONC2, ex:Registro_TMOPERATIONC3, ex:Registro_TMOPERATIONC4,
                       ex:Marca_TMOPSTROBEC1, ex:Marca_TMOPSTROBEC2, ex:Marca_TMOPSTROBEC3, ex:Marca_TMOPSTROBEC4,
                       ex:Registro_LEAVEPOSMZ1, ex:Registro_LEAVEPOSMZ2, ex:Registro_LEAVEPOSMZ3, ex:Registro_LEAVEPOSMZ4,
                       ex:Registro_TAKEPOSMZ1, ex:Registro_TAKEPOSMZ2, ex:Registro_TAKEPOSMZ3, ex:Registro_TAKEPOSMZ4 .

### Registros TMOPERATION (canales 1-4)
ex:Registro_TMOPERATIONC1
    a ex:Parametro ;
    rdfs:label "TMOPERATIONC1" ;
    ex:identificador "TMOPERATIONC1" ;
    ex:textoExtracto "TMOPERATIONC1 (equivalente a TMOPERATION). Este registro indica el tipo de operación que desea realizar el gestor de herramientas." ;
    ex:monitoreaParametro ex:InterfazGestorHerramientas .

ex:Registro_TMOPERATIONC2
    a ex:Parametro ;
    rdfs:label "TMOPERATIONC2" ;
    ex:identificador "TMOPERATIONC2" ;
    ex:textoExtracto "TMOPERATIONC2. Este registro indica el tipo de operación que desea realizar el gestor de herramientas." ;
    ex:monitoreaParametro ex:InterfazGestorHerramientas .

ex:Registro_TMOPERATIONC3
    a ex:Parametro ;
    rdfs:label "TMOPERATIONC3" ;
    ex:identificador "TMOPERATIONC3" ;
    ex:textoExtracto "TMOPERATIONC3. Este registro indica el tipo de operación que desea realizar el gestor de herramientas." ;
    ex:monitoreaParametro ex:InterfazGestorHerramientas .

ex:Registro_TMOPERATIONC4
    a ex:Parametro ;
    rdfs:label "TMOPERATIONC4" ;
    ex:identificador "TMOPERATIONC4" ;
    ex:textoExtracto "TMOPERATIONC4. Este registro indica el tipo de operación que desea realizar el gestor de herramientas." ;
    ex:monitoreaParametro ex:InterfazGestorHerramientas .

### Marcas TMOPSTROBE (canales 1-4)
ex:Marca_TMOPSTROBEC1
    a ex:Parametro ;
    rdfs:label "TMOPSTROBEC1" ;
    ex:identificador "TMOPSTROBEC1" ;
    ex:textoExtracto "TMOPSTROBEC1 (equivalente a TMOPSTROBE). El canal del CNC pone esta marca a (=1) para indicar al PLC que debe ejecutar la operación indicada en TMOPERATION." ;
    ex:monitoreaParametro ex:InterfazGestorHerramientas .

ex:Marca_TMOPSTROBEC2
    a ex:Parametro ;
    rdfs:label "TMOPSTROBEC2" ;
    ex:identificador "TMOPSTROBEC2" ;
    ex:textoExtracto "TMOPSTROBEC2. El canal del CNC pone esta marca a (=1) para indicar al PLC que debe ejecutar la operación indicada en TMOPERATION." ;
    ex:monitoreaParametro ex:InterfazGestorHerramientas .

ex:Marca_TMOPSTROBEC3
    a ex:Parametro ;
    rdfs:label "TMOPSTROBEC3" ;
    ex:identificador "TMOPSTROBEC3" ;
    ex:textoExtracto "TMOPSTROBEC3. El canal del CNC pone esta marca a (=1) para indicar al PLC que debe ejecutar la operación indicada en TMOPERATION." ;
    ex:monitoreaParametro ex:InterfazGestorHerramientas .

ex:Marca_TMOPSTROBEC4
    a ex:Parametro ;
    rdfs:label "TMOPSTROBEC4" ;
    ex:identificador "TMOPSTROBEC4" ;
    ex:textoExtracto "TMOPSTROBEC4. El canal del CNC pone esta marca a (=1) para indicar al PLC que debe ejecutar la operación indicada en TMOPERATION." ;
    ex:monitoreaParametro ex:InterfazGestorHerramientas .

### Registros LEAVEPOS (almacenes MZ1-MZ4)
ex:Registro_LEAVEPOSMZ1
    a ex:Parametro ;
    rdfs:label "LEAVEPOSMZ1" ;
    ex:identificador "LEAVEPOSMZ1" ;
    ex:textoExtracto "LEAVEPOSMZ1 (también se puede programar como LEAVEPOS). Este registro indica la posición de almacén en la que hay que dejar la herramienta. Durante la selección de una posición de la torreta (sentencia #ROTATEMZ), este registro tomará valor ꞏ0ꞏ si es un posicionamiento relativo positivo y valor ꞏ1ꞏ si es un posicionamiento relativo negativo." ;
    ex:monitoreaParametro ex:InterfazGestorHerramientas .

ex:Registro_LEAVEPOSMZ2
    a ex:Parametro ;
    rdfs:label "LEAVEPOSMZ2" ;
    ex:identificador "LEAVEPOSMZ2" ;
    ex:textoExtracto "LEAVEPOSMZ2. Este registro indica la posición de almacén en la que hay que dejar la herramienta." ;
    ex:monitoreaParametro ex:InterfazGestorHerramientas .

