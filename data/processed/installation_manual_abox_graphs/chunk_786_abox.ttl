    a ex:Parametro ;
    rdfs:label "TAKEPOSMZ3" ;
    ex:identificador "TAKEPOSMZ3" ;
    ex:textoExtracto "TAKEPOSMZ3. Este registro indica la posición de almacén que ocupa la herramienta que hay que coger." ;
    ex:monitoreaParametro ex:InterfazGestorHerramientas .

ex:Registro_TAKEPOSMZ4
    a ex:Parametro ;
    rdfs:label "TAKEPOSMZ4" ;
    ex:identificador "TAKEPOSMZ4" ;
    ex:textoExtracto "TAKEPOSMZ4. Este registro indica la posición de almacén que ocupa la herramienta que hay que coger." ;
    ex:monitoreaParametro ex:InterfazGestorHerramientas .