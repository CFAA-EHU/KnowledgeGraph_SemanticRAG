    a ex:Parametro ;
    rdfs:label "LEAVEPOSMZ3" ;
    ex:identificador "LEAVEPOSMZ3" ;
    ex:textoExtracto "LEAVEPOSMZ3. Este registro indica la posición de almacén en la que hay que dejar la herramienta." ;
    ex:monitoreaParametro ex:InterfazGestorHerramientas .

ex:Registro_LEAVEPOSMZ4
    a ex:Parametro ;
