@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:RegistroAlmacen ex:textoExtracto "Hay un registro para cada almacén." ;
    rdfs:label "Registro de almacén" ;
    a ex:Parametro .

ex:NEXTPOS ex:textoExtracto "NEXTPOS" ;
    rdfs:label "NEXTPOS" ;
    a ex:Parametro .

ex:NEXTPOSMZ1 ex:textoExtracto "NEXTPOSMZ1 (también se puede programar como NEXTPOS)" ;
    rdfs:label "NEXTPOSMZ1" ;
    a ex:Parametro .

ex:NEXTPOSMZ2 ex:textoExtracto "NEXTPOSMZ2" ;
    rdfs:label "NEXTPOSMZ2" ;
    a ex:Parametro .

ex:NEXTPOSMZ3 ex:textoExtracto "NEXTPOSMZ3" ;
    rdfs:label "NEXTPOSMZ3" ;
    a ex:Parametro .

ex:NEXTPOSMZ4 ex:textoExtracto "NEXTPOSMZ4" ;
    rdfs:label "NEXTPOSMZ4" ;
    a ex:Parametro .

ex:TWORNOUT ex:textoExtracto "TWORNOUT Hay una marca para" ;
    rdfs:label "TWORNOUT" ;
    a ex:Parametro .