@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ROTATEMZ a ex:Parametro ;
    rdfs:label "ROTATEMZ" ;
    ex:textoExtracto "(sentencia #ROTATEMZ), en un posicionamiento absoluto este registro indica la posición a alcanzar y en un posicionamiento relativo indica el número de posiciones a girar." .

ex:TWORNOUTC1 a ex:Parametro ;
    rdfs:label "TWORNOUTC1" ;
    ex:textoExtracto "TWORNOUTC1 (también se puede programar como TWORNOUT)" .

