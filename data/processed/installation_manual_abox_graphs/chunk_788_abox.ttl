@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Se_al_ROTATEMZ
    a               ex:Parametro ;
    rdfs:label      "Señal ROTATEMZ" ;
    ex:textoExtracto "en un posicionamiento absoluto este registro indica la posición a alcanzar y en un posicionamiento relativo indica el número de posiciones a girar." ;
    ex:monitoreaParametro ex:SistemaGestorHerramientas .

ex:Se_al_TWORNOUT
    a               ex:Parametro ;
    rdfs:label      "Señal TWORNOUT (rechazo herramienta por tiempo)" ;
    ex:textoExtracto "El canal del CNC pone esta marca a (=1) para indicar al PLC que la herramienta ha sido rechazada porque se ha usado más tiempo del previsto (vida real > vida máxima)." ;
    ex:identificador "TWORNOUTC1, TWORNOUTC2, TWORNOUTC3, TWORNOUTC4" ;
    ex:monitoreaParametro ex:SistemaGestorHerramientas .

ex:Se_al_TMINEM
    a               ex:Parametro ;
    rdfs:label      "Señal TMINEM (emergencia en gestor)" ;
    ex:textoExtracto "El CNC pone esta marca a (=1) para indicar al PLC que se ha producido una emergencia en el gestor de herramientas." ;
    ex:identificador "TMINEMZ1, TMINEMZ2, TMINEMZ3, TMINEMZ4" ;
    ex:monitoreaParametro ex:SistemaGestorHerramientas .

ex:Se_al_MZID
    a               ex:Parametro ;
    rdfs:label      "Señal MZID (identificación almacén)" ;
    ex:textoExtracto "Este registro indica el almacén en el que se encuentra la herramienta que ha solicitado el canal. Cuando en el cambio de herramienta intervengan dos almacenes, en la parte baja de este registro se indica el almacén en el que hay que dejar la herramienta y en la parte alta el almacén del que hay que coger la herramienta." ;
    ex:identificador "MZIDC1, MZIDC2, MZIDC3, MZIDC4" ;
    ex:monitoreaParametro ex:SistemaGestorHerramientas .

ex:SistemaGestorHerramientas
    a               ex:Sistema ;
    rdfs:label      "Sistema gestor de herramientas (CNC/PLC)" ;
    ex:textoExtracto "Señales de consulta del gestor de herramientas: ROTATEMZ, TWORNOUT, TMINEM, MZID." .