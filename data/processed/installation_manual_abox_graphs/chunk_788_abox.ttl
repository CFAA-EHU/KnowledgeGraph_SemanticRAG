    ns1:ilustra ns1:CNC8070_1be71d00c5 ;
    ns1:textoExtracto """| MFUN1C1 | MFUN2C1 | MFUN3C1 - MFUN7C1 |
| --- | --- | --- |
| 100 | 135 | $FFFFFFFF |""" .

