ns1:RegistroMFUN1ParaElPrimerCanal a ns1:Parametro ;
    rdfs:label "Registro MFUN1 para el primer canal" ;
    ns1:documentadoEn ns1:TablaRegistrosCanal ;
    ns1:identificador "MFUN1C1" ;
    ns1:textoExtracto "MFUN1C1 - MFUN7C1 para el primer canal." .

