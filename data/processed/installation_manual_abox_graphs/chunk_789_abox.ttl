@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:KEYBD1 a ex:InterfazUsuario ;
    rdfs:label "KEYBD1" ;
    ex:textoExtracto "KEYBD1 / KEYBD2 / KEYBD3 Estos registros son una copia del mapa de teclas pulsadas del último teclado utilizado." ;
    ex:identificador "KEYBD1" .

ex:KEYBD2 a ex:InterfazUsuario ;
    rdfs:label "KEYBD2" ;
    ex:textoExtracto "Registros KEYBD2 / KEYBD2_1 a KEYBD2_8. Teclas genéricas. Registros KEYBD2 / KEYBD2_1 a KEYBD2_8. Selector del feed override. Registros KEYBD2 / KEYBD2_1 a KEYBD2_8. Selector de movimiento (volante, jog incremental o jog continuo)." ;
    ex:identificador "KEYBD2" .

ex:KEYBD3 a ex:InterfazUsuario ;
    rdfs:label "KEYBD3" ;
    ex:textoExtracto "KEYBD1 / KEYBD2 / KEYBD3 Estos registros son una copia del mapa de teclas pulsadas del último teclado utilizado." ;
    ex:identificador "KEYBD3" .

ex:KEYBD1_1 a ex:InterfazUsuario ;
    rdfs:label "KEYBD1_1" ;
    ex:textoExtracto "KEYBD1_1 / KEYBD2_1 / KEYBD3_1 KEYBD1_8 / KEYBD2_8 / KEYBD3_8 Estos registros indican (bit=1) qué tecla se ha pulsado en cada panel de mando. Los registros KEYBD1_1 a KEYBD3_1 corresponden al primer panel de mando" ;
    ex:identificador "KEYBD1_1" .

ex:KEYBD2_1 a ex:InterfazUsuario ;
    rdfs:label "KEYBD2_1" ;
    ex:textoExtracto "KEYBD1_1 / KEYBD2_1 / KEYBD3_1 KEYBD1_8 / KEYBD2_8 / KEYBD3_8 Estos registros indican (bit=1) qué tecla se ha pulsado en cada panel de mando. Los registros KEYBD1_1 a KEYBD3_1 corresponden al primer panel de mando" ;
    ex:identificador "KEYBD2_1" .

ex:KEYBD3_1 a ex:InterfazUsuario ;
    rdfs:label "KEYBD3_1" ;
    ex:textoExtracto "KEYBD1_1 / KEYBD2_1 / KEYBD3_1 KEYBD1_8 / KEYBD2_8 / KEYBD3_8 Estos registros indican (bit=1) qué tecla se ha pulsado en cada panel de mando. Los registros KEYBD1_1 a KEYBD3_1 corresponden al primer panel de mando" ;
    ex:identificador "KEYBD3_1" .

ex:KEYBD1_8 a ex:InterfazUsuario ;
    rdfs:label "KEYBD1_8" ;
    ex:textoExtracto "KEYBD1_1 / KEYBD2_1 / KEYBD3_1 KEYBD1_8 / KEYBD2_8 / KEYBD3_8 Estos registros indican (bit=1) qué tecla se ha pulsado en cada panel de mando." ;
    ex:identificador "KEYBD1_8" .

ex:KEYBD2_8 a ex:InterfazUsuario ;
    rdfs:label "KEYBD2_8" ;
    ex:textoExtracto "KEYBD1_1 / KEYBD2_1 / KEYBD3_1 KEYBD1_8 / KEYBD2_8 / KEYBD3_8 Estos registros indican (bit=1) qué tecla se ha pulsado en cada panel de mando." ;
    ex:identificador "KEYBD2_8" .

ex:KEYBD3_8 a ex:InterfazUsuario ;
    rdfs:label "KEYBD3_8" ;
    ex:textoExtracto "KEYBD1_1 / KEYBD2_1 / KEYBD3_1 KEYBD1_8 / KEYBD2_8 / KEYBD3_8 Estos registros indican (bit=1) qué tecla se ha pulsado en cada panel de mando." ;
    ex:identificador "KEYBD3_8" .

ex:SpindleOverrideMas a ex:ComponenteElectrico ;
    rdfs:label "Spindle override +" ;
    ex:textoExtracto "Bit 0 | Spindle override +" .

ex:SpindleHorario a ex:ComponenteElectrico ;
    rdfs:label "Spindle clockwise" ;
    ex:textoExtracto "Bit 1 | Spindle clockwise" .

ex:PosicionamientoHusillo a ex:ComponenteElectrico ;
    rdfs:label "Spindle positioning" ;
    ex:textoExtracto "Bit 2 | Spindle positioning" .

ex:ParoHusillo a ex:ComponenteElectrico ;
    rdfs:label "Spindle stop" ;
    ex:textoExtracto "Bit 3 | Spindle stop" .

ex:SpindleOverrideMenos a ex:ComponenteElectrico ;
    rdfs:label "Spindle override -" ;
    ex:textoExtracto "Bit 4 | Spindle override -" .

ex:SpindleAntihorario a ex:ComponenteElectrico ;
    rdfs:label "Spindle counterclockwise" ;
    ex:textoExtracto "Bit 5 | Spindle counterclockwise" .

ex:TeclaSTART a ex:ComponenteElectrico ;
    rdfs:label "START" ;
    ex:textoExtracto "Bit 6 | START" .

ex:TeclaSTOP a ex:ComponenteElectrico ;
    rdfs:label "STOP" ;
    ex:textoExtracto "Bit 7 | STOP" .

ex:TeclaGenerica1 a ex:ComponenteElectrico ;
    rdfs:label "Generic Key 1" ;
    ex:textoExtracto "Bit 8 | Generic Key 1" .

ex:TeclaGenerica2 a ex:ComponenteElectrico ;
    rdfs:label "Generic Key 2" ;
    ex:textoExtracto "Bit 9 | Generic Key 2" .