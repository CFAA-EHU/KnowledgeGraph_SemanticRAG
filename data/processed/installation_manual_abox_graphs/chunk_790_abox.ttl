@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazUsuario_Se_alesTeclas
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de señales de teclas genéricas" ;
    ex:textoExtracto "Teclas genéricas. Registros KEYBD2 / KEYBD2_1 a KEYBD2_8. Selector del feed override. Registros KEYBD2 / KEYBD2_1 a KEYBD2_8. Selector de movimiento (volante, jog incremental o jog continuo). Registros KEYBD3 / KEYBD3_1 a KEYBD3_8. Selector del speed override." ;
    ex:identificador "KEYBD2, KEYBD3, KEYHBLS1, KEYHBLS2" .

ex:Parametro_KEYBD2
    a ex:Parametro ;
    rdfs:label "Registro KEYBD2" ;
    ex:textoExtracto "Registros KEYBD2 / KEYBD2_1 a KEYBD2_8. Selector del feed override." ;
    ex:identificador "KEYBD2" ;
    ex:monitoreaParametro ex:InterfazUsuario_Se_alesTeclas .

ex:Parametro_KEYBD3
    a ex:Parametro ;
    rdfs:label "Registro KEYBD3" ;
    ex:textoExtracto "Registros KEYBD3 / KEYBD3_1 a KEYBD3_8. Selector de movimiento (volante, jog incremental o jog continuo)." ;
    ex:identificador "KEYBD3" ;
    ex:monitoreaParametro ex:InterfazUsuario_Se_alesTeclas .

ex:Parametro_KEYHBLS1
    a ex:Parametro ;
    rdfs:label "Registro KEYHBLS1" ;
    ex:textoExtracto "El registro KEYHBLS1 corresponde al primer volante y KEYHBLS2 al segundo. Estos registros son una copia del mapa de teclas del volante HBLS e indican qué tecla se ha pulsado (bit=1)." ;
    ex:identificador "KEYHBLS1" ;
    ex:monitoreaParametro ex:InterfazUsuario_Se_alesTeclas .

ex:Parametro_KEYHBLS2
    a ex:Parametro ;
    rdfs:label "Registro KEYHBLS2" ;
    ex:textoExtracto "El registro KEYHBLS1 corresponde al primer volante y KEYHBLS2 al segundo. Estos registros son una copia del mapa de teclas del volante HBLS e indican qué tecla se ha pulsado (bit=1)." ;
    ex:identificador "KEYHBLS2" ;
    ex:monitoreaParametro ex:InterfazUsuario_Se_alesTeclas .