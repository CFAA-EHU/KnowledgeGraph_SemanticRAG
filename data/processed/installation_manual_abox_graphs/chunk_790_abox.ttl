@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:KEYBD2 a ex:Sensor ;
    rdfs:label "Teclas genéricas" ;
    ex:identificador "KEYBD2 / KEYBD2_1 a KEYBD2_8" ;
    ex:textoExtracto "Teclas genéricas. Registros KEYBD2 / KEYBD2_1 a KEYBD2_8." .

ex:KEYBD3 a ex:Sensor ;
    rdfs:label "Selector de movimiento" ;
    ex:identificador "KEYBD3 / KEYBD3_1 a KEYBD3_8" ;
    ex:textoExtracto "Selector de movimiento (volante, jog incremental o jog continuo). Registros KEYBD3 / KEYBD3_1 a KEYBD3_8." .

ex:KEYHBLS1 a ex:Sensor ;
    rdfs:label "Registro de teclas del volante HBLS 1" ;
    ex:identificador "KEYHBLS1" ;
    ex:textoExtracto "KEYHBLS1 KEYHBLS2 Estos registros son una copia del mapa de teclas del volante HBLS e indican qué tecla se ha pulsado (bit=1). El registro KEYHBLS1 corresponde al primer volante y KEYHBLS2 al segundo." .

ex:KEYHBLS2 a ex:Sensor ;
    rdfs:label "Registro de teclas del volante HBLS 2" ;
    ex:identificador "KEYHBLS2" ;
    ex:textoExtracto "KEYHBLS1 KEYHBLS2 Estos registros son una copia del mapa de teclas del volante HBLS e indican qué tecla se ha pulsado (bit=1). El registro KEYHBLS1 corresponde al primer volante y KEYHBLS2 al segundo." .