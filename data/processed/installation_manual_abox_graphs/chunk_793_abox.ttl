@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_f21894344a a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC indica el PLC mediante el registro de 32 bits SFUN1 el valor de la función S programada en el bloque." .

ns1:RegistroSFUN1 a ns1:ComponenteElectrico ;
    rdfs:label "Registro SFUN1" ;
    ns1:textoExtracto "El CNC indica el PLC mediante el registro de 32 bits SFUN1 el valor de la función S programada en el bloque." .

ns1:TiempoDeVelocidadDelCabezal a ns1:Parametro ;
    rdfs:label "Tiempo de velocidad del cabezal" ;
    ns1:textoExtracto "El comando SFUN sólo toma el valor de la S programada si el parámetro de cabezal SPDLTIME es distinto de cero." .

ns1:VelocidadDeGiroDelCabezalOPosicionAOrientar a ns1:Parametro ;
    rdfs:label "Velocidad de giro del cabezal o posición a orientar" ;
    ns1:textoExtracto "La función auxiliar S indica la velocidad de giro del cabezal con M03 y M04, o la posición a orientar el cabezal con M19." .

