@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:senal_STOP a ex:Sensor ;
    rdfs:label "senal _STOP" ;
    ex:textoExtracto "señal _STOP es similar al que recibe la tecla [STOP] del CNC" .

ex:tecla_STOP a ex:Sensor ;
    rdfs:label "tecla [STOP]" ;
    ex:textoExtracto "tecla [STOP] del CNC" .

ex:senal_XFERINH a ex:Sensor ;
    rdfs:label "senal _XFERINH" ;
    ex:textoExtracto "Con esta señal a nivel lógico bajo, todas las teclas permanecen habilitadas. _ XFERINH Hay una marca para cada canal." .

ex:senal_XFERINHC1 a ex:Sensor ;
    rdfs:label "senal _XFERINHC1" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. _ XFERINHC1 (también se puede programar como _XFERINH)" .

ex:senal_XFERINHC2 a ex:Sensor ;
    rdfs:label "senal _XFERINHC2" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. ... _XFERINHC2" .

ex:senal_XFERINHC3 a ex:Sensor ;
    rdfs:label "senal _XFERINHC3" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. ... _XFERINHC3" .

ex:senal_XFERINHC4 a ex:Sensor ;
    rdfs:label "senal _XFERINHC4" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. ... _XFERINHC4" .

ex:senal_XFITOIND a ex:Parametro ;
    rdfs:label "_XFITOIND" ;
    ex:textoExtracto "los programados desde el PLC dependen del parámetro XFITOIND" .

ex:canal_CNC a ex:Sistema ;
    rdfs:label "canal del CNC" ;
    ex:textoExtracto "el canal del CNC detiene la ejecución del programa al final del bloque que se está ejecutando e impide la ejecución del siguiente bloque", "el canal del CNC detiene sus movimientos de eje independiente cuando estos llegan a posición e impide la ejecución del siguiente movimiento" .

ex:movimiento_eje a ex:ComponenteMecanico ;
    rdfs:label "movimiento de eje" ;
    ex:textoExtracto "el CNC no permite movimientos en jog para los ejes del canal", "Esta marca siempre afecta a los movimientos de eje independiente programados desde el CNC" .

ex:parametro_XFITOIND a ex:Parametro ;
    rdfs:label "parámetro XFITOIND" ;
    ex:textoExtracto "los programados desde el PLC dependen del parámetro XFITOIND" .

ex:senal_STOP ex:controla ex:canal_CNC ;
    ex:textoExtracto "señal _STOP es similar al que recibe la tecla [STOP] del CNC. Con esta señal a nivel lógico bajo, todas las teclas permanecen habilitadas" .

ex:senal_XFERINH ex:controla ex:canal_CNC ;
    ex:textoExtracto "Si el PLC pone esta marca a (=0), el canal del CNC detiene la ejecución del programa al final del bloque que se está ejecutando e impide la ejecución del siguiente bloque", "Cuando la marca vuelve a (=1), el CNC continúa con la ejecución del programa", "Con la marca a (=0) el CNC no permite movimientos en jog para los ejes del canal; la pulsación de una tecla de jog no tiene efecto", "Si el PLC desactiva la marca _XFERINH, el canal del CNC detiene sus movimientos de eje independiente cuando estos llegan a posición e impide la ejecución del siguiente movimiento" .

ex:senal_XFERINHC1 ex:controla ex:canal_CNC ;
    ex:textoExtracto "Si el PLC pone esta marca a (=0), el canal del CNC detiene la ejecución del programa al final del bloque que se está ejecutando e impide la ejecución del siguiente bloque" .

ex:senal_XFERINHC2 ex:controla ex:canal_CNC ;
    ex:textoExtracto "Si el PLC pone esta marca a (=0), el canal del CNC detiene la ejecución del programa al final del bloque que se está ejecutando e impide la ejecución del siguiente bloque" .

ex:senal_XFERINHC3 ex:controla ex:canal_CNC ;
    ex:textoExtracto "Si el PLC pone esta marca a (=0), el canal del CNC detiene la ejecución del programa al final del bloque que se está ejecutando e impide la ejecución del siguiente bloque" .

ex:senal_XFERINHC4 ex:controla ex:canal_CNC ;
    ex:textoExtracto "Si el PLC pone esta marca a (=0), el canal del CNC detiene la ejecución del programa al final del bloque que se está ejecutando e impide la ejecución del siguiente bloque" .

ex:canal_CNC ex:compuestoPor ex:movimiento_eje ;
    ex:textoExtracto "Esta marca siempre afecta a los movimientos de eje independiente programados desde el CNC" .

ex:senal_XFERINH ex:mitigaRiesgo ex:AccionProhibida ;
    ex:textoExtracto "el CNC no permite movimientos en jog para los ejes del canal; la pulsación de una tecla de jog no tiene efecto" .