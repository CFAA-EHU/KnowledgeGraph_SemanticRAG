@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_73f7f47a21 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC puede disponer de hasta cuatro cabezales." .

ns1:NumeroLogicoDelCabezal a ns1:Parametro ;
    rdfs:label "Número lógico del cabezal" ;
    ns1:identificador "SPDLNAME" ;
    ns1:textoExtracto "El número de cabezal viene determinado por su número lógico, que se establece según el orden en el que fue definido en el parámetro máquina SPDLNAME." .

ns1:Parametro_1d45785189 a ns1:Parametro ;
    rdfs:label "Función S programada para el cabezal 2" ;
    ns1:identificador "SFUN2" ;
    ns1:textoExtracto "El CNC indica el PLC mediante los registros de 32 bits SFUN1 a SFUN4, las funciones S programadas en el bloque en ejecución." .

