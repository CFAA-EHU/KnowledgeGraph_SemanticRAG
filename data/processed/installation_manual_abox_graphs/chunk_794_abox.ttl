@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:XFITOIND a ex:Tabla ;
    ex:textoExtracto "XFITOIND | Significado." ;
    ex:tieneComponente ex:XFITOIND_Si, ex:XFITOIND_No .

ex:XFITOIND_Si a ex:Parametro ;
    ex:identificador "XFITOIND" ;
    ex:valor "Sí" ;
    ex:textoExtracto "Sí | La marca _XFERINH afecta a los movimientos de eje independiente programados desde el PLC y CNC." .

ex:XFITOIND_No a ex:Parametro ;
    ex:identificador "XFITOIND" ;
    ex:valor "No" ;
    ex:textoExtracto "No | La marca _XFERINH no afecta a los movimientos de eje independiente programados desde el PLC; sí afecta a los programados desde el CNC." .