@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Marca_IXFERINH
    a               ex:Parametro ;
    rdfs:label      "Marca _IXFERINH(axis) para transfer inhibit por eje"@es ;
    ex:textoExtracto "Para gestionar el transfer inhibit en un movimiento independiente, el PLC también dispone de una marca particular por eje (marca _IXFERINH(axis))."@es ;
    ex:identificador "_IXFERINH(axis)" .

ex:Marca_FEEDHOLC1
    a               ex:Parametro ;
    rdfs:label      "Marca _FEEDHOLC1 (o _FEEDHOL) para detención temporal de avance"@es ;
    ex:textoExtracto "_FEEDHOLC1 (también se puede programar como _FEEDHOL). Si el PLC pone esta marca a nivel lógico bajo, el canal del CNC detiene temporalmente el avance de los ejes."@es ;
    ex:identificador "_FEEDHOLC1" .

ex:Marca_FEEDHOLC2
    a               ex:Parametro ;
    rdfs:label      "Marca _FEEDHOLC2 para detención temporal de avance"@es ;
    ex:textoExtracto "_FEEDHOLC2. Si el PLC pone esta marca a nivel lógico bajo, el canal del CNC detiene temporalmente el avance de los ejes."@es ;
    ex:identificador "_FEEDHOLC2" .

ex:Marca_FEEDHOLC3
    a               ex:Parametro ;
    rdfs:label      "Marca _FEEDHOLC3 para detención temporal de avance"@es ;
    ex:textoExtracto "_FEEDHOLC3. Si el PLC pone esta marca a nivel lógico bajo, el canal del CNC detiene temporalmente el avance de los ejes."@es ;
    ex:identificador "_FEEDHOLC3" .

ex:Marca_FEEDHOLC4
    a               ex:Parametro ;
    rdfs:label      "Marca _FEEDHOLC4 para detención temporal de avance"@es ;
    ex:textoExtracto "_FEEDHOLC4. Si el PLC pone esta marca a nivel lógico bajo, el canal del CNC detiene temporalmente el avance de los ejes."@es ;
    ex:identificador "_FEEDHOLC4" .

ex:Marca_CYSTARTC1
    a               ex:Parametro ;
    rdfs:label      "Marca CYSTARTC1 (o CYSTART) para inicio de ciclo"@es ;
    ex:textoExtracto "CYSTARTC1 (también se puede programar como CYSTART). Cuando el operario pulsa la tecla [START] el canal del CNC se lo indica al PLC activando la marca START."@es ;
    ex:identificador "CYSTARTC1" .

ex:Marca_CYSTARTC2
    a               ex:Parametro ;
    rdfs:label      "Marca CYSTARTC2 para inicio de ciclo"@es ;
    ex:textoExtracto "CYSTARTC2. Cuando el operario pulsa la tecla [START] el canal del CNC se lo indica al PLC activando la marca START."@es ;
    ex:identificador "CYSTARTC2" .

ex:Marca_CYSTARTC3
    a               ex:Parametro ;
    rdfs:label      "Marca CYSTARTC3 para inicio de ciclo"@es ;
    ex:textoExtracto "CYSTARTC3. Cuando el operario pulsa la tecla [START] el canal del CNC se lo indica al PLC activando la marca START."@es ;
    ex:identificador "CYSTARTC3" .

ex:Marca_CYSTARTC4
    a               ex:Parametro ;
    rdfs:label      "Marca CYSTARTC4 para inicio de ciclo"@es ;
    ex:textoExtracto "CYSTARTC4. Cuando el operario pulsa la tecla [START] el canal del CNC se lo indica al PLC activando la marca START."@es ;
    ex:identificador "CYSTARTC4" .

ex:Indicador_Freal
    a               ex:InterfazUsuario ;
    rdfs:label      "Indicador 'Freal' en pantalla de modos automático/manual"@es ;
    ex:textoExtracto "El texto \"Freal\" de las pantallas de los modos automático y manual muestra el estado de esta marca. El texto aparece en color rojo cuando la marca _FEEDHOL está activa."@es ;
    ex:monitoreaParametro ex:Marca_FEEDHOLC1 , ex:Marca_FEEDHOLC2 , ex:Marca_FEEDHOLC3 , ex:Marca_FEEDHOLC4 .