ex:MarcaSTART a ex:ComponenteElectrico ;
    ex:textoExtracto "Cuando el operario pulsa la tecla [START] el canal del CNC se lo indica al PLC activando la marca START." .

ex:MarcaCYSTART a ex:ComponenteElectrico ;
    ex:textoExtracto "el PLC debe activar la marca CYSTART para que comience la ejecución del programa." .

ex:MarcaSBLOCK a ex:ComponenteElectrico ;
    ex:textoExtracto "SBLOCK Hay una marca para cada canal. Los mnemónicos para cada canal son los" .

ex:MarcaCYSTARTC1 a ex:ComponenteElectrico ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. CYSTARTC1 (también se puede programar como CYSTART)" .

ex:MarcaCYSTARTC2 a ex:ComponenteElectrico ;
    ex:textoExtracto "CYSTARTC2" .

ex:MarcaCYSTARTC3 a ex:ComponenteElectrico ;
    ex:textoExtracto "CYSTARTC3" .

ex:MarcaCYSTARTC4 a ex:ComponenteElectrico ;
    ex:textoExtracto "CYSTARTC4" .