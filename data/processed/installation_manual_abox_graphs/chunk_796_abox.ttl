@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AuxEnd a ns1:ComponenteElectrico ;
    rdfs:label "Entrada general AUXEND" ;
    ns1:textoExtracto "el CNC espera la activación de la entrada general AUXEND, indicativo de fin de ejecución del PLC." .

ns1:CNC8070_88ec3943a9 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:SalidaLogicaGeneralHSTROBE,
        ns1:SalidaLogicaGeneralMSTROBE,
        ns1:SalidaLogicaGeneralSSTROBE ;
    ns1:textoExtracto "El CNC asigna a los registros MFUN1 a MFUN7 del canal los números de las funciones M programadas en el bloque." .

ns1:TiempoDeEsperaParaLaFinalizacionDeEjecucion a ns1:Parametro ;
    rdfs:label "Tiempo de espera para la finalización de ejecución" ;
    ns1:textoExtracto "Esta marca se mantiene a (=1) durante el tiempo indicado en el parámetro MINAENDW." .

ns1:SalidaLogicaGeneralHSTROBE a ns1:ComponenteElectrico ;
    rdfs:label "Salida lógica general HSTROBE" ;
    ns1:textoExtracto "EL CNC activa la salida lógica general HSTROBE para indicar al PLC que debe ejecutarlas." .

ns1:SalidaLogicaGeneralMSTROBE a ns1:ComponenteElectrico ;
    rdfs:label "Salida lógica general MSTROBE" ;
    ns1:textoExtracto "El CNC activa la salida lógica general MSTROBE para indicar al PLC que debe ejecutarlas." .

ns1:SalidaLogicaGeneralSSTROBE a ns1:ComponenteElectrico ;
    rdfs:label "Salida lógica general SSTROBE" ;
    ns1:textoExtracto "El CNC activa la salida lógica general SSTROBE para indicar al PLC que debe ejecutarla." .

