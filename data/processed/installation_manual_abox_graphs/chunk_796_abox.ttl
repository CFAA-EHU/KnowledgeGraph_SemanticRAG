@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Se_al_CYSTART a ex:ComponenteElectrico ;
    rdfs:label "Señal CYSTART (inicio de ejecución)"@es ;
    ex:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. CYSTARTC1 (también se puede programar como CYSTART) [...] el PLC debe activar la marca CYSTART para que comience la ejecución del programa."@es ;
    ex:identificador "CYSTART" .

ex:Se_al_CYSTARTC1 a ex:ComponenteElectrico ;
    rdfs:label "Señal CYSTARTC1"@es ;
    ex:textoExtracto "CYSTARTC1 (también se puede programar como CYSTART)"@es ;
    ex:identificador "CYSTARTC1" .

ex:Se_al_CYSTARTC2 a ex:ComponenteElectrico ;
    rdfs:label "Señal CYSTARTC2"@es ;
    ex:textoExtracto "CYSTARTC2"@es ;
    ex:identificador "CYSTARTC2" .

ex:Se_al_CYSTARTC3 a ex:ComponenteElectrico ;
    rdfs:label "Señal CYSTARTC3"@es ;
    ex:textoExtracto "CYSTARTC3"@es ;
    ex:identificador "CYSTARTC3" .

ex:Se_al_CYSTARTC4 a ex:ComponenteElectrico ;
    rdfs:label "Señal CYSTARTC4"@es ;
    ex:textoExtracto "CYSTARTC4"@es ;
    ex:identificador "CYSTARTC4" .

ex:Se_al_SBLOCK a ex:ComponenteElectrico ;
    rdfs:label "Señal SBLOCK"@es ;
    ex:textoExtracto "SBLOCK. Hay una marca para cada canal."@es ;
    ex:identificador "SBLOCK" .

ex:Se_al_START a ex:ComponenteElectrico ;
    rdfs:label "Señal START (tecla de operario)"@es ;
    ex:textoExtracto "Cuando el operario pulsa la tecla [START] el canal del CNC se lo indica al PLC activando la marca START."@es ;
    ex:identificador "START" .

ex:Interfaz_CNC_PLC a ex:InterfazUsuario ;
    rdfs:label "Interfaz CNC-PLC para señales de control"@es ;
    ex:textoExtracto "el canal del CNC se lo indica al PLC activando la marca START [...] el PLC debe activar la marca CYSTART para que comience la ejecución del programa."@es ;
    ex:tieneComponente ex:Se_al_START, ex:Se_al_CYSTART, ex:Se_al_CYSTARTC1, ex:Se_al_CYSTARTC2, ex:Se_al_CYSTARTC3, ex:Se_al_CYSTARTC4, ex:Se_al_SBLOCK ;
    ex:controla ex:Se_al_CYSTART .