@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Tecla_RESET a ex:ComponenteElectrico ;
    rdfs:label "tecla [RESET]" ;
    ex:textoExtracto "tecla de [RESET]" .

ex:Marca_RESET a ex:Parametro ;
    rdfs:label "marca RESET" ;
    ex:textoExtracto "marca" .

ex:Canal_CNC a ex:ComponenteElectrico ;
    rdfs:label "canal del CNC" ;
    ex:textoExtracto "canal del CNC" .

ex:Flanco_Subida a ex:Parametro ;
    rdfs:label "flanco de subida" ;
    ex:textoExtracto "flanco de subida (cambio de 0 a 1)" .

ex:PLC a ex:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ex:textoExtracto "el PLC" .

ex:Proceso_Reset a ex:AccionProhibida ;
    rdfs:label "proceso de reset" ;
    ex:textoExtracto "El proceso de reset es como sigue" .

ex:Panel_Usuario a ex:InterfazUsuario ;
    rdfs:label "panel de usuario" ;
    ex:textoExtracto "panel" .