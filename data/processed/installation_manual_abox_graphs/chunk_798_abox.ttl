@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_403b815963 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC indica en los registros MFUN1 a MFUN7 del canal las funciones M programadas en el bloque y activa la marca MSTROBE para que el PLC las ejecute." .

ns1:MarcaAUXEND a ns1:ComponenteElectrico ;
    rdfs:label "Marca AUXEND" ;
    ns1:textoExtracto "El PLC debe desactivar la marca AUXEND para indicar al CNC que comienza la ejecución." .

ns1:MarcaMSTROBE a ns1:ComponenteElectrico ;
    rdfs:label "Marca MSTROBE" ;
    ns1:textoExtracto "El CNC indica en los registros MFUN1 a MFUN7 del canal las funciones M programadas en el bloque y activa la marca MSTROBE para que el PLC las ejecute." .

ns1:MarcaSSTROBE a ns1:ComponenteElectrico ;
    rdfs:label "Marca SSTROBE" ;
    ns1:textoExtracto "El CNC indica en los registros SFUN1 a SFUN4 el valor de la S programada en el bloque y activa la marca SSTROBE para que el PLC las ejecute." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "El PLC debe desactivar la marca AUXEND para indicar al CNC que comienza la ejecución." .

ns1:TiempoMinimoDeEsperaParaFinalizacionDeFuncionesAuxiliares a ns1:Parametro ;
    rdfs:label "Tiempo mínimo de espera para finalización de funciones auxiliares" ;
    ns1:identificador "MINAENDW" ;
    ns1:textoExtracto "La marca AUXEND debe mantenerse a (=1) un tiempo superior al definido en el parámetro MINAENDW." .

