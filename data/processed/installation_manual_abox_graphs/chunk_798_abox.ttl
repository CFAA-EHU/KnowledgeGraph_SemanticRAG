@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Se_al_RESETIN
    a               ex:InterfazUsuario ;
    rdfs:label      "Señal RESETIN" ;
    ex:textoExtracto
                    "El tratamiento que recibe esta marca es similar al que recibe la tecla de [RESET]. Con un flanco de subida (cambio de 0 a 1) de esta marca, el canal del CNC se resetea. Una vez iniciado el reset, el PLC puede desactivar esta marca (RESETIN=0)." ;
    ex:identificador
                    "RESETIN" .

ex:Tecla_RESET
    a               ex:InterfazUsuario ;
    rdfs:label      "Tecla RESET" ;
    ex:textoExtracto
                    "El usuario pulsa la tecla [RESET] del panel" ;
    ex:identificador
                    "RESET" .

ex:Proceso_ResetCNC
    a               ex:ModoOperacion ;
    rdfs:label      "Proceso de reset del canal CNC" ;
    ex:textoExtracto
                    "El proceso de reset es como sigue. 1 El usuario pulsa la tecla [RESET] del panel" ;
    ex:habilitadoPor
                    ex:Se_al_RESETIN ;
    ex:ejecutadoPor
                    ex:Tecla_RESET .