@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_c0bca84eb0 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:SistemaPLC ;
    ns1:monitoreaParametro ns1:TiempoDeEsperaParaEjecucionDeFuncionesMYH ;
    ns1:textoExtracto "El CNC mantiene activa la marca MSTROBE durante el tiempo indicado en el parámetro MINAENDW." .

ns1:FrecuenciaDeEjecucionDelProgramaPLC a ns1:Parametro ;
    rdfs:label "Frecuencia de ejecución del programa PLC" ;
    ns1:identificador "PRGFREQ" ;
    ns1:textoExtracto "Es aconsejable que el valor del parámetro MINAENDW sea igual o superior a la periodicidad con que se ejecuta el programa de PLC, parámetro PRGFREQ." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:monitoreaParametro ns1:FrecuenciaDeEjecucionDelProgramaPLC ;
    ns1:textoExtracto "Es aconsejable que el valor del parámetro MINAENDW sea igual o superior a la periodicidad con que se ejecuta el programa de PLC, parámetro PRGFREQ." .

ns1:TiempoDeEsperaParaEjecucionDeFuncionesMYH a ns1:Parametro ;
    rdfs:label "Tiempo de espera para ejecución de funciones M y H" ;
    ns1:identificador "MINAENDW" ;
    ns1:textoExtracto "El CNC mantiene activa la marca MSTROBE durante el tiempo indicado en el parámetro MINAENDW." .

