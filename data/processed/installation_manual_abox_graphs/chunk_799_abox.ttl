@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:RESETIN a ex:Parametro ;
    rdfs:label "RESETIN" ;
    ex:textoExtracto "el PLC puede desactivar esta marca (RESETIN=0)" .

ex:RESETOUT a ex:Parametro ;
    rdfs:label "RESETOUT" ;
    ex:textoExtracto "el canal activa la marca RESETOUT (RESETOUT=1)" .

ex:PROGRAM_RESET a ex:AccionProhibida ;
    rdfs:label "PROGRAM_RESET" ;
    ex:textoExtracto "el canal ejecuta la subrutina asociada al reset (PROGRAM_RESET), si existe" .

ex:MINAENDW a ex:Parametro ;
    rdfs:label "MINAENDW" ;
    ex:textoExtracto "el tiempo fijado en el parámetro general en la página 406. MINAENDW" .

ex:tecla_RESET a ex:ComponenteElectrico ;
    rdfs:label "[RESET]" ;
    ex:textoExtracto "el usuario pulsa la tecla [RESET] del panel de mando" .

ex:canal_CNC a ex:Componente ;
    rdfs:label "canal del CNC" ;
    ex:textoExtracto "el canal del CNC se resetea" ;
    ex:tieneComponente ex:RESETIN, ex:RESETOUT, ex:PROGRAM_RESET, ex:MINAENDW, ex:tecla_RESET .

ex:panel_de_mando a ex:InterfazUsuario ;
    rdfs:label "panel de mando" ;
    ex:textoExtracto "la tecla [RESET] del panel de mando" ;
    ex:tieneComponente ex:tecla_RESET .