@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ProcesoResetCNC
    a ex:ModoOperacion ;
    rdfs:label "Proceso de reset del canal CNC" ;
    ex:textoExtracto "el canal del CNC se resetea. Una vez iniciado el reset, el PLC puede desactivar esta marca (RESETIN=0). El proceso de reset es como sigue. 1 El usuario pulsa la tecla [RESET] del panel de mando o el PLC activa la marca RESETIN. 2 El canal asume las condiciones iniciales (las definidas en los parámetros máquina). 3 El canal activa la marca RESETOUT (RESETOUT=1) para indicar que ha finalizado el reset. Esta marca permanece activa el tiempo fijado en el parámetro general en la página 406. MINAENDW. 4 El canal ejecuta la subrutina asociada al reset (PROGRAM_RESET), si existe." .

ex:TeclaReset
    a ex:InterfazUsuario ;
    rdfs:label "Tecla [RESET]" ;
    ex:textoExtracto "El usuario pulsa la tecla [RESET] del panel de mando" ;
    ex:habilitadoPor ex:ProcesoResetCNC .

ex:MarcaRESETIN
    a ex:Parametro ;
    rdfs:label "RESETIN" ;
    ex:identificador "RESETIN" ;
    ex:valor "0" ;
    ex:textoExtracto "el PLC activa la marca RESETIN. Una vez iniciado el reset, el PLC puede desactivar esta marca (RESETIN=0)" ;
    ex:monitoreaParametro ex:ProcesoResetCNC .

ex:MarcaRESETOUT
    a ex:Parametro ;
    rdfs:label "RESETOUT" ;
    ex:identificador "RESETOUT" ;
    ex:valor "1" ;
    ex:textoExtracto "El canal activa la marca RESETOUT (RESETOUT=1) para indicar que ha finalizado el reset. Esta marca permanece activa el tiempo fijado en el parámetro general en la página 406. MINAENDW." ;
    ex:monitoreaParametro ex:ProcesoResetCNC .

ex:ParametroMINAENDW
    a ex:Parametro ;
    rdfs:label "MINAENDW" ;
    ex:identificador "MINAENDW" ;
    ex:textoExtracto "Esta marca [RESETOUT] permanece activa el tiempo fijado en el parámetro general en la página 406. MINAENDW." ;
    ex:documentadoEn ex:Pagina406 .

ex:Pagina406
    a ex:Pagina ;
    rdfs:label "Página 406" ;
    ex:identificador "406" ;
    ex:textoExtracto "el parámetro general en la página 406. MINAENDW." .

ex:SubrutinaPROGRAM_RESET
    a ex:ModoOperacion ;
    rdfs:label "PROGRAM_RESET" ;
    ex:identificador "PROGRAM_RESET" ;
    ex:textoExtracto "El canal ejecuta la subrutina asociada al reset (PROGRAM_RESET), si existe." ;
    ex:ejecutadoPor ex:ProcesoResetCNC .