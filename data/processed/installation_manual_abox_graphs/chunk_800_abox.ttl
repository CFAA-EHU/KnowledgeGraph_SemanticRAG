@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_ea1e95b1ed a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:ManualOperacionPLC ;
    ns1:textoExtracto "El PLC dispone de 1024 marcas para visualización de mensajes y 1024 marcas para visualizar errores en el CNC." .

ns1:Error1 a ns1:Parametro ;
    rdfs:label "Error 1" ;
    ns1:identificador "ERR1" ;
    ns1:textoExtracto "ERR1 - ERR1024 para visualizar errores." .

ns1:Mensaje1 a ns1:Parametro ;
    rdfs:label "Mensaje 1" ;
    ns1:identificador "MSG1" ;
    ns1:textoExtracto "MSG1 - MSG1024 para visualizar mensajes." .

ns1:TablaMensajesErroresPLC a ns1:Tabla ;
    rdfs:label "Tabla de mensajes y errores del PLC" ;
    ns1:textoExtracto "En el PLC hay una tabla de mensajes y errores en la que se puede asociar a cada mensaje o error lo siguiente:" .

ns1:ManualOperacionPLC a ns1:Manual ;
    rdfs:label "Manual de operación" ;
    ns1:textoExtracto "Para más información sobre cómo editar esta tabla consultar el manual de operación." .

