@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SeñalesModificablesGenerales a ex:Sistema ;
    ex:textoExtracto "AUXEND Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. AUXENDC1 (también se puede programar como AUXEND) AUXENDC2 AUXENDC3 AUXENDC4 Se utiliza en la ejecución de las funciones auxiliares S y M con sincronización. El funcionamiento es el siguiente: 1 2 3 4" ;
    ex:tieneComponente ex:AUXEND, ex:AUXENDC1, ex:AUXENDC2, ex:AUXENDC3, ex:AUXENDC4 .

ex:AUXEND a ex:ComponenteElectrico ;
    ex:textoExtracto "AUXEND Hay una marca para cada canal." ;
    rdfs:label "AUXEND" .

ex:AUXENDC1 a ex:ComponenteElectrico ;
    ex:textoExtracto "AUXENDC1 (también se puede programar como AUXEND)" ;
    rdfs:label "AUXENDC1" .

ex:AUXENDC2 a ex:ComponenteElectrico ;
    ex:textoExtracto "AUXENDC2" ;
    rdfs:label "AUXENDC2" .

ex:AUXENDC3 a ex:ComponenteElectrico ;
    ex:textoExtracto "AUXENDC3" ;
    rdfs:label "AUXENDC3" .

ex:AUXENDC4 a ex:ComponenteElectrico ;
    ex:textoExtracto "AUXENDC4" ;
    rdfs:label "AUXENDC4" .