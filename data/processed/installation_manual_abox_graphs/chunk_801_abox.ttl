@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivacionDeEmergencia a ns1:AvisoSeguridad ;
    rdfs:label "Activación de emergencia" ;
    ns1:textoExtracto "Si el error tiene seleccionado el campo \"Emergen\", el error abrirá el relé de emergencia del CNC." .

ns1:ActivacionDeMarcasERR a ns1:AvisoSeguridad ;
    rdfs:label "Activación de marcas ERR" ;
    ns1:textoExtracto "Al activarse una de las marcas ERR se detiene la ejecución del programa pieza y se muestra en el centro de la pantalla una ventana con el número de error y su texto asociado." .

ns1:CNC8070_a74c301076 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:DocumentoTecnicoInformacionAdicional ;
    ns1:textoExtracto "Errores de PLC. Al activarse una de las marcas ERR se detiene la ejecución del programa pieza y se muestra en el centro de la pantalla una ventana con el número de error y su texto asociado." .

ns1:ReleDeEmergencia_d01bc336bc a ns1:ComponenteElectrico ;
    rdfs:label "Relé de emergencia" ;
    ns1:textoExtracto "Si el error tiene seleccionado el campo \"Emergen\", el error abrirá el relé de emergencia del CNC." .

ns1:DocumentoTecnicoInformacionAdicional a ns1:DocumentoTecnico ;
    rdfs:label "Archivo de información adicional" ;
    ns1:textoExtracto "El archivo deberá ser de texto (extensión txt) y podrá tener cualquier nombre. La información de cada mensaje y error debe estar estructurada de acuerdo al siguiente formato: <texto> El campo <id>, manteniendo los corchetes, será el código de identificación del texto de ayuda dentro del archivo." .

