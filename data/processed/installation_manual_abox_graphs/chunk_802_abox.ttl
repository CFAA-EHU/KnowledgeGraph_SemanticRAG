    rdfs:label "Aviso de mensaje o error PLC" ;
    ns1:textoExtracto "Para asociar el mensaje de ayuda a un mensaje o error de PLC, el campo \"Archivo asociado\" hay que definirlo de la forma <archivo>#<id>." .

