@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:PRG_AUTOMAT_AND_INCYCLE ex:textoExtracto """PRG
AUTOMAT AND INCYCLE = TIMERON
Contador activo durante el mecanizado. ()= CNCRD (PLC.TIMER, R300, M12)
El registro R300 muestra el valor del contador. END""" ;
    a ex:ModoOperacion ;
    ex:identificador "PRG AUTOMAT AND INCYCLE" .

ex:PLC_TIMER ex:textoExtracto """PLC.TIMER""" ;
    a ex:Parametro ;
    ex:identificador "PLC.TIMER" .

ex:R300 ex:textoExtracto """R300""" ;
    a ex:Parametro ;
    ex:identificador "R300" .

ex:R100 ex:textoExtracto """R100""" ;
    a ex:Parametro ;
    ex:identificador "R100" .

ex:M11 ex:textoExtracto """M11""" ;
    a ex:Parametro ;
    ex:identificador "M11" .

ex:M12 ex:textoExtracto """M12""" ;
    a ex:Parametro ;
    ex:identificador "M12" .

ex:ContadorMecanizado ex:textoExtracto """Contador activo durante el mecanizado""" ;
    a ex:Sistema ;
    ex:identificador "ContadorMecanizado" .