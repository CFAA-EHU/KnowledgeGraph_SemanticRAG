@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Parametro_RAPIDEN
    a ex:Parametro ;
    rdfs:label "Parámetro RAPIDEN"@es ;
    ex:textoExtracto "El funcionamiento de esta marca depende de cómo esté definido el parámetro RAPIDEN."@es ;
    ex:identificador "RAPIDEN" .

ex:InterfazUsuario_TeclaAvanceRapido
    a ex:InterfazUsuario ;
    rdfs:label "Tecla de avance rápido del panel de mando"@es ;
    ex:textoExtracto "El tratamiento de esta señal es similar al de la tecla de avance rápido del panel de mando."@es .

ex:Parametro_PLCABORTC1
    a ex:Parametro ;
    rdfs:label "Marca PLCABORTC1 (PLCABORT)"@es ;
    ex:textoExtracto "PLCABORTC1 (también se puede programar como PLCABORT)"@es ;
    ex:identificador "PLCABORTC1" .

ex:Parametro_PLCABORTC2
    a ex:Parametro ;
    rdfs:label "Marca PLCABORTC2"@es ;
    ex:textoExtracto "PLCABORTC2"@es ;
    ex:identificador "PLCABORTC2" .

ex:Parametro_PLCABORTC3
    a ex:Parametro ;
    rdfs:label "Marca PLCABORTC3"@es ;
    ex:textoExtracto "PLCABORTC3"@es ;
    ex:identificador "PLCABORTC3" .

ex:Parametro_PLCABORTC4
    a ex:Parametro ;
    rdfs:label "Marca PLCABORTC4"@es ;
    ex:textoExtracto "PLCABORTC4"@es ;
    ex:identificador "PLCABORTC4" .

ex:Sistema_CNC
    a ex:Sistema ;
    rdfs:label "Sistema CNC (Control Numérico Computarizado)"@es ;
    ex:textoExtracto "el canal del CNC aborta el comando CNCEX lanzado desde el PLC"@es ;
    ex:tieneComponente ex:Parametro_RAPIDEN ;
    ex:tieneComponente ex:Parametro_PLCABORTC1 ;
    ex:tieneComponente ex:Parametro_PLCABORTC2 ;
    ex:tieneComponente ex:Parametro_PLCABORTC3 ;
    ex:tieneComponente ex:Parametro_PLCABORTC4 .

ex:Comando_CNCEX
    a ex:AccionProhibida ;
    rdfs:label "Comando CNCEX"@es ;
    ex:textoExtracto "el canal del CNC aborta el comando CNCEX lanzado desde el PLC"@es ;
    ex:identificador "CNCEX" .