@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EstadoDelAnilloSercos a ns1:Parametro ;
    rdfs:label "Estado del anillo Sercos" ;
    ns1:identificador "SERCOSRDY" ;
    ns1:textoExtracto "Esta marca indica el estado del anillo. El CNC pone esta marca a (=1) para indicar que el anillo Sercos se encuentra inicializado correctamente." .

ns1:EstadoDelCNC_279ec30b88 a ns1:Parametro ;
    rdfs:label "Estado del CNC" ;
    ns1:identificador "CNCREADY" ;
    ns1:textoExtracto "Esta marca indica el estado del CNC. Tiene el valor (=0) cuando el CNC se encuentra en estado de error (ventana de status en rojo) y el valor (=1) el resto de los casos." .

ns1:EstadoDelCanal1DelCNC a ns1:Parametro ;
    rdfs:label "Estado del canal 1 del CNC" ;
    ns1:identificador "READYC1" ;
    ns1:textoExtracto "Esta marca indica el estado del canal del CNC. Tiene el valor (=0) cuando el CNC se encuentra en estado de error (ventana de status en rojo) y el valor (=1) el resto de los casos." .

