@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_RAPIDEN a ex:Parametro ;
    rdfs:label "RAPIDEN" ;
    ex:textoExtracto "El funcionamiento de esta marca depende de cómo esté definido el parámetro RAPIDEN." .

ex:Tecla_AvanceRapido a ex:InterfazUsuario ;
    rdfs:label "tecla de avance rápido" ;
    ex:textoExtracto "El tratamiento de esta señal es similar al de la tecla de avance rápido del panel de mando." .

ex:Marca_PLCABORT a ex:ComponenteElectrico ;
    rdfs:label "PLCABORT" ;
    ex:textoExtracto "PLCABORT Hay una marca para cada canal." .

ex:Marca_PLCABORTC1 a ex:ComponenteElectrico ;
    rdfs:label "PLCABORTC1" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. PLCABORTC1 (también se puede programar como PLCABORT)" .

ex:Marca_PLCABORTC2 a ex:ComponenteElectrico ;
    rdfs:label "PLCABORTC2" ;
    ex:textoExtracto "PLCABORTC2" .

ex:Marca_PLCABORTC3 a ex:ComponenteElectrico ;
    rdfs:label "PLCABORTC3" ;
    ex:textoExtracto "PLCABORTC3" .

ex:Marca_PLCABORTC4 a ex:ComponenteElectrico ;
    rdfs:label "PLCABORTC4" ;
    ex:textoExtracto "PLCABORTC4" .

ex:Accion_AbortarCanal a ex:AccionProhibida ;
    rdfs:label "abortar el comando CNCEX" ;
    ex:textoExtracto "Si el PLC pone esta marca a (=1), el canal del CNC aborta el comando CNCEX lanzado desde el PLC, pero sin inicializar las condiciones del canal y manteniendo la historia del canal." .

ex:ModoOperacion_CNCEX a ex:ModoOperacion ;
    rdfs:label "CNCEX" ;
    ex:textoExtracto "el canal del CNC aborta el comando CNCEX lanzado desde el PLC" .

ex:ModoOperacion_MDI a ex:ModoOperacion ;
    rdfs:label "MDI" ;
    ex:textoExtracto "Esta marca sólo es válida cuando el canal está ejecutando un CNCEX; no en otras ejecuciones de programa o MDI." .