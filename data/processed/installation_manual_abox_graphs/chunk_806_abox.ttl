@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:CNCEX a ex:ModoOperacion ;
    ex:textoExtracto "CNCEX" .

ex:marcaFREE a ex:Parametro ;
    ex:identificador "FREE" ;
    ex:textoExtracto "marca FREE del canal a (=1)" .

ex:marcaPLCABORT a ex:Parametro ;
    ex:identificador "PLCABORT" ;
    ex:textoExtracto "marca PLCABORT" .

ex:marcaPRGABORT a ex:Parametro ;
    ex:textoExtracto "marca PRGABORT" .

ex:PRGABORTC1 a ex:Parametro ;
    ex:identificador "PRGABORTC1" ;
    ex:textoExtracto "PRGABORTC1 (también se puede programar como PRGABORT)" .

ex:PRGABORTC2 a ex:Parametro ;
    ex:identificador "PRGABORTC2" ;
    ex:textoExtracto "PRGABORTC2" .

ex:PRGABORTC3 a ex:Parametro ;
    ex:identificador "PRGABORTC3" ;
    ex:textoExtracto "PRGABORTC3" .

ex:PRGABORTC4 a ex:Parametro ;
    ex:identificador "PRGABORTC4" ;
    ex:textoExtracto "PRGABORTC4" .

ex:marcaNEXTMPGAXIS a ex:Parametro ;
    ex:identificador "NEXTMPGAXIS" ;
    ex:textoExtracto "marca NEXTMPGAXIS" .

ex:marcaCanal a ex:Parametro ;
    ex:identificador "marca para cada canal" ;
    ex:textoExtracto "Hay una marca para cada canal" .

ex:etiquetaABORT a ex:Parametro ;
    ex:identificador "#ABORT" ;
    ex:textoExtracto "etiqueta indicada en la sentencia #ABORT activa en el programa pieza" .

ex:selectorVolante a ex:InterfazUsuario ;
    ex:textoExtracto "selector en modo volante" .

ex:modoManual a ex:ModoOperacion ;
    ex:textoExtracto "modo manual" .

ex:canalCNC a ex:Sistema ;
    ex:textoExtracto "canal del CNC" .

ex:programaPieza a ex:TareaMantenimiento ;
    ex:textoExtracto "programa pieza" .