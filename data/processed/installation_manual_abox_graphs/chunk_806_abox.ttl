@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_4d397e7c4c a ns1:Parametro ;
    rdfs:label "Marca RESETOUT para cada canal" ;
    ns1:identificador "RESETOUT" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. RESETOUTC1 (también se puede programar como RESETOUT)" .

ns1:Parametro_642ca6fcdc a ns1:Parametro ;
    rdfs:label "Marca CYSTART para inicio de ejecución del programa" ;
    ns1:identificador "CYSTART" ;
    ns1:textoExtracto "el PLC debe activar la marca CYSTART para que comience la ejecución del programa." .

ns1:Parametro_e7a901260a a ns1:Parametro ;
    rdfs:label "Marca RESETOUT para el canal 1" ;
    ns1:identificador "RESETOUTC1" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. RESETOUTC1 (también se puede programar como RESETOUT)" .

