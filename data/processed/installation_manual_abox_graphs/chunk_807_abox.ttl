@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ModoSeleccionEjes_807
    a                     ex:ModoOperacion ;
    rdfs:label            "Modo de selección cíclica de ejes"@es ;
    ex:textoExtracto      "Si no hay ningún eje seleccionado, selecciona el primer eje que se está visualizando. Si hay un eje seleccionado, selecciona el siguiente; si el eje seleccionado es el último, vuelve a seleccionar el primero. La selección de ejes se anula al salir del modo volante con el selector de movimientos y tras un reset."@es .

ex:SelectorMovimientos_807
    a                     ex:InterfazUsuario ;
    rdfs:label            "Selector de movimientos (modo volante)"@es ;
    ex:textoExtracto      "La selección de ejes se anula al salir del modo volante con el selector de movimientos"@es ;
    ex:habilitadoPor      ex:ModoSeleccionEjes_807 .

ex:PulsadorVolante_807
    a                     ex:InterfazUsuario ;
    rdfs:label            "Pulsador de volante"@es ;
    ex:textoExtracto      "Esta marca está orientada a los volantes con pulsador."@es .