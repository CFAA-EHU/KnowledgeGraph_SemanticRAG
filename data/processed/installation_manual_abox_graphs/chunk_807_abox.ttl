@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoVolanteSeleccionEje a ex:ModoOperacion ;
    rdfs:label "modo volante con selector de movimientos"@es ;
    ex:textoExtracto "Esta marca está orientada a los volantes con pulsador. En este modo volante con selector de movimientos"@es .

ex:SelectorMovimientos a ex:Componente ;
    rdfs:label "selector de movimientos"@es ;
    ex:textoExtracto "tras un reset. Esta marca está orientada a los volantes con pulsador. En este modo volante con selector de movimientos"@es .

ex:Eje a ex:ComponenteMecanico ;
    rdfs:label "eje"@es ;
    ex:textoExtracto "Si no hay ningún eje seleccionado, selecciona el primer eje que se está visualizando. • Si hay un eje seleccionado, selecciona el siguiente; si el eje seleccionado es el último, vuelve a seleccionar el primero."@es .