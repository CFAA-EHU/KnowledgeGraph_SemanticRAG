ns1:CNC8070_34ba250400 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El canal del CNC activa esta marca (nivel \"0\") cuando hay una alarma, una emergencia generada por el canal del CNC o cuando el PLC activa señal de emergencia _EMERGEN."@es .

ns1:ComponenteElectrico_177cedc53e a ns1:ComponenteElectrico ;
