@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_ddf4cf6054 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:ReleDeEmergencia_0dbef62eaf ;
    ns1:solucionaFallo ns1:ColisionEnMovimientoDePosicionamientoORetirada ;
    ns1:textoExtracto "El canal del CNC desactiva esta marca (nivel \"1\") cuando se ha eliminado el mensaje del canal del CNC y ha desaparecido la causa de la alarma o emergencia." .

ns1:senalAlarm a ns1:Parametro ;
    rdfs:label "Señal de alarma" ;
    ns1:identificador "_ALARM" ;
    ns1:textoExtracto "detiene el movimiento, muestra el error correspondiente, abre el relé de emergencia y activa la señal _ALARM (nivel \"0\")." .

ns1:ColisionEnMovimientoDePosicionamientoORetirada a ns1:DiagnosticoFallo ;
    rdfs:label "Colisión en movimiento de posicionamiento o retirada" ;
    ns1:textoExtracto "Colisión en movimiento de posicionamiento o retirada" .

ns1:ReleDeEmergencia_0dbef62eaf a ns1:Alarma ;
    rdfs:label "Relé de emergencia" ;
    ns1:textoExtracto "detiene el movimiento, muestra el error correspondiente, abre el relé de emergencia y activa la señal _ALARM (nivel \"0\")." .

