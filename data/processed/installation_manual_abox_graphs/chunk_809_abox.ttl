ns1:CNC8070_74cdffc85d a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El canal del CNC pone esta marca a (=1) cuando está seleccionado el modo MDI (introducción manual de datos)." .

