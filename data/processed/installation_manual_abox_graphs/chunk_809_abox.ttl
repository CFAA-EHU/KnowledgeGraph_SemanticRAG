@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla_809_6_8 a ex:Tabla ;
    ex:textoExtracto """| Address | Elemento | Marca de PLC |
| --- | --- | --- |
| 0 | CNC |  |
| 1 | Grupo remoto (I/Os) |  |
| 2 | Panel de jog | PANELOFF1 |
| 3 | Grupo remoto (I/Os) |  |
| 4 | Grupo remoto (I/Os) |  |
| 5 | Teclado + Panel de jog | PANELOFF2 |""" ;
    ex:tieneComponente ex:Componente_0_809, ex:Componente_1_809, ex:Componente_2_809, ex:Componente_3_809, ex:Componente_4_809, ex:Componente_5_809 .

ex:Componente_0_809 a ex:Maquina ;
    ex:textoExtracto "CNC" ;
    ex:identificador "0" .

ex:Componente_1_809 a ex:Sistema ;
    ex:textoExtracto "Grupo remoto (I/Os)" ;
    ex:identificador "1" .

ex:Componente_2_809 a ex:InterfazUsuario ;
    ex:textoExtracto "Panel de jog" ;
    ex:identificador "2" ;
    ex:identificador "PANELOFF1" .

ex:Componente_3_809 a ex:Sistema ;
    ex:textoExtracto "Grupo remoto (I/Os)" ;
    ex:identificador "3" .

ex:Componente_4_809 a ex:Sistema ;
    ex:textoExtracto "Grupo remoto (I/Os)" ;
    ex:identificador "4" .

ex:Componente_5_809 a ex:InterfazUsuario ;
    ex:textoExtracto "Teclado + Panel de jog" ;
    ex:identificador "5" ;
    ex:identificador "PANELOFF2" .