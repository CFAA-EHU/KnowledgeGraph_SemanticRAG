@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_Se_alesModificablesGenerales
    a ex:Tabla ;
    rdfs:label "Tabla de direcciones de señales modificables generales"@es ;
    ex:textoExtracto """
| Address | Elemento | Marca de PLC |
| --- | --- | --- |
| 0 | CNC |  |
| 1 | Grupo remoto (I/Os) |  |
| 2 | Panel de jog | PANELOFF1 |
| 3 | Grupo remoto (I/Os) |  |
| 4 | Grupo remoto (I/Os) |  |
| 5 | Teclado + Panel de jog | PANELOFF2
""" .

ex:InterfazUsuario_CNC
    a ex:InterfazUsuario ;
    ex:identificador "0" ;
    ex:textoExtracto "CNC"@es ;
    ex:documentadoEn ex:Tabla_Se_alesModificablesGenerales .

ex:ComponenteElectrico_GrupoRemotoIO_1
    a ex:ComponenteElectrico ;
    ex:identificador "1" ;
    ex:textoExtracto "Grupo remoto (I/Os)"@es ;
    ex:documentadoEn ex:Tabla_Se_alesModificablesGenerales .

ex:InterfazUsuario_PanelJog_2
    a ex:InterfazUsuario ;
    ex:identificador "PANELOFF1" ;
    ex:textoExtracto "Panel de jog"@es ;
    ex:documentadoEn ex:Tabla_Se_alesModificablesGenerales .

ex:ComponenteElectrico_GrupoRemotoIO_3
    a ex:ComponenteElectrico ;
    ex:identificador "3" ;
    ex:textoExtracto "Grupo remoto (I/Os)"@es ;
    ex:documentadoEn ex:Tabla_Se_alesModificablesGenerales .

ex:ComponenteElectrico_GrupoRemotoIO_4
    a ex:ComponenteElectrico ;
    ex:identificador "4" ;
    ex:textoExtracto "Grupo remoto (I/Os)"@es ;
    ex:documentadoEn ex:Tabla_Se_alesModificablesGenerales .

ex:InterfazUsuario_TecladoPanelJog_5
    a ex:InterfazUsuario ;
    ex:identificador "PANELOFF2" ;
    ex:textoExtracto "Teclado + Panel de jog"@es ;
    ex:documentadoEn ex:Tabla_Se_alesModificablesGenerales .