@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_NRETBLK
    a ex:Parametro ;
    rdfs:label "NRETBLK" ;
    ex:textoExtracto "El número máximo de bloques a ejecutar en retrace lo define el parámetro máquina NRETBLK." ;
    ex:identificador "NRETBLK" .

ex:ModoOperacion_Retrace
    a ex:ModoOperacion ;
    rdfs:label "Retrace" ;
    ex:textoExtracto "La función retrace se puede activar durante una interpolación, a mitad de un bloque, y también al final del bloque, tanto si la ejecución está detenida por M0 como por el modo bloque a bloque." ;
    ex:monitoreaParametro ex:Parametro_NRETBLK .

ex:ModoOperacion_BlockToBlock
    a ex:ModoOperacion ;
    rdfs:label "Bloque a bloque" ;
    ex:textoExtracto "modo bloque a bloque" .

ex:ModoOperacion_DetencionM0
    a ex:ModoOperacion ;
    rdfs:label "Detención por M0" ;
    ex:textoExtracto "tanto si la ejecución está detenida por M0" .