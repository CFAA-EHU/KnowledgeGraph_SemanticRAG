@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_NRETBLK a ex:Parametro ;
    rdfs:label "NRETBLK" ;
    ex:textoExtracto "El número máximo de bloques a ejecutar en retrace lo define el parámetro máquina NRETBLK." ;
    ex:identificador "NRETBLK" .

ex:Accion_ReactivarRetrace a ex:AccionProhibida ;
    rdfs:label "activar retrace" ;
    ex:textoExtracto "La función retrace se puede activar durante una interpolación, a mitad de un bloque, y también al final del bloque, tanto si la ejecución está detenida por M0 como por el modo bloque a bloque." .

ex:Accion_DetenerRetrace a ex:AccionProhibida ;
    rdfs:label "detener retrace" ;
    ex:textoExtracto "Si el PLC pone a (=0) esta marca, finaliza la función RETRACE." .

ex:Accion_FinalizarRetrace a ex:AccionProhibida ;
    rdfs:label "finalizar retrace" ;
    ex:textoExtracto "La función retrace también finaliza" .