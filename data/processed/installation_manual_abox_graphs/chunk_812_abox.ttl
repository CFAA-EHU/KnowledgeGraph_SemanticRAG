@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:ModoBloqueABlocke ex:textoExtracto """tanto si la ejecución está detenida por M0 como por el modo bloque a bloque.""" .
ex:ModoBloqueABlocke a ex:ModoOperacion .

ex:FuncionRETRACE a ex:Tabla ;
    ex:textoExtracto """La función retrace también finaliza tras ejecutar M30, con un reset y cuando el canal del CNC pone a (=1) la marca RETRAEND.""" .
ex:FuncionRETRACE a ex:AccionProhibida .

ex:MarcaRETRACAC ex:textoExtracto """La función retrace debe estar habilitada en el parámetro máquina RETRACAC.""" .
ex:MarcaRETRACAC a ex:Parametro ;
    ex:identificador "RETRACAC" ;
    ex:textoExtracto """La función retrace debe estar habilitada en el parámetro máquina RETRACAC.""" .

ex:MarcaRETRAEND ex:textoExtracto """cuando el canal del CNC pone a (=1) la marca RETRAEND.""" .
ex:MarcaRETRAEND a ex:Parametro ;
    ex:identificador "RETRAEND" ;
    ex:textoExtracto """cuando el canal del CNC pone a (=1) la marca RETRAEND.""" .

ex:MarcaINHIBITMPG1 ex:textoExtracto """INHIBITMPG1 INHIBITMPG12 Si el PLC activa una de estas marcas, se deshabilita el volante correspondiente. El PLC dispone de una marca para cada volante; la marca INHIBITMPG1 deshabilita el primer volante, la marca INHIBITMPG2 el segundo y así sucesivamente.""" .
ex:MarcaINHIBITMPG1 a ex:Parametro ;
    ex:identificador "INHIBITMPG1" ;
    ex:textoExtracto """INHIBITMPG1 INHIBITMPG12 Si el PLC activa una de estas marcas, se deshabilita el volante correspondiente. El PLC dispone de una marca para cada volante; la marca INHIBITMPG1 deshabilita el primer volante, la marca INHIBITMPG2 el segundo y así sucesivamente.""" .

ex:MarcaINHIBITMPG2 ex:textoExtracto """INHIBITMPG1 INHIBITMPG12 Si el PLC activa una de estas marcas, se deshabilita el volante correspondiente. El PLC dispone de una marca para cada volante; la marca INHIBITMPG1 deshabilita el primer volante, la marca INHIBITMPG2 el segundo y así sucesivamente.""" .
ex:MarcaINHIBITMPG2 a ex:Parametro ;
    ex:identificador "INHIBITMPG2" ;
    ex:textoExtracto """INHIBITMPG1 INHIBITMPG12 Si el PLC activa una de estas marcas, se deshabilita el volante correspondiente. El PLC dispone de una marca para cada volante; la marca INHIBITMPG1 deshabilita el primer volante, la marca INHIBITMPG2 el segundo y así sucesivamente.""" .

ex:VariableG_HANDP ex:textoExtracto """( V.)G.HANDP[hw] Número de impulsos enviados por el volante desde el arranque del sistema.""" .
ex:VariableG_HANDP a ex:Parametro ;
    ex:identificador "G.HANDP[hw]" ;
    ex:textoExtracto """( V.)G.HANDP[hw] Número de impulsos enviados por el volante desde el arranque del sistema.""" .

ex:MarcaENABLEAxis ex:textoExtracto """Si se trata de un volante individual, asociado a un eje, la marca ENABLE(axis) del eje permanecerá activa.""" .
ex:MarcaENABLEAxis a ex:Parametro ;
    ex:textoExtracto """Si se trata de un volante individual, asociado a un eje, la marca ENABLE(axis) del eje permanecerá activa.""" .

ex:RegistroKEYBD1CH ex:textoExtracto """KEYBD1CH KEYBD8CH En el arranque, el CNC siempre asume la configuración de teclados definida en los parámetros máquina.""" .
ex:RegistroKEYBD1CH a ex:Parametro ;
    ex:identificador "KEYBD1CH" ;
    ex:textoExtracto """KEYBD1CH KEYBD8CH En el arranque, el CNC siempre asume la configuración de teclados definida en los parámetros máquina.""" .

ex:RegistroKEYBD8CH ex:textoExtracto """KEYBD1CH KEYBD8CH En el arranque, el CNC siempre asume la configuración de teclados definida en los parámetros máquina.""" .
ex:RegistroKEYBD8CH a ex:Parametro ;
    ex:identificador "KEYBD8CH" ;
    ex:textoExtracto """KEYBD1CH KEYBD8CH En el arranque, el CNC siempre asume la configuración de teclados definida en los parámetros máquina.""" .