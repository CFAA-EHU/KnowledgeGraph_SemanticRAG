@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:KEYBD1CH a ex:Parametro ;
    ex:identificador "KEYBD1CH" ;
    ex:textoExtracto "KEYBD1CH" .

ex:KEYBD8CH a ex:Parametro ;
    ex:identificador "KEYBD8CH" ;
    ex:textoExtracto "KEYBD8CH" .

ex:PanelJogCanal1 a ex:ComponenteElectrico ;
    ex:textoExtracto "Panel de jog asignado al canal 1" .

ex:PanelJogCanal2 a ex:ComponenteElectrico ;
    ex:textoExtracto "Panel de jog asignado al canal 2" .

ex:PanelJogCanal3 a ex:ComponenteElectrico ;
    ex:textoExtracto "Panel de jog asignado al canal 3" .

ex:PanelJogCanal4 a ex:ComponenteElectrico ;
    ex:textoExtracto "Panel de jog asignado al canal 4" .

ex:PanelJogCanalActivo a ex:ComponenteElectrico ;
    ex:textoExtracto "Panel de jog asignado al canal activo" .

ex:VOLCOMP1 a ex:Parametro ;
    ex:identificador "VOLCOMP1" ;
    ex:textoExtracto "VOLCOMP1" .

ex:VOLCOMP4 a ex:Parametro ;
    ex:identificador "VOLCOMP4" ;
    ex:textoExtracto "VOLCOMP4" .

ex:ParametroConfiguracionMaquina a ex:Parametro ;
    ex:textoExtracto "Configuración definida en los parámetros máquina" .

ex:Tabla6_8 a ex:Tabla ;
    ex:textoExtracto "| KEYBD1CH\nꞏꞏ\nKEYBD8CH | Significado. |\n| --- | --- |\n| 0 | Configuración definida en los parámetros máquina. |\n| 1 | Panel de jog asignado al canal 1. |\n| 2 | Panel de jog asignado al canal 2. |\n| 3 | Panel de jog asignado al canal 3. |\n| 4 | Panel de jog asignado al canal 4. |\n| FF | Panel de jog asignado al canal activo. |\n VOLCOMP1 VOLCOMP4 Si el PLC activa una de estas marcas (cambio de 0 a 1), el CNC activa la compensación volumétrica correspondiente (parámetro VOLCOMP). Si el PLC desactiva una de estas marcas (cambio de 1 a 0), el CNC desactiva la compensación volumétrica correspondiente." ;
    ex:tieneComponente ex:KEYBD1CH, ex:KEYBD8CH, ex:ParametroConfiguracionMaquina, ex:PanelJogCanal1, ex:PanelJogCanal2, ex:PanelJogCanal3, ex:PanelJogCanal4, ex:PanelJogCanalActivo, ex:VOLCOMP1, ex:VOLCOMP4 .