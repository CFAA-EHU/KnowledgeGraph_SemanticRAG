@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvisoSeguridad_35ee523869 a ns1:AvisoSeguridad ;
    rdfs:label "Marca ADVINPOS" ;
    ns1:textoExtracto "También puede utilizarse la marca ADVINPOS. Ver en la página 414." .

ns1:AvisoSeguridad_d12e9572cf a ns1:AvisoSeguridad ;
    rdfs:label "Marca INTEREND" ;
    ns1:textoExtracto "La marca INTEREND puede utilizarse para activar mecanismos antes de llegar los ejes a posición." .

ns1:IndicadorDePosicionAlcanzadaPorEjesYCabezalesActivos a ns1:Parametro ;
    rdfs:label "Indicador de posición alcanzada por ejes y cabezales activos" ;
    ns1:identificador "INPOSI" ;
    ns1:textoExtracto "El canal del CNC pone la marca INPOSI a (=1) para indicar que todos sus ejes y cabezales activos han llegado a posición, exceptuando los ejes independientes programados desde el PLC." .

ns1:IndicadorDePosicionDelCanal1 a ns1:Parametro ;
    rdfs:label "Indicador de posición del canal 1" ;
    ns1:identificador "INPOSIC1" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. INPOSIC1 (también se puede programar como INPOSI o INPOS)" .

ns1:IndicadorDePosicionDelCanal2 a ns1:Parametro ;
    rdfs:label "Indicador de posición del canal 2" ;
    ns1:identificador "INPOSIC2" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. INPOSIC2" .

ns1:IndicadorDePosicionDelCanal3 a ns1:Parametro ;
    rdfs:label "Indicador de posición del canal 3" ;
    ns1:identificador "INPOSIC3" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. INPOSIC3" .

ns1:IndicadorDePosicionDelCanal4 a ns1:Parametro ;
    rdfs:label "Indicador de posición del canal 4" ;
    ns1:identificador "INPOSIC4" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. INPOSIC4" .

