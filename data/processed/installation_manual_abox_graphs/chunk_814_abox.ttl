@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:VOLCOMP1 a ex:Parametro ;
    ex:textoExtracto "Activar la primera compensación volumétrica (parámetro maquina VOLCOMP1)." ;
    rdfs:label "VOLCOMP1" .

ex:VOLCOMP2 a ex:Parametro ;
    ex:textoExtracto "Activar la segunda compensación volumétrica (parámetro maquina VOLCOMP2)." ;
    rdfs:label "VOLCOMP2" .

ex:VOLCOMP3 a ex:Parametro ;
    ex:textoExtracto "Activar la tercera compensación volumétrica (parámetro maquina VOLCOMP3)." ;
    rdfs:label "VOLCOMP3" .

ex:VOLCOMP4 a ex:Parametro ;
    ex:textoExtracto "Activar la cuarta compensación volumétrica (parámetro maquina VOLCOMP4)." ;
    rdfs:label "VOLCOMP4" .