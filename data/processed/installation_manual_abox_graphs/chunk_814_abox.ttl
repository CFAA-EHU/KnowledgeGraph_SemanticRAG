@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_Se_alesModificablesGenerales_6.8
    a ex:Tabla ;
    rdfs:label "Tabla de señales modificables generales (Sección 6.8)" ;
    ex:textoExtracto "Marca. | Significado. --- | --- VOLCOMP1 | Activar la primera compensación volumétrica (parámetro maquina VOLCOMP1). VOLCOMP2 | Activar la segunda compensación volumétrica (parámetro maquina VOLCOMP2). VOLCOMP3 | Activar la tercera compensación volumétrica (parámetro maquina VOLCOMP3). VOLCOMP4 | Activar la cuarta compensación volumétrica (parámetro maquina VOLCOMP4)." .

ex:Parametro_VOLCOMP1
    a ex:Parametro ;
    rdfs:label "VOLCOMP1" ;
    ex:identificador "VOLCOMP1" ;
    ex:textoExtracto "Activar la primera compensación volumétrica (parámetro maquina VOLCOMP1)." ;
    ex:documentadoEn ex:Tabla_Se_alesModificablesGenerales_6.8 .

ex:Parametro_VOLCOMP2
    a ex:Parametro ;
    rdfs:label "VOLCOMP2" ;
    ex:identificador "VOLCOMP2" ;
    ex:textoExtracto "Activar la segunda compensación volumétrica (parámetro maquina VOLCOMP2)." ;
    ex:documentadoEn ex:Tabla_Se_alesModificablesGenerales_6.8 .

ex:Parametro_VOLCOMP3
    a ex:Parametro ;
    rdfs:label "VOLCOMP3" ;
    ex:identificador "VOLCOMP3" ;
    ex:textoExtracto "Activar la tercera compensación volumétrica (parámetro maquina VOLCOMP3)." ;
    ex:documentadoEn ex:Tabla_Se_alesModificablesGenerales_6.8 .

ex:Parametro_VOLCOMP4
    a ex:Parametro ;
    rdfs:label "VOLCOMP4" ;
    ex:identificador "VOLCOMP4" ;
    ex:textoExtracto "Activar la cuarta compensación volumétrica (parámetro maquina VOLCOMP4)." ;
    ex:documentadoEn ex:Tabla_Se_alesModificablesGenerales_6.8 .