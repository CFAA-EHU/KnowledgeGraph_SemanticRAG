@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_fb531870a7 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El canal del CNC pone la marca INPOSI a (=1) para indicar que todos sus ejes y cabezales activos han llegado a posición, exceptuando los ejes independientes programados desde el PLC." ;
    ns1:tieneComponente ns1:BandaDeMuerte,
        ns1:Parametro_348f2bb567,
        ns1:RegistroSPN1C1,
        ns1:RegistroSPN1C2,
        ns1:RegistroSPN1C3,
        ns1:RegistroSPN1C4,
        ns1:TiempoDePosicion .

ns1:BandaDeMuerte a ns1:Parametro ;
    rdfs:label "Banda de muerte" ;
    ns1:identificador "INPOSW" ;
    ns1:textoExtracto "Un eje está en posición cuando permanece dentro de la banda de muerte (parámetro INPOSW)" .

ns1:Parametro_348f2bb567 a ns1:Parametro ;
    rdfs:label "Marca de posición" ;
    ns1:identificador "INPOSI" ;
    ns1:textoExtracto "La marca INPOSI permanece a (=1) durante el movimiento de los ejes independientes." .

ns1:RegistroSPN1C1 a ns1:ComponenteElectrico ;
    rdfs:label "Registro SPN1C1" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. Se muestra como ejemplo los mnemónicos de SPN1; para el resto de registros es equivalente. SPN1C1 SPN1C2 SPN1C3 SPN1C4" .

ns1:RegistroSPN1C2 a ns1:ComponenteElectrico ;
    rdfs:label "Registro SPN1C2" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. Se muestra como ejemplo los mnemónicos de SPN1; para el resto de registros es equivalente. SPN1C1 SPN1C2 SPN1C3 SPN1C4" .

ns1:RegistroSPN1C3 a ns1:ComponenteElectrico ;
    rdfs:label "Registro SPN1C3" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. Se muestra como ejemplo los mnemónicos de SPN1; para el resto de registros es equivalente. SPN1C1 SPN1C2 SPN1C3 SPN1C4" .

ns1:RegistroSPN1C4 a ns1:ComponenteElectrico ;
    rdfs:label "Registro SPN1C4" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. Se muestra como ejemplo los mnemónicos de SPN1; para el resto de registros es equivalente. SPN1C1 SPN1C2 SPN1C3 SPN1C4" .

ns1:TiempoDePosicion a ns1:Parametro ;
    rdfs:label "Tiempo de posición" ;
    ns1:identificador "INPOTIME" ;
    ns1:textoExtracto "el tiempo indicado en el parámetro INPOTIME." .

