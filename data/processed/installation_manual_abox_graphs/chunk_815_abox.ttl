@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:MarcasQWERTYOFF
    a ex:InterfazUsuario ;
    rdfs:label "Marcas QWERTYOFF (1-8)" ;
    ex:textoExtracto "QWERTYOFF1 QWERTYOFF8 [...] Cada marca permite deshabilitar un teclado USB (modelo 10K) o uno integrado en el bus CAN (modelo 15\")." ;
    ex:controla ex:TecladoAlfanumericoUSB_10K, ex:TecladoCAN_15in .

ex:TecladoAlfanumericoUSB_10K
    a ex:InterfazUsuario ;
    rdfs:label "Teclado alfanumérico USB (modelo 10K)" ;
    ex:textoExtracto "teclado alfanumérico correspondiente [...] modelo 10K [...] interface USB" ;
    ex:identificador "10K" .

ex:TecladoCAN_15in
    a ex:InterfazUsuario ;
    rdfs:label "Teclado CAN integrado (modelo 15\")" ;
    ex:textoExtracto "teclado integrado en el bus CAN (modelo 15\")" ;
    ex:identificador "15\"" .

ex:MarcaFLIMITAC
    a ex:Parametro ;
    rdfs:label "Marca FLIMITAC" ;
    ex:textoExtracto "FLIMITAC [...] el CNC activa los límites de seguridad para el avance (parámetro FLIMIT) en todos los ejes del sistema" ;
    ex:monitoreaParametro ex:ParametroFLIMIT .

ex:ParametroFLIMIT
    a ex:Parametro ;
    rdfs:label "Parámetro FLIMIT" ;
    ex:textoExtracto "límite de seguridad para el avance (parámetro FLIMIT)" ;
    ex:valor "FLIMIT" .

ex:MarcaFLIMITACCH
    a ex:Parametro ;
    rdfs:label "Marca FLIMITACCH" ;
    ex:textoExtracto "FLIMITACCH [...] Hay una marca para cada canal." .