@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_2a9e321433 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:monitoreaParametro ns1:GiroADerechasDelCabezalS1A1000Rpm,
        ns1:GiroAIzquierdasDelCabezalS2A500Rpm ;
    ns1:textoExtracto "Si no se utilizan todos los registros, el CNC asigna el valor hexadecimal $FFFFFFFF a los que queden libres, los de numeración más alta." .

ns1:GiroADerechasDelCabezalS1A1000Rpm a ns1:Parametro ;
    rdfs:label "Giro a derechas del cabezal S1 a 1000 rpm" ;
    ns1:identificador "M3.S1" ;
    ns1:textoExtracto "M3.S1 S1=1000 Giro a derechas del cabezal S1 a 1000 rpm y giro a izquierdas del cabezal S2 a 500 rpm." .

ns1:GiroAIzquierdasDelCabezalS2A500Rpm a ns1:Parametro ;
    rdfs:label "Giro a izquierdas del cabezal S2 a 500 rpm" ;
    ns1:identificador "M4.S2" ;
    ns1:textoExtracto "M3.S1 S1=1000 M4.S2 S2=500 Giro a derechas del cabezal S1 a 1000 rpm y giro a izquierdas del cabezal S2 a 500 rpm." .

