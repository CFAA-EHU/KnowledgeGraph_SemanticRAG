ns1:Parametro_11d8c4e6c5 a ns1:Parametro ;
    rdfs:label "Función programada en el primer canal" ;
    ns1:identificador "MFUN2C1" ;
    ns1:textoExtracto "De esta forma si en el primer canal se encuentran programadas las funciones M100 y M135 y en el segundo canal las funciones M88 y M75, el CNC pasará al PLC la siguiente información." .

