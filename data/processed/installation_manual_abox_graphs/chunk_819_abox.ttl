@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SubrutinaInterrupcion1 a ex:ModoOperacion ;
    ex:textoExtracto "Si la subrutina finaliza con M30, también finaliza la ejecución del programa." ;
    ex:valor "M30" .

ex:SubrutinaInterrupcion2 a ex:ModoOperacion ;
    ex:textoExtracto "Si el programa está interrumpido (STOP) o no hay programa en ejecución (canal en estado READY) la ejecución de la subrutina depende del parámetro SUBINTSTOP." ;
    ex:valor "SUBINTSTOP" .

ex:SubrutinaInterrupcion3 a ex:ModoOperacion ;
    ex:textoExtracto "para poder ejecutar la subrutina cuando no hay programa en ejecución, el canal debe estar en modo automático; no se permite ejecutar la subrutina desde el modo manual." .

ex:SubrutinaInterrupcion4 a ex:ModoOperacion ;
    ex:textoExtracto "La ejecución de una subrutina de interrupción se podrá interrumpir a su vez mediante un STOP, pero no por otra subrutina de interrupción." .

ex:SubrutinaInterrupcion5 a ex:ModoOperacion ;
    ex:textoExtracto "Cuando una subrutina esté interrumpida, no se podrá entrar en el modo inspección." .

ex:SubrutinaInterrupcion6 a ex:ModoOperacion ;
    ex:textoExtracto "El CNC desactiva la marca al comenzar a ejecutar la subrutina o cuando rechaza la ejecución de la subrutina." .

ex:ParametroINT1SUB a ex:Parametro ;
    ex:textoExtracto "asociada a los parámetros INT1SUB a INT4SUB" ;
    ex:valor "INT1SUB" .

ex:ParametroINT2SUB a ex:Parametro ;
    ex:textoExtracto "asociada a los parámetros INT1SUB a INT4SUB" ;
    ex:valor "INT2SUB" .

ex:ParametroINT3SUB a ex:Parametro ;
    ex:textoExtracto "asociada a los parámetros INT1SUB a INT4SUB" ;
    ex:valor "INT3SUB" .

ex:ParametroINT4SUB a ex:Parametro ;
    ex:textoExtracto "asociada a los parámetros INT1SUB a INT4SUB" ;
    ex:valor "INT4SUB" .

ex:ParametroSUBINTSTOP a ex:Parametro ;
    ex:textoExtracto "la ejecución de la subrutina depende del parámetro SUBINTSTOP" ;
    ex:valor "SUBINTSTOP" .

ex:MarcaPROBE1ENA a ex:Parametro ;
    ex:textoExtracto "PROBE1ENA Marcas activas por defecto. Estas marcas indican que el palpador está habilitado." ;
    ex:valor "PROBE1ENA" .

ex:MarcaPROBE2ENA a ex:Parametro ;
    ex:textoExtracto "PROBE1ENA Marcas activas por defecto. Estas marcas indican que el palpador está habilitado." ;
    ex:valor "PROBE2ENA" .

ex:MarcaPROBE1MONIT a ex:Parametro ;
    ex:textoExtracto "PROBE1MONIT Estas marcas están asociadas al modo seguro del palpador. Si la marca está activa, el palpador está en modo seguro monitorizando colisiones." ;
    ex:valor "PROBE1MONIT" .

ex:MarcaPROBE2MONIT a ex:Parametro ;
    ex:textoExtracto "PROBE1MONIT Estas marcas están asociadas al modo seguro del palpador. Si la marca está activa, el palpador está en modo seguro monitorizando colisiones." ;
    ex:valor "PROBE2MONIT" .

ex:SubrutinaProbeToolBegin a ex:TareaMantenimiento ;
    ex:textoExtracto "Estas marcas se deberían testear en las subrutinas Sub_Probe_Tool_Begin.fst y Sub_Probe_Piece_Begin.fst, de modo que la subrutina espere hasta que la marca esté activa." ;
    ex:identificador "Sub_Probe_Tool_Begin.fst" .

ex:SubrutinaProbePieceBegin a ex:TareaMantenimiento ;
    ex:textoExtracto "Estas marcas se deberían testear en las subrutinas Sub_Probe_Tool_Begin.fst y Sub_Probe_Piece_Begin.fst, de modo que la subrutina espere hasta que la marca esté activa." ;
    ex:identificador "Sub_Probe_Piece_Begin.fst" .