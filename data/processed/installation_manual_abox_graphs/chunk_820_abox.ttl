ns1:Parametro_2073c3d6a2 a ns1:Parametro ;
    rdfs:label "Función H40 en el segundo canal" ;
    ns1:identificador "HFUN2C2" ;
    ns1:textoExtracto "en el segundo canal las funciones H30 y H40" ;
