ns1:ValorHexadecimalFFFFFFFFParaLosRegistrosLibresDelPrimerCanal a ns1:Parametro ;
    rdfs:label "Valor hexadecimal $FFFFFFFF para los registros libres del primer canal" ;
    ns1:identificador "HFUN3C1" ;
    ns1:textoExtracto "el CNC asigna el valor hexadecimal $FFFFFFFF a los que queden libres, los de numeración más alta." ;
    ns1:valor "$FFFFFFFF" .

ns1:ValorHexadecimalFFFFFFFFParaLosRegistrosLibresDelSegundoCanal a ns1:Parametro ;
