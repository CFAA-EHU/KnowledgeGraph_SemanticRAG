@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PROBE1MONIT a ex:Sensor ;
    rdfs:label "PROBE1MONIT" ;
    ex:textoExtracto "PROBE1MONIT Estas marcas están asociadas al modo seguro del palpador. Si la marca está activa, el palpador está en modo seguro monitorizando colisiones." .

ex:PROBE2MONIT a ex:Sensor ;
    rdfs:label "PROBE2MONIT" ;
    ex:textoExtracto "PROBE2MONIT Estas marcas están asociadas al modo seguro del palpador. Si la marca está activa, el palpador está en modo seguro monitorizando colisiones." .

ex:ModoSeguroPalpador a ex:ModoOperacion ;
    rdfs:label "modo seguro del palpador" ;
    ex:textoExtracto "modo seguro del palpador" .

ex:Palpador a ex:ComponenteMecanico ;
    rdfs:label "palpador" ;
    ex:textoExtracto "el palpador está en modo seguro monitorizando colisiones" .

ex:SistemaMonitorizacionColisiones a ex:Sistema ;
    rdfs:label "sistema de monitorización de colisiones" ;
    ex:textoExtracto "Monitorización a nivel de lazo, controlando todas las situaciones de colisión en cualquiera de los dos palpadores." ;
    ex:compuestoPor ex:PROBE1MONIT, ex:PROBE2MONIT ;
    ex:controla ex:Palpador .