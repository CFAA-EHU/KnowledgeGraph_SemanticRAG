@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:LCOUNTALARMOFF1 a ex:Parametro ;
    rdfs:label "LCOUNTALARMOFF1" ;
    ex:identificador "LCOUNTALARMOFF1" ;
    ex:textoExtracto "Estas marcas están referidas a las entradas de captación local 1 (LCOUNTALARMOFF1) y 2 (LCOUNTALARMOFF2)." .

ex:LCOUNTALARMOFF2 a ex:Parametro ;
    rdfs:label "LCOUNTALARMOFF2" ;
    ex:identificador "LCOUNTALARMOFF2" ;
    ex:textoExtracto "Estas marcas están referidas a las entradas de captación local 1 (LCOUNTALARMOFF1) y 2 (LCOUNTALARMOFF2)." .

ex:FBACKAL a ex:Parametro ;
    rdfs:label "FBACKAL" ;
    ex:identificador "FBACKAL" ;
    ex:textoExtracto "El report de alarma está condicionado al parámetro FBACKAL." .

ex:COLLISIONOFF a ex:Parametro ;
    rdfs:label "COLLISIONOFF" ;
    ex:identificador "COLLISIONOFF" ;
    ex:textoExtracto "COLLISIONOFF Hay una marca para cada canal." .

ex:RKIN1 a ex:Parametro ;
    rdfs:label "RKIN1" ;
    ex:identificador "RKIN1" ;
    ex:textoExtracto "RKIN1 RKIN32 Estas registros permiten la comunicación entre el PLC y las cinemáticas de usuario." .

ex:RKIN32 a ex:Parametro ;
    rdfs:label "RKIN32" ;
    ex:identificador "RKIN32" ;
    ex:textoExtracto "RKIN1 RKIN32 Estas registros permiten la comunicación entre el PLC y las cinemáticas de usuario." .

ex:Sub_Probe_Tool_Begin_fst a ex:Figura ;
    rdfs:label "Sub_Probe_Tool_Begin.fst" ;
    ex:textoExtracto "Estas marcas se deberían testear en las subrutinas Sub_Probe_Tool_Begin.fst y Sub_Probe_Piece_Begin.fst, para avisar, si están desactivadas, que el palpador está en modo no seguro." .

ex:Sub_Probe_Piece_Begin_fst a ex:Figura ;
    rdfs:label "Sub_Probe_Piece_Begin.fst" ;
    ex:textoExtracto "Estas marcas se deberían testear en las subrutinas Sub_Probe_Tool_Begin.fst y Sub_Probe_Piece_Begin.fst, para avisar, si están desactivadas, que el palpador está en modo no seguro." .