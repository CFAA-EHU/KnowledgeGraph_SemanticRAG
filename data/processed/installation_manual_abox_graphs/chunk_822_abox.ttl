@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:RKIN1 a ex:Parametro ;
    rdfs:label "RKIN1" ;
    ex:textoExtracto "RKIN1 RKIN32 Estas registros permiten la comunicación entre el PLC y las cinemáticas de usuario." ;
    ex:valor "Registro de comunicación PLC-cinemáticas de usuario" .

ex:RKIN32 a ex:Parametro ;
    rdfs:label "RKIN32" ;
    ex:textoExtracto "RKIN1 RKIN32 Estas registros permiten la comunicación entre el PLC y las cinemáticas de usuario." ;
    ex:valor "Registro de comunicación PLC-cinemáticas de usuario" .

ex:COLLISIONOFF a ex:Parametro ;
    rdfs:label "COLLISIONOFF" ;
    ex:textoExtracto "COLLISIONOFF Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. COLLISIONOFFC1 (también se puede programar como COLLISIONOFF) COLLISIONOFFC2 COLLISIONOFFC3 COLLISIONOFFC4 Si el PLC activa esta marca (cambio de 0 a 1), desactiva la opción FCAS (control de colisiones). Si el PLC desactiva esta marca (cambio de 1 a 0), activa la opción FCAS (control de colisiones)." ;
    ex:valor "Marca de control de colisiones" .

ex:COLLISIONOFFC1 a ex:Parametro ;
    rdfs:label "COLLISIONOFFC1" ;
    ex:textoExtracto "COLLISIONOFFC1 (también se puede programar como COLLISIONOFF)" ;
    ex:valor "Marca de control de colisiones para canal 1" .

ex:COLLISIONOFFC2 a ex:Parametro ;
    rdfs:label "COLLISIONOFFC2" ;
    ex:textoExtracto "COLLISIONOFFC2" ;
    ex:valor "Marca de control de colisiones para canal 2" .

ex:COLLISIONOFFC3 a ex:Parametro ;
    rdfs:label "COLLISIONOFFC3" ;
    ex:textoExtracto "COLLISIONOFFC3" ;
    ex:valor "Marca de control de colisiones para canal 3" .

ex:COLLISIONOFFC4 a ex:Parametro ;
    rdfs:label "COLLISIONOFFC4" ;
    ex:textoExtracto "COLLISIONOFFC4" ;
    ex:valor "Marca de control de colisiones para canal 4" .

ex:VIRTUALJOGENA a ex:Parametro ;
    rdfs:label "VIRTUALJOGENA" ;
    ex:textoExtracto "VIRTUALJOGENA El PLC utiliza esta marca para habilitar" ;
    ex:valor "Marca de habilitación de jog virtual" .

ex:FCAS a ex:Parametro ;
    rdfs:label "FCAS" ;
    ex:textoExtracto "desactiva la opción FCAS (control de colisiones)" ;
    ex:valor "Control de colisiones" .