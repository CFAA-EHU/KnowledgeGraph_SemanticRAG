ns1:Parametro_2cdf463309 a ns1:Parametro ;
    rdfs:label "Marca para indicar al PLC que debe ejecutar la(s) función(es) auxiliares H" ;
    ns1:identificador "HSTROBEC1" ;
    ns1:textoExtracto "El canal del CNC pone esta marca a (=1) para indicar al PLC que debe ejecutar la(s) función(es) auxiliares H que se le indican en los registros HFUN1 a HFUN7." .

