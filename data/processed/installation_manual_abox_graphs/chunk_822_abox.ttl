ns1:CNC8070_4576c300d5 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC sólo utiliza los registros de los cabezales cuyo parámetro SPDLTIME tenga un valor distinto de cero." .

ns1:IndicaLaVelocidadProgramadaEnElCabezal1 a ns1:Parametro ;
    rdfs:label "Indica la velocidad programada en el cabezal 1" ;
    ns1:identificador "SFUN1" ;
    ns1:textoExtracto "Estos registro indican la velocidad programada en cada uno de los cabezales." .

