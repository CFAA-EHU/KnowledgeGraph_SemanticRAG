@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:FCAS a ex:ModoOperacion ;
    rdfs:label "FCAS (control de colisiones)" ;
    ex:textoExtracto "la opción FCAS (control de colisiones). Si el PLC desactiva esta marca (cambio de 1 a 0), activa la opción FCAS (control de colisiones)." .

ex:marca_FCAS a ex:Parametro ;
    rdfs:label "marca FCAS" ;
    ex:textoExtracto "Si el PLC desactiva esta marca (cambio de 1 a 0), activa la opción FCAS (control de colisiones)." .

ex:VIRTUALJOGENA a ex:InterfazUsuario ;
    rdfs:label "VIRTUALJOGENA" ;
    ex:textoExtracto "VIRTUALJOGENA El PLC utiliza esta marca para habilitar (=1) o deshabilitar (=0) el teclado virtual de jog (teclado en pantalla)." .

ex:marca_VIRTUALJOGENA a ex:Parametro ;
    rdfs:label "marca VIRTUALJOGENA" ;
    ex:textoExtracto "El PLC utiliza esta marca para habilitar (=1) o deshabilitar (=0) el teclado virtual de jog (teclado en pantalla)." .

ex:DMCON a ex:ModoOperacion ;
    rdfs:label "DMCON" ;
    ex:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. DMCON (también se puede programar como DMCON)" .

ex:DMCONC1 a ex:ModoOperacion ;
    rdfs:label "DMCONC1" ;
    ex:textoExtracto "DMCONC1 (también se puede programar como DMCON)" .

ex:DMCONC2 a ex:ModoOperacion ;
    rdfs:label "DMCONC2" ;
    ex:textoExtracto "DMCONC2" .

ex:DMCONC3 a ex:ModoOperacion ;
    rdfs:label "DMCONC3" ;
    ex:textoExtracto "DMCONC3" .

ex:DMCONC4 a ex:ModoOperacion ;
    rdfs:label "DMCONC4" ;
    ex:textoExtracto "DMCONC4" .

ex:marca_DMCON a ex:Parametro ;
    rdfs:label "marca DMCON" ;
    ex:textoExtracto "Con un flanco de bajada de esta marca (cambio de 1 a 0), el CNC desactiva el DMC. Con un flanco de subida de esta marca (cambio de 0 a 1), el CNC reactiva el DMC." .

ex:PLC a ex:Sistema ;
    rdfs:label "PLC" ;
    ex:textoExtracto "Si el PLC desactiva esta marca (cambio de 1 a 0), activa la opción FCAS (control de colisiones). VIRTUALJOGENA El PLC utiliza esta marca para habilitar (=1) o deshabilitar (=0) el teclado virtual de jog (teclado en pantalla)." .

ex:CNC a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "Con un flanco de bajada de esta marca (cambio de 1 a 0), el CNC desactiva el DMC. Con un flanco de subida de esta marca (cambio de 0 a 1), el CNC reactiva el DMC." .