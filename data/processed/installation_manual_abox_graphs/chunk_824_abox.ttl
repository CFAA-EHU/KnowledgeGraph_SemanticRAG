@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SenalLIMITPOS a ex:Sensor ;
    rdfs:label "LIMITPOS(axis)" ;
    ex:textoExtracto "LIMITPOS(axis) [...] Si el PLC pone esta marca a (=1), el CNC entiende que el eje o cabezal correspondiente ha sobrepasado el límite de recorrido en el sentido positivo (POS)."@es ;
    ex:monitoreaParametro ex:LimiteRecorridoPositivo .

ex:SenalLIMITNEG a ex:Sensor ;
    rdfs:label "LIMITNEG(axis)" ;
    ex:textoExtracto "LIMITNEG(axis) [...] Si el PLC pone esta marca a (=1), el CNC entiende que el eje o cabezal correspondiente ha sobrepasado el límite de recorrido en el sentido negativo (NEG)."@es ;
    ex:monitoreaParametro ex:LimiteRecorridoNegativo .

ex:SenalDECEL a ex:Sensor ;
    rdfs:label "DECEL(axis)" ;
    ex:textoExtracto "DECEL(axis) [...] El PLC la pone a (=1) para indicar que el micro de búsqueda de referencia máquina está pulsado. El CNC decelera el eje, pasa del avance rápido indicado por el parámetro máquina REFFEED1, al avance lento indicado por el parámetro máquina REFFEED2."@es ;
    ex:monitoreaParametro ex:DeceleracionBusquedaReferencia .

ex:SenalINHIBIT a ex:Sensor ;
    rdfs:label "INHIBIT(axis)" ;
    ex:textoExtracto "INHIBIT(axis) [...] Si el PLC pone esta marca a (=1) el CNC impide cualquier movimiento del eje o cabezal correspondiente."@es ;
    ex:controla ex:MovimientoEje .

ex:ParametroREFFEED1 a ex:Parametro ;
    rdfs:label "REFFEED1" ;
    ex:textoExtracto "avance rápido indicado por el parámetro máquina REFFEED1"@es ;
    ex:valor "avance rápido" .

ex:ParametroREFFEED2 a ex:Parametro ;
    rdfs:label "REFFEED2" ;
    ex:textoExtracto "avance lento indicado por el parámetro máquina REFFEED2"@es ;
    ex:valor "avance lento" .

ex:LimiteRecorridoPositivo a ex:Parametro ;
    rdfs:label "Límite de recorrido positivo" ;
    ex:textoExtracto "ha sobrepasado el límite de recorrido en el sentido positivo (POS)"@es .

ex:LimiteRecorridoNegativo a ex:Parametro ;
    rdfs:label "Límite de recorrido negativo" ;
    ex:textoExtracto "ha sobrepasado el límite de recorrido en el sentido negativo (NEG)"@es .

ex:DeceleracionBusquedaReferencia a ex:Parametro ;
    rdfs:label "Deceleración en búsqueda de referencia" ;
    ex:textoExtracto "El CNC decelera el eje, pasa del avance rápido [...] al avance lento"@es .

ex:MovimientoEje a ex:ModoOperacion ;
    rdfs:label "Movimiento de eje/cabezal" ;
    ex:textoExtracto "impide cualquier movimiento del eje o cabezal correspondiente"@es .

ex:AvisoErrorLimiteRecorrido a ex:AvisoSeguridad ;
    rdfs:label "Error de límite de recorrido" ;
    ex:textoExtracto "visualizando en la pantalla el error correspondiente"@es ;
    ex:mitigaRiesgo ex:SenalLIMITPOS, ex:SenalLIMITNEG .

ex:ModoManual a ex:ModoOperacion ;
    rdfs:label "Modo manual" ;
    ex:textoExtracto "Para llevar el eje a la zona permitida acceder al modo manual y mover el eje o cabezal"@es .