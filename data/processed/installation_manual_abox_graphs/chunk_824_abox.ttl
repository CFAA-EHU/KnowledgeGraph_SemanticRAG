@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:LIMITPOSX a ex:Sensor ;
    rdfs:label "LIMITPOSX" ;
    ex:textoExtracto "LIMITPOSX" ;
    ex:identificador "LIMITPOSX" .

ex:LIMITPOSZ2 a ex:Sensor ;
    rdfs:label "LIMITPOSZ2" ;
    ex:textoExtracto "LIMITPOSZ2" ;
    ex:identificador "LIMITPOSZ2" .

ex:LIMITPOSB a ex:Sensor ;
    rdfs:label "LIMITPOSB" ;
    ex:textoExtracto "LIMITPOSB" ;
    ex:identificador "LIMITPOSB" .

ex:LIMITPOSS a ex:Sensor ;
    rdfs:label "LIMITPOSS" ;
    ex:textoExtracto "LIMITPOSS" ;
    ex:identificador "LIMITPOSS" .

ex:LIMITPOS3 a ex:Sensor ;
    rdfs:label "LIMITPOS3" ;
    ex:textoExtracto "LIMITPOS3" ;
    ex:identificador "LIMITPOS3" .

ex:LIMITPOS5 a ex:Sensor ;
    rdfs:label "LIMITPOS5" ;
    ex:textoExtracto "LIMITPOS5" ;
    ex:identificador "LIMITPOS5" .

ex:DECEL a ex:Parametro ;
    rdfs:label "DECEL" ;
    ex:textoExtracto "DECEL(axis)" .

ex:INHIBIT a ex:Parametro ;
    rdfs:label "INHIBIT" ;
    ex:textoExtracto "INHIBIT(axis)" .

ex:REFFEED1 a ex:Parametro ;
    rdfs:label "REFFEED1" ;
    ex:textoExtracto "REFFEED1" .

ex:REFFEED2 a ex:Parametro ;
    rdfs:label "REFFEED2" ;
