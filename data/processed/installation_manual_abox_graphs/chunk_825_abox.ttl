@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:INHIBIT_axis a ex:Parametro ;
    ex:textoExtracto "INHIBIT(axis) Si el PLC pone esta marca a (=1) el CNC impide cualquier movimiento del eje o cabezal correspondiente." ;
    rdfs:label "INHIBIT(axis)" .

ex:PLC a ex:ComponenteElectrico ;
    ex:textoExtracto "Si el PLC pone esta marca a (=1)" ;
    rdfs:label "PLC" .

ex:CNC a ex:Sistema ;
    ex:textoExtracto "el CNC impide cualquier movimiento del eje o cabezal correspondiente" ;
    rdfs:label "CNC" .

ex:Eje_o_cabezal a ex:ComponenteMecanico ;
    ex:textoExtracto "cualquier movimiento del eje o cabezal correspondiente" ;
    rdfs:label "Eje o cabezal" .