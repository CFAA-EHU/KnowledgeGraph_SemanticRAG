@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_7cc3a4ea98 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El canal del CNC pone esta señal a nivel lógico alto un tiempo antes de llegar los ejes a posición." ;
    ns1:tieneComponente ns1:Parametro_1d78b32a59,
        ns1:Parametro_5035fc6df9,
        ns1:Parametro_d6d7074c3d,
        ns1:Parametro_e3f3a9e171,
        ns1:TiempoAntesDeLlegadaAPosicion .

ns1:Parametro_1d78b32a59 a ns1:Parametro ;
    rdfs:label "Marca de consulta para canal 3" ;
    ns1:identificador "ADVINPOSC3" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. ADVINPOSC3" .

ns1:Parametro_5035fc6df9 a ns1:Parametro ;
    rdfs:label "Marca de consulta para canal 2" ;
    ns1:identificador "ADVINPOSC2" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. ADVINPOSC2" .

ns1:Parametro_d6d7074c3d a ns1:Parametro ;
    rdfs:label "Marca de consulta para canal 4" ;
    ns1:identificador "ADVINPOSC4" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. ADVINPOSC4" .

ns1:Parametro_e3f3a9e171 a ns1:Parametro ;
    rdfs:label "Marca de consulta para canal 1" ;
    ns1:identificador "ADVINPOSC1" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. ADVINPOSC1 (también se puede programar como ADVINPOS)" .

ns1:TiempoAntesDeLlegadaAPosicion a ns1:Parametro ;
    rdfs:label "Tiempo antes de llegada a posición" ;
    ns1:identificador "ANTIME" ;
    ns1:textoExtracto "Este tiempo lo fija el parámetro máquina ANTIME. Si la duración total del movimiento es inferior al valor especificado en el parámetro ANTIME, la marca se pone a (=1) inmediatamente." .

