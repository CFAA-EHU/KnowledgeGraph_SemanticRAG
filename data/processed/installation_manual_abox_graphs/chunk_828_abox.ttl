@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_92c7ad9010 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El canal del CNC pone esta señal a (=1) para indicar al PLC que está esperando una señal de sincronización." ;
    ns1:tieneComponente ns1:EstadoDelSistemaOperativo .

ns1:EstadoDelSistemaOperativo a ns1:Parametro ;
    rdfs:label "Estado del sistema operativo" ;
    ns1:identificador "MMCWDG" ;
    ns1:textoExtracto "Esta marca indica el estado del sistema operativo. Tiene el valor (=0) cuando el sistema operativo CNC funciona correctamente y valor (=1) en caso de bloqueo del" .

