@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Eje ex:textoExtracto "cada vez que quiere mover el eje. Ver \"ENABLE(axis)\" 418. ( no errores) AND (regulador OK) AND ENABLE = SERVOON Si se mueve el eje cuando está bloqueado, el CNC almacena la desviación como error de seguimiento. Al volver a controlarlo (SERVOON=1) vuelve a posición. ERROR" ;
    a ex:ComponenteMecanico ;
    ex:tieneComponente ex:SERVOON .

ex:SERVOON ex:textoExtracto "ENABLE = SERVOON" ;
    a ex:ModoOperacion ;
    ex:identificador "SERVOON" .

ex:ErrorSeguimiento ex:textoExtracto "el CNC almacena la desviación como error de seguimiento" ;
    a ex:DiagnosticoFallo .

ex:ReguladorOK ex:textoExtracto "(regulador OK)" ;
    a ex:Parametro ;
    ex:identificador "regulador OK" .