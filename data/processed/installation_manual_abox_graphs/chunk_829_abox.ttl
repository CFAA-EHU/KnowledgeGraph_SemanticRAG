    rdfs:label "Control tangencial activo para el canal 3" ;
    ns1:identificador "TANGACTIVC3" ;
    ns1:textoExtracto "El canal del CNC pone esta marca a (=1) para indicar que hay algún control tangencial activo en el canal." .

ns1:ControlTangencialActivoParaElCanal4 a ns1:Parametro ;
    rdfs:label "Control tangencial activo para el canal 4" ;
    ns1:identificador "TANGACTIVC4" ;
    ns1:textoExtracto "El canal del CNC pone esta marca a (=1) para indicar que hay algún control tangencial activo en el canal." .

ns1:EstadoDelSistemaOperativo a ns1:Parametro ;
    rdfs:label "Estado del sistema operativo" ;
    ns1:identificador "MMCWDG" ;
    ns1:textoExtracto "Esta marca indica el estado del sistema operativo. Tiene el valor (=0) cuando el sistema operativo CNC funciona correctamente y valor (=1) en caso de bloqueo del sistema operativo." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Incluir esta marca en la maniobra del PLC para habilitar las emergencias en caso de bloqueo del sistema operativo." .

