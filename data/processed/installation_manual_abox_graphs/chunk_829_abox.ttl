@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_1febc3e30f a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El sistema operativo CNC funciona correctamente y valor (=1) en caso de bloqueo del sistema operativo." .

ns1:CancelacionDeLaFuncionRetraceParaElCanal1 a ns1:Parametro ;
    rdfs:label "Cancelación de la función retrace para el canal 1" ;
    ns1:identificador "RETRAENDC1" ;
    ns1:textoExtracto "El canal del CNC pone esta marca a (=1) para cancelar la función retrace." .

ns1:CancelacionDeLaFuncionRetraceParaElCanal2 a ns1:Parametro ;
    rdfs:label "Cancelación de la función retrace para el canal 2" ;
    ns1:identificador "RETRAENDC2" ;
    ns1:textoExtracto "El canal del CNC pone esta marca a (=1) para cancelar la función retrace." .

