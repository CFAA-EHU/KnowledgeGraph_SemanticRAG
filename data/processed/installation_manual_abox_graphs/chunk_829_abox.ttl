    rdfs:label "Cancelación de la función retrace para el canal 3" ;
    ns1:identificador "RETRAENDC3" ;
    ns1:textoExtracto "El canal del CNC pone esta marca a (=1) para cancelar la función retrace." .

ns1:CancelacionDeLaFuncionRetraceParaElCanal4 a ns1:Parametro ;
    rdfs:label "Cancelación de la función retrace para el canal 4" ;
    ns1:identificador "RETRAENDC4" ;
    ns1:textoExtracto "El canal del CNC pone esta marca a (=1) para cancelar la función retrace." .

ns1:ControlTangencialActivoParaElCanal1 a ns1:Parametro ;
    rdfs:label "Control tangencial activo para el canal 1" ;
    ns1:identificador "TANGACTIVC1" ;
    ns1:textoExtracto "El canal del CNC pone esta marca a (=1) para indicar que hay algún control tangencial activo en el canal." .

ns1:ControlTangencialActivoParaElCanal2 a ns1:Parametro ;
    rdfs:label "Control tangencial activo para el canal 2" ;
    ns1:identificador "TANGACTIVC2" ;
    ns1:textoExtracto "El canal del CNC pone esta marca a (=1) para indicar que hay algún control tangencial activo en el canal." .

