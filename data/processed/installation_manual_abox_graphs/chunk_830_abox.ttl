@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PLC_830 a ex:ComponenteElectrico ;
    ex:textoExtracto "Si el PLC desactiva esta marca, el CNC vuelve a tener en cuenta los límites de software y las zonas de trabajo en el eje indicado." ;
    rdfs:label "PLC" .

ex:CNC_830 a ex:ComponenteElectrico ;
    ex:textoExtracto "el CNC vuelve a tener en cuenta los límites de software y las zonas de trabajo en el eje indicado" ;
    rdfs:label "CNC" .

ex:LimiteSoftware_830 a ex:Parametro ;
    ex:textoExtracto "los límites de software" ;
    rdfs:label "límite de software" .

ex:ZonaTrabajo_830 a ex:Parametro ;
    ex:textoExtracto "las zonas de trabajo" ;
    rdfs:label "zona de trabajo" .

ex:EjeIndicado_830 a ex:ComponenteMecanico ;
    ex:textoExtracto "en el eje indicado" ;
    rdfs:label "eje indicado" .

ex:Herramienta_830 a ex:PiezaRecambio ;
    ex:textoExtracto "la herramienta de nuevo a una zona permitida" ;
    rdfs:label "herramienta" .

ex:ZonaProhibida_830 a ex:AccionProhibida ;
    ex:textoExtracto "haya superado los límites de software o haya invadido una zona prohibida" ;
    rdfs:label "zona prohibida" .

ex:ParametroMaquina_830 a ex:Parametro ;
    ex:textoExtracto "Los límites de software se pueden fijar mediante los parámetros máquina" ;
    rdfs:label "parámetro máquina" .

ex:FuncionG198_830 a ex:Parametro ;
    ex:textoExtracto "mediante las funciones G198/G199" ;
    ex:identificador "G198/G199" ;
    rdfs:label "función G198/G199" .

ex:Variable_830 a ex:Parametro ;
    ex:textoExtracto "o mediante variables" ;
    rdfs:label "variable" .

ex:LimiteRecorrido_830 a ex:Parametro ;
    ex:textoExtracto "El CNC aplica siempre los límites de recorrido" ;
    rdfs:label "límite de recorrido" .