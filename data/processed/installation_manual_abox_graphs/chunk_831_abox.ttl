@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Parametro_Maquina_1 a ex:Parametro ;
    rdfs:label "parámetros máquina" ;
    ex:textoExtracto "Los límites de software se pueden fijar mediante los parámetros máquina" .

ex:Funcion_G198 a ex:Parametro ;
    rdfs:label "función G198" ;
    ex:textoExtracto "Los límites de software se pueden fijar mediante ... las funciones G198/G199" .

ex:Funcion_G199 a ex:Parametro ;
    rdfs:label "función G199" ;
    ex:textoExtracto "Los límites de software se pueden fijar mediante ... las funciones G198/G199" .

ex:Funcion_G120 a ex:Parametro ;
    rdfs:label "función G120" ;
    ex:textoExtracto "Las zonas de trabajo se pueden fijar mediante las funciones G120, G121, G122, G123" .

ex:Funcion_G121 a ex:Parametro ;
    rdfs:label "función G121" ;
    ex:textoExtracto "Las zonas de trabajo se pueden fijar mediante las funciones G120, G121, G122, G123" .

ex:Funcion_G122 a ex:Parametro ;
    rdfs:label "función G122" ;
    ex:textoExtracto "Las zonas de trabajo se pueden fijar mediante las funciones G120, G121, G122, G123" .

ex:Funcion_G123 a ex:Parametro ;
    rdfs:label "función G123" ;
    rdfs:label "función G123" ;
    ex:textoExtracto "Las zonas de trabajo se pueden fijar mediante las funciones G120, G121, G122, G123" .

ex:Marca_SPENA a ex:Parametro ;
    rdfs:label "marca SPENA(axis)" ;
    ex:textoExtracto "La marca SPENA(axis) corresponde a la señal \"speed enable\" y la marca DRENA(axis) a la señal \"drive enable\" del dispositivo" .

ex:Marca_DRENA a ex:Parametro ;
    rdfs:label "marca DRENA(axis)" ;
    ex:textoExtracto "La marca SPENA(axis) corresponde a la señal \"speed enable\" y la marca DRENA(axis) a la señal \"drive enable\" del dispositivo" .

ex:Marca_PARKED a ex:Parametro ;
    rdfs:label "marca PARKED(axis)" ;
    ex:textoExtracto "El PLC pone esta marca a (=1) para indicar al CNC que el eje o cabezal correspondiente está aparcado" .

ex:Marca_LUBRENA a ex:Parametro ;
    rdfs:label "marca LUBRENA(axis)" ;
    ex:textoExtracto "LUBRENA(axis) LUBROK(axis) Estas marcas junto con la señal de consulta de ejes LUBR(axis)" .

ex:Marca_LUBROK a ex:Parametro ;
    rdfs:label "marca LUBROK(axis)" ;
    ex:textoExtracto "LUBRENA(axis) LUBROK(axis) Estas marcas junto con la señal de consulta de ejes LUBR(axis)" .

ex:Marca_LUBR a ex:Parametro ;
    rdfs:label "señal de consulta de ejes LUBR(axis)" ;
    ex:textoExtracto "LUBRENA(axis) LUBROK(axis) Estas marcas junto con la señal de consulta de ejes LUBR(axis)" .

ex:Sistema_CNC a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "El CNC aplica siempre los límites de recorrido más restrictivos" .

ex:Sistema_PLC a ex:Sistema ;
    rdfs:label "PLC" ;
    ex:textoExtracto "El PLC utiliza estas marcas para habilitar los reguladores cuando la comunicación es vía Sercos o para habilitar los servos e inverters cuando la comunicación es vía Mechatrolink" .

ex:Comunicacion_Sercos a ex:Sistema ;
    rdfs:label "comunicación vía Sercos" ;
    ex:textoExtracto "El PLC utiliza estas marcas para habilitar los reguladores cuando la comunicación es vía Sercos" .

ex:Comunicacion_Mechatrolink a ex:Sistema ;
    rdfs:label "comunicación vía Mechatrolink" ;
    ex:textoExtracto "El PLC utiliza estas marcas para ... habilitar los servos e inverters cuando la comunicación es vía Mechatrolink" .

ex:Regulador_1 a ex:ComponenteElectrico ;
    rdfs:label "regulador" ;
    ex:textoExtracto "El PLC utiliza estas marcas para habilitar los reguladores cuando la comunicación es vía Sercos" .

ex:Servo_1 a ex:ComponenteElectrico ;
    rdfs:label "servo" ;
    ex:textoExtracto "El PLC utiliza estas marcas para ... habilitar los servos e inverters cuando la comunicación es vía Mechatrolink" .

ex:Inverter_1 a ex:ComponenteElectrico ;
    rdfs:label "inverter" ;
    ex:textoExtracto "El PLC utiliza estas marcas para ... habilitar los servos e inverters cuando la comunicación es vía Mechatrolink" .

ex:Motor_1 a ex:ComponenteElectrico ;
    rdfs:label "motor" ;
    ex:textoExtracto "el motor responderá a todas las variaciones de consigna" ;
    ex:textoExtracto "el circuito de potencia del dispositivo se apaga y el motor queda sin par" ;
    ex:textoExtracto "el motor frena manteniendo el par" ;
    ex:textoExtracto "el motor queda sin par" .

ex:Regulador_1 ex:controla ex:Motor_1 ;
    ex:textoExtracto "El PLC utiliza estas marcas para habilitar los reguladores cuando la comunicación es vía Sercos o para habilitar los servos e inverters cuando la comunicación es vía Mechatrolink" .

ex:Servo_1 ex:controla ex:Motor_1 ;
    ex:textoExtracto "El PLC utiliza estas marcas para ... habilitar los servos ... cuando la comunicación es vía Mechatrolink" .

ex:Inverter_1 ex:controla ex:Motor_1 ;
    ex:textoExtracto "El PLC utiliza estas marcas para ... habilitar ... inverters cuando la comunicación es vía Mechatrolink" .