@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:LUBR_axis a ex:Parametro ;
    ex:textoExtracto "LUBR(axis)" ;
    ex:valor "DISTLUBRI" .

ex:LUBRENA a ex:Parametro ;
    ex:textoExtracto "LUBRENA" ;
    ex:valor "1" .

ex:LUBROK_axis a ex:Parametro ;
    ex:textoExtracto "LUBROK(axis)" ;
    ex:valor "1" .

ex:DIFFCOMP_axis a ex:Parametro ;
    ex:textoExtracto "DIFFCOMP(axis)" .

ex:SERVO_axisON a ex:Parametro ;
    ex:textoExtracto "SERVO(axis)ON" .

ex:REFFEED2 a ex:Parametro ;
    ex:textoExtracto "REFFEED2" .

ex:REFPOIN_axis a ex:Parametro ;
    ex:textoExtracto "REFPOIN(axis)" .

ex:FBACKSEL_axis a ex:Parametro ;
    ex:textoExtracto "FBACKSEL(axis)" .

ex:FBMIXTIME a ex:Parametro ;
    ex:textoExtracto "FBMIXTIME" .

ex:FBACKSRC a ex:Parametro ;
    ex:textoExtracto "FBACKSRC" .

ex:PLC a ex:ComponenteElectrico ;
    ex:textoExtracto "PLC" .

ex:CNC a ex:ComponenteElectrico ;
    ex:textoExtracto "CNC" .