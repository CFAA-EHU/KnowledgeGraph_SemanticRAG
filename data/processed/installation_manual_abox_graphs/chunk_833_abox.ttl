@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_DISTLUBRI
    a ex:Parametro ;
    rdfs:label "DISTLUBRI" ;
    ex:textoExtracto "distancia fijada en el parámetro máquina DISTLUBRI" ;
    ex:monitoreaParametro ex:SistemaLubricacionEjes .

ex:Parametro_REFFEED2
    a ex:Parametro ;
    rdfs:label "REFFEED2" ;
    ex:textoExtracto "avance especificado en el parámetro REFFEED2" ;
    ex:monitoreaParametro ex:SistemaCorreccionGantry .

ex:Parametro_FBACKSRC
    a ex:Parametro ;
    rdfs:label "FBACKSRC" ;
    ex:textoExtracto "Consultar el parámetro FBACKSRC" ;
    ex:monitoreaParametro ex:SistemaCaptacionMixta .

ex:Parametro_FBMIXTIME
    a ex:Parametro ;
    rdfs:label "FBMIXTIME" ;
    ex:textoExtracto "mezcla de captaciones (parámetro FBMIXTIME)" ;
    ex:monitoreaParametro ex:SistemaCaptacionMixta .

ex:SistemaLubricacionEjes
    a ex:Sistema ;
    rdfs:label "Sistema de lubricación de ejes" ;
    ex:textoExtracto "LUBR(axis) se deben utilizar para el engrase de los ejes. [...] Con LUBRENA a (=1) el CNC actúa del siguiente modo: [...] El PLC tras engrasar el eje pone la marca LUBROK(axis) a (=1)" ;
    ex:tieneComponente ex:ComponenteLubricacionEje ;
    ex:requiereMantenimiento ex:TareaEngraseEjes .

ex:TareaEngraseEjes
    a ex:TareaMantenimiento ;
    rdfs:label "Engrase de ejes" ;
    ex:textoExtracto "engrase de los ejes. [...] se debe engrasar el eje" ;
    ex:requiereConsumible ex:LubricanteEjes .

ex:LubricanteEjes
    a ex:Consumible ;
    rdfs:label "Lubricante para ejes" ;
    ex:textoExtracto "LUBR(axis) se deben utilizar para el engrase de los ejes" .

ex:ComponenteLubricacionEje
    a ex:ComponenteMecanico ;
    rdfs:label "Componente de lubricación de eje" ;
    ex:textoExtracto "el PLC tras engrasar el eje pone la marca LUBROK(axis) a (=1)" .

ex:SistemaCorreccionGantry
    a ex:Sistema ;
    rdfs:label "Sistema de corrección gantry" ;
    ex:textoExtracto "DIFFCOMP(axis) [...] corrige la diferencia de cota entre el eje maestro y esclavo. [...] El proceso sólo se puede interrumpir con reset. La marca REFPOIN(axis) de ambos ejes se activa cuando termina la corrección" ;
    ex:controla ex:ComponenteEjeEsclavo ;
    ex:monitoreaParametro ex:Parametro_REFFEED2 .

ex:ComponenteEjeEsclavo
    a ex:ComponenteMecanico ;
    rdfs:label "Eje esclavo (sistema gantry)" ;
    ex:textoExtracto "el eje esclavo se moverá hasta alcanzar la cota del eje maestro" .

ex:SistemaCaptacionMixta
    a ex:Sistema ;
    rdfs:label "Sistema de captación mixta (externa+interna)" ;
    ex:textoExtracto "FBACKSEL(axis) [...] cuando el sistema dispone de captación externa+interna. [...] con el flanco de subida de esta marca se conmuta a la captación externa (captación directa) y con el flanco de bajada se conmuta a captación interna (captación motor)" ;
    ex:tieneComponente ex:SensorCaptacionExterna ,
                        ex:SensorCaptacionInterna ;
    ex:monitoreaParametro ex:Parametro_FBACKSRC ,
                          ex:Parametro_FBMIXTIME .

ex:SensorCaptacionExterna
    a ex:Sensor ;
    rdfs:label "Sensor de captación externa" ;
    ex:textoExtracto "captación externa (captación directa)" .

ex:SensorCaptacionInterna
    a ex:Sensor ;
    rdfs:label "Sensor de captación interna (captación motor)" ;
    ex:textoExtracto "captación interna (captación motor)" .