@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_5dcac5d768 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:Parametro_8ee555b09f,
        ns1:Parametro_91ce561a1c,
        ns1:Parametro_c78acc4fd3,
        ns1:Parametro_cb027595b8,
        ns1:Parametro_d77d9c9d9b,
        ns1:Parametro_f08341ce9f ;
    ns1:textoExtracto "El CNC activa esta marca cuando está activa la opción de pasadas iguales sincronizadas (#DINDIST[1]). El CNC desactiva esta marca cuando está activa la opción de reparto de pasadas entre canales (#DINDIST[0])." .

ns1:Parametro_8ee555b09f a ns1:Parametro ;
    rdfs:label "Marca asociada a la distribución dinámica del mecanizado entre canales para el canal 2" ;
    ns1:identificador "DINDISTYPEC2" ;
    ns1:textoExtracto "Esta marca está asociada a la distribución dinámica del mecanizado entre canales (sentencia #DINDIST) e indica el tipo activo." .

ns1:Parametro_91ce561a1c a ns1:Parametro ;
    rdfs:label "Marca asociada a la distribución dinámica del mecanizado entre canales para el canal 1" ;
    ns1:identificador "DINDISTYPEC1" ;
    ns1:textoExtracto "Esta marca está asociada a la distribución dinámica del mecanizado entre canales (sentencia #DINDIST) e indica el tipo activo." .

ns1:Parametro_c78acc4fd3 a ns1:Parametro ;
    rdfs:label "Marca asociada a la distribución dinámica del mecanizado entre canales para el canal 3" ;
    ns1:identificador "DINDISTYPEC3" ;
    ns1:textoExtracto "Esta marca está asociada a la distribución dinámica del mecanizado entre canales (sentencia #DINDIST) e indica el tipo activo." .

ns1:Parametro_cb027595b8 a ns1:Parametro ;
    rdfs:label "Marca que indica el estado de la temperatura del CNC" ;
    ns1:identificador "OVERTEMP" ;
    ns1:textoExtracto "Esta marca indica el estado de la temperatura del CNC." .

ns1:Parametro_d77d9c9d9b a ns1:Parametro ;
    rdfs:label "Marca asociada al cambio de la gama de trabajo o del set de parámetros de un regulador Sercos" ;
    ns1:identificador "SERPLCAC" ;
    ns1:textoExtracto "Esta marca está asociada al cambio de la gama de trabajo o del set de parámetros de un regulador Sercos (variable (V.)[ch].A.SETGE.xn)." .

ns1:Parametro_f08341ce9f a ns1:Parametro ;
    rdfs:label "Marca asociada a la distribución dinámica del mecanizado entre canales para el canal 4" ;
    ns1:identificador "DINDISTYPEC4" ;
    ns1:textoExtracto "Esta marca está asociada a la distribución dinámica del mecanizado entre canales (sentencia #DINDIST) e indica el tipo activo." .

