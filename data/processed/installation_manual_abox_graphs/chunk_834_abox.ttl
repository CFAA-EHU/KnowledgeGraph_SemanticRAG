@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Parametro_FBMIXTIME
    a ex:Parametro ;
    rdfs:label "FBMIXTIME" ;
    ex:textoExtracto "parámetro FBMIXTIME" ;
    ex:identificador "FBMIXTIME" .

ex:Sensor_CaptacionMotor
    a ex:Sensor ;
    rdfs:label "Captación motor (sensor interno)" ;
    ex:textoExtracto "captación interna (captación motor)" .

ex:Sistema_Regulador
    a ex:Sistema ;
    rdfs:label "Regulador del CNC" ;
    ex:textoExtracto "cuando se resetea el regulador" ;
    ex:monitoreaParametro ex:Parametro_FBMIXTIME ;
    ex:controla ex:Sensor_CaptacionMotor .

ex:InterfazUsuario_ACTFBACK
    a ex:InterfazUsuario ;
    rdfs:label "Señal ACTFBACK(axis)" ;
    ex:textoExtracto "marca ACTFBACK(axis)" ;
    ex:identificador "ACTFBACK(axis)" ;
    ex:ilustradoEn ex:Pagina_ACTFBACK .

ex:Pagina_ACTFBACK
    a ex:Pagina ;
    rdfs:label "Documentación de ACTFBACK(axis)" ;
    ex:textoExtracto "Ver en \"ACTFBACK(axis)\" la página" ;
    ex:identificador "Página ACTFBACK(axis)" .

ex:Sistema_AnilloSercos
    a ex:Sistema ;
    rdfs:label "Anillo Sercos" ;
    ex:textoExtracto "cuando se inicializa el anillo Sercos" ;
    ex:tieneComponente ex:Sensor_CaptacionMotor .