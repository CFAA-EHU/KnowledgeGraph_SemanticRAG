@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ApagarEquipo a ns1:AccionProhibida ;
    rdfs:label "Apagar equipo" ;
    ns1:textoExtracto "Apagar el aquipo para evitar" .

ns1:AvisoSeguridad_fc464737e3 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso sobre temperatura" ;
    ns1:textoExtracto "Incluir esta marca en la maniobra del PLC para restringir la operativa del CNC en caso de sobretemperatura." .

ns1:CNC8070_008ce2a8da a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC permitirá finalizar la ejecución en marcha, pero no permitirá reanudarla tras una interrupción, una inspección de herramienta, etc." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Si el PLC activa esta marca, existe riesgo de sobretemperatura y está en peligro la integridad del equipo." .

