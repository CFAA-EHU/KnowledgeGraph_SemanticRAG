@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_de2be3b4e1 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC activa esta marca para indicar que el bus Mechatrolink se encuentra inicializado correctamente." .

ns1:ControlDeColisionesActivo a ns1:Parametro ;
    rdfs:label "Control de colisiones activo" ;
    ns1:textoExtracto "El CNC activa esta marca (cambio de 0 a 1) cuando la opción FCAS está activa." .

ns1:ControlDeColisionesCanal1 a ns1:Parametro ;
    rdfs:label "Control de colisiones canal 1" ;
    ns1:textoExtracto "El CNC activa esta marca (cambio de 0 a 1) cuando la opción FCAS está activa." .

ns1:EstadoDelBusMechatrolink_c6cea37416 a ns1:Parametro ;
    rdfs:label "Estado del bus Mechatrolink" ;
    ns1:textoExtracto "En las configuraciones Mechatrolink, esta marca indica el estado del bus." .

ns1:RetraccionDeEjeCanal1 a ns1:Parametro ;
    rdfs:label "Retracción de eje canal 1" ;
    ns1:textoExtracto "El CNC utiliza esta marca cuando retira los ejes de la pieza tras interrumpir un roscado (tecla [STOP] o marca _FEEDHOL del PLC)." .

ns1:RetraccionDeEjeCanal2 a ns1:Parametro ;
    rdfs:label "Retracción de eje canal 2" ;
    ns1:textoExtracto "El CNC utiliza esta marca cuando retira los ejes de la pieza tras interrumpir un roscado (tecla [STOP] o marca _FEEDHOL del PLC)." .

ns1:RetraccionDeEjeCanal3 a ns1:Parametro ;
    rdfs:label "Retracción de eje canal 3" ;
    ns1:textoExtracto "El CNC utiliza esta marca cuando retira los ejes de la pieza tras interrumpir un roscado (tecla [STOP] o marca _FEEDHOL del PLC)." .

ns1:RetraccionDeEjeCanal4 a ns1:Parametro ;
    rdfs:label "Retracción de eje canal 4" ;
    ns1:textoExtracto "El CNC utiliza esta marca cuando retira los ejes de la pieza tras interrumpir un roscado (tecla [STOP] o marca _FEEDHOL del PLC)." .

