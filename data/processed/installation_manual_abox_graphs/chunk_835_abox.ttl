@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Se_al_ACTFBACK_axis
    a ex:Parametro ;
    rdfs:label "ACTFBACK(axis)" ;
    ex:textoExtracto "La marca ACTFBACK(axis) indica cuál es la captación activa. Ver en \"ACTFBACK(axis)\" la página 423." ;
    ex:identificador "ACTFBACK(axis)" .

ex:Se_al_DEAD_axis
    a ex:Parametro ;
    rdfs:label "DEAD(axis)" ;
    ex:textoExtracto "DEAD(axis) [...] indica como debe gestionar el CNC los empalmes entre bloques cuando está implicado el eje muerto." ;
    ex:identificador "DEAD(axis)" .

ex:Parametro_DWELL
    a ex:Parametro ;
    rdfs:label "DWELL" ;
    ex:textoExtracto "los movimientos en los que está implicado el eje muerto esperan el tiempo definido en el parámetro DWELL." ;
    ex:identificador "DWELL" .

ex:Se_al_SWITCH_axis
    a ex:Parametro ;
    rdfs:label "SWITCH(axis)" ;
    ex:textoExtracto "SWITCH(axis) [...] permite conmutar entre los diferentes ejes o cabezales del grupo." ;
    ex:identificador "SWITCH(axis)" .

ex:Se_al_TANDEMOFF_axis
    a ex:Parametro ;
    rdfs:label "TANDEMOFF(axis)" ;
    ex:textoExtracto "TANDEMOFF(axis) [...] permite desacoplar temporalmente en el lazo los ejes o cabezales implicados en el tándem." ;
    ex:identificador "TANDEMOFF(axis)" .

ex:SistemaControlEjes
    a ex:Sistema ;
    rdfs:label "Sistema de control de ejes y cabezales" ;
    ex:textoExtracto "motor) en el encendido, cuando se resetea el regulador y cuando se inicializa el anillo Sercos." ;
    ex:monitoreaParametro ex:Se_al_ACTFBACK_axis ;
    ex:monitoreaParametro ex:Se_al_DEAD_axis ;
    ex:monitoreaParametro ex:Parametro_DWELL ;
    ex:monitoreaParametro ex:Se_al_SWITCH_axis ;
    ex:monitoreaParametro ex:Se_al_TANDEMOFF_axis .

ex:ComponenteElectrico_MotorEje
    a ex:ComponenteElectrico ;
    rdfs:label "Motor de eje" ;
    ex:textoExtracto "motor) en el encendido, cuando se resetea el regulador y cuando se inicializa el anillo Sercos." ;
    ex:controla ex:Se_al_TANDEMOFF_axis .