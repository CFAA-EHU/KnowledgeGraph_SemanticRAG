@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MotorEjeC1 a ex:ComponenteMecanico ;
    rdfs:label "motor"@es ;
    ex:textoExtracto "motor"@es .

ex:MotorEjeC2 a ex:ComponenteMecanico ;
    rdfs:label "motor"@es ;
    ex:textoExtracto "motor"@es .

ex:EjeEsclavo a ex:ComponenteMecanico ;
    rdfs:label "eje esclavo"@es ;
    ex:textoExtracto "eje esclavo"@es .

ex:EjeMaestro a ex:ComponenteMecanico ;
    rdfs:label "eje maestro"@es ;
    ex:textoExtracto "eje maestro"@es .

ex:PLC a ex:ComponenteElectrico ;
    rdfs:label "PLC"@es ;
    ex:textoExtracto "PLC"@es .

ex:MarcaActivacion a ex:Parametro ;
    rdfs:label "marca de activación"@es ;
    ex:textoExtracto "Esta marca"@es .

ex:SistemaTandemEjeC a ex:Sistema ;
    rdfs:label "tándem de eje C"@es ;
    ex:textoExtracto "tándem de eje C"@es ;
    ex:compuestoPor ex:MotorEjeC1, ex:MotorEjeC2, ex:EjeEsclavo, ex:EjeMaestro, ex:PLC ;
    ex:tieneComponente ex:MarcaActivacion .