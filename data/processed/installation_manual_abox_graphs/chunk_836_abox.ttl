@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ControlDeColisiones a ns1:Parametro ;
    rdfs:label "Control de colisiones" ;
    ns1:identificador "COLLISIONOFF" ;
    ns1:textoExtracto "Para tener activo el control de colisiones, además de actuar sobre la marca COLLISIONOFF," .

ns1:EsquemaModelizadoMaquina a ns1:Esquema ;
    rdfs:label "Esquema modelizado de la máquina (archivo xca)" ;
    ns1:documentadoEn ns1:CNC8070_e952ae6594 ;
    ns1:textoExtracto "debe estar cargado el esquema modelizado de la máquina (archivo xca)" .

