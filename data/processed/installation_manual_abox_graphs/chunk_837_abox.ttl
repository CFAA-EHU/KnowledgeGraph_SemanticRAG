@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_11a7bafe8d a ns1:Parametro ;
    rdfs:label "Marca para cada canal de retención de potencia" ;
    ns1:identificador "DMCPWRHOLD" ;
    ns1:textoExtracto "Con el DMC activo, el canal del CNC activa (=1) esta marca si todos los valores de potencia leídos a lo largo de 2 segundos exceden la potencia a alcanzar multiplicada por el parámetro DMCPOWERFACTOR." .

ns1:Parametro_6f38ed9691 a ns1:Parametro ;
    rdfs:label "Marca para corte avanzado" ;
    ns1:identificador "ADVCUTOFF" ;
    ns1:textoExtracto "El CNC activa esta marca (cambio de 0 a 1) durante la ejecución de microjoints, cuando el láser alcanza la distancia G.ADVCUTOFFW o el tiempo G.ADVCUTOFFT antes del #CUTTING OFF." .

ns1:Parametro_c1c4d70610 a ns1:Parametro ;
    rdfs:label "Marca para cada canal de potencia pico" ;
    ns1:identificador "DMCPWRPEAK" ;
    ns1:textoExtracto "Con el DMC activo, el canal del CNC activa (=1) esta marca si la potencia leída supera a la potencia a alcanzar (potencia objetivo + potencia en vacío) en el porcentaje definido en el parámetro DMCPEAKSIZE." .

ns1:Parametro_ce16e79815 a ns1:Parametro ;
    rdfs:label "Marca para compensación cinemática 1" ;
    ns1:identificador "KINCOMP1" ;
    ns1:textoExtracto "El PLC activa esta marca cuando está activa la compensación de la cinemática (parámetro COMPID). Cada cinemática tiene una compensación asociada (parámetro COMPID)." .

ns1:Parametro_dee1a4d022 a ns1:Parametro ;
    rdfs:label "Marca para compensación cinemática 6" ;
    ns1:identificador "KINCOMP6" ;
    ns1:textoExtracto "El PLC activa esta marca cuando está activa la compensación de la cinemática (parámetro COMPID). Cada cinemática tiene una compensación asociada (parámetro COMPID)." .

