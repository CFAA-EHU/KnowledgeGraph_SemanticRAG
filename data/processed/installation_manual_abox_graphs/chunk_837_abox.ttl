@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SistemaTandemEjes
    a ex:Sistema ;
    rdfs:label "Sistema de control de ejes en tándem" ;
    ex:textoExtracto "Si el PLC activa esta marca, el eje esclavo se desacopla del maestro, y ambos ejes se pueden mover de forma independiente. [...] Aunque el tándem esté desacoplado, desde el punto de vista de programación, visualización, etc el tándem está activo." .

ex:SistemaGantryEjes
    a ex:Sistema ;
    rdfs:label "Sistema de control de ejes gantry" ;
    ex:textoExtracto "GANTRYOFF(axis) Esta marca hace referencia al eje esclavo del gantry. Si el PLC activa esta marca (cambio de 0 a 1), el CNC desacopla el eje gantry y permite mover sólo el eje maestro." .

ex:ParametroGANTRYOFF
    a ex:Parametro ;
    rdfs:label "GANTRYOFF(axis)" ;
    ex:identificador "GANTRYOFF(axis)" ;
    ex:textoExtracto "GANTRYOFF(axis) Esta marca hace referencia al eje esclavo del gantry. Si el PLC activa esta marca (cambio de 0 a 1), el CNC desacopla el eje gantry y permite mover sólo el eje maestro." ;
    ex:monitoreaParametro ex:SistemaGantryEjes .

ex:ParametroDesacopleTandem
    a ex:Parametro ;
    rdfs:label "Marca de desacople del eje esclavo (tándem)" ;
    ex:textoExtracto "Si el PLC activa esta marca, el eje esclavo se desacopla del maestro, y ambos ejes se pueden mover de forma independiente." ;
    ex:monitoreaParametro ex:SistemaTandemEjes .

ex:InterfazPanelJog
    a ex:InterfazUsuario ;
    rdfs:label "Panel de jog" ;
    ex:textoExtracto "El eje maestro se puede mover de la forma habitual desde el panel de jog, modo MDI/MDA, etc." ;
    ex:controla ex:SistemaTandemEjes .

ex:ModoMDI_MDA
    a ex:ModoOperacion ;
    rdfs:label "Modo MDI/MDA" ;
    ex:textoExtracto "El eje maestro se puede mover de la forma habitual desde el panel de jog, modo MDI/MDA, etc." ;
    ex:habilitadoPor ex:InterfazPanelJog .

ex:TareaBusquedaReferencia
    a ex:TareaMantenimiento ;
    rdfs:label "Búsqueda de referencia del eje maestro" ;
    ex:textoExtracto "El CNC podrá ejecutar una búsqueda de referencia del eje maestro, y al finalizar la búsqueda, el CNC también inicializará la cota del esclavo (con la cota del maestro)." ;
    ex:ejecutadoPor ex:SistemaTandemEjes .