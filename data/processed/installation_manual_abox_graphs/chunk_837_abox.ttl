@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:EjeMaestroA a ex:Maquina ;
    rdfs:label "eje maestro" ;
    ex:textoExtracto "El eje maestro se puede mover de la forma habitual desde el panel de jog, modo MDI/MDA, etc." .

ex:EjeEsclavoA a ex:Maquina ;
    rdfs:label "eje esclavo" ;
    ex:textoExtracto "el eje esclavo se desacopla del maestro, y ambos ejes se pueden mover de forma independiente", "El eje esclavo únicamente se puede mover desde el PLC a través del PLCOFFSET" .

ex:TandemA a ex:Sistema ;
    rdfs:label "tándem" ;
    ex:textoExtracto "esclavo del tándem", "Aunque el tándem esté desacoplado, desde el punto de vista de programación, visualización, etc el tándem está activo" ;
    ex:compuestoPor ex:EjeMaestroA, ex:EjeEsclavoA .

ex:PLCA a ex:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ex:textoExtracto "Si el PLC activa esta marca" .

ex:PLCOFFSETA a ex:Parametro ;
    rdfs:label "PLCOFFSET" ;
    ex:textoExtracto "El eje esclavo únicamente se puede mover desde el PLC a través del PLCOFFSET" .

ex:CNCA a ex:ComponenteElectrico ;
    rdfs:label "CNC" ;
    ex:textoExtracto "El CNC no generará consigna para el eje esclavo ni aplicará ninguna compensación", "El CNC visualiza las cotas del eje maestro", "El CNC podrá ejecutar una búsqueda de referencia del eje maestro, y al finalizar la búsqueda, el CNC también inicializará la cota del esclavo (con la cota del maestro)" .

ex:GANTRYOFF a ex:Parametro ;
    rdfs:label "GANTRYOFF(axis)" ;
    ex:textoExtracto "Esta marca hace referencia al eje esclavo del gantry. Si el PLC activa esta marca (cambio de 0 a 1), el CNC desacopla el eje gantry y permite mover sólo el eje maestro" .

ex:EjeGantryA a ex:Maquina ;
    rdfs:label "eje gantry" ;
    ex:textoExtracto "Esta marca hace referencia al eje esclavo del gantry" .

ex:ModoJogA a ex:ModoOperacion ;
    rdfs:label "modo jog" ;
    ex:textoExtracto "El eje maestro se puede mover de la forma habitual desde el panel de jog" .

ex:ModoMDIA a ex:ModoOperacion ;
    rdfs:label "modo MDI/MDA" ;
    ex:textoExtracto "modo MDI/MDA" .

ex:PanelJogA a ex:InterfazUsuario ;
    rdfs:label "panel de jog" ;
    ex:textoExtracto "desde el panel de jog" .