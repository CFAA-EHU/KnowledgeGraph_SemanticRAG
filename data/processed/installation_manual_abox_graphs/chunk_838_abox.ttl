@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CompensacionAsociada a ns1:Parametro ;
    rdfs:label "compensación asociada" ;
    ns1:textoExtracto "Cada cinemática tiene una compensación asociada (parámetro COMPID)." .

ns1:CompensacionKINCOMP1 a ns1:Parametro ;
    rdfs:label "compensación KINCOMP1" ;
    ns1:textoExtracto "KINCOMP1 está asociado a COMPID 1" .

ns1:CompensacionKINCOMP2 a ns1:Parametro ;
    rdfs:label "compensación KINCOMP2" ;
    ns1:textoExtracto "KINCOMP2 a COMPID2 y así sucesivamente." .

ns1:MarcaFWAITLIM a ns1:ElementoSeguridad ;
    rdfs:label "marca FWAITLIM" ;
    ns1:textoExtracto "El PLC activa esta marca cuando detiene la ejecución del programa por un #FOLLOW[WAITINLIMIT], para que la cota programada entre dentro de los límites (modelo láser)." .

