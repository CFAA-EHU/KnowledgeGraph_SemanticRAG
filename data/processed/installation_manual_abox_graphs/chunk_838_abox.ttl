@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:GEAR1 a ex:ModoOperacion ;
    rdfs:label "Modo de operación GEAR1" ;
    ex:textoExtracto "GEAR1SP1 (también se puede programar como GEAR1)" ;
    ex:identificador "GEAR1" .

ex:GEAR2 a ex:ModoOperacion ;
    rdfs:label "Modo de operación GEAR2" ;
    ex:textoExtracto "M42 con GEAR2" ;
    ex:identificador "GEAR2" .

ex:GEAR3 a ex:ModoOperacion ;
    rdfs:label "Modo de operación GEAR3" ;
    ex:textoExtracto "Hay una marca para cada cabezal. Los mnemónicos para cada cabezal son los siguientes. Se muestra como ejemplo los mnemónicos para GEAR1; para el resto de las marcas es igual." ;
    ex:identificador "GEAR3" .

ex:GEAR4 a ex:ModoOperacion ;
    rdfs:label "Modo de operación GEAR4" ;
    ex:textoExtracto "para el resto de las marcas es igual. [...] cuando el PLC recibe la confirmación de una de las marcas GEAR1 a GEAR4" ;
    ex:identificador "GEAR4" .

ex:GEAR1SP1 a ex:Parametro ;
    rdfs:label "Parámetro GEAR1SP1" ;
    ex:textoExtracto "GEAR1SP1 (también se puede programar como GEAR1)" ;
    ex:identificador "GEAR1SP1" .

ex:GEAR1SP2 a ex:Parametro ;
    rdfs:label "Parámetro GEAR1SP2" ;
    ex:textoExtracto "GEAR1SP2" ;
    ex:identificador "GEAR1SP2" .

ex:GEAR1SP3 a ex:Parametro ;
    rdfs:label "Parámetro GEAR1SP3" ;
    ex:textoExtracto "GEAR1SP3" ;
    ex:identificador "GEAR1SP3" .

ex:GEAR1SP4 a ex:Parametro ;
    rdfs:label "Parámetro GEAR1SP4" ;
    ex:textoExtracto "GEAR1SP4" ;
    ex:identificador "GEAR1SP4" .

ex:GEAR1SP5 a ex:Parametro ;
    rdfs:label "Parámetro GEAR1SP5" ;
    ex:textoExtracto "GEAR1SP5" ;
    ex:identificador "GEAR1SP5" .

ex:GEAR1SP6 a ex:Parametro ;
    rdfs:label "Parámetro GEAR1SP6" ;
    ex:textoExtracto "GEAR1SP6" ;
    ex:identificador "GEAR1SP6" .

ex:FuncionM41 a ex:ModoOperacion ;
    rdfs:label "Función auxiliar M41" ;
    ex:textoExtracto "El cambio de gama se da por finalizado cuando el PLC recibe la confirmación de la señal AUXEND. [...] Para que ambos sets de parámetros coincidan, deberá estar activa la función M41 en el CNC y la marca GEAR1 en el PLC" ;
    ex:identificador "M41" .

ex:FuncionM42 a ex:ModoOperacion ;
    rdfs:label "Función auxiliar M42" ;
    ex:textoExtracto "cuando el PLC recibe la confirmación de una de las marcas GEAR1 a GEAR4. [...] M42 con GEAR2" ;
    ex:identificador "M42" .

ex:FuncionM43 a ex:ModoOperacion ;
    rdfs:label "Función auxiliar M43" ;
    ex:textoExtracto "El CNC se lo indica al PLC mediante las funciones auxiliares M41, M42, M43 o M44" ;
    ex:identificador "M43" .

ex:FuncionM44 a ex:ModoOperacion ;
    rdfs:label "Función auxiliar M44" ;
    ex:textoExtracto "El CNC se lo indica al PLC mediante las funciones auxiliares M41, M42, M43 o M44" ;
    ex:identificador "M44" .

ex:SenalAUXEND a ex:Parametro ;
    rdfs:label "Señal AUXEND" ;
    ex:textoExtracto "El cambio de gama se da por finalizado cuando el PLC recibe la confirmación de la señal AUXEND" ;
    ex:identificador "AUXEND" .

ex:SenalGEAROK a ex:Parametro ;
    rdfs:label "Señal GEAROK" ;
    ex:textoExtracto "el cabezal activa la marca GEAROK" ;
    ex:identificador "GEAROK" .

ex:ParametroSZERO a ex:Parametro ;
    rdfs:label "Parámetro SZERO" ;
    ex:textoExtracto "cuando la velocidad del cabezal alcanza la velocidad definida en el parámetro SZERO" ;
    ex:identificador "SZERO" .

ex:ParametroNPULSES a ex:Parametro ;
    rdfs:label "Parámetro NPULSES" ;
    ex:textoExtracto "cuando el cambio de gama implica un cambio en la reducción (NPULSES, INPUTREV, OUTPUTREV)" ;
    ex:identificador "NPULSES" .

ex:ParametroINPUTREV a ex:Parametro ;
    rdfs:label "Parámetro INPUTREV" ;
    ex:textoExtracto "cuando el cambio de gama implica un cambio en la reducción (NPULSES, INPUTREV, OUTPUTREV)" ;
    ex:identificador "INPUTREV" .

ex:ParametroOUTPUTREV a ex:Parametro ;
    rdfs:label "Parámetro OUTPUTREV" ;
    ex:textoExtracto "cuando el cambio de gama implica un cambio en la reducción (NPULSES, INPUTREV, OUTPUTREV)" ;
    ex:identificador "OUTPUTREV" .

ex:SistemaControlCNC_PLC a ex:Sistema ;
    rdfs:label "Sistema de control CNC-PLC" ;
    ex:textoExtracto "El PLC utiliza estas marcas para indicar al CNC cuál de las gamas del cabezal está seleccionada (=1). Cuando se solicita un cambio de gama, el CNC se lo indica al PLC mediante las funciones auxiliares M41, M42, M43 o M44." ;
    ex:tieneComponente ex:FuncionM41, ex:FuncionM42, ex:FuncionM43, ex:FuncionM44 ;
    ex:monitoreaParametro ex:GEAR1, ex:GEAR2, ex:GEAR3, ex:GEAR4, ex:SenalGEAROK, ex:SenalAUXEND .

ex:FuncionM41 a ex:Tabla ;
    ex:habilitadoPor ex:GEAR1 .
ex:FuncionM42 a ex:Tabla ;
    ex:habilitadoPor ex:GEAR2 .