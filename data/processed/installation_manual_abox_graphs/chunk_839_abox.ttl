@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_009e5ee676 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC pone esta marca a (=1) para indicar al PLC que va a mover el eje o cabezal correspondiente en lazo cerrado." .

ns1:DireccionDeMovimientoDelEjeX a ns1:Parametro ;
    rdfs:label "Dirección de movimiento del eje X" ;
    ns1:identificador "DIRX" ;
    ns1:textoExtracto "El CNC pone esta marca a (=1) para indicar que el eje se desplaza en sentido negativo y a (=0) cuando se desplaza en sentido positivo." .

ns1:ParadaDeEjesPorPLC a ns1:AvisoSeguridad ;
    rdfs:label "Parada de ejes por PLC" ;
    ns1:textoExtracto "Si el PLC detiene el avance de los ejes (marca _FEEDHOL=0) la señal ENABLE(axis) se mantiene a (=1)." .

ns1:Parametro_0c85107319 a ns1:Parametro ;
    rdfs:label "Marca de habilitación del eje X" ;
    ns1:identificador "ENABLEX" ;
    ns1:textoExtracto "ENABLEX corresponde al eje X." .

ns1:Parametro_49dc616caf a ns1:Parametro ;
    rdfs:label "Marca de habilitación del eje B" ;
    ns1:identificador "ENABLEB" ;
    ns1:textoExtracto "ENABLE5 corresponde al eje B." .

ns1:Parametro_67f93aeb0e a ns1:Parametro ;
    rdfs:label "Marca de habilitación del eje Z2" ;
    ns1:identificador "ENABLEZ2" ;
    ns1:textoExtracto "ENABLEZ2 corresponde al eje Z2." .

ns1:Parametro_948dbb952d a ns1:Parametro ;
    rdfs:label "Marca de habilitación del cabezal S" ;
    ns1:identificador "ENABLES" ;
    ns1:textoExtracto "ENABLES corresponde al cabezal S." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "El PLC habilita el eje o cabezal si es necesario." .

