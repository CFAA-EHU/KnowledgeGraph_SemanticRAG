@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:MFUN1 a ex:Parametro ;
    ex:identificador "MFUN1" ;
    ex:textoExtracto "El CNC indica al PLC la gama solicitada con MFUN1=42" .

ex:MSTROBE a ex:Sensor ;
    ex:identificador "MSTROBE" ;
    ex:textoExtracto "el PLC al detectar la solicitud pone un indicativo interno. DFU MSTROBE AND CPS MFUN* EQ 42 = SET M1002" .

ex:M1002 a ex:Sensor ;
    ex:identificador "M1002" ;
    ex:textoExtracto "DFU MSTROBE AND CPS MFUN* EQ 42 = SET M1002" .

ex:AUXEND a ex:Sensor ;
    ex:identificador "AUXEND" ;
    ex:textoExtracto "se lo indica al CNC con AUXEND a (=0)" .

ex:GEAR1 a ex:Sensor ;
    ex:identificador "GEAR1" ;
    ex:textoExtracto "I21 = GEAR1" .

ex:GEAR2 a ex:Sensor ;
    ex:identificador "GEAR2" ;
    ex:textoExtracto "I22 = GEAR2" .

ex:MINAENDW a ex:Parametro ;
    ex:identificador "MINAENDW" ;
    ex:textoExtracto "el parámetro máquina MINAENDW" .

ex:PLCCNTL a ex:Sensor ;
    ex:identificador "PLCCNTL" ;
    ex:textoExtracto "Se dispone de una señal para cada cabezal. Los mnemónicos para cada cabezal son los siguientes. PLCCNTL1 (también se puede programar como PLCCNTL)" .

ex:PLCCNTL1 a ex:Sensor ;
    ex:identificador "PLCCNTL1" ;
    ex:textoExtracto "PLCCNTL1 (también se puede programar como PLCCNTL)" .

ex:SANALOG a ex:Parametro ;
    ex:identificador "SANALOG" ;
    ex:textoExtracto "SANALOG1 (también se puede programar como SANALOG)" .

ex:SANALOG1 a ex:Parametro ;
    ex:identificador "SANALOG1" ;
    ex:textoExtracto "SANALOG1 (también se puede programar como SANALOG)" .