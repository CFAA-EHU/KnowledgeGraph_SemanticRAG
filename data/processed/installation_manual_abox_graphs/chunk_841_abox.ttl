@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_3efc93dfac a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC activa (=1) la marca REFPOIN(axis) en el arranque si en la sesión anterior el eje ha sido referenciado correctamente, el CNC ha recuperado la posición del eje guardada en el apagado y la posición del encóder es la misma que la del apagado (diferencia de posiciones menor que el parámetro MAXDIFREF)." .

ns1:CaptacionAbsoluta a ns1:Parametro ;
    rdfs:label "Captación absoluta" ;
    ns1:identificador "ABSFEEDBACK" ;
    ns1:textoExtracto "Sin captación absoluta (parámetro ABSFEEDBACK=No)." .

ns1:DiferenciaMaximaDePosicionDeReferencia a ns1:Parametro ;
    rdfs:label "Diferencia máxima de posición de referencia" ;
    ns1:identificador "MAXDIFREF" ;
    ns1:textoExtracto "diferencia de posiciones menor que el parámetro MAXDIFREF." .

ns1:Parametro_2f5f18c208 a ns1:Parametro ;
    rdfs:label "Marca REFPOIN(axis)" ;
    ns1:identificador "REFPOIN" ;
    ns1:textoExtracto "La marca REFPOIN(axis) siempre está activa (=1). No es necesaria la búsqueda de referencia." .

