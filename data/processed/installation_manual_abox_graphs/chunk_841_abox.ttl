@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:CabezalSercosVelocidad rdfs:label "Cabezal Sercos en velocidad" ;
    a ex:ComponenteMecanico ;
    ex:textoExtracto "Cabezal Sercos en velocidad. La consigna en SANALOG vendrá expresada en diezmilésima de rpm." .

ex:CabezalSercosPosicion rdfs:label "Cabezal Sercos en posición" ;
    a ex:ComponenteMecanico ;
    ex:textoExtracto "Cabezal Sercos en posición. La consigna en SANALOG vendrá expresada en diezmilésima de grado." .

ex:CabezalMechatrolink rdfs:label "Cabezal Mechatrolink" ;
    a ex:ComponenteMecanico ;
    ex:textoExtracto "Cabezal Mechatrolink. La consigna en SANALOG vendrá expresada en centésimas de hercio." .

ex:SistemaSANALOG rdfs:label "SANALOG" ;
    a ex:Sistema ;
    ex:textoExtracto "La consigna en SANALOG vendrá expresada en diezmilésima de rpm." ,
        "La consigna en SANALOG vendrá expresada en diezmilésima de grado." ,
        "La consigna en SANALOG vendrá expresada en centésimas de hercio." .

ex:AvisoSincronizacionCabezal rdfs:label "aviso indicando que no es posible controlar cabezal sincronizado desde PLCCNTL" ;
    a ex:AvisoSeguridad ;
    ex:textoExtracto "Si se intenta controlar un cabezal sincronizado (tanto maestro como esclavo) mediante PLCCNTL, se mostrará un aviso indicando que no es posible." .

ex:PLC rdfs:label "PLC" ;
    a ex:ComponenteElectrico ;
    ex:textoExtracto "La consigna indicada en SANALOG no se aplica con rampa, por lo que será responsabilidad del programa de PLC aplicar de forma gradual la consigna cuando sea necesario." ,
        "Cuando el cabezal se controla desde el PLC no se pierde el punto de referencia del cabezal." ,
        "El PLC no es prioritario a una sincronización de cabezales." ,
        "Estando activa la gama 1 se solicita la gama 4." .

ex:Gama1 rdfs:label "gama 1" ;
    a ex:ModoOperacion ;
    ex:textoExtracto "Estando activa la gama 1 se solicita la gama 4." .

ex:Gama4 rdfs:label "gama 4" ;
    a ex:ModoOperacion ;
    ex:textoExtracto "Estando activa la gama 1 se solicita la gama 4." .