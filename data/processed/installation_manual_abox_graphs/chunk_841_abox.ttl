@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:CabezalesSistema
    a ex:Sistema ;
    rdfs:label "Sistema de cabezales controlados" ;
    ex:textoExtracto "Cabezal Sercos en velocidad... Cabezal Mechatrolink... sincronización de cabezales..." ;
    ex:tieneComponente ex:CabezalSercosVelocidad, ex:CabezalSercosPosicion, ex:CabezalMechatrolink ;
    ex:controla ex:ParametroSANALOG_Velocidad, ex:ParametroSANALOG_Posicion, ex:ParametroSANALOG_Frecuencia .

ex:CabezalSercosVelocidad
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal Sercos (modo velocidad)" ;
    ex:textoExtracto "Cabezal Sercos en velocidad. La consigna en SANALOG vendrá expresada en diezmilésima de rpm." ;
    ex:monitoreaParametro ex:ParametroSANALOG_Velocidad .

ex:CabezalSercosPosicion
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal Sercos (modo posición)" ;
    ex:textoExtracto "Cabezal Sercos en posición. La consigna en SANALOG vendrá expresada en diezmilésima de grado." ;
    ex:monitoreaParametro ex:ParametroSANALOG_Posicion .

ex:CabezalMechatrolink
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal Mechatrolink" ;
    ex:textoExtracto "Cabezal Mechatrolink. La consigna en SANALOG vendrá expresada en centésimas de hercio." ;
    ex:monitoreaParametro ex:ParametroSANALOG_Frecuencia .

ex:ParametroSANALOG_Velocidad
    a ex:Parametro ;
    rdfs:label "Consigna SANALOG (velocidad)" ;
    ex:textoExtracto "La consigna en SANALOG vendrá expresada en diezmilésima de rpm" ;
    ex:valor "unidad: diezmilésima de rpm" .

ex:ParametroSANALOG_Posicion
    a ex:Parametro ;
    rdfs:label "Consigna SANALOG (posición)" ;
    ex:textoExtracto "La consigna en SANALOG vendrá expresada en diezmilésima de grado" ;
    ex:valor "unidad: diezmilésima de grado" .

ex:ParametroSANALOG_Frecuencia
    a ex:Parametro ;
    rdfs:label "Consigna SANALOG (frecuencia)" ;
    ex:textoExtracto "La consigna en SANALOG vendrá expresada en centésimas de hercio" ;
    ex:valor "unidad: centésima de Hz" .

ex:AvisoControlSincronizado
    a ex:AvisoSeguridad ;
    rdfs:label "Aviso de control PLC en cabezales sincronizados" ;
    ex:textoExtracto "Si se intenta controlar un cabezal sincronizado (tanto maestro como esclavo) mediante PLCCNTL, se mostrará un aviso indicando que no es posible." ;
    ex:mitigaRiesgo ex:CabezalesSistema .