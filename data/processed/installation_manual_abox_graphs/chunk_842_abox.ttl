ns1:CNC8070_0cc93c26bc a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:monitoreaParametro ns1:Parametro_759776d7c3,
        ns1:Parametro_e53a04dc42 ;
    ns1:textoExtracto "El CNC utiliza estas marcas cuando la comunicación con el regulador es vía Sercos® e indican el estado del regulador." .

ns1:ComponenteElectrico_87317a9ba9 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador" ;
    ns1:activaAlarma ns1:AvisoSeguridad_52528c9d82 ;
    ns1:textoExtracto "Tras accionar el interruptor general del armario eléctrico se le proporcionan 24 V DC al regulador." .

ns1:AvisoSeguridad_52528c9d82 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de captación fallida" ;
    ns1:textoExtracto "En caso de error, ambas marcas se mantienen a (=1) si el eje se encuentra en movimiento." .

ns1:Parametro_759776d7c3 a ns1:Parametro ;
    rdfs:label "Marca de estado del regulador" ;
    ns1:identificador "DRSTAF(axis)" ;
    ns1:textoExtracto "El CNC utiliza estas marcas cuando la comunicación con el regulador es vía Sercos® e indican el estado del regulador." .

ns1:Parametro_e53a04dc42 a ns1:Parametro ;
    rdfs:label "Marca de estado del regulador" ;
    ns1:identificador "DRSTAS(axis)" ;
    ns1:textoExtracto "El CNC utiliza estas marcas cuando la comunicación con el regulador es vía Sercos® e indican el estado del regulador." .

