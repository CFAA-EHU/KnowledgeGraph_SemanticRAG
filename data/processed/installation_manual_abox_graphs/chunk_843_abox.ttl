@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaRegulador a ns1:Sistema ;
    rdfs:label "Sistema Regulador" ;
    ns1:parametroMonitoradoPor ns1:EstadoDeLaSalidaDelSistema,
        ns1:EstadoDelSistema ;
    ns1:textoExtracto "Para ello, activar las entradas Drive enable y Speed enable. Marcas DRSTAF(*)=1 DRSTAS(*)=0 4 Una vez activadas las entradas Drive enable y Speed enable el regulador está funcionando correctamente." .

ns1:EstadoDeLaSalidaDelSistema a ns1:Parametro ;
    rdfs:label "Estado de la salida del sistema" ;
    ns1:identificador "DRSTAF" ;
    ns1:textoExtracto "Marcas DRSTAF(*)=0 DRSTAS(*)=1 3 Cuando se dispone de potencia en el bus, el regulador está preparado para tener par." .

ns1:EstadoDelSistema a ns1:Parametro ;
    rdfs:label "Estado del sistema" ;
    ns1:identificador "DRSTAS" ;
    ns1:textoExtracto "Marcas DRSTAF(*)=0 DRSTAS(*)=1 3 Cuando se dispone de potencia en el bus, el regulador está preparado para tener par." .

