@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PLCM3 a ex:ComponenteElectrico ;
    rdfs:label "PLCM3" ;
    ex:textoExtracto "PLCM3" .

ex:PLCM4 a ex:ComponenteElectrico ;
    rdfs:label "PLCM4" ;
    ex:textoExtracto "PLCM4" .

ex:PLCM5 a ex:ComponenteElectrico ;
    rdfs:label "PLCM5" ;
    ex:textoExtracto "PLCM5" .

ex:PLC a ex:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ex:textoExtracto "El PLC dispone de una marca para cada cabezal." .

ex:CNC a ex:ComponenteElectrico ;
    rdfs:label "CNC" ;
    ex:textoExtracto "indicar al CNC que debe ejecutar la función M correspondiente" .