@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:PLC_SistemaControl ex:textoExtracto "El PLC podrá modificar la velocidad del cabezal mediante la variable (V.)PLC.S.sn, pero sin generar un cambio de gama aunque éste sea automático (parámetro AUTOGEAR)." ;
    a ex:Sistema ;
    ex:tieneComponente ex:Variable_PLC_S_sn .

ex:Variable_PLC_S_sn ex:textoExtracto "(V.)PLC.S.sn" ;
    a ex:Parametro .

ex:Parametro_AUTOGEAR ex:textoExtracto "parámetro AUTOGEAR" ;
    a ex:Parametro .

ex:CNC_SistemaControl ex:textoExtracto "El tratamiento de estas funciones M es igual que las ejecutadas desde el CNC. Cuando el PLC activa una de estas marcas, el CNC activa la marca MSTROBE y escribe en el registro MFUN la función M correspondiente." ;
    a ex:Sistema ;
    ex:tieneComponente ex:Marca_MSTROBE, ex:Registro_MFUN .

ex:Marca_MSTROBE ex:textoExtracto "marca MSTROBE" ;
    a ex:Parametro .

ex:Registro_MFUN ex:textoExtracto "registro MFUN" ;
    a ex:Parametro .

ex:Senal_AUXEND ex:textoExtracto "señal AUXEND" ;
    a ex:Sensor .

ex:Funcion_M a ex:Tabla ;
    ex:textoExtracto "funciones M" ;
    a ex:Parametro .

ex:Estado_Canal_EnError ex:textoExtracto "status del canal sea distinto de 'En error'" ;
    a ex:ModoOperacion .

ex:Estado_Canal_NoReady ex:textoExtracto "status del canal sea distinto de 'No ready'" ;
    a ex:ModoOperacion .

ex:Estado_CNC_EnError ex:textoExtracto "estado del CNC es 'En error'" ;
    a ex:ModoOperacion .

ex:Estado_CNC_NoReady ex:textoExtracto "estado del CNC es 'No ready'" ;
    a ex:ModoOperacion .

ex:Estado_CNC_Reset ex:textoExtracto "CNC está haciendo un reset" ;
    a ex:ModoOperacion .

ex:Estado_CNC_ValidandoParametros ex:textoExtracto "CNC validando parámetros máquina" ;
    a ex:ModoOperacion .

ex:Eje_C ex:textoExtracto "cabezal está trabajando como eje C" ;
    a ex:ComponenteMecanico .

ex:Roscado_Rigido ex:textoExtracto "cabezal está roscando (ya sea roscado rígido" ;
    a ex:TareaMantenimiento .

ex:Roscado_NoRigido ex:textoExtracto "roscado con macho no rígido" ;
    a ex:TareaMantenimiento .

ex:Roscado_Electronico ex:textoExtracto "roscado electrónico" ;
    a ex:TareaMantenimiento .

ex:Marca_PorCabezal ex:textoExtracto "Hay una marca para cada cabezal." ;
    a ex:Parametro .