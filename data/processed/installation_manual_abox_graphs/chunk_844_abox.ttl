@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BandaDeMuerte a ns1:Parametro ;
    rdfs:label "Banda de muerte" ;
    ns1:identificador "INPOSW" ;
    ns1:textoExtracto "Un eje está en posición cuando permanece dentro de la banda de muerte (parámetro INPOSW) el tiempo indicado en el parámetro INPOTIME." .

ns1:CNC8070_3d8a0f8c15 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC pone esta marca a (=1) cuando el eje o cabezal correspondiente se encuentra en posición y no hay ninguna petición de movimiento (marca ENABLE(axis) desactivada)." .

ns1:EjeEnPosicion a ns1:Parametro ;
    rdfs:label "Eje en posición" ;
    ns1:identificador "INPOS" ;
    ns1:textoExtracto "El CNC pone esta marca a (=1) cuando el eje o cabezal correspondiente se encuentra en posición y no hay ninguna petición de movimiento (marca ENABLE(axis) desactivada)." .

ns1:EstadoDelEjeHirth a ns1:Parametro ;
    rdfs:label "Estado del eje Hirth" ;
    ns1:identificador "HIRTHON" ;
    ns1:textoExtracto "La marca HIRTHON(axis) indica si el eje Hirth está trabajando como eje Hirth (=1) o como un eje rotativo o lineal normal (=0)." .

ns1:EstadoDelReguladorDriveReadyStatusA a ns1:Parametro ;
    rdfs:label "Estado del regulador (Drive Ready Status A)" ;
    ns1:identificador "DRSTAF" ;
    ns1:textoExtracto "Marcas DRSTAF(*)=1 DRSTAS(*)=0 4 Una vez activadas las entradas Drive enable y Speed enable el regulador está funcionando correctamente." .

ns1:EstadoDelReguladorDriveReadyStatusS a ns1:Parametro ;
    rdfs:label "Estado del regulador (Drive Ready Status S)" ;
    ns1:identificador "DRSTAS" ;
    ns1:textoExtracto "Marcas DRSTAF(*)=1 DRSTAS(*)=0 4 Una vez activadas las entradas Drive enable y Speed enable el regulador está funcionando correctamente." .

ns1:IndicadorDeEjeHirth a ns1:Parametro ;
    rdfs:label "Indicador de eje Hirth" ;
    ns1:identificador "HIRTH" ;
    ns1:textoExtracto "El parámetro máquina HIRTH indica si el eje puede trabajar como eje Hirth." .

ns1:TiempoParaEstarEnPosicion a ns1:Parametro ;
    rdfs:label "Tiempo para estar en posición" ;
    ns1:identificador "INPOTIME" ;
    ns1:textoExtracto "Un eje está en posición cuando permanece dentro de la banda de muerte (parámetro INPOSW) el tiempo indicado en el parámetro INPOTIME." .

