@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IndicaQueElEjeTrabajaComoEjeHirth a ns1:AccionProhibida ;
    rdfs:label "Indica que el eje trabaja como eje Hirth" ;
    ns1:textoExtracto "Las funciones G170 y G171 indican si se desea que el eje trabaje como eje Hirth (G171, función por defecto) o como un eje rotativo o lineal normal (G170)." .

ns1:IndicaQueElEjeTrabajaComoUnEjeRotativoOLinealNormal a ns1:AccionProhibida ;
    rdfs:label "Indica que el eje trabaja como un eje rotativo o lineal normal" ;
    ns1:textoExtracto "Las funciones G170 y G171 indican si se desea que el eje trabaje como eje Hirth (G171, función por defecto) o como un eje rotativo o lineal normal (G170)." .

ns1:IndicaSiElEjeHirthEstaBien a ns1:AccionProhibida ;
    rdfs:label "Indica si el eje Hirth está bien" ;
    ns1:textoExtracto "La marca MATCH(axis) indica si el eje Hirth está bien." .

ns1:IndicaSiElEjePuedeTrabajarComoEjeHirth a ns1:Parametro ;
    rdfs:label "Indica si el eje puede trabajar como eje Hirth" ;
    ns1:textoExtracto "El parámetro máquina HIRTH indica si el eje puede trabajar como eje Hirth." .

