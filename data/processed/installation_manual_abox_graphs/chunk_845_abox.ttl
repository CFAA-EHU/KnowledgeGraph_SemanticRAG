@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SLIMITACSPDL rdfs:label "SLIMITACSPDL" ;
    a ex:Parametro ;
    ex:textoExtracto "SLIMITACSPDL Hay una marca para cada cabezal. Los mnemónicos para cada cabezal son los siguientes. SLIMITACSPDL1 (también se puede programar como SLIMITACSPDL) SLIMITACSPDL2 SLIMITACSPDL3 SLIMITACSPDL4 SLIMITACSPDL5 SLIMITACSPDL6 Si el PLC activa esta marca, el CNC activa los límites de seguridad para la"@es .

ex:SLIMITACSPDL1 rdfs:label "SLIMITACSPDL1" ;
    a ex:Parametro ;
    ex:textoExtracto "SLIMITACSPDL1 (también se puede programar como SLIMITACSPDL)"@es .

ex:SLIMITACSPDL2 rdfs:label "SLIMITACSPDL2" ;
    a ex:Parametro ;
    ex:textoExtracto "SLIMITACSPDL2"@es .

ex:SLIMITACSPDL3 rdfs:label "SLIMITACSPDL3" ;
    a ex:Parametro ;
    ex:textoExtracto "SLIMITACSPDL3"@es .

ex:SLIMITACSPDL4 rdfs:label "SLIMITACSPDL4" ;
    a ex:Parametro ;
    ex:textoExtracto "SLIMITACSPDL4"@es .

ex:SLIMITACSPDL5 rdfs:label "SLIMITACSPDL5" ;
    a ex:Parametro ;
    ex:textoExtracto "SLIMITACSPDL5"@es .

ex:SLIMITACSPDL6 rdfs:label "SLIMITACSPDL6" ;
    a ex:Parametro ;
    ex:textoExtracto "SLIMITACSPDL6"@es .