@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_493aa293c4 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC pone esta marca a (=1) cuando el eje o cabezal correspondiente debe ser engrasado." .

ns1:IndicaLaDistanciaQueSeDebeMoverAntesDeSerEngrasado a ns1:Parametro ;
    rdfs:label "Indica la distancia que se debe mover antes de ser engrasado" ;
    ns1:identificador "DISTLUBRI" ;
    ns1:textoExtracto "El parámetro máquina DISTLUBRI indica la distancia que se debe mover antes de ser engrasado." .

ns1:IndicaQueSeEstaAparcandoUnEjeOCabezal a ns1:Parametro ;
    rdfs:label "Indica que se está aparcando un eje o cabezal" ;
    ns1:identificador "PARK(axis)" ;
    ns1:textoExtracto "El CNC pone la marca PARK(axis) a (=1) para indicar que se está aparcando un eje o cabezal." .

ns1:IndicaQueSeEstaDesaparcandoUnEjeOCabezal a ns1:Parametro ;
    rdfs:label "Indica que se está desaparcando un eje o cabezal" ;
    ns1:identificador "UNPARK(axis)" ;
    ns1:textoExtracto "El CNC pone la marca UNPARK(axis) a (=1) para indicar que se está desaparcando." .

ns1:IndicaSiElEjeHirthEstaBienPosicionado a ns1:Parametro ;
    rdfs:label "Indica si el eje Hirth está bien posicionado" ;
    ns1:identificador "MATCH(axis)" ;
    ns1:textoExtracto "La marca MATCH(axis) indica si el eje Hirth está bien posicionado (=1) o no (=0)." .

ns1:IndicaSiElEjeOCabezalCorrespondienteDebeSerEngrasado a ns1:Parametro ;
    rdfs:label "Indica si el eje o cabezal correspondiente debe ser engrasado" ;
    ns1:identificador "LUBR(axis)" ;
    ns1:textoExtracto "El CNC pone esta marca a (=1) cuando el eje o cabezal correspondiente debe ser engrasado." .

ns1:IndicaSiElEjeTrabajaComoEjeHirthOComoUnEjeRotativoOLinealNormal a ns1:Parametro ;
    rdfs:label "Indica si el eje trabaja como eje Hirth o como un eje rotativo o lineal normal" ;
    ns1:identificador "G171" ;
    ns1:textoExtracto "G171 indican si se desea que el eje trabaje como eje Hirth (G171, función por defecto) o como un eje rotativo o lineal normal (G170)." .

