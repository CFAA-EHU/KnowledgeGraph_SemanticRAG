@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:LASERON rdfs:label "LASERON" ;
    a ex:Sensor ;
    ex:textoExtracto "El PLC activa está marca para indicar que el láser está encendido." .

ex:SHUTTERON rdfs:label "SHUTTERON" ;
    a ex:Sensor ;
    ex:textoExtracto "El PLC activa está marca para indicar que el obturador de la fuente láser está abierto." .

ex:LASERREADY rdfs:label "LASERREADY" ;
    a ex:Sensor ;
    ex:textoExtracto "El PLC activa está marca para indicar que el láser está preparado." .

ex:PWMON rdfs:label "PWMON" ;
    a ex:Sensor ;
    ex:textoExtracto "Esta marca permite activar y desactivar el PWM desde el PLC." .

ex:PWMFREQ rdfs:label "PWMFREQ" ;
    a ex:Parametro ;
    ex:textoExtracto "Frecuencia del PWM (entre 2 y 5000 Hz; por defecto, 0)." ;
    ex:valor "2 a 5000 Hz; por defecto, 0" .

ex:PWMDUTY rdfs:label "PWMDUTY" ;
    a ex:Parametro ;
    ex:textoExtracto "Ciclo de trabajo del PWM (entre 1 y 1000; por defecto, 500)" ;
    ex:valor "1 a 1000; por defecto, 500" .

ex:Tabla_PWM a ex:Tabla ;
    rdfs:label "Tabla de registros PWM" ;
    a ex:Tabla ;
    ex:textoExtracto "La configuración del PWM se realiza con los siguiente registros. | Registros. | Significado. | | --- | --- | | PWMFREQ | Frecuencia del PWM (entre 2 y 5000 Hz; por defecto, 0). | | PWMDUTY | Ciclo de trabajo del PWM (entre 1 y 1000; por defecto, 500)" ;
    ex:compuestoPor ex:PWMFREQ, ex:PWMDUTY .