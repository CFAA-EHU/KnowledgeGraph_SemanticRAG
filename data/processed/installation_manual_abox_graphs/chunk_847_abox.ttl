@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SenalLaserOn
    a ex:InterfazUsuario ;
    rdfs:label "LASERON" ;
    ex:textoExtracto "LASERON El PLC activa está marca para indicar que el láser está encendido." ;
    ex:monitoreaParametro ex:EstadoLaser .

ex:SenalShutterOn
    a ex:InterfazUsuario ;
    rdfs:label "SHUTTERON" ;
    ex:textoExtracto "SHUTTERON El PLC activa está marca para indicar que el obturador de la fuente láser está abierto." ;
    ex:monitoreaParametro ex:EstadoObturador .

ex:SenalLaserReady
    a ex:InterfazUsuario ;
    rdfs:label "LASERREADY" ;
    ex:textoExtracto "LASERREADY El PLC activa está marca para indicar que el láser está preparado." ;
    ex:monitoreaParametro ex:EstadoPreparacionLaser .

ex:SenalPWMOn
    a ex:InterfazUsuario ;
    rdfs:label "PWMON" ;
    ex:textoExtracto "PWMON Esta marca permite activar y desactivar el PWM desde el PLC." ;
    ex:controla ex:ParametroPWM .

ex:ParametroPWM
    a ex:Parametro ;
    rdfs:label "Configuración PWM" ;
    ex:textoExtracto "La configuración del PWM se realiza con los siguiente registros." ;
    ex:tieneComponente ex:RegistroPWMFreq ,
                       ex:RegistroPWMDuty .

ex:RegistroPWMFreq
    a ex:Parametro ;
    rdfs:label "PWMFREQ" ;
    ex:identificador "PWMFREQ" ;
    ex:valor "Frecuencia del PWM (entre 2 y 5000 Hz; por defecto, 0)"^^xsd:string ;
    ex:textoExtracto "PWMFREQ | Frecuencia del PWM (entre 2 y 5000 Hz; por defecto, 0)." .

ex:RegistroPWMDuty
    a ex:Parametro ;
    rdfs:label "PWMDUTY" ;
    ex:identificador "PWMDUTY" ;
    ex:valor "Ciclo de trabajo del PWM (entre 1 y 1000; por defecto, 500)"^^xsd:string ;
    ex:textoExtracto "PWMDUTY | Ciclo de trabajo del PWM (entre 1 y 1000; por defecto, 500)" .

ex:EstadoLaser
    a ex:Parametro ;
    rdfs:label "Estado del láser (encendido/apagado)" ;
    ex:textoExtracto "LASERON [...] indicar que el láser está encendido." .

ex:EstadoObturador
    a ex:Parametro ;
    rdfs:label "Estado del obturador láser (abierto/cerrado)" ;
    ex:textoExtracto "SHUTTERON [...] indicar que el obturador de la fuente láser está abierto." .

ex:EstadoPreparacionLaser
    a ex:Parametro ;
    rdfs:label "Estado de preparación del láser" ;
    ex:textoExtracto "LASERREADY [...] indicar que el láser está preparado." .