@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Tabla848 a ex:Tabla ;
    ex:textoExtracto """| Estado del PWM desde
el CNC. | Estado del PWM desde
el PLC. | Estado de PWM. |
| --- | --- | --- |
| Apagado. | Apagado. | PWM apagado. |
| Activo. | Apagado. | PWM activo desde el CNC. |
| Apagado. | Activo. | PWM activo desde el PLC. |
| Activo. | Activo. | PWM activo desde el PLC. |""" .

ex:EstadoPWMApagado a ex:Parametro ;
    ex:textoExtracto "PWM apagado." ;
    rdfs:label "PWM apagado" .

ex:EstadoPWMCNCActivo a ex:Parametro ;
    ex:textoExtracto "PWM activo desde el CNC." ;
    rdfs:label "PWM activo desde el CNC" .

ex:EstadoPWCPLCActivo a ex:Parametro ;
    ex:textoExtracto "PWM activo desde el PLC." ;
    rdfs:label "PWM activo desde el PLC" .

ex:Tabla848 a ex:Tabla ;
    ex:compuestoPor ex:EstadoPWMApagado, ex:EstadoPWMCNCActivo, ex:EstadoPWCPLCActivo .