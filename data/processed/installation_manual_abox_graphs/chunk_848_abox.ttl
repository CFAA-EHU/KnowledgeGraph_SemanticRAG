ns1:CNC8070_11e97d1677 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC no permitirá aparcar un eje en los siguientes casos." .

ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:solucionaFallo ns1:FalloAparcamientoCabezal ;
    ns1:textoExtracto "El CNC no permitirá aparcar un cabezal en los siguientes casos." .

ns1:Eje a ns1:ComponenteMecanico ;
    rdfs:label "Eje" ;
    ns1:solucionaFallo ns1:FalloAparcamientoEje ;
    ns1:textoExtracto "El CNC no permitirá aparcar un eje en los siguientes casos." .

ns1:SenalDeHabilitacionParaAparcar a ns1:Parametro ;
    rdfs:label "Señal de habilitación para aparcar" ;
    ns1:textoExtracto "El CNC utiliza las señales PARK y UNPARK para informar al PLC que se ha desencadenado el proceso correspondiente de aparcar o desaparcar." .

ns1:SenalDeHabilitacionParaDesaparcar a ns1:Parametro ;
    rdfs:label "Señal de habilitación para desaparcar" ;
    ns1:textoExtracto "El CNC utiliza las señales PARK y UNPARK para informar al PLC que se ha desencadenado el proceso correspondiente de aparcar o desaparcar." .

ns1:FalloAparcamientoCabezal a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede aparcar el cabezal" ;
    ns1:textoExtracto "El CNC no permitirá aparcar un cabezal en los siguientes casos." .

ns1:FalloAparcamientoEje a ns1:DiagnosticoFallo ;
    rdfs:label "No se puede aparcar el eje" ;
    ns1:textoExtracto "El CNC no permitirá aparcar un eje en los siguientes casos." .

