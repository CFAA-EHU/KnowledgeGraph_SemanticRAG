@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:PWM ex:textoExtracto "Las modificaciones del PWM tanto desde programa como desde PLC se actualizan sin esperar a que termine el ciclo del PWM en proceso, y de la forma más continua posible respecto a las condiciones previas; es decir, no se espera a que la señal por defecto se ponga a cero o a uno en cada cambio." ;
    a ex:ComponenteElectrico ;
    ex:tieneFrecuencia ex:PWMFREQ ;
    ex:monitoreaParametro ex:PWMDUTY ;
    ex:monitoreaParametro ex:ENABLEPWM ;
    ex:monitoreaParametro ex:ENABLEPWROUT ;
    ex:monitoreaParametro ex:ENABLEPWRDUTY .

ex:PWMFREQ ex:textoExtracto "PWMFREQ Frecuencia del PWM, cuando el PWM ha sido activado desde el PLC (entre 2 y 5000 Hz; por defecto, 0)." ;
    a ex:Frecuencia ;
    ex:valor "entre 2 y 5000 Hz; por defecto, 0" .

ex:PWMDUTY ex:textoExtracto "PWMDUTY Ciclo de trabajo del PWM, cuando el PWM ha sido activado desde el PLC (entre 1 y 1000 décimas de %; por defecto, 500)." ;
    a ex:Parametro ;
    ex:valor "entre 1 y 1000 décimas de %; por defecto, 500" .

ex:ENABLEPWM ex:textoExtracto "ENABLEPWM El PLC activa esta marca (cambio de 1 a 0) para habilitar el PWM activo en el CNC; si no hay un PWM activo, esta marca no hace nada." ;
    a ex:Parametro ;
    ex:valor "marca (cambio de 1 a 0)" .

ex:ENABLEPWROUT ex:textoExtracto "ENABLEPWROUT Marca activa por defecto. Esta marca está asociada al control de potencia a través de la salida analógica asociada al cabezal (#PWRCTRL ON [OUT])." ;
    a ex:Parametro ;
    ex:valor "Marca activa por defecto" .

ex:ENABLEPWRDUTY ex:textoExtracto "ENABLEPWRDUTY Marca activa por defecto. Esta marca está asociada al control duty del PWM (#PWRCTRL ON [DUTY])." ;
    a ex:Parametro ;
    ex:valor "Marca activa por defecto" .