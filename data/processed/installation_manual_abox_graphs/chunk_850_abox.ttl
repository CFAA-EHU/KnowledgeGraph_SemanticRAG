@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_02e60c417f a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:SistemaPLC ;
    ns1:solucionaFallo ns1:ManiobraParaAparcarUnEjeOCabezalDesdeElCNC,
        ns1:ManiobraParaDesaparcarUnEjeOCabezalDesdeElCNC ;
    ns1:textoExtracto "El CNC comprueba si se puede aparcar el eje requerido." .

ns1:Parametro_0e54fd1ddd a ns1:Parametro ;
    rdfs:label "Marca para indicar que el eje debe ser aparcado" ;
    ns1:identificador "PARK" ;
    ns1:textoExtracto "el CNC pone la marca PARK a (=1) para indicar al PLC que debe aparcar el eje correspondiente." .

ns1:Parametro_7a6b527283 a ns1:Parametro ;
    rdfs:label "Marca para indicar que el eje debe ser desaparcado" ;
    ns1:identificador "UNPARK" ;
    ns1:textoExtracto "el CNC pone la marca UNPARK a (=1) para indicar al PLC que debe desaparcar el eje correspondiente." .

ns1:Parametro_a533b81001 a ns1:Parametro ;
    rdfs:label "Marca que indica si el eje ha sido aparcado o no" ;
    ns1:identificador "PARKED" ;
    ns1:textoExtracto "el PLC pone la marca PARKED a (=1)." .

ns1:ManiobraParaAparcarUnEjeOCabezalDesdeElCNC a ns1:TareaMantenimiento ;
    rdfs:label "Maniobra para aparcar un eje o cabezal desde el CNC" ;
    ns1:textoExtracto "Maniobra para aparcar un eje o cabezal desde el CNC." .

ns1:ManiobraParaDesaparcarUnEjeOCabezalDesdeElCNC a ns1:TareaMantenimiento ;
    rdfs:label "Maniobra para desaparcar un eje o cabezal desde el CNC" ;
    ns1:textoExtracto "Maniobra para desaparcar un eje o cabezal desde el CNC." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "PLC" ;
    ns1:textoExtracto "el PLC debe quitar previamente la habilitación del regulador correspondiente al eje a aparcar (DRENA)." .

