@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:MarcaPWM ex:textoExtracto "marca está asociada al control de la potencia del PWM (#PWRCTRL ON [FREQ])" ;
    a ex:Parametro ;
    ex:identificador "#PWMOUT. ENABLEPWRFREQ" .

ex:MarcaGap ex:textoExtracto "marca para deshabilitar el control del gap activo" ;
    a ex:Parametro .

ex:MarcaColisionGap ex:textoExtracto "sensor para el control del gap puede disponer de una señal de colisión que se conecta al CNC" ;
    a ex:Sensor ;
    ex:textoExtracto "sensor para el control del gap puede disponer de una señal de colisión que se conecta al CNC" .

ex:MarcaLeapfrog ex:textoExtracto "marca para deshabilitar el leapfrog activo" ;
    a ex:Parametro .

ex:MarcaCutViewRefresh ex:textoExtracto "marca para refrescar el Cut_View" ;
    a ex:Parametro .