@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_1e705b5e09 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:monitoreaParametro ns1:EstadoDeAparcadoDelEjeB,
        ns1:PeticionParaAparcarElEjeB,
        ns1:PeticionParaDesaparcarElEjeB ;
    ns1:textoExtracto "El CNC reconocerá que se ha completado el proceso al detectar que se ha desactivado la señal PARKED." .

ns1:Sensor_d506f90169 a ns1:Sensor ;
    rdfs:label "Sensor de presencia del eje B" ;
    ns1:textoExtracto "La entrada I15 corresponde al sensor de presencia del eje 'B' PARKB AND NOT I15 = SET PARKEDB" .

ns1:EstadoDeAparcadoDelEjeB a ns1:Parametro ;
    rdfs:label "Estado de aparcado del eje B" ;
    ns1:identificador "PARKEDB" ;
    ns1:textoExtracto "el eje está aparcado (SET PARKEDB)." .

ns1:PeticionParaAparcarElEjeB a ns1:Parametro ;
    rdfs:label "Petición para aparcar el eje B" ;
    ns1:identificador "PARKB" ;
    ns1:textoExtracto "Si hay una petición para aparcar el eje 'B' (PARKB)" .

ns1:PeticionParaDesaparcarElEjeB a ns1:Parametro ;
    rdfs:label "Petición para desaparcar el eje B" ;
    ns1:identificador "UNPARKB" ;
    ns1:textoExtracto "Si hay una petición para desaparcar el eje 'B' (UNPARKB)" .

