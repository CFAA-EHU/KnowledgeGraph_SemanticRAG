@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_1e7c9c4eb6 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:monitoreaParametro ns1:SenalDRENAB,
        ns1:SenalPARK,
        ns1:SenalPARKED,
        ns1:SenalREFPOIN,
        ns1:SenalSERVOBON,
        ns1:SenalSPENAB,
        ns1:SenalUNPARK ;
    ns1:textoExtracto "El CNC utiliza las señales lógicas PARK y UNPARK para informar al PLC que los procesos correspondientes de aparcar o desaparcar se encuentran en ejecución." .

ns1:Sensor_5583b88b57 a ns1:Sensor ;
    rdfs:label "Sensor de presencia del eje" ;
    ns1:textoExtracto "Esta marca normalmente está afectada por la entrada correspondiente al sensor de presencia del eje." .

ns1:SenalDRENAB a ns1:Parametro ;
    rdfs:label "Señal DRENAB" ;
    ns1:identificador "DRENAB" ;
    ns1:textoExtracto "NOT (PARKB OR UNPARKB OR PARKEDB) AND··· = DRENAB = SPENAB = SERVOBON Si el eje no está aparcado ni en proceso y se cumplen las condiciones de habilitación, se habilita el eje." .

ns1:SenalPARK a ns1:Parametro ;
    rdfs:label "Señal PARK" ;
    ns1:identificador "PARK" ;
    ns1:textoExtracto "El CNC utiliza las señales lógicas PARK y UNPARK para informar al PLC que los procesos correspondientes de aparcar o desaparcar se encuentran en ejecución." .

ns1:SenalPARKED a ns1:Parametro ;
    rdfs:label "Señal PARKED" ;
    ns1:identificador "PARKED" ;
    ns1:textoExtracto "La maniobra de aparcar/desaparcar ejes gestionada desde el programa de PLC se controla mediante la señal PARKED." .

ns1:SenalREFPOIN a ns1:Parametro ;
    rdfs:label "Señal REFPOIN" ;
    ns1:identificador "REFPOIN" ;
    ns1:textoExtracto "Por seguridad, tras aparcar y desaparcar un eje, la señal REFPOIN del eje se pone a (=0)." .

ns1:SenalSERVOBON a ns1:Parametro ;
    rdfs:label "Señal SERVOBON" ;
    ns1:identificador "SERVOBON" ;
    ns1:textoExtracto "NOT (PARKB OR UNPARKB OR PARKEDB) AND··· = DRENAB = SPENAB = SERVOBON Si el eje no está aparcado ni en proceso y se cumplen las condiciones de habilitación, se habilita el eje." .

ns1:SenalSPENAB a ns1:Parametro ;
    rdfs:label "Señal SPENAB" ;
    ns1:identificador "SPENAB" ;
    ns1:textoExtracto "NOT (PARKB OR UNPARKB OR PARKEDB) AND··· = DRENAB = SPENAB = SERVOBON Si el eje no está aparcado ni en proceso y se cumplen las condiciones de habilitación, se habilita el eje." .

ns1:SenalUNPARK a ns1:Parametro ;
    rdfs:label "Señal UNPARK" ;
    ns1:identificador "UNPARK" ;
    ns1:textoExtracto "El CNC utiliza las señales lógicas PARK y UNPARK para informar al PLC que los procesos correspondientes de aparcar o desaparcar se encuentran en ejecución." .

