@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PLC_852_1 a ex:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ex:textoExtracto "el PLC activa esta marca (cambio de 1 a 0)" .

ex:Marca_OUTOFGAP_852 a ex:Parametro ;
    rdfs:label "OUTOFGAP" ;
    ex:textoExtracto "OUTOFGAP El PLC activa esta marca (cambio de 1 a 0) para indicar que la boquilla ha salido alguna vez del gap (parámetros GAPMIN y GAPMAX) durante la ejecución del programa." .

ex:Marca_OUTOFTOL_852 a ex:Parametro ;
    rdfs:label "OUTOFTOL" ;
    ex:textoExtracto "OUTOFTOL El PLC activa esta marca para" .

ex:Parametro_GAPMIN_852 a ex:Parametro ;
    rdfs:label "GAPMIN" ;
    ex:textoExtracto "parámetros GAPMIN y GAPMAX" .

ex:Parametro_GAPMAX_852 a ex:Parametro ;
    rdfs:label "GAPMAX" ;
    ex:textoExtracto "parámetros GAPMIN y GAPMAX" .

ex:Boquilla_852 a ex:ComponenteMecanico ;
    rdfs:label "boquilla" ;
    ex:textoExtracto "la boquilla ha salido alguna vez del gap" .