@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Seccion6_11_SenalesLogicasModificablesLaser
    a ex:Capitulo ;
    rdfs:label "Señales lógicas modificables; láser"@es ;
    ex:textoExtracto "Señales lógicas modificables; láser. [...] Por ejemplo, el corte de chapas más largas que el recorrido de la mesa, en un único programa, se realiza en varias etapas [...] Al final de cada etapa, hay que refrescar el Cut_View para que muestre la nueva sección a cortar."@es ;
    ex:documentadoEn ex:Pagina455_456 .

ex:Pagina455_456
    a ex:Pagina ;
    ex:identificador "455-456" ;
    ex:textoExtracto "6.11 Señales lógicas modificables; láser. Por ejemplo, el corte de chapas más largas que el recorrido de la mesa, en un único programa, se realiza en varias etapas, moviendo la chapa entre una etapa y otra. Al final de cada etapa, hay que refrescar el Cut_View para que muestre la nueva sección a cortar."@es .

ex:InterfazCutView
    a ex:InterfazUsuario ;
    rdfs:label "Cut_View" ;
    ex:textoExtracto "Al final de cada etapa, hay que refrescar el Cut_View para que muestre la nueva sección a cortar."@es ;
    ex:ilustradoEn ex:Seccion6_11_SenalesLogicasModificablesLaser .

ex:SenalOUTOFGAP
    a ex:Parametro ;
    rdfs:label "OUTOFGAP" ;
    ex:textoExtracto "OUTOFGAP: El PLC activa esta marca (cambio de 1 a 0) para indicar que la boquilla ha salido alguna vez del gap (parámetros GAPMIN y GAPMAX) durante la ejecución del programa. Esta marca permanece activa hasta iniciar la ejecución de un programa."@es ;
    ex:monitoreaParametro ex:ParametroGAPMIN, ex:ParametroGAPMAX ;
    ex:documentadoEn ex:Seccion6_11_SenalesLogicasModificablesLaser .

ex:ParametroGAPMIN
    a ex:Parametro ;
    rdfs:label "GAPMIN" ;
    ex:textoExtracto "parámetros GAPMIN y GAPMAX"@es .

ex:ParametroGAPMAX
    a ex:Parametro ;
    rdfs:label "GAPMAX" ;
    ex:textoExtracto "parámetros GAPMIN y GAPMAX"@es .

ex:SenalOUTOFTOL
    a ex:Parametro ;
    rdfs:label "OUTOFTOL" ;
    ex:textoExtracto "OUTOFTOL: El PLC activa esta marca para [...]"@es ;
    ex:documentadoEn ex:Seccion6_11_SenalesLogicasModificablesLaser .