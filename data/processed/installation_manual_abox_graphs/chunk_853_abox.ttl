@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:OUTOFTOL a ex:Sensor ;
    rdfs:label "OUTOFTOL" ;
    ex:textoExtracto "OUTOFTOL El PLC activa esta marca para indicar que la boquilla ha salido alguna vez de la tolerancia del gap (parámetro GAPTOL) durante la ejecución del programa. Esta marca permanece activa hasta iniciar la ejecución de un programa."@es .

ex:GAPTOL a ex:Parametro ;
    rdfs:label "GAPTOL" ;
    ex:textoExtracto "parámetro GAPTOL"@es .

ex:GAPMIN a ex:Parametro ;
    rdfs:label "GAPMIN" ;
    ex:textoExtracto "parámetros GAPMIN"@es .

ex:GAPMAX a ex:Parametro ;
    rdfs:label "GAPMAX" ;
    ex:textoExtracto "parámetros GAPMAX"@es .