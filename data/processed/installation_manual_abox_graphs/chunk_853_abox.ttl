@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_20f4c6393d a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC envía al regulador el comando para aparcar el eje." .

ns1:EncendidoDelServoDelEjeV a ns1:Parametro ;
    rdfs:label "Encendido del servo del eje V" ;
    ns1:identificador "SERVOVON" ;
    ns1:textoExtracto "NOT (PARKV OR UNPARKV OR PARKEDV) AND··· = DRENAV = SPENAV = SERVOVON" .

ns1:HabilitacionDelEjeV a ns1:Parametro ;
    rdfs:label "Habilitación del eje V" ;
    ns1:identificador "SPENAV" ;
    ns1:textoExtracto "NOT (PARKV OR UNPARKV OR PARKEDV) AND··· = DRENAV = SPENAV" .

ns1:HabilitacionDelReguladorDelEjeV a ns1:Parametro ;
    rdfs:label "Habilitación del regulador del eje V" ;
    ns1:identificador "DRENAV" ;
    ns1:textoExtracto "NOT (PARKV OR UNPARKV OR PARKEDV) AND··· = DRENAV" .

ns1:Parametro_3384ed3204 a ns1:Parametro ;
    rdfs:label "Marca de aparcamiento del eje V" ;
    ns1:identificador "PARKV" ;
    ns1:textoExtracto "NOT (PARKV OR UNPARKV OR PARKEDV) AND··· = DRENAV" .

ns1:Parametro_697767810c a ns1:Parametro ;
    rdfs:label "Marca de desaparcamiento del eje V" ;
    ns1:identificador "UNPARKV" ;
    ns1:textoExtracto "NOT (PARKV OR UNPARKV OR PARKEDV) AND··· = DRENAV" .

ns1:Parametro_a7547dbb9a a ns1:Parametro ;
    rdfs:label "Marca para aparcar eje V" ;
    ns1:identificador "PARKEDV" ;
    ns1:textoExtracto "I10 = PARKEDV Eje presente." .

ns1:SeleccionDeCaptacion_e87b2c6a39 a ns1:Parametro ;
    rdfs:label "Selección de captación" ;
    ns1:identificador "FBACKSEL" ;
    ns1:textoExtracto "El tipo de captación se podrá conmutar desde el PLC mediante la marca FBACKSEL(axis)." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Desde al programa de PLC se pone la marca PARKED a (=1) para aparcar el eje correspondiente." .

ns1:TipoDeCaptacion a ns1:Parametro ;
    rdfs:label "Tipo de captación" ;
    ns1:identificador "FBACKSRC" ;
    ns1:textoExtracto "Consultar el parámetro máquina FBACKSRC." .

