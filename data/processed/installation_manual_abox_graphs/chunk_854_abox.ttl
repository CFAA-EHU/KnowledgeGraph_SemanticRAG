    ns1:identificador "TANGACT(axis)" ;
    ns1:textoExtracto "El CNC pone esta marca a (=1) para indicar que el control tangencial se encuentra activo en el eje." .

ns1:Parametro_c876e33d36 a ns1:Parametro ;
