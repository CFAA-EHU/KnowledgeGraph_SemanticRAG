@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SistemaGestorHerramientas
    a                     ex:Sistema ;
    rdfs:label            "Sistema de gestión de herramientas"@es ;
    ex:textoExtracto      "SETTMEM [...] El PLC pone esta marca a (=1) para activar la emergencia del gestor de herramientas. [...] RESTMEM [...] El PLC pone esta marca a (=1) para cancelar la emergencia del gestor de herramientas. [...] CUTTINGON [...] Cuando se le asocia un tiempo máximo de vida (monitorización) a la herramienta el CNC consulta esta marca para saber si la herramienta está ejecutando (=1) o no (=0). [...] TREJECT [...] Si el PLC pone esta marca a (=1) el CNC entiende que la herramienta debe ser rechazada."@es ;
    ex:tieneComponente    ex:Parametro_SETTMEMZ1, ex:Parametro_SETTMEMZ2, ex:Parametro_SETTMEMZ3, ex:Parametro_SETTMEMZ4,
                         ex:Parametro_RESTMEMZ1, ex:Parametro_RESTMEMZ2, ex:Parametro_RESTMEMZ3, ex:Parametro_RESTMEMZ4,
                         ex:Parametro_CUTTINGONC1, ex:Parametro_CUTTINGONC2, ex:Parametro_CUTTINGONC3, ex:Parametro_CUTTINGONC4,
                         ex:Parametro_TREJECTC1, ex:Parametro_TREJECTC2, ex:Parametro_TREJECTC3, ex:Parametro_TREJECTC4 .

ex:Parametro_SETTMEMZ1
    a                     ex:Parametro ;
    rdfs:label            "SETTMEMZ1 (activación emergencia almacén 1)"@es ;
    ex:identificador      "SETTMEMZ1" ;
    ex:valor              "1" ;
    ex:textoExtracto      "SETTMEMZ1 (también se puede programar como SETTMEM) [...] El PLC pone esta marca a (=1) para activar la emergencia del gestor de herramientas."@es ;
    ex:monitoreaParametro ex:SistemaGestorHerramientas .

