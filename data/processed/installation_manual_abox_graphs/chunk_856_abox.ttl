@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:MZTOCH1
    a ex:Parametro ;
    rdfs:label "MZTOCH1" ;
    ex:identificador "MZTOCH1" ;
    ex:textoExtracto "MZTOCH1 Hay una marca para cada almacén. [...] El PLC debe poner esta marca a (=1) tras llevar la herramienta del almacén al brazo cambiador 1." ;
    ex:monitoreaParametro ex:SistemaGestorHerramientas .

ex:MZTOCH1MZ1
    a ex:Parametro ;
    rdfs:label "MZTOCH1MZ1" ;
    ex:identificador "MZTOCH1MZ1" ;
    ex:textoExtracto "MZTOCH1MZ1 (también se puede programar como MZTOCH1)" ;
    ex:monitoreaParametro ex:SistemaGestorHerramientas .

ex:MZTOCH1MZ2
    a ex:Parametro ;
    rdfs:label "MZTOCH1MZ2" ;
    ex:identificador "MZTOCH1MZ2" ;
    ex:textoExtracto "MZTOCH1MZ2" ;
    ex:monitoreaParametro ex:SistemaGestorHerramientas .

ex:MZTOCH1MZ3
    a ex:Parametro ;
    rdfs:label "MZTOCH1MZ3" ;
    ex:identificador "MZTOCH1MZ3" ;
    ex:textoExtracto "MZTOCH1MZ3" ;
    ex:monitoreaParametro ex:SistemaGestorHerramientas .

ex:MZTOCH1MZ4
    a ex:Parametro ;
    rdfs:label "MZTOCH1MZ4" ;
    ex:identificador "MZTOCH1MZ4" ;
    ex:textoExtracto "MZTOCH1MZ4" ;
    ex:monitoreaParametro ex:SistemaGestorHerramientas .

ex:CH1TOSPDL
    a ex:Parametro ;
    rdfs:label "CH1TOSPDL" ;
    ex:identificador "CH1TOSPDL" ;
    ex:textoExtracto "CH1TOSPDL Hay una marca para cada almacén. [...] El PLC debe poner" ;
    ex:monitoreaParametro ex:SistemaGestorHerramientas .

ex:CH1TOSPDLMZ1
    a ex:Parametro ;
    rdfs:label "CH1TOSPDLMZ1" ;
    ex:identificador "CH1TOSPDLMZ1" ;
    ex:textoExtracto "CH1TOSPDLMZ1 (equivalente a CH1TOSPDL)" ;
    ex:monitoreaParametro ex:SistemaGestorHerramientas .

ex:CH1TOSPDLMZ2
    a ex:Parametro ;
    rdfs:label "CH1TOSPDLMZ2" ;
    ex:identificador "CH1TOSPDLMZ2" ;
    ex:textoExtracto "CH1TOSPDLMZ2" ;
    ex:monitoreaParametro ex:SistemaGestorHerramientas .

ex:CH1TOSPDLMZ3
    a ex:Parametro ;
    rdfs:label "CH1TOSPDLMZ3" ;
    ex:identificador "CH1TOSPDLMZ3" ;
    ex:textoExtracto "CH1TOSPDLMZ3" ;
    ex:monitoreaParametro ex:SistemaGestorHerramientas .

ex:CH1TOSPDLMZ4
    a ex:Parametro ;
    rdfs:label "CH1TOSPDLMZ4" ;
    ex:identificador "CH1TOSPDLMZ4" ;
    ex:textoExtracto "CH1TOSPDLMZ4" ;
    ex:monitoreaParametro ex:SistemaGestorHerramientas .

ex:SistemaGestorHerramientas
    a ex:Sistema ;
    rdfs:label "Sistema gestor de herramientas" ;
    ex:textoExtracto "Señales modificables del gestor de herramientas" ;
    ex:compuestoPor ex:MZTOCH1, ex:CH1TOSPDL, ex:MZTOCH1MZ1, ex:MZTOCH1MZ2, ex:MZTOCH1MZ3, ex:MZTOCH1MZ4, ex:CH1TOSPDLMZ1, ex:CH1TOSPDLMZ2, ex:CH1TOSPDLMZ3, ex:CH1TOSPDLMZ4 .