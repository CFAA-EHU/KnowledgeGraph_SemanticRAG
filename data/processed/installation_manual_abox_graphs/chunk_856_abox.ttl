@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MZTOCH1 a ex:Sensor ;
    rdfs:label "MZTOCH1" ;
    ex:identificador "MZTOCH1" ;
    ex:textoExtracto "Hay una marca para cada almacén. Los mnemónicos para cada almacén son los siguientes. MZTOCH1MZ1 (también se puede programar como MZTOCH1) MZTOCH1MZ2 MZTOCH1MZ3 MZTOCH1MZ4 Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del almacén al brazo cambiador 1." .

ex:MZTOCH1MZ1 a ex:Sensor ;
    rdfs:label "MZTOCH1MZ1" ;
    ex:identificador "MZTOCH1MZ1" ;
    ex:textoExtracto "MZTOCH1MZ1 (también se puede programar como MZTOCH1)" .

ex:MZTOCH1MZ2 a ex:Sensor ;
    rdfs:label "MZTOCH1MZ2" ;
    ex:identificador "MZTOCH1MZ2" ;
    ex:textoExtracto "MZTOCH1MZ2" .

ex:MZTOCH1MZ3 a ex:Sensor ;
    rdfs:label "MZTOCH1MZ3" ;
    ex:identificador "MZTOCH1MZ3" ;
    ex:textoExtracto "MZTOCH1MZ3" .

ex:MZTOCH1MZ4 a ex:Sensor ;
    rdfs:label "MZTOCH1MZ4" ;
    ex:identificador "MZTOCH1MZ4" ;
    ex:textoExtracto "MZTOCH1MZ4" .

ex:CH1TOSPDL a ex:Sensor ;
    rdfs:label "CH1TOSPDL" ;
    ex:identificador "CH1TOSPDL" ;
    ex:textoExtracto "Hay una marca para cada almacén. Los mnemónicos para cada almacén son los siguientes. CH1TOSPDLMZ1 (equivalente a CH1TOSPDL) CH1TOSPDLMZ2 CH1TOSPDLMZ3 CH1TOSPDLMZ4 Utilizar con almacén asíncrono o síncrono con brazo." .

ex:CH1TOSPDLMZ1 a ex:Sensor ;
    rdfs:label "CH1TOSPDLMZ1" ;
    ex:identificador "CH1TOSPDLMZ1" ;
    ex:textoExtracto "CH1TOSPDLMZ1 (equivalente a CH1TOSPDL)" .

ex:CH1TOSPDLMZ2 a ex:Sensor ;
    rdfs:label "CH1TOSPDLMZ2" ;
    ex:identificador "CH1TOSPDLMZ2" ;
    ex:textoExtracto "CH1TOSPDLMZ2" .

ex:CH1TOSPDLMZ3 a ex:Sensor ;
    rdfs:label "CH1TOSPDLMZ3" ;
    ex:identificador "CH1TOSPDLMZ3" ;
    ex:textoExtracto "CH1TOSPDLMZ3" .

ex:CH1TOSPDLMZ4 a ex:Sensor ;
    rdfs:label "CH1TOSPDLMZ4" ;
    ex:identificador "CH1TOSPDLMZ4" ;
    ex:textoExtracto "CH1TOSPDLMZ4" .