@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:CH1TOSPDLMZ1 a ex:Parametro ;
    ex:identificador "CH1TOSPDLMZ1" ;
    ex:textoExtracto "mnemónicos para cada almacén son los siguientes. CH1TOSPDLMZ1 (equivalente a CH1TOSPDL)" .

ex:CH1TOSPDLMZ2 a ex:Parametro ;
    ex:identificador "CH1TOSPDLMZ2" ;
    ex:textoExtracto "CH1TOSPDLMZ2" .

ex:CH1TOSPDLMZ3 a ex:Parametro ;
    ex:identificador "CH1TOSPDLMZ3" ;
    ex:textoExtracto "CH1TOSPDLMZ3" .

ex:CH1TOSPDLMZ4 a ex:Parametro ;
    ex:identificador "CH1TOSPDLMZ4" ;
    ex:textoExtracto "CH1TOSPDLMZ4 Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del brazo cambiador 1 al cabezal." .

ex:SPDLTOCH1 a ex:Parametro ;
    ex:identificador "SPDLTOCH1" ;
    ex:textoExtracto "Los mnemónicos para cada almacén son los siguientes. SPDLTOCH1MZ1 (equivalente a SPDLTOCH1) SPDLTOCH1MZ2 SPDLTOCH1MZ3 SPDLTOCH1MZ4 Utilizar con almacén síncrono con 1 sólo brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal al brazo cambiador 1." .

ex:SPDLTOCH1MZ1 a ex:Parametro ;
    ex:identificador "SPDLTOCH1MZ1" ;
    ex:textoExtracto "SPDLTOCH1MZ1 (equivalente a SPDLTOCH1)" .

ex:SPDLTOCH1MZ2 a ex:Parametro ;
    ex:identificador "SPDLTOCH1MZ2" ;
    ex:textoExtracto "SPDLTOCH1MZ2" .

ex:SPDLTOCH1MZ3 a ex:Parametro ;
    ex:identificador "SPDLTOCH1MZ3" ;
    ex:textoExtracto "SPDLTOCH1MZ3" .

ex:SPDLTOCH1MZ4 a ex:Parametro ;
    ex:identificador "SPDLTOCH1MZ4" ;
    ex:textoExtracto "SPDLTOCH1MZ4 Utilizar con almacén síncrono con 1 sólo brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal al brazo cambiador 1." .

ex:SPDLTOCH2 a ex:Parametro ;
    ex:identificador "SPDLTOCH2" ;
    ex:textoExtracto "Hay una marca para cada almacén. Los mnemónicos para cada almacén son los siguientes. SPDLTOCH2MZ1 (equivalente a SPDLTOCH2) SPDLTOCH2MZ2 SPDLTOCH2MZ3 SPDLTOCH2MZ4 Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal al brazo cambiador 2." .

ex:SPDLTOCH2MZ1 a ex:Parametro ;
    ex:identificador "SPDLTOCH2MZ1" ;
    ex:textoExtracto "SPDLTOCH2MZ1 (equivalente a SPDLTOCH2)" .

ex:SPDLTOCH2MZ2 a ex:Parametro ;
    ex:identificador "SPDLTOCH2MZ2" ;
    ex:textoExtracto "SPDLTOCH2MZ2" .

ex:SPDLTOCH2MZ3 a ex:Parametro ;
    ex:identificador "SPDLTOCH2MZ3" ;
    ex:textoExtracto "SPDLTOCH2MZ3" .

ex:SPDLTOCH2MZ4 a ex:Parametro ;
    ex:identificador "SPDLTOCH2MZ4" ;
    ex:textoExtracto "SPDLTOCH2MZ4 Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal al brazo cambiador 2." .

ex:CH1TOMZ a ex:Parametro ;
    ex:identificador "CH1TOMZ" ;
    ex:textoExtracto "Hay una marca para cada almacén. Los mnemónicos para cada almacén son los siguientes. CH1TOMZ1 (también se puede programar como CH1TOMZ) CH1TOMZ2 CH1TOMZ3 CH1TOMZ4 Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del brazo cambiador 1 al almacén." .

ex:CH1TOMZ1 a ex:Parametro ;
    ex:identificador "CH1TOMZ1" ;
    ex:textoExtracto "CH1TOMZ1 (también se puede programar como CH1TOMZ)" .

ex:CH1TOMZ2 a ex:Parametro ;
    ex:identificador "CH1TOMZ2" ;
    ex:textoExtracto "CH1TOMZ2" .

ex:CH1TOMZ3 a ex:Parametro ;
    ex:identificador "CH1TOMZ3" ;
    ex:textoExtracto "CH1TOMZ3" .

ex:CH1TOMZ4 a ex:Parametro ;
    ex:identificador "CH1TOMZ4" ;
    ex:textoExtracto "CH1TOMZ4 Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del brazo cambiador 1 al almacén." .

ex:CH2TOMZ a ex:Parametro ;
    ex:identificador "CH2TOMZ" ;
    ex:textoExtracto "CH2TOMZ Hay una marca para cada almacén. Los mnemónicos para cada almacén son los siguientes." .