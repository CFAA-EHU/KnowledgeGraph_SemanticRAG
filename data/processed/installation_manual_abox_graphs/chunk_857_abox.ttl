ex:Sistema_GestorHerramientas
    a ex:Sistema ;
    rdfs:label "Gestor de herramientas" ;
    ex:textoExtracto "Señales modificables del gestor de herramientas." ;
    ex:tieneComponente ex:Se_al_CH1TOSPDLMZ1, ex:Se_al_CH1TOSPDLMZ2, ex:Se_al_CH1TOSPDLMZ3, ex:Se_al_CH1TOSPDLMZ4,
                       ex:Se_al_SPDLTOCH1MZ1, ex:Se_al_SPDLTOCH1MZ2, ex:Se_al_SPDLTOCH1MZ3, ex:Se_al_SPDLTOCH1MZ4,
                       ex:Se_al_SPDLTOCH2MZ1, ex:Se_al_SPDLTOCH2MZ2, ex:Se_al_SPDLTOCH2MZ3, ex:Se_al_SPDLTOCH2MZ4,
                       ex:Se_al_CH1TOMZ1, ex:Se_al_CH1TOMZ2, ex:Se_al_CH1TOMZ3 .