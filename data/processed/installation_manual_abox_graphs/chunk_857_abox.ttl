@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Se_al_CH1TOSPDLMZ1
    a ex:Parametro ;
    rdfs:label "CH1TOSPDLMZ1" ;
    ex:identificador "CH1TOSPDLMZ1" ;
    ex:textoExtracto "mnemónicos para cada almacén son los siguientes. CH1TOSPDLMZ1 (equivalente a CH1TOSPDL) [...] El PLC debe poner esta marca a (=1) tras llevar la herramienta del brazo cambiador 1 al cabezal." ;
    ex:valor "1" .

