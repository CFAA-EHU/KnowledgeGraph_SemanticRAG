@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:CH2TOMZ a ex:Parametro ;
    rdfs:label "CH2TOMZ" ;
    ex:identificador "CH2TOMZ" ;
    ex:textoExtracto "El PLC debe poner esta marca a (=1) tras llevar la herramienta del brazo cambiador 1 al almacén. CH2TOMZ Hay una marca para cada almacén. Los mnemónicos para cada almacén son los siguientes. CH2TOMZ1 (también se puede programar como CH2TOMZ) CH2TOMZ2 CH2TOMZ3 CH2TOMZ4 Utilizar con almacén asíncrono o síncrono con brazo." .

ex:CH2TOMZ1 a ex:Parametro ;
    rdfs:label "CH2TOMZ1" ;
    ex:identificador "CH2TOMZ1" ;
    ex:textoExtracto "CH2TOMZ1 (también se puede programar como CH2TOMZ)" .

ex:CH2TOMZ2 a ex:Parametro ;
    rdfs:label "CH2TOMZ2" ;
    ex:identificador "CH2TOMZ2" ;
    ex:textoExtracto "CH2TOMZ2" .

ex:CH2TOMZ3 a ex:Parametro ;
    rdfs:label "CH2TOMZ3" ;
    ex:identificador "CH2TOMZ3" ;
    ex:textoExtracto "CH2TOMZ3" .

ex:CH2TOMZ4 a ex:Parametro ;
    rdfs:label "CH2TOMZ4" ;
    ex:identificador "CH2TOMZ4" ;
    ex:textoExtracto "CH2TOMZ4" .

ex:SPDLTOGR a ex:Parametro ;
    rdfs:label "SPDLTOGR" ;
    ex:identificador "SPDLTOGR" ;
    ex:textoExtracto "El PLC debe poner esta marca a (=1) tras llevar la herramienta del brazo cambiador 2 al almacén. SPDLTOGR Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. SPDLTOGRC1 (también se puede programar como SPDLTOGR) SPDLTOGRC2 SPDLTOGRC3 SPDLTOGRC4 Utilizar con almacén que permite herramientas de tierra." .

ex:SPDLTOGRC1 a ex:Parametro ;
    rdfs:label "SPDLTOGRC1" ;
    ex:identificador "SPDLTOGRC1" ;
    ex:textoExtracto "SPDLTOGRC1 (también se puede programar como SPDLTOGR)" .

ex:SPDLTOGRC2 a ex:Parametro ;
    rdfs:label "SPDLTOGRC2" ;
    ex:identificador "SPDLTOGRC2" ;
    ex:textoExtracto "SPDLTOGRC2" .

ex:SPDLTOGRC3 a ex:Parametro ;
    rdfs:label "SPDLTOGRC3" ;
    ex:identificador "SPDLTOGRC3" ;
    ex:textoExtracto "SPDLTOGRC3" .

ex:SPDLTOGRC4 a ex:Parametro ;
    rdfs:label "SPDLTOGRC4" ;
    ex:identificador "SPDLTOGRC4" ;
    ex:textoExtracto "SPDLTOGRC4" .

ex:GRTOSPDL a ex:Parametro ;
    rdfs:label "GRTOSPDL" ;
    ex:identificador "GRTOSPDL" ;
    ex:textoExtracto "El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal a tierra. GRTOSPDL Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. GRTOSPDLC1" .

ex:GRTOSPDLC1 a ex:Parametro ;
    rdfs:label "GRTOSPDLC1" ;
    ex:identificador "GRTOSPDLC1" ;
    ex:textoExtracto "GRTOSPDLC1" .