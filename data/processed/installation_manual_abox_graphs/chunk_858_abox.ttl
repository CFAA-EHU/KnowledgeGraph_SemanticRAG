@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_f3cc4f025f a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Esta marca permite distinguir entre una sincronización en posición o en velocidad, y saber así a cuál de las marcas SYNSPEED o SYNCPOSI atender." .

ns1:MaximoErrorEnPosicionPermitido a ns1:Parametro ;
    rdfs:label "Máximo error en posición permitido" ;
    ns1:identificador "DSYNCPOSW" ;
    ns1:textoExtracto "cuyo valor por defecto se define en el parámetro máquina DSYNCPOSW." .

ns1:MaximoErrorEnVelocidadPermitido a ns1:Parametro ;
    rdfs:label "Máximo error en velocidad permitido" ;
    ns1:identificador "DSYNCVELW" ;
    ns1:textoExtracto "cuyo valor por defecto se define en el parámetro máquina DSYNCVELW." .

ns1:SincronizacionEnPosicionDelCabezal1 a ns1:AvisoSeguridad ;
    rdfs:label "Sincronización en posición del cabezal 1" ;
    ns1:textoExtracto "Esta marca se activa en el cabezal esclavo cuando está sincronizado en posición." .

