@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:GRTOSPDL a ex:Parametro ;
    rdfs:label "GRTOSPDL" ;
    ex:textoExtracto "El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal a tierra." ;
    ex:valor "=1" .

ex:GRTOSPDLC1 a ex:Parametro ;
    rdfs:label "GRTOSPDLC1" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. GRTOSPDLC1 (también se puede programar como GRTOSPDL)" ;
    ex:valor "=1" .

ex:GRTOSPDLC2 a ex:Parametro ;
    rdfs:label "GRTOSPDLC2" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. GRTOSPDLC2" ;
    ex:valor "=1" .

