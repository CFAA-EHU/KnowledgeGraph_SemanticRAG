ex:Sistema_GestorHerramientas
    a ex:Sistema ;
    rdfs:label "Sistema de gestión de herramientas (PLC)"@es ;
    ex:textoExtracto "Señales modificables del gestor de herramientas"@es ;
    ex:tieneComponente ex:Se_al_GRTOSPDL, ex:Se_al_GRTOSPDLC1, ex:Se_al_GRTOSPDLC2, ex:Se_al_GRTOSPDLC3, ex:Se_al_GRTOSPDLC4,
                       ex:Se_al_MZTOSPDL, ex:Se_al_MZTOSPDLMZ1, ex:Se_al_MZTOSPDLMZ2, ex:Se_al_MZTOSPDLMZ3, ex:Se_al_MZTOSPDLMZ4,
                       ex:Se_al_SPDLTOMZ, ex:Se_al_SPDLTOMZ1, ex:Se_al_SPDLTOMZ2, ex:Se_al_SPDLTOMZ3, ex:Se_al_SPDLTOMZ4,
                       ex:Se_al_MZROT, ex:Se_al_MZROTMZ1, ex:Se_al_MZROTMZ2, ex:Se_al_MZROTMZ3, ex:Se_al_MZROTMZ4,
                       ex:Se_al_TCHANGEOK, ex:Se_al_TCHANGEOKMZ1, ex:Se_al_TCHANGEOKMZ2, ex:Se_al_TCHANGEOKMZ3, ex:Se_al_TCHANGEOKMZ4 .