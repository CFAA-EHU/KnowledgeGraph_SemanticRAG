@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Se_al_GRTOSPDL
    a ex:Parametro ;
    rdfs:label "Señal GRTOSPDL (herramienta a tierra)"@es ;
    ex:identificador "GRTOSPDL" ;
    ex:textoExtracto "El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal a tierra. GRTOSPDL Hay una marca para cada canal."@es ;
    ex:valor "1 (activo)" .

ex:Se_al_GRTOSPDLC1
    a ex:Parametro ;
    rdfs:label "Señal GRTOSPDLC1 (canal 1)"@es ;
    ex:identificador "GRTOSPDLC1" ;
    ex:textoExtracto "Los mnemónicos para cada canal son los siguientes. GRTOSPDLC1 (también se puede programar como GRTOSPDL)"@es .

