@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Senal_TCHANGEOKMZ1
    a ex:Parametro ;
    rdfs:label "TCHANGEOKMZ1" ;
    ex:identificador "TCHANGEOKMZ1" ;
    ex:textoExtracto "TCHANGEOKMZ1 (equivalente a TCHANGEOK) [...] El PLC debe poner esta marca a (=1) cuando se ha efectuado el cambio de herramienta (M06)." ;
    ex:valor "1"^^xsd:boolean .

ex:Senal_TCHANGEOKMZ2
    a ex:Parametro ;
    rdfs:label "TCHANGEOKMZ2" ;
    ex:identificador "TCHANGEOKMZ2" ;
    ex:textoExtracto "TCHANGEOKMZ2" .

ex:Senal_TCHANGEOKMZ3
    a ex:Parametro ;
    rdfs:label "TCHANGEOKMZ3" ;
    ex:identificador "TCHANGEOKMZ3" ;
    ex:textoExtracto "TCHANGEOKMZ3" .

ex:Senal_TCHANGEOKMZ4
    a ex:Parametro ;
    rdfs:label "TCHANGEOKMZ4" ;
    ex:identificador "TCHANGEOKMZ4" ;
    ex:textoExtracto "TCHANGEOKMZ4" .

ex:Registro_MZPOSMZ1
    a ex:Parametro ;
    rdfs:label "MZPOSMZ1" ;
    ex:identificador "MZPOSMZ1" ;
    ex:textoExtracto "MZPOSMZ1 (también se puede programar como MZPOS) [...] El PLC debe indicar en este registro la posición actual del almacén." .

ex:Registro_MZPOSMZ2
    a ex:Parametro ;
    rdfs:label "MZPOSMZ2" ;
    ex:identificador "MZPOSMZ2" ;
    ex:textoExtracto "MZPOSMZ2" .

ex:Registro_MZPOSMZ3
    a ex:Parametro ;
    rdfs:label "MZPOSMZ3" ;
    ex:identificador "MZPOSMZ3" ;
    ex:textoExtracto "MZPOSMZ3" .

ex:Registro_MZPOSMZ4
    a ex:Parametro ;
    rdfs:label "MZPOSMZ4" ;
    ex:identificador "MZPOSMZ4" ;
    ex:textoExtracto "MZPOSMZ4" .

ex:Sistema_GestorHerramientas
    a ex:Sistema ;
    rdfs:label "Gestor de herramientas" ;
    ex:textoExtracto "Señales modificables del gestor de herramientas." ;
    ex:tieneComponente ex:Senal_TCHANGEOKMZ1, ex:Senal_TCHANGEOKMZ2, ex:Senal_TCHANGEOKMZ3, ex:Senal_TCHANGEOKMZ4 ;
    ex:tieneComponente ex:Registro_MZPOSMZ1, ex:Registro_MZPOSMZ2, ex:Registro_MZPOSMZ3, ex:Registro_MZPOSMZ4 ;
    ex:monitoreaParametro ex:Senal_TCHANGEOKMZ1, ex:Registro_MZPOSMZ1 .