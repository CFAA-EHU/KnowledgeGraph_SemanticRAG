@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TCHANGEOKMZ1 a ex:Parametro ;
    rdfs:label "TCHANGEOKMZ1" ;
    ex:textoExtracto "Los mnemónicos para cada almacén son los siguientes. TCHANGEOKMZ1 (equivalente a TCHANGEOK)" ;
    ex:valor "TCHANGEOKMZ1" .

