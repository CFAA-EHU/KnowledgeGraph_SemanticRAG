@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:KEYLED1 a ex:Parametro ;
    rdfs:label "KEYLED1" ;
    ex:textoExtracto "Este registro enciende el led (bit=1) de las teclas de usuario en todos los paneles de mando simultáneamente." ;
    ex:valor "enciende el led (bit=1) de las teclas de usuario en todos los paneles de mando simultáneamente" .

ex:KEYLED1_1 a ex:Parametro ;
    rdfs:label "KEYLED1_1" ;
    ex:textoExtracto "KEYLED1_1 Este registro enciende los led (bit=1) de las teclas de usuario en un panel de mando." ;
    ex:valor "enciende los led (bit=1) de las teclas de usuario en un panel de mando" .

ex:KEYLED1_8 a ex:Parametro ;
    rdfs:label "KEYLED1_8" ;
    ex:textoExtracto "KEYLED1_8 Estos registros encienden los led (bit=1) de las teclas de usuario en un panel de mando." ;
    ex:valor "encienden los led (bit=1) de las teclas de usuario en un panel de mando" .

ex:B0KEYLED1_2 a ex:Parametro ;
    rdfs:label "B0KEYLED1_2" ;
    ex:textoExtracto "La siguiente instrucción cambia el estado del led de la primera tecla de usuario (bit 0) cada vez que se pulsa la tecla. DFU B0KEYBD1_2 = CPL B0KEYLED1_2" ;
    ex:valor "cambia el estado del led de la primera tecla de usuario (bit 0) cada vez que se pulsa la tecla" .

ex:KEYLED2 a ex:Parametro ;
    rdfs:label "KEYLED2" ;
    ex:textoExtracto "KEYLED2 Este registro enciende el led (bit=1) de las teclas en todos los módulos OP-PANEL-H/E simultáneamente." ;
    ex:valor "enciende el led (bit=1) de las teclas en todos los módulos OP-PANEL-H/E simultáneamente" .

ex:KEYLED2_1 a ex:Parametro ;
    rdfs:label "KEYLED2_1" ;
    ex:textoExtracto "KEYLED2_1 Este registro enciende los led (bit=1) de las siguientes teclas, en el módulo OP-PANEL-H/E." ;
    ex:valor "enciende los led (bit=1) de las siguientes teclas, en el módulo OP-PANEL-H/E" .

ex:KEYLED2_8 a ex:Parametro ;
    rdfs:label "KEYLED2_8" ;
    ex:textoExtracto "KEYLED2_8 Estos registros encienden los led (bit=1) de las siguientes teclas, en el módulo OP-PANEL-H/E." ;
    ex:textoExtracto "Registros KEYLED2 / KEYLED2_1 a KEYLED2_8." ;
    ex:valor "encienden los led (bit=1) de las siguientes teclas, en el módulo OP-PANEL-H/E" .