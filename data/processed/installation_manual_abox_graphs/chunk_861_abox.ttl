@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_2b8d11e484 a ns1:Parametro ;
    rdfs:label "Marca que indica si hay algún proceso de latcheo activo con el palpador 1 en el eje" ;
    ns1:identificador "LATCH1ACTIVE" ;
    ns1:textoExtracto "LATCH1ACTIVE(axis) Se aplica al proceso de latcheo de la cota de un eje. Hay una marca para cada palpador." .

ns1:Parametro_67d7468125 a ns1:Parametro ;
    rdfs:label "Marca que indica si se ha alcanzado la sincronización en el proceso de sincronización de eje independiente y leva electrónica" ;
    ns1:identificador "INSYNC" ;
    ns1:textoExtracto "INSYNC(axis) Para los movimientos de sincronización de eje independiente y leva electrónica, el interpolador del eje activa esta marca cuando se ha alcanzado la sincronización." .

ns1:Parametro_94e24275dc a ns1:Parametro ;
    rdfs:label "Marca que indica si la ejecución está detenida" ;
    ns1:identificador "IFHOUT" ;
    ns1:textoExtracto "IFHOUT(axis) Para los movimientos de eje independiente, el interpolador del eje activa esta marca cuando la ejecución está detenida." .

ns1:Parametro_aa0ccd7e81 a ns1:Parametro ;
    rdfs:label "Marca que indica si el interpolador del eje ha terminado de generar el movimiento teórico" ;
    ns1:identificador "IEND" ;
    ns1:textoExtracto "IEND(axis) Para los movimientos de eje independiente, el interpolador del eje activa esta marca cuando termina de generar el movimiento teórico." .

ns1:Parametro_afa1080c3f a ns1:Parametro ;
    rdfs:label "Marca que indica si el interpolador del eje está listo para aceptar un nuevo bloque de movimiento" ;
    ns1:identificador "IFREE" ;
    ns1:textoExtracto "IFREE(axis) Para los movimientos de eje independiente, el interpolador del eje activa esta marca cuando está listo para aceptar un nuevo bloque de movimiento." .

ns1:Parametro_c3545c024b a ns1:Parametro ;
    rdfs:label "Marca que indica si hay algún proceso de latcheo activo con el palpador 2" ;
    ns1:identificador "PROBE2ACTIVE" ;
    ns1:textoExtracto "PROBE2ACTIVE Se aplica al proceso de latcheo de la cota de un eje. Hay una marca para cada palpador." .

ns1:Parametro_c71a35232b a ns1:Parametro ;
    rdfs:label "Marca que indica si hay algún proceso de latcheo activo con el palpador 1" ;
    ns1:identificador "PROBE1ACTIVE" ;
    ns1:textoExtracto "PROBE1ACTIVE Se aplica al proceso de latcheo de la cota de un eje. Hay una marca para cada palpador." .

ns1:Parametro_ca8c27aaa8 a ns1:Parametro ;
    rdfs:label "Marca que indica si hay algún proceso de latcheo activo con el palpador 2 en el eje" ;
    ns1:identificador "LATCH2ACTIVE" ;
    ns1:textoExtracto "LATCH2ACTIVE(axis) Se aplica al proceso de latcheo de la cota de un eje. Hay una marca para cada palpador." .

ns1:Parametro_d3a8abd7cd a ns1:Parametro ;
    rdfs:label "Marca que indica si el interpolador del eje tiene alguna sentencia pendiente de ejecución" ;
    ns1:identificador "IBUSY" ;
    ns1:textoExtracto "IBUSY(axis) Para los movimientos de eje independiente, el interpolador del eje activa esta marca cuando tiene alguna sentencia pendiente de ejecución." .

