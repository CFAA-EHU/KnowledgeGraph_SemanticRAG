@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:KEYDIS1 a ex:InterfazUsuario ;
    ex:textoExtracto "Teclas de usuario. Registros KEYDIS1 / KEYDIS1_1 a KEYDIS1_8." ;
    ex:identificador "KEYDIS1" .

ex:KEYDIS1_1 a ex:InterfazUsuario ;
    ex:textoExtracto "Bit. | Tecla. | 0 | Spindle override +" ;
    ex:identificador "KEYDIS1_1" .

ex:KEYDIS1_2 a ex:InterfazUsuario ;
    ex:textoExtracto "Bit. | Tecla. | 1 | Spindle clockwise" ;
    ex:identificador "KEYDIS1_2" .

ex:KEYDIS1_3 a ex:InterfazUsuario ;
    ex:textoExtracto "Bit. | Tecla. | 2 | Spindle positioning" ;
    ex:identificador "KEYDIS1_3" .

ex:KEYDIS1_4 a ex:InterfazUsuario ;
    ex:textoExtracto "Bit. | Tecla. | 3 | Spindle stop" ;
    ex:identificador "KEYDIS1_4" .

ex:KEYDIS1_5 a ex:InterfazUsuario ;
    ex:textoExtracto "Bit. | Tecla. | 4 | Spindle override -" ;
    ex:identificador "KEYDIS1_5" .

ex:KEYDIS1_6 a ex:InterfazUsuario ;
    ex:textoExtracto "Bit. | Tecla. | 5 | Spindle counterclockwise" ;
    ex:identificador "KEYDIS1_6" .

ex:KEYDIS1_7 a ex:InterfazUsuario ;
    ex:textoExtracto "Bit. | Tecla. | 6 | START" ;
    ex:identificador "KEYDIS1_7" .

ex:KEYDIS1_8 a ex:InterfazUsuario ;
    ex:textoExtracto "Bit. | Tecla. | 7 | STOP" ;
    ex:identificador "KEYDIS1_8" .

ex:KEYDIS2 a ex:InterfazUsuario ;
    ex:textoExtracto "Teclas de jog. Registros KEYDIS2 / KEYDIS2_1 a KEYDIS2_8." ;
    ex:identificador "KEYDIS2" .

ex:KEYDIS2_1 a ex:InterfazUsuario ;
    ex:textoExtracto "Bit. | Tecla. | 0 | Spindle override +" ;
    ex:identificador "KEYDIS2_1" .

ex:KEYDIS2_2 a ex:InterfazUsuario ;
    ex:textoExtracto "Bit. | Tecla. | 1 | Spindle clockwise" ;
    ex:identificador "KEYDIS2_2" .

ex:KEYDIS3 a ex:InterfazUsuario ;
    ex:textoExtracto "Selector del feed override y selector de movimiento (volante, jog incremental o jog continuo). Registros KEYDIS3 / KEYDIS3_1 a KEYDIS3_8." ;
    ex:identificador "KEYDIS3" .

ex:KEYDIS4 a ex:InterfazUsuario ;
    ex:textoExtracto "Selector del speed override. Registros KEYDIS4 / KEYDIS4_1 a KEYDIS4_8." ;
    ex:identificador "KEYDIS4" .