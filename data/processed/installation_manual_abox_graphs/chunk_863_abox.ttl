@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:InterfazUsuario_Se_alesTeclas
    a ex:InterfazUsuario ;
    rdfs:label "Interfaz de señales modificables de teclas (KEYDIS1-KEYDIS4)"@es ;
    ex:textoExtracto "Teclas de usuario. Registros KEYDIS1 / KEYDIS1_1 a KEYDIS1_8. Teclas de jog. Registros KEYDIS2 / KEYDIS2_1 a KEYDIS2_8. [...] Registros KEYDIS4 / KEYDIS4_1 a KEYDIS4_8. Selector del speed override."@es ;
    ex:identificador "KEYDIS1-KEYDIS4" ;
    ex:tieneComponente ex:Tecla_SpindleOverridePositivo,
                        ex:Tecla_SpindleSentidoHorario,
                        ex:Tecla_PosicionamientoHuso,
                        ex:Tecla_ParoHuso,
                        ex:Tecla_SpindleOverrideNegativo,
                        ex:Tecla_SpindleSentidoAntihorario,
                        ex:Tecla_Start,
                        ex:Tecla_Stop .

ex:Tecla_SpindleOverridePositivo
    a ex:Componente ;
    rdfs:label "Tecla Spindle override +"@es ;
    ex:textoExtracto "Bit 0: Spindle override +"@es ;
    ex:documentadoEn ex:InterfazUsuario_Se_alesTeclas .

ex:Tecla_SpindleSentidoHorario
    a ex:Componente ;
    rdfs:label "Tecla Spindle clockwise"@en ;
    ex:textoExtracto "Bit 1: Spindle clockwise"@en ;
    ex:documentadoEn ex:InterfazUsuario_Se_alesTeclas .

ex:Tecla_PosicionamientoHuso
    a ex:Componente ;
    rdfs:label "Tecla Spindle positioning"@en ;
    ex:textoExtracto "Bit 2: Spindle positioning"@en ;
    ex:documentadoEn ex:InterfazUsuario_Se_alesTeclas .

ex:Tecla_ParoHuso
    a ex:Componente ;
    rdfs:label "Tecla Spindle stop"@en ;
    ex:textoExtracto "Bit 3: Spindle stop"@en ;
    ex:documentadoEn ex:InterfazUsuario_Se_alesTeclas .

ex:Tecla_SpindleOverrideNegativo
    a ex:Componente ;
    rdfs:label "Tecla Spindle override -"@es ;
    ex:textoExtracto "Bit 4: Spindle override - "@es ;
    ex:documentadoEn ex:InterfazUsuario_Se_alesTeclas .

ex:Tecla_SpindleSentidoAntihorario
    a ex:Componente ;
    rdfs:label "Tecla Spindle counterclockwise"@en ;
    ex:textoExtracto "Bit 5: Spindle counterclockwise"@en ;
    ex:documentadoEn ex:InterfazUsuario_Se_alesTeclas .

ex:Tecla_Start
    a ex:Componente ;
    rdfs:label "Tecla START"@es ;
    ex:textoExtracto "Bit 6: START"@es ;
    ex:documentadoEn ex:InterfazUsuario_Se_alesTeclas .

ex:Tecla_Stop
    a ex:Componente ;
    rdfs:label "Tecla STOP"@es ;
    ex:textoExtracto "Bit 7: STOP"@es ;
    ex:documentadoEn ex:InterfazUsuario_Se_alesTeclas .