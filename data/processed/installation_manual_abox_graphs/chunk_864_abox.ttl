@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_1ec893594e a ns1:Parametro ;
    rdfs:label "Marca que indica el estado de la operación de piercing" ;
    ns1:identificador "PIERCING" ;
    ns1:textoExtracto "El OEM debe gestionar esta marca desde la subrutina asociada al piercing (por defecto, Piercing.fst), para indicar al PLC cuando empieza (valor 1) y acaba (valor 0) la operación de piercing." .

ns1:Parametro_9e727c2974 a ns1:Parametro ;
    rdfs:label "Marca que indica el estado del corte activo" ;
    ns1:identificador "CUTTING" ;
    ns1:textoExtracto "CUTTING Cutting activo." .

ns1:Parametro_d3fc1b74cc a ns1:Parametro ;
    rdfs:label "Marca que indica la activación de un fichero de material" ;
    ns1:identificador "ACTIVEMATERIALON" ;
    ns1:textoExtracto "El CNC activa esta marca cuando hay un fichero de material activo (por la ejecución de #MATERIAL, #TECHTABLE, por activación desde HMI o por recuperación en el arranque)." .

