@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_d59f4f8418 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC activa esta marca cuando el usuario valida los parámetros comunes de la tabla de piercing o cutting activa." .

ns1:EstadoDeLaOperacionDeCutting a ns1:Parametro ;
    rdfs:label "Estado de la operación de cutting" ;
    ns1:identificador "V.PLC.CUTTING" ;
    ns1:textoExtracto "Esta marca refleja el estado de la variable V.PLC.CUTTING." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "El PLC debe desactivar esta marca cuando termina su gestión con estas variables." .

ns1:ValidacionDeParametrosComunesDeLaTabla a ns1:Parametro ;
    rdfs:label "Validación de parámetros comunes de la tabla" ;
    ns1:identificador "COMVARACT" ;
    ns1:textoExtracto "El CNC activa esta marca cuando el usuario valida los parámetros comunes de la tabla de piercing o cutting activa." .

ns1:ValidacionDeParametrosDeCutting a ns1:Parametro ;
    rdfs:label "Validación de parámetros de cutting" ;
    ns1:identificador "CUTVARACT" ;
    ns1:textoExtracto "El CNC activa esta marca cuando el usuario valida los parámetros de cutting de la tabla activa." .

