@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ConfiguracionAlmacenes
    a ex:Sistema ;
    rdfs:label "Configuración de almacenes y cambio de herramienta"@es ;
    ex:textoExtracto "Para configurar adecuadamente los almacenes y el cambio de herramienta se debe: • Personalizar los parámetros máquina. • Definir la tabla de herramientas y de los almacenes. • Elaborar el programa de PLC. • Programar la rutina asociada a la herramienta y a la función M06."@es ;
    ex:tieneComponente ex:ParametrosMaquina_Almacenes, ex:TablaHerramientas, ex:ProgramaPLC_CambioHerramienta, ex:RutinaM06 ;
    ex:detalladoEnEsquema ex:EjemplosTiposAlmacen .

ex:ParametrosMaquina_Almacenes
    a ex:Parametro ;
    rdfs:label "Parámetros máquina para almacenes"@es ;
    ex:textoExtracto "En los parámetros máquina se define el número de almacenes disponibles y las características de cada uno. Se puede disponer de hasta cuatro almacenes y cada uno de ellos podrá ser de un tipo diferente."@es ;
    ex:valor "1-4"^^xsd:string ;
    ex:documentadoEn ex:Pagina_469_TiposAlmacen .

ex:TablaHerramientas a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de herramientas y almacenes"@es ;
    ex:textoExtracto "Definir la tabla de herramientas y de los almacenes."@es .

ex:ProgramaPLC_CambioHerramienta
    a ex:Sistema ;
    rdfs:label "Programa PLC para gestión de almacenes"@es ;
    ex:textoExtracto "Elaborar el programa de PLC [...] hay que tener en cuenta el número de almacenes y canales disponibles. Para la comunicación entre el gestor de herramientas y el PLC, cada canal y cada almacén dispone de grupo de marcas y registros propios."@es ;
    ex:controla ex:GestorHerramientas ;
    ex:monitoreaParametro ex:ParametrosMaquina_Almacenes .

ex:RutinaM06
    a ex:Sistema ;
    rdfs:label "Rutina asociada a la función M06"@es ;
    ex:textoExtracto "Programar la rutina asociada a la herramienta y a la función M06."@es ;
    ex:ejecutadoPor ex:ProgramaPLC_CambioHerramienta .

ex:GestorHerramientas
    a ex:Sistema ;
    rdfs:label "Gestor de herramientas"@es ;
    ex:textoExtracto "Para la comunicación entre el gestor de herramientas y el PLC [...] el gestor esperará a que acabe el proceso en curso antes de atender la nueva solicitud."@es ;
    ex:controla ex:Almacen_Generico .

ex:Almacen_Generico
    a ex:ComponenteMecanico ;
    rdfs:label "Almacén de herramientas (genérico)"@es ;
    ex:textoExtracto "El CNC puede disponer de hasta cuatro almacenes y cada uno de ellos podrá ser de un tipo diferente. Cada almacén tiene sus propios parámetros de configuración [...] Un almacén no está asociado a ningún canal ni cabezal en particular; es decir, un almacén podrá ser compartido por varios canales."@es ;
    ex:tieneFrecuencia ex:FrecuenciaCambioParalelo ;
    ex:identificador "1-4"^^xsd:string .

ex:FrecuenciaCambioParalelo
    a ex:Frecuencia ;
    rdfs:label "Frecuencia de cambio de herramienta en paralelo"@es ;
    ex:textoExtracto "Todos los almacenes pueden realizar cambios de herramienta en paralelo (a la vez)."@es ;
    ex:valor "paralelo"^^xsd:string .

ex:Pagina_469_TiposAlmacen
    a ex:Pagina ;
    rdfs:label "Página 469: 7.1 Tipos de almacén"@es ;
    ex:identificador "469"^^xsd:string ;
    ex:textoExtracto "Ver en la página 469. \"7.1 Tipos de almacén.\""@es .

ex:EjemplosTiposAlmacen
    a ex:Esquema ;
    rdfs:label "Ejemplos por tipo de almacén"@es ;
    ex:textoExtracto "En sucesivos apartados de este capítulo se muestra un ejemplo para cada tipo de almacén."@es ;
    ex:ilustradoEn ex:Pagina_469_TiposAlmacen .