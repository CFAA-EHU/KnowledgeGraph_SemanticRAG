@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_0ca17cdc69 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controladoPor ns1:SistemaPLC ;
    ns1:textoExtracto "El CNC activa esta marca cuando el usuario valida los parámetros de cutting de la tabla activa. El PLC debe desactivar esta marca cuando termina su gestión con estas variables." .

ns1:Parametro_e8a998290b a ns1:Parametro ;
    rdfs:label "Marca CUTVARACT" ;
    ns1:identificador "CUTVARACT" ;
    ns1:textoExtracto "CUTVARACT El CNC activa esta marca cuando el usuario valida los parámetros de cutting de la tabla activa." .

ns1:SubrutinaCuttingonfst a ns1:Componente ;
    rdfs:label "Subrutina Cuttingon.fst" ;
    ns1:documentadoEn ns1:Tabla ;
    ns1:textoExtracto "Cuando la subrutina Cuttingon.fst sólo cambia el tipo de cutting (#CUTTING ON), el CNC no activa esta marca ya que la sincronización con el PLC es a través" .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "El PLC debe desactivar esta marca cuando termina su gestión con estas variables." .

