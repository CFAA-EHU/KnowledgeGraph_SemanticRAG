@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Almacen1 a ex:Maquina ;
    rdfs:label "almacén"@es ;
    ex:textoExtracto "El CNC puede disponer de hasta cuatro almacenes y cada uno de ellos podrá ser de un tipo diferente."@es .

ex:Almacen2 a ex:Maquina ;
    rdfs:label "almacén"@es ;
    ex:textoExtracto "Cada almacén tiene sus propios parámetros de configuración."@es .

ex:Almacen3 a ex:Maquina ;
    rdfs:label "almacén"@es ;
    ex:textoExtracto "Todos los almacenes pueden realizar cambios de herramienta en paralelo (a la vez)."@es .

ex:ParametroMaquina1 a ex:Parametro ;
    rdfs:label "parámetros máquina"@es ;
    ex:textoExtracto "En los parámetros máquina se define el número de almacenes disponibles y las características de cada uno."@es .

ex:ParametroMaquina2 a ex:Parametro ;
    rdfs:label "parámetros máquina"@es ;
    ex:textoExtracto "Cada almacén tiene sus propios parámetros de configuración."@es .

ex:ProgramaPLC1 a ex:Sistema ;
    rdfs:label "programa de PLC"@es ;
    ex:textoExtracto "Elaborar el programa de PLC."@es .

ex:ProgramaPLC2 a ex:Sistema ;
    rdfs:label "programa PLC"@es ;
    ex:textoExtracto "A la hora de realizar el programa PLC y la subrutina asociada a la herramienta y a la función M06, hay que tener en cuenta el número de almacenes y canales disponibles."@es .

ex:SubrutinaHerramienta1 a ex:TareaMantenimiento ;
    rdfs:label "subrutina asociada a la herramienta"@es ;
    ex:textoExtracto "Programar la rutina asociada a la herramienta y a la función M06."@es .

ex:SubrutinaHerramienta2 a ex:TareaMantenimiento ;
    rdfs:label "subrutina asociada a la herramienta"@es ;
    ex:textoExtracto "A la hora de realizar el programa PLC y la subrutina asociada a la herramienta y a la función M06, hay que tener en cuenta el número de almacenes y canales disponibles."@es .

ex:GestorHerramientas1 a ex:Sistema ;
    rdfs:label "gestor de herramientas"@es ;
    ex:textoExtracto "Para la comunicación entre el gestor de herramientas y el PLC, cada canal y cada almacén dispone de grupo de marcas y registros propios."@es .

ex:TablaHerramientas1 a ex:Tabla ;
    rdfs:label "tabla de herramientas"@es ;
    ex:textoExtracto "Definir la tabla de herramientas y de los almacenes."@es .

ex:TablaAlmacenes1 a ex:Tabla ;
    rdfs:label "tabla de los almacenes"@es ;
    ex:textoExtracto "Definir la tabla de herramientas y de los almacenes."@es .