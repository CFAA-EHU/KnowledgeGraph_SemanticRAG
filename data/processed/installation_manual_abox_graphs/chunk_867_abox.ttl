@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_b6792d4813 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:activaAlarma ns1:Parametro_0aeef780e9,
        ns1:Parametro_4d6802ff89,
        ns1:Parametro_51646c0a56,
        ns1:Parametro_7107ee1674,
        ns1:Parametro_f37b85d7ec ;
    ns1:textoExtracto "El CNC activa esta marca cuando el usuario valida los parámetros de piercing de la tabla activa." .

ns1:SistemaPLC_a2399c2e32 a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:mitigaRiesgo ns1:Parametro_4d6802ff89,
        ns1:Parametro_51646c0a56 ;
    ns1:textoExtracto "El PLC gestiona los efectos de estas variables sobre los dispositivos de la máquina (salidas analógicas, digitales, etc)." .

ns1:Parametro_0aeef780e9 a ns1:Parametro ;
    rdfs:label "Parámetro que establece el comportamiento del CNC cuando el gap sobrepasa el rango GAPMIN - GAPMAX" ;
    ns1:identificador "GAPERRORCANCEL" ;
    ns1:textoExtracto "El parámetro GAPERRORCANCEL establece el comportamiento del CNC cuando el gap sobrepasa el rango GAPMIN - GAPMAX." .

ns1:Parametro_7107ee1674 a ns1:Parametro ;
    rdfs:label "Parámetro que define el límite inferior del rango de gap" ;
    ns1:identificador "GAPMIN" ;
    ns1:textoExtracto "El CNC activa esta marca si el gap está dentro del rango definido por los parámetros GAPMIN-GAPMAX." .

ns1:Parametro_f37b85d7ec a ns1:Parametro ;
    rdfs:label "Parámetro que define el límite superior del rango de gap" ;
    ns1:identificador "GAPMAX" ;
    ns1:textoExtracto "El CNC activa esta marca si el gap está dentro del rango definido por los parámetros GAPMIN-GAPMAX." .

ns1:Parametro_4d6802ff89 a ns1:Parametro ;
    rdfs:label "Marca activada por el CNC cuando se validan parámetros de piercing" ;
    ns1:identificador "PIRVARACT" ;
    ns1:textoExtracto "El CNC activa esta marca cuando el usuario valida los parámetros de piercing de la tabla activa." .

ns1:Parametro_51646c0a56 a ns1:Parametro ;
    rdfs:label "Marca que indica si el gap está dentro del rango definido por GAPMIN y GAPMAX" ;
    ns1:identificador "INPOSGAP" ;
    ns1:textoExtracto "El CNC activa esta marca si el gap está dentro del rango definido por los parámetros GAPMIN-GAPMAX." .

