@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TablaHerramientas a ex:Tabla ;
    rdfs:label "tabla de herramientas"@es ;
    ex:textoExtracto "La lista de herramientas disponibles se guarda en la tabla de herramientas, única para todo el sistema."@es .

ex:GestorHerramientas a ex:Sistema ;
    rdfs:label "gestor de herramientas"@es ;
    ex:textoExtracto "El CNC dispone de un gestor de herramientas que sabe en todo momento dónde se encuentra cada una de las herramientas."@es .

ex:HerramientaTierra a ex:Herramienta ;
    rdfs:label "herramienta de tierra"@es ;
    ex:textoExtracto "Se denomina herramienta de tierra a aquella que no se guarda en ningún almacén y que se carga manualmente cuando es solicitada."@es .

ex:AlmacenHerramientas a ex:Sistema ;
    rdfs:label "almacén de herramientas"@es ;
    ex:textoExtracto "El almacén en el que se deja la herramienta y el almacén del que se coge la herramienta nueva pueden ser diferentes."@es .