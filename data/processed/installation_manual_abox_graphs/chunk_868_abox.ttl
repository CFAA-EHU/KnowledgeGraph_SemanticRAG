@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_0929dadf51 a ns1:Parametro ;
    rdfs:label "Marca que indica si el gap está dentro de la tolerancia definida por GAPTOL" ;
    ns1:textoExtracto "INTOL El CNC activa esta marca si el gap está dentro de la tolerancia definida por el parámetro GAPTOL, respecto el valor de gap programado." .

ns1:Parametro_21b8a92358 a ns1:Parametro ;
    rdfs:label "Marca que indica cuando el PLC ejecuta un piercing o cutting después de reiniciar por un punto interrumpido" ;
    ns1:textoExtracto "RESTARTPOINT El PLC activa esta marca cuando el CNC ejecuta un piercing o un cutting después de reiniciar por un punto interrumpido." .

ns1:Parametro_84db15f089 a ns1:Parametro ;
    rdfs:label "Marca que indica cuando el salto programado con un #LEAP alcanza el punto más alto" ;
    ns1:textoExtracto "INPOSLIMIT El CNC activa esta marca (cambio de 0 a 1) cuando el salto programado con un #LEAP alcanza el punto más alto (comando POSLIMIT)." .

ns1:Parametro_b76d655d0c a ns1:Parametro ;
    rdfs:label "Marca que establece el comportamiento del CNC cuando el gap sobrepasa la tolerancia definida en GAPTOL" ;
    ns1:textoExtracto "GAPTOLCANCEL | Significado. Sí. El CNC anula el error de gap fuera del rango y no detiene el movimiento de los ejes." .

ns1:Parametro_cc6c04b6ad a ns1:Parametro ;
    rdfs:label "Marca que indica si el CNC anula el error de gap fuera del rango" ;
    ns1:textoExtracto "GAPERRORCANCEL | Significado. Sí. El CNC anula el error de gap fuera del rango y no detiene el movimiento de los ejes." .

