@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AlmacenHerramientas_869
    a ex:Sistema ;
    rdfs:label "Almacén de herramientas"@es ;
    ex:textoExtracto "el almacén y coger otra. [...] Dependiendo del tipo de almacén y de la operación solicitada, a veces se deben efectuar varias acciones. Por ejemplo, en algunos almacenes para llevar una herramienta del cabezal al almacén primero hay que llevar la herramienta del cabezal al brazo cambiador y luego del brazo cambiador al almacén."@es ;
    ex:controla ex:BrazoCambiador_869 ;
    ex:compuestoPor ex:HerramientaCabezal_869, ex:BrazoCambiador_869 .

ex:BrazoCambiador_869
    a ex:ComponenteMecanico ;
    rdfs:label "Brazo cambiador"@es ;
    ex:textoExtracto "en algunos almacenes para llevar una herramienta del cabezal al almacén primero hay que llevar la herramienta del cabezal al brazo cambiador y luego del brazo cambiador al almacén."@es .

ex:HerramientaCabezal_869
    a ex:Herramienta ;
    rdfs:label "Herramienta del cabezal"@es ;
    ex:textoExtracto "Dejar la herramienta del cabezal en tierra. [...] Por ejemplo, en algunos almacenes para llevar una herramienta del cabezal al almacén primero hay que llevar la herramienta del cabezal al brazo cambiador"@es .

ex:PLC_869
    a ex:Actuador ;
    rdfs:label "PLC"@es ;
    ex:textoExtracto "El PLC, que es el encargado de controlar dichos movimientos, debe informar al gestor de las acciones efectuadas para que actualice su información."@es ;
    ex:controla ex:AlmacenHerramientas_869 .

ex:GestorHerramientas_869
    a ex:InterfazUsuario ;
    rdfs:label "Gestor de herramientas"@es ;
    ex:textoExtracto "El PLC [...] debe informar al gestor de las acciones efectuadas para que actualice su información. Para la comunicación entre el gestor de herramientas y el PLC, cada canal y almacén dispone de un grupo de marcas y registros."@es .

ex:SubrutinaFuncionT_869
    a ex:TareaMantenimiento ;
    rdfs:label "Subrutina asociada a la función T (selección de herramienta)"@es ;
    ex:textoExtracto "La rutina asociada a la herramienta se ejecuta automáticamente cada vez que se ejecuta una función T (selección de herramienta). Se dispone de una subrutina en cada canal."@es ;
    ex:ejecutadoPor ex:HerramientaCabezal_869 .

ex:SubrutinaFuncionM06_869
    a ex:TareaMantenimiento ;
    rdfs:label "Subrutina asociada a la función M06 (cambio de herramienta)"@es ;
    ex:textoExtracto "La función M06 ejecuta el cambio de herramienta. El CNC gestionará el cambiador de herramienta y actualizará la tabla correspondiente al almacén de herramientas."@es ;
    ex:ejecutadoPor ex:AlmacenHerramientas_869 ;
    ex:requiereMantenimiento ex:HerramientaCabezal_869 .

ex:TablaFuncionesM_869 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de funciones M"@es ;
    ex:textoExtracto "Se recomienda tener personalizada esta función en la tabla de funciones –M– de forma que ejecute la subrutina correspondiente al cambiador de herramientas instalado en la máquina."@es ;
    ex:documentadoEn ex:Manual_869 .

ex:Manual_869
    a ex:Manual ;
    rdfs:label "Manual de referencia (página 472)"@es ;
    ex:textoExtracto "Ver '7.3 Comunicación entre el gestor y el PLC.' en la página 472."@es ;
    ex:detalladoEnEsquema ex:ComunicacionGestorPLC_869 .

ex:ComunicacionGestorPLC_869
    a ex:Sistema ;
    rdfs:label "Comunicación entre el gestor de herramientas y el PLC"@es ;
    ex:textoExtracto "Para la comunicación entre el gestor de herramientas y el PLC, cada canal y almacén dispone de un grupo de marcas y registros."@es .