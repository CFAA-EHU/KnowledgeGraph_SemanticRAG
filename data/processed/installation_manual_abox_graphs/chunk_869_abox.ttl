@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_06dd6999ff a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El canal del CNC pone esta marca a (=1) para indicar al PLC que debe ejecutar la operación indicada en TMOPERATION." .

ns1:Parametro_5ac8d4cf1e a ns1:Parametro ;
    rdfs:label "Marca para indicar al PLC la ejecución de la operación para el canal 1" ;
    ns1:identificador "TMOPSTROBEC1" ;
    ns1:textoExtracto "El canal del CNC pone esta marca a (=1) para indicar al PLC que debe ejecutar la operación indicada en TMOPERATION." .

ns1:PosicionDeAlmacenDondeDejarLaHerramienta a ns1:Parametro ;
    rdfs:label "Posición de almacén donde dejar la herramienta" ;
    ns1:identificador "LEAVEPOSMZ1" ;
    ns1:textoExtracto "Este registro indica la posición de almacén en la que hay que dejar la herramienta." .

ns1:PosicionDeAlmacenQueOcupaLaHerramientaACoger a ns1:Parametro ;
    rdfs:label "Posición de almacén que ocupa la herramienta a coger" ;
    ns1:identificador "TAKEPOSMZ1" ;
    ns1:textoExtracto "Este registro indica la posición de almacén que ocupa la herramienta que hay que coger." .

ns1:TipoDeOperacionParaElCanal1 a ns1:Parametro ;
    rdfs:label "Tipo de operación para el canal 1" ;
    ns1:identificador "TMOPERATIONC1" ;
    ns1:textoExtracto "Este registro indica el tipo de operación que desea realizar el gestor de herramientas." .

