@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AlmacenTipoTorreta
    a ex:ComponenteMecanico ;
    rdfs:label "Almacén tipo torreta"@es ;
    ex:textoExtracto "Almacén tipo torreta."@es .

ex:AlmacenSincronoSinBrazoCambiador
    a ex:ComponenteMecanico ;
    rdfs:label "Almacén síncrono sin brazo cambiador"@es ;
    ex:textoExtracto "Almacén síncrono sin brazo cambiador."@es .

ex:AlmacenSincronoConBrazoCambiador
    a ex:ComponenteMecanico ;
    rdfs:label "Almacén síncrono con brazo cambiador"@es ;
    ex:textoExtracto "Almacén síncrono con brazo cambiador (1 ó 2 pinzas). El brazo cambiador no puede moverse durante el mecanizado de la pieza."@es .

ex:AlmacenAsincrono
    a ex:ComponenteMecanico ;
    rdfs:label "Almacén asíncrono"@es ;
    ex:textoExtracto "Almacén asíncrono. Brazo cambiador de movimientos independientes que puede moverse durante el mecanizado."@es .

ex:AlmacenRandom
    a ex:Sistema ;
    rdfs:label "Almacén Random"@es ;
    ex:textoExtracto "En un almacén random las herramientas pueden ocupar cualquier posición mientras que en un almacén no-random las herramientas deben ocupar siempre la misma posición."@es .

ex:AlmacenNoRandom
    a ex:Sistema ;
    rdfs:label "Almacén No-Random"@es ;
    ex:textoExtracto "En un almacén random las herramientas pueden ocupar cualquier posición mientras que en un almacén no-random las herramientas deben ocupar siempre la misma posición."@es .

ex:AlmacenCiclico
    a ex:Sistema ;
    rdfs:label "Almacén Cíclico"@es ;
    ex:textoExtracto "Un almacén cíclico necesita una orden de cambio de herramienta M06 después de buscar una herramienta y antes de buscar la siguiente."@es .

ex:AlmacenNoCiclico
    a ex:Sistema ;
    rdfs:label "Almacén No-Cíclico"@es ;
    ex:textoExtracto "Un almacén no-cíclico permite realizar varias búsquedas de herramienta seguidas, sin efectuar necesariamente el cambio de herramienta."@es .

ex:BrazoCambiador
    a ex:ComponenteMecanico ;
    rdfs:label "Brazo cambiador"@es ;
    ex:textoExtracto "brazo cambiador de movimientos independientes que puede moverse durante el mecanizado."@es ;
    ex:tieneComponente ex:Pinza .

ex:Pinza
    a ex:ComponenteMecanico ;
    rdfs:label "Pinza"@es ;
    ex:textoExtracto "Almacén síncrono con brazo cambiador (1 ó 2 pinzas)."@es .