@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaHerramientas_7.2
    a ex:Tabla ;
    rdfs:label "Tabla de herramientas (Sección 7.2)" ;
    ex:textoExtracto "En la tabla de herramientas se debe definir, entre otras cosas, la geometría, tipo de monitorización y tamaño de la herramienta. Hay que definir todas las herramientas, incluso las de tierra." .

ex:TablaAlmacenes_7.2
    a ex:Tabla ;
    rdfs:label "Tabla de almacenes (Sección 7.2)" ;
    ex:textoExtracto "Se dispone de una tabla para cada almacén. En cada una de las tablas se muestra qué herramienta hay en cada posición del almacén y en cada una de las pinzas del brazo cambiador (si se dispone de él)." .

ex:TablaHerramientasActivas_7.2
    a ex:Tabla ;
    rdfs:label "Tabla de herramientas activas (Sección 7.2)" ;
    ex:textoExtracto "La tabla de las herramientas activas muestra qué herramientas se encuentran activas en los cabezales." .

ex:AlmacenEjemplo_7.2
    a ex:Sistema ;
    rdfs:label "Almacén de herramientas (ejemplo de 10 posiciones)" ;
    ex:textoExtracto "Ejemplo: Se dispone de 10 herramientas y un almacén de 10 posiciones." ;
    ex:tieneComponente ex:Herramienta_T1, ex:Herramienta_T2, ex:Herramienta_T3, ex:Herramienta_T4, ex:Herramienta_T5, ex:Herramienta_T6, ex:Herramienta_T7 ;
    ex:documentadoEn ex:TablaAlmacenes_7.2 .

ex:Herramienta_T1
    a ex:Herramienta ;
    rdfs:label "Herramienta T1" ;
    ex:identificador "T1" ;
    ex:textoExtracto "La T1 en la posición 1." ;
    ex:documentadoEn ex:TablaHerramientas_7.2 .

ex:Herramienta_T2
    a ex:Herramienta ;
    rdfs:label "Herramienta T2 (tamaño grande)" ;
    ex:identificador "T2" ;
    ex:textoExtracto "La T2 en la posición 3. [...] La T2 ocupa las posiciones 2-3-4." ;
    ex:documentadoEn ex:TablaHerramientas_7.2 .

ex:Herramienta_T3
    a ex:Herramienta ;
    rdfs:label "Herramienta T3" ;
    ex:identificador "T3" ;
    ex:textoExtracto "La T3 en la posición 5." ;
    ex:documentadoEn ex:TablaHerramientas_7.2 .

ex:Herramienta_T4
    a ex:Herramienta ;
    rdfs:label "Herramienta T4 (tamaño personal)" ;
    ex:identificador "T4" ;
    ex:textoExtracto "La T4 en la posición 6. La T4 ocupa las posiciones 6-7." ;
    ex:documentadoEn ex:TablaHerramientas_7.2 .

ex:Herramienta_T5
    a ex:Herramienta ;
    rdfs:label "Herramienta T5" ;
    ex:identificador "T5" ;
    ex:textoExtracto "La T5 en la posición 8." ;
    ex:documentadoEn ex:TablaHerramientas_7.2 .

ex:Herramienta_T6
    a ex:Herramienta ;
    rdfs:label "Herramienta T6" ;
    ex:identificador "T6" ;
    ex:textoExtracto "La T6 en la posición 9." ;
    ex:documentadoEn ex:TablaHerramientas_7.2 .

ex:Herramienta_T7
    a ex:Herramienta ;
    rdfs:label "Herramienta T7" ;
    ex:identificador "T7" ;
    ex:textoExtracto "La T7 en la posición 10." ;
    ex:documentadoEn ex:TablaHerramientas_7.2 .

ex:Herramienta_T8
    a ex:Herramienta ;
    rdfs:label "Herramienta T8 (de tierra)" ;
    ex:identificador "T8" ;
    ex:textoExtracto "Las herramientas T8, T9 y T10 no entran en el almacén y serán herramientas de tierra." ;
    ex:documentadoEn ex:TablaHerramientas_7.2 .

ex:Herramienta_T9
    a ex:Herramienta ;
    rdfs:label "Herramienta T9 (de tierra)" ;
    ex:identificador "T9" ;
    ex:textoExtracto "Las herramientas T8, T9 y T10 no entran en el almacén y serán herramientas de tierra." ;
    ex:documentadoEn ex:TablaHerramientas_7.2 .

ex:Herramienta_T10
    a ex:Herramienta ;
    rdfs:label "Herramienta T10 (de tierra)" ;
    ex:identificador "T10" ;
    ex:textoExtracto "Las herramientas T8, T9 y T10 no entran en el almacén y serán herramientas de tierra." ;
    ex:documentadoEn ex:TablaHerramientas_7.2 .