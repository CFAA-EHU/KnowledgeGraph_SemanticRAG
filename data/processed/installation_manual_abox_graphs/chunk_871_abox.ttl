ns1:IndicaQueLaHerramientaHaSidoRechazadaPorTiempoExcedido a ns1:Parametro ;
    rdfs:label "Indica que la herramienta ha sido rechazada por tiempo excedido" ;
    ns1:identificador "TWORNOUTC1" ;
    ns1:textoExtracto "TWORNOUT Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. TWORNOUTC1 (también se puede programar como TWORNOUT)" .

