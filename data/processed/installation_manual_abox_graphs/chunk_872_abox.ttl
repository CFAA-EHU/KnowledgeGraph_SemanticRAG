@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RegistroDeAlmacenParaElCanal1 a ns1:Parametro ;
    rdfs:label "Registro de almacén para el canal 1" ;
    ns1:identificador "MZIDC1" ;
    ns1:textoExtracto "MZID Hay un registro para cada canal. MZIDC1 MZIDC2 MZIDC3 MZIDC4 Este registro indica el almacén en el que se encuentra la herramienta que ha solicitado el canal." .

