@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:GestorHerramientas a ex:ComponenteElectrico ;
    ex:textoExtracto "el gestor de herramientas" ;
    rdfs:label "gestor de herramientas" .

ex:PLC a ex:ComponenteElectrico ;
    ex:textoExtracto "el PLC" ;
    rdfs:label "PLC" .

ex:CNC a ex:ComponenteElectrico ;
    ex:textoExtracto "el CNC" ;
    rdfs:label "CNC" .

ex:Almacen a ex:ComponenteElectrico ;
    ex:textoExtracto "almacén" ;
    rdfs:label "almacén" .

ex:Canales a ex:ComponenteElectrico ;
    ex:textoExtracto "cada canal y almacén" ;
    rdfs:label "canales y almacenes" .

ex:MarcasRegistros a ex:ComponenteElectrico ;
    ex:textoExtracto "un grupo de marcas y registros" ;
    rdfs:label "marcas y registros" .

ex:FuncionT a ex:ModoOperacion ;
    ex:textoExtracto "la función T" ;
    rdfs:label "función T" .

ex:FuncionM06 a ex:ModoOperacion ;
    ex:textoExtracto "la función M06" ;
    rdfs:label "función M06" .

ex:RutinaAsociadaM06 a ex:TareaMantenimiento ;
    ex:textoExtracto "la rutina asociada a M06" ;
    rdfs:label "rutina asociada a M06" .

ex:BrazoCambiador a ex:ComponenteMecanico ;
    ex:textoExtracto "brazo cambiador" ;
    rdfs:label "brazo cambiador" .

ex:MarcaTCHANGEOK a ex:Sensor ;
    ex:textoExtracto "activar la marca TCHANGEOK" ;
    rdfs:label "marca TCHANGEOK" .

ex:EsquemaComunicacionGestorPLC a ex:Esquema ;
    ex:textoExtracto "Para la comunicación entre el gestor de herramientas y el PLC, cada canal y almacén dispone de un grupo de marcas y registros." ;
    ex:compuestoPor ex:GestorHerramientas, ex:PLC, ex:Canales, ex:MarcasRegistros ;
    ex:detalladoEnEsquema ex:Seccion7_3ComunicacionGestorPLC .

ex:Seccion7_3ComunicacionGestorPLC a ex:Capitulo ;
    ex:textoExtracto "Seccion 7.3 Comunicación entre el gestor y el PLC." ;
    rdfs:label "Sección 7.3 Comunicación entre el gestor y el PLC" .