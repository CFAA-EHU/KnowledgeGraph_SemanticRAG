@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TablaComunicacionGestorPLC a ex:Tabla ;
    ex:textoExtracto """El gestor utiliza los siguientes registros y marcas para informar al PLC de las operaciones que debe realizar. Algunas señales son por canal mientras que otras son por almacén. En la siguiente tabla se muestran los mnemónicos de cada marca (M) o registro (R) en cada de los canales o almacenes.""" .

ex:MarcaTMOPSTROBEC1 a ex:ComponenteElectrico ;
    rdfs:label "TMOPSTROBEC1" ;
    ex:textoExtracto """M | TMOPSTROBE
TMOPSTROBEC1 | Canal ꞏ1ꞏ""" .

ex:MarcaTMOPSTROBEC2 a ex:ComponenteElectrico ;
    rdfs:label "TMOPSTROBEC2" ;
    ex:textoExtracto """M | TMOPSTROBEC2 | Canal ꞏ2ꞏ""" .

ex:MarcaTMOPSTROBEC3 a ex:ComponenteElectrico ;
    rdfs:label "TMOPSTROBEC3" ;
    ex:textoExtracto """M | TMOPSTROBEC3 | Canal ꞏ3ꞏ""" .

ex:MarcaTMOPSTROBEC4 a ex:ComponenteElectrico ;
    rdfs:label "TMOPSTROBEC4" ;
    ex:textoExtracto """M | TMOPSTROBEC4 | Canal ꞏ4ꞏ""" .

ex:RegistroTMOPERATIONC1 a ex:ComponenteElectrico ;
    rdfs:label "TMOPERATIONC1" ;
    ex:textoExtracto """R | TMOPERATION
TMOPERATIONC1 | Canal ꞏ1ꞏ""" .

ex:RegistroTMOPERATIONC2 a ex:ComponenteElectrico ;
    rdfs:label "TMOPERATIONC2" ;
    ex:textoExtracto """R | TMOPERATIONC2 | Canal ꞏ2ꞏ""" .

ex:RegistroTMOPERATIONC3 a ex:ComponenteElectrico ;
    rdfs:label "TMOPERATIONC3" ;
    ex:textoExtracto """R | TMOPERATIONC3 | Canal ꞏ3ꞏ""" .

ex:RegistroTMOPERATIONC4 a ex:ComponenteElectrico ;
    rdfs:label "TMOPERATIONC4" ;
    ex:textoExtracto """R | TMOPERATIONC4 | Canal ꞏ4ꞏ""" .

ex:RegistroMZIDC1 a ex:ComponenteElectrico ;
    rdfs:label "MZIDC1" ;
    ex:textoExtracto """R | MZIDC1 | Canal ꞏ1ꞏ""" .

ex:RegistroMZIDC2 a ex:ComponenteElectrico ;
    rdfs:label "MZIDC2" ;
    ex:textoExtracto """R | MZIDC2 | Canal ꞏ2ꞏ""" .

ex:RegistroMZIDC3 a ex:ComponenteElectrico ;
    rdfs:label "MZIDC3" ;
    ex:textoExtracto """R | MZIDC3 | Canal ꞏ3ꞏ""" .

ex:RegistroMZIDC4 a ex:ComponenteElectrico ;
    rdfs:label "MZIDC4" ;
    ex:textoExtracto """R | MZIDC4 | Canal ꞏ4ꞏ""" .

ex:RegistroLEAVEPOSMZ1 a ex:ComponenteElectrico ;
    rdfs:label "LEAVEPOSMZ1" ;
    ex:textoExtracto """R | LEAVEPOS
LEAVEPOSMZ1 | Almacén ꞏ1ꞏ""" .

ex:RegistroLEAVEPOSMZ2 a ex:ComponenteElectrico ;
    rdfs:label "LEAVEPOSMZ2" ;
    ex:textoExtracto """R | LEAVEPOSMZ2 | Almacén ꞏ2ꞏ""" .

ex:RegistroLEAVEPOSMZ3 a ex:ComponenteElectrico ;
    rdfs:label "LEAVEPOSMZ3" ;
    ex:textoExtracto """R | LEAVEPOSMZ3 | Almacén ꞏ3ꞏ""" .

ex:RegistroLEAVEPOSMZ4 a ex:ComponenteElectrico ;
    rdfs:label "LEAVEPOSMZ4" ;
    ex:textoExtracto """R | LEAVEPOSMZ4 | Almacén ꞏ4ꞏ""" .

ex:RegistroTAKEPOSMZ1 a ex:ComponenteElectrico ;
    rdfs:label "TAKEPOSMZ1" ;
    ex:textoExtracto """R | TAKEPOS
TAKEPOSMZ1 | Almacén ꞏ1ꞏ""" .

ex:RegistroTAKEPOSMZ2 a ex:ComponenteElectrico ;
    rdfs:label "TAKEPOSMZ2" ;
    ex:textoExtracto """R | TAKEPOSMZ2 | Almacén ꞏ2ꞏ""" .

ex:RegistroTAKEPOSMZ3 a ex:ComponenteElectrico ;
    rdfs:label "TAKEPOSMZ3" ;
    ex:textoExtracto """R | TAKEPOSMZ3 | Almacén ꞏ3ꞏ""" .

ex:RegistroTAKEPOSMZ4 a ex:ComponenteElectrico ;
    rdfs:label "TAKEPOSMZ4" ;
    ex:textoExtracto """R | TAKEPOSMZ4 | Almacén ꞏ4ꞏ""" .

ex:RegistroNEXTPOSMZ1 a ex:ComponenteElectrico ;
    rdfs:label "NEXTPOSMZ1" ;
    ex:textoExtracto """R | NEXTPOS
NEXTPOSMZ1 | Almacén ꞏ1ꞏ""" .

ex:RegistroNEXTPOSMZ2 a ex:ComponenteElectrico ;
    rdfs:label "NEXTPOSMZ2" ;
    ex:textoExtracto """R | NEXTPOSMZ2 | Almacén ꞏ2ꞏ""" .

ex:RegistroNEXTPOSMZ3 a ex:ComponenteElectrico ;
