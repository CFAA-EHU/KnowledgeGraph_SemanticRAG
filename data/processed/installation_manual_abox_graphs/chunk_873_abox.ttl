ex:RegistroNEXTPOSMZ4 a ex:ComponenteElectrico ;
    rdfs:label "NEXTPOSMZ4" ;
    ex:textoExtracto """R | NEXTPOSMZ4 | Almacén ꞏ4ꞏ""" .

ex:TablaComunicacionGestorPLC a ex:Tabla ;
    ex:tieneComponente ex:MarcaTMOPSTROBEC1, ex:MarcaTMOPSTROBEC2, ex:MarcaTMOPSTROBEC3, ex:MarcaTMOPSTROBEC4, ex:RegistroTMOPERATIONC1, ex:RegistroTMOPERATIONC2, ex:RegistroTMOPERATIONC3, ex:RegistroTMOPERATIONC4, ex:RegistroMZIDC1, ex:RegistroMZIDC2, ex:RegistroMZIDC3, ex:RegistroMZIDC4, ex:RegistroLEAVEPOSMZ1, ex:RegistroLEAVEPOSMZ2, ex:RegistroLEAVEPOSMZ3, ex:RegistroLEAVEPOSMZ4, ex:RegistroTAKEPOSMZ1, ex:RegistroTAKEPOSMZ2, ex:RegistroTAKEPOSMZ3, ex:RegistroTAKEPOSMZ4, ex:RegistroNEXTPOSMZ1, ex:RegistroNEXTPOSMZ2, ex:RegistroNEXTPOSMZ3, ex:RegistroNEXTPOSMZ4 .