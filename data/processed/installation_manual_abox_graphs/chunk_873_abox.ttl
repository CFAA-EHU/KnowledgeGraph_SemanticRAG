@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SistemaPanelMando a ns1:Sistema ;
    rdfs:label "Panel de mando" ;
    ns1:textoExtracto "Registros KEYBD1 / KEYBD1_1 a KEYBD1_8. Teclas de usuario." ;
    ns1:tieneComponente ns1:MapaDeTeclasPulsadasDelUltimoTecladoUtilizado,
        ns1:MapaDeTeclasPulsadasDelUltimoTecladoUtilizado_30e438cf97,
        ns1:MapaDeTeclasPulsadasDelUltimoTecladoUtilizado_978ea466b0,
        ns1:ParametroKEYBD2_2,
        ns1:ParametroKEYBD2_3,
        ns1:ParametroKEYBD2_4,
        ns1:ParametroKEYBD2_5,
        ns1:ParametroKEYBD2_6,
        ns1:ParametroKEYBD2_7,
        ns1:TeclaPulsadaEnElOctavoPanelDeMando_43c51dbac5,
        ns1:TeclaPulsadaEnElPrimerPanelDeMando,
        ns1:TeclaPulsadaEnElPrimerPanelDeMando_0548e34140,
        ns1:TeclaPulsadaEnElPrimerPanelDeMando_50e114857b .

ns1:TeclaPulsadaEnElOctavoPanelDeMando a ns1:Parametro ;
    rdfs:label "Tecla pulsada en el octavo panel de mando" ;
    ns1:identificador "KEYBD1_8" ;
    ns1:textoExtracto "Estos registros indican (bit=1) qué tecla se ha pulsado en cada panel de mando." .

