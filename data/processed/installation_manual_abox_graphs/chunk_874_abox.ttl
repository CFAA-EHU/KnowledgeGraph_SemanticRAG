@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ComunicacionGestorPLC_731 a ex:Tabla ;
     a ex:Tabla ;
    ex:identificador "7.3.1" ;
    ex:textoExtracto "Marcas / Registros | Significado... [fragmento completo de tabla]" ;
    rdfs:label "Tabla de comunicación Gestor → PLC (7.3.1)"@es .

ex:Registro_TMOPSTROBE
    a ex:Parametro ;
    ex:identificador "TMOPSTROBE" ;
    ex:textoExtracto "El gestor de herramientas del canal pone esta marca a (=1) para indicar al PLC que debe ejecutar la operación indicada en la marca TMOPERATION del canal."@es ;
    ex:documentadoEn ex:Tabla_ComunicacionGestorPLC_731 ;
    ex:valor "0/1" ;
    rdfs:label "Registro TMOPSTROBE (señal de ejecución)"@es .

ex:Registro_TMOPERATION
    a ex:Parametro ;
    ex:identificador "TMOPERATION" ;
    ex:textoExtracto "Este registro indica el tipo de operación que desea realizar el gestor de herramientas."@es ;
    ex:documentadoEn ex:Tabla_ComunicacionGestorPLC_731 ;
    rdfs:label "Registro TMOPERATION (tipo de operación)"@es .

ex:Registro_LEAVEPOS
    a ex:Parametro ;
    ex:identificador "LEAVEPOS" ;
    ex:textoExtracto "Este registro indica la posición de almacén en la que hay que dejar la herramienta. Durante la selección de una posición de la torreta (sentencia #ROTATEMZ), este registro tomará valor ꞏ0ꞏ si es un posicionamiento relativo positivo y valor ꞏ1ꞏ si es un posicionamiento relativo negativo."@es ;
    ex:documentadoEn ex:Tabla_ComunicacionGestorPLC_731 ;
    ex:valor "0 (relativo +) / 1 (relativo -)" ;
    rdfs:label "Registro LEAVEPOS (posición de almacén para dejar herramienta)"@es .

ex:Registro_TAKEPOS
    a ex:Parametro ;
    ex:identificador "TAKEPOS" ;
    ex:textoExtracto "Este registro indica la posición de almacén que ocupa la herramienta que hay que coger. Durante la selección de una posición de la torreta (sentencia #ROTATEMZ), este registro tomará valor ꞏ0ꞏ si es un posicionamiento absoluto y valor ꞏ1ꞏ si es un posicionamiento relativo."@es ;
    ex:documentadoEn ex:Tabla_ComunicacionGestorPLC_731 ;
    ex:valor "0 (absoluto) / 1 (relativo)" ;
    rdfs:label "Registro TAKEPOS (posición de almacén para tomar herramienta)"@es .

ex:Registro_NEXTPOS
    a ex:Parametro ;
    ex:identificador "NEXTPOS" ;
    ex:textoExtracto "Este registro indica la posición de almacén que ocupa la siguiente herramienta. Durante la selección de una posición de la torreta (sentencia #ROTATEMZ), en un posicionamiento absoluto este registro indica la posición a alcanzar y en un posicionamiento relativo indica el número de posiciones a girar."@es ;
    ex:documentadoEn ex:Tabla_ComunicacionGestorPLC_731 ;
    rdfs:label "Registro NEXTPOS (posición siguiente o desplazamiento)"@es .

ex:Registro_MZID
    a ex:Parametro ;
    ex:identificador "MZID" ;
    ex:textoExtracto "Este registro indica el almacén en el que se encuentra la herramienta que ha solicitado el canal. Cuando en el cambio de herramienta intervengan dos almacenes, en la parte baja de este registro se indica el almacén en el que hay que dejar la herramienta y en la parte alta el almacén del que hay que coger la herramienta."@es ;
    ex:documentadoEn ex:Tabla_ComunicacionGestorPLC_731 ;
    rdfs:label "Registro MZID (identificador de almacén de herramientas)"@es .

ex:Sistema_ComunicacionGestorPLC
    a ex:Sistema ;
    ex:textoExtracto "Comunicación Gestor → PLC (sección 7.3.1)."@es ;
    rdfs:label "Sistema de comunicación Gestor-PLC"@es ;
    ex:tieneComponente ex:Registro_TMOPSTROBE , ex:Registro_TMOPERATION , ex:Registro_LEAVEPOS ,
                       ex:Registro_TAKEPOS , ex:Registro_NEXTPOS , ex:Registro_MZID ;
    ex:detalladoEnEsquema ex:Tabla_ComunicacionGestorPLC_731 .