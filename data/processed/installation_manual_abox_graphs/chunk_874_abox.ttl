@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:InterfazUsuarioTeclasGenericas a ns1:InterfazUsuario ;
    rdfs:label "Teclas genéricas" ;
    ns1:textoExtracto "Teclas genéricas. Registros KEYBD2 / KEYBD2_1 a KEYBD2_8." .

ns1:RegistroQueIndicaQueTeclaSeHaPulsadoDelPrimerVolante a ns1:Parametro ;
    rdfs:label "Registro que indica qué tecla se ha pulsado del primer volante" ;
    ns1:identificador "KEYHBLS1" ;
    ns1:textoExtracto "El registro KEYHBLS1 corresponde al primer volante y KEYHBLS2 al segundo." .

ns1:RegistroQueIndicaQueTeclaSeHaPulsadoDelSegundoVolante a ns1:Parametro ;
    rdfs:label "Registro que indica qué tecla se ha pulsado del segundo volante" ;
    ns1:identificador "KEYHBLS2" ;
    ns1:textoExtracto "El registro KEYHBLS1 corresponde al primer volante y KEYHBLS2 al segundo." .

ns1:SelectorDeMovimientoVolanteJogIncrementalOJogContinuo a ns1:Parametro ;
    rdfs:label "Selector de movimiento (volante, jog incremental o jog continuo)" ;
    ns1:identificador "KEYBD3" ;
    ns1:textoExtracto "Selector de movimiento (volante, jog incremental o jog continuo). Registros KEYBD3 / KEYBD3_1 a KEYBD3_8." .

ns1:SelectorDelFeedOverride a ns1:Parametro ;
    rdfs:label "Selector del feed override" ;
    ns1:identificador "KEYBD2" ;
    ns1:textoExtracto "Selector del feed override. Registros KEYBD2 / KEYBD2_1 a KEYBD2_8." .

