@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarMarcaSTOP a ns1:AccionProhibida ;
    rdfs:label "Activar marca STOP" ;
    ns1:textoExtracto "Si el PLC pone esta marca a nivel lógico bajo, el canal del CNC detiene la ejecución del programa pieza." .

ns1:Parametro_32e339d473 a ns1:Parametro ;
    rdfs:label "Marca para canal 2 de parada" ;
    ns1:identificador "_STOPC2" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. _ STOPC2" .

ns1:Parametro_63ca7de712 a ns1:Parametro ;
    rdfs:label "Marca para canal 4 de parada" ;
    ns1:identificador "_STOPC4" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. _ STOPC4" .

ns1:Parametro_67df8ea9c7 a ns1:Parametro ;
    rdfs:label "Marca para canal 2 de emergencia" ;
    ns1:identificador "_EMERGENC2" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. _ EMERGENC2" .

ns1:Parametro_6e7a8392fd a ns1:Parametro ;
    rdfs:label "Marca para canal 3 de emergencia" ;
    ns1:identificador "_EMERGENC3" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. _ EMERGENC3" .

ns1:Parametro_8e5977efb0 a ns1:Parametro ;
    rdfs:label "Marca para canal 1 de parada" ;
    ns1:identificador "_STOPC1" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. _ STOPC1 (también se puede programar como _STOP)" .

ns1:Parametro_bd6f0c8f33 a ns1:Parametro ;
    rdfs:label "Marca para canal 4 de emergencia" ;
    ns1:identificador "_EMERGENC4" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. _ EMERGENC4" .

ns1:Parametro_e4737aac22 a ns1:Parametro ;
    rdfs:label "Marca para canal 1 de emergencia" ;
    ns1:identificador "_EMERGENC1" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. _ EMERGENC1 (también se puede programar como _EMERGEN)" .

ns1:Parametro_fc4073084c a ns1:Parametro ;
    rdfs:label "Marca para canal 3 de parada" ;
    ns1:identificador "_STOPC3" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. _ STOPC3" .

ns1:PulsarTeclaDeEmergencia a ns1:AccionProhibida ;
    rdfs:label "Pulsar tecla de emergencia" ;
    ns1:activaAlarma ns1:CNC8070_51972e4c04 ;
    ns1:textoExtracto "Si se pulsa la seta de emergencia (I-EMERG=0) o se produce cualquier otra causa de emergencia (=0), la marca _EMERGEN se pone a (=0), produciéndose emergencia en el CNC." .

ns1:CNC8070_51972e4c04 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC detiene el avance de los ejes dejando de enviarles consigna; los ejes no se detienen siguiendo una rampa de deceleración establecida." .

