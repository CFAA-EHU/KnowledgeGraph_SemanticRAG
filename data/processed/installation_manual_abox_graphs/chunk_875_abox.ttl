@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MarcaPLC_Gestor ex:textoExtracto "El PLC utiliza las siguientes marcas para informar al gestor de las operaciones que ha realizado." ;
    rdfs:label "marca PLC para gestor" ;
    a ex:Sensor .

ex:RegistroPLC_Gestor ex:textoExtracto "un grupo de marcas para cada almacén" ;
    rdfs:label "registro PLC para gestor" ;
    a ex:Sensor .

ex:Tabla_MarcasPLC_Gestor a ex:Tabla ;
    ex:textoExtracto "En la siguiente tabla se muestran los mnemónicos de cada marca (M) o registro (R) en cada uno de los canales o almacenes." ;
    rdfs:label "tabla de marcas y registros PLC para gestor" ;
    a ex:Tabla ;
    ex:compuestoPor ex:MarcaPLC_Gestor, ex:RegistroPLC_Gestor .