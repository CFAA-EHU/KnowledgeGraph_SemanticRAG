@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:SenalSTOP a ns1:Parametro ;
    rdfs:label "Señal STOP" ;
    ns1:textoExtracto "Esta marca no detiene el giro del cabezal. Esta marca no afecta al movimiento independiente de un eje (interpolador independiente), al que tampoco afecta la tecla [STOP]. Esta marca no apaga el láser. Esta marca no desactiva el control del gap, excepto en el movimiento de aproximación." .

ns1:SenalXFERINH_5e57e68da0 a ns1:Parametro ;
    rdfs:label "Señal XFERINH" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para _XFERINH." .

ns1:TeclaSTOP a ns1:ComponenteElectrico ;
    rdfs:label "Tecla STOP" ;
    ns1:textoExtracto "Esta marca no afecta al movimiento independiente de un eje (interpolador independiente), al que tampoco afecta la tecla [STOP]." .

