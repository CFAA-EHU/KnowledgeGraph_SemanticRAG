@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:MZTOCH1 a ex:Parametro ;
    ex:identificador "MZTOCH1" ;
    ex:textoExtracto "Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del almacén al brazo cambiador 1." .

ex:CH1TOSPDL a ex:Parametro ;
    ex:identificador "CH1TOSPDL" ;
    ex:textoExtracto "Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del brazo cambiador 1 al cabezal." .

ex:SPDLTOCH1 a ex:Parametro ;
    ex:identificador "SPDLTOCH1" ;
    ex:textoExtracto "Utilizar con almacén síncrono con 1 sólo brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal al brazo cambiador 1." .

ex:SPDLTOCH2 a ex:Parametro ;
    ex:identificador "SPDLTOCH2" ;
    ex:textoExtracto "Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal al brazo cambiador 2." .

ex:CH1TOMZ a ex:Parametro ;
    ex:identificador "CH1TOMZ" ;
    ex:textoExtracto "Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del brazo cambiador 1 al almacén." .