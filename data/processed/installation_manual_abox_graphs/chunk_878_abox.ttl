@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:CH2TOMZ a ex:Parametro ;
    rdfs:label "CH2TOMZ" ;
    ex:textoExtracto "Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del brazo cambiador 2 al almacén." .

ex:SPDLTOGR a ex:Parametro ;
    rdfs:label "SPDLTOGR" ;
    ex:textoExtracto "Utilizar con almacén que permite herramientas de tierra. El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal a tierra." .

ex:GRTOSPDL a ex:Parametro ;
    rdfs:label "GRTOSPDL" ;
    ex:textoExtracto "Utilizar con almacén que permite herramientas de tierra. El PLC debe poner esta marca a (=1) tras llevar la herramienta de tierra al cabezal." .

ex:MZTOSPDL a ex:Parametro ;
    rdfs:label "MZTOSPDL" ;
    ex:textoExtracto "Utilizar con almacén síncrono (sin brazo). El PLC debe poner esta marca a (=1) tras llevar la herramienta del almacén al cabezal." .

ex:SPDLTOMZ a ex:Parametro ;
    rdfs:label "SPDLTOMZ" ;
    ex:textoExtracto "Utilizar con almacén síncrono (sin brazo). El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal al almacén." .

ex:MZROT a ex:Parametro ;
    rdfs:label "MZROT" ;
    ex:textoExtracto "Utilizar con almacén tipo torreta y con almacén síncrono. El PLC debe poner esta marca a (=1) cuando la torreta ha girado. En el almacén síncrono se utiliza para optimizar el cambio orientando el almacén durante el mecanizado. El PLC debe poner esta marca a (=1) para indicar que ha finalizado la operación, se haya orientado el almacén o no." .

ex:TCHANGEOK a ex:Parametro ;
    rdfs:label "TCHANGEOK" ;
    ex:textoExtracto "En almacenes asíncronos (con brazo cambiador de movimientos independientes) se puede activar la siguiente marca para que el CNC continúe con la ejecución del programa mientras se deja la herramienta en el almacén. El PLC debe poner esta marca a (=1) para indicar al gestor que debe continuar la ejecución del programa mientras se deja la herramienta en el almacén." .