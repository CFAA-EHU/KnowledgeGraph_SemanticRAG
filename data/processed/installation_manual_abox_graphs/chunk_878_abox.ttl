@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ComunicacionPLC_Gestor a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de marcas/registros para comunicación PLC-Gestor"@es ;
    ex:textoExtracto "Marcas / Registros. | Significado. | --- | --- | CH2TOMZ | Utilizar con almacén asíncrono o síncrono con brazo..."@es ;
    ex:documentadoEn ex:Pagina_474_475 .

ex:Marca_CH2TOMZ
    a ex:Parametro ;
    rdfs:label "CH2TOMZ" ;
    ex:identificador "CH2TOMZ" ;
    ex:valor "1" ;
    ex:textoExtracto "Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del brazo cambiador 2 al almacén."@es ;
    ex:documentadoEn ex:Tabla_ComunicacionPLC_Gestor .

ex:Marca_SPDLTOGR
    a ex:Parametro ;
    rdfs:label "SPDLTOGR" ;
    ex:identificador "SPDLTOGR" ;
    ex:valor "1" ;
    ex:textoExtracto "Utilizar con almacén que permite herramientas de tierra. El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal a tierra."@es ;
    ex:documentadoEn ex:Tabla_ComunicacionPLC_Gestor .

ex:Marca_GRTOSPDL
    a ex:Parametro ;
    rdfs:label "GRTOSPDL" ;
    ex:identificador "GRTOSPDL" ;
    ex:valor "1" ;
    ex:textoExtracto "Utilizar con almacén que permite herramientas de tierra. El PLC debe poner esta marca a (=1) tras llevar la herramienta de tierra al cabezal."@es ;
    ex:documentadoEn ex:Tabla_ComunicacionPLC_Gestor .

ex:Marca_MZTOSPDL
    a ex:Parametro ;
    rdfs:label "MZTOSPDL" ;
    ex:identificador "MZTOSPDL" ;
    ex:valor "1" ;
    ex:textoExtracto "Utilizar con almacén síncrono (sin brazo). El PLC debe poner esta marca a (=1) tras llevar la herramienta del almacén al cabezal."@es ;
    ex:documentadoEn ex:Tabla_ComunicacionPLC_Gestor .

ex:Marca_SPDLTOMZ
    a ex:Parametro ;
    rdfs:label "SPDLTOMZ" ;
    ex:identificador "SPDLTOMZ" ;
    ex:valor "1" ;
    ex:textoExtracto "Utilizar con almacén síncrono (sin brazo). El PLC debe poner esta marca a (=1) tras llevar la herramienta del cabezal al almacén."@es ;
    ex:documentadoEn ex:Tabla_ComunicacionPLC_Gestor .

ex:Marca_MZROT
    a ex:Parametro ;
    rdfs:label "MZROT" ;
    ex:identificador "MZROT" ;
    ex:valor "1" ;
    ex:textoExtracto "Utilizar con almacén tipo torreta y con almacén síncrono. El PLC debe poner esta marca a (=1) cuando la torreta ha girado. En el almacén síncrono se utiliza para optimizar el cambio orientando el almacén durante el mecanizado."@es ;
    ex:documentadoEn ex:Tabla_ComunicacionPLC_Gestor .

ex:Marca_TCHANGEOK
    a ex:Parametro ;
    rdfs:label "TCHANGEOK" ;
    ex:identificador "TCHANGEOK" ;
    ex:valor "1" ;
    ex:textoExtracto "En almacenes asíncronos (con brazo cambiador de movimientos independientes) se puede activar la siguiente marca para que el CNC continúe con la ejecución del programa mientras se deja la herramienta en el almacén. El PLC debe poner esta marca a (=1) para indicar al gestor que debe continuar la ejecución del programa mientras se deja la herramienta en el almacén."@es ;
    ex:documentadoEn ex:Tabla_ComunicacionPLC_Gestor .

ex:Pagina_474_475
    a ex:Pagina ;
    rdfs:label "Páginas 474-475"@es ;
    ex:identificador "474-475" ;
    ex:textoExtracto "Sección 7.3.2 Comunicación PLC --> Gestor"@es .