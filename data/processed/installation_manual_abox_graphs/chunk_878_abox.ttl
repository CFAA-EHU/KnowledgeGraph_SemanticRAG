@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_73a17733c2 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "Con la marca a (=0) el CNC no permite movimientos en jog para los ejes del canal; la pulsación de una tecla de jog no tiene efecto." .

ns1:DeterminaSiLosMovimientosProgramadosDesdeElPLCEstanAfectadosPorLaMarca a ns1:Parametro ;
    rdfs:label "Determina si los movimientos programados desde el PLC están afectados por la marca" ;
    ns1:identificador "XFITOIND" ;
    ns1:textoExtracto "los programados desde el PLC dependen del parámetro XFITOIND." .

ns1:Parametro_7107bca727 a ns1:Parametro ;
    rdfs:label "Marca que inhibe movimientos en jog" ;
    ns1:identificador "a" ;
    ns1:textoExtracto "Con la marca a (=0) el CNC no permite movimientos en jog para los ejes del canal; la pulsación de una tecla de jog no tiene efecto." .

ns1:Parametro_859067b115 a ns1:Parametro ;
    rdfs:label "Marca que inhibe movimientos de eje independiente" ;
    ns1:identificador "XFERINH" ;
    ns1:textoExtracto "Si el PLC desactiva la marca _XFERINH, el canal del CNC detiene sus movimientos de eje independiente cuando estos llegan a posición e impide la ejecución del siguiente movimiento." .

