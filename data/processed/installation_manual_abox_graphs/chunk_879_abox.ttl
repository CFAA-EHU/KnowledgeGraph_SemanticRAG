@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:RegistroMZPOS a ex:Parametro ;
    rdfs:label "MZPOS" ;
    ex:textoExtracto "MZPOS" ;
    ex:valor "posición actual del almacén"@es ;
    ex:textoExtracto "El PLC debe indicar en este registro la posición actual del almacén"@es .

ex:RegistroGestor a ex:Parametro ;
    rdfs:label "marca para gestor"@es ;
    ex:textoExtracto "esta marca a (=1)"@es ;
    ex:valor "indicar al gestor que debe continuar la ejecución del programa mientras se deja la herramienta en el almacén"@es ;
    ex:textoExtracto "El PLC debe poner esta marca a (=1) para indicar al gestor que debe continuar la ejecución del programa mientras se deja la herramienta en el almacén."@es .

ex:SistemaPLC a ex:Sistema ;
    ex:textoExtracto "El PLC debe poner esta marca a (=1) para indicar al gestor que debe continuar la ejecución del programa mientras se deja la herramienta en el almacén."@es ;
    ex:textoExtracto "El PLC debe indicar en este registro la posición actual del almacén"@es ;
    ex:compuestoPor ex:RegistroMZPOS, ex:RegistroGestor .