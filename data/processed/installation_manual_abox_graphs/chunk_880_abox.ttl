@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:RegistroPosicionAlmacenPLC a ex:Parametro ;
    rdfs:label "Registro de posición del almacén en PLC" ;
    ex:textoExtracto "El PLC debe indicar en este registro la posición actual del almacén; si el registro tiene valor ꞏ0ꞏ, el PLC mostrará el error correspondiente." ;
    ex:valor "0" .

ex:ErrorPosicionAlmacen a ex:AvisoSeguridad ;
    rdfs:label "Error de posición del almacén" ;
    ex:textoExtracto "si el registro tiene valor ꞏ0ꞏ, el PLC mostrará el error correspondiente." .