ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:controla ns1:ActivacionDeCYSTART ;
    ns1:textoExtracto "el PLC debe activar la marca CYSTART para que comience la ejecución del programa." .

ns1:ActivacionDeCYSTART a ns1:TareaMantenimiento ;
    rdfs:label "Activación de CYSTART" ;
    ns1:textoExtracto "Si se cumplen el resto de condiciones (hidráulico, seguridades, etc), el PLC debe activar la marca CYSTART para que comience la ejecución del programa." .

