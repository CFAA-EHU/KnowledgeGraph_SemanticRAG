@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:GestorEmergencia a ex:Sistema ;
    ex:textoExtracto "El gestor se puede poner en estado de emergencia si se produce una anomalía (el PLC ha ejecutado una acción equivocada, cambio no finalizado, etc) o si el PLC activa la emergencia." ;
    ex:tieneComponente ex:SETTMEM, ex:RESTMEM, ex:TMINEM, ex:SETTMEMZ1, ex:SETTMEMZ2, ex:SETTMEMZ3, ex:SETTMEMZ4, ex:RESTMEMZ1, ex:RESTMEMZ2, ex:RESTMEMZ3, ex:RESTMEMZ4, ex:TMINEMZ1, ex:TMINEMZ2, ex:TMINEMZ3, ex:TMINEMZ4 .

ex:SETTMEM a ex:ComponenteElectrico ;
    ex:textoExtracto "SETTMEM: El PLC pone esta marca a (=1) para activar la emergencia del gestor de herramientas." ;
    rdfs:label "SETTMEM" .

ex:RESTMEM a ex:ComponenteElectrico ;
    ex:textoExtracto "RESTMEM: El PLC pone esta marca a (=1) para cancelar la emergencia del gestor de herramientas." ;
    rdfs:label "RESTMEM" .

ex:TMINEM a ex:ComponenteElectrico ;
    ex:textoExtracto "TMINEM: El CNC pone esta marca a (=1) para indicar al PLC que se ha producido una emergencia en el gestor de herramientas." ;
    rdfs:label "TMINEM" .

ex:SETTMEMZ1 a ex:ComponenteElectrico ;
    ex:textoExtracto "SETTMEMZ1: Marca de PLC relacionada con la emergencia del gestor en el almacén 1." ;
    rdfs:label "SETTMEMZ1" .

ex:SETTMEMZ2 a ex:ComponenteElectrico ;
    ex:textoExtracto "SETTMEMZ2: Marca de PLC relacionada con la emergencia del gestor en el almacén 2." ;
    rdfs:label "SETTMEMZ2" .

ex:SETTMEMZ3 a ex:ComponenteElectrico ;
    ex:textoExtracto "SETTMEMZ3: Marca de PLC relacionada con la emergencia del gestor en el almacén 3." ;
    rdfs:label "SETTMEMZ3" .

ex:SETTMEMZ4 a ex:ComponenteElectrico ;
    ex:textoExtracto "SETTMEMZ4: Marca de PLC relacionada con la emergencia del gestor en el almacén 4." ;
    rdfs:label "SETTMEMZ4" .

ex:RESTMEMZ1 a ex:ComponenteElectrico ;
    ex:textoExtracto "RESTMEMZ1: Marca de PLC relacionada con la cancelación de emergencia del gestor en el almacén 1." ;
    rdfs:label "RESTMEMZ1" .

ex:RESTMEMZ2 a ex:ComponenteElectrico ;
    ex:textoExtracto "RESTMEMZ2: Marca de PLC relacionada con la cancelación de emergencia del gestor en el almacén 2." ;
    rdfs:label "RESTMEMZ2" .

ex:RESTMEMZ3 a ex:ComponenteElectrico ;
    ex:textoExtracto "RESTMEMZ3: Marca de PLC relacionada con la cancelación de emergencia del gestor en el almacén 3." ;
    rdfs:label "RESTMEMZ3" .

ex:RESTMEMZ4 a ex:ComponenteElectrico ;
    ex:textoExtracto "RESTMEMZ4: Marca de PLC relacionada con la cancelación de emergencia del gestor en el almacén 4." ;
    rdfs:label "RESTMEMZ4" .

ex:TMINEMZ1 a ex:ComponenteElectrico ;
    ex:textoExtracto "TMINEMZ1: Marca de CNC relacionada con la emergencia del gestor en el almacén 1." ;
    rdfs:label "TMINEMZ1" .

ex:TMINEMZ2 a ex:ComponenteElectrico ;
    ex:textoExtracto "TMINEMZ2: Marca de CNC relacionada con la emergencia del gestor en el almacén 2." ;
    rdfs:label "TMINEMZ2" .

ex:TMINEMZ3 a ex:ComponenteElectrico ;
    ex:textoExtracto "TMINEMZ3: Marca de CNC relacionada con la emergencia del gestor en el almacén 3." ;
    rdfs:label "TMINEMZ3" .

ex:TMINEMZ4 a ex:ComponenteElectrico ;
    ex:textoExtracto "TMINEMZ4: Marca de CNC relacionada con la emergencia del gestor en el almacén 4." ;
    rdfs:label "TMINEMZ4" .