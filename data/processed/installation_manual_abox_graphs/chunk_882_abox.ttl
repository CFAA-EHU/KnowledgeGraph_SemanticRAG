@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_1fa5dc1b1e a ns1:Parametro ;
    rdfs:label "Marca OVRCANC1 para override del 100% al avance de los ejes",
        "Marca OVRCANC2 para override del 100% al avance de los ejes",
        "Marca OVRCANC3 para override del 100% al avance de los ejes",
        "Marca OVRCANC4 para override del 100% al avance de los ejes" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. OVRCANC1 (también se puede programar como OVRCAN)" .

ns1:Parametro_470f1a64c1 a ns1:Parametro ;
    rdfs:label "Marca CYSTART para inicio de ejecución del programa" ;
    ns1:textoExtracto "PLC debe activar la marca CYSTART para que comience la ejecución del programa." .

ns1:Parametro_53e404b56a a ns1:Parametro ;
    rdfs:label "Marca RESETINC1 para reset en el CNC",
        "Marca RESETINC2 para reset en el CNC",
        "Marca RESETINC3 para reset en el CNC",
        "Marca RESETINC4 para reset en el CNC" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. RESETINC1 (también se puede programar como RESETIN)" .

ns1:Parametro_9ae5c73532 a ns1:Parametro ;
    rdfs:label "Marca SBLOCKC1 para modo de ejecución bloque a bloque",
        "Marca SBLOCKC2 para modo de ejecución bloque a bloque",
        "Marca SBLOCKC3 para modo de ejecución bloque a bloque",
        "Marca SBLOCKC4 para modo de ejecución bloque a bloque" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. SBLOCKC1 (también se puede programar como SBLOCK)" .

ns1:Parametro_db51b0f463 a ns1:Parametro ;
    rdfs:label "Marca MANRAPIDC1 para avance rápido en modo manual",
        "Marca MANRAPIDC2 para avance rápido en modo manual",
        "Marca MANRAPIDC3 para avance rápido en modo manual",
        "Marca MANRAPIDC4 para avance rápido en modo manual" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. MANRAPIDC1 (también se puede programar como MANRAPID)" .

