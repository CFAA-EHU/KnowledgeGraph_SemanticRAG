@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_3e3a47f7c3 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "el canal del CNC se resetea" .

ns1:GeneracionDeFlancoDeSubidaEnLaMarca a ns1:AccionProhibida ;
    rdfs:label "Generación de flanco de subida en la marca" ;
    ns1:textoExtracto "Con un flanco de subida (cambio de 0 a 1) de esta marca, el canal del CNC se resetea" .

ns1:Parametro_843c588c65 a ns1:Parametro ;
    rdfs:label "Marca de reset desactivada por PLC" ;
    ns1:identificador "RESETIN" ;
    ns1:textoExtracto "Una vez iniciado el reset, el PLC puede desactivar esta marca (RESETIN=0)" .

ns1:PulsarTeclaRESET a ns1:AccionProhibida ;
    rdfs:label "Pulsar tecla [RESET]" ;
    ns1:textoExtracto "El usuario pulsa la tecla [RESET] del panel" .

