@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoNormal a ex:ModoOperacion ;
    rdfs:label "Modo normal" ;
    ex:textoExtracto "Con valor ꞏ0ꞏ Modo normal (por defecto y tras reset)." ;
    ex:valor "0" .

ex:ModoCargaAlmacen a ex:ModoOperacion ;
    rdfs:label "Modo carga de almacén" ;
    ex:textoExtracto "Con valor ꞏ1ꞏ Modo carga de almacén." ;
    ex:valor "1" .

ex:ModoDescargaAlmacen a ex:ModoOperacion ;
    rdfs:label "Modo descarga de almacén" ;
    ex:textoExtracto "Con valor ꞏ2ꞏ Modo descarga de almacén." ;
    ex:valor "2" .

ex:EstadoFuncionamientoNormal a ex:ModoOperacion ;
    rdfs:label "Funcionamiento normal" ;
    ex:textoExtracto "Con valor ꞏ0ꞏ Funcionamiento normal." ;
    ex:valor "0" .

ex:EstadoErrorGestor a ex:ModoOperacion ;
    rdfs:label "Se ha producido un error" ;
    ex:textoExtracto "Con valor ꞏ1ꞏ Se ha producido un error." ;
    ex:valor "1" .

ex:EstadoErrorEsperaManiobra a ex:ModoOperacion ;
    rdfs:label "Se ha producido un error pero se espera a que finalice la maniobra en marcha" ;
    ex:textoExtracto "Con valor ꞏ2ꞏ Se ha producido un error pero se espera a que finalice la maniobra en marcha." ;
    ex:valor "2" .

ex:EstadoEmergencia a ex:ModoOperacion ;
    rdfs:label "Emergencia" ;
    ex:textoExtracto "Con valor ꞏ4ꞏ Emergencia." ;
    ex:valor "4" .

ex:GestorNoEnEjecucion a ex:ModoOperacion ;
    rdfs:label "No hay ninguna secuencia en ejecución" ;
    ex:textoExtracto "Con valor ꞏ0ꞏ No hay ninguna secuencia en ejecución." ;
    ex:valor "0" .

ex:GestorEnEjecucion a ex:ModoOperacion ;
    rdfs:label "Indica que hay una secuencia en ejecución" ;
    ex:textoExtracto "Con valor ꞏ1ꞏ Indica que hay una secuencia en ejecución." ;
    ex:valor "1" .

ex:NoHayQueEsperar a ex:ModoOperacion ;
    rdfs:label "No hay que esperar" ;
    ex:textoExtracto "Con valor ꞏ0ꞏ No hay que esperar." ;
    ex:valor "0" .

ex:HayQueEsperar a ex:ModoOperacion ;
    rdfs:label "Hay que esperar" ;
    ex:textoExtracto "Con valor ꞏ1ꞏ Hay que esperar." ;
    ex:valor "1" .