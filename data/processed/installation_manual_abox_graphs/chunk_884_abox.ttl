@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_4d397e7c4c a ns1:Parametro ;
    rdfs:label "Marca de finalización del reseteo del canal" ;
    ns1:documentadoEn ns1:SistemaCNC ;
    ns1:identificador "RESETOUT" ;
    ns1:textoExtracto "El canal activa la marca RESETOUT (RESETOUT=1) para indicar que ha finalizado el reset." .

ns1:Parametro_843c588c65 a ns1:Parametro ;
    rdfs:label "Marca de reseteo del canal" ;
    ns1:documentadoEn ns1:SistemaCNC ;
    ns1:identificador "RESETIN" ;
    ns1:textoExtracto "El PLC puede desactivar esta marca (RESETIN=0)." .

ns1:ProcesoDeReseteoDelCanal a ns1:TareaMantenimiento ;
    rdfs:label "Proceso de reseteo del canal" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "El proceso de reset es como sigue. 1 El usuario pulsa la tecla [RESET] del panel de mando o el PLC activa la marca RESETIN." .

ns1:TiempoDeActivacionDeLaMarcaRESETOUT a ns1:Parametro ;
    rdfs:label "Tiempo de activación de la marca RESETOUT" ;
    ns1:documentadoEn ns1:SistemaCNC ;
    ns1:identificador "MINAENDW" ;
    ns1:textoExtracto "Esta marca permanece activa el tiempo fijado en el parámetro general MINAENDW." .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "Sistema CNC" ;
    ns1:textoExtracto "de esta marca, el canal del CNC se resetea." .

