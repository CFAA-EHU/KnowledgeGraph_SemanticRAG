@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TablaAlmacenHerramientas_884_479 a ex:Tabla ;
    ex:textoExtracto "En cada una de las tablas del almacén existen softkeys que permiten inicializar, cargar y descargar herramientas en el almacén de forma manual y automática." ;
    ex:compuestoPor ex:SoftkeyCargaDescargaHerramientas_884_479 .

ex:SoftkeyCargaDescargaHerramientas_884_479 a ex:InterfazUsuario ;
    ex:textoExtracto "En cada una de las tablas del almacén existen softkeys que permiten inicializar, cargar y descargar herramientas en el almacén de forma manual y automática." .

ex:TablaAlmacenCabezal_884_479 a ex:Tabla ;
    ex:textoExtracto "La carga y descarga de herramientas en el cabezal y en las pinzas del brazo cambiador hay que hacerlo siempre de forma manual desde la tabla del almacén." .

ex:VariableTM_MZMODE_884 a ex:Parametro ;
    ex:identificador "V.TM.MZMODE" ;
    ex:textoExtracto "Personalizar la variable V.TM.MZMODE=1, para indicar al gestor que se desea trabajar en modo de carga de almacén." ;
    ex:valor "1" .

ex:VariableTM_MZMODE_884_2 a ex:Parametro ;
    ex:identificador "V.TM.MZMODE" ;
    ex:textoExtracto "Personalizar la variable V.TM.MZMODE=2, para indicar al gestor que se desea trabajar en modo descarga de almacén." ;
    ex:valor "2" .

ex:InstruccionTM6_884 a ex:TareaMantenimiento ;
    ex:identificador "T1 M6" ;
    ex:textoExtracto "Si a continuación se ejecuta la instrucción T1 M6 el gestor entiende que se desea llevar la herramienta T1 de tierra al almacén pasando por el cabezal y se lo comunicará al PLC con TMOPERATION=9." .

ex:InstruccionTM6_884_2 a ex:TareaMantenimiento ;
    ex:identificador "T1 M6" ;
    ex:textoExtracto "Si a continuación se ejecuta la instrucción T1 M6 el gestor entiende que se desea llevar la herramienta T1 del almacén a tierra pasando por el cabezal y se lo comunicará al PLC con TMOPERATION=10." .

ex:TMOPERATION_9_884 a ex:Parametro ;
    ex:identificador "TMOPERATION" ;
    ex:textoExtracto "el gestor ... se lo comunicará al PLC con TMOPERATION=9." ;
    ex:valor "9" .

ex:TMOPERATION_10_884 a ex:Parametro ;
    ex:identificador "TMOPERATION" ;
    ex:textoExtracto "el gestor ... se lo comunicará al PLC con TMOPERATION=10." ;
    ex:valor "10" .