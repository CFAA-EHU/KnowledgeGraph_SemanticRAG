@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_648e4ae019 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El PLC pone esta marca a (=1) para indicar al canal del CNC que la condición de salto de bloque \"/\" se cumple." .

ns1:CondicionDeSaltoDeBloqueParaElCanal1 a ns1:Parametro ;
    rdfs:label "Condición de salto de bloque para el canal 1" ;
    ns1:textoExtracto "El PLC pone esta marca a (=1) para indicar al canal del CNC que la condición de salto de bloque \"/\" se cumple." .

ns1:ParadasCondicionalesM01ParaElCanal1 a ns1:Parametro ;
    rdfs:label "Paradas condicionales (M01) para el canal 1" ;
    ns1:textoExtracto "El PLC pone esta marca a (=1) para indicar al canal del CNC que tenga en cuenta las paradas condicionales (M01)." .

ns1:Parametro_710f8bf833 a ns1:Parametro ;
    rdfs:label "Marca RESETIN" ;
    ns1:textoExtracto "El PLC activa la marca RESETIN." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "El PLC activa la marca RESETIN." .

ns1:TiempoFijadoEnElParametroGeneralMINAENDW a ns1:Parametro ;
    rdfs:label "Tiempo fijado en el parámetro general MINAENDW" ;
    ns1:textoExtracto "Esta marca permanece activa el tiempo fijado en el parámetro general MINAENDW." .

ns1:TipoDeFuncionamientoDeLasTeclasDeJOGEnElModoManual a ns1:Parametro ;
    rdfs:label "Tipo de funcionamiento de las teclas de JOG en el modo manual" ;
    ns1:textoExtracto "Esta marca permite seleccionar el tipo de funcionamiento de las teclas de JOG en el modo manual." .

