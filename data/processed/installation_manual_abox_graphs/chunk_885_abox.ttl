@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:SubrutinaM06 a ex:TareaMantenimiento ;
    rdfs:label "Subrutina asociada a la función M06" ;
    ex:textoExtracto "En la subrutina asociada a la función M06 y en el programa del PLC deberá estar definida la maniobra necesaria para realizar el cambio." ;
    ex:compuestoPor ex:ProgramaPLC, ex:ManiobraCambioHerramienta .

ex:ProgramaPLC a ex:Sistema ;
    rdfs:label "Programa del PLC" ;
    ex:textoExtracto "en el programa del PLC deberá estar definida la maniobra necesaria para realizar el cambio." .

ex:ManiobraCambioHerramienta a ex:TareaMantenimiento ;
    rdfs:label "Maniobra necesaria para realizar el cambio de herramienta" ;
    ex:textoExtracto "deberá estar definida la maniobra necesaria para realizar el cambio." .

ex:GestorAlmacen a ex:Sistema ;
    rdfs:label "Gestor actualiza la tabla de almacén" ;
    ex:textoExtracto "Tras descargar la herramienta el gestor actualiza la tabla de almacén." ;
    ex:tieneComponente ex:TablaAlmacen .

ex:TablaAlmacen a ex:Tabla ;
    rdfs:label "Tabla de almacén" ;
    ex:textoExtracto "actualiza la tabla de almacén." .

ex:Herramienta a ex:PiezaRecambio ;
    rdfs:label "Herramienta" ;
    ex:textoExtracto "Tras descargar la herramienta" .

ex:ProgramaMDI a ex:InterfazUsuario ;
    rdfs:label "Programa MDI Personalizar" ;
    ex:textoExtracto "Colocar una herramienta en el cabezal desde programa o MDI Personalizar la variable" .

ex:VariablePersonalizada a ex:Parametro ;
    rdfs:label "Variable personalizada" ;
    ex:textoExtracto "Personalizar la variable" .