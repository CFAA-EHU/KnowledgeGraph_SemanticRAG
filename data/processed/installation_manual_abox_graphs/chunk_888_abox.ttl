@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_OperacionesGestorHerramientas a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de operaciones válidas del gestor de herramientas"@es ;
    ex:textoExtracto "Operaciones válidas del gestor de herramientas para este almacén. Las operaciones posibles en este tipo de almacén son las siguientes. | TMOPERATION | Significado. | --- | --- | 0 | No hay que hacer nada. | 3 | Poner en el cabezal una herramienta de tierra. | 4 | Dejar la herramienta del cabezal en tierra. | 8 | Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra."@es ;
    ex:ilustradoEn ex:Pagina_481 .

ex:Operacion_TMOPERATION_0
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION 0"@es ;
    ex:identificador "0" ;
    ex:textoExtracto "No hay que hacer nada."@es ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Operacion_TMOPERATION_3
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION 3"@es ;
    ex:identificador "3" ;
    ex:textoExtracto "Poner en el cabezal una herramienta de tierra."@es ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Operacion_TMOPERATION_4
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION 4"@es ;
    ex:identificador "4" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en tierra."@es ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Operacion_TMOPERATION_8
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION 8"@es ;
    ex:identificador "8" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra."@es ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Herramienta_T7
    a ex:Herramienta ;
    rdfs:label "Herramienta T7"@es ;
    ex:identificador "T7" ;
    ex:textoExtracto "las herramientas T7 y T8 son de tierra."@es .

ex:Herramienta_T8
    a ex:Herramienta ;
    rdfs:label "Herramienta T8"@es ;
    ex:identificador "T8" ;
    ex:textoExtracto "las herramientas T7 y T8 son de tierra."@es .

ex:Sistema_GestorHerramientas
    a ex:Sistema ;
    rdfs:label "Gestor de herramientas"@es ;
    ex:textoExtracto "Operaciones válidas del gestor de herramientas para este almacén."@es ;
    ex:tieneComponente ex:Herramienta_T7, ex:Herramienta_T8 ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .