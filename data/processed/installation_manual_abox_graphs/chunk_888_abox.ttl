@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ContadorActivoDuranteElMecanizado a ns1:Parametro ;
    rdfs:label "Contador activo durante el mecanizado" ;
    ns1:identificador "PLC.TIMER" ;
    ns1:textoExtracto "PRG AUTOMAT AND INCYCLE = TIMERON Contador activo durante el mecanizado. ()= CNCRD (PLC.TIMER, R300, M12) El registro R300 muestra el valor del contador." .

ns1:InicializaElContadorA0TrasElEncendido a ns1:Parametro ;
    rdfs:label "Inicializa el contador a 0 tras el encendido" ;
    ns1:identificador "CY1" ;
    ns1:textoExtracto "CY1 ()= MOV 0 R100 ()= CNCWR (R100, PLC.TIMER, M11) Inicializa el contador a 0 tras el encendido." .

ns1:RegistroR300 a ns1:Parametro ;
    rdfs:label "El registro R300 muestra el valor del contador" ;
    ns1:identificador "R300" ;
    ns1:textoExtracto "PRG AUTOMAT AND INCYCLE = TIMERON Contador activo durante el mecanizado. ()= CNCRD (PLC.TIMER, R300, M12) El registro R300 muestra el valor del contador." .

