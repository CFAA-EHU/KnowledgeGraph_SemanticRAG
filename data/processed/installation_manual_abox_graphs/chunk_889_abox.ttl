@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TMOPERATION_3 a ex:ModoOperacion ;
    ex:identificador "TMOPERATION = 3" ;
    ex:textoExtracto "Poner en el cabezal una herramienta de tierra. La secuencia de esta operación es la siguiente. 1 Tras finalizar la operación, activar la marca GRTOSPDL." .

ex:TMOPERATION_4 a ex:ModoOperacion ;
    ex:identificador "TMOPERATION = 4" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en tierra. La secuencia de esta operación es la siguiente. 1 Tras finalizar la operación, activar la marca SPDLTOGR." .

ex:TMOPERATION_8 a ex:ModoOperacion ;
    ex:identificador "TMOPERATION = 8" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra. La secuencia de esta operación es la siguiente. 1 Dejar la herramienta del cabezal en tierra y activar la marca SPDLTOGR. 2 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

ex:GRTOSPDL a ex:Parametro ;
    ex:identificador "GRTOSPDL" ;
    ex:textoExtracto "activar la marca GRTOSPDL" .

ex:SPDLTOGR a ex:Parametro ;
    ex:identificador "SPDLTOGR" ;
    ex:textoExtracto "activar la marca SPDLTOGR" .