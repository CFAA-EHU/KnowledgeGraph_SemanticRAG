@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
ex:TMOPERATION a ex:Parametro ;
    ex:textoExtracto "el registro TMOPERATION" ;
    ex:identificador "TMOPERATION" .

ex:T a ex:ModoOperacion ;
    ex:textoExtracto "la función T" ;
    ex:identificador "T" .

ex:GRTOSPDL a ex:ModoOperacion ;
    ex:textoExtracto "SET GRTOSPDL" ;
    ex:identificador "GRTOSPDL" .

ex:SPDLTOGR a ex:ModoOperacion ;
    ex:textoExtracto "SET SPDLTOGR" ;
    ex:identificador "SPDLTOGR" .

ex:TMOPSTROBE a ex:Sensor ;
    ex:textoExtracto "DFU TMOPSTROBE" ;
    ex:identificador "TMOPSTROBE" .

ex:DFU a ex:AccionProhibida ;
    ex:textoExtracto "DFU" ;
    ex:identificador "DFU" .

ex:TareaCambioHerramienta a ex:TareaMantenimiento ;
    ex:textoExtracto "petición de cambio de herramienta" .

ex:PLC a ex:Sistema ;
    ex:textoExtracto "El PLC" ;
    ex:identificador "PLC" .

ex:Gestor a ex:Personal ;
    ex:textoExtracto "El gestor" ;
    ex:identificador "gestor" .