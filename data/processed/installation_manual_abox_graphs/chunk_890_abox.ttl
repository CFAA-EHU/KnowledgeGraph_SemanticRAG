@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_b51a989ba1 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El funcionamiento de esta marca depende de cómo esté definido el parámetro RAPIDEN." .

ns1:Parametro_0c4eae3f15 a ns1:Parametro ;
    rdfs:label "Marca para habilitar el avance rápido durante la ejecución de un programa" ;
    ns1:identificador "EXRAPID" ;
    ns1:textoExtracto "Si el PLC activa esta marca, el canal del CNC habilita el avance rápido durante la ejecución de un programa." .

ns1:Parametro_5c21c62d68 a ns1:Parametro ;
    rdfs:label "Marca para habilitar el avance rápido en el canal 1" ;
    ns1:identificador "EXRAPIDC1" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. EXRAPIDC1 (también se puede programar como EXRAPID)" .

ns1:Parametro_ab31958752 a ns1:Parametro ;
    rdfs:label "Marca para habilitar el avance rápido en el canal 2" ;
    ns1:identificador "EXRAPIDC2" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. EXRAPIDC2" .

ns1:Parametro_b5e6e5c1ce a ns1:Parametro ;
    rdfs:label "Marca para habilitar el avance rápido en el canal 4" ;
    ns1:identificador "EXRAPIDC4" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. EXRAPIDC4" .

ns1:Parametro_cf1eb34cf4 a ns1:Parametro ;
    rdfs:label "Marca para habilitar el avance rápido en el canal 3" ;
    ns1:identificador "EXRAPIDC3" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. EXRAPIDC3" .

ns1:Parametro_fdb4869759 a ns1:Parametro ;
    rdfs:label "Marca para deshabilitar la tabla 1 de compensación cruzada" ;
    ns1:identificador "DISCROSS1" ;
    ns1:textoExtracto "DISCROSS1 es para la tabla 1, DISCROSS2 para la tabla 2 y así sucesivamente." .

