@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:AlmacenTorreta891 a ex:Maquina ;
    rdfs:label "almacén tipo torreta"@es ;
    ex:textoExtracto "Es el almacén típico de torno."@es .

ex:GestorAlmacenTorreta891 a ex:Componente ;
    rdfs:label "gestor"@es ;
    ex:textoExtracto "Habitualmente, en este tipo de almacén la comunicación entre el gestor y el PLC se configura para que se realice en una única fase"@es .

ex:PLCAlmacenTorreta891 a ex:Componente ;
    rdfs:label "PLC"@es ;
    ex:textoExtracto "la comunicación entre el gestor y el PLC se configura para que se realice en una única fase"@es .

ex:FuncionTAlmacenTorreta891 a ex:Parametro ;
    rdfs:label "función T"@es ;
    ex:textoExtracto "la comunicación entre el gestor y el PLC se configura para que se realice en una única fase, con la ejecución de la función T"@es .

ex:FuncionM06AlmacenTorreta891 a ex:Parametro ;
    rdfs:label "función M06"@es ;
    ex:textoExtracto "Se recomienda que la rutina asociada a T incluya la función M06."@es .

ex:CNCAlmacenTorreta891 a ex:Componente ;
    rdfs:label "CNC"@es ;
    ex:textoExtracto "Cuando el CNC selecciona una herramienta"@es .

ex:SubrutinaTAlmacenTorreta891 a ex:TareaMantenimiento ;
    rdfs:label "subrutina asociada a T"@es ;
    ex:textoExtracto "Si la subrutina asociada a T no incluye la función M06, cuando el CNC selecciona una herramienta, internamente ejecuta un bloque T# M6 para ejecutar el cambio."@es .