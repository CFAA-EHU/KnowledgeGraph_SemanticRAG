ns1:Parametro_1982096ecc a ns1:Parametro ;
    rdfs:label "Marca para abortar comando CNCEX en el canal del CNC" ;
    ns1:identificador "PLCABORT" ;
    ns1:textoExtracto "PLCABORT Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes." .

