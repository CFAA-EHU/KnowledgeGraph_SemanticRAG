@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:AlmacenTipoTorreta a ex:Sistema ;
    rdfs:label "almacén tipo torreta"@es ;
    ex:textoExtracto "Almacén tipo torreta."@es ;
    ex:compuestoPor ex:GestorCambioHerramienta, ex:PLC, ex:CNC ;
    ex:tieneComponente ex:BrazoCambiador, ex:GiroAlmacen, ex:DesplazamientoAlmacen .

ex:GestorCambioHerramienta a ex:Sistema ;
    rdfs:label "gestor de cambio de herramienta"@es ;
    ex:textoExtracto "El gestor envía una orden al PLC para que seleccione la próxima herramienta en el almacén."@es, "El gestor envía una orden al PLC para efectuar el cambio."@es .

ex:PLC a ex:ComponenteElectrico ;
    rdfs:label "PLC"@es ;
    ex:textoExtracto "El gestor envía una orden al PLC para que seleccione la próxima herramienta en el almacén."@es, "El gestor envía una orden al PLC para efectuar el cambio."@es .

ex:CNC a ex:ComponenteElectrico ;
    rdfs:label "CNC"@es ;
    ex:textoExtracto "El CNC ejecuta la función T y la subrutina el bloque M06."@es, "El CNC genera internamente un bloque T# M06."@es, "El CNC espera a que el gestor de por finalizada la operación para continuar con la ejecución del programa."@es .

ex:BrazoCambiador a ex:ComponenteMecanico ;
    rdfs:label "brazo cambiador"@es ;
    ex:textoExtracto "Utilizar funciones auxiliares para gobernar desde la rutina M06 los desplazamientos de los distintos dispositivos (giro almacén, desplazamiento almacén, brazo cambiador, etc.)."@es .

ex:GiroAlmacen a ex:ComponenteMecanico ;
    rdfs:label "giro almacén"@es ;
    ex:textoExtracto "Utilizar funciones auxiliares para gobernar desde la rutina M06 los desplazamientos de los distintos dispositivos (giro almacén, desplazamiento almacén, brazo cambiador, etc.)."@es .

ex:DesplazamientoAlmacen a ex:ComponenteMecanico ;
    rdfs:label "desplazamiento almacén"@es ;
    ex:textoExtracto "Utilizar funciones auxiliares para gobernar desde la rutina M06 los desplazamientos de los distintos dispositivos (giro almacén, desplazamiento almacén, brazo cambiador, etc.)."@es .