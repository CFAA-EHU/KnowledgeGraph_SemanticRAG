@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_OperacionesGestorHerramientas a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de operaciones válidas del gestor de herramientas"@es ;
    ex:textoExtracto "Operaciones válidas del gestor de herramientas para este almacén. Las operaciones posibles en este tipo de almacén son las siguientes."@es ;
    ex:ilustradoEn ex:Pagina_484_485 .

ex:Operacion_TMOPERATION_0
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION = 0"@es ;
    ex:textoExtracto "0 | No hay que hacer nada."@es ;
    ex:identificador "0" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Operacion_TMOPERATION_1
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION = 1"@es ;
    ex:textoExtracto "1 | Asumir la herramienta actual como herramienta activa."@es ;
    ex:identificador "1" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Operacion_TMOPERATION_3
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION = 3"@es ;
    ex:textoExtracto "3 | Poner en el cabezal una herramienta de tierra."@es ;
    ex:identificador "3" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Operacion_TMOPERATION_4
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION = 4"@es ;
    ex:textoExtracto "4 | Dejar la herramienta del cabezal en tierra."@es ;
    ex:identificador "4" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Operacion_TMOPERATION_9
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION = 9"@es ;
    ex:textoExtracto "9 | Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal."@es ;
    ex:identificador "9" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Operacion_TMOPERATION_10
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION = 10"@es ;
    ex:textoExtracto "10 | Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal."@es ;
    ex:identificador "10" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Operacion_TMOPERATION_11
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION = 11"@es ;
    ex:textoExtracto "11 | Orientar la torreta."@es ;
    ex:identificador "11" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Operacion_TMOPERATION_15
    a ex:ModoOperacion ;
    rdfs:label "TMOPERATION = 15"@es ;
    ex:textoExtracto "15 | Seleccionar una posición de la torreta."@es ;
    ex:identificador "15" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Parametro_TAKEPOS
    a ex:Parametro ;
    rdfs:label "TAKEPOS"@es ;
    ex:textoExtracto "Las señales TAKEPOS y LEAVEPOS pueden tomar los siguientes valores."@es ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Parametro_LEAVEPOS
    a ex:Parametro ;
    rdfs:label "LEAVEPOS"@es ;
    ex:textoExtracto "Las señales TAKEPOS y LEAVEPOS pueden tomar los siguientes valores."@es ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Parametro_NEXTPOS
    a ex:Parametro ;
    rdfs:label "NEXTPOS"@es ;
    ex:textoExtracto "En un posicionamiento absoluto este registro indica la posición a alcanzar y en un posicionamiento relativo indica el número de posiciones a girar."@es ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Valor_TAKEPOS_0
    a ex:ModoOperacion ;
    rdfs:label "TAKEPOS = 0"@es ;
    ex:textoExtracto "Este registro tomará valor ꞏ0ꞏ si es un posicionamiento absoluto."@es ;
    ex:valor "0" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Valor_TAKEPOS_1
    a ex:ModoOperacion ;
    rdfs:label "TAKEPOS = 1"@es ;
    ex:textoExtracto "valor ꞏ1ꞏ si es un posicionamiento relativo."@es ;
    ex:valor "1" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Valor_LEAVEPOS_0
    a ex:ModoOperacion ;
    rdfs:label "LEAVEPOS = 0"@es ;
    ex:textoExtracto "valor ꞏ0ꞏ si es un posicionamiento relativo positivo."@es ;
    ex:valor "0" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Valor_LEAVEPOS_1
    a ex:ModoOperacion ;
    rdfs:label "LEAVEPOS = 1"@es ;
    ex:textoExtracto "valor ꞏ1ꞏ si es un posicionamiento relativo negativo."@es ;
    ex:valor "1" ;
    ex:documentadoEn ex:Tabla_OperacionesGestorHerramientas .

ex:Pagina_484_485
    a ex:Pagina ;
    rdfs:label "Páginas 484-485"@es ;
    ex:textoExtracto "Sección 7.7.1 Operaciones válidas y marcas que activa el PLC con cada una de ellas."@es .