@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ModoOperacionVolante a ns1:ModoOperacion ;
    rdfs:label "modo volante" ;
    ns1:textoExtracto "La selección de ejes se anula al salir del modo volante con el selector de movimientos y tras un reset." .

ns1:SeleccionDeEjesEnModoVolante a ns1:AccionProhibida ;
    rdfs:label "Selección de ejes en modo volante" ;
    ns1:textoExtracto "Si no hay ningún eje seleccionado, selecciona el primer eje que se está visualizando. Si hay un eje seleccionado, selecciona el siguiente; si el eje seleccionado es el último, vuelve a seleccionar el primero." .

