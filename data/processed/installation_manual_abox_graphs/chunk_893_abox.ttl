@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoOperacion_0 a ex:ModoOperacion ;
    rdfs:label "0" ;
    ex:textoExtracto "No hay que hacer nada." ;
    ex:identificador "TMOPERATION 0" .

ex:ModoOperacion_1 a ex:ModoOperacion ;
    rdfs:label "1" ;
    ex:textoExtracto "Asumir la herramienta actual como herramienta activa." ;
    ex:identificador "TMOPERATION 1" .

ex:ModoOperacion_3 a ex:ModoOperacion ;
    rdfs:label "3" ;
    ex:textoExtracto "Poner en el cabezal una herramienta de tierra." ;
    ex:identificador "TMOPERATION 3" .

ex:ModoOperacion_4 a ex:ModoOperacion ;
    rdfs:label "4" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en tierra." ;
    ex:identificador "TMOPERATION 4" .

ex:ModoOperacion_9 a ex:ModoOperacion ;
    rdfs:label "9" ;
    ex:textoExtracto "Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal." ;
    ex:identificador "TMOPERATION 9" .

ex:ModoOperacion_10 a ex:ModoOperacion ;
    rdfs:label "10" ;
    ex:textoExtracto "Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal." ;
    ex:identificador "TMOPERATION 10" .

ex:ModoOperacion_11 a ex:ModoOperacion ;
    rdfs:label "11" ;
    ex:textoExtracto "Orientar la torreta." ;
    ex:identificador "TMOPERATION 11" .

ex:ModoOperacion_15 a ex:ModoOperacion ;
    rdfs:label "15" ;
    ex:textoExtracto "Seleccionar una posición de la torreta." ;
    ex:identificador "TMOPERATION 15" .

ex:Parametro_TAKEPOS_0 a ex:Parametro ;
    rdfs:label "TAKEPOS 0" ;
    ex:textoExtracto "Este registro tomará valor ꞏ0ꞏ si es un posicionamiento absoluto" ;
    ex:valor "0" .

ex:Parametro_TAKEPOS_1 a ex:Parametro ;
    rdfs:label "TAKEPOS 1" ;
    ex:textoExtracto "Este registro tomará valor ꞏ1ꞏ si es un posicionamiento relativo." ;
    ex:valor "1" .

ex:Parametro_LEAVEPOS_0 a ex:Parametro ;
    rdfs:label "LEAVEPOS 0" ;
    ex:textoExtracto "Este registro tomará valor ꞏ0ꞏ si es un posicionamiento relativo positivo" ;
    ex:valor "0" .

ex:Parametro_LEAVEPOS_1 a ex:Parametro ;
    rdfs:label "LEAVEPOS 1" ;
    ex:textoExtracto "Este registro tomará valor ꞏ1ꞏ si es un posicionamiento relativo negativo." ;
    ex:valor "1" .

ex:Parametro_NEXTPOS a ex:Parametro ;
    rdfs:label "NEXTPOS" ;
    ex:textoExtracto "En un posicionamiento absoluto este registro indica la posición a alcanzar y en un posicionamiento relativo indica el número de posiciones a girar." .

ex:Tabla_Resumen_Operaciones a ex:Tabla ;
    ex:textoExtracto "A continuación se muestra una tabla resumen de los valores TAKEPOS y LEAVEPOS que utiliza el gestor en cada una de las operaciones, así como las marcas que debe activar el PLC al finalizar cada operación." ;
    ex:compuestoPor ex:ModoOperacion_0, ex:ModoOperacion_1, ex:ModoOperacion_3, ex:ModoOperacion_4, ex:ModoOperacion_9, ex:ModoOperacion_10, ex:ModoOperacion_11, ex:ModoOperacion_15, ex:Parametro_TAKEPOS_0, ex:Parametro_TAKEPOS_1, ex:Parametro_LEAVEPOS_0, ex:Parametro_LEAVEPOS_1, ex:Parametro_NEXTPOS .