@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ConmutadorAddress a ns1:ComponenteElectrico ;
    rdfs:label "Conmutador Address" ;
    ns1:textoExtracto "El orden de los elementos dentro del bus CAN lo determina el conmutador \"Address\"." .

ns1:Parametro_2a8b724426 a ns1:Parametro ;
    rdfs:label "Marca NEXTMPGAXIS" ;
    ns1:identificador "NEXTMPGAXIS" ;
    ns1:textoExtracto "Lo habitual en estos casos es conectar el pulsador del volante a una entrada digital, que será la encargada de gestionar la marca NEXTMPGAXIS." .

ns1:Parametro_99a90f8aa9 a ns1:Parametro ;
    rdfs:label "Marca PANELOFF2" ;
    ns1:identificador "PANELOFF2" ;
    ns1:textoExtracto "La marca PANELOFF2 deshabilita el segundo del bus." .

ns1:Parametro_de9a76597c a ns1:Parametro ;
    rdfs:label "Marca PANELOFF1" ;
    ns1:identificador "PANELOFF1" ;
    ns1:textoExtracto "La marca PANELOFF1 deshabilita el primero del bus." .

