@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SistemaControlCNC a ex:Sistema ;
    ex:textoExtracto "El siguiente ejemplo muestra, suponiendo que no hay herramienta en el cabezal, las funciones que ejecuta el CNC, los valores que envía el gestor al PLC en cada una de las operaciones y las marcas que debe activar el PLC en cada caso." ;
    ex:compuestoPor ex:AlmacenHerramientasNoRandom, ex:HerramientaT7 .

ex:AlmacenHerramientasNoRandom a ex:Componente ;
    ex:textoExtracto "El almacén es no-random, cada herramienta ocupa la posición de su mismo número" .

ex:HerramientaT7 a ex:PiezaRecambio ;
    ex:identificador "T7" ;
    ex:textoExtracto "la herramienta T7 es de tierra" .