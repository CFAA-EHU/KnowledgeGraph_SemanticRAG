@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PanelJog a ns1:ComponenteElectrico ;
    rdfs:label "Panel de jog" ;
    ns1:identificador "PANELOFF1" ;
    ns1:textoExtracto "Address 2 Panel de jog" .

ns1:SistemaCNC a ns1:Sistema ;
    rdfs:label "CNC" ;
    ns1:textoExtracto "Address 0 CNC" .

ns1:TecladoConPanelJog a ns1:ComponenteElectrico ;
    rdfs:label "Teclado + Panel de jog" ;
    ns1:identificador "PANELOFF2" ;
    ns1:textoExtracto "Address 5 Teclado + Panel de jog" .

