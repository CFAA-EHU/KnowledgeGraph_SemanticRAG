@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Valor0 rdfs:label "0" ;
    a ex:Parametro ;
    ex:textoExtracto "0 | No hay que hacer nada." ;
    ex:valor "0" .

ex:ValorNumeral rdfs:label "#" ;
    a ex:Parametro ;
    ex:textoExtracto "# | Posición en el almacén." ;
    ex:valor "#" .

ex:ValorMenos4 rdfs:label "-4" ;
    a ex:Parametro ;
    ex:textoExtracto "-4 | Herramienta de tierra." ;
    ex:valor "-4" .