@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RegistroParaSincronizacionDeCanalesYCabezales a ns1:Parametro ;
    rdfs:label "Registro para sincronización de canales y cabezales" ;
    ns1:identificador "SYNC" ;
    ns1:textoExtracto "Este registro se utiliza cuando desde un canal se desea utilizar un cabezal determinado a efectos de sincronización, aunque el cabezal se encuentre en otro canal." .

ns1:RegistroParaSincronizacionDelCanal1 a ns1:Parametro ;
    rdfs:label "Registro para sincronización del canal 1" ;
    ns1:identificador "SYNC1" ;
    ns1:textoExtracto "Este registro se utiliza cuando desde un canal se desea utilizar un cabezal determinado a efectos de sincronización, aunque el cabezal se encuentre en otro canal." .

ns1:RegistroParaSincronizacionDelCanal2 a ns1:Parametro ;
    rdfs:label "Registro para sincronización del canal 2" ;
    ns1:identificador "SYNC2" ;
    ns1:textoExtracto "Este registro se utiliza cuando desde un canal se desea utilizar un cabezal determinado a efectos de sincronización, aunque el cabezal se encuentre en otro canal." .

ns1:RegistroParaSincronizacionDelCanal3 a ns1:Parametro ;
    rdfs:label "Registro para sincronización del canal 3" ;
    ns1:identificador "SYNC3" ;
    ns1:textoExtracto "Este registro se utiliza cuando desde un canal se desea utilizar un cabezal determinado a efectos de sincronización, aunque el cabezal se encuentre en otro canal." .

ns1:RegistroParaSincronizacionDelCanal4 a ns1:Parametro ;
    rdfs:label "Registro para sincronización del canal 4" ;
    ns1:identificador "SYNC4" ;
    ns1:textoExtracto "Este registro se utiliza cuando desde un canal se desea utilizar un cabezal determinado a efectos de sincronización, aunque el cabezal se encuentre en otro canal." .

ns1:SecuenciaDeApagadoDelCNC a ns1:Parametro ;
    rdfs:label "Secuencia de apagado del CNC" ;
    ns1:identificador "CNCOFF" ;
    ns1:textoExtracto "Si el PLC pone esta marca a (=1) comienza la secuencia de apagado del CNC." .

