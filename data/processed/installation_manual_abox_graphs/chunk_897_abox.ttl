@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_6f6ce54e6a a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC evaluará el contenido de este registro al comienzo de bloque." .

ns1:ContenidoDelRegistroSYNC a ns1:Parametro ;
    rdfs:label "Contenido del registro SYNC" ;
    ns1:identificador "SYNC" ;
    ns1:textoExtracto "El registro SYNC tomará valores de ꞏ1ꞏ a ꞏ4ꞏ; si se asigna valor ꞏ0ꞏ, se utilizará el cabezal master del canal." .

ns1:Parametro_3c685f9753 a ns1:Parametro ;
    rdfs:label "Marca RETRACE para el canal 4" ;
    ns1:identificador "RETRACEC4" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. RETRACEC1 RETRACEC2 RETRACEC3 RETRACEC4" .

ns1:Parametro_53e23ecf13 a ns1:Parametro ;
    rdfs:label "Marca RETRACE para el canal 3" ;
    ns1:identificador "RETRACEC3" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. RETRACEC1 RETRACEC2 RETRACEC3 RETRACEC4" .

ns1:Parametro_b062770781 a ns1:Parametro ;
    rdfs:label "Marca RETRACE para el canal 1" ;
    ns1:identificador "RETRACEC1" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. RETRACEC1 RETRACEC2 RETRACEC3 RETRACEC4" .

ns1:Parametro_e74ae7d7a0 a ns1:Parametro ;
    rdfs:label "Marca RETRACE para el canal 2" ;
    ns1:identificador "RETRACEC2" ;
    ns1:textoExtracto "Los mnemónicos para cada canal son los siguientes. RETRACEC1 RETRACEC2 RETRACEC3 RETRACEC4" .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Para ello, el PLC indica en el registro SYNC del canal el cabezal que deberá utilizarse, exclusivamente a efectos de sincronización." .

