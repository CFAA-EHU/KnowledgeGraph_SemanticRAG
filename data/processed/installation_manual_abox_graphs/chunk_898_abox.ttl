@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:MZROT a ex:ModoOperacion ;
    ex:textoExtracto "activar la marca MZROT" .

ex:TMOPERATION a ex:Parametro ;
    ex:textoExtracto "TMOPERATION = 15" .

ex:TAKEPOS a ex:Parametro ;
    ex:textoExtracto "TAKEPOS Este registro tomará valor ꞏ0ꞏ si es un posicionamiento absoluto y valor ꞏ1ꞏ si es un posicionamiento relativo." .

ex:LEAVEPOS a ex:Parametro ;
    ex:textoExtracto "LEAVEPOS Este registro tomará valor ꞏ0ꞏ si es un posicionamiento relativo positivo y valor ꞏ1ꞏ si es un posicionamiento relativo negativo." .

ex:NEXTPOS a ex:Parametro ;
    ex:textoExtracto "NEXTPOS En un posicionamiento absoluto este registro indica la posición a alcanzar y en un posicionamiento relativo indica el número de posiciones a girar." .