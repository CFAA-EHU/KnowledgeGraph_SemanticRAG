@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:NumeroMaximoDeBloquesAEjecutarEnRetrace a ns1:Parametro ;
    rdfs:label "Número máximo de bloques a ejecutar en retrace" ;
    ns1:identificador "NRETBLK" ;
    ns1:textoExtracto "El número máximo de bloques a ejecutar en retrace lo define el parámetro máquina NRETBLK." .

ns1:Parametro_0ebef2bfe9 a ns1:Parametro ;
    rdfs:label "Marca que finaliza la función RETRACE" ;
    ns1:identificador "marca" ;
    ns1:textoExtracto "Si el PLC pone a (=0) esta marca, finaliza la función RETRACE." .

