@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:M1107 a ex:Sensor ;
    rdfs:label "M1107" ;
    ex:textoExtracto "Marca. | M1107 | SPDLTOGR | La herramienta se ha llevado del cabezal a tierra." .

ex:M1108 a ex:Sensor ;
    rdfs:label "M1108" ;
    ex:textoExtracto "Marca. | M1108 | GRTOSPDL | La herramienta se ha llevado de tierra al cabezal." .

ex:M1109 a ex:Sensor ;
    rdfs:label "M1109" ;
    ex:textoExtracto "Marca. | M1109 | MZTOSPDL | Asumir la herramienta actual como herramienta activa." .

ex:M1110 a ex:Sensor ;
    rdfs:label "M1110" ;
    ex:textoExtracto "Marca. | M1110 | SPDLTOGR | Asumir la herramienta actual como herramienta activa." .

ex:M1111 a ex:Sensor ;
    rdfs:label "M1111" ;
    ex:textoExtracto "Marca. | M1111 | MZROT | Marca que indica que ya ha girado el almacén." .

ex:M109 a ex:Sensor ;
    rdfs:label "M109" ;
    ex:textoExtracto "Función. | M109 | Seleccionar en el almacén la posición que indica TAKEPOS y poner la herramienta en el cabezal." .

ex:M110 a ex:Sensor ;
    rdfs:label "M110" ;
    ex:textoExtracto "Función. | M110 | Seleccionar en el almacén la posición que indica LEAVEPOS y dejar la herramienta del cabezal." .