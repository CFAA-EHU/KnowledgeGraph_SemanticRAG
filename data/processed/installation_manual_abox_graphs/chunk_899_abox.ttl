@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_13c5304119 a ns1:Parametro ;
    rdfs:label "Marca RETRAEND" ;
    ns1:textoExtracto "canal del CNC pone a (=1) la marca RETRAEND." .

ns1:Parametro_37bccba35c a ns1:Parametro ;
    rdfs:label "Parámetro máquina RETRACAC" ;
    ns1:textoExtracto "La función retrace debe estar habilitada en el parámetro máquina RETRACAC." .

ns1:Parametro_62eff48a9c a ns1:Parametro ;
    rdfs:label "Marca INHIBITMPG2" ;
    ns1:textoExtracto "La marca INHIBITMPG2 el segundo y así sucesivamente." .

ns1:Parametro_894cc8863c a ns1:Parametro ;
    rdfs:label "Marca INHIBITMPG1" ;
    ns1:textoExtracto "Si el PLC activa una de estas marcas, se deshabilita el volante correspondiente. La marca INHIBITMPG1 deshabilita el primer volante." .

