@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_e3a66aebcb a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "En el arranque, el CNC siempre asume la configuración de teclados definida en los parámetros máquina." .

ns1:ConfiguracionDeTecladosParaElCanal1 a ns1:Parametro ;
    rdfs:label "Configuración de teclados para el canal 1" ;
    ns1:identificador "KEYBD1CH" ;
    ns1:textoExtracto "En el arranque, el CNC siempre asume la configuración de teclados definida en los parámetros máquina. Estos registros permiten modificar el comportamiento por defecto de los teclados respecto a los canales, definido en los parámetros máquina." .

ns1:ConfiguracionDeTecladosParaElCanal8 a ns1:Parametro ;
    rdfs:label "Configuración de teclados para el canal 8" ;
    ns1:identificador "KEYBD8CH" ;
    ns1:textoExtracto "En el arranque, el CNC siempre asume la configuración de teclados definida en los parámetros máquina. Estos registros permiten modificar el comportamiento por defecto de los teclados respecto a los canales, definido en los parámetros máquina." .

ns1:NumeroDeImpulsosEnviadosPorElVolanteDesdeElArranqueDelSistema_09d848f61d a ns1:Parametro ;
    rdfs:label "Número de impulsos enviados por el volante desde el arranque del sistema" ;
    ns1:identificador "G.HANDP" ;
    ns1:textoExtracto "Mientras el volante está inhibido, la variable asociada al volante no guarda los impulsos que envía el volante. ( V.)G.HANDP Número de impulsos enviados por el volante desde el arranque del sistema." .

