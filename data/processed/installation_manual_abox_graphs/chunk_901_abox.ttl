@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CompensacionVolumetricaParaElCanal1 a ns1:Parametro ;
    rdfs:label "Compensación volumétrica para el canal 1" ;
    ns1:identificador "VOLCOMP1" ;
    ns1:textoExtracto "Si el PLC activa una de estas marcas (cambio de 0 a 1), el CNC activa la compensación volumétrica correspondiente." .

ns1:CompensacionVolumetricaParaElCanal4 a ns1:Parametro ;
    rdfs:label "Compensación volumétrica para el canal 4" ;
    ns1:identificador "VOLCOMP4" ;
    ns1:textoExtracto "Si el PLC desactiva una de estas marcas (cambio de 1 a 0), el CNC desactiva la compensación volumétrica correspondiente." .

ns1:ConfiguracionDelPanelDeJogParaElCanal1 a ns1:Parametro ;
    rdfs:label "Configuración del panel de jog para el canal 1" ;
    ns1:identificador "KEYBD1CH" ;
    ns1:textoExtracto "0 - Configuración definida en los parámetros máquina." .

ns1:ConfiguracionDelPanelDeJogParaElCanal8 a ns1:Parametro ;
    rdfs:label "Configuración del panel de jog para el canal 8" ;
    ns1:identificador "KEYBD8CH" ;
    ns1:textoExtracto "FF - Panel de jog asignado al canal activo." .

