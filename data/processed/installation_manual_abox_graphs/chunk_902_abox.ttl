@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:RutinaM06_CNC
    a ex:ModoOperacion ;
    rdfs:label "Rutina M06 (Cambio de herramienta)"@es ;
    ex:textoExtracto """
    CNC en ejecución $SWITCH V.PLC.TMOPERATION; Analiza el tipo de operación.
    $CASE 1 ; Asumir la herramienta actual como herramienta activa.
    $CASE 3 ; Colocar la herramienta de tierra en el cabezal.
    $CASE 4 ; Dejar la herramienta del cabezal en tierra.
    $CASE 9 ; Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal.
    $CASE 10 ; Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal.
    $CASE 11 ; Orientar la torreta.
    """@es ;
    ex:identificador "M06" .

ex:Subrutina_SUB_MZ_TO_SPD
    a ex:TareaMantenimiento ;
    rdfs:label "SUB_MZ_TO_SPD (Traslado de almacén a cabezal)"@es ;
    ex:textoExtracto "LL SUB_MZ_TO_SPD ; [Asumir herramienta activa o poner herramienta del almacén en el cabezal]."@es .

ex:Subrutina_SUB_SPD_GMCHG
    a ex:TareaMantenimiento ;
    rdfs:label "SUB_SPD_GMCHG (Cambio manual de cabezal)"@es ;
    ex:textoExtracto "LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual."@es .

ex:Subrutina_SUB_GR_TO_SPD
    a ex:TareaMantenimiento ;
    rdfs:label "SUB_GR_TO_SPD (Colocar herramienta de tierra en cabezal)"@es ;
    ex:textoExtracto "LL SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal."@es .

ex:Subrutina_SUB_SPD_TO_GR
    a ex:TareaMantenimiento ;
    rdfs:label "SUB_SPD_TO_GR (Retirar herramienta del cabezal)"@es ;
    ex:textoExtracto "LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal."@es .

ex:Subrutina_SUB_SPD_AUTCHG
    a ex:TareaMantenimiento ;
    rdfs:label "SUB_SPD_AUTCHG (Cambio automático de cabezal)"@es ;
    ex:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático."@es .

ex:Subrutina_SUB_MZ_ROT
    a ex:TareaMantenimiento ;
    rdfs:label "SUB_MZ_ROT (Orientación de torreta)"@es ;
    ex:textoExtracto "LL SUB_MZ_ROT ; Orientar la torreta."@es .

ex:Variable_V.PLC.TMOPERATION
    a ex:Parametro ;
    rdfs:label "V.PLC.TMOPERATION (Tipo de operación)"@es ;
    ex:textoExtracto "$SWITCH V.PLC.TMOPERATION; Analiza el tipo de operación."@es .

ex:Variable_V.TM.MZWAIT
    a ex:Parametro ;
    rdfs:label "V.TM.MZWAIT (Espera del gestor del almacén)"@es ;
    ex:textoExtracto "$WHILE V.TM.MZWAIT == 1 ; Espera al gestor del almacén."@es .

ex:RutinaM06_CNC
    ex:tieneComponente ex:Subrutina_SUB_MZ_TO_SPD ,
                      ex:Subrutina_SUB_SPD_GMCHG ,
                      ex:Subrutina_SUB_GR_TO_SPD ,
                      ex:Subrutina_SUB_SPD_TO_GR ,
                      ex:Subrutina_SUB_SPD_AUTCHG ,
                      ex:Subrutina_SUB_MZ_ROT ;
    ex:monitoreaParametro ex:Variable_V.PLC.TMOPERATION ,
                         ex:Variable_V.TM.MZWAIT .