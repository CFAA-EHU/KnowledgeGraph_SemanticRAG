@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarLaCuartaCompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Activar la cuarta compensación volumétrica" ;
    ns1:identificador "VOLCOMP4" ;
    ns1:textoExtracto "Activar la cuarta compensación volumétrica (parámetro maquina VOLCOMP4)." .

ns1:ActivarLaPrimeraCompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Activar la primera compensación volumétrica" ;
    ns1:identificador "VOLCOMP1" ;
    ns1:textoExtracto "Activar la primera compensación volumétrica (parámetro maquina VOLCOMP1)." .

ns1:ActivarLaSegundaCompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Activar la segunda compensación volumétrica" ;
    ns1:identificador "VOLCOMP2" ;
    ns1:textoExtracto "Activar la segunda compensación volumétrica (parámetro maquina VOLCOMP2)." .

ns1:ActivarLaTerceraCompensacionVolumetrica a ns1:Parametro ;
    rdfs:label "Activar la tercera compensación volumétrica" ;
    ns1:identificador "VOLCOMP3" ;
    ns1:textoExtracto "Activar la tercera compensación volumétrica (parámetro maquina VOLCOMP3)." .

