@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_610e6dbe64 a ns1:Parametro ;
    rdfs:label "Marca que deshabilita los teclados CAN según la numeración lógica de los nodos, de menor a mayor" ;
    ns1:identificador "QWERTYOFF8" ;
    ns1:textoExtracto "Las marcas QWERTYOFF2 a QWERTYOFF8 actúan sobre el resto de teclados CAN, según la numeración lógica de los nodos, de menor a mayor." .

ns1:Parametro_813d3e9c72 a ns1:Parametro ;
    rdfs:label "Marca que activa los límites de seguridad para el avance en todos los ejes del sistema" ;
    ns1:identificador "FLIMITAC" ;
    ns1:textoExtracto "Si el PLC activa esta marca, el CNC activa los límites de seguridad para el avance (parámetro FLIMIT) en todos los ejes del sistema, durante la ejecución del bloque." .

ns1:Parametro_aec70d3978 a ns1:Parametro ;
    rdfs:label "Marca que controla los límites de seguridad para el avance por canal" ;
    ns1:identificador "FLIMITACCH" ;
    ns1:textoExtracto "Hay una marca para cada canal." .

ns1:Parametro_ead9925b42 a ns1:Parametro ;
    rdfs:label "Marca que deshabilita el teclado alfanumérico y las softkeys del monitor (interface USB) en el modelo 10K" ;
    ns1:identificador "QWERTYOFF1" ;
    ns1:textoExtracto "En el modelo 10K, esta marca afecta al teclado alfanumérico y las softkeys del monitor (interface USB)." .

