@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TMOPERATION_11 a ex:ModoOperacion ;
    ex:identificador "TMOPERATION=11" ;
    ex:textoExtracto "el gestor envía al PLC el código TMOPERATION=11" .

ex:MZROT a ex:Parametro ;
    ex:identificador "MZROT" ;
    ex:textoExtracto "Activar la marca MZROT para indicar al gestor que se ha finalizado la operación." .

ex:SPDLTOGR a ex:Parametro ;
    ex:identificador "SPDLTOGR" ;
    ex:textoExtracto "La herramienta se ha llevado del cabezal a tierra." .

ex:GRTOSPDL a ex:Parametro ;
    ex:identificador "GRTOSPDL" ;
    ex:textoExtracto "La herramienta se ha llevado de tierra al cabezal." .

ex:MZTOSPDL a ex:Parametro ;
    ex:identificador "MZTOSPDL" ;
    ex:textoExtracto "La herramienta se ha llevado del almacén al cabezal." .

ex:M1107 a ex:Parametro ;
    ex:identificador "M1107" ;
    ex:textoExtracto "DFU M1107 = SET SPDLTOGR DFD SPDLTOGR = RES M1107" .

ex:M1108 a ex:Parametro ;
    ex:identificador "M1108" ;
    ex:textoExtracto "DFU M1108 = SET GRTOSPDL DFD GRTOSPDL = RES M1108" .

ex:M1109 a ex:Parametro ;
    ex:identificador "M1109" ;
    ex:textoExtracto "DFU M1109 = SET MZTOSPDL DFD MZTOSPDL = RES M1109" .

ex:M1110 a ex:Parametro ;
    ex:identificador "M1110" ;
    ex:textoExtracto "DFU M1110 = SET SPDLTOGR DFD SPDLTOGR = RES M1110" .

ex:M1111 a ex:Parametro ;
    ex:identificador "M1111" ;
    ex:textoExtracto "DFU M1111 = SET MZROT DFD MZROT = RES M1111" .

ex:M06 a ex:ModoOperacion ;
    ex:identificador "M06" ;
    ex:textoExtracto "Cuando se ejecuta la función –M06– Cada vez que la rutina M06 finaliza una acción se lo indica al PLC para que active la marca correspondiente del gestor." .

ex:M109 a ex:TareaMantenimiento ;
    ex:identificador "M109" ;
    ex:textoExtracto "M109 Seleccionar en el almacén la posición que indica TAKEPOS y poner la herramienta en el cabezal." .

ex:M110 a ex:TareaMantenimiento ;
    ex:identificador "M110" ;
    ex:textoExtracto "M110 Seleccionar en el almacén la posición que indica LEAVEPOS y dejar la herramienta del cabezal." .

ex:TAKEPOS a ex:Parametro ;
    ex:identificador "TAKEPOS" ;
    ex:textoExtracto "Este registro indica la posición de almacén que ocupa la herramienta que hay que coger." .

ex:LEAVEPOS a ex:Parametro ;
    ex:identificador "LEAVEPOS" ;
    ex:textoExtracto "Este registro indica la posición de almacén en la que hay que dejar la herramienta." .

ex:senalEmergenciaGestor a ex:Parametro ;
    ex:identificador "Señal de emergencia del gestor" ;
    ex:textoExtracto "En determinadas operaciones hay que utilizar la información que pasa el gestor en los siguientes registros: ... Señal de emergencia del gestor." .