@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:LEAVEPOS a ex:Parametro ;
    ex:textoExtracto "Este registro indica la posición de almacén en la que hay que dejar la herramienta." ;
    rdfs:label "LEAVEPOS" .

ex:TAKEPOS a ex:Parametro ;
    ex:textoExtracto "Este registro indica la posición de almacén que ocupa la herramienta que hay que coger." ;
    rdfs:label "TAKEPOS" .

ex:TMINEM a ex:Parametro ;
    ex:textoExtracto "Señal de emergencia del gestor. Tratamiento de la señal de emergencia del gestor de herramientas. DFU B11KEYBD1 AND NOT TMINEM = SET SETTMEM DFU TMINEM = RES SETTMEM Si se pulsa la tecla USER12 se activa la emergencia. TMINEM = B11KEYLED1 Lámpara de la tecla USER12 iluminada cuando hay" ;
    rdfs:label "TMINEM" .

ex:USER12 a ex:Parametro ;
    ex:textoExtracto "Si se pulsa la tecla USER12 se activa la emergencia." ;
    rdfs:label "USER12" .

ex:B11KEYBD1 a ex:ComponenteElectrico ;
    ex:textoExtracto "DFU B11KEYBD1 AND NOT TMINEM = SET SETTMEM DFU TMINEM = RES SETTMEM" ;
    rdfs:label "B11KEYBD1" .

ex:B11KEYLED1 a ex:ComponenteElectrico ;
    ex:textoExtracto "TMINEM = B11KEYLED1 Lámpara de la tecla USER12 iluminada cuando hay" ;
    rdfs:label "B11KEYLED1" .

ex:SETTMEM a ex:Parametro ;
    ex:textoExtracto "DFU B11KEYBD1 AND NOT TMINEM = SET SETTMEM DFU TMINEM = RES SETTMEM" ;
    rdfs:label "SETTMEM" .