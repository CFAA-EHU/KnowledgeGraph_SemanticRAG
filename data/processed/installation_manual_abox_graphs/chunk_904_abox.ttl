@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LimiteDeAvanceParaCadaCanal a ns1:Parametro ;
    rdfs:label "Límite de avance para cada canal" ;
    ns1:identificador "FLIMITACCH" ;
    ns1:textoExtracto "Este parámetro no afecta a los roscados ni a los movimientos de eje independiente, que se ejecutan al avance programado." .

ns1:LimiteDeAvanceParaElCanal1 a ns1:Parametro ;
    rdfs:label "Límite de avance para el canal 1" ;
    ns1:identificador "FLIMITACCHC1" ;
    ns1:textoExtracto "FLIMITACCHC1 (también se puede programar como FLIMITACCH)" .

ns1:LimiteDeAvanceParaElCanal2 a ns1:Parametro ;
    rdfs:label "Límite de avance para el canal 2" ;
    ns1:identificador "FLIMITACCHC2" ;
    ns1:textoExtracto "FLIMITACCHC2" .

ns1:LimiteDeAvanceParaElCanal3 a ns1:Parametro ;
    rdfs:label "Límite de avance para el canal 3" ;
    ns1:identificador "FLIMITACCHC3" ;
    ns1:textoExtracto "FLIMITACCHC3" .

ns1:LimiteDeAvanceParaElCanal4 a ns1:Parametro ;
    rdfs:label "Límite de avance para el canal 4" ;
    ns1:identificador "FLIMITACCHC4" ;
    ns1:textoExtracto "FLIMITACCHC4" .

