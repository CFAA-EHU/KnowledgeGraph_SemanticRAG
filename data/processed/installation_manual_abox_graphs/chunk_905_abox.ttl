@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tecla_USER12
    a ex:ComponenteElectrico ;
    rdfs:label "Tecla USER12" ;
    ex:textoExtracto "Si se pulsa la tecla USER12 se activa la emergencia." ;
    ex:controla ex:SenalEmergencia_TMINEM .

ex:Tecla_USER13
    a ex:ComponenteElectrico ;
    rdfs:label "Tecla USER13" ;
    ex:textoExtracto "Si se pulsa la tecla USER13 se quita la emergencia." ;
    ex:controla ex:SenalEmergencia_TMINEM .

ex:LamparaTecla_USER12
    a ex:ComponenteElectrico ;
    rdfs:label "Lámpara de la tecla USER12" ;
    ex:textoExtracto "Lámpara de la tecla USER12 iluminada cuando hay emergencia." ;
    ex:monitoreaParametro ex:SenalEmergencia_TMINEM .

ex:SenalEmergencia_TMINEM
    a ex:Parametro ;
    rdfs:label "TMINEM" ;
    ex:identificador "TMINEM" ;
    ex:textoExtracto "TMINEM = B11KEYLED1" ;
    ex:valor "Señal de emergencia activa" .