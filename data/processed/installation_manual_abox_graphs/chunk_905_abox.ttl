@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:USER12 a ex:Sensor ;
    rdfs:label "USER12" ;
    ex:textoExtracto "Si se pulsa la tecla USER12 se activa la emergencia." .

ex:USER13 a ex:Sensor ;
    rdfs:label "USER13" ;
    ex:textoExtracto "Si se pulsa la tecla USER13 se quita la emergencia." .

ex:TMINEM a ex:Parametro ;
    rdfs:label "TMINEM" ;
    ex:textoExtracto "TMINEM = B11KEYLED1 Lámpara de la tecla USER12 iluminada cuando hay emergencia." .

ex:B11KEYLED1 a ex:ComponenteElectrico ;
    rdfs:label "B11KEYLED1" ;
    ex:textoExtracto "TMINEM = B11KEYLED1 Lámpara de la tecla USER12 iluminada cuando hay emergencia." .

ex:B11KEYBD1 a ex:ComponenteElectrico ;
    rdfs:label "B11KEYBD1" ;
    ex:textoExtracto "DFU B11KEYBD1 AND NOT TMINEM = SET SETTMEM DFU TMINEM = RES SETTMEM" .

ex:B12KEYBD1 a ex:ComponenteElectrico ;
    rdfs:label "B12KEYBD1" ;
    ex:textoExtracto "TMINEM AND DFU B12KEYBD1 = SET RESTMEM" .