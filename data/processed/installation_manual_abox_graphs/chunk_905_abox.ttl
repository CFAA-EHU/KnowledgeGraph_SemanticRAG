@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_d7880db2ac a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "el CNC activa los límites de seguridad para el avance (parámetro FLIMIT) en todos los ejes del canal, durante la ejecución del bloque." .

ns1:LimiteDeSeguridadDeLaVelocidad a ns1:Parametro ;
    rdfs:label "Límite de seguridad de la velocidad" ;
    ns1:identificador "SLIMIT" ;
    ns1:textoExtracto "el CNC activa los límites de seguridad para la velocidad (parámetro SLIMIT) en todos los cabezales del sistema, durante la ejecución del bloque actual." .

ns1:LimiteDeSeguridadDelAvance a ns1:Parametro ;
    rdfs:label "Límite de seguridad del avance" ;
    ns1:identificador "FLIMIT" ;
    ns1:textoExtracto "el CNC activa los límites de seguridad para el avance (parámetro FLIMIT) en todos los ejes del canal, durante la ejecución del bloque." .

ns1:Parametro_3cc0d1f482 a ns1:Parametro ;
    rdfs:label "Marca para límite de seguridad del avance en el canal 4" ;
    ns1:identificador "FLIMITACCHC4" ;
    ns1:textoExtracto "FLIMITACCHC4" .

ns1:Parametro_5c60c1370c a ns1:Parametro ;
    rdfs:label "Marca para límite de seguridad del avance en el canal 1" ;
    ns1:identificador "FLIMITACCHC1" ;
    ns1:textoExtracto "FLIMITACCHC1 (también se puede programar como FLIMITACCH)" .

ns1:Parametro_bc46163d15 a ns1:Parametro ;
    rdfs:label "Marca para límite de seguridad del avance en el canal 2" ;
    ns1:identificador "FLIMITACCHC2" ;
    ns1:textoExtracto "FLIMITACCHC2" .

ns1:Parametro_e4cc2aff3a a ns1:Parametro ;
    rdfs:label "Marca para límite de seguridad del avance en el canal 3" ;
    ns1:identificador "FLIMITACCHC3" ;
    ns1:textoExtracto "FLIMITACCHC3" .

ns1:Parametro_fac9f8c76c a ns1:Parametro ;
    rdfs:label "Marca para límite de seguridad de la velocidad" ;
    ns1:identificador "SLIMITAC" ;
    ns1:textoExtracto "Si el PLC activa esta marca, el CNC activa los límites de seguridad para la velocidad (parámetro SLIMIT) en todos los cabezales del sistema, durante la ejecución del bloque actual." .

