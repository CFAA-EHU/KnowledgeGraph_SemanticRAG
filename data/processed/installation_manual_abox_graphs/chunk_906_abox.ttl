@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_0079dcbefa a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:monitoreaParametro ns1:Parametro_c8e1032762 ;
    ns1:textoExtracto "Si el PLC desactiva esta marca, el CNC recupera la velocidad programada." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:controla ns1:Parametro_0a8cbac0da,
        ns1:Parametro_8126d673b2 ;
    ns1:textoExtracto "El PLC dispone de las siguientes marcas para poder deshabilitar la sonda temporalmente (por ejemplo, en un cambio de cabezal)." .

ns1:SondaDeLaEntrada1 a ns1:ComponenteElectrico ;
    rdfs:label "Sonda de la entrada 1" ;
    ns1:textoExtracto "La marca PT100OFF1 corresponde a la sonda de la entrada 1" .

ns1:SondaDeLaEntrada2 a ns1:ComponenteElectrico ;
    rdfs:label "Sonda de la entrada 2" ;
    ns1:textoExtracto "La marca PT100OFF2 corresponde a la sonda de la entrada 2" .

ns1:Parametro_0a8cbac0da a ns1:Parametro ;
    rdfs:label "Marca para deshabilitar temporalmente la sonda de la entrada 2" ;
    ns1:identificador "PT100OFF2" ;
    ns1:textoExtracto "La marca PT100OFF2 corresponde a la sonda de la entrada 2" .

ns1:Parametro_8126d673b2 a ns1:Parametro ;
    rdfs:label "Marca para deshabilitar temporalmente la sonda de la entrada 1" ;
    ns1:identificador "PT100OFF1" ;
    ns1:textoExtracto "La marca PT100OFF1 corresponde a la sonda de la entrada 1" .

ns1:Parametro_c8e1032762 a ns1:Parametro ;
    rdfs:label "Parámetro máquina que activa las entradas PT100" ;
    ns1:textoExtracto "Las entradas PT100 se activan desde los parámetros máquina." .

