@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:AlmacenSincronoSinBrazoCambiador_906 a ex:Sistema ;
    ex:textoExtracto "En un almacén síncrono sin brazo cambiador el almacén debe desplazarse hasta el cabezal para efectuar el cambio." ;
    ex:compuestoPor ex:CNC_906, ex:Gestor_906, ex:PLC_906, ex:FuncionT_906, ex:FuncionM06_906 .

ex:CNC_906 a ex:ComponenteElectrico ;
    ex:textoExtracto "El CNC ejecuta la función T, se lo indica al gestor." ;
    ex:textoExtracto "El CNC ejecuta la función M06, realiza una llamada a la rutina asociada." ;
    ex:textoExtracto "El CNC continúa con la ejecución del programa, no espera a que el gestor de por finalizada la operación." ;
    ex:textoExtracto "El CNC espera a que el gestor de por finalizada la operación para continuar con la ejecución del programa." .

ex:Gestor_906 a ex:ComponenteElectrico ;
    ex:textoExtracto "El gestor envía una orden al PLC para que seleccione la próxima herramienta en el almacén (si se puede)." ;
    ex:textoExtracto "El gestor envía una orden al PLC para efectuar el cambio." ;
    ex:textoExtracto "Se aconseja incluir la gestión del cambio de herramienta en la rutina asociada a M06 y dejar como labor del PLC el control de los dispositivos externos." .

ex:PLC_906 a ex:ComponenteElectrico ;
    ex:textoExtracto "El gestor envía una orden al PLC para que seleccione la próxima herramienta en el almacén (si se puede)." ;
    ex:textoExtracto "El gestor envía una orden al PLC para efectuar el cambio." ;
    ex:textoExtracto "Utilizar funciones auxiliares para gobernar desde la rutina M06 los desplazamientos de los distintos dispositivos (giro almacén, desplazamiento almacén, etc.)." .

ex:FuncionT_906 a ex:ModoOperacion ;
    ex:textoExtracto "la ejecución de la función T" ;
    ex:textoExtracto "Cuando el CNC ejecuta la función T, se lo indica al gestor." ;
    ex:textoExtracto "El gestor envía una orden al PLC para que seleccione la próxima herramienta en el almacén (si se puede)." ;
    ex:textoExtracto "El CNC continúa con la ejecución del programa, no espera a que el gestor de por finalizada la operación." .

ex:FuncionM06_906 a ex:ModoOperacion ;
    ex:textoExtracto "la ejecución de la función M06" ;
    ex:textoExtracto "Cuando el CNC ejecuta la función M06, realiza una llamada a la rutina asociada." ;
    ex:textoExtracto "Dentro de dicha rutina hay que volver a programar la función M06 para que el CNC indique al gestor que debe comenzar el cambio de herramienta." ;
    ex:textoExtracto "El gestor envía una orden al PLC para efectuar el cambio." ;
    ex:textoExtracto "El CNC espera a que el gestor de por finalizada la operación para continuar con la ejecución del programa." .