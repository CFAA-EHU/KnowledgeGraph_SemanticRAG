@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoOperacion_0 a ex:ModoOperacion ;
    rdfs:label "0" ;
    ex:identificador "0" ;
    ex:textoExtracto "No hay que hacer nada." ;
    ex:valor "0" .

ex:ModoOperacion_1 a ex:ModoOperacion ;
    rdfs:label "1" ;
    ex:identificador "1" ;
    ex:textoExtracto "Coger una herramienta del almacén y ponerla en el cabezal." ;
    ex:valor "1" .

ex:ModoOperacion_2 a ex:ModoOperacion ;
    rdfs:label "2" ;
    ex:identificador "2" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén." ;
    ex:valor "2" .

ex:ModoOperacion_3 a ex:ModoOperacion ;
    rdfs:label "3" ;
    ex:identificador "3" ;
    ex:textoExtracto "Poner en el cabezal una herramienta de tierra." ;
    ex:valor "3" .

ex:ModoOperacion_4 a ex:ModoOperacion ;
    rdfs:label "4" ;
    ex:identificador "4" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en tierra." ;
    ex:valor "4" .

ex:ModoOperacion_5 a ex:ModoOperacion ;
    rdfs:label "5" ;
    ex:identificador "5" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén." ;
    ex:valor "5" .

ex:ModoOperacion_6 a ex:ModoOperacion ;
    rdfs:label "6" ;
    ex:identificador "6" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger una herramienta de tierra." ;
    ex:valor "6" .

ex:ModoOperacion_7 a ex:ModoOperacion ;
    rdfs:label "7" ;
    ex:identificador "7" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en tierra y coger una herramienta del almacén." ;
    ex:valor "7" .

ex:ModoOperacion_8 a ex:ModoOperacion ;
    rdfs:label "8" ;
    ex:identificador "8" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra." ;
    ex:valor "8" .

ex:ModoOperacion_9 a ex:ModoOperacion ;
    rdfs:label "9" ;
    ex:identificador "9" ;
    ex:textoExtracto "Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal." ;
    ex:valor "9" .

ex:ModoOperacion_10 a ex:ModoOperacion ;
    rdfs:label "10" ;
    ex:identificador "10" ;
    ex:textoExtracto "Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal." ;
    ex:valor "10" .

ex:ModoOperacion_11 a ex:ModoOperacion ;
    rdfs:label "11" ;
    ex:identificador "11" ;
    ex:textoExtracto "Orientar el almacén." ;
    ex:valor "11" .

ex:ModoOperacion_12 a ex:ModoOperacion ;
    rdfs:label "12" ;
    ex:identificador "12" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén (como TMOPERATION=5). Es una operación optimizada, válida sólo cuando el almacén es random y la herramienta es especial." ;
    ex:valor "12" .

ex:ModoOperacion_13 a ex:ModoOperacion ;
    rdfs:label "13" ;
    ex:identificador "13" ;
    ex:textoExtracto "Orientar dos almacenes." ;
    ex:valor "13" .

ex:ModoOperacion_14 a ex:ModoOperacion ;
    rdfs:label "14" ;
    ex:identificador "14" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén." ;
    ex:valor "14" .

ex:ModoOperacion_0_TAKEPOS a ex:ModoOperacion ;
    rdfs:label "0" ;
    ex:identificador "0" ;
    ex:textoExtracto "No hay que hacer nada." ;
    ex:valor "0" .

ex:ModoOperacion_0_LEAVEPOS a ex:ModoOperacion ;
    rdfs:label "0" ;
    ex:identificador "0" ;
    ex:textoExtracto "No hay que hacer nada." ;
    ex:valor "0" .

ex:ModoOperacion_TAKEPOS a ex:ModoOperacion ;
    rdfs:label "#" ;
    ex:identificador "#" ;
    ex:textoExtracto "Posición en el almacén." ;
    ex:valor "#" .

ex:ModoOperacion_LEAVEPOS a ex:ModoOperacion ;
    rdfs:label "#" ;
    ex:identificador "#" ;
    ex:textoExtracto "Posición en el almacén." ;
    ex:valor "#" .