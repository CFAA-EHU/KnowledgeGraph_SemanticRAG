@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TAKEPOS a ex:Parametro ;
    rdfs:label "TAKEPOS" ;
    ex:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor." ;
    ex:valor "registros TAKEPOS y LEAVEPOS" .

ex:LEAVEPOS a ex:Parametro ;
    rdfs:label "LEAVEPOS" ;
    ex:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor." ;
    ex:valor "registros TAKEPOS y LEAVEPOS" .

ex:Tabla7_8_1 a ex:Tabla ;
    ex:textoExtracto "Valores | Valor | Significado |\n| --- | --- |\n| 0 | No hay que hacer nada. |\n| # | Posición en el almacén. |\n| -4 | Herramienta de tierra. |\n A continuación se muestra una tabla resumen de los valores TAKEPOS y LEAVEPOS que utiliza el gestor en cada una de las operaciones, así como las marcas que debe activar el PLC al finalizar cada operación." ;
    ex:compuestoPor ex:Valor0, ex:PosicionAlmacen, ex:HerramientaTierra .

ex:Valor0 a ex:Parametro ;
    rdfs:label "0" ;
    ex:textoExtracto "Valor | 0 | No hay que hacer nada." ;
    ex:valor "0" .

ex:PosicionAlmacen a ex:Parametro ;
    rdfs:label "#" ;
    ex:textoExtracto "Valor | # | Posición en el almacén." ;
    ex:valor "#" .

ex:HerramientaTierra a ex:Parametro ;
    rdfs:label "-4" ;
    ex:textoExtracto "Valor | -4 | Herramienta de tierra." ;
    ex:valor "-4" .