@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_Valores_TAKEPOS_LEAVEPOS a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de valores TAKEPOS y LEAVEPOS"@es ;
    ex:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor. [...] A continuación se muestra una tabla resumen de los valores TAKEPOS y LEAVEPOS que utiliza el gestor en cada una de las operaciones, así como las marcas que debe activar el PLC al finalizar cada operación."@es ;
    ex:documentadoEn ex:Pagina_493_494 .

ex:Parametro_TAKEPOS
    a ex:Parametro ;
    rdfs:label "TAKEPOS"@es ;
    ex:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor."@es ;
    ex:valor "0" , "#" , "-4" ;
    ex:documentadoEn ex:Tabla_Valores_TAKEPOS_LEAVEPOS .

ex:Parametro_LEAVEPOS
    a ex:Parametro ;
    rdfs:label "LEAVEPOS"@es ;
    ex:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor."@es ;
    ex:valor "0" , "#" , "-4" ;
    ex:documentadoEn ex:Tabla_Valores_TAKEPOS_LEAVEPOS .

ex:Valor_TAKEPOS_0
    a ex:Parametro ;
    rdfs:label "Valor TAKEPOS 0"@es ;
    ex:identificador "0" ;
    ex:textoExtracto "0 | No hay que hacer nada."@es ;
    ex:valor "0" ;
    ex:documentadoEn ex:Tabla_Valores_TAKEPOS_LEAVEPOS .

ex:Valor_TAKEPOS_HerramientaTierra
    a ex:Parametro ;
    rdfs:label "Valor TAKEPOS -4 (Herramienta de tierra)"@es ;
    ex:identificador "-4" ;
    ex:textoExtracto "-4 | Herramienta de tierra."@es ;
    ex:valor "-4" ;
    ex:documentadoEn ex:Tabla_Valores_TAKEPOS_LEAVEPOS .

ex:Valor_TAKEPOS_PosicionAlmacen
    a ex:Parametro ;
    rdfs:label "Valor TAKEPOS # (Posición en el almacén)"@es ;
    ex:identificador "#" ;
    ex:textoExtracto "# | Posición en el almacén."@es ;
    ex:valor "#" ;
    ex:documentadoEn ex:Tabla_Valores_TAKEPOS_LEAVEPOS .

ex:Pagina_493_494
    a ex:Pagina ;
    rdfs:label "Páginas 493-494"@es ;
    ex:identificador "493-494" ;
    ex:textoExtracto "Sección 7.8.1 Operaciones válidas y marcas que activa el PLC con cada una de ellas."@es .