@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_a400cebb30 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC ejecuta la subrutina con la historia actual del programa interrumpido (funciones G, avance, etc)." ;
    ns1:tieneComponente ns1:EjecucionDeSubrutinaCuandoNoHayProgramaEnEjecucion,
        ns1:HabilitacionDelPalpador1PorDefecto,
        ns1:HabilitacionDelPalpador2PorDefecto,
        ns1:ModoSeguroDelPalpador1,
        ns1:ModoSeguroDelPalpador2,
        ns1:SubrutinaDeInterrupcion1,
        ns1:SubrutinaDeInterrupcion2,
        ns1:SubrutinaDeInterrupcion3,
        ns1:SubrutinaDeInterrupcion4 .

ns1:EjecucionDeSubrutinaCuandoNoHayProgramaEnEjecucion a ns1:Parametro ;
    rdfs:label "Ejecución de subrutina cuando no hay programa en ejecución" ;
    ns1:identificador "SUBINTSTOP" ;
    ns1:textoExtracto "la ejecución de la subrutina depende del parámetro SUBINTSTOP." .

ns1:HabilitacionDelPalpador1PorDefecto a ns1:Parametro ;
    rdfs:label "Habilitación del palpador 1 por defecto" ;
    ns1:identificador "PROBE1ENA" ;
    ns1:textoExtracto "Estas marcas indican que el palpador está habilitado." .

ns1:HabilitacionDelPalpador2PorDefecto a ns1:Parametro ;
    rdfs:label "Habilitación del palpador 2 por defecto" ;
    ns1:identificador "PROBE2ENA" ;
    ns1:textoExtracto "Estas marcas indican que el palpador está habilitado." .

ns1:ModoSeguroDelPalpador1 a ns1:Parametro ;
    rdfs:label "Modo seguro del palpador 1" ;
    ns1:identificador "PROBE1MONIT" ;
    ns1:textoExtracto "Estas marcas están asociadas al modo seguro del palpador." .

ns1:ModoSeguroDelPalpador2 a ns1:Parametro ;
    rdfs:label "Modo seguro del palpador 2" ;
    ns1:identificador "PROBE2MONIT" ;
    ns1:textoExtracto "Estas marcas están asociadas al modo seguro del palpador." .

ns1:SubrutinaDeInterrupcion1 a ns1:Parametro ;
    rdfs:label "Subrutina de interrupción 1" ;
    ns1:identificador "INT1SUB" ;
    ns1:textoExtracto "asociada a los parámetros INT1SUB a INT4SUB." .

ns1:SubrutinaDeInterrupcion2 a ns1:Parametro ;
    rdfs:label "Subrutina de interrupción 2" ;
    ns1:identificador "INT2SUB" ;
    ns1:textoExtracto "asociada a los parámetros INT1SUB a INT4SUB." .

ns1:SubrutinaDeInterrupcion3 a ns1:Parametro ;
    rdfs:label "Subrutina de interrupción 3" ;
    ns1:identificador "INT3SUB" ;
    ns1:textoExtracto "asociada a los parámetros INT1SUB a INT4SUB." .

ns1:SubrutinaDeInterrupcion4 a ns1:Parametro ;
    rdfs:label "Subrutina de interrupción 4" ;
    ns1:identificador "INT4SUB" ;
    ns1:textoExtracto "asociada a los parámetros INT1SUB a INT4SUB." .

