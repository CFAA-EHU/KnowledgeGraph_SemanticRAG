@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:OperacionesAlmacen_7_8_2
    a ex:Sistema ;
    rdfs:label "Operaciones del almacén (7.8.2)" ;
    ex:textoExtracto "A continuación se muestra una descripción detallada de las operaciones válidas para este almacén. Para cada operación se indica cuales de las señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas, así como su significado. También aparece cuál es la secuencia a seguir para completar la operación." ;
    ex:tieneComponente ex:Senal_TAKEPOS, ex:Senal_LEAVEPOS, ex:Senal_NEXTPOS, ex:Senal_MZID .

ex:Senal_TAKEPOS
    a ex:ComponenteElectrico ;
    rdfs:label "TAKEPOS" ;
    ex:textoExtracto "señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas" ;
    ex:identificador "TAKEPOS" .

ex:Senal_LEAVEPOS
    a ex:ComponenteElectrico ;
    rdfs:label "LEAVEPOS" ;
    ex:textoExtracto "señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas" ;
    ex:identificador "LEAVEPOS" .

ex:Senal_NEXTPOS
    a ex:ComponenteElectrico ;
    rdfs:label "NEXTPOS" ;
    ex:textoExtracto "señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas" ;
    ex:identificador "NEXTPOS" .

ex:Senal_MZID
    a ex:ComponenteElectrico ;
    rdfs:label "MZID" ;
    ex:textoExtracto "señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas" ;
    ex:identificador "MZID" .