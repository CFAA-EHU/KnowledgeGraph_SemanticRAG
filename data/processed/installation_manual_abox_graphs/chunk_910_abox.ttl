@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:OperacionAlmacen_910 a ex:TareaMantenimiento ;
    ex:textoExtracto "A continuación se muestra una descripción detallada de las operaciones válidas para este almacén. Para cada operación se indica cuales de las señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas, así como su significado. También aparece cuál es la secuencia a seguir para completar la operación. Las señales TAKEPOS, LEAVEPOS y NEXTPOS pueden tomar los siguientes valores." ;
    ex:compuestoPor ex:SenalTAKEPOS_910, ex:SenalLEAVEPOS_910, ex:SenalNEXTPOS_910, ex:SenalMZID_910 .

ex:SenalTAKEPOS_910 a ex:Sensor ;
    ex:identificador "TAKEPOS" ;
    ex:textoExtracto "señales TAKEPOS, LEAVEPOS y NEXTPOS" .

ex:SenalLEAVEPOS_910 a ex:Sensor ;
    ex:identificador "LEAVEPOS" ;
    ex:textoExtracto "señales TAKEPOS, LEAVEPOS y NEXTPOS" .

ex:SenalNEXTPOS_910 a ex:Sensor ;
    ex:identificador "NEXTPOS" ;
    ex:textoExtracto "señales TAKEPOS, LEAVEPOS y NEXTPOS" .

ex:SenalMZID_910 a ex:Sensor ;
    ex:identificador "MZID" ;
    ex:textoExtracto "señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID" .