    rdfs:label "Marca para desactivar la opción FCAS (control de colisiones) del canal 1"@es ;
    ns1:identificador "COLLISIONOFFC1" ;
    ns1:textoExtracto "COLLISIONOFFC1 (también se puede programar como COLLISIONOFF)" .

