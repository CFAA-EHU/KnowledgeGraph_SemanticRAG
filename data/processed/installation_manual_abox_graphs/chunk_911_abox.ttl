PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_CodigosAlmacen_782 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de códigos de operaciones del almacén (Sección 7.8.2)"@es ;
    ex:textoExtracto """
| Valor | Significado |
| --- | --- |
| 0 | No hay que hacer nada. |
| # | Posición en el almacén. |
| -4 | Herramienta de tierra. |
"""@es ;
    ex:documentadoEn ex:Pagina_495_497 .

ex:HerramientaTierra_Almacen
    a ex:Herramienta ;
    rdfs:label "Herramienta de tierra (código -4)"@es ;
    ex:identificador "-4" ;
    ex:textoExtracto "Herramienta de tierra."@es ;
    ex:documentadoEn ex:Tabla_CodigosAlmacen_782 .