ns1:Parametro_11a57736de a ns1:Parametro ;
    rdfs:label "Marca para desactivar la opción FCAS (control de colisiones)"@es ;
    ns1:identificador "COLLISIONOFF" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes." .

