@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TMOPERATION_1 a ex:ModoOperacion ;
    ex:identificador "TMOPERATION = 1" ;
    ex:textoExtracto "Coger una herramienta del almacén y ponerla en el cabezal. TAKEPOS=# Posición del almacén para coger la herramienta. La secuencia de esta operación es la siguiente. 1 Tras finalizar la operación, activar la marca MZTOSPDL." .

ex:TMOPERATION_2 a ex:ModoOperacion ;
    ex:identificador "TMOPERATION = 2" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén. LEAVEPOS=# Posición del almacén para dejar la herramienta. La secuencia de esta operación es la siguiente. 1 Tras finalizar la operación, activar la marca SPDLTOMZ." .

ex:TMOPERATION_3 a ex:ModoOperacion ;
    ex:identificador "TMOPERATION = 3" ;
    ex:textoExtracto "Poner en el cabezal una herramienta de tierra. La secuencia de esta operación es la siguiente. 1 Tras finalizar la operación, activar la marca GRTOSPDL." .

ex:TMOPERATION_4 a ex:ModoOperacion ;
    ex:identificador "TMOPERATION = 4" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en tierra. La secuencia de esta operación es la siguiente. 1 Tras finalizar la operación, activar la marca SPDLTOGR." .

ex:TMOPERATION_5 a ex:ModoOperacion ;
    ex:identificador "TMOPERATION = 5" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén. TAKEPOS=# Posición del almacén para coger la herramienta. LEAVEPOS=# Posición del almacén para dejar la herramienta. La secuencia de esta operación es la siguiente. 1 Dejar la herramienta del cabezal en el almacén y activar la marca SPDLTOMZ. 2 Poner la herramienta del almacén en el cabezal y activar la marca MZTOSPDL." .

ex:TMOPERATION_6 a ex:ModoOperacion ;
    ex:identificador "TMOPERATION = 6" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger una herramienta de tierra. TAKEPOS=-4 Herramienta de tierra. LEAVEPOS=# Posición del almacén para dejar la herramienta. La secuencia de esta operación es la siguiente. 1 Dejar la herramienta del cabezal en el almacén y activar la marca SPDLTOMZ. 2 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

ex:TMOPERATION_7 a ex:ModoOperacion ;
    ex:identificador "TMOPERATION = 7" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en tierra y coger una herramienta del almacén." .