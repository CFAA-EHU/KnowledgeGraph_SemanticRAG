ns1:TecladoVirtualDeJog a ns1:Parametro ;
    rdfs:label "teclado virtual de jog" ;
    ns1:identificador "VIRTUALJOGENA" ;
    ns1:textoExtracto "VIRTUALJOGENA El PLC utiliza esta marca para habilitar (=1) o deshabilitar (=0) el teclado virtual de jog (teclado en pantalla)." .

