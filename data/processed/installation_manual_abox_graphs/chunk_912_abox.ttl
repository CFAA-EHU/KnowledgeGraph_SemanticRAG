@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:OperacionCogerHerramientaDelAlmacen
    a ex:TareaMantenimiento ;
    rdfs:label "Coger herramienta del almacén (TMOPERATION=1)" ;
    ex:textoExtracto "TMOPERATION = 1 Coger una herramienta del almacén y ponerla en el cabezal. TAKEPOS=# Posición del almacén para coger la herramienta." ;
    ex:activaAlarma ex:MarcaMZTOSPDL .

ex:OperacionDejarHerramientaEnAlmacen
    a ex:TareaMantenimiento ;
    rdfs:label "Dejar herramienta en almacén (TMOPERATION=2)" ;
    ex:textoExtracto "TMOPERATION = 2 Dejar la herramienta del cabezal en el almacén. LEAVEPOS=# Posición del almacén para dejar la herramienta." ;
    ex:activaAlarma ex:MarcaSPDLTOMZ .

ex:OperacionPonerHerramientaDeTierra
    a ex:TareaMantenimiento ;
    rdfs:label "Poner herramienta de tierra (TMOPERATION=3)" ;
    ex:textoExtracto "TMOPERATION = 3 Poner en el cabezal una herramienta de tierra." ;
    ex:activaAlarma ex:MarcaGRTOSPDL .

ex:OperacionDejarHerramientaEnTierra
    a ex:TareaMantenimiento ;
    rdfs:label "Dejar herramienta en tierra (TMOPERATION=4)" ;
    ex:textoExtracto "TMOPERATION = 4 Dejar la herramienta del cabezal en tierra." ;
    ex:activaAlarma ex:MarcaSPDLTOGR .

ex:OperacionIntercambioHerramientaEnAlmacen
    a ex:TareaMantenimiento ;
    rdfs:label "Intercambio herramienta en almacén (TMOPERATION=5)" ;
    ex:textoExtracto "TMOPERATION = 5 Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén." ;
    ex:activaAlarma ex:MarcaSPDLTOMZ, ex:MarcaMZTOSPDL .

ex:OperacionIntercambioHerramientaTierraAlmacen
    a ex:TareaMantenimiento ;
    rdfs:label "Intercambio herramienta tierra-almacén (TMOPERATION=6)" ;
    ex:textoExtracto "TMOPERATION = 6 Dejar la herramienta del cabezal en el almacén y coger una herramienta de tierra. TAKEPOS=-4 Herramienta de tierra." ;
    ex:activaAlarma ex:MarcaSPDLTOMZ, ex:MarcaGRTOSPDL .

ex:OperacionIntercambioHerramientaAlmacenTierra
    a ex:TareaMantenimiento ;
    rdfs:label "Intercambio herramienta almacén-tierra (TMOPERATION=7)" ;
    ex:textoExtracto "TMOPERATION = 7 Dejar la herramienta del cabezal en tierra y coger una herramienta del almacén." .

ex:MarcaMZTOSPDL
    a ex:Alarma ;
    rdfs:label "MZTOSPDL" ;
    ex:textoExtracto "activar la marca MZTOSPDL" ;
    ex:identificador "MZTOSPDL" .

ex:MarcaSPDLTOMZ
    a ex:Alarma ;
    rdfs:label "SPDLTOMZ" ;
    ex:textoExtracto "activar la marca SPDLTOMZ" ;
    ex:identificador "SPDLTOMZ" .

ex:MarcaGRTOSPDL
    a ex:Alarma ;
    rdfs:label "GRTOSPDL" ;
    ex:textoExtracto "activar la marca GRTOSPDL" ;
    ex:identificador "GRTOSPDL" .

ex:MarcaSPDLTOGR
    a ex:Alarma ;
    rdfs:label "SPDLTOGR" ;
    ex:textoExtracto "activar la marca SPDLTOGR" ;
    ex:identificador "SPDLTOGR" .