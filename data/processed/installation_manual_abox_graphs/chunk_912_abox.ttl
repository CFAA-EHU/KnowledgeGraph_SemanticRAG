@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ControlDeColisiones_24d702cfd8 a ns1:Parametro ;
    rdfs:label "control de colisiones" ;
    ns1:identificador "FCAS" ;
    ns1:textoExtracto "la opción FCAS (control de colisiones). Si el PLC desactiva esta marca (cambio de 1 a 0), activa la opción FCAS (control de colisiones)." .

ns1:Parametro_2e9bc57ec4 a ns1:Parametro ;
    rdfs:label "marca del canal 4" ;
    ns1:identificador "DMCONC4" ;
    ns1:textoExtracto "DMCON Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. DMCONC4" .

