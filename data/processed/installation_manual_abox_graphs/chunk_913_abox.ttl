@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_f3ab8af22c a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:SistemaPLC ;
    ns1:textoExtracto "el CNC entiende que el eje o cabezal correspondiente ha sobrepasado el límite de recorrido en el sentido positivo (POS) o negativo (NEG)" .

ns1:Parametro_4f431ceab5 a ns1:Parametro ;
    rdfs:label "Marca que indica el límite de recorrido en sentido positivo" ;
    ns1:identificador "LIMITPOS" ;
    ns1:textoExtracto "LIMITPOS(axis) Si el PLC pone esta marca a (=1), el CNC entiende que el eje o cabezal correspondiente ha sobrepasado el límite de recorrido en el sentido positivo (POS)" .

ns1:Parametro_bdc210176f a ns1:Parametro ;
    rdfs:label "Marca que indica el límite de recorrido en sentido negativo" ;
    ns1:identificador "LIMITNEG" ;
    ns1:textoExtracto "LIMITNEG(axis) Si el PLC pone esta marca a (=1), el CNC entiende que el eje o cabezal correspondiente ha sobrepasado el límite de recorrido en el sentido negativo (NEG)" .

ns1:Parametro_c7182f4e92 a ns1:Parametro ;
    rdfs:label "Marca usada durante la búsqueda de referencia máquina" ;
    ns1:identificador "DECEL" ;
    ns1:textoExtracto "Esta marca se usa durante la búsqueda de referencia máquina. El PLC la pone a (=1) para indicar que el micro de búsqueda de referencia máquina está pulsado." .

ns1:Parametro_f5d656189b a ns1:Parametro ;
    rdfs:label "Marca que impide cualquier movimiento del eje o cabezal correspondiente" ;
    ns1:identificador "INHIBIT" ;
    ns1:textoExtracto "Si el PLC pone esta marca a (=1) el CNC impide cualquier movimiento del eje o cabezal correspondiente." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "Si el PLC pone esta marca a (=1), el CNC entiende que el eje o cabezal correspondiente ha sobrepasado el límite de recorrido en el sentido positivo (POS) o negativo (NEG)" .

