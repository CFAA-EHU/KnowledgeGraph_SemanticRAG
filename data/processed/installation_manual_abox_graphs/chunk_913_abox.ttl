@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:OperacionAlmacen_782_01
    a ex:TareaMantenimiento ;
    rdfs:label "Poner herramienta de tierra en cabezal y activar marca GRTOSPDL"@es ;
    ex:textoExtracto "Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL."@es ;
    ex:identificador "TMOPERATION = 7" .

ex:OperacionAlmacen_782_02
    a ex:TareaMantenimiento ;
    rdfs:label "Dejar herramienta en tierra y tomar herramienta del almacén"@es ;
    ex:textoExtracto "Dejar la herramienta del cabezal en tierra y coger una herramienta del almacén."@es ;
    ex:identificador "TAKEPOS=# ; LEAVEPOS=-4" .

ex:HerramientaTierra
    a ex:Herramienta ;
    rdfs:label "Herramienta de tierra"@es ;
    ex:textoExtracto "Herramienta de tierra."@es .

ex:Parametro_TAKEPOS
    a ex:Parametro ;
    rdfs:label "Posición de toma en almacén (TAKEPOS)"@es ;
    ex:textoExtracto "TAKEPOS=# Posición del almacén para coger la herramienta."@es ;
    ex:valor "#" .

ex:Parametro_LEAVEPOS
    a ex:Parametro ;
    rdfs:label "Posición de tierra (LEAVEPOS)"@es ;
    ex:textoExtracto "LEAVEPOS=-4 Herramienta de tierra."@es ;
    ex:valor "-4" .

ex:Marca_GRTOSPDL
    a ex:InterfazUsuario ;
    rdfs:label "Marca GRTOSPDL"@es ;
    ex:textoExtracto "activar la marca GRTOSPDL"@es .

ex:Marca_SPDLTOGR
    a ex:InterfazUsuario ;
    rdfs:label "Marca SPDLTOGR"@es ;
    ex:textoExtracto "activar la marca SPDLTOGR"@es .

ex:OperacionAlmacen_782_03
    a ex:TareaMantenimiento ;
    rdfs:label "Dejar herramienta en tierra y activar SPDLTOGR"@es ;
    ex:textoExtracto "Dejar la herramienta del cabezal en tierra y activar la marca SPDLTOGR."@es .

ex:OperacionAlmacen_782_04
    a ex:TareaMantenimiento ;
    rdfs:label "Poner herramienta del almacén en cabezal"@es ;
    ex:textoExtracto "Poner la herramienta del almacén en el cabezal y activar la"@es .