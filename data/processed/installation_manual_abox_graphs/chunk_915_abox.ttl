@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MarcaMZROT a ex:Sensor ;
    rdfs:label "MZROT" ;
    ex:textoExtracto "Activar la marca MZROT para indicar que ha finalizado la operación" .

ex:TMOPERATION_12 a ex:ModoOperacion ;
    rdfs:label "TMOPERATION = 12" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén (como TMOPERATION=5). Es una operación optimizada, válida sólo cuando el almacén es random y la herramienta es especial." .

ex:TMOPERATION_13 a ex:ModoOperacion ;
    rdfs:label "TMOPERATION = 13" ;
    ex:textoExtracto "Orientar dos almacenes. Esta operación es una optimización del cambio de herramienta que permite" .

ex:Almacen a ex:Sistema ;
    rdfs:label "almacén" ;
    ex:textoExtracto "cuando el almacén es random" .

ex:Herramienta a ex:PiezaRecambio ;
    rdfs:label "herramienta" ;
    ex:textoExtracto "coger una herramienta del mismo almacén" .