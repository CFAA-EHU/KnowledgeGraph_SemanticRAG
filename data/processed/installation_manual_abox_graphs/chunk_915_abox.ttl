@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_a2d19afb6d a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controladoPor ns1:SenalSincronizacion ;
    ns1:documentadoEn ns1:ModoOperacionManual ;
    ns1:mitigaRiesgo ns1:AvisoEstadoCabezal,
        ns1:AvisoEstadoEje ;
    ns1:textoExtracto "El CNC utiliza estas marcas cuando se encuentra trabajando en el modo de operación manual." .

ns1:AvisoEstadoCabezal a ns1:AvisoSeguridad ;
    rdfs:label "Aviso estado cabezal" ;
    ns1:textoExtracto "Para los cabezales, el texto \"Sreal\" aparece en color rojo cuando esta marca está activa para el cabezal." .

ns1:AvisoEstadoEje a ns1:AvisoSeguridad ;
    rdfs:label "Aviso estado eje" ;
    ns1:textoExtracto "Para los ejes, el nombre del eje que antecede a la cota aparece en color rojo cuando esta marca está activa para el eje." .

ns1:ModoOperacionManual a ns1:ModoOperacion ;
    rdfs:label "Modo operación manual" ;
    ns1:textoExtracto "El CNC utiliza estas marcas cuando se encuentra trabajando en el modo de operación manual." .

ns1:SenalSincronizacion a ns1:AvisoSeguridad ;
    rdfs:label "Señal de sincronización" ;
    ns1:textoExtracto "si el PLC pone esta señal a (=1), se detiene el movimiento de sincronización, pasando a velocidad nula." .

