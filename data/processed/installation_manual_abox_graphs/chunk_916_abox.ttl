@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_a2d19afb6d a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:monitoreaParametro ns1:Parametro_3738031b4f,
        ns1:Parametro_8533383f6a,
        ns1:Parametro_a337f4e2a6 ;
    ns1:textoExtracto "El CNC utiliza estas marcas cuando se encuentra trabajando en el modo de operación manual." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:controla ns1:Parametro_8533383f6a,
        ns1:Parametro_a337f4e2a6 ;
    ns1:textoExtracto "Si el PLC pone una de estas marcas a (=1), el CNC desplazará el eje correspondiente en el sentido indicado." .

ns1:AvisoSeguridad_171422faf5 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de detención del movimiento" ;
    ns1:mitigaRiesgo ns1:DetenerMovimientoDeEjesOCabezales ;
    ns1:textoExtracto "Si durante el desplazamiento del eje o cabezal se pone la marca SERVO(axis)ON a (=0) el CNC detiene el avance de los ejes y el giro del cabezal, visualizando en la pantalla el error correspondiente." .

ns1:DetenerMovimientoDeEjesOCabezales a ns1:AccionProhibida ;
    rdfs:label "Detener movimiento de ejes o cabezales" ;
    ns1:riesgoMitigadoPor ns1:AvisoSeguridad_171422faf5 ;
    ns1:textoExtracto "Si durante el desplazamiento del eje o cabezal se pone la marca SERVO(axis)ON a (=0) el CNC detiene el avance de los ejes y el giro del cabezal, visualizando en la pantalla el error correspondiente." .

ns1:Parametro_3738031b4f a ns1:Parametro ;
    rdfs:label "Marca que permite el movimiento del eje correspondiente" ;
    ns1:identificador "SERVO(axis)ON" ;
    ns1:textoExtracto "Esta marca debe estar a (=1) para permitir el movimiento (desbloqueo) del eje correspondiente." .

ns1:Parametro_8533383f6a a ns1:Parametro ;
    rdfs:label "Marca que indica el desplazamiento negativo del eje en modo manual" ;
    ns1:identificador "AXISNEG" ;
    ns1:textoExtracto "AXISPOS(axis) AXISNEG(axis) El CNC utiliza estas marcas cuando se encuentra trabajando en el modo de operación manual." .

ns1:Parametro_a337f4e2a6 a ns1:Parametro ;
    rdfs:label "Marca que indica el desplazamiento positivo del eje en modo manual" ;
    ns1:identificador "AXISPOS" ;
    ns1:textoExtracto "AXISPOS(axis) AXISNEG(axis) El CNC utiliza estas marcas cuando se encuentra trabajando en el modo de operación manual." .

