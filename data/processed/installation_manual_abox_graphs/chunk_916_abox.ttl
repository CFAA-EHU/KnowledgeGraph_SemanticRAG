@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:OperacionTM13 a ex:TareaMantenimiento ;
    rdfs:label "TMOPERATION = 13 Orientar dos almacenes" ;
    ex:textoExtracto "Esta operación es una optimización del cambio de herramienta que permite orientar dos almacenes durante el mecanizado. Activar la marca MZROT en ambos almacenes para indicar que ha finalizado la operación, se hayan orientado los almacenes o no." ;
    ex:identificador "TMOPERATION = 13" .

ex:OperacionTM14 a ex:TareaMantenimiento ;
    rdfs:label "TMOPERATION = 14 Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén. La secuencia de esta operación es la siguiente. 1 Dejar la herramienta del cabezal en el almacén y activar la marca SPDLTOMZ. 2 Poner la herramienta del almacén en el cabezal y activar la marca MZTOSPDL." ;
    ex:identificador "TMOPERATION = 14" .

ex:MarcaMZROT a ex:Parametro ;
    rdfs:label "MZROT" ;
    ex:textoExtracto "Activar la marca MZROT en ambos almacenes para indicar que ha finalizado la operación, se hayan orientado los almacenes o no." .

ex:MarcaSPDLTOMZ a ex:Parametro ;
    rdfs:label "SPDLTOMZ" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén y activar la marca SPDLTOMZ." .

ex:MarcaMZTOSPDL a ex:Parametro ;
    rdfs:label "MZTOSPDL" ;
    ex:textoExtracto "Poner la herramienta del almacén en el cabezal y activar la marca MZTOSPDL." .

ex:RegistroMZID a ex:Componente ;
    rdfs:label "MZID" ;
    ex:textoExtracto "En la parte baja de este registro se indica el almacén en el que hay que dejar la herramienta y en la parte alta el almacén del que hay que coger la herramienta." .

ex:PosicionLEAVEPOS a ex:Parametro ;
    rdfs:label "LEAVEPOS" ;
    ex:textoExtracto "Posición del almacén para dejar la herramienta." .

ex:PosicionTAKEPOS a ex:Parametro ;
    rdfs:label "TAKEPOS" ;
    ex:textoExtracto "Posición del almacén para coger la herramienta." .