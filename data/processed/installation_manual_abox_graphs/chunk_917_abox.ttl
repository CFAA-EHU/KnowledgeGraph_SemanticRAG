@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:M1107 a ex:Sensor ;
    rdfs:label "M1107" ;
    ex:textoExtracto "Marca. | M1107 | SPDLTOGR | La herramienta se ha llevado del cabezal a tierra." ;
    ex:valor "SPDLTOGR" .

ex:M1108 a ex:Sensor ;
    rdfs:label "M1108" ;
    ex:textoExtracto "Marca. | M1108 | GRTOSPDL | La herramienta se ha llevado de tierra al cabezal." ;
    ex:valor "GRTOSPDL" .

ex:M1109 a ex:Sensor ;
    rdfs:label "M1109" ;
    ex:textoExtracto "Marca. | M1109 | MZTOSPDL | La herramienta se ha llevado del almacén al cabezal." ;
    ex:valor "MZTOSPDL" .

ex:M1110 a ex:Sensor ;
    rdfs:label "M1110" ;
    ex:textoExtracto "Marca. | M1110 | SPDLTOMZ | La herramienta se ha llevado del cabezal al almacén." ;
    ex:valor "SPDLTOMZ" .

ex:M109 a ex:Sensor ;
    rdfs:label "M109" ;
    ex:textoExtracto "Función. | M109 | Seleccionar en el almacén la posición que indica TAKEPOS y poner la herramienta en el cabezal." ;
    ex:valor "Seleccionar en el almacén la posición que indica TAKEPOS y poner la herramienta en el cabezal." .

ex:M110 a ex:Sensor ;
    rdfs:label "M110" ;
    ex:textoExtracto "Función. | M110 | Seleccionar en el almacén la posición que indica LEAVEPOS y dejar la herramienta del cabezal." ;
    ex:valor "Seleccionar en el almacén la posición que indica LEAVEPOS y dejar la herramienta del cabezal." .