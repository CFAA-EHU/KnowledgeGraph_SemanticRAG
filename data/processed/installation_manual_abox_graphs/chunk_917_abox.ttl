@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_d61775651f a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC la pone a (=1) cada vez que quiere mover el eje. Ver \"ENABLE(axis)\" 418." .

ns1:Parametro_7cbccb0cfe a ns1:Parametro ;
    rdfs:label "Marca SERVOON para control continuo del eje" ;
    ns1:identificador "SERVOON" ;
    ns1:textoExtracto "Para disponer de control continuo del eje, la marca SERVOON debe estar siempre a (no hay errores) AND (regulador eje OK) = SERVOnON" .

ns1:Parametro_ccfabce9b6 a ns1:Parametro ;
    rdfs:label "Marca ENABLE para controlar el eje en desplazamientos" ;
    ns1:identificador "ENABLE" ;
    ns1:textoExtracto "Para controlar el eje sólo en los desplazamientos, se debe utilizar la marca ENABLE. El CNC la pone a (=1) cada vez que quiere mover el eje." .

