@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SUB_SPD_TO_GR a ex:TareaMantenimiento ;
    ex:textoExtracto "Quitar la herramienta del cabezal (llevarla a tierra). # MSG [\"Extraer herramienta T%D y pulsar MARCHA\", V.TM.TOOL] ; Mensaje al operario para que quite la herramienta." .

ex:SUB_GR_TO_SPD a ex:TareaMantenimiento ;
    ex:textoExtracto "Colocar la herramienta de tierra en el cabezal. # MSG [\"Insertar herramienta T%D y pulsar MARCHA\", V.TM.NXTOOL] ; Mensaje al operario para que ponga la herramienta." .

ex:SUB_MZ_TO_SPD a ex:TareaMantenimiento ;
    ex:textoExtracto "Coger la herramienta del almacén y ponerla en el cabezal. M109 ; Función auxiliar para ejecutar acción." .

ex:SUB_SPD_TO_MZ a ex:TareaMantenimiento ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén. M110 ; Función auxiliar para ejecutar acción." .

ex:SUB_SPD_GMCHG a ex:TareaMantenimiento ;
    ex:textoExtracto "Llevar el cabezal al punto de cambio manual. G1 Z_ F_ ; Desplazar el cabezal." .

ex:SUB_SPD_AUTCHG a ex:TareaMantenimiento ;
    ex:textoExtracto "Llevar el cabezal al punto de cambio automático. G1 Z_ F_ ; Desplazar el cabezal." .

ex:M6 a ex:TareaMantenimiento ;
    ex:textoExtracto "Orden al gestor para comenzar el cambio de herramienta." .

ex:M06 a ex:ModoOperacion ;
    ex:textoExtracto "M6 ; Orden al gestor para comenzar el cambio de herramienta." .

ex:MSG_ExtraerHerramienta a ex:AvisoSeguridad ;
    ex:textoExtracto "# MSG [\"Extraer herramienta T%D y pulsar MARCHA\", V.TM.TOOL] ; Mensaje al operario para que quite la herramienta." .

ex:MSG_InsertarHerramienta a ex:AvisoSeguridad ;
    ex:textoExtracto "# MSG [\"Insertar herramienta T%D y pulsar MARCHA\", V.TM.NXTOOL] ; Mensaje al operario para que ponga la herramienta." .