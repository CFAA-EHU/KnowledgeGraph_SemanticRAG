@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ControlDeServoHabilitado a ns1:Parametro ;
    rdfs:label "Control de servo habilitado" ;
    ns1:identificador "SERVOON" ;
    ns1:textoExtracto "ENABLE = SERVOON" .

ns1:EstadoDelRegulador_bf29a0907f a ns1:Parametro ;
    rdfs:label "Estado del regulador" ;
    ns1:textoExtracto "(regulador OK)" .

ns1:FalloDesviacionSeguimiento a ns1:DiagnosticoFallo ;
    rdfs:label "Error de seguimiento por desviación" ;
    ns1:textoExtracto "el CNC almacena la desviación como error de seguimiento." .

ns1:HabilitacionDelEje a ns1:Parametro ;
    rdfs:label "Habilitación del eje" ;
    ns1:identificador "ENABLE(axis)" ;
    ns1:textoExtracto "Ver \"ENABLE(axis)\" 418." .

