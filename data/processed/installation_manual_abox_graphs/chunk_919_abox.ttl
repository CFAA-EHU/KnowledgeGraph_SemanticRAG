@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_a0e743a684 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "el CNC espera el tiempo indicado en el parámetro DWELL solamente si SERVOnON está a (=0)." ;
    ns1:tieneComponente ns1:Parametro_018472477d,
        ns1:Parametro_07c99aa9d1,
        ns1:TiempoDeEsperaAntesDeActivarSERVOnON .

ns1:DesactivacionDeLimitesDeSoftware a ns1:AccionProhibida ;
    rdfs:label "Desactivación de límites de software" ;
    ns1:textoExtracto "Si el PLC activa esta marca, el CNC no tiene en cuenta los límites de software ni las zonas de trabajo fijadas para el eje correspondiente." .

ns1:ErrorDeEjeBloqueadoEnEmpalmeDeBloques a ns1:AccionProhibida ;
    rdfs:label "Error de eje bloqueado en empalme de bloques" ;
    ns1:textoExtracto "puede dar error de eje bloqueado en el empalme de bloques si alguno de los ejes implicados no tiene activa la marca SERVOnON de antemano." .

ns1:ErrorDeEjeBloqueado_ee34822e51 a ns1:AccionProhibida ;
    rdfs:label "Error de eje bloqueado" ;
    ns1:textoExtracto "el CNC muestra el error 'eje bloqueado'." .

ns1:Parametro_018472477d a ns1:Parametro ;
    rdfs:label "Marca SERVOnON para control del eje" ;
    ns1:identificador "SERVOnON" ;
    ns1:textoExtracto "el CNC espera el tiempo indicado en el parámetro DWELL solamente si SERVOnON está a (=0)." .

ns1:Parametro_07c99aa9d1 a ns1:Parametro ;
    rdfs:label "Marca DRO para visualizador" ;
    ns1:identificador "DRO" ;
    ns1:textoExtracto "Esta marca, junto con la marca SERVOnON correspondiente permite que el eje o cabezal trabaje como visualizador" .

ns1:TiempoDeEsperaAntesDeActivarSERVOnON a ns1:Parametro ;
    rdfs:label "Tiempo de espera antes de activar SERVOnON" ;
    ns1:identificador "DWELL" ;
    ns1:textoExtracto "el CNC espera el tiempo indicado en el parámetro DWELL solamente si SERVOnON está a (=0)." .

