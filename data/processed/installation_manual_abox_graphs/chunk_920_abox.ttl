@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:LimiteDeSoftware a ns1:Parametro ;
    rdfs:label "Límite de Software" ;
    ns1:textoExtracto "Los límites de software se pueden fijar mediante los parámetros máquina, mediante las funciones G198/G199 o mediante variables." .

ns1:SistemaPLC920 a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:controla ns1:CNC8070_2258f5cfbb ;
    ns1:textoExtracto "Si el PLC desactiva esta marca, el CNC vuelve a tener en cuenta los límites de software y las zonas de trabajo en el eje indicado." .

ns1:CNC8070_2258f5cfbb a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "el CNC vuelve a tener en cuenta los límites de software y las zonas de trabajo en el eje indicado." .

