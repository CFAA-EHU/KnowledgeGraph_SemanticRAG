@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:RutinaM06_Caso7
    a ex:TareaMantenimiento ;
    rdfs:label "Rutina M06 - Caso 7: Cambio manual de herramienta (cabezal → tierra → almacén)"@es ;
    ex:textoExtracto "Dejar la herramienta del cabezal en tierra, y coger otra del almacén."@es ;
    ex:requiereMantenimiento ex:SistemaCambioHerramientas .

ex:RutinaM06_Caso8
    a ex:TareaMantenimiento ;
    rdfs:label "Rutina M06 - Caso 8: Cambio manual de herramienta (cabezal → tierra → tierra)"@es ;
    ex:textoExtracto "Dejar la herramienta del cabezal en tierra y coger otra de tierra."@es ;
    ex:requiereMantenimiento ex:SistemaCambioHerramientas .

ex:SistemaCambioHerramientas
    a ex:Sistema ;
    rdfs:label "Sistema de cambio de herramientas (manual/automático)"@es ;
    ex:textoExtracto "LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual... LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático."@es .

ex:Subrutina_SUB_SPD_GMCHG
    a ex:ModoOperacion ;
    rdfs:label "SUB_SPD_GMCHG: Posicionar cabezal en punto de cambio manual"@es ;
    ex:textoExtracto "LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual."@es ;
    ex:ejecutadoPor ex:SistemaCambioHerramientas .

ex:Subrutina_SUB_GR_TO_SPD
    a ex:ModoOperacion ;
    rdfs:label "SUB_GR_TO_SPD: Colocar herramienta de tierra en cabezal"@es ;
    ex:textoExtracto "LL SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal."@es ;
    ex:ejecutadoPor ex:SistemaCambioHerramientas .

ex:Subrutina_SUB_SPD_TO_GR
    a ex:ModoOperacion ;
    rdfs:label "SUB_SPD_TO_GR: Retirar herramienta del cabezal a tierra"@es ;
    ex:textoExtracto "LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal."@es ;
    ex:ejecutadoPor ex:SistemaCambioHerramientas .

ex:Subrutina_SUB_SPD_AUTCHG
    a ex:ModoOperacion ;
    rdfs:label "SUB_SPD_AUTCHG: Posicionar cabezal en punto de cambio automático"@es ;
    ex:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático."@es ;
    ex:ejecutadoPor ex:SistemaCambioHerramientas .

ex:Subrutina_SUB_MZ_TO_SPD
    a ex:ModoOperacion ;
    rdfs:label "SUB_MZ_TO_SPD: Transferir herramienta del almacén al cabezal"@es ;
    ex:textoExtracto "LL SUB_MZ_TO_SPD ; Poner la herramienta del almacén en el cabezal."@es ;
    ex:ejecutadoPor ex:SistemaCambioHerramientas .