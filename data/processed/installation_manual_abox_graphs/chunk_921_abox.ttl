@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:LL_SUB_SPD_GMCHG a ex:TareaMantenimiento ;
    ex:textoExtracto "LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual." .

ex:LL_SUB_GR_TO_SPD a ex:TareaMantenimiento ;
    ex:textoExtracto "LL SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal." .

ex:LL_SUB_SPD_TO_GR a ex:TareaMantenimiento ;
    ex:textoExtracto "LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal." .

ex:LL_SUB_SPD_AUTCHG a ex:TareaMantenimiento ;
    ex:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático." .

ex:LL_SUB_MZ_TO_SPD a ex:TareaMantenimiento ;
    ex:textoExtracto "LL SUB_MZ_TO_SPD ; Poner la herramienta del almacén en el cabezal." .

ex:SistemaCambioHerramienta a ex:Sistema ;
    ex:textoExtracto "Programa de la rutina M06." ;
    ex:compuestoPor ex:LL_SUB_SPD_GMCHG, ex:LL_SUB_GR_TO_SPD, ex:LL_SUB_SPD_TO_GR, ex:LL_SUB_SPD_AUTCHG, ex:LL_SUB_MZ_TO_SPD ;
    ex:detalladoEnEsquema ex:SistemaCambioHerramienta .