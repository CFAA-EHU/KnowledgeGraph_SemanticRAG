@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IndicadorDeAparcado a ns1:Parametro ;
    rdfs:label "Indicador de aparcado" ;
    ns1:identificador "PARKED(axis)" ;
    ns1:textoExtracto "El PLC pone esta marca a (=1) para indicar al CNC que el eje o cabezal correspondiente está aparcado." .

ns1:SenalDriveEnable a ns1:Parametro ;
    rdfs:label "Señal drive enable" ;
    ns1:identificador "DRENA(axis)" ;
    ns1:monitoreaParametro ns1:SistemaPLC ;
    ns1:textoExtracto "La marca DRENA(axis) corresponde a la señal \"drive enable\" del dispositivo." .

ns1:SenalSpeedEnable a ns1:Parametro ;
    rdfs:label "Señal speed enable" ;
    ns1:identificador "SPENA(axis)" ;
    ns1:monitoreaParametro ns1:SistemaPLC ;
    ns1:textoExtracto "La marca SPENA(axis) corresponde a la señal \"speed enable\" del dispositivo." .

ns1:CNC8070_767832e350 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC aplica siempre los límites de recorrido más restrictivos." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:controla ns1:CNC8070_767832e350 ;
    ns1:textoExtracto "El PLC utiliza estas marcas para habilitar los reguladores cuando la comunicación es vía Sercos o para habilitar los servos e inverters cuando la comunicación es vía Mechatrolink." .

