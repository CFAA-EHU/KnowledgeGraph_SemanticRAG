@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:IndicaSiSeDeseaLaPrestacionDeEngrase a ns1:Parametro ;
    rdfs:label "Indica si se desea la prestación de engrase" ;
    ns1:identificador "LUBRENA" ;
    ns1:textoExtracto "La marca LUBRENA indica si se desea esta prestación (=1), o no (=0)." .

ns1:SenalDeConsultaDeEngraseDeLosEjes a ns1:Parametro ;
    rdfs:label "Señal de consulta de engrase de los ejes" ;
    ns1:identificador "LUBR" ;
    ns1:textoExtracto "Estas marcas junto con la señal de consulta de ejes LUBR(axis) se deben utilizar para el en la página 420. engrase de los ejes." .

ns1:SenalDeConsultaDeEngraseDeLosEjes_79a9ecdf1a a ns1:Parametro ;
    rdfs:label "Señal de consulta de engrase de los ejes" ;
    ns1:identificador "LUBROK" ;
    ns1:textoExtracto "Estas marcas junto con la señal de consulta de ejes LUBR(axis) se deben utilizar para el en la página 420. engrase de los ejes." .

