@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AvanceParaCorreccionDeCotaEnEjesGantry a ns1:Parametro ;
    rdfs:label "Avance para corrección de cota en ejes gantry" ;
    ns1:identificador "REFFEED2" ;
    ns1:textoExtracto "al avance especificado en el parámetro REFFEED2" .

ns1:CNC8070_9e967cf19f a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "el CNC actúa del siguiente modo" .

ns1:DistanciaParaEngraseDelEje a ns1:Parametro ;
    rdfs:label "Distancia para engrase del eje" ;
    ns1:identificador "DISTLUBRI" ;
    ns1:textoExtracto "la distancia fijada en el parámetro máquina DISTLUBRI" .

ns1:Parametro_09ac959ab8 a ns1:Parametro ;
    rdfs:label "Marca LUBR para engrase del eje" ;
    ns1:identificador "LUBR" ;
    ns1:textoExtracto "el CNC pone la marca LUBR a (=1) para indicar al PLC que se debe engrasar el eje." .

ns1:Parametro_0e7814b322 a ns1:Parametro ;
    rdfs:label "Marca FBACKSEL para selección de captación" ;
    ns1:identificador "FBACKSEL" ;
    ns1:textoExtracto "El CNC utiliza esta marca cuando el sistema dispone de captación externa+interna" .

ns1:Parametro_45f81e4258 a ns1:Parametro ;
    rdfs:label "Marca LUBROK para confirmación de engrase del eje" ;
    ns1:identificador "LUBROK" ;
    ns1:textoExtracto "El PLC tras engrasar el eje pone la marca LUBROK(axis) a (=1)" .

ns1:Parametro_48e834d453 a ns1:Parametro ;
    rdfs:label "Marca LUBRENA" ;
    ns1:identificador "LUBRENA" ;
    ns1:textoExtracto "La marca LUBRENA indica si se desea esta prestación (=1), o no (=0)." .

ns1:Parametro_5a9875232f a ns1:Parametro ;
    rdfs:label "Marca DIFFCOMP para corrección de cota en ejes gantry" ;
    ns1:identificador "DIFFCOMP" ;
    ns1:textoExtracto "Esta marca corrige la diferencia de cota entre el eje maestro y esclavo" .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "El PLC tras engrasar el eje pone la marca LUBROK(axis) a (=1)" .

