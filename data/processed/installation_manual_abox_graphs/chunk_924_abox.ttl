@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:RegistroLEAVEPOS
    a ex:Parametro ;
    rdfs:label "Registro LEAVEPOS" ;
    ex:textoExtracto "LEAVEPOS Este registro indica la posición de almacén en la que hay que dejar la herramienta." ;
    ex:identificador "LEAVEPOS" .

ex:RegistroTAKEPOS
    a ex:Parametro ;
    rdfs:label "Registro TAKEPOS" ;
    ex:textoExtracto "TAKEPOS Este registro indica la posición de almacén que ocupa la herramienta que hay que coger." ;
    ex:identificador "TAKEPOS" .

ex:SenalEmergenciaGestor
    a ex:AvisoSeguridad ;
    rdfs:label "Señal de emergencia del gestor de herramientas" ;
    ex:textoExtracto "Señal de emergencia del gestor. Tratamiento de la señal de emergencia del gestor de herramientas." .

ex:InterfazTecladoDFU_B11KEYBD1
    a ex:InterfazUsuario ;
    rdfs:label "Tecla DFU B11KEYBD1" ;
    ex:textoExtracto "DFU B11KEYBD1 AND NOT TMINEM = SET SETTMEM" ;
    ex:identificador "B11KEYBD1" .

ex:ParametroTMINEM
    a ex:Parametro ;
    rdfs:label "Parámetro TMINEM" ;
    ex:textoExtracto "DFU B11KEYBD1 AND NOT TMINEM = SET SETTMEM [...] DFU TMINEM = RES SETTMEM" ;
    ex:identificador "TMINEM" .

ex:ParametroSETTMEM
    a ex:Parametro ;
    rdfs:label "Parámetro SETTMEM" ;
    ex:textoExtracto "DFU B11KEYBD1 AND NOT TMINEM = SET SETTMEM [...] DFU TMINEM = RES SETTMEM" ;
    ex:identificador "SETTMEM" .

ex:InterfazTecladoDFU_TMINEM
    a ex:InterfazUsuario ;
    rdfs:label "Tecla DFU TMINEM" ;
    ex:textoExtracto "DFU TMINEM = RES SETTMEM" ;
    ex:identificador "TMINEM_DFU" .