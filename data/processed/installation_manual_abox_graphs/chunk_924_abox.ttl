@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:RegistroLEAVEPOS a ex:Parametro ;
    rdfs:label "LEAVEPOS" ;
    ex:textoExtracto "LEAVEPOS Este registro indica la posición de almacén en la que hay que dejar la herramienta." ;
    ex:valor "Posición de almacén para dejar herramienta" .

ex:RegistroTAKEPOS a ex:Parametro ;
    rdfs:label "TAKEPOS" ;
    ex:textoExtracto "TAKEPOS Este registro indica la posición de almacén que ocupa la herramienta que hay que coger." ;
    ex:textoExtracto "Señal de emergencia del gestor. Tratamiento de la señal de emergencia del gestor de herramientas." ;
    ex:valor "Posición de almacén para coger herramienta" .

ex:SenalEmergenciaGestor a ex:Sensor ;
    rdfs:label "Señal de emergencia del gestor" ;
    ex:textoExtracto "Señal de emergencia del gestor. Tratamiento de la señal de emergencia del gestor de herramientas." ;
    ex:valor "DFU B11KEYBD1 AND NOT TMINEM = SET SETTMEM DFU TMINEM = RES SETTMEM" .