@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CaptacionActiva a ns1:Parametro ;
    rdfs:label "captación activa" ;
    ns1:identificador "ACTFBACK(axis)" ;
    ns1:textoExtracto "La marca ACTFBACK(axis) indica cuál es la captación activa." .

ns1:MezclaDeCaptaciones a ns1:Parametro ;
    rdfs:label "mezcla de captaciones" ;
    ns1:identificador "FBMIXTIME" ;
    ns1:textoExtracto "Si está activa la mezcla de captaciones (parámetro FBMIXTIME)" .

