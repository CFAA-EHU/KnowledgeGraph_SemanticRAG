@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:EmergenciaGestor a ex:AccionProhibida ;
    ex:textoExtracto "Señal de emergencia del gestor. Tratamiento de la señal de emergencia del gestor de herramientas." .

ex:TeclaUSER12 a ex:Sensor ;
    ex:textoExtracto "Si se pulsa la tecla USER12 se activa la emergencia." ;
    ex:identificador "USER12" .

ex:TeclaUSER13 a ex:Sensor ;
    ex:textoExtracto "Si se pulsa la tecla USER13 se quita la emergencia." ;
    ex:identificador "USER13" .

ex:LamparaUSER12 a ex:ComponenteElectrico ;
    ex:textoExtracto "Lámpara de la tecla USER12 iluminada cuando hay emergencia." .

ex:TMINEM a ex:Parametro ;
    ex:textoExtracto "TMINEM = B11KEYLED1 Lámpara de la tecla USER12 iluminada cuando hay emergencia. TMINEM AND DFU B12KEYBD1 = SET RESTMEM" ;
    ex:identificador "TMINEM" .

ex:DFU a ex:Parametro ;
    ex:textoExtracto "DFU B11KEYBD1 AND NOT TMINEM = SET SETTMEM DFU TMINEM = RES SETTMEM" ;
    ex:identificador "DFU" .

ex:SETTMEM a ex:ModoOperacion ;
    ex:textoExtracto "DFU B11KEYBD1 AND NOT TMINEM = SET SETTMEM DFU TMINEM = RES SETTMEM" ;
    ex:identificador "SETTMEM" .

ex:RESTMEM a ex:ModoOperacion ;
    ex:textoExtracto "TMINEM AND DFU B12KEYBD1 = SET RESTMEM" ;
    ex:identificador "RESTMEM" .