@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CaptacionActivaDelEje a ns1:Parametro ;
    rdfs:label "Captación activa del eje" ;
    ns1:identificador "ACTFBACK" ;
    ns1:textoExtracto "La marca ACTFBACK(axis) indica cuál es la captación activa." .

ns1:ConmutacionEntreEjesOCabezalesDelGrupoMultieje a ns1:Parametro ;
    rdfs:label "Conmutación entre ejes o cabezales del grupo multieje" ;
    ns1:identificador "SWITCH" ;
    ns1:textoExtracto "Esta marca permite conmutar entre los diferentes ejes o cabezales del grupo." .

ns1:DesacoplamientoTemporalEnElLazoDeTandem a ns1:Parametro ;
    rdfs:label "Desacoplamiento temporal en el lazo de tándem" ;
    ns1:identificador "TANDEMOFF" ;
    ns1:textoExtracto "Esta marca permite desacoplar temporalmente en el lazo los ejes o cabezales implicados en el tándem, para poder moverlos de forma independiente." .

ns1:GestionDeEmpalmesEntreBloquesParaEjeMuerto a ns1:Parametro ;
    rdfs:label "Gestión de empalmes entre bloques para eje muerto" ;
    ns1:identificador "DEAD" ;
    ns1:textoExtracto "Para evitar este error, el PLC dispone de esta marca que indica como debe gestionar el CNC los empalmes entre bloques cuando está implicado el eje muerto." .

