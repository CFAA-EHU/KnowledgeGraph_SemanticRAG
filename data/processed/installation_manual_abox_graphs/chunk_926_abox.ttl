@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:AlmacenSincronoConBrazoCambiador_926_502 a ex:Maquina ;
    rdfs:label "Almacén síncrono con brazo cambiador" ;
    ex:textoExtracto "Los almacenes síncronos con brazo cambiador (1 o 2 pinzas) tienen el almacén próximo al cabezal y el cambio se realiza con ayuda del brazo cambiador." .

ex:BrazoCambiador_926_502 a ex:ComponenteMecanico ;
    rdfs:label "Brazo cambiador" ;
    ex:textoExtracto "el cambio se realiza con ayuda del brazo cambiador" .

ex:GestorHerramientas_926_502 a ex:Sistema ;
    rdfs:label "Gestor de herramientas" ;
    ex:textoExtracto "el gestor envía una orden al PLC para que seleccione la próxima herramienta en el almacén (si se puede)" .

ex:PLC_926_502 a ex:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ex:textoExtracto "el gestor envía una orden al PLC para que seleccione la próxima herramienta en el almacén" .

ex:FuncionT_926_502 a ex:ModoOperacion ;
    rdfs:label "Función T" ;
    ex:textoExtracto "la ejecución de la función T" .

ex:FuncionM06_926_502 a ex:ModoOperacion ;
    rdfs:label "Función M06" ;
    ex:textoExtracto "la ejecución de la función M06" .

ex:RutinaAsociadaM06_926_502 a ex:TareaMantenimiento ;
    rdfs:label "Rutina asociada a M06" ;
    ex:textoExtracto "Dentro de dicha rutina hay que volver a programar la función M06 para que el CNC indique al gestor que debe comenzar el cambio de herramienta." .

ex:CNC_926_502 a ex:Sistema ;
    rdfs:label "CNC" ;
    ex:textoExtracto "Cuando el CNC ejecuta la función T, se lo indica al gestor" .

ex:AlmacenHerramientas_926_502 a ex:ComponenteMecanico ;
    rdfs:label "Almacén de herramientas" ;
    ex:textoExtracto "el gestor envía una orden al PLC para que seleccione la próxima herramienta en el almacén" .

ex:GiroAlmacen_926_502 a ex:ComponenteMecanico ;
    rdfs:label "Giro almacén" ;
    ex:textoExtracto "gobernar desde la rutina M06 los desplazamientos de los distintos dispositivos (giro almacén, desplazamiento almacén, brazo cambiador, etc.)" .

ex:DesplazamientoAlmacen_926_502 a ex:ComponenteMecanico ;
    rdfs:label "Desplazamiento almacén" ;
    ex:textoExtracto "gobernar desde la rutina M06 los desplazamientos de los distintos dispositivos (giro almacén, desplazamiento almacén, brazo cambiador, etc.)" .