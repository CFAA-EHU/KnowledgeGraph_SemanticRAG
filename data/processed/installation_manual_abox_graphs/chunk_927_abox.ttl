@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_1e7046ef90 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:EjeEsclavo,
        ns1:EjeMaestro ;
    ns1:textoExtracto "El CNC no generará consigna para el eje esclavo ni aplicará ninguna compensación." .

ns1:DesacoplarTandem a ns1:AccionProhibida ;
    rdfs:label "Desacoplar Tándem",
        "Personal Técnico" ;
    ns1:ejecutadoPor ns1:PersonalTecnico ;
    ns1:solucionaFallo ns1:EjesCruzados ;
    ns1:textoExtracto "Esta marca facilita el ajuste del gantry, y permite corregir la posición de los ejes cuando estos se han cruzado y no se pueden recuperar automáticamente." .

ns1:EjeEsclavo a ns1:ComponenteMecanico ;
    rdfs:label "Eje Esclavo" ;
    ns1:textoExtracto "El eje esclavo únicamente se puede mover desde el PLC a través del PLCOFFSET." .

ns1:EjeMaestro a ns1:ComponenteMecanico ;
    rdfs:label "Eje Maestro" ;
    ns1:textoExtracto "El eje maestro se puede mover de la forma habitual desde el panel de jog, modo MDI/MDA, etc." .

ns1:EjesCruzados a ns1:DiagnosticoFallo ;
    rdfs:label "Ejes Cruzados" ;
    ns1:textoExtracto "Esta marca facilita el ajuste del gantry, y permite corregir la posición de los ejes cuando estos se han cruzado y no se pueden recuperar automáticamente." .

