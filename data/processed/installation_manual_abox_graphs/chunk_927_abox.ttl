@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:OperacionGestorHerramientas a ex:TareaMantenimiento ;
    ex:textoExtracto "Operaciones válidas del gestor de herramientas para este almacén. Las operaciones posibles en este tipo de almacén son las siguientes." .

ex:TMOperation0 a ex:ModoOperacion ;
    ex:identificador "0" ;
    ex:textoExtracto "0 | No hay que hacer nada." ;
    rdfs:label "No hay que hacer nada" .

ex:TMOperation1 a ex:ModoOperacion ;
    ex:identificador "1" ;
    ex:textoExtracto "1 | Coger una herramienta del almacén y ponerla en el cabezal." ;
    rdfs:label "Coger una herramienta del almacén y ponerla en el cabezal" .

ex:TMOperation2 a ex:ModoOperacion ;
    ex:identificador "2" ;
    ex:textoExtracto "2 | Dejar la herramienta del cabezal en el almacén." ;
    rdfs:label "Dejar la herramienta del cabezal en el almacén" .

ex:TMOperation3 a ex:ModoOperacion ;
    ex:identificador "3" ;
    ex:textoExtracto "3 | Poner en el cabezal una herramienta de tierra." ;
    rdfs:label "Poner en el cabezal una herramienta de tierra" .

ex:TMOperation4 a ex:ModoOperacion ;
    ex:identificador "4" ;
    ex:textoExtracto "4 | Dejar la herramienta del cabezal en tierra." ;
    rdfs:label "Dejar la herramienta del cabezal en tierra" .

ex:TMOperation5 a ex:ModoOperacion ;
    ex:identificador "5" ;
    ex:textoExtracto "5 | Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén." ;
    rdfs:label "Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén" .

ex:TMOperation6 a ex:ModoOperacion ;
    ex:identificador "6" ;
    ex:textoExtracto "6 | Dejar la herramienta del cabezal en el almacén y coger una herramienta de tierra." ;
    rdfs:label "Dejar la herramienta del cabezal en el almacén y coger una herramienta de tierra" .

ex:TMOperation7 a ex:ModoOperacion ;
    ex:identificador "7" ;
    ex:textoExtracto "7 | Dejar la herramienta del cabezal en tierra y coger una herramienta del almacén." ;
    rdfs:label "Dejar la herramienta del cabezal en tierra y coger una herramienta del almacén" .

ex:TMOperation8 a ex:ModoOperacion ;
    ex:identificador "8" ;
    ex:textoExtracto "8 | Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra." ;
    rdfs:label "Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra" .

ex:TMOperation9 a ex:ModoOperacion ;
    ex:identificador "9" ;
    ex:textoExtracto "9 | Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal." ;
    rdfs:label "Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal" .

ex:TMOperation10 a ex:ModoOperacion ;
    ex:identificador "10" ;
    ex:textoExtracto "10 | Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal." ;
    rdfs:label "Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal" .

ex:TMOperation11 a ex:ModoOperacion ;
    ex:identificador "11" ;
    ex:textoExtracto "11 | Orientar el almacén." ;
    rdfs:label "Orientar el almacén" .

ex:TMOperation13 a ex:ModoOperacion ;
    ex:identificador "13" ;
    ex:textoExtracto "13 | Orientar dos almacenes." ;
    rdfs:label "Orientar dos almacenes" .

ex:TMOperation14 a ex:ModoOperacion ;
    ex:identificador "14" ;
    ex:textoExtracto "14 | Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén." ;
    rdfs:label "Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén" .

ex:TAKEPOS a ex:Parametro ;
    ex:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor. Las señales TAKEPOS y LEAVEPOS pueden tomar los siguientes valores." .

ex:TAKEPOS_0 a ex:Parametro ;
    ex:identificador "0" ;
    ex:textoExtracto "0 | No hay que hacer nada." ;
    rdfs:label "No hay que hacer nada" .

ex:TAKEPOS_HerramientaAlmacen a ex:Parametro ;
    ex:identificador "#" ;
    ex:textoExtracto "# | Posición en el almacén." ;
    rdfs:label "Posición en el almacén" .

ex:TAKEPOS_HerramientaTierra a ex:Parametro ;
    ex:identificador "-4" ;
    ex:textoExtracto "-4 | Herramienta de tierra." ;
    rdfs:label "Herramienta de tierra" .

ex:LEAVEPOS a ex:Parametro ;
    ex:textoExtracto "Valores de los registros TAKEPOS y LEAVEPOS utilizados por el gestor." .

ex:LEAVEPOS_0 a ex:Parametro ;
    ex:identificador "0" ;
    ex:textoExtracto "0 | No hay que hacer nada." ;
    rdfs:label "No hay que hacer nada" .

ex:LEAVEPOS_HerramientaAlmacen a ex:Parametro ;
    ex:identificador "#" ;
    ex:textoExtracto "# | Posición en el almacén." ;
    rdfs:label "Posición en el almacén" .

ex:LEAVEPOS_HerramientaTierra a ex:Parametro ;
    ex:identificador "-4" ;
    ex:textoExtracto "-4 | Herramienta de tierra." ;
    rdfs:label "Herramienta de tierra" .