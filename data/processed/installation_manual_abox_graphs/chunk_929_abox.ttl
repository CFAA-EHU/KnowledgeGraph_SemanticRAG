@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_0b0c77b46e a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:SistemaPLC ;
    ns1:textoExtracto "El CNC indica al PLC la gama solicitada con MFUN1=42 y pone la marca MSTROBE." .

ns1:CabezalAnalogo a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal Analógico" ;
    ns1:textoExtracto "Estas señales se utilizan con cabezal analógico, Sercos en posición, Sercos en velocidad y Mechatrolink." .

ns1:RegistroDeConsignaParaCabezal1 a ns1:Parametro ;
    rdfs:label "Registro de consigna para cabezal 1" ;
    ns1:identificador "SANALOG1" ;
    ns1:textoExtracto "Estas señales se utilizan con cabezal analógico, Sercos en posición, Sercos en velocidad y Mechatrolink." .

ns1:SenalDeControlParaCabezal1 a ns1:Parametro ;
    rdfs:label "Señal de control para cabezal 1" ;
    ns1:identificador "PLCCNTL1" ;
    ns1:textoExtracto "Los mnemónicos para cada cabezal son los siguientes. PLCCNTL1 (también se puede programar como PLCCNTL)" .

ns1:SenalDeControlParaCabezal2 a ns1:Parametro ;
    rdfs:label "Señal de control para cabezal 2" ;
    ns1:identificador "PLCCNTL2" ;
    ns1:textoExtracto "Los mnemónicos para cada cabezal son los siguientes. PLCCNTL2" .

ns1:TiempoMinimoParaDesactivacionDeMSTROBE a ns1:Parametro ;
    rdfs:label "Tiempo mínimo para desactivación de MSTROBE" ;
    ns1:identificador "MINAENDW" ;
    ns1:textoExtracto "La marca AUXEND debe mantenerse a (=1) un tiempo superior al definido en el parámetro máquina MINAENDW." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "El PLC al detectar la solicitud pone un indicativo interno." .

