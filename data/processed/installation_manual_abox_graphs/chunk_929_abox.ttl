@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaOperacionesPLC_TM a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de operaciones válidas entre TM y PLC (pág. 503-504)"@es ;
    ex:textoExtracto """
| TM => PLC |  |  | PLC => TM |
| --- | --- | --- | --- |
| TMOPERATION | TAKEPOS | LEAVEPOS |  |
| 1 | # | 0 | MZTOCH1 + CH1TOSPDL |
| 2 | 0 | # | SPDLTOCH1 + CH1TOMZ |
| 3 | 0 | 0 | GRTOSPDL |
| 4 | 0 | 0 | SPDLTOGR |
| 5 | # | # | SPDLTOCH1 + CH1TOMZ + MZTOCH1 + CH1TOSPDL |
| 6 | -4 | # | SPDLTOCH1 + (CH1TOMZ & GRTOSPDL) |
| 7 | # | -4 | (SPDLTOGR & MZTOCH1) + CH1TOSPDL |
| 8 | 0 | 0 | SPDLTOGR + GRTOSPDL |
| 9 | -4 | # | GRTOSPDL + SPDLTOCH1 + CH1TOMZ |
| 10 | # | -4 | MZTOCH1 + CH1TOSPDL + SPDLTOGR |
| 11 | 0 | 0 | MZROT |
| 13 | # | 0 | MZROT + MZROT |
| 14 | # | # | SPDLTOCH1 + CH1TOMZ + MZTOCH1 + CH1TOSPDL |
"""@es ;
    ex:identificador "7.9.1" .

ex:SistemaControlTM_PLC
    a ex:Sistema ;
    rdfs:label "Sistema de control entre Transfer Machine (TM) y PLC"@es ;
    ex:textoExtracto "Ejemplo de funcionamiento. El siguiente ejemplo muestra, suponiendo que no hay herramienta en el cabezal, las funciones que ejecuta el CNC, los valores que envía el gestor al PLC en cada una de las operaciones y las marcas que debe activar el PLC en cada caso."@es ;
    ex:documentadoEn ex:TablaOperacionesPLC_TM .

ex:ComponenteElectrico_MZTOCH1
    a ex:ComponenteElectrico ;
    rdfs:label "MZTOCH1" ;
    ex:textoExtracto "MZTOCH1" ;
    ex:compuestoPor ex:SistemaControlTM_PLC .

