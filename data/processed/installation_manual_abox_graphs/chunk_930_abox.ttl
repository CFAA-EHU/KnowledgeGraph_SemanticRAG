@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:OperacionesAlmacen_7_9_2
    a ex:Sistema ;
    rdfs:label "Operaciones del almacén (Sección 7.9.2)" ;
    ex:textoExtracto "A continuación se muestra una descripción detallada de las operaciones válidas para este almacén. Para cada operación se indica cuales de las señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas, así como su significado. También aparece cuál es la secuencia a seguir para completar la operación." ;
    ex:identificador "7.9.2" .

ex:Senal_TAKEPOS
    a ex:ComponenteElectrico ;
    rdfs:label "Señal TAKEPOS" ;
    ex:textoExtracto "Las señales TAKEPOS, LEAVEPOS y NEXTPOS pueden tomar los siguientes valores." ;
    ex:monitoreaParametro ex:Param_TAKEPOS .

ex:Senal_LEAVEPOS
    a ex:ComponenteElectrico ;
    rdfs:label "Señal LEAVEPOS" ;
    ex:textoExtracto "Las señales TAKEPOS, LEAVEPOS y NEXTPOS pueden tomar los siguientes valores." ;
    ex:monitoreaParametro ex:Param_LEAVEPOS .

ex:Senal_NEXTPOS
    a ex:ComponenteElectrico ;
    rdfs:label "Señal NEXTPOS" ;
    ex:textoExtracto "Las señales TAKEPOS, LEAVEPOS y NEXTPOS pueden tomar los siguientes valores." ;
    ex:monitoreaParametro ex:Param_NEXTPOS .

ex:Senal_MZID
    a ex:ComponenteElectrico ;
    rdfs:label "Señal MZID" ;
    ex:textoExtracto "Para cada operación se indica [...] cuales de las señales [...] MZID están implicadas, así como su significado." ;
    ex:monitoreaParametro ex:Param_MZID .

ex:Param_TAKEPOS
    a ex:Parametro ;
    rdfs:label "Parámetro TAKEPOS" ;
    ex:textoExtracto "Las señales TAKEPOS, LEAVEPOS y NEXTPOS pueden tomar los siguientes valores." .

ex:Param_LEAVEPOS
    a ex:Parametro ;
    rdfs:label "Parámetro LEAVEPOS" ;
    ex:textoExtracto "Las señales TAKEPOS, LEAVEPOS y NEXTPOS pueden tomar los siguientes valores." .

ex:Param_NEXTPOS
    a ex:Parametro ;
    rdfs:label "Parámetro NEXTPOS" ;
    ex:textoExtracto "Las señales TAKEPOS, LEAVEPOS y NEXTPOS pueden tomar los siguientes valores." .

ex:Param_MZID
    a ex:Parametro ;
    rdfs:label "Parámetro MZID" ;
    ex:textoExtracto "Para cada operación se indica [...] cuales de las señales [...] MZID están implicadas, así como su significado." .

ex:OperacionesAlmacen_7_9_2
    ex:tieneComponente ex:Senal_TAKEPOS, ex:Senal_LEAVEPOS, ex:Senal_NEXTPOS, ex:Senal_MZID .