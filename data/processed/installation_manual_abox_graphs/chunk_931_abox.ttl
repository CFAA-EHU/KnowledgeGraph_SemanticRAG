@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_8be3a77c27 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:CabezalSercosVelocidad ;
    ns1:textoExtracto "No es necesario realizar una nueva búsqueda de referencia cuando el cabezal pase a estar controlado por el CNC." .

ns1:CabezalSercosPosicion a ns1:ComponenteElectrico ;
    rdfs:label "Cabezal Sercos en posición" ;
    ns1:textoExtracto "La consigna en SANALOG vendrá expresada en diezmilésima de grado." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:controla ns1:CabezalMechatrolink ;
    ns1:mitigaRiesgo ns1:AvisoSeguridad_71d7356d95 ;
    ns1:textoExtracto "La consigna indicada en SANALOG no se aplica con rampa, por lo que será responsabilidad del programa de PLC aplicar de forma gradual la consigna cuando sea necesario." .

ns1:AvisoSeguridad_71d7356d95 a ns1:AvisoSeguridad ;
    rdfs:label "Aviso de control sincronizado" ;
    ns1:textoExtracto "Si se intenta controlar un cabezal sincronizado (tanto maestro como esclavo) mediante PLCCNTL, se mostrará un aviso indicando que no es posible." .

ns1:CabezalMechatrolink a ns1:ComponenteElectrico ;
    rdfs:label "Cabezal Mechatrolink" ;
    ns1:textoExtracto "La consigna en SANALOG vendrá expresada en centésimas de hercio." .

ns1:CabezalSercosVelocidad a ns1:ComponenteElectrico ;
    rdfs:label "Cabezal Sercos en velocidad" ;
    ns1:textoExtracto "La consigna en SANALOG vendrá expresada en diezmilésima de rpm." .

