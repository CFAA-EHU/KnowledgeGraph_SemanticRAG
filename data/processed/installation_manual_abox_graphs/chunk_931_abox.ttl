@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Valor0 a ex:ModoOperacion ;
    rdfs:label "0" ;
    ex:textoExtracto "No hay que hacer nada." ;
    ex:valor "0" .

ex:ValorSustitutoPosicion a ex:Parametro ;
    rdfs:label "#" ;
    ex:textoExtracto "Posición en el almacén." ;
    ex:valor "#" .

ex:ValorHerramientaTierra a ex:Herramienta ;
    rdfs:label "-4" ;
    ex:textoExtracto "Herramienta de tierra." ;
    ex:valor "-4" .