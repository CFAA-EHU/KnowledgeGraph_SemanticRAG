@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Pinza1 a ex:Herramienta ;
    rdfs:label "pinza 1" ;
    ex:textoExtracto "herramienta de la pinza ꞏ1ꞏ" .

ex:MarcaCH1TOMZ a ex:AvisoSeguridad ;
    rdfs:label "CH1TOMZ" ;
    ex:textoExtracto "activar la marca CH1TOMZ" .

ex:MarcaMZTOCH1 a ex:AvisoSeguridad ;
    rdfs:label "MZTOCH1" ;
    ex:textoExtracto "activar la marca MZTOCH1" .

ex:MarcaCH1TOSPDL a ex:AvisoSeguridad ;
    rdfs:label "CH1TOSPDL" ;
    ex:textoExtracto "activar la marca CH1TOSPDL" .

ex:TMOPERATION a ex:Parametro ;
    rdfs:label "TMOPERATION" ;
    ex:identificador "6" ;
    ex:textoExtracto "TMOPERATION = 6" .

ex:TAKEPOS a ex:Parametro ;
    rdfs:label "TAKEPOS" ;
    ex:identificador "-4" ;
    ex:textoExtracto "TAKEPOS=-4" ;
    ex:valor "-4" .

ex:HerramientaTierra a ex:PiezaRecambio ;
    rdfs:label "Herramienta de tierra" ;
    ex:textoExtracto "Herramienta de tierra" .

ex:LEAVEPOS a ex:Parametro ;
    rdfs:label "LEAVEPOS" ;
    ex:textoExtracto "LEAVEPOS=# Posición del almacén para dejar la herramienta" .

ex:SecuenciaOperacion a ex:TareaMantenimiento ;
    rdfs:label "Secuencia de operación" ;
    ex:textoExtracto "La secuencia de esta operación es la siguiente. El gestor también admite la secuencia 1-3-2." .

ex:Secuencia1 a ex:TareaMantenimiento ;
    rdfs:label "Secuencia 1" ;
    ex:textoExtracto "1 Coger la herramienta del cabezal con la pinza ꞏ1ꞏ y activar la marca SPDLTOCH1." .

ex:Secuencia2 a ex:TareaMantenimiento ;
    rdfs:label "Secuencia 2" ;
    ex:textoExtracto "2 Dejar la herramienta" .

ex:Secuencia3 a ex:TareaMantenimiento ;
    rdfs:label "Secuencia 3" ;
    ex:textoExtracto "3 Coger la herramienta del almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1." .