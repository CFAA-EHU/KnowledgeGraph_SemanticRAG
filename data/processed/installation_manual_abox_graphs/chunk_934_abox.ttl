@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_b100446be8 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controladoPor ns1:Parametro_4265c12da5 ;
    ns1:monitoreaParametro ns1:VariableParaModificarLaVelocidadDelCabezal ;
    ns1:textoExtracto "El CNC activa la marca MSTROBE y escribe en el registro MFUN la función M correspondiente." ;
    ns1:tieneComponente ns1:MarcaMSTROBE,
        ns1:RegistroMFUN .

ns1:MarcaMSTROBE a ns1:ComponenteElectrico ;
    rdfs:label "Marca MSTROBE" ;
    ns1:textoExtracto "el CNC activa la marca MSTROBE y escribe en el registro MFUN la función M correspondiente." .

ns1:Parametro_4265c12da5 a ns1:Parametro ;
    rdfs:label "Parámetro de cambio automático de gama" ;
    ns1:identificador "AUTOGEAR" ;
    ns1:textoExtracto "El PLC podrá modificar la velocidad del cabezal mediante la variable (V.)PLC.S.sn, pero sin generar un cambio de gama aunque éste sea automático (parámetro AUTOGEAR)." .

ns1:RegistroMFUN a ns1:ComponenteElectrico ;
    rdfs:label "Registro MFUN" ;
    ns1:textoExtracto "el CNC activa la marca MSTROBE y escribe en el registro MFUN la función M correspondiente." .

ns1:VariableParaModificarLaVelocidadDelCabezal a ns1:Parametro ;
    rdfs:label "Variable para modificar la velocidad del cabezal" ;
    ns1:identificador "PLC.S.sn" ;
    ns1:textoExtracto "El PLC podrá modificar la velocidad del cabezal mediante la variable (V.)PLC.S.sn." .

