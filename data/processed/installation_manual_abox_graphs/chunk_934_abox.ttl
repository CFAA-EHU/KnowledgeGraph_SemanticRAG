@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TMOPERATION_7 a ex:TareaMantenimiento ;
    ex:identificador "7" ;
    ex:textoExtracto "TMOPERATION = 7 Dejar la herramienta del cabezal en tierra y coger una herramienta del almacén. TAKEPOS=# Posición del almacén para coger la herramienta. LEAVEPOS=-4 Herramienta de tierra." .

ex:TMOPERATION_8 a ex:TareaMantenimiento ;
    ex:identificador "8" ;
    ex:textoExtracto "TMOPERATION = 8 Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra." .

ex:TMOPERATION_9 a ex:TareaMantenimiento ;
    ex:identificador "9" ;
    ex:textoExtracto "TMOPERATION = 9 Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal. TAKEPOS=-4 Herramienta de tierra. LEAVEPOS=# Posición del almacén para dejar la herramienta." .

ex:Pinza_1 a ex:ComponenteMecanico ;
    ex:textoExtracto "pinza ꞏ1ꞏ" .

ex:HerramientaTierra a ex:PiezaRecambio ;
    ex:textoExtracto "Herramienta de tierra" .

