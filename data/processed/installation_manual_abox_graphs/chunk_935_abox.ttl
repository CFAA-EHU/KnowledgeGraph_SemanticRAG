@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_40d6482c3f a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controladoPor ns1:ComponenteElectrico_40fc375fb9 ;
    ns1:monitoreaParametro ns1:Parametro_c792290cf5 ;
    ns1:textoExtracto "El CNC ignora las peticiones del PLC en los siguientes casos, en los cuales el CNC ignora la marca puesta por el PLC y la borra para que la petición no quede pendiente." .

ns1:ComponenteElectrico_40fc375fb9 a ns1:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ns1:textoExtracto "Si durante la inspección de herramienta, el PLC cambia el sentido de giro de un cabezal con estas marcas, el cambio será identificado en la reposición y aparecerá como pendiente de reposicionar." .

ns1:Parametro_c792290cf5 a ns1:Parametro ;
    rdfs:label "Marca para cada cabezal" ;
    ns1:identificador "SLIMITACSPDL" ;
    ns1:textoExtracto "Hay una marca para cada cabezal. Los mnemónicos para cada cabezal son los siguientes." .

