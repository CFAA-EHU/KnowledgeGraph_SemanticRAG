@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:HerramientaTierra a ex:Herramienta ;
    rdfs:label "Herramienta de tierra" ;
    ex:textoExtracto "Herramienta de tierra" .

ex:Pinza1 a ex:Herramienta ;
    rdfs:label "pinza ꞏ1ꞏ" ;
    ex:textoExtracto "pinza ꞏ1ꞏ" .

ex:MarcaGRTOSPDL a ex:Parametro ;
    rdfs:label "marca GRTOSPDL" ;
    ex:textoExtracto "activar la marca GRTOSPDL" .

ex:MarcaSPDLTOCH1 a ex:Parametro ;
    rdfs:label "marca SPDLTOCH1" ;
    ex:textoExtracto "activar la marca SPDLTOCH1" .

ex:MarcaCH1TOMZ a ex:Parametro ;
    rdfs:label "marca CH1TOMZ" ;
    ex:textoExtracto "activar la marca CH1TOMZ" .

ex:MarcaMZTOCH1 a ex:Parametro ;
    rdfs:label "marca MZTOCH1" ;
    ex:textoExtracto "activar la marca MZTOCH1" .

ex:TMOPERATION10 a ex:Parametro ;
    rdfs:label "TMOPERATION = 10" ;
    ex:textoExtracto "TMOPERATION = 10" .

ex:TAKEPOS a ex:Parametro ;
    rdfs:label "TAKEPOS" ;
    ex:textoExtracto "TAKEPOS=# Posición del almacén para coger la herramienta" .

ex:LEAVEPOS a ex:Parametro ;
    rdfs:label "LEAVEPOS" ;
    ex:textoExtracto "LEAVEPOS=-4" .