@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Pinza1 a ex:Herramienta ;
    rdfs:label "pinza 1" ;
    ex:textoExtracto "Coger la herramienta del almacén con la pinza ꞏ1ꞏ" .

ex:MarcaMZTOCH1 a ex:ModoOperacion ;
    ex:identificador "MZTOCH1" ;
    ex:textoExtracto "activar la marca MZTOCH1" .

ex:MarcaCH1TOSPDL a ex:ModoOperacion ;
    ex:identificador "CH1TOSPDL" ;
    ex:textoExtracto "activar la marca CH1TOSPDL" .

ex:MarcaSPDLTOGR a ex:ModoOperacion ;
    ex:identificador "SPDLTOGR" ;
    ex:textoExtracto "activar la marca SPDLTOGR" .

ex:MarcaMZROT a ex:ModoOperacion ;
    ex:identificador "MZROT" ;
    ex:textoExtracto "Activar la marca MZROT para indicar que ha finalizado la operación" .

ex:TMOPERATION11 a ex:ModoOperacion ;
    ex:identificador "TMOPERATION = 11" ;
    ex:textoExtracto "TMOPERATION = 11 Orientar el almacén. Esta operación es una optimización del cambio de herramienta que permite orientar el almacén durante el mecanizado." .

ex:TMOPERATION13 a ex:ModoOperacion ;
    ex:identificador "TMOPERATION = 13" ;
    ex:textoExtracto "TMOPERATION = 13 Orientar dos almacenes. Esta operación es una optimización del cambio de herramienta que permite orientar dos almacenes durante el mecanizado." .

ex:TMOPERATION14 a ex:ModoOperacion ;
    ex:identificador "TMOPERATION = 14" ;
    ex:textoExtracto "TMOPERATION = 14 Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén." .

ex:MarcaSPDLTOCH1 a ex:ModoOperacion ;
    ex:identificador "SPDLTOCH1" ;
    ex:textoExtracto "activar la marca SPDLTOCH1" .

ex:MarcaCH1TOMZ a ex:ModoOperacion ;
    ex:identificador "CH1TOMZ" ;
    ex:textoExtracto "activar la marca CH1TOMZ" .