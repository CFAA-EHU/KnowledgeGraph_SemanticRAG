@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CicloDeTrabajoDelPWM a ns1:Parametro ;
    rdfs:label "Ciclo de trabajo del PWM" ;
    ns1:identificador "PWMDUTY" ;
    ns1:textoExtracto "Ciclo de trabajo del PWM (entre 1 y 1000; por defecto, 500)." ;
    ns1:valor "500 (por defecto)" .

ns1:ControlDeActivacionDesactivacionDelPWMDesdeElPLC a ns1:Parametro ;
    rdfs:label "Control de activación/desactivación del PWM desde el PLC" ;
    ns1:identificador "PWMON" ;
    ns1:textoExtracto "Esta marca permite activar y desactivar el PWM desde el PLC." .

ns1:FrecuenciaDelPWM a ns1:Parametro ;
    rdfs:label "Frecuencia del PWM" ;
    ns1:identificador "PWMFREQ" ;
    ns1:textoExtracto "Frecuencia del PWM (entre 2 y 5000 Hz; por defecto, 0)." ;
    ns1:valor "0 Hz (por defecto)" .

ns1:IndicadorDeEncendidoDelLaser a ns1:Parametro ;
    rdfs:label "Indicador de encendido del láser" ;
    ns1:identificador "LASERON" ;
    ns1:textoExtracto "El PLC activa está marca para indicar que el láser está encendido." .

ns1:IndicadorDeObturadorAbiertoDelLaser a ns1:Parametro ;
    rdfs:label "Indicador de obturador abierto del láser" ;
    ns1:identificador "SHUTTERON" ;
    ns1:textoExtracto "El PLC activa está marca para indicar que el obturador de la fuente láser está abierto." .

ns1:IndicadorDePreparacionDelLaser a ns1:Parametro ;
    rdfs:label "Indicador de preparación del láser" ;
    ns1:identificador "LASERREADY" ;
    ns1:textoExtracto "El PLC activa está marca para indicar que el láser está preparado." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "La activación del PWM desde el PLC tiene prioridad sobre la activación desde el CNC." .

