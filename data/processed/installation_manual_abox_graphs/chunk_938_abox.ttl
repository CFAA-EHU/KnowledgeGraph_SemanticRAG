@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:ComunicacionPLC_RutinaM06 a ex:Sistema ;
    ex:textoExtracto "La comunicación entre el PLC y la rutina M06 se realiza mediante una serie de marcas y registros genéricos. En el programa de la subrutina M06 que se ofrece como ejemplo se han utilizado las siguientes marcas y registros."@es ;
    rdfs:label "Comunicación PLC-Rutina M06 (marcas y registros)"@es .

### Marcas activadas por rutina M06 (señales de estado)
ex:Marca_M1101 a ex:Parametro ;
    ex:identificador "M1101" ;
    ex:valor "MZTOCH1" ;
    ex:textoExtracto "M1101 | MZTOCH1: La herramienta se ha llevado del almacén a la pinza 1."@es ;
    ex:monitoreaParametro ex:ComunicacionPLC_RutinaM06 .

ex:Marca_M1102 a ex:Parametro ;
    ex:identificador "M1102" ;
    ex:valor "CH1TOSPDL" ;
    ex:textoExtracto "M1102 | CH1TOSPDL: La herramienta se ha llevado de la pinza 1 al cabezal."@es ;
    ex:monitoreaParametro ex:ComunicacionPLC_RutinaM06 .

ex:Marca_M1103 a ex:Parametro ;
    ex:identificador "M1103" ;
    ex:valor "SPDLTOCH1" ;
    ex:textoExtracto "M1103 | SPDLTOCH1: La herramienta se ha llevado del cabezal a la pinza 1."@es ;
    ex:monitoreaParametro ex:ComunicacionPLC_RutinaM06 .

ex:Marca_M1105 a ex:Parametro ;
    ex:identificador "M1105" ;
    ex:valor "CH1TOMZ" ;
    ex:textoExtracto "M1105 | CH1TOMZ: La herramienta se ha llevado de la pinza 1 al almacén."@es ;
    ex:monitoreaParametro ex:ComunicacionPLC_RutinaM06 .

ex:Marca_M1107 a ex:Parametro ;
    ex:identificador "M1107" ;
    ex:valor "SPDLTOGR" ;
    ex:textoExtracto "M1107 | SPDLTOGR: La herramienta se ha llevado del cabezal a tierra."@es ;
    ex:monitoreaParametro ex:ComunicacionPLC_RutinaM06 .

ex:Marca_M1108 a ex:Parametro ;
    ex:identificador "M1108" ;
    ex:valor "GRTOSPDL" ;
    ex:textoExtracto "M1108 | GRTOSPDL: La herramienta se ha llevado de tierra al cabezal."@es ;
    ex:monitoreaParametro ex:ComunicacionPLC_RutinaM06 .

### Funciones M del PLC (acciones controladas)
ex:Funcion_M101 a ex:AccionProhibida ;  # *Nota: "AccionProhibida" usado como aproximación canónica a "función controlada" (no existe clase ex:FuncionPLC)
    ex:identificador "M101" ;
    ex:textoExtracto "M101 | Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1."@es ;
    ex:documentadoEn ex:ComunicacionPLC_RutinaM06 .

ex:Funcion_M102 a ex:AccionProhibida ;
    ex:identificador "M102" ;
    ex:textoExtracto "M102 | Llevar la herramienta de la pinza 1 al cabezal."@es ;
    ex:documentadoEn ex:ComunicacionPLC_RutinaM06 .

ex:Funcion_M103 a ex:AccionProhibida ;
    ex:identificador "M103" ;
    ex:textoExtracto "M103 | Coger la herramienta del cabezal con la pinza 1."@es ;
    ex:documentadoEn ex:ComunicacionPLC_RutinaM06 .

ex:Funcion_M105 a ex:AccionProhibida ;
    ex:identificador "M105" ;
    ex:textoExtracto "M105 | Seleccionar en el almacén la posición que indica LEAVEPOS y dejar la herramienta de la pinza 1."@es ;
    ex:documentadoEn ex:ComunicacionPLC_RutinaM06 .

### Relación entre marcas y funciones (sincronización)
ex:SincronizacionM_AntesAntes a ex:ModoOperacion ;
    ex:textoExtracto "Personalizar todas funciones M con sincronización 'antes - antes' para que continúe el programa tras su finalización."@es ;
    ex:documentadoEn ex:ComunicacionPLC_RutinaM06 .