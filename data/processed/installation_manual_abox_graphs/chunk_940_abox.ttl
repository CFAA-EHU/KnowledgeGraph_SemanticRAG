@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:MSG_T_D_MARCHA a ex:AvisoSeguridad ;
    ex:textoExtracto "MSG [\"Insertar herramienta T%D y pulsar MARCHA\", V.TM.NXTOOL] ; Mensaje al operario para que ponga la herramienta." .

ex:V_PLC_M_1108 a ex:Sensor ;
    ex:identificador "V.PLC.M[1108]" ;
    ex:textoExtracto "V.PLC.M[1108]=1 ; Marca GRTOSPDL al gestor." .

ex:SUB_SPD_GMCHG a ex:TareaMantenimiento ;
    ex:identificador "SUB_SPD_GMCHG" ;
    ex:textoExtracto "Llevar el cabezal al punto de cambio manual." .

ex:SUB_SPD_AUTCHG a ex:TareaMantenimiento ;
    ex:identificador "SUB_SPD_AUTCHG" ;
    ex:textoExtracto "Llevar el cabezal al punto de cambio automático." .

ex:SUB_M6_nc a ex:Esquema ;
    ex:identificador "SUB_M6.nc" ;
    ex:textoExtracto "# RET %SUB_M6.nc #ESBLK ; Activar tratamiento de bloque único" .

ex:DSTOP a ex:Actuador ;
    ex:identificador "DSTOP" ;
    ex:textoExtracto "Deshabilitar tecla STOP" .

ex:M6 a ex:ModoOperacion ;
    ex:identificador "M6" ;
    ex:textoExtracto "Orden al gestor para comenzar el cambio de herramienta." .

ex:V_G_FULLSTATUS a ex:Sensor ;
    ex:identificador "V.G.FULLSTATUS" ;
    ex:textoExtracto "$IF [[[V.G.FULLSTATUS & 255]<9] | [[V.G.FULLSTATUS & 255]>13]]" .

ex:V_G_CNCAUTSTATUS a ex:Sensor ;
    ex:identificador "V.G.CNCAUTSTATUS" ;
    ex:textoExtracto "$IF [[V.G.CNCAUTSTATUS & 4096] | [V.G.CNCAUTSTATUS & 8192]]" .

ex:V_S_EXECUTION a ex:Sensor ;
    ex:identificador "V.S.EXECUTION" ;
    ex:textoExtracto "V.S.EXECUTION = 0 ; Ejecución simulada; teórico o funciones G." .