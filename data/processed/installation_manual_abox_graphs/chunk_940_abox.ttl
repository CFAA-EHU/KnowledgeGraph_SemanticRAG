@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CicloDeTrabajoDelPWM a ns1:Parametro ;
    rdfs:label "Ciclo de trabajo del PWM" ;
    ns1:identificador "PWMDUTY" ;
    ns1:textoExtracto "PWMDUTY Ciclo de trabajo del PWM, cuando el PWM ha sido activado desde el PLC (entre 1 y 1000 décimas de %; por defecto, 500)." .

ns1:ControlDePotenciaATravesDeLaSalidaAnalogicaAsociadaAlCabezal a ns1:Parametro ;
    rdfs:label "Control de potencia a través de la salida analógica asociada al cabezal" ;
    ns1:identificador "ENABLEPWROUT" ;
    ns1:textoExtracto "Esta marca está asociada al control de potencia a través de la salida analógica asociada al cabezal (#PWRCTRL ON [OUT]). El PLC desactiva esta marca para deshabilitar el control de potencia activo." .

ns1:ControlDutyDelPWM a ns1:Parametro ;
    rdfs:label "Control duty del PWM" ;
    ns1:identificador "ENABLEPWRDUTY" ;
    ns1:textoExtracto "Esta marca está asociada al control duty del PWM (#PWRCTRL ON [DUTY]). El PLC desactiva esta marca para deshabilitar el control de duty activo." .

ns1:FrecuenciaDelPWM a ns1:Parametro ;
    rdfs:label "Frecuencia del PWM" ;
    ns1:identificador "PWMFREQ" ;
    ns1:textoExtracto "PWMFREQ Frecuencia del PWM, cuando el PWM ha sido activado desde el PLC (entre 2 y 5000 Hz; por defecto, 0)." .

ns1:HabilitarElPWMActivoEnElCNC a ns1:Parametro ;
    rdfs:label "Habilitar el PWM activo en el CNC" ;
    ns1:identificador "ENABLEPWM" ;
    ns1:textoExtracto "El PLC activa esta marca (cambio de 1 a 0) para habilitar el PWM activo en el CNC; si no hay un PWM activo, esta marca no hace nada." .

