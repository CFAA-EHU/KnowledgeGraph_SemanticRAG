@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ControlDeLaPotenciaDelPWM a ns1:Parametro ;
    rdfs:label "Control de la potencia del PWM" ;
    ns1:documentadoEn ns1:CNC8070_2e76add390 ;
    ns1:identificador "PWMOUT.ENABLEPWRFREQ" ;
    ns1:textoExtracto "Esta marca está asociada al control de la potencia del PWM (#PWRCTRL ON [FREQ])." .

ns1:ControlDutyDelPWM_85f6686216 a ns1:Parametro ;
    rdfs:label "Control duty del PWM" ;
    ns1:documentadoEn ns1:CNC8070_2e76add390 ;
    ns1:identificador "PWRCTRL ON [DUTY]" ;
    ns1:textoExtracto "Esta marca está asociada al control duty del PWM (#PWRCTRL ON [DUTY])." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:controla ns1:CNC8070_2e76add390 ;
    ns1:textoExtracto "El PLC desactiva esta marca para deshabilitar el control de duty activo." .

ns1:CNC8070_2e76add390 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC deshabilita el control de duty, y éste queda fijado al máximo definido en la sentencia #PWMOUT." .

