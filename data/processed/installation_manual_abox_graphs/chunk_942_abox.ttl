@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_1eee4227eb a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El PLC activa esta marca para habilitar el control de potencia activo en el CNC;" .

ns1:ControlDeColisionDelGap a ns1:Parametro ;
    rdfs:label "Control de colisión del gap" ;
    ns1:identificador "GAPCOLLISION" ;
    ns1:textoExtracto "Con esta marca activa, el CNC mostrará o no un error según lo definido en el parámetro GAPCOLLISION." .

ns1:ControlDelLeapfrog a ns1:Parametro ;
    rdfs:label "Control del leapfrog" ;
    ns1:identificador "ENABLELEAP" ;
    ns1:textoExtracto "El PLC desactiva esta marca para deshabilitar el leapfrog activo. El PLC activa esta marca para habilitar el leapfrog activo en el CNC;" .

ns1:Parametro_52680efbc9 a ns1:Parametro ;
    rdfs:label "Marca activa por defecto para control del gap" ;
    ns1:identificador "ENABLEGAP" ;
    ns1:textoExtracto "ENABLEGAP Marca activa por defecto. El PLC desactiva esta marca para deshabilitar el control del gap activo." .

ns1:Parametro_e09f7fcf2e a ns1:Parametro ;
    rdfs:label "Marca activa por defecto para control de potencia del PWM" ;
    ns1:identificador "ENABLEPWRFREQ" ;
    ns1:textoExtracto "ENABLEPWRFREQ Marca activa por defecto. Esta marca está asociada al control de la potencia del PWM (#PWRCTRL ON [FREQ])." .

ns1:RefrescoDelCutView a ns1:Parametro ;
    rdfs:label "Refresco del Cut_View" ;
    ns1:identificador "CVIEWREFRESH" ;
    ns1:textoExtracto "El PLC activa esta marca para refrescar el Cut_View." .

ns1:Sensor_d264e19494 a ns1:Sensor ;
    rdfs:label "Sensor de control del gap" ;
    ns1:textoExtracto "El sensor para el control del gap puede disponer de una señal de colisión que se conecta al CNC," .

