@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SUB_SPD_AUTCHG a ex:TareaMantenimiento ;
    ex:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático." .

ex:SUB_SPD_TO_CH1 a ex:TareaMantenimiento ;
    ex:textoExtracto "LL SUB_SPD_TO_CH1 ; Coger la herramienta del cabezal con la pinza 1." .

ex:SUB_CH1_TO_MZ a ex:TareaMantenimiento ;
    ex:textoExtracto "LL SUB_CH1_TO_MZ ; Dejar la herramienta de la pinza 1 en el almacén." .

ex:SUB_CH1_TO_SPD a ex:TareaMantenimiento ;
    ex:textoExtracto "LL SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal." .

ex:SUB_MZ_TO_CH1 a ex:TareaMantenimiento ;
    ex:textoExtracto "LL SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1." .

ex:SUB_SPD_GMCHG a ex:TareaMantenimiento ;
    ex:textoExtracto "LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual." .

ex:SUB_SPD_TO_GR a ex:TareaMantenimiento ;
    ex:textoExtracto "LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal." .

ex:V_TM_MZWAIT a ex:Parametro ;
    ex:textoExtracto "$WHILE V.TM.MZWAIT == 1 $ENDWHILE ; Espera al gestor del almacén." .