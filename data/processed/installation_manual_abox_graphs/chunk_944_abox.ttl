@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:RutinaM06 a ex:TareaMantenimiento ;
    rdfs:label "Rutina M06 (Cambio de herramienta automático)"@es ;
    ex:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático. [...] $ENDIF"@es ;
    ex:identificador "M06" .

ex:Subrutina_SPD_AUTCHG a ex:ModoOperacion ;
    rdfs:label "Subrutina SPD_AUTCHG"@es ;
    ex:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático."@es ;
    ex:identificador "SUB_SPD_AUTCHG" .

ex:Subrutina_SPD_TO_CH1 a ex:ModoOperacion ;
    rdfs:label "Subrutina SPD_TO_CH1"@es ;
    ex:textoExtracto "LL SUB_SPD_TO_CH1 ; Coger la herramienta del cabezal con la pinza 1."@es ;
    ex:identificador "SUB_SPD_TO_CH1" .

ex:Subrutina_CH1_TO_MZ a ex:ModoOperacion ;
    rdfs:label "Subrutina CH1_TO_MZ"@es ;
    ex:textoExtracto "LL SUB_CH1_TO_MZ ; Dejar la herramienta de la pinza 1 en el almacén."@es ;
    ex:identificador "SUB_CH1_TO_MZ" .

ex:Subrutina_MZ_TO_CH1 a ex:ModoOperacion ;
    rdfs:label "Subrutina MZ_TO_CH1"@es ;
    ex:textoExtracto "LL SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1."@es ;
    ex:identificador "SUB_MZ_TO_CH1" .

ex:Subrutina_CH1_TO_SPD a ex:ModoOperacion ;
    rdfs:label "Subrutina CH1_TO_SPD"@es ;
    ex:textoExtracto "LL SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal."@es ;
    ex:identificador "SUB_CH1_TO_SPD" .

ex:Subrutina_SPD_GMCHG a ex:ModoOperacion ;
    rdfs:label "Subrutina SPD_GMCHG"@es ;
    ex:textoExtracto "LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual."@es ;
    ex:identificador "SUB_SPD_GMCHG" .

ex:Subrutina_SPD_TO_GR a ex:ModoOperacion ;
    rdfs:label "Subrutina SPD_TO_GR"@es ;
    ex:textoExtracto "LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal."@es ;
    ex:identificador "SUB_SPD_TO_GR" .

ex:CondicionMZWAIT a ex:Parametro ;
    rdfs:label "Parámetro V.TM.MZWAIT"@es ;
    ex:textoExtracto "$WHILE V.TM.MZWAIT == 1 [...] Espera al gestor del almacén."@es ;
    ex:identificador "V.TM.MZWAIT" ;
    ex:valor "1" .

ex:RutinaM06 ex:compuestoPor ex:Subrutina_SPD_AUTCHG ,
                               ex:Subrutina_SPD_TO_CH1 ,
                               ex:Subrutina_CH1_TO_MZ ,
                               ex:Subrutina_MZ_TO_CH1 ,
                               ex:Subrutina_CH1_TO_SPD ,
                               ex:Subrutina_SPD_GMCHG ,
                               ex:Subrutina_SPD_TO_GR .

ex:RutinaM06 ex:monitoreaParametro ex:CondicionMZWAIT .