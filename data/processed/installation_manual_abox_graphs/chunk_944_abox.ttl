@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_9a81a020e7 a ns1:Parametro ;
    rdfs:label "GAPMAX",
        "GAPMIN",
        "GAPTOL" ;
    ns1:textoExtracto "Esta marca permanece activa hasta iniciar la ejecución de un programa. OUTOFTOL El PLC activa esta marca para indicar que la boquilla ha salido alguna vez de la tolerancia del gap (parámetro GAPTOL) durante la ejecución del programa." .

