@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:LL_SUB_SPD_TO_GR a ex:ComponenteElectrico ;
    rdfs:label "LL SUB_SPD TO GR" ;
    ex:textoExtracto "cambio manual. LL SUB_SPD_TO_GR" .

ex:BREAK a ex:ComponenteElectrico ;
    rdfs:label "BREAK" ;
    ex:textoExtracto "$BREAK" .

ex:ENDSWITCH a ex:ComponenteElectrico ;
    rdfs:label "ENDSWITCH" ;
    ex:textoExtracto "$ENDSWITCH" .

ex:WHILE_V_TM_MZWAIT a ex:ComponenteElectrico ;
    rdfs:label "WHILE V.TM.MZWAIT" ;
    ex:textoExtracto "$WHILE V.TM.MZWAIT == 1 $ENDWHILE" .

ex:ESTOP a ex:ComponenteElectrico ;
    rdfs:label "ESTOP" ;
    ex:textoExtracto "# ESTOP" .

ex:RET a ex:ComponenteElectrico ;
    rdfs:label "RET" ;
    ex:textoExtracto "# RET" .

ex:DSBLK a ex:ComponenteElectrico ;
    rdfs:label "DSBLK" ;
    ex:textoExtracto "#DSBLK" .