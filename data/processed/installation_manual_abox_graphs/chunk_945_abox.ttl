@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:RutinaM06 a ex:ModoOperacion ;
    rdfs:label "Rutina M06" ;
    ex:textoExtracto "cambio manual. LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal. [...] # RET" ;
    ex:identificador "M06" .

ex:Subrutina_SUB_SPD_TO_GR a ex:TareaMantenimiento ;
    rdfs:label "SUB_SPD_TO_GR" ;
    ex:textoExtracto "LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal." ;
    ex:ejecutadoPor ex:RutinaM06 .

ex:TeclaSTOP a ex:ElementoSeguridad ;
    rdfs:label "Tecla STOP" ;
    ex:textoExtracto "# ESTOP ; Habilitar la tecla STOP." ;
    ex:habilitadoPor ex:RutinaM06 .

ex:GestorAlmacen a ex:Sistema ;
    rdfs:label "Gestor del almacén" ;
    ex:textoExtracto "$WHILE V.TM.MZWAIT == 1 $ENDWHILE ; Espera al gestor del almacén." ;
    ex:monitoreaParametro ex:ParametroMZWAIT .

ex:ParametroMZWAIT a ex:Parametro ;
    rdfs:label "V.TM.MZWAIT" ;
    ex:textoExtracto "V.TM.MZWAIT" ;
    ex:valor "1" .