@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:TMOPERATION ex:textoExtracto "Cuando se ejecuta la función –T– Cuando se ejecuta la función T el gestor envía al PLC el código TMOPERATION=11." ;
    a ex:Parametro ;
    ex:identificador "TMOPERATION=11" ;
    ex:valor "11" .

ex:MZROT ex:textoExtracto "Activar la marca MZROT para indicar al gestor que se ha finalizado la operación." ;
    a ex:ComponenteElectrico ;
    rdfs:label "MZROT" .

ex:M06 ex:textoExtracto "Cada vez que la rutina M06 finaliza una acción se lo indica al PLC para que active la marca correspondiente del gestor." ;
    a ex:TareaMantenimiento ;
    rdfs:label "M06" .

ex:MZTOCH1 ex:textoExtracto "DFU M1101 = SET MZTOCH1 DFD MZTOCH1 = RES M1101 La herramienta se ha llevado del almacén a la pinza 1." ;
    a ex:ComponenteElectrico ;
    rdfs:label "MZTOCH1" .

ex:CH1TOSPDL ex:textoExtracto "DFU M1102 = SET CH1TOSPDL DFD CH1TOSPDL = RES M1102 La herramienta se ha llevado de la pinza 1 al cabezal." ;
    a ex:ComponenteElectrico ;
    rdfs:label "CH1TOSPDL" .

ex:SPDLTOCH1 ex:textoExtracto "DFU M1103 = SET SPDLTOCH1 DFD SPDLTOCH1 = RES M1103 La herramienta se ha llevado del cabezal a la pinza 1." ;
    a ex:ComponenteElectrico ;
    rdfs:label "SPDLTOCH1" .

ex:CH1TOMZ ex:textoExtracto "DFU M1105 = SET CH1TOMZ DFD CH1TOMZ = RES M1105 La herramienta se ha llevado de la pinza 1 al almacén." ;
    a ex:ComponenteElectrico ;
    rdfs:label "CH1TOMZ" .

ex:SPDLTOGR ex:textoExtracto "DFU M1107 = SET SPDLTOGR DFD SPDLTOGR = RES M1107 La herramienta se ha llevado del cabezal a tierra." ;
    a ex:ComponenteElectrico ;
    rdfs:label "SPDLTOGR" .

ex:GRTOSPDL ex:textoExtracto "DFU M1108 = SET GRTOSPDL DFD GRTOSPDL = RES M1108 La herramienta se ha llevado de tierra al cabezal." ;
    a ex:ComponenteElectrico ;
    rdfs:label "GRTOSPDL" .

ex:M101 ex:textoExtracto "M101 Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1." ;
    a ex:TareaMantenimiento ;
    rdfs:label "M101" .

ex:M102 ex:textoExtracto "M102 Llevar la herramienta de la pinza 1 al cabezal." ;
    a ex:TareaMantenimiento ;
    rdfs:label "M102" .

ex:M103 ex:textoExtracto "M103 Coger la herramienta del cabezal con la pinza 1." ;
    a ex:TareaMantenimiento ;
    rdfs:label "M103" .

ex:TAKEPOS ex:textoExtracto "M101 Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1." ;
    a ex:Parametro ;
    rdfs:label "TAKEPOS" .