@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_c55e3d90df a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC consulta esta marca para saber si la herramienta está ejecutando (=1) o no (=0)." .

ns1:Parametro_0ec228a4f0 a ns1:Parametro ;
    rdfs:label "Marca que indica que la herramienta debe ser rechazada" ;
    ns1:identificador "TREJECTC1" ;
    ns1:textoExtracto "Si el PLC pone esta marca a (=1) el CNC entiende que la herramienta debe ser rechazada." .

ns1:Parametro_172ce6feaa a ns1:Parametro ;
    rdfs:label "Marca para cancelar la emergencia del gestor de herramientas" ;
    ns1:identificador "RESTMEMZ1" ;
    ns1:textoExtracto "El PLC pone esta marca a (=1) para cancelar la emergencia del gestor de herramientas." .

ns1:Parametro_555083edd4 a ns1:Parametro ;
    rdfs:label "Marca que indica si la herramienta está ejecutando" ;
    ns1:identificador "CUTTINGONC1" ;
    ns1:textoExtracto "El CNC consulta esta marca para saber si la herramienta está ejecutando (=1) o no (=0)." .

ns1:Parametro_88e4dec094 a ns1:Parametro ;
    rdfs:label "Marca para activar la emergencia del gestor de herramientas" ;
    ns1:identificador "SETTMEMZ1" ;
    ns1:textoExtracto "El PLC pone esta marca a (=1) para activar la emergencia del gestor de herramientas." .

