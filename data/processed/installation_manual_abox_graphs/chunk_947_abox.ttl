@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:M101 a ex:TareaMantenimiento ;
    rdfs:label "M101" ;
    ex:identificador "M101" ;
    ex:textoExtracto "Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1." .

ex:M102 a ex:TareaMantenimiento ;
    rdfs:label "M102" ;
    ex:identificador "M102" ;
    ex:textoExtracto "Llevar la herramienta de la pinza 1 al cabezal." .

ex:M103 a ex:TareaMantenimiento ;
    rdfs:label "M103" ;
    ex:identificador "M103" ;
    ex:textoExtracto "Coger la herramienta del cabezal con la pinza 1." .

ex:M105 a ex:TareaMantenimiento ;
    rdfs:label "M105" ;
    ex:identificador "M105" ;
    ex:textoExtracto "Seleccionar en el almacén la posición que indica LEAVEPOS y dejar la herramienta de la pinza 1." .

ex:TAKEPOS a ex:Parametro ;
    rdfs:label "TAKEPOS" ;
    ex:identificador "TAKEPOS" ;
    ex:textoExtracto "Este registro indica la posición de almacén en la que hay que coger la herramienta." .

ex:LEAVEPOS a ex:Parametro ;
    rdfs:label "LEAVEPOS" ;
    ex:identificador "LEAVEPOS" ;
    ex:textoExtracto "Este registro indica la posición de almacén en la que hay que dejar la herramienta." .