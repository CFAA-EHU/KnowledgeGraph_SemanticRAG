@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Registro_LEAVEPOS
    a ex:Parametro ;
    rdfs:label "Registro LEAVEPOS" ;
    ex:textoExtracto "LEAVEPOS: Este registro indica la posición de almacén en la que hay que dejar la herramienta." ;
    ex:identificador "LEAVEPOS" .

ex:Registro_TAKEPOS
    a ex:Parametro ;
    rdfs:label "Registro TAKEPOS" ;
    ex:textoExtracto "TAKEPOS: Este registro indica la posición de almacén que ocupa la herramienta que hay que coger." ;
    ex:identificador "TAKEPOS" .

ex:SenalEmergenciaGestor
    a ex:Alarma ;
    rdfs:label "Señal de emergencia del gestor de herramientas" ;
    ex:textoExtracto "Señal de emergencia del gestor. Tratamiento de la señal de emergencia del gestor de herramientas." .

ex:Tecla_USER12
    a ex:InterfazUsuario ;
    rdfs:label "Tecla USER12" ;
    ex:textoExtracto "Si se pulsa la tecla USER12 se activa la emergencia." ;
    ex:identificador "USER12" ;
    ex:activaAlarma ex:SenalEmergenciaGestor .

ex:Lampara_USER12
    a ex:InterfazUsuario ;
    rdfs:label "Lámpara de la tecla USER12" ;
    ex:textoExtracto "Lámpara de la tecla USER12 iluminada cuando hay emergencia." ;
    ex:identificador "B11KEYLED1" .

ex:Tecla_USER13
    a ex:InterfazUsuario ;
    rdfs:label "Tecla USER13" ;
    ex:textoExtracto "Si se pulsa la tecla USER13 se quita la emergencia." ;
    ex:identificador "USER13" .