@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:AlmacenSincronoConBrazoCambiador_949 a ex:Sistema ;
    ex:textoExtracto "Los almacenes síncronos con brazo cambiador (1 o 2 pinzas) tienen el almacén próximo al cabezal y el cambio se realiza con ayuda del brazo cambiador." ;
    ex:compuestoPor ex:BrazoCambiador_949, ex:Almacen_949 .

ex:BrazoCambiador_949 a ex:ComponenteMecanico ;
    ex:textoExtracto "brazo cambiador" .

ex:Almacen_949 a ex:Componente ;
    ex:textoExtracto "almacén" .

ex:Gestor_949 a ex:Sistema ;
    ex:textoExtracto "gestor" ;
    ex:controla ex:PLC_949 ;
    ex:controla ex:CNC_949 .

ex:PLC_949 a ex:ComponenteElectrico ;
    ex:textoExtracto "PLC" .

ex:CNC_949 a ex:ComponenteElectrico ;
    ex:textoExtracto "CNC" .

ex:FuncionT_949 a ex:ModoOperacion ;
    ex:textoExtracto "función T" ;
    ex:ejecutadoPor ex:CNC_949 ;
    ex:ejecutadoPor ex:Gestor_949 .

ex:FuncionM06_949 a ex:ModoOperacion ;
    ex:textoExtracto "función M06" ;
    ex:ejecutadoPor ex:CNC_949 ;
    ex:ejecutadoPor ex:Gestor_949 .

ex:RutinaAsociadaM06_949 a ex:TareaMantenimiento ;
    ex:textoExtracto "rutina asociada a M06" ;
    ex:ejecutadoPor ex:Gestor_949 .