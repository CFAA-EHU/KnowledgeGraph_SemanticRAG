@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:AlmacenSincrono_Brazo2Pinzas
    a                     ex:Sistema ;
    rdfs:label            "Almacén síncrono con brazo cambiador de 2 pinzas"@es ;
    ex:textoExtracto      "Los almacenes síncronos con brazo cambiador (1 o 2 pinzas) tienen el almacén próximo al cabezal y el cambio se realiza con ayuda del brazo cambiador. No es posible efectuar el cambio de herramienta durante el mecanizado de la pieza."@es ;
    ex:compuestoPor       ex:BrazoCambiador_2Pinzas ;
    ex:compuestoPor       ex:AlmacenHerramientas_ProximoCabezal ;
    ex:controla          ex:CambioHerramienta_Proceso .

ex:BrazoCambiador_2Pinzas
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Brazo cambiador de 2 pinzas"@es ;
    ex:textoExtracto      "el cambio se realiza con ayuda del brazo cambiador"@es .

ex:AlmacenHerramientas_ProximoCabezal
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Almacén de herramientas próximo al cabezal"@es ;
    ex:textoExtracto      "tienen el almacén próximo al cabezal"@es .

ex:CambioHerramienta_Proceso
    a                     ex:TareaMantenimiento ;
    rdfs:label            "Proceso de cambio de herramienta (T + M06)"@es ;
    ex:textoExtracto      "La comunicación entre el gestor y el PLC se realiza en 2 fases; la primera con la ejecución de la función T y la segunda con la ejecución de la función M06."@es ;
    ex:requiereMantenimiento ex:SistemaGestion_CNC_PLC ;
    ex:ejecutadoPor       ex:GestorHerramientas ;
    ex:ejecutadoPor       ex:PLC_ControlAlmacen .

ex:SistemaGestion_CNC_PLC
    a                     ex:Sistema ;
    rdfs:label            "Sistema de gestión CNC-PLC para cambio de herramienta"@es ;
    ex:textoExtracto      "La comunicación entre el gestor y el PLC se realiza en 2 fases; [...] Se aconseja incluir la gestión del cambio de herramienta en la rutina asociada a M06 y dejar como labor del PLC el control de los dispositivos externos."@es ;
    ex:compuestoPor       ex:GestorHerramientas ;
    ex:compuestoPor       ex:PLC_ControlAlmacen .

ex:GestorHerramientas
    a                     ex:InterfazUsuario ;
    rdfs:label            "Gestor de herramientas (interfaz CNC)"@es ;
    ex:textoExtracto      "El gestor envía una orden al PLC para que seleccione la próxima herramienta en el almacén [...] El gestor envía una orden al PLC para efectuar el cambio."@es ;
    ex:controla          ex:PLC_ControlAlmacen .

ex:PLC_ControlAlmacen
    a                     ex:Actuador ;
    rdfs:label            "PLC de control del almacén y brazo cambiador"@es ;
    ex:textoExtracto      "el PLC el control de los dispositivos externos. Utilizar funciones auxiliares para gobernar desde la rutina M06 los desplazamientos de los distintos dispositivos (giro almacén, desplazamiento almacén, brazo cambiador, etc.)."@es ;
    ex:controla          ex:BrazoCambiador_2Pinzas ;
    ex:controla          ex:AlmacenHerramientas_ProximoCabezal ;
    ex:controla          ex:DispositivoGiro_Almacen ;
    ex:controla          ex:DispositivoDesplazamiento_Almacen .

ex:DispositivoGiro_Almacen
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Dispositivo de giro del almacén"@es ;
    ex:textoExtracto      "giro almacén"@es .

ex:DispositivoDesplazamiento_Almacen
    a                     ex:ComponenteMecanico ;
    rdfs:label            "Dispositivo de desplazamiento del almacén"@es ;
    ex:textoExtracto      "desplazamiento almacén"@es .

ex:FuncionT_CNC a ex:Tabla ;
     a                     ex:Parametro ;
    rdfs:label            "Función T (selección de herramienta)"@es ;
    ex:textoExtracto      "ejecución de la función T. [...] seleccione la próxima herramienta en el almacén"@es ;
    ex:monitoreaParametro ex:SistemaGestion_CNC_PLC .

ex:FuncionM06_CNC a ex:Tabla ;
     a                     ex:Parametro ;
    rdfs:label            "Función M06 (cambio de herramienta)"@es ;
    ex:textoExtracto      "ejecución de la función M06. [...] debe comenzar el cambio de herramienta"@es ;
    ex:monitoreaParametro ex:SistemaGestion_CNC_PLC ;
    ex:requiereMantenimiento ex:CambioHerramienta_Proceso .