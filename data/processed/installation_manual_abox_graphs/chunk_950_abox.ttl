@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Parametro_4cee47112d a ns1:Parametro ;
    rdfs:label "Marca para indicar que la herramienta del cabezal ha sido llevada a tierra" ;
    ns1:identificador "GRTOSPDLC1" ;
    ns1:textoExtracto "GRTOSPDLC1 (también se puede programar como GRTOSPDL)" .

ns1:Parametro_756de140b9 a ns1:Parametro ;
    rdfs:label "Marca para indicar que la herramienta de tierra ha sido llevada al cabezal" ;
    ns1:identificador "MZTOSPDLMZ1" ;
    ns1:textoExtracto "MZTOSPDLMZ1 (también se puede programar como MZTOSPDL)" .

ns1:Parametro_ad5468fa66 a ns1:Parametro ;
    rdfs:label "Marca para indicar que la herramienta del almacén ha sido llevada al cabezal" ;
    ns1:identificador "SPDLTOMZ1" ;
    ns1:textoExtracto "SPDLTOMZ1 (también se puede programar como SPDLTOMZ)" .

ns1:Parametro_b8fd6e0f69 a ns1:Parametro ;
    rdfs:label "Marca para indicar que la torreta ha girado y el cambio de herramienta se ha efectuado" ;
    ns1:identificador "TCHANGEOKMZ1" ;
    ns1:textoExtracto "TCHANGEOKMZ1 (equivalente a TCHANGEOK)" .

ns1:Parametro_f8c2611a95 a ns1:Parametro ;
    rdfs:label "Marca para indicar que la herramienta del cabezal ha sido llevada al almacén" ;
    ns1:identificador "MZROTMZ1" ;
    ns1:textoExtracto "MZROTMZ1 (también se puede programar como MZROT)" .

