@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:Tabla950_1 a ex:Tabla ;
    ex:textoExtracto "Operaciones válidas del gestor de herramientas para este almacén. Las operaciones posibles en este tipo de almacén son las siguientes. | TMOPERATION | Significado. |" ;
    ex:tieneComponente ex:TMOPERATION_0, ex:TMOPERATION_1, ex:TMOPERATION_2, ex:TMOPERATION_3, ex:TMOPERATION_4, ex:TMOPERATION_5, ex:TMOPERATION_6, ex:TMOPERATION_7, ex:TMOPERATION_8, ex:TMOPERATION_9, ex:TMOPERATION_10, ex:TMOPERATION_11, ex:TMOPERATION_12, ex:TMOPERATION_13, ex:TMOPERATION_14 .

ex:TMOPERATION_0 a ex:ModoOperacion ;
    ex:identificador "0" ;
    ex:textoExtracto "No hay que hacer nada." .

ex:TMOPERATION_1 a ex:ModoOperacion ;
    ex:identificador "1" ;
    ex:textoExtracto "Coger una herramienta del almacén y ponerla en el cabezal." .

ex:TMOPERATION_2 a ex:ModoOperacion ;
    ex:identificador "2" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén." .

ex:TMOPERATION_3 a ex:ModoOperacion ;
    ex:identificador "3" ;
    ex:textoExtracto "Poner en el cabezal una herramienta de tierra." .

ex:TMOPERATION_4 a ex:ModoOperacion ;
    ex:identificador "4" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en tierra." .

ex:TMOPERATION_5 a ex:ModoOperacion ;
    ex:identificador "5" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén." .

ex:TMOPERATION_6 a ex:ModoOperacion ;
    ex:identificador "6" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger una herramienta de tierra." .

ex:TMOPERATION_7 a ex:ModoOperacion ;
    ex:identificador "7" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en tierra y coger una herramienta del almacén." .

ex:TMOPERATION_8 a ex:ModoOperacion ;
    ex:identificador "8" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra." .

ex:TMOPERATION_9 a ex:ModoOperacion ;
    ex:identificador "9" ;
    ex:textoExtracto "Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal." .

ex:TMOPERATION_10 a ex:ModoOperacion ;
    ex:identificador "10" ;
    ex:textoExtracto "Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal." .

ex:TMOPERATION_11 a ex:ModoOperacion ;
    ex:identificador "11" ;
    ex:textoExtracto "Orientar el almacén." .

ex:TMOPERATION_12 a ex:ModoOperacion ;
    ex:identificador "12" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén (como TMOPERATION=5). Es una operación optimizada válida sólo en los siguientes tipos de almacén síncrono. • Tipo no-random con brazo cambiador de dos pinzas. • Tipo random cuando se trata de herramientas especiales." .

ex:TMOPERATION_13 a ex:ModoOperacion ;
    ex:identificador "13" ;
    ex:textoExtracto "Orientar dos almacenes." .

ex:TMOPERATION_14 a ex:ModoOperacion ;
    ex:identificador "14" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén." .