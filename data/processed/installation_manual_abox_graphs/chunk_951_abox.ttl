@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:TablaOperacionesPLC a ex:Tabla ;
     a                       ex:Tabla ;
    rdfs:label              "Tabla de operaciones válidas y marcas PLC (TMOPERATION 5-14)"@es ;
    ex:textoExtracto        """
    | TMOPERATION | TAKEPOS | LEAVEPOS | PLC => TM (marcas) |
    |--------------|---------|----------|---------------------|
    | 5            | #       | #        | (SPDLTOCH2 & MZTOCH1) + (CH1TOSPDL & CH2TOMZ) |
    | 6            | -4      | #        | SPDLTOCH2 + (CH2TOMZ & GRTOSPDL) |
    | 7            | #       | -4       | (SPDLTOGR & MZTOCH1) + CH1TOSPDL |
    | 8            | 0       | 0        | SPDLTOGR + GRTOSPDL |
    | 9            | -4      | #        | GRTOSPDL + SPDLTOCH2 + CH2TOMZ |
    | 10           | #       | -4       | MZTOCH1 + CH1TOSPDL + SPDLTOGR |
    | 11           | 0       | 0        | MZROT |
    | 12           | #       | #        | SPDLTOCH2 + CH2TOMZ + MZTOCH1 + CH1TOSPDL |
    | 13           | #       | 0        | MZROT + MZROT |
    | 14           | #       | #        | SPDLTOCH2 + CH2TOMZ + MZTOCH1 + CH1TOSPDL |
    """@es ;
    ex:identificador         "TMOPERATION 5-14" .

ex:ParametroTAKEPOS
    a                       ex:Parametro ;
    rdfs:label              "TAKEPOS" ;
    ex:textoExtracto        "Valores TAKEPOS en operaciones 5-14 (ej: #, -4, 0)"@es ;
    ex:documentadoEn        ex:TablaOperacionesPLC .

ex:ParametroLEAVEPOS
    a                       ex:Parametro ;
    rdfs:label              "LEAVEPOS" ;
    ex:textoExtracto        "Valores LEAVEPOS en operaciones 5-14 (ej: #, -4, 0)"@es ;
    ex:documentadoEn        ex:TablaOperacionesPLC .

ex:HerramientaTierra
    a                       ex:Herramienta ;
    rdfs:label              "Herramienta de tierra"@es ;
    ex:textoExtracto        "-4 => Herramienta de tierra"@es ;
    ex:identificador         "-4" .

ex:PosicionAlmacen
    a                       ex:Parametro ;
    rdfs:label              "Posición en el almacén"@es ;
    ex:textoExtracto        "# => Posición en el almacén"@es ;
    ex:identificador         "#" .

ex:EstadoInactivo
    a                       ex:Parametro ;
    rdfs:label              "No hay que hacer nada"@es ;
    ex:textoExtracto        "0 => No hay que hacer nada"@es ;
    ex:identificador         "0" .