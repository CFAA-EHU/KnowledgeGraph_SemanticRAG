@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:SistemaCambioHerramientas_952
    a               ex:Sistema ;
    rdfs:label      "Sistema de cambio de herramientas (no-random)"@es ;
    ex:textoExtracto "El almacén es no-random, cada herramienta ocupa la posición de su mismo número y las herramientas T7, T8 y T9 son de tierra."@es ;
    ex:tieneComponente
        ex:Herramienta_T7_952 ,
        ex:Herramienta_T8_952 ,
        ex:Herramienta_T9_952 .

ex:Herramienta_T7_952
    a               ex:Herramienta ;
    ex:identificador "T7" ;
    ex:textoExtracto "herramienta T7 [...] son de tierra"@es .

ex:Herramienta_T8_952
    a               ex:Herramienta ;
    ex:identificador "T8" ;
    ex:textoExtracto "herramienta T8 [...] son de tierra"@es .

ex:Herramienta_T9_952
    a               ex:Herramienta ;
    ex:identificador "T9" ;
    ex:textoExtracto "herramienta T9 [...] son de tierra"@es .

ex:InterfazPLC_CNC_952
    a               ex:InterfazUsuario ;
    rdfs:label      "Interfaz PLC-CNC para operaciones de cambio de herramienta"@es ;
    ex:textoExtracto "las funciones que ejecuta el CNC, los valores que envía el gestor al PLC en cada una de las operaciones y las marcas que debe activar el PLC en cada caso"@es ;
    ex:controla    ex:SistemaCambioHerramientas_952 .