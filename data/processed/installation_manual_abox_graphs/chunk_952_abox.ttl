@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EnciendeElLedDeLasTeclasDeUsuarioEnElOctavoPanelDeMando a ns1:Parametro ;
    rdfs:label "Enciende el led de las teclas de usuario en el octavo panel de mando" ;
    ns1:identificador "KEYLED1_8" ;
    ns1:textoExtracto "Estos registros encienden los led (bit=1) de las teclas de usuario en un panel de mando. El registro KEYLED1_8 corresponde al octavo panel de mando." .

ns1:EnciendeElLedDeLasTeclasDeUsuarioEnElPrimerPanelDeMando a ns1:Parametro ;
    rdfs:label "Enciende el led de las teclas de usuario en el primer panel de mando" ;
    ns1:identificador "KEYLED1_1" ;
    ns1:textoExtracto "Estos registros encienden los led (bit=1) de las teclas de usuario en un panel de mando. El registro KEYLED1_1 corresponde al primer panel de mando." .

ns1:EnciendeElLedDeLasTeclasDeUsuarioEnTodosLosPanelesDeMandoSimultaneamente a ns1:Parametro ;
    rdfs:label "Enciende el led de las teclas de usuario en todos los paneles de mando simultáneamente" ;
    ns1:identificador "KEYLED1" ;
    ns1:textoExtracto "Este registro enciende el led (bit=1) de las teclas de usuario en todos los paneles de mando simultáneamente." .

ns1:EnciendeElLedDeLasTeclasEnElOctavoModuloOPPANELHE a ns1:Parametro ;
    rdfs:label "Enciende el led de las teclas en el octavo módulo OP-PANEL-H/E" ;
    ns1:identificador "KEYLED2_8" ;
    ns1:textoExtracto "Estos registros encienden los led (bit=1) de las siguientes teclas, en el módulo OP-PANEL-H/E. El registro KEYLED2_8 corresponde al octavo panel de mando." .

ns1:EnciendeElLedDeLasTeclasEnElPrimerModuloOPPANELHE a ns1:Parametro ;
    rdfs:label "Enciende el led de las teclas en el primer módulo OP-PANEL-H/E" ;
    ns1:identificador "KEYLED2_1" ;
    ns1:textoExtracto "Estos registros encienden los led (bit=1) de las siguientes teclas, en el módulo OP-PANEL-H/E. El registro KEYLED2_1 corresponde al primer panel de mando." .

ns1:EnciendeElLedDeLasTeclasEnTodosLosModulosOPPANELHESimultaneamente a ns1:Parametro ;
    rdfs:label "Enciende el led de las teclas en todos los módulos OP-PANEL-H/E simultáneamente" ;
    ns1:identificador "KEYLED2" ;
    ns1:textoExtracto "Este registro enciende el led (bit=1) de las teclas en todos los módulos OP-PANEL-H/E simultáneamente." .

