@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:EnciendeLosLEDDeLasTeclasDelPrimerVolanteHBLS a ns1:Parametro ;
    rdfs:label "Enciende los LED de las teclas del primer volante HBLS" ;
    ns1:identificador "KEYLEDHBLS1" ;
    ns1:textoExtracto "El registro KEYLEDHBLS1 corresponde al primer volante." .

ns1:EnciendeLosLEDDeLasTeclasDelSegundoVolanteHBLS a ns1:Parametro ;
    rdfs:label "Enciende los LED de las teclas del segundo volante HBLS" ;
    ns1:identificador "KEYLEDHBLS2" ;
    ns1:textoExtracto "El registro KEYLEDHBLS2 corresponde al segundo volante." .

ns1:InhibeLasTeclasYLosConmutadoresEnElOctavoPanelDeMando a ns1:Parametro ;
    rdfs:label "Inhibe las teclas y los conmutadores en el octavo panel de mando" ;
    ns1:identificador "KEYDIS2_8" ;
    ns1:textoExtracto "Los registros KEYDIS1_1 a KEYDIS4_1 corresponden al primer panel de mando, KEYDIS1_2 a KEYDIS4_2 al segundo y así sucesivamente." .

ns1:InhibeLasTeclasYLosConmutadoresEnElPrimerPanelDeMando a ns1:Parametro ;
    rdfs:label "Inhibe las teclas y los conmutadores en el primer panel de mando" ;
    ns1:identificador "KEYDIS1_1" ;
    ns1:textoExtracto "Los registros KEYDIS1_1 a KEYDIS4_1 corresponden al primer panel de mando." .

ns1:InhibeLasTeclasYLosConmutadoresEnTodosLosPanelesDeMandoSimultaneamente a ns1:Parametro ;
    rdfs:label "Inhibe las teclas y los conmutadores en todos los paneles de mando simultáneamente" ;
    ns1:identificador "KEYDIS1" ;
    ns1:textoExtracto "Estos registros inhiben (bit=1) las teclas y los conmutadores en todos los paneles de mando simultáneamente." .

