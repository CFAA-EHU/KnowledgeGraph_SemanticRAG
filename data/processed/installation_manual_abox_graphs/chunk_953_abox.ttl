@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:OperacionesAlmacen_7_10_2
    a ex:ModoOperacion ;
    rdfs:label "Descripción detallada de las operaciones del almacén" ;
    ex:textoExtracto "A continuación se muestra una descripción detallada de las operaciones válidas para este almacén. Para cada operación se indica cuales de las señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas, así como su significado. También aparece cuál es la secuencia a seguir para completar la operación." ;
    ex:identificador "7.10.2" .

ex:Senal_TAKEPOS
    a ex:Parametro ;
    rdfs:label "TAKEPOS" ;
    ex:textoExtracto "Las señales TAKEPOS, LEAVEPOS y NEXTPOS pueden tomar los siguientes valores." ;
    ex:monitoreaParametro ex:OperacionesAlmacen_7_10_2 .

ex:Senal_LEAVEPOS
    a ex:Parametro ;
    rdfs:label "LEAVEPOS" ;
    ex:textoExtracto "Las señales TAKEPOS, LEAVEPOS y NEXTPOS pueden tomar los siguientes valores." ;
    ex:monitoreaParametro ex:OperacionesAlmacen_7_10_2 .

ex:Senal_NEXTPOS
    a ex:Parametro ;
    rdfs:label "NEXTPOS" ;
    ex:textoExtracto "Las señales TAKEPOS, LEAVEPOS y NEXTPOS pueden tomar los siguientes valores." ;
    ex:monitoreaParametro ex:OperacionesAlmacen_7_10_2 .

ex:Senal_MZID
    a ex:Parametro ;
    rdfs:label "MZID" ;
    ex:textoExtracto "Para cada operación se indica cuales de las señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas, así como su significado." ;
    ex:monitoreaParametro ex:OperacionesAlmacen_7_10_2 .