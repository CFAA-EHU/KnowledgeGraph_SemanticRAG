@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Valor0 a ex:Parametro ;
    rdfs:label "0" ;
    ex:textoExtracto "0" ;
    ex:valor "No hay que hacer nada." .

ex:ValorSustituto a ex:Parametro ;
    rdfs:label "#" ;
    ex:textoExtracto "#" ;
    ex:valor "Posición en el almacén." .

ex:ValorMenos4 a ex:Parametro ;
    rdfs:label "-4" ;
    ex:textoExtracto "-4" ;
    ex:valor "Herramienta de tierra." .