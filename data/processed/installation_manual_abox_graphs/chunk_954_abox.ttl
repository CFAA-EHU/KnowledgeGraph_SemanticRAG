@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ValoresAlmacen a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de valores de operaciones del almacén"@es ;
    ex:textoExtracto """
| Valor | Significado |
| --- | --- |
| 0 | No hay que hacer nada. |
| # | Posición en el almacén. |
| -4 | Herramienta de tierra. """@es ;
    ex:ilustradoEn ex:Pagina_517_519 .

ex:HerramientaTierra
    a ex:Herramienta ;
    rdfs:label "Herramienta de tierra"@es ;
    ex:identificador "-4" ;
    ex:textoExtracto "Herramienta de tierra."@es ;
    ex:documentadoEn ex:Tabla_ValoresAlmacen .