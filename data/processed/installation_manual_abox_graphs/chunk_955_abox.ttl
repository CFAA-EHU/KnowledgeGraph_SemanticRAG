@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:RegistroQueInhibeTeclasYConmutadoresEnElPrimerVolanteHBLS a ns1:Parametro ;
    rdfs:label "Registro que inhibe teclas y conmutadores en el primer volante HBLS" ;
    ns1:identificador "KEYDISHBLS1" ;
    ns1:textoExtracto "El registro KEYDISHBLS1 corresponde al primer volante." .

ns1:RegistroQueInhibeTeclasYConmutadoresEnElSegundoVolanteHBLS a ns1:Parametro ;
    rdfs:label "Registro que inhibe teclas y conmutadores en el segundo volante HBLS" ;
    ns1:identificador "KEYDISHBLS2" ;
    ns1:textoExtracto "El registro KEYDISHBLS2 corresponde al segundo volante." .

ns1:SelectorDelSpeedOverride a ns1:Parametro ;
    rdfs:label "Selector del speed override" ;
    ns1:identificador "KEYDIS4" ;
    ns1:textoExtracto "Registros KEYDIS4 / KEYDIS4_1 a KEYDIS4_8. Selector del speed override." .

