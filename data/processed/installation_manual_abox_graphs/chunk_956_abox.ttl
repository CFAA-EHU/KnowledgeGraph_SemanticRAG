@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Pinza1 a ex:Herramienta ;
    rdfs:label "pinza 1" ;
    ex:textoExtracto "Coger la herramienta del almacén con la pinza ꞏ1ꞏ" .

ex:Pinza2 a ex:Herramienta ;
    rdfs:label "pinza 2" ;
    ex:textoExtracto "Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén" .

ex:MarcaMZTOCH1 a ex:ModoOperacion ;
    rdfs:label "MZTOCH1" ;
    ex:textoExtracto "activar la marca MZTOCH1" .

ex:MarcaCH2TOMZ a ex:ModoOperacion ;
    rdfs:label "CH2TOMZ" ;
    ex:textoExtracto "activar la marca CH2TOMZ" .

ex:MarcaCH1TOSPDL a ex:ModoOperacion ;
    rdfs:label "CH1TOSPDL" ;
    ex:textoExtracto "activar la marca CH1TOSPDL" .

ex:TMOPERATION a ex:Parametro ;
    rdfs:label "TMOPERATION" ;
    ex:valor "6" ;
    ex:textoExtracto "TMOPERATION = 6" .

ex:TAKEPOS a ex:Parametro ;
    rdfs:label "TAKEPOS" ;
    ex:valor "-4" ;
    ex:textoExtracto "TAKEPOS=-4" .

ex:HerramientaTierra a ex:Herramienta ;
    rdfs:label "Herramienta de tierra" ;
    ex:textoExtracto "coger una herramienta de tierra" .

ex:LEAVEPOS a ex:Parametro ;
    rdfs:label "LEAVEPOS" ;
    ex:textoExtracto "LEAVEPOS=# Posición del almacén para dejar la herramienta" .