@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TMOPERATION_7 a ex:TareaMantenimiento ;
    ex:textoExtracto "TMOPERATION = 7 Dejar la herramienta del cabezal en tierra y coger una herramienta del almacén. TAKEPOS=# Posición del almacén para coger la herramienta. LEAVEPOS=-4 Herramienta de tierra." ;
    ex:identificador "TMOPERATION = 7" .

ex:TMOPERATION_8 a ex:TareaMantenimiento ;
    ex:textoExtracto "TMOPERATION = 8 Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra." ;
    ex:identificador "TMOPERATION = 8" .

ex:TMOPERATION_9 a ex:TareaMantenimiento ;
    ex:textoExtracto "TMOPERATION = 9 Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal." ;
    ex:identificador "TMOPERATION = 9" .

