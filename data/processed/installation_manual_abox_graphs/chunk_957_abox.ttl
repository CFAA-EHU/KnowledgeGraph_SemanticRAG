@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_51ac509559 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:requiereMantenimiento ns1:ProgramarPLC ;
    ns1:textoExtracto "El CNC puede disponer de hasta cuatro almacenes y cada uno de ellos podrá ser de un tipo diferente." ;
    ns1:tieneComponente ns1:TablaHerramientas .

ns1:NumeroDeAlmacenesDisponibles a ns1:Parametro ;
    rdfs:label "Número de almacenes disponibles" ;
    ns1:identificador "NUM_ALMACENES" ;
    ns1:textoExtracto "En los parámetros máquina se define el número de almacenes disponibles y las características de cada uno." .

ns1:Sistema_a11e2c9c39 a ns1:Sistema ;
    rdfs:label "Almacén Tipo 1",
        "Almacén Tipo 2",
        "Almacén Tipo 3",
        "Almacén Tipo 4" ;
    ns1:textoExtracto "Cada almacén tiene sus propios parámetros de configuración." .

ns1:PersonalTecnicoAutorizado a ns1:Personal ;
    rdfs:label "Personal Técnico Autorizado" ;
    ns1:textoExtracto "Elaborar el programa de PLC." .

ns1:ProgramarPLC a ns1:TareaMantenimiento ;
    rdfs:label "Programar PLC" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "Elaborar el programa de PLC." .

ns1:TablaHerramientas a ns1:Tabla ;
    rdfs:label "Tabla de herramientas y almacenes" ;
    ns1:textoExtracto "Definir la tabla de herramientas y de los almacenes." .

