@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Sistema_11b859348b a ns1:Sistema ;
    rdfs:label "Almacén de herramientas" ;
    ns1:requiereMantenimiento ns1:CambioHerramienta ;
    ns1:textoExtracto "un almacén sólo puede estar involucrado en un proceso de cambio de herramienta." .

ns1:CambioHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta" ;
    ns1:textoExtracto "en un proceso de cambio de herramienta" .

