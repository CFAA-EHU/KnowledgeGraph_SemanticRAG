@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:OperacionAlmacen_958
    a ex:TareaMantenimiento ;
    rdfs:label "Operación de transferencia de herramienta (almacén ↔ tierra)"@es ;
    ex:textoExtracto "La secuencia de esta operación es la siguiente. 1 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL. 2 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 3 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ. TMOPERATION = 10 Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal."@es ;
    ex:identificador "TMOPERATION=10" ;
    ex:requiereMantenimiento ex:Herramienta_958_Pinza2 .

ex:Herramienta_958_Pinza2
    a ex:Herramienta ;
    rdfs:label "Herramienta manipulada por pinza ꞏ2ꞏ"@es ;
    ex:textoExtracto "Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén"@es .

ex:Herramienta_958_Pinza1
    a ex:Herramienta ;
    rdfs:label "Herramienta manipulada por pinza ꞏ1ꞏ"@es ;
    ex:textoExtracto "Coger la herramienta del almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1"@es .

ex:Parametro_TAKEPOS_958
    a ex:Parametro ;
    rdfs:label "TAKEPOS"@es ;
    ex:textoExtracto "TAKEPOS=# Posición del almacén para coger la herramienta."@es ;
    ex:valor "#" .  # Valor genérico según texto

ex:Parametro_LEAVEPOS_958
    a ex:Parametro ;
    rdfs:label "LEAVEPOS"@es ;
    ex:textoExtracto "LEAVEPOS=-4 Herramienta de tierra."@es ;
    ex:valor "-4" .

ex:SistemaMarcas_958
    a ex:Sistema ;
    rdfs:label "Sistema de marcas de operación (GRTOSPDL, SPDLTOCH2, CH2TOMZ, MZTOCH1)"@es ;
    ex:textoExtracto "activar la marca GRTOSPDL [...] activar la marca SPDLTOCH2 [...] activar la marca CH2TOMZ [...] activar la marca MZTOCH1"@es ;
    ex:compuestoPor ex:Marca_GRTOSPDL_958, ex:Marca_SPDLTOCH2_958, ex:Marca_CH2TOMZ_958, ex:Marca_MZTOCH1_958 .

ex:Marca_GRTOSPDL_958
    a ex:ComponenteElectrico ;
    rdfs:label "Marca GRTOSPDL"@es ;
    ex:textoExtracto "activar la marca GRTOSPDL"@es ;
    ex:documentadoEn ex:SistemaMarcas_958 .

ex:Marca_SPDLTOCH2_958
    a ex:ComponenteElectrico ;
    rdfs:label "Marca SPDLTOCH2"@es ;
    ex:textoExtracto "activar la marca SPDLTOCH2"@es ;
    ex:documentadoEn ex:SistemaMarcas_958 .

ex:Marca_CH2TOMZ_958
    a ex:ComponenteElectrico ;
    rdfs:label "Marca CH2TOMZ"@es ;
    ex:textoExtracto "activar la marca CH2TOMZ"@es ;
    ex:documentadoEn ex:SistemaMarcas_958 .

ex:Marca_MZTOCH1_958
    a ex:ComponenteElectrico ;
    rdfs:label "Marca MZTOCH1"@es ;
    ex:textoExtracto "activar la marca MZTOCH1"@es ;
    ex:documentadoEn ex:SistemaMarcas_958 .