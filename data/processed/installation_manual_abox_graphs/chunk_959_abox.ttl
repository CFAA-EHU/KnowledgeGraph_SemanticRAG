@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_78f5b01a74 a ns1:Componente ;
    rdfs:label "Herramienta de Tierra" ;
    ns1:textoExtracto "Se denomina herramienta de tierra a aquella que no se guarda en ningún almacén y que se carga manualmente cuando es solicitada." .

ns1:ElAlmacenEnElQueSeDejaLaHerramientaYElAlmacenDelQueSeCogeLaHerramientaNuevaPuedenSerDiferentes a ns1:Sistema ;
    rdfs:label "Almacén de Herramientas" ;
    ns1:textoExtracto "El almacén en el que se deja la herramienta y el almacén del que se coge la herramienta nueva pueden ser diferentes." .

ns1:Herramienta a ns1:Componente ;
    rdfs:label "Herramienta" ;
    ns1:textoExtracto "Cada herramienta se identifica mediante su número, que es único para todo el sistema;" .

ns1:GestorHerramientas a ns1:Sistema ;
    rdfs:label "Gestor de Herramientas" ;
    ns1:documentadoEn ns1:TablaHerramientas ;
    ns1:textoExtracto "El CNC dispone de un gestor de herramientas que sabe en todo momento dónde se encuentra cada una de las herramientas." .

ns1:TablaHerramientas a ns1:Tabla ;
    rdfs:label "Tabla de Herramientas" ;
    ns1:documenta ns1:CNC8070_5bff8283d8 ;
    ns1:documentadoEn ns1:CNC8070_5bff8283d8 ;
    ns1:textoExtracto "La lista de herramientas disponibles se guarda en la tabla de herramientas, única para todo el sistema." .

ns1:CNC8070_5bff8283d8 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC dispone de un gestor de herramientas que sabe en todo momento dónde se encuentra cada una de las herramientas." ;
    ns1:tieneComponente ns1:GestorHerramientas .

