@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:HerramientaTierra a ex:Herramienta ;
    rdfs:label "Herramienta de tierra"@es ;
    ex:textoExtracto "Herramienta de tierra. La secuencia de esta operación es la siguiente. 1 Coger la herramienta del almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1."@es .

ex:Pinza1 a ex:ComponenteElectrico ;
    rdfs:label "pinza 1"@es ;
    ex:textoExtracto "Coger la herramienta del almacén con la pinza ꞏ1ꞏ"@es .

ex:MarcaMZTOCH1 a ex:Parametro ;
    rdfs:label "MZTOCH1"@es ;
    ex:identificador "MZTOCH1" ;
    ex:textoExtracto "activar la marca MZTOCH1"@es .

ex:MarcaCH1TOSPDL a ex:Parametro ;
    rdfs:label "CH1TOSPDL"@es ;
    ex:identificador "CH1TOSPDL" ;
    ex:textoExtracto "activar la marca CH1TOSPDL"@es .

ex:MarcaSPDLTOGR a ex:Parametro ;
    rdfs:label "SPDLTOGR"@es ;
    ex:identificador "SPDLTOGR" ;
    ex:textoExtracto "activar la marca SPDLTOGR"@es .

ex:TMOPERATION11 a ex:ModoOperacion ;
    rdfs:label "TMOPERATION = 11"@es ;
    ex:identificador "11" ;
    ex:textoExtracto "TMOPERATION = 11 Orientar el almacén. Esta operación es una optimización del cambio de herramienta que permite orientar el almacén durante el mecanizado."@es .

ex:MarcaMZROT a ex:Parametro ;
    rdfs:label "MZROT"@es ;
    ex:identificador "MZROT" ;
    ex:textoExtracto "Activar la marca MZROT para indicar que ha finalizado la operación"@es .

ex:TMOPERATION12 a ex:ModoOperacion ;
    rdfs:label "TMOPERATION = 12"@es ;
    ex:identificador "12" ;
    ex:textoExtracto "TMOPERATION = 12 Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén (como TMOPERATION=5)."@es .

ex:TMOPERATION13 a ex:ModoOperacion ;
    rdfs:label "TMOPERATION = 13"@es ;
    ex:identificador "13" ;
    ex:textoExtracto "TMOPERATION = 13 Orientar dos almacenes. Esta operación es una optimización del cambio de herramienta que permite orientar dos almacenes durante el mecanizado."@es .

ex:TMOPERATION14 a ex:ModoOperacion ;
    rdfs:label "TMOPERATION = 14"@es ;
    ex:identificador "14" ;
    ex:textoExtracto "TMOPERATION = 14 Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén."@es .

ex:MarcaMZID a ex:Parametro ;
    rdfs:label "MZID"@es ;
    ex:identificador "MZID" ;
    ex:textoExtracto "MZID En la parte baja de este registro se indica el almacén en el que hay que dejar la herramienta y en la parte alta el almacén del que hay que coger la herramienta."@es .