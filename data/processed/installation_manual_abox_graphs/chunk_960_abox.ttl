@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TMOPERATION_14 a ex:TareaMantenimiento ;
    ex:textoExtracto "TMOPERATION = 14 Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén." ;
    ex:identificador "TMOPERATION=14" .

ex:TAKEPOS a ex:Parametro ;
    ex:textoExtracto "TAKEPOS=# Posición del almacén para coger la herramienta." ;
    ex:identificador "TAKEPOS" .

ex:LEAVEPOS a ex:Parametro ;
    ex:textoExtracto "LEAVEPOS=# Posición del almacén para dejar la herramienta." ;
    ex:identificador "LEAVEPOS" .

ex:MZID a ex:Parametro ;
    ex:textoExtracto "MZID En la parte baja de este registro se indica el almacén en el que hay que dejar la herramienta y en la parte alta el almacén del que hay que coger la herramienta." ;
    ex:identificador "MZID" .