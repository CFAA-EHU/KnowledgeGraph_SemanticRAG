@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioDeHerramienta_be17129d85 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta" ;
    ns1:textoExtracto "Dependiendo del tipo de almacén y de la operación solicitada, a veces se deben efectuar varias acciones." .

ns1:SistemaPLC960 a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:controla ns1:BrazoCambiador,
        ns1:Herramienta_8cb260dda3,
        ns1:Sistema_5f7275da9c ;
    ns1:textoExtracto "El PLC, que es el encargado de controlar dichos movimientos, debe informar al gestor de las acciones efectuadas para que actualice su información." .

ns1:SubrutinaCambioHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Subrutina de cambio de herramienta" ;
    ns1:textoExtracto "Hay dos subrutinas asociadas al cambio de herramienta." .

ns1:SubrutinaFuncionT a ns1:TareaMantenimiento ;
    rdfs:label "Rutina asociada a la función T" ;
    ns1:textoExtracto "La rutina asociada a la herramienta se ejecuta automáticamente cada vez que se ejecuta una función T (selección de herramienta)." .

ns1:BrazoCambiador a ns1:ComponenteMecanico ;
    rdfs:label "Brazo cambiador" ;
    ns1:textoExtracto "en algunos almacenes para llevar una herramienta del cabezal al almacén primero hay que llevar la herramienta del cabezal al brazo cambiador y luego del brazo cambiador al almacén." .

ns1:Herramienta_8cb260dda3 a ns1:Herramienta ;
    rdfs:label "Herramienta del cabezal" ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en tierra." .

ns1:Sistema_5f7275da9c a ns1:Sistema ;
    rdfs:label "Almacén de herramientas" ;
    ns1:textoExtracto "en algunos almacenes para llevar una herramienta del cabezal al almacén primero hay que llevar la herramienta del cabezal al brazo cambiador y luego del brazo cambiador al almacén." .

