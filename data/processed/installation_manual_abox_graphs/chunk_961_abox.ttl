@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_ad9a9e8d01 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controla ns1:CambioDeHerramienta_e4835c35ad ;
    ns1:textoExtracto "El CNC gestionará el cambiador de herramienta y actualizará la tabla correspondiente al almacén de herramientas." .

ns1:SubrutinaCambioHerramienta a ns1:Sistema ;
    rdfs:label "Subrutina de Cambio de Herramienta" ;
    ns1:textoExtracto "Se recomienda tener personalizada esta función en la tabla de funciones –M– de forma que ejecute la subrutina correspondiente al cambiador de herramientas instalado en la máquina." .

ns1:CambioDeHerramienta_e4835c35ad a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de Herramienta" ;
    ns1:solucionaFallo ns1:CondicionModalEnCiclosFijos ;
    ns1:textoExtracto "La función M06 ejecuta el cambio de herramienta." .

ns1:CondicionModalEnCiclosFijos a ns1:DiagnosticoFallo ;
    rdfs:label "Condición Modal en Ciclos Fijos" ;
    ns1:textoExtracto "Esta característica se recupera cuando finaliza la ejecución de la subrutina." .

