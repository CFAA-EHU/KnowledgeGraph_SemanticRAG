@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:RegistroAlmacenMZID a ex:Tabla ;
    ex:textoExtracto "En la parte baja de este registro se indica el almacén en el que hay que dejar la herramienta y en la parte alta el almacén del que hay que coger la herramienta." ;
    ex:tieneComponente ex:Pinza2, ex:Pinza1, ex:MarcaSPDLTOCH2, ex:MarcaCH2TOMZ, ex:MarcaMZTOCH1, ex:MarcaCH1TOSPDL .

ex:Pinza2 a ex:ComponenteMecanico ;
    ex:textoExtracto "Coger la herramienta del cabezal con la pinza ꞏ2ꞏ" .

ex:Pinza1 a ex:ComponenteMecanico ;
    ex:textoExtracto "Coger la herramienta del otro almacén con la pinza ꞏ1ꞏ" .

ex:MarcaSPDLTOCH2 a ex:Parametro ;
    ex:textoExtracto "activar la marca SPDLTOCH2" .

ex:MarcaCH2TOMZ a ex:Parametro ;
    ex:textoExtracto "activar la marca CH2TOMZ" .

ex:MarcaMZTOCH1 a ex:Parametro ;
    ex:textoExtracto "activar la marca MZTOCH1" .

ex:MarcaCH1TOSPDL a ex:Parametro ;
    ex:textoExtracto "activar la marca CH1TOSPDL" .