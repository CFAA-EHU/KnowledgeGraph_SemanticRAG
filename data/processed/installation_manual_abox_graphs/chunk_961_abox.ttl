@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:OperacionAlmacenamientoHerramientas_961
    a ex:TareaMantenimiento ;
    rdfs:label "Operación de almacenamiento de herramientas (MZID)"@es ;
    ex:textoExtracto "MZID En la parte baja de este registro se indica el almacén en el que hay que dejar la herramienta y en la parte alta el almacén del que hay que coger la herramienta. La secuencia de esta operación es la siguiente. 1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 2 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ. 3 Coger la herramienta del otro almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1. 4 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal y activar la marca CH1TOSPDL."@es ;
    ex:requiereMantenimiento ex:Pinza_2 ;
    ex:requiereMantenimiento ex:Pinza_1 ;
    ex:requiereMantenimiento ex:Herramienta_Cabezal ;
    ex:requiereMantenimiento ex:Herramienta_Almacen .

ex:Pinza_2
    a ex:ComponenteMecanico ;
    rdfs:label "Pinza 2"@es ;
    ex:identificador "ꞏ2ꞏ" ;
    ex:textoExtracto "Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ."@es .

ex:Pinza_1
    a ex:ComponenteMecanico ;
    rdfs:label "Pinza 1"@es ;
    ex:identificador "ꞏ1ꞏ" ;
    ex:textoExtracto "Coger la herramienta del otro almacén con la pinza ꞏ1ꞏ y activar la marca MZTOCH1. Poner la herramienta de la pinza ꞏ1ꏊ en el cabezal y activar la marca CH1TOSPDL."@es .

ex:Herramienta_Cabezal
    a ex:Herramienta ;
    rdfs:label "Herramienta del cabezal"@es ;
    ex:textoExtracto "Coger la herramienta del cabezal con la pinza ꞏ2ꞏ"@es .

ex:Herramienta_Almacen
    a ex:Herramienta ;
    rdfs:label "Herramienta del almacén"@es ;
    ex:textoExtracto "Coger la herramienta del otro almacén con la pinza ꞏ1ꞏ"@es .

ex:Marca_SPDLTOCH2
    a ex:InterfazUsuario ;
    rdfs:label "Marca SPDLTOCH2"@es ;
    ex:identificador "SPDLTOCH2" ;
    ex:textoExtracto "activar la marca SPDLTOCH2"@es .

ex:Marca_CH2TOMZ
    a ex:InterfazUsuario ;
    rdfs:label "Marca CH2TOMZ"@es ;
    ex:identificador "CH2TOMZ" ;
    ex:textoExtracto "activar la marca CH2TOMZ"@es .

ex:Marca_MZTOCH1
    a ex:InterfazUsuario ;
    rdfs:label "Marca MZTOCH1"@es ;
    ex:identificador "MZTOCH1" ;
    ex:textoExtracto "activar la marca MZTOCH1"@es .

ex:Marca_CH1TOSPDL
    a ex:InterfazUsuario ;
    rdfs:label "Marca CH1TOSPDL"@es ;
    ex:identificador "CH1TOSPDL" ;
    ex:textoExtracto "activar la marca CH1TOSPDL"@es .