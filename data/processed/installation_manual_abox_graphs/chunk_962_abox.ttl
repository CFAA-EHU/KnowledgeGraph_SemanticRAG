@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:M1101 a ex:Sensor ;
    rdfs:label "M1101" ;
    ex:textoExtracto "Marca. | M1101 | MZTOCH1 | La herramienta se ha llevado del almacén a la pinza 1." ;
    ex:valor "MZTOCH1" .

ex:M1102 a ex:Sensor ;
    rdfs:label "M1102" ;
    ex:textoExtracto "Marca. | M1102 | CH1TOSPDL | La herramienta se ha llevado de la pinza 1 al cabezal." ;
    ex:valor "CH1TOSPDL" .

ex:M1104 a ex:Sensor ;
    rdfs:label "M1104" ;
    ex:textoExtracto "Marca. | M1104 | SPDLTOCH2 | La herramienta se ha llevado del cabezal a la pinza 2." ;
    ex:valor "SPDLTOCH2" .

ex:M1106 a ex:Sensor ;
    rdfs:label "M1106" ;
    ex:textoExtracto "Marca. | M1106 | CH2TOMZ | La herramienta se ha llevado de la pinza 2 al almacén." ;
    ex:valor "CH2TOMZ" .

ex:M1107 a ex:Sensor ;
    rdfs:label "M1107" ;
    ex:textoExtracto "Marca. | M1107 | SPDLTOGR | La herramienta se ha llevado del cabezal a tierra." ;
    ex:valor "SPDLTOGR" .

ex:M1108 a ex:Sensor ;
    rdfs:label "M1108" ;
    ex:textoExtracto "Marca. | M1108 | GRTOSPDL | La herramienta se ha llevado de tierra al cabezal." ;
    ex:valor "GRTOSPDL" .

ex:M101 a ex:Sensor ;
    rdfs:label "M101" ;
    ex:textoExtracto "Función. | M101 | Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1." .

ex:M102 a ex:Sensor ;
    rdfs:label "M102" ;
    ex:textoExtracto "Función. | M102 | Llevar la herramienta de la pinza 1 al cabezal." .

ex:M104 a ex:Sensor ;
    rdfs:label "M104" ;
    ex:textoExtracto "Función. | M104 | Coger la herramienta del cabezal con la pinza 2." .

ex:M106 a ex:Sensor ;
    rdfs:label "M106" ;
    ex:textoExtracto "Función. | M106 | Seleccionar en el almacén la posición que indica LEAVEPOS y dejar la herramienta de la pinza 2." .