@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlmacenAsincrono a ns1:Sistema ;
    rdfs:label "Almacén asíncrono" ;
    ns1:textoExtracto "Almacén asíncrono. Brazo cambiador de movimientos independientes que puede moverse durante el mecanizado." .

ns1:AlmacenCiclico a ns1:Sistema ;
    rdfs:label "Almacén cíclico" ;
    ns1:textoExtracto "Un almacén cíclico necesita una orden de cambio de herramienta M06 después de buscar una herramienta y antes de buscar la siguiente." .

ns1:AlmacenNoCiclico a ns1:Sistema ;
    rdfs:label "Almacén no-cíclico" ;
    ns1:textoExtracto "Un almacén no-cíclico permite realizar varias búsquedas de herramienta seguidas, sin efectuar necesariamente el cambio de herramienta." .

ns1:AlmacenNoRandom a ns1:Sistema ;
    rdfs:label "Almacén no-random" ;
    ns1:textoExtracto "En un almacén random las herramientas pueden ocupar cualquier posición mientras que en un almacén no-random las herramientas deben ocupar siempre la misma posición." .

ns1:AlmacenRandom a ns1:Sistema ;
    rdfs:label "Almacén random" ;
    ns1:textoExtracto "En un almacén random las herramientas pueden ocupar cualquier posición mientras que en un almacén no-random las herramientas deben ocupar siempre la misma posición." .

ns1:AlmacenSincronoSinBrazoCambiador a ns1:Sistema ;
    rdfs:label "Almacén síncrono sin brazo cambiador" ;
    ns1:textoExtracto "Almacén síncrono sin brazo cambiador." .

ns1:Sistema_04b97102b9 a ns1:Sistema ;
    rdfs:label "Almacén síncrono con brazo cambiador (1 ó 2 pinzas)" ;
    ns1:textoExtracto "Almacén síncrono con brazo cambiador (1 ó 2 pinzas)." .

ns1:Sistema_9baec1604a a ns1:Sistema ;
    rdfs:label "Almacén tipo torreta" ;
    ns1:textoExtracto "Almacén tipo torreta." .

