@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:RutinaM06
    a ex:ModoOperacion ;
    rdfs:label "Rutina M06 (Programa de transferencia de herramientas)" ;
    ex:textoExtracto """
%L SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1.
%L SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal.
%L SUB_SPD_TO_CH2 ; Coger la herramienta del cabezal con la pinza 2.
%L SUB_CH2_TO_MZ ; Llevar la herramienta de la pinza 2 al almacén.
%L SUB_SPD_TO_GR ; Quitar la herramienta del cabezal (llevarla a tierra).
%L SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal.""" .

ex:Pinza1
    a ex:ComponenteMecanico ;
    rdfs:label "Pinza 1" ;
    ex:textoExtracto "Coger la herramienta del almacén con la pinza 1. Llevar la herramienta de la pinza 1 al cabezal." ;
    ex:tieneComponente ex:HerramientaEnTransito .

ex:Pinza2
    a ex:ComponenteMecanico ;
    rdfs:label "Pinza 2" ;
    ex:textoExtracto "Coger la herramienta del cabezal con la pinza 2. Llevar la herramienta de la pinza 2 al almacén." ;
    ex:tieneComponente ex:HerramientaEnTransito .

ex:Cabezal
    a ex:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ex:textoExtracto """
Llevar la herramienta de la pinza 1 al cabezal.
Coger la herramienta del cabezal con la pinza 2.
Quitar la herramienta del cabezal (llevarla a tierra).
Colocar la herramienta de tierra en el cabezal.""" .

ex:AlmacenHerramientas
    a ex:Sistema ;
    rdfs:label "Almacén de herramientas" ;
    ex:textoExtracto """
Coger la herramienta del almacén con la pinza 1.
Llevar la herramienta de la pinza 2 al almacén.""" .

ex:HerramientaEnTransito
    a ex:Herramienta ;
    rdfs:label "Herramienta en tránsito (T%D)" ;
    ex:textoExtracto """
Extraer herramienta T%D y pulsar MARCHA.
Insertar herramienta T%D y pulsar MARCHA.""" .

ex:InterfazOperario_M06
    a ex:InterfazUsuario ;
    rdfs:label "Mensajes de operario (Rutina M06)" ;
    ex:textoExtracto """
MSG [\"Extraer herramienta T%D y pulsar MARCHA\", V.TM.TOOL].
MSG [\"Insertar herramienta T%D y pulsar MARCHA\", V.TM.NXTOOL].""" ;
    ex:ilustradoEn ex:RutinaM06 .

ex:GestorPLC_Marcas
    a ex:Sistema ;
    rdfs:label "Gestor PLC (Marcas M1101-M1107)" ;
    ex:textoExtracto """
V.PLC.M[1101]=1 ; Marca MZTOCH1 al gestor.
V.PLC.M[1102]=1 ; Marca CH1TOSPDL al gestor.
V.PLC.M[1104]=1 ; Marca SPDLTOCH2 al gestor.
V.PLC.M[1106]=1 ; Marca CH2TOMZ al gestor.
V.PLC.M[1107]=1 ; Marca SPDLTOGR al gestor.""" ;
    ex:controla ex:Pinza1, ex:Pinza2, ex:Cabezal, ex:AlmacenHerramientas .

ex:FuncionAuxiliar_M101 a ex:Tabla ;
     a ex:ModoOperacion ;
    ex:identificador "M101" ;
    rdfs:label "Función auxiliar M101 (MZTOCH1)" ;
    ex:textoExtracto "M101 ; Función auxiliar para ejecutar acción. V.PLC.M[1101]=1 ; Marca MZTOCH1 al gestor." ;
    ex:ejecutadoPor ex:GestorPLC_Marcas .

ex:FuncionAuxiliar_M102 a ex:Tabla ;
     a ex:ModoOperacion ;
    ex:identificador "M102" ;
    rdfs:label "Función auxiliar M102 (CH1TOSPDL)" ;
    ex:textoExtracto "M102 ; Función auxiliar para ejecutar acción. V.PLC.M[1102]=1 ; Marca CH1TOSPDL al gestor." ;
    ex:ejecutadoPor ex:GestorPLC_Marcas .

ex:FuncionAuxiliar_M104 a ex:Tabla ;
     a ex:ModoOperacion ;
    ex:identificador "M104" ;
    rdfs:label "Función auxiliar M104 (SPDLTOCH2)" ;
    ex:textoExtracto "M104 ; Función auxiliar para ejecutar acción. V.PLC.M[1104]=1 ; Marca SPDLTOCH2 al gestor." ;
    ex:ejecutadoPor ex:GestorPLC_Marcas .

ex:FuncionAuxiliar_M106 a ex:Tabla ;
     a ex:ModoOperacion ;
    ex:identificador "M106" ;
    rdfs:label "Función auxiliar M106 (CH2TOMZ)" ;
    ex:textoExtracto "M106 ; Función auxiliar para ejecutar acción. V.PLC.M[1106]=1 ; Marca CH2TOMZ al gestor." ;
    ex:ejecutadoPor ex:GestorPLC_Marcas .