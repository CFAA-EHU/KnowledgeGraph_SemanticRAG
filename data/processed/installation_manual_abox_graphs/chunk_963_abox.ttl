@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Herramienta_e3e31878b8 a ns1:Herramienta ;
    rdfs:label "Herramienta de Tierra T10",
        "Herramienta de Tierra T8",
        "Herramienta de Tierra T9" ;
    ns1:textoExtracto "Las herramientas T8, T9 y T10 no entran en el almacén y serán herramientas de tierra." .

ns1:TablaHerramientas a ns1:Tabla ;
    rdfs:label "Tabla de Herramientas" ;
    ns1:documentadoEn ns1:SistemaHidraulicoAlmacen ;
    ns1:textoExtracto "En la tabla de herramientas se debe definir, entre otras cosas, la geometría, tipo de monitorización y tamaño de la herramienta." .

ns1:HerramientaT1 a ns1:Herramienta ;
    rdfs:label "Herramienta T1" ;
    ns1:esComponenteDe ns1:SistemaHidraulicoAlmacen ;
    ns1:textoExtracto "La T1 en la posición 1." .

ns1:HerramientaT2 a ns1:Herramienta ;
    rdfs:label "Herramienta T2" ;
    ns1:esComponenteDe ns1:SistemaHidraulicoAlmacen ;
    ns1:textoExtracto "La herramienta es de tamaño grande. La T2 en la posición 3." .

ns1:HerramientaT3 a ns1:Herramienta ;
    rdfs:label "Herramienta T3" ;
    ns1:esComponenteDe ns1:SistemaHidraulicoAlmacen ;
    ns1:textoExtracto "La T3 en la posición 5." .

ns1:HerramientaT4 a ns1:Herramienta ;
    rdfs:label "Herramienta T4" ;
    ns1:esComponenteDe ns1:SistemaHidraulicoAlmacen ;
    ns1:textoExtracto "La herramienta es de tamaño personal. La T4 en la posición 6." .

ns1:HerramientaT5 a ns1:Herramienta ;
    rdfs:label "Herramienta T5" ;
    ns1:esComponenteDe ns1:SistemaHidraulicoAlmacen ;
    ns1:textoExtracto "La T5 en la posición 8." .

ns1:HerramientaT6 a ns1:Herramienta ;
    rdfs:label "Herramienta T6" ;
    ns1:esComponenteDe ns1:SistemaHidraulicoAlmacen ;
    ns1:textoExtracto "La T6 en la posición 9." .

ns1:HerramientaT7 a ns1:Herramienta ;
    rdfs:label "Herramienta T7" ;
    ns1:esComponenteDe ns1:SistemaHidraulicoAlmacen ;
    ns1:textoExtracto "La T7 en la posición 10." .

ns1:SistemaHidraulicoAlmacen a ns1:Sistema ;
    rdfs:label "Sistema de Almacén" ;
    ns1:textoExtracto "Se dispone de una tabla para cada almacén. En cada una de las tablas se muestra qué herramienta hay en cada posición del almacén y en cada una de las pinzas del brazo cambiador (si se dispone de él)." ;
    ns1:tieneComponente ns1:HerramientaT1,
        ns1:HerramientaT2,
        ns1:HerramientaT3,
        ns1:HerramientaT4,
        ns1:HerramientaT5,
        ns1:HerramientaT6,
        ns1:HerramientaT7 .

