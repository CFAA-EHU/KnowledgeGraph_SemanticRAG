@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:MSG_InsertarHerramienta_TD ex:textoExtracto """MSG ["Insertar herramienta T%D y pulsar MARCHA", V.TM.NXTOOL] ; Mensaje al operario para que ponga la herramienta.""" ;
    a ex:InterfazUsuario ;
    rdfs:label "MSG Insertar herramienta T%D y pulsar MARCHA" .

ex:Marca_GRTOSPDL ex:textoExtracto """V.PLC.M[1108]=1 ; Marca GRTOSPDL al gestor.""" ;
    a ex:Parametro ;
    ex:identificador "V.PLC.M[1108]" ;
    ex:valor "1" .

ex:SUB_SPD_GMCHG ex:textoExtracto """%L SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual.""" ;
    a ex:TareaMantenimiento ;
    rdfs:label "SUB_SPD_GMCHG" .

ex:SUB_SPD_AUTCHG ex:textoExtracto """%L SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático.""" ;
    a ex:TareaMantenimiento ;
    rdfs:label "SUB_SPD_AUTCHG" .

ex:SUB_M6_nc ex:textoExtracto """%SUB_M6.nc #ESBLK ; Activar tratamiento de bloque único""" ;
    a ex:TareaMantenimiento ;
    rdfs:label "SUB_M6.nc" .

ex:DSTOP ex:textoExtracto """#DSTOP ; Deshabilitar tecla STOP""" ;
    a ex:InterfazUsuario ;
    rdfs:label "DSTOP" .

ex:M6 ex:textoExtracto """M6 ; Orden al gestor para comenzar el cambio de herramienta.""" ;
    a ex:ModoOperacion ;
    rdfs:label "M6" .

ex:Parametro_FULLSTATUS ex:textoExtracto """V.G.FULLSTATUS & 255""" ;
    a ex:Parametro ;
    ex:identificador "V.G.FULLSTATUS" ;
    ex:valor "255" .

ex:Parametro_CNCAUTSTATUS ex:textoExtracto """V.G.CNCAUTSTATUS & 4096 | V.G.CNCAUTSTATUS & 8192""" ;
    a ex:Parametro ;
    ex:identificador "V.G.CNCAUTSTATUS" ;
    ex:valor "4096 | 8192" .

ex:Parametro_EXECUTION ex:textoExtracto """V.S.EXECUTION = 0 ; Ejecución simulada; teórico o funciones G.""" ;
    a ex:Parametro ;
    ex:identificador "V.S.EXECUTION" ;
    ex:valor "0" .