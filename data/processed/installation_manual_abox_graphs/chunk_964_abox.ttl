@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivacionDeMarcaTCHANGEOKEnGestionAsincrona a ns1:AccionProhibida ;
    rdfs:label "Activación de marca TCHANGEOK en gestión asíncrona" ;
    ns1:identificador "TCHANGEOK" ;
    ns1:textoExtracto "En almacenes asíncronos (brazo cambiador de movimientos independientes) es posible, cuando el cambio implica dejar una herramienta en el almacén, activar la marca TCHANGEOK para que el CNC continúe con la ejecución del programa mientras se deja la herramienta en el almacén." .

ns1:CNC8070_539c2a6b43 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:GestionDelCambioDeHerramienta,
        ns1:RutinaAsociadaAM06 ;
    ns1:textoExtracto "El CNC mantiene la compatibilidad con las marcas y registros de versiones anteriores, cuyos mnemónicos no hacen referencia a ningún canal o almacén en particular." .

ns1:GestionAsincronaDelCambioDeHerramienta a ns1:AccionProhibida ;
    rdfs:label "Gestión asíncrona del cambio de herramienta" ;
    ns1:textoExtracto "En almacenes asíncronos (brazo cambiador de movimientos independientes) es posible, cuando el cambio implica dejar una herramienta en el almacén, activar la marca TCHANGEOK para que el CNC continúe con la ejecución del programa mientras se deja la herramienta en el almacén." .

ns1:Parametro_78e25a06f2 a ns1:Parametro ;
    rdfs:label "Función de cambio de herramienta" ;
    ns1:identificador "M06" ;
    ns1:textoExtracto "Dentro de dicha rutina hay que volver a programar la función M06 para que el CNC indique al gestor que debe comenzar el cambio de herramienta." .

ns1:Parametro_9eb0d1cf51 a ns1:Parametro ;
    rdfs:label "Función de indicación de canal" ;
    ns1:identificador "T" ;
    ns1:textoExtracto "Cuando se ejecuta la función T el canal del CNC se lo indica al gestor." .

ns1:GestionDelCambioDeHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Gestión del cambio de herramienta" ;
    ns1:textoExtracto "Se aconseja incluir la gestión del cambio de herramienta en la rutina asociada a M06 y dejar como labor del PLC el control de los dispositivos externos." .

ns1:RutinaAsociadaAM06 a ns1:TareaMantenimiento ;
    rdfs:label "Rutina asociada a M06" ;
    ns1:textoExtracto "Dentro de dicha rutina hay que volver a programar la función M06 para que el CNC indique al gestor que debe comenzar el cambio de herramienta." .

