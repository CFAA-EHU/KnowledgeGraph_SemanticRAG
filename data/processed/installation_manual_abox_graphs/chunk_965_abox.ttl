@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaComunicacionGestorPLC a ns1:Tabla ;
    rdfs:label "Tabla de comunicacion Gestor --> PLC" ;
    ns1:ilustra ns1:Parametro_63a661861b,
        ns1:RegistroDeIdentificacionDelCanal1,
        ns1:RegistroParaDejarPosicionEnAlmacen,
        ns1:RegistroParaInformarOperacionesAlPLC,
        ns1:RegistroParaSiguientePosicionEnAlmacen,
        ns1:RegistroParaTomarPosicionEnAlmacen ;
    ns1:textoExtracto "En la siguiente tabla se muestran los mnemónicos de cada marca (M) o registro (R) en cada uno de los canales o almacenes." .

ns1:Parametro_63a661861b a ns1:Parametro ;
    rdfs:label "Marca para informar operaciones al PLC" ;
    ns1:identificador "TMOPSTROBE" ;
    ns1:textoExtracto "M | TMOPSTROBE" .

ns1:RegistroDeIdentificacionDelCanal1 a ns1:Parametro ;
    rdfs:label "Registro de identificación del canal 1" ;
    ns1:identificador "MZIDC1" ;
    ns1:textoExtracto "R | MZIDC1" .

ns1:RegistroParaDejarPosicionEnAlmacen a ns1:Parametro ;
    rdfs:label "Registro para dejar posición en almacén" ;
    ns1:identificador "LEAVEPOS" ;
    ns1:textoExtracto "R | LEAVEPOS" .

ns1:RegistroParaInformarOperacionesAlPLC a ns1:Parametro ;
    rdfs:label "Registro para informar operaciones al PLC" ;
    ns1:identificador "TMOPERATION" ;
    ns1:textoExtracto "R | TMOPERATION" .

ns1:RegistroParaSiguientePosicionEnAlmacen a ns1:Parametro ;
    rdfs:label "Registro para siguiente posición en almacén" ;
    ns1:identificador "NEXTPOS" ;
    ns1:textoExtracto "R | NEXTPOS" .

ns1:RegistroParaTomarPosicionEnAlmacen a ns1:Parametro ;
    rdfs:label "Registro para tomar posición en almacén" ;
    ns1:identificador "TAKEPOS" ;
    ns1:textoExtracto "R | TAKEPOS" .

