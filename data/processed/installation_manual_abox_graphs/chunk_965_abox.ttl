@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:RutinaM06_EjecucionSimulada
    a ex:ModoOperacion ;
    rdfs:label "Modo de ejecución simulada (V.S.EXECUTION = 0)" ;
    ex:textoExtracto "V.S.EXECUTION = 0 ; Ejecución simulada; teórico o funciones G." .

ex:RutinaM06_EjecucionReal
    a ex:ModoOperacion ;
    rdfs:label "Modo de ejecución real (V.S.EXECUTION = 1)" ;
    ex:textoExtracto "$IF [V.S.EXECUTION == 1] ; CNC en ejecución" .

ex:Parametro_V_S_EXECUTION
    a ex:Parametro ;
    rdfs:label "V.S.EXECUTION" ;
    ex:valor "0" , "1" ;
    ex:textoExtracto "V.S.EXECUTION = 0 ; Simulación [...] $IF [V.S.EXECUTION == 1] ; CNC en ejecución" .

ex:Parametro_V_PLC_TMOPERATION
    a ex:Parametro ;
    rdfs:label "V.PLC.TMOPERATION" ;
    ex:textoExtracto "$SWITCH V.PLC.TMOPERATION; Analiza el tipo de operación." .

ex:TareaMantenimiento_CambioHerramientaAutomatico_Caso1
    a ex:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta: Almacén → Cabezal (Caso 1)" ;
    ex:textoExtracto "$CASE 1 ; Coger una herramienta del almacén y ponerla en el cabezal. LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático. LL SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1. LL SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal." .

ex:TareaMantenimiento_DevolucionHerramientaAutomatica_Caso2
    a ex:TareaMantenimiento ;
    rdfs:label "Devolución de herramienta: Cabezal → Almacén (Caso 2)" ;
    ex:textoExtracto "$CASE 2 ; Dejar la herramienta del cabezal en el almacén. LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático. LL SUB_SPD_TO_CH2 ; Coger la herramienta del cabezal con la pinza 2. LL SUB_CH2_TO_MZ ; Dejar la herramienta de la pinza 2 en el almacén." .

ex:TareaMantenimiento_ColocacionHerramientaTierra_Caso3
    a ex:TareaMantenimiento ;
    rdfs:label "Colocación de herramienta de tierra en cabezal (Caso 3)" ;
    ex:textoExtracto "$CASE 3 ; Colocar la herramienta de tierra en el cabezal. LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual. LL SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal." .

ex:TareaMantenimiento_DevolucionHerramientaTierra_Caso4
    a ex:TareaMantenimiento ;
    rdfs:label "Devolución de herramienta a tierra (Caso 4)" ;
    ex:textoExtracto "$CASE 4 ; Dejar la herramienta del cabezal en tierra. LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual. LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal." .

ex:TareaMantenimiento_CambioHerramientaCombinado_Caso5
    a ex:TareaMantenimiento ;
    rdfs:label "Cambio combinado: Cabezal → Almacén + Almacén → Cabezal (Caso 5)" ;
    ex:textoExtracto "$CASE 5 ; Dejar la herramienta del cabezal en el almacén, y coger otra del almacén. LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático." .

ex:Subrutina_SUB_SPD_AUTCHG
    a ex:TareaMantenimiento ;
    rdfs:label "Subrutina SUB_SPD_AUTCHG" ;
    ex:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático." .

ex:Subrutina_SUB_MZ_TO_CH1
    a ex:TareaMantenimiento ;
    rdfs:label "Subrutina SUB_MZ_TO_CH1" ;
    ex:textoExtracto "LL SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1." .

ex:Subrutina_SUB_CH1_TO_SPD
    a ex:TareaMantenimiento ;
    rdfs:label "Subrutina SUB_CH1_TO_SPD" ;
    ex:textoExtracto "LL SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal." .

ex:Subrutina_SUB_SPD_TO_CH2
    a ex:TareaMantenimiento ;
    rdfs:label "Subrutina SUB_SPD_TO_CH2" ;
    ex:textoExtracto "LL SUB_SPD_TO_CH2 ; Coger la herramienta del cabezal con la pinza 2." .

ex:Subrutina_SUB_CH2_TO_MZ
    a ex:TareaMantenimiento ;
    rdfs:label "Subrutina SUB_CH2_TO_MZ" ;
    ex:textoExtracto "LL SUB_CH2_TO_MZ ; Dejar la herramienta de la pinza 2 en el almacén." .

ex:Subrutina_SUB_SPD_GMCHG
    a ex:TareaMantenimiento ;
    rdfs:label "Subrutina SUB_SPD_GMCHG" ;
    ex:textoExtracto "LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual." .

ex:Subrutina_SUB_GR_TO_SPD
    a ex:TareaMantenimiento ;
    rdfs:label "Subrutina SUB_GR_TO_SPD" ;
    ex:textoExtracto "LL SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal." .

ex:Subrutina_SUB_SPD_TO_GR
    a ex:TareaMantenimiento ;
    rdfs:label "Subrutina SUB_SPD_TO_GR" ;
    ex:textoExtracto "LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal." .

ex:RutinaM06
    a ex:ModoOperacion ;
    rdfs:label "Rutina M06 (Programa de cambio de herramienta)" ;
    ex:textoExtracto "$SWITCH V.PLC.TMOPERATION; Analiza el tipo de operación." ;
    ex:tieneFrecuencia ex:RutinaM06_EjecucionSimulada , ex:RutinaM06_EjecucionReal ;
    ex:compuestoPor ex:TareaMantenimiento_CambioHerramientaAutomatico_Caso1 ,
                     ex:TareaMantenimiento_DevolucionHerramientaAutomatica_Caso2 ,
                     ex:TareaMantenimiento_ColocacionHerramientaTierra_Caso3 ,
                     ex:TareaMantenimiento_DevolucionHerramientaTierra_Caso4 ,
                     ex:TareaMantenimiento_CambioHerramientaCombinado_Caso5 ,
                     ex:Subrutina_SUB_SPD_AUTCHG ,
                     ex:Subrutina_SUB_MZ_TO_CH1 ,
                     ex:Subrutina_SUB_CH1_TO_SPD ,
                     ex:Subrutina_SUB_SPD_TO_CH2 ,
                     ex:Subrutina_SUB_CH2_TO_MZ ,
                     ex:Subrutina_SUB_SPD_GMCHG ,
                     ex:Subrutina_SUB_GR_TO_SPD ,
                     ex:Subrutina_SUB_SPD_TO_GR .