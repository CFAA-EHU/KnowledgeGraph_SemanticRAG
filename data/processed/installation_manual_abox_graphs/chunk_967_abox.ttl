@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:RutinaM06 a ex:ModoOperacion ;
    rdfs:label "Rutina M06 (Cambio de herramientas)"@es ;
    ex:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático. [...] LL SUB_CH2_TO_MZ ; Dejar la herramienta de la pinza 2 en el almacén."@es ;
    ex:identificador "M06" .

ex:PuntoCambioAutomatico a ex:ComponenteMecanico ;
    rdfs:label "Punto de cambio automático de herramientas"@es ;
    ex:textoExtracto "Llevar el cabezal al punto de cambio automático"@es .

ex:PuntoCambioManual a ex:ComponenteMecanico ;
    rdfs:label "Punto de cambio manual de herramientas"@es ;
    ex:textoExtracto "Llevar el cabezal al punto de cambio manual"@es .

ex:Pinza1 a ex:ComponenteMecanico ;
    rdfs:label "Pinza 1"@es ;
    ex:textoExtracto "coger la herramienta del almacén con la pinza 1 [...] llevar la herramienta de la pinza 1 al cabezal"@es .

ex:Pinza2 a ex:ComponenteMecanico ;
    rdfs:label "Pinza 2"@es ;
    ex:textoExtracto "coger la herramienta del cabezal con la pinza 2 [...] dejar la herramienta de la pinza 2 en el almacén"@es .

ex:AlmacenHerramientas a ex:ComponenteMecanico ;
    rdfs:label "Almacén de herramientas"@es ;
    ex:textoExtracto "dejar la herramienta [...] en el almacén [...] coger la herramienta del almacén"@es .

ex:Cabezal a ex:ComponenteMecanico ;
    rdfs:label "Cabezal portaherramientas"@es ;
    ex:textoExtracto "llevar el cabezal al punto de cambio [...] quitar la herramienta del cabezal [...] colocar la herramienta de tierra en el cabezal"@es .

ex:HerramientaTierra a ex:Herramienta ;
    rdfs:label "Herramienta de tierra"@es ;
    ex:textoExtracto "colocar la herramienta de tierra en el cabezal"@es .

ex:RutinaM06 ex:tieneComponente ex:Cabezal, ex:Pinza1, ex:Pinza2, ex:PuntoCambioAutomatico, ex:PuntoCambioManual, ex:AlmacenHerramientas .
ex:RutinaM06 ex:requiereMantenimiento ex:HerramientaTierra .