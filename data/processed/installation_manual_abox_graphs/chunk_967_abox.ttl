@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:LL_SUB_SPD_AUTCHG a ex:ModoOperacion ;
    ex:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático." .

ex:LL_SUB_SPD_TO_CH2 a ex:ModoOperacion ;
    ex:textoExtracto "LL SUB_SPD_TO_CH2 ; Coger la herramienta del cabezal con la pinza 2." .

ex:LL_SUB_CH2_TO_MZ a ex:ModoOperacion ;
    ex:textoExtracto "LL SUB_CH2_TO_MZ ; Dejar la herramienta de la pinza 2 en el almacén." .

ex:LL_SUB_SPD_GMCHG a ex:ModoOperacion ;
    ex:textoExtracto "LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual." .

ex:LL_SUB_GR_TO_SPD a ex:ModoOperacion ;
    ex:textoExtracto "LL SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal." .

ex:LL_SUB_SPD_TO_GR a ex:ModoOperacion ;
    ex:textoExtracto "LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal." .

ex:LL_SUB_MZ_TO_CH1 a ex:ModoOperacion ;
    ex:textoExtracto "LL SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1." .

ex:LL_SUB_CH1_TO_SPD a ex:ModoOperacion ;
    ex:textoExtracto "LL SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal." .