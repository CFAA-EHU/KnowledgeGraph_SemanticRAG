@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Gestor a ns1:Sistema ;
    rdfs:label "Gestor" ;
    ns1:textoExtracto "informar al gestor de las operaciones que ha realizado." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:documentadoEn ns1:TablaMarcasRegistros ;
    ns1:textoExtracto "El PLC utiliza las siguientes marcas para informar al gestor de las operaciones que ha realizado." .

ns1:TablaMarcasRegistros a ns1:Tabla ;
    rdfs:label "Tabla de Marcas y Registros" ;
    ns1:textoExtracto "En la siguiente tabla se muestran los mnemónicos de cada marca (M) o registro (R) en cada uno de los canales o almacenes." .

