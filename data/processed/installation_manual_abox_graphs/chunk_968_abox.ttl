    rdfs:label "LL SUB_SPD_TO_CH2" ;
    ex:textoExtracto "LL SUB_SPD_TO_CH2 ; Coger la herramienta del cabezal con la pinza 2." .

ex:LL_SUB_CH2_TO_MZ_968 a ex:TareaMantenimiento ;
    rdfs:label "LL SUB_CH2_TO_MZ" ;
    ex:textoExtracto "LL SUB_CH2_TO_MZ ; Dejar la herramienta de la pinza 2 en el almacén." .

ex:BREAK_CASE_10_968 a ex:TareaMantenimiento ;
    rdfs:label "$BREAK $CASE 10" ;
    ex:textoExtracto "$BREAK $CASE 10 ; Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal." .

