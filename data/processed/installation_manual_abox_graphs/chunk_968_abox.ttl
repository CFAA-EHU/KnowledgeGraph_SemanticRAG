@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:TablaMnemonicosAlmacen a ns1:Tabla ;
    rdfs:label "Tabla de mnemónicos de marcas y registros en almacenes" ;
    ns1:ilustra ns1:Parametro_92b7e6b9ba,
        ns1:PosicionDelEjeEnElAlmacen,
        ns1:VelocidadDeCorteAlCanal1,
        ns1:VelocidadDeCorteDelEje1AlCanal ;
    ns1:textoExtracto "En la siguiente tabla se muestran los mnemónicos de cada marca (M) o registro (R) en cada uno de los canales o almacenes." .

ns1:Parametro_92b7e6b9ba a ns1:Parametro ;
    rdfs:label "Marca para canal 1 a almacen" ;
    ns1:identificador "MZTOCH1" ;
    ns1:textoExtracto "MZTOCH1" .

ns1:PosicionDelEjeEnElAlmacen a ns1:Parametro ;
    rdfs:label "Posición del eje en el almacen" ;
    ns1:identificador "MZPOS" ;
    ns1:textoExtracto "MZPOS" .

ns1:VelocidadDeCorteAlCanal1 a ns1:Parametro ;
    rdfs:label "Velocidad de corte al canal 1" ;
    ns1:identificador "SPDLTOCH1" ;
    ns1:textoExtracto "SPDLTOCH1" .

ns1:VelocidadDeCorteDelEje1AlCanal a ns1:Parametro ;
    rdfs:label "Velocidad de corte del eje 1 al canal" ;
    ns1:identificador "CH1TOSPDL" ;
    ns1:textoExtracto "CH1TOSPDL" .

