@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:RutinaM06 a ex:ModoOperacion ;
    rdfs:label "Rutina M06 (Programa de cambio manual)"@es ;
    ex:textoExtracto "cambio manual. LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal. [...] # RET"@es ;
    ex:identificador "M06" .

ex:Subrutina_SUB_SPD_TO_GR a ex:TareaMantenimiento ;
    rdfs:label "SUB_SPD_TO_GR (Quitar herramienta del cabezal)"@es ;
    ex:textoExtracto "LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal."@es ;
    ex:identificador "SUB_SPD_TO_GR" ;
    ex:ejecutadoPor ex:RutinaM06 .

ex:GestorAlmacen a ex:Sistema ;
    rdfs:label "Gestor del almacén (MZWAIT)"@es ;
    ex:textoExtracto "$WHILE V.TM.MZWAIT == 1 $ENDWHILE ; Espera al gestor del almacén."@es ;
    ex:identificador "MZWAIT" .

ex:TeclaESTOP a ex:ElementoSeguridad ;
    rdfs:label "Tecla STOP (ESTOP)"@es ;
    ex:textoExtracto "# ESTOP ; Habilitar la tecla STOP."@es ;
    ex:identificador "ESTOP" ;
    ex:mitigaRiesgo ex:RutinaM06 .