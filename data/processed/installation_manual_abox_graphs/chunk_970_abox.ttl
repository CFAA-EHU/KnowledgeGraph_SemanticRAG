@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Marca_MZROT a ex:Componente ;
    rdfs:label "MZROT" ;
    ex:textoExtracto "Activar la marca MZROT para indicar al gestor que se ha finalizado la operación." .

ex:Marca_MZTOCH1 a ex:Componente ;
    rdfs:label "MZTOCH1" ;
    ex:textoExtracto "DFU M1101 = SET MZTOCH1 DFD MZTOCH1 = RES M1101 La herramienta se ha llevado del almacén a la pinza 1." .

ex:Marca_CH1TOSPDL a ex:Componente ;
    rdfs:label "CH1TOSPDL" ;
    ex:textoExtracto "DFU M1102 = SET CH1TOSPDL DFD CH1TOSPDL = RES M1102 La herramienta se ha llevado de la pinza 1 al cabezal." .

ex:Marca_SPDLTOCH2 a ex:Componente ;
    rdfs:label "SPDLTOCH2" ;
    ex:textoExtracto "DFU M1104 = SET SPDLTOCH2 DFD SPDLTOCH2 = RES M1104 La herramienta se ha llevado del cabezal a la pinza 2." .

ex:Marca_CH2TOMZ a ex:Componente ;
    rdfs:label "CH2TOMZ" ;
    ex:textoExtracto "DFU M1106 = SET CH2TOMZ DFD CH2TOMZ = RES M1106 La herramienta se ha llevado de la pinza 2 al almacén." .

ex:Marca_SPDLTOGR a ex:Componente ;
    rdfs:label "SPDLTOGR" ;
    ex:textoExtracto "DFU M1107 = SET SPDLTOGR DFD SPDLTOGR = RES M1107 La herramienta se ha llevado del cabezal a tierra." .

ex:Marca_GRTOSPDL a ex:Componente ;
    rdfs:label "GRTOSPDL" ;
    ex:textoExtracto "DFU M1108 = SET GRTOSPDL DFD GRTOSPDL = RES M1108 La herramienta se ha llevado de tierra al cabezal." .

ex:Funcion_M101 a ex:Componente ;
    rdfs:label "M101" ;
    ex:textoExtracto "M101 Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1." .

ex:Funcion_M102 a ex:Componente ;
    rdfs:label "M102" ;
    ex:textoExtracto "M102 Llevar la herramienta de la pinza 1 al cabezal." .

ex:Funcion_M104 a ex:Componente ;
    rdfs:label "M104" ;
    ex:textoExtracto "M104 Coger la herramienta del cabezal con la pinza 2." .