@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:M101 a ex:TareaMantenimiento ;
    rdfs:label "M101" ;
    ex:textoExtracto "Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1." ;
    ex:identificador "M101" .

ex:M102 a ex:TareaMantenimiento ;
    rdfs:label "M102" ;
    ex:textoExtracto "Llevar la herramienta de la pinza 1 al cabezal." ;
    ex:identificador "M102" .

ex:M104 a ex:TareaMantenimiento ;
    rdfs:label "M104" ;
    ex:textoExtracto "Coger la herramienta del cabezal con la pinza 2." ;
    ex:identificador "M104" .

ex:M106 a ex:TareaMantenimiento ;
    rdfs:label "M106" ;
    ex:textoExtracto "Seleccionar en el almacén la posición que indica LEAVEPOS y dejar la herramienta de la pinza 2." ;
    ex:identificador "M106" .

ex:TAKEPOS a ex:Parametro ;
    rdfs:label "TAKEPOS" ;
    ex:textoExtracto "Este registro indica la posición de almacén en la que hay que coger la herramienta." .

ex:LEAVEPOS a ex:Parametro ;
    rdfs:label "LEAVEPOS" ;
    ex:textoExtracto "Este registro indica la posición de almacén en la que hay que dejar la herramienta." .

ex:M101 ex:ejecutadoPor ex:PLC ;
    ex:textoExtracto "Su programación depende del tipo de máquina." .

ex:PLC a ex:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ex:textoExtracto "Su programación depende del tipo de máquina." .