@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:LEAVEPOS a ex:Parametro ;
    ex:textoExtracto "Este registro indica la posición de almacén en la que hay que dejar la herramienta." ;
    rdfs:label "LEAVEPOS" .

ex:TAKEPOS a ex:Parametro ;
    ex:textoExtracto "Este registro indica la posición de almacén que ocupa la herramienta que hay que coger." ;
    rdfs:label "TAKEPOS" .

ex:TMINEM a ex:Parametro ;
    ex:textoExtracto "Señal de emergencia del gestor. Tratamiento de la señal de emergencia del gestor de herramientas. Si se pulsa la tecla USER12 se activa la emergencia. TMINEM = B11KEYLED1 Lámpara de la tecla USER12 iluminada cuando hay emergencia. TMINEM AND DFU B12KEYBD1 = SET RESTMEM Si se pulsa la tecla USER13 se quita la emergencia." ;
    rdfs:label "TMINEM" .

ex:USER12 a ex:Sensor ;
    ex:textoExtracto "Si se pulsa la tecla USER12 se activa la emergencia." ;
    rdfs:label "USER12" .

ex:USER13 a ex:Sensor ;
    ex:textoExtracto "Si se pulsa la tecla USER13 se quita la emergencia." ;
    rdfs:label "USER13" .

ex:B11KEYLED1 a ex:ComponenteElectrico ;
    ex:textoExtracto "TMINEM = B11KEYLED1 Lámpara de la tecla USER12 iluminada cuando hay emergencia." ;
    rdfs:label "B11KEYLED1" .

ex:B12KEYBD1 a ex:ComponenteElectrico ;
    ex:textoExtracto "TMINEM AND DFU B12KEYBD1 = SET RESTMEM" ;
    rdfs:label "B12KEYBD1" .