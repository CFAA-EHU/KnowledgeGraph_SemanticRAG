@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PosicionDelAlmacenTorreta a ns1:Parametro ;
    rdfs:label "Posición del almacén torreta" ;
    ns1:documentadoEn ns1:AsignacionDeValor0AlRegistroDePosicion ;
    ns1:identificador "ROTATEMZ" ;
    ns1:textoExtracto "En almacenes torreta se puede seleccionar una posición (sentencia #ROTATEMZ)." .

ns1:RegistroAlmacenTorreta a ns1:ComponenteElectrico ;
    rdfs:label "Registro de posición del almacén torreta" ;
    ns1:textoExtracto "El PLC debe indicar en este registro la posición actual del almacén." .

ns1:AsignacionDeValor0AlRegistroDePosicion a ns1:AccionProhibida ;
    rdfs:label "Asignación de valor 0 al registro de posición" ;
    ns1:textoExtracto "si el registro tiene valor ꞏ0ꞏ, el PLC mostrará el error correspondiente." .

