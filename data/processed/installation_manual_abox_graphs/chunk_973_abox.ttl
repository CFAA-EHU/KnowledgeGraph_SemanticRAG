@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:AlmacenAsincronoConBrazoCambiador a ex:Sistema ;
    rdfs:label "Almacén asíncrono con brazo cambiador" ;
    ex:textoExtracto "Los almacenes asíncronos tienen el almacén alejado del cabezal y el cambio se realiza con ayuda del brazo cambiador." ;
    ex:compuestoPor ex:BrazoCambiador, ex:AlmacenAsincrono ;
    ex:tieneComponente ex:PLC, ex:CNC .

ex:BrazoCambiador a ex:ComponenteMecanico ;
    rdfs:label "Brazo cambiador" ;
    ex:textoExtracto "el cambio se realiza con ayuda del brazo cambiador" .

ex:AlmacenAsincrono a ex:ComponenteMecanico ;
    rdfs:label "Almacén asíncrono" ;
    ex:textoExtracto "Los almacenes asíncronos tienen el almacén alejado del cabezal" .

ex:PLC a ex:ComponenteElectrico ;
    rdfs:label "PLC" ;
    ex:textoExtracto "la comunicación entre el gestor y el PLC se realiza en 2 fases" .

ex:CNC a ex:ComponenteElectrico ;
    rdfs:label "CNC" ;
    ex:textoExtracto "Cuando el CNC ejecuta la función T" .