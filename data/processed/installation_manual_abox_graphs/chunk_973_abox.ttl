@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_714ce331bc a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC pone esta marca a (=1) para indicar al PLC que se ha producido una emergencia en el gestor de herramientas." .

ns1:SistemaGestorHerramientas a ns1:Sistema ;
    rdfs:label "Sistema Gestor de Herramientas" ;
    ns1:textoExtracto "El gestor se puede poner en estado de emergencia si se produce una anomalía (el PLC ha ejecutado una acción equivocada, cambio no finalizado, etc) o si el PLC activa la emergencia." ;
    ns1:tieneComponente ns1:Parametro_9566f911cd,
        ns1:Parametro_b34662d52d,
        ns1:Parametro_d0f8f07b92 .

ns1:Parametro_9566f911cd a ns1:Parametro ;
    rdfs:label "Marca para activar la emergencia del gestor de herramientas" ;
    ns1:identificador "SETTMEM" ;
    ns1:textoExtracto "El PLC pone esta marca a (=1) para activar la emergencia del gestor de herramientas." .

ns1:Parametro_b34662d52d a ns1:Parametro ;
    rdfs:label "Marca para indicar una emergencia en el gestor de herramientas" ;
    ns1:identificador "TMINEM" ;
    ns1:textoExtracto "El CNC pone esta marca a (=1) para indicar al PLC que se ha producido una emergencia en el gestor de herramientas." .

ns1:Parametro_d0f8f07b92 a ns1:Parametro ;
    rdfs:label "Marca para cancelar la emergencia del gestor de herramientas" ;
    ns1:identificador "RESTMEM" ;
    ns1:textoExtracto "El PLC pone esta marca a (=1) para cancelar la emergencia del gestor de herramientas." .

