@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_47ae7a9d51 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:textoExtracto "El CNC consulta esta marca para saber si la herramienta está mecanizando." .

ns1:Parametro_2b84c3ac40 a ns1:Parametro ;
    rdfs:label "Marca que indica que la herramienta ha sido rechazada por uso excesivo" ;
    ns1:identificador "TWORNOUT" ;
    ns1:textoExtracto "El CNC pone esta marca a (=1) para indicar al PLC que la herramienta ha sido rechazada porque se ha usado más tiempo del previsto (vida real > vida máxima)." .

ns1:Parametro_b42675bf22 a ns1:Parametro ;
    rdfs:label "Marca que indica si la herramienta está mecanizando" ;
    ns1:identificador "CUTTINGON" ;
    ns1:textoExtracto "Cuando se le asocia a la herramienta un tiempo máximo de vida (monitorización) el CNC consulta esta marca para saber si la herramienta está mecanizando (=1) o no (=0)." .

ns1:Parametro_ec370ccb03 a ns1:Parametro ;
    rdfs:label "Marca que indica que la herramienta debe ser rechazada" ;
    ns1:identificador "TREJECT" ;
    ns1:textoExtracto "Si el PLC pone esta marca a (=1) el CNC entiende que la herramienta debe ser rechazada." .

