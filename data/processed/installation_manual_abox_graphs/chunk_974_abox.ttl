@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoOperacion0 a ex:ModoOperacion ;
    rdfs:label "0" ;
    ex:textoExtracto "No hay que hacer nada." ;
    ex:identificador "TMOPERATION 0" .

ex:ModoOperacion1 a ex:ModoOperacion ;
    rdfs:label "1" ;
    ex:textoExtracto "Coger una herramienta del brazo y ponerla en el cabezal." ;
    ex:identificador "TMOPERATION 1" .

ex:ModoOperacion2 a ex:ModoOperacion ;
    rdfs:label "2" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén." ;
    ex:identificador "TMOPERATION 2" .

ex:ModoOperacion3 a ex:ModoOperacion ;
    rdfs:label "3" ;
    ex:textoExtracto "Poner en el cabezal una herramienta de tierra." ;
    ex:identificador "TMOPERATION 3" .

ex:ModoOperacion4 a ex:ModoOperacion ;
    rdfs:label "4" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en tierra." ;
    ex:identificador "TMOPERATION 4" .

ex:ModoOperacion5 a ex:ModoOperacion ;
    rdfs:label "5" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger una herramienta del brazo. Las herramientas del cabezal y del brazo son del mismo almacén." ;
    ex:identificador "TMOPERATION 5" .

ex:ModoOperacion6 a ex:ModoOperacion ;
    rdfs:label "6" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger una herramienta de tierra." ;
    ex:identificador "TMOPERATION 6" .

ex:ModoOperacion7 a ex:ModoOperacion ;
    rdfs:label "7" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en tierra y coger una herramienta del brazo." ;
    ex:identificador "TMOPERATION 7" .

ex:ModoOperacion8 a ex:ModoOperacion ;
    rdfs:label "8" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra." ;
    ex:identificador "TMOPERATION 8" .

ex:ModoOperacion9 a ex:ModoOperacion ;
    rdfs:label "9" ;
    ex:textoExtracto "Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal." ;
    ex:identificador "TMOPERATION 9" .

ex:ModoOperacion10 a ex:ModoOperacion ;
    rdfs:label "10" ;
    ex:textoExtracto "Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal." ;
    ex:identificador "TMOPERATION 10" .

ex:ModoOperacion11 a ex:ModoOperacion ;
    rdfs:label "11" ;
    ex:textoExtracto "Coger una herramienta del almacén y ponerla en el brazo." ;
    ex:identificador "TMOPERATION 11" .

ex:ModoOperacion12 a ex:ModoOperacion ;
    rdfs:label "12" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén (como TMOPERATION=5). Es una operación optimizada, valida cuando ambas herramientas son especiales y pueden colisionar en el brazo o no se desea que coincidan en el brazo cambiador." ;
    ex:identificador "TMOPERATION 12" .

ex:ModoOperacion14 a ex:ModoOperacion ;
    rdfs:label "14" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger una herramienta del brazo. Las herramientas del cabezal y del brazo son de almacenes diferentes." ;
    ex:identificador "TMOPERATION 14" .

ex:ModoOperacion16 a ex:ModoOperacion ;
    rdfs:label "16" ;
    ex:textoExtracto "Dejar la herramienta del brazo (pinza ꞏ2ꞏ) en el almacén." ;
    ex:identificador "TMOPERATION 16" .