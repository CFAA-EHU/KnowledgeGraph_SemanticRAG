@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:HerramientaAlmacen1 a ex:Herramienta ;
    rdfs:label "herramienta del almacén"@es ;
    ex:textoExtracto "herramienta del almacén"@es .

ex:HerramientaBrazoPinza1 a ex:Herramienta ;
    rdfs:label "herramienta del brazo (pinza 1)"@es ;
    ex:textoExtracto "herramienta del brazo (pinza ꞏ1ꞏ)"@es .

ex:HerramientaBrazoPinza2 a ex:Herramienta ;
    rdfs:label "herramienta del brazo (pinza 2)"@es ;
    ex:textoExtracto "herramienta del brazo (pinza ꞏ2ꞏ)"@es .

ex:RegistroTAKEPOS a ex:Parametro ;
    rdfs:label "TAKEPOS"@es ;
    ex:textoExtracto "TAKEPOS"@es .

ex:RegistroLEAVEPOS a ex:Parametro ;
    rdfs:label "LEAVEPOS"@es ;
    ex:textoExtracto "LEAVEPOS"@es .