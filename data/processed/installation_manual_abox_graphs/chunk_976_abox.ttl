@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Tabla976_1 a ex:Tabla ;
    ex:textoExtracto """| Valor | Significado |
| --- | --- |
| 0 | No hay que hacer nada. |
| # | Posición en el almacén. |
| -1 | Pinza ꞏ1ꞏ del brazo cambiador. |
| -4 | Herramienta de tierra. |""" ;
    ex:compuestoPor ex:EntradaTabla976_0, ex:EntradaTabla976_1, ex:EntradaTabla976_2, ex:EntradaTabla976_3 .

ex:EntradaTabla976_0 a ex:Tabla ;
    ex:textoExtracto "| 0 | No hay que hacer nada. |" ;
    ex:valor "0" ;
    rdfs:label "No hay que hacer nada."@es .

ex:EntradaTabla976_1 a ex:Tabla ;
    ex:textoExtracto "| # | Posición en el almacén. |" ;
    ex:valor "#" ;
    rdfs:label "Posición en el almacén."@es .

ex:EntradaTabla976_2 a ex:Tabla ;
    ex:textoExtracto "| -1 | Pinza ꞏ1ꞏ del brazo cambiador. |" ;
    ex:valor "-1" ;
    rdfs:label "Pinza 1 del brazo cambiador."@es .

ex:EntradaTabla976_3 a ex:Tabla ;
    ex:textoExtracto "| -4 | Herramienta de tierra. |" ;
    ex:valor "-4" ;
    rdfs:label "Herramienta de tierra."@es .

ex:Tabla976_2 a ex:Tabla ;
    ex:textoExtracto """ A continuación se muestra una tabla resumen de los valores TAKEPOS y LEAVEPOS que utiliza el gestor en cada una de las operaciones, así como las marcas que debe activar el PLC al finalizar cada operación. La marca TCHANGEOK es opcional y sólo se debe utilizar cuando es posible. Una vez efectuado el cambio y la herramienta está en el brazo, activar la marca TCHANGEOK para continuar la ejecución del programa mientras se deja la herramienta en el almacén.""" ;
    ex:compuestoPor ex:MarcaTCHANGEOK .

ex:MarcaTCHANGEOK a ex:Sensor ;
    ex:textoExtracto "La marca TCHANGEOK es opcional y sólo se debe utilizar cuando es posible." ;
    rdfs:label "TCHANGEOK"@es .