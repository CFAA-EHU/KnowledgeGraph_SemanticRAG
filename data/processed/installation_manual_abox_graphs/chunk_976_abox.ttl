@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_ValoresTAKEPOS_LEAVEPOS a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de valores TAKEPOS/LEAVEPOS y marcas PLC"@es ;
    ex:textoExtracto "A continuación se muestra una tabla resumen de los valores TAKEPOS y LEAVEPOS que utiliza el gestor en cada una de las operaciones, así como las marcas que debe activar el PLC al finalizar cada operación."@es ;
    ex:ilustradoEn ex:Pagina_527_529 .

ex:Parametro_TAKEPOS
    a ex:Parametro ;
    rdfs:label "Parámetro TAKEPOS"@es ;
    ex:textoExtracto "valores TAKEPOS [...] que utiliza el gestor en cada una de las operaciones"@es ;
    ex:documentadoEn ex:Tabla_ValoresTAKEPOS_LEAVEPOS ;
    ex:valor "0" , "#" , "-1" , "-4" .

ex:Parametro_LEAVEPOS
    a ex:Parametro ;
    rdfs:label "Parámetro LEAVEPOS"@es ;
    ex:textoExtracto "valores [...] LEAVEPOS que utiliza el gestor en cada una de las operaciones"@es ;
    ex:documentadoEn ex:Tabla_ValoresTAKEPOS_LEAVEPOS .

ex:Marca_PLC_TCHANGEOK
    a ex:AvisoSeguridad ;
    rdfs:label "Marca TCHANGEOK"@es ;
    ex:textoExtracto "La marca TCHANGEOK es opcional y sólo se debe utilizar cuando es posible. Una vez efectuado el cambio y la herramienta está en el brazo, activar la marca TCHANGEOK para continuar la ejecución del programa mientras se deja la herramienta en el almacén."@es ;
    ex:documentadoEn ex:Tabla_ValoresTAKEPOS_LEAVEPOS .

ex:Herramienta_PinzaBrazoCambiador
    a ex:Herramienta ;
    rdfs:label "Pinza ꞏ1ꞏ del brazo cambiador"@es ;
    ex:identificador "-1" ;
    ex:textoExtracto "-1: Pinza ꞏ1ꞏ del brazo cambiador."@es ;
    ex:documentadoEn ex:Tabla_ValoresTAKEPOS_LEAVEPOS .

ex:Herramienta_Tierra
    a ex:Herramienta ;
    rdfs:label "Herramienta de tierra"@es ;
    ex:identificador "-4" ;
    ex:textoExtracto "-4: Herramienta de tierra."@es ;
    ex:documentadoEn ex:Tabla_ValoresTAKEPOS_LEAVEPOS .

ex:Sistema_GestorPLC
    a ex:Sistema ;
    rdfs:label "Gestor PLC"@es ;
    ex:textoExtracto "gestor en cada una de las operaciones, así como las marcas que debe activar el PLC al finalizar cada operación"@es ;
    ex:controla ex:Marca_PLC_TCHANGEOK ;
    ex:monitoreaParametro ex:Parametro_TAKEPOS , ex:Parametro_LEAVEPOS .