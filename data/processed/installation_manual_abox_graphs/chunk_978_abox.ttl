@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioDeHerramientas a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramientas" ;
    ns1:textoExtracto "En la subrutina asociada a la función M06 y en el programa del PLC deberá estar definida la maniobra necesaria para realizar el cambio." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "En la subrutina asociada a la función M06 y en el programa del PLC deberá estar definida la maniobra necesaria para realizar el cambio." .

ns1:TablaAlmacenHerramientas a ns1:Tabla ;
    rdfs:label "Tabla de almacén" ;
    ns1:textoExtracto "Tras descargar la herramienta el gestor actualiza la tabla de almacén." .

ns1:VariablePersonalizada a ns1:Parametro ;
    rdfs:label "Variable personalizada para colocar herramienta en cabezal" ;
    ns1:identificador "variable personalizada" ;
    ns1:textoExtracto "Colocar una herramienta en el cabezal desde programa o MDI Personalizar la variable" .

