@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CambioDeHerramientaDesdeProgramaOMDI a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta desde programa o MDI" ;
    ns1:textoExtracto "Personalizar la variable V.TM.MZMODE=0, para indicar al gestor que se desea trabajar en modo normal." .

ns1:ModoDeTrabajoNormalParaElCambioDeHerramienta a ns1:Parametro ;
    rdfs:label "Modo de trabajo normal para el cambio de herramienta" ;
    ns1:identificador "VTM.ZMODE" ;
    ns1:textoExtracto "Personalizar la variable V.TM.MZMODE=0, para indicar al gestor que se desea trabajar en modo normal." .

ns1:OperacionDeCambioDeHerramientaAsignadaAlPLC a ns1:Parametro ;
    rdfs:label "Operación de cambio de herramienta asignada al PLC" ;
    ns1:identificador "TMOPERATION" ;
    ns1:textoExtracto "comunica al PLC la operación a efectuar asignando a TMOPERATION el valor adecuado." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "comunica al PLC la operación a efectuar asignando a TMOPERATION el valor adecuado." .

ns1:SubrutinaFuncionM06 a ns1:Sistema ;
    rdfs:label "Subrutina asociada a la función M06" ;
    ns1:textoExtracto "En la subrutina asociada a la función M06 y en el programa del PLC deberá estar definida la maniobra necesaria para realizar el cambio." .

ns1:TablaAlmacenHerramientas a ns1:Sistema ;
    rdfs:label "Tabla de almacén de herramientas" ;
    ns1:textoExtracto "Tras descargar la herramienta el gestor actualiza la tabla de almacén." .

