@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:Tabla_OperacionesPLC_7_11_1 a ex:Tabla ;
     a ex:Tabla ;
    rdfs:label "Tabla de operaciones válidas y marcas activadas por el PLC (Sección 7.11.1)" ;
    ex:textoExtracto " | CNC | TMOPERATION | TAKEPOS | LEAVEPOS |  | | --- | --- | --- | --- | --- | | T1 M6 | 11 1 | 1 -1 | 0 0 | MZTOCH1 CH1TOSPDL | | T2 M6 | 11 5 | 2 -1 | 0 1 | MZTOCH1 SPDLTOCH2 + CH1TOSPDL + (TCHANGEOK) + CH2TOMZ | | T7 M6 | 0 6 | 0 -4 | 0 2 | SPDLTOCH2 + CH2TOMZ + GRTOSPDL | | T8 M6 | 0 8 | 0 -4 | 0 -4 | SPDLTOGR + GRTOSPDL | | T3 T4 M6 | 11 11 7 | 3 4 -1 | 0 3 -4 | MZTOCH1 CH1TOMZ + MZTOCH1 SDPLTOGR + CH1TOSPDL | | T0 M6 | 0 2 | 0 0 | 0 4 | SPDLTOCH2 + (TCHANGEOK) + CH2TOMZ | " .

ex:Sistema_ControlPLC_7_11_1
    a ex:Sistema ;
    rdfs:label "Sistema de control PLC para operaciones de cambio de herramienta" ;
    ex:textoExtracto "Operaciones válidas y marcas que activa el PLC con cada una de ellas" ;
    ex:documentadoEn ex:Tabla_OperacionesPLC_7_11_1 .

ex:ModoOperacion_T1_M6
    a ex:ModoOperacion ;
    rdfs:label "Modo T1 (M6)" ;
    ex:identificador "T1 M6" ;
    ex:textoExtracto "TMOPERATION=11/1, TAKEPOS=1/-1, LEAVEPOS=0/0 | Marcas: MZTOCH1, CH1TOSPDL" ;
    ex:detalladoEnEsquema ex:Tabla_OperacionesPLC_7_11_1 .

ex:ModoOperacion_T2_M6
    a ex:ModoOperacion ;
    rdfs:label "Modo T2 (M6)" ;
    ex:identificador "T2 M6" ;
    ex:textoExtracto "TMOPERATION=11/5, TAKEPOS=2/-1, LEAVEPOS=0/1 | Marcas: MZTOCH1, SPDLTOCH2, CH1TOSPDL, (TCHANGEOK), CH2TOMZ" ;
    ex:detalladoEnEsquema ex:Tabla_OperacionesPLC_7_11_1 .

ex:ModoOperacion_T7_M6
    a ex:ModoOperacion ;
    rdfs:label "Modo T7 (M6)" ;
    ex:identificador "T7 M6" ;
    ex:textoExtracto "TMOPERATION=0/6, TAKEPOS=0/-4, LEAVEPOS=0/2 | Marcas: SPDLTOCH2, CH2TOMZ, GRTOSPDL" ;
    ex:detalladoEnEsquema ex:Tabla_OperacionesPLC_7_11_1 .

ex:ModoOperacion_T8_M6
    a ex:ModoOperacion ;
    rdfs:label "Modo T8 (M6)" ;
    ex:identificador "T8 M6" ;
    ex:textoExtracto "TMOPERATION=0/8, TAKEPOS=0/-4, LEAVEPOS=0/-4 | Marcas: SPDLTOGR, GRTOSPDL" ;
    ex:detalladoEnEsquema ex:Tabla_OperacionesPLC_7_11_1 .

ex:ModoOperacion_T3_T4_M6
    a ex:ModoOperacion ;
    rdfs:label "Modo T3/T4 (M6)" ;
    ex:identificador "T3 T4 M6" ;
    ex:textoExtracto "TMOPERATION=11/11/7, TAKEPOS=3/4/-1, LEAVEPOS=0/3/-4 | Marcas: MZTOCH1, CH1TOMZ, SDPLTOGR, CH1TOSPDL" ;
    ex:detalladoEnEsquema ex:Tabla_OperacionesPLC_7_11_1 .

ex:ModoOperacion_T0_M6
    a ex:ModoOperacion ;
    rdfs:label "Modo T0 (M6)" ;
    ex:identificador "T0 M6" ;
    ex:textoExtracto "TMOPERATION=0/2, TAKEPOS=0/0, LEAVEPOS=0/4 | Marcas: SPDLTOCH2, (TCHANGEOK), CH2TOMZ" ;
    ex:detalladoEnEsquema ex:Tabla_OperacionesPLC_7_11_1 .