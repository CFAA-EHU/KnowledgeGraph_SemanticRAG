@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:OperacionesAlmacen_7_11_2
    a               ex:Sistema ;
    rdfs:label      "Operaciones del almacén (Sección 7.11.2)"@es ;
    ex:textoExtracto "A continuación se muestra una descripción detallada de las operaciones válidas para este almacén. Para cada operación se indica cuáles de las señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas, así como su significado. También aparece cuál es la secuencia a seguir para completar la operación."@es ;
    ex:identificador "7.11.2" .

ex:Senal_TAKEPOS
    a               ex:ComponenteElectrico ;
    rdfs:label      "Señal TAKEPOS"@es ;
    ex:textoExtracto "señales TAKEPOS"@es ;
    ex:monitoreaParametro ex:Param_TAKEPOS .

ex:Senal_LEAVEPOS
    a               ex:ComponenteElectrico ;
    rdfs:label      "Señal LEAVEPOS"@es ;
    ex:textoExtracto "señales LEAVEPOS"@es ;
    ex:monitoreaParametro ex:Param_LEAVEPOS .

ex:Senal_NEXTPOS
    a               ex:ComponenteElectrico ;
    rdfs:label      "Señal NEXTPOS"@es ;
    ex:textoExtracto "señales NEXTPOS"@es ;
    ex:monitoreaParametro ex:Param_NEXTPOS .

ex:Senal_MZID
    a               ex:ComponenteElectrico ;
    rdfs:label      "Señal MZID"@es ;
    ex:textoExtracto "señal MZID"@es ;
    ex:monitoreaParametro ex:Param_MZID .

ex:Param_TAKEPOS
    a               ex:Parametro ;
    rdfs:label      "Valor de TAKEPOS"@es ;
    ex:textoExtracto "valores [de TAKEPOS]"@es .

ex:Param_LEAVEPOS
    a               ex:Parametro ;
    rdfs:label      "Valor de LEAVEPOS"@es ;
    ex:textoExtracto "[LEAVEPOS] pueden tomar los siguientes valores"@es .

ex:Param_NEXTPOS
    a               ex:Parametro ;
    rdfs:label      "Valor de NEXTPOS"@es ;
    ex:textoExtracto "[NEXTPOS] pueden tomar los siguientes valores"@es .

ex:Param_MZID
    a               ex:Parametro ;
    rdfs:label      "Valor de MZID"@es ;
    ex:textoExtracto "señal MZID"@es .

ex:OperacionesAlmacen_7_11_2
    ex:tieneComponente ex:Senal_TAKEPOS, ex:Senal_LEAVEPOS, ex:Senal_NEXTPOS, ex:Senal_MZID .