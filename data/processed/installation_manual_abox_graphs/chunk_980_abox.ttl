@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Señal_TAKEPOS a ex:Sensor ;
    rdfs:label "TAKEPOS" ;
    ex:textoExtracto "señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas" ;
    ex:valor "TAKEPOS" .

ex:Señal_LEAVEPOS a ex:Sensor ;
    rdfs:label "LEAVEPOS" ;
    ex:textoExtracto "señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas" ;
    ex:valor "LEAVEPOS" .

ex:Señal_NEXTPOS a ex:Sensor ;
    rdfs:label "NEXTPOS" ;
    ex:textoExtracto "señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas" ;
    ex:valor "NEXTPOS" .

ex:Señal_MZID a ex:Sensor ;
    rdfs:label "MZID" ;
    ex:textoExtracto "señales TAKEPOS, LEAVEPOS, NEXTPOS y MZID están implicadas" ;
    ex:valor "MZID" .