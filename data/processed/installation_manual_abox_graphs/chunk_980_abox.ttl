@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_c7935e6d42 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:documentadoEn ns1:ManualBrochadoraA218 ;
    ns1:ejecuta ns1:CambioDeHerramienta_21bce437cc ;
    ns1:textoExtracto "Cuando no hay almacén de herramientas, para realizar el cambio de herramienta sólo es necesario programar la función T, sin necesidad de M6." .

ns1:Parametro_14e0d3271a a ns1:Parametro ;
    rdfs:label "Función M6 Sin Almacén de Herramientas" ;
    ns1:identificador "M6" ;
    ns1:textoExtracto "la función M6 no activará marcas de PLC (por ejemplo DM06) ni ejecutará nada relacionado con el cambio de herramienta." .

ns1:Parametro_9eb0d1cf51 a ns1:Parametro ;
    rdfs:label "Función T para Cambio de Herramienta" ;
    ns1:identificador "T" ;
    ns1:textoExtracto "programar la función T, sin necesidad de M6." .

ns1:CambioDeHerramienta_21bce437cc a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de Herramienta" ;
    ns1:textoExtracto "para realizar el cambio de herramienta sólo es necesario programar la función T, sin necesidad de M6." .

