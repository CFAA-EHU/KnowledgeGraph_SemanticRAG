@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:ModoOperacion_0 a ex:ModoOperacion ;
    rdfs:label "0" ;
    ex:textoExtracto "0 | No hay que hacer nada." ;
    ex:valor "No hay que hacer nada." .

ex:ModoOperacion_hash a ex:ModoOperacion ;
    rdfs:label "#" ;
    ex:textoExtracto "# | Posición en el almacén." ;
    ex:valor "Posición en el almacén." .

ex:ModoOperacion_menos1 a ex:ModoOperacion ;
    rdfs:label "-1" ;
    ex:textoExtracto "-1 | Pinza ꞏ1ꞏ del brazo cambiador." ;
    ex:valor "Pinza ꞏ1ꞏ del brazo cambiador." .

ex:Herramienta_herramientaDeTierra a ex:Herramienta ;
    rdfs:label "-4" ;
    ex:textoExtracto "-4 | Herramienta de tierra." ;
    ex:valor "Herramienta de tierra." .