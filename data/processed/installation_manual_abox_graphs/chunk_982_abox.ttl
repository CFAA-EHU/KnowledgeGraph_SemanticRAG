@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TMOPERATION_1 a ex:ModoOperacion ;
    ex:identificador "TMOPERATION = 1" ;
    ex:textoExtracto "Coger una herramienta del brazo y ponerla en el cabezal." .

ex:TMOPERATION_2 a ex:ModoOperacion ;
    ex:identificador "TMOPERATION = 2" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén." .

ex:TMOPERATION_3 a ex:ModoOperacion ;
    ex:identificador "TMOPERATION = 3" ;
    ex:textoExtracto "Poner en el cabezal una herramienta de tierra." .

ex:TMOPERATION_4 a ex:ModoOperacion ;
    ex:identificador "TMOPERATION = 4" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en tierra." .

ex:TMOPERATION_5 a ex:ModoOperacion ;
    ex:identificador "TMOPERATION = 5" ;
    ex:textoExtracto "Dejar la herramienta del cabezal en el almacén y coger una herramienta del brazo." .

ex:CH1TOSPDL a ex:Parametro ;
    ex:identificador "CH1TOSPDL" ;
    ex:textoExtracto "activar la marca CH1TOSPDL" .

ex:SPDLTOCH2 a ex:Parametro ;
    ex:identificador "SPDLTOCH2" ;
    ex:textoExtracto "activar la marca SPDLTOCH2" .

ex:TCHANGEOK a ex:Parametro ;
    ex:identificador "TCHANGEOK" ;
    ex:textoExtracto "activar TCHANGEOK" .

ex:CH2TOMZ a ex:Parametro ;
    ex:identificador "CH2TOMZ" ;
    ex:textoExtracto "activar la marca CH2TOMZ" .

ex:GRTOSPDL a ex:Parametro ;
    ex:identificador "GRTOSPDL" ;
    ex:textoExtracto "activar la marca GRTOSPDL" .

ex:SPDLTOGR a ex:Parametro ;
    ex:identificador "SPDLTOGR" ;
    ex:textoExtracto "activar la marca SPDLTOGR" .