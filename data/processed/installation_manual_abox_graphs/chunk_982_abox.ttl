@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Componente_cea6ff1445 a ns1:Componente ;
    rdfs:label "Almacén de herramientas" ;
    ns1:textoExtracto "El almacén es no-random, cada herramienta ocupa la posición de su mismo número y las herramientas T7 y T8 son de tierra." ;
    ns1:tieneComponente ns1:HerramientaT7,
        ns1:HerramientaT8 .

ns1:HerramientaT7 a ns1:Componente ;
    rdfs:label "Herramienta T7" ;
    ns1:textoExtracto "El almacén es no-random, cada herramienta ocupa la posición de su mismo número y las herramientas T7 y T8 son de tierra." .

ns1:HerramientaT8 a ns1:Componente ;
    rdfs:label "Herramienta T8" ;
    ns1:textoExtracto "El almacén es no-random, cada herramienta ocupa la posición de su mismo número y las herramientas T7 y T8 son de tierra." .

