@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:HerramientaCabezalAlmacen a ex:Herramienta ;
    rdfs:label "Herramienta del cabezal"@es ;
    ex:textoExtracto "Las herramientas del cabezal y del brazo son del mismo almacén."@es .

ex:HerramientaBrazoAlmacen a ex:Herramienta ;
    rdfs:label "Herramienta del brazo"@es ;
    ex:textoExtracto "Las herramientas del cabezal y del brazo son del mismo almacén."@es .

ex:TAKEPOS_1 a ex:Parametro ;
    ex:identificador "TAKEPOS=-1" ;
    ex:textoExtracto "TAKEPOS=-1 Herramienta en el brazo cambiador."@es .

ex:LEAVEPOS a ex:Parametro ;
    ex:identificador "LEAVEPOS=#" ;
    ex:textoExtracto "LEAVEPOS=# Posición del almacén para dejar la herramienta."@es .

ex:GestorOperacionAlmacen a ex:Sistema ;
    rdfs:label "gestor"@es ;
    ex:textoExtracto "el gestor admite dos secuencias"@es .

ex:TMOPERATION_11 a ex:Parametro ;
    ex:identificador "TMOPERATION=11" ;
    ex:textoExtracto "el gestor envía el código TMOPERATION=11 para coger la herramienta del almacén con la pinza 1"@es .

ex:Pinza_1 a ex:Actuador ;
    rdfs:label "pinza 1"@es ;
    ex:textoExtracto "con la pinza 1"@es .

ex:Pinza_2 a ex:Actuador ;
    rdfs:label "pinza 2"@es ;
    ex:textoExtracto "con la pinza ꞏ2ꞏ"@es .

ex:MarcaSPDLTOCH2 a ex:Parametro ;
    ex:identificador "SPDLTOCH2" ;
    ex:textoExtracto "activar la marca SPDLTOCH2"@es .

ex:MarcaCH2TOMZ a ex:Parametro ;
    ex:identificador "CH2TOMZ" ;
    ex:textoExtracto "activar la marca CH2TOMZ"@es .

ex:SecuenciaOperacionAlmacen a ex:TareaMantenimiento ;
    rdfs:label "Primera secuencia"@es ;
    ex:textoExtracto "Primera secuencia: 1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 2 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ. 3 Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal"@es .