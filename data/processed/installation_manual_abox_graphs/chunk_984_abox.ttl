@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:Pinza2 a ex:ComponenteMecanico ;
    rdfs:label "pinza 2" ;
    ex:textoExtracto "del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2" .

ex:MarcaSPDLTOCH2 a ex:Parametro ;
    ex:identificador "SPDLTOCH2" ;
    ex:textoExtracto "activar la marca SPDLTOCH2" .

ex:MarcaCH2TOMZ a ex:Parametro ;
    ex:identificador "CH2TOMZ" ;
    ex:textoExtracto "activar la marca CH2TOMZ" .

ex:Pinza1 a ex:ComponenteMecanico ;
    rdfs:label "pinza 1" ;
    ex:textoExtracto "Poner la herramienta de la pinza ꞏ1ꞏ en el cabezal" .

ex:MarcaCH1TOSPDL a ex:Parametro ;
    ex:identificador "CH1TOSPDL" ;
    ex:textoExtracto "activar la marca CH1TOSPDL" .

ex:MarcaTCHANGEOK a ex:Parametro ;
    ex:identificador "TCHANGEOK" ;
    ex:textoExtracto "activar TCHANGEOK" .

ex:MarcaGRTOSPDL a ex:Parametro ;
    ex:identificador "GRTOSPDL" ;
    ex:textoExtracto "activar la marca GRTOSPDL" .

ex:BrazoCambiador a ex:ComponenteMecanico ;
    rdfs:label "brazo cambiador" ;
    ex:textoExtracto "Comenzar el envío del brazo cambiador al almacén" .

ex:HerramientaTierra a ex:PiezaRecambio ;
    rdfs:label "herramienta de tierra" ;
    ex:textoExtracto "coger una herramienta de tierra" .

ex:Almacen a ex:Sistema ;
    rdfs:label "almacén" ;
    ex:textoExtracto "Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén" .

ex:Cabezal a ex:ComponenteMecanico ;
    rdfs:label "cabezal" ;
    ex:textoExtracto "Coger la herramienta del cabezal" .