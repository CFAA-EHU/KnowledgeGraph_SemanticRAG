@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:PeticionDeCambioDeHerramienta a ns1:Parametro ;
    rdfs:label "Petición de cambio de herramienta" ;
    ns1:identificador "TMOPSTROBE" ;
    ns1:textoExtracto "DFU TMOPSTROBE AND (CPS TMOPERATION EQ 3) = SET GRTOSPDL Hay una petición de cambio de herramienta y TMOPERATION=3." .

ns1:SistemaGestor a ns1:Sistema ;
    rdfs:label "Gestor" ;
    ns1:monitoreaParametro ns1:Parametro_aed1a67bbe ;
    ns1:textoExtracto "El gestor ha desactivado la marca SPDLTOGR y TMOPERATION=8." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:monitoreaParametro ns1:CodigoCorrespondienteALaOperacionQueSeDebeRealizar,
        ns1:Parametro_7959033478,
        ns1:Parametro_aed1a67bbe ;
    ns1:textoExtracto "el gestor envía al PLC en el registro TMOPERATION el código correspondiente a la operación que se debe realizar." .

ns1:CodigoCorrespondienteALaOperacionQueSeDebeRealizar a ns1:Parametro ;
    rdfs:label "Código correspondiente a la operación que se debe realizar" ;
    ns1:identificador "TMOPERATION" ;
    ns1:textoExtracto "el registro TMOPERATION el código correspondiente a la operación que se debe realizar." .

ns1:Parametro_7959033478 a ns1:Parametro ;
    rdfs:label "Herramienta desde tierra al cabezal" ;
    ns1:identificador "GRTOSPDL" ;
    ns1:textoExtracto "El PLC ha llevado la herramienta desde tierra al cabezal." .

ns1:Parametro_aed1a67bbe a ns1:Parametro ;
    rdfs:label "Herramienta desde el cabezal a tierra" ;
    ns1:identificador "SPDLTOGR" ;
    ns1:textoExtracto "El PLC ha llevado la herramienta desde el cabezal a tierra." .

