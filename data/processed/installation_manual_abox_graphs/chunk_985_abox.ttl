@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:Cabezal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "El PLC ha llevado la herramienta desde tierra al cabezal." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "El PLC ha llevado la herramienta desde tierra al cabezal." .

ns1:Herramienta a ns1:Herramienta ;
    rdfs:label "Herramienta" ;
    ns1:textoExtracto "El PLC ha llevado la herramienta desde tierra al cabezal." .

