@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:HerramientaBrazoCambiador a ex:Herramienta ;
    rdfs:label "Herramienta en el brazo cambiador" ;
    ex:textoExtracto "Herramienta en el brazo cambiador. LEAVEPOS=-4 Herramienta de tierra." .

ex:Pinza1 a ex:ComponenteMecanico ;
    rdfs:label "pinza 1" ;
    ex:textoExtracto "coger la herramienta del almacén con la pinza 1" .

ex:Pinza2 a ex:ComponenteMecanico ;
    rdfs:label "pinza 2" ;
    ex:textoExtracto "Coger la herramienta del cabezal con la pinza 2" .

ex:MarcaSPDLTOGR a ex:Parametro ;
    rdfs:label "SPDLTOGR" ;
    ex:textoExtracto "activar la marca SPDLTOGR" .

ex:MarcaCH1TOSPDL a ex:Parametro ;
    rdfs:label "CH1TOSPDL" ;
    ex:textoExtracto "activar la marca CH1TOSPDL" .

ex:MarcaGRTOSPDL a ex:Parametro ;
    rdfs:label "GRTOSPDL" ;
    ex:textoExtracto "activar la marca GRTOSPDL" .

ex:MarcaSPDLTOCH2 a ex:Parametro ;
    rdfs:label "SPDLTOCH2" ;
    ex:textoExtracto "activar la marca SPDLTOCH2" .

ex:MarcaCH2TOMZ a ex:Parametro ;
    rdfs:label "CH2TOMZ" ;
    ex:textoExtracto "activar la marca CH2TOMZ" .

ex:MarcaTCHANGEOK a ex:Parametro ;
    rdfs:label "TCHANGEOK" ;
    ex:textoExtracto "activar TCHANGEOK" .

ex:TMOPERATION8 a ex:ModoOperacion ;
    rdfs:label "TMOPERATION = 8" ;
    ex:textoExtracto "TMOPERATION = 8 Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra." .

ex:TMOPERATION9 a ex:ModoOperacion ;
    rdfs:label "TMOPERATION = 9" ;
    ex:textoExtracto "TMOPERATION = 9 Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal." .

ex:TMOPERATION10 a ex:ModoOperacion ;
    rdfs:label "TMOPERATION = 10" ;
    ex:textoExtracto "TMOPERATION = 10 Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal." .

ex:TMOPERATION11 a ex:ModoOperacion ;
    rdfs:label "TMOPERATION = 11" ;
    ex:textoExtracto "el gestor envía el código TMOPERATION=11 para coger la herramienta del almacén con la pinza 1" .

ex:TAKEPOS4 a ex:Parametro ;
    rdfs:label "TAKEPOS=-4" ;
    ex:textoExtracto "TAKEPOS=-4 Herramienta de tierra" .

ex:LEAVEPOS4 a ex:Parametro ;
    rdfs:label "LEAVEPOS=-4" ;
    ex:textoExtracto "LEAVEPOS=-4 Herramienta de tierra" .