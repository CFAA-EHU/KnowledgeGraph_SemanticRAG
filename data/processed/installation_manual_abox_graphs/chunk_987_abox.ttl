@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CNC8070_4d9b0d5491 a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controladoPor ns1:SistemaGestorHerramientas ;
    ns1:textoExtracto "El CNC ejecuta la función T y la subrutina el bloque M06." .

ns1:CambioDeHerramienta_9905614d85 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta" ;
    ns1:textoExtracto "La rutina asociada a la función T ejecuta la función M06. La rutina M06 también puede tener una rutina asociada." .

ns1:ComponenteMecanico_23a4cfcdee a ns1:ComponenteMecanico ;
    rdfs:label "Almacén tipo torreta" ;
    ns1:textoExtracto "El gestor envía una orden al PLC para que seleccione la próxima herramienta en el almacén." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:controladoPor ns1:SistemaGestorHerramientas ;
    ns1:textoExtracto "El gestor envía una orden al PLC para efectuar el cambio." .

ns1:SistemaGestorHerramientas a ns1:Sistema ;
    rdfs:label "Sistema Gestor de Herramientas" ;
    ns1:controla ns1:SistemaPLC ;
    ns1:textoExtracto "Dentro de dicha rutina hay que programar la función M06 para que el CNC indique al gestor que debe comenzar el cambio de herramienta." .

