@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TMOPERATION_10 a ex:TareaMantenimiento ;
    ex:identificador "TMOPERATION = 10" ;
    ex:textoExtracto "TMOPERATION = 10 Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal." .

ex:TAKEPOS a ex:Parametro ;
    ex:identificador "TAKEPOS=#" ;
    ex:textoExtracto "TAKEPOS=# Posición del almacén para coger la herramienta." .

ex:LEAVEPOS a ex:Parametro ;
    ex:identificador "LEAVEPOS=-4" ;
    ex:textoExtracto "LEAVEPOS=-4 Herramienta de tierra." .

ex:CH1TOSPDL a ex:Sensor ;
    ex:identificador "CH1TOSPDL" ;
    ex:textoExtracto "activar la marca CH1TOSPDL" .

ex:SPDLTOGR a ex:Sensor ;
    ex:identificador "SPDLTOGR" ;
    ex:textoExtracto "activar la marca SPDLTOGR" .

ex:TMOPERATION_11 a ex:TareaMantenimiento ;
    ex:identificador "TMOPERATION = 11" ;
    ex:textoExtracto "TMOPERATION = 11 Coger una herramienta del almacén y ponerla en el brazo." .