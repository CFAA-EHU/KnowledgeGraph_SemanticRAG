@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TMOPERATION_11 a ex:TareaMantenimiento ;
    ex:textoExtracto "TMOPERATION = 11 Coger una herramienta del almacén y ponerla en el brazo. Esta operación es una optimización del cambio de herramienta que permite colocar una herramienta en la pinza ꞏ1ꞏ del brazo cambiador durante el mecanizado." ;
    ex:identificador "TMOPERATION = 11" .

ex:TMOPERATION_12 a ex:TareaMantenimiento ;
    ex:textoExtracto "TMOPERATION = 12 Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén (como TMOPERATION=5). Es una operación optimizada, valida cuando ambas herramientas son especiales y pueden colisionar en el brazo o no se desea que coincidan en el brazo cambiador." ;
    ex:identificador "TMOPERATION = 12" .

ex:TMOPERATION_14 a ex:TareaMantenimiento ;
    ex:textoExtracto "TMOPERATION = 14 Dejar la herramienta del cabezal en el almacén y coger una herramienta del brazo. Las herramientas del cabezal y del brazo son de almacenes diferentes." ;
    ex:identificador "TMOPERATION = 14" .

ex:Pinza_1 a ex:ComponenteMecanico ;
    ex:textoExtracto "colocar una herramienta en la pinza ꞏ1ꞏ del brazo cambiador" .

ex:AlmacenHerramientas a ex:Sistema ;
    ex:textoExtracto "almacén" .

ex:BrazoCambiador a ex:ComponenteMecanico ;
    ex:textoExtracto "brazo cambiador" .