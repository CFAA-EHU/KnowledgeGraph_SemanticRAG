@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:AlmacenTipoTorreta a ns1:Sistema ;
    rdfs:label "Almacén tipo torreta" ;
    ns1:textoExtracto "Herramientas de tierra en un almacén tipo torreta." ;
    ns1:tieneComponente ns1:Componente_c772693e6b .

ns1:CabezalTrabajo a ns1:Componente ;
    rdfs:label "Cabezal de trabajo" ;
    ns1:textoExtracto "La maniobra para cargar/descargar una herramienta en el cabezal (en la posición de trabajo) directamente o pasando por el cabezal es la misma." .

ns1:GestionDelCambioDeHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Gestión del cambio de herramienta" ;
    ns1:ejecutadoPor ns1:CNC8070_5ef3b83dee ;
    ns1:textoExtracto "Se aconseja incluir la gestión del cambio de herramienta en la rutina asociada a M06 y dejar como labor del PLC el control de los dispositivos externos." .

ns1:CNC8070_5ef3b83dee a ns1:Sistema ;
    rdfs:label "CNC 8070" ;
    ns1:controladoPor ns1:SistemaPLC ;
    ns1:textoExtracto "El CNC espera a que el gestor de por finalizada la operación para continuar con la ejecución del programa." .

ns1:Componente_c772693e6b a ns1:Componente ;
    rdfs:label "Herramienta de tierra" ;
    ns1:textoExtracto "En este almacén se dispone de la posibilidad de trabajar con herramientas de tierra." .

ns1:SistemaPLC a ns1:Sistema ;
    rdfs:label "Sistema PLC" ;
    ns1:textoExtracto "dejar como labor del PLC el control de los dispositivos externos." .

