@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalTrabajo a ns1:Componente ;
    rdfs:label "Cabezal de trabajo" ;
    ns1:textoExtracto "cargar/descargar una herramienta en el cabezal (en la posición de trabajo)" .

ns1:ModoDeCargaDescargaDelCabezal a ns1:Parametro ;
    rdfs:label "Modo de carga/descarga del cabezal" ;
    ns1:identificador "VTM.ZMODE" ;
    ns1:textoExtracto "la variable V.TM.MZMODE deberá tener el valor adecuado para realizar la carga o descarga." .

