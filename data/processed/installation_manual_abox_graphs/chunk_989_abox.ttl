@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:PosicionAlmacenHerramienta a ex:Componente ;
    rdfs:label "Posición del almacén para dejar la herramienta"@es ;
    ex:textoExtracto "LEAVEPOS=# Posición del almacén para dejar la herramienta. MZID En la parte baja de este registro se indica el almacén en el que hay que dejar la herramienta y en la parte alta el almacén del que hay que coger la herramienta."@es .

ex:GestorAlmacen a ex:Sistema ;
    rdfs:label "gestor"@es ;
    ex:textoExtracto "el gestor admite dos secuencias. Previamente, durante el mecanizado (al ejecutar la T), el gestor envía el código TMOPERATION=11 para coger la herramienta del almacén con la pinza 1."@es .

ex:Pinza1 a ex:ComponenteMecanico ;
    rdfs:label "pinza 1"@es ;
    ex:textoExtracto "coger la herramienta del almacén con la pinza 1"@es .

ex:Pinza2 a ex:ComponenteMecanico ;
    rdfs:label "pinza 2"@es ;
    ex:textoExtracto "Coger la herramienta del cabezal con la pinza ꞏ2ꞏ"@es .

ex:TMOPERATION11 a ex:Parametro ;
    rdfs:label "TMOPERATION=11"@es ;
    ex:identificador "TMOPERATION=11" ;
    ex:textoExtracto "el gestor envía el código TMOPERATION=11 para coger la herramienta del almacén con la pinza 1"@es .

ex:TareaMecanizado a ex:TareaMantenimiento ;
    rdfs:label "T"@es ;
    ex:identificador "T" ;
    ex:textoExtracto "durante el mecanizado (al ejecutar la T)"@es .