@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:TMOPERATION_11 a ex:TareaMantenimiento ;
    ex:textoExtracto "el gestor envía el código TMOPERATION=11 para coger la herramienta del almacén con la pinza 1." ;
    ex:identificador "TMOPERATION=11" .

ex:Pinza_1 a ex:ComponenteMecanico ;
    ex:textoExtracto "pinza ꞏ1ꞏ" .

ex:Pinza_2 a ex:ComponenteMecanico ;
    ex:textoExtracto "pinza ꞏ2ꞏ" .

ex:AlmacenHerramientas a ex:Sistema ;
    ex:textoExtracto "almacén" .

ex:Marca_SPDLTOCH2 a ex:Parametro ;
    ex:textoExtracto "activar la marca SPDLTOCH2" .

ex:Marca_CH2TOMZ a ex:Parametro ;
    ex:textoExtracto "activar la marca CH2TOMZ" .

ex:Marca_CH1TOSPDL a ex:Parametro ;
    ex:textoExtracto "activar la marca CH1TOSPDL" .

ex:TMOPERATION_16 a ex:TareaMantenimiento ;
    ex:textoExtracto "TMOPERATION = 16 Dejar la herramienta del brazo (pinza ꞏ2ꞏ) en el almacén. Coger una herramienta del almacén y ponerla en el brazo (pinza ꞏ1ꞏ)." ;
    ex:identificador "TMOPERATION=16" .

ex:TAKEPOS a ex:Parametro ;
    ex:textoExtracto "TAKEPOS=# Posición que ocupa la herramienta." .

ex:LEAVEPOS a ex:Parametro ;
    ex:textoExtracto "LEAVEPOS=# Posición para dejar la herramienta." .

ex:Marca_CH2TOMZ_2 a ex:Parametro ;
    ex:textoExtracto "activar la marca CH2TOMZ" .

ex:Marca_MZTOCH1 a ex:Parametro ;
    ex:textoExtracto "activar la marca MZTOCH1" .