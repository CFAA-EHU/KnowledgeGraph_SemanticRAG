@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
ex:M1100 a ex:Sensor ;
    rdfs:label "M1100" ;
    ex:textoExtracto "Marca. | Significado. | M1100 | TCHANGEOK Se puede continuar con la ejecución del programa." ;
    ex:valor "TCHANGEOK" .

ex:M1101 a ex:Sensor ;
    rdfs:label "M1101" ;
    ex:textoExtracto "Marca. | Significado. | M1101 | MZTOCH1 La herramienta se ha llevado del almacén a la pinza 1." ;
    ex:valor "MZTOCH1" .

ex:M1102 a ex:Sensor ;
    rdfs:label "M1102" ;
    ex:textoExtracto "Marca. | Significado. | M1102 | CH1TOSPDL La herramienta se ha llevado de la pinza 1 al cabezal." ;
    ex:valor "CH1TOSPDL" .

ex:M1104 a ex:Sensor ;
    rdfs:label "M1104" ;
    ex:textoExtracto "Marca. | Significado. | M1104 | SPDLTOCH2 La herramienta se ha llevado del cabezal a la pinza 2." ;
    ex:valor "SPDLTOCH2" .

ex:M1107 a ex:Sensor ;
    rdfs:label "M1107" ;
    ex:textoExtracto "Marca. | Significado. | M1107 | SPDLTOGR La herramienta se ha llevado del cabezal a tierra." ;
    ex:valor "SPDLTOGR" .

ex:M1108 a ex:Sensor ;
    rdfs:label "M1108" ;
    ex:textoExtracto "Marca. | Significado. | M1108 | GRTOSPDL La herramienta se ha llevado de tierra al cabezal." ;
    ex:valor "GRTOSPDL" .

ex:CH2TOMZ a ex:Sensor ;
    rdfs:label "CH2TOMZ" ;
    ex:textoExtracto "La marca CH2TOMZ la pondrá el PLC cuando se haya dejado la herramienta." .

ex:M101 a ex:Sensor ;
    rdfs:label "M101" ;
    ex:textoExtracto "Función. | Significado. | M101 | Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1." ;
    ex:valor "Seleccionar en el almacén la posición que indica TAKEPOS y coger la herramienta con la pinza 1." .

ex:M102 a ex:Sensor ;
    rdfs:label "M102" ;
    ex:textoExtracto "Función. | Significado. | M102 | Llevar la herramienta de la pinza 1 al cabezal." ;
    ex:valor "Llevar la herramienta de la pinza 1 al cabezal." .

ex:M104 a ex:Sensor ;
    rdfs:label "M104" ;
    ex:textoExtracto "Función. | Significado. | M104 | Coger la herramienta del cabezal con la pinza 2." ;
    ex:valor "Coger la herramienta del cabezal con la pinza 2." .

ex:M106 a ex:Sensor ;
    rdfs:label "M106" ;
    ex:textoExtracto "Función. | Significado. | M106 | Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza 2." ;
    ex:valor "Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza 2." .

ex:M121 a ex:Sensor ;
    rdfs:label "M121" ;
    ex:textoExtracto "Función. | Significado. | M121 | Llevar el brazo cambiador al punto de cambio." ;
    ex:valor "Llevar el brazo cambiador al punto de cambio." .

ex:M122 a ex:Sensor ;
    rdfs:label "M122" ;
    ex:textoExtracto "Función. | Significado. | M122 | Llevar el brazo cambiador al almacén." ;
    ex:valor "Llevar el brazo cambiador al almacén." .

ex:M123 a ex:Sensor ;
    rdfs:label "M123" ;
    ex:textoExtracto "Función. | Significado. | M123 | Retirar el brazo cambiador." ;
    ex:valor "Retirar el brazo cambiador." .