@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SUB_MZ_TO_CH1 a ex:TareaMantenimiento ;
    ex:textoExtracto "SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1. M101 ; Función auxiliar para ejecutar acción. V.PLC.M[1101]=1 ; Marca MZTOCH1 al gestor." .

ex:SUB_CH1_TO_SPD a ex:TareaMantenimiento ;
    ex:textoExtracto "SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal. M102 ; Función auxiliar para ejecutar acción. V.PLC.M[1102]=1 ; Marca CH1TOSPDL al gestor." .

ex:SUB_SPD_TO_CH2 a ex:TareaMantenimiento ;
    ex:textoExtracto "SUB_SPD_TO_CH2 ; Coger la herramienta del cabezal con la pinza 2. M104 ; Función auxiliar para ejecutar acción. V.PLC.M[1104]=1 ; Marca SPDLTOCH2 al gestor." .

ex:SUB_CH2_TO_MZ a ex:TareaMantenimiento ;
    ex:textoExtracto "SUB_CH2_TO_MZ ; Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza 2. M106 ; Función auxiliar para ejecutar acción. ; El PLC debe dar por finalizada la M106 cuando el brazo abandona la zona de posible colisión y se puede mecanizar. ; La marca CH2TOMZ la pondrá el PLC cuando se haya dejado la herramienta." .

ex:SUB_SPD_TO_GR a ex:TareaMantenimiento ;
    ex:textoExtracto "SUB_SPD_TO_GR ; Quitar la herramienta del cabezal (llevarla a tierra). # MSG [\"Extraer herramienta T%D y pulsar MARCHA\", V.TM.TOOL] ; Mensaje al operario para que quite la herramienta. M0 ; Esperar a que finalice la operación. # MSG [\"\"] ; Quitar mensaje. V.PLC.M[1107]=1 ; Marca SPDLTOGR al gestor." .

ex:SUB_GR_TO_SPD a ex:TareaMantenimiento ;
    ex:textoExtracto "SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal. # MSG [\"Insertar herramienta T%D y pulsar MARCHA\", V.TM.NXTOOL] ; Mensaje al operario para que ponga la herramienta." .

ex:M101 a ex:TareaMantenimiento ;
    ex:textoExtracto "M101 ; Función auxiliar para ejecutar acción." .

ex:M102 a ex:TareaMantenimiento ;
    ex:textoExtracto "M102 ; Función auxiliar para ejecutar acción." .

ex:M104 a ex:TareaMantenimiento ;
    ex:textoExtracto "M104 ; Función auxiliar para ejecutar acción." .

ex:M106 a ex:TareaMantenimiento ;
    ex:textoExtracto "M106 ; Función auxiliar para ejecutar acción." .