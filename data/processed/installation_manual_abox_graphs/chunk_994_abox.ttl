@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarLaMarcaGRTOSPDL_6818b4dc83 a ns1:AccionProhibida ;
    rdfs:label "Activar la marca GRTOSPDL" ;
    ns1:textoExtracto "1 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL." .

ns1:ActivarLaMarcaMZTOSPDL a ns1:AccionProhibida ;
    rdfs:label "Activar la marca MZTOSPDL" ;
    ns1:textoExtracto "1 Tras finalizar la operación, activar la marca MZTOSPDL." .

ns1:ActivarLaMarcaSPDLTOGR_84926fbb65 a ns1:AccionProhibida ;
    rdfs:label "Activar la marca SPDLTOGR" ;
    ns1:textoExtracto "1 Dejar la herramienta del cabezal en tierra y activar la marca SPDLTOGR." .

ns1:Almacen a ns1:Sistema ;
    rdfs:label "Almacén" ;
    ns1:textoExtracto "TMOPERATION = 9 Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal." .

ns1:Cabezal a ns1:Componente ;
    rdfs:label "Cabezal" ;
    ns1:textoExtracto "La secuencia de esta operación es la siguiente. 1 Tras finalizar la operación, activar la marca GRTOSPDL." .

ns1:Componente_a62c857c41 a ns1:Componente ;
    rdfs:label "Herramienta de tierra" ;
    ns1:textoExtracto "TMOPERATION = 3 Poner en el cabezal una herramienta de tierra." .

ns1:OperacionEnElAlmacen a ns1:TareaMantenimiento ;
    rdfs:label "Operación en el almacén" ;
    ns1:ejecutadoPor ns1:PersonalTecnico ;
    ns1:textoExtracto "TMOPERATION = 1 Asumir la herramienta actual como herramienta activa." .

ns1:PersonalTecnico a ns1:Personal ;
    rdfs:label "Personal Técnico" ;
    ns1:textoExtracto "TMOPERATION = 1 Asumir la herramienta actual como herramienta activa." .

