@prefix ex: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
PREFIX ex: <https://vocab.cfaa.eus/broaching/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ex:RutinaM06 a ex:TareaMantenimiento ;
    rdfs:label "Rutina M06 (Cambio de herramienta)"@es ;
    ex:textoExtracto """
    %SUB_M6.nc
    #ESBLK ; Activar tratamiento de bloque único
    M6 ; Orden al gestor para comenzar el cambio de herramienta.
    """@es ;
    ex:identificador "M06" .

ex:Subrutina_SUB_ARM_TO_CHG a ex:TareaMantenimiento ;
    rdfs:label "SUB_ARM_TO_CHG"@es ;
    ex:textoExtracto "%L SUB_ARM_TO_CHG ; Llevar el brazo cambiador al punto de cambio."@es ;
    ex:identificador "SUB_ARM_TO_CHG" .

ex:Subrutina_SUB_ARM_TO_MZ a ex:TareaMantenimiento ;
    rdfs:label "SUB_ARM_TO_MZ"@es ;
    ex:textoExtracto "%L SUB_ARM_TO_MZ ; Llevar el brazo cambiador al almacén."@es ;
    ex:identificador "SUB_ARM_TO_MZ" .

ex:Subrutina_SUB_ARM_BACK a ex:TareaMantenimiento ;
    rdfs:label "SUB_ARM_BACK"@es ;
    ex:textoExtracto "%L SUB_ARM_BACK ; Retirar el brazo cambiador."@es ;
    ex:identificador "SUB_ARM_BACK" .

ex:Subrutina_SUB_SPD_AUTCHG a ex:TareaMantenimiento ;
    rdfs:label "SUB_SPD_AUTCHG"@es ;
    ex:textoExtracto "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático."@es ;
    ex:identificador "SUB_SPD_AUTCHG" .

ex:Subrutina_SUB_CH1_TO_SPD a ex:TareaMantenimiento ;
    rdfs:label "SUB_CH1_TO_SPD"@es ;
    ex:textoExtracto "LL SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal."@es ;
    ex:identificador "SUB_CH1_TO_SPD" .

ex:ModoEjecucionSimulada a ex:ModoOperacion ;
    rdfs:label "Ejecución simulada"@es ;
    ex:textoExtracto "V.S.EXECUTION = 0 ; Ejecución simulada; teórico o funciones G."@es ;
    ex:valor "0" .

ex:ModoEjecucionReal a ex:ModoOperacion ;
    rdfs:label "Ejecución real"@es ;
    ex:textoExtracto "V.S.EXECUTION = 1 ; Ejecución"@es ;
    ex:valor "1" .

ex:OperacionCogerHerramienta a ex:ModoOperacion ;
    rdfs:label "Coger herramienta del almacén (Caso 1)"@es ;
    ex:textoExtracto """
    $CASE 1 ; Coger una herramienta del almacén y ponerla en el cabezal.
    Previamente, durante el mecanizado (al ejecutar T), se pone la herramienta del almacén en la pinza 1.
    """@es ;
    ex:valor "1" .

ex:OperacionDejarHerramienta a ex:ModoOperacion ;
    rdfs:label "Dejar herramienta en el almacén (Caso 2)"@es ;
    ex:textoExtracto "$CASE 2 ; Dejar la herramienta del cabezal en el almacén."@es ;
    ex:valor "2" .

ex:RutinaM06 ex:compuestoPor ex:Subrutina_SUB_ARM_TO_CHG ,
                              ex:Subrutina_SUB_ARM_TO_MZ ,
                              ex:Subrutina_SUB_ARM_BACK ,
                              ex:Subrutina_SUB_SPD_AUTCHG ,
                              ex:Subrutina_SUB_CH1_TO_SPD .

ex:OperacionCogerHerramienta ex:habilitadoPor ex:Subrutina_SUB_SPD_AUTCHG ,
                                               ex:Subrutina_SUB_ARM_TO_CHG ,
                                               ex:Subrutina_SUB_CH1_TO_SPD ,
                                               ex:Subrutina_SUB_ARM_BACK .

ex:OperacionDejarHerramienta ex:habilitadoPor ex:Subrutina_SUB_SPD_AUTCHG ,
                                               ex:Subrutina_SUB_ARM_TO_CHG .