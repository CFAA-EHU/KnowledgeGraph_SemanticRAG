@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:ActivarLaMarcaMZROT_c96dbab3aa a ns1:AccionProhibida ;
    rdfs:label "Activar la marca MZROT" ;
    ns1:textoExtracto "Tras finalizar la operación, activar la marca MZROT." .

ns1:PosicionAAlcanzarONumeroDePosicionesAGirar_9186331879 a ns1:Parametro ;
    rdfs:label "Posición a alcanzar o número de posiciones a girar" ;
    ns1:identificador "NEXTPOS" ;
    ns1:textoExtracto "En un posicionamiento absoluto este registro indica la posición a alcanzar y en un posicionamiento relativo indica el número de posiciones a girar." .

ns1:PosicionamientoAbsolutoORelativo a ns1:Parametro ;
    rdfs:label "Posicionamiento absoluto o relativo" ;
    ns1:identificador "TAKEPOS" ;
    ns1:textoExtracto "Este registro tomará valor ꞏ0ꞏ si es un posicionamiento absoluto y valor ꞏ1ꞏ si es un posicionamiento relativo." .

ns1:PosicionamientoRelativoPositivoONegativo a ns1:Parametro ;
    rdfs:label "Posicionamiento relativo positivo o negativo" ;
    ns1:identificador "LEAVEPOS" ;
    ns1:textoExtracto "Este registro tomará valor ꞏ0ꞏ si es un posicionamiento relativo positivo y valor ꞏ1ꞏ si es un posicionamiento relativo negativo." .

ns1:ValorDeLaOperacion a ns1:Parametro ;
    rdfs:label "Valor de la operación" ;
    ns1:identificador "TMOPERATION" ;
    ns1:textoExtracto "TMOPERATION = 15 Seleccionar una posición del almacén." .

