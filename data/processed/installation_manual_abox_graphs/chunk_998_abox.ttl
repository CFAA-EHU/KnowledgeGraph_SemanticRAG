@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:BloqueUnicoTratamiento a ns1:AccionProhibida ;
    rdfs:label "Activar tratamiento de bloque único" ;
    ns1:textoExtracto "#ESBLK ; Activar tratamiento de bloque único" .

ns1:CabezalPrincipal a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal principal" ;
    ns1:textoExtracto "Desplazar el cabezal." .

ns1:CambioDeHerramienta_ad185fecc3 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta" ;
    ns1:textoExtracto "M6 ; Orden al gestor para comenzar el cambio de herramienta." .

ns1:TeclaStop a ns1:ComponenteElectrico ;
    rdfs:label "Tecla STOP" ;
    ns1:textoExtracto "#DSTOP ; Deshabilitar tecla STOP" .

