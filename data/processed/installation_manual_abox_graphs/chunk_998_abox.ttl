@prefix ex: <https://vocab.cfaa.eus/broaching/> .
ex:SUB_SPD_TO_CH2 a ex:TareaMantenimiento ;
    ex:textoExtracto "LL SUB_SPD_TO_CH2 ; Coger la herramienta del cabezal con la pinza 2." .

ex:SUB_ARM_BACK a ex:TareaMantenimiento ;
    ex:textoExtracto "LL SUB_ARM_BACK ; Retirar el brazo cambiador." .

ex:SUB_SPD_GMCHG a ex:TareaMantenimiento ;
    ex:textoExtracto "LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual." .

ex:SUB_GR_TO_SPD a ex:TareaMantenimiento ;
    ex:textoExtracto "LL SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal." .

ex:SUB_CH2_TO_MZ a ex:TareaMantenimiento ;
    ex:textoExtracto "LL SUB_CH2_TO_MZ ; Comenzar el envío del brazo cambiador al almacén para dejar la herramienta." .

ex:TCHANGEOK a ex:Parametro ;
    ex:identificador "V.PLC.M[1100]" ;
    ex:textoExtracto "V.PLC.M[1100]=1 ; Orden al PLC para que active la marca TCHANGEOK, indicando al gestor que puede continuar la ejecución." .

ex:CASE_7 a ex:ModoOperacion ;
    ex:identificador "$CASE 7" ;
    ex:textoExtracto "$BREAK $CASE 7 ; Dejar la herramienta del cabezal en tierra, y coger otra del almacén. ; Previamente, durante el mecanizado (al ejecutar T), se pone la herramienta del almacén en la pinza 1." .