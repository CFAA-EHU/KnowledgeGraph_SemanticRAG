@prefix ns1: <https://vocab.cfaa.eus/broaching/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ns1:CabezalHerramientas a ns1:ComponenteMecanico ;
    rdfs:label "Cabezal de herramientas" ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio manual." .

ns1:CambioDeHerramientaAutomatico a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta automático" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio automático. LL SUB_SPD_AUTCHG ; Dejar la herramienta del cabezal en el almacén." .

ns1:CambioDeHerramientaManual a ns1:TareaMantenimiento ;
    rdfs:label "Cambio de herramienta manual" ;
    ns1:ejecutadoPor ns1:PersonalTecnicoAutorizado ;
    ns1:textoExtracto "Colocar la herramienta de tierra en el cabezal. LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual." .

ns1:ComponenteMecanico_2c93a93856 a ns1:ComponenteMecanico ;
    rdfs:label "Almacén de herramientas" ;
    ns1:textoExtracto "Dejar la herramienta del cabezal en el almacén." .

ns1:Herramienta_414d337620 a ns1:Herramienta ;
    rdfs:label "Herramienta de tierra" ;
    ns1:textoExtracto "Colocar la herramienta de tierra en el cabezal." .

ns1:PuntoDeCambioManual a ns1:ElementoSeguridad ;
    rdfs:label "Punto de cambio manual" ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio manual." .

ns1:PersonalTecnicoAutorizado a ns1:Personal ;
    rdfs:label "Personal Técnico Autorizado" ;
    ns1:textoExtracto "Llevar el cabezal al punto de cambio manual." .

