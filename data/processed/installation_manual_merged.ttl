    ns1:monitoreaParametro ns1:MAXDMCOVR,
        ns1:MINDMCOVR ;
    ns1:textoExtracto "Modo automático. Estado y progreso del DMC." .

ns1:ModoDiagnosis a ns1:ModoOperacion ;
    rdfs:label "Modo diagnosis" ;
    ns1:textoExtracto "Algunas utilidades del sistema operativo (administrador de tareas, reloj) estarán disponibles desde el modo diagnosis." .

ns1:ModoDiagnosisCNC a ns1:ModoOperacion ;
    rdfs:label "Modo diagnosis del CNC"@es ;
    ns1:monitoreaParametro ns1:ParametrosBusEtherCAT ;
    ns1:textoExtracto "El modo diagnosis ofrece toda la información necesaria de los módulos conectados al bus EtherCAT."@es .

ns1:ModoEjecucionReal a ns1:ModoOperacion ;
    rdfs:label "Ejecución real"@es ;
    ns1:textoExtracto "V.S.EXECUTION = 1 ; Ejecución"@es ;
    ns1:valor "1" .

ns1:ModoHSC a ns1:ModoOperacion ;
    rdfs:label "Modo HSC"@es ;
    ns1:documentadoEn ns1:TablaParametrosHSC ;
    ns1:identificador "HSC" ;
    ns1:textoExtracto "modo HSC de trabajo"@es .

ns1:ModoLevaElectronica a ns1:ModoOperacion ;
    rdfs:label "Modo de leva electrónica" ;
    ns1:monitoreaParametro ns1:ParametroMasterOff,
        ns1:ParametroRangeMaster,
        ns1:ParametroRangeSlave,
        ns1:ParametroSlaveOff ;
    ns1:textoExtracto "Modo de leva. Se pueden activar dos tipos de leva; levas en función de tiempo o levas en función de la posición de un eje maestro." ;
    ns1:tieneComponente ns1:LevaNoPeriodica,
        ns1:LevaPeriodica .

ns1:ModoMDI_MDA a ns1:ModoOperacion ;
    rdfs:label "Modo MDI/MDA" ;
    ns1:habilitadoPor ns1:InterfazPanelJog ;
    ns1:textoExtracto "El eje maestro se puede mover de la forma habitual desde el panel de jog, modo MDI/MDA, etc." .

ns1:ModoManual a ns1:ModoOperacion ;
    rdfs:label "Modo manual" ;
    ns1:textoExtracto "Para llevar el eje a la zona permitida acceder al modo manual y mover el eje o cabezal"@es .

ns1:ModoMonoestable_TG1 a ns1:ModoOperacion ;
    rdfs:label "Modo monoestable (TG1)" ;
    ns1:identificador "TG1" ;
    ns1:monitoreaParametro ns1:Parametro_T,
        ns1:Parametro_TEN,
        ns1:Parametro_TRS,
        ns1:Parametro_t ;
    ns1:textoExtracto "tras un flanco de subida en TG1, T pasa a 1 y t asciende linealmente hasta la constante de tiempo; al alcanzarla, T retorna a 0 y t se mantiene. Se indican flancos adicionales en TG1 sin efecto durante la temporización." .

ns1:ModoNestingAutomatico a ns1:ModoOperacion ;
    rdfs:label "Nesting automático" ;
    ns1:habilitadoPor ns1:LantekExpertInside ;
    ns1:textoExtracto "nesting automático (el software coloca la piezas en la chapa basándose en sus parámetros de configuración)"@es .

ns1:ModoNestingManual a ns1:ModoOperacion ;
    rdfs:label "Nesting manual" ;
    ns1:habilitadoPor ns1:LantekExpertInside ;
    ns1:textoExtracto "nesting manual (el usuario coloca las piezas en la chapa como le resulte conveniente)"@es .

ns1:ModoOperacionTorno a ns1:ModoOperacion ;
    rdfs:label "Modo torno"@es ;
    ns1:documentadoEn ns1:ManualMaquina ;
    ns1:textoExtracto "Personalización para máquina combinada [...] parámetros sólo afectan a los ejes que pueden trabajar en modo torno"@es .

ns1:ModoOperacion_0 a ns1:ModoOperacion ;
    rdfs:label "TMOPERATION=0 (No acción)"@es ;
    ns1:documentadoEn ns1:Tabla_OperacionesGestorHerramientas ;
    ns1:identificador "0" ;
    ns1:textoExtracto "0 | No hay que hacer nada."@es .

ns1:ModoOperacion_1 a ns1:ModoOperacion ;
    rdfs:label "TMOPERATION=1 (Coger herramienta del almacén)"@es ;
    ns1:documentadoEn ns1:Tabla_OperacionesGestorHerramientas ;
    ns1:identificador "1" ;
    ns1:textoExtracto "1 | Coger una herramienta del almacén y ponerla en el cabezal."@es .

ns1:ModoOperacion_12 a ns1:ModoOperacion ;
    rdfs:label "TMOPERATION=12 (Intercambio optimizado en almacén síncrono)"@es ;
    ns1:documentadoEn ns1:Tabla_OperacionesGestorHerramientas ;
    ns1:identificador "12" ;
    ns1:textoExtracto "12 | Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén (como TMOPERATION=5). Es una operación optimizada válida sólo en los siguientes tipos de almacén síncrono: • Tipo no-random con brazo cambiador de dos pinzas. • Tipo random cuando se trata de herramientas especiales."@es .

ns1:ModoOperacion_14 a ns1:ModoOperacion ;
    rdfs:label "TMOPERATION=14 (Intercambio entre almacenes)"@es ;
    ns1:documentadoEn ns1:Tabla_OperacionesGestorHerramientas ;
    ns1:identificador "14" ;
    ns1:textoExtracto "14 | Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén."@es .

ns1:ModoOperacion_2 a ns1:ModoOperacion ;
    rdfs:label "TMOPERATION=2 (Dejar herramienta en almacén)"@es ;
    ns1:documentadoEn ns1:Tabla_OperacionesGestorHerramientas ;
    ns1:identificador "2" ;
    ns1:textoExtracto "2 | Dejar la herramienta del cabezal en el almacén."@es .

ns1:ModoOperacion_3 a ns1:ModoOperacion ;
    rdfs:label "TMOPERATION=3 (Poner herramienta de tierra)"@es ;
    ns1:documentadoEn ns1:Tabla_OperacionesGestorHerramientas ;
    ns1:identificador "3" ;
    ns1:textoExtracto "3 | Poner en el cabezal una herramienta de tierra."@es .

ns1:ModoOperacion_4 a ns1:ModoOperacion ;
    rdfs:label "TMOPERATION=4 (Dejar herramienta en tierra)"@es ;
    ns1:documentadoEn ns1:Tabla_OperacionesGestorHerramientas ;
    ns1:identificador "4" ;
    ns1:textoExtracto "4 | Dejar la herramienta del cabezal en tierra."@es .

ns1:ModoOperacion_5 a ns1:ModoOperacion ;
    rdfs:label "TMOPERATION=5 (Intercambio en almacén)"@es ;
    ns1:documentadoEn ns1:Tabla_OperacionesGestorHerramientas ;
    ns1:identificador "5" ;
    ns1:textoExtracto "5 | Dejar la herramienta del cabezal en el almacén y coger una herramienta del mismo almacén."@es .

ns1:ModoOperacion_AceleracionTrapezoidal a ns1:ModoOperacion ;
    rdfs:label "Aceleración trapezoidal y seno cuadrado" ;
    ns1:monitoreaParametro ns1:Parametro_ACCEL,
        ns1:Parametro_ACCJERK,
        ns1:Parametro_DECEL,
        ns1:Parametro_DECJERK ;
    ns1:textoExtracto "1 El eje se empieza a mover con una aceleración uniformemente creciente, con una pendiente limitada por ACCJERK, hasta alcanzar la aceleración indicada en ACCEL. 2 La aceleración pasa a ser constante y su valor es ACCEL. 3 Antes de alcanzar la velocidad programada hay una aceleración uniformemente decreciente, con una pendiente limitada por ACCJERK. 4 Continúa con el avance programado y con aceleración 0. 5 Cuando se desea disminuir la velocidad o parar el eje, se aplica una deceleración, con una pendiente limitada por DECJERK. 6 La deceleración pasa a ser constante y su valor es DECEL. 7 Antes de alcanzar la velocidad programada, o pararse, hay una deceleración limitada por DECJERK." .

ns1:ModoOperacion_AjusteApropiado a ns1:ModoOperacion ;
    rdfs:label "Ajuste apropiado (sin ganancia)" ;
    ns1:monitoreaParametro ns1:Parametro_GananciaACForward ;
    ns1:textoExtracto "Ajuste apropiado. Respuesta del sistema sin ganancia AC-forward (10 µm por cuadro)." .

ns1:ModoOperacion_AjusteInapropiado a ns1:ModoOperacion ;
    rdfs:label "Ajuste inapropiado (con ganancia)" ;
    ns1:monitoreaParametro ns1:Parametro_GananciaACForward ;
    ns1:textoExtracto "Picos invertidos; ajuste inapropiado. Respuesta del sistema con ganancia AC-forward (1 µm por cuadro)." .

ns1:ModoOperacion_AlignC_No a ns1:ModoOperacion ;
    rdfs:label "Modo ALIGNC = No"@es ;
    ns1:textoExtracto "la herramienta puede mecanizar diametralmente toda la superficie sin girar el eje C. Las viñetas muestran la trayectoria continua sobre el cilindro, resaltando la ausencia de realineamiento intermedio."@es .

ns1:ModoOperacion_AparcadoAutomatico a ns1:ModoOperacion ;
    rdfs:label "Park/Unpark desde CNC (automático)"@es ;
    ns1:activaAlarma ns1:Senal_PARK,
        ns1:Senal_UNPARK ;
    ns1:ilustradoEn ns1:Comando_PARK,
        ns1:Comando_UNPARK ;
    ns1:textoExtracto "Este tipo de maniobra está indicado para aplicaciones que necesitan ejecutar el proceso de aparcar ejes o cabezales de forma automática, por ejemplo desde un programa pieza."@es .

ns1:ModoOperacion_AproximacionChapa a ns1:ModoOperacion ;
