ns1:ComunicacionGestorPLC_869 a ns1:Sistema ;
    rdfs:label "Comunicación entre el gestor de herramientas y el PLC"@es ;
    ns1:textoExtracto "Para la comunicación entre el gestor de herramientas y el PLC, cada canal y almacén dispone de un grupo de marcas y registros."@es .

ns1:CondicionMZWAIT a ns1:Parametro ;
    rdfs:label "Parámetro V.TM.MZWAIT"@es ;
    ns1:identificador "V.TM.MZWAIT" ;
    ns1:textoExtracto "$WHILE V.TM.MZWAIT == 1 [...] Espera al gestor del almacén."@es ;
    ns1:valor "1" .

ns1:CondicionMovimientoEje a ns1:ModoOperacion ;
    rdfs:label "Condición de movimiento de eje (ENABLE=SERVOON)"@es ;
    ns1:identificador "ENABLE(axis)" ;
    ns1:textoExtracto "cada vez que quiere mover el eje. [...] AND (regulador OK) AND ENABLE = SERVOON"@es .

ns1:CondicionServoON a ns1:Parametro ;
    rdfs:label "Condición SERVOON",
        "Condición para SERVOON" ;
    ns1:identificador "SERVOON" ;
    ns1:monitoreaParametro ns1:Se_alENABLE_Eje ;
    ns1:textoExtracto "AND ENABLE = SERVOON",
        "Para disponer de control continuo del eje, la marca SERVOON debe estar siempre a (no hay errores) AND (regulador eje OK) = SERVOnON"@es ;
    ns1:valor "ENABLE = SERVOON" .

ns1:Conector_RIO5_X1 a ns1:ComponenteElectrico ;
    rdfs:label "Conector RIO5 X1 (+24V/GND)" ;
    ns1:identificador "RIO5_X1" ;
    ns1:textoExtracto "conectores X1–X8 y leyendas de borneado (+24 V, GND)" .

