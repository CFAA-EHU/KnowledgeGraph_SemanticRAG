    ns1:ilustradoEn ns1:InterfazUsuario_OP_PANEL ;
    ns1:textoExtracto "Rejilla ilustrativa de teclas de jog (1–15) y bloque de funciones (START, STOP, ZERO, RESET, husillo y override) para el mapeo KEYDIS2"@es .

ns1:Figura_RespuestaMaquinaResonancia a ns1:Figura ;
    rdfs:label "Gráfico de respuesta de máquina (resonancia y SHARE)"@es ;
    ns1:ilustradoEn ns1:Parametro_Ao,
        ns1:Parametro_Ar,
        ns1:Parametro_SHARE,
        ns1:Parametro_fr ;
    ns1:textoExtracto "Gráfico de respuesta de máquina que muestra amplitud base (Ao), sobrepasamiento en resonancia (Ar) y frecuencia de resonancia (fr), acompañado de la fórmula SHARE=100(Ar–Ao)/Ar."@es .

ns1:Figura_Tipos13_14 a ns1:Figura ;
    rdfs:label "Croquis de cinemáticas cabezal-mesa (tipos 13 y 14)"@es ;
    ns1:detalladoEnEsquema ns1:Parametro_TDATA1,
        ns1:Parametro_TDATA11,
        ns1:Parametro_TDATA13,
        ns1:Parametro_TDATA14,
        ns1:Parametro_TDATA15,
        ns1:Parametro_TDATA2,
        ns1:Parametro_TDATA3,
        ns1:Parametro_TDATA4,
        ns1:Parametro_TDATA5,
        ns1:Parametro_TDATA6 ;
    ns1:ilustradoEn ns1:Sistema_CinematicoCabezalMesa ;
    ns1:textoExtracto "Dos conjuntos de viñetas para las combinaciones A-B y A-C: cotas TDATA1…TDATA6 para separar nariz, ejes de rotación y referencia máquina, más TDATA13…TDATA15 para colocación del cabezal."@es .

ns1:FiltroPasoBajoFAGOR a ns1:Componente,
        ns1:ComponenteElectrico ;
    rdfs:label "Filtro paso bajo FAGOR" ;
    ns1:monitoreaParametro ns1:Parametro_ORDER,
        ns1:Parametro_TYPE ;
    ns1:textoExtracto "El filtro \"paso bajo FAGOR\" introduce un desfase constante, independiente de la frecuencia. Este tipo de filtro necesita mayor orden para tener el mismo nivel de filtrado.",
