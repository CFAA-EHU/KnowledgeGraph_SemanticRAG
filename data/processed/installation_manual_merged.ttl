ns1:EsquemaCinematica_TYPE20 a ns1:Esquema ;
    rdfs:label "Esquema de cinemática TYPE=20 (ejes X-Y-Z, rotación B)" ;
    ns1:identificador "TYPE=20" ;
    ns1:textoExtracto "Esquema de cinemática TYPE=20 con ejes X-Y-Z y rotación B, con despieces laterales que indican TDATA (1, 2, 3, 4, 5, 7, 9, 10, 11) y la secuencia 1º-3º. Las flechas muestran direccionalidad y el signo de cada componente." .

ns1:LantekExpertInside a ns1:Sistema ;
    rdfs:label "Lantek Expert Inside" ;
    ns1:identificador "Lantek Expert Inside" ;
    ns1:textoExtracto "Fagor Automation y Lantek han colaborado en la integración del software Lantek Expert Inside para los modelos CNC 8060 y 8070. A partir de figuras en formato dxf, dwg o ficheros paramétricos, este software permite distribuirlas en un chapa optimizando el aprovechamiento de la misma, definir la estrategia de entrada/salida (lead-in/lead-out), etc para finalmente generar un programa pieza en lenguaje Fagor."@es .

ns1:Leapfrog a ns1:ModoOperacion ;
    rdfs:label "Leapfrog" ;
    ns1:textoExtracto "Respuesta dinámica del salto durante el leapfrog. [...] Suavizar el movimiento va a hacer que aumente el tiempo de mecanizado cuando hay leapfrogs." .

ns1:Maquina_CNC a ns1:Maquina ;
    rdfs:label "CNC",
        "Máquina CNC",
        "CNC (Torno)"@es ;
    ns1:monitoreaParametro ns1:Parametro_MAXJERK,
        ns1:Parametro_PROBE,
        ns1:Parametro_PROBEDATA ;
    ns1:textoExtracto "CNC aplica este filtro en HSC, G50, G5 y G7.",
        "El CNC puede tener configurados dos palpadores; habitualmente será un palpador de sobremesa para calibrar herramientas y un palpador de medida para realizar mediciones en la pieza.",
        "El CNC utiliza las señales PARK y UNPARK para informar al PLC que se ha desencadenado el proceso correspondiente de aparcar o desaparcar.",
        "El ciclo de calibración de cinemática tiene asociadas dos subrutinas (KinCal_Begin.nc y KinCal_End.nc) que el CNC ejecuta antes y después del ciclo.",
        "configuración de la máquina",
        "El CNC asume el cambio inmediatamente y permanece activo hasta ejecutar M30 o reset, en cuyo caso el CNC recupera el valor fijado por el parámetro máquina."@es,
        "Si se trata de un CNC modelo TORNO, las cotas deben expresarse en radios."@es ;
    ns1:tieneComponente ns1:Componente_PalpadorMedida,
        ns1:Componente_PalpadorSobremesa,
        ns1:PalpadorSobremesa .

ns1:PLCM3 a ns1:Sistema ;
    rdfs:label "PLCM3" ;
    ns1:identificador "PLCM3" ;
    ns1:textoExtracto "PLCM3SP1 (también se puede programar como PLCM3)" .

ns1:Parametro_ACCJERK a ns1:Parametro ;
    rdfs:label "ACCJERK",
        "ACCJERK (jerk en seno cuadrado)"@es,
        "Parámetro ACCJERK"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_ParametrosLeapfrog ;
    ns1:documentadoEn ns1:Tabla_G0ACDCJERK ;
    ns1:identificador "ACCJERK",
        "V.[ch].MPA.ACCJERK[set].xn" ;
    ns1:monitoreaParametro ns1:Leapfrog,
        ns1:ModoOperacion_HSC,
        ns1:Sistema_CNC ;
    ns1:textoExtracto "El CNC utiliza los parámetros ACCEL/DECEL/ACCJERK/DECJERK.",
        "Jerk de aceleración y deceleración. Los parámetros ACCJERK y DECJERK definen la pendiente de la aceleración y deceleración. [...] Cuanto menor sea el valor asignado a estos parámetros, la respuesta de la máquina será más suave pero aumentará el tiempo de aceleración / deceleración.",
        "Jerk de aceleración. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado.",
        "Los movimientos en G0 utilizan los parámetros ACCJERK y DECJERK.",
        "Los parámetros ACCJERK y DECJERK definen la pendiente de la aceleración y deceleración.",
        "aceleración con jerk (parámetros ACCEL/DECEL y ACCJERK/DECJERK)",
        "parámetros G00FEED, ACCEL, LACC1, LACC2 y ACCJERK testeados y ajustados",
        "rampas con pendiente limitada por ACCJERK/DECJERK, mostrando cómo los límites de jerk suavizan la transición de aceleración.",
        "G00FEED ACCEL ACCJERK [...] ACCJERK = 3 x"@es,
        "Los movimientos en G0 utilizan los parámetros ACCJERK y DECJERK."@es ;
    ns1:valor "3x",
        "45000.000 mm/s³ / 1771.65354 inch/s³ / 45000.000 grados/s³"^^xsd:string .

ns1:Parametro_TDATA18 a ns1:Parametro ;
    rdfs:label "TDATA18",
        "TDATA18 (sentido de giro del eje rotativo secundario)",
        "TDATA18"@es,
        "TDATA18 (Sentido de giro del eje rotativo secundario)"@es,
        "TDATA18: Sentido de giro del eje rotativo secundario"@es ;
    ns1:documentadoEn ns1:Tabla_RedefinicionCinematicaTipo1_16,
        ns1:Tabla_RedefinicionCinematicaVectorial_293_308 ;
    ns1:identificador "TDATA18" ;
    ns1:textoExtracto "Ilustración de la regla de la mano derecha junto a los ejes para fijar el sentido de giro del eje rotativo principal/secundario; incluye bocetos de mano y ejes rotulados, como apoyo a TDATA8/18 y a la distinción manual/servo (TDATA9/19).",
        "TDATA18 Sentido de giro del eje rotativo secundario del cabezal.",
        "TDATA18 Sentido de giro del eje rotativo secundario. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0.",
        "TDATA18 | TDATA10",
        "TDATA18 Sentido de giro del eje rotativo secundario del cabezal. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0."@es,
        "TDATA18 Sentido de giro del eje rotativo secundario. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0."@es,
        "TDATA18 | TDATA10"@es,
        "TDATA18 | TDATA11"@es,
        "| TDATA18 | TDATA11 |"@es ;
    ns1:valor 0,
        "0",
        "TDATA10",
        "TDATA11"^^xsd:string,
        "TDATA11",
        "0 (DIN 66217) / 1 (contrario a DIN 66217)"@es,
        "TDATA10"@es .

ns1:Parametro_TG3 a ns1:Parametro ;
    rdfs:label "Temporizador TG3 (retardo a la desconexión)"@es ;
    ns1:identificador "TG3" ;
    ns1:textoExtracto "tras un flanco de subida en TG3, T=1; el retardo comienza con el flanco de bajada de TG3 (t sube desde 0) y, al agotarse el tiempo, T pasa a 0."@es .

ns1:Parametro_TYPE a ns1:Parametro ;
    rdfs:label "TYPE",
        "TYPE (Tipo de filtro)",
        "Tipo de cinemática (TYPE)",
