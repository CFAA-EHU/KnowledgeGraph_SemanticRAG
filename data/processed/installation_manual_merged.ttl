    ns1:textoExtracto "Se define asignando al parámetro type el valor \"CONT\"." .

ns1:AccionProhibida_0110ddb5a2 a ns1:AccionProhibida ;
    rdfs:label "CH2TOMZ" ;
    ns1:textoExtracto "activar la marca CH2TOMZ." .

ns1:AccionProhibida_11f48809c0 a ns1:AccionProhibida ;
    rdfs:label "GRTOSPDL" ;
