ns1:InterfazUsuario_1362 a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de topología (ventana izquierda)"@es ;
    ns1:textoExtracto "colocar el ratón sobre el máster de la topología (ventana izquierda), pulsar el botón derecho del ratón y seleccionar la opción \"Export\" y \"Export Master Configuration ETG Standard\"."@es .

ns1:InterfazUsuario_AjusteApropiado a ns1:InterfazUsuario ;
    rdfs:label "Panel 'Ajuste apropiado'" ;
    ns1:identificador "icono de verificación" ;
    ns1:ilustradoEn ns1:Esquema_GamasTrabajo_Ejes ;
    ns1:textoExtracto "panel 'Ajuste apropiado' (icono de verificación) para AC-Forward: respuesta del sistema sin ganancia AC-forward (10 µm por cuadro) frente a respuesta con AC-forward (1 µm por cuadro)." .

ns1:InterfazUsuario_CNC8070 a ns1:InterfazUsuario ;
    rdfs:label "Carpeta CNC8070"@es,
        "Interfaz de usuario del CNC8070"@es ;
    ns1:identificador "C:\\CNC8070" ;
    ns1:monitoreaParametro ns1:Parametro_RecursosSistema_CNC8070 ;
    ns1:textoExtracto "Los ficheros necesarios para el funcionamiento del CNC se encuentran en la carpeta C:\\CNC8070, y sus correspondientes subcarpetas."@es,
        "verifique [...] que el **refresco de pantallas** [...] es el correcto."@es .

ns1:InterfazUsuario_CNC_703 a ns1:InterfazUsuario ;
    rdfs:label "Pantalla de monitorización CNC" ;
    ns1:textoExtracto "La monitorización en la pantalla del CNC de los recursos del PLC."@es .

ns1:InterfazUsuario_CNC_Avanzado a ns1:InterfazUsuario ;
    rdfs:label "Interfaz CNC Avanzado" ;
    ns1:textoExtracto "Forma de operar basada en la tecla [Main-Menu], que muestra un menú principal desde el que se accede, mediante softkeys, a los diferentes modos de trabajo, (automático, manual, editor, etc). También es posible utilizar las hotkeys de acceso directo. Esta la forma de operar estándar del 8058, 8060 y 8065." .

ns1:InterfazUsuario_CNC_Clasico a ns1:InterfazUsuario ;
    rdfs:label "Interfaz CNC Clásico" ;
    ns1:textoExtracto "Forma de operar basada en hotkeys, para seleccionar el modo de trabajo (automático, manual, editor, etc). Esta la forma de operar estándar del 8070." .

ns1:InterfazUsuario_CNC_ConfiguracionCinematica a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de configuración de cinemáticas del CNC" ;
    ns1:monitoreaParametro ns1:Parametro_Cinematica_TYPE ;
    ns1:textoExtracto "El CNC ofrece una serie de cinemáticas predefinidas y que se pueden configurar fácilmente desde los parámetros máquina."@es .

ns1:InterfazUsuario_CNC_Estandar a ns1:InterfazUsuario ;
    rdfs:label "Interfaz CNC Estándar" ;
    ns1:textoExtracto "Forma de operar por defecto en el CNC, que podrá ser la forma clásica o avanzada, dependiendo del modelo de CNC." .

ns1:InterfazUsuario_CodigosTecla a ns1:InterfazUsuario ;
    rdfs:label "Códigos de tecla (scan codes) del CNC"@es ;
    ns1:documentadoEn ns1:Pagina_543 ;
    ns1:textoExtracto "Los códigos de tecla (scan codes) permiten conocer cuál ha sido la última tecla aceptada por el CNC y también permiten simular el teclado desde el PLC. A cada tecla le corresponden dos códigos; uno para la acción de pulsar tecla y otro para la acción de soltar tecla."@es .

ns1:InterfazUsuario_ComandosProgramacion a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de comandos de programación CNC"@es ;
    ns1:documentadoEn ns1:Manual_Seccion4_6 ;
    ns1:textoExtracto "Instrucciones de acción lógicas, aritméticas, específicas, de leva electrónica y de ejes independientes para programación CNC."@es .

ns1:InterfazUsuario_ConfiguracionCinematica_504 a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de configuración de cinemáticas (#KIN ID)"@es ;
    ns1:monitoreaParametro ns1:Parametro_MAX_OFFSET_504,
        ns1:Parametro_OFFSET_504,
        ns1:Parametro_VALUE_504 ;
    ns1:textoExtracto "Los valores de offset definidos por el usuario se sumarán a su parámetro TDATA correspondiente. El nuevo valor se hará efectivo al activar la cinemática (#KIN ID) o el RTCP."@es .

ns1:InterfazUsuario_ConfiguradorMDP a ns1:InterfazUsuario ;
    rdfs:label "Interfaz del configurador MDP"@es ;
    ns1:ilustradoEn ns1:Pagina_743_744 ;
    ns1:textoExtracto "ventana izquierda [...] pestaña 'MDP modules' [...] opciones 'Scan configuration', 'Upload detected Module Ident list', 'Attach master', 'Detach master'."@es .

ns1:InterfazUsuario_CustomKey a ns1:InterfazUsuario ;
    rdfs:label "Tecla [CUSTOM] (USERKEY)" ;
    ns1:textoExtracto "USERKEY Personalización de la tecla de usuario." ;
    ns1:tieneComponente ns1:Parametro_APPLICATION,
        ns1:Parametro_COMPONENT,
        ns1:Parametro_FUNCTION .

ns1:InterfazUsuario_DiskMonitor a ns1:InterfazUsuario ;
    rdfs:label "DiskMonitor"@es ;
    ns1:textoExtracto "desde el modo SETUP, a través de \"DiskMonitor\" se accede directamente al modo USER."@es .

ns1:InterfazUsuario_FGUIM a ns1:InterfazUsuario ;
    rdfs:label "Aplicación FGUIM" ;
    ns1:textoExtracto "Para ello, utilizando la aplicación FGUIM, se deben modificar las propiedades Channel1 y Channel2 de la ventana gráfica para poder ver en un gráfico la ejecución de ambos canales." .

ns1:InterfazUsuario_FagorEtherCATMapper a ns1:InterfazUsuario ;
    rdfs:label "Fagor EtherCAT Mapper",
        "Interfaz de usuario del Fagor EtherCAT Mapper" ;
    ns1:ilustradoEn ns1:Tabla_IconosFagorEtherCATMapper ;
    ns1:textoExtracto "Los bloques codifican tipo de recurso por color (DI/DO, registros, analógicas).",
        "Vista general del 'Fagor EtherCAT Mapper': captura con (A) barra de iconos y nombre del ENI cargado, (B) barra de configuración por defecto (fichas de entradas/salidas y registros), (C) validación 'Overlapped', (D) topología en árbol, y (E) topología en bloques.",
        "Una vez instalado, en el escritorio aparece el siguiente icono. | Icono. | Función. | --- | --- |  | Mapeador de recursos EtherCAT."@es .

ns1:InterfazUsuario_JogPanel a ns1:InterfazUsuario ;
    rdfs:label "Jog-Panel",
        "Interfaz de usuario JOG-PANEL"@es ;
    ns1:compuestoPor ns1:Sistema_RemoteIO_Address3,
        ns1:Sistema_RemoteIO_Address4,
        ns1:Sistema_RemoteIO_Address5 ;
    ns1:detalladoEnEsquema ns1:Esquema_AsignacionTeclasJog_245 ;
    ns1:identificador "Jog-Panel" ;
    ns1:textoExtracto "Jog-Panel",
        "Diagrama de teclado con nueve casillas activas que alterna teclas de sentido (+/−) y de eje (X, Y, 4, 5) más tecla R. Ilustra una asignación en la que el usuario primero selecciona el sentido y luego el eje, con la tecla R centrada para activar el avance rápido."@es ;
    ns1:tieneComponente ns1:Tecla_Eje_4,
        ns1:Tecla_Eje_5,
        ns1:Tecla_Eje_X,
        ns1:Tecla_Eje_Y,
        ns1:Tecla_Rapido_R .

ns1:InterfazUsuario_KeyLED1 a ns1:InterfazUsuario ;
    rdfs:label "KEYLED1" ;
    ns1:identificador "KEYLED1" ;
    ns1:textoExtracto "KEYLED1 Este registro enciende el led (bit=1) de las teclas de usuario en todos los paneles de mando simultáneamente." .

ns1:InterfazUsuario_KeyLED1_1 a ns1:InterfazUsuario ;
    rdfs:label "KEYLED1_1" ;
    ns1:identificador "KEYLED1_1" ;
    ns1:textoExtracto "KEYLED1_1 Estos registros encienden los led (bit=1) de las teclas de usuario en un panel de mando. El registro KEYLED1_1 corresponde al primer panel de mando." .

ns1:InterfazUsuario_KeyLED1_2 a ns1:InterfazUsuario ;
    rdfs:label "KEYLED1_2" ;
    ns1:identificador "KEYLED1_2" ;
    ns1:textoExtracto "KEYLED1_2 al segundo panel de mando." .

ns1:InterfazUsuario_KeyLED2 a ns1:InterfazUsuario ;
    rdfs:label "KEYLED2" ;
    ns1:identificador "KEYLED2" ;
    ns1:textoExtracto "KEYLED2 Este registro enciende el led (bit=1) de las teclas en todos los módulos OP-PANEL-H/E simultáneamente." .

ns1:InterfazUsuario_KeyLED2_1 a ns1:InterfazUsuario ;
    rdfs:label "KEYLED2_1" ;
    ns1:identificador "KEYLED2_1" ;
    ns1:textoExtracto "KEYLED2_1 Estos registros encienden los led (bit=1) de las teclas en el módulo OP-PANEL-H/E. El registro KEYLED2_1 corresponde al primer panel de mando." .

ns1:InterfazUsuario_KeyLED2_2 a ns1:InterfazUsuario ;
    rdfs:label "KEYLED2_2" ;
    ns1:identificador "KEYLED2_2" ;
    ns1:textoExtracto "KEYLED2_2 al segundo panel de mando." .

ns1:InterfazUsuario_Keybd2 a ns1:InterfazUsuario ;
    rdfs:label "KEYBD2" ;
    ns1:identificador "KEYBD2" ;
    ns1:textoExtracto "KEYBD1 / KEYBD2 / KEYBD3 Estos registros son una copia del mapa de teclas pulsadas del último teclado utilizado. [...] Registros KEYBD2 / KEYBD2_1 a KEYBD2_8. Teclas genéricas. Registros KEYBD2 / KEYBD2_1 a KEYBD2_8. Selector del feed override. Registros KEYBD2 / KEYBD2_1 a KEYBD2_8. Selector de movimiento (volante, jog incremental o jog continuo)." .

ns1:InterfazUsuario_LCD10K a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de usuario LCD-10K"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_AsignacionTeclasLCD10K_246 ;
    ns1:textoExtracto "Teclado con nueve teclas: X+, Y+, 4+, 5+, R, 5−, X−, Y−, 4−."@es ;
    ns1:tieneComponente ns1:Tecla_4Neg_LCD10K,
        ns1:Tecla_4Pos_LCD10K,
        ns1:Tecla_5Neg_LCD10K,
        ns1:Tecla_5Pos_LCD10K,
        ns1:Tecla_R_LCD10K,
        ns1:Tecla_XNeg_LCD10K,
        ns1:Tecla_XPos_LCD10K,
        ns1:Tecla_YNeg_LCD10K,
        ns1:Tecla_YPos_LCD10K .

ns1:InterfazUsuario_LantekExpertInside_ConfiguracionTecnologica a ns1:InterfazUsuario ;
    rdfs:label "Configuración tecnológica de Lantek Expert Inside" ;
    ns1:textoExtracto "Captura de configuración tecnológica que destaca selección de puntos de entrada/salida, microjuntas y orden de corte. Incluye indicadores visuales de direccionalidad (flechas en trayectorias) y listas de parámetros para ajustar automáticamente o de forma manual." .

ns1:InterfazUsuario_LantekExpertInside_Idioma a ns1:InterfazUsuario ;
    rdfs:label "Ventana de configuración de idioma de Lantek Expert Inside" ;
    ns1:textoExtracto "Ventana de 'General/Idioma' de Lantek con menú desplegable para selección de idioma (en, es, fr, etc.)." .

ns1:InterfazUsuario_ModoAutomatico a ns1:InterfazUsuario ;
    rdfs:label "Pantalla de modo automático" ;
    ns1:ilustradoEn ns1:TablaSenalesPLC_16_2_6 ;
    ns1:textoExtracto "El texto \"Freal\" de las pantallas de los modos automático y manual muestra el estado de la marca _FEEDHOL. El texto aparece en color rojo cuando la marca _FEEDHOL está activa." .

ns1:InterfazUsuario_OP_PANEL_H_E a ns1:InterfazUsuario ;
    rdfs:label "OP-PANEL-H/E"@es ;
    ns1:detalladoEnEsquema ns1:Esquema_AsignacionBitsTeclasOP_PANEL_H_E ;
    ns1:textoExtracto "Esquema de asignación de bits a teclas del OP-PANEL-H/E (tabla gráfica sobre el teclado)."@es ;
    ns1:tieneComponente ns1:Tecla_Ejecucion,
        ns1:Tecla_Husillo,
        ns1:Tecla_Interbloqueo .

ns1:InterfazUsuario_OpenPCSRemoto_21_21 a ns1:InterfazUsuario ;
    rdfs:label "Interfaz OpenPCS Remoto (Sección 21.21)"@es,
        "Interfaz de OpenPCS Remoto (Sección 21.21)"@es ;
    ns1:ilustradoEn ns1:Esquema_AccionesExportacion_OpenPCS,
        ns1:Esquema_EntradasAnalogicas_Fagor_IB_IL_AI4_U-PAC,
        ns1:Esquema_MesaRotativa_17_3,
        ns1:Esquema_OverlappedNo_Error,
        ns1:Esquema_OverlappedRight_Demo,
        ns1:Esquema_SalidasAnalogicas_Fagor_IB_IL_AO2_U-PAC ;
    ns1:textoExtracto "Se muestran palpados en Y y Z sobre un cilindro (puntos 1–4), las lecturas ΔY1/ΔY2 y ΔZ1/ΔZ2, y la obtención de TDATA3 (Y) y Pz (Z) con cotas y radio R."@es,
        "Se observan campos editables y previsualización del bloque afectado."@es .

ns1:InterfazUsuario_OpenPCSRemoto_SeleccionIdiomaTeclado a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de selección de idioma y distribución de teclado (OpenPCS Remoto)"@es ;
    ns1:identificador "8.1" ;
    ns1:textoExtracto "Captura de la ventana 'Teclados e idiomas' con el botón 'Cambiar teclados…'. Se aprecia la jerarquía de pestañas y el flujo para abrir el cuadro de 'Servicios instalados', paso necesario para agregar un idioma de entrada y su distribución de teclado."@es .

ns1:InterfazUsuario_PicosInvertidos a ns1:InterfazUsuario ;
    rdfs:label "Panel 'Picos invertidos; ajuste inapropiado'" ;
    ns1:identificador "icono de equis" ;
    ns1:ilustradoEn ns1:Esquema_GamasTrabajo_Ejes ;
    ns1:textoExtracto "panel 'Picos invertidos; ajuste inapropiado' (icono de equis) que evidencia un AC-Forward excesivo: los picos de error se invierten y aparecen oscilaciones." .

ns1:InterfazUsuario_TeclaRESET a ns1:InterfazUsuario ;
    rdfs:label "Tecla RESET" ;
    ns1:identificador "RESET" ;
    ns1:textoExtracto "El usuario pulsa la tecla [RESET] del panel de mando" .

ns1:InterfazUsuario_TeclaR_pido a ns1:InterfazUsuario ;
    rdfs:label "Tecla de rápido" ;
    ns1:controla ns1:Parametro_FRAPIDEN ;
    ns1:textoExtracto "La tecla de rápido, por el contrario, afecta simultáneamente a todos los canales que en ese momento se encuentren en situación de ser afectados." .

ns1:InterfazUsuario_Teclado a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de teclado (tecla NEXT)",
        "Teclado (distribución Inglés - Estados Unidos)"@es ;
    ns1:documentadoEn ns1:Tabla_CHANGEKEY ;
    ns1:textoExtracto "Configuración del teclado (tecla [NEXT]).",
        "Scan codes. Distribución de teclado \"Inglés (Estados Unidos)\""@es ;
    ns1:tieneComponente ns1:Tecla_Alt,
        ns1:Tecla_AltGr,
        ns1:Tecla_AvPag,
        ns1:Tecla_Backspace,
        ns1:Tecla_BarraEspaciadora,
        ns1:Tecla_BloquearMayusculas,
        ns1:Tecla_Ctrl,
        ns1:Tecla_Fin,
        ns1:Tecla_FlechaAbajo,
        ns1:Tecla_FlechaArriba,
        ns1:Tecla_FlechaDerecha,
        ns1:Tecla_FlechaIzquierda,
        ns1:Tecla_ImprPantalla,
        ns1:Tecla_Inicio,
        ns1:Tecla_RePag,
        ns1:Tecla_Shift .

ns1:InterfazUsuario_TeclasJog a ns1:InterfazUsuario ;
    rdfs:label "Teclas de usuario configurables como teclas de jog" ;
    ns1:controla ns1:Parametro_JOGKEYDEF ;
    ns1:textoExtracto "El significado de este parámetro es similar al parámetro máquina JOGKEYDEF. Para definir el comportamiento de cada una de las teclas, se les asignará uno de los siguientes valores: [...] Las teclas de usuario así definidas se comportan de la misma manera que las teclas de jog" .

ns1:InterfazUsuario_VentanaPrincipal a ns1:InterfazUsuario ;
    rdfs:label "Ventana principal (HMI)"@es,
        "Ventana principal del HMI"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionVentanaPrincipal ;
    ns1:monitoreaParametro ns1:Parametro_Height,
        ns1:Parametro_Resolution,
        ns1:Parametro_Width ;
    ns1:textoExtracto "Dimensiones y resolución de la ventana principal"@es,
        "Este parámetro muestra los datos para configurar la ventana principal. [...] El interface se podrá desplazar haciendo click con el ratón sobre el icono que muestra el estado del programa del canal activo."@es ;
    ns1:tieneComponente ns1:Parametro_HEIGHT,
        ns1:Parametro_POSX,
        ns1:Parametro_POSY,
        ns1:Parametro_RESOLUTION,
        ns1:Parametro_WIDTH .

ns1:InterfazUsuario_VisualizacionErroresPLC a ns1:InterfazUsuario ;
    rdfs:label "Interfaz de visualización de errores y mensajes del PLC"@es ;
    ns1:ilustradoEn ns1:Pagina_403_404 ;
    ns1:textoExtracto "mostrar el fichero de información adicional hay que desplegar la lista de mensajes, seleccionar el mensaje y pulsar [ENTER] o al hacer click con el ratón sobre el mensaje. Para cerrar la ventana de información adicional, pulsar la tecla [ESC]. Errores de PLC. Al activarse una de las marcas ERR se detiene la ejecución del programa pieza y se muestra en el centro de la pantalla una ventana con el número de error y su texto asociado."@es .

ns1:InterfazUsuario_panelJog a ns1:InterfazUsuario ;
    rdfs:label "Panel de jog"@es ;
    ns1:textoExtracto "tecla \"rápido\" del panel de jog"@es .

ns1:Interfaz_B10KEYLED1 a ns1:InterfazUsuario ;
    rdfs:label "B10KEYLED1 Interface" ;
    ns1:textoExtracto "DFDB B10KEYLED1 = SET ENABLEGAP = SET ENABLELEAP" .

ns1:Interfaz_CNC_BusCAN a ns1:InterfazUsuario ;
    rdfs:label "Panel CNC (Address=0)" ;
    ns1:detalladoEnEsquema ns1:DiagramaBusCAN ;
    ns1:textoExtracto "iconos del CNC (Address=0)"@es .

ns1:Interfaz_DiskMonitor a ns1:InterfazUsuario ;
    rdfs:label "Ventana DiskMonitor"@es ;
    ns1:textoExtracto "el equipo muestra la ventana DiskMonitor para cambiar de un modo de trabajo a otro. [...] En la ventana anterior, al seleccionar el botón -i- de la parte superior derecha, el equipo muestra la lista de carpetas y archivos desprotegidos en ese momento."@es .

ns1:Interfaz_JogPanel_2 a ns1:InterfazUsuario ;
    rdfs:label "Jog-Panel (Address=2)" ;
    ns1:detalladoEnEsquema ns1:DiagramaBusCAN ;
    ns1:textoExtracto "dos 'Jog-Panel' (Address=2 y 5)"@es .

ns1:Interfaz_JogPanel_5 a ns1:InterfazUsuario ;
    rdfs:label "Jog-Panel (Address=5)" ;
    ns1:detalladoEnEsquema ns1:DiagramaBusCAN ;
    ns1:textoExtracto "dos 'Jog-Panel' (Address=2 y 5)"@es .

ns1:Interfaz_OPPanel_433 a ns1:InterfazUsuario ;
    rdfs:label "OP-PANEL (teclas START/STOP, husillo, override, jog 1-15)"@es ;
    ns1:compuestoPor ns1:Matriz_Jog_1_15_433,
        ns1:Tecla_Husillo_433,
        ns1:Tecla_Override_433,
        ns1:Tecla_StartStop_433 ;
    ns1:textoExtracto "Conjunto de tres fotografías (OP-PANEL, OP-PANEL-329 y QC-C65□-10K) repetidas para la sección de 'Teclas de jog' y 'Registros KEYBD2…'. Subrayan la ubicación de START/STOP, sentido de husillo y override, así como la matriz de jog 1–15, apoyando la lectura de bits asignados a cada tecla/posición."@es .

ns1:InterpoladorEjes_693 a ns1:ComponenteElectrico ;
    rdfs:label "Interpolador independiente de ejes" ;
    ns1:controla ns1:VariableLATCH1_693,
        ns1:VariableLATCH2_693 ;
    ns1:textoExtracto "El interpolador independiente activa esta marca al producirse el evento de latch en el eje con el palpador indicado; la desactiva al activar un nuevo proceso de latch en el eje con el mismo palpador." .

ns1:InterpoladorIndependiente a ns1:ComponenteElectrico ;
    rdfs:label "Interpolador independiente" ;
    ns1:activaAlarma ns1:Senal_LATCH1ACTIVE,
        ns1:Senal_LATCH1DONE,
        ns1:Senal_LATCH2ACTIVE,
        ns1:Senal_LATCH2DONE ;
    ns1:controla ns1:Eje_X,
        ns1:Eje_Y,
        ns1:Palpador_1,
        ns1:Palpador_2 ;
    ns1:textoExtracto "El interpolador independiente sólo activará la marca LATCH1DONE(axis) o LATCH2DONE(axis) del eje en el que se ha producido el evento." .

ns1:Interpolador_CNC a ns1:ComponenteElectrico ;
    rdfs:label "Interpolador del CNC",
