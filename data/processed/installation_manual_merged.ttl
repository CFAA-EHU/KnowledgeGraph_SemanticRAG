    ns1:textoExtracto "Relojes (CLK). Son relojes internos de diferentes periodos de tiempo que pueden ser utilizados en el programa de PLC."@es .

ns1:Reset_CNC a ns1:AccionProhibida ;
    rdfs:label "Reset del CNC" ;
    ns1:textoExtracto "el reset también desactivan el DMC." .

ns1:RetardoSeguridad_200ms a ns1:Parametro ;
    rdfs:label "Retardo de seguridad (200 ms)" ;
    ns1:textoExtracto "En el ejemplo se utiliza un retardo de 200ms entre el envío de ambos códigos (por seguridad)." ;
    ns1:valor "200" .

ns1:RoscadoElectronicoG33 a ns1:ModoOperacion ;
    rdfs:label "Roscado electrónico G33"@es ;
    ns1:textoExtracto "Roscado electrónico G33. Consideraciones"@es ;
    ns1:tieneComponente ns1:OverrideCabezalRoscado .

ns1:RotacionRegistro_RL1 a ns1:AccionProhibida ;
    rdfs:label "Rotación de registro a izquierdas tipo 1 (RL1)" ;
    ns1:identificador "RL1" ;
    ns1:textoExtracto "Tipo de rotación 1 (RL1 o RR1): Introduce un 0 en el bit menos significativo (RL1) o en el más significativo (RR1), desplazando los restantes bits del registro." .

ns1:RotacionRegistro_RL2 a ns1:AccionProhibida ;
    rdfs:label "Rotación de registro a izquierdas tipo 2 (RL2)" ;
    ns1:identificador "RL2" ;
    ns1:textoExtracto "Tipo de rotación 2 (RL2 o RR2): Rotación circular del registro en el sentido indicado." .

ns1:RotacionRegistro_RR1 a ns1:AccionProhibida ;
    rdfs:label "Rotación de registro a derechas tipo 1 (RR1)" ;
    ns1:identificador "RR1" ;
    ns1:textoExtracto "Rotación de registros. [...] Tipo de rotación 1 (RL1 o RR1): Introduce un 0 en el bit menos significativo (RL1) o en el más significativo (RR1), desplazando los restantes bits del registro. [...] RR1 R100 1 R200 Realiza una rotación a derechas tipo 1 de R100 dejando el resultado en R200." .

ns1:RotacionRegistro_RR2 a ns1:AccionProhibida ;
    rdfs:label "Rotación de registro a derechas tipo 2 (RR2)" ;
    ns1:identificador "RR2" ;
    ns1:textoExtracto "Tipo de rotación 2 (RL2 o RR2): Rotación circular del registro en el sentido indicado." .

ns1:RutaAlmacenamiento_MtbSubHelp a ns1:InterfazUsuario ;
    rdfs:label "Ruta de almacenamiento de subrutinas (..\\Mtb\\Sub\\Help)"@es ;
    ns1:documentadoEn ns1:InterfazUsuario_EditorCNC8070 ;
    ns1:identificador "..\\Mtb\\Sub\\Help" ;
    ns1:textoExtracto "El fabricante de la máquina guardará el archivo en la carpeta ..\\Mtb\\Sub\\Help."@es .

ns1:RutaAlmacenamiento_UsersSubHelp a ns1:InterfazUsuario ;
    rdfs:label "Ruta de almacenamiento de subrutinas (..\\Users\\Sub\\Help)"@es ;
    ns1:documentadoEn ns1:InterfazUsuario_EditorCNC8070 ;
    ns1:identificador "..\\Users\\Sub\\Help" ;
    ns1:textoExtracto "el usuario deberá guardar su archivo pcall.txt ..\\Users\\Sub\\Help."@es .

ns1:RutaAsociacionMensajes a ns1:InterfazUsuario ;
    rdfs:label "Ruta de asociación de mensajes de ayuda" ;
    ns1:identificador "C:\\FAGORCNC\\MTB\\PLC\\LANG\\OEM.txt" ;
    ns1:textoExtracto "El campo 'Archivo asociado' estará definido de la forma: C:\\FAGORCNC\\MTB\\PLC\\LANG\\OEM.txt#27"^^rdfs:Literal .

ns1:RutinaCambioHerramienta_7_7 a ns1:ModoOperacion ;
    rdfs:label "Rutina de cambio de herramienta (T+M06)"@es ;
    ns1:ejecutadoPor ns1:SistemaComunicacionGestorPLC_7_7 ;
    ns1:habilitadoPor ns1:FuncionT_7_7 ;
    ns1:textoExtracto "Se recomienda que la rutina asociada a T incluya la función M06. [...] la rutina asociada a T ejecuta la función M06 (cambio de herramienta), detiene el mecanizado y el gestor envía al PLC el código correspondiente."@es .

ns1:RutinaM06_CNC a ns1:ModoOperacion ;
    rdfs:label "Rutina M06 (Cambio de herramienta)"@es ;
    ns1:identificador "M06" ;
    ns1:monitoreaParametro ns1:Variable_V.PLC.TMOPERATION,
        ns1:Variable_V.TM.MZWAIT ;
    ns1:textoExtracto """\r
    CNC en ejecución $SWITCH V.PLC.TMOPERATION; Analiza el tipo de operación.\r
    $CASE 1 ; Asumir la herramienta actual como herramienta activa.\r
    $CASE 3 ; Colocar la herramienta de tierra en el cabezal.\r
    $CASE 4 ; Dejar la herramienta del cabezal en tierra.\r
    $CASE 9 ; Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal.\r
    $CASE 10 ; Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal.\r
    $CASE 11 ; Orientar la torreta.\r
    """@es ;
    ns1:tieneComponente ns1:Subrutina_SUB_GR_TO_SPD,
        ns1:Subrutina_SUB_MZ_ROT,
        ns1:Subrutina_SUB_MZ_TO_SPD,
        ns1:Subrutina_SUB_SPD_AUTCHG,
        ns1:Subrutina_SUB_SPD_GMCHG,
        ns1:Subrutina_SUB_SPD_TO_GR .

ns1:RutinaM06_CambioHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Rutina M06 (Cambio de herramienta)",
        "Rutina M06: Cambio de herramienta en cabezal"@es,
        "Rutina M06: Programa de cambio de herramienta"@es ;
    ns1:ejecutadoPor ns1:Cabezal ;
    ns1:identificador "M06" ;
    ns1:ilustradoEn ns1:AlmacenHerramientas,
        ns1:PuntoCambioAutomatico,
        ns1:PuntoCambioManual ;
    ns1:requiereMantenimiento ns1:HerramientaGenerica,
        ns1:HerramientaTierra,
        ns1:SistemaCambioAutomaticoHerramientas ;
    ns1:textoExtracto "G1 Z_ F_ ; Desplazar el cabezal. # RET %L SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático. [...] M6 ; Orden al gestor para comenzar el cambio de herramienta.",
        "LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal. [...] $CASE 6 ; Dejar la herramienta del cabezal en el almacén y coger otra de tierra."@es,
        "del cabezal en tierra y coger otra de tierra. [...] $ENDSWITCH ; Fin análisis del tipo de operación."@es .

ns1:RutinaM06_Caso3 a ns1:TareaMantenimiento ;
    rdfs:label "Colocar herramienta de tierra en cabezal (Caso 3)" ;
    ns1:identificador "M06-CASE3" ;
    ns1:textoExtracto "$CASE 3 ; Colocar la herramienta de tierra en el cabezal. LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual. LL SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal." .

ns1:RutinaM06_Caso4 a ns1:TareaMantenimiento ;
    rdfs:label "Dejar herramienta del cabezal en tierra (Caso 4)" ;
    ns1:identificador "M06-CASE4" ;
    ns1:textoExtracto "$CASE 4 ; Dejar la herramienta del cabezal en tierra. LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual. LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal." .

ns1:RutinaM06_Caso6 a ns1:TareaMantenimiento ;
    rdfs:label "Cambio automático de herramienta (cabezal → almacén + tierra → cabezal) (Caso 6)",
        "Rutina M06 - Caso 6: Cambio de herramienta a tierra" ;
    ns1:ejecutadoPor ns1:BrazoCambiador ;
    ns1:identificador "CASE 6",
        "M06-CASE6" ;
    ns1:requiereMantenimiento ns1:CabezalM06,
        ns1:Pinza2,
        ns1:Subrutina_CH1_TO_MZ,
        ns1:Subrutina_SPD_AUTCHG,
        ns1:Subrutina_SPD_TO_CH1 ;
    ns1:textoExtracto "$CASE 6 ; Dejar la herramienta del cabezal en el almacén y coger otra de tierra. LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático. LL SUB_ARM_TO_CHG ; Llevar el brazo cambiador al punto de cambio. LL SUB_SPD_TO_CH2 ; Coger la herramienta del cabezal con la pinza 2. LL SUB_ARM_BACK ; Retirar el brazo cambiador. LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual.",
        "Dejar la herramienta del cabezal en el almacén y coger otra de tierra." .

ns1:RutinaM06_Caso7 a ns1:TareaMantenimiento ;
    rdfs:label "Rutina M06 - Caso 7: Cambio de herramienta (almacén → cabezal)",
        "Rutina M06 - Caso 7: Cambio manual de herramienta (cabezal → tierra → almacén)"@es ;
    ns1:ejecutadoPor ns1:Subrutina_SUB_ARM_BACK,
        ns1:Subrutina_SUB_ARM_TO_CHG,
        ns1:Subrutina_SUB_CH1_TO_SPD,
        ns1:Subrutina_SUB_SPD_AUTCHG,
        ns1:Subrutina_SUB_SPD_GMCHG,
        ns1:Subrutina_SUB_SPD_TO_GR ;
    ns1:identificador "M06_Case7" ;
    ns1:requiereMantenimiento ns1:BrazoCambiador,
        ns1:Cabezal,
        ns1:Pinza1,
        ns1:SistemaCambioHerramientas ;
    ns1:textoExtracto "$BREAK $CASE 7 ; Dejar la herramienta del cabezal en tierra, y coger otra del almacén. [...] LL SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal.",
        "Dejar la herramienta del cabezal en tierra, y coger otra del almacén."@es .

ns1:RutinaM06_Caso8 a ns1:TareaMantenimiento ;
    rdfs:label "Rutina M06 - Caso 8: Cambio de herramienta (tierra → cabezal)",
        "Rutina M06 - Caso 8: Cambio manual de herramienta (cabezal → tierra → tierra)"@es ;
    ns1:ejecutadoPor ns1:Subrutina_SUB_GR_TO_SPD,
        ns1:Subrutina_SUB_SPD_GMCHG,
        ns1:Subrutina_SUB_SPD_TO_GR ;
    ns1:identificador "M06_Case8" ;
    ns1:requiereMantenimiento ns1:Cabezal,
        ns1:SistemaCambioHerramientas ;
    ns1:textoExtracto "$BREAK $CASE 8 ; Dejar la herramienta del cabezal en tierra y coger otra de tierra. [...] LL SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal.",
        "Dejar la herramienta del cabezal en tierra y coger otra de tierra."@es .

ns1:RutinaM06_Caso9 a ns1:TareaMantenimiento ;
    rdfs:label "Rutina M06 - Caso 9: Cambio de herramienta (tierra → almacén vía cabezal)" ;
    ns1:activaAlarma ns1:Se_al_TCHANGEOK ;
    ns1:ejecutadoPor ns1:Subrutina_SUB_ARM_BACK,
        ns1:Subrutina_SUB_ARM_TO_CHG,
        ns1:Subrutina_SUB_CH2_TO_MZ,
        ns1:Subrutina_SUB_GR_TO_SPD,
        ns1:Subrutina_SUB_SPD_AUTCHG,
        ns1:Subrutina_SUB_SPD_GMCHG,
        ns1:Subrutina_SUB_SPD_TO_CH2 ;
    ns1:identificador "M06_Case9" ;
    ns1:requiereMantenimiento ns1:BrazoCambiador,
        ns1:Cabezal,
        ns1:Pinza2 ;
    ns1:textoExtracto "$BREAK $CASE 9 ; Coger una herramienta de tierra y llevarla al almacén pasando por el cabezal. [...] LL SUB_CH2_TO_MZ ; Comenzar el envío del brazo cambiador al almacén para dejar la herramienta." .

ns1:Rutina_M06_CambioHerramienta a ns1:TareaMantenimiento ;
    rdfs:label "Rutina M06 (Cambio de herramienta)"@es ;
    ns1:identificador "M06" ;
    ns1:requiereMantenimiento ns1:Sistema_Cabezal_Desplazamiento ;
    ns1:textoExtracto "M06 ; Orden al gestor para comenzar el cambio de herramienta."@es .

ns1:SWLIMITTOL a ns1:Parametro ;
    rdfs:label "SWLIMITTOL",
        "SWLIMITTOL (Tolerancia de los límites de software)" ;
    ns1:identificador "SWLIMITTOL" ;
    ns1:textoExtracto "SWLIMITTOL Tolerancia de los límites de software. Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): Entre ±99999.9999 mm. Valores posibles (2): Entre ±3937.00787 inch. Valores posibles (3): Entre ±99999.9999 grados. Valor por defecto: 0.1000 mm / 0.00394 inch / 0.1000 grados.",
        "SWLIMITTOL | Tolerancia de los límites de software." ;
    ns1:valor "0.1000 mm / 0.00394 inch / 0.1000 grados",
        "Tolerancia de los límites de software" .

ns1:Salida_ANAOUT2 a ns1:ComponenteElectrico ;
    rdfs:label "Salida analógica ANAOUT2" ;
    ns1:identificador "ANAOUT2" ;
    ns1:textoExtracto "salidas analógicas (ANAOUT) [...] E21A/ANAOUT2" .

ns1:SalidasAnalogicas_Fagor a ns1:Actuador ;
    rdfs:label "Salidas analógicas Fagor (amarillo)"@es ;
    ns1:documentadoEn ns1:Tabla_20_2_2_Interface ;
    ns1:textoExtracto "Color amarillo. Registros de las salidas analógicas Fagor."@es .

ns1:SalidasDigitales_Interface a ns1:ComponenteElectrico ;
    rdfs:label "Salidas digitales (morado)"@es ;
    ns1:documentadoEn ns1:Tabla_20_2_2_Interface ;
    ns1:textoExtracto "Color morado. Salidas digitales."@es .

ns1:Se_alAXISNEG a ns1:ComponenteElectrico ;
    rdfs:label "AXISNEG(axis)" ;
    ns1:controla ns1:MovimientoEjeNegativo ;
    ns1:identificador "AXISNEG" ;
    ns1:textoExtracto "AXISNEG(axis) [...] Si el PLC pone una de estas marcas a (=1), el CNC desplazará el eje correspondiente en el sentido indicado, negativo (NEG)."@es .

ns1:Se_alAXISPOS a ns1:ComponenteElectrico ;
    rdfs:label "AXISPOS(axis)" ;
    ns1:controla ns1:MovimientoEjePositivo ;
    ns1:identificador "AXISPOS" ;
    ns1:textoExtracto "AXISPOS(axis) [...] Si el PLC pone una de estas marcas a (=1), el CNC desplazará el eje correspondiente en el sentido indicado, positivo (POS)."@es .

ns1:Se_alCNC_ActivoEje a ns1:ComponenteElectrico ;
    rdfs:label "Señal de eje activo (CNC)" ;
    ns1:textoExtracto "se encuentra activo en el eje. El CNC pone esta marca a (=0) cuando se suspende (congela) o anula el control tangencial del eje." .

ns1:Se_alCNC_LOPEN a ns1:ComponenteElectrico ;
    rdfs:label "LOPEN(axis)" ;
    ns1:identificador "LOPEN(axis)" ;
    ns1:textoExtracto "El CNC activa esta marca para indicar al PLC que el lazo de posición del eje está abierto." .

ns1:Se_alCoincidenciaParametrosCNC_PLC a ns1:Sensor ;
    rdfs:label "Señal de coincidencia de parámetros CNC-PLC"@es ;
    ns1:activaAlarma ns1:AccionDetencionCabezal ;
    ns1:monitoreaParametro ns1:ParametroSetCNC,
        ns1:ParametroSetPLC ;
    ns1:textoExtracto "activa esta marca cuando el set de parámetros seleccionado en el CNC y en el PLC coinciden. Para que ambos sets de parámetros coincidan, deberá estar activa la función M41 en el CNC y la marca GEAR1 en el PLC, M42 con GEAR2 y así sucesivamente."@es .

ns1:Se_alDetencionSincronizacion a ns1:ComponenteElectrico ;
    rdfs:label "Señal de detención de sincronización" ;
    ns1:monitoreaParametro ns1:EstadoSincronizacionEjes ;
    ns1:textoExtracto "si el PLC pone esta señal a (=1), se detiene el movimiento de sincronización, pasando a velocidad nula. El sistema permanece en espera hasta que se desactive la señal para reanudar la ejecución y el movimiento desde el punto en el que se detuvo."@es .

ns1:Se_alENABLE a ns1:ComponenteElectrico ;
    rdfs:label "ENABLE(axis)" ;
    ns1:identificador "ENABLE" ;
    ns1:textoExtracto "Para controlar el eje sólo en los desplazamientos, se debe utilizar la marca ENABLE. [...] El CNC la pone a (=1) cada vez que quiere mover el eje."@es .

ns1:Se_alPARKB a ns1:Parametro ;
    rdfs:label "Señal PARKB",
        "Señal PARKB (petición de aparcar eje B)" ;
    ns1:identificador "PARKB" ;
    ns1:textoExtracto "Si hay una petición para desaparcar el eje 'B' (UNPARKB) y el eje está presente (I15), [...] Las señales lógicas PARK y UNPARK para informar al PLC que los procesos correspondientes de aparcar o desaparcar se encuentran en ejecución.",
        "petición para aparcar el eje \"B\" (PARKB)" ;
    ns1:valor "PARKB" .

ns1:Se_alREFPOIN a ns1:Parametro ;
    rdfs:label "Señal REFPOIN (referencia de punto del eje)" ;
    ns1:identificador "REFPOIN" ;
    ns1:textoExtracto "Por seguridad, tras aparcar y desaparcar un eje, la señal REFPOIN del eje se pone a (=0)." .

ns1:Se_alSERVOBON a ns1:Parametro ;
    rdfs:label "Señal SERVOBON (servo del eje B activado)" ;
    ns1:identificador "SERVOBON" ;
    ns1:textoExtracto "NOT (PARKB OR UNPARKB OR PARKEDB) AND··· = DRENAB = SPENAB = SERVOBON" .

ns1:Se_alSERVOON a ns1:ComponenteElectrico ;
    rdfs:label "SERVO(axis)ON" ;
    ns1:habilitadoPor ns1:CondicionServoON ;
    ns1:identificador "SERVOON" ;
    ns1:textoExtracto "Esta marca debe estar a (=1) para permitir el movimiento (desbloqueo) del eje correspondiente. Si durante el desplazamiento del eje o cabezal se pone la marca SERVO(axis)ON a (=0) el CNC detiene el avance de los ejes y el giro del cabezal, visualizando en la pantalla el error correspondiente."@es .

ns1:Se_alSPENAB a ns1:Parametro ;
    rdfs:label "Señal SPENAB (habilitación de servo del eje B)" ;
    ns1:identificador "SPENAB" ;
    ns1:textoExtracto "NOT (PARKB OR UNPARKB OR PARKEDB) AND··· = DRENAB = SPENAB = SERVOBON" .

ns1:Se_alUNPARKB a ns1:Parametro ;
    rdfs:label "Señal UNPARKB",
        "Señal UNPARKB (petición de desaparcar eje B)" ;
    ns1:identificador "UNPARKB" ;
    ns1:textoExtracto "Si hay una petición para desaparcar el eje 'B' (UNPARKB) y el eje está presente (I15), el eje está desaparcado (RES PARKEDB).",
        "petición para desaparcar el eje \"B\" (UNPARKB)" ;
    ns1:valor "UNPARKB" .

ns1:Se_al_ALARM a ns1:Alarma ;
    rdfs:label "Señal _ALARM"@es ;
    ns1:textoExtracto "Los errores no activan la alarma del CNC, señal (_ALARM)."@es .

ns1:Se_al_AUXENDC1 a ns1:InterfazUsuario ;
    rdfs:label "AUXENDC1" ;
    ns1:documentadoEn ns1:Manual_Seccion6.8 ;
    ns1:identificador "AUXENDC1" ;
    ns1:textoExtracto "AUXENDC1 (también se puede programar como AUXEND)" .

ns1:Se_al_AUXENDC2 a ns1:InterfazUsuario ;
    rdfs:label "AUXENDC2" ;
    ns1:documentadoEn ns1:Manual_Seccion6.8 ;
    ns1:identificador "AUXENDC2" ;
    ns1:textoExtracto "AUXENDC2" .

ns1:Se_al_AUXENDC3 a ns1:InterfazUsuario ;
    rdfs:label "AUXENDC3" ;
    ns1:documentadoEn ns1:Manual_Seccion6.8 ;
    ns1:identificador "AUXENDC3" ;
    ns1:textoExtracto "AUXENDC3" .

ns1:Se_al_AUXENDC4 a ns1:InterfazUsuario ;
    rdfs:label "AUXENDC4" ;
    ns1:documentadoEn ns1:Manual_Seccion6.8 ;
    ns1:identificador "AUXENDC4" ;
    ns1:textoExtracto "AUXENDC4" .

ns1:Se_al_DRENA a ns1:Parametro ;
    rdfs:label "DRENA(axis)"@es ;
    ns1:monitoreaParametro ns1:DiagramaTemporal_PLC_Se_alesEjes ;
    ns1:textoExtracto "Representa DRENA(axis) en el diagrama temporal de maniobra desde PLC."@es .

ns1:Se_al_ENABLEGAP a ns1:ComponenteElectrico ;
    rdfs:label "ENABLEGAP" ;
    ns1:identificador "ENABLEGAP" ;
    ns1:textoExtracto "ENABLEGAP | Marca activa por defecto. El PLC desactiva esta marca para deshabilitar"@es .

ns1:Se_al_IBUSY a ns1:Parametro ;
    rdfs:label "IBUSY(axis)" ;
    ns1:monitoreaParametro ns1:InterpoladorEjeIndependiente ;
    ns1:textoExtracto "Para los movimientos de eje independiente, el interpolador del eje activa esta marca cuando tiene alguna sentencia pendiente de ejecución." .

ns1:Se_al_IEND a ns1:Parametro ;
    rdfs:label "IEND(axis)" ;
    ns1:monitoreaParametro ns1:InterpoladorEjeIndependiente ;
    ns1:textoExtracto "Para los movimientos de eje independiente, el interpolador del eje activa esta marca cuando termina de generar el movimiento teórico." .

ns1:Se_al_IFHOUT a ns1:Parametro ;
    rdfs:label "IFHOUT(axis)" ;
    ns1:monitoreaParametro ns1:InterpoladorEjeIndependiente ;
    ns1:textoExtracto "Para los movimientos de eje independiente, el interpolador del eje activa esta marca cuando la ejecución está detenida." .

ns1:Se_al_IFREE a ns1:Parametro ;
    rdfs:label "IFREE(axis)" ;
    ns1:monitoreaParametro ns1:InterpoladorEjeIndependiente ;
    ns1:textoExtracto "Para los movimientos de eje independiente, el interpolador del eje activa esta marca cuando está listo para aceptar un nuevo bloque de movimiento." .

ns1:Se_al_INPOSI a ns1:InterfazUsuario ;
    rdfs:label "INPOSI" ;
    ns1:identificador "INPOSI" ;
    ns1:textoExtracto "El canal del CNC pone la marca INPOSI a (=1) para indicar que todos sus ejes y cabezales activos han llegado a posición, exceptuando los ejes independientes programados desde el PLC. La marca INPOSI permanece a (=1) durante el movimiento de los ejes independientes." .

ns1:Se_al_INSYNC a ns1:Parametro ;
    rdfs:label "INSYNC(axis)" ;
    ns1:monitoreaParametro ns1:InterpoladorEjeIndependiente ;
    ns1:textoExtracto "Para los movimientos de sincronización de eje independiente y leva electrónica, el interpolador del eje activa esta marca cuando se ha alcanzado la sincronización." .

ns1:Se_al_LATCH1ACTIVE a ns1:Parametro ;
    rdfs:label "LATCH1ACTIVE(axis)" ;
    ns1:monitoreaParametro ns1:InterpoladorEjeIndependiente ;
    ns1:textoExtracto "Se aplica al proceso de latcheo de la cota de un eje. [...] El interpolador independiente activa esta marca al activar un proceso de latcheo en el eje con el palpador 1." .

ns1:Se_al_LATCH2ACTIVE a ns1:Parametro ;
    rdfs:label "LATCH2ACTIVE(axis)" ;
    ns1:monitoreaParametro ns1:InterpoladorEjeIndependiente ;
    ns1:textoExtracto "Se aplica al proceso de latcheo de la cota de un eje. [...] El interpolador independiente activa esta marca al activar un proceso de latcheo en el eje con el palpador 2." .

ns1:Se_al_MZID a ns1:Parametro ;
    rdfs:label "Señal MZID (identificación almacén)" ;
    ns1:identificador "MZIDC1, MZIDC2, MZIDC3, MZIDC4" ;
    ns1:monitoreaParametro ns1:SistemaGestorHerramientas ;
    ns1:textoExtracto "Este registro indica el almacén en el que se encuentra la herramienta que ha solicitado el canal. Cuando en el cambio de herramienta intervengan dos almacenes, en la parte baja de este registro se indica el almacén en el que hay que dejar la herramienta y en la parte alta el almacén del que hay que coger la herramienta." .

ns1:Se_al_PROBE1ACTIVE a ns1:Parametro ;
    rdfs:label "PROBE1ACTIVE" ;
    ns1:monitoreaParametro ns1:InterpoladorEjeIndependiente ;
    ns1:textoExtracto "Se aplica al proceso de latcheo de la cota de un eje. [...] El interpolador independiente activa esta marca cuando hay algún proceso de latcheo activo con el palpador 1." .

ns1:Se_al_PROBE2ACTIVE a ns1:Parametro ;
    rdfs:label "PROBE2ACTIVE" ;
    ns1:monitoreaParametro ns1:InterpoladorEjeIndependiente ;
    ns1:textoExtracto "Se aplica al proceso de latcheo de la cota de un eje. [...] El interpolador independiente activa esta marca cuando hay algún proceso de latcheo activo con el palpador 2." .

ns1:Se_al_REFPOIN a ns1:Parametro ;
    rdfs:label "REFPOIN(axis)"@es ;
    ns1:monitoreaParametro ns1:DiagramaTemporal_PLC_Se_alesEjes ;
    ns1:textoExtracto "Representa REFPOIN(axis) en el diagrama temporal de maniobra desde PLC."@es .

ns1:Se_al_ROTATEMZ a ns1:Parametro ;
    rdfs:label "Señal ROTATEMZ" ;
    ns1:monitoreaParametro ns1:SistemaGestorHerramientas ;
    ns1:textoExtracto "en un posicionamiento absoluto este registro indica la posición a alcanzar y en un posicionamiento relativo indica el número de posiciones a girar." .

ns1:Se_al_SERPLCAC a ns1:ComponenteElectrico ;
    rdfs:label "SERPLCAC" ;
    ns1:identificador "SERPLCAC" ;
    ns1:textoExtracto "Verificar que el cambio de set y/o gama ha terminado (marca SERPLCAC)" .

ns1:Se_al_SFUN1 a ns1:ComponenteElectrico ;
    rdfs:label "Señal SFUN1"@es ;
    ns1:textoExtracto "el CNC entiende que se debe pasar el valor de la S al PLC mediante las señales SSTROBE + SFUN1."@es .

ns1:Se_al_SSTROBE a ns1:ComponenteElectrico ;
    rdfs:label "Señal SSTROBE"@es ;
    ns1:textoExtracto "el CNC entiende que se debe pasar el valor de la S al PLC mediante las señales SSTROBE + SFUN1."@es .

ns1:Se_al_STOP a ns1:ComponenteElectrico ;
    rdfs:label "_STOP" ;
    ns1:identificador "_STOP" ;
    ns1:textoExtracto "El tratamiento que recibe la señal _STOP es similar al que recibe la tecla [STOP] del CNC. Con esta señal a nivel lógico bajo, todas las teclas permanecen habilitadas."@es .

ns1:Se_al_STOP_CNC a ns1:InterfazUsuario ;
    rdfs:label "Señal STOP del CNC" ;
    ns1:textoExtracto "[STOP] del CNC. Con esta señal a nivel lógico bajo, todas las teclas permanecen habilitadas." .

ns1:Se_al_TMINEM a ns1:Parametro ;
    rdfs:label "Señal TMINEM (emergencia en gestor)" ;
    ns1:identificador "TMINEMZ1, TMINEMZ2, TMINEMZ3, TMINEMZ4" ;
    ns1:monitoreaParametro ns1:SistemaGestorHerramientas ;
    ns1:textoExtracto "El CNC pone esta marca a (=1) para indicar al PLC que se ha producido una emergencia en el gestor de herramientas." .

ns1:Se_al_TWORNOUT a ns1:Parametro ;
    rdfs:label "Señal TWORNOUT (rechazo herramienta por tiempo)" ;
    ns1:identificador "TWORNOUTC1, TWORNOUTC2, TWORNOUTC3, TWORNOUTC4" ;
    ns1:monitoreaParametro ns1:SistemaGestorHerramientas ;
    ns1:textoExtracto "El canal del CNC pone esta marca a (=1) para indicar al PLC que la herramienta ha sido rechazada porque se ha usado más tiempo del previsto (vida real > vida máxima)." .

ns1:Seccion6_1_SenalesConsultaGenerales a ns1:InterfazUsuario ;
    rdfs:label "Sección 6.1: Señales de consulta generales" ;
    ns1:textoExtracto "Señales de consulta generales. SSTROBE, DM00, DM03, BLKSEARCH y otras marcas asociadas a funciones M del CNC." ;
    ns1:tieneComponente ns1:BLKSEARCH,
        ns1:DM00,
        ns1:DM00C1,
        ns1:DM00C2,
        ns1:DM00C3,
        ns1:DM00C4,
        ns1:DM03SP1,
        ns1:SPDLTIME,
        ns1:SSTROBE1,
        ns1:SSTROBE2,
        ns1:SSTROBE3,
        ns1:SSTROBE4 .

ns1:SecuenciaAlternativa_1_3_2 a ns1:ModoOperacion ;
    rdfs:label "Secuencia alternativa 1-3-2" ;
    ns1:textoExtracto "El gestor también admite la secuencia 1-3-2."@es .

ns1:SecuenciaOperacionAlmacen_7_11_2 a ns1:ModoOperacion ;
    rdfs:label "Secuencia de operación del almacén (7.11.2)" ;
    ns1:controla ns1:HerramientaPinza2,
        ns1:HerramientaTierra ;
    ns1:ejecutadoPor ns1:BrazoCambiador ;
    ns1:habilitadoPor ns1:MarcaCH2TOMZ,
        ns1:MarcaGRTOSPDL,
        ns1:MarcaSPDLTOCH2,
        ns1:MarcaTCHANGEOK ;
    ns1:identificador "TMOPERATION=7" ;
    ns1:textoExtracto "Segunda secuencia: 1 Coger la herramienta del cabezal con la pinza ꞏ2ꞏ y activar la marca SPDLTOCH2. 2 Poner la herramienta de tierra en el cabezal y activar la marca GRTOSPDL. 3 Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza ꞏ2ꞏ. 4 Al abandonar el brazo la zona de posible colisión activar TCHANGEOK, si se desea, para que continúe la ejecución del programa. 5 Dejar la herramienta de la pinza ꞏ2ꞏ en el almacén y activar la marca CH2TOMZ. TMOPERATION = 7 Dejar la herramienta del cabezal en tierra y coger una herramienta del brazo. TAKEPOS=-1 Herramienta en el brazo cambiador. LEAVEPOS=-4 Herramienta de tierra." .

ns1:SecuenciaParametros_12_1_4 a ns1:Parametro ;
    rdfs:label "Secuencia de valores para archivo de configuración"@es ;
    ns1:identificador "12.1.4" ;
    ns1:textoExtracto """\r
        4 X(P1) Y(P1) Z(P2) X(P2) Y(P1) Z(P2) Z X(Pn) Y(P1) Z(P2) X Y X(Pn) NPOINTAX1 Y(Pn) X(P4) NPOINTAX2 Z(P2) X(P3) Y(P2) X(P2) XYZ(P1)\r
        5 X(P1) Y(P2) Z(P2) X(P2) Y(P2) Z(P2) Z X(Pn) Y(P2) Z(P2) X(P1) Y(Pn) Z(P2) X Y X(P2) Y(Pn) Z(P2) X(Pn) ··· NPOINTAX1 Y(Pn) X(P4) NPOINTAX2 X(Pn) Y(Pn) Z(P2) Z(P2) X(P3) Y(P2) X(P2) XYZ(P1) X(P1) Y(P1) Z(Pn)\r
        6 X(P2) Y(P1) Z(Pn) X(Pn) Y(P1) Z(Pn) Z X(P1) Y(Pn) Z(Pn) X(P2) Y(Pn) Z(Pn) X Y X(Pn) X(Pn) Y(Pn) Z(Pn) NPOINTAX1 Y(Pn) X(P4) NPOINTAX2 X(P3) X(P1) Y(Pn) Z(Pn) Y(P2) X(P2) X(P2) Y(Pn) Z(Pn) XYZ(P1) X(Pn) Y(Pn) Z(Pn)\r
        """ .

ns1:SelectorMovimientos_807 a ns1:InterfazUsuario ;
    rdfs:label "Selector de movimientos (modo volante)"@es ;
    ns1:habilitadoPor ns1:ModoSeleccionEjes_807 ;
    ns1:textoExtracto "La selección de ejes se anula al salir del modo volante con el selector de movimientos"@es .

ns1:Selector_ModoVolante a ns1:InterfazUsuario ;
    rdfs:label "Selector en modo volante"@es ;
    ns1:textoExtracto "el CNC se encuentra en modo manual y el selector en modo volante."@es .

ns1:SenalActivacionMaterial a ns1:Parametro ;
    rdfs:label "ACTIVEMATERIALON" ;
    ns1:identificador "ACTIVEMATERIALON" ;
    ns1:monitoreaParametro ns1:SistemaCNC ;
    ns1:textoExtracto "ACTIVEMATERIALON: El CNC activa esta marca cuando hay un fichero de material activo (por la ejecución de #MATERIAL, #TECHTABLE, por activación desde HMI o por recuperación en el arranque)." .

ns1:SenalCDW a ns1:Parametro ;
    rdfs:label "Entrada CDW (desconteo)" ;
    ns1:monitoreaParametro ns1:ContadorPLC ;
    ns1:textoExtracto "decrementos por flancos de subida" .

ns1:SenalCEN a ns1:Parametro ;
    rdfs:label "Entrada CEN (enable)" ;
    ns1:monitoreaParametro ns1:ContadorPLC ;
    ns1:textoExtracto "efecto de CEN=0 (inhibe CUP/CDW)" .

ns1:SenalCUP a ns1:Parametro ;
    rdfs:label "Entrada CUP (conteo)" ;
    ns1:monitoreaParametro ns1:ContadorPLC ;
    ns1:textoExtracto "incrementos por flancos de subida" .

ns1:SenalComVarAct a ns1:Parametro ;
    rdfs:label "COMVARACT" ;
    ns1:identificador "COMVARACT" ;
    ns1:monitoreaParametro ns1:SistemaCNC ;
    ns1:textoExtracto "COMVARACT: El CNC activa esta marca cuando el usuario valida los parámetros comunes de la tabla de piercing o cutting activa. El PLC debe desactivar esta marca cuando termina su gestión con estas variables." .

ns1:SenalCutVarAct a ns1:Parametro ;
    rdfs:label "CUTVARACT" ;
    ns1:identificador "CUTVARACT" ;
    ns1:monitoreaParametro ns1:SistemaCNC ;
    ns1:textoExtracto "CUTVARACT: El CNC activa esta marca cuando el usuario valida los parámetros de cutting de la tabla activa. El PLC debe desactivar esta marca cuando termina su gestión con estas variables." .

ns1:SenalCuttingActivo a ns1:Parametro ;
    rdfs:label "CUTTING" ;
    ns1:identificador "CUTTING" ;
    ns1:monitoreaParametro ns1:SistemaCNC ;
    ns1:textoExtracto "CUTTING: Cutting activo. El OEM debe gestionar esta marca desde las subrutinas asociadas al cutting (por defecto, Cuttingon.fst / Cuttingoff.fst), para indicar al PLC cuando empieza (valor 1) y acaba (valor 0) la operación de cutting." ;
    ns1:valor "0",
        "1" .

ns1:SenalDECEL a ns1:Sensor ;
    rdfs:label "DECEL(axis)" ;
    ns1:monitoreaParametro ns1:DeceleracionBusquedaReferencia ;
    ns1:textoExtracto "DECEL(axis) [...] El PLC la pone a (=1) para indicar que el micro de búsqueda de referencia máquina está pulsado. El CNC decelera el eje, pasa del avance rápido indicado por el parámetro máquina REFFEED1, al avance lento indicado por el parámetro máquina REFFEED2."@es .

ns1:SenalLaserOn a ns1:InterfazUsuario ;
    rdfs:label "LASERON" ;
    ns1:monitoreaParametro ns1:EstadoLaser ;
    ns1:textoExtracto "LASERON El PLC activa está marca para indicar que el láser está encendido." .

ns1:SenalLaserReady a ns1:InterfazUsuario ;
    rdfs:label "LASERREADY" ;
    ns1:monitoreaParametro ns1:EstadoPreparacionLaser ;
    ns1:textoExtracto "LASERREADY El PLC activa está marca para indicar que el láser está preparado." .

ns1:SenalOUTOFGAP a ns1:Parametro ;
    rdfs:label "OUTOFGAP" ;
    ns1:documentadoEn ns1:Seccion6_11_SenalesLogicasModificablesLaser ;
    ns1:monitoreaParametro ns1:ParametroGAPMAX,
        ns1:ParametroGAPMIN ;
    ns1:textoExtracto "OUTOFGAP: El PLC activa esta marca (cambio de 1 a 0) para indicar que la boquilla ha salido alguna vez del gap (parámetros GAPMIN y GAPMAX) durante la ejecución del programa. Esta marca permanece activa hasta iniciar la ejecución de un programa."@es .

ns1:SenalOUTOFTOL a ns1:Parametro ;
    rdfs:label "OUTOFTOL" ;
    ns1:documentadoEn ns1:Seccion6_11_SenalesLogicasModificablesLaser ;
    ns1:textoExtracto "OUTOFTOL: El PLC activa esta marca para [...]"@es .

ns1:SenalPWMOn a ns1:InterfazUsuario ;
    rdfs:label "PWMON" ;
    ns1:controla ns1:ParametroPWM ;
    ns1:textoExtracto "PWMON Esta marca permite activar y desactivar el PWM desde el PLC." .

ns1:SenalPiercingActivo a ns1:Parametro ;
    rdfs:label "PIERCING" ;
    ns1:identificador "PIERCING" ;
    ns1:monitoreaParametro ns1:SistemaCNC ;
    ns1:textoExtracto "PIERCING: Piercing activo. El OEM debe gestionar esta marca desde la subrutina asociada al piercing (por defecto, Piercing.fst), para indicar al PLC cuando empieza (valor 1) y acaba (valor 0) la operación de piercing." ;
    ns1:valor "0",
        "1" .

ns1:SenalSYNC a ns1:ComponenteElectrico ;
    rdfs:label "Señal SYNC" ;
    ns1:textoExtracto "Esta marca se activa en el cabezal esclavo e indica que ha comenzado una sincronización mediante la sentencia #SYNC." ;
    ns1:tieneComponente ns1:SistemaSincronizacionCabezales .

ns1:SenalShutterOn a ns1:InterfazUsuario ;
    rdfs:label "SHUTTERON" ;
    ns1:monitoreaParametro ns1:EstadoObturador ;
    ns1:textoExtracto "SHUTTERON El PLC activa está marca para indicar que el obturador de la fuente láser está abierto." .

ns1:SenalSincronizacionCNC a ns1:ComponenteElectrico ;
    rdfs:label "Señal de sincronización CNC-PLC"@es ;
    ns1:identificador "#WAIT, #MEET" ;
    ns1:textoExtracto "El canal del CNC pone esta señal a (=1) para indicar al PLC que está esperando una señal de sincronización. Las señales de sincronización se pueden ejecutar desde el programa pieza mediante las sentencias #WAIT o #MEET."@es .

ns1:SenalTEN_TG4 a ns1:Parametro ;
    rdfs:label "Señal TEN en modo TG4" ;
    ns1:monitoreaParametro ns1:ModoLimitadorTG4 ;
    ns1:textoExtracto "con la temporización activa, forzar TEN=0 congela t y mantiene el estado hasta recuperar TEN=1, cuando la temporización prosigue hasta su fin o hasta la caída de TG4." .

ns1:SenalTRS_TG4 a ns1:Parametro ;
    rdfs:label "Señal TRS en modo TG4" ;
    ns1:monitoreaParametro ns1:ModoLimitadorTG4 ;
    ns1:textoExtracto "la señal TRS, por flanco de subida, reinicia el temporizador (T=0, t=0) en cualquier momento del ciclo y requiere nueva activación mediante TG4." .

ns1:Senal_ADVINPOS a ns1:InterfazUsuario ;
