ns1:NodoRIO5_1400 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo RIO5 (módulo físico = bloque lógico)"@es ;
    ns1:identificador "RIO5" ;
    ns1:textoExtracto "En los nodos RIO5 y RIOR, cada módulo es un bloque lógico, no se permite agrupar varios módulos en un bloque ni dividir un módulo en bloques. Los bloques lógicos deben coincidir en número y dimensión con los módulos detectados físicamente en el bus. En los nodos RIO5, cada módulo doble (módulo con dos placas) cuenta como dos; es decir, dos bloques lógicos."@es .

ns1:NodoRIOR_1400 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo RIOR (módulo físico = bloque lógico)"@es ;
    ns1:identificador "RIOR" ;
    ns1:textoExtracto "En los nodos RIO5 y RIOR, cada módulo es un bloque lógico, no se permite agrupar varios módulos en un bloque ni dividir un módulo en bloques."@es .

ns1:NodoRIOW_1400 a ns1:ComponenteElectrico ;
