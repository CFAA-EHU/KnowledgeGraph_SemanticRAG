ns1:ReguladorSercos_1289 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos con interfaz A1/SI"@es ;
    ns1:textoExtracto "regulador Sercos de cualquier eje [...] Las entradas analógicas del regulador son una opción de hardware; para disponer de ellas, el regulador debe disponer de una interfaz de comunicación con entradas analógicas A1 o SI."@es ;
    ns1:tieneComponente ns1:InterfazAnalogicaA1_1289 .

ns1:ReguladorSercos_Posicion a ns1:ComponenteElectrico ;
    rdfs:label "Regulador Sercos en modo posición"@es ;
    ns1:monitoreaParametro ns1:Parametro_FBACKSRC ;
    ns1:textoExtracto "Modo de operación del regulador en Sercos posición. • La consigna se envía al regulador en cotas absolutas, en diezmilésimas de milímetro (ejes lineales) o milésimas de grado (ejes rotativos). [...] El regulador suaviza la consigna mediante una interpolación cúbica y cierra el lazo de posición cada 256 microsegundos."@es .

ns1:ReguladorV6_14 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador V6.14"@es ;
    ns1:identificador "V6.14" ;
    ns1:textoExtracto "La gestión de cabezales y ejes tándem requiere una versión del regulador V6.14 o superior."@es .

ns1:Regulador_Gap a ns1:ComponenteElectrico ;
    rdfs:label "Regulador (entrada X3 para sensor de gap)"@es ;
    ns1:documentadoEn ns1:Tabla_2.3.31_ModosConexionSensorGap ;
    ns1:monitoreaParametro ns1:SensorGap ;
    ns1:textoExtracto "El sensor del gap está conectado a la entrada X3 del regulador. El CNC controla el eje del sensor hasta que alcanza el gap programado (teniendo en cuenta GAPINPOSW). Una vez alcanzada esta posición, el regulador controla el gap."@es .

ns1:Regulador_Seccion6_2 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador de eje/cabezal" ;
    ns1:monitoreaParametro ns1:Parametro_DRSTAF,
        ns1:Parametro_DRSTAS ;
    ns1:textoExtracto "El regulador efectúa una comprobación interna. Si es correcta activa la salida System OK. [...] el regulador está funcionando correctamente."@es ;
    ns1:tieneComponente ns1:Entrada_DriveEnable,
        ns1:Entrada_SpeedEnable,
        ns1:Salida_SystemOK .

ns1:Regulador_v9.10 a ns1:ComponenteElectrico ;
    rdfs:label "Regulador (versión 9.10 o posterior)"@es ;
    ns1:identificador "v9.10" ;
    ns1:textoExtracto "Esta prestación requiere una versión de regulador v9.10 o posterior. Consultar en el manual de i regulador el conexionado del sensor del gap."@es .

ns1:RelojComparador_17_2 a ns1:Herramienta ;
    rdfs:label "Reloj comparador para medición de precisión"@es ;
    ns1:ilustradoEn ns1:EsquemaPosicionamiento_17_2 ;
    ns1:textoExtracto "un reloj comparador [...] Es recomendable que el reloj esté lo más perpendicular posible a la tangente de la superficie a medir."@es .

ns1:Reloj_CLK a ns1:Parametro ;
