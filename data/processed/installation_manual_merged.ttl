    ns1:requiereMantenimiento ns1:Parametro_DWELL ;
    ns1:textoExtracto "Cuando está quieto (freno activo) se dice que el eje está 'muerto'."@es .

ns1:ModoOperacion_EjeRotativoMultiVuelta a ns1:ModoOperacion ;
    rdfs:label "Modo de operación: eje rotativo (múltiples vueltas)"@es ;
    ns1:textoExtracto "Si el desplazamiento programado es superior al módulo, el eje da más de una vuelta."@es .

ns1:ModoOperacion_EjeRotativoPosicionamiento a ns1:ModoOperacion ;
    rdfs:label "Eje rotativo de posicionamiento" ;
    ns1:textoExtracto "Eje rotativo de posicionamiento. Este tipo de eje rotativo se puede desplazar en ambos sentidos, pero en los movimientos absolutos se desplaza por el camino más corto. El CNC visualiza las cotas entre los límites del módulo." ;
    ns1:tieneComponente ns1:Parametro_MODLOWLIM,
        ns1:Parametro_MODUPLIM,
        ns1:Parametro_SHORTESTWAY,
        ns1:Parametro_UNIDIR .

ns1:ModoOperacion_EjeRotativoUnVuelta a ns1:ModoOperacion ;
    rdfs:label "Modo de operación: eje rotativo (1 vuelta máxima)"@es ;
    ns1:textoExtracto "Aunque el desplazamiento programado sea superior al módulo, el eje nunca da más de una vuelta."@es .

ns1:ModoOperacion_EjeRotativo_Linearlike a ns1:ModoOperacion ;
    rdfs:label "Modo de operación de eje rotativo (Linearlike)" ;
    ns1:identificador "AXISMODE_Linearlike" ;
    ns1:textoExtracto "Comportamiento cuando AXISMODE = Linearlike. Actúa parecido a un eje lineal. Se pueden programar desplazamientos en G0/G1 y G90/G91. El contaje es libre y en grados (no le afecta mm/inch)."@es .

ns1:ModoOperacion_EjeVivo a ns1:ModoOperacion ;
    rdfs:label "Modo 'Eje Vivo' (desplazamiento activo)"@es ;
    ns1:habilitadoPor ns1:Parametro_DWELL ;
    ns1:textoExtracto "Cuando está gobernado por el CNC (desplazamientos) se dice que el eje está 'vivo'."@es .

ns1:ModoOperacion_EntradaPieza a ns1:ModoOperacion ;
