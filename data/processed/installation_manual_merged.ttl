ns1:Marca_ALARMC4 a ns1:Componente ;
    rdfs:label "Marca _ALARM Canal 4" ;
    ns1:identificador "_ALARMC4" ;
    ns1:textoExtracto "_ALARMC4" .

ns1:Marca_AUXEND_802 a ns1:ComponenteElectrico ;
    rdfs:label "Marca AUXEND" ;
    ns1:identificador "AUXEND" ;
    ns1:textoExtracto "El PLC, al detectar la activación de una de estas marcas, debe desactivar la marca AUXEND para indicar al CNC que comienza la ejecución. [...] Una vez ejecutadas las funciones auxiliares requeridas, el PLC debe activar la marca AUXEND para indicar al CNC que ha finalizado."@es .

ns1:Marca_CH1TOMZ a ns1:InterfazUsuario,
        ns1:Parametro ;
    rdfs:label "CH1TOMZ",
        "Marca CH1TOMZ (herramienta dejada en almacén desde pinza ꞏ1ꞏ)",
        "Marca CH1TOMZ"@es ;
    ns1:documentadoEn ns1:Tabla_ComunicacionPLC_Gestor_732 ;
    ns1:identificador "CH1TOMZ" ;
    ns1:monitoreaParametro ns1:SistemaComunicacionPLC_Gestor ;
    ns1:textoExtracto "activar la marca CH1TOMZ",
        "CH1TOMZ (Almacén 1-4: CH1TOMZ1, CH1TOMZ2, CH1TOMZ3, CH1TOMZ4)"@es,
        "Utilizar con almacén asíncrono o síncrono con brazo. El PLC debe poner esta marca a (=1) tras llevar la herramienta del brazo cambiador 1 al almacén."@es,
        "activar la marca CH1TOMZ"@es ;
    ns1:valor "1" .

