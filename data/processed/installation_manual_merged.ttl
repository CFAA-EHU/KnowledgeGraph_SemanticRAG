    ns1:valor "G95" .

ns1:Parametro_GAPANAINID_1292 a ns1:Parametro ;
    rdfs:label "GAPANAINID" ;
    ns1:identificador "GAPANAINID" ;
    ns1:textoExtracto "Este parámetro identifica la entrada analógica donde está conectado el sensor; si remoto CAN, de 1 a 60; si regulador, de 101 a 132 o de 201 a 232. [...] El parámetro se define mediante un número de tres dígitos; el primer dígito indica el número de la entrada analógica a utilizar (1 ó 2) y los dos dígitos siguientes indican la dirección lógica del regulador (de 1 a 32)."@es ;
    ns1:valor "101-132, 201-232 (regulador) / 1-60 (CAN)" .

ns1:Parametro_GAPANAINTYPE_1292 a ns1:Parametro ;
    rdfs:label "GAPANAINTYPE" ;
    ns1:identificador "GAPANAINTYPE" ;
    ns1:textoExtracto "Este parámetro indica dónde está ubicada la entrada analógica conectada al sensor; en los módulos remotos CAN o en un regulador Sercos. Se recomienda utilizar una entrada del regulador."@es .

