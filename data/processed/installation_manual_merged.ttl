        "1" .

ns1:Parametro_298105100a a ns1:Parametro ;
    rdfs:label "FREQUENCY"@es ;
    ns1:documentadoEn ns1:Tabla_FiltrosResonancia ;
    ns1:textoExtracto "Frecuencia de corte o central."@es .

ns1:Parametro_29ba282a4b a ns1:Parametro ;
    rdfs:label "SMOOTHFREQ"@es ;
    ns1:documentadoEn ns1:TablaDeParametrosDeConfiguracionHSCPaginas621622 ;
    ns1:identificador "SMOOTHFREQ MPG" ;
    ns1:textoExtracto "Este parámetro fija la frecuencia de suavizado en la interpolación de trayectorias. Este parámetro evita acelerar y decelerar a lo largo de una trayectoria, por encima de una determinada frecuencia al generar una velocidad promediada."@es .

ns1:Parametro_2a8b724426 a ns1:Parametro ;
    rdfs:label "NEXTMPGAXIS" ;
