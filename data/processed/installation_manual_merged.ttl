    rdfs:label "ZONELIMITTOL" ;
    ns1:identificador "ZONELIMITTOL" ;
    ns1:monitoreaParametro ns1:SistemaCNC ;
    ns1:textoExtracto "Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 99999.9999 mm o grados / de 0 a 3937.00787 inch. Valor por defecto: 0.1000 mm o grados / 0.00394 inch." ;
    ns1:valor "0.1000" .

