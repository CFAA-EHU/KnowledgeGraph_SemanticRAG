        ns1:Se_al_PARK,
        ns1:Se_al_PARKED ;
    ns1:requiereMantenimiento ns1:Sensor_Presencia_EjeV ;
    ns1:textoExtracto "Maniobra para aparcar un eje o cabezal desde el PLC." .

ns1:Tarea_CopiarArchivoRutadoCNC a ns1:TareaMantenimiento ;
    rdfs:label "Copiar archivo de rutado al CNC"@es ;
    ns1:identificador "resourceRouterConf.xml" ;
    ns1:textoExtracto "Para copiar el archivo de rutado al CNC (archivo xml), renombrarlo como 'resourceRouterConf.xml' y copiarlo a la carpeta ../Mtb/Data."@es .

