ns1:Parametro_TEN a ns1:Parametro ;
    rdfs:label "Parámetro TEN"@es ;
    ns1:textoExtracto "Con TEN=1 y TRS=0, el temporizador se activa al producirse un flanco de subida en la entrada TG4. [...] Si una vez activado el temporizador se selecciona TEN=0, el PLC detiene la temporización, siendo necesario asignar TEN=1 para que dicha temporización continúe."@es ;
    ns1:valor "0",
        "1" .

ns1:Parametro_TRS a ns1:Parametro ;
    rdfs:label "Parámetro TRS"@es ;
    ns1:textoExtracto "Funcionamiento de la entrada TRS en este modo. Si se produce un flanco de subida en la entrada TRS, durante la temporización o después de ella, el PLC inicializa el temporizador, asignando el valor 0 a su estado T y cancelando su cuenta (la inicializa a 0)."@es ;
    ns1:valor "0",
        "1" .

