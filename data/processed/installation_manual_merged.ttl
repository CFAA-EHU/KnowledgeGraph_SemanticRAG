ns1:Esquema_CompensacionCruzada a ns1:Esquema ;
    rdfs:label "Diagrama de compensación cruzada entre ejes" ;
    ns1:detalladoEnEsquema ns1:SistemaCompensacionCruzada ;
    ns1:textoExtracto "Diagrama conceptual de 'compensación cruzada' donde un eje maestro (MOVAXIS) provoca variaciones en un eje compensado (COMPAXIS)." .

ns1:Esquema_ComportamientoModulo a ns1:Esquema ;
    rdfs:label "Esquema de comportamiento 'Módulo' para ejes rotativos"@es ;
    ns1:ilustradoEn ns1:Pagina_158 ;
    ns1:textoExtracto "Tres esquemas circulares comparan el comportamiento 'Módulo': posiciones programadas a 90° y 330° y desplazamientos relativos (B300/B–300) con flechas de sentido y arcos trazados. Ilustran cómo, en G90/G91, el recorrido efectivo es inferior a una vuelta, y cómo el signo fija el sentido cuando no hay SHORTESTWAY ni UNIDIR."@es .

ns1:Esquema_ELUDOM_EVIRD a ns1:Esquema ;
