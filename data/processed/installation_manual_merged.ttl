    ns1:identificador "#DMCON" ;
    ns1:textoExtracto "comando ON para activar la función (por ejemplo, #DMCON [...])" .

ns1:Comando_DMC_ON_Default a ns1:InterfazUsuario ;
    rdfs:label "Comando DMC ON (valores por defecto)" ;
    ns1:textoExtracto "#DMC ON (El CNC activa el DMC con los valores por defecto). (El DMC inicia la fase de aprendizaje para calcular la potencia objetivo)." .

