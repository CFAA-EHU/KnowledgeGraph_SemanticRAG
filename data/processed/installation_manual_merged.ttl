ns1:Parametro_d399ad6a05 a ns1:Parametro ;
    rdfs:label "SUBPATH" ;
    ns1:identificador "SUBPATH" ;
    ns1:monitoreaParametro ns1:Maquina_8055MC,
        ns1:Maquina_8055TC ;
    ns1:textoExtracto "SUBPATH Path de las subrutinas de programa. Variable asociada: (V.)[ch].MPG.SUBPATH Este parámetro indica el directorio, por defecto, en que se encuentran las subrutinas de usuario y las subrutinas necesarias para poder ejecutar programas del 8055 MC y 8055 TC." .

ns1:Parametro_d3e3a60ab6 a ns1:Parametro ;
