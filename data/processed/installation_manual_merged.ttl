        "control del gap"@es ;
    ns1:textoExtracto "Esta marca no desactiva el control del gap, excepto en el movimiento de aproximación." .

ns1:ControlGap_1427 a ns1:ModoOperacion ;
    rdfs:label "Control de gap (GAPCTRL)"@es ;
    ns1:controla ns1:Sensor_57eef5f3fe ;
    ns1:ejecutadoPor ns1:MaquinaCNC_1427 ;
    ns1:monitoreaParametro ns1:Parametro_9306311404,
        ns1:Parametro_a52fd8378e ;
    ns1:textoExtracto """Tras activar el control de gap, el eje asociado al sensor se mueve al avance programado [...] hasta detectar la pieza con el sensor o bien hasta la cota programada (POS).\r
        El CNC considera que el bloque de aproximación ha terminado cuando el sensor alcanza el gap con la tolerancia definida en el parámetro máquina GAPTOL.\r
        Una vez detectada la pieza, el CNC mantendrá el gap definido"""@es .

ns1:ControlOverride a ns1:Alarma ;
