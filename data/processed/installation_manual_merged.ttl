        ns1:VariableTM_MZTYPE ;
    ns1:detalladoEnEsquema ns1:TablaGestionAlmacen ;
    ns1:textoExtracto "MANAGEMENT Parámetros relacionados con la gestión del almacén. Este parámetro muestra los datos para configurar la gestión del almacén."@es .

ns1:ParametrosSimuladorCNC a ns1:Parametro ;
    rdfs:label "Parámetros por defecto en modo simulador"@es ;
    ns1:documentadoEn ns1:Manual_ParametrosMaquina ;
    ns1:textoExtracto "Valor por defecto de los parámetros en un simulador. Cuando el CNC se instala como simulador en un PC, el valor por defecto de algunos parámetros máquina puede ser diferente a los aquí mencionados. Básicamente los cambios se refieren a los avances máximos de ejes, aceleraciones y jerk."@es ;
    ns1:valor "avances_máximos_ejes: modificado; aceleraciones: modificado; jerk: modificado"@es .

ns1:PasoDeRosca a ns1:Parametro ;
    rdfs:label "Paso de rosca"@es ;
    ns1:textoExtracto "el CNC respeta el paso [...] de la rosca"@es .

ns1:PasoIncrementalDeSpeedOverrideSTEPOVR_2bb1a6d930 a ns1:Parametro ;
