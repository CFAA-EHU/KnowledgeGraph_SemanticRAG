    ns1:identificador "R12" ;
    ns1:textoExtracto "CPS R12 GT 2000 = ..."@es,
        "R12"@es ;
    ns1:valor 2000,
        "2000" .

ns1:Parametro_RAPIDEN a ns1:Parametro ;
    rdfs:label "RAPIDEN",
        "Parámetro RAPIDEN"@es ;
    ns1:identificador "RAPIDEN",
        "V.[ch].MPG.RAPIDEN" ;
    ns1:monitoreaParametro ns1:Maquina_Actual ;
    ns1:textoExtracto "Avance máximo del eje para el programa en ejecución, cuando está activo el avance rápido para el modo automático (parámetro RAPIDEN).",
        "Avance máximo en el canal para el programa en ejecución, cuando está activo el avance rápido para el modo automático (parámetro RAPIDEN).",
        "El funcionamiento de esta marca depende de cómo esté definido el parámetro RAPIDEN."@es,
        "RAPIDEN Permitir habilitar el avance rápido para el modo automático. Valores posibles: Deshabilitado / EXRAPID o tecla rápido / EXRAPID y tecla rápido. Valor por defecto: Deshabilitado."@es ;
    ns1:valor "Deshabilitado",
        "EXRAPID o tecla de rápido" .

ns1:Parametro_RENAMECANCEL a ns1:Parametro ;
    rdfs:label "RENAMECANCEL" ;
    ns1:identificador "MPG.RENAMECANCEL" ;
    ns1:textoExtracto "RENAMECANCEL Cancelar el cambio de nombre de los ejes y los cabezales. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)MPG.RENAMECANCEL" ;
    ns1:valor "Sí"^^xsd:string .

ns1:Parametro_SSIALARMLEVEL a ns1:Parametro ;
    rdfs:label "SSIALARMLEVEL" ;
    ns1:identificador "(V.)[ch].MPA.SSIALARMLEVEL[set].xn",
        "SSIALARMLEVEL" ;
    ns1:textoExtracto "SSIALARMLEVEL = 1 | El acknowledge se indica con data a 0; por tanto, se produce una señal de alarma cuando el bit es un 1.",
        "SSIALARMLEVEL = 2",
        "Valor que tienen que tener los bits de alarma/acknowledge para que se produzca una condición de error. Valores posibles: De 0 a 3. Valor por defecto: 0.",
        "Valores que pueden provocar que el encoder transmita uno o más bits indicando algún tipo de error." ;
    ns1:valor "0-3",
        "1",
        "2" .

ns1:Parametro_TDATA22 a ns1:Parametro ;
    rdfs:label "TDATA22",
