ns1:Parametro_NLOCOUT a ns1:Parametro ;
    rdfs:label "NLOCOUT" ;
    ns1:identificador "MPG.NLOCOUT",
        "NLOCOUT" ;
    ns1:textoExtracto "NLOCOUT Número de salidas digitales locales. Valores posibles: De 0 a 8. Valor por defecto: 0. Variable asociada: (V.)MPG.NLOCOUT",
        "Número de salidas digitales locales. Para la conmutación sincronizada sólo se podrán utilizar las salidas locales asociadas a los pines LI/O1 (salida local 1) y LI/O2 (salida local 2), ya que están personalizadas para aplicaciones de láser. Para ello será necesario parametrizar el parámetro NLOCOUT con valor 8.",
        "Para el PWM sólo se podrán utilizar las salidas locales asociadas a los pines LI/O1 (salida local 1) y LI/O2 (salida local 2), ya que están personalizadas para aplicaciones de láser. Para ello será necesario parametrizar el parámetro NLOCOUT con valor 8." ;
    ns1:valor 8,
        "0-8",
        "8" .

ns1:Parametro_NPOINTSAX1 a ns1:Parametro ;
    rdfs:label "NPOINTSAX1",
        "Parámetro NPOINTSAX1",
        "Contador NPOINTSAX1"@es ;
    ns1:documentadoEn ns1:Esquema_MallaVolumetrica_3D,
        ns1:Tabla_VOLCOMP ;
    ns1:identificador "NPOINTSAX1" ;
    ns1:ilustradoEn ns1:EsquemaPaso3_CompensacionVolumetrica ;
    ns1:textoExtracto "El número de puntos viene definido por la expresión: NPOINTSAX1 × NPOINTSAX2 × NPOINTSAX3",
        "La segunda fila corresponde al punto 'X(P2), Y(P1), Z(P1)', la tercera al punto 'X(P3), Y(P1), Z(P1)', y así sucesivamente hasta completar todos los puntos del X (parámetro NPOINTSAX1).",
        "NPOINTSAX1=3",
        "NPOINTSAX1 [...] Número de puntos de la compensación volumétrica básica para el eje MOVAXIS. Valores posibles: De 2 a 1000 puntos. Variable asociada: (V.)MPG.NPOINTSAX1[tbl]."@es,
        "Se resaltan los contadores NPOINTSAX1 y NPOINTSAX2"@es,
        "distribución NPOINTSAX1×NPOINTSAX2×NPOINTSAX3"@es ;
    ns1:valor "(V.)MPG.NPOINTSAX1[tbl]",
        "3" .

ns1:Parametro_NPOINTSAX2 a ns1:Parametro ;
    rdfs:label "NPOINTSAX2",
        "Parámetro NPOINTSAX2",
        "Contador NPOINTSAX2"@es ;
    ns1:documentadoEn ns1:Esquema_MallaVolumetrica_3D,
        ns1:Tabla_ParametrosCompensacionVolumetrica_1123,
        ns1:Tabla_VOLCOMP ;
    ns1:identificador "NPOINTSAX2" ;
    ns1:ilustradoEn ns1:EsquemaPaso3_CompensacionVolumetrica ;
    ns1:textoExtracto "El número de puntos viene definido por la expresión: NPOINTSAX1 × NPOINTSAX2 × NPOINTSAX3",
        "NPOINTSAX2=2",
        "Repetir la misma operación para definir todos los puntos del eje X, desde el punto Y(P2) hasta el último punto del eje Y (parámetro NPOINTSAX2).",
        "NPOINTSAX2 [...] Número de puntos de la compensación volumétrica básica. Variable asociada: (V.)MPG.NPOINTSAX2[tbl]."@es,
        "Número de puntos que definen el volumen a compensar en cada eje. El número total de puntos del volumen está limitado a 15.625, y se calcula de la forma NPOINTSAX1×NPOINTSAX2×NPOINTSAX3."@es,
        "Se resaltan los contadores NPOINTSAX1 y NPOINTSAX2"@es,
        "distribución NPOINTSAX1×NPOINTSAX2×NPOINTSAX3"@es ;
    ns1:valor "(V.)MPG.NPOINTSAX2[tbl]",
        "2" .

ns1:Parametro_NPOINTSAX3 a ns1:Parametro ;
    rdfs:label "NPOINTSAX3",
        "Parámetro NPOINTSAX3" ;
    ns1:documentadoEn ns1:Esquema_MallaVolumetrica_3D,
        ns1:Tabla_ParametrosCompensacionVolumetrica_1123,
        ns1:Tabla_VOLCOMP ;
    ns1:identificador "NPOINTSAX3" ;
    ns1:textoExtracto "El número de puntos viene definido por la expresión: NPOINTSAX1 × NPOINTSAX2 × NPOINTSAX3",
        "NPOINTSAX3=2",
        "repetir la misma operación desde el punto 'X(P1), Y(P1), Z(P2)' hasta el último punto del eje Z (parámetro NPOINTSAX3).",
        "NPOINTSAX3 [...] Número de puntos de la compensación volumétrica básica. Variable asociada: (V.)MPG.NPOINTSAX3[tbl]."@es,
        "Número de puntos que definen el volumen a compensar en cada eje. El número total de puntos del volumen está limitado a 15.625, y se calcula de la forma NPOINTSAX1×NPOINTSAX2×NPOINTSAX3."@es,
        "distribución NPOINTSAX1×NPOINTSAX2×NPOINTSAX3"@es ;
    ns1:valor "(V.)MPG.NPOINTSAX3[tbl]",
        "2" .

ns1:Parametro_NPULSES a ns1:Parametro ;
    rdfs:label "NPULSES",
        "Parámetro NPULSES" ;
    ns1:documentadoEn ns1:Tabla_ParametrosBusquedaReferencia1151 ;
    ns1:identificador "NPULSES" ;
    ns1:monitoreaParametro ns1:ComponenteElectrico_Encoder,
        ns1:SistemaCNC ;
    ns1:textoExtracto "Este parámetro sólo se tiene en cuenta cuando los parámetros NPULSES y NPULSES2 se han definido con valor distinto de 0.",
        "Número de impulsos del encoder. Parámetro válido para ejes lineales, rotativos y cabezales. Valores posibles: De 0 a 1000000. Valor por defecto: 1250. Este parámetro define el número de impulsos por vuelta del encoder.",
        "Si se definen los parámetros NPULSES y NPULSES2 con valor distinto de ꞏ0ꞏ...",
        "NPULSES | Número de impulsos del encoder."@es ;
    ns1:valor 1250,
        "distinto de 0",
        "pulsos",
        "Número de impulsos del encoder"@es .

ns1:Parametro_NPULSES2 a ns1:Parametro ;
    rdfs:label "NPULSES2",
