ns1:MesaRotativaABTYPE9 a ns1:ComponenteMecanico ;
    rdfs:label "Mesa rotativa AB (TYPE=9)"@es ;
    ns1:identificador "TYPE=9" ;
    ns1:monitoreaParametro ns1:DistanciaEntreEjesRotativosTDATA5,
        ns1:PosicionDelEjeRotativoSecundarioXTDATA2,
        ns1:PosicionDelEjeRotativoSecundarioYTDATA3,
        ns1:PosicionDelEjeRotativoSecundarioZTDATA4 ;
    ns1:textoExtracto "En este ejemplo se calculan las dimensiones de una mesa rotativa AB con un rango de movimientos del eje A -90º a 90º y del eje B de 0º a -90º; parámetro TYPE con valor ꞏ9ꞏ. [...] Dimensiones a calcular en una mesa rotativa AB (TYPE=9)."@es ;
    ns1:tieneComponente ns1:EjeRotativoA,
        ns1:EjeRotativoB .

ns1:MesaRotativa_CalculoDimensiones a ns1:Sistema ;
    rdfs:label "Cálculo de dimensiones de la mesa rotativa"@es ;
    ns1:monitoreaParametro ns1:EDistanciaDesdeLaSuperficieDeLaMesaHastaElEjeB,
        ns1:FDistanciaDesdeLaSuperficieDeLaMesaHastaElEjeA,
        ns1:Parametro_0c1f628ac1,
        ns1:Parametro_6cd9cee7e4,
        ns1:Parametro_95137c6bdd ;
    ns1:textoExtracto "Segunda posición. 1 Posicionar el eje rotativo A en 0º y el eje B en -90º. 2 Realizar un movimiento de palpación en la dirección del eje Z, sobre el punto 3. Anotar la cota que aparece en el CNC, denominada en el dibujo Z1."@es ;
    ns1:tieneComponente ns1:EjeRotativo_A,
        ns1:EjeRotativo_B,
        ns1:Sensor_c580a53635 .

ns1:MicroDeReferenciaI0 a ns1:ComponenteElectrico ;
