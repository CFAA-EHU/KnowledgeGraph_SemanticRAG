ns1:MotorTandemEsclavo_1056 a ns1:ComponenteMecanico ;
    rdfs:label "Motor tándem esclavo"@es ;
    ns1:textoExtracto "El otro eje (eje tándem esclavo) no se visualiza y no es programable; es controlado por el CNC."@es .

ns1:PLC_ControlAlmacen a ns1:Actuador,
        ns1:InterfazUsuario ;
    rdfs:label "PLC de control del almacén"@es,
        "PLC de control del almacén y brazo cambiador"@es ;
    ns1:controla ns1:AlmacenHerramientas_Asincrono,
        ns1:AlmacenHerramientas_ProximoCabezal,
        ns1:BrazoCambiador_2Pinzas,
        ns1:BrazoCambiador_AlmacenAsincrono,
        ns1:DispositivoDesplazamiento_Almacen,
        ns1:DispositivoGiro_Almacen ;
    ns1:textoExtracto "La comunicación entre el gestor y el PLC se realiza en 2 fases [...] El gestor envía una orden al PLC para que seleccione la próxima herramienta en el almacén [...] El gestor envía una orden al PLC para efectuar el cambio."@es,
        "el PLC el control de los dispositivos externos. Utilizar funciones auxiliares para gobernar desde la rutina M06 los desplazamientos de los distintos dispositivos (giro almacén, desplazamiento almacén, brazo cambiador, etc.)."@es .

ns1:Parametro_AXISMODE a ns1:Parametro ;
    rdfs:label "AXISMODE",
        "Modo de eje (AXISMODE)",
        "Parámetro AXISMODE (modo de eje)"@es ;
    ns1:documentadoEn ns1:Pagina_572_ConfiguracionTandem ;
    ns1:identificador "AXISMODE",
        "V.[ch].MPA.AXISMODE.xn" ;
    ns1:textoExtracto "AXISMODE Modo de trabajo del eje rotativo. Parámetro válido para ejes rotativos. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Linearlike / Módulo. Valor por defecto: Módulo.",
        "AXISMODE | Módulo.",
        "El CNC sólo tiene en cuenta estos parámetros con AXISMODE = Módulo.",
        "parámetros AXISMODE y SHORTESTWAY iguales para ambos ejes",
        "Cuando los ejes sean rotativos, ambos ejes deberán ser del mismo tipo (parámetros AXISMODE y SHORTESTWAY iguales para ambos ejes)."@es ;
    ns1:valor "Módulo",
        "igual",
        "Módulo"@es .

ns1:Parametro_COMPONENT a ns1:Parametro ;
    rdfs:label "COMPONENT" ;
    ns1:documentadoEn ns1:Tabla_USERKEY ;
    ns1:textoExtracto "Acceder a uno de los componentes del CNC. Valores posibles: Diagnosis / PLC / Parámetros máquina / DDSSETUP / TUNING" .

ns1:Parametro_FFGAIN a ns1:Parametro ;
    rdfs:label "FFGAIN",
        "FFGAIN (Porcentaje de feed forward en automático)",
        "Ganancia de feed-forward (FFGAIN)",
        "Parámetro FFGAIN",
        "FFGAIN"@es ;
    ns1:identificador "(V.)[ch].MPA.FFGAIN[set].xn",
        "FFGAIN" ;
    ns1:monitoreaParametro ns1:Sensor_ErrorSeguimiento,
        ns1:Sistema_CNC,
        ns1:Sistema_ControlAvance ;
    ns1:textoExtracto "Cuanto menor sea el valor asignado a estos parámetros, la respuesta de la máquina será más suave",
        "El parámetro FFGAIN [...] define la parte de la consigna (analog output) que es proporcional al avance programado (programmed feedrate).",
        "FFGAIN Porcentaje de feed forward en automático. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 120 %. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.FFGAIN[set].xn",
        "Un eje que vaya a trabajar como eje independiente debería tener definido el mismo feed forward en los modos automáticos y manual; es decir, los parámetros FFGAIN y MANFFGAIN deberían ser iguales.",
        "Variable asociada: (V.)[ch].MPA.FFGAIN[set].xn. El CNC sólo tiene en cuenta este parámetro cuando trabaja con feed forward; parámetro FFWTYPE si regulador analógico o simulado y parámetro OPMODEP si regulador Sercos.",
        "bloque \"FFGAIN\"",
        "feed forward (parámetro FFGAIN)",
        "valores de FFGAIN cercanos al 100%",
        "Programmed FFGAIN Feedrate"@es,
        "• FFGAIN = 90 %."@es ;
    ns1:valor "0",
        "90 %",
        "FFGAIN" .

ns1:Parametro_INCJOGDIST a ns1:Parametro ;
    rdfs:label "INCJOGDIST",
        "INCJOGDIST (Tabla de desplazamientos en jog incremental)",
        "Distancia incremental de jog (INCJOGDIST)"@es ;
    ns1:documentadoEn ns1:Tabla_MANUAL ;
    ns1:identificador "INCJOGDIST",
        "MPA.INCJOGDIST" ;
    ns1:textoExtracto "Tabla de desplazamientos en jog incremental. Este parámetro muestra la tabla para definir los desplazamientos del eje en cada posición del conmutador de jog. La tabla consta de cinco parámetros, uno para cada posición del conmutador del panel de mando: INCJOGDIST1 (ꞏ1ꞏ), INCJOGDIST2 (ꞏ10ꞏ), INCJOGDIST3 (ꞏ100ꞏ), INCJOGDIST4 (ꞏ1000ꞏ), INCJOGDIST5 (ꞏ10000ꞏ).",
        "Distancia a recorrer en jog incremental."@es,
        "Variable asociada: (V.)[ch].MPA.INCJOGDIST[pos].xn. En cada parámetro hay que definir la distancia que se desplaza el eje cada vez que se pulsa la tecla de jog."@es ;
    ns1:valor "Rango 1: 0.0001 a 99999.9999 mm / Rango 2: 0.0000 a 3937.00787 inch / Rango 3: 0.0001 a 99999.9999 grados"@es .

ns1:Parametro_LEAVEPOS a ns1:Parametro ;
    rdfs:label "Dirección de posicionamiento (LEAVEPOS)",
        "LEAVEPOS",
        "Parámetro LEAVEPOS (Posición de depósito de herramienta)",
        "Parámetro LEAVEPOS (posición para dejar herramienta en almacén)",
        "LEAVEPOS"@es,
        "Parámetro LEAVEPOS"@es,
        "Posición de tierra (LEAVEPOS)"@es,
        "Registro LEAVEPOS"@es,
        "Registro LEAVEPOS (posición de almacenamiento de herramienta)"@es,
        "Registro LEAVEPOS (posición de depósito de herramienta)"@es ;
