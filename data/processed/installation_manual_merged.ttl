    ns1:identificador "SBS R CNC-PLC" ;
    ns1:textoExtracto "SBS R CNC-PLC R CNC-PLC R CNC-PLC" .

ns1:Instruccion_SET a ns1:AccionProhibida ;
    rdfs:label "Instrucción SET" ;
    ns1:identificador "SET" ;
    ns1:textoExtracto "Si expresión \"1\" asigna \"1\" al recurso. Si el resultado obtenido en la evaluación de la expresión lógica es un \"1\", asigna un \"1\" al recurso especificado. Si el resultado es un \"0\", no modifica el recurso." .

ns1:Instruccion_SUB a ns1:ModoOperacion ;
    rdfs:label "SUB (Definición de subrutina)" ;
