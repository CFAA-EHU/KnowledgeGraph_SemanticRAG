    ns1:documentadoEn ns1:Tabla_ParametrosBusquedaReferencia1151 ;
    ns1:identificador "NPULSES2" ;
    ns1:monitoreaParametro ns1:Componente_SensorEncoderCaptacionExterna,
        ns1:SistemaCNC ;
    ns1:textoExtracto "Este parámetro sólo se tiene en cuenta cuando los parámetros NPULSES y NPULSES2 se han definido con valor distinto de 0.",
        "Número de impulsos del encoder (captación externa). Parámetro válido para ejes lineales, rotativos y cabezales. Valores posibles: De 0 a 1000000. Valor por defecto: 1250. Este parámetro define el número de impulsos por vuelta del encoder para la segunda captación.",
        "Si se definen los parámetros NPULSES y NPULSES2 con valor distinto de ꞏ0ꞏ...",
        "NPULSES2 | Número de impulsos del encoder (captación externa)."@es ;
    ns1:valor 1250,
        "distinto de 0",
