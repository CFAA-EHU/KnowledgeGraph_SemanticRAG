    ns1:documentadoEn ns1:Pagina_564_1041 ;
    ns1:textoExtracto "G17: Plano X-Y. Eje perpendicular Z. G18: Plano Z-X. Eje perpendicular Y. G19: Plano Y-Z. Eje perpendicular X. G20: Cualquier plano y/o eje longitudinal."@es .

ns1:Tabla_Planos_1043 a ns1:Tabla ;
    rdfs:label "Tabla de selección de planos (G17/G18/G19)"@es ;
    ns1:documentadoEn ns1:Pagina_565 ;
    ns1:ilustradoEn ns1:ConfiguracionEjes_1043 ;
    ns1:textoExtracto "Orden lógico. • CHSPDLNAME 1 • S • Cabezal con índice •1•. Número lógico •4•. Selección de planos en el canal •1•."@es .

ns1:Tabla_RecomendacionesSERPOWSE_PlacaI a ns1:Tabla ;
