ns1:ConfiguracionTandem_1062 a ns1:Sistema ;
    rdfs:label "Configuración del eje tándem"@es ;
    ns1:controla ns1:Parametro_DistribucionPar_1062 ;
    ns1:textoExtracto "Consideraciones para cabezales tándem. [...] La distribución del par establece el porcentaje de par que realiza cada motor para conseguir el par total necesario en el tándem."@es ;
