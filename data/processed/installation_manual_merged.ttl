ns1:Instruccion_RES a ns1:AccionProhibida ;
    rdfs:label "Instrucción RES" ;
    ns1:identificador "RES" ;
    ns1:textoExtracto "Si expresión \"1\" asigna \"0\" al recurso. Si el resultado obtenido en la evaluación de la expresión lógica es un \"1\", asigna un \"0\" al recurso especificado. Si el resultado es un \"0\", no modifica el recurso." .

ns1:Instruccion_RET a ns1:AccionProhibida ;
    rdfs:label "Instrucción RET (retorno de subrutina)"@es,
        "RET (Retorno o final de subrutina)"@es ;
    ns1:identificador "RET" ;
    ns1:solucionaFallo ns1:Subrutina_RupturaSecuencia_443 ;
    ns1:textoExtracto "= RET Retorno o final de subrutina."@es,
        "RET Retorno o final de subrutina. Si el resultado obtenido en la evaluación de la expresión lógica es un '1' esta acción será tratada por el PLC como la proposición directiva END. Si el resultado es '0', será ignorada por el PLC."@es .

ns1:Instruccion_RL2 a ns1:AccionProhibida ;
    rdfs:label "Rotación a izquierdas tipo 2 (RL2)" ;
    ns1:controla ns1:Registro_R101,
        ns1:Registro_R102 ;
    ns1:identificador "RL2" ;
    ns1:textoExtracto "RL2 R102 4 R101 Realiza cuatro rotaciones a izquierdas tipo 2 de R102 dejando el resultado en R101." .

ns1:Instruccion_RR1 a ns1:AccionProhibida ;
    rdfs:label "Rotación a derechas tipo 1 (RR1)" ;
    ns1:controla ns1:Registro_R100,
        ns1:Registro_R200 ;
    ns1:identificador "RR1" ;
    ns1:textoExtracto "RR1 R100 1 R200 Realiza una rotación a derechas tipo 1 de R100 dejando el resultado en R200." .

ns1:Instruccion_SBS_R_CNC_PLC a ns1:AccionProhibida ;
