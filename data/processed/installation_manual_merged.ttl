    ns1:monitoreaParametro ns1:ComponenteMecanico_6e7533677c ;
    ns1:textoExtracto "Apuntar la cota que aparece en el CNC (Xb)." .

ns1:Parametro_36e5c6b3d6 a ns1:Parametro ;
    ns1:documentadoEn ns1:TablaDeSubrutinasOEMYDeUsuarioPaginas635636 ;
    ns1:identificador "FINALSUB" ;
    ns1:textoExtracto "Nombre: Parámetro general FINALSUB. Canales: Subrutina por canal." .

ns1:Parametro_37383338e6 a ns1:Parametro ;
    rdfs:label "NEXT" ;
    ns1:identificador "NEXT" ;
    ns1:textoExtracto "El eje alcanza la posición indicada al avance especificado en el siguiente bloque." .

ns1:Parametro_375ee86d45 a ns1:Parametro ;
    rdfs:label "BACKLASH" ;
    ns1:documentadoEn ns1:TablaParametrosCNC ;
    ns1:identificador "PP58" ;
    ns1:textoExtracto "BACKLASH | PP58 | Posición." ;
    ns1:valor "Posición" .

ns1:Parametro_378a1f4013 a ns1:Parametro ;
    rdfs:label "FEEDBACKTYPE" ;
    ns1:identificador "MPA.FEEDBACKTYPE[set].xn" ;
    ns1:monitoreaParametro ns1:Modulo_RCS_S ;
    ns1:textoExtracto "FEEDBACKTYPE Tipo de captación del módulo RCS-S. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos velocidad. Valores posibles (1): Entradas locales; TTL / TTL diferencial / Vpp / SSI. Valores posibles (2): Contadora Sercos; TTL / TTL diferencial / Vpp / SSI / FeeDat / EnDat. Valor por defecto: TTL diferencial." ;
    ns1:valor "TTL diferencial"^^xsd:string .

ns1:Parametro_37bb4f09b3 a ns1:Parametro ;
    rdfs:label "Marca ENABLE(axis)" ;
    ns1:identificador "ENABLE(axis)" ;
    ns1:textoExtracto "Si se trata de un volante individual, asociado a un eje, la marca ENABLE(axis) del eje permanecerá activa." .

ns1:Parametro_3821bf9028 a ns1:Parametro ;
    rdfs:label "Parámetro MPG.MAXROUND"@es ;
    ns1:identificador "MPG.MAXROUND" ;
    ns1:monitoreaParametro ns1:ROUNDTYPEErrorCordal ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.MAXROUND. Este parámetro define la desviación máxima permitida entre el punto programado y el perfil resultante del matado de arista. El CNC lo tiene en cuenta con ROUNDTYPE = Error cordal. Este parámetro también define el error de contorno máximo permitido para el modo HSC cuando no se programa CONTERROR (modo CONTERROR) ni E (modo FAST)."@es ;
    ns1:valor "0.00394 inch"@es .

ns1:Parametro_384c3b5bc7 a ns1:Parametro ;
    rdfs:label "TCHANGEOK",
        "TCHANGEOK"@es ;
    ns1:documentadoEn ns1:Tabla_MarcasComunicacionPLC_Gestor ;
    ns1:identificador "TCHANGEOK" ;
    ns1:textoExtracto "activar la marca TCHANGEOK, indicando al gestor que puede continuar la ejecución." .

ns1:Parametro_3905aa558c a ns1:Parametro ;
    rdfs:label "Marca MANRAPIDC1 (MANRAPID)" ;
    ns1:identificador "MANRAPIDC1" ;
    ns1:monitoreaParametro ns1:ModoAvance_Rapido ;
    ns1:textoExtracto "MANRAPIDC1 (también se puede programar como MANRAPID). Si el PLC activa esta marca, el CNC selecciona el avance rápido para los movimientos en jog continuo que se realicen desde el modo manual." .

ns1:Parametro_390eab7cc5 a ns1:Parametro ;
    rdfs:label "Parámetro I0CODDI2" ;
    ns1:identificador "V.[ch].MPA.I0CODDI2[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.I0CODDI2[set].xn. Valor por defecto: 1001." ;
    ns1:valor "1001" .

ns1:Parametro_39ab8ef07a a ns1:Parametro ;
    rdfs:label "FREQUENCY" ;
    ns1:documentadoEn ns1:Tabla_FILTER ;
    ns1:identificador "(V.)[ch].MPA.FREQUENCY[nb].xn" ;
    ns1:textoExtracto "Frecuencia de corte o central. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 500.0 Hz. Valor por defecto: 30.0 Hz." ;
    ns1:valor "30.0" .

ns1:Parametro_3a5b5c0c23 a ns1:Parametro ;
    rdfs:label "FEEDAVRG"@es ;
    ns1:documentadoEn ns1:TablaDeParametrosDeConfiguracionHSCPaginas621622 ;
    ns1:identificador "FEEDAVRG MPG" ;
    ns1:textoExtracto "Este parámetro habilita el ajuste del avance en función de la velocidad de lectura de bloques y del tamaño de los mismos. Este ajuste evita tener que frenar por un suministro inadecuado de bloques pequeños; aunque como consecuencia de ello la velocidad alcanzada sea menor, el tiempo total de mecanizado mejorará."@es .

ns1:Parametro_3a9c9a8c4c a ns1:Parametro ;
    rdfs:label "PROBETYPE1" ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionPalpador ;
    ns1:identificador "PROBETYPE1" ;
    ns1:textoExtracto "Tipo de palpador 1."@es .

ns1:Parametro_3aab288217 a ns1:Parametro ;
    rdfs:label "ΔZ1",
        "ΔZ2" ;
    ns1:documentadoEn ns1:Tabla_17_3_1 ;
    ns1:textoExtracto "ΔZ1, ΔZ2 [...] Cotas que indica el CNC." .

ns1:Parametro_3ad2f75ec2 a ns1:Parametro ;
    rdfs:label "wintype"@es ;
    ns1:documentadoEn ns1:TablaDeParametrosDeLatcheoSeccion4410 ;
    ns1:textoExtracto "Tipo de ventana para el latcheo. Se programa mediante los comandos DISABLE (sin ventana), EXCLUSIVE (latch fuera de la ventana) e INCLUSIVE (latch dentro de la ventana)."@es .

ns1:Parametro_3b80c23c00 a ns1:Parametro ;
    rdfs:label "IMOVE" ;
    ns1:identificador "IMOVE" ;
    ns1:textoExtracto "Parámetro IMOVE; tipo de movimiento (G0/G1) en el arranque, tras un reset o M30. El valor IMOVE=G0 tiene prioridad sobre G0MODAL=No." ;
    ns1:valor "G0/G1" .

ns1:Parametro_3cc0d1f482 a ns1:Parametro ;
    rdfs:label "FLIMITACCHC4" ;
    ns1:identificador "FLIMITACCHC4" ;
    ns1:textoExtracto "FLIMITACCHC4" .

ns1:Parametro_3cd1256ec5 a ns1:Parametro ;
    rdfs:label "PEAKDISP" ;
    ns1:textoExtracto "El parámetro PEAKDISP define la distancia real recorrida por el eje, después de la inversión de movimiento teórica, a la que el CNC corta el pico de inversión en dicho eje (impulso adicional de consigna). [ rev/min]"@es ;
    ns1:valor "distancia real recorrida por el eje tras inversión de movimiento [rev/min]" .

ns1:Parametro_3d2cc23383 a ns1:Parametro ;
    rdfs:label "MAXFLWE" ;
    ns1:textoExtracto "El parámetro MAXFLWE indica a partir de qué valor del error de seguimiento comienza la supervisión dinámica." ;
    ns1:valor "valor_umbral_error_seguimiento" .

ns1:Parametro_3e7c643602 a ns1:Parametro ;
    rdfs:label "FEEDAVRG" ;
    ns1:identificador "(V.)[ch].MPG.FEEDAVRG" ;
    ns1:textoExtracto "FEEDAVRG Calcular el promedio del avance. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)[ch].MPG.FEEDAVRG Este parámetro habilita el ajuste del avance en función de la velocidad de lectura de bloques y del tamaño de los mismos." ;
    ns1:valor "Sí" .

ns1:Parametro_3e9717ada3 a ns1:Parametro ;
    rdfs:label "TDATA15" ;
    ns1:documentadoEn ns1:TablaDeEquivalenciaEntreParametrosDeCinematicaTipo50YTipo4_df21b027cb ;
    ns1:textoExtracto "| TDATA15 | 1 |"@es ;
