    rdfs:label "Primer nodo RIO5 (bloque de 24 entradas desde I1)"@es ;
    ns1:textoExtracto "El primer nodo RIO5 como un bloque de 24 entradas a partir de la I1."@es .

ns1:NodoRIO5_1264 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo RIO5 (módulo físico = bloque lógico)" ;
    ns1:identificador "RIO5" ;
    ns1:textoExtracto "En los nodos RIO5 y RIOR, cada módulo es un bloque lógico, no se permite agrupar varios módulos en un bloque ni dividir un módulo en bloques. Los bloques lógicos deben coincidir en número y dimensión con los módulos detectados físicamente en el bus."^^xsd:string .

ns1:NodoRIO5_2 a ns1:ComponenteElectrico ;
    rdfs:label "Segundo nodo RIO5 (tres bloques de 24 entradas desde I49, I73, I97)"@es ;
    ns1:textoExtracto "El segundo nodo RIO5 como tres bloques de 24 entradas a partir de la I49, I73 e I97."@es .

ns1:NodoRIO5_3 a ns1:ComponenteElectrico ;
    rdfs:label "Tercer nodo RIO5 (dos bloques de 24 entradas desde I257, I129)"@es ;
    ns1:textoExtracto "El tercer nodo RIO5 como dos bloques de 24 entradas a partir de la I257 e I129."@es .

ns1:NodoRIOR_1264 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo RIOR (módulo físico = bloque lógico)" ;
    ns1:identificador "RIOR" ;
    ns1:textoExtracto "En los nodos RIO5 y RIOR, cada módulo es un bloque lógico, no se permite agrupar varios módulos en un bloque ni dividir un módulo en bloques."^^xsd:string .

ns1:NodoRIOW_1264 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo RIOW (bloques lógicos virtualizables)" ;
    ns1:identificador "RIOW" ;
    ns1:textoExtracto "En los nodos RIOW y de terceros, se permite virtualizar los bloques lógicos que se desee, tanto en número como en dimensión."^^xsd:string .

ns1:NodoTerceros_1264 a ns1:ComponenteElectrico ;
    rdfs:label "Nodo de terceros (bloques lógicos virtualizables)" ;
    ns1:identificador "Terceros" ;
    ns1:textoExtracto "En los nodos RIOW y de terceros, se permite virtualizar los bloques lógicos que se desee, tanto en número como en dimensión."^^xsd:string .

ns1:Normativa_DIN66217 a ns1:Directiva ;
    rdfs:label "Norma DIN 66217" ;
    ns1:identificador "DIN 66217" ;
    ns1:textoExtracto "Sentido de giro del eje giratorio. Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217)." .

ns1:OEM_Fagor a ns1:Empresa ;
    rdfs:label "Fagor (OEM)"@es ;
    ns1:textoExtracto "Es responsabilidad del OEM garantizar que la subrutina cumple todos los aspectos de seguridad relativos al manejo del láser."@es .

ns1:OP_PANEL_329 a ns1:InterfazUsuario ;
    rdfs:label "Panel OP-PANEL-329 (selector circular, pulsadores de jog en columna)"@es ;
    ns1:ilustradoEn ns1:DiagramaTemporal_PLC_Se_alesEjes ;
    ns1:textoExtracto "Fotografía del panel OP-PANEL-329 mostrando un layout compacto: selector circular, pulsadores de jog en columna y teclas de usuario en bloque. La imagen ilustra la codificación por bits de las teclas (user y jog) que se consultan en KEYBD1/2/3 y variantes por panel."@es .

ns1:OP_PANEL_TecladoUsuario a ns1:InterfazUsuario ;
    rdfs:label "Panel OP-PANEL con teclado de usuario y bloque de teclas de jog"@es ;
    ns1:ilustradoEn ns1:DiagramaTemporal_PLC_Se_alesEjes ;
    ns1:textoExtracto "Fotografía del panel OP-PANEL con teclado de usuario y bloque de teclas de jog. Se distinguen pulsadores iluminables, con agrupación jerárquica por funciones (usuario, jog, husillo, start/stop) y distribución matricial que el texto asocia a bits KEYBD1/2/3."@es .

ns1:OpcionOverlapped_1368_C a ns1:Componente ;
    rdfs:label "Validación de la opción 'Overlapped'"@es ;
    ns1:textoExtracto "C. Validación de la opción \"Overlapped\"."@es .

