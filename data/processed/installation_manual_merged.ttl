ns1:Funcion_G74 a ns1:ModoOperacion,
        ns1:Parametro,
        ns1:Tabla ;
    rdfs:label "Función G74",
        "G74",
        "Función G74 (búsqueda de referencia máquina)"@es,
        "Función G74 (búsqueda de referencia)"@es ;
    ns1:documentadoEn ns1:Tabla_Subrutinas_FuncionesM_G74_G180_189 ;
    ns1:habilitadoPor ns1:SistemaCNC ;
    ns1:identificador "G74" ;
    ns1:solucionaFallo ns1:PerdidaPosicionCNC ;
    ns1:textoExtracto "Cuando se programa una nueva búsqueda de referencia con la función G74, desde el programa o modo MDI/MDA.",
        "El CNC arranca sin gama, y nada más arrancar el CNC ejecuta una [...] G74.",
        "Subrutina asociada a la función G74.",
        "Búsqueda de referencia por programa o MDI, mediante la función G74."@es,
        "La función G74 (búsqueda de referencia máquina) se puede programar de 2 formas; indicando los ejes y el orden en el que se referencia los ejes o programando sólo G74 (sin ejes)."@es .

