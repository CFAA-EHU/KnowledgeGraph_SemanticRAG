ns1:Contador_Generico a ns1:ComponenteElectrico ;
    rdfs:label "Contador genérico (C1, C25, C102, etc.)",
        "Contador (genérico)"@es ;
    ns1:monitoreaParametro ns1:Parametro_CuentaInterna,
        ns1:Parametro_EstadoLogicoContador,
        ns1:Parametro_ValorCuentaContador ;
    ns1:textoExtracto "(C) Salida de estado. Indica el estado lógico del contador. Se referencia mediante la letra C seguida del número de contador que se desea referenciar, por ejemplo C1, C25, C102, etc.",
        "Todos los contadores disponen de la salida estado C y de las entradas CUP, CDW, CEN y CPR. También es posible consultar en cualquier momento el valor de su cuenta interna. La cuenta de un contador se almacena en una variable de 32 bits, por lo que su valor puede estar comprendido entre ±2147483647."@es ;
    ns1:tieneComponente ns1:Entrada_CDW,
        ns1:Entrada_CEN,
        ns1:Entrada_CPR,
        ns1:Entrada_CUP,
        ns1:Salida_Estado_C .

