    ns1:activaAlarma ns1:MarcaSPDLTOMZ ;
    ns1:textoExtracto "TMOPERATION = 2 Dejar la herramienta del cabezal en el almacén. LEAVEPOS=# Posición del almacén para dejar la herramienta." .

ns1:OperacionDejarHerramientaEnTierra a ns1:TareaMantenimiento ;
