    rdfs:label "velocidad"@es ;
    ns1:monitoreaParametro ns1:EditorLevasElectronicas_692 ;
    ns1:textoExtracto "edición de valores de velocidad"@es .

ns1:Parametro_20feef9b4a a ns1:Parametro ;
    rdfs:label "BIDIR" ;
    ns1:textoExtracto "El parámetro NEGERROR sólo se muestra si se ha definido la tabla con compensación bidireccional (BIDIR = Sí)." .

