ns1:ModuloEntradasDigitales_RIOW a ns1:ComponenteElectrico ;
    rdfs:label "Módulo de 64 entradas digitales (RIOW)" ;
    ns1:textoExtracto "Grupo remoto RIOW con 64 entradas digitales." ;
    ns1:valor 64 .

ns1:ModuloHardware_JOG_PANEL a ns1:ComponenteElectrico ;
