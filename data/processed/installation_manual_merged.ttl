    ns1:textoExtracto "los movimientos en jog serán en G94 (avance por minuto)."@es ;
    ns1:valor "G94" .

ns1:Parametro_GANTRY a ns1:Parametro ;
    rdfs:label "Configuración de ejes gantry (GANTRY)" ;
    ns1:identificador "GANTRY" ;
    ns1:textoExtracto "GANTRY n Configuración de los ejes gantry. Este parámetro muestra la tabla de parámetros para definir los ejes gantry del sistema" .

ns1:Parametro_GANTRY_DIFFCOMP a ns1:Parametro ;
    rdfs:label "DIFFCOMP" ;
    ns1:textoExtracto "Compensar la diferencia de cota entre ambos ejes tras G74." ;
    ns1:valor "Compensación de diferencia de cota entre ejes" .

ns1:Parametro_GANTRY_MAXCOUPE a ns1:Parametro ;
    rdfs:label "MAXCOUPE" ;
    ns1:textoExtracto "Diferencia entre el error de seguimiento de ambos ejes para mostrar un warning." ;
    ns1:valor "Diferencia entre el error de seguimiento de ambos ejes" .

ns1:Parametro_GANTRY_MAXDIFF a ns1:Parametro ;
    rdfs:label "MAXDIFF" ;
    ns1:textoExtracto "Máxima diferencia de cota permitida entre ambos ejes para poder compensarla." ;
    ns1:valor "Máxima diferencia de cota permitida" .

ns1:Parametro_GAPANAINID a ns1:Parametro ;
    rdfs:label "GAPANAINID" ;
    ns1:identificador "MPG.GAPANAINID" ;
    ns1:textoExtracto "GAPANAINID Número de entrada analógica conectada al sensor. Valores posibles (1): Si GAPANAINTYPE=Remoto CAN, de 1 a 60. Valores posibles (2): Si GAPANAINTYPE=Regulador, de 101 a 132 o de 201 a 232. Valores posibles (3): Si GAPANAINTYPE=Captación, número de nodo del regulador. Valores posibles (4): Si GAPANAINTYPE=EtherCAT, de 1 a 1024. Valor por defecto: Ninguna (no hay control del gap). Variable asociada: (V.)MPG.GAPANAINID" ;
    ns1:valor "1-60 (Remoto CAN), 101-132/201-232 (Regulador), 1-1024 (EtherCAT), nodo (Captación)" .

ns1:Parametro_GAPCTRL a ns1:Parametro ;
    rdfs:label "#GAPCTRL" ;
    ns1:monitoreaParametro ns1:Sistema_CNC ;
    ns1:textoExtracto "Para programar la cota de aproximación en coordenadas incrementales, añadir el comando \"INC\" a la sentencia #GAPCTRL." ;
    ns1:valor "INC" .

ns1:Parametro_GAPSENSORFILTER a ns1:Parametro ;
    rdfs:label "GAPSENSORFILTER",
        "GAPSENSORFILTER"@es ;
    ns1:identificador "GAPSENSORFILTER" ;
    ns1:textoExtracto "Filtro paso bajo; se recomienda definir un filtro de orden 2 y frecuencia de corte de 30 Hz.",
        "Tabla para configurar el filtro del sensor. Este parámetro muestra la tabla para configurar el filtro del sensor.",
        "filtro paso bajo (ORDER/FREQUENCY)"@es .

ns1:Parametro_GAPSENSOROFFSET a ns1:Parametro ;
