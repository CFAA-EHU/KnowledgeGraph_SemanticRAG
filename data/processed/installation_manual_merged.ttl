        ns1:Subrutina_SPD_TO_CH1,
        ns1:Subrutina_SPD_TO_CH2,
        ns1:Subrutina_SPD_TO_GR,
        ns1:Subrutina_SPD_TO_MZ,
        ns1:Subrutina_SUB_ARM_BACK,
        ns1:Subrutina_SUB_ARM_TO_CHG,
        ns1:Subrutina_SUB_ARM_TO_MZ,
        ns1:Subrutina_SUB_CH1_TO_SPD,
        ns1:Subrutina_SUB_CH2_TO_MZ,
        ns1:Subrutina_SUB_GR_TO_SPD,
        ns1:Subrutina_SUB_MZ_TO_CH1,
        ns1:Subrutina_SUB_SPD_AUTCHG,
        ns1:Subrutina_SUB_SPD_GMCHG,
        ns1:Subrutina_SUB_SPD_TO_CH2,
        ns1:Subrutina_SUB_SPD_TO_GR,
        ns1:TareaMantenimiento_CambioHerramientaAutomatico_Caso1,
        ns1:TareaMantenimiento_CambioHerramientaCombinado_Caso5,
        ns1:TareaMantenimiento_ColocacionHerramientaTierra_Caso3,
        ns1:TareaMantenimiento_DevolucionHerramientaAutomatica_Caso2,
        ns1:TareaMantenimiento_DevolucionHerramientaTierra_Caso4 ;
    ns1:controla ns1:BrazoCambiador,
        ns1:Cabezal,
        ns1:PLC_AlmacenTorreta,
        ns1:Pinza1 ;
    ns1:ejecutadoPor ns1:Cabezal,
        ns1:GestorCNC,
        ns1:Pinza1,
        ns1:Pinza2,
        ns1:ProgramaPLC_CambioHerramienta ;
    ns1:habilitadoPor ns1:FuncionAuxiliarM101,
        ns1:FuncionAuxiliarM102,
        ns1:FuncionAuxiliarM103 ;
    ns1:identificador "M06" ;
    ns1:ilustradoEn ns1:MensajeOperario_ExtraerHerramienta,
        ns1:MensajeOperario_InsertarHerramienta ;
    ns1:monitoreaParametro ns1:CondicionMZWAIT,
        ns1:MarcaTCHANGEOK,
        ns1:ParametroV_PLC_TMOPERATION,
        ns1:ParametroV_S_EXECUTION ;
    ns1:requiereEPI ns1:HerramientaTierra ;
    ns1:requiereMantenimiento ns1:HerramientaT_D,
        ns1:HerramientaTierra,
        ns1:Pinza1,
        ns1:SistemaCambioHerramienta,
        ns1:SubrutinaMZ_TO_SPD,
        ns1:SubrutinaSPD_AUTCHG,
        ns1:SubrutinaSUB_GR_TO_SPD,
        ns1:SubrutinaSUB_M6,
        ns1:SubrutinaSUB_MZ_TO_SPD,
        ns1:SubrutinaSUB_SPD_AUTCHG,
        ns1:SubrutinaSUB_SPD_GMCHG,
        ns1:SubrutinaSUB_SPD_TO_GR,
        ns1:SubrutinaSUB_SPD_TO_MZ ;
    ns1:textoExtracto """\r
%L SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1.\r
%L SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal.\r
%L SUB_SPD_TO_CH2 ; Coger la herramienta del cabezal con la pinza 2.\r
%L SUB_CH2_TO_MZ ; Comenzar el envío del brazo cambiador al almacén para dejar la herramienta de la pinza 2.\r
%L SUB_SPD_TO_GR ; Quitar la herramienta del cabezal (llevarla a tierra).\r
%L SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal.""",
        """\r
%L SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1.\r
%L SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal.\r
%L SUB_SPD_TO_CH2 ; Coger la herramienta del cabezal con la pinza 2.\r
%L SUB_CH2_TO_MZ ; Llevar la herramienta de la pinza 2 al almacén.\r
%L SUB_SPD_TO_GR ; Quitar la herramienta del cabezal (llevarla a tierra).\r
%L SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal.""",
        "$SWITCH V.PLC.TMOPERATION; Analiza el tipo de operación.",
        "Cada vez que la rutina M06 finaliza una acción se lo indica al PLC para que active la marca correspondiente del gestor.",
        "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático. LL SUB_SPD_TO_CH1 ; Coger la herramienta del cabezal con la pinza 1. [...] LL SUB_CH1_TO_MZ ; Dejar la herramienta de la pinza 1 en el almacén.",
        "La rutina M06 utiliza las siguientes funciones auxiliares M para indicar al PLC qué movimientos debe realizar.",
        "MSG [\"Insertar herramienta T%D y pulsar MARCHA\", V.TM.NXTOOL] ; Mensaje al operario para que ponga la herramienta. [...] M6 ; Orden al gestor para comenzar el cambio de herramienta.",
        "WAIT FOR [V.PLC.M[1107]==0] #RET %L SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal. [...] # RET %L SUB_ARM_TO_MZ ; Llevar el brazo cambiador al almacén. M122 ; Función auxiliar para ejecutar acción.",
        "cambio manual. LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal. [...] # RET",
        """\r
    %L SUB_MZ_ROT V.PLC.M[1111]=1 #WAIT FOR [V.PLC.M[1111]==0]; Marca MZROT al gestor.\r
    %L SUB_SPD_TO_GR ; Quitar la herramienta del cabezal (llevarla a tierra).\r
    %L SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal.\r
    %L SUB_MZ_TO_SPD ; Coger la herramienta del almacén y ponerla en el cabezal.\r
    %L SUB_SPD_TO_MZ ; Dejar la herramienta del cabezal en el almacén.\r
    """@es,
        """\r
    %L SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1.\r
    %L SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal.\r
    %L SUB_SPD_TO_CH1 ; Coger la herramienta del cabezal con la pinza 1.\r
    %L SUB_CH1_TO_MZ ; Llevar la herramienta de la pinza 1 al almacén.\r
    %L SUB_SPD_TO_GR ; Quitar la herramienta del cabezal (llevarla a tierra).\r
    %L SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal."""@es,
        """\r
    %SUB_M6.nc\r
    #ESBLK ; Activar tratamiento de bloque único\r
    M6 ; Orden al gestor para comenzar el cambio de herramienta.\r
    """@es,
        """\r
$SWITCH V.PLC.TMOPERATION; Analiza el tipo de operación.\r
$CASE 1 ; Coger una herramienta del almacén y ponerla en el cabezal.\r
$CASE 2 ; Dejar la herramienta del cabezal en el almacén.\r
$CASE 3 ; Colocar la herramienta de tierra en el cabezal.\r
$CASE 4 ; Dejar la herramienta del cabezal en tierra.\r
$CASE 5 ; Dejar la herramienta del cabezal en el almacén, y coger otra del almacén."""@es,
        """\r
LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático.\r
LL SUB_SPD_TO_CH2 ; Coger la herramienta del cabezal con la pinza 2.\r
LL SUB_CH2_TO_MZ ; Dejar la herramienta de la pinza 2 en el almacén.\r
$BREAK $CASE 10 ; Coger una herramienta del almacén y dejarla en tierra pasando por el cabezal.\r
LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático.\r
LL SUB_MZ_TO_CH1 ; Coger la herramienta del almacén con la pinza 1.\r
LL SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal.\r
LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual.\r
LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal.\r
$BREAK $ENDSWITCH ; Fin análisis del tipo de operación.\r
$WHILE V.TM.MZWAIT == 1 $ENDWHILE ; Espera al gestor del almacén.\r
"""@es,
        """\r
LL SUB_SPD_TO_CH2 ; Coger la herramienta del cabezal con la pinza 2.\r
LL SUB_ARM_BACK ; Retirar el brazo cambiador.\r
LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual.\r
LL SUB_GR_TO_SPD ; Colocar la herramienta de tierra en el cabezal.\r
LL SUB_CH2_TO_MZ ; Comenzar el envío del brazo cambiador al almacén para dejar la herramienta.\r
$CASE 7 ; Dejar la herramienta del cabezal en tierra, y coger otra del almacén.\r
; Previamente, durante el mecanizado (al ejecutar T), se pone la herramienta del almacén en la pinza 1."""@es,
        "$BREAK $CASE 2 ; Dejar la herramienta del cabezal en el almacén... $BREAK $CASE 3 ; Colocar la herramienta de tierra en el cabezal."@es,
        "%L SUB_SPD_TO_GR ; Quitar la herramienta del cabezal (llevarla a tierra). [...] M6 ; Orden al gestor para comenzar el cambio de herramienta."@es,
        "1 ; Coger una herramienta del almacén y ponerla en el cabezal... $CASE 7 ; Dejar la herramienta del cabezal en tierra, y coger otra del almacén."@es,
        "Dentro de dicha rutina hay que programar la función M06 para que el CNC indique al gestor que debe comenzar el cambio de herramienta. [...] Se aconseja incluir la gestión del cambio de herramienta en la rutina asociada a M06."@es,
        "LL SUB_ARM_BACK ; Retirar el brazo cambiador. LL SUB_CH2_TO_MZ ; Comenzar el envío del brazo cambiador al almacén para dejar la herramienta. [...] LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual."@es,
        "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático. [...] $ENDIF"@es,
        "LL SUB_SPD_AUTCHG ; Llevar el cabezal al punto de cambio automático. [...] LL SUB_CH2_TO_MZ ; Dejar la herramienta de la pinza 2 en el almacén."@es,
        "M6 ; Orden al gestor para comenzar el cambio de herramienta."@es,
        "Programar la rutina asociada a la herramienta y a la función M06."@es,
        "cambio manual. LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal. [...] # RET"@es,
        "punto de cambio. LL SUB_CH1_TO_SPD ; Llevar la herramienta de la pinza 1 al cabezal. LL SUB_ARM_BACK ; Retirar el brazo cambiador. LL SUB_SPD_GMCHG ; Llevar el cabezal al punto de cambio manual. LL SUB_SPD_TO_GR ; Quitar la herramienta del cabezal."@es ;
    ns1:tieneComponente ns1:AlmacenHerramientas,
        ns1:Cabezal,
        ns1:FuncionM101,
        ns1:FuncionM102,
        ns1:FuncionM104,
        ns1:FuncionM106,
        ns1:FuncionM121,
        ns1:FuncionM122,
        ns1:FuncionM123,
        ns1:Pinza1,
        ns1:Pinza2,
        ns1:PuntoCambioAutomatico,
        ns1:PuntoCambioManual ;
    ns1:tieneFrecuencia ns1:RutinaM06_EjecucionReal,
        ns1:RutinaM06_EjecucionSimulada .

ns1:Tabla_OperacionesGestorHerramientas a ns1:Tabla ;
    rdfs:label "Tabla de operaciones válidas del gestor de herramientas"@es,
        "Tabla de operaciones válidas del gestor de herramientas (TMOPERATION)"@es ;
    ns1:documentadoEn ns1:Pagina_493_494 ;
    ns1:identificador "TMOPERATION" ;
    ns1:ilustradoEn ns1:Pagina_481,
        ns1:Pagina_484_485,
        ns1:Pagina_503_504 ;
    ns1:textoExtracto """\r
    Operaciones válidas del gestor de herramientas para este almacén. Las operaciones posibles en este tipo de almacén son las siguientes.\r
    | TMOPERATION | Significado. |\r
    | --- | --- |\r
    | 0 | No hay que hacer nada.\r
    | 1 | Coger una herramienta del brazo y ponerla en el cabezal.\r
    ...\r
    | 16 | Dejar la herramienta del brazo (pinza ꞏ2ꞏ) en el almacén."""@es,
        "Operaciones válidas del gestor de herramientas para este almacén. Las operaciones posibles en este tipo de almacén son las siguientes."@es,
        "Operaciones válidas del gestor de herramientas para este almacén. Las operaciones posibles en este tipo de almacén son las siguientes. | TMOPERATION | Significado. |"@es,
        "Operaciones válidas del gestor de herramientas para este almacén. Las operaciones posibles en este tipo de almacén son las siguientes. | TMOPERATION | Significado. | --- | --- | 0 | No hay que hacer nada. | 3 | Poner en el cabezal una herramienta de tierra. | 4 | Dejar la herramienta del cabezal en tierra. | 8 | Dejar la herramienta del cabezal en tierra y coger una herramienta de tierra."@es,
        "Operaciones válidas del gestor de herramientas para este almacén. Las operaciones posibles en este tipo de almacén son las siguientes. | TMOPERATION | Significado. | [...] | 14 | Dejar la herramienta del cabezal en el almacén y coger una herramienta de otro almacén."@es .

