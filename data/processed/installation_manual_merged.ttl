ns1:Parametro_00588f2873 a ns1:Parametro ;
    rdfs:label "MAXLOCP" ;
    ns1:identificador "MAXLOCP" ;
    ns1:textoExtracto "MAXLOCP Parámetro aritmético local máximo. Valores posibles: De 0 a 99. Valor por defecto: 25. Variable asociada: (V.)MPG.MAXLOCP" ;
    ns1:valor "25" .

ns1:Parametro_009d5c5bd3 a ns1:Parametro ;
    rdfs:label "PEAKDISP" ;
    ns1:textoExtracto "PEAKDISP: Distancia de corte del pico de holgura. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos. Valores posibles: De 0 a 99999.9999 mm / 0 a 3937.00787 inch / 0 a 99999.9999 grados." ;
    ns1:valor "0-99999.9999 mm, 0-3937.00787 inch, 0-99999.9999°" .

ns1:Parametro_0132277a06 a ns1:Parametro ;
    rdfs:label "CIRINERR" ;
    ns1:textoExtracto "El parámetro CIRINERR indica el error absoluto máximo permitido." ;
    ns1:valor "error_absoluto_máximo" .

ns1:Parametro_024081cd8c a ns1:Parametro ;
    rdfs:label "SMOOTHFREQ" ;
    ns1:textoExtracto "aplicar la frecuencia de suavizado en la interpolación de la trayectoria (parámetro SMOOTHFREQ)" ;
    ns1:valor "frecuencia de suavizado" .

ns1:Parametro_02ce58d7de a ns1:Parametro ;
    rdfs:label "MAXMANFEED" ;
    ns1:textoExtracto "MAXMANFEED: 120 mm/min" ;
    ns1:valor "120 mm/min" .

ns1:Parametro_02f4d4564c a ns1:Parametro ;
    rdfs:label "Parámetro S (velocidad de giro)"@es ;
    ns1:textoExtracto "La función auxiliar S indica la velocidad de giro del cabezal con M03 y M04"@es ;
    ns1:valor "SFUN1 (registro 32 bits)"@es .

ns1:Parametro_031bad53e6 a ns1:Parametro ;
    rdfs:label "OVRMIN" ;
    ns1:identificador "OVRMIN" ;
    ns1:textoExtracto "#DMC ON [<OVRMIN value>..." .

ns1:Parametro_048995059b a ns1:Parametro ;
    rdfs:label "DIMOD" ;
    ns1:identificador "DIMOD" ;
    ns1:textoExtracto "DIMOD n Índice base de los módulos de entradas digitales. Valores posibles: De 0 a 1009. Valor por defecto: El primer valor válido. Variable asociada: (V.)MPG.DIMODADDR[nb]" ;
    ns1:valor 1 .

ns1:Parametro_0489f8b8e3 a ns1:Parametro ;
    rdfs:label "MODUPLIM"@es ;
    ns1:textoExtracto "Los parámetros máquina MODUPLIM [...] establecen los límites del módulo del eje"@es ;
    ns1:valor "Límite superior del módulo"@es .

ns1:Parametro_048fd1ef38 a ns1:Parametro ;
    rdfs:label "SERVOOFF" ;
    ns1:identificador "SERVOOFF" ;
    ns1:textoExtracto "SERVOOFF Compensación del offset. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico. Valores posibles: Entre ±32767. Valor por defecto: 0. Variable asociada: (V.)[ch].MPA.SERVOOFF[set].xn Consigna que se aplica como offset al regulador. La consigna se expresa en unidades del conversor D/A, admitiendo cualquier número entero entre ±32767, correspondiendo para el valor ±32767 la consigna de ±10 V." ;
    ns1:valor "-32767 a 32767" .

ns1:Parametro_04a151789a a ns1:Parametro ;
    rdfs:label "Función G95 (avance por vuelta)"@es ;
    ns1:textoExtracto "Se permite la función G95 (avance por vuelta) para los movimientos en jog desde el modo manual. [...] No se permite la función G95 (avance por vuelta) para los movimientos en jog desde el modo manual."@es ;
    ns1:valor "G95" .

ns1:Parametro_0520e02adf a ns1:Parametro ;
    rdfs:label "NEGERROR" ;
    ns1:textoExtracto "Para cada uno de los puntos se deben definir los parámetros POSITION, POSERROR y NEGERROR. El parámetro NEGERROR sólo se muestra si se ha definido la tabla con compensación bidireccional (BIDIR = Sí)." .

ns1:Parametro_05674bdd90 a ns1:Parametro ;
    rdfs:label "Parámetro PITCH2 (regulador Sercos)" ;
    ns1:identificador "MPA.PITCH2[set].xn" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPA.PITCH2[set].xn. El significado de este parámetro depende del tipo captación. • En un eje lineal con encoder y husillo, el parámetro define el paso de husillo. • En un eje lineal con transductor lineal (regla), el parámetro define el paso de la regla. • En un eje rotativo, el parámetro define el número de grados por vuelta de encoder." ;
    ns1:valor "5 mm / 0.19685 inch / 360º"^^xsd:string .

ns1:Parametro_056de254f8 a ns1:Parametro ;
    rdfs:label "Acción al ejecutar una M06 sin T seleccionada"@es ;
    ns1:textoExtracto "M6ALONE Acción al ejecutar una M06 sin T seleccionada."@es .

ns1:Parametro_059c080e25 a ns1:Parametro ;
    rdfs:label "Marca M1101 (MZTOCH1: almacén → pinza 1)"@es ;
    ns1:documentadoEn ns1:TablaMarcasM06 ;
