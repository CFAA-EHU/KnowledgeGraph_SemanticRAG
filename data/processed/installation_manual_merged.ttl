ns1:CeroM_quina a ns1:ComponenteMecanico ;
    rdfs:label "Cero máquina"@es ;
    ns1:textoExtracto "El cero máquina es el origen del sistema de referencia de la máquina, fijado por el fabricante de la máquina."@es .

ns1:CilindroReferencia_17_2 a ns1:Consumible ;
    rdfs:label "Cilindro de diámetro conocido para calibración"@es ;
    ns1:textoExtracto "un cilindro de diámetro conocido colocado en el cabezal"@es .

ns1:CodigoValidacion_Administrador a ns1:Parametro ;
    rdfs:label "Código de validación para acceso administrador"@es ;
    ns1:identificador "código de validación" ;
    ns1:textoExtracto "El acceso al modo administrador se habilita con el código de validación."@es .

ns1:ComandoCNCWR a ns1:AccionProhibida ;
    rdfs:label "Comando CNCWR"@es ;
    ns1:identificador "CNCWR" ;
    ns1:requiereMantenimiento [ a ns1:TareaMantenimiento ;
            rdfs:label "Retardo de seguridad entre códigos de tecla"@es ;
            ns1:textoExtracto "se recomienda utilizar un retardo de al menos 200 ms entre el envío de ambos códigos (por seguridad)."@es ;
            ns1:tieneFrecuencia [ a ns1:Frecuencia ;
                    rdfs:label "200 ms"@es ;
                    ns1:textoExtracto "retardo de al menos 200 ms"@es ;
                    ns1:valor "200" ] ] ;
    ns1:textoExtracto "El comando CNCWR escribe en la variable el valor del registro R101. [...] { condición} = CNCWR(R101,G.KEY,M101)"@es .

ns1:Comando_CAM_SELECT a ns1:InterfazUsuario,
        ns1:ModoOperacion ;
    rdfs:label "CAM SELECT",
        "CAM SELECT"@es ;
    ns1:controla ns1:LevaElectronica_Archivo ;
    ns1:identificador "CAM SELECT",
        "CAM SELECT (cam, file)"@es ;
    ns1:textoExtracto "Seleccionar (CAM SELECT) o anular una leva de archivo",
        "El formato de programación para cada uno de ellos es el siguiente. CAM SELECT (cam, file)"@es .

ns1:Comando_CNCRD a ns1:InterfazUsuario,
        ns1:Parametro ;
    rdfs:label "CNCRD",
        "Comando CNCRD"@es,
        "Comando CNCRD (lectura de variables síncronas)"@es ;
    ns1:identificador "CNCRD" ;
    ns1:monitoreaParametro ns1:MarcaComunicacion_CNCRD,
        ns1:Parametro_R12,
        ns1:Variable_GKEY ;
    ns1:textoExtracto "En la lectura mediante CNCRD de las variables de los parámetros aritméticos y de fabricante se devuelve el valor multiplicado por 10000 (lectura en modo float).",
        "<condición> = CNCRD (G.FREAL, R12, M12) CPS R12 GT 2000 = ... no hace falta esperar para consultar los datos porque las variables síncronas se resuelven inmediatamente."@es,
        "El comando CNCRD guarda el código de la tecla en el registro R100. [...] { condición} = CNCRD(G.KEY,R100,M100)"@es .

ns1:Comando_CNCWR a ns1:InterfazUsuario ;
    rdfs:label "CNCWR",
        "Comando CNCWR (escritura de variables síncronas)"@es ;
    ns1:controla ns1:Parametro_PLC_TIMER ;
    ns1:monitoreaParametro ns1:MarcaComunicacion_CNCWR,
        ns1:Parametro_R13 ;
    ns1:textoExtracto "CNCWR carga el contenido del registro en la variable. La marca se pone a \"1\" cuando comienza la operación y se mantiene a dicho valor hasta que finaliza la misma.",
        "<condición> = CNCWR (R13, PLC.TIMER, M13) Inicializa el reloj habilitado por el PLC con el valor que contiene el registro R13."@es .

ns1:Comando_DMCOFF a ns1:InterfazUsuario ;
    rdfs:label "Comando #DMC OFF (desactivación DMC)" ;
    ns1:identificador "#DMC OFF" ;
    ns1:textoExtracto "comando OFF para anularla (por ejemplo, #DMC OFF)" .

