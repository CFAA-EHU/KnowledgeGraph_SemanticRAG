    rdfs:label "Modo de referencia codificado decreciente"@es ;
    ns1:documentadoEn ns1:Tabla_ModosReferenciaEncoder ;
    ns1:textoExtracto "La codificación de I0 será decreciente si la distancia entre las marcas de I0 disminuye según el sentido de movimiento, durante la búsqueda de referencia." .

ns1:ModoReferencia_Normal a ns1:ModoOperacion ;
    rdfs:label "Modo de referencia normal"@es ;
    ns1:documentadoEn ns1:Tabla_ModosReferenciaEncoder ;
    ns1:textoExtracto "El encóder puede tener una o varias marcas de I0, pero sólo hay una marca seleccionada (por ejemplo, con un micro (home-switch)). El encóder referencia la posición con esta marca de I0. En función de la posición inicial, pueden ser necesarios largos recorridos hasta referenciar la posición." .

ns1:ModoRetardoConexion_TG2 a ns1:ModoOperacion ;
    rdfs:label "Modo retardo a la conexión (entrada TG2)"@es ;
    ns1:monitoreaParametro ns1:TiempoTranscurridoT ;
    ns1:textoExtracto "Este modo de funcionamiento permite realizar un retardo entre la activación de la entrada de arranque TG2 y la activación de la salida de estado T del temporizador. La duración del retardo la fija la constante de tiempo."@es ;
    ns1:tieneComponente ns1:ConstanteDeTiempo_f3f28bc44e,
        ns1:Entrada_TG2,
        ns1:Parametro_786b2eb120,
        ns1:Parametro_eac9a4ae87,
        ns1:Salida_T .

ns1:ModoRetardoDesconexion_TG3 a ns1:ModoOperacion ;
    rdfs:label "Modo retardo a la desconexión (entrada TG3)"@es ;
    ns1:controla ns1:Temporizador_T ;
    ns1:textoExtracto "Este modo de funcionamiento permite realizar un retardo entre la desactivación de la entrada de arranque TG3 y la desactivación de la salida T del temporizador. La duración del retardo, está determinada por la constante de tiempo."@es ;
    ns1:tieneComponente ns1:ConstanteDeTiempo,
        ns1:Entrada_TG3,
        ns1:Parametro_786b2eb120,
        ns1:Parametro_eac9a4ae87,
        ns1:Salida_T .

ns1:ModoSETUP_CNC a ns1:ModoOperacion ;
    rdfs:label "Modo SETUP (puesta a punto, CNC)"@es ;
    ns1:habilitadoPor ns1:SubrutinasFabricante ;
    ns1:textoExtracto "Con el CNC en modo SETUP (puesta a punto), las rutinas OEM cuya extensión sea .fst se cargarán en la memoria RAM la primera vez que se ejecutan dentro del programa."@es .

ns1:ModoSimulador a ns1:ModoOperacion ;
    rdfs:label "Modo simulador" ;
    ns1:textoExtracto "su funcionamiento queda restringido a modo simulador y no se podrá conectar a ningún tipo de máquina." .

ns1:ModoSincrono a ns1:ModoOperacion ;
    rdfs:label "Modo síncrono"@es ;
    ns1:textoExtracto "Modificar el FFGAIN en el regulador (PP216) en modo síncrono."@es .

ns1:ModoTelediagnosis a ns1:ModoOperacion ;
    rdfs:label "Telediagnosis" ;
    ns1:textoExtracto "Puede ser necesaria su utilización cuando se trabaja con telediagnosis (control remoto de CNC)." .

ns1:ModoUSER_CNC a ns1:ModoOperacion ;
    rdfs:label "Modo USER (CNC)"@es ;
    ns1:habilitadoPor ns1:SubrutinasFabricante ;
    ns1:textoExtracto "Con el CNC en modo USER, las rutinas OEM cuya extensión sea .fst, se cargan en la memoria RAM en el arranque de la aplicación CNC."@es .

ns1:ModoUser a ns1:ModoOperacion ;
    rdfs:label "Modo User"@es ;
    ns1:textoExtracto """\r
Modo User. Las variables sólo pueden escribir los parámetros con permiso de escritura. Los nuevos valores se mantienen tras reiniciar o apagar el CNC."""@es .

ns1:Modo_CONTERROR a ns1:ModoOperacion ;
    rdfs:label "Modo CONTERROR" ;
    ns1:habilitadoPor ns1:Variable_LIMERROR ;
    ns1:textoExtracto "modo CONTERROR" .

ns1:Modo_Diagnosis a ns1:ModoOperacion ;
    rdfs:label "Modo diagnosis"@es ;
    ns1:textoExtracto "En el modo diagnosis se pueden consultar las opciones de software disponibles en el CNC."@es .

ns1:Modo_MDI_MDA a ns1:ModoOperacion ;
    rdfs:label "Modo MDI/MDA"@es ;
    ns1:habilitadoPor ns1:Variable_G.ANAI,
        ns1:Variable_G.ANAO ;
    ns1:textoExtracto "Las variables son accesibles desde el programa pieza y desde el modo MDI/MDA."@es .

ns1:ModosAcceso_CNC8070 a ns1:ModoOperacion ;
    rdfs:label "Modos de acceso del CNC8070"@es ;
    ns1:documentadoEn ns1:Manual_CNC8070_ModosTrabajo ;
    ns1:textoExtracto "El disco está preconfigurado con tres modos de acceso, cada uno de los cuales ofrece un nivel de protección diferente."@es .

ns1:Modulo1_0b1799e9f9 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo 1" ;
    ns1:textoExtracto "la vista de árbol se expande para facilitar la detección y el panel derecho lista módulos con iconografía por tipo." ;
