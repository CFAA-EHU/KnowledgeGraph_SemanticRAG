    ns1:textoExtracto "Entradas analógicas en tensión (V). | Décimas de milivoltio." ;
    ns1:valor "décimas de milivoltio" .

ns1:Parametro_EntradaCorriente_mA a ns1:Parametro ;
    rdfs:label "Entradas analógicas en corriente (mA)"@es ;
