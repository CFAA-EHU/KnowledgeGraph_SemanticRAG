ns1:Parametro_PIERCING a ns1:Parametro ;
    rdfs:label "Parámetro PIERCING",
        "PIERCING"@es ;
    ns1:documentadoEn ns1:Tabla_SubrutinasControlNumerico ;
    ns1:identificador "(V.)[ch].MPG.PIERCING",
        "PIERCING" ;
    ns1:textoExtracto "Variable asociada: (V.)[ch].MPG.PIERCING. Este parámetro indica el nombre de la subrutina asociada a la sentencia #PIERCING. Cada vez que el CNC ejecuta esta sentencia, efectúa una llamada a la subrutina asociada (por defecto, Piercing.fst).",
        "Nombre: Parámetro general PIERCING. Canales: Subrutina por canal."@es ;
    ns1:valor "Cualquier texto de hasta 64 caracteres" .

ns1:Parametro_PIERCING_Marca a ns1:Parametro ;
    rdfs:label "Marca PIERCING (estado de operación)" ;
    ns1:identificador "PIERCING" ;
    ns1:textoExtracto "Al comienzo de la subrutina (o cuando el OEM lo considere necesario), el OEM debe activar la marca PIERCING (asignarle valor 1) para indicar al PLC que empieza la operación de piercing. Al final de la subrutina (o cuando el OEM lo considere necesario), el OEM debe desactivar esta marca (asignarle valor 0) para indicar al CNC que ha finalizado la operación de piercing." ;
    ns1:valor "0 o 1" .

ns1:Parametro_PITCH_Encoder8192 a ns1:Parametro ;
    rdfs:label "PITCH (Husillo 10mm)" ;
    ns1:identificador "10mm" ;
    ns1:textoExtracto "Para el caso de un encoder de 8192 pulsos por vuelta y un husillo de paso 10 mm. PITCH = 10 mm." ;
    ns1:valor "10" .

ns1:Parametro_PITCH_Inductosyn2Grad a ns1:Parametro ;
