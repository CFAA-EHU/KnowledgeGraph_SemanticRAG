    ns1:textoExtracto "$IF [V.PLC.PROBE1MONIT==0] #MSG[\"PROBE NOT IN SAFE MODE\"] $ENDIF" .

ns1:ItActivatesPROBE2InSAFEMode a ns1:Parametro ;
