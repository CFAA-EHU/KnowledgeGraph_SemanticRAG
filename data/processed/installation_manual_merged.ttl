        ns1:Tabla_PlanosTrabajo_234 ;
    ns1:identificador "G17" ;
    ns1:textoExtracto "G17: No cambia de plano y muestra un warning avisando de ello." ;
    ns1:valor "X-Y" .

ns1:Parametro_d86b77943f a ns1:Parametro ;
    rdfs:label "Marca CNCOFF" ;
    ns1:identificador "CNCOFF" ;
    ns1:textoExtracto "CNCOFF: Si el PLC pone esta marca a (=1) comienza la secuencia de apagado del CNC. Activar esta marca es equivalente a pulsar la combinación de teclas [ALT][F4]." .

ns1:Parametro_d897b90078 a ns1:Parametro ;
    rdfs:label "PRELOAD" ;
    ns1:monitoreaParametro ns1:SistemaTandem ;
    ns1:textoExtracto "La precarga se define con el parámetro PRELOAD, el cual indica qué porcentaje del par nominal del motor maestro se aplicará como precarga." .

ns1:Parametro_d9236f2275 a ns1:Parametro ;
    rdfs:label "Parámetro OVRMAX (override máximo)",
        "Parámetro OVRMIN (override mínimo)" ;
    ns1:textoExtracto "El override mínimo (OVRMIN) debe ser menor que el override máximo (OVRMAX)." ;
    ns1:valor "OVRMAX",
        "OVRMIN" .

ns1:Parametro_d9d7d0d677 a ns1:Parametro ;
    rdfs:label "SSIALARMBITS" ;
    ns1:textoExtracto "SSIALARMBITS = 1" ;
    ns1:valor 2 .

ns1:Parametro_daa89ab534 a ns1:Parametro ;
    rdfs:label "LCOMPTYP" ;
    ns1:identificador "LCOMPTYP" ;
    ns1:textoExtracto "LCOMPTYP Mantener el eje longitudinal al cambiar plano (G17/G18/G19). Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)[ch].MPG.LCOMPTYPE" ;
    ns1:valor "No"^^xsd:string .

ns1:Parametro_db4e226835 a ns1:Parametro ;
