ns1:Sistema_ContadoresYEjes_1261 a ns1:Sistema ;
    rdfs:label "Sistema de contadoras Sercos y ejes"@es ;
    ns1:compuestoPor ns1:ContadoraSercos_Nodo3,
        ns1:ContadoraSercos_Nodo5,
        ns1:ReguladorSercosAXD_Nodo1,
        ns1:ReguladorSercosAXD_Nodo2,
        ns1:ReguladorSercosAXD_Nodo4 ;
    ns1:textoExtracto "El sistema dispone de 2 contadoras Sercos (nodos 3, 5) y de 3 reguladores Sercos AXD (nodos 1, 2, 4). Además, el sistema se compone de los siguientes ejes. • 3 ejes analógicos X Y Z. • 1 eje semisercos U. • 1 eje Sercos V. • 1 volante. • 1 cabezal Sercos S."@es ;
    ns1:tieneComponente ns1:CabezalSercos_S,
        ns1:EjeAnalogico_X,
        ns1:EjeAnalogico_Y,
        ns1:EjeAnalogico_Z,
        ns1:EjeSemisercos_U,
        ns1:EjeSercos_V,
        ns1:Volante_1 .

