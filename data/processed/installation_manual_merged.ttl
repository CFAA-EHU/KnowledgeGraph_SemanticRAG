ns1:ModoOperacion_G0 a ns1:ModoOperacion ;
    rdfs:label "G0",
        "Movimiento en G0",
        "Movimientos en G0",
        "Modo de operación G0 (movimientos rápidos)"@es,
        "Movimientos en G0"@es ;
    ns1:documentadoEn ns1:Tabla_413_G0ACDCJERK,
        ns1:Tabla_G0ACDCJERK ;
    ns1:identificador "G0" ;
    ns1:monitoreaParametro ns1:Parametro_ACCJERK,
        ns1:Parametro_ACCJERKG0,
        ns1:Parametro_DECJERK,
        ns1:Parametro_DECJERKG0,
        ns1:Parametro_LACC1G0,
        ns1:Parametro_LACC2G0,
        ns1:Parametro_LFEEDG0 ;
    ns1:textoExtracto "El CNC aplica los parámetros LACC1G0 y LACC2G0 a los movimientos en G0.",
        "El CNC asume la función G0. Los desplazamientos en G0 se realizan al avance rápido definido en el parámetro G00FEED. El CNC visualiza G0 en la historia de funciones G. Al acceder al modo MDI/MDA y programar un movimiento sin G, el CNC lo ejecuta en G0. Al programar un movimiento desde el modo manual, el eje se mueve en G0.",
        "movimientos en G0",
        "Los movimientos en G0 utilizan los parámetros ACCELG0 y DECELG0... Los parámetros ACCJERKG0 y DECJERKG0 definen la pendiente de la aceleración y deceleración."@es,
        "Los movimientos en G0 utilizan los parámetros ACCJERKG0 y DECJERKG0. [...] Los movimientos en G0 utilizan los parámetros ACCJERK y DECJERK."@es .

