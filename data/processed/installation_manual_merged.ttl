ns1:Parametro_V_ch_TM_MZMODE a ns1:Parametro ;
    rdfs:label "Modo de funcionamiento del gestor (V.[ch].TM.MZMODE)" ;
    ns1:textoExtracto "V.[ch].TM.MZMODE Modo de funcionamiento del gestor. Con valor ꞏ0ꞏ Modo normal (por defecto y tras reset). Con valor ꞏ1ꞏ Modo carga de almacén. Con valor ꞏ2ꞏ Modo descarga de almacén." ;
    ns1:valor "0,1,2" .

ns1:Parametro_V_ch_TM_MZRUN a ns1:Parametro ;
    rdfs:label "Gestor de herramientas en funcionamiento (V.[ch].TM.MZRUN)" ;
    ns1:textoExtracto "V.[ch].TM.MZRUN Gestor de herramientas en funcionamiento. Con valor ꞏ0ꞏ No hay ninguna secuencia en ejecución. Con valor ꞏ1ꞏ Indica que hay una secuencia en ejecución." ;
    ns1:valor "0,1" .

ns1:Parametro_V_ch_TM_MZSTATUS a ns1:Parametro ;
    rdfs:label "Estado del gestor de herramientas (V.[ch].TM.MZSTATUS)" ;
    ns1:textoExtracto "V.[ch].TM.MZSTATUS Estado del gestor de herramientas. Con valor ꞏ0ꞏ Funcionamiento normal. Con valor ꞏ1ꞏ Se ha producido un error. Con valor ꞏ2ꞏ Se ha producido un error pero se espera a que finalice la maniobra en marcha. Con valor ꞏ4ꞏ Emergencia." ;
    ns1:valor "0,1,2,4" .

ns1:Parametro_V_ch_TM_MZWAIT a ns1:Parametro ;
    rdfs:label "Gestor procesando una maniobra (V.[ch].TM.MZWAIT)" ;
    ns1:textoExtracto "V.[ch].TM.MZWAIT Gestor procesando una maniobra. Indica si hay que esperar porque hay una maniobra en marcha. Con valor ꞏ0ꞏ No hay que esperar. Con valor ꞏ1ꞏ Hay que esperar." ;
    ns1:valor "0,1" .

