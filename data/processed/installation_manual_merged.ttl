ns1:Parametro_REFINI a ns1:Parametro ;
    rdfs:label "Parámetro REFINI",
        "REFINI" ;
    ns1:documentadoEn ns1:Tabla_ParametrosBusquedaReferencia1151 ;
    ns1:identificador "MPA.REFINI.xn",
        "REFINI" ;
    ns1:monitoreaParametro ns1:SistemaCNC ;
    ns1:textoExtracto "El parámetro REFINI establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento.",
        "REFINI Búsqueda de cero en el primer movimiento. Parámetro válido para cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: Sí / No. Valor por defecto: Sí. Variable asociada: (V.)[ch].MPA.REFINI.xn Este parámetro establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento.",
        "el parámetro REFINI establece si el CNC hace una búsqueda de referencia del cabezal con su primer movimiento.",
        "REFINI | Búsqueda de cero en el primer movimiento."@es ;
    ns1:valor "Sí/No",
        "Búsqueda de cero en el primer movimiento"@es .

ns1:Parametro_REFNEED a ns1:Parametro ;
    rdfs:label "REFNEED",
        "REFNEED"@es ;
    ns1:identificador "MPG.REFNEED[tbl]",
        "REFNEED" ;
    ns1:textoExtracto "REFNEED Búsqueda de cero necesaria. [...] Valores posibles: Sí / No. Valor por defecto: No.",
        "REFNEED Búsqueda de referencia necesaria para compensar. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPG.REFNEED[tbl] Parámetro incluido en la tabla CROSSCOMP. Este parámetro indica si es necesario referenciar ambos ejes para empezar a aplicar la compensación."@es ;
    ns1:valor "Sí/No"^^xsd:string,
        "No"@es .

ns1:Parametro_RETRACTTHREAD a ns1:Parametro ;
    rdfs:label "RETRACTTHREAD" ;
    ns1:documentadoEn ns1:Sistema_Se_alesConsultaCNC ;
    ns1:identificador "RETRACTTHREAD",
        "V.[ch].MPG.RETRACTTHREAD" ;
    ns1:textoExtracto "La retirada de ejes se habilita en el parámetro RETRACTTHREAD, y se aplica al roscado electrónico (G33/G34) y los ciclos fijos de roscado del modelo -T-.",
        "RETRACTTHREAD Habilitar la retirada de herramienta en los roscados. Valores posibles: ON / OFF. Valor por defecto: ON." ;
    ns1:valor "ON"^^xsd:string .

ns1:Parametro_REVEHYST a ns1:Parametro ;
    rdfs:label "REVEHYST",
        "Histéresis de inversión (REVEHYST)"@es ;
    ns1:identificador "REVEHYST" ;
    ns1:monitoreaParametro ns1:Parametro_PEAKDISP,
        ns1:Sistema_CompensacionHolgura ;
    ns1:textoExtracto "Histéresis para aplicar el impulso adicional de consigna en las inversiones de movimiento. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico y Sercos. Valores posibles (1): De 0 a 99999.9999 mm. Valores posibles (2): De 0 a 3937.00787 inch. Valores posibles (3): De 0 a 99999.9999 grados. Valor por defecto: 0.",
        "Si REVEHYST= 0.0005 mm, el CNC no activará la compensación en las inversiones posteriores a la primera mientras la posición del eje no varíe al menos el valor definido en este parámetro",
        "diagrama temporal 'Posición' frente a 't' que ilustra la histéresis REVEHYST en inversiones de movimiento. [...] La curva de posición incluye pequeñas oscilaciones; sobre ella se superponen tramos sombreados etiquetados REVEHYST a ambos lados del cero, indicando la banda de histéresis que debe superarse para aplicar/cancelar el impulso adicional de consigna."@es,
        "valor REVEHYST distinto de 0 [...] REVEHYST= 0.0005 mm"@es ;
    ns1:valor 0.0,
        "0.0005",
        "0.0005 mm" .

ns1:Parametro_RecursosSistema_CNC8070 a ns1:Parametro ;
    rdfs:label "Recursos del sistema (CPU, memoria, disco)"@es ;
    ns1:textoExtracto "compruebe que el CNC cumple con los requisitos que requiere el software, tanto en **CPU como en memoria** [...] verifique el **espacio libre en el disco**"@es .

ns1:Parametro_SERCOUNTID a ns1:Parametro ;
