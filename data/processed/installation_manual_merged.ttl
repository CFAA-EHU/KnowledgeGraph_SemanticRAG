ns1:Senal_XFERINH a ns1:ComponenteElectrico ;
    rdfs:label "Señal _XFERINH" ;
    ns1:textoExtracto "Hay una marca para cada canal. Los mnemónicos para _XFERINH..." .

ns1:SenalesLogicasCNC a ns1:Sistema ;
    rdfs:label "Señales lógicas del CNC" ;
    ns1:compuestoPor ns1:SenalAUXEND,
        ns1:SenalCNCREADY,
        ns1:SenalMANUAL,
        ns1:Senal_ALARM,
        ns1:Senal_EMERGEN,
        ns1:Senal_STOP ;
    ns1:textoExtracto "El CNC dispone además de una serie de entradas y salidas lógicas para el intercambio de información interna con las marcas y registros del PLC. Cada una de estas entradas y salidas lógicas puede referenciarse mediante su mnemónico asociado." .

ns1:SensorCaptacionExterna a ns1:Sensor ;
    rdfs:label "Sensor de captación externa" ;
    ns1:textoExtracto "captación externa (captación directa)" .

ns1:SensorCaptacionInterna a ns1:Sensor ;
    rdfs:label "Sensor de captación interna (captación motor)" ;
    ns1:textoExtracto "captación interna (captación motor)" .

ns1:SensorFeedback_1093_A1 a ns1:Sensor ;
    rdfs:label "Sensor de feedback directo para Eje A1"@es ;
    ns1:monitoreaParametro ns1:ParametroVelocidad_1093_A1 ;
    ns1:textoExtracto "Eje A1: La captación externa (directa) está conectada a los módulos remotos."@es .

ns1:SensorFeedback_1093_A2 a ns1:Sensor ;
    rdfs:label "Sensor de feedback directo para Eje A2"@es ;
    ns1:monitoreaParametro ns1:ParametroVelocidad_1093_A2 ;
    ns1:textoExtracto "Eje A2: La captación externa (directa) está conectada a los módulos remotos."@es .

ns1:SensorGapLaser a ns1:Sensor ;
    rdfs:label "Sensor de control del gap láser" ;
    ns1:monitoreaParametro ns1:ParametroGap ;
    ns1:textoExtracto "un sensor conectado al CNC, de manera que éste compensará las variaciones del sensor sobre la distancia programada con movimientos adicionales en el eje longitudinal." .

ns1:SensorGap_1292 a ns1:Sensor ;
    rdfs:label "Sensor del gap"@es ;
    ns1:monitoreaParametro ns1:Parametro_GAPANAINID_1292,
        ns1:Parametro_GAPANAINTYPE_1292,
        ns1:Parametro_GAPDISTLIMIT_1292,
        ns1:Parametro_GAPSENSORCH_1292,
        ns1:Parametro_GAPSENSOROFFSET_1292,
        ns1:Parametro_GAPVOLTLIMIT_1292 ;
    ns1:textoExtracto "Configurar la entrada analógica a la que está conectado el sensor."@es .

ns1:SensorPT100_5 a ns1:Sensor ;
    rdfs:label "Sensor PT100 (entrada 5)" ;
    ns1:identificador "5" ;
    ns1:monitoreaParametro ns1:ParametroTemperatura_5 ;
    ns1:textoExtracto "PT100 1 = 5" .

ns1:SensorPT100_6 a ns1:Sensor ;
    rdfs:label "Sensor PT100 (entrada 6)" ;
    ns1:identificador "6" ;
    ns1:monitoreaParametro ns1:ParametroTemperatura_6 ;
    ns1:textoExtracto "PT100 2 = 6" .

ns1:SensorPT100_9 a ns1:Sensor ;
    rdfs:label "Sensor PT100 (entrada 9)" ;
    ns1:identificador "9" ;
    ns1:monitoreaParametro ns1:ParametroTemperatura_9 ;
    ns1:textoExtracto "PT100 3 = 9" .

ns1:SensorPresenciaEje a ns1:Sensor ;
    rdfs:label "Sensor de presencia de eje"@es ;
    ns1:monitoreaParametro ns1:SenalPARKED ;
    ns1:textoExtracto "Tras comprobar que el eje se ha aparcado (sensores de presencia) el PLC pone la marca PARKED a (=1) [...] Tras comprobar que el eje se ha desaparcado (sensores de presencia) el PLC pone la marca PARKED a (=0)"@es .

ns1:Sensor_AUXEND a ns1:Sensor ;
    rdfs:label "AUXEND" ;
    ns1:identificador "AUXEND" ;
    ns1:ilustradoEn ns1:Figura_DiagramaTemporalNoSincronizado,
        ns1:Figura_DiagramaTemporalSincronizado ;
    ns1:textoExtracto "Diagrama temporal con tres señales digitales (SSTROBE, MSTROBE y AUXEND) representadas en forma de trenes de impulsos"@es .

ns1:Sensor_EntradaAnalogica a ns1:Sensor ;
    rdfs:label "Entrada analógica [n]"@es ;
    ns1:textoExtracto "Tensión en voltios de la entrada analógica [n] o temperatura en décimas de grado si es una sonda de temperatura PT100."@es .

ns1:Sensor_EntradaCaptacionLocal a ns1:Sensor ;
    rdfs:label "Entrada de captación local"@es ;
    ns1:textoExtracto "La unidad central dispone de dos entradas de captación. Este parámetro indica la entrada de captación que se utiliza."@es .

ns1:Sensor_EntradaCaptacionRemota a ns1:Sensor ;
    rdfs:label "Entrada de captación en módulos remotos CANfagor"@es ;
    ns1:textoExtracto "Para la entrada de captación se utiliza un módulo de contadoras en los módulos remotos. [...] Las contadoras del primer módulo serán 1 a 4, las del segundo 5 a 8 y así sucesivamente."@es ;
    ns1:tieneComponente ns1:ComponenteElectrico_ModuloContadoras .

ns1:Sensor_EntradaCaptacionSercos a ns1:Sensor ;
    rdfs:label "Entrada de captación en reguladores Sercos"@es ;
    ns1:textoExtracto "En este caso siempre se utilizará la segunda entrada de captación del regulador. [...] La dirección lógica la establece el conmutador rotativo 'address' (de 1 a 32)."@es .

ns1:Sensor_FollowingError a ns1:Sensor ;
    rdfs:label "Sensor de Following Error" ;
    ns1:activaAlarma ns1:AlarmaAntiembalamiento ;
    ns1:textoExtracto "oscilograma de ESTDELAY que compara 'Theoretical Following Error (1)' y 'Real Following Error (2)' durante una aceleración/parada." .

ns1:Sensor_GAP a ns1:Sensor ;
    rdfs:label "Sensor de posición del gap" ;
    ns1:monitoreaParametro ns1:Parametro_GAPGAIN ;
    ns1:textoExtracto "Valor real del gap, detectado por el sensor (V.)G.GAP." .

ns1:Sensor_GAP1 a ns1:Sensor ;
    rdfs:label "Sensor de gap 1"@es ;
    ns1:textoExtracto "el eje asociado al sensor se mueve al avance programado [...] hasta detectar la pieza con el sensor"@es .

ns1:Sensor_GAP2 a ns1:Sensor ;
    rdfs:label "Sensor de gap 2"@es ;
    ns1:textoExtracto "#GAPCTRL ON [Z-11, GAP 2]"@es .

ns1:Sensor_GAP5 a ns1:Sensor ;
    rdfs:label "Sensor de gap 5"@es ;
    ns1:textoExtracto "#GAPCTRL ON [GAP 5]"@es .

ns1:Sensor_I0 a ns1:Sensor ;
    rdfs:label "Sensor I0",
        "Sensor I0 (sistema de captación codificado)" ;
    ns1:monitoreaParametro ns1:Parametro_I0TYPE ;
    ns1:textoExtracto "Cuando el sistema de captación dispone de I0 codificado, la búsqueda de referencia se puede efectuar en cualquier punto de la máquina; [...] hasta que el CNC recibe un impulso de I0 del sistema de captación.",
        "Si alguno de los ejes del grupo programado no dispone de micro, el eje espera a que los demás lleguen a sus micros, y una vez ocurrido esto, buscará su I0 al avance REFFEED2 dentro del orden que le toque." .

ns1:Sensor_I0EjeEsclavo a ns1:Sensor ;
    rdfs:label "I0 del eje esclavo" ;
    ns1:textoExtracto "el eje esclavo encuentre el I0" .

ns1:Sensor_INCYCLEC1 a ns1:Sensor ;
    rdfs:label "INCYCLEC1" ;
    ns1:identificador "INCYCLEC1" ;
    ns1:monitoreaParametro ns1:Parametro_EstadoCanalC1 ;
    ns1:textoExtracto "INCYCLEC1 (también se puede programar como INCYCLE)" .

ns1:Sensor_INCYCLEC2 a ns1:Sensor ;
    rdfs:label "INCYCLEC2" ;
    ns1:identificador "INCYCLEC2" ;
    ns1:monitoreaParametro ns1:Parametro_EstadoCanalC2 ;
    ns1:textoExtracto "INCYCLEC2" .

