    ns1:textoExtracto "C Entrada a la pieza."@es .

ns1:ModoOperacion_FLWEMONITOR_Lineal a ns1:ModoOperacion ;
    rdfs:label "Modo Lineal (FLWEMONITOR)"@es ;
    ns1:textoExtracto "Con FLWEMONITOR = Lineal, MAXFLWE indica a partir de qué valor del error de seguimiento comienza la supervisión dinámica."@es .

ns1:ModoOperacion_FLWEMONITOR_Standard a ns1:ModoOperacion ;
    rdfs:label "Modo Standard (FLWEMONITOR)"@es ;
    ns1:textoExtracto "Con FLWEMONITOR = Standard, MAXFLWE indica el máximo error de seguimiento permitido cuando el eje está en movimiento."@es .

ns1:ModoOperacion_FOLLOW_OFF a ns1:ModoOperacion ;
