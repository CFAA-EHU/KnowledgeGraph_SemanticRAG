    ns1:textoExtracto "los desplazamientos de los distintos dispositivos (giro almacén, desplazamiento almacén, brazo cambiador, etc.)" .

ns1:DespuesDespuesSincronizacionFuncionM a ns1:Parametro ;
    rdfs:label "Después - Después (sincronización función M)" ;
    ns1:ilustradoEn ns1:TablaFuncionesM_561 ;
    ns1:textoExtracto "Después - Después. La función M se envía al PLC y se sincroniza después del movimiento." ;
    ns1:valor "Después - Después" .

ns1:DetencionPorColisionEnCicloDePalpador a ns1:AccionProhibida ;
    rdfs:label "Detención por colisión en ciclo de palpador"@es ;
    ns1:activaAlarma ns1:SenalALARMNivel0 ;
    ns1:textoExtracto "detiene el movimiento, muestra el error correspondiente, abre el relé de emergencia y activa la señal _ALARM (nivel \"0\")"@es .

ns1:DiagramaComportamientoEjeRotativo a ns1:Esquema ;
    rdfs:label "Comportamiento de eje rotativo de posicionamiento" ;
    ns1:textoExtracto "Tres diagramas polares comparan el comportamiento de un eje rotativo 'de posicionamiento' (camino más corto), mostrando arcos de 60° y 300° con flechas que indican trayectorias mínima y alternativa; los rótulos B300/–B300 señalan límites de módulo y la cota visible." .

ns1:DiagramaDeTecladoJOGPANELPag246Ejemplo3 a ns1:Esquema ;
    rdfs:label "Diagrama de teclado JOG-PANEL (pág. 246, Ejemplo 3)"@es ;
    ns1:detalladoEnEsquema ns1:InterfazUsuario_JogPanel ;
    ns1:ilustradoEn ns1:Pagina_2ecb675d2d ;
    ns1:textoExtracto "Diagrama de teclado con nueve casillas activas que alterna teclas de sentido (+/−) y de eje (X, Y, 4, 5) más tecla R. Ilustra una asignación en la que el usuario primero selecciona el sentido y luego el eje, con la tecla R centrada para activar el avance rápido."@es .

ns1:DiagramaDeTecladoLCD10KPag246Ejemplo4 a ns1:Esquema ;
    rdfs:label "Diagrama de teclado LCD-10K (pág. 246, Ejemplo 4)"@es ;
    ns1:detalladoEnEsquema ns1:InterfazUsuario_LCD10K ;
    ns1:ilustradoEn ns1:Pagina_2ecb675d2d ;
    ns1:textoExtracto "Teclado con nueve teclas: X+, Y+, 4+, 5+, R, 5−, X−, Y−, 4−. El diagrama organiza las flechas por cuadrantes para expresar direccionalidad y agrupar por eje, ejemplificando una configuración directa 'eje con signo' para jog."@es .

ns1:DiagramaEstados_SERVOON_ENABLE a ns1:Esquema ;
    rdfs:label "Diagrama de estados para SERVOON/ENABLE"@es ;
    ns1:ilustradoEn ns1:Pagina_9d5c50b612 ;
    ns1:textoExtracto "Diagrama de estados para SERVOON/ENABLE con trazas 'Velocity Command', ventanas de DWELL y condición de ERROR. Expone la lógica de habilitación del regulador, la espera configurada por DWELL y el disparo de error si no se cumple la condición de servo activo antes del movimiento."@es .

ns1:DiagramaIsometrico a ns1:Esquema ;
    rdfs:label "Diagrama isométrico del husillo y su entorno inmediato"@es ;
    ns1:textoExtracto "Diagrama isométrico del husillo y su entorno inmediato que identifica la relación entre los parámetros LONGAXIS (eje longitudinal), FACEAXIS (eje transversal) y CAXIS (eje rotativo)."@es .

ns1:DiagramaMesaRotativaAB1596 a ns1:Esquema ;
    ns1:textoExtracto "Conjunto de diagramas de una mesa rotativa AB (TYPE=9) que definen sentidos positivos y parámetros TDATA2, TDATA3, TDATA4 y TDATA5. Se indican ejes A y B, la intersección de ejes en X-Y-Z y la distancia entre ejes con flechas, signos (+) y bloques etiquetados." ;
    ns1:tieneComponente ns1:BloqueEtiquetado_1596,
        ns1:DistanciaEjes_1596,
        ns1:Figura_25c7ae4113,
        ns1:Figura_7779bb227a,
        ns1:FlechaSentidoPositivo_1596,
        ns1:InterseccionEjesXYZ_1596,
        ns1:SignoPositivo_1596 .

ns1:DiagramaOscilacionCabezal_PLC a ns1:Esquema ;
    rdfs:label "Diagrama temporal de oscilación del cabezal controlada por PLC"@es ;
    ns1:detalladoEnEsquema ns1:Senal_PLCCNTL,
        ns1:Senal_SANALOG ;
    ns1:ilustradoEn ns1:Pagina_bbeb4e7709 ;
    ns1:textoExtracto "Diagrama temporal de oscilación del cabezal controlada por PLC durante cambio de gama, con trazas MFUN, MSTROBE, AUXEND, GEAR1/GEAR4 y señales SANALOG/PLCCNTL. Representa conmutación de control al PLC, consigna analógica residual y devolución del control al CNC."@es .

ns1:DiagramaPrecarga_1175 a ns1:Figura ;
    rdfs:label "Diagramas de efecto de precarga en diferentes situaciones"@es ;
    ns1:ilustradoEn ns1:Entity575576 ;
    ns1:textoExtracto "Los siguientes diagramas muestran el efecto de la precarga en diferentes situaciones. Precarga en reposo. Precarga con aceleración. Precarga a velocidad constante. Par de fricción > Precarga. Precarga a velocidad constan..."@es .

ns1:DiagramaSolucionGeometrica1596 a ns1:Esquema ;
    ns1:textoExtracto "Diagrama de solución geométrica: construcción de XM = 0,5·(Xb+Xa) y cálculo TDATA6 = 2·XM − TDATA1, con esquema Y-Z, marca de ángulo 45° y flechas de referencia; se destaca la relación entre la media de lecturas laterales y el descentramiento respecto a TDATA1." ;
    ns1:tieneComponente ns1:EjeYZ_1596,
        ns1:FlechaReferencia1_1596,
        ns1:FlechaReferencia2_1596,
        ns1:MarcaAngulo45_1596 .

ns1:DiagramaTemporalPLC a ns1:Esquema ;
    rdfs:label "Diagrama temporal multiseñal del PLC"@es ;
    ns1:detalladoEnEsquema ns1:BloqueAdvertenciaOvertemp ;
    ns1:textoExtracto "Diagrama temporal multiseñal que muestra la secuencia de aparcado/desaparcado gestionada desde el CNC. Incluye trazas PARK(axis), UNPARK(axis), PARKED(axis), DRENA(axis) y REFPOIN(axis), numeradas (1–6) para los hitos del proceso. Se señalan ventanas temporales MINAENDW. El esquema clarifica la lógica: solicitud del CNC, actuación del PLC sobre habilitaciones/regulador y confirmación mediante PARKED/REFPOIN. --- Páginas: 422 | Sección: 6.2 Señales de consulta de los ejes y cabezales (Maniobra desde el PLC) | Título: — ---"@es .

ns1:DiagramaTemporal_CambioGama_GEAR1_GEAR2 a ns1:Esquema ;
    rdfs:label "Diagrama temporal de cambio de gama (GEAR1→GEAR2)"@es ;
    ns1:detalladoEnEsquema ns1:Senal_AUXEND,
        ns1:Senal_GEAR1,
        ns1:Senal_GEAR2,
        ns1:Senal_MFUN,
        ns1:Senal_MSTROBE ;
    ns1:ilustradoEn ns1:Pagina_9246418c31 ;
    ns1:textoExtracto "Diagrama temporal de cambio de gama (GEAR1→GEAR2) con señales MFUN, MSTROBE, AUXEND, indicadores GEAR1/GEAR2, pista 'CHANGE' y referencia MINAENDW. Describe la secuencia: solicitud M4x, comienzo/fin de cambio (AUXEND), confirmación de gama y liberación del strobe."@es .

ns1:DiagramaTemporal_ParkUnpark_PLC a ns1:Figura ;
    rdfs:label "Diagrama temporal de señales PARK/UNPARK desde PLC"@es ;
    ns1:ilustradoEn ns1:Manual_OpenPCS_Remoto_Seccion6_2 ;
    ns1:textoExtracto "Diagrama temporal análogo al anterior, pero para la maniobra iniciada desde el PLC. Representa PARK(axis), UNPARK(axis), PARKED(axis), DRENA(axis) y REFPOIN(axis) con numeración (1–4) de eventos. La gráfica distingue claramente la iniciación por PARKED, el comienzo de PARK/UNPARK por parte del CNC y la finalización con restablecimiento de habilitaciones."@es .

ns1:DialogoConnectionsFagorCNCTCPEdit a ns1:InterfazUsuario ;
    rdfs:label "Diálogo 'Connections → FagorCNCTCP → Edit' del OpenPCS para configurar conexión, con campos de nombre y parámetros. Se destaca el acceso a 'Settings'" ;
    ns1:textoExtracto "OPENPCS REMOTO | Título: — --- (Elemento 1) Diálogo 'Connections → FagorCNCTCP → Edit' del OpenPCS para configurar conexión, con campos de nombre y parámetros. Se destaca el acceso a 'Settings'" ;
    ns1:tieneComponente ns1:DialogoSettings .

ns1:DialogoDeExportacion1 a ns1:InterfazUsuario ;
    rdfs:label "Diálogo de exportación 1" ;
    ns1:textoExtracto "(Arriba) Diálogo de exportación 'Export → Export Master Configuration ETG Standard' para generar el XML de configuración; (abajo) opción 'File → Save' para guardar proyecto *.ecsn. Se observan rutas de archivo, nombres propuestos y botones de confirmación." .

ns1:DibujoDePosicionesDelEjeAPag716719 a ns1:Figura ;
    rdfs:label "Dibujo de posiciones del eje A (pág. 716-719)"@es ;
    ns1:ilustradoEn ns1:Pagina_716,
        ns1:Pagina_717,
        ns1:Pagina_718,
        ns1:Pagina_719 ;
    ns1:textoExtracto "En el dibujo se muestran dos posiciones distintas que tienen en común el centro del eje A"@es .

ns1:DireccionDeEjesXYZSegunDIN66217 a ns1:Parametro ;
    rdfs:label "Dirección de ejes X/Y/Z según DIN 66217" ;
    ns1:identificador "DIN_66217_EjesXYZ" ;
    ns1:textoExtracto "Valores posibles: 0 (según la norma DIN 66217) / 1 (contrario a la norma DIN 66217). Valor por defecto: 0. La dirección de los ejes X Y Z, según la norma DIN 66217, se puede recordar fácilmente utilizando la regla de la mano derecha." ;
    ns1:valor "0" .

ns1:DireccionLogicaDelReguladorSercos a ns1:Parametro ;
    rdfs:label "Dirección lógica del regulador (Sercos)"@es ;
    ns1:monitoreaParametro ns1:Regulador_Sercos ;
    ns1:textoExtracto "El parámetro indica la dirección lógica del regulador (de 1 a 32)."@es ;
    ns1:valor "1-32" .

ns1:Directiva_DEF a ns1:Directiva ;
    rdfs:label "DEF" ;
    ns1:textoExtracto "Los símbolos se programarán siempre al principio del programa, antes que los módulos CY1, PRG y PEt. El PLC permite definir una serie de símbolos para facilitar la programación y posterior comprensión del programa de PLC. Estos símbolos se programan mediante la directiva DEF o PDEF, seguida del nombre del símbolo una constante o recurso del PLC." .

ns1:Directiva_EXTERN a ns1:Directiva ;
    rdfs:label "Directiva EXTERN",
        "EXTERN" ;
    ns1:documentadoEn ns1:Manual_Seccion4_1 ;
    ns1:identificador "EXTERN" ;
    ns1:textoExtracto "La directiva EXTERN permite definir dichas subrutinas una a una. Se define con EXTERN seguido de un espacio y del nombre de la subrutina, hasta 24 caracteres." .

ns1:Directiva_EXTERN_722 a ns1:Directiva ;
    rdfs:label "Directiva EXTERN (Subrutina externa)"@es ;
    ns1:documentadoEn ns1:SistemaProgramacionPLC_722 ;
    ns1:identificador "EXTERN" ;
    ns1:textoExtracto "EXTERN Definición de subrutina externa. Las subrutinas definidas en el fichero de lenguaje C que utiliza el programa deben estar definidas como externas al principio del programa, antes que la directiva DEF y los módulos CY1, PRE y PEt."@es .

ns1:Directiva_L_722 a ns1:Directiva ;
    rdfs:label "Directiva L (Etiqueta)"@es ;
    ns1:identificador "L" ;
    ns1:textoExtracto "L Etiqueta. Sirve para identificar una línea de programa. Se puede definir de 2 formas: • Con L seguido de hasta 7 cifras (L1 - L9999999). • Con L_ seguido de hasta 8 caracteres (L_GEAR). Si está definida dentro de un módulo (CY1, PRG o PE), identifica una línea de programa y permite realizar referencias o saltos de programa."@es .

ns1:Directiva_NOMONIT a ns1:Directiva ;
    rdfs:label "Directiva NOMONIT para deshabilitar monitorización",
        "NOMONIT" ;
    ns1:identificador "NOMONIT" ;
    ns1:textoExtracto "NOMONIT No monitorización. Cuando se programa esta directiva no se genera la información necesaria para la monitorización del programa de PLC." .

ns1:Directiva_ProgramacionInicial a ns1:Directiva ;
    rdfs:label "Directiva de programación inicial" ;
    ns1:cumpleNormativa ns1:ModoOperacion_Critico ;
    ns1:identificador "Directiva_ProgramacionInicial" ;
    ns1:textoExtracto "Programarla siempre al principio del programa, antes que la directiva DEF y los módulos CY1, PRG y PEt. Se aconseja utilizar esta directiva cuando el tiempo de ejecución del programa de PLC es muy crítico. Definirla tras depurar el programa de PLC." .

ns1:Directiva_SUB_722 a ns1:Directiva ;
    rdfs:label "Directiva SUB (Subrutina)"@es ;
    ns1:documentadoEn ns1:SistemaProgramacionPLC_722 ;
    ns1:identificador "SUB" ;
    ns1:textoExtracto "SUB Definición de subrutina. Indica el comienzo de una subrutina. Se denomina subrutina a una parte de programa que puede ser llamada desde cualquier proposición ejecutable. Se define con SUB seguido de un espacio y hasta 24 caracteres. Una subrutina debe finalizar siempre con la directiva END."@es .

ns1:DirectorioCNC8070_USERS a ns1:Sistema ;
    rdfs:label "Directorio CNC8070\\USERS" ;
    ns1:textoExtracto "en un directorio desprotegido, por ejemplo CNC8070\\USERS. En ningún caso debe utilizar un directorio protegido, ya que sólo tendría carácter temporal, desaparecería tras apagar el CNC." .

ns1:Directorio_CNC8070_USERS a ns1:InterfazUsuario ;
    rdfs:label "Directorio CNC8070\\USERS" ;
    ns1:textoExtracto "guardarse en un directorio desprotegido, por ejemplo CNC8070\\USERS" .

ns1:DiscoDuro_CNC a ns1:ComponenteElectrico ;
    rdfs:label "Disco duro" ;
    ns1:textoExtracto "compact flash más disco duro" .

ns1:DispositivoExterno a ns1:Componente ;
    rdfs:label "dispositivos externos" ;
    ns1:textoExtracto "dispositivos externos" .

ns1:DispositivoExterno_1033_1 a ns1:Componente ;
    rdfs:label "dispositivos externos" ;
    ns1:textoExtracto "el control de los dispositivos externos" .

ns1:DispositivosExternos a ns1:Componente ;
    ns1:textoExtracto "el control de los dispositivos externos" .

ns1:DistanciaDeEntradaAPiezaRadio a ns1:Parametro ;
    rdfs:label "Distancia de entrada a pieza (radio)" ;
    ns1:textoExtracto "a partir de que la herramienta entre en la pieza una distancia igual al radio" ;
    ns1:valor "radio" .

ns1:DistanciaDeSeguridadDeLosLimitesDeLasZonasDeTrabajo a ns1:Parametro ;
    rdfs:label "Distancia de seguridad de los límites de las zonas de trabajo"@es ;
    ns1:identificador "(V.)[ch].A.ZONELIMITTOL.xn" ;
    ns1:textoExtracto "La distancia de seguridad se puede modificar con la siguiente variable, que en el arranque tomará el valor de este parámetro. ( V.)[ch].A.ZONELIMITTOL.xn Distancia de seguridad de los límites de las zonas de trabajo."@es ;
    ns1:valor "Distancia de seguridad configurada"@es .

ns1:DistanciaLimiteDelSensor a ns1:Parametro ;
    rdfs:label "Distancia límite del sensor"@es ;
    ns1:documentadoEn ns1:Tabla_GAPCONTROL ;
    ns1:identificador "GAPDISTLIMIT" ;
    ns1:monitoreaParametro ns1:Sensor_7ec45705f9 ;
    ns1:textoExtracto "GAPDISTLIMIT | Distancia que corresponde a la señal analógica límite del sensor."@es .

ns1:DistanciaMovidaConG201ADDMANOF a ns1:Parametro ;
    rdfs:label "Distancia movida con G201 (ADDMANOF)"@es ;
    ns1:documentadoEn ns1:Tabla_13_3_6_VariablesCotasLazo ;
    ns1:identificador "(V.)[ch].A.ADDMANOF.xn" ;
    ns1:textoExtracto "Distancia movida con G201. Unidades: Milímetros, pulgadas o grados."@es ;
    ns1:valor "Milímetros, pulgadas o grados"@es .

ns1:DistanciaRetiroHerramienta a ns1:Parametro ;
    rdfs:label "Distancia de retiro de herramienta" ;
    ns1:monitoreaParametro ns1:CiclosFijosRoscado_T ;
    ns1:textoExtracto "La distancia que se retira la herramienta depende de la programación del ciclo." .

ns1:DistribucionDeParEnEjeTandem a ns1:Parametro ;
    rdfs:label "Distribución de par en eje tándem"@es ;
    ns1:monitoreaParametro ns1:ConfiguracionEjeTandem_1177 ;
    ns1:textoExtracto "Ganancia de normalización de los pares generados por los motores cuyo fin es establecer un reparto de pares que no siga una relación 1:1."@es ;
    ns1:valor "ganancia de normalización"@es .

ns1:DuracionDeFaseDeAprendizajeDMC a ns1:Parametro ;
    rdfs:label "Duración de fase de aprendizaje (DMC)" ;
    ns1:textoExtracto "La fase de aprendizaje dura un minuto" ;
    ns1:valor "1 minuto" .

ns1:EMERGEN a ns1:Parametro ;
    rdfs:label "_EMERGEN" ;
    ns1:textoExtracto "Las señales _EMERGEN, _STOP, _FEEDHOL, _XFERINH y CYSTART deben estar definidas en el programa de PLC. _ EMERGEN Hay una marca para cada canal. Los mnemónicos para cada canal son los siguientes. _ EMERGENC1 (también se puede programar como _EMERGEN) _EMERGENC2 _EMERGENC3 _EMERGENC4 Si el PLC pone esta marca a (=0), el CNC detiene el avance de los ejes y el giro del cabezal, visualizando en la pantalla el error correspondiente. El CNC detiene el avance de los ejes dejando de enviarles consigna; los ejes no se detienen siguiendo una rampa de deceleración establecida. Mientras la marca _EMERGEN está a (=0) el canal del CNC prohíbe la ejecución de programas y aborta cualquier intento de movimiento de los ejes o de cabezal. I-EMERG AND (resto de condiciones) = _EMERGEN Si se pulsa la seta de emergencia (I-EMERG=0) o se produce cualquier otra causa de emergencia (=0), la marca _EMERGEN se pone a (=0), produciéndose emergencia en el CNC." ;
    ns1:valor "marca de emergencia del CNC" .

ns1:ENABLEGAP a ns1:Parametro ;
    rdfs:label "ENABLEGAP" ;
    ns1:textoExtracto "Marca activa por defecto. El PLC desactiva esta marca para deshabilitar el control del gap activo. El PLC activa esta marca para habilitar el control del gap activo en el CNC; si no hay un control del gap activo, esta marca no hace nada." .

ns1:ENABLEPWM_MarcaControl a ns1:Parametro ;
    rdfs:label "ENABLEPWM" ;
    ns1:controla ns1:PWM_Se_alL_gica ;
    ns1:identificador "ENABLEPWM" ;
    ns1:textoExtracto "El PLC activa esta marca (cambio de 1 a 0) para habilitar el PWM activo en el CNC; si no hay un PWM activo, esta marca no hace nada." .

ns1:ENABLEPWRDUTY_MarcaControl a ns1:Parametro ;
    rdfs:label "ENABLEPWRDUTY" ;
    ns1:controla ns1:CicloDeTrabajoPWM ;
    ns1:identificador "ENABLEPWRDUTY" ;
    ns1:textoExtracto "Marca activa por defecto. Esta marca está asociada al control duty del PWM (#PWRCTRL ON [DUTY]). El PLC desactiva esta marca para deshabilitar el control de duty activo." .

ns1:ENABLEPWROUT_MarcaControl a ns1:Parametro ;
    rdfs:label "ENABLEPWROUT" ;
    ns1:controla ns1:Cabezal_SalidaPotencia ;
    ns1:identificador "ENABLEPWROUT" ;
    ns1:textoExtracto "Marca activa por defecto. Esta marca está asociada al control de potencia a través de la salida analógica asociada al cabezal (#PWRCTRL ON [OUT]). El PLC desactiva esta marca para deshabilitar el control de potencia activo." .

ns1:ESTOPHabilitarLaTeclaSTOP a ns1:AccionProhibida ;
    ns1:textoExtracto "# ESTOP ; Habilitar la tecla STOP." .

ns1:EditorCNC_Unicode a ns1:Componente ;
    rdfs:label "Editor del CNC (soporte Unicode)" ;
    ns1:textoExtracto "El editor del CNC admite caracteres Unicode. Los programas en formato Unicode no son compatibles con versiones anteriores a la versión V4.0." .

ns1:Eje a ns1:ComponenteMecanico ;
    rdfs:label "eje"@es ;
    ns1:textoExtracto "el eje permanecerá parado y sin control del gap hasta que se reanude el movimiento."@es .

ns1:Eje1 a ns1:Parametro ;
