ns1:Parametro_GAPMAX a ns1:Parametro ;
    rdfs:label "GAPMAX" ;
    ns1:documentadoEn ns1:Tabla_ParametrosGap ;
    ns1:identificador "GAPMAX",
        "MPG.GAPMAX" ;
    ns1:monitoreaParametro ns1:Senal_INPOSGAP ;
    ns1:textoExtracto "GAPMAX Límite máximo del sensor. Valores posibles: De 0 a 99999.9999 mm / De 0 a 3937.00787 inch. Valor por defecto: 5.0000 mm / 0.19685 inch. Variable asociada: (V.)MPG.GAPMAX Máximo valor permitido para el gap.",
        "los parámetros GAPMIN-GAPMAX",
        "parámetro GAPMAX",
        "rango definido por los parámetros GAPMIN-GAPMAX",
        "Máximo valor permitido para el gap; por encima de este valor, el CNC mostrará o no un error según lo definido en el parámetro GAPERRORCANCEL. Este parámetro debe ser inferior a GAPDISTLIMIT."@es ;
    ns1:valor "5.0000",
        "GAPMAX" .

ns1:Parametro_GAPMIN a ns1:Parametro ;
    rdfs:label "GAPMIN" ;
    ns1:documentadoEn ns1:Tabla_ParametrosGap ;
    ns1:identificador "GAPMIN",
        "MPG.GAPMIN" ;
    ns1:monitoreaParametro ns1:Senal_INPOSGAP ;
    ns1:textoExtracto "GAPMIN Límite mínimo del sensor. Valores posibles: De 0 a 99999.9999 mm / De 0 a 3937.00787 inch. Valor por defecto: 0. Variable asociada: (V.)MPG.GAPMIN Mínimo valor permitido para el gap.",
        "los parámetros GAPMIN-GAPMAX",
        "parámetro GAPMIN",
        "rango definido por los parámetros GAPMIN-GAPMAX",
        "Mínimo valor permitido para el gap; por debajo de este valor, el CNC mostrará o no un error según lo definido en el parámetro GAPERRORCANCEL."@es ;
    ns1:valor "0",
        "GAPMIN" .

ns1:Parametro_GAPTOLCANCEL a ns1:Parametro ;
    rdfs:label "GAPTOLCANCEL",
        "Parámetro GAPTOLCANCEL"@es ;
    ns1:documentadoEn ns1:TablaSenalesPLC_16_2_6,
        ns1:Tabla_ParametrosGap,
        ns1:Tabla_SenalesLogicasConsultaLaser ;
    ns1:identificador "GAPTOLCANCEL",
        "MPG.GAPTOLCANCEL" ;
    ns1:textoExtracto "El comportamiento del CNC depende del parámetro GAPTOLCANCEL.",
        "GAPTOLCANCEL Anular el error de gap fuera del rango definido por GAPTOL. Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)MPG.GAPTOLCANCEL El parámetro GAPTOLCANCEL establece el comportamiento del CNC cuando el gap supera el margen definido en el parámetro GAPTOL.",
        "Sí. El CNC anula el error de gap fuera de tolerancia y no detiene el movimiento de los ejes. / No. El CNC da error de gap fuera de tolerancia y detiene el movimiento de los ejes, respetando la rampa de frenado y controlando el gap durante la rampa.",
        "según lo definido en el parámetro GAPTOLCANCEL",
        "El parámetro GAPTOLCANCEL establece el comportamiento del CNC cuando el gap sobrepasa la tolerancia definida en GAPTOL."@es,
        "Este parámetro indica si el CNC debe anular el error de gap fuera de tolerancia, cuando el gap supera el margen definido en el parámetro GAPTOL."@es,
        "dependiendo del parámetro máquina GAPTOLCANCEL"@es ;
    ns1:valor "No" .

ns1:Parametro_I0TYPE a ns1:Parametro ;
    rdfs:label "I0TYPE",
        "I0TYPE (Tipo de I0)",
        "Parámetro I0TYPE",
        "Tipo de codificación (I0TYPE)"@es ;
    ns1:documentadoEn ns1:Tabla_HomogeneizacionParametrosCNC_Drive,
        ns1:Tabla_ParametrosBusquedaReferenciaGantry ;
    ns1:identificador "I0TYPE" ;
    ns1:monitoreaParametro ns1:ComponenteElectrico_PP115,
        ns1:Encoder_Generico ;
    ns1:textoExtracto "I0TYPE Tipo de I0. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: No codificado / Codificado creciente / Codificado decreciente. Valor por defecto: No codificado.",
        "I0TYPE | Codificado creciente. Codificado decreciente.",
        "Las reglas con I0 codificado permiten conocer la posición de la máquina tras un recorrido mínimo de 20 o 100 mm.",
        "El CNC sólo tiene en cuenta este parámetro con I0TYPE = Codificado."@es,
        "I0TYPE"@es,
        "Tipo de I0. No codificado en ambos ejes. A definir en los ejes maestro y esclavo."@es ;
    ns1:valor "Codificado creciente; Codificado decreciente",
        "Modo: Codificado/No codificado",
        "No codificado" .

ns1:Parametro_INPOSW a ns1:Parametro ;
    rdfs:label "INPOSW",
        "INPOSW (Banda de muerte)",
        "INPOSW (Banda de muerte)"@es ;
    ns1:identificador "INPOSW" ;
    ns1:textoExtracto "Cuando se trabaja en arista viva, el CNC comienza la ejecución del siguiente desplazamiento cuando el eje entra en la banda de muerte, definida en el parámetro INPOSW.",
        "Un eje está en posición cuando permanece dentro de la banda de muerte (parámetro INPOSW) el tiempo indicado en el parámetro INPOTIME.",
        "INPOSW Banda de muerte. Parámetro válido para ejes lineales, rotativos y cabezales. [...] Se define como banda de muerte la zona anterior y posterior de la cota programada en la que se considera que el eje se encuentra en posición. El parámetro INPOSW define la anchura de ambas zonas."@es,
        "Un eje está en posición cuando permanece dentro de la banda de muerte (parámetro INPOSW) el tiempo indicado en el parámetro INPOTIME."@es ;
    ns1:valor "0.0100" .

ns1:Parametro_IPOACCP a ns1:Parametro ;
    rdfs:label "IPOACCP",
        "Parámetro IPOACCP (Aceleración en modo manual superpuesto)"@es,
        "Parámetro IPOACCP (máximo % aceleración en G201)"@es ;
    ns1:documentadoEn ns1:Tabla_MANUAL ;
    ns1:identificador "IPOACCP" ;
    ns1:textoExtracto "IPOACCP Máximo porcentaje aceleración de ejecución en G201. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 100. Valor por defecto: 80. Variable asociada: (V.)[ch].MPA.IPOACCP.xn"@es,
        "Máximo porcentaje de aceleración de ejecución en G201."@es,
        "Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles: De 0 a 100. Valor por defecto: 80. Variable asociada: (V.)[ch].MPA.IPOACCP.xn [...] ambos parámetros indican la máxima aceleración a utilizar de cada modo."@es ;
    ns1:valor 80,
        "80" .

