ns1:Error23102 a ns1:AvisoSeguridad ;
    rdfs:label "Error del sistema de compensación volumétrica"@es,
        "Error del sistema de compensación volumétrica; compensación desactivada"@es ;
    ns1:identificador "23102" ;
    ns1:solucionaFallo ns1:FalloCompensacionVolumetrica ;
    ns1:textoExtracto "23102 'Error del sistema de compensación volumétrica;"@es,
        "23102 'Error del sistema de compensación volumétrica; compensación desactivada' DETECCIÓN Durante la ejecución. CAUSA El CNC ha detectado un error interno en el cálculo de la compensación volumétrica, y ha anulado los valores de la compensación. SOLUCIÓN Póngase en contacto con Fagor Automation."@es .

ns1:Error23103 a ns1:AvisoSeguridad ;
    rdfs:label "No se puede activar la marca VOLCOMP sin una tabla validada"@es ;
    ns1:identificador "23103" ;
    ns1:textoExtracto "23103 'No se puede activar la marca VOLCOMP sin una tabla validada' DETECCIÓN Durante la ejecución. CAUSA El PLC ha intentado activar una compensación volumétrica que no está definida de forma correcta y por lo tanto no es posible la compensación de la máquina. SOLUCIÓN Definir una compensación volumétrica adecuada en los parámetros máquina (parámetros VOLCOMP)."@es .

ns1:Error23104 a ns1:AvisoSeguridad ;
    rdfs:label "No se puede activar la marca VOLCOMP con otra tabla activa sobre ejes comunes"@es ;
    ns1:identificador "23104" ;
    ns1:textoExtracto "23104 'No se puede activar la marca VOLCOMP con otra tabla activa sobre ejes comunes' DETECCIÓN Durante la ejecución. CAUSA El PLC ha intentado activar una compensación volumétrica con otra activa, y alguno de los ejes utilizados es común en ambas compensaciones. SOLUCIÓN No puede haber activas dos compensaciones volumétricas que tengan algún eje en común. Antes de activar una compensación, anular la activa mediante la marca de PLC correspondiente."@es .

ns1:Error24499_EtherCAT a ns1:AvisoSeguridad ;
    rdfs:label "Error 24499" ;
    ns1:identificador "24499" ;
    ns1:mitigaRiesgo ns1:ModoDiagnosis_EtherCAT ;
    ns1:textoExtracto "Error 24499. Error genérico de EtherCAT. El CNC muestra el siguiente error genérico cuando detecta un error en un nodo." .

ns1:ErrorCNC_EjesAusentes a ns1:AvisoSeguridad ;
    rdfs:label "Error CNC por ejes A/B ausentes"@es ;
    ns1:textoExtracto "el CNC mostrará error porque los tiene en cuenta (reguladores, sistemas de captación, etc.)"@es .

ns1:ErrorIncoherenciaSoftwareBusCAN a ns1:AvisoSeguridad ;
    rdfs:label "Error de incoherencia de software en bus CAN"@es ;
    ns1:textoExtracto "no se completa con éxito, y por tanto no se puede garantizar la coherencia de software entre todos los elementos del bus CAN, se visualizará el error correspondiente en el CNC cada vez que se pulse la tecla [RESET]."@es .

ns1:ErrorPosicionNoValida a ns1:AvisoSeguridad ;
    rdfs:label "Error de posición no válida en almacén torreta" ;
    ns1:textoExtracto "si el registro tiene valor ꞏ0ꞏ, el PLC mostrará el error correspondiente" .

ns1:ErrorSeguimientoEje a ns1:AvisoSeguridad ;
    rdfs:label "Error de seguimiento por movimiento de eje bloqueado"@es ;
    ns1:textoExtracto "Si se mueve el eje cuando está bloqueado, el CNC almacena la desviación como error de seguimiento."@es .

ns1:ErrorSeguimiento_264 a ns1:Parametro ;
    rdfs:label "Error de seguimiento" ;
    ns1:textoExtracto "El error de seguimiento [...] se calculan en el CNC."@es .

ns1:ErrorSeguimiento_epsilon a ns1:Parametro ;
    rdfs:label "Error de seguimiento (ε)" ;
    ns1:textoExtracto "minimizando el error de seguimiento \"\" [...] el resto de la consigna será proporcional al error de seguimiento \"\"" ;
    ns1:valor "ε" .

ns1:Error_E173 a ns1:AvisoSeguridad ;
    rdfs:label "Error E173 (temperatura > 65 ºC)" ;
    ns1:identificador "E173" ;
    ns1:textoExtracto "El CNC comprueba que la temperatura ambiente no sobrepase los 65ºC (149ºF), y en caso de superar dicho valor, invalida el [START] y muestra el error E173." .

ns1:Error_E9332 a ns1:AvisoSeguridad ;
    rdfs:label "Error E9332" ;
    ns1:identificador "E9332" ;
    ns1:textoExtracto "el CNC mostrará un error E9332 por cada eje Sercos con captación externa. Este error indica que los valores de los parámetros COUNTERTYPE y COUNTERID son incompatibles" .

ns1:EsclavosEtherCAT a ns1:Componente ;
    rdfs:label "Esclavos del bus EtherCAT"@es ;
    ns1:textoExtracto "Información de los esclavos."@es .

ns1:EsquemaBus_OPENPCS a ns1:Esquema ;
    rdfs:label "Esquema lineal del bus OPENPCS Remoto" ;
    ns1:ilustradoEn ns1:Sistema_OPENPCS_Remoto ;
    ns1:textoExtracto "esquema lineal del bus. Incluye una relación 'Address → Elemento → Número de orden' que clarifica la jerarquía y la asociación física en el bus." .

ns1:EsquemaConexionSensorGap_1289 a ns1:Esquema ;
    rdfs:label "Esquema eléctrico: Conexión del sensor del gap"@es ;
    ns1:ilustradoEn ns1:Pagina_696 ;
    ns1:textoExtracto "Esquema eléctrico. Conexión del sensor a una entrada analógica del regulador Sercos. El ejemplo utiliza la primera entrada analógica del regulador (pines 4 y 5); para utilizar la segunda, utilizar los pines 2 y 3."@es .

ns1:EsquemaConexionado_1275 a ns1:Esquema ;
