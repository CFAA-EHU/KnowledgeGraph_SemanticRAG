ns1:MANPG a ns1:Tabla ;
    rdfs:label "MANPG" ;
    ns1:documentadoEn ns1:ManualModoManual ;
    ns1:textoExtracto "MANPG Tabla de volantes. Este parámetro muestra la lista de volantes disponibles." .

ns1:MANPG_n a ns1:Tabla ;
    rdfs:label "MANPG n" ;
    ns1:documentadoEn ns1:ManualModoManual ;
    ns1:textoExtracto "MANPG n Configuración del volante. Este parámetro muestra la tabla para configurar los volantes." .

ns1:MANRAPID a ns1:Parametro ;
    rdfs:label "MANRAPID (marca PLC por canal)" ;
    ns1:identificador "MANRAPID" ;
    ns1:textoExtracto "La marca MANRAPID del PLC pasa de ser una marca general a ser una marca por canal. La marca MANRAPID que en versiones anteriores afectaba a todos los ejes del sistema, ahora sólo afectará a los ejes del primer canal." .

ns1:MANRAPIDC1 a ns1:Parametro ;
    rdfs:label "MANRAPIDC1 (marca PLC para canal 1)" ;
    ns1:identificador "MANRAPIDC1" ;
    ns1:textoExtracto "Para que la marca afecte a todos los ejes del sistema, hay que modificar el programa de PLC y utilizar las marcas MANRAPIDC1 a MANRAPIDC4, en función de los canales que tenga el sistema." .

ns1:MANRAPIDC4 a ns1:Parametro ;
    rdfs:label "MANRAPIDC4 (marca PLC para canal 4)" ;
    ns1:identificador "MANRAPIDC4" ;
    ns1:textoExtracto "Para que la marca afecte a todos los ejes del sistema, hay que modificar el programa de PLC y utilizar las marcas MANRAPIDC1 a MANRAPIDC4, en función de los canales que tenga el sistema." .

ns1:MAXFEED a ns1:Parametro ;
    rdfs:label "MAXFEED" ;
    ns1:documentadoEn ns1:TablaParametrosPuestaMarcha ;
    ns1:identificador "MAXFEED" ;
    ns1:monitoreaParametro ns1:AvanceMecanizado ;
    ns1:textoExtracto "MAXFEED Máximo avance de mecanizado del eje. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado.",
        "Máximo avance para el mecanizado. Se recomienda definir este parámetro con un valor distinto de ꞏ0ꞏ."@es .

ns1:MAXFLWE a ns1:Parametro ;
    rdfs:label "MAXFLWE" ;
    ns1:documentadoEn ns1:TablaParametrosPuestaMarcha ;
    ns1:identificador "MAXFLWE" ;
    ns1:textoExtracto "Para una monitorización \"standard\" del error de seguimiento, este parámetro indica el máximo error de seguimiento permitido cuando el eje está en movimiento. Para una monitorización \"lineal\" del error de seguimiento, este parámetro indica a partir de qué valor comienza la supervisión dinámica."@es .

ns1:MAXFLWE_Parametro a ns1:Parametro ;
    rdfs:label "MAXFLWE" ;
    ns1:textoExtracto "umbral MAXFLWE desde el que se activa la supervisión dinámica"@es ;
    ns1:valor "MAXFLWE" .

ns1:MAXOVR a ns1:Parametro ;
    rdfs:label "MAXOVR" ;
    ns1:identificador "MAXOVR" ;
    ns1:textoExtracto "El CNC siempre respeta el límite máximo definido en el parámetro máquina MAXOVR.",
        "Nunca se podrán superar los límites definidos mediante los parámetros máquina MINOVR y MAXOVR." .

ns1:MAXVOLT a ns1:Parametro ;
    rdfs:label "MAXVOLT" ;
    ns1:identificador "MAXVOLT" ;
    ns1:textoExtracto "los watios definidos en el parámetro G00FEED como potencia del generador deben corresponder al nivel de voltios definidos en el parámetro MAXVOLT." ;
    ns1:valor "Potencia máxima del generador (modelo láser)"^^xsd:string .

ns1:MINAENDW a ns1:Parametro ;
    rdfs:label "MINAENDW" ;
    ns1:identificador "MINAENDW" ;
    ns1:textoExtracto "Este parámetro define el tiempo que mínimamente debe permanecer activa la señal AUXEND para que el CNC la interprete como señal válida.",
        "MINAENDW Duración mínima de la señal AUXEND. Valores posibles: De 0 a 65535 ms. Valor por defecto: 10 ms.",
        "Para las funciones –M– que no necesitan sincronización, este parámetro indica la duración de la señal MSTROBE. Para las funciones –H– (que no necesitan sincronización) este parámetro indica la duración de la señal HSTROBE." ;
    ns1:valor 10 .

ns1:MINFLWE a ns1:Parametro ;
    rdfs:label "MINFLWE" ;
    ns1:documentadoEn ns1:TablaParametrosPuestaMarcha ;
    ns1:identificador "MINFLWE" ;
    ns1:textoExtracto "Este parámetro indica el máximo error de seguimiento permitido cuando el eje está parado."@es .

ns1:MINOVR a ns1:Parametro ;
    rdfs:label "MINOVR" ;
    ns1:identificador "MINOVR" ;
    ns1:textoExtracto "Nunca se podrán superar los límites definidos mediante los parámetros máquina MINOVR y MAXOVR." .

ns1:MMCWDG a ns1:Parametro ;
    rdfs:label "MMCWDG" ;
    ns1:textoExtracto "MMCWDG [...] indica el estado del sistema operativo. Tiene el valor (=0) cuando el sistema operativo CNC funciona correctamente y valor (=1) en caso de bloqueo del sistema operativo." ;
    ns1:valor "0 (operativo), 1 (bloqueo)" .

ns1:MPGRESOL a ns1:Parametro ;
    rdfs:label "MPGRESOL" ;
    ns1:textoExtracto "Para fijar la resolución de cada volante, cuánto avanza en cada una de las posiciones del conmutador, se debe personalizar el parámetro MPGRESOL." .

ns1:MacrosProGTL3_Preasignadas a ns1:Sistema ;
    rdfs:label "Macros preasignadas ProGTL3" ;
    ns1:cumpleNormativa ns1:DirectivaFagor_ProGTL3 ;
    ns1:textoExtracto "Algunas de estas subrutinas tienen un funcionamiento preasignado por Fagor como macros del lenguaje ProGTL3. Si se programa una de estas funciones G, el CNC ejecuta la macro correspondiente y no la subrutina." .

