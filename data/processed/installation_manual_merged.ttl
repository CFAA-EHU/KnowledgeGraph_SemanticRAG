    ns1:identificador "RETRACE" ;
    ns1:monitoreaParametro ns1:FuncionRetrace ;
    ns1:textoExtracto "cuando al PLC pone a (=0) la marca RETRACE del canal" .

ns1:Parametro_e9608b7c72 a ns1:Parametro ;
    rdfs:label "Parámetro TDATA1 (primer contacto)"@es ;
    ns1:monitoreaParametro ns1:ProcesoDeMedicionConRelojComparadorParaCabezalAngularYZ45 ;
    ns1:textoExtracto """\r
    Cálculo del parámetro TDATA1. Primer contacto: 1) Posicionar los ejes rotativos B y C en 0º. B=0º C=0º 2) Colocar el reloj sobre la mesa, en la dirección del eje Y. 3) Desplazar la mesa en el eje Y hasta que el reloj y el cilindro se toquen en el punto 1. 4) Preseleccionar Y=R, para que Y=0 coincida con el eje del cilindro colocado en el cabezal."""@es ;
    ns1:valor "Y=R" .

ns1:Parametro_e9e52258b6 a ns1:Parametro ;
    rdfs:label "SHORTESTWAY"@es ;
    ns1:monitoreaParametro ns1:SistemaEjesRotativos ;
    ns1:textoExtracto "Posicionamiento por el camino más corto (SHORTESTWAY = Sí)"@es ;
    ns1:valor "Sí/No"@es .

ns1:Parametro_ea61769241 a ns1:Parametro ;
    rdfs:label "CORNERJERK" ;
    ns1:identificador "V.[ch].MPA.CORNERJERK[set].xn" ;
    ns1:textoExtracto "CORNERJERK Jerk máximo permitido en las esquinas. Parámetro válido para ejes lineales, rotativos y cabezales. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0 a 1E+009 mm/s³. Valores posibles (2): De 0 a 39370078.74016 inch/s³. Valores posibles (3): De 0 a 1E+009 grados/s³. Valor por defecto: 0." ;
    ns1:valor "0" .

