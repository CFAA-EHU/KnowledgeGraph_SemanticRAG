ns1:InstruccionesAccion_PLC_4_4 a ns1:Sistema ;
    rdfs:label "Instrucciones de acción del PLC (Sección 4.4)"@es ;
    ns1:textoExtracto "Las instrucciones de acción, en función del resultado obtenido en la expresión lógica permiten alterar el estado de los recursos del PLC y de las marcas de comunicación CNC-PLC. [...] Las instrucciones de acción pueden alterar el estado de todos los recursos del PLC excepto de las entradas físicas utilizadas."@es ;
    ns1:tieneComponente ns1:Contador_CPR1,
        ns1:Entrada_I2,
        ns1:Marca_M100,
        ns1:Salida_O3,
