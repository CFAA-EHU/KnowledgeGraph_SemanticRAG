ns1:ModoOperacion_GapInvertido a ns1:ModoOperacion ;
    rdfs:label "Modo de operación con eje Z invertido (gap)"@es ;
    ns1:ilustradoEn ns1:Tabla_2.3.31_ControlGap ;
    ns1:textoExtracto "El sentido positivo del eje Z es hacia abajo y el negativo hacia arriba (eje Z invertido). El eje se mueve en sentido positivo (hacia abajo) para alcanzar el gap."@es .

ns1:ModoOperacion_GapNormal a ns1:ModoOperacion ;
