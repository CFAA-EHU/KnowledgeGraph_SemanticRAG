ns1:TablaCinematicas a ns1:Tabla ;
    rdfs:label "tabla de cinemáticas"@es ;
    ns1:textoExtracto "Parámetros de la tabla de cinemáticas. Estos parámetros indican el tipo y características de cada una de las cinemáticas."@es .

