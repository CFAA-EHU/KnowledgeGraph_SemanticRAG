    ns1:identificador "(V.)[ch].MPA.HPITCH.xn" ;
    ns1:monitoreaParametro ns1:HIRTHEjeConDentadoHirth_d9f50b062d ;
    ns1:textoExtracto "Paso del eje Hirth. Parámetro válido para ejes lineales y rotativos. Parámetro válido para regulador analógico, Sercos y simulado. Valores posibles (1): De 0 a 99999.9999 mm. Valores posibles (2): De 0 a 3937.00787 inch. Valores posibles (3): De 0 a 99999.9999 grados. Valor por defecto: 1 mm / 0.03937 inch / 1 grado. Variable asociada: (V.)[ch].MPA.HPITCH.xn"@es ;
    ns1:valor "1 mm / 0.03937 inch / 1 grado" .

