ns1:Senal_PARK a ns1:InterfazUsuario ;
    rdfs:label "Señal PARK",
        "Señal PARK"@es ;
    ns1:monitoreaParametro ns1:Parametro_Aparcado ;
    ns1:textoExtracto "El CNC utiliza las señales PARK y UNPARK para informar al PLC que se ha desencadenado el proceso correspondiente de aparcar o desaparcar.",
        "El CNC utiliza las señales PARK y UNPARK para informar al PLC que se ha desencadenado el proceso correspondiente de aparcar o desaparcar."@es .

ns1:Senal_SSTROBE a ns1:ComponenteElectrico ;
    rdfs:label "SSTROBE" ;
    ns1:textoExtracto "activa la marca SSTROBE para que el PLC las ejecute.",
        "El CNC activa la salida lógica general SSTROBE para indicar al PLC que debe ejecutarla [función S]."@es .

ns1:Senal_TCHANGEOKMZ1 a ns1:Parametro ;
    rdfs:label "TCHANGEOKMZ1" ;
    ns1:identificador "TCHANGEOKMZ1" ;
