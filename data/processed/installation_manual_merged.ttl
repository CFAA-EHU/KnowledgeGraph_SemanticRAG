    ns1:identificador "INTEREND, INTERENDC1, INTERENDC2, INTERENDC3, INTERENDC4" ;
    ns1:textoExtracto "El canal del CNC pone la marca INTEREND a (=1) cuando ha finalizado el desplazamiento teórico de los ejes (cuando deja de enviar consigna)." .

ns1:Senal_IRESET a ns1:AccionProhibida ;
    rdfs:label "IRESET(axis)" ;
    ns1:textoExtracto "Si el PLC activa la marca IRESET(axis), cancela el proceso de latcheo en el eje y el interpolador independiente desactiva la marca LATCH1ACTIVE(axis) o LATCH2ACTIVE(axis) asociada al proceso." .

ns1:Senal_PLCCNTL a ns1:Parametro ;
    rdfs:label "PLCCNTL" ;
    ns1:textoExtracto "Cuando el PLC pone la marca PLCCNTL a (=1), el cabezal decelera con rampa hasta detenerse y pasa a estar controlado por el PLC.",
        "no se tienen en cuenta las señales PLCCNTL [...] durante el roscado" ;
    ns1:valor "1" .

ns1:Senal_READYC1 a ns1:Parametro ;
    rdfs:label "READYC1" ;
    ns1:monitoreaParametro ns1:CanalCNC_1 ;
    ns1:textoExtracto "Esta marca indica el estado del canal del CNC. Tiene el valor (=0) cuando el CNC se encuentra en estado de error (ventana de status en rojo) y el valor (=1) el resto de los casos." ;
    ns1:valor "0,1" .

ns1:Senal_READYC2 a ns1:Parametro ;
    rdfs:label "READYC2" ;
    ns1:monitoreaParametro ns1:CanalCNC_2 ;
    ns1:textoExtracto "Esta marca indica el estado del canal del CNC. Tiene el valor (=0) cuando el CNC se encuentra en estado de error (ventana de status en rojo) y el valor (=1) el resto de los casos." ;
    ns1:valor "0,1" .

ns1:Senal_READYC3 a ns1:Parametro ;
    rdfs:label "READYC3" ;
    ns1:monitoreaParametro ns1:CanalCNC_3 ;
    ns1:textoExtracto "Esta marca indica el estado del canal del CNC. Tiene el valor (=0) cuando el CNC se encuentra en estado de error (ventana de status en rojo) y el valor (=1) el resto de los casos." ;
    ns1:valor "0,1" .

ns1:Senal_READYC4 a ns1:Parametro ;
    rdfs:label "READYC4" ;
    ns1:monitoreaParametro ns1:CanalCNC_4 ;
    ns1:textoExtracto "Esta marca indica el estado del canal del CNC. Tiene el valor (=0) cuando el CNC se encuentra en estado de error (ventana de status en rojo) y el valor (=1) el resto de los casos." ;
    ns1:valor "0,1" .

ns1:Senal_RIGID a ns1:InterfazUsuario ;
    rdfs:label "Señal RIGID (roscado rígido)" ;
    ns1:identificador "RIGID, RIGIDC1, RIGIDC2, RIGIDC3, RIGIDC4" ;
    ns1:textoExtracto "Hay una marca para cada canal. [...] El canal del CNC pone esta marca a (=1) cuando está ejecutando un bloque de roscado rígido (G63). Los roscados con macho (G84 en fresadora y G83 en torno) parametrizados como roscados rígidos ponen esta marca a (=1) durante todo el roscado, incluida la temporización en el fondo de la rosca." .

ns1:Senal_RoscadoMacho a ns1:InterfazUsuario ;
    rdfs:label "Señal de ciclo fijo de roscado con macho" ;
    ns1:textoExtracto "CNC pone esta marca a (=1) cuando está ejecutando el ciclo fijo de roscado con macho. La marca se mantiene activa durante la posible temporización que se haya programado en el fondo de la rosca." .

ns1:Senal_SERCOSRDY a ns1:Parametro ;
    rdfs:label "SERCOSRDY" ;
    ns1:monitoreaParametro ns1:AnilloSercos ;
    ns1:textoExtracto "En las configuraciones Sercos, esta marca indica el estado del anillo. El CNC pone esta marca a (=1) para indicar que el anillo Sercos se encuentra inicializado correctamente." ;
    ns1:valor "0,1" .

ns1:Senal_SERVOON a ns1:ComponenteElectrico,
        ns1:Parametro ;
    rdfs:label "SERVOON",
        "Señal SERVOON" ;
    ns1:monitoreaParametro ns1:Parametro_DWELL ;
    ns1:textoExtracto "se espera a la señal SERVOON (en el caso de tener DWELL).",
        "la señal SERVOON que el regulador está listo"@es .

ns1:Senal_SPDLEREV a ns1:Parametro ;
    rdfs:label "SPDLEREV" ;
    ns1:textoExtracto "no se tienen en cuenta las señales SPDLEREV [...] durante el roscado" .

ns1:Senal_STARTC1 a ns1:Parametro ;
    rdfs:label "STARTC1" ;
    ns1:monitoreaParametro ns1:InterfazPanelMando ;
    ns1:textoExtracto "El canal del CNC activa esta marca para indicar al PLC que se ha pulsado la tecla [START] del panel de mando." ;
    ns1:valor "0,1" .

ns1:Senal_SYNCHRON a ns1:Parametro ;
    rdfs:label "SYNCHRON" ;
    ns1:identificador "SYNCHRON1, SYNCHRON2, SYNCHRON3, SYNCHRON4, SYNCHRON5, SYNCHRON6" ;
    ns1:textoExtracto "Hay una marca para cada cabezal." .

ns1:Senal_SYNCMASTER a ns1:Parametro ;
    rdfs:label "SYNCMASTER" ;
    ns1:identificador "SYNCMASTER1, SYNCMASTER2, SYNCMASTER3, SYNCMASTER4, SYNCMASTER5, SYNCMASTER6" ;
