ns1:InstruccionADS a ns1:Parametro ;
    rdfs:label "Instrucción ADS (suma)"@es ;
    ns1:documentadoEn ns1:SeccionInstruccionesAritmeticas ;
    ns1:identificador "ADS" ;
    ns1:textoExtracto "=ADS R100 R101 R102 ; R102 = 1234 + 100 = 1334"@es .

ns1:InstruccionAritmetica_MOV a ns1:Parametro ;
    rdfs:label "Instrucción aritmética MOV"@es ;
    ns1:documentadoEn ns1:InstruccionesProgramacionCNC_4_6 ;
    ns1:textoExtracto "= MOV Mover."@es .

ns1:InstruccionAsignacion_I a ns1:Parametro ;
    rdfs:label "Instrucción de asignación I"@es ;
    ns1:documentadoEn ns1:InstruccionesProgramacionCNC_4_6 ;
    ns1:textoExtracto "= I 1/1024"@es ;
    ns1:valor "1/1024" .

ns1:InstruccionAsignacion_M a ns1:Parametro ;
    rdfs:label "Instrucción de asignación M"@es ;
    ns1:documentadoEn ns1:InstruccionesProgramacionCNC_4_6 ;
    ns1:textoExtracto "= M 1/8192"@es ;
    ns1:valor "1/8192" .

ns1:InstruccionAsignacion_O a ns1:Parametro ;
    rdfs:label "Instrucción de asignación O"@es ;
    ns1:documentadoEn ns1:InstruccionesProgramacionCNC_4_6 ;
    ns1:textoExtracto "= O 1/1024"@es ;
    ns1:valor "1/1024" .

ns1:InstruccionBinaria_Asignacion_TG1_T4 a ns1:TareaMantenimiento ;
    rdfs:label "Asignación de entrada TG1 a temporizador T4"@es ;
    ns1:identificador "TG1 4 100" ;
    ns1:textoExtracto "Asigna a la entrada de arranque TG1 del temporizador T4 el estado de la entrada I3, por lo que un flanco de subida en I3 activará la entrada de arranque TG1 del temporizador T4."@es .

ns1:InstruccionBinaria_ExpresionLogica_M111 a ns1:TareaMantenimiento ;
    rdfs:label "Asignación de expresión lógica a marca M111"@es ;
    ns1:identificador "M111" ;
    ns1:textoExtracto "Asigna a la marca M111 el valor obtenido en la evaluación de la Expresión lógica (I2 OR I3) AND (I4 OR (NOT I5 AND I6))."@es .

ns1:InstruccionCondicional_RES a ns1:Parametro ;
    rdfs:label "Instrucción condicional RES"@es ;
    ns1:documentadoEn ns1:InstruccionesProgramacionCNC_4_6 ;
    ns1:textoExtracto "= RES Si expresión \"1\" asigna \"0\" al recurso."@es .

ns1:InstruccionCondicional_SET a ns1:Parametro ;
    rdfs:label "Instrucción condicional SET"@es ;
    ns1:documentadoEn ns1:InstruccionesProgramacionCNC_4_6 ;
    ns1:textoExtracto "= SET Si expresión \"1\" asigna \"1\" al recurso."@es .

ns1:InstruccionDVS a ns1:Parametro ;
    rdfs:label "Instrucción DVS (división)"@es ;
    ns1:documentadoEn ns1:SeccionInstruccionesAritmeticas ;
    ns1:identificador "DVS" ;
    ns1:textoExtracto "=DVS R100 R101 R105 ; R105 = 1234 : 100 = 12"@es .

ns1:InstruccionMDS a ns1:Parametro ;
    rdfs:label "Instrucción MDS (módulo)"@es ;
    ns1:documentadoEn ns1:SeccionInstruccionesAritmeticas ;
    ns1:identificador "MDS" ;
    ns1:textoExtracto "=MDS R100 R101 R106 ; R106 = 1234 MOD 100 = 34"@es .

ns1:InstruccionMLS a ns1:Parametro ;
    rdfs:label "Instrucción MLS (multiplicación)"@es ;
    ns1:documentadoEn ns1:SeccionInstruccionesAritmeticas ;
    ns1:identificador "MLS" ;
    ns1:textoExtracto "=MLS R100 R101 R104 ; R104 = 1234 x 100 = 123400"@es .

ns1:InstruccionRuptura_JMP a ns1:Parametro ;
    rdfs:label "Instrucción de ruptura JMP"@es ;
    ns1:documentadoEn ns1:InstruccionesProgramacionCNC_4_6 ;
    ns1:textoExtracto "= JMP L Salto incondicional."@es .

ns1:InstruccionSBS a ns1:Parametro ;
    rdfs:label "Instrucción SBS (resta)"@es ;
    ns1:documentadoEn ns1:SeccionInstruccionesAritmeticas ;
    ns1:identificador "SBS" ;
    ns1:textoExtracto "=SBS R100 R101 R103 ; R103 = 1234 - 100 = 1134"@es .

ns1:Instruccion_ADS_R1_1024 a ns1:AccionProhibida ;
    rdfs:label "ADS R1/1024 (Suma aritmética)" ;
    ns1:identificador "ADS R1/1024" ;
    ns1:textoExtracto "ADS R1/1024 R1/1024 R1/1024" .

ns1:Instruccion_CAL a ns1:AccionProhibida ;
    rdfs:label "CAL (Llamada a subrutina)"@es ;
    ns1:identificador "CAL" ;
    ns1:textoExtracto "= CAL Llamada a subrutina. Si el resultado obtenido en la evaluación de la expresión lógica es un '1' esta acción ejecuta la subrutina indicada. Si el resultado obtenido en la evaluación de la expresión lógica es un '0' esta acción será ignorada por el PLC, continuando el programa sin ejecutar dicha subrutina."@es .

ns1:Instruccion_CPL a ns1:AccionProhibida ;
    rdfs:label "Instrucción CPL" ;
    ns1:identificador "CPL" ;
    ns1:textoExtracto "Si expresión \"1\" complementa el recurso. Si el resultado obtenido en la evaluación de la expresión lógica es un \"1\" complementa el estado del recurso especificado. Si el resultado es un \"0\", no modificará el recurso." .

ns1:Instruccion_CPS_C123_GT_1000 a ns1:TareaMantenimiento ;
    rdfs:label "Instrucción CPS C123 > 1000" ;
    ns1:activaAlarma ns1:Marca_M100 ;
    ns1:monitoreaParametro ns1:Parametro_ValorCuentaContador ;
    ns1:textoExtracto "CPS C123 GT 1000 = M100. Compara si la cuenta de C123 es mayor que 1000, en cuyo caso activa la marca M100." .

