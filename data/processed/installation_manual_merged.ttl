ns1:Sistema_DMC a ns1:Sistema ;
    rdfs:label "DMC (Control Dinámico del Mecanizado)",
        "DMC (Dynamic Machining Control)",
        "Sistema DMC (Dynamic Motion Control)",
        "DMC"@es,
        "Sistema DMC (Dynamic Machining Control)"@es ;
    ns1:activaAlarma ns1:AvisoSeguridad_DMCPWRPEAK,
        ns1:AvisoSeguridad_WarningPotenciaDMC ;
    ns1:controla ns1:Parametro_MAXDMCOVR,
        ns1:Parametro_MINDMCOVR ;
    ns1:monitoreaParametro ns1:Parametro_DMCPEAKSIZE,
        ns1:Parametro_DMC_ACTPWR,
        ns1:Parametro_DMC_FZ,
        ns1:Parametro_DMC_LEARNEDPWRSP,
        ns1:Parametro_DMC_NOLOADPWR,
        ns1:Parametro_DMC_OVR,
        ns1:Parametro_DMC_PotenciaCabezalVacio,
        ns1:Parametro_DMC_SAVEDTIME,
        ns1:Parametro_DMC_TiempoAhorrado,
        ns1:Parametro_FZMAX,
        ns1:Parametro_FZMAX_DMCON,
        ns1:Parametro_FZMIN,
        ns1:Parametro_FZMIN_DMCON,
        ns1:Parametro_OVRMAX,
        ns1:Parametro_OVRMAX_DMCON,
        ns1:Parametro_OVRMIN,
        ns1:Parametro_OVRMIN_DMCON ;
    ns1:textoExtracto "#DMC ON/OFF [...] función #DMC [...] DMCON",
        "Configuración del DMC",
        "Sistema de control dinámico que calcula y mide parámetros como potencia, avance y tiempo en procesos de mecanizado.",
        "control dinámico del mecanizado (DMC)",
        "Configuración del DMC [...] monitorizar los picos de potencia en el DMC."@es,
        "El porcentaje fijado por el DMC afecta al porcentaje fijado desde el conmutador. [...] El DMC podrá modificar su override dentro de los límites fijados por la sentencia #DMCON"@es,
        "Potencia del cabezal en vacío medida por el DMC [...] Tiempo ahorrado por acción del DMC"@es ;
    ns1:tieneComponente ns1:Parametro_DMCPWRFACTOR,
        ns1:Parametro_DMCPWRHOLD,
        ns1:Parametro_DMCPWRPEAK,
        ns1:Parametro_FZMAX,
        ns1:Parametro_FZMIN,
        ns1:Parametro_OVRMAX,
        ns1:Parametro_OVRMIN .

