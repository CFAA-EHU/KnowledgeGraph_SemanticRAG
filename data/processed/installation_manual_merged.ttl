ns1:Subrutina_Sub_Probe_Piece_Begin a ns1:Componente,
        ns1:InterfazUsuario,
        ns1:Sistema ;
    rdfs:label "Sub_Probe_Piece_Begin.fst",
        "Subrutina Sub_Probe_Piece_Begin",
        "Subrutina Sub_Probe_Piece_Begin.fst" ;
    ns1:controla ns1:Marca_PROBE1MONIT,
        ns1:Marca_PROBE2MONIT ;
    ns1:documentadoEn ns1:Manual_CicloMedicion ;
    ns1:habilitadoPor ns1:Marca_PROBE1ENA,
        ns1:Marca_PROBE2ENA ;
    ns1:identificador "Sub_Probe_Piece_Begin.fst" ;
    ns1:mitigaRiesgo ns1:AvisoModoNoSeguro ;
    ns1:requiereMantenimiento ns1:Sistema_Palpador ;
    ns1:textoExtracto "El nombre de las subrutinas es Sub_Probe_Piece_Begin.fst [...] Al ser una subrutina OEM con extensión fst, el CNC carga esta subrutina en la memoria RAM del CNC.",
        "Estas marcas se deberían testear en las subrutinas Sub_Probe_Tool_Begin.fst y Sub_Probe_Piece_Begin.fst",
        "Se recomienda que OEM gestione ambas marca desde la subrutina Sub_Probe_Piece_Begin.fst para avisar, si están desactivadas, que el palpador está en modo no seguro.",
        "Subrutina asociada al inicio del ciclo de medición de pieza",
        "subrutina Sub_Probe_Piece_Begin.fst asociada a la entrada de palpador 2",
        "Ejemplo de subrutina Sub_Probe_Piece_Begin.fst suministrada por Fagor (a adaptar por el OEM). # ESBLK ; Activate PROBE 2 Hardware by PLC output. ; Check PROBE is READY with PLC Input from Probe Hardware. # MSG[\"WAIT FOR ENABLING PROBE2\"] #WAIT FOR[V.PLC.PROBE2ENA==1] ; Select PROBE 2 input for using in Probing. # SELECT PROBE[2] #FLUSH $IF [V.G.PRBST2==1] #WARNING[\"PROBE2 SIGNAL TOUCHING\"] M0 $ENDIF ; Check probe in safe mode feature is actived. $IF [V.PLC.PROBE2MONIT==0] #MSG[\"PROBE NOT IN SAFE MODE\"] $ENDIF #RETDSBLK"@en ;
    ns1:tieneComponente ns1:Sonda_Probe2 .

