    ns1:textoExtracto "Diagrama del modo monoestable (TG1): tras un flanco de subida en TG1, T pasa a 1 y t asciende linealmente hasta la constante de tiempo; al alcanzarla, T retorna a 0 y t se mantiene." .

ns1:ModoMonoestableTG1 a ns1:Parametro ;
    rdfs:label "Modo monoestable TG1" ;
    ns1:identificador "TG1" ;
    ns1:textoExtracto "TG1 activa el modo monoestable." .

