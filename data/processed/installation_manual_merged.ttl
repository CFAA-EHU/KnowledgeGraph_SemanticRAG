ns1:Sistema_AlmacenHerramientas_Sincrono a ns1:Sistema ;
    rdfs:label "Sistema de almacén síncrono con brazo cambiador (1 o 2 pinzas)"@es ;
    ns1:documentadoEn ns1:Tabla_GestionAlmacen ;
    ns1:textoExtracto "Los almacenes síncronos con brazo cambiador (1 o 2 pinzas), tienen el almacén próximo al cabezal. No es posible efectuar el cambio de herramienta durante el mecanizado de la pieza, porque el brazo entraría en colisión."@es .

ns1:Sistema_BusCAN a ns1:Sistema ;
    rdfs:label "Bus CAN",
        "Bus CAN (conmutador Address)",
        "Sistema de bus CAN",
        "Bus CAN"@es,
        "Bus CAN de interfaz de usuario"@es ;
    ns1:detalladoEnEsquema ns1:Tabla_VelocidadesCANopen ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionPanelesJog ;
    ns1:monitoreaParametro ns1:Parametro_DOMOD,
        ns1:Parametro_NDOMOD ;
    ns1:textoExtracto "Configuración del bus CAN. Bus CANfagor. Si se utiliza el tipo de bus CANfagor, hay que definir la longitud máxima del bus mediante el parámetro CANLENGTH. Bus CANopen. Si se utiliza el tipo de bus CANopen, la velocidad de trabajo se define en cada uno de los nodos.",
        "El CNC numera los paneles de mando según el orden que ocupan dentro del bus CAN (conmutador Address). El primer panel de jog será el de numeración más baja y así sucesivamente.",
        "bus CAN",
        "Bus CAN que integra paneles de jog y teclados. Cada marca PANELOFF afecta solo al panel de jog correspondiente sin alterar otros elementos del bus."@es,
        "El orden de los elementos dentro del bus CAN lo determina el conmutador 'Address'. El primer elemento será el de numeración más baja y así sucesivamente."@es ;
    ns1:tieneComponente ns1:InterfazUsuario_PanelJog,
        ns1:InterfazUsuario_PanelJog_1,
        ns1:Parametro_CANLENGTH,
        ns1:Parametro_CANMODE,
        ns1:Parametro_CANOPENFREQ,
        ns1:Tabla_DOMODADDR .

ns1:Sistema_BusSercos a ns1:Sistema ;
    rdfs:label "Bus Sercos" ;
    ns1:textoExtracto "anillo Sercos [...] módulos RCS-S del bus [...] dirección física, fijada por su conmutador rotativo (número de nodo)." ;
    ns1:tieneComponente ns1:Modulo_RCS_S .

ns1:Sistema_CabezalAngular a ns1:Sistema ;
    rdfs:label "Cabezal angular",
        "Cabezal angular con ejes rotativos B y C",
        "Sistema de cabezal angular con ejes rotativos B y C"@es ;
