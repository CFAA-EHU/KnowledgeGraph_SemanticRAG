ns1:Marcador_AUXEND a ns1:Componente ;
    rdfs:label "Marca AUXEND" ;
    ns1:textoExtracto "El PLC pone esta marca a (=1) para indicar al canal del CNC condiciones de finalización auxiliar." .

ns1:Marcador_BLKSKIP1 a ns1:Componente ;
    rdfs:label "Marca BLKSKIP1" ;
    ns1:textoExtracto "El PLC pone esta marca a (=1) para indicar al canal del CNC que la condición de salto de bloque '/' se cumple, por lo que no se ejecutarán los bloques que tengan esta condición." .

ns1:Marcador_IRESET a ns1:ComponenteElectrico ;
    rdfs:label "IRESET(axis)" ;
    ns1:textoExtracto "Si el PLC activa la marca IRESET(axis) se cancela el proceso de latcheo en el eje." .

ns1:Marcador_LATCH1ACTIVE a ns1:ComponenteElectrico ;
    rdfs:label "LATCH1ACTIVE(axis)" ;
    ns1:textoExtracto "LATCH1ACTIVE(axis) [...] El interpolador independiente activa esta marca al activar un proceso de latcheo en el eje con el palpador indicado; la desactiva cuando finaliza el proceso de latcheo o cuando se cancela el proceso." .

ns1:Marcador_LATCH2ACTIVE a ns1:ComponenteElectrico ;
    rdfs:label "LATCH2ACTIVE(axis)" ;
    ns1:textoExtracto "LATCH2ACTIVE(axis) [...] El interpolador independiente activa esta marca al activar un proceso de latcheo en el eje con el palpador indicado; la desactiva cuando finaliza el proceso de latcheo o cuando se cancela el proceso." .

ns1:Marcador_LATCHM a ns1:Componente ;
    rdfs:label "Marca LATCHM" ;
    ns1:textoExtracto "Esta marca permite seleccionar el tipo de funcionamiento de las teclas de JOG en el modo manual." .

ns1:Marcador_M01STOP a ns1:Componente ;
    rdfs:label "Marca M01STOP" ;
    ns1:textoExtracto "El PLC pone esta marca a (=1) para indicar al canal del CNC que tenga en cuenta las paradas condicionales (M01)." .

ns1:Marcador_PROBE1ACTIVE a ns1:ComponenteElectrico ;
    rdfs:label "PROBE1ACTIVE" ;
    ns1:textoExtracto "PROBE1ACTIVE [...] El interpolador independiente activa esta marca cuando hay algún proceso de latcheo activo con el palpador indicado y la desactiva cuando no hay ningún proceso de latcheo activo con el palpador indicado." .

ns1:Marcador_PROBE2ACTIVE a ns1:ComponenteElectrico ;
    rdfs:label "PROBE2ACTIVE" ;
    ns1:textoExtracto "PROBE2ACTIVE [...] El interpolador independiente activa esta marca cuando hay algún proceso de latcheo activo con el palpador indicado y la desactiva cuando no hay ningún proceso de latcheo activo con el palpador indicado." .

ns1:Marcador_RESETIN a ns1:Componente ;
    rdfs:label "Marca RESETIN" ;
    ns1:monitoreaParametro ns1:Parametro_MINAENDW ;
    ns1:textoExtracto "El PLC activa la marca RESETIN." .

ns1:Marcador_RESETOUT a ns1:Componente ;
    rdfs:label "Marca RESETOUT" ;
    ns1:textoExtracto "El canal activa la marca RESETOUT. Esta marca permanece activa el tiempo fijado en el parámetro general MINAENDW." .

ns1:MarcasComunicacionCNC_648 a ns1:Parametro ;
    rdfs:label "Marcas de comunicación CNC-PLC"@es ;
    ns1:textoExtracto "marcas [...] de comunicación CNC-PLC"@es .

ns1:MarcasPLC_703 a ns1:ComponenteElectrico ;
    rdfs:label "Marcas del PLC para control lógico y mensajes" ;
    ns1:monitoreaParametro ns1:Parametro_EstadoLogico_703 ;
    ns1:textoExtracto "intercambio de información [...] mediante determinadas Marcas y Registros del PLC. [...] Generar mensajes y errores en el CNC, mediante determinadas Marcas del PLC."@es .

ns1:MarcasPROBE1MONIT_PROBE2MONIT a ns1:Parametro ;
    rdfs:label "Marcas PROBE1MONIT/PROBE2MONIT"@es ;
    ns1:monitoreaParametro ns1:ModoSeguroPalpador ;
    ns1:textoExtracto "Gestión de las marcas PROBE1MONIT/PROBE2MONIT en la subrutina. Estas marcas están asociadas al modo seguro del palpador."@es .

ns1:MarcasRegistrosLegacy_872 a ns1:InterfazUsuario ;
    rdfs:label "Marcas y registros de versiones anteriores (compatibilidad)"@es ;
    ns1:identificador "V2.00" ;
    ns1:textoExtracto "El CNC mantiene la compatibilidad con las marcas y registros de versiones anteriores, cuyos mnemónicos no hacen referencia a ningún canal o almacén en particular. A partir de la versión de software V2.00 estas señales hacen referencia al primer canal o almacén, según corresponda."@es .

ns1:Matriz_Jog_1_15_433 a ns1:ComponenteElectrico ;
    rdfs:label "Matriz de teclas jog 1-15 (OP-PANEL)"@es ;
    ns1:textoExtracto "matriz de jog 1–15"@es .

ns1:MecanismoDesplazamientoAlmacen a ns1:ComponenteMecanico ;
    rdfs:label "Mecanismo de desplazamiento del almacén"@es ;
    ns1:textoExtracto "Utilizar funciones auxiliares para gobernar desde la rutina M06 los desplazamientos de los distintos dispositivos (giro almacén, desplazamiento almacén, brazo cambiador, etc.)."@es .

ns1:MecanismoGiroAlmacen a ns1:ComponenteMecanico ;
    rdfs:label "Mecanismo de giro del almacén"@es ;
    ns1:textoExtracto "Utilizar funciones auxiliares para gobernar desde la rutina M06 los desplazamientos de los distintos dispositivos (giro almacén, desplazamiento almacén, brazo cambiador, etc.)."@es .

ns1:MensajeExtraerHerramienta a ns1:AvisoSeguridad ;
    rdfs:label "Mensaje: Extraer herramienta T%D y pulsar MARCHA"@es ;
    ns1:textoExtracto "# MSG [\"Extraer herramienta T%D y pulsar MARCHA\", V.TM.TOOL] ; Mensaje al operario para que quite la herramienta."@es .

ns1:MensajeInsertarHerramienta a ns1:AvisoSeguridad ;
    rdfs:label "Mensaje: Insertar herramienta T%D y pulsar MARCHA"@es ;
    ns1:textoExtracto "# MSG [\"Insertar herramienta T%D y pulsar MARCHA\", V.TM.NXTOOL] ; Mensaje al operario para que ponga la herramienta."@es .

ns1:MensajeOperario_ExtraerHerramienta a ns1:InterfazUsuario ;
    rdfs:label "Mensaje: Extraer herramienta T%D"@es,
        "Mensaje: Extraer herramienta T%D y pulsar MARCHA"@es ;
    ns1:textoExtracto """\r
    # MSG ["Extraer herramienta T%D y pulsar MARCHA", V.TM.TOOL] ; Mensaje al operario para que quite la herramienta."""@es,
        "# MSG [\"Extraer herramienta T%D y pulsar MARCHA\", V.TM.TOOL]"@es .

ns1:MensajeOperario_InsertarHerramienta a ns1:InterfazUsuario ;
    rdfs:label "Mensaje: Insertar herramienta T%D"@es,
        "Mensaje: Insertar herramienta T%D y pulsar MARCHA"@es ;
    ns1:textoExtracto """\r
    # MSG ["Insertar herramienta T%D y pulsar MARCHA", V.TM.NXTOOL] ; Mensaje al operario para que ponga la herramienta."""@es,
        "# MSG [\"Insertar herramienta T%D y pulsar MARCHA\", V.TM.NXTOOL]"@es .

ns1:Menu_Configuracion_NEXT a ns1:InterfazUsuario ;
    rdfs:label "Menú de configuración (tecla NEXT)" ;
    ns1:textoExtracto "El menú estará deshabilitado. [...] El menú muestra los componentes o modos de trabajo del CNC."@es ;
    ns1:tieneComponente ns1:Opcion_Canales,
        ns1:Opcion_Componentes,
        ns1:Opcion_Deshabilitado,
        ns1:Opcion_Paginas .

ns1:MesaTipo52 a ns1:ComponenteMecanico ;
    rdfs:label "Mesa (cinemática tipo 52)"@es ;
    ns1:textoExtracto "Mesa: T4: Vector traslación del tercer eje rotativo. T5: Vector traslación del cuarto eje rotativo."@es ;
    ns1:tieneComponente ns1:EjeRotativo3_Mesa,
        ns1:EjeRotativo4_Mesa .

ns1:MicroEjeEsclavo a ns1:Sensor ;
    rdfs:label "Micro (eje esclavo)" ;
    ns1:controla ns1:SistemaBusquedaReferenciaEjesGantry ;
    ns1:textoExtracto "hasta que el segundo eje pulse su micro" .

ns1:MicroEjeMaestro a ns1:Sensor ;
    rdfs:label "Micro (eje maestro)" ;
    ns1:controla ns1:SistemaBusquedaReferenciaEjesGantry ;
    ns1:textoExtracto "hasta que alguno de los ejes pulse su micro",
        "hasta que el eje que pulsó el micro encuentra el I0" .

ns1:MicroReferencia_1097 a ns1:Sensor ;
    rdfs:label "Micro de referencia máquina"@es ;
    ns1:textoExtracto "El fabricante debe colocar, en cada eje, un micro de referencia en la posición que ocupa el punto de referencia máquina. Al iniciar la búsqueda, el eje se desplaza... hasta que pulsa el micro de referencia máquina."@es .

ns1:MicrointerruptorReferencia a ns1:ComponenteElectrico ;
    rdfs:label "micro (interruptor de referencia)"@es ;
    ns1:textoExtracto "Si alguno de los ejes del grupo programado no dispone de micro, el eje espera a que los demás lleguen a sus micros"@es .

ns1:ModoCargaAlmacen_7.5 a ns1:ModoOperacion ;
    rdfs:label "Modo de carga de almacén"@es ;
    ns1:identificador "V.TM.MZMODE=1" ;
    ns1:textoExtracto "Personalizar la variable V.TM.MZMODE=1, para indicar al gestor que se desea trabajar en modo de carga de almacén."@es .

ns1:ModoDescargaAlmacen_7.5 a ns1:ModoOperacion ;
    rdfs:label "Modo de descarga de almacén"@es ;
    ns1:identificador "V.TM.MZMODE=2" ;
    ns1:textoExtracto "Personalizar la variable V.TM.MZMODE=2, para indicar al gestor que se desea trabajar en modo descarga de almacén."@es .

ns1:ModoDiagnostico_CNC8070 a ns1:ModoOperacion ;
    rdfs:label "Modo diagnosis del CNC"@es ;
    ns1:monitoreaParametro ns1:Parametro_RecursosSistema_CNC8070 ;
    ns1:textoExtracto "Esta información la puede consultar dentro del **modo diagnosis** del CNC."@es .

ns1:ModoEjecucionSimulada a ns1:ModoOperacion ;
    rdfs:label "Ejecución simulada"@es,
        "Modo ejecución simulada (Funciones G)"@es ;
    ns1:textoExtracto "El CNC ejecuta la subrutina con la opción 'Funciones G' del modo ejecución simulada"@es,
        "V.S.EXECUTION = 0 ; Ejecución simulada; teórico o funciones G."@es ;
    ns1:valor "0" .

ns1:ModoHSC_CONTERROR a ns1:ModoOperacion ;
    rdfs:label "Modo HSC CONTERROR" ;
    ns1:textoExtracto "SLOPETYPE), que es el perfil de aceleración por defecto para el modo HSC CONTERROR. [...] Este parámetro activa un filtro automático FIR para todos los ejes del canal durante la ejecución en modo CONTERROR." .

ns1:ModoHSC_SURFACE a ns1:ModoOperacion ;
    rdfs:label "Modo HSC SURFACE" ;
    ns1:textoExtracto "FTIMELIM Diferencia de tiempo admisible en la interpolación del avance (modo FAST y SURFACE). [...] La interpolación del avance en los modos HSC FAST y SURFACE mejora la calidad del mecanizado." .

ns1:ModoInspeccionHerramienta a ns1:ModoOperacion ;
    rdfs:label "Modo de inspección de herramienta"@es ;
    ns1:textoExtracto "El entrar en el modo de inspección de herramienta, el DMC se desactiva. Al finalizar la inspección de herramienta, el DMC se activa automáticamente"@es .

ns1:ModoMDICNC a ns1:ModoOperacion ;
    rdfs:label "Modo MDI CNC"@es ;
    ns1:textoExtracto "; El CNC accede al modo MDI. [CTRL]+[F8]"@es .

ns1:ModoMDI_CNC a ns1:ModoOperacion ;
    rdfs:label "Modo MDI (CNC)" ;
    ns1:textoExtracto "El CNC accede al modo MDI." .

ns1:ModoManualCNC a ns1:ModoOperacion ;
    rdfs:label "Modo Manual CNC"@es,
        "Modo manual del CNC"@es ;
    ns1:textoExtracto "; El CNC accede al modo manual. [CTRL]+[F7]"@es,
        "Para llevar el eje a la zona permitida, acceder al modo manual y mover el eje o cabezal que ha sobrepasado el límite."@es .

ns1:ModoManual_CNC a ns1:ModoOperacion ;
    rdfs:label "Modo manual (CNC)" ;
    ns1:textoExtracto "El CNC accede al modo manual." .

ns1:ModoOperacion_AlmacenAsincrono a ns1:ModoOperacion ;
    rdfs:label "Modo de operación: Almacén asíncrono"@es ;
    ns1:identificador "Asíncrono" ;
    ns1:textoExtracto "El almacén está alejado del cabezal. La mayoría de los movimientos se pueden efectuar durante el mecanizado de la pieza, minimizando tiempos. El cambio de herramienta se realiza de la siguiente manera. (1)Durante el mecanizado, el almacén selecciona la nueva herramienta. El brazo cambiador coge la herramienta del almacén y la trae junto al cabezal. (2)El CNC finaliza el movimiento de los ejes. (3)La segunda pinza del brazo cambiador coge la herramienta del cabezal y efectúa el cambio. (4)El CNC continúa con la ejecución del programa y el brazo cambiador vuelve al almacén para dejar la herramienta."@es .

ns1:ModoOperacion_AlmacenSincrono a ns1:ModoOperacion ;
    rdfs:label "Modo de operación: Almacén síncrono"@es ;
    ns1:identificador "Síncrono" ;
    ns1:textoExtracto "En un almacén síncrono sin brazo cambiador el almacén debe desplazarse hasta el cabezal para efectuar el cambio. No es posible efectuar el cambio de herramienta durante el mecanizado de la pieza. El cambio de herramienta se realiza de la siguiente manera. (1)El CNC finaliza el movimiento de los ejes. (2)El almacén se aproxima al cabezal para coger la herramienta. (3)El almacén selecciona la nueva herramienta y la coloca en el cabezal. (4)El almacén se retira del cabezal. (5)El CNC continúa con la ejecución del programa."@es .

ns1:ModoOperacion_Auto a ns1:ModoOperacion ;
    rdfs:label "Modo automático (AUTO)" ;
    ns1:identificador "AUTO" ;
    ns1:textoExtracto "Modo automático. | AUTO | [CTRL]+[F6]" .

ns1:ModoOperacion_Automatico a ns1:ModoOperacion ;
    rdfs:label "Modo automático",
        "Modo de operación automático",
        "Modo automático"@es ;
    ns1:identificador "AUTOMAT, AUTOMATC1, AUTOMATC2, AUTOMATC3, AUTOMATC4" ;
    ns1:textoExtracto "El canal del CNC pone esta marca a (=1) cuando está seleccionado el modo de operación automático.",
        "Este parámetro indica el tipo de aceleración que se aplica por defecto en los movimientos automáticos.",
        "Para poder ejecutar la subrutina cuando no hay programa en ejecución, el canal debe estar en modo automático",
        "Si estando en modo automático se selecciona –bloque a bloque– se activan las marcas AUTOMAT y SBOUT.",
        "Un eje que vaya a trabajar como eje independiente debería tener definido el mismo feed forward en los modos automáticos y manual",
        "modo automático",
        "al pasar del modo automático al modo manual con G95 activa"@es .

ns1:ModoOperacion_AvanceConstante a ns1:ModoOperacion ;
    rdfs:label "Avance constante (G1/G2/G3)" ;
    ns1:mitigaRiesgo [ a ns1:AvisoSeguridad ;
            rdfs:label "Riesgo de excitación de frecuencias de la máquina" ;
            ns1:textoExtracto "Esta opción permite evitar posibles problemas de excitación de frecuencias de la máquina, obteniendo mejor calidad del corte, tanto en precisión como superficial."@es ] ;
    ns1:textoExtracto "El corte se ejecuta a avance constante (con el avance del G1/G2/G3 anterior), sin acelerar en los tramos en G0."@es .

ns1:ModoOperacion_AvanceRapido a ns1:ModoOperacion ;
    rdfs:label "Avance rápido (G0)" ;
    ns1:controla ns1:Parametro_G00FEED ;
    ns1:habilitadoPor ns1:Parametro_SWTG0FEED ;
    ns1:textoExtracto "Los tramos en G0 se ejecutan a avance rápido (parámetro G00FEED)."@es .

ns1:ModoOperacion_BloqueABloque a ns1:ModoOperacion ;
    rdfs:label "Modo de ejecución 'bloque a bloque'" ;
    ns1:identificador "SBOUT, SBOUTC1, SBOUTC2, SBOUTC3, SBOUTC4" ;
    ns1:textoExtracto "El canal del CNC pone esta marca a (=1) cuando está seleccionado el modo de ejecución 'bloque a bloque'.",
        "Si estando en modo automático se selecciona –bloque a bloque– se activan las marcas AUTOMAT y SBOUT. Si estando en modo manual se selecciona –bloque a bloque– se activan las marcas MANUAL y SBOUT." .

ns1:ModoOperacion_BusquedaBloque a ns1:ModoOperacion ;
    rdfs:label "Búsqueda de bloque" ;
    ns1:documentadoEn ns1:Pagina_141 ;
    ns1:textoExtracto "La búsqueda de bloque permite recuperar la historia del programa hasta un bloque determinado, que podrá estar en un programa o una subrutina, de tal forma que si a continuación se reanuda la ejecución a partir de ese bloque, lo hará en las mismas condiciones que si se hubiera ejecutado desde el principio." .

ns1:ModoOperacion_CNC_BusquedaReferencia a ns1:ModoOperacion ;
    rdfs:label "Modo CNC (búsqueda de referencia)"@es ;
    ns1:identificador "CNC" ;
    ns1:textoExtracto "El CNC realiza la búsqueda de referencia del eje como si éste fuera Sercos velocidad. El CNC ejecuta la homogeneización de parámetros como si el eje fuera Sercos velocidad."@es .

ns1:ModoOperacion_Cabezal a ns1:ModoOperacion ;
    rdfs:label "Modo de operación del cabezal (M3/M4)" ;
    ns1:textoExtracto "El parámetro SLOPETYPE no afecta al cabezal (M3/M4), que siempre utiliza aceleración con jerk [...] Cuando el cabezal trabaja como eje C, utilizará aceleración lineal o aceleración con jerk en función del tipo de mecanizado." .

ns1:ModoOperacion_CompensacionVolumetricaMedia a ns1:ModoOperacion ;
    rdfs:label "Compensación volumétrica media" ;
    ns1:habilitadoPor ns1:ModoOperacion_CompensacionVolumetricaBasica ;
    ns1:textoExtracto "La opción \"Compensación volumétrica media\" también permite utilizar la opción básica." .

ns1:ModoOperacion_DesplazamientoEje a ns1:ModoOperacion ;
    rdfs:label "Control de eje en desplazamientos" ;
    ns1:requiereMantenimiento ns1:TareaMantenimiento_AjusteDWELL ;
    ns1:textoExtracto "Cuando se desea controlar el eje sólo en los desplazamientos, se debe asignar al parámetro máquina DWELL un valor superior al tiempo entre 2 scan de PLC" .

ns1:ModoOperacion_EdicionSimulacion a ns1:ModoOperacion ;
    rdfs:label "Modo edición-simulación"@es ;
    ns1:textoExtracto "En el modo de trabajo edición - simulación hay una opción que permite calcular el tiempo que se necesitará para ejecutar la pieza con las condiciones de mecanizado establecidas en el programa."@es .

ns1:ModoOperacion_FACEAXIS a ns1:ModoOperacion ;
    rdfs:label "FACEAXIS" ;
    ns1:textoExtracto "El CNC sólo tiene en cuenta este parámetro cuando FACEAXIS = Sí." ;
    ns1:valor "Sí / No" .

ns1:ModoOperacion_G17 a ns1:ModoOperacion ;
    rdfs:label "Modo G17 (Plano XY)"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionEjesCNC ;
    ns1:identificador "G17" ;
    ns1:textoExtracto "G17: CHAXISNAME 1 (abscisas), CHAXISNAME 2 (ordenadas), CHAXISNAME 3 (longitudinal)."@es .

ns1:ModoOperacion_G18 a ns1:ModoOperacion ;
    rdfs:label "Modo G18 (Plano ZX)"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionEjesCNC ;
    ns1:identificador "G18" ;
    ns1:textoExtracto """\r
G18: CHAXISNAME 3 (abscisas), CHAXISNAME 1 (ordenadas), CHAXISNAME 2 (longitudinal).\r
El plano de trabajo siempre es G18; el parámetro máquina IPLANE no se aplica.\r
"""@es .

ns1:ModoOperacion_G19 a ns1:ModoOperacion ;
    rdfs:label "Modo G19 (Plano YZ)"@es ;
    ns1:documentadoEn ns1:Tabla_ConfiguracionEjesCNC ;
    ns1:identificador "G19" ;
    ns1:textoExtracto "G19: CHAXISNAME 2 (abscisas), CHAXISNAME 3 (ordenadas), CHAXISNAME 1 (longitudinal)."@es .

ns1:ModoOperacion_G90 a ns1:ModoOperacion ;
    rdfs:label "G90 (Posicionamiento absoluto)",
        "Modo G90 (absoluto)",
        "Modo de operación G90 (absoluto)" ;
    ns1:ilustradoEn ns1:Tabla_ConfiguracionEjeRotativo ;
    ns1:textoExtracto "El eje se desplaza por el camino más corto, hasta alcanzar la cota programada. Aunque el desplazamiento programado sea superior al módulo, el eje nunca da más de una vuelta.",
        "Movimientos en G90. | El eje se desplaza según su sentido predeterminado, hasta alcanzar la cota programada.",
        "Movimientos en G90: El signo de la cota indica el sentido del desplazamiento; el valor absoluto de la cota indica la posición final." .

ns1:ModoOperacion_G91 a ns1:ModoOperacion ;
    rdfs:label "G91 (Posicionamiento incremental)",
        "Modo G91 (incremental)",
        "Modo de operación G91 (incremental)" ;
    ns1:ilustradoEn ns1:Tabla_ConfiguracionEjeRotativo ;
    ns1:textoExtracto "Movimiento incremental normal. El signo de la cota indica el sentido del desplazamiento; el valor absoluto de la cota indica el incremento de posición. Si el desplazamiento programado es superior al módulo, el eje da más de una vuelta.",
        "Movimientos en G91. | El eje sólo admite movimientos según su sentido predeterminado. El signo de la cota indica el sentido del desplazamiento; el valor absoluto de la cota indica el incremento de posición.",
        "Movimientos en G91: Movimiento incremental normal. El signo de la cota indica el sentido del desplazamiento; el valor absoluto de la cota indica el incremento de posición." .

ns1:ModoOperacion_HSC_CONTERROR a ns1:ModoOperacion ;
    rdfs:label "HSC CONTERROR",
        "Modo HSC CONTERROR",
        "Modo HSC CONTERROR"@es,
        "Modo HSC CONTERROR (optimización de error cordal)"@es ;
    ns1:habilitadoPor ns1:Parametro_SLOPETYPE ;
    ns1:monitoreaParametro ns1:Parametro_CORNERJERK,
        ns1:Parametro_FILTER,
        ns1:Parametro_HSCFILTFREQ,
        ns1:Parametro_SLOPETYPE,
        ns1:Parametro_SMOOTHFREQ ;
    ns1:textoExtracto "Modo HSC CONTERROR cuando SLOPETYPE=Lineal. Modo HSC CONTERROR cuando SLOPETYPE=Trapezoidal. Modo HSC CONTERROR cuando SLOPETYPE=Seno cuadrado.",
        "Mecanizado HSC optimizando el error cordal (modo CONTERROR). En este modo el CNC modifica la geometría mediante algoritmos inteligentes de eliminación de puntos innecesarios y generación de splines o transiciones polinómicas entre los bloques, respetando siempre los límites de error impuestos para este modo."@es,
        "modo HSC CONTERROR"@es .

ns1:ModoOperacion_ManualVolantes a ns1:ModoOperacion ;
    rdfs:label "Modo manual con volantes"@es ;
    ns1:habilitadoPor ns1:InterfazUsuario_TecladoJog ;
    ns1:textoExtracto "2.7 Parámetros máquina del modo manual. - 2.7.1 Configuración de los volantes."@es,
        "Para mover un eje con un volante general, hay que seleccionar desde el teclado de jog el eje a desplazar. Para mover un eje con un volante individual, no hay que hacer ninguna selección previa."@es,
        "Si el CNC tiene varios volantes generales, cualquiera de ellos podrá desplazar los ejes seleccionados en modo volante."@es,
        "Si hay seleccionado un eje que tiene un volante individual asociado, este eje se podrá mover con el volante general, con el individual o con ambos a la vez."@es,
        "Si hay varios ejes seleccionados en modo volante, con el volante general se desplazarán todos ellos."@es .

ns1:ModoOperacion_ModoSeguroPalpador a ns1:ModoOperacion ;
    rdfs:label "Modo seguro del palpador"@es ;
    ns1:identificador "PROBE1MONIT",
        "PROBE2MONIT" ;
    ns1:textoExtracto "PROBE1MONIT PROBE2MONIT Estas marcas están asociadas al modo seguro del palpador. Si la marca está activa, el palpador está en modo seguro monitorizando colisiones."@es .

ns1:ModoOperacion_NEXT a ns1:ModoOperacion ;
    rdfs:label "NEXT" ;
    ns1:textoExtracto "NEXT El eje alcanza la posición indicada al avance especificado en el siguiente bloque." .

ns1:ModoOperacion_NULL a ns1:ModoOperacion ;
    rdfs:label "NULL" ;
    ns1:textoExtracto "NULL El eje alcanza la posición indicada a avance nulo." .

ns1:ModoOperacion_Regulador_BusquedaReferencia a ns1:ModoOperacion ;
    rdfs:label "Modo Regulador (búsqueda de referencia)"@es ;
    ns1:identificador "Regulador" ;
    ns1:textoExtracto "El regulador realiza la búsqueda de referencia del eje como si éste fuera Sercos posición."@es .

ns1:ModoOperacion_SURFACE a ns1:ModoOperacion ;
    rdfs:label "Modo SURFACE"@es ;
    ns1:textoExtracto "Los algoritmos más sofisticados del modo SURFACE hacen que los mecanizados sean más precisos."@es,
        "optimizando el acabado superficial (modo SURFACE)"@es .

ns1:ModoOperacion_SeleccionEjesVolante a ns1:ModoOperacion ;
    rdfs:label "Modo selección de ejes con volante y pulsador"@es ;
    ns1:textoExtracto "La selección de ejes se anula al salir del modo volante con el selector de movimientos y tras un reset. Esta marca está orientada a los volantes con pulsador. En este tipo de volantes, el pulsador permite seleccionar de forma secuencial el eje que se desea desplazar."@es .

ns1:ModoOperacion_SercosVelocidad a ns1:ModoOperacion ;
    rdfs:label "Modo Sercos velocidad",
        "Modo Sercos velocidad"@es ;
    ns1:textoExtracto "los cabezales lo hagan en modo Sercos velocidad. [...] Los ejes tándem deberán operar obligatoriamente en modo Sercos velocidad. [...] La consigna se envía al regulador en diezmilésimas de rpm del motor.",
        "el eje sólo podrá operar en modo Sercos velocidad"@es .

ns1:ModoOperacion_SingleBlock a ns1:ModoOperacion ;
    rdfs:label "Modo bloque a bloque (SINGLE)" ;
    ns1:identificador "SINGLE" ;
    ns1:textoExtracto "Modo bloque a bloque. | SINGLE | [CTRL]+[B]" .

ns1:ModoOperacion_TG1 a ns1:ModoOperacion ;
    rdfs:label "Modo monoestable (TG1)" ;
    ns1:identificador "TG1" ;
    ns1:textoExtracto "modo monoestable (TG1)" .

ns1:ModoOperacion_TG2 a ns1:ModoOperacion ;
    rdfs:label "Modo retardo a la conexión (TG2)" ;
    ns1:identificador "TG2" ;
    ns1:textoExtracto "modo de retardo a la conexión (TG2)" .

ns1:ModoOperacion_Torreta a ns1:ModoOperacion ;
    rdfs:label "Modo de operación: Torreta"@es ;
    ns1:identificador "Torreta" ;
    ns1:textoExtracto "Almacén típico de torno. No es posible efectuar el cambio de herramienta durante el mecanizado de la pieza. El cambio de herramienta se realiza de la siguiente manera. (1)El CNC finaliza el movimiento de los ejes. (2)El almacén se aleja del cabezal. (3)El almacén gira para colocar la nueva herramienta en la posición de trabajo. (4)El CNC continúa con la ejecución del programa."@es .

ns1:ModoOperacion_USER a ns1:ModoOperacion ;
    rdfs:label "Modo USER"@es,
        "Modo USER (modo de trabajo)"@es ;
    ns1:habilitadoPor ns1:InterfazUsuario_DiskMonitor ;
    ns1:textoExtracto "Con el CNC en modo USER, las rutinas OEM cuya extensión sea .fst, se cargan en la memoria RAM en el arranque de la aplicación CNC."@es,
        "Modo USER (modo de trabajo). En el encendido, el CNC verifica que existen passwords y la copia de seguridad. En caso de que no exista alguno de los dos, el CNC mostrará un mensaje indicando que la puesta a punto se encuentra sin finalizar."@es .

ns1:ModoOperacion_Usuario a ns1:ModoOperacion ;
    rdfs:label "Modo Usuario",
        "Modo de usuario",
        "Modo usuario (User Mode)"@es ;
    ns1:documentadoEn ns1:Tabla_ModosOperacionCNC ;
    ns1:textoExtracto "Modo de usuario. | [SHIFT]+[F1]",
        "Modo usuario. Es el modo habitual de trabajo para el",
        "Modo usuario (User Mode)."@es .

ns1:ModoOperacion_Utilidades a ns1:ModoOperacion ;
    rdfs:label "Modo utilidades (UTILITIES)" ;
    ns1:identificador "UTILITIES" ;
    ns1:textoExtracto "Modo utilidades. | UTILITIES | [CTRL]+[F12]" .

ns1:ModoOperacion_ValoresImagen a ns1:ModoOperacion ;
    rdfs:label "Modo de operación con valores imagen (IMA)"@es ;
    ns1:identificador "IMA" ;
    ns1:textoExtracto "necesita 4 ciclos con valores imagen (IMA). [...] trabajar con valores imagen (IMA) permite analizar un mismo recurso a lo largo del programa con el mismo valor, independientemente del valor real que en ese momento disponga."@es .

ns1:ModoOperacion_ValoresReales a ns1:ModoOperacion ;
    rdfs:label "Modo de operación con valores reales (REA)"@es ;
    ns1:identificador "REA" ;
    ns1:textoExtracto "Con valores reales (REA) la salida O5 toma el valor 1 al finalizar el primer scan o ciclo, mientras que necesita 4 ciclos con valores imagen (IMA). [...] El sistema es más rápido trabajando con valores reales (REA)"@es .

ns1:ModoOperacion_VisualizacionCinematica a ns1:ModoOperacion ;
    rdfs:label "Modo visualización de cinemática paralela" ;
    ns1:textoExtracto "Cinemática activa en modo visualización. El CNC actualiza la cota del eje maestro con el desplazamiento realizado por eje aditivo, de manera que el eje maestro siempre muestra la distancia de la herramienta a la pieza." .

ns1:ModoOperacion_Visualizador a ns1:ModoOperacion ;
    rdfs:label "Modo visualizador de eje/cabezal" ;
    ns1:textoExtracto "permite que el eje o cabezal trabaje como visualizador. [...] el CNC no cierra el lazo de posición ni genera error de seguimiento, ya que se igualan la cota real y teórica" .

ns1:ModoOperacion_avanceRapidoAutomatico a ns1:ModoOperacion ;
    rdfs:label "Avance rápido para modo automático"@es ;
    ns1:textoExtracto "2.4.19 Avance rápido para el modo automático. [...] El avance rápido no está disponible para el modo automático."@es .

ns1:ModoSeleccionEjes_807 a ns1:ModoOperacion ;
    rdfs:label "Modo de selección cíclica de ejes"@es ;
    ns1:textoExtracto "Si no hay ningún eje seleccionado, selecciona el primer eje que se está visualizando. Si hay un eje seleccionado, selecciona el siguiente; si el eje seleccionado es el último, vuelve a seleccionar el primero. La selección de ejes se anula al salir del modo volante con el selector de movimientos y tras un reset."@es .

ns1:ModoTrabajo_Administrador a ns1:ModoOperacion ;
    rdfs:label "Modo administrador"@es ;
    ns1:habilitadoPor ns1:OpcionSoftware_SistemaAbierto ;
    ns1:textoExtracto "Modo administrador. El acceso al modo administrador se habilita con el código de validación (opción de software 'Sistema abierto')."@es .

ns1:Modo_GapActivo a ns1:ModoOperacion ;
    rdfs:label "Control del gap activo" ;
    ns1:textoExtracto "control del gap activo" .

ns1:ModuloES_Address1 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo E/S remota (Address=1)" ;
    ns1:identificador "1" ;
    ns1:textoExtracto "módulos de E/S remotas (Address=1,3,4)" .

ns1:ModuloES_Address3 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo E/S remota (Address=3)" ;
    ns1:identificador "3" ;
    ns1:textoExtracto "módulos de E/S remotas (Address=1,3,4)" .

ns1:ModuloES_Address4 a ns1:ComponenteElectrico ;
    rdfs:label "Módulo E/S remota (Address=4)" ;
    ns1:identificador "4" ;
    ns1:textoExtracto "módulos de E/S remotas (Address=1,3,4)" .

ns1:ModuloEjecucionPeriodica_PE a ns1:Sistema ;
    rdfs:label "Módulo de ejecución periódica (PE)"@es ;
    ns1:identificador "PE" ;
    ns1:textoExtracto "Módulo de ejecución periódica. [...] El módulo periódico comienza con la proposición directiva PE y termina con la proposición directiva END. El PLC ejecuta el módulo periódico de forma periódica, con la frecuencia fijada en la directiva PE."@es .

