ns1:EsquemaVi_etasCombinaciones a ns1:Esquema ;
    ns1:detalladoEnEsquema ns1:Vi_etasCombinacionesA_B ;
    ns1:ilustradoEn ns1:FiguraVi_etasCombinaciones ;
    ns1:textoExtracto "Dos conjuntos de viñetas para las combinaciones A-B y A-C: cotas TDATA1…TDATA6 para separar nariz, ejes de rotación y referencia máquina, más TDATA13…TDATA15 para colocación del cabezal. Incluye croquis de inversión del sentido de giro (TDATA11=0/1)." .

ns1:Esquema_EncoderLineal a ns1:Esquema ;
    rdfs:label "Esquema de encoder lineal con referencia codificada" ;
