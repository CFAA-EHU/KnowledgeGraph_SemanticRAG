    ns1:textoExtracto "Entradas analógicas en corriente (mA). | Microamperios."@es ;
    ns1:valor "Microamperios"@es .

ns1:Parametro_EntradaPt100 a ns1:Parametro ;
    rdfs:label "Entradas para sondas de temperatura Pt100"@es ;
    ns1:documentadoEn ns1:Tabla_1366_UnidadesRecursosEtherCAT ;
    ns1:textoExtracto "Entradas para sondas de temperatura Pt100. | Décimas de grado."@es ;
    ns1:valor "Décimas de grado"@es .

ns1:Parametro_ErrorSeguimiento a ns1:Parametro ;
    rdfs:label "Error de seguimiento (ε)"@es ;
    ns1:textoExtracto "minimizando el error de seguimiento \"\" en los arranques, frenadas y cambios de sentido"@es .

ns1:Parametro_EstadoDMC a ns1:Parametro ;
    rdfs:label "Estado del DMC (ON/OFF)"@es ;
    ns1:monitoreaParametro ns1:InterfazUsuario_DMC_ModoAutomatico ;
    ns1:textoExtracto "A Estado del DMC; ON/OFF."@es .

ns1:Parametro_EtherCATBus a ns1:Parametro ;
