    ns1:textoExtracto "El eje se desplaza en el sentido indicado por el parámetro REFDIREC..."@es,
        "REFDIREC | Sentido del movimiento para la búsqueda de referencia."@es .

ns1:Parametro_REFFEED1_1097 a ns1:Parametro ;
    rdfs:label "REFFEED1" ;
