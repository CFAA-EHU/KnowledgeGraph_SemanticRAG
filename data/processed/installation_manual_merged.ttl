    ns1:textoExtracto "Doble diagrama circular comparando origen RTCP en la mesa: aplicación respecto a cero máquina (C=0°) frente a cero pieza (C'=0°)" .

ns1:Sistema_ReferenciadoEjesGantry a ns1:Sistema ;
    rdfs:label "Sistema de referencia de ejes gantry" ;
    ns1:compuestoPor ns1:Marca_DIFFCOMP,
        ns1:Marca_SERVOxnON,
        ns1:Parametro_DIFFCOMP,
        ns1:Parametro_REFFEED1,
        ns1:Parametro_REFFEED2 ;
    ns1:textoExtracto "búsqueda de referencia máquina (ejes gantry)",
        "el CNC envía al regulador la orden de referenciar el eje maestro. En este caso es el eje esclavo el que sigue al eje maestro",
        "el CNC vigila que el incremento de la cota real se corresponda como máximo al avance de búsqueda de referencia (parámetro REFFEED1)" .

ns1:Sistema_RegulacionEjes a ns1:Sistema ;
    rdfs:label "Sistema de regulación de ejes (CNC)",
        "Sistema de regulación de ejes (analógico, Sercos y simulado)"@es ;
    ns1:monitoreaParametro ns1:AXDELAY,
        ns1:Parametro_AXISCH,
        ns1:Parametro_INPOSW,
        ns1:Parametro_LOOPCH ;
    ns1:textoExtracto "El CNC también tiene en cuenta este retardo en el calculo del tiempo de anticipación (marca ADVINPOS), en el repaso de roscas y en el cálculo de la distancia de frenado del palpador.",
        "El parámetro AXDELAY es una estimación del retardo del regulador a la hora de aplicar la consigna enviada por el CNC. El CNC utiliza este parámetro para compensar la diferencia de retardo entre los ejes de un canal, de manera que la consigna llegue a todos los ejes de forma simultánea y el movimiento de los ejes comience y finalice a la vez.",
        "Parámetro válido para regulador analógico, Sercos y simulado."@es ;
    ns1:tieneComponente ns1:Parametro_AXISCH,
        ns1:Parametro_INPOSW,
        ns1:Parametro_LOOPCH .

