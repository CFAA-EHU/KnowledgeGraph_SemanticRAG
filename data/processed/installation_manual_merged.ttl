    rdfs:label "Módulos MDP disponibles"@es ;
    ns1:ilustradoEn ns1:InterfazUsuario_ConfiguradorTopologiaBus ;
    ns1:textoExtracto "En la pestaña \"MDP modules\" está la lista de módulos disponibles para la cabecera seleccionada."@es .

ns1:Sistema_ModulosOP_PANEL_H_E a ns1:Sistema ;
    rdfs:label "Módulos OP-PANEL-H/E" ;
