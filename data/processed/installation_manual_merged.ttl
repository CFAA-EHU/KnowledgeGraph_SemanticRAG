ns1:Parametro_G00COMP a ns1:Parametro ;
    rdfs:label "G00COMP" ;
    ns1:identificador "G00COMP" ;
    ns1:textoExtracto "G00COMP Aplicar compensación de radio en G00. Valores posibles: Sí / No. Valor por defecto: Sí (fresadora y torno) / No (láser). Variable asociada: (V.)[ch].MPG.G00COMP Este parámetro indica si el CNC aplica o no compensación de radio en los movimientos en G00.",
        "los movimientos en G00 no aplican la compensación de radio. Ésto se corrige en versiones posteriores mediante el parámetro G00COMP.",
        "posteriores mediante el parámetro G00COMP. Versión V5.40." ;
    ns1:valor "Sí (fresadora y torno) / No (láser)" .

