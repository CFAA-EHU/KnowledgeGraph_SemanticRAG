ns1:Marca_DINDISTC3 a ns1:Parametro ;
    rdfs:label "DINDISTC3" ;
    ns1:textoExtracto "El CNC dispone de tres marcas para cada canal. Los mnemónicos para cada canal son los siguientes. DINDISTC3C1 DINDISTC3C2 DINDISTC3C4 [...] Estas marcas están asociadas a la distribución dinámica del mecanizado entre canales." .

ns1:Marca_DRENA a ns1:ComponenteElectrico ;
    rdfs:label "DRENA" ;
    ns1:textoExtracto "activar su marca [...] DRENA" .

ns1:Marca_ENABLE a ns1:ComponenteElectrico ;
    rdfs:label "ENABLE" ;
    ns1:textoExtracto "vigila qué marca ENABLE se activa" .

ns1:Marca_INPOSI a ns1:Parametro ;
    rdfs:label "INPOSI" ;
    ns1:identificador "INPOSI" ;
    ns1:textoExtracto "La marca INTEREND puede utilizarse para activar mecanismos antes de llegar los ejes a posición. También puede utilizarse la marca ADVINPOS. [...] El canal del CNC pone la marca INPOSI a (=1) para indicar que todos sus ejes y cabezales activos han llegado a posición, exceptuando los ejes independientes programados desde el PLC.",
        "Hay una marca INPOS(axis) para cada eje y cabezal, y una marca INPOSI general para el canal que indica si todos sus ejes y cabezales activos han llegado a posición, exceptuando los ejes independientes programados desde el PLC. Ver en la página 410."@es ;
    ns1:valor "0",
        "1" .

ns1:Marca_MZTOSPDL a ns1:Alarma,
        ns1:Parametro ;
    rdfs:label "MZTOSPDL",
        "Marca MZTOSPDL",
        "Marca de finalización: herramienta activa asumida"@es ;
    ns1:documentadoEn ns1:Tabla_ComunicacionPLC_Gestor ;
    ns1:identificador "MZTOSPDL" ;
    ns1:monitoreaParametro ns1:SistemaComunicacionPLC_Gestor ;
    ns1:textoExtracto "La herramienta se ha llevado del almacén al cabezal.",
        "MZTOSPDL (Almacén 1-4: MZTOSPDLMZ1, MZTOSPDLMZ2, MZTOSPDLMZ3, MZTOSPDLMZ4)"@es,
        "Utilizar con almacén síncrono (sin brazo). El PLC debe poner esta marca a (=1) tras llevar la herramienta del almacén al cabezal."@es,
        "activar la marca MZTOSPDL"@es ;
    ns1:valor "1" .

ns1:Marca_PROBE1ENA a ns1:Parametro,
        ns1:Sensor ;
    rdfs:label "Marca PROBE1ENA",
        "PROBE1ENA" ;
    ns1:identificador "PROBE1ENA" ;
    ns1:monitoreaParametro ns1:Subrutina_Sub_Probe_Piece_Begin ;
    ns1:textoExtracto "Gestión de las marcas PROBE1ENA/PROBE2ENA en la subrutina",
        "PROBE1ENA [...] Marcas activas por defecto. Estas marcas indican que el palpador está habilitado",
        "indican que el palpador está habilitado",
        "marcas PROBE1ENA/PROBE2ENA en la subrutina. Estas marcas indican que el palpador está habilitado" ;
    ns1:valor "activa" .

ns1:Marca_PROBE1MONIT a ns1:Parametro,
        ns1:Sensor ;
    rdfs:label "Marca PROBE1MONIT",
        "PROBE1MONIT" ;
    ns1:identificador "PROBE1MONIT" ;
    ns1:monitoreaParametro ns1:ModoSeguroPalpador,
        ns1:Subrutina_Sub_Probe_Piece_Begin ;
    ns1:textoExtracto "Gestión de las marcas PROBE1MONIT/PROBE2MONIT en la subrutina",
        "Gestión de las marcas PROBE1MONIT/PROBE2MONIT en la subrutina. Estas marcas están asociadas al modo seguro del palpador.",
        "PROBE1MONIT [...] Estas marcas están asociadas al modo seguro del palpador. Si la marca está activa, el palpador está en modo seguro monitorizando colisiones",
        "asociadas al modo seguro del palpador",
        "marcas PROBE1MONIT/PROBE2MONIT en la subrutina. Estas marcas están asociadas al modo seguro del palpador" ;
    ns1:valor "modo_seguro" .

ns1:Marca_PROBE2ENA a ns1:Parametro,
