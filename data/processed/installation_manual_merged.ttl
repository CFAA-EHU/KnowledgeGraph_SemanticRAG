    ns1:identificador "V.[ch].MPG.GROUPID" ;
    ns1:textoExtracto "Grupo al que pertenece el canal. Valores posibles: De 0 a 2. Valor por defecto: 0 (no pertenece a ningún grupo). Variable asociada: (V.)[ch].MPG.GROUPID" ;
    ns1:valor "0-2" .

