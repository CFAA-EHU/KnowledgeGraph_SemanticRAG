    ns1:identificador "MULTIAXIS | GROUP_1" ;
    ns1:ilustradoEn ns1:SistemaMultieje_1093 ;
    ns1:textoExtracto "Sercos CAN Configuración del grupo multieje. | MULTIAXIS | GROUP_1 | [...] A1 A2 Configuración de los ejes. | DRIVEID | OPMODEP FBACK | SRC COUNTERTYPE | COUNTERID | Eje A1 | 1 | Velocidad Externa Regulador | 1 | Eje A2 | 1 | Velocidad Externa Remoto | 1"@es .

ns1:EsquemaJOGKEYS a ns1:Esquema ;
    rdfs:label "Esquema de teclas de usuario (JOGKEYS)" ;
    ns1:textoExtracto "banda de teclas numeradas (1, 2, …, 15, 16) bajo la leyenda 'JOGKEYS'." .

ns1:EsquemaModelizadoMaquina a ns1:Esquema ;
    rdfs:label "Esquema modelizado de la máquina (archivo xca)"@es ;
    ns1:identificador "xca" ;
    ns1:textoExtracto "debe estar cargado el esquema modelizado de la máquina (archivo xca)"@es .

ns1:EsquemaPaso4_CompensacionVolumetrica a ns1:Esquema ;
    rdfs:label "Esquema 3D (Paso 4) que inicia el segundo nivel Z(P2)"@es ;
    ns1:identificador "Paso 4" ;
    ns1:textoExtracto "Esquema 3D (Paso 4) que inicia el segundo nivel Z(P2): desde X(P1), Y(P1), Z(P2) se repite el barrido en X e Y. Flechas y etiquetas Z(P2) señalan el cambio de cota y la replicación del patrón del primer plano."@es .

ns1:EsquemaPaso6_CompensacionVolumetrica a ns1:Esquema ;
    rdfs:label "Esquema 3D (Paso 6) del volumen totalmente relleno hasta Z(Pn)"@es ;
    ns1:identificador "Paso 6" ;
    ns1:textoExtracto "Esquema 3D (Paso 6) del volumen totalmente relleno hasta Z(Pn). Se observan todas las capas Z apiladas, el patrón de serpenteo por planos y la malla completa que sustenta la interpolación de errores dentro del volumen."@es .

ns1:EsquemaPrecargaTandem a ns1:Esquema ;
    rdfs:label "Esquema de precarga en tándem (efecto de la precarga)"@es ;
    ns1:ilustradoEn ns1:Pagina_575,
        ns1:Pagina_576 ;
    ns1:textoExtracto "Esquema lateral de dos trenes motor–reductor–piñón contra cremallera inmóviles; vectores opuestos de par en maestro y esclavo visualizan una tracción previa que elimina holguras cuando el sistema está parado. [...] Gráfico similar al anterior, pero con precarga dominante sobre la fricción"@es .

ns1:EsquemaTecladoJog a ns1:Esquema ;
    rdfs:label "Esquema de teclado jog con teclas 1-15" ;
    ns1:textoExtracto "Ilustración del teclado de jog con distribución de teclas numeradas (1–15) y ejemplo de mapeo de funciones para ejes y sentidos de desplazamiento (p. ej., X+, 7+)." .

ns1:Esquema_17.1_TDATA5_SegundaPalpacion a ns1:Esquema ;
    ns1:identificador "17.1 - TDATA5 (Segunda palpación)" ;
    ns1:ilustradoEn ns1:Pagina_708 ;
    ns1:textoExtracto "Diagrama 'Segunda palpación': B=0°, C=180°, contacto sobre misma cara con lectura ΔX, resaltando el giro alrededor de 2 y el desplazamiento resultante." .

ns1:Esquema_17.1_TDATA5_Solucion a ns1:Esquema ;
    ns1:identificador "17.1 - TDATA5 (Solución)" ;
    ns1:ilustradoEn ns1:Pagina_709 ;
    ns1:textoExtracto "Esquema de solución con marcadores de B/C y anotación TDATA5 = 0,5·|ΔX|; la figura asocia gráficamente la variación de lectura con el desfase geométrico del eje herramienta." .

ns1:Esquema_17_2_UsoRelojComparador a ns1:Esquema ;
    rdfs:label "Ilustración del uso correcto e incorrecto del reloj comparador"@es ;
    ns1:detalladoEnEsquema ns1:ComponenteMecanico_CilindroPatron,
        ns1:Herramienta_RelojComparador ;
    ns1:ilustradoEn ns1:Pagina_712 ;
    ns1:textoExtracto "Ilustración del uso correcto del reloj comparador sobre un cilindro: palpado tangencial en la línea exterior del cilindro con el palpador lo más perpendicular posible a la tangente. Dos esquemas con marcas de error (cruz) que ejemplifican colocaciones incorrectas del reloj comparador sobre el cilindro, indicando direccionalidad y geometría de contacto que producen errores al asignar el radio."@es .

ns1:Esquema_AccionesExportacion_OpenPCS a ns1:Esquema ;
    rdfs:label "Acciones de exportación en OpenPCS Remoto"@es ;
    ns1:documentadoEn ns1:Pagina_762 ;
    ns1:ilustradoEn ns1:InterfazUsuario_OpenPCSRemoto_21_21 ;
    ns1:textoExtracto "Tres acciones ilustradas en capturas: (a) 'Export router file' para generar el XML de rutado, (b) 'Generate project' para guardar proyecto *.fem, (c) renombrar y copiar 'resourceRouterConf.xml' a ../Mtb/Data del CNC."@es .

ns1:Esquema_BloquesFeedForward a ns1:Esquema ;
    rdfs:label "Esquema de bloques de feed-forward" ;
    ns1:ilustradoEn ns1:Figura_OscilogramaAjusteCorrecto,
        ns1:Figura_OscilogramaAjusteIncorrecto,
        ns1:Figura_PanelAjusteACForward ;
    ns1:textoExtracto "esquema de bloques de feed-forward: \"Programmed Feedrate\" alimenta un bloque \"FFGAIN\"" .

ns1:Esquema_CaptacionDirecta_CounterTypeLocal a ns1:Esquema ;
    rdfs:label "Esquema: COUNTERTYPE = Local (captación en unidad central)"@es ;
    ns1:ilustradoEn ns1:Pagina_587 ;
    ns1:textoExtracto "Esquema donde la captación directa entra en las entradas locales de contaje de la unidad central; se muestran puntos de conexión y el flujo de datos hacia el CNC sin regulador intermedio."@es .

ns1:Esquema_CinematicaCabezalTipo50 a ns1:Esquema ;
    rdfs:label "Definición vectorial de cinemáticas de cabezal (tipo 50)" ;
    ns1:detalladoEnEsquema ns1:Parametro_TDATA10,
        ns1:Parametro_TDATA2,
        ns1:Parametro_TDATA4 ;
    ns1:textoExtracto "Conjunto de diagramas: pictogramas de cabezales (esférico, ortogonal, angular) y tres vistas con vectores T1/T2/T3 (traslación) y V1/V2/V3 (dirección). Ejes X-Y-Z, flechas, y etiquetas TDATA1–26 indican componentes, posiciones de reposo y sentidos." .

ns1:Esquema_Cinematica_TYPE13_24 a ns1:Esquema ;
    rdfs:label "Cinemáticas TYPE=13–24 (combinaciones 3 ejes rotativos)" ;
    ns1:textoExtracto "Viñetas TYPE=13…24 con combinaciones cabeza-mesa de tres ejes rotativos (ABA, ACA, etc.)." .

ns1:Esquema_Cinematica_TYPE1_12 a ns1:Esquema ;
    rdfs:label "Cinemáticas TYPE=1–12 (cabezal ortogonal y mesas rotativas)" ;
    ns1:textoExtracto "12 mini-ilustraciones etiquetadas TYPE=1…12 que representan configuraciones de cinemática de cabezal y mesa (p. ej., cabezal ortogonal XY/ZX, mesa rotativa AB/AC/BA/BC)." .

ns1:Esquema_Cinematica_TYPE41_52 a ns1:Esquema ;
    rdfs:label "Cinemáticas TYPE=41–52 (modos eje C y vectoriales)" ;
    ns1:textoExtracto "Modos de eje C (TYPE=41–43) y definiciones vectoriales (TYPE=50–52)." .

ns1:Esquema_CompensacionDispersionLaserCO2 a ns1:Esquema ;
    rdfs:label "Diagrama de compensación con eje esclavo (SLAVE) y trayectorias del rayo láser"@es ;
    ns1:ilustradoEn ns1:Pagina_105 ;
    ns1:textoExtracto "Diagrama de compensación con eje esclavo (SLAVE) y trayectorias del rayo láser. Muestra triedro X-Y y el efecto del seguimiento (#FOLLOW): líneas sólidas y discontinuas marcan el recorrido óptico y el desplazamiento del eje esclavo para mantener constante la longitud del haz, minimizando variaciones en el punto de corte."@es .

ns1:Esquema_CompensacionVolumetrica a ns1:Esquema ;
    rdfs:label "Esquema de compensación volumétrica"@es ;
    ns1:textoExtracto "Ilustración isométrica de un centro de mecanizado con un volumen cúbico transparente sobre la mesa que contiene una nube de puntos azules."@es .

ns1:Esquema_ConexionSensorGap_CAN a ns1:Esquema ;
    rdfs:label "Diagrama de conexión del sensor de gap (módulos CAN RIOR)" ;
    ns1:detalladoEnEsquema ns1:Sensor_GapLaser ;
    ns1:textoExtracto "Diagrama de conexión del sensor de gap a una entrada analógica en módulos remotos CAN (RIOR). Se identifican pines AI1+/AI1− y la cadena 'CNC – RIOR – CAN – GAP SENSOR', mostrando alternativa de cableado cuando no se usa el regulador." .

ns1:Esquema_ConexionSensorGap_Sercos a ns1:Esquema ;
    rdfs:label "Diagrama eléctrico de conexión del sensor de gap (Sercos)" ;
    ns1:detalladoEnEsquema ns1:Sensor_GapLaser ;
    ns1:textoExtracto "Diagrama eléctrico de conexión del sensor de gap a una entrada analógica del regulador Sercos. Representa bornes X7 (AI1+/AI1−), señal analógica ± y bloques 'CNC', 'DRIVE' y 'SERCOS', con flechas de señal entre módulos." .

ns1:Esquema_ConfiguracionPlano a ns1:Esquema ;
    rdfs:label "Esquema de configuración de ejes en plano"@es ;
    ns1:textoExtracto "Configuración de ejes tipo 'plano'."@es .

ns1:Esquema_ConfiguracionTriedro a ns1:Esquema ;
    rdfs:label "Esquema de configuración de ejes en triedro (XYZ)"@es ;
    ns1:textoExtracto "Configuración de ejes tipo 'triedro'. Y+ X+ Z+ Esta configuración dispone de tres ejes formando un triedro cartesiano tipo XYZ como en una fresadora."@es .

ns1:Esquema_ControlGapLaser a ns1:Esquema ;
    rdfs:label "Esquema de control de gap láser" ;
    ns1:textoExtracto "Esquema del control de gap con boquilla láser, superficie de pieza y eje asociado (X/Z según máquina). Muestra el sensor manteniendo una distancia fija (gap) y la compensación en el eje longitudinal para seguir irregularidades; incluye rótulos 'LASER', 'GAP' y 'Workpiece surface'." .

ns1:Esquema_CoordenadasPiezaMaquina a ns1:Esquema ;
    rdfs:label "Esquema de coordenadas pieza (X'-Y'-Z') y máquina (X-Y-Z) con orientación B-30°"@es ;
    ns1:textoExtracto "Esquemas de RTCP con pieza girando alrededor de B y dos escenarios del sistema de coordenadas pieza (TDATA31=0/1) [...] X', Z' y la orientación B-30°"@es .

ns1:Esquema_CoordenadasRTCP a ns1:Esquema ;
    rdfs:label "Esquema de sistemas de coordenadas (Z' X' con RTCP)" ;
    ns1:ilustradoEn ns1:Tabla_DefinicionCinematicas ;
    ns1:textoExtracto "Z' X' Z' X' #RTCP ON B-30 B TDATA16 = 0 TDATA16 = 1" .

ns1:Esquema_GestionMultieje_UnMotorDosEjes a ns1:Esquema ;
    rdfs:label "Esquema: Grupo multieje con un motor y dos ejes (A1, A2)"@es ;
    ns1:ilustradoEn ns1:Pagina_584 ;
    ns1:textoExtracto "Diagrama donde un solo motor, mediante acoplamientos, gobierna alternativamente dos ejes (A1 y A2) seleccionados por el regulador; se muestra la captura directa y la arquitectura CAN entre módulos."@es .

ns1:Esquema_Interconexion_Sercos_RCS_S_AXD a ns1:Esquema ;
    rdfs:label "Esquema de interconexión Sercos con RCS-S y AXD" ;
    ns1:identificador "15.5.1_Ejemplo_Interconexion_Sercos" ;
    ns1:textoExtracto "Esquema de interconexión del sistema Sercos con dos contadoras RCS-S (nodos 3 y 5) y tres reguladores AXD (nodos 1, 2 y 4). Se muestran bloques para ejes analógicos (X, Y, Z), ejes Sercos (U, V), un volante y un cabezal S, con líneas que conectan salidas analógicas (ANAOUT) y entradas de captación (E21A/B/C). Las etiquetas de nodo y de conector (p. ej., E21A/ANAOUT2) guían la asignación física y lógica." .

ns1:Esquema_JogKeys_Ejemplo5 a ns1:Esquema ;
    rdfs:label "Esquema de teclas Jog (Ejemplo 5)" ;
    ns1:textoExtracto "Gráfico de disposición de teclas de eje (X, Y, 4, 5) y sentido (+, −) con tecla R" .

ns1:Esquema_JogKeys_USERKEYS a ns1:Esquema ;
    rdfs:label "Esquema híbrido JogKeys + USERKEYS (Ejemplo 6)" ;
    ns1:textoExtracto "Diagrama mixto con bloque 'JOGKEYS' (X+, Y+, R, X−, Y−) y bloque 'USERKEYS' (4, 5, +, −)" .

ns1:Esquema_ManoEjesGiro a ns1:Esquema ;
    rdfs:label "Esquema de mano y ejes para sentido de giro (RTCP vs. cero máquina/pieza)"@es ;
    ns1:textoExtracto "Ilustración de mano y ejes para sentido de giro [...] origen RTCP respecto a cero máquina (C=0°) frente a cero pieza (C'=0°)"@es .

ns1:Esquema_MesaRotativa a ns1:Esquema ;
    rdfs:label "Esquema de mesa rotativa con cotas y palpado" ;
    ns1:ilustradoEn ns1:Tabla_17_3_CalculoParametros ;
    ns1:textoExtracto "Según el cuadro sombreado del dibujo. E = 0,5·(ΔX + ΔZ +2R+r)" .

ns1:Esquema_OverlappedNo_Error a ns1:Esquema ;
    rdfs:label "Caso 'Overlapped = No' en mapeo EtherCAT"@es ;
    ns1:documentadoEn ns1:Pagina_756 ;
    ns1:ilustradoEn ns1:AvisoSeguridad_Solapamiento_I33 ;
    ns1:textoExtracto "Caso 'Overlapped = No': al duplicar numeración, el programa muestra un diálogo de error sobre el bloque implicado; se identifica la entrada I33 con icono de advertencia, impidiendo el solapamiento."@es .

ns1:Esquema_OverlappedRight_Demo a ns1:Esquema ;
    rdfs:label "Demostración 'Overlapped = Right' en mapeo EtherCAT"@es ;
    ns1:documentadoEn ns1:Pagina_755 ;
    ns1:textoExtracto "Demostración 'Overlapped = Right': al asignar un número ya existente, el mapeador reordena automáticamente los recursos posteriores (numeración superior), respetando los anteriores. La captura incluye bloques desplazados y avisos gráficos que señalan el solapamiento."@es .

ns1:Esquema_ParametrosEje a ns1:Esquema ;
    ns1:ilustradoEn ns1:Tabla_ConfiguracionSalidasAnalogicas ;
    ns1:textoExtracto "Parámetros máquina para configuración de salidas analógicas por eje." .

ns1:Esquema_PlanosTrabajo_G17_G18_G19 a ns1:Esquema ;
    rdfs:label "Esquema de planos de trabajo asociados a funciones G17, G18 y G19"@es ;
    ns1:textoExtracto "En cada ejemplo también se muestra el plano de trabajo asociado a las funciones G17, G18 y G19."@es .

ns1:Esquema_Precarga_Aceleracion a ns1:Esquema ;
    rdfs:label "Precarga con aceleración" ;
    ns1:textoExtracto "Precarga con aceleración." .

ns1:Esquema_Precarga_Deceleracion a ns1:Esquema ;
    rdfs:label "Precarga con deceleración" ;
    ns1:textoExtracto "Precarga con deceleración." .

