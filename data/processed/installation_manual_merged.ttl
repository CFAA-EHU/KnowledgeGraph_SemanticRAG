        ns1:Funcion_G18,
        ns1:Funcion_G19 ;
    ns1:textoExtracto "Configuración geométrica de los ejes del canal. Valores posibles: Plano / Triedro. Valor por defecto: Triedro. Variable asociada: (V.)[ch].MPG.GEOCONFIG"@es,
        "En los ejemplos de torno está indicado el valor del parámetro máquina GEOCONFIG, ya que en función de este parámetro cambia el comportamiento de las funciones asociadas a los planos de trabajo."@es ;
    ns1:valor "Triedro" .

ns1:Parametro_GRAPHTYPE a ns1:Parametro ;
    rdfs:label "GRAPHTYPE" ;
    ns1:identificador "GRAPHTYPE" ;
    ns1:textoExtracto "GRAPHTYPE Lista de gráficos en cada canal. En el modelo torno, este parámetro muestra la tabla para definir la configuración de los gráficos en cada canal." .

ns1:Parametro_GROUND a ns1:Parametro ;
    rdfs:label "GROUND" ;
    ns1:identificador "TM.MZGROUND[mz]" ;
    ns1:textoExtracto "GROUND Se permiten herramientas de tierra (carga manual). Valores posibles: Sí / No. Valor por defecto: No. Variable asociada: (V.)TM.MZGROUND[mz] Se denominan herramientas de tierra a las que no están situadas en el almacén." ;
    ns1:valor "No" .

ns1:Parametro_G_ANAI a ns1:Parametro ;
    rdfs:label "G.ANAI[n]" ;
    ns1:documentadoEn ns1:Tabla_VariablesCNC_15_6_1 ;
    ns1:monitoreaParametro ns1:Sensor_EntradaAnalogica ;
    ns1:textoExtracto "(V.)G.ANAI[n] | R | Tensión en voltios de la entrada analógica [n] o temperatura en décimas de grado si es una sonda de temperatura PT100. Unidades: Voltios / décimas de grado."@es ;
    ns1:valor "R (solo lectura)" .

ns1:Parametro_G_ANAO a ns1:Parametro ;
    rdfs:label "G.ANAO[n]" ;
    ns1:controla ns1:Actuador_SalidaAnalogica ;
    ns1:documentadoEn ns1:Tabla_VariablesCNC_15_6_1 ;
    ns1:textoExtracto "(V.)G.ANAO[n] | R/W | Tensión en voltios de la salida [n]. Unidades: Voltios."@es ;
    ns1:valor "R/W (lectura/escritura)" .

ns1:Parametro_G_AXLIMC a ns1:Parametro ;
    rdfs:label "Variable (V.)[ch].G.AXLIMC" ;
    ns1:documentadoEn ns1:Tabla_13_3_4_VariablesLimitacionAvance ;
    ns1:identificador "G.AXLIMC" ;
    ns1:textoExtracto "Número lógico del eje que limita el avance en la esquina, en el bloque en ejecución. Junto a la variable V.G.PARLIMC permite evaluar el comportamiento del mecanizado en una esquina determinada, en el que el avance baja en exceso o es un avance irregular." .

ns1:Parametro_G_AXLIMF a ns1:Parametro ;
    rdfs:label "Variable (V.)[ch].G.AXLIMF" ;
    ns1:documentadoEn ns1:Tabla_13_3_4_VariablesLimitacionAvance ;
    ns1:identificador "G.AXLIMF" ;
    ns1:textoExtracto "Número lógico del eje que limita el avance, en el bloque en ejecución. Junto a la variable V.G.PARLIMF permite evaluar el comportamiento del mecanizado en un tramo determinado, en el que el avance baja en exceso o es un avance irregular." .

ns1:Parametro_G_CNCFRO a ns1:Parametro ;
    rdfs:label "Porcentaje de avance (feed override) seleccionado en el conmutador del panel de mando"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables_18_2_3 ;
    ns1:textoExtracto "(V.)[ch].G.CNCFRO - Porcentaje de avance (feed override) seleccionado en el conmutador del panel de mando. Unidades: Porcentaje."@es ;
    ns1:valor "Porcentaje" .

ns1:Parametro_G_FRO a ns1:Parametro ;
    rdfs:label "Porcentaje de avance (feed override) activo"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables_18_2_3 ;
    ns1:textoExtracto "(V.)[ch].G.FRO - Porcentaje de avance (feed override) activo. Unidades: Porcentaje."@es ;
    ns1:valor "Porcentaje" .

ns1:Parametro_G_NCUTTERS a ns1:Parametro ;
    rdfs:label "Herramienta en preparación. Número de dientes"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables_18_2_3 ;
    ns1:textoExtracto "(V.)[ch].G.NCUTTERS - Herramienta en preparación. Número de dientes. Unidades: Dientes."@es ;
    ns1:valor "Dientes" .

ns1:Parametro_G_PARLIMF a ns1:Parametro ;
    rdfs:label "Variable (V.)[ch].G.PARLIMF" ;
    ns1:documentadoEn ns1:Tabla_13_3_4_VariablesLimitacionAvance ;
    ns1:identificador "G.PARLIMF" ;
    ns1:textoExtracto "Causa que limita el avance en el bloque en ejecución. La variable devuelve uno de los siguientes valores. [1] El avance máximo del eje. [2] La aceleración debida a la curvatura (parámetro CURVACC). [3] El jerk debido a la curvatura (parámetro CURVJERK). [6] El error que comete el spline. [7] Espacio insuficiente por bloques muy pequeños y/o buffer lleno. [10] Máximo avance del eje en transformaciones. [11] Máxima aceleración del eje en transformaciones." .

ns1:Parametro_G_PRGFRO a ns1:Parametro ;
    rdfs:label "Porcentaje de avance (feed override) definido por programa"@es ;
    ns1:documentadoEn ns1:Tabla_ResumenVariables_18_2_3 ;
    ns1:textoExtracto "(V.)[ch].G.PRGFRO - Porcentaje de avance (feed override) definido por programa. Unidades: Porcentaje."@es ;
    ns1:valor "Porcentaje" .

