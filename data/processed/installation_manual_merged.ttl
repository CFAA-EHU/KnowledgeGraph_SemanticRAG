        ns1:RegistroR101,
        ns1:RegistroR102,
        ns1:RegistroR103 ;
    ns1:textoExtracto "Ejemplo de maniobra del PLC. La máquina dispone de un pulsador para activar y desactivar el volante de avance (entrada I71) y el control del avance se efectúa con el segundo volante." ;
    ns1:tieneComponente ns1:PulsadorVolanteAvance_I71,
        ns1:VolanteAvance .

